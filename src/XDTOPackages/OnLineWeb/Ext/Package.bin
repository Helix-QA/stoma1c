<package xmlns="http://v8.1c.ru/8.1/xdto" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://reservi.ru">
	<objectType name="Appointment" ordered="false" sequenced="true">
		<property name="ID" type="xs:string" nillable="true"/>
		<property name="XML_ID" type="xs:string" nillable="true"/>
		<property name="ACTIVE" type="xs:boolean" nillable="true"/>
		<property name="_unit" type="xs:string" nillable="true"/>
		<property name="_client_name" type="xs:string" nillable="true"/>
		<property name="_client_phone" type="xs:string" nillable="true"/>
		<property name="_client_email" type="xs:string" nillable="true"/>
		<property name="_brand" type="xs:string" nillable="true"/>
		<property xmlns:d3p1="http://reservi.ru" name="_services" type="d3p1:AppointmentServiceList" nillable="true"/>
		<property name="_sourcerecord" type="xs:string" nillable="true"/>
		<property name="_comments" type="xs:string" nillable="true"/>
		<property name="_rate" type="xs:integer" nillable="true"/>
		<property name="_status" type="xs:string" nillable="true"/>
	</objectType>
	<objectType name="AppointmentServiceList">
		<property xmlns:d3p1="http://reservi.ru" name="list" type="d3p1:AppointmentServiceStruct" lowerBound="0" upperBound="-1" nillable="true"/>
	</objectType>
	<objectType name="AppointmentServiceStruct">
		<property name="ACTIVE_FROM" type="xs:dateTime" nillable="true"/>
		<property name="ACTIVE_TO" type="xs:dateTime" nillable="true"/>
		<property name="_service" type="xs:string" nillable="true"/>
		<property name="_service_name" type="xs:string" nillable="true"/>
		<property name="_employee" type="xs:string" nillable="true"/>
		<property name="_room" type="xs:string" nillable="true"/>
		<property name="_price" type="xs:float" nillable="true"/>
	</objectType>
	<objectType name="Response" ordered="false" sequenced="true">
		<property name="ID" type="xs:string"/>
		<property name="isError" type="xs:boolean"/>
		<property name="Message" type="xs:string"/>
	</objectType>
</package>