&НаКлиенте
// Функция - Найти открытую форму
//
// Параметры:
//  ИмяФормы	 - 	 - 
//  Заголовок	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НайтиОткрытуюФорму(ИмяФормы, Заголовок)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Открыта", Ложь); 
	
	// Получение всех открытых окон приложения
	ОкнаПриложения = ПолучитьОкна();
	Для Каждого ОкноПриложения Из ОкнаПриложения Цикл
		// Анализ заголовка окна
		Если ОкноПриложения.Заголовок = Заголовок Тогда
			// Получение формы
			НайденнаяФорма = ОкноПриложения.Содержимое[0];
			// Анализ реквизита формы
			Если НайденнаяФорма.ИмяФормы = ИмяФормы Тогда
				ПараметрыФормы.Вставить("Открыта"		, Истина);
				ПараметрыФормы.Вставить("ОкноПриложения", ОкноПриложения); 				
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПараметрыФормы;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, создает новую сделку клиенту.
//
Функция СоздатьСделку(ВидСделки, ОтборСтруктурнаяЕдиница = Неопределено)
			
	НоваяСделка = Справочники.Сделки.СоздатьЭлемент();		
	ПерыйЭтап 	= ПолучитьСтартовыйЭтапВидаСделкиНаСервере(ВидСделки);
	
	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("ВидСделки",          ВидСделки);
	ДанныеЗаполнения.Вставить("ЭтапСделки",         ПерыйЭтап);
	ДанныеЗаполнения.Вставить("ДатаСделки",         ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), ОтборСтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));
	
	НоваяСделка.Заполнить(ДанныеЗаполнения);
	
	Попытка
		
		НоваяСделка.Записать();
		Возврат НоваяСделка.Ссылка;
		
	Исключение		
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Не удалось создать сделку: ';en='Not succeeded create deal:'") + ОписаниеОшибки());	
	КонецПопытки;
		
КонецФункции

