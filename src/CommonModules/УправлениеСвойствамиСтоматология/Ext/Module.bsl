				КнопкаУдаленияНаФорме = Форма.Элементы.Найти("УдалитьЭлементДлительностиПриема"); 
				
				Если НЕ КнопкаУдаленияНаФорме = Неопределено Тогда
					Форма.Элементы.Удалить(КнопкаУдаленияНаФорме);					
				КонецЕсли;
												
				КнопкаЭлементаДлительности = Форма.Элементы.Добавить("УдалитьЭлементДлительностиПриема", Тип("КнопкаФормы"), ?(ВозможностьУдалять, ГруппаВыравниваниеЭлементаДлительности, ГруппаДляРазмещенияДлительностиОбщая)); //);
