		ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.РегистрацияТриггерныхСобытий);					
		Возврат;
	КонецЕсли;
	
	// Если МассивСтруктурныхЕдиниц = Неопределено Тогда 	
	//	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
	//		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
	//		Возврат;
	//	КонецЕсли;
	//	
	//	Попытка
	//		ЧасовойПоясТекущегоСеанса = ЧасовойПоясСеанса();	
	//		ТаблицаЧасовыхПоясов = РегламентныеЗаданияСерверСтоматология.ПолучитьТаблицуЧасовыхПоясовСтруктурныхЕдиниц(ЧасовойПоясТекущегоСеанса);
	//		Для Каждого СтрокаЧасовойПояс Из ТаблицаЧасовыхПоясов Цикл 
	//			// Актуализируем часовой пояс исходя из структурной единицы
	//			Если ЧасовойПоясТекущегоСеанса <> СтрокаЧасовойПояс.ЧасовойПояс Тогда 
	//				УстановитьЧасовойПоясСеанса(СтрокаЧасовойПояс.ЧасовойПояс);
	//				ЧасовойПоясТекущегоСеанса = СтрокаЧасовойПояс.ЧасовойПояс;
