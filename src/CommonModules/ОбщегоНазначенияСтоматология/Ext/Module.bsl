		|	ГДЕ
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей ПОДОБНО &Поиск
		|		И Контрагенты.Родитель.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Ссылка,
		|	ВложенныйЗапрос.Фамилия,
		|	ВложенныйЗапрос.Имя,
		|	ВложенныйЗапрос.Отчество,
		|	ВложенныйЗапрос.Телефон,
		|	ВложенныйЗапрос.ДатаРожденияКлиента,
		|	ВложенныйЗапрос.ТекущаяМедицинскаяКартаКодБезНулей
		|
		|УПОРЯДОЧИТЬ ПО
		|	Индекс,
		|	ВложенныйЗапрос.Фамилия,
		|	ВложенныйЗапрос.Имя,
		|	ВложенныйЗапрос.Отчество";
				
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 20
		|	ВложенныйЗапрос.Ссылка КАК Ссылка,
		|	МИНИМУМ(ВложенныйЗапрос.Индекс) КАК Индекс,
		|	ВложенныйЗапрос.Фамилия КАК Фамилия,
		|	ВложенныйЗапрос.Имя КАК Имя,
		|	ВложенныйЗапрос.Отчество КАК Отчество,
		|	ВложенныйЗапрос.ТекущаяМедицинскаяКартаКод КАК ТекущаяМедицинскаяКартаКод,
		|	ВложенныйЗапрос.ДатаРождения КАК ДатаРождения,
		|	ВложенныйЗапрос.Телефон КАК Телефон
		|ИЗ
		|	(ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка КАК Ссылка,
		|		1 КАК Индекс,
		|		Контрагенты.Фамилия КАК Фамилия,
		|		Контрагенты.Имя КАК Имя,
		|		Контрагенты.Отчество КАК Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей КАК ТекущаяМедицинскаяКартаКод,
		|		Контрагенты.ДатаРожденияКлиента КАК ДатаРождения,
		|		Контрагенты.Телефон КАК Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.Фамилия ПОДОБНО &Поиск
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		2,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.Имя ПОДОБНО &Поиск
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		3,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.Отчество ПОДОБНО &Поиск
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		4,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.Наименование ПОДОБНО &СтрокаПоискаНаименование
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		6,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей ПОДОБНО &Поиск
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Ссылка,
		|	ВложенныйЗапрос.Фамилия,
		|	ВложенныйЗапрос.Имя,
		|	ВложенныйЗапрос.Отчество,
		|	ВложенныйЗапрос.ТекущаяМедицинскаяКартаКод,
		|	ВложенныйЗапрос.ДатаРождения,
		|	ВложенныйЗапрос.Телефон
		|
		|УПОРЯДОЧИТЬ ПО
		|	Индекс,
		|	Фамилия,
		|	Имя,
		|	Отчество";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Поиск"         			, СокрЛ(СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("СтрокаПоискаНаименование", "" + СокрЛ(СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("ТипКонтрагента"			, ТипКонтрагента);
	
	Если ВыводитьВсе = Истина Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 20", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Контрагенты.Ссылка.ПометкаУдаления = ЛОЖЬ", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Контрагенты.ПометкаУдаления = ЛОЖЬ", ""); 	
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если ВернутьВыборкуЗапроса = Истина Тогда
		Возврат Результат;
	КонецЕсли;
	
	СписокКонтрагентов = Новый СписокЗначений;
	
	Если Результат.Количество() > РазмерПорции Тогда		
		СписокКонтрагентов.Добавить(Справочники.Контрагенты.ПустаяСсылка(), "Найдено более " + РазмерПорции + " клиентов, уточните поиск.");		
		Возврат СписокКонтрагентов;
	КонецЕсли;
	
	Пока Результат.Следующий() Цикл
 			
		Представление = "" + Результат.Ссылка + 
						?(ЗначениеЗаполнено(Результат.ДатаРождения), ", " + Формат(Результат.ДатаРождения, "ДФ=dd.MM.yyyy") + 
																	 " (" + ВозвратитьВозрастСтрокой(Результат.ДатаРождения) + ")", "") +
		                ?(ВыводитьНомерТелефона И ЗначениеЗаполнено(Результат.Телефон), ", тел.:" + Результат.Телефон, "") +
						?(ВыводитьНомерМедКарты И ЗначениеЗаполнено(Результат.ТекущаяМедицинскаяКартаКод), "      № " + Результат.ТекущаяМедицинскаяКартаКод, "");
				
		СписокКонтрагентов.Добавить(Результат.Ссылка, Представление);
		
	КонецЦикла;
	
	Если СписокКонтрагентов.Количество() = 0 Тогда 
		
		// Добавляем строку создания нового клиента.
		Если ДобавлятьЭлементСоздания И ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
			СписокКонтрагентов.Добавить("СоздатьНовогоКлиента", "Пациент не найден. Создать нового пациента.");
		КонецЕсли;
		
		// Добавляем строку переноса нового клиента.
		Если ПереноситьЭлементПоиска Тогда
			СписокКонтрагентов.Добавить("ПеренестиИскомогоКлиента", "Клиент не найден. Создать нового клиента позже.");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СписокКонтрагентов;
	
КонецФункции

// Функция, возвращает ставку НДС по умолчанию
//
Функция ПолучитьСтавкуНДС(СтруктурнаяЕдиница = Неопределено) Экспорт
	
	Если СтруктурнаяЕдиница = Неопределено Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Возврат СтруктурнаяЕдиница.Организация.СтавкаНДС;	
	
КонецФункции

// Функция, возвращает ставку НДС для авансов.
//
Функция ПолучитьСтавкуНДСАванс(СтруктурнаяЕдиница = Неопределено) Экспорт
	
	Если СтруктурнаяЕдиница = Неопределено Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Организация			= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "Организация");
	ДанныеОрганизации	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация, "СтавкаНДСДляАвансов, СтавкаНДС");
	
	Возврат ?(ЗначениеЗаполнено(ДанныеОрганизации.СтавкаНДСДляАвансов), ДанныеОрганизации.СтавкаНДСДляАвансов, ДанныеОрганизации.СтавкаНДС);	
	
КонецФункции   

// Функция, возвращает вид налога для авансов.
//
Функция ПолучитьВидНалогаАванс(СтруктурнаяЕдиница = Неопределено) Экспорт
	
	Если СтруктурнаяЕдиница = Неопределено Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Организация			= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "Организация");
	ДанныеОрганизации	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация, "СистемаНалогообложенияДляАвансов, СистемаНалогообложенияДляТоваров");
	
	Возврат ?(ЗначениеЗаполнено(ДанныеОрганизации.СистемаНалогообложенияДляАвансов),
				ДанныеОрганизации.СистемаНалогообложенияДляАвансов, 
				ДанныеОрганизации.СистемаНалогообложенияДляТоваров);	
	
КонецФункции  

// Функция, вернуть текущую структурную единицу
//
Функция ПолучитьТекущуюСтруктурнуюЕдиницу() Экспорт
	
	Возврат ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
КонецФункции

// Функция ПолучитьЗначениеРеквизита возвращает значение
// реквизита, прочитанного из информационной базы по ссылке на объект.
// 
//  Если доступа к реквизиту нет, возникнет исключение прав доступа.
//  Если необходимо зачитать реквизит независимо от прав текущего пользователя,
//  то следует использовать предварительный переход в привилегированный режим.
// 
// Параметры:
//  Ссылка       - ссылка на объект, - элемент справочника, документ, ...
//  ИмяРеквизита - Строка, например, "Код".
// 
// Возвращаемое значение:
//  Произвольный    - зависит от типа значения прочитанного реквизита.
// 
Функция ПолучитьЗначениеРеквизита(Ссылка, ИмяРеквизита) Экспорт
	
	Результат = ПолучитьЗначенияРеквизитов(Ссылка, ИмяРеквизита);
	Возврат Результат[ИмяРеквизита];
	
КонецФункции 

// Функция ПолучитьЗначенияРеквизитов возвращает структуру,
// содержащую значения реквизитов прочитанные из информационной базы
// по ссылке на объект.
// 
//  Если доступа к одному из реквизитов нет, возникнет исключение прав доступа.
//  Если необходимо зачитать реквизит независимо от прав текущего пользователя,
//  то следует использовать предварительный переход в привилегированный режим.
// 
// Параметры:
//  Ссылка       - ссылка на объект, - элемент справочника, документ, ...
//  ИменаРеквизитов - Строка, имена реквизитов перечисленные через запятую,
//               в формате требований к свойствам структуры.
//               Например, "Код, Наименование, Родитель".
// 
// Возвращаемое значение:
//  Структура    - содержит список свойств, как список имен в строке
//                 ИменаРеквизитов, со значениям реквизитов, прочитанных
//                 из информационной базы.
// 
Функция ПолучитьЗначенияРеквизитов(Ссылка, ИменаРеквизитов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
		|	" + ИменаРеквизитов + "
		|ИЗ
		|	" + Ссылка.Метаданные().ПолноеИмя() + " КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Результат = Новый Структура(ИменаРеквизитов);
	ЗаполнитьЗначенияСвойств(Результат, Выборка);
	
	Возврат Результат;
	
КонецФункции

// Функция, проверяет наличие упаковок у номенклатуры и возвращает список упаковок.
//  Параметры:
//   Номенклатура - ссылка номенклатура, позиция номенклатуры, по которой надо получить список упаковок.
//   ДанныеВыбора - структура, выбор данных по упаковкам.
//  Возвращаемое значение:
//   Признак наличия упаковок - булево.
//
Функция ПроверитьИспользованиеУпаковокИПолучитьСписокДляВыбора(Номенклатура, ДанныеВыбора, СтрокаПоиска = Неопределено) Экспорт
	

	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЕСТЬNULL(УпаковкиНоменклатуры.Ссылка, НЕОПРЕДЕЛЕНО) КАК Упаковка,
	|	ПРЕДСТАВЛЕНИЕ(УпаковкиНоменклатуры.Ссылка) КАК УпаковкаПредставление,
	|	ПРЕДСТАВЛЕНИЕ(УпаковкиНоменклатуры.Коэффициент) КАК КоэффициентПредставление
	|ИЗ
	|	Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	|ГДЕ
	|	УпаковкиНоменклатуры.Владелец = &ВладелецНоменклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	УпаковкиНоменклатуры.Коэффициент,
	|	УпаковкиНоменклатуры.Ссылка
	|АВТОУПОРЯДОЧИВАНИЕ");
	
	Запрос.УстановитьПараметр("ВладелецНоменклатура", Номенклатура);
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Если ТЗ.Количество() = 0 Тогда
		Возврат Ложь;
	Иначе
		Для каждого СтрокаТЗ из ТЗ Цикл
			Если СтрокаТЗ.Упаковка = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеВыбора.Добавить(СтрокаТЗ.Упаковка, СтрокаТЗ.УпаковкаПредставление
			+ " (" + СтрокаТЗ.КоэффициентПредставление+ ")");
		КонецЦикла;
	КонецЕсли;
			
	Возврат Истина;
	
КонецФункции

// Функция вернет признак оказания стоматологических услуг
//
Функция ПолучитьПризнакОказанияСтоматологическихУслуг(Сотрудник_ = Неопределено) Экспорт
	ЭтоСтоматологическиеУслуги = Истина;
	Возврат ЭтоСтоматологическиеУслуги;
КонецФункции

// Процедура, выполняет инициализацию реквизита "ХарактеристикиИспользуются" ТЧ "Запасы"
//
Процедура ЗаполнитьПризнакИспользованияХарактеристик(Запасы) Экспорт
	
	Если Запасы.Количество() > 0 Тогда					
		Если Запасы[0].Свойство("Номенклатура") Тогда
			ВыбираемоеПоле = "Номенклатура";
		ИначеЕсли Запасы[0].Свойство("НСМНоменклатура") Тогда
			ВыбираемоеПоле = "НСМНоменклатура";
		ИначеЕсли Запасы[0].Свойство("СННоменклатура") Тогда
			ВыбираемоеПоле = "СННоменклатура";
		Иначе
			ВыбираемоеПоле = "Сертификат";	
		КонецЕсли;		
	КонецЕсли;
	
	Для Каждого СтрокаЗапасы из Запасы Цикл 		
		СтрокаЗапасы.ХарактеристикиИспользуются = СтрокаЗапасы[ВыбираемоеПоле].ИспользоватьПартии;				
	КонецЦикла;
	
КонецПроцедуры

// Функция ИнформационнаяБазаФайловая определяет режим эксплуатации
// информационной базы файловый (Истина) или Серверный (Ложь).
//  При проверке используется СтрокаСоединенияИнформационнойБазы, которую
// можно указать явно.
//
// Параметры:
//  СтрокаСоединенияИнформационнойБазы - Строка - параметр используется, если
//                 нужно проверить строку соединения не текущей информационной базы.
//
// Возвращаемое значение:
//  Булево.
//
Функция ИнформационнаяБазаФайловая(Знач СтрокаСоединенияИнформационнойБазы = "") Экспорт
			
	Если ПустаяСтрока(СтрокаСоединенияИнформационнойБазы) Тогда
		СтрокаСоединенияИнформационнойБазы =  СтрокаСоединенияИнформационнойБазы();
	КонецЕсли;
	Возврат Найти(Врег(СтрокаСоединенияИнформационнойБазы), "FILE=") = 1;
	
КонецФункции 

&НаСервере
// Функция возвращает значение константы
//
Функция ПолучитьЗначениеКонстанты(ИмяКонстанты, ИмяРеквизита = "") Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	Константы."+ИмяКонстанты+" КАК Константа
	                      |ИЗ
	                      |	Константы КАК Константы");
	Выборка = Запрос.Выполнить().Выбрать();
	Если  Выборка.Следующий() Тогда
		Возврат ?(ЗначениеЗаполнено(ИмяРеквизита), Выборка.Константа[ИмяРеквизита], Выборка.Константа); 
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция возвращающая символьный код валюты
// данные берутся и константы ВалютаУчета
Функция ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти() Экспорт
	
	ТекущаяВалюта    = Константы.ВалютаУчета.Получить();
	СтрокаПараметров = СтрЗаменить(ТекущаяВалюта.ПараметрыПрописи, ",", Символы.ПС);
	ЦелаяЧасть       = СокрЛП(СтрПолучитьСтроку(СтрокаПараметров,10));
	Если  ЦелаяЧасть ="" тогда
		Возврат " "+Строка(ТекущаяВалюта)+" ";
	Иначе Возврат " "+ЦелаяЧасть+" ";
	Конецесли;
	
КонецФункции

// Функция возвращает сивольный код дробной части используемой валюты.
// 
Функция ПолучитьСимвольныйКодИспользуемойВалютыДробнойЧасти() Экспорт
	
