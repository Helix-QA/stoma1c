&НаСервереБезКонтекста
// Функция - Получить ключ записи.
//
// Параметры:
//  ЗаметкаИД	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПолныйТекстЗаметкиЗвонка(IDЗвонка, Контрагент, ТекстЗаметки)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИсторияВызовов.Заметка КАК Заметка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.Контрагент = &Контрагент
	|	И ИсторияВызовов.IDЗвонка = &IDЗвонка";
	
	Запрос.УстановитьПараметр("IDЗвонка"	, IDЗвонка);
	Запрос.УстановитьПараметр("Контрагент"	, Контрагент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда	
		Возврат Выборка.Заметка;	
	КонецЕсли;
	
	Возврат ТекстЗаметки;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик оповещения.
//
Процедура ЗавершитьРедактированиеЗаметкиЗвонок(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ТекстЗаметки     = Результат.ТекстЗаметки; 	
		ЭлементHTML      = ДопПараметры.ЭлементHTML;	
		СтрокаТЗ         = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ДопПараметры.ИдЗвонка);
		СтрокаТЗ.Заметка = ТекстЗаметки; 
		
		ЗавершитьРедактированиеЗаметкиЗвонокНаСервере(ТекстЗаметки, СтрокаТЗ.Взаимодействие);
		
		Если ЗначениеЗаполнено(ТекстЗаметки) Тогда
			ЭлементHTML.innerHTML = ?(СтрДлина(ТекстЗаметки) > 200, Лев(Результат.ТекстЗаметки, 200) + "...", ТекстЗаметки);
