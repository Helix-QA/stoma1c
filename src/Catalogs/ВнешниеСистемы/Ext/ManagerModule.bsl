КонецФункции

// Функция - Получить внешние системы
//
// Параметры:
//  ТипСистемы			 - 	 - 
//  ТолькоИспользуемое	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВнешниеСистемы(ТипСистемы = Неопределено, ТолькоИспользуемое = Истина, СтруктурнаяЕдиница = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Код КАК Код,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ТолькоИспользуемое = ИСТИНА
	|				ТОГДА ВнешниеСистемы.Используется = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА &ТипСистемы <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.ТипВнешнейСистемы = &ТипСистемы
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ");	
	
    Запрос.УстановитьПараметр("ТипСистемы"        , ?(ЗначениеЗаполнено(ТипСистемы), ТипСистемы, Неопределено));
	Запрос.УстановитьПараметр("ТолькоИспользуемое", ТолькоИспользуемое);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция, возвращает внешние системы мессенджера.
//
Функция ПолучитьВнешниеСистемыМессенджераChatApi(СтруктурнаяЕдиница = Неопределено) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.ВерсияДанных КАК ВерсияДанных,
	|	ВнешниеСистемы.ПометкаУдаления КАК ПометкаУдаления,
	|	ВнешниеСистемы.Код КАК Код,
	|	ВнешниеСистемы.Наименование КАК Наименование,
	|	ВнешниеСистемы.Используется КАК Используется,
	|	ВнешниеСистемы.КлючПриложения КАК КлючПриложения,
	|	ВнешниеСистемы.Параметры КАК Параметры,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.ТокенДоступа КАК ТокенДоступа,
	|	ВнешниеСистемы.Предопределенный КАК Предопределенный,
	|	ВнешниеСистемы.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
	|	ВнешниеСистемы.Представление КАК Представление,
	|	0 КАК Порядок
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.Используется
	|	И ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi)
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВнешниеСистемы.Ссылка,
	|	ВнешниеСистемы.ВерсияДанных,
	|	ВнешниеСистемы.ПометкаУдаления,
	|	ВнешниеСистемы.Код,
	|	ВнешниеСистемы.Наименование,
	|	ВнешниеСистемы.Используется,
	|	ВнешниеСистемы.КлючПриложения,
	|	ВнешниеСистемы.Параметры,
	|	ВнешниеСистемы.ТипВнешнейСистемы,
	|	ВнешниеСистемы.ТокенДоступа,
	|	ВнешниеСистемы.Предопределенный,
	|	ВнешниеСистемы.ИмяПредопределенныхДанных,
	|	ВнешниеСистемы.Представление,
	|	1
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.Используется
	|	И ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi)
	|	И ВнешниеСистемы.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, Неопределено));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

// Процедура - Установить состояние внешней системе
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  Используется	 - 	 - 
//
Процедура УстановитьСостояниеВнешнейСистеме(ВнешняяСистема, Используется, Синхронизирована = Истина, СтруктурнаяЕдиница = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если (ЗначениеЗаполнено(СтруктурнаяЕдиница) И СтруктурнаяЕдиница <> ВнешняяСистема.СтруктурнаяЕдиница)
		Или ВнешняяСистема.Используется <> Используется Тогда
		
		ВнешняяСистемаОбъект = ВнешняяСистема.ПолучитьОбъект(); 
		ВнешняяСистемаОбъект.Используется     = Используется;
		ВнешняяСистемаОбъект.Синхронизирована = Синхронизирована;
		ВнешняяСистемаОбъект.Записать();
		
	КонецЕсли;

КонецПроцедуры

// Функция - Создать внешнюю систему
//
// Параметры:
//  ТипВнешнейСистемы	 - 	 - 
//  Наименование		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьВнешнююСистему(ТипВнешнейСистемы, Наименование = Неопределено, Используется = Неопределено, КлючПриложения = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ВнешняяСистемаОбъект = Справочники.ВнешниеСистемы.СоздатьЭлемент();
	ВнешняяСистемаОбъект.ТипВнешнейСистемы = ТипВнешнейСистемы;
	ВнешняяСистемаОбъект.КлючПриложения    = ?(ЗначениеЗаполнено(КлючПриложения), Строка(КлючПриложения), Строка(Новый УникальныйИдентификатор()));
	
	Если Используется <> Неопределено Тогда 
		ВнешняяСистемаОбъект.Используется = Используется;
	КонецЕсли;
	
	ТипыУпрМзКабинета = ТипыВнешнихСистемУправляемыхизЛичногоКабинета();
	
	Если ТипыУпрМзКабинета.Найти(ТипВнешнейСистемы) <> Неопределено Тогда		
		ВнешняяСистемаОбъект.УправлениеВЛичномКабинете = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Наименование) Тогда
		ВнешняяСистемаОбъект.Наименование = Наименование;
	Иначе
		ВнешняяСистемаОбъект.Наименование = Строка(ТипВнешнейСистемы);
	КонецЕсли;
		
	ВнешняяСистемаОбъект.Записать();

	Возврат ВнешняяСистемаОбъект.Ссылка;
	
КонецФункции

