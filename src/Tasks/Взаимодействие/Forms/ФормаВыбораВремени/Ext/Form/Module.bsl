//	               |			КОНЕЦ
//	               |	КОНЕЦ
//	               |ИЗ
//	               |	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
//	               |ГДЕ
//	               |	ЗадачаИсполнителя.Исполнитель = &Сотрудник
//	               |	И ЗадачаИсполнителя.ЗадачаНазначеннаяДата МЕЖДУ ДОБАВИТЬКДАТЕ(&ДатаНачала, ДЕНЬ, 1) И ДОБАВИТЬКДАТЕ(&ДатаОкончания, ДЕНЬ, 1)
//	               |	И &НачальнаяСтраница
//	               |
//	               |ОБЪЕДИНИТЬ ВСЕ
//	               |
//	               |ВЫБРАТЬ
//	               |	ЗадачаИсполнителя.Ссылка,
