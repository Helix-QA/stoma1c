
#Область ОбработчикиСобытийЭлементовФормы 

&НаСервере
// Обработчик создания формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Список.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	Параметры.Свойство("ОтборПериодНачало",ОтборПериодНачало);
	Параметры.Свойство("ОтборПериодКонец" ,ОтборПериодКонец);
    Параметры.Свойство("ОтборКонтрагент"  ,ОтборКонтрагент);
    Параметры.Свойство("ОтборСотрудник"   ,ОтборСотрудник);
    Параметры.Свойство("ОтборПомещение"   ,ОтборПомещение);
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОтборДатаНачала"     , НачалоДня(ОтборПериодНачало), ЗначениеЗаполнено(ОтборПериодНачало),ВидСравненияКомпоновкиДанных.БольшеИлиРавно);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОтборДатаОкончания"  , КонецДня(ОтборПериодКонец), ЗначениеЗаполнено(ОтборПериодКонец),ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент"          , ОтборКонтрагент, ЗначениеЗаполнено(ОтборКонтрагент));
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Сотрудник"           , ОтборСотрудник, ЗначениеЗаполнено(ОтборСотрудник));
	Если ЗначениеЗаполнено(ОтборПомещение) И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОтборПомещение,"ЭтоГруппа") Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Помещение", ОтборПомещение, ЗначениеЗаполнено(ОтборПомещение),ВидСравненияКомпоновкиДанных.ВИерархии);
	Иначе
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Помещение", ОтборПомещение, ЗначениеЗаполнено(ОтборПомещение));
	КонецЕсли;

КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Обработчик изменения выбора фильтра 
//
Процедура ОтборПериодНачалоПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОтборДатаНачала", НачалоДня(ОтборПериодНачало), ЗначениеЗаполнено(ОтборПериодНачало),ВидСравненияКомпоновкиДанных.БольшеИлиРавно);
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения выбора фильтра 
//
Процедура ОтборПериодКонецПриИзменении(Элемент)    
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОтборДатаОкончания", КонецДня(ОтборПериодКонец), ЗначениеЗаполнено(ОтборПериодКонец),ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения выбора фильтра
//
Процедура ОтборСтруктурнаяЕдиницаПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница, ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница)); 
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения выбора фильтра
//
Процедура ОтборКонтрагентПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", ОтборКонтрагент, ЗначениеЗаполнено(ОтборКонтрагент));  
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения выбора фильтра 
//
Процедура ОтборСотрудникПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Сотрудник", ОтборСотрудник, ЗначениеЗаполнено(ОтборСотрудник)); 
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения выбора фильтра  
//
Процедура ОтборПомещениеПриИзменении(Элемент) 
	
	Если ЗначениеЗаполнено(ОтборПомещение) И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОтборПомещение,"ЭтоГруппа") Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Помещение", ОтборПомещение, ЗначениеЗаполнено(ОтборПомещение),ВидСравненияКомпоновкиДанных.ВИерархии);
	Иначе
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Помещение", ОтборПомещение, ЗначениеЗаполнено(ОтборПомещение));
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
// Обработчик выбора значения в списке таблицы 
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка) 
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ТекущиеДанные.Ссылка));
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандвФормы 

&НаКлиенте
// Обработчик кнопки изменения фильтра 
//
Процедура СписокОбновить(Команда)
	
	Элементы.Список.Обновить(); 
	
КонецПроцедуры

&НаКлиенте
// Обработчик кнопки открытия формы документа  
//
Процедура ЗаписьРедактировать(Команда) 
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ТекущиеДанные.Ссылка));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик кнопки восстановления записиси 
//
Процедура ЗаписьВосстановить(Команда)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		ОбщегоНазначенияКлиент.ОтменитьСобытие(ТекущиеДанные.Ссылка,Истина);
		Элементы.Список.Обновить();
		ОповеститьОбИзменении(ТекущиеДанные.Ссылка);
		Оповестить("ОБНОВИТЬ_ГРАФИК_ПЗ");
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

