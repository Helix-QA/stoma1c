// Процедура - Установка видимости полей сертификата
//
Процедура УстановкаВидимостиПолейСертификата()
	
	Если Объект.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.БезОграниченияСрока ИЛИ НЕ ЗначениеЗаполнено(Объект.ТипСрокаДействия) Тогда
		Элементы.СтраницаСОграничениемНаДату.Видимость = Ложь;
		Элементы.СтраницаПериодПослеПродажи.Видимость = Ложь;
	ИначеЕсли Объект.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.СОграничениемНаДату Тогда
		Элементы.СтраницаСОграничениемНаДату.Видимость = Истина;
		Элементы.СтраницаПериодПослеПродажи.Видимость = Ложь;
	ИначеЕсли Объект.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.ПериодПослеПродажи Тогда
		Элементы.СтраницаСОграничениемНаДату.Видимость = Ложь;
		Элементы.СтраницаПериодПослеПродажи.Видимость = Истина;
	КонецЕсли;
	
	// Элементы.СтраницыСрокДействияСертификатов.Видимость = (Объект.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.СОграничениемНаДату ИЛИ Объект.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.ПериодПослеПродажи);
	Элементы.ПерейтиНаСерииСертификатов.Видимость = Объект.ИспользоватьПартии;	
	Элементы.СертификатМногоразовоеИспользование.Доступность = (Объект.ИспользоватьПартии = Истина);
	Элементы.Номинал.Доступность = НЕ Объект.ВидНоминала;
	
	Элементы.ГруппаСертификаты.Видимость = ?((ЗначениеЗаполнено(Объект.ТипНоменклатуры) и Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат), Истина, Ложь);			
	
КонецПроцедуры

