	СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов", МассивРазрешенныхТипов); 
	СтруктураПараметры.Вставить("Заголовок"                  , "Выберите материал");	   
	СтруктураПараметры.Вставить("ВыбранныеЗначения"          , Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Номенклатура);
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры",
	СтруктураПараметры,,,,,
	Новый ОписаниеОповещения("ТаблицаВыбранныхЗначенийНоменклатураНачалоВыбораЗавершение", ЭтотОбъект), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора значений номенклатуры
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ТаблицаВыбранныхЗначенийНоменклатураНачалоВыбораЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) И РезультатВыбора.Свойство("Номенклатура") Тогда
		
		Номенклатура = РезультатВыбора.Номенклатура;
		
		Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Номенклатура = Номенклатура;
		Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Склад        = СкладПоУмолчанию;
		Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Номенклатура, "ИспользоватьПартии");
		Если Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Номенклатура <> ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Упаковка, "Владелец") Тогда
			Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Упаковка = Неопределено;
		КонецЕсли; 			
		Если Не ЗначениеЗаполнено(Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Количество) Тогда
			Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные.Количество = 1;
		КонецЕсли;

	КонецЕсли; 	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить остаток
//
Функция ПолучитьОстаток(Номенклатура, Склад, Упаковка, Партия)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) КАК Остаток
	|ИЗ
	|	РегистрНакопления.Запасы.Остатки(
	|			,
	|			Номенклатура = &Номенклатура
	|				И Склад = &Склад
	|				И Партия = &партия) КАК ЗапасыОстатки";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад"       , Склад);
	Запрос.УстановитьПараметр("Партия"		, Партия);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), ?(Упаковка.Коэффициент <> 0, Выборка.Остаток / Упаковка.Коэффициент, Выборка.Остаток) , 0);
	
КонецФункции

#КонецОбласти