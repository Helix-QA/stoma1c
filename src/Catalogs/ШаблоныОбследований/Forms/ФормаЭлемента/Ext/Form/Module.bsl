// Заполнить дерево параметров  
//
Процедура ЗаполнитьДеревоПараметровСервер()
		
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ШаблоныОбследованийПарамтеры.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ШаблоныОбследованийПарамтеры.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ + ВЫБОР
	|		КОГДА ШаблоныОбследованийПарамтеры.ПометкаУдаления
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ИндексКартинки,
	|	СУММА(ЕСТЬNULL(ЗапросКоличестваЭлементов.Количество, 0)) КАК КоличествоЭлементов,
	|	ШаблоныОбследованийПарамтеры.ЭтоГруппа КАК ЭтоГруппа,
	|	ШаблоныОбследованийПарамтеры.ТипПараметра КАК ТипПараметра,
	|	ШаблоныОбследованийПарамтеры.Предопределенный КАК Предопределенный
	|ИЗ
	|	ПланВидовХарактеристик.ПараметрыОбследований КАК ШаблоныОбследованийПарамтеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ШаблоныОбследованийПарамтеры.Ссылка) КАК Количество,
	|			ШаблоныОбследованийПарамтеры.Родитель КАК Родитель
	|		ИЗ
	|			ПланВидовХарактеристик.ПараметрыОбследований КАК ШаблоныОбследованийПарамтеры
	|		ГДЕ
	|			ШаблоныОбследованийПарамтеры.ЭтоГруппа = ЛОЖЬ
	|			И ШаблоныОбследованийПарамтеры.ПометкаУдаления = ЛОЖЬ
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ШаблоныОбследованийПарамтеры.Родитель) КАК ЗапросКоличестваЭлементов
	|		ПО (ШаблоныОбследованийПарамтеры.ЭтоГруппа = ИСТИНА)
	|			И (ЗапросКоличестваЭлементов.Родитель = ШаблоныОбследованийПарамтеры.Ссылка)
	|ГДЕ
	|	ШаблоныОбследованийПарамтеры.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА &БезГрупп
	|				ТОГДА ШаблоныОбследованийПарамтеры.ЭтоГруппа = ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ШаблоныОбследованийПарамтеры.Ссылка,
	|	ВЫБОР
	|		КОГДА ШаблоныОбследованийПарамтеры.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ,
	|	ШаблоныОбследованийПарамтеры.ЭтоГруппа,
	|	ШаблоныОбследованийПарамтеры.ТипПараметра,
	|	ШаблоныОбследованийПарамтеры.Предопределенный,
	|	ВЫБОР
	|		КОГДА ШаблоныОбследованийПарамтеры.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ + ВЫБОР
	|		КОГДА ШаблоныОбследованийПарамтеры.ПометкаУдаления
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|АВТОУПОРЯДОЧИВАНИЕ";
	Если НЕ ПарамтерыШаблонаРежимотображения Тогда
		ЗапросДанных.Текст = ЗапросДанных.Текст +" УПОРЯДОЧИТЬ ПО
		|	ЭтоГруппа,
		|	Ссылка
		|ИТОГИ
		|	СУММА(КоличествоЭлементов)
		|ПО
		|	Ссылка ИЕРАРХИЯ"; 
	КонецЕсли;
	ЗапросДанных.УстановитьПараметр("БезГрупп", ПарамтерыШаблонаРежимотображения);
	РезЗапроса = ЗапросДанных.Выполнить();
	ПарамтерыШаблона.ПолучитьЭлементы().Очистить();
	ИдентификаторПозиционирования = Неопределено;
	Если НЕ ПарамтерыШаблонаРежимотображения Тогда
	    РекурсивноеЗаполнениеДереваПарамтеров(РезЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией,"Ссылка"),
			ПарамтерыШаблона.ПолучитьЭлементы(),Неопределено);
	Иначе
		ЗаполнитьПараметрыСписком(РезЗапроса.Выбрать(), ПарамтерыШаблона.ПолучитьЭлементы());
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Функция рекурсивного заполнения дерева
//
Процедура РекурсивноеЗаполнениеДереваПарамтеров(Выборка,Дерево,ПредРодитель) 
	
	Пока Выборка.Следующий() Цикл
		//ИЛИ (Выборка.ЭтоГруппа И Выборка.КоличествоЭлементов = 0)
		Если ПредРодитель =  Выборка.Ссылка  Тогда
			Продолжить;
		КонецЕсли;	
		НовыйЭл = Дерево.Добавить();
		ЗаполнитьЗначенияСвойств(НовыйЭл,Выборка);
		НовыйЭл.ТипЗначения                  = НовыйЭл.Ссылка.ТипЗначения;
		Если ПараметрыШаблонаТекущийПараметр = НовыйЭл.Ссылка Тогда
			ИдентификаторПозиционирования = НовыйЭл.ПолучитьИдентификатор();
		КонецЕсли;	
		Если Выборка.ЭтоГруппа Тогда
			РекурсивноеЗаполнениеДереваПарамтеров(Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией,"Ссылка"),НовыйЭл.ПолучитьЭлементы(),Выборка.Ссылка);
		КонецЕсли;				
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Заполнить дерево парамтеров в виде списка  
//
Процедура ЗаполнитьПараметрыСписком(Выборка,Дерево)  
	
	Пока Выборка.Следующий() Цикл
		НовыйЭл = Дерево.Добавить();
		ЗаполнитьЗначенияСвойств(НовыйЭл,Выборка);	
		НовыйЭл.ТипЗначения = НовыйЭл.Ссылка.ТипЗначения;
		Если ПараметрыШаблонаТекущийПараметр = НовыйЭл.Ссылка Тогда
			ИдентификаторПозиционирования = НовыйЭл.ПолучитьИдентификатор();
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьГлавныйКонтейнер(ДочернийHtmlЭлемент)	 
	
	Если ДочернийHtmlЭлемент.className = "border" Тогда
		Возврат ДочернийHtmlЭлемент;
	ИначеЕсли ДочернийHtmlЭлемент.ParentElement <> Неопределено Тогда
		Возврат ПолучитьГлавныйКонтейнер(ДочернийHtmlЭлемент.ParentElement); 
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

&НаСервере
// Процедура перемещения параметра в другую группу    
//
Процедура ПереместитьПараметр(СсылкаИсточника,СсылкаПриемника)	
	
	ОбъектИсточника = СсылкаИсточника.ПолучитьОбъект();
	Родитель = Неопределено;
	Если СсылкаПриемника.ЭтоГруппа Тогда
		Родитель = СсылкаПриемника;
	Иначе
		Родитель = СсылкаПриемника.Родитель;
	КонецЕсли;		 
	Если НЕ Родитель = ОбъектИсточника.Родитель Тогда
		ОбъектИсточника.Родитель = Родитель;
		ОбъектИсточника.Записать();
	КонецЕсли;
	
КонецПроцедуры

