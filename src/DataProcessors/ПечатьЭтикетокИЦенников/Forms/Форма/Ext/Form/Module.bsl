	ЗаполнитьТаблицуТоваровНаСервере(Истина, Ложь, Ложь, Ложь, Ложь, Истина);
	Документ = Неопределено;

КонецПроцедуры

&НаСервере
// Процедура выполняет заполнение табличной части "Товары".
//
Процедура ЗаполнитьТаблицуТоваровНаСервере(
	ПроверятьЗаполнение       = Истина, 
	Сохранять                 = Истина, 
	ПоОстаткам 				  = Ложь, 
	ПоДокументуПоступления    = Истина, 
	ПоДокументуПеремещения    = Ложь, 
	ПоСправочникуНоменклатуры = Ложь)
    	
	Если ПроверятьЗаполнение И ЭтаФорма.ПроверитьЗаполнение() = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	// Сохранение выбранных позиций для их последующего восстановления.
	Если Сохранять Тогда
		ТаблицаВыбранныеПозиции = Объект.Товары.Выгрузить();
	КонецЕсли;
	
	// Поля необходимые для вывода в таблицу товаров на форме.
	СтруктураНастроек = Обработки.ПечатьЭтикетокИЦенников.ПолучитьПустуюСтруктуруНастроек();
	
	СтруктураНастроек.ОбязательныеПоля.Добавить("Цена");
	СтруктураНастроек.ОбязательныеПоля.Добавить("Штрихкод");
	СтруктураНастроек.ОбязательныеПоля.Добавить("Количество");
	СтруктураНастроек.ОбязательныеПоля.Добавить("Номенклатура");
	СтруктураНастроек.ОбязательныеПоля.Добавить("Партия");
	СтруктураНастроек.ОбязательныеПоля.Добавить("Упаковка");
	СтруктураНастроек.ОбязательныеПоля.Добавить("ОстатокНаСкладе");
	
	// Шаблоны этикеток и ценников.	
	СтруктураНастроек.ПараметрыДанных.Вставить("ВидЦен"   				 , Объект.ВидЦен);
	СтруктураНастроек.ПараметрыДанных.Вставить("СтруктурнаяЕдиницаДляЦен", Объект.СтруктурнаяЕдиница);
	СтруктураНастроек.ПараметрыДанных.Вставить("ЦеныНаДату"				 , Объект.ЦеныНаДату);	
	СтруктураНастроек.ПараметрыДанных.Вставить("Организация"			 , Объект.Организация);
	СтруктураНастроек.КомпоновщикНастроек = КомпоновщикНастроек;
	
	Если ПоДокументуПоступления Тогда 
		
		СтруктураНастроек.ИмяМакетаСхемыКомпоновкиДанных = "ПоДокументуПоступления";
		СтруктураНастроек.ПараметрыДанных.Вставить("ДокументПоступления", Документ);
		Элементы.Декорация_ДокументПоступления.Заголовок = "Поступление товаров № " + Документ.Номер + " от " + Формат(Документ.Дата, "ДЛФ=DD");
		
	ИначеЕсли ПоДокументуПеремещения Тогда 
		
		СтруктураНастроек.ИмяМакетаСхемыКомпоновкиДанных = "ПоДокументуПеремещения";
		СтруктураНастроек.ПараметрыДанных.Вставить("ДокументПоступления", Документ);
		Элементы.Декорация_ДокументПоступления.Заголовок = "Перемещение товаров № " + Документ.Номер + " от " + Формат(Документ.Дата, "ДЛФ=DD");
	Иначе 
		Если Объект.ИсходныеДанные.Количество() > 0  Тогда
			СтруктураНастроек.ИмяМакетаСхемыКомпоновкиДанных = "ПоляШаблона";
			СтруктураНастроек.ИсходныеДанные = Объект.ИсходныеДанные.Выгрузить();
		Иначе
			СтруктураНастроек.ИмяМакетаСхемыКомпоновкиДанных = "ПоляШаблонаБД";
		КонецЕсли;
		
		Элементы.Декорация_ДокументПоступления.Заголовок = "";
		
	КонецЕсли;
	
	Объект.Товары.Очистить();
	
	// Загрузка сформированного списка товаров.
	СтруктураРезультата = Обработки.ПечатьЭтикетокИЦенников.ПодготовитьСтруктуруДанных(СтруктураНастроек);
	Для Каждого СтрокаТЧ Из СтруктураРезультата.ТаблицаТоваров Цикл
		
		Если ((ПоДокументуПоступления ИЛИ ПоДокументуПеремещения) И СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас)
			ИЛИ (СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас И ПоОстаткам И СтрокаТЧ.ОстатокНаСкладе <> Null И СтрокаТЧ.ОстатокНаСкладе > 0) 
			ИЛИ ПоСправочникуНоменклатуры Тогда
			
			НоваяСтрока = Объект.Товары.Добавить();
			НоваяСтрока.Номенклатура         = СтрокаТЧ.Номенклатура;
			НоваяСтрока.Партия               = СтрокаТЧ.Партия;
			НоваяСтрока.Упаковка             = СтрокаТЧ.Упаковка;		
			НоваяСтрока.Цена                 = СтрокаТЧ.Цена;
			НоваяСтрока.Штрихкод             = СтрокаТЧ.Штрихкод;
			НоваяСтрока.ОстатокНаСкладе      = СтрокаТЧ.ОстатокНаСкладе;
			НоваяСтрока.КоличествоЦенников 	 = СтрокаТЧ.ОстатокНаСкладе;
			
			Если Объект.ШаблонДляПечати <> Справочники.ХранилищеШаблонов.ПустаяСсылка() Тогда
			     НоваяСтрока.ШаблонЦенника   = Объект.ШаблонДляПечати;
			КонецЕсли;
						
			// Восстановление позиций, сохраненных перед заполнением ТЧ. 
			Если Сохранять Тогда
				
				ПараметрыОтбора = Новый Структура();
				ПараметрыОтбора.Вставить("Номенклатура", НоваяСтрока.Номенклатура);
				ПараметрыОтбора.Вставить("Партия"      , НоваяСтрока.Партия);
				ПараметрыОтбора.Вставить("Упаковка"    , НоваяСтрока.Упаковка);
				
				НайденныеСтроки = ТаблицаВыбранныеПозиции.НайтиСтроки(ПараметрыОтбора);
				
				Если НайденныеСтроки.Количество() > 0 Тогда
					ЗаполнитьЗначенияСвойств(НоваяСтрока, НайденныеСтроки[0],"ШаблонЦенника, КоличествоЦенников");	
				КонецЕсли;
				
			КонецЕсли;
			
			НоваяСтрока.Выбран = ПроверитьВозможностьВыбораТовара(НоваяСтрока, Режим);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Элементы.Товары.Обновить();
	
КонецПроцедуры // ЗаполнитьТаблицуТоваровНаСервере()

 #КонецОбласти
