// Процедура, обработчик команды.
//
Процедура СоздатьSMSРассылку(Команда)
	
	Если Не ПроверитьВидимостьВсплывающихГрупп("SMS") Тогда
		Возврат;
	КонецЕсли;

	Если Объект.Ссылка.Пустая() Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВзаимодействиеПослеВопросаОЗаписиЗаявки", ЭтотОбъект, Новый Структура("ВыполнитьДействие", "СоздатьSMS"));
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Для отправки sms сообщения нужно произвести запись заявки. Записать?'; en = 'To send an sms message, you need to record the application. To record?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		Если Модифицированность И Не ЭтаФорма.Записать() Тогда
			Возврат;
		КонецЕсли;

		СоздатьSMSРассылкуНаКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, создает sms рассылку.
//
Процедура СоздатьSMSРассылкуНаКлиенте()
	
	МассивНомеровТелефонов = ПолучитьНомераТелефоновЗаявкиКлиента(Объект.Ссылка);
	
	Если ЗначениеЗаполнено(МассивНомеровТелефонов) Тогда
		
		ЭтотОбъект.ВзаимодействиеSMSСписокНомеровТелефонов.ЗагрузитьЗначения(МассивНомеровТелефонов);
		
		Если Не (ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеSMSНомерТелефона)
			И МассивНомеровТелефонов.Найти(ЭтотОбъект.ВзаимодействиеSMSНомерТелефона) <> Неопределено) Тогда
			
			ЭтотОбъект.ВзаимодействиеSMSНомерТелефона = МассивНомеровТелефонов[0];
		КонецЕсли;
		
		Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Заголовок = ЭтотОбъект.ВзаимодействиеSMSНомерТелефона;
		
		ПереместитьЭлементСделкиВзаимодействия("ГруппаВзаимодействиеSMSШапка");
		
		УстановитьВидимостьВсплывающихГрупп("SMS");
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'У клиента не задан номер телефона, или рассылка запрещена'; en = 'The client does not have a phone number or mailing is prohibited'"));
	КонецЕсли;
	
КонецПроцедуры

