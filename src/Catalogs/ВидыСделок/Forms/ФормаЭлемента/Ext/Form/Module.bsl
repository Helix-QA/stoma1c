&НаКлиенте
// Процедура - Структурная единица обработка выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура СтруктурнаяЕдиницаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	МассивОтбираемыхСЕ = Новый Массив;
	Для Каждого ЭлементСписка Из СписокДоступныхСтруктурныхЕдиниц Цикл
		Если Объект.СтруктурныеЕдиницыПрименения.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ЭлементСписка.Значение)).Количество() = 0 
			И НЕ ЭлементСписка.Значение = ВыбранноеЗначение Тогда 
			МассивОтбираемыхСЕ.Добавить(ЭлементСписка.Значение);
		КонецЕсли;	
	КонецЦикла;
	Массив = Новый Массив;
	Массив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивОтбираемыхСЕ)));
	
	Элементы.СтруктурныеЕдиницыПримененияСтруктурнаяЕдиница.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Декорация подсказка добавить нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДекорацияПодсказкаДобавитьНажатие(Элемент)
	
	УстановитьВидимостьЭлементамСпискаСтруктурныхЕдиниц(Истина);
	Элементы.СтруктурныеЕдиницыПрименения.ДобавитьСтроку();	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Структурные единицы применения при активизации поля
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура СтруктурныеЕдиницыПримененияПриАктивизацииПоля(Элемент)
	
	Если Элемент.ТекущийЭлемент.Имя = "СтруктурныеЕдиницыПримененияУдаление" Тогда
		Если Элемент.ТекущиеДанные <> Неопределено Тогда
			МассивОтбираемыхСЕ = Новый Массив;			
			Объект.СтруктурныеЕдиницыПрименения.Удалить(Элемент.ТекущиеДанные);
			Для Каждого ЭлементСписка Из СписокДоступныхСтруктурныхЕдиниц Цикл
				Если Объект.СтруктурныеЕдиницыПрименения.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ЭлементСписка.Значение)).Количество() = 0 Тогда 
					МассивОтбираемыхСЕ.Добавить(ЭлементСписка.Значение);
				КонецЕсли;	
			КонецЦикла;
			Массив = Новый Массив;
			Массив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивОтбираемыхСЕ)));
			
			Элементы.СтруктурныеЕдиницыПримененияСтруктурнаяЕдиница.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
			ЭтаФорма.Модифицированность = Истина;
		КонецЕсли;	
	КонецЕсли;
	ЭтаФорма.ТекущийЭлемент = Элементы.СтруктурныеЕдиницыПримененияСтруктурнаяЕдиница;
	
КонецПроцедуры

