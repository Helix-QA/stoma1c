		И ЗначениеЗаполнено(МассивТелефонов) Тогда
			
			Запрос = Новый Запрос;
			ТекстЗапроса = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	КонтрагентыКонтактнаяИнформация.Ссылка
			|ИЗ
			|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
			|ГДЕ
			|	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
			|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
			|	И (КонтрагентыКонтактнаяИнформация.НомерТелефона В (&МассивТелефонов)
			|			ИЛИ ВЫРАЗИТЬ(КонтрагентыКонтактнаяИнформация.Представление КАК СТРОКА(100)) В (&МассивТелефонов))
			|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления
			|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ЭтоГруппа";
			
			Запрос.УстановитьПараметр("МассивТелефонов", МассивТелефонов);
			
			Запрос.Текст = ТекстЗапроса;
			Выборка = Запрос.Выполнить().Выбрать();
			
			Пока Выборка.Следующий() Цикл
				Контрагент = Выборка.Ссылка;
			КонецЦикла;
					
	ИначеЕсли НомерПоиска = 2
		И ЗначениеЗаполнено(КодСинхронизации) Тогда
			
			Попытка
				СправочникСсылка = Справочники.Контрагенты.НайтиПоРеквизиту("КодСинхронизации", КодСинхронизации);		
			Исключение
				СправочникСсылка = Справочники.Контрагенты.ПустаяСсылка();
			КонецПопытки;
			
			Если НЕ СправочникСсылка.Пустая() Тогда
				
				Контрагент = СправочникСсылка;
				
			КонецЕсли;
		
	КонецЕсли;
	
