
&НаКлиенте
Перем ФормироватьНаименованиеПолноеАвтоматически; // надо ли формировать автоматически НаименованиеПолное или нет

&НаКлиенте
Перем ЗаписатьИндексСортировкиНоменклатуры;

#Область ОБРАБОТЧИКИ_СОБЫТИЙ_ФОРМЫ

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Элементы.Код.Видимость = ОтображниеКода;
	Элементы.Код.ПоложениеЗаголовка = ?(ОтображниеКода, ПоложениеЗаголовкаЭлементаФормы.Авто, ПоложениеЗаголовкаЭлементаФормы.Нет);
	
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Объект, "СтраницаДополнительныеРеквизиты");	
	
	ЭтоУслуга = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга);
	СоздатьДеревоСтруктурныхЕдиниц();
	ЭтотОбъект.ОнлайнЗапись = (Объект.НормаВремени <> 0 ИЛИ Не ЭтоУслуга) И НоменклатураДоступнаДляОнлайнЗаписи();  
	
	Если ЭтотОбъект.ОнлайнЗапись Тогда
		ЗаполнитьДеревоУслуг();
	КонецЕсли;
	
	// установим видимость ставки НДС
	УстановитьВидимостьЭлементов();
	//Элементы.НормыСписанияМатериалов.Видимость = ?((ЗначениеЗаполнено(Объект.ТипНоменклатуры) и ЭтоУслуга),Истина, Ложь);
	
	УстановкаВидимостиПолейСертификата();
	НовыйЭлемент = Объект.Ссылка.Пустая();
	Если Не НовыйЭлемент Тогда 
		СерийныйНомер.Параметры.УстановитьЗначениеПараметра("Номенклатура", Объект.Ссылка);  
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ЕдиницаИзмерения) Тогда
		Объект.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
	КонецЕсли;
	
	// Создаем элемент существующих строк состав набора
	Для Каждого СтрокаТЗ ИЗ Объект.СоставНабора Цикл
		ДобавитьЭлементыФормыСоставНабора(СтрокаТЗ.ПолучитьИдентификатор());
	КонецЦикла;
	
	Элементы.ГруппаСертификаты.Видимость = ?((ЗначениеЗаполнено(Объект.ТипНоменклатуры) И Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат), Истина, Ложь);			
	ЗаполнитьДеревоСостояний();
	
	СоставУслугиОнЛайнКаталога = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Объект.ОбменССайтомСоответствиеУслуги, "||");
	Если СоставУслугиОнЛайнКаталога.Количество() = 2 Тогда
		ОбменССайтомСоответствиеУслуги_Код = СоставУслугиОнЛайнКаталога[0];
		ОбменССайтомСоответствиеУслуги_Наименование = СоставУслугиОнЛайнКаталога[1];
	КонецЕсли;	
	
	Если ЭтоУслуга И НовыйЭлемент Тогда
		Объект.НормаВремени = ?(Объект.НормаВремени <> 0, Объект.НормаВремени, 30);
	ИначеЕсли ЭтоУслуга Тогда
		ЭтотОбъект.НормаВремени = Объект.НормаВремени;
	КонецЕсли;	
	
	Если Не НовыйЭлемент Тогда
		ЭтаФорма.УстановитьПараметрыФункциональныхОпцийФормы(Новый Структура("Номенклатура", Объект.Ссылка));
	Иначе
		ЭтаФорма.ТекущийЭлемент = Элементы.Наименование;
	КонецЕсли; 

	СформироватьБлокЦен();
	ОбновитьСтатусНоменклатуры(); 
	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии"
Процедура ПриОткрытии(Отказ)
	
	УстановитьФлагФормироватьНаименованиеПолноеАвтоматически();
	
	Если НовыйЭлемент Тогда 		
		ТипНоменклатурыПриИзменении(Неопределено); 
		НаименованиеПриИзменении(Неопределено)
	КонецЕсли;
		 	
КонецПроцедуры

&НаКлиенте       
// Процедура Обработчик события формы - ПередЗаписью.
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Для каждого СтрокаТЧ Из Объект.СоставНабора Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.СННоменклатура) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Элемент не записан. В составе набора услуг пустая строка.';en='The item is not written. As part of the service set, an empty string.'"));
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	КонецЦикла;          
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере"
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
		
	// ЗаполнитьОбластиЗубнойФормулы(ТекущийОбъект);
	
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	ОбработкаТабличныхЧастейКлиент.ЗаполнитьМассивВыбранныхСтруктурныхЕдиниц(
		ЭтотОбъект.ПодборСтруктурныеЕдиницы.ПолучитьЭлементы(), 
		МассивВыбранныхСтруктурныхЕдиниц);
	
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);      
	
	// Обработчик подсистемы запрета редактирования реквизитов объектов
	// ЗапретРедактированияРеквизитовОбъектов.ПередЗаписью(ЭтаФорма, ТекущийОбъект, Отказ);
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриЗаписиНаСервере"
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	ОбработкаТабличныхЧастейКлиент.ЗаполнитьМассивВыбранныхСтруктурныхЕдиниц(
		ЭтотОбъект.ПодборСтруктурныеЕдиницы.ПолучитьЭлементы(), 
		МассивВыбранныхСтруктурныхЕдиниц);
	
	РегистрыСведений.РеквизитыОбъектов.СоздатьЗаписиВРегистреРеквизитыОбъектов(ТекущийОбъект.Ссылка, 
		МассивВыбранныхСтруктурныхЕдиниц, "ОнлайнЗапись", Истина);

КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере".
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// Обработчик подсистемы запрета редактирования реквизитов объектов
	// ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтаФорма, Элементы.ГруппаРедактированияРеквизитовОбъекта);
	
	// Синхронизация реквизитов с регистрами сведений.
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	УстановитьСтатусПродажиНоменклатуры(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Объект.Ссылка, ТекущаяДата(), ЭтаФорма.СтатусПродажиНоменклатуры);
	
	Элементы.НеобходимоЗаписатьДокумент.Видимость = Не ЗначениеЗаполнено(Объект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения"
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// Обработчик механизма "Свойства".
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
		ОбновитьДополнительныеРеквизиты();
	КонецЕсли;
	  
	Если ИмяСобытия = "ЗаписатьОбластиЗубнойФормулы" Тогда 
		ЗаполнитьОбластиЗубнойФормулы(Параметр);
	ИначеЕсли ИмяСобытия = "ВставитьУпаковку" Тогда
		
		Если ЭтаФорма.ТекущийЭлемент <> Неопределено И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтаФорма.ТекущийЭлемент, "Имя") Тогда
			
			МассивЭлементов = СтрРазделить("УпаковкаПоУмолчанию,УпаковкаПоУмолчаниюМатериал,УпаковкаПоУмолчаниюИмущество", ",");
			
			Если ЭтаФорма.ТекущийЭлемент.Имя = "УпаковкаДляОтчета" Тогда
				Объект.УпаковкаДляОтчета = Параметр;
			ИначеЕсли МассивЭлементов.Найти(ЭтаФорма.ТекущийЭлемент.Имя) <> Неопределено Тогда			
				Объект.УпаковкаПоУмолчанию = Параметр;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриЗакрытии"
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗаписатьИндексСортировкиНоменклатуры = Истина
		И ЗначениеЗаполнено(Объект.Ссылка)
		И Объект.ИндексСортировки <> ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Ссылка, "ИндексСортировки")
		И (Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга")
				И Объект.ГруппаОнлайнЗаписи = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Ссылка, "ГруппаОнлайнЗаписи")) Тогда
		
		ИндексСортировки = Объект.ИндексСортировки;
		
		ЭтаФорма.Прочитать();
		Объект.ИндексСортировки = ИндексСортировки;
		ЭтаФорма.Записать();
		
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи"
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ЗаписатьИндексСортировкиНоменклатуры = Ложь;

КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриЧтенииНаСервере"
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
КонецПроцедуры

#КонецОбласти  

#Область ОБРАБОТЧИКИ_РЕКВИЗИТОВ_ШАПКИ

&НаКлиенте
// Процедура, обработчик события "Нажатие".
//
Процедура ИсторияИзмененияСтатусаНажатие(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Элемент не записан. Открыть историю статусов незаписанного элемента невозможно.';en='Element not recorded by. Open unwritten element status history impossible.'"));
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Отбор, Видимость", Новый Структура("Номенклатура", Объект.Ссылка), Ложь);	
	ОткрытьФорму("РегистрСведений.СтатусыНоменклатуры.ФормаСписка", ПараметрыФормы,,,,, Новый ОписаниеОповещения("ИсторияИзмененияСтатусаНажатиеЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - История изменения цены нажатие завершение
// Завершение немодального открытия окна формы - Регистр сведений Цены номенклатуры - ФормаСписка
// Параметры:
//  Результат	 - 	 Результат Оповещения 
//  Параметры	 - 	 Параметры Оповещения 
//
Процедура ИсторияИзмененияСтатусаНажатиеЗавершение(Результат, Параметры) Экспорт
	
	ОбновитьСтатусНоменклатуры();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ТипНоменклатурыПриИзменении(Элемент)
	
	УстановитьВидимостьЭлементов();
	УстановкаВидимостиПолейСертификата();	
	
	Если Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") Тогда
		Объект.НормаВремени = ?(Объект.НормаВремени <> 0, Объект.НормаВремени, 30);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Тип номенклатуры обработка выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ТипНоменклатурыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандратнаяОбработка = Ложь;
	
	Если ВыбранноеЗначение <> ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") 
		И Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") И Не Объект.Ссылка.Пустая() Тогда
		
		Если НормыСписанияСуществуют(Объект.Ссылка) Тогда 
			
			ТекстВопроса = "Нормы списания материалов для данной услуги будут удалены. Продолжить?";
			ОписаниеОповещения = Новый ОписаниеОповещения("ТипНоменклатурыОбработкаВыбораЗавершение"
														  , ЭтотОбъект
														  , Новый Структура("ВыбранныйТипНоменклатуры", ВыбранноеЗначение));
			ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса,РежимДиалогаВопрос.ДаНет);
			Возврат;
			
		КонецЕсли;
	
		
	КонецЕсли;
	
	Если Не ВыбранноеЗначение = Объект.ТипНоменклатуры Тогда
		ТипНоменклатурыПриИзменении(Неопределено);           
	КонецЕсли;
	
КонецПроцедуры 

&НаСервереБезКонтекста
// Функция - Нормы списания существуют
// 
// Возвращаемое значение:
//   - 
//
Функция НормыСписанияСуществуют(Номенклатура)
	
	Возврат РегистрыСведений.НормыСписанияМатериалов.ЗаписиВРегистреДляНоменклатурыСуществуют(Номенклатура);
	
КонецФункции

&НаКлиенте
// Процедура - Тип номенклатуры обработка выбора завершение
//
// Параметры:
//  РезультатВопроса - 	 - 
//  ДопПараметры	 - 	 - 
//
Процедура ТипНоменклатурыОбработкаВыбораЗавершение(РезультатВопроса, ДопПараметры) Экспорт

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		
		УдалитьНормыСписанияМатериаловПоНоменклатуре(Объект.Ссылка);
		Объект.ТипНоменклатуры = ДопПараметры.ВыбранныйТипНоменклатуры;
		ТипНоменклатурыПриИзменении(Неопределено);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Удалить нормы списания материалов по номенклатуре
//
Процедура УдалитьНормыСписанияМатериаловПоНоменклатуре(Номенклатура)
	
	НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
	
	Попытка
		НаборЗаписей.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении", элемент "НаименованиеПолное"
//
Процедура НаименованиеПриИзменении(Элемент)
	
	Если ФормироватьНаименованиеПолноеАвтоматически Тогда
		Объект.НаименованиеПолное = Объект.Наименование;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// При изменении выбора специализации
//
Процедура СпециализацияПриИзменении(Элемент)
	УстановитьВидимостьЭлементов();
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость элементов формы.
//
// Параметры:
//  Нет.
//
Процедура УстановитьВидимостьЭлементов()
	
	ТекСтруктурнаяЕд = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;    	
	Если ЗначениеЗаполнено(ТекСтруктурнаяЕд) Тогда
		Элементы.СтавкаНДС.Видимость = ?(ТекСтруктурнаяЕд.Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая, Истина, Ложь);
		Если ЗначениеЗаполнено(ТекСтруктурнаяЕд.Организация)
			И Объект.Ссылка = Справочники.Номенклатура.ПустаяСсылка() Тогда
			
			Если ТекСтруктурнаяЕд.Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда
				Объект.СтавкаНДС =  ТекСтруктурнаяЕд.Организация.СтавкаНДС;
			Иначе
				Объект.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Элементы.СтавкаНДС.Видимость = Ложь;
	КонецЕсли;
	
	// Для типа подарочный сертификат	
	ЗаполнитьСписокВыбораСрокДействияСертификата();
	ЗаполнитьСписокВыбораВидаНоминалаСертификата();		
	
	ТипНоменклатурыЗапас     = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
	ТипНоменклатурыМатериал  = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал);
	ТипНоменклатурыИмущество = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Имущество);
	ТипНоменклатурыУслуга    = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга);
	ТипНоменклатурыНабор     = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор);
	
	Элементы.ГруппаХарактеристики.Видимость	= (НЕ ЗначениеЗаполнено(Объект.ТипНоменклатуры)) ИЛИ ТипНоменклатурыЗапас ИЛИ ТипНоменклатурыМатериал ИЛИ ТипНоменклатурыИмущество;
	Элементы.УпаковкаДляОтчета.Видимость 	= (ТипНоменклатурыЗапас ИЛИ ТипНоменклатурыМатериал ИЛИ ТипНоменклатурыИмущество);
	Элементы.УпаковкаПоУмолчанию.Видимость 	= (ТипНоменклатурыЗапас ИЛИ ТипНоменклатурыМатериал ИЛИ ТипНоменклатурыИмущество);
	Элементы.НормаВремени.Видимость 	    = ТипНоменклатурыУслуга;
	Элементы.Гарантия.Видимость 			= ТипНоменклатурыУслуга;	
	Элементы.GTIN.Видимость 			    = ТипНоменклатурыЗапас;
	Элементы.ГруппаКодУслуги.Видимость      = ТипНоменклатурыУслуга;
	
	Если Константы.ИспользоватьУЕТ.Получить() = Истина И ТипНоменклатурыУслуга Тогда
		Элементы.УЕТ.Видимость       		    = Истина;  
	Иначе 
		Элементы.УЕТ.Видимость       		    = Ложь; 
	КонецЕсли;
	
	Элементы.МатериалХарактеристики.Видимость       = Объект.ИспользоватьПартии;     	
	Элементы.НормыСписанияМатериалов.Видимость 		 = ТипНоменклатурыУслуга;
	Элементы.ОбязательноУказаниеАссистента.Видимость = ТипНоменклатурыУслуга;
	Элементы.ОбластиЗуубнойФормулы.Видимость    	 = ТипНоменклатурыУслуга;
	Элементы.СкидкиЗапрещены.Видимость          	 = НЕ ТипНоменклатурыИмущество;
    Элементы.ИнформацияОЦенах.Видимость         	 = НЕ ТипНоменклатурыИмущество;
    Элементы.Специализация.Видимость            	 = НЕ ТипНоменклатурыИмущество;
	// Элементы.СоставНабора.Видимость                  = ТипНоменклатурыНабор;  	
		
	Если НЕ ПравоДоступа("Изменение", Метаданные.Справочники.Номенклатура) Тогда
		Элементы.ОбластиЗуубнойФормулы.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если Элементы.ОбластиЗуубнойФормулы.ТолькоПросмотр Тогда
		Элементы.ДеревоСостоянийВыделитьВсе.Доступность = Ложь;
		Элементы.ДеревоСостоянийСнятьВсе.Доступность    = Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Специализация) Тогда
		Элементы.ОбластиЗуубнойФормулы.Видимость = Объект.Специализация.СтоматологическиеУслуги;
	Иначе
		Элементы.ОбластиЗуубнойФормулы.Видимость = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг();
	КонецЕсли;
	
	
	Элементы.ОбластиЗуубнойФормулы.Видимость 	 = НЕ ТипНоменклатурыНабор;
	// Элементы.ГруппаПраваяКолонкаШапки.Видимость  = НЕ ТипНоменклатурыНабор;
	Элементы.ГруппаСоставНабора.Видимость        = ТипНоменклатурыНабор;
	Элементы.Группа_Лаборатория_Скидки.Видимость = НЕ ТипНоменклатурыНабор;
	Элементы.ЕдиницаИзмерения.Видимость 	     = НЕ ТипНоменклатурыНабор И НЕ ТипНоменклатурыУслуга;
	Элементы.СтавкаНДС.Видимость 				 = НЕ ТипНоменклатурыНабор;
	Элементы.ИнформацияОЦенах.Видимость 		 = НЕ ТипНоменклатурыНабор;
	Элементы.Специализация.Видимость 			 = НЕ ТипНоменклатурыНабор;	
	
	Элементы.ГруппаНастройкаОнлайнЗаписи.Видимость = ЭтотОбъект.ОнлайнЗапись И ВернутьМассивСтруктурныхЕдиниц().Количество() > 1;
	Элементы.ГруппаОнлайнЗапись.Видимость          = ТипНоменклатурыУслуга;
	Элементы.ГруппаОнлайнЗаписи.Видимость		   = ЭтотОбъект.ОнлайнЗапись;
	Элементы.НеобходимоЗаписатьДокумент.Видимость  = Не ЗначениеЗаполнено(Объект.Ссылка);
	Элементы.ОткрытьГруппуСДеревомУслуг.Видимость  = ЭтотОбъект.ОнлайнЗапись;
	Элементы.ОписаниеДляОнлайнЗаписи.Видимость	   = ЭтотОбъект.ОнлайнЗапись;
		
	ЭтотОбъект.Элементы.ГруппаНормыСписанияМатериалов.Видимость = Ложь;
	
	ВывестиСсылкуНаТоварИЛИУслугу();
	
КонецПроцедуры

// Процедура - Вывести ссылку на товар ИЛИУслугу
//
Процедура ВывестиСсылкуНаТоварИЛИУслугу()
	
	ЭтоУслуга = Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
	
	Элементы.СсылкаНаТоварУслугу.Заголовок = "";
	Если ЭтотОбъект.ОнлайнЗапись = Истина И ЭтоУслуга Тогда		
		
		СтруктурнаяЕдиница = ПолучитьСтруктурнуюЕдиницуВиджета();		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) И Не Объект.Ссылка.Пустая() Тогда		
			
			УИДСалона = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "УникальныйИдентификаторСтруктурнойЕдиницы");
			Если УИДСалона = "" Тогда
				УИДСалона = Строка(СтруктурнаяЕдиница.УникальныйИдентификатор()); 
			КонецЕсли;
			
			Элементы.СсылкаНаТоварУслугу.Заголовок = "https://reservi.ru/stoma1c/" + УИДСалона + "/?service=" + Строка(Объект.Ссылка.УникальныйИдентификатор());	
			ВидимостьЭлемента = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	Элементы.ГруппаСсылкаНаТовар.Видимость = ЗначениеЗаполнено(Элементы.СсылкаНаТоварУслугу.Заголовок);	
	
КонецПроцедуры

// Функция - Получить структурную единицу онлайн магазина ИЛИВиджета
//
// Параметры:
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктурнуюЕдиницуВиджета()
	
	ТекущаяСтруктурнаяЕдиница	= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;	
	ВнешняяСистема				= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи);
	
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда		
		
		ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();			
		
		Если ПараметрыВнешнейСистемы <> Неопределено И ПараметрыВнешнейСистемы.Свойство("ИспользуемыеСтруктурныеЕдиницы") Тогда			
			Для Каждого СтруктурнаяЕдиница Из ПараметрыВнешнейСистемы.ИспользуемыеСтруктурныеЕдиницы Цикл
				Если ТекущаяСтруктурнаяЕдиница = СтруктурнаяЕдиница Тогда
					Возврат СтруктурнаяЕдиница;
				КонецЕсли;								
			КонецЦикла;			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Справочники.СтруктурныеЕдиницы.ПустаяСсылка();

КонецФункции

