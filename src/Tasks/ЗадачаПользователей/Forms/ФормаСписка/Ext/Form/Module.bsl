
#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы на серевер
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	#Если НЕ МобильноеПриложениеСервер Тогда
	Если НЕ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ОтображатьЗадачиВсехПользователей, Ложь)  Тогда

		ПоИсполнителю                      = ПараметрыСеанса.ТекущийПользователь;
		Элементы.ПоИсполнителю.Видимость   = Ложь;
		Элементы.ГрПоИсполнителю.Видимость = Ложь;
		
	КонецЕсли;
	#КонецЕсли
	
	Если Параметры.Свойство("Предмет") Тогда
		Клиент = Параметры.Предмет;	
	КонецЕсли;	
	
	УстановитьОтбор();

КонецПроцедуры

&НаСервере
// Обработчик загрузки настроек формы
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	#Если НЕ МобильноеПриложениеСервер Тогда
	Если НЕ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ОтображатьЗадачиВсехПользователей, Ложь)  Тогда

		ПоИсполнителю = ПараметрыСеанса.ТекущийПользователь;
				
	КонецЕсли;
	
	УстановитьОтбор();
	#КонецЕсли
		
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// при активации строки в таблице задачи
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено И  ТекущиеДанные.Свойство("Выполнена") Тогда 
		
		Элементы.ПринятьКИсполнению.Доступность  = Ложь;
		Элементы.ОтменитьНапоминание.Доступность = Ложь;
		Элементы.СписокКонтекстноеМенюОтменитьПринятиеКИсполнению.Доступность  = Ложь;
		Элементы.СписокКонтекстноеМенюПринятьКИсполнению.Доступность           = Ложь;
	
		Если НЕ ТекущиеДанные.Выполнена Тогда
			
			Если ТекущиеДанные.НеНапоминать Тогда
				
				Элементы.ПринятьКИсполнению.Доступность                                = Истина;
				Элементы.СписокКонтекстноеМенюПринятьКИсполнению.Доступность           = Истина;
				Элементы.ОтменитьНапоминание.Доступность                               = Ложь;
				Элементы.СписокКонтекстноеМенюОтменитьПринятиеКИсполнению.Доступность  = Ложь;

			Иначе
				
				Элементы.ПринятьКИсполнению.Доступность                                = Ложь;
				Элементы.СписокКонтекстноеМенюПринятьКИсполнению.Доступность           = Ложь;
				Элементы.ОтменитьНапоминание.Доступность                               = Истина;
				Элементы.СписокКонтекстноеМенюОтменитьПринятиеКИсполнению.Доступность  = Истина;

            КонецЕсли;
				
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик переопределения действий по выбору исполнителя
Процедура ПоИсполнителюНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Оповещение = Новый ОписаниеОповещения("ПоИсполнителюНачалоВыбораЗавершение", ЭтотОбъект);
	ОткрытьФорму("Задача.ЗадачаПользователей.Форма.ФормаВыбораИсполнителя",
	Новый Структура("Ключ",ПоИсполнителю),,,,,
	Оповещение, 
	РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

	
КонецПроцедуры

&НаКлиенте
// Процедура - После открытия формы выбора исполнителя
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ПоИсполнителюНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ПоИсполнителю  = ?(Результат <> Неопределено,Результат,ПоИсполнителю);
	КонецЕсли;         
	
	УстановитьОтбор();
	
КонецПроцедуры

&НаКлиенте
// Обработчик установки отбора по исполнителю
Процедура ПоИсполнителюПриИзменении(Элемент)
	
	УстановитьОтбор();
	
КонецПроцедуры

&НаКлиенте
// Обработчик установки отбора по автору
Процедура ПоАвторуПриИзменении(Элемент)
	
	УстановитьОтбор();
	
КонецПроцедуры

&НаКлиенте
// При изменении состояния флагов отображения задач
Процедура ПоказыватьЗадачиПриИзменении(Элемент)
	
	УстановитьОтбор();
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения статуса задачи
Процедура ПринятьКИсполнению(Команда)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда 

       Если ПринятьКисполнениюОтменитьСервер(ТекущиеДанные,Истина) Тогда
	       Элементы.Список.Обновить();
	   Иначе
		   ПоказатьПредупреждение(,"Задача уже выполнена!");
	   КонецЕсли;
	   
     КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения статуса задачи
Процедура ОтменитьПринятиеКИсполнению(Команда)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда 

       Если ПринятьКисполнениюОтменитьСервер(ТекущиеДанные,Ложь) Тогда
	        Элементы.Список.Обновить();
	   Иначе
			ПоказатьПредупреждение(,"Задача уже выполнена!");
	   КонецЕсли;
		
     КонецЕсли;

КонецПроцедуры

#КонецОбласти

