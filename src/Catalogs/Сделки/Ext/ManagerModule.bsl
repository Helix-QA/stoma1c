                                              
#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Функция - Инициализировать предопределенную сделку
//
// Параметры:
//  Контрагент			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  Врач				 - 	 - 
//  Специализация		 - 			 - 
//  ВидОсмотра			 - 			 - 
//  Записан				 - 			 - 
//  ГенерироватьСделку	 - 			 - 
//  ЭтапГенерации		 - 			 - 
//  ВключитьБизнесЛогику - 			 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПредопределеннуюСделку(Контрагент
											, СтруктурнаяЕдиница 	= Неопределено
											, Врач 					= Неопределено
											, Специализация 		= Неопределено
											, ВидОсмотра 			= Неопределено
											, Записан 				= Ложь
											, ГенерироватьСделку 	= Ложь
											, ЭтапГенерации 		= Неопределено
											, МассивСделокИсключения = Неопределено
											, ВключитьБизнесЛогику 	= Ложь) Экспорт
								
											
	Сделка = Неопределено;
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
		
	ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	Если НЕ ЗначениеЗаполнено(ВидСделки) Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось инициализировать предопределенную сделку по причине: Не инициализирован предопределенный вид сделки ""Первичный, повторный пациент""'");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Врач) Тогда
		Врач = Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;
	
	Попытка
		КоллекцияСделок = ПолучитьСделкиПоКлиенту(Контрагент
												, СтруктурнаяЕдиница
												, Истина
												, Врач
												, ?(ВидОсмотра = Перечисления.ВидыОсмотров.Направление, Специализация, Неопределено)
												, 
												, Истина
												, Ложь
												, Перечисления.РезультатыСделок.ПустаяСсылка()
												,
												,
												,
												, МассивСделокИсключения
												, ВидОсмотра);
												
		Если КоллекцияСделок.Количество() > 0 И ТипЗнч(КоллекцияСделок) = Тип("ТаблицаЗначений") Тогда
			Если ЗначениеЗаполнено(ВидОсмотра) Тогда 										
				СтркутураПоиска1 = Новый Структура("ВидСделки, СтруктурнаяЕдиница, Врач, Записан", ВидСделки, СтруктурнаяЕдиница, Врач, Записан);
			Иначе 
				СтркутураПоиска1 = Новый Структура("ВидСделки, СтруктурнаяЕдиница, Записан", ВидСделки, СтруктурнаяЕдиница, Записан);
			КонецЕсли;	
			КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(СтркутураПоиска1);
			Если КоллекцияСтрок.Количество() > 0 Тогда 
				Сделка = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), КоллекцияСделок[0], КоллекцияСтрок[КоллекцияСтрок.Количество()-1].Сделка);
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Сделка) И НЕ Записан Тогда 
				Если ЗначениеЗаполнено(ВидОсмотра) Тогда 										
					СтркутураПоиска2 = Новый Структура("ВидСделки, СтруктурнаяЕдиница, Врач, Записан", ВидСделки, СтруктурнаяЕдиница, Врач, Истина);
					КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(СтркутураПоиска2);
					Если КоллекцияСтрок.Количество() = 0 И ВидОсмотра = Перечисления.ВидыОсмотров.Направление И НЕ ЗначениеЗаполнено(Врач) И ЗначениеЗаполнено(Специализация) Тогда
						СтркутураПоиска2 = Новый Структура("ВидСделки, СтруктурнаяЕдиница, Специализация, Записан", ВидСделки, СтруктурнаяЕдиница, Специализация, Истина);
					КонецЕсли;	
				Иначе 
					СтркутураПоиска2 = Новый Структура("ВидСделки, СтруктурнаяЕдиница, Записан", ВидСделки, СтруктурнаяЕдиница, Истина);
				КонецЕсли;	
				КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(СтркутураПоиска2);
				Если КоллекцияСтрок.Количество() > 0 Тогда
					Записан = Истина;
					Сделка = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), КоллекцияСделок[0], КоллекцияСтрок[КоллекцияСтрок.Количество()-1].Сделка);
				КонецЕсли;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Сделка) И ЗначениеЗаполнено(Врач) И ЗначениеЗаполнено(Специализация) И ВидОсмотра = Перечисления.ВидыОсмотров.Направление Тогда 
				СтркутураПоиска = Новый Структура("ВидСделки, СтруктурнаяЕдиница, Специализация, Записан", ВидСделки, СтруктурнаяЕдиница, Специализация, Записан);
				КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(СтркутураПоиска);
				Если КоллекцияСтрок.Количество() > 0 Тогда 
					Сделка = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), КоллекцияСделок[0], КоллекцияСтрок[КоллекцияСтрок.Количество()-1].Сделка);
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
												
		
		Если ЗначениеЗаполнено(Сделка) Тогда 
			Возврат Сделка;		
		ИначеЕсли НЕ ГенерироватьСделку Тогда 
			Возврат Неопределено;
		КонецЕсли;
		
		// Формируем данные заполнения генерируемой сделки
		Если ЗначениеЗаполнено(ЭтапГенерации) Тогда 
			Если ТипЗнч(ЭтапГенерации) = Тип("Число") Тогда 
				ЭтапГенерации = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, ЭтапГенерации);
			ИначеЕсли НЕ ТипЗнч(ЭтапГенерации) = Тип("СправочникСсылка.ЭтапыСделок") Тогда 
        		ЭтапГенерации = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 3);
			КонецЕсли;
		Иначе 
        	ЭтапГенерации = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 1);
		КонецЕсли;	
					
		Если НЕ ЗначениеЗаполнено(ЭтапГенерации) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		ДанныеЗаполнения = Новый Структура();
		ДанныеЗаполнения.Вставить("ВидСделки"         		, ВидСделки);
		ДанныеЗаполнения.Вставить("Контрагент"        		, Контрагент);
		ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
		ДанныеЗаполнения.Вставить("ЭтапСделки"        		, ЭтапГенерации);
		ДанныеЗаполнения.Вставить("Врач"              		, Врач);
		ДанныеЗаполнения.Вставить("ИнтерактивнаяЗапись"		, Истина);
		ДанныеЗаполнения.Вставить("СформироватьНаименование", Истина);		
		
		ЗаякаПациента = Справочники.Заявки.ПолучитьЗаявкуКонтрагента(Контрагент,  , СтруктурнаяЕдиница, Истина);
		Если ЗначениеЗаполнено(ЗаякаПациента) Тогда
			ДанныеЗаполнения.Вставить("Заявка", ЗаякаПациента);	
		КонецЕсли;
		
		НоваяСделка = СоздатьНовуюСделку(ДанныеЗаполнения, ВключитьБизнесЛогику);
		Возврат НоваяСделка;
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// Функция - Создать новую сделку
//
// Параметры:
//  ДанныеГенерации	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьНовуюСделку(ДанныеГенерации, ВключитьБизнесЛогику = Ложь, ВернутьОбъект = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если ТипЗнч(ДанныеГенерации) = Тип("Структура") Тогда 
		
		Если ДанныеГенерации.Свойство("СсылкаНовойСделки") И ОбщегоНазначения.СсылкаСуществует(ДанныеГенерации.СсылкаНовойСделки) Тогда
			Возврат ДанныеГенерации.СсылкаНовойСделки;
		КонецЕсли;
		
		НоваяСделка = СоздатьЭлемент();
		НоваяСделка.Заполнить(ДанныеГенерации);
		Если ДанныеГенерации.Свойство("СсылкаНовойСделки") Тогда 
			НоваяСделка.УстановитьСсылкуНового(ДанныеГенерации.СсылкаНовойСделки);
		КонецЕсли;
		Если ДанныеГенерации.Свойство("ИнтерактивнаяЗапись") Тогда 
			НоваяСделка.ДополнительныеСвойства.Вставить("ИнтерактивнаяЗапись", Истина);
		КонецЕсли;
		Если ДанныеГенерации.Свойство("ЗаявкаСинхронизации") Тогда 
			НоваяСделка.ДополнительныеСвойства.Вставить("ЗаявкаСинхронизации", ДанныеГенерации.ЗаявкаСинхронизации);
		КонецЕсли;
		Если ДанныеГенерации.Свойство("НеобходимаГенерацияЗаявки") Тогда 
			НоваяСделка.ДополнительныеСвойства.Вставить("НеобходимаГенерацияЗаявки", ДанныеГенерации.НеобходимаГенерацияЗаявки);
		КонецЕсли;
		Если ДанныеГенерации.Свойство("КаналПривлечения") Тогда
			НоваяСделка.КаналПривлечения = ?(ЗначениеЗаполнено(ДанныеГенерации.КаналПривлечения), ДанныеГенерации.КаналПривлечения, НоваяСделка.КаналПривлечения);
			НоваяСделка.ДополнительныеСвойства.Вставить("КаналПривлечения", ДанныеГенерации.КаналПривлечения);
		КонецЕсли;
		Если ДанныеГенерации.Свойство("КаналПривлеченияЗначение") Тогда
			НоваяСделка.КаналПривлеченияЗначение = ?(ЗначениеЗаполнено(ДанныеГенерации.КаналПривлеченияЗначение), ДанныеГенерации.КаналПривлеченияЗначение, НоваяСделка.КаналПривлеченияЗначение);			
			НоваяСделка.ДополнительныеСвойства.Вставить("КаналПривлеченияЗначение", ДанныеГенерации.КаналПривлеченияЗначение);
		КонецЕсли;
		ЗадачаСделки = Неопределено;
		Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеГенерации, "СгенерироватьЗадачу", Ложь) Тогда
			ПараметрыЗадачи = Новый Структура;
			ПараметрыЗадачи.Вставить("НаправившийВрач", ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеГенерации, "НаправившийВрач", Неопределено));
			ЗадачаСделки = Задачи.Взаимодействие.ИнициализироватьЗадачуСделки(НоваяСделка
																			, ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеГенерации, "ВидОсмотра", Неопределено)
																			, ПараметрыЗадачи
																			, ВключитьБизнесЛогику
																			, Истина);
		КонецЕсли;	
		Попытка
			НоваяСделка.ОбменДанными.Загрузка = НЕ ВключитьБизнесЛогику;			
			НоваяСделка.Записать();
			Если НЕ ЗадачаСделки = Неопределено Тогда 
				ЗадачаСделки.Сделка = НоваяСделка.Ссылка;
				//ЗадачаСделки.ОбменДанными.Загрузка = НЕ ВключитьБизнесЛогику;				
				ЗадачаСделки.Записать();
			КонецЕсли;	
			Если ВернутьОбъект Тогда 
				Возврат НоваяСделка;
			Иначе 	
				Возврат НоваяСделка.Ссылка;
			КонецЕсли;	
		Исключение
			МетаданныеСправочника 		= Метаданные.Справочники.Сделки;
			ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
			
			ОбъектИнициации = Неопределено;
			ДанныеГенерации.Свойство("ОбъектИнициации", ОбъектИнициации);
			// Сформируем комментарий
			Если ОбъектИнициации = Неопределено Тогда 
				ШаблонКомментария = НСтр("ru = 'Не удалось создать новую сделку
				|по причине: %1'");
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонКомментария,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));				
			Иначе
				ПредставлениеОбъекта = СокрЛП(Строка(ОбъектИнициации));
				Если ТипЗнч(ОбъектИнициации) = Тип("ДокументСсылка.Прием") Тогда 
					ШаблонКомментария = НСтр("ru = 'При записи приема: %1, не удалось создать новую сделку
					|по причине: %2'");
				Иначе 
					ШаблонКомментария = НСтр("ru = 'При записи объекта: %1, не удалось создать новую сделку
					|по причине: %2'");
				КонецЕсли;	
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонКомментария,
				ПредставлениеОбъекта,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));				
			КонецЕсли;	
			
			// Запишем в журнал
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Создание сделки'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			МетаданныеСправочника,,
			Комментарий);
			
			ВызватьИсключение Комментарий;
		КонецПопытки;	
	КонецЕсли;	
	
	Возврат Неопределено;
	
КонецФункции

// Процедура - Проверить бизнес логику создания
//
// Параметры:
//  ГенерируемыйОбъект	 - 	 - 
//  СделкаАналог		 - 	 - 
//  Комментарий			 - 	 - 
//  СообщатьПользователю - 	 - 
//  Отказ				 - 	 - 
//
Процедура ПроверитьБизнесЛогикуСоздания(ГенерируемыйОбъект
										, СделкаАналог = Неопределено
										, Комментарий = ""
										, СообщатьПользователю = Ложь
										, Отказ = Ложь) Экспорт
										
	Если ЗначениеЗаполнено(СделкаАналог) Тогда 
		СделкаАналог = Справочники.Сделки.ПустаяСсылка();
	КонецЕсли;
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ГенерируемыйОбъект) = Тип("СправочникОбъект.Сделки") Тогда
		Если ГенерируемыйОбъект.ДополнительныеСвойства.Свойство("ИнтерактивнаяЗапись") И ГенерируемыйОбъект.ДополнительныеСвойства.ИнтерактивнаяЗапись = Истина Тогда
			// Проверка была произведена ранее из формы объекта. Уходим.
			Возврат;
		КонецЕсли;	
		ГенерируемаяСделка = ГенерируемыйОбъект;
	ИначеЕсли ТипЗнч(ГенерируемыйОбъект) = Тип("ФормаКлиентскогоПриложения") И ГенерируемыйОбъект.ИмяФормы = "Справочник.Сделки.Форма.ФормаЭлемента" Тогда
		ГенерируемаяСделка = ГенерируемыйОбъект.Объект;
	Иначе 
		Возврат;
	КонецЕсли;	
	
	ЭтоСозданиеСделки = НЕ ЗначениеЗаполнено(ГенерируемаяСделка.Ссылка);
	
	ИзмененыИзмеренияЛогикиУникальностиСделок = НЕ ЭтоСозданиеСделки 
												И (ГенерируемаяСделка.СтруктурнаяЕдиница <> ГенерируемаяСделка.Ссылка.СтруктурнаяЕдиница
												ИЛИ ГенерируемаяСделка.Контрагент <> ГенерируемаяСделка.Ссылка.Контрагент
												ИЛИ ГенерируемаяСделка.Врач <> ГенерируемаяСделка.Ссылка.Врач
												ИЛИ (ГенерируемаяСделка.Врач = ГенерируемаяСделка.Ссылка.Врач И ГенерируемаяСделка.Специализация <> ГенерируемаяСделка.Ссылка.Специализация));

	Если НЕ ЗначениеЗаполнено(ГенерируемаяСделка.ВидСделки) 
		ИЛИ (НЕ ЭтоСозданиеСделки И (НЕ ИзмененыИзмеренияЛогикиУникальностиСделок ИЛИ ЗначениеЗаполнено(ГенерируемаяСделка.РезультатСделки))) Тогда 
		Возврат;
	КонецЕсли;
		
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ГенерируемаяСделка.СтруктурнаяЕдиница) Тогда 
		СтруктурнаяЕдиница 	= ГенерируемаяСделка.СтруктурнаяЕдиница
	Иначе 	
		СтруктурнаяЕдиница 	= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ГенерируемаяСделка.Контрагент) Тогда 
		Пациент 			= ГенерируемаяСделка.Контрагент;
		//СтатусПациента 		= РегистрыСведений.СтатусыКонтрагентов.ПолучитьСтатусКлиента(Пациент, ТекущаяДатаСеанса(), , Перечисления.СтатусыКонтрагентов.Потенциальный);
	Иначе 
		Пациент 			= Справочники.Контрагенты.ПустаяСсылка();																				
		//СтатусПациента 		= Перечисления.СтатусыКонтрагентов.Потенциальный;
	КонецЕсли;	
