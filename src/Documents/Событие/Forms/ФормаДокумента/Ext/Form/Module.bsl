		СписокВеремени 		= ВернутьСписокВремени(МассивПериодов, Истина, ОпределнениеИнтервалаВремени(ИнтервалГрафика));		
		НачальноеЗначение 	= СписокВеремени.НайтиПоЗначению(ТекущаяСтрока.ДатаНачала);		

		ПоказатьВыборИзСписка(Новый ОписаниеОповещения("ТЧУслугиДатаНачалаПослеВыбораИзСписка", ЭтотОбъект, Новый Структура("Элемент, СтрокаВвода", Элемент, ТекущаяСтрока)), СписокВеремени, Элемент, НачальноеЗначение);
		
