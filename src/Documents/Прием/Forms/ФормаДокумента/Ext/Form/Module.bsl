// Процедура, обработчик события "АвтоПодбор"
//
Процедура КонтрагентАвтоПодбор(Элемент, Текст, ДанныеВыбора, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Не ЗначениеЗаполнено(Текст);
	
	Если СтрДлина(Текст) >= 3 Тогда
				
		ДанныеВыбора = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(Текст, 10, Истина, Истина);
		
	Иначе
		
		СписокКонтрагентов = Новый СписокЗначений;
		СписокКонтрагентов.Добавить(Неопределено, "Для поиска необходимо ввести 3 и более символа.");		
		ДанныеВыбора = СписокКонтрагентов;
		
	КонецЕсли;
		
