
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Контрагент", Пациент);
	ЗаполнитьТаблицуПриемов();	
	Элементы.ТаблицаПриемов.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВсеУровни;
	ТипЗубнойФормулы = ?(ЗначениеЗаполнено(Пациент), Пациент.ТипЗубнойФормулы, 0);
	HTML             = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст(); 
	УстановитьЗубнуюФормулу();
	SVGМассивСтатусовЗубов     = "var status = ''";
	SVGМассивОбластей          = "var ColorStatus = ''";
	Если ТипЗубнойФормулы = 1 Тогда
		ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовокДФ").ПолучитьТекст();
	Иначе
		ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовок").ПолучитьТекст();
	КонецЕсли;		
	ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var ReadOnly = false;", "var ReadOnly = true;");
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

 &НаКлиенте 
// Процедура, Обработчик события "ТаблицаПриемовПриАктивизацииСтроки"
//
Процедура ТаблицаПриемовПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущиеДанные <> Неопределено И ЗначениеЗаполнено(Элемент.ТекущиеДанные.Ссылка) Тогда 
		Прием = Элемент.ТекущиеДанные.Ссылка;
		СтруктураДанных = ПолучитьИнформациюИзТекущегоПриема(Прием);
		СтатусыЗубов.Очистить();
		СостоянияЗубов.Очистить();
		Услуги.Очистить();
		
		Если ЗначениеЗаполнено(СтруктураДанных) Тогда
			Для Каждого СтрокаТЧ из СтруктураДанных.Статусы Цикл
				НоваяСтрока = СтатусыЗубов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;
			
			Для Каждого СтрокаТЧ из СтруктураДанных.Состояния Цикл
				НоваяСтрока = СостоянияЗубов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;
			
			Если СтруктураДанных.ТипЗубнойФормулы <> ТипЗубнойФормулы Тогда 
				ТипЗубнойФормулы = СтруктураДанных.ТипЗубнойФормулы; 
				ПолучитьМакетНаСервере();
			КонецЕсли; 	  			
			
			Для Каждого СтрокаТЧ из СтруктураДанных.МассивУслуг Цикл
				НоваяСтрока = Услуги.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;  
			
			ЗаполнитьОбследованиеПоТекущемуПриему(СтруктураДанных.МассивОбследований); 
		КонецЕсли;	
		
		ОбновитьДокумент();
		
	Иначе
		СтатусыЗубов.Очистить();
		СостоянияЗубов.Очистить(); 
		
		СтруктураДанных = ПолучитьИнформациюИзТекущегоПриема(Новый Структура("Контрагент, Дата", Пациент, ТекущаяДата())); 
				
		Для Каждого СтрокаТЧ из СтруктураДанных.Статусы Цикл
			НоваяСтрока = СтатусыЗубов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		КонецЦикла; 
		
		Для Каждого СтрокаТЧ из СтруктураДанных.Состояния Цикл
			НоваяСтрока = СостоянияЗубов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		КонецЦикла;	
		
		ОбновитьДокумент();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте 
// Процедура, Обработчик события "ТаблицаПриемовВыбор".
//
Процедура ТаблицаПриемовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		ПоказатьЗначение(, Элемент.ТекущиеДанные.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить информацию из текущего приема
//
// Параметры:
//  Прием	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьИнформациюИзТекущегоПриема(Прием)
	Возврат Документы.Прием.ПолучитьИнформациюИзТекущегоПриема(Прием);	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере 
// Процедура, Обработчик события "ЗаполнитьТаблицуПриемов".
//
Процедура ЗаполнитьТаблицуПриемов()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Ссылка КАК Ссылка,
	|	Прием.Дата КАК Дата,
	|	Прием.Номер КАК Номер,
	|	Прием.Сотрудник КАК Сотрудник,
	|	Прием.СуммаДокумента КАК СуммаДокумента,
	|	Прием.СуммаОплачено КАК СуммаОплачено,
	|	Прием.ПолисМедСтрахования КАК ПолисМедСтрахования,
	|	Прием.СтруктурнаяЕдиница.Представление КАК СтруктурнаяЕдиница,
	|	ЕСТЬNULL(ВложенныйЗапрос.Специализация, ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)) КАК Специализация,
	|	Прием.КурсЛечения КАК КурсЛечения,
	|	Прием.ЛечениеВрача КАК ЛечениеВрача,
	|	ВЫБОР
	|		КОГДА Прием.Проведен
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК Картинка,
	|	Прием.Комментарий КАК Комментарий,
	|	Прием.Представление КАК Представление,
	|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
	|	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема
	|ИЗ
	|	Документ.Прием КАК Прием
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СотрудникиСпецилазацииСотрудника.Специализация КАК Специализация,
	|			СотрудникиСпецилазацииСотрудника.Ссылка КАК Ссылка
	|		ИЗ
	|			Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|		ГДЕ
	|			СотрудникиСпецилазацииСотрудника.Основная
	|			И НЕ СотрудникиСпецилазацииСотрудника.Специализация.ПометкаУдаления) КАК ВложенныйЗапрос
	|		ПО Прием.Сотрудник = ВложенныйЗапрос.Ссылка
	|ГДЕ
	|	НЕ Прием.ПометкаУдаления
	|	И Прием.Контрагент = &Контрагент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|ИТОГИ ПО
	|	КурсЛечения,
	|	ЛечениеВрача");  
	
	Запрос.УстановитьПараметр("Контрагент", Пациент);
	УстановитьПривилегированныйРежим(Истина); 
	ВыборкаКурсовЛечения = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 	   
	
	Пока ВыборкаКурсовЛечения.Следующий() Цикл 	
		Если ЗначениеЗаполнено(ВыборкаКурсовЛечения.КурсЛечения) Тогда
			СтрокаДереваКурсовЛечения = ТаблицаПриемов.ПолучитьЭлементы().Добавить();
			СтруктураКурсаЛечения     = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ВыборкаКурсовЛечения.КурсЛечения, "ДатаНачала, ДатаОкончания");
			ПредставлениеКурсаЛечения = "Курс лечения" + ?(ЗначениеЗаполнено(СтруктураКурсаЛечения.ДатаНачала),  " с " + Формат(СтруктураКурсаЛечения.ДатаНачала, "ДФ=dd.MM.yyyy"), "") 
			+ ?(ЗначениеЗаполнено(СтруктураКурсаЛечения.ДатаОкончания), " по " + Формат(СтруктураКурсаЛечения.ДатаОкончания, "ДФ=dd.MM.yyyy"), ""); 
			СтрокаДереваКурсовЛечения.ДокументПредставление = ПредставлениеКурсаЛечения;  
			СтрокаДереваКурсовЛечения.Картинка = 3;
			ВыборкаЛечения       = ВыборкаКурсовЛечения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
			Пока ВыборкаЛечения.Следующий() Цикл 				
				СтруктураЛечения    = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ВыборкаЛечения.ЛечениеВрача, "Сотрудник, ДатаНачала, ДатаОкончания"); 							
				СтрокаДереваЛечений = СтрокаДереваКурсовЛечения.ПолучитьЭлементы().Добавить(); 
				Если ЗначениеЗаполнено(СтруктураЛечения.Сотрудник) Тогда
					СтруктураСотрудника     = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтруктураЛечения.Сотрудник, "НаименованиеСокращенное, Наименование");
					ПредставлениеСотрудника = ?(ЗначениеЗаполнено(СтруктураСотрудника.НаименованиеСокращенное), СтруктураСотрудника.НаименованиеСокращенное, 
					?(ЗначениеЗаполнено(СтруктураСотрудника.Наименование), СтруктураСотрудника.Наименование, ""));  
					СтрокаДереваЛечений.Сотрудник = СтруктураЛечения.Сотрудник;
				Иначе
					ПредставлениеСотрудника = "";
				КонецЕсли;
				ПредставлениеЛечения = "Лечение" + ?(ЗначениеЗаполнено(ПредставлениеСотрудника), " у " + ПредставлениеСотрудника, "") +
				?(ЗначениеЗаполнено(СтруктураЛечения.ДатаНачала), " с " + Формат(СтруктураЛечения.ДатаНачала, "ДФ=dd.MM.yyyy"), "") 
				+ ?(ЗначениеЗаполнено(СтруктураЛечения.ДатаОкончания), " по " + Формат(СтруктураЛечения.ДатаОкончания, "ДФ=dd.MM.yyyy"), "");			
				СтрокаДереваЛечений.ДокументПредставление = ПредставлениеЛечения;
				СтрокаДереваЛечений.Картинка = 3;
				ДетальныеЗаписи = ВыборкаЛечения.Выбрать();
				Пока ДетальныеЗаписи.Следующий() Цикл 
					СтрокаДерева        = СтрокаДереваЛечений.ПолучитьЭлементы().Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаДерева, ДетальныеЗаписи);	
					ДатаПриема          = Формат(ДетальныеЗаписи.Дата, "ДЛФ=DD");
					ПредставлениеПриема = "Прием №" + ДетальныеЗаписи.Номер + ?(ЗначениеЗаполнено(ДетальныеЗаписи.ВремяНачалаПриема), ?(ЗначениеЗаполнено(ДетальныеЗаписи.ВремяОкончанияПриема), " окончен в "+
					                      Формат(ДетальныеЗаписи.ВремяОкончанияПриема, "ДФ=ЧЧ:мм") + ", ", "начат в " + Формат(ДетальныеЗаписи.ВремяНачалаПриема, "ДФ=ЧЧ:мм") + ", "), " от ") + 
										  Лев(ДатаПриема, СтрДлина(ДатаПриема) - 2); 					 
					СтрокаДерева.ДокументПредставление = ПредставлениеПриема; 				
				КонецЦикла;
			КонецЦикла; 
		Иначе 
			ВыборкаЛечения = ВыборкаКурсовЛечения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
			Пока ВыборкаЛечения.Следующий() Цикл
				ДетальныеЗаписи = ВыборкаЛечения.Выбрать();
				Пока ДетальныеЗаписи.Следующий() Цикл
					СтрокаДерева = ТаблицаПриемов.ПолучитьЭлементы().Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаДерева, ДетальныеЗаписи);  
					ДатаПриема          = Формат(ДетальныеЗаписи.Дата, "ДЛФ=DD");
					ПредставлениеПриема = "Прием №" + ДетальныеЗаписи.Номер + ?(ЗначениеЗаполнено(ДетальныеЗаписи.ВремяНачалаПриема), ?(ЗначениеЗаполнено(ДетальныеЗаписи.ВремяОкончанияПриема), " окончен в "+
					                      Формат(ДетальныеЗаписи.ВремяОкончанияПриема, "ДФ=ЧЧ:мм") + ", ", "начат в " + Формат(ДетальныеЗаписи.ВремяНачалаПриема, "ДФ=ЧЧ:мм") + ", "), " от ") + 
										  Лев(ДатаПриема, СтрДлина(ДатаПриема) - 2);					 
					СтрокаДерева.ДокументПредставление = ПредставлениеПриема;	
				КонецЦикла;  
			КонецЦикла;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры   

&НаКлиенте 
// Процедура, заполняет поле html обследование, значениями обследования из массива.
//
Процедура ЗаполнитьОбследованиеПоТекущемуПриему(МассивОбследований)
	
	ТекстОбследования =
	"<!DOCTYPE html>
	|<html>
	|<head>
	|<title>HTML Дневник</title>
	|</head>
	|<body> 
	|<h3 align=""center"" style=""color:Black""> Дневник </h3>
	|</body>
	|</html>
	|<style>
	|p {
	|margin-top: 0.3em; /* Отступ сверху */
	|margin-bottom: 0.3em; /* Отступ снизу */
	|}
	|</style>
	|</head>
	|<body>"; 
	
	Для Каждого СтрокаТ Из МассивОбследований Цикл
		ТекстОбследования = ТекстОбследования + "<p><b>"+СтрокаТ.РеквизитНаименование + ":"+"</b><p>" + "<p style=""margin-left: 40px"">"+ СтрокаТ.РеквизитЗначение +"<p>";
	КонецЦикла;
	
	HTMLДокумент = ТекстОбследования;
	
КонецПроцедуры	

&НаСервере
// Процедура, выполняет получение макета ЗФ
//
Процедура УстановитьЗубнуюФормулу()
	
	Если ТипЗубнойФормулы = 1 Тогда
		mSvg  = ПолучитьОбщийМакет("SVGПодборДетский").ПолучитьТекст();
	Иначе
		mSvg  = ПолучитьОбщийМакет("SVGПодборВзрослый").ПолучитьТекст();
	КонецЕсли;
	mHTML = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст();
	Svg = СтрЗаменить(mHTML, "SVGElement", mSvg); 
	Svg = СтрЗаменить(Svg, "document.getElementById('Layer_1').setAttributeNS(null, 'height', window.innerHeight+'px')", "document.getElementById('Layer_1').setAttributeNS(null, 'height', (window.innerHeight - 15)+'px')");
	
КонецПроцедуры

&НаСервере 
// Функция - Получить макет на сервере
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьМакетНаСервере()
	
	Если ТипЗубнойФормулы = 1 Тогда
		ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовокДФ").ПолучитьТекст();
	Иначе
		ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовок").ПолучитьТекст();
	КонецЕсли;		
	ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var ReadOnly = false;", "var ReadOnly = true;");
		
КонецФункции    

&НаКлиенте
// Процедура, обновляет картинку подбора зубов
//
Процедура ОбновитьДокумент()
		
	ЗубнаяФормулаSVGBody = ФормированиеSVGКлиентСервер.СформироватьЗубнуюФормулу(СтатусыЗубов, ?(ТипЗубнойФормулы = 1, Истина, Ложь));
		
	мМассивСтатусовЗубов = "var  status = '";
	Для Каждого СтокаТЧ из СтатусыЗубов Цикл
		Если СтокаТЧ.СтатусЗуба <> "0" Тогда
			мМассивСтатусовЗубов = мМассивСтатусовЗубов + "Об" + СтокаТЧ.Зуб + "|"+СтокаТЧ.СтатусЗуба+"|";									
		КонецЕсли;
	КонецЦикла;		
	
	Если СтрДлина(мМассивСтатусовЗубов) > 15 Тогда
		мМассивСтатусовЗубов = Сред(мМассивСтатусовЗубов, 1, СтрДлина(мМассивСтатусовЗубов)-1);
	КонецЕсли;
	мМассивСтатусовЗубов = мМассивСтатусовЗубов + "';";
	
	мМассивОбластей = "var ColorStatus = '";
	Для Каждого СтрокаТЧ из СостоянияЗубов Цикл
		Если мМассивОбластей <> "var ColorStatus = '" Тогда
			мМассивОбластей = мМассивОбластей + "|Об" + Строка(СтрокаТЧ.Зуб) + СтрокаТЧ.Область + "|"+ СтрокаТЧ.Цвет + "|" + СтрокаТЧ.Состояние;				
		Иначе
			мМассивОбластей = мМассивОбластей + "Об" + Строка(СтрокаТЧ.Зуб) + СтрокаТЧ.Область + "|"+ СтрокаТЧ.Цвет + "|" + СтрокаТЧ.Состояние;
		КонецЕсли;
	КонецЦикла;
	мМассивОбластей 		  = мМассивОбластей + "'";
	ЗубнаяФормулаSVG 		  = СтрЗаменить(ЗубнаяФормулаSVG, SVGМассивОбластей, мМассивОбластей);
	SVGМассивОбластей 		  = мМассивОбластей; 
	
	ЗубнаяФормулаSVG 		  = СтрЗаменить(ЗубнаяФормулаSVG, SVGМассивСтатусовЗубов, мМассивСтатусовЗубов);
	SVGМассивСтатусовЗубов 	  = мМассивСтатусовЗубов;
	
	mSVG 					  = СтрЗаменить(HTML, "SVGElement", ЗубнаяФормулаSVG + ЗубнаяФормулаSVGBody);
	HTMLДокументЗубнаяФормула = mSVG;
	
КонецПроцедуры  

#КонецОбласти
