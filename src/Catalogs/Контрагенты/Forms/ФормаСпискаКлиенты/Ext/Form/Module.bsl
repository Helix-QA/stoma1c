// Процедура, обработчик завершения процедуры "ПредставлениеДатаВизитаНажатие".
//
Процедура ПредставлениеДатаПриемаПриИзмененииЗавершение(НовыйПериод, Параметры) Экспорт
	
	Если НовыйПериод = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(НовыйПериод)=Тип("СтандартныйПериод") Тогда
		ОтборДатаПриема = НовыйПериод;
	ИначеЕсли ТипЗнч(НовыйПериод)=Тип("Дата") Тогда
		ОтборДатаПриема.ДатаОкончания = НовыйПериод;
	КонецЕсли;
	
	ПредставлениеДатаПриема = РаботаСОтборами.ОбновитьПредставлениеПериода(ОтборДатаПриема, "Дата приема: ");
	
	#Если ВебКлиент Тогда
		ОбновитьОтображениеДанных();
	#КонецЕсли 
	
	УстановитьЗапросДинамическогоСписка();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ПриИзменении
//
Процедура РасширенныйПоискПриИзменении(Элемент)
	
	Если РасширенныйПоиск <> "" Тогда
		
		Если Элементы.Список.Отображение <> ОтображениеТаблицы.Список Тогда
			Результат = Неопределено;

			ПоказатьВопрос(Новый ОписаниеОповещения("РасширенныйПоискПриИзмененииЗавершение", ЭтотОбъект), 
			НСтр("ru='Рекомендуется включить режим отображения списком. Включить отображения списком?'"), РежимДиалогаВопрос.ДаНет);
			Возврат;
			
		КонецЕсли;
		
		ДанныеВыбора = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(РасширенныйПоиск, , Истина,,,,,, Истина);
		
		// установить отбор по списку найденных партнеров
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(ЭтаФорма.Список, "Ссылка", ДанныеВыбора, Истина, ВидСравненияКомпоновкиДанных.ВСписке);
		
	Иначе
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Ссылка");		
	КонецЕсли;
	
	Элементы.Список.Обновить();	
	
КонецПроцедуры

&НаКлиенте
Процедура РасширенныйПоискПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Результат = РезультатВопроса; 
	Если Результат = КодВозвратаДиалога.Да Тогда
		Элементы.Список.Отображение = ОтображениеТаблицы.Список;
	КонецЕсли;
	
	ДанныеВыбора = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(РасширенныйПоиск, , Истина,,,,,, Истина);
	
	// установить отбор по списку найденных партнеров
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(ЭтаФорма.Список, "Ссылка", ДанныеВыбора, Истина, ВидСравненияКомпоновкиДанных.ВСписке);
	
	Элементы.Список.Обновить();	
	
КонецПроцедуры
 
