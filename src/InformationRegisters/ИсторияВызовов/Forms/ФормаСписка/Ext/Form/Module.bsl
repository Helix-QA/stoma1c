
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
	Если Параметры.Свойство("УстановитьТекущуюСтруктурнуюЕдиницу") Тогда 
		ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; 
	Иначе
		ОтборСтруктурнаяЕдиница = ХранилищеОбщихНастроек.Загрузить("ИсторияВызовов","СтруктурнаяЕдиница");
	КонецЕсли;	
	
	Если Параметры.Свойство("ОтборТипЗвонка") Тогда 
		Параметры.Свойство("ОтборТипЗвонка", ОтборТипЗвонка);
	Иначе 
		ОтборТипЗвонка = 3; // по умолчанию все звонки
	КонецЕсли;
	ПолныеПрава = РольДоступна("ПолныеПрава") или РольДоступна("ЧтениеИсторииВызовов");
	
	// Если открываем не через "Все функции" - то скрываем не нужные колонки
	Параметры.Свойство("ОтобразитьПользовательскийВидФормы", ОтобразитьПользовательскийВидФормы);
	Если ОтобразитьПользовательскийВидФормы Тогда
		Элементы.ОборудованиеТелефонии.Видимость 		= Ложь;		
		Элементы.IDЗвонка.Видимость 					= Ложь;
		
		//Элементы.ИсходящийЗвонок.Видимость 			= Ложь;		
		//Элементы.НачалоВызова.Видимость 				= Ложь;
		Элементы.ФайлЗаписи.Видимость 					= Ложь;
		Элементы.ОкончаниеЗвонка.Видимость 				= Ложь;
		Элементы.URLЗаписиСсылка.Видимость 				= Ложь;
		Элементы.ПопытокПолученияФайлаЗаписи.Видимость 	= Ложь;
		Элементы.НеОбработан.Видимость 					= Ложь;
	КонецЕсли;
	
	ДоступныеНомера = ПолучитьДоступныеНомера();
	
	// Загрузим в список номера контрагента
	Если Параметры.Свойство("СписокНомеровТелефонов") Тогда
		Для Каждого ЭлементСпискаНомеровКонтрагента Из Параметры.СписокНомеровТелефонов Цикл 
			Если СписокНомеров.НайтиПоЗначению(ЭлементСпискаНомеровКонтрагента.Значение) = Неопределено Тогда 
				СписокНомеров.Добавить(ЭлементСпискаНомеровКонтрагента.Значение, , Истина);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Загрузим в список внутренние номера
	Параметры.Свойство("ТелефонныйАппарат", ОтборПользовательSIP);
	Если ЗначениеЗаполнено(ОтборПользовательSIP) Тогда 
		Если Параметры.Свойство("ВнутреннийНомер") И Параметры.Свойство("ВнутреннийНомерРодителя") Тогда
			
			Если ЗначениеЗаполнено(Параметры.ВнутреннийНомер) 
				И (ПолныеПрава Или ДоступныеНомера.Найти(Параметры.ВнутреннийНомер) <> Неопределено) Тогда
				
				СписокНомеров.Добавить(Параметры.ВнутреннийНомер, , Ложь);
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Параметры.ВнутреннийНомерРодителя) 
				И (ПолныеПрава Или ДоступныеНомера.Найти(Параметры.ВнутреннийНомерРодителя) <> Неопределено) Тогда
				
				СписокНомеров.Добавить(Параметры.ВнутреннийНомерРодителя, , Ложь);
			КонецЕсли;	
		Иначе
			Если ЗначениеЗаполнено(ОтборПользовательSIP.ВнутреннийНомер) 
				И (ПолныеПрава Или ДоступныеНомера.Найти(Параметры.ВнутреннийНомер) <> Неопределено) Тогда
				СписокНомеров.Добавить(ОтборПользовательSIP.ВнутреннийНомер	, , Ложь);
			КонецЕсли;
			Если НЕ ОтборПользовательSIP.ЭтоГруппа И ЗначениеЗаполнено(ОтборПользовательSIP.Родитель.ВнутреннийНомер) 
				И (ПолныеПрава Или  ДоступныеНомера.Найти(ОтборПользовательSIP.Родитель.ВнутреннийНомер) <> Неопределено) Тогда
				СписокНомеров.Добавить(ОтборПользовательSIP.Родитель.ВнутреннийНомер, , Ложь);
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;	
	
	УстановитьОтборПоПользователюSip(Истина);
	
	Если Параметры.Свойство("ОтборПериод") Тогда	
		ОтборПериод = Параметры.ОтборПериод;
	Иначе
		ОтборПериод = ХранилищеОбщихНастроек.Загрузить("ИсторияВызовов","Период");	
	КонецЕсли;	      
	
	УстановитьОтборПоПериоду(Истина);
	
	КоличествоНеОбработанныхЗвонков = ВернутьКоличествоНеОбработанныхЗвонков(ОтборПериод, СписокНомеров);
	УстановитьОтборПоТипуЗвонка();

	УстановитьОтборПоСтруктурнойЕдинице(Истина);

	Элементы.СписокКонтекстноеМенюКнопкаОткрытьФормуЗаписи.Видимость = ПолныеПрава;
	
	Список.Параметры.УстановитьЗначениеПараметра("ДоступныеНомера", ДоступныеНомера);
	Список.Параметры.УстановитьЗначениеПараметра("ПолныеПрава"    , ПолныеПрава);
	
	УстановитьКоличествоЗвонков(ПолныеПрава, ДоступныеНомера);
	
	Если РольДоступна(Метаданные.Роли.ПолныеПрава) Тогда
		ПроверкаПодключеннойТелефонии();
	КонецЕсли;                   
	
	СоздатьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_КОЛИЧЕСТВО_НЕ_ОБРАБОТАННЫХ" Тогда 
		Если ЭтаФорма.КлючУникальности = Параметр ИЛИ НЕ ОтобразитьПользовательскийВидФормы Тогда
			АктуализироватьКоличествоНеОбработанныхЗвонков();
		КонецЕсли;
	КонецЕсли;	
	
	Если ИмяСобытия = "ОбновитьСписокИсторииЗвонков" Тогда
		Элементы.Список.Обновить();
		УстановитьКоличествоЗвонков();
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
// Процедура, ПередЗакрытием
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ЗавершениеРаботы Тогда
		
		ЗапомнитьНастройкиСписка(ОтборСтруктурнаяЕдиница, ОтборПериод); 
		
	КонецЕсли;  
	
КонецПроцедуры

#КонецОбласти

