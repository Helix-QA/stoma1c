//
//
Процедура ЗаполнитьРеквизитПриемВНарядЗаказе____И____ПроставитьСоответствующиеСтатусы(МассивНарядЗаказов, ТаблицаУдаляемыхСтрок, РежимЗаписиПриема, Отказ)
	
	Если НЕ Отказ Тогда 
		
		ТаблицаОбщихСтатусовНарядЗаказов = ОбщегоНазначенияСтоматология.ВернутьТаблицуСтатусовНарядЗаказов(МассивНарядЗаказов);
		
		Для Каждого НарядЗаказ Из МассивНарядЗаказов Цикл 
			МассивНайденныхСтрокВ_ТЧ_Лечение 	= Лечение.НайтиСтроки(Новый Структура("ДокументАванса", НарядЗаказ));
			МассивНайденныхСтрокВ_ТЧ_Запасы 	= Запасы.НайтиСтроки(Новый Структура("ДокументАванса", НарядЗаказ));			
			МассивУдаляемыхСтрок				= ?(ТаблицаУдаляемыхСтрок = Неопределено, Новый Массив, ТаблицаУдаляемыхСтрок.НайтиСтроки(Новый Структура("ДокументАванса", НарядЗаказ)));
			Если МассивНайденныхСтрокВ_ТЧ_Лечение.Количество() > 0 ИЛИ МассивНайденныхСтрокВ_ТЧ_Запасы.Количество() > 0  ИЛИ МассивУдаляемыхСтрок.Количество() > 0 Тогда 
				НарядЗаказОбъект = НарядЗаказ.ПолучитьОбъект();
				
				Для Каждого УдаляемаяСтрока Из МассивУдаляемыхСтрок Цикл 
					СтрокаТЧЗапасы_НарядЗаказ = НарядЗаказОбъект.Запасы.Найти(УдаляемаяСтрока.КлючСтроки, "КлючСтроки");
					Если СтрокаТЧЗапасы_НарядЗаказ <> Неопределено Тогда				
						СтрокаТЧЗапасы_НарядЗаказ.Прием = Документы.Прием.ПустаяСсылка();		
					КонецЕсли;
				КонецЦикла;
				
				// Работа с найденными строками в ТЧ Лечение
				Для Каждого НайденнаяСтрокаВ_ТЧ_Лечение Из МассивНайденныхСтрокВ_ТЧ_Лечение Цикл 
					СтрокаТЧЗапасы_НарядЗаказ = НарядЗаказОбъект.Запасы.Найти(НайденнаяСтрокаВ_ТЧ_Лечение.КлючСтроки, "КлючСтроки");
					Если СтрокаТЧЗапасы_НарядЗаказ <> Неопределено Тогда
						
						Если РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда
							СтрокаТЧЗапасы_НарядЗаказ.Прием = Документы.Прием.ПустаяСсылка();
						Иначе
							Если ЗначениеЗаполнено(СтрокаТЧЗапасы_НарядЗаказ.Прием) И НЕ СтрокаТЧЗапасы_НарядЗаказ.Прием = Ссылка Тогда 
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приём не может быть проведен, так как данные услуги уже проведенны в " 
								+ Строка(СтрокаТЧЗапасы_НарядЗаказ.Прием) + " ! ");
								Отказ = Истина;
								Возврат;
							Иначе	
								
								ПараметрыИспользованияЕдиницНоменклатуры = ИспользованоКоличествоПоНарядЗаказу("Лечение", НарядЗаказ, НайденнаяСтрокаВ_ТЧ_Лечение.Зуб, НайденнаяСтрокаВ_ТЧ_Лечение.Номенклатура, НайденнаяСтрокаВ_ТЧ_Лечение.Упаковка, СтрокаТЧЗапасы_НарядЗаказ.КлючСтроки);
						        ДоступноКИспользованию = СтрокаТЧЗапасы_НарядЗаказ.КоличествоУпаковок - ПараметрыИспользованияЕдиницНоменклатуры.КоличествоУпаковок; 
								
								Если ДоступноКИспользованию >= 0 Тогда
									// Пишем Ссылку
									СтрокаТЧЗапасы_НарядЗаказ.Прием = Ссылка;
								Иначе
									Если НЕ (ДополнительныеСвойства.Свойство("ОбновлениеИнформационнойБазы") И ДополнительныеСвойства.ОбновлениеИнформационнойБазы) Тогда										
										
										ТекстСообщения = СтрШаблон("Приём не может быть проведен, так как в табличной части ""Лечение"" количество %1 номенклатуры ""%2"" превышает количество в документе основания (%3) на %4 ед."
																, ?(ЗначениеЗаполнено(НайденнаяСтрокаВ_ТЧ_Лечение.Упаковка), "упаковок", "единиц")
																, СокрЛП(ПараметрыИспользованияЕдиницНоменклатуры.НоменклатураНаименование)
																, СокрЛП(ПараметрыИспользованияЕдиницНоменклатуры.ДокументАвансаПредставление)
																, ДоступноКИспользованию * -1);
										
										ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
																
										Отказ = Истина;
										Возврат;
										
									КонецЕсли;
									
								КонецЕсли;		
								// Проставим статус в строке: Выполнено
								СтрокаТЧЗапасы_НарядЗаказ.Статус = Перечисления.СтатусыНарядЗаказа.Выполнено;
								Если Не ЗначениеЗаполнено(СтрокаТЧЗапасы_НарядЗаказ.ДатаВыполнения) Тогда 
									СтрокаТЧЗапасы_НарядЗаказ.ДатаВыполнения = Дата;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;	
					КонецЕсли;
				КонецЦикла; 
				
				// Работа с найденными строками в ТЧ Запасы
				Для Каждого НайденнаяСтрокаВ_ТЧ_Запасы Из МассивНайденныхСтрокВ_ТЧ_Запасы Цикл 
					СтрокаТЧЗапасы_НарядЗаказ = НарядЗаказОбъект.Запасы.Найти(НайденнаяСтрокаВ_ТЧ_Запасы.КлючСтроки, "КлючСтроки");
					Если СтрокаТЧЗапасы_НарядЗаказ <> Неопределено Тогда
						Если РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда
							СтрокаТЧЗапасы_НарядЗаказ.Прием = Документы.Прием.ПустаяСсылка();
						Иначе
							Если ЗначениеЗаполнено(СтрокаТЧЗапасы_НарядЗаказ.Прием) И НЕ СтрокаТЧЗапасы_НарядЗаказ.Прием = Ссылка Тогда 
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приём не может быть проведен, так как данные услуги уже проведенны в " 
								+ Строка(СтрокаТЧЗапасы_НарядЗаказ.Прием) + " ! ");
								Отказ = Истина;
								Возврат;
							Иначе  
								ПараметрыИспользованияЕдиницНоменклатуры = ИспользованоКоличествоПоНарядЗаказу("Запасы", НарядЗаказ, , НайденнаяСтрокаВ_ТЧ_Запасы.Номенклатура, НайденнаяСтрокаВ_ТЧ_Запасы.Упаковка, НайденнаяСтрокаВ_ТЧ_Запасы.НомерЗаказа);
						        ДоступноКИспользованию = СтрокаТЧЗапасы_НарядЗаказ.КоличествоУпаковок - ПараметрыИспользованияЕдиницНоменклатуры.КоличествоУпаковок; 
								
								Если ДоступноКИспользованию >= 0 Тогда
									// Пишем Ссылку
									СтрокаТЧЗапасы_НарядЗаказ.Прием = Ссылка;
								Иначе
									
									ТекстСообщения = СтрШаблон("Приём не может быть проведен, так как в табличной части ""Запасы"" количество %1 номенклатуры ""%2"" превышает количество в документе основания (%3) на %4 ед."
																, ?(ЗначениеЗаполнено(НайденнаяСтрокаВ_ТЧ_Лечение.Упаковка), "упаковок", "единиц")
																, СокрЛП(ПараметрыИспользованияЕдиницНоменклатуры.НоменклатураНаименование)
																, СокрЛП(ПараметрыИспользованияЕдиницНоменклатуры.ДокументАвансаПредставление)
																, ДоступноКИспользованию * -1);
										
									ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);

									Отказ = Истина;
									Возврат;
									
								КонецЕсли;		
								// Проставим статус в строке: Выполнено
								СтрокаТЧЗапасы_НарядЗаказ.Статус = Перечисления.СтатусыНарядЗаказа.Выполнено;
								Если Не ЗначениеЗаполнено(СтрокаТЧЗапасы_НарядЗаказ.ДатаВыполнения) Тогда 
									СтрокаТЧЗапасы_НарядЗаказ.ДатаВыполнения = Дата;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;	
					КонецЕсли;
				КонецЦикла;
				
				// Проставим статус НарядЗаказу
				СтрокаТаблицыОбщихСтатусовНарядЗаказа = ТаблицаОбщихСтатусовНарядЗаказов.Найти(НарядЗаказ, "НарядЗаказ");
				Если СтрокаТаблицыОбщихСтатусовНарядЗаказа <> Неопределено Тогда 
					Если СтрокаТаблицыОбщихСтатусовНарядЗаказа.СтатусПоОстаткам = "Закрыт" И РежимЗаписиПриема = РежимЗаписиДокумента.Проведение Тогда
						НарядЗаказОбъект.Статус = Истина;
					ИначеЕсли СтрокаТаблицыОбщихСтатусовНарядЗаказа.СтатусПоОстаткам = "Открыт" И РежимЗаписиПриема = РежимЗаписиДокумента.Проведение Тогда
						НарядЗаказОбъект.Статус = Ложь;
					ИначеЕсли РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда						
						НарядЗаказОбъект.Статус = Ложь;
					КонецЕсли;
				КонецЕсли;	
				
				НарядЗаказОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
				НарядЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
			КонецЕсли;		
		КонецЦикла;			
	КонецЕсли;		
	
КонецПроцедуры

// Функция - Получить приемы по наряд заказу
//
// Параметры:
//  НарядЗаказ	 - 	 - 
//  Зуб			 - 	 - 
//  Номенклатура - 	 - 
//  Упаковка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИспользованоКоличествоПоНарядЗаказу(ТЧ, НарядЗаказ, Зуб = Неопределено, Номенклатура, Упаковка, КлючСтроки = Неопределено)
	
	// сделать 2 запроса
	Если ТЧ = "Лечение" Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(ПриемЛечение.КоличествоУпаковок) КАК КоличествоУпаковок,
		|	ПриемЛечение.ДокументАванса.Представление КАК ДокументАвансаПредставление,
		|	ПриемЛечение.Номенклатура.Наименование КАК НоменклатураНаименование
		|ИЗ
		|	Документ.Прием.Лечение КАК ПриемЛечение
		|ГДЕ
		|	ПриемЛечение.Ссылка.Проведен
		|	И ПриемЛечение.ДокументАванса = &ДокументАванса
		|	И ПриемЛечение.Зуб = &Зуб
		|	И ПриемЛечение.Упаковка = &Упаковка
		|	И ПриемЛечение.КлючСтроки = &КлючСтроки
		|	И ПриемЛечение.Номенклатура = &Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриемЛечение.ДокументАванса.Представление,
		|	ПриемЛечение.Номенклатура.Наименование";

	Иначе
		
		ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(ПриемЗапасы.КоличествоУпаковок) КАК КоличествоУпаковок,
		|	ПриемЗапасы.ДокументАванса.Представление КАК ДокументАвансаПредставление,
		|	ПриемЗапасы.Номенклатура.Наименование КАК НоменклатураНаименование
		|ИЗ
		|	Документ.Прием.Запасы КАК ПриемЗапасы
		|ГДЕ
		|	ПриемЗапасы.Ссылка.Проведен
		|	И ПриемЗапасы.ДокументАванса = &ДокументАванса
		|	И ПриемЗапасы.Упаковка = &Упаковка
		|	И ПриемЗапасы.НомерЗаказа = &КлючСтроки
		|	И ПриемЗапасы.Номенклатура = &Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриемЗапасы.ДокументАванса.Представление,
		|	ПриемЗапасы.Номенклатура.Наименование";

	КонецЕсли;
	
	Запрос       = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументАванса", НарядЗаказ); 
	Запрос.УстановитьПараметр("Зуб"           , Зуб);	
	Запрос.УстановитьПараметр("Упаковка"      , Упаковка);
	Запрос.УстановитьПараметр("КлючСтроки"    , КлючСтроки);
    Запрос.УстановитьПараметр("Номенклатура"  , Номенклатура);

	Выборка = Запрос.Выполнить().Выбрать();
	
	СтруктураВозврата = Новый Структура("КоличествоУпаковок, ДокументАвансаПредставление, НоменклатураНаименование", 0, "", "");

	Если Выборка.Следующий() Тогда
		СтруктураВозврата.КоличествоУпаковок = Выборка.КоличествоУпаковок;
		СтруктураВозврата.ДокументАвансаПредставление = Выборка.ДокументАвансаПредставление;
		СтруктураВозврата.НоменклатураНаименование = Выборка.НоменклатураНаименование;	
	КонецЕсли;
		
	Возврат СтруктураВозврата;
	
КонецФункции

// Процедура проверяет заполнение сертификатов.
//
Процедура ОбработкаПроверкиЗаполненияРаботаССертификатами(Отказ)
	
	Для Каждого СтрокаЗапасы Из Запасы Цикл				
		Если СтрокаЗапасы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
		   И СтрокаЗапасы.Номенклатура.ИспользоватьПартии
		   И СтрокаЗапасы.Партия.Пустая() Тогда	
		   
		   Отказ = Истина;
		   ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке № " + СтрокаЗапасы.НомерСтроки + " табличной части " + """" + "Запасы" + """" + " не заполнено поле " + """"+ "Характеристика, серия" + """");
		КонецЕсли; 		
	КонецЦикла;   
	
	Для Каждого СтрокаПодарки Из Подарки Цикл	
		
		Если НЕ СтрокаПодарки.Использование Тогда
			Продолжить;
		КонецЕсли;
		
		РеквизитыНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(
									СтрокаПодарки.Номенклатура, 
									"ТипНоменклатуры, ВидНоминала, ИспользоватьПартии");  
		
		 Если РеквизитыНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
			И РеквизитыНоменклатуры.ВидНоминала = Истина // определяется при продаже.
			И СтрокаПодарки.СуммаПодарочногоСертификата = 0 Тогда	
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='В строке № %1 табличной части ""Подарки"" не указана сумма подарочного сертификата.';en='In line № %1 of the tabular parts ""Presents"" the indicated amount of gift certificate.'"), СтрокаПодарки.НомерСтроки));			
			Отказ = Истина;  			
		КонецЕсли;     	
		
		Если РеквизитыНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
		   И РеквизитыНоменклатуры.ИспользоватьПартии
		   И НЕ ЗначениеЗаполнено(СтрокаПодарки.Партия) Тогда	
		   
		   ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='В строке № %1 табличной части ""Подарки"" не заполнено поле Характеристика/серия.';en='In line № %1 of the tabular parts ""Presents"" the indicated amount of gift certificate.'"), СтрокаПодарки.НомерСтроки));
   		   Отказ = Истина;
		КонецЕсли; 		
	КонецЦикла; 
	
КонецПроцедуры

// Процедура - Сформировать массив сотрудников для формирования интервалов
//
Процедура СформироватьМассивСотрудниковДляФормированияИнтервалов()
	
	МассивСотрудников = Новый Массив;
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.Лечение Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник)
			И МассивСотрудников.Найти(СтрокаТЧ.Сотрудник) = Неопределено Тогда
			МассивСотрудников.Добавить(СтрокаТЧ.Сотрудник);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.Ссылка.Лечение Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник)
			И МассивСотрудников.Найти(СтрокаТЧ.Сотрудник) = Неопределено Тогда
			МассивСотрудников.Добавить(СтрокаТЧ.Сотрудник);
		КонецЕсли;
	КонецЦикла;
	
	ЭтотОбъект.ДополнительныеСвойства.Вставить("СотрудникиДляФормированияИнтервалов", МассивСотрудников);
	
КонецПроцедуры	

// Процедура - Сформировать интервалы по сотрудникам
//
Процедура СформироватьИнтервалыПоСотрудникам()
	
	Если НачалоДня(ЭтотОбъект.Дата) >= НачалоДня(ТекущаяДатаСеанса())
		И ЭтотОбъект.ДополнительныеСвойства.Свойство("СотрудникиДляФормированияИнтервалов")
		И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.СотрудникиДляФормированияИнтервалов) Тогда
		
		МассивСотрудников = ЭтотОбъект.ДополнительныеСвойства.СотрудникиДляФормированияИнтервалов;
		РегистрыСведений.СвободныеИнтервалыСотрудников.СформироватьИнтервалыПоСотрудникам(
			СтруктурнаяЕдиница, МассивСотрудников, НачалоДня(ЭтотОбъект.Дата), КонецДня(ЭтотОбъект.Дата));
			
	КонецЕсли;
	
КонецПроцедуры

// Процедура заполняет табличную часть "Лечение" и возможно табличную часть "СкидкиНаценки" по указанному плану лечения.
//
Процедура ЗаполнитьТаблицуЛечение(Основание)
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ПланЛечения") Тогда
		Для Каждого СтрокаТЧЛечение Из Основание.Лечение Цикл
			Если СтрокаТЧЛечение.ПризнакВыбора Тогда 
				Если Документы.ПланЛечения.ОстатокУслугПоПлануЛечения(СтрокаТЧЛечение.Номенклатура, Основание.Контрагент, СтрокаТЧЛечение.Зуб, Основание.СтруктурнаяЕдиница) >= СтрокаТЧЛечение.Количество Тогда
					// Добавим услуги
					НоваяСтрокаЛечение = Лечение.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаЛечение, СтрокаТЧЛечение);
					НоваяСтрокаЛечение.КлючСтроки         	= Новый УникальныйИдентификатор;
					НоваяСтрокаЛечение.КоличествоУпаковок 	= НоваяСтрокаЛечение.Количество;
					НоваяСтрокаЛечение.ДокументАванса 	    = Основание;					
					// Добавим скидки
					СтруктураОтбора = Новый Структура("КлючСтроки", СтрокаТЧЛечение.КлючСтроки);
					СтрокиСкидок = Основание.СкидкиНаценки.НайтиСтроки(СтруктураОтбора);
					Для Каждого СтрокаСкидка Из СтрокиСкидок Цикл 
						НоваяСтрокаСкидкиНаценки = СкидкиНаценки.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрокаСкидкиНаценки, СтрокаСкидка);
						НоваяСтрокаСкидкиНаценки.КлючСтроки = НоваяСтрокаЛечение.КлючСтроки;					
					КонецЦикла;	
					
					НормыСписанияМатериалов = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(СтрокаТЧЛечение.Номенклатура, СтруктурнаяЕдиница); 
					
					Для Каждого СтрокаНСМ Из НормыСписанияМатериалов Цикл
						
						НоваяСтрокаМатериала                    = Материалы.Добавить();
						НоваяСтрокаМатериала.КлючСтроки         = НоваяСтрокаЛечение.КлючСтроки;
						НоваяСтрокаМатериала.Услуга             = СтрокаТЧЛечение.Номенклатура;
						НоваяСтрокаМатериала.Материал           = СтрокаНСМ.Материал;
						НоваяСтрокаМатериала.КоличествоУпаковок = ?(СтрокаНСМ.НеЗависитОтКоличестваУслуг, СтрокаНСМ.Количество, СтрокаНСМ.Количество * ?(НоваяСтрокаЛечение.КоличествоУпаковок = 0, 1, НоваяСтрокаЛечение.КоличествоУпаковок));
						НоваяСтрокаМатериала.Количество         = НоваяСтрокаМатериала.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаНСМ.Упаковка.Коэффициент), СтрокаНСМ.Упаковка.Коэффициент, 1);
						НоваяСтрокаМатериала.Упаковка           = СтрокаНСМ.Упаковка;
						НоваяСтрокаМатериала.Склад              = РегистрыСведений.НормыСписанияМатериалов.ПолучитьСкладСписанияНормМатериалов(СтрокаНСМ, СтруктурнаяЕдиница, Основание.Сотрудник);
						НоваяСтрокаМатериала.Сотрудник          = Основание.Сотрудник;
						НоваяСтрокаМатериала.ВключатьВСтоимость = СтрокаНСМ.ВключатьВСтоимостьУслуги;
						НоваяСтрокаМатериала.ВидЦен				= СтрокаНСМ.ВидЦен;
						
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.Событие") Тогда
		Для Каждого СтрокаТЧУслуги Из Основание.Услуги Цикл
			Если ЗначениеЗаполнено(СтрокаТЧУслуги.Номенклатура) Тогда
				НоваяСтрокаТЧ = Лечение.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ, СтрокаТЧУслуги);
				НоваяСтрокаТЧ.КлючСтроки         = Новый УникальныйИдентификатор;
				НоваяСтрокаТЧ.Количество         = 1;
				НоваяСтрокаТЧ.КоличествоУпаковок = 1;
				НоваяСтрокаТЧ.Зуб                = Перечисления.Зубы.ВсяПолость;
				
				НормыСписанияМатериалов = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(СтрокаТЧУслуги.Номенклатура, СтруктурнаяЕдиница);
				
				Для Каждого СтрокаНСМ Из НормыСписанияМатериалов Цикл
					
					НоваяСтрокаМатериала                    = Материалы.Добавить();
					НоваяСтрокаМатериала.КлючСтроки         = НоваяСтрокаТЧ.КлючСтроки;
					НоваяСтрокаМатериала.Услуга             = СтрокаТЧУслуги.Номенклатура;
					НоваяСтрокаМатериала.Материал           = СтрокаНСМ.Материал;
					НоваяСтрокаМатериала.КоличествоУпаковок = ?(СтрокаНСМ.НеЗависитОтКоличестваУслуг, СтрокаНСМ.Количество, СтрокаНСМ.Количество * ?(НоваяСтрокаТЧ.КоличествоУпаковок = 0, 1, НоваяСтрокаТЧ.КоличествоУпаковок));
					НоваяСтрокаМатериала.Количество         = НоваяСтрокаМатериала.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаНСМ.НСМУпаковка.Коэффициент), СтрокаНСМ.НСМУпаковка.Коэффициент, 1);
					НоваяСтрокаМатериала.Упаковка           = СтрокаНСМ.Упаковка;
					НоваяСтрокаМатериала.Склад              = РегистрыСведений.НормыСписанияМатериалов.ПолучитьСкладСписанияНормМатериалов(СтрокаНСМ, СтруктурнаяЕдиница, СтрокаТЧУслуги.Сотрудник);
					НоваяСтрокаМатериала.Сотрудник          = СтрокаТЧУслуги.Сотрудник;
					НоваяСтрокаМатериала.ВключатьВСтоимость = СтрокаНСМ.ВключатьВСтоимостьУслуги;
					НоваяСтрокаМатериала.ВидЦен				= СтрокаНСМ.ВидЦен;
					
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.НарядЗаказ") Тогда
		
		ОстаткиПоВыполненнымУслугам = Документы.НарядЗаказ.ПолучитьОстаткиПоВыполненнымСтрокамНарядЗаказа(Основание);		
		Для Каждого СтрокаТЧ Из ОстаткиПоВыполненнымУслугам Цикл
			Если СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
				НоваяСтрокаТЧ = Лечение.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ, СтрокаТЧ);
				НоваяСтрокаТЧ.КлючСтроки         	= Новый УникальныйИдентификатор;
				НоваяСтрокаТЧ.КоличествоУпаковок 	= НоваяСтрокаТЧ.Количество;
				НоваяСтрокаТЧ.ДокументАванса 		= Основание;
				
				НормыСписанияМатериалов = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница);
				
				Для Каждого СтрокаНСМ Из НормыСписанияМатериалов Цикл
					НоваяСтрокаМатериала                    = Материалы.Добавить();
					НоваяСтрокаМатериала.КлючСтроки         = НоваяСтрокаТЧ.КлючСтроки;
					НоваяСтрокаМатериала.Услуга             = СтрокаТЧ.Номенклатура;
					НоваяСтрокаМатериала.Материал           = СтрокаНСМ.Материал;
					НоваяСтрокаМатериала.КоличествоУпаковок = ?(СтрокаНСМ.НеЗависитОтКоличестваУслуг, СтрокаНСМ.Количество, СтрокаНСМ.Количество * ?(НоваяСтрокаТЧ.КоличествоУпаковок = 0, 1, НоваяСтрокаТЧ.КоличествоУпаковок));
					НоваяСтрокаМатериала.Количество         = НоваяСтрокаМатериала.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаНСМ.НСМУпаковка.Коэффициент), СтрокаНСМ.НСМУпаковка.Коэффициент, 1);					
					НоваяСтрокаМатериала.Упаковка           = СтрокаНСМ.Упаковка;
					НоваяСтрокаМатериала.Склад              = РегистрыСведений.НормыСписанияМатериалов.ПолучитьСкладСписанияНормМатериалов(СтрокаНСМ, СтруктурнаяЕдиница, Основание.Сотрудник);
					НоваяСтрокаМатериала.Сотрудник          = Основание.Сотрудник;
					НоваяСтрокаМатериала.ВключатьВСтоимость = СтрокаНСМ.ВключатьВСтоимостьУслуги;
					НоваяСтрокаМатериала.ВидЦен				= СтрокаНСМ.ВидЦен;
					НоваяСтрокаМатериала.ЗубнойТехник       = СтрокаТЧ.ЗубнойТехник;
				КонецЦикла;
			ИначеЕсли СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас Тогда
				НоваяСтрокаТЧ = Запасы.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ, СтрокаТЧ);
				НоваяСтрокаТЧ.КлючСтроки         	= Новый УникальныйИдентификатор;
				НоваяСтрокаТЧ.КоличествоУпаковок 	= НоваяСтрокаТЧ.Количество;
				НоваяСтрокаТЧ.ДокументАванса 	    = Основание;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

//
//
Функция ЗаполнитьСотрудника(ДанныеЗаполнения)
	
	Если ДанныеЗаполнения.Услуги.Количество() > 0 Тогда
		СотрудникДляВовзрата = ДанныеЗаполнения.Услуги[0].Сотрудник;
	КонецЕсли;
	Для Каждого СтрокаУслуг Из ДанныеЗаполнения.Услуги Цикл
		Если ДанныеЗаполнения.Услуги[0].Сотрудник <> СтрокаУслуг.Сотрудник Тогда
			СотрудникДляВовзрата = Справочники.Сотрудники.ПустаяСсылка();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ?(СотрудникДляВовзрата <> Неопределено, СотрудникДляВовзрата, Справочники.Сотрудники.ПустаяСсылка());
	
КонецФункции

// Процедура осуществляет проверку на превышение лимита полиса
//
Процедура ПроверитьОстатокПоМедицинскомуПолису(Отказ)
	
	// Проверим, не превышен ли лимит по страховому полису
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда 
		Если ПолисМедСтрахования.ЛимитПолиса <> 0 Тогда 
			СуммаРанееОказанныхУслуг = ПолучитьСуммуВсехРанееОказанныхУслуг();
			ОбщаяСумма = СуммаРанееОказанныхУслуг + СуммаДокумента;
			Если ОбщаяСумма > ПолисМедСтрахования.ЛимитПолиса Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Общий лимит по медицинскому полису превышен!");
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;                 
	КонецЕсли;
	
КонецПроцедуры

// Функция возвращает сумму всех ранее оказанных услуг
//
Функция ПолучитьСуммуВсехРанееОказанныхУслуг() Экспорт 
		
	ОбщаяСумма = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаРасход), 0) КАК СуммаРасход
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|			,
	|			&Дата,
	|			Авто,
	|			ДокументРеализации ССЫЛКА Документ.Прием
	|				И ДокументРеализации.ПолисМедСтрахования = &ПолисМедСтрахования) КАК ВзаиморасчетыСКонтрагентамиОбороты";
	
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Ссылка), Дата - 5, ТекущаяДата()));
	Запрос.УстановитьПараметр("ПолисМедСтрахования", ПолисМедСтрахования);
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл 
		ОбщаяСумма = ОбщаяСумма + Результат.СуммаРасход;
	КонецЦикла;	
		
	Возврат ОбщаяСумма;
	
КонецФункции

//
//
Функция ВернутьДокументОснования(ДанныеЗаполнения)
	
	ДокументОсн = ДанныеЗаполнения;
	Если НЕ ДанныеЗаполнения.ДокументОснование.Пустая() Тогда
		Если ТипЗнч(ДанныеЗаполнения.ДокументОснование) = Тип("ДокументСсылка.Событие") Тогда
			Если ДанныеЗаполнения.ДокументОснование.Услуги.Количество() > 0 Тогда 
				Если ВернутьДатуУслугиИзПЗ(ДанныеЗаполнения.ДокументОснование.Услуги) = НачалоДня(ТекущаяДата()) Тогда 
					ДокументОсн = ДанныеЗаполнения.ДокументОснование;					
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	
	Возврат ДокументОсн;
	
КонецФункции

//
//
Функция ВернутьДатуУслугиИзПЗ(ТЧУслуги)
	
	ТаблицаДат = ТЧУслуги.Выгрузить();
	ТаблицаДат.Сортировать("ДатаНачала");
	Возврат НачалоДня(ТаблицаДат[0].ДатаНачала);
	
КонецФункции

// Устанвоить статусы пациента в документе
Процедура УстановитьПризнакПервичногоПациента()
		
	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Пациент,
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.РанееБылиПриемы, 0)) КАК РанееБылиПриемы,
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.ДляСотрудникаРанееБылиПриемы, 0)) КАК ДляСотрудникаРанееБылиПриемы
	|ИЗ
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|		Продажи.Контрагент КАК Пациент,
	|		1 КАК РанееБылиПриемы,
	|		NULL КАК ДляСотрудникаРанееБылиПриемы
	|	ИЗ
	|		РегистрНакопления.Продажи КАК Продажи
	|	ГДЕ
	|		Продажи.Контрагент = &Контрагент
	|		И Продажи.Период < &Дата
	|		И Продажи.Регистратор ССЫЛКА Документ.Прием
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ ПЕРВЫЕ 1
	|		Продажи.Контрагент,
	|		NULL,
	|		1
	|	ИЗ
	|		РегистрНакопления.Продажи КАК Продажи
	|	ГДЕ
	|		ВЫБОР
	|				КОГДА &Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|					ТОГДА Продажи.Сотрудник = &Сотрудник
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		И Продажи.Контрагент = &Контрагент
	|		И Продажи.Период < &Дата
	|		И Продажи.Регистратор ССЫЛКА Документ.Прием) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Пациент";
	
	Запрос.УстановитьПараметр("Сотрудник"         , ЭтотОбъект.Сотрудник);
	Запрос.УстановитьПараметр("Контрагент"        , ЭтотОбъект.Контрагент);
	Запрос.УстановитьПараметр("Дата"              , ?(НЕ ЗначениеЗаполнено(ЭтотОбъект.Дата) Или НачалоДня(ЭтотОбъект.Дата) = НачалоДня(ТекущаяДата()),ТекущаяДата(),ЭтотОбъект.Дата)); 
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если Выборка.РанееБылиПриемы = 1 Тогда
			ЭтотОбъект.СтатусПациента = Перечисления.СтатусыКонтрагентов.Постоянный;
		Иначе
			ЭтотОбъект.СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЭтотОбъект.Сотрудник) Тогда 
			Если Выборка.ДляСотрудникаРанееБылиПриемы = 1 Тогда
				ЭтотОбъект.ЭтоПервичныйПациентДляВрача = Ложь;
			Иначе
				ЭтотОбъект.ЭтоПервичныйПациентДляВрача = Истина;
			КОнецЕсли;
		КОнецЕсли;						
	Иначе
		Если ЗначениеЗаполнено(ЭтотОбъект.Сотрудник) Тогда
			ЭтотОбъект.ЭтоПервичныйПациентДляВрача = Истина;
		КОнецЕсли;
		ЭтотОбъект.СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный;		
	КонецЕсли;
	
КонецПроцедуры

// Процедура добавляет необходимы движения по партиям 
// в таблицу движений регистра управленческий
Процедура ТаблицаУправленческийДобавитьДвиженияПоПартиям(ТаблицаУправленческий, ТаблицаПартии)	
	ВременнаяТаблица = ТаблицаПартии.Скопировать();
    ВременнаяТаблица.Свернуть("Номенклатура,Склад","Стоимость,Количество");	
	Для Каждого СтрокаТ ИЗ ВременнаяТаблица Цикл	
		НайденныеСтроки = ТаблицаУправленческий.НайтиСтроки(Новый Структура("СубконтоКт1,СубконтоКт2",СтрокаТ.Номенклатура,СтрокаТ.Склад));
		Если НайденныеСтроки.Количество() > 0 Тогда
			НайденныеСтроки[0].Сумма       = СтрокаТ.Стоимость;
			НайденныеСтроки[0].Количество  = СтрокаТ.Количество;
		Иначе
			НоваяСтрока                    = ТаблицаУправленческий.Добавить();
			НоваяСтрока.НомерСтроки        = ТаблицаУправленческий.Количество();
			НоваяСтрока.Период             = ЭтотОбъект.Дата;
			НоваяСтрока.СтруктурнаяЕдиница = ЭтотОбъект.СтруктурнаяЕдиница;
			НоваяСтрока.СчетДт             = ПланыСчетов.Управленческий.РасходыСебестоимость;
			НоваяСтрока.СчетКт             = ПланыСчетов.Управленческий.Запасы;
			НоваяСтрока.СубконтоДт1        = СтрокаТ.Номенклатура.Специализация;
			НоваяСтрока.СубконтоДт2        = ЭтотОбъект.Контрагент;
			НоваяСтрока.СубконтоДт3        = ЭтотОбъект.Сотрудник;
			НоваяСтрока.СубконтоДт4        = Справочники.СтатьиДоходовИРасходов.СебестоимостьТоваров;
			НоваяСтрока.СубконтоКт1        = СтрокаТ.Номенклатура;
			НоваяСтрока.СубконтоКт2        = СтрокаТ.Склад;
			НоваяСтрока.Сумма              = СтрокаТ.Стоимость;
			НоваяСтрока.Количество         = СтрокаТ.Количество;
			НоваяСтрока.Содержание         = "Проведение приема(Запасы)";			
		КонецЕсли;
	КонецЦикла;		
КонецПроцедуры

//
//
Функция ПодготовитьТаблицуДляСписанияПартииТоваров()
	
	ТаблицаСписанияНоменклатуры = Ссылка.Запасы.ВыгрузитьКолонки();
	ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(Ссылка.Запасы, ТаблицаСписанияНоменклатуры);
	Для Каждого СтрокаПодарки Из Подарки Цикл
		Если СтрокаПодарки.Использование = Ложь Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств( ТаблицаСписанияНоменклатуры.Добавить(), СтрокаПодарки);
	КонецЦикла;

	// ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(Ссылка.Подарки, ТаблицаСписанияНоменклатуры);
	// Если списываем материалы в момент оказания услуги тогда:
	Если НЕ Константы.СписыватьМатериалыПриЗакрытииКассовойСмены.Получить() Тогда
		// ТаблицаСписанияНоменклатуры.Колонки.Добавить("ЗубнойТехник"	, Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));		
		ТаблицаСписанияНоменклатуры.Колонки.Добавить("Услуга"	, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(Тип("СправочникСсылка.Склады"));
		МассивТипов.Добавить(Тип("СправочникСсылка.Сотрудники"));		
		ТаблицаСписанияНоменклатуры.Колонки.Добавить("Склад"	, Новый ОписаниеТипов(МассивТипов));		
		ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(Ссылка.Материалы, ТаблицаСписанияНоменклатуры);
		ДополнительныеСвойства.Вставить("СтруктураПолейПерегрузка", Новый Структура("Услуга, Склад, ЗубнойТехник", "Услуга", "Склад", "ЗубнойТехник"));
		
		// ДополнительныеСвойства.Вставить("СтруктураПолейПерегрузка", Новый Структура("Склад", "Склад"));
	КонецЕсли;	
	
	Возврат ТаблицаСписанияНоменклатуры;
	
КонецФункции

// Процедура - Поместить ссылку новой сделки
//
Процедура ПоместитьСсылкуНовойСделки()
	
	Если НЕ Ссылка.Пустая() ИЛИ ЗначениеЗаполнено(Сделка) Тогда
		Возврат;
	КонецЕсли;	
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ВидСделкиГенерации") И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.ВидСделкиГенерации) Тогда
		Если НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("СсылкаНовойСделки") Тогда
			СсылкаНовойСделки = Справочники.Сделки.ПолучитьСсылку(Новый УникальныйИдентификатор);
			ЭтотОбъект.ДополнительныеСвойства.Вставить("СсылкаНовойСделки", СсылкаНовойСделки);
			ЭтотОбъект.Сделка = СсылкаНовойСделки;				
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

// Процедура - Создать новую воронку
//
Процедура СоздатьНовуюВоронку()
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ВидСделкиГенерации") И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.ВидСделкиГенерации) И ЭтотОбъект.ДополнительныеСвойства.Свойство("СсылкаНовойСделки") Тогда
		ДанныеЗаполнения = ЗначениеИзСтрокиВнутр(ЗначениеВСтрокуВнутр(ЭтотОбъект.ДополнительныеСвойства));
		ДанныеЗаполнения.Вставить("ВидСделки"				, ДанныеЗаполнения.ВидСделкиГенерации);
		// ДанныеЗаполнения.Вставить("ДатаСделки"			, ЭтотОбъект.Дата);
		ДанныеЗаполнения.Вставить("Контрагент"				, ЭтотОбъект.Контрагент);
		ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"		, ЭтотОбъект.СтруктурнаяЕдиница);
		ДанныеЗаполнения.Вставить("ЭтапСделки"				, ДанныеЗаполнения.ЭтапСделкиГенерации);
		Если ЗначениеЗаполнено(ЭтотОбъект.Сотрудник) Тогда 
			ДанныеЗаполнения.Вставить("Врач"				, ЭтотОбъект.Сотрудник);
		КонецЕсли;
		ДанныеЗаполнения.Вставить("ОбъектИнициации"			, ЭтотОбъект.Ссылка);
		ДанныеЗаполнения.Вставить("ИнтерактивнаяЗапись"		, Истина);
		ДанныеЗаполнения.Вставить("СформироватьНаименование", Истина);		
		ДанныеЗаполнения.Вставить("КурсЛечения", ЭтотОбъект.КурсЛечения);
		ДанныеЗаполнения.Вставить("Лечение"	   , ЭтотОбъект.ЛечениеВрача);

		НоваяСделка = Справочники.Сделки.СоздатьНовуюСделку(ДанныеЗаполнения, Истина);
	КонецЕсли;

КонецПроцедуры

// Процедура - Сменить этап предопределенной воронки
//
Процедура СменитьЭтапПредопределеннойВоронки()
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Сделка) И ЭтотОбъект.Проведен Тогда // ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства.ДанныеПередЗаписью, "ЭтоНовый", Ложь) Тогда 
		ДанныеСделки = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ЭтотОбъект.Сделка, "ВидСделки, ЭтапСделки, РезультатСделки");
		Если НЕ ЗначениеЗаполнено(ДанныеСделки.РезультатСделки) И ЗначениеЗаполнено(ДанныеСделки.ВидСделки) И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДанныеСделки.ВидСделки, "Предопределенный") = Истина Тогда 
			АктуальныйЭтап = Справочники.Сделки.ПолучитьАктуальныйЭтапВоронки(ЭтотОбъект.Сделка, ДанныеСделки.ВидСделки, ЭтотОбъект.Контрагент);
			Если ЗначениеЗаполнено(АктуальныйЭтап) И НЕ ДанныеСделки.ЭтапСделки = АктуальныйЭтап Тогда 
				Справочники.Сделки.УстановитьЭтапСделке(ЭтотОбъект.Сделка, АктуальныйЭтап, Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработать согласования страховых услуг.
//
Процедура ОбработатьСогласованияСтраховыхУслуг(Знач ИспользоватьСистемуВзаимодействия)
	
	Если ДополнительныеСвойства.Свойство("ТаблицаСогласованийУслуг") = Ложь Тогда
		Возврат;	
	КонецЕсли;
	
	РегистрыСведений.СогласованияСтраховыхУслуг.ЗаписатьСогласованияСтраховыхУслуг(Ссылка, ДополнительныеСвойства.ТаблицаСогласованийУслуг); 
	
	СтрокиНаСогласование = ДополнительныеСвойства.ТаблицаСогласованийУслуг.НайтиСтроки(Новый Структура("СтатусСогласования", Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования));
	Если СтрокиНаСогласование.Количество() > 0 Тогда
		
		ТекущиеСеансы = ПолучитьСеансыИнформационнойБазы();
		НомерСеанса   = НомерСеансаИнформационнойБазы();
		
		ПользователиОповещения = Новый Массив;
		
		Для Каждого ТекущийСеанс Из ТекущиеСеансы Цикл
			
			Если НомерСеанса <> ТекущийСеанс.НомерСеанса
				И (ТекущийСеанс.ИмяПриложения = "1CV8C"
				ИЛИ ТекущийСеанс.ИмяПриложения = "WebClient") Тогда
				
				СодержитРоль = ТекущийСеанс.Пользователь.Роли.Содержит(Метаданные.Роли.СогласованиеСтраховыхУслуг);
				Если СодержитРоль = Истина Тогда
					
					Если ИспользоватьСистемуВзаимодействия = Истина Тогда
						
						// Получаем сеансы, которые необходимо оповестить.
						ПользователиОповещения.Добавить(ТекущийСеанс.Пользователь);
						
					Иначе	
						
						// Создаем оповещение через регистр сведений.
						РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(ТекущийСеанс.НомерСеанса,
						СтруктурнаяЕдиница,
						"ПоказатьОповещениеУслугиНаСогласование", 
						ТекущаяДатаСеанса(), 
						60);  
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла; 
		
		Если ИспользоватьСистемуВзаимодействия = Истина
			И ПользователиОповещения.Количество() > 0 Тогда
			
			// Создаем оповещение через систему взаимодействия.
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("Ключ", "ПоказатьОповещениеУслугиНаСогласование");
			
			ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Добавить сообщение в систему взаимодействия
//
// Параметры:
//  ИспользоватьСистемуВзаимодействия	 - 	 - 
//
Процедура ДобавитьСообщениеВСистемуВзаимодействия(Знач ИспользоватьСистемуВзаимодействия)
		
	ПользователиОповещения = ОбсужденияСистемыВзаимодействия.ПолучитьАктивныхПользователейДляОповещения(ЭтотОбъект.СтруктурнаяЕдиница);
	
	Если ИспользоватьСистемуВзаимодействия = Истина И ЗначениеЗаполнено(ПользователиОповещения) Тогда
		
		// Создаем оповещение через систему взаимодействия.
		ДанныеСообщения = Новый Структура;
		ДанныеСообщения.Вставить("Ключ"				 , "ОбновлениеРабочегоСтола");
		ДанныеСообщения.Вставить("ДатаСобытия"		 , ЭтотОбъект.ВремяНачалаПриема);
		ДанныеСообщения.Вставить("СтруктурнаяЕдиница", ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(ЭтотОбъект.СтруктурнаяЕдиница));
		
		ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, ПользователиОповещения);
		
	КонецЕсли;
	
КонецПроцедуры

#Область КурсЛеченияИЛечениеВрача

// Процедура - Устанавливаем курс лечения и лечение врача
//
Процедура УстанавливаемКурсЛеченияИЛечениеВрача(Отказ)

	// 1. Найти / создать лечение по сотруднику с приоритетом по открытому лечению
	Если Не ЗначениеЗаполнено(ЭтотОбъект.ЛечениеВрача) Тогда
		ЭтотОбъект.ЛечениеВрача = НайтиСоздатьЛечениеЛечениеВрача(Отказ);  
		Если Отказ Тогда
			Возврат;	
		КонецЕсли;
	КонецЕсли;
	
	// 2. Найти / создать курс
	Если Не ЗначениеЗаполнено(ЭтотОбъект.КурсЛечения) Тогда
		ЭтотОбъект.КурсЛечения = НайтиСоздатьКурсЛечения(Отказ); 
		Если Отказ Тогда
			Возврат;	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Найти создать лечение лечение врача
// 
// Возвращаемое значение:
//   - 
//
Функция НайтиСоздатьЛечениеЛечениеВрача(Отказ)  
	
	// 1. Найти лечение врача
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Лечения.Ссылка КАК Ссылка,
	|	1 КАК Приоритет,
	|	Лечения.ДатаОкончания КАК ДатаОкончания,
	|	Лечения.ДатаНачала КАК ДатаНачала
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	Справочник.Лечения КАК Лечения
	|ГДЕ
	|	Лечения.Контрагент = &Контрагент
	|	И Лечения.Сотрудник = &Сотрудник
	|	И Лечения.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|	И Лечения.ДатаНачала <= &ДатаНачалаЛечения
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Лечения.Ссылка,
	|	2,
	|	Лечения.ДатаОкончания,
	|	Лечения.ДатаНачала
	|ИЗ
	|	Справочник.Лечения КАК Лечения
	|ГДЕ
	|	Лечения.Контрагент = &Контрагент
	|	И Лечения.Сотрудник = &Сотрудник
	|	И Лечения.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|	И Лечения.ДатаНачала <= &ДатаНачалаЛечения
	|	И Лечения.ДатаОкончания >= &ДатаОкончанияЛечения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТ.Ссылка КАК Ссылка,
	|	ВТ.Приоритет КАК Приоритет,
	|	ВТ.ДатаОкончания КАК ДатаОкончания,
	|	ВТ.ДатаНачала КАК ДатаНачала
	|ИЗ
	|	ВТ КАК ВТ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет,
	|	ДатаНачала,
	|	ДатаОкончания";
	
	Запрос.УстановитьПараметр("ДатаНачалаЛечения"   , ДобавитьМесяц(ЭтотОбъект.ВремяНачалаПриема, 1));
	Запрос.УстановитьПараметр("Контрагент"          , ЭтотОбъект.Контрагент);
	Запрос.УстановитьПараметр("Сотрудник"           , ЭтотОбъект.Сотрудник);
	Запрос.УстановитьПараметр("ДатаОкончанияЛечения", ДобавитьМесяц(ЭтотОбъект.ВремяНачалаПриема, -4));
    Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка; 		
	Иначе
		
		// 2. Найти / создать курс
		ЭтотОбъект.КурсЛечения = НайтиСоздатьКурсЛечения(Отказ);
		Если Отказ Тогда
		    Возврат Неопределено;
		КонецЕсли;

		// 3. Создать лечение
		ЛечениеВрачаОбъект               = Справочники.Лечения.СоздатьЭлемент();
		ЛечениеВрачаОбъект.ДатаНачала    = ЭтотОбъект.ВремяНачалаПриема; 
		ЛечениеВрачаОбъект.Контрагент    = ЭтотОбъект.Контрагент;
		ЛечениеВрачаОбъект.Сотрудник     = ЭтотОбъект.Сотрудник;
		ЛечениеВрачаОбъект.СуммаЛечения  = ЭтотОбъект.СуммаДокумента;     
		ЛечениеВрачаОбъект.КурсЛечения   = ЭтотОбъект.КурсЛечения; 
		ЛечениеВрачаОбъект.ДатаОкончания = ?(ЭтотОбъект.РезультатПриема = 1, ЭтотОбъект.ВремяОкончанияПриема, Дата(1,1,1));		
		Попытка 
			ЛечениеВрачаОбъект.Записать();
			ЭтотОбъект.ДополнительныеСвойства.Вставить("СозданоЛечениеЭтимПриемом", Истина);
			Возврат ЛечениеВрачаОбъект.Ссылка;
		Исключение
			ОписаниеОшибки = "Ошибка при записи лечения по приему " + Строка(ЭтотОбъект.Ссылка) + " " + ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("ЗаполнениеЛеченияПриЗаписиПриема", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			Отказ = Истина; 
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	
КонецФункции

// Функция - Найти создать курс лечения
// 
// Возвращаемое значение:
//   - 
//
Функция НайтиСоздатьКурсЛечения(Отказ)
	
	Запрос       = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КурсыЛечения.Ссылка КАК Ссылка,
		|	1 КАК Приоритет,
		|	КурсыЛечения.ДатаОкончания КАК ДатаОкончания,
		|	КурсыЛечения.ДатаНачала КАК ДатаНачала
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Справочник.КурсыЛечения КАК КурсыЛечения
		|ГДЕ
		|	КурсыЛечения.Контрагент = &Контрагент
		|	И КурсыЛечения.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
		|	И НЕ КурсыЛечения.ПометкаУдаления
		|	И КурсыЛечения.ДатаНачала <= &ДатаНачалаКурса
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КурсыЛечения.Ссылка,
		|	2,
		|	КурсыЛечения.ДатаОкончания,
		|	КурсыЛечения.ДатаНачала
		|ИЗ
		|	Справочник.КурсыЛечения КАК КурсыЛечения
		|ГДЕ
		|	КурсыЛечения.Контрагент = &Контрагент
		|	И КурсыЛечения.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
		|	И НЕ КурсыЛечения.ПометкаУдаления
		|	И КурсыЛечения.ДатаНачала <= &ДатаНачалаКурса
		|	И КурсыЛечения.ДатаОкончания >= &ДатаОкончанияКурса
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВТ.Ссылка КАК Ссылка,
		|	ВТ.Приоритет КАК Приоритет,
		|	ВТ.ДатаОкончания КАК ДатаОкончания,
		|	ВТ.ДатаНачала КАК ДатаНачала
		|ИЗ
		|	ВТ КАК ВТ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Приоритет,
		|	ДатаНачала,
		|	ДатаОкончания";
	
	Запрос.УстановитьПараметр("Контрагент"        , ЭтотОбъект.Контрагент);
	Запрос.УстановитьПараметр("ДатаНачалаКурса"   , ДобавитьМесяц(ЭтотОбъект.ВремяНачалаПриема, 1));
	Запрос.УстановитьПараметр("ДатаОкончанияКурса", ДобавитьМесяц(ЭтотОбъект.ВремяНачалаПриема, -4));
	
	Выборка = Запрос.Выполнить().Выбрать(); 

	Если Выборка.Следующий() Тогда   
		Возврат Выборка.Ссылка;
	Иначе
		КурсЛеченияОбъект                = Справочники.КурсыЛечения.СоздатьЭлемент();
		КурсЛеченияОбъект.Контрагент     = ЭтотОбъект.Контрагент; 
		КурсЛеченияОбъект.ДатаНачала     = ЭтотОбъект.ВремяНачалаПриема;
		КурсЛеченияОбъект.СтатусПациента = ЭтотОбъект.СтатусПациента; 
		КурсЛеченияОбъект.СуммаКурса     = ЭтотОбъект.СуммаДокумента;
		КурсЛеченияОбъект.ДатаОкончания  = ?(ЭтотОбъект.РезультатПриема = 1, ЭтотОбъект.ВремяОкончанияПриема, Дата(1,1,1));
		Попытка 
			КурсЛеченияОбъект.Записать(); 
			ЭтотОбъект.ДополнительныеСвойства.Вставить("СозданКурсЭтимПриемом", Истина);
			Возврат КурсЛеченияОбъект.Ссылка;
		Исключение  
			ОписаниеОшибки = "Ошибка при записи курса лечения по приему " + Строка(ЭтотОбъект.Ссылка) + " " + ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("ЗаполнениеКурсаПриЗаписиПриема", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			Отказ = Истина;
			Возврат Неопределено;
		КонецПопытки;
		
	КонецЕсли;
	
КонецФункции

// Процедура - Открываем закрываем курс лечения и лечение
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ОткрываемЗакрываемКурсЛеченияИЛечение(Отказ)
	
	ИзмененоЛечение = Ложь;
	// 1. Открыть / закрыть лечение
	Если ЗначениеЗаполнено(ЭтотОбъект.ЛечениеВрача) И Не ЭтотОбъект.ДополнительныеСвойства.Свойство("СозданоЛечениеЭтимПриемом") Тогда
        ОткрытьЗакрытьЛечениеВрача(Отказ, ИзмененоЛечение); 
		Если Отказ Тогда
			Возврат;	
		КонецЕсли;
	КонецЕсли;
	
	// 2. Открыть / закрыть курс
	Если ЗначениеЗаполнено(ЭтотОбъект.КурсЛечения) И Не ЭтотОбъект.ДополнительныеСвойства.Свойство("СозданКурсЭтимПриемом")
		И (ИзмененоЛечение Или ЭтотОбъект.ДополнительныеСвойства.Свойство("СозданоЛечениеЭтимПриемом")) Тогда
		ОткрытьЗакрытьКурсЛечения(Отказ); 
		Если Отказ Тогда
			Возврат;	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Процедура - Открыть закрыть лечение врача
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ОткрытьЗакрытьЛечениеВрача(Отказ, ИзмененоЛечение = Ложь)

	// 1. Открываем, когда результат Продолжает лечение и это последний прием в цепочке по курсу и по сотруднику из приема
	// 2. Закрываем, когда результат Санация и это последний прием в цепочке по курсу и по сотруднику из приема
	// 3. Перемещаем дату начала, если дата текущего приема меньше даты лечения.
	// 4. Рассчитать итоговую сумму		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Прием.Ссылка КАК Ссылка,
		|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
		|	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема,
		|	Прием.Номер КАК Номер,
		|	Прием.РезультатПриема КАК РезультатПриема,
		|	Прием.СуммаДокумента КАК СуммаДокумента
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.КурсЛечения = &КурсЛечения
		|	И Прием.Сотрудник = &Сотрудник
		|	И Прием.Проведен
		|	И Прием.РезультатПриема <> 0
		|	И Прием.Контрагент = &Контрагент
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВремяОкончанияПриема УБЫВ,
		|	ВремяНачалаПриема УБЫВ,
		|	Ссылка УБЫВ,
		|	Номер УБЫВ";
	
	Запрос.УстановитьПараметр("Контрагент" , ЭтотОбъект.Контрагент);
	Запрос.УстановитьПараметр("КурсЛечения", ЭтотОбъект.КурсЛечения);
	Запрос.УстановитьПараметр("Сотрудник"  , ЭтотОбъект.Сотрудник);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;	
	РезультатТЧ            = Результат.Выгрузить();
	ДанныеПоследнегоПриема = РезультатТЧ[0]; 
	ИзменитьДатуНачала     = Ложь;
	ИзменитьДатуОкончания  = Ложь;
	ИтоговаяСумма          = РезультатТЧ.Итог("СуммаДокумента");
	ЛечениеВрачаОбъект     = ЭтотОбъект.ЛечениеВрача.ПолучитьОбъект();

	Если ДанныеПоследнегоПриема.Ссылка = ЭтотОбъект.Ссылка Тогда
		ИзменитьДатуОкончания = Истина;  
		ИзменитьДатуНачала    = (ЭтотОбъект.ВремяНачалаПриема < ЛечениеВрачаОбъект.ДатаНачала);
	ИначеЕсли ЭтотОбъект.ВремяНачалаПриема < ЛечениеВрачаОбъект.ДатаНачала Тогда
		ИзменитьДатуНачала = Истина;
	КонецЕсли;
	
	Если ИзменитьДатуНачала = Истина Или ИзменитьДатуОкончания = Истина Или ИтоговаяСумма <> ЛечениеВрачаОбъект.СуммаЛечения Тогда 
		Если ИзменитьДатуОкончания Тогда
			ЛечениеВрачаОбъект.ДатаОкончания = ?(ДанныеПоследнегоПриема.РезультатПриема = 2, Дата(1,1,1), ДанныеПоследнегоПриема.ВремяОкончанияПриема);
		КонецЕсли;
		Если ИзменитьДатуНачала Тогда
			ЛечениеВрачаОбъект.ДатаНачала = ?(ЭтотОбъект.ВремяНачалаПриема < ЛечениеВрачаОбъект.ДатаНачала, ЭтотОбъект.ВремяНачалаПриема, ЛечениеВрачаОбъект.ДатаНачала);
		КонецЕсли;
		ЛечениеВрачаОбъект.СуммаЛечения = ИтоговаяСумма;
		Попытка  
			ЛечениеВрачаОбъект.Записать(); 
			ИзмененоЛечение = Истина;
		Исключение 
			ОписаниеОшибки = "Ошибка при записи лечения по приему " + Строка(ЭтотОбъект.Ссылка) + " " + ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("ОткрытьЗакрытьЛечениеВрачаПриЗаписиПриема", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			Отказ = Истина; 
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

// Процедура - Открыть закрыть курс лечения
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ОткрытьЗакрытьКурсЛечения(Отказ)
	
	// 1. Открываем, если есть открытое лечение и результат Продолжает лечение
	// 2. Закрываем, если нет открытых лечений и результат Санация
	// 3. Перемещаем дату начала, если дата текущего приема меньше даты курса.
	// 4. Рассчитать итоговую сумму
	Открыть = Ложь;
	Закрыть = Ложь;
	ПереместитьДатуНачала = Ложь; 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Лечения.ДатаОкончания КАК ДатаОкончания,
		|	Лечения.СуммаЛечения КАК СуммаЛечения,
		|	Лечения.ДатаНачала КАК ДатаНачала
		|ИЗ
		|	Справочник.Лечения КАК Лечения
		|ГДЕ
		|	Лечения.КурсЛечения = &КурсЛечения
		|	И НЕ Лечения.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаОкончания УБЫВ,
		|	ДатаНачала УБЫВ";	
	Запрос.УстановитьПараметр("КурсЛечения", КурсЛечения);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		 Возврат;
	КонецЕсли;

	РезультатТЧ = Результат.Выгрузить();
	Если ЭтотОбъект.РезультатПриема = 2 И ЭтотОбъект.ЛечениеВрача.ДатаОкончания = Дата(1,1,1) Тогда
		Открыть = Истина;
	ИначеЕсли ЭтотОбъект.РезультатПриема = 1 Тогда		 
		НайденныеСтроки            = РезультатТЧ.НайтиСтроки(Новый Структура("ДатаОкончания", Дата(1,1,1)));
		ЕстьОткрытыеЛеченияПоКурсу = НайденныеСтроки.Количество() <> 0;
		Если Не ЕстьОткрытыеЛеченияПоКурсу Тогда 
			Для Каждого СтрокаТЧ Из РезультатТЧ Цикл 
				Если СтрокаТЧ.ДатаОкончания <> Дата(1,1,1) Тогда 
					ДатаОкончания = СтрокаТЧ.ДатаОкончания;
				КонецЕсли;	
			КонецЦикла;
			Если ДатаОкончания > ЭтотОбъект.КурсЛечения.ДатаОкончания Тогда
				Закрыть = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ЭтотОбъект.ВремяНачалаПриема < ЭтотОбъект.КурсЛечения.ДатаНачала Тогда
		ПереместитьДатуНачала = Истина;
	КонецЕсли;
	
	ИтоговаяСуммаЛечения = РезультатТЧ.Итог("СуммаЛечения"); 
	
	Если Открыть = Истина Или Закрыть = Истина Или ПереместитьДатуНачала = Истина Тогда
		КурсЛеченияОбъект = ЭтотОбъект.КурсЛечения.ПолучитьОбъект(); 
		
		Если Открыть Тогда
			ДатаОкончания = Дата(1,1,1);
		ИначеЕсли Не Закрыть Тогда
			ДатаОкончания = КурсЛеченияОбъект.ДатаОкончания;
		КонецЕсли; 
		КурсЛеченияОбъект.ДатаОкончания = ДатаОкончания; 
		КурсЛеченияОбъект.ДатаНачала    = ?(ПереместитьДатуНачала, ЭтотОбъект.ВремяНачалаПриема, КурсЛеченияОбъект.ДатаНачала); 
		КурсЛеченияОбъект.СуммаКурса    = ИтоговаяСуммаЛечения;
		Попытка 
			КурсЛеченияОбъект.Записать(); 
		Исключение  
			ОписаниеОшибки = "Ошибка при записи курса лечения по приему " + Строка(ЭтотОбъект.Ссылка) + " " + ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("ОткрытьЗакрытьКурсЛечения", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			Отказ = Истина;
		КонецПопытки;
    КонецЕсли; 

КонецПроцедуры
  
#КонецОбласти 

#КонецОбласти

#КонецЕсли
