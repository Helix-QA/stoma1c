		Справочники.КлассификаторСоциальныхСтатусов.СоздатьЗначенияПоУмолчанию();
		// Заполняем справочник КлассификаторСпециальностей из классификатора
		Справочники.КлассификаторСпециальностей.СоздатьЗначенияПоУмолчанию();
