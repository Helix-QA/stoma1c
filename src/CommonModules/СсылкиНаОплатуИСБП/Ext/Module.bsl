// Функция - Тинькофф зарегистрировать QR
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_ЗарегистрироватьQR(СтруктураПараметров)
	
	ПараметрыПШ                 = СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 				= СтруктураПараметров.СуммаОплаты;	
	КлючТерминалаТинькофф  		= СтруктураПараметров.ПараметрыПШ.КлючТерминалаТинькофф;
	СекретныйКлючТинькофф  		= СтруктураПараметров.ПараметрыПШ.СекретныйКлючТинькофф;
	ВремяЖизни					= СтруктураПараметров.ПараметрыПШ.ВремяЖизни;
	
	Если ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктураПараметров.ЭквайринговыйТерминал, "ТипФискализации") = Перечисления.ТипыФискализации.ВТинькофф Тогда
		СтруктураTinkoffReceipt = СтруктураTinkoffReceipt(СтруктураПараметров);
	КонецЕсли;
	
	РезультатЗапроса = Тинькофф_ИнициализацияПлатежнойСессии(ПараметрыПШ, СуммаОплаты, СтруктураTinkoffReceipt);
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		ПараметрыЗапроса = Новый Структура();
		ПараметрыЗапроса.Вставить("TerminalKey"	, КлючТерминалаТинькофф);
		ПараметрыЗапроса.Вставить("PaymentId"	, РезультатЗапроса.ПараметрыРезультата.PaymentId);
		
		ОбязательностьПодписиЗапросаТинькофф = Истина;	
		Если ОбязательностьПодписиЗапросаТинькофф Тогда
			ПараметрыЗапроса.Вставить("Token", Тинькофф_СформироватьПодписьЗапроса(ПараметрыЗапроса, СекретныйКлючТинькофф));	
		КонецЕсли;
		
		ТекстЗапроса = "";
		РезультатЗапроса = Тинькофф_ЗарегистрироватьQRЗапрос(ПараметрыЗапроса, ПараметрыПШ, ТекстЗапроса);
		
		Если РезультатЗапроса.ВыполненоУспешно Тогда
			
			Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл	
				
				КороткаяСсылка 	= РезультатЗапроса.ПараметрыРезультата.Data; //ОбщегоНазначения.ПолучитьКороткуюСсылку(РезультатЗапроса.ПараметрыРезультата.Data);
				
				РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
				СтрокаТ.ДокументЗадолженности,
				СтрокаТ.Задолженность,
				Формат(РезультатЗапроса.ПараметрыРезультата.PaymentId, "ЧГ=100"),
				КороткаяСсылка,
				Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено,
				СтруктураПараметров.ЭквайринговыйТерминал,
				РезультатЗапроса.ПараметрыРезультата.OrderId,ТекстЗапроса,,
				СтруктураПараметров.Контрагент,,
				СтруктураПараметров.СтруктурнаяЕдиница,
				ТекущаяДатаСеанса(),,
				Перечисления.ТипыСсылокНаОплату.СБПТинькофф,
				ПараметрыСеанса.ТекущийПользователь,
				ТекущаяДатаСеанса() + ВремяЖизни*3600
				);
				
			КонецЦикла;
			
			РезультатЗапроса.Вставить("СсылкаНаОплату"		, КороткаяСсылка);
			РезультатЗапроса.Вставить("ВремяДействителенДо"	, ТекущаяДатаСеанса() + ВремяЖизни*3600);
			РезультатЗапроса.Вставить("НомерЗаказа"			, РезультатЗапроса.ПараметрыРезультата.OrderId);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - Тинькофф инициализация платежной сессии
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_ИнициализацияПлатежнойСессии(ПараметрыПШ, СуммаОплаты, СтруктураTinkoffReceipt = Неопределено) Экспорт
		
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
		
	НастройкиСериализацииJSON = Новый НастройкиСериализацииJSON;
	НастройкиСериализацииJSON.ВариантЗаписиДаты 	 = ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением;
	НастройкиСериализацииJSON.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	
	НомерЗаказа = СформироватьНомерЗаказаСБП();
	ДатаСтрокой = ЗаписатьДатуJSON(ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600, ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением);	
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("TerminalKey"		, ПараметрыПШ.КлючТерминалаТинькофф);
	ПараметрыЗапроса.Вставить("Amount"			, СуммаОплаты*100); // Сумма в копейках 
	ПараметрыЗапроса.Вставить("OrderId"			, НомерЗаказа);
	ПараметрыЗапроса.Вставить("RedirectDueDate" , ДатаСтрокой);
	
	Если ЗначениеЗаполнено(СтруктураTinkoffReceipt) Тогда 		
		ПараметрыЗапроса.Вставить("Receipt", СтруктураTinkoffReceipt);
	КонецЕсли;
	
	ОбязательностьПодписиЗапросаТинькофф = Истина;	
	Если ОбязательностьПодписиЗапросаТинькофф И ЗначениеЗаполнено(СтруктураTinkoffReceipt) Тогда
		ПараметрыЗапроса.Вставить("Token", Тинькофф_СформироватьПодписьЗапроса(ПараметрыЗапроса, ПараметрыПШ.СекретныйКлючТинькофф));	
	КонецЕсли;
	
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса,, НастройкиСериализацииJSON);
	
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "rest-api-test.tinkoff.ru", "securepay.tinkoff.ru");
	Соединение		= Новый HTTPСоединение(АдресСервера,,,,,5, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос		= Новый HTTPЗапрос("/v2/Init/", ЗаголовкиHTTP);			
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
	
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Success И НРег(РезультатЗапроса.Status) = НРег("NEW");
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь, 
			РезультатЗапроса.message + ?(РезультатЗапроса.Свойство("details"), " " + ?(РезультатЗапроса.details = "{request.validate.expected.receipt}", "Необходимо включить в эквайринговом терминале фискализацию на стороне тинькофф", РезультатЗапроса.details), ""), ТелоОтвета);
			
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Тинькофф зарегистрировать QRЗапрос
//
// Параметры:
//  ПараметрыЗапроса - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_ЗарегистрироватьQRЗапрос(ПараметрыЗапроса, ПараметрыПШ, ТекстЗапроса = "")
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
			
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса);

	АдресСервера	= ?(ПараметрыПШ.ТестовыйРежим, "rest-api-test.tinkoff.ru", "securepay.tinkoff.ru");
	Соединение 		= Новый HTTPСоединение(АдресСервера,,,,,5, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос 		= Новый HTTPЗапрос("/v2/GetQr", ЗаголовкиHTTP);			
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
	
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Success;
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь, 
			РезультатЗапроса.message + ?(РезультатЗапроса.Свойство("details"), " " + РезультатЗапроса.details, ""), ТелоОтвета);
		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Сформировать подпись запроса тинькофф
//
// Параметры:
//  ПараметрыЗапроса - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_СформироватьПодписьЗапроса(ПараметрыЗапроса, СекретныйКлючТинькофф)
		
	Если ТипЗнч(ПараметрыЗапроса) <> Тип("Структура") ИЛИ Не ЗначениеЗаполнено(ПараметрыЗапроса) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыЗапроса.Вставить("Password", СекретныйКлючТинькофф);
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Ключ");
	ТЗ.Колонки.Добавить("Значение");
	
	Для Каждого ЭлСтруктуры Из ПараметрыЗапроса Цикл
		НоваяСтрока				= ТЗ.Добавить();
		НоваяСтрока.Ключ		= ЭлСтруктуры.Ключ;
		НоваяСтрока.Значение	= ЭлСтруктуры.Значение;
	КонецЦикла;
	
	ТЗ.Сортировать("Ключ");
	
	ПараметрыЗапроса.Очистить();
	Для Каждого СтрокаТЗ Из ТЗ Цикл
		ПараметрыЗапроса.Вставить(СтрокаТЗ.Ключ, СтрокаТЗ.Значение);
	КонецЦикла;
	
	ПараметрыСтрокой = "";
	
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		
		Если НРег(ПараметрЗапроса.Ключ) = НРег("Shops") ИЛИ НРег(ПараметрЗапроса.Ключ) = НРег("Receipt") 
			ИЛИ НРег(ПараметрЗапроса.Ключ) = НРег("DATA") ИЛИ НРег(ПараметрЗапроса.Ключ) = НРег("paymentType") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ПараметрЗапроса.Значение) = Тип("Число") Тогда
			ПараметрЗначение = Формат(ПараметрЗапроса.Значение, "ЧГ=100");
		ИначеЕсли ТипЗнч(ПараметрЗапроса.Значение) = Тип("Булево") Тогда 
			ПараметрЗначение = Формат(ПараметрЗапроса.Значение, "БЛ=false; БИ=true");
		Иначе
			ПараметрЗначение = ПараметрЗапроса.Значение
		КонецЕсли;
		
		ПараметрыСтрокой = ПараметрыСтрокой + ПараметрЗначение;
		
	КонецЦикла;
	
	ПараметрыЗапроса.Удалить("Password");
	
	Возврат IPТелефония.SHA256(ПараметрыСтрокой);
	
КонецФункции

// Функция - Тинькофф отменить QRКод
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_ОтменитьQRКод(СтруктураПараметров)
	
	ДокументыЗадолженности = Новый Массив;
	Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл
		ДокументыЗадолженности.Добавить(СтрокаТ.ДокументЗадолженности);	
	КонецЦикла;

	РезультатОперации	= СтруктураПараметров.СтруктураВозврата;
	ПараметрыПШ			= СтруктураПараметров.ПараметрыПШ;	
	НомерЗаказа			= ?(СтруктураПараметров.Свойство("НомерЗаказа"), СтруктураПараметров.НомерЗаказа, Неопределено);
	
	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьЗаказыПоДокументам(ДокументыЗадолженности, СтруктураПараметров.ЭквайринговыйТерминал, НомерЗаказа);
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		РезультатОперации.ОписаниеОшибки = "Не найдено неоплаченных заказов по данной ссылке";
		Возврат РезультатОперации;	
	КонецЕсли;
	
	МассивИдСБП = Новый Массив;
	Для Каждого СтрокаЗаказа Из ТаблицаЗаказов Цикл
		
		Если МассивИдСБП.Найти(СтрокаЗаказа.ИдЗаказа) = Неопределено Тогда
									
			РезультатОперации = Тинькофф_ОтменитьQRКодЗапрос(СтрокаЗаказа.ИдЗаказа, ПараметрыПШ);
			
			Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
				Возврат РезультатОперации;	
			КонецЕсли;
			
			МассивИдСБП.Добавить(СтрокаЗаказа.ИдЗаказа);
			
		КонецЕсли;
		
		ОписаниеСтатуса  = НСтр("ru='Платеж отменен пользователем ';en='Payment canceled by user '") + Строка(ПараметрыСеанса.ТекущийПользователь);
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаЗаказа.Основание,,,,
		Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ,,
		СтрокаЗаказа.НомерЗаказа,,,,,,,
		ОписаниеСтатуса);
		
	КонецЦикла;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Тинькофф отменить QRКод запрос
//
// Параметры:
//  ИдСБП		 - 	 - 
//  ПараметрыПШ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_ОтменитьQRКодЗапрос(ИдСБП, ПараметрыПШ, ТелоОтвета = Неопределено)
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("TerminalKey"	, ПараметрыПШ.КлючТерминалаТинькофф);
	ПараметрыЗапроса.Вставить("PaymentId"	, Число(ИдСБП));
	
	ОбязательностьПодписиЗапросаТинькофф = Истина;	
	Если ОбязательностьПодписиЗапросаТинькофф Тогда
		ПараметрыЗапроса.Вставить("Token", Тинькофф_СформироватьПодписьЗапроса(ПараметрыЗапроса, ПараметрыПШ.СекретныйКлючТинькофф));	
	КонецЕсли;	
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
	
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса);
	
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "rest-api-test.tinkoff.ru", "securepay.tinkoff.ru");
	Соединение		= Новый HTTPСоединение(АдресСервера,,,,,10, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос		= Новый HTTPЗапрос("/v2/Cancel", ЗаголовкиHTTP);					
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);			
								
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Success;
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь, 
			РезультатЗапроса.message + ?(РезультатЗапроса.Свойство("details"), " " + РезультатЗапроса.details, ""), ТелоОтвета);
			
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Тинькофф получить статус платежа
//
// Параметры:
//  ИдСБП		 - 	 - 
//  ПараметрыПШ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Тинькофф_ПолучитьСтатусПлатежа(ИдСБП, ПараметрыПШ, ТелоОтвета = Неопределено) Экспорт
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("TerminalKey"	, ПараметрыПШ.КлючТерминалаТинькофф);
	ПараметрыЗапроса.Вставить("PaymentId"	, ИдСБП);
	
	ОбязательностьПодписиЗапросаТинькофф = Истина;	
	Если ОбязательностьПодписиЗапросаТинькофф Тогда
		ПараметрыЗапроса.Вставить("Token", Тинькофф_СформироватьПодписьЗапроса(ПараметрыЗапроса, ПараметрыПШ.СекретныйКлючТинькофф));	
	КонецЕсли;	
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
	
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса);
	
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "rest-api-test.tinkoff.ru", "securepay.tinkoff.ru");
	Соединение		= Новый HTTPСоединение(АдресСервера,,,,,3, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос		= Новый HTTPЗапрос("/v2/GetState", ЗаголовкиHTTP);					
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);			
								
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Success;
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь, 
			РезультатЗапроса.message + ?(РезультатЗапроса.Свойство("details"), " " + РезультатЗапроса.details, ""), ТелоОтвета);
			
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

