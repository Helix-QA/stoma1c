
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ДатаНачала", 				ЭтотОбъект.НоваяДатаНачала);
	Параметры.Свойство("ДатаОкончания", 			ЭтотОбъект.НоваяДатаОкончания);
	Параметры.Свойство("Событие", 					ЭтотОбъект.ПереносимоеСобытие);
	Параметры.Свойство("Сотрудник", 				ЭтотОбъект.Сотрудник);
	Параметры.Свойство("СтруктурнаяЕдиница",		ЭтотОбъект.СтруктурнаяЕдиница);	
	Параметры.Свойство("Помещение",					ЭтотОбъект.Помещение);
	Параметры.Свойство("ВернутьВыбраннуюКоманду",	ЭтотОбъект.ВернутьВыбраннуюКоманду);
	Параметры.Свойство("ЭтоКопирование",			ЭтотОбъект.ЭтоКопирование);
	Параметры.Свойство("ЭтоПеренос",				ЭтотОбъект.ЭтоПеренос);
	
	ИнтервалЗаписи = ?(Параметры.Свойство("ИнтервалЗаписи"), Параметры.ИнтервалЗаписи, 0); 	
	ЭтотОбъект.ИнтервалЗаписи = ?(ИнтервалЗаписи = 1, 10, ?(ИнтервалЗаписи = 2, 5, ?(ИнтервалЗаписи = 3, 30, 15)));
	
	ЗаполнитьТаблицуПерекрестныхПриемов();
    ИзменитьДоступностьЭлементовФормы();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

 &НаКлиенте
// Процедура - Сократить время приема.
//
Процедура СократитьВремяПриема(Команда)
	
	Если ЭтотОбъект.ВернутьВыбраннуюКоманду Тогда
		ВернутьПараметрИЗакрытьФорму(Команда.Имя);
		Возврат;
	КонецЕсли;
	
	ДатаНачала = Дата(1,1,1);
	ДатаОкончания = Дата(1,1,1);
	
	ЭтотОбъект.ТаблицаПереносимыхПриемов.Очистить();
	
	НоваяСтрокаПереносимыхПриемов = ЭтотОбъект.ТаблицаПереносимыхПриемов.Добавить();
	НоваяСтрокаПереносимыхПриемов.Событие = ЭтотОбъект.ПереносимоеСобытие;
	
	Если ЭтотОбъект.ТаблицаПерекрестныхПриемов.Количество() = 1 Тогда
		
		СтрокаТЗ =  ЭтотОбъект.ТаблицаПерекрестныхПриемов[0];		
		ДатаНачала = ?(ЭтотОбъект.НоваяДатаНачала > СтрокаТЗ.ДатаНачала, СтрокаТЗ.ДатаОкончания, ЭтотОбъект.НоваяДатаНачала);
		ДатаОкончания = ?(ЭтотОбъект.НоваяДатаНачала > СтрокаТЗ.ДатаНачала, ЭтотОбъект.НоваяДатаОкончания, СтрокаТЗ.ДатаНачала);	
				
	Иначе	
		
		ТЗПерекрестныхПриемов = ЭтотОбъект.ТаблицаПерекрестныхПриемов;
		СвободныйИнтервал = ПолучитьСвободныйИнтервалМеждуСобытиями(ТЗПерекрестныхПриемов, ЭтотОбъект.НоваяДатаНачала, ЭтотОбъект.НоваяДатаОкончания);
		
		Если НЕ СвободныйИнтервал.МаксДатаОкончанияВерхних = Дата(1,1,1) И НЕ СвободныйИнтервал.МинДатаНачалаНижних = Дата(3000,1,1) Тогда
			ДатаНачала = СвободныйИнтервал.МаксДатаОкончанияВерхних;	
			ДатаОкончания = СвободныйИнтервал.МинДатаНачалаНижних;
		КонецЕсли;
				
	КонецЕсли;	
			
	Если ЭтотОбъект.ЭтоКопирование Тогда
		
		ВозвращаемыйПараметр = Новый Структура("Команда, ДатаНачала, ДатаОкончания", "СократитьВремяПриема", ДатаНачала, ДатаОкончания);		
		ВернутьПараметрИЗакрытьФорму(ВозвращаемыйПараметр);	
		Возврат;
		
	КонецЕсли;
	
	НоваяСтрокаПереносимыхПриемов.ДатаНачала = ДатаНачала;
	НоваяСтрокаПереносимыхПриемов.ДатаОкончания = ДатаОкончания;
	
	ПеренестиСобытияИОбновитьПланировщик();	
		
КонецПроцедуры

&НаКлиенте
// Процедура - Освободить время приема.
//
Процедура ОсвободитьВремяПриема(Команда)
	
	Если ЭтотОбъект.ВернутьВыбраннуюКоманду Тогда
		ВернутьПараметрИЗакрытьФорму(Команда.Имя);
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.ТаблицаПереносимыхПриемов.Очистить();
	
	Для Каждого СтрокаТЗ Из ЭтотОбъект.ТаблицаПерекрестныхПриемов Цикл
		
		Если НЕ СтрокаТЗ.ТипПерекрытия = 3 Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаПереносимыхПриемов = ЭтотОбъект.ТаблицаПереносимыхПриемов.Добавить();
		НоваяСтрокаПереносимыхПриемов.Событие = СтрокаТЗ.Событие;
				
		ОдинаковаяГраницаВремени = ((СтрокаТЗ.ДатаНачала = ЭтотОбъект.НоваяДатаНачала) ИЛИ (СтрокаТЗ.ДатаОкончания = ЭтотОбъект.НоваяДатаОкончания));
		
		Если НЕ ОдинаковаяГраницаВремени И СтрокаТЗ.ДатаОкончания > ЭтотОбъект.НоваяДатаОкончания Тогда
			
			НоваяСтрокаПереносимыхПриемов.ДатаНачала	= СтрокаТЗ.ДатаНачала + ?(ОдинаковаяГраницаВремени, 0, СтрокаТЗ.ПерекрываемоеВремя * 60);
			НоваяСтрокаПереносимыхПриемов.ДатаОкончания	= СтрокаТЗ.ДатаОкончания - ?(ОдинаковаяГраницаВремени, СтрокаТЗ.ПерекрываемоеВремя * 60, 0);
			
		ИначеЕсли НЕ ОдинаковаяГраницаВремени И СтрокаТЗ.ДатаНачала < ЭтотОбъект.НоваяДатаНачала Тогда
			
			НоваяСтрокаПереносимыхПриемов.ДатаНачала	= СтрокаТЗ.ДатаНачала + ?(ОдинаковаяГраницаВремени, СтрокаТЗ.ПерекрываемоеВремя * 60, 0);
			НоваяСтрокаПереносимыхПриемов.ДатаОкончания	= СтрокаТЗ.ДатаОкончания - ?(ОдинаковаяГраницаВремени, 0, СтрокаТЗ.ПерекрываемоеВремя * 60);				
			
		ИначеЕсли ОдинаковаяГраницаВремени Тогда
			
			НоваяСтрокаПереносимыхПриемов.ДатаНачала	= СтрокаТЗ.ДатаНачала + ?(СтрокаТЗ.ДатаНачала = ЭтотОбъект.НоваяДатаНачала, СтрокаТЗ.ПерекрываемоеВремя * 60, 0);
			НоваяСтрокаПереносимыхПриемов.ДатаОкончания	= СтрокаТЗ.ДатаОкончания - ?(СтрокаТЗ.ДатаОкончания = ЭтотОбъект.НоваяДатаОкончания, СтрокаТЗ.ПерекрываемоеВремя * 60, 0);		
						
		КонецЕсли;
		
	КонецЦикла;	
	
	Если НЕ ЭтотОбъект.ЭтоКопирование Тогда
		ДобавитьВТаблицуПереносимыхТекущийПрием();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ТаблицаПереносимыхПриемов) Тогда 	
		ПеренестиСобытияИОбновитьПланировщик();	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Перенести как есть.
//
Процедура ПеренестиКакЕсть(Команда)
	
	Если ЭтотОбъект.ВернутьВыбраннуюКоманду ИЛИ ЭтотОбъект.ЭтоКопирование Тогда
		ВернутьПараметрИЗакрытьФорму(Команда.Имя);
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.ТаблицаПереносимыхПриемов.Очистить();	
	ДобавитьВТаблицуПереносимыхТекущийПрием();
	ПеренестиСобытияИОбновитьПланировщик();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - Добавить в таблицу переносимых текущий прием.
//
Процедура ДобавитьВТаблицуПереносимыхТекущийПрием()
	
	НоваяСтрокаПереносимыхПриемов = ЭтотОбъект.ТаблицаПереносимыхПриемов.Добавить();
	НоваяСтрокаПереносимыхПриемов.Событие = ЭтотОбъект.ПереносимоеСобытие;
	НоваяСтрокаПереносимыхПриемов.ДатаНачала = ЭтотОбъект.НоваяДатаНачала;
	НоваяСтрокаПереносимыхПриемов.ДатаОкончания = ЭтотОбъект.НоваяДатаОкончания;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Перенести события и обновить планировщик.
//
Процедура ПеренестиСобытияИОбновитьПланировщик()
	
	ТЗПереносимыхПриемов = ЭтотОбъект.ТаблицаПереносимыхПриемов;
	ПеренестиСобытия(ТЗПереносимыхПриемов, ЭтотОбъект.Сотрудник, ЭтотОбъект.Помещение);	
	ВернутьПараметрИЗакрытьФорму(?(ЭтотОбъект.ЭтоКопирование, "ПеренестиКакЕсть", "ОбновлениеСтраницыЖурналПредварительнойЗаписи"));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Вернуть команду и закрыть форму.
//
Процедура ВернутьПараметрИЗакрытьФорму(ВозвращаемыйПараметр = Неопределено)

	ЭтаФорма.Закрыть(ВозвращаемыйПараметр);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Перенести события из ТЗ ТаблицаПереносимыхПриемов.
//
Процедура ПеренестиСобытия(ТаблицаПереносимыхПриемов, Сотрудник, Помещение = Неопределено)
	
	Для Каждого ПереносимыйПрием Из ТаблицаПереносимыхПриемов Цикл
		Документы.Событие.ПеренестиПредварительнуюЗапись(ПереносимыйПрием.Событие, Сотрудник, Помещение, ПереносимыйПрием.ДатаНачала, ПереносимыйПрием.ДатаОкончания, Истина); 		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Функция - Просчитать время перекрытия событий.
// 
Функция ПросчитатьВремяПерекрытияСобытий()	
	
	// Типы перекрытий:
	// 1 - Полностью перекрывает.
	// 2 - Свободный промежуток меньше одной строки журнала.
	// 3 - Частичное перекрытие, остается 1 и более строк журнала.
	
	ДлительностьПереносимогоПриема = ЭтотОбъект.НоваяДатаОкончания - ЭтотОбъект.НоваяДатаНачала;
	
	Для Каждого СтрокаТЗ Из ЭтотОбъект.ТаблицаПерекрестныхПриемов Цикл
		
		Перекрытие = 0;
		
		Если (СтрокаТЗ.ДатаНачала <= ЭтотОбъект.НоваяДатаНачала И СтрокаТЗ.ДатаОкончания >= ЭтотОбъект.НоваяДатаОкончания) ИЛИ
			 (СтрокаТЗ.ДатаНачала >= ЭтотОбъект.НоваяДатаНачала И СтрокаТЗ.ДатаОкончания <= ЭтотОбъект.НоваяДатаОкончания) Тогда						 
			 
			Если (НЕ СтрокаТЗ.ДатаОкончания - СтрокаТЗ.ДатаНачала = ДлительностьПереносимогоПриема) И 
					(ЭтотОбъект.НоваяДатаНачала = СтрокаТЗ.ДатаНачала ИЛИ ЭтотОбъект.НоваяДатаОкончания = СтрокаТЗ.ДатаОкончания) Тогда	 
					
				Перекрытие = ДлительностьПереносимогоПриема / 60;	
			Иначе
				Перекрытие = СтрокаТЗ.Длительность;
			КонецЕсли;
			
		ИначеЕсли СтрокаТЗ.ДатаНачала > ЭтотОбъект.НоваяДатаНачала И СтрокаТЗ.ДатаОкончания > ЭтотОбъект.НоваяДатаОкончания Тогда			
			Перекрытие = (ЭтотОбъект.НоваяДатаОкончания - СтрокаТЗ.ДатаНачала) / 60;							
		ИначеЕсли СтрокаТЗ.ДатаНачала < ЭтотОбъект.НоваяДатаНачала И СтрокаТЗ.ДатаОкончания < ЭтотОбъект.НоваяДатаОкончания Тогда				
			Перекрытие = (СтрокаТЗ.ДатаОкончания - ЭтотОбъект.НоваяДатаНачала) / 60;									
		КонецЕсли;	
		
		СтрокаТЗ.ПерекрываемоеВремя = Перекрытие;
		СтрокаТЗ.ТипПерекрытия = ?(Перекрытие = СтрокаТЗ.Длительность, 1, ?(СтрокаТЗ.Длительность - Перекрытие < ИнтервалЗаписи, 2, 3)); 			
		
	КонецЦикла;	
		
КонецФункции

&НаСервере
// Процедура - Изменить доступность элементов формы.
//
Процедура ИзменитьДоступностьЭлементовФормы()
	
	ОсвободитьВремяДоступна = Ложь;
	СократитьПриемДоступна = Ложь;
	
	КоличествоПерекрестныхПриемов = ЭтотОбъект.ТаблицаПерекрестныхПриемов.Количество();																									
	
	Если КоличествоПерекрестныхПриемов > 0 Тогда																				
		
		ПросчитатьВремяПерекрытияСобытий();
		
		КолвоПриемовСТипом3 = ЭтотОбъект.ТаблицаПерекрестныхПриемов.НайтиСтроки(Новый Структура("ТипПерекрытия", 3)).Количество();
		
		Если КоличествоПерекрестныхПриемов = 1 Тогда
			
			СтрокаТЗ = ЭтотОбъект.ТаблицаПерекрестныхПриемов[0];							
			ЕстьСвоободнаяСтрока = ((ЭтотОбъект.НоваяДатаОкончания - СтрокаТЗ.ДатаОкончания) / 60 >= ЭтотОбъект.ИнтервалЗаписи ИЛИ
			(СтрокаТЗ.ДатаНачала - ЭтотОбъект.НоваяДатаНачала) / 60 >= ЭтотОбъект.ИнтервалЗаписи);								
			
			ОсвободитьВремяДоступна = (СтрокаТЗ.ТипПерекрытия = 3);
			СократитьПриемДоступна = (ОсвободитьВремяДоступна И ЕстьСвоободнаяСтрока);
			
		ИначеЕсли КолвоПриемовСТипом3 = КоличествоПерекрестныхПриемов Тогда					
			
			// Если все приемы частично-перекрыты.
			ОсвободитьВремяДоступна = Истина;  									
			СократитьПриемДоступна = ВозможноСокращениеВремениСобытия();
			
		КонецЕсли;		
		
	КонецЕсли;
	
	Элементы.КомандаОсвободитьВремяДляПриема.Доступность = ОсвободитьВремяДоступна;
	Элементы.КомандаСократитьВремяПриема.Доступность = СократитьПриемДоступна;
	
	ЭтоВставка = (ЭтотОбъект.ЭтоКопирование = Истина);
	ЭтаФорма.Заголовок = ?(ЭтоВставка, "Как вставить?", "Как перенести?"); 
	Если НЕ ЭтотОбъект.ЭтоКопирование И НЕ ЭтотОбъект.ЭтоПеренос Тогда
		Элементы.КомандаПеренестиКакЕсть.Видимость = Ложь;
		ЭтаФорма.Заголовок = "Как записать?";
	КонецЕсли;
	Элементы.КомандаПеренестиКакЕсть.Заголовок = ?(ЭтоВставка, " Вставить", " Перенести") + " как есть                   " + ?(ЭтоВставка, "  ", "");	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция - Получить свободный интервал между событиями.
// 
Функция ПолучитьСвободныйИнтервалМеждуСобытиями(ТаблицаПерекрестныхПриемов, НоваяДатаНачала, НоваяДатаОкончания)
	
	МаксДатаОкончанияВерхних = Дата(1,1,1);
	МинДатаНачалаНижних = Дата(3000,1,1);	
	
	Для Каждого СтрокаТЗ Из ТаблицаПерекрестныхПриемов Цикл
		
		Если СтрокаТЗ.ДатаНачала < НоваяДатаНачала И СтрокаТЗ.ДатаОкончания > МаксДатаОкончанияВерхних Тогда			
			МаксДатаОкончанияВерхних = СтрокаТЗ.ДатаОкончания;				
		ИначеЕсли СтрокаТЗ.ДатаОкончания > НоваяДатаОкончания И СтрокаТЗ.ДатаНачала < МинДатаНачалаНижних Тогда
			МинДатаНачалаНижних = СтрокаТЗ.ДатаНачала;			
		КонецЕсли;	
		
	КонецЦикла;
	
	// Чтоб не делать еще проверки. Вверху или внизу может не быть событий, но нужно получить границу вставки!
	
	МинДатаНачалаНижних = ?(МинДатаНачалаНижних = Дата(3000,1,1), НоваяДатаОкончания, МинДатаНачалаНижних);
	МаксДатаОкончанияВерхних = ?(МаксДатаОкончанияВерхних = Дата(1,1,1), НоваяДатаНачала, МаксДатаОкончанияВерхних);
	
	Возврат Новый Структура("МаксДатаОкончанияВерхних, МинДатаНачалаНижних", МаксДатаОкончанияВерхних, МинДатаНачалаНижних);
	
КонецФункции

&НаСервере
// Функция - Возможно сокращение времени события.
// 
Функция ВозможноСокращениеВремениСобытия()
	
	ТЗПерекрестныхПриемов = ЭтотОбъект.ТаблицаПерекрестныхПриемов;
	СвободныйИнтервал = ПолучитьСвободныйИнтервалМеждуСобытиями(ТЗПерекрестныхПриемов, ЭтотОбъект.НоваяДатаНачала, ЭтотОбъект.НоваяДатаОкончания);
	
	Если НЕ СвободныйИнтервал.МаксДатаОкончанияВерхних = Дата(1,1,1) И НЕ СвободныйИнтервал.МинДатаНачалаНижних = Дата(3000,1,1) Тогда		
		РезультатПроверки = ((СвободныйИнтервал.МинДатаНачалаНижних - СвободныйИнтервал.МаксДатаОкончанияВерхних) / 60) >= ЭтотОбъект.ИнтервалЗаписи;	
	Иначе		
		РезультатПроверки = Ложь;		
	КонецЕсли;
		
	Возврат РезультатПроверки;
	
КонецФункции

&НаСервере
// Процедура - Заполнить таблицу перекрестных приемов.
