// Функция, возвращает ссылку по УИД.
// 
Функция ПолучитьСсылкуОбъектаПоУИД(УИД, ВидОбъекта, ИмяОбъекта)
	
	Попытка
		
		ИмяТаблицы = ВидОбъекта;
		Выполнить("ВидОбъекта = " + ВидОбъекта);
		Ссылка = ВидОбъекта[ИмяОбъекта].ПолучитьСсылку(Новый УникальныйИдентификатор(УИД));
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ТекущиеДанные.Ссылка КАК Ссылка
		|ИЗ
		|	[ИмяТаблицы] КАК ТекущиеДанные
		|ГДЕ
		|	ТекущиеДанные.Ссылка = &Ссылка");
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		
		ИмяТаблицы = Сред(ИмяТаблицы, 1, СтрДлина(ИмяТаблицы) - 1);
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "[ИмяТаблицы]", ИмяТаблицы + "." + ИмяОбъекта);
		
		Если Запрос.Выполнить().Пустой() Тогда
			Ссылка = Неопределено;
		КонецЕсли;		
		
	Исключение
		Ссылка = Неопределено;
	КонецПопытки;
	
	Возврат Ссылка;
	
КонецФункции

// Функция - возвращает цвет текста для указанного цвета фона.
// 
// Параметры:
//  ЦветФона - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьЦветТекстаПоЦветуФона(ЦветФонаСтруктурой)
	
	RGBЦвет = Новый Цвет(Число(ЦветФонаСтруктурой.Красный), Число(ЦветФонаСтруктурой.Зеленый), Число(ЦветФонаСтруктурой.Синий));
	
	Если RGBЦвет <> Неопределено Тогда
		
		// Если цвет белый.
		Если RGBЦвет.Красный = 255
			И RGBЦвет.Зеленый = 255
			И RGBЦвет.Синий = 255 Тогда
			
			ЦветТекста = Новый Цвет(128, 128, 128);
			
		ИначеЕсли (1 - (0.299 * RGBЦвет.Красный + 0.587 * RGBЦвет.Зеленый + 0.114 * RGBЦвет.Синий) / 255) > 0.5 Тогда
			
			ЦветТекста = Новый Цвет(250, 250, 250);
		Иначе
			ЦветТекста = Новый Цвет(64, 64, 64);
		КонецЕсли;
		
	Иначе
		ЦветТекста = Новый Цвет(64, 64, 64);
	КонецЕсли;
	
	Возврат Новый Структура("Красный, Зеленый, Синий", ЦветТекста.Красный, ЦветТекста.Зеленый, ЦветТекста.Синий)
	
КонецФункции

// Процедура - Обработка визитов
// 
// Параметры:
//  НайденныеСтроки	 - 	 - 
// 
Процедура ОбработкаСтрокСобытия(СтрокиСОбытия)
	
	Индекс = 0;
	Пока Индекс < СтрокиСОбытия.Количество() - 1 Цикл 
		
		СтрокаСобытия = СтрокиСОбытия[Индекс];
		
		Если СтрокаСобытия.ДатаВремяОкончания < СтрокиСОбытия[Индекс + 1].ДатаВремяНачала Тогда
			СтрокиСОбытия.Удалить(Индекс + 1);
			Продолжить;
		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Для Каждого СтрокаСобытия Из СтрокиСОбытия Цикл						
		СтрокаСобытия.Использован = Истина;		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Нумерация записей планировщика
// 
// Параметры:
//  МассивВизитов	 - 	 - 
// 
Процедура НумерацияЗаписейПланировщика(МассивВозврат)
	
	Для Индекс = 0 По МассивВозврат.Количество() - 1 Цикл
		
		КолЭлем = 1; 
		Для ИндексСтр = Индекс + 1 По МассивВозврат.Количество() - 1 Цикл
			
			Если МассивВозврат[ИндексСтр].Визит = МассивВозврат[Индекс].Визит Тогда
				
				КолЭлем = КолЭлем + 1;
				МассивВозврат[ИндексСтр].Текст = "[" + КолЭлем + "] " + МассивВозврат[ИндексСтр].Текст;  
				
			КонецЕсли;
		КонецЦикла;
		
		Если КолЭлем > 1 Тогда
			МассивВозврат[Индекс].Текст = "[1] " + МассивВозврат[Индекс].Текст;
			Индекс = Индекс + КолЭлем - 1;    	
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры

