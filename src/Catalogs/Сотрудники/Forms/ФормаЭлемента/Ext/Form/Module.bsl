// Процедура - Установить видимость элементов
//
Процедура УстановитьВидимостьЭлементов(ПриИзмененииРоли = Ложь)
	
	ЭтоВрач = (Объект.Роль = Перечисления.РольПользователя.Врач ИЛИ Объект.Роль = Перечисления.РольПользователя.ГлавныйВрач);
	
	Если Не ЭтоВрач Тогда
		ЭтотОбъект.ОнлайнЗапись = Ложь;
	КонецЕсли;
	
	Элементы.ГруппаОнлайнЗапись.Видимость 			= ЭтоВрач;
	Элементы.ГруппаНастройкаОнлайнЗаписи.Видимость  = ЭтотОбъект.ОнлайнЗапись И ЭтотОбъект.ДоступныеСтруктурныеЕдиницы.Количество() > 1;
	Элементы.ГруппаОписаниеДляСайтаHTML.Видимость   = ЭтотОбъект.ОнлайнЗапись;
	
	Если ПриИзмененииРоли И Не Объект.Ссылка.Пустая() И Не ЭтоВрач Тогда
		
		РегистрыСведений.РеквизитыОбъектов.УдалитьЗаписиВРегистреРеквизитыОбъектов(Объект.Ссылка, "ОнлайнЗаписьСотрудник");
		
	КонецЕсли;
	
	Элементы.АдресКартинкиКонтекстноеМенюВставитьИзФайла.Доступность  = ЭтотОбъект.РедактированиеРазрешено;
	Элементы.АдресКартинкиКонтекстноеМенюСохранить.Доступность		  = ЭтотОбъект.РедактированиеРазрешено;
	Элементы.АдресКартинкиКонтекстноеМенюУдалить.Доступность          = ЭтотОбъект.РедактированиеРазрешено;
	ВывестиСсылкуНаСотрудника();
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Если НЕ ПривилегированныйРежим() Тогда 
			УстановитьПривилегированныйРежим(Истина);
		КонецЕсли;
		Если Объект.Ссылка = Константы.СотрудникЧатБота.Получить() Тогда 
			Элементы.ГруппаПользовательИБДобавить.Доступность = Ложь;
		КонецЕсли;                                                   
	КонецЕсли;	
	
	// МобильноеПриложениеУправляющего.
	Если Не Объект.Ссылка.Пустая() Тогда
		
		Если РегистрыСведений.КлючиВнешнихСистем.СотрудникЗарегистрированДляВнешнейСистемы(Объект.Ссылка, Истина, ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего) Тогда
			
			ОписаниеОшибки = "";
			ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего = АктуализироватьДоступКличномуРасписанию(ОписаниеОшибки, ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего);
			
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка синхронизации мобильного приложения с CRM. " + ОписаниеОшибки);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.Роль.Видимость = Не ДоступКИБ;
	
	НомерТелефонаТекущий = ПолучитьНомерТелефонаСотрудника(Объект.Ссылка);
	
	Элементы.ГруппаДоступКЛичномуРасписаниюУправляющего.ТолькоПросмотр	= НЕ РольДоступна("ПолныеПрава");
	
	ДоступноПриложениеУправляющего = Объект.Роль <> Перечисления.РольПользователя.Бухгалтер И Объект.Роль <> Перечисления.РольПользователя.АдминистраторБазыДанных И Объект.Роль <> Перечисления.РольПользователя.СестраХозяйка; 
	
	Элементы.ГруппаДоступКЛичномуРасписаниюУправляющего.Видимость = ДоступноПриложениеУправляющего;
	
	Если ДоступноПриложениеУправляющего Тогда
		
		Элементы.КодПодтверждения.Видимость = ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего;
		
		Если Элементы.КодПодтверждения.Видимость Тогда
			ПолучитьКодПодтвержденияДляАвторизации(ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего);
		КонецЕсли;
		ЭтотОбъект.ВклОтклПриложениеУправляющего = ЭтотОбъект.ДоступКЛичномуРасписаниюУправляющего;
		
	КонецЕсли;
	
	Элементы.ДоступныеКлиникиЖурналаПриемов.Видимость = ЭтотОбъект.ДоступКИБ;
	Элементы.ДоступныеКассы.Видимость 				  = ЭтотОбъект.ДоступКИБ;
	
КонецПроцедуры

