		мПараметрыВыбора.Вставить("Склад"             , Объект.Склад);
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		мПараметрыВыбора.Вставить("Дата"              , Объект.Дата);
        мПараметрыВыбора.Вставить("МножественныйВыбор", Истина);

		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", мПараметрыВыбора,,,,, 
						Новый ОписаниеОповещения("ЗапасыПартияНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
    
	КонецЕсли;
	
