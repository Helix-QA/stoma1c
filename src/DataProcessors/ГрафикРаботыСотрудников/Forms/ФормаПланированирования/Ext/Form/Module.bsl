&НаСервере
// Обработчик при создании формы на сервере
// 
// 
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЕстьПравоРедактирования = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ДобавлениеИзменениеГрафикаРаботыСотрудников"); 
	
	ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	ОтборСотрудникДолжность = "Все";
	
	Элементы.ОткрытьСписокСотрудники.Заголовок	= "Все";
	Элементы.ОткрытьСписокДолжности.Заголовок	= "Все"; 
	Элементы.ОткрытьСписокРоли.Заголовок		= "Все";
	Элементы.ОткрытьСписокКлиник.Заголовок		= Строка(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		
	// Получаем массив номеров рабочих дней недели для СЕ	
	ОбновитьМассивРабочихДнейВНеделе();
	
	// Добавим первую пустую неудаляемую строку интервала 
	ОтборИнтервалыРаботы.Добавить(Новый Структура("НачалоРаботы, ОкончаниеРаботы", Неопределено, Неопределено));
	
    Элементы.ГруппаПереклКлиника.Видимость = ПолучитьТаблицуКлиник().Количество() > 1;
	Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.Доступность = ЕстьПравоРедактирования;
	Элементы.ГруппаОтбораИнтерваловРаботы.Видимость = ЕстьПравоРедактирования;
	
КонецПроцедуры

&НаКлиенте
// Обработчик открытия формы
// 
// 
Процедура ПриОткрытии(Отказ)
	
	Если Не ФлагОткрытия Тогда
		ПриОткрытииНаСервере();	
	КонецЕсли;
	ЗадатьПериодСменыНаФорме();

КонецПроцедуры

&НаКлиенте
// Обработчик оповещения формы о внешнем событии
// 
// 
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПРИ_ЗАПИСИ_СТРУКТУРНОЙ_ЕДИНИЦЫ" Тогда
		// Получаем массив номеров рабочих дней недели для СЕ	
		ОбновитьМассивРабочихДнейВНеделе();
		ОбновитьОтображениеПланирования(Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик перед закрытием формы
// 
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда 
		Возврат;
	КонецЕсли;
	
	Если ПроверятьНеобхЗаписи = Истина И ПроверитьНеобходимостьФиксацииИзмененийВПлане() = Истина Тогда	
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаОЗаписиИзмененийОповещение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение,"Имеются несохраненные изменения графика работы. Записать изменения перед закрытием ?", РежимДиалогаВопрос.ДаНетОтмена);
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

