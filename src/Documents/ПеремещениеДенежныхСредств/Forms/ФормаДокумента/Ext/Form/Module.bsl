// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ РЕКВИЗИТОВ ШАПКИ

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	Если НачалоДня(Объект.Дата) < НачалоДня(ТекущаяДата()) Тогда
		 Объект.Дата = КонецДня(Объект.Дата);
	КонецЕсли;	 
	
	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
	ИсточникДенежныхСредствПриИзмененииСервер();
	ПриемникДенежныхСредствПриИзмененииСервер(); 
	
КонецПроцедуры 

&НаСервереБезКонтекста  
// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции 

&НаКлиенте
// Процедура - обработчик события ПриИзменении поля ввода ТипДенежныхСредств.
//
Процедура ТипДенежныхСредствПриИзменении(Элемент)
	
	УстановитьВидимость();
	Объект.ИсточникСписанияСредств   = Неопределено;
	Объект.ИсточникВидЛицевогоСчета  = ?(Элементы.ИсточникВидЛицевогоСчета.Видимость,Неопределено,Объект.ИсточникВидЛицевогоСчета);
	Объект.ПриемникЗачисленияСредств = Неопределено;
	Объект.ПриемникВидЛицевогоСчета  = ?(Элементы.ПриемникВидЛицевогоСчета.Видимость,Неопределено,Объект.ПриемникВидЛицевогоСчета);
    Объект.СуммаДокумента            = 0;
		
КонецПроцедуры // ТипДенежныхСредствПриИзменении()

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля "Комментарий".
//
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиентСтоматология.ОткрытьФормуРедактированияКомментария(Элемент.ТекстРедактирования, Объект.Комментарий, Модифицированность);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля "Комментарий".
//
Процедура ИсточникДенежныхСредствНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Объект.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные") Тогда
		
		Отбор = Новый Структура("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		ОткрытьФорму("Справочник.Кассы.ФормаВыбора", Новый Структура("Отбор", Отбор),,,,,Новый ОписаниеОповещения("ИсточникДенежныхСредствНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	ИначеЕсли Объект.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет") Тогда
		
		ОткрытьФорму("Справочник.Контрагенты.ФормаВыбора",,,,,,Новый ОписаниеОповещения("ИсточникДенежныхСредствНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	ИначеЕсли Объект.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные") Тогда
		
		Отбор = Новый Структура("Владелец", ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация"));
		ОткрытьФорму("Справочник.БанковскиеСчета.ФормаВыбора", Новый Структура("Отбор", Отбор),,,,,Новый ОписаниеОповещения("ИсточникДенежныхСредствНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриемникДенежныхСредствНачалоВыбораЗавершение"
//
Процедура ИсточникДенежныхСредствНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Объект.ИсточникСписанияСредств = Результат;
		ИсточникДенежныхСредствПриИзмененииСервер();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// При изменении значения выбора источника денежных средств
Процедура ИсточникДенежныхСредствПриИзменении(Элемент)	
	  ИсточникДенежныхСредствПриИзмененииСервер();	
КонецПроцедуры

&НаСервере
// При изменении значения выбора источника денежных средств сервер
Процедура ИсточникДенежныхСредствПриИзмененииСервер()
	
	// Получение остатков по источнику
	ОстатокСредств = 0;
	Если ЗначениеЗаполнено(Объект.ИсточникСписанияСредств) И ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
		
		Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные 
			ИЛИ Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			
			ОстатокСредств = РегистрыНакопления.ДенежныеСредства.ПолучитьОстаткоДенежныхСредств(Объект.Дата,Объект.ИсточникСписанияСредств,Объект.Ссылка);
		ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
			
			ОстатокСредств = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.ИсточникСписанияСредств,Объект.Дата,Объект.Ссылка,Объект.СтруктурнаяЕдиница,Объект.ИсточникВидЛицевогоСчета,Истина);
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ДекорацияОстатокПоИсточнику.Заголовок = "Остаток " +ОстатокСредств+ " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
	Если ОстатокСредств < 0 Тогда
		Элементы.ДекорацияОстатокПоИсточнику.ЦветТекста = WebЦвета.Красный;
	Иначе
		Элементы.ДекорацияОстатокПоИсточнику.ЦветТекста = WebЦвета.Черный;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// При изменении контрагента источника
Процедура ИсточникКонтрагентПриИзменении(Элемент)
	ИсточникДенежныхСредствПриИзмененииСервер();	
КонецПроцедуры

&НаКлиенте
