		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПродажиОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ПродажиОбороты.Номенклатура КАК НоменклатураСтатья,
	ПродажиОбороты.Партия КАК Партия,
	ПродажиОбороты.ДокументПродажи КАК ДокументПродажи,
	ПродажиОбороты.Сотрудник КАК Сотрудник,
	ПродажиОбороты.Контрагент КАК Контрагент,
	0 КАК Затраты,
	0 КАК Зарплата,
	0 КАК ПризнакВидаЗатрат,
	ЕСТЬNULL(ПродажиОбороты.КоличествоОборот, 0) КАК Количество,
	ЕСТЬNULL(ПродажиОбороты.СтоимостьОборот, 0) КАК Стоимость,
	ЕСТЬNULL(ПродажиСебестоимостьОбороты.КоличествоОборот, 0) КАК СебестоимостьКоличество,
	ЕСТЬNULL(ПродажиСебестоимостьОбороты.СтоимостьОборот, 0) КАК Себестоимость,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ПродажиОбороты.ДокументПродажи) = ТИП(Документ.Прием)
			ТОГДА ПродажиОбороты.ДокументПродажи.СтатусПациента
	КОНЕЦ КАК СтатусПациента,
	ПродажиОбороты.ПериодСекунда,
	ПродажиОбороты.ПериодМинута,
	ПродажиОбороты.ПериодЧас,
	ПродажиОбороты.ПериодДень,
	ПродажиОбороты.ПериодНеделя,
	ПродажиОбороты.ПериодДекада,
	ПродажиОбороты.ПериодМесяц,
	ПродажиОбороты.ПериодКвартал,
	ПродажиОбороты.ПериодПолугодие,
	ПродажиОбороты.ПериодГод
ИЗ
	РегистрНакопления.Продажи.Обороты(, , Авто, ) КАК ПродажиОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПродажиСебестоимость.Обороты(, , Авто, ) КАК ПродажиСебестоимостьОбороты
		ПО ПродажиОбороты.ДокументПродажи = ПродажиСебестоимостьОбороты.ДокументПродажи
			И ПродажиОбороты.Номенклатура = ПродажиСебестоимостьОбороты.Номенклатура
			И ПродажиОбороты.СтруктурнаяЕдиница = ПродажиСебестоимостьОбороты.СтруктурнаяЕдиница
			И ПродажиОбороты.Сотрудник = ПродажиСебестоимостьОбороты.Сотрудник
			И ПродажиОбороты.Контрагент = ПродажиСебестоимостьОбороты.Контрагент
			И (ВЫБОР
				КОГДА ПродажиСебестоимостьОбороты.Склад ССЫЛКА Справочник.Склады
					ТОГДА ПродажиОбороты.Склад = ПродажиСебестоимостьОбороты.Склад
				ИНАЧЕ ПродажиОбороты.Сотрудник = ПродажиСебестоимостьОбороты.Склад
			КОНЕЦ)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗатратыОбороты.СтруктурнаяЕдиница,
	ВЫБОР
		КОГДА ЗатратыОбороты.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
				ИЛИ ЗатратыОбороты.Номенклатура ЕСТЬ NULL
			ТОГДА " " + ЗатратыОбороты.СтатьяЗатрат.Наименование
		ИНАЧЕ ЗатратыОбороты.Номенклатура
	КОНЕЦ,
	NULL,
	ЗатратыОбороты.Регистратор,
	ЗатратыОбороты.Сотрудник,
	ЗатратыОбороты.Контрагент,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ЗатратыОбороты.СтатьяЗатрат) = ТИП(Справочник.СтатьиДоходовИРасходов)
			ТОГДА ЕСТЬNULL(ЗатратыОбороты.СуммаОборот, 0)
		ИНАЧЕ 0
	КОНЕЦ,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ЗатратыОбороты.СтатьяЗатрат) = ТИП(Справочник.НачисленияИУдержанияСотрудников)
				ИЛИ ТИПЗНАЧЕНИЯ(ЗатратыОбороты.СтатьяЗатрат) = ТИП(Справочник.ПрочиеНачисленияИУдержания)
			ТОГДА ЕСТЬNULL(ЗатратыОбороты.СуммаОборот, 0)
		ИНАЧЕ 0
	КОНЕЦ,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ЗатратыОбороты.СтатьяЗатрат) = ТИП(Справочник.НачисленияИУдержанияСотрудников)
			ТОГДА ВЫБОР
					КОГДА ЗатратыОбороты.СтатьяЗатрат.ТипНачисленияУдержания = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийУдержаний.Процент)
						ТОГДА 1
					ИНАЧЕ 2
				КОНЕЦ
		ИНАЧЕ 3
	КОНЕЦ,
	0,
	0,
	0,
	0,
	NULL,
	ЗатратыОбороты.ПериодСекунда,
	ЗатратыОбороты.ПериодМинута,
	ЗатратыОбороты.ПериодЧас,
	ЗатратыОбороты.ПериодДень,
	ЗатратыОбороты.ПериодНеделя,
