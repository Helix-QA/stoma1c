// Процедура, устанавливает блокировку.
//
Процедура УстановитьБлокировку(БлокируемыйДокумент, РеквизитБлокировки, ЗначениеРеквизита) Экспорт
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(БлокируемыйДокумент);
	ЭлементБлокировки.УстановитьЗначение(РеквизитБлокировки, ЗначениеРеквизита);
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	Блокировка.Заблокировать();
	
КонецПроцедуры

// Функция - Создать поступление денежных средств на лицевой счет
//
// Параметры:
//  СтруктурнаяЕдиница		 - 	 - 
//  Клиент					 - 	 - 
//  ТипОплаты				 - 	 - 
//  ЛицевойСчет				 - 	 - 
//  ЭквайринговыйТерминал	 - 	 - 
//  КассаОплаты				 - 	 - 
//  ИдТранзакции			 - 	 - 
//  СуммаДокумента			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьПоступлениеДенежныхСредствНаЛицевойСчет(ДанныеЗаполнения) Экспорт
	
	ПоступлениеНаСчет                             = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(ПоступлениеНаСчет, ДанныеЗаполнения);
	
	ПоступлениеНаСчет.Дата							= ТекущаяДатаСеанса();
	ПоступлениеНаСчет.ТипДенежныхСредств			= Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта;
	ПоступлениеНаСчет.ВидОперации					= Перечисления.ВидыОпераций.ВзносНаЛицевойСчет;
	ПоступлениеНаСчет.Статья						= Справочники.СтатьиДоходовИРасходов.ВзносНаЛицевойСчет;
	ПоступлениеНаСчет.ЛицевойСчетКонтрагента		= ДанныеЗаполнения.ВидЛицевогоСчета;
	ПоступлениеНаСчет.ДатаВходящегоДокумента		= ТекущаяДатаСеанса();
	ПоступлениеНаСчет.Комментарий					= "Оплата через внешнюю платежную систему";
	ПоступлениеНаСчет.АвторДокумента				= ПараметрыСеанса.ТекущийПользователь;

	Возврат ПоступлениеНаСчет;
	
КонецФункции

// Функция, создаёт поступление денежных средств.
//
Функция СоздатьПоступлениеДенежныхСредств(СтруктураПараметровЗаполнения, ТаблицаОснований = Неопределено) Экспорт
	
	//СтруктураПараметровЗаполнения = {Организация, СтруктурнаяЕдиница, Контрагент, Дата, ЭквайрингТерминал, Касса, НомерВходящегоДокумента, ДокументАванса, ТипРасчета, Основание,СуммаДокумента}
		
	ПоступлениеДС                         = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();		
	ЗаполнитьЗначенияСвойств(ПоступлениеДС, СтруктураПараметровЗаполнения);
	ПоступлениеДС.АвторДокумента          = ПараметрыСеанса.ТекущийПользователь;
	ПоступлениеДС.Сотрудник               = ПараметрыСеанса.ТекущийПользователь;
	ПоступлениеДС.ДатаВходящегоДокумента  = ПоступлениеДС.Дата;
	ПоступлениеДС.ТипДенежныхСредств      = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта;
	ПоступлениеДС.ВидОперации             = Перечисления.ВидыОпераций.ОплатаОтКлиента;
	ПоступлениеДС.Статья               	  = Справочники.СтатьиДоходовИРасходов.ОплатаОтКлиента;	
	ПоступлениеДС.Комментарий			  = "Оплата через внешнюю платежную систему";
	СуммаОплачено						  = СтруктураПараметровЗаполнения.СуммаДокумента;
	
	Если ТаблицаОснований = Неопределено Тогда
		
		НоваяСтрока 		       			  = ПоступлениеДС.РасшифровкаПлатежа.Добавить();
		НоваяСтрока.ДокументОснования 		  = ?(СтруктураПараметровЗаполнения.Свойство("Основание"), СтруктураПараметровЗаполнения.Основание, Неопределено);
		НоваяСтрока.ДокументАванса 			  = ?(СтруктураПараметровЗаполнения.Свойство("ДокументАванса"), СтруктураПараметровЗаполнения.ДокументАванса, Неопределено);
		НоваяСтрока.Статья      			  = Справочники.СтатьиДоходовИРасходов.ОплатаОтКлиента; 
		НоваяСтрока.Сумма          			  = СуммаОплачено;				
		
	Иначе	
		
		Для Каждого СтрокаОснования Из ТаблицаОснований Цикл
			
			СуммаНаДокументОснования = СтрокаОснования.СуммаЗаказа;	
			Сумма = ?(СуммаОплачено >= СуммаНаДокументОснования, СуммаНаДокументОснования, СуммаОплачено);   
			ЭтоАванс = ТипЗнч(СтрокаОснования.Основание) = Тип("ДокументСсылка.НарядЗаказ") ИЛИ ТипЗнч(СтрокаОснования.Основание) = Тип("ДокументСсылка.ПланЛечения");
			
			НоваяСтрока = ПоступлениеДС.РасшифровкаПлатежа.Добавить();
			
			Если ЭтоАванс Тогда
				НоваяСтрока.ДокументАванса = СтрокаОснования.Основание;
				НоваяСтрока.Статья      			  = Справочники.СтатьиДоходовИРасходов.ВзносАвансаОтКлиента;
			Иначе
				НоваяСтрока.ДокументОснования = СтрокаОснования.Основание;
				НоваяСтрока.Статья      			  = Справочники.СтатьиДоходовИРасходов.ОплатаОтКлиента;
			КонецЕсли;			
			
			
			НоваяСтрока.ЭтоАванс     			  = ЭтоАванс;
			НоваяСтрока.Сумма          			  = Сумма;
			
			СуммаОплачено = СуммаОплачено - Сумма;
			
		КонецЦикла;
			
	КонецЕсли;
	
    ПоступлениеДС.СуммаДокумента = ПоступлениеДС.РасшифровкаПлатежа.Итог("Сумма");
	
	Возврат ПоступлениеДС;
	
КонецФункции

