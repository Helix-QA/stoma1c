// Обработчик проведения оплаты по подготовленным данным на сервере
Функция ОперацияОплатыСервер(ОписаниеОшибки)
	
	УстановитьПривилегированныйРежим(Истина);
	
	МассивДокОплаты = Неопределено; 
	НомераЧековККМ  = Неопределено;
	НомерВходящегоДокумента = "";
	
	// ПОДГОТОВКА И ПРОВЕДЕНИЕ ДОКУМЕНТОВ ПОСТУПЛЕНИЯ ДС
	
	// Получить выбранные строки документа задолженности
	МассивОплачиваемыхСтрок = ПолучитьВыбранныеСтрокиДереваЗадолженностиСервер();
	
	МассивСтрокДереваОплата = ПолучитьСтрокиСВнесеннойОплатойСервер();
	МассивСтрокДереваОплата = ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(
	МассивСтрокДереваОплата,
	"Контрагент,КассаОплаты,ТипДенежныхСредств,НаименованиеВидаОплаты,
	 |ОплачиваемаяСумма,ВидЛицевогоСчета,Сертификат,СертификатПартия,ЭквайрингНомерПлатежнойКарты,
	 |ЭквайрингСсылочныйНомер,ЭквайрингКодАвторизации,НомерЧекаЭТ, ДокументАванса, СертификатСерийныйНомер, ЭквайрингВидПлатежнойКарты, БонусныйСчет");
	
	РасшифровкаОплатВозвр = Неопределено;
	// Вызов функции формирования документов оплаты
	ID_Транзакции = Новый УникальныйИдентификатор;
	МассивДокОплаты = Обработки.ПомощникПроведенияОплаты.СоздатьДокументыОплатыПоТаблицеВидовОплат(
		ЭтотОбъект.Контрагент,
		ЭтотОбъект.ВидОперации,
		ЭтотОбъект.ТекущаяКасса,
		МассивСтрокДереваОплата, 
		МассивОплачиваемыхСтрок,
		РасшифровкаОплатВозвр,
		ОписаниеОшибки,
		ID_Транзакции);
	
	ЭтотОбъект.РасшифровкаОплатыПоДокументам = Новый ФиксированныйМассив(РасшифровкаОплатВозвр);
	
	Счетчик = 0;
	// Проведение созданных документов
	Для Каждого ДокОплаты ИЗ МассивДокОплаты Цикл
		
		ДокОплаты.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		ДокОплаты.Записать(РежимЗаписиДокумента.Проведение);
		
		// Подмена значения в массиве на ссылку
		МассивДокОплаты[Счетчик] = ДокОплаты.Ссылка;
		Счетчик                  = Счетчик + 1;
		
	КонецЦикла;
		
	Возврат МассивДокОплаты;	
	
КонецФункции

