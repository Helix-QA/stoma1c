// Процедура, обновляет картинку подбора зубов
//
Процедура ОбновитьДокумент()
								
	мМассивСтатусовЗубов = "var status = '";
	Для Каждого СтокаТЧ Из СтатусыЗубов Цикл
		Если СтокаТЧ.СтатусЗуба <> "0" Тогда
			мМассивСтатусовЗубов = мМассивСтатусовЗубов + "Об" + СтокаТЧ.Зуб + "|"+СтокаТЧ.СтатусЗуба+"|";									
		КонецЕсли;
	КонецЦикла;		
	
	Если СтрДлина(мМассивСтатусовЗубов) > 15 Тогда
		мМассивСтатусовЗубов = Сред(мМассивСтатусовЗубов, 1, СтрДлина(мМассивСтатусовЗубов)-1);
	КонецЕсли;
	мМассивСтатусовЗубов = мМассивСтатусовЗубов + "';";
	
	мМассивОбластей = "var ColorStatus = '";
	Для Каждого СтрокаТЧ Из СостоянияЗубов Цикл
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Состояние) Тогда
			Продолжить;
		КонецЕсли;
		Если мМассивОбластей <> "var ColorStatus = '" Тогда
			мМассивОбластей = мМассивОбластей + "|Об"+Строка(СтрокаТЧ.Зуб)+СтрокаТЧ.Область + "|"+СтрокаТЧ.Цвет+"|"+СтрокаТЧ.СостояниеНаименование;				
		Иначе
			мМассивОбластей = мМассивОбластей + "Об"+Строка(СтрокаТЧ.Зуб)+СтрокаТЧ.Область + "|"+СтрокаТЧ.Цвет+"|"+СтрокаТЧ.СостояниеНаименование;
		КонецЕсли;
	КонецЦикла;
	
	мМассивОбластей        = мМассивОбластей + "'";
	ЗубнаяФормулаSVG       = СтрЗаменить(ЗубнаяФормулаSVG, SVGМассивОбластей, мМассивОбластей);
	SVGМассивОбластей      = мМассивОбластей;		
	ЗубнаяФормулаSVG       = СтрЗаменить(ЗубнаяФормулаSVG, SVGМассивСтатусовЗубов, мМассивСтатусовЗубов);
	SVGМассивСтатусовЗубов = мМассивСтатусовЗубов;		
	mSVG                   = СтрЗаменить(HTML, "SVGElement", ЗубнаяФормулаSVG + ЗубнаяФормулаSVGBody);		
	SVGЗубнаяФормула       = mSVG;			
	
	Элементы.HTML.Ширина = ?(ТипЗубнойФормулы = 1, 90, 130);

КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обновление подбора зубов
//
Процедура ОбновитьSVGПодбор()
	
	Если МассивВыделенныхЗубов.Количество() > 0 Тогда
		мЗуб = СтрЗаменить(Строка(МассивВыделенныхЗубов[0].Значение), "Зуб", "");
		Svg  = СтрЗаменить(Svg, SVGВыделенныйЗуб, "var selectzub = '"+мЗуб+"';");	
		SVGВыделенныйЗуб = "var selectzub = '"+мЗуб+"';";
	Иначе
	   	Svg  = СтрЗаменить(Svg, SVGВыделенныйЗуб, "var selectzub;");	
		SVGВыделенныйЗуб = "var selectzub;";
	КонецЕсли;
	
	Если МножественныйРежимВыделения Тогда
		Svg = СтрЗаменить(Svg, "var FlagSinglSelect = true;", "var FlagSinglSelect = false;");
	Иначе
		Svg = СтрЗаменить(Svg, "var FlagSinglSelect = false;", "var FlagSinglSelect = true;");
	КонецЕсли;
  
	мМассив = "mas='";
	Для Каждого строкаТЧ из Объект.Лечение Цикл
		Если Найти(мМассив, Строка(строкаТЧ.зуб)) = 0 И НЕ строкаТЧ.зуб = ВсяПолость Тогда
			мМассив = мМассив +СтрокаТЧ.Зуб +",";
		КонецЕсли;
	КонецЦикла;
	Если СтрДлина(мМассив) > 5 Тогда
		мМассив = Сред(мМассив, 1, СтрДлина(мМассив)-1);
	КонецЕсли;
	мМассив                  = мМассив + "';";
	Svg                      = СтрЗаменить(Svg, SVGМассивЛечащихсяЗубов, мМассив);	
	SVGМассивЛечащихсяЗубов = мМассив;
	
	мМассив = "var SelectedTeeth = [";
	Для Каждого строкаТЧ из МассивВыделенныхЗубов Цикл
		мМассив = мМассив + "'Цвет"+строкаТЧ.Значение+"',";		
	КонецЦикла;
	Если СтрДлина(мМассив) > 21 Тогда
		мМассив = Сред(мМассив, 1, СтрДлина(мМассив)-1);
	КонецЕсли;
	мМассив = мМассив + "];";
	Svg = СтрЗаменить(Svg, SVGМассивВыделенныхЗубов, мМассив);
	SVGМассивВыделенныхЗубов = мМассив;	
	
	Svg = СтрЗаменить(Svg, "135px", ВысотаSVGПодбора);

	УслугиПодборЗубов        = Svg;
 	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриНажатии"
//
Процедура HTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если Не ДанныеСобытия.Element.ownerSVGElement = Неопределено Тогда 
		Если Не ДанныеСобытия.Element.ownerSVGElement = null и ЗначениеЗаполнено(ДанныеСобытия.Element.ownerSVGElement.id) Тогда
			
			СтруктураОткрытия = Неопределено;
			ОбновитьSVG = Ложь;
			ОбработатьВыбор(ДанныеСобытия.Element.ownerSVGElement.id, СтруктураОткрытия, ОбновитьSVG);
			
			Если Не СтруктураОткрытия = Неопределено и ОткрыватьПодбор Тогда 
				ОписаниеОповещения = Новый ОписаниеОповещения("HTMLПриНажатииЗавершение", ЭтотОбъект, Новый Структура("СтруктураОткрытия", СтруктураОткрытия));
				ОткрытьФорму("Справочник.Номенклатура.Форма.ЗубнаяФормулаПодбор", СтруктураОткрытия,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Если ОбновитьSVG Тогда
			ОбновитьДокумент();
		КонецЕсли;	
	КонецЕсли;				
	
КонецПроцедуры

&НаКлиенте
// Процедура - HTMLПри нажатии завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура HTMLПриНажатииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ИдентификаторыНовыхСтрок = Новый Массив();
	СтруктураОткрытия = ДополнительныеПараметры.СтруктураОткрытия;
	
	Если Не Результат = Неопределено И Результат.Количество() > 0 Тогда
		Для Каждого СтрокаМассива Из Результат Цикл
			НоваяСтрока              = Объект.Лечение.Добавить();
			НоваяСтрока.КлючСтроки   = НоваяСтрока.ПолучитьИдентификатор();
			НоваяСтрока.Номенклатура = СтрокаМассива;																		
			НоваяСтрока.Зуб          = СтруктураОткрытия.Зуб; 
			Элементы.ТаблицаЛечение.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
			ИдентификаторыНовыхСтрок.Добавить(НоваяСтрока.ПолучитьИдентификатор());
			ТаблицаУслугиНоменклатураПриИзмененииСервер(ИдентификаторыНовыхСтрок, Истина, Неопределено);
		КонецЦикла;  
		
		ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
		ОбновитьSVGПодбор();
		Модифицированность = Истина;  								
	КонецЕсли;
	
	ОбновитьSVG = Истина;
	
	Если ОбновитьSVG Тогда
		ОбновитьДокумент();
	КонецЕсли;  

КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обработку выбора HTML
//
Процедура ОбработатьВыбор(Выбор, СтруктураОткрытия = Неопределено, ОбновитьSVG = Ложь)
	
	Зуб = Сред(Выбор, 1, 2); 	
	Если Зуб = "Об" Тогда		
		Зуб =  ПредопределенноеЗначение("Перечисление.Зубы."+СтрЗаменить(Сред(Выбор, 1, 4), "Об", "Зуб")+""); 
		Статус = Сред(Выбор, Найти(Выбор, "#")+1);
		Если СтрДлина(Статус) > 1 и Статус <> Выбор Тогда
			Область = ПредопределенноеЗначение("Перечисление.ОбластиЗубнойФормулы."+СокрЛП(СтрЗаменить(СтрЗаменить(Сред(Выбор, 5), "#"+Статус, ""), ".", ""))+"");			
			Если Статус = "null" Тогда
				СостояниеЗуба = Неопределено;
				НайденныеСтроки = СостоянияЗубов.НайтиСтроки(Новый Структура("Зуб, Область", Зуб, Область));
				Если НайденныеСтроки.Количество() > 0 Тогда	
					НайденныеСтроки[0].Состояние = Неопределено;
				КонецЕсли;	
				Модифицированность = Истина;
				Возврат;
			Иначе
				СостояниеЗуба = ВернутьСсылкуНаЗУб(Статус);
			КонецЕсли;
			
			НайденныеСтроки = СостоянияЗубов.НайтиСтроки(Новый Структура("Зуб, Область", Зуб, Область));
			масСтатусЗуба = СтатусыЗубов.НайтиСтроки(Новый Структура("Зуб", Зуб));			
			Если масСтатусЗуба.Количество() > 0 Тогда				
				мСтатус = масСтатусЗуба[0].СтатусЗуба;
			Иначе
				мСтатус = 0;
				НоваяСтрока = СтатусыЗубов.Добавить();
				НоваяСтрока.Зуб = Зуб;
				НоваяСтрока.СтатусЗуба = мСтатус;				
			КонецЕсли;			
			Если НайденныеСтроки.Количество() > 0 Тогда			
				НайденныеСтроки[0].Зуб       = Зуб;
				НайденныеСтроки[0].Состояние = СостояниеЗуба.Зуб;
				НайденныеСтроки[0].Область   = Область;
				НайденныеСтроки[0].Цвет      = СостояниеЗуба.Цвет;				
				НайденныеСтроки[0].СтатусЗуба = мСтатус;
			Иначе
				НоваяСтрока = СостоянияЗубов.Добавить();
				НоваяСтрока.Зуб = Зуб;
				НоваяСтрока.Состояние = СостояниеЗуба.Зуб;
				НоваяСтрока.Область   = Область;
				НоваяСтрока.Цвет      = СостояниеЗуба.Цвет;				
				НоваяСтрока.СтатусЗуба = мСтатус; 
			КонецЕсли;
			СтруктураОткрытия = ПолучитьСтруктуруОткрытия(Объект.Дата, СостояниеЗуба.Зуб, СтруктураОткрытия, Объект.ВидЦен, Зуб);
		ИначеЕсли Статус <> Выбор Тогда
			НайденныеСтроки = СтатусыЗубов.НайтиСтроки(Новый Структура("Зуб", Зуб));
			Если НайденныеСтроки.Количество() > 0 Тогда			
				НайденныеСтроки[0].Зуб = Зуб;
				НайденныеСтроки[0].СтатусЗуба = Статус; 	
			Иначе
				НоваяСтрока = СтатусыЗубов.Добавить();
				НоваяСтрока.Зуб = Зуб;
				НоваяСтрока.СтатусЗуба = Статус;
			КонецЕсли;
			
			ЗубнаяФормулаSVGBody = ФормированиеSVGКлиентСервер.СформироватьЗубнуюФормулу(СтатусыЗубов, ?(ТипЗубнойФормулы = 1, Истина, Ложь));			
			ОбновитьSVG = Истина;
		КонецЕсли;		
		
		Модифицированность = Истина;
	КонецЕсли;    	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает структуру открытия
//
Функция ПолучитьСтруктуруОткрытия(Дата, СостояниеЗуба, СтруктурнаяЕдиница, ВидЦен, Зуб)
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Номенклатура.СостояниеЗубнойФормулы
	|ИЗ
	|	Справочник.Номенклатура.ОбластиЗубнойФормулы КАК Номенклатура
	|ГДЕ
	|	Номенклатура.СостояниеЗубнойФормулы = &СостояниеЗубнойФормулы");
	Запрос.УстановитьПараметр("СостояниеЗубнойФормулы", СостояниеЗуба);
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда			
		СтруктураОткрытия = Новый Структура("Сегмент, СтруктурнаяЕдиница, ВидЦен, Дата, Зуб", 			
		СостояниеЗуба, СтруктурнаяЕдиница, ВидЦен, ?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДата()),  Зуб);
	КонецЕсли;

	Возврат СтруктураОткрытия;	
	
