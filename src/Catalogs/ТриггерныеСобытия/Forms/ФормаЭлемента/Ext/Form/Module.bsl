				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ВидПолучателя_Индекс_" + Строка(ИндексСтроки));
