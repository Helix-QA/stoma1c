// Функция - Определить подключаемое оборудование
// 
// Параметры:
//  ТипОборудования	 - 	 - 
//  Логин			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ОпределитьПодключаемоеОборудование(ТипОборудования, Логин = "") Экспорт
	
	Результат = Неопределено;
		
	// Получение подклчаемого оборудования
	ТаблицаПодключаемогоОборудованияТелефонии = ПолучитьСписокОборудованияIPТелефонии();
	Для Каждого СтрТаблицы ИЗ ТаблицаПодключаемогоОборудованияТелефонии Цикл
		
		Если СтрТаблицы.ОбработчикДрайвера <> ТипОборудования Тогда
			Продолжить
		КонецЕсли;
		
		Результат = СтрТаблицы.Ссылка;
		Прервать;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция - Получить параметры оборудования
