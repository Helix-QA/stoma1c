// Обработчик активации области журнала ПЗ
//
Процедура ТабличныйДокументПриАктивизацииОбласти(Элемент)
	
	Расшифровка = Элементы.ТабличныйДокумент.ТекущаяОбласть.Расшифровка;
	ПЗРасшифровкаТекущейОбласти = Неопределено;
	Если Не Расшифровка = Неопределено И ТипЗнч(Расшифровка) = Тип("Строка") И НЕ ВводПриемаЧерезКонтекстноеМеню Тогда				
		ПЗРасшифровкаТекущейОбласти = КонвертироватьРасшифровкуТабличногоДокумента(Расшифровка, ПолучитьСтраницуМенеджера(), ПЗФильтраГрафикаРежим);					
	КонецЕсли;
	Если ПЗГрафикаРежимОтображения = 0 И ПЗРасшифровкаТекущейОбласти <> Неопределено И ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) Тогда
		ВыбранныйСотрудник_РежимНеделя = ПЗРасшифровкаТекущейОбласти.Сотрудник;	
	КонецЕсли;	
	
	// Если не у становлен режим отображения только оменнеых ПЗ 
	ВводПриемаЧерезКонтекстноеМеню = Ложь;
	
КонецПроцедуры

&НаКлиенте
// Обработчик события ОбработкаРасшифровки элемента ТабличныйДокумент.
//
Процедура ТабличныйДокументОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СтруктураДанных      = ПЗРасшифровкаТекущейОбласти;
	Если ТипЗнч(Расшифровка) = Тип("Строка") Тогда		
		// СтруктураДанных = КонвертироватьРасшифровкуТабличногоДокумента(Расшифровка,ПолучитьСтраницуМенеджера());		
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("Дата") Тогда			
		Объект.Дата               = Расшифровка;		
		ПЗГрафикаРежимОтображения = 0;
		ОбновлениеСтраницыЖурналПредварительнойЗаписи(,Истина);			
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("СправочникСсылка.Сотрудники") Тогда 		
		ОткрытьФорму("Справочник.Должности.ФормаОбъекта", Новый Структура("Ключ",ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Расшифровка, "Должность")));	
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("СправочникСсылка.Помещения") Тогда 		
		ОткрытьФорму("Справочник.Помещения.ФормаОбъекта", Новый Структура("Ключ",Расшифровка));		
	КонецЕсли;	
	// Если удалось успешно конвертировать строку данных
	Если НЕ СтруктураДанных = Неопределено Тогда
		
		Если СтруктураДанных.Свойство("КоличествоВЛистеОжидания") И НЕ СтруктураДанных.КоличествоВЛистеОжидания = Неопределено
			И ЗначениеЗаполнено(СтруктураДанных.Сотрудник) Тогда
			
			Если ЗначениеЗаполнено(СтруктураДанных.КоличествоВЛистеОжидания) Тогда
				ОткрытьЛистОжиданияПациентов(СтруктураДанных.Сотрудник, СтруктураДанных.Дата);
			КонецЕсли;
			
			Возврат;
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтруктураДанных.Событие) Тогда
			
			СтандартнаяОбработка = Ложь;
			СоздатьСобытие(Неопределено);
			
		Иначе
			
			Прием = ПолучитьСсылкуНаПрием(СтруктураДанных.Событие);
			
			Если Не ЗначениеЗаполнено(Прием) Или ЭтоЖурналЗаписиПоРасширеннымНастройкам = Истина Тогда		
				СтандартнаяОбработка = Ложь;
				ОткрытьФорму("Документ.Событие.ФормаОбъекта", Новый Структура("Ключ, ИнтервалГрафика, ЭтоРабочееВремя, ИсточникЗаписи", СтруктураДанных.Событие, ЭтотОбъект.ИнтервалГрафика, Неопределено, ЭтотОбъект.ИсточникЗаписи));		
			Иначе
				СтандартнаяОбработка = Ложь;
				ОткрытьФорму("Документ.Прием.ФормаОбъекта", Новый Структура("Ключ, ИнтервалГрафика, ЭтоРабочееВремя, ИсточникЗаписи", Прием, ЭтотОбъект.ИнтервалГрафика, Неопределено, ЭтотОбъект.ИсточникЗаписи),, СтруктураДанных.Событие);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОбработкаДополнительнойРасшифровки"
//
Процедура ТабличныйДокументОбработкаДополнительнойРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)
	
	Если ПЗРасшифровкаТекущейОбласти = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	// Устанавливаем доступность всем в Ложь
	СтруктураСостояния = Новый Структура;
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюСоздатьСобытие"         			,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюОтменитьСобытие"        			,Ложь);
	// --------------------------------------------Статусы-------------------------------------------------
	// СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусЗапланировано" 	,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПациентОжидает" 	,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПациентВКресле" 	,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПриемНеСостоялся" 	,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПриемОкончен" 		,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПриемОтменен" 		,Ложь);
	// ----------------------------------------------------------------------------------------------------
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПодтверждена"		,Ложь); 
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусНеПодтверждена"	,Ложь); 
	// ----------------------------------------Ввод на основании-------------------------------------------
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюВвестиПосещение"        			,Ложь);		
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюВвестиПланЛечения"        			,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюВвестиНарядЗаказ"        			,Ложь);		
	// ----------------------------------------------------------------------------------------------------
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюКнопкаРезерв"         				,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюКнопкаОтменитьРезервВремени"   	,Ложь);
	// ----------------------------------------------------------------------------------------------------
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаВырезать"         			,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаКопировать"       			,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаВставить"        			,Ложь);
	// ----------------------------------------------------------------------------------------------------
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюЗаписатьИзОчереди"        			,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюИнформацияОПациенте"    			,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПозвонитьКлиенту"                  ,Ложь);
	СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюТалон"                 			,Ложь);
	
	СтруктураСостояния.Вставить("ТабличныйДокументПЗКонтекстноеМенюРабочееВремяРасширить", ЕстьПравоДоступаКГрафикуРаботы(ЭтоЖурналЗаписиПоРасширеннымНастройкам));
	СтруктураСостояния.Вставить("ТабличныйДокументПЗКонтекстноеМенюРабочееВремяУменьшить", ЕстьПравоДоступаКГрафикуРаботы(ЭтоЖурналЗаписиПоРасширеннымНастройкам));
	
	Если ПЗРасшифровкаТекущейОбласти.ЭтоПеренос = Истина Тогда
		Перейти ~УстановкаДоступности; 
	КонецЕсли;
	
	// В зависимости от расшифровки, устанавливаем видимость в Истину для определенных элементов меню
	СотрудникВыделеннойОбласти = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник), ПЗРасшифровкаТекущейОбласти.Сотрудник, ПЗФиьтрГрафикаТекущаяСтрока);
	ИскомыйСотрудник = СотрудникВыделеннойОбласти;

	Если ЭтоВрач И СотрудникВыделеннойОбласти <> Врач Тогда // когда врач редактирует график другого врача
		
		СтруктураСостояния.Вставить("ТабличныйДокументПЗКонтекстноеМенюРабочееВремяРасширить"  		,Ложь);
		СтруктураСостояния.Вставить("ТабличныйДокументПЗКонтекстноеМенюРабочееВремяУменьшить"		,Ложь);
		
		Если НЕ ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда
			СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюСоздатьСобытие", Истина);
		КонецЕсли;  	
  
		Если НЕ  ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда  
			СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаВставить", Истина);
		КонецЕсли;
		
		Если ЭтоГлавВрач Тогда
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюИнформацияОПациенте 	= Истина;	
		КонецЕсли;
				
	Иначе
		
		Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда // Для области занятой существующим ПЗ
			Если ПЗРасшифровкаТекущейОбласти.Резерв Тогда 
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюКнопкаОтменитьРезервВремени = Истина;							
			Иначе				
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюОтменитьСобытие = Истина;
				// ---------------------------------------------Статусы--------------------------------------------------
				СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПациентОжидает" 	, Истина);
				СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПациентВКресле" 	, Истина);
				СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПриемНеСостоялся" 	, Истина);
				СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПриемОкончен" 		, Истина);	
				// ----------------------------------------------------------------------------------------------------
				СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусПодтверждена"		, Истина); 
				СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюУстановитьСтатусНеПодтверждена"	, Истина); 
				// ----------------------------------------Ввод на основании---------------------------------------------  
				Если НачалоДня(ПЗРасшифровкаТекущейОбласти.Дата) = НачалоДня(ТекущаяДата()) Тогда
					СтруктураСостояния.ТабличныйДокументКонтекстноеМенюВвестиПосещение  = Не ЭтоЖурналЗаписиПоРасширеннымНастройкам; 
				КонецЕсли;
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюВвестиПланЛечения    = Не ЭтоЖурналЗаписиПоРасширеннымНастройкам;
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюВвестиНарядЗаказ     = Не ЭтоЖурналЗаписиПоРасширеннымНастройкам;
				// ------------------------------------------------------------------------------------------------------
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюИнформацияОПациенте 	= Истина;
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПозвонитьКлиенту     = ЭтотОбъект.ВключенаТелефония;
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюТалон                = Истина;
			КонецЕсли;		
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПравкаКопировать 		= Истина;	
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПравкаВырезать   		= Истина;
		Иначе	// Для свободной области	
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюКнопкаРезерв 			= Истина;
			// СтруктураСостояния.ТабличныйДокументКонтекстноеМенюЗаписатьИзОчереди 		= Истина;
			
			Сотрудник = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) И ТипЗнч(ПЗРасшифровкаТекущейОбласти.Сотрудник) = Тип("СправочникСсылка.Сотрудники")
						, ПЗРасшифровкаТекущейОбласти.Сотрудник
						, Неопределено);
						
			ВЛистеОжиданияЕстьПациенты = Ложь;
			Если ЗначениеЗаполнено(Сотрудник) Тогда
				ВЛистеОжиданияЕстьПациенты = НЕ ЭтотОбъект.СписокСотрудниковВЛистеОжидания.НайтиПоЗначению(Сотрудник) = Неопределено;
			КонецЕсли;
			
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюЗаписатьИзОчереди 		= ВЛистеОжиданияЕстьПациенты;
			
			Если (ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) 
				ИЛИ ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники")
				ИЛИ ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Помещения")) Тогда
				СтруктураСостояния.ТабличныйДокументКонтекстноеМенюСоздатьСобытие 		= Истина;
				Если БуферОбмена.Буфер <> Неопределено Тогда
					СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПравкаВставить 	= Истина;
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли;
		
	КонецЕсли;
	
	~УстановкаДоступности:
	
	// Установить доступность элементам	
	Для Каждого ЭлементС ИЗ СтруктураСостояния Цикл		
		Если НЕ Элементы[ЭлементС.Ключ].Доступность = ЭлементС.Значение Тогда
			Элементы[ЭлементС.Ключ].Доступность = ЭлементС.Значение;
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры

//////////////////////////// ОБРАБОТЧИКИ КОНТЕКСТНОГО МЕНЮ //////////////////////////////////

&НаКлиенте
// Процедура - команда создания нового события
//
Процедура СоздатьСобытие(Команда)
	
	Область = Элементы.ТабличныйДокумент.ТекущаяОбласть;	
	Если НЕ ПЗРасшифровкаТекущейОбласти = Неопределено И НЕ ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда
		
		Если ВыводитьОповещениеОНерабочемДнеКлиники(ПЗРасшифровкаТекущейОбласти.Дата, "НазначитьПрием") Тогда 
			Возврат;
		КонецЕсли;
		
		ЗаполняемыйКонтрагент = Неопределено;
		Если ЗначениеЗаполнено(ЭтотОбъект.КлиентДляОткрытия) Тогда
			ЗаполняемыйКонтрагент = ЭтотОбъект.КлиентДляОткрытия;
			
		ИначеЕсли ТипЗнч(Команда) = Тип("Структура") И Команда.Свойство("КлиентДляОткрытия")
					И ТипЗнч(Команда.КлиентДляОткрытия) = Тип("СправочникСсылка.Контрагенты") Тогда
					
				ЗаполняемыйКонтрагент = Команда.КлиентДляОткрытия;			
		КонецЕсли;
									
		ИнтервалВремени = ОпределнениеИнтервалаВремени(ИнтервалГрафика);
		Старт = ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ ИнтервалВремени)) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ИнтервалВремени)) * (60/ИнтервалВремени) * ИнтервалВремени * 60;
		ОснЗаполнение = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник), ПЗРасшифровкаТекущейОбласти.Сотрудник, ПЗФиьтрГрафикаТекущаяСтрока);
		Финиш = Старт + (Область.Низ - Область.Верх + 1) / (60/ ИнтервалВремени) * 60 * 60; //(Область.Низ - Область.Верх + 1) / (60/ИнтервалВремени)
		ЗначениеЗаполнения = Новый Структура();
		ЗначениеЗаполнения.Вставить("ДатаНачала"	 		, Старт);
		ЗначениеЗаполнения.Вставить("ДатаОкончания"	 		, Финиш);
		ЗначениеЗаполнения.Вставить("Контрагент"	 		, ЗаполняемыйКонтрагент);
		ЗначениеЗаполнения.Вставить("ИнтервалГрафика"		, ИнтервалГрафика);
		ЗначениеЗаполнения.Вставить("ИсточникЗаписи" 		, ЭтотОбъект.ИсточникЗаписи);
		ЗначениеЗаполнения.Вставить("СтруктурнаяЕдиница" 	, Объект.СтруктурнаяЕдиница);
		
		Если ЗначениеЗаполнено(ЭтотОбъект.Сделка) Тогда
			ЗначениеЗаполнения.Вставить("Сделка"		       			 , ЭтотОбъект.Сделка);
		КонецЕсли;  
		Если ЗначениеЗаполнено(ЭтотОбъект.Заявка) Тогда
			ЗначениеЗаполнения.Вставить("Заявка"		       			 , ЭтотОбъект.Заявка);
		КонецЕсли;
		ЗначениеЗаполнения.Вставить("ВнутреннийНомерСотрудника"		 , ВнутреннийНомерСотрудника);
		ЗначениеЗаполнения.Вставить("IDЗвонка"		 				 , IDЗвонка);

		Если ТипЗнч(ОснЗаполнение) = Тип("СправочникСсылка.Сотрудники") Тогда
			ЗначениеЗаполнения.Вставить("Сотрудник", ОснЗаполнение);
			
			Если ЗначениеЗаполнено(ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента)
				И ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента <> ОснЗаполнение Тогда
				
				ЗначениеЗаполнения.Контрагент = Неопределено;
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(ОснЗаполнение) = Тип("СправочникСсылка.Помещения") Тогда
			ЗначениеЗаполнения.Вставить("Помещение", ОснЗаполнение);			
		КонецЕсли;
		// Проверка на существование предварительной записи на это время.
		Если ТипЗнч(ОснЗаполнение) = Тип("СправочникСсылка.Сотрудники") ИЛИ ТипЗнч(ОснЗаполнение) = Тип("СправочникСсылка.Помещения") Тогда
			
			РабочееВремяСотрудника = ПроверитьРаботаетЛиСотрудникВпериодВремя(Старт, Финиш);
			Описаниеограничения = ""; 
			Сотрудник = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник), ПЗРасшифровкаТекущейОбласти.Сотрудник, ПЗФиьтрГрафикаТекущаяСтрока);
			ВозможностьЗаписи = ПроверитьВозможностьЗаписи(Старт,Финиш,Сотрудник,Объект.СтруктурнаяЕдиница,Описаниеограничения);
			Если ВозможностьЗаписи Тогда
				Если Не РабочееВремяСотрудника Тогда 
					
					Сотрудник = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник), ПЗРасшифровкаТекущейОбласти.Сотрудник, ПЗФиьтрГрафикаТекущаяСтрока);
					Если ЕстьПравоРедактированияГрафикаРаботСотрудника Тогда
						
						Если ЗначениеЗаполнения.Свойство("Сотрудник") Тогда					
							ДополнительныеПараметры = Новый Структура;
							ДополнительныеПараметры.Вставить("Старт"			 , Старт);
							ДополнительныеПараметры.Вставить("Финиш"			 , Финиш);
							ДополнительныеПараметры.Вставить("Сотрудник"		 , Сотрудник);
							ДополнительныеПараметры.Вставить("ЗначениеЗаполнения", ЗначениеЗаполнения);	
							Оповещение = Новый ОписаниеОповещения("СоздатьСобытиеВопросЗавершение", ЭтотОбъект, ДополнительныеПараметры);
							ПоказатьВопрос(Оповещение, "Выбранное время не является рабочим для сотрудника: " + Сотрудник + ". Отметить выбранный период рабочим и продолжить?", РежимДиалогаВопрос.ДаНет);									
						Иначе
							ЗначениеЗаполнения.Вставить("ЭтоРабочееВремя", Неопределено);
							ОткрытьФорму("Документ.Событие.ФормаОбъекта", ЗначениеЗаполнения);
						КонецЕсли;
					Иначе  
						ПоказатьПредупреждение( , "Выбранное время не является рабочим для сотрудника: " + Сотрудник + ".");
					КонецЕсли;
					
				Иначе
					ЗначениеЗаполнения.Вставить("ЭтоРабочееВремя", Неопределено);	
					ОткрытьФорму("Документ.Событие.ФормаОбъекта", ЗначениеЗаполнения);
					
				КонецЕсли;
			Иначе
				ПоказатьПредупреждение(, ОписаниеОграничения,,"Внимание!");
			КонецЕсли;
					
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Создать событие вопрос завершение.
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СоздатьСобытиеВопросЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		УстановитьРабочееВремя(ДополнительныеПараметры.Старт, ДополнительныеПараметры.Финиш, ДополнительныеПараметры.Сотрудник, Истина, Объект.СтруктурнаяЕдиница);
		ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь,Истина);
		ДополнительныеПараметры.ЗначениеЗаполнения.Вставить("ЭтоРабочееВремя", Ложь);	
		ОткрытьФорму("Документ.Событие.ФормаОбъекта", ДополнительныеПараметры.ЗначениеЗаполнения);
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Функция, проверить работает ли сотрудник впериод время.
//
Функция ПроверитьРаботаетЛиСотрудникВпериодВремя(ВремяНачала, ВремяОкончания)
	
	Сотрудник = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник), ПЗРасшифровкаТекущейОбласти.Сотрудник, ПЗФиьтрГрафикаТекущаяСтрока);  
	
	Возврат РегистрыСведений.ВремяРаботыСотрудниковПлан.ПроверитьРаботаетЛиСотрудникВпериодВремя(ВремяНачала, ВремяНачала, ВремяОкончания, Сотрудник, Объект.СтруктурнаяЕдиница);
	
КонецФункции 

&НаСервереБезКонтекста
// Функция, проверить возможность записи.
//
Функция ПроверитьВозможностьЗаписи(Старт, Финиш, Сотрудник, СтруктурнаяЕдиница, Описаниеограничения)
		
	Возврат РегистрыСведений.ВремяРаботыСотрудниковПлан.ПроверитьВозможностьЗаписиРабочегоВремени(Старт,Финиш,Сотрудник,СтруктурнаяЕдиница,Описаниеограничения);
	
КонецФункции

&НаКлиенте
// Процедура создание групповой записи копированием из существующей.
//
Процедура СоздатьСобытиеКопированием(СтруктураСобытия, Перенести = Ложь)
	
	ИнтервалВремени = ОпределнениеИнтервалаВремени(ИнтервалГрафика);
	
	ВставкаДатаНачала = ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ ИнтервалВремени)) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ИнтервалВремени)) * (60/ИнтервалВремени) * ИнтервалВремени * 60;	
	ВставкаСотрудник = ПЗРасшифровкаТекущейОбласти.Сотрудник;
		
	КопируемоеСобытие = ?(ТипЗнч(СтруктураСобытия) = Тип("Структура") И СтруктураСобытия.Свойство("Событие"), СтруктураСобытия.Событие, Неопределено);	
	ДанныеКопируемогоСобытия = ПолучитьДанныеСобытия(КопируемоеСобытие);
		
	ДлительностьСобытия = ?(ДанныеКопируемогоСобытия.Свойство("Длительность"), ДанныеКопируемогоСобытия.Длительность, 0);
	
	СтартДельта = ?(ДанныеКопируемогоСобытия.Свойство("ДатаЗапланированная"), ДанныеКопируемогоСобытия.ДатаЗапланированная, Дата(1,1,1));
	ВставкаДатаОкончания = ВставкаДатаНачала + ДлительностьСобытия * 60;	
	
	ИсключаемоеСобытие = ?(Перенести = Истина, КопируемоеСобытие, Неопределено);	
	ПериодЗанятСобытиями = ПроверитьНаличиеСобытийВВыбранномПериоде(ВставкаДатаНачала, ВставкаДатаОкончания, Объект.СтруктурнаяЕдиница, ВставкаСотрудник, Неопределено, ИсключаемоеСобытие);
	
	ДопПараметры = Новый Структура;		
	ДопПараметры.Вставить("КопируемоеСобытие",	КопируемоеСобытие);
	ДопПараметры.Вставить("Перенести",			Перенести);	
	ДопПараметры.Вставить("ДатаНачала",			ВставкаДатаНачала); 	
	ДопПараметры.Вставить("ДатаОкончания",		ВставкаДатаОкончания);
	ДопПараметры.Вставить("СтартДельта",		СтартДельта);
	ДопПараметры.Вставить("Сотрудник",			ВставкаСотрудник);
	ДопПараметры.Вставить("Длительность",		ДлительностьСобытия);
	
	УслугиНЕДоступныДляСотрудника = ПроверитьДоступностьУслугСотрудникомПоСобытию(ВставкаСотрудник, Объект.СтруктурнаяЕдиница, КопируемоеСобытие);
	
	Если УслугиНЕДоступныДляСотрудника.Количество() = 0 Тогда
		
		Если ПериодЗанятСобытиями = Истина Тогда
			
			ДопПараметры.Вставить("Событие", Неопределено);	
			ДопПараметры.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
			ДопПараметры.Вставить("ИнтервалЗаписи", ИнтервалГрафика);		
			ДопПараметры.Вставить("ЭтоКопирование", Истина);
			ДопПараметры.Вставить("КонфликтВставки", Истина);
			
			Оповещение = Новый ОписаниеОповещения("СоздатьСобытиеКопированиемЗавершение", ЭтотОбъект, ДопПараметры);
			
			ОткрытьФорму("Обработка.РабочийКалендарь.Форма.ФормаДиалогаПереносаПриемов", ДопПараметры,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		Иначе		
			СоздатьСобытиеКопированиемЗавершение("ПеренестиКакЕсть", ДопПараметры);				
		КонецЕсли;
		
	Иначе    
		
		ТекстОшибки = "Врач " + ВставкаСотрудник + ?(УслугиНЕДоступныДляСотрудника.Количество() = 1, " не оказывает услугу: ", " не оказывает услуги: ") + Символы.ПС;
		Для Каждого Элемент Из УслугиНЕДоступныДляСотрудника Цикл
			ТекстОшибки = ТекстОшибки + Элемент + Символы.ПС;	
		КонецЦикла;
		ТекстОшибки = ТекстОшибки + "Копирование записи невозможно.";
		ОчиститьБуферОбмена(ЭтотОбъект.БуферОбмена);
		ПоказатьПредупреждение(, ТекстОшибки);
		
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
// Процедура - Создать событие копированием завершение
//
Процедура СоздатьСобытиеКопированиемЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если НЕ ЗначениеЗаполнено(Результат) ИЛИ НЕ ЗначениеЗаполнено(ДополнительныеПараметры) Тогда
		Возврат;
	КонецЕсли;
	
	Команда = ?(ТипЗнч(Результат) = Тип("Строка"), Результат, ?(ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("Команда"), Результат.Команда, Неопределено));
	
	Если Команда = "ПеренестиКакЕсть" Тогда
		
		СохранитьСкопированноеИлиВырезанноеСобытие(ДополнительныеПараметры.КопируемоеСобытие, ДополнительныеПараметры.Перенести, ДополнительныеПараметры);		
		
	ИначеЕсли Команда = "СократитьВремяПриема" Тогда
		
		НоваДатаНачала = ?(Результат.Свойство("ДатаНачала"), Результат.ДатаНачала, ДополнительныеПараметры.ДатаНачала);
		НоваяДатаОкончания = ?(Результат.Свойство("ДатаОкончания"), Результат.ДатаОкончания, ДополнительныеПараметры.ДатаОкончания);
		ДлительностьДельта = (НоваяДатаОкончания - НоваДатаНачала) / 60;
		
		ДополнительныеПараметры.ДатаНачала = НоваДатаНачала;
		ДополнительныеПараметры.ДатаОкончания = НоваяДатаОкончания;
		ДополнительныеПараметры.Вставить("Длительность", ДлительностьДельта);
		
		СохранитьСкопированноеИлиВырезанноеСобытие(ДополнительныеПараметры.КопируемоеСобытие, ДополнительныеПараметры.Перенести, ДополнительныеПараметры);
		
	КонецЕсли;	
	
	ОчиститьБуферОбмена(ЭтотОбъект.БуферОбмена);
	
	Если ДополнительныеПараметры.Свойство("КонфликтВставки") Тогда
		ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);
	КонецЕсли;
		
КонецПроцедуры   

&НаСервереБезКонтекста
// Функция - Проверить доступные услуги сотрудника.
//
Функция ПроверитьДоступностьУслугСотрудникомПоСобытию(Сотрудник, СтруктурнаяЕдиница, Событие)
	
	МассивНедоступныхУслуг = Новый Массив;
	
	Для Каждого Элемент Из Событие.Услуги Цикл
		ДоступнаяУслуга = РегистрыСведений.УслугиСотрудника.УслугаДоступнаДляСотрудника(Элемент.Номенклатура, Сотрудник, СтруктурнаяЕдиница);
		Если НЕ ДоступнаяУслуга И ЗначениеЗаполнено(Элемент.Номенклатура) Тогда
			МассивНедоступныхУслуг.Добавить(Элемент.Номенклатура.Наименование);	
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивНедоступныхУслуг;
	
КонецФункции

