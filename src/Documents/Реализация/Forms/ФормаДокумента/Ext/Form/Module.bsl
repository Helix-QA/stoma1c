// Процедура, выполняет пересчет автоматических скидок в документе.
//
Процедура ПересчитатьАвтоматическиеСкидки()

	// получаем новые 
	ТаблицаИспользуемыхСкидокНаценок = Объект.СкидкиНаценки.Выгрузить(Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("Использование", Истина)));

	ТаблицаОплатаБонусами = УправлениеМаркетинговымиАкциями.ЗапросПоОплатеБонусами(
								Объект,
								Объект.Запасы.Выгрузить(), 
								Неопределено,
								Объект.Услуги.Выгрузить(),
								ТаблицаИспользуемыхСкидокНаценок);
								
	ТаблицаОплатаБонусами.Свернуть("БонусныйСчет, СуммаОстаток", "МаксимальнаяСуммаОплаты, СуммаДляРасчетаБонусов");
	
	СкидкаНаценкаОплатаБонусамиВременная = СкидкаНаценкаОплатаБонусами.Выгрузить();
	ЗаполнитьТаблицуСкидокНаценокОплатБонусами(ТаблицаОплатаБонусами, СкидкаНаценкаОплатаБонусамиВременная);
	
	// обнуляем если изменился состав табличной части "Запасы", "Скидки"
	ИспользуемаяВалюта		= ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
	СуммаДляРасчетаБонусов	= ?(СкидкаНаценкаОплатаБонусамиВременная.Количество() > 0,
									СкидкаНаценкаОплатаБонусамиВременная[0].СуммаДляРасчетаБонусов, 0);
	ВидЦенВременный			= ?(ЗначениеЗаполнено(Объект.ВидЦен), Объект.ВидЦен, Справочники.ВидыЦен.Розничная);
	ПараметрыОкругления		= Новый Структура("ОкруглятьВБольшуюСторону, ПорядокОкругления", 
									ВидЦенВременный.ОкруглятьВБольшуюСторону, ВидЦенВременный.ПорядокОкругления);
	
	Для Каждого СтрокаТЗ Из СкидкаНаценкаОплатаБонусами Цикл
		МассивВременный = СкидкаНаценкаОплатаБонусамиВременная.НайтиСтроки(Новый Структура("БонусныйСчет", СтрокаТЗ.БонусныйСчет));
		Если МассивВременный.Количество() > 0 и СтрокаТЗ.МаксимальнаяСуммаОплаты > МассивВременный[0].МаксимальнаяСуммаОплаты Тогда
			СуммаНовая = ?(СуммаДляРасчетаБонусов > 0, МассивВременный[0].МаксимальнаяСуммаОплаты, 0);
			Если СтрокаТЗ.Сумма > СуммаНовая Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Сумма оплаты бонусным счетом ""%1"" уменьшена с %2 %3 до %4 %3';en='Amount payment bonus account ""%1"" decreased from %2 %3 to %4 %3'"), СтрокаТЗ.БонусныйСчет, СтрокаТЗ.Сумма, ИспользуемаяВалюта, СуммаНовая));
				СтрокаТЗ.Сумма = СуммаНовая;  
			КонецЕсли;              			
			СуммаДляРасчетаБонусов = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(СуммаДляРасчетаБонусов, ПараметрыОкругления.ПорядокОкругления, ПараметрыОкругления.ОкруглятьВБольшуюСторону)
										- ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(МассивВременный[0].МаксимальнаяСуммаОплаты, ПараметрыОкругления.ПорядокОкругления, ПараметрыОкругления.ОкруглятьВБольшуюСторону);
		ИначеЕсли МассивВременный.Количество() = 0 Тогда
			Если СтрокаТЗ.Сумма <> 0 и Объект.Запасы.Количество() > 0 Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Сумма оплаты бонусным счетом ""%1"" уменьшена с %2 %3 до 0 %3';en='Amount payment bonus account ""%1"" reduced from %2 %3 to 0 %3'"), СтрокаТЗ.БонусныйСчет, СтрокаТЗ.Сумма, ИспользуемаяВалюта));			
			КонецЕсли;
			СтрокаТЗ.Сумма = 0;	
		КонецЕсли;
	КонецЦикла;                	
	
	мСуммаДокументаБезСкидок = Ценообразование.ПолучитьСуммуДокументаБезСкидки(Объект.Запасы)
								+ Ценообразование.ПолучитьСуммуДокументаБезСкидки(Объект.Услуги);

	// Сохраняем список временых реквизитов - Запасы
	ВременноХранениеВиртуальныхРкЗапасов = Объект.Запасы.Выгрузить(,"
	|КлючСтроки,
	|НомерСтроки, 
	|ХарактеристикиИспользуются, 
	|СкидкиЗапрещены,
	|ТипНоменклатуры, 
	|ЭтоСертификат, 
	|Бесплатно,
	|ВидНалога");
	
	// Сохраняем список временых реквизитов - Услуги
	ВременноХранениеВиртуальныхРкУслуг = Объект.Услуги.Выгрузить(,"
	|КлючСтроки,
	|НомерСтроки, 
	|ХарактеристикиИспользуются, 
	|СкидкиЗапрещены,
	|ЭтоСертификат");
	
	// Сохраняем список отключенных скидок
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки = Новый ТаблицаЗначений;
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("КлючСтроки"	, Новый ОписаниеТипов("УникальныйИдентификатор"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("Использование", Новый ОписаниеТипов("Булево"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("СкидкаНаценка", Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("Номенклатура"	, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	Для Каждого СтрокаТЗ Из Объект.СкидкиНаценки Цикл
		НоваяСтрока = ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		НоваяСтрока.Номенклатура = СтрокаТЗ.НоменклатураСкидки;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из Объект.Подарки Цикл
		НоваяСтрока = ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
	КонецЦикла;

	// Пересчитываем скидки
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДатаСкидок", ?(Объект.Ссылка.Пустая() = Истина, ТекущаяДатаСеанса(), Объект.Дата));
	СтруктураПараметров.Вставить("Получатель", Объект.Контрагент);
	СтруктураПараметров.Вставить("Карта"	 , Объект.КартаКонтрагента);

	ЗначениеОбъект = РеквизитФормыВЗначение("Объект");
	УправлениеМаркетинговымиАкциями.РассчитатьСкидкиПриПродаже(
		ЗначениеОбъект,
		"Запасы",
		Неопределено,
		"Услуги",
		"СкидкиНаценки",
		"Подарки",
		ЭтотОбъект.СкидкаНаценкаОплатаБонусами,
		ВременноХранениеПредыдщееСостояниеСкидкиПодарки,
		СтруктураПараметров);
		
	ЗначениеВРеквизитФормы(ЗначениеОбъект, "Объект");
	
	// Восстановить значение вируальных реквизитов - ЗАПАСЫ
	Для А = 0 По ВременноХранениеВиртуальныхРкЗапасов.Количество() - 1 Цикл
		ЗаполнитьЗначенияСвойств(Объект.Запасы[А], ВременноХранениеВиртуальныхРкЗапасов[А]);
	КонецЦикла;
	
	// Восстановить значение вируальных реквизитов - УСЛУГИ
	Для А = 0 По ВременноХранениеВиртуальныхРкУслуг.Количество() - 1 Цикл
		ЗаполнитьЗначенияСвойств(Объект.Услуги[А], ВременноХранениеВиртуальныхРкУслуг[А]);
	КонецЦикла;

	// Проставляем виртуальное поле тип скидки
	ПроставитьТипСкидкиНаценки();
	
	// заполняем вирутальные реквизиты тч "Подарки"
	ЗаполнитьВирутальныеРеквизитыПодарков();
	
	// Актуализируем таблицу на форме с выводом оплат бонусами
	ЗаполнитьТЧДоступныеОплатыБонусами();

	// Пересчитываем суммы
	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл
		СтруктураПараметров = Новый Структура("ПорядокОкругления, ОкруглятьВБольшуюСторону", СтрокаТЧ.ВидЦен.ПорядокОкругления, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);		
		// Пересчитываем сумму строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
		// Пересчитываем сумму НДС строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
		// Пересчитываем всего строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
	КонецЦикла;		
	
	Для Каждого СтрокаТЧ Из Объект.Услуги Цикл
		СтруктураПараметров = Новый Структура("ПорядокОкругления, ОкруглятьВБольшуюСторону", СтрокаТЧ.ВидЦен.ПорядокОкругления, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);		
		// Пересчитываем сумму строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
		// Пересчитываем сумму НДС строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
		// Пересчитываем всего строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
	КонецЦикла;		
	
	Объект.СуммаДокумента = Объект.Запасы.Итог("Сумма")	 	+ Объект.Услуги.Итог("Сумма"); 
	СуммаДокумента 		  = Объект.СуммаДокумента;
	СуммаНДС			  = Объект.Запасы.Итог("СуммаНДС")  + Объект.Услуги.Итог("СуммаНДС");
	
	УстановитьВидимостьЭлементов();     	
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет именными пакетами услуг
//
Процедура ПроставитьТипСкидкиНаценки()
	
	Для Каждого СтрокаТЗ Из Объект.СкидкиНаценки Цикл
		
		СтрокаТЗ.ПризнакИспользованиеНаУсмотрение = СтрокаТЗ.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение;
		СтрокаТЗ.Тип = "Скидка";
		
		Если ЗначениеЗаполнено(СтрокаТЗ.СкидкаНаценка)
			И СтрокаТЗ.СкидкаНаценка.НачислениеБонусами = Истина Тогда
			
			СтрокаТЗ.Тип = "Бонус";
		ИначеЕсли СтрокаТЗ.ПризнакОплатыБонусом = Истина Тогда
			СтрокаТЗ.Тип = "Оплата";			
		КонецЕсли;
		
		Если СтрокаТЗ.Тип = "Скидка" Тогда
			
			// запасы.
			ОграничениеПроцент = 0;
			МассивСтрок = Объект.Запасы.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТЗ.КлючСтроки));
			Если НЕ МассивСтрок.Количество() = 0 Тогда
				
				СуммаБезСкидки = МассивСтрок[0].КоличествоУпаковок * МассивСтрок[0].Цена;
				Если СуммаБезСкидки <> 0
					И СтрокаТЗ.СкидкаНаценка.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
					ПолнаяСкидка = СтрокаТЗ.СкидкаНаценка.ЗначениеСкидкиНаценки * СуммаБезСкидки / 100;
					Если ПолнаяСкидка > СтрокаТЗ.Сумма Тогда 
						ОграничениеПроцент = (ПолнаяСкидка - СтрокаТЗ.Сумма) / (СуммаБезСкидки / 100);
						ОграничениеПроцент = ?(ОграничениеПроцент < 1, 0, ОграничениеПроцент);
					КонецЕсли;
				КонецЕсли;
				
				Если ОграничениеПроцент = 0 Тогда 
					СтрокаТЗ.ГрупповоеОграничение = "";
				Иначе				
					СтрокаТЗ.ГрупповоеОграничение = "Групповое ограничение скидки: -" + Строка(Окр(ОграничениеПроцент, 2, РежимОкругления.Окр15как20)) + "%";
				КонецЕсли;
				
			Иначе
				// Услуги.
				ОграничениеПроцент = 0;
				МассивСтрок = Объект.Услуги.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТЗ.КлючСтроки));
				Если НЕ МассивСтрок.Количество() = 0 Тогда
					
					СуммаБезСкидки = МассивСтрок[0].КоличествоУпаковок * МассивСтрок[0].Цена;
					Если СуммаБезСкидки <> 0
						И СтрокаТЗ.СкидкаНаценка.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
						ПолнаяСкидка = СтрокаТЗ.СкидкаНаценка.ЗначениеСкидкиНаценки * СуммаБезСкидки / 100;
						Если ПолнаяСкидка > СтрокаТЗ.Сумма Тогда 
							ОграничениеПроцент = (ПолнаяСкидка - СтрокаТЗ.Сумма) / (СуммаБезСкидки / 100);
							ОграничениеПроцент = ?(ОграничениеПроцент < 1, 0, ОграничениеПроцент);
						КонецЕсли;
					КонецЕсли;
					
				КонецЕсли;
				
				Если ОграничениеПроцент = 0 Тогда 
					СтрокаТЗ.ГрупповоеОграничение = "";
				Иначе				
					СтрокаТЗ.ГрупповоеОграничение = "Групповое ограничение скидки: -" + Строка(Окр(ОграничениеПроцент, 2, РежимОкругления.Окр15как20)) + "%";
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из Объект.Подарки Цикл
		СтрокаТЗ.ПризнакИспользованиеНаУсмотрение = СтрокаТЗ.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет виртуальные реквизиты табличной части "Подарки"
//
Процедура ЗаполнитьВирутальныеРеквизитыПодарков()
	
	Для Каждого СтрокаПодарки Из Объект.Подарки Цикл
		СтруктураПараметровНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаПодарки.Номенклатура, "ТипНоменклатуры, ИспользоватьПартии");
		ЗаполнитьЗначенияСвойств(СтрокаПодарки, СтруктураПараметровНоменклатуры);	
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписью".
//
Процедура ЗаполнитьТЧДоступныеОплатыБонусами()
	
	ТаблицаИспользуемыхСкидокНаценок = Объект.СкидкиНаценки.Выгрузить(Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("Использование", Истина)));
	
	ТаблицаОплатаБонусами = УправлениеМаркетинговымиАкциями.ЗапросПоОплатеБонусами(
								Объект, 
								Объект.Запасы.Выгрузить(), 
								Объект.Услуги.Выгрузить(),
								Неопределено, 
								ТаблицаИспользуемыхСкидокНаценок);
								
	ТаблицаОплатаБонусами.Свернуть("БонусныйСчет, СуммаОстаток", "МаксимальнаяСуммаОплаты, СуммаДляРасчетаБонусов");
	
	ЗаполнитьТаблицуСкидокНаценокОплатБонусами(ТаблицаОплатаБонусами, СкидкаНаценкаОплатаБонусами);
	
	// Проставляем сумму списания уже существущих оплат или добавляем для отображения
	Для Каждого СтрокаТЧ Из Объект.СкидкиНаценки Цикл
		Если СтрокаТЧ.ПризнакОплатыБонусом = Истина Тогда
			МассивНайденныеСтрока = СкидкаНаценкаОплатаБонусами.НайтиСтроки(Новый Структура("БонусныйСчет", СтрокаТЧ.БонусныйСчет));
			Если МассивНайденныеСтрока.Количество() > 0 Тогда
				МассивНайденныеСтрока[0].Сумма	= МассивНайденныеСтрока[0].Сумма + СтрокаТЧ.Сумма;
			Иначе
				НайденнаяСтрока = СкидкаНаценкаОплатаБонусами.Добавить();
				НайденнаяСтрока.БонусныйСчет	= НайденнаяСтрока.БонусныйСчет;
				НайденнаяСтрока.Сумма			= НайденнаяСтрока.Сумма + СтрокаТЧ.Сумма;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет переданную таблицу значений данными из ТаблицыОплатБонусами.
//
Процедура ЗаполнитьТаблицуСкидокНаценокОплатБонусами(ТаблицаОплатаБонусами, ТаблицаСкидокНаценокОплатБонусами)
	
	// Заполняем таблицу остатками по бонусным счетам
	ТаблицаСкидокНаценокОплатБонусами.Очистить();
	Для Каждого СтрокаТЗ Из ТаблицаОплатаБонусами Цикл
		
		ПараметрыБонусногоСчета = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаТЗ.БонусныйСчет, "СрокДействияНачало, СрокДействияКонец");
		
		Если (ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияНачало) 
			И ПараметрыБонусногоСчета.СрокДействияНачало <= ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса())
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияНачало))
			И (ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияКонец)
			И КонецДня(ПараметрыБонусногоСчета.СрокДействияКонец) >= ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса())
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияКонец)) Тогда
			
			НоваяСтрока = ТаблицаСкидокНаценокОплатБонусами.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
			НоваяСтрока.МаксимальнаяСуммаОплаты = ?(НоваяСтрока.СуммаОстаток < НоваяСтрока.МаксимальнаяСуммаОплаты,
													НоваяСтрока.СуммаОстаток, 
													НоваяСтрока.МаксимальнаяСуммаОплаты);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет установку видимости элементов.
//
Процедура УстановитьВидимостьЭлементов()
	
	ОбщегоНазначенияСтоматология.УстановитьОтображениеЗакладокСкидкиНаценкиПодарки(ЭтаФорма);
	
	Если Объект.СкидкиНаценки.Количество() > 0 Тогда
		
		Элементы.СкидкиНаценкиСкидки.ОтборСтрок = Новый ФиксированнаяСтруктура("Тип", "Скидка");
		Элементы.СкидкиНаценкиБонусы.ОтборСтрок = Новый ФиксированнаяСтруктура("Тип", "Бонус");
		
		Элементы.СкидкиНаценкиСкидки.ВысотаВСтрокахТаблицы = Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("Тип", "Скидка")).Количество();
