// Процедура - Перезаполнить фото и наименования клиентов в фоне
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  UrlApi			 - 	 - 
//  ApiToken		 - 	 - 
//  ChannelId		 - 	 - 
//
Процедура ЗаполнитьИсториюСообщенийВФоне(ВнешняяСистема, UrlApi, ApiToken, ChannelId) Экспорт
	
	ПараметрыДанных = Новый Структура("ВнешняяСистема, UrlApi, ApiToken, ChannelId", ВнешняяСистема, UrlApi, ApiToken, ChannelId);
	
	УИДФоновогоЗадания = Новый УникальныйИдентификатор;
	мПараметры = Новый Массив;
	мПараметры.Добавить(УИДФоновогоЗадания);
	мПараметры.Добавить(ПараметрыДанных);
	
	ФоновыеЗадания.Выполнить("МессенджерСтоматология.ЗаполнитьИсториюСообщенийФоновое", мПараметры, УИДФоновогоЗадания, "Заполнить историю сообщений для мессенджера");
	
КонецПроцедуры

// Процедура - Перезаполнить фото и наименования клиентов фоновое
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
//
Процедура ЗаполнитьИсториюСообщенийФоновое(УИДФоновогоЗадания, СтруктураПараметров) Экспорт
	
	ВнешняяСистема	 = СтруктураПараметров.ВнешняяСистема;
	UrlApi			 = СтруктураПараметров.UrlApi;
	ApiToken		 = СтруктураПараметров.ApiToken;
	ChannelId		 = СтруктураПараметров.ChannelId;
	
	ТипВнешнейСистемы = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВнешняяСистема, "ТипВнешнейСистемы");
	
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		ЗаполнитьИсториюСообщенийGreenApi(ВнешняяСистема, UrlApi, ApiToken, ChannelId);
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.VkontakteApi Тогда
		ЗаполнитьИсториюСообщенийVK(ВнешняяСистема, UrlApi, ApiToken, ChannelId);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, заполняет историю сообщений VK.
//
Процедура ЗаполнитьИсториюСообщенийVK(ВнешняяСистема, Сервер, ТокенДоступа, ИдСообщества)
	
	МассивДанныхКонтактов = Новый Массив;
	МассивДанныхСообщений = Новый Массив;
	
	РазмерПорции = 15;
	
	HTTPСоединение = Новый HTTPСоединение(Сервер,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	КодДляИсполнения = 
	"var conversations = API.messages.getConversations({""group_id"":"+ИдСообщества+",""count"":"+РазмерПорции+"});
	|var user_ids = conversations.items@.conversation@.peer@.id;
	|var dialogs = [];
	|var i = 0;
	|while (i < conversations.items.length) {
	|	dialogs.push(API.messages.getHistory({""count"":50,""group_id"":"+ИдСообщества+",""user_id"":user_ids[i]}));
	|	i = i %2b 1;
	|}
	|return {""dialogs"":dialogs,""conversations"":conversations,""user_data"":API.users.get({""user_ids"":user_ids,""fields"":""photo_200""})};";
	
	HTTPЗапрос = Новый HTTPЗапрос("/method/execute?code="+КодДляИсполнения+"&access_token="+ТокенДоступа+"&v=5.124");
	
	СтруктураОтвета = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
	
	Если СтруктураОтвета.Свойство("error") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось заполнить контакты мессенджера в фоне.");
		Возврат;
	КонецЕсли;
	
	МассивДанныхСообщений.Добавить(СтруктураОтвета.response.dialogs);
	МассивДанныхКонтактов.Добавить(СтруктураОтвета.response.user_data);
	
	КоличествоБесед = СтруктураОтвета.response.conversations.count;
	
	Счетчик = РазмерПорции;
	СчетчикОшибок = 0;
	
	Попытка
	
		Пока Счетчик < КоличествоБесед Цикл
			
			КодДляИсполнения = 
			"var conversations = API.messages.getConversations({""group_id"":"+ИдСообщества+",""count"":"+РазмерПорции+",""offset"":"+Счетчик+"});
			|var user_ids = conversations.items@.conversation@.peer@.id;
			|var dialogs = [];
			|var i = 0;
			|while (i < conversations.items.length) {
			|	dialogs.push(API.messages.getHistory({""count"":20,""group_id"":"+ИдСообщества+",""user_id"":user_ids[i]}));
			|	i = i %2b 1;
			|}
			|return {""dialogs"":dialogs,""conversations"":conversations,""user_data"":API.users.get({""user_ids"":user_ids,""fields"":""photo_200""})};";
			
			HTTPЗапрос = Новый HTTPЗапрос("/method/execute?code="+КодДляИсполнения+"&access_token="+ТокенДоступа+"&v=5.124");
			
			СтруктураОтвета = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
			
			Если СтруктураОтвета.Свойство("error") Тогда
				СчетчикОшибок = СчетчикОшибок + 1;
				Если СчетчикОшибок > 5 Тогда
					Прервать;
				Иначе
					Продолжить;
				КонецЕсли;	
			КонецЕсли;	
			
			МассивДанныхСообщений.Добавить(СтруктураОтвета.response.dialogs);
			МассивДанныхКонтактов.Добавить(СтруктураОтвета.response.user_data);
			
			Счетчик = Счетчик + РазмерПорции;
			
		КонецЦикла;
	
	Исключение
	КонецПопытки;	
	
	ПоправкаВремени = ТекущаяДатаСеанса() - ТекущаяДата();
	
	Контакты = РегистрыСведений.КонтактыМессенджеров.СоздатьНаборЗаписей();
	Контакты.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
	
	Для Каждого Порция Из МассивДанныхКонтактов Цикл
		Для Каждого ДанныеПользователя Из Порция Цикл
			
			НоваяЗапись = Контакты.Добавить();
			
			НоваяЗапись.Идентификатор		 = Формат(ДанныеПользователя.id, "ЧГ=");
			НоваяЗапись.ВнешняяСистема		 = ВнешняяСистема;			
			НоваяЗапись.НаименованиеКлиента	 = ДанныеПользователя.first_name + " " + ДанныеПользователя.last_name;
			НоваяЗапись.ФотоКлиента			 = ДанныеПользователя.photo_200;
			
			ДиалогКонтакта = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
			ДиалогКонтакта.ИдДиалога		 = Строка(Новый УникальныйИдентификатор);
			ДиалогКонтакта.ИдКлиента		 = Формат(ДанныеПользователя.id, "ЧГ=");
			ДиалогКонтакта.ВнешняяСистема	 = ВнешняяСистема;
			ДиалогКонтакта.Начало			 = Дата(2022, 1, 1);
			ДиалогКонтакта.Окончание		 = Дата(2022, 1, 1);
			
			ДиалогКонтакта.Записать();
			
		КонецЦикла;
	КонецЦикла;	
	
	Попытка
		Контакты.Записать();
	Исключение
	КонецПопытки;
		
	Сообщения = РегистрыСведений.ЖурналСообщений.СоздатьНаборЗаписей();
	Сообщения.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
	
	Для Каждого Порция Из МассивДанныхСообщений Цикл
		Для Каждого ДанныеСообщений Из Порция Цикл
			Для Каждого ДанныеСообщения Из ДанныеСообщений.items Цикл
				
				НоваяЗапись = Сообщения.Добавить();
				
				НоваяЗапись.ИдКлиента			 = Формат(ДанныеСообщения.peer_id, "ЧГ=");
				НоваяЗапись.ИдСообщения			 = Формат(ДанныеСообщения.id, "ЧГ=");
				НоваяЗапись.ИдКанала			 = ИдСообщества;
				НоваяЗапись.ТекстСообщения		 = ДанныеСообщения.text;
				НоваяЗапись.Прочитано			 = Истина;
				НоваяЗапись.Мессенджер			 = Перечисления.Мессенджеры.vk;
				НоваяЗапись.СообщениеОтКлиента	 = Не Булево(ДанныеСообщения.out);
				НоваяЗапись.Период				 = Дата(1970,1,1) + ПоправкаВремени + ДанныеСообщения.date;
				НоваяЗапись.ДатаСообщения		 = Дата(1970,1,1) + ПоправкаВремени + ДанныеСообщения.date;
				НоваяЗапись.ВнешняяСистема		 = ВнешняяСистема;
				
				Если ДанныеСообщения.attachments.Количество() > 0 Тогда
					
					НоваяЗапись.Изображение	 = ?(ДанныеСообщения.attachments[0].type = "sticker", ДанныеСообщения.attachments[0].sticker.images[ДанныеСообщения.attachments[0].sticker.images.ВГраница()].url, Неопределено);
					НоваяЗапись.Аудио		 = ?(ДанныеСообщения.attachments[0].type = "audio_message", ДанныеСообщения.attachments[0].audio_message.link_mp3, Неопределено);
					
					Если Не ЗначениеЗаполнено(НоваяЗапись.Изображение) И Не ЗначениеЗаполнено(НоваяЗапись.Аудио) Тогда
						
						МассивВложений = Новый Массив;
						Для Каждого Вложение Из ДанныеСообщения.attachments Цикл
							
							ДанныеВложения = Вложение[Вложение.type];
							Если Вложение.type <> "video" Тогда
								МассивВложений.Добавить(?(Вложение.type = "photo", ДанныеВложения.sizes[ДанныеВложения.sizes.ВГраница()].url, ДанныеВложения.url));
							КонецЕсли;
							
						КонецЦикла;
						
						НоваяЗапись.PDF = СтрСоединить(МассивВложений, "|");
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;	
	
	Попытка
		Сообщения.Записать();
	Исключение
	КонецПопытки;
	
КонецПроцедуры

// Процедура, заполняет историю сообщений WhatsApp.
//
Процедура ЗаполнитьИсториюСообщенийGreenApi(ВнешняяСистема, UrlApi, ApiToken, ChannelId)
	
	Попытка
		
		Сервер	= UrlApi;
		Таймаут	= 5;
		
		Соединение = Новый HTTPСоединение(Сервер,,,,, Таймаут, Новый ЗащищенноеСоединениеOpenSSL);
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "application/json");
		
		АдресРесурса = "/waInstance" + ChannelId + "/GetContacts/" + ApiToken;
		
		Запрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
		
		Ответ			 = Соединение.Получить(Запрос);
		ТелоОтвета		 = Ответ.ПолучитьТелоКакСтроку();
		СтруктураОтвета	 = ДекодироватьИзJSON(ТелоОтвета);
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		
		ЗаписьЖурналаРегистрации(
			"ЗагрузкаКонтактовWhatsApp",
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.ВнешниеСистемы,
			ВнешняяСистема,
			"Не удалось загрузить контакты WhatsApp. Описание ошибки: " + ОписаниеОшибки + ?(ТелоОтвета = Неопределено, "", Символы.ПС + "Ответ сервера: " + ТелоОтвета)
		);
		
		Возврат;
		
	КонецПопытки;
	
	// Могут попадаться повторяющиеся контакты.
	ОбработанныеКонтакты = Новый Массив;
	
	Для Каждого ДанныеКонтакта Из СтруктураОтвета Цикл
		
		Если ОбработанныеКонтакты.Найти(ДанныеКонтакта.id) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если ДанныеКонтакта.type = "group" Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			Сервер	= "api.green-api.com";
			Таймаут	= 5;
			
			Соединение = Новый HTTPСоединение(Сервер,,,,, Таймаут, Новый ЗащищенноеСоединениеOpenSSL);
			
			Заголовки = Новый Соответствие;
			Заголовки.Вставить("Content-Type", "application/json");
			
			АдресРесурса = "/waInstance" + ChannelId + "/GetChatHistory/" + ApiToken;
			
			Запрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("chatId"	, ДанныеКонтакта.id);
			ПараметрыЗапроса.Вставить("count"	, 20);
			
			ТелоЗапроса = КодироватьВJSON(ПараметрыЗапроса);
			
			Запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
			
			Ответ			 = Соединение.ОтправитьДляОбработки(Запрос);
			ТелоОтвета		 = Ответ.ПолучитьТелоКакСтроку();
			ДанныеСообщений	 = ДекодироватьИзJSON(ТелоОтвета);
			
		Исключение
			ОписаниеОшибки	 = ОписаниеОшибки();
			ДанныеСообщений	 = Новый Массив;
			
		КонецПопытки;
		
		
		НачатьТранзакцию();
		Попытка
			
			Диалог					 = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
			Диалог.ВнешняяСистема	 = ВнешняяСистема;
			Диалог.ИдКлиента		 = ДанныеКонтакта.id;
			Диалог.ИдДиалога		 = Строка(Новый УникальныйИдентификатор);
			Диалог.Начало			 = Дата(2022, 1 ,1);
			Диалог.Окончание		 = Дата(2022, 1 ,1);
			
			НомерТелефона = УправлениеКонтактнойИнформациейСтоматология.ВернутьТелефонТолькоЦифрами(ДанныеКонтакта.id);
			
			КонтактМессенджера						 = РегистрыСведений.КонтактыМессенджеров.СоздатьМенеджерЗаписи();
			КонтактМессенджера.ВнешняяСистема		 = ВнешняяСистема;
			КонтактМессенджера.Идентификатор		 = ДанныеКонтакта.id;
			КонтактМессенджера.НаименованиеКлиента	 = ДанныеКонтакта.name;
			КонтактМессенджера.ИдПоследнегоДиалога	 = Диалог.ИдДиалога;
			КонтактМессенджера.НомерМессенджера		 = НомерТелефона;
			КонтактМессенджера.НаименованиеКлиента	 = ?(
				ЗначениеЗаполнено(КонтактМессенджера.НаименованиеКлиента),
				КонтактМессенджера.НаименованиеКлиента,
				НомерТелефона
			);
			
			Сообщения = РегистрыСведений.ЖурналСообщений.СоздатьНаборЗаписей();
			Сообщения.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
			Сообщения.Отбор.ИдКлиента.Установить(ДанныеКонтакта.id);
			
			Если ТипЗнч(ДанныеСообщений) = Тип("Массив") Тогда
				
				Для Каждого ДанныеСообщения Из ДанныеСообщений Цикл
					
					Если ДанныеСообщения.typeMessage = "textMessage" Тогда
						ТекстСообщения = ДанныеСообщения.textMessage;
						
					ИначеЕсли ДанныеСообщения.typeMessage = "extendedTextMessage" Тогда
						ТекстСообщения = ДанныеСообщения.extendedTextMessage.text;
						
					ИначеЕсли ДанныеСообщения.typeMessage = "imageMessage" Тогда
						ТекстСообщения	 = ?(ДанныеСообщения.Свойство("caption"), ДанныеСообщения.caption, "");
						Изображение		 = ДанныеСообщения.downloadUrl;
						
					ИначеЕсли ДанныеСообщения.typeMessage = "videoMessage" Тогда
						ТекстСообщения	 = ?(ДанныеСообщения.Свойство("caption"), ДанныеСообщения.caption, "");
						PDF				 = ДанныеСообщения.downloadUrl;
						
					ИначеЕсли ДанныеСообщения.typeMessage = "documentMessage" Тогда
						ТекстСообщения	 = ?(ДанныеСообщения.Свойство("caption"), ДанныеСообщения.caption, "");
						PDF				 = ДанныеСообщения.downloadUrl;
						
					ИначеЕсли ДанныеСообщения.typeMessage = "audioMessage" Тогда
						ТекстСообщения	 = ?(ДанныеСообщения.Свойство("caption"), ДанныеСообщения.caption, "");
						Аудио			 = ДанныеСообщения.downloadUrl;
						
					Иначе
						Продолжить;
						
					КонецЕсли;
					
					ОтметкаВремени	 = ДанныеСообщений.timestamp;
					ПоправкаВремени	 = ТекущаяДатаСеанса() - ТекущаяУниверсальнаяДата();
					
					ДатаСообщения = Дата(1970, 1, 1) + ОтметкаВремени + ПоправкаВремени;
					
					Сообщение					 = Сообщения.Добавить();
					Сообщение.ИдСообщения		 = ДанныеСообщения.idMessage;
					Сообщение.ВнешняяСистема	 = ВнешняяСистема;
					Сообщение.ИдКлиента			 = ДанныеКонтакта.id;
					Сообщение.Период			 = ДатаСообщения;
					Сообщение.ДатаСообщения		 = ДатаСообщения;
					Сообщение.ИдДиалога			 = Диалог.ИдДиалога;
					Сообщение.Мессенджер		 = Перечисления.Мессенджеры.whatsapp;
					Сообщение.СообщениеОтКлиента = (ДанныеСообщения.type = "incoming");
					Сообщение.Прочитано			 = Истина;
					Сообщение.ТекстСообщения	 = ТекстСообщения;
					Сообщение.Изображение		 = Изображение;
					Сообщение.PDF				 = PDF;
					Сообщение.Аудио				 = Аудио;

				КонецЦикла;
				
			КонецЕсли;
			
			Если Сообщения.Количество() = 0 Тогда
				ПустоеСообщение						 = Сообщения.Добавить();
				ПустоеСообщение.ИдСообщения			 = Строка(Новый УникальныйИдентификатор);
				ПустоеСообщение.ВнешняяСистема		 = ВнешняяСистема;
				ПустоеСообщение.ИдКлиента			 = ДанныеКонтакта.id;
				ПустоеСообщение.Период				 = Дата(2022, 1, 1);
				ПустоеСообщение.ДатаСообщения		 = Дата(2022, 1, 1);
				ПустоеСообщение.ИдДиалога			 = Диалог.ИдДиалога;
				ПустоеСообщение.Мессенджер			 = Перечисления.Мессенджеры.whatsapp;
				ПустоеСообщение.СообщениеОтКлиента	 = Ложь;
				ПустоеСообщение.Прочитано			 = Истина;
				ПустоеСообщение.ОжиданиеСообщения	 = Истина;
			КонецЕсли;
			
			Диалог.Записать();
			Сообщения.Записать();
			КонтактМессенджера.Записать();
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
		КонецПопытки;
		
		ОбработанныеКонтакты.Добавить(ДанныеКонтакта.id);
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Перезаполнить фото и наименования клиентов в фоне
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  UrlApi			 - 	 - 
//  ApiToken		 - 	 - 
//  ChannelId		 - 	 - 
//
Процедура ПерезаполнитьФотоИНаименованияКлиентовВФоне(ВнешняяСистема, UrlApi, ApiToken, ChannelId) Экспорт
	
	ПараметрыДанных = Новый Структура("ВнешняяСистема, UrlApi, ApiToken, ChannelId", ВнешняяСистема, UrlApi, ApiToken, ChannelId);
	
	УИДФоновогоЗадания = Новый УникальныйИдентификатор;
	мПараметры = Новый Массив;
	мПараметры.Добавить(УИДФоновогоЗадания);
	мПараметры.Добавить(ПараметрыДанных);
	
	ФоновыеЗадания.Выполнить("МессенджерСтоматология.ПерезаполнитьФотоИНаименованияКлиентовФоновое", мПараметры, УИДФоновогоЗадания, "Перезаполнить фото и наименования клиентов для мессенджера");
	
КонецПроцедуры

// Процедура - Перезаполнить фото и наименования клиентов фоновое
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
//
Процедура ПерезаполнитьФотоИНаименованияКлиентовФоновое(УИДФоновогоЗадания, СтруктураПараметров) Экспорт
	
	РегистрыСведений.КонтактыМессенджеров.ПерезаполнитьФотоИНаименованияКлиентов(СтруктураПараметров.ВнешняяСистема, СтруктураПараметров.UrlApi, СтруктураПараметров.ApiToken, СтруктураПараметров.ChannelId);
	
КонецПроцедуры

// Процедура, оповещает сотрудников о новом сообщении.
//
Процедура ОповеститьСотрудниковОНовомСообщении(
	ИдСообщения		 = Неопределено,
	ТексСообщения	 = Неопределено,
	ИдКлиента		 = Неопределено,
	Оператор		 = Неопределено,
	ВнешняяСистема	 = Неопределено)
	
	// Создаем оповещение других сеансов.
	УстановитьПривилегированныйРежим(Истина);
	
	ИдКонтакта = ИдКлиента + "_" + ВнешняяСистема.УникальныйИдентификатор();
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(ИдСообщения);
	МассивПараметров.Добавить(Неопределено);
	МассивПараметров.Добавить(Неопределено);
	МассивПараметров.Добавить(ИдКонтакта);
	МассивПараметров.Добавить(Неопределено);
	
	ТекущиеСеансы = ПолучитьСеансыИнформационнойБазы();
    НомерТекущегоСеанса = НомерСеансаИнформационнойБазы();
	
	ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
	ПользователиОповещения = Новый Массив;
	
	Для Каждого ТекущийСеанс Из ТекущиеСеансы Цикл
		
		Если НомерТекущегоСеанса = ТекущийСеанс.НомерСеанса Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТекущийСеанс.ИмяПриложения = "1CV8C" ИЛИ ТекущийСеанс.ИмяПриложения = "WebClient" Тогда
			
			РолиПользователя = ТекущийСеанс.Пользователь.Роли;
			
			Если РолиПользователя.Содержит(Метаданные.Роли.ИспользованиеМессенджера)
				ИЛИ РолиПользователя.Содержит(Метаданные.Роли.ПолныеПрава)
				ИЛИ РолиПользователя.Содержит(Метаданные.Роли.АдминистраторСистемы) Тогда
				
				Если ИспользоватьСистемуВзаимодействия = Истина Тогда
					ПользователиОповещения.Добавить(ТекущийСеанс.Пользователь);
				Иначе
					РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(ТекущийСеанс.НомерСеанса,, "НовоеСообщениеМессенджер", ТекущаяДатаСеанса(), 60,,, МассивПараметров);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;	
	
	Если ИспользоватьСистемуВзаимодействия = Истина И ПользователиОповещения.Количество() > 0 Тогда
		
		ДанныеСообщения = Новый Структура;
		ДанныеСообщения.Вставить("Ключ"				, "НовоеСообщениеМессенджер");
		ДанныеСообщения.Вставить("IDСообщения"		, ИдСообщения);
		ДанныеСообщения.Вставить("IDКлиента"		, ИдКонтакта);
		
		ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
		
	КонецЕсли;	
	
КонецПроцедуры

// Функция, возвращает параметры объекта идентификации.
//
Функция ПолучитьПараметрыОбъектаИдентификации(ОбъектИдентификации, ВнешняяСистема) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтактыМессенджеров.Идентификатор КАК ИдКлиента
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|ГДЕ
	|	КонтактыМессенджеров.ВнешняяСистема = &ВнешняяСистема
	|	И КонтактыМессенджеров.ОбъектИдентификации = &ОбъектИдентификации
	|	И &УсловиеПоиска
	|	И НЕ КонтактыМессенджеров.НеУчаствоватьВРассылке");
	
	Запрос.УстановитьПараметр("ОбъектИдентификации", ОбъектИдентификации);
	Запрос.УстановитьПараметр("ВнешняяСистема"     , ВнешняяСистема);
	
	УсловиеПоиска = ?(ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi, "И КонтактыМессенджеров.Идентификатор ПОДОБНО ""%@c.us""", "");
	Запрос.Текст  = СтрЗаменить(Запрос.Текст, "И &УсловиеПоиска", УсловиеПоиска);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Новый Структура("ИдКлиента", Выборка.ИдКлиента), Неопределено);
	
КонецФункции

&НаСервере
// Процедура, возвращает ид "ожидающего" сообщения в мессенджер.
//
Функция ПолучитьИдОжидающегоСообщенияВМесенджер(ИдКлиента, ВнешняяСистема) Экспорт
	
	ПоследнееСообщение = ПолучитьПоследнееСообщениеКлиента(ИдКлиента, ВнешняяСистема);
	
	Если ПоследнееСообщение = Неопределено Тогда
		
		ПоследнееСообщение = Новый Структура;
		ПоследнееСообщение.Вставить("ИдКлиента"		, ИдКлиента);
		ПоследнееСообщение.Вставить("ВнешняяСистема", ВнешняяСистема);
		ПоследнееСообщение.Вставить("Мессенджер"	, Перечисления.Мессенджеры.whatsapp);
		
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ЖурналСообщений.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ПоследнееСообщение);
	
	ТекДата     = ТекущаяДатаСеанса();
	ИдСообщения = Строка(Новый УникальныйИдентификатор());
	ИдДиалога	= РегистрыСведений.Диалоги.ПолучитьТекущийДиалог(
		ИдКлиента,
		ВнешняяСистема,
		// ПараметрыСеанса.ТекущийПользователь.Сотрудник, - не передаем пользователя чтобы не открывался новый диалог.
		Неопределено,
		ТекДата,
		Ложь,
		МенеджерЗаписи.Мессенджер
	);
	
	МенеджерЗаписи.Период             = ТекДата;
	МенеджерЗаписи.ДатаСообщения      = ТекДата;
	МенеджерЗаписи.ТекстСообщения     = "";
	МенеджерЗаписи.СообщениеОтКлиента = Ложь;
	МенеджерЗаписи.Триггер            = Ложь;
	МенеджерЗаписи.ОжиданиеСообщения  = Истина;
	МенеджерЗаписи.ИдСообщения        = ИдСообщения;
	МенеджерЗаписи.Изображение        = Неопределено;
	МенеджерЗаписи.Аудио              = Неопределено;
	МенеджерЗаписи.PDF                = Неопределено;
	МенеджерЗаписи.ИдДиалога		  = ИдДиалога;
	
	МенеджерЗаписи.Записать();
	
	Возврат ИдСообщения;
	
КонецФункции	

// Фкнция, возвращает последнее сообщение клиента.
//
Функция ПолучитьПоследнееСообщениеКлиента(ИдКлиента, ВнешняяСистема) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЖурналСообщений.Период КАК Период,
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения,
	|	ЖурналСообщений.ТекстСообщения КАК ТекстСообщения,
	|	ЖурналСообщений.ИдОператора КАК ИдОператора,
	|	ЖурналСообщений.Мессенджер КАК Мессенджер,
	|	ЖурналСообщений.ДатаСообщения КАК ДатаСообщения,
	|	ЖурналСообщений.ИдКанала КАК ИдКанала,
	|	ЖурналСообщений.СообщениеОтКлиента КАК СообщениеОтКлиента,
	|	ЖурналСообщений.ОператорСообщения КАК ОператорСообщения,
	|	ЖурналСообщений.Изображение КАК Изображение,
	|	ЖурналСообщений.Аудио КАК Аудио,
	|	ЖурналСообщений.PDF КАК PDF,
	|	ЖурналСообщений.Прочитано КАК Прочитано,
	|	ЖурналСообщений.Триггер КАК Триггер,
	|	ЖурналСообщений.ИдНаписавшегоВГруппу КАК ИдНаписавшегоВГруппу,
	|	ЖурналСообщений.ОжиданиеСообщения КАК ОжиданиеСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЖурналСообщений.Период УБЫВ");
	
	Запрос.УстановитьПараметр("ИдКлиента"     , ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка, Неопределено);
	
КонецФункции

// Возвращает иконку мессенджера.
//
Функция ПолучитьИконкуМессенджера(Мессенджер) Экспорт
	
	Если Мессенджер = Перечисления.Мессенджеры.facebook Тогда
		Возврат БиблиотекаКартинок.Пустая;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.instagram Тогда
		Возврат БиблиотекаКартинок.Пустая;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.ok Тогда
		Возврат БиблиотекаКартинок.Пустая;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.skype Тогда
		Возврат БиблиотекаКартинок.Skype;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.telegram Тогда
		Возврат БиблиотекаКартинок.Telegram;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.viber Тогда
		Возврат БиблиотекаКартинок.Viber;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.vk Тогда
		Возврат БиблиотекаКартинок.Vk;
	ИначеЕсли Мессенджер = Перечисления.Мессенджеры.whatsapp Тогда
		Возврат БиблиотекаКартинок.Whatsapp;
	КонецЕсли;
	
	Возврат БиблиотекаКартинок.Пустая;
	
КонецФункции

// Процедура, оповещает сотрудника мессенджера о событии.
//
Процедура ОповеститьСотрудникаМессенджера(Оператор, Ключ, ИдКлиента) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(ИдКлиента);
	
	ТекущиеСеансы = ПолучитьСеансыИнформационнойБазы();
	
	ИдентификаторПользователяИБ = Оператор.ИдентификаторПользователяИБ;
	
	ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
	
	Для Каждого ТекущийСеанс Из ТекущиеСеансы Цикл
		
		Если (ТекущийСеанс.ИмяПриложения = "1CV8C" ИЛИ ТекущийСеанс.ИмяПриложения = "WebClient")
			И ТекущийСеанс.Пользователь.УникальныйИдентификатор = ИдентификаторПользователяИБ Тогда
			
			Если ИспользоватьСистемуВзаимодействия = Истина Тогда

				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("Ключ"		, Ключ);
				ДанныеСообщения.Вставить("IDКлиента", ИдКлиента);
								
				ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, Оператор);
				
			Иначе
				РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(Оператор,, Ключ, ТекущаяДатаСеанса(), 60,,, МассивПараметров);
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЦикла
		
КонецПроцедуры

// Функция, возвращает признак необходимости оповещения сотрудника.
//
Функция РазрешеноОповещениеСотрудника(ИдКонтакта) Экспорт
	
	Если Не РольДоступна("ИспользованиеМессенджера") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПозицияРазделителя	 = СтрНайти(ИдКонтакта, "_", НаправлениеПоиска.СКонца);
	ИдКлиента			 = Лев(ИдКонтакта, ПозицияРазделителя - 1);
	ВнешняяСистема		 = ПолучитьСсылкуОбъектаПоUID("Справочники", "ВнешниеСистемы", Сред(ИдКонтакта, ПозицияРазделителя + 1));
	
	ОператорДиалога = РегистрыСведений.Диалоги.ПолучитьОператораПоследнегоДиалога(ИдКлиента, ВнешняяСистема);
	
	Возврат (ОператорДиалога = ПараметрыСеанса.ТекущийПользователь Или Не ЗначениеЗаполнено(ОператорДиалога));
	
КонецФункции

// Функция, загружает файл и возвращает ссылку для доступа к нему.
//
Функция ЗагрузитьФайлВХранилищеИПолучитьСсылку(Файл, ОписаниеОшибки = Неопределено)
	
	Попытка
		Соединение = Новый HTTPСоединение("cloud.1c.fitness/upload_file/index.php",,,,, 10, Новый ЗащищенноеСоединениеOpenSSL);
		Запрос = Новый HTTPЗапрос();
		
		ЧастиИмени = СтрРазделить(Файл.ИмяФайла, ".", Истина);
		Расширение = "";
		Если ЧастиИмени.Количество() Тогда
			Расширение = "." + ЧастиИмени[ЧастиИмени.Количество() - 1];
			ЧастиИмени.Удалить(ЧастиИмени.Количество() - 1);
		КонецЕсли;
		
		ИмяФайла = СтрСоединить(ЧастиИмени, "_") + Расширение;
		
		ПараметрыТела = Новый Структура;
		ПараметрыТела.Вставить("name"		, "file" + Строка(Новый УникальныйИдентификатор) + "_" + СтрЗаменить(ИмяФайла, " ", "_"));
		ПараметрыТела.Вставить("file_data"	, Сред(Файл.ДанныеФайла, СтрНайти(Файл.ДанныеФайла, ",") + 1));
		
		Запрос.УстановитьТелоИзСтроки(КодироватьВJSON(ПараметрыТела));
		
		Ответ			 = Соединение.ОтправитьДляОбработки(Запрос);
		ТелоОтвета		 = Ответ.ПолучитьТелоКакСтроку();
		СтруктураОтвета	 = ДекодироватьИзJSON(ТелоОтвета);
		
		Если Ответ.КодСостояния = 200 И ЗначениеЗаполнено(СтруктураОтвета) И СтруктураОтвета.Свойство("url") Тогда
			Возврат СтруктураОтвета.url;
		КонецЕсли;
		
		ОписаниеОшибки =
		"Файловый сервер не вернул приемлемый ответ." + Символы.ПС +
		"Ответ файлового сервера: " + ТелоОтвета;
		
	Исключение
		ОписаниеОшибки =
		"Текст ошибки: " + ОписаниеОшибки() + Символы.ПС +
		?(ЗначениеЗаполнено(ТелоОтвета), "Ответ файлового сервера: " + ТелоОтвета, "Ответ файлового сервера не был получен.");
		
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

// Функция, получает файл по временной ссылке, загружает в файловое хранилище и возвращает постоянную ссылку на файл.
//
Функция ПреобразоватьВременнуюСсылку(АдресФайла) Экспорт
	
	Попытка
		
		Если СтрНачинаетсяС(АдресФайла, "http://") Тогда
			ЗащищенноеСоединение = Неопределено;
			Адрес = СтрЗаменить(АдресФайла, "http://", "");
		ИначеЕсли СтрНачинаетсяС(АдресФайла, "https://") Тогда
			ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
			Адрес = СтрЗаменить(АдресФайла, "https://", "");
		КонецЕсли;
		
		Соединение	 = Новый HTTPСоединение(Адрес,,,,, 5, ЗащищенноеСоединение);
		Запрос		 = Новый HTTPЗапрос("");
		
		Результат = Соединение.Получить(Запрос);
		
		ОписаниеФайла = Новый Структура;
		ОписаниеФайла.Вставить("ДанныеФайла", Результат.ПолучитьТелоКакДвоичныеДанные());
		ОписаниеФайла.Вставить("ИмяФайла"	, Строка(Новый УникальныйИдентификатор));
		
		ПостояннаяСсылка = ЗагрузитьФайлВХранилищеИПолучитьСсылку(ОписаниеФайла);
		
		// Если нет постоянной ссылки, возвращаем хотя бы временную.
		Возврат ?(ЗначениеЗаполнено(ПостояннаяСсылка), ПостояннаяСсылка, АдресФайла);
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат АдресФайла;
	
КонецФункции

