#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции	
	
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаНачислениеЗарплаты, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	РасчетЗарплаты.Ссылка.Дата КАК Период,
	|	РасчетЗарплаты.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	РасчетЗарплаты.Сотрудник,
	|	РасчетЗарплаты.Сумма,
	|	НАЧАЛОПЕРИОДА(РасчетЗарплаты.Ссылка.ДатаНачалаПериода, МЕСЯЦ) КАК МесяцНачисления,
	|	РасчетЗарплаты.Ссылка КАК ДокументНачисления
	|ПОМЕСТИТЬ ТаблицаРасчетыСПерсоналом
	|ИЗ
	|	Документ.НачислениеЗарплаты.РасчетЗарплаты КАК РасчетЗарплаты
	|ГДЕ
	|	РасчетЗарплаты.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	НачислениеЗарплатыАвансы.Ссылка.Дата,
	|	НачислениеЗарплатыАвансы.Ссылка.СтруктурнаяЕдиница,
	|	НачислениеЗарплатыАвансы.Сотрудник,
	|	-НачислениеЗарплатыАвансы.Сумма,
	|	НАЧАЛОПЕРИОДА(НачислениеЗарплатыАвансы.Ссылка.ДатаНачалаПериода, МЕСЯЦ),
	|	NULL
	|ИЗ
	|	Документ.НачислениеЗарплаты.Авансы КАК НачислениеЗарплатыАвансы
	|ГДЕ
	|	НачислениеЗарплатыАвансы.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	3,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	НачислениеЗарплатыАвансы.Ссылка.Дата,
	|	НачислениеЗарплатыАвансы.Ссылка.СтруктурнаяЕдиница,
	|	НачислениеЗарплатыАвансы.Сотрудник,
	|	НачислениеЗарплатыАвансы.Сумма,
	|	НАЧАЛОПЕРИОДА(НачислениеЗарплатыАвансы.Ссылка.ДатаНачалаПериода, МЕСЯЦ),
	|	НачислениеЗарплатыАвансы.Ссылка
	|ИЗ
	|	Документ.НачислениеЗарплаты.Авансы КАК НачислениеЗарплатыАвансы
	|ГДЕ
	|	НачислениеЗарплатыАвансы.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	1,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.Дата,
	|	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.СтруктурнаяЕдиница,
	|	НачислениеЗарплатыПрочиеНачисленияИУдержания.Сотрудник,
	|	НачислениеЗарплатыПрочиеНачисленияИУдержания.Сумма,
	|	НАЧАЛОПЕРИОДА(НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.ДатаНачалаПериода, МЕСЯЦ),
	|	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка
	|ИЗ
	|	Документ.НачислениеЗарплаты.ПрочиеНачисленияИУдержания КАК НачислениеЗарплатыПрочиеНачисленияИУдержания
	|ГДЕ
	|	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Затраты.Ссылка.Дата КАК Период,
	|	Затраты.Ссылка.СтруктурнаяЕдиница,
	|	Затраты.ВидНачисления,
	|	Затраты.Сотрудник,
	|	Затраты.Контрагент,
	|	Затраты.Номенклатура,
	|	Затраты.Сумма
	|ПОМЕСТИТЬ ТаблицаЗатрат
	|ИЗ
	|	Документ.НачислениеЗарплаты.Затраты КАК Затраты
	|ГДЕ
	|	Затраты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(Затраты.НомерСтроки) КАК НомерСтроки,
	|	Затраты.Ссылка.Дата КАК Период,
	|	Затраты.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыСебестоимость) КАК СчетДт,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Зарплата) КАК СчетКт,
	|	ВЫБОР
	|		КОГДА НЕ СотрудникиСпецилазацииСотрудника.Специализация ЕСТЬ NULL 
	|			ТОГДА СотрудникиСпецилазацииСотрудника.Специализация
	|		ИНАЧЕ Затраты.Номенклатура.Специализация
	|	КОНЕЦ КАК СубконтоДт1,
	|	ВЫБОР
	|		КОГДА Затраты.Документ ССЫЛКА Документ.Прием
	|				И Затраты.Документ.ПолисМедСтрахования <> ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяССылка)
	|			ТОГДА Затраты.Документ.ПолисМедСтрахования.СтраховаяКомпания
	|		ИНАЧЕ Затраты.Контрагент
	|	КОНЕЦ КАК СубконтоДт2,
	|	Затраты.Документ.Сотрудник КАК СубконтоДт3,
	|	Затраты.СтатьяРасходов КАК СубконтоДт4,
	|	Затраты.Документ.Сотрудник КАК СубконтоКт1,
	|	СУММА(Затраты.Сумма) КАК Сумма,
	|	""Начисление заплаты"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.НачислениеЗарплаты.Затраты КАК Затраты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|		ПО Затраты.Сотрудник = СотрудникиСпецилазацииСотрудника.Ссылка
	|			И (СотрудникиСпецилазацииСотрудника.Основная = ИСТИНА)
	|ГДЕ
	|	Затраты.Ссылка = &Ссылка
	|	И Затраты.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Затраты.Ссылка.Дата,
	|	Затраты.Ссылка.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ СотрудникиСпецилазацииСотрудника.Специализация ЕСТЬ NULL 
	|			ТОГДА СотрудникиСпецилазацииСотрудника.Специализация
	|		ИНАЧЕ Затраты.Номенклатура.Специализация
	|	КОНЕЦ,
	|	Затраты.Документ.Сотрудник,
	|	ВЫБОР
	|		КОГДА Затраты.Документ ССЫЛКА Документ.Прием
	|				И Затраты.Документ.ПолисМедСтрахования <> ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяССылка)
	|			ТОГДА Затраты.Документ.ПолисМедСтрахования.СтраховаяКомпания
	|		ИНАЧЕ Затраты.Контрагент
	|	КОНЕЦ,
	|	Затраты.СтатьяРасходов,
	|	Затраты.Документ.Сотрудник
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СУММА(Затраты.НомерСтроки),
	|	Затраты.Ссылка.Дата,
	|	Затраты.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыПрочие),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Зарплата),
	|	Затраты.СтатьяРасходов,
	|	ВЫБОР
	|		КОГДА НЕ СотрудникиСпецилазацииСотрудника.Специализация ЕСТЬ NULL 
	|			ТОГДА СотрудникиСпецилазацииСотрудника.Специализация
	|		ИНАЧЕ Затраты.Номенклатура.Специализация
	|	КОНЕЦ,
	|	NULL,
	|	NULL,
	|	Затраты.Сотрудник,
	|	СУММА(Затраты.Сумма),
	|	""Начисление заплаты""
	|ИЗ
	|	Документ.НачислениеЗарплаты.Затраты КАК Затраты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|		ПО Затраты.Сотрудник = СотрудникиСпецилазацииСотрудника.Ссылка
	|			И (СотрудникиСпецилазацииСотрудника.Основная = ИСТИНА)
	|ГДЕ
	|	Затраты.Ссылка = &Ссылка
	|	И Затраты.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Затраты.Ссылка.Дата,
	|	Затраты.Ссылка.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ СотрудникиСпецилазацииСотрудника.Специализация ЕСТЬ NULL 
	|			ТОГДА СотрудникиСпецилазацииСотрудника.Специализация
	|		ИНАЧЕ Затраты.Номенклатура.Специализация
	|	КОНЕЦ,
	|	Затраты.Сотрудник,
	|	Затраты.СтатьяРасходов";
	
	Запрос.УстановитьПараметр("Ссылка" , ДокументСсылкаНачислениеЗарплаты);
	Запрос.ВыполнитьПакет();
	
	СформироватьТаблицаРасчетыСПерсоналом(ДокументСсылкаНачислениеЗарплаты, СтруктураДополнительныеСвойства);
	СформироватьТаблицаЗатраты(ДокументСсылкаНачислениеЗарплаты, СтруктураДополнительныеСвойства);
	СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства);	

	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыСПерсоналом(ДокументСсылкаНачислениеЗарплаты, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РасчетыСПерсоналом.НомерСтроки КАК НомерСтроки,
	|	РасчетыСПерсоналом.ВидДвижения,
	|	РасчетыСПерсоналом.Период,
	|	РасчетыСПерсоналом.ДокументНачисления,
	|	РасчетыСПерсоналом.СтруктурнаяЕдиница,
	|	РасчетыСПерсоналом.МесяцНачисления,
	|	РасчетыСПерсоналом.Сотрудник,
	|	СУММА(РасчетыСПерсоналом.Сумма) КАК Сумма
	|ИЗ
	|	ТаблицаРасчетыСПерсоналом КАК РасчетыСПерсоналом
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСПерсоналом.НомерСтроки,
	|	РасчетыСПерсоналом.ВидДвижения,
	|	РасчетыСПерсоналом.Период,
	|	РасчетыСПерсоналом.ДокументНачисления,
	|	РасчетыСПерсоналом.СтруктурнаяЕдиница,
	|	РасчетыСПерсоналом.МесяцНачисления,
	|	РасчетыСПерсоналом.Сотрудник
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПерсоналом", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗатраты(ДокументСсылкаНачислениеЗарплаты, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Затраты.Период,
	|	Затраты.СтруктурнаяЕдиница,
	|	Затраты.ВидНачисления КАК СтатьяЗатрат,
	|	Затраты.Сотрудник,
	|	Затраты.Контрагент,
	|	Затраты.Номенклатура,
	|	Затраты.Сумма
	|ИЗ
	|	ТаблицаЗатрат КАК Затраты";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗатраты", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	ВременнаяТаблицаУправленческий.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаУправленческий.Период,
	|	ВременнаяТаблицаУправленческий.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаУправленческий.СчетДт,
	|	ВременнаяТаблицаУправленческий.СчетКт,
	|	ВременнаяТаблицаУправленческий.СубконтоДт1,
	|	ВременнаяТаблицаУправленческий.СубконтоДт2,
	|	ВременнаяТаблицаУправленческий.СубконтоДт3,
	|	ВременнаяТаблицаУправленческий.СубконтоДт4,
	|	ВременнаяТаблицаУправленческий.СубконтоКт1,
	|	ВременнаяТаблицаУправленческий.Сумма,
	|	ВременнаяТаблицаУправленческий.Содержание КАК Содержание
	|ИЗ
	|	ВременнаяТаблицаУправленческий КАК ВременнаяТаблицаУправленческий
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
		
	РезультатЗапроса = Запрос.Выполнить();	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаУправленческий", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры


