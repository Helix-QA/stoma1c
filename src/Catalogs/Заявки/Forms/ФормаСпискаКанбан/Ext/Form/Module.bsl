	БлокСотрудника			 = Документ.getElementById(ИдентификаторЗаявки).querySelector(".manager");
	БлокСотрудника.id		 = ДанныеСотрудника.ИдентификаторСотрудника;
	БлокСотрудника.innerText = ДанныеСотрудника.ПредставлениеСотрудника;
	
КонецПроцедуры

&НаКлиенте
