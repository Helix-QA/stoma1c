// Процедура - Инициализация внешней системы оценок и отзывов
//
// Параметры:
//  АктивироватьСистему	 - 	 - 
//
Процедура ИнициализацияВнешнейСистемыОценокИОтзывов(АктивироватьСистему = Неопределено)
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ОценкиИОтзывы, Ложь); 
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда			
		ВнешняяСистема = Справочники.ВнешниеСистемы.СоздатьВнешнююСистему(Перечисления.ТипыВнешнихСистем.ОценкиИОтзывы,,Истина);
	КонецЕсли;
	
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВнешняяСистема, "Используется") = Ложь И АктивироватьСистему <> Неопределено И АктивироватьСистему = Истина Тогда 
		ВлкОтклВС = ВнешняяСистема.ПолучитьОбъект();
		Если АктивироватьСистему = Неопределено Тогда 
			АктивироватьСистему = Константы.УдалитьИнформироватьОбОценкеЗанятия.Получить();
		КонецЕсли;	
		Если АктивироватьСистему Тогда
			ВлкОтклВС.Используется 	= Истина;
			УидСессии        		= ЛичныйКабинет.УидТекущейСессии();
			Справочники.ВнешниеСистемы.ПодключитьВнешнююСистему(ВнешняяСистема, Ложь, УидСессии);
		Иначе
			ВлкОтклВС.Используется = Ложь;
		КонецЕсли;
		ВлкОтклВС.Записать();
	КонецЕсли;

КонецПроцедуры

