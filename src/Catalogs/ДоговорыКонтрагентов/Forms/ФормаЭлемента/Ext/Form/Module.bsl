&НаКлиенте
// Процедура, обработчик команды формы "ДобавитьВДеревоУслуг".
//
Процедура ДобавитьВДеревоУслуг(Команда)
		
	МассивВыбранныхНоменклатур = ПолучитьМассивВыбранныхНоменклатур();
	
	СтруктураПараметры = Новый Структура();	
	СтруктураПараметры.Вставить("МножественныйВыбор"          	, Истина);
	СтруктураПараметры.Вставить("МассивНоменклатур" 			, МассивВыбранныхНоменклатур);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДеревоУслугиНоменклатураНачалоВыбораЗавершение", ЭтаФорма, МассивВыбранныхНоменклатур); 	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаВыбора", СтруктураПараметры, ЭтаФорма,,,, 
	ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
// Функция, возвращает массив выбранных номенклатур из табличной части услуги.
//
Функция ПолучитьМассивВыбранныхНоменклатур()
	
	МассивВыбранныхНоменклатур = Новый Массив();
	ПервичныйМассив = ВыгрузитьДеревоЗначенийВТаблицу(РеквизитФормыВЗначение("ДеревоНоменклатур"), Ложь).НайтиСтроки(Новый Структура("Выбран", 1));
	
	ДеревоЗначенийУслуг = РеквизитФормыВЗначение("ДеревоУслуг");
	Для каждого СтрокаМассива Из ПервичныйМассив Цикл
		
		МассивНайденныхСтрок = ДеревоЗначенийУслуг.Строки.НайтиСтроки(Новый Структура("Номенклатура",СтрокаМассива.Номенклатура), Истина);
		Если МассивНайденныхСтрок.Количество() = 0 Тогда
			МассивВыбранныхНоменклатур.Добавить(СтрокаМассива.Номенклатура);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивВыбранныхНоменклатур;

КонецФункции

&НаКлиенте
// Процедура, выбрать все строки.
//
Процедура ВыбратьСтроки(Команда)
	
	ОтметитьУслуги(1);
	
КонецПроцедуры

&НаКлиенте
// Процедура, исключить все строки.
//
Процедура ИсключитьСтроки(Команда)
		
	//ИсключитьСтрокиНаСервере();
	
	МассивНоменклатур = Новый Массив();
	ДеревоУслугОграниченийГрупа = ДеревоУслуг.ПолучитьЭлементы();
	Для каждого СтрокаДереваГруппа Из ДеревоУслугОграниченийГрупа Цикл
		// Вложенность только 1.
		ДанныеДереваЭлементы = СтрокаДереваГруппа.ПолучитьЭлементы();
		Для каждого ЭлементДерева Из ДанныеДереваЭлементы Цикл
			МассивНоменклатур.Добавить(ЭлементДерева.Номенклатура);
		КонецЦикла;
	КонецЦикла;
	
	ОтметитьУслуги(0, МассивНоменклатур);
	ЭтаФорма.Модифицированность = Истина;
	УстановитьНачальныеФлагиНаГруппы();	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды формы "ИмпортСтраховыхПациентов".
//
Процедура ИмпортСтраховыхПациентов(Команда)
	
	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("СтраховаяКомпания", Объект.Контрагент);
	ПараметрыЗаполнения.Вставить("ДоговорСтраховойКомпании", Объект.Ссылка);
	
	ОткрытьФорму("Обработка.ИмпортСтраховыхПациентов.Форма", ПараметрыЗаполнения, ЭтаФорма,Ложь,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды формы "ДобавитьПолис".
//
Процедура ДобавитьПолис(Команда)
	
	СтруктураЗаполнения = Новый Структура();
	СтруктураЗаполнения.Вставить("СтраховаяКомпания", Объект.Контрагент);
	
	ОткрытьФорму("Справочник.ПолисыМедицинскогоСтрахования.Форма.ФормаЭлемента", СтруктураЗаполнения,ЭтаФорма,Ложь,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	
КонецПроцедуры



