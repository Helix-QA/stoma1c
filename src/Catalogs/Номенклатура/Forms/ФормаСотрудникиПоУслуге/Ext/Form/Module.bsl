// Функция - Получить список сотрудников.
// 
// 
Функция ПолучитьСписокДолжностей(ВременныйСписокСотрудников = Неопределено)
	
	ТаблицаДолжностей = ПолучитьТаблицуДолжностей(ВременныйСписокСотрудников);
	ТаблицаДолжностей.Сортировать("КоличествоСотрудников Убыв",);
	СписокДолжностей = Новый СписокЗначений;
	
	// Заполнение списка сотрудников.
	Отступ = "    ";
	СписокДолжностей.Добавить("Все", "Все",,БиблиотекаКартинок.ПапкаНовая);	// Все.
	
	Для Каждого СтрокаДолжность Из ТаблицаДолжностей Цикл
		
		Если СтрокаДолжность.КоличествоСотрудников > 0 Тогда
			СписокДолжностей.Добавить(
			СтрокаДолжность.Должность,
			Отступ+Строка(СтрокаДолжность.Должность) + "(" + Строка(СтрокаДолжность.КоличествоСотрудников) + ")",,
			БиблиотекаКартинок.РеквизитКартинка);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СписокДолжностей;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Получить таблицу сотрудников.
// 
// Параметры:
//  ДатаВремяНачала						 - 	 -
//  ДатаВремяОкончания					 - 	 -
// 
// Возвращаемое значение:
//   -
// 
Функция ПолучитьТаблицуДолжностей(ВременныйСписокСотрудников = Неопределено)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сотрудники.Ссылка) КАК КоличествоСотрудников,
	|	Сотрудники.Должность КАК Должность
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В (&СписокСотрудников)
	|   И Сотрудники.Должность <> ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
	|СГРУППИРОВАТЬ ПО
	|	Сотрудники.Должность";
	
	Если Не ЗначениеЗаполнено(ВременныйСписокСотрудников) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сотрудники.Ссылка В (&СписокСотрудников)", "Истина");	
	Иначе
		Запрос.УстановитьПараметр("СписокСотрудников", ВременныйСписокСотрудников);
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции 

#КонецОбласти

#Область ПоРоли

&НаКлиенте
// Процедура - Открыть список ролей.
// 
// 
Процедура ОткрытьСписокРолей(Команда)
	
	ВременныйСписокСотрудников = Неопределено;
	
	ЗаполнитьСорудниковСогласноОтборов(ОтборСотрудникРоль, ВременныйСписокСотрудников);
	
	СписокЗначений = ПолучитьСписокРолей(ВременныйСписокСотрудников);
	
	Оповещение = Новый ОписаниеОповещения("ОткрытьСписокРолейЗавершение", ЭтотОбъект);
	
	ПоказатьВыборИзМеню(Оповещение, СписокЗначений, ЭтаФорма.Элементы.ПереклРоль);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Открыть список заверщение Клиент.
// 
// Параметры:
//  Результат	 - 	 -
//  ДопПараметры - 	 -
// 
Процедура ОткрытьСписокРолейЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборСотрудникРоль = Результат.Значение;
	ОбновитьДеревоПодборовСотрудников(,,Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить отбор по сотруднику.
// 
// 
Процедура ОтменитьОтборПоРоли(Команда)
	
	ОтборСотрудникРоль = ПредопределенноеЗначение("Перечисление.РольПользователя.ПустаяСсылка"); 	
	ОбновитьДеревоПодборовСотрудников(,,Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить список сотрудников.
// 
// 
Функция ПолучитьСписокРолей(ВременныйСписокСотрудников = Неопределено)
	
	ТаблицаРолей = ПолучитьТаблицуРолей(ВременныйСписокСотрудников);
	ТаблицаРолей.Сортировать("КоличествоСотрудников Убыв",);
	СписокРолей = Новый СписокЗначений;
	
	// Заполнение списка сотрудников.
	Отступ = "    ";
	СписокРолей.Добавить("Все", "Все",,БиблиотекаКартинок.ПапкаНовая);	// Все.
	
	Для Каждого СтрокаРоль Из ТаблицаРолей Цикл
		
		Если СтрокаРоль.КоличествоСотрудников > 0 Тогда
			СписокРолей.Добавить(
			СтрокаРоль.Роль,
			Отступ+Строка(СтрокаРоль.Роль) + "(" + Строка(СтрокаРоль.КоличествоСотрудников) + ")",,
			БиблиотекаКартинок.РеквизитКартинка);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СписокРолей;
	
КонецФункции

