// Процедура - Представление даты нажатие завершение.
//
// Параметры:
//  Результат	 - 	 -
//  Параметры	 - 	 -
//
Процедура ПредставлениеДатыНажатиеЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СрезПрайса = Результат.НачалоПериода;  
	Элементы.ВыбратьПериодПланирования.Заголовок = Формат(СрезПрайса, "ДЛФ=ДД.ММ.ГГГГ");
	НастройкиШапкиПрайсаПриИзменении();
	
КонецПроцедуры

&НаКлиенте
Процедура Сохранить(Команда)
	
	ИмяФайла = "ПрайсЛист.xls";
	ДиалогОткрытияФайла                    = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогОткрытияФайла.ПолноеИмяФайла     = ИмяФайла;
	ДиалогОткрытияФайла.Каталог		       = КаталогВременныхФайлов();
	ДиалогОткрытияФайла.Фильтр		       = "Файлы Microsoft Excel (*.xls)|*.xls|Все файлы (*.*)|*.*";
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	
	ДиалогОткрытияФайла.Показать(Новый ОписаниеОповещения("СохранитьЗавершение", ЭтотОбъект, Новый Структура("ДиалогОткрытияФайла", ДиалогОткрытияФайла))); 
	 
КонецПроцедуры

