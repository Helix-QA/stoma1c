// Процедура - Вывести скрепку.
//
// Параметры:
//  ТекстHTML			 - 	 - 
//  СобытиеЗакреплено	 - 	 - 
//  Уид					 - 	 - 
//
Процедура ВывестиСкрепку(ТекстHTML, СобытиеЗакреплено, Уид)
	
	Если СобытиеЗакреплено Тогда		
		// БиблиотекаКартинок.ОткрепитьСобытие
		// АдресКартинки = "v8config:// v8cfgHelp/mdpicture/id7e7cf2e6-d5e8-4956-b44e-129cb027955b"; 
		АдресКартинки = Base64Строка(БиблиотекаКартинок.ОткрепитьСобытие.ПолучитьДвоичныеДанные());
		КлассСтиля    = "clip on"; 
		Подсказка     = Нстр("ru='Открепить';en='Unpin'");	
	Иначе
		// БиблиотекаКартинок.ЗакрепитьСобытие
		// АдресКартинки = "v8config:// v8cfgHelp/mdpicture/id9226965f-9078-49f2-a1de-f61618482ca5"; 
		АдресКартинки = Base64Строка(БиблиотекаКартинок.ЗакрепитьСобытие.ПолучитьДвоичныеДанные());
		КлассСтиля    = "clip off";
		Подсказка     = Нстр("ru='Закрепить';en='ToFasten'");			
