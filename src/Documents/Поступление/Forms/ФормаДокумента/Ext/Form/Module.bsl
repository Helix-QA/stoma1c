#Область ТабличнаяЧастьЗапасы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" таблицы "Запасы". 
//
Процедура ЗапасыПриИзменении(Элемент)
	
	Если Объект.ВключениеСтоимостиУслугВСебестоимостьЗапасов > 0 Тогда
		ВключениеСтоимостиУслугВСебестоимостьЗапасовПриИзменении(Неопределено);
	КонецЕсли;
	Объект.СуммаДокумента = Объект.Запасы.Итог("Сумма") + Объект.Расходы.Итог("Сумма");
	СуммаНДС			  = Объект.Запасы.Итог("СуммаНДС") + Объект.Расходы.Итог("СуммаНДС");
	ОбновитьЗаголовкиТабЧастейНаКлиенте();

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередНачаломДобавления" таблицы "Запасы". 
//
Процедура ЗапасыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если Копирование Тогда
		СтрокаЗапасов = Объект.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЗапасов, Элемент.ТекущиеДанные);
		СтрокаЗапасов.Партия = Неопределено;
		Если Объект.ВключениеСтоимостиУслугВСебестоимостьЗапасов > 0 Тогда
			ВключениеСтоимостиУслугВСебестоимостьЗапасовПриИзменении(Неопределено);
		КонецЕсли;
		Объект.СуммаДокумента = Объект.Запасы.Итог("Сумма") + Объект.Расходы.Итог("Сумма");
		СуммаНДС			  = Объект.Запасы.Итог("СуммаНДС") + Объект.Расходы.Итог("СуммаНДС");

		Отказ = Истина;
		ОбновитьЗаголовкиТабЧастейНаКлиенте();

	КонецЕсли;
	
КонецПроцедуры

