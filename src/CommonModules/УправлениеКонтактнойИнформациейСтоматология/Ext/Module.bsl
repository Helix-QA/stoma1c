	КонецЕсли;
	
	// Оставим одни лишь цифры
	НомерТелефона_ТолькоЦифры = УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(ТелефонПредставление);
	
	Если СтрДлина(НомерТелефона_ТолькоЦифры) = 10 Тогда
		Если Лев(НомерТелефона_ТолькоЦифры, 1) <> "0" Тогда 
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;		
	ИначеЕсли СтрДлина(НомерТелефона_ТолькоЦифры) = 11 Тогда
		Если Сред(НомерТелефона_ТолькоЦифры, 2, 1) = "0"
			ИЛИ Сред(НомерТелефона_ТолькоЦифры, 1, 1) = "7" Тогда 
			НомерТелефона_ТолькоЦифры = Сред(НомерТелефона_ТолькоЦифры, 2, 10);
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;	
	Иначе 
		ПравильныйНомер = Ложь;
	КонецЕсли;
	
	Если ПравильныйНомер Тогда 
		МассивКодов = ВернутьМассивМобильныхТрехЗначныхКодовДляКазахстана();
		Если МассивКодов.Найти(Сред(НомерТелефона_ТолькоЦифры, 1, 3)) = Неопределено Тогда
			КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 3);
			НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 4, 7);
		Иначе                                                  // это мобильный
			КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 3);
			НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 4, 7);
		КонецЕсли;
		// ----------------------Проверим комментарий--------------------------
		Поз = Найти(ТелефонПредставление, ", ");
		Если Поз <> 0 Тогда
			// вырежем комментарий
			Комментарий = СокрЛП(Сред(ТелефонПредставление, Поз + 2));
		КонецЕсли;	
		// ------------------- Поправим представление ------------------------
		Представление = СокрЛП(КодСтраны);				
		Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + "(" + СокрЛП(КодГорода) + ")";				
		Если Не ПустаяСтрока(НомерТелефона) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + СокрЛП(НомерТелефона);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Добавочный) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + "доб. " + СокрЛП(Добавочный);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Комментарий) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + СокрЛП(Комментарий);
		КонецЕсли;
		// --------------------------------------------------------------------
				
		
		СписокПолей.Добавить(?(КодСтраны = "+7", КодСтраны, УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(КодСтраны)), "КОДСТРАНЫ");
		СписокПолей.Добавить(КодГорода		, "КОДГОРОДА");
		СписокПолей.Добавить(НомерТелефона	, "НОМЕРТЕЛЕФОНА");
		СписокПолей.Добавить(Добавочный		, "ДОБАВОЧНЫЙ");
		СписокПолей.Добавить(Представление	, "ПРЕДСТАВЛЕНИЕ");		
		СписокПолей.Добавить(Комментарий	, "КОММЕНТАРИЙ");
		
	Иначе
		СтруктураРезультата.ПравильныйНомер = Ложь;		
		ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Преобразовать для объединенные арабские эмираты
//
// Параметры:
//  Представление		 - 	 - 
//  СписокПолей			 - 	 - 
//  СтруктураРезультата	 - 	 - 
//
Процедура ПреобразоватьДля_ОбъединенныеАрабскиеЭмираты(Представление, СписокПолей, СтруктураРезультата)
	
	ТелефонПредставление = СокрЛП(Представление);	
	// СписокПолей = "";
	КодСтраны     = "";
	КодГорода     = "";
	НомерТелефона = "";
	Добавочный    = "";
	Комментарий   = "";
	
	// Вычислим код страны
	ВнутреннийФормат = СтруктураРезультата.ФорматТелНомера = 0;
	Если Не ЗначениеЗаполнено(КодСтраны) Тогда
		КодСтраны = "+971";
	КонецЕсли;
	
	// ----------------------Проверим комментарий--------------------------
	Поз = Найти(ТелефонПредставление, ", ");
	Если Поз <> 0 Тогда
		// Вырежем комментарий
		Комментарий 			= СокрЛП(Сред(ТелефонПредставление, Поз + 2));
		ТелефонПредставление 	= СтрЗаменить(ТелефонПредставление, Комментарий, "");
	КонецЕсли;	
	
	// Оставим одни лишь цифры
	НомерТелефона_ТолькоЦифры = УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(ТелефонПредставление);
	// Отсекаем лидирующие нули
	НомерТелефона_ТолькоЦифры = СтрЗаменить(СокрЛ(СтрЗаменить(НомерТелефона_ТолькоЦифры, "0", " ")), " ", "0");
	
	ПравильныйНомер = Ложь;	
	// Уберем код страны, если есть для правильного анализа
	НомерТелефонаБезКодаСтраны = НомерТелефона_ТолькоЦифры;
	Если СтрДлина(НомерТелефона_ТолькоЦифры) > 9 Тогда 
		Если СтрНайти(Лев(НомерТелефона_ТолькоЦифры, 3), "971") <> 0 Тогда 
			НомерТелефонаБезКодаСтраны = Сред(НомерТелефона_ТолькоЦифры, СтрНайти(Лев(НомерТелефона_ТолькоЦифры, 3), "971") + 3);
			// Отсекаем лидирующие нули
			НомерТелефонаБезКодаСтраны = СтрЗаменить(СокрЛ(СтрЗаменить(НомерТелефонаБезКодаСтраны, "0", " ")), " ", "0");			
			ПравильныйНомер = Истина;			
		КонецЕсли;
	КонецЕсли;
	
	Если СтрДлина(НомерТелефонаБезКодаСтраны) = 9 Тогда
		МассивКодовОператоров = ВернутьМассивМобильныхКодовДляОАЭ();
		Если МассивКодовОператоров.Найти(Сред(НомерТелефонаБезКодаСтраны, 1, 2)) <> Неопределено Тогда
			КодГорода 		= ?(ВнутреннийФормат, "0", "") + Сред(НомерТелефонаБезКодаСтраны, 1, 2);
			НомерТелефона 	= Сред(НомерТелефонаБезКодаСтраны, 3, 7);
			ПравильныйНомер = Истина;			
		Иначе 
			ПравильныйНомер = Ложь;	
		КонецЕсли;
	ИначеЕсли СтрДлина(НомерТелефонаБезКодаСтраны) = 8 Тогда
		КодГорода 		= ?(ВнутреннийФормат, "0", "") + Сред(НомерТелефонаБезКодаСтраны, 1, 1);
		НомерТелефона 	= Сред(НомерТелефонаБезКодаСтраны, 2, 7);
		ПравильныйНомер = Истина;		
	Иначе 
		ПравильныйНомер = Ложь;	
	КонецЕсли;
	
	Если ПравильныйНомер Тогда 
		// ------------------- Поправим представление ------------------------
		Представление = СокрЛП(КодСтраны);				
		Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + "(" + СокрЛП(КодГорода) + ")";				
		Если Не ПустаяСтрока(НомерТелефона) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + Лев(СокрЛП(НомерТелефона), 3) + " " + Сред(СокрЛП(НомерТелефона), 4);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Добавочный) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + "доб. " + СокрЛП(Добавочный);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Комментарий) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + СокрЛП(Комментарий);
		КонецЕсли;
		// --------------------------------------------------------------------
					
		СписокПолей.Добавить(?(КодСтраны = "971", КодСтраны, УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(КодСтраны)), "КОДСТРАНЫ");
		СписокПолей.Добавить(КодГорода		, "КОДГОРОДА");
		СписокПолей.Добавить(НомерТелефона	, "НОМЕРТЕЛЕФОНА");
		СписокПолей.Добавить(Добавочный		, "ДОБАВОЧНЫЙ");
		СписокПолей.Добавить(Представление	, "ПРЕДСТАВЛЕНИЕ");		
		СписокПолей.Добавить(Комментарий	, "КОММЕНТАРИЙ");
		
	Иначе
		СтруктураРезультата.ПравильныйНомер = Ложь;		
		ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);
	КонецЕсли;		
	
КонецПроцедуры

