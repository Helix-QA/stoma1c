
#Область СлужебныеПроцедурыИФункции
  
//// НоваяФормаОплаты

// Функция создания и заполнения необходимых документов поступления денежных средств 
// по подготовленным видам оплаты
Функция СоздатьДокументыОплатыПоТаблицеВидовОплат(
		Контрагент,
		ВидОперации,
		Касса, 
		МассивСтрокОплаты, 
		ТаблицаЗадолженностей,
		РасшифровкаОплатВозвр = Неопределено,
		ОписаниеОшибки = Неопределено,
		ID_Транзакции) Экспорт
	
	Если ОписаниеОшибки = Неопределено Тогда 
		ОписаниеОшибки = "";
	КонецЕсли;
			
	// Сортировка видов оплат, фискальные выносим вперед 
	Индекс = 0;
	Для Каждого СтрокаПлатежа ИЗ МассивСтрокОплаты Цикл
		
		Если НЕ МенеджерОборудованияВызовСервера.ПолучитьПризнакФискальностиВидаОплатыПоКассе(Касса, СтрокаПлатежа.ТипДенежныхСредств) Тогда
			
			врПерем                                               = МассивСтрокОплаты[МассивСтрокОплаты.Количество() - 1];
			МассивСтрокОплаты[МассивСтрокОплаты.Количество() - 1] = СтрокаПлатежа;
			МассивСтрокОплаты[Индекс]                             = врПерем;

		КонецЕсли;
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
	ВидОперацииДокОплаты = Неопределено;
	Если ВидОперации = Перечисления.ВидыОпераций.Продажа Тогда
		
		ВидОперацииДокОплаты = Перечисления.ВидыОпераций.ОплатаОтКлиента;	
	ИначеЕсли ВидОперации = Перечисления.ВидыОпераций.Возврат Тогда
		
		КассаИспользуетсяККТ = Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;
		ВидОперацииДокОплаты = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту;
	КонецЕсли;

	ДокументыОплаты          = Новый Массив;
	СписаниеАвансов          = Новый Массив; 
	РасшифровкаОплатВозвр    = Новый Массив;
	ДокументыОплатыПКО       = Новый Массив;
	
	// Главный цикл перебора оплачиваемых документов
	Для Каждого СтрокаЗадолженности ИЗ ТаблицаЗадолженностей Цикл
		
		Если СтрокаЗадолженности.ПризнакВыбора
			И СтрокаЗадолженности.Задолженность > 0
			И ОписаниеОшибки = "" Тогда			
						
			ДокументЗадолженности       = СтрокаЗадолженности.ДокументЗадолженности;
			ОстатокЗадолженности        = СтрокаЗадолженности.Задолженность;
			ВСуммеОплаченоПоДокументу   = 0;
			
			// Цикл перебора видов оплаты
			Для Каждого СтрокаОплаты ИЗ МассивСтрокОплаты Цикл
				
				ОплаченоПоДокументу  = 0;
				
				// Если вид оплаты содержит средства для оплаты
				Если ОстатокЗадолженности > 0 
					И СтрокаОплаты.ОплачиваемаяСумма > 0 Тогда	
					
					ОстатокСуммыПлатежа = ?(СтрокаОплаты.ОплачиваемаяСумма >= ОстатокЗадолженности, ОстатокЗадолженности, СтрокаОплаты.ОплачиваемаяСумма);
					
					РезОплаты = Неопределено;
					
					Если ВидОперацииДокОплаты = Перечисления.ВидыОпераций.ОплатаОтКлиента  Тогда
						
						Если (СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат) Тогда
							
							РезОплаты = ФормированиеОплатыНаличнымиКартойЛССертификатом(Контрагент,
								Касса, 
								ДокументЗадолженности, 
								ОстатокСуммыПлатежа,
								ДокументыОплаты, 
								ВидОперацииДокОплаты, 
								СтрокаОплаты,
								ДокументыОплатыПКО,
								ID_Транзакции);		
							
							Если ДокументыОплатыПКО.Найти(РезОплаты.ДокументОплаты) = Неопределено Тогда
								ДокументыОплатыПКО.Добавить(РезОплаты.ДокументОплаты);
							КонецЕсли;

							ОплаченоПоДокументу = РезОплаты.СуммаОплаты; 
												
						ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс Тогда
							
							Если Не ЗначениеЗаполнено(СтрокаОплаты.ДокументАванса) Тогда
								РезОплаты = ФомированиеОплатыВнесеннымАвансом(
									Контрагент,
									ДокументЗадолженности,
									ОстатокСуммыПлатежа, 
									СписаниеАвансов, 
									СтрокаОплаты);
								
							Иначе
								РезОплаты = ФомированиеОплатыВнесеннымАвансомПоДокументуАванса(
									Контрагент,
									ДокументЗадолженности,
									ОстатокСуммыПлатежа, 
									СписаниеАвансов, 
									СтрокаОплаты,
									СтрокаОплаты.ДокументАванса);
								
							КонецЕсли;
							ОплаченоПоДокументу = РезОплаты.СуммаОплаты; 
							
						ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.БонусныйСчет Тогда
								
							РезОплаты = СформироватьОплатуБонуснымСчетомСтарая(
								Контрагент,
								ДокументЗадолженности, 
								ОстатокСуммыПлатежа,
								СписаниеАвансов,							
								СтрокаОплаты);
							
							ОплаченоПоДокументу = РезОплаты.СуммаОплаты;
							
						ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПустаяСсылка() Тогда
							
							РезОплаты = Новый Структура("СуммаОплаты", СтрокаОплаты.ОплачиваемаяСумма);			
							ОплаченоПоДокументу = РезОплаты.СуммаОплаты;
							
						КонецЕсли;
						
					ИначеЕсли ВидОперацииДокОплаты = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда
										
						Если (СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет
							ИЛИ СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат) Тогда
							
						    РезОплаты = ФормированиеВозвратаОплатыНаличнымиКартойБезналомЛССертификатом(
								Контрагент,
								Касса, 
								ДокументЗадолженности, 
								ОстатокСуммыПлатежа, 
								ВидОперацииДокОплаты, 
								СтрокаОплаты);					
							
							Если ДокументыОплатыПКО.Найти(РезОплаты.ДокументОплаты) = Неопределено Тогда
								ДокументыОплатыПКО.Добавить(РезОплаты.ДокументОплаты);
							КонецЕсли;

							ОплаченоПоДокументу = РезОплаты.СуммаОплаты; 
														
						ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс Тогда
							
							РезОплаты = ФормированиеВозвратаОплатыВнесеннымАвансом(
								Контрагент,
								ДокументЗадолженности, 
								ОстатокСуммыПлатежа,
								СписаниеАвансов,
								СтрокаОплаты);
							
							ОплаченоПоДокументу = РезОплаты.СуммаОплаты;
							
						ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПустаяСсылка() Тогда
							
							РезОплаты = Новый Структура("СуммаОплаты", СтрокаОплаты.ОплачиваемаяСумма);			
							ОплаченоПоДокументу = РезОплаты.СуммаОплаты;		
							
						КонецЕсли;
						
					КонецЕсли;
					
					ОстатокЗадолженности = ОстатокЗадолженности - РезОплаты.СуммаОплаты;
					СтрокаОплаты.ОплачиваемаяСумма   = СтрокаОплаты.ОплачиваемаяСумма - ОстатокСуммыПлатежа;	
					
				КонецЕсли;	
				
				ВСуммеОплаченоПоДокументу = ВСуммеОплаченоПоДокументу + ОплаченоПоДокументу;
				
			КонецЦикла;
			
			РасшифровкаОплатВозвр.Добавить(Новый Структура("ДокументЗадолженности, СуммаОплаты", СтрокаЗадолженности.ДокументЗадолженности, ВСуммеОплаченоПоДокументу));

		КонецЕсли;
		
	КонецЦикла;	
	
	// Списание авансов визитами обязательно должны быть первыми!
	// т.к. будет конфлик при обновлении суммы оплачено 
	Для Каждого СтрокаТ Из СписаниеАвансов Цикл
	    ДокументыОплаты.Добавить(СтрокаТ.ДокументОбъект);
	КонецЦикла;

	Для Каждого ДокументПКО Из ДокументыОплатыПКО Цикл
		ДокументыОплаты.Добавить(ДокументПКО);
	КонецЦикла;
		
	Возврат ДокументыОплаты;
	
КонецФункции

//// ФормирвоаниеОплаты

// Функция - Фомирование оплаты внесенным авансом
// 
// Параметры:
//  ДокументЗадолженности	 - 	 - 
//  ОстатокЗадолженности	 - 	 - 
//  ДокументыОплаты			 - 	 - 
//  СтрокаОплаты			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ФомированиеОплатыВнесеннымАвансом(
	Контрагент,
	ДокументЗадолженности, 
	ОстатокЗадолженности, 
	ДокументыОплаты,
	СтрокаОплаты) 
	
	СуммаОстаткаАванса = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокАвансаПоКонтрагенту(Контрагент, ТекущаяДатаСеанса(),, Истина);
	ДоступноКОплате = ОстатокЗадолженности;
	Если ОстатокЗадолженности > СуммаОстаткаАванса Тогда
		ДоступноКОплате = СуммаОстаткаАванса;
	КонецЕсли;
		
	Если ДоступноКОплате > 0 Тогда
				
		// Проверка существовани откр. объекта
		НайденнвяСтр = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ДокументыОплаты, "ДокументСсылка", ДокументЗадолженности);
		
		Если НайденнвяСтр = Неопределено Тогда
			
			ПриемОбъект = ДокументЗадолженности.ПолучитьОбъект();
			ДокументыОплаты.Добавить(Новый Структура("ДокументСсылка,ДокументОбъект", ДокументЗадолженности, ПриемОбъект));
			
		Иначе
			
			ПриемОбъект = НайденнвяСтр.ДокументОбъект;
		КонецЕсли;
		
		// Проверка существования открытого аванса
		СтрокаАванса    = Неопределено;
		НайденныеСтроки = ПриемОбъект.УчтенныеАвансы.НайтиСтроки(Новый Структура("ДокументАванса", Неопределено));
		Если НайденныеСтроки.Количество() > 0 Тогда
			
			СтрокаАванса             = НайденныеСтроки[0];
			СтрокаАванса.СуммаАванса = СтрокаАванса.СуммаАванса + ДоступноКОплате;
			
		Иначе
			
			СтрокаАванса                     = ПриемОбъект.УчтенныеАвансы.Добавить();
			СтрокаАванса.ДокументАванса      = Неопределено;
			СтрокаАванса.СуммаАванса         = ДоступноКОплате;
			СтрокаАванса.ДатаПлатежа         = ТекущаяДатаСеанса();

		КонецЕсли;	
		
	КонецЕсли;

	Возврат Новый Структура("ДокументОплаты, СуммаОплаты", ПриемОбъект, ДоступноКОплате);
	
КонецФункции

// Функция - Фомирование оплаты внесенным авансом
// 
// Параметры:
//  ДокументЗадолженности	 - 	 - 
//  ОстатокЗадолженности	 - 	 - 
//  ДокументыОплаты			 - 	 - 
//  СтрокаОплаты			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ФомированиеОплатыВнесеннымАвансомПоДокументуАванса(
		Контрагент,
		ДокументЗадолженности, 
		ОстатокЗадолженности, 
		ДокументыОплаты,
		СтрокаОплаты,
		ДокументАванса) 
	
	МассивДокументовАванса = Новый Массив;
	МассивДокументовАванса.Добавить(ДокументАванса);
	
	Результат = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОстаткаАвансаПоДокументу(
		ДокументЗадолженности, МассивДокументовАванса);
		
	СуммаОстаткаАванса = Результат[0].СуммаДоступнаяДляОплатыАвансом;
	
	ДоступноКОплате = ОстатокЗадолженности;
	Если ОстатокЗадолженности > СуммаОстаткаАванса Тогда
		ДоступноКОплате = СуммаОстаткаАванса;
	КонецЕсли;
		
	Если ДоступноКОплате > 0 Тогда
				
		// Проверка существовани откр. объекта
		НайденнвяСтр = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ДокументыОплаты, "ДокументСсылка", ДокументЗадолженности);
		
		Если НайденнвяСтр = Неопределено Тогда
			
			ПриемОбъект = ДокументЗадолженности.ПолучитьОбъект();
			ДокументыОплаты.Добавить(Новый Структура("ДокументСсылка, ДокументОбъект", ДокументЗадолженности, ПриемОбъект));
			
		Иначе
			
			ПриемОбъект = НайденнвяСтр.ДокументОбъект;
		КонецЕсли;
		
		// Проверка существования открытого аванса
		СтрокаАванса    = Неопределено;
		НайденныеСтроки = ПриемОбъект.УчтенныеАвансы.НайтиСтроки(Новый Структура("ДокументАванса", ДокументАванса));
		Если НайденныеСтроки.Количество() > 0 Тогда
			
			СтрокаАванса             = НайденныеСтроки[0];
			СтрокаАванса.СуммаАванса = СтрокаАванса.СуммаАванса + ДоступноКОплате;
			
		Иначе
			
			СтрокаАванса                     = ПриемОбъект.УчтенныеАвансы.Добавить();
			СтрокаАванса.СуммаАванса         = ДоступноКОплате;
		    СтрокаАванса.ДокументАванса      = ДокументАванса;
			СтрокаАванса.ДатаПлатежа         = ТекущаяДатаСеанса();
			
		КонецЕсли;	
		                                       
	КонецЕсли;

	Возврат Новый Структура("ДокументОплаты, СуммаОплаты", ПриемОбъект, ДоступноКОплате);
	
КонецФункции

// Функция - Формирование оплаты документами ПДС и СДС
// 
// Параметры:
//  Касса					 - 	 - 
//  ДокументЗадолженности	 - 	 - 
//  ВидОперацииДокОплаты	 - 	 - 
//  СтрокаОплаты			 - 	 - 
//  ТаблицаВидовОплат		 - 	 - 
//  СуммаПлатежа			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ФормированиеОплатыНаличнымиКартойЛССертификатом(
		Контрагент,
		Касса, 
		ДокументЗадолженности,
		ОстатокЗадолженности, 
		ДокументыОплаты, 
		ВидОперацииДокОплаты,
		СтрокаОплаты,
		ДокументыОплатыПКО,
		ID_Транзакции)
	
	ДокументОплаты = ПолучитьСуществующийДокументОплатыПоТипуДенежныхСредств(
		Контрагент, СтрокаОплаты.ТипДенежныхСредств, ДокументыОплатыПКО, СтрокаОплаты.ВидЛицевогоСчета, СтрокаОплаты.Сертификат, СтрокаОплаты.СертификатПартия);
	
	Если ДокументОплаты = Неопределено Тогда
		
		ДокументОплаты                      = СоздатьДокументОплатыПоТипуДенежныхСредств(СтрокаОплаты.ТипДенежныхСредств);
		ДокументОплаты.ID_Транзакции        = ID_Транзакции;
		ДокументОплаты.Контрагент           = ?(Контрагент = СтрокаОплаты.Контрагент, Контрагент, СтрокаОплаты.Контрагент);	
		ДокументОплаты.СтруктурнаяЕдиница   = ДокументЗадолженности.СтруктурнаяЕдиница;
		
		ДокументОплаты.Заполнить(Новый Структура("СтрокаТаблицыОплата, Касса, ТипДенежныхСредств, ВидОперации", 
			СтрокаОплаты, Касса, СтрокаОплаты.ТипДенежныхСредств, ВидОперацииДокОплаты));
		
	КонецЕсли;
	
	НоваяСтрокаТЧ = ДокументОплаты.РасшифровкаПлатежа.Добавить();
	
	ЭтоВзносАванса                  = (ТипЗнч(ДокументЗадолженности) = Тип("ДокументСсылка.НарядЗаказ") 
		Или ТипЗнч(ДокументЗадолженности) = Тип("ДокументСсылка.ПланЛечения"));
	НоваяСтрокаТЧ.ДокументОснования = ?(ЭтоВзносАванса, Неопределено, ДокументЗадолженности);	
	
	Если ЭтоВзносАванса Тогда
		Статья = Справочники.СтатьиДоходовИРасходов.ВзносАвансаОтКлиента;
	Иначе
		Статья = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(ВидОперацииДокОплаты);
	КонецЕсли;
	НоваяСтрокаТЧ.Статья            = Статья;		                                                
	ДокументОплаты.Статья           = Статья;
	НоваяСтрокаТЧ.Сумма             = ОстатокЗадолженности;		
	НоваяСтрокаТЧ.ДокументАванса    = ?(ЭтоВзносАванса, ДокументЗадолженности, Неопределено);	
		
	ДокументОплаты.СуммаДокумента   = ДокументОплаты.РасшифровкаПлатежа.Итог("Сумма");	

	Если СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
		 ДокументОплаты.Сертификат              = СтрокаОплаты.Сертификат;
		 ДокументОплаты.СертификатСерийныйНомер = СтрокаОплаты.СертификатПартия;
	КонецЕсли;
	
	Возврат Новый Структура("ДокументОплаты, СуммаОплаты", ДокументОплаты, НоваяСтрокаТЧ.Сумма);

КонецФункции

// Создать документ оплаты по нужному типу ден. средств
Функция СоздатьДокументОплатыПоТипуДенежныхСредств(ТипДенежныхСредств) Экспорт
	
	Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные
		ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
		
		ДокОбъект = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();					
	Иначе		
		ДокОбъект = Документы.СписаниеДенежныхСредств.СоздатьДокумент();		
	КонецЕсли;
		
	Возврат ДокОбъект;	
		
КонецФункции

// Функция - Получить существующий документ оплаты по типу денежных средств
// 
// Параметры:
//  Контрагент			 - 	 - 
//  ТипДенежныхСредств	 - 	 - 
//  ДокументыОплатыПКО	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСуществующийДокументОплатыПоТипуДенежныхСредств(
		Контрагент, ТипДенежныхСредств, ДокументыОплатыПКО, ЛицевойСчетКонтрагента = Неопределено, Сертификат = Неопределено, Серия = Неопределено)
	
	Для Каждого ДокументОплатыСуществующий Из ДокументыОплатыПКО Цикл
		
		Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет
			И ЛицевойСчетКонтрагента <> Неопределено Тогда
			
			Если ДокументОплатыСуществующий.Контрагент = Контрагент
				И ДокументОплатыСуществующий.ТипДенежныхСредств = ТипДенежныхСредств
				И ДокументОплатыСуществующий.ЛицевойСчетКонтрагента = ЛицевойСчетКонтрагента Тогда
				
				Возврат ДокументОплатыСуществующий;
			КонецЕсли;

		ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат
			И Сертификат <> Неопределено
			И Серия <> Неопределено Тогда
			
			Если ДокументОплатыСуществующий.Контрагент = Контрагент
				И ДокументОплатыСуществующий.ТипДенежныхСредств = ТипДенежныхСредств
				И ДокументОплатыСуществующий.Сертификат = Сертификат 
				И ДокументОплатыСуществующий.СертификатСерийныйНомер = Серия Тогда
				
				Возврат ДокументОплатыСуществующий;
			КонецЕсли;
			
		Иначе
			Если ДокументОплатыСуществующий.Контрагент = Контрагент
				И ДокументОплатыСуществующий.ТипДенежныхСредств = ТипДенежныхСредств Тогда
				
				Возврат ДокументОплатыСуществующий;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции

// Функция возвращает массиво товаров для чека ККТ по документу задолженности.
//
Функция ПолучитьТекстЗапросаПолученияТоваровККТ(ДокументОснования) Экспорт

	МассивОбъединениеЗапросов = Новый Массив;
	
	СтрокаОбъединение = 
	"ОБЪЕДИНИТЬ ВСЕ
	|";	
	
	Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", ДокументОснования.Метаданные()) = Истина Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|	ВложенныйЗапрос.Цена КАК Цена,
		|	ВложенныйЗапрос.СтавкаНДС КАК СтавкаНДС,
		|	СУММА(ВложенныйЗапрос.КоличествоУпаковок) КАК КоличествоУпаковок,
		|	СУММА(ВложенныйЗапрос.СуммаНДС) КАК СуммаНДС,
		|	СУММА(ВложенныйЗапрос.Сумма) КАК Сумма,
		|	ВложенныйЗапрос.Упаковка КАК Упаковка,
		|	NULL КАК Партия,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))) <> """"
		|			ТОГДА ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))
		|		ИНАЧЕ ВложенныйЗапрос.Номенклатура.Наименование
		|	КОНЕЦ КАК Наименование
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВозвратОтПокупателяЛечение.Номенклатура КАК Номенклатура,
		|		ВозвратОтПокупателяЛечение.Цена КАК Цена,
		|		ВозвратОтПокупателяЛечение.СтавкаНДС КАК СтавкаНДС,
		|		-1 * ВозвратОтПокупателяЛечение.КоличествоУпаковок КАК КоличествоУпаковок,
		|		-1 * ВозвратОтПокупателяЛечение.СуммаНДС КАК СуммаНДС,
		|		-1 * ВозвратОтПокупателяЛечение.Сумма КАК Сумма,
		|		ВозвратОтПокупателяЛечение.Упаковка КАК Упаковка
		|	ИЗ
		|		Документ.ВозвратОтПокупателя.Лечение КАК ВозвратОтПокупателяЛечение
		|	ГДЕ
		|		ВозвратОтПокупателяЛечение.Ссылка.ДокументОснования = &Ссылка
		|		И ВозвратОтПокупателяЛечение.Ссылка.Проведен = ИСТИНА
		|		И ТИПЗНАЧЕНИЯ(&Ссылка) = ТИП(Документ.Прием)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ПриемЛечение.Номенклатура,
		|		ПриемЛечение.Цена,
		|		ПриемЛечение.СтавкаНДС,
		|		ПриемЛечение.КоличествоУпаковок,
		|		ПриемЛечение.СуммаНДС,
		|		ПриемЛечение.Сумма,
		|		ПриемЛечение.Упаковка
		|	ИЗ
		|		Документ.Прием.Лечение КАК ПриемЛечение
		|	ГДЕ
		|		ПриемЛечение.Ссылка = &Ссылка) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Номенклатура,
		|	ВложенныйЗапрос.Цена,
		|	ВложенныйЗапрос.СтавкаНДС,
		|	ВложенныйЗапрос.Упаковка,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))) <> """"
		|			ТОГДА ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))
		|		ИНАЧЕ ВложенныйЗапрос.Номенклатура.Наименование
		|	КОНЕЦ
		|
		|ИМЕЮЩИЕ
		|	(СУММА(ВложенныйЗапрос.КоличествоУпаковок) > 0
		|		ИЛИ СУММА(ВложенныйЗапрос.Сумма) > 0)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТабличнаяЧастьЛечение.Номенклатура,
		|	ТабличнаяЧастьЛечение.Цена,
		|	ТабличнаяЧастьЛечение.СтавкаНДС,
		|	ТабличнаяЧастьЛечение.Количество,
		|	ТабличнаяЧастьЛечение.СуммаНДС,
		|	ТабличнаяЧастьЛечение.Сумма,
		|	ТабличнаяЧастьЛечение.Упаковка,
		|	NULL,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(ТабличнаяЧастьЛечение.Номенклатура.НаименованиеПолное КАК СТРОКА(150))) <> """"
		|			ТОГДА ВЫРАЗИТЬ(ТабличнаяЧастьЛечение.Номенклатура.НаименованиеПолное КАК СТРОКА(150))
		|		ИНАЧЕ ТабличнаяЧастьЛечение.Номенклатура.Наименование
		|	КОНЕЦ
		|ИЗ
		|	&ИмяТаблицы КАК ТабличнаяЧастьЛечение
		|ГДЕ
		|	ТабличнаяЧастьЛечение.Ссылка = &Ссылка
		|	И НЕ ТИПЗНАЧЕНИЯ(&Ссылка) = ТИП(Документ.Прием)";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяТаблицы", "Документ." + ДокументОснования.Метаданные().Имя + ".Лечение");
		
		МассивОбъединениеЗапросов.Добавить(ТекстЗапроса); 		
		
	КонецЕсли;
	
	Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы", ДокументОснования.Метаданные()) = Истина Тогда
		
