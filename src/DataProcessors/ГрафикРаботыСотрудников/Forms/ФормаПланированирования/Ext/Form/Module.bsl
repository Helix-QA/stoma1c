&НаСервере
// Процедура дополнения буфера новыми данными планирования
// 
Процедура ДополнитьБуферНовымиДаннымиПланирования(ТаблицаРезПланирования)
	
	Сотрудник				= Неопределено;
	МассивИзмененныхДней	= Новый Массив;
	 
	// Заполняем буфер новыми данными
	НомерОперации = НомерПоследнейОперацииВОчередиБуфераНаСервере() + 1;
	Для Каждого СтрокаРЗ ИЗ ТаблицаРезПланирования Цикл
		
		Сотрудник		= СтрокаРЗ.Сотрудник;			
		ФлагПроверки	= Истина;
		
		// проверем список периодов на пересечение по времени
		Если СтрокаРЗ.ИнтервалыРаботы.Количество() > 0 Тогда
			ПервыйПериодВСписке = СтрокаРЗ.ИнтервалыРаботы[0].Значение;
			Для Каждого ИнтервалСписка ИЗ СтрокаРЗ.ИнтервалыРаботы Цикл
				Если СтрокаРЗ.ИнтервалыРаботы.Индекс(ИнтервалСписка) = 0 Тогда
					Продолжить;
				КонецЕсли;    				
				
				// приоритет отдан этому механизму выявления пересечения периодов
				Если Макс(ПервыйПериодВСписке.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы) < Мин(ПервыйПериодВСписке.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Обнаружено пересечение времени: с " + Формат(Макс(ПервыйПериодВСписке.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы), "ДФ=HH:mm") + " по " + Формат(Мин(ПервыйПериодВСписке.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы), "ДФ=HH:mm"), ЭтотОбъект);
					ФлагПроверки = Ложь;	
					Прервать;
				КонецЕсли;   				
			КонецЦикла;	
		КонецЕсли;
		
		// проверка на дату увольнения и дату приема
		МассивДатыПриемаУвольнения = ТаблицаСотрудниковДатыПриемаУвольнения.НайтиСтроки(Новый Структура("Сотрудник", Сотрудник));
		Если МассивДатыПриемаУвольнения.Количество() > 0 Тогда
			СтрокаМассиваДатыПриемаУвольнения = МассивДатыПриемаУвольнения[0];
			Если НЕ (ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема) и СтрокаМассиваДатыПриемаУвольнения.ДатаПриема <= СтрокаРЗ.Дата или НЕ ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема)) Тогда
				
				ФлагПроверки = Ложь;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка задания периодов работы: " + Строка(Формат(СтрокаРЗ.Дата,"ДЛФ=ДД.ММ.ГГ"))+" "+Строка(ОтборСтруктурнаяЕдиница)+" сотрудник " + Строка(Сотрудник) + " еще не принят на работу."
				+?(ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема),"Дата приема на работу "+Строка(Формат(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема,"ДЛФ=ДД.ММ.ГГ")),"")
				);
				
			КонецЕсли;   			
			
			Если  НЕ (ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения) и СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения >= СтрокаРЗ.Дата  или НЕ ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения))  Тогда 
				
				ФлагПроверки = Ложь;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка задания периодов работы: " + Строка(Формат(СтрокаРЗ.Дата,"ДЛФ=ДД.ММ.ГГ"))+" "+Строка(ОтборСтруктурнаяЕдиница)+" сотрудник " + Строка(Сотрудник) + " уже уволен."
				+?(ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения),", дата увольнения "+Строка(Формат(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения,"ДЛФ=ДД.ММ.ГГ")),"") );
				
			КонецЕсли;		
		КонецЕсли;
		
		// Проверка на наличие приемов
		ПриемыВходятВИнтервалыРабот = ПроверитьПриемыВходятВИнтервалыРабот(Сотрудник, СтрокаРЗ.Дата, ОтборСтруктурнаяЕдиница, СтрокаРЗ.ИнтервалыРаботы);   			
		Если Не ПриемыВходятВИнтервалыРабот Тогда 
			ФлагПроверки = Ложь;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У сотрудника " + Сотрудник + " " + Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ")+ " запланированы приемы, не входящие в выбранные смены.");			
		КонецЕсли;
		
		// Проверяем на работу структурой единицы в выбранный интервал
		ВремяРаботыСтруктурнойЕдиницыДень = ВернутьВремяРаботыСтруктурнойЕдиницыПоДате(СтрокаРЗ.Дата,ОтборСтруктурнаяЕдиница);
		
		Если ВремяРаботыСтруктурнойЕдиницыДень <> неопределено Тогда
			
			// Если интервал начало или конец выходит за рамки работы структурной единицы то 
			Для Каждого Интервал из СтрокаРЗ.ИнтервалыРаботы Цикл	
				
				// Корректируем интервал начало или конец если он выходит за рамки работы структурной 
				Если Интервал.Значение.НачалоРаботы    < ВремяРаботыСтруктурнойЕдиницыДень.НачалоРаботы Тогда
					Интервал.Значение.НачалоРаботы = ВремяРаботыСтруктурнойЕдиницыДень.НачалоРаботы;
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Скорректировано время начала работы на "+ Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ") + " по времени работы клиники.");
				КонецЕсли;
				
				Если Интервал.Значение.ОкончаниеРаботы > ВремяРаботыСтруктурнойЕдиницыДень.ОкончаниеРаботы Тогда
					Интервал.Значение.ОкончаниеРаботы =  ВремяРаботыСтруктурнойЕдиницыДень.ОкончаниеРаботы ;
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Скорректировано время окончания работы на "+ Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ") + " по времени работы клиники.");
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			
			ФлагПроверки = Ложь;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Клиника не работает "+ Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ"));
			
		КонецЕсли;

		
		Если СтрокаРЗ.Свойство("ТипРабочегоВремени")
			И СтрокаРЗ.ТипРабочегоВремени <> Перечисления.ТипыРабочегоВремени.Больничный 
			И СтрокаРЗ.ТипРабочегоВремени <> Перечисления.ТипыРабочегоВремени.Отпуск Тогда
			
			// Проверка на работу сотрудника в этот период в другом салоне
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ВремяНачала,
			|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ВремяОкончания
			|ИЗ
			|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
			|ГДЕ
			|	ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
			|	И ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница
			|	И НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) = &Дата";
			
			Запрос.УстановитьПараметр("Дата"				, СтрокаРЗ.Дата);
			Запрос.УстановитьПараметр("Сотрудник"			, Сотрудник);
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
			
			Результат = Запрос.Выполнить().Выгрузить();
			
			Для Каждого СтрокаТЧ Из Результат Цикл
				Для Каждого СтрокаПериода из СтрокаРЗ.ИнтервалыРаботы Цикл
					СтрокаПериодаВремяНачала 	= СтрокаРЗ.Дата + (СтрокаПериода.Значение.НачалоРаботы - Дата(01, 01, 01));
					СтрокаПериодаВремяОкончания = СтрокаРЗ.Дата + (СтрокаПериода.Значение.ОкончаниеРаботы - Дата(01, 01, 01));
					Если (СтрокаПериодаВремяОкончания - СтрокаТЧ.ВремяНачала)*(СтрокаТЧ.ВремяОкончания - СтрокаПериодаВремяНачала) > 0 Тогда 
						ФлагПроверки = Ложь;
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сотрудник " + Сотрудник + " уже работает в этот период в другой клинике!");
						Прервать;           
					КонецЕсли;
				КонецЦикла;		
			КонецЦикла;     
			
		КонецЕсли;

		Если ФлагПроверки Тогда
			Если МассивИзмененныхДней.Найти(СтрокаРЗ.Дата) = Неопределено Тогда
				МассивИзмененныхДней.Добавить(СтрокаРЗ.Дата);
			КонецЕсли;
			
			Если ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный Тогда
				 ИнтервалыРаботыПредст = "Б";
			ИначеЕсли ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск Тогда
                 ИнтервалыРаботыПредст = "О";
			Иначе
			     ИнтервалыРаботыПредст = Обработки.ГрафикРаботыСотрудников.ПолучитьПредставлениеСпискаИнтервалов(СтрокаРЗ.ИнтервалыРаботы);
			КонецЕсли;
			 
			// Ищем существующее рабочее время на указанную дату
			НайденныеСтроки = БуферФормирования.НайтиСтроки(Новый Структура("Дата, Сотрудник", СтрокаРЗ.Дата, СтрокаРЗ.Сотрудник));
			Для Каждого СтрокаБуфера ИЗ НайденныеСтроки Цикл
				// Если найден существующий интервал, помечаем его на удаление 
				// и скрываем для отображения
				Если НЕ ЗначениеЗаполнено(СтрокаБуфера.Операция) Тогда
					СтрокаБуфера.Операция              = "Удалить";
					СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
					СтрокаБуфера.Скрыть                = Истина;
					// Если найден новый интервал, просто удаляем его, он будет заменен	
				ИначеЕсли СтрокаБуфера.Операция = "Создать" Тогда
					БуферФормирования.Удалить(СтрокаБуфера);
				КонецЕсли;
			КонецЦикла;
			
			НоваяСтрока                       = БуферФормирования.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРЗ);
			НоваяСтрока.ИнтервалыРаботыПредст = ИнтервалыРаботыПредст;
			НоваяСтрока.Должность             = НоваяСтрока.Сотрудник.Должность; 
			НоваяСтрока.ИдентификаторОбласти  = Новый УникальныйИдентификатор;
			НоваяСтрока.Операция              = "Создать";
			НоваяСтрока.НомерОчередиОперации  = НомерОперации;
		КонецЕсли;
		
	КонецЦикла;
	
	// Обновить визуализацию плана занятий
	ОбновитьОтображениеПланирования(Ложь, Сотрудник, МассивИзмененныхДней);

КонецПроцедуры

&НаКлиенте
// Вернет номер последней операции в очереди буфера
// 
Функция НомерПоследнейОперацииВОчередиБуфера()
	
	НомерОчередиОперации = 0;
	Для Каждого СтрокаТ ИЗ БуферФормирования Цикл
		Если СтрокаТ.НомерОчередиОперации > НомерОчередиОперации Тогда
			НомерОчередиОперации = СтрокаТ.НомерОчередиОперации;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат НомерОчередиОперации;
	
КонецФункции

&НаСервере
// Вернет номер последней операции в очереди буфера
// 
Функция НомерПоследнейОперацииВОчередиБуфераНаСервере()
	
	НомерОчередиОперации = 0;
	Для Каждого СтрокаТ ИЗ БуферФормирования Цикл
		Если СтрокаТ.НомерОчередиОперации > НомерОчередиОперации Тогда
			НомерОчередиОперации = СтрокаТ.НомерОчередиОперации;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат НомерОчередиОперации;
	
КонецФункции

&НаКлиенте
// Процедура - Обновить декорацию упраления сохранением шаблонов
// 
Процедура ОбновитьДекорациюУпраленияСохранениемШаблонов()
	
	Если СписокШаблоновСодержитСтруктуруИнтервалов().Успех Тогда 
		Элементы.ДекорацияУправленияСохранениемШаблонов.Картинка = БиблиотекаКартинок.РейтингЗвездаЗаполненная;
		Элементы.ДекорацияУправленияСохранениемШаблонов.Подсказка = "Удалить из списка шаблонов";
	Иначе 
		Элементы.ДекорацияУправленияСохранениемШаблонов.Картинка = БиблиотекаКартинок.РейтингЗвездаПустая;
		Элементы.ДекорацияУправленияСохранениемШаблонов.Подсказка = "Сохранить как шаблон в список";		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ФиксацияИзмененийВПлане

&НаКлиенте
// Функция вернет признак необходимости фиксации изменений в плане
// 
Функция ПроверитьНеобходимостьФиксацииИзмененийВПлане()
	
	СоздатьЗанятия  = БуферФормирования.НайтиСтроки(Новый Структура("Операция","Создать"));
	УдалитьЗанятия  = БуферФормирования.НайтиСтроки(Новый Структура("Операция","Удалить"));
	
	Возврат СоздатьЗанятия.Количество() > 0 ИЛИ УдалитьЗанятия.Количество() > 0;
	
КонецФункции

&НаСервере
// Зафиксировать изменения
// 
Процедура ЗафиксироватьИзмененияВПланеЗанятий()
	
	РегистрыСведений.ВремяРаботыСотрудниковПлан.ЗафиксироватьИзмененияВГрафикеСотрудников(ЭтотОбъект.ОтборСтруктурнаяЕдиница, ЭтотОбъект.БуферФормирования);
	ОбновитьОтображениеПланирования(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ДополнительныеПроцедурыИФункции

// Процедура, формирует текст периода.
// 
Процедура СформироватьТекстПериода()
	
	КомандаВыбораПериода = Команды.Найти("ВыбратьПериодПланирования");
	
	Если ОтборПериод.ДатаНачала = Дата(1,1,1) ИЛИ ОтборПериод.ДатаОкончания = Дата(1,1,1) Тогда 
		Элементы.ВыбратьПериодПланирования.Заголовок = "< не указан >";
		Если НЕ КомандаВыбораПериода = Неопределено Тогда 
			КомандаВыбораПериода.Подсказка = "Щелкните для выбора периода планирования";
		КонецЕсли;	
	Иначе
		Элементы.ВыбратьПериодПланирования.Заголовок = Формат(ОтборПериод.ДатаНачала, "ДФ=dd.MM.yy") + " - " + Формат(ОтборПериод.ДатаОкончания, "ДФ=dd.MM.yy");
		Если НЕ КомандаВыбораПериода = Неопределено Тогда 
			КомандаВыбораПериода.Подсказка = Элементы.ВыбратьПериодПланирования.Заголовок;
		КонецЕсли;			
	КонецЕсли;	
	
КонецПроцедуры

// Процедура, обновляет таблицу значений ГрафикПериодовРаботыТабДок согласно БуфераФормирования.
//  
Процедура ОбновитьСогласноБуфераФормирования(ПерезаполнитьБуфер, Сотрудник = Неопределено, МассивИзменныхДней = Неопределено)
	
	// очищаем строки таблицы
	Если ПерезаполнитьБуфер Тогда
		
		// табличный документ
		// ШАПКА
		ГрафикПериодовРаботыТабДок.Очистить();
		Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("ГрафикПериодовРаботы");
		ОбластьШапкаТаблицы_Заголовок	= Макет.ПолучитьОбласть("ШапкаТаблицы|Заголовок");
		ОбластьШапкаТаблицы_Период		= Макет.ПолучитьОбласть("ШапкаТаблицы|Период");
		ОбластьСтрока_Заголовок			= Макет.ПолучитьОбласть("Строка|Заголовок");
		ОбластьСтрока_Период			= Макет.ПолучитьОбласть("Строка|Период");
		
		ГрафикПериодовРаботыТабДок.Вывести(ОбластьШапкаТаблицы_Заголовок);
		ДатаПром = НачалоДня (ОтборПериод.ДатаНачала);
		Пока ДатаПром <= НачалоДня(ОтборПериод.ДатаОкончания) Цикл
			ОбластьШапкаТаблицы_Период.параметры.Период = Формат(ДатаПром,"ДФ=dd.MM.yy")+символы.ПС+ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьДеньНедели(ДеньНедели(ДатаПром));	
			ГрафикПериодовРаботыТабДок.Присоединить(ОбластьШапкаТаблицы_Период);
			
			Если ДеньНедели(ДатаПром) = 6 Или ДеньНедели(ДатаПром) = 7 Тогда
				ГрафикПериодовРаботыТабДок.Область("R1C"+СтрЗаменить(4+1+(НачалоДня(ДатаПром)-НачалоДня(ОтборПериод.ДатаНачала))/(24*60*60), Символы.НПП, "")).ЦветФона = Новый Цвет(255, 192, 203);
			Иначе
				//ГрафикПериодовРаботыТабДок.Область("R1C"+СтрЗаменить(4+1+(НачалоДня(ДатаПром)-НачалоДня(ОтборПериод.ДатаНачала))/(24*60*60), Символы.НПП, "")).ЦветФона = Новый Цвет(242, 242, 242);
			КонецЕсли;
			
			ДатаПром = ДатаПром + 24*60*60;
		КонецЦикла;
		
		ГрафикПериодовРаботыТабДок.ФиксацияСлева	= 4;
		ГрафикПериодовРаботыТабДок.ФиксацияСверху	= 1;
		
		// Сначала получаем список сотруников согласно справочника сотрудники.
		// Т.к. в буфере хранятся только уже заданные в регистре сведений 	
		Запрос = новый ЗАпрос;
		ЗАпрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	ВЫБОР
		|		КОГДА Сотрудники.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
		|			ТОГДА ""Без должности""
		|		ИНАЧЕ Сотрудники.Должность
		|	КОНЕЦ КАК Должность,
		|	НастройкиСотрудников.ДатаПриема КАК ДатаПриема,
		|	НастройкиСотрудников.ДатаУвольнения КАК ДатаУвольнения
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		|		ПО Сотрудники.Ссылка = НастройкиСотрудников.Сотрудник
		|ГДЕ
		|	НЕ Сотрудники.ЭтоГруппа
		|	И НЕ Сотрудники.ПометкаУдаления
		|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ВЫБОР
		|			КОГДА &ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 31, 23, 59, 59)
		|					И НастройкиСотрудников.ДатаПриема <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА НастройкиСотрудников.ДатаПриема <= &ДатаОкончания
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА &ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
		|					И НастройкиСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА НастройкиСотрудников.ДатаУвольнения >= &ДатаНачала
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Должность";  
		
				
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ДатаНачала"			, ОтборПериод.ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания"		, ОтборПериод.ДатаОкончания); 		
		
		ТаблицаСотрудников = Запрос.Выполнить().Выгрузить(); 
		
		// сохраняем в элементах формы для дальнейшенго контроля
		ТаблицаСотрудниковДатыПриемаУвольнения.Очистить(); 		
		
		КолВыведенныхСтрок = 2; // начинаем с 2 , т.к. первая строка это заголовок		
		Для Каждого СтрокаПериодРаботы Из ТаблицаСотрудников Цикл
						
			НоваяСтрокаТаблицыСотрудниковДатыПриемаУвольнения = ТаблицаСотрудниковДатыПриемаУвольнения.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицыСотрудниковДатыПриемаУвольнения, СтрокаПериодРаботы);
			
			ОбластьСтрока_Заголовок.Параметры.Заполнить(СтрокаПериодРаботы);
			ОбластьСтрока_Заголовок.Параметры.ИД_Сотрудника = СтрокаПериодРаботы.Сотрудник.УникальныйИдентификатор();
			
			ГрафикПериодовРаботыТабДок.Вывести(ОбластьСтрока_Заголовок);	
			
			ДатаПром = НачалоДня(ОтборПериод.ДатаНачала);
			Пока ДатаПром <= НачалоДня(ОтборПериод.ДатаОкончания) Цикл
				ОбластьСтрока_Период.параметры.Период = "";	
				ГрафикПериодовРаботыТабДок.Присоединить(ОбластьСтрока_Период);
				
				НомерКолонкиОбластиТабДок = (НачалоДня(ДатаПром) - НачалоДня(ОтборПериод.ДатаНачала))/(24*60*60);
				
				Если ДеньНедели(ДатаПром) = 6 Или ДеньНедели(ДатаПром) = 7 Тогда 
					ИмяОбластиТабДок = СтрЗаменить("R" + КолВыведенныхСтрок + "C" + (5 + НомерКолонкиОбластиТабДок) + ":" + "R" + (КолВыведенныхСтрок + 1) + "C" + (5 + НомерКолонкиОбластиТабДок), Символы.НПП, ""); 
					ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(255, 192, 203);
				Иначе
					ИмяОбластиТабДок = СтрЗаменить("R" + КолВыведенныхСтрок + "C" + (5 + НомерКолонкиОбластиТабДок) + ":" + "R" + (КолВыведенныхСтрок + 1) + "C" + (5 + НомерКолонкиОбластиТабДок), Символы.НПП, "");
					ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет;
				КонецЕсли;   
				
				Если (ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаУвольнения) и ДатаПром > СтрокаПериодРаботы.ДатаУвольнения)
					или (ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаПриема) и ДатаПром < СтрокаПериодРаботы.ДатаПриема) Тогда // сотрудник уволен или еще не принят
					ИмяОбластиТабДок = СтрЗаменить("R" + КолВыведенныхСтрок + "C" + (5 + НомерКолонкиОбластиТабДок) + ":" + "R" + (КолВыведенныхСтрок + 1) + "C" + (5 + НомерКолонкиОбластиТабДок), Символы.НПП, "");
					ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(242,242,242);
				КонецЕсли;    						
				
				ДатаПром = ДатаПром + 24*60*60;
			КонецЦикла; 
			
			КолВыведенныхСтрок = КолВыведенныхСтрок + 2; // высота области 2 строки
		КонецЦикла;
		
	КонецЕсли;   
	
	// массив сотрудников
	МассивСотрудников = Новый Массив;
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		МассивСотрудников.Добавить(Сотрудник);
	Иначе
		ВременнаяТаблица = БуферФормирования.Выгрузить(,"Сотрудник");
		ВременнаяТаблица.Свернуть("Сотрудник");
		МассивСотрудников = ВременнаяТаблица.ВыгрузитьКолонку("Сотрудник");	
	КонецЕсли;
	
	ФлагСотрудникЕстьБуфере = Ложь;
	Для Каждого СотрудникМ Из МассивСотрудников Цикл
		
		Если ЗначениеЗаполнено(Сотрудник) и СотрудникМ <> Сотрудник Тогда
			Продолжить;
		КонецЕсли;
		
		МассивСтрокПериодыРаботы	= ТаблицаСотрудниковДатыПриемаУвольнения.НайтиСтроки(Новый Структура("Сотрудник", СотрудникМ));
		СтрокаПериодРаботы			= ?(МассивСтрокПериодыРаботы.Количество() > 0, МассивСтрокПериодыРаботы[0], Неопределено);
		
		ФлагСотрудникЕстьБуфере		= Истина;
		
		НомерСтрокиТабДок			= ПолучитьНомерСтрокиТабДок(СотрудникМ);
		
		// периоды
		МассивПериодовСотрудника = БуферФормирования.НайтиСтроки(Новый Структура("Сотрудник", СотрудникМ));
		
		Если Не ЗначениеЗаполнено(МассивИзменныхДней) Или (Тип(МассивИзменныхДней) = Тип("Массив") и МассивИзменныхДней.Количество() = 0) Тогда
			ДатаПром = НачалоДня(ОтборПериод.ДатаНачала);
			Пока ДатаПром <= КонецДня(ОтборПериод.ДатаОкончания) Цикл
				
				ИмяОбластиТабДок = ПолучитьИмяОбластиТабДокПоНомеруСтроки(НомерСтрокиТабДок, ДатаПром); // ПолучитьИмяОбластиТабДок(СтрокаБуфера.Сотрудник, ДатаПром);
				Если НЕ ПустаяСтрока(ИмяОбластиТабДок) Тогда
					ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).Текст = "";
					
					МассивБуфера = БуферФормирования.НайтиСтроки(Новый Структура("Сотрудник, Дата",СотрудникМ, НачалоДня(ДатаПром))); // БуферФормирования
					Если МассивБуфера.Количество() > 0 Тогда
						СтрокаПериодов = "";
						Для Каждого СтрокаМассивБуфера Из МассивБуфера Цикл
							Если СтрокаМассивБуфера.Операция = "" Или СтрокаМассивБуфера.Операция = "Создать" Тогда
								
								Если СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный 
									Или СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск Тогда 
									СтрокаПериодов = СтрокаМассивБуфера.ИнтервалыРаботыПредст;
								Иначе
									
									Для Каждого Период Из СтрокаМассивБуфера.ИнтервалыРаботы Цикл
										СтрокаПериодов = СтрокаПериодов 
										+ ?(ПустаяСтрока(СтрокаПериодов),"",Символы.ПС)
										+ Строка(Формат(Период.Значение.НачалоРаботы, "ДФ='ЧЧ:мм'") + " - " + Формат(Период.Значение.ОкончаниеРаботы, "ДФ='ЧЧ:мм'"))+?(СтрокаМассивБуфера.Операция="","","*");
									КонецЦикла;
									
								КонецЕсли;
								
							КонецЕсли;
							
							ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).Текст   =  СтрокаПериодов;
							Если ((СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный
								Или СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск)
								И СтрокаМассивБуфера.Операция <> "Удалить") Тогда
								
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(164, 209, 251);
								
							ИначеЕсли ДеньНедели(ДатаПром) = 6 Или ДеньНедели(ДатаПром) = 7 Тогда 
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(255, 192, 203);
								
							ИначеЕсли СтрокаПериодРаботы <> Неопределено 
								И ((ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаУвольнения) и ДатаПром > СтрокаПериодРаботы.ДатаУвольнения)
								или (ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаПриема) и ДатаПром < СтрокаПериодРаботы.ДатаПриема)) Тогда // сотрудник уволен или еще не принят
								
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(242,242,242);
							Иначе
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет;
							КонецЕсли;
							
						КонецЦикла;
					КонецЕсли;
				КонецЕсли;
				Датапром = ДатаПром + 24*60*60;		
				
			КонецЦикла;
		ИначеЕсли Тип(МассивИзменныхДней)=Тип("Массив") Тогда
			
			// отрисовываем только переданные дни
			Для каждого ДеньИзменений из МассивИзменныхДней Цикл
				
				ИмяОбластиТабДок = ПолучитьИмяОбластиТабДок(СотрудникМ, ДеньИзменений); // СтрокаБуфера.Сотрудник
				Если НЕ ПустаяСтрока(ИмяОбластиТабДок) Тогда
					ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).Текст = "";
					
					МассивБуфера = БуферФормирования.НайтиСтроки(Новый Структура ("Сотрудник, Дата", СотрудникМ, НачалоДня(ДеньИзменений))); // СтрокаБуфера.Сотрудник
					Если МассивБуфера.количество()>0 Тогда
						СтрокаПериодов = "";
						Для каждого СтрокаМассивБуфера из МассивБуфера Цикл
							Если СтрокаМассивБуфера.Операция = "" или СтрокаМассивБуфера.Операция = "Создать" Тогда
								
								Если СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный 
									Или СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск Тогда
									СтрокаПериодов = СтрокаМассивБуфера.ИнтервалыРаботыПредст;
								Иначе
									
									Для каждого Период из СтрокаМассивБуфера.ИнтервалыРаботы Цикл
										СтрокаПериодов = СтрокаПериодов
										+ ?(ПустаяСтрока(СтрокаПериодов),"",Символы.ПС)
										+ Строка(Формат(Период.Значение.НачалоРаботы, "ДФ='ЧЧ:мм'") + " - " + Формат(Период.Значение.ОкончаниеРаботы, "ДФ='ЧЧ:мм'"))+?(СтрокаМассивБуфера.Операция="","","*");
									КонецЦикла;
								КонецЕсли;
								
							КонецЕсли;
							
							ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).Текст = СтрокаПериодов;
							Если ((СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный
								Или СтрокаМассивБуфера.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск)
								И СтрокаМассивБуфера.Операция <> "Удалить") Тогда
								
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(164, 209, 251);
							ИначеЕсли ДеньНедели(ДеньИзменений) = 6 Или ДеньНедели(ДеньИзменений) = 7 Тогда 
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет(255, 192, 203);
							Иначе
								ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).ЦветФона = Новый Цвет;
							КонецЕсли;
							
						КонецЦикла;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
			Прервать; // прерывам чтобы выйти из цикла перебора буфера
		КонецЕсли;
		
	КонецЦикла;     
	
	// в случае отсутствия сотрудников в буфере
	Если НЕ ФлагСотрудникЕстьБуфере и ГрафикПериодовРаботыТабДок.ВысотаТаблицы > 1 Тогда
		
		НомерСтрокиТабДок = 2;// 1 строка это заголовок  таблицы		
		Пока НомерСтрокиТабДок <= ГрафикПериодовРаботыТабДок.ВысотаТаблицы Цикл
			Сотрудник = НайтиСотрудникаПоИД(ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтрокиТабДок,символы.НПП,"")+"C2").Текст);
			// периоды
			Если Не ЗначениеЗаполнено(МассивИзменныхДней) или (Тип(МассивИзменныхДней)=Тип("Массив") и МассивИзменныхДней.Количество() = 0) Тогда
				
				ДатаПром = НачалоДня(ОтборПериод.ДатаНачала);
				Пока ДатаПром <= КонецДня(ОтборПериод.ДатаОкончания) Цикл
					НайденныеСтроки = БуферФормирования.НайтиСтроки(Новый Структура("Сотрудник, Дата", Сотрудник, ДатаПром));   
					Если НайденныеСтроки = Неопределено Тогда
						НомерКолонкиТабДок	= ПолучитьИмяКолонкиТабДок(ДатаПром);
						ИмяОбластиТабДок	= СтрЗаменить("R"+Строка(НомерСтрокиТабДок)+"C"+Строка(НомерКолонкиТабДок)+":"+"R"+Строка(НомерСтрокиТабДок+1)+"C"+Строка(НомерКолонкиТабДок),Символы.НПП,""); 
						ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).Текст = "";
					КонецЕсли;
					
					Датапром = ДатаПром + 24*60*60;		
					
				КонецЦикла;
			ИначеЕсли Тип(МассивИзменныхДней) = Тип("Массив") Тогда
				
				// отрисовываем только переданные дни
				Для Каждого ДеньИзменений из МассивИзменныхДней Цикл
					
					НайденныеСтроки = БуферФормирования.НайтиСтроки(Новый Структура("Сотрудник, Дата", Сотрудник, ДеньИзменений));   
					Если НайденныеСтроки = Неопределено Тогда
						НомерКолонкиТабДок	= ПолучитьИмяКолонкиТабДок(ДеньИзменений);
						ИмяОбластиТабДок	= СтрЗаменить("R"+Строка(НомерСтрокиТабДок)+"C"+Строка(НомерКолонкиТабДок)+":"+"R"+Строка(НомерСтрокиТабДок)+"C"+Строка(НомерКолонкиТабДок),Символы.НПП,""); 
						
						ГрафикПериодовРаботыТабДок.Область(ИмяОбластиТабДок).Текст = "";
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			НомерСтрокиТабДок = НомерСтрокиТабДок + 2;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры   

// Процедура, заполняет буфер существующими записями.
// 
Процедура ЗаполнитьБуферСуществующимиДанными()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
	|	ВремяРаботыСотрудниковПлан.Сотрудник.Должность КАК Должность,
	|	ВремяРаботыСотрудниковПлан.Минуты КАК СуммаРабочегоВремени,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК Дата,
	|	ВремяРаботыСотрудниковПлан.ТипРабочегоВремени КАК ТипРабочегоВремени
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО ВремяРаботыСотрудниковПлан.Сотрудник.Ссылка = НастройкиСотрудников.Сотрудник.Ссылка
	|ГДЕ
	|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяНачала >= &НачалоПериода
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяНачала <= &ОкончаниеПериода
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВремяРаботыСотрудниковПлан.МесяцОтбор,
	|	Сотрудник,
	|	Должность,
	|	ДатаВремяНачала"
	);
	
	Запрос.УстановитьПараметр("НачалоПериода"      , НачалоДня(ОтборПериод.ДатаНачала));
	Запрос.УстановитьПараметр("ОкончаниеПериода"   , КонецДня(ОтборПериод.ДатаОкончания));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница" , ОтборСтруктурнаяЕдиница);
	
	//СписокРолейПользователя = Новый СписокЗначений;
	//СписокРолейПользователя.Добавить(Перечисления.РольПользователя.АдминистраторБазыДанных);
	//СписокРолейПользователя.Добавить(Перечисления.РольПользователя.ПустаяСсылка());
	
	//Запрос.УстановитьПараметр("СписокРолейПользователя" , СписокРолейПользователя);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	БуферФормирования.Очистить();
	ТекДень            = Неопределено;
	ПредДень           = Неопределено;
	ТекСтрокаБуфера    = Неопределено;
	ПредСтрокаБуфера   = Неопределено;
	ПредставлениеИнтервала = "";
	
	Пока Выборка.Следующий() Цикл
		// Получаем дату тек. дня
		Если ЗначениеЗаполнено(Выборка.ДатаВремяНачала) Тогда
			ТекДень = День(Выборка.ДатаВремяНачала);
			// Если тек дата не совпадает или указанные параметры
			// создаем новую строку буфера, иначе считаем что это след. интервал в тот же день
			Если ТекДень <> ПредДень
				ИЛИ ТекСтрокаБуфера = Неопределено 
				ИЛИ ТекСтрокаБуфера.Сотрудник <> Выборка.Сотрудник
				ИЛИ ТекСтрокаБуфера.Должность <> Выборка.Должность Тогда
				
				ТекСтрокаБуфера = БуферФормирования.Добавить();
				ЗаполнитьЗначенияСвойств(ТекСтрокаБуфера, Выборка);
				ТекСтрокаБуфера.ИдентификаторОбласти  = Новый УникальныйИдентификатор;
				// ТекСтрокаБуфера.Дата                  = Выборка.ДатаВремяНачала;
				// ТекСтрокаБуфера.СуммаРабочегоВремени  = Выборка.КолМинут;
			Иначе
				ТекСтрокаБуфера.СуммаРабочегоВремени = ТекСтрокаБуфера.СуммаРабочегоВремени + Выборка.СуммаРабочегоВремени;
			КонецЕсли;
			
			// Переменная оптимизации. Кеширует массив данных на время серверного вызова
			МассивНадстрочныхСимволов = Неопределено;
			ПериодРаботы              = Новый Структура("НачалоРаботы, ОкончаниеРаботы, ВсегоМинут", Выборка.ДатаВремяНачала
			, Выборка.ДатаВремяОкончания
			, Выборка.СуммаРабочегоВремени);	
			
			НачалоПредст              = Формат(ПериодРаботы.НачалоРаботы	, "ДФ=HH:mm"); // Обработки.ПланированиеГрафикаРаботыСотрудников.ПредставлениеВремениСНадстрочнымиСимволами(ПериодРаботы.НачалоРаботы, МассивНадстрочныхСимволов);
			КонецПредст               = Формат(ПериодРаботы.ОкончаниеРаботы	, "ДФ=HH:mm"); // Обработки.ПланированиеГрафикаРаботыСотрудников.ПредставлениеВремениСНадстрочнымиСимволами(ПериодРаботы.ОкончаниеРаботы, МассивНадстрочныхСимволов);
			
			Если Выборка.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный Тогда
				ТекСтрокаБуфера.ИнтервалыРаботыПредст = "Б";
			ИначеЕсли Выборка.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск Тогда
				ТекСтрокаБуфера.ИнтервалыРаботыПредст = "О";
			Иначе	
				ВремяИнтервала 			= ?(Выборка.СуммаРабочегоВремени > 60, Строка(ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьМинутыВЧасы(Выборка.СуммаРабочегоВремени)), Строка(Выборка.СуммаРабочегоВремени) + " мин.");
				
				ПредставлениеИнтервала = НачалоПредст + " - " + КонецПредст + " (" + ВремяИнтервала + ")";
				ТекСтрокаБуфера.ИнтервалыРаботы.Добавить(ПериодРаботы, ПредставлениеИнтервала);
				// ТекСтрокаБуфера.ИнтервалыРаботыПредст = Обработки.ПланированиеГрафикаРаботыСотрудников.ПолучитьПредставлениеСпискаИнтервалов(ТекСтрокаБуфера.ИнтервалыРаботы);
			КонецЕсли;
			ПредДень         = ТекДень;
			ПредСтрокаБуфера = ТекСтрокаБуфера;	
			ТекСтрокаБуфера.ТипРабочегоВремени = Выборка.ТипРабочегоВремени;
			
		КонецЕсли;
	КонецЦикла;	 
	
КонецПроцедуры

// Функция, возвращает номер строки табличного документа.
// 
Функция ПолучитьНомерСтрокиТабДок(Сотрудник)  
	
	Область		= ГрафикПериодовРаботыТабДок.НайтиТекст(Сотрудник.УникальныйИдентификатор(),, ГрафикПериодовРаботыТабДок.Область("C2"));
	Если Область <> Неопределено Тогда
		ИмяОбласти	= Область.Имя; 
		Позиция_Двоеточие = СтрНайти(ИмяОбласти,"C");
		
		НомерСтроки = Число(Сред(ИмяОбласти,2,Позиция_Двоеточие-2));
	Иначе
		НомерСтроки = Неопределено;
	КонецЕсли;
	 		
	Возврат НомерСтроки;
	
КонецФункции

// Функция, возвращает имя области по номеру строки и дате табличного документа.
// 
Функция ПолучитьИмяОбластиТабДокПоНомеруСтроки(НомерСтроки, ДатаПром)  
			  	
	НомерКолонки = 5 + (ДатаПром - НачалоДня(ОтборПериод.ДатаНачала)) / 86400; 
	
	Если НомерСтроки <> Неопределено Тогда
		Имя = "R" + СтрЗаменить(НомерСтроки,символы.НПП,"") + "C" + СтрЗаменить(НомерКолонки,символы.НПП,"") + ":"
		    + "R" + СтрЗаменить(НомерСтроки+1,символы.НПП,"") + "C" + СтрЗаменить(НомерКолонки,символы.НПП,""); 
	Иначе
		Имя = "";
	КонецЕсли;
	
	Возврат Имя;
	
КонецФункции

// Функция, возвращает имя области табличного документа.
// 
Функция ПолучитьИмяОбластиТабДок(Сотрудник, ДатаПром)  
	
	Область	= ГрафикПериодовРаботыТабДок.НайтиТекст(Сотрудник.УникальныйИдентификатор(),, ГрафикПериодовРаботыТабДок.Область("C2"));
	Если Область <> Неопределено Тогда
		ИмяОбласти	= Область.Имя; 
		Позиция_Двоеточие = СтрНайти(ИмяОбласти,"C");
		
		НомерСтроки = Число(Сред(ИмяОбласти,2,Позиция_Двоеточие-2));
	Иначе
		НомерСтроки = Неопределено;
	КонецЕсли;
	  	
	Область = ГрафикПериодовРаботыТабДок.НайтиТекст(Формат(ДатаПром,"ДФ=dd.MM.yy"),, ГрафикПериодовРаботыТабДок.Область("R1"));
	Если Область <> Неопределено Тогда
		ИмяОбласти = Область.Имя;
		Позиция_Двоеточие = СтрНайти(ИмяОбласти,"C");
		
		НомерКолонки = Сред(ИмяОбласти, Позиция_Двоеточие+1);
	Иначе
		НомерКолонки = Неопределено;
	КонецЕсли;
		
	Если НомерКолонки <> Неопределено и НомерСтроки <> Неопределено Тогда
		Имя = "R" + СтрЗаменить(НомерСтроки,символы.НПП,"") + "C" + СтрЗаменить(НомерКолонки,символы.НПП,"") + ":"
		    + "R" + СтрЗаменить(НомерСтроки+1,символы.НПП,"") + "C" + СтрЗаменить(НомерКолонки,символы.НПП,""); 
	Иначе
		Имя = "";
	КонецЕсли;
	
	Возврат Имя;
	
КонецФункции

// Функция, возвращает имя колонки табличного документа.
// 
Функция ПолучитьИмяКолонкиТабДок(ДатаПром)
			
	Область = ГрафикПериодовРаботыТабДок.НайтиТекст(Формат(ДатаПром,"ДФ=dd.MM.yy"),, ГрафикПериодовРаботыТабДок.Область("R1"));
	Если Область <> Неопределено Тогда
		ИмяОбласти = Область.Имя;
		Позиция = СтрНайти(ИмяОбласти,"C");
		
		НомерКолонки = Сред(ИмяОбласти,Позиция+1);
	Иначе
		НомерКолонки = Неопределено;
	КонецЕсли;	
	
	Возврат НомерКолонки;
	
КонецФункции

