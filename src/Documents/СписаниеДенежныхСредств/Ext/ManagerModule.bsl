// Получить массив обязательных для заполнения реквизитов реквизитов  
//
Процедура ПолучитьМассивыОбязательныхРеквизитов(ДокументОбъект,МассивОбязательныхРеквизитов) Экспорт
	
	// ОБЯЗАТЕЛЬНЫЕ РЕКВИЗИТЫ ПО УМОЛЧАНИЮ
	МассивОбязательныхРеквизитов.Добавить("ТипДенежныхСредств");
	МассивОбязательныхРеквизитов.Добавить("ВидОперации");
	МассивОбязательныхРеквизитов.Добавить("СуммаДокумента");
	
	
	// ОБЯЗАТЕЛЬНЫЕ РЕКВИЗИТЫ В ЗАВИСИМОСТИ ОТ ТИПА ДЕН. СРЕДСТВ
	Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
		МассивОбязательныхРеквизитов.Добавить("Касса");
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		 
		МассивОбязательныхРеквизитов.Добавить("БанковскийСчет");
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда			
		МассивОбязательныхРеквизитов.Добавить("ЭквайрингТерминал");
		МассивОбязательныхРеквизитов.Добавить("ЭквайрингВидПлатежнойКарты");	
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
		МассивОбязательныхРеквизитов.Добавить("ЛицевойСчетКонтрагента");
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
		МассивОбязательныхРеквизитов.Добавить("Сертификат");
		Если ДокументОбъект.Сертификат.ИспользоватьПартии Тогда
			МассивОбязательныхРеквизитов.Добавить("СертификатСерийныйНомер");
		КонецЕсли; 
	КонецЕсли;
	
	// ОБЯЗАТЕЛЬНЫЕ РЕКВИЗИТЫ В ЗАВИСИМОСТИ ОТ ВИДА ОПЕРАЦИИ
	Если ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента Тогда	
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");	
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту
		ИЛИ ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту
		ИЛИ ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыСтраховойКомпании Тогда		
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");
		Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			МассивОбязательныхРеквизитов.Добавить("БанковскийСчетКонтрагента");			
		КонецЕсли;	
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику 
		ИЛИ ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВыдачаЗайма Тогда			
		МассивОбязательныхРеквизитов.Добавить("Контрагент");		
		Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			МассивОбязательныхРеквизитов.Добавить("БанковскийСчетКонтрагента");
		КонецЕсли;
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.СдачаНаличныхВБанк Тогда	
		МассивОбязательныхРеквизитов.Добавить("БанковскийСчетКонтрагента");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты Тогда			
		МассивОбязательныхРеквизитов.Добавить("ВыплатаЗПМесяц");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа");	
		Если ДокументОбъект.ВыплатаЗПРежимФормирования = 1 Тогда
			МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ДокументОснования");
		КонецЕсли;
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сотрудник");
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.Сумма");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета Тогда	
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
		МассивОбязательныхРеквизитов.Добавить("ЛицевойСчетКонтрагента");		
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику Тогда		
		МассивОбязательныхРеквизитов.Добавить("Контрагент");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ОплатаНалога Тогда
		МассивОбязательныхРеквизитов.Добавить("РасшифровкаПлатежа.ВидНалога");
	ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОпераций.ПрочееСписание Тогда
		МассивОбязательныхРеквизитов.Добавить("Затраты");
		МассивОбязательныхРеквизитов.Добавить("Затраты.СтатьяЗатрат");
	КонецЕсли;
КонецПроцедуры


