// Процедура, обработчик события "ПриИзменении"  поле ввода "Количество"
//
Процедура ЗапасыКоличествоУпаковокПриИзменении(Элемент)	
	
	СтрокаТабличнойЧасти = Элементы["Запасы"].ТекущиеДанные;
	
	Если СтрокаТабличнойЧасти.КоличествоУпаковок = 0 Тогда
		СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
	КонецЕсли;
	
	МаксимальноеКоличествоУпаковок = ПолучитьМаксимальноеКоличествоДляВозврата(Объект.ДокументОснования, СтрокаТабличнойЧасти.КлючСтроки, Истина, Объект.Ссылка);
	
	Если СтрокаТабличнойЧасти.КоличествоУпаковок > МаксимальноеКоличествоУпаковок Тогда
		СтрокаТабличнойЧасти.КоличествоУпаковок = МаксимальноеКоличествоУпаковок;
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти); 
	РассчитатьСуммуВСтрокеТабличнойЧасти("Запасы");
	
