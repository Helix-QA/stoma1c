&НаКлиенте
// Процедура, выполняет установку флагов на элменеты.
//
Процедура УстановитьФлагиНаЭлементы(ЗначениеФлага, ДанныеСтрокиДерева, ИмяКолонки, ИндексКолонки)
	
	Если ДанныеСтрокиДерева.ЭтоГруппа Тогда		
		
		ДанныеДерева = ДанныеСтрокиДерева.ПолучитьЭлементы();
		Для Каждого СтрокаДерева из ДанныеДерева Цикл
			Если СтрокаДерева.ЭтоГруппа Тогда
				
				Если ЗначениеФлага = 1 Тогда		
					Для Индекс = 0 По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
						СтрокаДерева["ГруппаОнлайнЗаписи_"+Индекс]= 0;
					КонецЦикла;
				КонецЕсли;				
				СтрокаДерева[ИмяКолонки] = ЗначениеФлага;
				
			КонецЕсли;			
			УстановитьФлагиНаЭлементы(ЗначениеФлага, СтрокаДерева, ИмяКолонки, ИндексКолонки);
		КонецЦикла;		
		
	Иначе			
		УстановитьФлагиНаЭлементыФрагмент(ДанныеСтрокиДерева, ЗначениеФлага, ИмяКолонки, ИндексКолонки);		
	КонецЕсли;		
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает флаги на подчиненные элементы.
//
Процедура УстановитьФлагиНаЭлементыФрагмент(ДанныеСтрокиДерева, ЗначениеФлага, ИмяКолонки, ИндексКолонки)
	
	ОбновитьЭлемент = Ложь;
	Для Индекс = 0  По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		Если ЗначениеФлага = 1 Тогда
			ДанныеСтрокиДерева["ГруппаОнлайнЗаписи_"+Индекс]= 0;
			ОбновитьЭлемент = Истина;
		ИначеЕсли ДанныеСтрокиДерева["ГруппаОнлайнЗаписи_"+ИндексКолонки] <> ЗначениеФлага Тогда
			ОбновитьЭлемент = Истина;
		КонецЕсли;		
	КонецЦикла;
	ДанныеСтрокиДерева[ИмяКолонки] = ЗначениеФлага;	
	
	Если ОбновитьЭлемент Тогда
		НоваяСтрока = ТаблицаНоменклатуры.Добавить();
		НоваяСтрока.Номенклатура = ДанныеСтрокиДерева.Номенклатура;		
		ТекущаяГруппаОнлайнЗаписи = ТаблицаГруппОнлайнЗаписей[ИндексКолонки].ГруппаОнлайнЗаписи;
		НоваяСтрока.ГруппаОнлайнЗаписи = ?(ЗначениеФлага = 0, Неопределено, ТекущаяГруппаОнлайнЗаписи);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает флаги на группы.
//
Процедура УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, ЭтоРодитель = Ложь)
	
	Если ЭтоРодитель Тогда
		Родитель = ТекущиеДанные;
	Иначе
		Родитель = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	Если Родитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДерева = Родитель.ПолучитьЭлементы();
	
	КоличествоВыбранных = 0;
	Для Каждого СтрокаДерева из ДанныеДерева Цикл
		Если СтрокаДерева[ИмяКолонки] = 1 Тогда
			КоличествоВыбранных = КоличествоВыбранных + 1;
		ИначеЕсли СтрокаДерева[ИмяКолонки] = 2 Тогда
			КоличествоВыбранных = -1;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоВыбранных = ДанныеДерева.Количество() Тогда
		Родитель[ИмяКолонки] = 1;
	ИначеЕсли КоличествоВыбранных = 0 Тогда
		Родитель[ИмяКолонки] = 0;
	Иначе
		Родитель[ИмяКолонки] = 2;
	КонецЕсли;		
	
	УстановитьФлагиНаГруппы(Родитель, ИмяКолонки);
	
КонецПроцедуры

