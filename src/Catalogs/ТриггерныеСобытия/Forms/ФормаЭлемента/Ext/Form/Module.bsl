			ЭлементФормы.СписокВыбора.Очистить();                                                                                                                                  
			
			// Добавим основных адресатов
			Если Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение ИЛИ Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
