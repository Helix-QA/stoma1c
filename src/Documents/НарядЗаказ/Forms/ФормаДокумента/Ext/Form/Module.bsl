// Функция - Получить организацию по структурной единице
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОрганизациюПоСтруктурнойЕдинице(СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	СтруктурныеЕдиницы.Организация КАК Организация
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|ГДЕ
		|	СтруктурныеЕдиницы.Ссылка = &СтруктурнаяЕдиница";
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Выбора = Запрос.Выполнить().Выбрать();
	Пока Выбора.Следующий() Цикл

		Возврат Выбора.Организация;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
// Процедура - Заполнить параметры выбора организаций
//
Процедура ЗаполнитьПараметрыВыбораОрганизаций()
	
	Если Не Объект.СтруктурнаяЕдиница.Пустая() Тогда
		
		ОрганизацияПоСЕ = ПолучитьОрганизациюПоСтруктурнойЕдинице(Объект.СтруктурнаяЕдиница);
		
		Если Не ОрганизацияПоСЕ = Неопределено Тогда
			
			Объект.Организация = ОрганизацияПоСЕ;
			МассивОрганизацияПоСЕ = Новый Массив();
			МассивОрганизацияПоСЕ.Добавить(ОрганизацияПоСЕ);
			ФиксированныйМассивОрганизацияПоСЕ = Новый ФиксированныйМассив(МассивОрганизацияПоСЕ);
			НовыйМассив 	    			   = Новый Массив();
			НовыйМассив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", ФиксированныйМассивОрганизацияПоСЕ));
			Элементы.Организация.ПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассив);
			
		Иначе
			
			Объект.Организация = Справочники.Организации.ПустаяСсылка();
			
		КонецЕсли;
	Иначе
		
		Объект.Организация = Справочники.Организации.ПустаяСсылка();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Нажатие"
//
Процедура ДекорацияДобавитьУслугиНажатие(Элемент)	
	
	МассивНайденныхСтрок = ТаблицаНезавершенныхПланирований.НайтиСтроки(Новый Структура("КлючЭлемента", СтрЗаменить(Элемент.Имя, "Декорация_ДобавитьУслуги_", "")));
	Если МассивНайденныхСтрок.Количество() > 0 Тогда
		
		МассивКлючейДобавленныхСтрок = Новый Массив;
		Для Каждого СтрокаЗапасы Из Объект.Запасы Цикл 
			Если МассивКлючейДобавленныхСтрок.Найти(СтрокаЗапасы.КлючСтроки) = Неопределено Тогда 
				МассивКлючейДобавленныхСтрок.Добавить(СтрокаЗапасы.КлючСтроки);
			КонецЕсли;			
		КонецЦикла;
		
		ПараметрыФормы =  Новый Структура("ОтборДокумент, МассивУжеДобавленныхСтрок, ОтборСотрудник, ОтборСтруктурнаяЕдиница",
										МассивНайденныхСтрок[0].Ссылка, МассивКлючейДобавленныхСтрок, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
									  
		ОткрытьФорму("Документ.Прием.Форма.ФормаПодбораЗапланированныхУслуг", ПараметрыФормы,,,,, Новый ОписаниеОповещения("ДекорацияДобавитьУслугиНажатиеЗавершение", ЭтотОбъект, Новый Структура("МассивНайденныхСтрок", МассивНайденныхСтрок)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Декорация добавить услуги нажатие завершение
//
// Параметры:
//  РезультатПодбора		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДекорацияДобавитьУслугиНажатиеЗавершение(РезультатПодбора, ДополнительныеПараметры) Экспорт
	
	МассивНайденныхСтрок = ДополнительныеПараметры.МассивНайденныхСтрок;
	
	Если РезультатПодбора <> Неопределено Тогда
		ЗаполнитьРезультатомПодбора(МассивНайденныхСтрок[0].Ссылка,РезультатПодбора);
	КонецЕсли;		
	ОбновитьSVGПодбор();

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Нажатие"
//
Процедура ДекорацияОткрытьНажатие(Элемент)	
	
	МассивНайденныхСтрок = ТаблицаНезавершенныхПланирований.НайтиСтроки(Новый Структура("КлючЭлемента", СтрЗаменить(Элемент.Имя, "Декорация_ОткрытьПланЛечения_", "")));
	Если МассивНайденныхСтрок.Количество() > 0 Тогда 
		Если ТипЗнч(МассивНайденныхСтрок[0].Ссылка) = Тип("ДокументСсылка.ПланЛечения") Тогда
			ОткрытьФорму("Документ.ПланЛечения.ФормаОбъекта", Новый Структура("Ключ", МассивНайденныхСтрок[0].Ссылка));
		ИначеЕсли ТипЗнч(МассивНайденныхСтрок[0].Ссылка) = Тип("ДокументСсылка.НарядЗаказ") Тогда
			ОткрытьФорму("Документ.НарядЗаказ.ФормаОбъекта", Новый Структура("Ключ", МассивНайденныхСтрок[0].Ссылка));	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура устанавливает видимость у надписи под зубами
// с гиперсылками "Открыть" и "ДобавитьУслуги"
//
Процедура УстановитьВидимостьНадписиСНезавершеннымиПланамиЛечения()
	
	ТаблицаНезавершенныхПланирований.Загрузить(ВернутьТаблицуНезавершенныхПланирований(Объект.Контрагент, Объект.СтруктурнаяЕдиница, Объект.Дата));
	ПерерисоватьНадписиНезавершенныхПланирований();	
	
КонецПроцедуры

&НаСервере
//
//
Процедура ПерерисоватьНадписиНезавершенныхПланирований()
	
	// Почистим группу перед добавлением в нее элементов
	ИндексЦикла = 0;
	КоличествоЭлементов = Элементы.ГруппаНезаконченныеПланыЛечения.ПодчиненныеЭлементы.Количество();	
	Пока ИндексЦикла < КоличествоЭлементов Цикл		
		ЭтаФорма.Элементы.Удалить(Элементы.ГруппаНезаконченныеПланыЛечения.ПодчиненныеЭлементы[0]);
		ИндексЦикла = ИндексЦикла + 1;
	КонецЦикла;
	
	// Элементы.ГруппаНезаконченныеПланыЛечения.Высота = ТаблицаНезавершенныхПланирований.Количество();
	Элементы.ГруппаНезаконченныеПланыЛечения.Заголовок = "Незаконченные планы лечения и наряд-заказы (" + ТаблицаНезавершенныхПланирований.Количество() + ")"; 	
	
	Для Каждого Планирование Из ТаблицаНезавершенныхПланирований Цикл
		Если ЗначениеЗаполнено(Планирование.Ссылка) И Планирование.Дата <> Дата(1,1,1) Тогда
			Если  ТипЗнч(Планирование.Ссылка) = Тип("ДокументСсылка.НарядЗаказ") И Не Константы.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Получить() И Планирование.Статус Тогда 
				Продолжить;
			КонецЕсли;
					
			Планирование.КлючЭлемента = ОбщегоНазначенияСтоматология.ТолькоЦифры(Планирование.Номер) +""+ОбщегоНазначенияСтоматология.ТолькоЦифры(Планирование.Дата);
			// Добавим группу   
			ЭлементГруппа                     		= ЭтаФорма.Элементы.Добавить("ГруппаПланаЛечения_" + Планирование.КлючЭлемента, Тип("ГруппаФормы"), Элементы.ГруппаНезаконченныеПланыЛечения);
			ЭлементГруппа.Вид                 		= ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементГруппа.ОтображатьЗаголовок 		= Ложь;
			ЭлементГруппа.Отображение         		= ОтображениеОбычнойГруппы.Нет;
			ЭлементГруппа.Группировка         		= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;		   
			ЭлементГруппа.РастягиватьПоВертикали 	= Ложь;
			ЭлементГруппа.Высота 					= 1;
			
			ЭлементГруппаВыравнивания          		           = ЭтаФорма.Элементы.Добавить("ГруппаПланаЛечения_Выравнивания" + Планирование.КлючЭлемента, Тип("ГруппаФормы"), ЭлементГруппа);
			ЭлементГруппаВыравнивания.Вид                 	   = ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементГруппаВыравнивания.ОтображатьЗаголовок 	   = Ложь;
			ЭлементГруппаВыравнивания.Отображение         	   = ОтображениеОбычнойГруппы.Нет;
			ЭлементГруппаВыравнивания.Группировка         	   = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;		   
			ЭлементГруппаВыравнивания.РастягиватьПоВертикали   = Ложь;
			ЭлементГруппаВыравнивания.Высота 				   = 1;
	
			// добавим элементы в эту группу
			ЭлементДекорация                          	= ЭтаФорма.Элементы.Добавить("Декорация_ПланЛечения_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппаВыравнивания);
			ЭлементДекорация.Вид                      	= ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Шрифт                    	= Новый Шрифт( , , Истина, );
			Если  ТипЗнч(Планирование.Ссылка) = Тип("ДокументСсылка.ПланЛечения") Тогда
				Если Планирование.Статус = Перечисления.СтатусыПланЛечения.Принят Тогда 
					ЭлементДекорация.Заголовок = "У пациента есть незаконченный план лечения";
				Иначе 
					ЭлементДекорация.Заголовок = "У пациента есть непринятый план лечения";
				КонецЕсли;
			ИначеЕсли ТипЗнч(Планирование.Ссылка) = Тип("ДокументСсылка.НарядЗаказ") Тогда
				ЭлементДекорация.Заголовок = "У пациента есть не закрытый наряд-заказ";
			КонецЕсли;
			// -------------------------------   
			СотрудникПланирования                       = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Планирование.Сотрудник, "НаименованиеСокращенное"); 
			СотрудникПланирования                       = ?(ЗначениеЗаполнено(СотрудникПланирования), СотрудникПланирования, "");
			СуммаПланирования                           = Формат(Планирование.Сумма, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(); 
			
			ЭлементДекорация                          	= ЭтаФорма.Элементы.Добавить("Декорация_ПланЛечения_Продолжение_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппаВыравнивания);
			ЭлементДекорация.Вид                      	= ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь; 
			ЭлементДекорация.АвтоМаксимальнаяШирина     = Ложь;
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Шрифт                    	= Новый Шрифт( , , Истина, );
			ЭлементДекорация.Заголовок = "от " + Формат(Планирование.Дата, "ДЛФ=DD") + " " + СотрудникПланирования + " Сумма " + СуммаПланирования + " " + Строка(Планирование.Статус);
			
			// -------------------------------
			// ЭлементДекорация                            = ЭтаФорма.Элементы.Добавить("Декорация_Заглушка_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппа);
			// ЭлементДекорация.Вид                        = ВидДекорацииФормы.Надпись;
			// ЭлементДекорация.ГоризонтальноеПоложение    = ГоризонтальноеПоложениеЭлемента.Лево;
			// ЭлементДекорация.РастягиватьПоГоризонтали 	= Истина;
			// ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;
			// ЭлементДекорация.Высота 					= 1;			
			// ЭлементДекорация.Заголовок                  = "";
			// -------------------------------
			ЭлементДекорация                            = ЭтаФорма.Элементы.Добавить("Декорация_ОткрытьПланЛечения_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппа);
			ЭлементДекорация.Вид                        = ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение    = ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Гиперссылка                = Истина;
			ЭлементДекорация.Заголовок                  = "Открыть";
			ЭлементДекорация.УстановитьДействие("Нажатие", "ДекорацияОткрытьНажатие");
			// -------------------------------
			ЭлементДекорация                            = ЭтаФорма.Элементы.Добавить("Декорация_ДобавитьУслуги_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппа);
			ЭлементДекорация.Вид                        = ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение    = ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;			
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Гиперссылка                = Истина;
			ЭлементДекорация.Заголовок                  = "Добавить услуги";
			// Если Планирование.Статус = Перечисления.СтатусыПланЛечения.Рассматривается Тогда 
			//	ЭлементДекорация.Доступность             = Ложь;
			// КонецЕсли;
			ЭлементДекорация.УстановитьДействие("Нажатие", "ДекорацияДобавитьУслугиНажатие");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, Возвращает таблицу незавершенных планирований.
//
Функция ВернутьТаблицуНезавершенныхПланирований(Контрагент, СтруктурнаяЕдиница, ДатаДокумента)
	
	Запрос       = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВложенныйЗапрос.ДокументПланирования КАК Ссылка,
	               |	ВложенныйЗапрос.НомерДокумента КАК Номер,
	               |	ВложенныйЗапрос.ДатаДокумента КАК Дата,
	               |	ВложенныйЗапрос.СтатусДокумента КАК Статус,
	               |	"""" КАК КлючЭлемента,
	               |	ВложенныйЗапрос.Сумма КАК Сумма,
	               |	ВложенныйЗапрос.Сотрудник КАК Сотрудник
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ПланыЛеченияОстатки.ПланЛечения КАК ДокументПланирования,
	               |		ПланыЛеченияОстатки.ПланЛечения.Номер КАК НомерДокумента,
	               |		ПланыЛеченияОстатки.ПланЛечения.Дата КАК ДатаДокумента,
	               |		ПланыЛеченияОстатки.ПланЛечения.Статус КАК СтатусДокумента,
	               |		ПланыЛеченияОстатки.ПланЛечения.Сотрудник КАК Сотрудник,
	               |		ПланыЛеченияОстатки.СуммаОстаток КАК Сумма
	               |	ИЗ
	               |		РегистрНакопления.ПланыЛечения.Остатки(
	               |				&ОтборПериод,
	               |				Контрагент = &ОтборКонтрагент
	               |					И СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница) КАК ПланыЛеченияОстатки
	               |	ГДЕ
	               |		ПланыЛеченияОстатки.КоличествоОстаток > 0
	               |		И ПланыЛеченияОстатки.ПланЛечения.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Закрыт)) КАК ВложенныйЗапрос
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВложенныйЗапрос.ДатаДокумента,
	               |	ВложенныйЗапрос.НомерДокумента,
	               |	ВложенныйЗапрос.ДокументПланирования,
	               |	ВложенныйЗапрос.СтатусДокумента,
	               |	ВложенныйЗапрос.Сумма,
	               |	ВложенныйЗапрос.Сотрудник
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВложенныйЗапрос.ДокументПланирования,
	               |	ВложенныйЗапрос.ДатаДокумента";
		
	Запрос.УстановитьПараметр("ОтборКонтрагент"         , Контрагент);	
	Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница" , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ОтборПериод"             , ?(ЗначениеЗаполнено(ДатаДокумента), КонецДня(ДатаДокумента), ТекущаяДата()));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

