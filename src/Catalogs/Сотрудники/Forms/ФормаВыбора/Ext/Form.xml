	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникСотрудники.Ссылка КАК Ссылка,
	СправочникСотрудники.ПометкаУдаления КАК ПометкаУдаления,
	СправочникСотрудники.Предопределенный КАК Предопределенный,
	СправочникСотрудники.Родитель КАК Родитель,
	СправочникСотрудники.Должность КАК Должность,
	СправочникСотрудники.ЭтоГруппа КАК ЭтоГруппа,
	СправочникСотрудники.Код КАК Код,
	СправочникСотрудники.Наименование КАК Наименование,
	СправочникСотрудники.ДатаРождения КАК ДатаРождения,
	НастройкиСотрудников.Сотрудник КАК Сотрудник,
	СотрудникиСпецилазацииСотрудника.Специализация КАК Специализация,
	ВЫБОР
		КОГДА СправочникСотрудники.ЭтоГруппа
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ + ВЫБОР
		КОГДА СправочникСотрудники.ПометкаУдаления
			ТОГДА 2
		ИНАЧЕ 0
	КОНЕЦ КАК ВариантКартинки
ИЗ
	Справочник.Сотрудники КАК СправочникСотрудники
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		ПО СправочникСотрудники.Ссылка = НастройкиСотрудников.Сотрудник
			И (ВЫБОР
				КОГДА &amp;ОтбиратьПоСтруктурнойЕдинице
					ТОГДА НастройкиСотрудников.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
				ИНАЧЕ ИСТИНА
			КОНЕЦ)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
		ПО СправочникСотрудники.Ссылка = СотрудникиСпецилазацииСотрудника.Ссылка
			И (ВЫБОР
				КОГДА &amp;Специализация &lt;&gt; НЕОПРЕДЕЛЕНО
					ТОГДА СотрудникиСпецилазацииСотрудника.Специализация = &amp;Специализация
				ИНАЧЕ СотрудникиСпецилазацииСотрудника.Основная = ИСТИНА
			КОНЕЦ)
ГДЕ
	СправочникСотрудники.ЭтоГруппа = ЛОЖЬ
	И &amp;УсловиеПользователиМессенджера
	И ВЫБОР
			КОГДА &amp;ИспользоватьОграничениеПоРегистру &lt;&gt; НЕОПРЕДЕЛЕНО
					И &amp;ИспользоватьОграничениеПоРегистру = ИСТИНА
				ТОГДА СправочникСотрудники.Ссылка В
							(ВЫБРАТЬ
								СвязкаПомещениеСотрудник.Сотрудник
							ИЗ
								РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник
							ГДЕ
								ВЫБОР
									КОГДА &amp;ОтбиратьПоСтруктурнойЕдинице
										ТОГДА СвязкаПомещениеСотрудник.Помещение.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
									ИНАЧЕ ИСТИНА
								КОНЕЦ)
						ИЛИ НЕ СправочникСотрудники.Ссылка В
								(ВЫБРАТЬ
									СвязкаПомещениеСотрудник.Сотрудник
								ИЗ
									РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ВыводитьПомеченныхНаУдаление = НЕОПРЕДЕЛЕНО
					ИЛИ &amp;ВыводитьПомеченныхНаУдаление = ЛОЖЬ
				ТОГДА СправочникСотрудники.ПометкаУдаления = ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ОтбиратьВрачей &lt;&gt; НЕОПРЕДЕЛЕНО
					И &amp;ОтбиратьВрачей = ИСТИНА
				ТОГДА НастройкиСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
						ИЛИ НастройкиСотрудников.ДатаУвольнения &gt; &amp;Дата
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И &amp;ОтборПоРолям
	И ВЫБОР
			КОГДА &amp;Сотрудник &lt;&gt; НЕОПРЕДЕЛЕНО
				ТОГДА СправочникСотрудники.Ссылка &lt;&gt; &amp;Сотрудник
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;Специализация &lt;&gt; НЕОПРЕДЕЛЕНО
				ТОГДА СотрудникиСпецилазацииСотрудника.Специализация = &amp;Специализация
						И ВЫБОР
							КОГДА &amp;ОтбиратьПоСтруктурнойЕдинице
								ТОГДА НастройкиСотрудников.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
							ИНАЧЕ ИСТИНА
						КОНЕЦ
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И СправочникСотрудники.Служебный = ЛОЖЬ

СГРУППИРОВАТЬ ПО
	СправочникСотрудники.Ссылка,
	СправочникСотрудники.ПометкаУдаления,
	СправочникСотрудники.Предопределенный,
	СправочникСотрудники.Родитель,
	СправочникСотрудники.ЭтоГруппа,
	СправочникСотрудники.Код,
	СправочникСотрудники.Наименование,
	СправочникСотрудники.ДатаРождения,
	НастройкиСотрудников.Сотрудник,
	СправочникСотрудники.Должность,
	СотрудникиСпецилазацииСотрудника.Специализация</QueryText>
