// Процедура - Создать клиента по входящей заявке.
//
Процедура СоздатьКлиентаЗавершение()
	
	ОписаниеОшибки = "";
	Результат 	   = ОбработкаСозданияКлиентаИСделки(ОписаниеОшибки, ЗаписьНаПрием);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ПоказатьПредупреждение(, ?(ЗначениеЗаполнено(ОписаниеОшибки), ОписаниеОшибки, НСтр("ru = 'Не удалось создать клиента!'; en = 'Failed to create client!'")));
	Иначе
		
		УстановитьСостояниеЭлементовФормыСтатусыЗаявки();
		Оповестить("ЗаписанНовыйКлиент", Результат, ЭтаФорма);
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Заявка"				, Объект.Ссылка);
		ПараметрыОповещения.Вставить("ОсновнойМенеджер"		, Объект.ОсновнойМенеджер);
		ПараметрыОповещения.Вставить("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
		
		Оповестить("ОбновленСтатусЗаявки", ПараметрыОповещения);
		
		Если ЗаписьНаПрием = Истина Тогда
			
			ПараметрыОткрытия = Новый Структура("ЗаписьИзДругойФормы, Контрагент", Истина, Результат);
			 
			ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыОткрытия, "ФормаЗаписи");
			ОткрытьФорму(ИмяФормыПланировщика, ПараметрыОткрытия,, Новый УникальныйИдентификатор,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		Иначе 
			
			ПоказатьЗначение(,Результат);
			ЭтаФорма.Закрыть();

		КонецЕсли;
	
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Функция, создает клиента и сделку.
//
Функция ОбработкаСозданияКлиентаИСделки(ОписаниеОшибки, ЗаписьНаПрием)
	
	ОсновнойКлиент = СоздатьПотенциальногоКлиентаПоВходящейЗаявке(Объект.Ссылка, ОписаниеОшибки);
	
	Если ЗначениеЗаполнено(ОсновнойКлиент) Тогда
		
		Объект.ОсновнойКлиент   = ОсновнойКлиент;
		ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Принята;
		
		Если Объект.Статус <> ЭтотОбъект.СтатусЗаявки Тогда
			Объект.Статус = ЭтотОбъект.СтатусЗаявки;
		КонецЕсли;
		
		ЭтотОбъект.ОповеститьОНовойЗаявке = Истина;
		ЭтаФорма.Записать();
		
		УстановитьСостояниеЭлементовФормы();
		
		Сделка = Неопределено;
		
		Если НЕ ЗаписьНаПрием = Истина Тогда
			
			Если ЗначениеЗаполнено(ЭтаФорма.ВидСделки) Тогда
				Сделка = СоздатьСделку(Объект.ОсновнойКлиент, ЭтаФорма.ВидСделки);					
			КонецЕсли;
			
		КонецЕсли;
		
		Задачи.Взаимодействие.ОбновитьЗадачиПоЗаявке(Объект.Ссылка, ОсновнойКлиент, Сделка);
		
		Возврат ОсновнойКлиент;
		
	Иначе
		Возврат ОписаниеОшибки;
	КонецЕсли;
	
КонецФункции

