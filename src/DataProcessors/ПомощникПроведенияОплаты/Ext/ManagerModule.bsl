		|	СУММА(ВложенныйЗапрос.Сумма) КАК Сумма,
		|	ВложенныйЗапрос.Упаковка КАК Упаковка,
		|	ВложенныйЗапрос.Партия КАК Партия,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))) <> """"
		|			ТОГДА ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))
		|		ИНАЧЕ ВложенныйЗапрос.Номенклатура.Наименование
		|	КОНЕЦ КАК Наименование
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВозвратОтПокупателяЗапасы.Номенклатура КАК Номенклатура,
		|		ВозвратОтПокупателяЗапасы.Цена КАК Цена,
		|		ВозвратОтПокупателяЗапасы.СтавкаНДС КАК СтавкаНДС,
		|		-1 * ВозвратОтПокупателяЗапасы.КоличествоУпаковок КАК КоличествоУпаковок,
		|		-1 * ВозвратОтПокупателяЗапасы.СуммаНДС КАК СуммаНДС,
		|		-1 * ВозвратОтПокупателяЗапасы.Сумма КАК Сумма,
		|		ВозвратОтПокупателяЗапасы.Упаковка КАК Упаковка,
		|		ВозвратОтПокупателяЗапасы.Партия КАК Партия
		|	ИЗ
		|		Документ.ВозвратОтПокупателя.Запасы КАК ВозвратОтПокупателяЗапасы
		|	ГДЕ
		|		ВозвратОтПокупателяЗапасы.Ссылка.ДокументОснования = &Ссылка
		|		И ВозвратОтПокупателяЗапасы.Ссылка.Проведен = ИСТИНА
		|		И ТИПЗНАЧЕНИЯ(&Ссылка) = ТИП(Документ.Реализация)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		РеализацияУслуги.Номенклатура,
		|		РеализацияУслуги.Цена,
		|		РеализацияУслуги.СтавкаНДС,
		|		РеализацияУслуги.КоличествоУпаковок,
		|		РеализацияУслуги.СуммаНДС,
		|		РеализацияУслуги.Сумма,
		|		РеализацияУслуги.Упаковка,
		|		РеализацияУслуги.Партия
		|	ИЗ
		|		Документ.Реализация.Услуги КАК РеализацияУслуги
		|	ГДЕ
		|		РеализацияУслуги.Ссылка = &Ссылка) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Номенклатура,
		|	ВложенныйЗапрос.Цена,
		|	ВложенныйЗапрос.СтавкаНДС,
		|	ВложенныйЗапрос.Упаковка,
		|	ВложенныйЗапрос.Партия,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))) <> """"
		|			ТОГДА ВЫРАЗИТЬ(ВложенныйЗапрос.Номенклатура.НаименованиеПолное КАК СТРОКА(150))
		|		ИНАЧЕ ВложенныйЗапрос.Номенклатура.Наименование
		|	КОНЕЦ
		|
		|ИМЕЮЩИЕ
		|	(СУММА(ВложенныйЗапрос.КоличествоУпаковок) > 0
		|		ИЛИ СУММА(ВложенныйЗапрос.Сумма) > 0)";
		
		МассивОбъединениеЗапросов.Добавить(ТекстЗапроса);
		
	КонецЕсли;
	
	Возврат СтрСоединить(МассивОбъединениеЗапросов, Символы.ПС);  
	
КонецФункции

&НаСервере
// Функция - возвращает массив параметров товаров.
//
Функция ПолучитьМассивПараметровТоваровККТ(ДокументОснования, ОплаченоПоДокументуРанее, СуммаОперации, Касса) Экспорт
	
	МассивТоваров = Новый Массив;
	
	Если Не ЗначениеЗаполнено(ДокументОснования) Тогда
		Возврат МассивТоваров;
	КонецЕсли;	
		
	Запрос = Новый Запрос(ПолучитьТекстЗапросаПолученияТоваровККТ(ДокументОснования));
	Запрос.УстановитьПараметр("Ссылка", ДокументОснования);
	
	ТаблицаТоваров = Запрос.Выполнить().Выгрузить();
	
	НайденныеСтроки = ТаблицаТоваров.НайтиСтроки(Новый Структура("Сумма", 0));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		Для каждого УдаляемаяСтрока Из НайденныеСтроки Цикл
			ТаблицаТоваров.Удалить(УдаляемаяСтрока);      
		КонецЦикла;
	КонецЕсли;
	
	Постоплата = ОплаченоПоДокументуРанее > 0
					Или	(ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("НомерЧекаККМ", ДокументОснования.Ссылка.Метаданные())
						И ЗначениеЗаполнено(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОснования, "НомерЧекаККМ")));
						
	ИтогСумма = ТаблицаТоваров.Итог("Сумма");						
	
	ПолнаяОплата = СуммаОперации >= ИтогСумма;
	
	Если Постоплата = Ложь Тогда
		
		ТаблицаТоваров.Колонки.Добавить("Всего", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));		
		
		Если Не ПолнаяОплата Тогда 
			// Это частичная оплата, распределяем ее по строкам номенклатуры
			ИтогСумма = ТаблицаТоваров.Итог("Сумма");  		
			
			Для Каждого СтрокаТЗ Из ТаблицаТоваров Цикл
				СтрокаТЗ.Всего = Окр((СтрокаТЗ.Сумма / ИтогСумма) * СуммаОперации, 2, 1);
			КонецЦикла;
			
		КонецЕсли;
		
		Для Каждого СтрокаТЧ из ТаблицаТоваров Цикл
			СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
			
			СтрокаТовара.Номенклатура           = СтрокаТЧ.Номенклатура;
			СтрокаТовара.Наименование           = СтрокаТЧ.Наименование;
			СтрокаТовара.СтоимостьБезСкидки     = СтрокаТЧ.КоличествоУпаковок * СтрокаТЧ.Цена;
			СтрокаТовара.СуммаСкидки            = СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок - СтрокаТЧ.Сумма;
			СтрокаТовара.СтоимостьСоСкидкой     = СтрокаТЧ.Сумма;
			СтрокаТовара.Количество             = СтрокаТЧ.КоличествоУпаковок;
			СтрокаТовара.СтавкаНДС              = СтрокаТЧ.СтавкаНДС;
			СтрокаТовара.СуммаНДС               = Ценообразование.РассчитатьСуммуНДС(СтрокаТЧ.Сумма, СтрокаТовара.СтавкаНДС);
			СтрокаТовара.НомерСекции            = Справочники.Кассы.ПолучитьСекциюНоменклатуры(СтрокаТЧ.Номенклатура, Касса);
			СтрокаТовара.Штрихкод               = МенеджерОборудованияВызовСервера.ПолучитьШтрихкодНоменклатуры(СтрокаТЧ.Номенклатура, СтрокаТЧ.Партия, СтрокаТЧ.Упаковка);
			СтрокаТовара.СуммаОплачено			= ?(ПолнаяОплата, СтрокаТЧ.Сумма, СтрокаТЧ.Всего);
			СтрокаТовара.ЭтоОплатаКредита       = Ложь;
			
			МассивТоваров.Добавить(СтрокаТовара);
		КонецЦикла;
	Иначе   		
		ТЗВременная = ТаблицаТоваров;
		
		ИтогСумма = ТЗВременная.Итог("Сумма");
		ИтогСумма = ?(ИтогСумма = 0, 1, ИтогСумма);
		
		Для Каждого СтрокаТЗ Из ТЗВременная Цикл
			СтрокаТЗ.Сумма = Окр((СтрокаТЗ.Сумма / ИтогСумма) * СуммаОперации, 2, 1);
		КонецЦикла;
		
		ИтогСуммаПересчитанный			= ТЗВременная.Итог("Сумма");
		ПогрешностьРаспределенияСуммы	= СуммаОперации - ИтогСуммаПересчитанный;
		
		Если ПогрешностьРаспределенияСуммы <> 0 
			И ТЗВременная.Количество() > 0 Тогда
			
			ТЗВременная[0].Сумма = ТЗВременная[0].Сумма + ПогрешностьРаспределенияСуммы;
		КонецЕсли;
		
		Для Каждого СтрокаТЗ Из ТЗВременная Цикл
			СтрокаТЗ.Цена		= Окр(СтрокаТЗ.Сумма / СтрокаТЗ.КоличествоУпаковок, 2, 1);
			СтрокаТЗ.СуммаНДС	= Ценообразование.РассчитатьСуммуНДС(СтрокаТЗ.Сумма, СтрокаТЗ.СтавкаНДС);
		КонецЦикла;
		
		Для Каждого СтрокаЗапаса Из ТЗВременная Цикл
			
			СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
			
			СтрокаТовара.Номенклатура           = СтрокаЗапаса.Номенклатура;
			СтрокаТовара.Наименование           = СтрокаЗапаса.Наименование;
			СтрокаТовара.СтоимостьБезСкидки     = СтрокаЗапаса.Сумма;
			СтрокаТовара.СуммаСкидки            = 0;
			СтрокаТовара.СтоимостьСоСкидкой     = СтрокаЗапаса.Сумма;
			СтрокаТовара.Количество             = СтрокаЗапаса.КоличествоУпаковок;
			СтрокаТовара.СтавкаНДС              = СтрокаЗапаса.СтавкаНДС;
			СтрокаТовара.СуммаНДС               = Ценообразование.РассчитатьСуммуНДС(СтрокаТовара.СтоимостьСоСкидкой, СтрокаЗапаса.СтавкаНДС);
			СтрокаТовара.НомерСекции            = Справочники.Кассы.ПолучитьСекциюНоменклатуры(СтрокаЗапаса.Номенклатура, Касса); 
			СтрокаТовара.Штрихкод               = РегистрыСведений.Штрихкоды.ПоулчитьШтрихкодПоОбъекту(СтрокаЗапаса.Номенклатура, СтрокаЗапаса.Партия);
			СтрокаТовара.СуммаОплачено          = СтрокаЗапаса.Сумма;
			СтрокаТовара.ЭтоОплатаКредита       = Постоплата;
			
			// Если ЭтоКомиссионнаяТорговля  Тогда
			//	СтрокаТовара.ПризнакАгентаПоПредметуРасчета = "Комиссионер";
			//	СтрокаТовара.ДанныеАгента.ПлатежныйАгент.Телефон = РеквизитыКонтрагентаПринципала.Телефон;
			//	СтрокаТовара.ДанныеПоставщика.ИНН                = РеквизитыКонтрагентаПринципала.ИНН;
			//	СтрокаТовара.ДанныеПоставщика.Телефон            = РеквизитыКонтрагентаПринципала.Телефон;
			//	СтрокаТовара.ДанныеПоставщика.Наименование       = РеквизитыКонтрагентаПринципала.Наименование;
			//	//?(ЗначениеЗаполнено(РеквизитыКонтрагентаПринципала.НаименованиеПолное),
			//	//		РеквизитыКонтрагентаПринципала.НаименованиеПолное, РеквизитыКонтрагентаПринципала.Наименование);
			// КонецЕсли;
			//
			// ДанныеМаркировки = МенеджерОборудованияМаркировкаКлиентСервер.РазобратьШтриховойКодТовара(СтрокаТовара.Штрихкод);
			// СтрокаТовара.ДанныеКодаТоварнойНоменклатуры.РеквизитКодаТовара = ДанныеМаркировки.РеквизитКодаТовара;													
			
			МассивТоваров.Добавить(СтрокаТовара);			
			
		КонецЦикла; 			
	КонецЕсли;
	
	Возврат МассивТоваров;
	
КонецФункции

// Функция - Добавить движения в регистр бонусные счета при необходимости
//
Процедура ДобавитьДвиженияВРегистрБонусныеСчета(МассивПриемов) Экспорт
	
	// 1) Проверка необходимости проведения по регистру Бонусные счета, если признак начисления бонуса
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Прием.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТПриемы
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка В(&МассивПриемов)
	|	И Прием.СкидкиНаценки.Использование = ИСТИНА
	|	И Прием.СкидкиНаценки.ПризнакОплатыБонусом = ЛОЖЬ
	|	И Прием.СкидкиНаценки.СкидкаНаценка.НачислениеБонусами = ИСТИНА
	|	И Прием.Проведен
	|	И Прием.СкидкиНаценки.Сумма <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТПриемы.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТПриемыОплачены
	|ИЗ
	|	ВТПриемы КАК ВТПриемы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
	|				,
	|				ДокументРеализации В
	|					(ВЫБРАТЬ
	|						ВТПриемы.Ссылка
	|					ИЗ
	|						ВТПриемы КАК ВТПриемы)) КАК РасчетыСПокупателямиОстатки
	|		ПО ВТПриемы.Ссылка = РасчетыСПокупателямиОстатки.ДокументРеализации
	|ГДЕ
	|	ЕСТЬNULL(РасчетыСПокупателямиОстатки.СуммаОстаток, 0) = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемСкидкиНаценки.БонусныйСчет КАК БонусныйСчет,
	|	ПриемСкидкиНаценки.Ссылка КАК ДокументНачисления,
	|	ПриемСкидкиНаценки.Ссылка.Дата КАК Дата,
	|	СУММА(ПриемСкидкиНаценки.Сумма) КАК Сумма
	|ИЗ
	|	Документ.Прием.СкидкиНаценки КАК ПриемСкидкиНаценки
	|ГДЕ
	|	ПриемСкидкиНаценки.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТПриемыОплачены.Ссылка
	|			ИЗ
	|				ВТПриемыОплачены)
	|	И ПриемСкидкиНаценки.Использование = ИСТИНА
	|	И ПриемСкидкиНаценки.ПризнакОплатыБонусом = ЛОЖЬ
	|	И ПриемСкидкиНаценки.СкидкаНаценка.НачислениеБонусами = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриемСкидкиНаценки.БонусныйСчет,
	|	ПриемСкидкиНаценки.Ссылка,
	|	ПриемСкидкиНаценки.Ссылка.Дата
	|ИТОГИ ПО
	|	ДокументНачисления";
	
	Запрос.УстановитьПараметр("МассивПриемов", МассивПриемов);	
	ВыборкаПрием = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	// 2) Добавить движения по бонусным счетам
	Пока ВыборкаПрием.Следующий() Цикл
		
		Прием        = ВыборкаПрием.ДокументНачисления;
		НаборЗаписей = РегистрыНакопления.БонусныеСчета.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Прием);
		НаборЗаписей.Прочитать();
		
		Выборка = ВыборкаПрием.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Запись = НаборЗаписей.ДобавитьПриход();
			
			Запись.Регистратор        = Прием;
			Запись.ДокументНачисления = Прием;
			Запись.БонусныйСчет       = Выборка.БонусныйСчет;		
			Запись.Период             = ?(Выборка.Дата > ТекущаяДата(), ТекущаяДата(), Выборка.Дата);	
			Запись.Сумма              = Выборка.Сумма;
			
		КонецЦикла;
		
		НаборЗаписей.Записать(); 
		
	КонецЦикла;
	
КонецПроцедуры

//// ОплатаБонуснымСчетом

// Процедура пересчитвает маркетинговые акции.
//
Процедура ПересчитатьМаркетинговыеАкции(РеализцияОбъект) Экспорт
	
	// Сохраняем список отключенных скидок  
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки = Новый ТаблицаЗначений;
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("КлючСтроки"	, Новый ОписаниеТипов("УникальныйИдентификатор"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("Использование", Новый ОписаниеТипов("Булево"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("СкидкаНаценка", Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("Номенклатура"	, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	ЕстьТЧЗапасы  = ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы" , РеализцияОбъект.Ссылка.Метаданные()) = Истина;
	ЕстьТЧЛечение = ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", РеализцияОбъект.Ссылка.Метаданные()) = Истина;
	ЕстьТЧУслуги  = ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги" , РеализцияОбъект.Ссылка.Метаданные()) = Истина;
	
	Для Каждого СтрокаТЗ Из РеализцияОбъект.СкидкиНаценки Цикл
		НоваяСтрока = ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		НоваяСтрока.Номенклатура = СтрокаТЗ.НоменклатураСкидки;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из РеализцияОбъект.Подарки Цикл
		НоваяСтрока = ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
	КонецЦикла;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДатаСкидок"			, РеализцияОбъект.Дата);
	СтруктураПараметров.Вставить("Получатель"			, РеализцияОбъект.Контрагент);
	СтруктураПараметров.Вставить("Карта"				, РеализцияОбъект.КартаКонтрагента);
	СтруктураПараметров.Вставить("ОплатаБонуснымСчетом"	, Истина);
	
	УправлениеМаркетинговымиАкциями.РассчитатьСкидкиПриПродаже(
		РеализцияОбъект, 
		?(ЕстьТЧЗапасы , "Запасы" , Неопределено),
		?(ЕстьТЧЛечение, "Лечение", Неопределено),
		?(ЕстьТЧУслуги , "Услуги" , Неопределено),
		"СкидкиНаценки", 
		"Подарки", 
		ПолучитьТЧДоступныеОплатыБонусами(РеализцияОбъект),
		ВременноХранениеПредыдщееСостояниеСкидкиПодарки,
		СтруктураПараметров);
		
	// Пересчитываем суммы
	Если ЕстьТЧЗапасы Тогда 
		Для Каждого СтрокаТЧ Из РеализцияОбъект.Запасы Цикл
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ПорядокОкругления"							, СтрокаТЧ.ВидЦен.ПорядокОкругления);
			СтруктураПараметров.Вставить("ОкруглятьВБольшуюСторону"						, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);
			СтруктураПараметров.Вставить("ЕстьКолонкаПроцентСкидкиНаценки"				, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки"	, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаКоличествоУпаковок"				, Истина);
			
			// Пересчитываем сумму строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
			// Пересчитываем сумму НДС строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
			// Пересчитываем всего строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
		КонецЦикла;	
	КонецЕсли;
	
	// Пересчитываем суммы
	Если ЕстьТЧЛечение Тогда 
		Для Каждого СтрокаТЧ Из РеализцияОбъект.Лечение Цикл
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ПорядокОкругления"							, СтрокаТЧ.ВидЦен.ПорядокОкругления);
			СтруктураПараметров.Вставить("ОкруглятьВБольшуюСторону"						, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);
			СтруктураПараметров.Вставить("ЕстьКолонкаПроцентСкидкиНаценки"				, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки"	, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаКоличествоУпаковок"				, Истина);
			
			// Пересчитываем сумму строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
			// Пересчитываем сумму НДС строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
			// Пересчитываем всего строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
		КонецЦикла;		
	КонецЕсли;
	
	// Пересчитываем суммы
	Если ЕстьТЧУслуги Тогда
		Для Каждого СтрокаТЧ Из РеализцияОбъект.Услуги Цикл
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ПорядокОкругления"							, СтрокаТЧ.ВидЦен.ПорядокОкругления);
			СтруктураПараметров.Вставить("ОкруглятьВБольшуюСторону"						, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);
			СтруктураПараметров.Вставить("ЕстьКолонкаПроцентСкидкиНаценки"				, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки"	, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаКоличествоУпаковок"				, Истина);
			
			// Пересчитываем сумму строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
			// Пересчитываем сумму НДС строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
			// Пересчитываем всего строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
		КонецЦикла;		
	КонецЕсли;
	
	РеализцияОбъект.СуммаДокумента = ?(ЕстьТЧЗапасы  , РеализцияОбъект.Запасы.Итог("Всего"), 0)
									+ ?(ЕстьТЧЛечение, РеализцияОбъект.Лечение.Итог("Всего"), 0)
									+ ?(ЕстьТЧУслуги , РеализцияОбъект.Услуги.Итог("Всего"), 0);
	
КонецПроцедуры

// Процедура, обработчик события "ПередЗаписью".
//
Функция ПолучитьТЧДоступныеОплатыБонусами(РеализцияОбъект)
	
	ТаблицаИспользуемыхСкидокНаценок = РеализцияОбъект.СкидкиНаценки.Выгрузить(РеализцияОбъект.СкидкиНаценки.НайтиСтроки(Новый Структура("Использование", Истина)));
	
	ТаблицаОплатаБонусами = УправлениеМаркетинговымиАкциями.ЗапросПоОплатеБонусами(
								РеализцияОбъект, 
								РеализцияОбъект.Запасы.Выгрузить(),
								?(ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", РеализцияОбъект.Ссылка.Метаданные()) = Истина, РеализцияОбъект.Лечение.Выгрузить(), Неопределено),
								?(ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", РеализцияОбъект.Ссылка.Метаданные()) = Истина, РеализцияОбъект.Услуги.Выгрузить(), Неопределено),
								ТаблицаИспользуемыхСкидокНаценок);
								
	ТаблицаОплатаБонусами.Свернуть("БонусныйСчет, СуммаОстаток", "МаксимальнаяСуммаОплаты, СуммаДляРасчетаБонусов");
	
	СкидкаНаценкаОплатаБонусами = Новый ТаблицаЗначений;
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("БонусныйСчет"				, Новый ОписаниеТипов("СправочникСсылка.БонусныеСчета"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("СуммаОстаток"				, Новый ОписаниеТипов("Число"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("МаксимальнаяСуммаОплаты"	, Новый ОписаниеТипов("Число"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("Сумма"					, Новый ОписаниеТипов("Число"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("СуммаДляРасчетаБонусов"	, Новый ОписаниеТипов("Число"));
	
	ЗаполнитьТаблицуСкидокНаценокОплатБонусами(ТаблицаОплатаБонусами, СкидкаНаценкаОплатаБонусами, РеализцияОбъект);
	
	// Проставляем сумму списания уже существущих оплат или добавляем для отображения
	Для Каждого СтрокаТЧ Из РеализцияОбъект.СкидкиНаценки Цикл
		Если СтрокаТЧ.ПризнакОплатыБонусом = Истина Тогда
			МассивНайденныеСтрока = СкидкаНаценкаОплатаБонусами.НайтиСтроки(Новый Структура("БонусныйСчет", СтрокаТЧ.БонусныйСчет));
			Если МассивНайденныеСтрока.Количество() > 0 Тогда
				МассивНайденныеСтрока[0].Сумма	= МассивНайденныеСтрока[0].Сумма + СтрокаТЧ.Сумма;
			Иначе
				НайденнаяСтрока = СкидкаНаценкаОплатаБонусами.Добавить();
				НайденнаяСтрока.БонусныйСчет	= СтрокаТЧ.БонусныйСчет;
				НайденнаяСтрока.Сумма			= НайденнаяСтрока.Сумма + СтрокаТЧ.Сумма;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СкидкаНаценкаОплатаБонусами;
	
КонецФункции    

// Процедура, заполняет переданную таблицу значений данными из ТаблицыОплатБонусами.
//
Процедура ЗаполнитьТаблицуСкидокНаценокОплатБонусами(ТаблицаОплатаБонусами, ТаблицаСкидокНаценокОплатБонусами, РеализцияОбъект)
	
	// Заполняем таблицу остатками по бонусным счетам
	ТаблицаСкидокНаценокОплатБонусами.Очистить();
	Для Каждого СтрокаТЗ Из ТаблицаОплатаБонусами Цикл
		
		ПараметрыБонусногоСчета = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаТЗ.БонусныйСчет, "СрокДействияНачало, СрокДействияКонец");
		
		Если (ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияНачало) 
			И ПараметрыБонусногоСчета.СрокДействияНачало <= РеализцияОбъект.Дата
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияНачало))
			И (ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияКонец)
			И КонецДня(ПараметрыБонусногоСчета.СрокДействияКонец) >= РеализцияОбъект.Дата
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияКонец)) Тогда
			
			НоваяСтрока = ТаблицаСкидокНаценокОплатБонусами.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
			НоваяСтрока.МаксимальнаяСуммаОплаты = ?(НоваяСтрока.СуммаОстаток < НоваяСтрока.МаксимальнаяСуммаОплаты, НоваяСтрока.СуммаОстаток, НоваяСтрока.МаксимальнаяСуммаОплаты);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция, возвращает объект документа задолженности.
//
Функция ПолучитьОбъектДокументаЗадолженности(ДокументыОплаты, ДокументЗадолженности)
	
	НайденнаяСтр = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ДокументыОплаты, "ДокументСсылка", ДокументЗадолженности);
	
	Если НайденнаяСтр = Неопределено Тогда
		
		ДокументЗадолженностиОбъект = ДокументЗадолженности.ПолучитьОбъект();
		ДокументыОплаты.Добавить(Новый Структура("ДокументСсылка,ДокументОбъект", ДокументЗадолженности, ДокументЗадолженностиОбъект));
		
	Иначе
		ДокументЗадолженностиОбъект = НайденнаяСтр.ДокументОбъект;
	КонецЕсли;
	
	Возврат ДокументЗадолженностиОбъект;
	
КонецФункции

// Получить признак необходимости перепроведения указанного документа
Функция ПроверитьНеобходимостьПерепроведенияРеализацииПослеОплаты(ДокументСсылка) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИСТИНА КАК Перепровести
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка = &ДокументСсылка
	|	И (Прием.СкидкиНаценки.ПризнакОплатыБонусом = ИСТИНА
	|			ИЛИ Прием.СкидкиНаценки.СкидкаНаценка.НачислениеБонусами = ИСТИНА)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА
	|ИЗ
	|	Документ.Реализация КАК Реализация
	|ГДЕ
	|	Реализация.Ссылка = &ДокументСсылка
	|	И (Реализация.СкидкиНаценки.ПризнакОплатыБонусом
	|			ИЛИ Реализация.СкидкиНаценки.СкидкаНаценка.НачислениеБонусами = ИСТИНА)");
	
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	Возврат Не Запрос.Выполнить().Пустой();

КонецФункции

//// ФормированиеВозвратаОплаты

// Создать документ оплаты по нужному типу ден. средств
Функция СоздатьДокументВозвратаОплатыПоТипуДенежныхСредств(ТипДенежныхСредств)
	
	Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные
		ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
		
		ДокОбъект = Документы.СписаниеДенежныхСредств.СоздатьДокумент();		
		Возврат ДокОбъект;
		
	Иначе
		
		ДокОбъект = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
		Возврат ДокОбъект;

	КонецЕсли;
	
КонецФункции

// Функция - Формирование оплаты документами ПДСи СДС
// 
// Параметры:
//  Касса					 - 	 - 
//  ДокументЗадолженности	 - 	 - 
//  ВидОперацииДокОплаты	 - 	 - 
//  СтрокаОплаты			 - 	 - 
//  ТаблицаВидовОплат		 - 	 - 
//  СуммаПлатежа			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ФормированиеВозвратаОплатыНаличнымиКартойБезналомЛССертификатом(
		Контрагент,
		Касса, 
		ДокументЗадолженности, 
		ОстатокЗадолженности, 
		ВидОперацииДокОплаты,
		СтрокаОплаты)
	
	ДокументОплаты                    = СоздатьДокументВозвратаОплатыПоТипуДенежныхСредств(СтрокаОплаты.ТипДенежныхСредств);
	ДокументОплаты.Статья             = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(ДокументОплаты.ВидОперации);
	ДокументОплаты.Контрагент         = Контрагент;
	ДокументОплаты.СтруктурнаяЕдиница = ДокументЗадолженности.СтруктурнаяЕдиница;
	ДокументОплаты.Заполнить(Новый Структура("СтрокаТаблицыОплата,Касса,ТипДенежныхСредств, ВидОперации", СтрокаОплаты, Касса, СтрокаОплаты.ТипДенежныхСредств, ВидОперацииДокОплаты));
		
	НоваяСтрокаТЧ = ДокументОплаты.РасшифровкаПлатежа.Добавить();
	
	НоваяСтрокаТЧ.ДокументОснования = ДокументЗадолженности;		
	НоваяСтрокаТЧ.Статья            = ДокументОплаты.Статья;		                                                
	НоваяСтрокаТЧ.Сумма             = ОстатокЗадолженности;		

	ДокументОплаты.СуммаДокумента   = ДокументОплаты.РасшифровкаПлатежа.Итог("Сумма");	

	Возврат Новый Структура("ДокументОплаты, СуммаОплаты", ДокументОплаты, НоваяСтрокаТЧ.Сумма);
	
КонецФункции	

// Функция - Фомирование оплаты внесенным авансом
// 
// Параметры:
//  ДокументЗадолженности	 - 	 - 
//  ОстатокЗадолженности	 - 	 - 
//  ДокументыОплаты			 - 	 - 
//  СтрокаОплаты			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ФормированиеВозвратаОплатыВнесеннымАвансом(
	Контрагент,
	ДокументЗадолженности,
	ОстатокЗадолженности,
	ДокументыОплаты,
	СтрокаОплаты) 
		
	// Проверка существовани откр. объекта
	НайденнвяСтр = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ДокументыОплаты, "ДокументСсылка", ДокументЗадолженности);
	
	Если НайденнвяСтр = Неопределено Тогда
		
		ВозвратПокупателюОбъект = ДокументЗадолженности.ПолучитьОбъект();
		ДокументыОплаты.Добавить(Новый Структура("ДокументСсылка,ДокументОбъект", ДокументЗадолженности, ВозвратПокупателюОбъект));
		
	Иначе
		
		ВозвратПокупателюОбъект = НайденнвяСтр.ДокументОбъект;
		
	КонецЕсли;
	
	// Проверка существования открытого аванса
	СтрокаАванса    = Неопределено;
	НайденныеСтроки = ВозвратПокупателюОбъект.УчтенныеАвансы.НайтиСтроки(Новый Структура("ДокументАванса", СтрокаОплаты.ДокументАванса));
	Если НайденныеСтроки.Количество() > 0 Тогда
		
		СтрокаАванса             = НайденныеСтроки[0];
		СтрокаАванса.СуммаАванса = СтрокаАванса.СуммаАванса + ОстатокЗадолженности;
		
	Иначе
		
		СтрокаАванса                     = ВозвратПокупателюОбъект.УчтенныеАвансы.Добавить();
		СтрокаАванса.ДокументАванса      = СтрокаОплаты.ДокументАванса;
		СтрокаАванса.СуммаАванса         = ОстатокЗадолженности;
		СтрокаАванса.ДатаПлатежа         = ТекущаяДата();
		
	КонецЕсли;	
	
	Возврат Новый Структура("ДокументОплаты, СуммаОплаты", ВозвратПокупателюОбъект, ОстатокЗадолженности);
	
КонецФункции

//// СтараяФормаОплаты

// Функция создания и заполнения необходимых документов поступления денежных средств - не используется
// по подготовленным видам оплаты
Функция СоздатьДокументыОплатыПоТаблицеВидовОплатСтарая(
	ID_Транзакции,
	ВидОперации,
	ТаблицаВидовОплат, 
	ТаблицаЗадолженностей, 
	ЭквайринговыйТерминал = Неопределено,
	РасшифровкаОплатВозвр = Неопределено) Экспорт
	
	Если РасшифровкаОплатВозвр = Неопределено Тогда
		РасшифровкаОплатВозвр = Новый Массив;
	КонецЕсли;
	
	СписаниеАвансов = Новый Массив;
		
	// Добавляем колонку для документов которые будут созданы
	ТаблицаВидовОплат.Колонки.Добавить("ДокументОплаты");	
	// Главный цикл перебора оплачиваемых документов
	Для Каждого СтрокаЗадолженности Из ТаблицаЗадолженностей Цикл		
		Если СтрокаЗадолженности.ПризнакВыбора И СтрокаЗадолженности.Задолженность > 0 Тогда
			ОстатокЗадолженности	  = СтрокаЗадолженности.Задолженность;
			ВСуммеОплаченоПоДокументу = 0;

			// Цикл перебора видов оплаты
			Для Каждого СтрокаОплаты Из ТаблицаВидовОплат Цикл
				// Если вид оплаты содержит средства для оплаты
				Если ОстатокЗадолженности > 0
					И СтрокаОплаты.Сумма > 0
					И НЕ ЗначениеЗаполнено(СтрокаОплаты.ДокументАванса) Тогда
					
					ОстатокСуммыПлатежа  = ?(СтрокаОплаты.Сумма >= ОстатокЗадолженности,ОстатокЗадолженности,СтрокаОплаты.Сумма);

					Если Не СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.БонусныйСчет Тогда
						ОплаченоПоДокументу  = 0;
						ДокументОплаты       = Неопределено;	
						// Если документ оплаты не существует создаем и заполняем его
						Если СтрокаОплаты.ДокументОплаты = Неопределено Тогда
							ДокументОплаты                    = СоздатьДокументОплатыПоТипуДенежныхСредствСтарая(СтрокаОплаты.ТипДенежныхСредств, ВидОперации);
							ДокументОплаты.ID_Транзакции 	  = ID_Транзакции; 
							Если ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда 
								ДокументОплаты.ВидОперации    = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту;
							Иначе
								ДокументОплаты.ВидОперации    = Перечисления.ВидыОпераций.ОплатаОтКлиента;
							КонецЕсли;
							ДокументОплаты.Статья             = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(ДокументОплаты.ВидОперации);
							ДокументОплаты.Контрагент         = ?(ТипЗнч(ТаблицаВидовОплат) = Тип("ТаблицаЗначений") И ТаблицаВидовОплат.Колонки.Найти("Контрагент") <> Неопределено И ЗначениеЗаполнено(СтрокаОплаты.Контрагент), СтрокаОплаты.Контрагент, СтрокаЗадолженности.ДокументЗадолженности.Контрагент);
							Если ДокументОплаты.Контрагент <> СтрокаЗадолженности.ДокументЗадолженности.Контрагент Тогда
								ДокументОплаты.Выгодоприобретатель = СтрокаЗадолженности.ДокументЗадолженности.Контрагент;	
							КонецЕсли;
							ДокументОплаты.СтруктурнаяЕдиница = СтрокаЗадолженности.ДокументЗадолженности.СтруктурнаяЕдиница;
							Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Касса",СтрокаЗадолженности.ДокументЗадолженности.Метаданные()) Тогда						
								Если ЗначениеЗаполнено(ЭквайринговыйТерминал) Тогда
									ДокументОплаты.Заполнить(Новый Структура("СтрокаТаблицыОплата,Касса,ЭквайринговыйТерминал",СтрокаОплаты,СтрокаЗадолженности.ДокументЗадолженности.Касса,ЭквайринговыйТерминал));
								Иначе
									ДокументОплаты.Заполнить(Новый Структура("СтрокаТаблицыОплата,Касса",СтрокаОплаты,СтрокаЗадолженности.ДокументЗадолженности.Касса));	
								КонецЕсли;
							Иначе
								ДокументОплаты.Заполнить(Новый Структура("СтрокаТаблицыОплата",СтрокаОплаты));
							КонецЕсли;												
							СтрокаОплаты.ДокументОплаты       = ДокументОплаты;						
						Иначе
							ДокументОплаты                    = СтрокаОплаты.ДокументОплаты;
							ДокументОплаты.ID_Транзакции	  = ID_Транзакции;
						КонецЕсли;					
						НоваяСтрокаТЧ = ДокументОплаты.РасшифровкаПлатежа.Добавить();
						// Если вносится аванс по документу заказа
						Если ТипЗнч(СтрокаЗадолженности.ДокументЗадолженности) = Тип("ДокументСсылка.НарядЗаказ")
							ИЛИ ТипЗнч(СтрокаЗадолженности.ДокументЗадолженности) = Тип("ДокументСсылка.ПланЛечения") Тогда 
							// Если аванс учитывается в разрезе документов внесения
							НоваяСтрокаТЧ.ЭтоАванс       = Истина;
							НоваяСтрокаТЧ.ДокументАванса = СтрокаЗадолженности.ДокументЗадолженности;
						Иначе
							НоваяСтрокаТЧ.ДокументОснования = СтрокаЗадолженности.ДокументЗадолженности;
							НоваяСтрокаТЧ.ДокументАванса    = СтрокаЗадолженности.ДокументАванса;
						КонецЕсли;	
						НоваяСтрокаТЧ.Статья            = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(ДокументОплаты.ВидОперации, НоваяСтрокаТЧ.ЭтоАванс);
						НоваяСтрокаТЧ.Сумма             = ОстатокСуммыПлатежа;				
						ДокументОплаты.Статья           = ?(НоваяСтрокаТЧ.Статья <> ДокументОплаты.Статья, НоваяСтрокаТЧ.Статья, ДокументОплаты.Статья);
						ОплаченоПоДокументу             = ОстатокСуммыПлатежа;
						
						ОстатокЗадолженности            = ОстатокЗадолженности - ОплаченоПоДокументу;
						СтрокаОплаты.Сумма              = СтрокаОплаты.Сумма   - ОплаченоПоДокументу;	
						ДокументОплаты.СуммаДокумента   = ДокументОплаты.РасшифровкаПлатежа.Итог("Сумма");	
						
						ВСуммеОплаченоПоДокументу = ВСуммеОплаченоПоДокументу + ОплаченоПоДокументу;
					Иначе
						Контрагент = ?(ТипЗнч(ТаблицаВидовОплат) = Тип("ТаблицаЗначений") 
										И ТаблицаВидовОплат.Колонки.Найти("Контрагент") <> Неопределено
										И ЗначениеЗаполнено(СтрокаОплаты.Контрагент), 
										СтрокаОплаты.Контрагент, 
										СтрокаЗадолженности.ДокументЗадолженности.Контрагент);
										
						РезультатСтруктура = СформироватьОплатуБонуснымСчетомСтарая(
							Контрагент,
							СтрокаЗадолженности.ДокументЗадолженности, 
							ОстатокСуммыПлатежа,
							СписаниеАвансов,							
							СтрокаОплаты);
							
						СтрокаОплаты.ДокументОплаты = РезультатСтруктура.ДокументОбъект;
						ОстатокСуммыПлатежа			= РезультатСтруктура.ДоступноКОплате; 

					КонецЕсли;
				КонецЕсли;			
			КонецЦикла;
			
			РасшифровкаОплатВозвр.Добавить(Новый Структура("ДокументЗадолженности, СуммаОплаты", СтрокаЗадолженности.ДокументЗадолженности, ВСуммеОплаченоПоДокументу));
		КонецЕсли;
	КонецЦикла;	
	
	Возврат ТаблицаВидовОплат.ВыгрузитьКолонку("ДокументОплаты");
	
КонецФункции

//// ОплатаБонуснымСчетом

// Функция, вносит оплату бонусным счетом в табличную часть "СкидкиНаценки".
//
Функция СформироватьОплатуБонуснымСчетомСтарая(
	Контрагент,
	ДокументЗадолженности,
	ОстатокЗадолженности,
	ДокументыОплаты,
	СтрокаОплаты)
	
	СуммаДоступнаяДляОплатыБонуснымСчетом = УправлениеМаркетинговымиАкциями.ПолучитьСуммуДоступнуюДляОплатыБонуснымСчетомВРеализацииПриеме(
												ДокументЗадолженности, 
												СтрокаОплаты.БонусныйСчет);
	
	ДоступноКОплате = ?(ОстатокЗадолженности > СуммаДоступнаяДляОплатыБонуснымСчетом, СуммаДоступнаяДляОплатыБонуснымСчетом, ОстатокЗадолженности);	
	Если ДоступноКОплате > 0 Тогда
		
		ДокументОбъект = ПолучитьОбъектДокументаЗадолженности(ДокументыОплаты, ДокументЗадолженности);
		ИмяТабличнойЧасти = "";
		Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы", ДокументОбъект.Ссылка.Метаданные())
			И ДокументОбъект.Запасы.Количество() > 0 Тогда
			ИмяТабличнойЧасти = "Запасы";
		ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", ДокументОбъект.Ссылка.Метаданные())
			И ДокументОбъект.Лечение.Количество() > 0 Тогда
			ИмяТабличнойЧасти = "Лечение";
		ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", ДокументОбъект.Ссылка.Метаданные())
			И ДокументОбъект.Услуги.Количество() > 0 Тогда
			ИмяТабличнойЧасти = "Услуги";
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИмяТабличнойЧасти) Тогда 
			СтрокаТЧ 					  = ДокументОбъект.СкидкиНаценки.Добавить();
			СтрокаТЧ.БонусныйСчет  		  = СтрокаОплаты.БонусныйСчет;
			СтрокаТЧ.Использование 		  = Истина;
			СтрокаТЧ.КлючСтроки	   		  = ДокументОбъект[ИмяТабличнойЧасти][0].КлючСтроки;
			СтрокаТЧ.Контрагент	   		  = СтрокаОплаты.Контрагент;
			СтрокаТЧ.НоменклатураСкидки   = ДокументОбъект[ИмяТабличнойЧасти][0].Номенклатура;
			СтрокаТЧ.ПризнакОплатыБонусом = Истина;
			СтрокаТЧ.Сумма				  = ДоступноКОплате;
		КонецЕсли;
		ПересчитатьМаркетинговыеАкцииСтарая(ДокументОбъект);
		
	КонецЕсли;
	
	Возврат Новый Структура("СуммаОплаты", ДоступноКОплате);
	
КонецФункции

// Процедура пересчитвает маркетинговые акции.
//
Процедура ПересчитатьМаркетинговыеАкцииСтарая(РеализцияОбъект) Экспорт
	
	// Сохраняем список отключенных скидок  
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки = Новый ТаблицаЗначений;
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("КлючСтроки"	, Новый ОписаниеТипов("УникальныйИдентификатор"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("Использование", Новый ОписаниеТипов("Булево"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("СкидкаНаценка", Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
	ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Колонки.Добавить("Номенклатура"	, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	ЕстьТЧЗапасы  = ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы" , РеализцияОбъект.Ссылка.Метаданные()) = Истина;
	ЕстьТЧЛечение = ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", РеализцияОбъект.Ссылка.Метаданные()) = Истина;
	ЕстьТЧУслуги  = ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги" , РеализцияОбъект.Ссылка.Метаданные()) = Истина;
	
	Для Каждого СтрокаТЗ Из РеализцияОбъект.СкидкиНаценки Цикл
		НоваяСтрока = ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		НоваяСтрока.Номенклатура = СтрокаТЗ.НоменклатураСкидки;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из РеализцияОбъект.Подарки Цикл
		НоваяСтрока = ВременноХранениеПредыдщееСостояниеСкидкиПодарки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
	КонецЦикла;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ДатаСкидок"			, РеализцияОбъект.Дата);
	СтруктураПараметров.Вставить("Получатель"			, РеализцияОбъект.Контрагент);
	СтруктураПараметров.Вставить("Карта"				, РеализцияОбъект.КартаКонтрагента);
	СтруктураПараметров.Вставить("ОплатаБонуснымСчетом"	, Истина);
	
	УправлениеМаркетинговымиАкциями.РассчитатьСкидкиПриПродаже(
		РеализцияОбъект, 
		?(ЕстьТЧЗапасы , "Запасы" , Неопределено),
		?(ЕстьТЧЛечение, "Лечение", Неопределено),
		?(ЕстьТЧУслуги , "Услуги" , Неопределено),
		"СкидкиНаценки", 
		"Подарки", 
		ПолучитьТЧДоступныеОплатыБонусамиСтарая(РеализцияОбъект),
		ВременноХранениеПредыдщееСостояниеСкидкиПодарки,
		СтруктураПараметров);
		
	// Пересчитываем суммы
	Если ЕстьТЧЗапасы Тогда 
		Для Каждого СтрокаТЧ Из РеализцияОбъект.Запасы Цикл
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ПорядокОкругления"							, СтрокаТЧ.ВидЦен.ПорядокОкругления);
			СтруктураПараметров.Вставить("ОкруглятьВБольшуюСторону"						, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);
			СтруктураПараметров.Вставить("ЕстьКолонкаПроцентСкидкиНаценки"				, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки"	, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаКоличествоУпаковок"				, Истина);
			
			// Пересчитываем сумму строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
			// Пересчитываем сумму НДС строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
			// Пересчитываем всего строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
		КонецЦикла;	
	КонецЕсли;
	
	// Пересчитываем суммы
	Если ЕстьТЧЛечение Тогда 
		Для Каждого СтрокаТЧ Из РеализцияОбъект.Лечение Цикл
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ПорядокОкругления"							, СтрокаТЧ.ВидЦен.ПорядокОкругления);
			СтруктураПараметров.Вставить("ОкруглятьВБольшуюСторону"						, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);
			СтруктураПараметров.Вставить("ЕстьКолонкаПроцентСкидкиНаценки"				, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки"	, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаКоличествоУпаковок"				, Истина);
			
			// Пересчитываем сумму строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
			// Пересчитываем сумму НДС строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
			// Пересчитываем всего строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
		КонецЦикла;		
	КонецЕсли;
	
	// Пересчитываем суммы
	Если ЕстьТЧУслуги Тогда
		Для Каждого СтрокаТЧ Из РеализцияОбъект.Услуги Цикл
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ПорядокОкругления"							, СтрокаТЧ.ВидЦен.ПорядокОкругления);
			СтруктураПараметров.Вставить("ОкруглятьВБольшуюСторону"						, СтрокаТЧ.ВидЦен.ОкруглятьВБольшуюСторону);
			СтруктураПараметров.Вставить("ЕстьКолонкаПроцентСкидкиНаценки"				, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки"	, Истина);
			СтруктураПараметров.Вставить("ЕстьКолонкаКоличествоУпаковок"				, Истина);
			
			// Пересчитываем сумму строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ, СтруктураПараметров);
			// Пересчитываем сумму НДС строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
			// Пересчитываем всего строки ТЧ
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
		КонецЦикла;		
	КонецЕсли;
	
	РеализцияОбъект.СуммаДокумента = ?(ЕстьТЧЗапасы  , РеализцияОбъект.Запасы.Итог("Всего"), 0)
									+ ?(ЕстьТЧЛечение, РеализцияОбъект.Лечение.Итог("Всего"), 0)
									+ ?(ЕстьТЧУслуги , РеализцияОбъект.Услуги.Итог("Всего"), 0);
	
КонецПроцедуры

// Процедура, обработчик события "ПередЗаписью".
//
Функция ПолучитьТЧДоступныеОплатыБонусамиСтарая(РеализцияОбъект)
	
	ТаблицаИспользуемыхСкидокНаценок = РеализцияОбъект.СкидкиНаценки.Выгрузить(РеализцияОбъект.СкидкиНаценки.НайтиСтроки(Новый Структура("Использование", Истина)));
	
	ТаблицаОплатаБонусами = УправлениеМаркетинговымиАкциями.ЗапросПоОплатеБонусами(
								РеализцияОбъект, 
								РеализцияОбъект.Запасы.Выгрузить(),
								?(ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", РеализцияОбъект.Ссылка.Метаданные()) = Истина, РеализцияОбъект.Лечение.Выгрузить(), Неопределено),
								?(ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", РеализцияОбъект.Ссылка.Метаданные()) = Истина, РеализцияОбъект.Услуги.Выгрузить(), Неопределено),
								ТаблицаИспользуемыхСкидокНаценок);
								
	ТаблицаОплатаБонусами.Свернуть("БонусныйСчет, СуммаОстаток", "МаксимальнаяСуммаОплаты, СуммаДляРасчетаБонусов");
	
	СкидкаНаценкаОплатаБонусами = Новый ТаблицаЗначений;
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("БонусныйСчет"				, Новый ОписаниеТипов("СправочникСсылка.БонусныеСчета"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("СуммаОстаток"				, Новый ОписаниеТипов("Число"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("МаксимальнаяСуммаОплаты"	, Новый ОписаниеТипов("Число"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("Сумма"					, Новый ОписаниеТипов("Число"));
	СкидкаНаценкаОплатаБонусами.Колонки.Добавить("СуммаДляРасчетаБонусов"	, Новый ОписаниеТипов("Число"));
	
	ЗаполнитьТаблицуСкидокНаценокОплатБонусамиСтарая(ТаблицаОплатаБонусами, СкидкаНаценкаОплатаБонусами, РеализцияОбъект);
	
	// Проставляем сумму списания уже существущих оплат или добавляем для отображения
	Для Каждого СтрокаТЧ Из РеализцияОбъект.СкидкиНаценки Цикл
		Если СтрокаТЧ.ПризнакОплатыБонусом = Истина Тогда
			МассивНайденныеСтрока = СкидкаНаценкаОплатаБонусами.НайтиСтроки(Новый Структура("БонусныйСчет", СтрокаТЧ.БонусныйСчет));
			Если МассивНайденныеСтрока.Количество() > 0 Тогда
				МассивНайденныеСтрока[0].Сумма	= МассивНайденныеСтрока[0].Сумма + СтрокаТЧ.Сумма;
			Иначе
				НайденнаяСтрока = СкидкаНаценкаОплатаБонусами.Добавить();
				НайденнаяСтрока.БонусныйСчет	= СтрокаТЧ.БонусныйСчет;
				НайденнаяСтрока.Сумма			= НайденнаяСтрока.Сумма + СтрокаТЧ.Сумма;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СкидкаНаценкаОплатаБонусами;
	
КонецФункции    

// Процедура, заполняет переданную таблицу значений данными из ТаблицыОплатБонусами.
//
Процедура ЗаполнитьТаблицуСкидокНаценокОплатБонусамиСтарая(ТаблицаОплатаБонусами, ТаблицаСкидокНаценокОплатБонусами, РеализцияОбъект)
	
	// Заполняем таблицу остатками по бонусным счетам
	ТаблицаСкидокНаценокОплатБонусами.Очистить();
	Для Каждого СтрокаТЗ Из ТаблицаОплатаБонусами Цикл
		
		ПараметрыБонусногоСчета = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаТЗ.БонусныйСчет, "СрокДействияНачало, СрокДействияКонец");
		
		Если (ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияНачало) 
			И ПараметрыБонусногоСчета.СрокДействияНачало <= РеализцияОбъект.Дата
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияНачало))
			И (ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияКонец)
			И КонецДня(ПараметрыБонусногоСчета.СрокДействияКонец) >= РеализцияОбъект.Дата
			ИЛИ НЕ ЗначениеЗаполнено(ПараметрыБонусногоСчета.СрокДействияКонец)) Тогда
			
			НоваяСтрока = ТаблицаСкидокНаценокОплатБонусами.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
			НоваяСтрока.МаксимальнаяСуммаОплаты = ?(НоваяСтрока.СуммаОстаток < НоваяСтрока.МаксимальнаяСуммаОплаты, НоваяСтрока.СуммаОстаток, НоваяСтрока.МаксимальнаяСуммаОплаты);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Создать документ оплаты по нужному типу ден. средств
Функция СоздатьДокументОплатыПоТипуДенежныхСредствСтарая(ТипДенежныхСредств, ВидОперации) Экспорт
	
	Если ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда
		Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
			ДокОбъект = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
			ДокОбъект.Заполнить(Новый Структура("ТипДенежныхСредств, ВидОперации", ТипДенежныхСредств, ВидОперации));  
			
			Возврат ДокОбъект;
		ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
			
			ДокОбъект = Документы.СписаниеДенежныхСредств.СоздатьДокумент();
			ДокОбъект.Заполнить(Новый Структура("ТипДенежныхСредств, ВидОперации", ТипДенежныхСредств, ВидОперации));  
			
			Возврат ДокОбъект;
 
		КонецЕсли;
	Иначе	
		Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
			
			ДокОбъект = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
			ДокОбъект.Заполнить(Новый Структура("ТипДенежныхСредств, ВидОперации", ТипДенежныхСредств, ВидОперации));  
			
			Возврат ДокОбъект;
			
		ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
			
			ДокОбъект = Документы.СписаниеДенежныхСредств.СоздатьДокумент();
			ДокОбъект.Заполнить(Новый Структура("ТипДенежныхСредств, ВидОперации",ТипДенежныхСредств, ВидОперации));  
			
			Возврат ДокОбъект;
			
		КонецЕсли;
	КонецЕсли;
		
КонецФункции

// Получить признак необходимости перепроведения указанного документа
Функция ПроверитьНеобходимостьПерепроведенияРеализацииПослеОплатыСтарая(ДокументСсылка) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИСТИНА КАК Перепровести
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка = &ДокументСсылка
	|	И (Прием.СкидкиНаценки.ПризнакОплатыБонусом = ИСТИНА
	|			ИЛИ Прием.СкидкиНаценки.СкидкаНаценка.НачислениеБонусами = ИСТИНА)");
	
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	Возврат Не Запрос.Выполнить().Пустой();

КонецФункции

#КонецОбласти
