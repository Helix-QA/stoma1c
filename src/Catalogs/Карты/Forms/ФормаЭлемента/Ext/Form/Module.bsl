// Процедура, возвращает массив доступных видов карт.
//
Функция ПолучитьМассивДоступныхВидовКарт(ЭлектроннаяКарта)
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыКарт.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыКарт КАК ВидыКарт
	|ГДЕ
	|	НЕ ВидыКарт.ПометкаУдаления
	|	И &УсловиеВидКарты");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеВидКарты", ?(ЭлектроннаяКарта, "И ВидыКарт.ИдентификаторПроекта <> 0", "И ВидыКарт.ИдентификаторПроекта = 0"));
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	       	
КонецФункции

