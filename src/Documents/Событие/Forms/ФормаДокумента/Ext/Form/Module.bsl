&НаКлиенте
// Процедура - Изменение рабочего времени при редактировании приема
//
Процедура ИзменениеРабочегоВремениПриРедактированииПриема(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Если Результат = КодВозвратаДиалога.Да И ДополнительныеПараметры.Свойство("НесколькоВрачейВПриеме") <> Неопределено Тогда
			
			Если ДополнительныеПараметры.НесколькоВрачейВПриеме = Ложь Тогда
				УставитьИнтервалРабочегоВремениСотрудника(ДополнительныеПараметры.ВремяНачала, ДополнительныеПараметры.ВремяОкончания, ДополнительныеПараметры.Сотрудник, ДополнительныеПараметры.СтруктурнаяЕдиница);		
			Иначе
				
			ВремяУслугМассив = ДополнительныеПараметры.ДополнительныеПараметры;
			Для Каждого ВремяУслугиВрача Из ВремяУслугМассив Цикл
				УставитьИнтервалРабочегоВремениСотрудника(ВремяУслугиВрача.ВремяНачала, ВремяУслугиВрача.ВремяОкончания, ВремяУслугиВрача.ФИО, ДополнительныеПараметры.СтруктурнаяЕдиница);		
			КонецЦикла;
								
			КонецЕсли;
			
			ПризнакИзмененияВремениВрачей = Истина;
			
			ПараметрыЗаписи = Новый Структура;
			ПараметрыЗаписи.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
			Если ЭтаФорма.Записать(ПараметрыЗаписи) Тогда 
				Если ЭтаФорма.Открыта() Тогда
					ЭтаФорма.Закрыть();	
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда Возврат;
		КонецЕсли;
		
	Иначе Возврат;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Изменение рабочего времени для нескольких врачей
//
Функция ИзменениеРабочегоВремениДляНесколькихВрачей(ТаблицаУслуги)
	
	ТаблицаВрачей = Новый ТаблицаЗначений;
	ТаблицаВрачей.Колонки.Добавить("ФИО");
	ТаблицаВрачей.Колонки.Добавить("ВремяНачала");
	ТаблицаВрачей.Колонки.Добавить("ВремяОкончания");
	
	Для Каждого СтрокаТЧ Из ТаблицаУслуги Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник) Тогда
			// СтрокаТаблицы = ТаблицаВрачей.Найти(СтрокаТЧ.Сотрудник, "ФИО");	
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("ФИО", СтрокаТЧ.Сотрудник); 
			СтрокаТаблицы = ТаблицаВрачей.НайтиСтроки(СтруктураПоиска);
			
			
			Если СтрокаТаблицы.Количество() = 0 Тогда
				НоваяСтрока = ТаблицаВрачей.Добавить();
				НоваяСтрока.ФИО = СтрокаТЧ.Сотрудник;
				НоваяСтрока.ВремяНачала = СтрокаТЧ.ДатаНачала;
				НоваяСтрока.ВремяОкончания = СтрокаТЧ.ДатаОкончания;
			Иначе
				ИндексСтроки = ТаблицаВрачей.Индекс(СтрокаТаблицы[СтрокаТаблицы.ВГраница()]);
				КоличествоСтрокПоИндексу = ТаблицаВрачей.Количество() - 1;
				
				Если ИндексСтроки = КоличествоСтрокПоИндексу Тогда
					// Строка с этим врачем находится в конце списка
				    ТаблицаВрачей[ИндексСтроки].ВремяОкончания = СтрокаТЧ.ДатаОкончания;
				Иначе
					НоваяСтрока = ТаблицаВрачей.Добавить();
					НоваяСтрока.ФИО = СтрокаТЧ.Сотрудник;
					НоваяСтрока.ВремяНачала = СтрокаТЧ.ДатаНачала;
					НоваяСтрока.ВремяОкончания = СтрокаТЧ.ДатаОкончания;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;			
	КонецЦикла;
	
	// После обработки услуг перенесем все в массив для работы на клиенте:
	
	ВремяУслугМассив = Новый Массив();
    СтруктураСтрокой = "";
    НужнаЗапятая = Ложь;
	
    Для Каждого Колонка Из ТаблицаВрачей.Колонки Цикл
		
		Если НужнаЗапятая Тогда
            СтруктураСтрокой = СтруктураСтрокой + ",";
		КонецЕсли;
		
        СтруктураСтрокой = СтруктураСтрокой + Колонка.Имя;
        НужнаЗапятая = Истина;
		
	КонецЦикла;
	
    Для Каждого Строка Из ТаблицаВрачей Цикл
		
		НоваяСтрока = Новый Структура(СтруктураСтрокой);
        ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
        ВремяУслугМассив.Добавить(НоваяСтрока);
		
    КонецЦикла;
		
	// Убираем рабочие куски времени из массива, чтобы потом не обрабатывать все строки (не делать рабочее время там, где оно уже рабочее), а только необходимые	
	Для ИтераторОбходаМассива = 0 По ВремяУслугМассив.ВГраница() Цикл
		
		// Без этого не работает
		Если ИтераторОбходаМассива > ВремяУслугМассив.ВГраница() Тогда Прервать; КонецЕсли;
		
		СтрокаПроверкаРабочегоВремени = ВремяУслугМассив.Получить(ИтераторОбходаМассива);
		ВремяРабочее = ПроверитьВхождениеИнтервалаВРабочееВремяСотрудника(СтрокаПроверкаРабочегоВремени.ВремяНачала , СтрокаПроверкаРабочегоВремени.ВремяНачала, СтрокаПроверкаРабочегоВремени.ВремяОкончания, СтрокаПроверкаРабочегоВремени.ФИО, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);	 			
		
		Если ВремяРабочее Тогда
			ВремяУслугМассив.Удалить(ИтераторОбходаМассива);
			ИтераторОбходаМассива = ИтераторОбходаМассива - 1;
		КонецЕсли;
		
	КонецЦикла;
	
	
	Возврат (ВремяУслугМассив);
	
КонецФункции

