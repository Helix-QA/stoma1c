&НаСервереБезКонтекста
// Функция, создает канал мессенджера.
//
Функция СоздатьКонтактМессенджера(ВнешняяСистема, Контрагент, Знач НомерТелефона)
	
	НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь);
	НомерТелефона = ?(СтрДлина(НомерТелефона) > 10 И Лев(НомерТелефона, 1) = "8", "7" + Сред(НомерТелефона, 2), НомерТелефона);
	
	ИдКлиента = НомерТелефона + "@c.us";
	ИдСообщения	 = Строка(Новый УникальныйИдентификатор);
	
	ДанныеКонтакта = Новый Структура;
	ДанныеКонтакта.Вставить("ИдКлиента"		, ИдКлиента);
	ДанныеКонтакта.Вставить("ИдСообщения"	, ИдСообщения);
	
	КонтактСуществует = РегистрыСведений.КонтактыМессенджеров.КонтактМессенджераСуществует(ИдКлиента, ВнешняяСистема);
	
	Если КонтактСуществует = Истина Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			НСтр("ru = 'Контакт с таким номером уже привязан к другому клиенту'; en = 'Contact with this number already linked to another client'")
		);
		Возврат ДанныеКонтакта;
	КонецЕсли;
	
	НовыйДиалог					 = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
	НовыйДиалог.ИдДиалога		 = Строка(Новый УникальныйИдентификатор);
	НовыйДиалог.ВнешняяСистема	 = ВнешняяСистема;
	НовыйДиалог.ИдКлиента		 = ИдКлиента;
	НовыйДиалог.Начало			 = Дата(2022, 1, 1);
	НовыйДиалог.Окончание		 = Дата(2022, 1, 1);
	
	НовыйДиалог.Записать();
	
	РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(
		ИдКлиента,
		Контрагент,
		НомерТелефона,,
		ВнешняяСистема,
		ОбщегоНазначения.ПолучитьЗначениеРеквизита(Контрагент, "Наименование"),,,,
		НовыйДиалог.ИдДиалога
	);
	
	РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
		ИдКлиента,
		ИдСообщения,,,
		НСтр("ru = 'Создан контакт'"),
		Истина,
		Перечисления.Мессенджеры.whatsapp,
		Ложь,
		ТекущаяДатаСеанса(),
		ВнешняяСистема,,,,,,,,,
		НовыйДиалог.ИдДиалога,
		Истина
	);
	
	Возврат ДанныеКонтакта;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, создает сообщение с признаком ожидания сообщения.
//
Функция УстановитьОжиданиеСообщения(ИдКлиента, ВнешняяСистема, ОписаниеОшибки, Объект = Неопределено, НомерТелефона = "")
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		
		ДанныеКонтакта	 = СоздатьКонтактМессенджера(ВнешняяСистема, Объект, НомерТелефона);
		ИдКлиента		 = ДанныеКонтакта.ИдКлиента;
		ИдСообщения		 = ДанныеКонтакта.ИдСообщения;
		
	Иначе
		ИдСообщения = МессенджерСтоматология.ПолучитьИдОжидающегоСообщенияВМесенджер(ИдКлиента, ВнешняяСистема);
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		ОписаниеОшибки = НСтр("ru = 'Не удалось создать клиента в мессенджере.'; en = 'Failed to create messenger client.'");
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ИдСообщения;
	
КонецФункции

&НаСервере
// Процедура - устанавливает доступность элементов формы.
//
Процедура УстановитьВидимостьИДоступностьФормы()
	
	Если Не ЗначениеЗаполнено(ВзаимодействиеSMSСписокНомеровТелефонов) Тогда
		
		Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
			
			УстановитьНеАктивностьПереключателямSmsPushMessageНаСервере();
			
			Элементы.ГруппаКнопкиPush.ЦветФона    = Новый Цвет(25,  116, 206);	
			Элементы.ПереключательPush.ЦветТекста = Новый Цвет(255, 255, 255);
			
			ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление");
			
		КонецЕсли;
		
		Элементы.ПереключательSms.Доступность = Ложь;
		
	КонецЕсли;
	
	Если Не (ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеPushВнешняяСистемаWallet) И Справочники.Карты.КлиентУчаствуетВРассылкеWallet(ЭтотОбъект.Контрагент)) Тогда
		
		Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда
			
			УстановитьНеАктивностьПереключателямSmsPushMessageНаСервере();
			
			Элементы.ГруппаКнопкиПисьмо.ЦветФона    = Новый Цвет(25,  116, 206);	
			Элементы.ПереключательПисьмо.ЦветТекста = Новый Цвет(255, 255, 255);
			
			ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо");
			
		КонецЕсли;
		
		Элементы.ПереключательPush.Доступность = Ложь;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВзаимодействиеПисьмоАдресЭП) Тогда
		
		Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо") Тогда
			
			УстановитьНеАктивностьПереключателямSmsPushMessageНаСервере();
			
			Элементы.ГруппаКнопкиМессенджер.ЦветФона    = Новый Цвет(25,  116, 206);	
			Элементы.ПереключательМессенджер.ЦветТекста = Новый Цвет(255, 255, 255);
			
			ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер");
			
			Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Видимость = Ложь;
			Элементы.ГруппаВыбораВнешнейСистемыМессенджера.Видимость = Истина;
			
		КонецЕсли;
		
		Элементы.ПереключательПисьмо.Доступность = Ложь;
		
	КонецЕсли;
	
	Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо") Тогда
		Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость = Не НаличиеПочтовогоАккаунта();
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
		Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость     = Не НаличиеСервисаSMSРассылки();
	КонецЕсли;
	
	Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость = Не Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость ИЛИ Не Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость;
	
КонецПроцедуры

&НаКлиенте
// Процедура, создает sms рассылку.
//
Процедура СоздатьSMSРассылкуНаКлиенте()
	
	Элементы.ВзаимодействиеПисьмоТема.Видимость = ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо");
	Элементы.ГруппаВаимодействиеСделкаПредставление.Видимость		 = Ложь;
	Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость		 = Ложь;
	Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость	 = Ложь;
	Элементы.ВзаимодействиеSMSВыбратьШаблон.Видимость				 = Не (ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо"));
	
	Если ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
		
		НайденныеСтрокиКИ = ВзаимодействиеSMSСписокНомеровТелефонов; 
		
		Если ЗначениеЗаполнено(НайденныеСтрокиКИ) и ЗначениеЗаполнено(НайденныеСтрокиКИ[0].Значение) Тогда
			
			МассивНомеровТелефонов = Новый Массив;
			
			Для Каждого СтрокаКИ Из НайденныеСтрокиКИ Цикл
				МассивНомеровТелефонов.Добавить(СтрокаКИ.Значение);
			КонецЦикла;
			
			Если ЗначениеЗаполнено(МассивНомеровТелефонов) Тогда
				
				ЭтотОбъект.ВзаимодействиеSMSСписокНомеровТелефонов.ЗагрузитьЗначения(МассивНомеровТелефонов);
				
				Если Не (ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеКаналРассылки)
					И МассивНомеровТелефонов.Найти(ЭтотОбъект.ВзаимодействиеКаналРассылки) <> Неопределено) Тогда
					
					ЭтотОбъект.ВзаимодействиеКаналРассылки = МассивНомеровТелефонов[0];
				КонецЕсли;
				
				Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Заголовок  = ЭтотОбъект.ВзаимодействиеКаналРассылки;
				Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость = Не НаличиеСервисаSMSРассылки(); 
				Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость        = Не Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость;
				Элементы.ГруппаВаимодействиеСделкаПредставление.Видимость = ЗначениеЗаполнено(Контрагент); //ОбщегоНазначения.ЭтоВерсияКОРП() И 
				
				ЭтаФорма.ТекущийЭлемент = Элементы.ВзаимодействиеSMSТекст;
				
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У клиента запрещена рассылка sms сообщений");
			КонецЕсли;
			
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У клиента не задан номер телефона");
			
			ЭтотОбъект.ВзаимодействиеКаналРассылки = "";
			Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Заголовок = "Выбрать канал рассылки";
			
		КонецЕсли;
		
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда
		
		Элементы.ВзаимодействиеSMSСтатусВведенныхСимволов.Видимость	 = Ложь;
		Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Видимость	 = Ложь;
		Элементы.ГруппаПерейтиВЧат.Видимость						 = Ложь;
		Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость			 = Истина;
		
		ЭтаФорма.ТекущийЭлемент = Элементы.ВзаимодействиеSMSТекст;
		
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда 	
		
		Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость = Истина;
		
		ЭтаФорма.ТекущийЭлемент = Элементы.ВзаимодействиеSMSТекст;
		
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо") Тогда 
		
		НайденныеСтрокиКИ = ВзаимодействиеПисьмоСписокАдресовЭП;
		
		Если НЕ ЗначениеЗаполнено(НайденныеСтрокиКИ) ИЛИ НЕ ЗначениеЗаполнено(НайденныеСтрокиКИ[0].Значение) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У клиента не указан адрес электронной почты");
		КонецЕсли;
		
		Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость = Не НаличиеПочтовогоАккаунта();
		Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость         	  = Не Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость;
		Элементы.ГруппаВаимодействиеСделкаПредставление.Видимость     = ЗначениеЗаполнено(Контрагент); //ОбщегоНазначения.ЭтоВерсияКОРП() И 
		
		ЭтотОбъект.ВзаимодействиеКаналРассылки = НайденныеСтрокиКИ[0].Значение;
		Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Заголовок = ЭтотОбъект.ВзаимодействиеКаналРассылки;
		
		ЭтаФорма.ТекущийЭлемент = Элементы.ВзаимодействиеSMSТекст;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
