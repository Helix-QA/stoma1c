&НаСервереБезКонтекста
Функция ПолучитьМестаРаботы(Сотрудник) 
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СотрудникиМестаРаботы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ИЗ
		|	Справочник.Сотрудники.МестаРаботы КАК СотрудникиМестаРаботы
		|ГДЕ
		|	СотрудникиМестаРаботы.Ссылка = &Ссылка
		|	И СотрудникиМестаРаботы.Ссылка.ПометкаУдаления = ЛОЖЬ
		|	И СотрудникиМестаРаботы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Ссылка", Сотрудник);
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");
	
	Возврат Результат;
	
КонецФункции

// Функция - проверяет наличие Визита сотрудника
// 
Функция ПроверитьНаличиеВизита(Знач Сотрудник, Знач Период, Знач СписокПериодов, Знач СтруктурнаяЕдиница = Неопределено)
	
	ЕстьЗаписи = Ложь;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВложенныйЗапрос.Ссылка КАК Ссылка,
	               |	ВложенныйЗапрос.ДатаНачала КАК ДатаНачала,
	               |	ВложенныйЗапрос.ДатаОкончания КАК ДатаОкончания
	               |ИЗ
	               |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |		ПриемЛечение.Ссылка КАК Ссылка,
	               |		НАЧАЛОПЕРИОДА(ПриемЛечение.Ссылка.ВремяНачалаПриема, МИНУТА) КАК ДатаНачала,
	               |		НАЧАЛОПЕРИОДА(ПриемЛечение.Ссылка.ВремяОкончанияПриема, МИНУТА) КАК ДатаОкончания
	               |	ИЗ
	               |		Документ.Прием.Лечение КАК ПриемЛечение
	               |	ГДЕ
	               |		ПриемЛечение.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |		И ПриемЛечение.Сотрудник = &Сотрудник
	               |		И ПриемЛечение.Ссылка.Проведен = ИСТИНА
	               |		И НАЧАЛОПЕРИОДА(ПриемЛечение.Ссылка.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Период, ДЕНЬ)
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |		СобытиеУслуги.Ссылка,
	               |		СобытиеУслуги.ДатаНачала,
	               |		СобытиеУслуги.ДатаОкончания
	               |	ИЗ
	               |		Документ.Событие.Услуги КАК СобытиеУслуги
	               |	ГДЕ
	               |		СобытиеУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |		И СобытиеУслуги.Сотрудник = &Сотрудник
	               |		И СобытиеУслуги.Ссылка.Проведен = ИСТИНА
	               |		И СобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемНеСостоялся)
	               |		И СобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	               |		И НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Период, ДЕНЬ)) КАК ВложенныйЗапрос
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаНачала,
	               |	ДатаОкончания";

	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);	
	Запрос.УстановитьПараметр("Сотрудник"         , ?(ЗначениеЗаполнено(Сотрудник), Сотрудник, Неопределено));
	Запрос.УстановитьПараметр("Период"            , Период);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	СтрокаСобытияЕстьВПериоде = Ложь;
	Пока Результат.Следующий() Цикл 
		
		Для Каждого ЭлементСписка Из СписокПериодов Цикл
			
			// Если существует визит, пересекающийся с заданным периодом
			Если (Результат.ДатаНачала >= ЭлементСписка.Значение.НачалоРаботы И Результат.ДатаНачала < ЭлементСписка.Значение.ОкончаниеРаботы)
			ИЛИ  (Результат.ДатаНачала <= ЭлементСписка.Значение.НачалоРаботы И Результат.ДатаОкончания > ЭлементСписка.Значение.НачалоРаботы) Тогда
			
			    СтруктураВозврата = Новый Структура("НачалоРаботы, ОкончаниеРаботы", ЭлементСписка.Значение.НачалоРаботы, ЭлементСписка.Значение.ОкончаниеРаботы);
				Возврат СтруктураВозврата;
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
		
	Возврат Ложь;
	
КонецФункции

