&НаКлиенте
// Процедура, обработчик Команды "ЗаполнитьПоОстаткам
//
Процедура ЗаполнитьПоДокументуПоступления(Команда)
	
	ОткрытьФорму("Документ.Поступление.Форма.ФормаВыбора", Новый Структура("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница),,,,,Новый ОписаниеОповещения("ЗаполнитьПоДокументуПоступленияЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ЗаполнитьПоДокументуПоступленияЗавершение"
//
Процедура ЗаполнитьПоДокументуПоступленияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Документ = Результат;
		ЗаполнитьТаблицуТоваровНаСервере(Истина, Ложь, Ложь, Истина);
		ЭтаФорма.ТекущийЭлемент = Элементы.Печать;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды "ЗаполнитьПоДокументуПеремещения".
//
Процедура ЗаполнитьПоДокументуПеремещения(Команда)
	
	ОткрытьФорму("Документ.ПеремещениеЗапасов.Форма.ФормаВыбора", Новый Структура("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница),,,,,Новый ОписаниеОповещения("ЗаполнитьПоДокументуПеремещенияЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ЗаполнитьПоДокументуПеремещенияЗавершение"
//
Процедура ЗаполнитьПоДокументуПеремещенияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Документ = Результат;
		ЗаполнитьТаблицуТоваровНаСервере(Истина, Ложь, Ложь, Ложь, Истина);
		ЭтаФорма.ТекущийЭлемент = Элементы.Печать;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Нажатие"
//
Процедура Декорация_ДокументПоступленияНажатие(Элемент)
	
	Если Документ <> Неопределено Тогда 
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
			ОткрытьФорму("Документ.ПеремещениеЗапасов.ФормаОбъекта", Новый Структура("Ключ", Документ));
		Иначе
			ОткрытьФорму("Документ.Поступление.ФормаОбъекта", Новый Структура("Ключ", Документ));
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды "Печать".
//       
Процедура Печать(Команда)
	
	Если Объект.ШаблонДляПечати.Пустая() = Истина Тогда
	    ПоказатьПредупреждение(,НСтр("ru = 'Не выбран шаблон для печати'"));
		Возврат;
    КонецЕсли;
	
	Если Объект.Товары.НайтиСтроки(Новый Структура("Выбран", Истина)).Количество() = 0 Тогда
		
		 ПоказатьПредупреждение(,НСтр("ru = 'Не выбрано ни одного товара'"));
		Возврат;
		
	КонецЕсли;
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		
		ПараметрКоманды = Новый Массив;   // Добавим объект обработки печати ценников и этикеток в массив параметров печати.
		ПараметрКоманды.Добавить(Объект); // В дальнейшем будем обращаться к объекту через ПараметрКоманды[0]
		
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
			"Обработка.ПечатьЭтикетокИЦенников", // Для вызова метода менеджера обработки "Печать".
			"Ценники,Этикетки",
			ПараметрКоманды,
			ЭтаФорма, // Форма владелец
			Новый Структура("Режим", Режим));
		
	КонецЕсли;
	
КонецПроцедуры // Печать()

&НаСервере
// Процедура - обработчик события "ПриСохраненииДанныхВНастройкахНаСервере" формы.
//
Процедура ПриСохраненииДанныхВНастройкахНаСервере(Настройки)
	
	Если СохраненныеНастройки <> Неопределено Тогда
		
		Для Каждого КлючИЗначение Из СохраненныеНастройки Цикл
			// Обратное преобразование имени для хранения ключа соответствия для хранения в структуре
			ИмяКлюча = СтрЗаменить(КлючИЗначение.Ключ,"_QTQ_",".");
			ИмяКлюча = СтрЗаменить(ИмяКлюча,"_QPQ_"," ");
			Если ИмяКлюча = "_QQQ_" Тогда
				ИмяКлюча = "";
			КонецЕсли;
			Настройки.Вставить(ИмяКлюча, КлючИЗначение.Значение);
		КонецЦикла;
		
	Иначе		
		// Сохранение отбора выполняется только если это не печать из документа
		Настройки.Вставить("НастройкиОтбора",Новый ХранилищеЗначения(КомпоновщикНастроек.Настройки));		
	КонецЕсли;
	
КонецПроцедуры // ПриСохраненииДанныхВНастройкахНаСервере()

&НаСервере
// Процедура - обработчик события "ПриЗагрузкеДанныхИзНастроекНаСервере" формы.
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если Параметры.Свойство("АдресВХранилище") И ЗначениеЗаполнено(Параметры.АдресВХранилище) Тогда
		
		СохраненныеНастройки = Новый Структура;
		Для Каждого КлючИЗначение Из Настройки Цикл
			// Преобразование имени для хранения ключа соответствия для хранения в структуре
			ИмяКлюча = СтрЗаменить(КлючИЗначение.Ключ,".","_QTQ_");
			ИмяКлюча = СтрЗаменить(ИмяКлюча," ","_QPQ_");
			Если ИмяКлюча = "" Тогда
				ИмяКлюча = "_QQQ_";
			КонецЕсли;
			СохраненныеНастройки.Вставить(ИмяКлюча, КлючИЗначение.Значение);
		КонецЦикла;
		
		Настройки.Очистить();
		
	Иначе
		
		// ВидимостьОтбора = Настройки.Получить("ВидимостьОтбора");
		// Элементы.ГруппаОтбор.Видимость = ВидимостьОтбора;
		Элементы.Отбор.Заголовок = ?(ВидимостьОтбора, НСтр("ru = 'Скрыть отбор'"), НСтр("ru = 'Показать отбор'"));
		Объект.ШаблонДляПечати=Настройки.Получить("ШаблонДляПечати");
		Объект.Организация=Настройки.Получить("Организация");
        Объект.СтруктурнаяЕдиница=Настройки.Получить("СтруктурнаяЕдиница");
        Объект.ВидЦен=Настройки.Получить("ВидЦен");
        Объект.ЦеныНаДату=Настройки.Получить("ЦеныНаДату");
	
		НастройкиОтбора = Настройки.Получить("НастройкиОтбора");
		Если НастройкиОтбора <> Неопределено Тогда
			КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиОтбора.Получить());
		Иначе
			ЗагрузитьНастройкиОтбораПоУмолчанию();
		КонецЕсли;
		
		Режим = Настройки.Получить("Режим");
		Если ЗначениеЗаполнено(Режим) Тогда
			УстановитьРежим(Режим);
		КонецЕсли;
		
		ЦеныНаДату = Настройки.Получить("Объект.ЦеныНаДату");
		Если ЗначениеЗаполнено(ЦеныНаДату) Тогда		
			Объект.ЦеныНаДату = ЦеныНаДату;		
		Иначе		
			Объект.ЦеныНаДату = ТекущаяДата();		
		КонецЕсли;	
		
		СтруктурнаяЕдиниа = Настройки.Получить("СтруктурнаяЕдиниа");
		Если ЗначениеЗаполнено(СтруктурнаяЕдиниа) Тогда
			Объект.СтруктурнаяЕдиниа = СтруктурнаяЕдиниа;			
		КонецЕсли;	
		
	КонецЕсли;
		

	
КонецПроцедуры // ПриЗагрузкеДанныхИзНастроекНаСервере()

&НаКлиентеНаСервереБезКонтекста
//
//
Функция ПроверитьВозможностьВыбораТовара(ТекущиеДанные, Режим)
		
	Если ТекущиеДанные.КоличествоЦенников = 0 ИЛИ НЕ ЗначениеЗаполнено(ТекущиеДанные.ШаблонЦенника) Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
		
КонецФункции // ПроверитьВозможностьВыбораТовара()

