// Процедура заполнения данных документа по указанным параметрам начисления ЗП.
//
Процедура ЗаполнитьРасшифровкуДокументаПоДаннымЧисленияЗП()
	
	Объект.РасшифровкаПлатежа.Очистить();
	
	// Если выполняется режим заполнения по остаткам на указанный месяц расчета
	Если Объект.ВыплатаЗПРежимФормирования = 0 И ЗначениеЗаполнено(Объект.ВыплатаЗПМесяц) Тогда		
		ТаблицаЗадолженностей = РегистрыНакопления.РасчетыСПерсоналом.ПолучитьТаблицуЗадолженностиПередПерсоналом(Объект.ВыплатаЗПМесяц,,Объект.СтруктурнаяЕдиница,,Объект.Ссылка);
		Если Объект.ВыплатаЗПАванс Тогда
			ТаблицаЗадолженностей.Свернуть("СтруктурнаяЕдиница, Сотрудник", "Сумма");
		КонецЕсли;	
		Объект.РасшифровкаПлатежа.Загрузить(ТаблицаЗадолженностей);		
		// Если выполняется режим заполнения по документу начисления 
	ИначеЕсли Объект.ВыплатаЗПРежимФормирования = 1 Тогда		
		ТаблицаЗадолженностей = РегистрыНакопления.РасчетыСПерсоналом.ПолучитьТаблицуЗадолженностиПередПерсоналом(,Объект.ВыплатаЗПДокументОснования,Объект.СтруктурнаяЕдиница,,Объект.Ссылка);
		Объект.РасшифровкаПлатежа.Загрузить(ТаблицаЗадолженностей);					
		Объект.ВыплатаЗПМесяц = НачалоМесяца(Объект.ВыплатаЗПДокументОснования.ДатаНачалаПериода);		
	КонецЕсли;		
	Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("Сумма");
		
КонецПроцедуры

