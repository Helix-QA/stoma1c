// Процедура, обработчик настроек подбора номенклатуры.
//
Процедура НастройкаПодбораПриИзминении(Элемент)
	
	ТекущаяСтраница = СтрРазделить(Элемент.Родитель.Имя, "_", Ложь)[1];
	
	ТаблицыПодбора = Новый Массив;
	ТаблицыПодбора.Добавить("_ПодборНоменклатур");
	
	Если Элемент.Имя = "ОтображатьАртикулЛечение" ИЛИ Элемент.Имя = "ОтображатьАртикулЗапасы" Тогда
		НаименованиеРеквизита = "ОтображатьАртикул";
		ТаблицыПодбора.Добавить("_ПодборНоменклатурУслуги");
		НазваниеПоляСортировки = "Артикул";
		
	ИначеЕсли Элемент.Имя = "ОтображатьЦенуЛечение" ИЛИ Элемент.Имя = "ОтображатьЦенуЗапасы" Тогда
		НаименованиеРеквизита = "ОтображатьЦену";
		ТаблицыПодбора.Добавить("_ПодборНоменклатурУслуги");
		НазваниеПоляСортировки = "Цена";
		
	ИначеЕсли Элемент.Имя = "ОтображатьОстатокЗапасы" Тогда
		НаименованиеРеквизита = "ОтображатьОстаток";
		НазваниеПоляСортировки = "Количество";
				
	КонецЕсли;
			
	ПараметрыНастройки = ПолучитьПараметрыНастройки(НаименованиеРеквизита, ТаблицыПодбора);
	
	Если ПараметрыНастройки.КолонкаТаб1 <> Неопределено Тогда
		ПараметрыНастройки.КолонкаТаб1.Видимость = ЭтотОбъект[НаименованиеРеквизита];
	КонецЕсли;
	
	Если ПараметрыНастройки.КолонкаТаб2 <> Неопределено Тогда
		ПараметрыНастройки.КолонкаТаб2.Видимость = ЭтотОбъект[НаименованиеРеквизита];
	КонецЕсли;
	
	// Сделаем сортировку по наименованию,
	// если колонку предыдущей сортировки скрыли (выключили).
	
	ОбновитьТаблицуНазвание = Новый СписокЗначений;
	
	Если НЕ ЭтотОбъект[НаименованиеРеквизита] Тогда
		
		ТребуетсяОбновитьПодборУслуг = Ложь;
		ТребуетсяОбновитьПодборЗапасов = Ложь;
		
		Если ЭтотОбъект.ПолеСортировкиУслуг = НазваниеПоляСортировки Тогда
			НастройкаСортировкиПодбораЗавершение(Новый Структура("Значение, Представление", "Наименование", "Наименование"), Новый Структура("ТекущаяСтраница", "Лечение"));	
			ТребуетсяОбновитьПодборУслуг = Истина;
		КонецЕсли;
				
		Если ЭтотОбъект.ПолеСортировкиЗапасов = НазваниеПоляСортировки Тогда 		
			НастройкаСортировкиПодбораЗавершение(Новый Структура("Значение, Представление", "Наименование", "Наименование"), Новый Структура("ТекущаяСтраница", "Запасы"));	
			ТребуетсяОбновитьПодборЗапасов = Истина;
		КонецЕсли;
				
        ПринудительноеОбновлениеТаблицыПодбора = ?(ТекущаяСтраница = "Лечение", ?(ТребуетсяОбновитьПодборЗапасов, "_ПодборНоменклатур", ""),
																				?(ТребуетсяОбновитьПодборУслуг, "_ПодборНоменклатурУслуги", ""));
							
	КонецЕсли;
	
