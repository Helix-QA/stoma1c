
&НаКлиенте
Перем COMОбъект;
&НаКлиенте
Перем WSHShell;
&НаКлиенте
Перем ПолеЛогин, ПолеПароль, ПолеНаименованиеОрганизации, ПолеФИОРуководителя, ПолеДолжностьРуководителя, ПолеИНН, ПолеКПП, ПолеАдрес, ПолеEmail, ПолеТелефон;
&НаКлиенте
Перем НажимаемаяКнопка, НомерШагаПолученияПодписи;
&НаКлиенте
Перем АвторизацияПройдена, РеквизитыОрганизацииЗаполнены;


#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - Обработка события ПриСозданииНаСервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("НеСоздаватьНовуюПодпись")
		И Параметры.НеСоздаватьНовуюПодпись Тогда
		
		ЭтотОбъект.НеСоздаватьНовуюПодпись = Истина;
	КонецЕсли;
	
	Если Параметры.Свойство("СервисSMS") Тогда
		ЭтотОбъект.СервисSMS = Параметры.СервисSMS;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка события ПриОткрытии
//
Процедура ПриОткрытии(Отказ)
	
	НомерШагаПолученияПодписи = 0;
	
	#Если не ВебКлиент Тогда
		Системнаяинформация = Новый Системнаяинформация;
		Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 
			WSHShell = Новый COMОбъект("WScript.Shell");
		КонецЕсли;
	#Конецесли
	// Отобразить стартовую страницу
	HtmlText = "http://my.smsws.ru/Auth?redirectUrl=%2F";
	ЭтотОбъект.ПолеHTML = HtmlText;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - Обработка события ДокументСформирован
//
Процедура ПолеHTMLДокументСформирован(Элемент)
	
	COMОбъект = Элементы.ПолеHTML.Документ;
	
	Если АвторизацияПройдена <> Истина
		И ПолучитьНомерТекущейФормы() = 0 Тогда
		
		Если ПолеЛогин <> Неопределено
			И ПолеПароль <> Неопределено Тогда
			
			Возврат;
		КонецЕсли;
		
		ЗаполнитьЛогинИПарольДляАвторизации();
		
		// Поиск кнопки "Войти"
		ГруппаЭлементов = Элемент.Документ.getElementsByClassName("btn btn-default pull-right");
		Для Каждого Кнопка Из ГруппаЭлементов Цикл
			НажимаемаяКнопка = Кнопка;
		КонецЦикла;
		
		Если ПолеЛогин <> Неопределено
			И ПолеПароль <> Неопределено Тогда
			
			ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.1, Истина);
			
		КонецЕсли;
		
	ИначеЕсли ПолучитьНомерТекущейФормы() = 1
		И НЕ ЭтотОбъект.НеСоздаватьНовуюПодпись Тогда
		
		// Добавить новое имя отправителя
		ГруппаЭлементов = Элемент.Документ.getElementsByClassName("btn btn-default");
		
		Для Каждого Кнопка Из ГруппаЭлементов Цикл
			
			АтрибутПривязки = Кнопка.getAttributeNode("data-bind");
			
			Если АтрибутПривязки.nodeValue = "click: newSenderId" Тогда
				
				Кнопка.click();
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура заполняет реквизиты атворизации
//
Процедура ЗаполнитьЛогинИПарольДляАвторизации()
	
	ГруппаЭлементов = COMОбъект.getElementsByClassName("form-control");
	
	Для Каждого ПолеЭлемента Из ГруппаЭлементов Цикл
		
		СтруктураВозврата = ПолучитьЛогинИПарольСервисаСМС(ЭтотОбъект.СервисSMS);
		
		АтрибутПривязки = ПолеЭлемента.getAttributeNode("data-bind");
		
		Если СтрНайти(АтрибутПривязки.nodeValue, "value: login") Тогда
			
			ПолеЭлемента.value = СтруктураВозврата.Логин;
			ПолеЛогин   	   = ПолеЭлемента;
			
		КонецЕсли;
		
		Если СтрНайти(АтрибутПривязки.nodeValue, "value: password") Тогда
			
			ПолеЭлемента.value = СтруктураВозврата.Пароль;
			ПолеПароль  	   = ПолеЭлемента;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Прцоедура - Обработка события ПриНажатии
//
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	НажатыйЭлемент = ДанныеСобытия.Element;
	
	Если НажатыйЭлемент <> Неопределено Тогда
		
		Если НажатыйЭлемент.className = "btn btn-success" Тогда
			
			Если ПолучитьНомерТекущейФормы() = 1 Тогда
				
				ЗаполнитьРеквизитыОрганизацииНаФорме();
				
				НомерШагаПолученияПодписи = 3;
				ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.5, Истина);
				
			ИначеЕсли ПолучитьНомерТекущейФормы() = 3 Тогда
				
				ГруппаЭлементов = Элемент.Документ.getElementsByClassName("btn btn-success");
				
				Для Каждого Кнопка Из ГруппаЭлементов Цикл
					
					АтрибутПривязки = Кнопка.getAttributeNode("data-bind");
					
					Если СтрНайти(АтрибутПривязки.nodeValue, "click: nextStep") Тогда
						
						НажимаемаяКнопка = Кнопка;
						Прервать;
						
					КонецЕсли;
					
				КонецЦикла;
				
				НомерШагаПолученияПодписи = 9;
				ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.5, Истина);
				
			ИначеЕсли ПолучитьНомерТекущейФормы() = 5 Тогда
				
				НомерШагаПолученияПодписи = 10;
				ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.1, Истина);
				
			КонецЕсли;
			
		ИначеЕсли НажатыйЭлемент.className = "btn btn-primary btn-sm pull-right" Тогда
			АвторизацияПройдена = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - Сформировать значение для ввода в поле элемента
//
Функция СформироватьЗначениеДляВводаВПолеЭлемента(Значение)
	
	Возврат ?(РеквизитыОрганизацииЗаполнены = Истина, Значение + "*", "*" + Значение);
	
КонецФункции

&НаКлиенте
// Процедура заполняет реквизиты организации
//
Процедура ЗаполнитьРеквизитыОрганизацииНаФорме()
	
	СтруктураДанных = ПолучитьСтруктуруДанныхОрганизации();
	ГруппаЭлементов = COMОбъект.getElementsByClassName("col-sm-9");
	
	Для Каждого ЭлементМассива Из ГруппаЭлементов Цикл
		
		Для Каждого ПолеЭлемента Из ЭлементМассива.all Цикл
			
			АтрибутПривязки = ПолеЭлемента.getAttributeNode("data-bind");
			
			Если ЗначениеЗаполнено(ПолеЭлемента.value)
				И СтрНайти(АтрибутПривязки.nodeValue, "name") = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если СтрНайти(АтрибутПривязки.nodeValue, "name") <> 0 Тогда
				
				НаименованиеОрганизации = "";
				
				Если НЕ СтруктураДанных.ЮрЛицо
					И НЕ СтрНачинаетсяС(ПолеЭлемента.value, "ИП") Тогда
					
					НаименованиеОрганизации = "ИП " + ?(ЗначениеЗаполнено(ПолеЭлемента.value), ПолеЭлемента.value, СтруктураДанных.НаименованиеОрганизации);
				Иначе
					НаименованиеОрганизации = ?(ЗначениеЗаполнено(ПолеЭлемента.value), ПолеЭлемента.value, СтруктураДанных.НаименованиеОрганизации);
				КонецЕсли;
				
				ПолеЭлемента.value 	  	  	= СформироватьЗначениеДляВводаВПолеЭлемента(СтруктураДанных.НаименованиеОрганизации);
				ПолеНаименованиеОрганизации = ПолеЭлемента;
				
			ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "headName") <> 0 Тогда
				
				ПолеЭлемента.value 	  	    = СформироватьЗначениеДляВводаВПолеЭлемента(СтруктураДанных.ФИОРуководителя);
				ПолеФИОРуководителя   	    = ПолеЭлемента;
				
			ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "headPosition") <> 0 Тогда
				
				ПолеЭлемента.value          = СформироватьЗначениеДляВводаВПолеЭлемента(СтруктураДанных.ДолжностьРуководителя);
				ПолеДолжностьРуководителя   = ПолеЭлемента;
				
			ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "address") <> 0 Тогда
				
				ПолеЭлемента.value 	  	    = СформироватьЗначениеДляВводаВПолеЭлемента(СтруктураДанных.ЮридическийАдрес);
				ПолеАдрес 			        = ПолеЭлемента;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ГруппаЭлементов = COMОбъект.getElementsByClassName("col-xs-2");
	
	Для Каждого ЭлементМассива Из ГруппаЭлементов Цикл
		
		Для Каждого ПолеЭлемента Из ЭлементМассива.all Цикл
			
			Если ЗначениеЗаполнено(ПолеЭлемента.value) Тогда
				Продолжить;
			КонецЕсли;
			
			АтрибутПривязки = ПолеЭлемента.getAttributeNode("data-bind");
			
			Если СтрНайти(АтрибутПривязки.nodeValue, "inn") <> 0 Тогда
				
				ПолеЭлемента.value = СформироватьЗначениеДляВводаВПолеЭлемента(СтруктураДанных.ИНН);
				ПолеИНН 		   = ПолеЭлемента;
				
			ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "kpp") <> 0 Тогда
				
				ПолеЭлемента.value = СформироватьЗначениеДляВводаВПолеЭлемента(СтруктураДанных.КПП);
				ПолеКПП 		   = ПолеЭлемента;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ГруппаЭлементов = COMОбъект.getElementsByClassName("col-sm-4");
	
	Для Каждого ЭлементМассива Из ГруппаЭлементов Цикл
		
		Для Каждого ПолеЭлемента Из ЭлементМассива.all Цикл
			
			АтрибутПривязки = ПолеЭлемента.getAttributeNode("data-bind");
			
			Если СтрНайти(АтрибутПривязки.nodeValue, "email") <> 0 Тогда
				
				Если ЗначениеЗаполнено(ПолеЭлемента.value) Тогда
					ПолеЭлемента.value = СтруктураДанных.Email;
				КонецЕсли;
				
			ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "phone") <> 0 Тогда
				
				ПолеЭлемента.value = СтруктураДанных.Телефон;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура заполняет элементы поля HTML с обработкой ожидания
//
Процедура ЗаполнитьЭлементыФормыСОбработкойОжидания()
	
	Если НомерШагаПолученияПодписи = 0 Тогда
		
		ПолеЛогин.focus();
		WSHShell.SendKeys("{Backspace}");
		
		НомерШагаПолученияПодписи = 1;
		ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.1, Истина);
		
	ИначеЕсли НомерШагаПолученияПодписи = 1 Тогда
		
		ПолеПароль.focus();
		WSHShell.SendKeys("{Backspace}");
		
		НомерШагаПолученияПодписи = 2;
		ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.1, Истина);
		
	ИначеЕсли НомерШагаПолученияПодписи = 2 Тогда
		
		НажимаемаяКнопка.click();
		НажимаемаяКнопка 	= Неопределено;
		АвторизацияПройдена = Истина;
		
	КонецЕсли;
	
	Если НомерШагаПолученияПодписи = 3 Тогда
		
		Если ПолучитьНомерТекущейФормы() = 2 Тогда
			СэмулироватьНажатиеКлавиши(ПолеНаименованиеОрганизации);
		КонецЕсли;
		
	ИначеЕсли НомерШагаПолученияПодписи = 4 Тогда
		
		СэмулироватьНажатиеКлавиши(ПолеФИОРуководителя);
		
	ИначеЕсли НомерШагаПолученияПодписи = 5 Тогда
		
		СэмулироватьНажатиеКлавиши(ПолеДолжностьРуководителя);
		
	ИначеЕсли НомерШагаПолученияПодписи = 6 Тогда
		
		СэмулироватьНажатиеКлавиши(ПолеАдрес);
		
	ИначеЕсли НомерШагаПолученияПодписи = 7 Тогда
		
		СэмулироватьНажатиеКлавиши(ПолеИНН);
		
	ИначеЕсли НомерШагаПолученияПодписи = 8 Тогда
		
		СэмулироватьНажатиеКлавиши(ПолеКПП);
		РеквизитыОрганизацииЗаполнены = Истина;
		
	ИначеЕсли НомерШагаПолученияПодписи = 9 Тогда
		
		Если ПолучитьНомерТекущейФормы() = 3
			И НажимаемаяКнопка <> Неопределено Тогда
			НажимаемаяКнопка.click();
		КонецЕсли;
		
	ИначеЕсли НомерШагаПолученияПодписи = 10 Тогда
		
		Оповестить("ИзмененаПодписьСервисаСМС");
		ЭтаФорма.Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сымитировать нажатие delete
//
Процедура СэмулироватьНажатиеКлавиши(ПолеВвода)
	
	Если ПолеВвода <> Неопределено Тогда
		
		ПолеВвода.focus();
		Если РеквизитыОрганизацииЗаполнены <> Истина Тогда
			WSHShell.SendKeys("{DELETE}");
		Иначе
			WSHShell.SendKeys("{Backspace}");
		КонецЕсли;
		
		ПолеВвода = Неопределено;
		
	КонецЕсли;
	
	Если НомерШагаПолученияПодписи < 8 Тогда
		НомерШагаПолученияПодписи = НомерШагаПолученияПодписи + 1;
		ПодключитьОбработчикОжидания("ЗаполнитьЭлементыФормыСОбработкойОжидания", 0.1, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция определяет номер этапа добавления подписи
//
Функция ПолучитьНомерТекущейФормы()
	
	МассивГрупп = COMОбъект.getElementsByClassName("modal-body");
	
	Для Каждого Группа Из МассивГрупп Цикл
		
		Для Каждого ВложеннаяГруппа Из Группа.children Цикл
			
			Для Каждого ВложеннаяГруппа2 Из ВложеннаяГруппа.children Цикл
				
				АтрибутПривязки = ВложеннаяГруппа2.getAttributeNode("data-bind");
				АтрибутСтиля 	= ВложеннаяГруппа2.getAttributeNode("style");
				
				Если АтрибутПривязки = Неопределено Или АтрибутСтиля = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Если СтрНайти(АтрибутСтиля.nodeValue, "display: none") = 0 Тогда
					
					Если СтрНайти(АтрибутПривязки.nodeValue, "currentStep() == 1") <> 0 Тогда
						Возврат 1;
					ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "currentStep() == 2") <> 0 Тогда
						Возврат 2;
					ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "currentStep() == 3") <> 0 Тогда
						Возврат 3;
					ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "currentStep() == 4") <> 0 Тогда
						Возврат 4;
					ИначеЕсли СтрНайти(АтрибутПривязки.nodeValue, "currentStep() == 5") <> 0 Тогда
						Возврат 5;
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

#Область ДополнительныеФункции

&НаСервереБезКонтекста
// Функция возвращает структуру данных по организации
//
Функция ПолучитьСтруктуруДанныхОрганизации()
	
	ТекущаяОрганизация = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
	
	КонтактнаяИнформация = МенеджерОборудованияВызовСервера.ПолучитьКонтактнуюИнформацию(ТекущаяОрганизация);
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ФИОРуководителя"		  , ТекущаяОрганизация.ФИОРуководителя.Наименование);
	СтруктураДанных.Вставить("ДолжностьРуководителя"  , ТекущаяОрганизация.ДолжностьРуководителя.Наименование);
	СтруктураДанных.Вставить("ИНН"					  , ТекущаяОрганизация.ИНН);
	СтруктураДанных.Вставить("КПП"					  , ТекущаяОрганизация.КПП);
	СтруктураДанных.Вставить("ЮрЛицо"			  	  , (ТекущаяОрганизация.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо));
	СтруктураДанных.Вставить("НаименованиеОрганизации", ТекущаяОрганизация.ПолноеНаименование);
	СтруктураДанных.Вставить("ЮридическийАдрес"		  , ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ТекущаяОрганизация, "Юридический"));
	СтруктураДанных.Вставить("Email"				  , КонтактнаяИнформация.Email);
	СтруктураДанных.Вставить("Телефон"		  		  , КонтактнаяИнформация.Телефон);
	
	Возврат СтруктураДанных;
	
КонецФункции

&НаСервереБезКонтекста
// Функция возвращает логин и пароль Сервиса СМС
//
Функция ПолучитьЛогинИПарольСервисаСМС(СервисSMS)
	
	Возврат Новый Структура("Логин, Пароль", СервисSMS.Пользователь, СервисSMS.Пароль);
	
КонецФункции

#КонецОбласти

#КонецОбласти