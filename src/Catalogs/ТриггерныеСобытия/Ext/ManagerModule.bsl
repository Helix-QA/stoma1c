				ТриггерВзносНаЛицевойСчет 							= ГенерируемыйТриггер.ПолучитьОбъект();
			Иначе 	
				// Генерируем триггер
				ТриггерВзносНаЛицевойСчет 							= СоздатьЭлемент();
			КонецЕсли;
			ТриггерВзносНаЛицевойСчет.Активно 						= Истина;
			ТриггерВзносНаЛицевойСчет.Наименование 					= ?(ЗначениеЗаполнено(ГенерируемыйТриггер), ТриггерВзносНаЛицевойСчет.Наименование, НСтр("ru = 'Взнос на лицевой счет';en= 'Contribution to a personal account'"));
