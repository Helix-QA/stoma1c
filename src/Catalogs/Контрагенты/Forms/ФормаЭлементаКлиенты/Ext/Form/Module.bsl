		НазваниеЭлемента = "СМС";
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMSМессенджер = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда
		НазваниеЭлемента = "Push";
	ИначеЕсли ЭтотОбъект.ТипСообщенияPushSMSМессенджер = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
