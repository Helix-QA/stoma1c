&НаКлиенте
// Процедура - обработчик команды "Загрузить".
//
Процедура Загрузить(Команда)
	
	Если СоздаватьНенайденнуюНоменклатуру И ПапкаДляНовыйНоменклатуры.Пустая() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Поле ""Папка"" не заполнено.");
		Возврат;
	КонецЕсли;
	
	МассивСтрок = Объект.ТаблицаСоответсвийПолей.НайтиСтроки(Новый Структура("РеквизитСправочника", КлючеваяСтрокаТЧ));
	ЗначениеКлючевойСтрокиТЧ = ?(МассивСтрок.Количество() > 0, МассивСтрок[0].КолонкаФайла, Неопределено);
	Если ПустаяСтрока(ЗначениеКлючевойСтрокиТЧ) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Поле ""Колонка файла"" по реквизиту "+КлючеваяСтрокаТЧ+" не заполнено.");
		Возврат;
	КонецЕсли;
	
	ЗагрузитьИзExcel();
	
КонецПроцедуры

