#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции	
	
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаПеремещениеЗапасов, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПеремещениеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	|	ПеремещениеЗапасовЗапасы.Ссылка КАК Документ,
	|	ПеремещениеЗапасовЗапасы.Ссылка.Склад КАК Склад,
	|	ПеремещениеЗапасовЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПеремещениеЗапасовЗапасы.Ссылка.СкладПолучатель КАК СкладПолучатель,
	|	ПеремещениеЗапасовЗапасы.Ссылка.СтруктурнаяЕдиницаПолучатель КАК СтруктурнаяЕдиницаПолучатель,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПеремещениеЗапасовЗапасы.Ссылка.Дата КАК Период,
	|	ПеремещениеЗапасовЗапасы.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА ПеремещениеЗапасовЗапасы.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	ПеремещениеЗапасовЗапасы.Количество КАК Количество
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасы
	|ИЗ
	|	Документ.ПеремещениеЗапасов.Запасы КАК ПеремещениеЗапасовЗапасы
	|ГДЕ
	|	ПеремещениеЗапасовЗапасы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПеремещениеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	|	ПеремещениеЗапасовЗапасы.Ссылка.Дата КАК Период,
	|	ПеремещениеЗапасовЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы) КАК СчетДт,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы) КАК СчетКт,
	|	ПеремещениеЗапасовЗапасы.Номенклатура КАК СубконтоДт1,
	|	ПеремещениеЗапасовЗапасы.Ссылка.СкладПолучатель КАК СубконтоДт2,
	|	ПеремещениеЗапасовЗапасы.Номенклатура КАК СубконтоКт1,
	|	ПеремещениеЗапасовЗапасы.Ссылка.Склад КАК СубконтоКт2,
	|	0 КАК Сумма,
	|	ВЫБОР
	|		КОГДА ПеремещениеЗапасовЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|				ИЛИ ПеремещениеЗапасовЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Материал)
	|			ТОГДА ПеремещениеЗапасовЗапасы.Количество
	|	КОНЕЦ КАК Количество,
	|	""Перемещение запасов"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.ПеремещениеЗапасов.Запасы КАК ПеремещениеЗапасовЗапасы
	|ГДЕ
	|	ПеремещениеЗапасовЗапасы.Ссылка = &Ссылка
	|	И ПеремещениеЗапасовЗапасы.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество)";
	
	Запрос.УстановитьПараметр("Ссылка"            , ДокументСсылкаПеремещениеЗапасов);
	Запрос.УстановитьПараметр("ИспользоватьПартии", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьПартии);
	
	Запрос.ВыполнитьПакет();
	СформироватьТаблицаЗапасыНаСкладах(СтруктураДополнительныеСвойства);
	СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗапасыНаСкладах(СтруктураДополнительныеСвойства)
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МИНИМУМ(ТаблицаЗапасыНаСкладах.НомерСтроки) КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаЗапасыНаСкладах.Период КАК Период,
	|	ТаблицаЗапасыНаСкладах.Склад КАК Склад,
	|	ТаблицаЗапасыНаСкладах.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаЗапасыНаСкладах.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасыНаСкладах.Партия КАК Партия,
	|	СУММА(ТаблицаЗапасыНаСкладах.Количество) КАК Количество
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаЗапасыНаСкладах
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаЗапасыНаСкладах.Период,
	|	ТаблицаЗапасыНаСкладах.Склад,
	|	ТаблицаЗапасыНаСкладах.СтруктурнаяЕдиница,
	|	ТаблицаЗапасыНаСкладах.Номенклатура,
	|	ТаблицаЗапасыНаСкладах.Партия
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	МИНИМУМ(ТаблицаЗапасыНаСкладах.НомерСтроки),
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаЗапасыНаСкладах.Период,
	|	ТаблицаЗапасыНаСкладах.СкладПолучатель,
	|	ТаблицаЗапасыНаСкладах.СтруктурнаяЕдиницаПолучатель,
	|	ТаблицаЗапасыНаСкладах.Номенклатура,
	|	ТаблицаЗапасыНаСкладах.Партия,
	|	СУММА(ТаблицаЗапасыНаСкладах.Количество)
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаЗапасыНаСкладах
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаЗапасыНаСкладах.Период,
	|	ТаблицаЗапасыНаСкладах.СкладПолучатель,
	|	ТаблицаЗапасыНаСкладах.СтруктурнаяЕдиницаПолучатель,
	|	ТаблицаЗапасыНаСкладах.Номенклатура,
	|	ТаблицаЗапасыНаСкладах.Партия";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасыНаСкладах", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаЗапасыНаСкладах()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ВременнаяТаблицаУправленческий.Период,
	|	ВременнаяТаблицаУправленческий.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаУправленческий.СчетДт,
	|	ВременнаяТаблицаУправленческий.СчетКт,
	|	ВременнаяТаблицаУправленческий.СубконтоДт1,
	|	ВременнаяТаблицаУправленческий.СубконтоДт2,
	|	ВременнаяТаблицаУправленческий.СубконтоКт1,
	|	ВременнаяТаблицаУправленческий.СубконтоКт2,
	|	СУММА(ВременнаяТаблицаУправленческий.Сумма) КАК Сумма,
	|	СУММА(ВременнаяТаблицаУправленческий.Количество) КАК Количество,
	|	ВременнаяТаблицаУправленческий.Содержание
	|ИЗ
	|	ВременнаяТаблицаУправленческий КАК ВременнаяТаблицаУправленческий
	|
	|СГРУППИРОВАТЬ ПО
	|	ВременнаяТаблицаУправленческий.Период,
	|	ВременнаяТаблицаУправленческий.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаУправленческий.СчетДт,
	|	ВременнаяТаблицаУправленческий.СчетКт,
	|	ВременнаяТаблицаУправленческий.СубконтоДт1,
	|	ВременнаяТаблицаУправленческий.СубконтоДт2,
	|	ВременнаяТаблицаУправленческий.СубконтоКт1,
	|	ВременнаяТаблицаУправленческий.СубконтоКт2,
	|	ВременнаяТаблицаУправленческий.Содержание";
	
	РезультатЗапроса = Запрос.Выполнить();	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаУправленческий", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры


// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФормуНакладнойНаПеремещениеТоваров(МассивОбъектов, ОбъектыПечати)
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_Накладная";
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПеремещениеЗапасов.ПФ_MXL_НакладнаяНаПеремещение");
	
	// ОбластьЗаголовка  = Макет.ПолучитьОбласть("Заголовок");
	ОбластьНомераЗаголовок = Макет.ПолучитьОбласть("Заголовок|НомерСтроки");
	ОбластьКодовЗаголовок  =  Макет.ПолучитьОбласть("Заголовок|КолонкаКодов");
	ОбластьУпаковокЗаголовок  =  Макет.ПолучитьОбласть("Заголовок|КолонкаУпаковок");
	ОбластьДанныхЗаголовок = Макет.ПолучитьОбласть("Заголовок|Товар");
	ОбластьКонецСтрокиЗаголовок = Макет.ПолучитьОбласть("Заголовок|КонецСтроки");
	
	ОбластьОрганизация = Макет.ПолучитьОбласть("ОрганизацияОтправитель");
	// ОбластьТовары = Макет.Область("Товар");
	// ОбластьТовары.ШиринаКолонки = ОбластьТовары.ШиринаКолонки + Макет.Область("КолонкаКодов").ШиринаКолонки;
	
	ОбластьНомераШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
	ОбластьКодовШапка  =  Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
	ОбластьУпаковокШапка  =  Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаУпаковок");
	ОбластьДанныхШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
	ОбластьКонецСтрокиШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|КонецСтроки");
	
	ОбластьНомераСтрока = Макет.ПолучитьОбласть("Строка1|НомерСтроки");
	ОбластьКодовСтрока =  Макет.ПолучитьОбласть("Строка1|КолонкаКодов");
	ОбластьУпаковокСтрока =  Макет.ПолучитьОбласть("Строка1|КолонкаУпаковок");
	ОбластьДанныхСтрока = Макет.ПолучитьОбласть("Строка1|Товар");
	ОбластьКонецСтрокиСтрока = Макет.ПолучитьОбласть("Строка1|КонецСтроки");
	
	ОбластьНомераПодвал = Макет.ПолучитьОбласть("Подвал|НомерСтроки");
	ОбластьКодовПодвал =  Макет.ПолучитьОбласть("Подвал|КолонкаКодов");
	ОбластьУпаковокПодвал =  Макет.ПолучитьОбласть("Подвал|КолонкаУпаковок");
	ОбластьДанныхПодвал = Макет.ПолучитьОбласть("Подвал|Товар");
	ОбластьКонецСтрокиПодвал = Макет.ПолучитьОбласть("Подвал|КонецСтроки");
	
	ОбластьПодписей = Макет.ПолучитьОбласть("Подписи");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	Запрос.Текст ="ВЫБРАТЬ РАЗРЕШЕННЫЕ
	              |	ПеремещениеЗапасов.Номер,
	              |	ПеремещениеЗапасов.Дата КАК Дата,
	              |	ПеремещениеЗапасов.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
	              |	ПеремещениеЗапасов.Склад.Представление КАК ОтправительПредставление,
	              |	ПеремещениеЗапасов.СкладПолучатель.Представление КАК ПолучательПредставление,
	              |	ПеремещениеЗапасов.СтруктурнаяЕдиница.Организация.Наименование КАК ОрганизацияПредставление,
	              |	ПеремещениеЗапасов.Ссылка КАК Ссылка
	              |ИЗ
	              |	Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов
	              |ГДЕ
	              |	ПеремещениеЗапасов.Ссылка В(&МассивДокументов)
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Дата,
	              |	Ссылка
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	              |	ПеремещениеЗапасовЗапасы.Номенклатура КАК Товар,
	              |	ПеремещениеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.НаименованиеПолное КАК ТоварНаименование,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.Код КАК Код,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения КАК ПредставлениеЕдининицыИзмеренияУпаковки,
	              |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения) КАК ПредставлениеБазовойЕдиницыИзмерения,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения,
	              |	ПеремещениеЗапасовЗапасы.КоличествоУпаковок,
	              |	ПеремещениеЗапасовЗапасы.Количество,
	              |	ПеремещениеЗапасов.Ссылка КАК Ссылка,
	              |	ПеремещениеЗапасовЗапасы.Упаковка.Коэффициент КАК Коэффициент,
	              |	ПеремещениеЗапасовЗапасы.Упаковка,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.Артикул КАК Артикул,
	              |	ПеремещениеЗапасовЗапасы.Партия КАК Партия
	              |ИЗ
	              |	Документ.ПеремещениеЗапасов.Запасы КАК ПеремещениеЗапасовЗапасы
	              |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов
	              |		ПО ПеремещениеЗапасовЗапасы.Ссылка = ПеремещениеЗапасов.Ссылка
	              |ГДЕ
	              |	ПеремещениеЗапасов.Ссылка В(&МассивДокументов)
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Ссылка,
	              |	НомерСтроки
	              |ИТОГИ ПО
	              |	Ссылка"  ;
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Шапка = РезультатЗапроса[0].Выбрать();
	ВыборкаТЧ = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ПервыйДокумент = Истина;
	
	ДопКолонка = ЗначениеНастроекПовтИсп.ПолучитьЗначениеКонстанты("ДополнительнаяКолонкаПечатныхФормДокументов");
	Если ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул Тогда
		ВыводитьКоды = Истина;
		Колонка = "Артикул";
	ИначеЕсли ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Код Тогда
		ВыводитьКоды = Истина;
		Колонка = "Код";
	Иначе
		ВыводитьКоды = Ложь;
	КонецЕсли;
	
	Пока Шапка.Следующий() Цикл
		
		Если Не ВыборкаТЧ.НайтиСледующий(Новый Структура("Ссылка", Шапка.Ссылка)) Тогда
			Продолжить;
		КонецЕсли;
		
		ВыборкаСтрокТовары = ВыборкаТЧ.Выбрать();
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		// Выводим шапку накладной
		ОбластьНомераЗаголовок.Параметры.ТекстЗаголовка = ФормированиеПечатныхФорм.СформироватьЗаголовокДокумента(Шапка, "Накладная на перемещение");
		ТабДокумент.Вывести(ОбластьНомераЗаголовок);
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовЗаголовок);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьУпаковокЗаголовок);
		ТабДокумент.Присоединить(ОбластьДанныхЗаголовок);
		ТабДокумент.Присоединить(ОбластьКонецСтрокиЗаголовок);
		
		ОбластьОрганизация.Параметры.Заполнить(Шапка);
		ТабДокумент.Вывести(ОбластьОрганизация);
		
		// ОбластьЗаголовка.Параметры.ТекстЗаголовка = ФормированиеПечатныхФорм.СформироватьЗаголовокДокумента(Шапка, "Накладная на перемещение");
		// ОбластьЗаголовка.Параметры.Заполнить(Шапка);
		// ТабДокумент.Вывести(ОбластьЗаголовка);
		ТабДокумент.Вывести(ОбластьНомераШапка);
		Если ВыводитьКоды Тогда
			ОбластьКодовШапка.Параметры.ИмяКолонкиКодов = Колонка;
			ТабДокумент.Присоединить(ОбластьКодовШапка);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьДанныхШапка); 
		ТабДокумент.Присоединить(ОбластьУпаковокШапка);
		ТабДокумент.Присоединить(ОбластьКонецСтрокиШапка);
		
		// Выборка товаров
		Пока ВыборкаСтрокТовары.Следующий() Цикл
			
			ОбластьНомераСтрока.Параметры.НомерСтроки = ВыборкаСтрокТовары.НомерСтроки;
			ТабДокумент.Вывести(ОбластьНомераСтрока);
			
			Если ВыводитьКоды Тогда
				Если Колонка = "Артикул" Тогда
					ОбластьКодовСтрока.Параметры.Артикул = ВыборкаСтрокТовары.Артикул;
				Иначе
					ОбластьКодовСтрока.Параметры.Артикул = ВыборкаСтрокТовары.Код;
				КонецЕсли;
				ТабДокумент.Присоединить(ОбластьКодовСтрока);
			КонецЕсли;
			
			ОбластьДанныхСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			ОбластьДанныхСтрока.Параметры.Товар = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати
			(ВыборкаСтрокТовары.ТоварНаименование, Неопределено);
			
			ТабДокумент.Присоединить(ОбластьДанныхСтрока);
			
			ОбластьУпаковокСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			Если  НЕ ВыборкаСтрокТовары.Упаковка = Справочники.УпаковкиНоменклатуры.ПустаяСсылка() Тогда
				ПредставлениеУпаковки = ОбластьУпаковокСтрока.Параметры.ПредставлениеЕдининицыИзмеренияУпаковки;
				ПредставлениеУпаковки = ?(ЗначениеЗаполнено(ПредставлениеУпаковки), " " + ПредставлениеУпаковки, " шт.");
				ОбластьУпаковокСтрока.Параметры.ПредставлениеЕдининицыИзмеренияУпаковки = ВыборкаСтрокТовары.Упаковка.Наименование + " (" + ВыборкаСтрокТовары.Коэффициент + ПредставлениеУпаковки + ")";				
			КонецЕсли;
			
			ТабДокумент.Присоединить(ОбластьУпаковокСтрока);
			
			ОбластьКонецСтрокиСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			ТабДокумент.Присоединить(ОбластьКонецСтрокиСтрока);
			
		КонецЦикла;
		
		ТабДокумент.Вывести(ОбластьНомераПодвал);  
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовПодвал);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьДанныхПодвал);
		ТабДокумент.Присоединить(ОбластьУпаковокПодвал);
		ТабДокумент.Присоединить(ОбластьКонецСтрокиПодвал);
		
		// Вывести подписи.
		ТабДокумент.Вывести(ОбластьПодписей);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
		
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабДокумент;
	
КонецФункции // ПечатьПеремещениеТоваров()

//////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ
//  &НаКлиенте
// Функция ВидЦен()
//	СтруктураПараметров = Новый Структура;
//	СтруктураЦены = ОткрытьФормуМодально("ОбщаяФорма.ФормаЦены", СтруктураПараметров);
//	Возврат  СтруктураЦены.ВидЦен;
// КонецФункции
//  
// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФормуНакладнойНаПеремещениеТоваровПоТипуЦен(МассивОбъектов, ОбъектыПечати)
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_Накладная";
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПеремещениеЗапасов.ПФ_MXL_НакладнаяНаПеремещениеПоТипуЦен");
	
	ОбластьНомераЗаголовок = Макет.ПолучитьОбласть("Заголовок|НомерСтроки");
	ОбластьКодовЗаголовок  =  Макет.ПолучитьОбласть("Заголовок|КолонкаКодов");
	ОбластьУпаковокЗаголовок  =  Макет.ПолучитьОбласть("Заголовок|КолонкаУпаковок");
	ОбластьДанныхЗаголовок = Макет.ПолучитьОбласть("Заголовок|Товар");
	ОбластьКонецСтрокиЗаголовок = Макет.ПолучитьОбласть("Заголовок|КонецСтроки");
	ОбластьОрганизация = Макет.ПолучитьОбласть("ОрганизацияОтправитель");
	
	ОбластьНомераШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
	ОбластьКодовШапка  =  Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
	ОбластьУпаковокШапка  =  Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаУпаковок");
	ОбластьДанныхШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
	ОбластьКонецСтрокиШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|КонецСтроки");
	
	ОбластьНомераСтрока = Макет.ПолучитьОбласть("Строка1|НомерСтроки");
	ОбластьКодовСтрока =  Макет.ПолучитьОбласть("Строка1|КолонкаКодов");
	ОбластьУпаковокСтрока =  Макет.ПолучитьОбласть("Строка1|КолонкаУпаковок");
	ОбластьДанныхСтрока = Макет.ПолучитьОбласть("Строка1|Товар");
	ОбластьКонецСтрокиСтрока = Макет.ПолучитьОбласть("Строка1|КонецСтроки");
	
	ОбластьНомераПодвал = Макет.ПолучитьОбласть("Подвал|НомерСтроки");
	ОбластьКодовПодвал =  Макет.ПолучитьОбласть("Подвал|КолонкаКодов");
	ОбластьУпаковокПодвал =  Макет.ПолучитьОбласть("Подвал|КолонкаУпаковок");
	ОбластьДанныхПодвал = Макет.ПолучитьОбласть("Подвал|Товар");
	ОбластьКонецСтрокиПодвал = Макет.ПолучитьОбласть("Подвал|КонецСтроки");
	ОбластьПодписей = Макет.ПолучитьОбласть("Подписи");
	
	ОбластьЦенаЗаголовок = Макет.ПолучитьОбласть("Заголовок|Цена");
	ОбластьЦенаШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Цена");
	ОбластьЦенаСтрока = Макет.ПолучитьОбласть("Строка|Цена");
	ОбластьЦенаПодвал = Макет.ПолучитьОбласть("Подвал|Цена");
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов[0]);
	Дата = Неопределено; // МассивОбъектов[0][0].Дата
	
	Для Каждого ДокументИзМассива Из МассивОбъектов[0] Цикл
		Дата = ?(Дата = Неопределено, ДокументИзМассива.Дата, Дата);
		Дата = ?(ДокументИзМассива.Дата > Дата, ДокументИзМассива.Дата, Дата);
	КонецЦикла;
		
	ВидЦен = МассивОбъектов[1];

	Запрос.УстановитьПараметр("ВидЦен", ВидЦен);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.Текст ="ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	              |	ПеремещениеЗапасов.Номер,
	              |	ПеремещениеЗапасов.Дата КАК Дата,
	              |	ПеремещениеЗапасов.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
	              |	ПеремещениеЗапасов.Склад.Представление КАК ОтправительПредставление,
	              |	ПеремещениеЗапасов.СкладПолучатель.Представление КАК ПолучательПредставление,
	              |	ПеремещениеЗапасов.СтруктурнаяЕдиница.Организация.Наименование КАК ОрганизацияПредставление,
	              |	ПеремещениеЗапасов.Ссылка КАК Ссылка
	              |ИЗ
	              |	Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов
	              |ГДЕ
	              |	ПеремещениеЗапасов.Ссылка В(&Ссылка)
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Дата,
	              |	Ссылка
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	              |	ПеремещениеЗапасовЗапасы.Номенклатура КАК Товар,
	              |	ПеремещениеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.Код КАК Код,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения КАК ПредставлениеЕдининицыИзмеренияУпаковки,
	              |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения) КАК ПредставлениеБазовойЕдиницыИзмерения,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения,
	              |	ПеремещениеЗапасовЗапасы.КоличествоУпаковок,
	              |	ПеремещениеЗапасовЗапасы.Количество,
	              |	ПеремещениеЗапасов.Ссылка КАК Ссылка,
	              |	ПеремещениеЗапасовЗапасы.Упаковка.Коэффициент КАК Коэффициент,
	              |	ПеремещениеЗапасовЗапасы.Упаковка,
	              |	ПеремещениеЗапасовЗапасы.Партия,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.Артикул КАК Артикул,
	              |	МАКСИМУМ(ЦеныНоменклатурыСрезПоследних.Цена) КАК Цена,
	              |	ЦеныНоменклатурыСрезПоследних.Цена * ПеремещениеЗапасовЗапасы.КоличествоУпаковок КАК Сумма,
	              |	ПеремещениеЗапасов.Дата
	              |ИЗ
	              |	Документ.ПеремещениеЗапасов.Запасы КАК ПеремещениеЗапасовЗапасы
	              |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов
	              |		ПО ПеремещениеЗапасовЗапасы.Ссылка = ПеремещениеЗапасов.Ссылка
	              |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	              |				&Дата,
	              |				Актуальность = ИСТИНА
	              |					И Номенклатура В
	              |						(ВЫБРАТЬ
	              |							ПеремещениеЗапасовЗапасы.Номенклатура
	              |						ИЗ
	              |							Документ.ПеремещениеЗапасов.Запасы КАК ПеремещениеЗапасовЗапасы)
	              |					И ВидЦен = &ВидЦен) КАК ЦеныНоменклатурыСрезПоследних
	              |		ПО ПеремещениеЗапасовЗапасы.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	              |ГДЕ
	              |	ПеремещениеЗапасов.Ссылка В(&Ссылка)
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ПеремещениеЗапасовЗапасы.Номенклатура,
	              |	ПеремещениеЗапасовЗапасы.НомерСтроки,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.Код,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения,
	              |	ПеремещениеЗапасовЗапасы.КоличествоУпаковок,
	              |	ПеремещениеЗапасовЗапасы.Количество,
	              |	ПеремещениеЗапасов.Ссылка,
	              |	ПеремещениеЗапасовЗапасы.Упаковка.Коэффициент,
	              |	ПеремещениеЗапасовЗапасы.Упаковка,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.Артикул,
	              |	ПеремещениеЗапасовЗапасы.Партия,
	              |	ПеремещениеЗапасов.Дата,
	              |	ЦеныНоменклатурыСрезПоследних.Цена * ПеремещениеЗапасовЗапасы.КоличествоУпаковок,
	              |	ПеремещениеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Ссылка,
	              |	НомерСтроки
	              |ИТОГИ
	              |	СУММА(Сумма)
	              |ПО
	              |	Ссылка";
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Шапка = РезультатЗапроса[0].Выбрать();
	ВыборкаТЧ = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ПервыйДокумент = Истина;
	
	ДопКолонка = ЗначениеНастроекПовтИсп.ПолучитьЗначениеКонстанты("ДополнительнаяКолонкаПечатныхФормДокументов");
	Если ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул Тогда
		ВыводитьКоды = Истина;
		Колонка = "Артикул";
	ИначеЕсли ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Код Тогда
		ВыводитьКоды = Истина;
		Колонка = "Код";
	Иначе
		ВыводитьКоды = Ложь;
	КонецЕсли;
	
	Пока Шапка.Следующий() Цикл
		
		Если Не ВыборкаТЧ.НайтиСледующий(Новый Структура("Ссылка", Шапка.Ссылка)) Тогда
			Продолжить;
		КонецЕсли;
		
		ВыборкаСтрокТовары = ВыборкаТЧ.Выбрать();
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		// Выводим шапку накладной
		ОбластьНомераЗаголовок.Параметры.ТекстЗаголовка = ФормированиеПечатныхФорм.СформироватьЗаголовокДокумента(Шапка, "Накладная на перемещение");
		ТабДокумент.Вывести(ОбластьНомераЗаголовок);
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовЗаголовок);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьУпаковокЗаголовок);
		ТабДокумент.Присоединить(ОбластьДанныхЗаголовок);
		ТабДокумент.Присоединить(ОбластьКонецСтрокиЗаголовок);
		ТабДокумент.Присоединить(ОбластьЦенаЗаголовок);
		ОбластьОрганизация.Параметры.Заполнить(Шапка);
		ТабДокумент.Вывести(ОбластьОрганизация);
		ТабДокумент.Вывести(ОбластьНомераШапка);
		Если ВыводитьКоды Тогда
			ОбластьКодовШапка.Параметры.ИмяКолонкиКодов = Колонка;
			ТабДокумент.Присоединить(ОбластьКодовШапка);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьДанныхШапка); 
		ТабДокумент.Присоединить(ОбластьУпаковокШапка);
		ТабДокумент.Присоединить(ОбластьКонецСтрокиШапка);
		ТабДокумент.Присоединить(ОбластьЦенаШапка);
		
		// Выборка товаров
		Итого = 0;
		Пока ВыборкаСтрокТовары.Следующий() Цикл
			
			ОбластьНомераСтрока.Параметры.НомерСтроки = ВыборкаСтрокТовары.НомерСтроки;
			ТабДокумент.Вывести(ОбластьНомераСтрока);
			
			Если ВыводитьКоды Тогда
				Если Колонка = "Артикул" Тогда
					ОбластьКодовСтрока.Параметры.Артикул = ВыборкаСтрокТовары.Артикул;
				Иначе
					ОбластьКодовСтрока.Параметры.Артикул = ВыборкаСтрокТовары.Код;
				КонецЕсли;
				ТабДокумент.Присоединить(ОбластьКодовСтрока);
			КонецЕсли;
			ОбластьДанныхСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			ОбластьДанныхСтрока.Параметры.Товар = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати
			(ВыборкаСтрокТовары.Товар, Неопределено);
			ТабДокумент.Присоединить(ОбластьДанныхСтрока);
			ОбластьУпаковокСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			Если  НЕ ВыборкаСтрокТовары.Упаковка = Справочники.УпаковкиНоменклатуры.ПустаяСсылка() Тогда
				ПредставлениеУпаковки = ОбластьУпаковокСтрока.Параметры.ПредставлениеЕдининицыИзмеренияУпаковки;
				ПредставлениеУпаковки = ?(ЗначениеЗаполнено(ПредставлениеУпаковки), " " + ПредставлениеУпаковки, " шт.");
				ОбластьУпаковокСтрока.Параметры.ПредставлениеЕдининицыИзмеренияУпаковки = ВыборкаСтрокТовары.Упаковка.Наименование + " (" + ВыборкаСтрокТовары.Коэффициент + ПредставлениеУпаковки + ")";
			КонецЕсли;
			ТабДокумент.Присоединить(ОбластьУпаковокСтрока);
			ОбластьКонецСтрокиСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			ТабДокумент.Присоединить(ОбластьКонецСтрокиСтрока);
			ОбластьЦенаСтрока.Параметры.Цена = ВыборкаСтрокТовары.Цена;
			ОбластьЦенаСтрока.Параметры.Сумма = ВыборкаСтрокТовары.Сумма; 
			ТабДокумент.Присоединить(ОбластьЦенаСтрока); 	
		КонецЦикла;
		ТабДокумент.Вывести(ОбластьНомераПодвал);  
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовПодвал);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьДанныхПодвал);
		ТабДокумент.Присоединить(ОбластьУпаковокПодвал);
		ТабДокумент.Присоединить(ОбластьКонецСтрокиПодвал);
		ОбластьЦенаПодвал.Параметры.Сумма =  ВыборкаТЧ.Сумма;
		ТабДокумент.Присоединить(ОбластьЦенаПодвал);
		// Вывести подписи.
		ТабДокумент.Вывести(ОбластьПодписей);
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
	КонецЦикла;	
	ТабДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабДокумент;
	
КонецФункции // ПечатьПеремещениеТоваров()


// Процедура печати документа.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "НакладнаяНаПеремещение") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"НакладнаяНаПеремещение",
		"Накладная на перемещение",
		СформироватьПечатнуюФормуНакладнойНаПеремещениеТоваров(МассивОбъектов, ОбъектыПечати)
		);
	КонецЕсли;
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "НакладнаяНаПеремещениеПоТипуЦен") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"НакладнаяНаПеремещениеПоТипуЦен",
		"Накладная на перемещение по типу цен",
		СформироватьПечатнуюФормуНакладнойНаПеремещениеТоваровПоТипуЦен(МассивОбъектов, ОбъектыПечати)
		);
	КонецЕсли;
КонецПроцедуры

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("НакладнаяНаПеремещение", "Накладная на перемещение", , БиблиотекаКартинок.Документ);
	Список.Добавить("НакладнаяНаПеремещениеПоТипуЦен", "Накладная на перемещение по типу цен", , БиблиотекаКартинок.Документ);
		
	Возврат Список;
	
КонецФункции

// Процедура - устанавливает фильтр для списков документов
//
Процедура УстановитьФильтр(СтрЕдиницаОтбор,ВидОперацииОтбор,СкладСотрудникОтбор,Список) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Ссылка
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПеремещениеЗапасов.Дата КАК Дата,
	|		ПеремещениеЗапасов.Номер КАК Номер,
	|		ПеремещениеЗапасов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		ПеремещениеЗапасов.ВидОперации КАК ВидОперации,
	|		ПеремещениеЗапасов.Склад КАК Склад,
	|		ПеремещениеЗапасов.СкладПолучатель КАК СкладПолучатель,
	|		ПеремещениеЗапасов.АвторДокумента КАК АвторДокумента,
	|		ПеремещениеЗапасов.Комментарий КАК Комментарий,
	|		ПеремещениеЗапасов.Ссылка КАК Ссылка
	|	ИЗ
	|		Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВложенныйЗапрос.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВложенныйЗапрос.ВидОперации = &ВидОперации
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ТипСкладСотрудник = ""Не определено""
	|					ИЛИ &СкладСотрудник = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|					ИЛИ &СкладСотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВложенныйЗапрос.Склад = &СкладСотрудник
	|					ИЛИ ВложенныйЗапрос.СкладПолучатель = &СкладСотрудник
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтрЕдиницаОтбор);
	Запрос.УстановитьПараметр("ВидОперации", ВидОперацииОтбор);
	Запрос.УстановитьПараметр("ТипСкладСотрудник", Строка(ТипЗнч(СкладСотрудникОтбор)));
	Запрос.УстановитьПараметр("СкладСотрудник", СкладСотрудникОтбор);
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Ссылка", Результат, Истина, ВидСравненияКомпоновкиДанных.ВСписке);
	
КонецПроцедуры

