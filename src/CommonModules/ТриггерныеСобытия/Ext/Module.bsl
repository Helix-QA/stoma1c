		               |			ТОГДА ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ТаблицаНеОтработанныхЗаявок.ДатаСоздания, ДЕНЬ), ЧАС, ЧАС(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ОкончаниеРаботы, ДАТАВРЕМЯ(1, 1, 1, 23, 59, 59)))), МИНУТА, МИНУТА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ОкончаниеРаботы, ДАТАВРЕМЯ(1, 1, 1, 23, 59, 59)))), СЕКУНДА, СЕКУНДА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ОкончаниеРаботы, ДАТАВРЕМЯ(1, 1, 1, 23, 59, 59)))), СЕКУНДА, 86400)
		               |		ИНАЧЕ ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ТаблицаНеОтработанныхЗаявок.ДатаСоздания, ДЕНЬ), ЧАС, ЧАС(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ОкончаниеРаботы, ДАТАВРЕМЯ(1, 1, 1, 23, 59, 59)))), МИНУТА, МИНУТА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ОкончаниеРаботы, ДАТАВРЕМЯ(1, 1, 1, 23, 59, 59)))), СЕКУНДА, СЕКУНДА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ОкончаниеРаботы, ДАТАВРЕМЯ(1, 1, 1, 23, 59, 59))))
		               |	КОНЕЦ КАК ОкончаниеРаботы,
		               |	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ТаблицаНеОтработанныхЗаявок.ДатаСоздания, СЕКУНДА, 86400), ДЕНЬ), ЧАС, ЧАС(ЕСТЬNULL(ТаблицаВремениРаботыСЕ2.НачалоРаботы, ДАТАВРЕМЯ(1, 1, 1)))), МИНУТА, МИНУТА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ2.НачалоРаботы, ДАТАВРЕМЯ(1, 1, 1)))), СЕКУНДА, СЕКУНДА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ2.НачалоРаботы, ДАТАВРЕМЯ(1, 1, 1)))) КАК НачалоРаботыСледующегоДня
		               |ПОМЕСТИТЬ ТаблицаЗаявокИРежимовРаботыСЕ
