#Область Обработчики_VkApi

// Функция, получает данные клиента в VK и возвращает результат запроса.
//
Функция ПолучитьДанныеКлиента_VkApi(Идентификатор, ВнешняяСистема) Экспорт
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	Если Не (ПараметрыВнешнейСистемы.Свойство("UrlApi") И ПараметрыВнешнейСистемы.Свойство("ApiToken")) Тогда
		Возврат Новый Структура("Имя, Фамилия, Фото", "Пользователь VK " + Идентификатор, "", "");
	КонецЕсли;	
	
	Сервер		 = ПараметрыВнешнейСистемы.UrlApi;
	ТокенДоступа = ПараметрыВнешнейСистемы.ApiToken;
	
	HTTPСоединение = Новый HTTPСоединение(Сервер,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	HTTPЗапрос = Новый HTTPЗапрос("/method/users.get?user_ids="+ФорматироватьИдентификатор(Идентификатор)+"&fields=photo_200&access_token="+ТокенДоступа+"&v=5.124");
	
	СтруктураОтвета = ДекодироватьИзJSON((HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку()));
	
	Если СтруктураОтвета.Свойство("error") Тогда
		Возврат Новый Структура("Имя, Фамилия, Фото", "Пользователь VK " + Идентификатор, "", "");
	КонецЕсли;
	
	Если СтруктураОтвета.response.Количество() > 0 Тогда
		
		Возврат Новый Структура("Имя, Фамилия, Фото", СтруктураОтвета.response[0].first_name, СтруктураОтвета.response[0].last_name, СтруктураОтвета.response[0].photo_200);
		
	КонецЕсли;
	
КонецФункции

// Функция, отправляет сообщение через API VK и возвращает структуру с параметрами результата.
//
Функция ОтправитьСообщениеКлиентуVkApi(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона = Неопределено, ИдКанала = "")
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВыполненоУспешно", Ложь);
	СтруктураВозврата.Вставить("ОписаниеОшибки"  , "");
	СтруктураВозврата.Вставить("ИдСообщения"     , "");
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы)
		ИЛИ ТипЗнч(ПараметрыВнешнейСистемы) <> Тип("Структура")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("ApiToken")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("ИдОператора")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("UrlApi") Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не заполнены параметры внешней системы."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Клиент) Тогда		
		ПараметрыКлиента = ПолучитьПараметрыОбъектаИдентификации(Клиент, ВнешняяСистема);
	Иначе
		ПараметрыКлиента = Неопределено;
	КонецЕсли;
	
	Если ПараметрыКлиента = Неопределено Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не найден контакт мессенджера."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	РезультатОперации = VkApi_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы);
	
	// Если сообщение отправлено.
	Если РезультатОперации.ВыполненоУспешно Тогда
		
		СтруктураВозврата.ВыполненоУспешно = Истина;
		СтруктураВозврата.ИдСообщения      = РезультатОперации.ИдСообщения;
		
		// Добавляем отправленное сообщенте в регистр.
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
			ПараметрыКлиента.ИдКлиента,
			РезультатОперации.ИдСообщения,,
			РезультатОперации.ИдКанала,
			ТекстСообщения,
			Истина,
			Перечисления.Мессенджеры.vk,
			Ложь,
			ТекущаяДатаСеанса(),
			ВнешняяСистема,
			//// ПараметрыКлиента.ОператорСообщения
		);
		
		// Оповещаем сотрудников о новом отправленном сообщении.
		ОповеститьСотрудниковОНовомСообщении(РезультатОперации.ИдСообщения,, ПараметрыКлиента.ИдКлиента,, ВнешняяСистема);		
	
	ИначеЕсли РезультатОперации.Свойство("ОписаниеОшибки") Тогда // Если есть расшифровка ошибки, то вернем ее
		СтруктураВозврата.ОписаниеОшибки = РезультатОперации.ОписаниеОшибки;
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке.";
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область Обработчики_Telegram

// Функция, отправляет сообщение клиенту.
//
Функция ОтправитьСообщениеКлиентуTelegram(ТекстСообщения
										, Клиент
										, ВнешняяСистема
										, НомерТелефона = Неопределено
										, ИдКанала = ""
										, ДополнительныеПараметры = Неопределено)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВыполненоУспешно", Ложь);
	СтруктураВозврата.Вставить("ОписаниеОшибки"  , "");
	СтруктураВозврата.Вставить("ИдСообщения"     , "");
	
	ПараметрыВнешнейСистемы = Неопределено;	
	Если НЕ ИнициализированыПараметрыВнешнейСистемы(ВнешняяСистема, ПараметрыВнешнейСистемы) Тогда 
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не заполнены параметры внешней системы."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Клиент) Тогда		
		ПараметрыКлиента = ПолучитьПараметрыОбъектаИдентификации(Клиент, ВнешняяСистема);
	Иначе
		ПараметрыКлиента = Неопределено;		
	КонецЕсли;
	
	Если ПараметрыКлиента = Неопределено Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не найден контакт мессенджера."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	РезультатОперации = Telegram_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, , ДополнительныеПараметры);
	
	// Если сообщение отправлено.
	Если РезультатОперации.ВыполненоУспешно Тогда
		
		СтруктураВозврата.ВыполненоУспешно = Истина;
		СтруктураВозврата.ИдСообщения      = РезультатОперации.ИдСообщения;
		
		ОператорСообщения 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ОператорСообщения"	, Неопределено);
		Триггер 			= ?(ТипЗнч(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ПараметрыРегистрацииТриггера", Ложь)) = Тип("Структура"), Истина, Ложь);
		СтартСценария 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "СтартСценария"		, Ложь);
		
		// Добавляем отправленное сообщенте в регистр.
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(ПараметрыКлиента.ИдКлиента
													, РезультатОперации.ИдСообщения
													,
													, РезультатОперации.ИдКанала
													, ТекстСообщения
													, Истина
													, Перечисления.Мессенджеры.telegram
													, Ложь
													, ТекущаяДатаСеанса()
													, ВнешняяСистема
													, ОператорСообщения
													,
													, 
													, 
													, Триггер
													, 
													, ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "JSONСтруктураКнопок", Неопределено) <> Неопределено
													, 
													, 
													, 
													, ДополнительныеПараметры);		
		
		// Оповещаем сотрудников о новом отправленном сообщении.
		ОповеститьСотрудниковОНовомСообщении(РезультатОперации.ИдСообщения,, ПараметрыКлиента.ИдКлиента,, ВнешняяСистема);		
	
	ИначеЕсли РезультатОперации.Свойство("ОписаниеОшибки") Тогда // Если есть расшифровка ошибки, то вернем ее
		СтруктураВозврата.ОписаниеОшибки = РезультатОперации.ОписаниеОшибки;
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке.";
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Инициализированы параметры внешней системы
//
// Параметры:
//  ВнешняяСистема			 - 	 - 
//  ПараметрыВнешнейСистемы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализированыПараметрыВнешнейСистемы(ВнешняяСистема, ПараметрыВнешнейСистемы) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураВнешнейСистемы 	= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ВнешняяСистема, "Параметры, ТипВнешнейСистемы");
	
	ПараметрыХранилищеЗначений 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураВнешнейСистемы, "Параметры"			, Неопределено);
	ТипВнешнейСистемы 			= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураВнешнейСистемы, "ТипВнешнейСистемы"	, Перечисления.ТипыВнешнихСистем.ПустаяСсылка());

	Если ПараметрыХранилищеЗначений = Неопределено ИЛИ НЕ ЗначениеЗаполнено(ТипВнешнейСистемы) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	ПараметрыВнешнейСистемы = ПараметрыХранилищеЗначений.Получить();
	Если НЕ ЗначениеЗаполнено(ПараметрыВнешнейСистемы) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура") Тогда 
		Возврат Ложь;
	КонецЕсли;
	ПараметрыВнешнейСистемы.Вставить("ТипВнешнейСистемы", ТипВнешнейСистемы);
		
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда 
		ПараметрыВнешнейСистемы.Вставить("Мессенджер", Перечисления.Мессенджеры.whatsapp);
		
		Возврат ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура")
				И ПараметрыВнешнейСистемы.Свойство("ApiToken")
				И ПараметрыВнешнейСистемы.Свойство("ИдОператора")
				И ПараметрыВнешнейСистемы.Свойство("UrlApi")
				И ПараметрыВнешнейСистемы.Свойство("ChannelId");
				
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда	
		ПараметрыВнешнейСистемы.Вставить("Мессенджер", Перечисления.Мессенджеры.telegram);
				
		Возврат ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура")
				И ПараметрыВнешнейСистемы.Свойство("ApiToken")
				И ПараметрыВнешнейСистемы.Свойство("ИдОператора")
				И ПараметрыВнешнейСистемы.Свойство("UrlApi");
				
	Иначе 
		Возврат Ложь;			
	КонецЕсли;	
	
КонецФункции

// Функция, получает данные клиента в Telegram и возвращает результат запроса.
//
Функция ПолучитьДанныеКлиента_Telegram(Идентификатор, ВнешняяСистема) Экспорт
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	Если Не (ПараметрыВнешнейСистемы.Свойство("UrlApi") И ПараметрыВнешнейСистемы.Свойство("ApiToken")) Тогда
		Возврат Новый Структура("Имя, Фамилия, Фото", "Чат Telegram " + Идентификатор, "", "");
	КонецЕсли;
	
	HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/getChat?chat_id=" + Идентификатор);
	
	СтруктураОтвета = ДекодироватьИзJSON((HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку()));
	
	Если Не СтруктураОтвета.Свойство("result") Тогда
		Возврат Новый Структура("Имя, Фамилия, Фото", "Чат Telegram " + Идентификатор, "", "");
	КонецЕсли;
	
	Если СтруктураОтвета.ok Тогда
		
		ПредставлениеЧата = ПолучитьПредставлениеЧата_Telegram(СтруктураОтвета.result, Истина);
		
		Если СтруктураОтвета.result.Свойство("photo") Тогда
			СтруктураПараметров = Новый Структура("file_id", СтруктураОтвета.result.photo.big_file_id);
			Фото = ПолучитьСсылкуНаФайл_Telegram(СтруктураПараметров, ПараметрыВнешнейСистемы);
		Иначе
			Фото = "";
		КонецЕсли;
		
		ПредставлениеЧата.Вставить("Фото", Фото);
		
		Возврат ПредставлениеЧата;
		
	Иначе
		Возврат Новый Структура("Имя, Фамилия, Фото", "Чат Telegram " + Идентификатор, "", "");
		
	КонецЕсли;
	
КонецФункции

// Функция, возвращает ссылку на файл по идентификатору файла в Telegram.
//
Функция ПолучитьСсылкуНаФайл_Telegram(Файл, ПараметрыВнешнейСистемы) Экспорт
	
	Если ТипЗнч(Файл) = Тип("Массив") Тогда
		ИдентификаторФайла = Файл[Файл.ВГраница()].file_id;
	Иначе
		ИдентификаторФайла = Файл.file_id;
	КонецЕсли;
	
	HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/getFile?file_id=" + ИдентификаторФайла);
	
	СтруктураОтвета = ДекодироватьИзJSON((HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку()));
	
	Возврат ?(СтруктураОтвета.Свойство("result") И СтруктураОтвета.result.Свойство("file_path"), "https://api.telegram.org/file/bot" + ПараметрыВнешнейСистемы.ApiToken + "/" + СтруктураОтвета.result.file_path, "");
	
КонецФункции

// Функция, возвращает имя и фамилию пользователя Telegram.
//
Функция ПолучитьПредставлениеЧата_Telegram(СтруктураЧата, ВозвращатьСтруктуру = Ложь) Экспорт
	
	Если СтруктураЧата.Свойство("first_name") Тогда
		Имя		= СтруктураЧата.first_name;
		Фамилия	= ?(СтруктураЧата.Свойство("last_name"), СтруктураЧата.last_name, "");
	ИначеЕсли СтруктураЧата.Свойство("title") Тогда
		Имя		= СтруктураЧата.title;
		Фамилия	= "";
	ИначеЕсли СтруктураЧата.Свойство("username") Тогда
		Имя		= СтруктураЧата.username;
		Фамилия	= "";
	Иначе
		Имя		= "Чат Telegram " + СтруктураЧата.id;
		Фамилия = "";
	КонецЕсли;
	
	Возврат ?(ВозвращатьСтруктуру = Истина, Новый Структура("Имя, Фамилия", Имя, Фамилия), СокрЛП(Имя + " " + Фамилия));
	
КонецФункции

