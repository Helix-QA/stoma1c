// Функция, возвращает список заначений активных заявок контрагента
//
Функция ПолучитьАктивныеЗаявкиКонтрагента(Текст = "", Контрагент, ВернутьМассив = Ложь)
	
	МассивЗаявок = Справочники.Заявки.ПолучитьМассивАктуальныхЗаявокКонтрагента(Текст, Контрагент);
	
