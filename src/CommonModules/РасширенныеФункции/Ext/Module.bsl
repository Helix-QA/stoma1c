// Возвращает остаток от деления
// 
// Параметры:
//  Число1 - Число, числитель.
//  Число2 - Число, знаменатель.
// 
// Возвращаемое значение:
//  Число, оостаток от деления.
// 
Функция Ост(Число1, Число2) Экспорт

	Возврат Число1 - Цел(Число1 / Число2) * Число2;

КонецФункции

// Возвращает время с нулевой датой
// 
Функция ВыделитьВремя(ДатаВремя) Экспорт
	
	Возврат Дата(01, 01, 01) + (ДатаВремя - НачалоДня(ДатаВремя));
	
КонецФункции

// Процедура выполняет паузу с указанной длительностью
// 
Процедура Пауза_WScript_Shell(ПродолжительностьСекунд = 1) Экспорт
	
	#Если Не МобильныйКлиент И Не ВебКлиент Тогда
		Системнаяинформация = Новый Системнаяинформация;
		Попытка
			
			Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда
				ОбъектShell = Новый COMОбъект("WScript.Shell");
				ОбъектShell.Run("ping -n " + СокрЛП(Число(ПродолжительностьСекунд) + 1) + " 127.0.0.1", 0, 1);
			КонецЕсли;
			
		Исключение
			
		КонецПопытки;
	#КонецЕсли

КонецПроцедуры

