  
#Область ОбработчикиСобытийФормы  
  
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщиеПараметры = Неопределено;
	Параметры.Свойство("XMLЧека"       , ЭтотОбъект.XMLЧека);
    Параметры.Свойство("ОбщиеПараметры", ОбщиеПараметры);
	
	Если ЗначениеЗаполнено(ОбщиеПараметры) Тогда
		
		Для Каждого ЭлементМ ИЗ ОбщиеПараметры.ПозицииЧека Цикл
			
			НоваяСтрока = ПозицииЧека.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
			
		КонецЦикла;
		
		Для Каждого ЭлементМ ИЗ ОбщиеПараметры.ТаблицаОплат Цикл
			
			НоваяСтрока = ТаблицаОплат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
			
		КонецЦикла;

		ЭтотОбъект.ПокупательEmail = ОбщиеПараметры.ПокупательEmail;
		ЭтотОбъект.ПокупательНомер = ОбщиеПараметры.ПокупательНомер;
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти