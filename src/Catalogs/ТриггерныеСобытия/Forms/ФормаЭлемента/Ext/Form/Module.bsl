// Процедура - Выбор взаимодействия завершение
//
Процедура ВыборРежимаНапоминанияЗавершение(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Результат <> Неопределено Тогда
		Объект.Действия[ДополнительныеПараметры.ИндексСтроки].ЗадачаРежимНапоминания = Результат.Значение;
		Если Результат.Значение > -1 Тогда 
			ДополнительныеПараметры.ЭлементКнопка.Заголовок = Нстр("ru = 'Напомнить '; en = 'Remind me '") + Результат.Представление;
			ДополнительныеПараметры.ЭлементКнопка.Картинка 	= БиблиотекаКартинок.Напомнить;			
		Иначе 	
			ДополнительныеПараметры.ЭлементКнопка.Заголовок = Нстр("ru = 'Не напоминать'; en = 'Don''t remind me'");
			ДополнительныеПараметры.ЭлементКнопка.Картинка 	= БиблиотекаКартинок.НапоминаниеОтключить;			
		КонецЕсли;
		ЭлементФормы = Элементы.Найти("ПрименитьПараметрыДействия_Индекс_" + Строка(ДополнительныеПараметры.ИндексСтроки));
		Если НЕ ЭлементФормы = Неопределено Тогда
			ЭтаФорма.ТекущийЭлемент = ЭлементФормы;
		КонецЕсли;			
	КонецЕсли;
	
КонецПроцедуры

