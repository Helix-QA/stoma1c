
#Область СлужебныеПроцедурыИФункции

// Функция вернет временную таблицу с выборкой данных шаблону обследования
// "Обследование стоматолога" для всех документов
Функция ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(Контрагент, ПреимСсылка = Неопределено, МассивПриемов = Неопределено, ДиагнозСКодом = Ложь) Экспорт
	
	ЗапросВЫборка = Новый Запрос();
    ЗапросВЫборка.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияПараметровОбследований.Документ КАК Прием,
	|	ЗначенияПараметровОбследований.Параметр КАК Реквизит,
	|	ЗначенияПараметровОбследований.Зуб КАК Зуб,
	|	ЗначенияПараметровОбследований.ЗначениеСтрокой КАК Значение,
	|	ЗначенияПараметровОбследований.Значение КАК ЗначениеПоля,
	|	ЗначенияПараметровОбследований.Параметр.Наименование КАК РеквизитНаименование,
	|	ЗначенияПараметровОбследований.Параметр.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
	|	ЗначенияПараметровОбследований.Параметр.ПривязкаКЗубам КАК ПривязкаКЗубам,
	|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
	|	ЗначенияПараметровОбследований.Значение.Код КАК КодМКБ10
	|ИЗ
	|	РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
	|ГДЕ
	|	ЗначенияПараметровОбследований.Документ.Контрагент = &Контрагент
	|	И ВЫБОР
	|			КОГДА &Документ <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ЗначенияПараметровОбследований.Документ = &Документ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоПриемам = ИСТИНА
	|				ТОГДА ЗначенияПараметровОбследований.Документ В (&МассивПриемов)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗначенияПараметровОбследований.Документ,
	|	ЗначенияПараметровОбследований.ПорядковыйНомер";
	
	ЗапросВЫборка.УстановитьПараметр("Контрагент"    , Контрагент);
	ЗапросВЫборка.УстановитьПараметр("Документ"      , ПреимСсылка);
	ЗапросВЫборка.УстановитьПараметр("МассивПриемов" , МассивПриемов);
    ЗапросВЫборка.УстановитьПараметр("ОтборПоПриемам", МассивПриемов <> Неопределено);
	
	РезультатЗапроса = ЗапросВЫборка.Выполнить().Выгрузить();
		
	ВременнаяТаблица = Новый ТаблицаЗначений;
	ВременнаяТаблица.Колонки.Добавить("Прием"                		, Новый ОписаниеТипов("ДокументСсылка.Прием"));
	ВременнаяТаблица.Колонки.Добавить("РеквизитИмя"          		, Новый ОписаниеТипов("Строка"));
	ВременнаяТаблица.Колонки.Добавить("РеквизитНаименование" 		, Новый ОписаниеТипов("Строка"));
	ВременнаяТаблица.Колонки.Добавить("РеквизитЗначение"     		, Новый ОписаниеТипов("Строка"));
	ВременнаяТаблица.Колонки.Добавить("ЭтоТитульныйРеквизит" 		, Новый ОписаниеТипов("Булево"));
	ВременнаяТаблица.Колонки.Добавить("ТипРеквизита");
    ВременнаяТаблица.Колонки.Добавить("КодМКБ10"             		, Новый ОписаниеТипов("Строка"));

	//// Построение временной таблицы
	ТекщийДокумент = Неопределено;
	ТекущаяСтрока  = Неопределено;
	Для Каждого СтрокаТ ИЗ РезультатЗапроса Цикл
		
		СтрокаТВ = Неопределено;
		Если СтрокаТ.ПривязкаКЗубам Тогда
			НайденныеСтроки = ВременнаяТаблица.НайтиСтроки(Новый Структура("Прием,РеквизитНаименование",СтрокаТ.Прием,СтрокаТ.РеквизитНаименование)); 
			Если НайденныеСтроки.Количество() > 0 Тогда
				СтрокаТВ = НайденныеСтроки[0];
			КонецЕсли;
		КонецЕсли;

		Если СтрокаТВ = Неопределено Тогда 
			
			Если МассивПриемов <> Неопределено Тогда
				НайденныеСтроки = ВременнаяТаблица.НайтиСтроки(Новый Структура("РеквизитНаименование", СтрокаТ.РеквизитНаименование));
				Если НайденныеСтроки.Количество() > 0 Тогда
					СтрокаТВ = НайденныеСтроки[0];
				КонецЕсли;
			КонецЕсли;
						
	    КонецЕсли;
		
		Если СтрокаТВ = Неопределено Тогда 
		    СтрокаТВ = ВременнаяТаблица.Добавить();
        КонецЕсли;

		СтрокаТВ.Прием                = СтрокаТ.Прием;
		СтрокаТВ.РеквизитНаименование = СтрокаТ.РеквизитНаименование;
		Если НЕ ЗначениеЗаполнено(СтрокаТ.ИмяПредопределенныхДанных) Тогда
			СтрокаТВ.РеквизитИмя          = СтрЗаменить(СтрЗаменить(ТРег(СтрокаТ.РеквизитНаименование)," ",""),",","");
		Иначе
			СтрокаТВ.РеквизитИмя          = СтрокаТ.ИмяПредопределенныхДанных;
		КонецЕсли;
 
		СтрокаТВ.РеквизитЗначение     = СтрокаТВ.РеквизитЗначение 
		                              + ?(ЗначениеЗаполнено(СтрокаТВ.РеквизитЗначение),"; ","")
									  + ?(ЗначениеЗаполнено(СтрокаТ.Зуб),"" + СтрокаТ.Зуб + " - ","") + СтрокаТ.Значение;
									  							  
		Если ЗначениеЗаполнено(СтрокаТ.ЗначениеПоля) И ТипЗнч(СтрокаТ.ЗначениеПоля) = Тип("СправочникСсылка.Диагнозы") И ЗначениеЗаполнено(СтрокаТ.КодМКБ10) Тогда			  
			ЧистыйКодМКБ10 = СокрЛП(СтрокаТ.КодМКБ10);
			СтрокаТВ.КодМКБ10 = СтрокаТВ.КодМКБ10 + ?(ЗначениеЗаполнено(ЧистыйКодМКБ10), ЧистыйКодМКБ10 + "; ", "");			
			СтрокаТВ.РеквизитЗначение = ?(ДиагнозСКодом = Истина, СокрЛП(СтрокаТВ.РеквизитЗначение) + ", " + ЧистыйКодМКБ10, СтрокаТВ.РеквизитЗначение);
			
		Иначе
			СтрокаТВ.КодМКБ10 = "";
		КонецЕсли;	
		 		 
		СтрокаТВ.ТипРеквизита = ТипЗнч(СтрокаТ.ЗначениеПоля);
																	  																	  
		 // Для первичного осмотра необходимо определить титульные реквизиты							  
		Если СтрокаТ.ШаблонОбследования = Справочники.ШаблоныОбследований.ПервичныйСтоматологическийОсмотр Тогда	 
			 Если СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.Диагноз
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.Жалобы 
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.ПеренесенныеИСопутствующиеЗаболевания
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.РазвитиеНастоящегоЗаболевания
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.ДанныеОбъективногоИсследования
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.Прикус
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.СостояниеСлизистойОболочкиПолостиРта
				 ИЛИ СтрокаТ.Реквизит = ПланыВидовХарактеристик.ПараметрыОбследований.ДанныеРентгеновскихЛабораторныхИсследований Тогда
				 
				 СтрокаТВ.ЭтоТитульныйРеквизит = Истина;
			 КонецЕсли;	 			  
		КонецЕсли;	
	КонецЦикла;
	   
   Возврат ВременнаяТаблица;
	
КонецФункции

#КонецОбласти