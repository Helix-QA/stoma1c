						КомандаУдалить 				= Форма.Команды.Добавить("Подключаемый_Удалить_Промокод_" + ИндексСтроки);
						КомандаУдалить.Заголовок 	= "Удалить промокод";
						КомандаУдалить.Подсказка 	= КомандаУдалить.Заголовок;					   
						КомандаУдалить.Действие		= "Подключаемый_Удалить_Промокод_Нажатие";
						КомандаУдалить.ИзменяетСохраняемыеДанные = Истина;
					КонецЕсли;
					КнопкаУдалить.ИмяКоманды 				= "Подключаемый_Удалить_Промокод_" + ИндексСтроки;
