&НаКлиенте
// Обработчик кнопки автогенерации штрихкода карты
Процедура СгенерироватьКод(Команда)
	
	Если Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Штриховая") Тогда
		Объект.КодКарты = СформироватьШтрихкодEAN13();
	Иначе 
		Объект.КодКарты = СформироватьКодКартыW26(); 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Поиск и печать шаблона карты
//
Процедура ПечатьКарты(Команда)
	
	ВыборкаШаблонов = ПолучитьШаблоныПластиковыхКарт();
	
	Если ВыборкаШаблонов.Количество() = 0 Тогда
		
		// запрос на создание новой карты
		ПоказатьВопрос(Новый ОписаниеОповещения("ПечатьКартыОтвет", ЭтаФорма)
				, НСтр("ru='Создать шаблон карты?';en='Create template cards?'")
				, РежимДиалогаВопрос.ДаНет,,
				,НСтр("ru='Не обнаружено ни одного шаблона карты!';en='Not discovered any one pattern cards!'"));
		
	ИначеЕсли ВыборкаШаблонов.Количество() = 1 Тогда
		
		ШаблонКарты = ЗаполнитьШаблонКарты(ВыборкаШаблонов[0],Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Штриховая"));	
		ШаблонКарты.Показать();	
		
	Иначе
		
		// форма выбора макета
		ПараметрыФормы = Новый Структура("Отбор", Новый Структура("ТипШаблона",ПредопределенноеЗначение("Перечисление.ТипыШаблонов.ПластиковаяКарта")));
		ОткрытьФорму("Справочник.ХранилищеШаблонов.ФормаВыбора", ПараметрыФормы, ЭтаФорма);
		
	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
