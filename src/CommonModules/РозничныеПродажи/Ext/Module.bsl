// РЕГЛАМЕНТНЫЕ ЗАДАНИЯ
// Процедура выполняет архивирование чеков с регистрацией события в журнале регистрации.
// Вызывается регламентным заданием.
//
Процедура АрхивированиеЧековККМ() Экспорт
	
	ЗаписьЖурналаРегистрации(НСтр("ru = 'Архивирование чеков'"),
	УровеньЖурналаРегистрации.Информация, , ,
	НСтр("ru = 'Начато регламентное архивирование чеков'"));
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КассоваяСмена.Ссылка КАК КассоваяСмена
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.Проведен
	|	И КассоваяСмена.СтатусыКассовойСмены = &СтатусыКассовойСмены";
	
	Запрос.УстановитьПараметр("СтатусыКассовойСмены", Перечисления.СтатусыКассовойСмены.Закрыта);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОписаниеОшибки = "";
		// АрхивацияВыполнена = 
		
		// РозничныеПродажи.ВыполнитьАрхивациюЧековККМ(Выборка.КассоваяСмена, ОписаниеОшибки);
		
		АрхивацияВыполнена = ?(ОписаниеОшибки = "", Истина, Ложь);
		
		Если НЕ АрхивацияВыполнена Тогда
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Архивирование чеков'"),
			УровеньЖурналаРегистрации.Ошибка, , ,
			НСтр("ru = 'Во время регламентного архивирования чеков произошла ошибка.'")
			+ Символы.ПС + ОписаниеОшибки);
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаписьЖурналаРегистрации(НСтр("ru = 'Архивирование чеков'"),
	УровеньЖурналаРегистрации.Информация, , ,
	НСтр("ru = 'Закончено регламентное архивирование чеков'"));
	
КонецПроцедуры // АрхивированиеЧековККМ()

// Функция формирует документы СписаниеМатериалов
//
Функция СформироватьСписаниеМатериалов(КассоваяСмена, ОписаниеОшибки = "") Экспорт
	
	МассивДокументов = Новый Массив;
	Если КассоваяСмена.Касса.АвтоматическоеСписаниеМатериалов Тогда 
		
		ВыборкаМатериалы = ПолучитьВыборкуСписываемыхМатериалов(КассоваяСмена);	
		Пока ВыборкаМатериалы.Следующий() Цикл			
			СписаниеМатериалов = Документы.СписаниеМатериалов.СоздатьДокумент();	
			СписаниеМатериалов.Дата = ТекущаяДата();
			СписаниеМатериалов.СтруктурнаяЕдиница = КассоваяСмена.СтруктурнаяЕдиница;
			Если ТипЗнч(ВыборкаМатериалы.Склад) = Тип("СправочникСсылка.Сотрудники") Тогда 
				СписаниеМатериалов.ВидОперации 	= Перечисления.ВидыОпераций.ПоСотруднику;
			ИначеЕсли ТипЗнч(ВыборкаМатериалы.Склад) = Тип("СправочникСсылка.Склады") Тогда	
				СписаниеМатериалов.ВидОперации = Перечисления.ВидыОпераций.ПоСкладу;
			КонецЕсли;	
			СписаниеМатериалов.Склад			= ВыборкаМатериалы.Склад; 
			СписаниеМатериалов.АвторДокумента	= ПараметрыСеанса.ТекущийПользователь;
			
			ВыборкаПоСкладам = ВыборкаМатериалы.Выбрать(ОбходРезультатаЗапроса.Прямой);
			Пока ВыборкаПоСкладам.Следующий() Цикл				
				СтрокаЗапасы = СписаниеМатериалов.Запасы.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаЗапасы, ВыборкаПоСкладам);
				СтрокаЗапасы.КоличествоУпаковок = СтрокаЗапасы.Количество;				
				СтрокаЗапасы.СтруктурнаяЕдиница = КассоваяСмена.СтруктурнаяЕдиница;
			КонецЦикла;
			СписаниеМатериалов.Записать();
			МассивДокументов.Добавить(СписаниеМатериалов.Ссылка);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивДокументов;
	
КонецФункции

// Функция возвращает выборку списываемых материалов
//
Функция ПолучитьВыборкуСписываемыхМатериалов(КассоваяСмена)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МатериалыКСписанию.Период КАК Период,
	|	МатериалыКСписанию.Склад КАК Склад,
	|	МатериалыКСписанию.Услуга КАК Услуга,
	|	МатериалыКСписанию.Материал КАК Номенклатура,
	|	МатериалыКСписанию.Партия КАК Партия,
	|	МатериалыКСписанию.Сотрудник КАК Сотрудник,
	|	МатериалыКСписанию.Клиент КАК Контрагент,
	|	МатериалыКСписанию.ДокументПродажи КАК ДокументПродажи,
	|	МатериалыКСписанию.Количество КАК Количество,
	|	ВложенныйЗапрос.ОкончаниеКассовойСмены КАК ОкончаниеКассовойСмены
	|ИЗ
	|	РегистрНакопления.МатериалыКСписанию КАК МатериалыКСписанию
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ ПЕРВЫЕ 1
	|			КассоваяСмена.ОкончаниеКассовойСмены КАК ОкончаниеКассовойСмены,
	|			КассоваяСмена.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|			КассоваяСмена.Касса КАК Касса
	|		ИЗ
	|			Документ.КассоваяСмена КАК КассоваяСмена
	|		ГДЕ
	|			КассоваяСмена.Касса = &Касса
	|			И КассоваяСмена.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			И КассоваяСмена.Ссылка <> &Ссылка
	|		
	|		УПОРЯДОЧИТЬ ПО
	|			КассоваяСмена.Дата УБЫВ) КАК ВложенныйЗапрос
	|		ПО МатериалыКСписанию.СтруктурнаяЕдиница = ВложенныйЗапрос.СтруктурнаяЕдиница
	|			И МатериалыКСписанию.ДокументПродажи.Касса = ВложенныйЗапрос.Касса
	|ГДЕ
	|	МатериалыКСписанию.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА ВложенныйЗапрос.ОкончаниеКассовойСмены ЕСТЬ NULL
	|				ТОГДА МатериалыКСписанию.Период >= &ПериодОт
	|			ИНАЧЕ МатериалыКСписанию.Период > ВложенныйЗапрос.ОкончаниеКассовойСмены
	|		КОНЕЦ
	|	И МатериалыКСписанию.Период <= &ПериодДо
	|	И МатериалыКСписанию.Регистратор ССЫЛКА Документ.Прием
	|
	|УПОРЯДОЧИТЬ ПО
	|	МатериалыКСписанию.Материал.Наименование
	|ИТОГИ ПО
	|	Склад");

	Запрос.УстановитьПараметр("Ссылка"				, КассоваяСмена);			   
	Запрос.УстановитьПараметр("Касса"				, КассоваяСмена.Касса); 				   
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, КассоваяСмена.СтруктурнаяЕдиница); 
	Запрос.УстановитьПараметр("ПериодОт"			, КассоваяСмена.НачалоКассовойСмены); 
	Запрос.УстановитьПараметр("ПериодДо"			, КассоваяСмена.ОкончаниеКассовойСмены); 
	
	Возврат Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	
КонецФункции

//////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ ОТКРЫТИЯ И ЗАКРЫТИЯ КАССОВОЙ СМЕНЫ
     
// Процедура выполняет закрытие кассовой смены.
//
Функция ВыполнитьОперациюЗакрытияКассовойСмены(Касса, ОшибкаПриСнятииZОтчета, ОписаниеОшибки = "") Экспорт
	                                            	
	МассивДокументов = Новый Массив;
	
	Попытка
		
		НачатьТранзакцию();
		
		// Закрытие кассовой смены 	
		КассоваяСмена = ОбщегоНазначенияСтоматология.ВернутьКассуИВыполнитьЗакрытиеСмены(Касса, ОписаниеОшибки);
		Если КассоваяСмена = Неопределено Тогда
			ВызватьИсключение ОписаниеОшибки;
		КонецЕсли;
		
		// Формирование документа СписаниеМатериалов
		МассивСозданных = СформироватьСписаниеМатериалов(КассоваяСмена, ОписаниеОшибки);
		Если МассивСозданных <> Неопределено Тогда 
			Для Каждого ДокСсылка Из МассивСозданных Цикл 
				МассивДокументов.Добавить(ДокСсылка);	
			КонецЦикла;
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
		
		// Выполним попытку проведения документов отчет, в том случае, если транзакция удалась, но по каким-то причинам отчет не провелся.
		Для Каждого ДокументКПроведению Из МассивДокументов Цикл
			Если ЗначениеЗаполнено(ДокументКПроведению.Ссылка) и (НЕ ДокументКПроведению.Проведен) Тогда
				ДокументКПроведениюОбъект = ДокументКПроведению.ПолучитьОбъект();
				Попытка
					ДокументКПроведениюОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Оперативный);
				Исключение
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось провести документ """ + ДокументКПроведению + """.");
				КонецПопытки;  				
			КонецЕсли;
		КонецЦикла;
		
	Исключение
		
		ОтменитьТранзакцию();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		
	КонецПопытки;
	
	Возврат МассивДокументов;
	
КонецФункции // ВыполнитьОперациюЗакрытияКассовойСмены()
           
