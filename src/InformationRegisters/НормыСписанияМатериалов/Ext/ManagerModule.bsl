#Область СлужебныеПроцедурыИФункции

// Функция - Получить нормы списания материалов
//
// Параметры:
//  Номенклатура		 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНормыСписанияМатериалов(Номенклатура, СтруктурнаяЕдиница, Упаковка = Неопределено, Материал = Неопределено) Экспорт
		                           
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НормыСписанияМатериалов.Материал КАК Материал,
	|	НормыСписанияМатериалов.Номенклатура КАК Номенклатура,
	|	НормыСписанияМатериалов.Партия КАК Партия,
	|	НормыСписанияМатериалов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НормыСписанияМатериалов.ВидЦен КАК ВидЦен,
	|	НормыСписанияМатериалов.Количество КАК Количество,
	|	НормыСписанияМатериалов.СкладСписания КАК СкладСписания,
	|	НормыСписанияМатериалов.Упаковка КАК Упаковка,
	|	НормыСписанияМатериалов.Номенклатура.ЕдиницаИзмерения.Наименование КАК НоменклатураЕдиницаИзмерения,
	|	НормыСписанияМатериалов.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	НормыСписанияМатериалов.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	НормыСписанияМатериалов.НормыСписанияНеИспользуются КАК НормыСписанияНеИспользуются
	|ПОМЕСТИТЬ НормыСписанияМатериалов
	|ИЗ
	|	РегистрСведений.НормыСписанияМатериалов КАК НормыСписанияМатериалов
	|ГДЕ
	|	НормыСписанияМатериалов.Номенклатура = &Номенклатура
	|	И ВЫБОР
	|			КОГДА &Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НормыСписанияМатериалов.Упаковка = &Упаковка
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &Материал = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НормыСписанияМатериалов.Материал = &Материал
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НормыСписанияМатериалов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НормыСписанияМатериалов.Номенклатура КАК Номенклатура,
	|	НормыСписанияМатериалов.Материал КАК Материал,
	|	НормыСписанияМатериалов.СкладСписания КАК СкладСписания,
	|	НормыСписанияМатериалов.Партия КАК Партия,
	|	НормыСписанияМатериалов.Упаковка КАК Упаковка,
	|	НормыСписанияМатериалов.Количество КАК Количество,
	|	НормыСписанияМатериалов.ВидЦен КАК ВидЦен,
	|	НормыСписанияМатериалов.НоменклатураЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	НормыСписанияМатериалов.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	НормыСписанияМатериалов.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	НормыСписанияМатериалов.НормыСписанияНеИспользуются КАК НормыСписанияНеИспользуются
	|ИЗ
	|	НормыСписанияМатериалов КАК НормыСписанияМатериалов
	|ГДЕ
	|	НормыСписанияМатериалов.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	Материал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НормыСписанияМатериалов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НормыСписанияМатериалов.Номенклатура КАК Номенклатура,
	|	НормыСписанияМатериалов.Материал КАК Материал,
	|	НормыСписанияМатериалов.СкладСписания КАК СкладСписания,
	|	НормыСписанияМатериалов.Партия КАК Партия,
	|	НормыСписанияМатериалов.Упаковка КАК Упаковка,
	|	НормыСписанияМатериалов.Количество КАК Количество,
	|	НормыСписанияМатериалов.ВидЦен КАК ВидЦен,
	|	НормыСписанияМатериалов.НоменклатураЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	НормыСписанияМатериалов.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	НормыСписанияМатериалов.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	НормыСписанияМатериалов.НормыСписанияНеИспользуются КАК НормыСписанияНеИспользуются
	|ИЗ
	|	НормыСписанияМатериалов КАК НормыСписанияМатериалов
	|ГДЕ
	|	НормыСписанияМатериалов.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Материал";   
	
	Запрос.УстановитьПараметр("Номенклатура"		, Номенклатура);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	Если Упаковка <> Неопределено Тогда
		
		Запрос.УстановитьПараметр("Упаковка", Упаковка);
		
	Иначе 
		
		Запрос.УстановитьПараметр("Упаковка", Справочники.УпаковкиНоменклатуры.ПустаяСсылка());
		
	КонецЕсли;
	Если Материал <> Неопределено Тогда
		
		Запрос.УстановитьПараметр("Материал", Материал);
		
	Иначе
		
		Запрос.УстановитьПараметр("Материал", Справочники.Номенклатура.ПустаяСсылка());

	КонецЕсли;
	
	Пакет = Запрос.ВыполнитьПакет();
	
	ИндивидуальныеНормыСписания = Пакет[1].Выгрузить();
	ОбщиеНормыСписания			= Пакет[2].Выгрузить();
	
	Возврат ?(ИндивидуальныеНормыСписания.Количество() = 0, ОбщиеНормыСписания, ИндивидуальныеНормыСписания);
	
КонецФункции                                                         

// Процедура - Записать нормы списания в регистр
//
// Параметры:
//  НоменклатураНормСписания - 	 - 
//  СтруктурнаяЕдиница		 - 	 - 
//
Процедура ЗаписатьНормыСписанияВРегистр(НоменклатураНормСписания, СтруктурнаяЕдиница) Экспорт
	
	НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Номенклатура.Установить(НоменклатураНормСписания);
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
	
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Значение = СтруктурнаяЕдиница;
	НаборЗаписей.Отбор.Номенклатура.Значение = СтруктурнаяЕдиница;
			
	НаборЗаписей.Записать(Истина);
	
КонецПроцедуры

// Функция - Получить склад списания норм материалов
//
// Параметры:
//  СтрокаТЧ			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  Сотрудник			 - 	 - 
//  Помещение			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСкладСписанияНормМатериалов(СтрокаТЧ, СтруктурнаяЕдиница, Сотрудник) Экспорт
	
	// Индивидуальная норма списания.
	СкладСписания = Справочники.Склады.ПустаяСсылка();
	Если ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) И ЗначениеЗаполнено(СтрокаТЧ.СкладСписания) Тогда  
		
		СкладСписания = СтрокаТЧ.СкладСписания; 
		
	// Общие нормы списания.
	ИначеЕсли ТипЗнч(СтрокаТЧ.СкладСписания) = Тип("СправочникСсылка.Склады") Тогда
		
		СкладСписания = СтруктурнаяЕдиница.ОсновнойСклад;
		
		Если НЕ ЗначениеЗаполнено(СкладСписания) Тогда
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
				СкладСписания = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТЧ.СтруктурнаяЕдиница, "ОсновнойСклад");	
			Иначе
				СкладСписания = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "ОсновнойСклад"); 
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		СкладСписания = Сотрудник;
		
	КонецЕсли;
	
	Возврат СкладСписания;
	
КонецФункции

#Область ЗагрузкаДанныхИзВнешнегоИсточника

// Процедура - Записи в регистре для номенклатуры существуют
//
// Параметры:
//  Номенклатура - 	 - 
//
Функция ЗаписиВРегистреДляНоменклатурыСуществуют(Номенклатура) Экспорт
	
	НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
	НаборЗаписей.Прочитать();
	
	Возврат НаборЗаписей.Количество() > 0;	

КонецФункции 

// Процедура - При определении образцов загрузки данных.
//
Процедура ПриОпределенииОбразцовЗагрузкиДанных(НастройкиЗагрузкиДанных, УникальныйИдентификатор) Экспорт
	
	Образец_xlsx = ПолучитьМакет("ОбразецЗагрузкиДанных_xlsx");
	ОбразецЗагрузкиДанных_xlsx = ПоместитьВоВременноеХранилище(Образец_xlsx, УникальныйИдентификатор);
	НастройкиЗагрузкиДанных.Вставить("ОбразецЗагрузкиДанных_xlsx", ОбразецЗагрузкиДанных_xlsx);
	
КонецПроцедуры

// Процедура - Поля загрузки данных из внешнего источника.
//
Процедура ПоляЗагрузкиДанныхИзВнешнегоИсточника(ТаблицаПолейЗагрузки, НастройкиЗагрузкиДанных) Экспорт
	
	//
	// Для группы полей действует правило: хотя бы одно поле в группе должно быть выбрано в колонках
	//
	
	ОписаниеТиповСтрока11 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(11));
	ОписаниеТиповСтрока25 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(25));
	ОписаниеТиповСтрока100 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	ОписаниеТиповСтрока150 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(150));
	ОписаниеТиповСтрока200 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(200));
	ОписаниеТиповСтрока1000 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(1000));
	ОписаниеТиповЧисло15_2 = Новый ОписаниеТипов("Число", , , , Новый КвалификаторыЧисла(15, 3, ДопустимыйЗнак.Неотрицательный));
	ОписаниеТиповДата = Новый ОписаниеТипов("Дата", , , , Новый КвалификаторыДаты(ЧастиДаты.Дата));
	ОписаниеТиповБулево = Новый ОписаниеТипов("Булево");
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НоменклатураКодСинхронизации", "Код синхронизации", ОписаниеТиповСтрока25, ОписаниеТиповКолонка, "Номенклатура", 1);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НоменклатураНаименование","Номенклатура (наименование)", ОписаниеТиповСтрока100, ОписаниеТиповКолонка, "Номенклатура", 2, , Истина);
	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "МатериалКодСинхронизации","Код синхронизации", ОписаниеТиповСтрока100, ОписаниеТиповКолонка, "Материал", 1);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "МатериалНаименование","Материал (наименование)", ОписаниеТиповСтрока100, ОписаниеТиповКолонка, "Материал", 2,, Истина);
		
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Количество", "Количество", ОписаниеТиповСтрока25, ОписаниеТиповЧисло15_2, , , Истина);
	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ВключатьВСтоимостьУслуги", "Включать в стоимость услуги", ОписаниеТиповСтрока11, ОписаниеТиповБулево);

	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НеЗависитОтКоличестваУслуг", "Зависит от услуг", ОписаниеТиповСтрока11, ОписаниеТиповБулево);

	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "СтруктурнаяЕдиница","Структурная единица", ОписаниеТиповСтрока100, ОписаниеТиповКолонка);
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.Склады");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "СкладСписания","Склад списания", ОписаниеТиповСтрока100, ОписаниеТиповКолонка);
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.ВидыЦен");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ВидЦен","Вид цен стоимости материалов", ОписаниеТиповСтрока100, ОписаниеТиповКолонка);
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.УпаковкиНоменклатуры");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Упаковка", "Упаковка", ОписаниеТиповСтрока100, ОписаниеТиповКолонка);
	
	//ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.Калькуляции");
	//ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Калькуляция", "Калькуляция", ОписаниеТиповСтрока100, ОписаниеТиповКолонка);
	
КонецПроцедуры

// Процедура - Сопоставить загружаемые данные из внешнего источника.
//
Процедура СопоставитьЗагружаемыеДанныеИзВнешнегоИсточника(ПараметрыСопоставления, АдресРезультата) Экспорт
	Перем ОбщееЗначение;
	
	ТаблицаСопоставленияДанных	= ПараметрыСопоставления.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	НастройкиЗагрузкиДанных		= ПараметрыСопоставления.НастройкиЗагрузкиДанных;
	
	ОбновлятьДанные = НастройкиЗагрузкиДанных.ОбновлятьСуществующие;
	
	НастройкиЗагрузкиДанных.Свойство("ОбщееЗначение", ОбщееЗначение);
	
	// ТаблицаСопоставленияДанных - Тип ДанныеФормыКоллекция
	Для каждого СтрокаТаблицыФормы Из ТаблицаСопоставленияДанных Цикл
		
		// Номенклатура
		СопоставитьНоменклатуру(СтрокаТаблицыФормы.Номенклатура, СтрокаТаблицыФормы.НоменклатураНаименование, СтрокаТаблицыФормы.НоменклатураКодСинхронизации, Перечисления.ТипыНоменклатуры.Услуга);	
		
		// Материал
		СопоставитьНоменклатуру(СтрокаТаблицыФормы.Материал, СтрокаТаблицыФормы.МатериалНаименование, СтрокаТаблицыФормы.МатериалКодСинхронизации, Перечисления.ТипыНоменклатуры.Запас);
		
		// Количество
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Количество, СтрокаТаблицыФормы.Количество_ВходящиеДанные);
		
		// Структурная единица
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьСтруктурнуюЕдиницу(СтрокаТаблицыФормы.СтруктурнаяЕдиница, СтрокаТаблицыФормы.СтруктурнаяЕдиница_ВходящиеДанные, Неопределено);
		
		// Склад списания
		СопоставитьСклад(СтрокаТаблицыФормы.СкладСписания, СтрокаТаблицыФормы.СкладСписания_ВходящиеДанные, СтрокаТаблицыФормы.СтруктурнаяЕдиница);
		
		// Включать в стоимость услуги
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВБулево(СтрокаТаблицыФормы.ВключатьВСтоимостьУслуги, СтрокаТаблицыФормы.ВключатьВСтоимостьУслуги_ВходящиеДанные);
		
		// Не зависит от количества услуг
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВБулево(СтрокаТаблицыФормы.НеЗависитОтКоличестваУслуг, СтрокаТаблицыФормы.НеЗависитОтКоличестваУслуг_ВходящиеДанные);
		
		// Вид цен стоимости материалов
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьВидЦен(СтрокаТаблицыФормы.ВидЦен, СтрокаТаблицыФормы.ВидЦен_ВходящиеДанные, Справочники.ВидыЦен.ПустаяСсылка());
		
		// Упаковка
		НоменклатураУпаковки = ?(ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура), СтрокаТаблицыФормы.Номенклатура, СтрокаТаблицыФормы.НоменклатураНаименование);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьУпаковку(СтрокаТаблицыФормы.Упаковка, СтрокаТаблицыФормы.Упаковка_ВходящиеДанные, Неопределено, НоменклатураУпаковки);
		
		//// Калькуляция
		//СопоставитьКалькуляцию(СтрокаТаблицыФормы.Калькуляция, СтрокаТаблицыФормы.Калькуляция_ВходящиеДанные, СтрокаТаблицыФормы.Номенклатура);
		
		ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы);
		
		ЗагрузкаДанныхИзВнешнегоИсточника.ПрогрессСопоставленияДанных(ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицыФормы), РазмерТаблицыДанных);
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ТаблицаСопоставленияДанных, АдресРезультата);
	
КонецПроцедуры

// Процедура - Проверить корректность данных в строке таблицы.
//
Процедура ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения = "") Экспорт
	
	ИмяСлужебногоПоля = ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна();
	СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.Количество)
				И ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура);
	
	Если СтрокаТаблицыФормы[ИмяСлужебногоПоля] Тогда
		
		НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтрокаТаблицыФормы.СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТаблицыФормы.Номенклатура);
		НаборЗаписей.Отбор.Материал.Установить(СтрокаТаблицыФормы.Материал);
		//НаборЗаписей.Отбор.Калькуляция.Установить(СтрокаТаблицыФормы.Калькуляция);
		
		НаборЗаписей.Прочитать();
		
		СтрокаТаблицыФормы._СтрокаСопоставлена = (НаборЗаписей.Количество() > 0);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработать подготовленные данные.
//
Процедура ОбработатьПодготовленныеДанные(СтруктураДанных, ФоновоеЗаданиеАдресХранилища = "") Экспорт
	
	ОбновлятьСуществующие		= СтруктураДанных.НастройкиЗагрузкиДанных.ОбновлятьСуществующие;
	СоздаватьНовые 				= СтруктураДанных.НастройкиЗагрузкиДанных.СоздаватьЕслиНеСопоставлено;
	ТаблицаСопоставленияДанных	= СтруктураДанных.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	КоличествоЗаписейТранзакции	= 0;
	ТранзакцияОткрыта			= Ложь;
	
	Попытка
		
		Для каждого СтрокаТаблицы Из ТаблицаСопоставленияДанных Цикл
			
			Если НЕ ТранзакцияОткрыта
				И КоличествоЗаписейТранзакции = 0 Тогда
				
				НачатьТранзакцию();
				ТранзакцияОткрыта = Истина;
				
			КонецЕсли;
			
			ЗагрузкаВПриложениеВозможна = СтрокаТаблицы[ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна()];
			
			СогласованноеСостояниеСтроки = (СтрокаТаблицы._СтрокаСопоставлена И ОбновлятьСуществующие) 
				ИЛИ (НЕ СтрокаТаблицы._СтрокаСопоставлена И СоздаватьНовые);
			
			Если ЗагрузкаВПриложениеВозможна И СогласованноеСостояниеСтроки Тогда
				
				КоличествоЗаписейТранзакции = КоличествоЗаписейТранзакции + 1;
				
				// Создаем материал
				Если Не ЗначениеЗаполнено(СтрокаТаблицы.Материал) Тогда
					
					НовыйМатериал = Справочники.Номенклатура.СоздатьЭлемент();
					НовыйМатериал.Заполнить(Новый Структура);
					НовыйМатериал.Наименование = ?(ЗначениеЗаполнено(СтрокаТаблицы.МатериалНаименование), СтрокаТаблицы.МатериалНаименование, "Загруженный материал " + СтрокаТаблицы.МатериалКодСинхронизации);
					НовыйМатериал.Родитель = Справочники.Номенклатура.НайтиПоНаименованию("Материалы");
					НовыйМатериал.КодСинхронизации = СтрокаТаблицы.МатериалКодСинхронизации;
					НовыйМатериал.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал;
					НовыйМатериал.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
					НовыйМатериал.Записать();
					
					СтрокаТаблицы.Материал = НовыйМатериал.Ссылка;
					
				КонецЕсли;
								
				НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
				
				НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтрокаТаблицы.СтруктурнаяЕдиница);
				НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТаблицы.Номенклатура);
				НаборЗаписей.Отбор.Материал.Установить(СтрокаТаблицы.Материал);
				//НаборЗаписей.Отбор.Калькуляция.Установить(СтрокаТаблицы.Калькуляция);
				
				НаборЗаписей.Прочитать();
				Если НаборЗаписей.Количество() <> 0 Тогда				
					НаборЗаписей.Очистить();				
				КонецЕсли;
				
				НоваяСтрока = НаборЗаписей.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
				НоваяСтрока.ВключатьВСтоимостьУслуги = СтрокаТаблицы.ВключатьВСтоимостьУслуги;
				//НоваяСтрока.НеЗависитОтКоличестваУслуг = Не НоваяСтрока.НеЗависитОтКоличестваУслуг;
				//НоваяСтрока.НормыСписанияНеИспользуются = ?(СтрокаТаблицы.Количество = 0, Истина, Ложь);
							
				НаборЗаписей.Записать();
				
			КонецЕсли;
			
			ИндексТекущейстроки	= ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицы);
			ТекстПрогресса		= СтрШаблон(НСтр("ru ='Обработано %1 из %2 строк...'"), ИндексТекущейстроки, РазмерТаблицыДанных);
			
			#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
				ДлительныеОперации.СообщитьПрогресс(ОКР(ИндексТекущейстроки * 100 / РазмерТаблицыДанных, 1), ТекстПрогресса);
			#КонецЕсли
			Если ТранзакцияОткрыта
				И КоличествоЗаписейТранзакции > ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.МаксимумЗаписейВОднойТранзакции() Тогда
				
				ЗафиксироватьТранзакцию();			
				ТранзакцияОткрыта = Ложь;
				КоличествоЗаписейТранзакции = 0;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если КоличествоЗаписейТранзакции > 0 Тогда
			
			ЗафиксироватьТранзакцию();	
			ТранзакцияОткрыта = Ложь;
			
		КонецЕсли;
		
	Исключение
		
		ЗаписьЖурналаРегистрации(Нстр("ru='Загрузка данных'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.РегистрыСведений.ЦеныНоменклатуры, , ОписаниеОшибки());
		ОтменитьТранзакцию();
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

