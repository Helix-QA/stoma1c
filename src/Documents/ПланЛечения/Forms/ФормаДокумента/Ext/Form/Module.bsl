// Функция, получить представление строки авто подбора
//
Функция ПолучитьПредставлениеУслугиАвтоПодбора(СтруктураДанные)
	
	ПредставлениеНормыВремени = "";
	Если ЗначениеЗаполнено(СтруктураДанные.НормаВремени) Тогда
		ПредставлениеНормыВремени = Новый ФорматированнаяСтрока(",", Новый ФорматированнаяСтрока(" " + СтруктураДанные.НормаВремени + " мин",, Новый Цвет(0,112,210)));
	КонецЕсли;
	
	ПредставлениеЦены = "";
	Если ЗначениеЗаполнено(СтруктураДанные.Цена) Тогда
		
		СтранаУчета = Константы.СтранаУчета.Получить();  		
		
		ПредставлениеВалютыУчета = СтрРазделить(СтранаУчета.ВалютаУчета.ПараметрыПрописи, ",");
		
		НаименованиеВалюты = ?(ПредставлениеВалютыУчета.Количество() > 9, ПредставлениеВалютыУчета[9], "руб.");
		
		ПредставлениеЦены = Новый ФорматированнаяСтрока(",", Новый ФорматированнаяСтрока(" " + СтруктураДанные.Цена 
			+ НаименованиеВалюты,, ЦветаСтиля.ФайлЗанятыйТекущимПользователем));
		
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока((СтруктураДанные.Наименование), ПредставлениеНормыВремени, ПредставлениеЦены);
	
КонецФункции

