// Процедура, ОбновитьРеквизитыТаблицыУслуг.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ОбновитьРеквизитыТаблицыУслуг()
	
	НесколькоВрачейВОдномПриеме = Константы.НесколькоВрачейВОдномПриеме.Получить();

	Если НЕ НесколькоВрачейВОдномПриеме Тогда
		
		ОсновнойВрач = ?(Объект.Услуги.Количество()>0, Объект.Услуги[0].Сотрудник, Неопределено);
		ОсновноеПомещение = ?(Объект.Услуги.Количество()>0, Объект.Услуги[0].Помещение, Неопределено);	
		
		 Для Каждого СтрокаТЧ Из Объект.Услуги Цикл
			 
			  СтрокаТЧ.Сотрудник = ОсновнойВрач;
			  СтрокаТЧ.Помещение = ОсновноеПомещение;
			 
		 КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

