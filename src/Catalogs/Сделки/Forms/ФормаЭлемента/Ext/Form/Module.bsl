// Процедура, УстановитьУсловноеОформмлениеСписка.
//
Процедура УстановитьУсловноеОформмлениеСписка()
	
	Если ЗначениеЗаполнено(Объект.ПричинаОтказа) Тогда
		
		НайденнаяСтрока = ЭтотОбъект.СписокПричинОтказа.НайтиПоЗначению(Объект.ПричинаОтказа);
		
		Если НайденнаяСтрока <> Неопределено Тогда
			
			ЭтаФорма.УсловноеОформление.Элементы.Очистить();
			
			ЭлементУФ = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
			// Создаем условие отбора
			ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("СписокПричинОтказа.Значение"); // имя поля
			ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно; // либо задаем свой	
			ЭлементОтбора.ПравоеЗначение = Объект.ПричинаОтказа;
			ЭлементОтбора.Использование  = Истина;
			
			ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона", Новый Цвет(246, 110, 110));
			ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255, 255, 255));
			
			ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
			ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("СписокПричинОтказаЗначение");
			ПолеОформления.Использование = Истина;
						
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

