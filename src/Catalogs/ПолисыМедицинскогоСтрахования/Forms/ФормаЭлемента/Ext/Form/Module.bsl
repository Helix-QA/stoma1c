
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, Обработчик "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	
	ОтображатьКод = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	
	Элементы.Код.Видимость          = ОтображатьКод;
	Элементы.Код.ПоложениеЗаголовка = ?(ОтображатьКод, ПоложениеЗаголовкаЭлементаФормы.Авто, ПоложениеЗаголовкаЭлементаФормы.Нет);
	
	Элементы.Контрагент.ТолькоПросмотр = Параметры.Свойство("КотрагентТолькоПросмотр") И Параметры.КотрагентТолькоПросмотр;
	Элементы.ВалютаУчета.Заголовок     = Строка(Объект.СтраховаяКомпания.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств);
	Если Параметры.Свойство("Контрагент") И ЗначениеЗаполнено(Параметры.Контрагент) Тогда
		
		Объект.Контрагент = Параметры.Контрагент;
		Элементы.Контрагент.Видимость = Ложь;
		
	КонецЕсли; 
	
	Если Параметры.Свойство("СтраховаяКомпания")
		И НЕ ЗначениеЗаполнено(Объект.СтраховаяКомпания) Тогда
		Объект.СтраховаяКомпания = Параметры.СтраховаяКомпания;	
	КонецЕсли;
	
	Если НЕ Объект.Ссылка.Пустая()
		И Объект.ЛимитПолиса > 0 Тогда
		ПостроитьТаблицуИсторииОбъекта();	
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("СозданПолисМедСтрахования");
	
КонецПроцедуры

#КонецОбласти

