// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
			
	Параметры.Свойство("Сотрудник"					      , ОтборСотрудник);
	Параметры.Свойство("Контрагент"					      , ОтборКонтрагент);
	Параметры.Свойство("ЗакрытьПриСозданииЗаписи"	      , ПФЗакрытьПриСозданииЗаписи);
	Параметры.Свойство("ИмяКонтрагента"				      , ИмяКонтрагента);
	Параметры.Свойство("ТелефонКонтрагента"			      , ТелефонКонтрагента);
	Параметры.Свойство("Дата"                    	      , Объект.Дата); 
	Параметры.Свойство("ПеренесённаяПредварительнаяЗапись", ПеренесённаяПредварительнаяЗапись); 
	Параметры.Свойство("СтруктурнаяЕдиница"				  , Объект.СтруктурнаяЕдиница);
	
	Если НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
		Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	ПЗГрафикаРежимОтображения = 1;
	Если Параметры.Свойство("ПереключательПериода")
		И ЗначениеЗаполнено(Параметры.ПереключательПериода) Тогда
		
		ПЗГрафикаРежимОтображения = ?(Параметры.ПереключательПериода = Перечисления.ДоступныеПериодыОтчета.День, 0, 1);
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОтборСотрудник) И Параметры.Свойство("СпециализацияВрача") Тогда
		СпециализацияВрача = Параметры.СпециализацияВрача;
		Элементы.ОтборСотрудник.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
	КонецЕсли;	
	
	БуферОбмена = Новый Структура("Буфер, ПризнакВырезать");
	
	Если Не ЗначениеЗаполнено(Объект.Дата) Тогда
		Объект.Дата = ?(ЗначениеЗаполнено(Константы.ДатаДемоРежима.Получить()), Константы.ДатаДемоРежима.Получить(), ТекущаяДата());
	КонецЕсли;	
	ДобавитьДинамическиЛегендыПоКатегорям();
	
	ПолучитьРазрешениеМонитораКлиента();
	
	ЭтотОбъект.ЦветаЭлементов = Новый Структура;
	
	ЦветаЭлементов.Вставить("ЦветФона"                   , Новый Цвет(255, 255, 255));
	ЦветаЭлементов.Вставить("ЦветФонаВыбранного"         , Новый Цвет(218, 230, 244));
	ЦветаЭлементов.Вставить("ЦветТекста"                 , Новый Цвет(51,  102, 187));
	ЦветаЭлементов.Вставить("ЦветТекстаВыбранного"       , Новый Цвет(64,  64,  64));
	ЦветаЭлементов.Вставить("ЦветТекстаНеактивногоВизита", Новый Цвет(128, 128, 128));
	ЦветаЭлементов.Вставить("ЦветРамкиАктивногоВизита"   , WebЦвета.Красный);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ПриОткрытии(Отказ)
	
	РазрешениеЭкрана = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьТекущееРазрешениеЭкрана();
	
	// Устанавливаем необходимые свойства
	ТабличныйДокумент.ФиксацияСверху = 1;
	ТабличныйДокумент.ФиксацияСлева = 2;
	ОтображениеГрафика = ?(ЗначениеЗаполнено(СпециализацияВрача) ИЛИ ЭтотОбъект.ПЗГрафикаРежимОтображения = 0, Элементы.День, Элементы.Неделя);
	
	УстановитьСтраницуМенеджера(ОтображениеГрафика); 
	
	ОбновитьГрафик(,Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик оповещения формы.
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзмененоСобытие" Тогда
		ОбновитьГрафик(Ложь);
		ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента = Неопределено;
	ИначеЕсли ИмяСобытия = "ИзмененаСтруктурнаяЕдиница" Тогда
		Объект.СтруктурнаяЕдиница = Параметр.ТекущаяСтруктурнаяЕдиница;
		ОбновитьГрафик(); 
	ИначеЕсли ИмяСобытия = "ОбновлениеРабочегоСтола" Тогда		
		ОбновитьГрафик(Ложь);	
	ИначеЕсли ИмяСобытия = "СозданиеСобытияСКонтрагентом" Тогда
		
		Если Параметр.Свойство("Контрагент") Тогда
			ЭтотОбъект.ОтборКонтрагент = Параметр.Контрагент;
		КонецЕсли;
		
		Если Параметр.Свойство("КонтролироватьЗаписьПациентаПоСотруднику")
			И Параметр.КонтролироватьЗаписьПациентаПоСотруднику = Истина Тогда
			
			Параметр.Свойство("СотрудникПриКонтролеЗаписиПациента", ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента);
		Иначе
			ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента = Неопределено;		
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Обработчик 
Процедура ОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	
	Если ПФЗакрытьПриСозданииЗаписи Тогда
		ОповеститьОЗаписиНового(НовыйОбъект);
		Закрыть(НовыйОбъект);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура заполняет табличный документ.
//
Процедура ОбновитьГрафик(РазрешитьСмещениеГрафика = Истина,ОбновитьПанельДни = Ложь)
	
	ВыбранныеСотрудники = Новый Массив;
	// ВыбранныеСотрудники.Добавить("Все");
	Если ЗначениеЗаполнено(СпециализацияВрача) Тогда
		МассивСотрудников = ПолучитьМассивВрачейПоСпециализации(СпециализацияВрача); 
		Если ЗначениеЗаполнено(МассивСотрудников) Тогда
			Для Каждого Сотрудник Из МассивСотрудников Цикл
				ВыбранныеСотрудники.Добавить(Сотрудник); 	
			КонецЦикла;
		Иначе 
			ВыбранныеСотрудники.Добавить("Все");
		КонецЕсли;
	Иначе
		ВыбранныеСотрудники.Добавить(?(Не ОтборСотрудник.Пустая(), ОтборСотрудник, "Все")); 
	КонецЕсли;
	ВыбранныеПомещения = Новый Массив; 
	ВыбранныеПомещения.Добавить("Все");
	
	// Создаем структуру с параметрами построения графика
	ПараметрыПостроения = Новый Структура("ВыбранныеСотрудники, ВыбранныеПомещения, ВыбранныеКонтрагенты, СтраницаМенеджера, РазрешениеЭкрана, СтруктурнаяЕдиница, Дата, РазрешитьСмещениеГрафика,НаВсюФорму");
	ПараметрыПостроения.ВыбранныеСотрудники			=	ВыбранныеСотрудники;
	ПараметрыПостроения.ВыбранныеПомещения			=	ВыбранныеПомещения;
	ПараметрыПостроения.ВыбранныеКонтрагенты		=	Неопределено;
	ПараметрыПостроения.СтраницаМенеджера			=	ПолучитьСтраницуМенеджера();
	ПараметрыПостроения.СтруктурнаяЕдиница			=	Объект.СтруктурнаяЕдиница;
	ПараметрыПостроения.Дата						=	Объект.Дата;
	ПараметрыПостроения.РазрешитьСмещениеГрафика	=   РазрешитьСмещениеГрафика;
	ПараметрыПостроения.РазрешениеЭкрана			=   РазрешениеЭкрана;
	ПараметрыПостроения.НаВсюФорму			        =   Истина;
	#Если Не ВебКлиент Тогда
		ПараметрыПостроения.Вставить("ВыводитьКартинки", Истина);
	#КонецЕсли
	
	РабочийКалендарьСформироватьГрафикСобытий(ПараметрыПостроения,РазрешитьСмещениеГрафика,ОбновитьПанельДни);
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет формирование графика событий.
//  Параметры: 
//   ПараметрыПостроения - структура, содержит параметры, по которым выполняется формирование графика.
//
Процедура РабочийКалендарьСформироватьГрафикСобытий(ПараметрыПостроения, РазрешитьСмещениеГрафика = Истина,ОбновитьПанельДни = Ложь)	
	
	Если ОбновитьПанельДни Тогда
		ОбновитьПанельДниНеделиСервер();
	КонецЕсли;
	
	ЭтотОбъект.СписокСотрудниковВЛистеОжидания.Очистить();
	ПараметрыПостроения.Вставить("СписокСотрудниковВЛистеОжидания", ЭтотОбъект.СписокСотрудниковВЛистеОжидания);
	
	// Вызываем процедуру построения графика
	ГрафикСобытий = ОбщегоНазначенияСтоматология.СформироватьГрафикСобытий(ПараметрыПостроения);
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.ВставитьОбласть(ГрафикСобытий.Область());	
	// Устанавливаем необходимые свойства
	НеобходимаяГоризонтальнаяПрокрутка = ?(ПараметрыПостроения.Свойство("ОграничениеНаШиринуДня"), Истина, Ложь);
	Если Элементы.ТабличныйДокумент.ГоризонтальнаяПолосаПрокрутки <> НеобходимаяГоризонтальнаяПрокрутка Тогда
		Элементы.ТабличныйДокумент.ГоризонтальнаяПолосаПрокрутки = НеобходимаяГоризонтальнаяПрокрутка;
	КонецЕсли;	
	// ИнтервалГрафикаЗанятий = Пользователи.ПолучитьЗначениеПоУмолчаниюПользователя(, "ИнтервалГрафикаЗанятий");
	ИнтервалГрафикаЗанятий = 15; //?(ЗначениеЗаполнено(ИнтервалГрафикаЗанятий), Число(Сред(ИнтервалГрафикаЗанятий, 1, 2)), 15);	
	
	ТабличныйДокумент.ФиксацияСверху = ?(НЕ ГрафикСобытий.ФиксацияСверху = 0, ГрафикСобытий.ФиксацияСверху, 1);
	
КонецПроцедуры

&НаСервере
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Процедура ОбновитьПанельДниНеделиСервер() 
	
	Если Элементы.Неделя.Пометка Тогда
		КонецМесяца = КонецМесяца(Объект.Дата);
		НомерВсегоНедель = Цел((День(КонецМесяца) - ДеньНедели(КонецМесяца)) / 7) + ?((День(КонецМесяца) - ДеньНедели(КонецМесяца)) % 7 > 0, 1, 0) + 1;
		Элементы.ДатаНеделяМесяца1.Пометка = Ложь;
		Элементы.ДатаНеделяМесяца2.Пометка = Ложь;
		Элементы.ДатаНеделяМесяца3.Пометка = Ложь;
		Элементы.ДатаНеделяМесяца4.Пометка = Ложь;
		Элементы.ДатаНеделяМесяца5.Пометка = Ложь;
		Элементы.ДатаНеделяМесяца6.Пометка = Ложь;
		Элементы.ДатаНеделяМесяца1.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 1);
		Элементы.ДатаНеделяМесяца2.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 2);
		Элементы.ДатаНеделяМесяца3.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 3);
		Элементы.ДатаНеделяМесяца4.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 4);
		Элементы.ДатаНеделяМесяца5.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 5);
		Элементы.ДатаНеделяМесяца6.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 6);
		Элементы["ДатаНеделяМесяца" + ВернутьНомерНеделиМесяца(Объект.Дата)].Пометка = Истина;
		Для а = 1 По 6 Цикл
			Элементы["ДатаНеделяМесяца" + а + ""].Видимость = ?(а <= НомерВсегоНедель, Истина, Ложь);
		КонецЦикла;
	Иначе
	    Элементы.ДатаДеньНедели1.Пометка = Ложь;
		Элементы.ДатаДеньНедели2.Пометка = Ложь;
		Элементы.ДатаДеньНедели3.Пометка = Ложь;
		Элементы.ДатаДеньНедели4.Пометка = Ложь;
		Элементы.ДатаДеньНедели5.Пометка = Ложь;
		Элементы.ДатаДеньНедели6.Пометка = Ложь;
		Элементы.ДатаДеньНедели7.Пометка = Ложь;		
		Элементы.ДатаДеньНедели1.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 1);
		Элементы.ДатаДеньНедели2.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 2);
		Элементы.ДатаДеньНедели3.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 3);
		Элементы.ДатаДеньНедели4.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 4);
		Элементы.ДатаДеньНедели5.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 5);
		Элементы.ДатаДеньНедели6.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 6);
		Элементы.ДатаДеньНедели7.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 7);
		Элементы["ДатаДеньНедели" + ДеньНедели(Объект.Дата)].Пометка = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьДинамическиЛегендыПоКатегорям()
	
	// ВыборкаМеток = Справочники.Метки.Выбрать();
	// Пока ВыборкаМеток.Следующий() Цикл
	//	Если Не ВыборкаМеток.ЭтоГруппа Тогда 
	//		Элемент = Элементы.Добавить("КнопкаМетка_" + ВыборкаМеток.Код, Тип("КнопкаФормы"), Элементы.ГруппаЛегендыЦветовСобытий);
	//		Элемент.ЦветФона = ?(ЗначениеЗаполнено(ВыборкаМеток.ЦветМетки), ЗначениеИзСтрокиВнутр(ВыборкаМеток.ЦветМетки), Новый Цвет());
	//		Элемент.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	//		Элемент.ИмяКоманды = "ЛегендаИзменениеЦвета";
	//		Элемент.Отображение = ОтображениеКнопки.Картинка;
	//		Элемент.Ширина = 3;
	//		Элемент = Элементы.Добавить("НадписьМетка_" + ВыборкаМеток.Код, Тип("ДекорацияФормы"), Элементы.ГруппаЛегендыЦветовСобытий);
	//		Элемент.Вид = ВидДекорацииФормы.Надпись;
	//		Элемент.Заголовок = "-  " + ВыборкаМеток.Наименование;
	//	КонецЕсли;
	// КонецЦикла;
	
	ЗаголовокУстановлен = Ложь;
	Индекс = 0;
	Для Каждого СтатусСобытия Из Перечисления.СтатусыСобытия Цикл
		Если СтатусСобытия <> Перечисления.СтатусыСобытия.ПриемОтменен Тогда
			Если НЕ ЗаголовокУстановлен Тогда
				Элемент = Элементы.Добавить("НадписьМетка_Заголовок_Статусы", Тип("ДекорацияФормы"), Элементы.ГруппаЛегендыЦветовСобытий);
				Элемент.Вид = ВидДекорацииФормы.Надпись;
				Элемент.Заголовок = "Статусы:";
				ЗаголовокУстановлен = Истина;
			КонецЕсли;
			Элемент = Элементы.Добавить("КнопкаСтатус_" + Индекс, Тип("КнопкаФормы"), Элементы.ГруппаЛегендыЦветовСобытий);
			Элемент.ЦветФона = ОбщегоНазначенияСтоматология.ПолучитьЦветФонаСобытия(СтатусСобытия);
			Элемент.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
			Элемент.ИмяКоманды = "ЛегендаИзменениеЦвета";
			Элемент.Отображение = ОтображениеКнопки.Картинка;
			Элемент.Ширина = 3;
			Элемент = Элементы.Добавить("НадписьСтатус_" + Индекс, Тип("ДекорацияФормы"), Элементы.ГруппаЛегендыЦветовСобытий);
			Элемент.Вид = ВидДекорацииФормы.Надпись;
			Элемент.Заголовок = "" + Строка(СтатусСобытия);
			Индекс = Индекс + 1;
		КонецЕсли;
	КонецЦикла;

	
КонецПроцедуры

&НаКлиенте 
Функция ПолучитьСтраницуМенеджера() 
	
	СтраницаМенеджера = "";	
	Если Элементы.Неделя.Пометка Тогда
		СтраницаМенеджера = "Неделя";
	ИначеЕсли Элементы.День.Пометка Тогда
		СтраницаМенеджера = "Сотрудники";
	КонецЕсли;	
	Возврат СтраницаМенеджера;
	
КонецФункции

