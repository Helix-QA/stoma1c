// Функция вернет признак использоватия ТО в указанной кассек ККМ.
//
Функция ПроверитьИспользованиеФРвКассе(Касса, РабочееМесто, ВернутьСтруктуру = Ложь) Экспорт
	
	Если ВернутьСтруктуру = Ложь Тогда
		
		Если Касса.ИспользоватьБезПодключенияОборудования = Ложь 
			И ЗначениеЗаполнено(Касса.ВнешнееОборудование)
			И Касса.ВнешнееОборудование.УстройствоИспользуется = Истина Тогда
			
			Если Касса.ВнешнееОборудование.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикАтолККТ54ФЗ Тогда
				Возврат Истина;
			Иначе 
				Возврат (Касса.ВнешнееОборудование.РабочееМесто = РабочееМесто);
			КонецЕсли;
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	Иначе
		
		Результат = Новый Структура("Используется, ДоступностьПробития, ДоступностьСмены", Истина, Истина, Истина);
		
		Если Касса.ВнешнееОборудование.Пустая() ИЛИ Касса.ВнешнееОборудование.УстройствоОтключено Тогда
			Результат.Используется			= Ложь;
			Результат.ДоступностьПробития	= Истина;
			Результат.ДоступностьСмены		= Истина;
		ИначеЕсли Касса.ИспользоватьБезПодключенияОборудования = ЛОЖЬ Тогда
			Результат.Используется = ?(ПараметрыСеанса.РабочееМестоКлиента = Касса.ВнешнееОборудование.РабочееМесто, Истина, "ИспользуетсяУдаленно");
			Результат.ДоступностьСмены = ?(ПараметрыСеанса.РабочееМестоКлиента = Касса.ВнешнееОборудование.РабочееМесто, Истина, Ложь);
			Результат.ДоступностьПробития = ?(ПараметрыСеанса.РабочееМестоКлиента = Касса.ВнешнееОборудование.РабочееМесто 
			ИЛИ ПараметрыСеанса.РабочееМестоКлиента <> Касса.ВнешнееОборудование.РабочееМесто И ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьОплатуПоНеФискальнымВидамОплатСЛюбогоРабочегоМеста, Ложь), Истина, Ложь);
		ИначеЕсли Касса.ИспользоватьБезПодключенияОборудования = ИСТИНА Тогда
			Результат.Используется = ?(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница = Касса.СтруктурнаяЕдиница, Ложь, "ИспользуетсяУдаленно");
			Результат.ДоступностьСмены = ?(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница = Касса.СтруктурнаяЕдиница, Истина, Ложь);
			Результат.ДоступностьПробития = ?(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница = Касса.СтруктурнаяЕдиница 
			ИЛИ ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница <> Касса.СтруктурнаяЕдиница И ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьОплатуПоНеФискальнымВидамОплатСЛюбогоРабочегоМеста, Ложь), Истина, Ложь);
		КонецЕсли;
		
		Возврат Результат; 
		
	КонецЕсли;
	
КонецФункции

// Функция выполняет получение параметров кассы ККМ.
//
Функция ПолучитьИдентификаторФискальногоРегистратораДляКассы(Касса) Экспорт
	
	Если ЗначениеЗаполнено(Касса.ВнешнееОборудование) И
		Касса.ИспользоватьБезПодключенияОборудования = Ложь
		И Касса.ВнешнееОборудование.УстройствоОтключено = Ложь
		И Касса.ВнешнееОборудование.ПометкаУдаления = Ложь Тогда
		
		Возврат Касса.ВнешнееОборудование;
	Иначе
		Возврат Неопределено;		
	КонецЕсли;
		
КонецФункции 

// Вернет признак фискальности указанного вида оплаты для данной кассы.
//
Функция ПолучитьПризнакФискальностиВидаОплатыПоКассе(Касса, ВидОплаты) Экспорт
	
	Возврат Справочники.Кассы.ПолучитьПризнакФискальностиВидаОплатыПоКассе(Касса, ВидОплаты);	
	
КонецФункции 

