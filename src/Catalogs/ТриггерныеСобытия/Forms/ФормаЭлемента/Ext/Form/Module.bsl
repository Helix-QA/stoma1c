// Процедура - Подключаемый взаимодействие режим напоминания выполнить команду
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Подключаемый_ВзаимодействиеРежимНапоминания_ВыполнитьКоманду(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Команда, ТекущаяСтруктурнаяЕдиница);
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		ЭлементФормы = Элементы.Найти("ВзаимодействиеРежимНапоминания_Индекс_" + Строка(СтруктураДанныеЭлемента.ИндексСтроки));
		Если НЕ ЭлементФормы = Неопределено Тогда
			Для Каждого ЭлементСписка Из ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора Цикл 
				Если Объект.Действия[СтруктураДанныеЭлемента.ИндексСтроки].ЗадачаРежимНапоминания = ЭлементСписка.Значение Тогда 
					ЭлементСписка.Картинка = БиблиотекаКартинок.Будильник24;
					ЭлементСписка.Пометка = Истина
				Иначе 
					ЭлементСписка.Картинка = БиблиотекаКартинок.Пустая;
					ЭлементСписка.Пометка = Ложь;
				КонецЕсли;	
			КонецЦикла;	
			Оповещение = Новый ОписаниеОповещения("ВыборРежимаНапоминанияЗавершение", ЭтотОбъект, Новый Структура("ИндексСтроки, ЭлементКнопка", СтруктураДанныеЭлемента.ИндексСтроки, ЭлементФормы));
			ПоказатьВыборИзМеню(Оповещение, ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора, ЭлементФормы);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

