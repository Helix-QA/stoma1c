// Функция - Получить доступные сервисы рассылки сообщений.
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДоступныеСервисыРассылкиСообщений(СтруктурнаяЕдиница)
	
	ТипыВнешнихСистемМессенджеров = ?(
		ЭтотОбъект.РасширениеМессенджераПодключено,
		Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера(),
		Новый Массив
	);
	
	ТипыВнешнихСистемМессенджеровДляОтправкиПервым = ?(
		ЭтотОбъект.РасширениеМессенджераПодключено,
		Справочники.ВнешниеСистемы.ПолучитьТипыВнешнихСистемМессенджераОтправитьПервым(),
		Новый Массив
	);
	
	ТипыВнешнихСистемPush = Новый Массив;
	ТипыВнешнихСистемPush.Добавить(Перечисления.ТипыВнешнихСистем.Wallet);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК СервисРассылки
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистемМессенджеровОтправкаПервым)
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						ИЛИ ВнешниеСистемы.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi) УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК СервисРассылки
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистемМессенджеров)
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						ИЛИ ВнешниеСистемы.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК СервисРассылки
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистемPush)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СервисыSMSрассылки.Ссылка КАК СервисРассылки
	|ИЗ
	|	Справочник.СервисыРассылки КАК СервисыSMSрассылки
	|ГДЕ
	|	НЕ СервисыSMSрассылки.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА СервисыSMSрассылки.Ссылка = &СервисSMSРассылкиПоУмолчанию
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ");
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистемМессенджеровОтправкаПервым"	, ТипыВнешнихСистемМессенджеровДляОтправкиПервым);
	Запрос.УстановитьПараметр("ТипыВнешнихСистемМессенджеров"				, ТипыВнешнихСистемМессенджеров);
	Запрос.УстановитьПараметр("СервисSMSРассылкиПоУмолчанию"				, Константы.СервисSMSРассылкиПоУмолчанию.Получить());
	Запрос.УстановитьПараметр("ТипыВнешнихСистемPush"						, ТипыВнешнихСистемPush);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"							, СтруктурнаяЕдиница);
	
	Результат = Запрос.ВыполнитьПакет();
	
	СервисыРассылки = Новый Структура;
	СервисыРассылки.Вставить("МессенджерОтправкаПервым"	, Результат[0].Выгрузить().ВыгрузитьКолонку("СервисРассылки"));
	СервисыРассылки.Вставить("Мессенджер"				, Результат[1].Выгрузить().ВыгрузитьКолонку("СервисРассылки"));
	СервисыРассылки.Вставить("Push"						, Результат[2].Выгрузить().ВыгрузитьКолонку("СервисРассылки"));
	СервисыРассылки.Вставить("SMS"						, Результат[3].Выгрузить().ВыгрузитьКолонку("СервисРассылки"));
	
	Возврат СервисыРассылки;
	
КонецФункции

