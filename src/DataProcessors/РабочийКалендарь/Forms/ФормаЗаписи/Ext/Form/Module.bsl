&НаСервере
// Процедура, выполняет формирование графика событий.
//  Параметры: 
//   ПараметрыПостроения - структура, содержит параметры, по которым выполняется формирование графика.
//
Процедура ОбновлениеСтраницыЖурналПредварительнойЗаписиСервер(ПараметрыПостроенияГрафикаПЗ,ОбновитьПанельДни, МассивСотрудниковИОбластей)
	
	// Устанавливаем необходимые свойства
//	ТабличныйДокумент.ФиксацияСверху = 1;
	ТабличныйДокумент.ТолькоПросмотр = Истина;	
	// Установка состояния переключателей режима отображения Дни/Недели
	СтруктураСостояния = Новый Структура;
	СтруктураСостояния.Вставить("ГруппаКоманднаяПанельНедели"	, Ложь);
	СтруктураСостояния.Вставить("ГруппаКоманднаяПанельДни"		, Ложь);
	Элементы.День.Пометка 			               				= Ложь;
	Элементы.Неделя.Пометка 		               				= Ложь;
	Если ПЗГрафикаРежимОтображения = 0 Тогда
		Элементы.Декорация_ФИОВрача.Видимость 					= Ложь;	
		Элементы.День.Пометка                       			= Истина;
		СтруктураСостояния.ГруппаКоманднаяПанельДни 			= Истина;	
	ИначеЕсли ПЗГрафикаРежимОтображения = 1 Тогда
		Если ПЗФильтраГрафикаРежим = 0 Тогда
			Элементы.Декорация_ФИОВрача.Видимость 				= Истина;		
		Иначе 
			Элементы.Декорация_ФИОВрача.Видимость 				= Ложь;	
		КонецЕсли;	
		Элементы.Неделя.Пометка 		               			= Истина;
		СтруктураСостояния.ГруппаКоманднаяПанельНедели 			= Истина;
	КонецЕсли;	
	Элементы.ГруппаКоманднаяПанельНедели.Видимость = СтруктураСостояния.ГруппаКоманднаяПанельНедели;
	Элементы.ГруппаКоманднаяПанельДни.Видимость    = СтруктураСостояния.ГруппаКоманднаяПанельДни;
	
	// Обновление состояния правой панели фильтра
	Элементы.ГруппаПраваяПанель.Видимость = ПЗПанельФильтраВидимость;
	
	// Обновление панели кнопок переключателей текущей даты
	Если ОбновитьПанельДни Тогда
		ОбновитьПанельДниНедели();
	КонецЕсли;
	// Обновление фильтра графика ПЗ
	Если ПЗФильтрГрафикаОбновить Тогда
		Если ПЗФильтраГрафикаРежим = 0 Тогда
			Элементы.ДеревоСотрудников.Видимость = Истина;
			Элементы.ДеревоПомещений.Видимость = Ложь;
			ОбновитьТаблицуСотрудников();
		ИначеЕсли ПЗФильтраГрафикаРежим = 1 Тогда
			Элементы.ДеревоСотрудников.Видимость = Ложь;
			Элементы.ДеревоПомещений.Видимость = Истина;
			ОбновитьТаблицуПомещений();
		КонецЕсли;
	КонецЕсли;  
	
	// Вызываем процедуру построения графика
	ПараметрыПостроенияГрафикаПЗ.ВыбранныеСотрудники =	ВернутьОтборПоСотрудникам();
	ПараметрыПостроенияГрафикаПЗ.ВыбранныеПомещения  =	ВернутьОтборПоПомещениям();
	
	ЭтотОбъект.СписокСотрудниковВЛистеОжидания.Очистить();
	ПараметрыПостроенияГрафикаПЗ.Вставить("СписокСотрудниковВЛистеОжидания", ЭтотОбъект.СписокСотрудниковВЛистеОжидания);
	
	ИнтервалВремени = ОпределнениеИнтервалаВремени(ИнтервалГрафика);

	ГрафикСобытий = ОбщегоНазначенияСтоматология.СформироватьГрафикСобытий(ПараметрыПостроенияГрафикаПЗ, МассивСотрудниковИОбластей, ИнтервалВремени);
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.ВставитьОбласть(ГрафикСобытий.Область()); 	
	// Смещаем график ПЗ на текущий час -1
	Если ПараметрыПостроенияГрафикаПЗ.РазрешитьСмещениеГрафика Тогда	
		СтрокаОбластиСмещения = ПолучитьНомерСтрСмещенияГрафикаПЗ(ПараметрыПостроенияГрафикаПЗ);
		ОблСмещения           = ТабличныйДокумент.Область(СтрокаОбластиСмещения,3,СтрокаОбластиСмещения,3);	
		Если ОблСмещения.Текст = "" Тогда
			ОблСмещения.Текст = " ";
		КонецЕсли;
		Элементы.ТабличныйДокумент.ТекущаяОбласть = ОблСмещения;
	КонецЕсли;
	// Устанавливаем необходимые свойства
	ТабличныйДокумент.ФиксацияСлева  = 2;
	ТабличныйДокумент.ФиксацияСверху = ?(НЕ ГрафикСобытий.ФиксацияСверху = 0, ГрафикСобытий.ФиксацияСверху, 1);
	
	// Нарисуем ФИО сотрудника в шапке
	Если ПараметрыПостроенияГрафикаПЗ.ВыбранныеСотрудники <> Неопределено И ТипЗнч(ПараметрыПостроенияГрафикаПЗ.ВыбранныеСотрудники) = Тип("Массив") И ПЗГрафикаРежимОтображения = 1 И ПЗФильтраГрафикаРежим = 0 Тогда 
		Если ПараметрыПостроенияГрафикаПЗ.ВыбранныеСотрудники.Количество() = 1 Тогда 
			Элементы.Декорация_ФИОВрача.Заголовок = ВернутьФИОВрача(ПараметрыПостроенияГрафикаПЗ.ВыбранныеСотрудники[0]);			
		КонецЕсли;
	КонецЕсли;
	
	Если ПЗРасшифровкаСтатусовОбновить Тогда
		ДобавитьДинамическиЛегендыПоКатегорям();
		ПЗРасшифровкаСтатусовОбновить = Ложь;
	КонецЕсли;
	
	Элементы.ПредставлениеДаты_0.Заголовок = ПолучитьПредставлениеДатыДень(Объект.Дата);	
	
КонецПроцедуры

&НаСервере
// Получить номер строки смещения в графике ПЗ на текущий час -1
//
Функция ПолучитьНомерСтрСмещенияГрафикаПЗ(ПараметрыПостроения)
	
	Смещение=1;
	// Смещаем только если текущий вывод совпадает с текущей датой
	Если ((ПараметрыПостроения.СтраницаМенеджера="Сотрудники"
		ИЛИ ПараметрыПостроения.СтраницаМенеджера="Помещения")	
		И НачалоДня(ПараметрыПостроения.Дата)=НачалоДня(ТекущаяДата())) 
		ИЛИ (ПараметрыПостроения.СтраницаМенеджера="Неделя" 
		И НачалоДня(ТекущаяДата())>=НачалоНедели(ПараметрыПостроения.Дата)
		И НачалоДня(ТекущаяДата())<=КонецНедели(ПараметрыПостроения.Дата)) Тогда
		
		
		ВысотаЭкрана = Число(Сред(ПараметрыПостроения.РазрешениеЭкрана, Найти(ПараметрыПостроения.РазрешениеЭкрана, "*") 
		+ 1,(СтрДлина(ПараметрыПостроения.РазрешениеЭкрана)
		-Найти(ПараметрыПостроения.РазрешениеЭкрана, "*") + 1)));
		// Получаем вместимость строк в график в зависимости от разрешения
		КоэфВместимостиПоля=Неопределено;
		
		Если ИнтервалГрафика = 0 Тогда
			КоэфВместимостиПоля = 4;
			СмещениеВМинутах = Цел(Минута(ТекущаяДата())/15)+1;
		ИначеЕсли ИнтервалГрафика = 1 Тогда
			КоэфВместимостиПоля = 6;
			СмещениеВМинутах = Цел(Минута(ТекущаяДата())/10)+1;
		Иначе
			КоэфВместимостиПоля = 12;
			СмещениеВМинутах = Цел(Минута(ТекущаяДата())/5)+1;
		КонецЕсли;

		Если КоэфВместимостиПоля<>Неопределено Тогда
			
			ЧасНачала=Час(ПараметрыПостроения.СтруктурнаяЕдиница.ВремяНачалаРаботы);
			ЧасТекущий=Час(ТекущаяДата());
			РазницаЧасов=ЧасТекущий-ЧасНачала;
			
			Если РазницаЧасов>0 Тогда
				Смещение=КоэфВместимостиПоля*РазницаЧасов + СмещениеВМинутах+1;
			КонецЕсли;  	
		КонецЕсли;
		
	КонецЕсли;  
	Возврат Смещение;
КонецФункции

