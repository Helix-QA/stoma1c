//
//
Функция ПолученыШтрихкоды(ДанныеШтрикодов)
	
	Если ДанныеШтрикодов.Количество() > 0 Тогда
		ДанныеПоШтрихкодам = ВернутьДанныеПоШтрихкоду(ДанныеШтрикодов[0].Штрихкод);
		Если ДанныеПоШтрихкодам <> Неопределено и ТипЗнч(ДанныеПоШтрихкодам.Объект) = Тип("СправочникСсылка.Карты") Тогда
			// Контрагент = ДанныеПоШтрихкодам.ВладелецКарты;
		ИначеЕсли ДанныеПоШтрихкодам <> Неопределено и ТипЗнч(ДанныеПоШтрихкодам.Объект) = Тип("СправочникСсылка.Номенклатура") Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("На данный штрихкод записана номенклатура: "+ДанныеПоШтрихкодам.Объект);
		ИначеЕсли ДанныеПоШтрихкодам <> Неопределено и ТипЗнч(ДанныеПоШтрихкодам.Объект) = Тип("ДокументСсылка.Событие") Тогда
			Создать_Открыть_СоответствующийДокумент(ДанныеПоШтрихкодам);
		КонецЕсли; 
	КонецЕсли;
	
КонецФункции

&НаСервере
//
//
Функция ВернутьДанныеПоШтрихкоду(ДанныеШтрихкода)
	
	ДанныеПоШтрихкодам = РегистрыСведений.Штрихкоды.ПолучитьДанныеПоШтрихкодам(ДанныеШтрихкода);
	Если ДанныеПоШтрихкодам.Свойство("Объект") Тогда
		Возврат ДанныеПоШтрихкодам;		 
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Клиент со штриховым кодом "+ДанныеШтрихкода+" не найден");
		Возврат Неопределено;
	КонецЕсли; 
	
КонецФункции

&НаКлиенте
//
//
Процедура Создать_Открыть_СоответствующийДокумент(ДанныеПоШтрихкодам)
	
	Если ДанныеПоШтрихкодам.Действие = 0 Тогда 
		Прием = ВернутьДокументПоЗначениюРеквизита("Прием", ДанныеПоШтрихкодам.Объект, "ДокументОснование");
		Если ЗначениеЗаполнено(Прием) Тогда	
			СтруктураПараметры = Новый Структура("Ключ", Прием);	
		Иначе
