// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ ФОРМЫ

// Процедура подготовки печатных форм 
//
Функция ПечатнаяФорма(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_Табель";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Табель.Дата КАК ДатаДокумента,
		|	Табель.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	Табель.Период КАК ПериодРегистрации,
		|	Табель.Номер,
		|	Табель.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
		|	Табель.СтруктурнаяЕдиница.Организация.ПолноеНаименование КАК ПолноеНаименование,
		|	Табель.СтруктурнаяЕдиница.Организация КАК Организация
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени КАК Табель
		|ГДЕ
		|	Табель.Ссылка = &ТекущийДокумент";
		
		Шапка = Запрос.Выполнить().Выбрать();
		Шапка.Следующий();
		
		ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Табель_Макет";		
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ТабельУчетаРабочегоВремени.ПФ_MXL_Макет");
		
		ОбластьШапкаДокумента = Макет.ПолучитьОбласть("ШапкаДокумента");
		ОбластьШапка          = Макет.ПолучитьОбласть("Шапка");
		ОбластьДетали         = Макет.ПолучитьОбласть("Детали");
		ОбластьПодвал         = Макет.ПолучитьОбласть("Подвал");
		
		Если Шапка.ДатаДокумента < Дата('20110101') Тогда
			НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Шапка.Номер, Шапка.Префикс);
		Иначе
			НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Шапка.Номер, Истина, Истина);
		КонецЕсли;		
		
		ОбластьШапкаДокумента.Параметры.ИмяОрганизации   = ?(ЗначениеЗаполнено(Шапка.ПолноеНаименование),Шапка.ПолноеНаименование, Строка(Шапка.Организация));

		ОбластьШапкаДокумента.Параметры.НомерДокумента   = НомерДокумента;
		ОбластьШапкаДокумента.Параметры.ДатаЗаполнения   = Шапка.ДатаДокумента;
		ОбластьШапкаДокумента.Параметры.ДатаНач          = Шапка.ПериодРегистрации;
		ОбластьШапкаДокумента.Параметры.ДатаКон          = КонецМесяца(Шапка.ПериодРегистрации);
		
		ТабличныйДокумент.Вывести(ОбластьШапкаДокумента);
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка",   ТекущийДокумент);
		Запрос.УстановитьПараметр("ПериодРегистрации",   Шапка.ПериодРегистрации);
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТабельОтработанноеВремяПоДням.Сотрудник,
		|	ТабельОтработанноеВремяПоДням.Должность,
		|	ТабельОтработанноеВремяПоДням.Сотрудник.Код КАК ТабНомер,
		|	ТабельОтработанноеВремяПоДням.День1,
		|	ТабельОтработанноеВремяПоДням.День2,
		|	ТабельОтработанноеВремяПоДням.День3,
		|	ТабельОтработанноеВремяПоДням.День4,
		|	ТабельОтработанноеВремяПоДням.День5,
		|	ТабельОтработанноеВремяПоДням.День6,
		|	ТабельОтработанноеВремяПоДням.День7,
		|	ТабельОтработанноеВремяПоДням.День8,
		|	ТабельОтработанноеВремяПоДням.День9,
		|	ТабельОтработанноеВремяПоДням.День10,
		|	ТабельОтработанноеВремяПоДням.День11,
		|	ТабельОтработанноеВремяПоДням.День12,
		|	ТабельОтработанноеВремяПоДням.День13,
		|	ТабельОтработанноеВремяПоДням.День14,
		|	ТабельОтработанноеВремяПоДням.День15,
		|	ТабельОтработанноеВремяПоДням.День16,
		|	ТабельОтработанноеВремяПоДням.День17,
		|	ТабельОтработанноеВремяПоДням.День18,
		|	ТабельОтработанноеВремяПоДням.День19,
		|	ТабельОтработанноеВремяПоДням.День20,
		|	ТабельОтработанноеВремяПоДням.День21,
		|	ТабельОтработанноеВремяПоДням.День22,
		|	ТабельОтработанноеВремяПоДням.День23,
		|	ТабельОтработанноеВремяПоДням.День24,
		|	ТабельОтработанноеВремяПоДням.День25,
		|	ТабельОтработанноеВремяПоДням.День26,
		|	ТабельОтработанноеВремяПоДням.День27,
		|	ТабельОтработанноеВремяПоДням.День28,
		|	ТабельОтработанноеВремяПоДням.День29,
		|	ТабельОтработанноеВремяПоДням.День30,
		|	ТабельОтработанноеВремяПоДням.День31
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени.ДниРаботы КАК ТабельОтработанноеВремяПоДням
		|ГДЕ
		|	ТабельОтработанноеВремяПоДням.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТабельОтработанноеВремяПоДням.НомерСтроки";
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		НПП = 0;
		Пока Выборка.Следующий() Цикл
			
			ЧасыПерваяПоловина = 0;
			ДниПерваяПоловина  = 0;
			ЧасыВтораяПоловина = 0;
			ДниВтораяПоловина  = 0;
			
			НПП = НПП + 1;				
			ОбластьДетали.Параметры.НомерПП = НПП;
			ОбластьДетали.Параметры.Заполнить(Выборка);
			Если ЗначениеЗаполнено(Выборка.Сотрудник) Тогда
				ФИО = ФормированиеПечатныхФорм.ПолучитьФамилиюИмяОтчество(Выборка.Сотрудник.Фамилия, Выборка.Сотрудник.Имя, Выборка.Сотрудник.Отчество,Истина);
			Иначе
				ФИО = "";
			КонецЕсли;
			
			ОбластьДетали.Параметры.НаименованиеСотрудник = ?(ЗначениеЗаполнено(ФИО), ФИО, Выборка.Сотрудник);
			ОбластьДетали.Параметры.Должность             = Строка(Выборка.Сотрудник.Должность);
			
			Для Счетчик = 1 По 15 Цикл
				
				СтрокаЧасы = Выборка["День" + Счетчик];								 		 
				ОбластьДетали.Параметры["ДополнительноеЗначение" + Счетчик] = СтрокаЧасы;
				ЧасыПерваяПоловина = ЧасыПерваяПоловина + (Цел(СтрокаЧасы)*60 + (СтрокаЧасы - Цел(СтрокаЧасы))*60);
				
				ДниПерваяПоловина  = ДниПерваяПоловина + ?(СтрокаЧасы > 0, 1, 0);
				
			КонецЦикла; 
			
			Для Счетчик = 16 По День(КонецМесяца(ТекущийДокумент.Период)) Цикл
				
				СтрокаЧасы = Выборка["День" + Счетчик];							 		 
				ОбластьДетали.Параметры["ДополнительноеЗначение" + Счетчик] = СтрокаЧасы;			 							 
				// ЧасыВтораяПоловина = ЧасыВтораяПоловина +  СтрокаЧасы;
				ЧасыВтораяПоловина = ЧасыВтораяПоловина + (Цел(СтрокаЧасы)*60 + (СтрокаЧасы - Цел(СтрокаЧасы))*60);
				ДниВтораяПоловина  = ДниВтораяПоловина + ?(СтрокаЧасы > 0, 1, 0);
				
			КонецЦикла; 
			
			Для Счетчик = День(КонецМесяца(ТекущийДокумент.Период)) + 1 По 31 Цикл
				
				ОбластьДетали.Параметры["Символ" + Счетчик] = "Х";			 
				ОбластьДетали.Параметры["ДополнительноеЗначение" + Счетчик] = "Х";
				
			КонецЦикла; 
			
			ОбластьДетали.Параметры.ЧасыПерваяПоловина = Цел(ЧасыПерваяПоловина/60) + (ЧасыПерваяПоловина - Цел(ЧасыПерваяПоловина/60)*60)/60;
			// ОбластьДетали.Параметры.ЧасыПерваяПоловина = ЧасыПерваяПоловина;
			ОбластьДетали.Параметры.ДниПерваяПоловина  = ДниПерваяПоловина;
			// ОбластьДетали.Параметры.ЧасыВтораяПоловина = ЧасыВтораяПоловина;
			ОбластьДетали.Параметры.ЧасыВтораяПоловина = Цел(ЧасыВтораяПоловина/60) + (ЧасыВтораяПоловина - Цел(ЧасыВтораяПоловина/60)*60)/60;
			ОбластьДетали.Параметры.ДниВтораяПоловина  = ДниВтораяПоловина;
			ОбластьДетали.Параметры.ДниЗаМесяц         = ДниПерваяПоловина  + ДниВтораяПоловина;
			ОбластьДетали.Параметры.ЧасыЗаМесяц        = Цел((ЧасыПерваяПоловина+ЧасыВтораяПоловина)/60) 
															+ ((ЧасыПерваяПоловина+ЧасыВтораяПоловина) - Цел((ЧасыПерваяПоловина+ЧасыВтораяПоловина)/60)*60)/60;
			
			ТабличныйДокумент.Вывести(ОбластьДетали);
			
		КонецЦикла;
				
		ОбластьПодвала = Макет.ПолучитьОбласть("Подвал");
		
		ОбластьПодвала.Параметры.ФИОРуководителя       = ФормированиеПечатныхФорм.ПредставлениеОтветственногоЛица(Перечисления.ТипыОтветственныхЛиц.Руководитель,Шапка.Организация,Шапка.ДатаДокумента);
		ОбластьПодвала.Параметры.ФИОГлавногоБухгалтера = ФормированиеПечатныхФорм.ПредставлениеОтветственногоЛица(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер,Шапка.Организация,Шапка.ДатаДокумента);
		
		ОбластьПодвала.Параметры.РуководительДолжность = ФормированиеПечатныхФорм.ПредставлениеДолжностиОтветственногоЛица(Перечисления.ТипыОтветственныхЛиц.Руководитель,Шапка.Организация,Шапка.ДатаДокумента);
		ОбластьПодвала.Параметры.ГлБухДолжность        = ФормированиеПечатныхФорм.ПредставлениеДолжностиОтветственногоЛица(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер,Шапка.Организация,Шапка.ДатаДокумента);
		
		ТабличныйДокумент.Вывести(ОбластьПодвала);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	// ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
		
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Табель") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм,
			"Табель",
			"Табель учета рабочего времени",            
			ПечатнаяФорма(МассивОбъектов, ОбъектыПечати)
		);
		
	КонецЕсли;
	
КонецПроцедуры

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("Табель", "Табель учета рабочего времени", , БиблиотекаКартинок.Документ);
	
	Возврат Список;
	
КонецФункции

#КонецОбласти

#КонецЕсли