	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(ЖурналСообщений.ТекстСообщения КАК СТРОКА(10))) = """"""""
	|			ТОГДА ""(Прикрепленный файл)""
	|		ИНАЧЕ ВЫРАЗИТЬ(ЖурналСообщений.ТекстСообщения КАК СТРОКА(1024))
	|	КОНЕЦ,
	|	ЖурналСообщений.ИдКлиента,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	ВтКонтактыМессенджеровИФото.Фото,
	|	ВЫБОР
	|		КОГДА ЖурналСообщений.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.JivoSite)
	|			ТОГДА ЖурналСообщений.ИдОператора
	|		КОГДА ЖурналСообщений.СообщениеОтКлиента
	|			ТОГДА ""0""
	|		ИНАЧЕ """"
	|	КОНЕЦ
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтКонтактыМессенджеровИФото КАК ВтКонтактыМессенджеровИФото
	|		ПО ЖурналСообщений.ИдКлиента = ВтКонтактыМессенджеровИФото.Идентификатор
	|ГДЕ
	|	ЖурналСообщений.ИдКлиента В
	|			(ВЫБРАТЬ
	|				ВтКонтактыМессенджеровИФото.Идентификатор КАК Идентификатор
	|			ИЗ
	|				ВтКонтактыМессенджеровИФото КАК ВтКонтактыМессенджеровИФото)
	|	И ЖурналСообщений.ВнешняяСистема.ТипВнешнейСистемы В(&ТипыВнешнихСистемМессенджера)
	|	И ЖурналСообщений.ВнешняяСистема.СтруктурнаяЕдиница В(&СтруктурныеЕдиницы)
	|	И НЕ ЖурналСообщений.ОжиданиеСообщения
	|	И &ВыводитьСообщения
	|	И ЖурналСообщений.СлужебноеСообщение = ЛОЖЬ
	|	И ЖурналСообщений.ДатаСообщения МЕЖДУ &СделкаДатаНачала И &СделкаДатаОкончания
	|	И НЕ ЖурналСообщений.ИдСообщения В (&МассивИсключенияИдСообщения)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заявки.Ссылка,
	|	ВЫБОР
	|		КОГДА Заявки.ДатаОбработки <> ДАТАВРЕМЯ(1, 1, 1)
	|				И НЕ Заявки.ДатаОбработки ЕСТЬ NULL
	|			ТОГДА Заявки.ДатаОбработки
	|		ИНАЧЕ Заявки.ДатаСоздания
	|	КОНЕЦ,
	|	""Обращение"",
	|	ВЫБОР
	|		КОГДА Заявки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Принята), ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена))
	|			ТОГДА ""История""
	|		ИНАЧЕ ""Просроченно""
	|	КОНЕЦ,
	|	NULL,
	|	NULL,
	|	ВЫРАЗИТЬ(Заявки.Комментарий КАК СТРОКА(1024)),
	|	Заявки.Статус,
	|	NULL,
	|	NULL,
	|	ВЫБОР
	|		КОГДА Заявки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Принята), ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена))
	|			ТОГДА 0
	|		ИНАЧЕ 10
	|	КОНЕЦ,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ПометкаУдаления = ЛОЖЬ
	|	И Заявки.ОсновнойКлиент = &Контрагент
	|	И ВЫРАЗИТЬ(&Сделка КАК Справочник.Сделки).Заявка = Заявки.Ссылка
	|	И &ВыводитьОбращения
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок УБЫВ,
	|	Дата УБЫВ";
		
	//ВсеФильтрыОтключены = ВсеФильтрыОтключены(Фильтры);
	//
	//Если ВсеФильтрыОтключены Тогда
	//	Фильтры = Новый Структура();
	//КонецЕсли;
	
	ДатаРождения = ПараметрыДанных.ДатаРожденияКлиента;
	
	ТипыВнешнихСистемМессенджера = Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера();
	
	СтруктурныеЕдиницы = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник,"Массив");
	СтруктурныеЕдиницы.Добавить(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	СтруктурныеЕдиницы.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());

	Запрос.УстановитьПараметр("Контрагент"     , ПараметрыДанных.Контрагент);
	Запрос.УстановитьПараметр("ТекущаяДата"    , ТекущаяДатаСеанса());
	
	Если ПараметрыДанных.Свойство("Заявка") И ЗначениеЗаполнено(ПараметрыДанных.Заявка) Тогда 
		Запрос.УстановитьПараметр("Заявка", ПараметрыДанных.Заявка);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(Заметки.Объект = &Контрагент
		|			ИЛИ Заметки.Объект = &Заявка)"	, "Заметки.Объект = &Контрагент");
	КонецЕсли;
	
	Если ПараметрыДанных.Свойство("Сделка") И ЗначениеЗаполнено(ПараметрыДанных.Сделка) Тогда 
		ПредыдущийПрием 		= РегистрыСведений.Профосмотры.ПолучитьПрошлыйПрием(ПараметрыДанных.Контрагент, , ПараметрыДанных.Сделка);
		
		Запрос.УстановитьПараметр("Сделка"						, ПараметрыДанных.Сделка);
		Запрос.УстановитьПараметр("ПрофосмотрСделка"			, ПараметрыДанных.Сделка); 
		Запрос.УстановитьПараметр("СделкаДатаНачала"			, ПараметрыДанных.СделкаДатаНачала);
		Запрос.УстановитьПараметр("СделкаДатаОкончания"			, ПараметрыДанных.СделкаДатаОкончания);
		Запрос.УстановитьПараметр("СделкаДатаОкончания"			, ПараметрыДанных.СделкаДатаОкончания); 
		Запрос.УстановитьПараметр("МассивИсключенияИдСообщения"	, ПолучитьМассивСообщенийИсключенияПоСделке(ПараметрыДанных.Контрагент, ПараметрыДанных.Сделка)); 
		Запрос.УстановитьПараметр("СделкаПредыдущийПрием"		, ПредыдущийПрием);
	
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(Событие.Сделка = &Сделка
		|			ИЛИ Событие.Врач = ВЫРАЗИТЬ(&Сделка КАК Справочник.Сделки).Врач
		|				И Событие.Дата >= &ТекущаяДата)", "ИСТИНА");  
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(Прием.Сделка = &Сделка
		|			ИЛИ Прием.Ссылка = &СделкаПредыдущийПрием
		|			ИЛИ Прием.Сотрудник = ВЫРАЗИТЬ(&Сделка КАК Справочник.Сделки).Врач
		|				И Прием.Дата >= &ТекущаяДата)"	, "ИСТИНА");
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "СделкиИсторияИзмененияЭтапов.Ссылка = &Сделка"								, "ИСТИНА");   
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Прием.Сделка = &ПрофосмотрСделка"												, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЖурналСообщений.ДатаСообщения МЕЖДУ &СделкаДатаНачала И &СделкаДатаОкончания"	, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Заметки.Сделка = &Сделка"														, "ИСТИНА"); 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "НЕ ЖурналСообщений.ИдСообщения В (&МассивИсключенияИдСообщения)"				, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗадачаПользователей.Сделка = &Сделка"											, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫРАЗИТЬ(&Сделка КАК Справочник.Сделки).Заявка = Заявки.Ссылка"				, "ИСТИНА");
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистемМессенджера", ТипыВнешнихСистемМессенджера);
	Запрос.УстановитьПараметр("СтруктурныеЕдиницы"			, СтруктурныеЕдиницы);
	
	МассивНомеровТелефонов = IPТелефония.СформироватьМассивНомеровТелефоновПоКонтрагентуИлиТелефону(ПараметрыДанных.Контрагент); 
	
	Если ПараметрыДанных.Свойство("ВходящийНомерТелефона") Тогда
		МассивНомеровВходящих = IPТелефония.СформироватьМассивНомеровТелефоновПоКонтрагентуИлиТелефону(,ПараметрыДанных.ВходящийНомерТелефона);
		Для Каждого Элемент Из МассивНомеровВходящих Цикл
			Если МассивНомеровТелефонов.Найти(Элемент) = Неопределено Тогда
				МассивНомеровТелефонов.Добавить(Элемент);	                   
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Если год не высокосный, тогда передвигаем дату рождения на один день. 
	Если ЗначениеЗаполнено(ДатаРождения) и Месяц(ДатаРождения) = 2 и День(ДатаРождения) = 29 И НЕ ДеньГода(КонецГода(ТекущаяДатаСеанса())) = 366 Тогда
		ДатаРождения = ДатаРождения + 86400;		      
	КонецЕсли;
	
	ДатаРождения = Дата("" + Формат(ТекущаяДата(),"ДФ=yyyy; ДП=0001") + "" + Формат(ДатаРождения,"ДФ=MM; ДП=01") + "" + Формат(ДатаРождения,"ДФ=dd; ДП=01"));
	
	ВсеФильтрыОтключены = ВсеФильтрыОтключены(Фильтры);
		
	Запрос.УстановитьПараметр("ВыводитьСобытия"      	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("События")  		, Фильтры.События   	, Истина));
	Запрос.УстановитьПараметр("ВыводитьЗаметки"      	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Заметки")    	, Фильтры.Заметки   	, Истина));
	Запрос.УстановитьПараметр("ВыводитьПриемы"       	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Приемы")      	, Фильтры.Приемы     	, Истина));
	Запрос.УстановитьПараметр("ВыводитьОбращения"     	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Обращения")    	, Фильтры.Обращения   	, Истина));
	Запрос.УстановитьПараметр("ВыводитьПланыЛечения"    , ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("ПланыЛечения")   , Фильтры.ПланыЛечения  , Истина));
	Запрос.УстановитьПараметр("ВыводитьНарядЗаказы"    	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("НарядЗаказы")    , Фильтры.НарядЗаказы   , Истина));
	Запрос.УстановитьПараметр("ВыводитьСообщения"       , ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Сообщения")     	, Фильтры.Сообщения    	, Истина));
	Запрос.УстановитьПараметр("ВыводитьЗадачи"      	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Задачи")			, Фильтры.Задачи		, Истина));
	Запрос.УстановитьПараметр("ВыводитьЗвонки"      	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Звонки")			, Фильтры.Звонки		, Истина)); 
	Запрос.УстановитьПараметр("ВыводитьСделки"      	, ВсеФильтрыОтключены);
	Запрос.УстановитьПараметр("ВыводитьДатуРегистрации"	, ВсеФильтрыОтключены);                                              	 
	Запрос.УстановитьПараметр("МассивНомеровТелефонов"  , МассивНомеровТелефонов);
	Запрос.УстановитьПараметр("ДатаРождения"       	    , ДатаРождения);

	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции

// Процедура, формирует историю взаимодействия с контрагентом.
//
Функция СформироватьИсториюВзаимодействияСКлиентом(ЭтаФорма, ПараметрыДанных, РежимПодробно = Ложь, ВыводитьВсе = Ложь, Фильтры) Экспорт 
	
	ТекстовыйПосторитель = Новый ЗаписьXML;
	ТекстовыйПосторитель.УстановитьСтроку();		
	
	ТекстHTML = 
	"<html>
	|<meta http-equiv='X-UA-Compatible' content='IE=8'
	|<head>
	|<title></title>
