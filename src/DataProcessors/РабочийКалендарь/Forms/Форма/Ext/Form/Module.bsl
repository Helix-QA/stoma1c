// Процедура - История взаимодействия при нажатии
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеСобытия		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ИсторияВзаимодействияПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если ДанныеСобытия.Element.id = "ЭтоЛицевойСчет" Тогда 
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("СформироватьПриОткрытии", Истина);
		ОтборРасшифровки = Новый Соответствие;
		ОтборРасшифровки.Вставить("Контрагент", ЭтотОбъект.Контрагент);
		ПараметрыОткрытия.Вставить("ОтборРасшифровки", ОтборРасшифровки);
		Вариант =  СсылкаВариантаОтчета("ПерейтиЛицевыеСчета", "Основной");
		ВариантыОтчетовКлиент.ОткрытьФормуОтчета(ЭтаФорма, Вариант, ПараметрыОткрытия);
	
		// ПараметрыФормы = Новый Структура("Контрагент", ЭтотОбъект.Контрагент);		 
		// ОткрытьФорму("Отчет.ПерейтиЛицевыеСчета.Форма.ФормаОтчетаЛицевыеСчета", ПараметрыФормы);
		Возврат;
	КонецЕсли;
	
	Если ДанныеСобытия.Element.id = "ЭтоДолг" Тогда 
		
		ПараметрыФормы = Новый Структура("Контрагент", ЭтотОбъект.Контрагент);
		ОткрытьФорму("Отчет.ВзаиморасчетыПодробно.Форма.ФормаОтчета", ПараметрыФормы);
		Возврат;
		
	КонецЕсли;
	
	Если ДанныеСобытия.Element.id = "ЭтоЛистОжидания" Тогда 
		
		КлючЗаписи = ПолучитьИзВременногоХранилища(СтрЗаменить(ДанныеСобытия.Href, ДанныеСобытия.Element.baseURI, ""));
		ОткрытьФорму("РегистрСведений.Профосмотры.Форма.ФормаРедактированияЗаписиПлана", Новый Структура("Ключ", КлючЗаписи));
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеСобытия.Href) Тогда
		
		СтандартнаяОбработка = Ложь;
		Попытка
			ПерейтиПоНавигационнойСсылке(ДанныеСобытия.Href); 
		Исключение
		КонецПопытки;
		
	Иначе
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

