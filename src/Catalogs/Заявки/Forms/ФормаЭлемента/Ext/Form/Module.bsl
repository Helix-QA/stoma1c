&НаКлиенте
// Процедура - Статус обработана.
//
// Параметры:
//  Команда	 - 	 -
//
Процедура СтатусОбработанЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	ИначеЕсли Результат.Значение = "СоздатьКлиента" Тогда
		
		КлиентСоздатьНового(); 
		
	ИначеЕсли Результат.Значение = "НазначитьПрием" Тогда
		
		ЗаписьНаПрием = Истина;
		КлиентСоздатьНового();
		                                             
	ИначеЕсли Результат.Значение = "ВыбратьСуществующего" Тогда
		
		ВыбратьСуществующегоКлиента();
		
	ИначеЕсли Результат.Значение = "НекачественнаяЗаявка" Тогда
		
		ОценкаЗаявкиНачалоВыбора();
		Возврат;
		
	ИначеЕсли ТипЗнч(Результат.Значение) = Тип("СправочникСсылка.ВидыСделок") Тогда
		
		Если Объект.Ссылка.Пустая()
			ИЛИ Объект.ОсновнойКлиент.Пустая() Тогда
			
			КлиентСоздатьНового();
			
		Иначе
			
			ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Принята");
			
			Если Объект.Статус <> ЭтотОбъект.СтатусЗаявки Тогда
				Объект.Статус = ЭтотОбъект.СтатусЗаявки;
			КонецЕсли;
			
			ЭтаФорма.Записать();
			
		КонецЕсли;
		
		УстановитьСостояниеЭлементовФормыСтатусыЗаявки();
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ЗаписьИзДругойФормы", Истина);
		ПараметрыОткрытия.Вставить("Контрагент"			, Объект.ОсновнойКлиент);
		ПараметрыОткрытия.Вставить("Сделка"				, СоздатьСделку(Объект.ОсновнойКлиент, Результат.Значение));
		
		Оповестить("ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ", ПараметрыОткрытия.Сделка);
		
		ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыОткрытия, "ФормаЗаписи");
		ОткрытьФорму(ИмяФормыПланировщика, ПараметрыОткрытия,, Новый УникальныйИдентификатор,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;

	УстановитьСостояниеЭлементовФормы();

КонецПроцедуры

