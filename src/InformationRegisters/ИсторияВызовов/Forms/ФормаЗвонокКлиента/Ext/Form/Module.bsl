		//		КонецЕсли;
		//		
		//		ТекстКнопкиОсновногоМенеджера = ?(ЗначениеЗаполнено(ЭлементСписка.Значение.ОсновнойМенеджер), НСтр("ru = 'Осн. менеджер: '; en = 'Primary manager: '") + СокрЛП(ФИОСокращенное), "");
