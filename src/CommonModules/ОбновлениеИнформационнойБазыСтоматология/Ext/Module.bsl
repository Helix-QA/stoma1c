Процедура ПриПодготовкеМакетаОписанияОбновлений(Знач Макет) Экспорт
	
КонецПроцедуры	

// Если нет ни одного пользователя со свойством показывать в списке выбора, создает пользователя с полными провами.
//
Процедура СоздатьПриНеобходимостиПользователяСПолнымиПравами() Экспорт
	
	Для Каждого ПользовательИБ Из ПользователиИнформационнойБазы.ПолучитьПользователей() Цикл
		Если ПользовательИБ.ПоказыватьВСпискеВыбора = Истина И ПользовательИБ.Имя <> "Администратор (полные права)" Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	ПользовательИБ = Справочники.Пользователи.НайтиПоНаименованию("Администратор (полные права)");
	Если ПользовательИБ.Пустая() Тогда
		ПользовательИБ = Справочники.Пользователи.СоздатьЭлемент();
		ПользовательИБ.Наименование = "Администратор (полные права)";
		ПользовательИБСуществует = Ложь;
	Иначе
		ПользовательИБ = ПользовательИБ.ПолучитьОбъект();
		ПользовательИБСуществует = Истина;
	КонецЕсли;
	
	НовыеСвойства = Неопределено;
	ПользователиСтоматология.ПрочитатьПользователяИБ(ПользовательИБ.ИдентификаторПользователяИБ, НовыеСвойства);
	НовыеСвойства.ПользовательИнфБазыИмя                       = ПользовательИБ.Наименование;
	НовыеСвойства.ПользовательИнфБазыПолноеИмя                 = ПользовательИБ.Наименование;
	НовыеСвойства.ПользовательИнфБазыПароль                    = Неопределено;
	НовыеСвойства.ПользовательИнфБазыАутентификацияСтандартная = Истина;
	НовыеСвойства.ПользовательИнфБазыПоказыватьВСпискеВыбора   = Истина;
	НовыеСвойства.ПользовательИнфБазыЯзык                      = "Русский";
	
	НовыеРоли = Новый Массив;  	
	НовыеРоли.Добавить("ПолныеПрава");
	НовыеРоли.Добавить("АдминистраторСистемы");
		
	ОписаниеОшибки = "";
	ПользователиСтоматология.ЗаписатьПользователяИБ(ПользовательИБ.ИдентификаторПользователяИБ, НовыеСвойства, НовыеРоли, НЕ ПользовательИБСуществует, ОписаниеОшибки);
	ПользовательИБ.ИдентификаторПользователяИБ = НовыеСвойства.ПользовательИнфБазыУникальныйИдентификатор;
	ПользовательИБ.Записать();
	
	Если ОписаниеОшибки <> "" Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти  

#Область СлужебныеПроцедурыИФункции

// Процедура - Обновить расширение мессенджера
//
Процедура ОбновитьРасширениеМессенджера() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	РасширениеМессенджера = ПолучитьРасширениеМесседжера();
		
	Если РасширениеМессенджера = Неопределено Тогда
		// Расширение мессенджера не установлено, обновление не требуется.
		Возврат;
	КонецЕсли;
	
	МетаданныеМакета = Метаданные.ОбщиеМакеты.Найти("РасширениеМессенджера");
	
	Если МетаданныеМакета = Неопределено Тогда
		// Макет удален из конфигурации.
		Возврат;
	КонецЕсли;
	
	ДанныеРасширения = ПолучитьОбщийМакет(МетаданныеМакета);
	МетаданныеПоставляемогоРасширения = Новый ОбъектМетаданныхКонфигурация(ДанныеРасширения);
	
	РасширениеАктивно = РасширениеМессенджера.Активно;
	
	Если ТребуетсяОбновлениеПоставляемогоРасширения(РасширениеМессенджера, МетаданныеПоставляемогоРасширения) = Истина Тогда
		
		Попытка
			
			РасширениеМессенджера.Удалить();
			
		Исключение
			
			КомментарийОшибки = "Не удалось обновить расширение мессенджера." + Символы.ПС + ОписаниеОшибки();
			
			ЗаписьЖурналаРегистрации("УстановкаРасширенияМессенджера", УровеньЖурналаРегистрации.Ошибка,,, КомментарийОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КомментарийОшибки);
			
			Возврат;
			
		КонецПопытки;
		
		ЗащитаОтОпасныхДействий = Новый ОписаниеЗащитыОтОпасныхДействий();
		ЗащитаОтОпасныхДействий.ПредупреждатьОбОпасныхДействиях = Ложь;
		
		НовоеРасширениеМессенджера = РасширенияКонфигурации.Создать();
		
		НовоеРасширениеМессенджера.Активно										 = РасширениеАктивно;
		НовоеРасширениеМессенджера.БезопасныйРежим								 = Ложь;
		НовоеРасширениеМессенджера.ЗащитаОтОпасныхДействий						 = ЗащитаОтОпасныхДействий;
		НовоеРасширениеМессенджера.ИспользоватьОсновныеРолиДляВсехПользователей	 = Ложь;
		
		НовоеРасширениеМессенджера.Записать(ДанныеРасширения);
		
	КонецЕсли;
	
КонецПроцедуры

// Функция - Получить расширение месседжера
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьРасширениеМесседжера() Экспорт
	
	РасширениеМессенджера = Неопределено;
	
	Для Каждого Расширение Из РасширенияКонфигурации.Получить(Новый Структура("Имя", "Mессенджер"), ИсточникРасширенийКонфигурации.БазаДанных) Цикл
		РасширениеМессенджера = Расширение;
		Прервать;
	КонецЦикла;
	
	Если РасширениеМессенджера = Неопределено Тогда
		// Это разные имена, сделано ради возможности подключения защищенного и обычного расширений одновременно.
		Для Каждого Расширение Из РасширенияКонфигурации.Получить(Новый Структура("Имя", "Мессенджер"), ИсточникРасширенийКонфигурации.БазаДанных) Цикл
			РасширениеМессенджера = Расширение;
			Прервать;
		КонецЦикла;
	КонецЕсли;
	
	Если РасширениеМессенджера = Неопределено Тогда
		// Ищем расширения, содержащие слово "Мессенджер".
		Для Каждого Расширение Из РасширенияКонфигурации.Получить(,ИсточникРасширенийКонфигурации.БазаДанных) Цикл
			Если СтрНайти(НРег(Расширение.Имя), "мессенджер") Тогда
				РасширениеМессенджера = Расширение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат РасширениеМессенджера;
	
КонецФункции

// Функция - Требуется обновление поставляемого расширения
//
// Параметры:
//  УстановленноеРасширение				 - 	 - 
//  КонфигурацияПоставляемогоРасширения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ТребуетсяОбновлениеПоставляемогоРасширения(УстановленноеРасширение, КонфигурацияПоставляемогоРасширения) Экспорт
	
	Если УстановленноеРасширение.БезопасныйРежим
		Или УстановленноеРасширение.ЗащитаОтОпасныхДействий.ПредупреждатьОбОпасныхДействиях
		Или УстановленноеРасширение.ИспользоватьОсновныеРолиДляВсехПользователей Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(УстановленноеРасширение.Версия) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ВерсияУстановленногоРасширения = СтрРазделить(УстановленноеРасширение.Версия, ".");
	ВерсияПоставляемогоРасширения = СтрРазделить(КонфигурацияПоставляемогоРасширения.Версия, ".");
	
	Если ВерсияУстановленногоРасширения.Количество() > ВерсияПоставляемогоРасширения.Количество() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для Индекс = 0 По ВерсияПоставляемогоРасширения.Количество() - 1 Цикл
		
		Результат = Число(ВерсияПоставляемогоРасширения[Индекс]) - Число(ВерсияУстановленногоРасширения[Индекс]);
		
		Если Результат > 0 Тогда
			Возврат Истина;
			
		ИначеЕсли Результат < 0 Тогда
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

