			Отбор = Новый Структура("Вид", Справочники.ВидыКонтактнойИнформации.ТелефонПользователя);
		КонецЕсли;
		НайденныеСтроки = Контрагент.КонтактнаяИнформация.НайтиСтроки(Отбор);
		
