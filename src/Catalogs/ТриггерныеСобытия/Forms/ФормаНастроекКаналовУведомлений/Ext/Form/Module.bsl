// Процедура - Подключаемый отправка messenger поле при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ОтправкаMessenger_Поле_ПриИзменении(Элемент)

	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Элемент, , "МоделируемыеНастройкиКаналовУведомлений");
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		УстановитьСвойстваЭлементамАккаунтаСообщения(, СтруктураДанныеЭлемента.ИндексСтроки);
		Если ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.АккаунтВнешнейСистемы) Тогда 
			Если СтруктураДанныеЭлемента.ДанныеЭлемента.СписокАккаунтовMessenger.НайтиПоЗначению(СтруктураДанныеЭлемента.ДанныеЭлемента.АккаунтВнешнейСистемы) = Неопределено Тогда 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru = 'Указан не корректный аккаунт'; en = 'The specified account is not correct'"), ЭтотОбъект, "МоделируемыеНастройкиКаналовУведомлений[" + Строка(СтруктураДанныеЭлемента.ИндексСтроки) + "].АккаунтВнешнейСистемы");
			КонецЕсли;
		КонецЕсли;	
		ЭлементФормы = Элементы.Найти("АккаунтСообщенийМессенджера_Индекс_" + Строка(СтруктураДанныеЭлемента.ИндексСтроки));
		Если НЕ ЭлементФормы = Неопределено Тогда 			
			ЭтаФорма.ТекущийЭлемент = ЭлементФормы;		
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

