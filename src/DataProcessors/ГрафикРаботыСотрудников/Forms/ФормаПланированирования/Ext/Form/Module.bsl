// Функция - проверяет входят ли приемы в указанный интервал работ
// 
Функция ПроверитьПриемыВходятВИнтервалыРабот(Сотрудник, Дата, ОтборСтруктурнаяЕдиница, ИнтервалыРаботы) 
	
	Запрос = Новый Запрос( 
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СобытиеУслуги.Ссылка КАК Ссылка,
	|	СобытиеУслуги.ДатаНачала КАК ДатаНачала,
	|	СобытиеУслуги.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	Документ.Событие.Услуги КАК СобытиеУслуги
	|ГДЕ
	|	СобытиеУслуги.Ссылка.Проведен
	|	И СобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	|	И СобытиеУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И СобытиеУслуги.Сотрудник = &Сотрудник 
	|	И НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ДЕНЬ) = &Дата");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник"			, Сотрудник);
	Запрос.УстановитьПараметр("Дата"				, НачалоДня(Дата));
	
	ТаблицаПриемов = Запрос.Выполнить().Выгрузить();
	
	Флаг = Ложь; 	
	Для Каждого СтрокаТЗ Из ТаблицаПриемов Цикл
		
		Флаг = Ложь;   
		Для Каждого СтрокаПеридов Из ИнтервалыРаботы Цикл
			
			НачалоПериода	= СтрокаПеридов.Значение.НачалоРаботы;
			КонецПериода	= СтрокаПеридов.Значение.ОкончаниеРаботы;
			
			НачалоПериода	= НачалоДня(Дата) + Час(НачалоПериода)*60*60 + Минута(НачалоПериода)*60 + Секунда(НачалоПериода);
			КонецПериода	= НачалоДня(Дата) + Час(КонецПериода)*60*60	 + Минута(КонецПериода)*60  + Секунда(КонецПериода);
			
			// Если (Результат.ДатаНачала >= ЭлементСписка.Значение.НачалоРаботы И Результат.ДатаНачала < ЭлементСписка.Значение.ОкончаниеРаботы)
			// 	ИЛИ (Результат.ДатаНачала <= ЭлементСписка.Значение.НачалоРаботы И Результат.ДатаОкончания > ЭлементСписка.Значение.НачалоРаботы) Тогда
			
			Если СтрокаТЗ.ДатаНачала >= НачалоПериода и СтрокаТЗ.ДатаОкончания <= КонецПериода Тогда
				Флаг = Истина;			
			КонецЕсли;
			
			// уже есть период графика работ, в который входит прием.
			Если флаг Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;   
		
		Если Не Флаг Тогда
			Прервать;					
		КонецЕсли; 		
			
	КонецЦикла;
	
	Возврат	?(ТаблицаПриемов.Количество() > 0, Флаг, Истина);
	
КонецФункции

&НаКлиенте
// Процедура - Обработчик события "ПриАктивизацииОбласти".
//
Процедура ГрафикПериодовРаботыТабДокПриАктивизацииОбласти(Элемент)
	
	Если ЕстьПравоРедактирования Тогда
		ИмяОбласти = Элементы.ГрафикПериодовРаботыТабДок.ТекущаяОбласть.Имя; 
		
		Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюГруппаУдалить.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКомандаУдалитьВыбранные.Доступность = Истина;
		Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюГруппаУдалить.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКомандаУдалитьЗаПериод.Доступность = Истина;
		Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюГруппаСкопировать.Доступность = Истина;
		
		Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.Доступность = НЕ ВыделенаНеКорректнаяОбласть(ИмяОбласти);
		
		ДанныеЯчейки = ПолучитьДанныеВыделеннойОбластиГрафикПериодовРаботыТабДок(ИмяОбласти);
		
		Если ДанныеЯчейки.ВыбПериод <> Неопределено Тогда
			
			ДнПрописью   = ДеньНеделиПрописью(ДеньНедели(ДанныеЯчейки.ВыбПериод), , Истина);
			
			Элементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКнопкаСкопироватьДеньСПредыдущейНедели.Заголовок = ДнПрописью;
			
			ИндексКартинки = ДеньНеделиПрописью(ДеньНедели(ДанныеЯчейки.ВыбПериод));
			
			//Элементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКнопкаСкопироватьДеньСПредыдущейНедели.Картинка = БиблиотекаКартинок[ИндексКартинки];
			//Элементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКомандаУдалитьЗаПериод.Картинка = БиблиотекаКартинок[ИндексКартинки];
			
			ДнПрописью = ДеньНеделиПрописью(ДеньНедели(ДанныеЯчейки.ВыбПериод), Истина);
			Элементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКомандаУдалитьЗаПериод.Заголовок = "По """ + ДнПрописью + """";
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция вернет день недеи прописью
// 
Функция ДеньНеделиПрописью(НомерДняНедели, ВСклонении1 = Ложь, ВСклонении2 = Ложь)
	
	Если НомерДняНедели = 1 Тогда
		Возврат ?(ВСклонении2, "Прошлый понедельник", ?(ВСклонении1 = Истина, "Понедельникам", "Понедельник"));
	ИначеЕсли НомерДняНедели = 2 Тогда
	    Возврат ?(ВСклонении2, "Прошлый вторник", ?(ВСклонении1 = Истина, "Вторникам", "Вторник"));
	ИначеЕсли НомерДняНедели = 3 Тогда
	    Возврат ?(ВСклонении2, "Прошлую среду", ?(ВСклонении1 = Истина, "Средам", "Среда"));
	ИначеЕсли НомерДняНедели = 4 Тогда
	    Возврат ?(ВСклонении2, "Прошлый четверг", ?(ВСклонении1 = Истина, "Четвергам", "Четверг"));
	ИначеЕсли НомерДняНедели = 5 Тогда
	    Возврат ?(ВСклонении2, "Прошлую пятницу", ?(ВСклонении1 = Истина, "Пятницам", "Пятница"));
	ИначеЕсли НомерДняНедели = 6 Тогда
	    Возврат ?(ВСклонении2, "Прошлую субботу", ?(ВСклонении1 = Истина, "Субботам", "Суббота"));
	ИначеЕсли НомерДняНедели = 7 Тогда
	    Возврат ?(ВСклонении2, "Прошлое воскресенье", ?(ВСклонении1 = Истина, "Воскресеньям", "Воскресенье"));
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Функция проверяет корректность выделенной области для доступности контекстного меню.
//
Функция ВыделенаНеКорректнаяОбласть(ИмяОбласти)
	
	Если НЕ ЗначениеЗаполнено(ИмяОбласти) Тогда
		Возврат Истина;
	КонецЕсли;
		
	Позиция_Двоеточие 	= СтрНайти(Имяобласти,":");
	
	ПерваяЧастьОбласти = Сред(ИмяОбласти, 1, Позиция_Двоеточие - 1);
	Позиция1Области    = СтрНайти(ПерваяЧастьОбласти, "C");      
	
	ВторояЧастьОбласти = Сред(ИмяОбласти, Позиция_Двоеточие + 1);
	Позиция2Области    = СтрНайти(ВторояЧастьОбласти, "C");   
	
	Попытка
		НомерКолонкиНачало = Число(Сред(ПерваяЧастьОбласти, Позиция1Области + 1));
		Если НомерКолонкиНачало = 1  Тогда
			Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюГруппаУдалить.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКомандаУдалитьВыбранные.Доступность = Ложь;
			Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюГруппаУдалить.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюКомандаУдалитьЗаПериод.Доступность = Ложь;
			Элементы.ГрафикПериодовРаботыТабДок.КонтекстноеМеню.ПодчиненныеЭлементы.ГрафикПериодовРаботыТабДокКонтекстноеМенюГруппаСкопировать.Доступность = Ложь;
		КонецЕсли;
		
		Если НомерКолонкиНачало > 1 И НомерКолонкиНачало < 5 Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
		Возврат Истина;
	КонецПопытки;
	
	Попытка 
		НомерСтрокиНачало = Число(Сред(ПерваяЧастьОбласти, 2, Позиция1Области - 2));
		Если НомерСтрокиНачало <= 1 тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
		Возврат Истина;
	КонецПопытки;
	
	Попытка
		НомерКолонкиКонец = Число(Сред(ВторояЧастьОбласти, Позиция2Области + 1));
	Исключение
		Возврат Истина;
	КонецПопытки;
	
	Попытка 
		НомерСтрокиКонец = Число(Сред(ВторояЧастьОбласти, 2, Позиция2Области - 2));
	Исключение
		Возврат Истина;
	КонецПопытки;
	
	//Если НомерКолонкиКонец - НомерКолонкиНачало > 0
	//	ИЛИ НомерСтрокиКонец - НомерСтрокиНачало > 1 Тогда
	//	
	//	Возврат Истина;
	//КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

