					ИндексСтроки = 0;
				//Иначе
				//	КоличествоОплат = Форма.Информация_По_Оплате.Количество();
				//	ИндексСтроки = ?(КоличествоОплат > 0, КоличествоОплат, ИндексСтроки); 
