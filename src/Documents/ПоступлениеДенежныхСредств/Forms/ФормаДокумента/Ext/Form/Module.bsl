// Процедура - обработчик события "ПриИзменении" поля "СуммаДокумента".
//
Процедура СуммаДокументаПриИзменении(Элемент)
	Если Объект.РасшифровкаПлатежа.Количество() = 1 Тогда		
		СтрокаТаблицы       = Объект.РасшифровкаПлатежа[0];
		СтрокаТаблицы.Сумма = Объект.СуммаДокумента;		
	КонецЕсли;
	// Пересчет суммы коммии банка
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеОтЭквайера") Тогда
		ПроцентКомиссии                    = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.ЭквайрингТерминал,"ПроцентКомиссии");
	    Объект.ЭквайрингСуммаКомиссииБанка = (Объект.СуммаДокумента * ПроцентКомиссии) / (100 - ПроцентКомиссии);
	КонецЕсли;	
КонецПроцедуры // СуммаДокументаПриИзменении()

