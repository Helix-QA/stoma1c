	ТаблицаНастроекКаналовУведомлений 	= РезультатПакетаЗапросов[4].Выгрузить();
	
	Если НЕ ЗначениеЗаполнено(ТаблицаНастроекКаналовУведомлений) Тогда
		Возврат;
	КонецЕсли;	
	
	// --------------Выключаем регламент пока обновляем настройки------------
	ЗаданиеНашли = Истина;
	// Ищем задание по наименованию.
	Отбор = Новый Структура();
