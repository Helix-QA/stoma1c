// Функция - Получить данные истории вызова
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеИсторииВызова(IDЗвонка, Сообщение = "")
	
	СтруктураВызова = РегистрыСведений.ИсторияВызовов.ПолучитьПоIDЗвонка(IDЗвонка);
	Если ЗначениеЗаполнено(СтруктураВызова) Тогда  
		
		Если Справочники.ТелефонныеАппараты.ЗаписьРазговораДоступна(ПараметрыСеанса.ТекущийПользователь, СтруктураВызова.ПользовательSip) Тогда
			
			Возврат СтруктураВызова; 
		Иначе
			Сообщение = НСтр("ru='Нет прав на прослушивание текущей записи';en='Not is right to listen to current records'");
		КонецЕсли;	
		
	КонецЕсли;
	
	Возврат Неопределено;	
	
КонецФункции

&НаКлиенте
// Процедура, обработчик завершения перехода в чат мессенджера.
//
Процедура ПерейтиВЧат(ИдКлиента, ВнешняяСистема)
	
	// Проверим подключенно ли расширение мессенджера.
	Если НЕ ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") Тогда 
		Возврат;
	КонецЕсли;
	
	ИдСообщения = УстановитьОжиданиеСообщения(ИдКлиента, ВнешняяСистема);
	
	ДанныеКаналаСтруктура = Новый Структура;
	ДанныеКаналаСтруктура.Вставить("ИдКлиента"		, ИдКлиента);
	ДанныеКаналаСтруктура.Вставить("ВнешняяСистема"	, ВнешняяСистема);
	ДанныеКаналаСтруктура.Вставить("ИдСообщения"	, ИдСообщения);
	
	ПараметрыОткрытия = Новый Структура("ДанныеКанала", ДанныеКаналаСтруктура);
	
	Оповестить("ОткрытьДиалог", ПараметрыОткрытия);
	ОткрытьФорму("Обработка.Мессенджер_Стоматология.Форма.ФормаЧатаНовая", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, создает сообщение с признаком ожидания сообщения.
//
Функция УстановитьОжиданиеСообщения(ИдКлиента, ВнешняяСистема, ОписаниеОшибки = "", Объект = Неопределено, НомерТелефона = "")
	
	Если ТипЗнч(ВнешняяСистема) = Тип("Строка") Тогда
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьСсылку(Новый УникальныйИдентификатор(ВнешняяСистема));
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдКлиента) и ЗначениеЗаполнено(Объект) Тогда
		
		ДанныеКонтакта	 = СоздатьКонтактМессенджера(ВнешняяСистема, Объект, НомерТелефона);
		ИдКлиента		 = ДанныеКонтакта.ИдКлиента;
		ИдСообщения		 = ДанныеКонтакта.ИдСообщения;
		
	Иначе
		
		ИдСообщения = МессенджерСтоматология.ПолучитьИдОжидающегоСообщенияВМесенджер(ИдКлиента, ВнешняяСистема);
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		ОписаниеОшибки = НСтр("ru = 'Не удалось создать клиента в мессенджере.'; en = 'Failed to create messenger client.'");
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ИдСообщения;

	
КонецФункции

&НаСервереБезКонтекста
// Функция, создает канал мессенджера.
//
Функция СоздатьКонтактМессенджера(ВнешняяСистема, Контрагент, Знач НомерТелефона)
	
	Если ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		
		НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь);
		НомерТелефона = ?(СтрДлина(НомерТелефона) > 10 И Лев(НомерТелефона, 1) = "8", "7" + Сред(НомерТелефона, 2), НомерТелефона);
		
		ИдКлиента = НомерТелефона + "@c.us";
		
	КонецЕсли;
	
	ИдКлиента	 = ИдКлиента;
	ИдСообщения	 = Строка(Новый УникальныйИдентификатор);
	
	Если ЗначениеЗаполнено(ИдКлиента) Тогда
		
		НовыйДиалог					 = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
		НовыйДиалог.ИдДиалога		 = Строка(Новый УникальныйИдентификатор);
		НовыйДиалог.ВнешняяСистема	 = ВнешняяСистема;
		НовыйДиалог.ИдКлиента		 = ИдКлиента;
		НовыйДиалог.Начало			 = Дата(2022, 1, 1);
		НовыйДиалог.Окончание		 = Дата(2022, 1, 1);
		
		НовыйДиалог.Записать();
		
		РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(
			ИдКлиента,
			Контрагент,
			НомерТелефона,,
			ВнешняяСистема,
			ОбщегоНазначения.ПолучитьЗначениеРеквизита(Контрагент, "Наименование"),,,,
			НовыйДиалог.ИдДиалога
		);
		
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
			ИдКлиента,
			ИдСообщения,,,
			НСтр("ru = 'Создан контакт'"),
			Истина,
			Перечисления.Мессенджеры.whatsapp,
			Ложь,
			ТекущаяДатаСеанса(),
			ВнешняяСистема,,,,,,,,,
			НовыйДиалог.ИдДиалога,
			Истина
		);
		
	КонецЕсли;
	
	ДанныеКонтакта = Новый Структура;
	ДанныеКонтакта.Вставить("ИдКлиента"		, ИдКлиента);
	ДанныеКонтакта.Вставить("ИдСообщения"	, ИдСообщения);
	
	Возврат ДанныеКонтакта;
	
КонецФункции

