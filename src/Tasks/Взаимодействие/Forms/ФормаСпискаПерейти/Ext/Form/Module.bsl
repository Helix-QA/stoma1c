				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Час Тогда
				ВыбранныйПериод = 4;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;
			КонецЕсли;
		КонецЕсли;
		ОбновитьСписок = Истина;		
		УстановитьСвойстваОтображенияЭлементов();		
	КонецЕсли;
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры  

&НаСервере
// Процедура, УстановтьРежимОтображения.
//
Процедура УстановтьРежимОтображения(ОбновитьДанные = Истина)
	
	Если ЭтаФорма.РежимОтображенияФормы = 0 Тогда
		
		Элементы.ГруппаСписок.Видимость 		 	   = Истина;
		Элементы.СтраницаПланировщик.Видимость 	 	   = Ложь;   
		Элементы.ГруппаКоманднаяПанель.Видимость 	   = Истина;
		ОбновитьДанныеДляОтображения(Ложь,,,, ОбновитьДанные);
		
	ИначеЕсли ЭтаФорма.РежимОтображенияФормы = 1 Тогда
		
		Элементы.ГруппаСписок.Видимость 			   = Ложь;
		Элементы.СтраницаПланировщик.Видимость 		   = Истина;
		Элементы.ГруппаКоманднаяПанель.Видимость 	   = Ложь;
		СписокОтборСтатус = УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус");
		СтатусПросрочена = СписокОтборСтатус.НайтиПоЗначению("Просрочена");
		Если СтатусПросрочена <> Неопределено Тогда 
			СписокОтборСтатус.Удалить(СтатусПросрочена);
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", СписокОтборСтатус);		
		КонецЕсли;	
		ОбновитьДанныеДляОтображения(Истина,,, ОбновитьДанные);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр статус.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Статус(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра	
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru= 'Статус'; en='Status'"));	
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("Строка"));  
	
	// Формируем коллекцию сами
	КоллекцияЗначений = Новый ТаблицаЗначений;
	КоллекцияЗначений.Колонки.Добавить("Ссылка"			, Новый ОписаниеТипов("Строка"));
	КоллекцияЗначений.Колонки.Добавить("Представление"	, Новый ОписаниеТипов("Строка"));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", "Выполнена"		, Нстр("ru = 'Выполнена'; en = 'Completed'")));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", "Не выполнена"	, Нстр("ru = 'Не выполнена'; en = 'Not completed'")));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", "Просрочена"	, Нстр("ru = 'Просрочена'; en = 'Expired'")));
		
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений);
	
	// Обновляем элементы фильтрации для текущего фильтра	
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																														
	
КонецПроцедуры

&НаСервере
// Процедура, актуализировать данные списка согласно отборов.
//
Процедура АктуализироватьДанныеСпискаСогласноОтборов()
	
	СтруктураОтборов 				= ПолучитьСтруктуруЗначенийОтбора();
	ЗапросДляДинамическогоСписка 	= ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов);
	
	// Цепляем наш запрос динамическому списку
	Список.ТекстЗапроса = ЗапросДляДинамическогоСписка.Текст;
	
	// Устанавливаем параметры динамическому списку
	Для Каждого ПараметрЗапроса Из ЗапросДляДинамическогоСписка.Параметры Цикл 
		Список.Параметры.УстановитьЗначениеПараметра(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);		
	КонецЦикла;
	
КонецПроцедуры  

&НаСервере
// Функция, возвращает запрос с установленными параметрами, для списка формы.
//
Функция ПолучитьЗапросДляДинамическогоСписка(ЗНАЧ СтруктураОтборов)
	
	// текст запроса без отборов (чистый)
	Запрос = Новый Запрос(	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Исполнитель
	|ПОМЕСТИТЬ ТаблицаИсполнителей
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	&УсловиеСотрудники
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СотрудникиСегмента.Сегмент
	|ИЗ
	|	РегистрСведений.СотрудникиСегмента КАК СотрудникиСегмента
	|ГДЕ
	|	&УсловиеСегментСотрудники
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.ВидВзаимодействияСправочник.ИндексКартинки КАК ИндексКартинкиВзаимодействия,
	|	Взаимодействие.Ссылка КАК Ссылка,
	|	Взаимодействие.Выполнена КАК Выполнена,
	|	Взаимодействие.ДатаИсполнения КАК ДатаРаботы,
	|	НАЧАЛОПЕРИОДА(Взаимодействие.ДатаИсполнения, ДЕНЬ) = Взаимодействие.ДатаИсполнения КАК ПустоеВремяДатаРаботы,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ПериодВыполнения,
	|	ЗНАЧЕНИЕ(Перечисление.Периодичность.Час) КАК Периодичность,
	|	Взаимодействие.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата,
	|	Взаимодействие.КоличествоПереносов КАК КоличествоПереносов,
	|	Взаимодействие.ВидВзаимодействияСправочник КАК ВидВзаимодействия,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Справочник.Заявки)
	|		ИНАЧЕ Взаимодействие.Контрагент
	|	КОНЕЦ КАК Контрагент,
	|	ЕСТЬNULL(КонтрагентыСведенияДляСписка.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)) КАК СтатусКонтрагента,
	|	Взаимодействие.Сделка КАК Сделка,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыСделок.ПустаяСсылка)
	|		ИНАЧЕ Взаимодействие.Сделка.ВидСделки
	|	КОНЕЦ КАК ВидСделки,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|		ИНАЧЕ Взаимодействие.Сделка.ЭтапСделки
	|	КОНЕЦ КАК СделкаЭтапСделки,
	|	Взаимодействие.ЗадачаТема КАК ЗадачаТема,
	|	Взаимодействие.ТриггерноеСобытие КАК ТриггерноеСобытие,
	|	Взаимодействие.ЗадачаОписание КАК ЗадачаОписание,
	|	Взаимодействие.ДатаИсполнения КАК ДатаИсполнения,
	|	Взаимодействие.ЗадачаПредмет КАК ЗадачаПредмет,
	|	Взаимодействие.ИсполнительФактический КАК ИсполнительФактический,
	|	Взаимодействие.Исполнитель КАК Исполнитель,
	|	ВЫРАЗИТЬ(ВЫРАЗИТЬ(Взаимодействие.Сделка КАК Справочник.Сделки).ЭтапСделки.ЦветЭтапа КАК СТРОКА(150)) КАК ЦветЭтапа,
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДата, ДЕНЬ), Взаимодействие.ЗадачаНазначеннаяДата, МИНУТА) > 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПустоеВремя,
	|	"""" КАК Просрочена
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Взаимодействие.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	&УсловиеПометкаУдаления
	|	И Взаимодействие.Выполнена = ИСТИНА
	|	И Взаимодействие.ДатаИсполнения МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
	|	И &УсловиеВидВзаимодействия
	|	И &УсловиеКонтрагент
	|	И &УсловиеСделки
	|	И &УсловиеВидСделки
	|	И &УсловиеЭтап
	|	И &УсловиеИсполнительФактический
	|	И Взаимодействие.Исполнитель В
	|			(ВЫБРАТЬ
	|				ТаблицаИсполнителей.Исполнитель
	|			ИЗ
	|				ТаблицаИсполнителей КАК ТаблицаИсполнителей)
	|	И &УсловиеСтатус
	|	И &УсловиеСтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Взаимодействие.ВидВзаимодействияСправочник.ИндексКартинки,
	|	Взаимодействие.Ссылка,
	|	Взаимодействие.Выполнена,
	|	Взаимодействие.ЗадачаНазначеннаяДата,
	|	НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДата, ДЕНЬ) = Взаимодействие.ЗадачаНазначеннаяДата,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ЗНАЧЕНИЕ(Перечисление.Периодичность.Час),
	|	Взаимодействие.ЗадачаНазначеннаяДата,
	|	Взаимодействие.КоличествоПереносов,
	|	Взаимодействие.ВидВзаимодействияСправочник,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Справочник.Заявки)
	|		ИНАЧЕ Взаимодействие.Контрагент
	|	КОНЕЦ,
	|	ЕСТЬNULL(КонтрагентыСведенияДляСписка.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)),
	|	Взаимодействие.Сделка,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыСделок.ПустаяСсылка)
	|		ИНАЧЕ Взаимодействие.Сделка.ВидСделки
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|		ИНАЧЕ Взаимодействие.Сделка.ЭтапСделки
	|	КОНЕЦ,
	|	Взаимодействие.ЗадачаТема,
	|	Взаимодействие.ТриггерноеСобытие,
	|	Взаимодействие.ЗадачаОписание,
	|	Взаимодействие.ДатаИсполнения,
	|	Взаимодействие.ЗадачаПредмет,
	|	Взаимодействие.ИсполнительФактический,
	|	Взаимодействие.Исполнитель,
	|	ВЫРАЗИТЬ(ВЫРАЗИТЬ(Взаимодействие.Сделка КАК Справочник.Сделки).ЭтапСделки.ЦветЭтапа КАК СТРОКА(150)),
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДата, ДЕНЬ), Взаимодействие.ЗадачаНазначеннаяДата, МИНУТА) > 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	""""
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Взаимодействие.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	&УсловиеПометкаУдаления
	|	И Взаимодействие.Выполнена = ЛОЖЬ
	|	И Взаимодействие.ЗадачаНазначеннаяДатаНачало = ДАТАВРЕМЯ(1, 1, 1)
	|	И Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
	|	И &УсловиеВидВзаимодействия
	|	И &УсловиеКонтрагент
	|	И &УсловиеСделки
	|	И &УсловиеВидСделки
	|	И &УсловиеЭтап
	|	И &УсловиеИсполнительФактический
	|	И Взаимодействие.Исполнитель В
	|			(ВЫБРАТЬ
	|				ТаблицаИсполнителей.Исполнитель
	|			ИЗ
	|				ТаблицаИсполнителей КАК ТаблицаИсполнителей)
	|	И &УсловиеСтатус
	|	И &УсловиеСтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Взаимодействие.ВидВзаимодействияСправочник.ИндексКартинки,
	|	Взаимодействие.Ссылка,
	|	Взаимодействие.Выполнена,
	|	Взаимодействие.ЗадачаНазначеннаяДатаНачало,
	|	НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДатаНачало, ДЕНЬ) = Взаимодействие.ЗадачаНазначеннаяДатаНачало,
	|	Взаимодействие.ЗадачаНазначеннаяДата,
	|	ВЫБОР
	|		КОГДА Взаимодействие.ЗадачаНазначеннаяДата <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|			ТОГДА ВЫБОР
	|					КОГДА НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДатаНачало, ДЕНЬ) = НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДата, ДЕНЬ)
	|						ТОГДА ЗНАЧЕНИЕ(Перечисление.Периодичность.Час)
	|					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Периодичность.День)
	|				КОНЕЦ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Периодичность.Час)
	|	КОНЕЦ,
	|	Взаимодействие.ЗадачаНазначеннаяДата,
	|	Взаимодействие.КоличествоПереносов,
	|	Взаимодействие.ВидВзаимодействияСправочник,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА ВЫРАЗИТЬ(Взаимодействие.ЗадачаПредмет КАК Справочник.Заявки)
	|		ИНАЧЕ Взаимодействие.Контрагент
	|	КОНЕЦ,
	|	ЕСТЬNULL(КонтрагентыСведенияДляСписка.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)),
	|	Взаимодействие.Сделка,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыСделок.ПустаяСсылка)
	|		ИНАЧЕ Взаимодействие.Сделка.ВидСделки
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|		ИНАЧЕ Взаимодействие.Сделка.ЭтапСделки
	|	КОНЕЦ,
	|	Взаимодействие.ЗадачаТема,
	|	Взаимодействие.ТриггерноеСобытие,
	|	Взаимодействие.ЗадачаОписание,
	|	Взаимодействие.ДатаИсполнения,
	|	Взаимодействие.ЗадачаПредмет,
	|	Взаимодействие.ИсполнительФактический,
	|	Взаимодействие.Исполнитель,
	|	ВЫРАЗИТЬ(ВЫРАЗИТЬ(Взаимодействие.Сделка КАК Справочник.Сделки).ЭтапСделки.ЦветЭтапа КАК СТРОКА(150)),
	|	ВЫБОР
	|		КОГДА РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(Взаимодействие.ЗадачаНазначеннаяДата, ДЕНЬ), Взаимодействие.ЗадачаНазначеннаяДата, МИНУТА) > 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	""""
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Взаимодействие.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	&УсловиеПометкаУдаления
	|	И Взаимодействие.Выполнена = ЛОЖЬ
	|	И Взаимодействие.ЗадачаНазначеннаяДатаНачало <> ДАТАВРЕМЯ(1, 1, 1)
	|	И (Взаимодействие.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
	|			ИЛИ Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
	|			ИЛИ &ПериодОтбораДатаНачала >= Взаимодействие.ЗадачаНазначеннаяДатаНачало
	|				И &ПериодОтбораДатаОкончания <= Взаимодействие.ЗадачаНазначеннаяДата)
	|	И &УсловиеВидВзаимодействия
	|	И &УсловиеКонтрагент
	|	И &УсловиеСделки
	|	И &УсловиеВидСделки
	|	И &УсловиеЭтап
	|	И &УсловиеИсполнительФактический
	|	И Взаимодействие.Исполнитель В
	|			(ВЫБРАТЬ
	|				ТаблицаИсполнителей.Исполнитель
	|			ИЗ
	|				ТаблицаИсполнителей КАК ТаблицаИсполнителей)
	|	И &УсловиеСтатус
	|	И &УсловиеСтруктурнаяЕдиница");				  
	
	// Отбор пометка удаления.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПометкаУдаления)
		И СтруктураОтборов.ОтборПометкаУдаления[0].Значение = Истина Тогда
		
		УсловиеПометкаУдаления = СтруктураОтборов.ОтборПометкаУдаления.ДоступныеЗначения[0].Представление + "Взаимодействие.ПометкаУдаления = ИСТИНА";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", УсловиеПометкаУдаления);
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор вид взаимодействия.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборВидВзаимодействия) Тогда
		УсловиеВидВзаимодействия = СтруктураОтборов.ОтборВидВзаимодействия.ДоступныеЗначения[0].Представление +  "Взаимодействие.ВидВзаимодействияСправочник В (&ОтборВидВзаимодействия)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВидВзаимодействия", УсловиеВидВзаимодействия);
		Запрос.УстановитьПараметр("ОтборВидВзаимодействия", СтруктураОтборов.ОтборВидВзаимодействия.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВидВзаимодействия", "ИСТИНА");
	КонецЕсли;
	
	// Отбор вид сделки. 
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборВидСделки) Тогда
		МассивЗначений = СтруктураОтборов.ОтборВидСделки.ВыгрузитьЗначения();
		Если МассивЗначений.Найти(Справочники.ВидыСделок.ПустаяСсылка()) = Неопределено Тогда 
			УсловиеВидСделки = СтруктураОтборов.ОтборВидСделки.ДоступныеЗначения[0].Представление +  "Взаимодействие.Сделка.ВидСделки В (&ОтборВидСделки)";
			Запрос.УстановитьПараметр("ОтборВидСделки", МассивЗначений);			
		ИначеЕсли СтруктураОтборов.ОтборВидСделки.Количество() = 1 Тогда 
			УсловиеВидСделки = СтруктураОтборов.ОтборВидСделки.ДоступныеЗначения[0].Представление +  "Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";
		Иначе
			МассивЗначений.Удалить(МассивЗначений.Найти(Справочники.ВидыСделок.ПустаяСсылка()));
			УсловиеВидСделки = СтруктураОтборов.ОтборВидСделки.ДоступныеЗначения[0].Представление +  "(Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка) ИЛИ Взаимодействие.Сделка.ВидСделки В (&ОтборВидСделки))";
			Запрос.УстановитьПараметр("ОтборВидСделки", МассивЗначений);			
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВидСделки", УсловиеВидСделки);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВидСделки", "ИСТИНА");
	КонецЕсли;
	
	// Отбор этап. 
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда
		УсловиеЭтап = СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление +  "Взаимодействие.Сделка.ЭтапСделки В (&ОтборЭтап)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", УсловиеЭтап);
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");
	КонецЕсли;
	
	// Отбор исполнитель.
	ВариантВыбора = СтруктураОтборов.ОтборИсполнитель.ДоступныеЗначения[0].Представление;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудники"		, ВариантВыбора + "Сотрудники.Ссылка В(&МассивСотрудников)");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСегментСотрудники", ВариантВыбора + "СотрудникиСегмента.Сотрудник В(&МассивСотрудников)");
	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборИсполнитель) Тогда	
		Запрос.УстановитьПараметр("МассивСотрудников", СтруктураОтборов.ОтборИсполнитель.ВыгрузитьЗначения());
	Иначе
		Запрос.УстановитьПараметр("МассивСотрудников", СтруктураОтборов.ОтборИсполнитель.ДоступныеЗначения.ВыгрузитьЗначения());		
	КонецЕсли;
	
	// Отбор кто выполнил. 
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКтоВыполнил) Тогда
		УсловиеИсполнитель = СтруктураОтборов.ОтборКтоВыполнил.ДоступныеЗначения[0].Представление + "Взаимодействие.ИсполнительФактический В (&ОтборИсполнительФактический)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеИсполнительФактический", УсловиеИсполнитель);
		Запрос.УстановитьПараметр("ОтборИсполнительФактический" , СтруктураОтборов.ОтборКтоВыполнил.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеИсполнительФактический", "ИСТИНА");
	КонецЕсли;
	
	// Отбор структурная единица. 
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Взаимодействие.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница" , СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Взаимодействие.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);		
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница" , СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения());		
	КонецЕсли;
	
	//// Отбор контрагент.	
	//Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКонтрагент) Тогда
	//	УсловиеКонтрагент = СтруктураОтборов.ОтборКонтрагент.ДоступныеЗначения[0].Представление + "Взаимодействие.Контрагент В (&ОтборКонтрагент)";
	//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонтрагент", УсловиеКонтрагент);
	//	Запрос.УстановитьПараметр("ОтборКонтрагент", СтруктураОтборов.ОтборКонтрагент.ВыгрузитьЗначения());
	//Иначе
	//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонтрагент", "ИСТИНА");
	//КонецЕсли; 
	
	// Отбор контрагент.	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКонтрагент) ИЛИ ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда  
		КонтрагентДляОтбора = ?(ЗначениеЗаполнено(СтруктураОтборов.ОтборКонтрагент), СтруктураОтборов.ОтборКонтрагент.ВыгрузитьЗначения(), ЭтотОбъект.Контрагент);
		УсловиеКонтрагент = СтруктураОтборов.ОтборКонтрагент.ДоступныеЗначения[0].Представление + "Взаимодействие.Контрагент В (&ОтборКонтрагент)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонтрагент", УсловиеКонтрагент);
		Запрос.УстановитьПараметр("ОтборКонтрагент", КонтрагентДляОтбора);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКонтрагент", "ИСТИНА");
	КонецЕсли;
	
	// Отбор сделка.  
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСделка)
		И СтруктураОтборов.ОтборСделка[0].Значение = Ложь Тогда 	
		
		УсловиеСделки = СтруктураОтборов.ОтборСделка.ДоступныеЗначения[0].Представление + "Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСделки", УсловиеСделки);
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСделки", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор статус задачи. 	
	МассивСтатусов = Новый Массив;	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтатус) Тогда
		Если СтруктураОтборов.ОтборСтатус.НайтиПоЗначению("Выполнена") <> Неопределено Тогда 
			МассивСтатусов.Добавить(Истина);
		КонецЕсли;
		Если СтруктураОтборов.ОтборСтатус.НайтиПоЗначению("Не выполнена") <> Неопределено ИЛИ СтруктураОтборов.ОтборСтатус.НайтиПоЗначению("Просрочена") <> Неопределено Тогда 
			МассивСтатусов.Добавить(Ложь);
		КонецЕсли;
		УсловиеСтатус = СтруктураОтборов.ОтборСтатус.ДоступныеЗначения[0].Представление + "Взаимодействие.Выполнена В(&МассивСтатусов)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", УсловиеСтатус);
		Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
		Если СтруктураОтборов.ОтборСтатус.НайтиПоЗначению("Просрочена") <> Неопределено Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "(Взаимодействие.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
			|			ИЛИ Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
			|			ИЛИ &ПериодОтбораДатаНачала >= Взаимодействие.ЗадачаНазначеннаяДатаНачало
			|				И &ПериодОтбораДатаОкончания <= Взаимодействие.ЗадачаНазначеннаяДата)", "ИСТИНА");			
				
		КонецЕсли;	
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", "ИСТИНА");			
	КонецЕсли;
	
	Если СтруктураОтборов.ОтборСтатус.НайтиПоЗначению("Просрочена") <> Неопределено Тогда
		ДатаНачала    	= Дата(01,01,0001);
		ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;     		
		Запрос.УстановитьПараметр("ПериодОтбораДатаНачала",    ДатаНачала);
		Запрос.УстановитьПараметр("ПериодОтбораДатаОкончания", ДатаОкончания);
	Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Взаимодействие.ДатаИсполнения МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания", "ИСТИНА");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания", "ИСТИНА");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "(Взаимодействие.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
			|			ИЛИ Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ПериодОтбораДатаНачала И &ПериодОтбораДатаОкончания
			|			ИЛИ &ПериодОтбораДатаНачала >= Взаимодействие.ЗадачаНазначеннаяДатаНачало
			|				И &ПериодОтбораДатаОкончания <= Взаимодействие.ЗадачаНазначеннаяДата)", "ИСТИНА");
					
	КонецЕсли; 
	
	Возврат Запрос;
	
КонецФункции 

&НаКлиенте
// Процедура - Обработчик нажатия элемента фильтрации данных.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОбработчикНажатияЭлементаФильтрацииДанных(Команда, ВыбранноеЗначение, СтандартнаяОбработка) Экспорт
	
	МассивИмен = СтрРазделить(Команда.Имя,"_");
	
	Если МассивИмен.Количество() <> 0 Тогда 
		
		Если МассивИмен[0] = "Удалить" Тогда
			
			РезультатОбновления = УправлениеИнтерфейсамиКлиент.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, Команда.Имя, , ВыбранноеЗначение);
			Если РезультатОбновления.Свойство("ДействиеЭлемента") И РезультатОбновления.ДействиеЭлемента = "ОбработкаВыбора" Тогда 
				Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда 
					СтандартнаяОбработка = Ложь;
				КонецЕсли;
			КонецЕсли;
			
		Иначе
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("Отбор"				, ПараметрыВыбранныхФильтров(Новый Структура));
			ПараметрыФормы.Вставить("ИмяКоманды"		, Команда.Имя);
			ПараметрыФормы.Вставить("ВыбранноеЗначение" , ВыбранноеЗначение);
			ПараметрыФормы.Вставить("ФормаСпискаПерейти", Истина);
			
			ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаФильтры",
						 ПараметрыФормы,,,,,
						 Новый ОписаниеОповещения("ОткрытиеФильтровЗавершение", ЭтотОбъект),
						 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
// Процедура - ОткрытиеФильтровЗавершение.
//
Процедура ОткрытиеФильтровЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОткрытиеФильтровНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
// Процедура - ОткрытиеФильтровНаСервере.
//
Процедура ОткрытиеФильтровНаСервере(Результат)
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ПараметрыОтбора = ПолучитьИзВременногоХранилища(Результат);
		ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора, Истина);	
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОчиститьФильтры = Ложь)
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Строка.Инициализирован = Ложь;
	КонецЦикла;
	
	МассивИменОчищаемыхФильтров = Новый Массив();
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВидВзаимодействия");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВидСделки");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Этап");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Контрагент");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтатусКлиента");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Сделка"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияЗадачи"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Исполнитель");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_КтоВыполнил"); 
	
	УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);

	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов();	
	
	// Отбор статус.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовЗадач");	
	ОбновитьДинамическоеМенюФильтрации_Статус(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовЗадач_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовЗадач_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусовЗадач, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор видов взаимодействия.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовВзаимодействия");	
	ОбновитьДинамическоеМенюФильтрации_ВидВзаимодействия(РезультатПакетногоЗапроса[2].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВидовВзаимодействия_ВариантОтбора"), ПараметрыОтбора.МассивВидовВзаимодействия_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидВзаимодействия", ПараметрыОтбора.МассивВидовВзаимодействия, Истина,,, ВариантОтбора);		
	КонецЕсли;
	
	// Отбор вид сделки.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовСделок");
	ОбновитьДинамическоеМенюФильтрации_ВидСделки(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВидовСделок_ВариантОтбора"), ПараметрыОтбора.МассивВидовСделок_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок, Истина,,, ВариантОтбора);		
	КонецЕсли;

	// Отбор этап.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивЭтапов");
	ОбновитьДинамическоеМенюФильтрации_Этап(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивЭтапов_ВариантОтбора"), ПараметрыОтбора.МассивЭтапов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов, Истина,,, ВариантОтбора);	
	КонецЕсли;	
	
	// Отбор по контрагентам.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКлиентов") ИЛИ ЗначениеЗаполнено(ЭтотОбъект.Контрагент);
	ОбновитьДинамическоеМенюФильтрации_Контрагент(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКонтрагентов_ВариантОтбора"), ПараметрыОтбора.МассивКонтрагентов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Контрагент", ?(ЗначениеЗаполнено(ЭтотОбъект.Контрагент), ЭтотОбъект.Контрагент, ПараметрыОтбора.МассивКлиентов), Ложь,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор СЕ.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц");
	Если УстановитьОтбор И НЕ ЗначениеЗаполнено(ПараметрыОтбора.МассивСтруктурныхЕдиниц) Тогда	
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[6].Выгрузить(), УстановитьОтбор);
	Иначе 
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[5].Выгрузить(), УстановитьОтбор);
	КонецЕсли;
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц_ВариантОтбора"), ПараметрыОтбора.МассивСтруктурныхЕдиниц_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина,,, ВариантОтбора);	
	КонецЕсли;

	// Отбор итересов.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок");
	ОбновитьДинамическоеМенюФильтрации_Сделка(,УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовНаличияСделок_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Сделка", ПараметрыОтбора.МассивСтатусовНаличияСделок, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор пометка удаления сделки.         
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления"); 
	ОбновитьДинамическоеМенюФильтрации_ПометкаУдаленияЗадачи(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления_ВариантОтбора"), ПараметрыОтбора.СписокСтатусовПометокУдаления_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияЗадачи", ПараметрыОтбора.СписокСтатусовПометокУдаления, Истина,,, ВариантОтбора);				
	КонецЕсли;
	
	// Отбор исполнителей.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивИсполнителей"); 
	ОбновитьДинамическоеМенюФильтрации_Исполнитель(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивИсполнителей_ВариантОтбора"), ПараметрыОтбора.МассивИсполнителей_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Исполнитель", ПараметрыОтбора.МассивИсполнителей, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;	
	
	// Отбор исполнителей.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКтоВыполнил"); 
	ОбновитьДинамическоеМенюФильтрации_КтоВыполнил(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКтоВыполнил_ВариантОтбора"), ПараметрыОтбора.МассивКтоВыполнил_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КтоВыполнил", ПараметрыОтбора.МассивКтоВыполнил, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;
	
	Если ЭтаФорма.РежимОтображенияФормы = 0 Тогда 		
		АктуализироватьДанныеСпискаСогласноОтборов();
	ИначеЕсли ЭтаФорма.РежимОтображенияФормы = 1 Тогда
		СтруктураОтборов = ПолучитьСтруктуруЗначенийОтбора();		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Данные выбранных фильтров.
//
Функция ПараметрыВыбранныхФильтров(ПараметрыОтбора)
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Если Строка.КоличествоАктивированныхЗначений > 0 Тогда
			
			МассивДанных = ПолучениеЭлементовОтбора(Новый Массив, Строка.СписокЗначений, Строка.Наименование);
			
			Если Строка.Наименование = "Фильтр_Статус" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовЗадач"			   				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовЗадач_ВариантОтбора"			, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_ВидВзаимодействия" Тогда
				ПараметрыОтбора.Вставить("МассивВидовВзаимодействия"					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВидовВзаимодействия_ВариантОтбора"		, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ВидСделки" Тогда
				ПараметрыОтбора.Вставить("МассивВидовСделок"			  				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВидовСделок_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Этап" Тогда
				ПараметрыОтбора.Вставить("МассивЭтапов"			     					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивЭтапов_ВариантОтбора"					, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Контрагент" Тогда
				ПараметрыОтбора.Вставить("МассивКлиентов"							    , МассивДанных);
				ПараметрыОтбора.Вставить("МассивКонтрагентов_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_СтруктурнаяЕдиница" Тогда
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц"						, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц_ВариантОтбора"		, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Сделка" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияСделок"					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияСделок_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПометкаУдаленияЗадачи" Тогда
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления"				, МассивДанных);
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Исполнитель" Тогда
				ПараметрыОтбора.Вставить("МассивИсполнителей"			   				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивИсполнителей_ВариантОтбора"				, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_КтоВыполнил" Тогда
				ПараметрыОтбора.Вставить("МассивКтоВыполнил"							, МассивДанных);
				ПараметрыОтбора.Вставить("МассивКтоВыполнил_ВариантОтбора"				, Строка.ВариантОтбора);	
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ПараметрыОтбора, Новый УникальныйИдентификатор);
	
КонецФункции 

&НаСервереБезКонтекста
// Функция - ПолучениеЭлементовОтбора
Функция ПолучениеЭлементовОтбора(Массив, СписокЗначений, НаименованиеФильтра)
	
	Если СписокЗначений.Количество() > 0 Тогда
		Для каждого Значение из СписокЗначений Цикл
			Если Значение.Значение.Выбран = Истина Тогда
				Массив.Добавить(Значение.Значение.ЗначениеФильтра);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Массив;
	
КонецФункции

&НаСервере
// Функция, возвращает структуру отборов формы.
//
Функция ПолучитьСтруктуруЗначенийОтбора()
	
	// Метод "ПолучитьЗначенияФильтра" возвращает список активированных значений фильтра.
	// У полученного списка значений есть свойство "ДоступныеЗначения", в котором хранится список всех значений.
	// Таким образом мы одним методом за одну итерацию получаем 2 списка значений(с активированными значениями и всеми значениями).
	// Вариант отбора передается в свойстве "ДоступныеЗначения" в представлении у любого элемента списка.
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборСтатус"					  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус"));
	СтруктураОтборов.Вставить("ОтборВидВзаимодействия"		  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ВидВзаимодействия"));
	СтруктураОтборов.Вставить("ОтборКонтрагент"				  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Контрагент"));		
	СтруктураОтборов.Вставить("ОтборВидСделки"				  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ВидСделки"));	
	СтруктураОтборов.Вставить("ОтборЭтап"					  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Этап"));
	СтруктураОтборов.Вставить("ОтборСотрудникРегистрации"	  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СотрудникРегистрации"));
	СтруктураОтборов.Вставить("ОтборРекламныйИсточник"		  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_РекламныйИсточник"));
	СтруктураОтборов.Вставить("ОтборИсполнитель"			  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Исполнитель"));
	СтруктураОтборов.Вставить("ОтборКтоВыполнил"	 		  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_КтоВыполнил"));
	СтруктураОтборов.Вставить("ОтборСделка"	 				  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Сделка"));	
	СтруктураОтборов.Вставить("ОтборЗавершена"				  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПризнакВыполненияСделки"));
	СтруктураОтборов.Вставить("ОтборДатаСоздания"			  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СозданаПериод"));
	СтруктураОтборов.Вставить("ОтборДатаЗавершенияСделки"	  	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ЗавершенаПериод"));
	СтруктураОтборов.Вставить("ОтборДатаЗапланированнойЗадачи"	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПериодЗапланированнойЗадачи"));
	СтруктураОтборов.Вставить("ОтборСтруктурнаяЕдиница"       	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СтруктурнаяЕдиница"));
	СтруктураОтборов.Вставить("ОтборПометкаУдаления"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПометкаУдаленияЗадачи"));
	
	Возврат СтруктураОтборов;
	
КонецФункции   

