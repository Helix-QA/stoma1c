// Функция возвращает сегмент номенклатуры
//
Процедура УстановитьОтборСегментНоменклатуры(ПолисМедСтрахования,СтруктурнаяЕдиница,Сотрудник)
	
	СегментОтбора                   = Справочники.СегментыНоменклатуры.ПустаяСсылка();
	ОтборСегментУслугПоСогласованию = Неопределено;
	// По полису мед. страхования
	// Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда 
	//	Если НЕ ПолисМедСтрахования.СтраховаяКомпания.Пустая() Тогда 
	//		СегментОтбора                   = ПолисМедСтрахования.Договор.УслугиБезСогласования;
	//		ОтборСегментУслугПоСогласованию = ПолисМедСтрахования.Договор.УслугиПоСогласованию;
	//	КонецЕсли;	
	// КонецЕсли;
	// По сотруднику	
	Если СегментОтбора.Пустая() Тогда 
		Если НЕ Сотрудник.Пустая() И НЕ СтруктурнаяЕдиница.Пустая() Тогда 
			СегментОтбора = РегистрыСведений.НастройкиСотрудников.ВернутьСегментНоменклатурыПоСотруднику(Сотрудник, СтруктурнаяЕдиница);
		КонецЕсли;
	КонецЕсли;	
	_ПодборСегментНоменклатуры = СегментОтбора;	
КонецПроцедуры

