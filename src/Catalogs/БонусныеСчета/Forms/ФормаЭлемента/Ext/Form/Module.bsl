// Функция, возвращает текстовое представления графикаработы салона
//
Функция ВернутьСловоСклоненноеПоЧислу(Слово, Число) 
	
	Если Ост(Число, 10) = 1 И Ост(Число, 100) <> 11 Тогда
		ИндексСклоненияПоЧислу = 1;
	ИначеЕсли Ост(Число, 10) >= 2 И Ост(Число, 10) <= 4 Тогда
		ИндексСклоненияПоЧислу = 2;
	Иначе
		ИндексСклоненияПоЧислу = 5;
	КонецЕсли;
	
	СоответствиеПоЧислам = Новый Соответствие;
	Если Слово = "День" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'день';en ='day'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'дня';en ='days'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'дней';en ='days'"));
	ИначеЕсли Слово = "Месяц" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'месяц';en ='month'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'месяца';en ='months'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'месяцев';en ='months'"));
	ИначеЕсли Слово = "Год" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'год';en ='year'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'года';en ='years'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'лет';en ='years'"));		
	ИначеЕсли Слово = "Услуга" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'услуга';en ='service'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'услуги';en ='services'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'услуг';en ='services'"));
	ИначеЕсли Слово = "Минут" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'минута';en ='minute'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'минуты';en ='minutes'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'минут';en ='minutes'"));		
	ИначеЕсли Слово = "Раз" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'раз';en ='once'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'раза';en ='times'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'раз';en ='times'"));
	ИначеЕсли Слово = "Посещение" Тогда
		СоответствиеПоЧислам.Вставить(1, НСтр("ru= 'посещение';en ='visit'"));
		СоответствиеПоЧислам.Вставить(2, НСтр("ru= 'посещения';en ='visits'"));
		СоответствиеПоЧислам.Вставить(5, НСтр("ru= 'посещений';en ='visits'"));
	КонецЕсли;
		
	Возврат Строка(СоответствиеПоЧислам.Получить(ИндексСклоненияПоЧислу));
	
