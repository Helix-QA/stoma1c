&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере" ФормыЭлемента
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.РасширениеМессенджераПодключено = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") = Истина;
	
	Если Параметры.Свойство("ВладелецКарты") Тогда
		Объект.ВладелецКарты = Параметры.ВладелецКарты;
	КонецЕсли;

	Если Объект.Ссылка.Пустая() Тогда
		Объект.ДатаОткрытия = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() 
		ИЛИ Объект.ТипКода = Перечисления.ВидыКарт.Wallet Тогда
		
		Элементы.КартаТипКода.СписокВыбора.Добавить(Перечисления.ВидыКарт.Wallet);
				
	КонецЕсли;
	
	Если Параметры.Свойство("НовыйВладелецКарты") И ЗначениеЗаполнено(Параметры.НовыйВладелецКарты) Тогда
		
		Объект.ВладелецКарты = Параметры.НовыйВладелецКарты;		
		Объект.Наименование = "";
		
		Если Параметры.Заблокирована Тогда
			Объект.Заблокирована = Ложь
		КонецЕсли;
		
		Если Параметры.пометкаУдаления Тогда
			Объект.ПометкаУдаления = Ложь
		КонецЕсли;
		
	КонецЕсли;
			
	Если Не Объект.Ссылка.Пустая() И Объект.ТипКода = Перечисления.ВидыКарт.Штриховая Тогда
		
		ШтрихКодКарты = Справочники.Карты.ПолучитьДанныеШтрихкода(Объект.Ссылка);
		Если ШтрихКодКарты <> Объект.КодКарты Тогда
			Объект.КодКарты = ШтрихКодКарты;
			ЭтаФорма.Записать();
		КонецЕсли;
		
	КонецЕсли;
	
	НовыйЭлемент = Ложь;
	
	ВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);
	
	ИспользоватьКартыWallet = Константы.ИспользоватьWallet.Получить();
	
	Если Объект.ТипКода = Перечисления.ВидыКарт.ПустаяСсылка() Тогда
		
		НовыйЭлемент = Истина;
		
		ИспользуемыйВидКарт = Константы.ИспользуемыйВидКарт.Получить();
		
		Объект.ТипКода = ?(ИспользуемыйВидКарт = Перечисления.ВидыКарт.Wallet И ИспользоватьКартыWallet, ИспользуемыйВидКарт, Перечисления.ВидыКарт.Штриховая);	
		
	КонецЕсли;
		
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
			
//	ЭтотОбъект.ВзаимодействиеМессенджерВнешняяСистема = Документы.РассылкаСообщений.ПолучитьВнешнююСистемуМессенджераДляРассылки(Объект.ВладелецКарты, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Истина);
	ЭтотОбъект.ВзаимодействиеМессенджерВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.GreenApi, Истина);
	
	ЭтотОбъект.КартаУстановлена = Объект.КоличествоУстановок > 0;
	
	Если ЗначениеЗаполнено(Объект.ДатаБлокировки) Тогда				
		
		Элементы.ДатаБлокировки.Видимость  = Истина;	
		Элементы.КартаЗаблокирована.Доступность = Ложь;
		Элементы.ДатаОткрытия.Доступность   = Ложь;
		
	КонецЕсли;

	УстановитьВидимостьДоступность();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

