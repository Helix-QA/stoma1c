// Процедура - Показать сообщение на форму
// 
Процедура ПоказатьСообщениеНаФормуСервер(ТекстСообщения, Важность = 1)
	
	Элементы.ДекорацияСообщениеОПроблеме.Заголовок = ТекстСообщения;
	Элементы.ДекорацияСообщениеОПроблеме.Видимость = ЗначениеЗаполнено(ТекстСообщения);
	
	Если Важность = 1 Тогда
		Элементы.ДекорацияСообщениеОПроблеме.ЦветТекста = WebЦвета.Красный;
	Иначе
		Элементы.ДекорацияСообщениеОПроблеме.ЦветТекста = WebЦвета.Черный;
	КонецЕсли;

