#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события ОбработкаПроверкиЗаполненияНаСервере
//
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Штрихкоды.Штрихкод,
	|	Штрихкоды.Объект,
	|	Штрихкоды.Упаковка,
	|	Штрихкоды.Объект.Наименование КАК ОбъектПредставление,
	|	Штрихкоды.Упаковка.Наименование КАК УпаковкаПредставление
	|ИЗ
	|	РегистрСведений.Штрихкоды КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Штрихкод = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", Запись.Штрихкод);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() // Штрихкод уже записан в БД
		И Запись.ИсходныйКлючЗаписи.Штрихкод <> Запись.Штрихкод Тогда
		
		ОписаниеОшибки = НСтр("ru='Такой штрихкод уже назначен для объекта %Объект%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%Объект%", """" + Выборка.ОбъектПредставление + """"
		                            + ?(ЗначениеЗаполнено(Выборка.Упаковка), " """ + НСтр("ru='в упаковке'") + " " + Выборка.УпаковкаПредставление + """", ""));
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;
		Сообщение.Поле = "Запись.Штрихкод";
		Сообщение.Сообщить();
		Отказ = Истина;
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ПриОткрытии
//
Процедура ПриОткрытии(Отказ)
	
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события НачалоВыбора
//
Процедура УпаковкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПараметрыЗаписи = Новый Структура;
	ПараметрыЗаписи.Вставить("Номенклатура", Запись.Объект);
	ОбработкаТабличныхЧастейКлиент.ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, ПараметрыЗаписи);	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ПриИзменении
//
Процедура ОбъектПриИзменении(Элемент)
	
	Запись.Упаковка = Неопределено;
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события ПриСозданииНаСервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Запись.Объект) и ТипЗнч(Запись.Объект) = Тип("СправочникСсылка.Номенклатура") Тогда
		Элементы.Объект.Заголовок = "Номенклатура";
		Элементы.Объект.ВыбиратьТип = Ложь; 		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запись.Объект) и ТипЗнч(Запись.Объект) = Тип("СправочникСсылка.Карты") Тогда
		ЭтаФорма.ТолькоПросмотр = Истина;
	КонецЕсли; 
	
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	УстановитьВидимость();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура, обработчик события ОбработкаОповещения
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование"
	   И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			// Преобразуем предварительно к ожидаемому формату
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			
			ПолученыШтрихкоды(Данные);
			
		КонецЕсли;
	КонецЕсли;
	// Конец ВнешнееОборудование 
	
КонецПроцедуры
 
// МеханизмВнешнегоОборудования
&НаКлиенте
Функция ПолученыШтрихкоды(ДанныеШтрикодов)
	
	Модифицированность = Истина;
	
	Если ДанныеШтрикодов.Количество() > 0 Тогда
		Запись.Штрихкод = ДанныеШтрикодов[ДанныеШтрикодов.Количество() - 1].Штрихкод;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции // ПолученыШтрихкоды()

// Конец МеханизмВнешнегоОборудования

&НаКлиенте
// Процедура, обработчик события команды "СоздатьХарактеристику"
//
Процедура СоздатьХарактеристику(Команда)
	
	СоздатьХарактеристикуСерию();
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет создание характеристики
//
Процедура СоздатьХарактеристикуСерию()
	
	Если ЗначениеЗаполнено(Запись.Штрихкод) Тогда
		СпрОбъект = Справочники.ПартииНоменклатуры.СоздатьЭлемент();
		СпрОбъект.Владелец = Запись.Объект;
		СпрОбъект.Наименование = Запись.Штрихкод;
		СпрОбъект.Записать();
		Запись.ПартииНоменклатуры = СпрОбъект.Ссылка;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Штрихкод не заполнен!");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет установку видимости элементов
//
Процедура УстановитьВидимость()
	
	Если ТипЗнч(Запись.Объект) = Тип("СправочникСсылка.Номенклатура") и Запись.Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат и Запись.Объект.ИспользоватьПартии Тогда
		Элементы.СоздатьХарактеристику.Видимость = Истина;
	Иначе
		Элементы.СоздатьХарактеристику.Видимость = Ложь;
	КонецЕсли;
	Если ТипЗнч(Запись.Объект) = Тип("СправочникСсылка.Номенклатура") и  (Запись.Объект.ИспользоватьПартии)Тогда
		Элементы.ПартииНоменклатуры.Видимость = Истина;
	Иначе
		Элементы.ПартииНоменклатуры.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура ПартииНоменклатурыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ДанныеВыбора = ВернутьСписокПртий();	
	
КонецПроцедуры

&НаСервере
// Функция, выполняет возврат списка партий
//
Функция ВернутьСписокПртий()
	
	Запрос = Новый Запрос("ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	                      |	ПартииНоменклатуры.Ссылка КАК Партия
	                      |ИЗ
	                      |	Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	                      |ГДЕ
	                      |	ПартииНоменклатуры.Владелец = &Владелец");
	Запрос.УстановитьПараметр("Владелец", Запись.Объект);
	СписокЗн = Новый СписокЗначений;
	Массив = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Партия");
	Для Каждого СтрокаМассива из Массив Цикл
		СписокЗн.Добавить(СтрокаМассива);		
	КонецЦикла;	
	
	Возврат СписокЗн;
	
КонецФункции

&НаКлиенте
Процедура СгенерироватьШтрихкод(Команда)
	Запись.Штрихкод= СформироватьШтрихкодEAN13();
КонецПроцедуры

&НаСервереБезКонтекста
Функция СформироватьШтрихкодEAN13()
	
	Возврат РегистрыСведений.Штрихкоды.СформироватьШтрихкодEAN13();
	
КонецФункции // СформироватьШтрихкодEAN13()


#КонецОбласти