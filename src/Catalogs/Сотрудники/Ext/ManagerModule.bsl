// Процедура - Обновить данные сотрудника
//
// Параметры:
//  Сотрудник		 - 	 - 
//  ДанныеСотрудника - 	 - 
//
Процедура ОбновитьДанныеСотрудника(Сотрудник, ДанныеСотрудника) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда 
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДанныеСотрудника) ИЛИ НЕ ТипЗнч(ДанныеСотрудника) = Тип("Структура") Тогда 
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	Сотрудник_Объект = Сотрудник.ПолучитьОбъект();
	ЗаполнитьЗначенияСвойств(Сотрудник_Объект, ДанныеСотрудника);
	Сотрудник_Объект.Наименование = СокрЛП(СокрЛП(Сотрудник_Объект.Фамилия) + ?(ЗначениеЗаполнено(Сотрудник_Объект.Имя),  
									" " + СокрЛП(Сотрудник_Объект.Имя) + ?(ЗначениеЗаполнено(Сотрудник_Объект.Отчество), 
									" " + СокрЛП(Сотрудник_Объект.Отчество), ""), ""));
	Попытка
		Сотрудник_Объект.Записать();
	Исключение
		
	КонецПопытки;
	
КонецПроцедуры

// Функция - Получить массив сотрудников с ролью пользователя
//
// Параметры:
//  РольПользователя - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивСотрудниковСРольюПользователя(РольПользователя) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РольПользователя", РольПользователя);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И Сотрудники.Роль = &РольПользователя
	|	И Сотрудники.ЭтоПользовательИБ = ИСТИНА
	|	И Сотрудники.Служебный = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Пользователи.Сотрудник
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.ПометкаУдаления = ЛОЖЬ
	|	И Пользователи.Недействителен = ЛОЖЬ
	|	И Пользователи.Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Пользователи.РольПользователя = &РольПользователя
	|	И Пользователи.ЭтоПользовательИБ = ИСТИНА";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
КонецФункции

