	Запрос.УстановитьПараметр("ОбъектыОтбора"           , ОбъектыОтбора);
	Запрос.УстановитьПараметр("ТекущаяДата"             , ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	    , ПараметрыДанных.ТекущаяСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ВнешняяСистема"	  	    , МассивВнешнихСистем);
	
	Запрос.УстановитьПараметр("ВыводитьЗадачи"          , ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Задачи")			, Фильтры.Задачи	, Истина));
	Запрос.УстановитьПараметр("ВыводитьЗаметки"      	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Заметки")    	, Фильтры.Заметки 	, Истина));
	Запрос.УстановитьПараметр("ВыводитьСообщения"       , ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Сообщения")     	, Фильтры.Сообщения , Истина));
	Запрос.УстановитьПараметр("ВыводитьЗвонки"      	, ?(ВсеФильтрыОтключены = Ложь И Фильтры.Свойство("Звонки")			, Фильтры.Звонки	, Истина));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
