// Процедура, ОчиститьГруппуЭтапыСделки.
//
Процедура ОчиститьГруппуЭтапыСделки()
	
	ПодчиненныеЭлементыФормы = Элементы.ГруппаЭтапыСделки.ПодчиненныеЭлементы;	
	КоличествоСтрок 		 = ПодчиненныеЭлементыФормы.Количество();
	
	Пока КоличествоСтрок <> 0 Цикл 
		
		Элементы.Удалить(ПодчиненныеЭлементыФормы[0]);	
		КоличествоСтрок = КоличествоСтрок - 1;
		
	КонецЦикла;
		
