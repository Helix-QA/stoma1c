// Процедура - Сохранить заметку пользователя
//
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  IDЗвонка		 - 	 - 
//  Текст			 - 	 - 
//
Процедура СохранитьЗаметкуПользователя(ПОIPТелефонии, IDЗвонка, Текст)
	
	НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Значение 		= ПОIPТелефонии;
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Использование 	= Истина;
	НаборЗаписей.Отбор.IDЗвонка.Значение 					= IDЗвонка;
	НаборЗаписей.Отбор.IDЗвонка.Использование 				= Истина;
	
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда 
		Запись 			= НаборЗаписей[0];
		Запись.Заметка 	= Текст;
		НачатьТранзакцию();
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.Записать(Истина);
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры	

