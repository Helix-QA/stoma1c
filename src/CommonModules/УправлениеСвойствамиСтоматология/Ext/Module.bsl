				ДекорацияФормы_Представление = Элементы.Добавить("БудущееСобытие_" + ИндексСтроки, Тип("КнопкаФормы"), ГруппаБудущееСобытие);
				ДекорацияФормы_Представление.Заголовок                  = Формат(СтрокаТЗ.ДатаСобытия, "ДФ='дд ММММ ЧЧ:мм'") + " врач " + СтрокаТЗ.Сотрудник;
				ДекорацияФормы_Представление.Отображение       			= ОтображениеКнопки.Текст;
				ДекорацияФормы_Представление.ОтображениеФигуры			= ОтображениеФигурыКнопки.Нет;
				ДекорацияФормы_Представление.ИмяКоманды					= "ОткрытьПредварительнуюЗапись";
				ДекорацияФормы_Представление.Высота						= 1;
				ДекорацияФормы_Представление.РастягиватьПоГоризонтали  	= Ложь;	
				ДекорацияФормы_Представление.ЦветТекста 				= ЦветаСтиля.ТекстВторостепеннойНадписи;
				ДекорацияФормы_Представление.ЦветФона 					= ЦветаСтиля.ЦветФонаФормы;
				ДекорацияФормы_Представление.ГоризонтальноеПоложениеВГруппе   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Представление.ВертикальноеПоложениеВГруппе   	= ВертикальноеПоложениеЭлемента.Верх;
				
				Если ИндексСтроки = "0" Тогда
										
					Если ЗначениеЗаполнено(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВладелецСсылка, "Телефон")) Тогда					
						
						ГруппаНапомнитьПациенту = Элементы.Добавить("ГруппаНапомнитьПациентуОБудущихСобытиях", Тип("ГруппаФормы"), ГруппаБудущееСобытие);
						ГруппаНапомнитьПациенту.Вид							= ВидГруппыФормы.ОбычнаяГруппа;
						ГруппаНапомнитьПациенту.Отображение					= ОтображениеОбычнойГруппы.Нет;
						ГруппаНапомнитьПациенту.Группировка					= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
						ГруппаНапомнитьПациенту.ОтображатьЗаголовок			= Ложь;
						ГруппаНапомнитьПациенту.Высота						= 1;
						ГруппаНапомнитьПациенту.Ширина						= 0;
						ГруппаНапомнитьПациенту.РастягиватьПоГоризонтали	= Ложь;
						ГруппаНапомнитьПациенту.ЦветФона					= Новый Цвет(242, 242, 242);
						ГруппаНапомнитьПациенту.ГоризонтальноеПоложениеВГруппе	= ГоризонтальноеПоложениеЭлемента.Право;
						ГруппаНапомнитьПациенту.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Право;
						
						КнопкаНапомнитьПациенту = Элементы.Добавить("НапомнитьПациентуОБудущихСобытиях", Тип("КнопкаФормы"), ГруппаНапомнитьПациенту);
						КнопкаНапомнитьПациенту.Заголовок					= "Отправить";
						КнопкаНапомнитьПациенту.Отображение					= ОтображениеКнопки.Текст;
						КнопкаНапомнитьПациенту.ОтображениеФигуры			= ОтображениеФигурыКнопки.Нет;
						КнопкаНапомнитьПациенту.ИмяКоманды					= "НапомнитьПациентуОБудущихСобытиях";
						КнопкаНапомнитьПациенту.Высота						= 1;
						КнопкаНапомнитьПациенту.РастягиватьПоГоризонтали  	= Ложь; 
												
						Декорация_НапомнитьПациенту_Заглушка = Элементы.Добавить("НапомнитьПациентуОБудущихСобытиях_Декорация", Тип("ДекорацияФормы"), ГруппаБудущееСобытие);
						Декорация_НапомнитьПациенту_Заглушка.Вид 							    = ВидДекорацииФормы.Надпись;
						Декорация_НапомнитьПациенту_Заглушка.Заголовок                  		= " ";
						Декорация_НапомнитьПациенту_Заглушка.Ширина 							= 0;
						Декорация_НапомнитьПациенту_Заглушка.Высота 							= 1;
						Декорация_НапомнитьПациенту_Заглушка.ГоризонтальноеПоложение			= ГоризонтальноеПоложениеЭлемента.Право;				
						Декорация_НапомнитьПациенту_Заглушка.ГоризонтальноеПоложениеВГруппе 	= ГоризонтальноеПоложениеЭлемента.Право;
						Декорация_НапомнитьПациенту_Заглушка.РастягиватьПоГоризонтали			= Ложь;
						
					КонецЕсли;
				
				КонецЕсли;
				
			КонецЦикла;
			
			#Конецобласти 			
			
		ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" Тогда	
			
			#Область СОЗДАНИЕ_ЭЛЕМЕНТОВ_ПРОМОКОДА
						
			Для Каждого СтрокаТЗ Из Форма.ПромокодыСуществующие Цикл
				
				ИндексСтроки = Формат(Форма.ПромокодыСуществующие.Индекс(СтрокаТЗ), "ЧН=; ЧГ=0");
				
				// Создаем группу
				// --------------------------------------------------------------------------------------------
				ГруппаПромокодыСуществующие = Элементы.Добавить("ГруппаПромокодыСуществующие_" + ИндексСтроки, Тип("ГруппаФормы"), ГруппаРодитель);
				ГруппаПромокодыСуществующие.Вид 				= ВидГруппыФормы.ОбычнаяГруппа;
				ГруппаПромокодыСуществующие.Заголовок 			= ГруппаПромокодыСуществующие.Имя;
				ГруппаПромокодыСуществующие.Отображение 		= ОтображениеОбычнойГруппы.Нет;
				ГруппаПромокодыСуществующие.Группировка 		= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				ГруппаПромокодыСуществующие.ОтображатьЗаголовок = Ложь;
				
				ДекорацияФормы_Заглушка = Элементы.Добавить("ПромокодыЗаглушка_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаПромокодыСуществующие);
				ДекорацияФормы_Заглушка.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Заглушка.Заголовок 					= "";
				ДекорацияФормы_Заглушка.Гиперссылка 				= Ложь;
				ДекорацияФормы_Заглушка.ЦветТекста 					= ЦветаСтиля.ТекстВторостепеннойНадписи;
				ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Заглушка.Ширина 						= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.МаксимальнаяШирина       	= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали  	= Истина;
				
				// Создаем представление
				// --------------------------------------------------------------------------------------------		
				ДекорацияФормы_Представление = Элементы.Добавить("ПромокодыСуществующие_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаПромокодыСуществующие);
				ДекорацияФормы_Представление.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Представление.Заголовок                  = СформироватьПредставлениеЭлемента(Форма, СтрокаТЗ, ЭлементРодитель);
				ДекорацияФормы_Представление.Гиперссылка 				= Истина;
				ДекорацияФормы_Представление.ЦветТекста 				= ЦветаСтиля.ТекстВторостепеннойНадписи;
				ДекорацияФормы_Представление.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Представление.Ширина 					= 33;
				ДекорацияФормы_Представление.МаксимальнаяШирина        	= 33;
				ДекорацияФормы_Представление.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Представление.РастягиватьПоГоризонтали  	= Истина;
				
				ДекорацияФормы_Представление.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_Представление_Нажатие");								
				
			КонецЦикла;
			
			#КонецОбласти

		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция СоздатьГруппуФормы(Форма, Наименование, Родитель, ЦветФона = Неопределено)
	
	ГруппаФормы = Форма.Элементы.Добавить(Наименование, Тип("ГруппаФормы"), Родитель);
	ГруппаФормы.Вид 							 = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФормы.Отображение 					 = ОтображениеОбычнойГруппы.Нет;
	ГруппаФормы.Группировка 					 = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	ГруппаФормы.ОтображатьЗаголовок 			 = Ложь;
	ГруппаФормы.ВертикальноеПоложениеВГруппе 	 = ВертикальноеПоложениеЭлемента.Центр;
	ГруппаФормы.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
	
	Если ЦветФона <> Неопределено Тогда
		ГруппаФормы.ЦветФона                     = ЦветФона;
	КонецЕсли;
	
	Возврат ГруппаФормы;
	
КонецФункции

// Функция создает группу для кнопок типы оплаты.
//
Функция СоздатьГруппуДляКнопокТипОплаты(Форма, ГруппаРодитель, Индекс)
	
	Группа_Кнопки_ТипОплаты_Строка = Форма.Элементы.Добавить("Группа_Кнопки_ТипОплаты_Строка" + Индекс, Тип("ГруппаФормы"), ГруппаРодитель);
	Группа_Кнопки_ТипОплаты_Строка.Вид 				   = ВидГруппыФормы.ОбычнаяГруппа;
	Группа_Кнопки_ТипОплаты_Строка.Отображение 		   = ОтображениеОбычнойГруппы.Нет;
	Группа_Кнопки_ТипОплаты_Строка.Группировка 		   = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	Группа_Кнопки_ТипОплаты_Строка.ОтображатьЗаголовок = Ложь;
	  		
	Возврат Группа_Кнопки_ТипОплаты_Строка;
	
КонецФункции

//  Процедура - Очистить группу от созданных элементов
// 
//  Параметры:
//   Элементы		 - 	 - 
//   ЭлементРодитель	 - 	 - 
// 
Процедура ОчиститьГруппуОтСозданныхЭлементов(Элементы, Знач ГруппаРодитель)
	
	УдаляемыеЭлементы = Новый Массив;		
	Для Каждого ГруппаЭлементов Из ГруппаРодитель.ПодчиненныеЭлементы Цикл
		Если СтрНайти(ГруппаЭлементов.Имя, "Шаблон") = 0 Тогда
			УдаляемыеЭлементы.Добавить(ГруппаЭлементов);                           
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

//  Процедура - Сформировать представление элемента
// 
//  Параметры:
//   СтрокаТЗ		 - 	 - 
//   ЭлементРодитель	 - 	 - 
// 
Функция СформироватьПредставлениеЭлемента(Форма, Знач СтрокаТЗ, Знач ЭлементРодитель) Экспорт
	
	ПолучатьДанныеИзФормы = Ложь;
		  
	Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" Тогда
		
		Возврат СокрП(Строка(СтрокаТЗ.ВидДокумента)) + ?(ЗначениеЗаполнено(СтрокаТЗ.Серия), ", " + Строка(СтрокаТЗ.Серия), "") + " " + Строка(СтрокаТЗ.Номер) 
		+ ?(ЗначениеЗаполнено(СтрокаТЗ.ДатаВыдачи), ", выдан "+ Формат(СтрокаТЗ.ДатаВыдачи, "ДФ='dd.MM.yyyy'") + " г. ", "")	
		+ Строка(СтрокаТЗ.КемВыдан) 
		+ ?(ЗначениеЗаполнено(СтрокаТЗ.ДатаОкончания), " до " + Формат(СтрокаТЗ.ДатаОкончания, "ДФ='dd.MM.yyyy'") + " г. ", "");
		
	ИначеЕсли ЭлементРодитель = "ГруппаПолисыСуществующие" Тогда
		
		Возврат "" + СокрП(СтрокаТЗ.ТипПолиса) + ", " + 
		СтрокаТЗ.СтраховаяКомпания + 
		?(ЗначениеЗаполнено(СтрокаТЗ.СерияПолиса), ", " + Строка(СтрокаТЗ.СерияПолиса) + " ", "") +
		?(ЗначениеЗаполнено(СтрокаТЗ.НомерПолиса), "№" + Строка(СтрокаТЗ.НомерПолиса) + " ", "") +
		?(ЗначениеЗаполнено(СтрокаТЗ.ДатаНачала), ", с "+ Формат(СтрокаТЗ.ДатаНачала, "ДФ='dd.MM.yyyy'") + " г. ", "") +	
		?(ЗначениеЗаполнено(СтрокаТЗ.ДатаОкончания), " по " + Формат(СтрокаТЗ.ДатаОкончания, "ДФ='dd.MM.yyyy'") + " г. ", "");
		
	ИначеЕсли ЭлементРодитель = "ГруппаРодственникиСуществующие" Тогда
		Возврат Строка(СтрокаТЗ.Родственник) + " (" + СокрЛП(Строка(СтрокаТЗ.СтепеньРодства)) + ")" + ?(ЗначениеЗаполнено(СтрокаТЗ.Родственник.Телефон), " "+ СтрокаТЗ.Родственник.Телефон, "");
		
	ИначеЕсли ЭлементРодитель = "ГруппаПользовательИБСуществующий" Тогда
		Возврат Строка(СтрокаТЗ.Пользователь);

	ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробно" Тогда
		
		СтроковоеПредставление = "";
		
		Если СтрокаТЗ.Свойство("СуммаОплачено") Тогда 
			СуммаОплаты = СтрокаТЗ.СуммаОплачено;
			СуммаОплаты = ?(СуммаОплаты = Цел(СуммаОплаты), Формат(СуммаОплаты, "ЧДЦ=2"), СуммаОплаты);	
		КонецЕсли;
		
		Если ТипЗнч(СтрокаТЗ.ДокументОплаты) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
			
			СуммаВозврата = СтрокаТЗ.ДокументОплаты.СуммаДляВозврата;
			СуммаВозврата = ?(СуммаВозврата = Цел(СуммаВозврата), Формат(СуммаВозврата, "ЧДЦ=2"), СуммаВозврата);
			
			Если СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда 
				СтроковоеПредставление = Нстр("ru = 'Возврат наличными: '; en = 'Cash refund: '") + СуммаВозврата + " " + Валюта; // СтрокаТЗ.ДокументОплаты.СуммаДляВозврата
			ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда 
				СтроковоеПредставление = Нстр("ru = 'Возврат на платежную карту: '; en = 'Payment card refund: '") + СуммаВозврата + " " + Валюта;
			ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда 
				СтроковоеПредставление = Нстр("ru = 'Возврат на лицевой счет: '; en = 'Personal account refund: '") + СуммаВозврата + " " + Валюта;
			Иначе 
				СтроковоеПредставление = Нстр("ru = 'Возврат '; en = 'Refund '") + Строка(СтрокаТЗ.ТипДенежныхСредств) + ": " + СуммаВозврата + " " + Валюта;
			КонецЕсли;
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда 
			СтроковоеПредставление = Нстр("ru = 'Сертификат № '; en = 'Certificate: '") + Строка(СтрокаТЗ.ДокументОплаты.СертификатСерийныйНомер) + ": " + СуммаОплаты + " " + Валюта;  // СтрокаТЗ.СуммаОплачено
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
			СтроковоеПредставление = Нстр("ru = 'Карта: '; en = 'Card: '") + СуммаОплаты + " " + Валюта;
		Иначе 
			СтроковоеПредставление = Строка(СтрокаТЗ.ТипДенежныхСредств) + ": " + СуммаОплаты + " " + Валюта;
		КонецЕсли;

		Если ЗначениеЗаполнено(СтроковоеПредставление)
			И ?(ПолучатьДанныеИзФормы, НачалоДня(Форма.Дата), НачалоДня(Форма.Объект.Дата)) <> НачалоДня(СтрокаТЗ.ДатаПлатежа) Тогда
			
			СтроковоеПредставление = СтроковоеПредставление + Формат(СтрокаТЗ.ДатаПлатежа, "ДФ=' (dd.MM.yyyy)'");
		КонецЕсли;
		
		Возврат СтроковоеПредставление;	
		
	ИначеЕсли ЭлементРодитель = "ГруппаДолгиКонтрагентаСуществующие" Тогда
			
		Если СтрокаТЗ.Сумма <> 0 Тогда
			СуммаПредставление = "" + Формат(СтрокаТЗ.Сумма,"ЧЦ=15; ЧДЦ=2") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
		Иначе
			СуммаПредставление = Нстр("ru = 'Нет цены'; eb = 'No price'");
		КонецЕсли;
		
		ЗадолженностьПредставление = ПредставлениеЗадолженностиПоДокументу(СтрокаТЗ.Основание);
		// ТекущийДокумент = СтрРазделить(СтрокаТЗ.Основание, " ", Ложь)[0];
		
		ВозвращаемаяСтруктура = Новый Структура;
		ВозвращаемаяСтруктура.Вставить("ЗадолженностьПредставление", ЗадолженностьПредставление);
		ВозвращаемаяСтруктура.Вставить("СуммаПредставление"		   , СуммаПредставление);
		// ВозвращаемаяСтруктура.Вставить("ТекущийДокумент"		   , ТекущийДокумент);		

		Возврат ВозвращаемаяСтруктура;	
		
	ИначеЕсли ЭлементРодитель = "ГруппаКартыСуществующие" Тогда	
		
		ЭтоКартаWallet = ЗначениеЗаполнено(СтрокаТЗ.ВидКарты.ИдентификаторПроекта);
		
		Возврат "Карта №" + ?(ЗначениеЗаполнено(СтрокаТЗ.ВнутреннийКодКарты) И Не ЭтоКартаWallet, Строка(СтрокаТЗ.ВнутреннийКодКарты), Строка(СтрокаТЗ.КодКарты));	
		
	ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" Тогда
		
		СтроковоеПредставление = СтрокаТЗ.ПромокодСсылка.Наименование + ?(СтрокаТЗ.ПромокодСсылка.ПометкаУдаления, НСтр("ru = ' (удален)'; en = ' (deleted)'"), "") + ": " + СтрокаТЗ.Промокод;
		Возврат СтроковоеПредставление;
		
	КонецЕсли;
	
КонецФункции

// Функция создает представление задолженности пациента
//
Функция ПредставлениеЗадолженностиПоДокументу(Основание)
	
	// Справочно:
	// Док. Прием 		= ТЧ Лечение и ТЧ Запасы
	// Док. Реализация 	= ТЧ Услуги и ТЧ Запасы
	
	УстановитьПривилегированныйРежим(Истина); // 234696.
	
	Представление = "";
	
	МассивНоменклатуры = Новый Массив;
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Прием") Тогда 
		МассивНоменклатуры.Добавить(Основание.Лечение.ВыгрузитьКолонку("Номенклатура"));
	КонецЕсли;
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Реализация") Тогда
		МассивНоменклатуры.Добавить(Основание.Услуги.ВыгрузитьКолонку("Номенклатура"));	
	КонецЕсли;
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.Прием") ИЛИ ТипЗнч(Основание) = Тип("ДокументСсылка.Реализация") Тогда		
		МассивНоменклатуры.Добавить(Основание.Запасы.ВыгрузитьКолонку("Номенклатура"));	
	КонецЕсли;
	
	Для Каждого ЭлементМассиваТЧ Из МассивНоменклатуры Цикл
		Для Каждого ЭлементМассиваНоменклатура Из ЭлементМассиваТЧ Цикл
			Представление = Представление + ЭлементМассиваНоменклатура.Наименование + ", ";	
		КонецЦикла;
	КонецЦикла;
		
	// Убираем лишнюю запятую
	Если СтрДлина(Представление) > 2 Тогда 
		Представление = Лев(Представление,СтрДлина(Представление) - 2); 
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

//  Процедура - Обновить отображение табличных частей
// 
//  Параметры:
//   Форма			 - 	 - 
//   ВладелецСсылка	 - 	 - 
//   МассивПараметров - 	 - 
// 
Процедура ОбновитьОтображениеТабличныхЧастей(Форма, Знач ВладелецСсылка = Неопределено, Знач МассивТабличныхЧастей = Неопределено) Экспорт
	
	//  Выходим если параметры не переданы
	Если МассивТабличныхЧастей = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	//  Определяем владельца формы
	Если ВладелецСсылка = Неопределено Тогда
		ВладелецСсылка = Форма.Объект.Ссылка;
	ИначеЕсли НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда  
		Возврат;
	КонецЕсли;
	
	//  Создание таблиц-реквизитов формы, если отсутствуют	
	ДобавитьРеквизитыФормы(Форма);
	
	//  Пересоздание элементов формы по информации из таблицы для отображения
	ОбновитьДинамическиеЭлементыТабличныхЧастей(Форма, ВладелецСсылка, МассивТабличныхЧастей);
	
	//// Выводим шкалу с длительностью. Если она уже создана, не создаем второй раз
	// Если Форма.Элементы.Найти("ГруппаВыводаКнопокДлительности_5") = Неопределено Тогда 
	//	НовыйЭлементШкалыДлительности = Неопределено;
	//	ЗаполнитьШкалуДлительностиПриема(Форма, МассивТабличныхЧастей, НовыйЭлементШкалыДлительности);
	// КонецЕсли;

КонецПроцедуры

//  Процедура - Добавить реквизиты формы
// 
//  Параметры:
//   Форма	 - 	 - 
// 
Процедура ДобавитьРеквизитыФормы(Форма)
	
	//  Вычисляем существующие реквизиты
	СписокРеквизитовФормы = Форма.ПолучитьРеквизиты();
	
	СоздатьТаблицуВремениОжидания = Истина;
	
	Для Каждого Реквизит Из СписокРеквизитовФормы Цикл
		Если Реквизит.Имя = "Таблица_ВремениОжидания" 	Тогда
			СоздатьТаблицуВремениОжидания = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	//  Создаем реквизиты формы
	МассивДобавляемыхРеквизитов = Новый Массив;
	
	Если СоздатьТаблицуВремениОжидания Тогда 
		
		ИмяТаблицы = "Таблица_ВремениОжидания";
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КлючСтроки"				, Новый ОписаниеТипов("УникальныйИдентификатор"), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВремяОжидания"			, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(4, 0, ДопустимыйЗнак.Неотрицательный)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Надпись"	            	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВремяОжидания_Текст"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаНачалаОжидания"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10)), ИмяТаблицы));
	Иначе 
		Форма.Таблица_ВремениОжидания.Очистить();
	КонецЕсли;
	
	Если МассивДобавляемыхРеквизитов.Количество() > 0 Тогда
		Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

//  Процедура, перестраивает динамические элементы в визите.
// 
Процедура ОбновитьДинамическиеЭлементыТабличныхЧастей(Форма, ВладелецСсылка, МассивТабличныхЧастей)
	
	Элементы 	   = Форма.Элементы; 
	ДокументЗакрыт = ?(Форма.ИмяФормы = "Документ.Событие.Форма.ФормаДокумента", Ложь, Форма.ДокументЗакрыт);
	НесколькоВрачейВОдномПриеме = Константы.НесколькоВрачейВОдномПриеме.Получить();
	
	Для Каждого ПараметрыТабличнойЧасти Из МассивТабличныхЧастей Цикл 
		
		ГруппаРодительТабличнойЧасти = Элементы.Найти(ПараметрыТабличнойЧасти.ГруппаДляРазмещения);
		
		//  Пропускаем если нет группы для размещения или нет указанной табличной части
		Если ГруппаРодительТабличнойЧасти = Неопределено
			ИЛИ ВладелецСсылка.Метаданные().ТабличныеЧасти.Найти(ПараметрыТабличнойЧасти.ТабличнаяЧасть) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		//  Удалим элементы
		УдаляемыеЭлементы = Новый Массив;
		Для Каждого ГруппаЭлементов Из ГруппаРодительТабличнойЧасти.ПодчиненныеЭлементы Цикл
			
			Если ГруппаЭлементов.Имя <> "ГруппаОтменаВизитаПредварительнаяСтоимость" Тогда 
				УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
			КонецЕсли;	
			
		КонецЦикла;
		
		Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
			Элементы.Удалить(УдаляемыйЭлемент);
		КонецЦикла;
		
		//  Выводим элементы
		ПредыдущаяСтрока = Неопределено;	
		КоличествоСтрокТаблицы = Форма.Объект[ПараметрыТабличнойЧасти.ТабличнаяЧасть].Количество();
		Для Каждого СтрокаТЧ Из Форма.Объект[ПараметрыТабличнойЧасти.ТабличнаяЧасть] Цикл 
			
			Номенклатура = СтрокаТЧ.Номенклатура;
			ПроверкаБесплатность = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "Бесплатно");
			// Если ЗначениеЗаполнено(Номенклатура) 
			//	И (Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга 
			//	ИЛИ СтрокаТЧ.НормаВремени = 0) Тогда 
			//	
			//	Продолжить;
			// КонецЕсли;
			
			ТолькоПросмотрПоля = Ложь;// ЗначениеЗаполнено(СтрокаТЧ.Курс);
			
			ИндексСтрокиТЧ        = Форма.Объект[ПараметрыТабличнойЧасти.ТабличнаяЧасть].Индекс(СтрокаТЧ);
			НоменклатураЗаполнена = ЗначениеЗаполнено(Номенклатура) ИЛИ ИндексСтрокиТЧ = 0;
			
			ВремяОжидания = 0;
			ИспользоватьФункционалSPA = Ложь;// ПолучитьФункциональнуюОпцию("ИспользоватьФункционалSPA");
			ИспользоватьАссистентов   = Ложь;// ПолучитьФункциональнуюОпцию("ИспользоватьАссистентов");
			ИспользоватьРесурсы    	  = Ложь;// ПолучитьФункциональнуюОпцию("ИспользоватьРесурсы");
			
			Если НЕ ПредыдущаяСтрока = Неопределено И ПредыдущаяСтрока.ДатаОкончания <> Дата(1,1,1) И СтрокаТЧ.ДатаНачала  <> Дата(1,1,1) Тогда 
				Если ПредыдущаяСтрока.ДатаОкончания > СтрокаТЧ.ДатаНачала Тогда 
					ВремяОжидания = Цел(((ПредыдущаяСтрока.ДатаНачала - СтрокаТЧ.ДатаОкончания) / 60));					
				ИначеЕсли ПредыдущаяСтрока.ДатаОкончания < СтрокаТЧ.ДатаНачала Тогда 
					ВремяОжидания = Цел(((СтрокаТЧ.ДатаНачала - ПредыдущаяСтрока.ДатаОкончания) / 60));					
				КонецЕсли;	
			КонецЕсли;
			
			Если ВремяОжидания > 0 Тогда
				ДатаНачалаОжидания = Формат(ПредыдущаяСтрока.ДатаНачала + ПредыдущаяСтрока.НормаВремени * 60, "ДФ=HH:мм"); 
				ВывестиВремяОжидания(Форма, ГруппаРодительТабличнойЧасти, ПараметрыТабличнойЧасти, ВремяОжидания, ДатаНачалаОжидания, ИндексСтрокиТЧ);
			КонецЕсли;
			
