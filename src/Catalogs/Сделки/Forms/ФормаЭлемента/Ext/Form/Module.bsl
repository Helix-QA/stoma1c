// Процедура, оброботчик оповещения.
//
Процедура ВзаимодействиеПослеВопросаОЗаписиСделки(Ответ, ДопПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да 
		И ЭтаФорма.Записать() Тогда
		
		Действие = ДопПараметры.ВыполнитьДействие; 
		
		Если Действие = "СоздатьЗаметку" Тогда
			СоздатьЗаметкуНаКлиенте();
		ИначеЕсли Действие = "СоздатьПисьмо" Тогда
			СоздатьПисьмоНаКлиенте();
		ИначеЕсли Действие = "СоздатьSMS" Тогда
			СоздатьSMSРассылкуНаКлиенте();
		ИначеЕсли Действие = "ВыборВзаимодействия" Тогда
			ВыборВзаимодействиеЗадачаНаСервере();
		ИначеЕсли Параметры.ВыполнитьДействие = "ПерейтиКДиалогу" Тогда
			Подключаемый_ПерейтиКДиалогу(Параметры.Элемент);	
		КонецЕсли;
		
	КонецЕсли;
			
КонецПроцедуры

