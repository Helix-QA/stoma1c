&НаКлиенте
// Процедура лтправляет данные в Контур.Страхование
//
Процедура ОтправитьДанныеВКС(Команда)
	
	ТекСтрока = Элементы.Список.ТекущиеДанные;
	Если ТекСтрока = Неопределено Тогда
		ВызватьИсключение "Выберите строку с нужным событием";
	КонецЕсли;
	
	ОтправитьДанныеВКСНаСервере(ТекСтрока.Ссылка);  
	
КонецПроцедуры

