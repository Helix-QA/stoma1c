// Процедура - Отобразить заметки пользователей
//
Процедура ОтобразитьЗаметкиПользователей()
	
	Если НЕ СтруктураБлокировкиНомера = Неопределено Тогда
		Если ТипЗнч(СтруктураБлокировкиНомера) = Тип("Структура") И СтруктураБлокировкиНомера.Свойство("ПричинаБлокировки") И ЗначениеЗаполнено(СтруктураБлокировкиНомера.ПричинаБлокировки) Тогда 
			Если СтрНайти(ПараметрыТелефонногоЗвонка.Заметка, СтруктураБлокировкиНомера.ПричинаБлокировки) = 0 Тогда 
				Заметка = СтруктураБлокировкиНомера.ПричинаБлокировки + Символы.ПС + Символы.ПС + ПараметрыТелефонногоЗвонка.Заметка;
			Иначе 
				Заметка = ПараметрыТелефонногоЗвонка.Заметка;
			КонецЕсли;
		Иначе 
			Заметка = ПараметрыТелефонногоЗвонка.Заметка;
		КонецЕсли;	
	Иначе 
		Заметка = ПараметрыТелефонногоЗвонка.Заметка;		
	КонецЕсли;
	
