// Функция - Получить количество по полису.
//
Функция ПолучитьКоличествоПоПолису(ПолисМедСтрахования, ОбъектСсылка)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемЛечение.Номенклатура КАК Номенклатура,
	|	СУММА(ПриемЛечение.Количество) КАК Количество,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПриемЛечение.Зуб) КАК КоличествоЗубов
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|ГДЕ
	|	ПриемЛечение.Ссылка.ПолисМедСтрахования = &ПолисМедСтрахования
	|	И ПриемЛечение.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И ПриемЛечение.Ссылка <> &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриемЛечение.Номенклатура";
	Запрос.УстановитьПараметр("ПолисМедСтрахования", ПолисМедСтрахования);
	Запрос.УстановитьПараметр("Ссылка", ОбъектСсылка);
	ТаблицаНоменклатур = Запрос.Выполнить().Выгрузить();
	МассивСтруктур = ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(ТаблицаНоменклатур);
	Возврат МассивСтруктур;	
	
