// Процедура - Обновить дерево подборов сотрудников
//
// Параметры:
//  ОбновитьОтборПоСотруднику	 - 	 - 
//  ОбновитьОтборПоДолжности	 - 	 - 
//  ОбновитьОтборПоРоли			 - 	 - 
//
Процедура ОбновитьДеревоПодборовСотрудников(ОбновитьОтборПоСотруднику = Ложь, ОбновитьОтборПоДолжности = Ложь, ОбновитьОтборПоРоли = Ложь)
	
	ЗаполнитьДеревоПодбораСотрудников();
	
	ЗаполнитьСписокПодбораРекурсивноСервер(
	ЭтаФорма._ПодборСотрудниковИсточникГрупп.ПолучитьЭлементы(), 
	ЭтаФорма._ПодборСотрудниковИсточникЭлементов, 
	ЭтаФорма._ПодборСотрудников, ЭтаФорма);	
	
	Если ОбновитьОтборПоСотруднику Тогда
		Элементы.ОткрытьСписокСотрудники.Заголовок 	= ?(ЗначениеЗаполнено(ОтборСотрудник), ОтборСотрудник.Наименование, "Все");	
		Элементы.ОтменитьОтборПоСотруднику.Видимость = Элементы.ОткрытьСписокСотрудники.Заголовок <> "Все";
	КонецЕсли;
	
	Если ОбновитьОтборПоДолжности Тогда
		Элементы.ОткрытьСписокДолжности.Заголовок 	= ?(ЗначениеЗаполнено(ОтборСотрудникДолжность), ОтборСотрудникДолжность.Наименование, "Все");
		Элементы.ОтменитьОтборПоДолжности.Видимость = Элементы.ОткрытьСписокДолжности.Заголовок <> "Все";
	КонецЕсли;
	
	Если ОбновитьОтборПоРоли Тогда
		Элементы.ОткрытьСписокРоли.Заголовок 	= ?(ЗначениеЗаполнено(ОтборСотрудникРоль), Строка(ОтборСотрудникРоль), "Все");
		Элементы.ОтменитьОтборПоРоли.Видимость 	= Элементы.ОткрытьСписокРоли.Заголовок <> "Все";
	КонецЕсли;
	
КонецПроцедуры

