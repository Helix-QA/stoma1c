							ЭлементГруппаМетки.ОтображатьЗаголовок = Ложь;
							ЭлементГруппаМетки.Отображение         = ОтображениеОбычнойГруппы.Нет;
							ЭлементГруппаМетки.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	 
							
							Если ЗначениеЗаполнено(Элемент.ПолисМедСтрахования) Тогда 
								ПолисДействующий = Элемент.ПолисМедСтрахования;
								
								ЭлементГруппаМеткиПолис                     	= ЭтаФорма.Элементы.Добавить("ГруппаМеткиПолис_" + Индекс, Тип("ГруппаФормы"), ЭлементГруппаМетки);
								ЭлементГруппаМеткиПолис.Вид                 	= ВидГруппыФормы.ОбычнаяГруппа;
								ЭлементГруппаМеткиПолис.ОтображатьЗаголовок 	= Ложь;
								ЭлементГруппаМеткиПолис.Отображение         	= ОтображениеОбычнойГруппы.Нет;
								ЭлементГруппаМеткиПолис.Группировка         	= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
								ЭлементГруппаМеткиПолис.ГоризонтальныйИнтервал  = ИнтервалМеждуЭлементамиФормы.Нет;
								
								Если ЗначениеЗаполнено(ПолисДействующий.СтраховаяКомпания.КраткоеНаименование) Тогда
									ФонМетки = ?(ЗначениеЗаполнено(ПолисДействующий.СтраховаяКомпания.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(ПолисДействующий.СтраховаяКомпания.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
									
									ЭлементГруппаМетка                      	= ЭтаФорма.Элементы.Добавить("ГруппаМеткаСК_" + Индекс, Тип("ГруппаФормы"), ЭлементГруппаМеткиПолис);
									ЭлементГруппаМетка.Вид                  	= ВидГруппыФормы.ОбычнаяГруппа;
									ЭлементГруппаМетка.ОтображатьЗаголовок  	= Ложь;
									ЭлементГруппаМетка.Отображение          	= ОтображениеОбычнойГруппы.Нет;
									ЭлементГруппаМетка.ЦветФона          		= ФонМетки;
									
									ДекорацияФормы_Метка = Элементы.Добавить("ДекорацияМеткаСК_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаМетка);
									ДекорацияФормы_Метка.Вид 				   = ВидДекорацииФормы.Надпись;
									ДекорацияФормы_Метка.Заголовок 			   = ПолисДействующий.СтраховаяКомпания.КраткоеНаименование;
									ДекорацияФормы_Метка.АвтоМаксимальнаяШирина = Ложь;
									ДекорацияФормы_Метка.ЦветТекста             = ?(ПолисДействующий.СтраховаяКомпания.ЦветТекстаБелый, Новый Цвет(255,255,255), Новый Цвет(77,77,77));
								КонецЕсли;
								
								Если ЗначениеЗаполнено(ПолисДействующий.Договор) 
									И ЗначениеЗаполнено(ПолисДействующий.Договор.ПрограммаСтрахования) Тогда
									
									ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(ПолисДействующий.Договор.ПрограммаСтрахования); 
									
									ЭлементГруппаМетка                      	= ЭтаФорма.Элементы.Добавить("ГруппаМеткаДоговор_" + Индекс, Тип("ГруппаФормы"), ЭлементГруппаМеткиПолис);
									ЭлементГруппаМетка.Вид                  	= ВидГруппыФормы.ОбычнаяГруппа;
									ЭлементГруппаМетка.ОтображатьЗаголовок  	= Ложь;
									ЭлементГруппаМетка.Отображение          	= ОтображениеОбычнойГруппы.Нет;
									ЭлементГруппаМетка.ЦветФона          		= ДанныеПрограммыСтрахования.ЦветФона;
									
									ДекорацияФормы_Метка = Элементы.Добавить("ДекорацияМеткаДоговор_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаМетка);
									ДекорацияФормы_Метка.Вид 				   	= ВидДекорацииФормы.Надпись;
									ДекорацияФормы_Метка.Заголовок 			   	= ДанныеПрограммыСтрахования.Текст;
									ДекорацияФормы_Метка.АвтоМаксимальнаяШирина = Ложь;
									ДекорацияФормы_Метка.ЦветТекста             = ДанныеПрограммыСтрахования.ЦветТекста;
									
								КонецЕсли;  
								
							КонецЕсли;
							
							Если МеткиПациента.Количество() > 0 Тогда
								
								ИндексМетки = 0;
								
								// Размещаем элементы меток
								Для ИндексМетки = 0 По МеткиПациента.Количество()-1 Цикл
									
									ЭлементГруппаМеткаПациента                      	= ЭтаФорма.Элементы.Добавить("ГруппаМеткаПациента_" + Индекс + ИндексМетки, Тип("ГруппаФормы"), ЭлементГруппаМетки);
									ЭлементГруппаМеткаПациента.Вид                  	= ВидГруппыФормы.ОбычнаяГруппа;
									ЭлементГруппаМеткаПациента.ОтображатьЗаголовок  	= Ложь;
									ЭлементГруппаМеткаПациента.Отображение          	= ОтображениеОбычнойГруппы.Нет;
									ЭлементГруппаМеткаПациента.ЦветФона          		= ЗначениеИзСтрокиВнутр(МеткиПациента[ИндексМетки].ЦветМетки);
									
									// Создаем декорацию метки.
									ДекорацияФормы_Метка = Элементы.Добавить("ДекорацияМетка_" + Индекс + ИндексМетки, Тип("ДекорацияФормы"), ЭлементГруппаМеткаПациента);
									ДекорацияФормы_Метка.Вид 				   = ВидДекорацииФормы.Надпись;
									ДекорацияФормы_Метка.Заголовок 			   = МеткиПациента[ИндексМетки].Наименование;
									ДекорацияФормы_Метка.АвтоМаксимальнаяШирина = Ложь;
									ДекорацияФормы_Метка.ЦветТекста             = ?(МеткиПациента[ИндексМетки].ЦветТекстаБелый, Новый Цвет(255, 255, 255),Новый Цвет (77, 77 ,77));
									
								КонецЦикла;
								
							КонецЕсли;
							
							// Создаем заглушку.
							ДекорацияФормы_ЗаглушкаЕще = Элементы.Добавить("ЗаглушкаЕще_" + Индекс, Тип("ДекорацияФормы"), ЭлементПодГруппа);
							ДекорацияФормы_ЗаглушкаЕще.Вид					= ВидДекорацииФормы.Надпись;
							ДекорацияФормы_ЗаглушкаЕще.Шрифт				= Новый Шрифт("Arial", 2);
							
							////////////////////// Перенести Отменить ////////////////////////////////
							ЭлементГруппаПеренестиОтменить                     = ЭтаФорма.Элементы.Добавить("ГруппаПеренестиОтменить_" + Индекс, Тип("ГруппаФормы"), ЭлементГруппа);
							ЭлементГруппаПеренестиОтменить.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
							ЭлементГруппаПеренестиОтменить.ОтображатьЗаголовок = Ложь;
							ЭлементГруппаПеренестиОтменить.Отображение         = ОтображениеОбычнойГруппы.Нет;
							ЭлементГруппаПеренестиОтменить.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;			
							ЭлементГруппаПеренестиОтменить.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Право; 
							ЭлементГруппаПеренестиОтменить.Ширина              = 44;
							
							// Добавим декорацию перенести прием
							ДекорацияФормы_ПеренестиПрием 					= Элементы.Добавить("Декорация_ПеренестиПрием_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаПеренестиОтменить);
							ДекорацияФормы_ПеренестиПрием.Вид 				= ВидДекорацииФормы.Надпись;
							ДекорацияФормы_ПеренестиПрием.Заголовок 		= "Перенести"; 
							ДекорацияФормы_ПеренестиПрием.Гиперссылка 		= Истина;
							ДекорацияФормы_ПеренестиПрием.ЦветТекста 		= ЦветаСтиля.ЦветАкцента; 
							ДекорацияФормы_ПеренестиПрием.Шрифт 			= Новый Шрифт("Arial", 11);
							ДекорацияФормы_ПеренестиПрием.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_ПеренестиПрием_Нажатие");
							
							// Создаем заглушку.
							ДекорацияФормы_ЗаглушкаВторая = Элементы.Добавить("ЗаглушкаВторая_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаПеренестиОтменить);
							ДекорацияФормы_ЗаглушкаВторая.Вид 				   = ВидДекорацииФормы.Надпись;
							ДекорацияФормы_ЗаглушкаВторая.АвтоМаксимальнаяШирина = Ложь;
							ДекорацияФормы_ЗаглушкаВторая.МаксимальнаяШирина     = 2;
							ДекорацияФормы_ЗаглушкаВторая.Ширина                 = 2;	
							
							// Добавим декорацию перенести прием
							ДекорацияФормы_ПеренестиПрием 					= Элементы.Добавить("Декорация_ОтменитьПрием_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаПеренестиОтменить);
							ДекорацияФормы_ПеренестиПрием.Вид 				= ВидДекорацииФормы.Надпись;
							ДекорацияФормы_ПеренестиПрием.Заголовок 		= "Отменить"; 
							ДекорацияФормы_ПеренестиПрием.Гиперссылка 		= Истина;
							ДекорацияФормы_ПеренестиПрием.ЦветТекста 		= ЦветаСтиля.ЦветОсобогоТекста; 
							ДекорацияФормы_ПеренестиПрием.Шрифт 			= Новый Шрифт("Arial", 11);
							ДекорацияФормы_ПеренестиПрием.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_ОтменитьПрием_Нажатие");
							
							СсылкаНаЗапись = ТаблицаЗаписей.Добавить();
							СсылкаНаЗапись.Запись = Элемент.Событие;
							
							Индекс = Индекс + 1;
						КонецЕсли;               
						
					КонецЦикла;
				ИначеЕсли ИндексСЕ > 0 Тогда
					ИндексСЕ = ИндексСЕ - 1;
				КонецЕсли;
				ИндексСЕ = ИндексСЕ + 1;
			КонецЦикла;			
			ИндексПациента = ИндексПациента + 1;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый отменить прием
//
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура Подключаемый_ДекорацияФормы_ПеренестиПрием_Нажатие(Элемент)

	Индекс 		  = Число(СтрЗаменить(Элемент.Имя, "Декорация_ПеренестиПрием_", ""));	
	СтрокаТаблицы = ЭтаФорма.ТаблицаЗаписей[Индекс];

	БуферОбмена = Новый Структура;
	БуферОбмена.Вставить("ПризнакВырезать", Истина);
	БуферОбмена.Вставить("Буфер", Новый Структура("Событие", СтрокаТаблицы.Запись));

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Контрагент"              ,ПациентПоПриему(СтрокаТаблицы.Запись));
	ПараметрыФормы.Вставить("ЗакрытьПриСозданииЗаписи",Истина);    
	ПараметрыФормы.Вставить("БуферОбмена", БуферОбмена); 

	ОписаниеОповещения = Новый ОписаниеОповещения("ПеренестиПриемЗавершение", ЭтаФорма);
	//ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаПредварительнойЗаписи");
	//ОткрытьФорму(ИмяФормыПланировщика, ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаЗаписи");
	Форма = ПолучитьФорму(ИмяФормыПланировщика, ПараметрыФормы,, "ФормаПланировщикКлючУникальности");
	Форма.Открыть();                            
	Оповестить("ПереносПриема", ПараметрыФормы);
	
КонецПроцедуры

