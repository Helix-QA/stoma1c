// Процедура - Настройки онлайн записи при создании
//
Процедура НастройкиОнлайнЗаписиПриСоздании()
	
	ЭтотОбъект.ВиджетОнлайнЗаписи 				   = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи); 	
	ЭтотОбъект.ВиджетОнлайнЗаписиАвторизацияБезСМС = ЭтотОбъект.ВиджетОнлайнЗаписи.АвторизацияПоКодуБезСМС;
	
	ПараметрыВС = ЭтотОбъект.ВиджетОнлайнЗаписи.Параметры.Получить();
	
	Если ТипЗнч(ПараметрыВС) = Тип("Структура") Тогда 					
		
		ЭтотОбъект.РазделенныеПоляФИО		= ?(ПараметрыВС.Свойство("РазделенныеПоляФИО")		, ПараметрыВС.РазделенныеПоляФИО		, Неопределено);
		ЭтотОбъект.ВыводитьДатуРождения 	= ?(ПараметрыВС.Свойство("ВыводитьДатуРождения")	, ПараметрыВС.ВыводитьДатуРождения		, Неопределено);
		ЭтотОбъект.ВыводитьПочту			= ?(ПараметрыВС.Свойство("ВыводитьПочту")			, ПараметрыВС.ВыводитьПочту				, Неопределено);
		ЭтотОбъект.ВыводитьПолеНапоминания	= ?(ПараметрыВС.Свойство("ВыводитьПолеНапоминания")	, ПараметрыВС.ВыводитьПолеНапоминания	, Ложь);
		ЭтотОбъект.FacebookPixel			= ?(ПараметрыВС.Свойство("FacebookPixel")			, ПараметрыВС.FacebookPixel				, Неопределено);
		ЭтотОбъект.ЗапретОнлайнЗаписиС		= ?(ПараметрыВС.Свойство("ЗапретОнлайнЗаписиС")		, ПараметрыВС.ЗапретОнлайнЗаписиС		, Неопределено);
		ЭтотОбъект.ЗапретОнлайнЗаписиПо		= ?(ПараметрыВС.Свойство("ЗапретОнлайнЗаписиПо")	, ПараметрыВС.ЗапретОнлайнЗаписиПо		, Неопределено);
						
	КонецЕсли;

	ДоступныеТипыАвторизации = Константы.ДоступныеТипыАвторизации.Получить().Получить();
	
	Если ТипЗнч(ДоступныеТипыАвторизации) = Тип("Структура") И ДоступныеТипыАвторизации.Свойство("СписокТиповАвторизации") Тогда
		
		ЭтотОбъект.СписокТиповАвторизации = ДоступныеТипыАвторизации.СписокТиповАвторизации;
		
		Для Каждого ТипАвторизации Из ЭтотОбъект.СписокТиповАвторизации Цикл
			Если ТипАвторизации.Пометка Тогда
				УправлениеИнтерфейсамиСервер.ИзменитьАктивностьПереключателяФормы(Элементы[ТипАвторизации.Значение],, Истина);	
			КонецЕсли;
		КонецЦикла;			
		
	Иначе 
		ЭтотОбъект.СписокТиповАвторизации.Добавить("whats_app"	, "WhatsApp");
		ЭтотОбъект.СписокТиповАвторизации.Добавить("sms"		, "СМС");
		ЭтотОбъект.СписокТиповАвторизации.Добавить("email"		, "Email");
	КонецЕсли;
	
	УстановитьВидимостьЭлементов();
	УстановитьДоступностьТиповАвторизации();
	
КонецПроцедуры

