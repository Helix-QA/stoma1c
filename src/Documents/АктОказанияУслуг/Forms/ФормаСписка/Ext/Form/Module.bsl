#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы на сервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; 
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница, ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница));
	
	ВнешняяСистемаКС = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.КонтурСтрахование, Истина);
	
	Если ЗначениеЗаполнено(ВнешняяСистемаКС) Тогда
		
		Элементы.ОтправитьДанныеВКС.Видимость = Истина;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Установить отбор по структурной единице
Процедура ОтборСтруктурнаяЕдиницаПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница, ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница));
КонецПроцедуры

&НаКлиенте
// Устанвовить отбор по страховой компании
Процедура ОтборСтраховаяКомпанияПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", ОтборСтраховаяКомпания, ЗначениеЗаполнено(ОтборСтраховаяКомпания));
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ОтборОрганизацияПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Организация", ОтборОрганизация, ЗначениеЗаполнено(ОтборОрганизация));
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ОтборДоговорПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Договор", ОтборДоговор, ЗначениеЗаполнено(ОтборДоговор));
	
КонецПроцедуры

&НаКлиенте
// Процедура печати.
//
Процедура ДокументПечать(Команда)	
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "АктОказанияУслуг");	
	Структура.Вставить("МассивДокументов", Элементы.Список.ВыделенныеСтроки);
	
	СписокПечатныхФорм = ПолучитьСписокПечати();
	Оповещение = Новый ОписаниеОповещения("ОбработкаКоманды", УправлениеПечатьюКлиентСтоматология, Структура);									
	//ПоказатьВыборИзСписка(Оповещение, СписокПечатныхФорм, ТекущийЭлемент);
	ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, ТекущийЭлемент);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция Полчить список печатных форм.
//
Функция ПолучитьСписокПечати()                           	
	Возврат Документы.АктОказанияУслуг.ПолучитьСписокПечатныхФорм();	
КонецФункции

&НаСервере
// Процедура, отправляет данные по акту оказанных услуг в Контр.Страхование.
//
Процедура ОтправитьДанныеВКСНаСервере(Акт)
	
	ВнешняяСистемаКС = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.КонтурСтрахование, Истина);
	token = ВнешняяСистемаКС.ТокенДоступа;
	ПараметрыВС = ВнешняяСистемаКС.Параметры.Получить(); 
	mediIdСК = "";
	mediIdОрганизации = "";
	Для Каждого ЭлементМ Из ПараметрыВС.МассивОрганизаций Цикл
		Если ЭлементМ.partyTypeCode = "Insurer"  И Акт.Контрагент.ИНН = ЭлементМ.inn И Акт.Контрагент.КПП = ЭлементМ.kpp Тогда
			mediIdСК = ЭлементМ.mediId;
		ИначеЕсли ЭлементМ.partyTypeCode = "Clinic" Тогда
			mediIdОрганизации = ЭлементМ.mediId;
		КонецЕсли;
	КонецЦикла;      
	
	Если Не ЗначениеЗаполнено(mediIdСК) Тогда
		ТекстСообщения = НСтр("ru = 'Не заполнена организация получатель.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(mediIdОрганизации) Тогда
		ТекстСообщения = НСтр("ru = 'Не заполнена организация отправитель.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос("/V2/messages");
	Запрос.Заголовки.Вставить("Authorization", "Bearer "+token);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");

	ПутьКФайлу = ПолучитьПутьКФайлу(Акт, mediIdОрганизации, mediIdСК);
	
	ДвоичныеДанныеЗаписи = Новый ДвоичныеДанные(ПутьКФайлу);
	
	message = Base64Строка(ДвоичныеДанныеЗаписи);

	СтрокаJSON = "{ ""mediId"": """ + mediIdОрганизации + """, ""message"": """ + message + """}";

	Запрос.УстановитьТелоИзСтроки(СтрокаJSON,КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать); 
	
	//ЗапуститьПриложение(ПутьКФайлу);
	
	Ответ = Клиент_post(Запрос,ХостАпи(ПараметрыВС.Демо));    
	
	Если Ответ.КодСостояния = 404 Тогда
		ВызватьИсключение "Сообщение не найдено: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния = 401 Тогда
		ВызватьИсключение "Запрос не авторизован: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния = 400 Тогда
		ВызватьИсключение "Некорректный формат идентификатора сообщения: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния >= 300 Тогда
		ВызватьИсключение "Не удалось выполнить запрос: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния = 200 Тогда // Всё хорошо
		джсон = Новый ЧтениеJSON;
		джсон.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
		ОтветСервера = ПрочитатьJSON(джсон);
		джсон.Закрыть();
		
		НаборЗаписей = РегистрыСведений.СообщенияКонтурСтрахование.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.mediId.Установить(mediIdОрганизации);
		НаборЗаписей.Отбор.eventId.Установить(Строка(Акт.УникальныйИдентификатор()));
		НаборЗаписей.Отбор.eventType.Установить("NewInboxMessage"); 
        НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() = 0 Тогда
			НовыйНомер = НаборЗаписей.Добавить();
		Иначе
			НовыйНомер = НаборЗаписей[0];	
		КонецЕсли;
				
		НовыйНомер.mediId			= mediIdОрганизации;
		НовыйНомер.eventId			= Строка(Акт.УникальныйИдентификатор());
		НовыйНомер.eventPointer		= Строка(Новый УникальныйИдентификатор);
		НовыйНомер.eventType		= "NewInboxMessage"; 

		НовыйНомер.eventDateTime	= Строка(ТекущаяДатаСеанса());
		НовыйНомер.documentDate		= Строка(Акт.Дата);	
		НовыйНомер.documentNumber   = Строка(Акт.Номер);	
		НовыйНомер.documentType     = "Ihclme";
		
		НовыйНомер.senderMediId     = mediIdОрганизации;
		НовыйНомер.recipientMediId  = mediIdСК;
		НовыйНомер.contentType 		= "NewInboxMessageEventContent";
		НовыйНомер.messageId		= ОтветСервера.messageId;
		
		lastEventPointer = РегистрыСведений.СообщенияКонтурСтрахование.ПоследнееПисьмо();
		НовыйНомер.lastEventPointer	= lastEventPointer; 
		
		Попытка
			НаборЗаписей.Записать(Истина);
		Исключение	
			
		КонецПопытки;  
		АктОбъект = Акт.ПолучитьОбъект();
		АктОбъект.ОтправленВКонтурСтрахование = Истина; 
		АктОбъект.Комментарий = "Отправлен в Контур.Страхование"; 
		АктОбъект.Записать();
		
		// ОтветСервера.messageId - Id отправленного сообщения, по которому потом читать ленту и мониторить статус отправки и обработки

	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция возвращает путь к файлу
//
Функция ПолучитьПутьКФайлу(Акт, mediIdОрганизации, mediIdСК)
	
	ПутьКФайлу = ПолучитьИмяВременногоФайла("xml");
	
	Запись = Новый ЗаписьXML;
	Запись.ОткрытьФайл(ПутьКФайлу, "UTF-8"); 
	Запись.ЗаписатьОбъявлениеXML();
    Запись.ЗаписатьНачалоЭлемента("eDIMessage");
	Запись.ЗаписатьАтрибут("id", Строка(Акт.УникальныйИдентификатор()));
	
		Запись.ЗаписатьНачалоЭлемента("interchangeHeader");
	
			Запись.ЗаписатьНачалоЭлемента("sender");
			Запись.ЗаписатьТекст(mediIdОрганизации);
			Запись.ЗаписатьКонецЭлемента();
	
			Запись.ЗаписатьНачалоЭлемента("recipient");
			Запись.ЗаписатьТекст(mediIdСК);
			Запись.ЗаписатьКонецЭлемента();
		
			Запись.ЗаписатьНачалоЭлемента("documentType");
			Запись.ЗаписатьТекст("IHCLME");
			Запись.ЗаписатьКонецЭлемента();

			Запись.ЗаписатьНачалоЭлемента("creationDateTime"); 
			Запись.ЗаписатьТекст(ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO));
  			Запись.ЗаписатьКонецЭлемента();
		    
		Запись.ЗаписатьКонецЭлемента();
		
		Запись.ЗаписатьНачалоЭлемента("healthCareClaim");
		Запись.ЗаписатьАтрибут("healthCareClaimDate", Формат(Акт.Дата, "ДФ=yyyy-MM-dd"));
		Запись.ЗаписатьАтрибут("healthCareClaimNumber", ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Акт.Номер, Акт.Организация.Префикс));
		
			Запись.ЗаписатьНачалоЭлемента("claimPeriodFrom");
			Запись.ЗаписатьТекст(Формат(Акт.НачалоПериода, "ДФ=yyyy-MM-dd"));
			Запись.ЗаписатьКонецЭлемента();                  
			
			Запись.ЗаписатьНачалоЭлемента("claimPeriodTo");
			Запись.ЗаписатьТекст(Формат(Акт.ОкончаниеПериода, "ДФ=yyyy-MM-dd"));
			Запись.ЗаписатьКонецЭлемента();
			
			Запись.ЗаписатьНачалоЭлемента("contractIdentificator");
			Запись.ЗаписатьАтрибут("date", Формат(Акт.Договор.ДатаДоговора, "ДФ=yyyy-MM-dd"));
			Запись.ЗаписатьАтрибут("number", Строка(Акт.Договор.НомерДоговора));
			Запись.ЗаписатьКонецЭлемента();
			
			// Доп соглашение к договору
			//Запись.ЗаписатьНачалоЭлемента("supplementaryAgreementIdentificator");
			//Запись.ЗаписатьАтрибут("date", Формат(ТекСтрока.Дата, "ДФ=yyyy-MM-dd"));
			//Запись.ЗаписатьАтрибут("number", Строка(ТекСтрока.Номер));
			//Запись.ЗаписатьКонецЭлемента();
			
			// Номер и дата акта выполненных работ 
			Запись.ЗаписатьНачалоЭлемента("acceptanceCertificateIdentificator");
			Запись.ЗаписатьАтрибут("date", Формат(Акт.Дата, "ДФ=yyyy-MM-dd"));
			Запись.ЗаписатьАтрибут("number", ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Акт.Номер, Акт.Организация.Префикс));
			Запись.ЗаписатьКонецЭлемента();
			
			// Номер и дата счета на оплату 
			Запись.ЗаписатьНачалоЭлемента("proformaInvoiceIdentificator");
			Запись.ЗаписатьАтрибут("date", Формат(Акт.Дата, "ДФ=yyyy-MM-dd"));
			Запись.ЗаписатьАтрибут("number", ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Акт.Номер, Акт.Организация.Префикс));
			Запись.ЗаписатьКонецЭлемента();
			
			// Номер и дата счета-фактуры
			Запись.ЗаписатьНачалоЭлемента("invoiceIdentificator");
			Запись.ЗаписатьАтрибут("date", Формат(Акт.Дата, "ДФ=yyyy-MM-dd"));
			Запись.ЗаписатьАтрибут("number", ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Акт.Номер, Акт.Организация.Префикс));
			Запись.ЗаписатьКонецЭлемента();
			
			// Условия оплаты. Варианты: Prepaid(Предоплата), Postpaid(Постоплата)
			Запись.ЗаписатьНачалоЭлемента("termsOfPayment");
				Запись.ЗаписатьНачалоЭлемента("providedServicePaymentType");
					Запись.ЗаписатьТекст(?(Акт.Договор.ПрограммаСтрахования.ВидДоговора = Перечисления.ВидыСтраховыхДоговоров.Предоплата, "Prepaid", "Postpaid"));
				Запись.ЗаписатьКонецЭлемента();
			Запись.ЗаписатьКонецЭлемента();

            Запись.ЗаписатьНачалоЭлемента("insuranceCompany");
			
				Запись.ЗаписатьНачалоЭлемента("mediId");
			    Запись.ЗаписатьТекст(mediIdСК);
				Запись.ЗаписатьКонецЭлемента();
				
				Запись.ЗаписатьНачалоЭлемента("organization");
				
					Запись.ЗаписатьНачалоЭлемента("name");
			    	Запись.ЗаписатьТекст(Акт.Контрагент.Наименование);
					Запись.ЗаписатьКонецЭлемента();

					Запись.ЗаписатьНачалоЭлемента("inn");
			    	Запись.ЗаписатьТекст(Акт.Контрагент.ИНН);
					Запись.ЗаписатьКонецЭлемента();

					Запись.ЗаписатьНачалоЭлемента("kpp");
			    	Запись.ЗаписатьТекст(Акт.Контрагент.КПП);
					Запись.ЗаписатьКонецЭлемента();

				Запись.ЗаписатьКонецЭлемента();
				
				МассивАдресов =  Акт.Контрагент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес));
				Если МассивАдресов.Количество() > 0 Тогда
				
					ДанныеАдреса = УправлениеКонтактнойИнформациейСлужебный.JSONВКонтактнуюИнформациюПоПолям(МассивАдресов[0].Значение, Перечисления.ТипыКонтактнойИнформации.Адрес);
				
					Если НЕ ДанныеАдреса.addressType = "ВСвободнойФорме" Тогда
						
						Запись.ЗаписатьНачалоЭлемента("russianAddress");
						
							Если ЗначениеЗаполнено(ДанныеАдреса.ZIPcode) Тогда
								Запись.ЗаписатьНачалоЭлемента("postalCode");
								Запись.ЗаписатьТекст(ДанныеАдреса.ZIPcode);
								Запись.ЗаписатьКонецЭлемента();   
							КонецЕсли;	
								
							//Запись.ЗаписатьНачалоЭлемента("regionISOCode");
							//Запись.ЗаписатьТекст(ДанныеАдреса);
							//Запись.ЗаписатьКонецЭлемента();   
							
							Если ЗначениеЗаполнено(ДанныеАдреса.district) Тогда
  								Запись.ЗаписатьНачалоЭлемента("district");
								Запись.ЗаписатьТекст(ДанныеАдреса.district);
								Запись.ЗаписатьКонецЭлемента();   
							КонецЕсли;	
							
							Город = ДанныеАдреса.city;
							Если ДанныеАдреса.area = "Москва" Тогда
								Город = "Москва";
							ИначеЕсли ДанныеАдреса.area = "Санкт-Петербург" Тогда
								Город = "Санкт-Петербург";
							ИначеЕсли ДанныеАдреса.area = "Севастополь" Тогда
								Город = "Севастополь";
							ИначеЕсли ДанныеАдреса.area = "Байконур" Тогда
								Город = "Байконур";
							КонецЕсли;	
							Если Город <> "" Тогда 
								Запись.ЗаписатьНачалоЭлемента("city");
								Запись.ЗаписатьТекст(Город);
								Запись.ЗаписатьКонецЭлемента();
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ДанныеАдреса.settlement) Тогда
								Запись.ЗаписатьНачалоЭлемента("settlement");
								Запись.ЗаписатьТекст(ДанныеАдреса.settlement);
								Запись.ЗаписатьКонецЭлемента();   
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ДанныеАдреса.street) Тогда
								Запись.ЗаписатьНачалоЭлемента("street");
								Запись.ЗаписатьТекст(ДанныеАдреса.street);
								Запись.ЗаписатьКонецЭлемента();   
                            КонецЕсли;
							
							Если ЗначениеЗаполнено(ДанныеАдреса.houseNumber) Тогда
								Запись.ЗаписатьНачалоЭлемента("house");
								Запись.ЗаписатьТекст(ДанныеАдреса.houseNumber);
								Запись.ЗаписатьКонецЭлемента();   
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ДанныеАдреса.buildings) И ДанныеАдреса.buildings.Количество() > 0 Тогда
								Запись.ЗаписатьНачалоЭлемента("building");
								Запись.ЗаписатьТекст(ДанныеАдреса.buildings[0].number);
								Запись.ЗаписатьКонецЭлемента(); 
							КонецЕсли;
						
							//Запись.ЗаписатьНачалоЭлемента("office");
							//Запись.ЗаписатьТекст(ДанныеАдреса);
							//Запись.ЗаписатьКонецЭлемента();   
							
							Если ЗначениеЗаполнено(ДанныеАдреса.value) Тогда
								Запись.ЗаписатьНачалоЭлемента("fullAddress");
								Запись.ЗаписатьТекст(ДанныеАдреса.value);
								Запись.ЗаписатьКонецЭлемента();
							КонецЕсли;
							
						Запись.ЗаписатьКонецЭлемента(); 
