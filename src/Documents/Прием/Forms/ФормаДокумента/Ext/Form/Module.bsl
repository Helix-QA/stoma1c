// Процедура, выполняет формирование меню областей
//
Процедура СформироватьМенюОбластей(ЗубнаяФормулаSVG)
	
	МенюДесна = "";
	МенюКорень = "";
	МенюПоверхность = "";
	МенюКанал = "";
	МенюКоронкаЗуб = "";
	МенюКоронкаПротез = "";	
	МенюКость = "";
	МенюШтифт = "";
	МенюАбатмент = "";
	МенюКоронкаПротез = "";
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	СостояниеЗубнойФормулы.Цвет,
	                      |	СостояниеЗубнойФормулы.ОбластьЗубнойФормулы КАК ОбластьЗубнойФормулы,
	                      |	СостояниеЗубнойФормулы.Наименование КАК Наименование,
	                      |	СостояниеЗубнойФормулы.Ссылка
	                      |ИЗ
	                      |	Справочник.СостояниеЗубнойФормулы КАК СостояниеЗубнойФормулы
	                      |ГДЕ
	                      |	НЕ СостояниеЗубнойФормулы.ПометкаУдаления
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Наименование
	                      |ИТОГИ ПО
	                      |	ОбластьЗубнойФормулы");
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		ВыборкаСтроки = Выборка.Выбрать();
		Пока ВыборкаСтроки.Следующий() Цикл
			Если Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.Кость Тогда
				МенюКость = МенюКость+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.Десна Тогда
				МенюДесна = МенюДесна+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;													
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.КоронкаЗуб Тогда
				МенюКоронкаЗуб = МенюКоронкаЗуб+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.Корень1 Тогда
				МенюКорень = МенюКорень+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.Канал1 Тогда
				МенюКанал = МенюКанал+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.ПоверхностьЦентр Тогда
				МенюПоверхность = МенюПоверхность+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.Штифт Тогда
				МенюШтифт = МенюШтифт+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.Абатмент Тогда
				МенюАбатмент = МенюАбатмент+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			ИначеЕсли Выборка.ОбластьЗубнойФормулы = Перечисления.ОбластиЗубнойФормулы.КоронкаПротез Тогда
				МенюКоронкаПротез = МенюКоронкаПротез+"|"+ВыборкаСтроки.Наименование+"#"+ВыборкаСтроки.Ссылка.УникальныйИдентификатор()+"|"+ВыборкаСтроки.Цвет;				
			КонецЕсли;	
		КонецЦикла;
	КонецЦикла;	
	Если ЗначениеЗаполнено(МенюКость) Тогда		
		МенюКость = "var Kost_menu = 'Не выбрано#null|white"+ МенюКость + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Kost_menu", МенюКость); 
	КонецЕсли;	
	Если ЗначениеЗаполнено(МенюДесна) Тогда		
		МенюДесна = "var Desna_menu ='Не выбрано#null|white"+ МенюДесна + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Desna_menu", МенюДесна); 
	КонецЕсли;
	Если ЗначениеЗаполнено(МенюКоронкаЗуб) Тогда		
		МенюКоронкаЗуб = "var KoronkaZub_menu ='Не выбрано#null|white"+ МенюКоронкаЗуб + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var KoronkaZub_menu", МенюКоронкаЗуб); 
	КонецЕсли;
	Если ЗначениеЗаполнено(МенюКорень) Тогда		
		МенюКорень = "var Koren_menu ='Не выбрано #null|white"+ МенюКорень + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Koren_menu", МенюКорень); 
	КонецЕсли;
    Если ЗначениеЗаполнено(МенюКанал) Тогда		
		МенюКанал = "var Kanal_menu ='Не выбрано#null|white"+ МенюКанал + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Kanal_menu", МенюКанал); 
	КонецЕсли;
	Если ЗначениеЗаполнено(МенюПоверхность) Тогда		
		МенюПоверхность = "var Poverhn_menu ='Не выбрано#null|white"+ МенюПоверхность + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Poverhn_menu", МенюПоверхность); 
	КонецЕсли;
    Если ЗначениеЗаполнено(МенюШтифт) Тогда		
		МенюШтифт = "var Shtift_menu ='Не выбрано#null|white"+ МенюШтифт + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Shtift_menu", МенюШтифт); 
	КонецЕсли;
    Если ЗначениеЗаполнено(МенюАбатмент) Тогда		
		МенюАбатмент = "var Abatment_menu ='Не выбрано#null|white"+ МенюАбатмент + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Abatment_menu", МенюАбатмент); 
	КонецЕсли;
    Если ЗначениеЗаполнено(МенюКоронкаПротез) Тогда		
		МенюКоронкаПротез = "var Protez_menu ='Не выбрано#null|white"+ МенюКоронкаПротез + "'";
		ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var Protez_menu", МенюКоронкаПротез); 
