&НаСервере
// Процедура - Применить механизм фильтрации данных.
//
// Параметры:
//  ДанныеЭлементаФильтрации - 	 - 
//
Процедура ПрименитьМеханизмФильтрацииДанных(ДанныеЭлементаФильтрации) Экспорт
	
	МассивСтрокОбрабатываемыхФильтров = ТаблицаФильтров.НайтиСтроки(Новый Структура("Применен", Ложь));
	Для Каждого СтрокаФильтра ИЗ МассивСтрокОбрабатываемыхФильтров Цикл
		УправлениеИнтерфейсамиСервер.ОбновитьГруппуАктивированныхЗначенийФильтра(ЭтаФорма, СтрокаФильтра);
		Если СтрокаФильтра.ИмяГруппыТипФильтра = "Фильтр_Статус" Тогда 
			Если УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус").НайтиПоЗначению("Просрочена") <> Неопределено Тогда
				Если ЭтотОбъект.РежимОтображенияФормы = 0 Тогда
					ПериодОтбора.ДатаНачала    	= Дата(01,01,0001);
					ПериодОтбора.ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;
					ВыбранныйПериод 			= 4;
					УстановитьСвойстваОтображенияЭлементов();
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	ОбновитьДанныеДляОтображения(Ложь,,, Истина);	
	АктуализироватьДанныеСпискаСогласноОтборов();	
	ЭтаФорма.ТекущийЭлемент = Элементы.Список;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик нажатия элемента фильтрации данных.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОбработчикНажатияЭлементаФильтрацииДанных(Команда, ВыбранноеЗначение, СтандартнаяОбработка) Экспорт
	
	МассивИмен = СтрРазделить(Команда.Имя,"_");
	
	Если МассивИмен.Количество() <> 0 Тогда 
		
		Если МассивИмен[0] = "Удалить" Тогда
			
			РезультатОбновления = УправлениеИнтерфейсамиКлиент.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, Команда.Имя, , ВыбранноеЗначение);
			Если РезультатОбновления.Свойство("ДействиеЭлемента") И РезультатОбновления.ДействиеЭлемента = "ОбработкаВыбора" Тогда 
				Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда 
					СтандартнаяОбработка = Ложь;
					// ВыбранноеЗначение = Неопределено;
					// ЭлементФормы.ОбновитьТекстРедактирования(); 			
				КонецЕсли;
			КонецЕсли;
			
		Иначе
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("Отбор"				, ПараметрыВыбранныхФильтров(Новый Структура));
			ПараметрыФормы.Вставить("ИмяКоманды"		, Команда.Имя);
			ПараметрыФормы.Вставить("ВыбранноеЗначение" , ВыбранноеЗначение);
			
			ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаФильтры",
						 ПараметрыФормы,,,,,
						 Новый ОписаниеОповещения("ОткрытиеФильтровЗавершение", ЭтотОбъект),
						 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Данные выбранных фильтров.
//
Функция ПараметрыВыбранныхФильтров(ПараметрыОтбора)
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Если Строка.КоличествоАктивированныхЗначений > 0 Тогда
			
			МассивДанных = ПолучениеЭлементовОтбора(Новый Массив, Строка.СписокЗначений, Строка.Наименование);
			
			Если Строка.Наименование = "Фильтр_Статус" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовЗадач"			   				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовЗадач_ВариантОтбора"			, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_ВидВзаимодействия" Тогда
				ПараметрыОтбора.Вставить("МассивВидовВзаимодействия"					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВидовВзаимодействия_ВариантОтбора"		, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ВидСделки" Тогда
				ПараметрыОтбора.Вставить("МассивВидовСделок"			  				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВидовСделок_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Этап" Тогда
				ПараметрыОтбора.Вставить("МассивЭтапов"			     					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивЭтапов_ВариантОтбора"					, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Контрагент" Тогда
				ПараметрыОтбора.Вставить("МассивКонтрагентов"							, МассивДанных);
				ПараметрыОтбора.Вставить("МассивКонтрагентов_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_СтатусКлиента" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовКлиентов"			 		 	, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовКлиентов_ВариантОтбора"			, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_СтруктурнаяЕдиница" Тогда
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц"						, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц_ВариантОтбора"		, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Сделка" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияСделок"					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияСделок_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПометкаУдаленияЗадачи" Тогда
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления"				, МассивДанных);
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Исполнитель" Тогда
				ПараметрыОтбора.Вставить("МассивИсполнителей"			   				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивИсполнителей_ВариантОтбора"				, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_КтоВыполнил" Тогда
				ПараметрыОтбора.Вставить("МассивКтоВыполнил"							, МассивДанных);
				ПараметрыОтбора.Вставить("МассивКтоВыполнил_ВариантОтбора"				, Строка.ВариантОтбора);	
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ПараметрыОтбора, Новый УникальныйИдентификатор);
	
КонецФункции

&НаСервереБезКонтекста
// Функция - ПолучениеЭлементовОтбора
Функция ПолучениеЭлементовОтбора(Массив, СписокЗначений, НаименованиеФильтра)
	
	Если СписокЗначений.Количество() > 0 Тогда
		Для каждого Значение из СписокЗначений Цикл
			Если Значение.Значение.Выбран = Истина Тогда
				Массив.Добавить(Значение.Значение.ЗначениеФильтра);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Массив;
	
КонецФункции

&НаКлиенте
// Процедура - ОткрытиеФильтровЗавершение.
//
Процедура ОткрытиеФильтровЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОткрытиеФильтровНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
// Процедура - ОткрытиеФильтровНаСервере.
//
Процедура ОткрытиеФильтровНаСервере(Результат)
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ПараметрыОтбора = ПолучитьИзВременногоХранилища(Результат);
		ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора, Истина);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОчиститьФильтры = Ложь)
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Строка.Инициализирован = Ложь;
	КонецЦикла;
	
	МассивИменОчищаемыхФильтров = Новый Массив();
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВидВзаимодействия");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВидСделки");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Этап");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Контрагент");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтатусКлиента");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Сделка"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияЗадачи"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Исполнитель");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_КтоВыполнил"); 
	
	УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);

	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов();	
	
	// Отбор статус.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовЗадач");	
	ОбновитьДинамическоеМенюФильтрации_Статус(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовЗадач_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовЗадач_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусовЗадач, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор видов взаимодействия.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовВзаимодействия");	
	ОбновитьДинамическоеМенюФильтрации_ВидВзаимодействия(РезультатПакетногоЗапроса[2].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВидовВзаимодействия_ВариантОтбора"), ПараметрыОтбора.МассивВидовВзаимодействия_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидВзаимодействия", ПараметрыОтбора.МассивВидовВзаимодействия, Истина,,, ВариантОтбора);		
	КонецЕсли;
	
	// Отбор вид сделки.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовСделок");
	ОбновитьДинамическоеМенюФильтрации_ВидСделки(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВидовСделок_ВариантОтбора"), ПараметрыОтбора.МассивВидовСделок_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок, Истина,,, ВариантОтбора);		
	КонецЕсли;

	// Отбор этап.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивЭтапов");
	ОбновитьДинамическоеМенюФильтрации_Этап(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивЭтапов_ВариантОтбора"), ПараметрыОтбора.МассивЭтапов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов, Истина,,, ВариантОтбора);	
	КонецЕсли;	
	
	// Отбор по контрагентам.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКонтрагентов");
	ОбновитьДинамическоеМенюФильтрации_Контрагент(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКонтрагентов_ВариантОтбора"), ПараметрыОтбора.МассивКонтрагентов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Контрагент", ПараметрыОтбора.МассивКонтрагентов, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор статус клиента
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовКлиентов");	
	ОбновитьДинамическоеМенюФильтрации_СтатусКлиента(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовКлиентов_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовКлиентов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтатусКлиента", ПараметрыОтбора.МассивСтатусовКлиентов, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор СЕ.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц");
	Если УстановитьОтбор И НЕ ЗначениеЗаполнено(ПараметрыОтбора.МассивСтруктурныхЕдиниц) Тогда	
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[6].Выгрузить(), УстановитьОтбор);
	Иначе 
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[5].Выгрузить(), УстановитьОтбор);
	КонецЕсли;
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц_ВариантОтбора"), ПараметрыОтбора.МассивСтруктурныхЕдиниц_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина,,, ВариантОтбора);	
	КонецЕсли;

	// Отбор итересов.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок");
	ОбновитьДинамическоеМенюФильтрации_Сделка(,УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовНаличияСделок_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Сделка", ПараметрыОтбора.МассивСтатусовНаличияСделок, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор пометка удаления сделки.         
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления"); 
	ОбновитьДинамическоеМенюФильтрации_ПометкаУдаленияЗадачи(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления_ВариантОтбора"), ПараметрыОтбора.СписокСтатусовПометокУдаления_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияЗадачи", ПараметрыОтбора.СписокСтатусовПометокУдаления, Истина,,, ВариантОтбора);				
	КонецЕсли;
	
	// Отбор исполнителей.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивИсполнителей"); 
	ОбновитьДинамическоеМенюФильтрации_Исполнитель(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивИсполнителей_ВариантОтбора"), ПараметрыОтбора.МассивИсполнителей_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Исполнитель", ПараметрыОтбора.МассивИсполнителей, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;	
	
	// Отбор исполнителей.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКтоВыполнил"); 
	ОбновитьДинамическоеМенюФильтрации_КтоВыполнил(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКтоВыполнил_ВариантОтбора"), ПараметрыОтбора.МассивКтоВыполнил_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КтоВыполнил", ПараметрыОтбора.МассивКтоВыполнил, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;
	
	Если ЭтаФорма.РежимОтображенияФормы = 0 Тогда 		
		АктуализироватьДанныеСпискаСогласноОтборов();
	ИначеЕсли ЭтаФорма.РежимОтображенияФормы = 1 Тогда
		СтруктураОтборов = ПолучитьСтруктуруЗначенийОтбора();		
		ОбновитьПланировщик(СтруктураОтборов);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить свойства разделов фильтра.
//
// Параметры:
//  АктуализироватьФлаги - 	 - 
//
Процедура ОбновитьСвойстваРазделовФильтра(АктуализироватьФлаги = Ложь, ИмяСтраницыЗначенийФильтра = Неопределено) Экспорт
	
	Если ИмяСтраницыЗначенийФильтра <> Неопределено Тогда 
		Элементы.СтраницыЗначенийФильтров.ТекущаяСтраница = Элементы[ИмяСтраницыЗначенийФильтра];
	КонецЕсли;		
	УправлениеИнтерфейсамиСервер.ОбновитьСвойстваРазделовФильтра(ЭтаФорма, АктуализироватьФлаги);
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить группу значений фильтра.
//
// Параметры:
//  ИдентификаторСтрокиФильтра	 - 	 - 
//
Процедура ОбновитьГруппуЗначенийФильтра(ИдентификаторСтрокиФильтра, ИнициализироватьВыбранноеЗначение = Ложь, ВыбранноеЗначение = Неопределено) Экспорт
	
	СтрокаФильтра = ТаблицаФильтров.НайтиПоИдентификатору(ИдентификаторСтрокиФильтра);
	УправлениеИнтерфейсамиСервер.ОбновитьГруппуЗначенийФильтра(ЭтаФорма, СтрокаФильтра, ИнициализироватьВыбранноеЗначение, ВыбранноеЗначение);
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить свойства элемента значения.
//
// Параметры:
//  ДанныеЭлементаФильтрации - 	 - 
//
Процедура ОбновитьСвойстваЭлементаЗначения(ДанныеЭлементаФильтрации) Экспорт
	
	УправлениеИнтерфейсамиСервер.ОбновитьСвойстваЭлементаЗначения(ЭтаФорма, , , ДанныеЭлементаФильтрации);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор стандартного периода.
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборСтандартногоПериода(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НЕ РезультатВыбора = Неопределено И НЕ ДополнительныеПараметры = Неопределено Тогда
		ЭлементВариантСтандартногоПериода = ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы].НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторФильтра).СписокЗначений[0].Значение.СписокСтандартныхПериодов.НайтиПоЗначению(РезультатВыбора.Значение);
		Если НЕ ЭлементВариантСтандартногоПериода = Неопределено Тогда
			ДополнительныеПараметры.Вставить("ИдентификаторЗначения", ЭлементВариантСтандартногоПериода.ПолучитьИдентификатор());
			ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы].НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторФильтра).СписокЗначений[0].Значение.СписокСтандартныхПериодов.ЗаполнитьПометки(Ложь);
			ЭлементВариантСтандартногоПериода.Пометка = Истина;
			РезультатОбновления = УправлениеИнтерфейсамиКлиент.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, "УстановитьСтандартныйПериод_ЗначениеФильтра_Идентификатор_" + ДополнительныеПараметры.ИдентификаторФильтра, ДополнительныеПараметры);
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбновитьДинамическоеМеню

&НаСервере
// Процедура, получить значения отборов динамических списков.
//
Процедура ПолучитьЗначенияОтборов()
		
	СтруктураОтборов = ПолучитьСтруктуруЗначенийОтбора();
	
	Если РежимОтображенияФормы = 0 Тогда 		
		АктуализироватьДанныеСпискаСогласноОтборов();
		
	ИначеЕсли РежимОтображенияФормы = 1 Тогда
		ОбновитьПланировщик(СтруктураОтборов);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить все отборы формы
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//
Процедура ОбновитьВсеОтборыФормы(ПараметрыОтбора)
	
	МассивИменМеню = Новый Массив();
	МассивИменМеню.Добавить("МенюОтборСтатусЗадачи");
	МассивИменМеню.Добавить("МенюОтборВидВзаимодействия");
	МассивИменМеню.Добавить("МенюОтборЭтап");
	МассивИменМеню.Добавить("МенюОтборИсполнитель");
	МассивИменМеню.Добавить("МенюОтборКтоВыполнил");
	МассивИменМеню.Добавить("МенюОтборКонтрагенты");
	МассивИменМеню.Добавить("МенюОтборСделки");
	
	УправлениеИнтерфейсамиСервер.СнятьВыборВДинамическомМенюФормы(ЭтаФорма, МассивИменМеню);
	Если ТипЗнч(ПараметрыОтбора) = Тип("Структура") И ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборИсполнитель", ПараметрыОтбора.МассивМенеджеров, Истина);
	КонецЕсли;	
	Если ТипЗнч(ПараметрыОтбора) = Тип("Структура") И ПараметрыОтбора.Свойство("МассивСтатусовЗадач") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборСтатусЗадачи", ПараметрыОтбора.МассивСтатусовЗадач, Истина);
	КонецЕсли;		
	Если ПараметрыОтбора <> Неопределено И ТипЗнч(ПараметрыОтбора) = Тип("Структура") И (ПараметрыОтбора.Свойство("ОтборПериодТип") ИЛИ ПараметрыОтбора.Свойство("МассивСтатусовЗадач")) Тогда 
		Если УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСтатусЗадачи").Найти("Просрочена") <> Неопределено Тогда 
			Если ЭтаФорма.РежимОтображенияФормы = 1 Тогда
				РежимОтображенияФормы 		= 0;
				ПериодОтбора.ДатаНачала    	= Дата(01, 01, 0001);
				ПериодОтбора.ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;
				ВыбранныйПериод 			= 4;
				УстановтьРежимОтображения(Ложь);
				// ВыбранныйПериод 			= 0;
				// ПериодОтбора.Вариант		= ВариантСтандартногоПериода.Сегодня;
			Иначе 	
				ПериодОтбора.ДатаНачала    	= Дата(01, 01, 0001);
				ПериодОтбора.ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;
				ВыбранныйПериод 			= 4;
			КонецЕсли;
			УстановитьСвойстваОтображенияЭлементов();
		ИначеЕсли ПараметрыОтбора.Свойство("ОтборПериодТип") И ПараметрыОтбора.Свойство("ОтборПериодЗначение") Тогда 
			Если ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.День Тогда 
				ВыбранныйПериод = 0;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
				ВыбранныйПериод = 2;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда
				ВыбранныйПериод = 3;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Час Тогда
				ВыбранныйПериод = 4;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;
			КонецЕсли;
		КонецЕсли;
		ОбновитьСписок = Истина;		
		// СформироватьПериодОтбора();
		УстановитьСвойстваОтображенияЭлементов();		
	КонецЕсли;
	ПолучитьЗначенияОтборов();
	
КонецПроцедуры

#КонецОбласти

#Область ВсплывающаяГруппаИзменить

&НаСервере
// Процедура, заполнение данных в ТаблицаДействия.
//
Процедура ЗаполнениеТаблицыДействия(АдресВХ)
	
	ТаблицаДействия.Очистить();
	
	ДанныеДействия = ПолучитьИзВременногоХранилища(АдресВХ);
	
	Для каждого СтрокаТЗ из ДанныеДействия Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаДействия.Добавить(), СтрокаТЗ) 
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция, получение данных из ТаблицаДействия.
//
Функция ПолучениеТаблицыДействия()
		
	Возврат ПоместитьВоВременноеХранилище(ТаблицаДействия.Выгрузить(), Новый УникальныйИдентификатор); 
	
КонецФункции

&НаСервере
// Процедура, обработчик события команды на сервере "Применить".
//
Процедура ПрименитьНаСервере(ДопПараметры)
		
	Если ЗначениеЗаполнено(ДопПараметры) Тогда
		
		ТЗДинамическогоСписка = Новый ТаблицаЗначений();
		ТЗДинамическогоСписка.Колонки.Добавить("Ссылка");
		ТЗДинамическогоСписка.Колонки.Добавить("Контрагент");
		ТЗДинамическогоСписка.Колонки.Добавить("Сделка");
		
		ВыделенныеСтроки = Элементы.Список.ВыделенныеСтроки;
		Для Каждого ЭлементМассива Из ВыделенныеСтроки Цикл
			
			НоваяСтрока = ТЗДинамическогоСписка.Добавить();
			НоваяСтрока.Ссылка 		= ЭлементМассива;
			НоваяСтрока.Контрагент 	= ЭлементМассива.Контрагент;
			НоваяСтрока.Сделка 		= ЭлементМассива.Сделка;
			
		КонецЦикла;
		
	Иначе
		ТЗДинамическогоСписка = ПолучитьТаблицуЗначенийДинамическогоСписка();
	КонецЕсли;

	УстановитьФокусЭлементаСервер();
	
	Если ЭтотОбъект.Действие = "Исполнитель" Тогда	
		
		ИсполнителиРаспределитьВПропорции(ТЗДинамическогоСписка);
		
	ИначеЕсли ЭтотОбъект.Действие = "ДатаВыполнения" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				ОбъектЗадача 				  		= СтрокаТЗ.Ссылка.ПолучитьОбъект();
				ОбъектЗадача.ДатаИсполнения   		= ЭтотОбъект.ЗначениеДействия;
				ОбъектЗадача.Наименование	  		= ОбъектЗадача.ЗадачаТема + " (" + Строка(ОбъектЗадача.ВидВзаимодействияСправочник) + ")";
				ОбъектЗадача.ИсполнительФактический = ПараметрыСеанса.ТекущийСотрудник;
				ОбъектЗадача.Выполнена				= Истина;
				
				Если ОбъектЗадача.ПроверитьЗаполнение() Тогда
					
					Попытка
						ОбъектЗадача.Записать();	
					Исключение
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось записать задачу, по причине:';en='Succeeded writedown task for the reason:'") + ОписаниеОшибки());
					КонецПопытки;
					
				КонецЕсли;	
			КонецЦикла;
			
		Иначе	
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Выберите дату';en='Select date'"));
			Возврат;		
		КонецЕсли;
		
	ИначеЕсли ЭтотОбъект.Действие = "ДатаНазначено" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			КолВоНеобработанных = 0;	
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				Если СтрокаТЗ.Ссылка.Выполнена Тогда		
					КолВоНеобработанных = КолВоНеобработанных + 1;			
				Иначе
					
					ОбъектЗадача 				  		= СтрокаТЗ.Ссылка.ПолучитьОбъект();
					ОбъектЗадача.ЗадачаНазначеннаяДата	= ЭтотОбъект.ЗначениеДействия;
					
					Если ОбъектЗадача.ПроверитьЗаполнение() Тогда
						
						Попытка
							ОбъектЗадача.Записать();	
						Исключение
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось записать задачу, по причине:';en='Succeeded writedown task for the reason:'") + ОписаниеОшибки());
						КонецПопытки;
						
					КонецЕсли;				
				КонецЕсли;		
			КонецЦикла;
			
			Если КолВоНеобработанных > 0 Тогда
				
				ПредставлениеКолВаЗадач = СтрокаСЧислом(НСтр("ru = ';%1 задачу;;%1 задачи; %1 задач;'; en = ';%1 task;;;; %1 tasks'"), КолВоНеобработанных, ВидЧисловогоЗначения.Количественное, НСтр("ru='L=ru'; en='L=en'"));			
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ПредставлениеКолВаЗадач + НСтр("ru=' не удалось обработать т.к. у выполненных задач менять дату запрещено.';en='not succeeded process since completed tasks change the date prohibited.'"));
				
			КонецЕсли;
			
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Выберите дату';en='Select date'"));
			Возврат;
		КонецЕсли;
		
	ИначеЕсли ЭтотОбъект.Действие = "ВидВзаимодействия" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				ОбъектЗадача = СтрокаТЗ.Ссылка.ПолучитьОбъект();
				ОбъектЗадача.ВидВзаимодействияСправочник = ЭтотОбъект.ЗначениеДействия;
				ОбъектЗадача.ВидВзаимодействия 			 = ЭтотОбъект.ЗначениеДействия.ВидВзаимодействия;
				ОбъектЗадача.Записать();
				
			КонецЦикла;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Выберите значение';en='Select value'"));
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьВсеОтборыФормы(Неопределено);
	// ПолучитьПервоначальноеКоличествоКлиентов();
	
КонецПроцедуры

&НаСервере
// Процедура, Распределяет мененеджеров в пропорции.
//
Процедура ИсполнителиРаспределитьВПропорции(Знач ТЗДинамическогоСписка)
	
	КоличествоСотрудников = ЭтотОбъект.ТаблицаДействия.Количество();	
	Если КоличествоСотрудников <= 0 Тогда		
		Возврат;	
	КонецЕсли;
	
	ТипЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(3));
	
	ТЗСотрудников = ЭтотОбъект.ТаблицаДействия.Выгрузить();
	ТЗСотрудников.Колонки.Добавить("КоличествоЗадач"	, ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("ПроцентТекущий"		, ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("Дельта"				, ТипЧисло);
	
	ТЗКонтрагентов = ТЗДинамическогоСписка.Скопировать(,"Контрагент");
	ТЗКонтрагентов.Свернуть("Контрагент");
	
	Для Каждого СтрокаТЗ Из ТЗКонтрагентов Цикл
		
		ПриоритетныйСотрудник = Неопределено;
		ПриоритетныйПроцент   = 0;
		
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			Если СтрокаСотрудников.Дельта >= ПриоритетныйПроцент Тогда
				
				ПриоритетныйСотрудник = СтрокаСотрудников.Сотрудник;
				ПриоритетныйПроцент   = СтрокаСотрудников.Дельта;
				
			КонецЕсли;
			
		КонецЦикла;
		
		МассивКонтрагентов = ТЗДинамическогоСписка.НайтиСтроки(Новый Структура("Контрагент", СтрокаТЗ.Контрагент));
		Если МассивКонтрагентов.Количество() > 0 Тогда
			Для Каждого СтрокаМассива Из МассивКонтрагентов Цикл
				
				ОбъектЗадача = СтрокаМассива.Ссылка.ПолучитьОбъект();
				ОбъектЗадача.Исполнитель = ПриоритетныйСотрудник;
				ОбъектЗадача.Записать();
								
			КонецЦикла;
			
			// Обновляем менеджера в сделке.
			Если ЭтотОбъект.ЗаменитьМенеджераВСделках Тогда
				
				ТЗСделокКлиента = ТЗДинамическогоСписка.Скопировать(Новый Структура("Контрагент", СтрокаТЗ.Контрагент),"Сделка");
				ТЗСделокКлиента.Свернуть("Сделка");
				
				Для Каждого СделкаТЗ Из ТЗСделокКлиента Цикл		
					Если ЗначениеЗаполнено(СделкаТЗ.Сделка) Тогда
						
						ОбъектСделка = СделкаТЗ.Сделка.ПолучитьОбъект();
						ОбъектСделка.Менеджер = ПриоритетныйСотрудник;
						ОбъектСделка.Записать();

					КонецЕсли;			
				КонецЦикла;					
			КонецЕсли;	
		КонецЕсли;
		
		СтрокаТЗСотрудников = ТЗСотрудников.Найти(ПриоритетныйСотрудник);
		
		Если СтрокаТЗСотрудников <> Неопределено Тогда
			
			СтрокаТЗСотрудников.КоличествоЗадач = СтрокаТЗСотрудников.КоличествоЗадач + 1;
			СтрокаТЗСотрудников.ПроцентТекущий 	= СтрокаТЗСотрудников.КоличествоЗадач/ТЗСотрудников.Итог("КоличествоЗадач")*100; 
			СтрокаТЗСотрудников.Дельта 		    = СтрокаТЗСотрудников.Пропорция - СтрокаТЗСотрудников.ПроцентТекущий;
			
		КонецЕсли;
		
		// Обновляем данные в таблице значений.
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			СтрокаСотрудников.ПроцентТекущий = СтрокаСотрудников.КоличествоЗадач/ТЗСотрудников.Итог("КоличествоЗадач")*100; 
			СтрокаСотрудников.Дельта 		 = СтрокаСотрудников.Пропорция - СтрокаСотрудников.ПроцентТекущий;
			
		КонецЦикла;
		
		// Обновляем менеджера в контрагенте.
		Если ЭтотОбъект.ЗаменитьМенеджераПоПродажамВКлиенте
			И ЗначениеЗаполнено(СтрокаТЗ.Контрагент)Тогда
			
			ОбъектКонтрагент = СтрокаТЗ.Контрагент.ПолучитьОбъект();
			ОбъектКонтрагент.Менеджер = ПриоритетныйСотрудник;
			ОбъектКонтрагент.Записать();	
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, УстановтьРежимОтображения.
//
Процедура УстановтьРежимОтображения(ОбновитьДанные = Истина)
	
	Если ЭтаФорма.РежимОтображенияФормы = 0 Тогда
		
		Элементы.ГруппаСписок.Видимость 		 	   = Истина;
		Элементы.СтраницаПланировщик.Видимость 	 	   = Ложь;   
		Элементы.ГруппаКоманднаяПанель.Видимость 	   = Истина;
		ОбновитьДанныеДляОтображения(Ложь,,,, ОбновитьДанные);
		
	ИначеЕсли ЭтаФорма.РежимОтображенияФормы = 1 Тогда
		
		Элементы.ГруппаСписок.Видимость 			   = Ложь;
		Элементы.СтраницаПланировщик.Видимость 		   = Истина;
		Элементы.ГруппаКоманднаяПанель.Видимость 	   = Ложь;
		СписокОтборСтатус = УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус");
		СтатусПросрочена = СписокОтборСтатус.НайтиПоЗначению("Просрочена");
		Если СтатусПросрочена <> Неопределено Тогда 
			СписокОтборСтатус.Удалить(СтатусПросрочена);
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", СписокОтборСтатус);		
		КонецЕсли;	
		ОбновитьДанныеДляОтображения(Истина,,, ОбновитьДанные);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет обновление планировщика
//
Процедура ОбновитьПланировщик(СтруктураОтборов)
	
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	// Для произвольного периода - ограничиваем период одним месяцем, если превышен.
	Если ВыбранныйПериод = 4 Тогда
		
		Если Не ЗначениеЗаполнено(ПериодОтбора.ДатаОкончания) И Не ЗначениеЗаполнено(ПериодОтбора.ДатаНачала) Тогда
			
			ПериодОтбора.ДатаНачала		 = НачалоМесяца(ТекущаяДатаСеанса());
			ПериодОтбора.ДатаОкончания	 = КонецМесяца(ТекущаяДатаСеанса());
			
			ВыбранныйПериод = 3;
			
		ИначеЕсли Не ЗначениеЗаполнено(ПериодОтбора.ДатаОкончания) Тогда
			
			ПериодОтбора.ДатаНачала		 = НачалоМесяца(ПериодОтбора.ДатаНачала);
			ПериодОтбора.ДатаОкончания	 = КонецМесяца(ПериодОтбора.ДатаНачала);
			
			ВыбранныйПериод = 3;
			
		ИначеЕсли Не ЗначениеЗаполнено(ПериодОтбора.ДатаНачала) Тогда
			
			ПериодОтбора.ДатаНачала		 = НачалоМесяца(ПериодОтбора.ДатаОкончания);
			ПериодОтбора.ДатаОкончания	 = КонецМесяца(ПериодОтбора.ДатаОкончания);
			
			ВыбранныйПериод = 3;
			
		ИначеЕсли (ПериодОтбора.ДатаОкончания - ПериодОтбора.ДатаНачала) > 3600 * 24 * 31 Тогда
			
			ПериодОтбора.ДатаНачала		 = НачалоМесяца(ПериодОтбора.ДатаОкончания);
			ПериодОтбора.ДатаОкончания	 = КонецМесяца(ПериодОтбора.ДатаОкончания);
			
			ВыбранныйПериод = 3;
			
		ИначеЕсли НачалоМесяца(ПериодОтбора.ДатаОкончания) = ПериодОтбора.ДатаНачала
			И ПериодОтбора.ДатаОкончания = КонецМесяца(ПериодОтбора.ДатаНачала) Тогда
			
			ВыбранныйПериод = 3;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Планировщик.ОтображатьПеренесенныеЗаголовки   			= Не ВыбранныйПериод = 3;
	Планировщик.КратностьПериодическогоВарианта   			= ?(ВыбранныйПериод = 3, 7, 1);	
	Планировщик.ШкалаВремени.Элементы[0].Видимость 			= Не ВыбранныйПериод = 3;			
	Планировщик.ШкалаВремени.Элементы[1].Видимость 			= ВыбранныйПериод = 3;
	Планировщик.ШкалаВремени.Положение            		    = ?(ВыбранныйПериод = 3, ПоложениеШкалыВремени.Верх, ПоложениеШкалыВремени.Лево);
	Планировщик.ОтображатьПеренесенныеЗаголовкиШкалыВремени = ВыбранныйПериод = 3;			
	Планировщик.ВыравниватьГраницыЭлементовПоШкалеВремени   = ВыбранныйПериод = 3;
	
	Планировщик.ТекущиеПериодыОтображения.Очистить();
	Планировщик.ИнтервалыФона.Очистить();
	Планировщик.Измерения.Очистить();
	Планировщик.Элементы.Очистить();
	Планировщик.ШкалаВремени.Элементы[0].Метки.Очистить();
	
	Если ВыбранныйПериод = 3 Тогда		
		
		СтруктПериода 	= РасширениеПланировщикаСервер.РасчитатьИнтервалВремениДляРежимаМесяц(ПериодОтбора.ДатаНачала, ПериодОтбора.ДатаОкончания);		
		ДатаНачала 		= СтруктПериода.Начало;
		ДатаОкончания 	= СтруктПериода.Конец;
		Планировщик.ТекущиеПериодыОтображения.Добавить(ДатаНачала, ДатаОкончания);                  		
		
	Иначе
		
		ДатаДень = ПериодОтбора.ДатаНачала;
		
		Если ВыбранныйПериод = 0 Тогда
			МассивПериодов = РасширениеПланировщикаСервер.РасчитатьИнтервалВремениДляРежимаДень(СтруктурнаяЕдиница, ДатаДень);
		ИначеЕсли ВыбранныйПериод = 1 Тогда
			МассивПериодов = РасширениеПланировщикаСервер.РасчитатьИнтервалВремениДляМногодневногоРежима(СтруктурнаяЕдиница, ДатаДень, 4);	
		ИначеЕсли ВыбранныйПериод = 2 Тогда
			МассивПериодов = РасширениеПланировщикаСервер.РасчитатьИнтервалВремениДляМногодневногоРежима(СтруктурнаяЕдиница, ДатаДень, 7);
		ИначеЕсли ВыбранныйПериод = 4 Тогда
			МассивПериодов = РасширениеПланировщикаСервер.РасчитатьИнтервалВремениДляМногодневногоРежима(СтруктурнаяЕдиница, ДатаДень);
		КонецЕсли;
		
		Для Каждого ЭлементМ Из МассивПериодов Цикл
			Планировщик.ТекущиеПериодыОтображения.Добавить(ЭлементМ.Начало, ЭлементМ.Конец);
		КонецЦикла;
		
		ДатаНачала    = МассивПериодов[0].Начало;
		ДатаОкончания = МассивПериодов[МассивПериодов.Количество() - 1].Конец;
		
		Пока ДатаДень < ПериодОтбора.ДатаОкончания Цикл
			
			ДопДатаНачала    = ДатаДень;
			ДопДатаОкончания = ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ДатаДень, Дата(0001,01,01,00,59,00)); 
			
			НоваяМетка = Планировщик.ШкалаВремени.Элементы[0].Метки.Добавить(ДатаДень);
			НоваяМетка.ЦветЛинии = Новый Цвет(164,164,164);
			НоваяМетка.Текст     = Нстр("ru = 'Весь день'; en = 'Entire day'");
			
			Планировщик.ТекущиеПериодыОтображения.Добавить(ДопДатаНачала, ДопДатаОкончания);				
			
			НовыйИнтервал = Планировщик.ИнтервалыФона.Добавить(ДопДатаНачала, ДопДатаОкончания);
			НовыйИнтервал.Цвет = WebЦвета.ЦианСветлый;
			
			ДатаДень = ДатаДень + 86400;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Планировщик.ЦветФона = WebЦвета.Белый;	
	ЗадатьЦветФонаВыходныхДней(Планировщик, ?(ВыбранныйПериод = 3, ДатаНачала, ПериодОтбора.ДатаНачала), ДатаОкончания);
	
	// Получим таблицу задач
	ТаблицаЗадачДляПланировщика	= ПолучитьТаблицуЗадачПланировщика(СтруктураОтборов);
	
	// Сформируем структуру вывода текста взависимости от настроек
	СтруктураОписанияЗадачи = СформироватьСтруктуруТекстаЭлемента(СписокНастроек);
	
	// Выведем задачи
	Для Каждого СтрокаТЧ Из ТаблицаЗадачДляПланировщика Цикл
		
		ВремяНачала    = СтрокаТЧ.ДатаРаботы;
		ВремяОкончания = ВремяНачала;
		
		ВесьДень = Ложь;		
		
		Если ВремяНачала = НачалоДня(ВремяНачала) И ВремяОкончания = НачалоДня(ВремяОкончания) Тогда			
			ВесьДень = Истина;
			Для Каждого СтрокаМ Из Планировщик.ШкалаВремени.Элементы[0].Метки Цикл
				Если НачалоДня(СтрокаМ.Дата) = ВремяНачала Тогда
					ВремяНачала    = СтрокаМ.Дата;
					ВремяОкончания = СтрокаМ.Дата;					 
				КонецЕсли;				
			КонецЦикла;			
		КонецЕсли;
		
		ВремяОкончания = ВремяОкончания + 3600;  		
		
		НовыйЭлемент           	= Планировщик.Элементы.Добавить(ВремяНачала, ВремяОкончания);			
		НовыйЭлемент.Значение  	= СтрокаТЧ.Значение;
		ОписанияЗадачи 			= СформироватьТекстЭлемента(СписокНастроек, СтрокаТЧ, ВесьДень, СтрокаТЧ.ВремяНачала, СтруктураОписанияЗадачи);
		НовыйЭлемент.Текст     	= ОписанияЗадачи.Текст;	
		НовыйЭлемент.Подсказка 	= ОписанияЗадачи.ТекстПодсказки;
		
		Если ЗначениеЗаполнено(СтрокаТЧ.ИндексКартинкиВзаимодействия) Тогда		
			НовыйЭлемент.Картинка = БиблиотекаКартинок["ВидВзаимодействия_" + СтрокаТЧ.ИндексКартинкиВзаимодействия];
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТЧ.Цвет) Тогда
			НовыйЭлемент.ЦветФона = WebЦвета[СтрокаТЧ.Цвет];
		КонецЕсли;
		
		Если ВыбранныйПериод = 0 Тогда
			СоответствиеЗначений = Новый Соответствие;
			СоответствиеЗначений.Вставить("Задачи", СтрокаТЧ.Статус);		
			НовыйЭлемент.ЗначенияИзмерений = Новый ФиксированноеСоответствие(СоответствиеЗначений);			
		КонецЕсли; 
		
	КонецЦикла;
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

&НаСервере
// Процедура - Сформировать период отбора
//
Процедура СформироватьПериодОтбора(СдвинутьВременнойИнтервал = Ложь, НаправлениеДвиженияВременногоИнтервала = "")
	
	Если СдвинутьВременнойИнтервал Тогда 
		Если НаправлениеДвиженияВременногоИнтервала = "Вперед" Тогда 
			Если ВыбранныйПериод = 0 Тогда
				ПериодОтбора.ДатаНачала 	= НачалоДня(ПериодОтбора.ДатаНачала + 60*60*24);
				ПериодОтбора.ДатаОкончания 	= КонецДня(ПериодОтбора.ДатаНачала);
			ИначеЕсли ВыбранныйПериод = 1 Тогда 
				ПериодОтбора.ДатаНачала 	= НачалоДня(ПериодОтбора.ДатаНачала + 60*60*24*4);
				ПериодОтбора.ДатаОкончания 	= КонецДня(ПериодОтбора.ДатаОкончания + 60*60*24*4);
			ИначеЕсли ВыбранныйПериод = 2 Тогда
				ПериодОтбора.ДатаНачала 	= НачалоНедели(ПериодОтбора.ДатаНачала + 60*60*24*7);
				ПериодОтбора.ДатаОкончания 	= КонецНедели(ПериодОтбора.ДатаНачала);
			ИначеЕсли ВыбранныйПериод = 3 Тогда
				ПериодОтбора.ДатаНачала 	= НачалоМесяца(ДобавитьМесяц(ПериодОтбора.ДатаНачала, 1));
				ПериодОтбора.ДатаОкончания 	= КонецМесяца(ПериодОтбора.ДатаНачала);
			ИначеЕсли ВыбранныйПериод = 4 Тогда
				ПериодВСекундах 			= ПериодОтбора.ДатаОкончания - ПериодОтбора.ДатаНачала;
				ПериодОтбора.ДатаНачала 	= ПериодОтбора.ДатаОкончания;
				ПериодОтбора.ДатаОкончания 	= ПериодОтбора.ДатаНачала + ПериодВСекундах;
			КонецЕсли;
		ИначеЕсли НаправлениеДвиженияВременногоИнтервала = "Назад" Тогда	
			Если ВыбранныйПериод = 0 Тогда
				ПериодОтбора.ДатаНачала = НачалоДня(ПериодОтбора.ДатаНачала - 60*60*24);
				ПериодОтбора.ДатаОкончания = КонецДня(ПериодОтбора.ДатаНачала);
			ИначеЕсли ВыбранныйПериод = 1 Тогда
				ПериодОтбора.ДатаНачала = НачалоДня(ПериодОтбора.ДатаНачала - 60*60*24*4);
				ПериодОтбора.ДатаОкончания = КонецДня(ПериодОтбора.ДатаОкончания - 60*60*24*4);				
			ИначеЕсли ВыбранныйПериод = 2 Тогда
				ПериодОтбора.ДатаНачала = НачалоНедели(ПериодОтбора.ДатаНачала - 60*60*24*7);
				ПериодОтбора.ДатаОкончания = КонецНедели(ПериодОтбора.ДатаНачала);
			ИначеЕсли ВыбранныйПериод = 3 Тогда 
				ПериодОтбора.ДатаНачала = НачалоМесяца(ДобавитьМесяц(ПериодОтбора.ДатаНачала, -1));
				ПериодОтбора.ДатаОкончания = КонецМесяца(ПериодОтбора.ДатаНачала);
			ИначеЕсли ВыбранныйПериод = 4 Тогда
				ПериодВСекундах 			= ПериодОтбора.ДатаОкончания - ПериодОтбора.ДатаНачала;
				ПериодОтбора.ДатаОкончания 	= ПериодОтбора.ДатаНачала;
				ПериодОтбора.ДатаНачала 	= ПериодОтбора.ДатаОкончания - ПериодВСекундах;				
			КонецЕсли;
		КонецЕсли;
	Иначе 	
		Если ВыбранныйПериод = 0 Тогда 
			ПериодОтбора.Вариант 		= ВариантСтандартногоПериода.Сегодня; 
		ИначеЕсли ВыбранныйПериод = 1 Тогда
			ПериодОтбора.Вариант 		= ВариантСтандартногоПериода.ПроизвольныйПериод;
			ПериодОтбора.ДатаНачала 	= НачалоДня(ТекущаяДатаСеанса());
			ПериодОтбора.ДатаОкончания 	= КонецДня(ПериодОтбора.ДатаНачала + 3*24*60*60);
		ИначеЕсли ВыбранныйПериод = 2 Тогда
			ПериодОтбора.Вариант 		= ВариантСтандартногоПериода.ЭтаНеделя;		
		ИначеЕсли ВыбранныйПериод = 3 Тогда
			ПериодОтбора.Вариант 		= ВариантСтандартногоПериода.ЭтотМесяц;
		ИначеЕсли ВыбранныйПериод = 4 Тогда
			// формируется в асинхронном вызове
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить данные для отображения
//
// Параметры:
//  СформироватьПериод	 - 	 - 
//
Процедура ОбновитьДанныеДляОтображения(Знач СформироватьПериод = Ложь, Знач СдвинутьВременнойИнтервал = Ложь, Знач НаправлениеДвиженияВременногоИнтервала = "", ОтобразитьНеРаспределенныхКлиентов = Ложь, ОбновитьДанные = Истина)
	
	Если СформироватьПериод Тогда 
		СформироватьПериодОтбора(СдвинутьВременнойИнтервал, НаправлениеДвиженияВременногоИнтервала);
	КонецЕсли;
	
	Если ОбновитьДанные Тогда 
		ПолучитьЗначенияОтборов();
	КонецЕсли;
	
	УстановитьСвойстваОтображенияЭлементов();
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, выполняет окрашивание области 
//
Процедура ЗадатьЦветФонаВыходныхДней(Планировщик, ДатаНачала, ДатаОкончания)
	
	ДатаДень = ДатаНачала;      
	Пока ДатаДень < ДатаОкончания Цикл					
		Если ДеньНедели(ДатаДень) = 6 ИЛИ ДеньНедели(ДатаДень) = 7 Тогда
			НовыйИнтервал = Планировщик.ИнтервалыФона.Добавить(НачалоДня(ДатаДень), КонецДня(ДатаДень));
			НовыйИнтервал.Цвет = WebЦвета.ТусклоРозовый;			
		КонецЕсли;                    			
		ДатаДень = ДатаДень + 86400;		
	КонецЦикла;   	
	
КонецПроцедуры

