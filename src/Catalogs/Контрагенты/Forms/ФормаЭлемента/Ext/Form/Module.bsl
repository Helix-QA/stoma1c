КонецПроцедуры // РедактироватьСоставСвойств()

&НаКлиенте
// Процедура, обработчик команды "ЦветМетки".
//
Процедура ЦветМетки(Команда)
	
	ДиалогЦвета = Новый ДиалогВыбораЦвета();
	
	#Если Не ВебКлиент Тогда
		ДиалогЦвета.Цвет = Элементы.УстановкаЦвет.ЦветФона;
	#КонецЕсли
	
	ДиалогЦвета.Показать(Новый ОписаниеОповещения("ЦветМеткиЗавершение", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура ЦветМеткиЗавершение(Цвет, ДополнительныеПараметры) Экспорт
	
	Если Цвет <> Неопределено Тогда
		ИзменитьЦветМетки(Цвет);
	КонецЕсли;

КонецПроцедуры

// Процедура - Редактировать состав свойств
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура РедактироватьСоставСвойств(Команда)
	
	УправлениеСвойствамиКлиент.РедактироватьСоставСвойств(ЭтаФорма, Объект.Ссылка);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, обновляет элементы дополнительных реквизитов.
//
Процедура ОбновитьДополнительныеРеквизиты()
	
	УправлениеСвойствами.ОбновитьЭлементыДополнительныхРеквизитов(ЭтаФорма, РеквизитФормыВЗначение("Объект"));
	
КонецПроцедуры // ОбновитьЭлементыДополнительныхРеквизитов()

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура НаименованиеПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.НаименованиеПолное) Тогда
		Объект.НаименованиеПолное = Объект.Наименование;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Объект.КраткоеНаименование) И Объект.ТипКонтрагента = ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.СтраховаяКомпания") Тогда
		Объект.КраткоеНаименование = Объект.Наименование;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ЮрФизЛицоПриИзменении(Элемент)
	
	  УстановитьВидимостьРеквизитов();
      ПроверитьИННиКППиОКПО(СтруктураДляПроверкиИННиКППиОКПО(ЭтаФорма, Истина, Истина,Истина), ЭтаФорма);
     	
КонецПроцедуры
 
&НаСервере
// Процедура, устанавливает видимость реквизитов формы.
//
// Параметры:
//  Нет.
//
Процедура УстановитьВидимостьРеквизитов()

	ЭтоУкраина = Константы.СтранаУчета.Получить() = Справочники.СтраныМира.НайтиПоНаименованию("УКРАИНА");
	
	Если Объект.ЮрФизЛицо = ЮрЛицо Тогда
		Элементы.ГруппаВводаКПП.Видимость = Истина;
		Элементы.ИНН.ПодсказкаВвода  	  = "10 цифр";
		Элементы.КодПоОКПО.ПодсказкаВвода = "8 цифр";
	Иначе
		Элементы.ГруппаВводаКПП.Видимость = Ложь;
		Объект  .КПП           			  = ""; 
		Если ЭтоУкраина Тогда
			Элементы.ИНН.ПодсказкаВвода  	  = "10 цифр";
			Элементы.КодПоОКПО.ПодсказкаВвода = "8 цифр"; 	
		Иначе		
			Элементы.ИНН.ПодсказкаВвода  	  = "12 цифр";
			Элементы.КодПоОКПО.ПодсказкаВвода = "10 цифр"; 
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры // УстановитьВидимостьРеквизитов()

&НаКлиенте
// Процедура - Коды классификаторов при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура КодыКлассификаторовПриИзменении(Элемент)
	
	Объект.Инн       = СокрЛП(Объект.Инн);
	Объект.КПП       = СокрЛП(Объект.КПП);	
	Объект.КодПоОКПО = СокрЛП(Объект.КодПоОКПО);

	ПроверкаИНН  = Элемент.Имя = "ИНН";
	ПроверкаКПП  = Элемент.Имя = "КПП";
	ПроверкаОКПО = Элемент.Имя = "КодПоОКПО";
	ПроверитьИННиКППиОКПО(СтруктураДляПроверкиИННиКППиОКПО(ЭтаФорма, ПроверкаИНН, ПроверкаКПП,ПроверкаОКПО), ЭтаФорма);
	
	Если ИННВведенКорректно Тогда
		НадписьПоясненияНекорректногоИНН = "";
	КонецЕсли;
	
	Если КППВведенКорректно Тогда
		НадписьПоясненияНекорректногоКПП = "";
	КонецЕсли;  
	
	Если ОКПОВведенКорректно Тогда
		НадписьПоясненияНекорректногоОКПО = "";
	КонецЕсли;
	
	Если ПроверкаИНН И ИННВведенКорректно Тогда 
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаОЗаполненииДанныхПоИНН",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения,"ИНН был изменён. Заполнить данные контрагента по ИНН?",РежимДиалогаВопрос.ДаНет,,КодВозвратаДиалога.Да);
		
	КонецЕсли;
	
КонецПроцедуры 
 
&НаКлиенте
// Процедура, обработчик события "НачалоВыбора".
//
Процедура БанковскийСчетПоУмолчаниюНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		СтандартнаяОбработка = Ложь;
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru = 'Элемент справочника еще не записан!'");
		Сообщение.Сообщить();
	Иначе
		СтандартнаяОбработка = Ложь;
		
		ОткрытьФорму("Справочник.БанковскиеСчета.ФормаВыбора",
		Новый Структура("Владелец", Объект.Ссылка),,,,,
		Новый ОписаниеОповещения("БанковскийСчетПоУмолчаниюНачалоВыбораЗавершение", ЭтотОбъект), 
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Банковский счет по умолчанию создание.
//
Процедура БанковскийСчетПоУмолчаниюСоздание(Элемент, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		СтандартнаяОбработка = Ложь;		
		ОповещениеДляВопроса = Новый ОписаниеОповещения("БанковскийСчетПоУмолчаниюСозданиеЗавершение", ЭтотОбъект);
		ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны. Записать?", РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора банковского счета
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура БанковскийСчетПоУмолчаниюНачалоВыбораЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
		Объект.БанковскийСчетПоУмолчанию = РезультатВыбора;
		Модифицированность = Истина;
	КонецЕсли; 	
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события ПриИзменении поля ввода КонтактнаяИнформация.
// Процедура назначается динамически действию элемента формы поле ввода
//
Процедура Подключаемый_КонтактнаяИнформацияПриИзменении(Элемент)
	
	УправлениеКонтактнойИнформациейКлиент.ПредставлениеПриИзменении(ЭтаФорма, Элемент);
	
КонецПроцедуры // КонтактнаяИнформацияПриИзменении()

&НаКлиенте
// Процедура обработчик события НачалоВыбора поля ввода КонтактнаяИнформация.
// Процедура назначается динамически действию элемента формы поле ввода
//
Процедура Подключаемый_КонтактнаяИнформацияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	УправлениеКонтактнойИнформациейКлиент.ПредставлениеНачалоВыбора(ЭтаФорма, Элемент,Модифицированность, СтандартнаяОбработка);
	
КонецПроцедуры // КонтактнаяИнформацияНачалоВыбора()

&НаСервереБезКонтекста
// Функция, определяет, является ли родитель клиентом.
//  Параметры:
//   ГруппаКонтрагента - контрагенты - родитель, которого определеяем.
//  Возвращаемое значение:
//   Признак принадлежности к клиенту.
//
Функция ЭтоПапкаКлиентов(ГруппаКонтрагента)
			
	Возврат ГруппаКонтрагента.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты;
	
КонецФункции

&НаКлиенте
// Процедура - обработчик события "ПриИзменении"
//
Процедура ТипКонтрагентаПриИзменении(Элемент)
	
	УстановитьВидимостьРеквизитов();
	
	Если Объект.ТипКонтрагента = ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.СтраховаяКомпания") Тогда
		Объект.ЭтоНеСтраховаяКомпания = Ложь;
		Элементы.ГруппаМетка.Видимость = Истина;
	Иначе
		Объект.ЭтоНеСтраховаяКомпания = Истина;         
		Элементы.ГруппаМетка.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#Область КОНТАКТНАЯ_ИНФОРМАЦИЯ

&НаКлиенте
// Процедура - Добавить контактную информацию
//
// Параметры:
//  Команда	 - 	 - 
//
