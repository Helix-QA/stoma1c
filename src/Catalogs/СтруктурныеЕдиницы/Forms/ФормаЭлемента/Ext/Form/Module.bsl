&НаСервере
// Процедура - Обновить данные ссылки на онлайн запись
//
// Параметры:
//  ИндексЭлемента	 - 	 - 
//
Процедура ОбновитьДанныеСсылкиНаОнлайнЗапись(ИндексЭлемента)

	УстановитьВидимостьПереключателя(ИндексЭлемента);

	УИДДляСсылки = "";
	Если ИндексЭлемента = "1" Тогда
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект.УИДОрганизацииРезерви) Тогда
			Попытка
				
				org_id = ЛичныйКабинет.ПолучитьУИДИнформационнойБазы();
				
				ПараметрыЗапроса = Новый Структура("organizations", Новый_Массив(org_id));
				РезультатЗапроса = ЛичныйКабинет.ВыполнитьPOSTЗапросВReservi("get_org_id", ПараметрыЗапроса);
				
				ТекстJSON		 = РезультатЗапроса.ПолучитьТелоКакСтроку();					
				
				Если ЗначениеЗаполнено(ТекстJSON) Тогда
					
					ЧтениеJSON = Новый ЧтениеJSON;
					ЧтениеJSON.УстановитьСтроку(ТекстJSON);
					ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON, Истина);
					
					Если ЗначениеЗаполнено(ПараметрыJSON) И ТипЗнч(ПараметрыJSON) = Тип("Соответствие") Тогда
						ЭтотОбъект.УИДОрганизацииРезерви = ПараметрыJSON[org_id].Получить("ID");
					КонецЕсли;
					
				КонецЕсли;
			
			Исключение   	
			КонецПопытки;
		КонецЕсли;
		
		УИДДляСсылки = ЭтотОбъект.УИДОрганизацииРезерви;
		ЭтотОбъект.ОнлайнЗаписьПоСсылке	= "https://stoma1c.ru/widget-org/" + УИДДляСсылки;
		
	Иначе      
		
		Если ЗначениеЗаполнено(Объект.УникальныйИдентификаторСтруктурнойЕдиницы) Тогда 
			УИДСтрокой = Объект.УникальныйИдентификаторСтруктурнойЕдиницы;
		Иначе
			УИДСтрокой = Строка(Объект.Ссылка.УникальныйИдентификатор());
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ЭтотОбъект.УИДКлиникиРезерви) Тогда
			Попытка
				
				Соединение 		 = Новый HTTPСоединение("reservi.ru/4.0/?salons%5B%5D=" + УИДСтрокой + "&state=fastinit&ver=2.053",,,,,1, Новый ЗащищенноеСоединениеOpenSSL());
				ЗапросHTTP       = Новый HTTPЗапрос();
				РезультатЗапроса = Соединение.Получить(ЗапросHTTP);
				ТекстJSON		 = РезультатЗапроса.ПолучитьТелоКакСтроку();					
				
				Если ЗначениеЗаполнено(ТекстJSON) Тогда  
					
					ЧтениеJSON = Новый ЧтениеJSON;
					ЧтениеJSON.УстановитьСтроку(ТекстJSON);
					ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON, Истина);
					
					data 			 = ПараметрыJSON.Получить("data");
					fastinit 		 = data.Получить("fastinit");
					
					Если ТипЗнч(fastinit) = Тип("Соответствие") И fastinit.Количество() > 0 Тогда
						ЭтотОбъект.УИДКлиникиРезерви = fastinit[УИДСтрокой].Получить("ID");
					КонецЕсли;   
					
				КонецЕсли;
			
			Исключение   	
			КонецПопытки;
		КонецЕсли; 
		
		УИДДляСсылки = ЭтотОбъект.УИДКлиникиРезерви;
		ЭтотОбъект.ОнлайнЗаписьПоСсылке	= "https://reservi.ru/stoma1c/" + УИДСтрокой; 
	КонецЕсли;
	
	КодОнлайнЗаписи = "<script src=""//reservi.ru/4.0/" + УИДДляСсылки + "/""></script>";
	ЭтотОбъект.КодДляУстановкиОнлайнЗаписи = КодОнлайнЗаписи;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить видимость переключателя для отображения ссылок
//
// Параметры:
//  ИндексЭлемента	 - 	 - 
//
Процедура УстановитьВидимостьПереключателя(ИндексЭлемента)
	
	// Убираем выделение групп.
	Для каждого Группа Из Элементы.ГруппаПереключательСтруктурныхЕдиниц.ПодчиненныеЭлементы Цикл
		Группа.ЦветФона = Новый Цвет(242, 242, 242);
		Для каждого Кнопка Из Группа.ПодчиненныеЭлементы Цикл
			Кнопка.ЦветТекста = Новый Цвет(77, 77, 77);
		КонецЦикла;
	КонецЦикла;
	
	// Устанавливаем выделение выбранной группы метода авторизации.
	Элементы["ГруппаПереключатель_" + ИндексЭлемента].ЦветФона = Новый Цвет(25 , 116, 206);
	Элементы["ПереключитьСтраницуОнлайнЗаписи_" + ИндексЭлемента].ЦветТекста = Новый Цвет(255, 255, 255);   
	
КонецПроцедуры

