				КонецЕсли;
				
				Если СертификатПартия <> Неопределено 				
					И ЭлементНизУр.СертификатПартия <> СертификатПартия Тогда												
					Продолжить;
				КонецЕсли;
				
				МассивСтрок.Добавить(ЭлементНизУр);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат МассивСтрок;
	
КонецФункции

