
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.Обновить.Видимость = РольДоступна("АдминистраторСистемы");
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьИзКлассификатора(Команда)
	
	КоличествоДобавленных = ДобавитьИзКлассификатораНаСервере();
	Элементы.Список.Обновить();
	Если КоличествоДобавленных = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Справочник полный. Добавление диагнозов не требуется.");
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Добавленно: " + КоличествоДобавленных + " диагнозов.");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ДобавитьИзКлассификатораНаСервере()
	
	Возврат Справочники.Диагнозы.ДобавитьДиагнозыИзКлассификатора();
	
КонецФункции

&НаКлиенте
Процедура СписокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
		
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			НСтр("ru = 'Интерактивное добавление в справочник не поддерживается.""'"));

	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьНаСервере()
	 Справочники.Диагнозы.ДобавитьДиагнозыИзКлассификатора();
КонецПроцедуры

#КонецОбласти