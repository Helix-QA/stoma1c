					Долг = РегистрыНакопления.РасчетыСПокупателями.ПолучитьОстатокПоВзаиморасчетамСконтрагентомДляВизита(
																		Объект.Контрагент, 
																		Объект.Организация,
																		Объект.Ссылка);
