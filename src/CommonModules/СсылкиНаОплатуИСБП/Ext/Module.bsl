	//	ФискализацияЧекаЭвотор(МассивФискализации, КассаОплаты); 
	//ИначеЕсли ПараметрыФискализации.ОтправлятьДанныеВCheckbox Тогда  
	//	ОтправитьДокументыВCheckbox(МассивФискализации, КассаОплаты);
	КонецЕсли;
		
КонецПроцедуры

// Функция - Кассовый сервер используется для данной кассы
//
// Параметры:
//  КассаОплаты	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИспользуетсяКассовыйСервер(КассаОплаты)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПодключаемоеОборудование.Параметры КАК Параметры
	|ИЗ
	|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	|ГДЕ
	|	ПодключаемоеОборудование.УстройствоИспользуется = ИСТИНА
	|	И ПодключаемоеОборудование.ПометкаУдаления = ЛОЖЬ
	|	И ПодключаемоеОборудование.ТипОборудования = ЗНАЧЕНИЕ(Перечисление.ТипыПодключаемогоОборудования.ККТ)
	|	И ПодключаемоеОборудование.ДрайверОборудования.ИмяПредопределенныхДанных = ""ДрайверКассовогоСервера""");
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЗ Из РезультатЗапроса Цикл
		
		ПараметрыКассовогоСервера = СтрокаТЗ.Параметры.Получить();
		
		Если ПараметрыКассовогоСервера.КассаОплаты = КассаОплаты Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Процедура, добавляет переданные документы оплаты в очередь кассового сервера.
//
Процедура ДобавитьДокументОплатыВОчередьКассовогоСервера(МассивФискализации, КассаОплаты)
	
	Для Каждого ДокументОплаты Из МассивФискализации Цикл 
		
		Попытка
			РегистрыСведений.ОчередьКассовогоСервера.ДобавитьДокументОплатыВОчередь_v3(ДокументОплаты, КассаОплаты);
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СозданиеДинамическихЭлементовДокументов

&НаСервере
// Процедура - Обновить информацию по использованию ссылки на оплату.
//
Процедура ОбновитьИнформациюПоИспользованиюСсылкиНаОплату(ЭтаФорма) Экспорт
		
	Элементы = ЭтаФорма.Элементы;
	Объект = ЭтаФорма.Объект;
	Элементы.ГруппаСсылкаНаОплату_Шаблон.Видимость = Ложь;
	
	Если Объект.Ссылка.Пустая() ИЛИ Объект.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;
	
	МассивУдаляемых = Новый Массив;
	Для Каждого УдаляемыйЭлемент Из Элементы.ГруппаСсылокНаОплату.ПодчиненныеЭлементы Цикл
		МассивУдаляемых.Добавить(УдаляемыйЭлемент);
	КонецЦикла;
	Для Каждого УдаляемыйЭлемент Из МассивУдаляемых Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
		
	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьНеОплаченныеЗаказыПоДокументу(Объект.Ссылка);
	
	Для Каждого СтрокаТ Из ТаблицаЗаказов Цикл
		
		КартинкаПлатёжногоШлюза = УправлениеСвойствами.ПолучитьКартинкуПШ(СтрокаТ.ТипБанка);
		
		СуммаОплаты		= РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьСуммуОплатыПоЗаказу(СтрокаТ.СсылкаОплаты);
		Валюта			= ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		ЗаголовокЗаказа = "Ожидает оплаты: " + Формат(СуммаОплаты, "ЧДЦ=2; ЧН=0") + Валюта;
		ГруппаКнопки 	= УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(ЭтаФорма, Элементы.ГруппаСсылкаНаОплату_Шаблон, СтрокаТ.НомерЗаказа, Элементы.ГруппаСсылокНаОплату);
		КнопкаЗаказа 	= УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(ЭтаФорма, Элементы.КнопкаСсылкаНаОплату_Шаблон, СтрокаТ.НомерЗаказа, ГруппаКнопки,, ЗаголовокЗаказа,,, КартинкаПлатёжногоШлюза);
		КнопкаОтмены 	= УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(ЭтаФорма, Элементы.ОтменитьСсылку_Шаблон, СтрокаТ.НомерЗаказа, ГруппаКнопки);
	
	КонецЦикла;
		                                                        
	Если ТаблицаЗаказов.Количество() > 0 Тогда		
		ДокументОплачен = Объект.Проведен И (?(ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СуммаОплаченоПродажи"), Объект.СуммаОплаченоПродажи, Объект.СуммаОплачено) >= Объект.СуммаДокумента);
		Элементы.ГруппаСсылкаОплаты.Видимость = НЕ ДокументОплачен;		
	Иначе
		Элементы.ГруппаСсылкаОплаты.Видимость = Ложь;
	КонецЕсли;
	
	//Если ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Элементы, "Группа_Кнопки_Оплаты") Тогда
	//	Элементы.Переместить(Элементы.ГруппаСсылкаОплаты, Элементы.ГруппаИнформацияПоОплатеПодробно, Элементы.Группа_Кнопки_Оплаты);
	//КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

// Функция, формирует коротку ссылку.
//
Функция ПолучитьКороткуюСсылку(СсылкаНаОплату, ОписаниеОшибки = "") Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	link = СсылкаНаОплату;		
	
	ДеталиСсылки = Новый Структура;
	ДеталиСсылки.Вставить("domainUriPrefix", "https://glk.me");	
	ДеталиСсылки.Вставить("link", link);		
	
	ДанныеСсылки = Новый Структура("dynamicLinkInfo, suffix", ДеталиСсылки, Новый Структура("option", "SHORT"));	
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);		
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);	
	ЗаписатьJSON(ЗаписьJSON, ДанныеСсылки); 	
	ДанныеJSON = ЗаписьJSON.Закрыть();
	
	Попытка		
		HTTPСоединение = Новый HTTPСоединение("firebasedynamiclinks.googleapis.com",,,,,3,Новый ЗащищенноеСоединениеOpenSSL());
		ЗаголовкиHTTP  = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json");
		
		HTTPЗапрос = Новый HTTPЗапрос("/v1/shortLinks/?key=AIzaSyAoS1PL4lwzRZWxMlPY1fGex4OC1L65jhw", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(ДанныеJSON); 		
		
		Запрос = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ТекстJSON  = Запрос.ПолучитьТелоКакСтроку();
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
	
	Если Запрос.КодСостояния = 200 Тогда
		Возврат ПараметрыJSON.shortLink;
	Иначе
		ОписаниеОшибки = НСтр("ru= 'Код состояния: ';en= 'Status code: '") + Запрос.КодСостояния + Символы.ПС + ТекстJSON;
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

#КонецОбласти
