
#Область СлужебныйПрограммныйИнтерфейс

// Функция, возвращает ссылки на объекты, по которым необходимо записать изменения в сегментах.
//
Функция ПолучитьПорциюОднотипныхОбъектовДляОбработки() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 100
	|	ФормированиеСегментовПоСтекуИзменений.Объект КАК Объект,
	|	ТИПЗНАЧЕНИЯ(ФормированиеСегментовПоСтекуИзменений.Объект) КАК ТипЗначения
	|ИЗ
	|	РегистрСведений.ФормированиеСегментовПоСтекуИзменений КАК ФормированиеСегментовПоСтекуИзменений
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТипЗначения
	|ИТОГИ ПО
	|	ТипЗначения");
	
	ВыгрузкаВерхнийУровень = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Если ВыгрузкаВерхнийУровень.Строки.Количество() > 0 Тогда
		
		Возврат ВыгрузкаВерхнийУровень.Строки[0].Строки.ВыгрузитьКолонку("Объект");
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти
