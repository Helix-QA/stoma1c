		//	ТекущиеДанные.СуммаРучнойСкидки    = (ТекущиеДанные.Цена/100)*ТекущиеДанные.ПроцентСкидкиНаценки;
		// Иначе
		//	ТекущиеДанные.СуммаРучнойСкидки    = 0;
		// КонецЕсли;
		ОбновитьSVGПодбор();
