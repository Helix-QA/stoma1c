// Процедура, выполняет запись новых данных задания
//
Функция ПерезаписатьДатуЗадания(Дата, Задача, ЭтоМесяц)
	
	ОбъектЗадача = Задача.ПолучитьОбъект();
	ОбъектЗадача.ЗадачаНазначеннаяДата = Дата + ?(ЭтоМесяц, Час(Задача.ЗадачаНазначеннаяДата) * 3600 + Минута(Задача.ЗадачаНазначеннаяДата) * 60, 0);
	ОбъектЗадача.Записать();
	
	Возврат Новый Структура("Тема, Дата", Задача.ЗадачаТема, Задача.ЗадачаНазначеннаяДата);
	
КонецФункции

