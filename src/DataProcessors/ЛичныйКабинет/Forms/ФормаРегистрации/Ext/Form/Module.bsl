// Функция - Адрес организации структурой
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьЮрридическийАдресОрганизацииСтруктурой(Организация)
	
	  НайденныеСтроки = Организация.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации)); 
	  
	  Если НайденныеСтроки.Количество() > 0 Тогда
		  
		 Адрес = УправлениеКонтактнойИнформациейСлужебныйСтоматология.СведенияОбАдресеВВидеСтруктуры(НайденныеСтроки[0].ЗначенияПолей, Неопределено);
		 
		 Если Адрес <> Неопределено Тогда
			 
			 Адрес.Вставить("Представление", НайденныеСтроки[0].Представление);
			 Адрес.Вставить("XML"          , НайденныеСтроки[0].ЗначенияПолей);

			 Возврат Адрес;
			 
		 КонецЕсли;
		 
	  КонецЕсли; 
	  
	  Возврат Неопределено;
	  
КонецФункции

