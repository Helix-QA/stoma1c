	|	ЛОЖЬ КАК ОтправкаPushWallet,
	|	ВЫБОР
	|		КОГДА ТаблицаДанныхНастроекКаналовОтправки.АккаунтВнешнейСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi)
	|			ТОГДА ЕСТЬNULL(СотрудникиКонтактнаяИнформация.НомерТелефона, """") <> """"
	|		ИНАЧЕ ТаблицаДанныхНастроекКаналовОтправки.ОтправкаMessenger
	|	КОНЕЦ КАК ОтправкаMessenger,
	|	ЛОЖЬ КАК ОтправкаSMS,
	|	ТаблицаДанныхНастроекКаналовОтправки.АккаунтВнешнейСистемы КАК АккаунтВнешнейСистемы,
	|	ТаблицаДанныхНастроекКаналовОтправки.КаналСистемыСообщений КАК КаналСистемыСообщений,
	|	НЕОПРЕДЕЛЕНО КАК АккаунтСервисаРассылкиSMS,
	|	ЕСТЬNULL(СотрудникиКонтактнаяИнформация.Сотрудник, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК Сотрудник,
	|	ЕСТЬNULL(СотрудникиКонтактнаяИнформация.НомерТелефона, """") КАК НомерТелефонаMessengerSMS,
	|	ЕСТЬNULL(СотрудникиКонтактнаяИнформация.Представление, """") КАК Представление,
	|	ЛОЖЬ КАК РассылкаЗапрещенаMessengerSMS
	|ИЗ
	|	ТаблицаДанныхНастроекКаналовОтправки КАК ТаблицаДанныхНастроекКаналовОтправки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКонтактнойИнформацииСотрудников КАК СотрудникиКонтактнаяИнформация
	|		ПО (СотрудникиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонСотрудника))
	|			И (ТаблицаДанныхНастроекКаналовОтправки.ОтправкаMessenger)
	|ГДЕ
	|	&ОтправитьСообщение = ИСТИНА
	|	И (&ИнформироватьВрачаПриема
	|			ИЛИ &ИнформироватьСотрудника
	|			ИЛИ &ИнформироватьКуратора)
	|	И ТаблицаДанныхНастроекКаналовОтправки.ОтправкаMessenger
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаДанныхНастроекКаналовОтправки.ИдентификаторДействия,
	|	ТаблицаДанныхНастроекКаналовОтправки.СтруктурнаяЕдиница,
	|	ТаблицаДанныхНастроекКаналовОтправки.Контрагент,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СотрудникиКонтактнаяИнформация.НомерТелефона, """") <> """"
	|			ТОГДА ТаблицаДанныхНастроекКаналовОтправки.ОтправкаSMS
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	НЕОПРЕДЕЛЕНО,
	|	"""",
	|	ТаблицаДанныхНастроекКаналовОтправки.АккаунтСервисаРассылкиSMS,
	|	ЕСТЬNULL(СотрудникиКонтактнаяИнформация.Сотрудник, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)),
	|	ЕСТЬNULL(СотрудникиКонтактнаяИнформация.НомерТелефона, """"),
	|	ЕСТЬNULL(СотрудникиКонтактнаяИнформация.Представление, """"),
	|	ЛОЖЬ
	|ИЗ
	|	ТаблицаДанныхНастроекКаналовОтправки КАК ТаблицаДанныхНастроекКаналовОтправки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКонтактнойИнформацииСотрудников КАК СотрудникиКонтактнаяИнформация
	|		ПО (СотрудникиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонСотрудника))
	|			И (ТаблицаДанныхНастроекКаналовОтправки.ОтправкаSMS)
	|ГДЕ
	|	&ОтправитьСообщение = ИСТИНА
	|	И (&ИнформироватьВрачаПриема
	|			ИЛИ &ИнформироватьСотрудника
	|			ИЛИ &ИнформироватьКуратора)
	|	И ТаблицаДанныхНастроекКаналовОтправки.ОтправкаSMS
	|	И ЕСТЬNULL(СотрудникиКонтактнаяИнформация.Вид, ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонСотрудника)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаКонтактнойИнформацииСотрудников.Сотрудник КАК Сотрудник,
	|	ТаблицаКонтактнойИнформацииСотрудников.Представление КАК Представление,
	|	ТаблицаКонтактнойИнформацииСотрудников.НомерТелефона КАК НомерТелефона,
	|	ЛОЖЬ КАК НеУчаствоватьВРассылке
	|ИЗ
	|	ТаблицаКонтактнойИнформацииСотрудников КАК ТаблицаКонтактнойИнформацииСотрудников
	|ГДЕ
	|	&ИнформироватьПоEMail
	|	И ТаблицаКонтактнойИнформацииСотрудников.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailСотрудника)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОсновныхМенеджеров.Контрагент КАК Контрагент,
	|	ТаблицаОсновныхМенеджеров.Менеджер КАК Менеджер
	|ИЗ
	|	ТаблицаОсновныхМенеджеров КАК ТаблицаОсновныхМенеджеров";	
		
#КонецОбласти
		
	РезультатПакетаЗапросов 				= Запрос.ВыполнитьПакет();
	ТаблицаКлиентовСНомерамиТелефонов 		= РезультатПакетаЗапросов[7].Выгрузить();
	ТаблицаКлиентовСУказаннымиEmail 		= РезультатПакетаЗапросов[8].Выгрузить();
	ТаблицаСотрудниковСНомерамиТелефонов 	= РезультатПакетаЗапросов[12].Выгрузить();
	ТаблицаСотрудниковСУказаннымиEmail 		= РезультатПакетаЗапросов[13].Выгрузить();
	ТаблицаОсновныхМенеджеров 				= РезультатПакетаЗапросов[14].Выгрузить();
		
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	СтруктураКонтактнойИнформации.Вставить("ТаблицаКлиентовСНомерамиТелефонов"		, ТаблицаКлиентовСНомерамиТелефонов);
	СтруктураКонтактнойИнформации.Вставить("ТаблицаКлиентовСУказаннымиEmail"		, ТаблицаКлиентовСУказаннымиEmail);
	СтруктураКонтактнойИнформации.Вставить("ТаблицаОсновныхМенеджеров"				, ТаблицаОсновныхМенеджеров);
	СтруктураКонтактнойИнформации.Вставить("ТаблицаСотрудниковСНомерамиТелефонов"	, ТаблицаСотрудниковСНомерамиТелефонов);
	СтруктураКонтактнойИнформации.Вставить("ТаблицаСотрудниковСУказаннымиEmail"		, ТаблицаСотрудниковСУказаннымиEmail);
			
	Возврат СтруктураКонтактнойИнформации;
	
КонецФункции

// Функция - Получить массив врачей для информирования
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  ТаблицаДанныхОбъекта	 - 	 - 
//  ИнформироватьВрачаПриема - 	 - 
//  ИнформироватьСотрудника	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивВрачейДляИнформирования(ДанныеТриггера, ТаблицаДанныхОбъекта, ИнформироватьВрачаПриема, ИнформироватьСотрудника)
	
	МассивВрачей = Новый Массив;
	Если ИнформироватьВрачаПриема Тогда 
		ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
		СтрокаВариантУсловияТриггерногоСобытия = ТаблицаВсехВариантовУсловийТриггерныхСобытий.Найти(ДанныеТриггера.УсловиеСобытия, "ВариантыУсловийТриггерныхСобытий");
		Если СтрокаВариантУсловияТриггерногоСобытия = Неопределено Тогда 
			// Запрос.УстановитьПараметр("МассивВрачей"	, Новый Массив);
		ИначеЕсли СтрокаВариантУсловияТриггерногоСобытия.ВиртуальнаяГруппаСобытий = "СобытияПоЗаписям" Тогда
			Если ТаблицаДанныхОбъекта.Колонки.Найти("Сотрудник") <> Неопределено Тогда 
				МассивВрачей = ТаблицаДанныхОбъекта.ВыгрузитьКолонку("Сотрудник");
			Иначе 
				// Запрос.УстановитьПараметр("МассивВрачей"	, Новый Массив);
			КонецЕсли;	
		Иначе 	
			// Запрос.УстановитьПараметр("МассивВрачей"	, Новый Массив);
		КонецЕсли;
	Иначе 
		// Запрос.УстановитьПараметр("МассивВрачей"	, Новый Массив);			
	КонецЕсли;
	
	Если ИнформироватьСотрудника Тогда 
		Для Каждого СтрокаДействие Из ДанныеТриггера.ПланДействийТриггерногоСобытия Цикл 
			Если СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение ИЛИ СтрокаДействие.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
				Если СтрокаДействие.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник И ТипЗнч(СтрокаДействие.Адресат) = Тип("СправочникСсылка.Сотрудники") И ЗначениеЗаполнено(СтрокаДействие.Адресат) Тогда 
					Если МассивВрачей.Найти(СтрокаДействие.Адресат) = Неопределено Тогда 
						МассивВрачей.Добавить(СтрокаДействие.Адресат);	
					КонецЕсли;	
				КонецЕсли;	
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;
	
	Возврат МассивВрачей;
	
КонецФункции

// Функция - Получить структуру данных занятия
//
// Параметры:
//  Занятие	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуруДанныхЗанятия(Запись)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПредварительнаяЗапись.Ссылка КАК Ссылка,
	|	ПредварительнаяЗапись.Дата КАК Дата,
	|	ПредварительнаяЗапись.ДатаСоздания КАК ДатаСоздания,
	|	ДАТАВРЕМЯ(1,1,1) КАК ДатаВремяОкончания,
	|	ДАТАВРЕМЯ(1,1,1) КАК ДатаОтменыЗаписи,
	|	ПредварительнаяЗапись.Контрагент КАК Контрагент,	
	|	ПредварительнаяЗапись.Статус КАК Статус
	|ПОМЕСТИТЬ ТаблицаОсновныхДанныхЗанятия
	|ИЗ
	|	Документ.Событие КАК ПредварительнаяЗапись
	|ГДЕ
	|	ПредварительнаяЗапись.Ссылка = &Запись
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗанятиеСоставЗанятия.ДатаЗаписи КАК ДатаЗаписи,
	|	ЗанятиеСоставЗанятия.Контрагент КАК Контрагент,
	|	ЗанятиеСоставЗанятия.ДатаПрибытия КАК ДатаПрибытия,
	|	ЗанятиеСоставЗанятия.СтатусПрибытия КАК СтатусПрибытия,
	|	ЗанятиеСоставЗанятия.ДатаОтмены КАК ДатаОтмены,
	|	ЗанятиеСоставЗанятия.СписаниеПодтвержденоКлиентом КАК СписаниеПодтвержденоКлиентом,
	|	ЗанятиеСоставЗанятия.Ссылка КАК Ссылка,
	|	ЗанятиеСоставЗанятия.Ссылка.Дата КАК Дата,
	|	ЗанятиеСоставЗанятия.Ссылка.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ЗанятиеСоставЗанятия.Ссылка.ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	ЗанятиеСоставЗанятия.Ссылка.ДатаОтменыЗанятия КАК ДатаОтменыЗанятия,
	|	ЗанятиеСоставЗанятия.Ссылка.СтатусЗанятия КАК СтатусЗанятия,
	|	ЗанятиеСоставЗанятия.Ссылка.ТипЗанятия КАК ТипЗанятия
	|ПОМЕСТИТЬ ТаблицаСоставаЗанятия
	|ИЗ
	|	Документ.Занятие.СоставЗанятия КАК ЗанятиеСоставЗанятия
	|ГДЕ
	|	ЗанятиеСоставЗанятия.Ссылка = &Занятие
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОсновныхДанныхЗанятия.Ссылка КАК Ссылка,
	|	ТаблицаОсновныхДанныхЗанятия.Дата КАК Дата,
	|	ТаблицаОсновныхДанныхЗанятия.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ТаблицаОсновныхДанныхЗанятия.ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	ТаблицаОсновныхДанныхЗанятия.ДатаОтменыЗанятия КАК ДатаОтменыЗанятия,
	|	ТаблицаОсновныхДанныхЗанятия.СтатусЗанятия КАК СтатусЗанятия,
	|	ТаблицаОсновныхДанныхЗанятия.ТипЗанятия КАК ТипЗанятия,
	|	ТаблицаОсновныхДанныхЗанятия.УслугаТипСписанияЗанятием КАК УслугаТипСписанияЗанятием,
	|	ЕСТЬNULL(ТаблицаСоставаЗанятия.ДатаЗаписи, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаЗаписи,
	|	ЕСТЬNULL(ТаблицаСоставаЗанятия.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент,
	|	ЕСТЬNULL(ТаблицаСоставаЗанятия.ДатаПрибытия, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПрибытия,
	|	ЕСТЬNULL(ТаблицаСоставаЗанятия.СтатусПрибытия, -1) КАК СтатусПрибытия,
	|	ЕСТЬNULL(ТаблицаСоставаЗанятия.ДатаОтмены, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаОтмены,
	|	ЕСТЬNULL(ТаблицаСоставаЗанятия.СписаниеПодтвержденоКлиентом, ЛОЖЬ) КАК СписаниеПодтвержденоКлиентом
	|ИЗ
	|	ТаблицаОсновныхДанныхЗанятия КАК ТаблицаОсновныхДанныхЗанятия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСоставаЗанятия КАК ТаблицаСоставаЗанятия
	|		ПО ТаблицаОсновныхДанныхЗанятия.Ссылка = ТаблицаСоставаЗанятия.Ссылка";
	
	Запрос.УстановитьПараметр("Запись", Запись);
	ДанныеЗанятия = Запрос.Выполнить().Выгрузить();
	ТаблицаСоставаЗанятия = ДанныеЗанятия.Скопировать(, "ДатаЗаписи, Контрагент, ДатаПрибытия, СтатусПрибытия, ДатаОтмены, СписаниеПодтвержденоКлиентом");
	
	СтруктуруДанныхЗанятия = Новый Структура;
	СтруктуруДанныхЗанятия.Вставить("ТаблицаТекущихЗначений", ТаблицаСоставаЗанятия);
	Если ДанныеЗанятия.Количество() = 0 Тогда 
		СтруктуруДанныхЗанятия.Вставить("ДатаЗанятия"				, Неопределено);
		СтруктуруДанныхЗанятия.Вставить("ДатаВремяНачала"			, Неопределено);
		СтруктуруДанныхЗанятия.Вставить("ДатаВремяОкончания"		, Неопределено);		
		СтруктуруДанныхЗанятия.Вставить("ДатаОтменыЗанятия"			, Неопределено);
		СтруктуруДанныхЗанятия.Вставить("СтатусЗанятия"				, Неопределено);
		СтруктуруДанныхЗанятия.Вставить("ТипЗанятия"				, Неопределено);
		СтруктуруДанныхЗанятия.Вставить("УслугаТипСписанияЗанятием"	, Неопределено);		
	Иначе 
		СтруктуруДанныхЗанятия.Вставить("ДатаЗанятия"				, ДанныеЗанятия[0].Дата);
		СтруктуруДанныхЗанятия.Вставить("ДатаВремяНачала"			, ДанныеЗанятия[0].ДатаВремяНачала);
		СтруктуруДанныхЗанятия.Вставить("ДатаВремяОкончания"		, ДанныеЗанятия[0].ДатаВремяОкончания);		
		СтруктуруДанныхЗанятия.Вставить("ДатаОтменыЗанятия"			, ДанныеЗанятия[0].ДатаОтменыЗанятия);
		СтруктуруДанныхЗанятия.Вставить("СтатусЗанятия"				, ДанныеЗанятия[0].СтатусЗанятия);
		СтруктуруДанныхЗанятия.Вставить("ТипЗанятия"				, ДанныеЗанятия[0].ТипЗанятия);
		СтруктуруДанныхЗанятия.Вставить("УслугаТипСписанияЗанятием"	, ДанныеЗанятия[0].УслугаТипСписанияЗанятием);				
	КонецЕсли;	
	
	Возврат СтруктуруДанныхЗанятия;
	
КонецФункции

// Функция - Получить записи операции по членству пакету услуг
//
// Параметры:
//  ДокументОперация - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗаписиОперацииПоЧленствуПакетуУслуг(ДокументОперация)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументОперация", ДокументОперация);
	Запрос.УстановитьПараметр("ТекущаяДата"		, ТекущаяДатаСеанса());
	Запрос.Текст = "ВЫБРАТЬ
	               |	СтатусыЧленствПакетовУслуг.Период КАК Период,
	               |	ВЫРАЗИТЬ(СтатусыЧленствПакетовУслуг.Регистратор КАК Документ.ОперацииСЧленствомПакетомУслуг) КАК ДокументОперация,
	               |	ВЫРАЗИТЬ(СтатусыЧленствПакетовУслуг.Регистратор КАК Документ.ОперацииСЧленствомПакетомУслуг).ВидОперации КАК ВидОперации,
	               |	ВЫРАЗИТЬ(СтатусыЧленствПакетовУслуг.Регистратор КАК Документ.ОперацииСЧленствомПакетомУслуг).Контрагент КАК Контрагент,
	               |	СтатусыЧленствПакетовУслуг.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг,
	               |	СтатусыЧленствПакетовУслуг.Статус КАК Статус
	               |ПОМЕСТИТЬ ТаблицаЗаписейОперации
	               |ИЗ
	               |	РегистрСведений.СтатусыЧленствПакетовУслуг КАК СтатусыЧленствПакетовУслуг
	               |ГДЕ
	               |	СтатусыЧленствПакетовУслуг.Регистратор = &ДокументОперация
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СтатусыЧленствПакетовУслугСрезПоследних.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |ПОМЕСТИТЬ ТаблицаАктуальныхЧленстПакетовУслуг
	               |ИЗ
	               |	РегистрСведений.СтатусыЧленствПакетовУслуг.СрезПоследних(
	               |			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
	               |			ЧленствоПакетУслуг В
	               |					(ВЫБРАТЬ
	               |						ТаблицаЗаписейОперации.ЧленствоПакетУслуг
	               |					ИЗ
	               |						ТаблицаЗаписейОперации)
	               |				И ВЫБОР
	               |					КОГДА Регистратор = &ДокументОперация
	               |						ТОГДА Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЧленствПакетовУслуг.Активен)
	               |					ИНАЧЕ ИСТИНА
	               |				КОНЕЦ) КАК СтатусыЧленствПакетовУслугСрезПоследних
	               |ГДЕ
	               |	НЕ СтатусыЧленствПакетовУслугСрезПоследних.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыЧленствПакетовУслуг.Активен), ЗНАЧЕНИЕ(Перечисление.СтатусыЧленствПакетовУслуг.Закрыт))
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаЗаписейОперации.Период КАК Период,
	               |	ТаблицаЗаписейОперации.ДокументОперация КАК ДокументОперация,
	               |	ТаблицаЗаписейОперации.ВидОперации КАК ВидОперации,
	               |	ТаблицаЗаписейОперации.Контрагент КАК Контрагент,
	               |	ТаблицаЗаписейОперации.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг,
	               |	ТаблицаЗаписейОперации.Статус КАК Статус
	               |ИЗ
	               |	ТаблицаЗаписейОперации КАК ТаблицаЗаписейОперации
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАктуальныхЧленстПакетовУслуг КАК ТаблицаАктуальныхЧленстПакетовУслуг
	               |		ПО ТаблицаЗаписейОперации.ЧленствоПакетУслуг = ТаблицаАктуальныхЧленстПакетовУслуг.ЧленствоПакетУслуг
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Период";
	
	ЗаписиОперации = Запрос.Выполнить().Выгрузить();
	
	Возврат ЗаписиОперации;
	
КонецФункции

// Функция - Инициализировать таблицу времени работы структурной единицы
//
// Параметры:
//  ТаблицаДанныхОбъекта - 	 - 
//  ДанныеТриггера		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьТаблицуВремениРаботыСтруктурнойЕдиницы(ТаблицаДанныхОбъекта, ДанныеТриггера);

	НеобходимоПоставитьЗадачу = НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру, "ВидДействия") = Неопределено;
	
	Если НеобходимоПоставитьЗадачу Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	РасписаниеРаботы.Ссылка КАК СтруктурнаяЕдиница,
		               |	РасписаниеРаботы.НачалоРаботы КАК НачалоРаботы,
		               |	ВЫБОР
		               |		КОГДА РасписаниеРаботы.ОкончаниеРаботы = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		               |			ТОГДА КОНЕЦПЕРИОДА(ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0), ДЕНЬ)
		               |		ИНАЧЕ РасписаниеРаботы.ОкончаниеРаботы
		               |	КОНЕЦ КАК ОкончаниеРаботы
		               |ИЗ
		               |	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК РасписаниеРаботы
		               |ГДЕ
		               |	РасписаниеРаботы.Ссылка В(&МассивСтруктурныхЕдиниц)
		               |	И ДЕНЬНЕДЕЛИ(РасписаниеРаботы.ДеньНедели) = ДЕНЬНЕДЕЛИ(&Дата)
		               |	И НЕ РасписаниеРаботы.ДеньНедели = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		               |	И РасписаниеРаботы.Активность = ИСТИНА";
		
		Запрос.УстановитьПараметр("Дата"					, ТекущаяДатаСеанса());
		Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц"	, ТаблицаДанныхОбъекта.ВыгрузитьКолонку("СтруктурнаяЕдиница"));
		
		Возврат Запрос.Выполнить().Выгрузить();
	КонецЕсли;

	Возврат Неопределено;
	
КонецФункции

// Процедура - Начать генерацию объектов информирования
//
// Параметры:
//  ДанныеТриггера							 - 	 - 
//  ТаблицаДанныхОбъекта					 - 	 - 
//  СтруктураКонтактнойИнформации	 - 	 - 
//  ТаблицаВремениРаботыСтруктурнойЕдиницы	 - 	 - 
//  РегистрацияЗапланированных				 - 	 - 
//
Процедура НачатьГенерациюОбъектовИнформирования(ДанныеТриггера,
												ТаблицаДанныхОбъекта,
												СтруктураКонтактнойИнформации,
												ТаблицаВремениРаботыСтруктурнойЕдиницы,
												ПараметрыРегистрации)
	
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники Тогда
		СгруппироватьДанныеПоПосещениям(ТаблицаДанныхОбъекта);
	КонецЕсли;             
	
	ТаблицаИнформацииПоСделкам = Неопределено;
	// РазрешенаРаботаСоСделками = НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки, "ВидДействия") = Неопределено;
	// Если РазрешенаРаботаСоСделками Тогда
	//	ТаблицаИнформацииПоСделкам = ПолучитьТаблицуСделокДляДанныхОбъекта(ДанныеТриггера, ТаблицаДанныхОбъекта);
	// КонецЕсли;
		
	Для Каждого СтрокаТаблицыДанных Из ТаблицаДанныхОбъекта Цикл
		Если ПараметрыРегистрации.РегистрацияЗапланированных Тогда 
			Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса Тогда 
				МассивСтрокРеестра = ДанныеТриггера.РеестрЗапланированных.НайтиСтроки(Новый Структура("ТриггерноеСобытие, ДатаСменыСтатуса, Контрагент, Подтверждено", ДанныеТриггера.ТриггерноеСобытие, СтрокаТаблицыДанных.ДатаСменыСтатуса, СтрокаТаблицыДанных.Контрагент, Истина));
			Иначе 	
				МассивСтрокРеестра = ДанныеТриггера.РеестрЗапланированных.НайтиСтроки(Новый Структура("ТриггерноеСобытие, ОбъектСобытия, Контрагент, Подтверждено", ДанныеТриггера.ТриггерноеСобытие, СтрокаТаблицыДанных.ОбъектСобытия, СтрокаТаблицыДанных.Контрагент, Истина));
			КонецЕсли;	
			Для Каждого СтрокаРеестра Из МассивСтрокРеестра Цикл 
				СтрокаПлан = ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(СтрокаРеестра.ИдентификаторДействия, "ИдентификаторДействия");
				Если СтрокаПлан = Неопределено Тогда 
					
					ЗаписьЖурналаРегистрации(
					НСтр("ru='ТриггерныеСобытия.Рассинхронизация реестра с планом действий';en='Trigger Events.Desynchronizing the registry with the action plan'",
					ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка()),
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.НайтиПоТипу(ТипЗнч(ДанныеТриггера.ТриггерноеСобытие)),
					ДанныеТриггера.ТриггерноеСобытие,
					НСтр("ru='Запланированное событие не найдено в плане действий:';en='The scheduled event was not found in the action plan:'") + Символы.ПС + Строка(СтрокаРеестра.Период) + Символы.ПС + Строка(СтрокаРеестра.Контрагент) + Символы.ПС + Строка(СтрокаРеестра.ОбъектСобытия) + Символы.ПС + Строка(СтрокаРеестра.ИдентификаторДействия));
					
					
				Иначе 	
					Если СтрокаПлан.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки ИЛИ СтрокаПлан.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки Тогда 
						ТаблицаИнформацииПоСделкам = ПолучитьТаблицуСделокДляДанныхОбъекта(ДанныеТриггера, ТаблицаДанныхОбъекта, СтрокаПлан);
					КонецЕсли;	
					ЗарегистрироватьСобытиеВЖурнале(ДанныеТриггера,
													СтрокаТаблицыДанных,
													СтрокаПлан,
													СтрокаРеестра,
													СтруктураКонтактнойИнформации,
													ТаблицаВремениРаботыСтруктурнойЕдиницы,
													ТаблицаИнформацииПоСделкам,
													ПараметрыРегистрации);
					
				КонецЕсли;
			КонецЦикла;
		Иначе
			Для Каждого СтрокаПлан Из ДанныеТриггера.ПланДействийТриггерногоСобытия Цикл
				Если СтрокаПлан.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки ИЛИ СтрокаПлан.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки Тогда 
					ТаблицаИнформацииПоСделкам = ПолучитьТаблицуСделокДляДанныхОбъекта(ДанныеТриггера, ТаблицаДанныхОбъекта, СтрокаПлан);
				КонецЕсли;					
				ЗарегистрироватьСобытиеВЖурнале(ДанныеТриггера,
												СтрокаТаблицыДанных,
												СтрокаПлан,
												,
												СтруктураКонтактнойИнформации,
												ТаблицаВремениРаботыСтруктурнойЕдиницы,
												ТаблицаИнформацииПоСделкам,
												ПараметрыРегистрации);				
			КонецЦикла;
		КонецЕсли;
		
		// Добавление в стек обновления электронных карт
		Если (ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетВзнос
			ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетСписание)
			И ЗначениеЗаполнено(СтрокаТаблицыДанных.Контрагент) И ТипЗнч(СтрокаТаблицыДанных.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда 
			
			Попытка
				КартыКонтрагента = Справочники.Карты.ПолучитьКартыКлиента(СтрокаТаблицыДанных.Контрагент,, Перечисления.ВидыКарт.Wallet, Ложь,, Ложь);
				Если ЗначениеЗаполнено(КартыКонтрагента) Тогда 
					ЛицевыеСчета       = "";
					Баланс 			   = "";
					
					СимвольныйКодВалюты = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
					ИконкиУведомлений   = Справочники.Карты.ПолучитьИконкиУведомлений();
					
					// ОбменДаннымиСерверСтоматология.ДобавитьЛицевыеСчетаВОбновляемыеПоля(ЛицевыеСчета, Баланс, СтрокаТаблицыДанных.Контрагент, ИконкиУведомлений, СимвольныйКодВалюты);
					
					// Для Каждого КартаКонтрагента Из КартыКонтрагента Цикл
					//	РегистрыСведений.СтекОбновленияЭлектронныхКарт.ДобавитьЗаписьВСтек(КартаКонтрагента, "accounts", ЛицевыеСчета); 
					//	РегистрыСведений.СтекОбновленияЭлектронныхКарт.ДобавитьЗаписьВСтек(КартаКонтрагента, "balance" , Баланс); 
					// КонецЦикла;
				КонецЕсли;
			Исключение
				
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;	
		
КонецПроцедуры

// Функция - Получить таблицу сделок для данных объекта
//
// Параметры:
//  ДанныеТриггера		 - 	 - 
//  ТаблицаДанныхОбъекта - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуСделокДляДанныхОбъекта(ДанныеТриггера, ТаблицаДанныхОбъекта, СтрокаПлан)
	
	Запрос = Новый Запрос;                                 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаДанныхОбъекта, "ТаблицаОбъектов");
	
	Запрос.УстановитьПараметр("ВидСделки", СтрокаПлан.ВидСделки);
	
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПланЛеченияСозданиеПланаЛечения Тогда
		
#Область СделкиПоПлануЛечения
		
		МассивПлановЛечения = ТаблицаДанныхОбъекта.ВыгрузитьКолонку("ПланЛечения");
		УсловиеПоискаСделок = "Сделки.ПланЛечения В
		|			(&МассивПлановЛечения)";
		Запрос.УстановитьПараметр("МассивПлановЛечения", МассивПлановЛечения);
		
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	Сделки.Ссылка КАК Сделка,
		               |	Сделки.ВидСделки КАК ВидСделки,
		               |	Сделки.ЭтапСделки КАК ЭтапСделки,
		               |	Сделки.ДатаСделки КАК ДатаСделки,
		               |	Сделки.ПланЛечения КАК ПланЛечения,
		               |	Сделки.РезультатСделки КАК РезультатСделки,
		               |	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки
		               |ПОМЕСТИТЬ ТаблицаСделок
		               |ИЗ
		               |	Справочник.Сделки КАК Сделки
		               |ГДЕ
		               |	Сделки.ПометкаУдаления = ЛОЖЬ
		               |	И Сделки.ВидСделки = &ВидСделки
		               |	И &УсловиеПоискаСделок
		               |	И Сделки.СтруктурнаяЕдиница В
		               |			(ВЫБРАТЬ
		               |				ТаблицаОбъектов.СтруктурнаяЕдиница
		               |			ИЗ
		               |				ТаблицаОбъектов)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТаблицаСделок.Сделка) КАК КоличествоСделок,
		               |	ТаблицаСделок.ПланЛечения КАК ПланЛечения
		               |ПОМЕСТИТЬ ТаблицаКоличестваСделок
		               |ИЗ
		               |	ТаблицаСделок КАК ТаблицаСделок
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ТаблицаСделок.ПланЛечения
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	МАКСИМУМ(ТаблицаСделок.ДатаСделки) КАК ДатаСделки,
		               |	ТаблицаСделок.ПланЛечения КАК ПланЛечения
		               |ПОМЕСТИТЬ ТаблицаПоследнихОткрытыхСделок
		               |ИЗ
		               |	ТаблицаСделок КАК ТаблицаСделок
		               |ГДЕ
		               |	ТаблицаСделок.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ТаблицаСделок.ПланЛечения
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	МАКСИМУМ(ТаблицаСделок.ДатаЗавершенияСделки) КАК ДатаЗавершенияСделки,
		               |	ТаблицаСделок.ПланЛечения КАК ПланЛечения
		               |ПОМЕСТИТЬ ТаблицаПоследнихЗакртыхСделок
		               |ИЗ
		               |	ТаблицаСделок КАК ТаблицаСделок
		               |ГДЕ
		               |	НЕ ТаблицаСделок.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ТаблицаСделок.ПланЛечения
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
