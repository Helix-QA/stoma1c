
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущийПользователь = ПараметрыСеанса.ТекущийСотрудник;
	Элементы.Изменить.Видимость = РольДоступна(Метаданные.Роли.ПолныеПрава);
	Элементы.СоздатьСделку.Видимость = ПравоДоступа("Добавление", Метаданные.Справочники.Сделки);
	Если Элементы.СоздатьСделку.Видимость Тогда 
		МассивВидовСделок = ПолучитьВидыСделок();
		Элементы.СоздатьСделку.Доступность = НЕ МассивВидовСделок.Количество() = 0;
		Если МассивВидовСделок.Количество() > 1 Тогда
			Элементы.СоздатьСделку.Отображение = ОтображениеКнопки.КартинкаИТекст;
		Иначе 
			Элементы.СоздатьСделку.Отображение = ОтображениеКнопки.Текст;
		КонецЕсли;	
	КонецЕсли;
	
	// Должно вызываться до загрузки настроек из хранилища и формирования механизма фильтрации данных.
	ЗаполнитьОтборПоВидуСделки();
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Инициализируем настройки при первом открытии формы
	Если ХранилищеСистемныхНастроек.Загрузить("Справочник.Сделки.Форма.ФормаСпискаНовая/ТекущиеДанные") = Неопределено Тогда
		Настройки = Новый Соответствие;
		ХранилищеСистемныхНастроек.Сохранить("Справочник.Сделки.Форма.ФормаСпискаНовая/ТекущиеДанные", ,Настройки);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ИнициализироватьКонтекстноеМенюСменыВидаСделки();
	УстановитьОтображениеФильтраСтатусПациента(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОТБОРЫ_СПИСКА_СДЕЛОК" Тогда 
		ИнициализироватьМеханизмФильтрацииДанных(Параметр.Отбор, Истина);
	ИначеЕсли ИмяСобытия = "ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ" Тогда
		УстановитьЗаголовкиДополнительныхОтборов();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события при загрузке данных из настроек на сервере.
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если Параметры.Свойство("ПараметрыОтбора") Тогда
		ОбновитьМеханизмФильтрацииДанных(Параметры.ПараметрыОтбора, Истина);
		
	Иначе
		ИнициализироватьМеханизмФильтрацииДанных(Параметры.Отбор, Истина);
		
	КонецЕсли;
	
	СоздатьУсловноеОформление();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура, обработчик события "СписокВыбор".
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущаяСтрока 		 = Элементы.Список.ТекущиеДанные;
	
	Если Поле.Имя = "ЗапланированнаяПредварительнаяЗаписьДата"
		И ЗначениеЗаполнено(ТекущаяСтрока.ЗапланированнаяПредварительнаяЗапись) Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.ЗапланированнаяПредварительнаяЗапись);
	
	ИначеЕсли Поле.Имя = "ПоследняяЗадачаЗадачаНазначеннаяДата"
		И ЗначениеЗаполнено(ТекущаяСтрока.ПоследняяЗадача) Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.ПоследняяЗадача);
		
	ИначеЕсли Поле.Имя = "ЗапланированнаяЗадачаЗадачаНазначеннаяДата"
		И ЗначениеЗаполнено(ТекущаяСтрока.ЗапланированнаяЗадача)Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.ЗапланированнаяЗадача);
		
	ИначеЕсли Поле.Имя = "Клиент" 
		И ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.Контрагент);
		
	Иначе
		
		ПоказатьЗначение(,ТекущаяСтрока.Сделка);
		
	КонецЕсли;

КонецПроцедуры

