// Процедура - Изменить элемент длительности приема
//
Процедура ИзменитьЭлементДлительностиПриема(НовоеВремя, СтароеВремя, ПервоеОткрытиеФормы = Ложь, УдаляемаяДлительность = Неопределено)
	
	Если НовоеВремя = СтароеВремя Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементНовогоВремени = Элементы.Найти("ГруппаВыводаКнопокДлительности_"+НовоеВремя+"");
	ЭлементСтарогоВремени = Элементы.Найти("ГруппаВыводаКнопокДлительности_"+СтароеВремя+"");
	
	// Удаление/ перекраска старого элемента длительности.		
	
	ЭтоСтандартныйЭлементДлительности = СписокИнтерваловДлительностиПриема.НайтиПоЗначению(СтароеВремя);	
	
	Если ЭлементСтарогоВремени <> Неопределено Тогда // Такой элемент есть
		
		Если ЭтоСтандартныйЭлементДлительности <> Неопределено Тогда
			ЭлементСтарогоВремени.ЦветФона = Новый Цвет(242, 242, 242);
			ЭлементСтарогоВремени.ПодчиненныеЭлементы[0].ЦветТекста = Новый Цвет(77, 77, 77);	
		Иначе	
			СписокИнтерваловДлительностиПриема[0].Значение = СтароеВремя;
			УдалитьЭтуДлительностьПриема("УдалитьСтрокуТЧ");
			Возврат;	
		КонецЕсли;	
		
	Иначе // Такого элемента нет, перекрашиваем в серый все элементы.
		
		Для Каждого ГруппаСДлительностьюОбщая Из Элементы.ГруппаВыводаКнопокДлительности.ПодчиненныеЭлементы Цикл
			
			Для Каждого ГруппаСДлительностью Из ГруппаСДлительностьюОбщая.ПодчиненныеЭлементы Цикл
				Если ТипЗнч(ГруппаСДлительностью) = Тип("ГруппаФормы") Тогда
					ГруппаСДлительностью.ЦветФона = Новый Цвет(242, 242, 242);
					ГруппаСДлительностью.ПодчиненныеЭлементы[0].ЦветТекста = Новый Цвет(77, 77, 77);
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;	
		
	КонецЕсли;
	
	// Создание/ покраска нового элемента длительности	
	Если НЕ ЭлементНовогоВремени = Неопределено И (НЕ ПервоеОткрытиеФормы ИЛИ СписокИнтерваловДлительностиПриема[0].Значение = "N") Тогда
		
		Если НЕ УдаляемаяДлительность = Неопределено Тогда
			СохранитьИлиУдалитьДлительностиПриемаНаСервере(?(НовоеВремя = 0, 0, Неопределено), УдаляемаяДлительность);
		КонецЕсли;
		
		КнопкаКнопкаДлительности_N = Элементы.Найти("КнопкаДлительности_N");
		Если НЕ КнопкаКнопкаДлительности_N = Неопределено Тогда
			КнопкаКнопкаДлительности_N.Видимость = Истина;	
		КонецЕсли;
		
		КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
		Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
			КнопкаУдалитьЭлементДлительностиПриема.Видимость = Ложь;	
		КонецЕсли;		
		
	Иначе // Создаем новый элемент времени
		
		Если НЕ ПервоеОткрытиеФормы Тогда
			СохранитьИлиУдалитьДлительностиПриемаНаСервере(НовоеВремя, УдаляемаяДлительность);			
		КонецЕсли;
		
		КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
		Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
			КнопкаУдалитьЭлементДлительностиПриема.Видимость = Истина;	
		КонецЕсли;
		
		КнопкаКнопкаДлительности_N = Элементы.Найти("КнопкаДлительности_N");
		Если НЕ КнопкаКнопкаДлительности_N = Неопределено Тогда
			КнопкаКнопкаДлительности_N.Видимость = Ложь;	
		КонецЕсли;
		
		СписокИнтерваловДлительностиПриема[0].Значение = НовоеВремя;
		ЭлементНовогоВремени = Элементы.Найти("ГруппаВыводаКнопокДлительности_"+НовоеВремя+"");
		
	КонецЕсли;
	
	ЭлементНовогоВремени.ЦветФона = Новый Цвет(25 , 116, 206);
	ЭлементНовогоВремени.ПодчиненныеЭлементы[0].ЦветТекста = Новый Цвет(255 , 255, 255);
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ИзменитьДлительностьПриема" 
//
Процедура ИзменитьДлительностьПриема(Команда)
		
	НажатаяКнопка = Элементы.Найти(ТекущийЭлемент.Имя);
	НажатаяКнопка.Видимость = Ложь;
		
	ЭтотОбъект.НовыйЭлементДлительностиПриема = ?(НажатаяКнопка.Имя = "КнопкаДлительности_N", 0, Число(СтрРазделить(ТекущийЭлемент.Имя, "_", Ложь)[1]));

	КнопкаСохранитьЭлементДлительностиПриема = Элементы.Найти("СохранитьЭлементДлительностиПриема");
	Если НЕ КнопкаСохранитьЭлементДлительностиПриема = Неопределено Тогда
		КнопкаСохранитьЭлементДлительностиПриема.Видимость = Истина;	
	КонецЕсли;
	
	СписокИнтерваловДлительностиПриема[0].Значение = ?(ЗначениеЗаполнено(ЭтотОбъект.НовыйЭлементДлительностиПриема), ЭтотОбъект.НовыйЭлементДлительностиПриема, "N");
 	
	КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
	Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
		КнопкаУдалитьЭлементДлительностиПриема.Видимость = Ложь;	
	КонецЕсли;	
	
	ПолеВводаНовыйЭлементДлительностиПриема = Элементы.Найти("НовыйЭлементДлительностиПриема");
	Если НЕ ПолеВводаНовыйЭлементДлительностиПриема = Неопределено Тогда
		ПолеВводаНовыйЭлементДлительностиПриема.Видимость = Истина;
		ЭтаФорма.ТекущийЭлемент =  ПолеВводаНовыйЭлементДлительностиПриема;
	КонецЕсли;
	
КонецПроцедуры

