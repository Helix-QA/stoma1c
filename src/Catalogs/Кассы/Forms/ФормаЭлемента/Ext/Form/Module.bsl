&НаСервере       
// Процедура, обработчик получения кассы терминала.
//
Функция ПолучитьКассуТерминала(Терминал, ЭтаКасса)
	
	ЗапросКассаТерминала = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЭквайринговыеТерминалыКассы.Ссылка КАК Касса
	|ИЗ
	|	Справочник.Кассы.ЭквайринговыеТерминалы КАК ЭквайринговыеТерминалыКассы
	|ГДЕ
	|	ЭквайринговыеТерминалыКассы.ЭквайринговыйТерминал = &ЭквайринговыйТерминал
	|	И ЭквайринговыеТерминалыКассы.Ссылка <> &Касса");
	
	ЗапросКассаТерминала.УстановитьПараметр("ЭквайринговыйТерминал"	, Терминал);
	ЗапросКассаТерминала.УстановитьПараметр("Касса"					, ЭтаКасса);
	
	РезультатКассаТерминала = ЗапросКассаТерминала.Выполнить().Выбрать();
	
	Если РезультатКассаТерминала.Следующий() Тогда
		Возврат РезультатКассаТерминала.Касса;	
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

&НаКлиенте
// Процедура, обработчик при изменении типа кассы.
//
Процедура ТипКассыПриИзменении(Элемент)
	
	УстановитьСотсояниеЭлементов();	
	
	Если Объект.ТипКассы = ПредопределенноеЗначение("Перечисление.ТипыКасс.КассаПредприятия") Тогда 	
		
		Объект.ИспользоватьБезПодключенияОборудования = Истина;
		Объект.БлокироватьПечатьЧека 					   = Ложь;
		Объект.ЭквайринговыйТерминал 					   = Неопределено;
		Объект.ВнешнееОборудование 						   = Неопределено;
		Объект.КассаДляСдачиВыручки 					   = Неопределено;
		Объект.АвтСдачаВыемкиПриЗакрытииСмены 			   = Ложь;
		Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения = Ложь;                                  	
		Объект.АвтоматическоеСписаниеМатериалов			   = Ложь;

	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик при изменении выключателя.
//
Процедура ЗавершатьАвтоматическиОперацииВемкиВнесенияПриИзменении(Элемент)
	Элементы.ГруппаКассаПредприятия.Видимость = Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения;	
	Элементы.КассаДляСдачиВыручки.Видимость	  = Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения;	
	
	Если Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения = Ложь Тогда
		Объект.КассаДляСдачиВыручки = Неопределено;
	КонецЕсли;
КонецПроцедуры

