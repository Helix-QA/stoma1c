// Функция, возвращает сформированную строку чека.
//
Функция СформироватьПозициюАвансаЧека(Статья, Сумма)
	
	НомерСекции = 2;  	
	Наименование = ?(Статья = Справочники.СтатьиДоходовИРасходов.ВзносНаЛицевойСчет,
					НСтр("ru = 'Взнос на лицевой счет:'"), НСтр("ru = 'Взнос Аванса:'"));
								
	ПозицияЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
	
	ПозицияЧека.Наименование		= Наименование + " " + Объект.Контрагент;
	ПозицияЧека.Количество			= 1; 
	ПозицияЧека.СтоимостьБезСкидки  = Сумма;
	ПозицияЧека.СуммаСкидки         = 0;
	ПозицияЧека.СтоимостьСоСкидкой	= Сумма;	
	ПозицияЧека.СтавкаНДС 			= МенеджерОборудованияВызовСервера.ПолучитьНДСПриВзносеНаЛицевойСчет(Объект.СтруктурнаяЕдиница.Организация);
	ПозицияЧека.СуммаНДС     		= Ценообразование.РассчитатьСуммуНДС(Сумма, ПозицияЧека.СтавкаНДС);
	ПозицияЧека.НомерСекции 		= НомерСекции;
	ПозицияЧека.Штрихкод 			= null;
	ПозицияЧека.СуммаОплачено       = ?(ПозицияЧека.СтоимостьСоСкидкой > Сумма, Сумма, ПозицияЧека.СтоимостьСоСкидкой);
	ПозицияЧека.ЭтоОплатаКредита    = Ложь;

	Возврат ПозицияЧека;	
	
КонецФункции

