// Возвращает строку, полученную из массива элементов, разделенных символом разделителя
//
// Параметры:
//  Массив - Массив - массив элементов из которых необходимо получить строку
//  Разделитель - Строка - любой набор символов, который будет использован как разделитель между элементами в строке
//
// Возвращаемое значение:
//  Результат - Строка - строка, полученная из массива элементов, разделенных символом разделителя
// 
Функция ПолучитьСтрокуИзМассиваПодстрок(Массив, Разделитель = ",") Экспорт
	
	// возвращаемое значение функции
	Результат = "";
	
	Для Каждого Элемент ИЗ Массив Цикл
		
		Подстрока = ?(ТипЗнч(Элемент) = Тип("Строка"), Элемент, Строка(Элемент));
		
		РазделительПодстрок = ?(ПустаяСтрока(Результат), "", Разделитель);
		
		Результат = Результат + РазделительПодстрок + Подстрока;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// функция из текста формирует массив строк, разбитых по заданной ширине
//
Функция РазбитьТекстНаСтроки(Знач Текст, ШиринаСтрок) Экспорт
	
	ТаблицаШириныСимволов = Неопределено;
	
	МассивСтрок = Новый Массив;
	МассивШиринаСтрок = Новый Массив;
	Если ТипЗнч(ШиринаСтрок) = Тип("Строка") Тогда
		МассивШиринаСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ШиринаСтрок, ",");
	ИначеЕсли ТипЗнч(ШиринаСтрок) = Тип("Число") Тогда
		МассивШиринаСтрок.Добавить(ШиринаСтрок);
	КонецЕсли;
	
	Для Каждого ШиринаСтроки Из МассивШиринаСтрок Цикл
		ШиринаСтроки = Число(ШиринаСтроки);// М*
		// Вычислим необходимое количество символов строки
		ВремШиринаСтроки = 0;
		ВремДлинаСтроки = 0;
		Пока ВремШиринаСтроки < ШиринаСтроки И ВремДлинаСтроки < СтрДлина(Текст) Цикл
			ВремДлинаСтроки = ВремДлинаСтроки + 1;
			ВремШиринаСтроки = ВремШиринаСтроки + ШиринаСимвола(Сред(Текст, ВремДлинаСтроки, 1), Истина, ТаблицаШириныСимволов);
			Если Сред(Текст, ВремДлинаСтроки, 1) = Символы.ПС Тогда 
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		// Сделаем перенос по словам
		Если Сред(Текст, ВремДлинаСтроки, 1) <> Символы.ПС Тогда 
			Счетчик = 0;
			Пока Счетчик < ВремДлинаСтроки И ВремШиринаСтроки >= ШиринаСтроки Цикл
				Если Сред(Текст, ВремДлинаСтроки - Счетчик, 1) = " " Тогда
					ВремДлинаСтроки = ВремДлинаСтроки - Счетчик;
					Прервать;
				КонецЕсли;
				Счетчик = Счетчик + 1;
			КонецЦикла;
		КонецЕсли;
		
		ОбрезаннаяСтрока = Сред(Текст, 1, ВремДлинаСтроки);
		МассивСтрок.Добавить(ОбрезаннаяСтрока);
		Текст = Сред(Текст, СтрДлина(ОбрезаннаяСтрока) + 1);
		
		Если Текст <> "" И ТипЗнч(ШиринаСтрок) = Тип("Число") Тогда 
			МассивШиринаСтрок.Добавить(ШиринаСтрок);
		КонецЕсли;		
		
	КонецЦикла;

	Возврат МассивСтрок;
	
КонецФункции          

// функция определяет ширину символа
//
// Параметры
//  Символ - Строка, символ ширину которого необходимо вернуть
//  ПрямоеОпределение - Число, определять ширину символа, или среднюю ширину
//
// Возвращаемое значение:
//   Число
//
Функция ШиринаСимвола(Символ, ПрямоеОпределение = Истина, ТаблицаШириныСимволов = Неопределено) Экспорт
	
	Если ТаблицаШириныСимволов = Неопределено Тогда
		ТаблицаШириныСимволов = Новый ТабличныйДокумент;
		ТаблицаШириныСимволов.Область(1, 1).Текст = "ЙЫИ";
		ТаблицаШириныСимволов.Область(1, 1).Расшифровка = 40 / 31;
		ТаблицаШириныСимволов.Область(2, 1).Текст = "ЦУКНЗХВПЛСЬБвъRUSDHKZXCBN";
		ТаблицаШириныСимволов.Область(2, 1).Расшифровка = 40 / 40;
		ТаблицаШириныСимволов.Область(3, 1).Текст = "ЕГРИТЁ023456789_=+?йцуенхапролдэячситьбETPFLqeyuopasdghzxcvbn";
