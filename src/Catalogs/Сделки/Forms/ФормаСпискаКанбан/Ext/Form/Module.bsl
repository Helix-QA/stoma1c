// Функция, сворачивает всплывающие меню и возвращает свернутые элементы.
//
Функция СвернутьВсплывающиеМеню(ДанныеСобытия)
	
	СвернутыеМеню = Новый Массив;
	
	ЭлементМеню = ДанныеСобытия.Element.closest(".menu");
	
	АктивныеЭлементыМеню = ДанныеСобытия.Document.querySelectorAll(".menu.active");
	
	Для Каждого Меню Из АктивныеЭлементыМеню Цикл
		
		// Не сворачиваем активное меню при нажатии.
		Если Меню = ЭлементМеню Тогда
			Продолжить;
		КонецЕсли;
		
		Меню.classList.toggle("active");
		СвернутыеМеню.Добавить(Меню);
		
	КонецЦикла;
	
	Возврат СвернутыеМеню
	
КонецФункции

