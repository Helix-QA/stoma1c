// Процедура, обработчик команды.
//
Процедура СоздатьПисьмо(Команда)
	
	Если Не ПроверитьВидимостьВсплывающихГрупп("Письмо") Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВзаимодействиеПослеВопросаОЗаписиЗаявки", ЭтотОбъект, Новый Структура("ВыполнитьДействие", "СоздатьПисьмо"));
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Для отправки электронного письма нужно произвести запись заявки. Записать?'; en = 'To send an email you need to record the application. To record?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		Если Модифицированность И Не ЭтаФорма.Записать() Тогда
			Возврат;
		КонецЕсли;
		
		СоздатьПисьмоНаКлиенте();
		
	КонецЕсли;

КонецПроцедуры

