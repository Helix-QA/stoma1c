		Если СтрЧислоВхождений(Команда.Имя,"НеПодтверждена") > 0 Тогда	
			СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.НеПодтверждена");
		ИначеЕсли СтрЧислоВхождений(Команда.Имя,"Подтверждена") > 0 Тогда	
			СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.Подтверждена");
		ИначеЕсли СтрЧислоВхождений(Команда.Имя,"ПациентВКресле") > 0 Тогда
			СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемНачат");	
		ИначеЕсли СтрЧислоВхождений(Команда.Имя,"ПриемОкончен") > 0 Тогда	
			СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемОкончен");
		ИначеЕсли СтрЧислоВхождений(Команда.Имя,"ПриемОтменен") > 0 Тогда
			СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемОтменен");
		ИначеЕсли СтрЧислоВхождений(Команда.Имя,"ПриемНеСостоялся") > 0 Тогда
			СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемНеСостоялся");
