				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ИСТИНА КАК Картинка,
	Сотрудники.Ссылка КАК Ссылка,
	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
ИЗ
	Справочник.Сотрудники КАК Сотрудники
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			НастройкиСотрудников.Сотрудник КАК Сотрудник,
			НастройкиСотрудников.ДатаУвольнения КАК ДатаУвольнения
		ИЗ
			РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		ГДЕ
			НастройкиСотрудников.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница) КАК Настройки
		ПО Сотрудники.Ссылка = Настройки.Сотрудник
ГДЕ
	Сотрудники.ПометкаУдаления = ЛОЖЬ
	И Сотрудники.Служебный = ЛОЖЬ
	И ВЫБОР
			КОГДА ЕСТЬNULL(Настройки.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И Сотрудники.Ссылка В
			(ВЫБРАТЬ
				Пользователи.Сотрудник.Ссылка КАК СотрудникСсылка
			ИЗ
				Справочник.Пользователи КАК Пользователи
			ГДЕ
				Пользователи.ЭтоПользовательИБ
				И НЕ Пользователи.ПометкаУдаления)</QueryText>
