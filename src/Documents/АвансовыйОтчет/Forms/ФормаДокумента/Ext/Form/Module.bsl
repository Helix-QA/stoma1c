// Процедура, обработчик события "НачалоВыбора"
//
Процедура РасходыПартияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущаяСтрока = Элементы.Расходы.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Номенклатура) Тогда
		
		мПараметрыВыбора = Новый Структура;
		мПараметрыВыбора.Вставить("Владелец"                       , ТекущаяСтрока.Номенклатура);
		мПараметрыВыбора.Вставить("Склад"                          , ТекущийСклад);
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница"             , Объект.СтруктурнаяЕдиница);
		мПараметрыВыбора.Вставить("Дата"                           , Объект.Дата);
		мПараметрыВыбора.Вставить("НеКонтролироватьОстаткиПоСкладу", Истина);
        мПараметрыВыбора.Вставить("МножественныйВыбор"             , Ложь);

		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", мПараметрыВыбора,,,,,Новый ОписаниеОповещения("ЗапасыРасходыПартияНачалоВыбораЗавершение", ЭтотОбъект, ТекущаяСтрока), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;
	
КонецПроцедуры

