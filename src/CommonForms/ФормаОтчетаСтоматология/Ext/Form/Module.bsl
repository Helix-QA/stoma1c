&НаКлиенте
// Процедура, открывает групповую обработку изменения клиентов.
//
Процедура ИзменитьКлиентовИзОтчета()
	
	МассивКонтрагентов = ПолучитьМассивКонтрагентовИзРезультата();
	Если МассивКонтрагентов.Количество() > 0 Тогда	
		ПараметрыФормы = Новый Структура("МассивОбъектов", МассивКонтрагентов);
		ОткрытьФорму("Обработка.ГрупповоеИзменениеОбъектов.Форма", ПараметрыФормы);
	Иначе
		ПоказатьПредупреждение(,НСтр("ru='В отчете не найдены пациенты!';en='No clients found in report!'"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, создает сегмент клиентов из отчета.
//
Процедура СоздатьСегментКлиентовИзОтчета()
	
	МассивКонтрагентовОбщий = ПолучитьМассивКонтрагентовИзРезультата();
	
	МассивКонтрагентов = Новый Массив;
	Для Каждого СтрокаМассива Из МассивКонтрагентовОбщий Цикл
		Если ТипЗнч(СтрокаМассива) = Тип("СправочникСсылка.Контрагенты") Тогда
			МассивКонтрагентов.Добавить(СтрокаМассива);
		КонецЕсли;
	КонецЦикла;
	Если МассивКонтрагентов.Количество() > 0 Тогда
		СозданныйСегмент = СформироватьСегментКлиентовИзОтчета(МассивКонтрагентов);
		ПоказатьЗначение(, СозданныйСегмент);
	Иначе
		ПоказатьПредупреждение(,НСтр("ru='В отчете не найдены пациенты!';en='No clients found in report!'"));
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Функция, созадает сегмент клиентов из отчета.
//
Функция СформироватьСегментКлиентовИзОтчета(МассивКлиентов)
	
	СпрОбъект = Справочники.СегментыКонтрагентов.СоздатьЭлемент();
	// СпрОбъект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	СпрОбъект.СпособФормирования = Перечисления.СпособыФормированияСегментов.ФормироватьВручную;
	СпрОбъект.ДатаСоздания       = ТекущаяДатаСеанса();
	СпрОбъект.Наименование       = "Сегмент из отчета: " + НаименованиеОтчета;
	// СпрОбъект.Сотрудник          = ПараметрыСеанса.ТекущийПользователь;
	
	СпрОбъект.Записать();
	
	Сегменты.СформироватьПоМассиву(СпрОбъект.Ссылка, МассивКлиентов);
	
	Возврат СпрОбъект.Ссылка;
	
КонецФункции

&НаКлиенте
// Процедура, обновляет сегмент клиентов из отчета.
//
Процедура ОбновитьСегментИзОтчета()
	
	ПараметрыОкрытияФормы = Новый Структура("Отбор", Новый Структура("СпособФормирования, ПометкаУдаления", ПредопределенноеЗначение("Перечисление.СпособыФормированияСегментов.ФормироватьВручную"), Ложь));
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьСегментИзОтчетаЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.СегментыКонтрагентов.ФормаВыбора", ПараметрыОкрытияФормы,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события завершения.
//
Процедура ОбновитьСегментИзОтчетаЗавершение(Результат, Параметры) Экспорт
	
	Если Не Результат = Неопределено Тогда
		МассивКонтрагентов = ПолучитьМассивКонтрагентовИзРезультата();
		Если МассивКонтрагентов.Количество() > 0 Тогда
			ОбновленныйСегмент = ОбновитьСегментКлиентовИзОтчета(Результат, МассивКонтрагентов);
			ПоказатьЗначение(, ОбновленныйСегмент);
		Иначе
			ПоказатьПредупреждение(,НСтр("ru='В отчете не найдены пациенты!';en='No clients found in report!'"));
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, обновляет сегмент клиентов из отчета.
//
Функция ОбновитьСегментКлиентовИзОтчета(Сегмент, МассивКлиентов)
	
    Сегменты.ОбновитьСегментПоМассиву(Сегмент, МассивКлиентов); 
	Возврат Сегмент;
	
КонецФункции

&НаСервере
// Функция - Получить номера телефонов контрагента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНомераТелефоновКонтрагента(Контрагент) 
	
	ТелефоныКонтрагента = Новый Массив;
	Если ЗначениеЗаполнено(Контрагент) И ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		Отбор = Новый Структура("Вид, НеУчаствоватьВРассылке", Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, Ложь);
		НайденныеСтроки = Контрагент.КонтактнаяИнформация.НайтиСтроки(Отбор);
		
		Для Каждого Контакт Из НайденныеСтроки Цикл
			Если ЗначениеЗаполнено(Контакт.НомерТелефона) Тогда
				ТелефоныКонтрагента.Добавить(Контакт.НомерТелефона);
			КонецЕсли;
		КонецЦикла;
				
	КонецЕсли;
	
	Возврат ТелефоныКонтрагента;
	
КонецФункции

&НаКлиенте
// Процедура - обработчик команды "СоздатьДокументПоЗапасам"
//
Процедура СоздатьДокументПоЗапасам(Команда)
	
	// Получим структуру данных
	СтруктураЗаполнения = ПолучитьСтруктуруДанных();
	ГруппировкаНоменклатура = Ложь;
	
	// Проверим, не убрал ли пользователь группировку "Номенклатура"
	Для Каждого ЭлементМассива Из СтруктураЗаполнения.МассивЗапасов Цикл 
		Если ЭлементМассива.Свойство("Номенклатура") Тогда 
			ГруппировкаНоменклатура = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;		
	
	Если ГруппировкаНоменклатура Тогда 		
		Если СтруктураЗаполнения.МассивСкладов.Количество() > 1 Тогда
			ЗаполнитьДокумент(СтруктураЗаполнения.МассивЗапасов, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, , Команда.Имя);
		ИначеЕсли СтруктураЗаполнения.МассивСкладов.Количество() = 1 Тогда
			Если ТипЗнч(СтруктураЗаполнения.МассивСкладов[0]) = Тип("СправочникСсылка.Склады") Тогда 
				ЗаполнитьДокумент(СтруктураЗаполнения.МассивЗапасов, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, СтруктураЗаполнения.МассивСкладов[0], Команда.Имя);		
			ИначеЕсли ТипЗнч(СтруктураЗаполнения.МассивСкладов[0]) = Тип("СправочникСсылка.Сотрудники") Тогда
				Склад = ПолучитьСкладПоСотруднику(СтруктураЗаполнения.СтруктурнаяЕдиница, СтруктураЗаполнения.МассивСкладов[0]);
				ЗаполнитьДокумент(СтруктураЗаполнения.МассивЗапасов, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, ?(Склад = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка"), Неопределено, Склад), Команда.Имя);		
			КонецЕсли;
		ИначеЕсли СтруктураЗаполнения.МассивСкладов.Количество() = 0 Тогда	
			ЗаполнитьДокумент(СтруктураЗаполнения.МассивЗапасов, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, , Команда.Имя);
		КонецЕсли;	
	Иначе 
		ПоказатьВопрос(Неопределено, НСтр("ru='Установите в настройках отчета группировку Номенклатура!';en='Set the Nomenclature grouping in the report settings!'"), РежимДиалогаВопрос.ОК, , , НСтр("ru='Сообщение';en='Message'"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, показать всплывающую группу "ГруппаВзаимодействиеЗадачаВсплывающая".
// Устанавливает видимость элементов группы, а так же показывает группу.
//
Процедура ПоказатьВсплывающуюГруппу()

	ЭтотОбъект.ТаблицаДействия.Очистить();
	ЭтотОбъект.ВзаимодействиеПараметры = Неопределено;
	
	Если ЭтотОбъект.СоздатьЗадачу Тогда
		
		// Подтягиваем первый вид задачи из списка.
		Если ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора.Количество() > 0 Тогда
			Взаимодействие = ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора[0];
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Пустая таблица видов взаимодействия';en='Nasty table species interactions'"));
			Возврат;
		КонецЕсли;
		
		// Заполняем произвольный реквизит формы.
		ЭтотОбъект.ВзаимодействиеПараметры = Новый Структура;
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Взаимодействие"   , Взаимодействие.Значение.Взаимодействие);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("ВидВзаимодействия", Взаимодействие.Значение.ВидВзаимодействия);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("ТемаПоУмолчанию"  , Взаимодействие.Значение.ТемаПоУмолчанию);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Представление"    , Взаимодействие.Представление);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Картинка"         , Взаимодействие.Картинка);
		
		Элементы.ВыбратьВидЗадачиСделки.Заголовок 			= Взаимодействие.Значение.ВидВзаимодействия; 
		Элементы.ДекорацияВзаимодействиеИконка.Картинка     = ЭтотОбъект.ВзаимодействиеПараметры.Картинка;

		// Установить тему по умолчанию.
		ЭтотОбъект.ВзаимодействиеЗадачаТема  = ЭтотОбъект.ВзаимодействиеПараметры.ТемаПоУмолчанию;
		ЭтотОбъект.ВзаимодействиеОписание = "";

		// Установить дату взаимодействия.
		ЭтотОбъект.ВзаимодействиеЗадачаДата = ПолучитьОкругленноеВремяВзаимодействия();	
		ВзаимодействиеЗадачаДатаПриИзмененииНаСервере();

		// Обновить режим напоминания взаимодействия.
		РежимНапоминанияПоУмолчанию = ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминанияСписокВыбора[0];		
		
		ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминания    = РежимНапоминанияПоУмолчанию.Значение;
		Элементы.ВзаимодействиеЗадачаНапоминание.Заголовок = РежимНапоминанияПоУмолчанию.Представление;
		
		Элементы.ВзаимодействиеЗадачаПрочееТема.Видимость 	= Истина;
		Элементы.ВзаимодействиеЗадачаНапоминание.Видимость 	= Истина;
		Элементы.ГруппаВзаимодействиеВид.Видимость			= Истина;
		Элементы.ГруппаВзаимодействиеЗадачаДата.Видимость	= Истина;
		Элементы.ГруппаВидСделки.Видимость					= Ложь;
		
	Иначе
			
		Элементы.ВзаимодействиеЗадачаПрочееТема.Видимость 	= Ложь;
		Элементы.ВзаимодействиеЗадачаНапоминание.Видимость 	= Ложь;
		Элементы.ГруппаВзаимодействиеВид.Видимость			= Ложь;
		Элементы.ГруппаВзаимодействиеЗадачаДата.Видимость	= Ложь;	
		Элементы.ГруппаВидСделки.Видимость					= Истина;
		
		// Устанавливаем первый попавшийся вид сделки.
		МассивВидовСделок = ПолучитьВидыСделок();
		Если МассивВидовСделок.Количество() > 0 Тогда
			ЭтотОбъект.ВидСделки = МассивВидовСделок[0];
		КонецЕсли;
		
	КонецЕсли;
	
	// Меняем фокус, что бы скрыть вслывающую группу, изменить ее вид и корректно показать на форме.
	СменитьФокусЭлементаНаКлиенте();
	Элементы.ГруппаВзаимодействиеЗадачаВсплывающая.Показать();

КонецПроцедуры

