			Комментарий 		= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария, СокрЛП(Строка(ГенерируемаяСделка.ВидСделки)));		
		//ИначеЕсли ТаблицаДоступныхВидовСделокПоСтатусам.Количество() = 0 Тогда 
		//	ШаблонКомментария 	= НСтр("ru = 'Создание сделок с видом ""%1"" запрещено для пациентов со статусом ""%2""! Обратитесь к администратору базы данных!'");
		//	Комментарий 		= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария, СокрЛП(Строка(ГенерируемаяСделка.ВидСделки)), СокрЛП(Строка(СтатусПациента)));				
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(Комментарий) Тогда 
			Отказ = Истина;
			Если СообщатьПользователю Тогда 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Комментарий, ГенерируемыйОбъект);
			КонецЕсли;	
			Возврат;
		КонецЕсли;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Пациент) 
		ИЛИ НЕ ГенерируемаяСделка.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ГенерируемаяСделка.Специализация) Тогда 
		Специализация = ГенерируемаяСделка.Специализация;
	Иначе 
		Специализация = Справочники.Специализации.ПустаяСсылка();																				
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ВидСделки"			, ГенерируемаяСделка.ВидСделки);		
	Запрос.УстановитьПараметр("Пациент"				, Пациент);
	Запрос.УстановитьПараметр("Врач"				, Врач);
	Запрос.УстановитьПараметр("Специализация"		, Специализация);	
