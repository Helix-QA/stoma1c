		               |			ИЗ
		               |				ТаблицаНеОтработанныхЗаявок)
		               |	И НЕ РасписаниеРаботы.ДеньНедели = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		               |	И РасписаниеРаботы.Активность = ИСТИНА
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаНеОтработанныхЗаявок.Заявка КАК Заявка,
		               |	ТаблицаНеОтработанныхЗаявок.ДатаСоздания КАК ДатаСоздания,
		               |	ТаблицаНеОтработанныхЗаявок.ОсновнойМенеджер КАК ОсновнойМенеджер,
		               |	ТаблицаНеОтработанныхЗаявок.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.ДеньНедели, ДЕНЬНЕДЕЛИ(ТаблицаНеОтработанныхЗаявок.ДатаСоздания)) КАК ДеньНедели,
		               |	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(ТаблицаНеОтработанныхЗаявок.ДатаСоздания, ДЕНЬ), ЧАС, ЧАС(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.НачалоРаботы, ДАТАВРЕМЯ(1, 1, 1)))), МИНУТА, МИНУТА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.НачалоРаботы, ДАТАВРЕМЯ(1, 1, 1)))), СЕКУНДА, СЕКУНДА(ЕСТЬNULL(ТаблицаВремениРаботыСЕ1.НачалоРаботы, ДАТАВРЕМЯ(1, 1, 1)))) КАК НачалоРаботы,
		               |	ВЫБОР
