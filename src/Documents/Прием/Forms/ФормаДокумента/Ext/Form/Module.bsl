&НаСервере
// Процедура - Добавить номенклатуру из документа основания.
//
Процедура ДобавитьНоменклатуруИзДокументаОснования(Знач ДокументОснования, Знач ИдентификаторыНовыхСтрокЛечения, Знач СтрокаИсточника, ОжидаетСогласования = Ложь, НаращиватьКоличество = Ложь)
		
	Если НаращиватьКоличество = Истина Тогда
		
		СтруктураПоиска = Новый Структура();
		Если ОжидаетСогласования = Истина Тогда
			СтруктураПоиска.Вставить("КлючСтроки", СтрокаИсточника.КлючСтроки);	
			СтруктураПоиска.Вставить("СтатусСогласования", Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования);
		Иначе
			СтруктураПоиска.Вставить("КлючСтроки", СтрокаИсточника.КлючСтроки);
		КонецЕсли;
		
		НайденнаяСтрока = Объект.Лечение.НайтиСтроки(СтруктураПоиска);	
		
		Если НайденнаяСтрока.Количество() > 0 Тогда
			
			Если ОжидаетСогласования = Истина 
				И НЕ ЗначениеЗаполнено(НайденнаяСтрока[0].СтатусСогласования) Тогда
				
				НоваяСтрока = Объект.Лечение.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
				НоваяСтрока.Количество = 1;
				
			Иначе
				НоваяСтрока = НайденнаяСтрока[0];
				НоваяСтрока.Количество = НоваяСтрока.Количество + 1;
			КонецЕсли;
			
		Иначе
			НоваяСтрока = Объект.Лечение.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
			НоваяСтрока.Количество = 1;
		КонецЕсли;
	Иначе
		НоваяСтрока = Объект.Лечение.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);	
	КонецЕсли;
		
	Если ОжидаетСогласования = Истина Тогда
		НоваяСтрока.СтатусСогласования = Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования;
		НоваяСтрока.ТребуетсяСогласование = Перечисления.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении;
	КонецЕсли;

	НоваяСтрока.НомерЗаказа                         = СтрокаИсточника.НомерПриема;
	НоваяСтрока.ДокументАванса                      = ДокументОснования;
	НоваяСтрока.КоличествоУпаковок                  = НоваяСтрока.Количество;
	НоваяСтрока.Сотрудник 				 			= Объект.Сотрудник;
	НоваяСтрока.Гарантия 							= НоваяСтрока.Номенклатура.Гарантия;
	НоваяСтрока.КодУслуги                           = НоваяСтрока.Номенклатура.КодУслуги;
	
	Если ПрименятьСкидкиПоПланамЛечения = Ложь
		И Объект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("ДокументАванса") <> Неопределено		
		И ЗначениеЗаполнено(НоваяСтрока.ДокументАванса)
		И ТипЗнч(НоваяСтрока.ДокументАванса) <> Тип("ДокументСсылка.ПланЛечения") Тогда
		
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("ДатаОбработки"	 , Объект.Дата);
		СтруктураДанных.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		СтруктураДанных.Вставить("Номенклатура"		 , НоваяСтрока.Номенклатура);
		СтруктураДанных.Вставить("ВидЦен"			 , Объект.ВидЦен);
		СтруктураДанных.Вставить("Упаковка"			 , НоваяСтрока.Упаковка);
		СтруктураДанных.Вставить("СтавкаНДС"		 , НоваяСтрока.СтавкаНДС);
		
		Цена = Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураДанных);
		НоваяСтрока.Цена = Цена;
	КонецЕсли;
	
	// ОбработкаТабличныхЧастейКлиент.ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(НоваяСтрока);					
	
	// Добавляем материалы данной услуги 
	НормыСписанияМатериалов = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(НоваяСтрока.Номенклатура, Объект.СтруктурнаяЕдиница);

	Для Каждого СтрокаТЧ ИЗ НормыСписанияМатериалов Цикл			
		НоваяСтрокаМатериалы                     = Объект.Материалы.Добавить();
		НоваяСтрокаМатериалы.КлючСтроки          = НоваяСтрока.КлючСтроки;
		НоваяСтрокаМатериалы.Услуга              = НоваяСтрока.Номенклатура;
		НоваяСтрокаМатериалы.Материал            = СтрокаТЧ.Материал;
		НоваяСтрокаМатериалы.КоличествоУпаковок  = ?(СтрокаТЧ.НеЗависитОтКоличестваУслуг, СтрокаТЧ.Количество, СтрокаТЧ.Количество * ?(НоваяСтрока.КоличествоУпаковок = 0, 1, НоваяСтрока.КоличествоУпаковок));
		НоваяСтрокаМатериалы.Количество          = НоваяСтрокаМатериалы.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаТЧ.Упаковка.Коэффициент), СтрокаТЧ.Упаковка.Коэффициент, 1);
		НоваяСтрокаМатериалы.Упаковка            = СтрокаТЧ.Упаковка;
		НоваяСтрокаМатериалы.Партия              = СтрокаТЧ.Партия;		
		НоваяСтрокаМатериалы.Склад               = РегистрыСведений.НормыСписанияМатериалов.ПолучитьСкладСписанияНормМатериалов(СтрокаТЧ, Объект.СтруктурнаяЕдиница, Объект.Сотрудник); 
		НоваяСтрокаМатериалы.Сотрудник           = Объект.Сотрудник;
	КонецЦикла;	
	//// Получаем строку источника заполнения
	// СтрокиИсточникаСкидки = ДокументОснования.СкидкиНаценки.НайтиСтроки(Новый Структура("КлючСтроки",СтрокаИсточника.КлючСтроки));			
	//// Добавим скидки в ТЧ СкидкиНаценки
	// Для Каждого СтрокаСкидки Из СтрокиИсточникаСкидки Цикл 
	//	НоваяСтрокаСкидкиНаценки           			= Объект.СкидкиНаценки.Добавить();
	//	ЗаполнитьЗначенияСвойств(НоваяСтрокаСкидкиНаценки, СтрокаСкидки);
	//	НоваяСтрокаСкидкиНаценки.КлючСтроки         = НоваяСтрока.КлючСтроки;
	// КонецЦикла;
	ИдентификаторыНовыхСтрокЛечения.Добавить(НоваяСтрока.ПолучитьИдентификатор());
	// ТабличныеЧастиПересчетПослеИзменений("Лечение",НоваяСтрока.ПолучитьИдентификатор());

КонецПроцедуры

&НаСервереБезКонтекста
//
//
Функция ВернутьТаблицуНезавершенныхПланирований(Контрагент, СтруктурнаяЕдиница, ДатаДокумента)
	
	Запрос       = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВложенныйЗапрос.ДокументПланирования КАК Ссылка,
	               |	ВложенныйЗапрос.НомерДокумента КАК Номер,
	               |	ВложенныйЗапрос.ДатаДокумента КАК Дата,
	               |	ВложенныйЗапрос.СтатусДокумента КАК Статус,
	               |	ВложенныйЗапрос.Сумма КАК Сумма,
	               |	ВложенныйЗапрос.Сотрудник КАК Сотрудник,
	               |	"""" КАК КлючЭлемента
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		НарядЗаказыОстатки.НарядЗаказ КАК ДокументПланирования,
	               |		НарядЗаказыОстатки.НарядЗаказ.Номер КАК НомерДокумента,
	               |		НарядЗаказыОстатки.НарядЗаказ.Дата КАК ДатаДокумента,
	               |		НарядЗаказыОстатки.НарядЗаказ.Статус КАК СтатусДокумента,
	               |		НарядЗаказыОстатки.НарядЗаказ.СуммаДокумента КАК Сумма,
	               |		НарядЗаказыОстатки.НарядЗаказ.Сотрудник КАК Сотрудник
	               |	ИЗ
	               |		РегистрНакопления.НарядЗаказы.Остатки(
	               |				&ОтборПериод,
	               |				Контрагент = &ОтборКонтрагент
	               |					И СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница) КАК НарядЗаказыОстатки
	               |	ГДЕ
	               |		НарядЗаказыОстатки.КоличествоОстаток > 0
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ПланыЛеченияОстатки.ПланЛечения,
	               |		ПланыЛеченияОстатки.ПланЛечения.Номер,
	               |		ПланыЛеченияОстатки.ПланЛечения.Дата,
	               |		ПланыЛеченияОстатки.ПланЛечения.Статус,
	               |		ПланыЛеченияОстатки.СуммаОстаток,
	               |		ПланыЛеченияОстатки.ПланЛечения.Сотрудник
	               |	ИЗ
	               |		РегистрНакопления.ПланыЛечения.Остатки(
	               |				&ОтборПериод,
	               |				Контрагент = &ОтборКонтрагент
	               |					И СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница) КАК ПланыЛеченияОстатки
	               |	ГДЕ
	               |		ПланыЛеченияОстатки.КоличествоОстаток > 0) КАК ВложенныйЗапрос
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВложенныйЗапрос.ДатаДокумента,
	               |	ВложенныйЗапрос.НомерДокумента,
	               |	ВложенныйЗапрос.ДокументПланирования,
	               |	ВложенныйЗапрос.СтатусДокумента,
	               |	ВложенныйЗапрос.Сумма,
	               |	ВложенныйЗапрос.Сотрудник
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВложенныйЗапрос.ДокументПланирования,
	               |	ВложенныйЗапрос.ДатаДокумента";
		
	Запрос.УстановитьПараметр("ОтборКонтрагент"        , Контрагент);	
	Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ОтборПериод"            , ?(ЗначениеЗаполнено(ДатаДокумента), КонецДня(ДатаДокумента), ТекущаяДатаСеанса()));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

