// Функция - Установить обязательные динамические поля.
// 
// Возвращаемое значение:
//   - СтруктураОбязательныхДинамическихПолей - Структура - Структура обязательных полей контактной информации.
//
Функция ПолучитьОбязательныеДинамическиеПоля()
	
	СтруктураОбязательныхДинамическихПолей = Новый Структура();
	СтруктураОбязательныхДинамическихПолей.Вставить("ФлагТелефон", Ложь);
	СтруктураОбязательныхДинамическихПолей.Вставить("ФлагEmail"  , Ложь);
	СтруктураОбязательныхДинамическихПолей.Вставить("ФлагАдрес"  , Ложь);
	
	СтруктураОбязательныеПоля = ВернутьЗначениеКонстантыОбязательныеПоля();
	
	ОбязательныеПоля = Неопределено;
	
	Если Объект.Ссылка.Пустая()		
		И ТипЗнч(СтруктураОбязательныеПоля) = Тип("Структура") Тогда
		
		СтруктураОбязательныеПоля.Свойство("ОбязательныеПоляДляНовых", ОбязательныеПоля);		
		
	КонецЕсли;
		
	Если ОбязательныеПоля <> Неопределено Тогда
		
		Для Каждого ОбязательноеПоле Из ОбязательныеПоля Цикл
			
			Если ОбязательноеПоле.Значение = Истина Тогда
				
				Если ОбязательноеПоле.Ключ = "ЗАЯВКА_ПредставлениеКИ_0" Тогда
					СтруктураОбязательныхДинамическихПолей.ФлагТелефон = Истина;
				ИначеЕсли ОбязательноеПоле.Ключ = "ЗАЯВКА_ПредставлениеКИ_1" Тогда
					СтруктураОбязательныхДинамическихПолей.ФлагEmail   = Истина;
				ИначеЕсли ОбязательноеПоле.Ключ = "ЗАЯВКА_ПредставлениеКИ_2" Тогда
					СтруктураОбязательныхДинамическихПолей.ФлагАдрес   = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СтруктураОбязательныхДинамическихПолей;
	
КонецФункции

&НаКлиенте
// Функция - Проверить обязательные динамические поля.
//
// Параметры:
//  Элемент						 - Элемент формы - 
//  СтруктураФлаговДинамПолей	 - Структура	 - 
// 
// Возвращаемое значение:
//   - СтруктураФлаговДинамическихПолей - Структура
//
Функция ПроверитьОбязательныеДинамическиеПоля(Элемент, СтруктураФлаговДинамическихПолей)
	
	Если СтруктураФлаговДинамическихПолей = Неопределено Тогда
		СтруктураФлаговДинамическихПолей = СоздатьОбнуленнуюСтруктуруФлаговДинамическихПолей();
	КонецЕсли;
	
	Если Элемент.Подсказка = "Телефон" Тогда 
		
		Если СтруктураФлаговДинамическихПолей.ХотяБыОдинТелефон = Ложь Тогда
			СтруктураФлаговДинамическихПолей.ХотяБыОдинТелефон  = ЗначениеЗаполнено(Элемент.ТекстРедактирования);
		КонецЕсли;
		
	ИначеЕсли Элемент.Подсказка = "Адрес электронной почты" Тогда
		
		Если СтруктураФлаговДинамическихПолей.ХотяБыОдинEmail = Ложь Тогда
			СтруктураФлаговДинамическихПолей.ХотяБыОдинEmail  = ЗначениеЗаполнено(Элемент.ТекстРедактирования);
		КонецЕсли;
		
	ИначеЕсли Элемент.Подсказка = "Адрес" Тогда
		
		Если СтруктураФлаговДинамическихПолей.ХотяБыОдинАдрес = Ложь Тогда
			СтруктураФлаговДинамическихПолей.ХотяБыОдинАдрес  = ЗначениеЗаполнено(Элемент.ТекстРедактирования);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтруктураФлаговДинамическихПолей;
	
КонецФункции

