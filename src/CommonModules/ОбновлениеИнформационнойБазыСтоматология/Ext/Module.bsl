// Процедура - Обновить использование справочника программы страхования.
//
// Параметры:
//  Параметры	 - 	 - 
//
Процедура ОбновитьИспользованиеСправочникаПрограммыСтрахования(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрограммыСтрахования.Ссылка КАК Ссылка,
	|	ПрограммыСтрахования.ВидДоговора КАК ВидДоговора,
	|	ПрограммыСтрахования.Владелец КАК Владелец
	|ПОМЕСТИТЬ СозданныеПрграммыСтрахования
	|ИЗ
	|	Справочник.ПрограммыСтрахования КАК ПрограммыСтрахования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
	|	ДоговорыКонтрагентов.ВидДоговора_Удалить КАК ВидДоговора_Удалить,
	|	ДоговорыКонтрагентов.Контрагент КАК Контрагент,
	|	СозданныеПрграммыСтрахования.Ссылка КАК ПрограммаСтрахования
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ СозданныеПрграммыСтрахования КАК СозданныеПрграммыСтрахования
	|		ПО ДоговорыКонтрагентов.Контрагент = СозданныеПрграммыСтрахования.Владелец
	|			И ДоговорыКонтрагентов.ВидДоговора_Удалить = СозданныеПрграммыСтрахования.ВидДоговора
	|ГДЕ
	|	ДоговорыКонтрагентов.ПрограммаСтрахования = ЗНАЧЕНИЕ(Справочник.ПрограммыСтрахования.ПустаяСсылка)
	|	И ДоговорыКонтрагентов.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяССылка)";

	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ВидДоговора = ?(Не ЗначениеЗаполнено(Выборка.ВидДоговора_Удалить), Перечисления.ВидыСтраховыхДоговоров.Фактовый, Выборка.ВидДоговора_Удалить);
		
		ПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьПрограммыСтрахованияПоВладельцу(Выборка.Контрагент, ВидДоговора, 1);
		
		Если ПрограммыСтрахования.Количество() > 0 Тогда
			ПрограммаСтрахования = ПрограммыСтрахования[0]; 
		Иначе
			ТекстОшибки = "";
			ПрограммаСтрахования = СоздатьСправочникПрограммаСтрахования(ВидДоговора, Выборка.Контрагент, ТекстОшибки);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда 
				
				ЗаписьЖурналаРегистрации("ОбновлениеСправочникаПрограммыСтрахования", УровеньЖурналаРегистрации.Ошибка,, ТекстОшибки);	
				
				Продолжить;	
			КонецЕсли;
		КонецЕсли;
				
		СправочникОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		СправочникОбъект.ПрограммаСтрахования = ПрограммаСтрахования;
		
		Попытка 
			
			СправочникОбъект.Записать(); 
			
		Исключение
			
			ЗаписьЖурналаРегистрации("ОбновлениеПредопределенныхЭлементовСправочникаПрограммыСтрахования", УровеньЖурналаРегистрации.Ошибка,, ОписаниеОшибки());	

		КонецПопытки;
			
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Создать справочник программа страхования.
//
Функция СоздатьСправочникПрограммаСтрахования(ВидДоговора, Владелец, ТекстОшибки)
	
	НовыйСправочник = Справочники.ПрограммыСтрахования.СоздатьЭлемент();
	
	Если ВидДоговора = Перечисления.ВидыСтраховыхДоговоров.Фактовый Тогда
		ЦветФона 		= Новый Цвет(25, 116, 206);                                  
		Если ЗначениеЗаполнено(Владелец) Тогда
			Наименование = СтрШаблон("%1 %2", Владелец.Наименование, "(Фактовый)");
		Иначе
			Наименование 	= "Фактовый";
		КонецЕсли;
		НаименованиеКратко = "Факт";
	Иначе
		ЦветФона 		= Новый Цвет(209, 9, 78);
		Если ЗначениеЗаполнено(Владелец) Тогда
			Наименование = СтрШаблон("%1 %2", Владелец.Наименование, "(Предоплата)");
		Иначе
			Наименование 	= "Предоплата";
		КонецЕсли;
		НаименованиеКратко = "Пред";	
	КонецЕсли;

	НовыйСправочник.Наименование 				= Наименование;
	НовыйСправочник.НаименованиеКратко 			= НаименованиеКратко;
	НовыйСправочник.ЦветФона 					= ЗначениеВСтрокуВнутр(ЦветФона);
	НовыйСправочник.Владелец					= Владелец;
	НовыйСправочник.ВидДоговора					= ВидДоговора;
	// Цвет текста белый заполнится при записи объекта.
	
	Попытка
		НовыйСправочник.Записать();
		СправочникПрограммыСтрахованияФактовый = НовыйСправочник.Ссылка; 
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки; 
	
	Возврат НовыйСправочник.Ссылка;
	
КонецФункции

// Процедура, переносит записи с видом осмотра ОчередьНаЗапись из регистра Профосмотры 
// в регистр ИнтервалыЛистаОжиания.
//
Процедура ПеренестиОчередьНаЗаписьВЛистОжидания(Параметры = Неопределено) Экспорт

	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрофосмотрыСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПрофосмотрыСрезПоследних.Контрагент КАК Контрагент,
	|	ПрофосмотрыСрезПоследних.Сотрудник КАК Сотрудник,
	|	ПрофосмотрыСрезПоследних.ДатаЗапланированная КАК Дата,
	|	ЗНАЧЕНИЕ(Перечисление.ПериодыДня.ВесьДень) КАК ПериодДня,
	|	ПрофосмотрыСрезПоследних.Период КАК ДатаЗаписи,
	|	ПрофосмотрыСрезПоследних.Комментарий КАК Комментарий,
	|	ЗНАЧЕНИЕ(Перечисление.ПериодыДня.ВесьДень) КАК ПериодДняСтрокой
	|ИЗ
	|	РегистрСведений.Профосмотры.СрезПоследних(
	|			,
	|			ДатаЗапланированная >= &ТекущаяДата
	|				И ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.ОчередьНаЗапись)
	|				И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован)) КАК ПрофосмотрыСрезПоследних";
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл		
		
		Попытка
						
			НаборЗаписей = РегистрыСведений.ИнтервалыЛистаОжидания.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(Выборка.СтруктурнаяЕдиница); 
			НаборЗаписей.Отбор.Контрагент.Установить(Выборка.Контрагент);
			НаборЗаписей.Отбор.Сотрудник.Установить(Выборка.Сотрудник);
			
			ОбрабатываемаяДата = Выборка.Дата;
			
			Для Итератор = 0 По 31 Цикл
				
				НоваяЗапись = НаборЗаписей.Добавить(); 
				ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
				НоваяЗапись.Дата =  ОбрабатываемаяДата + (Итератор * (60*60*24));
				
			КонецЦикла;
			
			НаборЗаписей.ОбменДанными.Загрузка = Истина;
			НаборЗаписей.Записать();
			
		Исключение	
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Заполнить время отправки сообщений чат бота
//
Процедура ЗаполнитьВремяОтправкиСообщенийЧатБота() Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СценарииЧатБотов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
	|ГДЕ
	|	СценарииЧатБотов.ПометкаУдаления = ЛОЖЬ
	|	И (СценарииЧатБотов.ВремяОтправкиСообщенийС = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ СценарииЧатБотов.ВремяОтправкиСообщенийПо = ДАТАВРЕМЯ(1, 1, 1))";
	
	ВыборкаСценариев = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаСценариев.Следующий() Цикл 
		СценарийОбъект = ВыборкаСценариев.Ссылка.ПолучитьОбъект();
		Если СценарийОбъект = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		СценарийОбъект.ВремяОтправкиСообщенийС 	= Дата(01,01,01,08,00,00);
		СценарийОбъект.ВремяОтправкиСообщенийПо = Дата(01,01,01,20,00,00);
		СценарийОбъект.ОбменДанными.Загрузка 	= Истина;
		Попытка
			СценарийОбъект.Записать();
		Исключение
			МетаданныеСправочника 				= Метаданные.Справочники.СценарииЧатБотов;		
			ШаблонКомментария = НСтр("ru = 'Не удалось заполнить время отправки сообщений чат-бота для сценария ""%1"" 
			|по причине: %2'");
		
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, СценарийОбъект.Наименование
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
								, УровеньЖурналаРегистрации.Ошибка
								, МетаданныеСправочника
								,
								, Комментарий);
		КонецПопытки;	
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Удалить предопределенные драйверы оборудования
//
Процедура УдалитьПредопределенныеДрайверыОборудования() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли; 
	
	МетаданныеСправочника = Метаданные.Справочники.ДрайверыОборудования;
	ШаблонКомментария = НСтр("ru = 'Не удалось удалить драйвер оборудования ""%1"" 
			|по причине: %2'");		
			
	ДрайверYarus = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ДрайверыОборудования.ДрайверШтрихМПлатежныйТерминалYarus");
	
	Если ЗначениеЗаполнено(ДрайверYarus) Тогда
		
		Попытка
			ДрайверОбъект = ДрайверYarus.ПолучитьОбъект();
			ДрайверОбъект.ИмяПредопределенныхДанных = "";
			ДрайверОбъект.Записать();	
			ДрайверОбъект.Удалить();
		Исключение
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, ДрайверYarus.Наименование
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
								, УровеньЖурналаРегистрации.Ошибка
								, МетаданныеСправочника
								,
								, Комментарий);
																
		КонецПопытки;
		
	КонецЕсли;
	
	ДрайверПриват = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ДрайверыОборудования.ДрайверПриватбанкЭквайринговыеТерминалы");
	Если ЗначениеЗаполнено(ДрайверПриват) Тогда
		
		Попытка
			ДрайверОбъект = ДрайверПриват.ПолучитьОбъект();
			ДрайверОбъект.ИмяПредопределенныхДанных = "";
			ДрайверОбъект.Записать();	
			ДрайверОбъект.Удалить();
		Исключение
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, ДрайверПриват.Наименование
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
								, УровеньЖурналаРегистрации.Ошибка
								, МетаданныеСправочника
								,
								, Комментарий);
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры	

// Процедура, обновляет реквизит "СуммаОплачено" в документах Поступление, Возврат и заказ поставщику, Возрат от покупателя.
//
Процедура ОбновитьРеквизитСуммаОплаченоВДокументах(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка КАК ДокументОплаты
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.СуммаОплачено = 0
	|	И (СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.Ссылка ССЫЛКА Документ.Поступление
	|			ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.Ссылка ССЫЛКА Документ.ВозвратОтПокупателя
	|			ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.Ссылка ССЫЛКА Документ.ЗаказПоставщику)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
	|	И ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.СуммаОплачено = 0
	|	И ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.Ссылка ССЫЛКА Документ.ВозвратПоставщику");
	
	//|	И (СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаПоставщику)
	//|			ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту))
	
	РезультатЗапроса = Запрос.Выполнить();	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			ДенежныеСредстваСервер.ЗаполнитьРеквизитыОплатыДокументаОснования(Выборка.ДокументОплаты);
		Исключение			
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, Обновляет внешнюю систему IP-Телефонии ITOOLABS в CRM, дописывая наименование АТС (Для статистики).
//
Процедура ЗаполнитьНаименованиеАТСДляIPТелефонииItoolabsВCRM(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Попытка
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ВнешниеСистемы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
		|ГДЕ
		|	НЕ ВнешниеСистемы.ПометкаУдаления
		|	И ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.IPТелефония)
		|	И ВнешниеСистемы.Используется
		|	И ВнешниеСистемы.Синхронизирована
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПодключаемоеОборудование.Ссылка КАК ПодключаемоеОборудование,
		|	ПодключаемоеОборудование.Параметры КАК Параметры
		|ИЗ
		|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
		|ГДЕ
		|	НЕ ПодключаемоеОборудование.ПометкаУдаления
		|	И ПодключаемоеОборудование.УстройствоИспользуется
		|	И ПодключаемоеОборудование.ТипОборудования = ЗНАЧЕНИЕ(Перечисление.ТипыПодключаемогоОборудования.IPТелефония)
		|	И ПодключаемоеОборудование.ДрайверОборудования = ЗНАЧЕНИЕ(Справочник.ДрайверыОборудования.ДрайверХеликсITOOLABS)");
		
		РезультатЗапроса = Запрос.ВыполнитьПакет();	
		ВыборкаВС = РезультатЗапроса[0].Выбрать();
		ВыборкаОборудование = РезультатЗапроса[1].Выгрузить(); 
		
		Если ЗначениеЗаполнено(ВыборкаОборудование) Тогда
			
			name_ATS = "";
			
			ПараметрыВС = ВыборкаОборудование[0].Параметры.Получить();		
			Если ТипЗнч(ПараметрыВС) = Тип("Структура") И ПараметрыВС.Свойство("ВыбранныйОператор")
				И ТипЗнч(ПараметрыВС.ВыбранныйОператор) = Тип("Структура") Тогда
				
				ПараметрыВС.ВыбранныйОператор.Свойство("Представление", name_ATS);
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(name_ATS) Тогда
				
				УИДТекущейСессии = ЛичныйКабинет.УидТекущейСессии();
				
				ДопПараметры = Новый Структура("operator_IP_telephony, name_ATS", "ITOOLABS", name_ATS); 
				
				Пока ВыборкаВС.Следующий() Цикл			
					ЛичныйКабинет.ОбновитьДанныеПубликацииВнешнейСистемы(ВыборкаВС.Ссылка, Истина, УИДТекущейСессии, ДопПараметры);	
				КонецЦикла;

			КонецЕсли;
			
		КонецЕсли; 
		
	Исключение
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Обновление внешней системы IP-Телефонии в CRM."
		, УровеньЖурналаРегистрации.Ошибка
		,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры  

// Процедура, заполняет реквизит "СодержаниеPush" в шаблонах сообщений.
//
Процедура ЗаполнениеСодержанияPushУведомленийШаблоновСообщений() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ШаблоныСообщений.Ссылка КАК Ссылка,
	|	ШаблоныСообщений.Содержание КАК Содержание
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	НЕ ШаблоныСообщений.ЭтоГруппа
	|	И НЕ ШаблоныСообщений.ПометкаУдаления
	|	И НЕ ШаблоныСообщений.Содержание ПОДОБНО """"");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			ШаблонОбъект				 = Выборка.Ссылка.ПолучитьОбъект();
			ШаблонОбъект.СодержаниеPush	 = Выборка.Содержание;
			ШаблонОбъект.Записать();
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры  

// Процедура - Добавить роль добавление изменение заявок регистратуре
//
Процедура ДобавитьРольДобавлениеИзменениеЗаявокРегистратуре() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.ПометкаУдаления = ЛОЖЬ
	|	И Пользователи.РольПользователя = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура)";
		
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Пока Выборка.Следующий() Цикл
		
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ);		
		
		Если ПользовательИБ <> Неопределено 		
			И ПользовательИБ.Роли.Содержит(Метаданные.Роли.ДобавлениеИзменениеЗаявокВсех) = Ложь Тогда
			
			ПользовательИБ.Роли.Добавить(Метаданные.Роли.ДобавлениеИзменениеЗаявокВсех);
			
			Попытка 
				ПользовательИБ.Записать();
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
