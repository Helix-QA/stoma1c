&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере" ФормыЭлемента
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Параметры.Свойство("ВладелецКарты", Объект.ВладелецКарты);
	Параметры.Свойство("ВидКарты"	  , Объект.ВидКарты);
	Параметры.Свойство("ТипКода"	  , Объект.ТипКода);
		
	Элементы.ВладелецКарты.Видимость = Не ЗначениеЗаполнено(Объект.ВладелецКарты);
	
	Объект.ДатаОткрытия = ТекущаяДата();
		
	НовыйЭлемент = Истина;
	
	ВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);	
	ВСНастроена 		 = Константы.ИспользоватьWallet.Получить() И ЗначениеЗаполнено(ВнешняяСистемаWallet.КлючШифрования) И ЗначениеЗаполнено(ВнешняяСистемаWallet.ТокенДоступа);
		
	ИспользуемыйВидКарт = Константы.ИспользуемыйВидКарт.Получить();
	
	Если Не ЗначениеЗаполнено(Объект.ТипКода) Тогда
		Объект.ТипКода = ?(ИспользуемыйВидКарт = Перечисления.ВидыКарт.Wallet И ВСНастроена, ИспользуемыйВидКарт, Перечисления.ВидыКарт.Штриховая);	
	КонецЕсли;
	
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ЭтотОбъект.ВидКартыWalletПоУмолчанию = Константы.ВидКартыWalletПоУмолчанию.Получить(); 

	Если Объект.ТипКода = Перечисления.ВидыКарт.Wallet
		И Не ЗначениеЗаполнено(Объект.ВидКарты) Тогда
		Объект.ВидКарты = ЭтотОбъект.ВидКартыWalletПоУмолчанию;		
	КонецЕсли;
	
	ЗаполнитьСервисыРассылки();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	Объект.Наименование = СформироватьАвтоНаименование();
	
	//ПодключитьОбработчикОжидания("УстановитьВидимостьДоступность", 0.001, Истина);
	
	ПредВидКарты = Объект.ВидКарты;
	
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события формы "ПриЗакрытии".
//
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	//УстановитьФлагБиометрииГантнер(Ложь);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения формы.
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		
		Если ИмяСобытия = "ScanData" Тогда
			
			// Преобразуем предварительно к ожидаемому формату.
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных.
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных.
			КонецЕсли;
			
			ПолученыШтрихкоды(Данные, ИмяСобытия);
			
		ИначеЕсли ИмяСобытия = "TracksData" Тогда
			
			ДанныеКарты     = МенеджерОборудованияКлиент.ОбработатьДанныеМагнитнойКарты(Параметр);
			Объект.КодКарты = ДанныеКарты.КодШифра;
			Объект.ТипКода  = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная");
						
		КонецЕсли;
		
		УстановитьВидимостьДоступность();
		
	КонецЕсли;
	
	Если ИмяСобытия = "СОХРАНЕНИЕ_ВНЕШНЕЙ_СИСТЕМЫ" Тогда
		
		ВСНастроена = ВСWalletНастроена();
		
		УстановитьВидимостьДоступность();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере" ЭлементаФормы
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
		
	Если НЕ Константы.ИспользуемыйВидКарт.Получить() = Объект.ТипКода Тогда
		
		Константы.ИспользуемыйВидКарт.Установить(Объект.ТипКода);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события формы "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("СозданаНоваяКарта"); 
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды "СгенерироватьКодКарты".
//
Процедура СгенерироватьКодКарты(Команда)
	
