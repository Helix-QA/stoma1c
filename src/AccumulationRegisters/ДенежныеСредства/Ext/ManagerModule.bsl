
#Область СлужебныеПроцедурыИФункции

// Функция вернет остатко денежных средств по переданным параметрам
Функция ПолучитьОстаткоДенежныхСредств(Период = Неопределено
	                                  ,БанковскийСчетКасса  = Неопределено
									  ,НеУчитываемыйРегистратор = Неопределено) Экспорт
	
	  ЗапросВыборка = Новый Запрос(
	  "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	  |	ДенежныеСредстваОбороты.БанковскийСчетКасса КАК Приемник,
	  |	ДенежныеСредстваОбороты.ТипДенежныхСредств КАК ТипДенежныхСредств,
	  |	СУММА(ДенежныеСредстваОбороты.СуммаОборот) КАК СуммаОстаток
	  |ИЗ
	  |	РегистрНакопления.ДенежныеСредства.Обороты(
	  |			,
	  |			&Период,
	  |			Авто,
	  |			ВЫБОР
	  |				КОГДА НЕ &Приемник = НЕОПРЕДЕЛЕНО
	  |					ТОГДА БанковскийСчетКасса = &Приемник
	  |				ИНАЧЕ ИСТИНА
	  |			КОНЕЦ) КАК ДенежныеСредстваОбороты
	  |ГДЕ
	  |	ВЫБОР
	  |			КОГДА НЕ &Регистратор = НЕОПРЕДЕЛЕНО
	  |				ТОГДА НЕ ДенежныеСредстваОбороты.Регистратор = &Регистратор
	  |			ИНАЧЕ ИСТИНА
	  |		КОНЕЦ
	  |
	  |СГРУППИРОВАТЬ ПО
	  |	ДенежныеСредстваОбороты.БанковскийСчетКасса,
	  |	ДенежныеСредстваОбороты.ТипДенежныхСредств");
	
	ЗапросВыборка.УстановитьПараметр("Период"             ,?(Период = Неопределено, Дата(0001,01,01,0,0,0),Период));
	ЗапросВыборка.УстановитьПараметр("Регистратор"        ,НеУчитываемыйРегистратор);
	ЗапросВыборка.УстановитьПараметр("Приемник"           ,БанковскийСчетКасса);
	
	Резвыборки = ЗапросВыборка.Выполнить().Выгрузить();
	
	Возврат Резвыборки.Итог("СуммаОстаток");
	
КонецФункции

#КонецОбласти