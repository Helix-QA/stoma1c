// Процедура, обработчик завершения
//
Процедура ВопросОЗаписиОбъектаЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Если Объект.ИспользоватьЯндексКарты Тогда
			Объект.ИспользоватьЯндексКарты = Ложь;
			ЭтотОбъект.Записать();
			Объект.ИспользоватьЯндексКарты = Истина;
		Иначе
			ЭтотОбъект.Записать();
		КонецЕсли;
		ВставитьИзФайлаОбработка("КартинкаЯндексСалон");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Вставить из файла обработка
// Завершение процедуры Вставить из файла ответ
Процедура ВставитьИзФайлаОбработка(ТипКартинки)
	
	ИдентификаторФайла = Новый УникальныйИдентификатор;
	
	Фильтр = НСтр("ru = 'Все картинки (*.bmp;*.gif;*.png;*.jpeg;*.dib;*.rle;*.tif;*.jpg;*.ico;*.wmf;*.emf)|*.bmp;*.gif;*.png;*.jpeg;*.dib;*.rle;*.tif;*.jpg;*.ico;*.wmf;*.emf"
	+ "|Все файлы(*.*)|*.*"
	+ "|Формат bmp(*.bmp*;*.dib;*.rle)|*.bmp;*.dib;*.rle"
	+ "|Формат GIF(*.gif*)|*.gif"
	+ "|Формат JPEG(*.jpeg;*.jpg)|*.jpeg;*.jpg"
	+ "|Формат PNG(*.png*)|*.png"
	+ "|Формат TIFF(*.tif)|*.tif"
	+ "|Формат icon(*.ico)|*.ico"
	+ "|Формат метафайл(*.wmf;*.emf)|*.wmf;*.emf'");
	
	РаботаСФайламиКлиент.ДобавитьФайлы(СтруктурнаяЕдиница, ИдентификаторФайла, Фильтр,,, ТипКартинки);
	ЭтаФорма.Модифицированность = Истина;
	
	
КонецПроцедуры

&НаСервере
// Процедура, устававливает видимость картинки
//
Процедура ПриИзмененииКартинки()
	
	Видимость = Не ЭтотОбъект.ФайлКартинки.Пустая();
	
	Если Видимость Тогда
		АдресКартинки = ПолучитьНавигационнуюСсылкуКартинки(ЭтотОбъект.ФайлКартинки, УникальныйИдентификатор);
		//Элементы.АдресКартинки.РазмерКартинки = РазмерКартинки.Пропорционально;
	Иначе
		АдресКартинки = ПоместитьВоВременноеХранилище(БиблиотекаКартинок.ВашЛоготип.ПолучитьДвоичныеДанные(), УникальныйИдентификатор);
		//Элементы.АдресКартинки.РазмерКартинки = РазмерКартинки.РеальныйРазмер;
	Конецесли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - использовать яндекс карты при изменении
//
Процедура ИспользоватьЯндексКартыПриИзменении(Элемент)
	
	ЭтаФорма.Модифицированность = Истина;
	Элементы.ГруппаЯндексИдентификаторРубрики.Видимость = ИспользоватьЯндексКарты;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Нажатие".
//
Процедура ПолеКартинкиНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Индекс 		 = ПолучитьИндексИмениЭлемента(Элемент.Имя);
	ФайлКартинки = ЭтотОбъект.ФайлыКартинок.Получить(Индекс - 1).Значение;
	
	ОткрытьКартинку(ФайлКартинки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Нажатие".
//
Процедура ОсновнаяКартинкаНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЭтотОбъект.ФайлыКартинок.Количество() > 0 Тогда
		ОткрытьКартинку(ЭтотОбъект.ФайлыКартинок.Получить(0).Значение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, открывает картинку.
//
Процедура ОткрытьКартинку(ФайлКартинки)
	
	ДанныеФайла = ПолучитьДанныеФайла(ФайлКартинки, ЭтаФорма.УникальныйИдентификатор);
	Если ДанныеФайла <> Неопределено Тогда 		
		РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработка выбора СЕ.
//
Процедура СтруктурнаяЕдиницаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Объект.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
КонецПроцедуры

 &НаКлиенте
 // Процедура обработчик коменты: Удалить, Помечает на удаление текущую внешнюю систему
 //
 Процедура УдалитьИЗакрыть(Команда)
	 
	 Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса",
	 ЭтотОбъект);	
	 
	 ПоказатьВопрос(Оповещение,
	 "Вы точнохотите пометить на удаление данный элемент справочника?",
	 РежимДиалогаВопрос.ДаНетОтмена,
	 0, 
	 КодВозвратаДиалога.Да
	 );    
	 
	 
 КонецПроцедуры
 
 &НаКлиенте
 // Процедура, помечает внешнюю систему на удаление или снимает пометку.
 //
 Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	 
	 Если Результат = КодВозвратаДиалога.Да Тогда
		 
		 ПометитьНаУдаление();
		 
		 ПараметрыОповещения = Новый Структура;
		 ПараметрыОповещения.Вставить("ВнешняяСистема"	, Объект.Ссылка);
		 ПараметрыОповещения.Вставить("ТипВнешнейСистемы", Объект.ТипВнешнейСистемы);
		 
		 Оповестить("УдаленаВнешняяСистема", ПараметрыОповещения);
		 
		 ЭтаФорма.Закрыть();
	 КонецЕсли;	
	 
 КонецПроцедуры 
 
 &НаСервере
 // Процедура, помечает внешнюю систему на удаление или снимает пометку.
 //
 Процедура ПометитьНаУдаление()
	 
	 ВнешняяСистемаОбъект = Объект.Ссылка.ПолучитьОбъект();
	 ВнешняяСистемаОбъект.ПометкаУдаления = Истина;
	 ВнешняяСистемаОбъект.Используется = Ложь;
	 
	 Попытка
		 ВнешняяСистемаОбъект.Записать();
	 Исключение 
	 КонецПопытки;
	 
 КонецПроцедуры
 
