&НаКлиенте
// Процедура - Подключаемый подбор номенклатура выбор обработка
//
// Параметры:
//  МассивПартий		 - 	 - 
//  ОбработкаНаСервере	 - 	 - 
//
Процедура Подключаемый_ПодборНоменклатураВыборОбработка(МассивПартий, ОбработкаНаСервере)
	
	СтрокаПодбора         = Элементы._ПодборНоменклатур.ТекущиеДанные;
	Материал              = СтрокаПодбора.Номенклатура;
	
	
	СтруктурнаяЕденицаВЗависимостиОтВидаНормСписания = ?(Не ОбщиеНормыСписания, ОтборСтруктурнаяЕдиница, ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка"));
	
	НайденныеСтроки = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("Материал, СтруктурнаяЕдиница", Материал, СтруктурнаяЕденицаВЗависимостиОтВидаНормСписания));
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		
		НоваяСтрока                               	= ТаблицаНормыСписанияМатериалов.Добавить();
		НоваяСтрока.Материал                  		= Материал;
		НоваяСтрока.Количество                    	= 1;
		НоваяСтрока.ХарактеристикиИспользуются    	= СтрокаПодбора.ИспользоватьПартии; 
		НоваяСтрока.СтруктурнаяЕдиница 				= СтруктурнаяЕденицаВЗависимостиОтВидаНормСписания; 
		
		ТаблицаВыбранныхЗначенийПриИзмененииСервер(НоваяСтрока.ПолучитьИдентификатор());
		
	Иначе
		
		СуществуетСтрокаБезПартии = Ложь;
		Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Партия) Тогда
				СуществуетСтрокаБезПартии              = Истина;
				СтрокаТЧ.Количество                    = СтрокаТЧ.Количество + 1;
				СтрокаТЧ.ХарактеристикиИспользуются    = СтрокаПодбора.ИспользоватьПартии;
				СтрокаТЧ.СтруктурнаяЕдиница 		   = СтруктурнаяЕденицаВЗависимостиОтВидаНормСписания;
				
				Этаформа.Модифицированность = Истина;	
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если СуществуетСтрокаБезПартии = Ложь Тогда
			
			НоваяСтрока                               	= ТаблицаНормыСписанияМатериалов.Добавить();
			НоваяСтрока.Материал                    	= Материал;
			НоваяСтрока.Количество                    	= 1;
			НоваяСтрока.ХарактеристикиИспользуются    	= СтрокаПодбора.ИспользоватьПартии; 
			НоваяСтрока.СтруктурнаяЕдиница 				= СтруктурнаяЕденицаВЗависимостиОтВидаНормСписания;
			ТаблицаВыбранныхЗначенийПриИзмененииСервер(НоваяСтрока.ПолучитьИдентификатор());
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Выбор"
//
Процедура Подключаемый_ПодборТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтрокаПодбора = Элементы._ПодборНоменклатур.ТекущиеДанные;
	
	Если СтрокаПодбора <> Неопределено 
		И Не СтрокаПодбора.ЭтоГруппа Тогда	
	
		СтандартнаяОбработка = Ложь;
		Материал = СтрокаПодбора.Номенклатура;
		
		МассивПартий = Новый Массив;
		МассивПартий.Добавить(ПредопределенноеЗначение("Справочник.ПартииНоменклатуры.ПустаяСсылка"));
		Подключаемый_ПодборНоменклатураВыборОбработка(МассивПартий, Ложь);

		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Таблица выбранных значений номенклатура при изменении сервер.
//
// Параметры:
//  Список	 - 	 - 
//
Процедура ТаблицаВыбранныхЗначенийПриИзмененииСервер(ИДТекущейСтроки, ЗначениеНоменклатуры = Неопределено, ОбновлятьКоличество = Истина)
	
	СтрокаТабличнойЧасти = ЭтотОбъект.ТаблицаНормыСписанияМатериалов.НайтиПоИдентификатору(ИДТекущейСтроки);
	
	Если ЗначениеНоменклатуры <> Неопределено Тогда  
		
		Если СтрокаТабличнойЧасти.Материал <> ЗначениеНоменклатуры Тогда 
			
			СтрокаТабличнойЧасти.Материал = ЗначениеНоменклатуры;
			СтрокаТабличнойЧасти.Цена     = Неопределено;
			СтрокаТабличнойЧасти.Упаковка = Неопределено;
			СтрокаТабличнойЧасти.Партия   = Неопределено;
		Иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.Материал) Тогда
		Возврат;
	КонецЕсли;
		
	СтрокаТабличнойЧасти.ХарактеристикиИспользуются = СтрокаТабличнойЧасти.Материал.ИспользоватьПартии;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ВидЦен"            , ЭтотОбъект.ВидЦенМатериалов);	
	СтруктураДанные.Вставить("Номенклатура"      , СтрокаТабличнойЧасти.Материал);
	СтруктураДанные.Вставить("ДатаОбработки"     , ТекущаяДатаСеанса());
	СтруктураДанные.Вставить("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
	СтруктураДанные.Вставить("Упаковка"          , СтрокаТабличнойЧасти.Упаковка);
	
	Если ОбновлятьКоличество = Истина Тогда
		СтрокаТабличнойЧасти.Количество = ?(НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Количество), 1, СтрокаТабличнойЧасти.Количество);
	КонецЕсли;

	СтруктураДанные               = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);			
	СтрокаТабличнойЧасти.ВидЦен   = СтруктураДанные.ВидЦен;	
	СтрокаТабличнойЧасти.Упаковка = СтруктураДанные.Упаковка;	
	
	СтрокаТабличнойЧасти.СписыватьМатериал = 1;
	
	СтрокаТабличнойЧасти.ВключатьВСтоимостьУслуги = СтрокаТабличнойЧасти.ВключатьВСтоимостьУслуги;
	
	Модифицированность = Истина;
	
КонецПроцедуры

