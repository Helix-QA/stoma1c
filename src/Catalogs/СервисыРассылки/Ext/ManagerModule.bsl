//
Функция RocketSMS_ПослатьКоманду(Команда, Аргументы = "", СервисSMSРассылки, ОписаниеОшибки) Экспорт

	Сервер = "api.rocketsms.by";
	
	Ресурс = Команда;                         
    Параметры = "username=" + СокрЛП(СервисSMSРассылки.Пользователь) + "&password=" + ПолучитьMD5(СокрЛП(URLEncode(СервисSMSРассылки.Пароль))) + Аргументы;	
	Результат = ПрочитатьАдрес(Сервер, Ресурс, Параметры, ОписаниеОшибки);                       
	
	Возврат Результат;	
	
