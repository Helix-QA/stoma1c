&НаКлиентеНаСервереБезКонтекста
// Функция вернет идентификатор строки данных по имени элемента
Функция ИндексСтрокиДанныхПоИмениЭлемента(ИмяЭлемента)
	
	НомерСимвола = Найти(ИмяЭлемента,"_");
	Если НомерСимвола > 0 Тогда
		
		стрИд = Число(Прав(ИмяЭлемента,СтрДлина(ИмяЭлемента) - НомерСимвола)); 
		
		Возврат Число(стрИд);
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Функция вернет идентификатор строки данных по имени элемента
Функция СтрокаДанныхПоИмениЭлемента(ИмяЭлемента, ИмяТаблицы)

	Возврат ЭтотОбъект[ИмяТаблицы][ИндексСтрокиДанныхПоИмениЭлемента(ИмяЭлемента)];
		
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Функция вернет идентификатор строки данных по имени элемента
Функция ИндексСтрокиДанныхДереваПоИмениЭлемента(ИмяЭлемента)
	
	НомерСимвола = Найти(ИмяЭлемента,"_");
	Если НомерСимвола > 0 Тогда
		
		стрИд = Прав(ИмяЭлемента,СтрДлина(ИмяЭлемента) - НомерСимвола); 
		
		Возврат стрИд;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Функция вернет идентификатор строки данных по имени элемента
Функция СтрокаДанныхДереваПоИмениЭлемента(ИмяЭлемента, ИмяТаблицы)

	ИндексСтрокой = ИндексСтрокиДанныхДереваПоИмениЭлемента(ИмяЭлемента);
	
	Если СтрНайти(ИндексСтрокой,"x") > 0 Тогда
		
		НомерСимвола = Найти(ИндексСтрокой,"x");
		ид1          = Лев(ИндексСтрокой, НомерСимвола - 1);
        ид2          = Прав(ИндексСтрокой, СтрДлина(ИндексСтрокой) - НомерСимвола); 

		Возврат ЭтотОбъект[ИмяТаблицы].ПолучитьЭлементы()[Число(ид1)].ПолучитьЭлементы()[Число(ид2)];
		
	Иначе
		
		Возврат ЭтотОбъект[ИмяТаблицы].ПолучитьЭлементы()[Число(ИндексСтрокой)]
		
	КонецЕсли;
			
КонецФункции

&НаСервереБезКонтекста
// Получает ссылки на внешнее оборудование.
// 
Функция ПолучитьФРКассы(ТекущаяКасса)	
	ФискальныйРегистратор = ?(ЗначениеЗаполнено(ТекущаяКасса)
	И ЗначениеЗаполнено(ТекущаяКасса.ВнешнееОборудование),
	ТекущаяКасса.ВнешнееОборудование.Ссылка,
	Справочники.ПодключаемоеОборудование.ПустаяСсылка());
	
	Возврат ФискальныйРегистратор;
КонецФункции 

&НаСервереБезКонтекста
// Процедура - "ЗаписатьДокументы".
//
Процедура ЗаписатьДокументы(
	ТекущаяКассаИспользуетсяККТ,
		МассивДокументов, 
		РежимЗаписи_, 
		ТекущаяКасса			= Неопределено,
		НомерЧекаККМ			= Неопределено,
		ДанныеПлатежаПоКарте	= Неопределено,
		МассивОплат				= Неопределено)
		
	ПараметрыСеанса.ОбменДаннымиВключен = Истина;
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		
		ФлагИсключения = Ложь;
		Попытка 
			ЗаписатьДокумент(
					ТекущаяКассаИспользуетсяККТ,
					ДокСсылка,
					РежимЗаписи_, 
					ТекущаяКасса,
					НомерЧекаККМ,
					ДанныеПлатежаПоКарте,
					Ложь,
					МассивОплат);
		Исключение
			ФлагИсключения = Истина;
		КонецПопытки;
		
		Если ФлагИсключения Тогда 
			Попытка 
				ЗаписатьДокумент(
						ТекущаяКассаИспользуетсяККТ,
						ДокСсылка,
						РежимЗаписи_, 
						ТекущаяКасса,
						НомерЧекаККМ,
						ДанныеПлатежаПоКарте,
						Истина,
						МассивОплат);
			Исключение
				ТекстСообщения = "Не удалось записать результат фискализации в %1" +
										?(ЗначениеЗаполнено(НомерЧекаККМ), "Номер чека: %2", "") + 
										?(ЗначениеЗаполнено(ДанныеПлатежаПоКарте),
										"Данные эквайринга: № платежной карты - %3, ссылочный Номер - %4. код авторизации - %5, номер чека - %6", "") +
										"Описание ошибки: %7";
				ТекстСообщения = СтрШаблон(ТекстСообщения,
										ДокСсылка,
										НомерЧекаККМ,
										?(ЗначениеЗаполнено(ДанныеПлатежаПоКарте), ДанныеПлатежаПоКарте.НомерКарты		, ""),
										?(ЗначениеЗаполнено(ДанныеПлатежаПоКарте), ДанныеПлатежаПоКарте.СсылочныйНомер	, ""),
										?(ЗначениеЗаполнено(ДанныеПлатежаПоКарте), ДанныеПлатежаПоКарте.КодАвторизации	, ""),
										?(ЗначениеЗаполнено(ДанныеПлатежаПоКарте), ДанныеПлатежаПоКарте.НомерЧека		, ""),
										ОписаниеОшибки());			
				ЗаписьЖурналаРегистрации("Оплата", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			КонецПопытки; 
		КонецЕсли;        		
				
	КонецЦикла; 

КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - записывает документ.
//
Процедура ЗаписатьДокумент(
	ТекущаяКассаИспользуетсяККТ,
	ДокСсылка,
	РежимЗаписи, 
	ТекущаяКасса				= Неопределено,
	НомерЧекаККМ				= Неопределено,
	ДанныеПлатежаПоКарте		= Неопределено,
	ПрочитатьДокумент			= Ложь,
	МассивОплат					= Неопределено)
	
	ДокОбъект = ДокСсылка.ПолучитьОбъект();
	Если ПрочитатьДокумент Тогда
		ДокОбъект.Прочитать();
	КонецЕсли;        
	
	Если НомерЧекаККМ <> Неопределено Тогда
		
		Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("НомерЧекаККМ", ДокСсылка.Метаданные()) = Истина Тогда
			Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("ТипДенежныхСредств", ДокСсылка.Метаданные())
				ИЛИ ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
				ДокОбъект.НомерЧекаККМ = НомерЧекаККМ.НомерФискальногоЧека;		
			Иначе
				ДокОбъект.НомерЧекаККМ = НомерЧекаККМ.НомерНеФискальногоЧека;
			КонецЕсли;
		КонецЕсли;		
		
		// записываем идентификатор фискальной записи в учтенные авансы
		Если (ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.Прием") Или ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ВозвратОтПокупателя"))
			И НомерЧекаККМ.Свойство("ИдентификаторФискальнойЗаписи")
			И ЗначениеЗаполнено(НомерЧекаККМ.ИдентификаторФискальнойЗаписи)
			И ЗначениеЗаполнено(МассивОплат) Тогда			
			
			ИмяТабличнойЧасти = "УчтенныеАвансы";
			
			МассивСтрокУчтенныеАвансы = Новый Массив;
			
			Для Каждого СтрокаТ ИЗ МассивОплат Цикл
				
				//Если НЕ ЗначениеЗаполнено(СтрокаТ.ДокументАванса) Тогда					
				//	Продолжить;
				//КонецЕсли;
				
				ИскомыйАванс = СтрокаТ.ДокументАванса;
				
				МассивСтрок = ДокОбъект[ИмяТабличнойЧасти].НайтиСтроки(Новый Структура("ДокументАванса, СуммаАванса", ИскомыйАванс, СтрокаТ.Внесено));
				
				Если МассивСтрок.Количество() = 1 И НачалоДня(МассивСтрок[0].ДатаПлатежа) = НачалоДня(ТекущаяДатаСеанса()) Тогда
					МассивСтрокУчтенныеАвансы.Добавить(МассивСтрок[0]);
				ИначеЕсли МассивСтрок.Количество() > 1 Тогда
					ДатаПлатежаМаксимум = МассивСтрок[0].ДатаПлатежа;
					Для Каждого ЭлементМ Из МассивСтрок Цикл
						Если ЭлементМ.ДатаПлатежа > ДатаПлатежаМаксимум Тогда
							ДатаПлатежаМаксимум = ЭлементМ.ДатаПлатежа;
						КонецЕсли;						 
					КонецЦикла;
					МассивСтрокДата = ДокОбъект.УчтенныеАвансы.НайтиСтроки(Новый Структура("ДокументАванса, СуммаАванса, ДатаПлатежа", ИскомыйАванс, СтрокаТ.Внесено, ДатаПлатежаМаксимум));
					МассивСтрокУчтенныеАвансы.Добавить(МассивСтрокДата[0]);
				КонецЕсли;
				
				Для Каждого ЭлементМ Из МассивСтрокУчтенныеАвансы Цикл
					ЭлементМ.ИдентификаторФискальнойЗаписи = НомерЧекаККМ.ИдентификаторФискальнойЗаписи;
					ЭлементМ.НомерЧекаККМ = ?(НомерЧекаККМ.Свойство("НомерФискальногоЧека"), НомерЧекаККМ.НомерФискальногоЧека, "");
				КонецЦикла;   
				
			КонецЦикла;
			
			Если МассивСтрокУчтенныеАвансы.Количество() > 0 Тогда
				ДокОбъект.ДополнительныеСвойства.Вставить("НеПолучатьРазрешениеЗаписиПоПравам"		, Истина);
				ДокОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных"	, Истина);
				
				ДокОбъект.Записать(РежимЗаписи);
			КонецЕсли;
			
		КонецЕсли;  
	КонецЕсли;                                                                
	
	Если (ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств")
		Или ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.СписаниеДенежныхСредств"))
		И ЗначениеЗаполнено(ДанныеПлатежаПоКарте) Тогда
		
		ДокОбъект.ЭквайрингНомерПлатежнойКарты = ДанныеПлатежаПоКарте.НомерКарты;
		ДокОбъект.ЭквайрингСсылочныйНомер      = ДанныеПлатежаПоКарте.СсылочныйНомер;
		ДокОбъект.ЭквайрингКодАвторизации      = ДанныеПлатежаПоКарте.КодАвторизации;
		ДокОбъект.ЭквайрингНомерЧека           = ДанныеПлатежаПоКарте.НомерЧека;   		
	КонецЕсли;
	
	Если (ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.Реализация") Или ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.Прием"))
		И Обработки.ПомощникПроведенияОплаты.ПроверитьНеобходимостьПерепроведенияРеализацииПослеОплатыСтарая(ДокСсылка) = Истина Тогда		
		
		РежимЗаписи = РежимЗаписиДокумента.Проведение;
	КонецЕсли;	
	
	ДокОбъект.ДополнительныеСвойства.Вставить("НеПолучатьРазрешениеЗаписиПоПравам"	 , Истина);
	ДокОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
	ДокОбъект.Записать(РежимЗаписи); 
	
КонецПроцедуры

