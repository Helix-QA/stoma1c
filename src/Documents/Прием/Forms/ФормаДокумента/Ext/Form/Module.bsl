// Функция, возвращает параметры настройки.
//
Функция ПолучитьПараметрыНастройки(Настройка, ТаблицыПодбора)
			
	Если Настройка = "ОтображатьАртикул" Тогда
		Возврат Новый Структура("КолонкаТаб1, КолонкаТаб2, Настройка",
			Элементы.Найти(ТаблицыПодбора[0]+"Артикул"),
			?(ТаблицыПодбора.Количество() = 2, Элементы.Найти(ТаблицыПодбора[1]+"Артикул"), Неопределено),
			ПредопределенноеЗначение("ПланВидовХарактеристик.НастройкиПользователей.ОтображатьАртикул"));  
		
	ИначеЕсли Настройка = "ОтображатьЦену" Тогда
		Возврат Новый Структура("КолонкаТаб1, КолонкаТаб2, Настройка",
			Элементы.Найти(ТаблицыПодбора[0]+"Цена"),
			?(ТаблицыПодбора.Количество() = 2, Элементы.Найти(ТаблицыПодбора[1]+"Цена"), Неопределено),
			ПредопределенноеЗначение("ПланВидовХарактеристик.НастройкиПользователей.ОтображатьЦену"));
			
	ИначеЕсли Настройка = "ОтображатьОстаток" Тогда
		Возврат Новый Структура("КолонкаТаб1, КолонкаТаб2, Настройка",
			Элементы.Найти(ТаблицыПодбора[0]+"Количество"), Неопределено,
			ПредопределенноеЗначение("ПланВидовХарактеристик.НастройкиПользователей.ОтображатьОстаток"));
			
	КонецЕсли;
	
КонецФункции

