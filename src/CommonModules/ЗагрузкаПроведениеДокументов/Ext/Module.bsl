					Если СтрокаТЗЗапасы.Всего <= 0 Тогда 
						СтрокаТЗЗапасы.Цена = 0;
						СтрокаТЗЗапасы.Сумма = 0;
					// Иначе 
					//	СтрокаТЗЗапасы.Цена = 0;
					//	СтрокаТЗЗапасы.Сумма = 0;
					КонецЕсли;	
				КонецЕсли;
				ЗаполнитьЗначенияСвойств(ДокументРеализация.Запасы.Добавить(), СтрокаТЗЗапасы);
			КонецЦикла;
			// ------------------------------------------------------------------------------------------------------------------------
			
			НеобходиомПерепроведение = ДокументРеализация.Проведен И ДокументРеализация.СуммаДокумента <> ДокументРеализация.Запасы.Итог("Всего");
						
			// Если реализация не пустая то создадим ПКО или РКО для оплаты
			Если ДокументРеализация.Запасы.Количество() > 0 Тогда
				// И ЕстьПакетУслуг Тогда // Только пакеты
				ДокументРеализация.СуммаДокумента = ДокументРеализация.Запасы.Итог("Всего");
				Если ДокументРеализация.Запасы.Количество() > 1 И ДокументРеализация.СуммаДокумента < 0 Тогда  // зачем эта проверка???
					Продолжить;
				КонецЕсли;
				
				Попытка
					// Запишем документ	
					ЗаписатьДокумент(ДокументРеализация, , , НеобходиомПерепроведение);						
				Исключение
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка сохранения документа Реализация ""%2"" Код синхронизации: %3 %1 %4';en=' %1 Mistake save of the document Implementation ""%2"" Sync Code: %3 %1 %4'"), Символы.ПС, Строка(ТекущийКлиент), СокрЛП(ВыборкаПоЧекам.НомерСчета), ОписаниеОшибки()));						
				КонецПопытки;	
				
				// Накапливаем и выводим статисические данные и оповещаем клиент
				ПредставлениеРеализации			= Строка(ДокументРеализация.Ссылка);
				Прогресс 						= Цел(100 * СозданоРеализаций / ОбщееКоличествоРеализаций);
				ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
				ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
				ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по реализациям...';en='Saving data by realizations...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеРеализации, ОсталосьВремени, ПредставлениеОставшегосяВремени));
				СообщилиПрогресс = Истина;
				
				// Заполним ссылку на реализацию во всех пакетах и запишем их 
				Для Каждого СтрокаЗапас Из ДокументРеализация.Запасы Цикл
					Если ЗначениеЗаполнено(СтрокаЗапас.Основание) И ТипЗнч(СтрокаЗапас.Основание) = Тип("ДокументСсылка.ЧленствоПакетУслуг") Тогда
						ПакетУслугОбъект 						= СтрокаЗапас.Основание.ПолучитьОбъект();
						ПакетУслугОбъект.ДокументПродажи 		= ДокументРеализация.Ссылка;
						// Все ЧПУ грузим с флагом ЛОЖЬ, для того чтобы были подхвачены закрытием дня (свернем движения по месячно в момент проведения)						
						//// Проверка на свёрнут
						// ДатаОкончания = КонецДня(ПакетУслугОбъект.ДатаРучнойАктивации + ПакетУслугОбъект.СрокДействия*24*60*60);
						// Если ДатаОкончания < ТекущаяДатаСеанса() И ПакетУслугОбъект.СрокДействия > 0 Тогда
						//	ПакетУслугОбъект.Свёрнут 			= Истина;	
						// КонецЕсли;
						//// Запишем документ
						Попытка
							ЗаписатьДокумент(ПакетУслугОбъект);												
						Исключение
							// Запись в лог
							ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + СтрШаблон(НСтр("ru = 'Ошибка сохранения док-та Пакет услуг клиента ""%1"" Код синхронизации: %2';en= 'Error saving document Client service package ""%1"" Synchronization code: %2'"), Строка(ТекущийКлиент), СокрЛП(ПакетУслугОбъект.КодСинхронизации) + Символы.ПС + ОписаниеОшибки()));						
						КонецПопытки;	
					КонецЕсли;		
				КонецЦикла;	
				
				ВыборкаПоОплатам = ВыборкаПоЧекам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерЧека");
				
				#Область Создание_обновление_финансовых_документов
				        
				ПерваяОплата 	= Истина;
				СуммаОплатыПКО 	= 0;
				ПкоРко 			= Неопределено;
				ДокументРеализация.УчтенныеАвансы.Очистить();
				Пока ВыборкаПоОплатам.Следующий() Цикл
					// Если ПерваяОплата  Тогда	
					//	ПерваяОплата = Ложь; 
					Если ВыборкаПоОплатам.СуммаОплаты = 0 тогда 
						Продолжить;
					КонецЕсли;
					Если ЗначениеЗаполнено(ВыборкаПоОплатам.ПКОСсылка) Тогда
						ПкоРко 				= ВыборкаПоОплатам.ПКОСсылка.ПолучитьОбъект();
						ПкоРко.НомерЧекаККМ = ?(ВыборкаПоОплатам.Пробит = 1, ВыборкаПоОплатам.НомерЧекаККМ, ПкоРко.НомерЧекаККМ);						
						СуммаОплатыПКО = ВыборкаПоОплатам.СуммаОплаты;
						Если СуммаОплатыПКО <> ПкоРко.СуммаДокумента Тогда 
							ПкоРко.СуммаДокумента = СуммаОплатыПКО;
							ПкоРко.РасшифровкаПлатежа[0].Сумма 		= ВыборкаПоОплатам.СуммаОплаты;
							ЗаписатьДокумент(ПкоРко);
						КонецЕсли;	
					ИначеЕсли ЗначениеЗаполнено(ВыборкаПоОплатам.РКОСсылка) Тогда
						ПкоРко 				= ВыборкаПоОплатам.РКОСсылка.ПолучитьОбъект();
						ПкоРко.НомерЧекаККМ = ?(ВыборкаПоОплатам.Пробит = 1, ВыборкаПоОплатам.НомерЧекаККМ, ПкоРко.НомерЧекаККМ);						
						СуммаОплатыПКО = ВыборкаПоОплатам.СуммаОплаты;
						Если СуммаОплатыПКО <> ПкоРко.СуммаДокумента Тогда 
							ПкоРко.СуммаДокумента = СуммаОплатыПКО;
							ПкоРко.РасшифровкаПлатежа[0].Сумма 		= ВыборкаПоОплатам.СуммаОплаты;
							ЗаписатьДокумент(ПкоРко);
						КонецЕсли;	
					Иначе
						Если ВыборкаПоОплатам.ТипОплаты = 6 ИЛИ ВыборкаПоОплатам.ТипОплаты = 7 Тогда
							ЛицевойСчетНайден = Ложь;
							// Получаем вид ЛС
							СтруктураВидаЛицевогоСчета = ПолучитьВидЛицевогоСчета(ВыборкаПоОплатам.ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе);							
							Если КлиентНайден = Истина Тогда 
								// Получаем ЛС
								СтруктураПоиска = Новый Структура;
								Если НЕ ЗначениеЗаполнено(ВыборкаПоОплатам.НомерЛС) Тогда 
									СтруктураПоиска.Вставить("ВладелецЛицевогоСчета", ТекущийКлиент);
								Иначе 
									СтруктураПоиска.Вставить("КодСинхронизации"		, ВыборкаПоОплатам.НомерЛС);
									СтруктураПоиска.Вставить("ПрефиксСинхронизации"	, ВыборкаПоОплатам.ПрефиксСинхронизации);									
								КонецЕсли;
								Если ЗначениеЗаполнено(СтруктураВидаЛицевогоСчета.Ссылка) Тогда 
									СтруктураПоиска.Вставить("ВидЛицевогоСчета", СтруктураВидаЛицевогоСчета.Ссылка);
								КонецЕсли;
								МассивСтрокЛС = ТаблицаЛицевыхСчетовВБазе.НайтиСтроки(СтруктураПоиска);
								Если НЕ МассивСтрокЛС.Количество() = 0 Тогда
									ЛицевойСчетКонтрагента 	= МассивСтрокЛС[0].Ссылка;
									ВладелецЛицевогоСчета 	= МассивСтрокЛС[0].ВладелецЛицевогоСчета;
									ЛицевойСчетНайден 		= Истина;
								Иначе 
									ЛицевойСчетКонтрагента = СоздатьЛицевойСчетКонтрагента(ТекущийКлиент, СтруктураВидаЛицевогоСчета.Ссылка, , , ВыборкаПоОплатам.НомерЛС);
								КонецЕсли;	
							Иначе 
								ЛицевойСчетКонтрагента = ВернутьЛицевойСчетКонтрагента(ТекущийКлиент, ВыборкаПоОплатам.ДатаОплаты, СтруктураВидаЛицевогоСчета.Ссылка, , ВыборкаПоОплатам.НомерЛС);
								Если ЛицевойСчетКонтрагента = Неопределено Тогда
									ЛицевойСчетКонтрагента = СоздатьЛицевойСчетКонтрагента(ТекущийКлиент, СтруктураВидаЛицевогоСчета.Ссылка, , , ВыборкаПоОплатам.НомерЛС);
								КонецЕсли;	
							КонецЕсли;
							Отбор = Новый Структура();
							Отбор.Вставить("Аванс", ЛицевойСчетКонтрагента);
							//			Отбор.Вставить("СуммаАванса",ВыборкаПоОплатам.СуммаОплаты);
							//	Отбор.Вставить("ДатаПлатежа",ВыборкаПоОплатам.ДатаОплаты);
							Строки = ДокументРеализация.УчтенныеАвансы.НайтиСтроки(Отбор);
							Если Строки.Количество() > 0 Тогда
								НоваяСтрока 					= Строки[0];
							Иначе			
								НоваяСтрока                 	= ДокументРеализация.УчтенныеАвансы.Добавить();
							КонецЕсли;
							НоваяСтрока.ТипАвансовыхСредств 	= ТипДенежныхСредств_ЛицевойСчет;
							НоваяСтрока.Аванс               	= ЛицевойСчетКонтрагента;
							НоваяСтрока.ВладелецАванса      	= ?(ЛицевойСчетНайден = Истина, ВладелецЛицевогоСчета, ЛицевойСчетКонтрагента.ВладелецЛицевогоСчета);
							НоваяСтрока.КассаОплаты         	= ТекКасса;
							НоваяСтрока.ДатаПлатежа         	= ВыборкаПоОплатам.ДатаОплаты;
							НоваяСтрока.СуммаАванса				= НоваяСтрока.СуммаАванса + ВыборкаПоОплатам.СуммаОплаты;
							ДокументРеализация.Комментарий 		= ДокументРеализация.Комментарий + " (Оплата " + ВыборкаПоОплатам.ПрефиксСинхронизации + " - " + Строка(Формат(ВыборкаПоОплатам.НомерЧека, "ЧГ=0"))+")";
							СуммаОплатыЛС 						= ВыборкаПоОплатам.СуммаОплаты;
						Иначе
							// Оператор оплаты
							ОператорОплатыСтрокой 	= СокрЛП(ВыборкаПоОплатам.ОператорОплаты);
							ОператорОплаты 			= Сотрудник_ПустаяСсылка;
							Если ОператорОплатыСтрокой <> "" Тогда
								СтрокаОператорОплаты = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", ОператорОплатыСтрокой, Ложь));
								Если НЕ СтрокаОператорОплаты.Количество() = 0 Тогда
									ОператорОплаты = СтрокаОператорОплаты[0].Ссылка;
								КонецЕсли;
							КонецЕсли;	
							Если ВыборкаПоОплатам.СуммаОплаты > 0 Тогда // Приходник
								ПкоРко 							= Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
								ПкоРко.ОбменДанными.Загрузка 	= Истина;									
								ПкоРко.СтруктурнаяЕдиница 		= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;									
								ПкоРко.Касса 					= ТекКасса;
								Если ВыборкаПоОплатам.ТипОплаты = 2 Тогда
									ПкоРко.ТипДенежныхСредств 	= ТипДенежныхСредств_Безналичные;
									ПкоРко.БанковскийСчет 		= БанковскийСчетПоУмолчанию;
								ИначеЕсли ВыборкаПоОплатам.ТипОплаты = 3 Тогда
									ПкоРко.ТипДенежныхСредств 	= ТипДенежныхСредств_ПлатежнаяКарта;
									ПкоРко.ЭквайрингТерминал 	= ЭквайринговыйТерминал;
								Иначе
									ПкоРко.ТипДенежныхСредств 	= ТипДенежныхСредств_Наличные;	
								КонецЕсли;									
								ПкоРко.Заполнить(ДокументРеализация.Ссылка);
								ПкоРко.СтатьяДДС 				= СтатьяДвиженияДенежныхСредств_ОплатаОтКлиента;
								ПкоРко.СуммаДокумента			= ВыборкаПоОплатам.СуммаОплаты;
								ПкоРко.Дата 					= ?(ЗначениеЗаполнено(ВыборкаПоОплатам.ДатаОплаты), ВыборкаПоОплатам.ДатаОплаты, ТекущаяДатаСеанса());
								ПкоРко.АвторДокумента 			= ОператорОплаты;
								ПкоРко.НомерЧекаККМ 			= ?(ВыборкаПоОплатам.Пробит = 1, ВыборкаПоОплатам.НомерЧекаККМ, ПкоРко.НомерЧекаККМ);								
								ПкоРко.КодСинхронизации 		= ВыборкаПоОплатам.НомерЧека;
								ПкоРко.ПрефиксСинхронизации		= ВыборкаПоОплатам.ПрефиксСинхронизации;								
								ПкоРко.Комментарий 				= ВыборкаПоОплатам.ПрефиксСинхронизации + " - " + Формат(ВыборкаПоОплатам.НомерЧека, "ЧГ=0");
								Если ПкоРко.РасшифровкаПлатежа.Количество() = 0 ТОгда
									НС 							= ПкоРко.РасшифровкаПлатежа.Добавить();
									НС.Основание 				= ДокументРеализация.Ссылка;
									НС.Сумма 					= ВыборкаПоОплатам.СуммаОплаты;
								Иначе
									ПкоРко.РасшифровкаПлатежа[0].Основание 	= ДокументРеализация.Ссылка;
									ПкоРко.РасшифровкаПлатежа[0].Сумма 		= ВыборкаПоОплатам.СуммаОплаты;
								КонецЕсли;
								Попытка
									ЗаписатьДокумент(ПкоРко);
								Исключение
									// Запись в лог
									ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка сохранения док-та Поступление денежных средств! Код синхронизации: ';en= 'Error saving document Cash receipt! Sync Code: '") + Строка(ВыборкаПоОплатам.НомерЧека) + Символы.ПС + ОписаниеОшибки());						
								КонецПопытки;	
							Иначе // Возврат
								ПкоРко 							= Документы.СписаниеДенежныхСредств.СоздатьДокумент();
								ПкоРко.ОбменДанными.Загрузка 	= Истина;									
								ПкоРко.СтруктурнаяЕдиница 		= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;									
								ПкоРко.Касса 					= ТекКасса;
								Если ВыборкаПоОплатам.ТипОплаты = 2 Тогда
									ПкоРко.ТипДенежныхСредств 	= ТипДенежныхСредств_Безналичные;
									ПкоРко.БанковскийСчет 		= БанковскийСчетПоУмолчанию;
								ИначеЕсли ВыборкаПоОплатам.ТипОплаты = 3 Тогда
									ПкоРко.ТипДенежныхСредств 	= ТипДенежныхСредств_ПлатежнаяКарта;
									ПкоРко.ЭквайрингТерминал 	= ЭквайринговыйТерминал;
								Иначе
									ПкоРко.ТипДенежныхСредств 	= ТипДенежныхСредств_Наличные;	
								КонецЕсли;									
								ПкоРко.Заполнить(ДокументРеализация.Ссылка);
								ПкоРко.Контрагент				= ТекущийКлиент;
								ПкоРко.ВидОперации 				= Перечисления.ВидыОпераций.ВозвратОплатыКлиенту;
								ПкоРко.СтатьяДДС 				= СтатьяДвиженияДенежныхСредств_ВозвратОплатыКлиенту;
								ПкоРко.СуммаДокумента			= - ВыборкаПоОплатам.СуммаОплаты;
								ПкоРко.Дата 					= ?(ЗначениеЗаполнено(ВыборкаПоОплатам.ДатаОплаты), ВыборкаПоОплатам.ДатаОплаты, ТекущаяДатаСеанса());
								ПкоРко.АвторДокумента 			= ОператорОплаты;
								ПкоРко.КодСинхронизации 		= ВыборкаПоОплатам.НомерЧека;
								ПкоРко.ПрефиксСинхронизации		= ВыборкаПоОплатам.ПрефиксСинхронизации;																
								ПкоРко.Комментарий 				= ВыборкаПоОплатам.ПрефиксСинхронизации + " - " + Формат(ВыборкаПоОплатам.НомерЧека, "ЧГ=0");
								Если ПкоРко.РасшифровкаПлатежа.Количество() = 0 ТОгда
									НС 							= ПкоРко.РасшифровкаПлатежа.Добавить();
									НС.Основание 				= ДокументРеализация.Ссылка;
									НС.Сумма 					= - ВыборкаПоОплатам.СуммаОплаты;
								Иначе
									ПкоРко.РасшифровкаПлатежа[0].Основание 	= ДокументРеализация.Ссылка;
									ПкоРко.РасшифровкаПлатежа[0].Сумма 		= - ВыборкаПоОплатам.СуммаОплаты;
								КонецЕсли;
								Попытка
									ЗаписатьДокумент(ПкоРко);
								Исключение
									// Запись в лог
									ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка сохранения док-та Списание денежных средств! Код синхронизации: ';en= 'Error saving document Debt of funds! Sync Code: '") + Строка(ВыборкаПоОплатам.НомерЧека) + Символы.ПС + ОписаниеОшибки());						
								КонецПопытки;	
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;					
				КонецЦикла;	
				
				#КонецОбласти
				
				Если ДокументРеализация.УчтенныеАвансы.Количество() > 0 Тогда
					Попытка
						ЗаписатьДокумент(ДокументРеализация);						
					Исключение
						// Запись в лог
						ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка сохранения док-та Реализация ""%2"" Код синхронизации: %3 %1 %4';en='%1 Mistake save dock Implementation ""%2"" Sync code: %3 %1 %4'"), Символы.ПС, Строка(ТекущийКлиент), СокрЛП(ДокументРеализация.КодСинхронизации), ОписаниеОшибки()));						
					КонецПопытки;	
				КонецЕсли;
				
			Иначе
				Продолжить;
			КонецЕсли;	
			
		КонецЦикла; // ВыборкаПоЧекам
		Если СообщилиПрогресс = Ложь Тогда
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеРеализации			= "";
			Прогресс 						= Цел(100 * СозданоРеализаций / ОбщееКоличествоРеализаций);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по реализациям...';en='Saving data by realizations...'") + Символы.Таб + " Осталось: " + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеРеализации, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;
	КонецЦикла; // ВыборкаПоКлиентам
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда				
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаТренеров.Очистить();	 							ТаблицаТренеров 				= Неопределено;	
	ТаблицаМенеджеровПоПродажам.Очистить();					ТаблицаМенеджеровПоПродажам 	= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
	ТаблицаВидовЛицевыхСчетовВБазе.Очистить();				ТаблицаВидовЛицевыхСчетовВБазе 	= Неопределено;
	ТаблицаЛицевыхСчетов.Очистить(); 						ТаблицаЛицевыхСчетов 			= Неопределено;
	ТаблицаЛицевыхСчетовВБазе.Очистить();					ТаблицаЛицевыхСчетовВБазе 		= Неопределено;
	ВыборкаПоКлиентам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить реализации в фоне access многопоточно
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьРеализацииВФонеAccessМногопоточно(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ЮрФизЛицо_ФизЛицо 									= Перечисления.ЮрФизЛицо.ФизЛицо;
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	ВидКарты_Магнитная 									= Перечисления.ВидыКарт.Магнитная;		
	ВидКартыШтриховая 									= Перечисления.ВидыКарт.Штриховая;	
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	ТипДенежныхСредств_Наличные 						= Перечисления.ТипыДенежныхСредств.Наличные;
	ТипДенежныхСредств_ЛицевойСчет 						= Перечисления.ТипыДенежныхСредств.ЛицевойСчет;
	ТипДенежныхСредств_Безналичные 						= Перечисления.ТипыДенежныхСредств.Безналичные;	
	ТипДенежныхСредств_ПлатежнаяКарта 					= Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта;	
	СтатьяДвиженияДенежныхСредств_ОплатаОтКлиента		= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ОплатаОтКлиента);
	СтатьяДвиженияДенежныхСредств_ВозвратОплатыКлиенту 	= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Реализации 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Реализации;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Реализации, "Таблица_Реализации");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Таблица_Реализации.Организация КАК Организация
	               |ИЗ
	               |	Таблица_Реализации КАК Таблица_Реализации
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации.Организация
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Реализации.Исполнитель КАК Тренер,
	               |	Таблица_Реализации.ИсполнительГруппа КАК ТренерГруппа
	               |ИЗ
	               |	Таблица_Реализации КАК Таблица_Реализации
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации.ИсполнительГруппа,
	               |	Таблица_Реализации.Исполнитель
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Реализации.ОператорЧека КАК МенеджерПоПродажам
	               |ИЗ
	               |	Таблица_Реализации КАК Таблица_Реализации
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации.ОператорЧека
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Таблица_Реализации.ОператорОплаты
	               |ИЗ
	               |	Таблица_Реализации КАК Таблица_Реализации
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации.ОператорОплаты
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВидыЛицевыхСчетов.Ссылка КАК Ссылка,
	               |	ВидыЛицевыхСчетов.Наименование КАК Наименование,
	               |	ВидыЛицевыхСчетов.Предопределенный КАК Предопределенный,
	               |	ВидыЛицевыхСчетов.ОграничиватьСуммуСписанияСоСчета КАК ОграничиватьСуммуСписанияСоСчета,
	               |	ВидыЛицевыхСчетов.ПроцентОграниченияСуммыСписанияСоСчета КАК ПроцентОграниченияСуммыСписанияСоСчета,
	               |	ВидыЛицевыхСчетов.ОграничениеПоСрокуДействия КАК ОграничениеПоСрокуДействия,
	               |	ВидыЛицевыхСчетов.Внешний КАК Внешний,
	               |	ВидыЛицевыхСчетов.Организация КАК Организация,
	               |	ВидыЛицевыхСчетов.НеВестиУчетВРазрезеОрганизаций КАК НеВестиУчетВРазрезеОрганизаций,
	               |	ВидыЛицевыхСчетов.СрокДействияДатойС КАК СрокДействияДатойС,
	               |	ВидыЛицевыхСчетов.СрокДействияДатойПо КАК СрокДействияДатойПо,
	               |	ВидыЛицевыхСчетов.СрокДействияТип КАК СрокДействияТип,
	               |	ВидыЛицевыхСчетов.СрокДействия КАК СрокДействия
	               |ИЗ
	               |	Справочник.ВидыЛицевыхСчетов КАК ВидыЛицевыхСчетов
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Реализации.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Реализации.ИДКлиента КАК ИДКлиента,
	               |	Таблица_Реализации.НомерСчета КАК НомерСчета,
	               |	Таблица_Реализации.НомерЛС КАК НомерЛС,
	               |	Таблица_Реализации.Аннулирован КАК Аннулирован,
	               |	Таблица_Реализации.ТипОплаты КАК ТипОплаты,
	               |	Таблица_Реализации.СуммаОплаты КАК СуммаОплаты,
	               |	Таблица_Реализации.ДатаЧека КАК ДатаПродажи,
	               |	Таблица_Реализации.ДатаОплаты КАК ДатаОплаты,
	               |	Контрагенты.Ссылка КАК Клиент,
	               |	ПоступлениеДенежныхСредств.Ссылка КАК ПкоСсылка,
	               |	СписаниеДенежныхСредств.Ссылка КАК РкоСсылка
	               |ИЗ
	               |	Таблица_Реализации КАК Таблица_Реализации
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Реализации.ИДКлиента = Контрагенты.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.ИДКлиента > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	               |		ПО Таблица_Реализации.НомерЧека = ПоступлениеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = ПоступлениеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.НомерЧека > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	               |		ПО Таблица_Реализации.НомерЧека = СписаниеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = СписаниеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.НомерЧека > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДКлиента,
	               |	НомерСчета,
	               |	Таблица_Реализации.НомерЧека
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЛицевыеСчета.Ссылка КАК Ссылка,
	               |	ЛицевыеСчета.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
	               |	ЛицевыеСчета.ВладелецЛицевогоСчета КАК ВладелецЛицевогоСчета,
	               |	ЛицевыеСчета.КодСинхронизации КАК КодСинхронизации,
	               |	ЛицевыеСчета.ПрефиксСинхронизации КАК ПрефиксСинхронизации
	               |ИЗ
	               |	Справочник.ЛицевыеСчета КАК ЛицевыеСчета";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ВыборкаОрганизации			 				= РезультатПакетаЗапросов[0].Выбрать();
	ТаблицаТренеров	 							= РезультатПакетаЗапросов[1].Выгрузить();	
	ТаблицаМенеджеровПоПродажам					= РезультатПакетаЗапросов[2].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[3].Выгрузить();
	ТаблицаВидовЛицевыхСчетовВБазе				= РезультатПакетаЗапросов[4].Выгрузить();
	ТаблицаЛицевыхСчетов 						= РезультатПакетаЗапросов[5].Выгрузить();
	ТаблицаЛицевыхСчетовВБазе					= РезультатПакетаЗапросов[6].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем необходимые виды ЛС на текущем этапе
	АктуализироватьТаблицуВидовЛицевыхСчетов(ТаблицаВидовЛицевыхСчетовВБазе);
	
	// Создадим и заполним таблицу соответствия организаций и касс	
	ТаблицаОрганизации = Новый ТаблицаЗначений;
	ТаблицаОрганизации.Колонки.Добавить("Организация"				,Новый ОписаниеТипов("Строка" ,, Новый КвалификаторыСтроки(90)));
	ТаблицаОрганизации.Колонки.Добавить("ОрганизацияСсылка"			,Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТаблицаОрганизации.Колонки.Добавить("КассаСсылка"				,Новый ОписаниеТипов("СправочникСсылка.Кассы"));
	ТаблицаОрганизации.Колонки.Добавить("БанковскийСчетПоУмолчанию"	,Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));
	ТаблицаОрганизации.Колонки.Добавить("ЭквайринговыйТерминал"		,Новый ОписаниеТипов("СправочникСсылка.ЭквайринговыеТерминалы"));
	
	// Создаем организации и соответствия организаций и касс
	Пока ВыборкаОрганизации.Следующий() Цикл
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));	
		ОрганизацияНаименование 					= СтрЗаменить(ВыборкаОрганизации.Организация, """""", """");
		СтрокаОрганизация = ТаблицаОрганизации.Найти(ОрганизацияНаименование, "Организация");
		Если СтрокаОрганизация = Неопределено Тогда 
			СтруктураОрганизация 						= СоздатьОрганизацию(ОрганизацияНаименование, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТаблицаВидовЛицевыхСчетовВБазе);
			СтрокаТаблицыОиК 							= ТаблицаОрганизации.Добавить();
			СтрокаТаблицыОиК.Организация 				= ВыборкаОрганизации.Организация;
			СтрокаТаблицыОиК.ОрганизацияСсылка 			= СтруктураОрганизация.ОрганизацияСсылка;
			СтрокаТаблицыОиК.КассаСсылка 				= СтруктураОрганизация.КассаСсылка;
			СтрокаТаблицыОиК.БанковскийСчетПоУмолчанию 	= СтруктураОрганизация.БанковскийСчетПоУмолчанию;
			СтрокаТаблицыОиК.ЭквайринговыйТерминал 		= СтруктураОрганизация.ЭквайринговыйТерминал;
		КонецЕсли;
	КонецЦикла;	
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	// Получим должность для тренера	
	ДолжностьТренер 	= ПолучитьДолжностьПоНаименованию("Тренер");
	
	// Создаем необходимых тренеров на текущем этапе
	Для Каждого СтрокаТренер Из ТаблицаТренеров Цикл
		Если НЕ СокрЛП(СтрокаТренер.Тренер) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.Тренер), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				ГруппаСотрудника = Неопределено;
				Если НЕ СокрЛП(СтрокаТренер.ТренерГруппа) = "" Тогда
					МассивСтрокГруппСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.ТренерГруппа), Истина));
					Если МассивСтрокГруппСотрудников.Количество() = 0 Тогда
						ГруппаСотрудника = СоздатьГруппуСотрудникаПоНаименованию(СтрокаТренер.ТренерГруппа, ТекстовыйНакопитель);
						ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ГруппаСотрудника);
					Иначе 
						ГруппаСотрудника = МассивСтрокГруппСотрудников[0].Ссылка;
					КонецЕсли;
				КонецЕсли;
				ТренерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаТренер.Тренер, ДолжностьТренер, ГруппаСотрудника, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ТренерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаТренер.Тренер, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеровПоПродажам Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.МенеджерПоПродажам) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.МенеджерПоПродажам), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.МенеджерПоПродажам, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.МенеджерПоПродажам, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимые ЛС на текущем этапе
	АктуализироватьТаблицуЛицевыхСчетовНаЭтапеРеализация(ТаблицаЛицевыхСчетовВБазе, ТаблицаЛицевыхСчетов, ТаблицаВидовЛицевыхСчетовВБазе, ТекстовыйНакопитель);
	
	#КонецОбласти
		
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по реализациям...';en='Saving data by realizations...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	КоличествоПотоков 				= ПараметрыЗадания.ПараметрыЗагрузки.КоличествоПотоковДляЭтапаРеализации;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	МассивТаблиц 					= Новый Массив;
	РазбитьТаблицуОбъектовПоКлючевомуПолю(Таблица_Реализации, "ИДКлиента", КоличествоПотоков, МассивТаблиц);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Генерация фоновых заданий...';en='Generation of background works...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Генерируем фоновые задания
	МассивФоновыхЗаданий 				= Новый Массив;
	МассивИдентификаторовФоновыхЗаданий = Новый Массив;
	Для Каждого ТаблицаОбъектов Из МассивТаблиц Цикл 
		УникальныйИдентификаторЗадания 	= Новый УникальныйИдентификатор();
		ПараметрыПроцедуры = ПараметрыЗадания;
		ПараметрыПроцедуры.СписокТаблиц[0].Значение.Таблица_Реализации 			= ТаблицаОбъектов;
		ПараметрыПроцедуры.СписокТаблиц[0].Значение.КоличествоПолученныхСтрок 	= ТаблицаОбъектов.Количество();
		ПараметрыПроцедуры.Вставить("ТаблицаВидовЛицевыхСчетовВБазе"		, ТаблицаВидовЛицевыхСчетовВБазе);
		ПараметрыПроцедуры.Вставить("ТаблицаОрганизации"					, ТаблицаОрганизации);
		ПараметрыПроцедуры.Вставить("ТаблицаСотрудниковВБазе"				, ТаблицаСотрудниковВБазе);
		ПараметрыПроцедуры.Вставить("ТаблицаЛицевыхСчетовВБазе"				, ТаблицаЛицевыхСчетовВБазе);
		
		Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторЗадания,
		"ЗагрузкаПроведениеДокументов.ЗагрузитьРеализацииВПотокеAccess",
		ПараметрыПроцедуры,
		НСтр("ru = 'Генерация док-ов Реализация. Поток № " + Строка(МассивТаблиц.Найти(ТаблицаОбъектов)) + "'"));
		
		Если НЕ Результат = Неопределено Тогда 
			Задание = ДлительныеОперации.НайтиЗаданиеПоИдентификатору(Результат.ИдентификаторЗадания);
			Если НЕ Задание = Неопределено Тогда 
				МассивФоновыхЗаданий.Добавить(Задание);
				МассивИдентификаторовФоновыхЗаданий.Добавить(Результат.ИдентификаторЗадания);
			КонецЕсли;
		Иначе 
			ОшибкаИнициацииФоновогоЗадания = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Передача идентификаторов фоновых заданий...';en='Broadcast background assignments ids...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, МассивИдентификаторовФоновыхЗаданий", "", 0, "", МассивИдентификаторовФоновыхЗаданий));
	
	// Ожидаем выполнения фоновых заданий 
	Если МассивФоновыхЗаданий.Количество() > 0 Тогда 
		Попытка 
			ФоновыеЗадания.ОжидатьЗавершения(МассивФоновыхЗаданий); 
		Исключение
			ОшибкаИнициацииФоновогоЗадания = Истина;			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка проведения!");
		КонецПопытки; 
	КонецЕсли;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаТренеров.Очистить(); 						ТаблицаТренеров 				= Неопределено;
	ТаблицаМенеджеровПоПродажам.Очистить(); 			ТаблицаМенеджеровПоПродажам 	= Неопределено;	
	ТаблицаСотрудниковВБазе.Очистить();					ТаблицаСотрудниковВБазе 		= Неопределено;
	ТаблицаВидовЛицевыхСчетовВБазе.Очистить(); 			ТаблицаВидовЛицевыхСчетовВБазе 	= Неопределено;
	ТаблицаЛицевыхСчетов.Очистить(); 					ТаблицаЛицевыхСчетов 			= Неопределено;
	ТаблицаЛицевыхСчетовВБазе.Очистить(); 				ТаблицаЛицевыхСчетовВБазе 		= Неопределено;
									 					
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить реализации в потоке access
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьРеализацииВПотокеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ЮрФизЛицо_ФизЛицо 									= Перечисления.ЮрФизЛицо.ФизЛицо;
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	ВидКарты_Магнитная 									= Перечисления.ВидыКарт.Магнитная;		
	ВидКартыШтриховая 									= Перечисления.ВидыКарт.Штриховая;	
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	ТипДенежныхСредств_Наличные 						= Перечисления.ТипыДенежныхСредств.Наличные;
	ТипДенежныхСредств_ЛицевойСчет 						= Перечисления.ТипыДенежныхСредств.ЛицевойСчет;
	ТипДенежныхСредств_Безналичные 						= Перечисления.ТипыДенежныхСредств.Безналичные;	
	ТипДенежныхСредств_ПлатежнаяКарта 					= Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта;	
	СтатьяДвиженияДенежныхСредств_ОплатаОтКлиента		= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ОплатаОтКлиента);
	СтатьяДвиженияДенежныхСредств_ВозвратОплатыКлиенту 	= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Реализации 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Реализации;
	ТаблицаВидовЛицевыхСчетовВБазе 						= ПараметрыЗадания.ТаблицаВидовЛицевыхСчетовВБазе;
	ТаблицаОрганизации 									= ПараметрыЗадания.ТаблицаОрганизации;
	ТаблицаЛицевыхСчетовВБазе 							= ПараметрыЗадания.ТаблицаЛицевыхСчетовВБазе;
	ТаблицаСотрудниковВБазе 							= ПараметрыЗадания.ТаблицаСотрудниковВБазе;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Реализации, "Таблица_Реализации");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Реализации.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Реализации.ИДКлиента КАК ИДКлиента,
	               |	Таблица_Реализации.НомерСчета КАК НомерСчета,
	               |	Таблица_Реализации.НомерЧека КАК НомерЧека,
	               |	Таблица_Реализации.НомерЧекаККМ КАК НомерЧекаККМ,
	               |	Таблица_Реализации.ИДНоменклатуры КАК ИДНоменклатуры,
	               |	Таблица_Реализации.ИДНоменклатурыДоп КАК ИДНоменклатурыДоп,
	               |	Таблица_Реализации.Исполнитель КАК Исполнитель,
	               |	Таблица_Реализации.ИДБлока КАК ИДБлока,
	               |	Таблица_Реализации.Организация КАК Организация,
	               |	Таблица_Реализации.Аннулирован КАК Аннулирован,
	               |	Таблица_Реализации.ДатаЧека КАК ДатаЧека,
	               |	Таблица_Реализации.ОператорЧека КАК ОператорЧека,
	               |	Таблица_Реализации.СуммаОплаты КАК СуммаОплаты,
	               |	Таблица_Реализации.Пробит КАК Пробит,
	               |	Таблица_Реализации.ТипОплаты КАК ТипОплаты,
	               |	Таблица_Реализации.ДатаОплаты КАК ДатаОплаты,
	               |	Таблица_Реализации.СрокДействияВычисляемый КАК СрокДействияВычисляемый,
	               |	Таблица_Реализации.ОператорОплаты КАК ОператорОплаты,
	               |	Таблица_Реализации.КоличествоНоменклатуры КАК КоличествоНоменклатуры,
	               |	Таблица_Реализации.Цена КАК Цена,
	               |	Таблица_Реализации.Цена * ВЫБОР
	               |		КОГДА Таблица_Реализации.КоличествоНоменклатуры > 0
	               |				И Таблица_Реализации.ТипНоменклатуры = 3
	               |			ТОГДА 1
	               |		ИНАЧЕ Таблица_Реализации.КоличествоНоменклатуры
	               |	КОНЕЦ КАК Стоимость,
	               |	Таблица_Реализации.СтоимостьСУчетомВозврата КАК СтоимостьСУчетомВозврата,
	               |	Таблица_Реализации.ТипНоменклатуры КАК ТипНоменклатуры,
	               |	Таблица_Реализации.КоличествоУслуг КАК КоличествоУслуг,
	               |	Таблица_Реализации.ИсполнительГруппа КАК ИсполнительГруппа,
	               |	Таблица_Реализации.НомерЛС КАК НомерЛС,
	               |	Таблица_Реализации.ОкончаниеКонтракта КАК ОкончаниеКонтракта,
	               |	Таблица_Реализации.КоличествоДнейЗаморозки КАК КоличествоДнейЗаморозки,
	               |	Контрагенты.Ссылка КАК Клиент,
	               |	НоменклатураСтроки.Ссылка КАК НоменклатураСтроки,
	               |	НоменклатураСтрокиДоп.Ссылка КАК НоменклатураСтрокиДоп,
	               |	ВЫБОР
	               |		КОГДА НЕ НоменклатураСтроки.Ссылка ЕСТЬ NULL
	               |			ТОГДА НоменклатураСтроки.ТипНоменклатуры
	               |		КОГДА НЕ НоменклатураСтрокиДоп.Ссылка ЕСТЬ NULL
	               |			ТОГДА НоменклатураСтрокиДоп.ТипНоменклатуры
	               |		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПустаяСсылка)
	               |	КОНЕЦ КАК ТипНоменклатурыСтроки,
	               |	НоменклатураУслугиПакета.Ссылка КАК НоменклатураУслугиПакета,
	               |	НоменклатураУслугиПакетаДоп.Ссылка КАК НоменклатураУслугиПакетаДоп,
	               |	ЧленствоПакетУслуг.Ссылка КАК ПакетУслугСсылка,
	               |	Реализация.Ссылка КАК РеализацияСсылка,
	               |	ПоступлениеДенежныхСредств.Ссылка КАК ПкоСсылка,
	               |	СписаниеДенежныхСредств.Ссылка КАК РкоСсылка
	               |ИЗ
	               |	Таблица_Реализации КАК Таблица_Реализации
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Реализации.ИДКлиента = Контрагенты.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.ИДКлиента > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСтроки
	               |		ПО Таблица_Реализации.ИДНоменклатуры = НоменклатураСтроки.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = НоменклатураСтроки.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.ИДНоменклатуры > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСтрокиДоп
	               |		ПО Таблица_Реализации.ИДНоменклатурыДоп = НоменклатураСтрокиДоп.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = НоменклатураСтрокиДоп.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.ИДНоменклатурыДоп > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураУслугиПакета
	               |		ПО Таблица_Реализации.КодУслугиБлока_ИДНоменклатуры = НоменклатураУслугиПакета.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = НоменклатураУслугиПакета.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.КодУслугиБлока_ИДНоменклатуры > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураУслугиПакетаДоп
	               |		ПО Таблица_Реализации.КодУслугиБлока_ИДНоменклатурыДоп = НоменклатураУслугиПакетаДоп.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = НоменклатураУслугиПакетаДоп.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.КодУслугиБлока_ИДНоменклатурыДоп > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |		ПО Таблица_Реализации.ИДБлока = ЧленствоПакетУслуг.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = ЧленствоПакетУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.ИДБлока > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Реализация КАК Реализация
	               |		ПО Таблица_Реализации.НомерСчета = Реализация.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = Реализация.ПрефиксСинхронизации
	               |			И Таблица_Реализации.ИДКлиента = Реализация.Контрагент.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = Реализация.Контрагент.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.НомерСчета > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	               |		ПО Таблица_Реализации.НомерЧека = ПоступлениеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = ПоступлениеДенежныхСредств.ПрефиксСинхронизации
	               |			И Таблица_Реализации.ИДКлиента = ПоступлениеДенежныхСредств.Контрагент.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = ПоступлениеДенежныхСредств.Контрагент.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.НомерЧека > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	               |		ПО Таблица_Реализации.НомерЧека = СписаниеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Реализации.ПрефиксСинхронизации = СписаниеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Реализации.НомерЧека > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДКлиента,
	               |	НомерСчета,
	               |	НомерЧека
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(НомерЧекаККМ),
	               |	МАКСИМУМ(Исполнитель),
	               |	МАКСИМУМ(Организация),
	               |	МАКСИМУМ(Аннулирован),
	               |	МАКСИМУМ(ДатаЧека),
	               |	МАКСИМУМ(ОператорЧека),
	               |	МАКСИМУМ(СуммаОплаты),
	               |	МАКСИМУМ(Пробит),
	               |	МАКСИМУМ(ТипОплаты),
	               |	МАКСИМУМ(ДатаОплаты),
	               |	МАКСИМУМ(ОператорОплаты),
	               |	СУММА(КоличествоНоменклатуры),
	               |	МАКСИМУМ(Цена),
	               |	СУММА(Стоимость),
	               |	МАКСИМУМ(СтоимостьСУчетомВозврата),
	               |	МАКСИМУМ(ТипНоменклатуры),
	               |	МАКСИМУМ(КоличествоУслуг),
	               |	МАКСИМУМ(ИсполнительГруппа),
	               |	МАКСИМУМ(НомерЛС),
	               |	МАКСИМУМ(ОкончаниеКонтракта),
	               |	МАКСИМУМ(КоличествоДнейЗаморозки),
	               |	МАКСИМУМ(Клиент),
	               |	МАКСИМУМ(НоменклатураСтроки),
	               |	МАКСИМУМ(НоменклатураСтрокиДоп),
	               |	МАКСИМУМ(ТипНоменклатурыСтроки),
	               |	МАКСИМУМ(НоменклатураУслугиПакета),
	               |	МАКСИМУМ(НоменклатураУслугиПакетаДоп),
	               |	МАКСИМУМ(ПакетУслугСсылка),
	               |	МАКСИМУМ(РеализацияСсылка),
	               |	МАКСИМУМ(ПкоСсылка),
	               |	МАКСИМУМ(РкоСсылка)
	               |ПО
	               |	ИДКлиента,
	               |	НомерСчета,
	               |	ИДНоменклатуры,
	               |	Исполнитель,
	               |	НомерЧека";
	
	#КонецОбласти
	                                        
	ВыборкаПоКлиентам									= Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	Если ВыборкаПоКлиентам.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по реализациям...';en='Saving data by realizations...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоРеализаций 	= ВыборкаПоКлиентам.Количество();
	ОбщееКоличествоРеализаций	= ?(ОбщееКоличествоРеализаций < 1, 1, ОбщееКоличествоРеализаций);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоРеализаций			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеРеализации		= "";
	
	МассивБессрочныхЧПУ = ПолучитьМассивБессрочныхЧПУ(ПараметрыЗадания.ПараметрыЗагрузки.СегментБессрочныхЧПУ);
	ПараметрыЗадания.ПараметрыЗагрузки.Вставить("МассивБессрочных", МассивБессрочныхЧПУ);
	
	ЕстьПакетУслуг = Ложь;	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКлиентам.Следующий() Цикл
		СообщилиПрогресс 	= Ложь;
		СозданоРеализаций 	= СозданоРеализаций + 1;
		
	#Область Получение_контрагента
		
		// Создаем клиента не выгруженного по каким-то причинам (наполнение контрагента будет отличаться от созданных на этапе "Клиенты"!)
		Если ЗначениеЗаполнено(ВыборкаПоКлиентам.Клиент) Тогда
			ТекущийКлиент 				= ВыборкаПоКлиентам.Клиент;
			КлиентНайден 				= Истина;
		Иначе
			Клиент 						= Справочники.Контрагенты.СоздатьЭлемент();
			Клиент.Родитель 			= ПараметрыЗадания.ПараметрыЗагрузки.ВыборПапкиСправочника; 
			Клиент.Наименование 		= ВыборкаПоКлиентам.ИДКлиента;
			Клиент.НаименованиеПолное 	= ВыборкаПоКлиентам.ИДКлиента;
			Клиент.КодСинхронизации 	= ВыборкаПоКлиентам.ИДКлиента;
			Клиент.ПрефиксСинхронизации	= ВыборкаПоКлиентам.ПрефиксСинхронизации;			
			Клиент.ЮрФизЛицо 			= ЮрФизЛицо_ФизЛицо;
			Клиент.ТипКонтрагента 		= ТипКонтрагента_Клиенты;
			Клиент.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			Клиент.Комментарий 			= ВыборкаПоКлиентам.ПрефиксСинхронизации;
			Клиент.УстановитьНовыйКод();
			Клиент.ОбменДанными.Загрузка = Истина;
			Попытка
				Клиент.Записать();
			Исключение
				// Запись в лог						
				ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка при создании клиента! Код синхронизации: ';en= 'Error creating client! Sync Code: '") + Строка(ВыборкаПоКлиентам.ИДКлиента) + Символы.ПС + ОписаниеОшибки());						
			КонецПопытки;	
			ТекущийКлиент 				= Клиент.Ссылка; // Создаем клиента не выгруженного по каким-то причинам   
			КлиентНайден 				= Ложь;			
		КонецЕсли;
		
	#КонецОбласти
		
		ВыборкаПоЧекам = ВыборкаПоКлиентам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НомерСчета");
		
		Пока ВыборкаПоЧекам.Следующий() Цикл
			Если ВыборкаПоЧекам.Аннулирован <> 0 Тогда  // пропускаем аннулированные реализации.
				Продолжить;
			КонецЕсли;
			ЕстьПакетУслуг = Ложь;
			// Выберем организацию и кассу тек.строки
			СтрокаОрганизация 			= ТаблицаОрганизации.Найти(ВыборкаПоЧекам.Организация, "Организация");
			ТекКасса 					= СтрокаОрганизация.КассаСсылка;
			ТекОрганизация 				= СтрокаОрганизация.ОрганизацияСсылка;
			БанковскийСчетПоУмолчанию 	= СтрокаОрганизация.БанковскийСчетПоУмолчанию;
			ЭквайринговыйТерминал 		= СтрокаОрганизация.ЭквайринговыйТерминал; 
			
			// Менеджер реализации
			МенеджерСтрокой = СокрЛП(ВыборкаПоЧекам.ОператорЧека);
			МенеджерРеализации = Сотрудник_ПустаяСсылка;
			Если МенеджерСтрокой <> "" Тогда
				СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", МенеджерСтрокой, Ложь));
				Если НЕ СтрокаМенеджерСотрудник.Количество() = 0 Тогда
					МенеджерРеализации = СтрокаМенеджерСотрудник[0].Ссылка;
				КонецЕсли;
			КонецЕсли;	
			
			Если ЗначениеЗаполнено(ВыборкаПоЧекам.РеализацияСсылка) Тогда
				Если ПараметрыЗадания.ПараметрыЗагрузки.ТолькоНовые Тогда
					Продолжить;
				Иначе				
					ДокументРеализация = ВыборкаПоЧекам.РеализацияСсылка.ПолучитьОбъект();
					ДокументРеализация.Запасы.Очистить();
				КонецЕсли;
			Иначе
				ДокументРеализация 						= Документы.Реализация.СоздатьДокумент();
				ДокументРеализация.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
				ДокументРеализация.Склад 				= ПараметрыЗадания.ПараметрыЗагрузки.ОсновнойСкладСтруктурнойЕдиницы;
				ДокументРеализация.Организация 			= ТекОрганизация;
				ДокументРеализация.Дата 				= ВыборкаПоЧекам.ДатаЧека;
				ДокументРеализация.КодСинхронизации 	= ВыборкаПоЧекам.НомерСчета;
				ДокументРеализация.ПрефиксСинхронизации	= ВыборкаПоЧекам.ПрефиксСинхронизации;				
				ДокументРеализация.Комментарий 			= ВыборкаПоЧекам.ПрефиксСинхронизации + " - " + Формат(ВыборкаПоЧекам.НомерСчета, "ЧГ=0");
				ДокументРеализация.Контрагент 			= ТекущийКлиент;
				ДокументРеализация.АвторДокумента 		= ?(ЗначениеЗаполнено(МенеджерРеализации), МенеджерРеализации, ТекущийПользовательСеанса);
				ДокументРеализация.ВидЦен 				= ВидЦен_Розничная;
			КонецЕсли;		
			
			МоделируемаяТаблицаЗапасов = ИнициализироватьТаблицуЗначенийЗапасы();
			
			ВыборкаПоНоменклатуре = ВыборкаПоЧекам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ИДНоменклатуры");
			
			#Область Создание_пакетов_услуг_и_заполнение_их_в_ТЧ_Реализации
			
			Пока ВыборкаПоНоменклатуре.Следующий() Цикл
				Если ВыборкаПоНоменклатуре.КоличествоНоменклатуры = 0 И ВыборкаПоНоменклатуре.Стоимость = 0 Тогда // пропуск если полный возврат номенклатуры
					Продолжить;
				КонецЕсли;
				ВыборкаПоСтрокам = ВыборкаПоНоменклатуре.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Исполнитель");
				Пока ВыборкаПоСтрокам.Следующий() Цикл
					Если ВыборкаПоСтрокам.КоличествоНоменклатуры = 0 И ВыборкаПоСтрокам.Стоимость = 0 Тогда // пропуск если полный возврат номенклатуры
						Продолжить;
					КонецЕсли;
					// Строка в реализации с номенклатурой и исполнителем
