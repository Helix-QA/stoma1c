	// Закладка скидки/наценки
	Если ЭтаФорма.Элементы.Найти("Группа_Кнопки_СкидкиНаценки") <> Неопределено Тогда	
		
		Если Объект.СкидкиНаценки.Количество() > 0 Тогда
			ЭтаФорма.Элементы.Группа_Кнопки_СкидкиНаценки.Видимость = Истина;
