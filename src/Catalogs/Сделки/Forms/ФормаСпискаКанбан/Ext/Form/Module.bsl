// Функция, возвращает данные сделки.
//
Функция ПолучитьДанныеСделки(Знач СтруктураОтбора, Сделка = Неопределено, ИсключаемыеСделки = Неопределено)
	
	Запрос = ЗапросПолученияДанных(СтруктураОтбора, Сделка, ИсключаемыеСделки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КолонкиРезультата = Новый Массив;
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		КолонкиРезультата.Добавить(Колонка.Имя);
	КонецЦикла;
	
	ВыборкаПоЭтапу = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПоЭтапу.Следующий();
	
	Выборка = ВыборкаПоЭтапу.Выбрать();
	Выборка.Следующий();
	
	ДанныеСделки = Новый Структура(СтрСоединить(КолонкиРезультата, ","));
	ЗаполнитьЗначенияСвойств(ДанныеСделки, Выборка);
	
	Возврат ДанныеСделки;
	
КонецФункции

