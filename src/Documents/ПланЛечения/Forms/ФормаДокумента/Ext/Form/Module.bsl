			// Заполнение списка выбора
			Элементы.КартаКонтрагента.СписокВыбора.ЗагрузитьЗначения(МассивДисконтныхКарт);
			Если МассивДисконтныхКарт.Количество() > 0 И РежимНастройки = Неопределено Тогда
				Объект.КартаКонтрагента = МассивДисконтныхКарт[0];
			КонецЕсли;
		Иначе 
			Объект.КартаКонтрагента = Неопределено;
			Элементы.КартаКонтрагента.СписокВыбора.Очистить();
