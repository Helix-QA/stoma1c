// Функция - Рабочие дни структурной единицы
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РабочиеДниСтруктурнойЕдиницы(СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СтруктурныеЕдиницыРасписаниеРаботы.ДеньНедели КАК ДеньНедели,
	|	СтруктурныеЕдиницыРасписаниеРаботы.НачалоРаботы КАК НачалоРаботы,
	|	СтруктурныеЕдиницыРасписаниеРаботы.ОкончаниеРаботы КАК ОкончаниеРаботы,
	|	СтруктурныеЕдиницыРасписаниеРаботы.Активность КАК Активность
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК СтруктурныеЕдиницыРасписаниеРаботы
	|ГДЕ
	|	СтруктурныеЕдиницыРасписаниеРаботы.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДеньНедели");
	
	Запрос.УстановитьПараметр("Ссылка", СтруктурнаяЕдиница);
	
	РасписаниеРаботы = Запрос.Выполнить().Выгрузить();
	
	РабочиеДни = Новый Массив;
	Для Каждого СтрокаТ ИЗ РасписаниеРаботы Цикл		
		Если СтрокаТ.Активность = Истина Тогда			
			ДатаОкончанияРаботы = СтрокаТ.ОкончаниеРаботы;
			Если НЕ ЗначениеЗаполнено(ДатаОкончанияРаботы) Тогда
				ДатаОкончанияРаботы = Дата('0001010123:59:59')
			КонецЕсли;			
			РабочиеДни.Добавить(Новый Структура("ДеньНедели,ДатаНачала,ДатаОкончания", Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели)), СтрокаТ.НачалоРаботы, ДатаОкончанияРаботы));			
		КонецЕсли;		
	КонецЦикла;	  
	
	Возврат РабочиеДни;
	
КонецФункции

// Функция - Версия ПОСервер актуальна
//
// Параметры:
//  ВерсияПОСервер		 - 	 - 
//  ЗначениеСравнения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВерсияПОСерверАктуальна(Знач ВерсияПОСервер, Знач ЗначениеСравнения)
	
	Если СтрЗаканчиваетсяНа(ВерсияПОСервер, "00") Тогда
		ВерсияПОСервер = Сред(ВерсияПОСервер, 1, СтрДлина(ВерсияПОСервер) - 2);
	КонецЕсли;
	
	Строка1 = ?(ПустаяСтрока(ВерсияПОСервер), "0.0.0.0", ВерсияПОСервер);
	Строка2 = ?(ПустаяСтрока(ЗначениеСравнения), "0.0.0.0", ЗначениеСравнения);
	Версия1 = СтрРазделить(Строка1, ".");
	Если Версия1.Количество() <> 4 Тогда
		Возврат Ложь;
	КонецЕсли;
	Версия2 = СтрРазделить(Строка2, ".");
	Если Версия2.Количество() <> 4 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Результат = 0;
	Для Разряд = 0 По 3 Цикл
		Результат = Число(Версия1[Разряд]) - Число(Версия2[Разряд]);
		Если Результат <> 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат >= 0;
	
КонецФункции

// Функция - Заменить номер телефона для врача
//
// Параметры:
//  НомерТелефона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаменитьНомерТелефонаДляВрача(НомерТелефона)
	
	ВремТелефон = "";
	
	Для Индекс = 1 По СтрДлина(НомерТелефона) Цикл
		Символ = Сред(НомерТелефона, Индекс, 1);
		Если КодСимвола(Символ) >= 48 И КодСимвола(Символ) <= 57 Тогда
			Символ = "*";
		КонецЕсли;
		ВремТелефон = ВремТелефон + Символ;
	КонецЦикла;
	
	Возврат ВремТелефон;
	
КонецФункции

// Функция - Роль пользователя урезана
//
// Параметры:
//  Сотрудник	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РольПользователяУрезана(Сотрудник, РольПользователя = Неопределено)
	
	Если РольПользователя = Неопределено Тогда
		РольПользователя = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник,"Роль");
	КонецЕсли;
	
	Возврат РольПользователя = Перечисления.РольПользователя.Врач 
		ИЛИ РольПользователя = Перечисления.РольПользователя.ГлавныйВрач 
		ИЛИ РольПользователя = Перечисления.РольПользователя.Ассистент;
	
КонецФункции

