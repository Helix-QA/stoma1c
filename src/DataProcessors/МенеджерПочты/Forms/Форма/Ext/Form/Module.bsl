// Процедура осуществляет необходимые действия при изменении папки электронных писем
//
Процедура ПанельУправленияПриАктивизацииСтроки(Элемент)
	
	ОписаниеПисьма = "
	|<html>
	|<head>  
	|<META http-equiv=Content-Type content=""text/html; charset=utf-8"">
	|<META content=""MSHTML 6.00.2800.1400"" name=GENERATOR>
	|<body scroll=""auto"">
	|</body>
	|</html>";
	
	СтрОтправитель = "";
	СтрКому = "";
	СтрТема = "";
	Вложения.Очистить();
		
	ОбновитьСписокПисем();
	
КонецПроцедуры

&НаКлиенте
// Процедура выполняет необходимые действия при выделении электронного письма в списке писем
//
Процедура СписокПисемПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ОбработчикОжиданияСписокПисемПриАктивизацииСтроки",0.1,Истина);
	
	Если ОтборСпискаПисем <> "Непрочитанные" Тогда
		ПодключитьОбработчикОжидания("АвтоустановкаРассмотренностиПисьма", 1, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура выполняет сопутствующие действия перед открытием формы выбранного электронного письма
//
Процедура СписокПисемВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОтключитьОбработчикОжидания("АвтоустановкаРассмотренностиПисьма");
	
	АвтоустановкаРассмотренностиПисьма();
	
КонецПроцедуры

&НаКлиенте
// Процедура перестраивает список писем в соответствии с установленным отбором
//
Процедура ПолеОтбораПриИзменении(Элемент)
	
	ОбновитьСписокПисем();	
	
КонецПроцедуры

