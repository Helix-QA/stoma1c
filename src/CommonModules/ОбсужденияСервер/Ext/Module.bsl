Процедура ПреобразоватьСсылкиПользователей(Текст, ПользователиРассылки) Экспорт
	
	ОписанияПользователей = МассивОписанийПользователей();
	Для каждого Элемент Из ОписанияПользователей Цикл
		Если Найти(Текст, "@"+Элемент.Имя)=0 Тогда
			Продолжить;
		КонецЕсли;
		Текст = СтрЗаменить(Текст, "@"+Элемент.Имя, HTMLСсылка(Элемент.Пользователь));
		ПользователиРассылки.Добавить(Элемент.Пользователь);
	КонецЦикла; 
	
КонецПроцедуры

Процедура СформироватьНапоминанияПользователям(Ссылка, Комментарий, ПользователиРассылки) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Для каждого ПользовательРассылки Из ПользователиРассылки Цикл
		НоваяЗадача = Задачи.ЗадачаИсполнителя.СоздатьЗадачу();
		Основание = ?(ТипЗнч(Ссылка) = Тип("СправочникСсылка.Контрагенты"), "из заметок", "из задачи");
