&НаСервере
// Функция - Заполнить информацию по кассам
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаполнитьИнформациюПоКассам()
	
	ОтборКассы = Неопределено;
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ОтборКассоваяСмена) Тогда
	 	ОтборКассы = Справочники.Кассы.ПолучитьКассыДляОплаты(СтруктурнаяЕдиница);		
	Иначе
		ОтборКассы = Новый Массив;
		ОтборКассы.Добавить(ЭтотОбъект.ОтборКассоваяСмена.Касса);
	КонецЕсли;
	 	
	ДанныеПоКассам.Очистить();
	
	Счетчик = 1;
	Для Каждого Касса Из ОтборКассы Цикл
		
		СтатусФр = РозничныеПродажи.ПроверитьИспользованиеФРвКассе(Касса);
				
		ДатаВремяНачалаОтбора = Неопределено;
		ДатаВремяКонцаОтбора  = Неопределено;

		Если СтатусФр = Истина И ОтборПериод.Вариант = ВариантСтандартногоПериода.Сегодня Тогда
			
			ДокКассовойСмены = ПолучитьДокументКассовойСмены(Касса, ОтборПериод.ДатаОкончания);
			
			Если ЗначениеЗаполнено(ДокКассовойСмены) Тогда
				
				Если ДокКассовойСмены.СтатусыКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта Тогда
					
					ДатаВремяНачалаОтбора = ДокКассовойСмены.НачалоКассовойСмены;
					ДатаВремяКонцаОтбора  = ?(ЗначениеЗаполнено(ДокКассовойСмены.ОкончаниеКассовойСмены), ДокКассовойСмены.ОкончаниеКассовойСмены, КонецДня(ОтборПериод.ДатаОкончания));
					
				Иначе
					
					ДатаВремяНачалаОтбора = ДокКассовойСмены.ОкончаниеКассовойСмены;
					
					Если ОтборПериод.ДатаОкончания > ДатаВремяНачалаОтбора Тогда
						
						ДатаВремяКонцаОтбора = ОтборПериод.ДатаОкончания;
						
					Иначе
						
						ДатаВремяКонцаОтбора = КонецДня(ТекущаяДатаСеанса());
						
						Если ДатаВремяНачалаОтбора > ДатаВремяКонцаОтбора Тогда
							ДатаВремяНачалаОтбора = НачалоДня(ТекущаяДатаСеанса());		
						КонецЕсли;
						
					КонецЕсли;

				КонецЕсли;
			
			КонецЕсли;	
			
		КонецЕсли;
		
		// Если ДатаВремяНачалаОтбора = Неопределено Тогда
		//	
		//	ВремяРаботыСЕ = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(ОтборПериод.ДатаНачала, ЭтотОбъект.СтруктурнаяЕдиница, ДеньНедели(ОтборПериод.ДатаНачала));
		//	
		//	Если ВремяРаботыСЕ <> Неопределено Тогда
		//		
		//		ДатаВремяНачалаОтбора = ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ОтборПериод.ДатаНачала, ВремяРаботыСЕ.НачалоРаботы);
		//		ДатаВремяКонцаОтбора  = ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ОтборПериод.ДатаОкончания, ВремяРаботыСЕ.ОкончаниеРаботы);
		//		
		//	Иначе
				
				ДатаВремяНачалаОтбора = ОтборПериод.ДатаНачала;
				ДатаВремяКонцаОтбора  = ОтборПериод.ДатаОкончания;
				
		//	КонецЕсли;
		//				
		// КонецЕсли;	
		
		ВыборкаПоКассам = ПолучитьДанныеПоКассовойСмены(Касса, ДатаВремяНачалаОтбора, ДатаВремяКонцаОтбора);
		
		Если ВыборкаПоКассам.Следующий() Тогда
			
			НоваяСтрока = ДанныеПоКассам.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаПоКассам);	
			
			Если СтатусФр = Истина 
				И ЗначениеЗаполнено(ВыборкаПоКассам.ДатаВремяОткрытияСмены) Тогда
				
				НоваяСтрока.ВремяОткрытияСмены          = Формат(ВыборкаПоКассам.ДатаВремяОткрытияСмены, "ДФ='dd.MM.yyyy HH:mm'" );
				НоваяСтрока.ВремяОткрытияСменыЗаголовок = ?(Счетчик = 1, НСтр("ru= 'открыта';en ='open'"), "");
				НоваяСтрока.Открыта                     = Истина;
				
			КонецЕсли;
			
			Если Счетчик = 1 Тогда 
				
				НоваяСтрока.НачальныйОстатокЗаголовок = НСтр("ru= 'начало';en ='start'");
				НоваяСтрока.КонечныйОстатокЗаголовок  = НСтр("ru= 'конец';en ='end'");
				НоваяСтрока.ПриходЗаголовок           = НСтр("ru= 'приход';en ='coming'");
				НоваяСтрока.РасходЗаголовок           = НСтр("ru= 'расход';en ='consumption'");
				
			КонецЕсли;
			
		КонецЕсли;
		
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
	Элементы.ДанныеПоКассам.ВысотаВСтрокахТаблицы = ДанныеПоКассам.Количество();	
	
	ИтогПоКассамНачальныйОстаток = ДанныеПоКассам.Итог("НачальныйОстаток");
	ИтогПоКассамКонечныйОстаток  = ДанныеПоКассам.Итог("КонечныйОстаток");
    ИтогПоКассамПриход           = ДанныеПоКассам.Итог("Приход");
    ИтогПоКассамРасход           = ДанныеПоКассам.Итог("Расход");
	
	Возврат ОтборКассы;
	
КонецФункции

&НаСервере
// Заполнить дерево данных.
//
Процедура ЗаполнитьТаблицыДанных()
	
	ОтборКассы = ЗаполнитьИнформациюПоКассам();
	
	МаксКолКнопокПоКассам = 0;
	СоздатьДинамическиеКнопкиОперацииСФР(МаксКолКнопокПоКассам);
	
	// Заполнение данных по эквайрингам	
	ЭквайринговыеТерминалы = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыеТерминалыДляРабочегоМеста(ОтборКассы, РабочееМесто);
	ДанныеПоЭквайрингам.Очистить();
	
	Счетчик = 1;
	Для Каждого ЭквТерминал ИЗ ЭквайринговыеТерминалы Цикл
		
		// Предложено Денисом, что бы не давать пользователю 
		// права на чтение контрагентов(для параметра "БанковскийСчет")
		УстановитьПривилегированныйРежим(Истина);
		
		ДвиженияПоЭквайрингу = Новый Запрос(
		"ВЫБРАТЬ
		|	РасчетыПоЭквайрингуОстаткиИОбороты.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
		|	СУММА(РасчетыПоЭквайрингуОстаткиИОбороты.СуммаПриход) КАК Приход,
		|	СУММА(РасчетыПоЭквайрингуОстаткиИОбороты.СуммаРасход) КАК Расход
		|ИЗ
		|	РегистрНакопления.РасчетыПоЭквайрингу.ОстаткиИОбороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			Авто,
		|			,
		|			ЭквайринговыйТерминал В (&ЭквТерминал)
		|				И ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта)) КАК РасчетыПоЭквайрингуОстаткиИОбороты
		|ГДЕ
		|	(РасчетыПоЭквайрингуОстаткиИОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКЛиента)
		|			ИЛИ РасчетыПоЭквайрингуОстаткиИОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту)
		|			ИЛИ РасчетыПоЭквайрингуОстаткиИОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
		|			ИЛИ РасчетыПоЭквайрингуОстаткиИОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВзносНаЛицевойСчет)
		|			ИЛИ РасчетыПоЭквайрингуОстаткиИОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета))
		|
		|СГРУППИРОВАТЬ ПО
		|	РасчетыПоЭквайрингуОстаткиИОбороты.ЭквайринговыйТерминал");
		
		ДвиженияПоЭквайрингу.УстановитьПараметр("НачалоПериода", ОтборПериод.ДатаНачала);
		ДвиженияПоЭквайрингу.УстановитьПараметр("КонецПериода" , ОтборПериод.ДатаОкончания);
		ДвиженияПоЭквайрингу.УстановитьПараметр("ЭквТерминал"  , ЭквТерминал);
		
		ОстаткиПоЭкв = ДвиженияПоЭквайрингу.Выполнить().Выгрузить();
		
		УстановитьПривилегированныйРежим(Ложь);

		НоваяСтрока           = ДанныеПоЭквайрингам.Добавить();
		НоваяСтрока.Эквайринг = ЭквТерминал;
		Если ОстаткиПоЭкв.Количество() > 0 Тогда
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ОстаткиПоЭкв[0]);
		КонецЕсли;
		
		Если Счетчик = 1 Тогда 
			НоваяСтрока.ПриходЗаголовок = НСтр("ru= 'приход';en ='coming'");
			НоваяСтрока.РасходЗаголовок = НСтр("ru= 'расход';en ='consumption'");
		КонецЕсли;
		
		Счетчик = Счетчик + 1;
	
	КонецЦикла;
		
	СоздатьДинамическиеКнопкиОперацииЭквайринга(МаксКолКнопокПоКассам);
	
	Если ДанныеПоЭквайрингам.Количество() > 0 Тогда
		Элементы.ГруппаДанныеПоЭквайрингам.Видимость = Истина;
		Элементы.ДанныеПоЭквайрингам.ВысотаВСтрокахТаблицы = ДанныеПоЭквайрингам.Количество();
	Иначе
		Элементы.ГруппаДанныеПоЭквайрингам.Видимость = Ложь;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Функция - Получить данные по кассовой смены.
//
// Параметры:
//  Касса			 - 	 - 
//  ДатаНачала		 - 	 - 
//  ДатаОкончания	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеПоКассовойСмены(Касса, ДатаНачала, ДатаОкончания)
	
	ДвиженияПоКассам = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Касса КАК Касса,
	|	ВложенныйЗапрос.Касса.Организация КАК Организация,
	|	СУММА(ВложенныйЗапрос.НачальныйОстаток) КАК НачальныйОстаток,
	|	СУММА(ВложенныйЗапрос.КонечныйОстаток) КАК КонечныйОстаток,
	|	СУММА(ВложенныйЗапрос.Приход) КАК Приход,
	|	СУММА(ВложенныйЗапрос.Расход) КАК Расход,
	|	ВложенныйЗапрос.НачалоКассовойСмены КАК ДатаВремяОткрытияСмены
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДенежныеСредстваОстаткиИОбороты.БанковскийСчетКасса КАК Касса,
	|		ДенежныеСредстваОстаткиИОбороты.СуммаНачальныйОстаток КАК НачальныйОстаток,
	|		ДенежныеСредстваОстаткиИОбороты.СуммаКонечныйОстаток КАК КонечныйОстаток,
	|		ДенежныеСредстваОстаткиИОбороты.СуммаПриход КАК Приход,
	|		ДенежныеСредстваОстаткиИОбороты.СуммаРасход КАК Расход,
	|		КассоваяСмена.НачалоКассовойСмены КАК НачалоКассовойСмены
	|	ИЗ
	|		РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , БанковскийСчетКасса = &Касса) КАК ДенежныеСредстваОстаткиИОбороты
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.КассоваяСмена КАК КассоваяСмена
	|			ПО ДенежныеСредстваОстаткиИОбороты.БанковскийСчетКасса = КассоваяСмена.Касса
	|				И (КассоваяСмена.Проведен = ИСТИНА)
	|				И (КассоваяСмена.СтатусыКассовойСмены = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта))
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Кассы.Ссылка,
	|		0,
	|		0,
	|		0,
	|		0,
	|		КассоваяСмена.НачалоКассовойСмены
	|	ИЗ
	|		Справочник.Кассы КАК Кассы
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.КассоваяСмена КАК КассоваяСмена
	|			ПО Кассы.Ссылка = КассоваяСмена.Касса
	|				И (КассоваяСмена.СтатусыКассовойСмены = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта))
	|				И (КассоваяСмена.Проведен = ИСТИНА)
	|	ГДЕ
	|		Кассы.Ссылка = &Касса
	|		И Кассы.ПометкаУдаления = ЛОЖЬ) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Касса,
	|	ВложенныйЗапрос.НачалоКассовойСмены,
	|	ВложенныйЗапрос.Касса.Организация");
	
	ДвиженияПоКассам.УстановитьПараметр("НачалоПериода", ДатаНачала);
	ДвиженияПоКассам.УстановитьПараметр("КонецПериода" , ДатаОкончания);
    ДвиженияПоКассам.УстановитьПараметр("Касса"        , Касса);
	
	Возврат ДвиженияПоКассам.Выполнить().Выбрать();
	
КонецФункции

&НаСервере
// Функция - Получить документ кассовой смены.
//
// Параметры:
//  Касса		 - 	 - 
//  ДатаОтбора	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДокументКассовойСмены(Касса, ДатаОтбора)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КассоваяСмена.Ссылка КАК КассоваяСмена
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.НачалоКассовойСмены <= &ДатаОтбора
	|	И КассоваяСмена.Проведен = ИСТИНА
	|	И КассоваяСмена.Касса = &Касса
	|
	|УПОРЯДОЧИТЬ ПО
	|	КассоваяСмена.НачалоКассовойСмены УБЫВ");
	
	Запрос.УстановитьПараметр("Касса"     , Касса);
	Запрос.УстановитьПараметр("ДатаОтбора", ДатаОтбора);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.КассоваяСмена, Неопределено);
	
КонецФункции

&НаСервере
// Создать динамические элементы.
//
Процедура СоздатьДинамическиеКнопкиОперацииСФР(МаксКолКнопок = 0)
	
	ОснГруппа = Элементы.ГруппаДинамическиеКнопки;
	Пока ОснГруппа.ПодчиненныеЭлементы.Количество() > 1 Цикл
		Элементы.Удалить(ОснГруппа.ПодчиненныеЭлементы[1]);
	КонецЦикла;
	
	КолЭлементов = ДанныеПоКассам.Количество();
	Для А = 0 По КолЭлементов - 1 Цикл
		
		НоваяГруппа             = Элементы.Добавить("ГруппаКнопок_" + А, Тип("ГруппаФормы"), ОснГруппа);
		НоваяГруппа.Вид 		= ВидГруппыФормы.ОбычнаяГруппа;
		НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		НоваяГруппа.ОтображатьЗаголовок = Ложь;
		// НоваяГруппа.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Лево;

		// Декорация касса открыта
		ДекВыемка          = Элементы.Добавить("ДекорацияКассаОткрыта_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
		ДекВыемка.Вид      = ВидДекорацииФормы.Картинка;
		ДекВыемка.Картинка = ?(ДанныеПоКассам[А].Открыта, БиблиотекаКартинок.КассаОткрыта, БиблиотекаКартинок.Пустая);
		// ДекВыемка.Гиперссылка = Истина;
		ДекВыемка.Подсказка = ?(ДанныеПоКассам[А].Открыта, НСтр("ru= 'Касса открыта';en ='Cash desk is open'"), "");
		ДекВыемка.Высота   = 2;
		ДекВыемка.Ширина   = 5;
		// ДекВыемка.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево; 
		// ДекВыемка.УстановитьДействие("Нажатие","ВыемкаВыручки");
		
		// Кнопка выемки из кассы
		ДекВыемка          = Элементы.Добавить("ДекорацияВыемкаВыручки_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
		ДекВыемка.Вид      = ВидДекорацииФормы.Картинка;
		ДекВыемка.Картинка = БиблиотекаКартинок.ВыемкаВыручкиИзОперационнойКассы32;
		ДекВыемка.Гиперссылка = Истина;
		ДекВыемка.Подсказка = НСтр("ru= 'Выемка выручки в кассу предприятия';en ='Revenues to the cash desk of the enterprise'");
		ДекВыемка.Высота   = 2;
		ДекВыемка.Ширина   = 5;
		// ДекВыемка.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево; 
		ДекВыемка.УстановитьДействие("Нажатие","ВыемкаВыручки");
		
	    // Кнопка поступления в кассу
		ДекПоступления          = Элементы.Добавить("ДекорацияПоступлениеВКассу_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
		ДекПоступления.Вид      = ВидДекорацииФормы.Картинка;
		ДекПоступления.Картинка = БиблиотекаКартинок.ПоступлениеВОперационнуюКассу32;
		ДекПоступления.Гиперссылка = Истина;
		ДекПоступления.Подсказка = НСтр("ru= 'Поступление в операционную кассу из кассы предприятия';en ='Receipt to the operating cash desk from the cash desk of the enterprise'");
		ДекПоступления.Высота   = 2;
		ДекПоступления.Ширина   = 5;
		ДекПоступления.УстановитьДействие("Нажатие","ПоступлениеВКассу");
		
		МаксКолКнопок = ?(МаксКолКнопок > 2, МаксКолКнопок, 2);
		СтатусФр = РозничныеПродажи.ПроверитьИспользованиеФРвКассе(ДанныеПоКассам[А].Касса, РабочееМесто);
		Если СтатусФр = Истина Тогда
			
			// Кнопка Z-отчета
			ДекZОтчета          = Элементы.Добавить("ДекорацияZОтчета_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
			ДекZОтчета.Вид      = ВидДекорацииФормы.Картинка;
			Если ДанныеПоКассам[А].Открыта Тогда
				ДекZОтчета.Картинка = БиблиотекаКартинок.ZОтчет32;			
				ДекZОтчета.Подсказка = НСтр("ru= 'Закрыть смену, Z-отчет';en ='Close shift, Z-report'");
			Иначе
				ДекZОтчета.Картинка = БиблиотекаКартинок.ОткрытьКассовуюСмену32;			
				ДекZОтчета.Подсказка = НСтр("ru= 'Открыть смену';en ='Open shift'");
			КонецЕсли;
			ДекZОтчета.Гиперссылка = Истина;
			ДекZОтчета.Высота   = 2;
			ДекZОтчета.Ширина   = 5;
			ДекZОтчета.УстановитьДействие("Нажатие","ZОтчет");
			
			// Кнопка X-отчета
			ДекXОтчета             = Элементы.Добавить("ДекорацияXОтчета_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
			ДекXОтчета.Вид         = ВидДекорацииФормы.Картинка;
			ДекXОтчета.Гиперссылка = Истина;
			ДекXОтчета.Картинка    = БиблиотекаКартинок.XОтчет32;
			ДекXОтчета.Подсказка   = НСтр("ru= 'Вывести X-отчет';en ='Display X-report'");
			ДекXОтчета.Высота      = 2;
			ДекXОтчета.Ширина      = 5;
			ДекXОтчета.УстановитьДействие("Нажатие","ХОтчет");	
			
			МаксКолКнопок = 4;
		КонецЕсли;
	КонецЦикла;
	
	Если ОснГруппа.ПодчиненныеЭлементы.Количество() > 0 Тогда
		ДекЗаглушка = Элементы.Добавить("ДекорацияЗаглушка_999",Тип("ДекорацияФормы"), ОснГруппа);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
// Создать динамические элементы.
//
Процедура СоздатьДинамическиеКнопкиОперацииЭквайринга(КолКнопокПоКассам)
	
	ОснГруппа = Элементы.ГруппаДинамическиеКнопкиЭквайринга;
	
	Пока ОснГруппа.ПодчиненныеЭлементы.Количество() > 1 Цикл		
		Элементы.Удалить(ОснГруппа.ПодчиненныеЭлементы[1]);		
	КонецЦикла;
	
	КолЭлементов = ДанныеПоЭквайрингам.Количество();
	Для А = 0 По КолЭлементов - 1 Цикл
		
		Если ЗначениеЗаполнено(ДанныеПоЭквайрингам[А].Эквайринг.ПодключаемоеОборудование) 
			И ДанныеПоЭквайрингам[А].Эквайринг.ИспользоватьБезПодключенияОборудования = Ложь
			И ЗначениеЗаполнено(ДанныеПоЭквайрингам[А].Эквайринг.ПодключаемоеОборудование.РабочееМесто) Тогда 
						
			НоваяГруппа             = Элементы.Добавить("ГруппаКнопокЭквайрнг_" + А, Тип("ГруппаФормы"), ОснГруппа);
			НоваяГруппа.Вид 		= ВидГруппыФормы.ОбычнаяГруппа;
			НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			НоваяГруппа.ОтображатьЗаголовок = Ложь;
			
			// Кнопка выемки из кассы
			ДекСверкаИтогов          = Элементы.Добавить("ДекорацияВыполнитьСверкуИтогов_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
			ДекСверкаИтогов.Вид      = ВидДекорацииФормы.Картинка;
			ДекСверкаИтогов.Картинка = БиблиотекаКартинок.СверкаИтоговЭквайринга32;
			ДекСверкаИтогов.Гиперссылка = Истина;
			ДекСверкаИтогов.Подсказка = НСтр("ru= 'Выполнить сверку итогов';en ='Reconcile totals'");
			ДекСверкаИтогов.Высота   = 2;
			ДекСверкаИтогов.Ширина   = 5;
			ДекСверкаИтогов.УстановитьДействие("Нажатие","ВыполнитьСверкуИтогов");
			
			// Кнопка поступления в кассу
			ДекНапечататьПослСлип          = Элементы.Добавить("ДекорацияНапечататьПоследнийСлип_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
			ДекНапечататьПослСлип.Вид      = ВидДекорацииФормы.Картинка;
			ДекНапечататьПослСлип.Картинка = БиблиотекаКартинок.НапечататьПоследнийСлипЧек32;
			ДекНапечататьПослСлип.Гиперссылка = Истина;
			ДекНапечататьПослСлип.Подсказка = НСтр("ru= 'Напечатать последний слип';en ='Print last slip'");
			ДекНапечататьПослСлип.Высота   = 2;
			ДекНапечататьПослСлип.Ширина   = 5;
			ДекНапечататьПослСлип.УстановитьДействие("Нажатие","НапечататьПоследнийСлип");
			
			Если КолКнопокПоКассам = 4 Тогда
				ДекЗаглушка = Элементы.Добавить("ДекорацияЗаглушкаЭквайрнг_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
				ДекЗаглушка.Высота   = 2;
				ДекЗаглушка.Ширина   = 11;			
			КонецЕсли;
			
		Иначе
			
			НоваяГруппа             = Элементы.Добавить("ГруппаКнопокЭквайрнг_" + А, Тип("ГруппаФормы"), ОснГруппа);
			НоваяГруппа.Вид 		= ВидГруппыФормы.ОбычнаяГруппа;
			НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			НоваяГруппа.ОтображатьЗаголовок = Ложь;
			
			ДекСверкаИтогов          = Элементы.Добавить("ДекорацияВыполнитьСверкуИтогов_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
			ДекСверкаИтогов.Вид      = ВидДекорацииФормы.Надпись;
			ДекСверкаИтогов.Заголовок = " ";
			ДекСверкаИтогов.Высота   = 3;
			ДекСверкаИтогов.Ширина   = 5;

			Если КолКнопокПоКассам = 4 Тогда
				ДекЗаглушка = Элементы.Добавить("ДекорацияЗаглушкаЭквайрнг_" + А,Тип("ДекорацияФормы"), НоваяГруппа);
				ДекЗаглушка.Высота   = 2;
				ДекЗаглушка.Ширина   = 11;			
			КонецЕсли;

		КонецЕсли;	
	КонецЦикла;
	
	Если ОснГруппа.ПодчиненныеЭлементы.Количество() > 0 Тогда
		
		ДекЗаглушка = Элементы.Добавить("ДекорацияЗаглушкаЭквайрнг_999999",Тип("ДекорацияФормы"), ОснГруппа);
		
	Иначе	
		Если КолКнопокПоКассам = 4 Тогда
			ДекЗаглушка = Элементы.Добавить("ДекорацияЗаглушкаЭквайрнг_99999",Тип("ДекорацияФормы"), ОснГруппа);
			ДекЗаглушка.Высота   = 2;
			ДекЗаглушка.Ширина   = 20;	
		Иначе			
			ДекЗаглушка = Элементы.Добавить("ДекорацияЗаглушкаЭквайрнг_99999",Тип("ДекорацияФормы"), ОснГруппа);
			ДекЗаглушка.Высота   = 2;
			ДекЗаглушка.Ширина   = 10;			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

