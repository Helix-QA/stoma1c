
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.МаксимальноеКоличествоСделокВКолонке = 15;
	
	ЭтотОбъект.ТекущийСотрудник				 = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница	 = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ЭтотОбъект.ЭтоПолноправныйПользователь	 = РольДоступна(Метаданные.Роли.ПолныеПрава);
	
	ЗаполнитьДоступныеВидыСделок();
	ИнициализироватьДанныеПредопределенногоВидаСделки();
	
	УстановитьОтображениеФильтраСтатусПациента(ЭтотОбъект);
	
	Если Параметры.Свойство("ПараметрыОтбора") И ЗначениеЗаполнено(Параметры.ПараметрыОтбора) Тогда
		ОбновитьМеханизмФильтрацииДанных(Параметры.ПараметрыОтбора, Истина);
	Иначе
		ИнициализироватьМеханизмФильтрацииДанных();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	// Запускаем обновление канбана раз в 10 минут.
	ПодключитьОбработчикОжидания("ОбновитьПредставлениеКанбана", 600, Ложь);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если Источник = ЭтотОбъект Тогда
		// Не обрабатываем оповещения, если они возникли на этой же форме.
		Возврат;
	КонецЕсли;
	
	Если ИмяСобытия = "ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ" Тогда
		
		ОбработатьИзменениеСделки(Параметр);
		
	ИначеЕсли ИмяСобытия = "ДобавленаСделка" Тогда
		
		Если Параметр.ВидСделки = ЭтотОбъект.ВидСделки Тогда
			ОбработатьИзменениеСделки(Параметр.Сделка);
		КонецЕсли;
			
	ИначеЕсли ИмяСобытия = "ИзмененЭтапСделки" Тогда
		
		Если Параметр.ВидСделки = ЭтотОбъект.ВидСделки Тогда
			
			// Обновляем блок сделки только если он выведен на форму.
			БлокИзмененнойСделки = ПолучитьЭлементБлокаСделки(Параметр.Сделка);
			Если БлокИзмененнойСделки <> Неопределено Тогда
				ОбработатьИзменениеСделки(Параметр.Сделка);
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ОбновитьЗадачуКанбан" И ЗначениеЗаполнено(Параметр) Тогда
		
		ОбновитьДанныеЗадач(Параметр);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ИзменитьВидСделки(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораВидаСделки", ЭтотОбъект);
	ПоказатьВыборИзМеню(ОписаниеОповещения, ЭтотОбъект.ДоступныеВидыСделок, Элементы.ИзменитьВидСделки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОткрытьСписок(Команда)
	
	ПерейтиВСписок();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОбновитьКанбан(Команда)
	
	ОбновитьПредставлениеКанбана();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ОтборБезЗадач".
//
Процедура ОтборБезЗадач(Команда)
	
	ОбновитьОтборНаСервере(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "ОтборПросроченныхЗадач".
//
Процедура ОтборПросроченныхЗадач(Команда)
	
	ОбновитьОтборНаСервере(, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОтборСЗадачамиНаСегодня(Команда)
	
	ОбновитьОтборНаСервере(,, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура СброситьОтборПоЗадачам(Команда)
	
	ОбновитьОтборНаСервере();
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды.
//
Процедура УстановитьФильтрПостоянные(Команда)
	
	СтатусПостоянный = ПредопределенноеЗначение("Перечисление.СтатусыКонтрагентов.Постоянный");
	
	ЭтотОбъект.ОтборСтатусПациента = ?(ЭтотОбъект.ОтборСтатусПациента = СтатусПостоянный, Неопределено, СтатусПостоянный);
	УстановитьОтображениеФильтраСтатусПациента(ЭтотОбъект);
	
	СформироватьКанбан();
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик команды.
//
Процедура УстановитьФильтрНовые(Команда)
	
	СтатусНовый = ПредопределенноеЗначение("Перечисление.СтатусыКонтрагентов.Первичный");
	
	ЭтотОбъект.ОтборСтатусПациента = ?(ЭтотОбъект.ОтборСтатусПациента = СтатусНовый, Неопределено, СтатусНовый);
	УстановитьОтображениеФильтраСтатусПациента(ЭтотОбъект);
	
	СформироватьКанбан();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ДокументСформирован".
//
Процедура КанбанДокументСформирован(Элемент)
	
	ЭтотОбъект.ШиринаОкна = Элементы.Канбан.Документ.defaultView.innerWidth;
	ЭтотОбъект.ВысотаОкна = Элементы.Канбан.Документ.defaultView.innerHeight;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриНажатии".
//
Процедура КанбанПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СвернутыеМеню = СвернутьВсплывающиеМеню(ДанныеСобытия);
	
	Если ДанныеСобытия.Element.id = "eventSender" Тогда
		ОбработатьВызовСобытия(ДанныеСобытия.Element.dataset.eventName);
		
	ИначеЕсли ДанныеСобытия.Element.className = "phone-number" Тогда
		
		Если Не ЭтотОбъект.ТелефонияДоступна Тогда
			// Если нет доступа к телефонии - ничего не делаем при нажатии на номер.
			Возврат;
		КонецЕсли;
		
		ИдентификаторСделки = ДанныеСобытия.Element.closest(".item-col").id;
		ПредставлениеНомера = ДанныеСобытия.Element.innerText;
		СовершитьЗвонок(ИдентификаторСделки, ПредставлениеНомера);
			
	ИначеЕсли ДанныеСобытия.Element.className = "ico-chat" Тогда
		ИдентификаторКлиента = ДанныеСобытия.Element.closest(".item-col").querySelector(".client-name").id;
		ПерейтиКДиалогу(ИдентификаторКлиента);
			
	ИначеЕсли ДанныеСобытия.Element.className = "title-col" Тогда
		ИдентификаторСделки = ДанныеСобытия.Element.dataset.dealId;
		ОткрытьСделку(ИдентификаторСделки);
		
	ИначеЕсли ДанныеСобытия.Element.className = "client-name" Тогда
		ИдентификаторКлиента = ДанныеСобытия.Element.id;
		ОткрытьКлиента(ИдентификаторКлиента);
		
	ИначеЕсли ДанныеСобытия.Element.className = "doctor" Или ДанныеСобытия.Element.className = "manager" Тогда
		ИдентификаторСотрудника = ДанныеСобытия.Element.id;
		ОткрытьСотрудника(ИдентификаторСотрудника);
		
	ИначеЕсли ДанныеСобытия.Element.className = "button-create" Тогда
		СоздатьСделку();
		
	ИначеЕсли ДанныеСобытия.Element.className = "create-task" Тогда
		БлокСделки			 = ДанныеСобытия.Element.closest(".item-col");
		ИдентификаторСделки	 = БлокСделки.id;
		ИдентификаторКлиента = БлокСделки.querySelector(".client-name").id;
		
		СоздатьЗадачу(ИдентификаторСделки, ИдентификаторКлиента);
		
	ИначеЕсли ДанныеСобытия.Element.className = "current-tasks" Тогда
		
		ВсплывающееМенюЗадач = ДанныеСобытия.Element.parentElement.querySelector(".menu");
		
		Для Каждого Меню Из СвернутыеМеню Цикл
			
			// Повторные клик на кнопку открытия меню, не переоткрываем.
			Если Меню = ВсплывающееМенюЗадач Тогда
				Возврат;
			КонецЕсли;
			
		КонецЦикла;
		
		ВсплывающееМенюЗадач.style = Неопределено;
		ВсплывающееМенюЗадач.classList.toggle("active");
		
		КонтейнерЗадач = ВсплывающееМенюЗадач.children[0];
		
		ИдентификаторСделки		 = ДанныеСобытия.Element.closest(".item-col").id;
		КонтейнерЗадач.innerHTML = ПолучитьДанныеЗадач(ИдентификаторСделки);
		
		ИнвертироватьГоризонтально	 = (ЭтотОбъект.ШиринаОкна < ДанныеСобытия.Event.clientX + КонтейнерЗадач.clientWidth + 100);
		ИнвертироватьВертикально	 = (ЭтотОбъект.ВысотаОкна < ДанныеСобытия.Event.clientY + КонтейнерЗадач.clientHeight + 50);
		
		Если ИнвертироватьВертикально = Истина Тогда
			ВсплывающееМенюЗадач.style.bottom = 25;
		Иначе
			ВсплывающееМенюЗадач.style.top = 40;
		КонецЕсли;
		
		Если ИнвертироватьГоризонтально = Истина Тогда
			ВсплывающееМенюЗадач.style.right = 0;
		Иначе
			ВсплывающееМенюЗадач.style.left = 0;
		КонецЕсли;
		
	ИначеЕсли ДанныеСобытия.Element.className = "checkbox" Тогда
		ИдентификаторЗадачи = ДанныеСобытия.Element.closest(".container").id;
		ВыполнитьЗадачу(ИдентификаторЗадачи);
		
	ИначеЕсли СтрЧислоВхождений(ДанныеСобытия.Element.className, "show-all") Тогда
		ИдентификаторВидаСделки = ДанныеСобытия.Element.dataset.id;
		ПерейтиВСписок(ИдентификаторВидаСделки);
		
	ИначеЕсли ДанныеСобытия.Element.closest(".task-data") <> Неопределено Тогда
		ИдентификаторЗадачи = ДанныеСобытия.Element.closest(".container").id;
		ОткрытьЗадачу(ИдентификаторЗадачи);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
// Процедура, устанавливает отображение фильтров по задачам.
//
Процедура УстановитьОтображениеФильтровПоЗадачам(Форма, ОтборБезАктивности = Ложь, ОтборПросроченныхЗадач = Ложь, ОтборЗадачНаСегодня = Ложь)
	
	ФонАктивнойГруппы	 = Новый Цвет(218, 230, 244);
	ФонНеактивнойГруппы	 = Новый Цвет(255, 255, 255);
	
	Форма.Элементы.ГруппаБезЗадач.ЦветФона			 = ФонНеактивнойГруппы;
	Форма.Элементы.ГруппаЗадачиНаСегодня.ЦветФона	 = ФонНеактивнойГруппы;
	Форма.Элементы.ГруппаПросроченныеЗадачи.ЦветФона = ФонНеактивнойГруппы;
	
	Форма.Элементы.СброситьОтборБезЗадач.Видимость			 = Ложь;
	Форма.Элементы.СброситьОтборЗадачиНаСегодня.Видимость	 = Ложь;
	Форма.Элементы.СброситьОтборПросроченныеЗадачи.Видимость = Ложь;
	
	Если ОтборБезАктивности = Истина Тогда
		
		Форма.Элементы.ГруппаБезЗадач.ЦветФона			 = ФонАктивнойГруппы;
		Форма.Элементы.СброситьОтборБезЗадач.Видимость	 = Истина;
		
		Форма.ОтборПоЗадачам = 3;
		
	ИначеЕсли ОтборЗадачНаСегодня = Истина Тогда
		
		Форма.Элементы.ГруппаЗадачиНаСегодня.ЦветФона			 = ФонАктивнойГруппы;
		Форма.Элементы.СброситьОтборЗадачиНаСегодня.Видимость	 = Истина;
		
		Форма.ОтборПоЗадачам = 1;
		
	ИначеЕсли ОтборПросроченныхЗадач = Истина Тогда
		
		Форма.Элементы.ГруппаПросроченныеЗадачи.ЦветФона			 = ФонАктивнойГруппы;
		Форма.Элементы.СброситьОтборПросроченныеЗадачи.Видимость	 = Истина;
		
		Форма.ОтборПоЗадачам = 2;
		
	Иначе
		Форма.ОтборПоЗадачам = 0;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, открывает форму задачи.
//
Процедура ОткрытьЗадачу(ИдентификаторЗадачи)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ИдентификаторЗадачи", ИдентификаторЗадачи);
	
	ОткрытьФорму("Задача.Взаимодействие.ФормаОбъекта", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает признак выполнения задачи.
//
Процедура ВыполнитьЗадачу(ИдентификаторЗадачи)
	
	СтруктураОтбора = ПолучитьСтруктуруЗначенийОтбораКлиент();
	
	РезультатОперации = ВыполнитьЗадачуНаСервере(ИдентификаторЗадачи, СтруктураОтбора);
	
	Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОперации.ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ОбновитьКоличествоСделокВБлоках(РезультатОперации.ДанныеКоличества);
	УстановитьЗаголовкиДополнительныхОтборов(ЭтотОбъект, СтруктураОтбора, РезультатОперации.ДанныеКоличестваПоОтборам);
	
	БлокТекущейСделки = Элементы.Канбан.Документ.querySelector(ПолучитьСелекторСсылки(РезультатОперации.Сделка) + ".item-col");
	
	Если Не ЗначениеЗаполнено(РезультатОперации.БлокСделки) Тогда
		БлокТекущейСделки.remove();
		
	Иначе
		// Блок сделки не обновляется полностью чтобы не закрывалось меню задач.
		БлокЗадачи = БлокТекущейСделки.querySelector(ПолучитьСелекторСсылки(РезультатОперации.Задача) + ".container");
		БлокЗадачи.remove();
			
		// Обновляем количество в блоке "Дела".
		БлокТекущейСделки.querySelector(".current-tasks").dataset.taskCount = БлокТекущейСделки.querySelectorAll(".container").length;
		
		// Иногда остаются пробельные символы после удаления элементов из блока - нарушает логику стилей.
		КолонкаЗадач = БлокТекущейСделки.querySelector(".menu-container");
		Если КолонкаЗадач.children.length = 0 Тогда
			КолонкаЗадач.innerHTML = "";
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, устанавливает признак выполнения задачи и возвращает результат операции.
//
Функция ВыполнитьЗадачуНаСервере(ИдентификаторЗадачи, СтруктураОтбора)
	
	РезультатОперации = Новый Структура;
	РезультатОперации.Вставить("ОписаниеОшибки"		, "");
	РезультатОперации.Вставить("ВыполненоУспешно"	, Ложь);
	
	Задача = Задачи.Взаимодействие.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторЗадачи));
	
	Попытка
		ЗадачаОбъект			 = Задача.ПолучитьОбъект();
		ЗадачаОбъект.Выполнена	 = Истина;
		ЗадачаОбъект.Записать();
		
		РезультатОперации.Вставить("Задача", ЗадачаОбъект.Ссылка);
		РезультатОперации.ВыполненоУспешно = Истина;
		
		ЗаполнитьДополнительныеПараметрыРезультата(ЗадачаОбъект.Сделка, РезультатОперации, СтруктураОтбора, Неопределено);
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Не удалось выполнить задачу. Текст ошибки: '") + ОписаниеОшибки;
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

&НаКлиенте
// Процедура, выполняет обновление данных о задачах в блоке сделки.
//
Процедура ОбновитьДанныеЗадач(ПараметрыОповещения)
	
	Если ПараметрыОповещения.Свойство("ВидСделки") И ПараметрыОповещения.ВидСделки <> ЭтотОбъект.ВидСделки Тогда
		Возврат;
	КонецЕсли;
	
	// Обновляем блок сделки только если он выведен на форму.
	БлокСделки = ПолучитьЭлементБлокаСделки(ПараметрыОповещения.Сделка);
	
	Если БлокСделки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МенюЗадач = БлокСделки.querySelector(".menu");
	МенюАктивно = МенюЗадач.classList.contains("active");
	
	Если МенюАктивно Тогда
		ОбновитьБлокЗадачи(БлокСделки, ПараметрыОповещения);
	Иначе
		ОбновитьБлокСделки(БлокСделки, ПараметрыОповещения.Сделка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет блок задачи в меню.
//
Процедура ОбновитьБлокЗадачи(БлокСделки, ПараметрыОповещения)
	
	Документ = Элементы.Канбан.Документ;
	ОбновляемаяЗадача = ПараметрыОповещения.Задача;
	
	СтруктураОтборов	 = ПолучитьСтруктуруЗначенийОтбораКлиент();
	ДанныеДляОбновления	 = ПолучитьДанныеДляОбновленияЗадач(ПараметрыОповещения.Сделка, ОбновляемаяЗадача, СтруктураОтборов);
	
	// Сделка больше не удовлетворяет параметрам фильтрации - удаляем блок.
	Если Не ЗначениеЗаполнено(ДанныеДляОбновления.БлокСделки) Тогда
		БлокСделки.remove();
	КонецЕсли;
	
	СелекторЗадачи			 = ПолучитьСелекторСсылки(ОбновляемаяЗадача) + ".container";
	БлокОбновляемойЗадачи	 = БлокСделки.querySelector(СелекторЗадачи);
	
	Если СвойствоСтруктуры(ПараметрыОповещения, "УдалениеЗадачи", Ложь) Тогда
		
		// Удаляем блок после удаления или выполнения задачи.
		Если БлокОбновляемойЗадачи <> Неопределено Тогда
			БлокОбновляемойЗадачи.remove();
		КонецЕсли;
		
	Иначе
		
		Если БлокОбновляемойЗадачи = Неопределено Тогда
			КолонкаЗадач			 = БлокСделки.querySelector(".menu-container");
			КолонкаЗадач.innerHTML	 = КолонкаЗадач.innerHTML + ДанныеДляОбновления.БлокЗадачи;
		Иначе
			БлокОбновляемойЗадачи.outerHTML = ДанныеДляОбновления.БлокЗадачи;
		КонецЕсли;
		
	КонецЕсли;
	
	// Обновляем количество в блоке "Дела".
	БлокСделки.querySelector(".current-tasks").dataset.taskCount = БлокСделки.querySelectorAll(".container").length;
	
	// Иногда остаются пробельные символы после удаления элементов из блока - нарушает логику стилей.
	КолонкаЗадач = ?(КолонкаЗадач = Неопределено, БлокСделки.querySelector(".menu-container"), КолонкаЗадач);
	Если КолонкаЗадач.children.length = 0 Тогда
		КолонкаЗадач.innerHTML = "";
	КонецЕсли;
	
	ОбновитьКоличествоСделокВБлоках(ДанныеДляОбновления.ДанныеКоличества);
	УстановитьЗаголовкиДополнительныхОтборов(ЭтотОбъект, СтруктураОтборов, ДанныеДляОбновления.ДанныеКоличестваПоОтборам);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает блок задачи.
//
Функция ПолучитьДанныеДляОбновленияЗадач(Сделка, Задача, СтруктураОтборов)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.Ссылка КАК Ссылка,
	|	Взаимодействие.ЗадачаНазначеннаяДатаНачало КАК НазначеннаяДатаНачало,
	|	Взаимодействие.ЗадачаНазначеннаяДата КАК НазначеннаяДата,
	|	Взаимодействие.ВидВзаимодействияСправочник.Наименование КАК ВидВзаимодействия,
	|	Взаимодействие.ВидВзаимодействияСправочник.ИндексКартинки КАК ИндексКартинки,
	|	Взаимодействие.ЗадачаТема КАК Тема,
	|	Взаимодействие.ЗадачаОписание КАК Описание,
	|	Взаимодействие.ЗадачаНазначеннаяДата < &ТекущаяДата КАК Просрочена
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Ссылка = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка"		, Задача);
	Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДатаСеанса());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	КартинкаВзаимодействия = БиблиотекаКартинок["ВидВзаимодействия_" + Выборка.ИндексКартинки];
	ДвоичныеДанныеКартинки = КартинкаВзаимодействия.ПолучитьДвоичныеДанные();
	
	АдресКартинки = "data:image/svg+xml;base64," + СтрСоединить(СтрРазделить(Base64Строка(ДвоичныеДанныеКартинки), Символы.ПС + Символы.ВК));
	
	БлокЗадачи = ПолучитьБлокЗадачи(Выборка, АдресКартинки);
	
	ДанныеДляОбновления = Новый Структура;
	ДанныеДляОбновления.Вставить("БлокЗадачи", БлокЗадачи);
	
	ЗаполнитьДополнительныеПараметрыРезультата(Сделка, ДанныеДляОбновления, СтруктураОтборов, Неопределено);
	
	Возврат ДанныеДляОбновления;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает блок задачи.
//
Функция ПолучитьБлокЗадачи(ДанныеЗадачи, АдресКартинки)
	
	ПредставлениеДатыЗадачи	 = ПолучитьПредставлениеДатыЗадачи(ДанныеЗадачи);
	ИдентификаторЗадачи		 = XMLСтрока(ДанныеЗадачи.Ссылка);
	ТемаЗадачи				 = ДанныеЗадачи.Тема;
	ОписаниеЗадачи			 = ДанныеЗадачи.Описание;
	ВидВзаимодействия		 = ДанныеЗадачи.ВидВзаимодействия;
	КлассПросроченнойЗадачи	 = ?(ДанныеЗадачи.Просрочена = Истина, " timed-out", "");
	
	БлокЗадачи =
	"<div class='container' id='" + ИдентификаторЗадачи + "'>
	|	<div class='task'>
	|		<div class='checkbox-wrapper'><div class='checkbox' title='Выполнить задачу'></div></div>
	|		<div class='task-data'>
	|			<div class='date" + КлассПросроченнойЗадачи + "'>" + ПредставлениеДатыЗадачи + "</div>
	|			<div class='theme' title='" + ТемаЗадачи + "'>" + ТемаЗадачи + "</div>
	|			<div class='description' title='" + ОписаниеЗадачи + "'>" + ОписаниеЗадачи + "</div>
	|		</div>
	|		<div class='task-type'>
	|			<img class='interaction-image' src='" + АдресКартинки + "'>
	|			<div class='interaction-type'>" + ВидВзаимодействия + "</div>
	|		</div>
	|	</div>
	|	<div class='margin'></div>
	|</div>";
	
	Возврат БлокЗадачи;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает представление даты задачи.
//
Функция ПолучитьПредставлениеДатыЗадачи(ДанныеЗадачи)
	
	Если Не ЗначениеЗаполнено(ДанныеЗадачи.НазначеннаяДата) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Если НачалоДня(ДанныеЗадачи.НазначеннаяДата) > НачалоДня(ТекущаяДата) Тогда
		
		Возврат Формат(ДанныеЗадачи.НазначеннаяДата, "ДФ='d MMMM'");
		
	ИначеЕсли ДанныеЗадачи.НазначеннаяДата = НачалоДня(ТекущаяДата) Тогда
		
		Возврат "Сегодня, весь день";
		
	ИначеЕсли НачалоДня(ДанныеЗадачи.НазначеннаяДата) = НачалоДня(ТекущаяДата) Тогда
		
		Если ЗначениеЗаполнено(ДанныеЗадачи.НазначеннаяДатаНачало) И НачалоДня(ДанныеЗадачи.НазначеннаяДатаНачало) = НачалоДня(ТекущаяДата) Тогда
			Возврат СтрШаблон(НСтр("ru = 'Сегодня с %1 по %2'"), Формат(ДанныеЗадачи.НазначеннаяДатаНачало, "ДФ='ЧЧ:мм'"), Формат(ДанныеЗадачи.НазначеннаяДата, "ДФ='ЧЧ:мм'"));
		Иначе
			Возврат Формат(ДанныеЗадачи.НазначеннаяДата, "ДФ='''Сегодня ''ЧЧ:мм'");
		КонецЕсли;
		
	ИначеЕсли НачалоГода(ДанныеЗадачи.НазначеннаяДата) = НачалоГода(ТекущаяДата) Тогда
		
		Возврат Формат(ДанныеЗадачи.НазначеннаяДата, "ДФ='d MMMM'")
		
	Иначе
		Возврат Формат(ДанныеЗадачи.НазначеннаяДата, "ДФ='d MMMM yyyy'")
		
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

