&НаСервере
// Процедура заполняет контактную информацию.
//
Процедура ЗаполнитьКонтактнуюИнформацию(ДокументОплаты, ПочтаКлиента, ТелефонКлиента, Касса)
	
	Если Не ЗначениеЗаполнено(ДокументОплаты) Тогда
		Возврат;
	КонецЕсли;
		
	Если ЭтотОбъект.ПередаватьСмсКлиента 
		ИЛИ ЭтотОбъект.ПередаватьПочтуКлиента Тогда

		КонтактнаяИнформацияПлательщика = Неопределено;
		Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("КонтрагентПлательщик", ДокументОплаты.Метаданные()) Тогда
			КонтрагентПлательщик = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОплаты, "КонтрагентПлательщик");
			КонтактнаяИнформацияПлательщика = МенеджерОборудованияВызовСервера.ПолучитьКонтактнуюИнформацию(КонтрагентПлательщик,, Касса);  //КассаФискализации 
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КонтактнаяИнформацияПлательщика) Тогда
			
			ПочтаКлиента   = ?(ЭтотОбъект.ПередаватьПочтуКлиента, КонтактнаяИнформацияПлательщика.Email, Неопределено);
			ТелефонКлиента = ?(ЭтотОбъект.ПередаватьСмсКлиента И ЗначениеЗаполнено(Касса), КонтактнаяИнформацияПлательщика.Телефон, Неопределено);
			
			Если (Не ЗначениеЗаполнено(ПочтаКлиента) И ЭтотОбъект.ПередаватьПочтуКлиента)
				Или (Не ЗначениеЗаполнено(ТелефонКлиента) И ЭтотОбъект.ПередаватьСмсКлиента) Тогда
				
				Контрагент = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОплаты, "Контрагент");
				КонтактнаяИнформация = МенеджерОборудованияВызовСервера.ПолучитьКонтактнуюИнформацию(Контрагент,, Касса);  //КассаФискализации 
				   				
				Если НЕ ЗначениеЗаполнено(ПочтаКлиента)
					И ЭтотОбъект.ПередаватьПочтуКлиента Тогда
					
					ПочтаКлиента = КонтактнаяИнформация.Email;
				КонецЕсли;
				
				Если НЕ ЗначениеЗаполнено(ТелефонКлиента)
					И ЭтотОбъект.ПередаватьСмсКлиента
					И ЗначениеЗаполнено(Касса) Тогда
					
					ТелефонКлиента = КонтактнаяИнформация.Телефон;
				КонецЕсли;   				
			КонецЕсли;
			
		Иначе
			
			Контрагент = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОплаты, "Контрагент");
			КонтактнаяИнформация = МенеджерОборудованияВызовСервера.ПолучитьКонтактнуюИнформацию(Контрагент,, Касса);  //КассаФискализации 
			
			ПочтаКлиента   = ?(ЭтотОбъект.ПередаватьПочтуКлиента, КонтактнаяИнформация.Email, Неопределено);
			ТелефонКлиента = ?(ЭтотОбъект.ПередаватьСмсКлиента И ЗначениеЗаполнено(Касса), КонтактнаяИнформация.Телефон, Неопределено);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти