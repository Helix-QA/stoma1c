// Функция - Сформировать выемку из кассы
//
// Параметры:
//  Период			 - 	 - 
//  Касса			 - 	 - 
//  СуммаВыемки		 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьВыемкуИзКассы(СтруктураДанных, ОписаниеОшибки = "") Экспорт
	
	ДокВыемки      = Неопределено;                  
	ДокПоступления = Неопределено;
	Касса 		   = СтруктураДанных.Касса;
	СуммаВыемки    = СтруктураДанных.СуммаДокумента;		
	ВыемкаИзКассы  = Касса.ВыемкаИзКассы;                              	
	
	КассаВыемки                  = Касса.КассаДляСдачиВыручки;		
	ФормироватьПоступлениеВыемки = Касса.ЗавершатьАвтоматическиОперацииВемкиВнесения;
	
	ОстатокВКассе                = ДенежныеСредстваСервер.ПолучитьОстаткоДенежныхСредств(ТекущаяДатаСеанса(), СтруктураДанных.Касса);
	
	Если ОстатокВКассе < СтруктураДанных.СуммаДокумента Тогда
		ОписаниеОшибки = НСтр("ru= 'Остаток средств в кассе меньше запрошенной выемки!';en= 'The cash balance is less than the requested recess!'");
		Возврат Ложь;
	КонецЕсли;
	
	Если ФормироватьПоступлениеВыемки = Истина И НЕ ЗначениеЗаполнено(КассаВыемки) Тогда
		ОписаниеОшибки = НСтр("ru= 'В операционной кассе не указана касса поступления выручки!';en= 'The operating cash desk does not indicate the cash desk of the revenue!'");
		Возврат Ложь;
	КонецЕсли;
	
	Попытка    
		Если ВыемкаИзКассы = Перечисления.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия Тогда
			СтруктураДанных.Вставить("ВидОперации", Перечисления.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия);
		ИначеЕсли ВыемкаИзКассы = Перечисления.ВидыОпераций.СдачаНаличныхВБанк Тогда                              
			СтруктураДанных.Вставить("ВидОперации", Перечисления.ВидыОпераций.СдачаНаличныхВБанк);
		КонецЕсли;
		
		ДокОбъект = Документы.СписаниеДенежныхСредств.СоздатьДокумент();			
		ДокОбъект.Заполнить(СтруктураДанных);
		ДокОбъект.Дата = ТекущаяДатаСеанса();
		ДокОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные; 			
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		ДокВыемки = ДокОбъект.Ссылка;
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();		
	КонецПопытки;
	
	// Формируем автоматическое поступление выручки из опер. кассы
	Если ФормироватьПоступлениеВыемки = Истина Тогда
		
		ДокОбъект    = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
		
		СтруктураЗап = Новый Структура;
		СтруктураЗап.Вставить("ТипДенежныхСредств", Перечисления.ТипыДенежныхСредств.Наличные);
		СтруктураЗап.Вставить("ВидОперации"       , Перечисления.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы);
		СтруктураЗап.Вставить("Касса"             , КассаВыемки);
		СтруктураЗап.Вставить("СуммаДокумента"    , СуммаВыемки);
		
		ДокОбъект.Заполнить(СтруктураЗап);
		
		ДокОбъект.Дата = ТекущаяДатаСеанса();
		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		ДокПоступления = ДокОбъект.Ссылка;
	КонецЕсли;   	
	
	Возврат Новый Структура("ДокВыемки, ДокПоступления", ДокВыемки, ДокПоступления);
	
КонецФункции

// Функция - Сформировать поступление в операционную кассу изкассы предприятия
// (надо решить по поводу кассыпредприятия нужна ли она в стоме)
Функция СформироватьПоступлениеВОперационнуюКассуИзкассыПредприятия(Период, СтруктураДанных, ОписаниеОшибки = "") Экспорт

	Касса 			 = СтруктураДанных.Касса;         
	СуммаПоступления = СтруктураДанных.СуммаДокумента;
	Комментарий		 = СтруктураДанных.Комментарий;
	
	ДокПоступления   = Неопределено;
	ДокВыбытия       = Неопределено;
	КассаВыбытия     = Касса.КассаДляСдачиВыручки;
	ФормироватьВыемкуАвтоматически = Касса.ЗавершатьАвтоматическиОперацииВемкиВнесения;
	
	Если ФормироватьВыемкуАвтоматически = Истина Тогда 
		Если НЕ ЗначениеЗаполнено(КассаВыбытия) Тогда
			ОписаниеОшибки = НСтр("ru= 'В операционной кассе не указана касса предприятия!';en= 'The operating cash desk does not indicate the cash desk of the enterprise!'");
			Возврат Ложь;
		Иначе
			ОстатокВКассе = ДенежныеСредстваСервер.ПолучитьОстаткоДенежныхСредств(Период, КассаВыбытия);
			Если ОстатокВКассе < СуммаПоступления Тогда
				ОписаниеОшибки = НСтр("ru= 'Остаток средств в кассе предприятия меньше запрошенной суммы!';en= 'The balance at the cash desk of the enterprise is less than the requested amount!'");
				Возврат Ложь;
			КонецЕсли;		
		КонецЕсли;	
	КонецЕсли;

	Попытка
		ДокОбъект    = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
		СтруктураЗап = Новый Структура;
		СтруктураЗап.Вставить("ТипДенежныхСредств", Перечисления.ТипыДенежныхСредств.Наличные);
		СтруктураЗап.Вставить("ВидОперации"       , Перечисления.ВидыОпераций.ПоступлениеИзКассыПредприятия);
		СтруктураЗап.Вставить("Касса"             , Касса);
		СтруктураЗап.Вставить("СуммаДокумента"    , СуммаПоступления);		
		Если ЗначениеЗаполнено(Комментарий) Тогда
			СтруктураЗап.Вставить("Комментарий"   , Комментарий);			 
		КонецЕсли;
		
		ДокОбъект.Заполнить(СтруктураЗап);
		ДокОбъект.Дата = ТекущаяДатаСеанса(); 		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		ДокПоступления = ДокОбъект.Ссылка;
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Если ФормироватьВыемкуАвтоматически = Истина Тогда
		
		ДокОбъект    = Документы.СписаниеДенежныхСредств.СоздатьДокумент();
		СтруктураЗап = Новый Структура;
		СтруктураЗап.Вставить("ТипДенежныхСредств", Перечисления.ТипыДенежныхСредств.Наличные);
		СтруктураЗап.Вставить("ВидОперации"       , Перечисления.ВидыОпераций.ВыбытиеВОперационнуюКассу);
		СтруктураЗап.Вставить("Касса"             , КассаВыбытия);
		СтруктураЗап.Вставить("СуммаДокумента"    , СуммаПоступления);
		Если ЗначениеЗаполнено(Комментарий) Тогда
			СтруктураЗап.Вставить("Комментарий"   , Комментарий);			 
		КонецЕсли;
		
		ДокОбъект.Заполнить(СтруктураЗап);
		ДокОбъект.Дата = ТекущаяДатаСеанса();
		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		ДокВыбытия = ДокОбъект.Ссылка;	
	КонецЕсли;
	
	Возврат Новый Структура("ДокПоступления, ДокВыбытия", ДокПоступления, ДокВыбытия);
	
КонецФункции

// Процедура - Записать номер чека в документ
//
// Параметры:
//  ДокументСсылка	 - 	 - 
//  НомерЧека		 - 	 - 
//
Процедура ЗаписатьНомерЧекаВДокумент(ДокументСсылка, НомерЧека) Экспорт
	
	Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("НомерЧекаККМ", ДокументСсылка.Метаданные()) = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	ДокОбъект = ДокументСсылка.ПолучитьОбъект();
	ДокОбъект.НомерЧекаККМ = НомерЧека;
	ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
	 
КонецПроцедуры

// Функция - Получить кассы доступные для оплаты
// 
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Сотрудник			 - 	 - 
//  РабочееМесто		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьКассыДоступныеДляОплаты(Кассы, РабочееМесто, ЕслиЕстьФРТоТолькоДоступные = Истина, СтруктурнаяЕдиница = Неопределено) Экспорт
	
	МассивКасс = Новый Массив;
	
	Для Каждого Касса ИЗ Кассы Цикл
		
		КассаДоступнаПоФр = Истина;	
		ФРИспользуется    = ЗначениеЗаполнено(Касса.ВнешнееОборудование) И Касса.ВнешнееОборудование.УстройствоИспользуется = Истина;
		
		Если Касса.ИспользоватьБезПодключенияОборудования = Ложь 
			И ЗначениеЗаполнено(Касса.ВнешнееОборудование)
			И Касса.ВнешнееОборудование.УстройствоИспользуется = Истина
			И Касса.ВнешнееОборудование.РабочееМесто <> РабочееМесто Тогда
			
			КассаДоступнаПоФр = Ложь;
			
		КонецЕсли;
		
		МассивКасс.Добавить(Новый Структура("Касса,ФРИспользуется,КассаДоступна,ИспользуетсяОнлайн", Касса, ФРИспользуется, КассаДоступнаПоФр, Ложь));
		
	КонецЦикла;
	
	Возврат МассивКасс;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

