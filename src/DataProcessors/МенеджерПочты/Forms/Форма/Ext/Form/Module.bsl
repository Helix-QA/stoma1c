// Обработчик команды "ОтветитьВсем"
//
Процедура ОтветитьВсем(Команда)
	
	ТекущиеДанные = Элементы.СписокПисем.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда Возврат; КонецЕсли;
	
	ТекущиеДанныеДерева = Элементы.ПанельУправления.ТекущиеДанные;
	Если НЕ ПроверитьНаВозможностьОтпавкиПисьма(ТекущиеДанныеДерева.УчетнаяЗапись) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Учетная запись не предназначена для отправки писем");
		Возврат;
	КонецЕсли;
	
	Основание = Новый Структура("Предмет, Команда", ТекущиеДанные.Ссылка, "ОтветитьВсем");
	ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", Основание);
	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыОткрытия);
	
КонецПроцедуры

