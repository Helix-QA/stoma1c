		Соединение = Новый HTTPСоединение(ТестовыйСервер); //"api-test.itapi.ru"
		
		ТелоЗапросаJSON = "{""request_number"": ""+74951234567"", ""from_sipuri"": ""test_user@cloudpbx.rt.ru""}"; // Тестовое тело, иногда без тела возвращает ошибку валидации.
		СтрокаХешированиеДанных = SHA256(Код + ТелоЗапросаJSON + Ключ);
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
		ЗаголовкиHTTP.Вставить("X-Client-ID"  , Код);
		ЗаголовкиHTTP.Вставить("X-Client-Sign", СтрокаХешированиеДанных);
		
		HTTPЗапрос = Новый HTTPЗапрос("/call_back", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапросаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда // Немного странно, ОтветHTTP может прилететь либо в json, либо строка.				
				
				Попытка
					ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
					ОписаниеОшибки = ОписаниеОшибки + ?(ПараметрыJSON <> Неопределено И ПараметрыJSON.Свойство("resultMessage"), " (" + ПараметрыJSON.resultMessage + ")", "");
				Исключение
					ОписаниеОшибки = ОписаниеОшибки + " (" + ОтветHTTP + ")";
				КонецПопытки
				
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ROSTELECOM_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, IPТелефонияПараметры, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 						  = ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 			  = ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 				  = ПараметрыJSON.session_id;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 	  = Ложь;
	
	Если НРег(ПараметрыJSON.type)      = "incoming" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;				
	ИначеЕсли НРег(ПараметрыJSON.type) = "outbound" Тогда 		
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий;		
	ИначеЕсли НРег(ПараметрыJSON.type) = "internal" Тогда 		
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Внутренний;		
	КонецЕсли;

	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда		
		
		УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника = ?(ПараметрыJSON.Свойство("request_pin"), Строка(ПараметрыJSON.request_pin), ""); // PIN вызываемого сотрудника. для вх и внутренних	
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom		  = СтрЗаменить(СтрРазделить(ПараметрыJSON.from_number, "@")[0], "sip:", "");  // номер вызывающего абонента для исх. Кому я звоню.
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   		  = СтрЗаменить(СтрРазделить(ПараметрыJSON.request_number, "@")[0], "sip:", "");
		УнифицированнаяСтруктураСобытия.НомерКонтрагента		  = УнифицированнаяСтруктураСобытия.НомерТелефонаFrom;
		
	ИначеЕсли УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий Тогда
		
		УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника = ?(ПараметрыJSON.Свойство("from_pin"), Строка(ПараметрыJSON.from_pin), ""); // PIN сотрудника, который вызывает.
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 		  = УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника; 		
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo  		  = СтрЗаменить(СтрРазделить(ПараметрыJSON.request_number, "@")[0], "sip:", ""); // номер вызываемого абонента для исх. Кому я звоню.
	ИначеЕсли УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Внутренний Тогда	
		
		УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника = ?(ПараметрыJSON.Свойство("request_pin"), Строка(ПараметрыJSON.request_pin), "");
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom		  = ?(ПараметрыJSON.Свойство("from_pin"), Строка(ПараметрыJSON.from_pin), "");
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   		  = УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника;	
		
	КонецЕсли;
	
	УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = ?(СтрДлина(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom) > 10 И Лев(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom, 1) = "8", "7" + Сред(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom,2), УнифицированнаяСтруктураСобытия.НомерТелефонаFrom);
	УнифицированнаяСтруктураСобытия.НомерТелефонаTo   = ?(СтрДлина(УнифицированнаяСтруктураСобытия.НомерТелефонаTo) > 10 И Лев(УнифицированнаяСтруктураСобытия.НомерТелефонаTo, 1) = "8", "7" + Сред(УнифицированнаяСтруктураСобытия.НомерТелефонаTo,2), УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
	
	ТелефонныйАппарат 										  = Справочники.ТелефонныеАппараты.ПолучитьТелефонныйАппаратПоНомеру(?(ПараметрыJSON.Свойство("request_pin"), Строка(ПараметрыJSON.request_pin), Неопределено));	
	УнифицированнаяСтруктураСобытия.СтруктурнаяЕдиница        = ?(ЗначениеЗаполнено(ТелефонныйАппарат), ТелефонныйАппарат.СтруктурнаяЕдиница, IPТелефонияПараметры.СтруктурнаяЕдиница);
										
	Если НРег(ПараметрыJSON.state) = "new" ИЛИ НРег(ПараметрыJSON.state) = "calling" Тогда
		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 		   = Перечисления.СтатусыЗвонка.Вызов;							
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.timestamp);
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен  = Ложь;
		Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли НРег(ПараметрыJSON.state) = "connected" Тогда
		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка          = Перечисления.СтатусыЗвонка.Разговор;
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов    = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.timestamp);			
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = Ложь;
		Возврат СобытиеЗвонокСоединение(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли НРег(ПараметрыJSON.state) = "end" Тогда
		
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 		  = Истина;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = Ложь;	
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 		  = Перечисления.СтатусыЗвонка.Завершен;
		УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.timestamp);
		Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	// ИначеЕсли НРег(ПараметрыJSON.state) = "disconnected" Тогда
	// 	
	// 	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий Тогда
	// 		ОписаниеОшибки = "Данный запрос не используется";
	// 		Возврат Ложь;
	// 	КонецЕсли;
	// 	
	// 	УнифицированнаяСтруктураСобытия.ЗвонокУспешен         = Ложь;
	// 	УнифицированнаяСтруктураСобытия.СтатусЗвонка          = Перечисления.СтатусыЗвонка.Пропущен;
	// 	УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен = УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
	// 	Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки); 		
		
	Иначе
		ОписаниеОшибки = "Функция не существует или не распознана.";
		Возврат Истина;		
	КонецЕсли;
	
КонецФункции

// Функция - событие завершение звонка
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ROSTELECOM_СобытиеЗавершениеЗвонка(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.callid;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Истина;

	// Определяем направление вызова
	Если ПараметрыJSON.type = "INCOMING" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Входящий;
	ИначеЕсли ПараметрыJSON.type = "OUTGOING" Тогда 
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Исходящий;
	КонецЕсли;
	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= ПараметрыJSON.type = "CANCELLED";
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;						
	КонецЕсли;	
	
	// Определяем результат вызова
	ПризнакЗвонокПропущен 	= Ложь;			
	Если ПараметрыJSON.type = "CANCELLED" Тогда 
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 			= Ложь;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка			= ?(УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.НеДозвон);
	ИначеЕсли ПараметрыJSON.type = "COMPLETED" Тогда 
		УнифицированнаяСтруктураСобытия.ЗвонокУспешен 			= Истина;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка			= Перечисления.СтатусыЗвонка.Завершен;		
	КонецЕсли;	
			
	Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);			
	
КонецФункции

// Функция - событие запись разговора
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ROSTELECOM_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыJSON, IPТелефонияПараметры, ОписаниеОшибки = "") Экспорт
		
	Если НЕ IPТелефонияПараметры.Свойство("Сервер") ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("session_id", ПараметрыJSON.session_id);
	                                                                                                                             
	СтрокаТелаJSON = КодироватьВJSON(СтруктураПараметров);
	
	Попытка
		
		СайтАдрес = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
		
		Если СтрНайти(IPТелефонияПараметры.Сервер, "https://") = 1 Тогда  
			Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Иначе 
			Соединение = Новый HTTPСоединение(СайтАдрес, 80);
		КонецЕсли;
		
		СтрокаХешированиеДанных = SHA256(IPТелефонияПараметры.Код + СтрокаТелаJSON + IPТелефонияПараметры.Ключ); 
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
		ЗаголовкиHTTP.Вставить("X-Client-ID"  , IPТелефонияПараметры.Код);
		ЗаголовкиHTTP.Вставить("X-Client-Sign", СтрокаХешированиеДанных);
		
		HTTPЗапрос = Новый HTTPЗапрос("/get_record", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаТелаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
		ДанныеJSON  = ДекодироватьИзJSON(ОтветHTTP);
		
		Если СтруктураОтвета.КодСостояния = 200 И ДанныеJSON <> Неопределено И ДанныеJSON.result = "0" Тогда
			
			УнифицированнаяСтруктураСобытия 					  = ПолучитьУнифицированнуюСтруктуруСобытия();
			УнифицированнаяСтруктураСобытия.ПОIPТелефонии 		  = ПОIPТелефонии;
			УнифицированнаяСтруктураСобытия.IDЗвонка 			  = ПараметрыJSON.session_id;
			УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка  = ДанныеJSON.url;
			УнифицированнаяСтруктураСобытия.ФинализирующееСобытие = Ложь;
			ДобавитьОбновитьЗвонокВИсторию(ПараметрыJSON, УнифицированнаяСтруктураСобытия);			
			Возврат Истина;
			
		Иначе			
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОписаниеОшибки = ОписаниеОшибки + ?(ДанныеJSON <> Неопределено И ДанныеJSON.Свойство("resultMessage"), " (" + ДанныеJSON.resultMessage + ")", "");
			//ЗаписьЖурналаРегистрации("IP телефония", УровеньЖурналаРегистрации.Ошибка,,,ОтветHTTP);
			Возврат Ложь;
			
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		ЗаписьЖурналаРегистрации("IP телефония", УровеньЖурналаРегистрации.Ошибка,,,ОтветHTTP);
		Возврат Ложь;
		
	КонецПопытки; 
				
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ROSTELECOM_ИсходящийЗвонокОсуществить(ПОIPТелефонии, ВнутреннийНомерТелефона, ВнешнийНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("request_number", ВнешнийНомерТелефона);
	СтруктураПараметров.Вставить("from_pin"      , ВнутреннийНомерТелефона);
	
	СтрокаТелаJSON = КодироватьВJSON(СтруктураПараметров);
	
	Попытка
		
		СайтАдрес = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
		
		Если СтрНайти(IPТелефонияПараметры.Сервер, "https://") = 1 Тогда  
			Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Иначе 
			Соединение = Новый HTTPСоединение(СайтАдрес, 80);
		КонецЕсли;
		
		СтрокаХешированиеДанных = SHA256(IPТелефонияПараметры.Код + СтрокаТелаJSON + IPТелефонияПараметры.Ключ); 
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
		ЗаголовкиHTTP.Вставить("X-Client-ID"  , IPТелефонияПараметры.Код);
		ЗаголовкиHTTP.Вставить("X-Client-Sign", СтрокаХешированиеДанных);
		
		HTTPЗапрос = Новый HTTPЗапрос("/call_back", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаТелаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
		ДанныеJSON  = ДекодироватьИзJSON(ОтветHTTP);
		
		Если СтруктураОтвета.КодСостояния = 200 И ДанныеJSON <> Неопределено И ДанныеJSON.result = "0" Тогда			
			Возврат Истина;			
		Иначе					
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОписаниеОшибки = ОписаниеОшибки + ?(ДанныеJSON <> Неопределено И ДанныеJSON.Свойство("resultMessage"), " (" + ДанныеJSON.resultMessage + ")", "");
			Возврат Ложь;			
		КонецЕсли;
		
	Исключение		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;		
	КонецПопытки;
	
КонецФункции

// Функция - ROSTELECOM переадресация звонка
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ROSTELECOM_ПереадресацияЗвонка(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	ОбязательныйПараметр = "phone";
	Если Не ПараметрыJSON.Свойство(ОбязательныйПараметр) Тогда				
		ОписаниеОшибки = СтрШаблон(НСтр("ru='Отсутствует обязательный параметр %1.'"), ОбязательныйПараметр);
	КонецЕсли;
	
	// СтруктураЛичныйМенеджер = IPТелефония.ПолучитьЛичногоМенеджераДляПереадресации(ПараметрыJSON.phone, ОписаниеОшибки);
	СтруктураЛичныйМенеджер = Неопределено;
	ЗаписьJSON = Неопределено;
	Если СтруктураЛичныйМенеджер <> Неопределено Тогда
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет));
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		
		ЗаписьJSON.ЗаписатьИмяСвойства("contact_name");
		ЗаписьJSON.ЗаписатьЗначение(СтруктураЛичныйМенеджер.Представление);
		
		Если СтруктураЛичныйМенеджер.Свойство("InternalNumberGroup") Тогда
			ЗаписьJSON.ЗаписатьИмяСвойства("responsible");
			ЗаписьJSON.ЗаписатьЗначение(СтруктураЛичныйМенеджер.InternalNumberGroup);
		КонецЕсли;
		
		ЗаписьJSON.ЗаписатьКонецОбъекта();
		ПараметрыОтвета = ЗаписьJSON.Закрыть();
		
	КонецЕсли;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Если ЗаписьJSON <> Неопределено Тогда
		Ответ.УстановитьТелоИзСтроки(ПараметрыОтвета);
	КонецЕсли;	
	
	Возврат Ответ;
	
КонецФункции

// Процедура - ROSTELECOM получить URLЗаписей по регламенту
// 
Процедура ROSTELECOM_ПолучитьURLЗаписейИЗаписатьВРегистр(ПОIPТелефонии = Неопределено, КоличествоЗаписей) Экспорт
	
	Если ПОIPТелефонии = Неопределено Тогда
		ПОIPТелефонии = ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда
		Возврат;
	КонецЕсли;
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено 
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура") 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Сервер) 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Код) 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Ключ) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КоличествоЗаписей) Тогда
		КоличествоЗаписей = 1;
	КонецЕсли;
	
	РезультатЗапроса = ROSTELECOM_ПолучитьТаблицуЗвонков(КоличествоЗаписей);
	
	Для Каждого Звонок Из РезультатЗапроса Цикл
		
		СтруктураПараметров = Новый Структура();
		СтруктураПараметров.Вставить("session_id", Звонок.IDЗвонка);
		
		URLЗаписи = ROSTELECOM_HTTPЗапросНаПолучениеURLЗаписи(Звонок.IDЗвонка,,, IPТелефонияПараметры);
		
		Если ЗначениеЗаполнено(URLЗаписи) Тогда	
			УнифицированнаяСтруктураСобытия 					  = ПолучитьУнифицированнуюСтруктуруСобытия();
			УнифицированнаяСтруктураСобытия.ПОIPТелефонии 		  = ПОIPТелефонии;
			УнифицированнаяСтруктураСобытия.IDЗвонка 			  = Звонок.IDЗвонка;							
			УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка  = URLЗаписи;
			УнифицированнаяСтруктураСобытия.ФинализирующееСобытие = Ложь;
			ДобавитьОбновитьЗвонокВИсторию(, УнифицированнаяСтруктураСобытия);							
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Получить актуальный URLЗаписи ROSTELECOM
//
// Параметры:
//  АктуальныйURLЗаписи	 - 	 - 
//
Функция ПолучитьАктуальныйURLЗаписиROSTELECOMСервер(ИсходныйURLЗаписи, IDЗвонка, ВнешнийIPКлиента) Экспорт
	
	ПОIPТелефонии = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM);			
	URLЗаписи 	  = IPТелефония.ROSTELECOM_HTTPЗапросНаПолучениеURLЗаписи(IDЗвонка, ВнешнийIPКлиента, ПОIPТелефонии);
	
	Если ЗначениеЗаполнено(URLЗаписи) Тогда
		Возврат URLЗаписи;
	Иначе
		Возврат ИсходныйURLЗаписи;
	КонецЕсли;
	
КонецФункции

// Функция - ROSTELECOM HTTPЗапрос на получение URLЗаписи
//
// Параметры:
//  IDЗвонка			 - 	 - 
//  IPАдрес				 - 	 - 
//  IPТелефонияПараметры - 	 - 
//  ПОIPТелефонии		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ROSTELECOM_HTTPЗапросНаПолучениеURLЗаписи(IDЗвонка, IPАдрес = Неопределено, ПОIPТелефонии = Неопределено, IPТелефонияПараметры = Неопределено) Экспорт
	
	Если IPТелефонияПараметры = Неопределено И ПОIPТелефонии = Неопределено Тогда
		ПОIPТелефонии = ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM);
	КонецЕсли;
	
	Если IPТелефонияПараметры = Неопределено И ПОIPТелефонии <> Неопределено Тогда	
		IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();		
	КонецЕсли;
	
	Если IPТелефонияПараметры = Неопределено ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура") ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Сервер) 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Код) ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Ключ) Тогда
		
		Возврат Неопределено;		
	КонецЕсли;
		
	СайтАдрес = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("session_id", IDЗвонка);
	
	Если IPАдрес <> Неопределено Тогда
		СтруктураПараметров.Вставить("ip_adress", IPАдрес);
	КонецЕсли;
	
	СтрокаТелаJSON = КодироватьВJSON(СтруктураПараметров);
	
	Попытка
		
		Если СтрНайти(IPТелефонияПараметры.Сервер, "https://") = 1 Тогда  
			Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Иначе 
			Соединение = Новый HTTPСоединение(СайтАдрес, 80);
		КонецЕсли;
		
		СтрокаХешированиеДанных = SHA256(IPТелефонияПараметры.Код + СтрокаТелаJSON + IPТелефонияПараметры.Ключ); 
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
		ЗаголовкиHTTP.Вставить("X-Client-ID"  , IPТелефонияПараметры.Код);
		ЗаголовкиHTTP.Вставить("X-Client-Sign", СтрокаХешированиеДанных);
		
		HTTPЗапрос = Новый HTTPЗапрос("/get_record", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаТелаJSON);
		
		HTTPОтвет   = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоЗапроса = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		Если Не (HTTPОтвет.КодСостояния = 200 И ЗначениеЗаполнено(ТелоЗапроса)) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		ДанныеJSON = ДекодироватьИзJSON(ТелоЗапроса);
		
		Если Не (ЗначениеЗаполнено(ДанныеJSON) И ДанныеJSON.result = "0") Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Возврат ДанныеJSON.url;
		
	Исключение
		
		Возврат Неопределено;
		
	КонецПопытки
	
КонецФункции

// Функция - Получить таблицу звонков ROSTELECOM
//
// Параметры:
//  КоличествоЗаписей	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ROSTELECOM_ПолучитьТаблицуЗвонков(КоличествоВыбираемыхЗаписей)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ИсторияВызовов.IDЗвонка КАК IDЗвонка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.IDЗвонка <> """"
	|	И ИсторияВызовов.URLЗаписи = """"
	|	И ИсторияВызовов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Завершен)
	|	И ИсторияВызовов.ОкончаниеЗвонка >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1)
	|	И ИсторияВызовов.ОкончаниеЗвонка <= ДОБАВИТЬКДАТЕ(&ТекущаяДата, МИНУТА, -1)");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБРАТЬ РАЗРЕШЕННЫЕ", СтрШаблон("ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ %1", КоличествоВыбираемыхЗаписей));
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить таблицу звонков ROSTELECOM
//
// Параметры:
//  КоличествоЗаписей	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЭтоОбработчикДрайвераПереданнойПОIPТелефонии(ПОIPТелефонии, ОбработчикДрайвераПеречисление) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПодключаемоеОборудование.ДрайверОборудования.ОбработчикДрайвера КАК ОбработчикДрайвера
	|ИЗ
	|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	|ГДЕ
	|	ПодключаемоеОборудование.Ссылка = &ПОIPТелефонии");
		
	Запрос.УстановитьПараметр("ПОIPТелефонии", ПОIPТелефонии);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ОбработчикДрайвера = ОбработчикДрайвераПеречисление;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Процедура - ROSTELECOM получитет рекламную компанию 
// 
Процедура ROSTELECOM_ДополнитьЗвонокРекламнойКомпанией(ПОIPТелефонии, ПараметрыJSON) Экспорт
	
	Если ПОIPТелефонии = Неопределено Тогда
		ПОIPТелефонии = ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда
		Возврат;
	КонецЕсли;
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено 
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура") 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Сервер) 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Код) 
		ИЛИ Не ЗначениеЗаполнено(IPТелефонияПараметры.Ключ) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если ПараметрыJSON.Свойство("advertising_campaign") Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИсторияВызовов.ОборудованиеТелефонии КАК ОборудованиеТелефонии,
		|	ИсторияВызовов.IDЗвонка КАК IDЗвонка,
		|	ИсторияВызовов.НомерТелефона КАК НомерТелефона,
		|	ИсторияВызовов.НачалоВызова КАК НачалоВызова
		|ИЗ
		|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
		|ГДЕ
		|	ИсторияВызовов.НомерТелефона = &НомерТелефона
		|
		|УПОРЯДОЧИТЬ ПО
		|	ИсторияВызовов.НачалоВызова УБЫВ";
		
		Запрос.УстановитьПараметр("НомерТелефона", "+" + ПараметрыJSON.contact_info.contact_phone_number);
		
		РезультатаЗапроса = Запрос.Выполнить().Выбрать();	
		
		Если РезультатаЗапроса.Следующий() Тогда 
			
			НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
			
			НаборЗаписей.Отбор.ОборудованиеТелефонии.Установить(ПОIPТелефонии);
			НаборЗаписей.Отбор.IDЗвонка.Установить(РезультатаЗапроса.IDЗвонка);
			НаборЗаписей.Прочитать();
			
			Если НаборЗаписей.Количество() > 0 Тогда 
				Запись = НаборЗаписей[0];
				Запись.КоллтрекингНомер = ПараметрыJSON.call_session_id;
				
				РекламнаяПлощадка = Справочники.КаналыПривлечения.НайтиПоНаименованию(ПараметрыJSON.advertising_campaign);
				Если НЕ ЗначениеЗаполнено(РекламнаяПлощадка) Тогда
					РекламнаяПлощадка = Справочники.КаналыПривлечения.СоздатьЭлемент();
					РекламнаяПлощадка.Наименование = ПараметрыJSON.advertising_campaign;
					РекламнаяПлощадка.Записать();
					РекламнаяПлощадка = РекламнаяПлощадка.Ссылка;
				КонецЕсли;
				
				Запись.ИсточникЗвонка = РекламнаяПлощадка;
				
				НаборЗаписей.Записать(Истина);
				
			КонецЕсли;

		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

