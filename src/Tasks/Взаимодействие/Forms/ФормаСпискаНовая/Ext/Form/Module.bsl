КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПланПриОкончанииРедактирования".
//
Процедура ПланПриОкончанииРедактирования(Элемент, НовыйЭлемент, ОтменаРедактирования)
	
	Если Элемент.ВыделенныеЭлементы.Количество() > 0 Тогда
		// Отменим перетаскивание если задача выполнена
		Для Каждого ЭлементМассива Из Элемент.ВыделенныеЭлементы Цикл 
			Если ЗначениеЗаполнено(ЭлементМассива.Значение) И ТипЗнч(ЭлементМассива.Значение) = Тип("ЗадачаСсылка.Взаимодействие") Тогда 
				Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭлементМассива.Значение, "Выполнена") Тогда 
					ОтменаРедактирования = Истина;
					Прервать;
				КонецЕсли;	
			КонецЕсли;	
		КонецЦикла;
		Если ОтменаРедактирования Тогда 
			Возврат;
		КонецЕсли;	
		
		ЭлементПланировщика = Элемент.ВыделенныеЭлементы[0];
		ВремяНачало 		= ЭлементПланировщика.Начало;
		КорректировкаВремениЗадачи(ВремяНачало, ЭлементПланировщика);
		ВесьДень = Ложь;					
		
		ДанныеЗадачи = ПерезаписатьДатуЗадания(?(ВесьДень, НачалоДня(ВремяНачало), ВремяНачало), ЭлементПланировщика.Значение, ?(ВыбранныйПериод = 3, Истина, Ложь));				
		ВесьДень     = ?(ВыбранныйПериод = 3 и НачалоДня(ДанныеЗадачи.Дата) = ДанныеЗадачи.Дата, Истина, ВесьДень);		
		ЭлементПланировщика.Текст    = ?(ВесьДень, "", Формат(ДанныеЗадачи.Дата, "ДФ=HH:mm"))+" "+ ДанныеЗадачи.Тема;		                                                            
		ЭлементПланировщика.ЦветФона = ?(НачалоДня(ДанныеЗадачи.Дата) < НачалоДня(ТекущаяДата()) И НЕ ЭлементПланировщика.ЦветФона = WebЦвета.БледноЗеленый,
		WebЦвета.СветлоКоралловый, ?(ЭлементПланировщика.ЦветФона = WebЦвета.БледноЗеленый, ЭлементПланировщика.ЦветФона, Новый Цвет()));	
		
		Если ВыбранныйПериод = 3 Тогда
			ЭлементПланировщика.Начало = ДанныеЗадачи.Дата;
			ЭлементПланировщика.Конец  = ДанныеЗадачи.Дата + 3600;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
