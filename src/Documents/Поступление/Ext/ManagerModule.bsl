#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область СлужебныйПрограммныйИнтерфейс	
	
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаПриходнаяНакладная, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоступлениеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	|	ПоступлениеЗапасовЗапасы.Ссылка КАК Документ,
	|	ПоступлениеЗапасовЗапасы.Ссылка.Контрагент КАК Контрагент,
	|	ПоступлениеЗапасовЗапасы.Ссылка.Склад КАК Склад,
	|	ПоступлениеЗапасовЗапасы.Ссылка.Дата КАК Период,
	|	ПоступлениеЗапасовЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПоступлениеЗапасовЗапасы.Ссылка.ВидЦен КАК ВидЦен,
	|	ПоступлениеЗапасовЗапасы.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА ПоступлениеЗапасовЗапасы.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	ПоступлениеЗапасовЗапасы.Цена КАК Цена,
	|	ПоступлениеЗапасовЗапасы.Упаковка КАК Упаковка,
	|	ПоступлениеЗапасовЗапасы.Количество КАК Количество,
	|	ПоступлениеЗапасовЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	ПоступлениеЗапасовЗапасы.Всего КАК Сумма,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ПоступлениеЗапасовЗапасы.Ссылка.АвторДокумента КАК Автор
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасы
	|ИЗ
	|	Документ.Поступление.Запасы КАК ПоступлениеЗапасовЗапасы
	|ГДЕ
	|	ПоступлениеЗапасовЗапасы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоступлениеРасходы.НомерСтроки КАК НомерСтроки,
	|	ПоступлениеРасходы.Ссылка КАК Документ,
	|	ПоступлениеРасходы.Ссылка.Контрагент КАК Контрагент,
	|	ПоступлениеРасходы.Ссылка.Склад КАК Склад,
	|	ПоступлениеРасходы.Ссылка.Дата КАК Период,
	|	ПоступлениеРасходы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПоступлениеРасходы.Ссылка.ВидЦен КАК ВидЦен,
	|	ПоступлениеРасходы.Номенклатура КАК Номенклатура,
	|	ПоступлениеРасходы.Цена КАК Цена,
	|	ПоступлениеРасходы.Упаковка КАК Упаковка,
	|	ПоступлениеРасходы.Количество КАК Количество,
	|	ПоступлениеРасходы.СтавкаНДС КАК СтавкаНДС,
	|	ПоступлениеРасходы.Всего КАК Сумма,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ПоступлениеРасходы.Ссылка.АвторДокумента КАК Автор
	|ПОМЕСТИТЬ ВременнаяТаблицаРасходы
	|ИЗ
	|	Документ.Поступление.Расходы КАК ПоступлениеРасходы
	|ГДЕ
	|	ПоступлениеРасходы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.НомерСтроки КАК НомерСтроки,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка КАК Документ,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.Контрагент КАК Контрагент,
	|	ВЫБОР
	|		КОГДА ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.Дата КАК Период,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Сумма КАК Сумма,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Номенклатура КАК Номенклатура,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Цена КАК Цена,
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыКонтрагентов
	|ИЗ
	|	Документ.Поступление.Запасы КАК ПоступлениеЗапасовВзаморасчетыКонрагентов
	|ГДЕ
	|	ПоступлениеЗапасовВзаморасчетыКонрагентов.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходыВзаморасчетыКонрагентов.НомерСтроки,
	|	РасходыВзаморасчетыКонрагентов.Ссылка,
	|	РасходыВзаморасчетыКонрагентов.Ссылка.СтруктурнаяЕдиница,
	|	РасходыВзаморасчетыКонрагентов.Ссылка.Контрагент,
	|	ВЫБОР
	|		КОГДА РасходыВзаморасчетыКонрагентов.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА РасходыВзаморасчетыКонрагентов.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ РасходыВзаморасчетыКонрагентов.Ссылка.Организация
	|	КОНЕЦ,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	РасходыВзаморасчетыКонрагентов.Ссылка.Дата,
	|	РасходыВзаморасчетыКонрагентов.Сумма,
	|	РасходыВзаморасчетыКонрагентов.Номенклатура,
	|	РасходыВзаморасчетыКонрагентов.Цена,
	|	РасходыВзаморасчетыКонрагентов.Ссылка.Договор
	|ИЗ
	|	Документ.Поступление.Расходы КАК РасходыВзаморасчетыКонрагентов
	|ГДЕ
	|	РасходыВзаморасчетыКонрагентов.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Затраты.Период КАК Период,
	|	Затраты.Сотрудник КАК Сотрудник,
	|	Затраты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Затраты.Контрагент КАК Контрагент,
	|	Затраты.Номенклатура КАК Номенклатура,
	|	Затраты.СтатьяЗатрат КАК СтатьяЗатрат,
	|	СУММА(Затраты.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаЗатрат
	|ИЗ
	|	(ВЫБРАТЬ
	|		Затраты.Дата КАК Период,
	|		ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Сотрудник,
	|		Затраты.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		Затраты.Ссылка.Контрагент КАК Контрагент,
	|		NULL КАК Номенклатура,
	|		Затраты.СтатьяЗатрат КАК СтатьяЗатрат,
	|		Затраты.Сумма КАК Сумма
	|	ИЗ
	|		Документ.Поступление.Затраты КАК Затраты
	|	ГДЕ
	|		Затраты.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПоступлениеРасходы.Ссылка.Дата,
	|		ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка),
	|		ПоступлениеРасходы.Ссылка.СтруктурнаяЕдиница,
	|		ПоступлениеРасходы.Ссылка.Контрагент,
	|		ПоступлениеРасходы.Номенклатура,
	|		ПоступлениеРасходы.СтатьяРасходов,
	|		ПоступлениеРасходы.Всего
	|	ИЗ
	|		Документ.Поступление.Расходы КАК ПоступлениеРасходы
	|	ГДЕ
	|		ПоступлениеРасходы.Ссылка = &Ссылка
	|		И ПоступлениеРасходы.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)) КАК Затраты
	|
	|СГРУППИРОВАТЬ ПО
	|	Затраты.СтруктурнаяЕдиница,
	|	Затраты.Сотрудник,
	|	Затраты.СтатьяЗатрат,
	|	Затраты.Контрагент,
	|	Затраты.Период,
	|	Затраты.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ПоступлениеЗапасы.НомерСтроки) КАК НомерСтроки,
	|	ПоступлениеЗапасы.Ссылка.Дата КАК Период,
	|	ПоступлениеЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ПоступлениеЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество)
	|			ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы)
	|	КОНЕЦ КАК СчетДт,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики) КАК СчетКт,
	|	ПоступлениеЗапасы.Номенклатура КАК СубконтоДт1,
	|	ПоступлениеЗапасы.Ссылка.Склад КАК СубконтоДт2,
	|	NULL КАК СубконтоДт3,
	|	NULL КАК СубконтоДт4,
	|	ПоступлениеЗапасы.Ссылка.Контрагент КАК СубконтоКт1,
	|	СУММА(ПоступлениеЗапасы.Сумма) КАК Сумма,
	|	СУММА(ВЫБОР
	|			КОГДА ПоступлениеЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|					ИЛИ ПоступлениеЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Материал)
	|				ТОГДА ПоступлениеЗапасы.Количество
	|		КОНЕЦ) КАК Количество,
	|	""Поступление от поставщика(запасы)"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.Поступление.Запасы КАК ПоступлениеЗапасы
	|ГДЕ
	|	ПоступлениеЗапасы.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоступлениеЗапасы.Ссылка.Дата,
	|	ПоступлениеЗапасы.Ссылка.СтруктурнаяЕдиница,
	|	ПоступлениеЗапасы.Номенклатура,
	|	ПоступлениеЗапасы.Ссылка.Контрагент,
	|	ПоступлениеЗапасы.Ссылка.Склад,
	|	ВЫБОР
	|		КОГДА ПоступлениеЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Имущество)
	|			ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы)
	|	КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходыРасходыПрочие.НомерСтроки,
	|	РасходыРасходыПрочие.Ссылка.Дата,
	|	РасходыРасходыПрочие.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыПрочие),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики),
	|	РасходыРасходыПрочие.СтатьяРасходов,
	|	ВЫБОР
	|		КОГДА РасходыРасходыПрочие.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
	|			ТОГДА РасходыРасходыПрочие.Специализация
	|		ИНАЧЕ РасходыРасходыПрочие.Номенклатура.Специализация
	|	КОНЕЦ,
	|	NULL,
	|	NULL,
	|	РасходыРасходыПрочие.Ссылка.Контрагент,
	|	СУММА(РасходыРасходыПрочие.Сумма),
	|	NULL,
	|	""Поступление от поставщика(услуги)""
	|ИЗ
	|	Документ.Поступление.Расходы КАК РасходыРасходыПрочие
	|ГДЕ
	|	РасходыРасходыПрочие.Ссылка = &Ссылка
	|	И РасходыРасходыПрочие.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И (НЕ РасходыРасходыПрочие.ДокументОснования ССЫЛКА Документ.НарядЗаказ
	|			ИЛИ РасходыРасходыПрочие.ДокументОснования = ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка))
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходыРасходыПрочие.Ссылка.Дата,
	|	РасходыРасходыПрочие.Ссылка.СтруктурнаяЕдиница,
	|	РасходыРасходыПрочие.СтатьяРасходов,
	|	РасходыРасходыПрочие.Ссылка.Контрагент,
	|	РасходыРасходыПрочие.НомерСтроки,
	|	ВЫБОР
	|		КОГДА РасходыРасходыПрочие.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
	|			ТОГДА РасходыРасходыПрочие.Специализация
	|		ИНАЧЕ РасходыРасходыПрочие.Номенклатура.Специализация
	|	КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходыРасходыРаспределенные.НомерСтроки,
	|	РасходыРасходыРаспределенные.Ссылка.Дата,
	|	РасходыРасходыРаспределенные.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыРаспределенные),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики),
	|	ВЫБОР
	|		КОГДА РасходыРасходыРаспределенные.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяССылка)
	|			ТОГДА РасходыРасходыРаспределенные.Специализация
	|		ИНАЧЕ РасходыРасходыРаспределенные.Номенклатура.Специализация
	|	КОНЕЦ,
	|	РасходыРасходыРаспределенные.Сотрудник,
	|	ВЫБОР
	|		КОГДА РасходыРасходыРаспределенные.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА РасходыРасходыРаспределенные.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.Лаборатория)
	|	КОНЕЦ,
	|	NULL,
	|	РасходыРасходыРаспределенные.Ссылка.Контрагент,
	|	СУММА(РасходыРасходыРаспределенные.Сумма),
	|	NULL,
	|	""Поступление от поставщика(услуги)""
	|ИЗ
	|	Документ.Поступление.Расходы КАК РасходыРасходыРаспределенные
	|ГДЕ
	|	РасходыРасходыРаспределенные.Ссылка = &Ссылка
	|	И РасходыРасходыРаспределенные.Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И (НЕ РасходыРасходыРаспределенные.ДокументОснования ССЫЛКА Документ.НарядЗаказ
	|			ИЛИ РасходыРасходыРаспределенные.ДокументОснования = ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка))
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходыРасходыРаспределенные.Ссылка.Дата,
	|	РасходыРасходыРаспределенные.Ссылка.СтруктурнаяЕдиница,
	|	РасходыРасходыРаспределенные.Ссылка.Контрагент,
	|	РасходыРасходыРаспределенные.НомерСтроки,
	|	РасходыРасходыРаспределенные.Сотрудник,
	|	ВЫБОР
