
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

#Область Проведение

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаВводОстатков, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =   	
		
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Партия КАК СерийныйНомер,
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Номенклатура КАК Сертификат,
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковСерийныеНомераСертификатов.ВидНоминала
	|			ТОГДА ВводНачальныхОстатковСерийныеНомераСертификатов.Партия.Номинал
	|		ИНАЧЕ ВводНачальныхОстатковСерийныеНомераСертификатов.Номенклатура.Номинал
	|	КОНЕЦ КАК Сумма,
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Ссылка.Дата КАК Период,
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Клиент КАК Контрагент
	|ПОМЕСТИТЬ ВременнаяТаблицаСертификаты
	|ИЗ
	|	Документ.ВводНачальныхОстатков.СерийныеНомераСертификатов КАК ВводНачальныхОстатковСерийныеНомераСертификатов
	|ГДЕ
	|	ВводНачальныхОстатковСерийныеНомераСертификатов.Ссылка.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка.Дата КАК Период,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Контрагент КАК Контрагент,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.ВидЛицевогоСчета КАК ВидСчета,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредстваНаЛицевыхСчетах
	|ИЗ
	|	Документ.ВводНачальныхОстатков.ДенежныеСредстваНаЛицевыхСчетах КАК ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах
	|ГДЕ
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка.Дата КАК Период,
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВводНачальныхОстатковБонусныеСчета.БонусныйСчет КАК БонусныйСчет,
	|	СУММА(ВводНачальныхОстатковБонусныеСчета.Сумма) КАК Сумма,
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка КАК ДокументНачисления
	|ПОМЕСТИТЬ ВременнаяТаблицаБонусныеСчета
	|ИЗ
	|	Документ.ВводНачальныхОстатков.БонусныеСчета КАК ВводНачальныхОстатковБонусныеСчета
	|ГДЕ
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВводНачальныхОстатковБонусныеСчета.БонусныйСчет,
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка.Дата,
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка.СтруктурнаяЕдиница,
	|	ВводНачальныхОстатковБонусныеСчета.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблицаПродажи.Ссылка.Дата КАК Период,
	|	ВременнаяТаблицаПродажи.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВременнаяТаблицаПродажи.Контрагент КАК Контрагент,
	|	ВременнаяТаблицаПродажи.Номенклатура КАК Номенклатура,
	|	ВременнаяТаблицаПродажи.Сумма КАК Сумма,
	|	ВременнаяТаблицаПродажи.Ссылка КАК ДокументПродажи,
	|	ВременнаяТаблицаПродажи.Количество КАК Количество,
	|	ВременнаяТаблицаПродажи.Сотрудник КАК Сотрудник,
	|	ВременнаяТаблицаПродажи.Ссылка.СтруктурнаяЕдиница.ОсновнойСклад КАК Склад,
	|	ВременнаяТаблицаПродажи.Партия КАК Партия,
	|	ВременнаяТаблицаПродажи.Ассистент КАК Ассистент,
	|	ВременнаяТаблицаПродажи.КонтрагентПлательщик КАК КонтрагентПлательщик,
	|	ВременнаяТаблицаПродажи.НомерЗуба КАК НомерЗуба,
	|	ВременнаяТаблицаПродажи.СтоимостьБезСкидки КАК СтоимостьБезСкидки,
	|	ВременнаяТаблицаПродажи.ДатаПродажи КАК ДатаПродажи
	|ПОМЕСТИТЬ ВременнаяТаблицаПродажи
	|ИЗ
	|	Документ.ВводНачальныхОстатков.Продажи КАК ВременнаяТаблицаПродажи
	|ГДЕ
	|	ВременнаяТаблицаПродажи.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка КАК Ссылка,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.Дата КАК Период,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	|			ТОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Контрагент КАК Контрагент,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.ДокументРеализации КАК ДокументРеализации,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма < 0
	|			ТОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма * -1
	|		ИНАЧЕ ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма > 0
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ КАК ВидДвижения,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.ДокументАванса КАК ДокументАванса
	|ПОМЕСТИТЬ ВременнаяТаблица_ВзаиморасчетыСКонтрагентами
	|ИЗ
	|	Документ.ВводНачальныхОстатков.ВзаиморасчетыСКонтрагентами КАК ВводНачальныхОстатковВзаиморасчетыСКонтрагентами
	|ГДЕ
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка.Дата,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка.СтруктурнаяЕдиница,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка.СтруктурнаяЕдиница.Организация,
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Контрагент,
	|	NULL,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Сумма < 0
	|			ТОГДА ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Сумма * -1
	|		ИНАЧЕ ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Сумма
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Сумма > 0
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ,
	|	NULL
	|ИЗ
	|	Документ.ВводНачальныхОстатков.ДенежныеСредстваНаЛицевыхСчетах КАК ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах
	|ГДЕ
	|	ВводНачальныхОстатковДенежныеСредстваНаЛицевыхСчетах.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковРасчетыСПерсоаналом.Сумма >= 0
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ КАК ВидДвижения,
	|	ВводНачальныхОстатковРасчетыСПерсоаналом.Ссылка.Дата КАК Период,
	|	НАЧАЛОПЕРИОДА(ВводНачальныхОстатковРасчетыСПерсоаналом.МесяцНачисления, МЕСЯЦ) КАК МесяцНачисления,
	|	ВводНачальныхОстатковРасчетыСПерсоаналом.ДокументНачисления КАК ДокументНачисления,
	|	ВводНачальныхОстатковРасчетыСПерсоаналом.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВводНачальныхОстатковРасчетыСПерсоаналом.Сотрудник КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковРасчетыСПерсоаналом.Сумма < 0
	|			ТОГДА -ВводНачальныхОстатковРасчетыСПерсоаналом.Сумма
	|		ИНАЧЕ ВводНачальныхОстатковРасчетыСПерсоаналом.Сумма
	|	КОНЕЦ КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПерсоналом
	|ИЗ
	|	Документ.ВводНачальныхОстатков.РасчетыСПерсоаналом КАК ВводНачальныхОстатковРасчетыСПерсоаналом
	|ГДЕ
	|	ВводНачальныхОстатковРасчетыСПерсоаналом.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.НомерСтроки) КАК НомерСтроки,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.Дата КАК Период,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма < 0
	|			ТОГДА ВЫБОР
	|					КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Контрагент.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|						ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Покупатели)
	|					ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики)
	|				КОНЕЦ
	|		ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Служебный)
	|	КОНЕЦ КАК СчетДт,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма > 0
	|			ТОГДА ВЫБОР
	|					КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Контрагент.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|						ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Покупатели)
	|					ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики)
	|				КОНЕЦ
	|		ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Служебный)
	|	КОНЕЦ КАК СчетКт,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма < 0
	|			ТОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Контрагент
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК СубконтоДт1,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма > 0
	|			ТОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Контрагент
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК СубконтоКт1,
	|	СУММА(ВЫБОР
	|			КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма < 0
	|				ТОГДА -ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма
	|			ИНАЧЕ ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма
	|		КОНЕЦ) КАК Сумма,
	|	""Ввод начальных остатков(взаиморасчеты)"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.ВводНачальныхОстатков.ВзаиморасчетыСКонтрагентами КАК ВводНачальныхОстатковВзаиморасчетыСКонтрагентами
	|ГДЕ
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.Дата,
	|	ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Ссылка.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма < 0
	|			ТОГДА ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконто.Контрагенты)
	|		ИНАЧЕ NULL
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма > 0
	|			ТОГДА ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконто.Контрагенты)
	|		ИНАЧЕ NULL
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма < 0
	|			ТОГДА ВЫБОР
	|					КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Контрагент.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|						ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Покупатели)
	|					ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики)
	|				КОНЕЦ
	|		ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Служебный)
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ВводНачальныхОстатковВзаиморасчетыСКонтрагентами.Сумма > 0
	|			ТОГДА ВЫБОР
