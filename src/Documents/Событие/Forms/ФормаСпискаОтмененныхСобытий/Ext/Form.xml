	СобытиеУслуги.ДатаНачала КАК ОтборДатаОкончания,
	СобытиеУслуги.ДатаОкончания КАК ДатаОкончания,
	СобытиеУслуги.Сотрудник КАК Сотрудник,
	СобытиеУслуги.Помещение КАК Помещение,
	СобытиеУслуги.Номенклатура КАК Номенклатура,
	СобытиеУслуги.Цена КАК Цена,
	СобытиеУслуги.НормаВремени КАК НормаВремени,
	СобытиеУслуги.Ссылка.Контрагент КАК Контрагент,
	СобытиеУслуги.Ссылка.Номер КАК Номер,
	СобытиеУслуги.Ссылка.Проведен КАК Проведен,
	СобытиеУслуги.Ссылка.ПричинаОтмены КАК ПричинаОтмены,
	СобытиеУслуги.Ссылка.ПометкаУдаления КАК ПометкаУдаления,
	ВЫБОР
		КОГДА СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА ДЕНЬГОДА(&amp;ТекущаяДата) &gt; ДЕНЬГОДА(СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента)
						ТОГДА РАЗНОСТЬДАТ(СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД)
					ИНАЧЕ (ВЫРАЗИТЬ(РАЗНОСТЬДАТ(СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД) КАК ЧИСЛО)) - 1
				КОНЕЦ
	КОНЕЦ КАК Возраст,
	СобытиеУслуги.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
ИЗ
	Документ.Событие.Услуги КАК СобытиеУслуги
ГДЕ
	СобытиеУслуги.Ссылка.Проведен = ИСТИНА
	И СобытиеУслуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	И СобытиеУслуги.НомерСтроки = 1

СГРУППИРОВАТЬ ПО
	СобытиеУслуги.Сотрудник,
	СобытиеУслуги.Ссылка,
	СобытиеУслуги.Помещение,
	СобытиеУслуги.ДатаНачала,
	СобытиеУслуги.Номенклатура,
	СобытиеУслуги.ДатаОкончания,
	СобытиеУслуги.Цена,
	СобытиеУслуги.НормаВремени,
	СобытиеУслуги.Ссылка.Контрагент,
	СобытиеУслуги.Ссылка.Номер,
	СобытиеУслуги.Ссылка.Проведен,
	СобытиеУслуги.Ссылка.ПричинаОтмены,
	СобытиеУслуги.Ссылка.ПометкаУдаления,
	ВЫБОР
		КОГДА СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА ДЕНЬГОДА(&amp;ТекущаяДата) &gt; ДЕНЬГОДА(СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента)
						ТОГДА РАЗНОСТЬДАТ(СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД)
					ИНАЧЕ (ВЫРАЗИТЬ(РАЗНОСТЬДАТ(СобытиеУслуги.Ссылка.Контрагент.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД) КАК ЧИСЛО)) - 1
				КОНЕЦ
	КОНЕЦ,
	СобытиеУслуги.ДатаНачала,
	СобытиеУслуги.ДатаНачала</QueryText>
