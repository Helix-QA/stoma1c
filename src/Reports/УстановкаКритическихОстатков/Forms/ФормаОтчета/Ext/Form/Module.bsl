// Функция возвращает полный путь к форме объекта справочника
//
Функция ВернутьПолноеИмяФормы(Ссылка, Группа)
	
	Если Группа Тогда
		ПолноеИмяФормыСсылки = "Справочник." + Ссылка.Метаданные().Имя + ".ФормаГруппы";
	Иначе
		ПолноеИмяФормыСсылки = "Справочник." + Ссылка.Метаданные().Имя + ".Форма.ФормаЭлемента";
	КонецЕсли;
	Возврат ПолноеИмяФормыСсылки;
	
