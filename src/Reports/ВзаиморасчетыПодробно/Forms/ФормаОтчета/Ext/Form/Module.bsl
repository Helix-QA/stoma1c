
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Контрагент") Тогда 
		Отчет.Контрагент = Параметры.Контрагент;
	КонецЕсли;
	
	ВывестиОтчет();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды "Сформировать"
//
Процедура Сформировать(Команда)
	
	ВывестиОтчет();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, формирует отчет
//
Процедура ВывестиОтчет()
	
	Отчеты.ВзаиморасчетыПодробно.ВывестиАктОбОказанныхУслугах(Отчет.Контрагент, Отчет.СтруктурнаяЕдиница, ТабличныйДокумент, НачалоПериода, КонецПериода);
	
КонецПроцедуры

#КонецОбласти


