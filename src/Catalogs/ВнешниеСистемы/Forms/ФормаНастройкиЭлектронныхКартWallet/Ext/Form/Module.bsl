// Процедура, обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Не ПодключениеУстановлено Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Введены неверные данные авторизации",,,, Отказ);
		Возврат;
		
	КонецЕсли;
	
	Если Не ЭтоОблако Тогда
		
		РезультатПроверки = ПроверитьПубликациюИнформационнойБазы();
		
		Если Не РезультатПроверки Тогда 
			
			ОткрытьФорму("Обработка.ЛичныйКабинет.Форма.ФормаНастройкиВнешнейПубликации",,ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);    
			
			ПоказатьОповещениеПользователя("Wallet",, "Необходимо настроить внешнюю публикацию", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);
			Отказ = Истина;
			
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УидСессии) Тогда      
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ПослеВопросаОРегистрацииВЛК", ЭтотОбъект),
		Нстр("ru='Необходимо авторизоваться в личном кабинете. Открыть личный кабинет?';en='Is necessary to log in to your account. Open private cabinet?'"), РежимДиалогаВопрос.ДаНет);          
		Отказ = Истина;  
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ПараметрыВнешнейСистемы = ТекущийОбъект.Параметры.Получить();
	
	Если ПараметрыВнешнейСистемы = Неопределено Тогда
		ПараметрыВнешнейСистемы = Новый Структура();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЭтоОблако 
		И Не ЗначениеЗаполнено(Константы.ВнешняяПубликацияАдрес.Получить()) Тогда
		
		АдресПубликации = "https://cloud.stoma1c.ru/app/" + Формат(ПараметрыСеанса.ОбластьДанныхЗначение, "ЧГ=");
		Константы.ВнешняяПубликацияАдрес.Установить(АдресПубликации);
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	СообщениеОбОшибке = ""; 
	
	ВнешняяСистема = РеквизитФормыВЗначение("Объект");
	
	// При дальнейшей обработке используется адрес API, который мог быть еще не сохранен в параметрах.
	СохраненныеПараметры = ВнешняяСистема.Параметры.Получить();
	СохраненныеПараметры = ?(ТипЗнч(СохраненныеПараметры) = Тип("Структура"), СохраненныеПараметры, Новый Структура);
	СохраненныеПараметры.Вставить("АдресAPI", ЭтотОбъект.АдресAPI);
	
	ВнешняяСистема.Параметры = Новый ХранилищеЗначения(СохраненныеПараметры);
	
	// создать (обновить) внешнюю систему в crm и ретрансляторе
	СоздатьВнешнююСистемуВ_CRM(СообщениеОбОшибке, ВнешняяСистема);
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОбОшибке,,,, Отказ);  
		Возврат;
		
	КонецЕсли;
	
	ОбработчикВебХука = "https://cloud.stoma1c.ru/api/hs/api/wallet/webhook?apikey=" + ВнешняяСистема.КлючПриложения; 
	
	Если Не ЗначениеЗаполнено(ИдВебХука) Тогда		
		
		// создаем вебхук
		Результат = Справочники.Карты.УстановитьВебХук(ВнешняяСистема, "ВсеСобытия", "*", ОбработчикВебХука);	
		
		Если Не Результат.Успешно Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки,,,, Отказ);	
			
		Иначе
			
			ЭтотОбъект.ИдВебХука = Результат.id;
			
			ДобавитьРеквизитВСтруктуру(ПараметрыВнешнейСистемы, "ИдВебХука", ЭтотОбъект.ИдВебХука);
			
		КонецЕсли;
		
	Иначе
		
		// обновляем вебхук
		Результат = Справочники.Карты.ОбновитьВебХук(ВнешняяСистема, ИдВебХука, ОбработчикВебХука);
		
		Если Не Результат.Успешно Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки,,,, Отказ);	
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.АдресAPI) Тогда
		ПараметрыВнешнейСистемы.Вставить("АдресAPI", ЭтотОбъект.АдресAPI);
	КонецЕсли;
	
	ТекущийОбъект.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы);
	
КонецПроцедуры

