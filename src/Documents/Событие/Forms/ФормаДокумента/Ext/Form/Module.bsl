	Элементы.ГруппаФормаКнопкаПрием.ЦветФона			 = ?(ПустойОбъект, ЦветФонаСерыйВторостепенный, ЦветФонаСерыйВторостепенный); // ЦветФонаСерыйВторостепенный, ЦветВажного
	Элементы.ФормаКнопкаВвестиПосещение.ЦветТекста		 = ?(ПустойОбъект, ЦветТекстаЧерный, ЦветТекстаЧерный);   // ЦветТекстаЧерный, ЦветФонаФормы
	
	Элементы.ГруппаФормаКнопкаПровестиИЗакрыть.ЦветФона	 = ?(ПустойОбъект, ЦветВажного, ЦветВажного);
	Элементы.ФормаКнопкаПровестиИЗакрыть.ЦветТекста		 = ?(ПустойОбъект, ЦветФонаФормы, ЦветФонаФормы);

