// Получить шаблон обследования 
//
Функция ШаблонОбследованияПациента()
	
	ШаблонСотрудникаПоУмолчанию = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Объект.Сотрудник, Объект.СтруктурнаяЕдиница , "ОсновнойШаблонОбследований");
	Если ЗначениеЗаполнено(ШаблонСотрудникаПоУмолчанию) Или ЭтоСтоматологическиеУслуги = Ложь Тогда 
		Возврат ШаблонСотрудникаПоУмолчанию;
	Иначе 
		Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
			
			Запрос       = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	ИСТИНА КАК РанееБылиПриемы,
			|	ПродажиОбороты.КоличествоОборот
			|ИЗ
			|	РегистрНакопления.Продажи.Обороты(, , , Контрагент = &Контрагент) КАК ПродажиОбороты";
			
			Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);					
			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				Возврат Справочники.ШаблоныОбследований.ПовторныйСтоматологическийОсмотр;
			Иначе	
				Возврат Справочники.ШаблоныОбследований.ПервичныйСтоматологическийОсмотр;
			КонецЕсли;
		Иначе
			Возврат Справочники.ШаблоныОбследований.ПервичныйСтоматологическийОсмотр;
		КонецЕсли;
	КонецЕсли;
	
