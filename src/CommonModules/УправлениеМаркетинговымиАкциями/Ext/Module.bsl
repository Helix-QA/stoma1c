	//	
	//	СуммаФактическогоРаспределения = 0;
	//	КоличествоФактическогоРаспределения = 0;
	//	Для каждого СтрокаСкидки Из ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки)) Цикл
	//		СтрокаСкидки.СуммаСкидки = ?(СуммаТоваровСтрокСкидки <> 0, Окр(СтрокаСкидки.Сумма * СуммаРаспределения / СуммаТоваровСтрокСкидки, 2, 1), 0);
	//		СтрокаСкидки.ЗначениеСкидкиНаценки = ?(СуммаТоваровСтрокСкидки <> 0, Окр(СтрокаСкидки.Сумма * КоличествоРаспределения / СуммаТоваровСтрокСкидки, 2, 1), 0);
	//		СуммаФактическогоРаспределения = СуммаФактическогоРаспределения + СтрокаСкидки.СуммаСкидки;
	//		КоличествоФактическогоРаспределения = КоличествоФактическогоРаспределения + СтрокаСкидки.ЗначениеСкидкиНаценки;			
	//	КонецЦикла;
	//	
	//	Если (СуммаРаспределения - СуммаФактическогоРаспределения) <> 0 Тогда
	//		МассивСтрокСкидок = ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", ЭлементСкидки));
	//		МассивСтрокСкидок[0].СуммаСкидки = МассивСтрокСкидок[0].СуммаСкидки + (СуммаРаспределения - СуммаФактическогоРаспределения);
	//	КонецЕсли;		
