	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура БанкКассаОтборПриИзменении(Элемент)
	
	Если ЭтаФорма.СчетКассаОтбор.Количество() > 0 Тогда
		ЭтаФорма.СчетКассаИспользование = Истина;
	Иначе
		ЭтаФорма.СчетКассаИспользование = Ложь;
	КонецЕсли;	
	
