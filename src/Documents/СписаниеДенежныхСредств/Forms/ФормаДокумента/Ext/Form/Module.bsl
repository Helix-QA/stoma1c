
#Область ОписаниеПеременных

&НаКлиенте
Перем ДоступностьКнопкиПечатьКМЗ; // Флаг для показа/скрытия печати ПМЗ 

&НаКлиенте
Перем ИскомыйКлиент;    

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы  
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РежимРаботыЕдинаяСеть = Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть; 
	// Если документ был создан на основании возврата получаем сумму сторнированного аванса
	Основание = Неопределено;
	Параметры.Свойство("Основание",Основание);
	Если ЗначениеЗаполнено(Основание) И ТипЗнч(Основание) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		СуммаСторнированныхАвансов = Основание.УчтенныеАвансы.Итог("СуммаАванса"); 
	КонецЕсли;
	ИспользоватьБезПодключенияОборудования 	= ?(ЗначениеЗаполнено(Объект.Касса), Объект.Касса.ИспользоватьБезПодключенияОборудования, Ложь);	
	ККТ                                     = Объект.Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;	
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	// УстановитьОтображениеЭлементовПереключателя(); 
	
	СоздатьЭлементыРасшифровкиПлатежа();
	
	Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Контрагент) 
		И ?(ТипЗнч(Объект.Контрагент) = Тип("СправочникСсылка.Контрагенты") 
		И Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Ложь, Истина);
		
КонецПроцедуры

&НаСервере
// Процедура, обработчик изменения видимости кнопок меню.
//
Процедура УстановитьОтображениеЭлементовПереключателя(ЭлементИмя = Неопределено)
	
	ВидыОпераций = Перечисления.ВидыОпераций;
	
	ОперацияБезТЧ = Объект.ВидОперации = ВидыОпераций.ВозвратСЛицевогоСчета Или Объект.ВидОперации = ВидыОпераций.СдачаНаличныхВБанк
	Или Объект.ВидОперации = ВидыОпераций.ВыдачаПодотчетнику Или Объект.ВидОперации = ВидыОпераций.ВозвратЗайма
	Или Объект.ВидОперации = ВидыОпераций.ВыплатаДивидендовУчредителю Или Объект.ВидОперации = ВидыОпераций.ВыбытиеВКассу;
	
	ОтобразитьДополнительно = ЭлементИмя = "_ГруппаДополнительно"; 
	ОтобразитьРасшифровку   = ЭлементИмя = "_ГруппаРасшифровка";
	ОтобразитьЗатраты       = ЭлементИмя = "_ГруппаЗатраты";
	
	Если ОперацияБезТЧ Тогда
		Элементы._Дополнительно.Видимость             = Истина; 
		Элементы.Дек_Дополнительно.Видимость          = Ложь;
		Элементы.ГруппаДополнительно.Видимость        = Не Элементы.ГруппаДополнительно.Видимость;
		Элементы._Дополнительно.ЦветТекста            = ?(Элементы.ГруппаДополнительно.Видимость, Новый Цвет(77, 77, 77), Новый Цвет(30, 144, 255)); 
		Элементы.Группа_Кнопки_Дополнительно.ЦветФона = ?(Элементы.ГруппаДополнительно.Видимость, Новый Цвет(242, 242, 242), Новый Цвет(255, 255, 255)); 
		
	ИначеЕсли Объект.ВидОперации = ВидыОпераций.ПрочееСписание Тогда
		
		Элементы._Затраты.Видимость                 = Не ОтобразитьЗатраты; 
		Элементы.Дек_Затраты.Видимость              = ОтобразитьЗатраты; 
		Элементы.ГруппаЗатраты.Видимость            = Не ОтобразитьДополнительно;
		Элементы._Расшифровка.Видимость             = Ложь;
		Элементы.Дек_Расшифровка.Видимость          = Ложь;   
		Элементы.ГруппаРасшифровкаПлатежа.Видимость = Ложь; 
		Элементы._Дополнительно.Видимость           = Не ОтобразитьДополнительно;
		Элементы.Дек_Дополнительно.Видимость        = ОтобразитьДополнительно; 
		Элементы.ГруппаДополнительно.Видимость      = Не ОтобразитьЗатраты;  
		
		Элементы.Группа_Кнопки_Затраты.ЦветФона		  = ?(ОтобразитьЗатраты, Новый Цвет(242, 242, 242), Новый Цвет(255, 255, 255));
		Элементы.Группа_Кнопки_Дополнительно.ЦветФона = ?(ОтобразитьДополнительно, Новый Цвет(242, 242, 242), Новый Цвет(255, 255, 255));
		
	Иначе
		Элементы.ГруппаЗатраты.Видимость	        = Ложь;
		Элементы.Дек_Затраты.Видимость	            = Ложь;
		Элементы._Затраты.Видимость	                = Ложь;
		Элементы._Расшифровка.Видимость             = Не ОтобразитьРасшифровку;
		Элементы.Дек_Расшифровка.Видимость          = ОтобразитьРасшифровку; 
		Элементы.ГруппаРасшифровкаПлатежа.Видимость = Не ОтобразитьДополнительно;
		Элементы._Дополнительно.Видимость           = Не ОтобразитьДополнительно; 
		Элементы.ГруппаДополнительно.Видимость      = Не ОтобразитьРасшифровку;
		Элементы.Дек_Дополнительно.Видимость        = ОтобразитьДополнительно; 
		
		Если Объект.ВидОперации = ВидыОпераций.ВозвратОплатыСтраховойКомпании Тогда
			Элементы.ГруппаРасшифровкаПлатежа.Видимость		 = Не ОтобразитьДополнительно;
			Элементы.ГруппаРасшифровкаДинамические.Видимость = Ложь;
		Иначе
			Элементы.ГруппаРасшифровкаПлатежа.Видимость		 = Ложь;
			Элементы.ГруппаРасшифровкаДинамические.Видимость = Не ОтобразитьДополнительно;
		КонецЕсли;
				
		Элементы.Группа_Кнопки_Расшифровка.ЦветФона	  = ?(ОтобразитьРасшифровку, Новый Цвет(242, 242, 242), Новый Цвет(255, 255, 255));
		Элементы.Группа_Кнопки_Дополнительно.ЦветФона = ?(ОтобразитьДополнительно, Новый Цвет(242, 242, 242), Новый Цвет(255, 255, 255));
		
	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
// Процедура - обработчик события формы "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
		
	// Если при возврате был сторнирован аванс сообщить об этом
	Если СуммаСторнированныхАвансов > 0 Тогда
		ПоказатьПредупреждение(,"При возврате был учтен аванс на сумму " + СуммаСторнированныхАвансов + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти() + ", остаток к возврату " + Объект.СуммаДокумента + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти()+
		Символы.ПС +"Изменить сумму учтенного аванса можно на соответсвующей закладке документа возврата."); 
		// Если аванс покрыл всю сумму отменить создание документа
		Если Объект.СуммаДокумента = 0 Тогда
			Отказ = истина;
		КонецЕсли;	
	КонецЕсли;
	УстановитьВидимость();
	ВидимостькомандыПечатьКМ3();
	
	// ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
	НастройкаШириныЭлементовФормы();
		
КонецПроцедуры

&НаКлиенте
// После записи формы на клиенте 
//
Процедура ПослеЗаписи(ПараметрыЗаписи, ДопПараметрыОтвета = Неопределено) Экспорт
	
	// Обработка рез. вопроса, смотри код ниже!!!
	Если ТипЗнч(ПараметрыЗаписи) = Тип("КодВозвратаДиалога") И ПараметрыЗаписи = КодВозвратаДиалога.Да Тогда
		РазрешенаОтправкаКомандыНаФР = Истина;
	ИначеЕсли ТипЗнч(ПараметрыЗаписи) = Тип("КодВозвратаДиалога") И ПараметрыЗаписи = КодВозвратаДиалога.Нет Тогда
		РазрешенаОтправкаКомандыНаФР = Ложь;
	КонецЕсли;
	
	// Проверка необходимости печати чека выемки
	Если Объект.Проведен
		И Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия")
		И НЕ ЗначениеЗаполнено(Объект.НомерЧекаККМ)
		И РозничныеПродажи.ПроверитьИспользованиеФРвКассе(Объект.Касса) = Истина Тогда
		
		Если РазрешенаОтправкаКомандыНаФР = Неопределено Тогда
			Оповещение = Новый ОписаниеОповещения("ПослеЗаписи", ЭтаФорма);
			ПоказатьВопрос(Оповещение,"Необходимо выполнить команду выемки на фискальном регистраторе. Выполнить ?",РежимДиалогаВопрос.ДаНет,,,"Внимание");
			Возврат;
			
		ИначеЕсли РазрешенаОтправкаКомандыНаФР = Истина Тогда
			
			// Выполнить печать чека выемки
			НапечататьЧек(Неопределено);
			ЭтаФорма.ОбновитьОтображениеДанных();
			
		КонецЕсли; 
	КонецЕсли;
	
	УстановитьВидимость();
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета") Тогда
		Оповестить("ПРОВЕДЕН_ВОЗВРАТ_С_ЛИЦЕВОГО_СЧЕТА");
	КонецЕсли;  

	Оповестить("ПОСТУПЛЕНИЕ_СПИСАНИЕ_ИНКАССАЦИЯ");
	// Оповестить динамические списки
	МассивТипов = Новый Массив;
	Для Каждого СтрокаТ ИЗ Объект.РасшифровкаПлатежа Цикл
		Если ЗначениеЗаполнено(СтрокаТ.ДокументОснования) И МассивТипов.Найти(ТипЗнч(СтрокаТ.ДокументОснования)) = Неопределено Тогда
			ОповеститьОбИзменении(СтрокаТ.ДокументОснования);
			МассивТипов.Добавить(ТипЗнч(СтрокаТ.ДокументОснования));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Перед записью формы на клиенте
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	// Проверка достстаочности средст на лицевом счете
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
		// Если это лицевой счет
		Если (Объект.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет") 
			ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета")) Тогда
			// Получаем остаток лицевого счета
			Если РежимРаботыЕдинаяСеть Тогда
				ОстаткоНаЛС = ДенежныеСредстваСервер.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент,Объект.Дата,Объект.Ссылка,,Объект.ЛицевойСчетКонтрагента,Истина);
			Иначе
				ОстаткоНаЛС = ДенежныеСредстваСервер.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент,Объект.Дата,Объект.Ссылка,Объект.СтруктурнаяЕдиница,Объект.ЛицевойСчетКонтрагента,Истина);
			КонецЕсли;	 
			Если ОстаткоНаЛС < Объект.СуммаДокумента Тогда 
				ПоказатьПредупреждение(,"Остаток лицевого счета на " + Формат(ТекущаяДата(), "ДФ='дд:ММ:гггг ЧЧ:мм'") + " составляет " 
								+ ?(ОстаткоНаЛС = 0, "0,00", Формат(ОстаткоНаЛС, "ЧДЦ=2")) 
								+ СокрП(ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти()) 
								+ ", чего не хватает для списания " + Формат(Объект.СуммаДокумента, "ЧДЦ=2") 
								+ СокрП(ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти()));  
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			// Получаем разрешенный процент списания со счета
			РазрешенныйПроцентСписания = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.ЛицевойСчетКонтрагента,"ПроцентОграниченияСуммыСписанияСоСчета");
			// Если ограничений нет
			Если ЗначениеЗаполнено(РазрешенныйПроцентСписания) Тогда
				РазрешеннаяСуммаСписания = ПолучитьСуммуДокументовОснования() * (РазрешенныйПроцентСписания / 100);
				Если РазрешеннаяСуммаСписания < Объект.СуммаДокумента Тогда
					ПоказатьПредупреждение(,"Счет ограничен суммой списания, " + РазрешенныйПроцентСписания +"% от суммы оплаты. Разрешено списать: " + РазрешеннаяСуммаСписания + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
					Отказ = Истина;
					Возврат;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
		Если Объект.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные") Тогда
			 ОстатокДС =  ДенежныеСредстваСервер.ПолучитьОстаткоДенежныхСредств(Объект.Дата,Объект.Касса,Объект.Ссылка);
			 Если ОстатокДС < Объект.СуммаДокумента Тогда
				  Отказ = Истина;
                  ПоказатьПредупреждение(,"Сумма документа больше остатка денежных средств в кассе. Остаток: " + ОстатокДС + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
			  КонецЕсли;
		ИначеЕсли Объект.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные") Тогда
			 ОстатокДС =  ДенежныеСредстваСервер.ПолучитьОстаткоДенежныхСредств(Объект.Дата,Объект.БанковскийСчет,Объект.Ссылка);
			 Если ОстатокДС < Объект.СуммаДокумента Тогда
				  Отказ = Истина;
                  ПоказатьПредупреждение(,"Сумма документа больше остатка денежных средств на счете. Остаток: " + ОстатокДС + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
			 КонецЕсли;
		КонецЕсли;
	КонецЕсли;  
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиЭлементовФормы

 &НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

 &НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "ВидОперации".
//
Процедура ВидОперацииПриИзменении(Элемент)
	
	ВидОперацииПриИзмененииСервер();	
	ВидимостькомандыПечатьКМ3();
	// ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	НастройкаШириныЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения типа денежных средств
//
Процедура ТипДенежныхСредствПриИзменении(Элемент)	
	
	УстановитьВидимость();	
	// ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	НастройкаШириныЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля "ВидОперации".
//
Процедура ВидОперацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекущаяОперация = Объект.ВидОперации;
КонецПроцедуры

&НаСервере
// Процедура - обработчик события на сервере "ПриИзменении" поля "ВидОперации".
//
Процедура ВидОперацииПриИзмененииСервер()
		
	Если ТекущаяОперация <> Объект.ВидОперации Тогда		
		Если Объект.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику Тогда			
			Объект.БанковскийСчет              = Неопределено;
			Объект.БанковскийСчетКонтрагента   = Неопределено;
			Объект.Касса	                   = Неопределено;		
			Если НЕ (Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет) Тогда
				Объект.Контрагент = Неопределено;
			КонецЕсли;
		КонецЕсли;
		Объект.Статья = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(Объект.ВидОперации);
