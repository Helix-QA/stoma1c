										СтруктураВидаЛицевогоСчета = ПолучитьВидЛицевогоСчета(СтрокаВыборкаПоОплатам.ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе);
										ДополнительныеПараметрыСоздания.Вставить("ВидЛицевогоСчетаКонтрагента", СтруктураВидаЛицевогоСчета.Ссылка);										
									ИначеЕсли СтрокаВыборкаПоОплатам.ВидОперации = 8 И СтрокаВыборкаПоОплатам.ТипОплаты = 7 Тогда 
										СтруктураВидаЛицевогоСчета = ПолучитьВидЛицевогоСчета(СтрокаВыборкаПоОплатам.ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе);
										ДополнительныеПараметрыСоздания.Вставить("ВидЛицевогоСчетаКонтрагента", СтруктураВидаЛицевогоСчета.Ссылка);											
									Иначе    
										ВернутьЛицевойСчет = Ложь;
										ДополнительныеПараметрыСоздания.Вставить("ВидЛицевогоСчетаКонтрагента", Неопределено);											
									КонецЕсли;
									// Получаем ЛС
									Если ВернутьЛицевойСчет = Истина Тогда 
										СтруктураПоиска = Новый Структура;
										Если НЕ ЗначениеЗаполнено(СтрокаВыборкаПоОплатам.НомерЛС) Тогда 
											СтруктураПоиска.Вставить("ВладелецЛицевогоСчета", ВыборкаПоКлиентам.Клиент);
										Иначе 
											СтруктураПоиска.Вставить("КодСинхронизации"		, СтрокаВыборкаПоОплатам.НомерЛС);
											СтруктураПоиска.Вставить("ПрефиксСинхронизации"	, СтрокаВыборкаПоОплатам.ПрефиксСинхронизации);
										КонецЕсли;
										Если ЗначениеЗаполнено(СтруктураВидаЛицевогоСчета.Ссылка) Тогда 
											СтруктураПоиска.Вставить("ВидЛицевогоСчета", СтруктураВидаЛицевогоСчета.Ссылка);
										КонецЕсли;
										МассивСтрокЛС = ТаблицаЛицевыхСчетовВБазе.НайтиСтроки(СтруктураПоиска);
										Если НЕ МассивСтрокЛС.Количество() = 0 Тогда
											ДополнительныеПараметрыСоздания.Вставить("ЛицевойСчетКонтрагента", МассивСтрокЛС[0].Ссылка);
											ДополнительныеПараметрыСоздания.Вставить("ВладелецЛицевогоСчета", МассивСтрокЛС[0].ВладелецЛицевогоСчета);
										Иначе 
											ДополнительныеПараметрыСоздания.Вставить("ЛицевойСчетКонтрагента", Неопределено);
											ДополнительныеПараметрыСоздания.Вставить("ВладелецЛицевогоСчета", Неопределено);											
										КонецЕсли;	
									Иначе 
										ДополнительныеПараметрыСоздания.Вставить("ЛицевойСчетКонтрагента", Неопределено);
										ДополнительныеПараметрыСоздания.Вставить("ВладелецЛицевогоСчета", Неопределено);										
									КонецЕсли;	
									// Получаем оператора оплаты
									ОператорОплатыСтрокой 		= СокрЛП(СтрокаВыборкаПоОплатам.ОператорОплаты);
									ДополнительныеПараметрыСоздания.Вставить("ОператорОплаты", Справочники.Сотрудники.ПустаяСсылка());																				
									Если ОператорОплатыСтрокой <> "" Тогда
										СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.Найти(ОператорОплатыСтрокой, "Наименование");
										Если НЕ СтрокаМенеджерСотрудник = Неопределено Тогда
											ДополнительныеПараметрыСоздания.Вставить("ОператорОплаты", СтрокаМенеджерСотрудник.Ссылка);											
										КонецЕсли;
									КонецЕсли;
									// Создаем документ
									ПкоРко = СоздатьДокументОплаты(СтрокаВыборкаПоОплатам, ДополнительныеПараметрыСоздания, ПараметрыЗадания.ПараметрыЗагрузки, ТекстовыйНакопитель);
									// СуммаОплатыПКО 	= ДополнительныеПараметрыСоздания.СуммаОплатыПКО;
									// СуммаОплатыРКО 	= ДополнительныеПараметрыСоздания.СуммаОплатыРКО;									
									// ДатаОплатыРКО 	= ДополнительныеПараметрыСоздания.ДатаОплатыРКО;																		
								КонецЕсли;
							Иначе
								Если ЗначениеЗаполнено(СтрокаВыборкаПоОплатам.ПкоСсылка) Тогда
									ПкоРко = СтрокаВыборкаПоОплатам.ПкоСсылка.ПолучитьОбъект();	
									ПкоРко.УстановитьПометкуУдаления(Истина);								
								ИначеЕсли ЗначениеЗаполнено(СтрокаВыборкаПоОплатам.РкоСсылка) Тогда
									ПкоРко = СтрокаВыборкаПоОплатам.РкоСсылка.ПолучитьОбъект();	
									ПкоРко.УстановитьПометкуУдаления(Истина);	
								КонецЕсли;	
							КонецЕсли;
							
							// Если СуммаОплатыПКО > 0
							//	И СуммаОплатыРКО > 0
							//	И ЗначениеЗаполнено(ДатаОплатыРКО)
							//	И ДатаОплатыРКО < ЧленствоОбъект.СрокДействияДатой
							//	И ДатаОплатыРКО > ЧленствоОбъект.ДатаРучнойАктивации
							//	И ЗначениеЗаполнено(ЧленствоОбъект.ДатаРучнойАктивации)
							//	И (ДокументРеализация.СуммаДокумента + СуммаОплатыРКО) = СуммаОплатыПКО Тогда
							//	
							//	ЧленствоОбъект.СрокДействияДатой 	= ДатаОплатыРКО;
							//	ЧленствоОбъект.СрокДействияТип 		= Перечисления.Периодичность.День;
							//	ЧленствоОбъект.СрокДействия 		= Цел((ДатаОплатыРКО - НачалоДня(ЧленствоОбъект.ДатаРучнойАктивации)) / 86400);
							//	
							//	Попытка
							//		ЗаписатьДокумент(ЧленствоОбъект, , , Истина);
							//	Исключение
							//		
							//	КонецПопытки;	
							// КонецЕсли;							
							
	#КонецОбласти
	
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				
	#Область Создание_рассрочки
				
				// РАССРОЧКА КОНТРАКТА//
				Если ТаблицаРассрочка.Количество() > 0 Тогда
					Если ТаблицаРассрочка.Итог("СуммаПлатежаПлан") < СтрокаВыборкаПоКонтрактам.СуммаКонтракта Тогда
						НСР 					= ТаблицаРассрочка.Добавить();  
						НСР.ДатаПлатежаПлан 	= СтрокаВыборкаПоКонтрактам.ДатаПродажи;
						НСР.СуммаПлатежаПлан 	= СтрокаВыборкаПоКонтрактам.СуммаКонтракта - ТаблицаРассрочка.Итог("СуммаПлатежаПлан");						
					КонецЕсли;	
					НаборЗаписей                               = РегистрыСведений.СхемыРассрочек.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Основание.Значение      = ДокументРеализация.Ссылка;
					НаборЗаписей.Отбор.Основание.Использование = Истина;
					ДатаПредыдущегоПлатежа = Дата('2001.01.01 01:01:01'); 
					
					ДатыПлатежа 	= Новый СписокЗначений;
					НомерПлатежа 	= 1;
					Для Каждого СтрокаРассрочка ИЗ ТаблицаРассрочка Цикл
						Если СтрокаРассрочка.СуммаПлатежаПлан > 0 Тогда
							НоваяЗапись                = НаборЗаписей.Добавить();
							НоваяЗапись.Период         = СтрокаВыборкаПоКонтрактам.ДатаПродажи;
							НоваяЗапись.ДатаПлатежа    = ?(ДатыПлатежа.НайтиПоЗначению(СтрокаРассрочка.ДатаПлатежаПлан) <> Неопределено, СтрокаРассрочка.ДатаПлатежаПлан + 60*60*24*НомерПлатежа, СтрокаРассрочка.ДатаПлатежаПлан);
							НоваяЗапись.Основание      = ДокументРеализация.Ссылка;
							НоваяЗапись.СуммаПлатежа   = СтрокаРассрочка.СуммаПлатежаПлан;
							НоваяЗапись.ПроцентПлатежа = (СтрокаРассрочка.СуммаПлатежаПлан * 100) / ТаблицаРассрочка.Итог("СуммаПлатежаПлан");
							ДатыПлатежа.Добавить(СтрокаРассрочка.ДатаПлатежаПлан);
							НомерПлатежа = НомерПлатежа + 1;
						КонецЕсли;
					КонецЦикла;
					
					// Корректировка отклонения
					СуммаПрц = НаборЗаписей.Итог("ПроцентПлатежа");
					Если СуммаПрц <> 100 Тогда
						Разница 				= СуммаПрц - 100;
						КСтрока 				= НаборЗаписей[НаборЗаписей.Количество() - 1];
						КСтрока.ПроцентПлатежа 	= КСтрока.ПроцентПлатежа - Разница;
					КонецЕсли;
					
					Если НаборЗаписей.Количество() > 0 Тогда
						Попытка
							НаборЗаписей.ОбменДанными.Загрузка 			= Истина;
							НаборЗаписей.Записать(Истина);
							ДокументРеализация 							= ДокументРеализация.Ссылка.ПолучитьОбъект();
							ДокументРеализация.ОплачиваетсяВРассрочку 	= Истина;
							ДокументРеализация.ОбменДанными.Загрузка 	= Истина;
							ДокументРеализация.Записать(РежимЗаписиДокумента.Запись);
						Исключение
							// Запись в лог
							ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка рассрочки: ';en= 'Installment error: '") + Строка(ДокументРеализация.Ссылка) + Символы.ПС + ОписаниеОшибки());													
						КонецПопытки;
					КонецЕсли;
					ТаблицаРассрочка.Очистить();
				Иначе 
					НаборЗаписей 								= РегистрыСведений.СхемыРассрочек.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Основание.Значение 		= ДокументРеализация.Ссылка;
					НаборЗаписей.Отбор.Основание.Использование 	= Истина;
					НаборЗаписей.ОбменДанными.Загрузка 			= Истина;
					НаборЗаписей.Записать(Истина);
					
				КонецЕсли;
				
	#КонецОбласти
				
			КонецЦикла; // ВыборкаПоКонтрактам
			
			// Менеджер клиента из последнего контракта
			Если ЗначениеЗаполнено(Менеджер) И НЕ ЭтоОбновлениеЧленства Тогда
				КлиентОбъект 						= ВыборкаПоКлиентам.Клиент.ПолучитьОбъект();
				КлиентОбъект.Менеджер 				= Менеджер.Ссылка;
				КлиентОбъект.ОбменДанными.Загрузка 	= Истина;																
				Попытка
					КлиентОбъект.Записать();
				Исключение
					// Запись в лог						
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка при записи клиента! Код синхронизации: %2 Клиент: %3 %1 %4';en='%1 Mistake at records client! Sync code: %2 Client: %3 %1 %4'"), Символы.ПС, Строка(КлиентОбъект.КодСинхронизации), Строка(ВыборкаПоКлиентам.Клиент), ОписаниеОшибки()));						
				КонецПопытки;	
				
			КонецЕсли;
			
		Иначе
			//// Запись в лог
			// ЗаписатьВЖурнал("Загрузка.Ошибка","Клиент не найден! ID: " + Строка(ВыборкаПоКлиентам.ИДКлиента));
		КонецЕсли;
		Если СообщилиПрогресс = Ложь Тогда 
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеКонтракта			= "";
			Прогресс 						= Цел(100 * СозданоКонтрактов / ОбщееКоличествоКонтрактов);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по контрактам...';en='Saving data on contracts...'") + Символы.Таб + НСтр("ru=' Осталось: ';en='Left:'") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКонтракта, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;		
	КонецЦикла; // ВыборкаПоКлиентам
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда				
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаКарт.Очистить();								ТаблицаКарт 					= Неопределено;
	ТаблицаКартВБазе.Очистить(); 						ТаблицаКартВБазе 				= Неопределено;
	ТаблицаСотрудников.Очистить(); 						ТаблицаСотрудников 				= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить();					ТаблицаСотрудниковВБазе 		= Неопределено;
	ТаблицаВидовЛицевыхСчетовВБазе.Очистить(); 			ТаблицаВидовЛицевыхСчетовВБазе 	= Неопределено;
	ТаблицаЛицевыхСчетов.Очистить(); 					ТаблицаЛицевыхСчетов 			= Неопределено;
	ТаблицаЛицевыхСчетовВБазе.Очистить(); 				ТаблицаЛицевыхСчетовВБазе 		= Неопределено;
									 					ВыборкаПоКлиентам 				= Неопределено;
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить контракты в фоне access многопоточно
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьКонтрактыВФонеAccessМногопоточно(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Кешируем данные
	Менеджер 											= Справочники.Сотрудники.ПустаяСсылка();
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	ВидКартыШтриховая 									= Перечисления.ВидыКарт.Штриховая;	
	ВидКарты_Магнитная 									= Перечисления.ВидыКарт.Магнитная;		
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	ТипДенежныхСредств_Наличные 						= Перечисления.ТипыДенежныхСредств.Наличные;
	СтруктураВидовДДС 									= Новый Структура;
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ОплатаОтКлиенат"		, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ОплатаОтКлиента));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ВзносНаЛицевойСчет"	, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВзносНаЛицевойСчет));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ПрочееСписание"		, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ПрочееСписание));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ВозвратОплатыКлиенту"	, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ПрочееПоступление"	, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ПрочееПоступление));
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Контракты 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Контракты;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Контракты, "Таблица_Контракты");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Таблица_Контракты.Организация КАК Организация
	               |ИЗ
