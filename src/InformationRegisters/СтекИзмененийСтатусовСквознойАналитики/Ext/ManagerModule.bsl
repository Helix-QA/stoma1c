
#Область СлужебныеПроцедурыИФункции

// Процедура, добавляет запись в регистр сведений;
//
Процедура ДобавитьЗапись(Объект, Статус, ВнешняяСистема) Экспорт 
	
	МенеджерЗаписи = РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.СоздатьМенеджерЗаписи();
	
	МенеджерЗаписи.Объект         = Объект;
	МенеджерЗаписи.ВнешняяСистема = ВнешняяСистема;
	МенеджерЗаписи.Статус         = Статус;
	МенеджерЗаписи.ДатаИзменения  = ТекущаяДатаСеанса();
	Если ТипЗнч(Объект) = Тип("СправочникСсылка.Сделки") Тогда
		МенеджерЗаписи.ЭтапСделки     = Объект.ЭтапСделки;
	КонецЕсли;
	
	Попытка
		МенеджерЗаписи.Записать(Истина);
	Исключение		
	КонецПопытки;
	
КонецПроцедуры

// Функция, возвращает список статусов сквозной аналитики.
//
Функция ПолучитьСписокССА(ТипВнешнейСистемы = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтекИзмененийСтатусовСквознойАналитики.Объект КАК Объект,
	|	СтекИзмененийСтатусовСквознойАналитики.ВнешняяСистема КАК ВнешняяСистема,
	|	СтекИзмененийСтатусовСквознойАналитики.Статус КАК Статус,
	|	СтекИзмененийСтатусовСквознойАналитики.ЭтапСделки КАК ЭтапСделки,
	|	СтекИзмененийСтатусовСквознойАналитики.ДатаИзменения КАК ДатаИзменения
	|ИЗ
	|	РегистрСведений.СтекИзмененийСтатусовСквознойАналитики КАК СтекИзмененийСтатусовСквознойАналитики
	|ГДЕ
	|	ИСТИНА
	|	И &УсловиеВнешнейСистемы
	|УПОРЯДОЧИТЬ ПО
	|	ДатаИзменения");
	
	Если ЗначениеЗаполнено(ТипВнешнейСистемы) Тогда 	
		
		УсловиеВнешнейСистемы = "СтекИзмененийСтатусовСквознойАналитики.ВнешняяСистема.ТипВнешнейСистемы = &ТипВнешнейСистемы";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВнешнейСистемы", УсловиеВнешнейСистемы);
		
		Запрос.УстановитьПараметр("ТипВнешнейСистемы", ТипВнешнейСистемы);	
		
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеВнешнейСистемы", "");		
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выгрузить();
		
	Возврат Результат;
	
КонецФункции

// Процедура, удаляет запись из регистра.
//
Процедура УдалитьЗаписьПоЗаявке(Объект, ВнешняяСистема, Статус = Неопределено) Экспорт
	
	МенеджерЗаписи = РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.СоздатьМенеджерЗаписи();
	
	МенеджерЗаписи.Объект = Объект;
	МенеджерЗаписи.ВнешняяСистема = ВнешняяСистема;
	Если Статус <> Неопределено Тогда
		МенеджерЗаписи.Статус = Статус;
	КонецЕсли;
	
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.Удалить();
	
КонецПроцедуры	

// Функция, возвращает статус объекта по ссылке (заявка или сделка).
//
Функция ВернутьСтатусОбъектаПоСсылке(Ссылка) Экспорт
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СтекИзмененийСтатусовСквознойАналитики.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.СтекИзмененийСтатусовСквознойАналитики КАК СтекИзмененийСтатусовСквознойАналитики
	|ГДЕ
	|	СтекИзмененийСтатусовСквознойАналитики.Объект = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Статус, Неопределено);
		
КонецФункции

#КонецОбласти