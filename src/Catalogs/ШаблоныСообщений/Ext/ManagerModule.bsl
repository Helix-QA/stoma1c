			ИначеЕсли ПараметрЗадача = "НаименованиеКонтрагента" Тогда
				РезультатЗадача = "{ФИОПациента}";
			ИначеЕсли ПараметрЗадача = "{ДатаРожденияПациента}" Тогда
				РезультатЗадача = "{ДатаРожденияПациента}"; 
			ИначеЕсли ПараметрЗадача = "СтруктурнаяЕдиницаПоЛистуОжидания"	Тогда
				РезультатЗадача = "{КлиникаПоЛистуОжидания}";
			ИначеЕсли ПараметрЗадача = "СтруктурнаяЕдиницаЗаписи" Тогда
				РезультатЗадача = "{КлиникаЗаписи}"; 
			ИначеЕсли ПараметрЗадача = "СтруктурнаяЕдиницаПриема" Тогда
				РезультатЗадача = "{КлиникаПриема}";  
			Иначе 
				РезультатЗадача = "{" + ПараметрЗадача + "}";
			КонецЕсли;
			
			Если РезультатЗадача <> Неопределено Тогда
				ШаблонСообщения.ЗадачаОписание = СтрЗаменить(ШаблонСообщения.ЗадачаОписание, "{" + ПараметрЗадача + "}", РезультатЗадача);
			КонецЕсли; 		
		КонецЦикла;
		
		Для Каждого ПараметрПисьма Из МассивПараметровПисьма Цикл
			Если ПараметрПисьма = "ПолныйАдресСтруктурнойЕдиницы" Тогда
				РезультатПисьмо = "{ПолныйАдресКлиники}";
			ИначеЕсли ПараметрПисьма = "КороткийАдресСтруктурнойЕдиницы" Тогда
				РезультатПисьмо = "{КороткийАдресКлиники}";
			ИначеЕсли ПараметрПисьма = "СайтСтруктурнойЕдиницы" Тогда
				РезультатПисьмо = "{СайтКлиники}";  
			ИначеЕсли ПараметрПисьма = "ФамилияКонтрагента" Тогда
				РезультатПисьмо = "{ФамилияПациента}";                             
			ИначеЕсли ПараметрПисьма = "ИмяКонтрагента" Тогда
				РезультатПисьмо = "{ИмяПациента}";                               
			ИначеЕсли ПараметрПисьма = "ОтчествоКонтрагента" Тогда
				РезультатПисьмо = "{ОтчествоПациента}";
			ИначеЕсли ПараметрПисьма = "НаименованиеКонтрагента" Тогда
				РезультатПисьмо = "{ФИОПациента}";
			ИначеЕсли ПараметрПисьма = "{ДатаРожденияПациента}" Тогда
				РезультатПисьмо = "{ДатаРожденияПациента}"; 
			ИначеЕсли ПараметрПисьма = "СтруктурнаяЕдиницаПоЛистуОжидания"	Тогда
				РезультатПисьмо = "{КлиникаПоЛистуОжидания}";
			ИначеЕсли ПараметрПисьма = "СтруктурнаяЕдиницаЗаписи" Тогда
