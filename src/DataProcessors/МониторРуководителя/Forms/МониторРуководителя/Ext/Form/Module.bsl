// Процедура - Обновить виджет загрузка врачей.
//
// Параметры:
//  ДанныеЗагрузкиВрачей - 	 - 
//
Процедура ОбновитьВиджетЗагрузкаВрачей(ДанныеЗагрузкиВрачей)
	
	#Область ____________ВиджетЗагрузкаВрачей____________
	
	Если ДанныеЗагрузкиВрачей = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Шапка
	Выборка = ДанныеЗагрузкиВрачей.ДанныеЗагрузкиВрачейОбщий.Выбрать(); 
	
	Процент = ?(Выборка.Следующий(), Выборка.Процент, 0);
	
	Элементы.ДекорацияЗагрузкаВрачейПроцент.Заголовок = Строка(Процент) + "%";   
	
	Если ОтображатьСравненияСПредыдущимПериодом И Процент <> 0 Тогда
		
		Выборка = ДанныеЗагрузкиВрачей.ДанныеЗагрузкиВрачейОбщийПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			ПроцентВчера = Выборка.Процент;
		Иначе
			ПроцентВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(ПроцентВчера = 0, 100, (Процент - ПроцентВчера) / ПроцентВчера * 100);
		Элементы.ДанныеЗагрузкаВрачейСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеЗагрузкаВрачейПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеЗагрузкаВрачейСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеЗагрузкаВрачейПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеЗагрузкаВрачей.Видимость = Истина;
	Иначе
		Элементы.ДанныеЗагрузкаВрачей.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
				
	ТаблицаРезультат = ДанныеЗагрузкиВрачей.ДанныеЗагрузкиВрачей.Выгрузить();
	ТаблицаРезультат.Сортировать("ПроцентЗагрузки Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаЗагрузкаВрачей.Обновление = Ложь;
	ДиаграммаЗагрузкаВрачей.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
				
		СерияДиаграммы 	= ДиаграммаЗагрузкаВрачей.Серии.Добавить("Загрузка врача");
			
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
			
			Точка = ДиаграммаЗагрузкаВрачей.Точки.Добавить();

			ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "Без сотрудника");	
			
			Точка.Текст				= ПредставлениеСотрудник;
			Точка.Значение			= СтрокаТЗ.ПроцентЗагрузки;	
			
			ДиаграммаЗагрузкаВрачей.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.ПроцентЗагрузки);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаЗагрузкаВрачей, ЕстьДанныеДляОтображения);	
	ДиаграммаЗагрузкаВрачей.Обновление = Истина;
	
	#КонецОбласти

КонецПроцедуры

&НаСервере 
// Процедура - Обновить виджет загрузка врачей.
//
// Параметры:
//  ДанныеЗагрузкиВрачей - 	 - 
//
Процедура ОбновитьВиджетСтоимостьЧасаВрача(ДанныеВиджета)
	
	#Область ____________ВиджетЗагрузкаВрачей____________
	
	Если ДанныеВиджета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Валюта 		= ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	
	// Шапка
	Выборка = ДанныеВиджета.ДанныеСредняяСтоимостьОдногоЧаса.Выбрать(); 
	
	Стоимость = ?(Выборка.Следующий(), Выборка.СредняяСтоимостьЧасаСотрудника, 0);
	
	Элементы.ДекорацияЧасаВрачей.Заголовок = СтрШаблон("%1 %2", Стоимость, Валюта);   
	    
	Если ОтображатьСравненияСПредыдущимПериодом И Стоимость <> 0 Тогда
		
		Выборка = ДанныеВиджета.ДанныеСредняяСтоимостьОдногоЧасаПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			СтоимостьВчера = Выборка.СредняяСтоимостьЧасаСотрудника;
		Иначе
			СтоимостьВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(СтоимостьВчера = 0, 100, (Стоимость - СтоимостьВчера) / СтоимостьВчера * 100);
		Элементы.ДанныеСтоимостьЧасаВрачейСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеСтоимостьЧасаВрачейПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + " " + "%";
		Элементы.ДанныеСтоимостьЧасаВрачейСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеСтоимостьЧасаВрачейПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеСтоимостьЧасаВрачей.Видимость = Истина;
	Иначе
		Элементы.ДанныеСтоимостьЧасаВрачей.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
				
	ТаблицаРезальтат = ДанныеВиджета.ДанныеСтоимостьОдногоЧасаПоВрачам.Выгрузить();
	ТаблицаРезальтат.Сортировать("Сумма Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезальтат.Количество() > 0;
	
	ДиаграммаСтоимостьЧасаВрачей.Обновление = Ложь;
	ДиаграммаСтоимостьЧасаВрачей.Очистить();  
	
	ДиаграммаСтоимостьЧасаВрачей.ФорматЗначенийВПодписях = СтрШаблон("ЧФ='Ч %1'", Валюта); 
	
	Если ЕстьДанныеДляОтображения Тогда 
				
		СерияДиаграммы 	= ДиаграммаСтоимостьЧасаВрачей.Серии.Добавить("Стоимость часа");
		
		МаксимальноеЗначение = 0;
		
		Для Каждого СтрокаТЗ Из ТаблицаРезальтат Цикл
			
			Точка = ДиаграммаСтоимостьЧасаВрачей.Точки.Добавить();

			ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "Без сотрудника");	
			
			Точка.Текст				= ПредставлениеСотрудник;
			Точка.Значение			= СтрокаТЗ.Сумма;	
			
			ДиаграммаСтоимостьЧасаВрачей.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Сумма);
			
			МаксимальноеЗначение = Макс(МаксимальноеЗначение, СтрокаТЗ.Сумма); 
		КонецЦикла;	
		    ДиаграммаСтоимостьЧасаВрачей.ОсьЗначений.МаксимальноеЗначение = МаксимальноеЗначение; 
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаСтоимостьЧасаВрачей, ЕстьДанныеДляОтображения);	
	ДиаграммаСтоимостьЧасаВрачей.Обновление = Истина;
	
	#КонецОбласти

КонецПроцедуры

&НаСервере
// Процедура - Обновить виджет коммуникации.
//
// Параметры:
//  ДанныеКомуникаци - 	 - 
//
Процедура ОбновитьВиджетКоммуникации(ДанныеКомуникаци)
	
	Если ДанныеКомуникаци = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	#Область ____________ДанныеТелефонии____________
	
	Выборка = ДанныеКомуникаци.ДанныеТелефонииШапка.Выбрать();
	
	Если Выборка.следующий() Тогда
		Входящие 	= Выборка.Входящий;
		Исходящие 	= Выборка.Исходящий; 
		Пропущенные = Выборка.Пропущен;
	КонецЕсли;
	
	Элементы.КоличествоВходящихКнопка.Заголовок		= ?(ЗначениеЗаполнено(Входящие)		, Входящие		, 0);
	Элементы.КоличествоИсходящихКнопка.Заголовок 	= ?(ЗначениеЗаполнено(Исходящие)	, Исходящие		, 0); 
	Элементы.КоличествоПропущенныхКнопка.Заголовок 	= ?(ЗначениеЗаполнено(Пропущенные)	, Пропущенные	, 0);
	
	ДанныеЗвонков = ДанныеКомуникаци.ДанныеТелефонииПредыдущий.Выгрузить();

	Если ОтображатьСравненияСПредыдущимПериодом И ЗначениеЗаполнено(Входящие) Тогда
			
		КоличествоВходящих = ?(ЗначениеЗаполнено(ДанныеЗвонков) И ЗначениеЗаполнено(ДанныеЗвонков[0].Входящий), ДанныеЗвонков[0].Входящий, 0);
			
		РазницаПроцент = ?(КоличествоВходящих = 0, 100, (Входящие - КоличествоВходящих) / КоличествоВходящих * 100);
		Элементы.ДанныеВходящиеСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеВходящиеПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеВходящиеСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеВходящиеПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ГруппаВходящиеПредыдущий.Видимость = Истина;
	Иначе
		Элементы.ГруппаВходящиеПредыдущий.Видимость = Ложь;
	КонецЕсли; 
	
	Если ОтображатьСравненияСПредыдущимПериодом И ЗначениеЗаполнено(Исходящие) Тогда
			
		КоличествоИсходящих = ?(ЗначениеЗаполнено(ДанныеЗвонков) И ЗначениеЗаполнено(ДанныеЗвонков[0].Исходящий), ДанныеЗвонков[0].Исходящий, 0);
		
		РазницаПроцент = ?(КоличествоИсходящих = 0, 100, (Исходящие - КоличествоИсходящих) / КоличествоИсходящих * 100);
		Элементы.ДанныеИсходящиеСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеИсходящиеПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеИсходящиеСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеИсходящиеПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ГруппаИсходящиеПредыдущий.Видимость = Истина;
	Иначе
		Элементы.ГруппаИсходящиеПредыдущий.Видимость = Ложь;
	КонецЕсли;
	
	Если ОтображатьСравненияСПредыдущимПериодом И ЗначениеЗаполнено(Пропущенные) Тогда
		
		КоличествоПропущенных = ?(ЗначениеЗаполнено(ДанныеЗвонков) И ЗначениеЗаполнено(ДанныеЗвонков[0].Пропущен), ДанныеЗвонков[0].Пропущен, 0);
				
		РазницаПроцент = ?(КоличествоПропущенных = 0, 100, (Пропущенные - КоличествоПропущенных) / КоличествоПропущенных * 100);
		Элементы.ДанныеПропущенныеСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеПропущенныеПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеПропущенныеСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеПропущенныеПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ГруппаПропущенныеПредыдущий.Видимость = Истина;
	Иначе
		Элементы.ГруппаПропущенныеПредыдущий.Видимость = Ложь;
	КонецЕсли;
	
	#КонецОбласти 
	
	#Область ____________ВиджетКоммуникации____________
	
	// Тело Диаграммы
			
	ТаблицаЗначений = ДанныеКомуникаци.ДанныеКомуникаци.Выгрузить();
	Периодичность	= ДанныеКомуникаци.Периодичность;
	ЕстьДанныеДляОтображения = ТаблицаЗначений.Количество() > 0;
	
	Диаграмма = ДиаграммаКоммуникации;
	
	ДиаграммаКоммуникации.Обновление = Ложь;
	ДиаграммаКоммуникации.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
					
		Диаграмма.КоличествоСерий = ТаблицаЗначений.Колонки.Количество() - 1;	
		Диаграмма.КоличествоТочек = ТаблицаЗначений.Количество();
		
		Для НомерСтроки = 0 По ТаблицаЗначений.Количество() -1 Цикл
			
			Период = ТаблицаЗначений[НомерСтроки].Звонки; 
			
			Диаграмма.Точки[НомерСтроки].Текст = Перечисления.Периодичность.ПолучитьПредставлениеДатыПоПериодичности(Периодичность, Период);
			
			Для НомерКолонки = 1 по ТаблицаЗначений.Колонки.Количество() -1  Цикл
				Серия = Диаграмма.Серии[НомерКолонки - 1];
				Серия.Текст = ТаблицаЗначений.Колонки[НомерКолонки].Имя;
				Серия.Цвет	= ПолучитьЦветСерииПоНаправлениюВызова(Серия.Текст);
				Точки = Диаграмма.Точки[НомерСтроки];
				Диаграмма.УстановитьЗначение(Точки, Серия, ТаблицаЗначений[НомерСтроки][НомерКолонки]);
			КонецЦикла;
			
		КонецЦикла;    
		
	КонецЕсли;
	
	Если Не ЕстьДанныеДляОтображения тогда
		УстановитьОтображениеДиаграммы(Диаграмма, ЕстьДанныеДляОтображения);
	КонецЕсли;
	
	Диаграмма.Обновление = Истина;
	
	#КонецОбласти 
	
	#Область ____________ВиджетКоммуникацииАктивность____________
	
	// Тело Диаграммы
	ВыборкаРамки = ДанныеКомуникаци.ВтРамкиАктивности.Выбрать();			
	Выборка = ДанныеКомуникаци.ДанныеКомуникациАктивность.Выбрать();
		
	ЕстьДанныеДляОтображения = Выборка.Количество() > 0;
	
	Диаграмма = ДиаграммаАктивность; 
	
	Диаграмма.Обновление = Ложь;
	Диаграмма.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 	
							
		СерияПН = Диаграмма.Серии.Добавить("Понедельник");
		СерияПН.Значение = 1;
		СерияВТ = Диаграмма.Серии.Добавить("Вторник");
		СерияВТ.Значение = 2;
		СерияСР = Диаграмма.Серии.Добавить("Среда");
		СерияСР.Значение = 3;
		СерияЧТ = Диаграмма.Серии.Добавить("Четверг");
		СерияЧТ.Значение = 4;
		СерияПТ = Диаграмма.Серии.Добавить("Пятница");
		СерияПТ.Значение = 5;
		СерияСБ = Диаграмма.Серии.Добавить("Суббота");
		СерияСБ.Значение = 6;
		СерияВС = Диаграмма.Серии.Добавить("Воскресенье"); 
		СерияВС.Значение = 7;
				
		СерияКоличество = Диаграмма.Серии.Добавить(" ");//("Количество активности");
		СерияЧасоваяОсь = Диаграмма.Серии.Добавить("Часы");//("Часы");
	    СерияЧасоваяОсь.Значение = 999;
		СерияКоличество.Значение = 888;
		
		Диаграмма.ИсточникЗначенийОсиТочек 			= ИсточникЗначенийОсиТочекДиаграммы.Серия;
		Диаграмма.СерияНаОсиТочек					= СерияЧасоваяОсь;
		Диаграмма.ИсточникЗначенияРазмераПузырька 	= ИсточникЗначенияРазмераПузырькаДиаграммы.ОбщаяСерия;
		Диаграмма.ОбщаяСерияРазмераПузырька			= СерияКоличество;  
		Диаграмма.ОтображатьЛегенду 				= Ложь;  
		
		Если ВыборкаРамки.Следующий() Тогда
			Диаграмма.ОсьТочек.МинимальноеЗначение = ВыборкаРамки.МинимальныйПериодЧас - 1;
			Диаграмма.ОсьТочек.МаксимальноеЗначение = ВыборкаРамки.МаксимальныйПериодЧас + 1;	
		КонецЕсли;   
		
		Пока Выборка.Следующий() = Истина Цикл 			
			Если Выборка.Количество > 0 Тогда 
				СерияДеньНедели = Диаграмма.УстановитьСерию(Выборка.ДеньНедели);
				
				СерияДеньНедели.ИспользуемаяОсьЗначений = ИспользуемаяОсьЗначенийДиаграммы.Основная;			
				СерияДеньНедели.Цвет = Новый Цвет(125, 171, 96);
				
				Точка = Диаграмма.Точки.Добавить();
				
				Точка.Текст = "";// Строка(Выборка.ПериодЧас); 
				Точка.Цвет = Новый Цвет(125, 171, 96);
				
				Диаграмма.УстановитьЗначение(Точка, СерияДеньНедели, Выборка.ДеньНедели	,, СерияДеньНедели.Текст + " " + Выборка.ПериодЧас + ":00 " + "Количество активности - " + Выборка.Количество);
				Диаграмма.УстановитьЗначение(Точка, СерияЧасоваяОсь, Выборка.ПериодЧас	,, "п");
				Диаграмма.УстановитьЗначение(Точка, СерияКоличество, Выборка.Количество	,, "р");
			КонецЕсли;	
		КонецЦикла;
		
		Диаграмма.СводнаяСерия.ОтображатьГрафическоеПредставлениеДанныхВДиаграмме = ОтображениеВДиаграмме.НеОтображать;
		СерияЧасоваяОсь.ОтображатьГрафическоеПредставлениеДанныхВДиаграмме = ОтображениеВДиаграмме.НеОтображать;
		СерияЧасоваяОсь.ИспользуемаяОсьЗначений = ИспользуемаяОсьЗначенийДиаграммы.Дополнительная;
		Диаграмма.Обновление = Истина;

	КонецЕсли;
	
	#КонецОбласти 
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить виджет приемы.
//
// Параметры:
//  ДанныеПриемов	 - 	 - 
//
Процедура ОбновитьВиджетРегистратура(ДанныеЗаписей)
		
	Если ДанныеЗаписей = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	#Область ____________ВиджетСозданноНовыхЗаписей____________
		
	// Шапка
	Выборка = ДанныеЗаписей.ДанныеСозданоНовыхЗаписейВсего.Выбрать(); 
	
	Количество 	= ?(Выборка.Следующий(), Выборка.Количество, 0);
	
	Элементы.ДекорацияНадписьСозданноЗаписейКоличество.Заголовок = Количество;
	
	Если ОтображатьСравненияСПредыдущимПериодом И Количество <> 0 Тогда
		
		Выборка = ДанныеЗаписей.ДанныеСозданоНовыхЗаписейВсегоПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			КоличествоВсегоВчера = Выборка.Количество;
		Иначе
			КоличествоВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(КоличествоВсегоВчера = 0, 100, (Количество - КоличествоВсегоВчера) / КоличествоВсегоВчера * 100);
		Элементы.ДанныеСозданноНовыхЗаписейСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеСозданноНовыхЗаписейПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеСозданноНовыхЗаписейСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеСозданноНовыхЗаписейПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеСозданноНовыхЗаписей.Видимость = Истина;
	Иначе
		Элементы.ДанныеСозданноНовыхЗаписей.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
		
	ТаблицаРезультат = ДанныеЗаписей.ДанныеСозданоНовыхЗаписей.Выгрузить();
	ТаблицаРезультат.Сортировать("Количество Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаСозданоЗаписей.Обновление = Ложь;
	ДиаграммаСозданоЗаписей.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
		
		Точка = ДиаграммаСозданоЗаписей.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
			
			ПредставлениеСтатуса 	= ПолучитьПредсталвениеСтатуса(СтрокаТЗ.Статус);
			
			СерияДиаграммы 			= ДиаграммаСозданоЗаписей.Серии.Добавить(ПредставлениеСтатуса); 
			Точка.Текст				= "Статус";
			Точка.Значение			= СтрокаТЗ.Количество;	
					
			ДиаграммаСозданоЗаписей.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Количество,,);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаСозданоЗаписей, ЕстьДанныеДляОтображения);	
	ДиаграммаСозданоЗаписей.Обновление = Истина;
		
	#КонецОбласти
	
	#Область ____________ВиджетСозданоПоАдминистраторам____________
			
	// Тело Диаграммы
			
	ТаблицаЗначений = ДанныеЗаписей.ДанныеСозданоЗаписейПоАвторам.Выгрузить();
	ТаблицаЗначений.Сортировать("ОбщееКоличество Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаЗначений.Количество() > 0;
	
	Диаграмма = ДиаграммаСозданоПоАдминистраторамНовыхЗаписей; 
	
	Диаграмма.Обновление = Ложь;
	Диаграмма.Очистить();

	Если ЕстьДанныеДляОтображения Тогда 
		
		Диаграмма.КоличествоСерий = ТаблицаЗначений.Колонки.Количество() - 2;	
		Диаграмма.КоличествоТочек = ТаблицаЗначений.Количество();
		
		Для НомерСтроки = 0 По ТаблицаЗначений.Количество() -1 Цикл
			
			Сотрудник = ТаблицаЗначений[НомерСтроки].Сотрудник; 
			
			Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда
				ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(Сотрудник), "Без автора");	
			ИначеЕсли ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Пользователи") И ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник, "Служебный") = Истина Тогда
				ПредставлениеСотрудник 	= "Онлайн-запись";	
			Иначе
				ПредставлениеСотрудник = Строка(Сотрудник);
			КонецЕсли;
			
			Диаграмма.Точки[НомерСтроки].Текст = ПредставлениеСотрудник;
			
			Для НомерКолонки = 1 по ТаблицаЗначений.Колонки.Количество() - 1  Цикл
				Если ТаблицаЗначений.Колонки[НомерКолонки].Имя = "ОбщееКоличество" Тогда
					Продолжить;
				КонецЕсли;
				Серия = Диаграмма.Серии[НомерКолонки - 1];
				Серия.Текст = ?(ТаблицаЗначений.Колонки[НомерКолонки].Имя = "БезСтатуса", "Без статуса", ТаблицаЗначений.Колонки[НомерКолонки].Имя);
				Точки = Диаграмма.Точки[НомерСтроки];
				Диаграмма.УстановитьЗначение(Точки, Серия, ТаблицаЗначений[НомерСтроки][НомерКолонки]);
			КонецЦикла;
			
		КонецЦикла;    
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(Диаграмма, ЕстьДанныеДляОтображения);	
	Диаграмма.Обновление = Истина;
		
	#КонецОбласти
	
	#Область ____________ВиджетДиаграммаОтмененныеЗаписи____________
		
	Выборка = ДанныеЗаписей.ДанныеОтмененныеЗаписиВсего.Выбрать();
	
	Количество 	= ?(Выборка.Следующий(), Выборка.Количество, 0);
	
	Элементы.ДекорацияНадписьОтмененоЗаписейКоличество.Заголовок = Количество;
	
	Если ОтображатьСравненияСПредыдущимПериодом И Количество <> 0 Тогда
		
		Выборка = ДанныеЗаписей.ДанныеОтмененныеЗаписиВсегоПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			КоличествоВсегоВчера = Выборка.Количество;
		Иначе
			КоличествоВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(КоличествоВсегоВчера = 0, 100, (Количество - КоличествоВсегоВчера) / КоличествоВсегоВчера * 100);
		Элементы.ДанныеОтмененоЗаписейСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеОтмененоЗаписейПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеОтмененоЗаписейСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеОтмененоЗаписейПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеОтмененоЗаписей.Видимость = Истина;
	Иначе
		Элементы.ДанныеОтмененоЗаписей.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
	  	
	ТаблицаРезальтат = ДанныеЗаписей.ДанныеОтмененныеЗаписи.Выгрузить();
	ТаблицаРезальтат.Сортировать("Количество Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезальтат.Количество() > 0;
	
	ДиаграммаОтмененоЗаписей.Обновление = Ложь;
	ДиаграммаОтмененоЗаписей.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
					
		Точка = ДиаграммаОтмененоЗаписей.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезальтат Цикл
			
			ПредставлениеСтатуса 	= ПолучитьПредсталвениеСтатуса(СтрокаТЗ.Статус);	
			
			СерияДиаграммы 			= ДиаграммаОтмененоЗаписей.Серии.Добавить(ПредставлениеСтатуса); 
			Точка.Текст				= "Статус";
			Точка.Значение			= СтрокаТЗ.Количество;	
			
			Если СтрокаТЗ.Статус = Перечисления.СтатусыКонтрагентов.Первичный Тогда
				СерияДиаграммы.Цвет = Новый Цвет(250, 164, 27);
			ИначеЕсли СтрокаТЗ.Статус = Перечисления.СтатусыКонтрагентов.Постоянный Тогда
				СерияДиаграммы.Цвет = Новый Цвет(242, 98, 35);
			Иначе
				СерияДиаграммы.Цвет = Новый Цвет(128, 129, 184);
			КонецЕсли;
						
			ДиаграммаОтмененоЗаписей.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Количество);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	Если Не ЕстьДанныеДляОтображения Тогда
		УстановитьОтображениеДиаграммы(ДиаграммаОтмененоЗаписей, ЕстьДанныеДляОтображения);	
	КонецЕсли;
	
	ДиаграммаОтмененоЗаписей.Обновление = Истина;
	
	#КонецОбласти
	
КонецПроцедуры

#КонецОбласти
	
#Область УправлениеФормойИЭлементами

&НаКлиентеНаСервереБезКонтекста
// Процедура - Управление формой.
//
// Параметры:
//  Форма	 - 	 - 
//
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	
	Если Форма.ФоновоеЗаданиеВыполнено Тогда
		Элементы.СтраницыФормы.ТекущаяСтраница = Элементы.СтраницаВиджеты;
	Иначе
		Элементы.СтраницыФормы.ТекущаяСтраница = Элементы.СтраницаОжидание;
	КонецЕсли;
	
	Элементы.ГруппаФильтров.Доступность = НЕ Форма.ФоновоеЗаданиеЗапущено;
		
КонецПроцедуры

#КонецОбласти  

#Область СлужебныеПроцедурыИФункции 

&НаКлиенте
// Процедура - Выбор структурной единицы завершение.
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ВыборСтруктурнойЕдиницыЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат <> Неопределено И ТипЗнч(Результат) = Тип("СправочникСсылка.СтруктурныеЕдиницы") И ОтборСтруктурнаяЕдиница <> Результат Тогда		
		 Элементы.ВыбратьСтруктурнуюЕдиницу.Заголовок = Строка(Результат);
		 ОтборСтруктурнаяЕдиница = Результат;
		 		 
		 ОбновитьВиджетНаКлиенте();
		 
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обновить виджет на клиенте.
//
Процедура ОбновитьВиджетНаКлиенте()
	
	ФоновоеЗаданиеВыполнено = Ложь;
	ФоновоеЗаданиеЗапущено = Истина;
	УправлениеФормой(ЭтотОбъект);
	
	ЗапуститьФоновоеЗаданиеНаСервере();
	НачатьОжиданиеЗавершенияФоновогоЗаданияНаКлиенте();
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура постобработки диаграмм. Устанавливает цвета серий и толщину линий.
//
// Параметры:
//  Диаграмма				 - диаграмма - обрабатываемая диаграмма
//  ЕстьДанныеДляОтображения - булево	 - признак наличия/отсутствия данных
//  ЦветаСерий				 - массив	 - массив цветов в соответствии с которым назначаются цвета. Если не задан, то назначаются по умолчанию
Процедура УстановитьОтображениеДиаграммы(Диаграмма, ЕстьДанныеДляОтображения, ЦветаСерий = Неопределено)
	
	Если ЦветаСерий = Неопределено Тогда
		ЦветаСерий = Обработки.МониторРуководителя.ЦветаСерийДиаграмм();
	КонецЕсли;
	
	// Если точек на диаграмме меньше, то серии рисуем толстой линией, если больше - то тонкой
	МаксТочекДиаграммыСТолстойЛинией = 32;
	
	ТонкаяЛиния = Новый Линия(ТипЛинииДиаграммы.Сплошная, 1);
	ТолстаяЛиния = Новый Линия(ТипЛинииДиаграммы.Сплошная, 2);
	
	Для ИндексСерии = 0 По Диаграмма.Серии.Количество() - 1 Цикл
		
		Серия = Диаграмма.Серии[ИндексСерии];
		
		Если ЕстьДанныеДляОтображения Тогда
			Серия.Цвет = ЦветаСерий[?(ИндексСерии/10>=1,ИндексСерии - Цел(ИндексСерии/10)*10,ИндексСерии)];
		Иначе
			Серия.Цвет = ЦветаСтиля.ЦветТекстаНевыбраннойКартинки;
		КонецЕсли;
		
		Если Диаграмма.Точки.Количество() > МаксТочекДиаграммыСТолстойЛинией Тогда
			Серия.Линия = ТонкаяЛиния;
		Иначе
			Серия.Линия = ТолстаяЛиния;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЕстьДанныеДляОтображения Тогда
		Диаграмма.ОтображатьЗаголовок = Ложь;
		Диаграмма.ОбластьПостроения.ОтображатьПодписиШкалыТочек = Истина;
		Диаграмма.ОбластьПостроения.ОтображатьПодписиШкалыЗначений = Истина;
	Иначе
		Диаграмма.ОтображатьЗаголовок = Истина;
		Диаграмма.ОбластьПостроения.ОтображатьПодписиШкалыТочек = Ложь;
		Диаграмма.ОбластьПостроения.ОтображатьПодписиШкалыЗначений = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить предсталвение статуса.
//
// Параметры:
//  Статус	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредсталвениеСтатуса(Статус)
	
	Если Статус = Перечисления.СтатусыКонтрагентов.Первичный Тогда
		Возврат "Первичные";
	ИначеЕсли Статус = Перечисления.СтатусыКонтрагентов.Постоянный Тогда
		Возврат "Повторные";
	ИначеЕсли Статус = Перечисления.СтатусыКонтрагентов.ПустаяСсылка() Тогда
		Возврат "Без статуса";
	Иначе
		Возврат Строка(Статус); 
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
