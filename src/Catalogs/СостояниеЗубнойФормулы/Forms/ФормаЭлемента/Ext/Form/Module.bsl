&НаСервере
// Процедура, формирует кнопки HTML
//
Процедура СформироватьКнопки()
	Счетчик = 0;	
	Если ЭтоВебКлиент Тогда
		Адрес = "e1cib/helpservice/topics/v8config/v8cfgHelp/"; 
	Иначе
		Адрес = "../../";
	КонецЕсли;
	МассивЦветов = СоздатьПалитру();
	Для каждого СтрокаТЧ из МассивЦветов Цикл
		Если Счетчик = 8 Тогда
			Счетчик = 0;
			ПолеHTML = ПолеHTML + "</tr>" + Символы.ПС + "<tr>";			
		КонецЕсли;
		ПолеHTML = ПолеHTML + "<td><table class = 'bt'   onmousedown = sf('"+СтрокаТЧ+"') onmouseup = sf2('"+СтрокаТЧ+"') Style = 'BackGround-Color: "+СтрокаТЧ+"' >
		|<tr>
		|<td id = 'l"+СтрокаТЧ+"' class = 'Left'></td>
		|<td id = 'c"+СтрокаТЧ+"' class = 'Center1'></td>
		|<td id = 's"+СтрокаТЧ+"' class = 'Center2'></td>

		//|<td id = 'c"+СтрокаТЧ+"' class = 'Center1'><IMG border=0 align = top src = '"+Адрес+Картинка+"'/></td>
		//|<td id = 's"+СтрокаТЧ+"' class = 'Ctnter2'>"+ЭтаФорма.Надпись+"</td>
		|<td id = 'r"+СтрокаТЧ+"' class = 'Right'></td>
		|</tr>
		|</table></td>";		
		Счетчик = Счетчик + 1;
	КонецЦикла;
	
	
КонецПроцедуры

