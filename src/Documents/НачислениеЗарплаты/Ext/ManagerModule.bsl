					КонецЕсли;
					
					ИмяРеквизита = "";
					Если ТипЗнч(ВыборкаДетально.ВидНачисления) = Тип("СправочникСсылка.НачисленияИУдержанияСотрудников") Тогда 
						ИмяРеквизита = "НачислениеУдержание";
					Иначе 
						ИмяРеквизита = "ТипНачисленияУдержания";
					КонецЕсли;
					
					Если ВыборкаДетально.ВидНачисления[ИмяРеквизита] = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда
						СуммаНачисленияИтого = СуммаНачисленияИтого + Выборка.Сумма;
					Иначе
						СуммаУдержанияИтого = СуммаУдержанияИтого + -1 * Выборка.Сумма;
					КонецЕсли;
					
					ТабличныйДокумент.Вывести(Область);
					
				КонецЦикла;
				
				ТабличныйДокумент.Область(НомерСтрокиТаблицыС + 1, 1, ТабличныйДокумент.ВысотаТаблицы, 1).Объединить();
				
			КонецЦикла;
			
			Область = Макет.ПолучитьОбласть("Итог");
			Область.Параметры.СуммаНачисленияИтого = СуммаНачисленияИтого;
			Область.Параметры.СуммаУдержанияИтого = СуммаУдержанияИтого;
			Область.Параметры.СуммаИтого = СуммаНачисленияИтого - СуммаУдержанияИтого;
			ТабличныйДокумент.Вывести(Область);
			
		КонецЦикла;
	КонецЕсли;
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуРасшифровкаНачисления()

// Процедура печати документа.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_РасчетныйЛисток") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"ПФ_MXL_РасчетныйЛисток",
		"Расходный кассовый ордер",
		СформироватьПечатнуюФорму(МассивОбъектов, ОбъектыПечати)
		);
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ПлатежнаяВедомость") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"ПФ_MXL_ПлатежнаяВедомость",
		"Расходный кассовый ордер",
		СформироватьПечатнуюФормуПлатежнаяВедомость(МассивОбъектов, ОбъектыПечати)
		);
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_РасшифровкаНачисленияПодробно") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_РасшифровкаНачисленияПодробно", "Расшифровка начисления (подробно)",
				СформироватьПечатнуюФормуРасшифровкаНачисленияПодробно(МассивОбъектов, ОбъектыПечати));		
				
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_РасшифровкаНачисления") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_РасшифровкаНачисления", "Расшифровка начисления",
				СформироватьПечатнуюФормуРасшифровкаНачисления(МассивОбъектов, ОбъектыПечати));		
				
	КонецЕсли;
	
КонецПроцедуры // Печать()

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("ПФ_MXL_ПлатежнаяВедомость", "Платежная ведомость", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_РасчетныйЛисток", "Расчетные листки", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_РасшифровкаНачисления", "Расшифровка начисления", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_РасшифровкаНачисленияПодробно", "Расшифровка начисления (подробно)", , БиблиотекаКартинок.Документ);
		
	Возврат Список;
	
КонецФункции

///////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ РАСЧЕТА НАЧИСЛЕНИЙ/УДЕРЖАНИЙ

// Процедура - обработчик команды формы "ЗаполнитьНаСервере".
//
Процедура ЗаполнитьТаблицуАвансов(Объект, СтруктурнаяЕдиница, МесяцНачисления, МассивСотрудников, ИсключитьРегистратор) Экспорт
	
	// Заполнить таблицу "Авансы"
	ЗапросВыборка = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                             |	ВложенныйЗапрос.Сотрудник,
	                             |	-ВложенныйЗапрос.Сумма КАК Сумма
	                             |ИЗ
	                             |	(ВЫБРАТЬ
	                             |		РасчетыСПерсоналомОбороты.Сотрудник КАК Сотрудник,
	                             |		РасчетыСПерсоналомОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	                             |		СУММА(РасчетыСПерсоналомОбороты.СуммаОборот) КАК Сумма,
	                             |		РасчетыСПерсоналомОбороты.ДокументНачисления КАК ДокументНачисления
	                             |	ИЗ
	                             |		РегистрНакопления.РасчетыСПерсоналом.Обороты(
	                             |				,
	                             |				,
	                             |				Авто,
	                             |				МесяцНачисления = &МесяцНачисления
	                             |					И ДокументНачисления = ЗНАЧЕНИЕ(Документ.НачислениеЗарплаты.ПустаяСсылка)
	                             |					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                             |					И Сотрудник В (&МассивСотрудников)) КАК РасчетыСПерсоналомОбороты
	                             |	ГДЕ
	                             |		НЕ РасчетыСПерсоналомОбороты.Регистратор = &ИсключитьРегистратор
	                             |	
	                             |	СГРУППИРОВАТЬ ПО
	                             |		РасчетыСПерсоналомОбороты.Сотрудник,
	                             |		РасчетыСПерсоналомОбороты.СтруктурнаяЕдиница,
	                             |		РасчетыСПерсоналомОбороты.ДокументНачисления) КАК ВложенныйЗапрос
	                             |ГДЕ
	                             |	ВложенныйЗапрос.Сумма < 0");
								 
	ЗапросВыборка.УстановитьПараметр("МесяцНачисления"     ,МесяцНачисления);
	ЗапросВыборка.УстановитьПараметр("СтруктурнаяЕдиница"  ,СтруктурнаяЕдиница);
    ЗапросВыборка.УстановитьПараметр("ИсключитьРегистратор",ИсключитьРегистратор);
	ЗапросВыборка.УстановитьПараметр("МассивСотрудников"   ,МассивСотрудников);
    Результат = ЗапросВыборка.Выполнить().Выгрузить();
	
    Объект.Авансы.Загрузить(Результат);	
	
КонецПроцедуры

// Процедура - обработчик команды формы "РассчитатьНаСервере".
//
Процедура РассчитатьЗарплатуПоДокументу(Объект) Экспорт
	
	Объект.Затраты.Очистить();
	
	Для Каждого СтрокаТЧ Из Объект.РасчетЗарплаты Цикл
		
		СтрокаТЧ.Описание = СтрокаТЧ.НачислениеУдержание.ПолноеНаименование;		
		
		ТаблицаРасшифровкиНачислений = РассчитатьЗарплатуПоНачислению(СтрокаТЧ.НачислениеУдержание, СтрокаТЧ.ПериодС, СтрокаТЧ.ПериодПо, ?(СтрокаТЧ.ВычисляетсяВручную, СтрокаТЧ, Неопределено));
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаРасшифровкиНачислений, Объект.Затраты);
		Объект.Затраты.Сортировать("Сотрудник, Дата, ВидНачисления");
		
		ИмяВремени = ?(СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф И СтрокаТЧ.НачислениеУдержание.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧас
			ИЛИ СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф И СтрокаТЧ.НачислениеУдержание.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования
			ИЛИ СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Оклад И СтрокаТЧ.НачислениеУдержание.ЗависимостьОтВыработки = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗависитОтВыработки И СтрокаТЧ.НачислениеУдержание.ТипПериодаНачисления = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоЧасам, "Часов", "Дней");
		// Если СтрокаТЧ.ВычисляетсяВручную Тогда
		//	СтрокаТЧ.Сумма = ТаблицаРасшифровкиНачислений.Итог("Сумма");
		// Иначе
			СтрокаТЧ.ЧасовПлан = 0; СтрокаТЧ.ДнейПлан = 0; СтрокаТЧ.ЧасовФакт = 0; СтрокаТЧ.ДнейФакт = 0;		
			СтрокаТЧ[ИмяВремени + "План"] = ?(ТаблицаРасшифровкиНачислений.Количество() > 0, ТаблицаРасшифровкиНачислений[0].План, 0);
			СтрокаТЧ[ИмяВремени + "Факт"] = ТаблицаРасшифровкиНачислений.Итог("Факт");
			СтрокаТЧ.База = ТаблицаРасшифровкиНачислений.Итог("База");			
			СтрокаТЧ.Размер = ?(ТаблицаРасшифровкиНачислений.Количество() > 0, ТаблицаРасшифровкиНачислений[0].Размер, СтрокаТЧ.НачислениеУдержание.Размер);
			СтрокаТЧ.Сумма = ТаблицаРасшифровкиНачислений.Итог("Сумма");
		// КонецЕсли;
		   
	КонецЦикла;
	
	Для Каждого СтрокаТЧ Из Объект.ПрочиеНачисленияИУдержания Цикл
		НоваяСтрока = Объект.Затраты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		НоваяСтрока.ВидНачисления 	= СтрокаТЧ.Начисление;
		НоваяСтрока.Размер 			= СтрокаТЧ.Сумма
	КонецЦикла;
	
	// Обрабатываем суммы начислений которые в группах
	МассивУдаляемыхНачислений = Новый Массив;
	Для Каждого СтрокаТЧ Из Объект.РасчетЗарплаты Цикл
		МассивПоРодителю = Новый Массив;
		Для Каждого СтрокаТЧВрем Из Объект.РасчетЗарплаты Цикл
			Если Не СтрокаТЧ.НачислениеУдержание.Родитель.Пустая() И СтрокаТЧВрем.НачислениеУдержание.Родитель = СтрокаТЧ.НачислениеУдержание.Родитель Тогда
				МассивПоРодителю.Добавить(СтрокаТЧВрем);
			КонецЕсли;
		КонецЦикла;
		Если МассивПоРодителю.Количество() >= 2 Тогда
			СтрокаПодходящегоВГруппе = Неопределено;
			Для Каждого СтрокаТЧВрем Из МассивПоРодителю Цикл
				Если СтрокаПодходящегоВГруппе = Неопределено Тогда
					СтрокаПодходящегоВГруппе = СтрокаТЧВрем;					
				Иначе
					Если СтрокаПодходящегоВГруппе.НачислениеУдержание.Родитель.ВариантИспользования = Перечисления.ВариантыИспользования.Максимум И СтрокаПодходящегоВГруппе.Сумма < СтрокаТЧВрем.Сумма
							ИЛИ СтрокаПодходящегоВГруппе.НачислениеУдержание.Родитель.ВариантИспользования = Перечисления.ВариантыИспользования.Минимум И СтрокаПодходящегоВГруппе.Сумма > СтрокаТЧВрем.Сумма Тогда
						МассивУдаляемыхНачислений.Добавить(СтрокаПодходящегоВГруппе.НачислениеУдержание);
						СтрокаПодходящегоВГруппе = СтрокаТЧВрем;
					Иначе
						МассивУдаляемыхНачислений.Добавить(СтрокаТЧВрем.НачислениеУдержание);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	// Удаляем строки которые неподошли по условиям группировок
	Для Каждого УдаляемоеНачисление Из МассивУдаляемыхНачислений Цикл
		Если Объект.РасчетЗарплаты.НайтиСтроки(Новый Структура("НачислениеУдержание", УдаляемоеНачисление)) <> Неопределено Тогда
			ПервоначальноеКоличество = Объект.РасчетЗарплаты.Количество();
			Для а = 1 По ПервоначальноеКоличество Цикл
				Если Объект.РасчетЗарплаты[ПервоначальноеКоличество - а].НачислениеУдержание = УдаляемоеНачисление Тогда
					Объект.РасчетЗарплаты.Удалить(ПервоначальноеКоличество - а);
				КонецЕсли;
			КонецЦикла;			
		КонецЕсли;		
		Если Объект.Затраты.НайтиСтроки(Новый Структура("ВидНачисления", УдаляемоеНачисление)) <> Неопределено Тогда
			ПервоначальноеКоличество = Объект.Затраты.Количество();
			Для а = 1 По ПервоначальноеКоличество Цикл
				Если Объект.Затраты[ПервоначальноеКоличество - а].ВидНачисления = УдаляемоеНачисление Тогда
					Объект.Затраты.Удалить(ПервоначальноеКоличество - а);
				КонецЕсли;
			КонецЦикла;			
		КонецЕсли;
	КонецЦикла;
	
	Объект.СуммаДокумента = Объект.РасчетЗарплаты.Итог("Сумма") + Объект.ПрочиеНачисленияИУдержания.Итог("Сумма");	
	
КонецПроцедуры // РассчитатьНаСервере()

// Процедура - производит проверку вида начисления, в зависимости от которого будет происходить начисление заработной платы
//
Функция РассчитатьЗарплатуПоНачислению(НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы = Неопределено) Экспорт
	
	ТаблицаРасшифровкиНачислений = Документы.НачислениеЗарплаты.СоздатьДокумент().Затраты.ВыгрузитьКолонки();
	
	Если НачислениеУдержание.НачислениеУдержание = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда
		Если НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Процент Тогда
			РасчетыПоПроцентномуНачислению(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы);
		ИначеЕсли НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Оклад Тогда
			РасчетыПоОкладу(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы);
		ИначеЕсли НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф Тогда			
			РасчетыПоТарифу(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы);
		КонецЕсли;
	Иначе
		РасчетыПоУдержанию(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы);
	КонецЕсли;
	
	Возврат ТаблицаРасшифровкиНачислений;
	
КонецФункции // ПроверкаВидаНачисления()

// Производится расчет ЗП при установленной виде начисления "Процент"
//
Процедура РасчетыПоПроцентномуНачислению(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы = Неопределено)
	
	Если СтруктураПереопределенияБазы <> Неопределено Тогда
		ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодПо, , , ,
						, , СтруктураПереопределенияБазы.База, СтруктураПереопределенияБазы.Размер, СтруктураПереопределенияБазы.База * СтруктураПереопределенияБазы.Размер / 100);
		Возврат;
	КонецЕсли;
	
	// Получаем временную таблицу проданных товаров и услуг
	ЗапросПоПродажам = Новый Запрос;
	
	Если НачислениеУдержание.УчитываяТолькоОплаченныеПродажи = Ложь Тогда
		ЗапросПоПродажам.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		                         |	ПродажиОбороты.ПериодСекунда КАК Дата,
		                         |	ПродажиОбороты.ДокументПродажи КАК Документ,
		                         |	ПродажиОбороты.Контрагент КАК Контрагент,
		                         |	ПродажиОбороты.Номенклатура КАК Номенклатура,
		                         |	ВЫБОР
		                         |		КОГДА &ИспользоватьСкидки = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоВидуЦен)
		                         |			ТОГДА ЕСТЬNULL(ЦеныНоменклатурыОстатки.Цена, 0) * ЕСТЬNULL(ПродажиОбороты.КоличествоОборот, 0)
		                         |		КОГДА &ИспользоватьСкидки = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.СоСкидкой)
		                         |			ТОГДА ПродажиОбороты.СтоимостьОборот
		                         |		ИНАЧЕ ПродажиОбороты.СтоимостьБезСкидкиОборот
		                         |	КОНЕЦ - ВЫБОР
		                         |		КОГДА &УчитыватьМатериалы = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.УчитыватьСебестоимостьТовара)
		                         |			ТОГДА ЕСТЬNULL(СебестоимостьОбороты.СтоимостьОборот, 0)
		                         |		ИНАЧЕ 0
		                         |	КОНЕЦ КАК Сумма,
		                         |	ЛОЖЬ КАК СписаниеПоМатериалам
		                         |ИЗ
		                         |	РегистрНакопления.Продажи.Обороты(
		                         |			&НачалоПериода,
		                         |			&КонецПериода,
		                         |			Авто,
		                         |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		                         |				И ВЫБОР
		                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСтоматологии)
		                         |						ТОГДА ИСТИНА
		                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотруднику)
		                         |						ТОГДА Сотрудник = &Сотрудник
		                         |								ИЛИ Ассистент = &Сотрудник
		                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеВрача)
		                         |						ТОГДА Сотрудник = &Сотрудник
		                         |					КОГДА &ОтПродаж = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоСотрудникуВКачествеАссистента)
		                         |						ТОГДА Ассистент = &Сотрудник
