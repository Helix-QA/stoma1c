// Функция, возвращает представление времени.
//
Функция ПолучитьПредставлениеВремениДляСписка(КоличествоСекунд)
	
	ПредставлениеВремени = "";
	
	Если Не ЗначениеЗаполнено(КоличествоСекунд) Тогда
		Возврат ПредставлениеВремени;
	КонецЕсли;
	
	Часы	 = Цел(КоличествоСекунд / 3600);
	Минуты	 = Цел((КоличествоСекунд % 3600) / 60);
	Секунды	 = Цел(КоличествоСекунд % 60);
	
	ОтображатьСекунды = (Часы = 0 И Минуты = 0);
	
	ПредставлениеВремени = 
	?(Часы = 0, "", "" + Часы + НСтр("ru = ' ч. '; en = ' h. '")) +
	?(Минуты = 0, "", "" + Минуты + НСтр("ru = ' мин. '; en = ' min. '")) +
	?(ОтображатьСекунды, "" + Секунды + НСтр("ru = ' сек.'; en = ' sec.'"), "");
	
	Возврат ПредставлениеВремени;
	
КонецФункции

&НаСервере
// Процедура, создает элементы условного оформления для сделок.
//
Процедура УстановитьУсловноеОформлениеСделок()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(ЭтапыСделок.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	НЕ (ВЫРАЗИТЬ(ЭтапыСделок.ЦветЭтапа КАК СТРОКА(100))) = """"";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ЭлементУсловногоОформления = ЭтотОбъект.СписокЧатов.УсловноеОформление.Элементы.Добавить();
		
		ЭлементОтбора				 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЦветЭтапа");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Выборка.ЦветЭтапа;
		ЭлементОтбора.Использование  = Истина;
		
		ЦветЭтапа = ЗначениеИзСтрокиВнутр(Выборка.ЦветЭтапа);
		ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветЭтапа);
		ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ПолучитьЦветТекстаПоФону(ЦветЭтапа));
		
		ПолеОформления				 = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЭтапСделки");
		ПолеОформления.Использование = Истина;
		
	КонецЦикла;
	
	// Условное оформление для успеха.
	ЭлементУсловногоОформления = СписокЧатов.УсловноеОформление.Элементы.Добавить();
	
	ЭлементОтбора				 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЭтапСделки");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно; 
	ЭлементОтбора.ПравоеЗначение = Справочники.ЭтапыСделок.Успех;
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона"  , Новый Цвет(72, 193, 123));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255, 255, 255));
	
	ПолеОформления				 = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЭтапСделки");
	ПолеОформления.Использование = Истина;
	
	// Условное оформление для отказа.
	ЭлементУсловногоОформления = СписокЧатов.УсловноеОформление.Элементы.Добавить();
	
	ЭлементОтбора				 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЭтапСделки");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Справочники.ЭтапыСделок.Отказ;
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона"  , Новый Цвет(246, 110, 110));
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 255, 255)));
	
	ПолеОформления				 = ЭлементУсловногоОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЭтапСделки");
	ПолеОформления.Использование = Истина;
	
КонецПроцедуры

