// 
Процедура ПодборМестаРаботыСотрудникаВыгружатьПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ПодборМестаРаботыСотрудника.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если ТекущиеДанные.Выгружать = 1 Тогда
		
		// Обновить таблицу мест работы сотрудника.
		ОбновитьМестаРаботыСотрудника();
		
		Если ТекущиеДанные.ЭтоГруппа Тогда
			Для Каждого СтрокаТ Из ЭтотОбъект.ДоступныеСтруктурныеЕдиницы Цикл
				УстановитьНастройкиСотрудникаПоУмолчанию(СтрокаТ.СтруктурнаяЕдиница);
			КонецЦикла;			
		Иначе
			УстановитьНастройкиСотрудникаПоУмолчанию(ТекущиеДанные.СтруктурнаяЕдиница);	
		КонецЕсли;
				
		Элементы.ГруппаНастрокиСотрудников.Видимость = Истина;
			
		// Обновить таблицы доступныъ журналов приемов и доступных касс сотрудника.
		ОбновитьТабличныеЧастиСотрудника(,, Ложь); 
			
		//ЭтаФорма.Записать();
		Модифицированность = Истина;
	Иначе
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("СтруктурнаяЕдиница", ТекущиеДанные.СтруктурнаяЕдиница);
		ПараметрыОповещения.Вставить("ЭтоГруппа"         , ТекущиеДанные.ЭтоГруппа);
		ПараметрыОповещения.Вставить("ТекущиеДанные"     , ТекущиеДанные);
		
		ОписаниеОповещения  = Новый ОписаниеОповещения("ПослеВопросаУдаленияМестаРаботыСотрудника", ЭтотОбъект, ПараметрыОповещения);
		
		ТекстВопроса = "Вы уверены, что хотите удалить все настройки пользователя для "  + ?(Не ТекущиеДанные.ЭтоГруппа, "клиники " + Строка(ТекущиеДанные.СтруктурнаяЕдиница) + "?", "всех клиник?");
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

