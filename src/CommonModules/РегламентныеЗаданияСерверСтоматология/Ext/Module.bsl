Процедура ЗакрытьНеактивныеДиалоги() Экспорт

	// Заглушка для процедуры регламента.
	Возврат;
	
КонецПроцедуры

#Область ОбновлениеСистемСквознойАналитики

// Процедура, обновляет сестему сквозной аналитики CoMagic. 
//
Процедура ОбновлениеСистемСквознойАналитики() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
		
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеДанныхСистемСквознойАналитики);
	
	Попытка

		ВнешняяСистемаCalltouch	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Calltouch, Истина);
		ВнешняяСистемаЯМетрика	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.ЯндексМетрика, Истина);
		ВнешняяСистемаComagic	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.CoMagic, Истина);
		
		Если ЗначениеЗаполнено(ВнешняяСистемаCalltouch) 
			И ТипЗнч(ВнешняяСистемаCalltouch.Параметры.Получить()) = Тип("Структура") 
			И ЗначениеЗаполнено(ВнешняяСистемаCalltouch.Параметры.Получить().ApiToken)
			И ЗначениеЗаполнено(ВнешняяСистемаCalltouch.Параметры.Получить().UrlApi) Тогда 
			СписокСтатусов = РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ПолучитьСписокССА(Перечисления.ТипыВнешнихСистем.Calltouch);
			СписокСтатусов.Сортировать("ДатаИзменения");
			Для Каждого СтрокаТЧ Из СписокСтатусов Цикл
				Если ЗначениеЗаполнено(СтрокаТЧ.ВнешняяСистема) Тогда
					Если СтрокаТЧ.Статус = Перечисления.СтатусыСквознойАналитики.СделкаСоздана 
						Или СтрокаТЧ.Статус = Перечисления.СтатусыСквознойАналитики.СделкаСостоялась
						Или СтрокаТЧ.Статус = Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась
						Или СтрокаТЧ.Статус = Перечисления.СтатусыСквознойАналитики.СделкаСменаЭтапа Тогда
						ОбновленоУспешно = ОтправитьСделкуВCalltouch(СтрокаТЧ, СтрокаТЧ.ВнешняяСистема);	
					Иначе
						ОбновленоУспешно = ОтправитьЗаявкуВCalltouch(СтрокаТЧ, СтрокаТЧ.ВнешняяСистема);
					КонецЕсли;
					
					Если ОбновленоУспешно Тогда
						РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.УдалитьЗаписьПоЗаявке(СтрокаТЧ.Объект, СтрокаТЧ.ВнешняяСистема, СтрокаТЧ.Статус);	
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;                  
		
		Если ЗначениеЗаполнено(ВнешняяСистемаЯМетрика) Тогда 
			СписокСтатусов = РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ПолучитьСписокССА(Перечисления.ТипыВнешнихСистем.ЯндексМетрика);
			СписокСтатусов.Сортировать("ДатаИзменения");
			Для Каждого СтрокаТЧ Из СписокСтатусов Цикл
				Если ЗначениеЗаполнено(СтрокаТЧ.ВнешняяСистема) Тогда
						ОбновленоУспешно = ОтправитьСделкуВЯМетрика(СтрокаТЧ);	

					Если ОбновленоУспешно Тогда
						РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.УдалитьЗаписьПоЗаявке(СтрокаТЧ.Объект, СтрокаТЧ.ВнешняяСистема, СтрокаТЧ.Статус);	
					Иначе
						РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(СтрокаТЧ.Объект, СтрокаТЧ.Статус, СтрокаТЧ.ВнешняяСистема);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;
		
		// Отправка в Comagic.
		Если ЗначениеЗаполнено(ВнешняяСистемаCoMagic) Тогда
			
			ПараметрыВС = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВнешняяСистемаCoMagic, "Параметры").Получить();
			
			Если ТипЗнч(ПараметрыВС) = Тип("Структура") И ПараметрыВС.Свойство("Токен") И ЗначениеЗаполнено(ПараметрыВС.Токен) Тогда
				
				// Сделан такой запрос, чтоб при выгрузке сделок не получать значения через точку.			
				СписокСтатусов = Справочники.Сделки.ПолучитьДанныеПоСделкамДляСквознойАналитики(Перечисления.ТипыВнешнихСистем.CoMagic);
				
				Если НЕ СписокСтатусов = Неопределено Тогда
					
					Для Каждого СтрокаТЧ Из СписокСтатусов Цикл			
						
						РезультатОтправки = ОтправитьСделкуВCoMagic(СтрокаТЧ, ВнешняяСистемаCoMagic);
						
						// Выгрузка невозможна, ошибка записана в журнал регистрации!
						Если РезультатОтправки.ПрекратитьВыгрузку Тогда
							Прервать;
						КонецЕсли;
						
						ОбновленоУспешно = Истина;
						
						Если ТипЗнч(СтрокаТЧ.Объект) = Тип("СправочникСсылка.Заявки") И
							Не СтрокаТЧ.Статус = Перечисления.СтатусыСквознойАналитики.СделкаСменаЭтапа Тогда
							
							ОбновленоУспешно = ПроставитьТегиCoMagic(СтрокаТЧ, ВнешняяСистемаCoMagic);
						КонецЕсли;
						
						Если РезультатОтправки.Результат Тогда
							РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.УдалитьЗаписьПоЗаявке(СтрокаТЧ.Объект, СтрокаТЧ.ВнешняяСистема, СтрокаТЧ.Статус);	
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли; // Список статусов.
				
			КонецЕсли; // Проверка токена.
			
		КонецЕсли; // ВС Comagic заполнена.
			
		ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеДанныхСистемСквознойАналитики);			
	Исключение
		ОписаниеОшибкиВыполнения = ОписаниеОшибки();
		ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеДанныхСистемСквознойАналитики, ОписаниеОшибкиВыполнения);		
	КонецПопытки;
	
КонецПроцедуры

 // Функция, отправляет данные о сделке в Calltouch/
//
Функция ОтправитьСделкуВCalltouch(ПараметрыСтатуса, ВнешняяСистемаCalltouch)
	
	Попытка
		
		Статус             = ПараметрыСтатуса.Статус;
		ДатаИзменения      = ПараметрыСтатуса.ДатаИзменения;
		
		Если ПараметрыСтатуса.ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Calltouch Тогда
			ВнешняяСистема = ПараметрыСтатуса.ВнешняяСистема;
		Иначе
			ВнешняяСистема = ВнешняяСистемаCalltouch; 
		КонецЕсли;
		
		СтруктураПараметров = ВнешняяСистема.Параметры.Получить();
		
		Сделка = ПараметрыСтатуса.Объект;
		
		Если ЗначениеЗаполнено(Сделка.Заявка) Тогда
			МассивТелефонов = Сделка.Заявка.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
			МассивEmail = Сделка.Заявка.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
		Иначе
			МассивТелефонов = Сделка.Контрагент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
			МассивEmail = Сделка.Контрагент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
		КонецЕсли;
		
		СуммаСделки = 0;
		Если ЗначениеЗаполнено(Сделка.Прием) Тогда
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СУММА(Прием.СуммаДокумента) КАК СуммаДокумента
			|ИЗ
			|	Документ.Прием КАК Прием
			|ГДЕ
			|	Прием.Сделка = &Сделка");
			
			Запрос.УстановитьПараметр("Сделка", Сделка);
			
			Результат = Запрос.Выполнить().Выгрузить(); 
			СуммаСделки = Результат[0].СуммаДокумента;
		Иначе
			СуммаСделки = Сделка.СуммаСделки;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Сделка) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		
		orders = Новый Массив;
		ordersSTR = Новый Структура;
		
		matching =  Новый Структура;
		matchingtype = Новый Массив;
		matchingtypeSTR = Новый Структура;
		
		Если Статус = Перечисления.СтатусыСквознойАналитики.СделкаСоздана Тогда
			
			
			/////////////////////////////// MATHING ///////////////////////////
			
			Если ПараметрыСтатуса.ВнешняяСистема = ВнешняяСистемаCalltouch Тогда  
				
				///////////////////////// REQUEST ///////////////////
				Если ЗначениеЗаполнено(Сделка.Заявка) И ЗначениеЗаполнено(Сделка.Заявка.communication_id) Тогда
					requestParams = Новый Структура;
					requestParams.Вставить("requestId"	, Сделка.Заявка.communication_id);
					matchingtypeSTR.Вставить("type", "request");
					matchingtypeSTR.Вставить("requestParams", requestParams); 
					matchingtype.Добавить(matchingtypeSTR);
				КонецЕсли;
				///////////////////////// REQUEST CONTACT ///////////////////
				
				requestContactParams = Новый Структура;
				emailsMAS = Новый Массив;
				Если МассивEmail.Количество() > 0 Тогда
					Для Каждого ЭлМассив Из МассивEmail Цикл
						emailsMAS.Добавить(ЭлМассив.АдресЭп);
					КонецЦикла;
					requestContactParams.Вставить("emails", emailsMAS);
				КонецЕсли;
				phonesMAS = Новый Массив;
				Если МассивТелефонов.Количество() > 0 Тогда
					Для Каждого ЭлМассив Из МассивТелефонов Цикл
						phonesMAS.Добавить(ЭлМассив.НомерТелефона);
					КонецЦикла;
					requestContactParams.Вставить("phones", phonesMAS);
				КонецЕсли;
				requestContactParams.Вставить("date", СтрЗаменить(Формат(Сделка.ДатаСделки, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-"));
				requestContactParams.Вставить("requestTypeToMatch", "nearest");
				requestContactParams.Вставить("searchDepth", 525600);
				matchingtypeSTRrequestContact = Новый Структура;
				matchingtypeSTRrequestContact.Вставить("type", "requestContact");
				matchingtypeSTRrequestContact.Вставить("requestContactParams", requestContactParams); 
				
				Если emailsMAS.Количество() > 0 Или phonesMAS.Количество() > 0 Тогда 
					matchingtype.Добавить(matchingtypeSTRrequestContact);
				КонецЕсли;
				///////////////////////// CALL CONTACT ///////////////////
				
				callContactParams = Новый Структура;
				phonesMAS = Новый Массив;
				Если МассивТелефонов.Количество() > 0 Тогда
					Для Каждого ЭлМассив Из МассивТелефонов Цикл
						phonesMAS.Добавить(ЭлМассив.НомерТелефона);
					КонецЦикла;
					callContactParams.Вставить("phones", phonesMAS);
				КонецЕсли;
				callContactParams.Вставить("date", СтрЗаменить(Формат(Сделка.ДатаСделки, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-")); 
				callContactParams.Вставить("callTypeToMatch", "nearest");
				callContactParams.Вставить("searchDepth", 525600);
				matchingtypeSTRrequestContact = Новый Структура;
				matchingtypeSTRrequestContact.Вставить("type", "callContact");
				matchingtypeSTRrequestContact.Вставить("callContactParams", callContactParams); 
				
				Если phonesMAS.Количество() > 0 Тогда 
					matchingtype.Добавить(matchingtypeSTRrequestContact);
				КонецЕсли;
 				
				///////////////////////// CUSTOM SOURCES ///////////////////
				Если ЗначениеЗаполнено(Сделка.Заявка) Тогда
					customSourceParams = Новый Структура;
					Если ЗначениеЗаполнено(Сделка.Заявка.РекламныйИсточник.Наименование) Тогда
						source = Сделка.Заявка.РекламныйИсточник.Наименование;
						medium = Сделка.Заявка.РекламнаяПлощадка.Наименование;
					Иначе
						source = Сделка.Заявка.utm_source;
						medium = Сделка.Заявка.utm_medium;
					КонецЕсли;
					//medium = "";
					campaign = Сделка.Заявка.utm_campaign;
					content =Сделка.Заявка.utm_content;
					term = Сделка.Заявка.utm_term;
					Если ЗначениеЗаполнено(source) И ЗначениеЗаполнено(medium) И ЗначениеЗаполнено(campaign) Тогда
						customSourceParams.Вставить("source"  , source);
						customSourceParams.Вставить("medium"  , medium);
						customSourceParams.Вставить("campaign", campaign);
						customSourceParams.Вставить("content" , content);
						customSourceParams.Вставить("term"	, term);
						matchingtypeSTRcustomSources = Новый Структура;
						matchingtypeSTRcustomSources.Вставить("type", "customSources");
						matchingtypeSTRcustomSources.Вставить("customSourceParams", customSourceParams); 
						matchingtype.Добавить(matchingtypeSTRcustomSources);
					КонецЕсли;
				Иначе 
					///////////////////////// WITHOUT SOURCES ///////////////////
					matchingtypeSTR.Вставить("type", "withoutSource");
					matchingtype.Добавить(matchingtypeSTR);
				КонецЕсли;
			КонецЕсли;
			/////////////////////////// ORDERS /////////////////
			
			ordersSTR.Вставить("matching", matchingtype);
			ordersSTR.Вставить("orderNumber", КраткийНомер(Сделка.Код));
			ordersSTR.Вставить("status", ПараметрыСтатуса.ЭтапСделки.Наименование);
			ordersSTR.Вставить("statusDate", СтрЗаменить(Формат(Сделка.ИсторияИзмененияЭтапов[(Сделка.ИсторияИзмененияЭтапов.Количество() - 1)].Дата, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-"));
			ordersSTR.Вставить("orderDate", СтрЗаменить(Формат(Сделка.ДатаСделки, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-"));
			ordersSTR.Вставить("manager", ?(ЗначениеЗаполнено(Сделка.Менеджер), Сделка.Менеджер.Наименование, ""));
			Если ЗначениеЗаполнено(Сделка.Описание) Тогда
				comment = новый Структура;
				comment.Вставить("text", Сделка.Описание);
				ordersSTR.Вставить("comment", comment);
			КонецЕсли;
			addTagMASS = Новый Массив;
			addTagsSTR = Новый Структура;
			addTagsSTR.Вставить("tag", Сделка.ВидСделки.Наименование);
			addTagMASS.Добавить(addTagsSTR);
			ordersSTR.Вставить("addTags", addTagMASS);
			orders.Добавить(ordersSTR);
			
			//////////////////////// ЗАПРОС  /////////
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("crm", "1С:Стоматология");
			ПараметрыЗапроса.Вставить("orders", orders);
			
			ТекстЗапроса     = СобратьJson(ПараметрыЗапроса);
			
			UrlApi = "api.calltouch.ru";
			
			Соединение = Новый HTTPСоединение(UrlApi,,,,,,НОвый ЗащищенноеСоединениеOpenSSL());
			
			ЗаголовкиHTTP = Новый Соответствие;
			ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
			ЗаголовкиHTTP.Вставить("SiteId", ВнешняяСистемаCalltouch.КлючПриложения);
			ЗаголовкиHTTP.Вставить("Access-Token", СтруктураПараметров.ApiToken);
			
			HTTPЗапрос = Новый HTTPЗапрос("/lead-service/v1/api/client-order/create", ЗаголовкиHTTP);		
			HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
			
			ВозвращаемыйРезультат = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
			
			Возврат ВозвращаемыйРезультат.КодСостояния = 200;

			Ответ = ВозвращаемыйРезультат.ПолучитьТелоКакСтроку();
			
		ИначеЕсли Статус = Перечисления.СтатусыСквознойАналитики.СделкаСостоялась 
			Или Статус = Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась 
			Или Статус = Перечисления.СтатусыСквознойАналитики.СделкаСменаЭтапа Тогда
			
			/////////////////////////// ORDERS /////////////////
			
			ordersSTR.Вставить("orderNumber", КраткийНомер(Сделка.Код));
			ordersSTR.Вставить("status", ПараметрыСтатуса.ЭтапСделки.Наименование);
			ordersSTR.Вставить("statusDate", СтрЗаменить(Формат(Сделка.ИсторияИзмененияЭтапов[(Сделка.ИсторияИзмененияЭтапов.Количество() - 1)].Дата + 60, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-"));
			ordersSTR.Вставить("updateDate", СтрЗаменить(Формат(Сделка.ИсторияИзмененияЭтапов[(Сделка.ИсторияИзмененияЭтапов.Количество() - 1)].Дата + 60, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-"));
			
			Если СуммаСделки > 0 Тогда
				ordersSTR.Вставить("revenue", СтрЗаменить(Формат(СуммаСделки, "ЧГ="),",","."));
			КонецЕсли;
			
			ordersSTR.Вставить("manager", ?(ЗначениеЗаполнено(Сделка.Менеджер), Сделка.Менеджер.Наименование, ""));
			Если ЗначениеЗаполнено(Сделка.Описание) Тогда
				comment = новый Структура;
				comment.Вставить("text", Сделка.Описание);
				ordersSTR.Вставить("addNewComment", comment);
			КонецЕсли;
			addTagsSTR = Новый Структура;
			addTagsSTR.Вставить("overwrite", false);
			addTagMASS = Новый Массив;
			addTagsSTRtag = Новый Структура;
			addTagsSTRtag.Вставить("tag", "1С:Стоматология");
			addTagMASS.Добавить(addTagsSTRtag);
			addTagsSTR.Вставить("tags", addTagMASS);
			ordersSTR.Вставить("addTags", addTagsSTR);
			
			orders.Добавить(ordersSTR);
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("orders", orders);
			
			ТекстЗапроса     = СобратьJson(ПараметрыЗапроса);
			
			UrlApi = "api.calltouch.ru";
			
			Соединение = Новый HTTPСоединение(UrlApi,,,,,,НОвый ЗащищенноеСоединениеOpenSSL());
			
			ЗаголовкиHTTP = Новый Соответствие;
			ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
			ЗаголовкиHTTP.Вставить("SiteId", ВнешняяСистемаCalltouch.КлючПриложения);
			ЗаголовкиHTTP.Вставить("Access-Token", СтруктураПараметров.ApiToken);
			
			HTTPЗапрос = Новый HTTPЗапрос("/lead-service/v1/api/client-order/update", ЗаголовкиHTTP);		
			HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
			
			ВозвращаемыйРезультат = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
			
			Возврат ВозвращаемыйРезультат.КодСостояния = 200;
			
			Ответ = ВозвращаемыйРезультат.ПолучитьТелоКакСтроку();
			 
		КонецЕсли;
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхCalltouch", УровеньЖурналаРегистрации.Ошибка,,, НСтр("ru= 'Ошибка обновления сделок Calltouch.';en= 'Error updating Calltouch deals.'") + ОписаниеОшибки);
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции	

// Функция, отправляет данные о заявке в Calltouch/
//
Функция ОтправитьЗаявкуВCalltouch(ПараметрыСтатуса, ВнешняяСистемаCalltouch)

		Попытка
		
		communication_id   = ПараметрыСтатуса.Объект.communication_id;
		Статус             = ПараметрыСтатуса.Статус;
		ДатаИзменения      = ПараметрыСтатуса.ДатаИзменения;
		
		Если ПараметрыСтатуса.Объект.ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Calltouch Тогда
			ВнешняяСистема = ПараметрыСтатуса.Объект.ВнешняяСистема;
		Иначе
			ВнешняяСистема = ВнешняяСистемаCalltouch; 
		КонецЕсли;
		
		СтруктураПараметров = ВнешняяСистема.Параметры.Получить();
		
		leads = Новый Массив;
		leadsSTR = Новый Структура;
		matching =  Новый Структура;
		matchingtype = Новый Массив;
		matchingtypeSTR = Новый Структура;
		
		///////////////////////// REQUEST ///////////////////
		
		requestParams = Новый Структура;
		requestParams.Вставить("requestId"	, ПараметрыСтатуса.Объект.communication_id);
		matchingtypeSTR.Вставить("type", "request");
		matchingtypeSTR.Вставить("requestParams", requestParams); 
		matchingtype.Добавить(matchingtypeSTR);
		
		
		///////////////////////// REQUEST CONTACT ///////////////////
		
		requestContactParams = Новый Структура;
		emailsMAS = Новый Массив;
		МассивEmail = ПараметрыСтатуса.Объект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
		Если МассивEmail.Количество() > 0 Тогда
			Для Каждого ЭлМассив Из МассивEmail Цикл
				emailsMAS.Добавить(ЭлМассив.АдресЭп);
			КонецЦикла;
			requestContactParams.Вставить("emails", emailsMAS);
		КонецЕсли;
		МассивТелефонов = ПараметрыСтатуса.Объект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
		phonesMAS = Новый Массив;
		Если МассивТелефонов.Количество() > 0 Тогда
			Для Каждого ЭлМассив Из МассивТелефонов Цикл
				phonesMAS.Добавить(ЭлМассив.НомерТелефона);
			КонецЦикла;
			requestContactParams.Вставить("phones", phonesMAS);
		КонецЕсли;
		requestContactParams.Вставить("date", СтрЗаменить(Формат(ПараметрыСтатуса.Объект.ДатаСоздания, "ДФ=dd-MM-yyyy hs:mm:ss"),".", "-"));
		requestContactParams.Вставить("requestTypeToMatch", "nearest");
		requestContactParams.Вставить("searchDepth", 525600);
		matchingtypeSTRrequestContact = Новый Структура;
		matchingtypeSTRrequestContact.Вставить("type", "requestContact");
		matchingtypeSTRrequestContact.Вставить("requestContactParams", requestContactParams); 
		
		Если emailsMAS.Количество() > 0 Или phonesMAS.Количество() > 0 Тогда 
			matchingtype.Добавить(matchingtypeSTRrequestContact);
		КонецЕсли;
		
		leadsSTR.Вставить("matching", matchingtype);
		
		addTagsSTR = Новый Структура;
		addTagsSTR.Вставить("overwrite", false);
		addTagMASS = Новый Массив;
		addTagsSTRtag = Новый Структура;
		Если ПараметрыСтатуса.Объект.Статус = Перечисления.СтатусыЗаявок.Отклонена Тогда
			addTagsSTRtag.Вставить("tag", "Заявка отклонена");
		Иначе
			addTagsSTRtag.Вставить("tag", "Заявка принята");
		КонецЕсли;
		addTagMASS.Добавить(addTagsSTRtag);
		addTagsSTR.Вставить("tags", addTagMASS);
		leadsSTR.Вставить("addTags", addTagsSTR);
		
		leads.Добавить(leadsSTR);
		
		//////////////////////////////// ЗАПРОС //////////////////////
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("leads", leads);
		
		ТекстЗапроса     = СобратьJson(ПараметрыЗапроса);
		
		UrlApi = "api.calltouch.ru";
		
		Соединение = Новый HTTPСоединение(UrlApi,,,,,,НОвый ЗащищенноеСоединениеOpenSSL());
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
		ЗаголовкиHTTP.Вставить("SiteId", ВнешняяСистемаCalltouch.КлючПриложения);
		ЗаголовкиHTTP.Вставить("Access-Token", СтруктураПараметров.ApiToken);
		
		HTTPЗапрос = Новый HTTPЗапрос("/lead-service/v1/api/tag/lead/add", ЗаголовкиHTTP);		
		HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
		
		ВозвращаемыйРезультат = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Возврат ВозвращаемыйРезультат.КодСостояния = 200;
		
		Ответ = ВозвращаемыйРезультат.ПолучитьТелоКакСтроку();
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхCalltouch", УровеньЖурналаРегистрации.Ошибка,,, НСтр("ru= 'Ошибка обновления заявок Calltouch.';en= 'Error updating Calltouch deals.'") + ОписаниеОшибки);
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции

// Функция, отправляет данные о сделке в Я Метрика
//
Функция ОтправитьСделкуВЯМетрика(ПараметрыСтатуса)
		
	ДанныеВнешнейСистемы = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ПараметрыСтатуса.ВнешняяСистема, "Параметры, ТокенДоступа");
	ПараметрыВС = ?(ЗначениеЗаполнено(ДанныеВнешнейСистемы.Параметры), ДанныеВнешнейСистемы.Параметры.Получить(), Новый Структура);
		
	Если НЕ ЗначениеЗаполнено(ДанныеВнешнейСистемы.ТокенДоступа) ИЛИ
		НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыВС, "МассивСтруктурныхЕдиниц") Тогда
		Возврат Ложь;	
	КонецЕсли;
	
	ДанныеСделки = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПараметрыСтатуса.Объект, "Контрагент, СтруктурнаяЕдиница, ЭтапСделки, ДатаСделки, Прием"); // ,ДатаЗавершенияСделки	 	
	
	Если НЕ ЗначениеЗаполнено(ДанныеСделки.Контрагент) ИЛИ НЕ ЗначениеЗаполнено(ДанныеСделки.СтруктурнаяЕдиница) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Счетчик = "";
	
	Для Каждого Элемент Из ПараметрыВС.МассивСтруктурныхЕдиниц Цикл
		Если ЗначениеЗаполнено(Элемент.Счетчик) И Элемент.СтруктурнаяЕдиница = ДанныеСделки.СтруктурнаяЕдиница Тогда
			Счетчик = Элемент.Счетчик; 
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(Счетчик) Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	ПараметрыЗапроса = "{
	|""order_statuses"" : [ 
	|{
	|""id"" : ""001"",
	|""humanized"" : ""Сделка создана"",
	|""type"" : ""IN_PROGRESS"" 
	|},
	|{
	|""id"" : ""002"",
	|""humanized"" : ""Успех"",
	|""type"" : ""PAID"" 
	|},
	|{
	|""id"" : ""003"",
	|""humanized"" : ""Отмена"",
	|""type"" : ""CANCELLED"" 
	|}
	|]
	|}";
	
	Метод = "order_statuses";
	ОтветОтСервера = ОтправитьДанныеВЯндекс(ПараметрыЗапроса, Счетчик, Метод, ДанныеВнешнейСистемы.ТокенДоступа);
	
	Если СтрНайти(ОтветОтСервера, "true") = 0 Тогда
		КомментарийОшибки = НСтр("ru= 'Ошибка обновления сделок Я.Метрика.';en= 'Error updating Yandex metika deals.'");
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхЯМетрика", УровеньЖурналаРегистрации.Ошибка,,, КомментарийОшибки + " " + ОтветОтСервера);
		Возврат Ложь;
	КонецЕсли;      
	
	///////////////////   Передаем данные клиента  ////////////
	///////////////////////////////////////////////////////////
			
	ДанныеКонтрагента = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ДанныеСделки.Контрагент, "ДатаРегистрации, Наименование");
	
	// Справочники.Контрагенты.ПолучитьМассивНомеровТелефонаКонтрагента(Контрагент);
	
	МассивТелефонов = ДанныеСделки.Контрагент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
	МассивEmail = ДанныеСделки.Контрагент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
	ДатаСозданияКонтрагента = СтрЗаменить(Формат(ДанныеКонтрагента.ДатаРегистрации, "ДФ='yyyy-MM-dd HH:mm:ss'"), ".", "-");
	ТекущаяДата = СтрЗаменить(Формат(ТекущаяДатаСеанса() - 61, "ДФ='yyyy-MM-dd HH:mm:ss'"), ".", "-"); 

	ПараметрыЗапросаНачало = "{
	|""contacts"":
	|[
	|{
	|""uniq_id"" : """ + Строка(ДанныеСделки.Контрагент.УникальныйИдентификатор()) + """,
	|""name"" : """ + ДанныеКонтрагента.Наименование + """,
	|""create_date_time"" : """ + ДатаСозданияКонтрагента + """,
	|""update_date_time"" : """ + ТекущаяДата + """";
	
	ПараметрыЗапросаСередина = "";
	
	ТаблицаИДКлиента = ПолучитьИДКлиента(ДанныеСделки.Контрагент);
	Если ТаблицаИДКлиента.Количество() > 0 Тогда	
		ПараметрыЗапросаСередина = ",
		|""client_ids"" : [";
		Для Каждого Элемент Из ТаблицаИДКлиента Цикл
			ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + """" + Элемент.ym_cid + """,";	
		КонецЦикла;
		ПараметрыЗапросаСередина = Лев(ПараметрыЗапросаСередина, СтрДлина(ПараметрыЗапросаСередина)-1) + "]";	
	КонецЕсли;
	
	Если МассивТелефонов.Количество() > 0 Тогда
		
		ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + ",
		|""phones"": [";
		Для Каждого ЭЛМассив Из МассивТелефонов Цикл
			ПараметрыЗапросаСередина = ПараметрыЗапросаСередина +  """" + СокрЛП(ЭЛМассив.НомерТелефона) + """,";
		КонецЦикла;
		ПараметрыЗапросаСередина = Лев(ПараметрыЗапросаСередина, СтрДлина(ПараметрыЗапросаСередина)-1) + "]";
		
	КонецЕсли;
	
	Если МассивEmail.Количество() > 0 Тогда
		
		ПочтаСтрокой = "";
		АдресЭПДобавлен = Ложь;
		Для Каждого ЭЛМассив Из МассивEmail Цикл		
			
			EmailПредставление = СокрЛП(ЭЛМассив.Представление);
			
			Если НЕ ОбщегоНазначенияКлиентСервер.АдресЭлектроннойПочтыСоответствуетТребованиям(EmailПредставление) Тогда
				Продолжить;
			КонецЕсли;
			АдресЭПДобавлен = Истина;
			
			ПочтаСтрокой = ПочтаСтрокой +  """" + EmailПредставление + """,";
			
		КонецЦикла; 
		
		Если АдресЭПДобавлен Тогда
			
			ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + ",
			|""emails"": [" + Лев(ПочтаСтрокой, СтрДлина(ПочтаСтрокой)-1) + "]";

		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыЗапросаКонец = "
	//|""attribute_values"" : {
	//|""age"" : " + ВозрастКонтрагента + ",
	//|""first_seen"" : ""2020-03-15"",
	//|""dates_of_meetings"" : [""2020-04-17"", ""2020-04-19"", ""2020-05-03""]
	//|}
	|}
	|]
	|}";
	
	ПараметрыЗапроса = ПараметрыЗапросаНачало + ПараметрыЗапросаСередина + ПараметрыЗапросаКонец;
	Метод = "contacts";
	ОтветОтСервера = ОтправитьДанныеВЯндекс(ПараметрыЗапроса, Счетчик, Метод, ДанныеВнешнейСистемы.ТокенДоступа);
	
	Если СтрНайти(ОтветОтСервера, "PASSED") = 0 Тогда		
		КомментарийОшибки = НСтр("ru= 'Ошибка обновления сделок Я.Метрика.';en= 'Error updating Yandex metika deals.'");
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхЯМетрика", УровеньЖурналаРегистрации.Ошибка,,, КомментарийОшибки + " " + ОтветОтСервера);
		Возврат Ложь;
	КонецЕсли; 

	///////////////////   Передаем данные сделки  /////////////
	///////////////////////////////////////////////////////////
	
	ДатаСозданияСделки = СтрЗаменить(Формат(ДанныеСделки.ДатаСделки, "ДФ='yyyy-MM-dd HH:mm:ss'"), ".", "-");	
	
	// ДатаЗавершенияСделки = СтрЗаменить(Формат(ДанныеСделки.ДатаЗавершенияСделки, "ДФ='yyyy-MM-dd HH:mm:ss'"), ".", "-");	
	//|""finish_date_time"" : """ + ДатаЗавершенияСделки + """"
	
	ПараметрыЗапросаНачало = "{
	|""orders"":
	|[
	|{
	|""id"" : """ + Строка(ПараметрыСтатуса.Объект.УникальныйИдентификатор()) + """,
	|""client_uniq_id"" : """ + Строка(ДанныеСделки.Контрагент.УникальныйИдентификатор()) + """,
	|""client_type"" : ""CONTACT"",
	|""create_date_time"" : """ + ДатаСозданияСделки + """,";
	
	ПараметрыЗапросаСередина = "";	
		
	Если ПараметрыСтатуса.Статус = Перечисления.СтатусыСквознойАналитики.СделкаСостоялась Тогда 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПриемЛечение.Номенклатура.Наименование КАК НоменклатураНаименование,
		|	ПриемЛечение.Количество КАК Количество,
		|	ПриемЛечение.Сумма КАК Сумма
		|ИЗ
		|	Документ.Прием.Лечение КАК ПриемЛечение
		|ГДЕ
		|	ПриемЛечение.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПриемЗапасы.Номенклатура.Наименование,
		|	ПриемЗапасы.Количество,
		|	ПриемЗапасы.Сумма
		|ИЗ
		|	Документ.Прием.Запасы КАК ПриемЗапасы
		|ГДЕ
		|	ПриемЗапасы.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", ДанныеСделки.Прием);	
		ТЗЗапасы = Запрос.Выполнить().Выгрузить();
		
		СуммаПриема = ТЗЗапасы.Итог("Сумма");
		
		ПараметрыЗапросаСередина =  "
		|""order_status"" : ""002"",
		|""revenue"" :  " + СтрЗаменить(Формат(СуммаПриема, "ЧН=; ЧГ="), ",", ".");
		
		Если ТЗЗапасы.Количество() > 0 Тогда
			
			ЗапросЗапасы = ",
			|""products"" : {"; 
			Для Каждого ЭлементТЗ Из ТЗЗапасы Цикл
				ЗапросЗапасы = ЗапросЗапасы + """" + СтрЗаменить(ЭлементТЗ.НоменклатураНаименование, """", "") + """ :" + ЭлементТЗ.Количество + ",";
			КонецЦикла;  
			ЗапросЗапасы = Лев(ЗапросЗапасы, СтрДлина(ЗапросЗапасы)-1) + "}"; 
			ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + ЗапросЗапасы;
			
		КонецЕсли;		
		
	ИначеЕсли ПараметрыСтатуса.Статус = Перечисления.СтатусыСквознойАналитики.СделкаУдалена ИЛИ
		ПараметрыСтатуса.Статус = Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась Тогда
		
		ПараметрыЗапросаСередина =  "
		|""order_status"" : ""003""";	
	Иначе
		
		ПараметрыЗапросаСередина =  "
		|""order_status"" : ""001""";	
		
	КонецЕсли;
	
	ПараметрыЗапросаКонец = "
	|}
	|]
	|}";
	
	ПараметрыЗапроса = ПараметрыЗапросаНачало + ПараметрыЗапросаСередина + ПараметрыЗапросаКонец;
	Метод = "orders";
	ОтветОтСервера = ОтправитьДанныеВЯндекс(ПараметрыЗапроса, Счетчик, Метод, ДанныеВнешнейСистемы.ТокенДоступа);
	
	Если СтрНайти(ОтветОтСервера, "PASSED") = 0 Тогда
		КомментарийОшибки = НСтр("ru= 'Ошибка обновления сделок Я.Метрика.';en= 'Error updating Yandex metika deals.'");
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхЯМетрика", УровеньЖурналаРегистрации.Ошибка,,, КомментарийОшибки + " " + ОтветОтСервера);
		Возврат Ложь;
	КонецЕсли; 

	Возврат Истина;
	
КонецФункции

// Функция, возвращает ответ от сервиса CoMagic, после установки тега.
//
Функция ОтправитьДанныеВЯндекс(ПараметрыЗапроса, Счетчик, Метод, ТокенДоступа)
	
	Попытка
		
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
		
		Соединение = Новый HTTPСоединение("api-metrika.yandex.net",,,,,, ЗащищенноеСоединение);
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
		ЗаголовкиHTTP.Вставить("Authorization" , "OAuth " + ТокенДоступа);
		
		Если Метод = "order_statuses" Тогда
			HTTPЗапрос = Новый HTTPЗапрос("/cdp/api/v1/counter/" + Счетчик + "/schema/order_statuses", ЗаголовкиHTTP);		
		ИначеЕсли Метод = "goals" Тогда
			HTTPЗапрос = Новый HTTPЗапрос("/management/v1/counter/" + Счетчик + "/goals", ЗаголовкиHTTP);
		Иначе
			HTTPЗапрос = Новый HTTPЗапрос("/cdp/api/v1/counter/" + Счетчик + "/data/" + Метод + "?merge_mode=save", ЗаголовкиHTTP);		
		КонецЕсли;
		
		HTTPЗапрос.УстановитьТелоИзСтроки(ПараметрыЗапроса);		
		
		ВозвращаемыйРезультат = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Ответ = ВозвращаемыйРезультат.ПолучитьТелоКакСтроку();
		
		Возврат Ответ;
		
	Исключение
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхЯМетрика", УровеньЖурналаРегистрации.Ошибка,,, НСтр("ru= 'Ошибка обновления сделок Я.Метрика.';en= 'Error updating Yandex metika deals.'"));
	КонецПопытки;
	
КонецФункции

// Функция - Получить ИДКлиента.
//
Функция ПолучитьИДКлиента(Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
	|	Заявки.Ссылка КАК Ссылка,
	|	Заявки.ym_cid КАК ym_cid
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ОсновнойКлиент = &Контрагент
	|	И Заявки.ym_cid <> """" ";	

	Запрос.УстановитьПараметр("Контрагент", Контрагент);	
	Выборка = Запрос.Выполнить().Выгрузить();

	Возврат Выборка;
	
КонецФункции

// Функция - Собрать json
//
// Параметры:
//  СтруктураДанных	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СобратьJson(СтруктураДанных) Экспорт
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, СтруктураДанных);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Функция - возвращает номер без нулей
//
// Параметры:
//  СтруктураДанных	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция КраткийНомер(ИсходныйНомер) Экспорт
	
	Номер   = СокрЛП(ИсходныйНомер);
	ЗначащиеЦифры = "123456789";
	Пока Найти(ЗначащиеЦифры,Лев(Номер,1))=0 Цикл
		Номер = Сред(Номер,2);    
	КонецЦикла; 
	Возврат Номер;
	
КонецФункции

// Функция, отправляет данные о сделке в CoMagic.
//
Функция ОтправитьСделкуВCoMagic(ПараметрыСтатуса, ВнешняяСистемаCoMagic, СделатьПаузу = Истина) Экспорт
	
	СтруктураВозврата = Новый Структура("Результат, ПрекратитьВыгрузку", Ложь, Ложь);
	
	Если НЕ ЗначениеЗаполнено(ПараметрыСтатуса) Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Попытка
		
		// Сделки нет.	
		Если НЕ ЗначениеЗаполнено(ПараметрыСтатуса.Сделка) Тогда	
			СтруктураВозврата.Результат = Истина;
			Возврат СтруктураВозврата; 
		КонецЕсли;
		
		ВнешняяСистема = ?(ЗначениеЗаполнено(ПараметрыСтатуса.ВнешняяСистема)
						 И ПараметрыСтатуса.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.CoMagic
						 , ПараметрыСтатуса.ВнешняяСистема
						 , ВнешняяСистемаCoMagic);
				
		Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
			Возврат СтруктураВозврата;		
		КонецЕсли;
				
		ПараметрыВС = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВнешняяСистема, "Параметры").Получить();
						
		Если ТипЗнч(ПараметрыВС) = Тип("Структура")
			И ПараметрыВС.Свойство("Токен")
			И ЗначениеЗаполнено(ПараметрыВС.Токен) Тогда
			
			ApiТокен = ПараметрыВС.Токен;
			
		Иначе
			Возврат СтруктураВозврата;
		КонецЕсли;
		
		// Учет лимита по запросам
		limits = Новый Структура();
		
		///////////////////////// УДАЛЕНИЕ СДЕЛОК //////////////////////////////////////////////////////////////
		
		Если ЗначениеЗаполнено(ПараметрыСтатуса.Статус) И ПараметрыСтатуса.Статус = Перечисления.СтатусыСквознойАналитики.СделкаУдалена Тогда
			
			Код = Формат(Число(КраткийНомер(ПараметрыСтатуса.СделкаКод)), "ЧГ=0");
			
			ПараметрыЗапроса = "{
			|""jsonrpc"": ""2.0"",
			|""id"":" + ?(ЗначениеЗаполнено(Код), Код, 1) + ",
			|""method"": ""delete.deals"",
			|""params"": {
			|""access_token"": """ + ApiТокен + """, 
			|""ext_id"": """+ Строка(ПараметрыСтатуса.Сделка.УникальныйИдентификатор()) +"""
			|}
			|}";  
			
			ОтветОтСервераУдаление = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
			
			// Вариант что такой сделки в CoMagic нет. Тогда возвращаем Истина и удаляем запись из регистра
			Если ОтветОтСервераУдаление.Свойство("error") И ОтветОтСервераУдаление.error.message <> ("Entity not found") Тогда
				Возврат СтруктураВозврата;
			Иначе
				СтруктураВозврата.Результат = Истина;
				Возврат СтруктураВозврата;
			КонецЕсли;
			
		КонецЕсли;
		
		///////////////////////// СДЕЛКИ ПРОДАЖ //////////////////////////////////////////////////////////////
		ПараметрыЗапроса = "{
		|""jsonrpc"":""2.0"",
		|""id"":1,
		|""method"":""get.sales_funnel"",
		|""params"":{
		|""access_token"":""" + ApiТокен + """,
		|""filter"":{
      	|""field"":""name"",
      	|""operator"":""="",
     	|""value"":"""+ПараметрыСтатуса.ВидСделкиНаименование+"""
    	|}
		|}
		|}";
		
		ОтветОтСервераВоронка = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);

#Область ПроверкаНаОшибки		
		
		РезультатПроверки = ПроверитьВозможностьВыгрузкиСделокВComagic(ОтветОтСервераВоронка, СделатьПаузу, ApiТокен, Истина);
		
		Если (НЕ РезультатПроверки.Результат) И РезультатПроверки.ПрекратитьВыгрузку Тогда
			
			Возврат РезультатПроверки; // Такая же структура как и в СтруктураВозврата.
			
		ИначеЕсли (НЕ РезультатПроверки.Результат) И РезультатПроверки.ПовторноСделатьЗапрос Тогда
			
			// В ходе проверки был обновлен лимит и можно выгружать сделки дальше. Прокинем этот запрос еще раз, чтобы вернул "result".						
			ОтветОтСервераВоронка = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
			
		КонецЕсли;

#КонецОбласти		
		
		Проверка = Ложь;
		ВоронкаДляСделки = Неопределено;
		
		Если ТипЗнч(ОтветОтСервераВоронка) = Тип("Структура") 
			И ОтветОтСервераВоронка.Свойство("result")
			И ОтветОтСервераВоронка.result.data.Количество() > 0 Тогда
			
			ВоронкаДляСделки = ОтветОтСервераВоронка.result.data[0];
			Проверка = Истина;
			
		КонецЕсли;
		
		Код = Формат(Число(КраткийНомер(ПараметрыСтатуса.ВидСделкиКод)), "ЧГ=0");

		Если Проверка = Ложь Тогда
			
			ВоронкаНаименование = СтрЗаменить(Строка(ПараметрыСтатуса.ВидСделкиНаименование), """", "\"""); // Экранируем кавычки.
			
			ПараметрыЗапросаНачало = "{
			|""jsonrpc"":""2.0"",
			|""id"":" + Код + ",
			|""method"":""create.sales_funnel"",
			|""params"":{
			|""access_token"":""" + ApiТокен + """,
			|""ext_id"":""" + Код + """,
			|""name"":""" + СокрЛП(ВоронкаНаименование) + """,
			|""stages"":{
			|""success"":{
			|""ext_id"":""1000"",
			|""name"":""Успех""
			|},
			|""failed"":{
			|""ext_id"":""1001"",
			|""name"":""Отказ""
			|},
			|""in_process"":[";
			
			ПараметрыЗапросаСередина = "";
			
			МассивЭтаповДляВоронки = Новый Массив;
			МассивЭтаповДляВоронки.Добавить(Новый Структура("stage_ext_id, stage_name, stage_status", "1000", "Успех", "success"));
			МассивЭтаповДляВоронки.Добавить(Новый Структура("stage_ext_id, stage_name, stage_status", "1001", "Отказ", "failed"));
			
			МассивВидовСделок = Справочники.ЭтапыСделок.ВернутьМассивЭтаповВидаСделки(ПараметрыСтатуса.ВидСделки);
			Для Каждого ЭлМассива Из МассивВидовСделок Цикл
				
				НаименованиеЭтапа = СтрЗаменить(Строка(ЭлМассива.Наименование), """", "\"""); // Экранируем кавычки.
				
				ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + "{""ext_id"":""" + (ЭлМассива.НомерЭтапа + 1) +
				""",""name"":""" + СокрЛП(НаименованиеЭтапа) + """,""order"":" + ((ЭлМассива.НомерЭтапа + 1) * 10) + "},"; 
				
				МассивЭтаповДляВоронки.Добавить(Новый Структура("stage_ext_id, stage_name, stage_status", Строка(ЭлМассива.НомерЭтапа + 1), СокрЛП(НаименованиеЭтапа), "in_process"));
				
			КонецЦикла;
			ПараметрыЗапросаСередина = Лев(ПараметрыЗапросаСередина, СтрДлина(ПараметрыЗапросаСередина)-1);
			
			ПараметрыЗапросаКонец = "
			|]
			|}
			|}
			|}";	
			
			ПараметрыЗапроса = ПараметрыЗапросаНачало + ПараметрыЗапросаСередина + ПараметрыЗапросаКонец;
			
			ОтветОтСервераВоронка = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
			
			// Создаем сделку из сделки, т.к. она нужна ниже для этапов прохода сделки.			
			ВоронкаДляСделки = Новый Структура("ext_id, name, stages", Код, СокрЛП(ВоронкаНаименование), МассивЭтаповДляВоронки);
			
		Иначе
			
			МассивВидовСделок = Справочники.ЭтапыСделок.ВернутьМассивЭтаповВидаСделки(ПараметрыСтатуса.ВидСделки);
			МассивВCoMagic = ВоронкаДляСделки.stages;
			
			Если МассивВидовСделок.Количество() <> (МассивВCoMagic.Количество() - 2) Тогда
				
				Для Каждого ЭлМассива Из ВоронкаДляСделки.stages Цикл
					 Если ЭлМассива.stage_status = "in_process" Тогда
				   	 ПараметрыЗапроса = "{
				   	 |""jsonrpc"": ""2.0"",
				   	 |""id"": " + ОтветОтСервераВоронка.id + ",
				   	 |""method"": ""delete.sales_funnel_stages"",
				   	 |""params"": {
				   	 |""access_token"": """ + ApiТокен + """,
				   	 |""sales_funnel_ext_id"": """ + Код + """,
				   	 |""ext_id"": """ + ЭлМассива.stage_ext_id + """
				   	 |}
				   	 |}";
				   	 
				   	 ОтветОтСервераВоронка = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
				    КонецЕсли;
				КонецЦикла;
				Для Каждого ЭлМассива Из МассивВидовСделок Цикл
				    ПараметрыЗапроса = "{
				    |""jsonrpc"": ""2.0"",
				    |""id"":" + ОтветОтСервераВоронка.id + ",
				    |""method"": ""create.sales_funnel_stages"",
				    |""params"": {
				    |""access_token"": """ + ApiТокен + """,
				    |""sales_funnel_ext_id"": """ + Код + """,
				    |""ext_id"": """ + (ЭлМассива.НомерЭтапа + 1) + """,
				    |""name"": """ + Строка(ЭлМассива.Наименование) + """,
				    |""order"": " + ((ЭлМассива.НомерЭтапа + 1) * 10) + "
				    |}
				    |}";
				    ОтветОтСервераВоронка = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
		
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
						
		///////////////////////////////  ПОДГОТОВКА ДАННЫХ ////////////////////////////////////////////////////////
		
		 // Если нет данных по контрагенту или сотруднику,
		 // то выгрузим сделку с пустыми идентификаторами в соответствующих полях,
		 // а в качестве имен укажем <Не указан>.
		
		Если НЕ ЗначениеЗаполнено(ПараметрыСтатуса.Менеджер) Тогда	
		    СделкаМенеджерНаименование = "<Не указан>";
			СделкаМенеджерКод = ПараметрыСтатуса.СделкаАвторКод;
		Иначе		
		    СделкаМенеджерНаименование = ПараметрыСтатуса.МенеджерНаименование;
			СделкаМенеджерКод = ПараметрыСтатуса.МенеджерКод;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ПараметрыСтатуса.Контрагент) Тогда
			СделкаКонтрагентДатаРегистрации = Дата(1,1,1);
		    СделкаКонтрагентНаименование = "<Не указан>";
			СделкаКонтрагентНаименованиеПолное = "<Не указан>";
			СделкаКонтрагентКод = "1";
		Иначе
			СделкаКонтрагентДатаРегистрации = ПараметрыСтатуса.КонтрагентДатаРегистрации;
			СделкаКонтрагентНаименование = ПараметрыСтатуса.КонтрагентНаименование;
			СделкаКонтрагентНаименованиеПолное = ПараметрыСтатуса.КонтрагентНаименованиеПолное;
			СделкаКонтрагентКод = ПараметрыСтатуса.КонтрагентКод;
		КонецЕсли;
		
		///////////////////////////////  ОТВЕТСТВЕННЫЙ СОТРУДНИК ////////////////////////////////////////////////////////
		
		Код = Формат(Число(КраткийНомер(СделкаМенеджерКод)), "ЧГ=0");
		
		ПараметрыЗапроса = "{
		|""jsonrpc"":""2.0"",
		|""id"":" + Код + ",
		|""method"":""get.deal_employees"",
		|""params"":{
		|""access_token"":""" + ApiТокен + """,
		|""filter"":{
		|""field"":""ext_id"",
		|""operator"":""="",
		|""value"":"""+ Строка(ПараметрыСтатуса.Менеджер.ИдентификаторПользователяИБ) +"""
		|}
		|}
		|}";
		
		ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
		
		Проверка = Ложь;		
		Если ТипЗнч(ОтветОтСервера) = Тип("Структура") 
			И ОтветОтСервера.Свойство("result")
			И ОтветОтСервера.result.data.Количество() > 0 Тогда
			
			Проверка = Истина;
			
		КонецЕсли;
		
		Если Проверка = Ложь Тогда
			
			МенеджерНаименование = СтрЗаменить(СделкаМенеджерНаименование, """", "\"""); // Экранируем кавычки.
			
			ПараметрыЗапроса = "{
			|""jsonrpc"": ""2.0"",
			|""id"":" + Код + ",
			|""method"": ""create.deal_employees"",
			|""params"": {
			|""access_token"":""" + ApiТокен + """,
			|""ext_id"": """ + Строка(ПараметрыСтатуса.Менеджер.ИдентификаторПользователяИБ) + """,
			|""name"": """ + СокрЛП(МенеджерНаименование) + """
			|}
			|}";
			ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
			
		КонецЕсли;
		
		//////////////////////////////////////// КОНТРАГЕНТ /////////////////////////////////////////////////////////
		
		ПараметрыЗапроса = "{
		|""jsonrpc"":""2.0"",
		|""id"":1,
		|""method"":""get.deal_contacts"",
		|""params"":{
		|""access_token"":""" + ApiТокен + """,
		|""filter"":{
		|""field"":""ext_id"",
		|""operator"":""="",
		|""value"":"""+Строка(ПараметрыСтатуса.Контрагент.УникальныйИдентификатор())+"""
		|}
		|}
		|}";
		
		ОтветОтСервера1 = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
		
		Если ОтветОтСервера1.Свойство("result") И ОтветОтСервера1.result.Свойство("metadata") И  ОтветОтСервера1.result.metadata.Свойство("limits") Тогда				
			limits = ОтветОтСервера1.result.metadata.limits;					
		КонецЕсли;
		
		Проверка = Ложь;
		Если ТипЗнч(ОтветОтСервера1) = Тип("Структура") 
			И ОтветОтСервера1.Свойство("result")
			И ОтветОтСервера1.result.data.Количество() > 0 Тогда
			
			КонтрагентДляПроверки = ОтветОтСервера1.result.data[0];
			Проверка = Истина;
			
		КонецЕсли;
		
		Код = Формат(Число(КраткийНомер(СделкаКонтрагентКод)), "ЧГ=0");
		
		ИмяКонтрагента = ?(ЗначениеЗаполнено(СделкаКонтрагентНаименованиеПолное), СделкаКонтрагентНаименованиеПолное, СделкаКонтрагентНаименование);
		ИмяКонтрагента = СтрЗаменить(ИмяКонтрагента, """", "\""");
		
		Если Проверка = Ложь Тогда
			
			КонтактныеДанные = Справочники.Контрагенты.ПолучитьМассивТелефоновИEmailКонтрагента(ПараметрыСтатуса.Контрагент);
			ДатаСозданияКонтрагента = СтрЗаменить(Формат(ПараметрыСтатуса.КонтрагентДатаРегистрации, "ДФ='yyyy-MM-dd HH:mm:ss'"),".", "-");
				
			ПараметрыЗапросаНачало = "{
			|""jsonrpc"": ""2.0"",
			|""id"":" + Код + ",
			|""method"": ""create.deal_contacts"",
			|""params"": {
			|""access_token"":""" + ApiТокен + """,
			|""contacts"": [
			|{
			|""ext_id"": """ + Строка(ПараметрыСтатуса.Контрагент.УникальныйИдентификатор()) + """,
			|""name"": """ + СокрЛП(ИмяКонтрагента) + """"; 
			
			ПараметрыЗапросаСередина = "";
			
			Если КонтактныеДанные.Телефоны.Количество() > 0 Тогда
				ПараметрыЗапросаСередина = """phone_numbers"": [";
				Для Каждого ЭЛМассив Из  КонтактныеДанные.Телефоны Цикл
					ПараметрыЗапросаСередина = ПараметрыЗапросаСередина +  """" + СокрЛП(ЭЛМассив) + """,";
				КонецЦикла;
				ПараметрыЗапросаСередина = Лев(ПараметрыЗапросаСередина, СтрДлина(ПараметрыЗапросаСередина)-1) + "]";
			КонецЕсли;
			
			КэшПараметрыЗапросаСередина = ПараметрыЗапросаСередина;
			АдресЭПДобавлен = Ложь;
			
			Если КонтактныеДанные.Email.Количество() > 0 Тогда
				ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + ?( КонтактныеДанные.Телефоны.Количество() > 0, ",""emails"": [", """emails"": [");			
				Для Каждого ЭЛМассив Из КонтактныеДанные.Email Цикл
					
					АдресЭП = СокрЛП(ЭЛМассив);
					
					// Проверка на валидность. Если почта не валидна, то контрагент не будет 
					// создан и не будет отправлена сделка.
					Если НЕ ОбщегоНазначенияКлиентСервер.АдресЭлектроннойПочтыСоответствуетТребованиям(АдресЭП) Тогда
						Продолжить;
					КонецЕсли;	
					АдресЭПДобавлен	= Истина;
					
					ПараметрыЗапросаСередина = ПараметрыЗапросаСередина +  """" + АдресЭП + """,";
					
				КонецЦикла;
				
				ПараметрыЗапросаСередина = Лев(ПараметрыЗапросаСередина, СтрДлина(ПараметрыЗапросаСередина)-1) + "]";
			КонецЕсли;
			
			Если НЕ АдресЭПДобавлен Тогда
				ПараметрыЗапросаСередина = КэшПараметрыЗапросаСередина;	
			КонецЕсли;
			
			ПараметрыДатаСозданияКлиента = ?(ЗначениеЗаполнено(ДатаСозданияКонтрагента),
											",
											|""created_date_time"":""" + ДатаСозданияКонтрагента + """", "");
			
			ПараметрыЗапросаНачало = ПараметрыЗапросаНачало + ПараметрыДатаСозданияКлиента + ?(ЗначениеЗаполнено(ПараметрыЗапросаСередина), ",","") + "";
									
			ПараметрыЗапросаКонец = "
			|}
			|]
			|}
			|}";
			
			ПараметрыЗапроса = ПараметрыЗапросаНачало + ПараметрыЗапросаСередина + ПараметрыЗапросаКонец;
			
			ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
			
		Иначе
			Если НЕ КонтрагентДляПроверки.name = СокрЛП(ИмяКонтрагента) Тогда
				
				ПараметрыЗапроса = "{
				|""jsonrpc"": ""2.0"",
				|""id"":" + Код + ",
				|""method"": ""update.deal_employees"",
				|""params"": {
				|""access_token"":""" + ApiТокен + """,
				|""ext_id"": """ + Строка(ПараметрыСтатуса.Контрагент.УникальныйИдентификатор()) + """,
				|""name"": """ + СокрЛП(ИмяКонтрагента) + """
				|}
				|}";
				
				ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
				
			КонецЕсли;
		КонецЕсли;
		
		//////////////////////////////////////////////// СДЕЛКИ ////////////////////////////////////////////////////////////
		
			
		ДатаСделки = СтрЗаменить(Формат(ПараметрыСтатуса.СделкаДатаСделки, "ДФ='yyyy-MM-dd HH:mm:ss'"),".", "-");
		Код = Формат(Число(КраткийНомер(ПараметрыСтатуса.СделкаКод)), "ЧГ=0");
		
		ПараметрыЗапросаНачало = "{
		|""jsonrpc"":""2.0"",
		|""id"":" + Код + ",
		|""method"":""upload.deals_history"",
		|""params"":{
		|""access_token"":""" + ApiТокен + """,
		|""deals"":[";
		
		ПараметрыЗапросаСередина = "";
		
		КоличествоЭтапов = 1;
		ИсторияЭтаповТЗ = Справочники.Сделки.ПолучитьТаблицуИсторииИзмененийЭтаповСделки(ПараметрыСтатуса.Сделка);
		
		Для Каждого СтрокаТЧ Из ИсторияЭтаповТЗ Цикл
			
			ЭтапСделки = "";
			Для Каждого ЭлВоронки Из ВоронкаДляСделки.stages Цикл
				Если ЭлВоронки.stage_name = СтрокаТЧ.ПереходНаЭтапНаименование Тогда
					ЭтапСделки = ЭлВоронки.stage_ext_id;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если ЭтапСделки <> "" Тогда 
				
				ЭтотЭтапЗавершен = СтрокаТЧ.ПереходНаЭтап = Справочники.ЭтапыСделок.Успех ИЛИ СтрокаТЧ.ПереходНаЭтап = Справочники.ЭтапыСделок.Отказ;
				
				// Если переходили с Успеха на Отказ или наоборот, то этот этап нужно пропустить. Нужен только последний итоговый этап.
				Если НЕ (КоличествоЭтапов = ИсторияЭтаповТЗ.Количество()) И ЭтотЭтапЗавершен Тогда
					
					КоличествоЭтапов = КоличествоЭтапов + 1;
					Продолжить;
					
				КонецЕсли;
				
				СделкаНаименование = СтрЗаменить(ПараметрыСтатуса.СделкаНаименование, """", "\"""); // Экранируем кавычки.
				
				ДатаНовогоЭтапа = СтрЗаменить(Формат(СтрокаТЧ.Дата + 1, "ДФ='yyyy-MM-dd HH:mm:ss'"),".", "-");
				СуммаСделки = ?(ЗначениеЗаполнено(ПараметрыСтатуса.ПриемСуммаДокумента), ПараметрыСтатуса.ПриемСуммаДокумента, ПараметрыСтатуса.СуммаСделки);
				СуммаСделки = СтрЗаменить(Формат(СуммаСделки, "ЧГ="),",",".");
				
				СделкаОписание = СтрЗаменить(ПараметрыСтатуса.СделкаОписание, "\", "\\");
				СделкаОписание = СтрЗаменить(СделкаОписание, """", "\""");
				СделкаОписание = СтрЗаменить(СделкаОписание, Символы.ПС, " ");
				СделкаОписание = СтрЗаменить(СделкаОписание, Символы.ВК, "");
				
				ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + "{
				|""ext_id"":""" + Строка(ПараметрыСтатуса.Сделка.УникальныйИдентификатор()) + """,
				|""name"":""" + СокрЛП(СделкаНаименование) + """,
				|""created_date_time"":""" + ДатаСделки + """,";
				
				Если ЭтотЭтапЗавершен Тогда 
					ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + "
					|""closed_date_time"":""" + ДатаНовогоЭтапа + """,";
				КонецЕсли;
				
				ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + "
				|""modified_date_time"":""" + ДатаНовогоЭтапа + """,
				|""modified_stage_date_time"":""" + ДатаНовогоЭтапа + """,
				|""contact_ext_ids"":[
				|""" + Строка(ПараметрыСтатуса.Контрагент.УникальныйИдентификатор()) + """
				|],
				|""main_contact_ext_id"": """ + Строка(ПараметрыСтатуса.Контрагент.УникальныйИдентификатор()) + """,
				|""employee_ext_id"": """ + Строка(ПараметрыСтатуса.Менеджер.ИдентификаторПользователяИБ) + """, ";
				
				Если СуммаСделки <> "" Тогда
					ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + "
					|""revenue"":" + СуммаСделки + ",";
				КонецЕсли;
				
				ПараметрыЗапросаСередина = ПараметрыЗапросаСередина + "
				|""sales_funnel_ext_id"": """ + ВоронкаДляСделки.ext_id + """,
				|""stage_ext_id"": """ + ЭтапСделки + """,
				|""comments"": """ + СокрЛП(СделкаОписание) + """
				|},";
			КонецЕсли;
			
			КоличествоЭтапов = КоличествоЭтапов + 1;
			
		КонецЦикла;
		ПараметрыЗапросаСередина = Лев(ПараметрыЗапросаСередина, СтрДлина(ПараметрыЗапросаСередина)-1);
		
		ПараметрыЗапросаКонец = "
		|]
		|}
		|}";
		
		ПараметрыЗапроса = ПараметрыЗапросаНачало + ПараметрыЗапросаСередина + ПараметрыЗапросаКонец;
		
		ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
		
		// Проверка на лимит запросов.
		// В CoMagic лимит составляет 60 запросов в минуту.
		// Все, что отправлено свыше принято не будет, а значит и сделки не уйдут в CoMagic.
		
		// limits также инициализируется при выполнении "upload.deals_history", но может быть
		// Ошибка загрузки сделки и мы не сможем увидеть лимит, 
		// А "get.deal_employees" должен выполниться без проблем. 
		
		// Пытаемся удалить сделку которая существует уже в CoMagic.
		Если ОтветОтСервера.Свойство("error") Тогда
			
			Код = Формат(Число(КраткийНомер(ПараметрыСтатуса.СделкаКод)), "ЧГ=0");
			
			ПараметрыЗапросаУдаление = "{
			|""jsonrpc"": ""2.0"",
			|""id"":" + ?(ЗначениеЗаполнено(Код), Код, 1) + ",
			|""method"": ""delete.deals"",
			|""params"": {
			|""access_token"": """ + ApiТокен + """, 
			|""ext_id"": """+ Строка(ПараметрыСтатуса.Сделка.УникальныйИдентификатор()) +"""
			|}
			|}";  
			
			ОтветОтСервераУдаление = ПолучитьОтветОтCoMagic(ПараметрыЗапросаУдаление);
			
			// Пробуем выгрузить еще раз!
			ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
			
		КонецЕсли;
		
		Если СделатьПаузу Тогда
			
			Если ОтветОтСервера.Свойство("result") И ОтветОтСервера.result.Свойство("metadata") И  ОтветОтСервера.result.metadata.Свойство("limits") Тогда 			
				limits = ОтветОтСервера.result.metadata.limits;				
			КонецЕсли;

			Если Значениезаполнено(limits) Тогда
				СделатьПаузуДоОбновленияЛимитаОтправок(limits, Истина);
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не ОтветОтСервера.Свойство("error") Тогда
			СтруктураВозврата.Результат = Истина;
			Возврат СтруктураВозврата;
		//ИначеЕсли ОтветОтСервера.Свойство("error") И ОтветОтСервера.error.code = -32602 Тогда.
		//	Возврат Истина;
		КонецЕсли;
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("ОбновлениеДанныхComagic", УровеньЖурналаРегистрации.Ошибка,,, НСтр("ru= 'Ошибка обновления сделок Comagic.';en= 'Error updating Comagic deals.'") + ОписаниеОшибки);
	КонецПопытки;

	Возврат СтруктураВозврата;

КонецФункции

// Функция, устанавливает теги у заявок в CoMagic.
// 
Функция ПроставитьТегиCoMagic(ПараметрыСтатуса, ВнешняяСистемаCoMagic, СделатьПаузу = Истина) Экспорт
			
	Попытка
		
		Если НЕ ЗначениеЗаполнено(ПараметрыСтатуса) ИЛИ НЕ ТипЗнч(ПараметрыСтатуса.Объект) = Тип("СправочникСсылка.Заявки") Тогда
			Возврат Ложь;
		КонецЕсли;
		
		ВнешняяСистема = ?(ЗначениеЗаполнено(ПараметрыСтатуса.ВнешняяСистема)
						 И ПараметрыСтатуса.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.CoMagic
						 , ПараметрыСтатуса.ВнешняяСистема
						 , ВнешняяСистемаCoMagic);
				
		Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
			Возврат Ложь;		
		КонецЕсли;
					
		ПараметрыВС = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВнешняяСистема, "Параметры").Получить();
						
		Если ТипЗнч(ПараметрыВС) = Тип("Структура")
			И ПараметрыВС.Свойство("Токен")
			И ЗначениеЗаполнено(ПараметрыВС.Токен) Тогда
			
			ApiТокен = ПараметрыВС.Токен;
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
		IdТега = Формат(ПолучитьIdТегаПоСтатусу(ПараметрыСтатуса.Статус), "ЧГ=");
		IdТегаДляСнятия = 0;
		ИтоговыйТегИзменился = Ложь;
		
		Если НЕ ЗначениеЗаполнено(IdТега) Тогда
			// Такого тега нет, заявка всегда будет висеть в регистре
			// и никогда не будет отправлена! Истина = удаляем!
			Возврат Истина;
		КонецЕсли;
							
		Если НЕ ЗначениеЗаполнено(ПараметрыСтатуса.communication_id) И НЕ ЗначениеЗаполнено(ПараметрыСтатуса.communication_type) Тогда
			// Заявку нужно удалить, она всегда будет висеть в регистре, 
			// т.к. она не учтена в comagic, и ее статус никогда не будет отправлен!
			Возврат Истина; 
		КонецЕсли;
		
		communication_type	= НРег(Строка(ПараметрыСтатуса.communication_type));
		
		// Учет лимита по запросам.
		limits = Новый Структура();
		
		// IdТегов:
		// Заявка отклонена     = 88
		// Заявка принята       = 1556
		// Сделка создана       = 24498
		// Сделка не создана    = 1111
		// Сделка не состоялась = 42169 + Сделка удалена
		// Сделка состоялась    = 1555
		
		// ТЕГИ ЗАЯВОК
		// Не требуется что-то снимать, т.к. статус устаналивается только один раз и больше не может меняться.
		
		// ТЕГИ СДЕЛОК:								
		Если ПараметрыСтатуса.Статус = Перечисления.СтатусыСквознойАналитики.СделкаУдалена Тогда
			// Если сделка дошла до успеха и была удалена, то меняем тег на "сделка не состоялась".
			IdТегаДляСнятия = ?(ПараметрыСтатуса.ЭтапСделки = Справочники.ЭтапыСделок.Успех, 1555, 0);				
		Иначе				
			// Если сделка состоялась или не состоялась, то удаляем тег "Сделка создана".			
			Если IdТега = "42169" ИЛИ IdТега = "1555" Тогда
				IdТегаДляСнятия = 24498;						
			КонецЕсли;				
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(IdТега) И НЕ IdТега = "1555" Тогда
			
			ПараметрыЗапроса = "{
			|""jsonrpc"":""2.0"",
			|""id"":""Helix"",
			|""method"":""set.tag_communications"",
			|""params"":{
			|""access_token"":""" + ApiТокен + """,
			|""communication_id"":" + ПараметрыСтатуса.communication_id + ",
			|""communication_type"":""" + communication_type + """,
			|""tag_id"":" + IdТега + "
			|}
			|}";	
			
		ИначеЕсли ЗначениеЗаполнено(IdТега) И IdТега = "1555" Тогда
			
			СуммаСделки	= ?(ЗначениеЗаполнено(ПараметрыСтатуса.ПриемСуммаДокумента), ПараметрыСтатуса.ПриемСуммаДокумента, ПараметрыСтатуса.СуммаСделки);
			
			ПараметрыЗапроса = "{
			|""jsonrpc"":""2.0"",
			|""id"":""Helix"",
			|""method"":""set.tag_sales"",
			|""params"":{
			|""access_token"":""" + ApiТокен + """,
			|""communication_id"":" + ПараметрыСтатуса.communication_id + ",
			|""communication_type"":""" + communication_type + """,
			|""date_time"":""" + Строка(Формат(ПараметрыСтатуса.ДатаИзменения, "ДФ=""yyyy-MM-dd hh:mm:ss""")) + """,
			|""transaction_value"":" + Формат(СуммаСделки, "ЧН=0; ЧГ=") + ",
			|""comment"":""set.tag_sales продажа""
			|}
			|}";
			
		КонецЕсли;	
			
		Если НЕ IdТегаДляСнятия = 0 Тогда
			
			ПараметрыСнятияТега = "{
			|""jsonrpc"":""2.0"",
			|""id"":""Helix"",
			|""method"":""unset.tag_communications"",
			|""params"":{
			|""access_token"":""" + ApiТокен + """,
			|""communication_id"":" + ПараметрыСтатуса.communication_id + ",
			|""communication_type"":""" + communication_type + """,
			|""tag_id"":" + Формат(IdТегаДляСнятия, "ЧГ=") + "
			|}
			|}";
			
			// Снимаем теги.
			ПолучитьОтветОтCoMagic(ПараметрыСнятияТега); 
		КонецЕсли;
		
		Если ЗначениеЗаполнено(IdТега) Тогда	
			ОтветОтСервера = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
		Иначе
			Возврат Истина;
		КонецЕсли;
		
		Если СделатьПаузу Тогда
			
			Если ОтветОтСервера.Свойство("result") И ОтветОтСервера.result.Свойство("metadata") И  ОтветОтСервера.result.metadata.Свойство("limits") Тогда 			
				limits = ОтветОтСервера.result.metadata.limits;				
			КонецЕсли;
			
			Если Значениезаполнено(limits) Тогда
				СделатьПаузуДоОбновленияЛимитаОтправок(limits, Истина);
			КонецЕсли;
			
		КонецЕсли;	
		
		Если Не ОтветОтСервера.Свойство("error") Тогда
			Возврат Истина;
		ИначеЕсли ОтветОтСервера.Свойство("error") И ОтветОтСервера.error.code = -32602 Тогда
			Возврат Истина;
		КонецЕсли;			
		
	Исключение
		ЗаписьЖурналаРегистрации("ОбновлениеТеговCoMagic", УровеньЖурналаРегистрации.Ошибка,,, НСтр("ru= 'Ошибка установки тегов CoMagic.';en= 'Error installing CoMagic tags.'"));
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции

// Функция, возвращает ответ от сервиса CoMagic.
//
Функция ПолучитьОтветОтCoMagic(ПараметрыЗапроса)

	Если ОбщегоНазначения.ЭтоLinuxСервер() Тогда
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	Иначе
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL( 
									Новый СертификатКлиентаWindows(), 
									Новый СертификатыУдостоверяющихЦентровWindows()); 
	КонецЕсли;
	
	//HTTPСоединение = Новый HTTPСоединение("dataapi-partner.comagic.ru",,,,,, ЗащищенноеСоединение); 
	HTTPСоединение = Новый HTTPСоединение("dataapi.uiscom.ru",,,,,, ЗащищенноеСоединение);
	
	ЗаголовкиHTTP  = Новый Соответствие; 
	ЗаголовкиHTTP.Вставить("Content-Type","application/json; charset=UTF-8");
	
	HTTPЗапрос  = Новый HTTPЗапрос("/v2.0", ЗаголовкиHTTP);	
	мДатаНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	HTTPЗапрос.УстановитьТелоИзСтроки(?(ЗначениеЗаполнено(ПараметрыЗапроса), ПараметрыЗапроса, ""));
	
	Запрос = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	мДатаКонца = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ВремяВыполненияЗапроса = (мДатаКонца - мДатаНачала) /1000;
	
	ТекстJSON  = Запрос.ПолучитьТелоКакСтроку(); 
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);	
	
	Возврат ПараметрыJSON;
	
КонецФункции

// Функция, возвращает id тега по статусу.
//
Функция ПолучитьIdТегаПоСтатусу(Статус)
	
	IdТега = 0;
	
	Если Статус = Перечисления.СтатусыСквознойАналитики.ЗаявкаОтклонена Тогда
		IdТега = 88;	
	ИначеЕсли Статус = Перечисления.СтатусыСквознойАналитики.ЗаявкаПринята Тогда
		IdТега = 1556;
	ИначеЕсли Статус = Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась ИЛИ 
			  Статус = Перечисления.СтатусыСквознойАналитики.СделкаУдалена Тогда	  
		IdТега = 42169;
	ИначеЕсли Статус = Перечисления.СтатусыСквознойАналитики.СделкаСоздана Тогда
		IdТега = 24498;
	ИначеЕсли Статус = Перечисления.СтатусыСквознойАналитики.СделкаСостоялась Тогда
		IdТега = 1555;
	ИначеЕсли Статус = Перечисления.СтатусыСквознойАналитики.СделкаНеСоздана Тогда
		IdТега = 1111;
	КонецЕсли;	
	
	Возврат IdТега;
	
КонецФункции	

// Процедура - Сделать паузу до обновления лимита отправок.
//
// Параметры:
//  limits		 - 	 Структура с лимитами, которую возвращает CoMagic если запрос удачен (result.metadata.limits) 
//  СделатьПаузу - 	 Истина, если необходимо сделать паузу согласно лимиту, который вернулся из CoMagic 
//
Процедура СделатьПаузуДоОбновленияЛимитаОтправок(limits, СделатьПаузу = Истина)

	Если ТипЗнч(limits) = Тип("Структура") Тогда
		
		// За основу взято 8 запросов, которые необходимо выполнить (6 на сделки и 2 на теги) для загрузки данных в CoMagic,
		// учитывая: 
		// - что сделки создаваться не больше будут (либо новых сделок не так много)
		// - этапы в сделках меняться не будут. Но если будут, всеравно будем учитывать лимит!
		НеобходимыйМинимум = 8;
		
		ЛимитОстаток = ?(limits.Свойство("minute_remaining"), Число(limits.minute_remaining), 0);  	
		
		Если ЛимитОстаток < НеобходимыйМинимум Тогда
			
			ЛимитОбновление = ?(limits.Свойство("minute_reset"), Число(limits.minute_reset), 60);
			
			Если СделатьПаузу Тогда
								
				ОбщегоНазначенияБТС.Пауза(ЛимитОбновление+5);
				
			КонецЕсли;
			
		КонецЕсли;
				
	КонецЕсли;
	
КонецПроцедуры

// Функция - Проверить возможность выгрузки сделок.
//
// Параметры:
//  ОтветОтСервера	 - 	 Ответ, который вернулся из Comagic
//  СделатьПаузу	 - 	 Нужно ли делать паузу (если предполагается ошибка limit_exceeded)
//  ApiТокен		 - 	 Токен Comagic, можно не заполнять, если СделатьПаузу = Ложь
//  СделатьЗаписьВЖурнал  - Нужно ли сделать запись об ошибке в журнал регистрации.
// 
// Возвращаемое значение:
//   - Структура с ключами типа булево - Результат, ПрекратитьВыгрузку, ПовторноСделатьЗапрос
//
Функция ПроверитьВозможностьВыгрузкиСделокВComagic(ОтветОтСервера, СделатьПаузу, ApiТокен = Неопределено, СделатьЗаписьВЖурнал = Ложь)
	
	СтруктураВозврата = Новый Структура("Результат, ПрекратитьВыгрузку, ПовторноСделатьЗапрос", Истина, Ложь, Ложь);
	
	Если ТипЗнч(ОтветОтСервера) = Тип("Структура")
			И ОтветОтСервера.Свойство("error") Тогда
			
			КодОшибки = Неопределено;
			МнемоникаОшибки = "";
			ОтветОтСервера.error.Свойство("code", КодОшибки); 						
			Если ОтветОтСервера.error.Свойство("data") Тогда
				ОтветОтСервера.error.data.Свойство("mnemonic", МнемоникаОшибки);		
			КонецЕсли;
			
			ЕстьОшибка = Ложь;
			
			// Других ошибок не наблюдалось и можно не прекращать выгрузку!
			
			Если КодОшибки = -32029 И СтрЧислоВхождений(МнемоникаОшибки, "limit_exceeded") > 0 Тогда															
				
				Если СделатьПаузу И ЗначениеЗаполнено(ApiТокен) Тогда
 
					// Если можно сделать паузу, то ждем минуту и прокинем тестовый запрос.
					// Можно сразу завершить выгрузку всех сделок, но для надежности сделаем проверку.
					// Если всеравно приходит ошибка, то с чистой совестью завершаем. Лимиты точно закончились!
					
					СделатьПаузуДоОбновленияЛимитаОтправок(Новый Структура, Истина);
					ПараметрыЗапроса = "{""jsonrpc"":""2.0"", ""id"":1, ""method"":""get.sales_funnel"", ""params"":{""access_token"":""" + ApiТокен + """}}";
					ОтветОтСервераПроверкаЛимита = ПолучитьОтветОтCoMagic(ПараметрыЗапроса);
					
					// А если, подождав минуту, лимиты обновились и снова доступна выгрузка,
					// то возвращаем Истину в параметре ПовторноСделатьЗапрос,
					// чтоб не оставлять эту сделку на следующий день!
					
					Если ТипЗнч(ОтветОтСервераПроверкаЛимита) = Тип("Структура") И (НЕ ОтветОтСервераПроверкаЛимита.Свойство("error")) Тогда
                        СтруктураВозврата.ПовторноСделатьЗапрос = Истина;
						Возврат СтруктураВозврата;
					КонецЕсли;
					
				КонецЕсли;	
									
				ЕстьОшибка = Истина;				
				Если СделатьЗаписьВЖурнал Тогда
					ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Ошибка при выгрузке сделок в Comagic"
																			, УровеньЖурналаРегистрации.Предупреждение,,
																	 		, "Выгрузка прекращена, закончился лимит для выгрузки сделок!");															
				КонецЕсли;	
			ИначеЕсли КодОшибки = -32001 И СтрЧислоВхождений(МнемоникаОшибки, "access_token_") > 0 Тогда															 
				
				ЕстьОшибка = Истина;														
				Если СделатьЗаписьВЖурнал Тогда
					ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Ошибка при выгрузке сделок в Comagic"
																			, УровеньЖурналаРегистрации.Ошибка,,
																	 		, "Ошибка аутентификации! Токен не найден, заблокирован, либо срок его жизни истек!");	
				КонецЕсли;	
			КонецЕсли;
			
			Если ЕстьОшибка Тогда				
				СтруктураВозврата.Результат = Ложь;
				СтруктураВозврата.ПрекратитьВыгрузку = Истина;					
			КонецЕсли;

		КонецЕсли;
		
		Возврат СтруктураВозврата;
		
КонецФункции

// Процедура, обновляет данные контр страхования. 
//
Процедура ОбновлениеДанныхКонтрСтрахование() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	ВнешняяСистемаКС = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.КонтурСтрахование, Истина);
	
	Если ЗначениеЗаполнено(ВнешняяСистемаКС) Тогда
		
		ПараметрыВС = ВнешняяСистемаКС.Параметры.Получить();
		
		ВременныйФайл = ПолучитьИмяВременногоФайла();
		
		Запись = Новый ЗаписьТекста(ВременныйФайл, "UTF-8");
		Запись.Записать(""+ПараметрыВС.clientId+":"+ПараметрыВС.clientSecret);
		Запись.Закрыть();
		
		ДвДанные = Новый ДвоичныеДанные(ВременныйФайл);
		
		КодТокена = Сред(Base64Строка(ДвДанные),5);
		КодТокена = СтрЗаменить(КодТокена,Символы.ПС,"");
		КодТокена = СтрЗаменить(КодТокена,Символы.ВК,"");
		
		Запрос = Новый HTTPЗапрос("/connect/token");
		Запрос.Заголовки.Вставить("Authorization", "Basic "+КодТокена);
		
		ИмяФайлаОтправки = ПолучитьимяВременногоФайла("txt");
		Boundary = СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
		
		ЗаписьТекста = Новый ЗаписьТекста(ИмяФайлаОтправки,"UTF-8");
		
		ЗаписьТекста.ЗаписатьСтроку("--"+boundary);
		ЗаписьТекста.ЗаписатьСтроку("Content-Disposition: form-data; name=""grant_type""");
		ЗаписьТекста.ЗаписатьСтроку("");
		ЗаписьТекста.ЗаписатьСтроку("client_credentials");
		
		ЗаписьТекста.ЗаписатьСтроку("--"+boundary);
		ЗаписьТекста.ЗаписатьСтроку("Content-Disposition: form-data; name=""scope""");
		ЗаписьТекста.ЗаписатьСтроку("");
		ЗаписьТекста.ЗаписатьСтроку("medi_api");
		
		ЗаписьТекста.ЗаписатьСтроку("--"+boundary+"--");
		
		ЗаписьТекста.Закрыть();
		
		ОБ_ДД=Новый ДвоичныеДанные(имяФайлаОтправки);
		Стр_Base64=Base64Строка(ОБ_ДД);
		ОБ_ДД=Base64Значение(Сред(Стр_Base64,5));
		ОБ_ДД.Записать(имяФайлаОтправки);
		
		ФайлОтправки = Новый Файл(имяФайлаОтправки);
		РазмерФайлаОтправки = XMLСтрока(ФайлОтправки.Размер());
		
		Запрос.Заголовки.Вставить("Content-Type", "multipart/form-data; boundary="+boundary);
		Запрос.Заголовки.Вставить("Content-Lenght", РазмерФайлаОтправки);	
		
		Запрос.УстановитьТелоИзДвоичныхДанных(ОБ_ДД);
		
		Если ПараметрыВС.Демо Тогда
			АдресСервера = "identity.testkontur.ru";	
		Иначе
			АдресСервера = "identity.kontur.ru";
		КонецЕсли;
		
		Ответ = ВыполнитьHTTPМетод("POST", Запрос, АдресСервера); 
		
		Если Ответ.КодСостояния = 400 Тогда
			ЗаписьЖурналаРегистрации("Неверный путь: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
		ИначеЕсли Ответ.КодСостояния = 403 Тогда
			ЗаписьЖурналаРегистрации("Нет доступа: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
		ИначеЕсли Ответ.КодСостояния = 401 Тогда
			ЗаписьЖурналаРегистрации("Запрос не авторизован: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
		ИначеЕсли Ответ.КодСостояния >= 300 Тогда
			ЗаписьЖурналаРегистрации("Не удалось выполнить запрос: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
		ИначеЕсли Ответ.КодСостояния = 200 Тогда	
			
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
			Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
			ТокенДоступа = Результат.Получить("access_token");
			
			ТаблицаВСКонтурСтрахования = Справочники.ВнешниеСистемы.ПолучитьВнешниеСистемы(Перечисления.ТипыВнешнихСистем.КонтурСтрахование, Истина);
			Если ТаблицаВСКонтурСтрахования.Количество() > 0 Тогда
				
				ВСКонтурСтрахованияОбъект = ТаблицаВСКонтурСтрахования[0].Ссылка.ПолучитьОбъект();
				ВСКонтурСтрахованияОбъект.ТокенДоступа = ТокенДоступа;
				ВСКонтурСтрахованияОбъект.Записать();
				
			КонецЕсли;
			
			Запрос = Новый HTTPЗапрос("/V2/parties");
			Запрос.Заголовки.Вставить("Authorization", "Bearer "+ТокенДоступа);
			
			Если ПараметрыВС.Демо Тогда
				АдресСервера = "medi-api.testkontur.ru";	
			Иначе
				АдресСервера = "medi-api.kontur.ru";
			КонецЕсли;
		
			Ответ = ВыполнитьHTTPМетод("GET", Запрос, АдресСервера);
			
			Если Ответ.КодСостояния = 403 Тогда
				ЗаписьЖурналаРегистрации("Нет доступа ни к одной организации: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
			ИначеЕсли Ответ.КодСостояния = 401 Тогда
				ЗаписьЖурналаРегистрации("Запрос не авторизован: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
			ИначеЕсли Ответ.КодСостояния >= 300 Тогда
				ЗаписьЖурналаРегистрации("Не удалось выполнить запрос: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
			ИначеЕсли Ответ.КодСостояния = 200 Тогда	
				
				ЧтениеJSON = Новый ЧтениеJSON;
				ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
				Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
				
				Если ТипЗнч(Результат) = Тип("Массив") Тогда
					Для Каждого Эл Из Результат Цикл
						
						lastEventPointer = РегистрыСведений.СообщенияКонтурСтрахование.ПоследнееПисьмо();
						Результат = ПолучитьСобытия(Эл.Получить("mediId"), lastEventPointer, 100, ТокенДоступа, АдресСервера);
						
						ПолучитьСписокСобытийНаСервере(Результат);
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
	
	РегистрыСведений.СообщенияКонтурСтрахование.ОбработатьСообщенияКонтурСтрахование();
	
КонецПроцедуры

// Функция выполняет HTTP соединение
//
Функция ВыполнитьHTTPМетод(Метод, Запрос, Хост)
	
	Возврат Соединение(Хост).ВызватьHTTPМетод(Метод, Запрос);
	
КонецФункции

// Функция возвращает новое соединение
//
Функция Соединение(Хост)

	Порт = 443;
	
	Соединение = Новый HTTPСоединение(Хост, Порт,,,,,Новый ЗащищенноеСоединениеOpenSSL);
		
	Возврат Соединение;

КонецФункции

// Функция получает события от Контур.Страхвание
//
Функция ПолучитьСобытия(mediId, lastEventPointer = "", Количество = 100, ТокенДоступа, АдресСервера) Экспорт

	Запрос = Новый HTTPЗапрос();
	Запрос.АдресРесурса = "/V2/events";
	Запрос.Заголовки.Вставить("Authorization", "Bearer "+ ТокенДоступа);
	
	URL_УстановитьПараметр(Запрос.АдресРесурса, "mediId", mediId);
	URL_УстановитьПараметр(Запрос.АдресРесурса, "count", Количество);
	Если ЗначениеЗаполнено(lastEventPointer) Тогда
		URL_УстановитьПараметр(Запрос.АдресРесурса, "lastEventPointer", lastEventPointer);
	КонецЕсли;
	        
	Ответ = ВыполнитьHTTPМетод("GET", Запрос, АдресСервера);
	
	Если Ответ.КодСостояния = 401 Тогда
		ЗаписьЖурналаРегистрации("Запрос не авторизован: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
	ИначеЕсли Ответ.КодСостояния = 400 Тогда
		ЗаписьЖурналаРегистрации("Некорректный запрос: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
	ИначеЕсли Ответ.КодСостояния >= 300 Тогда
		ЗаписьЖурналаРегистрации("Не удалось выполнить запрос: ", УровеньЖурналаРегистрации.Ошибка,,, Ответ.ПолучитьТелоКакСтроку());
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
	
	Результат = ПрочитатьJSON(ЧтениеJSON, Истина);

	Возврат Результат;

КонецФункции

