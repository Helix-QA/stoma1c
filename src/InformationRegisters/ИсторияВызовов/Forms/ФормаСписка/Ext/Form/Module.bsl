		Если ТипЗнч(ЭлементОтбораТипЗвонка) = Тип("ГруппаФормы") Тогда
			АктуальнаяГруппа = Ложь;
			Для Каждого ЭлементОтбораТипЗвонкаКнопка Из ЭлементОтбораТипЗвонка.ПодчиненныеЭлементы Цикл
				Если ТипЗнч(ЭлементОтбораТипЗвонкаКнопка) = Тип("КнопкаФормы") Тогда
					Если ЭлементОтбораТипЗвонкаКнопка.Имя = "Отбор_ВсеЗвонки" Тогда 
						АктуальнаяГруппа =  ОтборТипЗвонка = 3;
						ЭлементОтбораТипЗвонкаКнопка.ЦветТекста = ?(ОтборТипЗвонка = 3, Новый Цвет(255, 255, 255), Новый Цвет(77, 77, 77));
					ИначеЕсли ЭлементОтбораТипЗвонкаКнопка.Имя = "Отбор_ВходящиеЗвонки" Тогда 
						АктуальнаяГруппа =  ОтборТипЗвонка = 0;
						ЭлементОтбораТипЗвонкаКнопка.ЦветТекста = ?(ОтборТипЗвонка = 0, Новый Цвет(255, 255, 255), Новый Цвет(77, 77, 77));						
					ИначеЕсли ЭлементОтбораТипЗвонкаКнопка.Имя = "Отбор_ИсходящиеЗвонки" Тогда 
						АктуальнаяГруппа =  ОтборТипЗвонка = 1;
						ЭлементОтбораТипЗвонкаКнопка.ЦветТекста = ?(ОтборТипЗвонка = 1, Новый Цвет(255, 255, 255), Новый Цвет(77, 77, 77));												
					ИначеЕсли ЭлементОтбораТипЗвонкаКнопка.Имя = "Отбор_ПропущенныеЗвонки" Тогда 
						АктуальнаяГруппа =  ОтборТипЗвонка = 2;
						ЭлементОтбораТипЗвонкаКнопка.ЦветТекста = ?(ОтборТипЗвонка = 2, Новый Цвет(255, 255, 255), Новый Цвет(77, 77, 77));						
						//Если КоличествоНеОбработанныхЗвонков = 0 Тогда 
						//	ЭлементОтбораТипЗвонкаКнопка.Заголовок = "Пропущенные";
						//Иначе 
						//	ЭлементОтбораТипЗвонкаКнопка.Заголовок = Новый ФорматированнаяСтрока("Пропущенные ", Новый ФорматированнаяСтрока("(Без ответа " + Строка(КоличествоНеОбработанныхЗвонков) + ")", , Новый Цвет(255, 0, 0)));
						//КонецЕсли;
					//ИначеЕсли ЭлементОтбораТипЗвонкаКнопка.Имя = "Отбор_БезОтвета" Тогда
					//	АктуальнаяГруппа =  ОтборТипЗвонка = 4;
					//	ЭлементОтбораТипЗвонкаКнопка.ЦветТекста = ?(ОтборТипЗвонка = 4, Новый Цвет(255, 255, 255), Новый Цвет(77, 77, 77));
					//	Если КоличествоНеОбработанныхЗвонков = 0 Тогда 
					//		ЭлементОтбораТипЗвонкаКнопка.Заголовок = "Без ответа";
					//	Иначе 
					//		ЭлементОтбораТипЗвонкаКнопка.Заголовок = "Без ответа (" + Строка(КоличествоНеОбработанныхЗвонков) + ")";
					//	КонецЕсли;
					КонецЕсли;	
				КонецЕсли;
				Если АктуальнаяГруппа Тогда 
					Прервать;
				КонецЕсли;	
			КонецЦикла;
			Если АктуальнаяГруппа Тогда 
				ЭлементОтбораТипЗвонка.ЦветФона = Новый Цвет(25, 116, 206);
			Иначе 
				ЭлементОтбораТипЗвонка.ЦветФона = Новый Цвет(240, 240, 240);                  
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;	
	
	//ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "НеОбработан", ИСТИНА, ЛОЖЬ, ВидСравненияКомпоновкиДанных.Равно);	
	Если ОтборТипЗвонка = 0 Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ПиктограммаЗвонка", 1, ИСТИНА, ВидСравненияКомпоновкиДанных.Меньше);
	ИначеЕсли ОтборТипЗвонка = 3 Тогда
		ОтборыСписковКлиентСервер.УдалитьЭлементОтбораСписка(Список, "ПиктограммаЗвонка");
	ИначеЕсли ОтборТипЗвонка = 4 Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "НеОбработан", ИСТИНА, ИСТИНА, ВидСравненияКомпоновкиДанных.Равно);
	Иначе 	
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ПиктограммаЗвонка", ОтборТипЗвонка, ИСТИНА, ВидСравненияКомпоновкиДанных.Равно);
	КонецЕсли;	
	
