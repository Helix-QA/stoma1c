// Функция - Найти все сертифкаты в дереве доступных видов оплат сервер
// 
// Возвращаемое значение:
//   - 
// 
Функция НайтиВсеСтрокиСертифкатовВДеревеДоступныхВидовОплатСервер()
	
	СтрокиСертификатов = НайтиВВерхнемУровнеДереваДоступныхВидовОплат(Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат);
	МассивСертификатов = Новый Массив;
	
	Если СтрокиСертификатов <> Неопределено Тогда
		
		Для Каждого СтрокаТ ИЗ СтрокиСертификатов.ПолучитьЭлементы() Цикл
			
			Если ЗначениеЗаполнено(СтрокаТ.СертификатПартия) Тогда
				МассивСертификатов.Добавить(СтрокаТ);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;

    Возврат МассивСертификатов;
	
КонецФункции

&НаКлиенте
// Функция рекурсивного поиска в дереве доступных видов оплаты
Функция НайтиВДеревеДоступныхВидовОплат(	
	ТипДенСредств,
	ЛицевойСчет = Неопределено,								 
	ЭквайрингНомерПлатежнойКарты = Неопределено,
	Сертификат = Неопределено)
	
	МассивСтрок = Новый Массив;
	
	Для Каждого ЭлементВерхУр ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл	
		
		Если ЭлементВерхУр.ТипДенежныхСредств <> ТипДенСредств Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если ЛицевойСчет = Неопределено 
			И ЭквайрингНомерПлатежнойКарты = Неопределено
			И Сертификат = Неопределено Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ЛицевойСчет <> Неопределено 
			И ЭлементВерхУр.ЛицевойСчет = ЛицевойСчет Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ЭквайрингНомерПлатежнойКарты <> Неопределено 
			И ЭлементВерхУр.ЭквайрингНомерПлатежнойКарты = ЭквайрингНомерПлатежнойКарты Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если Сертификат <> Неопределено 
			И ЭлементВерхУр.Сертификат = Сертификат Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Для Каждого ЭлементНизУр ИЗ ЭлементВерхУр.ПолучитьЭлементы() Цикл	
			
			Если ЭлементНизУр.ТипДенежныхСредств <> ТипДенСредств Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			Если ЛицевойСчет = Неопределено 
				И ЭквайрингНомерПлатежнойКарты = Неопределено
				И Сертификат = Неопределено Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;

			Если ЛицевойСчет <> Неопределено 
				И ЭлементНизУр.ЛицевойСчет = ЛицевойСчет Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЭквайрингНомерПлатежнойКарты <> Неопределено 
				И ЭлементНизУр.ЭквайрингНомерПлатежнойКарты = ЭквайрингНомерПлатежнойКарты Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если Сертификат <> Неопределено 
				И ЭлементНизУр.Сертификат = Сертификат Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат МассивСтрок;

КонецФункции

&НаСервере
// Функция рекурсивного поиска в дереве доступных видов оплаты
Функция НайтиВДеревеДоступныхВидовОплатСервер(	
		ТипДенСредств,
		ВидЛицевогоСчета = Неопределено,								 
		ЭквайрингНомерПлатежнойКарты = Неопределено,
		СертификатПартия = Неопределено,
		ИсточникДанных = Неопределено,
		ПервуюСтроку = Ложь,
		ПоследнююСтроку = Ложь,
		ДокументАванса = Неопределено,
		Представление = Неопределено,
		БонусныйСчет = Неопределено,
		Пациент = Неопределено,
		ЭквайринговыйТерминал = Неопределено)
	
	Если ИсточникДанных = Неопределено Тогда
		ИсточникДанных = ЭтотОбъект.ВидыОплат;
	КонецЕсли;
	
	МассивСтрок = Новый Массив;
	
	Для Каждого ЭлементВерхУр ИЗ ИсточникДанных.ПолучитьЭлементы() Цикл	
				
		Если ЭлементВерхУр.ТипДенежныхСредств <> ТипДенСредств Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		Если ТипДенСредств = Перечисления.ТипыДенежныхСредств.Аванс
			И Представление <> Неопределено 
			И ЭлементВерхУр.Представление = Представление Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Прервать;

		КонецЕсли;
		
		Если ТипДенСредств = Перечисления.ТипыДенежныхСредств.БонусныйСчет
			И Представление <> Неопределено 
			И ЭлементВерхУр.Представление = Представление Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Прервать;

		КонецЕсли;

		Если ВидЛицевогоСчета = Неопределено 
			И ЭквайрингНомерПлатежнойКарты = Неопределено
			И СертификатПартия = Неопределено
			И ЭквайринговыйТерминал = Неопределено
			И ТипДенСредств <> Перечисления.ТипыДенежныхСредств.Аванс
			И ТипДенСредств <> Перечисления.ТипыДенежныхСредств.БонусныйСчет Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
	
		Если БонусныйСчет <> Неопределено И ЭлементВерхУр.БонусныйСчет = БонусныйСчет Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ВидЛицевогоСчета <> Неопределено И ЭлементВерхУр.ВидЛицевогоСчета = ВидЛицевогоСчета 
			ИЛИ ВидЛицевогоСчета = Справочники.ВидыЛицевыхСчетов.ПустаяСсылка() И ЭлементВерхУр.ВидЛицевогоСчета = Неопределено Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;

		Если ЭквайрингНомерПлатежнойКарты <> Неопределено 
			И ЭлементВерхУр.ЭквайрингНомерПлатежнойКарты = ЭквайрингНомерПлатежнойКарты Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если СертификатПартия <> Неопределено 
			И ?(ЭлементВерхУр.СертификатПартия = Неопределено, Справочники.ПартииНоменклатуры.ПустаяСсылка(), ЭлементВерхУр.СертификатПартия) = СертификатПартия Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Если ЭквайринговыйТерминал <> Неопределено 
			И ЭлементВерхУр.ЭквайринговыйТерминал = ЭквайринговыйТерминал Тогда
			
			МассивСтрок.Добавить(ЭлементВерхУр);
			Продолжить;
			
		КонецЕсли;
		
		Для Каждого ЭлементНизУр ИЗ ЭлементВерхУр.ПолучитьЭлементы() Цикл	
			
			Если ЭлементНизУр.ТипДенежныхСредств <> ТипДенСредств Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			Если ВидЛицевогоСчета = Неопределено 
				И ЭквайрингНомерПлатежнойКарты = Неопределено
				И СертификатПартия = Неопределено 
				И БонусныйСчет = Неопределено 
				И ДокументАванса = Неопределено 
				И ЭквайринговыйТерминал = Неопределено Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДокументАванса) И ЭлементНизУр.ДокументАванса = ДокументАванса Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;

			Если БонусныйСчет <> Неопределено И ЭлементНизУр.БонусныйСчет = БонусныйСчет Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ВидЛицевогоСчета <> Неопределено И ЭлементНизУр.ВидЛицевогоСчета = ВидЛицевогоСчета И (Пациент <> Неопределено И ЭлементНизУр.Контрагент = Пациент)
				ИЛИ ВидЛицевогоСчета = Справочники.ВидыЛицевыхСчетов.ПустаяСсылка() И ЭлементВерхУр.ВидЛицевогоСчета = Неопределено Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЭквайрингНомерПлатежнойКарты <> Неопределено 
				И ЭлементНизУр.ЭквайрингНомерПлатежнойКарты = ЭквайрингНомерПлатежнойКарты Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если СертификатПартия <> Неопределено 
				И ЭлементНизУр.СертификатПартия = СертификатПартия Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
			Если ЭквайринговыйТерминал <> Неопределено 
				И ЭлементНизУр.ЭквайринговыйТерминал = ЭквайринговыйТерминал Тогда
				
				МассивСтрок.Добавить(ЭлементНизУр);
				Продолжить;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если ПервуюСтроку = Истина Тогда
		Если МассивСтрок.Количество() > 0 Тогда
			Возврат МассивСтрок[0];
		Иначе
			Возврат Неопределено;
		КонецЕсли;		
	ИначеЕсли ПоследнююСтроку = Истина Тогда
		Если МассивСтрок.Количество() > 0 Тогда
			Возврат МассивСтрок[МассивСтрок.Количество() - 1];
		Иначе
			Возврат Неопределено;
		КонецЕсли;		
	Иначе	
		Возврат МассивСтрок;
	КонецЕсли;

КонецФункции

&НаКлиенте
// Функция рекурсивного поиска в дереве доступных видов оплаты
// 
Функция СуммаВнесенныхВидовОплат(
	ТипДенСредств = Неопределено,
	ЛицевойСчет = Неопределено,
	ЭквайрингНомерПлатежнойКарты = Неопределено,
	СертификатПартия = Неопределено)
	
	МассивСтрок = ПолучитьСтрокиСВнесеннойОплатой(ТипДенСредств, ЛицевойСчет, ЭквайрингНомерПлатежнойКарты, СертификатПартия);
	
	Сумма = 0;
	Для Каждого СтрокаОплаты ИЗ МассивСтрок Цикл			
		Сумма = Сумма + СтрокаОплаты.Внесено;		
	КонецЦикла;
	
	Возврат Сумма;
	
КонецФункции

