&НаСервере
// Процедура, отображает дополнительную информацию.
//
Процедура ОтобразитьИнформациюПоОплате()
	
	МассивРодителей = Новый Массив;
	МассивРодителей.Добавить("ГруппаИнформацияПоОплатеПодробно");
	УправлениеСвойствамиСтоматология.ОтображениеДополнительнойИнформации(ЭтаФорма, Объект, МассивРодителей);
	
КонецПроцедуры

&НаСервере
// Инициировать обновление клиентских меток.
//
Процедура ОбновитьМетки();
	
	// Получаем метки
	Метки = РегистрыСведений.МеткиКлиентов.ПолучитьАктивныеМеткиЗаписи(Объект.ДокументОснование);
	Если Метки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Индекс = 0;
	
	Если ЭтаФорма.Команды.Найти("ОтображатьМеткуПриНажатии") = Неопределено Тогда
		Команда 			= ЭтаФорма.Команды.Добавить("ОтображатьМеткуПриНажатии");
		Команда.Действие 	= "ОтображатьМеткуПриНажатии";
	КонецЕсли;

	Индекс = 0;
			
	ПолучитьНовуюСтроку = 0;
	
	// Размещаем элементы меток
	Для Индекс = 0 По Метки.Количество()-1 Цикл
		
		Если ПолучитьНовуюСтроку = 0 Тогда
			Группа_Заглушка_НоваяСтрока = ЭтаФорма.Элементы.Добавить("Группа_Заглушка_Строка" + Индекс, Тип("ГруппаФормы"), Элементы.ГруппаКлиентсикеМетки);
			Группа_Заглушка_НоваяСтрока.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			Группа_Заглушка_НоваяСтрока.Отображение = ОтображениеОбычнойГруппы.Нет;
			Группа_Заглушка_НоваяСтрока.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
			Группа_Заглушка_НоваяСтрока.ОтображатьЗаголовок = Ложь;
		КонецЕсли;
		
		Группа_Заглушка_Выравнивания = ЭтаФорма.Элементы.Добавить("Группа_Заглушка_Выравнивания" + Индекс, Тип("ГруппаФормы"), Группа_Заглушка_НоваяСтрока);
		Группа_Заглушка_Выравнивания.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		Группа_Заглушка_Выравнивания.Отображение = ОтображениеОбычнойГруппы.Нет;
		Группа_Заглушка_Выравнивания.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		Группа_Заглушка_Выравнивания.ОтображатьЗаголовок = Ложь;
		
		
		Группа_Заглушка_Метка = ЭтаФорма.Элементы.Добавить("Группа_Заглушка_" + Индекс, Тип("ГруппаФормы"), Группа_Заглушка_Выравнивания);
		Группа_Заглушка_Метка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		Группа_Заглушка_Метка.Отображение = ОтображениеОбычнойГруппы.Нет;
		Группа_Заглушка_Метка.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		Группа_Заглушка_Метка.ОтображатьЗаголовок = Ложь;
		Группа_Заглушка_Метка.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Одинарный;
		
		ДобавляемыеРеквизиты = Новый Массив;
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ФлажокМ_"+Индекс, Новый ОписаниеТипов("Булево")));
		ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		
		ЭтаФорма["ФлажокМ_"+Индекс] = Истина;
		
		НовыйЭлФлажок = ЭтаФорма.Элементы.Добавить("ФлажокМ_"+Индекс, Тип("ПолеФормы"), Группа_Заглушка_Метка);
		НовыйЭлФлажок.Вид = ВидПоляФормы.ПолеФлажка;
		НовыйЭлФлажок.Видимость = Ложь;
		НовыйЭлФлажок.ВидФлажка = ВидФлажка.Выключатель;
		НовыйЭлФлажок.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		НовыйЭлФлажок.ЦветРамки = ?(ЗначениеЗаполнено(Метки[Индекс].ЦветМетки),ЗначениеИзСтрокиВнутр(Метки[Индекс].ЦветМетки),ЦветаСтиля.ЦветФонаФормы);
		НовыйЭлФлажок.ПутьКДанным = "ФлажокМ_"+Индекс;
		НовыйЭлФлажок.УстановитьДействие("ПриИзменении","ОтображатьМеткуПриНажатии");
		Если ЭтаФорма["ФлажокМ_"+Индекс] Тогда
			Группа_Заглушка_Метка.ЦветФона = ?(ЗначениеЗаполнено(Метки[Индекс].ЦветМетки),ЗначениеИзСтрокиВнутр(Метки[Индекс].ЦветМетки),ЦветаСтиля.ЦветФонаФормы);
		Иначе
			Группа_Заглушка_Метка.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
		КонецЕсли;
		
		КнопкаМ            = ЭтаФорма.Элементы.Добавить("КнопкаМ_"+Индекс,Тип("КнопкаФормы"), Группа_Заглушка_Метка); // Группа_Заглушка_Выравнивания);
		КнопкаМ.Заголовок  = СокрЛП(Строка(Метки[Индекс].Ссылка));
		КнопкаМ.ИмяКоманды = "ОтображатьМеткуПриНажатии";
		КнопкаМ.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
	
		ЦветТекстаМеткиПоУмолчанию = ?(Метки[Индекс].ЦветТекстаБелый = Истина, Новый Цвет(255, 255, 255), Новый Цвет());
		КнопкаМ.ЦветТекста = ?(ЗначениеЗаполнено(Метки[Индекс].ЦветМетки) И ЭтаФорма["ФлажокМ_"+Индекс], ЦветТекстаМеткиПоУмолчанию, Новый Цвет());
		
		Если СтрДлина(КнопкаМ.Заголовок) < 19 Тогда
			КнопкаМ.РастягиватьПоВертикали = Ложь;
		КонецЕсли;
		
		ПолучитьНовуюСтроку = ПолучитьНовуюСтроку + 1;
		Если ПолучитьНовуюСтроку = 9 Тогда
			ПолучитьНовуюСтроку = 0;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

