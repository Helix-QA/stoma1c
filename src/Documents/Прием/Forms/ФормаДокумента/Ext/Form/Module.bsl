&НаКлиенте
// Процедура, обработчик описания оповещения ВыборРазделаОбращенияОкончание.
//
Процедура ВыборМедПолисаОкончание(Результат, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		Объект.ПолисМедСтрахования = Результат;
		ПредВыбранныйСтраховойПолис = Объект.ПолисМедСтрахования;
		
		Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда 			
			СтруктураПолис = ВернутьВидЦеныИДоговорПоПолису(Объект.ПолисМедСтрахования); 
			Если ЗначениеЗаполнено(СтруктураПолис.ВидЦен) Тогда 
				Объект.ВидЦен = СтруктураПолис.ВидЦен;
			Иначе 
				Объект.ВидЦен = КонтрагентСтраховойПолисОчисткаСервер(Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
			КонецЕсли;	
			ЭтотОбъект._ПодборДоговорПолиса = ?(ЗначениеЗаполнено(СтруктураПолис.Договор), СтруктураПолис.Договор, ПредопределенноеЗначение("Справочник.ДоговорыКонтрагентов.ПустаяСсылка"));
		КонецЕсли;
		
		// ТабличныеЧастиПересчетПослеИзменений("Запасы");
		// ТабличныеЧастиПересчетПослеИзменений("Лечение");
		ПересчетТабличныхЧастейФормы(); 
		Если Не Элементы.Найти("ФормаДокументОплатить") = Неопределено Тогда
			Элементы.ФормаДокументОплатить.Доступность = Не ЗначениеЗаполнено(Объект.ПолисМедСтрахования); 
		КонецЕсли;
		// УстановитьОтборСегментНоменклатуры(Объект.ПолисМедСтрахования, Объект.СтруктурнаяЕдиница, Объект.Сотрудник);
		
		ОбновлениеНоменклатурыВТаблицахПодбора("Полис");

	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура, отображает метку полиса.
//
Процедура ОтобразитьМеткуПолиса() 
	
	Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда 
		
		Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования.Договор) 
			И ЗначениеЗаполнено(Объект.ПолисМедСтрахования.Договор.ПрограммаСтрахования) Тогда
				
			ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(Объект.ПолисМедСтрахования.Договор.ПрограммаСтрахования); 
			
			Элементы.ДекорацияПрограммаСтрахования.Заголовок 	= ДанныеПрограммыСтрахования.Текст;
			Элементы.ДекорацияПрограммаСтрахования.ЦветТекста 	= ДанныеПрограммыСтрахования.ЦветТекста;
			Элементы.ГруппаПрограммаСтрахования.ЦветФона 		= ДанныеПрограммыСтрахования.ЦветФона;
			
			Элементы.ГруппаПрограммаСтрахования.Видимость  = Истина;
			
		КонецЕсли;                                                 
		
		
		Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования.СтраховаяКомпания.КраткоеНаименование) Тогда
			Элементы.ГруппаАльфа.Видимость  = Истина;
			ФонМетки = ?(ЗначениеЗаполнено(Объект.ПолисМедСтрахования.СтраховаяКомпания.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(Объект.ПолисМедСтрахования.СтраховаяКомпания.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
			Элементы.ДекорацияАльфа.ЦветТекста  = ?(Объект.ПолисМедСтрахования.СтраховаяКомпания.ЦветТекстаБелый, Новый Цвет(255,255,255), Новый Цвет(77,77,77));
			Элементы.ДекорацияАльфа.Заголовок	= Объект.ПолисМедСтрахования.СтраховаяКомпания.КраткоеНаименование;
			Элементы.ГруппаАльфа.ЦветФона  = ФонМетки; 
		Иначе
			Элементы.ГруппаАльфа.Видимость  = Ложь;
		КонецЕсли;

	Иначе
		Элементы.ГруппаПрограммаСтрахования.Видимость  = Ложь;
		Элементы.ГруппаАльфа.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

