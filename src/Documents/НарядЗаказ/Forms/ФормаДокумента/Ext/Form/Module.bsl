// Процедура, обработчик события "ПередНАчаломДобавления"
//
Процедура ЗапасыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	
	Если Не Копирование Тогда
		Отказ = Истина;		
		НоваяСтрока               = Объект.Запасы.Добавить();
		МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
		Если МассивЗубов.Количество() = 0 Тогда
			НоваяСтрока.Зуб       = ОбщиеПараметры.Перечисление_Зубы_ВсяПолость;
		Иначе
			НоваяСтрока.Зуб		= МассивЗубов[0];
		КонецЕсли;
		НоваяСтрока.Статус        = ПредопределенноеЗначение("Перечисление.СтатусыНарядЗаказа.Заказано");
		НоваяСтрока.Лаборатория   = Объект.Лаборатория;		
		НоваяСтрока.ВидЦен        = Объект.ВидЦен;
		НоваяСтрока.ВидЦенПродажи = Объект.ВидЦенПродажи;
		Элементы.Запасы.Обновить();
		Элементы.Запасы.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
	Если Копирование Тогда
		Отказ       = Истина;
		НоваяСтрока = Объект.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент.ТекущиеДанные);
		НоваяСтрока.НомерЗаказа = "";
		НоваяСтрока.КлючСтроки = Новый УникальныйИдентификатор;
	КонецЕсли;
	
	УстановитьНомерЗаказа();	
	ОбновитьСтатусДокумента();

КонецПроцедуры

