// Процедура, обработчик события "ПередНачаломИзменения"
//
Процедура ТаблицаТоварыПередНачаломИзменения(Элемент, Отказ)
	
	Если Элемент.ТекущийЭлемент.Имя = "ТаблицаТоварыПроцентСкидкиНаценки" Тогда
		Если РазрешенаУстановкаСкидки(Элемент.ТекущиеДанные) Тогда				
			// Открываем форму установки размера скидки
			ПроцентСкидки = ?(Элемент.ТекущиеДанные.КоличествоУпаковок * Элемент.ТекущиеДанные.Цена <> 0, 
			Окр(100 * Элемент.ТекущиеДанные.СуммаРучнойСкидки / (Элемент.ТекущиеДанные.КоличествоУпаковок * Элемент.ТекущиеДанные.Цена) , 2), 0);
			
			СтруктураЗаполнения = Новый Структура("ПроцентСкидки, МаксимальнаяРучнаяСкидка", ПроцентСкидки, ЭтотОбъект.МаксимальнаяРучнаяСкидка);  
			Описание = Новый ОписаниеОповещения("ПослеОткрытияФормыУстановкиРучнойСкидкиТаблицыТовары", ЭтаФорма);
			ОткрытьФорму("ОбщаяФорма.ФормаУстановкиРучнойСкидки", СтруктураЗаполнения,,,,, Описание, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 												
			
		КонецЕсли; 
