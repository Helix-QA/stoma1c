// Функция - Регистрация организации виджета
// 
// Параметры:
//  Организация	 - 	 - 
//  ApiKey		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция РегистрацияОрганизацииВиджета(Организация, ApiKey) Экспорт
	
	Попытка 
				
		ПараметрыОрганизации = Новый Структура;
		ПараметрыОрганизации.Вставить("id"	       			, ЛичныйКабинет.ПолучитьУИДИнформационнойБазы());
		ПараметрыОрганизации.Вставить("name"       			, ?(Не ЗначениеЗаполнено(Организация), ПолучитьНаименованиеОрганизации(), Организация.Наименование));
		ПараметрыОрганизации.Вставить("api_key"	   			, ApiKey);
		ПараметрыОрганизации.Вставить("use_advanced_name"	, Ложь);
		ПараметрыОрганизации.Вставить("use_birthday"		, Ложь);
					
		ВнешняяСитемаОнлайнЗаписи = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(ApiKey);    
		
		Если ЗначениеЗаполнено(ВнешняяСитемаОнлайнЗаписи) Тогда
			
			ПараметрыОрганизации.Вставить("auth_skip_confirm", ВнешняяСитемаОнлайнЗаписи.АвторизацияПоКодуБезСМС);
			
			ПараметрыВС = ВнешняяСитемаОнлайнЗаписи.Параметры.Получить();
			
			Если ТипЗнч(ПараметрыВС) = Тип("Структура") Тогда 					
				ПараметрыОрганизации.Вставить("use_advanced_name"	, ?(ПараметрыВС.Свойство("РазделенныеПоляФИО")		, ПараметрыВС.РазделенныеПоляФИО		, Ложь));
				ПараметрыОрганизации.Вставить("use_birthday"		, ?(ПараметрыВС.Свойство("ВыводитьДатуРождения")	, ПараметрыВС.ВыводитьДатуРождения		, Ложь));
				ПараметрыОрганизации.Вставить("use_email"			, ?(ПараметрыВС.Свойство("ВыводитьПочту")			, ПараметрыВС.ВыводитьПочту				, Ложь));
				ПараметрыОрганизации.Вставить("use_notify"			, ?(ПараметрыВС.Свойство("ВыводитьПолеНапоминания")	, ПараметрыВС.ВыводитьПолеНапоминания	, Ложь));
				ПараметрыОрганизации.Вставить("metric_js"			, ?(ПараметрыВС.Свойство("FacebookPixel")			, ПараметрыВС.FacebookPixel				, ""));
			КонецЕсли;
			
		КонецЕсли;
			
		МассивОрганизаций = Новый Массив;
		МассивОрганизаций.Добавить(ПараметрыОрганизации);
		
		ПарамтерыЗапроса = Новый Структура("organizations", МассивОрганизаций);
		РезультатЗапроса = ВыполнитьPOSTЗапросВReservi("add_org", ПарамтерыЗапроса);
		
		РезультатаОперции = СтруктураСтандартынхПараметровРезОперации();

		Если РезультатЗапроса.КодСостояния <> 200  Тогда
			ВызватьИсключение "КодОшибки = " + РезультатЗапроса.КодСостояния + ", Ошибка: " +  РезультатЗапроса.ПолучитьТелоКакСтроку();
		Иначе
			
			Ответ = РезультатЗапроса.ПолучитьТелоКакСтроку();
			
			Если СтрНайти(Ответ, """status"":true") > 0 Тогда
				РезультатаОперции.ВыполненоУспешно = Истина;
			Иначе
				ВызватьИсключение "Ошибка: " + Ответ;
			КонецЕсли;
						
		КонецЕсли;
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатаОперции;

КонецФункции

// Функция - Регистрация структурных единиц виджета
// 
// Параметры:
//  СтруктурныеЕдиницы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция РегистрацияСтруктурныхЕдиницВиджета(СтруктурныеЕдиницы) Экспорт
	
	Попытка
		
		МассивПараметровСтруктурныхЕдиниц = Новый Массив;
		
		Для Каждого СтрЕдиница ИЗ СтруктурныеЕдиницы Цикл
			
			Контакты = КонтактнаяИнформацияВызовСервераСтома.ПолучитьКонтактнуюИнформацию(СтрЕдиница);
			id = ?(ЗначениеЗаполнено(СтрЕдиница.УникальныйИдентификаторСтруктурнойЕдиницы), СтрЕдиница.УникальныйИдентификаторСтруктурнойЕдиницы, Строка(СтрЕдиница.УникальныйИдентификатор()));
			
			ПараметрыСтруктурнойЕдиницы = Новый Структура;
			ПараметрыСтруктурнойЕдиницы.Вставить("name"		    , СтрЕдиница.Наименование);
			ПараметрыСтруктурнойЕдиницы.Вставить("id"		    , id);
			ПараметрыСтруктурнойЕдиницы.Вставить("org_id"	    , ЛичныйКабинет.ПолучитьУИДИнформационнойБазы());
			ПараметрыСтруктурнойЕдиницы.Вставить("email"		, Контакты.Email);
			ПараметрыСтруктурнойЕдиницы.Вставить("address_full" , Контакты.Адрес);
			ПараметрыСтруктурнойЕдиницы.Вставить("address_short", ?(ЗначениеЗаполнено(Контакты.КороткийАдрес),Контакты.КороткийАдрес, ""));
			ПараметрыСтруктурнойЕдиницы.Вставить("phone"		, Контакты.Телефон);
			ПараметрыСтруктурнойЕдиницы.Вставить("country"		, Контакты.Город);
			ПараметрыСтруктурнойЕдиницы.Вставить("gmap_point"   , СтрШаблон("%1,%2", СтрЕдиница.Широта, СтрЕдиница.Долгота));
			ПараметрыСтруктурнойЕдиницы.Вставить("type"         , "stoma");
			ПараметрыСтруктурнойЕдиницы.Вставить("city"	        , Контакты.Город);
						
			МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(СтрЕдиница.Ссылка, "ЛоготипМагазина");
			МассивФайловКартинокЗаполнен = МассивФайловКартинок.Количество() > 0;
			Если МассивФайловКартинокЗаполнен Тогда
				ВнешняяСистемаReservi	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи);
				ЛогоМагазина 			= "http://cloud.stoma1c.ru/api/hs/api/files/" + ВнешняяСистемаReservi.КлючПриложения 
					+ "/" + Строка(МассивФайловКартинок[0].УникальныйИдентификатор()) + "." + МассивФайловКартинок[0].Расширение;
				ПараметрыСтруктурнойЕдиницы.Вставить("logo"  		, ЛогоМагазина);
			КонецЕсли;
			МассивПараметровСтруктурныхЕдиниц.Добавить(ПараметрыСтруктурнойЕдиницы);
			
		КонецЦикла;
		
		ПарамтерыЗапроса = Новый Структура("units", МассивПараметровСтруктурныхЕдиниц);
		РезультатЗапроса = ВыполнитьPOSTЗапросВReservi("add_se", ПарамтерыЗапроса);
		
		РезультатаОперции = СтруктураСтандартынхПараметровРезОперации();

		Если РезультатЗапроса.КодСостояния <> 200  Тогда
			ВызватьИсключение "КодОшибки = " +РезультатЗапроса.КодСостояния + ", Ошибка: " +  РезультатЗапроса.ПолучитьТелоКакСтроку();
		Иначе
			
			Ответ = РезультатЗапроса.ПолучитьТелоКакСтроку();
			
			Если СтрНайти(Ответ, """status"":true") > 0 Тогда 
				РезультатаОперции.ВыполненоУспешно = Истина;
			Иначе
				ВызватьИсключение "Ошибка: " + Ответ;
			КонецЕсли;
						
		КонецЕсли;
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатаОперции;

КонецФункции

