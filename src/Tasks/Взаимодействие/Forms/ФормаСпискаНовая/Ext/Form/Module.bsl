&НаКлиенте
// Процедура, обработчик события "ПланПередНачаломБыстрогоРедактирования".
//
Процедура ПланПередНачаломБыстрогоРедактирования(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если Элемент.ВыделенныеЭлементы.Количество() > 0 Тогда
		
		Задача	   = Элемент.ВыделенныеЭлементы[0].Значение;
		Контрагент = ПолучитьКонтрагентаИзЗадачи(Задача);
		
		Если ЗначениеЗаполнено(Контрагент) Тогда
			ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", Новый Структура("Ключ", Контрагент),,,,,, РежимОткрытияОкнаФормы.Независимый);	 	
		Иначе
			ОткрытьФорму("Задача.Взаимодействие.ФормаОбъекта", Новый Структура("Ключ", Задача),,,,,, РежимОткрытияОкнаФормы.Независимый);	 	
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - План перед удалением.
//
Процедура ПланПередУдалением(Элемент, Отказ)
	
	Если Элемент.ВыделенныеЭлементы.Количество() > 0 Тогда
		Для Каждого ЭлементМассива Из Элемент.ВыделенныеЭлементы Цикл 
			Если ЗначениеЗаполнено(ЭлементМассива.Значение) И ТипЗнч(ЭлементМассива.Значение) = Тип("ЗадачаСсылка.Взаимодействие") Тогда 
				Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭлементМассива.Значение, "Выполнена") Тогда 
					Отказ = Истина;
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Удалять задачи со статусом ""Выполнено"" запрещено!';en='Delete tasks with status ""Done"" prohibited!'"), ЭтотОбъект);
					Прервать;
				// ИначеЕсли ЗначениеЗаполнено(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭлементМассива.Значение, "БизнесПроцесс")) Тогда 
				//	Отказ = Истина;
				//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Удалять задачи принадлежащие бизнес-процессам запрещено!';en='Delete tasks belonging to prohibited business processes!'"), ЭтотОбъект);					
				//	Прервать;
				Иначе 
					ПометитьЗадачуНаУдаление(ЭлементМассива.Значение);
				КонецЕсли;	
			КонецЕсли;	
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "СписокВыбор".
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущаяСтрока 		 = Элементы.Список.ТекущиеДанные;
	
	Если Поле.Имя = "Сделка"
		И ЗначениеЗаполнено(ТекущаяСтрока.Сделка) Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.Сделка);
		
	ИначеЕсли Поле.Имя = "Контрагент" 
		И ЗначениеЗаполнено(ТекущаяСтрока.Контрагент)Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.Контрагент);
		
	Иначе
		
		ПоказатьЗначение(,ТекущаяСтрока.Ссылка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

