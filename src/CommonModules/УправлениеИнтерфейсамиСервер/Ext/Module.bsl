// Функция - Получить структуру фильтра
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуруФильтра() Экспорт
	
	СтруктураФильтра = Новый Структура;
	СтруктураФильтра.Вставить("Представление"							, "");	
	СтруктураФильтра.Вставить("Наименование"							, "");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "");
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "");
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "");
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, Ложь);
	СтруктураФильтра.Вставить("СписокЗначений"							, Неопределено);
	СтруктураФильтра.Вставить("ВариантОтбора"							, Истина);
	СтруктураФильтра.Вставить("Применен" 								, Истина);
	СтруктураФильтра.Вставить("ТолькоПолеВыбора" 						, Ложь);
	СтруктураФильтра.Вставить("РеквизитПолеВыбора" 						, Неопределено);
	СтруктураФильтра.Вставить("РеквизитДата" 							, Дата(1,1,1));
	СтруктураФильтра.Вставить("ЦветВыбранногоЗначения"					, Новый Цвет(218, 230, 244));
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Неопределено);
	СтруктураФильтра.Вставить("ПараметрыПолеВыбора"						, Новый Структура);
	СтруктураФильтра.Вставить("ВыводитьЗаголовокРаздела"				, Ложь);
	
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ПараметрыВыбора"			, Новый ФиксированныйМассив(Новый Массив));
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ФормаВыбора"				, ""); // Образец: "Справочник.Контрагенты.Форма.ФормаВыбора"
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("РежимВыбораИзСписка"		, Ложь);
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ВыбиратьТип"				, Ложь);
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("СписокВыбора"			, Неопределено);
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ВыборГруппИЭлементов"	, ГруппыИЭлементы.Элементы);
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ПодсказкаВвода"			, "");
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("АвтоМаксимальнаяШирина"	, Ложь);
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("МаксимальнаяШирина"		, 41);
	
	Возврат СтруктураФильтра;
	
КонецФункции

// Функция - Получить значения фильтра
//
// Параметры:
//  ТаблицаФильтров		 - 	 - 
//  НаименованиеФильтра	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗначенияФильтра(ТаблицаФильтров, НаименованиеФильтра = "") Экспорт
	
	СписокЗначенийФильтрации 					= Новый СписокЗначений;
	СписокЗначенийФильтрации.ДоступныеЗначения 	= Новый СписокЗначений;
	
	Если НЕ ЗначениеЗаполнено(НаименованиеФильтра) Тогда 
		Возврат СписокЗначенийФильтрации;
	КонецЕсли;
	
	МассивСтрокФильтра = ТаблицаФильтров.НайтиСтроки(Новый Структура("Наименование, Применен", НаименованиеФильтра, Истина));
	Если МассивСтрокФильтра.Количество() = 0 ИЛИ МассивСтрокФильтра.Количество() > 1 Тогда 
		Возврат СписокЗначенийФильтрации;
	КонецЕсли;
	
	СписокЗначенийФильтрации.ТипЗначения 		= МассивСтрокФильтра[0].ОписаниеТипаЗначения;
	
	МассивДопустимыхЗначений = Новый Массив;
	Если МассивСтрокФильтра[0].ТолькоПолеВыбора Тогда 
		Если ТипЗнч(МассивСтрокФильтра[0].ПараметрыПолеВыбора.ПараметрыВыбора) = Тип("ФиксированныйМассив") И МассивСтрокФильтра[0].ПараметрыПолеВыбора.ПараметрыВыбора.Количество() > 0 Тогда 
			Для Каждого ЭлементОтбора Из МассивСтрокФильтра[0].ПараметрыПолеВыбора.ПараметрыВыбора Цикл 
				Если ЭлементОтбора.Имя = "Отбор.Ссылка" И ТипЗнч(ЭлементОтбора.Значение) = Тип("ФиксированныйМассив") Тогда 
					МассивДопустимыхЗначений = Новый Массив(ЭлементОтбора.Значение);
					Прервать;
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;	
	Для Каждого ЭлементСписка Из МассивСтрокФильтра[0].СписокЗначений Цикл 
		СписокЗначенийФильтрации.ДоступныеЗначения.Добавить(ЭлементСписка.Значение.ЗначениеФильтра, ?(МассивСтрокФильтра[0].ВариантОтбора, "", "НЕ "));
		Если ЭлементСписка.Значение.Активирован Тогда 
			СписокЗначенийФильтрации.Добавить(ЭлементСписка.Значение.ЗначениеФильтра, ЭлементСписка.Представление);
		КонецЕсли;
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивДопустимыхЗначений Цикл
		ЭлементСписка = СписокЗначенийФильтрации.ДоступныеЗначения.НайтиПоЗначению(ЭлементМассива);
		Если ЭлементСписка = Неопределено Тогда 
			СписокЗначенийФильтрации.ДоступныеЗначения.Добавить(ЭлементМассива, ?(МассивСтрокФильтра[0].ВариантОтбора, "", "НЕ "));
			// Если ЭлементСписка.Значение.Активирован Тогда 
			//	СписокЗначенийФильтрации.Добавить(ЭлементСписка.Значение.ЗначениеФильтра, ЭлементСписка.Представление);
			// КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	
	Возврат СписокЗначенийФильтрации;
	
КонецФункции

// Процедура - Добавить параметры выбора
//
// Параметры:
//  СтруктураФильтра			 - 	 - 
//  СтруктураПараметровВыбора	 - 	 - 
//
Процедура ДобавитьПараметрыВыбора(СтруктураФильтра, СтруктураПараметровВыбора) Экспорт

	ПараметрыВыбора = Новый Массив;
	Для Каждого Параметр_Выбора Из СтруктураПараметровВыбора Цикл
		ИмяПараметраВыбора      = "Отбор." + Параметр_Выбора.Ключ;
		ЗначениеПараметраВыбора = ?(ТипЗнч(Параметр_Выбора.Значение) = Тип("Массив"), Новый ФиксированныйМассив(Параметр_Выбора.Значение), Параметр_Выбора.Значение);
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора(ИмяПараметраВыбора, ЗначениеПараметраВыбора));		
	КонецЦикла;	
	СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ПараметрыВыбора", Новый ФиксированныйМассив(ПараметрыВыбора))	
	
КонецПроцедуры

// Процедура - Инициализировать список значений
//
// Параметры:
//  СтруктураФильтра			 - 	 - 
//  КоллекцияЗначенийОтбора		 - 	 - 
//  ПустоеЗначение				 - 	 - 
//  ПредставлениеПустогоЗначения - 	 - 
//  АвтоВыбор					 - 	 - 
//  СортироватьПоПредставлению	 - 	 - 
//
Процедура ИнициализироватьСписокЗначений(СтруктураФильтра = Неопределено, КоллекцияЗначенийОтбора = Неопределено, ПустоеЗначение = Неопределено, ПредставлениеПустогоЗначения = Неопределено, АвтоВыбор = Ложь, СортироватьПоПредставлению = Ложь) Экспорт
	
	Если СтруктураФильтра = Неопределено Тогда 
		Возврат;
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(ПредставлениеПустогоЗначения) Тогда
		ПредставлениеПустогоЗначения = Нстр("ru = '<не указано>'; en = '<not indicated>'");
	КонецЕсли;	
		
	СписокЗначенийОтбора 				= Новый СписокЗначений;
	СписокЗначенийОтбора.ТипЗначения 	= Новый ОписаниеТипов("Структура");
	Если КоллекцияЗначенийОтбора = Неопределено ИЛИ (ТипЗнч(СтруктураФильтра) = Тип("Структура") И СтруктураФильтра.Свойство("ТолькоПолеВыбора") И СтруктураФильтра.ТолькоПолеВыбора = Истина) Тогда 
		Если СтруктураФильтра.Свойство("РеквизитДата") И СтруктураФильтра.РеквизитДата <> Дата(1,1,1) Тогда 
			ЭлементСписка 		= СписокЗначенийОтбора.Добавить();
			СтруктураЗначения 	= Новый Структура;			
			СтруктураЗначения.Вставить("ЗначениеФильтра"					, ПустоеЗначение);
			СтруктураЗначения.Вставить("ПрошлоеЗначениеФильтра"				, ПустоеЗначение);			
			СтруктураЗначения.Вставить("Выбран"								, АвтоВыбор);
			СтруктураЗначения.Вставить("Активирован"						, АвтоВыбор);
			СтруктураЗначения.Вставить("ИмяГруппыЗначенияФильтра"			, "");
			СтруктураЗначения.Вставить("ИмяКнопкиЗначенияФильтра"			, "");
			СтруктураЗначения.Вставить("ИмяКнопкиПериодаФильтра"			, "");
			СтруктураЗначения.Вставить("ИмяКнопкиВыбораСтандартногоПериода"	, "");
			СтруктураЗначения.Вставить("ИмяПоляКалендаряФильтра"			, "");
			СтруктураЗначения.Вставить("ПредставлениеПустогоПериода"		, ПредставлениеПустогоЗначения);
			СтруктураЗначения.Вставить("СписокСтандартныхПериодов"			, ИнициализироватьСписокСтандартныхПериодов());
			ЭлементСписка.Значение 		= СтруктураЗначения; 			
			ЭлементСписка.Представление = ПредставлениеПустогоЗначения;
		ИначеЕсли СтруктураФильтра.Свойство("ТолькоПолеВыбора") И СтруктураФильтра.ТолькоПолеВыбора = Истина Тогда 
			Если СтруктураФильтра.Свойство("ОписаниеТипаЗначения") И СтруктураФильтра.ОписаниеТипаЗначения <> Неопределено Тогда
				Если ТипЗнч(СтруктураФильтра) = Тип("Структура") Тогда 
					СтруктураФильтра.Вставить("РеквизитПолеВыбора", СтруктураФильтра.ОписаниеТипаЗначения.ПривестиЗначение());
				ИначеЕсли ТипЗнч(СтруктураФильтра) = Тип("ДанныеФормыЭлементКоллекции") Тогда
					СтруктураФильтра.РеквизитПолеВыбора = СтруктураФильтра.ОписаниеТипаЗначения.ПривестиЗначение();
				КонецЕсли;	
			КонецЕсли;
			Если НЕ КоллекцияЗначенийОтбора = Неопределено И СтруктураФильтра.ПараметрыПолеВыбора.ПараметрыВыбора.Количество() = 0 Тогда
				ПараметрыВыбора = Новый Массив;				
				Если ТипЗнч(КоллекцияЗначенийОтбора) = Тип("Массив") Тогда
					ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(КоллекцияЗначенийОтбора)));		
				ИначеЕсли ТипЗнч(КоллекцияЗначенийОтбора) = Тип("ТаблицаЗначений") Тогда
					ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(КоллекцияЗначенийОтбора.ВыгрузитьКолонку("Ссылка"))));		
				КонецЕсли;
				СтруктураФильтра.ПараметрыПолеВыбора.Вставить("ПараметрыВыбора", Новый ФиксированныйМассив(ПараметрыВыбора));
			КонецЕсли;
			Если НЕ ПустоеЗначение = Неопределено Тогда
				ЭлементСписка 				= СписокЗначенийОтбора.Добавить();
				СтруктураЗначения 			= Новый Структура;
				СтруктураЗначения.Вставить("ЗначениеФильтра"			, ПустоеЗначение);
				СтруктураЗначения.Вставить("Выбран"						, АвтоВыбор);
				СтруктураЗначения.Вставить("Активирован"				, АвтоВыбор);
				СтруктураЗначения.Вставить("ИмяГруппыЗначенияФильтра"	, "");
				СтруктураЗначения.Вставить("ИмяКнопкиЗначенияФильтра"	, "");
				ЭлементСписка.Значение 		= СтруктураЗначения; 
				ЭлементСписка.Представление = ПредставлениеПустогоЗначения;
			КонецЕсли;			
		КонецЕсли;	
	Иначе
		Если КоллекцияЗначенийОтбора.Количество() > 25 И ТипЗнч(СтруктураФильтра) = Тип("Структура") Тогда 
			СтруктураФильтра.Вставить("ТолькоПолеВыбора", Истина);
			ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначенийОтбора, ПустоеЗначение, ПредставлениеПустогоЗначения, АвтоВыбор, СортироватьПоПредставлению);
			Возврат;
		Иначе
			ЕстьПредставление = Ложь;
			Если ТипЗнч(КоллекцияЗначенийОтбора) = Тип("ТаблицаЗначений") И КоллекцияЗначенийОтбора.Колонки.Найти("Представление") <> Неопределено Тогда
				ЕстьПредставление = Истина;
			КонецЕсли;	
			Для Каждого ЭлементКоллекции Из КоллекцияЗначенийОтбора Цикл 
				ЭлементСписка 		= СписокЗначенийОтбора.Добавить();
				СтруктураЗначения 	= Новый Структура;
				Если ТипЗнч(КоллекцияЗначенийОтбора) = Тип("Массив") Тогда
					СтруктураЗначения.Вставить("ЗначениеФильтра", ЭлементКоллекции);
					Если ТипЗнч(ЭлементКоллекции) = Тип("СправочникСсылка.Сотрудники") Тогда 
						ЭлементСписка.Представление = ?(ЗначениеЗаполнено(ЭлементКоллекции),
										?(ЗначениеЗаполнено(СокрЛП(ЭлементКоллекции.НаименованиеСокращенное)), СокрЛП(ЭлементКоллекции.НаименованиеСокращенное), СокрЛП(Строка(ЭлементКоллекции))),
										ПредставлениеПустогоЗначения);
					Иначе 	
						ЭлементСписка.Представление = ?(ЗначениеЗаполнено(ЭлементКоллекции), СокрЛП(Строка(ЭлементКоллекции)),ПредставлениеПустогоЗначения);
					КонецЕсли;	
				ИначеЕсли ТипЗнч(КоллекцияЗначенийОтбора) = Тип("ТаблицаЗначений") Тогда
					СтруктураЗначения.Вставить("ЗначениеФильтра", ЭлементКоллекции.Ссылка);			
					ЭлементСписка.Представление = ?(ЗначениеЗаполнено(ЭлементКоллекции.Ссылка), ?(ЕстьПредставление, СокрЛП(ЭлементКоллекции.Представление), СокрЛП(Строка(ЭлементКоллекции.Ссылка))), ПредставлениеПустогоЗначения);
				КонецЕсли;
				// Если ТипЗнч(СтруктураЗначения.ЗначениеФильтра) = Тип("ПеречислениеСсылка.СтатусыЧленствПакетовУслуг") Тогда 
				//	ЭлементСписка.Представление = ?(СтруктураЗначения.ЗначениеФильтра = Перечисления.СтатусыЧленствПакетовУслуг.Активен, СтрЗаменить(ЭлементСписка.Представление, "ен", "н"), ЭлементСписка.Представление) + "о";
				// КонецЕсли;
				// Если ТипЗнч(СтруктураЗначения.ЗначениеФильтра) = Тип("ПеречислениеСсылка.СтатусыПродленияЧленствПакетовУслуг") Тогда 
				//	ЭлементСписка.Представление = ?(СтруктураЗначения.ЗначениеФильтра = Перечисления.СтатусыПродленияЧленствПакетовУслуг.Продлено, СтрЗаменить(ЭлементСписка.Представление, "ен", "н"), ЭлементСписка.Представление) + "о";
				// КонецЕсли;					
				СтруктураЗначения.Вставить("Выбран"						, АвтоВыбор);
				СтруктураЗначения.Вставить("Активирован"				, АвтоВыбор);
				СтруктураЗначения.Вставить("ИмяГруппыЗначенияФильтра"	, "");
				СтруктураЗначения.Вставить("ИмяКнопкиЗначенияФильтра"	, "");
				
				ЭлементСписка.Значение = СтруктураЗначения;
			КонецЦикла;
			
			Если НЕ ПустоеЗначение = Неопределено Тогда
				ЭлементСписка 				= СписокЗначенийОтбора.Добавить();
				СтруктураЗначения 			= Новый Структура;
				СтруктураЗначения.Вставить("ЗначениеФильтра"			, ПустоеЗначение);
				СтруктураЗначения.Вставить("Выбран"						, АвтоВыбор);
				СтруктураЗначения.Вставить("Активирован"				, АвтоВыбор);
				СтруктураЗначения.Вставить("ИмяГруппыЗначенияФильтра"	, "");
				СтруктураЗначения.Вставить("ИмяКнопкиЗначенияФильтра"	, "");
				ЭлементСписка.Значение 		= СтруктураЗначения; 
				ЭлементСписка.Представление = ПредставлениеПустогоЗначения;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если СортироватьПоПредставлению Тогда 
		СписокЗначенийОтбора.СортироватьПоПредставлению();
		// Передвигаем пустое значение в конец
		ПустоеЗначение = СтруктураФильтра.ОписаниеТипаЗначения.ПривестиЗначение();
		Для Каждого ЭлементСписка Из СписокЗначенийОтбора Цикл 
			Если ЭлементСписка.Значение.ЗначениеФильтра = ПустоеЗначение Тогда 
				СписокЗначенийОтбора.Сдвинуть(ЭлементСписка, СписокЗначенийОтбора.Количество() - 1 - СписокЗначенийОтбора.Индекс(ЭлементСписка));
				Прервать;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	Если ТипЗнч(СтруктураФильтра) = Тип("Структура") Тогда 
		СтруктураФильтра.Вставить("СписокЗначений", СписокЗначенийОтбора);
	Иначе 
		СтруктураФильтра.СписокЗначений = СписокЗначенийОтбора;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Инициализировать список стандартных периодов
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСписокСтандартныхПериодов()
	
	СписокСтандартныхПериодов = Новый СписокЗначений;  // ВариантСтандартногоПериода.
	// СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.Сегодня			, ВариантСтандартногоПериода.Сегодня);
	// СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.Вчера				, ВариантСтандартногоПериода.Вчера);
	// СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.Завтра			, ВариантСтандартногоПериода.Завтра);
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.Последние7Дней	, ВариантСтандартногоПериода.Последние7Дней);
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.ПрошлаяНеделя		, ВариантСтандартногоПериода.ПрошлаяНеделя);
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.ПрошлыйМесяц		, ВариантСтандартногоПериода.ПрошлыйМесяц);
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.ПрошлоеПолугодие	, ВариантСтандартногоПериода.ПрошлоеПолугодие);	
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.ЭтаНеделя			, ВариантСтандартногоПериода.ЭтаНеделя);	
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.ЭтотМесяц			, ВариантСтандартногоПериода.ЭтотМесяц);
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.ЭтоПолугодие		, ВариантСтандартногоПериода.ЭтоПолугодие);	
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.СледующаяНеделя	, ВариантСтандартногоПериода.СледующаяНеделя);		
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.СледующийМесяц	, ВариантСтандартногоПериода.СледующийМесяц);
    СписокСтандартныхПериодов.Добавить(ВариантСтандартногоПериода.СледующееПолугодие, ВариантСтандартногоПериода.СледующееПолугодие);
	
	Возврат СписокСтандартныхПериодов;
	
КонецФункции

// Процедура - Инициализировать выбранное значение всписке
//
// Параметры:
//  Форма				 - 	 - 
//  СтрокаФильтра		 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//
Процедура ИнициализироватьВыбранноеЗначениеВсписке(Форма, СтрокаФильтра, ВыбранноеЗначение) Экспорт
	
	ЕстьВСписке = Ложь;
	Для Каждого ЭлементСпискаЗначение Из СтрокаФильтра.СписокЗначений Цикл 
		Если ЭлементСпискаЗначение.Значение.ЗначениеФильтра = ВыбранноеЗначение Тогда 
			Если НЕ ЭлементСпискаЗначение.Значение.Выбран Тогда 
				ЭлементСпискаЗначение.Значение.Выбран = Истина;
				СтрокаФильтра.КоличествоАктивированныхЗначений = СтрокаФильтра.КоличествоАктивированныхЗначений + 1;
			КонецЕсли;	
		    ЕстьВСписке = Истина;
		КонецЕсли;	
	КонецЦикла;	
	
	Если ЕстьВСписке = Ложь Тогда 
		СтруктураФильтра = Новый Структура;
		МассивЗначений = Новый Массив;
		МассивЗначений.Добавить(ВыбранноеЗначение);
		ИнициализироватьСписокЗначений(СтруктураФильтра, МассивЗначений, , , Истина);
		СтруктураФильтра.СписокЗначений[0].Значение.Активирован = Ложь;
		СтрокаФильтра.СписокЗначений.Добавить(СтруктураФильтра.СписокЗначений[0].Значение, СтруктураФильтра.СписокЗначений[0].Представление);
		СтрокаФильтра.КоличествоАктивированныхЗначений = СтрокаФильтра.КоличествоАктивированныхЗначений + 1;		
	КонецЕсли;	
	
	// СтрокаФильтра.РеквизитПолеВыбора = СтрокаФильтра.ОписаниеТипаЗначения.ПривестиЗначение();
	
	СтрокаФильтра.Инициализирован 	= Ложь;
	СтрокаФильтра.Актуализирован 	= Ложь;
	
	// Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
	//	СписокВыбораИстория = Новый СписокЗначений;
	//	СпискиВыбораКлиентСервер.Загрузить("ИсторияПоиска" + СтрокаФильтра.Наименование, СписокВыбораИстория);
	//	СпискиВыбораКлиентСервер.ОбновитьСписокВыбора(СписокВыбораИстория, ВыбранноеЗначение, 7);
	//	СпискиВыбораКлиентСервер.Сохранить("ИсторияПоиска" + СтрокаФильтра.Наименование, СписокВыбораИстория);
	// КонецЕсли;
	
КонецПроцедуры

// Процедура - Обновить элементы фильтрации данных
//
// Параметры:
//  Форма			 - 	 - 
//  СтруктураФильтра - 	 - 
//
Процедура ОбновитьЭлементыФильтрацииДанных(Форма, СтруктураФильтра) Экспорт
	
	Если НЕ ИнициализированаСтруктураФильтра(СтруктураФильтра) Тогда 
		Возврат;
	КонецЕсли;
	
	СоздатьЭлементыУправленияФильтрациейДанных(Форма);
	
	МассивСтрокФильтр = Форма.ТаблицаФильтров.НайтиСтроки(Новый Структура("Наименование", СтруктураФильтра.Наименование));
	Если МассивСтрокФильтр.Количество() = 0 Тогда 
		СтрокаФильтр = Форма.ТаблицаФильтров.Добавить();
	Иначе 
		СтрокаФильтр = МассивСтрокФильтр[0];
		УдалитьЭлементыФильтра(Форма, СтрокаФильтр.ИмяГруппыТипФильтра);
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(СтрокаФильтр, СтруктураФильтра);
	
	ОбновитьМенюТипФильтра(Форма, СтрокаФильтр);
	
	Если СтруктураФильтра.ОбновитьЭлементыЗначений Тогда 
		ОбновитьГруппуЗначенийФильтра(Форма, СтрокаФильтр);	
	КонецЕсли;
	
	Если Форма.ИмяФормы = "Справочник.Сделки.Форма.ФормаСпискаНовая" Тогда 
		СтартовыйКоэф = 17;		
	ИначеЕсли СтрНайти(Форма.ИмяФормы, "ЧленствоПакетУслуг") <> 0 Тогда 
		СтартовыйКоэф = 20;		
	Иначе 
		СтартовыйКоэф = 13;
	КонецЕсли;	
	Форма.Элементы.ДекорацияРазделитель.МаксимальнаяВысота 		= ?(Форма.ТаблицаФильтров.Количество() < 9, 20, СтартовыйКоэф + Форма.ТаблицаФильтров.Количество());
	
КонецПроцедуры

// Функция - Инициализирована структура фильтра
//
// Параметры:
//  СтруктураФильтра - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализированаСтруктураФильтра(СтруктураФильтра)
	
	Возврат	(СтрНайти(СтруктураФильтра.Наименование, "Вероятность") <> 0 И СтруктураФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число"))) ИЛИ
		СтруктураФильтра.Свойство("СписокЗначений") И ТипЗнч(СтруктураФильтра.СписокЗначений) = Тип("СписокЗначений") И (НЕ СтруктураФильтра.СписокЗначений.Количество() = 0 ИЛИ СтруктураФильтра.ТолькоПолеВыбора);
	
КонецФункции

// Процедура - Создать элементы управления фильтрацией данных
//
// Параметры:
//  Форма	 - 	 - 
//
Процедура СоздатьЭлементыУправленияФильтрациейДанных(Форма)
	
	КнопкаАктивизацииМенюФильтрации = Форма.Элементы.Найти("Кнопка_ПоказатьМенюФильтрацииДанных");
	Если КнопкаАктивизацииМенюФильтрации = Неопределено Тогда 
		
		КомандаАктивизацииМенюФильтрации = Форма.Команды.Найти("ПоказатьМенюФильтрацииДанных");
		Если КомандаАктивизацииМенюФильтрации = Неопределено Тогда
			КомандаАктивизацииМенюФильтрации 						= Форма.Команды.Добавить("ПоказатьМенюФильтрацииДанных");
			КомандаАктивизацииМенюФильтрации.Заголовок 				= КомандаАктивизацииМенюФильтрации.Имя;
			КомандаАктивизацииМенюФильтрации.Подсказка 				= "";
			КомандаАктивизацииМенюФильтрации.Действие 				= "ОбработчикНажатияЭлементаФильтрацииДанных";
		КонецЕсли;
		
		КнопкаАктивизацииМенюФильтрации = Форма.Элементы.Вставить("Кнопка_ПоказатьМенюФильтрацииДанных", Тип("КнопкаФормы"), Форма.Элементы.ФильтрацияДанных, Форма.Элементы.АктивированныеФильтры);
		КнопкаАктивизацииМенюФильтрации.ИмяКоманды 										= КомандаАктивизацииМенюФильтрации.Имя;
		КнопкаАктивизацииМенюФильтрации.Заголовок 										= Нстр("ru='Фильтр';en='Filter'");
		КнопкаАктивизацииМенюФильтрации.Картинка 										= БиблиотекаКартинок.Фильтр24;		
		КнопкаАктивизацииМенюФильтрации.ОтображениеФигуры    							= ОтображениеФигурыКнопки.Нет;
		КнопкаАктивизацииМенюФильтрации.ПоложениеКартинки 								= ПоложениеКартинкиКнопкиФормы.Лево;
		КнопкаАктивизацииМенюФильтрации.Отображение 									= ОтображениеКнопки.КартинкаИТекст;
		КнопкаАктивизацииМенюФильтрации.Ширина 											= 9;
		КнопкаАктивизацииМенюФильтрации.АвтоМаксимальнаяШирина 							= Ложь;
		КнопкаАктивизацииМенюФильтрации.МаксимальнаяШирина 								= 9;
		КнопкаАктивизацииМенюФильтрации.РастягиватьПоГоризонтали 						= Истина;
		// КнопкаАктивизацииМенюФильтрации.ЦветТекста 										= Новый Цвет(0, 112, 210);
		КнопкаАктивизацииМенюФильтрации.Шрифт 											= Новый Шрифт("Arial", 11);
		КнопкаАктивизацииМенюФильтрации.ГоризонтальноеПоложениеВГруппе 					= ГоризонтальноеПоложениеЭлемента.Лево;
		КнопкаАктивизацииМенюФильтрации.ВертикальноеПоложениеВГруппе 					= ВертикальноеПоложениеЭлемента.Центр;
		
		УстановитьОтображениеКнопкиАктивизацииМенюФильтрации(Форма);
		
	КонецЕсли;	
	
	КнопкаПрименитьНастройкиФильтрации = Форма.Элементы.Найти("Кнопка_ПрименитьНастройкиФильтрации");
	Если КнопкаПрименитьНастройкиФильтрации = Неопределено Тогда 
		
		КомандаПрименитьНастройкиФильтрации = Форма.Команды.Найти("ПрименитьНастройкиФильтрации");
		Если КомандаПрименитьНастройкиФильтрации = Неопределено Тогда
			КомандаПрименитьНастройкиФильтрации 					= Форма.Команды.Добавить("ПрименитьНастройкиФильтрации");
			КомандаПрименитьНастройкиФильтрации.Заголовок 			= КомандаПрименитьНастройкиФильтрации.Имя;
			КомандаПрименитьНастройкиФильтрации.Подсказка 			= "";
			КомандаПрименитьНастройкиФильтрации.Действие 			= "ОбработчикНажатияЭлементаФильтрацииДанных";
		КонецЕсли;
		
		КнопкаПримененияНастроекФильтрации = Форма.Элементы.Вставить("Кнопка_ПрименитьНастройкиФильтрации", Тип("КнопкаФормы"), Форма.Элементы.ГруппаКнопкиПрименитьНастройкиФильтра);
		КнопкаПримененияНастроекФильтрации.ИмяКоманды 									= КомандаПрименитьНастройкиФильтрации.Имя;
		КнопкаПримененияНастроекФильтрации.Заголовок 									= Нстр("ru = 'Применить'; en = 'Apply'");
		// КнопкаПримененияНастроекФильтрации.Картинка 									= БиблиотекаКартинок.Фильтр24;		
		КнопкаПримененияНастроекФильтрации.ОтображениеФигуры    						= ОтображениеФигурыКнопки.Нет;
		// КнопкаПримененияНастроекФильтрации.ПоложениеКартинки 							= ПоложениеКартинкиКнопкиФормы.Право;
		КнопкаПримененияНастроекФильтрации.Отображение 									= ОтображениеКнопки.Текст;
		КнопкаПримененияНастроекФильтрации.Ширина 										= 9;
		КнопкаПримененияНастроекФильтрации.АвтоМаксимальнаяШирина 						= Ложь;
		КнопкаПримененияНастроекФильтрации.МаксимальнаяШирина 							= 9;
		КнопкаПримененияНастроекФильтрации.РастягиватьПоГоризонтали 					= Истина;		
		КнопкаПримененияНастроекФильтрации.ЦветТекста 									= Новый Цвет(255, 255, 255);// Новый Цвет(0, 112, 210);
		КнопкаПримененияНастроекФильтрации.Шрифт 										= Новый Шрифт("Arial", 11);
		// КнопкаПримененияНастроекФильтрации.ГоризонтальноеПоложениеВГруппе 			= ГоризонтальноеПоложениеЭлемента.Лево;
		// КнопкаПримененияНастроекФильтрации.ВертикальноеПоложениеВГруппе 				= ВертикальноеПоложениеЭлемента.Центр;
		
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Удалить элементы фильтра
//
// Параметры:
//  Форма		 - 	 - 
//  ИмяРодителя	 - 	 - 
//
Процедура УдалитьЭлементыФильтра(Форма, ИмяРодителя)
	
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из Форма.Элементы[ИмяРодителя].ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Форма.Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;

КонецПроцедуры

// Процедура - Обновить меню тип фильтра
//
// Параметры:
//  Форма		 - 	 - 
//  СтрокаФильтр - 	 - 
//
Процедура ОбновитьМенюТипФильтра(Форма, СтрокаФильтр)
	
	ИдентификаторФильтра 	= СтрокаФильтр.ПолучитьИдентификатор();
	ИмяТекущейСтраницы 		= Форма.Элементы.СтраницыЗначенийФильтров.ТекущаяСтраница.Имя;
	
	ГруппаКнопки_ТипФильтра_ = Форма.Элементы.Добавить("ГруппаКнопки_ТипФильтра_" + СтрокаФильтр.Наименование + "_" + ИдентификаторФильтра, Тип("ГруппаФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыТипФильтра]);
	ГруппаКнопки_ТипФильтра_.Вид 													= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКнопки_ТипФильтра_.Заголовок 												= ГруппаКнопки_ТипФильтра_.Имя;
	ГруппаКнопки_ТипФильтра_.Отображение 											= ОтображениеОбычнойГруппы.Нет;
	ГруппаКнопки_ТипФильтра_.Группировка 											= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаКнопки_ТипФильтра_.ОтображатьЗаголовок 									= Ложь;
