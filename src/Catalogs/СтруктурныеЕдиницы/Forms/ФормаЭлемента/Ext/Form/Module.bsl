// Процедура - Поле картинки нажатие
//
// Параметры:
//  Элемент				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаКлиенте
Процедура ПолеКартинкиНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Индекс 		 = ПолучитьИндексИмениЭлемента(Элемент.Имя);
	
	Если Индекс = 7 Тогда
		МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(Объект.Ссылка, "ЛоготипМагазина");
		ФайлКартинки		 = ?(МассивФайловКартинок.Количество() > 0, МассивФайловКартинок[0], Неопределено);
	Иначе
		ФайлКартинки = ЭтотОбъект.ФайлыКартинок.Получить(Индекс - 1).Значение;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ФайлКартинки) Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьКартинку(ФайлКартинки);

КонецПроцедуры

