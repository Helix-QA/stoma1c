			ДекорацияФормы_Услуги_Отсутствуют.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Услуги_Отсутствуют.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Услуги_Отсутствуют.Шрифт 								= Новый Шрифт("Arial", 11); 
			ДекорацияФормы_Услуги_Отсутствуют.ЦветФона 								= ЦветаСтиля.ЦветФонаЗадач;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Форма.ОтобразитьНовуюСтроку();
	
КонецПроцедуры

// Функция - Получить время ожидания
//
Функция ПолучитьВремяОжидания(СтрокаТЧ, ТаблицаЗапасы, Знач ПредыдущаяСтрока)
	
	ВремяОжидания = 0;
	Если СтрокаТЧ.НомерСтроки = 1 Или ПредыдущаяСтрока = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	//254690
	ВремяОкончанияМакс = ПолучитьВремяОкончанияМакс(ТаблицаЗапасы, СтрокаТЧ);
	
	Если ВремяОкончанияМакс <> Дата(1,1,1) И ВремяОкончанияМакс >= СтрокаТЧ.ДатаНачала Тогда
		ВремяОжидания = 0;
	ИначеЕсли ВремяОкончанияМакс <> Дата(1,1,1) И ВремяОкончанияМакс < СтрокаТЧ.ДатаНачала Тогда
		ВремяОжидания = Цел(((СтрокаТЧ.ДатаНачала - ВремяОкончанияМакс) / 60));
	КонецЕсли;
		
	//Если ПредыдущаяСтрока.ДатаОкончания <> Дата(1,1,1) И СтрокаТЧ.ДатаНачала  <> Дата(1,1,1) Тогда					
	//	Если ПредыдущаяСтрока.ДатаОкончания > СтрокаТЧ.ДатаНачала Тогда 
	//		ВремяОжидания = Цел(((ПредыдущаяСтрока.ДатаНачала - СтрокаТЧ.ДатаОкончания) / 60));					
	//	ИначеЕсли ПредыдущаяСтрока.ДатаОкончания < СтрокаТЧ.ДатаНачала Тогда 
	//		ВремяОжидания = Цел(((СтрокаТЧ.ДатаНачала - ПредыдущаяСтрока.ДатаОкончания) / 60));					
	//	КонецЕсли;	
	//КонецЕсли;
	
	Возврат ВремяОжидания;
	
КонецФункции

// Функция - Получить время окончания макс
//
// Параметры:
//  ТаблицаЗапасы	 - 	 - 
//  СтрокаТЧ		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВремяОкончанияМакс(ТаблицаЗапасы, СтрокаТЧ)
	
	ВремяОкончанияМаксимальное = Дата(1,1,1);
	
	Для Каждого СтрокаТ Из ТаблицаЗапасы Цикл
		
		Если СтрокаТ.ПолучитьИдентификатор() = СтрокаТЧ.ПолучитьИдентификатор() Тогда
			Прервать;
		КонецЕсли;
		
		ВремяОкончания = СтрокаТ.ДатаНачала + СтрокаТ.НормаВремени*60; 
		ВремяОкончанияМаксимальное = ?(ВремяОкончанияМаксимальное < ВремяОкончания, ВремяОкончания, ВремяОкончанияМаксимальное);	
		
	КонецЦикла;
	
	Возврат ВремяОкончанияМаксимальное;
	
КонецФункции

//  Процедура, заполняет свойства поля сотрудника.
// 
Процедура ЗаполнитьСвойстваПоляСотрудника(ПолеФормы_Сотрудник, ОтображатьЗаголовок)
	
	ПолеФормы_Сотрудник.Вид 					  = ВидПоляФормы.ПолеВвода;
	ПолеФормы_Сотрудник.ПоложениеЗаголовка 		  = ?(ОтображатьЗаголовок, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
	ПолеФормы_Сотрудник.ОтображениеКнопкиВыбора   = ОтображениеКнопкиВыбора.ОтображатьВПолеВвода;
	ПолеФормы_Сотрудник.КнопкаВыбора			  = Истина;
	ПолеФормы_Сотрудник.КнопкаВыпадающегоСписка   = Ложь;
	ПолеФормы_Сотрудник.КнопкаСоздания      	  = Ложь;
	ПолеФормы_Сотрудник.АвтоМаксимальнаяШирина 	  = Ложь;
	ПолеФормы_Сотрудник.ВыборГруппИЭлементов      = ГруппыИЭлементы.Элементы;
	ПолеФормы_Сотрудник.ИсторияВыбораПриВводе	  = ИсторияВыбораПриВводе.НеИспользовать;
	ПолеФормы_Сотрудник.АвтоОтметкаНезаполненного = Ложь;
	
КонецПроцедуры

Функция ЕстьДоступныйПакетУслугПоУслуге(Номенклатура, ВидЦен, ТаблицаОстатковПакетов)
	
	Для Каждого СтрокаТОП Из ТаблицаОстатковПакетов Цикл
		
		Если СтрокаТОП.Используется
				И СтрокаТОП.Количество > 0 
				И СтрокаТОП.КатегорияЦен = ВидЦен  						
				И ((ТипЗнч(СтрокаТОП.УслугаСегмент) = Тип("СправочникСсылка.СегментыНоменклатуры") 
				И РегистрыСведений.СоставСегментов.СегментСодержитОбъект(СтрокаТОП.УслугаСегмент, Номенклатура))
				ИЛИ СтрокаТОП.УслугаСегмент = Номенклатура) Тогда
				
				Возврат Истина;

		КонецЕсли;		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

//  Процедура - Вывести время ожидания
// 
//  Параметры:
//   Форма						 - 	 - 
//   ГруппаРодительТабличнойЧасти - 	 - 
//   ВремяОжидания				 - 	 - 
// 
Процедура ВывестиВремяОжидания(Форма, ГруппаРодительТабличнойЧасти, ПараметрыТабличнойЧасти, КлючСтроки, ВремяОжидания, ДатаНачалаОжидания, ИндексСтрокиТЧ)
	
	НоваяСтрока 					= Форма.Таблица_ВремениОжидания.Добавить();
	НоваяСтрока.КлючСтроки 			= КлючСтроки;
	НоваяСтрока.ВремяОжидания 		= ВремяОжидания;
	Часов  							= Цел(ВремяОжидания / 60);
	Минут 							= ВремяОжидания - (Часов * 60);
	НоваяСтрока.Надпись             = "Ожидание";
	НоваяСтрока.ВремяОжидания_Текст = СокрЛП(?(Часов > 0 ,"" + Часов + ?(Часов = 1, " час ", " часа "), "") + ?(Минут > 0 ,"" + Минут + " мин.", ""));
	НоваяСтрока.ДатаНачалаОжидания  = ДатаНачалаОжидания;
	
	ИндексСтроки 					= Форма.Таблица_ВремениОжидания.Индекс(НоваяСтрока);
	
	ГруппаСтрокиОжидания = Форма.Элементы.Добавить("Группа_Строка_Ожидания_" + ПараметрыТабличнойЧасти.ТабличнаяЧасть + "_" + ИндексСтроки, Тип("ГруппаФормы"), ГруппаРодительТабличнойЧасти);		
