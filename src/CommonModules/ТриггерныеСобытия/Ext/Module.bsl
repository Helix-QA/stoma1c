Функция ПолучитьДанныеСобытия_ЗаявкаНеОбработана(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		
#КонецОбласти
		
	Иначе
		 
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		ЗадержкаМинут = 0;
		Запрос.УстановитьПараметр("ДатаВыборки"					, ПолучитьДатуТриггера(ДанныеТриггера, ЗадержкаМинут));
		Если ЗадержкаМинут = 0 Тогда 
			Возврат Неопределено;
		КонецЕсли;	
		Запрос.УстановитьПараметр("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);
		// Запрос.УстановитьПараметр("ТекущаяСтруктурнаяЕдиница"	, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ТекущаяДата"					, ТекущаяДатаСеанса());
		Запрос.УстановитьПараметр("ПараметрЗадержкаМинут"		, ЗадержкаМинут);
		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	Заявки.Ссылка КАК Заявка,
		               |	Заявки.ДатаСоздания КАК ДатаСоздания,
		               |	Заявки.ОсновнойМенеджер КАК ОсновнойМенеджер,
		               |	Заявки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		               |ПОМЕСТИТЬ АнализируемаяТаблицаЗаявок
		               |ИЗ
		               |	Справочник.Заявки КАК Заявки
		               |ГДЕ
		               |	Заявки.ПометкаУдаления = ЛОЖЬ
		               |	И Заявки.СтруктурнаяЕдиница <> ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
		               |	И Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.НеОбработана)
