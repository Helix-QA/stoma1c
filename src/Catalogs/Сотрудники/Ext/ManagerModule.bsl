//
Функция ПолучитьСотрудникаПоКонтагенту(Контрагент) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Контрагент = &Контрагент
	|	И НЕ Сотрудники.ПометкаУдаления";
	
