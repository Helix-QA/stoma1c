		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОрганизация", "ИСТИНА");
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выгрузить();	
	Возврат ?(Результат.Количество() = 0, 0, Результат[0].КоличествоОбъектов);
	
КонецФункции

// Процедура - Преобразовать телефонные номера контрагентов
//
Процедура ПреобразоватьТелефонныеНомераКонтрагентов(КоличествоОбъектов, Индекс, СтруктураРезультата)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	КонтрагентыКонтактнаяИнформация.Ссылка КАК Контрагент
	               |ИЗ
	               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	               |ГДЕ
	               |	НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ЭтоГруппа
	               |	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления
	               |	И КонтрагентыКонтактнаяИнформация.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И (КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	               |			ИЛИ КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Факс))
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	КонтрагентыКонтактнаяИнформация.Ссылка
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КонтрагентыКонтактнаяИнформация.Ссылка.Наименование";
	
	Если ЗначениеЗаполнено(СтруктураРезультата.СтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктураРезультата.СтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "КонтрагентыКонтактнаяИнформация.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;
	
	ВыборкаСсылка 		= Запрос.Выполнить().Выбрать();
	Пока ВыборкаСсылка.Следующий() Цикл
		Индекс = Индекс + 1;	
		Прогресс = Цел(100 * Индекс / КоличествоОбъектов);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Преобразование формата телефонных номеров...';en='Convert phone numbers...'"), Новый Структура("ТипОбъекта, НаименованиеОбъекта", "Контрагент", Строка(ВыборкаСсылка.Контрагент)));
		ОтредактироватьФорматТелефонаОбъекта(ВыборкаСсылка.Контрагент, Истина, СтруктураРезультата);		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Преобразовать телефонные номера сотрудников
//
Процедура ПреобразоватьТелефонныеНомераСотрудников(КоличествоОбъектов, Индекс, СтруктураРезультата)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	//|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	//|	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник
	//|ПОМЕСТИТЬ ТаблицаСотрудниковРаботающихВПереданнойСЕ
	//|ИЗ
	//|	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	//|ГДЕ
	//|	СотрудникиМестаРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	//|	И НЕ СотрудникиМестаРаботы.Сотрудник В
	//|				(ВЫБРАТЬ
	//|					ТаблицаСотрудниковРаботающихВДругихСЕ.Сотрудник
	//|				ИЗ
	//|					ТаблицаСотрудниковРаботающихВДругихСЕ)
	//|; 
	//|////////////////////////////////////////////////////////////////////////////////   	
	
	               |	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник
	               |ПОМЕСТИТЬ ТаблицаСотрудниковРаботающихВДругихСЕ
	               |ИЗ
	               |	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	               |ГДЕ
	               |	СотрудникиМестаРаботы.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник
	               |ПОМЕСТИТЬ ТаблицаСотрудниковРаботающихВПереданнойСЕ
	               |ИЗ
	               |	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	               |ГДЕ
	               |	СотрудникиМестаРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И НЕ СотрудникиМестаРаботы.Сотрудник В
	               |				(ВЫБРАТЬ
	               |					ТаблицаСотрудниковРаботающихВДругихСЕ.Сотрудник
	               |				ИЗ
	               |					ТаблицаСотрудниковРаботающихВДругихСЕ)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	СотрудникиКонтактнаяИнформация.Ссылка КАК Сотрудник
	               |ИЗ
	               |	Справочник.Сотрудники.КонтактнаяИнформация КАК СотрудникиКонтактнаяИнформация
	               |ГДЕ
	               |	НЕ СотрудникиКонтактнаяИнформация.Ссылка.ЭтоГруппа
	               |	И НЕ СотрудникиКонтактнаяИнформация.Ссылка.ПометкаУдаления
	               //|	И СотрудникиКонтактнаяИнформация.Ссылка.Служебный = ЛОЖЬ
	               |	И СотрудникиКонтактнаяИнформация.Ссылка В
	               |			(ВЫБРАТЬ
	               |				ТаблицаСотрудниковРаботающихВПереданнойСЕ.Сотрудник
	               |			ИЗ
	               |				ТаблицаСотрудниковРаботающихВПереданнойСЕ)
	               |	И (СотрудникиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	               |			ИЛИ СотрудникиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Факс))
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СотрудникиКонтактнаяИнформация.Ссылка
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СотрудникиКонтактнаяИнформация.Ссылка.Наименование";
	
	Если ЗначениеЗаполнено(СтруктураРезультата.СтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктураРезультата.СтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "СотрудникиМестаРаботы.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница"	, "ЛОЖЬ");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "СотрудникиМестаРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница"	, "ИСТИНА");
	КонецЕсли;
	
	ВыборкаСсылка = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСсылка.Следующий() Цикл
		Индекс = Индекс + 1;	
		Прогресс = Цел(100 * Индекс / КоличествоОбъектов);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Преобразование формата телефонных номеров...';en='Convert phone numbers...'"), Новый Структура("ТипОбъекта, НаименованиеОбъекта", "Сотрудник", Строка(ВыборкаСсылка.Сотрудник)));		
		ОтредактироватьФорматТелефонаОбъекта(ВыборкаСсылка.Сотрудник, , СтруктураРезультата);		
	КонецЦикла;	
	
КонецПроцедуры

