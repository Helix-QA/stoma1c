&НаСервере
// При изменении значения выбора приемника денежных средств сервер
Процедура ПриемникДенежныхСредствПриИзмененииСервер()
	
	// Получение остатков по приемнику
	ОстатокСредств = 0;
	Если ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) И ЗначениеЗаполнено(Объект.ПриемникЗачисленияСредств) Тогда
		Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные 
			ИЛИ Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			
			ОстатокСредств = РегистрыНакопления.ДенежныеСредства.ПолучитьОстаткоДенежныхСредств(Объект.Дата,Объект.ПриемникЗачисленияСредств,Объект.Ссылка);
		ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда  
						
			ОстатокСредств = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.ПриемникЗачисленияСредств,Объект.Дата,Объект.Ссылка,Объект.СтруктурнаяЕдиница,Объект.ПриемникВидЛицевогоСчета,Истина);
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ДекорацияКассаПриемник.Заголовок = Элементы.ПриемникДенежныхСредств.Заголовок + ":";
	Элементы.Статья.МаксимальнаяШирина = ?(Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет, 42, 47);  
	Элементы.ПриемникДенежныхСредств.МаксимальнаяШирина = ?(Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет, 41, 47);  
	Элементы.ДекорацияКассаПриемник.Ширина  = ?(Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет, 11, 10);
	Элементы.ДекорацияОстаткоПоПриемнику.Заголовок = "Остаток " +ОстатокСредств+ " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
	Если ОстатокСредств < 0 Тогда
		Элементы.ДекорацияОстаткоПоПриемнику.ЦветТекста = WebЦвета.Красный;
	Иначе
		Элементы.ДекорацияОстаткоПоПриемнику.ЦветТекста = WebЦвета.Черный;
	КонецЕсли;
	
КонецПроцедуры

