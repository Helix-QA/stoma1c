		ПарамтерыЗапроса = Новый Структура("units", МассивПараметровСтруктурныхЕдиниц);
		РезультатЗапроса = ВыполнитьPOSTЗапросВReservi("remove_se", ПарамтерыЗапроса);
		
		РезультатаОперции = СтруктураСтандартынхПараметровРезОперации();
		
		//Если РезультатЗапроса.КодСостояния <> 200 Тогда
		//	ВызватьИсключение "КодОшибки = " + РезультатЗапроса.КодСостояния + ", Ошибка: " +  РезультатЗапроса.ПолучитьТелоКакСтроку();
		//Иначе
			// Так как код состояния равен 404 даже при успешном соединении, поэтому проверку на код состояния комментим
			Ответ = РезультатЗапроса.ПолучитьТелоКакСтроку();
			
