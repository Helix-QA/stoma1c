	ПараметрыЧека.НомерТелефонаКлиента    = ?(ЭтотОбъект.ЧекККОтправитьНаТелефон, ЭтотОбъект.ЧекККТТелефон	, Неопределено);
	
	ПараметрыЧека.МассивПараметровОплаты = ПараметрыОплаты.МассивОплат;  
	ПараметрыЧека.МассивПараметровТовары = ПолучитьМассивТоваровФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(ПараметрыОплаты.СуммаВзноса);   	
	
	ПараметрыЧека.МассивДокументовОснований = МассивДокументовОплаты; 
	
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека);  
	
	Возврат ФормированиеЧека;
	
