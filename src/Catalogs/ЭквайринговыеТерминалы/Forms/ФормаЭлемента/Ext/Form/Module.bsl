&НаСервере
// Процедура, выполняет пост запрос к CRM. 
//
Процедура ВыполнитьPOSTЗапрос(Метод, ТекстЗапроса)
	
	ПараметрыЛК = ЛичныйКабинет.ПараметрыПодклчюенияК_API_CRM();
	
	Соединение = Новый HTTPСоединение(
	ПараметрыЛК.АдресСервера,, 
