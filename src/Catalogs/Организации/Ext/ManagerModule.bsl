// Функция, ПолучитьПодчиненныеГоловнойОрганизации.
//
Функция ПолучитьПодчиненныеГоловнойОрганизации(ГоловнаяОрганизация) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.Ссылка КАК Организация
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ПометкаУдаления = ЛОЖЬ
	|	И Организации.ГоловнаяОрганизация = &ГоловнаяОрганизация
	|	И Организации.ЭтоГруппа = ЛОЖЬ";
	Запрос.УстановитьПараметр("ГоловнаяОрганизация", ГоловнаяОрганизация);
	МассивОрганизаций = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Организация");
	
	Возврат МассивОрганизаций;
	 
КонецФункции // ПолучитьПодчиненныеГоловнойОрганизации        

// Функция - Получить головную организацию.
//
Функция ПолучитьГоловнуюОрганизацию(ИНН, НеГоловную = Ложь) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Организации.Ссылка КАК Организация
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ПометкаУдаления = ЛОЖЬ
	|	И Организации.ИНН = &ИНН
	|	И Организации.ЭтоГруппа = ЛОЖЬ
	|	И Организации.ЭтоГоловнаяОрганизация = ИСТИНА";
	Запрос.УстановитьПараметр("ИНН", ИНН);
	
	Если НеГоловную Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Организации.ЭтоГоловнаяОрганизация = ИСТИНА", "");
	КонецЕсли;
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Возврат ?(ВыборкаЗапроса.Следующий(), ВыборкаЗапроса.Организация, Справочники.Организации.ПустаяСсылка());
	 
КонецФункции // ПолучитьГоловнуюОрганизацию 

// Процедура - Обработка получения полей представления.
//
Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
    Поля.Добавить("Наименование");
	Поля.Добавить("ПометкаУдаления");
	Поля.Добавить("ЭтоГоловнаяОрганизация");

КонецПроцедуры

// Процедура - Обработка получения представления.
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Представление = Данные.Наименование 
	+ ?(Данные.ЭтоГоловнаяОрганизация = Истина, НСтр("ru=' (головная)';en=' (head)'"), "")
	+ ?(Данные.ПометкаУдаления = Истина, НСтр("ru=' (удален)';en=' (deleted)'"), "");
	
КонецПроцедуры

#КонецОбласти