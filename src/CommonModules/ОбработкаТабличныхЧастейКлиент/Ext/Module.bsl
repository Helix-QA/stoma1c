// Процедура, выполняет выбор упаковки номенклатуры.
//  Параметры:
//   ДанныеВыбора - структура выбора;
//   СтандартнаяОбработка - признак выполнения стандартной обработки выбора.
//   ТекущаяСтрока - текущая строка табличной части, в которой осуществляется выбор значения.
//
Процедура ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, ТекущаяСтрока, ИмяКолонкиНоменклатуры = "Номенклатура") Экспорт

	СтандартнаяОбработка = Ложь;

	Если ЗначениеЗаполнено(ТекущаяСтрока[ИмяКолонкиНоменклатуры]) Тогда
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Справочник.УпаковкиНоменклатуры.ПустаяСсылка"), "<без упаковки>");

		Если Не ОбщегоНазначенияСтоматология.ПроверитьИспользованиеУпаковокИПолучитьСписокДляВыбора(ТекущаяСтрока[ИмяКолонкиНоменклатуры], ДанныеВыбора) Тогда
			// Предупреждение(НСтр("ru = 'Для данной номенклатуры нет упаковок.'"));
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры
  
// Процедура выполняет стандартные действия при изменении единицы цены
// в строке табличной части документа.
//
// Параметры:
//  СтрокаТабличнойЧасти - строка табличной части документа,
//  ДокументОбъект       - объект редактируемого документа
//
Процедура ПриИзмененииУпаковкиТабЧасти(СтрокаТабличнойЧасти, СтруктрураПараметров = Неопределено) Экспорт
 
	// Получим цену, если она есть.
	Если СтрокаТабличнойЧасти.Свойство("Цена") <> Неопределено и СтруктрураПараметров <> Неопределено Тогда
		СтруктрураПараметров.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
		СтруктрураПараметров.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);			
		СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктрураПараметров);
		СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	КонецЕсли;
	
	// Пересчитаем количество
	ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);	
	
КонецПроцедуры // ПриИзмененииЕдиницыТабЧасти

// Процедура, рассчитывает количество ед. изм.
//  Параметры:
//   СтрокаТабличнойЧасти - строка табличной части.
//
Процедура ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти, СтруктрураПараметров = Неопределено) Экспорт
	
	СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * ОбщегоНазначенияСтоматология.ВернутьКоэффициентУпаковки(СтрокаТабличнойЧасти.Упаковка);
	
	Если СтруктрураПараметров <> Неопределено Тогда
		Если СтруктрураПараметров.Свойство("РасчетДопКолонки", Истина) Тогда
			СтрокаТабличнойЧасти.КоличествоПоДаннымУчета =  СтрокаТабличнойЧасти.КоличествоУпаковокПоДаннымУчета * ОбщегоНазначенияСтоматология.ВернутьКоэффициентУпаковки(СтрокаТабличнойЧасти.Упаковка);
		КонецЕсли;		
	КонецЕсли;
	
	
КонецПроцедуры
       
// Функция выполняет добавление номенклатуры в ТЧ
//
Функция СШКОбработкаТабличнойЧасти(ТабличнаяЧасть, ДанныеШтрикодов, Контрагент = Неопределено, Карта = Неопределено, Документ = Неопределено, ТЧЗапасы = Неопределено, МассивНенайденныхШтрихкодов = Неопределено, ИдентификаторНовойСтрокиТЧ = Неопределено) Экспорт 
	
	Если ДанныеШтрикодов.Количество() > 0 Тогда
		ДанныеШтрихкода = ?(ТипЗнч(ДанныеШтрикодов) = Тип("Структура"), ДанныеШтрикодов, ДанныеШтрикодов[0]);		
		ДанныеПоШтрихкодам = ОбщегоНазначенияСтоматология.ВернутьНоменклатуруПоШтрихкоду(ДанныеШтрихкода.Штрихкод, МассивНенайденныхШтрихкодов = Неопределено);
		Если ДанныеПоШтрихкодам <> Неопределено Тогда
			Если ТипЗнч(ДанныеПоШтрихкодам.Объект) = Тип("СправочникСсылка.Номенклатура") Тогда
				Если ТабличнаяЧасть <> Неопределено и ОбщегоНазначенияСтоматология.ПроверитьТипНоменклатуры(Документ, ДанныеПоШтрихкодам.Объект) Тогда
					Отбор = ?(ТабличнаяЧасть.ТекущиеДанные <> Неопределено И ТабличнаяЧасть.ТекущиеДанные.Свойство("Партия"),
							Новый Структура("Номенклатура, Партия, Упаковка", ДанныеПоШтрихкодам.Объект, ДанныеПоШтрихкодам.Партия, ДанныеПоШтрихкодам.Упаковка),
							Новый Структура("Номенклатура, Упаковка", ДанныеПоШтрихкодам.Объект, ДанныеПоШтрихкодам.Упаковка));
					НайденноеЗначение = ТЧЗапасы.НайтиСтроки(Отбор);
					Если НайденноеЗначение.Количество() > 0 Тогда
						Если ТабличнаяЧасть.ТекущиеДанные.Свойство("КоличествоУпаковок") Тогда
							НайденноеЗначение[0].КоличествоУпаковок = НайденноеЗначение[0].КоличествоУпаковок + ?(ДанныеШтрихкода.Свойство("Количество"), ДанныеШтрихкода.Количество, 1);
						КонецЕсли;	
						ТабличнаяЧасть.ТекущаяСтрока = НайденноеЗначение[0].ПолучитьИдентификатор();
						ТабличнаяЧасть.Обновить();
						// Возврат Ложь;
						Возврат Истина;
					Иначе
						ТабличнаяЧасть.ДобавитьСтроку();
						ТабличнаяЧасть.ТекущиеДанные.Номенклатура = ДанныеПоШтрихкодам.Объект;
						Если ТабличнаяЧасть.ТекущиеДанные.Свойство("КоличествоУпаковок") Тогда
							ТабличнаяЧасть.ТекущиеДанные.КоличествоУпаковок = ?(ДанныеШтрихкода.Свойство("Количество"), ДанныеШтрихкода.Количество, 1);
						КонецЕсли;	
						ТабличнаяЧасть.ТекущиеДанные.Упаковка = ДанныеПоШтрихкодам.Упаковка;
						Если ТабличнаяЧасть.ТекущиеДанные.Свойство("Партия") Тогда
							ТабличнаяЧасть.ТекущиеДанные.Партия   = ДанныеПоШтрихкодам.Партия;
						КонецЕсли;
						ИдентификаторНовойСтрокиТЧ = ТабличнаяЧасть.ТекущиеДанные.ПолучитьИдентификатор();
						Возврат Истина;
					КонецЕсли;
				Иначе
					Возврат Ложь;
				КонецЕсли;
			ИначеЕсли  Контрагент <> Неопределено и Карта <> Неопределено Тогда
				Контрагент = ДанныеПоШтрихкодам.ВладелецКарты;
				Карта      = ДанныеПоШтрихкодам.Ссылка;
				Возврат Ложь;
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Штрихкод "+ДанныеШтрихкода.Штрихкод+" присвоен карте клиента "+ДанныеПоШтрихкодам.Объект+"");
				Возврат Ложь;
			КонецЕсли;
		Иначе
			Если МассивНенайденныхШтрихкодов <> Неопределено Тогда
				МассивНенайденныхШтрихкодов.Добавить(ДанныеШтрихкода);
			КонецЕсли;			
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ДинамическоеСозданиеМеню

// Процедура, создает динамические кнопки.
//
Процедура СоздатьМенюДокумента(Форма, СтруктураКнопок, ИмяЭлементаДляРазмещения) Экспорт
	
	масРеквизитов = Новый Массив;
	масРеквизитов.Добавить(Новый РеквизитФормы("_СписокПанелей", Новый ОписаниеТипов("СписокЗначений"), , "_СписокПанелей", Ложь));
	Форма.ИзменитьРеквизиты(масРеквизитов);
	
	Для Каждого Кнопка из СтруктураКнопок Цикл
		
		ИмяКнопки  = "_"+Кнопка.Ключ;	
		ИмяКоманды = "_"+Кнопка.Значение; 
		КомандаФормы  = Форма.Команды.Добавить(ИмяКоманды);
		КомандаФормы.Действие = "ПроцедураОбработкиНажатияМеню";
		
		ГруппаКнопки = Форма.Элементы.Добавить("Группа_Кнопки" + ИмяКнопки, Тип("ГруппаФормы"), Форма.Элементы[ИмяЭлементаДляРазмещения]);
		ГруппаКнопки.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаКнопки.Отображение 						= ОтображениеОбычнойГруппы.Нет;
		ГруппаКнопки.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаКнопки.ГоризонтальныйИнтервал				= ИнтервалМеждуЭлементамиФормы .Нет;
		ГруппаКнопки.ОтображатьЗаголовок 				= Ложь;
		ГруппаКнопки.ЦветФона 							= ?(Форма.Элементы[Кнопка.Значение].Видимость,Новый Цвет(242,242,242),Новый Цвет(255,255,255));
		ГруппаКнопки.ВертикальноеПоложениеВГруппе 		= ВертикальноеПоложениеЭлемента.Центр;
		ГруппаКнопки.ВертикальноеПоложениеПодчиненных 	= ВертикальноеПоложениеЭлемента.Центр;
		ГруппаКнопки.ГоризонтальноеПоложениеПодчиненных	= ГоризонтальноеПоложениеЭлемента.Центр;
		
		ДекорацияКнопка = Форма.Элементы.Добавить("Дек"+ИмяКнопки, Тип("ДекорацияФормы"), ГруппаКнопки);
		ДекорацияКнопка.Вид = ВидДекорацииФормы.Надпись;
		Если Кнопка.Ключ = "Номенклатура" Тогда
			ДекорацияКнопка.Заголовок = "Номенклатура";
		Иначе
			ДекорацияКнопка.Заголовок = Форма.Элементы[Кнопка.Значение].Заголовок;
		КонецЕсли;
		ДекорацияКнопка.Видимость = Форма.Элементы[Кнопка.Значение].Видимость;
		ДекорацияКнопка.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
		ДекорацияКнопка.Шрифт = Новый Шрифт(Форма.Элементы["Дек"+ИмяКнопки].Шрифт,,11);
		
		НоваяКнопка = Форма.Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), ГруппаКнопки);
		Если Кнопка.Ключ = "Номенклатура" Тогда
			НоваяКнопка.Заголовок = "Номенклатура";
		Иначе
			НоваяКнопка.Заголовок = Форма.Элементы[Кнопка.Значение].Заголовок;
		КонецЕсли;
		НоваяКнопка.ИмяКоманды = ИмяКоманды;
		НоваяКнопка.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
		НоваяКнопка.Видимость = НЕ Форма.Элементы[Кнопка.Значение].Видимость;
		НоваяКнопка.ЦветТекста = Новый Цвет(51,102,187);	
		НоваяКнопка.Шрифт = Новый Шрифт(Форма.Элементы[ИмяКнопки].Шрифт,,11); 		
		Форма._СписокПанелей.Добавить(Кнопка.Значение, ИмяКнопки);
		
	КонецЦикла;
	
КонецПроцедуры  


// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Форма, ЭлементИмя) Экспорт
	
	Для Каждого Панель из Форма._СписокПанелей Цикл
		
		Если Панель.Значение = Сред(ЭлементИмя,2) Тогда
			Форма.Элементы[Панель.Значение].Видимость = Истина;
			Форма.Элементы["Дек"+Панель.Представление].Видимость = Истина;
			Форма.Элементы[Панель.Представление].Видимость = Ложь;
			Форма.Элементы["Группа_Кнопки"+Панель.Представление].ЦветФона = Новый Цвет(242,242,242);			
		Иначе	
			Форма.Элементы[Панель.Значение].Видимость = Ложь;
			Форма.Элементы["Дек"+Панель.Представление].Видимость = Ложь;
			Форма.Элементы[Панель.Представление].Видимость = Истина;
			Форма.Элементы["Группа_Кнопки"+Панель.Представление].ЦветФона = Новый Цвет(255,255,255);			
		КонецЕсли;	
		
	КонецЦикла;
	
	ГруппаИнформацияПоОплате = Форма.Элементы.Найти("ГруппаИнформацияПоОплате");
	Если ГруппаИнформацияПоОплате <> Неопределено Тогда
		ГруппаИнформацияПоОплате.Видимость = Сред(ЭлементИмя,2) <> "ГруппаДополнительно";
	КонецЕсли;	
	
КонецПроцедуры

// Процедура, выполняет подсчет количества строк в таб.частях и выводит его в заголовок панели
//
Процедура ОбновитьЗаголовкиТабЧастей(Форма, ЧитатьДанныеИзФормы = Ложь) Экспорт
	
	Объект = ?(ЧитатьДанныеИзФормы, Форма, Форма.Объект);
	
	Для Каждого Панель Из Форма._СписокПанелей Цикл
		
		ИмяТабЧасти = Сред(Панель.Значение, 7);
		
		СтрокТабЧасти = "0";   		
		
		Если ИмяТабЧасти = "ЗапасыИУслуги" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.Запасы.Количество());
		ИначеЕсли ИмяТабЧасти = "СхемаРассрочки" Тогда
			СтрокТабЧасти = Строка(Форма.СхемаРассрочки.ПолучитьЭлементы().Количество());
		ИначеЕсли ИмяТабЧасти = "Подарки" Тогда
			// СтрокТабЧасти = Строка(Форма.Объект.Подарки.Количество());
			Если ЧитатьДанныеИзФормы Или Объект.Свойство(ИмяТабЧасти) Тогда
				КоличествоИспользуемых = Объект[ИмяТабЧасти].НайтиСтроки(Новый Структура("Использование", Истина)).Количество();
				СтрокТабЧасти 		   = "" + КоличествоИспользуемых + Нстр("ru = ' из '; en = ' out of '") + Объект[ИмяТабЧасти].Количество();
			КонецЕсли;     
		ИначеЕсли ИмяТабЧасти = "СкидкиНаценки" Тогда
			// СтрокТабЧасти = Строка(Форма.Объект.СкидкиНаценки.Количество());
			Если ЧитатьДанныеИзФормы ИЛИ Объект.Свойство(ИмяТабЧасти) Тогда   			 
				КоличествоИспользуемых = Объект[ИмяТабЧасти].НайтиСтроки(Новый Структура("ПризнакОплатыБонусом, Использование", Ложь, Истина)).Количество();
				КоличествоВсего		   = Объект[ИмяТабЧасти].НайтиСтроки(Новый Структура("ПризнакОплатыБонусом", Ложь)).Количество();				
				СтрокТабЧасти = "" + КоличествоИспользуемых + Нстр("ru = ' из '; en = ' out of '") + КоличествоВсего;       				
			КонецЕсли;        
		ИначеЕсли ИмяТабЧасти = "ВыданныеАвансы" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.ВыданныеАвансы.Количество());
		ИначеЕсли ИмяТабЧасти = "Авансы" Тогда
			Если Форма.Объект.Свойство("УчтенныеАвансы") Тогда
				СтрокТабЧасти = Строка(Форма.Объект.УчтенныеАвансы.Количество());
			Иначе
				СтрокТабЧасти = Строка(Форма.Объект.Авансы.Количество());
			КонецЕсли;	
		ИначеЕсли ИмяТабЧасти = "Запасы" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.Запасы.Количество());
		ИначеЕсли ИмяТабЧасти = "Расшифровка" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.РасшифровкаПлатежа.Количество());
		ИначеЕсли ИмяТабЧасти = "РасшифровкаСписания" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.РасшифрокаСписания.Количество());
		ИначеЕсли ИмяТабЧасти = "Затраты" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.Затраты.Количество());
		ИначеЕсли ИмяТабЧасти = "Расходы" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.Расходы.Количество());
		ИначеЕсли ИмяТабЧасти = "ОказанныеУслуги" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.ОказанныеУслуги.Количество());
		ИначеЕсли ИмяТабЧасти = "Оплаты" Тогда
			СтрокТабЧасти = Строка(Форма.Объект.Оплаты.Количество());
		ИначеЕсли ИмяТабЧасти = "СтруктурныеЕдиницы" Тогда
			ИмяТабЧасти = "ТаблицаСтруктурныеЕдиницыСкидки";
			СтрокТабЧасти = Форма[ИмяТабЧасти].Количество();
			
		ИначеЕсли ИмяТабЧасти = "Запись" Тогда			
			СтрокТабЧасти = Форма.ВернутьКоличествоУслуг();
			
		ИначеЕсли ИмяТабЧасти = "ОценкиИОтзывы" Тогда    			
			Продолжить;
			
		ИначеЕсли ИмяТабЧасти = "Переоценка" Тогда
			СтрокТабЧасти = ?(Форма.Объект.Свойство(ИмяТабЧасти), 
			"" + Форма.Объект[ИмяТабЧасти].НайтиСтроки(Новый Структура("Активность", Истина)).Количество() + 
			" из " + Форма.Объект[ИмяТабЧасти].Количество(), 0);      
		Иначе 	
			СтрокТабЧасти = ?(Форма.Объект.Свойство(ИмяТабЧасти), Форма.Объект[ИмяТабЧасти].Количество(), 0);
		КонецЕсли;
		
		ЗаголовокКнопки = Форма.Элементы[Панель.Представление].Заголовок;
		ЗаголовокКнопки = Сред(ЗаголовокКнопки, 1, ?(СтрНайти(ЗаголовокКнопки, " (") > 0, СтрНайти(ЗаголовокКнопки, " (") - 1, СтрДлина(ЗаголовокКнопки)));
		Форма.Элементы[Панель.Представление].Заголовок = ЗаголовокКнопки + ?(СтрокТабЧасти <> "0" И СтрокТабЧасти <> 0," ("+Строка(СтрокТабЧасти)+")", "");
		Форма.Элементы["Дек"+Панель.Представление].Заголовок = Форма.Элементы[Панель.Представление].Заголовок;
		
	КонецЦикла; 
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСДеревьями

&НаСервере
// Процедура, выполянет создание дерева структурных единиц.
//
Процедура СоздатьДеревоСтруктурныхЕдиниц(
		Форма, 
		Реквизит, 
		ОбъектОграничения, 
		УстановитьВсеФлагиВИстину = Неопределено, 
		МассивСтруктурныхЕдиниц = Неопределено, 
		МассивДоступныхСтруктурныхЕдиниц = Неопределено, 
		СоответствиеИндексамКартинок = Неопределено,
		МассивКолонок = Неопределено,
		ОтображатьПервыйУровеньДерева = Ложь) Экспорт
	
	Если МассивСтруктурныхЕдиниц = Неопределено Тогда
		МассивСтруктурныхЕдиниц = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц();
	КонецЕсли;
	КоличествоСтруктурныхЕдиниц = МассивСтруктурныхЕдиниц.Количество();
	
	ЭлементДерево            = ?(МассивДоступныхСтруктурныхЕдиниц = Неопределено, Форма.ПодборСтруктурныеЕдиницы, Форма.ПодборМестаРаботыСотрудника);
	ПервыйУровеньДерева 	 = ЭлементДерево.ПолучитьЭлементы();
	ПервоначальноеЗаполнение = ПервыйУровеньДерева.Количество() = 0;
	
	Если ПервоначальноеЗаполнение Тогда
		
		ОтображатьПервыйУровеньДерева = ОтображатьПервыйУровеньДерева ИЛИ ТипЗнч(ОбъектОграничения) = Тип("СправочникСсылка.Сотрудники");
		
		ЗаполнитьДеревоСтруктурныхЕдиниц(МассивСтруктурныхЕдиниц, ЭлементДерево, Форма, 
		СоответствиеИндексамКартинок, ОтображатьПервыйУровеньДерева, ОбъектОграничения);
		
		Если МассивДоступныхСтруктурныхЕдиниц = Неопределено Тогда 
			МассивВыбранныхСтруктурныхЕдиниц = РегистрыСведений.РеквизитыОбъектов.ПолучитьСтруктурныеЕдиницыПоОбъекту(ОбъектОграничения, Реквизит);
		Иначе
			МассивВыбранныхСтруктурныхЕдиниц = МассивДоступныхСтруктурныхЕдиниц;
		КонецЕсли;
		
	Иначе
		
		ДанныеДерева 		   = ПервыйУровеньДерева[0].ПолучитьЭлементы();
		МассивСтрокДляУдаления = Новый Массив();
		
		ДобавленыеСтруктурныеЕдиницы = Новый Массив;
		Для Каждого СтрокаДерева Из ДанныеДерева Цикл
			
			Если МассивСтруктурныхЕдиниц.Найти(СтрокаДерева.СтруктурнаяЕдиница) = Неопределено Тогда
				МассивСтрокДляУдаления.Добавить(СтрокаДерева);
			Иначе
				ДобавленыеСтруктурныеЕдиницы.Добавить(СтрокаДерева.СтруктурнаяЕдиница);
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
			ДанныеДерева.Удалить(СтрокаДляУдаления);		
		КонецЦикла;
		
		Если СоответствиеИндексамКартинок <> Неопределено
			И ТипЗнч(СоответствиеИндексамКартинок) = Тип("Соответствие") Тогда 
		
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
				Если ДобавленыеСтруктурныеЕдиницы.Найти(СтруктурнаяЕдиница) = Неопределено Тогда
					НоваяСтрока 				   = ДанныеДерева.Вставить(0);
					НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
					
					Индекс 						   = СоответствиеИндексамКартинок.Получить(СтруктурнаяЕдиница);
					НоваяСтрока.ИндКартинки 	   = ?(Индекс = Неопределено, 1, Индекс);
				КонецЕсли;
			КонецЦикла;
			
		Иначе
			
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
				Если ДобавленыеСтруктурныеЕдиницы.Найти(СтруктурнаяЕдиница) = Неопределено Тогда
					НоваяСтрока 				   = ДанныеДерева.Вставить(0);
					НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
					НоваяСтрока.ИндКартинки 	   = 1;	
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
		МассивВыбранныхСтруктурныхЕдиниц = Неопределено;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивКолонок) Тогда		
		Для Каждого  ЭлементМ Из МассивКолонок Цикл 
			УстановитьНачальноеСостояниеФлагов(ЭлементДерево.ПолучитьЭлементы(), МассивВыбранныхСтруктурныхЕдиниц, 
			КоличествоСтруктурныхЕдиниц, УстановитьВсеФлагиВИстину,, ЭлементМ);
		КонецЦикла;
	Иначе
		УстановитьНачальноеСостояниеФлагов(ЭлементДерево.ПолучитьЭлементы(), МассивВыбранныхСтруктурныхЕдиниц, 
		КоличествоСтруктурныхЕдиниц, УстановитьВсеФлагиВИстину);
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Процедура, выполянет создание дерева структурных единиц.
//
Процедура СоздатьДеревоСтруктурныхЕдиницЖурналаПриемов(
		Форма, 
		Реквизит, 
		ОбъектОграничения, 
		УстановитьВсеФлагиВИстину = Неопределено, 
		МассивСтруктурныхЕдиниц = Неопределено, 
		МассивДоступныхСтруктурныхЕдиниц = Неопределено, 
		СоответствиеИндексамКартинок = Неопределено,
		МассивКолонок = Неопределено,
		ОтображатьПервыйУровеньДерева = Ложь) Экспорт
	
	Если МассивСтруктурныхЕдиниц = Неопределено Тогда
		МассивСтруктурныхЕдиниц = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц();
	КонецЕсли;
	КоличествоСтруктурныхЕдиниц = МассивСтруктурныхЕдиниц.Количество();
	
	ЭлементДерево            = Форма.ПодборЖурналыПриемовСотрудника;
	ПервыйУровеньДерева 	 = ЭлементДерево.ПолучитьЭлементы();
	ПервоначальноеЗаполнение = ПервыйУровеньДерева.Количество() = 0;
	
	Если ПервоначальноеЗаполнение Тогда
		
		ОтображатьПервыйУровеньДерева = ОтображатьПервыйУровеньДерева ИЛИ ТипЗнч(ОбъектОграничения) = Тип("СправочникСсылка.Сотрудники");
		
		ЗаполнитьДеревоСтруктурныхЕдиниц(МассивСтруктурныхЕдиниц, ЭлементДерево, Форма, 
		СоответствиеИндексамКартинок, ОтображатьПервыйУровеньДерева, ОбъектОграничения);
		
		МассивВыбранныхСтруктурныхЕдиниц = МассивДоступныхСтруктурныхЕдиниц;
		
	Иначе
		
		ДанныеДерева 		   = ПервыйУровеньДерева[0].ПолучитьЭлементы();
		МассивСтрокДляУдаления = Новый Массив();
		
		ДобавленыеСтруктурныеЕдиницы = Новый Массив;
		Для Каждого СтрокаДерева Из ДанныеДерева Цикл
			
			Если МассивСтруктурныхЕдиниц.Найти(СтрокаДерева.СтруктурнаяЕдиница) = Неопределено Тогда
				МассивСтрокДляУдаления.Добавить(СтрокаДерева);
			Иначе
				ДобавленыеСтруктурныеЕдиницы.Добавить(СтрокаДерева.СтруктурнаяЕдиница);
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
			ДанныеДерева.Удалить(СтрокаДляУдаления);		
		КонецЦикла;
		
		Если СоответствиеИндексамКартинок <> Неопределено
			И ТипЗнч(СоответствиеИндексамКартинок) = Тип("Соответствие") Тогда
			
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
				Если ДобавленыеСтруктурныеЕдиницы.Найти(СтруктурнаяЕдиница) = Неопределено Тогда
					НоваяСтрока 				   = ДанныеДерева.Вставить(0);
					НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
					
					Индекс 						   = СоответствиеИндексамКартинок.Получить(СтруктурнаяЕдиница);
					НоваяСтрока.ИндКартинки 	   = ?(Индекс = Неопределено, 1, Индекс);
				КонецЕсли;
			КонецЦикла;
			
		Иначе
			
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
				Если ДобавленыеСтруктурныеЕдиницы.Найти(СтруктурнаяЕдиница) = Неопределено Тогда
					НоваяСтрока 				   = ДанныеДерева.Вставить(0);
					НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
					НоваяСтрока.ИндКартинки 	   = 1;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;	
		
		МассивВыбранныхСтруктурныхЕдиниц = Неопределено;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивКолонок) Тогда		
		Для Каждого  ЭлементМ Из МассивКолонок Цикл 
			УстановитьНачальноеСостояниеФлагов(ЭлементДерево.ПолучитьЭлементы(), МассивВыбранныхСтруктурныхЕдиниц, КоличествоСтруктурныхЕдиниц, УстановитьВсеФлагиВИстину,, ЭлементМ);
		КонецЦикла;
	Иначе
		УстановитьНачальноеСостояниеФлагов(ЭлементДерево.ПолучитьЭлементы(), МассивВыбранныхСтруктурныхЕдиниц, КоличествоСтруктурныхЕдиниц, УстановитьВсеФлагиВИстину);
	КонецЕсли;
		
КонецПроцедуры

