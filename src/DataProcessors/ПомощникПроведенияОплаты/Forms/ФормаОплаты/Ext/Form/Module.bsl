// Процедура - Установить авто ввод сумм для авансов
//
Процедура УстановитьАвтоВводСуммДляАвансов()   	
	
	Если ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Количество() <> 0
		И СписокИндексовСтрок.Количество() <> 0 
		И ЭтоВзносАванса = Ложь Тогда			
		
		Элементы.ГруппаТаблицаЗадолженностей.ТолькоПросмотр = Истина;
		Для Каждого ИндексСтроки Из СписокИндексовСтрок Цикл
			
			КнопкаВидыОплатаНаименованиеСтрока     = Элементы.Найти("КнопкаВидыОплатаНаименованиеСтрока_" + Строка(ИндексСтроки));
			Если КнопкаВидыОплатаНаименованиеСтрока <> Неопределено Тогда
				ОбработчикНажатияВидыОплатВыбор(КнопкаВидыОплатаНаименованиеСтрока,,, Ложь);
				ПолеВидыОплатВводСуммыСтрока = Элементы.Найти("ПолеВидыОплатВводСуммыСтрока_" + Строка(ИндексСтроки));
				Если ПолеВидыОплатВводСуммыСтрока <> Неопределено Тогда
					ЗавершитьРедактированиеПоляВводаСуммы(ПолеВидыОплатВводСуммыСтрока)
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

