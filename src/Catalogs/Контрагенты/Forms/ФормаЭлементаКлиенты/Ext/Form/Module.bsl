//
//
Функция ПолучитьСтруктуруПараметров(Элемент)
	
	КодСтраны = "";
	КодГорода = "";
	НомерТелефона = "";

	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ИмяЭлемента", 		Элемент.Имя);
	СтруктураПараметров.Вставить("ЗначениеЭлемента", 	Элемент.ТекстРедактирования);
	
	Если Элемент.Имя = "__КИ_Поле1" Тогда  // т.е. это телефон
		МассивСтрок = Этаформа.__КИ_ОписаниеДополнительныхРеквизитов.НайтиСтроки(Новый Структура("ИмяРеквизита", Элемент.Имя)); 
		Если МассивСтрок.Количество() > 0 Тогда 
			СписокЗначений = МассивСтрок[0].ЗначенияПолей;
			Для Каждого ЭлементСписка Из МассивСтрок[0].ЗначенияПолей Цикл 
				Если ЭлементСписка.Представление = "КодСтраны" Тогда 
					КодСтраны = ЭлементСписка.Значение;
				КонецЕсли;
				Если ЭлементСписка.Представление = "КодГорода" Тогда 
					КодГорода = ЭлементСписка.Значение;
				КонецЕсли;
				Если ЭлементСписка.Представление = "НомерТелефона" Тогда
					НомерТелефона = ЭлементСписка.Значение;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;		
	КонецЕсли;
	
	СтруктураПараметров.Вставить("КодСтраны", 		КодСтраны);
	СтруктураПараметров.Вставить("КодГорода", 		КодГорода);
	СтруктураПараметров.Вставить("НомерТелефона", 	НомерТелефона);
	
	Возврат СтруктураПараметров;
	
КонецФункции

