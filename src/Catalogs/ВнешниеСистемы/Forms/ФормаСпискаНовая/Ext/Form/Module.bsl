// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура УдалитьЭлементыВнешнейСистемы(ВнешняяСистема, Раздел)
	
	ЭтотОбъект.ТаблицаВнешнихСистем.Очистить();
	
	ИсключаемыеЭлементы = Новый Массив;                         
	ИсключаемыеЭлементы.Добавить(Элементы.ГруппаРазделы);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_ДекорацияКартинка);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_ДекорацияНадпись);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкиУправления);
    ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_ГруппаУдалить);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкаУдалить);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_ГруппаОтключить);
    ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкаОтключить);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_ГруппаНастройки);
	ИсключаемыеЭлементы.Добавить(Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкаНастройки);
	
	УправлениеИнтерфейсамиСервер.УдалитьПодчиненныеЭлементыГруппы(ЭтаФорма, Элементы.ГруппаРазделы, ИсключаемыеЭлементы);

КонецПроцедуры 

