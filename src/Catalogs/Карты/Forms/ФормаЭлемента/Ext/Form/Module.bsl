// Заполнить шаблон карты для печати
//
Функция ЗаполнитьШаблонКарты(ХранилищеШаблоновСсылка, ГенерироватьКартинкуШтрихкода)

	ШаблонКарты = ХранилищеШаблоновСсылка.Шаблон.Получить();
	
	ТабДок = Новый ТабличныйДокумент;	
	Если ШаблонКарты <> Неопределено Тогда
		ШаблонКарты.Свойство("РедакторТабличныйДокумент", ТабДок);	
	КонецЕсли;
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВладелецКартыИмя"     	     , Объект.ВладелецКарты.Имя));
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВладелецКартыФамилия" 	     , Объект.ВладелецКарты.Фамилия));
    МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВладелецКартыОтчество"	     , Объект.ВладелецКарты.Отчество));
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВладелецКартыНаименование"   , Объект.ВладелецКарты.Наименование));
	Если ТипЗнч(Объект.ВладелецКарты) = Тип("СправочникСсылка.Контрагенты") Тогда
		МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВладелецКартыДатаРегистрации", Формат(Объект.ВладелецКарты.ДатаРегистрации, "ДЛФ=Д")));	
	КонецЕсли;
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","КодКарты"                    , Объект.КодКарты));
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВидКарты"                    , Строка(Объект.ВидКарты)));	
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ТипКода"                     , Строка(Объект.ТипКода)));
	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ДатаОткрытия"                , Формат(Объект.ДатаОткрытия, "ДЛФ=Д")));

	МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВнутреннийКодКарты"          , Объект.ВнутреннийКодКарты));
	
	//// Если у владеца есть пиктограмма фотографии
	// Если Новый_Массив(Тип("СправочникСсылка.Контрагенты"), Тип("СправочникСсылка.Сотрудники")).Найти(ТипЗнч(Объект.ВладелецКарты)) <> Неопределено И ЗначениеЗаполнено(Объект.ВладелецКарты.ФайлКартинки) Тогда
	//	
	//	ФотоКлиента = ПолучитьНавигационнуюСсылкуКартинки(Объект.ВладелецКарты.ФайлКартинки,УникальныйИдентификатор);	
	//	ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(Объект.ВладелецКарты.ФайлКартинки);
	//	Если ДанныеФайла.ДвоичныеДанные <> Неопределено Тогда
	//		ФотоКлиента = Новый Картинка(ДанныеФайла.ДвоичныеДанные);
	//		МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра","ВладелецКартыФайлКартинки",ФотоКлиента));
	//	КонецЕсли;
	//	
	// КонецЕсли;
	
	Эталон = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("Эталон");
	КоличествоМиллиметровВПикселе = Эталон.Рисунки.Квадрат100Пикселей.Высота / 100;
	
	// Получаем картинку штрихкода карты
	Если ГенерироватьКартинкуШтрихкода Тогда
		Если ШаблонКарты <> Неопределено Тогда
			Область = ТабДок.ПолучитьОбласть(ШаблонКарты.ИмяОбластиПечати);
			
			Для каждого Рисунок Из Область.Рисунки Цикл
				Если Лев(Рисунок.Имя,8) = "ШтрихКод" Тогда
					
					// ЗначениеШтрихкода = СтрокаТовары[СтруктураРезультата.СоответствиеПолейСКДКолонкамТаблицыТоваров.Получить(ПолучитьИмяПараметраШтрихкод())];
					// Если ЗначениеЗаполнено(ЗначениеШтрихкода) Тогда
					
					ПараметрыШтрихкода = Новый Структура;
					ПараметрыШтрихкода.Вставить("Ширина",          Окр(Рисунок.Ширина / КоличествоМиллиметровВПикселе));
					ПараметрыШтрихкода.Вставить("Высота",          Окр(Рисунок.Высота / КоличествоМиллиметровВПикселе));
					ПараметрыШтрихкода.Вставить("ТипКода",         ШаблонКарты.ТипКода);
					ПараметрыШтрихкода.Вставить("ОтображатьТекст", ШаблонКарты.ОтображатьТекст);
					ПараметрыШтрихкода.Вставить("РазмерШрифта",    ШаблонКарты.РазмерШрифта);								
					ПараметрыШтрихкода.Вставить("Штрихкод",        Объект.КодКарты);
					
					Картинка          = Обработки.ПечатьЭтикетокИЦенников.ПолучитьКартинкуШтрихкода(ПараметрыШтрихкода);
					// Новый Структура("Ширина,Высота,ТипКода,ОтображатьТекст,РазмерШрифта,Штрихкод",400,40,3,Истина,8,Объект.КодКарты));	
					
					МассивПараметров.Добавить(Новый Структура("ИмяПараметра,ЗначениеПараметра", "ШтрихКод", Картинка));
					
					Прервать;
					
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;	
	
	Справочники.ХранилищеШаблонов.ЗаполнитьШаблоныВТабличномДокументе(ТабДок,МассивПараметров);
	
	ТабДок.ИмяПараметровПечати = "ПАРАМЕТРЫ_Печать_Карты";
	
	Возврат ТабДок;
	
КонецФункции

