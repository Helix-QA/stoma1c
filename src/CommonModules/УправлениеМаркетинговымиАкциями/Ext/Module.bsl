	Для Каждого СтрокаТЧСкидки Из ТаблицаСкидок Цикл
		
		Если СтрокаТЧСкидки.СпособПредоставленияСкидки <> Перечисления.СпособПредоставленияСкидки.Подарок Тогда
			Продолжить;
		КонецЕсли; 
		
		// Заполняем количество
		Если СтрокаТЧСкидки.СкидкаНаценка.СкидкаНаЕдиныйКомплект = Истина
				И СтрокаТЧСкидки.СкидкаНаценка.НаборПокупкиДляПолученияПодарков.Количество() > 0 Тогда
				
			Запрос.УстановитьПараметр("Ссылка" , СтрокаТЧСкидки.СкидкаНаценка);
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	НаборПокупкиДляПолученияПодарков.Скидка КАК Скидка,
			|	МИНИМУМ(ВЫБОР
			|			КОГДА НаборПокупкиДляПолученияПодарков.Количество = 0
			|				ТОГДА 0
			|			КОГДА ЕСТЬNULL(ТаблицаТоваров.Количество, 0) = 0
			|				ТОГДА 0
			|			ИНАЧЕ ТаблицаТоваров.Количество / НаборПокупкиДляПолученияПодарков.Количество
			|		КОНЕЦ) КАК Количество
			|ИЗ
			|	(ВЫБРАТЬ
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Ссылка КАК Скидка,
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Номенклатура КАК Номенклатура,
			|		СУММА(СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Количество) КАК Количество
			|	ИЗ
			|		Справочник.СкидкиНаценки.НаборПокупкиДляПолученияПодарков КАК СкидкиНаценкиНаборПокупкиДляПолученияПодарков
			|	ГДЕ
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Ссылка = &Ссылка
			|	
			|	СГРУППИРОВАТЬ ПО
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Ссылка,
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Номенклатура) КАК НаборПокупкиДляПолученияПодарков
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаТовары КАК ТаблицаТоваров
			|		ПО НаборПокупкиДляПолученияПодарков.Номенклатура = ТаблицаТоваров.Номенклатура
			|
			|СГРУППИРОВАТЬ ПО
			|	НаборПокупкиДляПолученияПодарков.Скидка";
			
			СтрокаТЧСкидки.ЗначениеСкидкиНаценки = 0;
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				СтрокаТЧСкидки.ЗначениеСкидкиНаценки = Цел(Выборка.Количество);
			КонецЕсли;
		ИначеЕсли СтрокаТЧСкидки.СкидкаНаценка.СкидкаНаЕдиныйКомплект = Истина
				И СтрокаТЧСкидки.СкидкаНаценка.НаборПокупкиДляПолученияПодарков.Количество() = 0 Тогда
			СтрокаТЧСкидки.ЗначениеСкидкиНаценки = СтрокаТЧСкидки.Количество;
		Иначе
			СтрокаТЧСкидки.ЗначениеСкидкиНаценки = 1;
		КонецЕсли;
		СтрокаТЧСкидки.СуммаСкидки = СтрокаТЧСкидки.СуммаСкидки * СтрокаТЧСкидки.ЗначениеСкидкиНаценки;
	КонецЦикла;
	
