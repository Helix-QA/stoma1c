&НаКлиенте
// Процедура - Открыть список салонов заверщение
// 
// Параметры:
//  Результат	 - 	 -
//  ДопПараметры - 	 -
// 
Процедура ОткрытьСписокКлиникЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ПроверитьНеобходимостьФиксацииИзмененийВПлане() = Истина Тогда
		СтруктураПарметров = Новый Структура;
		СтруктураПарметров.Вставить("ИмяЭлемента"	, Элементы.ОтборПериод.Имя);		
		СтруктураПарметров.Вставить("КодДляОтката"	, Элементы.ОтборПериод.Имя + "= ОткатВыбранногоЗначения;");
		Оповещение   = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОФиксацииизменений", ЭтотОбъект, СтруктураПарметров);
		ПоказатьВопрос(Оповещение, "Имеются не сохраненные изменения, они будут потеряны. Продолжить ?", РежимДиалогаВопрос.ДаНет,,, "Планирование");
		Возврат;
	Иначе 
		ОтборСотрудникДолжность = "Все";
		Элементы.ОткрытьСписокСотрудники.Заголовок =  "Все";
		
		ВыбранноеЗначение		= ?(ТипЗнч(Результат) = Тип("СправочникСсылка.СтруктурныеЕдиницы"), Результат,Результат.Значение);
		ОтборСтруктурнаяЕдиница = ВыбранноеЗначение;
		
		Элементы.ОткрытьСписокКлиник.Заголовок = Строка(ВыбранноеЗначение);
		
		ВремяРаботыСтруктурнойЕдиницы = ВернутьВремяРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница);
		
		СписокПериодов = ПолучитьСписокПериодовРаботы(ОтборСтруктурнаяЕдиница);
		ЗадатьПериодСменыНаФорме();
		
		ОбновитьОтображениеПланирования(Истина);	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Отбор периода планировании при изменении
// 
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ОтборПериодаПланированииПриИзменении(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат = Неопределено Тогда
		
		ЭтоОчистка = Результат.ДатаНачала = Дата(1,1,1);
		
		Если Не ЗначениеЗаполнено(Результат.ДатаОкончания) Тогда
			Результат.ДатаОкончания = КонецМесяца(?(ЗначениеЗаполнено(Результат.ДатаНачала), Результат.ДатаНачала, КонецМесяца(Результат.ДатаНачала)));		
		КонецЕсли;
		
		Если ДобавитьМесяц(Результат.ДатаНачала, 3) <  Результат.ДатаОкончания Тогда
			Результат.ДатаОкончания = ДобавитьМесяц(КонецМесяца(Результат.ДатаНачала), 2);	
		КонецЕсли;
		
		ОтборПериод = Результат;
		
		Если ПроверитьНеобходимостьФиксацииИзмененийВПлане() = Истина Тогда
			СтруктураПарметров = Новый Структура;
			Оповещение   = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОФиксацииизменений", ЭтотОбъект, СтруктураПарметров);
			ПоказатьВопрос(Оповещение,"Имеются не сохраненные изменения, они будут потеряны. Продолжить ?",РежимДиалогаВопрос.ДаНет,,,"Планирование");
			Возврат;
		Иначе 
			ОбновитьОтображениеПланирования(Истина);
		КонецЕсли;
		
		ОтборГрафикПериодовРаботыПоСотруднику();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - После закрытия формы создания оповещение
// 
// Параметры:
//  РезультатПланирования	 - 	 - 
//  ДопПараметры			 - 	 - 
// 
Процедура ПослеЗакрытияФормыСозданияОповещение(Результат, ДопПараметры) Экспорт
	
	НСтроки                = 0;
	ЗадаватьВопрос         = Истина;
	РезультатВопроса       = Неопределено;
	РезультатПланирования  = Неопределено;
	
	Если ТипЗнч(ДопПараметры) = Тип("Структура")
		И ДопПараметры.Свойство("РезВопроса") Тогда
		
		РезультатВопроса      = Результат;
		РезультатПланирования = ДопПараметры.РезультатПланирования;
		НСтроки               = ДопПараметры.НСтроки;		
		Если ЗначениеЗаполнено(РезультатВопроса) Тогда
			ЗадаватьВопрос = НЕ РезультатВопроса.ДляВсех;
		КонецЕсли;
	Иначе
		РезультатПланирования = Результат;
	КонецЕсли;
	
	// Не проверяем наложение новых рабочих периодов, на существующие интревалы
	Если РезультатПланирования <> Неопределено Тогда
		ДополнитьБуферНовымиДаннымиПланирования(РезультатПланирования);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор шаблона из списка
// 
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ВыборШаблонаИзСписка(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда 
		Возврат;
	Иначе
		ОтборИнтервалыРаботы.Очистить();
		
		Если ВыбранныйЭлемент.Значение = "Отпуск" 
			Или ВыбранныйЭлемент.Значение = "Больничный" Тогда
			
			Элементы.ГруппаСписокИнтерваловРаботы.Видимость = Ложь;
			Элементы.ГруппаДобавитьИнтервал.Видимость       = Ложь;	
			Элементы.ПоказатьСписокШаблонов.Заголовок       = ВыбранныйЭлемент.Значение;
			
			ТипРабочегоВремени = ?(ВыбранныйЭлемент.Значение = "Отпуск", ПредопределенноеЗначение("Перечисление.ТипыРабочегоВремени.Отпуск"), ПредопределенноеЗначение("Перечисление.ТипыРабочегоВремени.Больничный"));
			
		ИначеЕсли СокрЛП(ВыбранныйЭлемент.Значение) = "Смены:" Тогда
			
			Элементы.ГруппаСписокИнтерваловРаботы.Видимость = Истина;
			Элементы.ГруппаДобавитьИнтервал.Видимость       = Истина;	
			Элементы.ПоказатьСписокШаблонов.Заголовок       = ВыбранныйЭлемент.Значение;
			Если ОтборИнтервалыРаботы.Количество() = 0 Тогда
	            ОтборИнтервалыРаботы.Добавить(Новый Структура("НачалоРаботы, ОкончаниеРаботы", Неопределено, Неопределено));
			КонецЕсли;
			
			ОбновитьМенюОтбораИнтерваловРабот();
			ОбновитьОбщееВремяИнтервалов();		

			ТипРабочегоВремени = ПредопределенноеЗначение("Перечисление.ТипыРабочегоВремени.Рабочее");

		Иначе
			Для Каждого ЭлементСписка Из ВыбранныйЭлемент.Значение Цикл 
				ОтборИнтервалыРаботы.Добавить(ЭлементСписка.Значение, ЭлементСписка.Представление);
			КонецЦикла;	
			ОбновитьМенюОтбораИнтерваловРабот();
			ОбновитьОбщееВремяИнтервалов();		
			ОбновитьДекорациюУпраленияСохранениемСмен(ОтборСтруктурнаяЕдиница, ЭлементСписка.Значение);
			
			Элементы.ГруппаСписокИнтерваловРаботы.Видимость = Истина;
			Элементы.ГруппаДобавитьИнтервал.Видимость       = Истина;
			
			ТипРабочегоВремени = ПредопределенноеЗначение("Перечисление.ТипыРабочегоВремени.Рабочее");
			
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура - После вопроса о записи изменений оповещение
// 
// Параметры:
//  Ответ		 - 	 - 
//  ДопПараметры - 	 - 
// 
Процедура ПослеВопросаОЗаписиИзмененийОповещение(Ответ, ДопПараметры) Экспорт
	
	ПроверятьНеобхЗаписи = Ложь;
	Если Ответ = КодВозвратаДиалога.Да Тогда
		КомандаСформировать(Неопределено);	
	ИначеЕсли Ответ = КодВозвратаДиалога.Отмена Тогда
		ПроверятьНеобхЗаписи = Истина;
		Возврат;
	КонецЕсли;
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

&НаКлиенте
// Обработчик асинхронного вызова после диалога вопроса
// 
Процедура ПослеЗакрытияВопросаОФиксацииизменений(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Если ЭтоОчистка = Неопределено Тогда
			ЭтоОчистка = Ложь;
		КонецЕсли;
		
		Если ЭтоОчистка И Параметры.Свойство("ИмяЭлемента") И Параметры.ИмяЭлемента = "ОтборПериод" Тогда
			ЭтоОчистка = Ложь;
			БуферФормирования.Очистить();
		КонецЕсли;
		ОбновитьОтображениеПланирования(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор времени из списка
// 
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ВыборВремениИзСписка(ВыбранныйЭлемент, ДополнительныеПараметры = Неопределено) Экспорт
	
	Отказ = Ложь;
	
	Если ВыбранныйЭлемент = Неопределено Тогда 
		Возврат;
	Иначе
		// Запоминаем значение
		ЗначениеДоИзменения = ДополнительныеПараметры.ДанныеЭлемента.Значение;
		// Моделируем новое значение
		Если ДополнительныеПараметры.ЭтоНачалоИнтервала Тогда 
			ЗначениеПослеИзменения = Новый Структура("НачалоРаботы, ОкончаниеРаботы", ВыбранныйЭлемент.Значение, ЗначениеДоИзменения.ОкончаниеРаботы);
		Иначе 
			ЗначениеПослеИзменения = Новый Структура("НачалоРаботы, ОкончаниеРаботы", ЗначениеДоИзменения.НачалоРаботы, ВыбранныйЭлемент.Значение);
		КонецЕсли;
		// Производим проверку
		Если НЕ ЗначениеПослеИзменения.НачалоРаботы = Неопределено И НЕ ЗначениеПослеИзменения.ОкончаниеРаботы = Неопределено Тогда
			Если ЗначениеПослеИзменения.НачалоРаботы = ЗначениеПослеИзменения.ОкончаниеРаботы Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Время начала работы не может быть равно времени окончания работы!", ЭтотОбъект);
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			Если ЗначениеПослеИзменения.НачалоРаботы > ЗначениеПослеИзменения.ОкончаниеРаботы Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Время начала работы не может быть больше времени окончания работы!", ЭтотОбъект);
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			Для Каждого ИнтервалСписка ИЗ ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы] Цикл
				ИндексИнтервала = ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы].Индекс(ИнтервалСписка);
				Если ИндексИнтервала <> ДополнительныеПараметры.ИндексСтроки И 
					НЕ ИнтервалСписка.Значение.НачалоРаботы = Неопределено И НЕ ИнтервалСписка.Значение.ОкончаниеРаботы = Неопределено Тогда
					
					//  приоритет отдан этому механизму выявления пересечения периодов
					Если Макс(ЗначениеПослеИзменения.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы) < Мин(ЗначениеПослеИзменения.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы) Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Обнаружено пересечение времени: с " + Формат(Макс(ЗначениеПослеИзменения.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы), "ДФ=HH:mm") + " по " + Формат(Мин(ЗначениеПослеИзменения.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы), "ДФ=HH:mm"), ЭтотОбъект);
						Отказ = Истина;	
						Прервать;
					КонецЕсли;
					
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;			
		Если НЕ Отказ Тогда 
			ДополнительныеПараметры.ДанныеЭлемента.Значение 		= ЗначениеПослеИзменения;
			ДополнительныеПараметры.ДанныеЭлемента.Представление 	= ОбщегоНазначенияКлиентСерверСтоматология.ПолучитьПредставлениеИнтервала(ДополнительныеПараметры.ДанныеЭлемента.Значение);
			Элементы[ДополнительныеПараметры.ИмяЭлемента].Заголовок = Формат(ВыбранныйЭлемент.Значение, "ДФ=HH:mm");
			Если ДополнительныеПараметры.ЭтоНачалоИнтервала И ДополнительныеПараметры.ДанныеЭлемента.Значение.ОкончаниеРаботы = Неопределено Тогда
				Подключаемый_ВыборОкончанияИнтервала(ЭтаФорма.Команды.Найти("Подключаемый_ВыборОкончанияИнтервала_" + ДополнительныеПараметры.ИндексСтроки));
			КонецЕсли;
			ОбновитьОбщееВремяИнтервалов();
			ОбновитьДекорациюУпраленияСохранениемШаблонов();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

