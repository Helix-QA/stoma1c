// Функция - Создать пакет услуг
//
// Параметры:
//  СтруктураРеквизитов	 - 	 - 
//  НоменклатураПУ		 - 	 - 
//  ТекущийКлиент		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьПакетУслуг(СтруктураРеквизитов, НоменклатураПУ, ТекущийКлиент, ПараметрыЗагрузки, ТекстовыйНакопитель, ЗагружатьПакетыСНулевойСтоимостью = Ложь)
	
	ПакетУслугОбъект 							= Документы.ЧленствоПакетУслуг.СоздатьДокумент();
	ПакетУслугОбъект.ЗаполнитьЧленствоПакетУслугПоНоменклатуре(НоменклатураПУ);
	ПакетУслугОбъект.Контрагент 					= ТекущийКлиент;
	ПакетУслугОбъект.КодСинхронизации 				= СтруктураРеквизитов.ИДБлока;
	ПакетУслугОбъект.ПрефиксСинхронизации 			= СтруктураРеквизитов.ПрефиксСинхронизации;
	ПакетУслугОбъект.Комментарий 					= СтруктураРеквизитов.ПрефиксСинхронизации + " - " + Формат(СтруктураРеквизитов.ИДБлока, "ЧГ=0");
	ПакетУслугОбъект.Дата 							= СтруктураРеквизитов.ДатаЧека;	
	ПакетУслугОбъект.ДатаРучнойАктивации 			= СтруктураРеквизитов.ДатаЧека;	
	ПакетУслугОбъект.СтруктурнаяЕдиница 			= ПараметрыЗагрузки.СтруктурнаяЕдиница;
	
	Если ПараметрыЗагрузки.Свойство("МассивБессрочных") И ЗначениеЗаполнено(ПараметрыЗагрузки.МассивБессрочных) И НЕ ПараметрыЗагрузки.МассивБессрочных.Найти(НоменклатураПУ) = Неопределено Тогда 
		ПакетУслугОбъект.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокНеОграничен;	
	Иначе 		
		// Вычисляем срок действия исходя из даты окончания пакета в аклабе, которую в свою очередь тоже вычисляем, прибавлением кол-ва дней к дате константе.
		Если ЗначениеЗаполнено(СтруктураРеквизитов.СрокДействияВычисляемый) И СтруктураРеквизитов.СрокДействияВычисляемый > 0 Тогда 
			ДатаОкончанияПакетаУслуг 			= Дата('18991230000000') + СтруктураРеквизитов.СрокДействияВычисляемый * 86400;
			Если ДатаОкончанияПакетаУслуг > ПакетУслугОбъект.ДатаРучнойАктивации Тогда 
				ПакетУслугОбъект.СрокДействия 	= Цел((ДатаОкончанияПакетаУслуг - ПакетУслугОбъект.ДатаРучнойАктивации) / 86400);			
			КонецЕсли;
		Иначе
			СрокДействияСУчетомЗаморозки 		= НачалоДня(СтруктураРеквизитов.ОкончаниеКонтракта) + СтруктураРеквизитов.КоличествоДнейЗаморозки * 86400;
			ПакетУслугОбъект.СрокДействия 		= Цел((СрокДействияСУчетомЗаморозки - ПакетУслугОбъект.ДатаРучнойАктивации) / 86400);					
		КонецЕсли;
		
		// Скорей всего в Аклабе - это бессрочный пакет. У нас такие варианты не проходят - поэтому пишем им год.
		Если ПакетУслугОбъект.СрокДействия <= 0 Тогда 
			ПакетУслугОбъект.СрокДействия 		= 365;
		КонецЕсли;
		
		ПакетУслугОбъект.СрокДействияДатой 		= (НачалоДня(ПакетУслугОбъект.ДатаРучнойАктивации) + ПакетУслугОбъект.СрокДействия * 86400) - 86400;
		
		// Если СтруктураРеквизитов.СрокДействия > 0 Тогда  убрал ValidDays из запроса
		//	ПакетУслугОбъект.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокОграниченПериодом;
		//	ПакетУслугОбъект.СрокДействияТип = Перечисления.Периодичность.День;
		//	ПакетУслугОбъект.СрокДействия = СтруктураРеквизитов.СрокДействия;
		// КонецЕсли;
	КонецЕсли;

	//// Найти или добавить услугу в членство
	// КодУслуги = Строка(СтруктураРеквизитов.ИДНоменклатуры);
	// КодУслугиБлока = Прав(КодУслуги, СтрДлина(КодУслуги)-1);
	// КодУслугиБлока = Число("4" + КодУслугиБлока);	
	// НоменклатураУслуги = Справочники.Номенклатура.НайтиПоРеквизиту("КодСинхронизации", КодУслугиБлока);
	
	Если ЗначениеЗаполнено(СтруктураРеквизитов.НоменклатураУслугиПакета) Тогда // Если выше вдруг номенклатуру пакета получили из допника, то наверно и здесь надо брать номенклатуру услуги пакета из допника. Но решил пока не трогать логику Максима.
		СтрокаУслуга = ПакетУслугОбъект.СоставУслуг.Найти(СтруктураРеквизитов.НоменклатураУслугиПакета, "УслугаСегмент");
		Если СтрокаУслуга = Неопределено Тогда
			СтрокаУслуга = ПакетУслугОбъект.СоставУслуг.Добавить();
			СтрокаУслуга.УслугаСегмент = СтруктураРеквизитов.НоменклатураУслугиПакета;
		КонецЕсли;
		СтрокаУслуга.Количество = ?(НЕ ЗначениеЗаполнено(СтруктураРеквизитов.КоличествоУслуг) И ЗагружатьПакетыСНулевойСтоимостью, СтрокаУслуга.Количество, СтруктураРеквизитов.КоличествоУслуг);			
	КонецЕсли;
	
	Попытка
		ЗаписатьДокумент(ПакетУслугОбъект);	
	Исключение
		// Запись в лог
		ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + СтрШаблон(НСтр("ru = 'Ошибка создания док-та Пакет услуг клиента ""%1"" Код синхронизации: %2';en= 'Error creating document Client service package ""%1"" Sync code: %2'"),Строка(ТекущийКлиент), СокрЛП(СтруктураРеквизитов.ИДБлока) + Символы.ПС + ОписаниеОшибки()));						
	КонецПопытки;	
	
	// Доступные структурные единицы
	НаборЗаписей = РегистрыСведений.СтруктурныеЕдиницыОбъектов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Значение      = ПакетУслугОбъект.Ссылка;
	НаборЗаписей.Отбор.Объект.Использование = Истина;	
	НоваяЗапись                    			= НаборЗаписей.Добавить();
	НоваяЗапись.СтруктурнаяЕдиница			= ПараметрыЗагрузки.СтруктурнаяЕдиница;
	НоваяЗапись.Объект             			= ПакетУслугОбъект.Ссылка;
	НаборЗаписей.ОбменДанными.Загрузка = Истина;
	НаборЗаписей.Записать(Ложь);
	
	Возврат ПакетУслугОбъект.Ссылка;
	
КонецФункции

// Процедура - Обновить пакет услуг
//
// Параметры:
//  ПакетУслуг			 - 	 - 
//  СтруктураРеквизитов	 - 	 - 
//  НоменклатураПУ		 - 	 - 
//  ТекущийКлиент		 - 	 - 
//
Процедура ОбновитьПакетУслуг(ПакетУслуг, СтруктураРеквизитов, НоменклатураПУ, ТекущийКлиент, ПараметрыЗагрузки, ТекстовыйНакопитель, ЗагружатьПакетыСНулевойСтоимостью = Ложь)
	
	БессрочныйПакетУслуг = Ложь;
	Если ПараметрыЗагрузки.Свойство("МассивБессрочных") И ЗначениеЗаполнено(ПараметрыЗагрузки.МассивБессрочных) И НЕ ПараметрыЗагрузки.МассивБессрочных.Найти(НоменклатураПУ) = Неопределено Тогда 
		БессрочныйПакетУслуг = Истина; ПакетУслуг.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокНеОграничен;	
	КонецЕсли; 		
	
	СрокДействияПакета = ПакетУслуг.СрокДействия;
	Если НЕ БессрочныйПакетУслуг Тогда 
		// Вычисляем срок действия исходя из даты окончания пакета в аклабе, которую в свою очередь тоже вычисляем, прибавлением кол-ва дней к дате константе.
		Если ЗначениеЗаполнено(СтруктураРеквизитов.СрокДействияВычисляемый) И СтруктураРеквизитов.СрокДействияВычисляемый > 0 Тогда 
			ДатаОкончанияПакетаУслуг 		= Дата('18991230000000') + СтруктураРеквизитов.СрокДействияВычисляемый * 86400;
			Если ДатаОкончанияПакетаУслуг > СтруктураРеквизитов.ДатаЧека Тогда
				СрокДействияПакета 			= Цел((ДатаОкончанияПакетаУслуг - СтруктураРеквизитов.ДатаЧека) / 86400); 
			КонецЕсли;
		Иначе
			СрокДействияСУчетомЗаморозки 	= НачалоДня(СтруктураРеквизитов.ОкончаниеКонтракта) + СтруктураРеквизитов.КоличествоДнейЗаморозки * 86400;
			СрокДействияПакета 	= Цел((СрокДействияСУчетомЗаморозки - СтруктураРеквизитов.ДатаЧека) / 86400);
		КонецЕсли;
		
		// Скорей всего в Аклабе - это бессрочный пакет. У нас такие варианты не проходят - поэтому пишем им год.
		Если СрокДействияПакета <= 0 Тогда 
			СрокДействияПакета 				= 365;
		КонецЕсли;
	КонецЕсли;
	
	Если БессрочныйПакетУслуг ИЛИ ПакетУслуг.СрокДействия <> СрокДействияПакета ИЛИ ПакетУслуг.СоставУслуг.Итог("Количество") <> СтруктураРеквизитов.КоличествоУслуг Тогда
		ПакетУслугОбъект = ПакетУслуг.ПолучитьОбъект();
		ПакетУслугОбъект.СоставУслуг.Очистить();
		ПакетУслугОбъект.ЗаполнитьЧленствоПакетУслугПоНоменклатуре(НоменклатураПУ);
		ПакетУслугОбъект.Контрагент 			= ТекущийКлиент;
		ПакетУслугОбъект.КодСинхронизации 		= СтруктураРеквизитов.ИДБлока;
		ПакетУслугОбъект.Комментарий 			= ПакетУслугОбъект.ПрефиксСинхронизации + " - " + Формат(СтруктураРеквизитов.ИДБлока,"ЧГ=0");
		ПакетУслугОбъект.Дата 					= СтруктураРеквизитов.ДатаЧека;	
		ПакетУслугОбъект.ДатаРучнойАктивации 	= СтруктураРеквизитов.ДатаЧека;	
		ПакетУслугОбъект.СтруктурнаяЕдиница 	= ПараметрыЗагрузки.СтруктурнаяЕдиница;
		ПакетУслугОбъект.СрокДействия 			= СрокДействияПакета;			
		ПакетУслугОбъект.СрокДействияДатой 		= (НачалоДня(ПакетУслугОбъект.ДатаРучнойАктивации) + ПакетУслугОбъект.СрокДействия * 86400) - 86400;
		
		//// Найти или добавить услугу в членство
		// КодУслуги = Строка(СтруктураРеквизитов.ИДНоменклатуры);
		// КодУслугиБлока = Прав(КодУслуги, СтрДлина(КодУслуги)-1);
		// КодУслугиБлока = Число("4" + КодУслугиБлока);	
		// НоменклатураУслуги = Справочники.Номенклатура.НайтиПоРеквизиту("КодСинхронизации", КодУслугиБлока);
		
		Если ЗначениеЗаполнено(СтруктураРеквизитов.НоменклатураУслугиПакета) Тогда // Если выше номенклатуру пакета получили из допника, то наверно и здесь надо брать номенклатуру услуги пакета из допника. Но решил пока не трогать логику Максима.
			СтрокаУслуга = ПакетУслугОбъект.СоставУслуг.Найти(СтруктураРеквизитов.НоменклатураУслугиПакета, "УслугаСегмент");
			Если СтрокаУслуга = Неопределено Тогда
				СтрокаУслуга = ПакетУслугОбъект.СоставУслуг.Добавить();
				СтрокаУслуга.УслугаСегмент = СтруктураРеквизитов.НоменклатураУслугиПакета;
			КонецЕсли;
			СтрокаУслуга.Количество = ?(НЕ ЗначениеЗаполнено(СтруктураРеквизитов.КоличествоУслуг) И ЗагружатьПакетыСНулевойСтоимостью, СтрокаУслуга.Количество, СтруктураРеквизитов.КоличествоУслуг);			
		КонецЕсли;
		
		Попытка
			// Запишем документ
			ЗаписатьДокумент(ПакетУслугОбъект);	
		Исключение
			// Запись в лог
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + СтрШаблон(НСтр("ru = 'Ошибка сохранения док-та Пакет услуг клиента ""%1"" Код синхронизации: %2';en= 'Error saving document Client service package ""%1"" Synchronization code: %2'"), Строка(ТекущийКлиент), СокрЛП(СтруктураРеквизитов.ИДБлока) + Символы.ПС + ОписаниеОшибки()));						
		КонецПопытки;	
	Иначе
		Возврат;		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Актуализировать таблицу видов лицевых счетов
//
// Параметры:
//  ТаблицаВидовЛицевыхСчетовВБазе	 - 	 - 
//
Процедура АктуализироватьТаблицуВидовЛицевыхСчетов(ТаблицаВидовЛицевыхСчетовВБазе)

	ТаблицаВидовЛицевыхСчетовВБазе.Колонки.Добавить("ПакетУслугСоставУслуг");
	
	СтрокаВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Найти("Бартер", "Наименование");
	Если СтрокаВидЛС = Неопределено Тогда
		ВидЛС 									= Справочники.ВидыЛицевыхСчетов.СоздатьЭлемент();
		ВидЛС.Наименование 						= "Бартер";
		ВидЛС.НеВестиУчетВРазрезеОрганизаций 	= Истина;
	 	ВидЛС.ОграничениеПоСрокуДействия 		= Перечисления.ТипыОграниченийПакетовУслуг.Бессрочный;
		// ВидЛС.Организация 					= Организация.Ссылка;
		ВидЛС.УстановитьНовыйКод();										
		ВидЛС.ОбменДанными.Загрузка 			= Истина;
		ВидЛС.Записать();
		НоваяСтрока_ВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока_ВидЛС, ВидЛС);
		НоваяСтрока_ВидЛС.ПакетУслугСоставУслуг = ВидЛС.ПакетУслугСоставУслуг.Выгрузить();
	Иначе 
		СтрокаВидЛС.ПакетУслугСоставУслуг = СтрокаВидЛС.Ссылка.ПакетУслугСоставУслуг.Выгрузить();
	КонецЕсли;	
	СтрокаВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Найти("Бонусный", "Наименование");
	Если СтрокаВидЛС = Неопределено Тогда
		ВидЛС 									= Справочники.ВидыЛицевыхСчетов.СоздатьЭлемент();
		ВидЛС.Наименование = "Бонусный";
		ВидЛС.НеВестиУчетВРазрезеОрганизаций 	= Истина;
	 	ВидЛС.ОграничениеПоСрокуДействия 		= Перечисления.ТипыОграниченийПакетовУслуг.Бессрочный;		
		// ВидЛС.Организация 					= Организация.Ссылка;
		ВидЛС.УстановитьНовыйКод();													
		ВидЛС.ОбменДанными.Загрузка 			= Истина;			
		ВидЛС.Записать();
		НоваяСтрока_ВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока_ВидЛС, ВидЛС);
		НоваяСтрока_ВидЛС.ПакетУслугСоставУслуг = ВидЛС.ПакетУслугСоставУслуг.Выгрузить();
	Иначе 
		СтрокаВидЛС.ПакетУслугСоставУслуг = СтрокаВидЛС.Ссылка.ПакетУслугСоставУслуг.Выгрузить();		
	КонецЕсли;
	СтрокаВидЛС = ТаблицаВидовЛицевыхСчетовВБазе.Найти(Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет, "Ссылка");
	Если НЕ СтрокаВидЛС = Неопределено Тогда
		Если СтрокаВидЛС.НеВестиУчетВРазрезеОрганизаций = Ложь Тогда
			ВидЛС = СтрокаВидЛС.Ссылка.ПолучитьОбъект();
			ВидЛС.НеВестиУчетВРазрезеОрганизаций 	= Истина;
			ВидЛС.ОбменДанными.Загрузка 			= Истина;				
			ВидЛС.Записать();
			СтрокаВидЛС.НеВестиУчетВРазрезеОрганизаций = Истина;			
		КонецЕсли;
		СтрокаВидЛС.ПакетУслугСоставУслуг = СтрокаВидЛС.Ссылка.ПакетУслугСоставУслуг.Выгрузить();		
	КонецЕсли;

КонецПроцедуры

// Процедура - Актуализировать таблицу лицевых счетов
//
// Параметры:
//  ТаблицаЛицевыхСчетовВБазе		 - 	 - 
//  ТаблицаВидовЛицевыхСчетовВБазе	 - 	 - 
//
Процедура АктуализироватьТаблицуЛицевыхСчетовНаЭтапеКонтракты(ТаблицаЛицевыхСчетовВБазе, ТаблицаЛицевыхСчетов, ТаблицаВидовЛицевыхСчетовВБазе, ТекстовыйНакопитель)

	СтепеньРодстваПрочее = ПолучитьСтепеньРодстваПрочее();

	Для Каждого СтрокаЛицевойСчет Из ТаблицаЛицевыхСчетов Цикл
		СообщилиПрогресс = Ложь;
		Если ЗначениеЗаполнено(СтрокаЛицевойСчет.Клиент) Тогда 
			Если ЗначениеЗаполнено(СтрокаЛицевойСчет.Членство) ИЛИ (НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.Членство) И ЗначениеЗаполнено(СтрокаЛицевойСчет.НоменклатураЧленства)) Тогда 
				Если ЗначениеЗаполнено(СтрокаЛицевойСчет.ИДОплаты) И СтрокаЛицевойСчет.Аннулирован = Ложь И НЕ СтрокаЛицевойСчет.ВидОперации = 9 Тогда
					Если СтрокаЛицевойСчет.СуммаОплаты > 0 Тогда
						Если НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.ПкоСсылка) И НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.РкоСсылка) Тогда // И НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.Ссылка) Тогда
							СоздатьЛицевойСчет = Истина;
							Если СтрокаЛицевойСчет.ВидОперации = 1 ИЛИ СтрокаЛицевойСчет.ВидОперации = 5 Тогда 
								СтруктураВидаЛицевогоСчета = ПолучитьВидЛицевогоСчета(7, ТаблицаВидовЛицевыхСчетовВБазе);
							ИначеЕсли СтрокаЛицевойСчет.ВидОперации = 7 И (СтрокаЛицевойСчет.ТипОплаты = 7 ИЛИ СтрокаЛицевойСчет.ТипОплаты = 4 ИЛИ СтрокаЛицевойСчет.ТипОплаты = 6) Тогда 
								СтруктураВидаЛицевогоСчета = ПолучитьВидЛицевогоСчета(СтрокаЛицевойСчет.ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе);
							ИначеЕсли СтрокаЛицевойСчет.ВидОперации = 8 И СтрокаЛицевойСчет.ТипОплаты = 7 Тогда 
								СтруктураВидаЛицевогоСчета = ПолучитьВидЛицевогоСчета(СтрокаЛицевойСчет.ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе);
							Иначе    
								СоздатьЛицевойСчет = Ложь;
							КонецЕсли;
							// Ищем ЛС и если необходимо - создаем и добавляем в таблицу
