// Процедура - Задолженность установить снять галочки при изменении
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ЗадолженностьУстановитьСнятьГалочкиПриИзменении(Элемент)
	
	// Установка состояния флажков
	ОплатаСумма = 0;	
	ВыбранХотябыОдин = Ложь;
	
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ТаблицаЗадолженностей Цикл
		
		Если СтрокаТ.ОплатаЗаблокирована = Ложь Тогда
			
			СтрокаТ.ПризнакВыбора = ЭтотОбъект.ЗадолженностьУстановитьСнятьГалочки;
			ВыбранХотябыОдин      = СтрокаТ.ПризнакВыбора;
			
		Иначе
			
			СтрокаТ.ПризнакВыбора = Ложь;
			ПоказатьОповещениеПользователя("Оплата",,СтрокаТ.ОписаниеБлокировки,БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);
			
		КонецЕсли;
		
		КолВыбДок = ПолучитьВыбранныеДокументыЗадолженности().Количество();
		
		Если ЭтотОбъект.ВидНалогаОплачиваемыхДокументов <> СтрокаТ.ВидНалога
			И КолВыбДок > 1 Тогда
			
			ПоказатьОповещениеПользователя(
			"Оплата",,
			"Нельзя оплатить одним чеком два документа с разными видами налогообложения!", 
			БиблиотекаКартинок.Предупреждение32,
			СтатусОповещенияПользователя.Важное);
			
			СтрокаТ.ПризнакВыбора = Ложь;
			Продолжить;
			
		ИначеЕсли КолВыбДок = 1 Тогда
			
			ЭтотОбъект.ВидНалогаОплачиваемыхДокументов = СтрокаТ.ВидНалога;
			
		КонецЕсли;

		
	КонецЦикла;
	
	Если ВыбранХотябыОдин = Ложь Тогда
		ЭтотОбъект.ЗадолженностьУстановитьСнятьГалочки = Ложь;
	КонецЕсли;
	
    ОбновитьФорму(,Истина);
	УстановитьАвтоВводСуммДляАвансов();
	
КонецПроцедуры

// Процедура - Задолженность выбор строка при изменении
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ЗадолженностьВыборСтрока_ПриИзменении(Элемент)
	
	ТекущиеДанные = СтрокаДанныхПоИмениЭлемента(Элемент.Имя, "ТаблицаЗадолженностей"); 
	
	Если ТекущиеДанные.ОплатаЗаблокирована = Истина Тогда
		
		 ТекущиеДанные.ПризнакВыбора = Ложь;
		 ПоказатьОповещениеПользователя("Оплата",,ТекущиеДанные.ОписаниеБлокировки,БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);
		 Возврат;
		 
	КонецЕсли;
	
	КолВыбДок = ПолучитьВыбранныеДокументыЗадолженности().Количество();
	
	Если ЭтотОбъект.ВидНалогаОплачиваемыхДокументов <> ТекущиеДанные.ВидНалога
		И КолВыбДок > 1 Тогда
		
		ПоказатьОповещениеПользователя(
		"Оплата",,
		"Нельзя оплатить одним чеком два документа с разными видами налогообложения!", 
		БиблиотекаКартинок.Предупреждение32,
		СтатусОповещенияПользователя.Важное);
		
		ТекущиеДанные.ПризнакВыбора = Ложь;
		Возврат;
		
	ИначеЕсли КолВыбДок = 1 Тогда
		
		ЭтотОбъект.ВидНалогаОплачиваемыхДокументов = ТекущиеДанные.ВидНалога;
		
	КонецЕсли;

	Идентификатор = Неопределено;	
	ОбновитьФорму(,Истина, Идентификатор);
	УстановитьАвтоВводСуммДляАвансов();

КонецПроцедуры

// Процедура - Таблица задолженностей расшифровка нажатие
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ТаблицаЗадолженностейРасшифровкаНажатие(Элемент)
	
	ТекущиеДанные = СтрокаДанныхПоИмениЭлемента(Элемент.Имя, "ТаблицаЗадолженностей");
	
	Если НЕ ТекущиеДанные = Неопределено 
		И ЗначениеЗаполнено(ТекущиеДанные.ДокументЗадолженности) Тогда
		
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ТекущиеДанные.ДокументЗадолженности));
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

&НаСервере
// Функция - Получить источник данных по продажам для таблицы задолженностей
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьИсточникДанныхПоПродажамДляТаблицыЗадолженностей()
	
	// Получаем таблицу задолженностей	
	ЗапросПоЗадолженности = Новый Запрос;
	Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Организация КАК Организация,
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК ДокументЗадолженности,
	|	ВЫБОР
	|		КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации ССЫЛКА Документ.Прием
	|			ТОГДА ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Прием).СуммаДокумента
	|		ИНАЧЕ ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Реализация).СуммаДокумента
	|	КОНЕЦ КАК СуммаДокумента,
	|	ВЫБОР
	|		КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации ССЫЛКА Документ.Прием
	|			ТОГДА ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Прием).ВидНалога
	|		ИНАЧЕ ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Реализация).ВидНалога
	|	КОНЕЦ КАК ВидНалога,
	|	СУММА(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаКонечныйОстаток) * -1 КАК Задолженность,
	|	СУММА(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаПриход) КАК Оплачено
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.ОстаткиИОбороты(
	|			,
	|			&КонецПериода,
	|			Авто,
	|			,
	|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И (НЕ ДокументРеализации = НЕОПРЕДЕЛЕНО
	|					ИЛИ НЕ ДокументАванса = НЕОПРЕДЕЛЕНО)
	|				И Контрагент = &Контрагент) КАК ВзаиморасчетыСКонтрагентамиОстаткиИОбороты
	|ГДЕ
	|	НЕ ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации.Дата ЕСТЬ NULL
	|	И ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаКонечныйОстаток < 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Организация,
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СтруктурнаяЕдиница,
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации,
	|	ВЫБОР
	|		КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации ССЫЛКА Документ.Прием
	|			ТОГДА ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Прием).СуммаДокумента
	|		ИНАЧЕ ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Реализация).СуммаДокумента
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации ССЫЛКА Документ.Прием
	|			ТОГДА ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Прием).ВидНалога
	|		ИНАЧЕ ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации КАК Документ.Реализация).ВидНалога
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументЗадолженности";	 
	 
	ЗапросПоЗадолженности.УстановитьПараметр("КонецПериода"      , ?(ТекущаяДатаСеанса() > ЭтотОбъект.ДатаПродажи, ТекущаяДатаСеанса(), ЭтотОбъект.ДатаПродажи));
	ЗапросПоЗадолженности.УстановитьПараметр("Контрагент"        , Контрагент);
	ЗапросПоЗадолженности.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	ЗапросПоЗадолженности.Текст = Текст;
	
	Возврат ЗапросПоЗадолженности.Выполнить();
	
КонецФункции

&НаСервере
// Функция - Получить источник данных по взносам аванса для таблицы задолженностей
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьИсточникДанныхВзносАвансаДляТаблицыЗадолженностей()
	
	Запрос = Новый Запрос;
	
	Если ТипЗнч(ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда
				
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПланЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПланЛечения.Ссылка КАК ДокументЗадолженности,
		|	ПланЛечения.СуммаДокумента КАК СуммаДокумента,
		|	ЕСТЬNULL(ПланЛечения.ВидНалога, ЗНАЧЕНИЕ(Перечисление.ВидыНалогов.ПустаяСсылка)) КАК ВидНалога,
		|	ПланЛечения.СуммаОплачено КАК Оплачено,
		|	ПланЛечения.СуммаДокумента - ПланЛечения.СуммаОплачено КАК Задолженность
		|ИЗ
		|	Документ.ПланЛечения КАК ПланЛечения
		|ГДЕ
		|	ПланЛечения.Ссылка = &ДокументАванса";
		
	Иначе
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	НарядЗаказ.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	НарядЗаказ.Ссылка КАК ДокументЗадолженности,
		|	НарядЗаказ.СуммаДокумента КАК СуммаДокумента,
		|	ЕСТЬNULL(НарядЗаказ.ВидНалога, ЗНАЧЕНИЕ(Перечисление.ВидыНалогов.ПустаяСсылка)) КАК ВидНалога,
		|	ВЫБОР
		|		КОГДА &УчитыватьАвансыВРазрезеДокументов = ИСТИНА
		|			ТОГДА НарядЗаказ.СуммаОплаченоПродажи
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Оплачено,
		|	ВЫБОР
		|		КОГДА &УчитыватьАвансыВРазрезеДокументов = ИСТИНА
		|			ТОГДА НарядЗаказ.СуммаПродажи - НарядЗаказ.СуммаОплаченоПродажи
		|		ИНАЧЕ НарядЗаказ.СуммаПродажи
		|	КОНЕЦ КАК Задолженность
		|ИЗ
		|	Документ.НарядЗаказ КАК НарядЗаказ
		|ГДЕ
		|	НарядЗаказ.Ссылка = &ДокументАванса";

	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса; 
	НарядЗаказУвеличиваетЗадолженность = Константы.НарядЗаказУвеличиваетЗадолженность.Получить();
	Запрос.УстановитьПараметр("ДокументАванса"                    , ДокументАванса);	
	// Запрос.УстановитьПараметр("НарядЗаказУвеличиваетЗадолженность", НарядЗаказУвеличиваетЗадолженность);
	Запрос.УстановитьПараметр("УчитыватьАвансыВРазрезеДокументов" , УчитыватьАвансыВРазрезеДокументов);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

&НаСервере
// Процедура подготовки таблицы задолженностей для возвратов
// 
Функция ПолучитьИсточникДанныхПоВозвратамДляТаблицыЗадолженностей()
	
	ДокументВозврата = Неопределено;
	Если ЗначениеЗаполнено(ДокументыЗадолженности) 
		И ТипЗнч(ДокументыЗадолженности[0].Значение) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		
		ДокументВозврата = ДокументыЗадолженности[0].Значение;
	КонецЕсли;
	
	ЗапросПоЗадолженности = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВозвратОтПокупателя.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВозвратОтПокупателя.Ссылка КАК ДокументЗадолженности,
	|	ВозвратОтПокупателя.СуммаДокумента КАК СуммаДокумента,
	|	ВозвратОтПокупателя.СуммаОплачено КАК Оплачено,
	|	ВозвратОтПокупателя.ВидНалога КАК ВидНалога,
	|	ВозвратОтПокупателя.СуммаДокумента - ВозвратОтПокупателя.СуммаОплачено КАК Задолженность
	|ИЗ
	|	Документ.ВозвратОтПокупателя КАК ВозвратОтПокупателя
	|ГДЕ
	|	ВозвратОтПокупателя.Ссылка = &ДокументВозврата");
	  
    ЗапросПоЗадолженности.УстановитьПараметр("ДокументВозврата"  , ДокументВозврата);

	Возврат ЗапросПоЗадолженности.Выполнить();
	
КонецФункции

&НаСервере
// Процедура подготовки таблицы задолженностей
Процедура ПодготовкаТаблицыЗадолженностей()
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
		
		ОплатаСумма           = 0;
		ВыборкаЗадолженностей = Неопределено;
		
		// В зависимости от типа операции получаем исходные данные
		Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа Тогда
			
			Если ЭтоВзносАванса = Истина Тогда
				ЗапросПоЗадолженности = ПолучитьИсточникДанныхВзносАвансаДляТаблицыЗадолженностей();
			Иначе
			    ЗапросПоЗадолженности = ПолучитьИсточникДанныхПоПродажамДляТаблицыЗадолженностей();
			КонецЕсли;

		ИначеЕсли ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Возврат Тогда
			ЗапросПоЗадолженности = ПолучитьИсточникДанныхПоВозвратамДляТаблицыЗадолженностей();
		КонецЕсли;
		
		// добавить данные по планам лечения и по наряд-заказам 
		Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа Тогда
			МассивДокументовЗадолженности = ЗапросПоЗадолженности.Выгрузить().ВыгрузитьКолонку("ДокументЗадолженности");
			МассивДокументовЗадолженностиПриемы = Новый Массив;
			Если МассивДокументовЗадолженности.Количество() <> 0 Тогда 
				
				Для Каждого ДокументЗадолженности Из МассивДокументовЗадолженности Цикл 
					Если ТипЗнч(ДокументЗадолженности) = Тип("ДокументСсылка.Прием") Тогда
						МассивДокументовЗадолженностиПриемы.Добавить(ДокументЗадолженности);
					КонецЕсли;
				КонецЦикла;
				Если МассивДокументовЗадолженностиПриемы.Количество() > 0 Тогда
			    	ДобавитьДанныеПоПланамЛечения(МассивДокументовЗадолженностиПриемы);
			   		ДобавитьДанныеПоНарядЗаказам(МассивДокументовЗадолженностиПриемы);
				КонецЕсли; 
			КонецЕсли;   
		 КонецЕсли;
		 
		// Подготовка касс оплаты.	
		МассивДоступныхКасс	= Справочники.Кассы.ПолучитьКассыДляОплаты(СтруктурнаяЕдиница, Организация);
		//МассивДоступныхКасс = Кассы.ВыгрузитьКолонку("Касса");  
		//Если НЕ МассивДокументовЗадолженностиПриемы = Неопределено Тогда
		//	ДокументыЗадолженности.ЗагрузитьЗначения(МассивДокументовЗадолженностиПриемы);
		//КонецЕсли;
		ОбновитьВыборДоступныхКасс(?(ДокументыЗадолженности.Количество() > 0, ДокументыЗадолженности[0].Значение, Неопределено), МассивДоступныхКасс);
		
		ВыборкаЗадолженностей = ЗапросПоЗадолженности.Выбрать();
		ЭтотОбъект.ТаблицаЗадолженностей.Очистить();
		ВидНалогообложенияУстановлен = Ложь;
		ВыборкаЗадолженностей = ЗапросПоЗадолженности.Выбрать();

		Пока ВыборкаЗадолженностей.Следующий() Цикл 
			
			// Подготовка суммы задолженности
			ДокументСумма               = 0;
			ЗадолженностьСумма          = 0;
			ОплаченоСумма               = 0;
			
			ДокументСумма      = ВыборкаЗадолженностей.СуммаДокумента;
			ЗадолженностьСумма = ВыборкаЗадолженностей.Задолженность;
			ОплаченоСумма      = ВыборкаЗадолженностей.Оплачено;
			
			Если ЗадолженностьСумма > 0 Тогда
				
				// Получаем доступные кассы для это СЕ
				ОплатаЗаблокирована = (ЭтотОбъект.ТекущаяКасса.СтруктурнаяЕдиница <> ВыборкаЗадолженностей.СтруктурнаяЕдиница);
				
				НайденныеСтрокиПоПланамЛечения = ТаблицаАвансыПоПланамЛечения.НайтиСтроки(Новый Структура("Прием", ВыборкаЗадолженностей.ДокументЗадолженности));
				СписокПлановЛечения = Новый СписокЗначений;
				Для Каждого СтрокаТЧ Из НайденныеСтрокиПоПланамЛечения Цикл
					 СписокПлановЛечения.Добавить(СтрокаТЧ.ПланЛечения);
				КонецЦикла;
				
				НайденныеСтрокиПоНарядЗаказам = ТаблицаАвансыПоНарядЗаказам.НайтиСтроки(Новый Структура("Прием", ВыборкаЗадолженностей.ДокументЗадолженности));
				СписокНарядЗаказов = Новый СписокЗначений;
				Для Каждого СтрокаТЧ Из НайденныеСтрокиПоНарядЗаказам Цикл
					 СписокНарядЗаказов.Добавить(СтрокаТЧ.НарядЗаказ);
				КонецЦикла;
		
				НоваяСтрокаВрУровня = ЭтотОбъект.ТаблицаЗадолженностей.Добавить();
				
				ЗаполнитьЗначенияСвойств(НоваяСтрокаВрУровня, ВыборкаЗадолженностей);
				НоваяСтрокаВрУровня.Группировка    = ФормированиеПечатныхФорм.СформироватьПредставлениеДокумента(ВыборкаЗадолженностей.ДокументЗадолженности,, Истина);
				НоваяСтрокаВрУровня.СуммаДокумента = ДокументСумма;
				НоваяСтрокаВрУровня.Задолженность  = ЗадолженностьСумма;
				НоваяСтрокаВрУровня.Оплачено       = ОплаченоСумма;
				НоваяСтрокаВрУровня.ВидНалога      = ВыборкаЗадолженностей.ВидНалога;
				
				НоваяСтрокаВрУровня.ПланыЛечения = СписокПлановЛечения; 
				НоваяСтрокаВрУровня.НарядЗаказы  = СписокНарядЗаказов;
				
				// Подготовка представления
				Представление = "";
				
				// для наряд заказа это тч запасы и услуги
				Если ЗначениеЗаполнено(ДокументАванса) Тогда
					ТабличнаяЧастьДокумента = ?(ТипЗнч(ДокументАванса) = Тип("ДокументСсылка.ПланЛечения"), 
						ВыборкаЗадолженностей.ДокументЗадолженности.Лечение, ВыборкаЗадолженностей.ДокументЗадолженности.Запасы);
					Для Каждого СтрокаТ Из ТабличнаяЧастьДокумента Цикл
						Представление = Представление + Строка(СтрокаТ.Номенклатура) + ", ";
					КонецЦикла;
					
				ИначеЕсли (ТипЗнч(ВыборкаЗадолженностей.ДокументЗадолженности) = Тип("ДокументСсылка.Прием") 
					Или ТипЗнч(ВыборкаЗадолженностей.ДокументЗадолженности) = Тип("ДокументСсылка.ВозвратОтПокупателя")) Тогда 
					Для Каждого СтрокаТ Из ВыборкаЗадолженностей.ДокументЗадолженности.Лечение Цикл
						Представление = Представление + Строка(СтрокаТ.Номенклатура) + ", ";
					КонецЦикла;
					Для Каждого СтрокаТ Из ВыборкаЗадолженностей.ДокументЗадолженности.Запасы Цикл
						Представление = Представление + Строка(СтрокаТ.Номенклатура) + ", ";
					КонецЦикла;
				Иначе
					Для Каждого СтрокаТ Из ВыборкаЗадолженностей.ДокументЗадолженности.Запасы Цикл
						Представление = Представление + Строка(СтрокаТ.Номенклатура) + ", ";
					КонецЦикла;
				КонецЕсли;
	
				Если СтрДлина(Представление) > 2 Тогда 
					Представление = Лев(Представление, СтрДлина(Представление) - 2); 
				КонецЕсли;
				
				РазрешитьВыборПоУмолчанию = НЕ ОплатаЗаблокирована И (ДокументыЗадолженности.Количество() = 0 
					Или ДокументыЗадолженности.НайтиПоЗначению(ВыборкаЗадолженностей.ДокументЗадолженности) <> Неопределено); 
				
				Если РазрешитьВыборПоУмолчанию = Истина 
					И ВидНалогообложенияУстановлен = Ложь Тогда
					
					ЭтотОбъект.ВидНалогаОплачиваемыхДокументов = ВыборкаЗадолженностей.ВидНалога;
					ВидНалогообложенияУстановлен = Истина;
					
				КонецЕсли;
				
				Если РазрешитьВыборПоУмолчанию = Истина 
					И ЭтотОбъект.ВидНалогаОплачиваемыхДокументов <> ВыборкаЗадолженностей.ВидНалога Тогда
					
					РазрешитьВыборПоУмолчанию = Ложь;
				КонецЕсли;      
				
				НоваяСтрокаВрУровня.Представление        = Представление;
				НоваяСтрокаВрУровня.ПризнакВыбора        = РазрешитьВыборПоУмолчанию;
				НоваяСтрокаВрУровня.ОплатаЗаблокирована  = ОплатаЗаблокирована; 
				
				Если ОплатаЗаблокирована = Истина Тогда
					НоваяСтрокаВрУровня.ОписаниеБлокировки = "Не выбрана касса для оплаты!";
				Иначе
					НоваяСтрокаВрУровня.ОписаниеБлокировки = Неопределено;
				КонецЕсли;
				
				// Если это оплата долга				
				Если РазрешитьВыборПоУмолчанию Тогда
					ЭтотОбъект.ОплатаСумма  = ЭтотОбъект.ОплатаСумма + НоваяСтрокаВрУровня.Задолженность;
				КонецЕсли;	
				
			КонецЕсли;
		КонецЦикла;		
		
		ПостроитьДинамическуюТаблицуЗадолженностей();
		
	КонецЕсли;
	
	Элементы.ДекорацияЗаголовокНетЗадолженности.Видимость = НЕ ЭтотОбъект.ТаблицаЗадолженностей.Количество() > 0;
	Элементы.ГруппаТаблицаЗадолженностей.Видимость        = ЭтотОбъект.ТаблицаЗадолженностей.Количество() > 0;
	Элементы.ГруппаОплата.Видимость                       = ЭтотОбъект.ТаблицаЗадолженностей.Количество() > 0;
	
КонецПроцедуры

//YS ДобавитьДанныеПоПланамЛечения и ДобавитьДанныеПоНарядЗаказам переписать в один запрос

// Процедура - Добавить данные по планам лечения
// 
&НаСервере
Процедура ДобавитьДанныеПоПланамЛечения(МассивДокументовЗадолженности)
			
	Для Каждого ДокументЗадолженности Из МассивДокументовЗадолженности Цикл
			
		МассивПлановЛечения = Новый Массив;
		Для Каждого СтрокаПриема Из ДокументЗадолженности.Лечение Цикл
			
			Если ЗначениеЗаполнено(СтрокаПриема.ДокументАванса)
				И МассивПлановЛечения.Найти(СтрокаПриема.ДокументАванса) = Неопределено 
				И ТипЗнч(СтрокаПриема.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда
				МассивПлановЛечения.Добавить(СтрокаПриема.ДокументАванса);				 
			КонецЕсли;
			
		КонецЦикла;
		
		Если МассивПлановЛечения.Количество() <> 0 Тогда
					
			Результат = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОстаткаАвансаПоДокументу(
				ДокументЗадолженности, МассивПлановЛечения);
			
			Для Каждого СтрокаТЧ Из Результат Цикл
				
				НоваяСтрока = ТаблицаАвансыПоПланамЛечения.Добавить();
				
				НоваяСтрока.Прием                          = ДокументЗадолженности;
				НоваяСтрока.ПланЛечения                    = СтрокаТЧ.ДокументАванса;
	            НоваяСтрока.СуммаАванса                    = СтрокаТЧ.СуммаОстатокАванса;
				НоваяСтрока.СуммаДоступнаяДляОплатыАвансом = СтрокаТЧ.СуммаДоступнаяДляОплатыАвансом;
				
			КонецЦикла;
	
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

// Процедура - Добавить данные по наряд-заказам
// 
&НаСервере
Процедура ДобавитьДанныеПоНарядЗаказам(МассивДокументовЗадолженности)
			
	Для Каждого ДокументЗадолженности Из МассивДокументовЗадолженности Цикл
			
		МассивНарядЗаказов  = Новый Массив;

		Для Каждого СтрокаПриема Из ДокументЗадолженности.Лечение Цикл
			
			Если ЗначениеЗаполнено(СтрокаПриема.ДокументАванса)
				И МассивНарядЗаказов.Найти(СтрокаПриема.ДокументАванса) = Неопределено 
				И ТипЗнч(СтрокаПриема.ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда
				МассивНарядЗаказов.Добавить(СтрокаПриема.ДокументАванса);				 
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаПриема Из ДокументЗадолженности.Запасы Цикл
			
			Если ЗначениеЗаполнено(СтрокаПриема.ДокументАванса)
				И МассивНарядЗаказов.Найти(СтрокаПриема.ДокументАванса) = Неопределено 
				И ТипЗнч(СтрокаПриема.ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда
				МассивНарядЗаказов.Добавить(СтрокаПриема.ДокументАванса);				 
			КонецЕсли;
			
		КонецЦикла;
		
		Если МассивНарядЗаказов.Количество() <> 0 Тогда
					
			Результат = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОстаткаАвансаПоДокументу(
				ДокументЗадолженности, МассивНарядЗаказов);
			
			Для Каждого СтрокаТЧ Из Результат Цикл
				
				НоваяСтрока = ТаблицаАвансыПоНарядЗаказам.Добавить();
				
				НоваяСтрока.Прием                          = ДокументЗадолженности;
				НоваяСтрока.НарядЗаказ                     = СтрокаТЧ.ДокументАванса;
	            НоваяСтрока.СуммаАванса                    = СтрокаТЧ.СуммаОстатокАванса;
				НоваяСтрока.СуммаДоступнаяДляОплатыАвансом = СтрокаТЧ.СуммаДоступнаяДляОплатыАвансом;
				
			КонецЦикла;
	
		КонецЕсли; 
		
		
		МассивПлановЛечения = Новый Массив;    //для схемы План лечения - Аванс, План лечения -Наряд заказ, Наряд заказ - Прием
		
		Для Каждого НарядЗаказСсылка Из МассивНарядЗаказов Цикл
			Для Каждого СтрокаНарядЗаказ Из НарядЗаказСсылка.Запасы Цикл
				Если ЗначениеЗаполнено(СтрокаНарядЗаказ.ПланЛечения)
					И ТипЗнч(СтрокаНарядЗаказ.ПланЛечения) = Тип("ДокументСсылка.ПланЛечения") 
					И МассивПлановЛечения.Найти(СтрокаНарядЗаказ.ПланЛечения) = Неопределено 
					И ТаблицаАвансыПоПланамЛечения.НайтиСтроки(Новый Структура("ПланЛечения", СтрокаНарядЗаказ.ПланЛечения)).Количество() = 0 
					Тогда
					МассивПлановЛечения.Добавить(СтрокаНарядЗаказ.ПланЛечения);				 
				КонецЕсли;
				
			КонецЦикла;
		КонецЦикла; 
		

		
		Если МассивПлановЛечения.Количество() <> 0 Тогда
					
			Результат = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОстаткаАвансаПоДокументу(
				ДокументЗадолженности, МассивПлановЛечения);
			
			Для Каждого СтрокаТЧ Из Результат Цикл
				
				НоваяСтрока = ТаблицаАвансыПоПланамЛечения.Добавить();
				
				НоваяСтрока.Прием                          = ДокументЗадолженности;
				НоваяСтрока.ПланЛечения                    = СтрокаТЧ.ДокументАванса;
	            НоваяСтрока.СуммаАванса                    = СтрокаТЧ.СуммаОстатокАванса;
				НоваяСтрока.СуммаДоступнаяДляОплатыАвансом = СтрокаТЧ.СуммаДоступнаяДляОплатыАвансом;
				
			КонецЦикла;
	
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Получить оплачиваемые документы
Функция ПолучитьВыбранныеДокументыЗадолженности()
	
	МассивДокументов = Новый Массив;	
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ТаблицаЗадолженностей Цикл
		Если СтрокаТ.ПризнакВыбора Тогда
			МассивДокументов.Добавить(СтрокаТ.ДокументЗадолженности);
		КонецЕсли;
	КонецЦикла;
		
    Возврат МассивДокументов;	
	
КонецФункции

&НаСервере
// Получить оплачиваемые документы
Функция ПолучитьДокументыЗадолженностиСервер(ТолькоВыбранные, ТипДокумента = Неопределено)
	
	МассивДокументов = Новый Массив;
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ТаблицаЗадолженностей Цикл
		
		Если ТипДокумента <> Неопределено 
			И ТипДокумента <> ТипЗнч(СтрокаТ.ДокументЗадолженности) Тогда
			Продолжить;
		КонецЕсли;	
		
		Если НЕ ТолькоВыбранные ИЛИ СтрокаТ.ПризнакВыбора Тогда
			МассивДокументов.Добавить(СтрокаТ.ДокументЗадолженности);
		КонецЕсли;
		
	КонецЦикла;	
		
    Возврат МассивДокументов;	
	
КонецФункции

&НаСервере
// Получить выбранные строки дерева задолженности
Функция ПолучитьВыбранныеСтрокиДереваЗадолженностиСервер()
	
	МассивСтрок = Новый Массив;	
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ТаблицаЗадолженностей Цикл
		Если СтрокаТ.ПризнакВыбора Тогда
			МассивСтрок.Добавить(СтрокаТ);
		КонецЕсли;
	КонецЦикла;	
		
	Возврат МассивСтрок;	
КонецФункции

#Конецобласти

#Область ТаблицаВыбораОплаты

#Область УстановкаВидовОплат

&НаСервере
// Процедура - устанавливает виды оплат на странице "Оплата"
// 
Процедура УстановитьВидыОплатСервер(ОчищатьДеревоОплат = Ложь)
		
	ФРИспользуется				 = РозничныеПродажи.ПроверитьИспользованиеФРвКассе(ТекущаяКасса);
	ЭквайринговыйТерминал        = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыйТерминалПоУмолчанию(ТекущаяКасса);
	
	МассивНайденныхСтрок		 = ЭтотОбъект.ДоступныеКассы.НайтиСтроки(Новый Структура("Касса", ЭтотОбъект.ТекущаяКасса));
    ТекСтрокаКассы				 = ?(МассивНайденныхСтрок.Количество() > 0, МассивНайденныхСтрок[0], Неопределено); 
	ОплатаТолькоПоСсылкам		 = ТекСтрокаКассы <> Неопределено И ТекСтрокаКассы.ИспользуетсяОнлайн = Истина И ТекСтрокаКассы.КассаДоступна = Ложь;	
	
	ПересчитатьСуммуКоплате();
		
	МассивСертификатов = НайтиВсеСтрокиСертифкатовВДеревеДоступныхВидовОплатСервер();
	
	Если ОчищатьДеревоОплат = Истина Тогда
		
		ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Очистить();
		ЭтотОбъект.ОплатаВнесено = 0;
		ЭтотОбъект.ОплатаСдача   = 0;

	КонецЕсли;

	Если ЭтотОбъект.ОплатаСумма = 0 Тогда
		
		ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Очистить();
		Элементы.ГруппаОплата.Видимость = Ложь;
		Возврат;
		
	Иначе	
		
		Элементы.ГруппаОплата.Видимость = Истина;
		
	КонецЕсли;

	Если Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(ТекущаяКасса, Перечисления.ТипыДенежныхСредств.Наличные) 
		И Не ОплатаТолькоПоСсылкам Тогда
			
		УстановитьВидОплатыНаличными();
		
	КонецЕсли;		
	
	Если НЕ ЭквайринговыйТерминал.Пустая()
		И Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(ТекущаяКасса, Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта) 
		И Не ОплатаТолькоПоСсылкам Тогда 
		
		УстановитьВидОплатыПлатежнойКартой();
		
	КонецЕсли;
	
	Если ТекСтрокаКассы <> Неопределено И ТекСтрокаКассы.ИспользуетсяОнлайн = Истина Тогда 			
		УстановитьВидОплатыСБП_И_СсылокНаОплату();		
	КонецЕсли;
	
	Если Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(ТекущаяКасса, Перечисления.ТипыДенежныхСредств.ЛицевойСчет) 
		И Не ОплатаТолькоПоСсылкам Тогда 		
		
		Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа Тогда
			
			УстановитьВидОплатыЛицевымСчетомДляОплаты();
			
		Иначе
			
			УстановитьВидОплатыЛицевымСчетомДляВозврата();
			
		КонецЕсли;
		
	КонецЕсли;	
		
	Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа
		И Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(ТекущаяКасса, Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат) 
		И Не ОплатаТолькоПоСсылкам Тогда
				
		Для Каждого СтрокаВидаОплаты ИЗ МассивСертификатов Цикл
			
			УстановитьВидОплатыПодарочнымСертификатом(
			     ПолучитьДанныеСертификата(
				   СтрокаВидаОплаты.Сертификат, 
				   СтрокаВидаОплаты.СертификатПартия,
				   СтрокаВидаОплаты.СертификатПодтвержден,
				   СтруктурнаяЕдиница,
				   Контрагент));
				   
		КонецЦикла;
		
		УстановитьКнопкуДобавленияНовогоСертификата();

	КонецЕсли;
	
	// установить вид оплаты авансом
	Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа
		И Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(ТекущаяКасса, Перечисления.ТипыДенежныхСредств.Аванс)
		И УчитыватьАвансыВРазрезеДокументов = Ложь 
		И Не ОплатаТолькоПоСсылкам Тогда
			
		УстановитьВидОплатыАвансом();
		
	КонецЕсли;

	СписокИндексовСтрок.Очистить();
	Для Каждого СтрокаТЧ Из ТаблицаЗадолженностей Цикл
		Если СтрокаТЧ.ПризнакВыбора = Истина И СтрокаТЧ.ПланыЛечения.Количество() <> 0 Тогда
			
			Для Каждого ЭлементСписка Из СтрокаТЧ.ПланыЛечения Цикл
				НайденныеСтроки = ТаблицаАвансыПоПланамЛечения.НайтиСтроки(Новый Структура("Прием, ПланЛечения", СтрокаТЧ.ДокументЗадолженности, ЭлементСписка.Значение));
				Если НайденныеСтроки.Количество() <> 0 Тогда
					УстановитьВидОплатыАвансомПоДокументу(НайденныеСтроки, 1);
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
		Если СтрокаТЧ.ПризнакВыбора = Истина И СтрокаТЧ.НарядЗаказы.Количество() <> 0 Тогда
			
			Для Каждого ЭлементСписка Из СтрокаТЧ.НарядЗаказы Цикл
				НайденныеСтроки = ТаблицаАвансыПоНарядЗаказам.НайтиСтроки(Новый Структура("Прием, НарядЗаказ", СтрокаТЧ.ДокументЗадолженности, ЭлементСписка.Значение));
				Если НайденныеСтроки.Количество() <> 0 Тогда
					УстановитьВидОплатыАвансомПоДокументу(НайденныеСтроки, 2);
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
				
	КонецЦикла;
	
	Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа
 		И Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(ТекущаяКасса, Перечисления.ТипыДенежныхСредств.БонусныйСчет)
		И ЭтоВзносАванса = Ложь 
		И Не ОплатаТолькоПоСсылкам Тогда 		
		
		УстановитьВидОплатыБонуснымСчетом();		
	КонецЕсли;

	СтрокаДерева = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы();
	Если СтрокаДерева.Количество() = 0 
		ИЛИ (СтрокаДерева.Количество() > 0 И СтрокаДерева[0].ПолучитьЭлементы().Количество() > 0) Тогда
		СтрокаДерева.Вставить(0).Представление = "Заглушка";
	КонецЕсли;
	
	// Если ЭтотОбъект.ВидыОплат.ПолучитьЭлементы()[0].ПолучитьЭлементы().Количество() > 0 Тогда
	//	ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Вставить(0).Представление = "Заглушка";
	// КонецЕсли;
		
	СоздатьДинамическуюТаблицуДоступныхВидовОплат();
	
КонецПроцедуры

