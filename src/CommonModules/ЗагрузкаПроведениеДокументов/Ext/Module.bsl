	//	Возврат Неопределено;
	// Иначе
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания"	, Истина);				
	// КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийСотрудник);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ИнтерпретироватьСообщениеКлиентаВФоне",
	ПараметрыПроцедуры,
	НСтр("ru='Интерпретация сообщения пользователя...';en='Interpreting user message...'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Интерпретировать сообщение клиента в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ИнтерпретироватьСообщениеКлиентаВФоне(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ТаблицаВариантовОтветов = ПараметрыЗадания.ПараметрыЭтапаСценария.ТаблицаВариантовРазвитияСценария.Скопировать(Новый Структура("ИдентификаторЭтапа", ПараметрыЗадания.ПараметрыЭтапаСценария.ИдентификаторЭтапа));
	Если НЕ ЗначениеЗаполнено(ТаблицаВариантовОтветов) Тогда 
		Возврат;
	КонецЕсли;
	
	ПараметрыВарианта = Неопределено;
	ПараметрыСобщения = Неопределено;
	Если ПараметрыЗадания.ПараметрыЭтапаСценария.ФормироватьСтэкВариантовВыбораМетодом Тогда
		СтруктураВариантаОтвета = РегистрыСведений.КэшВариантовОтветов.ПолучитьЗначениеВариантаОтвета(ПараметрыЗадания.ДанныеСообщения.ИдДиалога, ?(ПараметрыЗадания.callback_query_data = Неопределено, ПараметрыЗадания.ДанныеСообщения.ТекстСообщения, ПараметрыЗадания.callback_query_data));
		Если СтруктураВариантаОтвета = Неопределено Тогда
			РегистрыСведений.ЖурналСообщений.АктуализироватьОжиданиеСообшения(ПараметрыЗадания.ДанныеСообщения.Период
																				, ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																				, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																				, ПараметрыЗадания.ДанныеСообщения.ИдСообщения
																				, Истина);
			
			ПараметрыЗадания.Вставить("ДополнительноеСообщение", НСтр("ru='Выбранный Вами вариант не понятен! Выберите один из предоставленных выше вариантов, указав его номер.';en='The option you have chosen is not clear! Choose one of the options above by entering its number.'"));
			Справочники.СценарииЧатБотов.ОтправитьДополнительноеСообщениеПоСценарию(ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																					, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																					, ПараметрыЗадания.ДополнительноеСообщение
																					, ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																					, ПараметрыЗадания.ДанныеСообщения.ИдКанала
																					, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота);
			Возврат;
		КонецЕсли;
		Если СтруктураВариантаОтвета.ЗначениеОтвета = Справочники.ВариантыОтветов.ВозвратНаПредыдущийЭтап Тогда
			ПараметрыВарианта = Новый Структура();
			ПараметрыВарианта.Вставить("СледующийЭтап", СтруктураВариантаОтвета.ИдентификаторЭтапаВозврата);
			СтрокаСвойствЭтапа = ПараметрыЗадания.ПараметрыЭтапаСценария.ТаблицаСвойствВсехЭтаповСценария.Найти(СтруктураВариантаОтвета.ИдентификаторЭтапаВозврата, "ИдентификаторЭтапа");
			Если НЕ СтрокаСвойствЭтапа = Неопределено Тогда
				СтруктураДанных = Неопределено;				
				Если СтрокаСвойствЭтапа.МетодФормированияСтэкаВариантовВыбора = Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПолучениеДоступныхДатДляЗаписиНаПрием ИЛИ СтрокаСвойствЭтапа.МетодФормированияСтэкаВариантовВыбора = Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПолучениеДоступныхДатДляПереносаЗаписиНаПрием Тогда 
					ДатаПриема = Дата(1,1,1);					
					ВариантСтандартногоПериодаСсылка = Неопределено;					
					ДанныеСценария = РегистрыСведений.ДанныеДиалоговЧатБотов.ПолучитьТаблицуДанныхДиалогаБота(ПараметрыЗадания.ДанныеДиалога.ИдДиалога, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота);
					Если ТипЗнч(ДанныеСценария) = Тип("ТаблицаЗначений") Тогда 
						Если ЗначениеЗаполнено(ДанныеСценария) Тогда 
							ДанныеСценария 						= ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ДанныеСценария[0]);
							ДатаПриема 							= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеСценария, "ДатаПриема", Дата(1,1,1));							
							ВариантСтандартногоПериодаСсылка 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеСценария, "ВариантСтандартногоПериодаСсылка", Неопределено);							
						КонецЕсли;
					КонецЕсли;
					СтруктураДанных = Новый Структура;
					Если ЗначениеЗаполнено(ВариантСтандартногоПериодаСсылка) Тогда
						КлючДанных = "ВариантСтандартногоПериодаСсылка";
						СтруктураДанных.Вставить(КлючДанных, РегистрыСведений.ДанныеДиалоговЧатБотов.ПолучитьПустоеЗначениеПоКлючуДанных(КлючДанных));
					КонецЕсли;	
					Если ЗначениеЗаполнено(ДатаПриема) Тогда 
						КлючДанных = "ДатаПриема";
						СтруктураДанных.Вставить(КлючДанных, РегистрыСведений.ДанныеДиалоговЧатБотов.ПолучитьПустоеЗначениеПоКлючуДанных(КлючДанных));						
					КонецЕсли;
					// Очистим данные текущего этапа
					РегистрыСведений.ДанныеДиалоговЧатБотов.ОчиститьДанныеТекущегоЭтапа(ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																						, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота
																						, КлючДанных
																						, СтруктураДанных);	
																						
					Если ЗначениеЗаполнено(ВариантСтандартногоПериодаСсылка) И НЕ ЗначениеЗаполнено(ДатаПриема) Тогда
						// Получаем дополнительные параметры
						ПараметрыСобщения = Справочники.СценарииЧатБотов.ИнициализироватьПараметрыСообщения(ПараметрыЗадания);
						Если ПараметрыСобщения.ЭтоКнопкиТелеграм Тогда
							// Формируем параметры выполнения для следующего/предыдущего этапа
							ПараметрыВыполнения = ИнициализироватьПараметрыВыполнения(ПараметрыЗадания, ПараметрыВарианта);
							ПараметрыВыполнения.Вставить("ПараметрыЭтапаСценария"		, ПараметрыЗадания.ПараметрыЭтапаСценария);
							ПараметрыВыполнения.Вставить("ОписаниеЭтапа"				, ?(ЗначениеЗаполнено(СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.ЗаголовокЭтапа)), СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.ЗаголовокЭтапа), СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБота)));
							ПараметрыВыполнения.Вставить("ИдентификаторТекущегоЭтапа"	, ПараметрыЗадания.ПараметрыЭтапаСценария.ИдентификаторЭтапа);
							// Кэшируем конкретные даты и формируем новый стек кнопок
							СформироватьИОтправитьНовыйСтекВариантовВыбораПериода(ПараметрыВыполнения, ПараметрыСобщения, ПараметрыЗадания);
							Возврат;
						КонецЕсли;	
					КонецЕсли;	
				Иначе 	
					// Определим ключ выбранного клиентом значения
					КлючДанных = Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПолучитьКлючЗначенияВариантаВыбора(СтрокаСвойствЭтапа.МетодФормированияСтэкаВариантовВыбора);
					// Очистим данные текущего этапа
					РегистрыСведений.ДанныеДиалоговЧатБотов.ОчиститьДанныеТекущегоЭтапа(ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																						, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота
																						, КлючДанных
																						, СтруктураДанных);
				КонецЕсли;
			КонецЕсли;	
		Иначе 	
			// Определим ключ выбранного клиентом значения
			КлючДанных = Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПолучитьКлючЗначенияВариантаВыбора(ПараметрыЗадания.ПараметрыЭтапаСценария.МетодФормированияСтэкаВариантовВыбора, СтруктураВариантаОтвета.ЗначениеОтвета);

			// Запишем выбранное значение в регистр данных диалога
			СтруктураДанных = Новый Структура;
			СтруктураДанных.Вставить(КлючДанных						, СтруктураВариантаОтвета.ЗначениеОтвета);
			РегистрыСведений.ДанныеДиалоговЧатБотов.ЗаписатьДанныеДиалоговЧатБота(ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																				, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота
																				, 
																				, СтруктураДанных
																				, 
																				, Истина
																				, Истина); 
																			
			СтрокаВариант = ТаблицаВариантовОтветов[0];
		КонецЕсли;
	Иначе
		ЗначениеВариантаОтвета 	= Неопределено;
		СтруктураВариантаОтвета = Неопределено;
		// Получаем дополнительные параметры
		ПараметрыСобщения = Справочники.СценарииЧатБотов.ИнициализироватьПараметрыСообщения(ПараметрыЗадания);
		
		Если ПараметрыЗадания.ПараметрыЭтапаСценария.ПредоставлятьВыборВариантовКнопками Тогда 
			// Ищем по регистру
			СтруктураВариантаОтвета = РегистрыСведений.КэшВариантовОтветов.ПолучитьЗначениеВариантаОтвета(ПараметрыЗадания.ДанныеСообщения.ИдДиалога, ?(ПараметрыЗадания.callback_query_data = Неопределено, ПараметрыЗадания.ДанныеСообщения.ТекстСообщения, ПараметрыЗадания.callback_query_data));
		КонецЕсли;	
		
		Если НЕ ЗначениеЗаполнено(СтруктураВариантаОтвета) Тогда 
			МассивДопустимыхВариантов = ТаблицаВариантовОтветов.ВыгрузитьКолонку("ВариантОтвета");
			// Пробуем определить что хочет клиент
			ЗначениеВариантаОтвета = Справочники.ВариантыОтветов.ОпределитьПредопределенныйВариантОтвета(?(ПараметрыЗадания.callback_query_data = Неопределено, ПараметрыЗадания.ДанныеСообщения.ТекстСообщения, ПараметрыЗадания.callback_query_data), МассивДопустимыхВариантов);
			Если НЕ ЗначениеЗаполнено(ЗначениеВариантаОтвета) ИЛИ МассивДопустимыхВариантов.Найти(ЗначениеВариантаОтвета) = Неопределено Тогда
				Если РегистрыСведений.Диалоги.ДиалогНеобходимоПеревестиНаОператора(ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																				, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																				, ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																				, ?(ПараметрыЗадания.callback_query_data = Неопределено, ПараметрыЗадания.ДанныеСообщения.ТекстСообщения, ПараметрыЗадания.callback_query_data)
																				, НСтр("ru='Пока не могу Вас понять! Попробуйте ответить однозначно.';en='Until I can understand you! Try to answer clearly.'")) Тогда 
																				
					// Сообщаем пациенту о переводе его на оператора																				
					ПараметрыЗадания.Вставить("ДополнительноеСообщение", НСтр("ru='Перевожу Вас на оператора';en='I''m transferring you to the operator'"));																				
					Справочники.СценарииЧатБотов.ОтправитьДополнительноеСообщениеПоСценарию(ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																					, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																					, ПараметрыЗадания.ДополнительноеСообщение
																					, ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																					, ПараметрыЗадания.ДанныеСообщения.ИдКанала
																					, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота);
																					
					// Формируем параметры
					ПараметрыВыполнения = ИнициализироватьПараметрыВыполнения(ПараметрыЗадания, ПараметрыВарианта);
					ПараметрыВыполнения.Вставить("ПараметрыЭтапаСценария"		, ПараметрыЗадания.ПараметрыЭтапаСценария);
					ПараметрыВыполнения.Вставить("ОписаниеЭтапа"				, ?(ЗначениеЗаполнено(СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.ЗаголовокЭтапа)), СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.ЗаголовокЭтапа), СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБота)));
					ПараметрыВыполнения.Вставить("ИдентификаторТекущегоЭтапа"	, ПараметрыЗадания.ПараметрыЭтапаСценария.ИдентификаторЭтапа);
					ДанныеСценария = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения, "ДанныеСценария", Неопределено);
					Если НЕ ЗначениеЗаполнено(ДанныеСценария) Тогда 
						ПараметрыВыполнения.Вставить("ДанныеСценария", РегистрыСведений.ДанныеДиалоговЧатБотов.ПолучитьТаблицуДанныхДиалогаБота(ПараметрыЗадания.ДанныеДиалога.ИдДиалога, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота));
					КонецЕсли;
					ПараметрыВыполнения.ВыполненоУспешно 	= Ложь;
					ПараметрыВыполнения.ОписаниеОшибки 		= "Не удалось интерпретировать сообщение. Перевод диалога на оператора.";
					
					// Закрываем диалог, фиксируем причину.
					Если ЗначениеЗаполнено(ПараметрыВыполнения.ДиалогID) Тогда  
						Справочники.СценарииЧатБотов.ЗафиксироватьКоллизиюДиалога(ПараметрыВыполнения);
					КонецЕсли;
					
					// Открываем новый диалог с оператором
					ПараметрыВыполнения.ПараметрыЭтапаСценария.Вставить("СтартовоеСообщениеНовогоДиалога", "Перевод диалога...");					
					Перечисления.МетодыСценариев.СоздатьНовыйДиалогСКлиентом(ПараметрыВыполнения);
					Возврат;
				КонецЕсли;
				
				Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСобщения, "ЭтоКнопкиТелеграм", Ложь) 
					И ПараметрыЗадания.ПараметрыЭтапаСценария.ПредоставлятьВыборВариантовКнопками Тогда 
					РегистрыСведений.ЖурналСообщений.АктуализироватьОжиданиеСообшения(ПараметрыЗадания.ДанныеСообщения.Период
																					, ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																					, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																					, ПараметрыЗадания.ДанныеСообщения.ИдСообщения
																					, Истина);
				КонецЕсли;
																				
				Если ПараметрыЗадания.ПараметрыЭтапаСценария.ПредоставлятьВыборВариантовКнопками Тогда
					ПараметрыЗадания.Вставить("ДополнительноеСообщение", НСтр("ru='Выбранный Вами вариант не понятен! Выберите один из предоставленных выше вариантов, указав его номер.';en='The option you have chosen is not clear! Choose one of the options above by entering its number.'"));
				Иначе 
					ПараметрыЗадания.Вставить("ДополнительноеСообщение", НСтр("ru='Пока не могу Вас понять! Попробуйте ответить однозначно.';en='Until I can understand you! Try to answer clearly.'"));
				КонецЕсли;	
				Справочники.СценарииЧатБотов.ОтправитьДополнительноеСообщениеПоСценарию(ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																					, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																					, ПараметрыЗадания.ДополнительноеСообщение
																					, ПараметрыЗадания.ДанныеСообщения.ИдДиалога
																					, ПараметрыЗадания.ДанныеСообщения.ИдКанала
																					, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота);
				Возврат;
			КонецЕсли;	
		КонецЕсли; 
		Если СтруктураВариантаОтвета = Неопределено Тогда 
			СтруктураВариантаОтвета = Новый Структура;
			СтруктураВариантаОтвета.Вставить("ЗначениеОтвета"			, ЗначениеВариантаОтвета);
			СтруктураВариантаОтвета.Вставить("ПредставлениеВарианта"	, ?(ЗначениеЗаполнено(ЗначениеВариантаОтвета), СокрЛП(Строка(ЗначениеВариантаОтвета)), ""));
			СтруктураВариантаОтвета.Вставить("ИдентификаторЭтапаВозврата", Неопределено);			
        КонецЕсли;
		СтрокаВариант = ТаблицаВариантовОтветов.Найти(СтруктураВариантаОтвета.ЗначениеОтвета, "ВариантОтвета");		
	КонецЕсли;
	
	// Получили параметры выбранного варианта - а следовательно и параметры выполнения следующего этапа
	Если НЕ ЗначениеЗаполнено(ПараметрыВарианта) Тогда 
		ПараметрыВарианта = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаВариант);
	КонецЕсли;
	
	// Получаем дополнительные параметры
	Если НЕ ЗначениеЗаполнено(ПараметрыСобщения) Тогда 	
		ПараметрыСобщения = Справочники.СценарииЧатБотов.ИнициализироватьПараметрыСообщения(ПараметрыЗадания);
	КонецЕсли;
	
	// Формируем параметры выполнения для следующего/предыдущего этапа
	ПараметрыВыполнения = ИнициализироватьПараметрыВыполнения(ПараметрыЗадания, ПараметрыВарианта);
	
	Если ПараметрыЗадания.ПараметрыЭтапаСценария.ФормироватьСтэкВариантовВыбораМетодом
		И (ПараметрыЗадания.ПараметрыЭтапаСценария.МетодФормированияСтэкаВариантовВыбора = Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПолучениеДоступныхДатДляЗаписиНаПрием ИЛИ ПараметрыЗадания.ПараметрыЭтапаСценария.МетодФормированияСтэкаВариантовВыбора = Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПолучениеДоступныхДатДляПереносаЗаписиНаПрием)
		И ТипЗнч(СтруктураВариантаОтвета.ЗначениеОтвета) = Тип("ПеречислениеСсылка.ВариантыСтандартногоПериода") Тогда
		
		ПараметрыВыполнения.Вставить("ПараметрыЭтапаСценария"		, ПараметрыЗадания.ПараметрыЭтапаСценария);
		ПараметрыВыполнения.Вставить("ОписаниеЭтапа"				, ?(ЗначениеЗаполнено(СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.ЗаголовокЭтапа)), СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.ЗаголовокЭтапа), СокрЛП(ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБота)));
		ПараметрыВыполнения.Вставить("ИдентификаторТекущегоЭтапа"	, ПараметрыЗадания.ПараметрыЭтапаСценария.ИдентификаторЭтапа);
		
		Если ПараметрыСобщения.ЭтоКнопкиТелеграм Тогда
			// Кэшируем конкретные даты и формируем новый стек кнопок
			СформироватьИОтправитьНовыйСтекВариантовВыбораПериода(ПараметрыВыполнения, ПараметрыСобщения, ПараметрыЗадания);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	                    
	Если ПараметрыСобщения.ЭтоКнопкиТелеграм Тогда 
		// Скрываем кнопки, чтобы не возникало желание на них жмакать после выбора и отработки сценария
		// Вместо них указываем выбранный клиентом вариант
		Если ЗначениеЗаполнено(ПараметрыСобщения.chat_id) И ЗначениеЗаполнено(ПараметрыСобщения.message_id) Тогда
			// РезультатОперации = МессенджерСтоматология.Telegram_РедактироватьСообщение("Ваш выбор:" + Символы.ПС + СтруктураВариантаОтвета.ПредставлениеВарианта
			//																		, ПараметрыСобщения
			//																		, ПараметрыЗадания.ДанныеСообщения
			//																		, Истина);
			
			// --------------------------------------------------------------------------------------------------------------------------------------
			ПараметрыВнешнейСистемы = Неопределено;	
			Если НЕ МессенджерСтоматология.ИнициализированыПараметрыВнешнейСистемы(ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема, ПараметрыВнешнейСистемы) Тогда
				ПараметрыВыполнения.ВыполненоУспешно 	= Ложь;
				ПараметрыВыполнения.ОписаниеОшибки 		= "Не удалось отправить сообщение. Не заполнены параметры внешней системы.";				
				Если ЗначениеЗаполнено(ПараметрыВыполнения.ДиалогID) Тогда  
					Справочники.СценарииЧатБотов.ЗафиксироватьКоллизиюДиалога(ПараметрыВыполнения);
					Возврат;
				КонецЕсли;
			КонецЕсли;			
			
			ОбработатьКнопкиВыбораВариантаТелеграм(ПараметрыВыполнения, ПараметрыЗадания, ПараметрыСобщения, ПараметрыВнешнейСистемы, СтруктураВариантаОтвета);
			
		КонецЕсли;
	КонецЕсли;			
		
	Справочники.СценарииЧатБотов.АктивироватьСценарийЧатБота(ПараметрыВыполнения, Ложь);
	
КонецПроцедуры	

// Функция - Инициализировать параметры выполнения
//
// Параметры:
//  ПараметрыЗадания	 - 	 - 
//  ПараметрыВарианта	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПараметрыВыполнения(ПараметрыЗадания, ПараметрыВарианта)
	
	// Формируем параметры выполнения для следующего/предыдущего этапа
	ПараметрыВыполнения = Неопределено;
	Справочники.СценарииЧатБотов.ИнициализироватьПараметрыВыполнения(ПараметрыВыполнения, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота);
	ПараметрыВыполнения.Вставить("ДиалогID"						, ПараметрыЗадания.ДанныеСообщения.ИдДиалога);
	ПараметрыВыполнения.Вставить("СценарийЧатБота"				, ПараметрыЗадания.ДанныеДиалога.СценарийЧатБота);
	Если ЗначениеЗаполнено(ПараметрыВарианта) Тогда
		ПараметрыВыполнения.Вставить("ИдентификаторТекущегоЭтапа", ПараметрыВарианта.СледующийЭтап);		
	КонецЕсли;	
	ПараметрыВыполнения.Вставить("ЗакрыватьДиалогПриОшибке"		, Истина);
	
	СтрокаКонтакт 						= ПараметрыВыполнения.ТаблицаКонтактов.Добавить();
	СтрокаКонтакт.Получатель 			= РегистрыСведений.КонтактыМессенджеров.ПолучитьОбъектИдентификацииПоИдентификаторуКлиента(ПараметрыЗадания.ДанныеСообщения.ИдКлиента, ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема);
	СтрокаКонтакт.СервисРассылки 		= ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема;
	СтрокаКонтакт.КаналСистемыСообщений = ПараметрыЗадания.ДанныеСообщения.ИдКанала;

	Возврат ПараметрыВыполнения;
	
КонецФункции

// Процедура - Сформировать и отправить новый стек вариантов выбора периода
//
// Параметры:
//  ПараметрыВыполнения	 - 	 - 
//  ПараметрыСобщения	 - 	 - 
//  ПараметрыЗадания	 - 	 - 
//
Процедура СформироватьИОтправитьНовыйСтекВариантовВыбораПериода(ПараметрыВыполнения, ПараметрыСобщения, ПараметрыЗадания)

	// Кэшируем конкретные даты и формируем новый стек кнопок
	Справочники.СценарииЧатБотов.ИнициализироватьВариантыВыбора(ПараметрыВыполнения);
	ПараметрыСобщения.Вставить("JSONСтруктураКнопок", ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения, "JSONСтруктураКнопок", Неопределено));
	Если ЗначениеЗаполнено(ПараметрыСобщения.chat_id) И ЗначениеЗаполнено(ПараметрыСобщения.message_id) Тогда
		ВариантСтандартногоПериодаСсылка = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения.ДанныеСценария, "ВариантСтандартногоПериодаСсылка", Неопределено);
		Если ЗначениеЗаполнено(ВариантСтандартногоПериодаСсылка) Тогда 
			ТекстСообщения 		= ?(ЗначениеЗаполнено(ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБотаВыборДаты), ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБотаВыборДаты, ПараметрыЗадания.ДанныеСообщения.ТекстСообщения);				
		Иначе 
			ТекстСообщения 		= ?(ЗначениеЗаполнено(ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБотаВыборПериода), ПараметрыЗадания.ПараметрыЭтапаСценария.СообщениеБотаВыборПериода, ПараметрыЗадания.ДанныеСообщения.ТекстСообщения);				
		КонецЕсли;	
		РезультатОперации 	= МессенджерСтоматология.Telegram_РедактироватьСообщение(ТекстСообщения
																					, ПараметрыСобщения
																					, ПараметрыЗадания.ДанныеСообщения); 
		
		Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(РезультатОперации, "ВыполненоУспешно", Ложь) Тогда
			РегистрыСведений.ЖурналСообщений.АктуализироватьОжиданиеСообшения(ПараметрыЗадания.ДанныеСообщения.Период
																			, ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																			, ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																			, ПараметрыЗадания.ДанныеСообщения.ИдСообщения
																			, Истина);
			
			// Закэшируем варианты ответов																					
			КэшВариантовОтветов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения, "КэшВариантовОтветов"	, Неопределено);
			Если ЗначениеЗаполнено(КэшВариантовОтветов) Тогда 
				РегистрыСведений.КэшВариантовОтветов.ЗакэшироватьВариантыОтветов(ПараметрыВыполнения.ДиалогID, КэшВариантовОтветов);	
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработать кнопки выбора варианта телеграм
//
// Параметры:
//  ПараметрыВыполнения		 - 	 - 
//  ПараметрыЗадания		 - 	 - 
//  ПараметрыСобщения		 - 	 - 
//  ПараметрыВнешнейСистемы	 - 	 - 
//  СтруктураВариантаОтвета	 - 	 - 
//
Процедура ОбработатьКнопкиВыбораВариантаТелеграм(ПараметрыВыполнения, ПараметрыЗадания, ПараметрыСобщения, ПараметрыВнешнейСистемы, СтруктураВариантаОтвета)

	СтруктураВариантаОтвета.Вставить("ДиалогID"			, ПараметрыЗадания.ДанныеСообщения.ИдДиалога);
	СтруктураВариантаОтвета.Вставить("ОтветУчастника"	, "buttondisabled");			
	ЗаполнитьЗначенияСвойств(ПараметрыВыполнения.КэшВариантовОтветов.Добавить(), СтруктураВариантаОтвета);
	ПараметрыВыполнения.Вставить("ПараметрыЭтапаСценария", Новый Структура("ПредоставлятьВыборВариантовКнопками, МетодФормированияСтэкаВариантовВыбора", Истина, Перечисления.МетодыФормированияСтэкаВариантовВыбора.ПустаяСсылка()));
	Справочники.СценарииЧатБотов.ИнициализироватьJSONСтруктуруКнопок(ПараметрыВыполнения, ПараметрыВнешнейСистемы.ТипВнешнейСистемы);
	ПараметрыВыполнения.Удалить("ПараметрыЭтапаСценария");
	ПараметрыСобщения.Вставить("JSONСтруктураКнопок", ПараметрыВыполнения.JSONСтруктураКнопок);
	
	// ПараметрыЗадания.ДополнительныеПараметры.text
	// ПараметрыЗадания.ДанныеСообщения.ТекстСообщения
	РезультатОперации = МессенджерСтоматология.Telegram_РедактироватьСообщение(ПараметрыЗадания.ДанныеСообщения.ТекстСообщенияUTF8
																			, ПараметрыСобщения
																			, ПараметрыЗадания);
	
	
	ПараметрыВыполнения.JSONСтруктураКнопок = Неопределено;
	// Если сообщение отправлено.
	Если РезультатОперации.ВыполненоУспешно Тогда
		ОператорСообщения 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения, "ОператорСообщения"	, Неопределено);
		Триггер 			= ?(ТипЗнч(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения, "ПараметрыРегистрацииТриггера", Ложь)) = Тип("Структура"), Истина, Ложь);
		ПараметрыВыполнения.Вставить("УстановкаФлагаПрочитано", Истина);
		// Добавляем отправленное сообщенте в регистр.
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(ПараметрыЗадания.ДанныеСообщения.ИдКлиента
																	, РезультатОперации.ИдСообщения
																	,
																	, РезультатОперации.ИдКанала
																	, СтруктураВариантаОтвета.ПредставлениеВарианта
																	, Истина
																	, Перечисления.Мессенджеры.telegram
																	, Истина
																	, ТекущаяДатаСеанса()
																	, ПараметрыЗадания.ДанныеСообщения.ВнешняяСистема
																	, ОператорСообщения
																	,
																	, 
																	, 
																	, Триггер
																	, 
																	, ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыВыполнения, "JSONСтруктураКнопок", Неопределено) <> Неопределено
																	, 
																	, 
																	, 
																	, ПараметрыВыполнения);
		
		ПараметрыВыполнения.Удалить("УстановкаФлагаПрочитано");																
	КонецЕсли;	
	
КонецПроцедуры

 #КонецОбласти    

 #КонецОбласти

