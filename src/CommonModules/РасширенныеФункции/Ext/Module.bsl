// Функция - Получить цвет из стиля платформы
//
// Параметры:
//  Цвет - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветИзСтиляПлатформы(Цвет) Экспорт
	
	Попытка
		
		ТабДок = Новый ТабличныйДокумент;
		
		ТабДок.Область(1,1,1,1).ЦветФона = Цвет;
		ВремФайл = ПолучитьИмяВременногоФайла("htm");
		ТабДок.Записать(ВремФайл,ТипФайлаТабличногоДокумента.HTML);
		
		КодПоиска = "tr.R0 td.R0C0{ background-color:"; // если 1С изменит формат, эту строку придётся поменять
		
		ТабДок = Новый ТекстовыйДокумент;
		
		ТабДок.Прочитать(ВремФайл);
		Стр = ТабДок.ПолучитьТекст();
		Позиция = Найти(Стр,КодПоиска);
		
		Если Позиция <> 0 Тогда	
			Возврат ВРег(Сред(Стр, Позиция + СтрДлина(КодПоиска),8));
		КонецЕсли;
		
		Возврат "";	
	Исключение
		Возврат "";	
	КонецПопытки;
	
КонецФункции

&НаСервере
// Функция - Получить структурную единицу
// 
// Параметры:
//  IDUnit	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПроверитьСсылкаБитая(Ссылка) Экспорт
	
	// Без прив. режима пытаемся получить ссылку, если запрос пустой, значит ссылка не доступна сотруднику
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|    Ссылка
	|ИЗ
	|    [ИмяТаблицы]
	|ГДЕ
	|    Ссылка = &Ссылка
	|";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "[ИмяТаблицы]", Метаданные.НайтиПоТипу(ТипЗнч(Ссылка)).ПолноеИмя());
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Запрос.Выполнить().Пустой();
	
КонецФункции

//////////// ТАБЛИЦЫ

// Функция выполняет добавление номенклатуры в ТЧ
// 
Функция ТаблицуЗначенийВМассивСтруктур(ТаблицаЗначений, ИменаКолонок = Неопределено, СтруктураОтбора = Неопределено) Экспорт 
	
	Результат = Новый Массив;
	Если ИменаКолонок = Неопределено Тогда
		ИменаКолонок = "";
		Если ТипЗнч(ТаблицаЗначений) = Тип("ТаблицаЗначений") Тогда
			Для Каждого КолонкаТЗ Из ТаблицаЗначений.Колонки Цикл
				ИменаКолонок = ИменаКолонок + КолонкаТЗ.Имя + ",";
			КонецЦикла;
		Иначе // Табличная часть
			Для Каждого КолонкаТЗ Из ТаблицаЗначений.Выгрузить().Колонки Цикл
				ИменаКолонок = ИменаКолонок + КолонкаТЗ.Имя + ",";
			КонецЦикла;
		КонецЕсли;
		ИменаКолонок = Сред(ИменаКолонок, 1, СтрДлина(ИменаКолонок) - 1);
	КонецЕсли;
	
	Для Каждого СтрокаТЗ Из ТаблицаЗначений Цикл
		СтрокаТЗСтруктура = Новый Структура(ИменаКолонок);
		ЗаполнитьЗначенияСвойств(СтрокаТЗСтруктура, СтрокаТЗ);
		СтрокаУдовлетворяетОтбору = Истина;
		Если СтруктураОтбора <> Неопределено Тогда
			Для каждого ЭлементОтбора Из СтруктураОтбора Цикл
				Если СтрокаТЗ[ЭлементОтбора.Ключ] <> ЭлементОтбора.Значение Тогда
					СтрокаУдовлетворяетОтбору = Ложь;
				КонецЕсли; 
			КонецЦикла; 
		КонецЕсли;
		Если СтрокаУдовлетворяетОтбору = Истина Тогда
			Результат.Добавить(СтрокаТЗСтруктура);
		КонецЕсли; 
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция выполняет добавление номенклатуры в ТЧ
// 
Функция СтрокуТаблицыЗначенийВСтруктуру(СтрокаТЗ, ИменаКолонокТаблицаЗначений) Экспорт 
	
	Если ТипЗнч(ИменаКолонокТаблицаЗначений) = Тип("Строка") Тогда
	    ИменаКолонок = ИменаКолонокТаблицаЗначений;
	ИначеЕсли ТипЗнч(ИменаКолонокТаблицаЗначений) = Тип("ТаблицаЗначений") Тогда
		ИменаКолонок = "";
		Для Каждого КолонкаТЗ Из ИменаКолонокТаблицаЗначений.Колонки Цикл
			ИменаКолонок = ИменаКолонок + КолонкаТЗ.Имя + ",";
		КонецЦикла;
		ИменаКолонок = Сред(ИменаКолонок, 1, СтрДлина(ИменаКолонок) - 1);
	Иначе
		ИменаКолонок = "";
	КонецЕсли;
	
	Результат = Новый Структура(ИменаКолонок);
	ЗаполнитьЗначенияСвойств(Результат, СтрокаТЗ);
	
	Возврат Результат;
	
КонецФункции

// Возвращает результат проверки равенства таблиц
// 
Функция СравнитьТаблицы(Знач ТаблицаЗначений1, Знач ТаблицаЗначений2, СовпадениеПоПозициям = Истина, СписокКолонокСтрокой = "") Экспорт

	Если ТипЗнч(ТаблицаЗначений1) <> Тип("ТаблицаЗначений") Тогда
		ТаблицаЗначений1 = ТаблицаЗначений1.Выгрузить();
	КонецЕсли;
	Если ТипЗнч(ТаблицаЗначений2) <> Тип("ТаблицаЗначений") Тогда
		ТаблицаЗначений2 = ТаблицаЗначений2.Выгрузить();
	КонецЕсли;
	
	Если СписокКолонокСтрокой = "" Тогда
		Для Каждого КолонкаТаблицы Из ТаблицаЗначений1.Колонки Цикл
			СписокКолонокСтрокой = СписокКолонокСтрокой + ?(ЗначениеЗаполнено(СписокКолонокСтрокой), ",", "") + КолонкаТаблицы.Имя;
		КонецЦикла;		
	КонецЕсли; 
	
	// Таблица 1 к таблице 2
	Для а = 1 По ТаблицаЗначений1.Количество() Цикл
		ВремСтруктураПоиска = Новый Структура(СписокКолонокСтрокой);
		ЗаполнитьЗначенияСвойств(ВремСтруктураПоиска, ТаблицаЗначений1[а-1]);
		Если ТаблицаЗначений2.Количество() < а 
				ИЛИ СовпадениеПоПозициям = Ложь И ТаблицаЗначений2.НайтиСтроки(ВремСтруктураПоиска).Количество() = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		Для Каждого ИмяКолонки Из СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СписокКолонокСтрокой, ",") Цикл			
			Если ТаблицаЗначений2.Колонки.Найти(ИмяКолонки) = Неопределено
					ИЛИ СовпадениеПоПозициям = Истина И ТаблицаЗначений1[а-1][ИмяКолонки] <> ТаблицаЗначений2[а-1][ИмяКолонки] Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Таблица 2 к таблице 1
	Для а = 1 По ТаблицаЗначений2.Количество() Цикл
		ВремСтруктураПоиска = Новый Структура(СписокКолонокСтрокой);
		ЗаполнитьЗначенияСвойств(ВремСтруктураПоиска, ТаблицаЗначений2[а-1]);
		Если ТаблицаЗначений1.Количество() < а 
				ИЛИ СовпадениеПоПозициям = Ложь И ТаблицаЗначений1.НайтиСтроки(ВремСтруктураПоиска).Количество() = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		Для Каждого ИмяКолонки Из СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СписокКолонокСтрокой, ",") Цикл			
			Если ТаблицаЗначений1.Колонки.Найти(ИмяКолонки) = Неопределено
					ИЛИ СовпадениеПоПозициям = Истина И ТаблицаЗначений2[а-1][ИмяКолонки] <> ТаблицаЗначений1[а-1][ИмяКолонки] Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Истина;

КонецФункции

// Возвращает результат проверки равенства таблиц
// 
Функция МассивСтрокТаблицыВТаблицуЗначений(Знач МассивСтрокТаблицыЗначений, ЗначТаблицаЗначений) Экспорт

	РезультатТаблицаЗначений = ЗначТаблицаЗначений.СкопироватьКолонки();
	
	Для Каждого ЭлементСтроки Из ЗначТаблицаЗначений Цикл
		НоваяСтрока = РезультатТаблицаЗначений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементСтроки);
	КонецЦикла;		
		
	Возврат РезультатТаблицаЗначений;

КонецФункции

// Дополняет таблицу значений-приемник данными из таблицы значений-источник
// 
// Параметры:
//  ТаблицаИсточник - Таблица значений - таблица из которой будут браться строки для заполнения
//  ТаблицаПриемник - Таблица значений - таблица в которую будут добавлены строки из таблицы-источника
//  
Процедура ДополнитьТаблицуИсточником(ТаблицаИсточник, ТаблицаПриемник, ДобавитьСсылкуНаСтрокуИсточник_Имя = "") Экспорт
	
	Для каждого СтрокаТаблицыИсточник Из ТаблицаИсточник Цикл
		НоваяСтрока = ТаблицаПриемник.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицыИсточник);
		Если ДобавитьСсылкуНаСтрокуИсточник_Имя <> "" Тогда
			Если ТипЗнч(ТаблицаПриемник) = Тип("ТаблицаЗначений") И ТаблицаПриемник.Колонки.Найти(ДобавитьСсылкуНаСтрокуИсточник_Имя) = Неопределено Тогда
				ТаблицаПриемник.Колонки.Добавить(ДобавитьСсылкуНаСтрокуИсточник_Имя);
			КонецЕсли; 
			НоваяСтрока[ДобавитьСсылкуНаСтрокуИсточник_Имя] = СтрокаТаблицыИсточник;
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Последовательности пакеты услуг при записи
// 
// Параметры:
//  Источник - 	 - 
//  Отказ	 - 	 - 
// 
Процедура ДобавитьСтрокуВТаблицу(Таблица, ИменаКолонок, Поле_1 = Неопределено, Поле_2 = Неопределено, Поле_3 = Неопределено, Поле_4 = Неопределено, Поле_5 = Неопределено) Экспорт
	
	НоваяСтрока = Таблица.Добавить();
	
	МассивИменКолонок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИменаКолонок, ",");
	МассивЗначений = Новый_Массив(Поле_1, Поле_2, Поле_3, Поле_4, Поле_5);
	ИндексЗначения = 0;
	Для Каждого ИмяКолонки Из МассивИменКолонок Цикл
		НоваяСтрока[ИмяКолонки] = МассивЗначений[ИндексЗначения];
		ИндексЗначения = ИндексЗначения + 1;
	КонецЦикла;
		
КонецПроцедуры

