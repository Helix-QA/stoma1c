// Функция - Войти в личный кабинет модель сервиса
// 
// Возвращаемое значение:
//   - 
// 
Функция ВойтиВЛичныйКабинетМодельСервиса() Экспорт
	
	Попытка 
		
		АдресЛичногоКабинетаВМоделиСервиса = Константы.АдресЛичногоКабинетаВМоделиСервиса.Получить();
		
		Если НЕ ЗначениеЗаполнено(АдресЛичногоКабинетаВМоделиСервиса) Тогда
			ВызватьИсключение "Константа АдресЛичногоКабинетаВМоделиСервиса не заполнена!";
		КонецЕсли;
		
		СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресЛичногоКабинетаВМоделиСервиса 
		     + ?(СтрЗаканчиваетсяНа(АдресЛичногоКабинетаВМоделиСервиса,"/"), "hs/api_private/v1/", "/hs/api_private/v1/")); 
		
		ПараметрыОсновные = ПараметрыПодклчюенияК_API_CRM();
		СтрПараметров     = Новый Структура;
		СтрПараметров.Вставить("АдресСервера"   , СтруктураURI.Хост);
		СтрПараметров.Вставить("АдресПубликации", СтруктураURI.ПутьНаСервере);
		СтрПараметров.Вставить("Пользователь"   , ПараметрыОсновные.Пользователь);
		СтрПараметров.Вставить("Пароль"         , ПараметрыОсновные.Пароль);
		
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("areanumber", ПолучитьНомерОбласти());
		
		РезультатЗапроса  = ВыполнитьPOSTЗапрос("account/auth", Неопределено, ЗаголовкиHTTP, СтрПараметров);
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
		Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
			
			РезультатаОперции.Вставить("ВходРазрешен"        , РезультатаОперции.ПараметрыРезультата.access_allow);
			РезультатаОперции.Вставить("ОписаниеРезультата"  , РезультатаОперции.ПараметрыРезультата.description);
			РезультатаОперции.Вставить("УИДСессии"           , РезультатаОперции.ПараметрыРезультата.uid_session);
			РезультатаОперции.Вставить("РегистрационныйНомер", РезультатаОперции.ПараметрыРезультата.registration_number);

		КонецЕсли;
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	    РезультатаОперции.Вставить("ВходРазрешен"        , Неопределено);
		РезультатаОперции.Вставить("ОписаниеРезультата"  , "Ошибка работы с личным кабинетом");
		РезультатаОперции.Вставить("УИДСессии"           , Неопределено);
        РезультатаОперции.Вставить("РегистрационныйНомер", Неопределено);

	КонецПопытки;
	
	Возврат РезультатаОперции;

