&НаСервереБезКонтекста
// Процедура - Заполнить список организаций.
//
Процедура ЗаполнитьСписокОрганизаций(СписокОрганизаций)
	
	СписокЗначений = Новый СписокЗначений;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации";
	ВыборкаОрганизаций = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаОрганизаций.Следующий() Цикл
		СписокЗначений.Добавить(ВыборкаОрганизаций.Ссылка);
	КонецЦикла;
	СписокОрганизаций = СписокЗначений;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый обработать активизацию строки списка.
//
Процедура Подключаемый_ОбработатьАктивизациюСтрокиСписка()
	
	ТекущаяСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущаяСтрока <> Неопределено Тогда
		СтруктураДанные = ПолучитьДанныеПоКассеБанковскомуСчету(ТекущаяСтрока.Дата, ?(ПереключательКассаБанк = 0, ТекущаяСтрока.Касса, ТекущаяСтрока.БанковскийСчет), ТипДенежныхСредств);
		ЗаполнитьЗначенияСвойств(ЭтаФорма, СтруктураДанные);
		Дата = Формат(ТекущаяСтрока.Дата, "ДЛФ=D");
	Иначе
		ИнформацияСуммаКонечныйОстаток = 0;
		ИнформацияСуммаНачальныйОстаток = 0;
		ИнформацияСуммаПриход = 0;
		ИнформацияСуммаРасход = 0;
		Дата = "";
	Конецесли;
	
КонецПроцедуры 

&НаСервереБезКонтекста
// Функция - Получить данные по кассе банковскому счету.
//
Функция ПолучитьДанныеПоКассеБанковскомуСчету(Период, КассаБанковскийСчет, ТипДенежныхСредств)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДенежныеСредстваОстаткиИОбороты.СуммаНачальныйОстаток КАК ИнформацияСуммаНачальныйОстаток,
	|	ДенежныеСредстваОстаткиИОбороты.СуммаПриход КАК ИнформацияСуммаПриход,
	|	ДенежныеСредстваОстаткиИОбороты.СуммаРасход КАК ИнформацияСуммаРасход,
	|	ДенежныеСредстваОстаткиИОбороты.СуммаКонечныйОстаток КАК ИнформацияСуммаКонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			День,
	|			,
	|			БанковскийСчетКасса = &КассаБанковскийСчет
	|				И ТипДенежныхСредств = &ТипДенежныхСредств) КАК ДенежныеСредстваОстаткиИОбороты";
	
	Запрос.УстановитьПараметр("НачалоПериода",      НачалоДня(Период));
	Запрос.УстановитьПараметр("КонецПериода",       КонецДня(Период));
	Запрос.УстановитьПараметр("КассаБанковскийСчет",КассаБанковскийСчет);
	Запрос.УстановитьПараметр("ТипДенежныхСредств", ТипДенежныхСредств);
	
	ВыборкаРезультата = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаРезультата.Следующий() Тогда
		СтруктураВозврата = Новый Структура("ИнформацияСуммаНачальныйОстаток, ИнформацияСуммаКонечныйОстаток, ИнформацияСуммаПриход, ИнформацияСуммаРасход");
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, ВыборкаРезультата);
		Возврат СтруктураВозврата;
	Иначе
		Возврат Новый Структура(
		"ИнформацияСуммаКонечныйОстаток, ИнформацияСуммаНачальныйОстаток, ИнформацияСуммаПриход, ИнформацияСуммаРасход",
		0,0,0,0,Ложь
		);
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура - Установить видимость отбор.
//
Процедура УстановитьВидимостьОтбор()
	
	ЭтоКасса = (ПереключательКассаБанк = 0);
	
	Если ЭтоКасса Тогда
		ТипДенежныхСредств =  ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные");		
		ЭтаФорма.Заголовок = Нстр("ru = 'Документы по кассе'; en = 'Cashbox documents'");	
	Иначе
		ТипДенежныхСредств =  ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные");
		ЭтаФорма.Заголовок = Нстр("ru = 'Документы по банку'; en = 'Bank documents'");		
	КонецЕсли;
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокДокументов, "ТипДенежныхСредств", ЭтаФорма.ТипДенежныхСредств, Истина);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокДокументов, "БанковскийСчет", ЭтаФорма.БанковскийСчет, ?(ЭтоКасса, Ложь, ЗначениеЗаполнено(ЭтаФорма.БанковскийСчет)));
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(СписокДокументов, "Касса", ЭтаФорма.Касса, ?(ЭтоКасса, ЗначениеЗаполнено(ЭтаФорма.Касса), Ложь));	
	
	Элементы.Касса.Видимость = ЭтоКасса;
	Элементы.СписокКасса.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьВозвратОтПодотчетника.Видимость = ЭтоКасса;
	Элементы.ФормаСоздатьВозвратОтПодотчетникаКонтекстноеМеню.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьПоступлениеИзБанка.Видимость = ЭтоКасса;
	Элементы.ФормаСоздатьПоступлениеИзБанкаКонтекстноеМеню.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьВыдачаПодотчетнику.Видимость = ЭтоКасса;
	Элементы.ФормаСоздатьВыдачаПодотчетникуКонтекстноеМеню.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьСдачаНаличныхВБанк.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьСдачаНаличныхВБанкКонтекстноеМеню.Видимость = ЭтоКасса;
	
	Элементы.ФормаСоздатьПоступлениеРозничнойВыручкиИзОперационнойКассы.Видимость = ЭтоКасса;
	Элементы.ФормаСоздатьПоступлениеРозничнойВыручкиИзОперационнойКассыКонтекстноеМеню.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьПоступлениеИзКассыПредприятия.Видимость = ЭтоКасса;	
	Элементы.ФормаСоздатьПоступлениеИзКассыПредприятияКонтекстноеМеню.Видимость = ЭтоКасса;                 
	Элементы.ФормаСоздатьВыбытиеВОперационнуюКассу.Видимость = ЭтоКасса;     
	Элементы.ФормаСоздатьВыбытиеВОперационнуюКассуКонтекстноеМеню.Видимость = ЭтоКасса;                     
	Элементы.ФормаСоздатьСдачаРозничнойВыручкиВКассуПредприятия.Видимость = ЭтоКасса;
	Элементы.ФормаСоздатьСдачаРозничнойВыручкиВКассуПредприятияКонтекстноеМеню.Видимость = ЭтоКасса;
	
	Элементы.БанковскийСчет.Видимость = НЕ ЭтоКасса;
	Элементы.СписокБанковскийСчет.Видимость = НЕ ЭтоКасса;		
	Элементы.ФормаСоздатьПоступлениеОтЭквайера.Видимость = НЕ ЭтоКасса;
	Элементы.ФормаСоздатьПоступлениеОтЭквайераКонтекстноеМеню.Видимость = НЕ ЭтоКасса;	
	Элементы.ФормаСоздатьВозвратНалога.Видимость = НЕ ЭтоКасса;
	Элементы.ФормаСоздатьВозвратНалогаКонтекстноеМеню.Видимость = НЕ ЭтоКасса; 	
	Элементы.ФормаСоздатьПоступлениеИзКассы.Видимость = НЕ ЭтоКасса;
	Элементы.ФормаСоздатьПоступлениеИзКассыКонтекстноеМеню.Видимость = НЕ ЭтоКасса;	
	Элементы.ФормаСоздатьОплатаНалога.Видимость = НЕ ЭтоКасса;
	Элементы.ФормаСоздатьОплатаНалогаКонтекстноеМеню.Видимость = НЕ ЭтоКасса;	
	Элементы.ФормаСоздатьВыбытиеВКассу.Видимость = НЕ ЭтоКасса;
	Элементы.ФормаСоздатьВыбытиеВКассуКонтекстноеМеню.Видимость = НЕ ЭтоКасса;
	
КонецПроцедуры

