// Функция, получает статус отправленного сообщения по его ID
//  Параметры:
//   МассивIDSMS: Массив, Массив ID сообщений.
//   
Функция RocketSMS_ПолучитьСтатусSMS(СервисSMSРассылки, IDСообщений)
	
	Результат = СоздатьТаблицуРезульта(IDСообщений, Ложь);
		
	Для Каждого СтрокаIDСообщения Из Результат Цикл
		
		ПОПЫТКА
			
			ОписаниеОшибки = "";
			Если ПустаяСтрока(СтрокаIDСообщения.IDСообщения) Тогда
				Продолжить;
			КонецЕсли;
			
			Ответ = RocketSMS_ПослатьКоманду("//simple/status/", "&id=" + URLEncode(СтрокаIDСообщения.IDСообщения), СервисSMSРассылки, ОписаниеОшибки);
			
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				
				СтрокаIDСообщения.СтатусСообщения = ОписаниеОшибки;
				СтрокаIDСообщения.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
				
				Возврат Результат;
				
			КонецЕсли;
			
			СтруктураОтвета = ДекодироватьИзJSON(Ответ);
			
			
			Если СтруктураОтвета.Свойство("status") Тогда
				status = СтруктураОтвета.status;
				Если status = "QUEUED" Или status = "SENT" Тогда
					СтатусСообщенияСтрока = "В редиме доставки";
					СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
				ИначеЕсли status = "DELIVERED"  Тогда
					СтадияДоставки = Перечисления.СтадииДоставкиSMSСообщений.СообщениеДоставлено;
					СтатусСообщенияСтрока = "Сообщение доставлено";
				ИначеЕсли status = "FAILED " Тогда
					СтадияДоставки = Перечисления.СтадииДоставкиSMSСообщений.ОшибкаДоставки;
					СтатусСообщенияСтрока = "Ошибка доставки";
				КонецЕсли;
				СтрокаIDСообщения.СтадияДоставки  = СтадияДоставки;
				СтрокаIDСообщения.СтатусСообщения = СтатусСообщенияСтрока;
			Иначе
				СтрокаIDСообщения.СтатусСообщения = "Ошибка доставки";
			    СтрокаIDСообщения.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
			КонецЕсли;
			
		ИСКЛЮЧЕНИЕ
			
			СтрокаIDСообщения.СтатусСообщения = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			СтрокаIDСообщения.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
			
		КОНЕЦПОПЫТКИ
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции // ПолучитьСтатусSMS()

// Функция, выполняет отправку смс сообщения
//  Параметры:
//
Функция RocketSMS_ПолучитьБаланс(СервисSMSРассылки)
		
	ОписаниеОшибки 	= "";
	Ответ			= RocketSMS_ПослатьКоманду("//simple/balance/",, СервисSMSРассылки, ОписаниеОшибки);
	
	Результат = Новый Структура("Баланс, Валюта, Ошибка, ОписаниеОшибки", 0, "Руб.", Ложь, "");
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		Результат.Ошибка         = Истина;
	    Результат.ОписаниеОшибки = ОписаниеОшибки;
		Возврат Результат;

	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ответ) Тогда
	    СтруктураОтвета = ДекодироватьИзJSON(Ответ);
		Результат.Ошибка = Ложь;
		Результат.Баланс = СтруктураОтвета.balance;
	Иначе
	    Результат.Ошибка         = Истина;
	    Результат.ОписаниеОшибки = "Неверный формат ответа";
	КонецЕсли;
		
    Возврат Результат;
	
КонецФункции

// Функция возвращает хеш строки
//
Функция ПолучитьMD5(Текст)
	
	ОбъектХеш = Новый ХешированиеДанных(ХешФункция.MD5);
	ОбъектХеш.Добавить(Текст);
	ХешСумма = СтрЗаменить(ОбъектХеш.ХешСумма, " ", "");
	Возврат ХешСумма;

КонецФункции

// Функция - Прочитать адрес
//
// Параметры:
//  Сервер			 - 	 - 
//  РесурсНаСервере	 - 	 - 
//  Параметры		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПрочитатьАдрес(Сервер, РесурсНаСервере, Параметры, ОписаниеОшибки) Экспорт
	
	ЗащищенноеСоединениеOpenSSL = Новый ЗащищенноеСоединениеOpenSSL(, );
	
	Попытка
        Соединение = Новый HTTPСоединение(Сервер,,,,,, ЗащищенноеСоединениеOpenSSL);
	Исключение
		ОписаниеОшибки = "Не удалось установить соединение с сервером:" + Символы.ПС + ИнформацияОбОшибке().Описание;
	    Возврат "";
	КонецПопытки;

	ИмяФайлаРезультата = ПолучитьИмяВременногоФайла();
	
	РесурсПараметры = РесурсНаСервере + "?" + Параметры;
	Если СтрДлина(РесурсПараметры) < 2000 Тогда // GET 
		
		Попытка
			Соединение.Получить(РесурсПараметры, ИмяФайлаРезультата);
			Соединение = Неопределено;
		Исключение 
			ОписаниеОшибки = "Не удалось получить данные с сервера";
			Возврат "";
		КонецПопытки;
			
	Иначе // POST	
		
		// Создаём файл отправки - содержимое POST-запроса. 
		ИмяФайлаОтправки = ПолучитьИмяВременногоФайла();
		ФайлОтправки = Новый ЗаписьТекста(ИмяФайлаОтправки, КодировкаТекста.ANSI, Символы.ПС, ЛОЖЬ);
		ФайлОтправки.ЗаписатьСтроку(Параметры); 
		ФайлОтправки.Закрыть(); 

		// Формируем заголовок POST-запроса.
	    ЗаголовокHTTP = Новый Соответствие();
	    ЗаголовокHTTP.Вставить("Content-Type", "application/x-www-form-urlencoded");
	    ФайлОтправки = Новый Файл(ИмяФайлаОтправки); 
	    РазмерФайлаОтправки = XMLСтрока(ФайлОтправки.Размер()); 
		ЗаголовокHTTP.Вставить("Content-Length", Строка(РазмерФайлаОтправки)); 

		Попытка
	 		Соединение.ОтправитьДляОбработки(ИмяФайлаОтправки, РесурсНаСервере, ИмяФайлаРезультата, ЗаголовокHTTP);
			Соединение = Неопределено;
		Исключение 
			ОписаниеОшибки = "Не удалось получить данные с сервера:" + Символы.ПС + ИнформацияОбОшибке().Описание;
			Возврат "";
		КонецПопытки;
		
		УдалитьФайлы(ИмяФайлаОтправки);
		
	КонецЕсли;	
		
	ФайлРезультата	= Новый ЧтениеТекста(ИмяФайлаРезультата);
	Результат    	= ФайлРезультата.Прочитать();
	ФайлРезультата.Закрыть();
		
	УдалитьФайлы(ИмяФайлаРезультата);
	
	Возврат Результат;
	
КонецФункции // ПрочитатьАдрес()

// Функция - Преобразоватьв систему
//
// Параметры:
//  Число10	 - 	 - 
//  система	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПреобразоватьвСистему(Число10, система)
	
	Если система > 36 или система < 2 тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выбранная система исчисления не поддерживается");
		Возврат -1;
	КонецЕсли;
	
	СтрокаЗначений = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	СтрокаСистема = "";
	Пока Число10 > 0 цикл
		РезДеления = Число10/система;
		ЧислоСистема = цел(РезДеления);
		остатокОтДеления = Число10 - система*(ЧислоСистема);
		СтрокаСистема = сред(СтрокаЗначений,остатокОтДеления+1,1)+ СтрокаСистема;
		Число10 = ?(ЧислоСистема=0,0,РезДеления); 
	КонецЦикла;
	
	//!!!!!!!!
	//[
	Нечётное = стрДлина(СтрокаСистема) - цел(стрДлина(СтрокаСистема)/2)*2;
	Если Нечётное тогда
		СтрокаСистема = "0"+СтрокаСистема;
	КонецЕсли;
	//]
	Возврат СтрокаСистема;
КонецФункции

// Функция - URLEncode
//
// Параметры:
//  Стр	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция URLEncode(Стр) Экспорт
	
	Длина=СтрДлина(Стр);
	Итог="";
	Для Н=1 По Длина Цикл
		Знак=Сред(Стр,Н,1);
		Код=КодСимвола(Знак);
		
		Если ((Знак>="a")и(Знак<="z")) или
			 ((Знак>="A")и(Знак<="Z")) или
			 ((Знак>="0")и(Знак<="9")) тогда
			Итог=Итог + Знак;
		Иначе
			Если (Код>=КодСимвола("А"))И(Код<=КодСимвола("п")) Тогда
				Итог=Итог+"%"+ПреобразоватьвСистему(208,16)+"%"+ПреобразоватьвСистему(144+Код-КодСимвола("А"),16);
			ИначеЕсли (Код>=КодСимвола("р"))И(Код<=КодСимвола("я")) Тогда
				Итог=Итог+"%"+ПреобразоватьвСистему(209,16)+"%"+ПреобразоватьвСистему(128+Код-КодСимвола("р"),16);
			ИначеЕсли (Знак="ё") Тогда
				Итог=Итог+"%"+ПреобразоватьвСистему(209,16)+"%"+ПреобразоватьвСистему(145,16);
			ИначеЕсли (Знак="Ё") Тогда
				Итог=Итог+"%"+ПреобразоватьвСистему(208,16)+"%"+ПреобразоватьвСистему(129,16);
			Иначе
				Итог=Итог+"%"+ПреобразоватьвСистему(Код,16);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Итог;
КонецФункции

