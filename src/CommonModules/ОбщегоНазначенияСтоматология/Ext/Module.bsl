// Функция, проверяет наличие времени у структурной единицы и возвращает список возможных смен.
//  Параметры:
// СтруктурнаяЕдиница - ссылка структурная единица, позиция  структурной единицы, по которой надо получить список смен.
//   ДанныеВыбора - структура, выбор данных по упаковкам.
//  Возвращаемое значение:
//   Признак наличия времени - булево.
//
Функция ПроверитьНаличиеВремениИПолучитьСписокДляВыбора(СтруктурнаяЕдиница, ДанныеВыбора, ДатаНачала, СтрокаПоиска = Неопределено, ВыбраннаяДатаНачала = Неопределено) Экспорт
	
	Период = ПолучитьНаибольшееВремяРаботы(СтруктурнаяЕдиница);
		
	Если Период <> неопределено Тогда
		Если НЕ ЗначениеЗаполнено(Период.НачалоРаботы) и Не ЗначениеЗаполнено(Период.ОкончаниеРаботы) Тогда
			возврат Ложь;
		КонецЕсли;
	Иначе
		возврат Ложь;
	КонецЕсли; 	
	
	Интервал = 15;
	мФормат = "ДФ=ЧЧ:мм";
	Если ДатаНачала Тогда
			Счетчик = 0;
		Иначе
			Счетчик = 1;
	КонецЕсли;	

	Если ДатаНачала Тогда
		Период.НачалоРаботы = НачалоЧаса(Период.НачалоРаботы) + Цел (Минута(Период.НачалоРаботы) / 15) * 15 * 60;
	ИначеЕсли Период.НачалоРаботы <= ВыбраннаяДатаНачала Тогда 
		Период.НачалоРаботы = ВыбраннаяДатаНачала;
	КонецЕсли;
	Пока Период.НачалоРаботы + Интервал * 60 * Счетчик <= Период.ОкончаниеРаботы Цикл
		Время = Период.НачалоРаботы + Интервал * 60 * Счетчик;
		Если ДанныеВыбора.НайтиПоЗначению(Время) = Неопределено Тогда
			Если не ЗначениеЗаполнено(Время) Тогда
				ДанныеВыбора.Добавить(Время, "00:00");
			Иначе
				ДанныеВыбора.Добавить(Время, Формат(Время, мФормат));
			КонецЕсли;
		КонецЕсли;			
		Счетчик = Счетчик + 1;
	КонецЦикла;
	Если Период.ОкончаниеРаботы = Дата(01,01,01,23,59,59) и не ДатаНачала Тогда
		ДанныеВыбора.Добавить(Период.НачалоРаботы + Интервал * 60 * Счетчик, "24:00");
	КонецЕсли;
	
	Возврат Истина;  
	
КонецФункции

// Функция возвращает наибольщий интервал работы структурной единицы
//
Функция ПолучитьНаибольшееВремяРаботы(СтруктурнаяЕдиница) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	МИНИМУМ(ВложенныйЗапрос.НачалоРаботы) КАК НачалоРаботы,
	                      |	МАКСИМУМ(ВложенныйЗапрос.ОкончаниеРаботы) КАК ОкончаниеРаботы
	                      |ИЗ
	                      |	(ВЫБРАТЬ
	                      |		РасписаниеРаботы.НачалоРаботы КАК НачалоРаботы,
	                      |		ВЫБОР
	                      |			КОГДА РасписаниеРаботы.ОкончаниеРаботы = &ПустаяДата
	                      |				ТОГДА &ДатаОкончания
	                      |			ИНАЧЕ РасписаниеРаботы.ОкончаниеРаботы
	                      |		КОНЕЦ КАК ОкончаниеРаботы
	                      |	ИЗ
	                      |		Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК РасписаниеРаботы
	                      |	ГДЕ
	                      |		РасписаниеРаботы.Активность = ИСТИНА
	                      |		И РасписаниеРаботы.Ссылка = &СтруктурнаяЕдиница) КАК ВложенныйЗапрос");
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ПустаяДата", Дата(01,01,01));
	Запрос.УстановитьПараметр("ДатаОкончания", Дата(01,01,01,23,59,59));
 	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
		ПериодРаботы = Новый Структура;
		ПериодРаботы.Вставить("НачалоРаботы",Выборка.НачалоРаботы);
		ПериодРаботы.Вставить("ОкончаниеРаботы",  Выборка.ОкончаниеРаботы); 
		Возврат ПериодРаботы;
	Иначе
		Возврат Неопределено
	КонецЕсли;
	
КонецФункции

// Функция определяет пол клиента по ФИО
// 
Функция ОпределитьПолКлиента(Фамилия, Имя, Отчество) Экспорт
	
	Фамилия = СокрЛП(Фамилия);
	Имя = СокрЛП(Имя);
	Отчество = СокрЛП(Отчество);
	Если Отчество <> "" Тогда
		Окончание_1_буква = НРег(Сред(Отчество, СтрДлина(Отчество)));
		Если Окончание_1_буква = "ч" ИЛИ Окончание_1_буква = "в" Тогда
			Возврат "Мужской";
		ИначеЕсли Окончание_1_буква = "а" Тогда
			Возврат "Женский";
		КонецЕсли;
	КонецЕсли;
	
	Окончание_1_буква = НРег(Сред(Фамилия, СтрДлина(Фамилия)));
	Окончание_2_буквы = НРег(Сред(Фамилия, СтрДлина(Фамилия) - 1));
	Окончание_3_буквы = НРег(Сред(Фамилия, СтрДлина(Фамилия) - 2));
	окончанияМужскихФамилий=",ов,ев,ий,ин,";
	окончанияЖенскихФамилий=",ова,ева,ина,ая,";
	Если Найти(окончанияМужскихФамилий, "," + Окончание_2_буквы + ",") > 0 Тогда
		Возврат "Мужской";
	ИначеЕсли Найти(окончанияЖенскихФамилий, "," + Окончание_2_буквы + ",") > 0 
		ИЛИ Найти(окончанияЖенскихФамилий, "," + Окончание_3_буквы + ",") > 0 
		Тогда
		Возврат "Женский";
	КонецЕсли;
	
	Если Имя <> "" Тогда
		Окончание_1_буква = НРег(Сред(Имя, СтрДлина(Имя)));
		Если Окончание_1_буква = "а" ИЛИ Окончание_1_буква = "я"  ИЛИ Окончание_1_буква = "е" Тогда
			Возврат "Женский";
		Иначе
			Возврат "Мужской";
		КонецЕсли;
	КонецЕсли;
	
	
	Возврат "";
КонецФункции

// Функция, возвращает массив сжатых картинок.
// 
Функция СжатьКартинки(МассивКартинокДляСжатия) Экспорт
	
	МассивСжатыхКартинок = Новый Массив;
	
	Для Каждого Картинка Из МассивКартинокДляСжатия Цикл
		
		ОбрабатываемаяКартинка = Новый ОбрабатываемаяКартинка(Картинка);
		
		ОбрабатываемаяКартинка.УстановитьФормат(ФорматКартинки.JPEG);
		
		КартинкаШирина = Картинка.Ширина();
		КартинкаВысота = Картинка.Высота();
		
		Если КартинкаШирина > 768 Или КартинкаВысота > 768 Тогда
			Если КартинкаШирина > КартинкаВысота Тогда
				ОбрабатываемаяКартинка.УстановитьРазмер(768, 0);
			Иначе
				ОбрабатываемаяКартинка.УстановитьРазмер(0, 768);
			КонецЕсли;
		КонецЕсли;
		
		Если Картинка.ГлубинаЦвета() = ГлубинаЦвета.БитНаПиксел32 Тогда
			ОбрабатываемаяКартинка.УстановитьГлубинуЦвета(ГлубинаЦвета.БитНаПиксел24);
		КонецЕсли;
	
		МассивСжатыхКартинок.Добавить(ОбрабатываемаяКартинка.ПолучитьКартинку());
		
	КонецЦикла;
	
	Возврат МассивСжатыхКартинок;
	
КонецФункции

// Функция, возвращает кассира.
//
Функция ПолучитьКассира(Касса = Неопределено, Сотрудник = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);     
	
	// Определим, как должно выглядеть представление кассира.
	// 0 - по умолчанию "Фамилия Имя Отчество".	
	ЗначениеПредставленияКассира = ?(ЗначениеЗаполнено(Касса) И ЗначениеЗаполнено(Касса.ПредставлениеКассира), Касса.ПредставлениеКассира, 0);	
	
	Кассир 			 	 = "";
	ДолжностьКассира	 = "";
	ПредставлениеКассира = "";

	// 1. Если в организации заполнен кассир, то берем его	
	Если ЗначениеЗаполнено(Касса) И ЗначениеЗаполнено(Касса.Организация.ФИОКассира) Тогда
		Кассир = Касса.Организация.ФИОКассира;                                           		
		ДолжностьКассира = Касса.Организация.ДолжностьКассира;
		
	ИначеЕсли ЗначениеЗаполнено(Сотрудник) Тогда                                        
		// Если сотрудник служебный, то меняем его на текущего,
		// чтобы в чеке не было "serviceUserApi" и подобных.
		Кассир = ?(Сотрудник.Служебный, ПараметрыСеанса.ТекущийПользователь, Сотрудник);      		
	Иначе
		// Если ничего не передали, берем текущего пользователя.
		Кассир = ПараметрыСеанса.ТекущийПользователь;                                		
	КонецЕсли;             	
	
	// Формирование представления кассира: если сотрудник без нужных данных в представлении будет наименование	
	Если ЗначениеЗаполнено(Кассир) Тогда   
		Если ТипЗнч(Кассир)	= Тип("СправочникСсылка.Пользователи") Тогда
			Кассир = Кассир.Сотрудник;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДолжностьКассира) Тогда
			ДолжностьКассира = Кассир.Должность;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Кассир.Фамилия) И НЕ ЗначениеЗаполнено(Кассир.Имя) И НЕ ЗначениеЗаполнено(Кассир.Отчество) Тогда
			ПредставлениеКассира = Кассир.Наименование;
			
		Иначе
			// Иначе будет формироваться по настройке.
			Если ЗначениеПредставленияКассира = 0 Тогда
				ПредставлениеКассира = СокрЛП(Кассир.Фамилия) + " " + СокрЛП(Кассир.Имя) + " " + СокрЛП(Кассир.Отчество);
				
			ИначеЕсли ЗначениеПредставленияКассира = 1 Тогда                                     
				ПредставлениеКассира = СокрЛП(Кассир.Фамилия) + " " + СокрЛП(Кассир.Имя);		
				
			ИначеЕсли ЗначениеПредставленияКассира = 2 Тогда                   
				Имя = ?(ЗначениеЗаполнено(Кассир.Имя), " " + ЛЕВ(СокрЛП(Кассир.Имя), 1)+".", "");
				Отчество = ?(ЗначениеЗаполнено(Кассир.Отчество), " " +  ЛЕВ(СокрЛП(Кассир.Отчество), 1)+".", "");
				ПредставлениеКассира = СокрЛП(Кассир.Фамилия) + Имя + Отчество;		
				
			ИначеЕсли ЗначениеПредставленияКассира = 3 Тогда     		
				Имя = ?(ЗначениеЗаполнено(Кассир.Имя), " " + ЛЕВ(СокрЛП(Кассир.Имя), 1)+".", "");
				ПредставлениеКассира = СокрЛП(Кассир.Фамилия) + Имя;
				
			ИначеЕсли ЗначениеПредставленияКассира = 4 Тогда
				ПредставлениеКассира = СокрЛП(Кассир.Фамилия);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Передача наименования должности.
	Если ЗначениеЗаполнено(Касса) И Касса.ПередаватьДолжность Тогда					
		НаименованиеДолжности = ?(ЗначениеЗаполнено(ДолжностьКассира), "" + ДолжностьКассира + ": ", "");
		ПредставлениеКассира  = НаименованиеДолжности + ПредставлениеКассира;		
	КонецЕсли;	
	
	// Заполним структуру по умолчанию.
	СтруктураКассира 		   = Новый Структура("Наименование, ИНН",  НСтр("ru='Администратор';en='Administrator'"), "");	
	СтруктураКассира.Наименование    = ПредставлениеКассира;
	СтруктураКассира.ИНН = ?(ЗначениеЗаполнено(Кассир.ИНН), Кассир.ИНН, "");	 
	
	Возврат СтруктураКассира; 
	
КонецФункции

// Процедура добавляет запись в журнал регистрации.
//
Процедура ДобавитьЗаписьВЖурналРегистрации(
	ИмяСобытия,
	Комментарий,	 
	Уровень			 = Неопределено, 
