// Функция, возвращает таблицу значений контрагентов из отчета.
Функция ПолучитьТаблицуЗначенийКонтрагентовИзРезультата()
	
	ТаблицаКонтрагентов = Новый ТаблицаЗначений;
	ТаблицаКонтрагентов.Колонки.Добавить("Контрагент");
	
	Если ЗначениеЗаполнено(ОтчетДанныеРасшифровки) Тогда
		ДанныеРасшифровкиХранилища = ПолучитьИзВременногоХранилища(ОтчетДанныеРасшифровки);
		Для Каждого ЭлементДанныеРасшифровкиХранилища Из ДанныеРасшифровкиХранилища.Элементы Цикл
			Если ТипЗнч(ЭлементДанныеРасшифровкиХранилища) = Тип("ЭлементРасшифровкиКомпоновкиДанныхПоля") Тогда
				Для Каждого ЭлементПоля Из ЭлементДанныеРасшифровкиХранилища.ПолучитьПоля() Цикл
					
					Если ТипЗнч(ЭлементПоля.Значение) = Тип("СправочникСсылка.Контрагенты")
						И ЭлементПоля.Значение.ЭтоГруппа = Ложь 
						И ТаблицаКонтрагентов.Найти(ЭлементПоля.Значение) = Неопределено Тогда
						
						НоваяСтрока = ТаблицаКонтрагентов.Добавить();
						НоваяСтрока.Контрагент = ЭлементПоля.Значение;
						
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	Возврат ТаблицаКонтрагентов;
	
КонецФункции

