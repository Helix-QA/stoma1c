#Область СлужебныеПроцедурыИФункции

Функция СгенерироватьКодМедКарты(Знач ДлинаНомера, Префикс, Суффикс) Экспорт
	
	Если Не ЗначениеЗаполнено(ДлинаНомера) Тогда
		ДлинаНомера = 12;
	КонецЕсли;
	
	МаксимальныйКод = Формат(999999999999999, "ЧЦ=" + (ДлинаНомера - СтрДлина(Префикс + Суффикс)) + "; ЧВН=; ЧГ=");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Максимум(МедицинскиеКарты.Код) КАК Код
	|ИЗ
	|	Справочник.МедицинскиеКарты КАК МедицинскиеКарты
	|ГДЕ
	|	МедицинскиеКарты.Код ПОДОБНО """ + Префикс + СтрЗаменить(МаксимальныйКод, "9", "[0-9]") + Суффикс + """";
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	ОписаниеТипаЧисла = Новый ОписаниеТипов("Число");
	Код = ОписаниеТипаЧисла.ПривестиЗначение(Сред(Выборка.Код, СтрДлина(Префикс) + 1, СтрДлина(Выборка.Код) - СтрДлина(Префикс + Суффикс))) + 1;
	
	Штрихкод = Префикс + Формат(Код, "ЧЦ=" + (ДлинаНомера - СтрДлина(Префикс + Суффикс)) + "; ЧВН=; ЧГ=") + Суффикс;
	
	Возврат Штрихкод;
	
КонецФункции

Функция НомерМедКартСуществует(Код, Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МедицинскиеКарты.Код КАК Код
	|ИЗ
	|	Справочник.МедицинскиеКарты КАК МедицинскиеКарты
	|ГДЕ
	|	МедицинскиеКарты.Ссылка <> &Ссылка
	|	И МедицинскиеКарты.Код ПОДОБНО &Код";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Код", "%" + Код + "%");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Выборка.Код = Код Тогда
			Возврат Истина;
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат Ложь;
	
КонецФункции

Функция ВернутьМестоположениеМедицинскойКарты(МедицинскаяКарта, Дата = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МестонахождениеМедицинскихКартСрезПоследних.Местоположение
	|ИЗ
	|	РегистрСведений.МестонахождениеМедицинскихКарт.СрезПоследних(&Дата, МедицинскаяКарта = &МедицинскаяКарта) КАК МестонахождениеМедицинскихКартСрезПоследних";
	Запрос.УстановитьПараметр("МедицинскаяКарта", МедицинскаяКарта);
	Запрос.УстановитьПараметр("Дата", ?(Дата = Неопределено, ТекущаяДата(), Дата));
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Местоположение;
	Иначе
		Возврат Справочники.Местоположения.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Процедура УстановитьМестоположениеМедицинскойКарты(МедицинскаяКарта, Местоположение, УстанавливатьПринудительно = Ложь) Экспорт
	
	Если УстанавливатьПринудительно = Ложь И Местоположение = ВернутьМестоположениеМедицинскойКарты(МедицинскаяКарта) Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.МестонахождениеМедицинскихКарт.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.МедицинскаяКарта = МедицинскаяКарта;
	МенеджерЗаписи.Местоположение = Местоположение;
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

Функция ПолучитьМедКартыКлиента(Контрагент) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МедицинскиеКарты.Ссылка
	|ИЗ
	|	Справочник.МедицинскиеКарты КАК МедицинскиеКарты
	|ГДЕ
	|	МедицинскиеКарты.ВладелецКарты = &ВладелецКарты
	|	И МедицинскиеКарты.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("ВладелецКарты", Контрагент);			   
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции


