// Вернуть описание скидки
//
Функция ВернутьОписаниеСкидки(Скидка)
	Описание = новый Структура;
	Описание.Вставить("ТипСкидки"     ,?(Скидка.ТипПолучателя = 2,"Персональная","Общая"));
	Описание.Вставить("ТипПолучателя" ,Скидка.ТипПолучателя);
	Описание.Вставить("Скидка"        ,Скидка);
	Описание.Вставить("РазмерСкидки"  ,Строка(Скидка.ЗначениеСкидкиНаценки) + "%");
	ОписаниеСкидки = РегистрыСведений.ДействиеСкидокНаценок.ПолучитьПарамтерыДействияСкидки(Скидка,ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
    Описание.Вставить("ДатаНачала"    ,?(ОписаниеСкидки.Количество() > 0,ОписаниеСкидки[0].ДатаНачала,Неопределено));
    Описание.Вставить("ДатаОкончания" ,?(ОписаниеСкидки.Количество() > 0,ОписаниеСкидки[0].ДатаОкончания,Неопределено));
	Возврат Описание;
КонецФункции

