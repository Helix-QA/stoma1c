// Процедура, выполняет установку отбора.
//
Процедура УстановитьОтбор()
	
	ОтборИнвентаризации.Настройки.Отбор.Элементы.Очистить();
	Если СписокНоменклатуры.Количество() > 0 Тогда
		ЭлементОтбора = ОтборИнвентаризации.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Номенклатура");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение = СписокНоменклатуры;
		ЭлементОтбора.Использование  = Истина;	
	КонецЕсли;
	Если СписокГруппНоменклатуры.Количество() > 0 Тогда
		ЭлементОтбора = ОтборИнвентаризации.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Номенклатура.Родитель");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСпискеПоИерархии;
		ЭлементОтбора.ПравоеЗначение = СписокГруппНоменклатуры;
		ЭлементОтбора.Использование  = Истина;	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет формирование заголовков.
//
Функция СформироватьЗаголовокОтбораИзСписка(СписокЭлементов)
	
	ЗаголовокОтбораСтрока = "";
	Для каждого ЭлементСписка Из СписокЭлементов Цикл
		ЗаголовокОтбораСтрока = ЗаголовокОтбораСтрока + ?(ЗаголовокОтбораСтрока = "","","; ") + ЭлементСписка.Представление;		
	КонецЦикла;
	
	Если ЗаголовокОтбораСтрока = "" Тогда
		ЗаголовокОтбораСтрока = НСтр("ru='Отбор не установлен';en='Selection not installed'");
	КонецЕсли;
	
	Возврат ЗаголовокОтбораСтрока;
	
КонецФункции 

