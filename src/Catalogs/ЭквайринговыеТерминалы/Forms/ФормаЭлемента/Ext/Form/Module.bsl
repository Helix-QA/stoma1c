&НаКлиенте
// Процедура, устанавливает видимость оплаты по ссылке.
//
Процедура УстановитьВидимостьОплатыПоСсылке(ПриСоздании = Ложь)
	
	Для Каждого КнопкиЗапретаРедактирования Из Элементы.ГруппаДляКнопкиЗапрета.ПодчиненныеЭлементы Цикл
		КнопкиЗапретаРедактирования.Отображение = ОтображениеКнопки.КартинкаИТекст;
		КнопкиЗапретаРедактирования.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
		КнопкиЗапретаРедактирования.Картинка = БиблиотекаКартинок.РедактироватьВыделенные;
		Прервать;
	КонецЦикла;
	
	ЭтоАльфаБанкСБП	 	 = (Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПАльфаБанк"));
	ЭтоТинькоффСБП	  	 = (Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПТинькофф"));
	ЭтоРайффайзенБанкСБП = (Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПРайффайзенБанк"));
	ЭтоСберБанкСБП       = (Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПСбербанк"));
	ЭтоСбербанкПлатиQR	 = (Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СбербанкПлатиQR"));
	ЭтоСБПСДМ	  	 	 = (Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПСДМ"));
	
	Элементы.Код.Видимость						= ОтображниеКода;
	Элементы.Код.ПоложениеЗаголовка 			= ?(ОтображниеКода, ПоложениеЗаголовкаЭлементаФормы.Авто, ПоложениеЗаголовкаЭлементаФормы.Нет);
	Элементы.ВнешнееОборудование.Доступность	= Не Объект.ИспользоватьБезПодключенияОборудования;
	Элементы.UrlRedirect.ТолькоПросмотр			= ЭтоРайффайзенБанкСБП ИЛИ ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ ИЛИ ЭтоАльфаБанкСБП ИЛИ ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR;
	Элементы.ТестовыйРежим.Видимость 				  = Не ЭтоСберБанкСБП И Не ЭтоСбербанкПлатиQR;
	Элементы.ТипБанка.АвтоМаксимальнаяШирина          = Не Элементы.ТестовыйРежим.Видимость;
	Элементы.ИспользоватьОплатуПоСсылке.Видимость	  = Не ЭтоРайффайзенБанкСБП И Не ЭтоТинькоффСБП И Не ЭтоСБПСДМ И Не ЭтоАльфаБанкСБП И Не ЭтоСберБанкСБП И Не ЭтоСбербанкПлатиQR;   
	Элементы.URLБанка.Видимость						  = Не ЭтоРайффайзенБанкСБП И Не ЭтоТинькоффСБП И Не ЭтоСБПСДМ И Не ЭтоАльфаБанкСБП;   
	Элементы.ГруппаСБПСберБанк.Видимость			  = ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR;
    Элементы.IDQR.Видимость							  = ЭтоСбербанкПлатиQR;
	Элементы.ВремяЖизниСсылкиНаОплату.ТолькоПросмотр  = ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR;
	
	Элементы.ПарольБанка.Заголовок      		= ?(ЭтоРайффайзенБанкСБП, "Секретный ключ", "Пароль");
	Элементы.ПарольБанка.ПодсказкаВвода 		= ?(ЭтоРайффайзенБанкСБП, "Секретный ключ", "Пароль");
    Элементы.ЛогинБанка.Заголовок				= ?(ЭтоРайффайзенБанкСБП, "Мерчант", "Логин");    
	Элементы.СекретныйКлючТинькофф.Заголовок	= ?(ЭтоСБПСДМ, "Пароль ключа", Элементы.СекретныйКлючТинькофф.Заголовок);
	
	Элементы.ГруппаЛогинПарольБанка.Видимость = ЭтоРайффайзенБанкСБП ИЛИ ЭтоАльфаБанкСБП;
	Элементы.ГруппаКлючиТинькофф.Видимость	  = ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ;
	Элементы.ГруппаQRЭквайринга.Видимость	  = ЭтоРайффайзенБанкСБП ИЛИ ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ ИЛИ ЭтоАльфаБанкСБП ИЛИ ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR;
    Элементы.ЗакрытыйКлюч.Видимость			  = ЭтоАльфаБанкСБП;
	Элементы.ТестоваяСсылкаНаОплату.Видимость = ЭтоТинькоффСБП; 
	
	Если ПриСоздании = Ложь Тогда
		ЭтотОбъект.UrlRedirect				= ?(ЭтоРайффайзенБанкСБП ИЛИ ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ ИЛИ ЭтоАльфаБанкСБП ИЛИ ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR, ПолучитьАдресПубликацииСБП(), ЭтотОбъект.UrlRedirect);
		ЭтотОбъект.ВремяЖизниСсылкиНаОплату = ?(ЭтоРайффайзенБанкСБП ИЛИ ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ ИЛИ ЭтоАльфаБанкСБП ИЛИ ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR, 72, ЭтотОбъект.ВремяЖизниСсылкиНаОплату);	
		ЭтотОбъект.ТестовыйРежим			= ?(ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ ИЛИ ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR, Ложь, ЭтотОбъект.ТестовыйРежим);
		Объект.ИспользоватьОплатуПоСсылке	= ?(ЭтоРайффайзенБанкСБП ИЛИ ЭтоТинькоффСБП ИЛИ ЭтоСБПСДМ ИЛИ ЭтоАльфаБанкСБП ИЛИ ЭтоСберБанкСБП ИЛИ ЭтоСбербанкПлатиQR, Ложь, Объект.ИспользоватьОплатуПоСсылке);
	КонецЕсли;
	
	ТипЭквайрингаПриИзменении(ЭтаФорма, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "РазрешитьРедактированиеРеквизитовОбъектаЗавершение"
//
Процедура РазрешитьРедактированиеРеквизитовОбъектаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Массив") И Результат.Количество() > 0 Тогда
		ЗапретРедактированияРеквизитовОбъектовКлиент.УстановитьДоступностьЭлементовФормы(ЭтаФорма, Результат);
