// Функция, возвращает свободные интервалы сотрудников.
// 
Функция ПолучитьСвободныеИнтервалы(
		СтруктурнаяЕдиница, 
		МассивСотрудников, 
		ДлительностьЗаписи = Неопределено, 
		НачалоПериода = Неопределено, 
		КонецПериода = Неопределено, 
		ПолучитьИнтервалыПослеТекущейДаты = Ложь, 
		ВнешняяСистема = Неопределено)

		НачалоПериодаЗапрета	= Неопределено;	
		КонецПериодаЗапрета		= Неопределено;
		
		Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
			
			ПараметрыВС = ВнешняяСистема.Параметры.Получить(); 	
			
			Если ПараметрыВС <> Неопределено И ПараметрыВС.Свойство("ЗапретОнлайнЗаписиС") И ПараметрыВС.Свойство("ЗапретОнлайнЗаписиПо")
				И ЗначениеЗаполнено(ПараметрыВС.ЗапретОнлайнЗаписиС) И ЗначениеЗаполнено(ПараметрыВС.ЗапретОнлайнЗаписиПо) Тогда
				
				НачалоПериодаЗапрета	= ПараметрыВС.ЗапретОнлайнЗаписиС; 
				КонецПериодаЗапрета 	= ПараметрыВС.ЗапретОнлайнЗаписиПо;
				
			КонецЕсли;
			
		КонецЕсли;
	
	Возврат РегистрыСведений.СвободныеИнтервалыСотрудников.ПолучитьСвободныеИнтервалы(
	СтруктурнаяЕдиница, 
	МассивСотрудников, 
	ДлительностьЗаписи, 
	НачалоПериода, 
	КонецПериода,, 
	ПолучитьИнтервалыПослеТекущейДаты,
	НачалоПериодаЗапрета,
	КонецПериодаЗапрета);
	
КонецФункции

// Функция, возвращает максимальную длительность, доступную для записи.
//
Функция МаксимальнаяДлительностьДоступнаяДляЗаписи(Номенклатура, ВремяНачала, Длительность, ОграниченияПоВремени = "")
	
	ДеньНедели 		   		 	= ДеньНедели(ВремяНачала);
	ЭтоПраздничныйДень 		 	= ОбщегоНазначения.ЭтоПраздничныйДень(ВремяНачала);
	ВремяОкончания 	   		 	= ВремяНачала + Длительность * 60;
	МаксимальнаяДлительность 	= 0;
	
	Возврат МаксимальнаяДлительность;
	
КонецФункции

// Функция, возвращает значение реквизита.
//
Функция ПолучитьЗначениеРеквизита(Ссылка, ИмяРеквизита)
	
	// Неопбходимо для оптимизации. Эта функция работает быстрее, чем получение значения через точку.
	Возврат ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Ссылка, ИмяРеквизита);
	
КонецФункции

// Функция, проверяет переданное занятие.
//
Функция ПолучитьМассивСсылокПоИдентификаторам(Идентификаторы, СтруктураОшибки, ЭтоСправочник = Истина, ИмяОбъекта, КодОшибки, ОбязательныйПараметр = Ложь)
	
	МассивИдентификаторов = ПреобразоватьКМассивуВходноеЗначение(Идентификаторы);
	МассивСсылок 		  = Новый Массив;
	
	Если МассивИдентификаторов.Количество() = 0 И ОбязательныйПараметр Тогда
		СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(КодОшибки);
		Возврат Неопределено;
	КонецЕсли;
	
	Для Каждого Идентификатор Из МассивИдентификаторов Цикл
		Ссылка = ПолучитьСсылкуПоИдентификатору(Идентификатор, СтруктураОшибки, ЭтоСправочник, ИмяОбъекта, КодОшибки, ОбязательныйПараметр);
		Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
			Возврат Неопределено;
		КонецЕсли;
		МассивСсылок.Добавить(Ссылка);
	КонецЦикла;
	
	Возврат МассивСсылок;
	
КонецФункции

// Функция - Преобразовать к массиву входное значение
//
// Параметры:
//  Значения - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПреобразоватьКМассивуВходноеЗначение(Значения)
	
	МассивЗначений = Новый Массив;
	
	Если ЗначениеЗаполнено(Значения) Тогда
		Если ТипЗнч(Значения) = Тип("Массив") Тогда
			МассивЗначений = Значения;
		Иначе
			МассивЗначений.Добавить(Значения);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивЗначений;
	
КонецФункции

// Функция - Получить начало периода
//
// Параметры:
//  start_date				 - 	 - 
//  СтруктураОшибки			 - 	 - 
//  ОбязательныйПараметр	 - 	 - 
//  ИзменятьНачалоПериода	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНачалоПериода(start_date, СтруктураОшибки, ОбязательныйПараметр = Ложь, ИзменятьНачалоПериода = Ложь)
	
	НачалоПериода = Неопределено;
	
	Если ЗначениеЗаполнено(start_date) Тогда
		Если ТипЗнч(start_date) = Тип("Строка") Тогда 
			НачалоПериода = ПолучитьДату(start_date);
		ИначеЕсли ТипЗнч(start_date) = Тип("Дата") Тогда 
			НачалоПериода = start_date;
		Иначе 
			НачалоПериода = Неопределено;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(НачалоПериода) Тогда
			СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(1054);
		КонецЕсли;
		
		Если ИзменятьНачалоПериода Тогда
			
			ВремяОграниченияНачалаОнлайнЗаписи = Константы.ВремяОграниченияНачалаОнлайнЗаписи.Получить();
			
			Если ЗначениеЗаполнено(ВремяОграниченияНачалаОнлайнЗаписи) Тогда
				
				ВремяОграниченияНачалаОнлайнЗаписи = ВремяОграниченияНачалаОнлайнЗаписи * 60;
				ОнлайнЗаписьВозможнаНа       	   = ТекущаяДатаСеанса() + ВремяОграниченияНачалаОнлайнЗаписи;
				
				Если НачалоМинуты(НачалоПериода) < НачалоМинуты(ОнлайнЗаписьВозможнаНа) Тогда
					НачалоПериода = ОнлайнЗаписьВозможнаНа;
				КонецЕсли;
				
			КонецЕсли;
		
			ТекущаяДатаСеанса = ТекущаяДатаСеанса();
			Если НачалоПериода < ТекущаяДатаСеанса Тогда
				НачалоПериода = ТекущаяДатаСеанса;
			ИначеЕсли НачалоДня(НачалоПериода) > НачалоДня(ТекущаяДатаСеанса) Тогда
				НачалоПериода = НачалоДня(НачалоПериода);
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ОбязательныйПараметр Тогда
		СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(1052);
	КонецЕсли;
	
	Возврат НачалоПериода
	
КонецФункции

// Функция, возвращает интервалы, доступные для записи.
//
Функция ПолучитьИнтервалыДоступныеДляЗаписиПоУслуге(Номенклатура, ВремяНачала, Длительность)
	
	ДеньНедели 		   = ДеньНедели(ВремяНачала);
	ЭтоПраздничныйДень = ОбщегоНазначения.ЭтоПраздничныйДень(ВремяНачала);
	ВремяОкончания 	   = ВремяНачала + Длительность * 60;
	МассивИнтервалов   = Новый Массив;
	
	МассивИнтервалов.Добавить(Новый Структура("ДатаВремяНачала, Длительность", ВремяНачала, Длительность));
	Возврат МассивИнтервалов;
		
КонецФункции

