КонецПроцедуры

// Функция, формирует блок день рождения клиента.
//
Функция СформироватьБлокДеньРожденияКлиента(ДатаРожденияКлиента)
		
	ШаблонДеньРождения = 
	"<div class='wr-message'>                                               
	|    <div class='message' style= '{СтильHtmlГраницаБлока}'>
	|		<div class='inner-message cake' style= '--top:-4px;'>
    |           <div class='text-message' style='color: #000'>{Представление}</div>
    |       </div> 
    |    </div>
	|</div>";
	
	Если ДатаРожденияКлиента = НачалоДня(ТекущаяДатаСеанса()) Тогда		
		ПредставлениеДняРождения = Нстр("ru='Сегодня у пациента день рождения!';en='Today client day of birth!'");
	Иначе
		ПредставлениеДняРождения = Формат(ДатаРожденияКлиента, "ДФ='d MMMM'") + Нстр("ru=', День рождения пациента!';en=', Day of birth client!'");			
	КонецЕсли;
	
	СтильHtmlГраницаБлока = "";
	
	Если День(ДатаРожденияКлиента) = День(ТекущаяДатаСеанса()) Тогда		
		СтильHtmlГраницаБлока 	= "border-color:#0cac09;";
	Иначе	
		СтильHtmlГраницаБлока 	= "border-color:#ff9b00;";		
	КонецЕсли;
	
	ШаблонДеньРождения = СтрЗаменить(ШаблонДеньРождения, "{Представление}"			, ПредставлениеДняРождения);
	ШаблонДеньРождения = СтрЗаменить(ШаблонДеньРождения, "{СтильHtmlГраницаБлока}"	, СтильHtmlГраницаБлока);
	
	Возврат ШаблонДеньРождения;
	
КонецФункции

