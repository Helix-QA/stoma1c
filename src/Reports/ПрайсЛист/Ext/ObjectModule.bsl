
#Область СлужебныйПрограммныйИнтерфейс

Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	ПараметрыОтчета = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы;
	Для Каждого ПараметрОтчета Из ПараметрыОтчета Цикл
		Если ТипЗнч(ПараметрОтчета) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") И ПараметрОтчета.Параметр = Новый ПараметрКомпоновкиДанных("ВыводитьАртикул") Тогда
			Для Каждого ТаблицаКД Из КомпоновщикНастроек.Настройки.Структура Цикл
				Если ТаблицаКД.Имя <> "Заголовок" Тогда
					Для Каждого ЭлТаблицы Из ТаблицаКД.Строки Цикл	
						Для Каждого Элемент Из ЭлТаблицы.Выбор.Элементы Цикл
							Если Элемент.Поле = Новый ПолеКомпоновкиДанных("Артикул") Тогда
								Если НЕ ПараметрОтчета.Значение Тогда
									Элемент.Использование = Ложь;
								Иначе
									Элемент.Использование = Истина;
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;		
					КонецЦикла;	
				Иначе
					Для Каждого ЭлементПД Из КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы Цикл
					    Если ЭлементПД.Параметр = Новый ПараметрКомпоновкиДанных("ВыводитьЗаголовок") Тогда
							ТаблицаКД.Использование = Не ЭлементПД.Использование;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли ТипЗнч(ПараметрОтчета) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") И ПараметрОтчета.Параметр = Новый ПараметрКомпоновкиДанных("ВыводитьДлительность") Тогда
			Для Каждого ТаблицаКД Из КомпоновщикНастроек.Настройки.Структура Цикл
				Если ТаблицаКД.Имя <> "Заголовок" Тогда
					Для Каждого ЭлТаблицы Из ТаблицаКД.Строки Цикл	
						Для Каждого Элемент Из ЭлТаблицы.Выбор.Элементы Цикл
							Если Элемент.Поле = Новый ПолеКомпоновкиДанных("НормаВремени") Тогда
								Если НЕ ПараметрОтчета.Значение Тогда
									Элемент.Использование = Ложь;
								Иначе
									Элемент.Использование = Истина;
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;		
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли ТипЗнч(ПараметрОтчета) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") И ПараметрОтчета.Параметр = Новый ПараметрКомпоновкиДанных("ВыводитьУпаковку") Тогда
			Для Каждого Элемент Из КомпоновщикНастроек.Настройки.Выбор.Элементы Цикл
				Если Элемент.Заголовок = "Упак." Тогда
					Элемент.Использование = ПараметрОтчета.Значение; 
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	ПараметрыОтчета = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы;
	Тек = ПараметрыОтчета.Найти("ВыводитьАртикул");
	Если Тек <> Неопределено Тогда
		Тек.Значение = Ложь;	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
