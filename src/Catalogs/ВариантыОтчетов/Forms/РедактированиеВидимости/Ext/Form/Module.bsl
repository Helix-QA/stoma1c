					Если СтрокаРедактирование.ПользовательРоль = СтрокаПользователя.Пользователь Тогда
						РедактированиеПроизводилось = Истина;
						Если СтрокаРедактирование.Доступность Тогда 
							ДоступностьРедактирование.Удалить(СтрокаРедактирование);
							РольПользователей = СтрокаПользователя.Пользователь;							
						КонецЕсли;	
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				Если НЕ РедактированиеПроизводилось Тогда 
					СтрокаРедактирования = ДоступностьРедактирование.Добавить();
					СтрокаРедактирования.ПользовательРоль 	= СтрокаПользователя.Пользователь;
					СтрокаРедактирования.Представление 		= СтрокаПользователя.Представление;
					СтрокаРедактирования.Доступность 		= Ложь;
					РольПользователей 						= СтрокаПользователя.Пользователь;					
				КонецЕсли;	
				СтрокаПользователя.Видимость 				= Ложь;
				УстановитьФлагиПользователямПоРоли(РольПользователей, Ложь);				
			КонецЕсли;	
