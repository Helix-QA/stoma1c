	
#Область СлужебныйПрограммныйИнтерфейс

// Процедура, выполняет формирование отчета по информации клиента
//
Процедура ВывестиПечатьФормы39(ТабДок, НачалоПериода, КонецПериода) Экспорт
	ТабДок.Очистить();
	Макет = Отчеты.ПечатьФормы39.ПолучитьМакет("Макет");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПродажиОбороты.Сотрудник КАК Сотрудник,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ПродажиОбороты.Контрагент.ДатаРожденияКлиента > ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ПродажиОбороты.ДокументПродажи.Дата, ГОД, -15), ДЕНЬ, 1)
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ДетиДо15Лет,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ПродажиОбороты.Контрагент.ДатаРожденияКлиента > ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ПродажиОбороты.ДокументПродажи.Дата, ГОД, -18), ДЕНЬ, 1)
		|					И ПродажиОбороты.Контрагент.ДатаРожденияКлиента < ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(ПродажиОбороты.ДокументПродажи.Дата, ГОД, -15), ДЕНЬ, 1)
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ПодросткиДо18Лет,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.ДокументПродажи.Ссылка) КАК Посещения,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Контрагент) КАК ВсегоПациентов,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Номенклатура) КАК ПроизведеноОпераций
		|ПОМЕСТИТЬ Таб
		|ИЗ
		|	РегистрНакопления.Продажи.Обороты(&НачалоПериода, &КонецПериода, Секунда, ) КАК ПродажиОбороты
		|
		|СГРУППИРОВАТЬ ПО
		|	ПродажиОбороты.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ  РАЗРЕШЕННЫЕ
		|	Таб.Сотрудник КАК Сотрудник,
		|	Таб.ДетиДо15Лет КАК ДетиДо15Лет,
		|	Таб.ПодросткиДо18Лет КАК ПодросткиДо18Лет,
		|	Таб.Посещения КАК Посещения,
		|	Таб.ВсегоПациентов КАК ВсегоПациентов,
		|	ВЫБОР
		|		КОГДА Таб.Посещения = Таб.ВсегоПациентов
		|			ТОГДА 1
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ВылеченоВ1Посещение,
		|	Таб.ДетиДо15Лет + Таб.ПодросткиДо18Лет КАК ВсегоПервичныхБольных,
		|	Таб.ПроизведеноОпераций КАК ПроизведеноОпераций,
		|	СУММА(РабочееВремяСотрудниковОбороты.ДнейОборот) КАК ДнейОборот
		|ИЗ
		|	Таб КАК Таб
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РабочееВремяСотрудников.Обороты(
		|				&НачалоПериода,
		|				&КонецПериода,
		|				День,
		|				Сотрудник В
		|					(ВЫБРАТЬ
		|						Таб.Сотрудник КАК Сотрудник
		|					ИЗ
		|						Таб КАК Таб)
		|				И Врач = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК РабочееВремяСотрудниковОбороты
		|		ПО Таб.Сотрудник = РабочееВремяСотрудниковОбороты.Сотрудник
		|
		|СГРУППИРОВАТЬ ПО
		|	Таб.Сотрудник,
		|	Таб.ДетиДо15Лет,
		|	Таб.ПодросткиДо18Лет,
		|	Таб.Посещения,
		|	Таб.ВсегоПациентов,
		|	Таб.ПроизведеноОпераций
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудник
		|ИТОГИ
		|	СУММА(ДетиДо15Лет),
		|	СУММА(ПодросткиДо18Лет),
		|	СУММА(Посещения),
		|	СУММА(ВсегоПациентов),
		|	СУММА(ВылеченоВ1Посещение),
		|	СУММА(ВсегоПервичныхБольных),
		|	СУММА(ПроизведеноОпераций),
		|	СУММА(ДнейОборот)
		|ПО
		|	ОБЩИЕ,
		|	Сотрудник";
   	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Результат = Запрос.Выполнить();
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
   	ОбластьЗаголовок.Параметры.НачалоПериода = Формат(НачалоПериода, "ДФ=""дд ММММ гггг 'г.'""");
	ОбластьЗаголовок.Параметры.КонецПериода = Формат(КонецПериода, "ДФ=""дд ММММ гггг 'г.'""");
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьСотрудник = Макет.ПолучитьОбласть("Врач");
	ОбластьДетальныхЗаписей = Макет.ПолучитьОбласть("Пациент");
    ОбластьОбщийИтог =  Макет.ПолучитьОбласть("Итог");
	ОбластьПодвал =  Макет.ПолучитьОбласть("Подвал");
	
	ТабДок.Очистить();
	ТабДок.Вывести(ОбластьЗаголовок);
	ТабДок.Вывести(ОбластьШапкаТаблицы);
	ТабДок.НачатьАвтогруппировкуСтрок();

	ВыборкаОбщийИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаОбщийИтог.Следующий();		// Общий итог
	ОбластьОбщийИтог.Параметры.Заполнить(ВыборкаОбщийИтог);
	
	ВыборкаСотрудник = ВыборкаОбщийИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
    Пока ВыборкаСотрудник.Следующий() Цикл
		ОбластьСотрудник.Параметры.Заполнить(ВыборкаСотрудник);
		ТабДок.Вывести(ОбластьСотрудник, ВыборкаСотрудник.Уровень());
 	КонецЦикла;
	ТабДок.Вывести(ОбластьОбщийИтог, ВыборкаОбщийИтог.Уровень());
	ТабДок.Вывести(ОбластьПодвал);
 КонецПроцедуры
 
 #КонецОбласти 
 
