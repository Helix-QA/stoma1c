// Процедура, обновляет параметры ДатаНачала и ДатаКонца по кассовой смене.
//
Процедура ОбновитьПериодОтчета(ТипОбновления, КассоваяСмена = Неопределено)
	
	ИдентификаторПользовательскойНастройки = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти("Период").ИдентификаторПользовательскойНастройки;
	Если ЗначениеЗаполнено(ИдентификаторПользовательскойНастройки) Тогда
		ПараметрПериод = Отчет.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(ИдентификаторПользовательскойНастройки);
	Иначе
		ПараметрПериод = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти("Период");
	КонецЕсли;
	
	ПараметрНачалоПериода = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти("НачалоПериода");
	ПараметрКонецПериода  = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти("КонецПериода");
	
	Если ТипОбновления = "ИзКассовойСмены" Тогда
		
		НачалоКассовойСмены    = ?(ЗначениеЗаполнено(КассоваяСмена), КассоваяСмена.НачалоКассовойСмены, Дата(1,1,1));
		ОкончаниеКассовойСмены = ?(ЗначениеЗаполнено(КассоваяСмена) И ЗначениеЗаполнено(КассоваяСмена.ОкончаниеКассовойСмены), КассоваяСмена.ОкончаниеКассовойСмены, Дата(3999,12,31));
		
		ПараметрПериод.Значение.Вариант 	  = ВариантСтандартногоПериода.ПроизвольныйПериод;
		ПараметрПериод.Значение.ДатаНачала 	  = НачалоКассовойСмены;
		ПараметрПериод.Значение.ДатаОкончания = ОкончаниеКассовойСмены;
		ПараметрПериод.Значение               = Новый СтандартныйПериод(НачалоКассовойСмены, ОкончаниеКассовойСмены);		
		ПараметрНачалоПериода.Значение        = НачалоКассовойСмены;
		ПараметрКонецПериода.Значение         = ОкончаниеКассовойСмены;
		
		Период = Новый СтандартныйПериод(НачалоКассовойСмены, ОкончаниеКассовойСмены);
		
	Иначе
		
		НачалоКассовойСмены            = ПараметрПериод.Значение.ДатаНачала;
		ОкончаниеКассовойСмены         = ПараметрПериод.Значение.ДатаОкончания;

		ПараметрНачалоПериода.Значение = НачалоКассовойСмены;
		ПараметрКонецПериода.Значение  = ОкончаниеКассовойСмены;
		ПараметрПериод.Значение        = Новый СтандартныйПериод(НачалоКассовойСмены, ОкончаниеКассовойСмены);
		ПараметрПериод.Значение.Вариант 	  = ВариантСтандартногоПериода.ПроизвольныйПериод;
		ПараметрПериод.Значение.ДатаНачала 	  = НачалоКассовойСмены;
		ПараметрПериод.Значение.ДатаОкончания = ОкончаниеКассовойСмены;
	КонецЕсли;

	ПараметрПериод.Использование = Истина;
	
КонецПроцедуры

