	Если Результат.ВыполненоУспешно = Истина Тогда
		
		Если Результат.ФорматНомераВерен = Ложь Тогда
			
			// ПоказатьСообщениеНаФорму("Регистрационный номер указан не верно. Номер должен быть меньше 13 цифр и начинаться на 10 или 12");
			
		Иначе
			
			ПоказатьСообщениеНаФорму("");
			
		КонецЕсли;
		
	Иначе
		
		ПоказатьСообщениеНаФорму(Результат.ОписаниеОшибки);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
