// Процедура, обработчик команды "ПодборРасходов".
//
Процедура ПодборРасходов(Команда)
	
	ИмяТабличнойЧасти  = "Расходы";
	ЕстьПартии		   = Ложь;
	ЕстьЦена		   = Истина;
		
	ПараметрыПодбора = Новый Структура;
	
