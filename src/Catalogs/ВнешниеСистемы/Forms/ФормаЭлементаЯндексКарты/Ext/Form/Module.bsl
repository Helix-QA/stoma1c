#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		Параметры.Свойство("ТипВнешнейСистемы", Объект.ТипВнешнейСистемы);
		Объект.КлючПриложения = Новый УникальныйИдентификатор();
		СформироватьНаименование(); 
		Элементы.ГруппаУдалить.Видимость 		 = Ложь;
	Иначе
		ПараметрыВнешнейСистемы = Объект.Ссылка.Параметры.Получить();		
	КонецЕсли;
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	Объект.СтруктурнаяЕдиница = СтруктурнаяЕдиница; 
	СтруктурнаяЕдиницаПриИзмененииНаСервере();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

// Процедура, формирует наименование.
//
Процедура СформироватьНаименование() 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВнешниеСистемы.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы = &ТипВнешнейСистемы");
	
	Запрос.УстановитьПараметр("ТипВнешнейСистемы", Объект.ТипВнешнейСистемы);
	
	ТаблицаВнешнихСистем = Запрос.Выполнить().Выгрузить();
	
	Объект.Наименование = Строка(Объект.ТипВнешнейСистемы) + ?(ТаблицаВнешнихСистем.Количество() > 1, "-" + Строка(ТаблицаВнешнихСистем.Количество()), ""); 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СоздатьКлюч" 
//
Процедура СоздатьКлюч(Команда)
	
	Объект.КлючПриложения = Строка(Новый УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
// Процедура - проверяет ответ
//
Процедура ЗаписатьОбъектОтвет(РезультатВопроса, Параметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Результат = ЭтаФорма.Записать();
		Если Не Результат Тогда
			Возврат;
		КонецЕсли;				
	Иначе
		СтруктурнаяЕдиница = Объект.СтруктурнаяЕдиница;
		Возврат;
	КонецЕсли;
	СтруктурнаяЕдиницаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
// Процедура - структерная единица при изменении на сервере
//
Процедура СтруктурнаяЕдиницаПриИзмененииНаСервере()
	
	Элементы.КомандыДобавленияКонтактнойИнформации.Видимость     = Истина;
	Элементы.КомандаПодобратьИдентификаторРубрики.Видимость      = Истина;
	Элементы.ГруппаНастройкиОнлайнЗаписиПравваяКолонка.Видимость = Истина;
	
	СЕ = СтруктурнаяЕдиница.ПолучитьОбъект();
	// Контактная информация
	УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервере(ЭтотОбъект, СЕ);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
	ИспользоватьЯндексКарты = СЕ.ИспользоватьЯндексКарты;
	
	Если ИспользоватьЯндексКарты Тогда
		ЯндексИдентификаторРубрики = СЕ.НастройкиЯндексКарты.Получить().ИдентификаторРубрики;
		Элементы.ГруппаЯндексИдентификаторРубрики.Видимость = Истина;
	Иначе
		Элементы.ГруппаЯндексИдентификаторРубрики.Видимость = Ложь;
	КонецЕсли;
	
	УдалитьДинамическиеЭлементы(Элементы.ГруппаРубрики, Элементы.ГруппаРубрика_Шаблон);
	ПостроитьДинамическиеЭлементы();
	ОтобразитьКартинки();
	
КонецПроцедуры

&НаКлиенте
// Процедура - структурная единица при изменении
//
Процедура СтруктурнаяЕдиницаПриИзменении(Элемент)
	
	Если ЭтаФорма.Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗаписатьОбъектОтвет", ЭтотОбъект), Нстр("ru='Для продолжения операции необходимо записать элемент, записать?';en='For continued operations is necessary writedown element writedown?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		СтруктурнаяЕдиницаПриИзмененииНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить контактную информацию
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура ДобавитьКонтактнуюИнформацию(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьКонтактнуюИнформациюВидВыбран", ЭтотОбъект);
	СписокДоступныхВидов = УправлениеКонтактнойИнформациейКлиентСерверСтоматология.СписокВидовДляДобавленияКонтактнойИнформации(ЭтаФорма.СвойстваВидовКонтактнойИнформации, ЭтаФорма.КонтактнаяИнформация);
	ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокДоступныхВидов, Элементы.КнопкаДобавитьКонтактнуюИнформацию);
	
КонецПроцедуры 

&НаКлиенте
// Процедура - обработчик оповещения "ДобавитьКонтактнуюИнформациюВидВыбран".
//
Процедура ДобавитьКонтактнуюИнформациюВидВыбран(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("Вид", ВыбранныйЭлемент.Значение);
	
	НайденныеСтроки = ЭтаФорма.СвойстваВидовКонтактнойИнформации.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СвойстваВида = НайденныеСтроки[0];
	
	ДобавитьКонтактнуюИнформациюСервер(ВыбранныйЭлемент.Значение);
	
КонецПроцедуры

&НаСервере
// Процедура - Добавить контактную информацию сервер
//
// Параметры:
//  ДобавляемыйВид				 - 	 - 
//  УстановитьВыводВФормеВсегда	 - 	 - 
//
Процедура ДобавитьКонтактнуюИнформациюСервер(ДобавляемыйВид, УстановитьВыводВФормеВсегда = Ложь) Экспорт
	
	УправлениеКонтактнойИнформациейСтоматология.ДобавитьКонтактнуюИнформацию(ЭтаФорма, Объект, ДобавляемыйВид, УстановитьВыводВФормеВсегда);
	
КонецПроцедуры

&НаСервере
// Процедура - перед записью на сервере
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
		ОбъектСЕ = Объект.СтруктурнаяЕдиница.ПолучитьОбъект();
		
		// КонтактнаяИнформация
		УправлениеКонтактнойИнформациейСтоматология.ПередЗаписьюНаСервере(ЭтотОбъект, ОбъектСЕ);
		// Конец КонтактнаяИнформация
		НастройкиЯндекса = ОбъектСЕ.НастройкиЯндексКарты.Получить();
		НастройкиЯндекса.ИдентификаторРубрики = ЭтотОбъект.ЯндексИдентификаторРубрики.Скопировать();
		Если ОбъектСЕ.ИспользоватьЯндексКарты = ИспользоватьЯндексКарты Тогда
			ОтправитьВЦРМ = Ложь; 
		Иначе
			ОтправитьВЦРМ = Истина;
		КонецЕсли;
		ОбъектСЕ.ИспользоватьЯндексКарты = ИспользоватьЯндексКарты;
		ОбъектСЕ.ДополнительныеСвойства.Вставить("НастройкиЯндексКарты", НастройкиЯндекса);
		ОбъектСЕ.Записать();
		
		Если (ЭтаФорма.Модифицированность И ИспользоватьЯндексКарты) Или ОтправитьВЦРМ Тогда
			
			ЯндексЧасыРаботы							= Справочники.СтруктурныеЕдиницы.ПолучитьПредставленияГрафикаРаботы(ОбъектСЕ);
			Если Не ЗначениеЗаполнено(ЯндексЧасыРаботы) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("На вкладке Основное не заполнено - Время работы");
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЯндексСайт) И Не (Лев(ЯндексСайт, 7) = "http://" Или Лев(ЯндексСайт, 8) = "https://") Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Основной сайт сети. Указывается в нижнем регистре, полностью, включая http:// или https://");
				Отказ = Истина;
				Возврат;
			КонецЕсли;

			Если Не ЗначениеЗаполнено(ЯндексИдентификаторРубрики) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо добавить от 1 до 3 рубрик");
				Отказ = Истина;
				Возврат;
			КонецЕсли;

			ЯндексНомерОбласти = ЛичныйКабинет.ПолучитьНомерОбласти();
			
			ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ЯндексКарты, ЛОжь); 
			
			Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда			
				ВнешняяСистема = Справочники.ВнешниеСистемы.СоздатьВнешнююСистему(Перечисления.ТипыВнешнихСистем.ЯндексКарты,,Объект.Наименование);
			КонецЕсли;	
			ЯндексКлючВнешнейСистемы = НРег(ВнешняяСистема.КлючПриложения);
			
			ПараметрыЗапроса = Новый Структура();
			
			МассивТелефоновЯ 							= ОбъектСЕ.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
			МассивЭлПочтыЯ 								= ОбъектСЕ.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)); 
			МассивСоциальныхСетейЯ                      = ОбъектСЕ.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.СоциальнаяСеть));
			МассивАдресовЯ 								= ОбъектСЕ.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес));
			
			Если ЗначениеЗаполнено(МассивТелефоновЯ)
				И ЗначениеЗаполнено(МассивТелефоновЯ[0].Значение) 
				И ЗначениеЗаполнено(МассивАдресовЯ)
				И ЗначениеЗаполнено(МассивАдресовЯ[0].Значение)
				И ЗначениеЗаполнено(НастройкиЯндекса.Сайт) Тогда
				
				МассивАдресовФакт						= ДекодироватьИзJSON(МассивАдресовЯ[0].Значение);
				ЯндексАдрес 							= МассивАдресовФакт.value;
				ЯндексДополнительнаяИнформацияКАдресу 	= ?(МассивАдресовФакт.Свойство("comment"), МассивАдресовФакт.comment, "");
				ЯндексГород 							= ?(МассивАдресовФакт.Свойство("city"), МассивАдресовФакт.city, "");
				Если НЕ ЗначениеЗаполнено(ЯндексГород) Тогда
					ЯндексГород = МассивАдресовФакт.area;	
				КонецЕсли;
				
				Если ЗначениеЗаполнено(МассивАдресовЯ) 
					И МассивАдресовЯ.Количество() > 1 
					И ЗначениеЗаполнено(МассивАдресовЯ[1].Значение) Тогда
					МассивКороткихАдресов			= ДекодироватьИзJSON(МассивАдресовЯ[1].Значение);
					ЯндексКороткийАдрес 			= МассивКороткихАдресов.value;
				Иначе
					ЯндексКороткийАдрес = "";
				КонецЕсли;
				
				
				МассивТелефонов = Новый Массив;
				Для Каждого СтрокаТ Из МассивТелефоновЯ Цикл
					
					СтруктураСтроки = Новый Структура("НомерТелефона, ДобавочныйНомер, ЧейНомер");
					ЗаполнитьЗначенияСвойств(СтруктураСтроки, СтрокаТ);
					МассивТелефонов.Добавить(СтруктураСтроки);
					
				КонецЦикла;
				ПараметрыЗапроса.Вставить("yandextelsp"		, МассивТелефонов);
				
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните обязательные поля - Телефон, фактический адрес и сайт");
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			УидТекущейСессии = ЛичныйКабинет.УидТекущейСессии();
			ПараметрыЗапроса.Вставить("session"				, УидТекущейСессии);
			ПараметрыЗапроса.Вставить("structuralunit"		, СтрЗаменить(Строка(ОбъектСЕ.Ссылка.УникальныйИдентификатор()), "-", ""));
			ПараметрыЗапроса.Вставить("name"				, Строка(ОбъектСЕ.Организация));
			ПараметрыЗапроса.Вставить("yandexadress"		, ЯндексАдрес);
			ПараметрыЗапроса.Вставить("yandexaddadress"		, ЯндексДополнительнаяИнформацияКАдресу);
			ПараметрыЗапроса.Вставить("yandexaddsite"		, НРег(НастройкиЯндекса.ДополнительныйСайт));
			ПараметрыЗапроса.Вставить("yandexinn"			, ОбъектСЕ.Организация.ИНН);
			ПараметрыЗапроса.Вставить("yandexsalon"			, НастройкиЯндекса.Салон);
			ПараметрыЗапроса.Вставить("yandexogrn"			, ОбъектСЕ.Организация.ОГРН);
			ПараметрыЗапроса.Вставить("yandexsite"			, НРег(НастройкиЯндекса.Сайт));
			ПараметрыЗапроса.Вставить("yandexfoto"			, НРег(НастройкиЯндекса.СсылкаНаФото));
			ПараметрыЗапроса.Вставить("yandexstrana"		, Строка(Константы.СтранаУчета.Получить()));
			ПараметрыЗапроса.Вставить("yandextime"			, НастройкиЯндекса.ЧасыРаботы);
			ПараметрыЗапроса.Вставить("yandexdata"			, Строка(Формат(ТекущаяДатаСеанса(), "ДЛФ=D")));
			ПараметрыЗапроса.Вставить("yandexgorod"			, ЯндексГород);
			ПараметрыЗапроса.Вставить("yandexstatus"		, ИспользоватьЯндексКарты);
			ПараметрыЗапроса.Вставить("yandexkey"			, ЭтаФорма.ЯндексКлючВнешнейСистемы);
			ПараметрыЗапроса.Вставить("yandexobl"			, ЯндексНомерОбласти);
			ПараметрыЗапроса.Вставить("yandexstructura"		, НастройкиЯндекса.Салон);
			ПараметрыЗапроса.Вставить("yandexshortadres"	, ЯндексКороткийАдрес);
			
			ПараметрыЗапроса.Вставить("yandextip"			, "2");   // 0 - Салон красоты, 1 - Фитнес, 2 - Стоматология
			
			РезультатЗапроса = ЛичныйКабинет.СоздатьВнешнююСистемуВ_CRM(ВнешняяСистема, УидТекущейСессии);
			
			МассивЯндексРубрик = Новый Массив;
			Для Каждого СтрокаТ Из ЯндексИдентификаторРубрики Цикл
				МассивЯндексРубрик.Добавить(СтрокаТ.Значение);	
			КонецЦикла;
			ПараметрыЗапроса.Вставить("yandexrubrika" , МассивЯндексРубрик);
			
			МассивКартинок = Новый Массив;
			
			Индекс = 0;
			Для Каждого СтрокаТ Из ЭтаФорма.ФайлыКартинок Цикл
				ФайлКартинки  = ЭтотОбъект.ФайлыКартинок[Индекс].Значение;				
				БазовыйURL    = "http://app.stoma1c.ru/api/hs/api";
				АдресКартинки = БазовыйURL + "/files/" + ВнешняяСистема.КлючПриложения + "/" + Строка(ФайлКартинки.УникальныйИдентификатор()) + "." + ФайлКартинки.Расширение;
				ЭтотОбъект.ФайлыКартинок[Индекс].Представление = АдресКартинки;
				Индекс = Индекс + 1; 
				МассивКартинок.Добавить(АдресКартинки);	
			КонецЦикла;
			
			ПараметрыЗапроса.Вставить("yandexkartinki" , МассивКартинок);
			
			МассивЯндексЭлПочты = Новый Массив;
			Для Каждого СтрокаТ Из МассивЭлПочтыЯ Цикл
				МассивЯндексЭлПочты.Добавить(СтрокаТ.Представление);	
			КонецЦикла;
			ПараметрыЗапроса.Вставить("yandexmailsp" , МассивЯндексЭлПочты);

			
			МассивЯндексСоциальныеСети = Новый Массив;
			Для Каждого СтрокаТ Из МассивСоциальныхСетейЯ Цикл
				МассивЯндексСоциальныеСети.Добавить(СтрокаТ.Представление);	
			КонецЦикла;
			ПараметрыЗапроса.Вставить("yandexsitesp" , МассивЯндексСоциальныеСети);
			
			РезультатЗапроса = ЛичныйКабинет.ОтправитьДанныеЯндексКартыВCRM(ПараметрыЗапроса);
			
			Если РезультатЗапроса.ВыполненоУспешно Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данные переданы для обработки!");
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Произошла ошибка, попробуйте еще раз!");
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

