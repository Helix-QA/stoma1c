// Процедура, вместо еще выводит выбранный прием.
//
Процедура ВывестиИЛИОчиститьРезультатВыбранногоПриема(Результат = неопределено, ИмяКоманды)
	
	Команда = ЭтаФорма.Команды.Найти("КнопкаИстория11");
	Кнопка  = Элементы.Найти("КнопкаИстория11"); 
	ОчисткаИстории = ИмяКоманды = "ОчисткаИстории"; 
	Элементы.ОчисткаИстории.Видимость = Не ОчисткаИстории; 
	
	Если НЕ ОчисткаИстории И Результат <> Неопределено Тогда 
		
		Команда.Действие          = "ИсторияНажатие"; 
		Команда.Заголовок         = Формат(НачалоДня(Результат.Дата), "ДЛФ=DD");
		Кнопка.Заголовок          = Формат(НачалоДня(Результат.Дата), "ДЛФ=DD");
		НоваяСтрока               = История.Добавить();
		НоваяСтрока.Наименование  = ИмяКоманды;
		НоваяСтрока.Дата          = КонецДня(Результат.Дата);
		
	Иначе 	
		
		Команда.Действие  = "ВыборПриемаДляОтображенияВЗубнойФормуле";  
		Команда.Заголовок = "Еще";
		Кнопка.Заголовок  = "Еще";
		
	КонецЕсли;

КонецПроцедуры

