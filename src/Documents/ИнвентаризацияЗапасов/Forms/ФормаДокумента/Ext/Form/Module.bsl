#Область ОбработчикиСобытийФормы
// Процедура, обработчик события "ПриСозданииНаСервере" управляемая форма документа.
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МассивТипов = Объект.Ссылка.Метаданные().ТабличныеЧасти.Запасы.Реквизиты.Номенклатура.ПараметрыВыбора[0].Значение;
	
	ОбработкаТабличныхЧастейКлиент.СоздатьДинамическийСписокПодбораНоменклатур(ЭтаФорма, Объект, "ГруппаПодборНоменклатура", МассивТипов, Истина);
	
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
			
	// Установим реквизиты
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	СхемаКомпоновкиДанных = Документы.ИнвентаризацияЗапасов.ПолучитьМакет("ОтборИнвентаризации");

	URLСхемы = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, Новый УникальныйИдентификатор());

	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(URLСхемы);

	ОтборИнвентаризации.Инициализировать(ИсточникНастроек);

	ТекОбъект    = РеквизитФормыВЗначение("Объект");
	ТекНастройки = ТекОбъект.ОтборИнвентаризации.Получить();
	Если ТекНастройки = Неопределено Тогда
		ОтборИнвентаризации.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	Иначе
		ОтборИнвентаризации.ЗагрузитьНастройки(ТекНастройки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		Объект.ВидЦен = Справочники.ВидыЦен.Закупочная;
	КонецЕсли;

	// Сформируем надпись	
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);
	ВидЦенНадпись = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи, Ложь);	

	ВидОперации = Объект.ВидОперации;
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	
	СоздатьМенюУправленияТабличнымиЧастями();
	ОбновитьЗаголовкиТабЧастейНаСервере();
	УстановитьИспользованиеПартийТЧЗапасы();
	
	// СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ИнвентаризацияЗапасов.ТабличныеЧасти.Запасы, НастройкиЗагрузкиДанных, ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = истина;	
		РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);		
	КонецЕсли;
	
	Элементы.Запасы.МаксимальнаяШирина = ?(Элементы.ГруппаПодборНоменклатура.Видимость, 99,140);
	
КонецПроцедуры

// Процедура, обработчик события "ПослеЗаписи" управляемая форма документа.
//
&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции    

&НаСервере
// Процедура - Установить использование партий ТЧЗапасы
//
Процедура УстановитьИспользованиеПартийТЧЗапасы()

	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл
		
		СтрокаТЧ.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "ИспользоватьПартии");
	    СтрокаТЧ.ЭтоСертификат              = (ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "ТипНоменклатуры") = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте 
// Обработчик события "ВидЦенНадписьНажатие"
//
Процедура ВидЦенНадписьНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	// 1. Формируем структуру параметров для заполнения формы "Цены и Валюта".
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ВидЦен", 	  			Объект.ВидЦен);
	СтруктураПараметров.Вставить("ПерезаполнитьЦены",	Ложь);
	
	// 2. Открвыаем форму "Цены и Валюта".
	ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,,Новый ОписаниеОповещения("РедактироватьЦеныЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события нажатие на кнопку "ЗаполнитьПоОстаткамНаСкладе".
//
Процедура КомандаЗаполнитьПоОстаткамНаСкладе(Команда)
	
	Если Объект.Запасы.Количество() > 0 Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("КомандаЗаполнитьПоОстаткамПослеВопросаОчиститьТЧ", ЭтотОбъект), НСтр("ru = 'Табличная часть будет очищена! Продолжить выполнение операции?'"), РежимДиалогаВопрос.ДаНет, 0);
        Возврат; 
	КонецЕсли;   	
	
	КомандаЗаполнитьПоОстаткамНаСкладеЗавершение();
КонецПроцедуры

&НаКлиенте
// Процедура - Команда заполнить по остаткам после вопроса очистить ТЧ
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура КомандаЗаполнитьПоОстаткамПослеВопросаОчиститьТЧ(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли; 
	
	КомандаЗаполнитьПоОстаткамНаСкладеЗавершение();

КонецПроцедуры

&НаКлиенте
// Процедура - Команда заполнить по остаткам на складе фрагмент
//
Процедура КомандаЗаполнитьПоОстаткамНаСкладеЗавершение()
		
	ПерезаполнитьЦены = Ложь; 
	ЗаполнитьПоОстаткамНаСкладе(ПерезаполнитьЦены, Ложь);
	Если ПерезаполнитьЦены Тогда 
		ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы");
	КонецЕсли;
	
	ОбработатьТЧЗапасыПослеЗаполненияУчетныхДанных();
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет табличную часть "Запасы" по остаткам склада.
//  Параметры:
//   Нет;
//
Процедура ЗаполнитьПоОстаткамНаСкладе(ПерезаполнитьЦены, ПоУпаковкам)
	
	Объект.Запасы.Очистить();
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	
	УстановитьЗначениеПараметраНастроек(ОтборИнвентаризации.Настройки, "Склад" , ТекОбъект.Склад);
	УстановитьЗначениеПараметраНастроек(ОтборИнвентаризации.Настройки, "Период", ПолучитьДатуОстатков(ТекОбъект));
	УстановитьЗначениеПараметраНастроек(ОтборИнвентаризации.Настройки, "СтруктурнаяЕдиница", ТекОбъект.СтруктурнаяЕдиница);
	
	СхемаКомпоновки = Документы.ИнвентаризацияЗапасов.ПолучитьМакет("ОтборИнвентаризации");
	
	МакетКомпоновки = ОбщегоНазначенияСтоматология.ПолучитьМакетКомпоновки(СхемаКомпоновки, ОтборИнвентаризации.Настройки);
	
	Запрос = ОбщегоНазначенияСтоматология.ПолучитьЗапросИзМакетаКомпоновки(МакетКомпоновки, "ЗаполнениеПоОтборам");
	
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = ТекОбъект.Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.КоличествоУпаковок = 0;
			НоваяСтрока.КоличествоВБазовыхЕИ = Выборка.КоличествоУпаковокПоДаннымУчета;	
			ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(НоваяСтрока); 
			Если ПоУпаковкам и ЗначениеЗаполнено(НоваяСтрока.Номенклатура.УпаковкаПоУмолчанию) и Не НоваяСтрока.Номенклатура.УпаковкаПоУмолчанию.Коэффициент = 0 Тогда				
				НоваяСтрока.КоличествоУпаковокПоДаннымУчета = НоваяСтрока.КоличествоУпаковокПоДаннымУчета/НоваяСтрока.Номенклатура.УпаковкаПоУмолчанию.Коэффициент;
				НоваяСтрока.КоличествоУпаковок = НоваяСтрока.КоличествоУпаковок/НоваяСтрока.Номенклатура.УпаковкаПоУмолчанию.Коэффициент;
				НоваяСтрока.Упаковка = НоваяСтрока.Номенклатура.УпаковкаПоУмолчанию;
			КонецЕсли;
			
			СтруктураДанные = Новый Структура();
			СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
			СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
			СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
			СтруктураДанные.Вставить("Номенклатура", 		НоваяСтрока.Номенклатура);
			СтруктураДанные.Вставить("Упаковка", 			НоваяСтрока.Упаковка);
			СтруктураДанные.Вставить("Сотрудник", 			Справочники.Сотрудники.ПустаяСсылка());	
			СтруктураДанные.Вставить("КоличествоУпаковок",  НоваяСтрока.КоличествоУпаковок);
			СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);			
			НоваяСтрока.Цена = СтруктураДанные.Цена;    
			
		КонецЦикла;
		
		ЗначениеВРеквизитФормы(ТекОбъект, "Объект");
		ПерезаполнитьЦены = Истина;
	КонецЕсли; 
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	
КонецПроцедуры
   
&НаСервере
// Устанавливает указанное значение параметра настроек компоновки данных
//
// Параметры:
//  Настройки - настройки компоновки данных
//  ИмяПараметра - имя параметра, значение которого нужно установить
//  Значение - устанавливаемое значение параметра
//
Процедура УстановитьЗначениеПараметраНастроек(Настройки, ИмяПараметра, Значение)

	Параметр = Настройки.ПараметрыДанных.Элементы.Найти(ИмяПараметра);
	
	Если Параметр <> Неопределено Тогда
		Параметр.Значение = Значение;
		Параметр.Использование = Истина;
	КонецЕсли;

КонецПроцедуры

// Функция, возвращает дату для получения остатков по номенклатуре, по регистру "ЗапасыНаСкладах"
//   Параметры:
//    ТекОбъект - документ.
//   Возвращаемое значение:
//    Результат - дата - на момент, которой получаем остаток
&НаСервере
Функция ПолучитьДатуОстатков(ТекОбъект)

	Если ТекОбъект.ЭтоНовый() Тогда
		Если НачалоДня(ТекОбъект.Дата) = НачалоДня(ТекущаяДата()) Тогда
			Результат = '00010101';
		Иначе
			Результат = ТекОбъект.Дата;
		КонецЕсли;   	
	Иначе
		Результат = ТекОбъект.МоментВремени();
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаКлиенте
// Процедура, обработчик события нажатия на кнопку "ЗаполнитьТолькоУчетныеДанные".
//
Процедура КомандаЗаполнитьТолькоУчетныеДанные(Команда)
	
	Если Объект.Запасы.Количество() > 0 Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("КомандаЗаполнитьТолькоУчетныеДанныеПослеВопросаОчиститьТЧ", ЭтотОбъект), НСтр("ru = 'Учетные данные будут очищены! Продолжить выполнение операции?'"), РежимДиалогаВопрос.ДаНет, 0);
        Возврат; 
	Иначе
		Возврат;
	КонецЕсли;

	КомандаЗаполнитьТолькоУчетныеДанныеЗавершение(); 
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Команда заполнить только учетные данные после вопроса очистить ТЧ
//
// Параметры:
//  РезультатВопроса		 - 	 - 
