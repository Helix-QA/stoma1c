// Обработчик кнопки проведения оплаты документа
//
Процедура ДокументОплатить(Команда)

	УстановитьФункциональнуюОпцию_ОбменДаннымиВключен(Истина);
	Если НЕ ЗначениеЗаполнено(Объект.РезультатПриема) Тогда 
		Если Элементы.ГруппаРезультатЛечения.Скрыта() Тогда 
			Если Объект.Ссылка.Пустая() Тогда
				ПараметрыЗаписи = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись);
				ЭтаФорма.Записать(ПараметрыЗаписи);  
			КонецЕсли;
			Элементы.ГруппаРезультатЛечения.Показать(); 
			ОбновитьСписокНаправленийНаКонсультацию();
		КонецЕсли;			
		Возврат;
	КонецЕсли;	
	
	// Явный вызов обработчика события(по причине записи документа на сервере) 
	ПередЗаписью(Неопределено, Неопределено);
	// Сохранить документ
	Если ЭтаФорма.Модифицированность = Истина ИЛИ НЕ Объект.Проведен Тогда
		Если ПроверитьЗаполнение() Тогда
			ЗаписатьДокументСервер();	
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	// Явный вызов обработчика события(по причине записи документа на сервере) 
	ПослеЗаписи(Неопределено);
	
	ПараметрыОплаты = Новый Структура;
	ПараметрыОплаты.Вставить("СтруктурнаяЕдиница"                , Объект.СтруктурнаяЕдиница);
	ПараметрыОплаты.Вставить("Касса"                             , Объект.Касса);
	ПараметрыОплаты.Вставить("ДатаПродажи"                       , Объект.Дата);
	ПараметрыОплаты.Вставить("ВидОперации"                       , ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа"));
	ПараметрыОплаты.Вставить("Контрагент"                        , Объект.Контрагент);
	ПараметрыОплаты.Вставить("ДокументыПродажи"                  , Объект.Ссылка);
	ПараметрыОплаты.Вставить("ЗакрытьФормуАвтоматически"         , Истина);
	
	РезОперации = Неопределено;
	
	ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОплаты", ПараметрыОплаты,,,,,
		Новый ОписаниеОповещения("ДокументОплатитьЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
			
КонецПроцедуры

