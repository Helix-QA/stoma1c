// Обработчик при формировании документа HTML
//
Процедура HTMLШаблонДокументСформирован(Элемент)  
	
	Документ                      = Элемент.Документ;	
	Документ.body.contentEditable = "true";	
	Если Объект.Ссылка.Пустая() Тогда
		Элементы.HTMLШаблон.Документ.execCommand("JustifyCenter", Ложь);
	КонецЕсли;
	
	#Если не ВебКлиент Тогда
		Системнаяинформация = Новый Системнаяинформация;
		Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 	
			// Перевести позиционирование HTML элемента в верхнее положение
			ТекущийЭлемент = Элементы.HTMLШаблон;
			WSHShell       = Новый COMОбъект("WScript.Shell");
			WSHShell.SendKeys("{PGUP}");
		КонецЕсли;
	#Конецесли	
	
