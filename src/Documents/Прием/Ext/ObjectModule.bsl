#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
 
Перем БлокироватьВызовПерезаполненияСуммыОплачено Экспорт; // флаг блокировки перезаполнения реквизита сумма оплачено

#Область ОбработчикиСобытий

// Обработчик заполнения объекта внешними данными
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	СтруктураРеквизитовСтруктурнойЕдиницы = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, "ВидЦенРеализации, ОсновнаяКасса, ОсновнойСклад");

	Склад              = СтруктураРеквизитовСтруктурнойЕдиницы.ОсновнойСклад;
	ВидЦен         	   = ?(Не СтруктураРеквизитовСтруктурнойЕдиницы.ВидЦенРеализации.Пустая(), СтруктураРеквизитовСтруктурнойЕдиницы.ВидЦенРеализации, Справочники.ВидыЦен.Розничная);
	АвторДокумента 	   = ПараметрыСеанса.ТекущийПользователь;
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;  
	
	// Заполнение на основании внешних данных.		
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		
		ДанныеЗаполнения.Свойство("Контрагент", ЭтотОбъект.Контрагент);
		ДанныеЗаполнения.Свойство("Сделка"	  , ЭтотОбъект.Сделка);    		
		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		Контрагент = ДанныеЗаполнения;
		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПланЛечения") Тогда
		
		ДокументОснование 	= ВернутьДокументОснования(ДанныеЗаполнения);		
		Контрагент          = ДанныеЗаполнения.Контрагент;
		КартаКонтрагента 	= ДанныеЗаполнения.КартаКонтрагента;		
		Сотрудник           = ДанныеЗаполнения.Сотрудник;
		СтруктурнаяЕдиница  = ДанныеЗаполнения.СтруктурнаяЕдиница;
		ПолисМедСтрахования = ДанныеЗаполнения.ПолисМедСтрахования;
		ВидЦен              = ДанныеЗаполнения.ВидЦен;
		
	КонецЕсли;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.НарядЗаказ") Тогда
		
		Контрагент          = ДанныеЗаполнения.Контрагент;
		Сотрудник           = ДанныеЗаполнения.Сотрудник;
		СтруктурнаяЕдиница  = ДанныеЗаполнения.СтруктурнаяЕдиница;
		ВидЦен              = ДанныеЗаполнения.ВидЦенПродажи;
		Склад               = ?(ЗначениеЗаполнено(ДанныеЗаполнения.Склад),ДанныеЗаполнения.Склад,Склад);
		
	КонецЕсли;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Событие") Тогда
		
		ДокументОснование  	= ДанныеЗаполнения;
		Контрагент         	= ДанныеЗаполнения.Контрагент;
		КартаКонтрагента 	= ДанныеЗаполнения.КартаКлиента;				
		Сотрудник          	= ЗаполнитьСотрудника(ДанныеЗаполнения);
		СтруктурнаяЕдиница 	= ДанныеЗаполнения.СтруктурнаяЕдиница;
		ВидЦен             	= ДанныеЗаполнения.ВидЦен; 
		ПолисМедСтрахования = ДанныеЗаполнения.ПолисМедСтрахования;
		Сделка 				= ?(ЗначениеЗаполнено(Сделка), Сделка, ДанныеЗаполнения.Сделка);
		
	КонецЕсли;
	
	МассивКасс		= Справочники.Кассы.ПолучитьКассыДляОплаты(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);	
	Касса 		   	= ?(МассивКасс.Количество() > 0, МассивКасс[0], СтруктураРеквизитовСтруктурнойЕдиницы.ОсновнаяКасса);
		
	// заполняем после того, как заполнили склад материалов
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Событие") Тогда
		ЗаполнитьТаблицуЛечение(ДанныеЗаполнения);
		СуммаДокумента = Лечение.Итог("Сумма") + Запасы.Итог("Сумма");
	КонецЕсли;
	
	// Последовательность вызова не менять!!!
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	// Получить шаблон. Это необходимо провести после получения статусов пациента!!!
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
		
		Если ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(ЭтотОбъект.Сотрудник) = Истина Тогда
			Если ЭтотОбъект.ЭтоПервичныйПациентДляВрача = Истина Тогда
				ЭтотОбъект.ШаблонОбследования = Справочники.ШаблоныОбследований.ПервичныйСтоматологическийОсмотр;
			Иначе
				ЭтотОбъект.ШаблонОбследования = Справочники.ШаблоныОбследований.ПовторныйСтоматологическийОсмотр;
			КонецЕсли;
		Иначе	
			ЭтотОбъект.ШаблонОбследования = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(ЭтотОбъект.Сотрудник, ЭтотОбъект.СтруктурнаяЕдиница , "ОсновнойШаблонОбследований");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

// Процедура, обработчик события "ПриКопировании"
//
Процедура ПриКопировании(ОбъектКопирования)
	
	ВремяНачалаПриема 	   	= Дата(1,1,1);
	ВремяОкончанияПриема   	= Дата(1,1,1);
	СуммаОплачено          	= 0;
	КодСинхронизации       	= "";
	РезультатПриема        	= 0;
	КурсЛечения            	= Неопределено;
	ЛечениеВрача           	= Неопределено;
	ДокументОснование 		= Неопределено;
	Сделка 					= Неопределено;
	УчтенныеАвансы.Очистить();
	ПредварительнаяЗаписьНаСледующийПрием = Неопределено;
	ИзмененПослеОплаты = Ложь;
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда
		Запасы.Очистить();
		Лечение.Очистить(); 
		Материалы.Очистить();
		СкидкиНаценки.Очистить(); 
		ПогашениеПодарочныхСертификатов.Очистить();
	Иначе
		
		Для Каждого СтрокаЛечение Из Лечение Цикл
			СтрокаЛечение.НомерЗаказа = "";
			СтрокаЛечение.ДокументАванса = Неопределено;
		КонецЦикла;
		
		Для Каждого СтрокаЗапасы Из Запасы Цикл  // при копировании нужно найти все ключи связи и обновить их		
			// запомним исходный ключ
			КлючСтокиДельта = СтрокаЗапасы.КлючСтроки; 		
			// назначим новый ключ
			СтрокаЗапасы.КлючСтроки = Новый УникальныйИдентификатор; 		
			// найдем старый ключ во всех табличных частях и обновим его
			СтруктураПоиска = Новый Структура("КлючСтроки", КлючСтокиДельта); 		
			// 1. Таблица "ПогашениеПодарочныхСертификатов"
			МассивСерийныеНомера = ПогашениеПодарочныхСертификатов.НайтиСтроки(СтруктураПоиска);  
			Для каждого МассивСтрСН из МассивСерийныеНомера Цикл
				МассивСтрСН.КлючСтроки = СтрокаЗапасы.КлючСтроки;
			КонецЦикла;  		
			
			//// 2. Таблица "Материалы"
			// МассивМатериалы = Материалы.НайтиСтроки(СтруктураПоиска);  
			// Для каждого МассивСтрМатериалы из МассивМатериалы Цикл
			//	МассивСтрМатериалы.КлючСтроки = СтрокаЗапасы.КлючСтроки;
			// КонецЦикла;
			
			// 3. Таблица "СкидкиНаценки"
			МассивСкидкиНаценки = СкидкиНаценки.НайтиСтроки(СтруктураПоиска);  
			Для каждого МассивСтрСкидкиНаценки из МассивСкидкиНаценки Цикл
				МассивСтрСкидкиНаценки.КлючСтроки = СтрокаЗапасы.КлючСтроки;
			КонецЦикла;
			СтрокаЗапасы.НомерЗаказа = "";
			СтрокаЗапасы.ДокументАванса = Неопределено;
		КонецЦикла;
	КонецЕсли;

	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	
КонецПроцедуры

// Процедура - обработчик события "ОбработкаПроверкиЗаполнения".
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Перем МассивВсехРеквизитов;
	МассивОбязательныхРеквизитов = Новый Массив;                            	
	//
	Документы.Прием.ПолучитьМассивыОбязательныхРеквизитов(ЭтотОбъект,
	МассивОбязательныхРеквизитов);
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	ДенежныеСредстваСервер.ЗаполнитьМассивНепроверяемыхРеквизитовПоОбъекту(ЭтотОбъект,
	МассивОбязательныхРеквизитов,
	МассивНепроверяемыхРеквизитов
	);
	//
	ДенежныеСредстваСервер.УдалитьНепроверяемыеРеквизитыИзМассива(
	ПроверяемыеРеквизиты,
	МассивНепроверяемыхРеквизитов
	);
	
	ДанныеТекущегоПользователя = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ПараметрыСеанса.ТекущийПользователь, "РольПользователя, Сотрудник"); 
	Если ДанныеТекущегоПользователя.РольПользователя = Перечисления.РольПользователя.Врач Тогда
		
		РазрешитьЗаписьКДругомуВрачу = Пользователи.ПолучитьЗначениеПраваПользователя("РазрешитьЗаписьКДругомуВрачу");
		Если НЕ РазрешитьЗаписьКДругомуВрачу Тогда						
			Если ЗначениеЗаполнено(Сотрудник) И НЕ Сотрудник = ДанныеТекущегоПользователя.Сотрудник Тогда				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Текущему врачу запрещено создавать приемы к другим врачам!");
				Отказ = Истина;
				Возврат;				
			КонецЕсли;				
		КонецЕсли; 
		
	КонецЕсли;
	
	// Если Рекламация И НЕ ЗначениеЗаполнено(РекламацияПрием) Тогда
	//	Отказ = Истина;
	//	Сообщить("Необходимо заполнить прием - основание для рекламации!");
	// КонецЕсли;		
	
	// 1. Определяем вид налога если он не заполнен, для старых документов.	
	Если Запасы.Количество() > 0 Тогда
		ВидНалога    = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Запасы[0].Номенклатура, СтруктурнаяЕдиница);// Запасы[0].Номенклатура.ВидНалога;
		Номенклатура = Запасы[0].Номенклатура;
	ИначеЕсли Лечение.Количество() > 0 Тогда
		ВидНалога    = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Лечение[0].Номенклатура, СтруктурнаяЕдиница);// Лечение[0].Номенклатура.ВидНалога;
		Номенклатура = Лечение[0].Номенклатура;
	Иначе
		Возврат;
	КонецЕсли;
	
	ЕстьРазличия = Ложь;
	Для Каждого СтрокаТЧ из Запасы Цикл
		Если НЕ Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница) = ВидНалога Тогда
			ЕстьРазличия = Истина;	
			мНоменклатура = СтрокаТЧ.Номенклатура;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЕстьРазличия Тогда
		Для Каждого СтрокаТЧ из Лечение Цикл
			Если НЕ Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница) = ВидНалога Тогда
				ЕстьРазличия = Истина;
				мНоменклатура = СтрокаТЧ.Номенклатура;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьРазличия Тогда
		Отказ = Истина;
		ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения. Номенклатура '%1' и '%2' используют разные режимы налогообложения";
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Номенклатура, мНоменклатура);	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;	
	
	
КонецПроцедуры

// Обработчик перед записью объекта
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Проверка на заполнения норм списания у номенклатуры
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
		Для Каждого СтрокаМатериал Из Материалы Цикл 
			Если НЕ ЗначениеЗаполнено(СтрокаМатериал.Материал) Тогда
				ПараметрыОтбора = Новый Структура;
				ПараметрыОтбора.Вставить("КлючСтроки", СтрокаМатериал.КлючСтроки); 
				НайденныеСтроки = Лечение.НайтиСтроки(ПараметрыОтбора);
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = "В услуге """ + СтрокаМатериал.Услуга + """ не выбраны материалы списния!" + Символы.ПС + "Проведение невозможно!";
				Сообщение.Поле = ?(НайденныеСтроки.Количество() > 0, "Объект.Лечение[" + Строка(НайденныеСтроки[0].НомерСтроки - 1) + "].Номенклатура", "Объект.Лечение");
				Сообщение.УстановитьДанные(Ссылка);
				Сообщение.Сообщить();
				Отказ = Истина;
			    Прервать;
			КонецЕсли;	
		КонецЦикла;        		
	КонецЕсли;	
		
	// Проверить соответствия авансов строкам ТЧ Запасов и Лечения, 
	// при необходимости удалить не связанные строки
	// ИндексСтроки = 0;
	// Пока ИндексСтроки < УчтенныеАвансы.Количество() Цикл
	//	НайденныеСтроки = Лечение.НайтиСтроки(Новый Структура("ДокументАванса",УчтенныеАвансы[ИндексСтроки].ДокументАванса));
	//	Если НайденныеСтроки.Количество() = 0 Тогда
	//		НайденныеСтроки = Запасы.НайтиСтроки(Новый Структура("ДокументАванса",УчтенныеАвансы[ИндексСтроки].ДокументАванса));
	//		Если НайденныеСтроки.Количество() = 0 Тогда
	//			УчтенныеАвансы.Удалить(УчтенныеАвансы[ИндексСтроки]);
	//			ИндексСтроки = ИндексСтроки - 1;
	//		КонецЕсли;
	//	КонецЕсли;  
	//	ИндексСтроки = ИндексСтроки + 1;
	// КонецЦикла;
	
	// Свернуть таблицу учтенные авансы по Документу аванса
	// УчтенныеАвансы.Свернуть("ДокументАванса, ДокументАвансаДляРегистра", "СуммаАванса");  // убрано (записывается результат фискализации).
	
	// Удаление данных по регистру планирования профосмотров
	РегистрыСведений.Профосмотры.ЗаписьПоПланированиюПрофосмотров(Ссылка,Истина);
	// Проставляем время окончания приема
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Если Час(ВремяОкончанияПриема) = 0 и Минута(ВремяОкончанияПриема) = 0 И РезультатПриема <> 0 Тогда 
			ВремяОкончанияПриема = ТекущаяДатаСеанса();
		КонецЕсли;	
	КонецЕсли;
	
	// Пропишем в ТЧ Лечение врача, если не заполнен
	Для Каждого СтрокаТЧЛечение Из Лечение Цикл 
		Если НЕ ЗначениеЗаполнено(СтрокаТЧЛечение.Сотрудник) Тогда 
			СтрокаТЧЛечение.Сотрудник = Сотрудник;
		КонецЕсли;
		
		Если НЕ Рекламация И ЗначениеЗаполнено(СтрокаТЧЛечение.Рекламация) Тогда
			Рекламация = Истина;
			РекламацияПрием = СтрокаТЧЛечение.Рекламация;			
		КонецЕсли;
		
	КонецЦикла;	
	
	// Установить статусы пациента 
	Если Не ЗначениеЗаполнено(СтатусПациента) И РежимЗаписи = РежимЗаписиДокумента.Проведение  Тогда
		УстановитьПризнакПервичногоПациента();
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
		ПроверитьОстатокПоМедицинскомуПолису(Отказ);
	КонецЕсли;  	    
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		
		Если СуммаОплачено > 0 И Документы.Прием.ДокументПробитПоФР(Ссылка) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Документ пробит на фискальном регистраторе. Отмена проведения невозможна!';
																  | en='The document is punched on the fiscal registrar. Cancellation is not possible!'"));
			Отказ = Истина;
			Возврат;	
		КонецЕсли;
			
	КонецЕсли;
	
	#Область _________________________________________ПостОбработкаДокументовАвансаПриОтменеПроведения______________________________________________________
	
	// -----------------------------ПостОбработка документов аванса при отмене проведения---------------------------------
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда 
		ПостОбработкаДокументовАванса(РежимЗаписи, Отказ);
	КонецЕсли;
	
	#КонецОбласти
	
	// -------------Проверка на указание ассистента--------------
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И НЕ ЗначениеЗаполнено(Ассистент) Тогда
		Для Каждого СтрокаЛечение Из Лечение Цикл 
			Если СтрокаЛечение.Номенклатура.ОбязательноУказаниеАссистента Тогда 
				Сообщение = Новый СообщениеПользователю();
    			Сообщение.Текст = "Для услуги """ + СтрокаЛечение.Номенклатура + """, обязательно указание ассистента!";
    			Сообщение.Поле = "Объект.Ассистент";
    			Сообщение.УстановитьДанные(Ссылка);
    			Сообщение.Сообщить();		
				Отказ = Истина;
				Прервать;
			КонецЕсли;	
		КонецЦикла;
	КонецЕсли;
	
	// -------------Проверка на заполненность табличных частей--------------
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение И Лечение.Количество() = 0 И Запасы.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "В табличных частях приёма не добавлены данные. Проведение приема невозможно!";
		// Сообщение.Поле = "Объект.Ассистент";
		// Сообщение.УстановитьДанные(Ссылка);
		Сообщение.Сообщить();		
		Отказ = Истина;		
	КонецЕсли;
	
	Если Запасы.Количество() > 0 Тогда
		ВидНалога = Запасы[0].Номенклатура.ВидНалога;
	ИначеЕсли Лечение.Количество() > 0 Тогда
		ВидНалога = Лечение[0].Номенклатура.ВидНалога;
	КонецЕсли;
	
	СформироватьМассивСотрудниковДляФормированияИнтервалов();
		
	Если Запасы.Количество() > 0 Тогда
		ВидНалога = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Запасы[0].Номенклатура, СтруктурнаяЕдиница); // Запасы[0].Номенклатура.ВидНалога;
	ИначеЕсли Лечение.Количество() > 0 Тогда
		ВидНалога = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Лечение[0].Номенклатура, СтруктурнаяЕдиница); // Лечение[0].Номенклатура.ВидНалога;
	КонецЕсли;
	
	// Создаем или подхватываем бонусный счет
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		УправлениеМаркетинговымиАкциями.УстановитьБонусныйСчетНачисленияВСкидках(
				ЭтотОбъект, 
				"СкидкиНаценки",
				Контрагент, 
				КартаКонтрагента,
				Отказ);
	КонецЕсли;	

	ОбработкаПроверкиЗаполненияРаботаССертификатами(Отказ);
	
	// Устанавливаем ссылку новой сделки
	ПоместитьСсылкуНовойСделки();
	
	// Устанавливаем курс лечения и лечение при необходимости
	Если Отказ = Ложь И РежимЗаписи = РежимЗаписиДокумента.Проведение И РезультатПриема <> 0 И ПометкаУдаления = Ложь Тогда	
		УстанавливаемКурсЛеченияИЛечениеВрача(Отказ);
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);  
		
		Если ЗначениеЗаполнено(ВнешняяСистема) И ЭтотОбъект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
			
			Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент.СоциальныйСтатус) И Не ЗначениеЗаполнено(ЭтотОбъект.Контрагент.СоциальныйСтатус.СоциальныйСтатусПоКлассификаторуИЭМК) Тогда
				ТекстСообщения = НСтр("ru = 'У клиента в поле ""Cоциальный статус"" не заполнено представление по ИЭМК.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Ссылка, , , Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ИзмененПослеОплаты") Тогда
		ИзмененПослеОплаты = ДополнительныеСвойства.ИзмененПослеОплаты;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обработчик события "ПриЗаписи"
//
Процедура ПриЗаписи(Отказ)	
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Хз зачем это!!....
	УстановитьПривилегированныйРежим(Истина);
	
	Если СуммаДокумента < РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОплатыПоДокументу(Ссылка) Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Проведение документа невозможно, т.к. сумма оплаты превышает итоговую сумму документа.';en='Holding of the document is not possible because amount payment exceeds total amount of the document.'"));	
		Возврат;
	КонецЕсли;	   
	
	// Запись по регистру планирования профосмотров
	РегистрыСведений.Профосмотры.ЗаписьПоПланированиюПрофосмотров(Ссылка);		
	// Работа со статусами документа основания приема    
	СтатусПЗ = Неопределено;                        
		
	Если ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Событие") Тогда
		Если Проведен Тогда      
			СтатусПЗ = Перечисления.СтатусыСобытия.ПриемОкончен;
		ИначеЕсли НЕ Проведен И НЕ ПометкаУдаления Тогда
			СтатусПЗ = Перечисления.СтатусыСобытия.ПриемНачат;
		ИначеЕсли ПометкаУдаления Тогда
			СтатусПЗ = Перечисления.СтатусыСобытия.Подтверждена;
		КонецЕсли;	
		
		ДанныеПЗ = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ДокументОснование, "Статус, СсылкаНаПрием, Контрагент");
		// Если статус документа основания не соответсвует текущему заменяем
		ОбновитьСтатус = ЗначениеЗаполнено(СтатусПЗ) И НЕ ДанныеПЗ.Статус = СтатусПЗ;
		
		Если ОбновитьСтатус ИЛИ НЕ ЗначениеЗаполнено(ДанныеПЗ.СсылкаНаПрием) Тогда 
			ОбъектДок        		= ДокументОснование.ПолучитьОбъект();
			ОбъектДок.Статус 		= ?(ОбновитьСтатус, СтатусПЗ, ОбъектДок.Статус);
			ОбъектДок.СсылкаНаПрием = ЭтотОбъект.Ссылка;
			ОбъектДок.ОбменДанными.Загрузка = Истина;
			ОбъектДок.Записать();			
		КонецЕсли;
		
		// Снимем метки "первичный прием" для всех последующих предварительных записей этого клиента
		
		Если СтатусПЗ = Перечисления.СтатусыСобытия.ПриемОкончен Тогда
			
			МеткаПервичный = Справочники.Метки.НайтиПоНаименованию("Первичный прием");
			Если ЗначениеЗаполнено(МеткаПервичный) Тогда
				
				ЗапросПЗ = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
				|	СобытиеУслуги.Ссылка КАК Ссылка
				|ИЗ
				|	Документ.Событие.Услуги КАК СобытиеУслуги
				|ГДЕ
				|	СобытиеУслуги.ДатаНачала >= &Дата
				|	И СобытиеУслуги.Ссылка <> &Ссылка
				|	И СобытиеУслуги.Ссылка.Контрагент = &Клиент");
				
				ЗапросПЗ.УстановитьПараметр("Дата"	, ?(ДокументОснование.Услуги.Количество() > 0, ДокументОснование.Услуги[0].ДатаНачала, ДокументОснование.Дата));
				ЗапросПЗ.УстановитьПараметр("Ссылка", ДокументОснование);
				ЗапросПЗ.УстановитьПараметр("Клиент", ДанныеПЗ.Контрагент);
				
				РезультатПЗ = ЗапросПЗ.Выполнить().Выбрать();
				
				Пока РезультатПЗ.Следующий() Цикл
					
					МеткиНабор = РегистрыСведений.МеткиКлиентов.СоздатьНаборЗаписей();
					МеткиНабор.Отбор.Клиент.Установить(РезультатПЗ.Ссылка);				
					МеткиНабор.Отбор.Метка.Установить(МеткаПервичный);
					МеткиНабор.Прочитать();
					МеткиНабор.Очистить();
					МеткиНабор.Записать();
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	
	
	Если ДополнительныеСвойства.Свойство("НаправленияНаКонсультацию") И ЗначениеЗаполнено(ДополнительныеСвойства.НаправленияНаКонсультацию) Тогда
		РегистрыСведений.Профосмотры.ЗаписатьДанныеВРегистрПрофосмотры(ДополнительныеСвойства.НаправленияНаКонсультацию, 
                                          Сотрудник, СтруктурнаяЕдиница, Контрагент, Ссылка)
	КонецЕсли;
	
	Если ЭтотОбъект.Проведен Тогда
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);  
		Если ЗначениеЗаполнено(ВнешняяСистема) И ЭтотОбъект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда 
			РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ЭтотОбъект.Контрагент.Ссылка, 0, "", "", Строка(ЭтотОбъект.Контрагент.Ссылка.УникальныйИдентификатор()), 0);
			РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ЭтотОбъект.Ссылка, 0, "", "", Строка(ЭтотОбъект.Ссылка.УникальныйИдентификатор()), 0);
		КонецЕсли;
	КонецЕсли;

	СформироватьИнтервалыПоСотрудникам();
	
	СоздатьНовуюВоронку(); 
	СменитьЭтапПредопределеннойВоронки();
		
	// Актуализация статуа клиента
	Если НЕ ДополнительныеСвойства.Свойство("НеАктуализироватьСтатус") И НЕ ДополнительныеСвойства.Свойство("ЭтоПроведениеЗагруженныхДанных") Тогда
		РегистрыСведений.СтатусыКонтрагентов.АктуализироватьСтатусПациента(ЭтотОбъект.Контрагент);
	КонецЕсли;
	
	ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
    ДобавитьСообщениеВСистемуВзаимодействия(ИспользоватьСистемуВзаимодействия);
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда		
		ОбработатьСогласованияСтраховыхУслуг(ИспользоватьСистемуВзаимодействия);				
	КонецЕсли;
	
	// Открываем / закрываем курс лечения и лечение при необходимости
	Если Отказ = Ложь И РезультатПриема <> 0 И ПометкаУдаления = Ложь Тогда	
		ОткрываемЗакрываемКурсЛеченияИЛечение(Отказ);
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, Режим)

	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);	
	
	// Запись номинала серии сертификата в элемент справочника "ПартииНоменклатуры".
	Документы.Прием.ЗаписатьНоминалСертификатаПриПродаже(Ссылка);
	
	// Инициализация данных документа.	
	Документы.Прием.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);	
	
	//
	ДополнительныеСвойства.ДляПроведения.Вставить("ВыполнятьДвиженияСебестоимость", Истина);
	
	// Сформируем таблицы списания номенклатуры
	УправлениеЗапасамиПартионныйУчет.СформироватьСписаниеТаблицаПартииТоваров(ПодготовитьТаблицуДляСписанияПартииТоваров(), ДополнительныеСвойства, Движения, Отказ);
	
	// Движения по регистрам
	ДвиженияДокументовСервер.ЗапасыНаСкладах(ДополнительныеСвойства, Движения, Отказ);   	
	ДвиженияДокументовСервер.ВзаиморасчетыСКонтрагентами(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ПартииТоваров(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ПродажиСебестоимость(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.Продажи(ДополнительныеСвойства, Движения, Отказ);
//	ДвиженияДокументовСервер.ДенежныеСредстваНаЛицевыхСчетах(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.Сертификаты(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ОборотыПредоставленныеСкидки(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ПланыЛечения(ДополнительныеСвойства, Движения, Отказ);   	
	ДвиженияДокументовСервер.МатериалыКСписанию(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ГарантияНаУслуги(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.НарядЗаказы(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.БонусныеСчета(ДополнительныеСвойства, Движения, Отказ);
	ТаблицаУправленческийДобавитьДвиженияПоПартиям(ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУправленческий
	                                              ,ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаПартииТоваров);
    ДвиженияДокументовСервер.Управленческий(ДополнительныеСвойства, Движения, Отказ);

	// Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);	
	// Запись значения реквизита "сумма оплачено"
	Если БлокироватьВызовПерезаполненияСуммыОплачено <> Истина Тогда
	     ДенежныеСредстваСервер.ЗаполнитьРеквизитыОплатыДокументаОснования(ЭтотОбъект);
    КонецЕсли;
	
	// Запись статуса контрагента
	мПараметры = Новый Структура;
	мПараметры.Вставить("Контрагент"		 	, Контрагент);
	мПараметры.Вставить("Период"				, Дата);
	мПараметры.Вставить("Добавление"		 	, Истина);
	мПараметры.Вставить("Статус"			 	, СтатусПациента);
	
	РегистрыСведений.СтатусыКонтрагентов.УстановитьСтатусКонтрагента(мПараметры);
	РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьСведенияДляСписка(Контрагент);

	#Область ____________________________________________ПостОбработкаДокументовАванса__________________________________________________________
	
	// --------------ПостОбработка документов аванса--------------
	ПостОбработкаДокументовАванса(РежимЗаписиДокумента.Проведение, Отказ);
	
	#КонецОбласти
			
КонецПроцедуры

// Обработчик удаления проведения
//
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ДенежныеСредстваСервер.ЗаполнитьРеквизитыОплатыДокументаОснования(ЭтотОбъект, Истина);
	
	СтруктураЗаписи = Новый Структура;
	СтруктураЗаписи.Вставить("Период"		, ЭтотОбъект.Дата);
	СтруктураЗаписи.Вставить("Контрагент"	, ЭтотОбъект.Контрагент);
	
	// Удаляем статусы пациентов из регистра по документу
	РегистрыСведений.СтатусыКонтрагентов.УдалениеСтатусаПациента(СтруктураЗаписи);
	
	// очищаем реквизит статус 
	СтатусПациента = Неопределено;
	РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьСведенияДляСписка(Контрагент, Ссылка);
	
	Если ЗначениеЗаполнено(ЭтотОбъект.КурсЛечения) Или ЗначениеЗаполнено(ЭтотОбъект.ЛечениеВрача) Тогда
		Документы.Прием.АктуализироватьДанныеКурсаИЛечения(ЭтотОбъект.Ссылка, ЭтотОбъект.КурсЛечения, ЭтотОбъект.ЛечениеВрача);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//
//
Процедура ПостОбработкаДокументовАванса(РежимЗаписиПриема = Неопределено, Отказ)
	             
	Если Проведен Тогда 
		// Получим 2 массива документов аванса из 2-х табличных частей (Лечение и Запасы)
		//  1 массив ПлановЛечения
		//  2 массив НарядЗаказов
		МассивПлановЛечения = Новый Массив;
		МассивНарядЗаказов	= Новый Массив;
		// табличная часть Лечение
		Для Каждого СтрокаТЧ Из Лечение Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) Тогда 
				Если ТипЗнч(СтрокаТЧ.ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда
					Если МассивНарядЗаказов.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда  
						МассивНарядЗаказов.Добавить(СтрокаТЧ.ДокументАванса);
					КонецЕсли;
				ИначеЕсли ТипЗнч(СтрокаТЧ.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда	
					Если МассивПлановЛечения.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда  
						МассивПлановЛечения.Добавить(СтрокаТЧ.ДокументАванса);
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
		КонецЦикла;
		// табличная часть Запасы
		Для Каждого СтрокаТЧ Из Запасы Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) Тогда 
				Если ТипЗнч(СтрокаТЧ.ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда
					Если МассивНарядЗаказов.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда  
						МассивНарядЗаказов.Добавить(СтрокаТЧ.ДокументАванса);
					КонецЕсли;
				ИначеЕсли ТипЗнч(СтрокаТЧ.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда	
					Если МассивПлановЛечения.Найти(СтрокаТЧ.ДокументАванса) = Неопределено Тогда  
						МассивПлановЛечения.Добавить(СтрокаТЧ.ДокументАванса);
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
		КонецЦикла;
		// Дополним массивы	документами, содержавшимися в строках, которые мы удалили	
		Если ДополнительныеСвойства.Свойство("ТаблицаУдаленныхСтрок") Тогда 
			ТаблицаУдаляемыхСтрок = ДополнительныеСвойства.ТаблицаУдаленныхСтрок.Выгрузить();
			ТаблицаУдаляемыхСтрок.Свернуть("КлючСтроки, ДокументАванса");
			Если ДополнительныеСвойства.ТаблицаУдаленныхСтрок.Количество() > 0 Тогда			
				ТаблицаДокументовАванса = ДополнительныеСвойства.ТаблицаУдаленныхСтрок.Выгрузить(, "ДокументАванса");			
				ТаблицаДокументовАванса.Свернуть("ДокументАванса");
				
				Для Каждого ДокументАванса Из ТаблицаДокументовАванса Цикл 
					Если ТипЗнч(ДокументАванса.ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда 
						Если МассивНарядЗаказов.Найти(ДокументАванса.ДокументАванса) = Неопределено Тогда  
							МассивНарядЗаказов.Добавить(ДокументАванса.ДокументАванса);
						КонецЕсли;
					ИначеЕсли ТипЗнч(ДокументАванса.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда	
						Если МассивПлановЛечения.Найти(ДокументАванса.ДокументАванса) = Неопределено Тогда  
							МассивПлановЛечения.Добавить(ДокументАванса.ДокументАванса);
						КонецЕсли;
					КонецЕсли;	
				КонецЦикла;
			КонецЕсли;	
		Иначе 
			ТаблицаУдаляемыхСтрок = Неопределено;
		КонецЕсли;
		
		ЗаполнитьРеквизитПриемВПланеЛечения____И____ПроставитьСоответствующиеСтатусы(МассивПлановЛечения, ТаблицаУдаляемыхСтрок, РежимЗаписиПриема, Отказ);
		ЗаполнитьРеквизитПриемВНарядЗаказе____И____ПроставитьСоответствующиеСтатусы(МассивНарядЗаказов, ТаблицаУдаляемыхСтрок, РежимЗаписиПриема, Отказ);
		ПометкаУдаления_Переменная = ПометкаУдаления;
		ЭтотОбъект.Прочитать();
		ПометкаУдаления = ПометкаУдаления_Переменная;
	КонецЕсли;
			
КонецПроцедуры

//
//
Процедура ЗаполнитьРеквизитПриемВПланеЛечения____И____ПроставитьСоответствующиеСтатусы(МассивПлановЛечения, ТаблицаУдаляемыхСтрок, РежимЗаписиПриема, Отказ)	
	
	Если НЕ Отказ Тогда 
		Для Каждого ПланЛечения Из МассивПлановЛечения Цикл 
			МассивНайденныхСтрок 	= Лечение.НайтиСтроки(Новый Структура("ДокументАванса", ПланЛечения));
			МассивУдаляемыхСтрок	= ?(ТаблицаУдаляемыхСтрок = Неопределено, Новый Массив, ТаблицаУдаляемыхСтрок.НайтиСтроки(Новый Структура("ДокументАванса", ПланЛечения)));
			Если МассивНайденныхСтрок.Количество() > 0 ИЛИ МассивУдаляемыхСтрок.Количество() > 0 Тогда 
				ПланЛеченияОбъект = ПланЛечения.ПолучитьОбъект();
				
				Для Каждого УдаляемаяСтрока Из МассивУдаляемыхСтрок Цикл 
					СтрокаТЧЛечение_План = ПланЛеченияОбъект.Лечение.Найти(УдаляемаяСтрока.КлючСтроки, "КлючСтроки");
					Если СтрокаТЧЛечение_План <> Неопределено Тогда				
						СтрокаТЧЛечение_План.Прием = Документы.Прием.ПустаяСсылка();		
					КонецЕсли;
				КонецЦикла;
				
				Для Каждого НайденнаяСтрока Из МассивНайденныхСтрок Цикл 
					СтрокаТЧЛечение_План = ПланЛеченияОбъект.Лечение.Найти(НайденнаяСтрока.КлючСтроки, "КлючСтроки");
					Если СтрокаТЧЛечение_План <> Неопределено Тогда				
						Если РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда
							СтрокаТЧЛечение_План.Прием = Документы.Прием.ПустаяСсылка();
						Иначе
							Если ЗначениеЗаполнено(СтрокаТЧЛечение_План.Прием) И НЕ СтрокаТЧЛечение_План.Прием = Ссылка Тогда 
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приём не может быть проведен, так как данные услуги уже проведенны в " + Строка(СтрокаТЧЛечение_План.Прием) + " ! ");
								Отказ = Истина;
								Возврат;
							Иначе 
								// Проверка совпадения значений реквизитов ТЧ на случай, если Прием создали на основании, но не провели.
								// После, изменили значения в строках документа основания (в нашем случае это ПланЛечения) и провели.
								Если Строка(СтрокаТЧЛечение_План.НомерПриема) 	= НайденнаяСтрока.НомерЗаказа 			И
									СтрокаТЧЛечение_План.Зуб 					= НайденнаяСтрока.Зуб 					И 
									СтрокаТЧЛечение_План.Номенклатура 			= НайденнаяСтрока.Номенклатура 			И 
									СтрокаТЧЛечение_План.Упаковка 				= НайденнаяСтрока.Упаковка 				И
									СтрокаТЧЛечение_План.Количество	    		= НайденнаяСтрока.КоличествоУпаковок 	Тогда // И
									// СтрокаТЧЛечение_План.Сумма 					= НайденнаяСтрока.Сумма 				Тогда
									
									// Пишем Ссылку
									СтрокаТЧЛечение_План.Прием = Ссылка;
								Иначе
									Если ДополнительныеСвойства.Свойство("ОбновлениеИнформационнойБазы") Тогда
										Если ДополнительныеСвойства.ОбновлениеИнформационнойБазы Тогда 
											// ничего не выводим
										Иначе	
											ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приём не может быть проведен, так как в документе основания (" + Строка(ПланЛечения) + ") были изменены значения в строках табличной части ""Лечение""! ");
											Отказ = Истина;
											Возврат;
										КонецЕсли;
									Иначе
										ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Приём не может быть проведен, так как в документе основания (" + Строка(ПланЛечения) + ") были изменены значения в строках табличной части ""Лечение""! ");
										Отказ = Истина;
										Возврат;
									КонецЕсли;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;	
					КонецЕсли;
				КонецЦикла;
				// Проставим статус Плану лечения
				Выполнен = Истина;
				Для Каждого СтрокаТЧПланаЛечения Из ПланЛеченияОбъект.Лечение Цикл 
					Если НЕ ЗначениеЗаполнено(СтрокаТЧПланаЛечения.Прием) Тогда
						Выполнен = Ложь;
						Прервать;
					ИначеЕсли ТипЗнч(СтрокаТЧПланаЛечения.Прием) = Тип("ДокументСсылка.НарядЗаказ") Тогда 
						НайденСтр =  СтрокаТЧПланаЛечения.Прием.Запасы.Найти(СтрокаТЧПланаЛечения.КлючСтроки, "КлючСтроки");
						Если НайденСтр <> Неопределено Тогда 
							Если НЕ ЗначениеЗаполнено(НайденСтр.Прием) Тогда 
								Выполнен = Ложь;
								Прервать;
							КонецЕсли;
						КонецЕсли;	
					КонецЕсли;	
				КонецЦикла;	
				Если Выполнен Тогда 
					ПланЛеченияОбъект.Статус = Перечисления.СтатусыПланЛечения.Закрыт;
				ИначеЕсли РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда
					ПланЛеченияОбъект.Статус = Перечисления.СтатусыПланЛечения.Принят;
				КонецЕсли;	
				
				ПланЛеченияОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
				ПланЛеченияОбъект.Записать(РежимЗаписиДокумента.Запись);
				
			КонецЕсли;		
		КонецЦикла;			
	КонецЕсли;	
	
	#Область __________________________________________________СтарыйМеханизм____________________________________________________________

	
	
	// Если Проведен Тогда
	//	Для Каждого СтрокаЛ Из Лечение Цикл
	//		Если ЗначениеЗаполнено(СтрокаЛ.ДокументАванса) И ТипЗнч(СтрокаЛ.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда 
	//			Выполнен = Истина;
	//			ПланЛеченияОбъект = СтрокаЛ.ДокументАванса.ПолучитьОбъект();
	//			Для Каждого СтрокаТЧ Из ПланЛеченияОбъект.Лечение Цикл 
	//				Для Каждого СтрокаТЗ Из Лечение Цикл 
	//					Если СтрокаЛ.ДокументАванса = СтрокаТЗ.ДокументАванса 		И
	//						СтрокаТЧ.НомерПриема 	= СтрокаТЗ.НомерЗаказа 			И
	//						СтрокаТЧ.Зуб 			= СтрокаТЗ.Зуб 					И 
	//						СтрокаТЧ.Номенклатура 	= СтрокаТЗ.Номенклатура 		И 
	//						СтрокаТЧ.Упаковка 		= СтрокаТЗ.Упаковка 			И 
	//						СтрокаТЧ.Количество	    = СтрокаТЗ.КоличествоУпаковок 	Тогда // И
	//						// СтрокаТЧ.Сумма 		= СтрокаТЗ.Сумма 				Тогда
	//						Если РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда 
	//							СтрокаТЧ.Прием         = Документы.Прием.ПустаяСсылка();
	//							СтрокаТЧ.ПризнакВыбора = Истина;  // помоему уже не используется
	//						Иначе  
	//							СтрокаТЧ.Прием         = Ссылка;
	//							СтрокаТЧ.ПризнакВыбора = Ложь;   // помоему уже не используется
	//						КонецЕсли;
	//					КонецЕсли;	 
	//				КонецЦикла;
	//				Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Прием) Тогда 
	//					Выполнен = Ложь;
	//				КонецЕсли;	
	//			КонецЦикла;
	//			Если Выполнен Тогда 
	//				ПланЛеченияОбъект.Статус = Перечисления.СтатусыПланЛечения.Закрыт;
	//			ИначеЕсли РежимЗаписиПриема = РежимЗаписиДокумента.ОтменаПроведения Тогда
	//				ПланЛеченияОбъект.Статус = Перечисления.СтатусыПланЛечения.Принят;
	//			КонецЕсли;	
	//			ПланЛеченияОбъект.Записать(РежимЗаписиДокумента.Запись);
