// Процедура, заполняет параметры платежного шлюза.
//
Процедура ЗаполнитьПараметрыПлатежногоШлюза()
	
	ПараметрыПШ = Объект.Ссылка.ПараметрыПлатежногоШлюза.Получить();
	Если ТипЗнч(ПараметрыПШ) = Тип("Структура") Тогда
		
		ЭтотОбъект.UrlRedirect               	= ПараметрыПШ.UrlRedirect;
		ЭтотОбъект.URLБанка                  	= ПараметрыПШ.URLБанка;
		ЭтотОбъект.ЛогинБанка                	= ПараметрыПШ.ЛогинБанка;
		ЭтотОбъект.ПарольБанка               	= ПараметрыПШ.ПарольБанка;
		ЭтотОбъект.ТестовыйРежим             	= ПараметрыПШ.ТестовыйРежим;
		ЭтотОбъект.ВремяЖизниСсылкиНаОплату  	= ПараметрыПШ.ВремяЖизни;
		ЭтотОбъект.КлючТерминалаТинькофф     	= ПолучитьЗначениеИзСтруктуры(ПараметрыПШ, "КлючТерминалаТинькофф");
		ЭтотОбъект.СекретныйКлючТинькофф     	= ПолучитьЗначениеИзСтруктуры(ПараметрыПШ, "СекретныйКлючТинькофф");
		ЭтотОбъект.ЗакрытыйКлюч    			 	= ПолучитьЗначениеИзСтруктуры(ПараметрыПШ, "ЗакрытыйКлюч");
		ЭтотОбъект.IDТерминала    			 	= ПолучитьЗначениеИзСтруктуры(ПараметрыПШ, "IDТерминала");
		ЭтотОбъект.IDQR    			 			= ПолучитьЗначениеИзСтруктуры(ПараметрыПШ, "IDQR");
		
	КонецЕсли;	
	
