
#Область СлужебныйПрограммныйИнтерфейс

// Рассчитывает сумму в строке табличной части документа
//
// Параметры:
//  СтрокаТабличнойЧасти - строка табличной части документа,
//  ДокументОбъект       - объект редактируемого документа,
//                         "Без учета ручной скидки", сумма минус автоматические скидки;
//                         "Без учета скидок", сумма (Цена * Количество);
//
Процедура РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, СтруктураПараметров = Неопределено) Экспорт
	
	Если СтруктураПараметров = Неопределено Тогда
		СтруктураПараметров = Новый Структура();
	КонецЕсли;
	
	Если ТипЗнч(СтрокаТабличнойЧасти) = Тип("ДанныеФормыЭлементКоллекции") И СтрокаТабличнойЧасти.Свойство("КоличествоУпаковок")
		ИЛИ СтруктураПараметров.Свойство("ЕстьКолонкаКоличествоУпаковок") И СтруктураПараметров.ЕстьКолонкаКоличествоУпаковок Тогда
		Сумма = СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.КоличествоУпаковок;
	ИначеЕсли ТипЗнч(СтрокаТабличнойЧасти) <> Тип("ДанныеФормыЭлементКоллекции") 
		И (ТипЗнч(СтрокаТабличнойЧасти) = Тип("ДокументТабличнаяЧастьСтрока.ВозвратОтПокупателя.Запасы") 
		ИЛИ ТипЗнч(СтрокаТабличнойЧасти) = Тип("ДокументТабличнаяЧастьСтрока.ВозвратОтПокупателя.Лечение")) Тогда 
		Сумма = СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.КоличествоУпаковок;
	Иначе
		Сумма = СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.Количество;
	КонецЕсли;
	
	СуммаСкидки = 0;                                    	
	
	// Для док.: "НарядЗаказ".
	Если ТипЗнч(СтрокаТабличнойЧасти) = Тип("ДанныеФормыЭлементКоллекции") И СтрокаТабличнойЧасти.Свойство("СуммаПродажи") Тогда
		
		Сумма       = СтрокаТабличнойЧасти.ЦенаПродажи * ?(СтрокаТабличнойЧасти.Свойство("КоличествоУпаковок"), СтрокаТабличнойЧасти.КоличествоУпаковок, СтрокаТабличнойЧасти.Количество);
		СуммаСкидки = СуммаСкидки + СтрокаТабличнойЧасти.СуммаАвтоматическойСкидкиНаценки;
		
		СтрокаТабличнойЧасти.СуммаПродажи = Сумма - СуммаСкидки;
		СтрокаТабличнойЧасти.ВсегоПродажи = СтрокаТабличнойЧасти.СуммаПродажи;  
		
		Если СтруктураПараметров.Свойство("ПорядокОкругления") И СтруктураПараметров.Свойство("ОкруглятьВБольшуюСторону") Тогда
			СтрокаТабличнойЧасти.СуммаПродажи = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(СтрокаТабличнойЧасти.СуммаПродажи, СтруктураПараметров.ПорядокОкругления, СтруктураПараметров.ОкруглятьВБольшуюСторону);
		КонецЕсли;
		
	Иначе 
		Если ТипЗнч(СтрокаТабличнойЧасти) = Тип("ДанныеФормыЭлементКоллекции") И СтрокаТабличнойЧасти.Свойство("СуммаРучнойСкидки")
			ИЛИ СтруктураПараметров.Свойство("ЕстьКолонкаПроцентСкидкиНаценки") И СтруктураПараметров.ЕстьКолонкаПроцентСкидкиНаценки Тогда
			СуммаСкидки = СтрокаТабличнойЧасти.СуммаРучнойСкидки;
		КонецЕсли;
		
		Если ТипЗнч(СтрокаТабличнойЧасти) = Тип("ДанныеФормыЭлементКоллекции") И СтрокаТабличнойЧасти.Свойство("СуммаАвтоматическойСкидкиНаценки")
			ИЛИ СтруктураПараметров.Свойство("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки") И СтруктураПараметров.ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки Тогда
			СуммаСкидки = СуммаСкидки + СтрокаТабличнойЧасти.СуммаАвтоматическойСкидкиНаценки;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.Сумма = Сумма - СуммаСкидки;
		Если СтруктураПараметров.Свойство("ПорядокОкругления") И СтруктураПараметров.Свойство("ОкруглятьВБольшуюСторону") Тогда
			СтрокаТабличнойЧасти.Сумма = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(СтрокаТабличнойЧасти.Сумма, СтруктураПараметров.ПорядокОкругления, СтруктураПараметров.ОкруглятьВБольшуюСторону);
		КонецЕсли;
	КонецЕсли;	

КонецПроцедуры // РассчитатьСуммуТабЧасти()

// Процедура, пересчитывает процент ручной скидки
//
Процедура ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(ТекущаяСтрока, ИспользоватьКоличество = Ложь)  Экспорт
	
	Если ИспользоватьКоличество <> Истина Тогда
		Если ТекущаяСтрока.КоличествоУпаковок * ТекущаяСтрока.Цена <> 0 Тогда
			ТекущаяСтрока.ПроцентСкидкиНаценки = Окр(100*ТекущаяСтрока.СуммаРучнойСкидки / (ТекущаяСтрока.КоличествоУпаковок *ТекущаяСтрока.Цена), 2);
		Иначе
			ТекущаяСтрока.ПроцентСкидкиНаценки = 0;
		КонецЕсли;	
	Иначе
		Если ТекущаяСтрока.Количество * ТекущаяСтрока.Цена <> 0 Тогда
			ТекущаяСтрока.ПроцентСкидкиНаценки = Окр(100*ТекущаяСтрока.СуммаРучнойСкидки / (ТекущаяСтрока.Количество *ТекущаяСтрока.Цена), 2);
		Иначе
			ТекущаяСтрока.ПроцентСкидкиНаценки = 0;
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

// Процедура, пересчитывает сумму ручной скидки
//
Процедура ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(ТекущаяСтрока, ИспользоватьКоличество = Ложь)  Экспорт

	Если ИспользоватьКоличество <> Истина Тогда
		ТекущаяСтрока.СуммаРучнойСкидки = Окр(ТекущаяСтрока.КоличествоУпаковок * ТекущаяСтрока.Цена * ТекущаяСтрока.ПроцентСкидкиНаценки / 100, 2);
	Иначе
		ТекущаяСтрока.СуммаРучнойСкидки = Окр(ТекущаяСтрока.Количество * ТекущаяСтрока.Цена * ТекущаяСтрока.ПроцентСкидкиНаценки / 100, 2);
	КонецЕсли;

КонецПроцедуры

// Расчет, исходя из постоянной суммы
//
// Параметры:
//  СтрокаТабличнойЧасти - строка табличной части документа,
//  ДокументОбъект       - объект редактируемого документа.
//
Процедура РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти) Экспорт
	
	СтрокаТабличнойЧасти.СуммаНДС = Ценообразование.РассчитатьСуммуНДС(СтрокаТабличнойЧасти.Сумма, СтрокаТабличнойЧасти.СтавкаНДС);
	
КонецПроцедуры // РассчитатьСуммуНДСТабЧасти()

// Процедура, рассчитывает сумму колонки "Всего" в табличной части документа.
//  Параметры:
//   СтрокаТабличнойЧасти - текущая строка табличной части документа.
//
Процедура РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти, УчитыватьСуммуРасходов = Ложь) Экспорт 
	
	Сумма = СтрокаТабличнойЧасти.Сумма;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТабличнойЧасти, "Рекламация") 
		И ЗначениеЗаполнено(СтрокаТабличнойЧасти.Рекламация) Тогда
		Сумма = 0;
	КонецЕсли;
	
	СтрокаТабличнойЧасти.Всего = Сумма;
	Если УчитыватьСуммуРасходов Тогда
				
		СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Всего + СтрокаТабличнойЧасти.СуммаРасходов;
	КонецЕсли;

КонецПроцедуры

