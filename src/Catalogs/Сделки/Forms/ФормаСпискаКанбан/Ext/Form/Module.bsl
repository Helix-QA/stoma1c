&НаСервере
// Функция, возвращает данные.
//
Функция ПолучитьПредставлениеБлоков(ДанныеСделок)
	
	БлокиКанбана = Новый Массив;
	
	Пока ДанныеСделок.Следующий() Цикл
		
		Выборка = ДанныеСделок.Выбрать();
		
		БлокСделок = Новый Массив;
		
		КоличествоБлоков = 0;
		
		Пока Выборка.Следующий() Цикл
			
			Если Не ЗначениеЗаполнено(Выборка.Сделка) Тогда
				Продолжить;
			КонецЕсли;
			
			Если КоличествоБлоков = ЭтотОбъект.МаксимальноеКоличествоСделокВКолонке Тогда
				Прервать;
			КонецЕсли;
			
			БлокСделок.Добавить(ПолучитьБлокСделкиДляФормированияКанбана(Выборка));
			КоличествоБлоков = КоличествоБлоков + 1;
			
		КонецЦикла;
		
		Количество = ?(КоличествоБлоков = 0, 0, Выборка.Количество());
		БлокиКанбана.Добавить(ПолучитьБлокКолонки(ДанныеСделок, БлокСделок, Количество));
		
	КонецЦикла;
	
	ПредставлениеБлоковКанбана = СтрСоединить(БлокиКанбана, "," + Символы.ПС);
	
	Возврат ПредставлениеБлоковКанбана;
	
КонецФункции

