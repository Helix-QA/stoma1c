	|		КОГДА &ДатаРождения = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
	|			ТОГДА ""История""
	|		ИНАЧЕ ""Запланировано""
	|	КОНЕЦ,
	|	NULL,
