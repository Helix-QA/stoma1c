// Процедура - Заполнить список каналов системы сообщения
//
Процедура ЗаполнитьСписокКаналовСистемыСообщения(ЭлементФормы, ИндексСтроки, СтрокаНастройкиКаналовУведомлений)
	
	Если НЕ ЭлементФормы = Неопределено Тогда 
		ЭлементФормы.Видимость = Ложь;		
		ЭлементФормы.СписокВыбора.Очистить();
		Если ЗначениеЗаполнено(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы) И ТипЗнч(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы) = Тип("СправочникСсылка.ВнешниеСистемы") Тогда 
			МассивСтрокВнешниСистем = ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("Ссылка", СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы));
			Если НЕ МассивСтрокВнешниСистем.Количество() = 0 Тогда 
				ТипВнешнейСистемы = МассивСтрокВнешниСистем[0].ТипВнешнейСистемы;
			Иначе 
				ТипВнешнейСистемы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы, "ТипВнешнейСистемы");
			КонецЕсли;
			
			Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk Тогда 
				ЭлементФормы.Видимость = Истина;			
				МассивКаналов = МессенджерСтоматология.ПолучитьКаналыChat2Desk(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы);
				Для Каждого ЭлементКанал Из МассивКаналов Цикл 
					ЭлементФормы.СписокВыбора.Добавить(ЭлементКанал.Значение, ЭлементКанал.Имя + " (" + Строка(ЭлементКанал.Значение) + ")", СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений = ЭлементКанал.Значение);
				КонецЦикла;
				Если ЗначениеЗаполнено(СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений) Тогда 
					ЭлементСпискаКанал = ЭлементФормы.СписокВыбора.НайтиПоЗначению(СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений);
					Если ЭлементСпискаКанал = Неопределено Тогда 
						ЭлементФормы.СписокВыбора.Добавить(СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений, Новый ФорматированнаяСтрока("Канал деактивирован (" + СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений + ")", , Новый Цвет(255, 0, 0)), Истина);
					КонецЕсли;
				КонецЕсли;
				Если ЭлементФормы.СписокВыбора.Количество() = 0 Тогда 
					ЭлементФормы.ПодсказкаВвода = НСтр("ru = 'Каналы сообщений не найдены'; en = 'Message channels are not found'");
				Иначе 
					ЭлементФормы.ПодсказкаВвода = НСтр("ru = 'Выберите канал сообщений'; en = 'Select a message channel'");
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Инициализировать структуру параметров отрисовки
//
// Параметры:
//  Объект	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСтруктуруПараметровОтрисовки(ИнициализироватьМассивАккаунтовСистемыОтправки = Истина, ИндексСтроки = Неопределено) Экспорт
	
	ПараметрыОтрисовки = Новый Структура;
	
	// Подготовка сервисов рассылки сообщений.	
	СервисыРассылки = Новый Структура;
	СервисыРассылки.Вставить("Push"     	, Неопределено);
	СервисыРассылки.Вставить("PushWallet"   , Неопределено);
	СервисыРассылки.Вставить("Messenger"	, Неопределено);
	СервисыРассылки.Вставить("SMS"      	, Неопределено);
	
	//Если ИнициализироватьМассивАккаунтовСистемыОтправки Тогда
	//	ПараметрыОтрисовки.Вставить("МассивАккаунтовСистемыОтправкиСообщений", ТаблицаВнешнихСистем.Выгрузить().ВыгрузитьКолонку("Ссылка"));
	//Иначе 
	//	ПараметрыОтрисовки.Вставить("МассивАккаунтовСистемыОтправкиСообщений", Новый Массив);
	//КонецЕсли;

	СтрокаНастроекКаналов = Неопределено;
	Если НЕ ИндексСтроки = Неопределено Тогда
		СтрокаНастроекКаналов = МоделируемыеНастройкиКаналовУведомлений[ИндексСтроки];
	Иначе 
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("СтруктурнаяЕдиница"	, ТекущаяСтруктурнаяЕдиница);
		СтруктураПоиска.Вставить("ИдентификаторДействия", ИдентификаторДействия);
		МассивСтрокНастроекКаналов = МоделируемыеНастройкиКаналовУведомлений.НайтиСтроки(СтруктураПоиска);
		Если НЕ МассивСтрокНастроекКаналов.Количество() = 0 Тогда 
			СтрокаНастроекКаналов = МассивСтрокНастроекКаналов[0];
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ СтрокаНастроекКаналов = Неопределено Тогда 
		// Сервис Push-уведомлений
		Если НЕ СтрокаНастроекКаналов.СписокАккаунтовPush.Количество() = 0 Тогда 
			СервисыРассылки.Push = СтрокаНастроекКаналов.СписокАккаунтовPush[0].Значение; 
		КонецЕсли;
		// Сервис Push Wallet
		Если НЕ СтрокаНастроекКаналов.СписокАккаунтовPushWallet.Количество() = 0 Тогда 
			СервисыРассылки.PushWallet = СтрокаНастроекКаналов.СписокАккаунтовPushWallet[0].Значение; 
		КонецЕсли;
		// Сервисы мессенджера
		СервисыMessenger = Новый Структура;
		СервисыMessenger.Вставить("GreenApi", Справочники.ВнешниеСистемы.ПустаяСсылка());
		Для Каждого ЭлементСервисMessenger Из СтрокаНастроекКаналов.СписокАккаунтовMessenger Цикл
			МассивСтрокВнешнихСистем = ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("Ссылка", ЭлементСервисMessenger.Значение));
			Если НЕ МассивСтрокВнешнихСистем.Количество() = 0 Тогда 
				Если МассивСтрокВнешнихСистем[0].ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда 
					СервисыMessenger.Вставить("GreenApi", ЭлементСервисMessenger.Значение);
				КонецЕсли;				
			КонецЕсли;
			Если ЗначениеЗаполнено(СервисыMessenger.GreenApi) Тогда 
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		СервисыРассылки.Messenger 	= СервисыMessenger;
		ОтправкаMessenger 			= ЗначениеЗаполнено(СервисыРассылки.Messenger.GreenApi);
		// Сервис sms-рассылки
		Если НЕ СтрокаНастроекКаналов.СписокАккаунтовSMS.Количество() = 0 Тогда 		
			СервисыРассылки.SMS 		= СтрокаНастроекКаналов.СписокАккаунтовSMS[0].Значение;
		КонецЕсли;	
	Иначе 
		
#Область СТАРЫЙ_МЕХАНИЗМ_ОПРЕДЕЛНИЯ_СЕРВИСОВ_РАССЫЛКИ_2
		
		// Сервис Push-уведомлений.
		СервисыРассылки.Push = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента, Истина);
		
		// Сервис Push Wallet 	
		СервисыРассылки.PushWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);
		
		// Севисы мессенджера.
		СервисыMessenger = Новый Структура;
		СервисыMessenger.Вставить("GreenApi", Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.GreenApi, Истина));
		
		СервисыРассылки.Messenger = СервисыMessenger;
		
		ОтправкаMessenger = ЗначениеЗаполнено(СервисыРассылки.Messenger.GreenApi);
		
		// Сервис sms-рассылки.
		СервисыРассылки.SMS = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.СервисSMSРассылки;
		СервисыРассылки.SMS = ?(Не ЗначениеЗаполнено(СервисыРассылки.SMS), Константы.СервисSMSРассылкиПоУмолчанию.Получить(), СервисыРассылки.SMS);
		
#КонецОбласти
		
	КонецЕсли;				
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("СервисыРассылки"  	, СервисыРассылки);
	ПараметрыРассылки.Вставить("ОтправкаPush"     	, ЗначениеЗаполнено(СервисыРассылки.Push));
	ПараметрыРассылки.Вставить("ОтправкаPushWallet" , ЗначениеЗаполнено(СервисыРассылки.PushWallet));
	ПараметрыРассылки.Вставить("ОтправкаMessenger"	, ОтправкаMessenger);
	ПараметрыРассылки.Вставить("ОтправкаSMS"      	, ЗначениеЗаполнено(СервисыРассылки.SMS));
	
	ПараметрыОтрисовки.Вставить("ПараметрыРассылки"	, ПараметрыРассылки);
	
	СтрокаНастроекКаналов.ПараметрыОтрисовки = ПараметрыОтрисовки;
	
	Возврат ПараметрыОтрисовки;
	
КонецФункции

#КонецОбласти









