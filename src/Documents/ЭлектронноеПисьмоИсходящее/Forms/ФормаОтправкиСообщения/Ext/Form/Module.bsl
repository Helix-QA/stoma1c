&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ПерейтиВЧат(Команда)
	
	//Если Не ЗначениеЗаполнено(ЭтотОбъект.ВнешняяСистемаМессенджера) Тогда
	//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Выберите внешнюю систему мессенджера'; en = 'Choose messenger external system'"));
	//	Возврат;
	//КонецЕсли;
	
	ДанныеКанала = ТаблицаКаналовРассылки.НайтиПоИдентификатору(ЭтотОбъект.ИдентификаторКаналаМессенджер);
	
	Если ДанныеКанала = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПерейтиВЧатЗавершение(ДанныеКанала);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения перехода в чат мессенджера.
//
Процедура ПерейтиВЧатЗавершение(ДанныеКанала)
	
	ОписаниеОшибки = "";
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ОбъектСсылка = Контрагент;
	Иначе
		ОбъектСсылка = Заявка; 
	КонецЕсли;
	
	ИдСообщения = УстановитьОжиданиеСообщения(ДанныеКанала.ИдКлиента, ДанныеКанала.ВнешняяСистема, ОписаниеОшибки, ОбъектСсылка, ДанныеКанала.НомерМессенджера);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ДанныеКаналаСтруктура = Новый Структура;
	ДанныеКаналаСтруктура.Вставить("ИдКлиента"		, ДанныеКанала.ИдКлиента);
	ДанныеКаналаСтруктура.Вставить("ВнешняяСистема"	, ДанныеКанала.ВнешняяСистема);
	ДанныеКаналаСтруктура.Вставить("ИдСообщения"	, ИдСообщения);
	
	ПараметрыОткрытия = Новый Структура("ДанныеКанала", ДанныеКаналаСтруктура);
	
	Оповестить("ОткрытьДиалог", ПараметрыОткрытия);
	ОткрытьФорму("Обработка.Мессенджер_Стоматология.Форма", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.Независимый);
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

