&НаКлиенте
// Процедура, обработчик команды ДобавитьИВыбратьКонтрагента
//
Процедура ДобавитьИВыбратьКонтрагента()
	
	ГруппаКлиентов = ОбщегоНазначенияСтоматология.ВернутьГруппуКлиентов();	
	ФИО = ОбщегоНазначенияКлиентСтоматология.ВернутьФИОКлиента(ИскомыйКлиент);	
	ТекущийРодитель = ?(ЗначениеЗаполнено(ГруппаКлиентов), ГруппаКлиентов, ГруппаКонтрагентов); 	

	ПараметрыОткрытияФормы = Новый Структура; 	
	ПараметрыОткрытияФормы.Вставить("ТекущийРодитель", ТекущийРодитель);
	ПараметрыОткрытияФормы.Вставить("Фамилия", ФИО.Фамилия);
	ПараметрыОткрытияФормы.Вставить("Имя", ФИО.Имя);
	ПараметрыОткрытияФормы.Вставить("Отчество", ФИО.Отчество);
	ПараметрыОткрытияФормы.Вставить("Наименование", ЗапонитьНаименование(ФИО));	
	ПараметрыОткрытияФормы.Вставить("Пол", ЗапонитьПол(ФИО));
	
	Оповещение = Новый ОписаниеОповещения("ДобавитьИВыбратьКонтрагентаЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", ПараметрыОткрытияФормы, ЭтаФорма,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить и выбрать контрагента завершение
//
Процедура ДобавитьИВыбратьКонтрагентаЗавершение(Результат, ДопПараметры) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
		
	Если ТипЗнч(Результат) = Тип("СправочникСсылка.Контрагенты") Тогда
		Контрагент = Результат;
	КонецЕсли;
	КонтрагентПриИзменении(Неопределено);	
	
КонецПроцедуры

&НаКлиенте
// Функция - Запонить наименование
//
Функция ЗапонитьНаименование(ИскомыйКлиент)
	
	Возврат (ИскомыйКлиент.Фамилия + ?(ЗначениеЗаполнено(ИскомыйКлиент.Фамилия), " ", "") +
			 ИскомыйКлиент.Имя + ?(ЗначениеЗаполнено(ИскомыйКлиент.Имя), " ", "") +
			 ИскомыйКлиент.Отчество);
	
КонецФункции

&НаКлиенте
// Функция - Запонить пол
//
Функция ЗапонитьПол(ИскомыйКлиент)
	
	ПолКлиента = ОбщегоНазначенияКлиентПовтИспСтоматология.ОпределитьПолКлиента(ИскомыйКлиент.Фамилия, ИскомыйКлиент.Имя, ИскомыйКлиент.Отчество);
	Возврат ?(ПолКлиента = "Мужской", ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Мужской"),
			?(ПолКлиента = "Женский", ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Женский"), Неопределено));
	
КонецФункции

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура КонтрагентПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Контрагент, Объект.СтруктурнаяЕдиница); 
	КонецЕсли;
	УстановитьВидимостьКнопокПереходаВМессенджер(ЭтотОбъект, Не ЗначениеЗаполнено(Контрагент));
	
	ЗаполнитьДанныеПоКонтрагенту(Контрагент);	
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "ЗаполнитьДанныеПоКонтрагенту"
//
Процедура ЗаполнитьДанныеПоКонтрагенту(Контрагент)
	
	ПодготовитьДанныеДляВыводаИнформацииПоКлиенту(Контрагент, Объект.СтруктурнаяЕдиница, ИнформацияКлиента, ШиринаИнформацииПоКлиенту, РазрешениеЭкрана);
	
	Если ЗначениеЗаполнено(Контрагент) Тогда 
		ПроверитьТекущиеНапоминанияПоПосещениямСтоматология(Контрагент);
	КонецЕсли;	
	
КонецПроцедуры	

