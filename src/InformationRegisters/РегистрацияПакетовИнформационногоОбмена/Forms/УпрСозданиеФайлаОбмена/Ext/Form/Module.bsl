///
Функция ФорматДаты(Дата)
	
	Возврат Формат(Дата,"ДФ=""гггг-ММ-дд""");
	
КонецФункции

 // Процедура: ТипFFOMS
 //   Получает тип XDTO по имени типа из пространства имен ffoms:order:79:2011-04-07
 // 
 // Параметры:
 ///
Функция ТипFFOMS(ИмяТипа, Фабрика_XDTO = Неопределено)
	
	ПространствоИмен = "ffoms:order:79:2011-04-07";	
		
	Если Фабрика_XDTO = Неопределено Тогда
		Возврат ФабрикаXDTO.Пакеты.Получить(ПространствоИмен).Получить(ИмяТипа);
	Иначе
		Возврат Фабрика_XDTO.Пакеты.Получить(ПространствоИмен).Получить(ИмяТипа);
	КонецЕсли;
	
