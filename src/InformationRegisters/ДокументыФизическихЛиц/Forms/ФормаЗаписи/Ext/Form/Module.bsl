
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Запись.Физлицо) И ТипЗнч(Запись.Физлицо) = Тип("СправочникСсылка.Сотрудники") Тогда
		Элементы.Физлицо.Заголовок = "Сотрудник";
		Элементы.Физлицо.ВыбиратьТип = Ложь;
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(Запись.Физлицо) И ТипЗнч(Запись.Физлицо) = Тип("СправочникСсылка.Контрагенты") Тогда
		Элементы.Физлицо.Заголовок = "Контрагент";
		Элементы.Физлицо.ВыбиратьТип = Ложь;
	КонецЕсли;
	
	Если Параметры.Свойство("Контрагент") И ЗначениеЗаполнено(Параметры.Контрагент) Тогда
		
		Запись.Физлицо = Параметры.Контрагент;
		Элементы.Физлицо.ТолькоПросмотр = Истина;
		
	КонецЕсли;
	
	ЗаполнитьСписокВыбораВидаДокумента();
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаписьДокумента = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
	ЗаписьДокумента.Физлицо = ТекущийОбъект.ФизЛицо;
	ЗаписьДокумента.ВидДокумента = ТекущийОбъект.ВидДокумента;
	ЗаписьДокумента.Прочитать();
	
	Если НЕ ЗаписьДокумента <> Неопределено Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данная запись уже существует!");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды "ЗаписатьИЗакрыть".
//
Процедура ЗаписатьИЗакрыть(Команда)
	
	ЭтаФорма.Записать();
	Закрыть();
	Оповестить("ОбновленыУдостоверения");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ВидДокументаПриИзменении(Элемент)
	
	Если ЯвляетсяУдостоверениемЛичности(Запись.Физлицо, Запись.ВидДокумента) Тогда
		Запись.ЯвляетсяДокументомУдостоверяющимЛичность = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Функция, возвращает булево значение ресурса регистра.
//
Функция ЯвляетсяУдостоверениемЛичности(Физлицо, ВидДокумента)
	
	Возврат РегистрыСведений.ДокументыФизическихЛиц.ЯвляетсяУдостоверениемЛичности(Физлицо, ВидДокумента);
	
КонецФункции

&НаСервере
// Процедура - Заполнить список выбора вида документа
//
Процедура ЗаполнитьСписокВыбораВидаДокумента()
	
	Элементы.ВидДокумента.СписокВыбора.Очистить();
	СписокВыбора = Справочники.ВидыДокументовФизическихЛиц.ПолучитьМассивВидов();
	Для каждого Вид Из СписокВыбора Цикл
	
		Элементы.ВидДокумента.СписокВыбора.Добавить(Вид);
	
	КонецЦикла;
	
КонецПроцедуры 


#КонецОбласти