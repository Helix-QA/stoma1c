	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ref</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникКонтрагенты.Ссылка,
	СправочникКонтрагенты.Наименование,
	СправочникКонтрагенты.ДатаРожденияКлиента,
	СправочникКонтрагенты.Фамилия,
	СправочникКонтрагенты.Имя,
	СправочникКонтрагенты.Отчество,
	СправочникКонтрагенты.Телефон,
	СправочникКонтрагенты.Родитель,
	ВЫБОР
		КОГДА СправочникКонтрагенты.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА ДЕНЬГОДА(&amp;ТекущаяДата) &gt; ДЕНЬГОДА(СправочникКонтрагенты.ДатаРожденияКлиента)
						ТОГДА РАЗНОСТЬДАТ(СправочникКонтрагенты.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД)
					ИНАЧЕ (ВЫРАЗИТЬ(РАЗНОСТЬДАТ(СправочникКонтрагенты.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД) КАК ЧИСЛО)) - 1
				КОНЕЦ
	КОНЕЦ КАК Возраст,
	ЕСТЬNULL(СправочникКонтрагенты.ТекущаяМедицинскаяКарта.КодБезНулей, "") КАК НомерМедКарты,
	ВЫБОР
		КОГДА СправочникКонтрагенты.ЭтоГруппа
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ + ВЫБОР
		КОГДА СправочникКонтрагенты.ПометкаУдаления
			ТОГДА 2
		ИНАЧЕ 0
	КОНЕЦ КАК ВариантКартинки
ИЗ
	Справочник.Контрагенты КАК СправочникКонтрагенты
ГДЕ
	НЕ &amp;ЗапретОтображения
	И ВЫБОР
			КОГДА НЕ &amp;Фамилия = ""
				ТОГДА СправочникКонтрагенты.Фамилия ПОДОБНО &amp;Фамилия
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;Имя = ""
				ТОГДА СправочникКонтрагенты.Имя ПОДОБНО &amp;Имя
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;Отчество = ""
				ТОГДА СправочникКонтрагенты.Отчество ПОДОБНО &amp;Отчество
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;Телефон = ""
				ТОГДА СправочникКонтрагенты.Телефон ПОДОБНО &amp;Телефон
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;ДатаРождения = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
				ТОГДА СправочникКонтрагенты.ДатаРожденияКлиента = &amp;ДатаРождения
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА НЕ &amp;НомерМедКарты = ""
				ТОГДА ЕСТЬNULL(СправочникКонтрагенты.ТекущаяМедицинскаяКарта.КодБезНулей, "") ПОДОБНО &amp;НомерМедКарты
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И НЕ СправочникКонтрагенты.ЭтоГруппа
	И НЕ СправочникКонтрагенты.ПометкаУдаления</QueryText>
				<MainTable>Catalog.Контрагенты</MainTable>
