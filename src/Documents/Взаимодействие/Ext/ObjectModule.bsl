
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Дата                    = ТекущаяДата();
	ЗадачаСрокВыполнения    = Дата;
	НапоминаниеИспользовать = Ложь;
	НапоминаниеРежим        = Перечисления.ВариантыНапоминаний.ЗаВремяОтносительноСобытия;
	ВидОперации   			= Перечисления.ВидыОперацийВзаимодействия.ТелефонныйЗвонокВходящий;
	// На основании документа взаимодействия
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Взаимодействие") Тогда
		
		ЗаполнитьНаОснованииВзаимодействия(ДанныеЗаполнения);
		
		// На основании переданной структуры данных	 
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		
		// ВидОперации   = ?(ДанныеЗаполнения.Свойство("ВидОперации"), ДанныеЗаполнения.ВидОперации, ВидОперации);
		ЗадачаПредмет = ?(ДанныеЗаполнения.Свойство("Предмет"), ДанныеЗаполнения.Предмет, ЗадачаПредмет);
		
		Если ДанныеЗаполнения.Свойство("НаОсновании") Тогда			
			ЗаполнитьНаОснованииВзаимодействия(ДанныеЗаполнения.НаОсновании);		
		КонецЕсли;
		
	КонецЕсли;		 
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	
КонецПроцедуры

// Процедура - обработчик события "ПриКопировании" объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	                       
КонецПроцедуры

// Обработка перед записью объекта на сервере
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	

	// Если во взаимодействие вид операции входящий звонок он по умолчанию отработан
	Если ВидОперации = Перечисления.ВидыОперацийВзаимодействия.ТелефонныйЗвонокВходящий Тогда
		ЗадачаОтработана = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Обработчик при записи объекта
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	

	Заглушка = Истина; // Заглушка, чтобы не было пустого обработчика :)
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Заполнить на основании переданного документа взаимодействие
//
Процедура ЗаполнитьНаОснованииВзаимодействия(ДокументСсылка)
	
	ТипОснования = ТипЗнч(ДокументСсылка);
	
	Если ТипОснования = Тип("ДокументСсылка.Взаимодействие") Тогда
		
		СтруктурнаяЕдиница = ДокументСсылка.СтруктурнаяЕдиница;
		АвторДокумента     = ДокументСсылка.АвторДокумента;
		ЗадачаПредмет      = ДокументСсылка.ЗадачаПредмет;
		Задача             = ДокументСсылка.Задача;
		ЗадачаОписание     = ДокументСсылка.ЗадачаОписание;
				
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти
