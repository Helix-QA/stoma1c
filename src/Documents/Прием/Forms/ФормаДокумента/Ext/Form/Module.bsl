&НаКлиенте
// Устанавливает видимость элементов переключателя закладок.
//
Процедура УстановитьОтображениеЭлементовПереключателя(ЭлементИмя = Неопределено)
		
	Элементы._Авансы.Видимость = Объект.УчтенныеАвансы.Количество() > 0 И ЭлементИмя <> "_ГруппаАвансы";
		
