// Функция - Получить организацию салона
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьНаименованиеОрганизации()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Организации.Ссылка.Наименование КАК ОрганизацияНаименование
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	НЕ Организации.ПометкаУдаления");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.ОрганизацияНаименование, Неопределено);
	
КонецФункции

// Получает все подчиненные файлы.
//
// Параметры:
//   ВладелецФайла - ЛюбаяСсылка - владелец файла.
//
// Возвращаемое значение:
//   Массив из СправочникСсылка.Файлы - массив файлов.
//
Функция ПолучитьВсеПодчиненныеФайлы(ВладелецФайла, Описание)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Файлы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Файлы КАК Файлы
	|ГДЕ
	|	Файлы.ВладелецФайла = &ВладелецФайла
	|	И НЕ Файлы.ПометкаУдаления
	|	И (ВЫРАЗИТЬ(Файлы.Описание КАК СТРОКА(100))) = &Описание");
	
	Запрос.УстановитьПараметр("ВладелецФайла", ВладелецФайла);
	Запрос.УстановитьПараметр("Описание"     , Описание);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция, создает или обновляет внешнюю систему в CRM.
//
Функция ОбработкаВнешнейСистемыВ_CRM_Ретранслятор(
		ВнешняяСистема, 
		ТекущаяСессия, 
		Используется = Истина, 
		СтруктураДополнительныхПараметров = Неопределено, 
		loginEvotor = Неопределено, 
		passwordEvotor =  Неопределено) Экспорт
	
	Попытка 
		
		ПользовательПубликации = Константы.ВнешняяПубликацияПользователь.Получить();
		
		Если Не ЗначениеЗаполнено(ПользовательПубликации) Тогда
			
			СлужебныйПользователь = ПользователиСтоматология.СлужебныйПользовательAPI();
			
			Если Не ЗначениеЗаполнено(СлужебныйПользователь) Тогда
				СлужебныйПользователь = ПользователиСтоматология.СоздатьСлужебногоПользователяAPI();
			КонецЕсли;
			
			Константы.ВнешняяПубликацияПользователь.Установить(СлужебныйПользователь);
			
		КонецЕсли;
		
		ПользовательСистемный = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(ПользовательПубликации.ИдентификаторПользователяИБ);
		
		Если ПользовательСистемный = Неопределено Тогда
			ПользователиСтоматология.СоздатьСлужебногоПользователяAPIДляСотрудника(ПользовательПубликации);
			ПользовательСистемный = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(ПользовательПубликации.ИдентификаторПользователяИБ);
		КонецЕсли;
		
		ЭтоОблачник 		  = (ЛичныйКабинет.ЛиныйКабинетВМоделиСервиса() = Истина);
		АдресПубликации       = Константы.ВнешняяПубликацияАдрес.Получить();
		КодПроверкиПубликации = Строка(Новый УникальныйИдентификатор); 		
		
		ЗаписатьКодПроверкиРубликации(КодПроверкиПубликации);
		
		Если Не ЭтоОблачник Тогда
			
			// Проверка публикации по регистрационному номеру анкеты.
			ДанныеАнкеты = ЛичныйКабинет.ПолучитьДанныеРегистрационнойАнкеты();
			
			Если Не ЗначениеЗаполнено(ДанныеАнкеты) Тогда
				ВызватьИсключение "Данные регистрационной анкеты не заполнены";
			ИначеЕсли Не ЗначениеЗаполнено(АдресПубликации) Тогда
				ВызватьИсключение "В ЛК не указан адрес публикации";
			КонецЕсли;
			
			Если Не ЭтоОблачник ИЛИ ПолучитьРеквизитИзДанныхРегистрационнойАнкеты("ПарольServiceUserAPIВнесенВCRM") <> Истина Тогда
				// Установка нового пароля Системному пользователю при неудачной поверке публикации. 	
				ПарольПользователя = ПользователиСтоматология.УстановитьНовыйСлучайныйПарольСлужебномуПользователюAPI(ПользовательПубликации.ИдентификаторПользователяИБ);
			Иначе
				ПарольПользователя = ПолучитьРеквизитИзДанныхРегистрационнойАнкеты("ПарольServiceUserAPI")
			КонецЕсли;
			
		
			
			ПарамтерыЗапроса = Новый Структура;
			ПарамтерыЗапроса.Вставить("publication_address", АдресПубликации);
			ПарамтерыЗапроса.Вставить("publication_user"   , ПользовательСистемный.Имя);
			ПарамтерыЗапроса.Вставить("check_code"         , КодПроверкиПубликации);		
			ПарамтерыЗапроса.Вставить("registration_number", ДанныеАнкеты.ПродуктРегистрационныйНомер);
			ПарамтерыЗапроса.Вставить("publication_password", ПарольПользователя);

			ТекстЗапроса = СобратьJson(ПарамтерыЗапроса);
			
			ДопЗаголовкиHTTP = Новый Соответствие;	
			ДопЗаголовкиHTTP.Вставить("session", ТекущаяСессия);
			
			Попытка
				РезультатЗапроса = ВыполнитьPUTЗапрос("external_app/publication", ТекстЗапроса, ДопЗаголовкиHTTP);
			Исключение
				Возврат ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), НСтр("ru = 'Произошла ошибка, связанная с подключением к серверу. Повторите попытку.'; en = 'An error occurred while connecting to the server. Try again.'"));
			КонецПопытки;
			
			РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);	
			
			// Ошибка 1057 - в случае когда на стороне crm нет внешних систем по данной анкете.
			Если Не РезультатаОперции.ВыполненоУспешно
				И РезультатаОперции.КодОшибки <> 1057 Тогда
				
				Возврат РезультатаОперции;
			КонецЕсли;
			
			ПроверкаПубликацииУспешна = РезультатаОперции.ВыполненоУспешно;
			
		Иначе
			ПроверкаПубликацииУспешна = Ложь;
		КонецЕсли;
		
	Исключение
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатаОперции; 

КонецФункции 

// Функция, получает активные подписки из ЦРМ.
//
Функция ПолучитьАктивныеПодпискиWhatsapp() Экспорт
	
	РезультатОперции = Неопределено; 
	
	ПараметрыAPIЦрм = ПараметрыПодклчюенияК_API_CRM();
	Метод = "/whatsapp/active_subscriptions";
	
	HTTPСоединение = Новый HTTPСоединение(ПараметрыAPIЦрм.АдресСервера,, ПараметрыAPIЦрм.Пользователь, ПараметрыAPIЦрм.Пароль); 	
	ЗаголовкиHTTP  = Новый Соответствие; 
	ЗаголовкиHTTP.Вставить("Content-Type", "application/json");
	
	НомерОбласти 		= ЛичныйКабинет.ПолучитьНомерОбласти();
	РегНомерПродукта 	= ЛичныйКабинет.ПолучитьРегистрационныйНомерПродукта(); 
	
	Если НомерОбласти <> 0 Тогда
		ЗаголовкиHTTP.Вставить("areanumber"	, НомерОбласти);
	КонецЕсли; 
	
	ЗаголовкиHTTP.Вставить("registrationnumber" , РегНомерПродукта);
	
	HTTPЗапрос = Новый HTTPЗапрос(ПараметрыAPIЦрм.АдресПубликации + Метод, ЗаголовкиHTTP);				
	
	Попытка
		
		Запрос = HTTPСоединение.Получить(HTTPЗапрос);
		
		ТекстJSON  = Запрос.ПолучитьТелоКакСтроку(); 
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);	
		
		РезультатОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(ПараметрыJSON);
		
	Исключение
		
		РезультатОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатОперции; 
	
КонецФункции

