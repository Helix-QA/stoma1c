// Процедура - Обновить меню отбора интервалов работ
// 
Процедура ОбновитьМенюОтбораИнтерваловРабот()
	   	
	Элементы.ГруппаДобавитьИнтервал.Видимость = Истина;
	
	РодительскаяГруппа = Элементы.ГруппаСписокИнтерваловРаботы;
	// Очистим группу
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из РодительскаяГруппа.ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	Если ОтборИнтервалыРаботы.Количество() = 0 Тогда 
		ДекорацияФормы_СписокИнтервалов_Пуст = Элементы.Добавить("ДекорацияФормы_СписокИнтервалов_Пуст", Тип("ДекорацияФормы"), РодительскаяГруппа);
		ДекорацияФормы_СписокИнтервалов_Пуст.Вид 									= ВидДекорацииФормы.Надпись;
		ДекорацияФормы_СписокИнтервалов_Пуст.Заголовок 								= "Список интервалов пуст";
		ДекорацияФормы_СписокИнтервалов_Пуст.АвтоМаксимальнаяШирина    				= Ложь;
		ДекорацияФормы_СписокИнтервалов_Пуст.Высота 								= 1;
		ДекорацияФормы_СписокИнтервалов_Пуст.МаксимальнаяШирина       				= 45;
		ДекорацияФормы_СписокИнтервалов_Пуст.ГоризонтальноеПоложение   				= ГоризонтальноеПоложениеЭлемента.Центр;
		ДекорацияФормы_СписокИнтервалов_Пуст.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
		ДекорацияФормы_СписокИнтервалов_Пуст.ВертикальноеПоложение 					= ВертикальноеПоложениеЭлемента.Центр;
		ДекорацияФормы_СписокИнтервалов_Пуст.ВертикальноеПоложениеВГруппе			= ВертикальноеПоложениеЭлемента.Центр;		
		ДекорацияФормы_СписокИнтервалов_Пуст.РастягиватьПоГоризонтали  				= Истина;
		ДекорацияФормы_СписокИнтервалов_Пуст.ЦветТекста								= Новый Цвет(170, 170, 170);
		ДекорацияФормы_СписокИнтервалов_Пуст.Шрифт 									= Новый Шрифт("Arial", 11);		
	Иначе 	
		Для Каждого ЭлементСписка Из ОтборИнтервалыРаботы Цикл 
			
			ИндексИнтервала = ОтборИнтервалыРаботы.Индекс(ЭлементСписка);
			
