&НаКлиенте
// Обработчик события изменения знаяения элемента дня недели
// 
Процедура ПолеДень_ПриИзменении(Элемент) 
	
	ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИменеиЭлемента(Элемент.Имя);
	СтрокаДанных   = ВремяПланирования.НайтиПоИдентификатору(ИДСтрокиДанных);
	ПолеВремени    = Элементы.Найти(ПараметрыСозданияЭлементовФормы.ПолеВремени + ИДСтрокиДанных);	
	// Проверям на дублирование дней недели
	Для Каждого СтрокаТ ИЗ ВремяПланирования Цикл
		Если ИДСтрокиДанных <> СтрокаТ.ПолучитьИдентификатор() 
			И ДеньНедели(СтрокаТ.Дата) = ДеньНедели(СтрокаДанных.Дата) Тогда
			
			ПоказатьПредупреждение(,"Нельзя указать два одинаковых дня недели!");
			СтрокаДанных.Дата       = Неопределено;
			СтрокаДанных.ДатаПредст = Неопределено;
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

