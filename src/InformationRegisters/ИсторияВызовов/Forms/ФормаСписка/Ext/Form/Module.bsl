// Функция - Получения доступных номеров
Функция ПолучитьДоступныеНомера()
	
	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ВнутреннийНомер КАК ВнутреннийНомер
	|ИЗ
	|	Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыОбъектыПривязки
	|ГДЕ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПривязанКСотрудникам = ИСТИНА
	|	И (ВЫРАЗИТЬ(ТелефонныеАппаратыОбъектыПривязки.Объект КАК Справочник.Сотрудники)) = &Сотрудник
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.ВнутреннийНомер <> """"
	|	И НЕ ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПометкаУдаления
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ВнутреннийНомер
	|ИЗ
	|	Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыОбъектыПривязки
	|ГДЕ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПривязанКСотрудникам = ЛОЖЬ
	|	И (ВЫРАЗИТЬ(ТелефонныеАппаратыОбъектыПривязки.Объект КАК Справочник.РабочиеМеста)) = &РабочееМесто
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.ВнутреннийНомер <> """"
	|	И НЕ ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПометкаУдаления
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.Родитель.ВнутреннийНомер
	|ИЗ
	|	Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыОбъектыПривязки
	|ГДЕ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПривязанКСотрудникам = ИСТИНА
	|	И (ВЫРАЗИТЬ(ТелефонныеАппаратыОбъектыПривязки.Объект КАК Справочник.Сотрудники)) = &Сотрудник
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.Родитель <> ЗНАЧЕНИЕ(Справочник.ТелефонныеАппараты.ПустаяСсылка)
	|	И НЕ ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПометкаУдаления
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.Родитель.ВнутреннийНомер
	|ИЗ
	|	Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыОбъектыПривязки
	|ГДЕ
	|	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПривязанКСотрудникам = ЛОЖЬ
	|	И (ВЫРАЗИТЬ(ТелефонныеАппаратыОбъектыПривязки.Объект КАК Справочник.РабочиеМеста)) = &РабочееМесто
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.Родитель <> ЗНАЧЕНИЕ(Справочник.ТелефонныеАппараты.ПустаяСсылка)
	|	И НЕ ТелефонныеАппаратыОбъектыПривязки.Ссылка.ПометкаУдаления
	|	И ТелефонныеАппаратыОбъектыПривязки.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
	
	Запрос.УстановитьПараметр("Сотрудник"         , ПараметрыСеанса.ТекущийПользователь.Сотрудник);
	Запрос.УстановитьПараметр("РабочееМесто"      , ПараметрыСеанса.РабочееМестоКлиента);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	ДоступныеНомера = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВнутреннийНомер");
	Возврат ДоступныеНомера;
	
КонецФункции

&НаСервере
// Процедура устанавливает количество звонков.
//
Процедура УстановитьКоличествоЗвонков(ПолныеПрава = Неопределено, ДоступныеНомера = Неопределено)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СУММА(ВЫБОР
	|			КОГДА ИсторияВызовов.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Входящий)
	|					И ИсторияВызовов.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Пропущен)
	|				ТОГДА 1
	|		КОНЕЦ) КАК Входящий,
	|	СУММА(ВЫБОР
	|			КОГДА ИсторияВызовов.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Исходящий)
	|				ТОГДА 1
	|		КОНЕЦ) КАК Исходящий,
	|	СУММА(ВЫБОР
	|			КОГДА ИсторияВызовов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Пропущен)
	|				ТОГДА 1
	|		КОНЕЦ) КАК Пропущен,
	|	КОЛИЧЕСТВО(ИсторияВызовов.IDЗвонка) КАК ОбщееКоличество
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ &ПолныеПрава
	|				ТОГДА ИсторияВызовов.ВнутреннийНомерСотрудника В (&ДоступныеНомера)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И &ОтборПоПериоду
	|	И &ОтборСалон
	|	И &ОтборПоПериоду
	|	И &ОтборПользовательSIP");	
	
	Если ДоступныеНомера = Неопределено Тогда
		ДоступныеНомера = ПолучитьДоступныеНомера();
	КонецЕсли;
	
	Если ПолныеПрава = Неопределено Тогда
		ПолныеПрава = РольДоступна("ПолныеПрава") или РольДоступна("ЧтениеИсторииВызовов");		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДоступныеНомера", ДоступныеНомера);
	Запрос.УстановитьПараметр("ПолныеПрава"    , ПолныеПрава);		
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеОтборСтруктурнаяЕдиница = "И ИсторияВызовов.СтруктурнаяЕдиница = &Салон";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборСалон", УсловиеОтборСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("Салон", ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборСалон", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборПользовательSIP) Тогда
		УсловиеОтборПользовательSIP = "И ИсторияВызовов.ВнутреннийНомерСотрудника = &ВнутреннийНомер";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборПользовательSIP", УсловиеОтборПользовательSIP);
		Запрос.УстановитьПараметр("ВнутреннийНомер", ЭтотОбъект.ОтборПользовательSIP.ВнутреннийНомер);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборПользовательSIP", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборПериод) Тогда
		УсловиеОтборПериод = "И НАЧАЛОПЕРИОДА(ИсторияВызовов.НачалоВызова, ДЕНЬ) МЕЖДУ &ДатаНачала И &ДатаОкончания";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборПоПериоду", УсловиеОтборПериод);
		Запрос.УстановитьПараметр("ДатаНачала", ЭтотОбъект.ОтборПериод.ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ЭтотОбъект.ОтборПериод.ДатаОкончания);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборПоПериоду",""); 
	КонецЕсли;
	
	ТаблицаЗвонков = Запрос.Выполнить().Выгрузить();
	
	Для каждого Звонок из ТаблицаЗвонков Цикл
		
		Если Звонок.ОбщееКоличество <> Неопределено Тогда			
			Элементы.Отбор_ВсеЗвонки.Заголовок = "Все звонки (" + Строка(?(ЗначениеЗаполнено(Звонок.ОбщееКоличество), Звонок.ОбщееКоличество, 0)) + ")";		
		КонецЕсли;
		
		Если Звонок.Входящий <> Неопределено Тогда
			Элементы.Отбор_ВходящиеЗвонки.Заголовок = "Входящие (" + Строка(?(ЗначениеЗаполнено(Звонок.Входящий), Звонок.Входящий, 0)) + ")";	
		КонецЕсли;
		
		Если Звонок.Исходящий <> Неопределено Тогда
			Элементы.Отбор_ИсходящиеЗвонки.Заголовок = "Исходящие (" + Строка(?(ЗначениеЗаполнено(Звонок.Исходящий), Звонок.Исходящий, 0)) + ")";	
		КонецЕсли;
		
		Если Звонок.Пропущен <> Неопределено Тогда
			Элементы.Отбор_ПропущенныеЗвонки.Заголовок = "Непринятые (" + Строка(?(ЗначениеЗаполнено(Звонок.Пропущен), Звонок.Пропущен, 0)) + ")";		
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры

