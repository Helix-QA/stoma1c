// Функция - Проверка наличия колонки
// 
Функция ПроверкаНаличияКолонки(Таблица, ИмяКолонки) Экспорт
    
	Если ТипЗнч(Таблица) = Тип("ТаблицаЗначений") Тогда
		Возврат (Таблица.Колонки.Найти(ИмяКолонки) <> Неопределено);
		
	ИначеЕсли СтрНайти(Строка(ТипЗнч(Таблица)), "табличная часть:") > 0 Тогда
		Возврат (Таблица.ВыгрузитьКолонки().Колонки.Найти(ИмяКолонки) <> Неопределено);
		
	Иначе
		Возврат ЛОЖЬ;
		
	КонецЕсли;
	
