		// КнопкаЗначениеФильтра.ПоложениеКартинки 									= ПоложениеКартинкиКнопкиФормы.Право;
		КнопкаЗначениеФильтра.Отображение 											= ОтображениеКнопки.Текст;//?(ЭлементСпискаЗначенияФильтра.Значение.Выбран, ОтображениеКнопки.КартинкаИТекст, ОтображениеКнопки.Текст);
		// КнопкаЗначениеФильтра.Ширина 												= ПараметрыОтображенияДанных.МаксимальнаяШирина_ВариантаВзаимодействия;
		// КнопкаЗначениеФильтра.РастягиватьПоГоризонтали 							= ;
		// КнопкаЗначениеФильтра.ЦветТекста 											= ?(ЭлементСпискаЗначенияФильтра.Значение.Выбран, Новый Цвет(255, 255, 255), Новый Цвет());
		// КнопкаЗначениеФильтра.Шрифт 												= Новый Шрифт("Arial", 11);
		// КнопкаЗначениеФильтра.ГоризонтальноеПоложениеВГруппе 						= ГоризонтальноеПоложениеЭлемента.Лево;
