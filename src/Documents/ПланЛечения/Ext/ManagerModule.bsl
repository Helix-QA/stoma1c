					КонецЦикла;  			
					
					НоваяСтрока.Зуб = Зубы;
						
					Если Макет.Области.Найти("Номенклатура") <> Неопределено Тогда
						ОбластьНоменклатура       = Макет.ПолучитьОбласть("Номенклатура");
						
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Количество") Тогда
							ОбластьНоменклатура.Параметры.Количество 	= НоваяСтрока.Количество;
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Зуб") Тогда
							ОбластьНоменклатура.Параметры.Зуб 			= НоваяСтрока.Зуб;
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Номенклатура") Тогда
							ОбластьНоменклатура.Параметры.Номенклатура 	= ?(ЗначениеЗаполнено(НоваяСтрока.Номенклатура.НаименованиеПолное),НоваяСтрока.Номенклатура.НаименованиеПолное, НоваяСтрока.Номенклатура);
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Цена") Тогда
							ОбластьНоменклатура.Параметры.Цена 			= НоваяСтрока.Цена;
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Сумма") Тогда
							ОбластьНоменклатура.Параметры.Сумма 		= НоваяСтрока.Сумма;
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "СуммаНДС") Тогда
							ОбластьНоменклатура.Параметры.СуммаНДС 		= НоваяСтрока.СуммаНДС;
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "СтавкаНДС") Тогда
							ОбластьНоменклатура.Параметры.СтавкаНДС 	= НоваяСтрока.СтавкаНДС;
						КонецЕсли;
						Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Артикул") Тогда
							ОбластьНоменклатура.Параметры.Артикул 		= НоваяСтрока.Артикул;
						КонецЕсли;
						
						ТабДокумент.Вывести(ОбластьНоменклатура, ВыборкаНоменклатура.Уровень());
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла; 
			
			Если Макет.Области.Найти("ИтогоНДС") <> Неопределено Тогда
				ОбластьИтогоНДС           = Макет.ПолучитьОбласть("ИтогоНДС"); 
				
				Если ЕстьПараметрОбласти(ОбластьИтогоНДС.Параметры, "ВсегоНДС") Тогда
					ОбластьИтогоНДС.Параметры.ВсегоНДС = НДСИтого;
				КонецЕсли;
				Если ЕстьПараметрОбласти(ОбластьИтогоНДС.Параметры, "Сумма") Тогда
					ОбластьИтогоНДС.Параметры.Сумма = СумИтого;
				КонецЕсли;
				ТабДокумент.Вывести(ОбластьИтогоНДС);
			КонецЕсли;
		КонецЕсли;
		
		Если Макет.Области.Найти("СуммаПрописью") <> Неопределено Тогда
			ОбластьСуммаПрописью = Макет.ПолучитьОбласть("СуммаПрописью"); 
			ОбластьСуммаПрописью.Параметры.ИтоговаяСтрока     = "Лечение на сумму: " + ФормированиеПечатныхФорм.СуммаРубКоп(СумИтого,,);// ФормированиеПечатныхФорм.СуммаРубКоп(Прием_Шапка.ОбщееИтогоСоСкидкой, ,);// Формат(ТаблицаУслуги.Итог("Сумма"), "ЧЦ=15; ЧДЦ=2; ЧН=") + " руб." ;
			ОбластьСуммаПрописью.Параметры.СуммаПрописью      = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(СумИтого); // Прием_Шапка.ОбщееИтогоСоСкидкой
			ТабДокумент.Вывести(ОбластьСуммаПрописью);
		КонецЕсли;	
		
		Если Макет.Области.Найти("Подвал") <> Неопределено Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
			Таблица       = ВернутьФИООтветственныеЛицаОрганизации(Объект.СтруктурнаяЕдиница.Организация);	
			Бухгалтер     = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер, "ТипОтветственногоЛица");
			Руководитель  = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.Руководитель    , "ТипОтветственногоЛица");		
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОБухгалтера") Тогда
				ОбластьМакета.Параметры.ФИОБухгалтера = ?(Бухгалтер <> Неопределено   , Бухгалтер.ФИО, "");
			КонецЕсли;
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОРуководителя") Тогда
				ОбластьМакета.Параметры.ФИОРуководителя   = ?(Руководитель <> Неопределено, Руководитель.ФИО, "");	
			КонецЕсли;
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		
		Если Макет.Области.Найти("ПодвалЗаказа") <> Неопределено Тогда
			ОбластьМакета                          = Макет.ПолучитьОбласть("ПодвалЗаказа");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОИсполнителя") Тогда
				ОбластьМакета.Параметры.ФИОИсполнителя = Объект.Сотрудник;
			КонецЕсли;
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОЗаказчика") Тогда
				ОбластьМакета.Параметры.ФИОЗаказчика   = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата), "ПолноеНаименование,");
			КонецЕсли;
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		Если Макет.Области.Найти("Комментарий") <> Неопределено Тогда
			ОбластьМакета                       = Макет.ПолучитьОбласть("Комментарий");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "Комментарий") Тогда
				ОбластьМакета.Параметры.Комментарий = Объект.Комментарий;
			КонецЕсли;
			Если ЗначениеЗаполнено(Объект.Комментарий) Тогда
				ТабДокумент.Вывести(ОбластьМакета);
			КонецЕсли;	
		КонецЕсли;
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабДокумент;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ФОРМИРОВАНИЯ ПЕЧАТНЫХ ФОРМ
// Функция, возвращающая табличный документ "Счет на оплату" для печати
//
Функция СформироватьПечатнуюФормуПланЛеченияМедицинский(МассивОбъектов, ОбъектыПечати)
	
	Если ИспользуетсяПользовательскийМакет("ПФ_MXL_ПланЛеченияМед") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Внимание используется пользовательский макет печати. Рекомендуется использовать оригинальный макет.");
	КонецЕсли;

	ТабДокумент                     = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПФ_MXL_ПланЛеченияМед";
	Макет                           = УправлениеПечатью.МакетПечатнойФормы("Документ.ПланЛечения.ПФ_MXL_ПланЛеченияМед");
	
	ПервыйДокумент    = Истина;
	
	Для Каждого Объект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент    = Ложь;	
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		
		ЭтоСтоматологическиеУслуги = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник); 
		
		ЗапросШапка = Новый Запрос;
		ЗапросШапка.УстановитьПараметр("ТекущийДокумент", Объект.Ссылка);
		ЗапросШапка.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетНаОплату.Номер КАК Номер,
		|	СчетНаОплату.Дата КАК Дата,
		|	СчетНаОплату.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
		|	СчетНаОплату.СуммаДокумента КАК СуммаДокумента,
		|	СчетНаОплату.СтруктурнаяЕдиница.Организация КАК Организация,
		|	СчетНаОплату.Контрагент КАК Получатель,
		|	СчетНаОплату.Сотрудник КАК Поставщик,
		|	СчетНаОплату.Ссылка
		|ИЗ
		|	Документ.ПланЛечения КАК СчетНаОплату
		|ГДЕ
		|	СчетНаОплату.Ссылка = &ТекущийДокумент";
		Шапка = ЗапросШапка.Выполнить().Выбрать();
		Шапка.Следующий();
		
		ЗапросУслуги = Новый Запрос;
		ЗапросУслуги.УстановитьПараметр("Ссылка", Объект.Ссылка);
		ЗапросУслуги.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПланЛеченияЛечение.Зуб КАК Зуб,
		|	ПланЛеченияЛечение.Номенклатура КАК Номенклатура,
		|	СУММА(ПланЛеченияЛечение.Количество) КАК Количество,
		|	ПланЛеченияЛечение.НомерПриема КАК НомерПриема,
		|	ПланЛеченияЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг КАК Артикул,
		|	ПланЛеченияЛечение.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
		|ГДЕ
		|	ПланЛеченияЛечение.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПланЛеченияЛечение.Зуб,
		|	ПланЛеченияЛечение.Номенклатура,
		|	ПланЛеченияЛечение.НомерПриема,
		|	ПланЛеченияЛечение.Номенклатура.Артикул,
		|	ПланЛеченияЛечение.НомерСтроки
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки,
		|   Зуб 
		|ИТОГИ
		|	СУММА(Количество)
		|ПО
		|	НомерПриема,
		|	Номенклатура";
		
		ВыборкаТаблицаЛечение 	= ЗапросУслуги.Выполнить();
	
		// Вывод реквизитов организации
		Если Макет.Области.Найти("РеквизитыОрганизации") <> Неопределено Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("РеквизитыОрганизации");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ПредставлениеОрганизации") Тогда  
				ПолноеПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, Шапка.Дата), "ПолноеНаименование,");
				ПредставлениеОрганизации       = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Шапка.Организация, "Наименование");
				ОбластьМакета.Параметры.ПредставлениеОрганизации = ?(ЗначениеЗаполнено(ПолноеПредставлениеОрганизации), ПолноеПредставлениеОрганизации, ПредставлениеОрганизации); 
			КонецЕсли;
			
			ФактАдрес = Шапка.Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, "Вид");
			ЮрАдрес   = Шапка.Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Вид");
			
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "АдресОрганизации") Тогда 
				
				Если НЕ ФактАдрес = Неопределено Тогда
					Адрес = ФактАдрес.Представление;
				ИначеЕсли НЕ ЮрАдрес = Неопределено Тогда
					Адрес = ЮрАдрес.Представление;
				КонецЕсли;
				
				ОбластьМакета.Параметры.АдресОрганизации = ?(ЗначениеЗаполнено(Адрес), Адрес, ""); 
				
			КонецЕсли;                                                                              
			
			ТабДокумент.Вывести(ОбластьМакета);                                                     			
			
		КонецЕсли;

		ВидыВыводимойКИ = Новый Массив;
		ВидыВыводимойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации);
		ВидыВыводимойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ФаксОрганизации);
		ВидыВыводимойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.EmailОрганизации);
		
		Для Каждого ВидКонтактнойИнформации Из ВидыВыводимойКИ Цикл		
			СтрокаКИ =  Шапка.Организация.КонтактнаяИнформация.Найти(ВидКонтактнойИнформации, "Вид");		
			Если СтрокаКИ <> Неопределено Тогда
				Если Макет.Области.Найти("СтрокаКИ") <> Неопределено Тогда
					ОбластьМакета = Макет.ПолучитьОбласть("СтрокаКИ");
					Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ВидКИ") Тогда
						ОбластьМакета.Параметры.ВидКИ = СтрокаКИ.Вид;
					КонецЕсли;
					Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ПредставлениеКИ") Тогда
						ОбластьМакета.Параметры.ПредставлениеКИ = СокрП(СтрокаКИ.Представление);				
					КонецЕсли;
					ТабДокумент.Вывести(ОбластьМакета);			
				КонецЕсли;				
			КонецЕсли;			
		КонецЦикла;
		// ***
		Если Макет.Области.Найти("Заголовок") <> Неопределено Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ТекстЗаголовка") Тогда
				ОбластьМакета.Параметры.ТекстЗаголовка = "План лечения № " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Шапка.Номер, Шапка.Префикс) + " от " + Формат(Шапка.Дата, "ДФ='дд ММММ гггг'") + " г.";
			КонецЕсли;	
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;			
		Если Макет.Области.Найти("Покупатель") <> Неопределено Тогда             
			ОбластьМакета           = Макет.ПолучитьОбласть("Покупатель"); 	
			ПредставлениеПолучателя = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Шапка.Получатель, "Наименование");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ПредставлениеПолучателя") Тогда
				ОбластьМакета.Параметры.ПредставлениеПолучателя = ПредставлениеПолучателя;
			КонецЕсли;			
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;	
		Если Макет.Области.Найти("Составитель") <> Неопределено Тогда
			ОбластьМакета                                    = Макет.ПолучитьОбласть("Составитель");
			ПредставлениеСоставителя                         = Объект.Сотрудник;
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ПредставлениеСоставителя") Тогда
				ОбластьМакета.Параметры.ПредставлениеСоставителя = ПредставлениеСоставителя;
			КонецЕсли;			
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;	
		//===================================================ВЫВОД ТАБЛИЦЫ ЛЕЧЕНИЕ=======================================================	
		Если Макет.Области.Найти("ШапкаТаблицыМед") <> Неопределено Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицыМед");
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;	
		
		КолИтого = 0;
		Таблица = Новый ТаблицаЗначений;
		ОписаниеКоличество = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3));
		Таблица.Колонки.Добавить("Зуб");
		Таблица.Колонки.Добавить("Номенклатура");
		Таблица.Колонки.Добавить("Количество", ОписаниеКоличество);
		Таблица.Колонки.Добавить("НомерПриема");
		Таблица.Колонки.Добавить("Артикул");
		ВыборкаИтог = ЗапросУслуги.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаИтог.Следующий() Цикл
			
			ВыборкаНоменклатура = ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Если Макет.Области.Найти("НомерПриемаМед") <> Неопределено Тогда
				ОбластьНомерСтроки = Макет.ПолучитьОбласть("НомерПриемаМед");
				ОбластьНомерСтроки.Параметры.Заполнить(ВыборкаНоменклатура);
				Если ЕстьПараметрОбласти(ОбластьНомерСтроки.Параметры, "НомерПриема") Тогда
					ОбластьНомерСтроки.Параметры.НомерПриема = ?(ВыборкаИтог.НомерПриема <> 0, "" + ВыборкаИтог.НомерПриема + " посещение", "");	
				КонецЕсли;
				ТабДокумент.Вывести(ОбластьНомерСтроки, ВыборкаИтог.Уровень());
			КонецЕсли;
			
			Пока ВыборкаНоменклатура.Следующий() Цикл
				
				НоваяСтрока             	= Таблица.Добавить();
				НоваяСтрока.Артикул 		= ВыборкаНоменклатура.Артикул;
				НоваяСтрока.Номенклатура 	= ВыборкаНоменклатура.Номенклатура;
				НоваяСтрока.Количество   	= ВыборкаНоменклатура.Количество;
				КолИтого = КолИтого + ВыборкаНоменклатура.Количество;
				ВыборкаЗубы = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.Прямой);
				СписокЗначений = Новый СписокЗначений;
				
				Пока ВыборкаЗубы.Следующий() Цикл
					
					СписокЗначений.Добавить(Строка(ВыборкаЗубы.Зуб));
					
				КонецЦикла;
				
				СписокЗначений.СортироватьПоЗначению();
				Зубы = "";
				Разделитель = "";
				
				Для Каждого СтрокаСЗ ИЗ СписокЗначений Цикл
					
					Зубы = Зубы + Разделитель + СтрокаСЗ.Значение;
					Разделитель = ",";				
					
				КонецЦикла;  			
				
				НоваяСтрока.Зуб = Зубы;
				
				Если Макет.Области.Найти("НоменклатураМед") <> Неопределено Тогда
					
					ОбластьНоменклатура = Макет.ПолучитьОбласть("НоменклатураМед");
					Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Количество") Тогда
						ОбластьНоменклатура.Параметры.Количество 	= НоваяСтрока.Количество;
					КонецЕсли;
					Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Зуб") Тогда
						ОбластьНоменклатура.Параметры.Зуб 			= НоваяСтрока.Зуб;
					КонецЕсли;
					Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Номенклатура") Тогда
						ОбластьНоменклатура.Параметры.Номенклатура 	= ?(ЗначениеЗаполнено(НоваяСтрока.Номенклатура.НаименованиеПолное),НоваяСтрока.Номенклатура.НаименованиеПолное, НоваяСтрока.Номенклатура);
					КонецЕсли;
					Если ЕстьПараметрОбласти(ОбластьНоменклатура.Параметры, "Артикул") Тогда
						ОбластьНоменклатура.Параметры.Артикул 		= НоваяСтрока.Артикул;
					КонецЕсли;
					ТабДокумент.Вывести(ОбластьНоменклатура, ВыборкаНоменклатура.Уровень());
				КонецЕсли;

			КонецЦикла;
			
		КонецЦикла;  
		
		Если Макет.Области.Найти("Итого") <> Неопределено Тогда
			ОбластьИтого        = Макет.ПолучитьОбласть("Итого");
			Если ЕстьПараметрОбласти(ОбластьИтого.Параметры, "Количество") Тогда
				ОбластьИтого.Параметры.Количество = КолИтого;
			КонецЕсли;
			ТабДокумент.Вывести(ОбластьИтого);
		КонецЕсли;
		
		Если Макет.Области.Найти("Подвал") <> Неопределено Тогда
			ОбластьМакета                             = Макет.ПолучитьОбласть("Подвал");
			Таблица                                   = ВернутьФИООтветственныеЛицаОрганизации(Объект.СтруктурнаяЕдиница.Организация);	
			Бухгалтер                                 = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер, "ТипОтветственногоЛица");
			Руководитель                              = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.Руководитель    , "ТипОтветственногоЛица");		
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОБухгалтера") Тогда
				ОбластьМакета.Параметры.ФИОБухгалтера     = ?(Бухгалтер <> Неопределено   , Бухгалтер.ФИО, "");
			КонецЕсли;
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОРуководителя") Тогда
				ОбластьМакета.Параметры.ФИОРуководителя   = ?(Руководитель <> Неопределено, Руководитель.ФИО, "");	
			КонецЕсли;
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		
		Если Макет.Области.Найти("ПодвалЗаказа") <> Неопределено Тогда
			ОбластьМакета                          = Макет.ПолучитьОбласть("ПодвалЗаказа");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОИсполнителя") Тогда
				ОбластьМакета.Параметры.ФИОИсполнителя = Объект.Сотрудник;
			КонецЕсли;
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ФИОЗаказчика") Тогда
				ОбластьМакета.Параметры.ФИОЗаказчика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата), "ПолноеНаименование,");			КонецЕсли;
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		
		Если Макет.Области.Найти("Комментарий") <> Неопределено Тогда
			ОбластьМакета                       = Макет.ПолучитьОбласть("Комментарий");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "Комментарий") Тогда
				ОбластьМакета.Параметры.Комментарий = Объект.Комментарий;
			КонецЕсли;
			Если ЗначениеЗаполнено(Объект.Комментарий) Тогда
				ТабДокумент.Вывести(ОбластьМакета);
			КонецЕсли;
		КонецЕсли;

		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб = Истина;
	Возврат ТабДокумент;
	
КонецФункции

Функция ЕстьПараметрОбласти(Область, ИмяПараметра) Экспорт
	
	КлючУникальности   = Новый УникальныйИдентификатор;
	
	СтруктураРеквизита = Новый Структура(ИмяПараметра, КлючУникальности);
	
	ЗаполнитьЗначенияСвойств(СтруктураРеквизита, Область);
	
	Возврат СтруктураРеквизита[ИмяПараметра] <> КлючУникальности;
	
КонецФункции 

// Только для внутреннего использования.
//
Функция ИспользуетсяПользовательскийМакет(ИмяМакета)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПользовательскиеМакетыПечати.ИмяМакета
	|ИЗ
	|	РегистрСведений.ПользовательскиеМакетыПечати КАК ПользовательскиеМакетыПечати
	|ГДЕ
	|	ПользовательскиеМакетыПечати.Использование = ИСТИНА
	|	И ПользовательскиеМакетыПечати.ИмяМакета = &ИмяМакета";
	
	Запрос.УстановитьПараметр("ИмяМакета", ИмяМакета);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() >0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("ПФ_MXL_ГарантийныйТалон", "Гарантийный талон", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_Квитанция", "Квитанция об оплате", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_ПланЛеченияМед", "План лечения (медицинский)", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_ПланЛечения", "План лечения (финансовый)", , БиблиотекаКартинок.Документ);	

	Возврат Список;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли
