// Процедура - Заполнить существующие услуги
//
Процедура ЗаполнитьСуществующиеУслуги()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КлассификаторНоменклатурыМедицинскихУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КлассификаторНоменклатурыМедицинскихУслуг КАК КлассификаторНоменклатурыМедицинскихУслуг
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
		|		ПО КлассификаторНоменклатурыМедицинскихУслуг.Наименование = Номенклатура.Наименование
		|ГДЕ
		|	Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|	И Номенклатура.ЭтоГруппа = ЛОЖЬ
		|	И КлассификаторНоменклатурыМедицинскихУслуг.ЭтоГруппа = ЛОЖЬ";
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	СуществующиеУслуги.ЗагрузитьЗначения(Результат);
	
КонецПроцедуры

