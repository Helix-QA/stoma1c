#Область СлужебныйПрограммныйИнтерфейс

#Область ФормированиеДанных

// Функция - Получить данные воронок.
//
// Параметры:
//  Параметры					 - 	 - 
//  ВременноеХранилищеРезультата - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеВоронок(Параметры, ВременноеХранилищеРезультата) Экспорт		
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтруктурнаяЕдиница 		= Параметры.СтруктурнаяЕдиница;
	ПериодРасчетаНачало 	= Параметры.ПериодРасчета.ДатаНачала;
	ПериодРасчетаОкончание 	= Параметры.ПериодРасчета.ДатаОкончания;
	ОтборПериодТип			= Параметры.ОтборПериодТип; 
	ПредопределеныйВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");  
	
	Если Не ЗначениеЗаполнено(ПредопределеныйВидСделки) Тогда            
		Возврат Неопределено;
	КонецЕсли;
			
	СоответствиеЭтаповСделок = ПолучитьЭтапыСделок(ПредопределеныйВидСделки);
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
	 "ВЫБРАТЬ
	 |	ЭтапыСделок.Ссылка КАК Этап,
	 |	ВЫБОР
	 |		КОГДА ЭтапыСделок.Ссылка = &ЭтапПациентПодтвердил
	 |			ТОГДА 4
	 |		КОГДА ЭтапыСделок.Ссылка = &ЭтапПациентЗаписан
	 |			ТОГДА 3
	 |		КОГДА ЭтапыСделок.Ссылка = &ЭтапПредложениеОзвучено
	 |			ТОГДА 2
	 |		КОГДА ЭтапыСделок.Ссылка = &ЭтапПотенциальныйПрием
	 |			ТОГДА 1
	 |	КОНЕЦ КАК НомерЭтапаПриведенный,
	 |	ВЫБОР
	 |		КОГДА ЭтапыСделок.Ссылка = &ЭтапПредложениеОзвучено
	 |				ИЛИ ЭтапыСделок.Ссылка = &ЭтапПотенциальныйПрием
	 |			ТОГДА ИСТИНА
	 |		ИНАЧЕ ЛОЖЬ
	 |	КОНЕЦ КАК ЭтапПодходитДляОтказа,
	 |	ИСТИНА КАК ЭтапПодходитДляУспеха
	 |ПОМЕСТИТЬ ВТЭтапыСделок
	 |ИЗ
	 |	Справочник.ЭтапыСделок КАК ЭтапыСделок
	 |ГДЕ
	 |	ЭтапыСделок.ВидСделки = &ВидСделки
	 |	И ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	 |
	 |ОБЪЕДИНИТЬ ВСЕ
	 |
	 |ВЫБРАТЬ
	 |	ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех),
	 |	5,
	 |	ЛОЖЬ,
	 |	ИСТИНА
	 |
	 |ОБЪЕДИНИТЬ ВСЕ
	 |
	 |ВЫБРАТЬ
	 |	ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ),
	 |	10,
	 |	ИСТИНА,
	 |	ЛОЖЬ
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Сделки.Ссылка КАК Сделка,
	 |	ВЫБОР
	 |		КОГДА Сделки.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ)
	 |			ТОГДА Сделки.ЭтапОтказа
	 |		ИНАЧЕ Сделки.ЭтапСделки
	 |	КОНЕЦ КАК ТекущийЭтапСделки,
	 |	Сделки.Заявка КАК Заявка,
	 |	ВТЭтапыСделок.НомерЭтапаПриведенный КАК НомерЭтапаПриведенный,
	 |	Сделки.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ) КАК СделкаВОтказе,
	 |	ВЫБОР
	 |		КОГДА Сделки.Заявка = ЗНАЧЕНИЕ(Справочник.Заявки.ПустаяСсылка)
	 |			ТОГДА 1
	 |		ИНАЧЕ 0
	 |	КОНЕЦ КАК СделкаБезЗаявки
	 |ПОМЕСТИТЬ ВтАнализируемыеСделки
	 |ИЗ
	 |	Справочник.Сделки КАК Сделки
	 |		ЛЕВОЕ СОЕДИНЕНИЕ ВТЭтапыСделок КАК ВТЭтапыСделок
	 |		ПО (ВЫБОР
	 |				КОГДА Сделки.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ)
	 |					ТОГДА Сделки.ЭтапОтказа
	 |				ИНАЧЕ Сделки.ЭтапСделки
	 |			КОНЕЦ = ВТЭтапыСделок.Этап)
	 |ГДЕ
	 |	Сделки.ПометкаУдаления = ЛОЖЬ
	 |	И Сделки.ВидСделки = &ВидСделки
	 |	И Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	 |	И ВЫБОР
	 |			КОГДА Сделки.СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный)
	 |					И Сделки.Заявка <> ЗНАЧЕНИЕ(Справочник.Заявки.ПустаяСсылка)
	 |				ТОГДА Сделки.Заявка.ДатаСоздания
	 |			ИНАЧЕ Сделки.ДатаСделки
	 |		КОНЕЦ МЕЖДУ &ДатаНачала И &ДатаОкончания
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Заявки.Ссылка КАК Заявка
	 |ПОМЕСТИТЬ ВТЗаявки
	 |ИЗ
	 |	Справочник.Заявки КАК Заявки
	 |ГДЕ
	 |	Заявки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	 |	И Заявки.ПометкаУдаления = ЛОЖЬ
	 |	И Заявки.ДатаСоздания МЕЖДУ &ДатаНачала И &ДатаОкончания
	 |
	 |ОБЪЕДИНИТЬ
	 |
	 |ВЫБРАТЬ
	 |	ВтАнализируемыеСделки.Заявка
	 |ИЗ
	 |	ВтАнализируемыеСделки КАК ВтАнализируемыеСделки
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВТЗаявки.Заявка.Ссылка КАК ЗаявкаСсылка,
	 |	ВТЗаявки.Заявка.Статус КАК ЗаявкаСтатус,
	 |	ВТЗаявки.Заявка.ДатаСоздания КАК ЗаявкаДатаСоздания,
	 |	ВЫБОР
	 |		КОГДА ВТЗаявки.Заявка.ДатаОбработки <> ДАТАВРЕМЯ(1, 1, 1)
	 |			ТОГДА ЕСТЬNULL(РАЗНОСТЬДАТ(ВТЗаявки.Заявка.ДатаСоздания, ВТЗаявки.Заявка.ДатаОбработки, МИНУТА), 0)
	 |		ИНАЧЕ 0
	 |	КОНЕЦ КАК ВремяОбработки,
	 |	ВЫБОР
	 |		КОГДА ВТЗаявки.Заявка.ДатаОбработки <> ДАТАВРЕМЯ(1, 1, 1)
	 |			ТОГДА 1
	 |		ИНАЧЕ 0
	 |	КОНЕЦ КАК Обработано,
	 |	ВЫБОР
	 |		КОГДА ВТЗаявки.Заявка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Принята)
	 |			ТОГДА 1
	 |		ИНАЧЕ 0
	 |	КОНЕЦ КАК ЗаявкаКачественная
	 |ПОМЕСТИТЬ ВтБазоваяТаблицаЗаявок
	 |ИЗ
	 |	ВТЗаявки КАК ВТЗаявки
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ЗаявкиИсторияИзмененияСтатусов.Ссылка КАК Ссылка,
	 |	МИНИМУМ(ЗаявкиИсторияИзмененияСтатусов.Дата) КАК Дата
	 |ПОМЕСТИТЬ ВтКачественныеЗаявки
	 |ИЗ
	 |	ВтБазоваяТаблицаЗаявок КАК ВтБазоваяТаблицаЗаявок
	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Заявки.ИсторияИзмененияСтатусов КАК ЗаявкиИсторияИзмененияСтатусов
	 |		ПО ВтБазоваяТаблицаЗаявок.ЗаявкаСсылка = ЗаявкиИсторияИзмененияСтатусов.Ссылка
	 |ГДЕ
	 |	ЗаявкиИсторияИзмененияСтатусов.ПереходВСтатус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Принята)
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	ЗаявкиИсторияИзмененияСтатусов.Ссылка
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ЕСТЬNULL(СУММА(ВтБазоваяТаблицаЗаявок.ЗаявкаКачественная), 0) + ВложенныйЗапрос.СуммаСделокБезЗаявок КАК КоличествоКачественныхЗаявок,
	 |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВтБазоваяТаблицаЗаявок.ЗаявкаСсылка) + ВложенныйЗапрос.СуммаСделокБезЗаявок КАК ОбщееКоличествоЗаявок,
	 |	ЕСТЬNULL(СУММА(ВтБазоваяТаблицаЗаявок.ВремяОбработки), 0) КАК ВремяОбработки,
	 |	ЕСТЬNULL(СУММА(ВтБазоваяТаблицаЗаявок.Обработано), 0) КАК ОбработаноКоличество
	 |ПОМЕСТИТЬ КоличественныеПоказателиЗаявок
	 |ИЗ
	 |	ВтБазоваяТаблицаЗаявок КАК ВтБазоваяТаблицаЗаявок
	 |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	 |			СУММА(ВтАнализируемыеСделки.СделкаБезЗаявки) КАК СуммаСделокБезЗаявок
	 |		ИЗ
	 |			ВтАнализируемыеСделки КАК ВтАнализируемыеСделки) КАК ВложенныйЗапрос
	 |		ПО (ИСТИНА)
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	ВложенныйЗапрос.СуммаСделокБезЗаявок
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ЕСТЬNULL(ВЫБОР
	 |			КОГДА КоличественныеПоказателиЗаявок.ОбработаноКоличество = 0
	 |				ТОГДА 0
	 |			ИНАЧЕ ВЫРАЗИТЬ(КоличественныеПоказателиЗаявок.ВремяОбработки / КоличественныеПоказателиЗаявок.ОбработаноКоличество КАК ЧИСЛО(15, 0))
	 |		КОНЕЦ, 0) КАК СреднееВремяОбработкиЗаявок,
	 |	ВЫБОР
	 |		КОГДА КоличественныеПоказателиЗаявок.ОбщееКоличествоЗаявок = 0
	 |			ТОГДА 0
	 |		ИНАЧЕ ВЫРАЗИТЬ(КоличественныеПоказателиЗаявок.КоличествоКачественныхЗаявок / КоличественныеПоказателиЗаявок.ОбщееКоличествоЗаявок * 100 КАК ЧИСЛО(15, 0))
	 |	КОНЕЦ КАК ПроцентКачественныхЗаявок
	 |ПОМЕСТИТЬ ВтПроцентныеПоказателиЗаявок
	 |ИЗ
	 |	КоличественныеПоказателиЗаявок КАК КоличественныеПоказателиЗаявок
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВтАнализируемыеСделки.Сделка КАК Сделка,
	 |	ВТЭтапыСделок.Этап КАК ЭтапСделки,
	 |	ВТЭтапыСделок.НомерЭтапаПриведенный КАК НомерЭтапаПриведенный,
	 |	ВтАнализируемыеСделки.СделкаВОтказе КАК СделкаВОтказе
	 |ПОМЕСТИТЬ ВтНедостающиеЭтапыСделок
	 |ИЗ
	 |	ВТЭтапыСделок КАК ВТЭтапыСделок
	 |		ПОЛНОЕ СОЕДИНЕНИЕ ВтАнализируемыеСделки КАК ВтАнализируемыеСделки
	 |		ПО ВТЭтапыСделок.НомерЭтапаПриведенный <= ВтАнализируемыеСделки.НомерЭтапаПриведенный
	 |			И (ВЫБОР
	 |				КОГДА ВтАнализируемыеСделки.ТекущийЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех)
	 |					ТОГДА ВТЭтапыСделок.ЭтапПодходитДляУспеха = ИСТИНА
	 |				ИНАЧЕ ИСТИНА
	 |			КОНЕЦ)
	 |ГДЕ
	 |	НЕ ВтАнализируемыеСделки.Сделка ЕСТЬ NULL
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	СделкиИсторияИзмененияЭтапов.Ссылка КАК Сделка,
	 |	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап КАК ЭтапСделки,
	 |	МИНИМУМ(СделкиИсторияИзмененияЭтапов.Дата) КАК ДатаЭтапа
	 |ПОМЕСТИТЬ ВтСуществующиеЭтапыСделки
	 |ИЗ
	 |	Справочник.Сделки.ИсторияИзмененияЭтапов КАК СделкиИсторияИзмененияЭтапов
	 |ГДЕ
	 |	СделкиИсторияИзмененияЭтапов.Ссылка В
	 |			(ВЫБРАТЬ
	 |				ВтАнализируемыеСделки.Сделка КАК Сделка
	 |			ИЗ
	 |				ВтАнализируемыеСделки КАК ВтАнализируемыеСделки)
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	СделкиИсторияИзмененияЭтапов.Ссылка,
	 |	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВтНедостающиеЭтапыСделок.Сделка КАК Сделка,
	 |	ВтНедостающиеЭтапыСделок.ЭтапСделки КАК ЭтапСделки,
	 |	ВтНедостающиеЭтапыСделок.НомерЭтапаПриведенный КАК НомерЭтапаПриведенный,
	 |	МИНИМУМ(ЕСТЬNULL(ВтСуществующиеЭтапыСделки.ДатаЭтапа, ВтНедостающиеЭтапыСделок.Сделка.ДатаСделки)) КАК ДатаЭтапа,
	 |	ВтНедостающиеЭтапыСделок.Сделка.Заявка.ДатаСоздания КАК ДатаСозданияЗаявки,
	 |	ВтНедостающиеЭтапыСделок.Сделка.Прием.Дата КАК ДатаПриема,
	 |	ВтНедостающиеЭтапыСделок.Сделка.ДатаСделки КАК ДатаСозданияСделки,
	 |	ВЫБОР
	 |		КОГДА ВтНедостающиеЭтапыСделок.Сделка.Заявка.ДатаСоздания ЕСТЬ NULL
	 |			ТОГДА 0
	 |		ИНАЧЕ 1
	 |	КОНЕЦ КАК ЕстьОбращение,
	 |	ВтНедостающиеЭтапыСделок.СделкаВОтказе КАК СделкаВОтказе
	 |ПОМЕСТИТЬ БазоваяТаблицаСделок
	 |ИЗ
	 |	ВтНедостающиеЭтапыСделок КАК ВтНедостающиеЭтапыСделок
	 |		ЛЕВОЕ СОЕДИНЕНИЕ ВтСуществующиеЭтапыСделки КАК ВтСуществующиеЭтапыСделки
	 |		ПО ВтНедостающиеЭтапыСделок.Сделка = ВтСуществующиеЭтапыСделки.Сделка
	 |			И ВтНедостающиеЭтапыСделок.ЭтапСделки = ВтСуществующиеЭтапыСделки.ЭтапСделки
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	ВтНедостающиеЭтапыСделок.Сделка,
	 |	ВтНедостающиеЭтапыСделок.ЭтапСделки,
	 |	ВтНедостающиеЭтапыСделок.НомерЭтапаПриведенный,
	 |	ВтНедостающиеЭтапыСделок.Сделка.Прием.Дата,
	 |	ВтНедостающиеЭтапыСделок.Сделка.ДатаСделки,
	 |	ВтНедостающиеЭтапыСделок.Сделка.Заявка.ДатаСоздания,
	 |	ВтНедостающиеЭтапыСделок.СделкаВОтказе
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	БазоваяТаблицаСделок.Сделка КАК Сделка,
	 |	МИНИМУМ(БазоваяТаблицаСделок.ДатаСозданияЗаявки) КАК ДатаСозданияЗаявки,
	 |	МИНИМУМ(БазоваяТаблицаСделок.ДатаЭтапа) КАК ДатаЭтапа,
	 |	МИНИМУМ(БазоваяТаблицаСделок.ДатаПриема) КАК ДатаПриема,
	 |	МАКСИМУМ(БазоваяТаблицаСделок.ЕстьОбращение) КАК ЕстьОбращение,
	 |	МИНИМУМ(ВЫБОР
	 |			КОГДА БазоваяТаблицаСделок.ЭтапСделки = &ЭтапПациентЗаписан
	 |				ТОГДА БазоваяТаблицаСделок.ДатаЭтапа
	 |		КОНЕЦ) КАК ДатаЭтапаПациентЗаписан,
	 |	СУММА(ВЫБОР
	 |			КОГДА БазоваяТаблицаСделок.ЭтапСделки = &ЭтапПациентЗаписан
	 |				ТОГДА 1
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ЕстьЭтапКлиентЗаписан,
	 |	МАКСИМУМ(ВЫБОР
	 |			КОГДА БазоваяТаблицаСделок.ЭтапСделки = &ЭтапПациентПодтвердил
	 |				ТОГДА 1
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ЕстьЭтапКлиентПодтвердил,
	 |	МАКСИМУМ(ВЫБОР
	 |			КОГДА БазоваяТаблицаСделок.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех)
	 |				ТОГДА 1
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ЕстьЭтапКлиентПришел,
	 |	МАКСИМУМ(ВЫБОР
	 |			КОГДА БазоваяТаблицаСделок.СделкаВОтказе = ИСТИНА
	 |				ТОГДА 1
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ЕстьЭтапОтказ,
	 |	МАКСИМУМ(ВЫБОР
	 |			КОГДА НЕ БазоваяТаблицаСделок.ДатаПриема ЕСТЬ NULL
	 |				ТОГДА 1
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ЕстьПрием
	 |ПОМЕСТИТЬ БазоваяТаблицаПервичныеПациенты
	 |ИЗ
	 |	БазоваяТаблицаСделок КАК БазоваяТаблицаСделок
	 |ГДЕ
	 |	БазоваяТаблицаСделок.Сделка.СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный)
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	БазоваяТаблицаСделок.Сделка
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	БазоваяТаблицаСделок.Сделка КАК Сделка,
	 |	МИНИМУМ(БазоваяТаблицаСделок.ДатаПриема) КАК ДатаПриема,
