// Процедура, обработчик события "ПриИзменении".
//
Процедура КассаПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Касса) Тогда
		ТекстОшибки   = "";
		СостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Объект.Касса);
		КассоваяСмена = ?(НЕ СостояниеКассовойСмены = Неопределено, СостояниеКассовойСмены.КассоваяСмена, ПредопределенноеЗначение("Документ.КассоваяСмена.ПустаяСсылка"));
		РозничныеПродажи.СменаОткрыта(КассоваяСмена, ТекущаяДата(), ТекстОшибки);		
		Если ((СокрЛП(ТекстОшибки) = "Кассовая смена закрыта") ИЛИ (СокрЛП(ТекстОшибки) = "Кассовая смена не открыта")) Тогда
			Если НЕ ИспользоватьБезПодключенияОборудования Тогда 
				ПоказатьВопрос(Новый ОписаниеОповещения("КассаПриИзмененииОткрытиеКассовойСмены", ЭтотОбъект, Новый Структура("ТекстОшибки", ТекстОшибки)), "Кассовая смена не открыта. Открыть смену?", РежимДиалогаВопрос.ДаНет, 0);
                Возврат;
			Иначе 
				ОбщегоНазначенияКлиентСтоматология.ОткрытьКассовуюСмену(Объект.Касса, УникальныйИдентификатор);
				СостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Объект.Касса);
				ПоказатьОповещениеПользователя("Сообщение:", , "Кассовая смена открыта", БиблиотекаКартинок.Информация32);				
			КонецЕсли;
		КонецЕсли;	
		
		// Задаем запрос о закрытии кассы.
		КассаПриИзмененииЗакрытиеКассовойСмены(ТекстОшибки);

	КонецЕсли;	
	
КонецПроцедуры

