&НаКлиенте
// Процедура, обработчик события "ПриОткрытии" ФормыЭлемента
//
Процедура ПриОткрытии(Отказ)
	
	ЕСЛИ Объект.Наименование = "" Тогда
		Объект.Наименование = СформироватьАвтоНаименование();
	КонецЕсли;
	СтараяСтрокаНаименования = Объект.Наименование;
	Если СтараяСтрокаНаименования = СформироватьАвтоНаименование() Тогда
		БлокировкаИзмНаименования = ЛОЖЬ;
	Иначе
		БлокировкаИзмНаименования = ИСТИНА;
	КонецЕсли;
	
	ЗаданВопросОБлокировкеАктивныхКарт = Ложь;
	
//	УстановитьВидимостьДоступность();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения" ФормыЭлемента.
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		
		Если ИмяСобытия = "ScanData" Тогда
			
			// Преобразуем предварительно к ожидаемому формату.
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных.
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных.
			КонецЕсли;
			
			ПолученыШтрихкоды(Данные, ИмяСобытия);
			
		ИначеЕсли ИмяСобытия = "TracksData" Тогда
			
			ДанныеКарты     = МенеджерОборудованияКлиент.ОбработатьДанныеМагнитнойКарты(Параметр);
			Объект.КодКарты = ДанныеКарты.КодШифра;
			Объект.ТипКода  = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИмяСобытия = "СОХРАНЕНИЕ_ВНЕШНЕЙ_СИСТЕМЫ" Тогда
		
		ВнешняяСистемаWallet = ПолучитьВнешнююСистемуНаСервере();
		
		// ЭлектроннаяКарта = Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet");
		// Элементы.ТипКода.ОтображениеПодсказки = ?(ЭлектроннаяКарта И Не ЗначениеЗаполнено(ВнешняяСистемаWallet), ОтображениеПодсказки.ОтображатьСнизу, ОтображениеПодсказки.Нет);
		Элементы.ДекорацияКартинка.РасширеннаяПодсказка.Заголовок = ПолучитьОписаниеПодсказки(Объект.ТипКода);
		
	КонецЕсли;
	// Конец ВнешнееОборудование 
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает внешнюю систему.
//
Функция ПолучитьВнешнююСистемуНаСервере()
	
	Возврат Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);
	
