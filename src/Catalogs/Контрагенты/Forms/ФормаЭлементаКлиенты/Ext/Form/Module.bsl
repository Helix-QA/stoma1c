// Процедура - Подключаемый обработка нажатия динамической кнопки запрещения рассылки
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ОбработкаНажатияДинамическойКнопкиЗапрещенияРассылки(Элемент)	
	
	ИндексСтроки = Число(Сред(Элемент.Имя, СтрДлина("РазрешитьЗапретитьРассылку_")+1));
	НеУчаствоватьВРассылке = Не ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке;
	ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке = НеУчаствоватьВРассылке;	
	Элемент.Картинка = ПолучитьКартинку(НеУчаствоватьВРассылке);
	Элемент.Подсказка = ПолучитьПодсказку(НеУчаствоватьВРассылке);
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

