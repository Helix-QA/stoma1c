// Процедура - формирует представление ФИО сотрудника
//
Процедура СформироватьПредставлениеФИО(СписокВыбораПредставления = Ложь)
	
	// Формируем полное представление в виде "Фамилия + Имя(полное) + Отчество(Полное)"
	ПредставлениеФИО = СокрЛП(СокрЛП(Объект.Фамилия) + ?(ЗначениеЗаполнено(Объект.Имя),  
						" " + СокрЛП(Объект.Имя) + ?(ЗначениеЗаполнено(Объект.Отчество), 
						" " + СокрЛП(Объект.Отчество), ""), ""));
						
	// Формируем список представлений ФИО
	Если СписокВыбораПредставления Тогда
		
		СписокВыбора = Новый СписокЗначений;
		
		Если НЕ ПустаяСтрока(Объект.Фамилия) Тогда
			СписокВыбора.Добавить(СокрЛП(Объект.Фамилия));
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(Объект.Фамилия) И НЕ ПустаяСтрока(Объект.Имя) Тогда
			СписокВыбора.Добавить(СокрЛП(Объект.Фамилия) + " " + СокрЛП(Объект.Имя));
			СписокВыбора.Добавить(СокрЛП(Объект.Фамилия) + " " + Сред(СокрЛП(Объект.Имя) ,1,1) + ".");
		КонецЕсли; 
		
		Если НЕ ПустаяСтрока(Объект.Фамилия) И НЕ ПустаяСтрока(Объект.Имя) И НЕ ПустаяСтрока(Объект.Отчество) Тогда
			СписокВыбора.Добавить(СокрЛП(Объект.Фамилия) + " " + СокрЛП(Объект.Имя) + " " + СокрЛП(Объект.Отчество));
			СписокВыбора.Добавить(СокрЛП(Объект.Фамилия) + " " + Сред(СокрЛП(Объект.Имя),1,1) + "." + Сред(СокрЛП(Объект.Отчество),1,1) + ".");
		КонецЕсли; 
		
		ПоказатьВыборИзСписка(Новый ОписаниеОповещения("СформироватьПредставлениеФИОЗавершение", ЭтотОбъект), СписокВыбора, Элементы.Наименование);
	Иначе
		Объект.Наименование = ПредставлениеФИО;	
		Объект.ПредставлениеДляОнлайнЗаписи = Объект.Фамилия + ?(ЗначениеЗаполнено(Объект.Фамилия), " ", "") + Объект.Имя;
		Объект.ПредставлениеДляОнлайнЗаписи = ?(ЗначениеЗаполнено(Объект.ПредставлениеДляОнлайнЗаписи), Объект.ПредставлениеДляОнлайнЗаписи, Объект.Отчество);

	КонецЕсли;
	
КонецПроцедуры

