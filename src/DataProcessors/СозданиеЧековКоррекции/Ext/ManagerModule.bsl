// Функция получает структуру позиции чека.
//
Функция ПолучитьСтруктуруПозицииЧека()
	
	Структура = Новый Структура;
	Структура.Вставить("ДанныеПоставщикаИНН");
	Структура.Вставить("ДанныеПоставщикаНаименование");
	Структура.Вставить("ДанныеПоставщикаТелефон");
	Структура.Вставить("Количество");
	Структура.Вставить("НаименованиеПредметаРасчета");
	Структура.Вставить("НомерСекции");
	Структура.Вставить("ПризнакАгентаПоПредметуРасчета");
	Структура.Вставить("ПризнакПредметаРасчета");
	Структура.Вставить("ПризнакСпособаРасчета");
	Структура.Вставить("СтавкаНДС");
	Структура.Вставить("СуммаНДС");
	Структура.Вставить("СуммаСкидок");
	Структура.Вставить("СуммаСоСкидками");
	Структура.Вставить("ЦенаСоСкидками");
	Структура.Вставить("Штрихкод");
	
	Возврат Структура;
	
КонецФункции

// Процедура заполняет позиции чека по общим параметрам.
//
Процедура ЗаполнитьПозицииЧекаПоОбщимПараметрамСНоменклатурой(Объект, ОбщиеПараметры)
	
	Для Каждого ПозицияЧека Из ОбщиеПараметры.ПозицииЧека Цикл
		
		НоваяСтрока = ПолучитьСтруктуруПозицииЧека(); // Объект.ПозицииЧека.Добавить();
		НоваяСтрока.Вставить("Номенклатура");
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПозицияЧека);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ПозицияЧека.ДанныеКодаТоварнойНоменклатуры);
		
		НоваяСтрока.ДанныеПоставщикаИНН 			= ПозицияЧека.ДанныеПоставщика.ИНН;
		НоваяСтрока.ДанныеПоставщикаНаименование 	= ПозицияЧека.ДанныеПоставщика.Наименование;
		НоваяСтрока.ДанныеПоставщикаТелефон 		= ПозицияЧека.ДанныеПоставщика.Телефон;
		
		НоваяСтрока.НаименованиеПредметаРасчета		= ?(ПозицияЧека.Свойство("Номенклатура") И ЗначениеЗаполнено(ПозицияЧека.Номенклатура), 
																						ПозицияЧека.Номенклатура, ПозицияЧека.Наименование);
		НоваяСтрока.СуммаСоСкидками					= ПозицияЧека.Сумма;	
		НоваяСтрока.СтавкаНДС						= Обработки.СозданиеЧековКоррекции.ПолучитьСтавкуНДСПоЗначениюСтавки(ПозицияЧека.СтавкаНДС);
		
		Объект.ПозицииЧека.Добавить(НоваяСтрока);
		
	КонецЦикла;
	
КонецПроцедуры

