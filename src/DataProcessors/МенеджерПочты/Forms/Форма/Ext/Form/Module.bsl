&НаСервере
// Обработчик события формы "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
		
	ТЗУчетныеЗаписи = Справочники.УчетныеЗаписиЭлектроннойПочты.ВернутьУчетныеЗаписиЭлектроннойПочтыОбщиеИЛичные(ПараметрыСеанса.ТекущийПользователь, Ложь, Ложь, Ложь, Ложь);	
	
	Дерево = РеквизитФормыВЗначение("ДеревоУчетныхЗаписей");
	Дерево.Строки.Очистить();
	
	ЭтаФорма.флОтказ = Истина;
	
	Для Каждого СтрокаТЗ Из ТЗУчетныеЗаписи Цикл

		ЭтаФорма.флОтказ = Ложь;
		
		СтрокаУЗ = Дерево.Строки.Добавить();
		
		СтрокаУЗ.Наименование	= СтрокаТЗ.Наименование;
		СтрокаУЗ.УчетнаяЗапись	= СтрокаТЗ.Ссылка;
		СтрокаУЗ.Картинка		= 4;
		
		СтрокаВходящие = СтрокаУЗ.Строки.Добавить();
		НеПрочитано = ПолучитьКоличествоНепрочитанныхПисем(СтрокаУЗ.УчетнаяЗапись);
		СтрокаВходящие.Наименование = "Входящие" + ?(НеПрочитано > 0, " (" + НеПрочитано + ")", "");
		СтрокаВходящие.ЖирныйШрифт = (НеПрочитано > 0);
		СтрокаВходящие.Картинка = 0;
		СтрокаВходящие.УчетнаяЗапись = СтрокаУЗ.УчетнаяЗапись;
		
		СтрокаИсходящие	= СтрокаУЗ.Строки.Добавить();
		НеОтправлено = ПолучитьКоличествоНеотправленныхПисем(СтрокаУЗ.УчетнаяЗапись);
		СтрокаИсходящие.Наименование = "Исходящие" + ?(НеОтправлено > 0, " (" + НеОтправлено + ")", "");
		СтрокаИсходящие.ЖирныйШрифт = (НеОтправлено > 0);
		СтрокаИсходящие.Картинка = 1;
		СтрокаИсходящие.УчетнаяЗапись = СтрокаУЗ.УчетнаяЗапись;
		
		СтрокаОтправленные = СтрокаУЗ.Строки.Добавить();
		СтрокаОтправленные.Наименование = "Отправленные";
		СтрокаОтправленные.ЖирныйШрифт = Ложь;
		СтрокаОтправленные.Картинка = 2;
		СтрокаОтправленные.УчетнаяЗапись = СтрокаУЗ.УчетнаяЗапись;
		
		// СтрокаЧерновики	= СтрокаУЗ.Строки.Добавить();
		// СтрокаЧерновики.Наименование = "Черновики";
		// СтрокаЧерновики.Картинка = 5;
		// СтрокаЧерновики.УчетнаяЗапись = СтрокаУЗ.УчетнаяЗапись;
		
		СтрокаУдаленные = СтрокаУЗ.Строки.Добавить();
		СтрокаУдаленные.Наименование = "Удаленные";
		СтрокаУдаленные.ЖирныйШрифт = Ложь;
		СтрокаУдаленные.Картинка = 3;
		СтрокаУдаленные.УчетнаяЗапись = СтрокаУЗ.УчетнаяЗапись;
		
	КонецЦикла;
	
	ЗначениеВДанныеФормы(Дерево, ДеревоУчетныхЗаписей);
	
    ОтборСпискаПисем = Элементы.ПолеОтбора.СписокВыбора[3];	// все письма
	
КонецПроцедуры

&НаКлиенте
// Обработчик оповещения формы
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "УстановленФлагОбработано" Тогда
		
		Элементы.СписокПисем.Обновить();
		ОбработчикОжиданияСписокПисемПриАктивизацииСтроки();
		
	ИначеЕсли ИмяСобытия = "ИзмененоЭлектронноеПисьмо"
		  ИЛИ ИмяСобытия = "ВыполненаОтправкаПисьма" Тогда
		  
		Элементы.СписокПисем.Обновить();  
		ОбновитьОтображаемоеКоличествоПисемВсехПапок();
		ОбработчикОжиданияСписокПисемПриАктивизацииСтроки();
		
	КонецЕсли;
	
КонецПроцедуры

