				СтрокаДействия.ИдентификаторДействия 				= Новый УникальныйИдентификатор();				
			Иначе 
				СтрокаДействия 										= СтрокаДействияОтправитьСообщение;
			КонецЕсли;
			Если НЕ СтрокаДействия = Неопределено Тогда
				СтрокаДействия.Использование 						= ПоздравлятьКлиентаПоEmail;
				СтрокаДействия.ВидДействия 							= Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо;
				СтрокаДействия.ВидАдресата 							= Перечисления.ВидыАдресатов.КонтрагентСобытия;
				СтрокаДействия.ШаблонСообщения 						= Справочники.ШаблоныСообщений.ИнициализироватьШаблонСообщения_КлиентДеньРождения(ШаблонСообщения);
				СтрокаДействия.Описание 							= НСтр("ru = 'Отправить клиенту электронное письмо';en= 'Send customer an email'");
			КонецЕсли;
		
			Если НЕ ЗначениеЗаполнено(ТриггерКлиентДеньРождения.Код) Тогда 
				ТриггерКлиентДеньРождения.УстановитьНовыйКод();
			КонецЕсли;
			// Сохраняем триггер
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ТриггерКлиентДеньРождения);					
		Исключение
			МетаданныеСправочника 				= Метаданные.Справочники.ТриггерныеСобытия;		
			ШаблонКомментария = НСтр("ru = 'Не удалось инициализировать триггерное событие ""День рождения клиента"" 
			|по причине: %1'");
			
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонКомментария,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Предупреждение,
			МетаданныеСправочника,,
			Комментарий);
		КонецПопытки;
	КонецЕсли
	
КонецПроцедуры

// Процедура - Инициализировать триггерное событие запись начало приема
//
// Параметры:
//  ТаблицаСервисовSMS	 - 	 - 
//
Процедура ИнициализироватьТриггерноеСобытие_ЗаписьНачалоПриема(ТаблицаСервисовSMS) Экспорт 
	
	СервисSMSРассылки 				= Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	НапоминатьКлиентуОЗаписиПоSMS 	= Ложь;
	Если НапоминатьКлиентуОЗаписиПоSMS И ЗначениеЗаполнено(ТаблицаСервисовSMS) Тогда
		
		// Если используется расширение мессенджера, то создавать этот триггер не имеет смысла, так как
		// есть соответствующий триггер и сценарий, им запускаемый, по подтверждению записи (что и есть информирование о предстоящей записи)
		Если ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") Тогда 
			Возврат;
		КонецЕсли;
		РасширениеМессенджера = ОбновлениеИнформационнойБазыСтоматология.ПолучитьРасширениеМесседжера();
		Если НЕ РасширениеМессенджера = Неопределено Тогда
			// Расширение мессенджера установлено, обновление не требуется.
			Возврат;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТриггерныеСобытия.Ссылка КАК Ссылка,
		|	ТриггерныеСобытия.ПометкаУдаления КАК ПометкаУдаления,
		|	ТриггерныеСобытия.Активно КАК Активно,
		|	ТриггерныеСобытия.МоментСобытия КАК МоментСобытия,
		|	ТриггерныеСобытия.ПериодСобытия КАК ПериодСобытия,
		|	ТриггерныеСобытия.ПериодСобытияВид КАК ПериодСобытияВид
		|ИЗ
		|	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
		|ГДЕ
		|	ТриггерныеСобытия.ЭтоГруппа = ЛОЖЬ
		|	И ТриггерныеСобытия.УсловиеСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема)";
		
		ТаблицаТриггеров = Запрос.Выполнить().Выгрузить();
		
		ТипИнформирования 	= 0;
		ПериодСобытияВид 	= ?(ТипИнформирования = 0, Перечисления.Периодичность.День, Перечисления.Периодичность.Час);
		ПериодСобытия 		= 0;
		Если ПериодСобытияВид = Перечисления.Периодичность.День И ПериодСобытия = 0 Тогда 
			ПериодСобытияВид = Перечисления.Периодичность.Час;
			ПериодСобытия 	= 12;
		Иначе 	
			ПериодСобытия 	= ?(ПериодСобытия < 1, 1, ?(ПериодСобытия > 24, 24, ПериодСобытия));
		КонецЕсли;				
		ВремяСобытия 		= Неопределено;
		ШаблонСообщения		= Неопределено;
		
		ГенерируемыйТриггер = Неопределено; 
		Если ЗначениеЗаполнено(ТаблицаТриггеров) Тогда
	        СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Активно"			, Истина);
			СтруктураПоиска.Вставить("ПометкаУдаления"	, Ложь);
			СтруктураПоиска.Вставить("МоментСобытия"	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия);
			СтруктураПоиска.Вставить("ПериодСобытияВид"	, ПериодСобытияВид);
			
			МассивТриггеров = ТаблицаТриггеров.НайтиСтроки(СтруктураПоиска);
			Если МассивТриггеров.Количество() > 0 Тогда 
				ГенерируемыйТриггер = МассивТриггеров[0];
			Иначе
				СтруктураПоиска.Удалить("Активно");
				СтруктураПоиска.Удалить("ПометкаУдаления");
				МассивТриггеров = ТаблицаТриггеров.НайтиСтроки(СтруктураПоиска);
				Если МассивТриггеров.Количество() > 0 Тогда 
					ГенерируемыйТриггер = МассивТриггеров[0];
				Иначе
					ГенерируемыйТриггер = ТаблицаТриггеров[0];
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
		
		Попытка
			Если ЗначениеЗаполнено(ГенерируемыйТриггер.Ссылка) 
				И ГенерируемыйТриггер.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия
				И ГенерируемыйТриггер.ПериодСобытияВид = ПериодСобытияВид
				И ((ПериодСобытияВид = Перечисления.Периодичность.День И ПериодСобытия = ГенерируемыйТриггер.ПериодСобытия) ИЛИ (ПериодСобытияВид = Перечисления.Периодичность.Час И (Макс(ПериодСобытия, ГенерируемыйТриггер.ПериодСобытия) - Мин(ПериодСобытия, ГенерируемыйТриггер.ПериодСобытия) < 3))) Тогда 
				ТриггерДоНачалаПриема 								= ГенерируемыйТриггер.Ссылка.ПолучитьОбъект();
			Иначе 	
				// Генерируем триггер
				ТриггерДоНачалаПриема 								= СоздатьЭлемент();
			КонецЕсли;
			ТриггерДоНачалаПриема.Активно 							= Истина;
			ТриггерДоНачалаПриема.Наименование 						= ?(ЗначениеЗаполнено(ГенерируемыйТриггер.Ссылка), ТриггерДоНачалаПриема.Наименование, НСтр("ru = 'Напоминание клиентам о предварительной записи на приём';en= 'Reminder clients to make an appointment'"));
			ТриггерДоНачалаПриема.УсловиеСобытия 					= Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема;
			ТриггерДоНачалаПриема.МоментСобытия 					= Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия;
			ТриггерДоНачалаПриема.ПериодСобытияВид 					= ПериодСобытияВид;
			ТриггерДоНачалаПриема.ПериодСобытия 					= ПериодСобытия;
			ТриггерДоНачалаПриема.ВремяСобытия 						= ВремяСобытия;
			СписокОписанийТриггеров 								= ПолучитьОписанияТриггеров();
			ЭлементСпискаОписаниеУсловия 							= СписокОписанийТриггеров.НайтиПоЗначению(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема);
			Если НЕ ЭлементСпискаОписаниеУсловия = Неопределено Тогда 
				ТриггерДоНачалаПриема.Описание 						= ?(ЗначениеЗаполнено(ГенерируемыйТриггер.Ссылка), ТриггерДоНачалаПриема.Описание, ЭлементСпискаОписаниеУсловия.Представление);
			КонецЕсли;
			Если ТриггерДоНачалаПриема.ПометкаУдаления = Истина Тогда 
				ТриггерДоНачалаПриема.ПометкаУдаления = Ложь;
			КонецЕсли;
			ТриггерДоНачалаПриема.СегментКонтрагентов 				= Справочники.СегментыКонтрагентов.ПустаяСсылка();
			
			МассивДействийОтправитьСообщение = ТриггерДоНачалаПриема.Действия.НайтиСтроки(Новый Структура("ВидДействия, ВидАдресата, Удалено", Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение, Перечисления.ВидыАдресатов.КонтрагентСобытия, Ложь));
			СтрокаДействияОтправитьСообщение = Неопределено;
			Если МассивДействийОтправитьСообщение.Количество() = 0 Тогда 
				СтрокаДействияОтправитьСообщение = Неопределено;
			Иначе
				Для Каждого СтрокаДействия Из МассивДействийОтправитьСообщение Цикл
					Если СтрокаДействия.Использование = Истина Тогда 
						СтрокаДействияОтправитьСообщение = СтрокаДействия;
						Прервать;
					КонецЕсли;					
				КонецЦикла;
				Если СтрокаДействияОтправитьСообщение = Неопределено Тогда 
					СтрокаДействияОтправитьСообщение = МассивДействийОтправитьСообщение[0];
				КонецЕсли;	
			КонецЕсли;	
			
			Если СтрокаДействияОтправитьСообщение = Неопределено Тогда 
				СтрокаДействия 											= ТриггерДоНачалаПриема.Действия.Добавить();
				СтрокаДействия.ИдентификаторДействия 					= Новый УникальныйИдентификатор();				
			Иначе 
				СтрокаДействия 											= СтрокаДействияОтправитьСообщение;
			КонецЕсли;
			Если НЕ СтрокаДействия = Неопределено Тогда			
				СтрокаДействия.Использование 							= Истина; 
				СтрокаДействия.ВидДействия 								= Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение;
				СтрокаДействия.ВидАдресата 								= Перечисления.ВидыАдресатов.КонтрагентСобытия;
				Если ЗначениеЗаполнено(ШаблонСообщения) И ТриггерДоНачалаПриема.Ссылка.Пустая() Тогда 
					СтрокаДействия.ШаблонСообщения 						= ШаблонСообщения;
				ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаДействия.ШаблонСообщения) Тогда  	
					СтрокаДействия.ШаблонСообщения 						= Справочники.ШаблоныСообщений.ИнициализироватьШаблонСообщения_НачалоПриема(ТриггерДоНачалаПриема.ВремяСобытия);
				КонецЕсли;	
				СтрокаДействия.Описание 								= НСтр("ru = 'Отправить пациенту сообщение';en= 'Send a message to the client'");
			КонецЕсли;
		
			Если НЕ СтрокаДействия = Неопределено Тогда 
				// Актуализируем настройки каналов уведомлений
				МассивНастроекКаналовУведомлений = ТриггерДоНачалаПриема.НастройкиКаналовУведомлений.НайтиСтроки(Новый Структура("ИдентификаторДействия", СтрокаДействия.ИдентификаторДействия));
				
				Если МассивНастроекКаналовУведомлений.Количество() = 0 Тогда 
					Для Каждого СтрокаТаблицаСервисовSMS Из ТаблицаСервисовSMS Цикл 
						СтрокаНастройкиКаналовУведомления									= ТриггерДоНачалаПриема.НастройкиКаналовУведомлений.Добавить();
						СтрокаНастройкиКаналовУведомления.ИдентификаторДействия 			= СтрокаДействия.ИдентификаторДействия;
						СтрокаНастройкиКаналовУведомления.СтруктурнаяЕдиница 				= СтрокаТаблицаСервисовSMS.СтруктурнаяЕдиница;
						СтрокаНастройкиКаналовУведомления.ОтправкаPushWallet 				= СтрокаТаблицаСервисовSMS.ОтправкаPushWallet;
						СтрокаНастройкиКаналовУведомления.ОтправкаMessenger 				= СтрокаТаблицаСервисовSMS.ОтправкаMessenger;
						СтрокаНастройкиКаналовУведомления.АккаунтВнешнейСистемы     		= СтрокаТаблицаСервисовSMS.АккаунтВнешнейСистемы;
						СтрокаНастройкиКаналовУведомления.ОтправкаSMS 						= ЗначениеЗаполнено(СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS);
						СтрокаНастройкиКаналовУведомления.АккаунтСервисаРассылкиSMS 		= СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS;
					КонецЦикла;
				Иначе 
					Для Каждого СтрокаТаблицаСервисовSMS Из ТаблицаСервисовSMS Цикл 
						МассивНастроекКаналовУведомлений = ТриггерДоНачалаПриема.НастройкиКаналовУведомлений.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница", СтрокаДействия.ИдентификаторДействия, СтрокаТаблицаСервисовSMS.СтруктурнаяЕдиница));
						Если МассивНастроекКаналовУведомлений.Количество() = 0 Тогда
							СтрокаНастройкиКаналовУведомления								= ТриггерДоНачалаПриема.НастройкиКаналовУведомлений.Добавить();
							СтрокаНастройкиКаналовУведомления.ИдентификаторДействия 		= СтрокаДействия.ИдентификаторДействия;
							СтрокаНастройкиКаналовУведомления.СтруктурнаяЕдиница 			= СтрокаТаблицаСервисовSMS.СтруктурнаяЕдиница;
							СтрокаНастройкиКаналовУведомления.ОтправкаPushWallet 			= СтрокаТаблицаСервисовSMS.ОтправкаPushWallet;
							СтрокаНастройкиКаналовУведомления.ОтправкаMessenger 			= СтрокаТаблицаСервисовSMS.ОтправкаMessenger;
							СтрокаНастройкиКаналовУведомления.АккаунтВнешнейСистемы     	= СтрокаТаблицаСервисовSMS.АккаунтВнешнейСистемы;
							СтрокаНастройкиКаналовУведомления.ОтправкаSMS 					= ЗначениеЗаполнено(СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS);
							СтрокаНастройкиКаналовУведомления.АккаунтСервисаРассылкиSMS 	= СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS;
						Иначе 
							МассивНастроекКаналовУведомлений[0].ОтправкаSMS 				= Истина;
							МассивНастроекКаналовУведомлений[0].АккаунтСервисаРассылкиSMS 	= СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS;
						КонецЕсли;	
					КонецЦикла;
				КонецЕсли;	
			КонецЕсли;
					
			Если НЕ ЗначениеЗаполнено(ТриггерДоНачалаПриема.Код) Тогда 
				ТриггерДоНачалаПриема.УстановитьНовыйКод();
			КонецЕсли;
			// Сохраняем триггер
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ТриггерДоНачалаПриема);
		Исключение
			МетаданныеСправочника 				= Метаданные.Справочники.ТриггерныеСобытия;		
			ШаблонКомментария = НСтр("ru = 'Не удалось инициализировать триггерное событие ""Начало приёма"" 
			|по причине: %1'");
			
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонКомментария,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Предупреждение,
			МетаданныеСправочника,,
			Комментарий);
		КонецПопытки;
	КонецЕсли
	
КонецПроцедуры

// Процедура - Инициализировать триггерное событие пациент окончание срока действия страхового полиса
//
// Параметры:
//  ТаблицаСервисовSMS	 - 	 - 
//
Процедура ИнициализироватьТриггерноеСобытие_ПациентОкончаниеСрокаДействияСтраховогоПолиса(ТаблицаСервисовSMS) Экспорт 
	
	СервисSMSРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();   
	ИнформироватьОбОкончанииСтраховогоПолисаИспользование = Ложь;
	
	Если ИнформироватьОбОкончанииСтраховогоПолисаИспользование И ЗначениеЗаполнено(ТаблицаСервисовSMS) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТриггерныеСобытия.Ссылка КАК Ссылка,
