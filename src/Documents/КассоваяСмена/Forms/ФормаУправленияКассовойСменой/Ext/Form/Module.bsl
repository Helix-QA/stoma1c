//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьФормуУправленияКассовойСменой" Тогда
		ЗаполнитьТаблицыДанных();	
	КонецЕсли;
	
КонецПроцедуры

