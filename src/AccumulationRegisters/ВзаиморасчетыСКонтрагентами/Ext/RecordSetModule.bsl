// ОБРАБОТЧИКИ СОБЫТИЙ

#Область ОбработчикиСобытий

&НаСервере
// Процедура - обработчик события ПередЗаписью набора записей.
//
Процедура ПередЗаписью(Отказ, Замещение)
	
	
	Если ОбменДанными.Загрузка
		ИЛИ НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
		ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;

	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	// Установка исключительной блокировки текущего набора записей регистратора.
	Блокировка              = Новый БлокировкаДанных;
	ЭлементБлокировки       = Блокировка.Добавить("РегистрНакопления.ВзаиморасчетыСКонтрагентами.НаборЗаписей");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Регистратор", Отбор.Регистратор.Значение);
	Блокировка.Заблокировать();
	
	Если НЕ СтруктураВременныеТаблицы.Свойство("ДвиженияВзаиморасчетыСКонтрагентамиИзменение") ИЛИ
		СтруктураВременныеТаблицы.Свойство("ДвиженияВзаиморасчетыСКонтрагентамиИзменение") И НЕ СтруктураВременныеТаблицы.ДвиженияВзаиморасчетыСКонтрагентамиИзменение Тогда
		
		// Если временная таблица "ДвиженияВзаиморасчетыСКонтрагентамиИзменение" не существует или не содержит записей
		// об изменении набора, значит набор записывается первый раз или для набора был выполнен контроль остатков.
		// Текущее состояние набора помещается во временную таблицу "ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно текущего.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВзаиморасчетыСКонтрагентами.НомерСтроки КАК НомерСтроки,
		|	ВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ВзаиморасчетыСКонтрагентами.Контрагент КАК Контрагент,
		|	ВзаиморасчетыСКонтрагентами.Организация КАК Организация,
		|	ВЫБОР
		|		КОГДА ВзаиморасчетыСКонтрагентами.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА ВзаиморасчетыСКонтрагентами.Сумма
		|		ИНАЧЕ -ВзаиморасчетыСКонтрагентами.Сумма
		|	КОНЕЦ КАК СуммаПередЗаписью
		|ПОМЕСТИТЬ ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами КАК ВзаиморасчетыСКонтрагентами
		|ГДЕ
		|	ВзаиморасчетыСКонтрагентами.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	Иначе
		
		// Если временная таблица "ДвиженияВзаиморасчетыСКонтрагентамиИзменение" существует и содержит записи
		// об изменении набора, значит набор записывается не первый раз и для набора не был выполнен контроль остатков.
		// Текущее состояние набора и текущее состояние изменений помещаются
		// во временную таблцу "ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно первоначального.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
		|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.НомерСтроки КАК НомерСтроки,
		|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.Контрагент КАК Контрагент,
		|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.Организация КАК Организация,
		|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СуммаПередЗаписью КАК СуммаПередЗаписью
		|ПОМЕСТИТЬ ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью
		|ИЗ
		|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение КАК ДвиженияВзаиморасчетыСКонтрагентамиИзменение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВзаиморасчетыСКонтрагентами.НомерСтроки,
		|	ВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница,
		|	ВзаиморасчетыСКонтрагентами.Контрагент,
		|	ВзаиморасчетыСКонтрагентами.Организация,
		|	ВЫБОР
		|		КОГДА ВзаиморасчетыСКонтрагентами.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА ВзаиморасчетыСКонтрагентами.Сумма
		|		ИНАЧЕ -ВзаиморасчетыСКонтрагентами.Сумма
		|	КОНЕЦ
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами КАК ВзаиморасчетыСКонтрагентами
		|ГДЕ
		|	ВзаиморасчетыСКонтрагентами.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	КонецЕсли;
	
	// Временная таблица "ДвиженияЗапасыНаСкладахИзменение" уничтожается
	// Удаляется информация о ее существовании.
	
	Если СтруктураВременныеТаблицы.Свойство("ДвиженияВзаиморасчетыСКонтрагентамиИзменение") Тогда
		
		Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияВзаиморасчетыСКонтрагентамиИзменение");
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		СтруктураВременныеТаблицы.Удалить("ДвиженияВзаиморасчетыСКонтрагентамиИзменение");
	
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - обработчик события ПриЗаписи набора записей.
//
Процедура ПриЗаписи(Отказ, Замещение)
	
	
	Если ОбменДанными.Загрузка
		ИЛИ НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
		ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	// Рассчитывается изменение нового набора относительно текущего с учетом накопленных изменений
	// и помещается во временную таблицу "ДвиженияВзаиморасчетыСКонтрагентамиИзменение".
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	МИНИМУМ(ДвиженияВзаиморасчетыСКонтрагентамиИзменение.НомерСтроки) КАК НомерСтроки,
	|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.Контрагент КАК Контрагент,
	|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.Организация КАК Организация,
	|	СУММА(ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СуммаПередЗаписью) КАК СуммаПередЗаписью,
	|	СУММА(ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СуммаИзменение) КАК СуммаИзменение,
	|	СУММА(ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СуммаПриЗаписи) КАК СуммаПриЗаписи
	|ПОМЕСТИТЬ ДвиженияВзаиморасчетыСКонтрагентамиИзменение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью.НомерСтроки КАК НомерСтроки,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью.Контрагент КАК Контрагент,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью.Организация КАК Организация,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью.СуммаПередЗаписью КАК СуммаПередЗаписью,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью.СуммаПередЗаписью КАК СуммаИзменение,
	|		0 КАК СуммаПриЗаписи
	|	ИЗ
	|		ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью КАК ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.НомерСтроки,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.СтруктурнаяЕдиница,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.Контрагент,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.Организация,
	|		0,
	|		ВЫБОР
	|			КОГДА ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА -ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.Сумма
	|			ИНАЧЕ ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.Сумма
	|		КОНЕЦ,
	|		ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.Сумма
	|	ИЗ
	|		РегистрНакопления.ВзаиморасчетыСКонтрагентами КАК ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи
	|	ГДЕ
	|		ДвиженияВзаиморасчетыСКонтрагентамиПриЗаписи.Регистратор = &Регистратор) КАК ДвиженияВзаиморасчетыСКонтрагентамиИзменение
	|
	|СГРУППИРОВАТЬ ПО
	|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СтруктурнаяЕдиница,
	|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.Контрагент,
	|	ДвиженияВзаиморасчетыСКонтрагентамиИзменение.Организация
	|
	|ИМЕЮЩИЕ
	|	СУММА(ДвиженияВзаиморасчетыСКонтрагентамиИзменение.СуммаИзменение) <> 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СтруктурнаяЕдиница,
	|	Контрагент,
	|	Организация");
	
	Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаИзРезультатаЗапроса = РезультатЗапроса.Выбрать();
	ВыборкаИзРезультатаЗапроса.Следующий();
	
	// Новые изменения были помещены во временную таблицу "ДвиженияВзаиморасчетыСКонтрагентамиИзменение".
	// Добавляется информация о ее существовании и наличии в ней записей об изменении.
	СтруктураВременныеТаблицы.Вставить("ДвиженияВзаиморасчетыСКонтрагентамиИзменение", ВыборкаИзРезультатаЗапроса.Количество > 0);
	
	// Временная таблица "ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью" уничтожается
	Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияВзаиморасчетыСКонтрагентамиПередЗаписью");
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
КонецПроцедуры


#КонецОбласти


