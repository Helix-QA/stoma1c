&НаСервере
// Процедура, создает динамические элементы расшифровки платежа.
//
Процедура СоздатьЭлементыРасшифровкиПлатежа()
	
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.ПрочееСписание Тогда
		ИмяТЧ = "Затраты";
	Иначе
		ИмяТЧ = "РасшифровкаПлатежа";
	КонецЕсли;	
	
	Индекс = 0;
	Для Каждого СтрокаТЧ Из Объект[ИмяТЧ] Цикл
		
		СоздатьСтрокуЭлементовРасшифровки(Индекс);
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Если Объект[ИмяТЧ].Количество() = 0 Тогда
		НоваяСтрока = Объект[ИмяТЧ].Добавить();	
		СоздатьСтрокуЭлементовРасшифровки(0);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, удаляет динамическую строку расшифровки платежа.
//
Процедура УдалитьЭлементыРасшифровкиПлатежа(ИндексСтроки)
	
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.ПрочееСписание Тогда
		ИмяТЧ = "Затраты";
	Иначе
		ИмяТЧ = "РасшифровкаПлатежа";
	КонецЕсли;	
	
	СтрокаДанных = Объект[ИмяТЧ][ИндексСтроки];	
	
	Если СтрокаДанных <> Неопределено Тогда 		
		
		Индекс = 0;
		Для Каждого СтрокаТЧ Из Объект[ИмяТЧ] Цикл
			Элементы.Удалить(Элементы["Строка" + ИмяТЧ + "_" + Индекс]);	
			Индекс = Индекс + 1;              
		КонецЦикла;				
		Объект[ИмяТЧ].Удалить(СтрокаДанных);		
		СоздатьЭлементыРасшифровкиПлатежа();
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, удаляет динамически созданные элементы расшифровки платежа.
//
Процедура ОчиститьЭлементыРасшифровки()
	
	Количество = Элементы.ГруппаСтрокиРасшифровкаПлатежа.ПодчиненныеЭлементы.Количество();  // Элементы.ФС...	
	Если Количество <> 0 Тогда
		
		Для Индекс = 0 По Количество - 1 Цикл
			Элементы.Удалить(Элементы.Найти("СтрокаРасшифровкаПлатежа_" + Индекс));
		КонецЦикла;	
	
	КонецЕсли;
	
	Количество = Элементы.ГруппаСтрокиЗатраты.ПодчиненныеЭлементы.Количество();
	Если Количество <> 0 Тогда
		
		Для Индекс = 0 По Количество - 1 Цикл
			Элементы.Удалить(Элементы.Найти("СтрокаЗатраты_" + Индекс));
		КонецЦикла;	
	
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость элементов в зависимости от вида операции.
//
Процедура ОбновитьОтображениеРасшифровки()
	
	ВидыОпераций = Перечисления.ВидыОпераций;
	
	ОперацияБезТЧ = Объект.ВидОперации = ВидыОпераций.ВозвратСЛицевогоСчета Или Объект.ВидОперации = ВидыОпераций.СдачаНаличныхВБанк
		Или Объект.ВидОперации = ВидыОпераций.ВыдачаПодотчетнику Или Объект.ВидОперации = ВидыОпераций.ВозвратЗайма
		Или Объект.ВидОперации = ВидыОпераций.ВыплатаДивидендовУчредителю Или Объект.ВидОперации = ВидыОпераций.ВыбытиеВКассу;
	
	Если Объект.ВидОперации = ВидыОпераций.ПрочееСписание Тогда
		
		Элементы.ГруппаЗатраты.Видимость		 = Истина;
		Элементы.Дек_Затраты.Видимость			 = Истина;
		Элементы._Затраты.Видимость				 = Ложь;
		Элементы.ГруппаРасшифровка.Видимость  	 = Ложь;
		Элементы.ГруппаДополнительно.Видимость	 = Ложь;
		Элементы._Расшифровка.Видимость			 = Ложь;
		Элементы.Дек_Расшифровка.Видимость		 = Ложь;
		Элементы._Дополнительно.Видимость		 = Истина;
		Элементы.Дек_Дополнительно.Видимость	 = Ложь;
		
		Элементы.Группа_Кнопки_Затраты.ЦветФона			 = Новый Цвет(242, 242, 242);
		Элементы.Группа_Кнопки_Расшифровка.ЦветФона		 = Новый Цвет(255, 255, 255);
		Элементы.Группа_Кнопки_Дополнительно.ЦветФона	 = Новый Цвет(255, 255, 255);
		
	ИначеЕсли ОперацияБезТЧ Тогда
		
		Элементы.ГруппаЗатраты.Видимость		 = Ложь;
		Элементы.ГруппаРасшифровка.Видимость	 = Ложь;
		Элементы.ГруппаДополнительно.Видимость	 = Ложь;
		Элементы._Расшифровка.Видимость			 = Ложь;
		Элементы.Дек_Расшифровка.Видимость		 = Ложь;
		Элементы._Дополнительно.Видимость		 = Истина;
		Элементы.Дек_Дополнительно.Видимость	 = Ложь;
		Элементы._Затраты.Видимость				 = Ложь;
		Элементы.Дек_Затраты.Видимость			 = Ложь;
		
		Элементы.Группа_Кнопки_Дополнительно.ЦветФона = Новый Цвет(255, 255, 255);
		Элементы.Группа_Кнопки_Затраты.ЦветФона		  = Новый Цвет(255, 255, 255);
		Элементы.Группа_Кнопки_Расшифровка.ЦветФона	  = Новый Цвет(255, 255, 255);

	Иначе
		
		Элементы.ГруппаЗатраты.Видимость		 = Ложь;
		Элементы.Дек_Затраты.Видимость			 = Ложь;
		Элементы._Затраты.Видимость				 = Ложь;
		Элементы.ГруппаРасшифровка.Видимость	 = Истина;
		Элементы.ГруппаДополнительно.Видимость	 = Ложь;
		Элементы._Расшифровка.Видимость			 = Ложь;
		Элементы.Дек_Расшифровка.Видимость		 = Истина;
		Элементы._Дополнительно.Видимость		 = Истина;
		Элементы.Дек_Дополнительно.Видимость	 = Ложь;
		
		Элементы.Группа_Кнопки_Затраты.ЦветФона			 = Новый Цвет(255, 255, 255);
		Элементы.Группа_Кнопки_Расшифровка.ЦветФона		 = Новый Цвет(242, 242, 242);
		Элементы.Группа_Кнопки_Дополнительно.ЦветФона	 = Новый Цвет(255, 255, 255);
				
		Если Объект.ВидОперации = ВидыОпераций.ВозвратОплатыСтраховойКомпании Тогда
			Элементы.ГруппаРасшифровкаПлатежа.Видимость		 = Истина;
			Элементы.ГруппаРасшифровкаДинамические.Видимость = Ложь;
		Иначе
			Элементы.ГруппаРасшифровкаПлатежа.Видимость		 = Ложь;
			Элементы.ГруппаРасшифровкаДинамические.Видимость = Истина;
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры	

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
Функция ПолучитьИндексСтроки(ИмяЭлемента)
	
	НомерСимвола = Найти(ИмяЭлемента,"_");
	Возврат Число(Прав(ИмяЭлемента,СтрДлина(ИмяЭлемента) - НомерСимвола)); 
	
КонецФункции

&НаСервере
// Функция возвращает ссылку на отчет
//
Функция СсылкаВариантаОтчета(ИмяОтчета, КлючВарианта)
	
	Отчет = ОбщегоНазначения.ИдентификаторОбъектаМетаданных("Отчет." + ИмяОтчета);
	Возврат ВариантыОтчетов.ВариантОтчета(Отчет, КлючВарианта);
	
КонецФункции

// Процедура - Договор начало выбора завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
&НаКлиенте
Процедура ДоговорНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		Объект.Договор = Результат;
	КонецЕсли;
		
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Видимость группа остаток на ЛС
// 
// Возвращаемое значение:
//   - 
//
Функция ВидимостьГруппаОстатокНаЛС(ВидОперации)
	
	Если ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

#КонецОбласти 
