			ЭлементФормы.Подсказка 		= Нстр("ru = 'Укажите исполнителя задачи'; en = 'Specify the task performer'");
			Объект.Действия[ИндексСтроки].Адресат = НашеОписание.ПривестиЗначение(Объект.Действия[ИндексСтроки].Адресат);
