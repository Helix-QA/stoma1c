// Процедура, устанавливает отображение фильтра.
//
Процедура УстановитьОтображениеФильтраСтатусПациента(Форма)
	
	ЦветАктивности	 = Новый Цвет(218, 230, 244);
	ЦветПоУмолчанию	 = Новый Цвет(255, 255, 255);
	
	Форма.Элементы.ГруппаФильтрСтатусНовые.ЦветФона		 = ?(Форма.ОтборСтатусПациента = ПредопределенноеЗначение("Перечисление.СтатусыКонтрагентов.Первичный"), ЦветАктивности, ЦветПоУмолчанию);
	Форма.Элементы.ГруппаФильтрСтатусПостоянные.ЦветФона = ?(Форма.ОтборСтатусПациента = ПредопределенноеЗначение("Перечисление.СтатусыКонтрагентов.Постоянный"), ЦветАктивности, ЦветПоУмолчанию);
	
КонецПроцедуры

&НаСервере
// Процедура, ОтборНаСервере.
//
Процедура ОбновитьОтборНаСервере(ОтборБезАктивности = Ложь, ОтборПросроченныхЗадач = Ложь, ОтборЗадачНаСегодня = Ложь, УстановитьТекущуюСтруктурнуюЕдиницу = Ложь)
	
	Для Каждого Строка из ТаблицаФильтров Цикл
		Строка.Инициализирован = Ложь;
	КонецЦикла;
	
	МассивИменОчищаемыхФильтров = Новый Массив();
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СотрудникРегистрации");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_РекламныйИсточник");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Тег");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Интерес");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПредварительнаяЗапись"); 	
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Задача"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_КаналПривлечения");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПризнакВыполненияСделки"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СозданаПериод");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ЗавершенаПериод"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПериодЗапланированнойЗадачи");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПричинаОтказа");		
	
	Если Не ОтборБезАктивности И Не ОтборПросроченныхЗадач И Не ОтборЗадачНаСегодня Тогда
		
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Менеджер");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияСделки");		
		
	КонецЕсли;
	
	УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	
	Если ОтборБезАктивности Тогда
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПредварительнаяЗапись", Ложь);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", Ложь);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", Ложь);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияСделки", Истина,,,, Ложь);
		
	ИначеЕсли ОтборПросроченныхЗадач Тогда
		
		СтруктураПериода = Новый Структура;
		СтруктураПериода.Вставить("Вариант"			, ВариантСтандартногоПериода.ПроизвольныйПериод);
		СтруктураПериода.Вставить("ДатаНачала"		, Дата(1, 1, 1));
		СтруктураПериода.Вставить("ДатаОкончания"	, КонецДня(ТекущаяДатаСеанса() - 86400));
		
		МассивПериодаЗапланированнойЗадачи = Новый_Массив(СтруктураПериода);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", МассивПериодаЗапланированнойЗадачи);		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", Ложь);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияСделки", Истина,,,, Ложь);
		
	ИначеЕсли ОтборЗадачНаСегодня Тогда
		
		СтруктураПериода = Новый Структура;
		СтруктураПериода.Вставить("Вариант"			, ВариантСтандартногоПериода.ПроизвольныйПериод);
		СтруктураПериода.Вставить("ДатаНачала"		, НачалоДня(ТекущаяДатаСеанса()));
		СтруктураПериода.Вставить("ДатаОкончания"	, КонецДня(ТекущаяДатаСеанса()));
		
		МассивПериодаЗапланированнойЗадачи = Новый_Массив(СтруктураПериода);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", МассивПериодаЗапланированнойЗадачи);		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", Ложь);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияСделки", Истина,,,, Ложь);
		
	Иначе
		
		Если УстановитьТекущуюСтруктурнуюЕдиницу = Истина Тогда
			ЗначенияФильтрации = Новый_Массив(ЭтотОбъект.ТекущаяСтруктурнаяЕдиница, Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ЗначенияФильтрации);
		КонецЕсли;
		
		УстановитьОтображениеФильтровПоЗадачам(ЭтотОбъект, ОтборБезАктивности, ОтборПросроченныхЗадач, ОтборЗадачНаСегодня);
		СформироватьКанбан();	
		Возврат;
		
	КонецЕсли;
	
	СтруктураОтборов = Новый Структура;
	СтруктураОтборов.Вставить("ОтборМенеджер"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Менеджер"));
	СтруктураОтборов.Вставить("ОтборСтруктурнаяЕдиница"	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СтруктурнаяЕдиница"));
	
	СписокМенеджеров = СтруктураОтборов.ОтборМенеджер;
	Если Не ЗначениеЗаполнено(СписокМенеджеров) Тогда
		СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения;
	КонецЕсли;
	УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", СписокМенеджеров.ВыгрузитьЗначения(), Истина);
	
	Если УстановитьТекущуюСтруктурнуюЕдиницу = Истина Тогда
		ЗначенияФильтрации = Новый_Массив(ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
		
	Иначе
		СписокКлиник = СтруктураОтборов.ОтборСтруктурнаяЕдиница;
		Если Не ЗначениеЗаполнено(СписокКлиник) Тогда
			СписокКлиник = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения;
		КонецЕсли;
		
		ЗначенияФильтрации = СписокКлиник.ВыгрузитьЗначения();
		
	КонецЕсли;
	
	УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ЗначенияФильтрации);
	
	УстановитьОтображениеФильтровПоЗадачам(ЭтотОбъект, ОтборБезАктивности, ОтборПросроченныхЗадач, ОтборЗадачНаСегодня);
	
	СформироватьКанбан();	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура ПослеВыбораВидаСделки(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Или Результат.Значение = ЭтотОбъект.ВидСделки Тогда
		// Ничего не изменилось - действий не требуется.
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.ВидСделки				 = Результат.Значение;
	Элементы.ИзменитьВидСделки.Заголовок = Результат.Представление;
	
	СформироватьКанбан();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обрабатывает оповещение об изменении сделки.
//
Процедура ОбработатьИзменениеСделки(Сделка)
	
	Документ = Элементы.Канбан.Документ;
	
	СелекторСделки		 = ПолучитьСелекторСсылки(Сделка) + ".item-col";
	УдаляемыйБлокСделки	 = Документ.querySelector(СелекторСделки);
	
	Если УдаляемыйБлокСделки <> Неопределено Тогда
		
		// При необходимости подгрузить следующую заявку для этоой колонки.
		КолонкаУдаляемойСделки = УдаляемыйБлокСделки.closest(".kanban-board");
		
		КоличествоСделокВКолонкеВсего	 = Число(КолонкаУдаляемойСделки.querySelector(".item-count").dataset.count);
		КоличествоСделокВКолонкеТекущее	 = КолонкаУдаляемойСделки.querySelectorAll(".kanban-item").length;
		ТребуетсяПолучитьСделкуИзОчереди = КоличествоСделокВКолонкеВсего > Макс(ЭтотОбъект.МаксимальноеКоличествоСделокВКолонке, КоличествоСделокВКолонкеТекущее);
		
		Если ТребуетсяПолучитьСделкуИзОчереди Тогда
			
			ИдентификаторыИсключаемыхСделок = Новый Массив;
			
			Для Каждого БлокЗаявки Из КолонкаУдаляемойСделки.querySelector(".kanban-drag").children Цикл
				
				Если БлокЗаявки.className = "show-all" Тогда
					Продолжить;
				КонецЕсли;
				
				ИдентификаторыИсключаемыхСделок.Добавить(БлокЗаявки.children[0].id);
				
			КонецЦикла;
			
			ИдентификаторЭтапа = КолонкаУдаляемойСделки.dataset.id;
			
			ПараметрыПолученияСделкиИзОчереди = Новый Структура;
			ПараметрыПолученияСделкиИзОчереди.Вставить("ЭтапСделки"						, ИдентификаторЭтапа);
			ПараметрыПолученияСделкиИзОчереди.Вставить("ИдентификаторыИсключаемыхСделок", ИдентификаторыИсключаемыхСделок);
			
		КонецЕсли;
		
		// Удаляем существующий неактуальный блок заявки.
		УдаляемыйБлокСделки.parentElement.remove();
		
	КонецЕсли;
	
	СтруктураОтбора	 = ПолучитьСтруктуруЗначенийОтбораКлиент();
	ДанныеБлока		 = ПолучитьДанныеБлокаСделки(Сделка, СтруктураОтбора, ПараметрыПолученияСделкиИзОчереди);
	
	Если Не ЗначениеЗаполнено(ДанныеБлока) Тогда
		Возврат;
	КонецЕсли;
	
	КолонкаДанныхКанбана = Документ.querySelector(".kanban-board[data-id=" + Документ.CSS.escape(ДанныеБлока.ПредставлениеКолонки) + "] .kanban-drag");
	
	// Добавляем новый блок в начало колонки.
	НовыйБлокСделки				 = Документ.createElement("div");
	НовыйБлокСделки.innerHTML	 = ДанныеБлока.БлокСделки;
	НовыйБлокСделки.className	 = "kanban-item";
	
	КолонкаДанныхКанбана.prepend(НовыйБлокСделки);
	
	ОбновитьКоличествоСделокВБлоках(ДанныеБлока.ДанныеКоличества);
	ВывестиСделкуИзОчереди(ДанныеБлока.ДанныеВыводимойСделки);
	
КонецПроцедуры

&НаСервере
// Процедура, инициализирует данные соответствия для дальнейшего использвания.
//
Процедура ИнициализироватьДанныеПредопределенногоВидаСделки()
	
	ВидСделкиПервичныйПовторный = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	Если НЕ ЗначениеЗаполнено(ВидСделкиПервичныйПовторный) Тогда 
		ДанныеВидаСделки = Новый Соответствие;
		ДанныеВидаСделки.Вставить("ИдентификаторПричиныОтказаНеПришел", "");		
		ЭтотОбъект.ДанныеПредопределенногоВидаСделки = Новый ФиксированноеСоответствие(ДанныеВидаСделки);
	КонецЕсли;		
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидСделкиПервичныйПовторный", ВидСделкиПервичныйПовторный);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Ссылка = &ВидСделкиПервичныйПовторный
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа,
	|	ЭтапыСделок.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ВидСделки = &ВидСделкиПервичныйПовторный
	|	И НЕ ЭтапыСделок.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЭтапыСделок.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ИмяПредопределенныхДанных = ""Отказ""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЭтапыСделок.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ИмяПредопределенныхДанных = ""Успех""";
	
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	
	ВыборкаВидСделки = РезультатыЗапросов[0].Выбрать();
	ВыборкаВидСделки.Следующий();
	
	ЭтотОбъект.ВидСделкиПоУмолчанию	 = ВыборкаВидСделки.Ссылка;
	ЭтотОбъект.ВидСделки			 = ВыборкаВидСделки.Ссылка;
	
	Элементы.ИзменитьВидСделки.Заголовок = ВыборкаВидСделки.Наименование;
	
	ВыборкаЭтапыСделок = РезультатыЗапросов[1].Выбрать();
	
	ДанныеВидаСделки = Новый Соответствие;
	
	Пока ВыборкаЭтапыСделок.Следующий() Цикл
		Если ВыборкаЭтапыСделок.НомерЭтапа = 1 Тогда
			ДанныеВидаСделки.Вставить("ЭтапПотенциальныйПрием", ВыборкаЭтапыСделок.Ссылка);
		ИначеЕсли ВыборкаЭтапыСделок.НомерЭтапа = 2 Тогда
			ДанныеВидаСделки.Вставить("ЭтапПредложениеОзвучено", ВыборкаЭтапыСделок.Ссылка);
		ИначеЕсли ВыборкаЭтапыСделок.НомерЭтапа = 3 Тогда
			ДанныеВидаСделки.Вставить("ЭтапКлиентЗаписан", ВыборкаЭтапыСделок.Ссылка);
		ИначеЕсли ВыборкаЭтапыСделок.НомерЭтапа = 4 Тогда
			ДанныеВидаСделки.Вставить("ЭтапКлиентПодтвердил", ВыборкаЭтапыСделок.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	ВыборкаЭтапОтказ = РезультатыЗапросов[2].Выбрать();
	ВыборкаЭтапОтказ.Следующий();
	ДанныеВидаСделки.Вставить("ЭтапОтказ", ВыборкаЭтапОтказ.Ссылка);
	
	ВыборкаЭтапУспех = РезультатыЗапросов[3].Выбрать();
	ВыборкаЭтапУспех.Следующий();
	ДанныеВидаСделки.Вставить("ЭтапУспех", ВыборкаЭтапУспех.Ссылка);
	
	//ВыборкаПричинаОтказаНеПришел = РезультатыЗапросов[2].Выбрать();
	//ВыборкаПричинаОтказаНеПришел.Следующий();
	
	ПричинаОтказаНеПришел = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентНеПришел");
	Если ЗначениеЗаполнено(ПричинаОтказаНеПришел) Тогда 
		ДанныеВидаСделки.Вставить("ИдентификаторПричиныОтказаНеПришел", Строка(ПричинаОтказаНеПришел.УникальныйИдентификатор()));
	Иначе 
		ДанныеВидаСделки.Вставить("ИдентификаторПричиныОтказаНеПришел", "");
	КонецЕсли;
	
	//ВыборкаПричинаОтказаОтказался = РезультатыЗапросов[3].Выбрать();
	//ВыборкаПричинаОтказаОтказался.Следующий(); 
	
	ПричинаОтказаОтказался = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался");
	Если ЗначениеЗаполнено(ПричинаОтказаНеПришел) Тогда 	
		ДанныеВидаСделки.Вставить("ПричинаОтказаОтказался", ПричинаОтказаОтказался);
	Иначе 
		ДанныеВидаСделки.Вставить("ПричинаОтказаОтказался", Справочники.ПричиныОтказов.ПустаяСсылка());
	КонецЕсли;
	
	ЭтотОбъект.ДанныеПредопределенногоВидаСделки = Новый ФиксированноеСоответствие(ДанныеВидаСделки);
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет доступные виды сделок.
//
Процедура ЗаполнитьДоступныеВидыСделок()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка КАК Ссылка,
	|	ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыСделок.СтруктурныеЕдиницыПрименения КАК ВидыСделокСтруктурныеЕдиницыПрименения
	|ГДЕ
	|	ВидыСделокСтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница В (&СтруктурнаяЕдиница, ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))
	|	И НЕ ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЭтотОбъект.ДоступныеВидыСделок.Добавить(Выборка.Ссылка, Выборка.Наименование);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет канбан.
//
Процедура ОбновитьПредставлениеКанбана() Экспорт
	
	СформироватьКанбан();
	ЭтотОбъект.ТекущийЭлемент = Элементы.Канбан;
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает отбор по статусу.
//
Процедура УстановитьОтбор(ПараметрыОтбора) Экспорт
	
	// Используется для установки фильтра из формы списка.
	// См. ФормаСписка.ОткрытьКанбан.
	ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет переход на форму списка с установкой фильтра по статусу.
//
Процедура ПерейтиВСписок(ИдентификаторЭтапа = Неопределено)
	
	ФормаСписка = ПолучитьОткрытуюФорму("Справочник.Сделки.Форма.ФормаСпискаНовая");
	
	ПараметрыОтбора = ПараметрыВыбранныхФильтровКлиент();
	ПараметрыОтбора.Вставить("ВидСделки"			, ЭтотОбъект.ВидСделки);
	ПараметрыОтбора.Вставить("ОтборСтатусПациента"	, ЭтотОбъект.ОтборСтатусПациента);
	ПараметрыОтбора.Вставить("ОтборПоЗадачам"		, ЭтотОбъект.ОтборПоЗадачам);
	
	Если ЗначениеЗаполнено(ИдентификаторЭтапа) Тогда
		ПараметрыОтбора.Вставить("МассивЭтапов"					, Новый_Массив(ПолучитьСсылку("Справочники", "ЭтапыСделок", ИдентификаторЭтапа)));
		ПараметрыОтбора.Вставить("МассивЭтапов_ВариантОтбора"	, Истина);
	КонецЕсли;
	
	Если ФормаСписка = Неопределено Тогда
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ПараметрыОтбора", ПараметрыОтбора);
		
		ОткрытьФормуСписка(ПараметрыОткрытия);
		
	Иначе
		ФормаСписка.Активизировать();
		ФормаСписка.УстановитьОтбор(ПараметрыОтбора);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, открывает форму списка сделок.
//
Процедура ОткрытьФормуСписка(ПараметрыОткрытия = Неопределено)
	
	ОткрытьФорму("Справочник.Сделки.Форма.ФормаСпискаНовая", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обрабатывает вызов события из HTML-документа.
//
Процедура ОбработатьВызовСобытия(ИмяСобытия)
	
	Если ИмяСобытия = "drop" Тогда
		ИзменитьЭтапСделки();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, изменяет этап сделки.
//
Процедура ИзменитьЭтапСделки()
	
	Документ = Элементы.Канбан.Документ;
	
	Если Документ.defaultView.dropElement.parentElement = Документ.defaultView.dropSource Тогда
		// Сделка осталась в том же блоке.
		Возврат;
	КонецЕсли;
	
	ИдентификаторЭтапа	 = Документ.defaultView.dropTarget.parentElement.dataset.id;
	ИдентификаторСделки	 = Документ.defaultView.dropElement.querySelector(".item-col").id;
	
	КоличествоСделокВИсточникеВсего		 = Число(Документ.defaultView.dropSource.parentElement.querySelector(".item-count").dataset.count);
	КоличествоСделокВИсточникеТекущее	 = Документ.defaultView.dropSource.querySelectorAll(".kanban-item").length;
	ТребуетсяПолучитьСделкуИзОчереди	 = КоличествоСделокВИсточникеВсего > Макс(ЭтотОбъект.МаксимальноеКоличествоСделокВКолонке, КоличествоСделокВИсточникеТекущее + 1);
	
	Если ТребуетсяПолучитьСделкуИзОчереди Тогда
		
		ИдентификаторыИсключаемыхСделок = Новый Массив;
		
		Для Каждого БлокСделки Из Документ.defaultView.dropSource.children Цикл
			
			Если БлокСделки.className = "show-all" Тогда
				Продолжить;
			КонецЕсли;
			
			ИдентификаторыИсключаемыхСделок.Добавить(БлокСделки.children[0].id);
			
		КонецЦикла;
		
		ИзмененныйЭтап = Документ.defaultView.dropSource.parentElement.dataset.id;
		
		ПараметрыПолученияСделкиИзОчереди = Новый Структура;
		ПараметрыПолученияСделкиИзОчереди.Вставить("ЭтапСделки"						, ИзмененныйЭтап);
		ПараметрыПолученияСделкиИзОчереди.Вставить("ИдентификаторыИсключаемыхСделок", ИдентификаторыИсключаемыхСделок);
		
	КонецЕсли;
	
	СтруктураОтборов = ПолучитьСтруктуруЗначенийОтбораКлиент();
	
	ОбработатьПереходНаЭтап(ИдентификаторСделки, ИдентификаторЭтапа, СтруктураОтборов, ПараметрыПолученияСделкиИзОчереди);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обрабатывает изменение этапа сделки.
//
Процедура ОбработатьПереходНаЭтап(ИдентификаторСделки, ИдентификаторЭтапа, СтруктураОтборов, ПараметрыПолученияСделкиИзОчереди)
	
	ЭтапОтказ = ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапОтказ");
	Если ЭтотОбъект.ВидСделки <> ЭтотОбъект.ВидСделкиПоУмолчанию И ЗначениеЗаполнено(ЭтапОтказ)
		И ИдентификаторЭтапа = Строка(ЭтапОтказ.УникальныйИдентификатор()) Тогда
		
		// Даем выбрать причину отказа только для пользователских видов сделок,
		// для предопределенного всегда "Клиент отказался".
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("СтруктураОтборов"					, СтруктураОтборов);
		ПараметрыОповещения.Вставить("ИдентификаторЭтапа"				, ИдентификаторЭтапа);
		ПараметрыОповещения.Вставить("ИдентификаторСделки"				, ИдентификаторСделки);
		ПараметрыОповещения.Вставить("ПараметрыПолученияСделкиИзОчереди", ПараметрыПолученияСделкиИзОчереди);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораРезультатаСделкиОтказ", ЭтотОбъект, ПараметрыОповещения);
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ИдентификаторСделки"	, ИдентификаторСделки);
		ПараметрыОткрытия.Вставить("ИмяЗавершающегоЭтапа"	, "Отказ");
		
		ОткрытьФорму("Справочник.Сделки.Форма.ФормаРезультатаСделки", ПараметрыОткрытия,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Возврат;
		
	КонецЕсли;
	
	ЭтапУспех = ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапУспех");
	Если ЭтотОбъект.ВидСделки <> ЭтотОбъект.ВидСделкиПоУмолчанию И ЗначениеЗаполнено(ЭтапУспех)
		И ИдентификаторЭтапа = Строка(ЭтапУспех.УникальныйИдентификатор()) Тогда
		
		// Перевести сделку в успех можно только в пользовательском виде сделки,
		// для предопределенного этап "Успех" проставляется автоматически.
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("СтруктураОтборов"					, СтруктураОтборов);
		ПараметрыОповещения.Вставить("ИдентификаторЭтапа"				, ИдентификаторЭтапа);
		ПараметрыОповещения.Вставить("ИдентификаторСделки"				, ИдентификаторСделки);
		ПараметрыОповещения.Вставить("ПараметрыПолученияСделкиИзОчереди", ПараметрыПолученияСделкиИзОчереди);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораРезультатаСделкиУспех", ЭтотОбъект, ПараметрыОповещения);
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ИдентификаторСделки"	, ИдентификаторСделки);
		ПараметрыОткрытия.Вставить("ИмяЗавершающегоЭтапа"	, "Успех");
		
		ОткрытьФорму("Справочник.Сделки.Форма.ФормаРезультатаСделки", ПараметрыОткрытия,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Возврат;
		
	КонецЕсли;
	
	ДополнительныеПараметрыСделки = Новый Структура;
	
	Если ЗначениеЗаполнено(ЭтапОтказ) И ИдентификаторЭтапа = Строка(ЭтапОтказ.УникальныйИдентификатор()) Тогда
		ДополнительныеПараметрыСделки.Вставить("ПричинаОтказа", ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ПричинаОтказаОтказался"));
	КонецЕсли;
	
	РезультатОперации = ОбработатьПереходНаЭтапНаСервере(
		ИдентификаторСделки,
		ИдентификаторЭтапа,
		СтруктураОтборов,
		ПараметрыПолученияСделкиИзОчереди,
		ДополнительныеПараметрыСделки
	);
	ОбработатьРезультатПереходаНаЭтап(РезультатОперации);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура ПослеВыбораРезультатаСделкиОтказ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		ОтменитьПеретаскиваниеСделки();
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметрыСделки = Новый Структура("ПричинаОтказа", Результат.ПричинаОтказа);
	
	РезультатОперации = ОбработатьПереходНаЭтапНаСервере(
		ДополнительныеПараметры.ИдентификаторСделки,
		ДополнительныеПараметры.ИдентификаторЭтапа,
		ДополнительныеПараметры.СтруктураОтборов,
		ДополнительныеПараметры.ПараметрыПолученияСделкиИзОчереди,
		ДополнительныеПараметрыСделки
	);
	ОбработатьРезультатПереходаНаЭтап(РезультатОперации);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура ПослеВыбораРезультатаСделкиУспех(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		ОтменитьПеретаскиваниеСделки();
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("Прием") Тогда
		ДополнительныеПараметрыСделки = Новый Структура("Прием", Результат.Прием);
	КонецЕсли;
	
	РезультатОперации = ОбработатьПереходНаЭтапНаСервере(
		ДополнительныеПараметры.ИдентификаторСделки,
		ДополнительныеПараметры.ИдентификаторЭтапа,
		ДополнительныеПараметры.СтруктураОтборов,
		ДополнительныеПараметры.ПараметрыПолученияСделкиИзОчереди,
		ДополнительныеПараметрыСделки
	);
	ОбработатьРезультатПереходаНаЭтап(РезультатОперации);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, выполняет переход сделки на этап.
//
Функция ОбработатьПереходНаЭтапНаСервере(
		ИдентификаторСделки,
		ИдентификаторЭтапа,
		СтруктураОтборов,
		ПараметрыПолученияСделкиИзОчереди,
		ДополнительныеПараметрыСделки = Неопределено
	)
	
	РезультатОперации = Новый Структура;
	РезультатОперации.Вставить("ОписаниеОшибки"		, "");
	РезультатОперации.Вставить("ВыполненоУспешно"	, Ложь);
	
	Попытка
		Сделка		 = Справочники.Сделки.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторСделки));
		ЭтапСделки	 = Справочники.ЭтапыСделок.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторЭтапа));
		СделкаОбъект = Сделка.ПолучитьОбъект();
		
		Если ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
			СделкаОбъект.ЭтапОтказа		 = СделкаОбъект.ЭтапСделки;
			СделкаОбъект.РезультатСделки = Перечисления.РезультатыСделок.Отказ;
		Иначе
			СделкаОбъект.ПричинаОтказа = Неопределено;
		КонецЕсли;
		
		Если ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда
			СделкаОбъект.ЭтапУспеха		 = СделкаОбъект.ЭтапСделки;
			СделкаОбъект.РезультатСделки = Перечисления.РезультатыСделок.Успех;
		КонецЕсли;
		
		Если ЭтапСделки <> Справочники.ЭтапыСделок.Успех И ЭтапСделки <> Справочники.ЭтапыСделок.Отказ Тогда
			СделкаОбъект.ЭтапУспеха		 = Неопределено;
			СделкаОбъект.ЭтапОтказа		 = Неопределено;
			СделкаОбъект.РезультатСделки = Неопределено;
		КонецЕсли;
		
		СделкаОбъект.ЭтапСделки = ЭтапСделки;
		
		Если ЗначениеЗаполнено(ДополнительныеПараметрыСделки) Тогда
			ЗаполнитьЗначенияСвойств(СделкаОбъект, ДополнительныеПараметрыСделки);
		КонецЕсли;
		
		СделкаОбъект.Записать();
		
		РезультатОперации.ВыполненоУспешно = Истина;
		
	Исключение
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Не удалось изменить этап сделки. Текст ошибки: '") + ОписаниеОшибки();
		
	КонецПопытки;
	
	Если РезультатОперации.ВыполненоУспешно Тогда
		ЗаполнитьДополнительныеПараметрыРезультата(СделкаОбъект.Ссылка, РезультатОперации, СтруктураОтборов, ПараметрыПолученияСделкиИзОчереди);
	КонецЕсли;
	
	Возврат РезультатОперации;
	
КонецФункции

&НаКлиенте
// Процедура, обрабатывает результат изменения этапа сделки.
//
Процедура ОбработатьРезультатПереходаНаЭтап(РезультатОперации, ОбрабатыватьИзменение = Ложь)
	
	// Все прошло успешно, обновляем количество сделок в блоках.
	Если РезультатОперации.ВыполненоУспешно = Истина Тогда
		
		Оповестить("ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ", РезультатОперации.Сделка, ?(ОбрабатыватьИзменение = Истина, Неопределено, ЭтотОбъект));
		
		ВывестиСделкуИзОчереди(РезультатОперации.ДанныеВыводимойСделки);
		ОбновитьКоличествоСделокВБлоках(РезультатОперации.ДанныеКоличества);
		ОбновитьПредставлениеСделки(РезультатОперации.Сделка, РезультатОперации.БлокСделки);
		УстановитьЗаголовкиДополнительныхОтборов(ЭтотОбъект, ПолучитьСтруктуруЗначенийОтбораКлиент(), РезультатОперации.ДанныеКоличестваПоОтборам);
		
		Возврат;
		
	КонецЕсли;
	
	// Сообщаем об ошибке и отменяем визуальные последствия действия.
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОперации.ОписаниеОшибки);
	ОтменитьПеретаскиваниеСделки();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет представление сделки.
//
Процедура ОбновитьПредставлениеСделки(Сделка, БлокСделки)
	
	Документ = Элементы.Канбан.Документ;
	
	СелекторСделки				 = ПолучитьСелекторСсылки(Сделка) + ".item-col";
	БлокСделкиЭлемент			 = Документ.querySelector(СелекторСделки);
	БлокСделкиЭлемент.outerHTML	 = БлокСделки;
	
КонецПроцедуры

&НаКлиенте
// Процедура, возвращает сделку в изначальный блок.
//
Процедура ОтменитьПеретаскиваниеСделки()
	
	Документ = Элементы.Канбан.Документ;
	
	Документ.defaultView.dropTarget.removeChild(Документ.defaultView.dropElement);
	Документ.defaultView.dropSource.prepend(Документ.defaultView.dropElement);
	
КонецПроцедуры

&НаКлиенте
// Процедура, выводит следующую в очереди сделку.
//
Процедура ВывестиСделкуИзОчереди(ДанныеВыводимойСделки)
	
	Если Не ЗначениеЗаполнено(ДанныеВыводимойСделки) Тогда
		Возврат;
	КонецЕсли;
	
	Документ = Элементы.Канбан.Документ;
	
	КолонкаДляДобавления = Документ.querySelector(".kanban-board[data-id='" + ДанныеВыводимойСделки.ЭтапСделки + "']");
	
	БлокВыводимойСделки = Документ.createElement("div");
	БлокВыводимойСделки.className = "kanban-item";
	БлокВыводимойСделки.innerHTMl = ДанныеВыводимойСделки.БлокСделки;
	
	КнопкаПереходаВСписок = КолонкаДляДобавления.querySelector(".show-all");
	КнопкаПереходаВСписок.before(БлокВыводимойСделки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет представление количества сделок в блоках.
//
Процедура ОбновитьКоличествоСделокВБлоках(ДанныеКоличества)
	
	Документ = Элементы.Канбан.Документ;
	
	КонтейнерБлоков = Документ.querySelector(".kanban-container");
	
	Для Каждого Блок Из КонтейнерБлоков.children Цикл
		
		КоличествоСделок = ДанныеКоличества.Получить(Блок.dataset.id);
		КоличествоСделок = ?(КоличествоСделок = Неопределено, 0, КоличествоСделок);
		
		КнопкаПоказатьВсе				 = Блок.querySelector(".show-all");
		КнопкаПоказатьВсе.dataset.count	 = КоличествоСделок;
		
		ПредставлениеКоличестваЭлемент				 = Блок.querySelector("span.item-count");
		ПредставлениеКоличестваЭлемент.dataset.count = КоличествоСделок;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, выполняет оповещение сеансов об изменении сделки и 
// Заполняет дополнительные параметры для обработки изменения сделки.
//
Процедура ЗаполнитьДополнительныеПараметрыРезультата(Сделка, РезультатОперации, СтруктураОтборов, ПараметрыПолученияСделкиИзОчереди)
	
	// Оповещение других сеансов не требуется - описано в модуле объекта.
	
	РезультатОперации.Вставить("Сделка", Сделка);
	
	// Получаем данные количества сделок.
	ДанныеКоличества = ПолучитьКоличествоСделокВКолонках(СтруктураОтборов);
	РезультатОперации.Вставить("ДанныеКоличества", ДанныеКоличества);
	
	// Получаем данные количества сделок по дополнительным отборам.
	ДанныеКоличестваПоОтборам = ПолучитьКоличествоСделокПоДополнительнымОтборам(СтруктураОтборов);
	РезультатОперации.Вставить("ДанныеКоличестваПоОтборам", ДанныеКоличестваПоОтборам);
	
	// Получаем следующую в очереди сделку для отображения в блоке.
	ДанныеВыводимойСделки = ПолучитьДанныеВыводимойСделки(СтруктураОтборов, ПараметрыПолученияСделкиИзОчереди);
	РезультатОперации.Вставить("ДанныеВыводимойСделки", ДанныеВыводимойСделки);
	
	// Получаем блок текущей сделки для обновления представления.
	ДанныеСделки			 = ПолучитьДанныеСделки(СтруктураОтборов, Сделка);
	ОбновленныйБлокСделки	 = ПолучитьБлокСделки(ДанныеСделки);
	РезультатОперации.Вставить("БлокСделки", ОбновленныйБлокСделки);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает данные сделки из очереди.
//
Функция ПолучитьДанныеВыводимойСделки(Знач СтруктураОтбора, ПараметрыПолученияСделкиИзОчереди)
	
	Если Не ЗначениеЗаполнено(ПараметрыПолученияСделкиИзОчереди) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЭтапСделки						 = ПараметрыПолученияСделкиИзОчереди.ЭтапСделки;
	ИдентификаторыИсключаемыхСделок	 = ПараметрыПолученияСделкиИзОчереди.ИдентификаторыИсключаемыхСделок;
	
	ИсключаемыеСделки = Новый Массив;
	
	Для Каждого ИдентификаторСделки Из ИдентификаторыИсключаемыхСделок Цикл
		
		ИсключаемаяСделка = Справочники.Сделки.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторСделки));
		ИсключаемыеСделки.Добавить(ИсключаемаяСделка);
		
	КонецЦикла;
	
	СтруктураОтбора.Вставить("ЭтапСделки", Справочники.ЭтапыСделок.ПолучитьСсылку(Новый УникальныйИдентификатор(ЭтапСделки)));
	
	ДанныеСделки = ПолучитьДанныеСделки(СтруктураОтбора,, ИсключаемыеСделки);
	
	Если Не ЗначениеЗаполнено(ДанныеСделки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	БлокСделки = ПолучитьБлокСделки(ДанныеСделки);
	
	ДанныеВыводимойСделки = Новый Структура;
	ДанныеВыводимойСделки.Вставить("ЭтапСделки"	, ЭтапСделки);
	ДанныеВыводимойСделки.Вставить("БлокСделки"	, БлокСделки);
	
	Возврат ДанныеВыводимойСделки;
	
КонецФункции

&НаСервере
// Функция, возвращает блок колонки.
//
Функция ПолучитьБлокКолонки(ДанныеСделки, БлокиСделок, КоличествоСделок)
	
	ИмяСтатуса					 = XMLСтрока(ДанныеСделки.ЭтапСделки);
