

#Область СлужебныеПроцедурыИФункции

// Возвращает реквизиты справочника, которые образуют естественный ключ
//  для элементов справочника.
//
// Возвращаемое значение: Массив(Строка) - массив имен реквизитов, образующих
//  естественный ключ.
//
Функция ПоляЕстественногоКлюча() Экспорт
	
	Результат = Новый Массив();
	
	Результат.Добавить("Код");
	
	Возврат Результат;
	
КонецФункции

Функция ДобавитьДиагнозыИзКлассификатора() Экспорт
	
	Возврат ДобавитьДиагнозыДляСтоматологии();
	
КонецФункции

Функция ДобавитьДиагнозыДляСтоматологии()

	КолличествоДобавленныхДиагнозов = 0;
	
	// Получим Область с данными диагноза из макета.
	КлассификаторАвтомобилей = ПолучитьМакет("КлассификаторДиагнозовСтоматология");
	СписокДиагнозов = КлассификаторАвтомобилей.ПолучитьОбласть("СписокДиагнозов");
	ОбластьПолеКод = КлассификаторАвтомобилей.Область("ПолеКод");
	ОбластьПолеДиагноз = КлассификаторАвтомобилей.Область("ПолеДиагноз");
	
	// Перебираем все диагнозы и сравниваем с существующими.
	Для СтрокаНомерСтроки = 1 По СписокДиагнозов.ВысотаТаблицы Цикл
		
		// Получилим наименование и код диагноза.
		СтрокаКод = СписокДиагнозов.Область(СтрокаНомерСтроки, ОбластьПолеКод.Лево, СтрокаНомерСтроки, ОбластьПолеКод.Право).Текст;
		СтрокаДиагноз = СписокДиагнозов.Область(СтрокаНомерСтроки, ОбластьПолеДиагноз.Лево, СтрокаНомерСтроки, ОбластьПолеДиагноз.Право).Текст;
		
		// Проверяем есть ли этот диагноза в базе, если нет - добавляем.
		Если Справочники.Диагнозы.НайтиПоКоду(СтрокаКод).Пустая() Тогда 
			
			Если Найти(СтрокаКод, ".") Тогда
				НовыйОбъект = Справочники.Диагнозы.СоздатьЭлемент();
				НовыйОбъект.Родитель = Справочники.Диагнозы.НайтиПоКоду(Сред(СтрокаКод, 1, Найти(СтрокаКод, ".") - 1));
			Иначе
				НовыйОбъект = Справочники.Диагнозы.СоздатьГруппу();
			КонецЕсли;
			НовыйОбъект.Код 			= СтрокаКод;
		  	НовыйОбъект.Наименование	= СтрокаДиагноз;
		  	НовыйОбъект.Записать();
			
		  	КолличествоДобавленныхДиагнозов = КолличествоДобавленныхДиагнозов + 1;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат(КолличествоДобавленныхДиагнозов);
	
КонецФункции

// Процедура создает значения из справочника oid:1.2.643.2.69.1.1.1.5 ИЭМК "КлассификаторСоциальныхСтатусов"
//
Процедура ЗаполнитьСправочникКлассификаторСоциальныхСтатусов(Параметры) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Для Каждого Элемент Из Параметры Цикл
		
		КодЭлемента = Формат(Число(СтрЗаменить(Элемент.code, ".", "")), "ЧЦ=9; ЧВН=; ЧГ=0");
		Если ЗначениеЗаполнено(Справочники.КлассификаторСоциальныхСтатусов.НайтиПоКоду(КодЭлемента)) Тогда
			Если НРег(Элемент.display) <> НРег(Справочники.КлассификаторСоциальныхСтатусов.НайтиПоКоду(КодЭлемента).Наименование) Тогда
				ЭлементСправочника = Справочники.КлассификаторСоциальныхСтатусов.НайтиПоКоду(КодЭлемента).ПолучитьОбъект();
				ЭлементСправочника.Наименование = Лев(Врег(Лев(Элемент.display,1))+ Нрег(Сред(Элемент.display,2)), 100);
				Если Элемент.code <> "1" И Элемент.code <> "2" Тогда
					ЭлементСправочника.КодОИД = Элемент.code;
				КонецЕсли;
				ЭлементСправочника.Записать();
			КонецЕсли;
		Иначе
			Если Элемент.code <> "1" И Элемент.code <> "2" Тогда
				ЭлементСправочника = Справочники.КлассификаторСоциальныхСтатусов.СоздатьЭлемент();
				ЭлементСправочника.КодОИД = Элемент.code;
				Если Лев(Элемент.code, 1) = "1" Или Лев(Элемент.code, 1) = "2" Тогда
					Родитель = Справочники.КлассификаторСоциальныхСтатусов.НайтиПоКоду(Формат(Число(Лев(Элемент.code, 1)), "ЧЦ=9; ЧВН=; ЧГ=0"));
				Иначе
					Родитель = Справочники.КлассификаторСоциальныхСтатусов.ПустаяСсылка();
				КонецЕсли;
				ЭлементСправочника.Родитель = Родитель;
				ЭлементСправочника.Наименование = Лев(Врег(Лев(Элемент.display,1))+ Нрег(Сред(Элемент.display,2)), 100);
				ЭлементСправочника.Код = КодЭлемента;
				ЭлементСправочника.Записать();
			Иначе
				ГруппаСправочника = Справочники.КлассификаторСоциальныхСтатусов.СоздатьГруппу();
				ГруппаСправочника.Наименование = Лев(Врег(Лев(Элемент.display,1))+ Нрег(Сред(Элемент.display,2)), 100);
				ГруппаСправочника.Код = КодЭлемента;
				ГруппаСправочника.Записать();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти