
#Область СлужебныйПрограммныйИнтерфейс
Перем БлокироватьВызовПерезаполненияСуммыОплачено Экспорт;  // флаг блокировки перезаполнения реквизита сумма оплачено

#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения <> Неопределено 
		И (ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Прием")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Реализация")
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.НарядЗаказ")) Тогда
		
		ЭтотОбъект.Контрагент         = ДанныеЗаполнения.Контрагент;
		ЭтотОбъект.СтруктурнаяЕдиница = ДанныеЗаполнения.СтруктурнаяЕдиница;
		ЭтотОбъект.ДокументОснования  = ДанныеЗаполнения.Ссылка;
		ЭтотОбъект.Склад			  =	ДанныеЗаполнения.Склад;
		АвторДокумента	   	 = ПараметрыСеанса.ТекущийПользователь;
		ВидЦен             = ?(Не СтруктурнаяЕдиница.ВидЦенРеализации.Пустая(),СтруктурнаяЕдиница.ВидЦенРеализации
		                                                                      ,Справочники.ВидыЦен.Розничная);
		
		
		ДанныеВозврата = Документы.ВозвратОтПокупателя.ПолучитьДанныеВозврата(
																				ЭтотОбъект.СтруктурнаяЕдиница, 
																				ЭтотОбъект.Контрагент,,
																				КонецДня(ТекущаяДатаСеанса()),
																				ЭтотОбъект.ДокументОснования);
		
		Для Каждого СтрокаТ ИЗ ДанныеВозврата.ТаблицаЗапасы Цикл
			
			НоваяСтрока = ЭтотОбъект.Запасы.Добавить();
			
			СтрокиСкидок = СтрокаТ.ДокументПродажи.СкидкиНаценки.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТ.КлючСтроки));
			
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТ);
			
			НоваяСтрока.ОснованиеВозврата = ЭтотОбъект.ДокументОснования; 
			
			ОбработкаТабличныхЧастейКлиент.ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(НоваяСтрока);
			
			Для Каждого СтрокаМ ИЗ СтрокиСкидок Цикл
				
				НоваяСтрокаС = ЭтотОбъект.СкидкиНаценки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаС, СтрокаМ);
				
			КонецЦикла;		
			
			ВидЦен 				 = ЭтотОбъект.ВидЦен;
			ПараметрыВидаЦены    = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ВидЦен, "ПорядокОкругления, ОкруглятьВБольшуюСторону");		
			
			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("ПорядокОкругления", ПараметрыВидаЦены.ПорядокОкругления); 
			ДопПараметры.Вставить("ОкруглятьВБольшуюСторону", ПараметрыВидаЦены.ОкруглятьВБольшуюСторону);
			ДопПараметры.Вставить("ЕстьКолонкаПроцентСкидкиНаценки", Истина);
			ДопПараметры.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки", Истина);
			
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(НоваяСтрока, ДопПараметры);	
			
		КонецЦикла; 
		
		Для Каждого СтрокаТ ИЗ ДанныеВозврата.ТаблицаУслуги Цикл
			
			НоваяСтрока = ЭтотОбъект.Лечение.Добавить();
			
			СтрокиСкидок = СтрокаТ.ДокументПродажи.СкидкиНаценки.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТ.КлючСтроки));
			
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТ);			
			
			ОбработкаТабличныхЧастейКлиент.ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(НоваяСтрока);
			
			Для Каждого СтрокаМ ИЗ СтрокиСкидок Цикл
				
				НоваяСтрокаС = ЭтотОбъект.СкидкиНаценки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаС, СтрокаМ);
				
			КонецЦикла;		
			
			ВидЦен 				 = ЭтотОбъект.ВидЦен;
			ПараметрыВидаЦены    = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ВидЦен, "ПорядокОкругления, ОкруглятьВБольшуюСторону");		
			
			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("ПорядокОкругления", ПараметрыВидаЦены.ПорядокОкругления); 
			ДопПараметры.Вставить("ОкруглятьВБольшуюСторону", ПараметрыВидаЦены.ОкруглятьВБольшуюСторону);
			ДопПараметры.Вставить("ЕстьКолонкаПроцентСкидкиНаценки", Истина);
			ДопПараметры.Вставить("ЕстьКолонкаСуммаАвтоматическойСкидкиНаценки", Истина);
			
			ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(НоваяСтрока, ДопПараметры);	
			
		КонецЦикла;
		
	    // Для Сертификатов пока старая логика, когда будет исправлена работа сертификатов нужно убрать.
		// И добавить расчет в Документы.ВозвратОтПокупателя.ПолучитьДанныеВозврата  
		Если ДанныеЗаполнения <> Неопределено Тогда 
			
			Для Каждого СтрокаТ Из ДанныеЗаполнения.Запасы.Выгрузить() Цикл
				Если СтрокаТ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
					НоваяСтрока = ЭтотОбъект.Запасы.Добавить(); 
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТ);
					ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(НоваяСтрока);
				КонецЕсли;		 
			КонецЦикла;
			
		КонецЕсли;
		
		СуммаДокумента = Запасы.Итог("Всего") + Лечение.Итог("Всего");
		
	КонецЕсли;
	
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	
КонецПроцедуры

// Процедура - обработчик события "ПриКопировании" объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	СуммаОплачено	= 0;
	НомерЧекаККМ	= 0;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	
КонецПроцедуры

// Процедура - обработчик события "ОбработкаПроверкиЗаполнения".
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Перем МассивВсехРеквизитов;
	МассивОбязательныхРеквизитов = Новый Массив;
	//
	Документы.ВозвратОтПокупателя.ПолучитьМассивыОбязательныхРеквизитов(ЭтотОбъект,
	МассивОбязательныхРеквизитов);
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	ДенежныеСредстваСервер.ЗаполнитьМассивНепроверяемыхРеквизитовПоОбъекту(ЭтотОбъект,
	МассивОбязательныхРеквизитов,
	МассивНепроверяемыхРеквизитов
	);
	//
	ДенежныеСредстваСервер.УдалитьНепроверяемыеРеквизитыИзМассива(
	ПроверяемыеРеквизиты,
	МассивНепроверяемыхРеквизитов
	);
	
	//// Проверка табличной части на разрешения по значениям 
	// Если ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьНулевуюСумму, Ложь) Тогда
	//	УдаляемыйЭлемент = ПроверяемыеРеквизиты.Найти("Запасы.Сумма");
	//	Если УдаляемыйЭлемент <> Неопределено Тогда
	//		ПроверяемыеРеквизиты.Удалить(УдаляемыйЭлемент);
	//	КонецЕсли;
	// КонецЕсли;
	
	
	// 1. Определяем вид налога если он не заполнен, для старых документов.	
	Если Запасы.Количество() > 0 Тогда
		ВидНалога    = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Запасы[0].Номенклатура, СтруктурнаяЕдиница); // Запасы[0].Номенклатура.ВидНалога;
		Номенклатура = Запасы[0].Номенклатура;
	ИначеЕсли Лечение.Количество() > 0 Тогда
		ВидНалога    = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Лечение[0].Номенклатура, СтруктурнаяЕдиница); // Лечение[0].Номенклатура.ВидНалога;
		Номенклатура = Лечение[0].Номенклатура;
	Иначе
		Возврат;
	КонецЕсли;
	
	ЕстьРазличия = Ложь;
	Для Каждого СтрокаТЧ из Запасы Цикл
		Если НЕ Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница) = ВидНалога Тогда
			ЕстьРазличия = Истина;	
			мНоменклатура = СтрокаТЧ.Номенклатура;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЕстьРазличия Тогда
		Для Каждого СтрокаТЧ из Лечение Цикл
			Если НЕ Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(СтрокаТЧ.Номенклатура, СтруктурнаяЕдиница) = ВидНалога Тогда
				ЕстьРазличия = Истина;
				мНоменклатура = СтрокаТЧ.Номенклатура;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ЕстьРазличия Тогда
		Отказ = Истина;
		ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения. Номенклатура '%1' и '%2' используют разные режимы налогообложения";
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Номенклатура, мНоменклатура);	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;	
	
КонецПроцедуры

// Обработчик перед записью данных объекта
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	// Дозааполнить реквизиты ТЧ запасы
	Для Каждого СтрокаТЧ ИЗ Запасы Цикл
		СтрокаТЧ.ОснованиеВозврата = ДокументОснования;
		СтрокаТЧ.Сотрудник         = Сотрудник;
	КонецЦикла;
	
	Если Запасы.Количество() > 0 Тогда
		ВидНалога = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Запасы[0].Номенклатура, СтруктурнаяЕдиница); // Запасы[0].Номенклатура.ВидНалога;
	ИначеЕсли Лечение.Количество() > 0 Тогда
		ВидНалога = Справочники.Номенклатура.ПолучитьВидНалогаНоменклатуры(Лечение[0].Номенклатура, СтруктурнаяЕдиница); // Лечение[0].Номенклатура.ВидНалога;
	КонецЕсли; 
	
КонецПроцедуры

// Процедура - При записи
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Актуализация статуа клиента
	Если НЕ ДополнительныеСвойства.Свойство("НеАктуализироватьСтатус") И НЕ ДополнительныеСвойства.Свойство("ЭтоПроведениеЗагруженныхДанных") Тогда
		РегистрыСведений.СтатусыКонтрагентов.АктуализироватьСтатусПациента(ЭтотОбъект.Контрагент);
	КонецЕсли;

КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);	
	
    // Инициализация данных документа.	
	Документы.ВозвратОтПокупателя.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);	
	
	ДополнительныеСвойства.Вставить("СтруктураПолейПерегрузка", Новый Структура("ОснованиеВозврата, Себестоимость, ДокументПродажи, Сотрудник", "ОснованиеВозврата", "Себестоимость", "ОснованиеВозврата", "Сотрудник"));
	ДополнительныеСвойства.ДляПроведения.Вставить("ВыполнятьДвиженияСебестоимость", Истина);
	ТаблицаСписанияНоменклатуры = Ссылка.Запасы.ВыгрузитьКолонки();
	ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(Ссылка.Запасы, ТаблицаСписанияНоменклатуры);
	ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(Ссылка.Подарки, ТаблицаСписанияНоменклатуры);
	УправлениеЗапасамиПартионныйУчет.СформироватьТаблицуВозвратаПартииТоваров(ТаблицаСписанияНоменклатуры, ДополнительныеСвойства, Движения, Отказ);

	// Движения по регистрам
	ДвиженияДокументовСервер.ЗапасыНаСкладах(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ВзаиморасчетыСКонтрагентами(ДополнительныеСвойства, Движения, Отказ);	
    ДвиженияДокументовСервер.ПартииТоваров(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ПродажиСебестоимость(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.Продажи(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ОборотыПредоставленныеСкидки(ДополнительныеСвойства, Движения, Отказ);
//	ДвиженияДокументовСервер.ДенежныеСредстваНаЛицевыхСчетах(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.Сертификаты(ДополнительныеСвойства, Движения, Отказ);
	ТаблицаУправленческийДобавитьДвиженияПоПартиям(ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУправленческий
	                                              ,ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаПартииТоваров);
	ДвиженияДокументовСервер.Управленческий(ДополнительныеСвойства, Движения, Отказ);

    // Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);
	
	// Запись значения реквизита "сумма оплачено"
	Если БлокироватьВызовПерезаполненияСуммыОплачено <> Истина Тогда
	     ДенежныеСредстваСервер.ЗаполнитьРеквизитыОплатыДокументаОснования(ЭтотОбъект);
    КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура добавляет необходимы движения по партиям 
// в таблицу движений регистра управленческий
Процедура ТаблицаУправленческийДобавитьДвиженияПоПартиям(ТаблицаУправленческий, ТаблицаПартии)	
	
	Для Каждого СтрокаТ ИЗ ТаблицаПартии Цикл
		НоваяСтрока                    = ТаблицаУправленческий.Добавить();
		НоваяСтрока.НомерСтроки        = ТаблицаУправленческий.Количество();
		НоваяСтрока.Период             = ЭтотОбъект.Дата;
		НоваяСтрока.СтруктурнаяЕдиница = ЭтотОбъект.СтруктурнаяЕдиница;
		НоваяСтрока.СчетДт             = ПланыСчетов.Управленческий.РасходыСебестоимость;
		НоваяСтрока.СчетКт             = ПланыСчетов.Управленческий.Запасы;
        НоваяСтрока.СубконтоДт1        = СтрокаТ.Номенклатура.Специализация;
		НоваяСтрока.СубконтоДт2        = ЭтотОбъект.Контрагент;
		НоваяСтрока.СубконтоДт3        = ЭтотОбъект.Сотрудник;
		НоваяСтрока.СубконтоДт4        = Справочники.СтатьиДоходовИРасходов.СебестоимостьТоваров;
		НоваяСтрока.СубконтоКт1        = СтрокаТ.Номенклатура;
		НоваяСтрока.СубконтоКт2        = СтрокаТ.Склад;
        НоваяСтрока.Сумма              = -СтрокаТ.Стоимость;
		НоваяСтрока.Количество         = -СтрокаТ.Количество;
		НоваяСтрока.Содержание         = "Возврат от покупателя(Запасы)";
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
