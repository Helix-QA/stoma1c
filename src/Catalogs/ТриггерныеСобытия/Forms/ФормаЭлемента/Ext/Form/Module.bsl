//
// Параметры:
//  УстановитьСвойстваЭлементамФормы - 	 - 
//  ПерезаполнитьСписокТриггеров	 - 	 - 
//
Процедура ЗаполнитьСписокМоментовАктивации(УстановитьСвойстваЭлементамФормы = Ложь
										, ПерезаполнитьСписокТриггеров = Ложь
										, ПерезаполнитьСписокТиповАктивацииЧленств = Ложь
										, ПерезаполнитьСписокСтруктурныхЕдиниц = Ложь
										, ПерезаполнитьСписокВидовПериодаСобытий = Ложь
										, ПерезаполнитьСписокВидовСделок = Ложь
										, ПерезаполнитьСписокВидовЛицевыхСчетов = Ложь
										, ПерезаполнитьСписокВидовБонусныхСчетов = Ложь
										, ПерезаполнитьСписокВариантовДействий = Ложь
										, ПерезаполнитьСписокСтатусовЗаписей = Ложь
										, ПерезаполнитьТиповСтраховыхПолисов = Ложь)
	
	Справочники.ТриггерныеСобытия.ИнициализироватьСписокМоментовАктивации(Элементы.МоментСобытия.СписокВыбора, Объект.УсловиеСобытия, Объект.МоментСобытия);
		
	Если ЗначениеЗаполнено(Объект.МоментСобытия) Тогда 
		ЭлементСписка = Элементы.МоментСобытия.СписокВыбора.НайтиПоЗначению(Объект.МоментСобытия); 
		Если ЭлементСписка = Неопределено Тогда 
			Объект.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПустаяСсылка();		
		КонецЕсли;	
	КонецЕсли;
	
	Если ПерезаполнитьСписокТриггеров = Истина Тогда 
		ЗаполнитьСписокТриггеров();
	КонецЕсли;
	
	Если ПерезаполнитьСписокСтруктурныхЕдиниц = Истина Тогда 
		ЗаполнитьСписокСтруктурныхЕдиниц();
	КонецЕсли;
	
	Если ПерезаполнитьСписокВидовПериодаСобытий = Истина Тогда 
		ЗаполнитьСписокВидовПериодаСобытий();
	КонецЕсли;
	
	Если ПерезаполнитьСписокВидовСделок = Истина Тогда 
		ЗаполнитьСписокВидовСделок();
	КонецЕсли;
	
	Если ПерезаполнитьСписокВидовЛицевыхСчетов = Истина Тогда 
		ЗаполнитьСписокВидовЛицевыхСчетов();
	КонецЕсли;
	
	Если ПерезаполнитьСписокВидовБонусныхСчетов = Истина Тогда 
		ЗаполнитьСписокВидовБонусныхСчетов();
	КонецЕсли;
	
	Если ПерезаполнитьСписокСтатусовЗаписей = Истина Тогда 
		ЗаполнитьСписокСтатусовПредварительнойЗаписи();
	КонецЕсли;

	Если ПерезаполнитьТиповСтраховыхПолисов = Истина Тогда 	
		ЗаполнитьСписокТиповСтраховыхПолисов();                
	КонецЕсли;
	
	Если УстановитьСвойстваЭлементамФормы = Истина Тогда 
		УстановитьСвойстваЭлементамФормы();
	КонецЕсли;
	
КонецПроцедуры

