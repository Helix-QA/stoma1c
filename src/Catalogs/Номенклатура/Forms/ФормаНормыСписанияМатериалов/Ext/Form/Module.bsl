КонецПроцедуры

&НаСервере
// Процедура, заполняет настройки подбора номенклатуры
//
Процедура ЗаполнитьНастройкиПодбораНоменклатуры()
	
	ОтображатьАртикулВрем   = РегистрыСведений.НастройкиПользователей.НастройкаПользователя(ТекущийСотрудник, 
																							ПланыВидовХарактеристик.НастройкиПользователей.ОтображатьАртикул,
																							ТекущаяСтруктурнаяЕдиница);  
	ОтображатьАртикул       = ОтображатьАртикулВрем = Неопределено ИЛИ ОтображатьАртикулВрем;
	
	ОтображатьОстатокВрем   = РегистрыСведений.НастройкиПользователей.НастройкаПользователя(ТекущийСотрудник, 
																							ПланыВидовХарактеристик.НастройкиПользователей.ОтображатьОстаток,
																							ТекущаяСтруктурнаяЕдиница);
	ОтображатьОстаток       = ОтображатьОстатокВрем = Неопределено ИЛИ ОтображатьОстатокВрем;
	
	ОтображатьЦенуВрем      = РегистрыСведений.НастройкиПользователей.НастройкаПользователя(ТекущийСотрудник, 
																							ПланыВидовХарактеристик.НастройкиПользователей.ОтображатьЦену,
																							ТекущаяСтруктурнаяЕдиница); 
	ОтображатьЦену          = ОтображатьЦенуВрем = Неопределено ИЛИ ОтображатьЦенуВрем;  
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзминении" на сервере.
//
Процедура НастройкаПриИзмененииНаСервере(Элемент)
		
	ТаблицаПодбора = "_ПодборНоменклатур";
	
	Если Элемент.Имя = "ОтображатьАртикул" Тогда
		
		НаименованиеРеквизита = "ОтображатьАртикул";
		НазваниеПоляСортировки = "Артикул";
		
	ИначеЕсли Элемент.Имя = "ОтображатьЦену" Тогда
		
		НаименованиеРеквизита = "ОтображатьЦену";
		НазваниеПоляСортировки = "Цена";
		
	ИначеЕсли Элемент.Имя = "ОтображатьОстаток" Тогда
		
		НаименованиеРеквизита = "ОтображатьОстаток";
		НазваниеПоляСортировки = "Количество";
		
	КонецЕсли;
	
	ПараметрыНастройки = ПолучитьПараметрыНастройки(НаименованиеРеквизита, ТаблицаПодбора);
	
	Если ПараметрыНастройки.КолонкаТаблицы <> Неопределено Тогда
		ПараметрыНастройки.КолонкаТаблицы.Видимость = ЭтотОбъект[НаименованиеРеквизита];
	КонецЕсли;
			
	ОбновитьТаблицуНазвание = Новый СписокЗначений;
	
	Если НЕ ЭтотОбъект[НаименованиеРеквизита] Тогда
							
		НастройкаСортировкиПодбораЗавершение(Новый Структура("Значение, Представление", "Наименование", "Наименование"));	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Настройка полей сортировки подбора
//
Процедура НастройкаСортировкиПодбораЗавершение(Результат) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ТекущаяТаблица = ЭтотОбъект["_ПодборНоменклатур"];	
	ТекущийПорядокСортировки = ПолучитьТекущийПорядокСортировкиПодбора(ТекущаяТаблица);
	ИзменитьСортировкуПодбора(ТекущаяТаблица, Результат.Значение, ТекущийПорядокСортировки);
		
КонецПроцедуры 

&НаКлиенте
// Функция - Получить текущий порядок сортировки подбора
//
Функция ПолучитьТекущийПорядокСортировкиПодбора(ТекущаяТаблица, НовыйПорядок = Ложь)
	
	Возврат(?(ТекущаяТаблица.КомпоновщикНастроек.Настройки.Порядок.Элементы[0].ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных.Возр,
			?(НовыйПорядок, "Убыв", "Возр"), ?(НовыйПорядок, "Возр", "Убыв") )); 
	
КонецФункции


&НаКлиентеНаСервереБезКонтекста
// Процедура - Изменить сортировку подбора
//
Процедура ИзменитьСортировкуПодбора(ТекущаяТаблица, ПолеСортировки, ПорядокСортировки)
	
	ТекущаяТаблица.Порядок.Элементы.Очистить();		
	Сортировка = ТекущаяТаблица.КомпоновщикНастроек.Настройки.Порядок.Элементы;
	
	УсловиеСортировки = Сортировка.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
	УсловиеСортировки.Поле = Новый ПолеКомпоновкиДанных(ПолеСортировки);
	УсловиеСортировки.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных[ПорядокСортировки];
	
	ТекущаяТаблица.КомпоновщикНастроек.ЗагрузитьНастройки(ТекущаяТаблица.КомпоновщикНастроек.Настройки);
		
КонецПроцедуры

&НаКлиенте
// Функция, возвращает параметры настройки.
//
Функция ПолучитьПараметрыНастройки(Настройка, ТаблицаПодбора)
			
	Если Настройка = "ОтображатьАртикул" Тогда
		Возврат Новый Структура("КолонкаТаблицы, Настройка",
			Элементы.Найти(ТаблицаПодбора+"Артикул"),
			ПредопределенноеЗначение("ПланВидовХарактеристик.НастройкиПользователей.ОтображатьАртикул"));  
		
	ИначеЕсли Настройка = "ОтображатьЦену" Тогда
		Возврат Новый Структура("КолонкаТаблицы, Настройка",
			Элементы.Найти(ТаблицаПодбора+"Цена"),
			ПредопределенноеЗначение("ПланВидовХарактеристик.НастройкиПользователей.ОтображатьЦену"));
			
	ИначеЕсли Настройка = "ОтображатьОстаток" Тогда
		Возврат Новый Структура("КолонкаТаблицы, Настройка",
			Элементы.Найти(ТаблицаПодбора+"Количество"),			
			ПредопределенноеЗначение("ПланВидовХарактеристик.НастройкиПользователей.ОтображатьОстаток"));
			
	КонецЕсли;
	
КонецФункции

