&НаСервере
// Функция - Преобразовать массив структур в таблицу значений
//
// Параметры:
//  МассивДанных - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПреобразоватьМассивСтруктурВТаблицуЗначений(МассивДанных)

	// Создадим структуру колонок с типами так как сменить тип колонки в ТЗ не получиться
	СтруктураКолонок = Новый Структура;
	
	Для Каждого ЭлементМассива Из МассивДанных Цикл
		// Ввиду того что массив может попасться разноколоночны нужно проверять не только первую строку.
		// А также, если типы отличаются в разных элементах массива, нужно иметь возможность получить читабельную ТЗ.
		Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
			ТипЗначенияКолонки = ТипЗнч(ЗначениеСтруктуры.Значение);
			Если НЕ СтруктураКолонок.Свойство(ЗначениеСтруктуры.Ключ) Тогда
				МассивДопустимыеТипы = Новый Массив;
				МассивДопустимыеТипы.Добавить(ТипЗначенияКолонки);
				СтруктураКолонок.Вставить(ЗначениеСтруктуры.Ключ, МассивДопустимыеТипы);
			Иначе
				СодержитТип = СтруктураКолонок[ЗначениеСтруктуры.Ключ].Найти(ТипЗначенияКолонки);
				Если СодержитТип = Неопределено Тогда
					СтруктураКолонок[ЗначениеСтруктуры.Ключ].Добавить(ТипЗначенияКолонки)
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Создадим ТЗ
	ТаблицаЗначенийДанные = Новый ТаблицаЗначений;
	
	// Добавим Колонки в ТЗ
	Для Каждого Колонка Из СтруктураКолонок Цикл
		ТаблицаЗначенийДанные.Колонки.Добавить(Колонка.Ключ, Новый ОписаниеТипов(Колонка.Значение));		
	КонецЦикла;
	
	// Теперь можно обработать нормально массив
	Для Каждого ЭлементМассива Из МассивДанных Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаЗначенийДанные.Добавить(), ЭлементМассива);
	КонецЦикла;
	
	Возврат ТаблицаЗначенийДанные;

КонецФункции

&НаСервере
// Процедура - Установить свойства элементам аккаунта сообщения
//
// Параметры:
//  ЭлементФормы					 - 	 - 
//  ИндексСтроки					 - 	 - 
//  ПараметрыОтображенияЭлементов	 - 	 - 
//
Процедура УстановитьСвойстваЭлементамАккаунтаСообщения(Знач ЭлементФормы = Неопределено, ИндексСтроки, Знач ПараметрыОтображенияЭлементов = Неопределено) Экспорт
	
	ПоискЭлемента = ?(ЭлементФормы = Неопределено, Истина, Ложь);
	ПараметрыОтображенияЭлементов = МоделируемыеНастройкиКаналовУведомлений[ИндексСтроки].ПараметрыОтрисовки;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ГруппаОтправкаMessenger_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;	
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ГруппаОтправкаMessenger_Индекс_" + Строка(ИндексСтроки) Тогда 		
			ЭлементФормы.Видимость = ТипКанала = "Messenger";
			Если НЕ ПоискЭлемента Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ГруппаОтправкаSMS_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;	
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ГруппаОтправкаSMS_Индекс_" + Строка(ИндексСтроки) Тогда 		
			ЭлементФормы.Видимость = ТипКанала = "SMS";
			Если НЕ ПоискЭлемента Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ОтправкаPush_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;			
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ОтправкаPush_Индекс_" + Строка(ИндексСтроки) Тогда
			ЭлементФормы.Видимость = ТипКанала = "Push";
			ЭлементФормы.Доступность = ПараметрыОтображенияЭлементов.ПараметрыРассылки.ОтправкаPush И (ПараметрыДействия.ВидАдресата = Перечисления.ВидыАдресатов.КонтрагентСобытия ИЛИ НЕ ЗначениеЗаполнено(ПараметрыДействия.ВидАдресата));
