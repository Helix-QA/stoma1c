&НаКлиенте
// Процедура - обработчик команды "СоздатьЧеки".
//
Процедура СоздатьЧеки(Команда)
	
	Если ВнесеныИзменения() Тогда
		ПоказатьВопрос(новый ОписаниеОповещения("СоздатьЧекиЗавершение", ЭтотОбъект),
		НСтр("ru='Создать чеки? Будут созданы и пробиты по ККТ чек ""сторно"" и измененный чек.'"),
		РежимДиалогаВопрос.ДаНетОтмена,,
		КодВозвратаДиалога.Да,,);
	Иначе
		ПоказатьПредупреждение(, НСтр("ru = 'Внесите изменения. Допускается корректировка: видов оплаты, ставки НДС, признака способа и предмета расчета.'"));
	КонецЕсли;
	
	Возврат;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик оповещения "СоздатьЧекиЗавершение".
//
Процедура СоздатьЧекиЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		// Выполнить контроль кассовой смены
		ОписаниеОшибки					= Неопределено;
		ВыполнятьОперациюНаФискальнике  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Касса, "ИспользоватьБезПодключенияОборудования") = Ложь; 
		ПараметрыИспользованияКассовойСмены = Новый Структура("ВыполнятьОперациюНаФискальнике", ВыполнятьОперациюНаФискальнике);
		РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, Объект.Касса, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки);

	КонецЕсли;
		
КонецПроцедуры

