// Процедура - заполняет признаки ЭтоЗапас, ЭтоУслуга и т.д.
//
Процедура ОбновлениеНоменклатуры() Экспорт
	
	Выборка = Справочники.Номенклатура.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОбъектНоменклатура = Выборка.ПолучитьОбъект();
		
		Если Не ОбъектНоменклатура.ЭтоГруппа И НЕ (ОбъектНоменклатура.ЭтоЗапас ИЛИ ОбъектНоменклатура.ЭтоИмущество
			ИЛИ ОбъектНоменклатура.ЭтоПакетУслуг ИЛИ ОбъектНоменклатура.ЭтоПодарочныйСертификат ИЛИ ОбъектНоменклатура.ЭтоУслуга) Тогда
			
			Если ОбъектНоменклатура.ТипНоменклатуры		= Перечисления.ТипыНоменклатуры.Запас
				Или ОбъектНоменклатура.ТипНоменклатуры	= Перечисления.ТипыНоменклатуры.Материал Тогда 
				ОбъектНоменклатура.ЭтоЗапас             = Истина;
			КонецЕсли;
			
			ОбъектНоменклатура.ЭтоИмущество        	   = ОбъектНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Имущество;
			ОбъектНоменклатура.ЭтоПакетУслуг           = ОбъектНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор;
			ОбъектНоменклатура.ЭтоПодарочныйСертификат = ОбъектНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат;
			ОбъектНоменклатура.ЭтоУслуга               = ОбъектНоменклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
			
			Попытка
				ОбъектНоменклатура.Записать();
			Исключение
				
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - удаляет драйвер Простые звонки.
//
Процедура УдалитьПредопределенныйДрайверПростыеЗвонки() Экспорт
	
НайденыйДрайвер = Справочники.ДрайверыОборудования.НайтиПоНаименованию("IP-Телефония: Простые звонки");

Если ЗначениеЗаполнено(НайденыйДрайвер) Тогда

	Попытка
		ДрайверОбъект = НайденыйДрайвер.ПолучитьОбъект();
		ДрайверОбъект.ИмяПредопределенныхДанных = "";
		ДрайверОбъект.Записать();	
		ДрайверОбъект.Удалить();
	Исключение
	
	КонецПопытки;
	
КонецЕсли;
	
КонецПроцедуры
     
// Процедура - Заполнить Классификатор услуг
//
Процедура ЗаполнитьКлассификаторУслуг() Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	// Заполняем справочник классификатор услуг
	Справочники.КлассификаторНоменклатурыМедицинскихУслуг.ЗаполнитьКлассификаторУслуг();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.КодНоменклатурыМедицинскиУслуг = """" ");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		СсылкаТек = Выборка.Ссылка;
		Если ЗначениеЗаполнено(СсылкаТек.КодНоменклатурыМедицинскиУслуг) Тогда
			
			КодУслуги = СсылкаТек.КодНоменклатурыМедицинскиУслуг;
			ОбъектТек = СсылкаТек.ПолучитьОбъект();
			
			ОбъектТек.НоменклатураМедицинскихУслуг = Справочники.КлассификаторНоменклатурыМедицинскихУслуг.НайтиПоКоду(КодУслуги);
			Если Не ЗначениеЗаполнено(ОбъектТек.НоменклатураМедицинскихУслуг) Тогда
				// Заменяем кирилицу на латиницу
				Если Лев(КодУслуги, 1) = "А" Тогда
					КодУслуги =	СтрЗаменить(КодУслуги, "А", "A"); 
				ИначеЕсли Лев(КодУслуги, 1) = "В" Тогда
					КодУслуги =	СтрЗаменить(КодУслуги, "В", "B"); 		
				КонецЕсли;
				ОбъектТек.НоменклатураМедицинскихУслуг = Справочники.КлассификаторНоменклатурыМедицинскихУслуг.НайтиПоКоду(КодУслуги);
			КонецЕсли;

			ОбъектТек.УЕТ = ОбъектТек.НоменклатураМедицинскихУслуг.УЕТ;
			
			Попытка
				ОбъектТек.Записать();
			Исключение
				
			КонецПопытки;
			
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// Процедура обновляет предопределенные виды контактной информации
//
Процедура ОбновитьПредопределенныеВидыКИ(Параметры = Неопределено) Экспорт 

	УстановитьПривилегированныйРежим(Истина);
		
	КонтактнаяИнформацияСервер.УстановитьСвойстваПредопределенныхВидовКонтактнойИнформации();

	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;

КонецПроцедуры

// Процедура, выполняет первоначальное заполнение регистра сведений "Диалоги".
//
Процедура ЗаполнитьДанныеДиалогов() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(ЖурналСообщений.Период) КАК Период,
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента
	|ПОМЕСТИТЬ ДатыПоследнихСообщений
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ПО КонтактыМессенджеров.ВнешняяСистема = ЖурналСообщений.ВнешняяСистема
	|			И КонтактыМессенджеров.Идентификатор = ЖурналСообщений.ИдКлиента
	|ГДЕ
	|	ЖурналСообщений.ОператорСообщения <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И НЕ ЖурналСообщений.ОжиданиеСообщения
	|	И НЕ ЖурналСообщений.СлужебноеСообщение
	|	И НЕ ЖурналСообщений.Триггер
	|
	|СГРУППИРОВАТЬ ПО
	|	ЖурналСообщений.ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЖурналСообщений.Период КАК Период,
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	МАКСИМУМ(ЖурналСообщений.ИдСообщения) КАК ИдСообщения
	|ПОМЕСТИТЬ ИдентификаторыСообщений
	|ИЗ
	|	ДатыПоследнихСообщений КАК ДатыПоследнихСообщений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ПО ДатыПоследнихСообщений.Период = ЖурналСообщений.Период
	|			И ДатыПоследнихСообщений.ВнешняяСистема = ЖурналСообщений.ВнешняяСистема
	|			И ДатыПоследнихСообщений.ИдКлиента = ЖурналСообщений.ИдКлиента
	|
	|СГРУППИРОВАТЬ ПО
	|	ЖурналСообщений.Период,
	|	ЖурналСообщений.ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	ЖурналСообщений.ОператорСообщения КАК ОператорСообщения
	|ПОМЕСТИТЬ ОператорыКонтактов
	|ИЗ
	|	ИдентификаторыСообщений КАК ИдентификаторыСообщений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ПО ИдентификаторыСообщений.ВнешняяСистема = ЖурналСообщений.ВнешняяСистема
	|			И ИдентификаторыСообщений.ИдКлиента = ЖурналСообщений.ИдКлиента
	|			И ИдентификаторыСообщений.ИдСообщения = ЖурналСообщений.ИдСообщения
	|			И ИдентификаторыСообщений.Период = ЖурналСообщений.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтактыМессенджеров.ВнешняяСистема КАК ВнешняяСистема,
	|	КонтактыМессенджеров.Идентификатор КАК ИдКлиента,
	|	ЕСТЬNULL(ОператорыКонтактов.ОператорСообщения, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК Оператор
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОператорыКонтактов КАК ОператорыКонтактов
	|		ПО КонтактыМессенджеров.ВнешняяСистема = ОператорыКонтактов.ВнешняяСистема
	|			И КонтактыМессенджеров.Идентификатор = ОператорыКонтактов.ИдКлиента");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ИдДиалога		 = Новый УникальныйИдентификатор;
		МенеджерЗаписи.ИдКлиента		 = Выборка.ИдКлиента;
		МенеджерЗаписи.ВнешняяСистема	 = Выборка.ВнешняяСистема;
		МенеджерЗаписи.Оператор			 = Выборка.Оператор;
		МенеджерЗаписи.Начало			 = Дата(2021, 1, 1);
		МенеджерЗаписи.Окончание		 = Дата(2021, 1, 1);
		
		МенеджерЗаписи.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, восстанавливает версии файлов.
// 
Процедура ОбработатьВерсииФайлов(Параметры = Неопределено) Экспорт
	
    Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВерсииФайлов.Ссылка КАК Ссылка,
	|	ВерсииФайлов.ФайлХранилище КАК ФайлХранилищеВерсий
	|ИЗ
	|	Справочник.ВерсииФайлов КАК ВерсииФайлов
	|ГДЕ
	|	ВерсииФайлов.ТипХраненияФайла = ЗНАЧЕНИЕ(Перечисление.ТипыХраненияФайлов.ВИнформационнойБазе)";
	
	
	Выборка = Запрос.Выполнить().Выбрать();	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			
			ДвоичныеДанные = Выборка.ФайлХранилищеВерсий.Получить();
			Если Не ЗначениеЗаполнено(ДвоичныеДанные) Тогда
				Продолжить;                                    
			КонецЕсли;
			НачатьТранзакцию();
			
			НаборЗаписей = РегистрыСведений.ДвоичныеДанныеФайлов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Файл.Установить(Выборка.Ссылка);
			
			ЗаписьНабора = НаборЗаписей.Добавить();
			ЗаписьНабора.Файл = Выборка.Ссылка;
			ЗаписьНабора.ДвоичныеДанныеФайла = Новый ХранилищеЗначения(ДвоичныеДанные, Новый СжатиеДанных(9));
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
			
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			ОбъектовОбработано = ОбъектовОбработано + 1;
			ЗафиксироватьТранзакцию();
		Исключение
			Если ТранзакцияАктивна()Тогда
				ОтменитьТранзакцию();        
			КонецЕсли;
			// Если не удалось обработать какой-либо документ, повторяем попытку снова.
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось обработать версию файла: %1 по причине:
			|%2'"), 
			Выборка.Ссылка, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), УровеньЖурналаРегистрации.Предупреждение,
			Выборка.Ссылка.Метаданные(), Выборка.Ссылка, ТекстСообщения);
		КонецПопытки;    
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, обновляет документы рассылки сообщений.
//
Процедура ПереходНаНовуюСистемуРассылкиСообщений(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Попытка
		
		// Обновление регламентного задания.
		НайденныеРегламентныеЗадания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Новый Структура("Метаданные", Метаданные.РегламентныеЗадания.ОбработкаSMSСообщений));
		
		Если НайденныеРегламентныеЗадания.Количество() > 0 Тогда
			
			РегламентноеЗадание = НайденныеРегламентныеЗадания[0];
			РегламентноеЗадание.Наименование = "Отправка сообщений и проверка статусов";
			РегламентноеЗадание.Расписание.ПериодПовтораВТечениеДня = 60;
			РегламентноеЗадание.Записать();
			
		КонецЕсли;
		
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка при переходе на новую систему рассылки сообщений. Обновление регламентного задания.", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());	
	КонецПопытки;

	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, сжимаект картинки
//
Процедура СжатьКартинкиВИнформационнойБазе(Параметры = Неопределено) Экспорт
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, исправляет виды КИ пациентов.
//
Процедура ИсправлениеВидовКИПациентов(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидРодителяКонтрагенты", "%" + "Контрагенты" + "%");
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Контрагенты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ТаблицаГруппКлиентов
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ИСТИНА
	|	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыКонтактнойИнформации.Ссылка КАК ВидКИ
	|ПОМЕСТИТЬ ТаблицаВидовКИ
	|ИЗ
	|	Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
	|ГДЕ
	|	ВидыКонтактнойИнформации.Предопределенный = ЛОЖЬ
	|	И ВидыКонтактнойИнформации.Родитель.Наименование ПОДОБНО &ВидРодителяКонтрагенты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Пациент
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаВидовКИ КАК ТаблицаВидовКИ
	|		ПО КонтрагентыКонтактнаяИнформация.Вид = ТаблицаВидовКИ.ВидКИ
	|ГДЕ
	|	(КонтрагентыКонтактнаяИнформация.Ссылка.Родитель В
	|				(ВЫБРАТЬ
	|					ТаблицаГруппКлиентов.Ссылка
	|				ИЗ
	|					ТаблицаГруппКлиентов)
	|			ИЛИ КонтрагентыКонтактнаяИнформация.Ссылка.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаВидовКИ.ВидКИ КАК ВидКИ
	|ИЗ
	|	ТаблицаВидовКИ КАК ТаблицаВидовКИ";
	
	ПакетЗапросов 		= Запрос.ВыполнитьПакет();
	МассивПациентов 	= ПакетЗапросов[2].Выгрузить().ВыгрузитьКолонку("Пациент");
	МассивБитыхВидовКИ 	= ПакетЗапросов[3].Выгрузить().ВыгрузитьКолонку("ВидКИ");
	
	ВидКИ__ТелефонКлиента 				= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента");
	ВидКИ__МобильноеПриложениеКлиента 	= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.МобильноеПриложениеКлиента");
	ВидКИ__ТелефонКлиентаДополнительный = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонКлиентаДополнительный");
	ВидКИ__EmailКлиента 				= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.EmailКлиента");
	ВидКИ__SkypeКлиента 				= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.SkypeКлиента");
	ВидКИ__АдресКлиента 				= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.АдресКлиента");
	ВидКИ__СоциальнаяСетьКлиента 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.СоциальнаяСетьКлиента");

	МетаданныеСправочника 		= Метаданные.Справочники.Контрагенты;
	ПредставлениеСправочника 	= МетаданныеСправочника.Представление();

	Для Каждого Пациент Из МассивПациентов Цикл 
		ПациентОбъект = Пациент.ПолучитьОбъект();
		Если ПациентОбъект = Неопределено Тогда 
			Продолжить;
		КонецЕсли;	
		Для Каждого СтрокаКИ Из ПациентОбъект.КонтактнаяИнформация Цикл 
			Если ЗначениеЗаполнено(СтрокаКИ.Тип) И НЕ МассивБитыхВидовКИ.Найти(СтрокаКИ.Вид) = Неопределено Тогда
				Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон И ЗначениеЗаполнено(ВидКИ__ТелефонКлиента) Тогда 
					СтрокаКИ.Вид = ВидКИ__ТелефонКлиента;
				ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.МобильноеПриложение И ЗначениеЗаполнено(ВидКИ__МобильноеПриложениеКлиента) Тогда	
					СтрокаКИ.Вид = ВидКИ__МобильноеПриложениеКлиента;
				ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Факс И ЗначениеЗаполнено(ВидКИ__ТелефонКлиентаДополнительный) Тогда	
					СтрокаКИ.Вид = ВидКИ__ТелефонКлиентаДополнительный;
				ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты И ЗначениеЗаполнено(ВидКИ__EmailКлиента) Тогда	
					СтрокаКИ.Вид = ВидКИ__EmailКлиента;
				ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Skype И ЗначениеЗаполнено(ВидКИ__SkypeКлиента) Тогда	
					СтрокаКИ.Вид = ВидКИ__SkypeКлиента;
				ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес И ЗначениеЗаполнено(ВидКИ__АдресКлиента) Тогда	
					СтрокаКИ.Вид = ВидКИ__АдресКлиента;
				ИначеЕсли СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.ВебСтраница ИЛИ СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.СоциальнаяСеть И ЗначениеЗаполнено(ВидКИ__СоциальнаяСетьКлиента) Тогда	
					СтрокаКИ.Вид = ВидКИ__СоциальнаяСетьКлиента;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ПациентОбъект);
		Исключение
			ШаблонКомментария = НСтр("ru = 'Не удалось исправить вид контактной информации у пациента: ""%1"", Описание ошибки: ""%2""' ");
			
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонКомментария,
			Пациент,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Предупреждение,
			МетаданныеСправочника,,
			Комментарий);
			
			ВызватьИсключение;
		КонецПопытки;	
	КонецЦикла;	

	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, переносит роль Использование мессенджера из расширения
//
Процедура ПереносРолиИспользованиеМессенджераИзРасширения() Экспорт

	Если Не ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") Тогда
		Возврат;	
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	МетаданныеСправочника 		= Метаданные.Справочники.Пользователи;
	ПредставлениеСправочника 	= МетаданныеСправочника.Представление();

	Для Каждого ПользовательИБ Из ПользователиИнформационнойБазы.ПолучитьПользователей() Цикл
		Если Метаданные.Роли.Найти("Мессенджер_ИспользоватьМессенджер") <> Неопределено
			И ПользовательИБ.Роли.Содержит(Метаданные.Роли.Мессенджер_ИспользоватьМессенджер) Тогда
			
			Попытка  
				
				НовыеРоли = Неопределено;
				НовыеСвойства = Неопределено;
				ПользователиСтоматология.ПрочитатьПользователяИБ(ПользовательИБ.УникальныйИдентификатор, НовыеСвойства, НовыеРоли);
				НовыеРоли.Добавить("ИспользованиеМессенджера");
				Индекс = НовыеРоли.Найти("Мессенджер_ИспользоватьМессенджер");
 				НовыеРоли.Удалить(Индекс); 
	  			ОписаниеОшибки = "";
				ПользователиСтоматология.ЗаписатьПользователяИБ(ПользовательИБ.УникальныйИдентификатор, НовыеСвойства, НовыеРоли, , ОписаниеОшибки);
				
			Исключение
				ШаблонКомментария = НСтр("ru = 'Не удалось добавить роль: Использование мессенджера, пользователю: ""%1"". Добавьте эту роль через карточку сотрудника.'");
				
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонКомментария,
				ПользовательИБ);
				
				ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Предупреждение,
				МетаданныеСправочника,,
				Комментарий);
				
				ВызватьИсключение;
			КонецПопытки;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура, устанавливает значение константы ОбязательныеПоляСобытие
//
Процедура ЗаполнитьКонстантуОбязательныеПоляСобытие() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	СтруктураОбязательныеПоля = Новый Структура;
		
	СтруктураОбязательныеПоля.Вставить("Контрагент", Истина);	
	СтруктураОбязательныеПоля.Вставить("Комментарий", Ложь);	
 	СтруктураОбязательныеПоля.Вставить("УслугиПричинаЗаписиПолем", Ложь);	
	СтруктураОбязательныеПоля.Вставить("УслугиСотрудникПолем", Ложь);	
	СтруктураОбязательныеПоля.Вставить("УслугиПомещениеПолем", Ложь);	
	
	Хранилище = Новый ХранилищеЗначения(СтруктураОбязательныеПоля);
	
	Константы.ОбязательныеПоляСобытие.Установить(Хранилище);
	
КонецПроцедуры

// Процедура, устанавливает значение константы ОбязательныеПоляСобытие
//
Процедура ДобавитьПользователямВрачИГлавныйВрачРольДобавлениеИзменениеКлиентов() Экспорт

	#Если Не ВнешнееСоединение Тогда
		
		Если НЕ ПривилегированныйРежим() Тогда 
			УстановитьПривилегированныйРежим(Истина);
		КонецЕсли;
		
		МетаданныеСправочника 		= Метаданные.Справочники.Пользователи;
		ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Пользователи.Ссылка КАК Ссылка,
		|	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.ПометкаУдаления = ЛОЖЬ
		|	И Пользователи.РольПользователя В (ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач))");
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Если ЗначениеЗаполнено(Выборка.ИдентификаторПользователяИБ) Тогда
				
				ПользовательИБ = ПользователиСтоматология.ПолучитьПользователяПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ);
				
				Попытка
					
					Если ПользовательИБ.Роли.Содержит(Метаданные.Роли.ДобавлениеИзменениеКлиентов) = Ложь 
						Или ПользовательИБ.Роли.Содержит(Метаданные.Роли.ЧтениеКлиентов) = Ложь
						Или ПользовательИБ.Роли.Содержит(Метаданные.Роли.ЧтениеКонтрагентов) = Ложь Тогда
						
						Если ПользовательИБ.Роли.Содержит(Метаданные.Роли.ДобавлениеИзменениеКлиентов) = Ложь Тогда
							ПользовательИБ.Роли.Добавить(Метаданные.Роли.ДобавлениеИзменениеКлиентов);                 
						КонецЕсли;
						
						Если ПользовательИБ.Роли.Содержит(Метаданные.Роли.ЧтениеКлиентов) = Ложь Тогда
							ПользовательИБ.Роли.Добавить(Метаданные.Роли.ЧтениеКлиентов);                 
						КонецЕсли;
						
						Если ПользовательИБ.Роли.Содержит(Метаданные.Роли.ЧтениеКонтрагентов) = Ложь Тогда
							ПользовательИБ.Роли.Добавить(Метаданные.Роли.ЧтениеКонтрагентов);                 
						КонецЕсли;
						
						ПользовательИБ.Записать();
						
					КонецЕсли;
					
				Исключение
					
					ШаблонКомментария = НСтр("ru = 'Не удалось добавить роль: ДобавлениеИзменениеКлиентов, пользователю: ""%1"". Добавьте эту роль через карточку сотрудника.'");
					
					Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					ШаблонКомментария,
					ПользовательИБ);
					
					ЗаписьЖурналаРегистрации(
					ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
					УровеньЖурналаРегистрации.Предупреждение,
					МетаданныеСправочника,,
					Комментарий);
					
					ВызватьИсключение;
					
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЦикла;
	#КонецЕсли
	
КонецПроцедуры

// Процедура - Инициализация предопределенных сценариев чат бота
//
Процедура ИнициализацияПредопределенныхСценариевЧатБота(ОбновитьМессенджер = Истина, ТаблицаСервисовSMS = Неопределено) Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Если ОбновитьМессенджер Тогда 
		Если НЕ ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") Тогда 
			Возврат;
		КонецЕсли;
		
		РасширениеМессенджера = ПолучитьРасширениеМесседжера();
		
		Если РасширениеМессенджера = Неопределено Тогда
			// Расширение мессенджера не установлено, обновление не требуется.
			Возврат;
		КонецЕсли;
		
		МетаданныеМакета = Метаданные.ОбщиеМакеты.Найти("РасширениеМессенджера");
		
		Если МетаданныеМакета = Неопределено Тогда
			// Макет удален из конфигурации.
			Возврат;
		КонецЕсли;
		
		ДанныеРасширения = ПолучитьОбщийМакет(МетаданныеМакета);
		МетаданныеПоставляемогоРасширения = Новый ОбъектМетаданныхКонфигурация(ДанныеРасширения);
		
		Если ТребуетсяОбновлениеПоставляемогоРасширения(РасширениеМессенджера, МетаданныеПоставляемогоРасширения) = Истина Тогда
			// Обновление месседжера выше не произведено. Отменяем обновление данных.
			Возврат;
		КонецЕсли;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СценарииЧатБотов.Ссылка КАК СценарийЧатБота,
	|	СценарииЧатБотов.Используется КАК ИспользуетсяСценарий,
	|	СценарииЧатБотов.ИмяМакетаПредопределенногоСценария КАК ИмяМакетаПредопределенногоСценария,
	|	ЕСТЬNULL(ТриггерныеСобытияДействия.Ссылка, ЗНАЧЕНИЕ(Справочник.ТриггерныеСобытия.ПустаяСсылка)) КАК Триггер,
	|	ЕСТЬNULL(ТриггерныеСобытияДействия.Ссылка.Активно, ЛОЖЬ) КАК ТриггерАктивно,
	|	ЕСТЬNULL(ТриггерныеСобытияДействия.Использование, ЛОЖЬ) КАК ИспользованиеДействияТриггера
	|ИЗ
	|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытияДействия
	|		ПО (ТриггерныеСобытияДействия.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота))
	|			И СценарииЧатБотов.Ссылка = ТриггерныеСобытияДействия.СценарийЧатБота
	|			И (ТриггерныеСобытияДействия.Ссылка.ПометкаУдаления = ЛОЖЬ)
	|			И (ТриггерныеСобытияДействия.Ссылка.ЭтоГруппа = ЛОЖЬ)
	|			И (ТриггерныеСобытияДействия.Удалено = ЛОЖЬ)
	|ГДЕ
	|	СценарииЧатБотов.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СценарииЧатБотовСвойстваЭтаповСценария.Ссылка КАК СценарийЧатБота,
	|	СценарииЧатБотовСвойстваЭтаповСценария.Ссылка.ИмяМакетаПредопределенногоСценария КАК ИмяМакетаПредопределенногоСценария,
	|	СценарииЧатБотовСвойстваЭтаповСценария.НаименованиеЭтапа КАК НаименованиеЭтапа,
	|	СценарииЧатБотовСвойстваЭтаповСценария.ФормироватьСообщениеПоШаблону КАК ФормироватьСообщениеПоШаблону,
	|	СценарииЧатБотовСвойстваЭтаповСценария.СообщениеБота КАК СообщениеБота,
	|	СценарииЧатБотовСвойстваЭтаповСценария.ШаблонСообщения КАК ШаблонСообщения
	|ИЗ
	|	Справочник.СценарииЧатБотов.СвойстваЭтаповСценария КАК СценарииЧатБотовСвойстваЭтаповСценария
	|ГДЕ
	|	СценарииЧатБотовСвойстваЭтаповСценария.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И СценарииЧатБотовСвойстваЭтаповСценария.ТипЭтапа В (5, 6)";
	
	РезультатПакетногоЗапроса 		= Запрос.ВыполнитьПакет();
	ТаблицаТриггеровИСценариев 		= РезультатПакетногоЗапроса[0].Выгрузить();
	ТаблицаСвойствЭтаповСценариев 	= РезультатПакетногоЗапроса[1].Выгрузить();
	
	ТаблицаСценариев 				= ТаблицаТриггеровИСценариев.Скопировать(, "СценарийЧатБота, ИспользуетсяСценарий, ИмяМакетаПредопределенногоСценария");
	ТаблицаСценариев.Свернуть("СценарийЧатБота, ИспользуетсяСценарий, ИмяМакетаПредопределенногоСценария");
	
	// ---------------------------------------------------------------------------------------------------------------------------	
	МассивСтрокСценариев = ТаблицаСценариев.НайтиСтроки(Новый Структура("ИмяМакетаПредопределенногоСценария", "ЗаписьНаПрофосмотр"));
	Для Каждого СтрокаСценарий Из МассивСтрокСценариев Цикл 
		Сценарий_Объект = СтрокаСценарий.СценарийЧатБота.ПолучитьОбъект();
		Сценарий_Объект.ПометкаУдаления = Истина;
		Сценарий_Объект.ОбменДанными.Загрузка = Истина;
		Попытка
			Сценарий_Объект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;	
	Сценарий_ЗаписьНаПрофосмотр = Справочники.СценарииЧатБотов.ИнициализироватьСценарий("ЗаписьНаПрофосмотр");
	Если ЗначениеЗаполнено(Сценарий_ЗаписьНаПрофосмотр) Тогда
		ЕстьТриггер = Ложь;
		Для Каждого СтрокаТаблицы Из ТаблицаТриггеровИСценариев Цикл 
			Если СтрокаТаблицы.ИмяМакетаПредопределенногоСценария = "ЗаписьНаПрофосмотр" И ЗначениеЗаполнено(СтрокаТаблицы.Триггер) Тогда
				Триггер_Объект = СтрокаТаблицы.Триггер.ПолучитьОбъект();
				МассивСтрокТЧ_Действия = Триггер_Объект.Действия.НайтиСтроки(Новый Структура("ВидДействия, СценарийЧатБота, Удалено", Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота, СтрокаТаблицы.СценарийЧатБота, Ложь));
				Для Каждого СтрокаТЧМассива Из МассивСтрокТЧ_Действия Цикл 
					СтрокаТЧМассива.СценарийЧатБота = Сценарий_ЗаписьНаПрофосмотр;
				КонецЦикла;	
				Триггер_Объект.ОбменДанными.Загрузка = Истина;
				Попытка
					Триггер_Объект.Записать();
					ЕстьТриггер = Истина;					
				Исключение
					
				КонецПопытки;	
			КонецЕсли;	
		КонецЦикла;
		Если НЕ ЕстьТриггер Тогда 
			ПараметрыТриггерногоСобытия = Новый Структура;
			ПараметрыТриггерногоСобытия.Вставить("Наименование" 	, "Чат-Бот: Запись на профилактический осмотр");
			ПараметрыТриггерногоСобытия.Вставить("Активно"			, Истина);
			ПараметрыТриггерногоСобытия.Вставить("УсловиеСобытия"	, Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияПрофосмотр);
			ПараметрыТриггерногоСобытия.Вставить("МоментСобытия"	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия);
			ПараметрыТриггерногоСобытия.Вставить("ПериодСобытия"	, 7);
			ПараметрыТриггерногоСобытия.Вставить("ПериодСобытияВид"	, Перечисления.Периодичность.День);
			ПараметрыТриггерногоСобытия.Вставить("ВремяСобытия"		, Дата('0001.01.01 12:30:00'));
			ПараметрыТриггерногоСобытия.Вставить("СтатусЗаписи"		, Перечисления.СтатусыСобытия.НеПодтверждена);
			ПараметрыТриггерногоСобытия.Вставить("ПараметрыДействия"
			, Новый Структура("Использование, ВидДействия, ВидАдресата, СценарийЧатБота, Описание", Истина, Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота, Перечисления.ВидыАдресатов.КонтрагентСобытия, Сценарий_ЗаписьНаПрофосмотр, НСтр("ru = 'Запустить сценарий: ""Запись на проф. осмотр""';en= 'Registration for prof. inspection'")));
			
			ТриггерноеСобытие = Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие(ПараметрыТриггерногоСобытия, , ТаблицаСервисовSMS);
		КонецЕсли;
	КонецЕсли;
	
	// ---------------------------------------------------------ПереносЗаписиНаПрием------------------------------------------------------------------	
	МассивСтрокСценариев = ТаблицаСценариев.НайтиСтроки(Новый Структура("ИмяМакетаПредопределенногоСценария", "ПереносЗаписиНаПрием"));
	Для Каждого СтрокаСценарий Из МассивСтрокСценариев Цикл 
		Сценарий_Объект = СтрокаСценарий.СценарийЧатБота.ПолучитьОбъект();
		Сценарий_Объект.ПометкаУдаления = Истина;
		Сценарий_Объект.ОбменДанными.Загрузка = Истина;
		Попытка
			Сценарий_Объект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;	
	Сценарий_ПереносЗаписиНаПрием = Справочники.СценарииЧатБотов.ИнициализироватьСценарий("ПереносЗаписиНаПрием");

	// ----------------------------------------------------------ПодтверждениеЗаписиНаПрием-----------------------------------------------------------------
	МассивСтрокСценариев = ТаблицаСценариев.НайтиСтроки(Новый Структура("ИмяМакетаПредопределенногоСценария", "ПодтверждениеЗаписиНаПрием"));
	Для Каждого СтрокаСценарий Из МассивСтрокСценариев Цикл 
		Сценарий_Объект = СтрокаСценарий.СценарийЧатБота.ПолучитьОбъект();
		Сценарий_Объект.ПометкаУдаления = Истина;
		Сценарий_Объект.ОбменДанными.Загрузка = Истина;
		Попытка
			Сценарий_Объект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;		
	Сценарий_ПодтверждениеЗаписиНаПрием = Справочники.СценарииЧатБотов.ИнициализироватьСценарий("ПодтверждениеЗаписиНаПрием");
	Если ЗначениеЗаполнено(Сценарий_ПодтверждениеЗаписиНаПрием) Тогда
		ЕстьТриггер = Ложь;
		Для Каждого СтрокаТаблицы Из ТаблицаТриггеровИСценариев Цикл 
			Если СтрокаТаблицы.ИмяМакетаПредопределенногоСценария = "ПодтверждениеЗаписиНаПрием" И ЗначениеЗаполнено(СтрокаТаблицы.Триггер) Тогда
				Триггер_Объект = СтрокаТаблицы.Триггер.ПолучитьОбъект();
				МассивСтрокТЧ_Действия = Триггер_Объект.Действия.НайтиСтроки(Новый Структура("ВидДействия, СценарийЧатБота, Удалено", Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота, СтрокаТаблицы.СценарийЧатБота, Ложь));
				Для Каждого СтрокаТЧМассива Из МассивСтрокТЧ_Действия Цикл 
					СтрокаТЧМассива.СценарийЧатБота = Сценарий_ПодтверждениеЗаписиНаПрием;
				КонецЦикла;	
				Триггер_Объект.ОбменДанными.Загрузка = Истина;
				Попытка
					Триггер_Объект.Записать();
					ЕстьТриггер = Истина;					
				Исключение
					
				КонецПопытки;	
			КонецЕсли;	
		КонецЦикла;
		Если НЕ ЕстьТриггер Тогда 		
			ПараметрыТриггерногоСобытия = Новый Структура;
			ПараметрыТриггерногоСобытия.Вставить("Наименование" 	, "Чат-Бот: Подтверждение записи на приём");
			ПараметрыТриггерногоСобытия.Вставить("Активно"			, Истина);
			ПараметрыТриггерногоСобытия.Вставить("УсловиеСобытия"	, Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема);
			ПараметрыТриггерногоСобытия.Вставить("МоментСобытия"	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия);
			ПараметрыТриггерногоСобытия.Вставить("ПериодСобытия"	, 1);
			ПараметрыТриггерногоСобытия.Вставить("ПериодСобытияВид"	, Перечисления.Периодичность.День);
			ПараметрыТриггерногоСобытия.Вставить("ВремяСобытия"		, Дата('0001.01.01 10:00:00'));
			ПараметрыТриггерногоСобытия.Вставить("СтатусЗаписи"		, Перечисления.СтатусыСобытия.НеПодтверждена);
			ПараметрыТриггерногоСобытия.Вставить("ПараметрыДействия"
			, Новый Структура("Использование, ВидДействия, ВидАдресата, СценарийЧатБота, Описание", Истина, Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота, Перечисления.ВидыАдресатов.КонтрагентСобытия, Сценарий_ПодтверждениеЗаписиНаПрием, НСтр("ru = 'Запустить сценарий: ""Подтверждение записи на приём""';en= 'Activate chatbot script'")));
			
			ТриггерноеСобытие = Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие(ПараметрыТриггерногоСобытия, , ТаблицаСервисовSMS);
		КонецЕсли;
	КонецЕсли;
	
	// ----------------------------------------------------------СборОтзывовОРаботеВрача-----------------------------------------------------------------
	МассивСтрокСценариев = ТаблицаСценариев.НайтиСтроки(Новый Структура("ИмяМакетаПредопределенногоСценария", "СборОтзывовОРаботеВрача"));
	Для Каждого СтрокаСценарий Из МассивСтрокСценариев Цикл 
		Сценарий_Объект = СтрокаСценарий.СценарийЧатБота.ПолучитьОбъект();
		Сценарий_Объект.ПометкаУдаления = Истина;
		Сценарий_Объект.ОбменДанными.Загрузка = Истина;
		Попытка
			Сценарий_Объект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;		
	Сценарий_СборОтзывовОРаботеВрача = Справочники.СценарииЧатБотов.ИнициализироватьСценарий("СборОтзывовОРаботеВрача");
	Если ЗначениеЗаполнено(Сценарий_СборОтзывовОРаботеВрача) Тогда
		ЕстьТриггер = Ложь;
		Для Каждого СтрокаТаблицы Из ТаблицаТриггеровИСценариев Цикл 
			Если СтрокаТаблицы.ИмяМакетаПредопределенногоСценария = "СборОтзывовОРаботеВрача" И ЗначениеЗаполнено(СтрокаТаблицы.Триггер) Тогда
				Триггер_Объект = СтрокаТаблицы.Триггер.ПолучитьОбъект();
				МассивСтрокТЧ_Действия = Триггер_Объект.Действия.НайтиСтроки(Новый Структура("ВидДействия, СценарийЧатБота, Удалено", Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота, СтрокаТаблицы.СценарийЧатБота, Ложь));
				Для Каждого СтрокаТЧМассива Из МассивСтрокТЧ_Действия Цикл 
					СтрокаТЧМассива.СценарийЧатБота = Сценарий_СборОтзывовОРаботеВрача;
				КонецЦикла;	
				Триггер_Объект.ОбменДанными.Загрузка = Истина;
				Попытка
					Триггер_Объект.Записать();
					ЕстьТриггер = Истина;					
				Исключение
					
				КонецПопытки;	
			КонецЕсли;	
		КонецЦикла;
		Если НЕ ЕстьТриггер Тогда 		
			ПараметрыТриггерногоСобытия = Новый Структура;
			ПараметрыТриггерногоСобытия.Вставить("Наименование" 	, "Чат-Бот: Сбор отзывов о работе врача");
			ПараметрыТриггерногоСобытия.Вставить("Активно"			, Истина);
			ПараметрыТриггерногоСобытия.Вставить("УсловиеСобытия"	, Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен);
			ПараметрыТриггерногоСобытия.Вставить("РезультатПриема"	, 1);
			ПараметрыТриггерногоСобытия.Вставить("МоментСобытия"	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия);
			ПараметрыТриггерногоСобытия.Вставить("ПериодСобытия"	, 1);
			ПараметрыТриггерногоСобытия.Вставить("ПериодСобытияВид"	, Перечисления.Периодичность.Час);
			ПараметрыТриггерногоСобытия.Вставить("ВремяСобытия"		, Дата('0001.01.01 10:00:00'));
			ПараметрыТриггерногоСобытия.Вставить("ПараметрыДействия"
			, Новый Структура("Использование, ВидДействия, ВидАдресата, СценарийЧатБота, Описание", Истина, Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота, Перечисления.ВидыАдресатов.КонтрагентСобытия, Сценарий_СборОтзывовОРаботеВрача, НСтр("ru = 'Запустить сценарий: ""Сбор отзывов о работе врача""';en= 'Activate chatbot script'")));
			
			ТриггерноеСобытие = Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие(ПараметрыТриггерногоСобытия, Истина, ТаблицаСервисовSMS);
		КонецЕсли;
	КонецЕсли;
	
	Справочники.ВариантыОтветов.ОбновитьБиблиотекуОтветов();
	
КонецПроцедуры  

// Процедура, Добавляет записи в регистр настройки пользователей
//
Процедура ДобавитьЗаписиВРегистрНастройкиПользователей() Экспорт  
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.Сотрудник КАК Сотрудник,
	|	НастройкиСотрудников.ДатаПриема КАК ДатаПриема,
	|	НастройкиСотрудников.ДатаУвольнения КАК ДатаУвольнения,
	|	НастройкиСотрудников.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НЕ НастройкиСотрудников.Сотрудник.ПометкаУдаления
	|	И НЕ НастройкиСотрудников.Сотрудник.ЭтоГруппа 
	|   И НастройкиСотрудников.Сотрудник.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И (НастройкиСотрудников.ДатаПриема <> ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ НастройкиСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1))
	|ИТОГИ ПО
	|	НастройкиСотрудников.СтруктурнаяЕдиница");
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл 		
		ВыборкаСотрудников = Выборка.Выбрать(ОбходРезультатаЗапроса.Прямой);
		Пока ВыборкаСотрудников.Следующий() Цикл  
			Пользователь = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ", ВыборкаСотрудников.Сотрудник.ИдентификаторПользователяИБ);
			НаборЗаписей = РегистрыСведений.НастройкиПользователей.СоздатьМенеджерЗаписи(); 
			НаборЗаписей.СтруктурнаяЕдиница = ВыборкаСотрудников.СтруктурнаяЕдиница;
			НаборЗаписей.Пользователь = ?(Пользователь.ЭтоПользовательИБ , Пользователь, ВыборкаСотрудников.Сотрудник);
			Если ВыборкаСотрудников.ДатаПриема <> ДАТА(1, 1, 1) Тогда
				НаборЗаписей.Настройка = ПланыВидовХарактеристик.НастройкиПользователей.ДатаПриема;
				НаборЗаписей.Значение = ВыборкаСотрудников.ДатаПриема;				
			КонецЕсли;
			Если ВыборкаСотрудников.ДатаУвольнения <> Дата(1, 1, 1) Тогда 
				Если НаборЗаписей.Значение = Неопределено Тогда	
					НаборЗаписей.Настройка = ПланыВидовХарактеристик.НастройкиПользователей.ДатаУвольнения;
					НаборЗаписей.Значение = ВыборкаСотрудников.ДатаУвольнения; 
				Иначе  
					НовыйНаборЗаписей = РегистрыСведений.НастройкиПользователей.СоздатьМенеджерЗаписи();
					НовыйНаборЗаписей.СтруктурнаяЕдиница = ВыборкаСотрудников.СтруктурнаяЕдиница;
					НовыйНаборЗаписей.Пользователь = ?(Пользователь.ЭтоПользовательИБ ,Пользователь, ВыборкаСотрудников.Сотрудник);
					НовыйНаборЗаписей.Настройка = ПланыВидовХарактеристик.НастройкиПользователей.ДатаУвольнения;
					НовыйНаборЗаписей.Значение = ВыборкаСотрудников.ДатаУвольнения;
					НовыйНаборЗаписей.Записать();
				КонецЕсли;
			КонецЕсли;
			НаборЗаписей.Записать();
		КонецЦикла;	
	КонецЦикла;	
	
КонецПроцедуры	

// Процедура - Перенести элементы справочника диагнозы
//
Процедура ПеренестиЭлементыСправочникаДиагнозы() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДиагнозыУдалить.Родитель КАК Родитель,
		|	ДиагнозыУдалить.ЭтоГруппа КАК ЭтоГруппа,
		|	ДиагнозыУдалить.Код КАК Код,
		|	ДиагнозыУдалить.Наименование КАК Наименование,
		|	ДиагнозыУдалить.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ДиагнозыУдалить КАК ДиагнозыУдалить
		|ГДЕ
		|	НЕ ДиагнозыУдалить.ПометкаУдаления";
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Код) Тогда		
			Диагноз = Справочники.Диагнозы.НайтиПоКоду(Выборка.Код);
			Если ЗначениеЗаполнено(Диагноз)
				И Диагноз.Наименование = Выборка.Наименование Тогда
				Продолжить;  				
			КонецЕсли;
		КонецЕсли;
		
		Если Выборка.ЭтоГруппа Тогда
			НовыйОбъект = Справочники.Диагнозы.СоздатьГруппу();
		Иначе
			НовыйОбъект = Справочники.Диагнозы.СоздатьЭлемент();
		КонецЕсли;
		НовыйОбъект.Код			 = Выборка.Код;
		НовыйОбъект.Наименование = Выборка.Наименование; 
		НовыйОбъект.Родитель	 = Выборка.Родитель;
		
		Попытка	
			НовыйОбъект.Записать();
		Исключение  
			ОписаниеОшибки = "Не перенесен диагноз " + Выборка.Наименование + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());  
			ЗаписьЖурналаРегистрации("ПеренестиЭлементыСправочникаДиагнозы", УровеньЖурналаРегистрации.Ошибка, 
				Метаданные.Справочники.ДиагнозыУдалить, Выборка.Ссылка, ОписаниеОшибки);			
		КонецПопытки;
		
	КонецЦикла;
		
КонецПроцедуры

// Процедура - Обновить записи регистра "Контрагенты сведения для списка".
//
Процедура ОбновитьЗаписиРегистраКонтрагентыСведенияДляСписка(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыСведенияДляСписка.Контрагент.Ссылка КАК КонтрагентСсылка
		|ИЗ
		|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
		|ГДЕ
		|	НЕ КонтрагентыСведенияДляСписка.Контрагент.ПометкаУдаления";   
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьСведенияДляСписка(Выборка.КонтрагентСсылка);
		КонецЦикла;		
		
	Исключение
		
		ЗаписьЖурналаРегистрации("Заполнение регистра сведений контрагенты сведения для списка", 
		УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
		
	КонецПопытки;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Перенести настройки этапов сценариев в хранилище значений
//
Процедура ПеренестиНастройкиЭтаповСценариевВХранилищеЗначений() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если НЕ ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") Тогда 
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СценарииЧатБотов.Ссылка КАК СценарииЧатБота,
	|	СценарииЧатБотов.НастройкиЭтапов КАК НастройкиЭтапов,
	|	СценарииЧатБотов.ИмяМакетаПредопределенногоСценария КАК ИмяМакетаПредопределенногоСценария
	|ИЗ
	|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
	|ГДЕ
	|	СценарииЧатБотов.ПометкаУдаления = ЛОЖЬ";
	
	ТаблицаСценариев = Запрос.Выполнить().Выгрузить();
	
	МетаданныеСправочника 		= Метаданные.Справочники.СценарииЧатБотов;
	ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
	
	Для Каждого СтрокаСценарий Из ТаблицаСценариев Цикл 
		НастройкиЭтапов = Справочники.СценарииЧатБотов.ИнициализироватьТаблицуНастроекЭтапов(СтрокаСценарий.НастройкиЭтапов);
		Если ЗначениеЗаполнено(НастройкиЭтапов) Тогда 
			Продолжить;
		КонецЕсли;
		Сценарий_Объект = СтрокаСценарий.СценарииЧатБота.ПолучитьОбъект();
		Для Каждого СтрокаСвойство Из Сценарий_Объект.СвойстваЭтаповСценария Цикл 
			ЗаполнитьЗначенияСвойств(НастройкиЭтапов.Добавить(), СтрокаСвойство);
		КонецЦикла;
		Сценарий_Объект.НастройкиЭтапов 		= Новый ХранилищеЗначения(НастройкиЭтапов);
		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Сценарий_Объект);
		Исключение
			ШаблонКомментария = НСтр("ru = 'Не удалось перенести настройки этапов сценария ""%1"" в хранилище значений, по причине: ""%2""' ");
			
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонКомментария,
			Сценарий_Объект.Ссылка,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Предупреждение,
			МетаданныеСправочника,,
			Комментарий);
		КонецПопытки;	
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Переименовать наименования параметров шаблонов сообщений.
//
Процедура ПереименоватьНаименованияПараметровШаблоновСообщений() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Справочники.ШаблоныСообщений.ПереименоватьПараметрыШаблоновСообщений();
	
КонецПроцедуры	

// Процедура - Заполнить организацию в актах оказания услуг.
//
Процедура ЗаполнитьОрганизациюВАктахОказанияУслуг(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АктОказанияУслуг.Ссылка КАК Ссылка,
	|	АктОказанияУслуг.СтруктурнаяЕдиница.Организация КАК ОрганизацияСЕ
	|ИЗ
	|	Документ.АктОказанияУслуг КАК АктОказанияУслуг
	|ГДЕ
	|	АктОказанияУслуг.Проведен = ИСТИНА
	|	И АктОказанияУслуг.СтруктурнаяЕдиница <> ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)";   
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл		
		
		ОбъектАкт = Выборка.Ссылка.ПолучитьОбъект();
		ОбъектАкт.Организация = Выборка.ОрганизацияСЕ;
		 
		Попытка	
			ОбъектАкт.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			
			ЗаписьЖурналаРегистрации("Заполнение организации в актах оказания услуг.", 
			УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
			
		КонецПопытки;

	КонецЦикла;	
			
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Перезаписать настройки цветов для структурной единицы.
//
Процедура ПерезаписьНастроекЦветовСтруктурнойЕдиницы() Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	СписокНастроек = Новый Массив();
	СписокНастроек.Добавить(ПланыВидовХарактеристик.НастройкиПользователей["ЦветСобытияЗапланировано"]);
	СписокНастроек.Добавить(ПланыВидовХарактеристик.НастройкиПользователей["ЦветСобытияНеПодтверждено"]);
	СписокНастроек.Добавить(ПланыВидовХарактеристик.НастройкиПользователей["ЦветСобытияПриемНеСостоялся"]);
	СписокНастроек.Добавить(ПланыВидовХарактеристик.НастройкиПользователей["ЦветСобытияПациентОжидает"]);
	СписокНастроек.Добавить(ПланыВидовХарактеристик.НастройкиПользователей["ЦветСобытияПриемОкончен"]);
	СписокНастроек.Добавить(ПланыВидовХарактеристик.НастройкиПользователей["ЦветСобытияПациентВКресле"]);
	
	// Выборка текущих записей цветов пользователя. 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиПользователей.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НастройкиПользователей.Настройка КАК Настройка,
	|	МАКСИМУМ(НастройкиПользователей.Значение) КАК Значение,
	|	МАКСИМУМ(НастройкиПользователей.Пользователь) КАК Пользователь
	|ИЗ
	|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	|ГДЕ
	|	НастройкиПользователей.Настройка В(&Настройка)
	|
	|СГРУППИРОВАТЬ ПО
	|	НастройкиПользователей.СтруктурнаяЕдиница,
	|	НастройкиПользователей.Настройка";
	
	Запрос.УстановитьПараметр("Настройка" , СписокНастроек);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Удаление старых записей цветов пользователя из регистра.
	
	Набор = РегистрыСведений.НастройкиПользователей.СоздатьНаборЗаписей(); 
	Для Каждого Настройка Из СписокНастроек Цикл
		
		Набор.Отбор.Настройка.Установить(Настройка); 
		
		Попытка
			Набор.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("ПерезаписьНастроекЦветовСтруктурнойЕдиницы", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		КонецПопытки; 
		
	КонецЦикла;
	
	// Запись новых цветов в регистр.
	
	Пока Выборка.Следующий() Цикл 
		
		ЗаписьРегистра 						= РегистрыСведений.НастройкиПользователей.СоздатьМенеджерЗаписи();
		ЗаписьРегистра.Пользователь 		= Выборка.Пользователь;
		ЗаписьРегистра.Настройка 			= Выборка.Настройка;
		ЗаписьРегистра.СтруктурнаяЕдиница 	= Выборка.СтруктурнаяЕдиница;
		ЗаписьРегистра.Значение 			= Выборка.Значение;
		
		Попытка
			ЗаписьРегистра.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("ПерезаписьНастроекЦветовСтруктурнойЕдиницы", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Обновить предопределенные отчеты.
//
Процедура ОбновитьПредопределенныеВариантыОтчетов() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Попытка
		
		ВариантыОтчетов.Обновить();
		ОтчетыСервер.Обновить();
		
	Исключение
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Обновление предопределенных вариантов отчетов"
																, УровеньЖурналаРегистрации.Ошибка,,
																, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
КонецПроцедуры 

// Процедура - Обновить текст отправки сообщения о новой карте
//
Процедура ОбновитьТекстОтправкиСообщенияОНовойКарте() Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ШаблоныСообщений.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	ШаблоныСообщений.ИмяПредопределенныхДанных = ""СозданиеКарты""
	|	И ШаблоныСообщений.ЭтоГруппа = ЛОЖЬ
	|	И ШаблоныСообщений.ПометкаУдаления = ЛОЖЬ
	|	И ШаблоныСообщений.Содержание ПОДОБНО """"");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
