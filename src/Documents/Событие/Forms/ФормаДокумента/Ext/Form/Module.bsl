																		, ОбщегоНазначения.ПолучитьЗначениеРеквизита(НаправившийВрач, "НаименованиеСокращенное"))
																		+ " записан " + Лев(ДатаСозданияОбращения, СтрДлина(ДатаСозданияОбращения) - 2) + " в " 
																		+ Формат(Объект.ДатаСоздания, "ДФ=HH:mm")+ ", " 
																		+ ПользователиСлужебныйКлиентСервер.ПолучитьКраткоеИмяПользователяИБНовый(Объект.АвторДокумента);
		Иначе 
			Элементы.ДекорацияКартинкаНаправления.Видимость = Ложь;
		КонецЕсли;
	КонецЕсли;																			
																				

	
	//Если НЕ ЭтоНовыйДок ИЛИ ЗначениеЗаполнено(СокрЛП(Объект.Комментарий)) ИЛИ НЕ ЗначениеЗаполнено(ТекущаяСделка) Тогда 
	//	Возврат;
	//КонецЕсли;
	//
	//// формируем здесь, так как сделка инициализируется при создании формы
	//Объект.Комментарий = СокрЛП(ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущаяСделка, "Описание"));	
	
КонецПроцедуры

&НаСервере
// Процедура - Услуги после удаления на сервере.
//
Процедура УслугиПослеУдаленияНаСервере()
	
	Если Объект.Услуги.Количество() > 0 Тогда 
		ТаблицаУслуги = Объект.Услуги.Выгрузить();
		Объект.Услуги.Очистить();
		Для Каждого СтрокаУслуга Из ТаблицаУслуги Цикл
			Если СтрокаУслуга.НомерСтроки = 1 Тогда 
				СледующаяДата = ДатаНачала;
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаУслуга.Номенклатура) Тогда				
				НоваяСтрока = Объект.Услуги.Добавить();
				НоваяСтрока.ДатаНачала 		= СледующаяДата;
				НоваяСтрока.ДатаОкончания 	= НоваяСтрока.ДатаНачала + СтрокаУслуга.НормаВремени * 60;
			    НоваяСтрока.НормаВремени 	= СтрокаУслуга.НормаВремени;
				НоваяСтрока.Номенклатура 	= СтрокаУслуга.Номенклатура;
				НоваяСтрока.Сотрудник 		= СтрокаУслуга.Сотрудник;
				НоваяСтрока.Помещение 		= СтрокаУслуга.Помещение;
				НоваяСтрока.ПричинаЗаписи 	= СтрокаУслуга.ПричинаЗаписи;
				СледующаяДата = НоваяСтрока.ДатаОкончания;
			КонецЕсли;	
		КонецЦикла;
		
		УстановитьДаты();
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура устанавливает видимость элементов.
//
Процедура УстановитьВидимостьЭлементов()
		
	Элементы.ГруппаПеренесеннаяЗапись.Видимость 	= ЗначениеЗаполнено(Объект.ПеренесённаяПредварительнаяЗапись);
	Если ЗначениеЗаполнено(Объект.ПеренесённаяПредварительнаяЗапись) Тогда 
		ДатаВремяЗаписи = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.ПеренесённаяПредварительнаяЗапись, "Дата");
		Элементы.ОткрытьПеренесеннуюЗапись.Заголовок = "Перезапись от " + Формат(ДатаВремяЗаписи, "ДФ='d MMM'','' H:mm'");
	КонецЕсли; 
		
	Если НЕ Объект.Резерв Тогда 
		Если Объект.Ссылка.Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
			Элементы.ПричинаОтмены.Видимость = Истина;
			Элементы.ПричинаОтмены.КнопкаОткрытия = Ложь;
			Элементы.ПричинаОтмены.ЦветТекста = Новый Цвет(77, 77, 77);
			Элементы.Выравнивание.Ширина = 71;
			Элементы.ГруппаФормаКнопкаОтменаПриема.Видимость    = Ложь; 
			Элементы.ГруппаФормаКнопкаЗаписатьНаПрием.Видимость = Истина; 
			Элементы.ГруппаФормаКнопкаПровестиИЗакрыть.ЦветФона = Новый Цвет(242, 242, 242);
			Элементы.ФормаКнопкаПровестиИЗакрыть.ЦветТекста     = Новый Цвет(51, 51, 51);
			СсылкаНаСобытие = ПолучитьПредварительнуюЗаписьОтмененногоСобытия(Объект.Ссылка);
			Если ЗначениеЗаполнено(СсылкаНаСобытие) Тогда 
				Элементы.ФормаКнопкаПерезаписать.Видимость         = Ложь;
				Элементы.АктуальнаяПредварительнаяЗапись.Видимость = Истина;
				Элементы.ГруппаФормаКнопкаЗаписатьНаПрием.ЦветФона = Новый Цвет(255, 255, 255);  
				ДатаВремяЗаписи = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СсылкаНаСобытие, "Дата");
				Элементы.АктуальнаяПредварительнаяЗапись.Заголовок = "Запись на " + Формат(ДатаВремяЗаписи, "ДФ='d MMM'','' H:mm'"); 
				Элементы.ФормаКнопкаВвестиПосещение.Доступность    = Ложь;
			КонецЕсли;	
			
		Иначе			
			Если Объект.Статус = Перечисления.СтатусыСобытия.ПриемОкончен ИЛИ Объект.Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда

			ИначеЕсли Объект.Ссылка.Статус = Перечисления.СтатусыСобытия.НеПодтверждена Или Объект.Ссылка.Статус = Перечисления.СтатусыСобытия.Подтверждена ИЛИ Объект.Ссылка.Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда
				Элементы.ФормаКнопкаВвестиПосещение.Картинка = БиблиотекаКартинок.Документ;   			
			ИначеЕсли Объект.Ссылка.Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда
				Элементы.ФормаКнопкаВвестиПосещение.Картинка = БиблиотекаКартинок.ДокументПроведен;				
			КонецЕсли;  			
			
