КонецПроцедуры	

&НаСервере
// Процедура - Установить тип адресата сведений на сервере
//
// Параметры:
//  КомандаТипаАдресата	 - 	 - 
//  ОбновитьДанные		 - 	 - 
//
Процедура УстановитьТипАдресатаСведенийНаСервере(Знач КомандаТипаАдресата = Неопределено, ОбновитьДанные = Ложь, СброситьОтборы = Истина)
	
	ОтборСотрудники = Неопределено;
	Если КомандаТипаАдресата = Неопределено И ЗначениеЗаполнено(ОтборАдресатСведенийТип) Тогда 
		// При открытии формы на сервере
	Иначе
		Если КомандаТипаАдресата = "ПоказатьСведенияДляВсехСотрудников" ИЛИ КомандаТипаАдресата = "Все" Тогда 
			Если ОтборАдресатСведенийТип = "ИзСписка" И СброситьОтборы Тогда 
				ПриИзмененииОтборовСервер("ДекорацияУдалитьЗначение_ME_МенюОтборСотрудники");
			КонецЕсли;	
			ОтборАдресатСведенийТип = "Все";
		ИначеЕсли КомандаТипаАдресата = "ПоказатьСведенияМои" ИЛИ КомандаТипаАдресата = "Мои" Тогда	
			Если ОтборАдресатСведенийТип = "ИзСписка" И СброситьОтборы Тогда 
				ПриИзмененииОтборовСервер("ДекорацияУдалитьЗначение_ME_МенюОтборСотрудники");
			КонецЕсли;				
			ОтборАдресатСведенийТип = "Мои";
		Иначе
			Если КомандаТипаАдресата = "КомандаСкрыть_ME_ПодчиненноеМенюОтборСотрудники" ИЛИ КомандаТипаАдресата = "ДекорацияУдалитьЗначение_ME_МенюОтборСотрудники" ИЛИ КомандаТипаАдресата = "КомандаПрименить_ME_ПодчиненноеМенюОтборСотрудники" ИЛИ СтрНайти(КомандаТипаАдресата, "МенюОтборСотрудники_Тип_ПереключательСотрудник") > 0 Тогда 
				ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
				Если ОтборСотрудники.Количество() = 0 Тогда 
					ОтборАдресатСведенийТип = ?(ОтборАдресатСведенийТип <> "ИзСписка", ОтборАдресатСведенийТип, "Мои");
					ЭлементФормы        = УправлениеИнтерфейсамиСервер.ЭлементФормыПоИмениЭлемента(ЭтаФорма, "ДекорацияУдалитьЗначение_ME_МенюОтборСотрудники");
					ИмяЭлемента         = ЭлементФормы.Имя;
					ОбновитьПланировщик = УправлениеИнтерфейсамиСервер.ОбработчикЭлементаДинамическогоМенюПриНажатии(ЭтаФорма, ИмяЭлемента);
				Иначе 
					ОтборАдресатСведенийТип = "ИзСписка";
				КонецЕсли;
			ИначеЕсли СтрНайти(КомандаТипаАдресата, "МенюОтборСотрудники_Тип_ПереключательСотрудник") > 0 ИЛИ СтрНайти(КомандаТипаАдресата, "КомандаОтбор_ME_ПодчиненноеМенюОтборСотрудники_Тип") > 0 Тогда 

			Иначе 
				ОтборАдресатСведенийТип = "ИзСписка";
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;

	УстановитьСвойстваОтображенияЭлементовАдресата();

	Если ОбновитьДанные Тогда
		АктуализироватьТаблицуСортировкиПоказателейKPI(, , ОтборСотрудники);		
		ОбновитьОбщиеСведения();
		ОбновитьСведенияПоСделкам();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства отображения элементов адресата
//
Процедура УстановитьСвойстваОтображенияЭлементовАдресата()
	
	// Управление свойствами элементов-переключателей устанавливающих отбор по адресату
	Для Каждого ЭлементГруппаПереключатель Из Элементы.ГруппаМоиВсе.ПодчиненныеЭлементы Цикл 
		ЭлементГруппаПереключатель.ЦветФона = Новый Цвет();
		Если ТипЗнч(ЭлементГруппаПереключатель) = Тип("ГруппаФормы") Тогда 
			Для Каждого ЭлементКнопкаПереключатель Из ЭлементГруппаПереключатель.ПодчиненныеЭлементы Цикл
				ЭлементКнопкаПереключатель.ЦветТекста = Новый Цвет();
			КонецЦикла;
		КонецЕсли;	
	КонецЦикла;
	
	Если ОтборАдресатСведенийТип = "Все" Тогда
		Элементы.ГруппаКнопкиПоказатьСведенияДляВсех.ЦветФона 	= Новый Цвет(242, 242, 242);		
		// Элементы.УстановитьПериодДень.ЦветТекста 				= Новый Цвет();
	ИначеЕсли ОтборАдресатСведенийТип = "Мои" Тогда
		Элементы.ГруппаКнопкиПоказатьСведенияМои.ЦветФона 		= Новый Цвет(242, 242, 242);		
		// Элементы.УстановитьПериодНеделя.ЦветТекста 			= Новый Цвет();
	ИначеЕсли ОтборАдресатСведенийТип = "ИзСписка" Тогда

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область _____________________УСТАНОВКА_ОТБОРА_ПО_ПЕРИОДУ________________________

&НаКлиенте
// Процедура - Установить период агрегирования информации
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура УстановитьПериодАгрегированияИнформации(Команда)

	ОбновитьДанные 							= Истина;
	СдвинутьВременнойИнтервал 				= Ложь;
	НаправлениеДвиженияВременногоИнтервала 	= "";
	
	Если Команда.Имя = "УстановитьПериодПроизвольный" Тогда	
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();
		Диалог.Период = ОтборПериодЗначение;
		Диалог.Показать(Новый ОписаниеОповещения("ОтборПериодаПланированииПриИзменении", ЭтаФорма)); 
		ОбновитьДанные = Ложь;
	ИначеЕсли Команда.Имя = "ПериодВперед" Тогда
		СдвинутьВременнойИнтервал 				= Истина;
		НаправлениеДвиженияВременногоИнтервала 	= "Вперед";
	ИначеЕсли Команда.Имя = "ПериодНазад" Тогда
		СдвинутьВременнойИнтервал 				= Истина;
		НаправлениеДвиженияВременногоИнтервала 	= "Назад";		
	КонецЕсли;
	
	Если ОбновитьДанные Тогда 
		УстановитьПериодАгрегированияИнформацииНаСервере(Команда.Имя, СдвинутьВременнойИнтервал, НаправлениеДвиженияВременногоИнтервала, ОбновитьДанные);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отбор периода планировании при изменении
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОтборПериодаПланированииПриИзменении(Результат, ДополнительныеПараметры) Экспорт 
	
	Если НЕ Результат = Неопределено Тогда
		ОтборПериодТип 		= ПредопределенноеЗначение("Перечисление.Периодичность.Час");
		ОтборПериодЗначение = Результат;
		УстановитьПериодАгрегированияИнформацииНаСервере(, , , Истина);	
	Иначе 
		УстановитьФокусЭлементаСервер();	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить период агрегирования информации на сервере
//
// Параметры:
//  КомандаПериода							 - 	 - 
//  СдвинутьВременнойИнтервал				 - 	 - 
//  НаправлениеДвиженияВременногоИнтервала	 - 	 - 
//  ОбновитьДанные							 - 	 - 
//
Процедура УстановитьПериодАгрегированияИнформацииНаСервере(Знач КомандаПериода = Неопределено, Знач СдвинутьВременнойИнтервал = Ложь, Знач НаправлениеДвиженияВременногоИнтервала = "", ОбновитьДанные = Ложь)
	
	Если КомандаПериода = Неопределено И ЗначениеЗаполнено(ОтборПериодТип) Тогда 
		// При открытии формы на сервере
	Иначе 
		Если КомандаПериода = "УстановитьПериодДень" Тогда 
			ОтборПериодТип = Перечисления.Периодичность.День;
		ИначеЕсли КомандаПериода = "УстановитьПериодНеделя" Тогда	
			ОтборПериодТип = Перечисления.Периодичность.Неделя;
		ИначеЕсли КомандаПериода = "УстановитьПериодМесяц" Тогда	
			ОтборПериодТип = Перечисления.Периодичность.Месяц;
		ИначеЕсли КомандаПериода = "УстановитьПериодПроизвольный" Тогда	
			ОтборПериодТип = Перечисления.Периодичность.Час;			
		ИначеЕсли НЕ СдвинутьВременнойИнтервал Тогда  
			ОтборПериодТип = Перечисления.Периодичность.День;
		КонецЕсли;
	КонецЕсли;

	СформироватьЗначениеПериодаОтбора(СдвинутьВременнойИнтервал, НаправлениеДвиженияВременногоИнтервала);
	
	УстановитьСвойстваОтображенияЭлементовПериода();

	ОбновитьДинамическоеМенюОтборСотрудники();
	Если ОтборАдресатСведенийТип = "ИзСписка" Тогда
		ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
		ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, Неопределено); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
	ИначеЕсли ОтборАдресатСведенийТип = "Мои" Тогда 
		ОтборСотрудники = Новый Массив();
		ОтборСотрудники.Добавить(ТекущийПользователь);
	Иначе 
		ОтборСотрудники = Неопределено; // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина);
	КонецЕсли;
	
	// АктуализироватьТаблицуСортировкиПоказателейKPI(, , ОтборСотрудники);
	
	Если ОбновитьДанные Тогда 
		ОбновитьОбщиеСведения(ОтборСотрудники);
		ОбновитьСведенияПоСделкам(ОтборСотрудники);
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Процедура - Сформировать значение периода отбора
//
Процедура СформироватьЗначениеПериодаОтбора(СдвинутьВременнойИнтервал = Ложь, НаправлениеДвиженияВременногоИнтервала = "")
	
	Если СдвинутьВременнойИнтервал Тогда 
		Если НаправлениеДвиженияВременногоИнтервала = "Вперед" Тогда 
			Если ОтборПериодТип = Перечисления.Периодичность.День Тогда
				ОтборПериодЗначение.ДатаНачала 		= НачалоДня(ОтборПериодЗначение.ДатаНачала + 60*60*24);
				ОтборПериодЗначение.ДатаОкончания 	= КонецДня(ОтборПериодЗначение.ДатаНачала);
			ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
				ОтборПериодЗначение.ДатаНачала 		= НачалоНедели(ОтборПериодЗначение.ДатаНачала + 60*60*24*7);
				ОтборПериодЗначение.ДатаОкончания 	= КонецНедели(ОтборПериодЗначение.ДатаНачала);
			ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда
				ОтборПериодЗначение.ДатаНачала 		= НачалоМесяца(ДобавитьМесяц(ОтборПериодЗначение.ДатаНачала, 1));
				ОтборПериодЗначение.ДатаОкончания 	= КонецМесяца(ОтборПериодЗначение.ДатаНачала);
			ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Час Тогда
				Если НачалоМесяца(ОтборПериодЗначение.ДатаНачала) = ОтборПериодЗначение.ДатаНачала И КонецМесяца(ОтборПериодЗначение.ДатаОкончания) = ОтборПериодЗначение.ДатаОкончания Тогда 
					ОтборПериодЗначение.ДатаНачала 		= НачалоМесяца(ДобавитьМесяц(ОтборПериодЗначение.ДатаНачала, 1));
					ОтборПериодЗначение.ДатаОкончания 	= КонецМесяца(ОтборПериодЗначение.ДатаНачала);
				Иначе 					
					ПериодВСекундах 					= ОтборПериодЗначение.ДатаОкончания - ОтборПериодЗначение.ДатаНачала;
					ОтборПериодЗначение.ДатаНачала 		= ОтборПериодЗначение.ДатаОкончания + 1;
					ОтборПериодЗначение.ДатаОкончания 	= ОтборПериодЗначение.ДатаНачала + ПериодВСекундах;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли НаправлениеДвиженияВременногоИнтервала = "Назад" Тогда	
			Если ОтборПериодТип = Перечисления.Периодичность.День Тогда
				ОтборПериодЗначение.ДатаНачала 		= НачалоДня(ОтборПериодЗначение.ДатаНачала - 60*60*24);
				ОтборПериодЗначение.ДатаОкончания 	= КонецДня(ОтборПериодЗначение.ДатаНачала);
			ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
				ОтборПериодЗначение.ДатаНачала 		= НачалоНедели(ОтборПериодЗначение.ДатаНачала - 60*60*24*7);
				ОтборПериодЗначение.ДатаОкончания 	= КонецНедели(ОтборПериодЗначение.ДатаНачала);
			ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда 
				ОтборПериодЗначение.ДатаНачала 		= НачалоМесяца(ДобавитьМесяц(ОтборПериодЗначение.ДатаНачала, -1));
				ОтборПериодЗначение.ДатаОкончания 	= КонецМесяца(ОтборПериодЗначение.ДатаНачала);
			ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Час Тогда
				Если НачалоМесяца(ОтборПериодЗначение.ДатаНачала) = ОтборПериодЗначение.ДатаНачала И КонецМесяца(ОтборПериодЗначение.ДатаОкончания) = ОтборПериодЗначение.ДатаОкончания Тогда 
					ОтборПериодЗначение.ДатаНачала 		= НачалоМесяца(ДобавитьМесяц(ОтборПериодЗначение.ДатаНачала, -1));
					ОтборПериодЗначение.ДатаОкончания 	= КонецМесяца(ОтборПериодЗначение.ДатаНачала);
				Иначе 	
					ПериодВСекундах 					= ОтборПериодЗначение.ДатаОкончания - ОтборПериодЗначение.ДатаНачала;
					ОтборПериодЗначение.ДатаОкончания 	= ОтборПериодЗначение.ДатаНачала - 1;
					ОтборПериодЗначение.ДатаНачала 		= ОтборПериодЗначение.ДатаОкончания - ПериодВСекундах;				
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе 	
		Если ОтборПериодТип = Перечисления.Периодичность.День Тогда 
			ОтборПериодЗначение.Вариант 			= ВариантСтандартногоПериода.Сегодня; 
		ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
			ОтборПериодЗначение.Вариант 			= ВариантСтандартногоПериода.ЭтаНеделя;
		ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда
			ОтборПериодЗначение.Вариант 			= ВариантСтандартногоПериода.ЭтотМесяц;
		ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Час Тогда
			// формируется в асинхронном вызове
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Установить видимость элементов
//
Процедура УстановитьСвойстваОтображенияЭлементовПериода()
	
	// Управление свойствами элементов-переключателей устанавливающих отбор по периоду
	Для Каждого ЭлементГруппаПереключательПериода Из Элементы.ГруппаОтборПоПериоду.ПодчиненныеЭлементы Цикл 
		ЭлементГруппаПереключательПериода.ЦветФона = Новый Цвет();
		Если ТипЗнч(ЭлементГруппаПереключательПериода) = Тип("ГруппаФормы") Тогда 
			Для Каждого ЭлементКнопкаПереключательПериода Из ЭлементГруппаПереключательПериода.ПодчиненныеЭлементы Цикл
				Если ТипЗнч(ЭлементКнопкаПереключательПериода) = Тип("КнопкаФормы") Тогда
					Если НЕ ЭлементКнопкаПереключательПериода.Имя = "УстановитьПериодПроизвольный" Тогда 
						ЭлементКнопкаПереключательПериода.ЦветТекста = Новый Цвет(127, 127, 127);
					КонецЕсли;	
				ИначеЕсли ТипЗнч(ЭлементКнопкаПереключательПериода) = Тип("ДекорацияФормы") Тогда
					ЭлементКнопкаПереключательПериода.ЦветФона = Новый Цвет(242, 242, 242);
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;	
	КонецЦикла;
	
	Если ОтборПериодТип = Перечисления.Периодичность.День Тогда
		// Элементы.ГруппаКнопкиУстановитьПериодДень.ЦветФона 			= Новый Цвет(242, 242, 242);		
		Элементы.УстановитьПериодДень.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодДень.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
		// Элементы.ГруппаКнопкиУстановитьПериодНеделя.ЦветФона 			= Новый Цвет(242, 242, 242);		
		Элементы.УстановитьПериодНеделя.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодНеделя.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда
		// Элементы.ГруппаКнопкиУстановитьПериодМесяц.ЦветФона 			= Новый Цвет(242, 242, 242);		
		Элементы.УстановитьПериодМесяц.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодМесяц.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Час Тогда
		// Элементы.ГруппаКнопкиУстановитьПериодПроизвольный.ЦветФона 	= Новый Цвет(242, 242, 242);		
		Элементы.УстановитьПериодПроизвольный.ЦветТекста 				= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодПроизвольный.ЦветФона = Новый Цвет(100, 177, 230); 
	КонецЕсли;
	
	// Формируем текст периода
	КомандаВыбораПроизвольногоПериода = ЭтаФорма.Команды.Найти("УстановитьПериодПроизвольный");
	Если ОтборПериодЗначение.ДатаНачала = Дата(1,1,1) И ОтборПериодЗначение.ДатаОкончания = Дата(1,1,1) Тогда 
		Элементы.УстановитьПериодПроизвольный.Заголовок = Нстр("ru='< не указан >';en='< not specified >'");
		Если НЕ КомандаВыбораПроизвольногоПериода = Неопределено Тогда 
			КомандаВыбораПроизвольногоПериода.Подсказка = Нстр("ru='Щелкните для выбора произвольного периода';en='Click for of choice arbitrary period'");
		КонецЕсли;	
	Иначе
		Если ОтборПериодТип = Перечисления.Периодичность.День Тогда 
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ОтборПериодЗначение.ДатаНачала, "ДФ='д ММММ гггг'");
		ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда	
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ОтборПериодЗначение.ДатаНачала, "ДФ=d.MM.yy") + " - " + Формат(ОтборПериодЗначение.ДатаОкончания, "ДФ=dd.MM.yy");
		ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда	
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ОтборПериодЗначение.ДатаНачала, "ДФ='ММММ гггг'");
		ИначеЕсли ОтборПериодТип = Перечисления.Периодичность.Час Тогда  // Произвольный
			Если ЗначениеЗаполнено(ОтборПериодЗначение.ДатаНачала) И ЗначениеЗаполнено(ОтборПериодЗначение.ДатаОкончания) Тогда
				Если НачалоДня(ОтборПериодЗначение.ДатаНачала) = ОтборПериодЗначение.ДатаНачала И КонецДня(ОтборПериодЗначение.ДатаОкончания) = ОтборПериодЗначение.ДатаОкончания И КонецДня(ОтборПериодЗначение.ДатаНачала) = ОтборПериодЗначение.ДатаОкончания Тогда 
					Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ОтборПериодЗначение.ДатаНачала, "ДФ='д ММММ гггг'");				
				ИначеЕсли НачалоМесяца(ОтборПериодЗначение.ДатаНачала) = ОтборПериодЗначение.ДатаНачала И КонецМесяца(ОтборПериодЗначение.ДатаОкончания) = ОтборПериодЗначение.ДатаОкончания И КонецМесяца(ОтборПериодЗначение.ДатаНачала) = ОтборПериодЗначение.ДатаОкончания Тогда 
					Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ОтборПериодЗначение.ДатаНачала, "ДФ='ММММ гггг'");
				Иначе 	
					Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ОтборПериодЗначение.ДатаНачала, "ДФ=d.MM.yy") + " - " + Формат(ОтборПериодЗначение.ДатаОкончания, "ДФ=dd.MM.yy");			
				КонецЕсли;	
			Иначе 
				Если НЕ ЗначениеЗаполнено(ОтборПериодЗначение.ДатаНачала) Тогда 
					Элементы.УстановитьПериодПроизвольный.Заголовок = Нстр("ru='по ';en='to '") + Формат(ОтборПериодЗначение.ДатаОкончания, "ДФ=d.MM.yy");			
				ИначеЕсли НЕ ЗначениеЗаполнено(ОтборПериодЗначение.ДатаОкончания) Тогда 	
					Элементы.УстановитьПериодПроизвольный.Заголовок = Нстр("ru='с ';en='from '") + Формат(ОтборПериодЗначение.ДатаНачала, "ДФ=d.MM.yy");			
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли; 	
		Если НЕ КомандаВыбораПроизвольногоПериода = Неопределено Тогда 
			КомандаВыбораПроизвольногоПериода.Подсказка = Элементы.УстановитьПериодПроизвольный.Заголовок;
		КонецЕсли;			
	КонецЕсли;	
	
	УстановитьФокусЭлементаСервер();
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
// Процедура - Перейти заявки все
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПерейтиЗаявкиВсе(Команда)
	
	// Формируем параметры
	ПараметрыОтбора = Новый Структура();
	МассивСтруктурныхЕдиниц = Новый Массив;
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		МассивСтруктурныхЕдиниц.Добавить(ОтборСтруктурнаяЕдиница);
	КонецЕсли;	
	ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);
	Если ОтборАдресатСведенийТип = "Мои" Тогда 
		ОтборСотрудники = Новый Массив;
		ОтборСотрудники.Добавить(ТекущийПользователь);
		ПараметрыОтбора.Вставить("МассивМенеджеров"	, ОтборСотрудники);		
	ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
		// ОтборСотрудники = ПолучитьМассивОтобранныхСотрудников(Истина);
		// ПараметрыОтбора.Вставить("МассивМенеджеров"	, ОтборСотрудники);								
	ИначеЕсли ОтборАдресатСведенийТип = "ИзСписка" Тогда	
		ОтборСотрудники = ПолучитьМассивОтобранныхСотрудников(, Истина);
		ПараметрыОтбора.Вставить("МассивМенеджеров"	, ОтборСотрудники);				
	КонецЕсли;
	ПараметрыОтбора.Вставить("ОчиститьВсеОтборы", Ложь);
	
	// Ищем открытую форму
