#Область СлужебныйПрограммныйИнтерфейс

// Процедура - Обработка получения представления.
//
// Параметры:
//  Данные				 - 	 - 
//  Представление		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Представление = ПолучитьПредставлениеВзаимодействия(Данные);
	
КонецПроцедуры

// Функция - Получить представление взаимодействия.
//
// Параметры:
//  Взаимодействие	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеВзаимодействия(Взаимодействие)
	
	Если ПользователиСлужебныйПовтИсп.ЯзыкИнтерфейсаАнглийский() Тогда
		
		Если Взаимодействие.Ссылка = Справочники.ВидыВзаимодействий.Встреча Тогда
			Представление = "Meeting";
		ИначеЕсли Взаимодействие.Ссылка = Справочники.ВидыВзаимодействий.ЗвонокВходящий Тогда
			Представление = "Incoming call";
		ИначеЕсли Взаимодействие.Ссылка = Справочники.ВидыВзаимодействий.ЗвонокИсходящий Тогда
			Представление = "Outgoing call";
		ИначеЕсли Взаимодействие.Ссылка = Справочники.ВидыВзаимодействий.ОнлайнЗаявка Тогда
			Представление = "Online application";
		ИначеЕсли Взаимодействие.Ссылка = Справочники.ВидыВзаимодействий.Прочее Тогда
			Представление = "Other";
		Иначе
			Представление = Взаимодействие.Наименование;
		КонецЕсли;
		
	Иначе
		Представление = Взаимодействие.Наименование;
	КонецЕсли;	
	
	Возврат Представление;
	
КонецФункции

// Функция - Получить список взаимодействий.
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокВзаимодействий(ОбъектНазначения = "") Экспорт 
	
	СписокВзаимодействий = Новый СписокЗначений;
	
	ТаблицаВзаимодействий = ПолучитьТаблицуВзаимодействий();
	МассивНеиспользуемых = ПолучитьМассивНеиспользуемых(ОбъектНазначения);
	
	Для Каждого Взаимодействие Из ТаблицаВзаимодействий Цикл
		Если НЕ МассивНеиспользуемых.Найти(Взаимодействие.Ссылка) = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
			
		Картинка = ?(ЗначениеЗаполнено(Взаимодействие.ИндексКартинки), БиблиотекаКартинок["ВидВзаимодействия_" + Взаимодействие.ИндексКартинки], Неопределено);
		
		ПараметрыДанных = Новый Структура;
		ПараметрыДанных.Вставить("Взаимодействие"   		, Взаимодействие.Ссылка);
		ПараметрыДанных.Вставить("ВидВзаимодействия"		, Взаимодействие.ВидВзаимодействия);

		Если ОбъектНазначения = "Обращение" И Взаимодействие.Ссылка = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыВзаимодействий.ЗвонокИсходящий") Тогда 
			ПараметрыДанных.Вставить("ТемаПоУмолчанию"  	, НСтр("ru = 'Позвонить пациенту'; en = 'Call the patient'"));
			СписокВзаимодействий.Добавить(ПараметрыДанных	, НСтр("ru = 'Звонок'; en = 'Call'"),, Картинка);
		Иначе 
			ПараметрыДанных.Вставить("ТемаПоУмолчанию"  	, Взаимодействие.ТемаПоУмолчанию);
			СписокВзаимодействий.Добавить(ПараметрыДанных	, ПолучитьПредставлениеВзаимодействия(Взаимодействие),, Картинка);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокВзаимодействий;
	
КонецФункции

// Функция - Получить таблицу взаимодействий.
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуВзаимодействий(ВидВзаимодействия = Неопределено) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыВзаимодействий.Ссылка КАК Ссылка,
	|	ВидыВзаимодействий.Наименование КАК Наименование,
	|	ВидыВзаимодействий.ВидВзаимодействия КАК ВидВзаимодействия,
	|	ВидыВзаимодействий.ИндексКартинки КАК ИндексКартинки,
	|	ВидыВзаимодействий.ТемаПоУмолчанию КАК ТемаПоУмолчанию 
	|ИЗ
	|	Справочник.ВидыВзаимодействий КАК ВидыВзаимодействий
	|ГДЕ
	|	НЕ ВидыВзаимодействий.ПометкаУдаления
	|	И &УсловиеВидВзаимодействия
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование");
	
	Запрос.УстановитьПараметр("ВидВзаимодействия", ВидВзаимодействия);
	
	УсловиеВидВзаимодействия = ?(ЗначениеЗаполнено(ВидВзаимодействия), "И ВидыВзаимодействий.Ссылка В (&ВидВзаимодействия)", "");
	Запрос.Текст             = СтрЗаменить(Запрос.Текст, "И &УсловиеВидВзаимодействия", УсловиеВидВзаимодействия);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить массив неиспользуемых
//
// Параметры:
//  ОбъектНазначения - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивНеиспользуемых(ОбъектНазначения) 
	
	МассивНеиспользуемых = Новый Массив;
	
	Если НЕ ЗначениеЗаполнено(ОбъектНазначения) Тогда 
		Возврат МассивНеиспользуемых;
	КонецЕсли;
	
	Если ОбъектНазначения = "Обращение" Тогда
		ВидВстреча = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыВзаимодействий.Встреча");
		Если ЗначениеЗаполнено(ВидВстреча) Тогда 
			МассивНеиспользуемых.Добавить(ВидВстреча);
		КонецЕсли;                                
		ВидЗвонокВходящий = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыВзаимодействий.ЗвонокВходящий");
		Если ЗначениеЗаполнено(ВидЗвонокВходящий) Тогда 
			МассивНеиспользуемых.Добавить(ВидЗвонокВходящий);
		КонецЕсли;	
		ВидОнлайнЗаявка = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыВзаимодействий.ОнлайнЗаявка");
		Если ЗначениеЗаполнено(ВидОнлайнЗаявка) Тогда 
			МассивНеиспользуемых.Добавить(ВидОнлайнЗаявка);
		КонецЕсли;	
	ИначеЕсли ОбъектНазначения = "Пациент" Тогда
		ВидВстреча = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыВзаимодействий.Встреча");
		Если ЗначениеЗаполнено(ВидВстреча) Тогда 
			МассивНеиспользуемых.Добавить(ВидВстреча);
		КонецЕсли;                                
	КонецЕсли;	
	
	Возврат МассивНеиспользуемых;
	
КонецФункции

// Функция - Получить таблицу взаимодействий задач
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуВзаимодействийЗадач() Экспорт 
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗадачаИсполнителя.ВидВзаимодействияСправочник КАК ВидВзаимодействияСправочник
	               |ПОМЕСТИТЬ ТаблицаВзаимодействий
	               |ИЗ
	               |	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗадачаИсполнителя.ВидВзаимодействияСправочник
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаВзаимодействий.ВидВзаимодействияСправочник КАК Ссылка,
	               |	ВЫБОР
	               |		КОГДА ТаблицаВзаимодействий.ВидВзаимодействияСправочник = ЗНАЧЕНИЕ(Справочник.ВидыВзаимодействий.ПустаяСсылка)
	               |			ТОГДА ""< не указано >""
	               |		ИНАЧЕ ТаблицаВзаимодействий.ВидВзаимодействияСправочник.Наименование
	               |	КОНЕЦ КАК Наименование,
	               |	ВЫБОР
	               |		КОГДА ТаблицаВзаимодействий.ВидВзаимодействияСправочник = ЗНАЧЕНИЕ(Справочник.ВидыВзаимодействий.ПустаяСсылка)
	               |			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыВзаимодействия.ПустаяСсылка)
	               |		ИНАЧЕ ТаблицаВзаимодействий.ВидВзаимодействияСправочник.ВидВзаимодействия
	               |	КОНЕЦ КАК ВидВзаимодействия
	               |ИЗ
	               |	ТаблицаВзаимодействий КАК ТаблицаВзаимодействий
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Наименование";
	
	РезультатПакета = Запрос.ВыполнитьПакет();
	
	Возврат РезультатПакета[1].Выгрузить();
	
КонецФункции

// Функция - Получить массив видов взаимодействий
//
// Параметры:
//  МассивТиповВзаимодействий	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивВидовВзаимодействий(МассивТиповВзаимодействий = Неопределено) Экспорт
	
	ОтборПоТипуВзаимодействияОтключить = Ложь;
	
	Если МассивТиповВзаимодействий = Неопределено ИЛИ НЕ ТипЗнч(МассивТиповВзаимодействий) = Тип("Массив") ИЛИ (ТипЗнч(МассивТиповВзаимодействий) = Тип("Массив") И МассивТиповВзаимодействий.Количество() = 0) Тогда 
		ОтборПоТипуВзаимодействияОтключить = Истина;
		Если НЕ ТипЗнч(МассивТиповВзаимодействий) = Тип("Массив") Тогда 
			МассивТиповВзаимодействий = Новый Массив;
		КонецЕсли;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыВзаимодействий.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыВзаимодействий КАК ВидыВзаимодействий
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ОтборПоТипуВзаимодействияОтключить
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ВидыВзаимодействий.ВидВзаимодействия В (&МассивТиповВзаимодействий)
	|		КОНЕЦ
	|	И НЕ ВидыВзаимодействий.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ОтборПоТипуВзаимодействияОтключить"	, ОтборПоТипуВзаимодействияОтключить);
	Запрос.УстановитьПараметр("МассивТиповВзаимодействий"			, МассивТиповВзаимодействий);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция - Вернуть вид взаимодействия
//
// Параметры:
//  ТипВзаимодействия	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьВидВзаимодействия(ТипВзаимодействия) Экспорт
	
	ВидВзаимодействия = Справочники.ВидыВзаимодействий.ПустаяСсылка();

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВидыВзаимодействий.Ссылка КАК Ссылка,
	               |	ВидыВзаимодействий.Наименование КАК Наименование,
	               |	ВидыВзаимодействий.ВидВзаимодействия КАК ВидВзаимодействия,
	               |	ВидыВзаимодействий.Предопределенный КАК Предопределенный
	               |ИЗ
	               |	Справочник.ВидыВзаимодействий КАК ВидыВзаимодействий
	               |ГДЕ
	               |	ВидыВзаимодействий.ВидВзаимодействия = &ТипВзаимодействия";
	
	Запрос.УстановитьПараметр("ТипВзаимодействия", ТипВзаимодействия);
	
	ТаблицаВзаимодействий = Запрос.Выполнить().Выгрузить();
	
	Если НЕ ТаблицаВзаимодействий.Количество() = 0 Тогда 
		МассивСтрок = ТаблицаВзаимодействий.НайтиСтроки(Новый Структура("Наименование, Предопределенный", Строка(ТипВзаимодействия), Истина));
		Если МассивСтрок.Количество() = 0 Тогда 
			ВидВзаимодействия = ТаблицаВзаимодействий[0].Ссылка; 
		Иначе 
			ВидВзаимодействия = МассивСтрок[0].Ссылка; 
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВидВзаимодействия;
	
КонецФункции

// Процедура - Заполнить справочник виды взаимодействий
//
Процедура ЗаполнитьСправочникВидыВзаимодействий() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	МассивПодготовленныхВзаимодействий 	= Новый Массив;
	МассивИменПредопределенныхЗначений 	= Метаданные.Справочники.ВидыВзаимодействий.ПолучитьИменаПредопределенных();
	Для Каждого ИмяПредопреленногоЗначения Из МассивИменПредопределенныхЗначений Цикл 
		ВидВзаимодействия = АктуализироватьПредопределенныйВидВзаимодейтсвия(ИмяПредопреленногоЗначения);
		Если ЗначениеЗаполнено(ВидВзаимодействия) И МассивПодготовленныхВзаимодействий.Найти(ВидВзаимодействия) = Неопределено Тогда 
			МассивПодготовленныхВзаимодействий.Добавить(ВидВзаимодействия);
		КонецЕсли;	
	КонецЦикла;
	
	// Деактивируем неактуальные
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивПодготовленныхВзаимодействий", МассивПодготовленныхВзаимодействий);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВидыВзаимодействий.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ВидыВзаимодействий КАК ВидыВзаимодействий
	               |ГДЕ
	               |	ВидыВзаимодействий.Предопределенный
	               |	И НЕ ВидыВзаимодействий.Ссылка В(&МассивПодготовленныхВзаимодействий)";
	
	МассивНеАктуальныхПредопределенных = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	МетаданныеСправочника 		= Метаданные.Справочники.ВидыВзаимодействий;
	ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
	
	Для Каждого НеАктуальныйВидВзаимодействия Из МассивНеАктуальныхПредопределенных Цикл 
		НеАктуальныйВидВзаимодействия_Объект = НеАктуальныйВидВзаимодействия.ПолучитьОбъект();
		//НеАктуальныйВидВзаимодействия_Объект.Предопределенный 			= Ложь;
		НеАктуальныйВидВзаимодействия_Объект.ИмяПредопределенныхДанных 	= "";
		НеАктуальныйВидВзаимодействия_Объект.ПометкаУдаления 			= Истина;
		
		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НеАктуальныйВидВзаимодействия_Объект);
		Исключение
			ШаблонКомментария = НСтр("ru = 'Не удалось деактивировать предопределенный вид взаимодейтсвия ""%1"" в справочнике ""%2""
			|по причине: %3'");
			
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонКомментария,
			Строка(НеАктуальныйВидВзаимодействия_Объект.Ссылка),
			ПредставлениеСправочника,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Предупреждение,
			МетаданныеСправочника,
			НеАктуальныйВидВзаимодействия_Объект.Ссылка,
			Комментарий);
		КонецПопытки;
	КонецЦикла;	
	
	//ЕстьПредопределнныеДанные 			= Истина;	
	//ЗначенияИменПеречисления 			= Новый Соответствие;
	//ЗначенияИменПеречисления.Вставить(Перечисления.ВидыВзаимодействия.Встреча			, Метаданные.Перечисления.ВидыВзаимодействия.ЗначенияПеречисления.Встреча.Имя);
	//ЗначенияИменПеречисления.Вставить(Перечисления.ВидыВзаимодействия.ЗвонокВходящий	, Метаданные.Перечисления.ВидыВзаимодействия.ЗначенияПеречисления.ЗвонокВходящий.Имя);
	//ЗначенияИменПеречисления.Вставить(Перечисления.ВидыВзаимодействия.ЗвонокИсходящий	, Метаданные.Перечисления.ВидыВзаимодействия.ЗначенияПеречисления.ЗвонокИсходящий.Имя);
	//ЗначенияИменПеречисления.Вставить(Перечисления.ВидыВзаимодействия.ОнлайнЗаявка		, Метаданные.Перечисления.ВидыВзаимодействия.ЗначенияПеречисления.ОнлайнЗаявка.Имя);
	//ЗначенияИменПеречисления.Вставить(Перечисления.ВидыВзаимодействия.Прочее			, Метаданные.Перечисления.ВидыВзаимодействия.ЗначенияПеречисления.Прочее.Имя);

	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//               |	ВидыВзаимодействий.Ссылка КАК Ссылка,
	//               |	ВидыВзаимодействий.Наименование КАК Наименование,
