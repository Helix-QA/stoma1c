// Процедура получает количество строк в динамическом списке .
//
Процедура УстановитьЗаголовокКоличествоЗадач(КоличествоЗадач, ЕстьОтборы = Ложь)
		
	Если КоличествоЗадач > 0 Тогда
		
		Если ЕстьОтборы Тогда
			
			Строка = СтрокаСЧислом(Нстр("ru = ';Найдена: %1 задача;;Найдено: %1 задачи;Найдено: %1 задач;Найдено: %1 задачи'; en = ';Found: %1 task;;;;Found: %1 tasks'"),
			КоличествоЗадач,
			ВидЧисловогоЗначения.Количественное,
			НСтр("ru='L=ru'; en='L=en'")); 
		Иначе
			Строка = Нстр("ru = 'Всего: '; en = 'Total: '") + КоличествоЗадач;
			
		КонецЕсли;
		
		Элементы.КоличествоОтобранныхЗадач.Заголовок = "(" + Строка + ")";		
	Иначе		
		Элементы.КоличествоОтобранныхЗадач.Заголовок = Нстр("ru = '(Задачи не найдены)'; en = '(Tasks not found)'");		
	КонецЕсли;
	
КонецПроцедуры

