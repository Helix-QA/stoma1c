// Процедура - Установить видимость элементов
//
Процедура УстановитьСвойстваОтображенияЭлементов()
	
	// Управление свойствами элементов-переключателей устанавливающих отбор по периоду
	Для Каждого ЭлементГруппаПереключательПериода Из Элементы.ГруппаПереключателиПериодов.ПодчиненныеЭлементы Цикл 
		ЭлементГруппаПереключательПериода.ЦветФона = Новый Цвет();
		Если ТипЗнч(ЭлементГруппаПереключательПериода) = Тип("ГруппаФормы") Тогда 
			Для Каждого ЭлементКнопкаПереключательПериода Из ЭлементГруппаПереключательПериода.ПодчиненныеЭлементы Цикл
				Если ТипЗнч(ЭлементКнопкаПереключательПериода) = Тип("КнопкаФормы") Тогда
					Если НЕ ЭлементКнопкаПереключательПериода.Имя = "УстановитьПериодПроизвольный" Тогда 
						ЭлементКнопкаПереключательПериода.ЦветТекста = Новый Цвет(127, 127, 127);
					КонецЕсли;	
				ИначеЕсли ТипЗнч(ЭлементКнопкаПереключательПериода) = Тип("ДекорацияФормы") Тогда
					ЭлементКнопкаПереключательПериода.ЦветФона = Новый Цвет(242, 242, 242);
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;	
	КонецЦикла;
	
	Если ВыбранныйПериод = 0 Тогда
		Элементы.УстановитьПериодДень.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодДень.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ВыбранныйПериод = 1 Тогда
		Элементы.УстановитьПериодЧетыреДня.ЦветТекста 					= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериод4Дня.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ВыбранныйПериод = 2 Тогда
		Элементы.УстановитьПериодНеделя.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодНеделя.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ВыбранныйПериод = 3 Тогда
		Элементы.УстановитьПериодМесяц.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныеПериодМесяц.ЦветФона 		= Новый Цвет(100, 177, 230); 
	ИначеЕсли ВыбранныйПериод = 4 Тогда
		Элементы.УстановитьПериодПроизвольный.ЦветТекста 				= Новый Цвет();	
		Элементы.ДекорацияУказательВыбранныеПериодПроизвольный.ЦветФона = Новый Цвет(100, 177, 230); 
	КонецЕсли;
	
	Если РежимОтображенияФормы = 0 Тогда
		
		Элементы.ПерейтиРежимСписок.ЦветТекста 							= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныйРежимСписок.ЦветФона 		= Новый Цвет(100, 177, 230); 
		
		Элементы.ПерейтиРежимКалендарь.ЦветТекста 						= Новый Цвет(127, 127, 127);
		Элементы.ДекорацияУказательВыбранныйРежимКалендарь.ЦветФона 	= Новый Цвет(242, 242, 242); 
		
	ИначеЕсли РежимОтображенияФормы = 1 Тогда
		
		Элементы.ПерейтиРежимКалендарь.ЦветТекста 						= Новый Цвет();
		Элементы.ДекорацияУказательВыбранныйРежимКалендарь.ЦветФона 	= Новый Цвет(100, 177, 230); 
		
		Элементы.ПерейтиРежимСписок.ЦветТекста 							= Новый Цвет(127, 127, 127);
		Элементы.ДекорацияУказательВыбранныйРежимСписок.ЦветФона 		= Новый Цвет(242, 242, 242); 
		
	КонецЕсли;
	
	СформироватьТекстПериода();
	
	Элементы.УстановитьПериодПроизвольный.Доступность 	= НЕ РежимОтображенияФормы = 1;
	
	Элементы.Изменить.Видимость = РольДоступна(Метаданные.Роли.ПолныеПрава);
	//Элементы.ГруппаКоманднаяПанель.Видимость = Ложь;
	
КонецПроцедуры

