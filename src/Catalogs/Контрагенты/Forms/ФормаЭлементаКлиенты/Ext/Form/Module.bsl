	УстановитьАктивностьПереключателямSmsPushMessage();

	Если НЕ ТипСообщенияПользователю = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда	
		ВзаимодействиеSMSОбновитьСтатусВведеныхСимволов();
	КонецЕсли;
		
	СоздатьSMSРассылкуНаКлиенте();
	
