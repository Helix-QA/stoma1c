&НаКлиенте
// Процедура, выполняет корректировку времени
//
Процедура КорректировкаВремениЗадачи(ВремяНачало, ЭлементПланировщика)
	
	ЧислоМинут = Минута(ВремяНачало);
	
	Если ЧислоМинут > 7 И ЧислоМинут < 23 Тогда
		ЧислоМинут = 15;
	ИначеЕсли ЧислоМинут > 22 И ЧислоМинут < 38 Тогда
		ЧислоМинут = 30;
	ИначеЕсли ЧислоМинут > 37 и ЧислоМинут < 52 Тогда
		ЧислоМинут = 45
	ИначеЕсли ЧислоМинут < 8 Тогда
		ЧислоМинут = 0;
	Иначе
		ЧислоМинут = 60;
	КонецЕсли;
	
	ВремяНачало = ВремяНачало - (Минута(ВремяНачало) * 60 + Секунда(ВремяНачало)) + (ЧислоМинут * 60);
	
	ЭлементПланировщика.Начало = ВремяНачало;
	ЭлементПланировщика.Конец  = ВремяНачало + 3600; 	
	
КонецПроцедуры

