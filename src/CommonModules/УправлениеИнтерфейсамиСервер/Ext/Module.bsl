	//		ЦветФона 	= ПолучитьЦветHEX(ЗначениеИзСтрокиВнутр(ЦветФона)); 
	//		ЦветТекста 	= "#000000";
	//	Иначе
	//		ЦветФона = Новый Цвет;  
	//		ЦветТекста 	= "#8b8484";
	//	КонецЕсли;
	//	
	//	БлокСтатусаПриема = "<span style='padding: 5px;'> <i style='background: {ЦветФона};	border-radius : 3px; color: {ЦветТекста}; font-style: normal;';> {Статус} </i></span>";
	//		
	//	БлокСтатусаПриема = СтрЗаменить(БлокСтатусаПриема	, "{ЦветФона}"	, ЦветФона); 
	//	БлокСтатусаПриема = СтрЗаменить(БлокСтатусаПриема	, "{ЦветТекста}", ЦветТекста);
	//	БлокСтатусаПриема = СтрЗаменить(БлокСтатусаПриема	, "{Статус}"	, СтатусПриема);	
	// КонецЕсли;
		
	ПредставлениеШапкиБлока = СтрШаблон("Прием от %1 - %2 <b>%3</b> %4" ,
										Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'"),
										ВремяПриемаВМинутах,
										ПредставлениеСотрудника,
										БлокМеткиМедСтрахования);
								
	БлокШаблон = "<i style= 'color: #000; font-size: 12px; font-style: normal;'> {Текст} </i>";
			
	ПредставлениеШапкиБлока = СтрЗаменить(БлокШаблон, "{Текст}"	, ПредставлениеШапкиБлока);
										
	ВремЗапасы 			= Прием.Лечение.Выгрузить().Скопировать(); 
	ВремТаблицаЗапасов 	= ВремЗапасы.Скопировать();
	ВремТаблицаЗапасов.Свернуть("Номенклатура");               
	
	ПредставлениеНоменклатура 	= "";	
	МассивНоменклатур 			= ВремТаблицаЗапасов.ВыгрузитьКолонку("Номенклатура"); 		
	
	Для Каждого Номенклатура Из МассивНоменклатур Цикл
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			МассивНоменклатур.Удалить(МассивНоменклатур.Найти(Номенклатура));	
		КонецЕсли;
	КонецЦикла;
	
	КоличествоСтрок   = МассивНоменклатур.Количество();
			
	Для Каждого Номенклатура Из МассивНоменклатур Цикл
		
		МассивСтрокТаблицы  = ВремЗапасы.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура)); 
		КоличествоСтрок    	= МассивСтрокТаблицы.Количество();		
		СтрокаЗубов 		= "";
		Для Счетчик = 0 По КоличествоСтрок - 1 Цикл 	
				
			Если ЗначениеЗаполнено(МассивСтрокТаблицы[Счетчик].Зуб) Тогда 
				
				Зуб = МассивСтрокТаблицы[Счетчик].Зуб;	
				Зуб = ?(Зуб <> Перечисления.Зубы.ВсяПолость, "<b>" + Зуб + "</b>", Зуб); // Номера зубов будут жирным. 
				
				СтрокаЗубов = СтрокаЗубов + Зуб;	
				СтрокаЗубов = ?(Счетчик <> КоличествоСтрок - 1, СтрокаЗубов + ", ", СтрокаЗубов);
							
			КонецЕсли;  
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(СтрокаЗубов) Тогда
			ПредставлениеНоменклатура =  ПредставлениеНоменклатура + СтрокаЗубов + " - " + Строка(Номенклатура) + Символы.ПС;
		Иначе
			ПредставлениеНоменклатура =  ПредставлениеНоменклатура + Строка(Номенклатура) + Символы.ПС;
		КонецЕсли; 
		
	КонецЦикла;  
	
	Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	
	СуммыДокумента	= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Прием, "СуммаДокумента, СуммаОплачено"); 
	Сумма 			= СтрШаблон("Сумма: %1 %2", 
								СуммыДокумента.СуммаДокумента,
								Валюта);
								
								
	СуммаОплачено	= СтрШаблон("Оплачено: %1 %2", 
								СуммыДокумента.СуммаОплачено,
								Валюта); 
								
	Если СуммыДокумента.СуммаДокумента > СуммыДокумента.СуммаОплачено Тогда 
		БлокОплачено = "<span><s style='background: rgb(255,200,200);border-radius: 5px; padding: 1px 7px 1px 7px; text-decoration: none;'=''>{ПредставлениеСуммаОплачено}</s> </span>";	
		БлокОплачено = СтрЗаменить(БлокОплачено, "{ПредставлениеСуммаОплачено}", СуммаОплачено);	
	Иначе
		БлокОплачено = СуммаОплачено;	
	КонецЕсли;	
	
	ПредставлениеСумм = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 			%2'"),
	Сумма,
	БлокОплачено);	
	
	Возврат ПредставлениеНоменклатура + Символы.ПС + ПредставлениеСумм;
	
КонецФункции 

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеНарядЗаказа(СтрокаТЗ, Статус, Запланировано = Ложь, ПредставлениеШапкиБлока)
	
	НарядЗаказ = СтрокаТЗ.Взаимодействие;
					
	//Статус = ?(Статус = Истина, "(Закрыт)", "(Открыт)");
	
	ПредставлениеШапкиБлока = СтрШаблон("Наряд заказ от %1" ,
										Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'"));
			
	ВремЗапасы = НарядЗаказ.Запасы.Выгрузить().Скопировать(); 
	ВремЗапасы.Свернуть("Номенклатура");                 
	
	ПредставлениеНоменклатура 	= "";	
	МассивНоменклатур 			= ВремЗапасы.ВыгрузитьКолонку("Номенклатура"); 		
	
	Для Каждого Номенклатура Из МассивНоменклатур Цикл
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			МассивНоменклатур.Удалить(МассивНоменклатур.Найти(Номенклатура));	
		КонецЕсли;
	КонецЦикла;
	
	КоличествоСтрок   = МассивНоменклатур.Количество();
			
	Для Счетчик = 0 По КоличествоСтрок - 1 Цикл 	
						
		Если Счетчик <> КоличествоСтрок - 1 Тогда                // Это не последний элемент.
			ПредставлениеНоменклатура = ПредставлениеНоменклатура + МассивНоменклатур[Счетчик] + ", " + Символы.ПС; 
		Иначе 
			ПредставлениеНоменклатура = ПредставлениеНоменклатура + МассивНоменклатур[Счетчик] + Символы.ПС; 	 
		КонецЕсли; 
			
	КонецЦикла; 
	
	СуммыДокумента = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(НарядЗаказ, "СуммаПродажи, СуммаОплаченоПродажи");
	
	Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	
	СуммаПродажи = СтрШаблон("Сумма наряд заказа: %1 %2", 
	СуммыДокумента.СуммаПродажи,
	Валюта);
	
	Если ЗначениеЗаполнено(СуммыДокумента.СуммаОплаченоПродажи) Тогда							
		СуммаАванса	= СтрШаблон("Сумма аванса: %1 %2", 
		СуммыДокумента.СуммаОплаченоПродажи,
		Валюта);
	Иначе
		СуммаАванса = "";
	КонецЕсли;
		
	ПредставлениеСумм = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 			%2'"),
	СуммаПродажи,
	СуммаАванса);

	Возврат ПредставлениеНоменклатура + Символы.ПС + ПредставлениеСумм;
	
КонецФункции

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПланаЛечения(СтрокаТЗ, Статус, Запланировано = Ложь, ПредставлениеШапкиБлока)
	
	ПланЛечения = СтрокаТЗ.Взаимодействие;
	
	ПолисМедСтрахования = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ПланЛечения, "ПолисМедСтрахования"); 
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда
		
		РеквизитыПолисаМедСтрахования 	= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПолисМедСтрахования, "СтраховаяКомпания, Договор");
		РеквизитыКонтрагента 			= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(РеквизитыПолисаМедСтрахования.СтраховаяКомпания, "ЦветФонаМетки, ЦветТекстаБелый, КраткоеНаименование");
		ПрограммаСтрахования 			= ОбщегоНазначения.ПолучитьЗначениеРеквизита(РеквизитыПолисаМедСтрахования.Договор, "ПрограммаСтрахования");
				
		ФонМетки 	= ?(ЗначениеЗаполнено(РеквизитыКонтрагента.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(РеквизитыКонтрагента.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
		ФонМетки 	= ПолучитьЦветHEX(ФонМетки);
		ЦветТекста  = ?(РеквизитыКонтрагента.ЦветТекстаБелый, "rgb(255,255,255)", "rgb(0,0,0)");	
		Заголовок	= РеквизитыКонтрагента.КраткоеНаименование;
		
		БордерРадиус = ?(ЗначениеЗаполнено(ПрограммаСтрахования), "border-radius: 3px 0 0 3px" , "border-radius: 3px");
		
		БлокМеткиМедСтрахования = "<span > <i style='background: {ФонМетки}; {БордерРадиус}; color:{ЦветТекста}; font-style: normal';> {Заголовок} </i></span>";
		
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{ФонМетки}"		, ФонМетки);  
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{ЦветТекста}"	, ЦветТекста);
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{Заголовок}"	, Заголовок);
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{БордерРадиус}"	, БордерРадиус);
	
		Если ЗначениеЗаполнено(ПрограммаСтрахования) Тогда
			
			ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(ПрограммаСтрахования);
	        
			ФонПрограммыСтрахования			= ПолучитьЦветHEX(ДанныеПрограммыСтрахования.ЦветФона);
			ЗаголовокПрограммыСтрахования 	= ДанныеПрограммыСтрахования.Текст;
			ЦветТекста						= ПолучитьЦветHEX(ДанныеПрограммыСтрахования.ЦветТекста);
			
			БлокВидДоговора = "<span> <i style='background: {ФонПрограммыСтрахования}; border-radius: 0 3px 3px 0; color: {ЦветТекста}; font-style: normal';> {ЗаголовокПрограммыСтрахования} </i> </span>";  
			
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ФонВидДоговора}"				 , ФонПрограммыСтрахования);
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ЗаголовокПрограммыСтрахования}" , ЗаголовокПрограммыСтрахования);
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ЦветТекста}"					 , ЦветТекста);
			
			БлокМеткиМедСтрахования = БлокМеткиМедСтрахования + Символы.ПС + БлокВидДоговора;
		КонецЕсли; 
	Иначе
		БлокМеткиМедСтрахования = "";	
	КонецЕсли;

	Статус = ?(ЗначениеЗаполнено(Статус), "(" + Статус + ")", "");
	
	ДатаДокумента = Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'");
		
	ПредставлениеШапкиБлока = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='План лечения от %1 %2 %3'"),
	ДатаДокумента,
	Статус,
	БлокМеткиМедСтрахования);
	
	// Представление табличной части номенклатуры  
	
	ВремЗапасы = ПланЛечения.Лечение.Выгрузить().Скопировать(); 

	ВремТаблицаЗапасов 	= ВремЗапасы.Скопировать();
	ВремТаблицаЗапасов.Свернуть("Номенклатура");               
	
	ПредставлениеНоменклатура 	= "";	
	МассивНоменклатур 			= ВремТаблицаЗапасов.ВыгрузитьКолонку("Номенклатура"); 		
	
	Для Каждого Номенклатура Из МассивНоменклатур Цикл
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			МассивНоменклатур.Удалить(МассивНоменклатур.Найти(Номенклатура));	
		КонецЕсли;
	КонецЦикла;
	
	КоличествоСтрок   = МассивНоменклатур.Количество();
			
	Для Каждого Номенклатура Из МассивНоменклатур Цикл
		
		МассивСтрокТаблицы  = ВремЗапасы.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура)); 
		КоличествоСтрок    	= МассивСтрокТаблицы.Количество();		
		СтрокаЗубов 		= "";
		Для Счетчик = 0 По КоличествоСтрок - 1 Цикл 	
				
			Если ЗначениеЗаполнено(МассивСтрокТаблицы[Счетчик].Зуб) Тогда 
				
				Если Счетчик <> КоличествоСтрок - 1 Тогда                // Это не последний элемент.
					СтрокаЗубов = СтрокаЗубов + МассивСтрокТаблицы[Счетчик].Зуб + ", "; 
				Иначе 
					СтрокаЗубов = СтрокаЗубов + МассивСтрокТаблицы[Счетчик].Зуб;	 
				КонецЕсли; 
				
			КонецЕсли;  
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(СтрокаЗубов) Тогда
			ПредставлениеНоменклатура =  ПредставлениеНоменклатура + "Зубы: " + СтрокаЗубов + " - " + Строка(Номенклатура) + Символы.ПС;
		Иначе
			ПредставлениеНоменклатура =  ПредставлениеНоменклатура + Строка(Номенклатура) + Символы.ПС;
		КонецЕсли; 
		
	КонецЦикла;
	
	Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	
	СуммыДокумента = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПланЛечения, "СуммаДокумента, СуммаОплачено");
	
	Сумма 			= СтрШаблон("Сумма: %1 %2", 
	СуммыДокумента.СуммаДокумента,
	Валюта);
	
	Если ЗначениеЗаполнено(СуммыДокумента.СуммаОплачено) Тогда
		СуммаАванса		= СтрШаблон("Сумма аванса: %1 %2", 
		СуммыДокумента.СуммаОплачено,
		Валюта);
	Иначе
		СуммаАванса = "";
	КонецЕсли;

								
	ПредставлениеСумм = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 			%2'"),
			Сумма,
			СуммаАванса);
	
	Возврат ПредставлениеНоменклатура + Символы.ПС + ПредставлениеСумм;
	
КонецФункции

// Функция, возвращает представление профосмотра.
//
Функция ПолучитьПредставлениеПрофосмотра(СтрокаТЗ, Статус, Запланировано = Ложь, ПредставлениеШапкиБлока)
	
	// Статус = ?(ЗначениеЗаполнено(Статус), "(" + Статус + ")", "");
	
	Дата = Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'");
		
	ПредставлениеШапкиБлока = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1'"),
	Дата
	);
	
	Если Статус = Перечисления.СтатусыПрофосмотров.Отказался Тогда 
		ПредставлениеЗаписиПрофосмотра = "Отказался от профосмотра";
		ПредставлениеЗаписиПрофосмотра = ?(ЗначениеЗаполнено(СтрокаТЗ.Начало), ПредставлениеЗаписиПрофосмотра + " " + Формат(СтрокаТЗ.Начало, "ДФ=dd.MM.yyyy"), ПредставлениеЗаписиПрофосмотра);
	Иначе	
		Если ЗначениеЗаполнено(СтрокаТЗ.ВидОсмотра) Тогда
			Если СтрокаТЗ.ВидОсмотра = Перечисления.ВидыОсмотров.Направление Тогда
				ПредставлениеЗаписиПрофосмотра = "Направление на консультацию";
			ИначеЕсли СтрокаТЗ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда
				ПредставлениеЗаписиПрофосмотра = "Повторный прием";
			ИначеЕсли СтрокаТЗ.ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр Тогда
				ПредставлениеЗаписиПрофосмотра = "Запланирован профосмотр";
			ИначеЕсли СтрокаТЗ.ВидОсмотра = Перечисления.ВидыОсмотров.ОчередьНаЗапись Тогда
				ПредставлениеЗаписиПрофосмотра = "Очередь на запись";	
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТЗ.Дата) Тогда
				ПредставлениеЗаписиПрофосмотра = ?(ЗначениеЗаполнено(ПредставлениеЗаписиПрофосмотра), ПредставлениеЗаписиПрофосмотра + " ", ПредставлениеЗаписиПрофосмотра);	
				ПредставлениеЗаписиПрофосмотра = ПредставлениеЗаписиПрофосмотра + Формат(СтрокаТЗ.Дата, "ДФ=dd.MM.yyyy"); 
			КонецЕсли;
			
			ПредсталениеСотрудника = ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "");
			
			// Представление специализации пишем в поле Взаимодействие.
			ПредсталениеСотрудника = ?(ЗначениеЗаполнено(ПредсталениеСотрудника),
			ПредсталениеСотрудника, 
			?(ЗначениеЗаполнено(СтрокаТЗ.Взаимодействие), СтрокаТЗ.Взаимодействие, "")); 
			
			Если ЗначениеЗаполнено(ПредсталениеСотрудника) Тогда
				ПредставлениеЗаписиПрофосмотра = ?(ЗначениеЗаполнено(ПредставлениеЗаписиПрофосмотра), ПредставлениеЗаписиПрофосмотра + " к ", ПредставлениеЗаписиПрофосмотра);	
				ПредставлениеЗаписиПрофосмотра = ПредставлениеЗаписиПрофосмотра + ПредсталениеСотрудника; 	
			КонецЕсли;
			
		Иначе
			ПредставлениеЗаписиПрофосмотра = "Вызвать на профосмотр";
			ПредставлениеЗаписиПрофосмотра = ?(ЗначениеЗаполнено(СтрокаТЗ.Начало), ПредставлениеЗаписиПрофосмотра + " " + Формат(СтрокаТЗ.Начало, "ДФ=dd.MM.yyyy"), ПредставлениеЗаписиПрофосмотра);
		КонецЕсли;
	
	КонецЕсли;
				
	Комментарий = ?(ЗначениеЗаполнено(СтрокаТЗ.Комментарий), Символы.ПС + СтрокаТЗ.Комментарий, "");
	
	Возврат ПредставлениеЗаписиПрофосмотра + Комментарий;
	
КонецФункции 

// Функция - Получить представление обращения.
//
// Параметры:
//  СтрокаТЗ				 - 	 - 
//  Статус					 - 	 - 
//  Запланировано			 - 	 - 
//  ПредставлениеШапкиБлока	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеОбращения(СтрокаТЗ, Статус, Запланировано = Ложь, ПредставлениеШапкиБлока)
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(МАКСИМУМ(ЗаявкиИсторияИзмененияСтатусов.Дата), ЗаявкиИсторияИзмененияСтатусов.Ссылка.ДатаСоздания) КАК ДатаСтатуса,
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.Статус КАК Статус,
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.ВнешняяСистема КАК ВнешняяСистема,
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.КаналПривлечения КАК КаналПривлечения,
	|	ЗаявкиИсторияИзмененияСтатусов.Автор КАК Автор
	|ИЗ
	|	Справочник.Заявки.ИсторияИзмененияСтатусов КАК ЗаявкиИсторияИзмененияСтатусов
	|ГДЕ
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка = &Заявка
	|	И ЗаявкиИсторияИзмененияСтатусов.ПереходВСтатус.Ссылка = ЗаявкиИсторияИзмененияСтатусов.Ссылка.Статус
	|                                             
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.Статус,
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.ВнешняяСистема,
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.КаналПривлечения,
	|	ЗаявкиИсторияИзмененияСтатусов.Ссылка.ДатаСоздания,
	|	ЗаявкиИсторияИзмененияСтатусов.Автор";
	
	Запрос.УстановитьПараметр("Заявка", СтрокаТЗ.Взаимодействие);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Статус 				= Выборка.Статус;
		ДатаСтатуса 		= Формат(Выборка.ДатаСтатуса,"ДЛФ=DT");
		ВнешняяСистема 		= Строка(Выборка.ВнешняяСистема);
		КаналПривлечения 	= Строка(Выборка.КаналПривлечения);
		Автор				= Справочники.сотрудники.ПредставлениеФИОСотрудника(Выборка.Автор);		
	Иначе
		Статус 				= СтрокаТЗ.Статус;
		ДатаСтатуса 		= СтрокаТЗ.Дата;
		ВнешняяСистема	 	= ""; 
		КаналПривлечения 	= "";
	КонецЕсли; 
	
	Комментарий 		= СтрокаТЗ.Комментарий;
	ПредставлениеЗаписи = "";
	
	ПредставлениеЗаписи = ?(ЗначениеЗаполнено(Комментарий)		, ПредставлениеЗаписи + Комментарий + Символы.ПС, ПредставлениеЗаписи);
	ПредставлениеЗаписи = ?(ЗначениеЗаполнено(ВнешняяСистема)	, ПредставлениеЗаписи + "Внешняя система - " + ВнешняяСистема + Символы.ПС, ПредставлениеЗаписи);
	ПредставлениеЗаписи = ?(ЗначениеЗаполнено(КаналПривлечения)	, ПредставлениеЗаписи + "Канал привлечения - " + КаналПривлечения + Символы.ПС, ПредставлениеЗаписи);
	
	ПредставлениеОбработки = ?(Статус = Перечисления.СтатусыЗаявок.НеОбработана, "создано", "обработано");
	
	ПредставлениеШапкиБлока = СтрШаблон("Обращение %1 в %2 %3", ПредставлениеОбработки, ДатаСтатуса, "<b>" + Автор + "</b>");
	
	ПредставлениеШапкиБлока = СтрШаблон("<i style= 'font-size: 12px; font-style: normal;'> %1 </i>", ПредставлениеШапкиБлока);
	
	Возврат ПредставлениеЗаписи;
	
КонецФункции

// Функция, возвращает основное представление записи .
//
Функция ПолучитьОсновноеПредставлениеЗаписи(СтрокаТЗ, Статус)
	
	Запись = СтрокаТЗ.Взаимодействие;
	Представление = "";
	
	Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();	

	Сумма 				= "";
	СуммаОплачено 		= "";  
	Продолжительность 	= "";
	
	Если СтрокаТЗ.ТипСобытия = "Прием" 
		Или СтрокаТЗ.ТипСобытия = "ПланЛечения"
		Или СтрокаТЗ.ТипСобытия = "НарядЗаказ"  Тогда
		
		Сумма 			= СтрШаблон("%1 %2", 
								ОбщегоНазначения.ПолучитьЗначениеРеквизита(Запись, "СуммаДокумента"),
								Валюта);
	КонецЕсли;						   
	
	Если СтрокаТЗ.ТипСобытия = "Прием" 
		Или СтрокаТЗ.ТипСобытия = "ПланЛечения"  Тогда
		
		СуммаОплачено	= СтрШаблон("Оплачено: %1 %2", 
								ОбщегоНазначения.ПолучитьЗначениеРеквизита(Запись, "СуммаОплачено"),
	                         	Валюта); 
	КонецЕсли;
	
	Если СтрокаТЗ.ТипСобытия = "Прием" Тогда 
		Статус = ?(Запись.Проведен, "Проведен", "Отложен");
		
		Если Запись.Проведен И ЗначениеЗаполнено(Запись.ВремяНачалаПриема) И ЗначениеЗаполнено(Запись.ВремяОкончанияПриема) Тогда 	
			Продолжительность = Строка(Окр((Запись.ВремяОкончанияПриема - Запись.ВремяНачалаПриема)/60, 0, РежимОкругления.Окр15как20)) + " " + "мин.";	
		КонецЕсли; 
		
	КонецЕсли;
	
	Статус = СтрЗаменить(Статус, "(", ""); 
	Статус = СтрЗаменить(Статус, ")", "");
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='(%1) %2 %3 %4'"),
	Статус,
	Продолжительность,
	Сумма,
	СуммаОплачено);
	
	Возврат Представление;
	
КонецФункции

// Функция изменяет устанавливает в значение реквизита - цвет фона.
//
Функция ПолучитьЦветHEX(Цвет)
	
	Если Цвет.Вид = ВидЦвета.ЭлементСтиля Тогда 
		
		Возврат СокрЛП(ПолучитьЦветИзСтиляПлатформы(Цвет));
		
	Иначе
		
		ТекстХТМЛДокумента = "";
		ФорматированныйДокумент = Новый ФорматированныйДокумент; 
		ФорматированныйДокумент.Добавить("ОпределениеЦвета", Тип("ТекстФорматированногоДокумента")); 
		ФорматированныйДокумент.Элементы[0].Элементы[0].ЦветФона = Цвет; 
		ФорматированныйДокумент.ПолучитьHTML(ТекстХТМЛДокумента, Новый Структура); 
		НомерСимволаЦвета = Найти(ТекстХТМЛДокумента, "background-color: #");
		
		ЦветРезультатHex  = Сред(ТекстХТМЛДокумента, НомерСимволаЦвета+19, 6);		
		
		Возврат "#" + ЦветРезультатHex;
		
	КонецЕсли;
		
КонецФункции

// Функция - Получить цвет записи по статусу.
//
// Параметры:
//  Статус				 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветЗаписиПоСтатусуСобытия(Статус, СтруктурнаяЕдиница)
	
	ТаблицаНастроек = РегистрыСведений.НастройкиИнтерфейсов.ПолучитьНастройкиЦветаЖурналаЗаписи(СтруктурнаяЕдиница);

	Если Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда
		Возврат ТаблицаНастроек.ЦветПриемНачат;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда
		Возврат ТаблицаНастроек.ЦветПриемНеСостоялся;
    ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда
		Возврат ТаблицаНастроек.ЦветПриемОкончен;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
		Возврат ТаблицаНастроек.ЦветПриемОтменен;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.НеПодтверждена Тогда
		Возврат ТаблицаНастроек.ЦветНеПодтверждена;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда
		Возврат ТаблицаНастроек.ЦветПодтверждена; 
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПациентОжидает Тогда
		Возврат ТаблицаНастроек.ЦветПациентОжидает;
	КонецЕсли;
	
КонецФункции

// Функция - Получить картинку для HTML.
//
// Параметры:
//  НазваниеКартинки - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКартинкуДляHTML(НазваниеКартинки, ФорматКартинкиПараметр = Неопределено)
	
	НашаКартинка 		= БиблиотекаКартинок[НазваниеКартинки];
  	
	Если ФорматКартинкиПараметр = Неопределено Или ФорматКартинкиПараметр = ФорматКартинки.SVG Тогда
		ТипКартинки = "svg+xml";	
	ИначеЕсли ФорматКартинкиПараметр = ФорматКартинки.PNG Тогда
		ТипКартинки = "png";
	Иначе
		Возврат "";
	КонецЕсли;
	
	Base64СтрокаКартинки	= Base64Строка(НашаКартинка.ПолучитьДвоичныеДанные());
	Base64СтрокаКартинки 	= СтрЗаменить(СтрЗаменить(Base64СтрокаКартинки ,Символы.ПС, ""), Символы.ВК, "");	
	
	Возврат СтрШаблон("url('data:image/%1;base64,%2')", ТипКартинки, Base64СтрокаКартинки);   
	
КонецФункции

