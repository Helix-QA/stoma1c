// Автоматическое создание документов Поступление
//
Процедура Создать_Синхронизировать_ДокументыПоступления()
	       
	УстановитьПривилегированныйРежим(Истина);
	Если Константы.АвтоматическиСоздаватьПоступлениеПриВыполненииНарядЗаказа.Получить() Тогда	
		
		// Получим структуру таблиц со строками, ранее попавшими в Поступления
		СтруктураТаблиц = ВернутьЗапасыИУслугиИзДокументовПоступления(Ссылка);
		
		// Если режим записи "ОтменаПроведения", отменим проведение у ранее созданных документов Поступления
		Если Перем_РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда 
			Для Каждого Документ_Поступление Из СтруктураТаблиц.МассивПоступлений Цикл
				Документ_Поступление_Объект = Документ_Поступление.Ссылка.ПолучитьОбъект();				
				Если Ссылка.ПометкаУдаления Тогда
					Документ_Поступление_Объект.УстановитьПометкуУдаления(Истина); 
					Документ_Поступление_Объект.Записать();
				Иначе
					Документ_Поступление_Объект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				КонецЕсли;				
			КонецЦикла;
			
		// Если режим записи "Запись"
		ИначеЕсли Перем_РежимЗаписи = РежимЗаписиДокумента.Запись Тогда	
			Для Каждого Документ_Поступление Из СтруктураТаблиц.МассивПоступлений Цикл
				Если Ссылка.ПометкаУдаления Тогда
					Если НЕ Документ_Поступление.Ссылка.ПометкаУдаления Тогда 
						Документ_Поступление_Объект = Документ_Поступление.Ссылка.ПолучитьОбъект();				
						Документ_Поступление_Объект.УстановитьПометкуУдаления(Истина);
						Документ_Поступление_Объект.Записать();
					КонецЕсли;
				Иначе 
					Если Документ_Поступление.Ссылка.ПометкаУдаления Тогда 
						Документ_Поступление_Объект = Документ_Поступление.Ссылка.ПолучитьОбъект();				
						Документ_Поступление_Объект.УстановитьПометкуУдаления(Ложь);
						Документ_Поступление_Объект.Записать();
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;						
			
		// Если режим записи "Проведение", сгенерируем документы Поступления и синхронизируем строки в ранее созданных
		ИначеЕсли Перем_РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
			
			// Выгрузим из Наряд-заказа все строки со статусом "Выполнено"
			ТаблицаВыполненныхЗаказов 	= Запасы.Выгрузить(Новый Структура("Статус", Перечисления.СтатусыНарядЗаказа.Выполнено));
			
			// Разделим таблицу на услуги и все остальное
			ТаблицаВыполненныхЗаказов_Запас 	= ТаблицаВыполненныхЗаказов.СкопироватьКолонки();
			ТаблицаВыполненныхЗаказов_Услуги 	= ТаблицаВыполненныхЗаказов.СкопироватьКолонки();		
			Для Каждого ВыполненныйЗаказ Из ТаблицаВыполненныхЗаказов Цикл 
				Если ВыполненныйЗаказ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда 
					СтрокаТаблицы = ТаблицаВыполненныхЗаказов_Услуги.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыполненныйЗаказ);
				Иначе 
					СтрокаТаблицы = ТаблицаВыполненныхЗаказов_Запас.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыполненныйЗаказ);	
				КонецЕсли;
			КонецЦикла;
			
			// Вычислим строки Наряд-заказа, не вошедшие в документы Поступления
			ТаблицаСтрокНеВошедшихВПоступление = ВернутьСтрокиНарядЗаказаНеВошедшиеВПоступление(СтруктураТаблиц, ТаблицаВыполненныхЗаказов);			
			
			
			// Произведем анализ для последующей синхронизации строк в Наряд-заказе и Поступлении
			МассивУдаленныхСтрок_Запасы 		= Новый Массив;
			МассивУдаленныхСтрок_Услуги 		= Новый Массив;
			МассивМодифицированныхСтрок_Запасы 	= Новый Массив;
			МассивМодифицированныхСтрок_Услуги 	= Новый Массив;
			МассивСтрокСИзмененнойЛабораторией 	= Новый Массив;
			
			Если СтруктураТаблиц.МассивПоступлений.Количество() > 0 Тогда 
				Для Каждого Поступление Из СтруктураТаблиц.МассивПоступлений Цикл
					
					МассивУдаленныхСтрок_Запасы.Очистить();
					МассивУдаленныхСтрок_Услуги.Очистить();
					МассивМодифицированныхСтрок_Запасы.Очистить();
					МассивМодифицированныхСтрок_Услуги.Очистить();					
					МассивСтрокСИзмененнойЛабораторией.Очистить();
					
					ПометитьПоступлениеНаУдаление = Ложь;
					
					МассивСтрок = СтруктураТаблиц.ТаблицаЗапасов.НайтиСтроки(Новый Структура("Ссылка", Поступление.Ссылка));
					Для Каждого СтрокаМассива Из МассивСтрок Цикл 
						СтрокаНарядЗаказа = ТаблицаВыполненныхЗаказов_Запас.Найти(СтрокаМассива.КлючСтроки, "КлючСтроки");
						Если СтрокаНарядЗаказа <> Неопределено Тогда 
							Если СтрокаНарядЗаказа.Номенклатура 		<> СтрокаМассива.Номенклатура 		ИЛИ 
								СтрокаНарядЗаказа.Упаковка 				<> СтрокаМассива.Упаковка 			ИЛИ
								СтрокаНарядЗаказа.КоличествоУпаковок 	<> СтрокаМассива.КоличествоУпаковок ИЛИ
								СтрокаНарядЗаказа.Цена 					<> СтрокаМассива.Цена 				ИЛИ
								СтрокаНарядЗаказа.Всего 				<> СтрокаМассива.Всего 				Тогда
								ЗаполнитьЗначенияСвойств(СтрокаМассива, СтрокаНарядЗаказа);
								МассивМодифицированныхСтрок_Запасы.Добавить(СтрокаМассива);
							КонецЕсли;
							Если СтрокаНарядЗаказа.Лаборатория <> Поступление.Ссылка.Контрагент Тогда 
								МассивСтрокСИзмененнойЛабораторией.Добавить(СтрокаНарядЗаказа);						
							КонецЕсли;							
						Иначе 
							МассивУдаленныхСтрок_Запасы.Добавить(СтрокаМассива);						 
						КонецЕсли;	
					КонецЦикла;
					
					МассивСтрок = СтруктураТаблиц.ТаблицаУслуг.НайтиСтроки(Новый Структура("Ссылка", Поступление.Ссылка));
					Для Каждого СтрокаМассива Из МассивСтрок Цикл 
						СтрокаНарядЗаказа = ТаблицаВыполненныхЗаказов_Услуги.Найти(СтрокаМассива.КлючСтроки, "КлючСтроки");
						Если СтрокаНарядЗаказа <> Неопределено Тогда 
							Если СтрокаНарядЗаказа.Номенклатура 		<> СтрокаМассива.Номенклатура 		ИЛИ 
								СтрокаНарядЗаказа.Упаковка 				<> СтрокаМассива.Упаковка 			ИЛИ
								СтрокаНарядЗаказа.КоличествоУпаковок 	<> СтрокаМассива.КоличествоУпаковок ИЛИ
								СтрокаНарядЗаказа.Цена 					<> СтрокаМассива.Цена 				ИЛИ
								СтрокаНарядЗаказа.Всего 				<> СтрокаМассива.Всего 				ИЛИ
								Ссылка.Сотрудник 						<> СтрокаМассива.Сотрудник 			Тогда
								ЗаполнитьЗначенияСвойств(СтрокаМассива, СтрокаНарядЗаказа);								
								МассивМодифицированныхСтрок_Услуги.Добавить(СтрокаМассива);
							КонецЕсли;
							Если СтрокаНарядЗаказа.Лаборатория <> Поступление.Ссылка.Контрагент Тогда 
								МассивСтрокСИзмененнойЛабораторией.Добавить(СтрокаНарядЗаказа);						
							КонецЕсли;						
						Иначе 
							МассивУдаленныхСтрок_Услуги.Добавить(СтрокаМассива);						 
						КонецЕсли;	
					КонецЦикла;
					
					// Синхронизируем строки
					Поступление_Объект = Неопределено;
					Если МассивУдаленныхСтрок_Запасы.Количество()		 	<> 0 ИЛИ
					 	 МассивУдаленныхСтрок_Услуги.Количество()		 	<> 0 ИЛИ
						 МассивМодифицированныхСтрок_Запасы.Количество() 	<> 0 ИЛИ
						 МассивМодифицированныхСтрок_Услуги.Количество()	<> 0 ИЛИ
						 МассивСтрокСИзмененнойЛабораторией.Количество() 	<> 0 Тогда
						
						Поступление_Объект = Поступление.Ссылка.ПолучитьОбъект();
						// Работа с модифицированными строками
						Для Каждого СтрокаМассива Из МассивМодифицированныхСтрок_Запасы Цикл 
							СтрокаПоступления = Поступление_Объект.Запасы.Найти(СтрокаМассива.КлючСтроки, "КлючСтроки");
							Если СтрокаПоступления <> Неопределено Тогда 
								ЗаполнитьЗначенияСвойств(СтрокаПоступления, СтрокаМассива);
							КонецЕсли;
						КонецЦикла;	
						
						Для Каждого СтрокаМассива Из МассивМодифицированныхСтрок_Услуги Цикл 
							СтрокаПоступления = Поступление_Объект.Расходы.Найти(СтрокаМассива.КлючСтроки, "КлючСтроки");
							Если СтрокаПоступления <> Неопределено Тогда 
								ЗаполнитьЗначенияСвойств(СтрокаПоступления, СтрокаМассива);
								СтрокаПоступления.Сотрудник = Ссылка.Сотрудник;
								СтрокаПоступления.Специализация = ?(ЗначениеЗаполнено(СтрокаПоступления.Сотрудник), ?(СтрокаПоступления.Сотрудник.СпецилазацииСотрудника.Найти(Истина, "Основная") <> Неопределено, СтрокаПоступления.Сотрудник.СпецилазацииСотрудника.Найти(Истина, "Основная").Специализация, Справочники.Специализации.ПустаяСсылка()), Справочники.Специализации.ПустаяСсылка());								
							КонецЕсли;
						КонецЦикла;
						
						// Работа с удаляемыми строками
						Для Каждого СтрокаМассива Из МассивУдаленныхСтрок_Запасы Цикл 
							СтрокаПоступления = Поступление_Объект.Запасы.Найти(СтрокаМассива.КлючСтроки, "КлючСтроки");
							Если СтрокаПоступления <> Неопределено Тогда 
								Поступление_Объект.Запасы.Удалить(СтрокаПоступления);
							КонецЕсли;
						КонецЦикла;
						
						Для Каждого СтрокаМассива Из МассивУдаленныхСтрок_Услуги Цикл 
							СтрокаПоступления = Поступление_Объект.Расходы.Найти(СтрокаМассива.КлючСтроки, "КлючСтроки");
							Если СтрокаПоступления <> Неопределено Тогда 
								Поступление_Объект.Расходы.Удалить(СтрокаПоступления);
							КонецЕсли;
						КонецЦикла;
						
						// Работа со строками с измененной лабораторией
  				    	Для Каждого СтрокаСИзмененнойЛабораторией Из МассивСтрокСИзмененнойЛабораторией Цикл 
							СтрокаПоступления = Поступление_Объект.Запасы.Найти(СтрокаСИзмененнойЛабораторией.КлючСтроки, "КлючСтроки");
							Если СтрокаПоступления <> Неопределено Тогда
								МассивУдаленныхСтрок_Запасы.Добавить(СтрокаПоступления);
								Поступление_Объект.Запасы.Удалить(СтрокаПоступления);
								НоваяСтрокаТаблицы = ТаблицаСтрокНеВошедшихВПоступление.Добавить();
								ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицы, СтрокаСИзмененнойЛабораторией);
							КонецЕсли;
							СтрокаПоступления = Поступление_Объект.Расходы.Найти(СтрокаСИзмененнойЛабораторией.КлючСтроки, "КлючСтроки");
							Если СтрокаПоступления <> Неопределено Тогда
								МассивУдаленныхСтрок_Услуги.Добавить(СтрокаПоступления);
								Поступление_Объект.Расходы.Удалить(СтрокаПоступления);
								НоваяСтрокаТаблицы = ТаблицаСтрокНеВошедшихВПоступление.Добавить();
								ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицы, СтрокаСИзмененнойЛабораторией);
							КонецЕсли;							
						КонецЦикла;
						
						//// Проставим флаг в истину если Наряд-Заказе удалены все строки
						// Если МассивУдаленныхСтрок_Услуги.Количество() = СтруктураТаблиц.ТаблицаУслуг.Количество() И
						//	МассивУдаленныхСтрок_Запасы.Количество() = СтруктураТаблиц.ТаблицаЗапасов.Количество() И 
						//	ТаблицаСтрокНеВошедшихВПоступление.Количество() = 0 Тогда 
						//	ПометитьПоступлениеНаУдаление = Истина;
						// КонецЕсли;						
					КонецЕсли;
					
					
					// Допишем новые строки в документ Поступление 
					МассивСтрок = ТаблицаСтрокНеВошедшихВПоступление.НайтиСтроки(Новый Структура("Лаборатория", Поступление.Ссылка.Контрагент));
					Если МассивСтрок.Количество() > 0 Тогда 
						Если Поступление_Объект = Неопределено Тогда
							Поступление_Объект = Поступление.Ссылка.ПолучитьОбъект();
						КонецЕсли;	
						Для Каждого СтрокаМассива Из МассивСтрок Цикл 
							Если СтрокаМассива.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда 
								СтрокаУслуги = Поступление_Объект.Расходы.Добавить();
							    ЗаполнитьЗначенияСвойств(СтрокаУслуги, СтрокаМассива);
								СтрокаУслуги.СтавкаНДС 			= Перечисления.СтавкиНДС.БезНдс;
								СтрокаУслуги.Сотрудник 			= Ссылка.Сотрудник;
								СтрокаУслуги.Специализация 		= ?(ЗначениеЗаполнено(Ссылка.Сотрудник), ?(Ссылка.Сотрудник.СпецилазацииСотрудника.Найти(Истина, "Основная") <> Неопределено, Ссылка.Сотрудник.СпецилазацииСотрудника.Найти(Истина, "Основная").Специализация, Справочники.Специализации.ПустаяСсылка()), Справочники.Специализации.ПустаяСсылка());
								СтрокаУслуги.СтатьяРасходов 	= Справочники.СтатьиДоходовИРасходов.Лаборатория;
								СтрокаУслуги.ДокументОснования 	= Ссылка;
							Иначе
								СтрокаУслуги = Поступление_Объект.Запасы.Добавить();
								ЗаполнитьЗначенияСвойств(СтрокаУслуги, СтрокаМассива);
								СтрокаУслуги.СтавкаНДС 			= Перечисления.СтавкиНДС.БезНдс;
								СтрокаУслуги.ДокументОснования 	= Ссылка;								
							КонецЕсли;
							ТаблицаСтрокНеВошедшихВПоступление.Удалить(СтрокаМассива);
						КонецЦикла;
					Иначе
						МассивСтрок_Из_ТаблицыЗапасов 	= СтруктураТаблиц.ТаблицаЗапасов.НайтиСтроки(Новый Структура("Ссылка", Поступление.Ссылка));
						МассивСтрок_Из_ТаблицыУслуг 	= СтруктураТаблиц.ТаблицаУслуг.НайтиСтроки(Новый Структура("Ссылка", Поступление.Ссылка));
						Если МассивУдаленныхСтрок_Услуги.Количество() = МассивСтрок_Из_ТаблицыУслуг.Количество() И
							МассивУдаленныхСтрок_Запасы.Количество() = МассивСтрок_Из_ТаблицыЗапасов.Количество() Тогда
							// Проставим флаг в истину если Наряд-Заказе удалены все строки
							ПометитьПоступлениеНаУдаление = Истина;
						КонецЕсли;	
					КонецЕсли;
					
					ПараметрыСеанса.ОбменДаннымиВключен = Истина;
					Если Поступление_Объект <> Неопределено Тогда						
						Если Поступление_Объект.ПометкаУдаления Тогда
							Если ПометитьПоступлениеНаУдаление Тогда 
								Поступление_Объект.Записать();
							Иначе
								Поступление_Объект.Записать();
								Поступление_Объект.УстановитьПометкуУдаления(Ложь);
								Поступление_Объект.Записать(РежимЗаписиДокумента.Проведение);
							КонецЕсли;	
						ИначеЕсли ПометитьПоступлениеНаУдаление Тогда
							Поступление_Объект.Записать();
							Поступление_Объект.УстановитьПометкуУдаления(Истина);
							Поступление_Объект.Записать();
						Иначе 
							Поступление_Объект.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;												
					ИначеЕсли Поступление_Объект = Неопределено И Перем_РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
						Поступление_Объект = Поступление.Ссылка.ПолучитьОбъект();
						Если Поступление_Объект.ПометкаУдаления Тогда 
							Поступление_Объект.УстановитьПометкуУдаления(Ложь);
						КонецЕсли;
						Поступление_Объект.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
					ПараметрыСеанса.ОбменДаннымиВключен = Ложь;
				КонецЦикла;		
			КонецЕсли;
			
			// Создадим документы Поступления для оставшихся строк
			Таблица_Лабораторий = ТаблицаСтрокНеВошедшихВПоступление.Скопировать();
			Таблица_Лабораторий.Свернуть("Лаборатория");
			Для Каждого Строка_Лаборатория Из Таблица_Лабораторий Цикл 
				МассивСтрок = ТаблицаСтрокНеВошедшихВПоступление.НайтиСтроки(Новый Структура("Лаборатория", Строка_Лаборатория.Лаборатория));
				МассивКлючей = ВернутьМассивКлючей(МассивСтрок);
				Поступление_Объект = Документы.Поступление.СоздатьДокумент();
				Поступление_Объект.Заполнить(Новый Структура("Документ, Лаборатория, Фильтр, МассивКлючей, Договор", Ссылка, Строка_Лаборатория.Лаборатория, Истина, МассивКлючей, Договор));
				Поступление_Объект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЦикла;
			
		КонецЕсли;	
		
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

//
//
Функция ВернутьЗапасыИУслугиИзДокументовПоступления(НарядЗаказСсылка)
	              
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас) КАК ТипНоменклатуры,
	               |	ПоступлениеЗапасы.Ссылка,
	               |	ПоступлениеЗапасы.Номенклатура,
	               |	ПоступлениеЗапасы.Упаковка,
	               |	ПоступлениеЗапасы.Количество,
	               |	ПоступлениеЗапасы.КоличествоУпаковок,
	               |	ПоступлениеЗапасы.Цена,
	               |	ПоступлениеЗапасы.Сумма,
	               |	ПоступлениеЗапасы.Всего,
	               |	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Сотрудник,
	               |	ПоступлениеЗапасы.ДокументОснования,
	               |	ПоступлениеЗапасы.КлючСтроки
	               |ИЗ
	               |	Документ.Поступление.Запасы КАК ПоступлениеЗапасы
	               |ГДЕ
	               |	ПоступлениеЗапасы.ДокументОснования = &НарядЗаказСсылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга),
	               |	ПоступлениеРасходы.Ссылка,
	               |	ПоступлениеРасходы.Номенклатура,
	               |	ПоступлениеРасходы.Упаковка,
	               |	ПоступлениеРасходы.Количество,
	               |	ПоступлениеРасходы.КоличествоУпаковок,
	               |	ПоступлениеРасходы.Цена,
	               |	ПоступлениеРасходы.Сумма,
	               |	ПоступлениеРасходы.Всего,
	               |	ПоступлениеРасходы.Сотрудник,
	               |	ПоступлениеРасходы.ДокументОснования,
	               |	ПоступлениеРасходы.КлючСтроки
	               |ИЗ
	               |	Документ.Поступление.Расходы КАК ПоступлениеРасходы
	               |ГДЕ
	               |	ПоступлениеРасходы.ДокументОснования = &НарядЗаказСсылка";
				   
	Запрос.УстановитьПараметр("НарядЗаказСсылка", НарядЗаказСсылка);
	
	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
	
	// Разделим таблицу на запасы и услуги
	ТаблицаЗапасов 	= ТаблицаРезультат.СкопироватьКолонки();
	ТаблицаУслуг 	= ТаблицаРезультат.СкопироватьКолонки();		
	Для Каждого СтрокаТаблицыРезультат Из ТаблицаРезультат Цикл 
		Если СтрокаТаблицыРезультат.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас Тогда 
			СтрокаТаблицы = ТаблицаЗапасов.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаТаблицыРезультат);
		ИначеЕсли СтрокаТаблицыРезультат.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда 
			СтрокаТаблицы = ТаблицаУслуг.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаТаблицыРезультат);	
		КонецЕсли;
	КонецЦикла;
	
	ТаблицаПоступление = ТаблицаРезультат.Скопировать();
	ТаблицаПоступление.Свернуть("Ссылка");
	МассивПоступлений = ТаблицаПоступление.ВыгрузитьКолонку("Ссылка");
	
	// Создадим структуру, состоящую, из полученных нами таблиц
	СтруктураТаблиц = Новый Структура;
	СтруктураТаблиц.Вставить("МассивПоступлений",	МассивПоступлений);
	СтруктураТаблиц.Вставить("ТаблицаЗапасов",		ТаблицаЗапасов);
	СтруктураТаблиц.Вставить("ТаблицаУслуг",		ТаблицаУслуг);
	
	Возврат СтруктураТаблиц;			   
	
КонецФункции

//
//
Функция ВернутьСтрокиНарядЗаказаНеВошедшиеВПоступление(СтруктураТаблиц, ТаблицаВыполненныхЗаказов)
	
	ТаблицаСтрокНеВошедшихВПоступление = ТаблицаВыполненныхЗаказов.СкопироватьКолонки();
	Для Каждого ВыполненныйЗаказ Из ТаблицаВыполненныхЗаказов Цикл
		СтрокаТаблицыЗапасов = СтруктураТаблиц.ТаблицаЗапасов.Найти(ВыполненныйЗаказ.КлючСтроки, "КлючСтроки");
		СтрокаТаблицыУслуг	 = СтруктураТаблиц.ТаблицаУслуг.Найти(ВыполненныйЗаказ.КлючСтроки, "КлючСтроки");
		Если СтрокаТаблицыЗапасов = Неопределено И СтрокаТаблицыУслуг = Неопределено Тогда 
			НоваяСтрока = ТаблицаСтрокНеВошедшихВПоступление.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыполненныйЗаказ);
		КонецЕсли;	
	КонецЦикла;
	
	Возврат ТаблицаСтрокНеВошедшихВПоступление;
			
КонецФункции

//
//
Функция ВернутьМассивКлючей(МассивСтрок)
	
	МассивКлючей = Новый Массив;
	Для Каждого СтрокаМассива Из МассивСтрок Цикл 
		МассивКлючей.Добавить(СтрокаМассива.КлючСтроки);
	КонецЦикла;
	
	Возврат МассивКлючей;		
		
КонецФункции


