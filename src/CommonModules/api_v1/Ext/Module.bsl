#Область РаботаСДаннымиКлиента

// Процедура - Создать нового клиента
//
// Параметры:
//  НомерТелефона	 - 	 - 
//
// Функция, создает элемент справочника "Контрагенты".
//
Функция СоздатьКлиента(Знач phone, 
					   СтруктурнаяЕдиница,
					   last_name,
					   name,
					   second_name = Неопределено,
					   email = Неопределено,
					   birthday = Неопределено,
					   sex = Неопределено,
					   ВнешняяСистема = Неопределено)
	
	КлиентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
	Родитель 	 = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "ГруппаКлиентов");
    Родитель	 = ?(ЗначениеЗаполнено(Родитель), Родитель, Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты));
	
	КлиентОбъект.Заполнить(Новый Структура("ТипКонтрагента, Родитель", Перечисления.ТипыКонтрагентов.Клиенты, Родитель));
	
	КлиентОбъект.Имя 		  		 = ?(ЗначениеЗаполнено(name), name, phone);
	КлиентОбъект.Фамилия 	  		 = last_name;
	КлиентОбъект.Отчество 	  		 = second_name;
	КлиентОбъект.Наименование 		 = КлиентОбъект.Фамилия + ?(ЗначениеЗаполнено(КлиентОбъект.Фамилия), " ", "") + КлиентОбъект.Имя + ?(ЗначениеЗаполнено(КлиентОбъект.Имя), " ", "") + КлиентОбъект.Отчество;
	КлиентОбъект.ПолКлиента 		 = ?(ЗначениеЗаполнено(sex), ПолучитьПолКлиента(sex), ПолучитьПолКлиентаПоФИО(name));
	
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда 
		КаналПривлечения = ПолучитьНаименованиеКаналаПривлечения(ВнешняяСистема);
		КлиентОбъект.КаналПривлечения = Справочники.КаналыПривлечения.ПолучитьКаналПривлечения(КаналПривлечения);
	КонецЕсли;
	
	Попытка
		Если ЗначениеЗаполнено(birthday) Тогда
			КлиентОбъект.ДатаРожденияКлиента = Дата(Сред(birthday,7), Сред(birthday,4,2), Сред(birthday,1,2)); 
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Если ЗначениеЗаполнено(phone) Тогда
		ЗаполнитьТелефон(КлиентОбъект, phone);
	КонецЕсли;
	Если ЗначениеЗаполнено(email) Тогда
		ЗаполнитьАдресЭлектроннойПочты(КлиентОбъект, email);
	КонецЕсли;
	
	КлиентОбъект.Записать();
	
	Возврат КлиентОбъект.Ссылка;
	
КонецФункции

// Функция, определяет пол клиента по ФИО.
//
Функция ПолучитьПолКлиентаПоФИО(Имя, Фамилия = "", Отчество = "")
	
	Если ЗначениеЗаполнено(Имя) ИЛИ ЗначениеЗаполнено(Фамилия) ИЛИ ЗначениеЗаполнено(Отчество) Тогда
		ПолКлиента = ОбщегоНазначенияСтоматология.ОпределитьПолКлиента(Фамилия, Имя, Отчество);
		Если ПолКлиента = "Мужской" Тогда
			Возврат Перечисления.ПолФизическогоЛица.Мужской;
		ИначеЕсли ПолКлиента = "Женский" Тогда
			Возврат Перечисления.ПолФизическогоЛица.Женский;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция, возвращает структуру XDTO телефона.
// 
Функция ПолучитьСтруктуру_XDTO(Представление, ТипКИ)
	
	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Возврат Неопределено;
	КонецЕсли;	
		
	Объект_XDTO = УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOПоПредставлению(Представление, ТипКИ);
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
		Если НЕ ЗначениеЗаполнено(Объект_XDTO.Состав.Номер) Тогда 
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат Объект_XDTO;
	
КонецФункции

// Процедура, добаляет телефон в контактную информация клиента.
// 
Процедура ЗаполнитьТелефон(НовыйЭлемент, НомерТелефона)
	
	Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон);
	
	Если Объект_XDTO_Телефон = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 						= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 					= Перечисления.ТипыКонтактнойИнформации.Телефон;
	НоваяСтрока.Вид 					= Справочники.ВидыКонтактнойИнформации.ТелефонКлиента;
	НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
	НоваяСтрока.НомерТелефонаБезКодов	= Объект_XDTO_Телефон.Состав.Номер;
	НоваяСтрока.Представление		 	= Объект_XDTO_Телефон.Представление;
	НоваяСтрока.ЗначенияПолей		 	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
	
КонецПроцедуры

// Функция, возвращает массив телефонов клиента.
//
Функция ПолучитьМассивТелефоновКлиента(Контрагент)
	
	МассивТелефонов = Новый Массив;
	
	Для Каждого СтрокаТЧ Из Контрагент.КонтактнаяИнформация Цикл
		Если СтрокаТЧ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
			МассивТелефонов.Добавить(СтрокаТЧ.Представление);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивТелефонов;
	
КонецФункции

// Функция, возвращает наименование канала привлечения для внешней системы.
//
Функция ПолучитьНаименованиеКаналаПривлечения(ВнешняяСистема, СозданиеЗаявки = Ложь)
		
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
		ТипВнешнейСистемы = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВнешняяСистема, "ТипВнешнейСистемы");
		Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ПроДокторов Тогда
			Возврат "ПроДокторов";
		Иначе
			Возврат "Онлайн запись"; 
		КонецЕсли; 
	Иначе
		Возврат "Онлайн запись";
	КонецЕсли;
	
КонецФункции

