&НаСервереБезКонтекста
// Функция, возвращает данные задач для формирования меню.
//
Функция ПолучитьДанныеЗадач(ИдентификаторСделки)
	
	Сделка = Справочники.Сделки.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторСделки));
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.Ссылка КАК Ссылка,
	|	Взаимодействие.ЗадачаНазначеннаяДатаНачало КАК НазначеннаяДатаНачало,
	|	Взаимодействие.ЗадачаНазначеннаяДата КАК НазначеннаяДата,
	|	Взаимодействие.ВидВзаимодействияСправочник.Наименование КАК ВидВзаимодействия,
	|	Взаимодействие.ВидВзаимодействияСправочник.ИндексКартинки КАК ИндексКартинки,
	|	Взаимодействие.ЗадачаТема КАК Тема,
	|	Взаимодействие.ЗадачаОписание КАК Описание,
	|	Взаимодействие.ЗадачаНазначеннаяДата < &ТекущаяДата КАК Просрочена
	|ПОМЕСТИТЬ ДанныеЗадач
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Сделка = &Сделка
	|	И НЕ Взаимодействие.Выполнена
	|	И НЕ Взаимодействие.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеЗадач.ИндексКартинки КАК ИндексКартинки
	|ИЗ
	|	ДанныеЗадач КАК ДанныеЗадач
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеЗадач.Ссылка КАК Ссылка,
	|	ДанныеЗадач.НазначеннаяДатаНачало КАК НазначеннаяДатаНачало,
	|	ДанныеЗадач.НазначеннаяДата КАК НазначеннаяДата,
	|	ДанныеЗадач.ВидВзаимодействия КАК ВидВзаимодействия,
	|	ДанныеЗадач.ИндексКартинки КАК ИндексКартинки,
	|	ДанныеЗадач.Тема КАК Тема,
	|	ДанныеЗадач.Описание КАК Описание,
	|	ДанныеЗадач.Просрочена КАК Просрочена
	|ИЗ
	|	ДанныеЗадач КАК ДанныеЗадач");
	
	Запрос.УстановитьПараметр("Сделка"		, Сделка);
	Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДатаСеанса());
	
	Результат = Запрос.ВыполнитьПакет();
	
	БлокиЗадач = Новый Массив;
	
	ДанныеКартинок = Новый Соответствие;
	ВыборкаИндексыКартинок = Результат[Результат.ВГраница() - 1].Выбрать();
	
	Пока ВыборкаИндексыКартинок.Следующий() Цикл
		
		КартинкаВзаимодействия = БиблиотекаКартинок["ВидВзаимодействия_" + ВыборкаИндексыКартинок.ИндексКартинки];
		ДвоичныеДанныеКартинки = КартинкаВзаимодействия.ПолучитьДвоичныеДанные();
		
		АдресКартинки = "data:image/svg+xml;base64," + СтрСоединить(СтрРазделить(Base64Строка(ДвоичныеДанныеКартинки), Символы.ПС + Символы.ВК));
		
		ДанныеКартинок.Вставить(ВыборкаИндексыКартинок.ИндексКартинки, АдресКартинки);
		
	КонецЦикла;
	
	Выборка = Результат[Результат.ВГраница()].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		БлокЗадачи = ПолучитьБлокЗадачи(Выборка, ДанныеКартинок.Получить(Выборка.ИндексКартинки));
		БлокиЗадач.Добавить(БлокЗадачи);
		
	КонецЦикла;
	
	Возврат СтрСоединить(БлокиЗадач, Символы.ПС);
	
КонецФункции

