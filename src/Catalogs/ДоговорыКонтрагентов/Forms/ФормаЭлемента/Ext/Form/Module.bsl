 &НаКлиенте
// Процедура, отмечает услуги сотрудников.
//
Процедура ОтметитьУслуги(Установить, МассивНоменклатур = Неопределено)
	
	ДанныеДерева = ЭтаФорма.ДеревоНоменклатур.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ Из ДанныеДерева Цикл
		  
		Если СтрокаТЧ.ЭтоГруппа Тогда
			СтрокаТЧ.Выбран = Установить;	
			УстановитьФлагиНаЭлементы(СтрокаТЧ, "Выбран", МассивНоменклатур);
			УстановитьФлагиНаГруппы(СтрокаТЧ, "Выбран", Истина);
		Иначе
			Если СтрокаТЧ.Выбран <> Установить Тогда
				
				НайденнаяНоменклатура = МассивНоменклатур.Найти(СтрокаТЧ.Номенклатура);
				Если НайденнаяНоменклатура = Неопределено Тогда
					СтрокаТЧ.Выбран = Установить;
					УстановитьФлагиНаГруппы(СтрокаТЧ, "Выбран");
				Иначе 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Удалите услугу: %1 из дерева ограничений", СтрокаТЧ.Номенклатура));
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры
 
