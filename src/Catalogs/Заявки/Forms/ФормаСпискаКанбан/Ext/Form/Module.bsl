// Функция, возвращает представление даты.
//
Функция ПолучитьПредставлениеДаты(Дата)
	
	Если Не ЗначениеЗаполнено(Дата) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Если НачалоДня(Дата) = НачалоДня(ТекущаяДата) Тогда
		// Сегодня - показываем время.
		Возврат Формат(Дата, "ДФ=''' сегодня в ''ЧЧ:мм'");
		
	ИначеЕсли НачалоГода(Дата) = НачалоГода(ТекущаяДата) Тогда
		// В этом году - не показывам год.
		Возврат Формат(Дата, "ДФ=' от d MMMM'")
		
	Иначе
		Возврат Формат(Дата, "ДФ=' от d MMMM yyyy'")
		
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает данные блока заявки (представление и родительский блок).
//
Функция ПолучитьДанныеБлокаЗаявки(Заявка, СтруктураОтбора, ПараметрыПолученияЗаявкиИзОчереди = Неопределено)
	
	ДанныеЗаявки = ПолучитьДанныеЗаявки(СтруктураОтбора, Заявка);
	
	Если Не ЗначениеЗаполнено(ДанныеЗаявки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеКоличества		 = ПолучитьКоличествоЗаявокВКолонках(СтруктураОтбора);
	ДанныеВыводимойЗаявки	 = ПолучитьДанныеВыводимойЗаявки(СтруктураОтбора, ПараметрыПолученияЗаявкиИзОчереди);
	
	Результат = Новый Структура;
	Результат.Вставить("БлокЗаявки"				, ПолучитьБлокЗаявки(ДанныеЗаявки));
	Результат.Вставить("ПредставлениеКолонки"	, XMLСтрока(ДанныеЗаявки.Статус));
	Результат.Вставить("ДанныеКоличества"		, ДанныеКоличества);
	Результат.Вставить("ДанныеВыводимойЗаявки"	, ДанныеВыводимойЗаявки);
	
	Возврат Результат
	
КонецФункции

