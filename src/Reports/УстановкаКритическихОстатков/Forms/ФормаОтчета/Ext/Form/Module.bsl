//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура СУчетомПартиПриИзменении(Элемент)
	
	УстановитьВариантОтчета(СУчетомПарти);
	СкомпоноватьДанныеРезультата();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура удаляет запись регистра.
//
Процедура УдалитьНаСервере(СтруктураПараметров)

	КлючЗаписи = ПолучитьКлючЗаписи(СтруктураПараметров);

	Если КлючЗаписи <> Неопределено Тогда
		
		НаборЗаписей = РегистрыСведений.КритическиеОстатки.СоздатьНаборЗаписей();
		Для каждого ЭлементСтруктуры Из КлючЗаписи Цикл
			НаборЗаписей.Отбор[ЭлементСтруктуры.Ключ].Установить(ЭлементСтруктуры.Значение);	
		КонецЦикла; 
		НаборЗаписей.Записать();
	
	КонецЕсли; 	

КонецПроцедуры // Удалить()

&НаСервере
// Функция возвращает ключ записи регистра.
//
// Параметры
//  <СтруктураПараметров>	- Структура	- Структура параметров расшифровки
//
// Возвращаемое значение:
//   <Структура>			- ключ записи регистра
//
Функция ПолучитьКлючЗаписи(СтруктураПараметров)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	   "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	   |	КритическиеОстатки.Номенклатура,
	   |	КритическиеОстатки.Количество,
	   |	КритическиеОстатки.Партия
	   |ИЗ
	   |	РегистрСведений.КритическиеОстатки КАК КритическиеОстатки
	   |ГДЕ
	   |	КритическиеОстатки.Номенклатура = &Номенклатура
	   |	И КритическиеОстатки.Склад = &Склад
	   |	И КритическиеОстатки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	   |	И КритическиеОстатки.Партия = &Партия";

	Запрос.УстановитьПараметр("Номенклатура", 		СтруктураПараметров.Номенклатура);
	Запрос.УстановитьПараметр("Партия", 			?(СтруктураПараметров.Свойство("Партия"), СтруктураПараметров.Партия, Справочники.ПартииНоменклатуры.ПустаяСсылка()));
	Запрос.УстановитьПараметр("Склад", 				СтруктураПараметров.Склад);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",	СтруктураПараметров.СтруктурнаяЕдиница);

	СтруктураВозврата = Новый Структура("Номенклатура, Партия, СтруктурнаяЕдиница, Склад");	
	ЗаполнитьЗначенияСвойств(СтруктураВозврата, СтруктураПараметров);
	
	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
	Если ТаблицаРезультат.Количество() > 0 Тогда
		СтруктураВозврата.Номенклатура 		= ТаблицаРезультат[0].Номенклатура;
		СтруктураВозврата.Партия 			= ТаблицаРезультат[0].Партия;
		Возврат СтруктураВозврата;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции // ПолучитьКлючЗаписи()

&НаСервере
// Функция возвращает данные расшифровки по расшифровке поля
//
// Параметры
//  <Расшифровка>	- ИндентификаторРасшифровки - Расшифровка ячейки
//
// Возвращаемое значение:
//   <Структура>	- Структура параметров расшифровки
//
Функция ПолучитьДанныеРасшифровки(Расшифровка)

	СтруктураПараметров = Новый Структура("СтруктурнаяЕдиница");
	
	СтруктураПараметров.СтруктурнаяЕдиница = СтруктурнаяЕдиницаОтбор;
	
	Если ТипЗнч(Расшифровка) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда		
		
		ОбработкаРасшифровки = Новый ОбработкаРасшифровкиКомпоновкиДанных(ДанныеРасшифровки, Новый ИсточникДоступныхНастроекКомпоновкиДанных(РеквизитФормыВЗначение("Отчет").СхемаКомпоновкиДанных));		
		ЭлементРасшифровки = ПолучитьИзВременногоХранилища(ДанныеРасшифровки).Элементы.Получить(Расшифровка);		
		
		Для Каждого ЭлементПоля Из ЭлементРасшифровки.ПолучитьПоля() Цикл
			СтруктураПараметров.Вставить(ЭлементПоля.Поле, ЭлементПоля.Значение);
			Если СтруктураПараметров.Свойство("Основной") Тогда
				СтруктураПараметров.Основной = ЭлементПоля.Значение;
			Иначе
				СтруктураПараметров.Вставить("Основной", ЭлементПоля.Значение);
			КонецЕсли;                  
		КонецЦикла;	
		Для Каждого ЭлементРодителя Из ЭлементРасшифровки.ПолучитьРодителей() Цикл
			Для Каждого ЭлементРКД Из ЭлементРодителя.ПолучитьПоля() Цикл
				СтруктураПараметров.Вставить(ЭлементРКД.Поле, ЭлементРКД.Значение);
			КонецЦикла;
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СтруктураПараметров;
	
КонецФункции // ОткрытьФормуЭлементаСправочника()

&НаСервере
// Функция проверяет существование элемента в регистре сведений КритическиеОстатки по измерениям "Номенклатура", 
// "СтруктурнаяЕдиница" и "Склад" и возвращает булево значение.
//
Функция ПроверкаСуществованияЭлемента(СтруктураПараметров)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	   "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	   |	КритическиеОстатки.Номенклатура
	   |ИЗ
	   |	РегистрСведений.КритическиеОстатки КАК КритическиеОстатки
	   |ГДЕ
	   |	КритическиеОстатки.Номенклатура = &Номенклатура
	   |	И КритическиеОстатки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	   |	И КритическиеОстатки.Склад = &Склад
	   |	И КритическиеОстатки.Партия = &Партия";

	Запрос.УстановитьПараметр("Номенклатура", 		СтруктураПараметров.Номенклатура);
	Запрос.УстановитьПараметр("Партия",				?(СтруктураПараметров.Свойство("Партия"), СтруктураПараметров.Партия, Справочники.ПартииНоменклатуры.ПустаяСсылка()));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",	СтруктураПараметров.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Склад",				СтруктураПараметров.Склад);

	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
	Если ТаблицаРезультат.Количество() > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

&НаСервере
// Процедура устанавливает параметр СтруктурнаяЕдиница в СКД.
//
