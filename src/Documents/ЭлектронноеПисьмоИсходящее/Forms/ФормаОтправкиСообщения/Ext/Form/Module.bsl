// Процедура, устананвливает видимость доступных каналов рассылки в мессенджер.
//
Процедура УстановитьВидимостьОтправкиВМессенджер()
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ОбъектСсылка = Контрагент;
	ИначеЕсли ЗначениеЗаполнено(Заявка) Тогда 
		ОбъектСсылка = Заявка;
	КонецЕсли;
	
	Элементы.ИдентификаторКаналаМессенджер.СписокВыбора.Очистить();
	
	ДанныеКаналовОтправки = Документы.РассылкаСообщений.ПолучитьДоступныеДляОтправкиВнешниеСистемыМессенджера(ОбъектСсылка, ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
	
	Если Не ЗначениеЗаполнено(ДанныеКаналовОтправки) Тогда
		Элементы.ПереключательМессенджер.Доступность = Ложь;
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.ВнешняяСистемаМессенджера = ДанныеКаналовОтправки[0].ВнешняяСистема;
	
	Для Каждого ДанныеКанала Из ДанныеКаналовОтправки Цикл
		
		КаналРассылки = ЭтотОбъект.ТаблицаКаналовРассылки.Добавить();
		
		ЗаполнитьЗначенияСвойств(КаналРассылки, ДанныеКанала);
		
		Элементы.ИдентификаторКаналаМессенджер.СписокВыбора.Добавить(
			КаналРассылки.ПолучитьИдентификатор(),
			ПолучитьПредставлениеКаналаОтправки(ДанныеКанала),,
			ПолучитьКартинкуМессенджера(ДанныеКанала.ТипВнешнейСистемы)
		);
		
	КонецЦикла;
	
	Элементы.ПереключательМессенджер.Доступность = Истина;
	
КонецПроцедуры

