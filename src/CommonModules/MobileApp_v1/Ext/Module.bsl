// Процедура - Создать нового клиента
//
// Параметры:
//  ФИО		 - 	 - 
//  Телефон	 - 	 - 
//
Функция СоздатьНовогоКлиента(ИмяКонтрагента, ТелефонКонтрагента, Автор)
	
	НовыйКонтрагент 				= Справочники.Контрагенты.СоздатьЭлемент();
	
	НаименованиеКлиента             = СокрЛП(ИмяКонтрагента);
	ПозицияПервогоПробела           = Найти(НаименованиеКлиента, " "); 
	Если ПозицияПервогоПробела = 0 Тогда
		Имя      = НаименованиеКлиента;
		Фамилия  = "";
		Отчество = "";
	Иначе
		Фамилия                    = Сред(НаименованиеКлиента, 1, ПозицияПервогоПробела - 1);
		НаименованиеКлиента        = СокрЛП(Сред(НаименованиеКлиента, ПозицияПервогоПробела + 1, СтрДлина(НаименованиеКлиента) - ПозицияПервогоПробела));
		ПозицияВторогоПробела      = Найти(НаименованиеКлиента, " ");
		Если ПозицияВторогоПробела = 0 Тогда
			Имя                    = СокрЛП(НаименованиеКлиента);
			Отчество               = "";
		Иначе
			Имя                    = Сред(НаименованиеКлиента, 1, ПозицияВторогоПробела - 1); 
			Отчество               = СокрЛП(Прав(НаименованиеКлиента, СтрДлина(НаименованиеКлиента) - ПозицияВторогоПробела));   
		КонецЕсли;
	КонецЕсли;
	
	НовыйКонтрагент.Имя						= Имя;
	НовыйКонтрагент.Фамилия					= Фамилия;
	НовыйКонтрагент.Отчество				= Отчество;			
	НовыйКонтрагент.Наименование			= СокрЛП(ИмяКонтрагента);			
	НовыйКонтрагент.СотрудникРегистрации	= Автор;
	
	// Заполняем пол клиента
	ПолКлиента = ОбщегоНазначенияСтоматология.ОпределитьПолКлиента(Фамилия, Имя, Отчество);
	Если ПолКлиента = "Мужской" Тогда
		ПолКлиента = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Мужской");
	ИначеЕсли ПолКлиента = "Женский" Тогда
		ПолКлиента = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Женский");
	КонецЕсли;
	НовыйКонтрагент.ПолКлиента = ПолКлиента;
	
	НовыйКонтрагент.Заполнить(Новый Структура("ТипКонтрагента, ИмяКлиента", Перечисления.ТипыКонтрагентов.Клиенты, ИмяКонтрагента));
	НовыйКонтрагент.ДополнительныеСвойства.Вставить("Статус", Перечисления.СтатусыКонтрагентов.Потенциальный);
	
	Если ЗначениеЗаполнено(ТелефонКонтрагента) Тогда
		
		// Получим КИ в нужном виде для поиска и последующей записи
		Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOПоПредставлению(ТелефонКонтрагента, Перечисления.ТипыКонтактнойИнформации.Телефон);
		Если НЕ Объект_XDTO_Телефон = Неопределено Тогда 
			Если ЗначениеЗаполнено(Объект_XDTO_Телефон.Состав.Номер) Тогда
				ТелефонКлиента = НовыйКонтрагент.КонтактнаяИнформация.Добавить();
				ТелефонКлиента.Тип 						= Перечисления.ТипыКонтактнойИнформации.Телефон;
				ТелефонКлиента.Вид 						= Справочники.ВидыКонтактнойИнформации.ТелефонКлиента;
				ТелефонКлиента.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
				ТелефонКлиента.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
				ТелефонКлиента.Представление		 	= Объект_XDTO_Телефон.Представление;
				ТелефонКлиента.ЗначенияПолей		 	= УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли; 
	
	Возврат НовыйКонтрагент;	
	
КонецФункции

// Функция возвращает структуру с заголовками запроса в нижнем регистре.
// 
// Параметры:
//  Запрос	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПривестиЗаголовкиВНижнийРегистр(Запрос) Экспорт
	
	СоответствиеСЗаголовками = Новый Соответствие;
	
	Для Каждого Заголовок Из Запрос.Заголовки Цикл
		СоответствиеСЗаголовками.Вставить(НРег(Заголовок.Ключ), Заголовок.Значение);
	КонецЦикла;
	
	Возврат СоответствиеСЗаголовками;
	
КонецФункции

// Функция - Валидация JSON
//
// Параметры:
//  ВходящийПараметр - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВалидацияJSON(ВходящийПараметр)
	
	Если ТипЗнч(ВходящийПараметр) = Тип("Структура") Тогда
		
		Для Каждого КлючЗначение Из ВходящийПараметр Цикл
			Если ТипЗнч(КлючЗначение.Значение) = Тип("Структура") ИЛИ ТипЗнч(КлючЗначение.Значение) = Тип("Массив") Тогда
				ВходящийПараметр[КлючЗначение.Ключ] = ВалидацияJSON(КлючЗначение.Значение);			
			Иначе
				ВходящийПараметр[КлючЗначение.Ключ] = ?(Не ЗначениеЗаполнено(КлючЗначение.Значение) И ТипЗнч(КлючЗначение.Значение) <> Тип("Дата"), Неопределено, КлючЗначение.Значение); 
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ВходящийПараметр) = Тип("Массив") Тогда
		
		Для Каждого СтрокаМ Из ВходящийПараметр Цикл
			
			Если ТипЗнч(СтрокаМ) = Тип("Структура") Тогда				
				СтрокаМ = ВалидацияJSON(СтрокаМ);
			Иначе				
				СтрокаМ = ?(Не ЗначениеЗаполнено(СтрокаМ) И ТипЗнч(СтрокаМ) <> Тип("Дата"), Неопределено, СтрокаМ);				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ВходящийПараметр; 
	
КонецФункции

// Процедура - Обновить константу настройки мобильного приложения стоматологии
//
Процедура ОбновитьКонстантуНастройкиМобильногоПриложенияСтоматологии() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПараметрыДанных = Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();
	
	ПараметрыДанных = ?(Не ЗначениеЗаполнено(ПараметрыДанных), Новый Структура(), ПараметрыДанных);
	
	Если НЕ ПараметрыДанных.Свойство("РазрешитьРедактированиеПриемовВрачом") Тогда
		ПараметрыДанных.Вставить("РазрешитьРедактированиеПриемовВрачом", Истина);
	КонецЕсли;
	
	Если НЕ ПараметрыДанных.Свойство("ВыводитьТелефонКлиентаВрачу") Тогда
		ПараметрыДанных.Вставить("ВыводитьТелефонКлиентаВрачу", Истина);
	КонецЕсли;
	
	Если НЕ ПараметрыДанных.Свойство("НеВыводитьИсториюПриемовПоКлиенту") Тогда
		ПараметрыДанных.Вставить("НеВыводитьИсториюПриемовПоКлиенту", Ложь);
	КонецЕсли;
	
	Если НЕ ПараметрыДанных.Свойство("ВыводитьВрачуКомментарий") Тогда
		ПараметрыДанных.Вставить("ВыводитьВрачуКомментарий", Истина);
	КонецЕсли;
	
	Если НЕ ПараметрыДанных.Свойство("УведомлятьВрачаОбИзмененииПриемов") Тогда
		ПараметрыДанных.Вставить("УведомлятьВрачаОбИзмененииПриемов", Истина);
	КонецЕсли;
			
	Константы.НастройкиМобильногоПриложенияСтоматологии.Установить(Новый ХранилищеЗначения(ПараметрыДанных));
	
КонецПроцедуры

// Функция - Получить статус события
//
// Параметры:
//  Статус	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтатусСобытия(Статус)
	
	Если Статус = Перечисления.СтатусыСобытия.НеПодтверждена Тогда
		Возврат "НеПодтверждена";
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда 
		Возврат "Подтверждена";
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПациентОжидает Тогда 
		Возврат "ПациентОжидает";
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда 
		Возврат "ПриемНачат";
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда 
		Возврат "ПриемОкончен";
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда 
		Возврат "ПриемНеСостоялся";
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда 
		Возврат "ПриемОтменен";
	КонецЕсли;
	
КонецФункции

// Функция - Получить роль пользователя
//
// Параметры:
//  Роль - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьРольПользователя(Роль)
	
	Если Роль = Перечисления.РольПользователя.Врач Тогда
		Возврат "Врач";
	ИначеЕсли Роль = Перечисления.РольПользователя.ГлавныйВрач Тогда 
		Возврат "ГлавныйВрач";
	ИначеЕсли Роль = Перечисления.РольПользователя.Регистратура Тогда 
		Возврат "Регистратура";
	ИначеЕсли Роль = Перечисления.РольПользователя.Руководитель Тогда 
		Возврат "Руководитель";
	ИначеЕсли Роль = Перечисления.РольПользователя.Управляющий Тогда 
		Возврат "Управляющий";
	КонецЕсли;
	
