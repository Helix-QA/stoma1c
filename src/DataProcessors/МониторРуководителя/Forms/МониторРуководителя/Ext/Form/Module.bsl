//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
		
	ПодключитьОбработчикОжидания("Подключаемый_ЗапуститьФоновоеЗаданиеПриОткрытии", 0.1, Истина);
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Выбрать структурную единицу.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВыбратьСтруктурнуюЕдиницу(Команда)
	
	ОповещениеПриЗакрытии = Новый ОписаниеОповещения("ВыборСтруктурнойЕдиницыЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.Форма.ФормаВыбора",,,,,, ОповещениеПриЗакрытии);
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Отчет выручка.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОткрытьОтчет(Команда)
	
	СвойстваОтчета = Новый Структура("ИмяОтчета, КлючВарианта");
	
	Отмененные = ?(СтрНайти(Команда.Имя, "Отмененные") <> 0, Истина, Ложь);
	
	СвойстваОтчета.КлючВарианта = СтрЗаменить(СтрЗаменить(Команда.Имя, "Отчет", ""), "Отмененные", ""); 
		
	СвойстваОтчета.ИмяОтчета = ?(СвойстваОтчета.КлючВарианта <> "ЗагрузкаРабочегоВремениВрача", "МониторРуководителя" + СвойстваОтчета.КлючВарианта, СвойстваОтчета.КлючВарианта);
	
	КомпоновщикНастроек = СформироватьКомпоновщикОтчетаСервер(СвойстваОтчета, ОтборСтруктурнаяЕдиница, ОтборПериодЗначение, Отмененные);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("КлючВарианта"					, СвойстваОтчета.КлючВарианта);
	ПараметрыФормы.Вставить("ПользовательскиеНастройки"		, КомпоновщикНастроек.ПользовательскиеНастройки);
	ПараметрыФормы.Вставить("СформироватьПриОткрытии"		, Истина); 
		
	ОткрытьФорму("Отчет." + СвойстваОтчета.ИмяОтчета +".Форма", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор);	
	
КонецПроцедуры

#КонецОбласти 

