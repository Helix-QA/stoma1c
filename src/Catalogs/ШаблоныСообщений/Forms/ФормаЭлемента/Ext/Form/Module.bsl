// Процедура - Процедура обработки нажатия меню
//
// Параметры:
//  АктивныйЭлементИмя	 - 	 - 
//  НЕАктивныйЭлементИмя - 	 - 
//
Процедура ПроцедураОбработкиНажатияМеню(АктивныйЭлементИмя, ПриОткрытииФормы = Ложь)
	
	Если ПриОткрытииФормы И НЕ Объект.Ссылка.Пустая() Тогда
		
		Если ЗначениеЗаполнено(СокрЛП(Объект.СодержаниеМессенджерHTML)) Тогда
			АктивныйЭлементИмя = "ШаблонМессенджера";			
			
		ИначеЕсли ЗначениеЗаполнено(СокрЛП(Объект.СодержаниеPush)) Тогда 
			АктивныйЭлементИмя = "ШаблонPush";
			
		ИначеЕсли ЗначениеЗаполнено(СокрЛП(Объект.Содержание)) Тогда 
			АктивныйЭлементИмя = "ШаблонSMS";
			
		ИначеЕсли ЗначениеЗаполнено(СокрЛП(Объект.ЗадачаОписание)) Тогда	
	        АктивныйЭлементИмя = "ШаблонЗадачи";
			
		ИначеЕсли ЗначениеЗаполнено(СокрЛП(ПисьмоТекстHTML)) Тогда
			АктивныйЭлементИмя = "ШаблонПисьма";
			
		КонецЕсли;
		
	КонецЕсли;			
	
	Элементы.ГруппаSMS.Видимость			 = (АктивныйЭлементИмя = "ШаблонSMS");
	Элементы.ГруппаPush.Видимость			 = (АктивныйЭлементИмя = "ШаблонPush");
	Элементы.ГруппаПисьмо.Видимость			 = (АктивныйЭлементИмя = "ШаблонПисьма");	
	Элементы.ГруппаЗадача.Видимость			 = (АктивныйЭлементИмя = "ШаблонЗадачи");
	Элементы.ГруппаМессенджер.Видимость		 = (АктивныйЭлементИмя = "ШаблонМессенджера");	
	Элементы.ГруппаПериодОтправки.Видимость	 = Элементы.ГруппаМессенджер.Видимость Или Элементы.ГруппаSMS.Видимость Или Элементы.ГруппаPush.Видимость;
	
	Элементы.СтатусВведенныхСимволов.Видимость = (АктивныйЭлементИмя = "ШаблонSMS");
	
	ЦветФонаАктивнойГруппы		 = Новый Цвет(242,242,242);
	ЦветФонаНеактивнойГруппы	 = Новый Цвет(255,255,255);
	ЦветТекстаАктивнойГруппы	 = Новый Цвет(51,51,51);
	ЦветТекстаНеактивнойГруппы	 = Новый Цвет(51,102,187);
	
	Элементы.ГруппаШаблонSMS.ЦветФона					 = ?((АктивныйЭлементИмя = "ШаблонSMS")			, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
	Элементы.ГруппаШаблонПисьма.ЦветФона				 = ?((АктивныйЭлементИмя = "ШаблонПисьма")		, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
	Элементы.ГруппаШаблонЗадача.ЦветФона				 = ?((АктивныйЭлементИмя = "ШаблонЗадачи")		, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
	Элементы.ГруппаШаблонPushУведомления.ЦветФона		 = ?((АктивныйЭлементИмя = "ШаблонPush")		, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
	Элементы.ГруппаШаблонСообщенияМессенджера.ЦветФона	 = ?((АктивныйЭлементИмя = "ШаблонМессенджера")	, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);	
	
	Элементы.ШаблонSMS.ЦветТекста			 = ?((АктивныйЭлементИмя = "ШаблонSMS")			, ЦветТекстаАктивнойГруппы, ЦветтекстаНеактивнойГруппы);
	Элементы.ШаблонPush.ЦветТекста			 = ?((АктивныйЭлементИмя = "ШаблонPush")		, ЦветТекстаАктивнойГруппы, ЦветтекстаНеактивнойГруппы);
	Элементы.ШаблонЗадачи.ЦветТекста		 = ?((АктивныйЭлементИмя = "ШаблонЗадачи")		, ЦветТекстаАктивнойГруппы, ЦветтекстаНеактивнойГруппы);
	Элементы.ШаблонПисьма.ЦветТекста		 = ?((АктивныйЭлементИмя = "ШаблонПисьма")		, ЦветТекстаАктивнойГруппы, ЦветтекстаНеактивнойГруппы);
	Элементы.ШаблонМессенджера.ЦветТекста	 = ?((АктивныйЭлементИмя = "ШаблонМессенджера")	, ЦветТекстаАктивнойГруппы, ЦветтекстаНеактивнойГруппы);
		
КонецПроцедуры

&НаКлиенте
// Процедура, вставляет параметр в элемент формы. 
//
Процедура ВставитьПараметр(Результат, ОбъектПоля, ЭлементПоля, УстановитьШрифт = Ложь)
	
	// Инициализация
	Начало = 0; Конец = 0; Вставка = Результат;
	
	// Получаем в переменные Начало и Конец границы выделения
	ЭлементПоля.ПолучитьГраницыВыделения(Начало, Конец);
	
	// Вставляем текст в начало границы выделения
	ВставленныйТекст = ОбъектПоля.Вставить(Начало, Вставка);
	
	// Устанавливаем жирный шрифт
	Если УстановитьШрифт Тогда		
		ВставленныйТекст.Шрифт = Новый Шрифт(,,Истина);
	КонецЕсли;
	
	// После текста "Вставки" вставляем пробел
	ВставленныйТекст = ОбъектПоля.Вставить(ВставленныйТекст.ЗакладкаКонца, " ");
	
	// Возвращаем шрифт установленный для редактора
	ВставленныйТекст.Шрифт = ЭлементПоля.Шрифт;
	
	// Возвращаем фокус на редактор
	ЭтаФорма.ТекущийЭлемент = ЭлементПоля;
	
	// Устанавливаем курсор в конец вставленного текста
	ЭлементПоля.УстановитьГраницыВыделения(ВставленныйТекст.ЗакладкаКонца, ВставленныйТекст.ЗакладкаКонца);		

КонецПроцедуры

&НаСервере
// Процедура, устанавливет текст шаблона
//
Процедура УстановитьТекстШаблона(ТекущийОбъект, СписокФайлов = Неопределено)
	
	УстановитьHTMLДляФорматированногоДокумента(ТекущийОбъект.ТекстHTML, ТекущийОбъект.Ссылка, СписокФайлов);

КонецПроцедуры

&НаСервере
// Процедура, устанавливет HTML для форматированного документа
//
Процедура УстановитьHTMLДляФорматированногоДокумента(ТекстШаблонаПисьмаHTML, СсылкаНаТекущийОбъект, СписокФайлов = Неопределено)
	
	ПараметрШаблона = Новый Структура("Шаблон, УникальныйИдентификатор");
	ПараметрШаблона.Шаблон = СсылкаНаТекущийОбъект;
	ПараметрШаблона.УникальныйИдентификатор = УникальныйИдентификатор;
	Сообщение = КонструкторСообщения();
	Сообщение.Текст = ТекстШаблонаПисьмаHTML;
	ОбработатьHTMLДляФорматированногоДокумента(ПараметрШаблона, Сообщение, Истина, СписокФайлов);
	СтруктураВложений = Новый Структура();
	Если СписокФайлов <> Неопределено Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ИдентификаторФормы", УникальныйИдентификатор);
		ДополнительныеПараметры.Вставить("ВызыватьИсключение", Ложь);
		
		Для каждого Вложение Из СписокФайлов Цикл
				Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.РаботаСФайлами") Тогда
					Если ЗначениеЗаполнено(Вложение.Наименование) И Не Вложение.ПометкаУдаления Тогда
						МодульРаботаСФайлами = ОбщегоНазначения.ОбщийМодуль("РаботаСФайлами");
						СведенияОФайле = РаботаСФайлами.ДанныеФайла(Вложение, ДополнительныеПараметры);
						Изображение = Новый Картинка(ПолучитьИзВременногоХранилища(СведенияОФайле.СсылкаНаДвоичныеДанныеФайла));
						СтруктураВложений.Вставить(СведенияОФайле.Наименование, Изображение);
					КонецЕсли;
				КонецЕсли;
		КонецЦикла;
	Иначе
		Для каждого ВложениеВHTML Из Сообщение.Вложения Цикл
			Изображение = Новый Картинка(ПолучитьИзВременногоХранилища(ВложениеВHTML.АдресВоВременномХранилище));
			СтруктураВложений.Вставить(ВложениеВHTML.Представление, Изображение);
		КонецЦикла;
	КонецЕсли;
	ПисьмоТекстHTML.УстановитьHTML(Сообщение.Текст , СтруктураВложений);
		
КонецПроцедуры

&НаСервере
// Функция, создает структуру сообщения
//
Функция КонструкторСообщения(ПараметрыШаблона = Неопределено)
	
	Сообщение = Новый Структура();
	Сообщение.Вставить("Тема", "");
	Сообщение.Вставить("Текст", "");
	Сообщение.Вставить("Получатель", Неопределено);
	Сообщение.Вставить("ДополнительныеПараметры",
		?(ПараметрыШаблона <> Неопределено, ПараметрыШаблона, Новый Структура()));
	Сообщение.Вставить("СообщенияПользователю", Новый ФиксированныйМассив(Новый Массив()));
	
	ТипСтрока = Новый ОписаниеТипов("Строка");
	Вложения1 = Новый ТаблицаЗначений;
	Вложения1.Колонки.Добавить("Представление", ТипСтрока);
	Вложения1.Колонки.Добавить("АдресВоВременномХранилище", ТипСтрока);
	Вложения1.Колонки.Добавить("Кодировка", ТипСтрока);
	Вложения1.Колонки.Добавить("Идентификатор", ТипСтрока);
	Сообщение.Вставить("Вложения", Вложения1);
	
	Если ПараметрыШаблона <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Сообщение, ПараметрыШаблона);
	КонецЕсли;
	
	Возврат Сообщение;
КонецФункции

&НаСервере
// Обрабатывает текст HTML для помещения в форматированный документ.
//
Процедура ОбработатьHTMLДляФорматированногоДокумента(ПараметрыШаблона, СформированноеСообщение, ПреобразовыватьHTMLДляФорматированногоДокумента, СписокФайлов = Неопределено)

	Если ПустаяСтрока(СформированноеСообщение.Текст) Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.РаботаСФайлами") Тогда
		МодульРаботаСФайлами = ОбщегоНазначения.ОбщийМодуль("РаботаСФайлами");
		
		Если СписокФайлов = Неопределено Тогда
			СписокФайлов = Новый Массив;
			МодульРаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(ПараметрыШаблона.Шаблон, СписокФайлов);
		КонецЕсли;
		
		ДокументHTML = Гипертекст.ПолучитьОбъектДокументHTMLИзТекстаHTML(СформированноеСообщение.Текст);
		Для каждого Картинка Из ДокументHTML.Картинки Цикл
			
			АтрибутИсточникКартинки = Картинка.Атрибуты.ПолучитьИменованныйЭлемент("src");
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ИдентификаторФормы", ПараметрыШаблона.УникальныйИдентификатор);
			ДополнительныеПараметры.Вставить("ВызыватьИсключение", Ложь);
			
			ИзображениеОтсутствуетВПрисоединенныхФайлах = Истина;
			Для Каждого ПрисоединенныйФайл Из СписокФайлов Цикл
				Проверка = Сред(СтрЗаменить(ПрисоединенныйФайл.Наименование, "_", "-"), 2);
				Если СтрЧислоВхождений(АтрибутИсточникКартинки.Значение, Проверка) > 0 Тогда
					ДанныеФайла = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл.Ссылка, ДополнительныеПараметры);
					ОбработатьКартинкуВТекстеHTMLДляФорматированногоДокумента(Картинка, ДанныеФайла, СформированноеСообщение, 
					АтрибутИсточникКартинки, ПрисоединенныйФайл.Наименование, ПрисоединенныйФайл.Наименование);
					ИзображениеОтсутствуетВПрисоединенныхФайлах = Ложь;
					Прервать;
				ИначеЕсли СтрНачинаетсяС(АтрибутИсточникКартинки.Значение, "cid:" + Проверка) Тогда
					НайденнаяСтрока = СформированноеСообщение.Вложения.Найти(ПрисоединенныйФайл.Наименование, "Представление");
					Если НайденнаяСтрока <> Неопределено Тогда
						СформированноеСообщение.Вложения.Удалить(НайденнаяСтрока);
					КонецЕсли;
					
					ДанныеФайла = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл.Ссылка, ДополнительныеПараметры);
					ОбработатьКартинкуВТекстеHTMLДляФорматированногоДокумента(Картинка, ДанныеФайла, СформированноеСообщение,
						АтрибутИсточникКартинки, ПрисоединенныйФайл.Наименование, ПрисоединенныйФайл.Наименование);
					ИзображениеОтсутствуетВПрисоединенныхФайлах = Ложь;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если ИзображениеОтсутствуетВПрисоединенныхФайлах Тогда
				ИмяКартинки = Сред(АтрибутИсточникКартинки.Значение, 5);
				НайденнаяСтрока = СформированноеСообщение.Вложения.Найти(ИмяКартинки, "Представление");
				Если НайденнаяСтрока <> Неопределено Тогда
					ДвоичныеДанные = ПолучитьИзВременногоХранилища(НайденнаяСтрока.АдресВоВременномХранилище);
					АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, ПараметрыШаблона.УникальныйИдентификатор);
					
					НайденнаяСтрока.Идентификатор = ИмяКартинки;
					НайденнаяСтрока.АдресВоВременномХранилище = АдресВоВременномХранилище;
					НовыйАтрибутКартинки = АтрибутИсточникКартинки.КлонироватьУзел(Ложь);
					НовыйАтрибутКартинки.ТекстовоеСодержимое = ИмяКартинки;
					Картинка.Атрибуты.УстановитьИменованныйЭлемент(НовыйАтрибутКартинки);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если ПреобразовыватьHTMLДляФорматированногоДокумента Тогда
			ТекстHTML = Гипертекст.ПолучитьТекстHTMLИзОбъектаДокументHTML(ДокументHTML);
			СформированноеСообщение.Текст = ТекстHTML;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обрабатывает картинку в тексте HTML
//
Процедура ОбработатьКартинкуВТекстеHTMLДляФорматированногоДокумента(Картинка, ПрисоединенныйФайл, СформированноеСообщение, АтрибутИсточникКартинки, Представление, Идентификатор)
	
	НовыйАтрибутКартинки = АтрибутИсточникКартинки.КлонироватьУзел(Ложь);
	НовыйАтрибутКартинки.ТекстовоеСодержимое = ПрисоединенныйФайл.Наименование;
	Картинка.Атрибуты.УстановитьИменованныйЭлемент(НовыйАтрибутКартинки);
	
	НовоеВложение = СформированноеСообщение.Вложения.Добавить();
	НовоеВложение.Представление = Представление + ".jpg";
	НовоеВложение.АдресВоВременномХранилище = ПрисоединенныйФайл.СсылкаНаДвоичныеДанныеФайла;
	НовоеВложение.Идентификатор = Идентификатор + ".jpg";

КонецПроцедуры

&НаСервере
// Процедура, заменяет имена картинок на идентификаторы
//
Процедура ЗаменитьИменаКартинокНаИдентификаторыПочтовыхВложенийВHTML(ДокументHTML, ТаблицаСоответствий)
	
	Для каждого Картинка Из ДокументHTML.Картинки Цикл
		
		АтрибутИсточникКартинки = Картинка.Атрибуты.ПолучитьИменованныйЭлемент("src");
		НайденнаяСтрока = ТаблицаСоответствий.НайтиПоЗначению(АтрибутИсточникКартинки.ТекстовоеСодержимое);
		Если НайденнаяСтрока <> Неопределено Тогда
			
			НовыйАтрибутКартинки = АтрибутИсточникКартинки.КлонироватьУзел(Ложь);
			НовыйАтрибутКартинки.ТекстовоеСодержимое = Строка("cid:" + НайденнаяСтрока.Представление);
			Картинка.Атрибуты.УстановитьИменованныйЭлемент(НовыйАтрибутКартинки);
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Сохраняет картинки форматированного документа как присоединенные файлы объекта.
//
// Параметры:
//  Ссылка  - ДокументСсылка - ссылка на владельца присоединенных файлов.
//  ТипТекстаПисьма  - Перечисление.СпособыРедактированияЭлектронныхПисем - для определения необходимости выполнения преобразований.
//  ТаблицаСоответствийИменВложенийИдентификаторам  - ТаблицаЗначений - позволяет определить какому вложению
//                                                                      соответствует какая картинка.
//  УникальныйИдентификатор  - УникальныйИдентификатор - уникальный идентификатор формы из которого выполняется сохранение.
//
Процедура СохранитьКартинкиФорматированногоДокументаКакПрисоединенныеФайлы(Ссылка, ТаблицаСоответствийИменВложенийИдентификаторам, УникальныйИдентификатор)
			
	Для каждого Вложение Из ТаблицаСоответствийИменВложенийИдентификаторам Цикл
		
		Вложение.Представление = Вложение.Представление + ".jpg";
		ДвоичныеДанныеКартинки = Вложение.Картинка.ПолучитьДвоичныеДанные();
		АдресКартинкиВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеКартинки, УникальныйИдентификатор);
		ПрисоединенныйФайл = УправлениеЭлектроннойПочтой.ЗаписатьВложениеЭлектронногоПисьмаИзВременногоХранилища(Ссылка, АдресКартинкиВоВременномХранилище,
		"_" + СтрЗаменить(Вложение.Представление, "-", "_"), ДвоичныеДанныеКартинки.Размер());
		
		Если ПрисоединенныйФайл <> Неопределено Тогда
			ПрисоединенныйФайлОбъект = ПрисоединенныйФайл.ПолучитьОбъект();
			ПрисоединенныйФайлОбъект.ИДФайлаЭлектронногоПисьма = Вложение.Представление;
			ПрисоединенныйФайлОбъект.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, удаляет присоедененный файл
//
Процедура УдалитьПрисоединенныйФайл(ПрисоединенныйФайл)
	ОбъектВложение = ПрисоединенныйФайл.ПолучитьОбъект();
	УстановитьПривилегированныйРежим(Истина);
	ОбъектВложение.Удалить();
КонецПроцедуры

