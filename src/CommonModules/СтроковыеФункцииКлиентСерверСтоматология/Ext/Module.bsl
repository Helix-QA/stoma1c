// Функция сортирует массив строк с указанным направлением сортировки
Функция СортироватьМассивСтрок(МассивСтрок,Напрвление = "Возр") Экспорт
	
	ТаблицаСортировки = Новый ТаблицаЗначений;
	ТаблицаСортировки.Колонки.Добавить("Значения",Новый ОписаниеТипов("Строка"));
	Для Каждого ЭлементМ ИЗ МассивСтрок Цикл
		НоваяСтрока          = ТаблицаСортировки.Добавить();
		НоваяСтрока.Значения = ЭлементМ;
	КонецЦикла;		
	ТаблицаСортировки.Сортировать("Значения" + " " + Напрвление);
	Возврат ТаблицаСортировки.ВыгрузитьКолонку("Значения");
	
КонецФункции

