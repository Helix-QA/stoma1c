
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("МассивРазделовОтбора") Тогда
		ЭтотОбъект.СписокРазделовОтбора.ЗагрузитьЗначения(Параметры.МассивРазделовОтбора);
	КонецЕсли;
	
	СформироватьДинамическиеЭлементыВнешнихСистем();
	Элементы.РазделДляКопирования.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаписанаВнешняяСистема" Тогда
		ДобавитьЭлементыВнешнейСистемы(Параметр.ВнешняяСистема, ПолучитьРазделВнешнейСистемы(Параметр.ТипВнешнейСистемы));
		ОбновитьЗаголовкиЭлементов(Параметр.ВнешняяСистема);
	ИначеЕсли ИмяСобытия = "УдаленаВнешняяСистема" Тогда
   		УдалитьЭлементыВнешнейСистемы(Параметр.ВнешняяСистема, ПолучитьРазделВнешнейСистемы(Параметр.ТипВнешнейСистемы));
		СформироватьДинамическиеЭлементыВнешнихСистем();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКоманд

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ДобавитьВнешнююСистему(Команда)
	
	ПараметрыОткрытия = Новый Структура("МассивРазделовОтбора", ЭтотОбъект.СписокРазделовОтбора.ВыгрузитьЗначения());
	ОткрытьФорму("Справочник.ВнешниеСистемы.Форма.ФормаДобавленияВнешнейСистемы", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОткрытьНастройкиВнешнейСистемы(Команда)
	
	ДанныеВнешнейСистемы = ПолучитьДанныеВСПоИмениЭлемента(ЭтотОбъект.ТекущийЭлемент.Имя);
	
	Если ЗначениеЗаполнено(ДанныеВнешнейСистемы) Тогда
		ОткрытьФорму("Справочник.ВнешниеСистемы.ФормаОбъекта", Новый Структура("Ключ", ДанныеВнешнейСистемы.ВнешняяСистема),,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура УдалитьВнешнююСистему(Команда)
	
	ДанныеВнешнейСистемы = ПолучитьДанныеВСПоИмениЭлемента(ЭтотОбъект.ТекущийЭлемент.Имя);
	
	Если ЗначениеЗаполнено(ДанныеВнешнейСистемы) Тогда
		
		ПараметрыОповещения	 = Новый Структура("ДанныеВнешнейСистемы, Действие", ДанныеВнешнейСистемы, "Удалить");
		ОписаниеОповещения	 = Новый ОписаниеОповещения("ПослеВопросаОбУдаленииОтключении", ЭтотОбъект, ПараметрыОповещения);
		Если ПолучитьЗначениеРеквизитаВнешнейСистемы(ДанныеВнешнейСистемы.ВнешняяСистема, "ПометкаУдаления") = Истина Тогда
			ТекстВопроса = СтрШаблон(НСтр("ru = 'Снять с ""%1"" пометку на удаление?'"), Строка(ДанныеВнешнейСистемы.ВнешняяСистема));
		Иначе
			ТекстВопроса = СтрШаблон(НСтр("ru = 'Пометить ""%1"" на удаление?'"), Строка(ДанныеВнешнейСистемы.ВнешняяСистема));
		КонецЕсли;
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОтключитьВнешнююСистему(Команда)
	
	ДанныеВнешнейСистемы = ПолучитьДанныеВСПоИмениЭлемента(ЭтотОбъект.ТекущийЭлемент.Имя);
	
	Если ЗначениеЗаполнено(ДанныеВнешнейСистемы) Тогда
		
		ПараметрыОповещения	 = Новый Структура("ДанныеВнешнейСистемы, Действие", ДанныеВнешнейСистемы, "Отключить");
		ОписаниеОповещения	 = Новый ОписаниеОповещения("ПослеВопросаОбУдаленииОтключении", ЭтотОбъект, ПараметрыОповещения);
		Если ПолучитьЗначениеРеквизитаВнешнейСистемы(ДанныеВнешнейСистемы.ВнешняяСистема, "Используется") = Истина Тогда
			ТекстВопроса = СтрШаблон(НСтр("ru = 'Внешняя система будет отмечена неиспользуемой. Отключить ""%1""?'"), Строка(ДанныеВнешнейСистемы.ВнешняяСистема));
		Иначе
			ТекстВопроса = СтрШаблон(НСтр("ru = 'Внешняя система будет отмечена используемой. Включить ""%1""?'"), Строка(ДанныеВнешнейСистемы.ВнешняяСистема));
		КонецЕсли;	
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область СозданиеДинамическихЭлементовФормы

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура СформироватьДинамическиеЭлементыВнешнихСистем()
	
	МассивВС = ПолучитьВнешниеСистемы();
	
	Для Каждого ВнешняяСистема Из МассивВС Цикл 
		Если ВнешняяСистема.ТипВнешнейСистемы <> Перечисления.ТипыВнешнихСистем.МобильноеПриложениеУправляющего Тогда
			ДобавитьЭлементыВнешнейСистемы(ВнешняяСистема, ПолучитьРазделВнешнейСистемы(ВнешняяСистема.ТипВнешнейСистемы));  
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура ДобавитьЭлементыВнешнейСистемы(ВнешняяСистема, Раздел)
	
	Если СписокРазделовОтбора.Количество() > 0 И СписокРазделовОтбора.НайтиПоЗначению(Раздел) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.Найти(Раздел) = Неопределено Тогда
		СоздатьРазделВнешнихСистем(Раздел);
	КонецЕсли;
	
	СоздатьЭлементыВнешнейСистемы(ВнешняяСистема, Раздел);
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура СоздатьЭлементыВнешнейСистемы(ВнешняяСистема, Раздел)
	
	Если ЗначениеЗаполнено(ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("ВнешняяСистема", ВнешняяСистема))) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаРаздела		 = НайтиСоздатьСтрокуРаздела(Раздел);
	ГруппаВнешнейСистемы = СоздатьГруппуВнешнейСистемы(СтрокаРаздела);
	
	СоздатьДекорациюКартинка(ВнешняяСистема, ГруппаВнешнейСистемы);
	СоздатьДекорациюОписание(ВнешняяСистема, ГруппаВнешнейСистемы);
	//ДобавитьКнопкиУправления(ВнешняяСистема, ГруппаВнешнейСистемы);
	ДобавитьКнопкуНастройки(ГруппаВнешнейСистемы);
	
	НоваяСтрока					 = ЭтотОбъект.ТаблицаВнешнихСистем.Добавить();
	НоваяСтрока.ВнешняяСистема	 = ВнешняяСистема;
	НоваяСтрока.ИмяЭлементаФормы = ГруппаВнешнейСистемы.Имя;
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура СоздатьРазделВнешнихСистем(Раздел)
	
	НовыйРаздел		 = Элементы.Добавить(Раздел, Тип("ГруппаФормы"), Элементы.ГруппаРазделы);
	НовыйРаздел.Вид	 = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(НовыйРаздел, Элементы.РазделДляКопирования,, "ПутьКДаннымЗаголовка, Заголовок, Видимость");
	
	НовыйРаздел.Заголовок = ПолучитьЗаголовокРаздела(Раздел);
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Функция НайтиСоздатьСтрокуРаздела(Раздел)
	
	ИндексСтроки = 0;
	Для Каждого СтрокаРаздела Из Элементы[Раздел].ПодчиненныеЭлементы Цикл
		Если СтрокаРаздела.ПодчиненныеЭлементы.Количество() < 4 Тогда // количество внешних систем в строке
			Возврат СтрокаРаздела;
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Возврат СоздатьСтрокуРаздела(Раздел, ИндексСтроки);
	
КонецФункции

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Функция СоздатьСтрокуРаздела(Раздел, ИндексСтроки)
	
	НоваяСтрока		 = Элементы.Добавить(Раздел + "_Строка_" + ИндексСтроки, Тип("ГруппаФормы"), Элементы[Раздел]);
	НоваяСтрока.Вид	 = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Элементы.РазделДляКопирования_Строка_0,, "ПутьКДаннымЗаголовка, Видимость");
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Функция СоздатьГруппуВнешнейСистемы(СтрокаРаздела)
	
	ГруппаВнешнейСистемы	 = Элементы.Добавить(СтрокаРаздела.Имя + "_Элемент_" + СтрокаРаздела.ПодчиненныеЭлементы.Количество(), Тип("ГруппаФормы"), СтрокаРаздела);
	ГруппаВнешнейСистемы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(ГруппаВнешнейСистемы, Элементы.РазделДляКопирования_Строка_0_Элемент_0,, "ПутьКДаннымЗаголовка, Видимость");
	
	Возврат ГруппаВнешнейСистемы;
	
КонецФункции

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура СоздатьДекорациюКартинка(ВнешняяСистема, ГруппаРодитель)
	
	Декорация	  = Элементы.Добавить(ГруппаРодитель.Имя + "_ДекорацияКартинка", Тип("ДекорацияФормы"), ГруппаРодитель);
	Декорация.Вид = ВидДекорацииФормы.Картинка;
	ЗаполнитьЗначенияСвойств(Декорация, Элементы.РазделДляКопирования_Строка_0_Элемент_0_ДекорацияКартинка,, "Картинка, Видимость");
	
	Декорация.Картинка = ПолучитьКартинкуВнешнейСистемы(ВнешняяСистема.ТипВнешнейСистемы);
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура СоздатьДекорациюОписание(ВнешняяСистема, ГруппаРодитель)
	
	Декорация	  = Элементы.Добавить(ГруппаРодитель.Имя + "_ДекорацияНадпись", Тип("ДекорацияФормы"), ГруппаРодитель);
	Декорация.Вид = ВидДекорацииФормы.Надпись;
	ЗаполнитьЗначенияСвойств(Декорация, Элементы.РазделДляКопирования_Строка_0_Элемент_0_ДекорацияНадпись,, "Заголовок, Видимость");
	
	Декорация.Заголовок = ПолучитьОписаниеВнешнейСистемы(ВнешняяСистема);
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы кнопок.
//
Процедура ДобавитьКнопкиУправления(ВнешняяСистема, ГруппаРодитель)
	
	ГруппаКнопокУправления		 = Элементы.Добавить(ГруппаРодитель.Имя + "_КнопкиУправления", Тип("ГруппаФормы"), ГруппаРодитель);
	ГруппаКнопокУправления.Вид	 = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(ГруппаКнопокУправления, Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкиУправления,, "ПутьКДаннымЗаголовка, Видимость");
	
	ГруппаКнопкиУдалить		 = Элементы.Добавить(ГруппаРодитель.Имя + "_ГруппаУдалить", Тип("ГруппаФормы"), ГруппаКнопокУправления);
	ГруппаКнопкиУдалить.Вид	 = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(ГруппаКнопкиУдалить, Элементы.РазделДляКопирования_Строка_0_Элемент_0_ГруппаУдалить,, "ПутьКДаннымЗаголовка, Видимость");
	
	КнопкаУдалить			 = Элементы.Добавить(ГруппаРодитель.Имя + "_КнопкаУдалить", Тип("КнопкаФормы"), ГруппаКнопкиУдалить);
	КнопкаУдалить.Вид		 = ВидКнопкиФормы.ОбычнаяКнопка;
	КнопкаУдалить.Заголовок	 = ?(ВнешняяСистема.ПометкаУдаления, НСтр("ru = 'Удалена'; en = 'Removed'"), НСтр("ru = 'Удалить'; en = 'Delete'"));
	ЗаполнитьЗначенияСвойств(КнопкаУдалить, Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкаУдалить,, "Видимость, Заголовок");
	
	ГруппаКнопкиОтключить		 = Элементы.Добавить(ГруппаРодитель.Имя + "_ГруппаОтключить", Тип("ГруппаФормы"), ГруппаКнопокУправления);
	ГруппаКнопкиОтключить.Вид	 = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(ГруппаКнопкиОтключить, Элементы.РазделДляКопирования_Строка_0_Элемент_0_ГруппаОтключить,, "ПутьКДаннымЗаголовка, Видимость");
	
	КнопкаОтключить				 = Элементы.Добавить(ГруппаРодитель.Имя + "_КнопкаОтключить", Тип("КнопкаФормы"), ГруппаКнопкиОтключить);
	КнопкаОтключить.Вид			 = ВидКнопкиФормы.ОбычнаяКнопка;
	КнопкаОтключить.Заголовок	 = ?(ВнешняяСистема.Используется, НСтр("ru = 'Отключить'; en = 'Disable'"), НСтр("ru = 'Включить'; en = 'Enable'"));
	ЗаполнитьЗначенияСвойств(КнопкаОтключить, Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкаОтключить,, "Видимость, Заголовок");
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет на форму динамические элементы внешних систем.
//
Процедура ДобавитьКнопкуНастройки(ГруппаРодитель)
	
	ГруппаКнопки	 = Элементы.Добавить(ГруппаРодитель.Имя + "_ГруппаНастройки", Тип("ГруппаФормы"), ГруппаРодитель);
	ГруппаКнопки.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ЗаполнитьЗначенияСвойств(ГруппаКнопки, Элементы.РазделДляКопирования_Строка_0_Элемент_0_ГруппаНастройки,, "ПутьКДаннымЗаголовка, Видимость");
	
	Кнопка		 = Элементы.Добавить(ГруппаРодитель.Имя + "_КнопкаНастройки", Тип("КнопкаФормы"), ГруппаКнопки);
	Кнопка.Вид	 = ВидКнопкиФормы.ОбычнаяКнопка;
	ЗаполнитьЗначенияСвойств(Кнопка, Элементы.РазделДляКопирования_Строка_0_Элемент_0_КнопкаНастройки,, "Видимость");
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
// Процедура, обработчик асинхронного события.
//
Процедура ПослеВопросаОбУдаленииОтключении(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ПослеВопросаОбУдаленииОтключенииСервер(ДополнительныеПараметры.Действие, ДополнительныеПараметры.ДанныеВнешнейСистемы);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик асинхронного события на сервере.
//
Процедура ПослеВопросаОбУдаленииОтключенииСервер(Действие, ДанныеВнешнейСистемы)
	
	Если Действие = "Удалить" Тогда
		ПометитьНаУдаление(ДанныеВнешнейСистемы);
	ИначеЕсли Действие = "Отключить" Тогда
		УстановитьАктивность(ДанныеВнешнейСистемы);
	КонецЕсли;
	
	ОбновитьЗаголовкиЭлементов(ДанныеВнешнейСистемы);
	
КонецПроцедуры

&НаСервере
// Процедура, обновляет заголовки элементов и данные в таблице ВС.
//
Процедура ОбновитьЗаголовкиЭлементов(ДанныеВнешнейСистемы)
	
	Если Не ЗначениеЗаполнено(ДанныеВнешнейСистемы) Тогда
		Возврат;
	ИначеЕсли ТипЗнч(ДанныеВнешнейСистемы) = Тип("СправочникСсылка.ВнешниеСистемы") Тогда
		ДанныеВнешнейСистемы = ПолучитьДанныеВСПоВнешнейСистеме(ДанныеВнешнейСистемы);
	КонецЕсли;
	
