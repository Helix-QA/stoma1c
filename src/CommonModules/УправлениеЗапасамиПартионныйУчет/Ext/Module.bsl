
#Область СлужебныйПрограммныйИнтерфейс

// Процедура формирует таблицу движений по регистру накопления ПартииТоваров
// Параметры:
// 		ТаблицаСписанияНоменклатуры - Таблица или табличная часть с номенклатурой;
//		СтруктураДополнительныеСвойства - структура, дополнительные свойства;
//      Движения - Движения документа по регистрам;
//      Отказ    - Отказ продедения;
Процедура СформироватьСписаниеТаблицаПартииТоваров(ТаблицаСписанияНоменклатуры, СтруктураДополнительныеСвойства, Движения, Отказ) Экспорт
	
	НаборДвижений   = Движения.ПартииТоваров;
    ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки("НомерСтроки,Период, ВидДвижения, ДокументПоступления, Номенклатура, Склад, СтруктурнаяЕдиница, Партия, Количество, Стоимость");
	
	Если  СтруктураДополнительныеСвойства.ДляПроведения.Свойство("ВыполнятьДвиженияСебестоимость") Тогда
		НаборДвижений   = Движения.ПродажиСебестоимость;
		ТаблицаДвиженийПродажи = НаборДвижений.ВыгрузитьКолонки("НомерСтроки,Период, Контрагент, ДокументПродажи, Номенклатура, Склад, Партия, СтруктурнаяЕдиница, Сотрудник, Ассистент, ЗубнойТехник, Материал, Количество, Стоимость");
	КонецЕсли;
	
	СпособОценкиМПЗ = Константы.СпособОценкиМПЗ.Получить();
	Если Не ЗначениеЗаполнено(СпособОценкиМПЗ) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена стратегия списания партий товаров!");
        СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПартииТоваров", ТаблицаДвижений);
		Если  СтруктураДополнительныеСвойства.ДляПроведения.Свойство("ВыполнятьДвиженияСебестоимость") Тогда
			  СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПродажиСебестоимость", ТаблицаДвиженийПродажи);
        КонецЕсли;
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТаблицаНоменклатуры = ПодготовитьТалицуКСписаниюОприходованиюПартий(ТаблицаСписанияНоменклатуры,СтруктураДополнительныеСвойства);			
	ТаблицаНоменклатуры.Сортировать("ОснованиеВозврата Возр");
	
	ЗапросПоПартиям = ПолучитьЗапросПартийДляСписания(СпособОценкиМПЗ);
	МенеджерВременнойТаблицы = ВыбратьТЗВВременнуюТаблицу(ТаблицаНоменклатуры, "ТаблицаНоменклатуры");
	Граница = Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.ссылка.МоментВремени(), ВидГраницы.Исключая); 
	ЗапросПоПартиям.УстановитьПараметр("Дата", Граница);
	ЗапросПоПартиям.УстановитьПараметр("Регистратор", СтруктураДополнительныеСвойства.ДляПроведения.ссылка);
	ЗапросПоПартиям.МенеджерВременныхТаблиц = МенеджерВременнойТаблицы;     
	ОстаткиПартий = ЗапросПоПартиям.Выполнить().Выгрузить();
    Таблица = Новый ТаблицаЗначений;	
    НеКонтроллироватьОстатки = Константы.НеКонтроллироватьОстатки.Получить();
	
	Счетчик = 0;
    Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл 		
			
		ОсталосьСписатьКоличество = СтрокаНоменклатуры.Количество;
		
		Если ОсталосьСписатьКоличество <=0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОтборПоНоменклатуре = Новый Структура("Номенклатура, СтруктурнаяЕдиница, Склад, Партия", СтрокаНоменклатуры.Номенклатура, СтрокаНоменклатуры.СтруктурнаяЕдиница, СтрокаНоменклатуры.Склад, СтрокаНоменклатуры.Партия );
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.ОснованиеВозврата) Тогда
			ОтборПоНоменклатуре.Вставить("ДокументПоступления", СтрокаНоменклатуры.ОснованиеВозврата)
		КонецЕсли;
		НоменклатураТаблицаПартий = ОстаткиПартий.НайтиСтроки(ОтборПоНоменклатуре);		
		
		НомерПартии = 0;
		Пока ОсталосьСписатьКоличество > 0 И НомерПартии < (НоменклатураТаблицаПартий.Количество())  Цикл
			ТекущаяПартия = НоменклатураТаблицаПартий[НомерПартии];
			Если ТекущаяПартия.Количество > 0 Тогда
			  	СписываемоеКоличество = ?( ОсталосьСписатьКоличество <= ТекущаяПартия.Количество, ОсталосьСписатьКоличество, ТекущаяПартия.Количество);	
				
				НоваяСтрока                     = ТаблицаДвижений.Добавить();
				НоваяСтрока.Период              = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
				НоваяСтрока.ВидДвижения         = ВидДвиженияНакопления.Расход;
				НоваяСтрока.ДокументПоступления = ТекущаяПартия.ДокументПоступления;
				НоваяСтрока.Номенклатура        = ТекущаяПартия.Номенклатура;
				НоваяСтрока.СтруктурнаяЕдиница  = ТекущаяПартия.СтруктурнаяЕдиница;
				НоваяСтрока.Склад               = ТекущаяПартия.Склад;
				НоваяСтрока.Партия              = ТекущаяПартия.Партия;
				НоваяСтрока.Количество          = СписываемоеКоличество;	
				
				Если СпособОценкиМПЗ = Перечисления.СпособОценки.ПоСредней Тогда
					Если (НомерПартии = НоменклатураТаблицаПартий.Количество()-1)
						И (ТекущаяПартия.Количество = СписываемоеКоличество) Тогда
						СтоимостьСредняя =0;
						Для Каждого СтрокаМассив Из НоменклатураТаблицаПартий Цикл   			
							СтоимостьСредняя = СтоимостьСредняя   + СтрокаМассив.Стоимость;
						КонецЦикла;	
						НоваяСтрока.Стоимость = СтоимостьСредняя;	 						
					Иначе
						НоваяСтрока.Стоимость = ТекущаяПартия.Цена * СписываемоеКоличество;
					КонецЕсли;
				Иначе
					Если СписываемоеКоличество = ТекущаяПартия.Количество Тогда
						НоваяСтрока.Стоимость = ТекущаяПартия.Стоимость;                     
					Иначе
						НоваяСтрока.Стоимость = СписываемоеКоличество * (ТекущаяПартия.Стоимость / ?(ТекущаяПартия.Количество = 0, 1, ТекущаяПартия.Количество));				
					КонецЕсли;
				КонецЕсли;
				
				Если СтруктураДополнительныеСвойства.ДляПроведения.Свойство("ВыполнятьДвиженияСебестоимость")
					И (СтрокаНоменклатуры.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас
					ИЛИ СтрокаНоменклатуры.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал) Тогда
					мНоваяСтрока = ТаблицаДвиженийПродажи.Добавить();
					мНоваяСтрока.ДокументПродажи    = СтрокаНоменклатуры.ДокументПродажиСебестоимость;
					мНоваяСтрока.Период             = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
					мНоваяСтрока.СтруктурнаяЕдиница = СтрокаНоменклатуры.СтруктурнаяЕдиница;
					мНоваяСтрока.Контрагент         = СтрокаНоменклатуры.Контрагент;
					Если ЗначениеЗаполнено(СтрокаНоменклатуры.Услуга) Тогда
						мНоваяСтрока.Номенклатура = СтрокаНоменклатуры.Услуга;
						мНоваяСтрока.Материал     = ТекущаяПартия.Номенклатура;
						мНоваяСтрока.Склад        = Справочники.Склады.ПустаяСсылка();
					Иначе
						мНоваяСтрока.Номенклатура       = ТекущаяПартия.Номенклатура;
						мНоваяСтрока.Склад              = ТекущаяПартия.Склад;
					КонецЕсли;
					мНоваяСтрока.Партия             = ТекущаяПартия.Партия;
					мНоваяСтрока.Количество         = СписываемоеКоличество;
					мНоваяСтрока.Сотрудник          = СтрокаНоменклатуры.Сотрудник;
					мНоваяСтрока.Ассистент          = СтрокаНоменклатуры.Ассистент;
					мНоваяСтрока.ЗубнойТехник       = СтрокаНоменклатуры.ЗубнойТехник;
					Если СпособОценкиМПЗ = Перечисления.СпособОценки.ПоСредней Тогда
						Если (НомерПартии = НоменклатураТаблицаПартий.Количество()-1)
							И (ТекущаяПартия.Количество = СписываемоеКоличество) Тогда
							мНоваяСтрока.Стоимость = ОстаткиПартий.Итог("Стоимость"); 						
						Иначе
							мНоваяСтрока.Стоимость = ТекущаяПартия.Цена * СписываемоеКоличество;
						КонецЕсли;
					Иначе
						Если СписываемоеКоличество = ТекущаяПартия.Количество Тогда
							мНоваяСтрока.Стоимость = ТекущаяПартия.Стоимость;
						Иначе
							мНоваяСтрока.Стоимость = СписываемоеКоличество * (ТекущаяПартия.Стоимость / ?(ТекущаяПартия.Количество = 0, 1, ТекущаяПартия.Количество));				
						КонецЕсли;
					КонецЕсли;					
				КонецЕсли;
				
				
				ТекущаяПартия.Стоимость   = ТекущаяПартия.Стоимость - НоваяСтрока.Стоимость;
				ТекущаяПартия.Количество  = ТекущаяПартия.Количество - НоваяСтрока.Количество;				
				ОсталосьСписатьКоличество = ОсталосьСписатьКоличество - СписываемоеКоличество;
			КонецЕсли;
			НомерПартии = НомерПартии + 1;
		КонецЦикла;		
			
		Если ОсталосьСписатьКоличество > 0 Тогда
			
			Отказ = Не НеКонтроллироватьОстатки;
			КоличествоДосупнойНоменклатуры = СтрокаНоменклатуры.Количество - ОсталосьСписатьКоличество;
			
			Если Отказ = Истина Тогда 
				
				СтрокаПартия = ?(ЗначениеЗаполнено(СтрокаНоменклатуры.Партия), "<"+СтрокаНоменклатуры.Партия+">", "");
				ЕИ = Справочники.КлассификаторЕдиницИзмерения.ПолучитьНаименованиеЕдиницыИзмеренияНоменклатуры(СтрокаНоменклатуры.Номенклатура,"шт");
				
				ТекстОшибки = "Не списано по партиям! """+ СтрокаНоменклатуры.Номенклатура + """ "+ СтрокаПартия +" на складе " + СтрокаНоменклатуры.Склад + " в структурной единице " + СтрокаНоменклатуры.СтруктурнаяЕдиница + " недостаточно.
				|		Остаток " + КоличествоДосупнойНоменклатуры +  " " + ЕИ +"; Требуется " + СтрокаНоменклатуры.Количество + " " + ЕИ + "; Не хватает " + (ОсталосьСписатьКоличество) + " " + ЕИ;						
				ОбменДаннымиСервер.СообщитьОбОшибке(ТекстОшибки);
				
			КонецЕсли;

		КонецЕсли; 
		Счетчик = Счетчик + 1;
	КонецЦикла;
	
	ТаблицаДвижений.Свернуть("Период, ВидДвижения, ДокументПоступления, Номенклатура, Склад, СтруктурнаяЕдиница, Партия", "Количество, Стоимость");
	
	Если СтруктураДополнительныеСвойства.ДляПроведения.Свойство("СкладПолучатель") И СтруктураДополнительныеСвойства.ДляПроведения.Свойство("СтруктурнаяЕдиницаПолучатель") Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("СкладПолучатель",СтруктураДополнительныеСвойства.ДляПроведения.СкладПолучатель);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиницаПолучатель",СтруктураДополнительныеСвойства.ДляПроведения.СтруктурнаяЕдиницаПолучатель);
		Запрос.МенеджерВременныхТаблиц = ВыбратьТЗВВременнуюТаблицу(ТаблицаДвижений, "ТаблицаДвижений");
		Запрос.Текст = ПолучитьЗапросПартийДляПеремещения();
		ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	КонецЕсли;
	
    СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПартииТоваров", ТаблицаДвижений);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПродажиСебестоимость", ТаблицаДвиженийПродажи);
	 
КонецПроцедуры

// Процедура выполняет возврат товаров по партиям
// Параметры:
// 		ТаблицаСписанияНоменклатуры - Таблица или табличная часть с номенклатурой;
//		СтруктураДополнительныеСвойства - структура, дополнительные свойства;
//      Движения - Движения документа по регистрам;
//      Отказ    - Отказ продедения;
Процедура СформироватьТаблицуВозвратаПартииТоваров(ТаблицаСписанияНоменклатуры, СтруктураДополнительныеСвойства, Движения, Отказ) Экспорт
	
	НаборДвижений   = Движения.ПартииТоваров;
    ТаблицаДвижений = НаборДвижений.ВыгрузитьКолонки("НомерСтроки,Период, ВидДвижения, ДокументПоступления, Номенклатура, Склад, СтруктурнаяЕдиница, Партия, Количество, Стоимость");
	
	Если  СтруктураДополнительныеСвойства.ДляПроведения.Свойство("ВыполнятьДвиженияСебестоимость") Тогда
		НаборДвижений   = Движения.ПродажиСебестоимость;
		ТаблицаДвиженийПродажи = НаборДвижений.ВыгрузитьКолонки("НомерСтроки,Период, Контрагент, ДокументПродажи, Номенклатура, Склад, Партия, СтруктурнаяЕдиница, Сотрудник, Ассистент, ЗубнойТехник, Количество, Стоимость");
	КонецЕсли;
	
	СпособОценкиМПЗ = Константы.СпособОценкиМПЗ.Получить();
	Если Не ЗначениеЗаполнено(СпособОценкиМПЗ) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнена стратегия списания партий товаров!");
        СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПартииТоваров", ТаблицаДвижений);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	ТаблицаНоменклатуры = ПодготовитьТалицуКСписаниюОприходованиюПартий(ТаблицаСписанияНоменклатуры,СтруктураДополнительныеСвойства);		

	ЗапросПоПартиям = ПолучитьЗапросПартийДляВозврата(СпособОценкиМПЗ);
	МенеджерВременнойТаблицы = ВыбратьТЗВВременнуюТаблицу(ТаблицаНоменклатуры, "ТаблицаНоменклатуры");
	ЗапросПоПартиям.МенеджерВременныхТаблиц = МенеджерВременнойТаблицы;
	ТаблицаПартий = ЗапросПоПартиям.Выполнить().Выгрузить();	
	
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.ОснованиеВозврата) Тогда			
			
			ОсталосьВернутьКоличество = СтрокаНоменклатуры.Количество; 			
			
			ОтборПоНоменклатуре = Новый Структура("Номенклатура, Партия", СтрокаНоменклатуры.Номенклатура, СтрокаНоменклатуры.Партия);	
			ОтборПоНоменклатуре.Вставить("ОснованиеВозврата", СтрокаНоменклатуры.ОснованиеВозврата);
			НоменклатураТаблицаПартий = ТаблицаПартий.НайтиСтроки(ОтборПоНоменклатуре);			
			
			Если ОсталосьВернутьКоличество <=0 Тогда
				Продолжить;
			КонецЕсли;
			
			НомерПартии = 0;
			Пока  ОсталосьВернутьКоличество > 0 и НомерПартии < (НоменклатураТаблицаПартий.Количество())  Цикл
				ТекущаяПартия = НоменклатураТаблицаПартий[НомерПартии];
				Если ТекущаяПартия.Количество > 0 Тогда
					СписываемоеКоличество = ?( ОсталосьВернутьКоличество <= ТекущаяПартия.Количество, ОсталосьВернутьКоличество, ТекущаяПартия.Количество);				
					НоваяСтрока = ТаблицаДвижений.Добавить();
					НоваяСтрока.Период              = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
        			НоваяСтрока.ВидДвижения         = ВидДвиженияНакопления.Приход;
					НоваяСтрока.ДокументПоступления = ТекущаяПартия.ДокументПоступления;
					НоваяСтрока.Номенклатура        = ТекущаяПартия.Номенклатура;
					НоваяСтрока.Партия              = ТекущаяПартия.Партия;
					НоваяСтрока.Количество          = СписываемоеКоличество;
					НоваяСтрока.СтруктурнаяЕдиница  = СтрокаНоменклатуры.СтруктурнаяЕдиница;
					НоваяСтрока.Склад               = СтрокаНоменклатуры.Склад;
					Если СписываемоеКоличество = ТекущаяПартия.Количество Тогда
						НоваяСтрока.Стоимость = ТекущаяПартия.Стоимость;
					Иначе
						НоваяСтрока.Стоимость = СписываемоеКоличество * (ТекущаяПартия.Стоимость / ТекущаяПартия.Количество);				
					КонецЕсли;
					
					Если  СтруктураДополнительныеСвойства.ДляПроведения.Свойство("ВыполнятьДвиженияСебестоимость") и (СтрокаНоменклатуры.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас
						ИЛИ СтрокаНоменклатуры.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал) Тогда
						мНоваяСтрока                    = ТаблицаДвиженийПродажи.Добавить();
						мНоваяСтрока.Период             = СтруктураДополнительныеСвойства.ДляПроведения.Дата;						
						мНоваяСтрока.Номенклатура       = СтрокаНоменклатуры.Номенклатура;
						мНоваяСтрока.Количество         = СписываемоеКоличество * (-1);
						Если СписываемоеКоличество = ТекущаяПартия.Количество Тогда
							мНоваяСтрока.Стоимость = ТекущаяПартия.Стоимость * (-1);
						Иначе
							мНоваяСтрока.Стоимость = СписываемоеКоличество * (ТекущаяПартия.Стоимость / ТекущаяПартия.Количество)*(-1);				
						КонецЕсли;			
						мНоваяСтрока.Контрагент         = СтрокаНоменклатуры.Контрагент;
						мНоваяСтрока.СтруктурнаяЕдиница = СтрокаНоменклатуры.СтруктурнаяЕдиница;
						мНоваяСтрока.ДокументПродажи    = СтрокаНоменклатуры.ДокументПродажи;
						мНоваяСтрока.Склад              = СтрокаНоменклатуры.Склад;
						мНоваяСтрока.Сотрудник          = СтрокаНоменклатуры.Сотрудник; 
						мНоваяСтрока.Ассистент          = СтрокаНоменклатуры.Ассистент;
						мНоваяСтрока.ЗубнойТехник       = СтрокаНоменклатуры.ЗубнойТехник;
					КонецЕсли;
					
					ТекущаяПартия.Стоимость = ТекущаяПартия.Стоимость - НоваяСтрока.Стоимость;
					ТекущаяПартия.Количество = ТекущаяПартия.Количество - НоваяСтрока.Количество;				
					ОсталосьВернутьКоличество = ОсталосьВернутьКоличество - СписываемоеКоличество;
				КонецЕсли;
				НомерПартии = НомерПартии + 1;
				
			КонецЦикла;
		Иначе
			НоваяСтрокаТовара = ТаблицаДвижений.Добавить(); 
			НоваяСтрокаТовара.Период             = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
			НоваяСтрокаТовара.ВидДвижения        = ВидДвиженияНакопления.Приход;
			НоваяСтрокаТовара.ДокументПоступления= СтруктураДополнительныеСвойства.ДляПроведения.Ссылка;
			НоваяСтрокаТовара.СтруктурнаяЕдиница = СтрокаНоменклатуры.СтруктурнаяЕдиница;
			НоваяСтрокаТовара.Склад		 	 	 = СтрокаНоменклатуры.Склад;
			НоваяСтрокаТовара.Номенклатура    	 = СтрокаНоменклатуры.Номенклатура;
