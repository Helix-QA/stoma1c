	Возврат Соединение(Хост).ВызватьHTTPМетод(Метод, Запрос);
	
КонецФункции

&НаКлиенте
// Процедура обработчик события Список при активации строки
//
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		Если Не Элементы.Найти("ОтправитьДанныеВКС") = Неопределено Тогда
			Элементы.ОтправитьДанныеВКС.Доступность = Не ТекущиеДанные.ОтправленВКонтурСтрахование; 		
		КонецЕсли;
	КонецЕсли; 
	
