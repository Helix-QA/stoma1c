// Процедура, обработчик команды подключаемый "ОтображатьМеткуПриНажатии".
//
Процедура Подключаемый_ОтображатьМеткуПриНажатии(Команда)
	
	КнопкаМетки = ТекущийЭлемент;
	ГруппаМетки = КнопкаМетки.Родитель;
	
 	ИндексМетки = Число(СтрЗаменить(КнопкаМетки.Имя, Лев(КнопкаМетки.Имя, Найти(КнопкаМетки.Имя, "_")), ""));
	ДанныеМетки = ЭтотОбъект.ТаблицаМеток.НайтиПоИдентификатору(ИндексМетки);
	
	Если ДанныеМетки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НовоеЗначениеАктивности = Не ДанныеМетки.Активна;
	
	ЗаписатьИзменениеМетки(ДанныеМетки.Метка, Объект.ОсновнойКлиент, НовоеЗначениеАктивности);
	
	ДанныеМетки.Активна = НовоеЗначениеАктивности;
	
	КнопкаМетки.ЦветТекста	 = ?(НовоеЗначениеАктивности И ДанныеМетки.ЦветТекстаБелый, Новый Цвет(255, 255, 255), Новый Цвет(77, 77, 77));
	ГруппаМетки.ЦветФона	 = ?(НовоеЗначениеАктивности, ДанныеМетки.ЦветФона, Новый Цвет(255, 255, 255));

