	ТекстОшибки = ?(ДополнительныеПараметры.Свойство("ТекстОшибки"),ДополнительныеПараметры.ТекстОшибки,"");
	Если (РезультатВопроса = КодВозвратаДиалога.Да)
		И (ЗначениеЗаполнено(Объект.Касса)) Тогда  				
		ОбщегоНазначенияКлиентСтоматология.ОткрытьКассовуюСмену(Объект.Касса, УникальныйИдентификатор);
		СостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Объект.Касса);	
	Иначе
		Возврат;
	КонецЕсли;
	
	КассаПриИзмененииВопросОЗакрытииСмены(ТекстОшибки);

