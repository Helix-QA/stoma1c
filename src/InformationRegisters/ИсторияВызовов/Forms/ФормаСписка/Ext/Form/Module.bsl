// Функция, возвращает цвет текста от передаваемого цвета фона.
//
Функция ПолучитьЦветТекстаПоФону(ЦветФона)
	
	Если (ЦветФона.Зеленый + ЦветФона.Красный + ЦветФона.Синий) > 383 Тогда
		Возврат Новый Цвет(60,60,60);		
	Иначе
		Возврат Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
// Процедура, СписокПриПолученииДанныхНаСервере.
//
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	// Отключаем РЛС, Журавель Р.
	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого Строка Из Строки Цикл
		
		Данные = Строка.Значение.Данные;
		Если Данные.Свойство("CRM") Тогда
			Если ЗначениеЗаполнено(Данные.Заявка) И НЕ Данные.Заявка.ПометкаУдаления Тогда
				Если ТипЗнч(Данные.Заявка) = Тип("СправочникСсылка.Сделки") Тогда
					
					Данные.CRM = Данные.Заявка;
					
					ЦветФона = Неопределено;
					Если Данные.Заявка.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда
						ЦветФона = Новый Цвет(72, 193, 123);
					ИначеЕсли Данные.Заявка.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
						ЦветФона = Новый Цвет(246, 110, 110);
					ИначеЕсли ЗначениеЗаполнено(Данные.Заявка.ЭтапСделки.ЦветЭтапа) Тогда
						ЦветФона = ЗначениеИзСтрокиВнутр(Данные.Заявка.ЭтапСделки.ЦветЭтапа);
					КонецЕсли;
					
					Если ЦветФона <> Неопределено тогда
						Строка.Значение.Оформление["CRM"].УстановитьЗначениеПараметра("ЦветТекста", ПолучитьЦветТекстаПоФону(ЦветФона));
						Строка.Значение.Оформление["CRM"].УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
					КонецЕсли;
					
				ИначеЕсли ЗначениеЗаполнено(Данные.CRM) И ТипЗнч(Данные.CRM) = Тип("Строка") Тогда
					
					Данные.CRM = "Обращение №" + ФормированиеПечатныхФорм.УдалитьЛидирующиеНулиИзНомераОбъекта(Данные.CRM);
					Строка.Значение.Оформление["CRM"].УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(128, 128, 128));
					
				КонецЕсли;
			Иначе
				Данные.CRM = Неопределено;
			КонецЕсли;
		КонецЕсли; 
		
		//Если Данные.Свойство("Контрагент") Тогда
		//	Если ЗначениеЗаполнено(Данные.Контрагент) И ТипЗнч(Данные.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда
		//		Данные.СтатусПациента = РегистрыСведений.СтатусыКонтрагентов.ПолучитьСтатусКлиента(Данные.Контрагент);
		//	КонецЕсли; 
		//КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

