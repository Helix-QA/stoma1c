
#Область ОбработчикиСобытийЭлементовФормы

&НаСервере
// Процедура, При создании на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("РасшифрокаСписания"	, "ГруппаРасшифровкаСписания");
	СтруктураМеню.Вставить("Дополнительно"		, "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура, При открытии.
//
Процедура ПриОткрытии(Отказ)
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик нажатия переключателя закладок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры

&НаКлиенте
// Обработчик после записи объекта на клиенте
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА");
КонецПроцедуры

&НаКлиенте
// При окончании редактирования таблицы расшифровки
//
Процедура СписаниеПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Объект.СуммаДокумента = Объект.РасшифрокаСписания.Итог("СуммаСписания");
КонецПроцедуры

&НаКлиенте
// После удаления строки расшифровки
//
Процедура РасшифрокаСписанияПослеУдаления(Элемент)
	
	Объект.СуммаДокумента = Объект.РасшифрокаСписания.Итог("СуммаСписания");
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Обработчик добавления документа в расшифроку
//
Процедура СписаниеДокументОснованияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	ПараметрыФормы       = Новый Структура;
	ПараметрыФормы.Вставить("Контрагент"        ,Объект.Контрагент);
	ПараметрыФормы.Вставить("КотрольКонтрагента",Истина);
	ПараметрыФормы.Вставить("СостояниеОплаты"   ,2);
	СписокТипов = Новый Массив;
	СписокТипов.Добавить(Тип("ДокументСсылка.Прием"));
	СписокТипов.Добавить(Тип("ДокументСсылка.Реализация"));
	СписокТипов.Добавить(Тип("ДокументСсылка.Поступление"));
	ПараметрыФормы.Вставить("СписокТипов",СписокТипов);
	
	ОткрытьФорму("ОбщаяФорма.ВыборДокументаРасчетов",ПараметрыФормы,Элемент);
КонецПроцедуры

&НаКлиенте
// Обработчик осуществления выбора документа основания
//
Процедура СписаниеДокументОснованияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	Если ВыбранноеЗначение <> Неопределено Тогда		
		Счетчик = 0;
		Для Каждого ЭлементМ ИЗ ВыбранноеЗначение Цикл		
			РазрешитьДобавление = Истина;
			// Проверка существования строки с выбранными данными
			Для Каждого СтрокаТ ИЗ объект.РасшифрокаСписания Цикл
				Если СтрокаТ.ДокументОснования = ЭлементМ.ДокументОснования Тогда
					СтрокаТ.СуммаДокумента     = ЭлементМ.СуммаДокумента; 
					РазрешитьДобавление = Ложь;
					Прервать;
				КонецЕсли;	
			КонецЦикла;
			// Есди добавление данных в строку разрешено
			Если РазрешитьДобавление = Истина Тогда
				ОбрабатываемаяСтрока = Неопределено;
				Если Счетчик = 0 Тогда
					ОбрабатываемаяСтрока = Элементы.РасшифрокаСписания.ТекущиеДанные;
				Иначе
					ОбрабатываемаяСтрока = Объект.РасшифрокаСписания.Добавить();
				КонецЕсли;	
				
				ОбрабатываемаяСтрока.ДокументОснования = ЭлементМ.ДокументОснования;
				ОбрабатываемаяСтрока.СуммаДокумента    = ЭлементМ.СуммаДокумента;
				
				Счетчик = Счетчик + 1;
			КонецЕсли;
		КонецЦикла;
		// Подсчет суммы документа
		Объект.СуммаДокумента = Объект.РасшифрокаСписания.Итог("СуммаСписания");
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
// При изменении суммы списания
//
Процедура СписаниеСуммаСписанияПриИзменении(Элемент)
	// Проверка допустимой виличины суммы списания
	ТекущиеДанные = Элементы.РасшифрокаСписания.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено И ЗначениеЗаполнено(ТекущиеДанные.ДокументОснования) Тогда
		СуммаЗадолженности = ПолучитьЗадолженностьПоДокументу(ТекущиеДанные.ДокументОснования,);
		Если ТекущиеДанные.СуммаСписания > СуммаЗадолженности Тогда
			ПоказатьПредупреждение(,"Сумма списания превышает задолженность по документу!");
			ТекущиеДанные.СуммаСписания =  СуммаЗадолженности;
		КонецЕсли;		
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
// При изменении статьи расходов в шапке
//
Процедура СтатьяРасходовПриИзменении(Элемент)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("СтатьяРасходовПриИзмененииЗавершение", ЭтотОбъект);

	ПоказатьВопрос(ОписаниеОповещения, "Перезаполнять заполненные значения?",РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Статья расходов при изменении завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СтатьяРасходовПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ПерезаполнятьЗаполненные = РезультатВопроса = КодВозвратаДиалога.Да;
	Для Каждого СтрокаТ ИЗ Объект.РасшифрокаСписания Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатьяРасходов) ИЛИ ПерезаполнятьЗаполненные = Истина Тогда
			СтрокаТ.СтатьяРасходов = Объект.СтатьяРасходов;
		КонецЕсли;;
	КонецЦикла;

КонецПроцедуры 

&НаКлиенте
// Процедура, Расшифрока списания при изменении.
//
Процедура РасшифрокаСписанияПриИзменении(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область обработчикиКомандФормы

&НаКлиенте
// Обработчик кнопки установки суммы списания документам
//
Процедура УстановитьСуммыСписанияПоРазмеруЗадолженности(Команда)
	УстановитьСуммыСписанияПоРазмеруЗадолженностиСервер();
КонецПроцедуры

&НаКлиенте
// Обработчик кнопки заполнения расшифровки задолженности по выбранному контрагенту
Процедура ЗаполнитьПоКонтрагенту(Команда)

	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ПоказатьПредупреждение(,"Для начала выберите контрагента");
		Возврат;
	КонецЕсли;
	
	Если Объект.РасшифрокаСписания.Количество() > 0 Тогда
		ОписаниеОтвета = Новый ОписаниеОповещения("ОбработчикОтветаНаВопросОбОчищенииРасшифровки",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОтвета,"Таблица расшифровки списания будет очищена, продолжить?",РежимДиалогаВопрос.ДаНет);
        Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуРасшифровкиПоКонтрагенту();
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьПоказатьДополнительно(Команда)
	
	Элементы.ГруппаДополнительно.Видимость = Не Элементы.ГруппаДополнительно.Видимость;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста  
// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции

&НаКлиенте
// Обработчик ответа на вопрос об очищении таблицы расшифровки  
//
Процедура ОбработчикОтветаНаВопросОбОчищенииРасшифровки(Ответ, ДопПараметры) Экспорт 
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Объект.РасшифрокаСписания.Очистить();
		ЗаполнитьПоКонтрагенту(Неопределено);
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
// Установить суммы списания документам
//
Процедура УстановитьСуммыСписанияПоРазмеруЗадолженностиСервер()
	Для Каждого СтрокаТ ИЗ Объект.РасшифрокаСписания Цикл
		Если ЗначениеЗаполнено(СтрокаТ.ДокументОснования) Тогда
			СтрокаТ.СуммаСписания = ПолучитьЗадолженностьПоДокументу(СтрокаТ.ДокументОснования,Объект.Ссылка);
		КонецЕсли;
	КонецЦикла;	
	Объект.СуммаДокумента = Объект.РасшифрокаСписания.Итог("СуммаСписания");
КонецПроцедуры

&НаСервере
// Заполнить таблицу расшифровки по контрагенту
Процедура ЗаполнитьТаблицуРасшифровкиПоКонтрагенту()
	
	ТаблицаВзаиморасчетов = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ДанныеПоВзаиморасчетамДляКонтрагента(Объект.Контрагент,КонецДня(Объект.Дата), Объект.СтруктурнаяЕдиница, Истина, Истина,Объект.Ссылка);
	Для Каждого СтрокаТ ИЗ ТаблицаВзаиморасчетов Цикл		
		НоваяСтрока                   = Объект.РасшифрокаСписания.Добавить();
		НоваяСтрока.ДокументОснования = СтрокаТ.ДокументРеализации;
		НоваяСтрока.ДокументАванса    = СтрокаТ.ДокументАванса;
		НоваяСтрока.ЭтоАванс          = СтрокаТ.ЭтоАванс;
		НоваяСтрока.СуммаДокумента    = СтрокаТ.СуммаДокумента;
		НоваяСтрока.СуммаСписания     = СтрокаТ.Задолженность;
		НоваяСтрока.СтатьяРасходов    = Объект.СтатьяРасходов;
	КонецЦикла;
	Объект.СуммаДокумента = Объект.РасшифрокаСписания.Итог("СуммаСписания");
КонецПроцедуры

&НаСервереБезКонтекста
// Получить сумму задолженности по документу
//
Функция ПолучитьЗадолженностьПоДокументу(ДокументСсылка,НеУчитыватьРегистратор)
	Возврат РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьЗадолженностьПоДокументу(ДокументСсылка,Неопределено,НеУчитыватьРегистратор);
КонецФункции

#КонецОбласти
