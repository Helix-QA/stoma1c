// Функция, создает сообщение с признаком ожидания сообщения.
//
Функция УстановитьОжиданиеСообщения(ИдКлиента, ВнешняяСистема, ОписаниеОшибки, Клиент = Неопределено, НомерТелефона = "")
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		ИдКлиента = СоздатьКлиентаМессенджера(ВнешняяСистема, Клиент, НомерТелефона);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		ОписаниеОшибки = НСтр("ru = 'Не удалось создать контакт мессенджера.'; en = 'Failed to create messenger client.'");
		Возврат Неопределено;
	КонецЕсли;
	
	ИдСообщения = МессенджерСтоматология.ПолучитьИдОжидающегоСообщенияВМесенджер(ИдКлиента, ВнешняяСистема);
	
	Возврат ИдСообщения;
	
КонецФункции

