	Иначе 
		НоваяСтрока 							= ОтобранныеЗапасы.Добавить();
		НоваяСтрока.Номенклатура 				= ПараметрыСтруктура.Номенклатура;
		НоваяСтрока.КоличествоУпаковок			= КоличествоУпаковок;
		НоваяСтрока.ИспользуютсяХарактеристики	= ПроверкаНаличияПартий(ПараметрыСтруктура.Номенклатура);
		// Если ИспользуютсяПартии Тогда
		//	НоваяСтрока.Партия 			= ПараметрыСтруктура.Партия;
