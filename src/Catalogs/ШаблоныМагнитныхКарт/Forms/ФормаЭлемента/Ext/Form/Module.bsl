&НаКлиенте
// Процедура, устанавливает доступность полей дорожек в зависимости от положения соответствующего флага
//
Процедура УстановитьДоступностьДорожек()
	
	Для й = 1 По 3 Цикл
		ДоступностьДорожки = Объект["ДоступностьДорожки"+Строка(й)];
		Элементы["Префикс"+Строка(й)].Видимость 				= ДоступностьДорожки;
		Элементы["ДлинаКода"+Строка(й)].Видимость 				= ДоступностьДорожки;
		Элементы["Суффикс"+Строка(й)].Видимость 				= ДоступностьДорожки;
		Элементы["РазделительБлоков"+Строка(й)].Видимость 		= ДоступностьДорожки;
		Элементы["ПоляДорожки"+Строка(й)].Видимость 			= ДоступностьДорожки;
		Элементы["ГруппаКоманднаяПанель"+Строка(й)].Видимость 	= ДоступностьДорожки;
	КонецЦикла;
	
КонецПроцедуры

