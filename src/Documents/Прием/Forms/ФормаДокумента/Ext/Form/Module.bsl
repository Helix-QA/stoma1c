// Процедура оформления кнопок приема.
//
Процедура ОформлениеКнопокПриема()
  
  Если ЗначениеЗаполнено(Объект.РезультатПриема) Тогда   
    Элементы.ФормаКнопкаРезультатПриема.Заголовок      = ?(Объект.РезультатПриема = 1, "Санация", "Продолжает лечение");
