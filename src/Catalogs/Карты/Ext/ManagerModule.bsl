// Функция, возвращает карты по дополнительному владельцу.
//
Функция ПолучитьКартыПоДопВладельцу(ДопВладелец) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Карты.Ссылка КАК Карта
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ДополнительныйВладелец = &ДопВладелец
	|	И НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Wallet)
	|	И Карты.ВнутреннийКодКарты <> """"");
	
	Запрос.УстановитьПараметр("ДопВладелец", ДопВладелец);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Карта");
	
КонецФункции

// Функция, возвращает адрес API webcitrus.
//
Функция ПолучитьАдресAPI(ВнешняяСистемаWallet)
	
	ПараметрыВнешнейСистемы = ВнешняяСистемаWallet.Параметры.Получить();
	
	Если ПараметрыВнешнейСистемы <> Неопределено И ПараметрыВнешнейСистемы.Свойство("АдресAPI") Тогда
		АдресAPI = ПараметрыВнешнейСистемы.АдресAPI;
	Иначе
		АдресAPI = "api.webcitrus.app";
	КонецЕсли;
	
	Возврат АдресAPI;
	
КонецФункции

// Функция возвращает массив актуальных дисконтных карт клиента.
//
Функция ПолучитьАктуальныеДисконтныеКартыКлиента(Клиент) Экспорт
	
	Если Не ЗначениеЗаполнено(Клиент) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Карты.Ссылка
	               |ИЗ
	               |	Справочник.Карты КАК Карты
	               |ГДЕ
	               |	НЕ Карты.ПометкаУдаления
	               |	И НЕ Карты.Заблокирована
	               |	И Карты.ВладелецКарты = &ВладелецКарты
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Карты.ДатаОткрытия УБЫВ";
				   
	Запрос.УстановитьПараметр("ВладелецКарты", Клиент);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить содержание текста выдачи карты
//
// Параметры:
//  КороткаяСсылка			 - 	 - 
//  ПараметрыВнешнейСистемы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСодержаниеТекстаВыдачиКарты(КороткаяСсылка, ПараметрыВнешнейСистемы = Неопределено, СтруктурнаяЕдиница = Неопределено, ВнешняяСистемаWallet = Неопределено) Экспорт
	
	ШаблонСообщения = "";
	
	Если Не ЗначениеЗаполнено(ВнешняяСистемаWallet) И Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы) Тогда
		ВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet, Истина);					
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ВнешняяСистемаWallet) И Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы) Тогда
		ПараметрыВнешнейСистемы = ВнешняяСистемаWallet.Параметры.Получить();
	КонецЕсли;
		
	Если ПараметрыВнешнейСистемы <> Неопределено И ЗначениеЗаполнено(СтруктурнаяЕдиница) И ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура") 
		И ПараметрыВнешнейСистемы.Свойство("ШаблонСообщения") И ПараметрыВнешнейСистемы.Свойство("ШаблонСообщенияПеревод") Тогда
		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница.Язык) И НРег(СтруктурнаяЕдиница.Язык.СимвольныйКод) = "en" Тогда		
			ШаблонСообщения = ?(ЗначениеЗаполнено(ПараметрыВнешнейСистемы.ШаблонСообщенияПеревод), ПараметрыВнешнейСистемы.ШаблонСообщенияПеревод, ПараметрыВнешнейСистемы.ШаблонСообщения);			
		Иначе
			ШаблонСообщения = ПараметрыВнешнейСистемы.ШаблонСообщения;				
		КонецЕсли;
		
	Иначе		
		ШаблонСообщения = "Выпущена электронная карта: " + КороткаяСсылка;		
	КонецЕсли;
	
	Если СтрНайти(ШаблонСообщения, "{КороткаяСсылкаНаКарту}") <> 0 Тогда		
		ШаблонСообщения = СтрЗаменить(ШаблонСообщения, "{КороткаяСсылкаНаКарту}", КороткаяСсылка);
	КонецЕсли;
	Если СтрНайти(ШаблонСообщения, "{ShortLinkOnCard}") <> 0 Тогда		
		ШаблонСообщения = СтрЗаменить(ШаблонСообщения, "{ShortLinkOnCard}", КороткаяСсылка);
	КонецЕсли;
	
	Возврат ШаблонСообщения;
	 	
КонецФункции

#КонецОбласти
