&НаСервере
Процедура ОтветственныеЛица(ТекущийОбъект)
	// запись в регистр ответственные лица
	ТекОбъект = ЭтаФорма.Объект;
	// руководитель
	Если (ЗначениеЗаполнено(ТекОбъект.ФИОРуководителя)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьРуководителя)) Тогда
		
		НаборЗаписей = РегистрыСведений.ОтветственныеЛица.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипОтветственногоЛица.Установить(Перечисления.ТипыОтветственныхЛиц.Руководитель);
		Запись = НаборЗаписей.Добавить();
		Запись.Период =  ТекущаяДата();
		Запись.Организация   = ТекущийОбъект.Ссылка;
		Запись.ТипОтветственногоЛица = Перечисления.ТипыОтветственныхЛиц.Руководитель;
		Запись.Сотрудник = ТекОбъект.ФИОРуководителя;  
		Запись.Должность = ТекОбъект.ДолжностьРуководителя;
		Если ПроверкаСуществованияЗаписи(ТекущийОбъект, Перечисления.ТипыОтветственныхЛиц.Руководитель) Тогда
			НаборЗаписей.Записать(); 
		Иначе
			НаборЗаписей.Записать(Ложь); 
		КонецЕсли;
	ИначеЕсли (ЗначениеЗаполнено(ТекОбъект.ФИОРуководителя)) и (не ЗначениеЗаполнено(ТекОбъект.ДолжностьРуководителя)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить должность руководителя");
	ИначеЕсли (не ЗначениеЗаполнено(ТекОбъект.ФИОРуководителя)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьРуководителя)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить ФИО руководителя");
	КонецЕсли;
	// гл бух
	Если (ЗначениеЗаполнено(ТекОбъект.ФИОГлавногоБухгалтера)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьГлавногоБухгалтера)) Тогда
		НаборЗаписей = РегистрыСведений.ОтветственныеЛица.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипОтветственногоЛица.Установить(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер);
		Запись = НаборЗаписей.Добавить();
		Запись.Период =  ТекущаяДата();
		Запись.Организация   = ТекущийОбъект.Ссылка;
		Запись.ТипОтветственногоЛица = Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер;
		Запись.Сотрудник = ТекОбъект.ФИОГлавногоБухгалтера;  
		Запись.Должность = ТекОбъект.ДолжностьГлавногоБухгалтера;
		Если ПроверкаСуществованияЗаписи(ТекущийОбъект, Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер) Тогда
			НаборЗаписей.Записать();
		Иначе
			НаборЗаписей.Записать(Ложь);
		КонецЕсли;
	ИначеЕсли (ЗначениеЗаполнено(ТекОбъект.ФИОГлавногоБухгалтера)) и (не ЗначениеЗаполнено(ТекОбъект.ДолжностьГлавногоБухгалтера)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить должность главного бухгалтера");
	ИначеЕсли (не ЗначениеЗаполнено(ТекОбъект.ФИОГлавногоБухгалтера)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьГлавногоБухгалтера)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить ФИО главного бухгалтера");
	КонецЕсли;
	// кассир
	Если (ЗначениеЗаполнено(ТекОбъект.ФИОКассира)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьКассира)) Тогда
		НаборЗаписей = РегистрыСведений.ОтветственныеЛица.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипОтветственногоЛица.Установить(Перечисления.ТипыОтветственныхЛиц.Кассир);
		Запись = НаборЗаписей.Добавить();
		Запись.Период =  ТекущаяДата();
		Запись.Организация   = ТекущийОбъект.Ссылка;
		Запись.ТипОтветственногоЛица = Перечисления.ТипыОтветственныхЛиц.Кассир;
		Запись.Сотрудник = ТекОбъект.ФИОКассира;  
		Запись.Должность = ТекОбъект.ДолжностьКассира;
		Если ПроверкаСуществованияЗаписи(ТекущийОбъект, Перечисления.ТипыОтветственныхЛиц.Кассир) Тогда
			НаборЗаписей.Записать();
		Иначе
			НаборЗаписей.Записать(Ложь);
		КонецЕсли;
		
	ИначеЕсли (ЗначениеЗаполнено(ТекОбъект.ФИОКассира)) и (не ЗначениеЗаполнено(ТекОбъект.ДолжностьКассира)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить должность кассира");
	ИначеЕсли (не ЗначениеЗаполнено(ТекОбъект.ФИОКассира)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьКассира)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить ФИО кассира");
	КонецЕсли;
	// кладовщик
	Если (ЗначениеЗаполнено(ТекОбъект.ФИОКладовщика)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьКладовщика)) Тогда
		НаборЗаписей = РегистрыСведений.ОтветственныеЛица.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипОтветственногоЛица.Установить(Перечисления.ТипыОтветственныхЛиц.Кладовщик);
		Запись = НаборЗаписей.Добавить();
		Запись.Период =  ТекущаяДата();
		Запись.Организация   = ТекущийОбъект.Ссылка;
		Запись.ТипОтветственногоЛица = Перечисления.ТипыОтветственныхЛиц.Кладовщик;
		Запись.Сотрудник = ТекОбъект.ФИОКладовщика;  
		Запись.Должность = ТекОбъект.ДолжностьКладовщика;
		Если ПроверкаСуществованияЗаписи(ТекущийОбъект, Перечисления.ТипыОтветственныхЛиц.Кладовщик) Тогда
			НаборЗаписей.Записать(); 
		Иначе
			НаборЗаписей.Записать(Ложь);
		КонецЕсли;
	ИначеЕсли (ЗначениеЗаполнено(ТекОбъект.ФИОКладовщика)) и (не ЗначениеЗаполнено(ТекОбъект.ДолжностьКладовщика)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить должность кладовщика");
	ИначеЕсли (не ЗначениеЗаполнено(ТекОбъект.ФИОКладовщика)) и (ЗначениеЗаполнено(ТекОбъект.ДолжностьКладовщика)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить ФИО кладовщика");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПроверкаСуществованияЗаписи(Организация, ТипыОтветственныхЛиц)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	               |	ОтветственныеЛицаСрезПоследних.Период,
	               |	ОтветственныеЛицаСрезПоследних.Организация,
	               |	ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица
	               |ИЗ
	               |	РегистрСведений.ОтветственныеЛица.СрезПоследних(&Дата, ) КАК ОтветственныеЛицаСрезПоследних
	               |ГДЕ
	               |	ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица = &ТипОтветственногоЛица
	               |	И ОтветственныеЛицаСрезПоследних.Организация = &Организация";
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Запрос.УстановитьПараметр("ТипОтветственногоЛица", ТипыОтветственныхЛиц);
    Запрос.УстановитьПараметр("Организация", Организация.Ссылка);

	Результат = Запрос.Выполнить();
	Если   Результат.Пустой() Тогда 
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции


