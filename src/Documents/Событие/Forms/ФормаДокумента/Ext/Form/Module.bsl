&НаКлиенте
// Процедура - После выбора канала привлечения
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыбораКаналаПривлечения(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт 

	Если ЗначениеЗаполнено(РезультатВыбора) Тогда 
		ЭтаФорма.КаналПривлечения = РезультатВыбора;
		Если ЭтаФорма.КаналПривлечения = ПредопределенноеЗначение("Справочник.КаналыПривлечения.ЧатСКлиентом") Тогда 
			ОповещениеВыбораМессенджера = Новый ОписаниеОповещения("ПослеВыбораМессенджера", ЭтотОбъект, ДополнительныеПараметры);
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("МножественныйВыбор"		, Ложь);
			ПараметрыОткрытия.Вставить("ЗакрыватьПриВыборе"		, Истина);
			ПараметрыОткрытия.Вставить("ВыборГруппИЭлементов"	, ГруппыИЭлементы.Элементы);
			ПараметрыОткрытия.Вставить("ВыборДляПервичнойСделки", Истина);
			ОткрытьФорму("Перечисление.Мессенджеры.ФормаВыбора", ПараметрыОткрытия, ЭтотОбъект, , , ,ОповещениеВыбораМессенджера, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			Возврат;
		ИначеЕсли ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ФормированиеПриема", Ложь) Тогда
			ВвестиПосещение(Неопределено); 
		Иначе
			Если ЭтаФорма.Записать(Новый Структура("РежимЗаписи, НеобходимаГенерацияЗаявки", РежимЗаписиДокумента.Проведение, Истина)) Тогда 
				Если ЭтаФорма.Открыта() Тогда 
					ЭтаФорма.Закрыть();          
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора мессенджера
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыбораМессенджера(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт 

	Если ЗначениеЗаполнено(РезультатВыбора) Тогда 
		ЭтаФорма.КаналПривлеченияЗначение = РезультатВыбора;
		Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ФормированиеПриема", Ложь) Тогда
			ВвестиПосещение(Неопределено); 
		Иначе
			Если ЭтаФорма.Записать(Новый Структура("РежимЗаписи, НеобходимаГенерацияЗаявки", РежимЗаписиДокумента.Проведение, Истина)) Тогда 
				Если ЭтаФорма.Открыта() Тогда
					ЭтаФорма.Закрыть();
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;
	Иначе 
		ЭтаФорма.КаналПривлечения = Неопределено;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)	
	
	// Если ТекущийОбъект.Статус = Перечисления.СтатусыСобытия.НеПодтверждена Тогда
	//	ТекущийОбъект.Статус = Перечисления.СтатусыСобытия.Подтверждена;
	// КонецЕсли;
	
	Если Ссылка_НовыйПациент <> Неопределено И ЗначениеЗаполнено(Ссылка_НовыйПациент) Тогда	
		
		НовыйКлиент = Справочники.Контрагенты.СоздатьЭлемент();
		НовыйКлиент.УстановитьСсылкуНового(Ссылка_НовыйПациент);
		
	    НовыйКлиент.Фамилия				 = ЭтотОбъект.Фамилия_НовыйПациент;
