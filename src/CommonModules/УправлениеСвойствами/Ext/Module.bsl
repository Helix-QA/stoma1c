					//Кнопка.МаксимальнаяШирина 		= 20;
					//Кнопка.РастягиватьПоГоризонтали = Истина;
					Кнопка.Шрифт 					= Новый Шрифт("Arial", 11);
					//Кнопка.ГоризонтальноеПоложениеВГруппе  = ГоризонтальноеПоложениеЭлемента.Право;
				КонецЕсли;
				
				Если ЗаголовокКнопкиОплаты = "Закрыть визит" И Форма.Объект.Статус = Перечисления.СтатусыВизитов.Окончен Тогда
