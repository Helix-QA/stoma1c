&НаКлиенте
Процедура СотрудникНачалоВыбораПродолжение()
		
	мПараметрыВыбора = Новый Структура;
	мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	мПараметрыВыбора.Вставить("ТекущаяСтрока"     , Объект.Сотрудник);
	мПараметрыВыбора.Вставить("ДатаДокумента"     , Объект.Дата);
	мПараметрыВыбора.Вставить("ОтбиратьВрачей"    , Истина); 
	мПараметрыВыбора.Вставить("Сотрудник"		  , Объект.Ассистент);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("СотрудникНачалоВыбораПродолжениеЗавершение", ЭтаФорма);	
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", мПараметрыВыбора,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
