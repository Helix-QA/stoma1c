	ОбластьИнформацияПоУслуге.Параметры.Услуга	= ПредставлениеНоменклатуры;
	ОбластьИнформацияПоУслуге.Параметры.Кол		= Количество;
	ТабДок.Вывести(ОбластьИнформацияПоУслуге);
	
	Если ВыводитьСотрудника Тогда
		ОбластьСотрудника.Параметры.Сотрудник = "(вр. " + Тренер + ")";
		ТабДок.Вывести(ОбластьСотрудника);
	КонецЕсли;
	
