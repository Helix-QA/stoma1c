	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура ПометкаУдаления(Команда)
	
	МассивСтрок = Элементы.СписокПисем.ВыделенныеСтроки;
	
	Выполнено = УстановитьПометкуНаУдаление(МассивСтрок);
	
	Если Выполнено Тогда
		
		Оповестить("ИзмененоЭлектронноеПисьмо", Элементы.СписокПисем.ТекущаяСтрока);
		
	КонецЕсли;
	
КонецПроцедуры

