// Процедура - инициализирует параметры макета, в который будет выводиться график занятий
//
Процедура ПараметрыМакета()
	
    // Рабочее время по умолчанию
	НачалоРабочегоДня = 0;
	КонецРабочегоДня  = 23;
	Расписание        = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.РасписаниеРаботы;
	
	// Получаем рабочее время по первой активной записи рассписания
	Для А = 0 По Расписание.Количество()-1 Цикл
		
		Если Расписание[А].Активность Тогда
			
			НачалоРабочегоДня = Час(Расписание[0].НачалоРаботы);
			КонецРабочегоДня = Час(Расписание[0].ОкончаниеРаботы)-1;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
		
	ПараметрыМакета = Новый Структура;
	ПараметрыМакета.Вставить("НачалоРабочегоДня"			    ,НачалоРабочегоДня);
	ПараметрыМакета.Вставить("ОкончаниеРабочегоДня"			    ,КонецРабочегоДня);	
	ПараметрыМакета.Вставить("КоличествоДнейВНеделе"        	,7);		
	ПараметрыМакета.Вставить("ВысотаЗаголовка"					,20);
	ПараметрыМакета.Вставить("ШиринаЗаголовкаНеделя"			,140/ПараметрыМакета.КоличествоДнейВНеделе);
	ПараметрыМакета.Вставить("ШиринаЗаголовкаДень"		    	,93);
	ПараметрыМакета.Вставить("ВысотаОбластейЧаса"				,20);

    // РАСЧЕТ ВЫСОТЫ СТРОК МАКЕТА 
	Если Режим="День" И НЕ Сотрудник.Пустая() Тогда
		
		 ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
		 РазмерОбласти = (297-ТабличныйДокумент.ПолеСверху-(((ПараметрыМакета.ВысотаЗаголовка*4)/11)*2));
		 СтрокВсего    = ((ПараметрыМакета.ОкончаниеРабочегоДня-ПараметрыМакета.НачалоРабочегоДня)+1)*4;
		 РазмерСтроки  = РазмерОбласти/СтрокВсего;
         ПараметрыМакета.Вставить("ВысотаОбластейЧаса",(11*РазмерСтроки)/4);
		 
	 Иначе
		 
		 ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		 РазмерОбласти = (210 - ТабличныйДокумент.ПолеСверху-(((ПараметрыМакета.ВысотаЗаголовка*4)/11)*2));
		 СтрокВсего    = ((ПараметрыМакета.ОкончаниеРабочегоДня-ПараметрыМакета.НачалоРабочегоДня)+1)*4;
		 РазмерСтроки  = РазмерОбласти/СтрокВсего;
         ПараметрыМакета.Вставить("ВысотаОбластейЧаса",(11*РазмерСтроки)/4);
		 
	КонецЕсли;
	
	ПараметрыМакета.Вставить("ШрифтДляНедели", Новый Шрифт(,7, Ложь,,));
	ПараметрыМакета.Вставить("ШрифтДляДня"   , Новый Шрифт(,10, Ложь,,));
	ПараметрыМакета.Вставить("ШрифтШапки"    , Новый Шрифт(,9, Ложь,,));
	
КонецПроцедуры

&НаКлиенте
