// Функция заполняет макет Медицинская карта по переданному пациенту
//
// Параметры:
// 		Пациент			- Контрагенты, пациент, на которого сформировать мед.карту
//
Функция СформироватьЛистУчетаДозовыхНагрузокПациента(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено) Экспорт
	
	ТабличныйДокумент                      = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЛистУчетаДозовыхНагрузок";
	ТабличныйДокумент.РазмерСтраницы       = "A4";
	
	ПервыйДокумент = Истина;
	
	Если Не ПервыйДокумент Тогда
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЕсли;
	ПервыйДокумент    = Ложь;	
	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
	
	Если ЗначениеЗаполнено(ПараметрыПечати) И ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("Контрагент")
		 И ЗначениеЗаполнено(ПараметрыПечати.Контрагент) Тогда
		 
		Контрагент = ПараметрыПечати.Контрагент;
	Иначе
		Контрагент = "";	
	КонецЕсли;

	Макет = ПолучитьМакет("ЛистУчетаДозовыхНагрузок");
		
	//==================================================================ПЕЧАТЬ ЛИСТКА УЧЕТА ЛУЧЕВОЙ НАГРУЗКИ========================================================
	ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	
	ОбластьМакета = Макет.ПолучитьОбласть("УчетЛучевойНагрузки");
	ОбластьМакета.Параметры.ФИОПациента = ?(ЗначениеЗаполнено(Контрагент), Строка(ОбщегоНазначения.ПолучитьЗначениеРеквизита(Контрагент, "Наименование")), "");
	
	ТабличныйДокумент.Вывести(ОбластьМакета);	
		
	ТабличныйДокумент.АвтоМасштаб        = Истина;	 

	Возврат ТабличныйДокумент; 
	
КонецФункции

// Функция заполняет параметры области макета из ТаблицыЗначений
//
// Параметры:
// 		Область							- Область макета для заполнения
// 		СтрокаОбследованияПриема		- ТаблицаЗначений, Таблица с обследованиями
// 		ПараметрыОбследования			- ТаблицаЗначений, Параметры которые заполняять и ширину полей
//
Процедура ЗаполнитьПараметрыОбследования(Область, ТаблицаЗначений, РеквизитыОбследования)
	
	Для Каждого Реквизит Из РеквизитыОбследования Цикл				
		
		ТекстДанныхОбследования = ""; 
		
		Если Реквизит.Ключ = "КодМКБ10" И (НЕ ТаблицаЗначений.Колонки.Найти("КодМКБ10") = Неопределено) Тогда
			СтрокиСДиагнозом = ТаблицаЗначений.НайтиСтроки(Новый Структура("ТипРеквизита", Тип("СправочникСсылка.Диагнозы")));
			Для Каждого СтрокаДиагноз Из СтрокиСДиагнозом Цикл
				ТекстДанныхОбследования = ?(ЗначениеЗаполнено(ТекстДанныхОбследования), СокрЛП(ТекстДанныхОбследования) + " ", ТекстДанныхОбследования) + СтрокаДиагноз.КодМКБ10;		
			КонецЦикла;
		ИначеЕсли Реквизит.Ключ = "Диагноз" Тогда
			СтрокиСДиагнозом = ТаблицаЗначений.НайтиСтроки(Новый Структура("ТипРеквизита", Тип("СправочникСсылка.Диагнозы")));
			Для Каждого СтрокаДиагноз Из СтрокиСДиагнозом Цикл
				ТекстДанныхОбследования = ТекстДанныхОбследования + ?(ЗначениеЗаполнено(СтрокаДиагноз.РеквизитЗначение), " " + СтрокаДиагноз.РеквизитЗначение + ";", "");		
			КонецЦикла;
		ИначеЕсли Реквизит.Ключ = "Анамнез" Тогда
			НайденныеСтроки = ТаблицаЗначений.НайтиСтроки(Новый Структура("РеквизитИмя", "АллергологическийАнамнез")); 
			ТекстДанныхОбследования = ?(Найденныестроки.Количество()>0, Найденныестроки[0].РеквизитЗначение, "");
		Иначе
			Найденныестроки	= ТаблицаЗначений.НайтиСтроки(Новый Структура("РеквизитИмя", Реквизит.Ключ));
			ТекстДанныхОбследования = ?(Найденныестроки.Количество()>0, Найденныестроки[0].РеквизитЗначение, "");
		КонецЕсли;
		
		ТекстДанныхОбследования = СтрЗаменить(ТекстДанныхОбследования, Символы.ПС, "");
		МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанныхОбследования, Реквизит.Значение);
		
		НомерСтроки = 0;
		Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл
			НомерСтроки = НомерСтроки + 1;
			Область.Параметры[Реквизит.Ключ + "Стр" + Строка(НомерСтроки)] = ТекстДанныхПоСтрокам;
		КонецЦикла;	
	КонецЦикла;
	
КонецПроцедуры

// По переданному номеру или части номера вернет всех найденных контрагентов
//
Функция ПолучитьКонтрагентовПоНомеруТелефона(НомерТелефона,ЧастьНомера=Ложь)Экспорт
	
	ЗапросВыборка = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Клиент,
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ЧастьНомера = ИСТИНА
	|				ТОГДА КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &НомерТелефона + ""%""
	|			ИНАЧЕ КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &НомерТелефона
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрагентыКонтактнаяИнформация.Ссылка,
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона");
	
	ЗапросВыборка.УстановитьПараметр("ЧастьНомера",ЧастьНомера);
	ЗапросВыборка.УстановитьПараметр("НомерТелефона",НомерТелефона);
	Выборка = ЗапросВыборка.Выполнить().Выгрузить();
	
	Возврат Выборка;
	
КонецФункции

