				"" + Ответ1С.Description + Символы.ПС + ТелоЗапроса);
				
				Возврат ПолучитьHTTPОтветAPI(400, Ответ1С, Истина);

			КонецЕсли;
			
		КонецЕсли;
		
		Ответ1С.Success     = Истина;
		Ответ1С.Description = "Выполнено успешно";		
		Возврат ПолучитьHTTPОтветAPI(200, Ответ1С, Истина);

	Исключение
		
		Ответ1С.Success = Ложь;
		Ответ1С.Description = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		
