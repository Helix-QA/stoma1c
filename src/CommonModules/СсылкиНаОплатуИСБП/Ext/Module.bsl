//
Функция РайффайзенБанк_ПолучитьСтатусПлатежа(ИдЗаказа, ПараметрыПШ, ТелоОтвета = Неопределено) Экспорт
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
	ЗаголовкиHTTP.Вставить("Authorization"		, "Bearer " + ПараметрыПШ.ПарольБанка);
		
	АдресСервера = ?(ПараметрыПШ.ТестовыйРежим, "test.ecom.raiffeisen.ru", "e-commerce.raiffeisen.ru");
	Соединение = Новый HTTPСоединение(АдресСервера,,,,,3, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос = Новый HTTPЗапрос(СтрЗаменить("/api/sbp/v1/qr/{qrId}/payment-info", "{qrId}", ИдЗаказа), ЗаголовкиHTTP);
		
	Попытка
		
		HTTPОтвет	 = Соединение.Получить(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			
			ИменаСвойствСоЗначениямиДата = Новый Массив;
			ИменаСвойствСоЗначениямиДата.Добавить("transactionDate");
			ИменаСвойствСоЗначениямиДата.Добавить("createDate");
			ИменаСвойствСоЗначениямиДата.Добавить("qrExpirationDate");
			
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета, ИменаСвойствСоЗначениямиДата);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
  		
		РезультатОперации = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса, КодСостояния);
		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

