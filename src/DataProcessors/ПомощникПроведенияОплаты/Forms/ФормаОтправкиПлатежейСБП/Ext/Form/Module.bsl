// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьСтатусНаСервере(НомерЗаказа)
	
	РезультатЗапроса = Неопределено;
	РегламентныеЗаданияСерверСтоматология.ОбработатьНеОплаченныеЗаказыСБП(НомерЗаказа, РезультатЗапроса);
	ВыборкаЗаказа = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьВыборкуЗаказаПоНомеру(НомерЗаказа);
	
	РезультатЗапроса.Вставить("Статус", ?(ВыборкаЗаказа <> Неопределено, ВыборкаЗаказа.Статус, Неопределено));
	
	Возврат РезультатЗапроса;
		
