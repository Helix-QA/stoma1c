&НаСервере
// Функция, создает контрагента и возвращает ссылку на него.
//
Функция СоздатьРодственника()
	
	КлиентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
	
	// Заполняем по умолчанию
	// Сотрудник регистрации, структурная единица, дата регистрации и прочее
	КлиентОбъект.Заполнить(Неопределено);
	
	КлиентОбъект.Фамилия  = Фамилия;
	КлиентОбъект.Имя      = Имя;
	КлиентОбъект.Отчество = Отчество;
	КлиентОбъект.ДатаРожденияКлиента = ДатаРождения;
	
	КлиентОбъект.Наименование	= КлиентОбъект.Фамилия + ?(ЗначениеЗаполнено(КлиентОбъект.Фамилия), " ", "") + КлиентОбъект.Имя + ?(ЗначениеЗаполнено(КлиентОбъект.Имя), " ", "") + КлиентОбъект.Отчество;
	КлиентОбъект.ТипКонтрагента	= Перечисления.ТипыКонтрагентов.Клиенты;
	КлиентОбъект.ЮрФизЛицо		= Перечисления.ЮрФизЛицо.ФизЛицо;
	
	КлиентОбъект.Родитель = Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);
	
	Если Не ПустаяСтрока(Телефон) Тогда
		// Преобразовываем номер согласно региональных настроек
		ОжидаемыйТип = УправлениеКонтактнойИнформациейСлужебныйПовтИсп.ТипВидаКонтактнойИнформации(Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
		ЗначенияПолей = Новый СписокЗначений;
		УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Телефон, ЗначенияПолей);
		// Получаем значение для записи
		Значение = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(УправлениеКонтактнойИнформациейСлужебный.ДесериализацияТелефона(ЗначенияПолей, Телефон, ОжидаемыйТип));		
		// Помещаем КИ в объект
		УправлениеКонтактнойИнформациейСтоматология.ЗаписатьКонтактнуюИнформацию(КлиентОбъект, Значение, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, ОжидаемыйТип);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПолНовогоКлиента) Тогда
		
		ПолКлиентаСтрокой = ОбщегоНазначенияСтоматология.ОпределитьПолКлиента(КлиентОбъект.Фамилия, КлиентОбъект.Имя, КлиентОбъект.Отчество);
		Если ПолКлиентаСтрокой = "Мужской" Тогда
			ПолРодственника = Перечисления.ПолФизическогоЛица.Мужской;
		ИначеЕсли ПолКлиентаСтрокой = "Женский" Тогда
			ПолРодственника = Перечисления.ПолФизическогоЛица.Женский;
		КонецЕсли;
		
	КонецЕсли;
	
	КлиентОбъект.ПолКлиента = ПолНовогоКлиента;
	
	// создать запись в регистре статусов контрагентов
	КлиентОбъект.ДополнительныеСвойства.Вставить("Статус", Перечисления.СтатусыКонтрагентов.Потенциальный);
	
	КлиентОбъект.Записать();
	
	Возврат КлиентОбъект.Ссылка;	
	
КонецФункции

&НаСервере
// Процедура - Удалить родственника на сервере.
//
Процедура УдалитьРодственникаНаСервере()
		
	НаборЗаписей = РегистрыСведений.РодственныеСвязи.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Контрагент.Установить(Запись.Контрагент);
	НаборЗаписей.Отбор.Родственник.Установить(РодственникДоИзменения);
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаконныйПредставительПриИзменении(Элемент)
	
	УстановитьВидимостьПолейРодственника();
		
КонецПроцедуры


