КонецФункции

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" Тогда// И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			ПолученыШтрихкоды(Данные);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолученыШтрихкоды(ДанныеШтрикодов)
	
	НеизвестныеШтрихкоды = Новый Массив;
	
	Для Каждого ЭлементШтрихкода Из ДанныеШтрикодов Цикл
		Если ОбработкаТабличныхЧастейКлиент.СШКОбработкаТабличнойЧасти(Элементы.Товары, ЭлементШтрихкода, Неопределено, Неопределено, Неопределено, Объект.Товары, НеизвестныеШтрихкоды) Тогда
		
			НоваяСтрока = Элементы.Товары.ТекущиеДанные;
			
			НоваяСтрока.ШаблонЦенника  = Объект.ШаблонДляПечати;
			НоваяСтрока.КоличествоЦенников	= 1;
			
			СтруктураДанные = Новый Структура();
			СтруктураДанные.Вставить("ДатаОбработки",		Объект.ЦеныНаДату);
			СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
			СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
			СтруктураДанные.Вставить("Номенклатура", 		НоваяСтрока.Номенклатура);
			СтруктураДанные.Вставить("Упаковка", 			НоваяСтрока.Упаковка);		
			
			СтруктураДанные                        = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);	
			НоваяСтрока.Цена                       = СтруктураДанные.Цена;
			НоваяСтрока.Упаковка                   = СтруктураДанные.Упаковка;
						
			НоваяСтрока.Штрихкод            = ЭлементШтрихкода.Штрихкод;			
			НоваяСтрока.ОстатокНаСкладе     = 0;// СтрокаТЧ.ОстатокНаСкладе;
			
			НоваяСтрока.Выбран = ПроверитьВозможностьВыбораТовара(НоваяСтрока, Режим);
			
		КонецЕсли;
		
		Если НеизвестныеШтрихкоды.Количество() > 0 Тогда 
			СтруктураПараметров = Новый Структура("НеизвестныеШтрихкоды", НеизвестныеШтрихкоды);
			ОткрытьФорму("РегистрСведений.Штрихкоды.Форма.РегистрацияШтрихкодовНоменклатуры", СтруктураПараметров, ЭтаФорма);
		КонецЕсли;
		
	КонецЦикла;
	
	
КонецФункции // ПолученыШтрихкоды()

