// Функция, выполняет проверку типа номенклатуры
//
Функция ПроверитьТипНоменклатуры(Документ, Номенклатура) Экспорт
	
	Если (ТипЗнч(Документ) = Тип("ДокументСсылка.ОприходованиеЗапасов") ИЛИ ТипЗнч(Документ) = Тип("ДокументСсылка.Поступление") 
			или ТипЗнч(Документ) = Тип("ДокументСсылка.ИнвентаризацияЗапасов") или ТипЗнч(Документ) = Тип("ДокументСсылка.СписаниеЗапасов") 
			или ТипЗнч(Документ) = Тип("ДокументСсылка.ВозвратОтПокупателя") или ТипЗнч(Документ) = Тип("ДокументСсылка.ВозвратПоставщику") 
			или ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеЗапасов")) 
			И (Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Запас
			И Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Материал
			И Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.ПодарочныйСертификат) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В данном документе нельзя добавлять "+Номенклатура.ТипНоменклатуры);
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
	
КонецФункции

