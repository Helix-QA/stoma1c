		Если СообщилиПрогресс = Ложь Тогда 
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеЗаморозки			= "";
			Прогресс 						= Цел(100 * СозданоЗаморозок / ОбщееКоличествоЗаморозок);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по актуальным заморозкам...';en='Saving data on current frosts...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеЗаморозки, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;			
	КонецЦикла;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
												
	ТаблицаМенеджеровПоПродажам.Очистить();					ТаблицаМенеджеровПоПродажам 	= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 					ТаблицаСотрудниковВБазе 		= Неопределено;
	ТаблицаАктуальныхОперации.Очистить(); 					ТаблицаАктуальныхОперации 		= Неопределено;
	ВыборкаПоКонтрактам 										= Неопределено;
												
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Загрузить долговые реализации в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьДолговыеРеализацииВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Закешируем константы, чтобы в цикле не обращаться к базе данных
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	Сотрудник_ПустаяСсылка								= Справочники.Сотрудники.ПустаяСсылка();	
	ЮрФизЛицо_ФизЛицо 									= Перечисления.ЮрФизЛицо.ФизЛицо;
	ТипКонтрагента_Клиенты						 		= Перечисления.ТипыКонтрагентов.Клиенты;
	ВидКарты_Магнитная 									= Перечисления.ВидыКарт.Магнитная;		
	ВидКартыШтриховая 									= Перечисления.ВидыКарт.Штриховая;	
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	ТипДенежныхСредств_Наличные 						= Перечисления.ТипыДенежныхСредств.Наличные;
	ТипДенежныхСредств_ЛицевойСчет 						= Перечисления.ТипыДенежныхСредств.ЛицевойСчет;
	ТипДенежныхСредств_Безналичные 						= Перечисления.ТипыДенежныхСредств.Безналичные;	
	ТипДенежныхСредств_ПлатежнаяКарта 					= Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта;	
	СтатьяДвиженияДенежныхСредств_ОплатаОтКлиента		= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ОплатаОтКлиента);
	СтатьяДвиженияДенежныхСредств_ВозвратОплатыКлиенту 	= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Реализации_Долг								= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Реализации_Долг;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Реализации_Долг, "Таблица_Реализации_Долг");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Таблица_Реализации_Долг.Организация КАК Организация
	               |ИЗ
	               |	Таблица_Реализации_Долг КАК Таблица_Реализации_Долг
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации_Долг.Организация
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Реализации_Долг.Исполнитель КАК Тренер,
	               |	Таблица_Реализации_Долг.ИсполнительГруппа КАК ТренерГруппа
	               |ИЗ
	               |	Таблица_Реализации_Долг КАК Таблица_Реализации_Долг
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации_Долг.ИсполнительГруппа,
	               |	Таблица_Реализации_Долг.Исполнитель
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Реализации_Долг.ОператорЧека КАК МенеджерПоПродажам
	               |ИЗ
	               |	Таблица_Реализации_Долг КАК Таблица_Реализации_Долг
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Реализации_Долг.ОператорЧека
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование,
	               |	Сотрудники.ЭтоГруппа КАК ЭтоГруппа
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВидыЛицевыхСчетов.Ссылка КАК Ссылка,
	               |	ВидыЛицевыхСчетов.Наименование КАК Наименование,
	               |	ВидыЛицевыхСчетов.Предопределенный КАК Предопределенный,
	               |	ВидыЛицевыхСчетов.ОграничиватьСуммуСписанияСоСчета КАК ОграничиватьСуммуСписанияСоСчета,
	               |	ВидыЛицевыхСчетов.ПроцентОграниченияСуммыСписанияСоСчета КАК ПроцентОграниченияСуммыСписанияСоСчета,
	               |	ВидыЛицевыхСчетов.ОграничениеПоСрокуДействия КАК ОграничениеПоСрокуДействия,
	               |	ВидыЛицевыхСчетов.Внешний КАК Внешний,
	               |	ВидыЛицевыхСчетов.Организация КАК Организация,
	               |	ВидыЛицевыхСчетов.НеВестиУчетВРазрезеОрганизаций КАК НеВестиУчетВРазрезеОрганизаций,
	               |	ВидыЛицевыхСчетов.СрокДействияДатойС КАК СрокДействияДатойС,
	               |	ВидыЛицевыхСчетов.СрокДействияДатойПо КАК СрокДействияДатойПо,
	               |	ВидыЛицевыхСчетов.СрокДействияТип КАК СрокДействияТип,
	               |	ВидыЛицевыхСчетов.СрокДействия КАК СрокДействия
	               |ИЗ
	               |	Справочник.ВидыЛицевыхСчетов КАК ВидыЛицевыхСчетов
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЛицевыеСчета.Ссылка КАК Ссылка,
	               |	ЛицевыеСчета.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
	               |	ЛицевыеСчета.ВладелецЛицевогоСчета КАК ВладелецЛицевогоСчета,
	               |	ЛицевыеСчета.КодСинхронизации КАК КодСинхронизации,
	               |	ЛицевыеСчета.ПрефиксСинхронизации КАК ПрефиксСинхронизации
	               |ИЗ
	               |	Справочник.ЛицевыеСчета КАК ЛицевыеСчета
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Реализации_Долг.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Реализации_Долг.ИДКлиента КАК ИДКлиента,
	               |	Таблица_Реализации_Долг.НомерЧека КАК НомерЧека,
	               |	Таблица_Реализации_Долг.ИДНоменклатуры КАК ИДНоменклатуры,
	               |	Таблица_Реализации_Долг.ИДНоменклатурыДоп КАК ИДНоменклатурыДоп,
	               |	Таблица_Реализации_Долг.Исполнитель КАК Исполнитель,
	               |	Таблица_Реализации_Долг.ИДБлока КАК ИДБлока,
	               |	Таблица_Реализации_Долг.Организация КАК Организация,
	               |	Таблица_Реализации_Долг.ДатаЧека КАК ДатаЧека,
	               |	Таблица_Реализации_Долг.ОператорЧека КАК ОператорЧека,
	               |	Таблица_Реализации_Долг.СрокДействияВычисляемый КАК СрокДействияВычисляемый,
	               |	Таблица_Реализации_Долг.КоличествоНоменклатуры КАК КоличествоНоменклатуры,
	               |	Таблица_Реализации_Долг.Цена КАК Цена,
	               |	Таблица_Реализации_Долг.Цена * Таблица_Реализации_Долг.КоличествоНоменклатуры КАК Стоимость,
	               |	Таблица_Реализации_Долг.ТипНоменклатуры КАК ТипНоменклатуры,
	               |	Таблица_Реализации_Долг.КоличествоУслуг КАК КоличествоУслуг,
	               |	Таблица_Реализации_Долг.ИсполнительГруппа КАК ИсполнительГруппа,
	               |	Таблица_Реализации_Долг.НомерЛС КАК НомерЛС,
	               |	Таблица_Реализации_Долг.ОкончаниеКонтракта КАК ОкончаниеКонтракта,
	               |	Таблица_Реализации_Долг.КоличествоДнейЗаморозки КАК КоличествоДнейЗаморозки,
	               |	Контрагенты.Ссылка КАК Клиент,
	               |	НоменклатураСтроки.Ссылка КАК НоменклатураСтроки,
	               |	НоменклатураСтрокиДоп.Ссылка КАК НоменклатураСтрокиДоп,
	               |	ВЫБОР
	               |		КОГДА НЕ НоменклатураСтроки.Ссылка ЕСТЬ NULL
	               |			ТОГДА НоменклатураСтроки.ТипНоменклатуры
	               |		КОГДА НЕ НоменклатураСтрокиДоп.Ссылка ЕСТЬ NULL
	               |			ТОГДА НоменклатураСтрокиДоп.ТипНоменклатуры
	               |		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПустаяСсылка)
	               |	КОНЕЦ КАК ТипНоменклатурыСтроки,
	               |	НоменклатураУслугиПакета.Ссылка КАК НоменклатураУслугиПакета,
	               |	НоменклатураУслугиПакетаДоп.Ссылка КАК НоменклатураУслугиПакетаДоп,
	               |	ЧленствоПакетУслуг.Ссылка КАК ПакетУслугСсылка
	               |ИЗ
	               |	Таблица_Реализации_Долг КАК Таблица_Реализации_Долг
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Реализации_Долг.ИДКлиента = Контрагенты.КодСинхронизации
	               |			И Таблица_Реализации_Долг.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Реализации_Долг.ИДКлиента > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСтроки
	               |		ПО Таблица_Реализации_Долг.ИДНоменклатуры = НоменклатураСтроки.КодСинхронизации
	               |			И Таблица_Реализации_Долг.ПрефиксСинхронизации = НоменклатураСтроки.ПрефиксСинхронизации
	               |			И (Таблица_Реализации_Долг.ИДНоменклатуры > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСтрокиДоп
	               |		ПО Таблица_Реализации_Долг.ИДНоменклатурыДоп = НоменклатураСтрокиДоп.КодСинхронизации
	               |			И Таблица_Реализации_Долг.ПрефиксСинхронизации = НоменклатураСтрокиДоп.ПрефиксСинхронизации
	               |			И (Таблица_Реализации_Долг.ИДНоменклатурыДоп > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураУслугиПакета
	               |		ПО (Таблица_Реализации_Долг.КодУслугиБлока_ИДНоменклатуры = НоменклатураСтроки.КодСинхронизации)
	               |			И (Таблица_Реализации_Долг.ПрефиксСинхронизации = НоменклатураСтроки.ПрефиксСинхронизации)
	               |			И (Таблица_Реализации_Долг.КодУслугиБлока_ИДНоменклатуры > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураУслугиПакетаДоп
	               |		ПО (Таблица_Реализации_Долг.КодУслугиБлока_ИДНоменклатурыДоп = НоменклатураСтрокиДоп.КодСинхронизации)
	               |			И (Таблица_Реализации_Долг.ПрефиксСинхронизации = НоменклатураСтрокиДоп.ПрефиксСинхронизации)
	               |			И (Таблица_Реализации_Долг.КодУслугиБлока_ИДНоменклатурыДоп > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг
	               |		ПО Таблица_Реализации_Долг.ИДБлока = ЧленствоПакетУслуг.КодСинхронизации
	               |			И Таблица_Реализации_Долг.ПрефиксСинхронизации = ЧленствоПакетУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Реализации_Долг.ИДБлока > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДКлиента
	               |ИТОГИ
	               |	МАКСИМУМ(ПрефиксСинхронизации),
	               |	МАКСИМУМ(НомерЧека),
	               |	МАКСИМУМ(Исполнитель),
	               |	МАКСИМУМ(Организация),
	               |	МАКСИМУМ(ОператорЧека),
	               |	СУММА(КоличествоНоменклатуры),
	               |	МАКСИМУМ(Цена),
	               |	СУММА(Стоимость),
	               |	МАКСИМУМ(ТипНоменклатуры),
	               |	МАКСИМУМ(КоличествоУслуг),
	               |	МАКСИМУМ(ИсполнительГруппа),
	               |	МАКСИМУМ(НомерЛС),
	               |	МАКСИМУМ(ОкончаниеКонтракта),
	               |	МАКСИМУМ(КоличествоДнейЗаморозки),
	               |	МАКСИМУМ(Клиент),
	               |	МАКСИМУМ(НоменклатураСтроки),
	               |	МАКСИМУМ(НоменклатураСтрокиДоп),
	               |	МАКСИМУМ(ТипНоменклатурыСтроки),
	               |	МАКСИМУМ(НоменклатураУслугиПакета),
	               |	МАКСИМУМ(НоменклатураУслугиПакетаДоп),
	               |	МАКСИМУМ(ПакетУслугСсылка)
	               |ПО
	               |	ИДКлиента,
	               |	ДатаЧека,
	               |	ИДНоменклатуры,
	               |	Исполнитель";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ВыборкаОрганизации			 				= РезультатПакетаЗапросов[0].Выбрать();
	ТаблицаТренеров	 							= РезультатПакетаЗапросов[1].Выгрузить();	
	ТаблицаМенеджеровПоПродажам					= РезультатПакетаЗапросов[2].Выгрузить();
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[3].Выгрузить();
	ТаблицаВидовЛицевыхСчетовВБазе				= РезультатПакетаЗапросов[4].Выгрузить();
	ТаблицаЛицевыхСчетовВБазе					= РезультатПакетаЗапросов[5].Выгрузить();	
	ВыборкаПоКлиентам							= РезультатПакетаЗапросов[6].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем необходимые виды ЛС на текущем этапе
	АктуализироватьТаблицуВидовЛицевыхСчетов(ТаблицаВидовЛицевыхСчетовВБазе);
	
	// Создадим и заполним таблицу соответствия организаций и касс	
	ТаблицаОрганизации = Новый ТаблицаЗначений;
	ТаблицаОрганизации.Колонки.Добавить("Организация"				,Новый ОписаниеТипов("Строка" ,, Новый КвалификаторыСтроки(90)));
	ТаблицаОрганизации.Колонки.Добавить("ОрганизацияСсылка"			,Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТаблицаОрганизации.Колонки.Добавить("КассаСсылка"				,Новый ОписаниеТипов("СправочникСсылка.Кассы"));
	ТаблицаОрганизации.Колонки.Добавить("БанковскийСчетПоУмолчанию"	,Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));
	ТаблицаОрганизации.Колонки.Добавить("ЭквайринговыйТерминал"		,Новый ОписаниеТипов("СправочникСсылка.ЭквайринговыеТерминалы"));
	
	// Создаем организации и соответствия организаций и касс
	Пока ВыборкаОрганизации.Следующий() Цикл
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));	
		ОрганизацияНаименование 					= СтрЗаменить(ВыборкаОрганизации.Организация, """""", """");
		СтрокаОрганизация = ТаблицаОрганизации.Найти(ОрганизацияНаименование, "Организация");
		Если СтрокаОрганизация = Неопределено Тогда 
			СтруктураОрганизация 						= СоздатьОрганизацию(ОрганизацияНаименование, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТаблицаВидовЛицевыхСчетовВБазе);
			СтрокаТаблицыОиК 							= ТаблицаОрганизации.Добавить();
			СтрокаТаблицыОиК.Организация 				= ВыборкаОрганизации.Организация;
			СтрокаТаблицыОиК.ОрганизацияСсылка 			= СтруктураОрганизация.ОрганизацияСсылка;
			СтрокаТаблицыОиК.КассаСсылка 				= СтруктураОрганизация.КассаСсылка;
			СтрокаТаблицыОиК.БанковскийСчетПоУмолчанию 	= СтруктураОрганизация.БанковскийСчетПоУмолчанию;
			СтрокаТаблицыОиК.ЭквайринговыйТерминал 		= СтруктураОрганизация.ЭквайринговыйТерминал;
		КонецЕсли;
	КонецЦикла;	
	
	// Получим должность для менеджеров по продажам	
	ДолжностьМенеджер 	= ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	// Получим должность для тренера	
	ДолжностьТренер 	= ПолучитьДолжностьПоНаименованию("Тренер");
	
	// Создаем необходимых тренеров на текущем этапе
	Для Каждого СтрокаТренер Из ТаблицаТренеров Цикл
		Если НЕ СокрЛП(СтрокаТренер.Тренер) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.Тренер), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				ГруппаСотрудника = Неопределено;
				Если НЕ СокрЛП(СтрокаТренер.ТренерГруппа) = "" Тогда
					МассивСтрокГруппСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаТренер.ТренерГруппа), Истина));
					Если МассивСтрокГруппСотрудников.Количество() = 0 Тогда
						ГруппаСотрудника = СоздатьГруппуСотрудникаПоНаименованию(СтрокаТренер.ТренерГруппа, ТекстовыйНакопитель);
						ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ГруппаСотрудника);
					Иначе 
						ГруппаСотрудника = МассивСтрокГруппСотрудников[0].Ссылка;
					КонецЕсли;
				КонецЕсли;
				ТренерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаТренер.Тренер, ДолжностьТренер, ГруппаСотрудника, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), ТренерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаТренер.Тренер, 0, ""));		
	КонецЦикла;
	
	// Создаем необходимых менеджеров на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеровПоПродажам Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.МенеджерПоПродажам) = "" Тогда 
			МассивСтрокСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", СокрЛП(СтрокаМенеджер.МенеджерПоПродажам), Ложь));
			Если МассивСтрокСотрудников.Количество() = 0 Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.МенеджерПоПродажам, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(МассивСтрокСотрудников[0].Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);					
			КонецЕсли;
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.МенеджерПоПродажам, 0, ""));		
	КонецЦикла;
	
	#КонецОбласти
	
	Если ВыборкаПоКлиентам.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по реализациям...';en='Saving data by realizations...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоРеализаций 	= ВыборкаПоКлиентам.Количество();
	ОбщееКоличествоРеализаций	= ?(ОбщееКоличествоРеализаций < 1, 1, ОбщееКоличествоРеализаций);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоРеализаций			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеРеализации		= "";
	
	МассивБессрочныхЧПУ = ПолучитьМассивБессрочныхЧПУ(ПараметрыЗадания.ПараметрыЗагрузки.СегментБессрочныхЧПУ);
	ПараметрыЗадания.ПараметрыЗагрузки.Вставить("МассивБессрочных", МассивБессрочныхЧПУ);
	
	ЕстьПакетУслуг = Ложь;	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКлиентам.Следующий() Цикл
		СообщилиПрогресс 	= Ложь;
		СозданоРеализаций 	= СозданоРеализаций + 1;
		
	#Область Получение_контрагента
		
		// Создаем клиента не выгруженного по каким-то причинам (наполнение контрагента будет отличаться от созданных на этапе "Клиенты"!)
		Если ЗначениеЗаполнено(ВыборкаПоКлиентам.Клиент) Тогда
			ТекущийКлиент 				= ВыборкаПоКлиентам.Клиент;
			КлиентНайден 				= Истина;
		Иначе
			Клиент 						= Справочники.Контрагенты.СоздатьЭлемент();
			Клиент.Родитель 			= ПараметрыЗадания.ПараметрыЗагрузки.ВыборПапкиСправочника; 
			Клиент.Наименование 		= ВыборкаПоКлиентам.ИДКлиента;
			Клиент.НаименованиеПолное 	= ВыборкаПоКлиентам.ИДКлиента;
			Клиент.КодСинхронизации 	= ВыборкаПоКлиентам.ИДКлиента;
			Клиент.ПрефиксСинхронизации = ВыборкаПоКлиентам.ПрефиксСинхронизации;			
			Клиент.ЮрФизЛицо 			= ЮрФизЛицо_ФизЛицо;
			Клиент.ТипКонтрагента 		= ТипКонтрагента_Клиенты;
			Клиент.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			Клиент.Комментарий 			= ВыборкаПоКлиентам.ПрефиксСинхронизации;
			Клиент.УстановитьНовыйКод();
			Клиент.ОбменДанными.Загрузка = Истина;
			Попытка
				Клиент.Записать();
			Исключение
				// Запись в лог						
				ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка при создании клиента! Код синхронизации: ';en= 'Error creating client! Sync Code: '") + Строка(ВыборкаПоКлиентам.ИДКлиента) + Символы.ПС + ОписаниеОшибки());						
			КонецПопытки;	
			ТекущийКлиент 				= Клиент.Ссылка; // Создаем клиента не выгруженного по каким-то причинам   
			КлиентНайден 				= Ложь;			
		КонецЕсли;
		
	#КонецОбласти
		
		ВыборкаПоЧекам = ВыборкаПоКлиентам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ДатаЧека");
		
		Пока ВыборкаПоЧекам.Следующий() Цикл
			ЕстьПакетУслуг = Ложь;
			// Выберем организацию и кассу тек.строки
			СтрокаОрганизация 			= ТаблицаОрганизации.Найти(ВыборкаПоЧекам.Организация, "Организация");
			ТекКасса 					= СтрокаОрганизация.КассаСсылка;
			ТекОрганизация 				= СтрокаОрганизация.ОрганизацияСсылка;
			БанковскийСчетПоУмолчанию 	= СтрокаОрганизация.БанковскийСчетПоУмолчанию;
			ЭквайринговыйТерминал 		= СтрокаОрганизация.ЭквайринговыйТерминал; 
			
			// Менеджер реализации
			МенеджерСтрокой = СокрЛП(ВыборкаПоЧекам.ОператорЧека);
			МенеджерРеализации = Сотрудник_ПустаяСсылка;
			Если МенеджерСтрокой <> "" Тогда
				СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Наименование, ЭтоГруппа", МенеджерСтрокой, Ложь));
				Если НЕ СтрокаМенеджерСотрудник.Количество() = 0 Тогда
					МенеджерРеализации = СтрокаМенеджерСотрудник[0].Ссылка;
				КонецЕсли;
			КонецЕсли;	
			
			ДокументРеализация 						= Документы.Реализация.СоздатьДокумент();
			ДокументРеализация.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			ДокументРеализация.Склад 				= ПараметрыЗадания.ПараметрыЗагрузки.ОсновнойСкладСтруктурнойЕдиницы;
			ДокументРеализация.Организация 			= ТекОрганизация;
			ДокументРеализация.Дата 				= ВыборкаПоЧекам.ДатаЧека;
			ДокументРеализация.КодСинхронизации 	= ВыборкаПоЧекам.НомерЧека;
			ДокументРеализация.ПрефиксСинхронизации = ВыборкаПоЧекам.ПрефиксСинхронизации;
			ДокументРеализация.Комментарий 			= ВыборкаПоЧекам.ПрефиксСинхронизации + " - " + Формат(ВыборкаПоЧекам.НомерЧека, "ЧГ=0");
			ДокументРеализация.Контрагент 			= ТекущийКлиент;
			ДокументРеализация.АвторДокумента 		= ?(ЗначениеЗаполнено(МенеджерРеализации), МенеджерРеализации, ТекущийПользовательСеанса);
			ДокументРеализация.ВидЦен 				= ВидЦен_Розничная;
			
			ВыборкаПоНоменклатуре = ВыборкаПоЧекам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ИДНоменклатуры");
			
			#Область Создание_пакетов_услуг_и_заполнение_их_в_ТЧ_Реализации
			
			Пока ВыборкаПоНоменклатуре.Следующий() Цикл
				Если ВыборкаПоНоменклатуре.КоличествоНоменклатуры = 0 И ВыборкаПоНоменклатуре.Стоимость = 0 Тогда // пропуск если полный возврат номенклатуры
					Продолжить;
				КонецЕсли;
				ВыборкаПоСтрокам = ВыборкаПоНоменклатуре.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Исполнитель");
				Пока ВыборкаПоСтрокам.Следующий() Цикл
					Если ВыборкаПоСтрокам.КоличествоНоменклатуры = 0 И ВыборкаПоСтрокам.Стоимость = 0 Тогда // пропуск если полный возврат номенклатуры
						Продолжить;
					КонецЕсли;
					// Строка в реализации с номенклатурой и исполнителем
					Если ВыборкаПоСтрокам.ТипНоменклатуры = 3  Тогда // Пакет услуг
						ВыборкаПоБлокам = ВыборкаПоСтрокам.Выбрать();
						Если ВыборкаПоСтрокам.КоличествоНоменклатуры = 0 И ВыборкаПоСтрокам.Стоимость > 0 Тогда //*** Блок с частичным возвратом суммы
							ВыборкаПоБлокам.Следующий(); //  Для того чтоб пропустить группировку по оплатам
							Если ЗначениеЗаполнено(ВыборкаПоБлокам.НоменклатураСтроки) Тогда
								НоменклатураСтроки = ВыборкаПоБлокам.НоменклатураСтроки;
							ИначеЕсли ЗначениеЗаполнено(ВыборкаПоБлокам.НоменклатураСтрокиДоп) Тогда // если перепутан тип номенклатуры 0->3
								НоменклатураСтроки = ВыборкаПоБлокам.НоменклатураСтрокиДоп;			
							Иначе
								НоменклатураСтроки = Неопределено;
								// Запись в лог...
								ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + "Не найдена номенклатура при попытке создания пакета услуг! Код синхронизации: " + Строка(ВыборкаПоБлокам.ИДНоменклатуры) + " Клиент: " + Строка(ТекущийКлиент));									
								Продолжить;
							КонецЕсли;
							
							// Создадим пакет услуг
							ПакетУслуг = Неопределено;
							Если ЗначениеЗаполнено(ВыборкаПоБлокам.ПакетУслугСсылка) Тогда
								ПакетУслуг = ВыборкаПоБлокам.ПакетУслугСсылка;
								ОбновитьПакетУслуг(ПакетУслуг, ВыборкаПоБлокам, НоменклатураСтроки, ТекущийКлиент, ПараметрыЗадания.ПараметрыЗагрузки, ТекстовыйНакопитель);
							Иначе
								
								НС 						= ДокументРеализация.Запасы.Добавить();
								НС.КлючСтроки 			= Новый УникальныйИдентификатор();
								НС.Номенклатура 		= НоменклатураСтроки.Ссылка;
								НС.Основание 			= ?(ПакетУслуг = Неопределено, Неопределено, ПакетУслуг.Ссылка);
