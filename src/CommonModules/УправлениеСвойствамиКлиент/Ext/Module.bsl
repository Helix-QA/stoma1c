
#Область СлужебныйПрограммныйИнтерфейс

// Выполнить редактирование состава свойств
//
Процедура РедактироватьСоставСвойств(Форма, Ссылка) Экспорт
	
	Наборы = Форма.__Свойства_ОсновнойНабор;
	// Если вернули СправочникСсылка.НаборыСвойств, то это объект с одним набором свойств
	Если ТипЗнч(Наборы) = Тип("СправочникСсылка.НаборыСвойств") Тогда
		ПараметрыФормыНабораСвойств = Новый Структура("Ключ", Форма.__Свойства_ОсновнойНабор);
		
		ОткрытьФорму("Справочник.НаборыСвойств.Форма.ФормаЭлемента", ПараметрыФормыНабораСвойств,,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
       	// ...Иначе - это объект у которого может быть несколько наборов свойств 
	// и требуется выбрать редактируемый набор
	Иначе
		Если Наборы.Количество() = 1 Тогда
			Элемент = Наборы.Получить(0);
		Иначе
			Элемент = Наборы.ВыбратьЭлемент();
			Если Элемент = Неопределено Тогда
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		ПараметрыФормыНабораСвойств = Новый Структура("Ключ", Элемент.Значение);
		
		ОткрытьФорму("Справочник.НаборыСвойств.Форма.ФормаЭлемента", ПараметрыФормыНабораСвойств,,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			
	КонецЕсли;
	
КонецПроцедуры

// Проверить, связано ли оповещение с изменением набора свойств и нужно ли 
// обрабатывать его в текущей форме
Функция ОбрабатыватьОповещения(Форма, ИмяСобытия, Параметр) Экспорт
	
	Если (ИмяСобытия <> "ИзмененНаборСвойств") ИЛИ Не Форма.__Свойства_ИспользоватьСвойства Тогда
		Возврат Ложь;
		
	ИначеЕсли Форма.__Свойства_ОсновнойНабор = Параметр Тогда
		Возврат Истина;
		
	ИначеЕсли (ТипЗнч(Форма.__Свойства_ОсновнойНабор) = Тип("СписокЗначений"))
		И (Форма.__Свойства_ОсновнойНабор.НайтиПоЗначению(Параметр) <> Неопределено) Тогда
		Возврат Истина;
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Процедура - Открыть форму ввода доп информации
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОткрытьФормуВводаДопИнформации(Результат = Неопределено, ДополнительныеПараметры = Неопределено, Форма, Знач ВладелецСсылка = Неопределено) Экспорт
	
	ЭтоКлиент 		= Ложь;
	ЭтоКонтрагент 	= Ложь;
		
	Если ТипЗнч(ВладелецСсылка) = Тип("СправочникСсылка.Контрагенты") Тогда
		Если Форма.ИмяФормы = "Документ.Визит.Форма.ФормаДокумента" Тогда
			ЭтоКлиент 		= Истина;
		ИначеЕсли Форма.Объект.ТипКонтрагента = ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Клиенты") Тогда 
			ЭтоКлиент 		= Истина;
		Иначе 
			ЭтоКонтрагент 	= Истина;
		КонецЕсли;
	КонецЕсли;	
	
	Если ТипЗнч(Результат) = Тип("КодВозвратаДиалога") И Результат = КодВозвратаДиалога.Да Тогда
		Записать = Истина;
	ИначеЕсли ТипЗнч(Результат) = Тип("КодВозвратаДиалога") И Результат = КодВозвратаДиалога.Нет Тогда
		Записать = Ложь;
	Иначе
		Записать = Неопределено;
	КонецЕсли;	
	
	Если ВладелецСсылка.Пустая() Тогда
		Если Записать = Неопределено Тогда
			Возврат;
		ИначеЕсли Записать = Истина И Форма.ПроверитьЗаполнение() Тогда
			ФормаЗаписана = Форма.Записать();
			ВладелецСсылка = Форма.Объект.Ссылка;
			Если НЕ ФормаЗаписана Тогда
				Возврат;
			КонецЕсли;
			Если ЭтоКлиент Тогда 
				Форма.Заголовок = Строка(ВладелецСсылка) + " (Клиент)";
			КонецЕсли;	
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Свойство("ЭтоУдостоверениеЛичности") И ДополнительныеПараметры.ЭтоУдостоверениеЛичности Тогда 
		
		Параметр = Новый Структура("Контрагент", ВладелецСсылка);
		ОткрытьФорму("РегистрСведений.ДокументыФизическихЛиц.ФормаЗаписи", Параметр,,,,,, РежимОткрытияОкнаФормы.Независимый);
		
	ИначеЕсли ДополнительныеПараметры.Свойство("ЭтоКарта") И ДополнительныеПараметры.ЭтоКарта Тогда
		
		Параметр = Новый Структура("ВладелецКарты", ВладелецСсылка);
		ОткрытьФорму("Справочник.Карты.Форма.ФормаНовогоЭлемента", Параметр);
			
	ИначеЕсли ДополнительныеПараметры.Свойство("ЭтоРодственник") И ДополнительныеПараметры.ЭтоРодственник Тогда	
		
		Параметр = Новый Структура("Контрагент", ВладелецСсылка);
		ОткрытьФорму("РегистрСведений.РодственныеСвязи.ФормаЗаписи", Параметр,,,,,, РежимОткрытияОкнаФормы.Независимый);
		
	ИначеЕсли ДополнительныеПараметры.Свойство("ЭтоВзносНаЛицевойСчет") И ДополнительныеПараметры.ЭтоВзносНаЛицевойСчет Тогда
		
		ЛицевойСчет = Неопределено;
		ДополнительныеПараметры.Свойство("ЛицевойСчет", ЛицевойСчет);
		ПараметрыФормы = Новый Структура("Контрагент, ЛицевойСчет", ВладелецСсылка, ЛицевойСчет);
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ДиалогВзносаНаЛицевойСчет", ПараметрыФормы, Форма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
		
	ИначеЕсли ДополнительныеПараметры.Свойство("ЭтоВзносНаБонусныйСчет") И ДополнительныеПараметры.ЭтоВзносНаБонусныйСчет Тогда
		
		БонусныйСчет = Неопределено;
		ДополнительныеПараметры.Свойство("БонусныйСчет", БонусныйСчет);
		ПараметрыФормы = Новый Структура("Контрагент, БонусныйСчет", ВладелецСсылка, БонусныйСчет);
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ДиалогВзносаНаБонусныйСчет", ПараметрыФормы, Форма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);  
			
	ИначеЕсли ДополнительныеПараметры.Свойство("ЭтоСкидка") И ДополнительныеПараметры.ЭтоСкидка Тогда
		
		ПараметрыОтбора = Новый Структура("ТипПолучателя, ТекущаяСтруктурнаяЕдиница, ТекущаяДата", 
		ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов"), Истина, ТекущаяДата());
		ОткрытьФорму("Справочник.СкидкиНаценки.ФормаВыбора", Новый Структура("Отбор, Клиент, ПравоНазначения", ПараметрыОтбора, ВладелецСсылка, Истина),, Новый УникальныйИдентификатор,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	ИначеЕсли ДополнительныеПараметры.Свойство("ЭтоПромокод") И ДополнительныеПараметры.ЭтоПромокод Тогда

	КонецЕсли;
	
КонецПроцедуры

// Процедура - Действие дополнительной информации нажатие
//
// Параметры:
//  Форма	 - 	 - 
//  Элемент	 - 	 - 
//
Процедура ДействиеДополнительнойИнформацииНажатие(Форма, Элемент) Экспорт
	
	Попытка
		
		СтруктураДанныеЭлемента = ПолучитьДанныеЭлемента(Форма, Элемент);
		
		Если СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
			Возврат;
		КонецЕсли;
		
		Если СтруктураДанныеЭлемента.ИмяТаблицы = "УдостоверенияЛичностиСуществующие" Тогда 
			
			КлючСтруктурой = ПолучитьКлючСтруктурой(СтруктураДанныеЭлемента);
			Если КлючСтруктурой <> Неопределено Тогда
				ПараметрыМассив = Новый Массив;
				ПараметрыМассив.Добавить(КлючСтруктурой);   		
				КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.ДокументыФизическихЛиц", ПараметрыМассив);
				ОткрытьФорму("РегистрСведений.ДокументыФизическихЛиц.Форма.ФормаЗаписи", Новый Структура("Ключ", КлючЗаписиРегистра),,,,,, РежимОткрытияОкнаФормы.Независимый);//РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
			КонецЕсли;
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "КартыСуществующие" Тогда
			
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.КартаСсылка));
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "АвтомобилиСуществующие" Тогда
			
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.АвтомобильСсылка));
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "РодственникиСуществующие" Тогда 
			
			КлючСтруктурой = ПолучитьКлючСтруктурой(СтруктураДанныеЭлемента);
			Если КлючСтруктурой <> Неопределено Тогда
				ПараметрыМассив = Новый Массив;
				ПараметрыМассив.Добавить(КлючСтруктурой);   		
				КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.РодственныеСвязи", ПараметрыМассив);
				ОткрытьФорму("РегистрСведений.РодственныеСвязи.Форма.ФормаЗаписи", Новый Структура("Ключ", КлючЗаписиРегистра),,,,,, РежимОткрытияОкнаФормы.Независимый);//РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
			КонецЕсли;
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "МестаРаботы" Тогда
			
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.СтруктурнаяЕдиница));
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "ДоступныеКассы" Тогда
			
			Если СтруктураДанныеЭлемента.ДанныеЭлемента.Основная Тогда 
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.Касса));
			Иначе 
				СписокВариантов = Новый СписокЗначений;
				СписокВариантов.Добавить(0, "Открыть");
				СписокВариантов.Добавить(1, "Назначить основной");
				ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВариантаДействияСКассой", Форма, СтруктураДанныеЭлемента.ДанныеЭлемента);
				Форма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВариантов, Элемент);
			КонецЕсли;
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "ДоступныеРесурсы" Тогда
			
			Если СтруктураДанныеЭлемента.ДанныеЭлемента.Основной Тогда 
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.Ресурс));
			Иначе 
				СписокВариантов = Новый СписокЗначений;
				СписокВариантов.Добавить(0, "Открыть");
				СписокВариантов.Добавить(1, "Назначить основным");
				ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВариантаДействияСРесурсом", Форма, СтруктураДанныеЭлемента.ДанныеЭлемента);
				Форма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВариантов, Элемент);
			КонецЕсли;

		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "ТаблицаЛицевыхСчетов" Тогда
			
			Если НЕ ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.ЛицевойСчет) Тогда 
				Возврат;
			Иначе 
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.ЛицевойСчет));
			КонецЕсли;
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "ТаблицаБонусныхСчетов" Тогда
			
			Если НЕ ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.БонусныйСчет) Тогда 
				Возврат;
			Иначе 
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.БонусныйСчет));
			КонецЕсли;	
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "ТаблицаВизитов" Тогда
			
			Если НЕ ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.Визит) Тогда 
				Возврат;
			Иначе 
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.Визит));
			КонецЕсли;
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "Информация_По_Оплате" Тогда
			
			Если СтруктураДанныеЭлемента.ДанныеЭлемента.ДокументОплаты <> Неопределено Тогда
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.ДокументОплаты));
			КонецЕсли;
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "СкидкиСуществующие" Тогда
			
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтруктураДанныеЭлемента.ДанныеЭлемента.Скидка));  
			
		ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "ПромокодыСуществующие" Тогда	
			
		КлючСтруктурой = Новый Структура;
		КлючСтруктурой.Вставить("Вид"		, СтруктураДанныеЭлемента.ДанныеЭлемента.ПромокодСсылка);
		КлючСтруктурой.Вставить("Владелец"	, Форма.Объект.Ссылка);
		ПараметрыМассив = Новый Массив;
		ПараметрыМассив.Добавить(КлючСтруктурой);   		
		КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.Промокоды", ПараметрыМассив);
		ОткрытьФорму("РегистрСведений.Промокоды.Форма.ФормаЗаписиБыстрая", Новый Структура("Ключ", КлючЗаписиРегистра),,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);			
		КонецЕсли;
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецПроцедуры

// Процедура - Действие дополнительной информации нажатие
//
// Параметры:
//  Форма	 - 	 - 
//  Элемент	 - 	 - 
//
Процедура ДействиеДополнительнойИнформации_Удалить_Нажатие(Форма, Элемент) Экспорт
	
	СтруктураДанныеЭлемента = ПолучитьДанныеЭлемента(Форма, Элемент);
	
	Если СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция - Получить данные элемента
//
// Параметры:
//  Форма	 - 	 - 
//  Элемент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеЭлемента(Знач Форма, Знач Элемент) Экспорт
	
	Если СтрНачинаетсяС(Элемент.Имя, "УдостоверенияЛичностиСуществующие_") Тогда 
		
		ИмяТаблицы 				= "УдостоверенияЛичностиСуществующие";        
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("УдостоверенияЛичностиСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.УдостоверенияЛичностиСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "УдостоверениеЛичностиУдалить_") Тогда
		
		ИмяТаблицы 				= "УдостоверениеЛичностиУдалить";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("УдостоверениеЛичностиУдалить_") + 1));
		ДанныеЭлемента 			= Форма.УдостоверенияЛичностиСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "КартыСуществующие_") Тогда
		
		ИмяТаблицы 				= "КартыСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("КартыСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.КартыСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "РодственникиСуществующие_") Тогда
		
		ИмяТаблицы 				= "РодственникиСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("РодственникиСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.РодственникиСуществующие[ИндексСтроки];

	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "СкидкиСуществующие_") Тогда
		
		ИмяТаблицы 				= "СкидкиСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("СкидкиСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.СкидкиСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ПромокодыСуществующие_") Тогда
		ИмяТаблицы 				= "ПромокодыСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ПромокодыСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.ПромокодыСуществующие[ИндексСтроки];	

	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "МестоРаботыВыбранные_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "МестоРаботыУдалить_") Тогда 
		
		ИмяТаблицы 				= "МестаРаботы";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "МестоРаботыВыбранные_"), СтрДлина("МестоРаботыВыбранные_"), СтрДлина("МестоРаботыУдалить_")) + 1));
		ДанныеЭлемента 			= Форма.Объект.МестаРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ДоступныйКабинетВыбранный_") Тогда 
		
		ИмяТаблицы 				= "ДоступныеРесурсы";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ДоступныйКабинетВыбранный_") + 1));
		ДанныеЭлемента 			= Форма.ДоступныеРесурсы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ДоступнаяКассаВыбранные_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "ДоступнаяКассаУдалить_") Тогда 
		
		ИмяТаблицы 				= "ДоступныеКассы";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "ДоступнаяКассаВыбранные_"), СтрДлина("ДоступнаяКассаВыбранные_"), СтрДлина("ДоступнаяКассаУдалить_")) + 1));
		ДанныеЭлемента 			= Форма.Объект.ДоступныеКассы[ИндексСтроки];

	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ДополнитьИнформациюОКлиенте_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ОформитьПродажу_") Тогда 
		
		ИмяТаблицы 				= "ТекущиеВзаимодействия";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ДополнитьИнформациюОКлиенте_"), СтрДлина("Подключаемый_ДополнитьИнформациюОКлиенте_"), СтрДлина("Подключаемый_ОформитьПродажу_")) + 1));
		ДанныеЭлемента 			= Форма.ТекущиеВзаимодействия[ИндексСтроки];
				
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_Открыть_Субъект_Оплаты_") Тогда
		
		ИмяТаблицы 				= "Информация_По_Оплате";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_Открыть_Субъект_Оплаты_") + 1));
		ДанныеЭлемента 			= Форма.Информация_По_Оплате[ИндексСтроки];  
		
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_Открыть_Субъект_Промокода_") Тогда
		ИмяТаблицы              = "Промокод";
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_Открыть_Субъект_Промокода_") + 1));
		ДанныеЭлемента			= Форма.Объект.Промокод;
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ДекорацияФормы_УдалениеИнтервала_") Тогда 
		
		ИмяТаблицы 				= "ОтборИнтервалыРаботы";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ДекорацияФормы_УдалениеИнтервала_") + 1));
		ДанныеЭлемента 			= Форма.ОтборИнтервалыРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ВыборНачалаИнтервала_") Тогда 
		
		ИмяТаблицы 				= "ОтборИнтервалыРаботы";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_ВыборНачалаИнтервала_") + 1));
		ДанныеЭлемента 			= Форма.ОтборИнтервалыРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ВыборОкончанияИнтервала_") Тогда 
		
		ИмяТаблицы 				= "ОтборИнтервалыРаботы";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_ВыборОкончанияИнтервала_") + 1));
		ДанныеЭлемента 			= Форма.ОтборИнтервалыРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ПомещениеСотрудника_Открыть_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "ПомещениеСотрудника_Удалить_") Тогда 
		
		ИмяТаблицы 				= "ТаблицаПомещенияСотрудника";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "ПомещениеСотрудника_Открыть_"), СтрДлина("ПомещениеСотрудника_Открыть_"), СтрДлина("ПомещениеСотрудника_Удалить_")) + 1));
		ДанныеЭлемента 			= Форма.ТаблицаПомещенияСотрудника[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Лицевой_Счет_Контрагента_") Тогда
		
		ИмяТаблицы 				= "ТаблицаЛицевыхСчетов";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Лицевой_Счет_Контрагента_") + 1));
		ДанныеЭлемента 			= Форма.ТаблицаЛицевыхСчетов[ИндексСтроки]; 
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Бонусный_Счет_Контрагента_") Тогда
		
		ИмяТаблицы 				= "ТаблицаБонусныхСчетов";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Бонусный_Счет_Контрагента_") + 1));
		ДанныеЭлемента 			= Форма.ТаблицаБонусныхСчетов[ИндексСтроки]; 
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Визит_Контрагента_") Тогда
		
		ИмяТаблицы 				= "ТаблицаВизитов";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Визит_Контрагента_") + 1));
		ДанныеЭлемента 			= Форма.ТаблицаВизитов[ИндексСтроки];
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "_ДобавитьСтрокуТабличнойЧасти_") = 0 Тогда
		
		ИмяТаблицы 				= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_ДобавитьСтрокуТабличнойЧасти_") + СтрДлина("_ДобавитьСтрокуТабличнойЧасти_"));
		ИндексСтроки 			= Неопределено;
		ДанныеЭлемента 			= Неопределено;
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "_УдалитьСтроку_ТЧ_") = 0 Тогда 
		
		ИмяТЧ_Индекс_Строкой 	= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_УдалитьСтроку_ТЧ_") + СтрДлина("_УдалитьСтроку_ТЧ_"));
		ИмяТаблицы 				= Лев(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") - 1);
		ИндексСтроки 			= Число(Сред(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") + 1));
		ДанныеЭлемента 			= ?(Форма.Объект[ИмяТаблицы].Количество()-1 >= ИндексСтроки, Форма.Объект[ИмяТаблицы][ИндексСтроки], Неопределено);
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "ПолеФормы_") = 0 И НЕ СтрНайти(Элемент.Имя, "_ТЧ_") = 0 Тогда
		
		ИмяТЧ_Индекс_Строкой 	= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_ТЧ_") + СтрДлина("_ТЧ_"));
		ИмяТаблицы 				= Лев(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") - 1);
		ИндексСтроки 			= Число(Сред(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") + 1));
		ДанныеЭлемента 			= Форма.Объект[ИмяТаблицы][ИндексСтроки];
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "ПолеРедактирование_") = 0 И НЕ СтрНайти(Элемент.Имя, "_ТЧ_") = 0 Тогда
		
		ИмяТЧ_Индекс_Строкой 	= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_ТЧ_") + СтрДлина("_ТЧ_"));
		ИмяТаблицы 				= Лев(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") - 1);
		ИндексСтроки 			= Число(Сред(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") + 1));
		ДанныеЭлемента 			= Форма.Объект[ИмяТаблицы][ИндексСтроки];

	Иначе 
		
		ИмяТаблицы 		= "";
		ДанныеЭлемента 	= Неопределено;
		
	КонецЕсли;
	
	Возврат Новый Структура("ИмяТаблицы, ИндексСтроки, ДанныеЭлемента", ИмяТаблицы, ИндексСтроки, ДанныеЭлемента);
	
КонецФункции

// Функция, возвращает структуру данных документов физ. лиц 
// клиенту
//
Функция ПолучитьКлючСтруктурой(Знач СтруктураДанныеЭлемента)
	
	Если СтруктураДанныеЭлемента.ИмяТаблицы = "УдостоверенияЛичностиСуществующие" Тогда
		
		СтруктураВозврата = Новый Структура("Период, ВидДокумента, Физлицо");	
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, СтруктураДанныеЭлемента.ДанныеЭлемента);
		
	ИначеЕсли СтруктураДанныеЭлемента.ИмяТаблицы = "РодственникиСуществующие" Тогда
		
		СтруктураВозврата = Новый Структура("Контрагент, Родственник");	
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, СтруктураДанныеЭлемента.ДанныеЭлемента);
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции 

#КонецОбласти
