// Процедура - Изменить видимость закрытого документа
//
// Параметры:
//  ЭтоБлокировка	 - 	 Булево. Истина - если нужно заблокировать документ. Ложь - если разблокировать (для полных прав). 
//
Процедура ИзменитьДоступностьЗакрытогоДокумента(ЭтоБлокировка = Истина)

	Если ЭтоБлокировка = Ложь И НЕ РольДоступна("ПолныеПрава") Тогда
		Возврат;
	КонецЕсли;
	
	// Шапка документа
	Элементы.Контрагент.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.КонтрагентСтраховойПолис.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.Сотрудник.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.Ассистент.ТолькоПросмотр = ЭтоБлокировка;
		
	// Страница Запасы.
	Элементы.ТаблицаТовары.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.ГруппаКоманднаяПанельПодборЗапасов.Доступность = НЕ ЭтоБлокировка;			
	Элементы.ГруппаПодборЗапасыОбщая.Видимость = НЕ ЭтоБлокировка;
	Элементы.ЗапасыСкрытьПодбор.Доступность = НЕ ЭтоБлокировка;
	Элементы.ЗапасыЗагрузитьДанныеИзТСД.Доступность = НЕ ЭтоБлокировка;
	
	// Страница Маркетинговые акции.
	Элементы.ГруппаСкидкиКомманднаяПанель.Доступность = НЕ ЭтоБлокировка;
	Элементы.СкидкиНаценкиСкидки.ТолькоПросмотр = ЭтоБлокировка;
		
	Элементы.ГруппаБонусыКомманднаяПанель.Доступность = НЕ ЭтоБлокировка;
	Элементы.СкидкиНаценкиБонусы.ТолькоПросмотр = ЭтоБлокировка;
		
	// Страница Подарки.	
	Элементы.ГруппаПодаркиКомманднаяПанель.Доступность = НЕ ЭтоБлокировка;
	Элементы.Подарки.ТолькоПросмотр = ЭтоБлокировка;
		
	// Страница Авансы.
	Элементы.ГруппаАвансы.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.ГруппаАвансыКомманднаяПанель.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.УчтенныеАвансы.ТолькоПросмотр = ЭтоБлокировка;
	
	// Страница Лечение.		
	Элементы.УслугиПодборЗубов.Доступность = НЕ ЭтоБлокировка;
	Элементы.УслугиПодборЗубов.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.ГруппаНезаконченныеПланыЛечения.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.ГруппаПодборУслугиОбщая.Видимость = НЕ ЭтоБлокировка;		
	Элементы.ГруппаЛечениеКомманднаяПанельРедактирование.Доступность = НЕ ЭтоБлокировка;
	Элементы.ЛечениеГруппаКнопки.Доступность = НЕ ЭтоБлокировка;
	Элементы.УслугиСкрытьПодбор.Доступность = НЕ ЭтоБлокировка;
	Элементы.ТаблицаУслугиДобавитьРекламацию.Доступность = НЕ ЭтоБлокировка;		
	Элементы.ТаблицаЛечение.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.ТаблицаЛечениеМатериалыПредставление.ТолькоПросмотр = Ложь;
		
	// Дополнительно.
	// Левая колонка.
	Элементы.ГруппаПервый.ТолькоПросмотр = ЭтоБлокировка; 
	
	// Средняя колонка.
	Элементы.ГруппаВремя.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.АвторДокумента.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.Касса.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.Склад.ТолькоПросмотр = ЭтоБлокировка И НЕ ПробитПоФР;
		
	// Правая колонка.
	Элементы.КартаКонтрагента.ТолькоПросмотр = ЭтоБлокировка;
	Элементы.ВидЦен.Доступность = НЕ ЭтоБлокировка;
	
	// Командная панель.
	Элементы.ФормаГруппаПроведение.Доступность = НЕ ЭтоБлокировка;
	Если Элементы.Найти("Удалить") <> Неопределено Тогда
		Элементы.Удалить.Доступность = НЕ ЭтоБлокировка;
	КонецЕсли;
	
КонецПроцедуры

