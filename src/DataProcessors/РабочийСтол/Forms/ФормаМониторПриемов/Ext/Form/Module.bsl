	МассивСтатусовЗадач = Новый Массив();
	МассивСтатусовЗадач.Добавить("Просрочена");
	ПараметрыОтбора.Вставить("МассивСтатусовЗадач", МассивСтатусовЗадач);
	МассивВидовСделок = ПолучитьМассивВсехВидовСделокПоПродажамНаСервере(Истина, ОтборСтруктурнаяЕдиница, ТекущийПользователь);
	МассивВидовСделок.Добавить(ПредопределенноеЗначение("Справочник.ВидыСделок.ПустаяСсылка"));	
	ПараметрыОтбора.Вставить("МассивВидовСделок", МассивВидовСделок);
	МассивСтруктурныхЕдиниц = Новый Массив;
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		МассивСтруктурныхЕдиниц.Добавить(ОтборСтруктурнаяЕдиница);
	КонецЕсли;	
	ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);	
	Если ОтборАдресатСведенийТип = "Мои" Тогда 
		ОтборСотрудники = Новый Массив;
		ОтборСотрудники.Добавить(ТекущийПользователь);
		ПараметрыОтбора.Вставить("МассивИсполнителей"	, ОтборСотрудники);		
	ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
		ОтборСотрудники = ПолучитьМассивОтобранныхСотрудников(Истина);
		ПараметрыОтбора.Вставить("МассивИсполнителей"	, ОтборСотрудники);								
	ИначеЕсли ОтборАдресатСведенийТип = "ИзСписка" Тогда	
		ОтборСотрудники = ПолучитьМассивОтобранныхСотрудников(, Истина);
		ПараметрыОтбора.Вставить("МассивИсполнителей"	, ОтборСотрудники);				
	КонецЕсли;
	ПараметрыОтбора.Вставить("ОчиститьВсеОтборы"	, Ложь);
	
	// Ищем открытую форму
	ПараметрыФормы = НайтиОткрытуюФорму("Задача.Взаимодействие.Форма.ФормаСпискаНовая", Нстр("ru = 'Задачи'; en = 'Tasks'"));
	Если ПараметрыФормы.Открыта Тогда
		ПараметрыОтбора.Вставить("ОчиститьВсеОтборы", Истина);
	    Оповестить("ОБНОВИТЬ_ОТБОРЫ_СПИСКА_ВЗАИМОДЕЙСТВИЙ", Новый Структура("Отбор", ПараметрыОтбора), ЭтаФорма);
		ПараметрыФормы.ОкноПриложения.Активизировать();
		Возврат;
	КонецЕсли;
	
	// Форму не нашли - открываем		
	ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаСпискаНовая", Новый Структура("Отбор", ПараметрыОтбора));	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый перейти сделки этап выполнить команду
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Подключаемый_ПерейтиСделкиЭтапКоличество_ВыполнитьКоманду(Команда) Экспорт

	ПозицияПричины = СтрНайти(Команда.Имя, "_ОтказПричина_");
	Если ПозицияПричины = 0 Тогда
		ИндексПричины 		= Неопределено;
		ИндексСтроки		= Число(Сред(Команда.Имя, СтрДлина("ПерейтиСделкиЭтапКоличество_Индекс_") + 1));
	Иначе 
		ИндексПричины 		= Число(Сред(Команда.Имя, (ПозицияПричины + СтрДлина("_ОтказПричина_")))); 
		ИндексСтроки 		= Число(Сред(Лев(Команда.Имя, СтрДлина(Лев(Команда.Имя, ПозицияПричины - 1))), СтрДлина("ПерейтиСделкиЭтапКоличество_Индекс_") + 1));
	КонецЕсли;	
	ДанныеЭлемента 			= ТаблицаВидовСделок[ИндексСтроки];
	
	Если ДанныеЭлемента = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	// Формируем параметры			
	ПараметрыОтбора = Новый Структура();
	МассивВидовСделок = Новый Массив;
	МассивВидовСделок.Добавить(ДанныеЭлемента.ВидСделки);
	ПараметрыОтбора.Вставить("МассивВидовСделок"	, МассивВидовСделок);
	МассивСтруктурныхЕдиниц = Новый Массив;
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		МассивСтруктурныхЕдиниц.Добавить(ОтборСтруктурнаяЕдиница);
	КонецЕсли;	
	ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);
	МассивСтатусовСделок = Новый Массив;
	Если ДанныеЭлемента.ЭтапСделки = ПредопределенноеЗначение("Справочник.ЭтапыСделок.Успех") ИЛИ ДанныеЭлемента.ЭтапСделки = ПредопределенноеЗначение("Справочник.ЭтапыСделок.Отказ") Тогда 
		МассивСтатусовСделок.Добавить("Да");
	Иначе 	
		МассивСтатусовСделок.Добавить("Нет");
	КонецЕсли;	
	ПараметрыОтбора.Вставить("МассивСтатусовСделок", МассивСтатусовСделок);		
	Если ОтборАдресатСведенийТип = "Мои" Тогда 
		ОтборСотрудники = Новый Массив;
		ОтборСотрудники.Добавить(ТекущийПользователь);
		ОтборСотрудники.Добавить(ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка"));		
		ПараметрыОтбора.Вставить("МассивМенеджеров"	, ОтборСотрудники);		
	ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
		// ОтборСотрудники = ПолучитьМассивОтобранныхСотрудников(Истина);
		// ПараметрыОтбора.Вставить("МассивМенеджеров"	, ОтборСотрудники);								
	ИначеЕсли ОтборАдресатСведенийТип = "ИзСписка" Тогда	
		ОтборСотрудники = ПолучитьМассивОтобранныхСотрудников();
		Если ЗначениеЗаполнено(ОтборСотрудники) Тогда 
			ПараметрыОтбора.Вставить("МассивМенеджеров"	, ОтборСотрудники);				
		КонецЕсли;	
	КонецЕсли;
	МассивЭтапов = Новый Массив;
	МассивЭтапов.Добавить(ДанныеЭлемента.ЭтапСделки);
	ПараметрыОтбора.Вставить("МассивЭтапов"			, МассивЭтапов);
	Если ДанныеЭлемента.ЭтапСделки = ПредопределенноеЗначение("Справочник.ЭтапыСделок.Успех") ИЛИ ДанныеЭлемента.ЭтапСделки = ПредопределенноеЗначение("Справочник.ЭтапыСделок.Отказ") Тогда  
		ПараметрыОтбора.Вставить("ПериодСделки"		, ОтборПериодЗначение);				
	КонецЕсли;
	МассивПричинОтказов = Новый Массив;	
	Если НЕ ИндексПричины = Неопределено И ДанныеЭлемента.ЭтапСделки = ПредопределенноеЗначение("Справочник.ЭтапыСделок.Отказ") И ЗначениеЗаполнено(ДанныеЭлемента.ТаблицаПричинОтказов) Тогда 
		МассивПричинОтказов.Добавить(ДанныеЭлемента.ТаблицаПричинОтказов[ИндексПричины].ПричинаОтказа);
	КонецЕсли;	
	ПараметрыОтбора.Вставить("МассивПричинОтказов", МассивПричинОтказов);
		
	ПараметрыОтбора.Вставить("ОчиститьВсеОтборы"		, Ложь);
	ПараметрыОтбора.Вставить("ОчиститьОтборПоСтатусу"	, Истина);
	
	// Ищем открытую форму
	ПараметрыФормы = НайтиОткрытуюФорму("Справочник.Сделки.Форма.ФормаСпискаНовая", Нстр("ru = 'Сделки'; en = 'Funnels'"));
	Если ПараметрыФормы.Открыта Тогда
		ПараметрыОтбора.Вставить("ОчиститьВсеОтборы", Истина);
	    Оповестить("ОБНОВИТЬ_ОТБОРЫ_СПИСКА_СДЕЛОК", Новый Структура("Отбор", ПараметрыОтбора), ЭтаФорма);
		ПараметрыФормы.ОкноПриложения.Активизировать();
		Возврат;
	КонецЕсли;
	
	// Форму не нашли - открываем		
	ОткрытьФорму("Справочник.Сделки.Форма.ФормаСпискаНовая", Новый Структура("Отбор", ПараметрыОтбора));	
	
КонецПроцедуры

#КонецОбласти

