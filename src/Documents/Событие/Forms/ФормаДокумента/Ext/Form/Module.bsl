	ЦветФонаСерыйВторостепенный = Новый Цвет(242, 242, 242);
	ЦветТекстаЧерный = Новый Цвет(77, 77, 77);
		
 	// Если прием не доступен по правам то скрываем кнопку открытия приема.
	МассивДоступныхСтруктурныхЕдиниц 			= ПолучитьМассивСтруктурныхЕдиницСотрудника();
