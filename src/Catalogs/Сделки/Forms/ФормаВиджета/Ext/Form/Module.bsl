			ПараметрыДекорации = Новый Структура;
			ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_СтрелкаВниз_" + Индекс);
			ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапы);
			ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.СтрелкаВниз);
			//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
			ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
			КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
			КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
			КартинкаВида.Ширина					 				= 2;
			КартинкаВида.Высота					 				= 1;
			КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
			КартинкаВида.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
		КонецЕсли;
	
		// Создание группы этапа.
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаЭтапа_" + Индекс);
		ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаЭтапы);
		ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
		ГруппаЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
		ГруппаЭтапа.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Полуторный;
		ГруппаЭтапа.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
		ГруппаЭтапа.Ширина = 30;
		ГруппаЭтапа.РастягиватьПоГоризонтали = Ложь;
				
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЭтапСделки" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
		ПараметрыДекорации.Вставить("Картинка"					, ?(СтрокаТЗ.Выбран, БиблиотекаКартинок.ЧекБоксПолный, БиблиотекаКартинок.Пустая));
		//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 1;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
		// Создание группы кнопки этапа.
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Этап_ГруппаКнопки" + Индекс);
		ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаЭтапа);
		ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
		ГруппаКнопкиЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
		ГруппаКнопкиЭтапа.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
		ГруппаКнопкиЭтапа.Ширина = 30;
		ГруппаКнопкиЭтапа.РастягиватьПоГоризонтали = Ложь;
		
		// Создаем команду кнопки.
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "Этап_Генерируемый_" + Индекс);
		КомандаКнопки =  УправлениеИнтерфейсамиСервер.СоздатьКомандуЭлемента(ЭтаФорма, ПараметрыКоманды);
		
		// Создаем кнопку.
		ПараметрыКнопки = Новый Структура;
		ПараметрыКнопки.Вставить("Заголовок"   	 	 , СтрокаТЗ.Наименование);
		ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "Этап_Генерируемый_" + Индекс);
		ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
		ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
		ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
		ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаКнопкиЭтапа);		
		
		КнопкаЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементКнопка(ЭтаФорма, ПараметрыКнопки);
		КнопкаЭтапа.РастягиватьПоГоризонтали 	= Истина;	 
		//КнопкаЭтапа.АвтоМаксимальнаяШирина 		= Ложь;	 
		//КнопкаЭтапа.МаксимальнаяШирина 			= 24;	 
		
		Если ЭтоПервичныйПовторныйПациент Тогда
			Если СтрокаТЗ.НомерЭтапа = 1 ИЛИ СтрокаТЗ.НомерЭтапа = 2 Тогда
				КнопкаЭтапа.Доступность 		= НомерЭтапа < 3;
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 3 Тогда 
				КнопкаЭтапа.Доступность 		= Ложь;
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 4 Тогда 	
				КнопкаЭтапа.Доступность 		= Ложь; //НомерЭтапа > 2;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.ЦветЭтапа)
			ИЛИ ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа) = Новый Цвет()
			ИЛИ СтрокаТЗ.НомерЭтапа > НомерЭтапа Тогда 
			Если СтрокаТЗ.Выбран Тогда
				Цвет = Новый Цвет(229, 229, 229);
			Иначе 	
				Цвет = Новый Цвет(243, 243, 243);
			КонецЕсли;
		ИначеЕсли СтрокаТЗ.Выбран Тогда
			Цвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа);
		Иначе		
			Цвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа);
		КонецЕсли;
		
		ГруппаКнопкиЭтапа.ЦветФона   	= Цвет;
		КнопкаЭтапа.ЦветТекста 			= УправлениеИнтерфейсамиСервер.ПолучитьЦветТекстаПоФону(ГруппаКнопкиЭтапа.ЦветФона);
		
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЭтапСделки_пустая" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
		ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.Пустая);
		//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 1;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Процедура - Обновить элементы выбора завершающих этапов генерируемой сделки
//
Процедура ОбновитьЭлементыВыбораЗавершающихЭтаповГенерируемойСделки();
	
	ТаблицаЭтапов = Неопределено;
	МассивСтрок = ТаблицаДоступныхВидовСделок.НайтиСтроки(Новый Структура("ВидСделки", ВыбранныйВидСделки));
	Если МассивСтрок.Количество() > 0 Тогда 
		ТаблицаЭтапов = МассивСтрок[0].ТаблицаЭтапов;
		ИндексВиджета = ТаблицаДоступныхВидовСделок.Индекс(МассивСтрок[0]);
		НаименованиеЭтапаУспех = МассивСтрок[0].НаименованиеЭтапаУспех;
		НаименованиеЭтапаОтказ = МассивСтрок[0].НаименованиеЭтапаОтказ;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТаблицаЭтапов) Тогда 
		Возврат;
	КонецЕсли;
	
	ГруппаРодитель 					= Элементы.ГруппаЗавершающиеЭтапы;
	ДоступностьЗавершающихЭтапов 	= НЕ ЭтоПервичныйПовторныйПациент;
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   		, "ГруппаЗавершающиеЭтапы_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		, ГруппаРодитель);	
	ПараметрыГруппы.Вставить("Группировка"   		, ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ГруппаЭтапы = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
