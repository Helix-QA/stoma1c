// Функция выполняет отмену события
//
Процедура ОтменитьСобытие(СобытиеСсылка, ВосстановитьСобытие = Ложь, Знач Оповещение) Экспорт
	
	Если НЕ Оповещение = Неопределено И ТипЗнч(Оповещение) = Тип("ОписаниеОповещения") Тогда
		
		Если НЕ ВосстановитьСобытие Тогда
			
			Результат = ОбщегоНазначенияСтоматология.ПроверитьВозможностьОтменыСобытия(СобытиеСсылка);
			Если Результат <> Истина Тогда
				ПоказатьПредупреждение(,Результат);
				ВыполнитьОбработкуОповещения(Оповещение, Ложь);
			КонецЕсли;	
			
			ДопПараметры = Новый Структура("СобытиеСсылка, Оповещение", СобытиеСсылка, Оповещение);
			ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьСобытиеЗавершение", ОбщегоНазначенияКлиентСтоматология, ДопПараметры);
			ОткрытьФорму("Справочник.ПричиныОтменыЗаписи.ФормаВыбора", Новый Структура,,,,, ОписаниеОповещения);
			
		Иначе
			
			СтатусСобытиеОтменено = ОбщегоНазначенияСтоматология.ОтменитьВосстановитьСобытие(СобытиеСсылка, Неопределено, ВосстановитьСобытие);
			ВыполнитьОбработкуОповещения(Оповещение, СтатусСобытиеОтменено);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - выполняет отмену события после выбора причины отмены.
//
Процедура ОтменитьСобытиеЗавершение(Результат, ДопПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтатусСобытиеОтменено = ОбщегоНазначенияСтоматология.ОтменитьВосстановитьСобытие(ДопПараметры.СобытиеСсылка, Результат, Ложь);
	ВыполнитьОбработкуОповещения(ДопПараметры.Оповещение, СтатусСобытиеОтменено);
	
КонецПроцедуры


#Область ОбработчикиОтображенияВсплывающихГрупп

// Функция - Проверить видимость всплывающей группы.
// 
// Параметры:
//  ИмяВзаимодействия	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПроверитьВидимостьВсплывающихГрупп(Форма, Знач ИмяЭлемента, Знач ИндексЭлемента = Неопределено) Экспорт
	
	ИндексЭлемента = ?(ЗначениеЗаполнено(ИндексЭлемента), "_" + ИндексЭлемента, ""); 	
	
	Для Каждого ЭлементС Из Форма.ВидимостьВсплывающихГрупп Цикл
		
		Если ЭлементС.Ключ <> ИмяЭлемента + ИндексЭлемента Тогда 
			Форма.ВидимостьВсплывающихГрупп[ЭлементС.Ключ] = Ложь;
		КонецЕсли;	
		
	КонецЦикла;	
	
	Если Форма.ВидимостьВсплывающихГрупп[ИмяЭлемента + ИндексЭлемента] = Истина Тогда
		
		Форма.ВидимостьВсплывающихГрупп[ИмяЭлемента + ИндексЭлемента] = Ложь;
		
		ИмяВсплывающейГруппы = "Группа" + ИмяЭлемента + "Всплывающая" + ИндексЭлемента;
	
		Форма.Элементы[ИмяВсплывающейГруппы].Скрыть();	

		Возврат Ложь;
		
	КонецЕсли;	
	
	Возврат Истина;
	
КонецФункции

// Процедура - Установить видимость всплывающих групп.
// 
// Параметры:
//  ИмяВзаимодействия	 - 	 - 
//  Видимость			 - 	 - 
// 
Процедура УстановитьВидимостьВсплывающихГрупп(Форма, Знач ИмяЭлемента, Знач ИндексЭлемента = Неопределено) Экспорт
	
	ИндексЭлемента = ?(ЗначениеЗаполнено(ИндексЭлемента), "_" + ИндексЭлемента, ""); 
	
	Форма.ВидимостьВсплывающихГрупп[ИмяЭлемента + ИндексЭлемента] = Истина; 
	
	ИмяВсплывающейГруппы = "Группа" + ИмяЭлемента + "Всплывающая" + ИндексЭлемента;
	
	Форма.Элементы[ИмяВсплывающейГруппы].Показать();	
	
КонецПроцедуры

