// Процедура - Актуализировать пропущенные звонки
// 
// Параметры:
//  Запись	 - 	 - 
// 
Процедура АктуализироватьПропущенныеЗвонки(Запись)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ИсторияВызовов.ОборудованиеТелефонии КАК ОборудованиеТелефонии,
	|	ИсторияВызовов.IDЗвонка КАК IDЗвонка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.IDЗвонка <> &IDЗвонка
	|	И ИсторияВызовов.НомерТелефона = &НомерТелефона
	|	И ИсторияВызовов.НеОбработан = ИСТИНА
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ИсторияВызовов.ОборудованиеТелефонии,
	|	ИсторияВызовов.IDЗвонка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.IDЗвонка <> &IDЗвонка
	|	И ИсторияВызовов.ПользовательSip = &НомерТелефона
	|	И ИсторияВызовов.НеОбработан = ИСТИНА");
	
	Запрос.УстановитьПараметр("IDЗвонка"		, Запись.IDЗвонка);
	Запрос.УстановитьПараметр("НомерТелефона"	, Запись.НомерТелефона);
	
	ВыборкаНеобработанных = Запрос.Выполнить().Выбрать();
	
	Если НЕ ВыборкаНеобработанных.Количество() = 0 Тогда 
		НаборЗаписейИсторииВызовов = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
	КонецЕсли;
	
	Пока ВыборкаНеобработанных.Следующий() Цикл 
		НаборЗаписейИсторииВызовов.Отбор.ОборудованиеТелефонии.Значение 		= ВыборкаНеобработанных.ОборудованиеТелефонии;
		НаборЗаписейИсторииВызовов.Отбор.ОборудованиеТелефонии.Использование 	= Истина;
		НаборЗаписейИсторииВызовов.Отбор.IDЗвонка.Значение 						= ВыборкаНеобработанных.IDЗвонка;
		НаборЗаписейИсторииВызовов.Отбор.IDЗвонка.Использование 				= Истина;
		
		НаборЗаписейИсторииВызовов.Прочитать();
		
		Если НаборЗаписейИсторииВызовов.Количество() > 0 Тогда
			НаборЗаписейИсторииВызовов[0].НеОбработан 							= Ложь;
			НаборЗаписейИсторииВызовов[0].ИдентификаторОбрабатывающего 			= Запись.IDЗвонка;
		КонецЕсли;
		НаборЗаписейИсторииВызовов.Записать();
	КонецЦикла;	
	
КонецПроцедуры

// Функция - Получить структуру XDTO телефона
// 
// Параметры:
//  Телефон	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСтруктуру_XDTO(Представление, ТипКИ)
	
	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	Объект_XDTO = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Представление, ТипКИ);
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
		Если НЕ ЗначениеЗаполнено(Объект_XDTO.Состав.Номер) Тогда 
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат Объект_XDTO;
	
КонецФункции

