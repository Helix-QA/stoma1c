// Процедура - Сформировать текст периода
//
Процедура СформироватьТекстПериода()
	
	КомандаВыбораПроизвольногоПериода = ЭтаФорма.Команды.Найти("УстановитьПериодПроизвольный");
	
	Если ПериодОтбора.ДатаНачала = Дата(1,1,1) И ПериодОтбора.ДатаОкончания = Дата(1,1,1) Тогда 
		
		Элементы.УстановитьПериодПроизвольный.Заголовок = Нстр("ru = '< не указан >'; en = '< not indicated >'");
		Если НЕ КомандаВыбораПроизвольногоПериода = Неопределено Тогда 
			КомандаВыбораПроизвольногоПериода.Подсказка = Нстр("ru = 'Щелкните для выбора произвольного периода'; en = 'Click to select any period'");
		КонецЕсли;
		
	Иначе
		
		Если ВыбранныйПериод = 0 Тогда 
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ПериодОтбора.ДатаНачала, "ДФ='дд ММММ гггг'");
		ИначеЕсли ВыбранныйПериод = 1 Тогда 
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ПериодОтбора.ДатаНачала, "ДФ=dd.MM.yy") + " - " + Формат(ПериодОтбора.ДатаОкончания, "ДФ=dd.MM.yy");
		ИначеЕсли ВыбранныйПериод = 2 Тогда	
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ПериодОтбора.ДатаНачала, "ДФ=dd.MM.yy") + " - " + Формат(ПериодОтбора.ДатаОкончания, "ДФ=dd.MM.yy");
		ИначеЕсли ВыбранныйПериод = 3 Тогда	
			Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ПериодОтбора.ДатаНачала, "ДФ='ММММ гггг'");
		ИначеЕсли ВыбранныйПериод = 4 Тогда
			Если ЗначениеЗаполнено(ПериодОтбора.ДатаНачала) И ЗначениеЗаполнено(ПериодОтбора.ДатаОкончания) Тогда 
				Элементы.УстановитьПериодПроизвольный.Заголовок = Формат(ПериодОтбора.ДатаНачала, "ДФ=dd.MM.yy") + " - " + Формат(ПериодОтбора.ДатаОкончания, "ДФ=dd.MM.yy");			
			Иначе 
				Если НЕ ЗначениеЗаполнено(ПериодОтбора.ДатаНачала) Тогда 
					Элементы.УстановитьПериодПроизвольный.Заголовок = Нстр("ru = 'по '; en = 'to '") + Формат(ПериодОтбора.ДатаОкончания, "ДФ=dd.MM.yy");			
				ИначеЕсли НЕ ЗначениеЗаполнено(ПериодОтбора.ДатаОкончания) Тогда 	
					Элементы.УстановитьПериодПроизвольный.Заголовок = Нстр("ru = 'с '; en = 'from '") + Формат(ПериодОтбора.ДатаНачала, "ДФ=dd.MM.yy");			
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли; 	
		
		Если НЕ КомандаВыбораПроизвольногоПериода = Неопределено Тогда 
			КомандаВыбораПроизвольногоПериода.Подсказка = Элементы.УстановитьПериодПроизвольный.Заголовок;
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

