	|ГДЕ
	|	СтатусыОплатыЗаказов.СсылкаОплаты = &СсылкаОплаты
	|	И СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)");
	
	Запрос.УстановитьПараметр("СсылкаОплаты", СсылкаОплаты);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Сумма, 0);
	
КонецФункции

