&НаСервере
// Процедура - Отобразить Метки Контрагента 
//
Процедура ОтобразитьМеткиКонтрагента(КлиентСсылка, ГруппаМетокКонтрагента, кИндекс)
	
	// Получаем метки Объект.Ссылка,ТекущаяДата(),ЭтаФорма,Элементы.ГруппаКлиентсикеМетки,,Истина,,,СоздатьСсылкуРедактирования)
	Метки = РегистрыСведений.МеткиКлиентов.ПолучитьМеткиКлиента(КлиентСсылка,ТекущаяДатаСеанса()).ВыгрузитьКолонку("Метка");

	мИндекс = 0;
	
	// Удаляем элементы группы
	Пока мИндекс < ГруппаМетокКонтрагента.ПодчиненныеЭлементы.Количество() Цикл
		
		ЭтаФорма.Элементы.Удалить(ГруппаМетокКонтрагента.ПодчиненныеЭлементы[мИндекс]);
		
	КонецЦикла;	
	
	ПолучитьНовуюСтроку = 0;
	// Размещаем элементы меток
	Для мИндекс = 0 По Метки.Количество()-1 Цикл
		
		Если ПолучитьНовуюСтроку = 0 Тогда
			
			Группа_Заглушка_НоваяСтрока 					= ЭтаФорма.Элементы.Добавить("Группа_Заглушка_Строка_" + кИндекс + "_" + мИндекс, Тип("ГруппаФормы"), ГруппаМетокКонтрагента);
			Группа_Заглушка_НоваяСтрока.Вид 				= ВидГруппыФормы.ОбычнаяГруппа;
			Группа_Заглушка_НоваяСтрока.Отображение 		= ОтображениеОбычнойГруппы.Нет;
			Группа_Заглушка_НоваяСтрока.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
			Группа_Заглушка_НоваяСтрока.ОтображатьЗаголовок = Ложь;
			
		КонецЕсли;
		
		Группа_Заглушка_Выравнивания					 = ЭтаФорма.Элементы.Добавить("Группа_Заглушка_Выравнивания_" +  кИндекс + "_" + мИндекс, Тип("ГруппаФормы"), Группа_Заглушка_НоваяСтрока);
		Группа_Заглушка_Выравнивания.Вид				 = ВидГруппыФормы.ОбычнаяГруппа;
		Группа_Заглушка_Выравнивания.Отображение		 = ОтображениеОбычнойГруппы.Нет;
		Группа_Заглушка_Выравнивания.Группировка 		 = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		Группа_Заглушка_Выравнивания.ОтображатьЗаголовок = Ложь;
		
		Группа_Заглушка_Метка						 = ЭтаФорма.Элементы.Добавить("Группа_Заглушка_" +  кИндекс + "_" + мИндекс, Тип("ГруппаФормы"), Группа_Заглушка_Выравнивания);
		Группа_Заглушка_Метка.Вид					 = ВидГруппыФормы.ОбычнаяГруппа;
		Группа_Заглушка_Метка.Отображение			 = ОтображениеОбычнойГруппы.Нет;
		Группа_Заглушка_Метка.Группировка			 = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		Группа_Заглушка_Метка.ОтображатьЗаголовок	 = Ложь;
		Группа_Заглушка_Метка.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Одинарный;
		Группа_Заглушка_Метка.ЦветФона 				 = ?(ЗначениеЗаполнено(Метки[мИндекс].ЦветМетки),ЗначениеИзСтрокиВнутр(Метки[мИндекс].ЦветМетки),ЦветаСтиля.ЦветФонаФормы);
		
		НоваяМетка 			  = ЭтаФорма.Элементы.Добавить("Метка_" + кИндекс + "_" + мИндекс, Тип("ДекорацияФормы"), Группа_Заглушка_Метка);
		НоваяМетка.Вид		  = ВидДекорацииФормы.Надпись;
		НоваяМетка.Заголовок  = СокрЛП(Строка(Метки[мИндекс].Ссылка));
		НоваяМетка.ЦветРамки  = ?(ЗначениеЗаполнено(Метки[мИндекс].ЦветМетки),ЗначениеИзСтрокиВнутр(Метки[мИндекс].ЦветМетки),ЦветаСтиля.ЦветФонаФормы);
		НоваяМетка.ЦветТекста = ?(ЗначениеИзСтрокиВнутр(Метки[мИндекс].ЦветМетки)<>Новый Цвет(), Новый Цвет(255, 255, 255), Новый Цвет());
		
		ПолучитьНовуюСтроку = ПолучитьНовуюСтроку + 1;
		
		Если ПолучитьНовуюСтроку = 6 Тогда
			ПолучитьНовуюСтроку = 0;
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры
 
