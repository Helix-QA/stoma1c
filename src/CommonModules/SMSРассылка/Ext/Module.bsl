// Функция - Выполнить GETЗапрос
//
// Параметры:
//  Метод		 - 	 - 
//  ДопЗаголовки - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВыполнитьGETЗапрос(Метод, ДопЗаголовки = Неопределено, Параметры = Неопределено)
	
	Если Параметры = Неопределено Тогда
		Параметры = ПараметрыПодклчюенияК_API_CRM();
