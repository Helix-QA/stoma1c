		КонецЕсли;
		
		ДобавитьРеквизитВСтруктуру(ПараметрыВнешнейСистемы, "ВидыКартПоУмолчанию", ЭтотОбъект.ВидыКартПоУмолчанию);
		
	КонецЕсли;
	
