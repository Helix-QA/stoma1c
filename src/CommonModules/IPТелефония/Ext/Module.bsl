// Функция - OKTELL событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПростыеЗвонки_СобытиеЗвонок(ПОIPТелефонии, ИмяФункции, Параметры, ОписаниеОшибки = "") Экспорт
	
	// ЗалогироватьСобытиеПростыхЗвонковВТрансляторе(ИмяФункции, Параметры); // Временно для дебага.
	Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЭтоЗавершениеЗвонка = (ИмяФункции = "IncomingCallCompleted" ИЛИ ИмяФункции = "OutgoingCallCompleted");
	
	Если ЭтоЗавершениеЗвонка И ЗвонокУжеЗаписанВБазуИНеТребуетсяЕгоПерезапись(Параметры.callID) Тогда
		Возврат Истина;		
	КонецЕсли;
	
	Результат = Ложь;
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= Параметры.callID;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
	УнифицированнаяСтруктураСобытия.Вставить("ЭтоЗавершениеЗвонка", ЭтоЗавершениеЗвонка);
	
	Если ИмяФункции = "IncomingCall" Тогда
		
#Область _____________________ВХОДЯЩИЙ_ДОЗВОН______________________
		
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= СокрЛП(УправлениеКонтактнойИнформациейКлиентСерверСтоматология.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(Параметры.ExternalNumber))));
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= СокрЛП(УправлениеКонтактнойИнформациейКлиентСерверСтоматология.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(Параметры.InternalNumber))));
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 			= Перечисления.ВариантыНаправленияВызова.Входящий;
