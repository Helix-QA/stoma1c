
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Сотрудник", Сотрудник); 	
	
	ЭтотОбъект.ПодборОтобразитьДеревом = Истина;
	ЭтотОбъект.ПодборРазвернутьДерево  = Истина;
	ЭтотОбъект.ДоступноИзменениеУслугСотрудника = РольДоступна("ДобавлениеИзменениеНоменклатуры") ИЛИ РольДоступна("ДобавлениеИзменениеСотрудников") 
														ИЛИ РольДоступна("ПолныеПрава") ИЛИ РольДоступна("АдминистраторСистемы");
	
	СоздатьДеревоУслуг();
	УстановитьУсловноеОформление();  

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьФильтр();
	ПослеЗаполненияСпискаподбораноменклатур(); 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы   

&НаКлиенте
// Процедура, обработчик команды "СкопироватьНастройки".
//
Процедура СкопироватьНастройки(Команда)
	
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора",,,,,,Новый ОписаниеОповещения("СкопироватьНастройкиЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения команды.
//
Процедура СкопироватьНастройкиЗавершение(Источник, Параметры) Экспорт
	
	Если Не Источник = Неопределено и Не Источник = Сотрудник Тогда
		СкопироватьНастройкиСотрудника(Источник);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ПодборПереключательФильтраПриИзменении(Элемент)
	
	ПерезаполнитьДеревоПодбораНоменклатур();
	
КонецПроцедуры
	
&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ПодборФильтрПриИзменении(Элемент)
	
	ПерезаполнитьДеревоПодбораНоменклатур();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ПодборФильтрАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ЭтотОбъект.ПодборФильтр = Текст;
	
	#Если не ВебКлиент Тогда
		Системнаяинформация = Новый Системнаяинформация;
		Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 
			WSHShell = Новый COMОбъект("WScript.Shell");
			WSHShell.SendKeys("{Right}");
		КонецЕсли;
	#Конецесли

ПерезаполнитьДеревоПодбораНоменклатур();

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ФильтрПриИзменении(Элемент)

УстановитьФильтр();
Если Фильтр = 1 Тогда
	
	ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборНоменклатур, Истина);
	Если ИдТекЭлемент <> Неопределено Тогда
		Элементы._ПодборНоменклатур.ТекущаяСтрока = ИдТекЭлемент;
	КонецЕсли;
	
КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура Подключаемый_ПодборНоменклатураПриИзменении(Элемент)
	
	ИмяКолонки 	  = Элемент.Имя;
	ТекущиеДанные = Элементы._ПодборНоменклатур.ТекущиеДанные;
	
	Если ТекущиеДанные.ЭтоГруппа Тогда  
		
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли;
		
		УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки);
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, Истина);
		
	Иначе
		
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли;
		
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки);
		
	КонецЕсли;
	
	Если Фильтр = 1 Тогда
		
		ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборНоменклатур, Истина);		
		Если ИдТекЭлемент <> Неопределено Тогда
			Элементы._ПодборНоменклатур.ТекущаяСтрока = ИдТекЭлемент;
		КонецЕсли;
		
	КонецЕсли;
	
	ТаблицаНоменклатуры.Очистить();
	ДанныеДерева = ЭтаФорма._ПодборНоменклатур.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ из ДанныеДерева Цикл
		
		Если СтрокаТЧ.ЭтоГруппа Тогда
			ЗаполнитьТаблицуНоменклатуры(СтрокаТЧ);
		Иначе
			ЗаполнитьСтрокуТаблицыНоменклатуры(СтрокаТЧ);
		КонецЕсли;
		
	КонецЦикла;
	
	СохранитьЗначения(ТаблицаНоменклатуры, Сотрудник);
	
КонецПроцедуры  

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура Подключаемый_НормаВремениПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы._ПодборНоменклатур.ТекущиеДанные;
	ТекущиеДанные.НормаВремениСотрудника = НЕ ТекущиеДанные.НормаВремени = ТекущиеДанные.БазоваяНормаВремени;
	
	ТаблицаНоменклатуры.Очистить();
	ДанныеДерева = ЭтаФорма._ПодборНоменклатур.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ из ДанныеДерева Цикл
		Если СтрокаТЧ.ЭтоГруппа Тогда
			ЗаполнитьТаблицуНоменклатуры(СтрокаТЧ);
		Иначе
			ЗаполнитьСтрокуТаблицыНоменклатуры(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
	СохранитьЗначения(ТаблицаНоменклатуры, Сотрудник);
	
КонецПроцедуры

&НаКлиенте
