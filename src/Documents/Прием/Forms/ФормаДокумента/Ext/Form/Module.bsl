// При изменении значения количества в строке.
//
Процедура ТаблицаУслугиКоличествоПриИзменении(Элемент)	
	
	СтрокаТабличнойЧасти = Элементы.ТаблицаЛечение.ТекущиеДанные; 
	
	ИспользуетсяПолисМедСтрахования = ЗначениеЗаполнено(Объект.ПолисМедСтрахования) И ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса);   
	Если ИспользуетсяПолисМедСтрахования = Истина Тогда 
	
		МассивСтруктурСКоличествомПоПолису = ПолучитьКоличествоПоПолису(Объект.ПолисМедСтрахования, Объект.Ссылка);
	
		ИнфаПоНоменклатуре 			= ПолучитьИнформациюНоменклатурыПоДоговору(ЭтотОбъект._ПодборДоговорПолиса, СтрокаТабличнойЧасти.Номенклатура);
		КоличествоНоменклатурыВТЧ 	= ВернутьКоличествоНоменклатурыВТЧЛечение(СтрокаТабличнойЧасти.Номенклатура);
		Если ИнфаПоНоменклатуре <> Неопределено Тогда
			
			КоличествоВсего = 0;
			Для каждого СтрокаМассива Из МассивСтруктурСКоличествомПоПолису Цикл
				Если СтрокаМассива.Номенклатура = СтрокаТабличнойЧасти.Номенклатура Тогда
					
					КоличествоВсего = СтрокаМассива.Количество;
					
				КонецЕсли;
			КонецЦикла;
							
			ИскатьПоСогласованию = Ложь;
			Если ИнфаПоНоменклатуре.Количество > 0
				И КоличествоВсего + КоличествоНоменклатурыВТЧ > ИнфаПоНоменклатуре.Количество Тогда
				
				СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.Количество; // Возвращаем обратно.
				ПоказатьПредупреждение(,"Ограничение по количеству услуг. Всего доступно: " + ИнфаПоНоменклатуре.Количество);
				Возврат;
				
			КонецЕсли;
			
			Если ИнфаПоНоменклатуре.КоличествоПриПревышении > 0
				И КоличествоВсего + КоличествоНоменклатурыВТЧ > ИнфаПоНоменклатуре.КоличествоПриПревышении Тогда
				ИскатьПоСогласованию = Истина;
			КонецЕсли;
			
			ТаблицаУслугиКоличествоПриИзмененииСервер(СтрокаТабличнойЧасти.ПолучитьИдентификатор(), ИскатьПоСогласованию, ИнфаПоНоменклатуре.Согласование);
			
		КонецЕсли;
	Иначе
		ТаблицаУслугиКоличествоПриИзмененииСервер(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Корректировка количества материалов(если было изменено количество услуг).
//
Процедура ТаблицаУслугиКоличествоПриИзмененииСервер(ИдентификаторСтроки, ИскатьПоСогласованию = Ложь, ТребуетсяСогласование = Неопределено)
	
	СтрокаТабличнойЧасти = Объект.Лечение.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если ИскатьПоСогласованию = Истина Тогда
		
		МассивСтрок = Объект.Лечение.НайтиСтроки(Новый Структура("КлючСтроки, СтатусСогласования", СтрокаТабличнойЧасти.КлючСтроки, Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования));
		Если МассивСтрок.Количество() > 0 Тогда
			СтрокаТабличнойЧасти = МассивСтрок[0];
		Иначе
			
			ВведенноеКоличество = СтрокаТабличнойЧасти.КоличествоУпаковок;
			СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.Количество;
			
			НоваяСтрока = Объект.Лечение.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТабличнойЧасти,,"Материалы");
			НоваяСтрока.КлючСтроки				= Новый УникальныйИдентификатор();
			НоваяСтрока.КоличествоУпаковок 		= ВведенноеКоличество - НоваяСтрока.КоличествоУпаковок;
			НоваяСтрока.ТребуетсяСогласование 	= ТребуетсяСогласование;
			НоваяСтрока.СтатусСогласования 		= Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования;
			СтрокаТабличнойЧасти 				= НоваяСтрока;
			
		КонецЕсли;

	КонецЕсли;                                    

	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
	// Пересчитать нормы списания
	НайденныеМатериалы = Объект.Материалы.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТабличнойЧасти.КлючСтроки));
	Для Каждого СтрокаМ ИЗ НайденныеМатериалы Цикл
		СтрокиНСМ = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(СтрокаТабличнойЧасти.Номенклатура,
																							 Объект.СтруктурнаяЕдиница,
																							 ?(ЗначениеЗаполнено(СтрокаМ.Упаковка), СтрокаМ.Упаковка, Неопределено),
																							 СтрокаМ.Материал);
																							 
        Если СтрокиНСМ.Количество() > 0 Тогда
			
			СтрокаМ.КоличествоУпаковок  = ?(СтрокиНСМ[0].НеЗависитОтКоличестваУслуг, СтрокиНСМ[0].Количество, СтрокиНСМ[0].Количество * ?(СтрокаТабличнойЧасти.КоличествоУпаковок = 0, 1, СтрокаТабличнойЧасти.КоличествоУпаковок));
			СтрокаМ.Количество          = СтрокаМ.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаМ.Упаковка.Коэффициент), СтрокаМ.Упаковка.Коэффициент, 1);
		КонецЕсли; 
		
	КонецЦикла;                      
	
	СтрокаТабличнойЧасти.Цена = РассчитатьЦенуПоМатериалам(СтрокаТабличнойЧасти.КлючСтроки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора" ручной скидки
//
Процедура ТаблицаУслугиПроцентСкидкиНаценкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
