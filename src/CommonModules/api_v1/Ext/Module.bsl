// Функция - Получить таблицу записи
//
// Параметры:
//  record_array	 - 	 - 
//  СтруктураОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуЗаписи(record_array, СтруктураОшибки)
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ТаблицаЗначений.Колонки.Добавить("ДатаЗаписи");
	ТаблицаЗначений.Колонки.Добавить("Услуга");
	ТаблицаЗначений.Колонки.Добавить("Сотрудник");
	ТаблицаЗначений.Колонки.Добавить("ПричинаЗаписи", Новый ОписаниеТипов("СправочникСсылка.ПричиныЗаписи"));
	ТаблицаЗначений.Колонки.Добавить("Длительность"	, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(3, 0, ДопустимыйЗнак.Неотрицательный)));
	
	Если НЕ ЗначениеЗаполнено(record_array) Тогда
		СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(1071);
		Возврат Неопределено;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из record_array Цикл
		
		datetime   		= ПолучитьЗначениеИзСтруктуры(СтрокаТЧ, "datetime");
		service_id 		= ПолучитьЗначениеИзСтруктуры(СтрокаТЧ, "service_id");
		staff_id   		= ПолучитьЗначениеИзСтруктуры(СтрокаТЧ, "staff_id");
		reason_entry 	= ПолучитьЗначениеИзСтруктуры(СтрокаТЧ, "reason_entry");
		duration 		= ПолучитьЗначениеИзСтруктуры(СтрокаТЧ, "duration", 0);
		
		НоваяСтрока = ТаблицаЗначений.Добавить();
		НоваяСтрока.ДатаЗаписи 		= ПолучитьИПроверитьДату(datetime, СтруктураОшибки, Истина);
		НоваяСтрока.Услуга	   		= ПолучитьСсылкуПоИдентификатору(service_id		, СтруктураОшибки,, "Номенклатура"	, 1051, Истина);
		
		Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
			ОшибкаДанные = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураОшибки, "Errors", Неопределено);
			Если ЗначениеЗаполнено(ОшибкаДанные) Тогда 
				КодОшибки = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОшибкаДанные, "code", 0);
				Если КодОшибки = 1051 Тогда 
					Если ЗначениеЗаполнено(duration) Тогда
						СтруктураОшибки = Неопределено;
					КонецЕсли;	
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
		
		НоваяСтрока.Сотрудник  		= ПолучитьСсылкуПоИдентификатору(staff_id  		, СтруктураОшибки,, "Сотрудники"  	, 1050);
		НоваяСтрока.ПричинаЗаписи	= ПолучитьСсылкуПоИдентификатору(reason_entry	, СтруктураОшибки,, "ПричиныЗаписи"	, 1130);
		НоваяСтрока.Длительность	= duration;
		
		Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаЗначений.Сортировать("ДатаЗаписи Возр");
	Возврат ТаблицаЗначений;
	
КонецФункции

// Функция, проверяет таблицу значений записи.
// 
Функция ПроверитьТаблицуЗаписи(ТаблицаЗначенийЗаписи, СтруктурнаяЕдиница)
	
	МассивСотрудников = Новый Массив;
	НачалоПериода 	  = ТаблицаЗначенийЗаписи[0].ДатаЗаписи;
	КонецПериода  	  = КонецДня(ТаблицаЗначенийЗаписи[0].ДатаЗаписи);
	
	ТаблицаЗначенийЗаписи.Колонки.Добавить("НормаВремени", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Неотрицательный)));
	
	Для Каждого СтрокаТаблицы Из ТаблицаЗначенийЗаписи Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.Услуга) Тогда 
			Если ЗначениеЗаполнено(СтрокаТаблицы.Сотрудник) Тогда
				СтрокаТаблицы.НормаВремени 	= ПолучитьНормуВремениНоменклатуры(СтрокаТаблицы.Услуга, СтрокаТаблицы.Сотрудник, СтруктурнаяЕдиница);
			Иначе
				СтрокаТаблицы.НормаВремени 	= ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТаблицы.Услуга, "НормаВремени") * 60;
			КонецЕсли;
		ИначеЕсли ЗначениеЗаполнено(СтрокаТаблицы.ПричинаЗаписи) Тогда
			СтрокаТаблицы.НормаВремени 		= ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТаблицы.ПричинаЗаписи, "НормаВремени") * 60;
		КонецЕсли;
	КонецЦикла;

	Для Индекс = 0 По ТаблицаЗначенийЗаписи.Количество() - 1 Цикл
		
		СтрокаТаблицы = ТаблицаЗначенийЗаписи[Индекс];
		
		Для Индекс2 = Индекс + 1 По ТаблицаЗначенийЗаписи.Количество() - 1 Цикл
			
			Если ВремяУслугСовпадает(СтрокаТаблицы, ТаблицаЗначенийЗаписи[Индекс2]) Тогда
				Возврат ПолучитьСтруктуруВозвратаОшибки(1103);
			КонецЕсли;
			
		КонецЦикла;
		
		Если МассивСотрудников.Найти(СтрокаТаблицы.Сотрудник) = Неопределено Тогда
			МассивСотрудников.Добавить(СтрокаТаблицы.Сотрудник);
		КонецЕсли;
		НачалоПериода = ?(СтрокаТаблицы.ДатаЗаписи < НачалоПериода, СтрокаТаблицы.ДатаЗаписи, НачалоПериода);
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Сотрудник) Тогда
			
			ИсключаемыеСотрудники = Новый Массив;
			
			Для Каждого СтрокаТЧ Из ТаблицаЗначенийЗаписи Цикл
				Если СтрокаТЧ <> СтрокаТаблицы И ВремяУслугСовпадает(СтрокаТаблицы, СтрокаТЧ) Тогда
					ИсключаемыеСотрудники.Добавить(СтрокаТЧ.Сотрудник);
				КонецЕсли;
			КонецЦикла;
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.Услуга) Тогда 
				ТаблицаСотрудников = РегистрыСведений.УслугиСотрудника.ПолучитьСотрудниковОказывающихУслугу(СтруктурнаяЕдиница
																										, СтрокаТаблицы.Услуга
																										, ИсключаемыеСотрудники);
			Иначе 
				ТаблицаСотрудников = ПолучитьСотрудниковСНормойВремени(СтруктурнаяЕдиница
																		, Неопределено
																		, СтрокаТаблицы.ДатаЗаписи);
			КонецЕсли;	
			
			Если ТаблицаСотрудников.Количество() = 0 Тогда
				Возврат ПолучитьСтруктуруВозвратаОшибки(1106, ?(ЗначениеЗаполнено(СтрокаТаблицы.Услуга), СокрЛП(СтрокаТаблицы.Услуга), ""));
			КонецЕсли;
			
			ТаблицаИнтерваловСотрудников = ПолучитьСвободныеИнтервалы(
				СтруктурнаяЕдиница, 
				ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник"),, 
				СтрокаТаблицы.ДатаЗаписи);
			
			Для Каждого СтрокаИнтервала Из ТаблицаИнтерваловСотрудников Цикл
				
				НормаВремениСотрудника = ТаблицаСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаИнтервала.Сотрудник))[0].НормаВремени;
				
				Если СтрокаИнтервала.Длительность >= НормаВремениСотрудника Тогда
					СтрокаТаблицы.Сотрудник = СтрокаИнтервала.Сотрудник;
				КонецЕсли;
				
			КонецЦикла;
			
			Если Не ЗначениеЗаполнено(СтрокаТаблицы.Сотрудник) Тогда
				Возврат ПолучитьСтруктуруВозвратаОшибки(1106, ?(ЗначениеЗаполнено(СтрокаТаблицы.Услуга), СокрЛП(СтрокаТаблицы.Услуга), ""));
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.Услуга) Тогда 
				СтрокаТаблицы.НормаВремени = ПолучитьНормуВремениНоменклатуры(СтрокаТаблицы.Услуга, СтрокаТаблицы.Сотрудник, СтруктурнаяЕдиница);
			КонецЕсли;	
			
		ИначеЕсли ЗначениеЗаполнено(СтрокаТаблицы.Услуга) И НЕ СотрудникОказываетУслугу(СтруктурнаяЕдиница, СтрокаТаблицы.Сотрудник, СтрокаТаблицы.Услуга) Тогда
			Возврат ПолучитьСтруктуруВозвратаОшибки(1100);
		КонецЕсли;
		
		Если МассивСотрудников.Найти(СтрокаТаблицы.Сотрудник) = Неопределено Тогда
			МассивСотрудников.Добавить(СтрокаТаблицы.Сотрудник);
		КонецЕсли;
		
		НачалоПериода = ?(СтрокаТаблицы.ДатаЗаписи < НачалоПериода, СтрокаТаблицы.ДатаЗаписи, НачалоПериода);
		
	КонецЦикла;
	
	ТаблицаИнтервалов = ПолучитьСвободныеИнтервалы(СтруктурнаяЕдиница, МассивСотрудников,, НачалоПериода, КонецПериода);
		
	Для Каждого СтрокаТаблицы Из ТаблицаЗначенийЗаписи Цикл
		
		ДатаЗаписи    		= СтрокаТаблицы.ДатаЗаписи;
		Если ЗначениеЗаполнено(СтрокаТаблицы.Длительность) Тогда 
			ДатаОкончания 	= ДатаЗаписи + (СтрокаТаблицы.Длительность*60);	
		Иначе 	
			ДатаОкончания 	= ДатаЗаписи + СтрокаТаблицы.НормаВремени;
		КонецЕсли;	
		Сотрудник     		= СтрокаТаблицы.Сотрудник;
		
		ВозможностьЗаписи   = Ложь;
		ИнтервалыСотрудника = ТаблицаИнтервалов.НайтиСтроки(Новый Структура("Сотрудник", Сотрудник));
		
		Для Каждого СтрокаТЧ Из ИнтервалыСотрудника Цикл
			
			Если СтрокаТЧ.ДатаВремяНачала <= ДатаЗаписи
				И СтрокаТЧ.ДатаВремяНачала + (СтрокаТЧ.Длительность * 60) >= ДатаОкончания Тогда
				
				ВозможностьЗаписи = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ВозможностьЗаписи Тогда
			ПриемыСотрудников = ПолучитьПриемыСотрудников(Сотрудник, СтруктурнаяЕдиница,, ДатаЗаписи, ДатаОкончания);
			Если ПриемыСотрудников.Количество() > 0 Тогда
				Возврат ПолучитьСтруктуруВозвратаОшибки(1131);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ВозможностьЗаписи Тогда
			Возврат ПолучитьСтруктуруВозвратаОшибки(1101);
		КонецЕсли;
				
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

// Функция, возвращает норму времени номенклатуры.
//
Функция ПолучитьНормуВремениНоменклатуры(Услуга, Сотрудник, СтруктурнаяЕдиница)
	
	Возврат РегистрыСведений.УслугиСотрудника.ПолучитьНормуВремениНоменклатуры(Услуга, Сотрудник, СтруктурнаяЕдиница) * 60;
	
КонецФункции

// Функция, формирует предварительную запись.
// 
Функция СформироватьСобытие(
		Клиент,
		ТаблицаЗначенийЗаписи,
		СтруктурнаяЕдиница,
		ВнешняяСистема,
		РекламныйИсточник,
		КомментарийЗаписи,
		Сделка,
		ЗаКакоеВремяНапоминатьОЗаписи)
		
	// Создание предварительной записи
	ОбъектСобытие = Документы.Событие.СоздатьДокумент();
	
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ОбъектСобытие,, 
		Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница));
	ОбъектСобытие.ДатаСоздания 				= ТекущаяДатаСеанса();
	ОбъектСобытие.КартаКлиента 				= Справочники.Карты.ПолучитьКартуКлиента(Клиент);
	ОбъектСобытие.Контрагент   				= Клиент;
	ОбъектСобытие.Статус	   				= Перечисления.СтатусыСобытия.НеПодтверждена;
	ОбъектСобытие.ТипСобытия   				= Перечисления.ТипыСобытий.ПредварительнаяЗапись;
	ОбъектСобытие.Комментарий  				= КомментарийЗаписи;
	ОбъектСобытие.Сделка       				= Сделка;
	ОбъектСобытие.ВремяНапоминанияДоЗаписи 	= ?(ЗначениеЗаполнено(ЗаКакоеВремяНапоминатьОЗаписи), ЗаКакоеВремяНапоминатьОЗаписи, 0);
	ОбъектСобытие.ИсточникЗаписи 			= ПолучитьИсточникЗаписи(ВнешняяСистема);
	Дата = ТекущаяДатаСеанса(); 
		
	Счетчик = 0;
	Для Каждого СтрокаТаблицы Из ТаблицаЗначенийЗаписи Цикл
		
		ДатаЗаписи    	 = СтрокаТаблицы.ДатаЗаписи; 
		Если Счетчик = 0 Тогда
			Дата = ДатаЗаписи; 
		КонецЕсли;
		Счетчик 					= Счетчик + 1;
		Сотрудник    	 			= СтрокаТаблицы.Сотрудник;
		Услуга 	   	 	 			= СтрокаТаблицы.Услуга;		
		НормаВремени 	 			= СтрокаТаблицы.НормаВремени / 60;
		
		ВидЦенСотрудника = РегистрыСведений.НастройкиСотрудников.ПолучитьВидЦенСотрудника(СтруктурнаяЕдиница, Сотрудник);
		ВидЦенСотрудника = ?(ЗначениеЗаполнено(ВидЦенСотрудника), ВидЦенСотрудника, Справочники.ВидыЦен.Розничная);
		
		Если ЗначениеЗаполнено(Услуга) Тогда 
			СтруктураДанные = Новый Структура("ДатаОбработки, СтруктурнаяЕдиница, ВидЦен, Номенклатура", 
												ДатаЗаписи, СтруктурнаяЕдиница, ВидЦенСотрудника, Услуга);
			СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
		Иначе 
			СтруктураДанные = Новый Структура("Цена", 0);
		КонецЕсли;	
		
		НоваяСтрока 			  		= ОбъектСобытие.Услуги.Добавить();
		НоваяСтрока.Номенклатура  		= Услуга;
		НоваяСтрока.Цена          		= СтруктураДанные.Цена;
		НоваяСтрока.Сотрудник     		= Сотрудник;
		Если НЕ ЗначениеЗаполнено(ОбъектСобытие.Врач) Тогда 
			ОбъектСобытие.Врач 			= Сотрудник;
		КонецЕсли;	
		НоваяСтрока.НормаВремени  		= НормаВремени;
		НоваяСтрока.ДатаНачала	  		= ДатаЗаписи;
		Если ЗначениеЗаполнено(СтрокаТаблицы.Длительность) Тогда
			НоваяСтрока.ДатаОкончания 	= ДатаЗаписи + СтрокаТаблицы.Длительность*60;
		Иначе 	
			НоваяСтрока.ДатаОкончания 	= ДатаЗаписи + СтрокаТаблицы.НормаВремени;
		КонецЕсли;	
		НоваяСтрока.Помещение     		= РегистрыСведений.СвязкаПомещениеСотрудник.ПолучитьПомещениеСотрудникаПоУмолчанию(
			Сотрудник, СтруктурнаяЕдиница);
			
		Если ЗначениеЗаполнено(СтрокаТаблицы.ПричинаЗаписи) Тогда 
			НоваяСтрока.ПричинаЗаписи 	= СтрокаТаблицы.ПричинаЗаписи;	
		КонецЕсли;
		
		ОбъектСобытие.ВидЦен = ВидЦенСотрудника;
		
	КонецЦикла;
    ОбъектСобытие.Дата = Дата;
	МассивПолисов = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(Клиент, ОбъектСобытие.Дата);
	Если МассивПолисов.Количество() > 0 Тогда
		ОбъектСобытие.ПолисМедСтрахования = МассивПолисов[0];	
	КонецЕсли;
	
	Возврат ОбъектСобытие;
	
КонецФункции

// Функция, возвращает источник записи по внешней системе.
//
Функция ПолучитьИсточникЗаписи(ВнешняяСистема) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИсточникиЗаписей.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ИсточникиЗаписей КАК ИсточникиЗаписей
	|ГДЕ
	|	НЕ ИсточникиЗаписей.ПометкаУдаления
	|	И ИсточникиЗаписей.ВнешняяСистема = &ВнешняяСистема");
	
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.ИсточникиЗаписей.СоздатьИсточникЗаписей(ВнешняяСистема);	
	КонецЕсли;	
	
КонецФункции	

// Функция, находит или создает рекламный источник.
//
Функция ПолучитьРекламныйИсточник(РекламныйИсточник)
	
	НаименованиеРекламногоИсточника 	= РаскодироватьСтроку(РекламныйИсточник, СпособКодированияСтроки.КодировкаURL);
	Если СтрЗаканчиваетсяНа(НаименованиеРекламногоИсточника, "/") Тогда
		НаименованиеРекламногоИсточника = Лев(НаименованиеРекламногоИсточника, СтрДлина(НаименованиеРекламногоИсточника) - 1);
	КонецЕсли;
	
	ИсточникИнформации = Неопределено;
	Если ЗначениеЗаполнено(НаименованиеРекламногоИсточника) Тогда
		ИсточникИнформации = Справочники.РекламныеИсточники.ПолучитьРекламныйИсточник(НаименованиеРекламногоИсточника);
		Если НЕ ЗначениеЗаполнено(ИсточникИнформации) Тогда
			ИсточникИнформации = Справочники.РекламныеИсточники.СоздатьРекламныйИсточник(НаименованиеРекламногоИсточника);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ИсточникИнформации;
	
КонецФункции

// Функция, обновляет ФИО и Email клиента.
// 
Функция ОбновитьИнформациюОКлиенте(Клиент, ФИОКлиента, РекламныйИсточник, Email = Неопределено, birthday = Неопределено, СтруктурнаяЕдиница = Неопределено)
	
	ИмяСовпадаетСНомеромТелефона = Ложь;
	НеобходимостьЗаписиОбъекта	 = Ложь;
	НаличиеТекущегоEmail    	 = Ложь;
	
	ОбъектКлиент = Клиент.ПолучитьОбъект();
	
	НаименованиеКлиента = СтрЗаменить(СокрЛП(Клиент.Наименование), "+", "");
	Для Каждого КонтактнаяИнформация Из Клиент.КонтактнаяИнформация Цикл
		
		Если КонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон
			И СокрЛП(КонтактнаяИнформация.НомерТелефона) = НаименованиеКлиента Тогда
			
			ИмяСовпадаетСНомеромТелефона = Истина;
		ИначеЕсли ЗначениеЗаполнено(Email) И КонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты И НРег(КонтактнаяИнформация.АдресЭП) = НРег(Email) Тогда			
			НаличиеТекущегоEmail = Истина;	
		КонецЕсли;
			
	КонецЦикла;
	
	Если ИмяСовпадаетСНомеромТелефона Тогда
		
		ОбъектКлиент.Фамилия  = "";
		ОбъектКлиент.Имя 	  = "";
		ОбъектКлиент.Отчество = "";
		ОбъектКлиент.Наименование = ФИОКлиента;
		
		МассивПодстрок = СтрРазделить(ФИОКлиента, " ", Ложь);
		
		Если МассивПодстрок.Количество() = 1 Тогда
			ОбъектКлиент.Имя = МассивПодстрок[0];
		ИначеЕсли МассивПодстрок.Количество() > 0 Тогда
			ОбъектКлиент.Фамилия = МассивПодстрок[0];
		КонецЕсли;
		
		Если МассивПодстрок.Количество() > 1 Тогда
			ОбъектКлиент.Имя = МассивПодстрок[1];
		КонецЕсли;
		
		Если МассивПодстрок.Количество() > 2 Тогда
			ОбъектКлиент.Отчество = МассивПодстрок[2];
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ОбъектКлиент.ПолКлиента) Тогда
			ОбъектКлиент.ПолКлиента = ПолучитьПолКлиентаПоФИО(ОбъектКлиент.Имя, ОбъектКлиент.Фамилия, ОбъектКлиент.Отчество);
		КонецЕсли;
		
		НеобходимостьЗаписиОбъекта = Истина;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Клиент.ИсточникИнформации)
		И ЗначениеЗаполнено(РекламныйИсточник) Тогда
		
		ОбъектКлиент.ИсточникИнформации = РекламныйИсточник;
		НеобходимостьЗаписиОбъекта = Истина;
	КонецЕсли;
	
	Если Не НаличиеТекущегоEmail И ЗначениеЗаполнено(Email) Тогда
		ЗаполнитьАдресЭлектроннойПочты(ОбъектКлиент, Email);
		НеобходимостьЗаписиОбъекта = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(birthday) И Не ЗначениеЗаполнено(ОбъектКлиент.ДатаРожденияКлиента) Тогда			
		Попытка                                       
			ОбъектКлиент.ДатаРожденияКлиента = Дата(Сред(birthday,7), Сред(birthday,4,2), Сред(birthday,1,2));
			НеобходимостьЗаписиОбъекта = Истина;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) И Не ЗначениеЗаполнено(ОбъектКлиент.СтруктурнаяЕдиница) Тогда
		ОбъектКлиент.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
		НеобходимостьЗаписиОбъекта = Истина;
	КонецЕсли;
	
	Если НеобходимостьЗаписиОбъекта Тогда
		
		Попытка
			ОбъектКлиент.Записать();
		Исключение
			Возврат ПолучитьСтруктуруВозвратаОшибки(1112, ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция, возвращает двоичные данные фото.
// 
Функция ПолучитьФайлКартинки(ВерсияСсылка)
	
	Возврат РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(ВерсияСсылка).ДвоичныеДанные;
	
КонецФункции

#КонецОбласти