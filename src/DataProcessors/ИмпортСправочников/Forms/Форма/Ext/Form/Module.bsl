//
//
Функция СравнитьТелефоны(Телефон1, Телефон2) 
	
	Телефон1 = СокрЛП(Телефон1);	
	Телефон2 = СокрЛП(Телефон2);	
	
	ПозицияЗапятой1 = Найти(Телефон1, ",");
	ПозицияЗапятой2 = Найти(Телефон2, ",");
	
	Если ПозицияЗапятой1 <> 0 Тогда 
		Телефон1 = Лев(Телефон1, ПозицияЗапятой1);
	КонецЕсли;
	
	Если ПозицияЗапятой2 <> 0 Тогда 
		Телефон2 = Лев(Телефон2, ПозицияЗапятой2);
	КонецЕсли;
	
	НомерТелефона1_ТолькоЦифры = ВернутьТелефонТолькоЦифрами(Телефон1);
	НомерТелефона2_ТолькоЦифры = ВернутьТелефонТолькоЦифрами(Телефон2);
	
	
	Если ?(Константы.СтранаУчета.Получить().Пустая(), 0, Константы.СтранаУчета.Получить().Код) = "804" Тогда 
		Если СтрДлина(НомерТелефона1_ТолькоЦифры) = 11 Тогда
			Если Сред(НомерТелефона1_ТолькоЦифры, 2, 1) = "0" Тогда 
				НомерТелефона1_ТолькоЦифры = Сред(НомерТелефона1_ТолькоЦифры, 2, 10);
			КонецЕсли;
		ИначеЕсли СтрДлина(НомерТелефона1_ТолькоЦифры) = 12 Тогда
			Если Сред(НомерТелефона1_ТолькоЦифры, 1, 2) = "38" Тогда 
				НомерТелефона1_ТолькоЦифры = Сред(НомерТелефона1_ТолькоЦифры, 3, 10);
			КонецЕсли;	
		КонецЕсли;		
		Если СтрДлина(НомерТелефона2_ТолькоЦифры) = 11 Тогда
			Если Сред(НомерТелефона2_ТолькоЦифры, 2, 1) = "0" Тогда 
				НомерТелефона2_ТолькоЦифры = Сред(НомерТелефона2_ТолькоЦифры, 2, 10);
			КонецЕсли;
		ИначеЕсли СтрДлина(НомерТелефона2_ТолькоЦифры) = 12 Тогда
			Если Сред(НомерТелефона2_ТолькоЦифры, 1, 2) = "38" Тогда 
				НомерТелефона2_ТолькоЦифры = Сред(НомерТелефона2_ТолькоЦифры, 3, 10);
			КонецЕсли;	
		КонецЕсли;		
	Иначе 	
		Если СтрДлина(НомерТелефона1_ТолькоЦифры) = 11 Тогда
			Если Лев(НомерТелефона1_ТолькоЦифры, 1) = "7" ИЛИ Лев(НомерТелефона1_ТолькоЦифры, 1) = "8" Тогда 
				НомерТелефона1_ТолькоЦифры = Сред(НомерТелефона1_ТолькоЦифры, 2, 10);
			КонецЕсли;		
		КонецЕсли;
		Если СтрДлина(НомерТелефона2_ТолькоЦифры) = 11 Тогда
			Если Лев(НомерТелефона2_ТолькоЦифры, 1) = "7" ИЛИ Лев(НомерТелефона2_ТолькоЦифры, 1) = "8" Тогда 
				НомерТелефона2_ТолькоЦифры = Сред(НомерТелефона2_ТолькоЦифры, 2, 10);
			КонецЕсли;		
		КонецЕсли;		
	КонецЕсли;
	
	Если НомерТелефона1_ТолькоЦифры = НомерТелефона2_ТолькоЦифры Тогда 
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаСервере
//
//
Функция ВернутьТелефонТолькоЦифрами(Строка) 
	
  СтрокаЧисел = "";

   Для Индекс = 1 По СтрДлина(Строка) Цикл
   
      Символ = Сред(Строка, Индекс, 1); // Перебираем все сиволы из нашей строки

      Если КодСимвола(Символ) >= 48 И КодСимвола(Символ) <= 57 Тогда // Код нуля - 48, код 9-ки - 57
         СтрокаЧисел = СтрокаЧисел + Символ;
      КонецЕсли;
   
   КонецЦикла;

   Возврат СтрокаЧисел;	
	
	
КонецФункции

// Функция - Получить структуру XDTO телефона
//
// Параметры:
//  Телефон	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуру_XDTO(Представление, ТипКИ)
	
	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	Объект_XDTO = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Представление, ТипКИ);
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
		Если НЕ ЗначениеЗаполнено(Объект_XDTO.Состав.Номер) Тогда 
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат Объект_XDTO;
	
КонецФункции

// Процедура - Заполнить телефон 
//
// Параметры:
//  НовыйЭлемент		 - 	 - 
//  Объект_XDTO_Телефон	 - 	 - 
//
Процедура ЗаполнитьТелефон(НовыйЭлемент, Знач Объект_XDTO_Телефон, Знач ВидКИ)
	
	Если Объект_XDTO_Телефон = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 						= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 					= Перечисления.ТипыКонтактнойИнформации.Телефон;
	НоваяСтрока.Вид 					= ВидКИ;
	НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
	НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
	
	НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияXMLПоПредставлению(Объект_XDTO_Телефон.Представление,ВидКИ);
	НоваяСтрока.Значение 				= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Объект_XDTO_Телефон.Представление, ВидКИ);

	НоваяСтрока.Представление			= Объект_XDTO_Телефон.Представление;
	// НоваяСтрока.ЗначенияПолей			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
	
КонецПроцедуры

// Процедура - Заполнить email 
//
// Параметры:
//  НовыйЭлемент		 - 	 - 
//  Объект_XDTO_Email	 - 	 - 
//
Процедура ЗаполнитьEmail(НовыйЭлемент, Знач Объект_XDTO_Email, Знач ВидКИ)
	
	Если Объект_XDTO_Email = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 				= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 			= Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	НоваяСтрока.Вид 			= ВидКИ;
	НоваяСтрока.АдресЭП 		= Объект_XDTO_Email.Представление;
	НоваяСтрока.ЗначенияПолей 	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Email);
	НоваяСтрока.Значение 		= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Объект_XDTO_Email.Представление, ВидКИ);
	НоваяСтрока.Представление 	= НоваяСтрока.АдресЭП;
	
КонецПроцедуры

// Процедура - Заполнить адрес
//
// Параметры:
//  НовыйЭлемент		 - 	 - 
//  Объект_XDTO_Адрес	 - 	 - 
//  ВидКИ				 - 	 - 
//
Процедура ЗаполнитьАдрес(НовыйЭлемент, Знач Объект_XDTO_Адрес, Знач ВидКИ)
	
	Если Объект_XDTO_Адрес = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 				= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 			= Перечисления.ТипыКонтактнойИнформации.Адрес;
	НоваяСтрока.Вид 			= ВидКИ;
	НоваяСтрока.Страна 			= ?(Объект_XDTO_Адрес.Состав.Страна = Неопределено, "", Объект_XDTO_Адрес.Состав.Страна);
	НоваяСтрока.Регион 			= ?(Объект_XDTO_Адрес.Состав.Состав.СубъектРФ = Неопределено, "", Объект_XDTO_Адрес.Состав.Состав.СубъектРФ);
	НоваяСтрока.Город 			= ?(Объект_XDTO_Адрес.Состав.Состав.Город = Неопределено, "", Объект_XDTO_Адрес.Состав.Состав.Город);
	НоваяСтрока.ЗначенияПолей 	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Адрес);
	НоваяСтрока.Значение 		= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Объект_XDTO_Адрес.Представление, ВидКИ);
	НоваяСтрока.Представление 	= Объект_XDTO_Адрес.Представление;
	
КонецПроцедуры

