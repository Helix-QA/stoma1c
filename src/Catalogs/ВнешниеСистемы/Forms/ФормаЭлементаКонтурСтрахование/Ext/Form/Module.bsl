КонецФункции

&НаКлиенте
Функция ХостТокен()
	
	Возврат ?(ЭтотОбъект.Демо ,"identity.testkontur.ru", "identity.kontur.ru");
	
КонецФункции

&НаКлиенте
Процедура ПолучитьСписокОрганизаций(Команда)

	Если Не ЗначениеЗаполнено(Объект.ТокенДоступа) Тогда
		ВызватьИсключение "Не указан токен";
	КонецЕсли;
	
	Результат = GetAccessiblePartiesInfo();
	
	ТаблицаОрганизаций.Очистить();
	
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Для Каждого Эл Из Результат Цикл
			НоваяСтрока = ТаблицаОрганизаций.Добавить();
			
			НоваяСтрока.mediId			= Эл.Получить("mediId");
			НоваяСтрока.name			= Эл.Получить("name");
			НоваяСтрока.inn				= Эл.Получить("inn");
			НоваяСтрока.kpp				= Эл.Получить("kpp");
			НоваяСтрока.partyTypeCode	= Эл.Получить("partyTypeCode");
			
		КонецЦикла;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Функция GetAccessiblePartiesInfo()

	Запрос = Новый HTTPЗапрос("/V2/parties");
	Запрос.Заголовки.Вставить("Authorization", "Bearer "+Объект.ТокенДоступа);
	
	Ответ = Клиент_get(Запрос,ХостАпи());
	
	Если Ответ.КодСостояния = 403 Тогда
		ВызватьИсключение "Нет доступа ни к одной организации: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния = 401 Тогда
		ВызватьИсключение "Запрос не авторизован: " + Ответ.ПолучитьТелоКакСтроку();
	ИначеЕсли Ответ.КодСостояния >= 300 Тогда
		ВызватьИсключение "Не удалось выполнить запрос: " + Ответ.ПолучитьТелоКакСтроку();
	КонецЕсли;
	
	Возврат JSON_Прочитать(Ответ.ПолучитьТелоКакСтроку());

КонецФункции

