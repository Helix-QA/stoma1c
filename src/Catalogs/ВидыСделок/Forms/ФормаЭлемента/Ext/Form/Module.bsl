			Объект.СтруктурныеЕдиницыПрименения.Очистить();
			НоваяСтрока = Объект.СтруктурныеЕдиницыПрименения.Добавить();
			Объект.СтруктурныеЕдиницыПрименения[0].СтруктурнаяЕдиница = ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка");
			УстановитьВидимостьЭлементамСпискаСтруктурныхЕдиниц();			
		КонецЕсли;
	КонецЕсли;	
	
