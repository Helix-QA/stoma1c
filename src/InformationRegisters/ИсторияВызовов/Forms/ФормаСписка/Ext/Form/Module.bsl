// Функция - Запись разговора доступна по ролям
//
// Параметры:
//  ТекущиеДанные	 - 	 - 
//  ТекущиеДанные	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаписьРазговораДоступнаПоРолям(Пользователь, Контрагент)
	
	СотрудникСсылка = Неопределено;
	
	Если ЗначениеЗаполнено(Пользователь) И ТипЗнч(Пользователь) = Тип("СправочникСсылка.Сотрудники") Тогда
		СотрудникСсылка = Пользователь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СотрудникСсылка) И ЗначениеЗаполнено(Контрагент) И ТипЗнч(Контрагент) = Тип("СправочникСсылка.Сотрудники") Тогда
		СотрудникСсылка = Контрагент;
	КонецЕсли;
	
	Возврат РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ЧтениеЗаписейРазговоров") ИЛИ СотрудникСсылка = ПараметрыСеанса.ТекущийПользователь;
	
КонецФункции

