////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);	
		
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВыполнить()
	
	Если Модифицированность Тогда
		Записать();
	КонецЕсли;
	
	Отказ = Ложь;
	
	ОписаниеОшибки = "";
	
	Если Объект.ПолучателиПисьма.Количество() > 1 И ИндивидуальнаяОтправка Тогда
		СтруктураПараметров = Новый Структура("Ключ", Объект.Ссылка);
		Результат = Неопределено;
		ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаИндивидуальнойОтправки", СтруктураПараметров, ЭтаФорма,,,, 
					Новый ОписаниеОповещения("ОтправитьВыполнитьЗавершение", ЭтотОбъект, ОписаниеОшибки), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
        Возврат;
	Иначе
		Результат = ВыполнитьОтправкуНаСервере(ОписаниеОшибки);
	КонецЕсли;                                                                     
	
	ОтправитьВыполнитьЗавершение(Результат, ОписаниеОшибки);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВыполнитьЗавершение(Результат, ОписаниеОшибки)
	
	Модифицированность = Ложь;
	
	Если Результат = Истина Тогда
		Оповестить("ВыполненаОтправкаПисьма", Объект.Ссылка);
		Закрыть();
	Иначе
		Если ОписаниеОшибки <> "" Тогда
			ПоказатьПредупреждение(,ОписаниеОшибки);
		КонецЕсли; 
	КонецЕсли;
	
	СохранениеВводимыхЗначений();

КонецПроцедуры

&НаКлиенте
Процедура КнопкаДополнительноВыполнить()
		
	Текст = Новый ТекстовыйДокумент;
	Текст.ДобавитьСтроку("Создано:    " + Объект.Дата);
	Текст.ДобавитьСтроку("Отправлено: " + Объект.ДатаОтправления);
	Текст.ДобавитьСтроку("");
	Текст.ДобавитьСтроку("");
	Текст.ДобавитьСтроку("-------------------------------------------------");
	Текст.ДобавитьСтроку("Идентификатор сообщения:  " + Объект.ИдентификаторСообщения);
	Текст.ДобавитьСтроку("Идентификатор основания:  " + Объект.ИдентификаторОснования);
	Текст.ДобавитьСтроку("Идентификаторы оснований: " + ПолучитьПредставлениеИдентификаторовОснований(Объект.ИдентификаторыОснований));
	Текст.Показать();

КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеОтправителяОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Объект.УчетнаяЗапись = ВыбранноеЗначение;
	ЭлементСписка = Элемент.СписокВыбора.НайтиПоЗначению(ВыбранноеЗначение);
	Если ЭлементСписка <> Неопределено Тогда
		СтандартнаяОбработка = Ложь;
		Объект.ОтправительПредставление = ЭлементСписка.Представление;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеHTMLДокументаДокументСформирован(Элемент)
	
	Документ = Элемент.Документ;
	Документ.Body.innerHTML = Объект.ТекстHTML;
	Документ.Body.scroll = "auto";
	
	Если НЕ ПисьмоОтправлено Тогда
		Документ.Body.ContentEditable = "true";
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПолеHTMLДокументаПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ПоказатьРежимыКнопок();
	Модифицированность = НЕ ПисьмоОтправлено;
	
КонецПроцедуры

