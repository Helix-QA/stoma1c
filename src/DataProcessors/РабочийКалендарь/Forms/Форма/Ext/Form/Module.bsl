&НаКлиенте
// Процедура обновления страницы работы с клиентом  
//
Процедура ОбновлениеСтраницыРаботаСклиентом(ОбновитьСписокДокументов = Ложь)
	
	ОбновлениеСтраницыРаботаСклиентомСервер(ОбновитьСписокДокументов, ШиринаИнформацииПоКлиенту);
	// ИнформацияКлиента.ФиксацияСлева = ШиринаИнформацииПоКлиенту;	
	Если ОбновитьСписокДокументов Тогда
		РазвернутьДеревоЗначенийОбработки(ДеревоТекущихКлиентов, "ТаблицаТекущиеКлиенты");
		РазвернутьДеревоЗначенийОбработки(ДеревоНЕ_ТекущихКлиентов, "ТаблицаНЕ_ТекущиеКлиенты");		 
	КонецЕсли;	
	СтраницаРаботаСКлиентомОбновлена = Истина;
	
КонецПроцедуры

&НаСервере
// Процедура обновления страницы работы с клиентом. Сервер. 
//
Процедура ОбновлениеСтраницыРаботаСклиентомСервер(ОбновитьСписокДокументов = Ложь, ШиринаИнформацииПоКлиенту)
	
	ОбновитьСостояниеКассы();
	
	СтруктураПроверки = Новый Структура("Касса, СтатусСмены", Касса, СтатусСмены);
	
	СтруктураКСИзменение = ОбновитьСостояниеКассыИзменение(СтруктураПроверки);
	
	Если СтруктураКСИзменение.Изменять Тогда
		
		Если ЗначениеЗаполнено(СтруктураКСИзменение.СтатусСмены <> "Неопределено") Тогда
			ТекстСтатусСмены 	= НСтр("ru='Касса: Смена %СтатусСмены% %ВремяИзменения%'");
			ТекстСтатусСмены 	= СтрЗаменить(ТекстСтатусСмены, "%СтатусСмены%", Нрег(СтруктураКСИзменение.СтатусСмены));
			ТекстСтатусСмены   = СтрЗаменить(ТекстСтатусСмены, "%ВремяИзменения%", СтруктураКСИзменение.ВремяИзменения);
			
			Если СтатусСмены <> СтруктураКСИзменение.СтатусСмены Тогда
				Элементы.ГруппаКасса.Заголовок = ТекстСтатусСмены;
			КонецЕсли;
			СтатусСмены = СтруктураКСИзменение.СтатусСмены;
		Иначе		
			Элементы.ГруппаКасса.Заголовок = НСтр("ru='Смена не открыта'");;
			СтатусСмены = СтруктураКСИзменение.СтатусСмены;
		КонецЕсли;	
		
	КонецЕсли;
	
	// М*
	
	// УстановитьВидимостьМеню();
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ПодготовитьДанныеДляВыводаИнформацииПоКлиенту(Контрагент, Объект.СтруктурнаяЕдиница, ИнформацияКлиента, ШиринаИнформацииПоКлиенту, РазрешениеЭкрана);
	КонецЕсли;
	Если ОбновитьСписокДокументов Тогда
		СформироватьСписокОбслуживаемыеКлиентыСервер();
		СформироватьСписокРанееОбслуживаемыехКлиентовСервер();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
