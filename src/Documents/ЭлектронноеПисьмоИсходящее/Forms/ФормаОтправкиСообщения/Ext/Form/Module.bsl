// Процедура, обновляет колличество введенных символов.
//
Процедура ВзаимодействиеSMSОбновитьСтатусВведеныхСимволов()
	
	// Удаляем символы переноса строки.
	мТекст = НРег(ЭтотОбъект.ВзаимодействиеSMSТекст);
	
	// 1-sms это 160 символов, если больше 160 символов, тогда 1 sms = 153.
	РазмерностьСообщения = ?(СтрДлина(мТекст) > 160, 153, 160);
	КоличествоСМС = 0;
	
	СтрокаСимволов = "абвгдеёжзийклмнопрстуфхцчшщъыьэюя@_$^~`№";
	
	Для а = 1 По СтрДлина(СтрокаСимволов) Цикл
		
		Если Найти(мТекст, Сред(СтрокаСимволов, а, 1)) > 0 Тогда
			
			// 1-sms это 70 символов, если больше 70 символов, тогда 1 sms = 67.
			РазмерностьСообщения = ?(СтрДлина(мТекст) > 70, 67, 70);
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	КоличествоСимволов = СтрДлина(мТекст);
	КоличествоСМС      = Цел(СтрДлина(мТекст) / РазмерностьСообщения) + ?(СтрДлина(мТекст) % РазмерностьСообщения > 0, 1, 0);
	
	ПредставлениеСимволов = СтрокаСЧислом(";%1 символ;;%1 символа; %1 символов;%1 символа", КоличествоСимволов, ВидЧисловогоЗначения.Количественное, "L=ru"); 
	Если ЭтотОбъект.ТипСообщенияPushSMS <> ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
		ЭтотОбъект.ВзаимодействиеSMSСтатусВведенныхСимволов = ПредставлениеСимволов + ", " + КоличествоСМС + " sms";
	Иначе
		ЭтотОбъект.ВзаимодействиеSMSСтатусВведенныхСимволов = "";
	КонецЕсли;
	
КонецПроцедуры

