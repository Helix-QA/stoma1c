
#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Сотрудник") Тогда
		Элементы.Список.ПодчиненныеЭлементы.Сотрудник.Видимость = Ложь;
		НовыйОтбор = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйОтбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Сотрудник");
		НовыйОтбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйОтбор.ПравоеЗначение = Параметры.Сотрудник;
		НовыйОтбор.Использование = Истина;
		ИмяРеквизитаОтбора = "Сотрудник";
	ИначеЕсли Параметры.Свойство("Помещение") Тогда
		Элементы.Список.ПодчиненныеЭлементы.Помещение.Видимость = Ложь;
		Элементы.Список.ПодчиненныеЭлементы.СтруктурнаяЕдиница.Видимость = Ложь;
		Элементы.УстановитьОсновным.Видимость = Ложь;
		НовыйОтбор = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйОтбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Помещение");
		НовыйОтбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйОтбор.ПравоеЗначение = Параметры.Помещение;
		НовыйОтбор.Использование = Истина;
		ИмяРеквизитаОтбора = "Помещение";
	КонецЕсли;
	
	Если Параметры.Свойство("Заголовок") Тогда
		АвтоЗаголовок = Ложь;
		Заголовок = Параметры.Заголовок;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ИмяРеквизитаОтбора = "Помещение" ИЛИ ИмяРеквизитаОтбора = "Сотрудник" Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура;
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить(ИмяРеквизитаОтбора, ИмяРеквизитаОтбора);
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ПараметрыФормы.Вставить("Ключ", ВыбраннаяСтрока);
		ОткрытьФорму("РегистрСведений.СвязкаПомещениеСотрудник.ФормаЗаписи",
		ПараметрыФормы,,,,,, 
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы


&НаКлиенте
Процедура Основное(Команда)
	
	Если Элементы.Список.ТекущиеДанные <> Неопределено Тогда
		УстановитьСоответствиеОсновным(Элементы.Список.ТекущиеДанные.Сотрудник, Элементы.Список.ТекущиеДанные.Помещение, Не Элементы.УстановитьОсновным.Пометка);
		Элементы.Список.Обновить();
		Элементы.УстановитьОсновным.Пометка = Элементы.Список.ТекущиеДанные.Основное;
		Оповестить("ОбновленыКабинеты");
	КонецЕсли;
		
КонецПроцедуры
	
&НаСервере
Процедура УстановитьСоответствиеОсновным(Сотрудник, Помещение, УстанавливаемоеЗначение = Истина)
	
	НаборЗаписей = РегистрыСведений.СвязкаПомещениеСотрудник.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Сотрудник.Установить(Сотрудник);
	НаборЗаписей.Прочитать();
	Для Каждого Запись Из НаборЗаписей Цикл
		Если Запись.Помещение.СтруктурнаяЕдиница = Помещение.СтруктурнаяЕдиница Тогда
			Запись.Основное = ?(Запись.Помещение = Помещение, УстанавливаемоеЗначение, Ложь);
		КонецЕсли;
	КонецЦикла;
	НаборЗаписей.Записать();
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	Если Элементы.Список.ТекущиеДанные <> Неопределено Тогда
		Элементы.УстановитьОсновным.Пометка = Элементы.Список.ТекущиеДанные.Основное;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти