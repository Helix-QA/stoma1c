				  + ?(СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 ,"СубконтоКт1 В (&СчетКасса)","")+") КАК УправленческийОборотыДтКт

	|		ПО УправленческийОборотыСтатьи.СубконтоКт2 = УправленческийОборотыДтКт.СубконтоКт2
	|
	//|"+ ?(СчетКассаИспользование И СчетКассаОтбор.Количество() > 0," ГДЕ УправленческийОборотыДтКт.СубконтоКт1 В (&СчетКасса) ","") +"
	//|"+ ?(ЗначениеЗаполнено(СчетКасса)," ГДЕ УправленческийОборотыДтКт.СубконтоКт1 = &СчетКасса ","") +"  
	|СГРУППИРОВАТЬ ПО
	|	УправленческийОборотыСтатьи.СубконтоКт2
	|УПОРЯДОЧИТЬ ПО
	|	Статья
	|ИТОГИ
	|	СУММА(СуммаОборот)
	|ПО
	|	ОБЩИЕ,
	|	Статья";
		
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);	
	КонецЕсли;	
	//Если ЗначениеЗаполнено(СчетКасса) Тогда
	//	Запрос.УстановитьПараметр("СчетКасса", СчетКасса);	
	//КонецЕсли;	
	
	Если СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 Тогда
		Запрос.УстановитьПараметр("СчетКасса", СчетКассаОтбор);	
	КонецЕсли;	
	
	Если ЭтаФорма.ПериодИспользование Тогда
		
		Запрос.УстановитьПараметр("НачалоПериода", Период.ДатаНачала);	
		Если НЕ ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
			Запрос.УстановитьПараметр("КонецПериода", Дата(3999, 1, 1));		
		Иначе	
			Запрос.УстановитьПараметр("КонецПериода", Период.ДатаОкончания);	
		КонецЕсли;	
		
	Иначе
		Запрос.УстановитьПараметр("НачалоПериода", '00010101');	
		Запрос.УстановитьПараметр("КонецПериода", '00010101');	
	КонецЕсли;
	
	ВыборкаИтог = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтог.Следующий();
	
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка1");
	ОбластьСтрока.Параметры.Статья = СтатьяДС;
	ОбластьСтрока.Параметры.Расход = ВыборкаИтог.СуммаОборот;
	ТабличныйДокумент.Вывести(ОбластьСтрока);			

	Если Первый Тогда
		СписокГруппировки.Добавить(ТабличныйДокумент.ВысотаТаблицы,,Истина);	
	КонецЕсли;

	
	ИтогДС = ИтогДС - ?(ЗначениеЗаполнено(ВыборкаИтог.СуммаОборот), ВыборкаИтог.СуммаОборот, 0);
	ИтогР = ИтогР + ?(ЗначениеЗаполнено(ВыборкаИтог.СуммаОборот), ВыборкаИтог.СуммаОборот, 0);
	
	ВыборкаСтатьи = ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
	Пока ВыборкаСтатьи.Следующий() Цикл		

		ОбластьСтрока = Макет.ПолучитьОбласть("Строка2");
		ОбластьСтрока.Параметры.Статья = ВыборкаСтатьи.Статья;
		ОбластьСтрока.Параметры.Расход = ВыборкаСтатьи.СуммаОборот;
		ТабличныйДокумент.Вывести(ОбластьСтрока);			
		
	КонецЦикла;
	
	Если Первый Тогда
		СписокГруппировки.Добавить(ТабличныйДокумент.ВысотаТаблицы,,Ложь);	
	КонецЕсли;
		
