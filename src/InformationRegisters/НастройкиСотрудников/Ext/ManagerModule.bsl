// Функция - Получить места работы сотрудника
//
// Параметры:
//  Сотрудник					 - 	 - 
//  ТипВозвращаемыхДанных		 - Строка - Если не указан - вернет массив
//  ВыбраннаяСтруктурнаяЕдиница	 - 	 - 
//  ДобавлятьТекущую			 - Булево - Добавляет, в случае отсутствия, текущую клинику
// 
// Возвращаемое значение:
//   - Список/Массив
//
Функция ПолучитьМестаРаботыСотрудника(Сотрудник = Неопределено
									, ТипВозвращаемыхДанных = "Список"
									, ВыбраннаяСтруктурнаяЕдиница = Неопределено
									, ДобавлятьТекущую = Ложь
									, ИспользоватьЗакешированноеЗначение = Истина) Экспорт
	
	Возврат Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(Сотрудник, ТипВозвращаемыхДанных,ВыбраннаяСтруктурнаяЕдиница,ДобавлятьТекущую,ИспользоватьЗакешированноеЗначение);	
	
КонецФункции	

// Функция - Получить сотрудников клиники
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  МассивСотрудников	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСотрудниковКлиники(СтруктурнаяЕдиница, МассивСотрудников = Неопределено) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());		
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Сотрудник В(&МассивСотрудников)
	|	И ВЫБОР
	|			КОГДА Сотрудники.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Сотрудники.ДатаУвольнения > &ТекущаяДата
	|		КОНЕЦ
	|	И Сотрудники.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сотрудники.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.СтруктурнаяЕдиница.ЭтоГруппа = ЛОЖЬ";
	
	Если ЗначениеЗаполнено(МассивСотрудников) И ТипЗнч(МассивСотрудников) = Тип("Массив") Тогда 
		Запрос.УстановитьПараметр("МассивСотрудников", МассивСотрудников);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сотрудники.Сотрудник В(&МассивСотрудников)
	|	И ", "");
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");	
	
КонецФункции

// Функция - Получить ассистента сотрудника.
//
Функция ПолучитьАссистентаСотрудника(Сотрудник, СтруктурнаяЕдиница) Экспорт
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.Ассистент КАК Ассистент
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.Сотрудник = &Сотрудник
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");   
	
	Запрос.УстановитьПараметр("Сотрудник"		  , ?(ЗначениеЗаполнено(Сотрудник), Сотрудник, Неопределено));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, Неопределено));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ассистент, Неопределено);
	
КонецФункции

