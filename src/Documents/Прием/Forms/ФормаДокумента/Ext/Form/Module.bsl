&НаКлиенте
// Процедура - Ассистент обработка выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура АссистентОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
		
	Если ЗначениеЗаполнено(Объект.Сотрудник) И Объект.Сотрудник = ВыбранноеЗначение Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Врач не может сам себя ассистировать!'"), , "Ассистент", "Объект");
        СтандартнаяОбработка = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сотрудник обработка выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура СотрудникОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) И ЗначениеЗаполнено(Объект.Сделка) И НЕ Объект.Ссылка.Пустая() Тогда 
		Если НЕ ВрачСоответствуетСделке(ВыбранноеЗначение, Объект.Сделка) Тогда 
			СтандартнаяОбработка = Ложь;
			ВыбранноеЗначение = Объект.Сотрудник;
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Выбранный врач не соответствует врачу, указанному в сделке!'"), , "Сотрудник", "Объект");
			Возврат;
		КонецЕсли;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ассистент) И Объект.Ассистент = ВыбранноеЗначение Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Ассистент не может быть врачём!'"), , "Сотрудник", "Объект");
        СтандартнаяОбработка = Ложь;
		
	КонецЕсли;
	
	Если Объект.Лечение.Количество() > 0 Тогда
		СтандартнаяОбработка = Ложь;
		ТекстВопроса = "При изменении сотрудника необходимо очистить табличную часть Лечение. Очистить?";
		ПоказатьВопрос(Новый ОписаниеОповещения("СотрудникОбработкаВыбораЗавершение", ЭтотОбъект, ВыбранноеЗначение), ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		Возврат;	
	КонецЕсли;
	
КонецПроцедуры 

