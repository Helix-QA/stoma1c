				, 
				,
				400); 								
				
			КонецЕсли;
			
			Возврат Новый HTTPСервисОтвет(400);	
		КонецЕсли;
		
	Исключение
		
		// Логирование
		Если ЛогироватьСобытие > 0 Тогда
			
			ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
			ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
			ИнформацияОбОшибке     = ИнформацияОбОшибке();
			ОписаниеОшибки         = ИнформацияОбОшибке.Причина.Описание;
			Если СтрНайти(ИнформацияОбОшибке.Причина.Описание, "Превышено время ожидания") > 0 Тогда						
				СтатусСобытия = Перечисления.СтатусыЗапросов.TimedOut;
			Иначе
