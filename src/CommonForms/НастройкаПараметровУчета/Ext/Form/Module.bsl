// Процедура, сохраняет внешнюю систему.
//
Процедура ЗаписатьВнешнююСистему(ВиджетОнлайнЗаписи, АвторизацияПоКодуБезСМС, ПараметрыВС)
	
	ВнешняяСистемаОбъект = ВиджетОнлайнЗаписи.ПолучитьОбъект();
	
	Если АвторизацияПоКодуБезСМС <> ВиджетОнлайнЗаписи.АвторизацияПоКодуБезСМС Тогда
		ВнешняяСистемаОбъект.АвторизацияПоКодуБезСМС = АвторизацияПоКодуБезСМС;     
	КонецЕсли;

	Если ЗначениеЗаполнено(ПараметрыВС) И ТипЗнч(ПараметрыВС) = Тип("Структура") Тогда
		
		ПараметрыВнешнейСистемы = ВнешняяСистемаОбъект.Параметры.Получить();
		
		Если ПараметрыВнешнейСистемы = Неопределено Тогда 
			ПараметрыВнешнейСистемы = Новый Структура();
		КонецЕсли;
		
		Для Каждого ПараметрВС Из ПараметрыВС Цикл
			
			Если ПараметрыВнешнейСистемы.Свойство(ПараметрВС.Ключ) Тогда 
				ПараметрыВнешнейСистемы[ПараметрВС.Ключ] = ПараметрВС.Значение;
			Иначе
				ПараметрыВнешнейСистемы.Вставить(ПараметрВС.Ключ, ПараметрВС.Значение);
			КонецЕсли;
			
		КонецЦикла;		
		
		ВнешняяСистемаОбъект.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы);
		
	КонецЕсли;
	
	ВнешняяСистемаОбъект.Записать();
	             
	ИспользуемыеСтруктурныеЕдиницы = Неопределено;
	ПараметрыВнешнейСистемы = ВиджетОнлайнЗаписи.Параметры.Получить();
	Если ПараметрыВнешнейСистемы <> Неопределено И ПараметрыВнешнейСистемы.Свойство("ИспользуемыеСтруктурныеЕдиницы") Тогда
		ИспользуемыеСтруктурныеЕдиницы = ПараметрыВнешнейСистемы.ИспользуемыеСтруктурныеЕдиницы;
	КонецЕсли;
	
	Если ИспользуемыеСтруктурныеЕдиницы <> Неопределено Тогда
		ЛичныйКабинет.ЗарегистироватьВиджет(ПолучитьОрганизациюСалона(), ВиджетОнлайнЗаписи.КлючПриложения, ИспользуемыеСтруктурныеЕдиницы)
	КонецЕсли;
	
КонецПроцедуры

