&НаСервере
// Процедура, выполняет проверку на дублирование клиентов.
//
Процедура ПроверкаДублированияКлиентаКонтактнаяИнформацияНаСервере(Знач ДанныеКИ = Неопределено, Знач ТекстРедактирования = Неопределено)
	
	Если (ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Отклонена
		  Или ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Принята)
		ИЛИ Не ЗначениеЗаполнено(ЭтаФорма.КонтактнаяИнформация) Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ПоказатьНаличиеДублейКлиентов.Видимость = Ложь;

	МассивДублей     = ПроверитьНаДублированиеКлиента();
	КоличествоДублей = МассивДублей.Количество();
	
	Если КоличествоДублей > 0 Тогда
		
		// Формирование представления проверки дублей.
		СтруктураПараметровСообщенияОДублях = Новый Структура;
		СтруктураПараметровСообщенияОДублях.Вставить("ЭлектроннаяПочта", НСтр("ru='почтой';en='by mail'"));
		СтруктураПараметровСообщенияОДублях.Вставить("НомерТелефона"   , НСтр("ru='номером телефона';en='number phone'"));
		
		Если КоличествоДублей = 1 Тогда
			
			СтруктураПараметровСообщенияОДублях.Вставить("КоличествоДублей" , НСтр("ru='один';en='one'"));
			СтруктураПараметровСообщенияОДублях.Вставить("СклонениеКлиентов", НСтр("ru='клиент';en='client'"));
			
		ИначеЕсли КоличествоДублей < 5 Тогда
			
			СтруктураПараметровСообщенияОДублях.Вставить("КоличествоДублей" , КоличествоДублей);
			СтруктураПараметровСообщенияОДублях.Вставить("СклонениеКлиентов", НСтр("ru='клиента';en='client'"));
		Иначе
			СтруктураПараметровСообщенияОДублях.Вставить("КоличествоДублей" , КоличествоДублей);
			СтруктураПараметровСообщенияОДублях.Вставить("СклонениеКлиентов", НСтр("ru='клиентов';en='clients'"));
			
		КонецЕсли;
		
		ОписаниеПредставления = НСтр("ru='С такой [ЭлектроннаяПочта] и [НомерТелефона] есть [КоличествоДублей] [СклонениеКлиентов]';en='With this [ЭлектроннаяПочта] and [НомерТелефона] there is [КоличествоДублей] [СклонениеКлиентов]'");
		ОписаниеПредставления = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ОписаниеПредставления, СтруктураПараметровСообщенияОДублях);
		
		ЭтотОбъект.СписокДублей.ЗагрузитьЗначения(МассивДублей);
		
		Элементы.ПоказатьНаличиеДублейКлиентов.Видимость = Истина;
		Элементы.ПоказатьНаличиеДублейКлиентов.Заголовок = ОписаниеПредставления;
		
	КонецЕсли;
	
КонецПроцедуры

