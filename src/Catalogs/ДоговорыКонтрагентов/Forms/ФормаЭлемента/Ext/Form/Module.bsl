// Процедура - Выбор договора для копирования обработка выбора.
//
Процедура ВыборДоговораДляКопированияОбработкаВыбора(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.УслугиПоДоговору.Количество() > 0 Тогда
		ПараметрыВопроса = Новый Структура("РезультатВыбора", Результат);
		Оповещение = Новый ОписаниеОповещения("КопированиеТЧЗавершение", ЭтотОбъект, ПараметрыВопроса); 
		ПоказатьВопрос(Оповещение, "Табличная часть с номенклатурой будет очищена. Продолжить?", РежимДиалогаВопрос.ДаНет);	
	Иначе
		ЗаполнитьСтрокиИзНовойТаблицыПоДоговору(Результат)	
	КонецЕсли;
	
КонецПроцедуры

