// Процедура, обработчик события "ПередНачаломИзменения"
//
Процедура ЗапасыПередНачаломИзменения(Элемент, Отказ)
	
	Если Элемент.ТекущийЭлемент.Имя = "ЗапасыПроцентСкидкиНаценки" Тогда		
		Если РазрешенаУстановкаСкидки(Элемент.ТекущиеДанные) Тогда			
			ПроцентСкидки = Элемент.ТекущиеДанные.ПроцентСкидкиНаценки;
			ПараметрыФормы = Новый Структура("ПроцентСкидки, МаксимальнаяРучнаяСкидка", ПроцентСкидки, ЭтотОбъект.МаксимальнаяРучнаяСкидка); 
			Описание = Новый ОписаниеОповещения("ПослеОткрытияФормыУстановкиРучнойСкидки", ЭтотОбъект);  
			// Открываем форму установки размера скидки  
			ОткрытьФорму("ОбщаяФорма.ФормаУстановкиРучнойСкидки", ПараметрыФормы,,,,, Описание,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли; 
		Отказ = Истина;	
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте 
// Процедура, Обработчик события "ПослеОткрытияФормыУстановкиРучнойСкидки".
//
Процедура ПослеОткрытияФормыУстановкиРучнойСкидки(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда 		
		Если Результат.ЗаполнитьВсеСтроки Тогда 
			Для Каждого СтрокаТЧ Из Объект.Запасы Цикл
				Если РазрешенаУстановкаСкидки(СтрокаТЧ) Тогда
					СтрокаТЧ.ПроцентСкидкиНаценки = Результат.ПроцентСкидки;
					ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(СтрокаТЧ); 
					
					РассчитатьСуммуПродажиВСтрокеТабличнойЧасти(СтрокаТЧ);
				КонецЕсли;
			КонецЦикла;		
		Иначе 
			ТекущаяСтрока                      = Элементы.Запасы.ТекущиеДанные;
			ТекущаяСтрока.ПроцентСкидкиНаценки = Результат.ПроцентСкидки;
			ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(ТекущаяСтрока); 
			
			РассчитатьСуммуПродажиВСтрокеТабличнойЧасти(ТекущаяСтрока);			
		КонецЕсли;   
	КонецЕсли;   
	
КонецПроцедуры

