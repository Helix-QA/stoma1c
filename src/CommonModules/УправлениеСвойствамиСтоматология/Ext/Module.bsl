// Функция возвращает интервалы времени
// 
//  Параметры
//   МассивПериодов - структура, периоды, между которыми необходимо возвратить интервалы
//   Интервал - число, интервал в минутах
//   Формат - строка, представление интервала
//
// Возвращаемое значение:
//   СписокЗначений, список времени с интервалом.
//
Функция ВернутьСписокВремениНаСервере(МассивПериодов, ДатаНачала, Интервал = 15, Формат = "ДФ=ЧЧ:мм") Экспорт
	
	СписокВремени = Новый СписокЗначений;
	
	Для Каждого Период Из МассивПериодов Цикл
		Если ДатаНачала Тогда
			Счетчик = 0;
		Иначе
			Счетчик = 1;
		КонецЕсли;
		Период.ДатаНачала = НачалоЧаса(Период.ДатаНачала) + Цел (Минута(Период.ДатаНачала) / 15) * 15 * 60;
		Пока Период.ДатаНачала + Интервал * 60 * Счетчик <= Период.ДатаОкончания Цикл
			Время = Период.ДатаНачала + Интервал * 60 * Счетчик;
			Если СписокВремени.НайтиПоЗначению(Время) = Неопределено Тогда
				Если не ЗначениеЗаполнено(Время) Тогда
					СписокВремени.Добавить(Время, "00:00");
				Иначе
					СписокВремени.Добавить(Время, Формат(Время, Формат));
				КонецЕсли;
			КонецЕсли;			
			Счетчик = Счетчик + 1;
		КонецЦикла;
		Если Период.ДатаОкончания = Дата(01,01,01,23,59,59) и не ДатаНачала Тогда
			СписокВремени.Добавить(Период.ДатаНачала + Интервал * 60 * Счетчик, "24:00");
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокВремени; 
	
КонецФункции

