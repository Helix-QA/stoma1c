// Функция, возвращает данные из таблицы внешних систем.
//
Функция ПолучитьДанныеВСПоВнешнейСистеме(ВнешняяСистема)
	
	МассивСтрок = ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("ВнешняяСистема", ВнешняяСистема));
	
	Если МассивСтрок.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат Новый Структура("ВнешняяСистема, ИмяЭлементаФормы", МассивСтрок[0].ВнешняяСистема, МассивСтрок[0].ИмяЭлементаФормы);
	КонецЕсли;
	
КонецФункции

&НаСервере
// Функция, возвращает данные из таблицы внешних систем.
//
Функция ПолучитьДанныеВСПоИмениЭлемента(ИмяЭлемента)
	
	ИмяЭлементаВТаблице = Лев(ИмяЭлемента, СтрНайти(ИмяЭлемента, "_", НаправлениеПоиска.СКонца) - 1);
	МассивСтрок = ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("ИмяЭлементаФормы", ИмяЭлементаВТаблице));
	
	Если МассивСтрок.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат Новый Структура("ВнешняяСистема, ИмяЭлементаФормы", МассивСтрок[0].ВнешняяСистема, МассивСтрок[0].ИмяЭлементаФормы);
	КонецЕсли;
	
КонецФункции

