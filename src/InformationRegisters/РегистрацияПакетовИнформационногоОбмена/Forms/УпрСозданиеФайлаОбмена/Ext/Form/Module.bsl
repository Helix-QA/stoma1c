
#Область СлужебныйПрограммныйИнтерфейс

#Область ОбрабочтикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.ДокументРеестра = Параметры.АктОказанияУслуг;
	Если ЗначениеЗаполнено(ЭтотОбъект.ДокументРеестра) Тогда
		ЭтотОбъект.Отправитель = ЭтотОбъект.ДокументРеестра.СтруктурнаяЕдиница.Организация;
		ЭтотОбъект.Получатель = ЭтотОбъект.ДокументРеестра.Контрагент;
		
		ОпределитьКоличествоПакетовОбмена();
		
		// определим параметры отображения списка пакетов за этот период
		
		ЭтотОбъект.СписокПакетовОтчетногоПериода.Параметры.УстановитьЗначениеПараметра(
			"Период", НачалоМесяца(ДокументРеестра.НачалоПериода)
		);
		ЭтотОбъект.СписокПакетовОтчетногоПериода.Параметры.УстановитьЗначениеПараметра(
			"Источник", ДокументРеестра.СтруктурнаяЕдиница.Организация
		);
		ЭтотОбъект.СписокПакетовОтчетногоПериода.Параметры.УстановитьЗначениеПараметра(
			"Получатель", ДокументРеестра.Контрагент
		);
		
		СформироватьДанныеОФайлахДокумента();
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбрабочтикиСобытийЭлементовФормы

&НаКлиенте
Процедура ДеревоСформированныеФайлыИмяФайлаОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		ПолучитьФайл(ТекДанные.АдресХранилища, ТекДанные.ИмяФайла);
	КонецЕсли;
	
КонецПроцедуры
 
&НаКлиенте
Процедура ДеревоСформированныеФайлыИмяФайлаПриИзменении(Элемент)
	
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		Если НЕ ЗначениеЗаполнено(ТекДанные.Родитель) Тогда
			Расширение = ".ZIP";
			ИмяФайлаВРег = ВРег(ТекДанные.ИмяФайла);
			Если Найти(ИмяФайлаВРег, Расширение) = 0 Тогда
				ТекДанные.ИмяФайла = ТекДанные.ИмяФайла + Расширение;
			КонецЕсли;
		Иначе
			Расширение = ".XML";
			ИмяФайлаВРег = ВРег(ТекДанные.ИмяФайла);
			Если Найти(ИмяФайлаВРег, Расширение) = 0 Тогда
				ТекДанные.ИмяФайла = ТекДанные.ИмяФайла + Расширение;
			КонецЕсли;
		КонецЕсли; ;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСформированныеФайлыПриАктивизацииСтроки(Элемент)
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		ЭтоАрхив = НЕ ЗначениеЗаполнено(ТекДанные.Родитель);
		Элементы.ПроверитьАрхив.Доступность = ЭтоАрхив И НЕ ТекДанные.Входящий;
		Элементы.СохранитьФайл.Доступность = ЭтоАрхив И НЕ ЗначениеЗаполнено(ТекДанные.СсылкаФайл);
		Элементы.РегистрацияПакета.Доступность = ЭтоАрхив И 
												 ТекДанные.Прикреплен И
												 НЕ ТекДанные.Зарегистрирован;
		Элементы.УдалитьФайлОбмена.Доступность = ЭтоАрхив;
	Иначе
		Элементы.ПроверитьАрхив.Доступность = Ложь;
		Элементы.СохранитьФайл.Доступность = Ложь;
		Элементы.РегистрацияПакета.Доступность = Ложь;
		Элементы.УдалитьФайлОбмена.Доступность = Ложь;
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСформированныеФайлыПередНачаломИзменения(Элемент, Отказ)
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	Если ТекДанные <> Неопределено И
		Элемент.ТекущийЭлемент <> Неопределено И
		Элемент.ТекущийЭлемент.Имя = "ДеревоСформированныеФайлыИмяФайла"
	Тогда
		Отказ = (ТекДанные.Прикреплен ИЛИ ТекДанные.Зарегистрирован);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСформированныеФайлыПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоСформированныеФайлыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	Если ТекДанные <> Неопределено И
		Элемент.ТекущийЭлемент <> Неопределено И
		Элемент.ТекущийЭлемент.Имя = "ДеревоСформированныеФайлыКнопкаПросмотра"
	Тогда
		СтандартнаяОбработка = Ложь;
		ПолучитьФайл(ТекДанные.АдресХранилища, ТекДанные.ИмяФайла);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
	
#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СформироватьФайлыОбмена(Команда)
	ЭлементыДерева =ЭтотОбъект.ДеревоСформированныеФайлы.ПолучитьЭлементы();
	ЭлементыДерева.Очистить();
	СформироватьФайлыОбменаСервер();
	СформироватьДанныеОФайлахДокумента();
КонецПроцедуры

&НаКлиенте
Процедура СохранитьФайл(Команда)
	
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	// сохраняем только те, что без ссылки
	Если ТекДанные <> Неопределено И
		 НЕ ЗначениеЗаполнено(ТекДанные.Родитель) И
		 НЕ ЗначениеЗаполнено(ТекДанные.СсылкаФайл)
	Тогда
		
		ФайлОтвет_ = СохранитьФайл_Сервер(ТекДанные.ИмяФайла, ТекДанные.АдресХранилища);
		Если ЗначениеЗаполнено(ФайлОтвет_) Тогда
			ТекДанные.СсылкаФайл = ФайлОтвет_;
			ТекДанные.Прикреплен = Истина;
			// дочерним узлам тоже проставим признак прикрепленности
			УзелДерева = Неопределено;
			Пока ОбщегоНазначенияКлиентСервер.ОбходДерева_Следующий(ЭтотОбъект.ДеревоСформированныеФайлы, УзелДерева) Цикл
				Если УзелДерева.Родитель = ТекДанные.УникальныйИдентификатор Тогда
					УзелДерева.СсылкаФайл = ФайлОтвет_;
					УзелДерева.Прикреплен = Истина;
				КонецЕсли;
			КонецЦикла;
		Иначе
			ПоказатьСообщение("РегистрацияПакетовИО_СохранениеНеУдалось");
		КонецЕсли;
		Элементы.ДеревоСформированныеФайлы.Обновить();
		ДеревоСформированныеФайлыПриАктивизацииСтроки(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РегистрацияПакета(Команда)
	
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	// сохраняем только те, что без ссылки
	Если ТекДанные <> Неопределено И
		 НЕ ЗначениеЗаполнено(ТекДанные.Родитель) И
		 ТекДанные.Прикреплен = Истина И
		 ТекДанные.Зарегистрирован = Ложь
	Тогда
		Ответ = РегистрацияПакета_Сервер(ТекДанные.СсылкаФайл, ТекДанные.Входящий);
		Если Ответ Тогда
			ТекДанные.Зарегистрирован = Истина;
			// дочерним узлам тоже проставим признак прикрепленности
			УзелДерева = Неопределено;
			Пока ОбщегоНазначенияКлиентСервер.ОбходДерева_Следующий(ЭтотОбъект.ДеревоСформированныеФайлы, УзелДерева) Цикл
				Если УзелДерева.Родитель = ТекДанные.УникальныйИдентификатор Тогда
					УзелДерева.Зарегистрирован = Истина;
				КонецЕсли;
			КонецЦикла;
			Элементы.ДеревоСформированныеФайлы.Обновить();
			Элементы.СписокПакетовОтчетногоПериода.Обновить();
			ДеревоСформированныеФайлыПриАктивизацииСтроки(Неопределено);
		КонецЕсли; 
	Конецесли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменаРегистрации(Команда)
	ТекДанные = Элементы.СписокПакетовОтчетногоПериода.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		МассивФайловДляОбновленияРегистрации = Новый Массив();
		МассивФайловДляОбновленияРегистрации.Добавить(ТекДанные.ФайлОбмена);
		Ответ = ОтменаРегистрации_Сервер(ТекДанные.Период,
								ТекДанные.НомерПакета,
								ТекДанные.Отправитель,
								ТекДанные.Получатель,
								ТекДанные.Входящий
							);
		Если Ответ Тогда
			ОбновитьЗарегистрированныеФайлы(МассивФайловДляОбновленияРегистрации);
			Элементы.СписокПакетовОтчетногоПериода.Обновить();
			Элементы.ДеревоСформированныеФайлы.Обновить();
			ДеревоСформированныеФайлыПриАктивизацииСтроки(Неопределено);
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьАрхив(Команда)
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	Если ТекДанные <> Неопределено Тогда
		Ответ = ПроверитьФайл_Сервер(ТекДанные.ИмяФайла, ТекДанные.АдресХранилища);
		Если Ответ = Ложь Тогда
			ВывестиПредупреждение("ОбменДанными_ФайлНеПрошелПроверку",
													Новый Структура("ИмяФайла", ТекДанные.ИмяФайла)
												);
		Иначе
			Состояние("Проверка файла «" + ТекДанные.ИмяФайла + "» прошла успешно.");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФайлОбмена(Команда)
	
	Обработчик = Новый ОписаниеОповещения("ДобавитьФайлПослеУстановкиРасширения", ЭтотОбъект);
	
	ОбщегоНазначенияКлиент.ПоказатьВопросОбУстановкеРасширенияРаботыСФайлами(Обработчик);
	
КонецПроцедуры
	
#КонецОбласти  

&НаКлиенте
// Процедура - Добавить файл после установки расширения
//
// Параметры:
//  Ответ					 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДобавитьФайлПослеУстановкиРасширения(Ответ, ДополнительныеПараметры) Экспорт
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ДобавитьФайлПослеПодключенияРасширения", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить файл после подключения расширения
//
// Параметры:
//  Подключено				 - 	 - 
//  ДополнительныеПараметры1 - 	 - 
//
Процедура ДобавитьФайлПослеПодключенияРасширения(Подключено, ДополнительныеПараметры1) Экспорт
	
	Если НЕ Подключено Тогда
		ПоказатьПредупреждениеОНеобходимостиРасширенияРаботыСФайлами(Неопределено);
		Возврат;
	КонецЕсли;
	
	ВыборФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ВыборФайла.МножественныйВыбор = Ложь;
	ВыборФайла.Заголовок = Получить("РегистрацияПакетовИО_ВыборФайлаОбменаДанными_ОМС");
	ВыборФайла.Фильтр = НСтр("ru = 'Архивы ZIP (*.zip)|*.zip*'");
	ВыборФайла.ПредварительныйПросмотр = Ложь;
	ВыборФайла.Показать(Новый ОписаниеОповещения("ДобавитьФайлПослеВыбораФайла", ЭтотОбъект, Новый Структура("ВыборФайла", ВыборФайла)));

КонецПроцедуры

&НаКлиенте
// Процедура - Добавить файл после выбора файла
//
// Параметры:
//  ВыбранныеФайлы			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДобавитьФайлПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	ВыборФайла = ДополнительныеПараметры.ВыборФайла;
		
	Если (ВыбранныеФайлы <> Неопределено) Тогда
		ПолныйПутьКФайлу = ВыборФайла.ПолноеИмяФайла;
	Иначе
		Возврат;
	КонецЕсли;
	ЗагружаемыйФайл =  Новый ДвоичныеДанные(ПолныйПутьКФайлу);
	АдресХранилища = ПоместитьВоВременноеХранилище(ЗагружаемыйФайл, ЭтотОбъект.УникальныйИдентификатор);
	
	СтрокиПути = ОбщегоНазначенияКлиентСервер.РазложитьСтрокуПоТочкамИСлэшам(ПолныйПутьКФайлу);
	Если СтрокиПути.Количество() >= 2 Тогда
		Расширение = СтрокиПути[СтрокиПути.Количество()-1];
		ИмяБезРасширения = СтрокиПути[СтрокиПути.Количество()-2];
		ПолноеИмяФайла = ИмяБезРасширения + "." + Расширение;
	Иначе
		ВызватьИсключение Получить("РегистрацияПакетовИО_ОшибкаПриПомещенииФайлаВХранилище",Новый Структура("Файл",ПолныйПутьКФайлу));
	КонецЕсли;
	
	ДобавитьФайлОбмена_Сервер(ВРег(ИмяБезРасширения), ВРег(Расширение), АдресХранилища);

КонецПроцедуры

&НаКлиенте
Процедура УдалитьФайлОбмена(Команда)
	
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	// сохраняем только те, что без ссылки
	Если ТекДанные <> Неопределено И НЕ ЗначениеЗаполнено(ТекДанные.Родитель) Тогда
		
		Если ТекДанные.Зарегистрирован = Истина Тогда
			ОбработкаОтвета = Новый ОписаниеОповещения("ПослеОтветаНаВопросОбОтменеРегистрации", ЭтотОбъект);
			ПоказатьВопрос(ОбработкаОтвета,
							Получить("РегистрацияПакетовИО_ХотитеОтменитьРегистрациюФайлаИУдалитьЕго"),
							РежимДиалогаВопрос.ДаНет
						);
		Иначе
			УдалитьТекущийФайлОбменаНепосредственно();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопросОбОтменеРегистрации(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		УдалитьТекущийФайлОбменаНепосредственно();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьТекущийФайлОбменаНепосредственно()
	
	ТекДанные = Элементы.ДеревоСформированныеФайлы.ТекущиеДанные;
	
	Ответ = УдалитьФайлОбмена_Сервер(ТекДанные.СсылкаФайл, ТекДанные.Прикреплен, ТекДанные.Зарегистрирован, ТекДанные.Входящий);
	
	Если Ответ Тогда
		Ид = ДеревоСформированныеФайлы.ПолучитьЭлементы().Индекс(ТекДанные);
		ДеревоСформированныеФайлы.ПолучитьЭлементы().Удалить(Ид);
	КонецЕсли;
		
КонецПроцедуры


