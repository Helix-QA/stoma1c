// Функция, возвращает источник записи по имени, создает в случае отсутствия.
//
Функция ПолучитьИсточникЗаписиПоИмени(ИсточникЗаписи)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ИсточникиЗаписей.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ИсточникиЗаписей КАК ИсточникиЗаписей
	|ГДЕ
	|	ИсточникиЗаписей.Наименование = &Наименование");
	
	Запрос.УстановитьПараметр("Наименование", ИсточникЗаписи);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Выборка.Ссылка;
		
	Иначе
		
		НовыйЭлемент = Справочники.ИсточникиЗаписей.СоздатьЭлемент();
		НовыйЭлемент.Наименование = ИсточникЗаписи;
		
		Попытка
			НовыйЭлемент.Записать();
		Исключение
		КонецПопытки;
		
		Возврат НовыйЭлемент.Ссылка;
		
	КонецЕсли;
	
КонецФункции

