	КонецЕсли;
	
	СтрокаДаных = ТаблицаЦенНоменклатуры.НайтиПоИдентификатору(Сред(Элемент.Имя, 13));
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Номенклатура"  , Объект.Ссылка);
	СтруктураПараметров.Вставить("ВидЦен"        , СтрокаДаных.ВидЦен);
	СтруктураПараметров.Вставить("Упаковка"      , СтрокаДаных.Упаковка);
	СтруктураПараметров.Вставить("ДеньНедели"    , СтрокаДаных.ДеньНедели);
	СтруктураПараметров.Вставить("ВремяНачала"   , СтрокаДаных.ВремяНачала);
	СтруктураПараметров.Вставить("ВремяОкончания", СтрокаДаных.ВремяОкончания);
	
	ПараметрыФормы = Новый Структура("Отбор, Видимость", СтруктураПараметров, Ложь);	
	ОткрытьФорму("РегистрСведений.ЦеныНоменклатуры.ФормаСписка", ПараметрыФормы,,,,, Новый ОписаниеОповещения("ИсторияИзмененияЦеныНажатиеЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

