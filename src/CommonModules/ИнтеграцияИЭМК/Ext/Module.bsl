
#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиРегламентныхЗаданий

// Обработчик регламентного задания "ОбновлениеДанныхИЭМК"
//
Процедура ОбновлениеДанныхИЭМК() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);  
	
	Если Не ЗначениеЗаполнено(ВнешняяСистема) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	guid = ПараметрыВнешнейСистемы.guid;
	idLPU = ПараметрыВнешнейСистемы.idLPU;
	Демо = ПараметрыВнешнейСистемы.РаботаВРежимеДемо;
	
	Если Не ЗначениеЗаполнено(guid) Или Не ЗначениеЗаполнено(idLPU) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЖурналОбменаИЭМК.Объект КАК Объект,
	|	ЖурналОбменаИЭМК.ОтветИЭМК КАК ОтветИЭМК,
	|	ЖурналОбменаИЭМК.КодОтвета КАК КодОтвета,
	|	ЖурналОбменаИЭМК.УидВИЭМК КАК УидВИЭМК,
	|	ЖурналОбменаИЭМК.УИД КАК УИД,
	|	ЖурналОбменаИЭМК.КоличествоПопыток КАК КоличествоПопыток,
	|	ЖурналОбменаИЭМК.ДатаОтправки КАК ДатаОтправки
	|ИЗ
	|	РегистрСведений.ЖурналОбменаИЭМК КАК ЖурналОбменаИЭМК
	|ГДЕ
	|	ЖурналОбменаИЭМК.КодОтвета <> 200
	|   И ЖурналОбменаИЭМК.КоличествоПопыток < 3";
	
	Результат = Запрос.Выполнить().Выбрать();	
	
	Пока Результат.Следующий() Цикл
		
		Если ТипЗнч(Результат.Объект) = Тип("СправочникСсылка.Контрагенты") Тогда
			СоздатьПациентаВИЭМК(Результат.Объект, guid, idLPU, Результат.КоличествоПопыток, Результат.УидВИЭМК, Демо)
		Иначе 
			СоздатьПриемВИЭМК(Результат.Объект, guid, idLPU, Результат.КоличествоПопыток, Результат.УидВИЭМК, Демо)	
		КонецЕсли;
		
	КонецЦикла;
	

КонецПроцедуры        

#КонецОбласти 

