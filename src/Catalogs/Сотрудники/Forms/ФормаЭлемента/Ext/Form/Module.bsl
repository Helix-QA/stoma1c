// Процедура - Заполнить журналы приемов сотрудника.
//
Процедура ЗаполнитьЖурналыПриемовСотрудника(ПриЗапуске = Истина)
			
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	Для Каждого СтрокаТЧ Из ДоступныеСтруктурныеЕдиницы Цикл 
		МассивВыбранныхСтруктурныхЕдиниц.Добавить(СтрокаТЧ.СтруктурнаяЕдиница);
	КонецЦикла;
	
	Если ПриЗапуске = Истина Тогда
		
		ДоступныеЖурналыПриемов.Очистить();
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СотрудникиДоступныеСтруктурныеЕдиницыЖурналаЗаписи.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	СтруктурныеЕдиницы.ПометкаУдаления КАК ПометкаУдаления
		|ИЗ
		|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницыЖурналаЗаписи КАК СотрудникиДоступныеСтруктурныеЕдиницыЖурналаЗаписи
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|		ПО СотрудникиДоступныеСтруктурныеЕдиницыЖурналаЗаписи.СтруктурнаяЕдиница = СтруктурныеЕдиницы.Ссылка
		|ГДЕ
		|	СотрудникиДоступныеСтруктурныеЕдиницыЖурналаЗаписи.Ссылка = &ТекущийСотрудник";
		
		Запрос.УстановитьПараметр("ТекущийСотрудник", Объект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			НоваяСтрока 					= ДоступныеЖурналыПриемов.Добавить();
			НоваяСтрока.СтруктурнаяЕдиница  = Выборка.СтруктурнаяЕдиница;
