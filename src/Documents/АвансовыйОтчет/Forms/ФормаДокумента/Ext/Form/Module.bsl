 &НаКлиенте
// Процедура, обработчик события "ПриИзменении" поле ввода "Номенклатура"
// 
Процедура ЗапасыНоменклатураПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Запасы.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("Номенклатура", 		ТекущаяСтрока.Номенклатура);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);
	СтруктураДанные.Вставить("Упаковка", 			ТекущаяСтрока.Упаковка);
	
	СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	ТекущаяСтрока.Упаковка = СтруктураДанные.Упаковка;
	ТекущаяСтрока.Цена = СтруктураДанные.Цена; 
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.КоличествоУпаковок) Тогда
		ТекущаяСтрока.КоличествоУпаковок = 1;
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(ТекущаяСтрока);
	
	РассчитатьСуммуВСтрокеТабличнойЧасти(ТекущаяСтрока); 
	
	ТекущаяСтрока.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущаяСтрока.Номенклатура, "ИспользоватьПартии");
	
КонецПроцедуры

