// Функция - Sbp GET
//
// Параметры:
//  Запрос	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция sbpGET(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	api_key = Запрос.ПараметрыURL["apikey"];
	
	ВнешняяСистема    = Неопределено;
	СообщениеОбОшибке = ПроверитьКлючПриложения(api_key, ВнешняяСистема); 
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда		
		Возврат ПолучитьHTTPОтвет(СообщениеОбОшибке);
	КонецЕсли;
	
	ПараметрыЗапроса = Запрос.ПараметрыЗапроса;
	
	method			= ПараметрыЗапроса.Получить("method");
  	acquiring_id	= ПараметрыЗапроса.Получить("acquiring_id");
			
	Если method = "redirect_sbp" Тогда
		
		Ответ1с = api_v1.redirect_sbp(acquiring_id);
		
		HTTPОтвет = Новый HTTPСервисОтвет(200);
		HTTPОтвет.УстановитьТелоИзСтроки(Ответ1с);
		HTTPОтвет.Заголовки["Content-Type"] = "text/html";
		
		Возврат HTTPОтвет; 
		
	КонецЕсли;
	
	HTTPОтвет = Новый HTTPСервисОтвет(200);
	HTTPОтвет.УстановитьТелоИзСтроки("OK");
	HTTPОтвет.Заголовки["Content-Type"] = "text"; 
	Возврат HTTPОтвет;
	
КонецФункции

