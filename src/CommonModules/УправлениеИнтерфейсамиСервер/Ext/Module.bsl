	МассивЦветов.Добавить(Новый Цвет(255, 219, 219));
	МассивЦветов.Добавить(Новый Цвет(255, 200, 200));
	МассивЦветов.Добавить(Новый Цвет(255, 143, 146));
	МассивЦветов.Добавить(Новый Цвет(214, 234, 255));
	МассивЦветов.Добавить(Новый Цвет(193, 224, 255));
	МассивЦветов.Добавить(Новый Цвет(152, 203, 255));
	МассивЦветов.Добавить(Новый Цвет(235, 255, 177));
	МассивЦветов.Добавить(Новый Цвет(222, 255, 129));
	МассивЦветов.Добавить(Новый Цвет(135, 242, 192));
