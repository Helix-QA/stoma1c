// Функция, выполняет проверку на дубли клиента.
//
Функция ПроверитьНаДублированиеКлиента()
	
	МассивКлиентов = Новый Массив;
	
	Для Каждого СтрокаКИ Из ЭтаФорма.КонтактнаяИнформация Цикл
		
		Если ЗначениеЗаполнено(Объект.ОсновнойКлиент) Тогда 
			ДублиКлиентов = Справочники.Контрагенты.ПроверитьНаДублированиеКлиентаКИ(Объект.ОсновнойКлиент, СтрокаКИ.Тип, СтрокаКИ.Представление);
		Иначе 	
			ДублиКлиентов = Справочники.Контрагенты.ПроверитьНаДублированиеКлиентаКИ(Неопределено, СтрокаКИ.Тип, СтрокаКИ.Представление);
		КонецЕсли;
	
		Если ЗначениеЗаполнено(ДублиКлиентов) Тогда
			ОбщегоНазначенияСтоматология.ДобавитьВМассив(МассивКлиентов, ДублиКлиентов, Истина);
		КонецЕсли;
		
	КонецЦикла;
		
	Возврат МассивКлиентов;

КонецФункции
	
