// Функция - Текущий пользователь имеет право на работу с смс сервисами
// 
// Возвращаемое значение:
//   - 
// 
Функция ТекущийПользовательИмеетПравоНаРаботуССмсСервисами()
	
	РольПользователя = ПараметрыСеанса.ТекущийПользователь.РольПользователя;
	
	Если РольПользователя = Перечисления.РольПользователя.АдминистраторБазыДанных
		ИЛИ РольПользователя = Перечисления.РольПользователя.Руководитель
		ИЛИ РольПользователя = Перечисления.РольПользователя.Бухгалтер Тогда
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции

// Процедура выполняет операции проверки стутса регистрационной 
// анкеты при запуске системы. 
функция ПроверитьНеобходимостьОповещенияПользователяОСтатусеАнкеты() Экспорт
	
	Ответ = Новый Структура("ОжиданиеПодтвержденияАнкеты,СтатусАнкетыИзмен,СтатусАнкетыОписание");
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		
		Возврат Ответ;
		
	КонецЕсли;

	// Операция доступна только для пользователей с полными правами
	Если НЕ ПользовательИмеетПравоНаРаботуСличнымКабинетом() Тогда
		
		Возврат Ответ;
		
	КонецЕсли;
	
	Попытка
		
		ДанныеАнкеты = ПолучитьДанныеРегистрационнойАнкеты();
		
		Если ДанныеАнкеты <> Неопределено Тогда
			
			ПродуктРегистрационныйНомер            = Неопределено;
			РегистрацияПринята                     = Неопределено;
			ИдентификаторПользователя              = Неопределено;
			РегистрацияОповещениеОСтатусеВыполнено = Неопределено;
			
			ДанныеАнкеты.Свойство("ПродуктРегистрационныйНомер"              ,ПродуктРегистрационныйНомер);
			ДанныеАнкеты.Свойство("РегистрацияПринята"                       ,РегистрацияПринята);
			ДанныеАнкеты.Свойство("РегистрацияОтправитель"                   ,ИдентификаторПользователя);
			ДанныеАнкеты.Свойство("РегистрацияОповещениеОСтатусеВыполнено"   ,РегистрацияОповещениеОСтатусеВыполнено);
			
			Ответ.ОжиданиеПодтвержденияАнкеты = НЕ РегистрацияОповещениеОСтатусеВыполнено = Истина;
			
			Если Ответ.ОжиданиеПодтвержденияАнкеты = Ложь Тогда
				
				Возврат Ответ;
				
			КонецЕсли;

			// Выполнять операцию только если совпадает текущий пользователь и пользователь 
			// зарегистрировавший анкету
			Если ИдентификаторПользователя = Неопределено 
				ИЛИ НЕ ПараметрыСеанса.ТекущийПользователь = Справочники.Сотрудники.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторПользователя)) Тогда
				
				Ответ.ОжиданиеПодтвержденияАнкеты = Ложь;
				Возврат Ответ;
				
			КонецЕсли;
			
			// Если анкета зарегистрирована, но не подтверждена
			Если РегистрацияПринята = Истина 
				И НЕ РегистрацияОповещениеОСтатусеВыполнено = Истина Тогда
				
				// Получаем статус анкеты на данный момент
				ОписаниеСтатуса = ДанныеПоСостояниюАнкетыПродукта(ПродуктРегистрационныйНомер);
				
				Если ОписаниеСтатуса.СтатусРегистрацииКод >= 303 
					И ОписаниеСтатуса.СтатусРегистрацииКод <= 306 Тогда					
										
					Ответ.СтатусАнкетыИзмен    = Истина;
					Ответ.СтатусАнкетыОписание = ОписаниеСтатуса.СтатусРегистрацииОписание;
					
				КонецЕсли;
								
			Иначе
				
				Ответ.ОжиданиеПодтвержденияАнкеты = Ложь;
				
			КонецЕсли;
			
		Иначе
			
			Ответ.ОжиданиеПодтвержденияАнкеты = Истина;
			
		КонецЕсли;
		
	Исключение
		
		пОписаниеОшибки = ОписаниеОшибки();
		// Запись в журнал регистрации
	    ЗаписьЖурналаРегистрации("Web-сервис регистрация анкет", УровеньЖурналаРегистрации.Ошибка, , , "Вызов функции>>ПриНачалеРаботыСистемы" + Символы.ПС + "Ошибка: " + пОписаниеОшибки);

	КонецПопытки;
	
	Возврат Ответ;

КонецФункции

// Проверить необходимость оповещения пользователя при отсутствии регистрации программного продукта
Функция ПроверитьНеобходимостьОповещенияОРегистрацииПрограммногоПродукта() Экспорт	
	
	ОповеститьПользователя = Ложь;
	// Операция доступна только для пользователей с полными правами
	Если НЕ ПользовательИмеетПравоНаРаботуСличнымКабинетом() Тогда
		
		Возврат ОповеститьПользователя;
		
	КонецЕсли;
			
	// анкета не зарегистрирована
	ДанныеАнкеты = ПолучитьДанныеРегистрационнойАнкеты();
	
	Если ДанныеАнкеты = Неопределено 
		ИЛИ ДанныеАнкеты.Свойство("РегистрацияПринята") = Ложь
		ИЛИ НЕ ДанныеАнкеты.РегистрацияПринята = Истина Тогда
		
		ОповеститьПользователя = Истина;
		
	КонецЕсли;	
	
	Возврат ОповеститьПользователя;
	
КонецФункции

