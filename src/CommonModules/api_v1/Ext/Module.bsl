		Возврат "Не найдена группа онлайн продажи";
	ИначеЕсли КодОшибки = 1118 Тогда
		Возврат "Строка поиска передана неверно";
	ИначеЕсли КодОшибки = 1119 Тогда
		Возврат "Строка поиска должна содержать хотя бы 3 символа";
	ИначеЕсли КодОшибки = 1120 Тогда
		Возврат "Не удалось отправить сообщение в мессенджер с кодом подтверждения по причине: " + ДополнительноеОписание;
	ИначеЕсли КодОшибки = 1121 Тогда
		Возврат "Неверный тип внешней системы.";
	ИначеЕсли КодОшибки = 1122 Тогда
		Возврат "Сумма визита больше, чем переданная сумма оплаты";
	ИначеЕсли КодОшибки = 1123 Тогда
		Возврат "Визит не требует предоплаты";
	ИначеЕсли КодОшибки = 1124 Тогда
		Возврат "Бонусный счет не найден";
	ИначеЕсли КодОшибки = 1125 Тогда
		Возврат "Передан неверный визит";
	ИначеЕсли КодОшибки = 1126 Тогда
		Возврат "Для использования предоплаты услуг необходимо включить соотвествующую настройку в структурной единице";
	ИначеЕсли КодОшибки = 1127 Тогда
		Возврат "Ошибка при записи в регистр Рекламные данные " + ДополнительноеОписание;
	ИначеЕсли КодОшибки = 1128 Тогда
		Возврат "Не удалось отправить письмо на почту с кодом подтверждения по причине: " + ДополнительноеОписание;
	ИначеЕсли КодОшибки = 1129 Тогда
		Возврат "Не найдено заказов по данному id";
	ИначеЕсли КодОшибки = 1130 Тогда
		Возврат "Не найдена причина записи";
	ИначеЕсли КодОшибки = 1131 Тогда
		Возврат "На данное время у сотрудника запланирован приём";						
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

// Функция, преобразует строку в дату.
//
Функция ПолучитьДату(СтроковаяДата)
	
	Попытка
		
		СтроковаяДата = СтрЗаменить(СтроковаяДата , "-","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата , ":","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата , "T","");
		СтроковаяДата = СтроковаяДата + "00";
		
		Возврат Дата(СтроковаяДата);
		
	Исключение
		Возврат Неопределено;		
	КонецПопытки;
	
КонецФункции

// Функция возвращает смены сотрудников, минимальную длительность услуги сотрудника
//
Функция ПолучитьГрафикРаботыСотрудников(МассивСотрудников,
										СтруктурнаяЕдиница,
										ДатаСреза = Неопределено,
										НачалоПериода = Неопределено,
										КонецПериода = Неопределено)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ДатаВремяОкончания
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|ГДЕ
	|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВремяРаботыСотрудниковПлан.Сотрудник В(&МассивСотрудников)
	|	И &УсловиеВремяСмены
	|	И &УсловиеМассивСотрудников
	|
	|СГРУППИРОВАТЬ ПО
	|	ВремяРаботыСотрудниковПлан.Сотрудник,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания");	
	
	Запрос.УстановитьПараметр("МассивСотрудников" , МассивСотрудников);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза"		  , ?(ЗначениеЗаполнено(ДатаСреза), ДатаСреза, ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("НачалоПериода"     , НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода"      , КонецПериода);
	
	
	Если ЗначениеЗаполнено(НачалоПериода)
		И ЗначениеЗаполнено(КонецПериода) Тогда
		
		УсловиеВремяСмены = "И ((ВремяРаботыСотрудниковПлан.ДатаВремяНачала >= &НачалоПериода
						    |И ВремяРаботыСотрудниковПлан.ДатаВремяНачала < &КонецПериода)
						    |ИЛИ (ВремяРаботыСотрудниковПлан.ДатаВремяОкончания > &НачалоПериода
						    |И ВремяРаботыСотрудниковПлан.ДатаВремяОкончания <= &КонецПериода)
							|ИЛИ (ВремяРаботыСотрудниковПлан.ДатаВремяНачала <= &НачалоПериода
						    |И ВремяРаботыСотрудниковПлан.ДатаВремяОкончания >= &КонецПериода))";
	Иначе
		
		УсловиеВремяСмены = "И ВремяРаботыСотрудниковПлан.ДатаВремяОкончания > &ДатаСреза"
			+ ?(ЗначениеЗаполнено(ДатаСреза), " И ВремяРаботыСотрудниковПлан.ДатаВремяНачала <= &ДатаСреза", "");
		
	КонецЕсли;
	Запрос.Текст             = СтрЗаменить(Запрос.Текст, "И &УсловиеВремяСмены", УсловиеВремяСмены);
	
	УсловиеМассивСотрудников = ?(ЗначениеЗаполнено(МассивСотрудников), "И ВремяРаботыСотрудниковПлан.Сотрудник В (&МассивСотрудников)", "");
	Запрос.Текст             = СтрЗаменить(Запрос.Текст, "И &УсловиеМассивСотрудников", УсловиеМассивСотрудников);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

