// Обработчик начала выбора дня проведения занятия
// 
Процедура ПолеДень_НачалоВыбора(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ИдСтрокиДанных = ИдентификаторСтрокиДанныхПоИменеиЭлемента(Элемент.Имя);
	СтрокаДанных   = ВремяПланирования.НайтиПоИдентификатору(ИдСтрокиДанных);
	
	НачалоПериода = ПериодЗаполнения.ДатаНачала;
	Если НачалоПериода = '00010101' тогда
		НачалоПериода = ФункцииОтчетовКлиентСервер.НачалоПериодаОтчета("Перечисление.ДоступныеПериодыОтчета.День", ОбщегоНазначенияКлиент.ДатаСеанса());
	КонецЕсли;
	
	ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День");
	
	// Выбор периода из выпадающего списка
	Оповещение = Новый ОписаниеОповещения("ПолеДень_КонецВыбораОповещение", ЭтаФорма, Новый Структура("ВидПериода,СтрокаДанных", ВидПериода, СтрокаДанных));
	ВыбратьПериодИзВыпадающегоСписка(Элемент, ВидПериода, НачалоПериода, ПериодЗаполнения.Вариант, Неопределено, Оповещение);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Поле день конец выбора оповещение
// 
Процедура ПолеДень_КонецВыбораОповещение(РезультатВыбора, ДопПараметры) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяДата = Неопределено;
	Если ТипЗнч(РезультатВыбора.Значение) = Тип("ВариантСтандартногоПериода") Тогда
		Если РезультатВыбора.Значение = ПредопределенноеЗначение("ВариантСтандартногоПериода.Сегодня") Тогда
			ВыбраннаяДата = ТекущаяДата();
		ИначеЕсли РезультатВыбора.Значение = ПредопределенноеЗначение("ВариантСтандартногоПериода.Вчера") Тогда
			ВыбраннаяДата = ТекущаяДата() - 86400;
		ИначеЕсли РезультатВыбора.Значение = ПредопределенноеЗначение("ВариантСтандартногоПериода.Завтра") Тогда
			ВыбраннаяДата = ТекущаяДата() + 86400;
		КонецЕсли;
	Иначе
		ВыбраннаяДата = ФункцииОтчетовКлиентСервер.НачалоПериодаОтчета(ДопПараметры.ВидПериода, РезультатВыбора.Значение);
	КонецЕсли;
	
	// Проверям входит ли день в рабочие дни
	Если ПроверитьВхождениеПериодаВРабочиеДни(ВыбраннаяДата) = Ложь Тогда
		ПоказатьПредупреждение(,"Выбранный день является не рабочим");
		Возврат;
	КонецЕсли;	
	
	ДопПараметры.СтрокаДанных.ДатаПредст     = ?(ПустаяСтрока(РезультатВыбора.Представление), Строка(РезультатВыбора.Значение), РезультатВыбора.Представление);
	ДопПараметры.СтрокаДанных.Дата           = ВыбраннаяДата;
	                                         
	// Если исп. циклический режим заполнения(смены)
	// при смене даты первого дня необходимо сместить следующие дни в цикле
	Если РежимПланированияРабочихДней = 1 Тогда
		Для А = 1 По ВремяПланирования.Количество() -1 Цикл
			ВремяПланирования[А].Дата       = ВремяПланирования[А - 1].Дата + 86400;
			ВремяПланирования[А].ДатаПредст =  Формат(ВремяПланирования[А].Дата,"ДФ='dd MMMM, dddd'");
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик события начала выбора времени занятия
// 
Процедура ПолеВремя_НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИменеиЭлемента(Элемент.Имя);
