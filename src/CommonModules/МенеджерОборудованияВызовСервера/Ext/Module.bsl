// Функция - Получить НДСПри взносе на лицевой счет
//
// Параметры:
//  Организация	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНДСПриВзносеНаЛицевойСчет(Организация) Экспорт
	
	Если ЗначениеЗаполнено(Организация.СистемаНалогообложенияДляАвансов) Тогда 
		
		Возврат ?(ЗначениеЗаполнено(Организация.СтавкаНДСДляАвансов), Организация.СтавкаНДСДляАвансов, Перечисления.СтавкиНДС.БезНДС);
		
	ИначеЕсли Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая
		И ЗначениеЗаполнено(Организация.СтавкаНДС) Тогда
		
		Возврат Организация.СтавкаНДС;
		
	Иначе
		Возврат Перечисления.СтавкиНДС.БезНДС;
		
	КонецЕсли;
		
КонецФункции

// Функция - Код системы налогообложения
//
// Параметры:
//  Организация	 - 	 - 
//  ВидНалога	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция КодСистемыНалогообложения(Организация, ВидНалога) Экспорт
	
	Если ТипЗнч(ВидНалога) = Тип("ПеречислениеСсылка.ВидыНалогов") Тогда
		
		Если Организация = Неопределено Тогда
			Организация = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
		КонецЕсли;
		
		Если ВидНалога = Перечисления.ВидыНалогов.ОСН Тогда		
			Возврат 0;
		ИначеЕсли ВидНалога = Перечисления.ВидыНалогов.УСНДоход Тогда
			Возврат 1;
		ИначеЕсли ВидНалога = Перечисления.ВидыНалогов.УСНДоходРасход Тогда
			Возврат 2;
		ИначеЕсли ВидНалога = Перечисления.ВидыНалогов.ЕНВД Тогда
			Возврат 3;
		ИначеЕсли ВидНалога = Перечисления.ВидыНалогов.ЕСХН Тогда
			Возврат 4;
		ИначеЕсли ВидНалога = Перечисления.ВидыНалогов.ПСН Тогда
			Возврат 5;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Организация.СистемаНалогообложенияДляТоваров) Тогда
			Возврат 0;
		Иначе
			Если Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда
				Возврат 0;
			ИначеЕсли Организация.ОбъектНалогообложения = Перечисления.ОбъектыНалогообложенияПоУСН.Доходы Тогда
				Возврат 1;
			Иначе
				Возврат 2;
			КонецЕсли;	
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ВидНалога) = Тип("ПеречислениеСсылка.ТипыСистемНалогообложенияККТ") Тогда	
		
		Если ВидНалога = Перечисления.ТипыСистемНалогообложенияККТ.ЕНВД Тогда
			Возврат 3;
		ИначеЕсли ВидНалога = Перечисления.ТипыСистемНалогообложенияККТ.ЕСН Тогда
			Возврат 4;
		ИначеЕсли ВидНалога = Перечисления.ТипыСистемНалогообложенияККТ.Патент Тогда
			Возврат 5;
		ИначеЕсли ВидНалога = Перечисления.ТипыСистемНалогообложенияККТ.ОСН Тогда
			Возврат 0;
		ИначеЕсли ВидНалога = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоход Тогда
			Возврат 1;
		ИначеЕсли ВидНалога = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоходРасход Тогда
			Возврат 2;
		КонецЕсли;
		
	Иначе
		
		Если НЕ ЗначениеЗаполнено(Организация.СистемаНалогообложенияДляТоваров) Тогда
			Возврат 0;
		Иначе    
			Если Организация.СистемаНалогообложенияДляТоваров = Перечисления.ТипыСистемНалогообложенияККТ.ОСН Тогда
				Возврат 0;
			ИначеЕсли Организация.СистемаНалогообложенияДляТоваров = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоход Тогда
				Возврат 1;
			ИначеЕсли Организация.СистемаНалогообложенияДляТоваров = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоходРасход Тогда
				Возврат 2;
			ИначеЕсли Организация.СистемаНалогообложенияДляТоваров = Перечисления.ТипыСистемНалогообложенияККТ.ЕНВД Тогда
				Возврат 3;
			ИначеЕсли Организация.СистемаНалогообложенияДляТоваров = Перечисления.ТипыСистемНалогообложенияККТ.ЕСН Тогда
				Возврат 4;
			ИначеЕсли Организация.СистемаНалогообложенияДляТоваров = Перечисления.ТипыСистемНалогообложенияККТ.Патент Тогда
				Возврат 5;
			КонецЕсли;			
				
		КонецЕсли;

	КонецЕсли;
	
КонецФункции

// Функция, возвращает ставку НДС для ККТ.
//
Функция ПолучитьСтавкуНДСККТ(СтавкаНДС) Экспорт
	
	Если СтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда
		Возврат 10;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда 		
		Возврат 18;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда 		
		Возврат 20;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
		Возврат 0;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
		Возврат Неопределено;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;       
	
КонецФункции

// Функция - Получить тип оплаты по типу денежных средств
//
// Параметры:
//  ЭтоККТ			 - 	 - 
//  ТипДенСредств	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТипОплатыПоТипуДенежныхСредств(ЭтоККТ, ТипДенСредств) Экспорт
	
	Если ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные") Тогда
		
		ТипОплаты = Перечисления.ТипыОплатыККТ.Наличные;			
		
	ИначеЕсли ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта") 
		// ИЛИ ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.КорпоративныйДоговор")
		ИЛИ ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные") Тогда
		
		ТипОплаты = Перечисления.ТипыОплатыККТ.Электронно;			
		
	ИначеЕсли ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет")
		ИЛИ ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Аванс") 
		ИЛИ ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат") Тогда
		
		ТипОплаты = Перечисления.ТипыОплатыККТ.Предоплата;
		
	ИначеЕсли ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыОплатыККТ.Постоплата") Тогда
		
		ТипОплаты = Перечисления.ТипыОплатыККТ.Постоплата;
		
	ИначеЕсли ТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыОплатыККТ.ВстречноеПредоставление") Тогда
		
		ТипОплаты = Перечисления.ТипыОплатыККТ.ВстречноеПредоставление;    
		
	ИначеЕсли ТипЗнч(ТипДенСредств) = Тип("ПеречислениеСсылка.ТипыОплатыККТ") Тогда
		
		ТипОплаты = ТипДенСредств;
		
	КонецЕсли;				
	
	Возврат ТипОплаты;
	
КонецФункции

// Функция, возвращает данные для пробития чека на ФР.
//
Функция ПодготовитьДанныеДляПробитияЧека(ПараметрыЧека) Экспорт
	
	РезультатОперации  = Новый Структура("Результат, ОписаниеОшибки", Истина, "");
	Касса              = ?(ПараметрыЧека.Свойство("Касса"), ПараметрыЧека.Касса, Неопределено);
		
	Если Касса = Неопределено Тогда		
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Для данной операции необходимо указать кассу!'; en = 'For this operation, you must specify the cashbox!'");
		Возврат РезультатОперации;		
		
	КонецЕсли;
	
	// Если в кассе не используется оборудование отменить операцию.
	Если Касса.ИспользоватьБезПодключенияОборудования Тогда
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Касса: %1 используется без подключения оборудования!';en= 'Cashbox: %1 is used without connecting equipment!'"), Касса);
		Возврат РезультатОперации;
		
	КонецЕсли;	
	
	Если Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ Тогда
		
	     Возврат ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека);

	Иначе
		
		Возврат ПодготовитьДанныеДляПробитияФискальногоИНеФискальногоЧекаФР(ПараметрыЧека);		
		
	КонецЕсли;
			
КонецФункции

// Функция - Подготовить данные для пробития не фискального чека
//
// Параметры:
//  ПараметрыЧека	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПодготовитьДанныеДляПробитияНеФискальногоЧека(ПараметрыЧека) Экспорт
	
	РезультатОперации                  = Новый Структура("Результат, ОписаниеОшибки, Параметры", Истина, "", Новый Структура());
	
	ЧекТип                             = ?(ПараметрыЧека.Свойство("ТипЧека")	  , ПараметрыЧека.ТипЧека, 0); // 0 - приход, 1 - возврат
	Касса                              = ?(ПараметрыЧека.Свойство("Касса")        , ПараметрыЧека.Касса, Неопределено);
	
	МассивНефискальныхПараметровОплаты = Новый Массив;
	СуммаНЕФискальныхТиповОплат        = 0;
	СуммаЧекаБезСкидок                 = 0;
	СуммаЧекаСоСкидками                = 0;
	ПроизошлоИсключение                = Ложь;

	Если Касса = Неопределено Тогда		
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Для данной операции необходимо указать кассу!'; en = 'For this operation, you must specify the cashbox!'");
		Возврат РезультатОперации;		
		
	КонецЕсли;
	
	// Если в кассе не используется оборудование отменить операцию.
	Если Касса.ИспользоватьБезПодключенияОборудования Тогда
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Касса: %1 используется без подключения оборудования!';en= 'Cashbox: %1 is used without connecting equipment!'"), Касса);
		Возврат РезультатОперации;
		
	КонецЕсли;		
		
	// Получаем общие параметры для пробития чека на ФР (ФИКСИРОВАННАЯ СТРУКТУРА).
	ОбщиеПараметры = ПолучитьОбщиеПараметрыПробитияЧека(ПараметрыЧека); 
	
	// Предварительная подготовка товаров и оплат.
	ОписаниеОшибки = "";
	Если Не СформироватьТаблицыТоваровИОплат(ПараметрыЧека, ОписаниеОшибки) Тогда
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = ОписаниеОшибки;
		Возврат РезультатОперации;
		
	КонецЕсли;
	
	// Разбиение фискальных и не фискальных видов оплаты.
	МассивПараметровОплаты = ПараметрыЧека.МассивПараметровОплаты;
	Для Каждого ЭлементМ ИЗ МассивПараметровОплаты Цикл		
		
		МассивНефискальныхПараметровОплаты.Добавить(ЭлементМ);
		СуммаНЕФискальныхТиповОплат = СуммаНЕФискальныхТиповОплат + ЭлементМ.Сумма;
		
	КонецЦикла;
	
	СуммаЧекаБезСкидок   = ПараметрыЧека.СуммаЧекаБезСкидок; 
	СуммаЧекаСоСкидками  = ПараметрыЧека.СуммаЧекаСоСкидками;
	МассивТоваров        = ПараметрыЧека.МассивПараметровТовары;
	
	ПараметрыПечатиЧека = Новый Структура();
	ПараметрыПечатиЧека.Вставить("ИспользоватьФР"        , Истина);
	ПараметрыПечатиЧека.Вставить("ШиринаЧекаФР"          , 32);
	ПараметрыПечатиЧека.Вставить("СтруктурнаяЕдиница"    , ПараметрыЧека.СтруктурнаяЕдиница);
	ПараметрыПечатиЧека.Вставить("Клиент"                , ПараметрыЧека.Клиент);
	ПараметрыПечатиЧека.Вставить("Дата"                  , ПараметрыЧека.Дата);
	ПараметрыПечатиЧека.Вставить("СуммаЧекаБезСкидок"    , СуммаЧекаБезСкидок);
	ПараметрыПечатиЧека.Вставить("СуммаЧекаСоСкидками"   , СуммаЧекаСоСкидками);
	ПараметрыПечатиЧека.Вставить("МассивПараметровТовары", МассивТоваров);
	ПараметрыПечатиЧека.Вставить("МассивПараметровОплаты", МассивНефискальныхПараметровОплаты);			
	
	ТекстНефискальноЧека = МенеджерОборудованияВызовСервера.ПолучитьПречекКассира(,ПараметрыПечатиЧека);
	
	РезультатОперации.Вставить("ДанныеЧека", ТекстНефискальноЧека);
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Подготовить данные для пробития фискального чека
//
// Параметры:
//  ПараметрыЧека	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПодготовитьДанныеДляПробитияФискальногоИНеФискальногоЧекаФР(ПараметрыЧека) Экспорт
	
	РезультатОперации                  = Новый Структура("Результат, ОписаниеОшибки", Истина, "");
	
	ЧекТип                             = ?(ПараметрыЧека.Свойство("ТипЧека")	  , ПараметрыЧека.ТипЧека, 0); // 0 - приход, 1 - возврат
	ЧекПризнакфискальности             = ?(ПараметрыЧека.Свойство("ЧекФискальный"), ПараметрыЧека.ЧекФискальный, Истина);	
	Касса                              = ?(ПараметрыЧека.Свойство("Касса")        , ПараметрыЧека.Касса, Неопределено);
	
	МассивфискальныхПараметровОплаты   = Новый Массив;
	МассивНефискальныхПараметровОплаты = Новый Массив;
	СуммаФискальныхТиповОплат          = 0;
	СуммаНЕФискальныхТиповОплат        = 0;
	СуммаЧекаБезСкидок                 = 0;
	СуммаЧекаСоСкидками                = 0;
	ПроизошлоИсключение                = Ложь;
	
	Если Касса = Неопределено Тогда
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Для данной операции необходимо указать кассу!'; en = 'For this operation, you must specify the cashbox!'");
		Возврат РезультатОперации;		
		
	КонецЕсли;
	
	// Если в кассе не используется оборудование отменить операцию.
	Если Касса.ИспользоватьБезПодключенияОборудования Тогда
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Касса: %1 используется без подключения оборудования!';en= 'Cashbox: %1 is used without connecting equipment!'"), Касса);
		Возврат РезультатОперации;
		
	КонецЕсли;	
	
	// Получаем общие параметры для пробития чека на ФР (ФИКСИРОВАННАЯ СТРУКТУРА).
	ОбщиеПараметры = ПолучитьОбщиеПараметрыПробитияЧека(ПараметрыЧека); 
	
	// Предварительная подготовка товаров и оплат.
	ОписаниеОшибки = "";
	Если Не СформироватьТаблицыТоваровИОплат(ПараметрыЧека, ОписаниеОшибки) Тогда
		
		РезультатОперации.Результат      = Ложь;
		РезультатОперации.ОписаниеОшибки = ОписаниеОшибки;
		Возврат РезультатОперации;
		
	КонецЕсли;
	
	// Разбиение фискальных и не фискальных видов оплаты.
	МассивПараметровОплаты = ПараметрыЧека.МассивПараметровОплаты;
	Для Каждого ЭлементМ ИЗ МассивПараметровОплаты Цикл
		
		Если ЧекПризнакфискальности  И ПолучитьПризнакФискальностиВидаОплатыПоКассе(ПараметрыЧека.Касса, ЭлементМ.ТипОплаты)  Тогда			
			
			МассивфискальныхПараметровОплаты.Добавить(ЭлементМ);		
			СуммаФискальныхТиповОплат = СуммаФискальныхТиповОплат + ЭлементМ.Сумма;
			
		Иначе	
			
			МассивНефискальныхПараметровОплаты.Добавить(ЭлементМ);
			СуммаНЕФискальныхТиповОплат = СуммаНЕФискальныхТиповОплат + ЭлементМ.Сумма;
			
		КонецЕсли;		
		
	КонецЦикла;
	
	Если СуммаФискальныхТиповОплат > 0 Тогда
		
		// Копируем основные параметры чека.
		ФискальныйЧек = Новый Структура(ОбщиеПараметры);
		ФискальныйЧек.ПозицииЧека  = Новый Массив;
		ФискальныйЧек.ТаблицаОплат = Новый Массив;
		
		// Если сумма фискальных видов оплат отличается от общей суммы чека проводим корректировку в стоимости товаров.
		Если ПараметрыЧека.СуммаЧекаСоСкидками > СуммаФискальныхТиповОплат Тогда
			
			СтруктураТоваров    = СформироватьФискальнуюТаблицуТоваров(ПараметрыЧека.МассивПараметровТовары, СуммаФискальныхТиповОплат);
			СуммаЧекаБезСкидок  = СтруктураТоваров.СуммаЧекаБезСкидок;
			СуммаЧекаСоСкидками = СтруктураТоваров.СуммаЧекаСоСкидками;
			МассивТоваров       = СтруктураТоваров.МассивТоваров;
			
		Иначе
			
			СуммаЧекаБезСкидок   = ПараметрыЧека.СуммаЧекаБезСкидок; 
			СуммаЧекаСоСкидками  = ПараметрыЧека.СуммаЧекаСоСкидками;
			МассивТоваров        = ПараметрыЧека.МассивПараметровТовары;			
			
		КонецЕсли; 			
		
		// Сохраняем массив для нефискальных видов оплаты.
		МассивФискальныхТоваров  = МассивТоваров;
		
		ДобавитьТоварыВОбщиеПараметрыЧека(ФискальныйЧек, МассивТоваров);
		ДобавитьОплатуВОбщиеПараметрыЧека(ФискальныйЧек, МассивфискальныхПараметровОплаты);		
		
		РезультатОперации.Вставить("ФискальныйЧек", ФискальныйЧек);
		
	КонецЕсли;
	
	Если СуммаНЕФискальныхТиповОплат > 0 Тогда
		
		// Если сумма НЕ фискальных видов оплат отличается от общей суммы чека проводим корректировку в стоимости товаров.
		Если ПараметрыЧека.СуммаЧекаСоСкидками > СуммаНЕФискальныхТиповОплат Тогда	
			СтруктураТоваров    = СформироватьНефискальнуюТаблицуТоваров(ПараметрыЧека.МассивПараметровТовары, МассивФискальныхТоваров, СуммаНЕФискальныхТиповОплат);
			СуммаЧекаБезСкидок  = СтруктураТоваров.СуммаЧекаБезСкидок;
			СуммаЧекаСоСкидками = СтруктураТоваров.СуммаЧекаСоСкидками;
			МассивТоваров       = СтруктураТоваров.МассивТоваров;			
		Иначе
			СуммаЧекаБезСкидок   = ПараметрыЧека.СуммаЧекаБезСкидок; 
			СуммаЧекаСоСкидками  = ПараметрыЧека.СуммаЧекаСоСкидками;
			МассивТоваров        = ПараметрыЧека.МассивПараметровТовары;
		КонецЕсли;
		
		ПараметрыПечатиЧека = Новый Структура();
		ПараметрыПечатиЧека.Вставить("ИспользоватьФР"        , Истина);
		ПараметрыПечатиЧека.Вставить("ШиринаЧекаФР"          , 32);
		ПараметрыПечатиЧека.Вставить("СтруктурнаяЕдиница"    , ПараметрыЧека.СтруктурнаяЕдиница);
		ПараметрыПечатиЧека.Вставить("Клиент"                , ПараметрыЧека.Клиент);
		ПараметрыПечатиЧека.Вставить("Дата"                  , ПараметрыЧека.Дата);
		ПараметрыПечатиЧека.Вставить("СуммаЧекаБезСкидок"    , СуммаЧекаБезСкидок);
		ПараметрыПечатиЧека.Вставить("СуммаЧекаСоСкидками"   , СуммаЧекаСоСкидками);
		ПараметрыПечатиЧека.Вставить("МассивПараметровТовары", МассивТоваров);
		ПараметрыПечатиЧека.Вставить("МассивПараметровОплаты", МассивНефискальныхПараметровОплаты);			
		
		ТекстНефискальноЧека = МенеджерОборудованияВызовСервера.ПолучитьПречекКассира(,ПараметрыПечатиЧека);
		
		РезультатОперации.Вставить("НефискальныйЧек", ТекстНефискальноЧека);
		
	КонецЕсли;	
	
	Возврат РезультатОперации;

КонецФункции

// Функция, формирует талицу товаров, на фискальную сумму.
//
Функция СформироватьФискальнуюТаблицуТоваров(МассивТоваров, СуммаФискальныхТиповОплат)
	
	СуммаЧекаБезСкидок   = 0;
	СуммаЧекаСоСкидками  = 0;	
	
	ВременныйМассивТоваров     = КопироватьМассивПарамтеровТоваров(МассивТоваров);	
	мСуммаФискальныхТиповОплат = СуммаФискальныхТиповОплат;
	
	Для НомерСтроки = 0 По ВременныйМассивТоваров.Количество() - 1 Цикл
		
		Если мСуммаФискальныхТиповОплат > 0 
			И мСуммаФискальныхТиповОплат > ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки Тогда
			
			мСуммаФискальныхТиповОплат = мСуммаФискальныхТиповОплат - ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки;						
			СуммаЧекаБезСкидок  = СуммаЧекаБезСкидок  + ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки;
			СуммаЧекаСоСкидками = СуммаЧекаСоСкидками + ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой;
			
		ИначеЕсли мСуммаФискальныхТиповОплат > 0 Тогда
			
			ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки = мСуммаФискальныхТиповОплат;
			ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой = мСуммаФискальныхТиповОплат;
			СуммаЧекаБезСкидок  = СуммаЧекаБезСкидок  + ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки;
			СуммаЧекаСоСкидками = СуммаЧекаСоСкидками + ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой;
			мСуммаФискальныхТиповОплат = 0;					
			
		Иначе
			
			ВременныйМассивТоваров.Удалить(НомерСтроки);
			Если НомерСтроки <= ВременныйМассивТоваров.Количество() - 1 Тогда
				НомерСтроки = НомерСтроки - 1;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЕсли;					
		
	КонецЦикла;  	
	
	Возврат Новый Структура("МассивТоваров, СуммаЧекаБезСкидок, СуммаЧекаСоСкидками", ВременныйМассивТоваров, СуммаЧекаБезСкидок, СуммаЧекаСоСкидками);
	
КонецФункции

// Функция, формирует таблицу товаров на нефискальную сумму.
//
Функция СформироватьНефискальнуюТаблицуТоваров(МассивТоваров, МассивФискальныхТоваров, СуммаНЕФискальныхТиповОплат)
		
	ВременныйМассивТоваров = КопироватьМассивПарамтеровТоваров(МассивТоваров);		
	
	СуммаЧекаБезСкидок  = 0;
	СуммаЧекаСоСкидками = 0;
	
	МассивФискальныхОплат = МассивФискальныхТоваров;
	
	Если ЗначениеЗаполнено(МассивТоваров) Тогда
		
		Для НомерСтроки = 0 По МассивФискальныхОплат.Количество() - 1 Цикл
			ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки = ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки - МассивФискальныхОплат[НомерСтроки].СтоимостьБезСкидки;
			ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой = ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой - МассивФискальныхОплат[НомерСтроки].СтоимостьСоСкидкой;						
		КонецЦикла;	


		
		// удаляем нулевые строки из массива
		НомерСтроки = 0;
		Пока НомерСтроки < ВременныйМассивТоваров.Количество() Цикл
			Если ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки = 0 Тогда					
				ВременныйМассивТоваров.Удалить(НомерСтроки);
			Иначе
				НомерСтроки = НомерСтроки + 1;
			КонецЕсли;
		КонецЦикла;  
		
	КонецЕсли;
	
	мСуммаНЕФискальныхТиповОплат = СуммаНЕФискальныхТиповОплат;
	Для НомерСтроки = 0 По ВременныйМассивТоваров.Количество() - 1 Цикл
		Если мСуммаНЕФискальныхТиповОплат > 0 и мСуммаНЕФискальныхТиповОплат > ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки Тогда

			мСуммаНЕФискальныхТиповОплат = мСуммаНЕФискальныхТиповОплат - ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки;						
			СуммаЧекаБезСкидок  = СуммаЧекаБезСкидок  + ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки;
			СуммаЧекаСоСкидками = СуммаЧекаСоСкидками + ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой;

		ИначеЕсли мСуммаНЕФискальныхТиповОплат > 0 Тогда

			ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки = мСуммаНЕФискальныхТиповОплат;
			ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой = мСуммаНЕФискальныхТиповОплат;
			СуммаЧекаБезСкидок  = СуммаЧекаБезСкидок  + ВременныйМассивТоваров[НомерСтроки].СтоимостьБезСкидки;
			СуммаЧекаСоСкидками = СуммаЧекаСоСкидками + ВременныйМассивТоваров[НомерСтроки].СтоимостьСоСкидкой;
			мСуммаНЕФискальныхТиповОплат = 0;					

		Иначе

			ВременныйМассивТоваров.Удалить(НомерСтроки);

			Если НомерСтроки <= ВременныйМассивТоваров.Количество() - 1 Тогда
				НомерСтроки = НомерСтроки - 1;
			Иначе
				Прервать;
			КонецЕсли;

		КонецЕсли;					

	КонецЦикла;  
	
	Возврат Новый Структура("МассивТоваров, СуммаЧекаБезСкидок, СуммаЧекаСоСкидками", ВременныйМассивТоваров, СуммаЧекаБезСкидок, СуммаЧекаСоСкидками);
	
КонецФункции

// Функция, копирует массив параметров чека
//
Функция КопироватьМассивПарамтеровТоваров(ИсходныйМассив)
	
	НовыйМассив = Новый Массив;
	Для Каждого ЭлементМ ИЗ ИсходныйМассив Цикл
		
		СтрДанных = ПустаяСтруктураСтрокиТоваровЧека();
		ЗаполнитьЗначенияСвойств(СтрДанных,ЭлементМ);
	    НовыйМассив.Добавить(СтрДанных);
		
	КонецЦикла;
	
	Возврат НовыйМассив;
	
КонецФункции

// Функция, возвращает структуру контактной информации.
//
Функция ПолучитьКонтактнуюИнформацию(Клиент, НормализоватьНомерТелефона = Истина, Касса = Неопределено) Экспорт
	
	EmailСтроки = Клиент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
	Email = Неопределено;
	Если EmailСтроки.Количество() > 0 Тогда
	  Email = EmailСтроки[0].АдресЭП;
	КонецЕсли;
	
	ТелефонСтроки = Клиент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
	НомерТелефона = Неопределено;
	Если ТелефонСтроки.Количество() > 0 Тогда
		
		НомерТелефона = ТелефонСтроки[0].НомерТелефона;
		
		Если НормализоватьНомерТелефона = Истина Тогда
			
			СписокПолей = Новый СписокЗначений;
			УправлениеКонтактнойИнформацией.ПреобразоватьНомерТелефона(НомерТелефона, СписокПолей, Касса); 
			Если Не ЗначениеЗаполнено(Касса) Тогда
				НомерТелефона = СписокПолей[1].Значение + СписокПолей[2].Значение;
			Иначе
				НомерТелефона = СписокПолей[0].Значение + СписокПолей[1].Значение + СписокПолей[2].Значение;
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат Новый Структура("Email, Телефон", Email, НомерТелефона);
	
КонецФункции

// Функция - Признак способа расчета при продаже или возврате членства, пакет услуг.
// 
Функция ПризнакСпособаРасчетаПриПродажеИлиВозвратеЧПУ(ЭтоОплатаКредита = Ложь) 
	
	Если ЭтоОплатаКредита Тогда
		Возврат Перечисления.ПризнакиСпособаРасчета.ОплатаКредита;
	КонецЕсли;
	
	Возврат Перечисления.ПризнакиСпособаРасчета.ПредоплатаПолная;
			
КонецФункции

// Функция возвращает по идентификатору наименование драйвера устройства.
//
Функция ПолучитьИмяДрайвераЭкземпляра(НаименованиеОбработчикаДрайвера) Экспорт

	Результат = "";

	Для каждого ИмяПеречисления Из Метаданные.Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ЗначенияПеречисления Цикл
		Если НаименованиеОбработчикаДрайвера = ИмяПеречисления.Синоним Тогда
			Результат = ИмяПеречисления.Имя;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Функция возвращает из переменной сеанса имя компьютера клиента.
//
Функция НайтиРабочиеМестаПоИмениКомпьютера(ИмяКомпьютера) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РабочиеМеста.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.РабочиеМеста КАК РабочиеМеста
	|ГДЕ
	|	(РабочиеМеста.Код = &Код
	|			ИЛИ РабочиеМеста.ИмяКомпьютера = &Код)
	|	И РабочиеМеста.ПометкаУдаления = ЛОЖЬ");

	Запрос.УстановитьПараметр("Код", ИмяКомпьютера);
	Выборка = Запрос.Выполнить().Выбрать();

	СписокКомпьютеров = Новый СписокЗначений();
	Пока Выборка.Следующий() Цикл
		СписокКомпьютеров.Добавить(Выборка.Ссылка);
	КонецЦикла;

	Возврат СписокКомпьютеров;

КонецФункции

// Функция возвращает макет слип чека по наименованию макета
//
Функция ПолучитьСлипЧек(ИмяМакета, ШиринаСлипЧека, Параметры) Экспорт

	Документ = Новый ТекстовыйДокумент();
	СлипЧек  = "";

	Макет    = Справочники.ПодключаемоеОборудование.ПолучитьМакет(ИмяМакета);
	Область  = Макет.ПолучитьОбласть("Чек" + ШиринаСлипЧека);

	Для Каждого Параметр Из Параметры Цикл
		Область.Параметры[Параметр.Ключ] = Параметр.Значение;
	КонецЦикла;

	Если Область <> Неопределено Тогда
		Документ.Вывести(Область);

		Для Индекс = 1 По Документ.КоличествоСтрок() Цикл
			СлипЧек = СлипЧек + Документ.ПолучитьСтроку(Индекс)
			        + ?(Индекс = Документ.КоличествоСтрок(), "", Символ(13) + Символ(10));
		КонецЦикла;
	КонецЕсли;

	Возврат СлипЧек;

КонецФункции

// Функция, устанавливет пробелы до и после указанных символов.
//  Параметры: 
//   СтрокаПоиска - тип "Строка", строка источник для поиска символов;
//   МассивСимволов - тип "Массив", содержит символы для поиска в строке.
//  Возвращаемое значение: 
//   ИсходнаяСтрока - тип "Строка", отредактированная строка. 
//
Функция ПоискСимволовПоСтроке(СтрокаПоиска, МассивСимволов)
	
	ИсходнаяСтрока  = "";
	Для Каждого СтрокаМассив ИЗ МассивСимволов Цикл
		Если Найти(СтрокаПоиска,СтрокаМассив) = 0 Тогда	
			Продолжить;
		КонецЕсли;
		
		Если ПустаяСтрока(ИсходнаяСтрока) Тогда
			ТекСтрока       = СтрЗаменить(СтрокаПоиска," ","");
		Иначе
			ТекСтрока = ИсходнаяСтрока;
		КонецЕсли;
		
		ПравЧастьСтроки = СтрокаМассив+" " + Сред(ТекСтрока,Найти(ТекСтрока, СтрокаМассив)+1);
		ЛевЧастьСтроки  = Сред(ТекСтрока,0,Найти(ТекСтрока, СтрокаМассив)-1) + " ";
		ИсходнаяСтрока =  ЛевЧастьСтроки + ПравЧастьСтроки;
		    		
	КонецЦикла;
	
	Возврат ?(ПустаяСтрока(ИсходнаяСтрока),СтрокаПоиска,ИсходнаяСтрока);
	
КонецФункции     

// Функция возвращает макет слип чека по наименованию макета
//
Функция ПолучитьПреЧекККТ(ПараметрыЧека, ШиринаПреЧека) Экспорт

	Документ = Новый ТекстовыйДокумент();
	ПреЧек  = "";

	Макет    = Справочники.ПодключаемоеОборудование.ПолучитьМакет("Пречек");
	Область  = Макет.ПолучитьОбласть("ЧекШапка" + ШиринаПреЧека);
	Документ.Вывести(Область);
	
	Область  = Макет.ПолучитьОбласть("ЧекЗаголовок" + ШиринаПреЧека);
	Область.Параметры.СтруктурнаяЕдиница  = ПараметрыЧека.Организация;
	Документ.Вывести(Область);
	
	Область  = Макет.ПолучитьОбласть("Дата");	
	Область.Параметры.Дата  = Формат(ТекущаяДатаСеанса(), "ДФ='dd.MM.yyyy hh:mm'");	
	Документ.Вывести(Область);
	
	Область  = Макет.ПолучитьОбласть("Кассир" + ШиринаПреЧека);	
	Область.Параметры.Кассир  = ПараметрыЧека.Кассир;	
	Документ.Вывести(Область);
	
	Область  = Макет.ПолучитьОбласть("ПустаяСтрока");	
	Документ.Вывести(Область);
	
	СуммаЧека = 0;
	Область  = Макет.ПолучитьОбласть("ЧекСтрока"+ШиринаПреЧека);
	ОбластьСкидки = Макет.ПолучитьОбласть("ЧекСкидка"+ШиринаПреЧека); 
	Для Каждого Элемент Из ПараметрыЧека.Запасы Цикл
		Область.Параметры.Наименование = Элемент.Наименование;
		Область.Параметры.Количество   = Элемент.Количество;
		Область.Параметры.Цена         = "="+Формат(Элемент.Цена,"ЧДЦ=2; ЧРД=.; ЧГ=");
		Документ.Вывести(Область);
		
		Если Элемент.СуммаСкидок > 0 Тогда
			ОбластьСкидки.Параметры.Скидка = "="+ФОрмат(Элемент.СуммаСкидок,"ЧДЦ=2; ЧРД=.; ЧГ=");// + "%";
			Документ.Вывести(ОбластьСкидки);
		КонецЕсли;
		
		СуммаЧека = СуммаЧека + Элемент.Сумма; 
	КонецЦикла;
	
	Область = Макет.ПолучитьОбласть("ЧекПодвал"+ШиринаПреЧека);
	Область.Параметры.Итого = "="+Формат(СуммаЧека,"ЧДЦ=2; ЧРД=.; ЧГ=");		
	Документ.Вывести(Область);
	
	Если НЕ ПараметрыЧека.Свойство("Пречек") Тогда
		
		Область  = Макет.ПолучитьОбласть("ЧекОплата" + ШиринаПреЧека);
		
		Для Каждого СтрокаОплаты ИЗ ПараметрыЧека.Оплата Цикл			
			Область.Параметры.Оплата = "" + СтрокаОплаты.ТипОплаты;
			Область.Параметры.Сумма  = "=" + Формат(СтрокаОплаты.Сумма, "ЧДЦ=2; ЧРД=.; ЧГ="); 
			Документ.Вывести(Область);               			
		КонецЦикла;
		
	КонецЕсли;	
	
	Для Индекс = 1 По Документ.КоличествоСтрок() Цикл
		ПреЧек = ПреЧек + Документ.ПолучитьСтроку(Индекс)
				+ ?(Индекс = Документ.КоличествоСтрок(), "", Символ(13) + Символ(10));
	КонецЦикла;

	Возврат ПреЧек;

КонецФункции

// Процедура устанавливает значения параметров сеанса, относящихся к внешнему оборудованию.
//
Процедура УстановитьПараметрыСеансаВнешнегоОборудования(ИмяПараметра, УстановленныеПараметры) Экспорт

	Если ИмяПараметра = "РабочееМестоКлиента" Тогда
		УстановитьРабочееМестоКлиента(Справочники.РабочиеМеста.ПустаяСсылка());
		УстановленныеПараметры.Добавить("РабочееМестоКлиента");
	КонецЕсли;

КонецПроцедуры

// Функция возвращает пользовательские настройки внешнего оборудования.
//
Функция ПолучитьПользовательскиеНастройкиВнешнегоОборудования() Экспорт

	СписокНастроек = ХранилищеОбщихНастроек.ПолучитьСписок("ПользовательскиеНастройкиВнешнегоОборудования");

	Настройки = Новый СписокЗначений();

	Для Каждого Элемент из СписокНастроек Цикл
		КлючНастройки = Элемент.Значение;
		ЗначениеНастройки = ХранилищеОбщихНастроек.Загрузить("ПользовательскиеНастройкиВнешнегоОборудования", КлючНастройки);
		Если ЗначениеНастройки <> Неопределено Тогда
			Настройки.Добавить(ЗначениеНастройки, КлючНастройки);
		КонецЕсли;
	КонецЦикла;

	Возврат Настройки;

КонецФункции

// Процедура сохраняет указанные пользовательские настройки внешнего оборудования.
//
Процедура СохранитьПользовательскиеНастройкиВнешнегоОборудования(СписокНастроек) Экспорт
    	
	Для Каждого Элемент Из СписокНастроек Цикл
		ХранилищеОбщихНастроек.Сохранить("ПользовательскиеНастройкиВнешнегоОборудования", Элемент.Представление, Элемент.Значение);
	КонецЦикла;

КонецПроцедуры

// Функция выполняет получение параметров кассы.
//
Функция ПолучитьПараметрыКассы(Касса) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ИСТИНА КАК ЭтоФискальныйРегистратор,
	|	Кассы.ВнешнееОборудование КАК ИдентификаторУстройства,
	|	Кассы.ИспользоватьБезПодключенияОборудования КАК ИспользоватьБезПодключенияОборудования,
	|	Кассы.ВнешнееОборудование.ТипОборудования КАК ТипОборудования
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Касса);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Возврат Новый Структура("ИдентификаторУстройства,
		                       |ИспользоватьБезПодключенияОборудования,
		                       |ЭтоФискальныйРегистратор,
							   |ТипОборудованияИмя",
		                       Выборка.ИдентификаторУстройства,
		                       Выборка.ИспользоватьБезПодключенияОборудования,
		                       Выборка.ЭтоФискальныйРегистратор,
							  ?(Выборка.ТипОборудования <> Null, МенеджерОборудованияВызовСервера.ПолучитьИмяТипаОборудования(Выборка.ТипОборудования), Неопределено)
		        );
		
	Иначе
		
		Возврат Новый Структура("ИдентификаторУстройства,
		                        |ИспользоватьБезПодключенияОборудования,
		                        |ЭтоФискальныйРегистратор,
								|ТипОборудованияИмя",
		                        Справочники.ПодключаемоеОборудование.ПустаяСсылка(),
		                        Ложь,
		                        Ложь,
								""
		        );
		
	КонецЕсли;
	
КонецФункции // ПолучитьПараметрыКассы()

// Получить таблицу доп.реквизитов из XML структуры
//
Функция ПолучитьТаблицуДопРеквизитов(ДанныеЗагрузки) Экспорт
	
	Результат = Новый Массив();
	
	Если НЕ ПустаяСтрока(ДанныеЗагрузки) Тогда
		
		ЧтениеXML = Новый ЧтениеXML; 
		ЧтениеXML.УстановитьСтроку(ДанныеЗагрузки);
		ЧтениеXML.ПерейтиКСодержимому();
		
		Если ЧтениеXML.Имя = "Table" и ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда  
			Пока ЧтениеXML.Прочитать() Цикл  
				Если ЧтениеXML.Имя = "Record" и ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда  
					Результат.Добавить(ЧтениеXML.ЗначениеАтрибута("VAT"));
					Результат.Добавить(Булево(ЧтениеXML.ЗначениеАтрибута("IsExcisable")));
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Сформировать таблицу доп.реквизитов для реализации
//
Функция СформироватьТаблицуДопРеквизитов(ДанныеЗагрузки) Экспорт
	
	Результат = Новый Массив();
	
	ЗаписьXML = Новый ЗаписьXML; 
	ЗаписьXML.УстановитьСтроку("UTF-8");
	ЗаписьXML.ЗаписатьОбъявлениеXML();

	ЗаписьXML.ЗаписатьНачалоЭлемента("Table");
	Для Каждого Позиция Из ДанныеЗагрузки  Цикл
		ЗаписьXML.ЗаписатьНачалоЭлемента("Record");
		ЗаписьXML.ЗаписатьАтрибут("VAT", Позиция[0]);
		ЗаписьXML.ЗаписатьАтрибут("IsExcisable", Строка(Формат(Позиция[1], "БЛ=False; БИ=True")));
		ЗаписьXML.ЗаписатьКонецЭлемента();
	КонецЦикла;
	ЗаписьXML.ЗаписатьКонецЭлемента();
    	
	Возврат ЗаписьXML.Закрыть();
	
КонецФункции

// Функция - "ПолучитьПризнакСпособаРасчетаДляПечати".
//
Функция ПолучитьПризнакСпособаРасчетаДляПечати(ПризнакСпособаРасчета) Экспорт
	
	Если ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПредоплатаПолная") Тогда
		ПризнакСпособаРасчетаДляПечати = "[ПрОп100]"   
	ИначеЕсли ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПредоплатаЧастичная") Тогда
		ПризнакСпособаРасчетаДляПечати = "[ПрОпл]"
	ИначеЕсли ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.Аванс") Тогда
		ПризнакСпособаРасчетаДляПечати = "[Аванс]"
	ИначеЕсли ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПередачаСПолнойОплатой") Тогда
		ПризнакСпособаРасчетаДляПечати = "[ПОпл]"
	ИначеЕсли ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПередачаСЧастичнойОплатой") Тогда
		ПризнакСпособаРасчетаДляПечати = "[ЧОпл]"
	ИначеЕсли ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПередачаБезОплаты") Тогда
		ПризнакСпособаРасчетаДляПечати = "[БезОп]" 
	ИначеЕсли ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ОплатаКредита") Тогда
		ПризнакСпособаРасчетаДляПечати = "[Кред]"
	КонецЕсли;
	
	Возврат ПризнакСпособаРасчетаДляПечати;
	
КонецФункции

// Получить наименование системы налогообложения по коду.
//
Функция ПолучитьНаименованиеСистемыНалогообложения(СистемаНалогообложения, Кратко = Ложь) Экспорт;
	
	СистемыНалогообложения = Новый Соответствие();
	Если Кратко Тогда
		СистемыНалогообложения.Вставить(0, НСтр("ru='ОСН'"));
		СистемыНалогообложения.Вставить(1, НСтр("ru='УСН доход'"));
		СистемыНалогообложения.Вставить(2, НСтр("ru='УСН доход-расход'"));
		СистемыНалогообложения.Вставить(3, НСтр("ru='ЕНВД'"));
		СистемыНалогообложения.Вставить(4, НСтр("ru='ЕСН'"));
		СистемыНалогообложения.Вставить(5, НСтр("ru='Патент'"));
	Иначе
		СистемыНалогообложения.Вставить(0, НСтр("ru='Общая'"));
		СистемыНалогообложения.Вставить(1, НСтр("ru='Упрощенная Доход'"));
		СистемыНалогообложения.Вставить(2, НСтр("ru='Упрощенная Доход минус Расход'"));
		СистемыНалогообложения.Вставить(3, НСтр("ru='Единый налог на вмененный доход'"));
		СистемыНалогообложения.Вставить(4, НСтр("ru='Единый сельскохозяйственный налог'"));
		СистемыНалогообложения.Вставить(5, НСтр("ru='Патентная система налогообложения'"));
	КонецЕсли;
	
	Возврат СистемыНалогообложения.Получить(СистемаНалогообложения);
	
КонецФункции

// Скопировать cтруктуру.
//
Функция СкопироватьСтруктуру(ТекущаяПозиция) Экспорт
	
	НоваяПозиция = Новый Структура;
	Для Каждого ЭлементСтруктуры Из ТекущаяПозиция Цикл
		НоваяПозиция.Вставить(ЭлементСтруктуры.Ключ, ЭлементСтруктуры.Значение);
	КонецЦикла;
	
	Возврат НоваяПозиция;
	
КонецФункции

// Функция, возвращает штрихкод номенклатуры для ККТ
//
Функция ПолучитьШтрихкодНоменклатуры(Номенклатура, Партия, Упаковка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Партия"      , Партия);
	Запрос.УстановитьПараметр("Упаковка"    , Упаковка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Штрихкоды.Штрихкод
	|ИЗ
	|	РегистрСведений.Штрихкоды КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Объект = &Номенклатура
	|	И Штрихкоды.ПартииНоменклатуры = &Партия
	|	И Штрихкоды.Упаковка = &Упаковка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Штрихкод;
	Иначе
		Возврат null;
	КонецЕсли;
	
КонецФункции

