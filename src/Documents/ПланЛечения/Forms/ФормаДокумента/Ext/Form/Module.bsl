&НаКлиенте 
// Процедура При изменении скидки наценки.
//
Процедура ТаблицаЛечениеПроцентСкидкиНаценкиПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ТаблицаЛечение.ТекущиеДанные;
	Если СтрокаТабличнойЧасти <> Неопределено Тогда	    
		Если МаксимальнаяРучнаяСкидка <> 0 И МаксимальнаяРучнаяСкидка < СтрокаТабличнойЧасти.ПроцентСкидкиНаценки Тогда
			ОбщегоНазначения.СообщитьПользователю("Максимальная ручная скидка составляет " + МаксимальнаяРучнаяСкидка + " %");
			Возврат;
		Иначе
			// Выполнить пересчет данных
			ОбработкаТабличныхЧастейКлиент.ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(СтрокаТабличнойЧасти, Истина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура При изменении ручной скидки.
//
Процедура ТаблицаЛучениеСуммаРучнойСкидкиПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ТаблицаЛечение.ТекущиеДанные;
	Если СтрокаТабличнойЧасти <> Неопределено Тогда	
		// Выполнить пересчет данных
		ОбработкаТабличныхЧастейКлиент.ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(СтрокаТабличнойЧасти, Истина);      
		Если МаксимальнаяРучнаяСкидка <> 0 И МаксимальнаяРучнаяСкидка < СтрокаТабличнойЧасти.ПроцентСкидкиНаценки Тогда
			ОбщегоНазначения.СообщитьПользователю("Максимальная ручная скидка составляет " + МаксимальнаяРучнаяСкидка + " %");
			СтрокаТабличнойЧасти.СуммаРучнойСкидки = 0;
			ОбработкаТабличныхЧастейКлиент.ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(СтрокаТабличнойЧасти);			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти 

