// Устанвоить состояние элементов формы
Процедура УстановитьСотсояниеЭлементов()
	
	Элементы.ИнофрмацияПоККМ.Видимость = Не Объект.ИспользоватьБезПодключенияОборудования;
    Элементы.ВнешнееОборудование.Доступность = Не Объект.ИспользоватьБезПодключенияОборудования;
	Элементы.ГруппаФорматТелефонногоНомераДляОтправкиЭлектронныхЧековККМ.Видимость = Константы.СтранаУчета.Получить().Код = "643"; //Только для РФ
	
	Элементы.ПечатьКопииЧекаКоличество.Видимость = Объект.ПечатьКопииЧеков = Истина;
	
	ЭтоОперационнаяКасса = Объект.ТипКассы = ПредопределенноеЗначение("Перечисление.ТипыКасс.ОперационнаяКасса"); 	
	Элементы.ГруппаОперационнаяКасса.Видимость = ЭтоОперационнаяКасса;
	
	ВыемкаСдачаНаличныхВбанк = Объект.ВыемкаИзКассы = ПредопределенноеЗначение("Перечисление.ВидыОпераций.СдачаНаличныхВБанк");	
	
	Если ВыемкаСдачаНаличныхВбанк Тогда
		Объект.КассаДляСдачиВыручки 		  = Неопределено;		
		Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения = Ложь;
	КонецЕсли;
	
	Элементы.ЗавершатьОперацииВыемки.Видимость = НЕ ВыемкаСдачаНаличныхВбанк;
	
	Элементы.ГруппаКассаПредприятия.Видимость  = Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения И НЕ ВыемкаСдачаНаличныхВбанк;
	Элементы.КассаДляСдачиВыручки.Видимость	   = Объект.ЗавершатьАвтоматическиОперацииВемкиВнесения;		            
КонецПроцедуры

