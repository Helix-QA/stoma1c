// Процедура - устанавливает видимость реквизитов в зависимости от хозяйственной операции.
//
Процедура УстановитьВидимость()
	
	ЭтаФорма.ТолькоПросмотр = ЗначениеЗаполнено(Объект.НомерЧекаККМ); 
	Элементы.ГруппаБлокировкаДокумента.Видимость =  ЗначениеЗаполнено(Объект.НомерЧекаККМ);
	
	// Если выбран режим заполнения выплаты ЗП по документу начисления
	// сбросить флаг выплаты аванса
	Если Объект.ВыплатаЗПРежимФормирования = 1 Тогда
		Объект.ВыплатаЗПАванс = Ложь;
	Иначе
		ВыплатаЗПМесяцПредставление = Формат(Объект.ВыплатаЗПМесяц,"ДФ='MMММ yyyy'");
	КонецЕсли;
	
    // Установка первой части заголовка документа в зависимости от вида операции 	
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда
		 ЭтаФорма.Заголовок = "Возврат оплаты клиенту";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику Тогда
		 ЭтаФорма.Заголовок = "Оплата поставщику";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.СдачаНаличныхВБанк Тогда
		 ЭтаФорма.Заголовок = "Сдача наличных в банк";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВыбытиеВКассу Тогда
		 ЭтаФорма.Заголовок = "Выбытие в кассу";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты Тогда
		 ЭтаФорма.Заголовок = "Выплата заработной платы"+?(Объект.ВыплатаЗПАванс,"(аванс)","");
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета Тогда
		 ЭтаФорма.Заголовок = "Возврат с лицевого счета";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику Тогда
		 ЭтаФорма.Заголовок = "Выдача подотчетнику";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыСтраховойКомпании Тогда
		 ЭтаФорма.Заголовок = "Возврат оплаты страховой компании";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВыдачаЗайма Тогда
		 ЭтаФорма.Заголовок = "Выдача, возврат займа";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаНалога Тогда
		 ЭтаФорма.Заголовок = "Оплата налога";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВыплатаДивидендовУчредителю Тогда
		 ЭтаФорма.Заголовок = "Выплата дивидендов учредителю";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПрочееСписание Тогда
		 ЭтаФорма.Заголовок = "Прочее списание";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту Тогда
		 ЭтаФорма.Заголовок = "Возврат ошибочной оплаты клиенту";
	КонецЕсли;
	
	// Изменение состава списка выбора операции
	Элементы.ВидОперации.СписокВыбора.Очистить();
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);  
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаПоставщику);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.СдачаНаличныхВБанк);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыдачаПодотчетнику);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыСтраховойКомпании);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыдачаЗайма);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыплатаДивидендовУчредителю);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПрочееСписание);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыбытиеВОперационнуюКассу);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия);
		// Элементы.Печать_КО2.Доступность = Истина;
		ЭтотОбъект.ДоступностьКнопкиПечатьРКО = Ложь;
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " наличными средствами";	
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаПоставщику);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыСтраховойКомпании);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыдачаЗайма);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыдачаПодотчетнику);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаНалога);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыплатаДивидендовУчредителю);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВыбытиеВКассу);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПрочееСписание);
		// Элементы.Печать_КО2.Доступность = Ложь;
		ЭтотОбъект.ДоступностьКнопкиПечатьРКО = Истина;
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " безналичными средствами";
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета);
		// Элементы.Печать_КО2.Доступность = Ложь;
		ЭтотОбъект.ДоступностьКнопкиПечатьРКО = Истина;
		ЭтаФорма.Заголовок              = ЭтаФорма.Заголовок + " платежной картой";		
     ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтКлиента);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПрочееСписание);
		// Элементы.Печать_КО2.Доступность = Ложь;
		ЭтотОбъект.ДоступностьКнопкиПечатьРКО = Истина;
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " с лицевого счета";		
      ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтКлиента);
		// Элементы.Печать_КО2.Доступность = Ложь;
		ЭтотОбъект.ДоступностьКнопкиПечатьРКО = Истина;
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " подарочным сертификатом";
	КонецЕсли;	
	
	Если Элементы.ВидОперации.СписокВыбора.НайтиПоЗначению(Объект.ВидОперации) = Неопределено Тогда	
		Объект.ВидОперации = Неопределено;
		ЭтаФорма.Заголовок = "Списание денежных средств";
	КонецЕсли;	
	Если Объект.Ссылка.Пустая() Тогда
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " (создание)";
    КонецЕсли;
	Если ЗначениеЗаполнено(Объект.КассоваяСмена) Тогда
		Элементы.КассоваяСменаТекущая.Видимость = Истина;
		мНомер = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Объект.КассоваяСмена.Номер, "");		
		КассоваяСменаТекущая    		= "Кассовая смена № " + ?(Найти(мНомер, "-") > 0, мНомер, "00"+мНомер) + " от " + Формат(Объект.КассоваяСмена.Дата,"ДФ=dd.MM.yyyy");
	Иначе
		Элементы.КассоваяСменаТекущая.Видимость = Ложь;
	КонецЕсли;
	
	// Установим видимость закладки Затраты. Она должна быть видна только при прочем списании или если есть хоть одна строка(Для старых документов)
	Если Объект.Затраты.Количество() > 0 Тогда
		Элементы.ГруппаЗатраты.Видимость = Истина;
	КонецЕсли;
	
	Элементы.Очистить_Чек.Доступность 			 = РольДоступна("ПолныеПрава") И Объект.НомерЧекаККМ = 99999999;
	Элементы.Очистить_Чек.Видимость				 = ЭтаФорма.ТолькоПросмотр;
	
	// Установка состояния элементов формы
	УправлениеИнтерфейсамиСервер.УстановкаСостоянийЭлементовФормы(ЭтаФорма,Объект);
    // Установка банковского счета контрагента по умолчанию(при указанных условиях)
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета
		И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты
		И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВыдачаПодотчетнику
		И НЕ ЗначениеЗаполнено(Объект.БанковскийСчетКонтрагента) 
		И ЗначениеЗаполнено(Объект.Контрагент) Тогда	
		Объект.БанковскийСчетКонтрагента = Объект.Контрагент.БанковскийСчетПоУмолчанию;
	ИначеЕсли  (Объект.ВидОперации  = Перечисления.ВидыОпераций.СдачаНаличныхВБанк ИЛИ Объект.ВидОперации  = Перечисления.ВидыОпераций.ВыбытиеВКассу)
		И НЕ ЗначениеЗаполнено(Объект.БанковскийСчетКонтрагента) Тогда
		Объект.БанковскийСчетКонтрагента = Объект.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию;
	КонецЕсли;   
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		И НЕ ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда	
		Объект.БанковскийСчет = Объект.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию;
	КонецЕсли; 
	// Устанвоить доступность печати чека
	УстановитьДоступностьПечатиЧека();
	
	Элементы.РасшифровкаПлатежаСтатья.Видимость = Объект.СтатьяВТаблице;
	ОбновитьИнформациюПоОстаткамЛСиЗадолженностям();
	Если ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
		Элементы.СтруктурнаяЕдиница.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Элементы.ГруппаЛеваяЧасть.Видимость = ВидимостьГруппаОстатокНаЛС(объект.ВидОперации);
	Элементы.Декорация3.Видимость 		= Элементы.ГруппаЛеваяЧасть.Видимость;
	
	ОбновитьОтображениеРасшифровки(); 
	
	Если ВыполнятьОперациюНаЭТ(Объект.ТипДенежныхСредств, Объект.ВидОперации, Объект.Касса, Объект.ЭквайрингТерминал) = Истина Тогда
		Элементы.НапечататьЧек.Заголовок = Нстр("ru = 'Пробить на ФР и ЭТ'; en = 'Punch on FR and AT'");
	Иначе
		Элементы.НапечататьЧек.Заголовок = Нстр("ru = 'Пробить на ФР'; en = 'Punch on FR'");
	КонецЕсли;
	
КонецПроцедуры   

