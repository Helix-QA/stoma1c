	             	  |ВЫБРАТЬ
	             	  |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТаблицаКлиентыОжидаютАктивности.Контрагент) КАК КоличествоОжидающихАктивности
	             	  |ИЗ
	             	  |	ТаблицаКлиентыОжидаютАктивности КАК ТаблицаКлиентыОжидаютАктивности";
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "КонтрагентыСведенияДляСписка.Контрагент.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ДатаНачалаПериода"	, НачалоДня(ОтборПериодЗначение.ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончаниеПериода", КонецДня(ОтборПериодЗначение.ДатаОкончания));
	Запрос.УстановитьПараметр("МассивМенеджеров"	, ОтборСотрудники);
	
	РезультатЗапроса 								= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваБезЗадач 						= РезультатЗапроса[4].Выбрать();
	ВыборкаКоличестваБезСделок 						= РезультатЗапроса[5].Выбрать();	
	ВыборкаКоличестваОжидающихАктивности 			= РезультатЗапроса[6].Выбрать();
	
	Если ВыборкаКоличестваОжидающихАктивности.Следующий() Тогда
		КоличествоОжидающихАктивности = ВыборкаКоличестваОжидающихАктивности.КоличествоОжидающихАктивности;
	Иначе 
		КоличествоОжидающихАктивности = 0;		
	КонецЕсли;
	Элементы.ПерейтиКлиентыОжидающиеАктивности.Заголовок 	= ?(КоличествоОжидающихАктивности > 0, Строка(КоличествоОжидающихАктивности) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Ожидает", КоличествоОжидающихАктивности) + Нстр("ru = ' активности'; en = ' activity'"), Нстр("ru='нет пациентов с запланированной активностью';en='no patients with planned activity'")); // подготовить к переводу
	Элементы.ПерейтиКлиентыОжидающиеАктивности.Доступность	= КоличествоОжидающихАктивности > 0;				
	// Элементы.ПерейтиКлиентыОжидающиеАктивности.ЦветТекста = ?(КоличествоОжидающихАктивности > 0, Новый Цвет(), Новый Цвет(242, 242, 242));					
		
	Если ВыборкаКоличестваБезЗадач.Следующий() Тогда
		КоличествоБезЗадач 							= ВыборкаКоличестваБезЗадач.КоличествоБезЗадач;		
	Иначе 	
		КоличествоБезЗадач 							= 0;		
	КонецЕсли;	
	Элементы.ПерейтиКлиентыБезЗадач.Заголовок 		= Строка(КоличествоБезЗадач) + Нстр("ru=' без задач';en=' without tasks'");
	Элементы.ПерейтиКлиентыБезЗадач.Доступность 	= КоличествоБезЗадач > 0;					
	Элементы.ПерейтиКлиентыБезЗадач.ЦветТекста 		= ?(КоличествоБезЗадач > 0, Новый Цвет(255, 0, 0), Новый Цвет(242, 242, 242));					
	
	Если ВыборкаКоличестваБезСделок.Следующий() Тогда
		КоличествоБезСделок 						= ВыборкаКоличестваБезСделок.КоличествоБезСделок;		
	Иначе 	
		КоличествоБезСделок 						= 0;		
	КонецЕсли;	
	Элементы.ПерейтиКлиентыБезСделок.Заголовок 		= Строка(КоличествоБезСделок) + Нстр("ru=' без сделок';en=' without deals'");
	Элементы.ПерейтиКлиентыБезСделок.Доступность 	= КоличествоБезСделок > 0;					
	Элементы.ПерейтиКлиентыБезСделок.ЦветТекста 	= ?(КоличествоБезСделок > 0, Новый Цвет(255, 0, 0), Новый Цвет(242, 242, 242));					
	
	Элементы.ПерейтиКлиентыБезЗадач.Видимость 		= КоличествоБезЗадач > 0 ИЛИ КоличествоБезСделок = 0;
	Элементы.ПерейтиКлиентыБезСделок.Видимость 		= КоличествоБезСделок > 0 ИЛИ КоличествоБезЗадач = 0;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить сведения по клиентам
//
// Параметры:
//  ОтборСотрудники	 - 	 - 
//
Процедура ОбновитьОбщиеСведенияПоСделкам(ЗНАЧ ОтборСотрудники = Неопределено)
	
	Если ОтборСотрудники = Неопределено Тогда
		Если ОтборАдресатСведенийТип = "Мои" Тогда 
			ОтборСотрудники = Новый Массив;
			ОтборСотрудники.Добавить(ТекущийПользователь);
		ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина);
		Иначе 	
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
			ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, Неопределено); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
		КонецЕсли;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, ОтборСтруктурнаяЕдиница);
	Иначе
		МассивСтруктурныхЕдиниц 	= РегистрыСведений.НастройкиСотрудников.ПолучитьМестаРаботыСотрудника(ТекущийПользователь, "Массив");		
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, МассивСтруктурныхЕдиниц);
	КонецЕсли;	
		
	Запрос 			= Новый Запрос;
	Запрос.УстановитьПараметр("МассивДоступныхВидовСделок", МассивДоступныхВидовСделок);
