 #Область FIREBIRD

// Функция - Начать импорт данных
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьИмпортДанныхFirebird(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Если ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Сотрудники" Тогда	
		ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьСотрудниковВФонеFirebird";
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Сотрудники""';en='Loading data. Stage ""Employees""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Клиенты" Тогда 
		ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьКлиентовВФонеFirebird";
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Клиенты""';en='Loading data. Stage ""Clients""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Номенклатура" Тогда
		ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьНоменклатуруВФонеFirebird";
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Номенклатура""';en='Loading data. Stage ""Nomenclature""'");
	КонецЕсли;
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	ИмяПроцедуры,
	ПараметрыПроцедуры,
	ОписаниеПроцедуры);
	Возврат Результат;
	
КонецФункции

// Процедура - Загрузить сотрудников в фоне firebird
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьСотрудниковВФонеFirebird(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	СозданоКлиентов 						= 0;
	СозданоАвто 							= 0;
	СозданоКлючей 							= 0;
	ГрузимФото 								= ЗначениеЗаполнено(ПараметрыЗадания.ПараметрыЗагрузки.ПапкаФотографии);
	
	ТипыКИ_АдресЭлектроннойПочты 			= Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	ТипыКИ_Адрес 							= Перечисления.ТипыКонтактнойИнформации.Адрес;
	ТипыКИ_Телефон 							= Перечисления.ТипыКонтактнойИнформации.Телефон;
	ВидКИ_ТелефонСотрудника					= Справочники.ВидыКонтактнойИнформации.ТелефонПользователя;
	ВидКИ_АдресСотрудника					= Справочники.ВидыКонтактнойИнформации.АдресСотрудника;
	ВидКИ_EmailСотрудника					= Справочники.ВидыКонтактнойИнформации.EmailПользователя;
	ВидДФЛ_ПаспортРФ 						= Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ.Ссылка;
	ТекущийПользовательСеанса 				= ПараметрыСеанса.ТекущийПользователь;	
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Сотрудников 						= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Сотрудников;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Сотрудников, "Таблица_Сотрудников");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Должности.Ссылка КАК Ссылка,
	               |	Должности.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.Должности КАК Должности
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Сотрудников.Должность КАК Должность
	               |ИЗ
	               |	Таблица_Сотрудников КАК Таблица_Сотрудников
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Сотрудников.Должность
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Фамилия КАК Фамилия,
	               |	Сотрудники.Имя КАК Имя,
	               |	Сотрудники.Отчество КАК Отчество
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.ЭтоГруппа = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Сотрудников.КодСинхронизации КАК КодСинхронизации,
	               |	Таблица_Сотрудников.Активен КАК Активен,
	               |	Таблица_Сотрудников.Фамилия КАК Фамилия,
	               |	Таблица_Сотрудников.Имя КАК Имя,
	               |	Таблица_Сотрудников.Отчество КАК Отчество,
	               |	Таблица_Сотрудников.ДатаРождения КАК ДатаРождения,
	               |	Таблица_Сотрудников.Должность КАК Должность,
	               |	Таблица_Сотрудников.НачалоРаботы КАК НачалоРаботы,
	               |	Таблица_Сотрудников.ОкончаниеРаботы КАК ОкончаниеРаботы,
	               |	Таблица_Сотрудников.Телефон КАК Телефон,
	               |	Таблица_Сотрудников.ТелефонРабочий КАК ТелефонРабочий,
	               |	Таблица_Сотрудников.Email КАК Email,
	               |	Таблица_Сотрудников.Комментарий КАК Комментарий
	               |ИЗ
	               |	Таблица_Сотрудников КАК Таблица_Сотрудников
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КодСинхронизации";
	
	#КонецОбласти
	
	РезультатПакетаЗапросов 		= Запрос.ВыполнитьПакет();
	ТаблицаДолжностейВБазе	 		= РезультатПакетаЗапросов[0].Выгрузить();
	ТаблицаДолжностей	 			= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСотрудниковВБазе 		= РезультатПакетаЗапросов[2].Выгрузить();
	Основная_Таблица_Сотрудников	= РезультатПакетаЗапросов[3].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые должности...", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем необходимые должности сотрудников на текущем этапе
	Для Каждого СтрокаДолжность Из ТаблицаДолжностей Цикл
		Если НЕ СокрЛП(СтрокаДолжность.Должность) = "" Тогда 
			СтрокаДолжностьВБазе = ТаблицаДолжностейВБазе.Найти(СокрЛП(СтрокаДолжность.Должность), "Наименование");
			Если СтрокаДолжностьВБазе = Неопределено Тогда
				Должность 						= Справочники.Должности.СоздатьЭлемент();
				Должность.Наименование 			= СокрЛП(СтрокаДолжность.Должность);
				Должность.УстановитьНовыйКод();					
				Должность.ОбменДанными.Загрузка = Истина;
				Должность.Записать();
				ЗаполнитьЗначенияСвойств(ТаблицаДолжностейВБазе.Добавить(), Должность);
			КонецЕсли;
		КонецЕсли;      
	КонецЦикла;
			
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по сотрудникам...';en='Saving data by employees...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоСотрудников 	= Основная_Таблица_Сотрудников.Количество();
	ОбщееКоличествоСотрудников 	= ?(ОбщееКоличествоСотрудников < 1, 1, ОбщееКоличествоСотрудников);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	ЗаписаноСотрудников 		= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеСотрудника		= "";
	
	// Создаем сотрудников
	Для Каждого СтрокаТаблицыСотрудники Из Основная_Таблица_Сотрудников Цикл 
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицыСотрудники.ДатаРождения) ИЛИ СтрокаТаблицыСотрудники.ДатаРождения > ТекущаяДатаСеанса() Тогда
			ДатаРождения = Дата(1,1,1);
		Иначе 
			ДатаРождения = СтрокаТаблицыСотрудники.ДатаРождения;
		КонецЕсли;	
					
		МассивСотрудников = ТаблицаСотрудниковВБазе.НайтиСтроки(Новый Структура("Фамилия, Имя, Отчество", СтрокаТаблицыСотрудники.Фамилия, СтрокаТаблицыСотрудники.Имя, СтрокаТаблицыСотрудники.Отчество));
		Если МассивСотрудников.Количество() = 0 Тогда
			// Создадим нового сотрудника
			МенеджерСотрудник 						= Справочники.Сотрудники.СоздатьЭлемент();
			МенеджерСотрудник.Фамилия 				= СокрЛП(СтрокаТаблицыСотрудники.Фамилия);
			МенеджерСотрудник.Имя 					= СокрЛП(СтрокаТаблицыСотрудники.Имя);
			МенеджерСотрудник.Отчество 				= СокрЛП(СтрокаТаблицыСотрудники.Отчество);			
			МенеджерСотрудник.Наименование 			= СокрЛП(СокрЛП(СтрокаТаблицыСотрудники.Фамилия) + " " + СокрЛП(СтрокаТаблицыСотрудники.Имя) + " " + СокрЛП(СтрокаТаблицыСотрудники.Отчество));
			СтрокаДолжность 						= ТаблицаДолжностейВБазе.Найти(СокрЛП(СтрокаТаблицыСотрудники.Должность), "Наименование");
			Если НЕ СтрокаДолжность = Неопределено Тогда 
				МенеджерСотрудник.Должность 		= СтрокаДолжность.Ссылка;
			КонецЕсли;
			МенеджерСотрудник.РольПользователя 		= Перечисления.РольПользователя.МенеджерОтделаПродаж;
			МенеджерСотрудник.ДатаРождения 			= ДатаРождения;
			МенеджерСотрудник.Комментарий 			= СокрЛП(СтрокаТаблицыСотрудники.Комментарий);
			
			// ТЕЛЕФОН сотрудника
			Если СокрЛП(СтрокаТаблицыСотрудники.Телефон) <> "" Тогда
				Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(СокрЛП(СтрокаТаблицыСотрудники.Телефон), ТипыКИ_Телефон);
				Если ЗначениеЗаполнено(Объект_XDTO_Телефон.Состав.Номер) Тогда 
					СтрокаТелефон = МенеджерСотрудник.КонтактнаяИнформация.Найти(Объект_XDTO_Телефон.Состав.Номер, "НомерТелефонаБезКодов");
					Если СтрокаТелефон = Неопределено Тогда			
						НоваяСтрока = МенеджерСотрудник.КонтактнаяИнформация.Добавить();
						НоваяСтрока.Тип 					= ТипыКИ_Телефон;
						НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
						НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
						НоваяСтрока.Представление 			= Объект_XDTO_Телефон.Представление;
						НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
						НоваяСтрока.Вид 					= ВидКИ_ТелефонСотрудника;
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			
			// ТЕЛЕФОН сотрудника раб.
			Если СокрЛП(СтрокаТаблицыСотрудники.ТелефонРабочий) <> "" Тогда
				Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(СокрЛП(СтрокаТаблицыСотрудники.ТелефонРабочий), ТипыКИ_Телефон);
				Если ЗначениеЗаполнено(Объект_XDTO_Телефон.Состав.Номер) Тогда 
					СтрокаТелефон = МенеджерСотрудник.КонтактнаяИнформация.Найти(Объект_XDTO_Телефон.Состав.Номер, "НомерТелефонаБезКодов");
					Если СтрокаТелефон = Неопределено Тогда			
						НоваяСтрока = МенеджерСотрудник.КонтактнаяИнформация.Добавить();
						НоваяСтрока.Тип 					= ТипыКИ_Телефон;
						НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
						НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
						НоваяСтрока.Представление 			= Объект_XDTO_Телефон.Представление;
						Объект_XDTO_Телефон.Комментарий 	= "рабочий";
						НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
						НоваяСтрока.Вид 					= ВидКИ_ТелефонСотрудника;
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;

			// EMAIL сотрудника
			Email = СтрокаТаблицыСотрудники.Email;
			Если СокрЛП(Email) <> "" Тогда
				Объект_XDTO_Email = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Email, ТипыКИ_АдресЭлектроннойПочты);
				СтрокаEmail = МенеджерСотрудник.КонтактнаяИнформация.Найти(СокрЛП(Email), "Представление");
				Если СтрокаEmail = Неопределено Тогда		
					НоваяСтрока = МенеджерСотрудник.КонтактнаяИнформация.Добавить();
					НоваяСтрока.Тип 			= ТипыКИ_АдресЭлектроннойПочты;
					НоваяСтрока.Вид 			= ВидКИ_EmailСотрудника;
					НоваяСтрока.АдресЭП 		= Объект_XDTO_Email.Представление;
					НоваяСтрока.Представление 	= НоваяСтрока.АдресЭП;
					НоваяСтрока.ЗначенияПолей	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Email);
				КонецЕсли;
			КонецЕсли;
			
			
			СтрМестоРаботы 							= МенеджерСотрудник.МестаРаботы.Добавить();
			СтрМестоРаботы.СтруктурнаяЕдиница 		= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			МенеджерСотрудник.УстановитьНовыйКод();								
			МенеджерСотрудник.ОбменДанными.Загрузка = Истина;
			Попытка
				МенеджерСотрудник.Записать();
			Исключение
				// Запись в лог						
				ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Ошибка при записи сотрудника! Наименование: ';en='Mistake at records employee! Name: '") + СокрЛП(СокрЛП(СтрокаТаблицыСотрудники.Фамилия) + " " + СокрЛП(СтрокаТаблицыСотрудники.Имя) + " " + СокрЛП(СтрокаТаблицыСотрудники.Отчество)) + Символы.ПС +  ОписаниеОшибки());						
			КонецПопытки;	                                                                                                                                         
		Иначе 
			МенеджерСотрудник = Справочники.Сотрудники.ПустаяСсылка();			
		КонецЕсли;
			
		// Накапливаем статисические данные и оповещаем клиент
		ЗаписаноСотрудников 			= ЗаписаноСотрудников + 1;
		ПредставлениеСотрудника			= ?(ЗначениеЗаполнено(МенеджерСотрудник.Ссылка), Строка(МенеджерСотрудник.Ссылка), "Загружен");
		Прогресс 						= Цел(100 * ЗаписаноСотрудников / ОбщееКоличествоСотрудников);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по сотрудникам...';en='Saving data by employees...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеСотрудника, ОсталосьВремени, ПредставлениеОставшегосяВремени));
		
	КонецЦикла;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл 
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;	

	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаДолжностейВБазе.Очистить(); 			ТаблицаДолжностейВБазе 			= Неопределено;
	ТаблицаДолжностей.Очистить(); 				ТаблицаДолжностей 				= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 		ТаблицаСотрудниковВБазе 		= Неопределено;
	Основная_Таблица_Сотрудников.Очистить(); 	Основная_Таблица_Сотрудников 	= Неопределено;
	
КонецПроцедуры

// Процедура - Загрузить клиентов в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьКлиентовВФонеFirebird(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
