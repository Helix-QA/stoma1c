// Процедура, обработчик события "ПриИзменении".
//
Процедура ГоловнаяОрганизацияПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ГоловнаяОрганизация) Тогда		
		Объект.ЭтоГоловнаяОрганизация = Ложь;
	КонецЕсли;
	
	Элементы.ЭтоГоловнаяОрганизация.ТолькоПросмотр = ЗначениеЗаполнено(Объект.ГоловнаяОрганизация);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ЭтоГоловнаяОрганизацияПриИзменении(Элемент)
	
	Если Объект.ЭтоГоловнаяОрганизация = Истина Тогда
		
		СуществующаяОрганизация = ПолучитьГоловнуюОрганизацию(Объект.ИНН);
		Если ЗначениеЗаполнено(СуществующаяОрганизация) Тогда
			ПоказатьПредупреждение(, "Уже существует головная организация с таким ИНН.");
			Объект.ЭтоГоловнаяОрганизация = Ложь;	
		КонецЕсли;
		
	Иначе
		
		Если Объект.Ссылка.Пустая() = Ложь Тогда
			МассивПодчиненныхОрганизаций = ПолучитьПодчиненныеГоловнойОрганизации(Объект.Ссылка);	
			Если МассивПодчиненныхОрганизаций.Количество() > 0 Тогда			
				ПоказатьПредупреждение(, "Эта организация является головной для других организаций.");
				Объект.ЭтоГоловнаяОрганизация = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.ГоловнаяОрганизация.ТолькоПросмотр = Объект.ЭтоГоловнаяОрганизация = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сотрудник начало выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеВыбора		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура СотрудникНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОписаниеОповещения   = Новый ОписаниеОповещения("СотрудникНачалоВыбораЗавершение", 
													ЭтаФорма, 
													Новый Структура("Сотрудник, Должность",Элемент.Имя, СтрЗаменить(Элемент.Имя, "ФИО", "Должность")));	
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", 
				 Новый Структура("БезОтбораПоРолям, ОтбиратьВрачей, ОтбиратьПоСтруктурнойЕдинице", Истина, Истина, Ложь),,,,,
				 ОписаниеОповещения, 
				 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

