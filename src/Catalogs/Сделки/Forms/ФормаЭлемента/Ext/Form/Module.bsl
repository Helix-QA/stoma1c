&НаСервереБезКонтекста
// Процедура, записывает изменение метки в регистр.
//
Процедура ЗаписатьИзменениеМетки(Метка, Клиент, Активна)
	
	НаборЗаписей = РегистрыСведений.МеткиКлиентов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Клиент.Установить(Клиент);
	НаборЗаписей.Отбор.Метка.Установить(Метка);
	
	Если Активна = Истина Тогда
		
		НоваяЗапись			 = НаборЗаписей.Добавить();
		НоваяЗапись.Период	 = ТекущаяДатаСеанса();
		НоваяЗапись.Клиент	 = Клиент;
		НоваяЗапись.Метка	 = Метка;
		НоваяЗапись.Активна	 = Активна;
		НоваяЗапись.Автор	 = ПараметрыСеанса.ТекущийПользователь;
		
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет таблицу меток разрешенными метками и устанавливает значения их активности.
//
Процедура ЗаполнитьТаблицуМеток()
	
	ТаблицаМеток.Очистить();
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Метки.Ссылка КАК Метка,
	|	ВЫБОР
	|		КОГДА МеткиДокументаКлиента.Активна
	|			ТОГДА МеткиДокументаКлиента.Активна
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Активна,
	|	Метки.ЦветМетки КАК ЦветМетки,
	|	Метки.ЦветТекстаБелый КАК ЦветТекстаБелый,
	|	Метки.Наименование КАК ПредставлениеМетки
	|ИЗ
	|	Справочник.Метки КАК Метки
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			МеткиКлиентов.Метка.Ссылка КАК МеткаСсылка,
	|			МеткиКлиентов.Активна КАК Активна
	|		ИЗ
	|			РегистрСведений.МеткиКлиентов КАК МеткиКлиентов
	|		ГДЕ
	|			МеткиКлиентов.Клиент = &Ссылка
	|			И МеткиКлиентов.Активна) КАК МеткиДокументаКлиента
	|		ПО Метки.Ссылка = МеткиДокументаКлиента.МеткаСсылка.Ссылка
	|ГДЕ
	|	Метки.ИспользоватьДляПациентов
	|
	|СГРУППИРОВАТЬ ПО
	|	Метки.Ссылка,
	|	ВЫБОР
	|		КОГДА МеткиДокументаКлиента.Активна
	|			ТОГДА МеткиДокументаКлиента.Активна
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Метки.Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Контрагент);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Метка Из Результат Цикл
		
		СтрокаТаблицы = ТаблицаМеток.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Метка);
		
		Если ЗначениеЗаполнено(Метка.ЦветМетки) Тогда
			
			ЦветМетки = ЗначениеИзСтрокиВнутр(Метка.ЦветМетки);
			
			Если ЦветМетки.Вид = ВидЦвета.АвтоЦвет Или (ЦветМетки.Красный = 255 И ЦветМетки.Зеленый = 255 И ЦветМетки.Синий = 255) Тогда
				ЦветФона = Новый Цвет(242, 242, 242);
			Иначе
				ЦветФона = ЦветМетки;
			КонецЕсли;
			
		Иначе
			ЦветФона = Новый Цвет(242, 242, 242);
			
		КонецЕсли;
		
		СтрокаТаблицы.ЦветФона = ЦветФона;
		
	КонецЦикла;
	
КонецПроцедуры

