// Функция, ОбновитьСписокОпераций.
//
Функция ОбновитьСписокОпераций()
	
	СписокВыбора = Новый СписокЗначений();
	Если РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ДобавлениеИзменениеКлиентов") Тогда
		СписокВыбора.Добавить("ИзменитьКлиентов", "Изменить",, БиблиотекаКартинок.Изменить);	
	КонецЕсли;
	
	Если ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Справочники.СегментыКонтрагентов) Тогда
		СписокВыбора.Добавить("СоздатьСегментКлиентов", "Создать сегмент",, БиблиотекаКартинок.СоздатьЭлементСписка);	
	КонецЕсли;
	
	Если ПравоДоступа("Редактирование", Метаданные.Справочники.СегментыКонтрагентов) Тогда
		СписокВыбора.Добавить("ОбновитьСегмент", "Обновить сегмент",, БиблиотекаКартинок.Обновить);	
	КонецЕсли;
	
	СписокВыбора.Добавить("ОтправитьПоЭлектроннойПочтеКлиентамИзОтчета", "Отправить письмо",, БиблиотекаКартинок.ОтправитьEmail);
	
	Если РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ДобавлениеИзменениеSMSРассылки") Тогда
		СписокВыбора.Добавить("Отправить_SMS", "Отправить SMS",, БиблиотекаКартинок.ОтправитьSMS);	
	КонецЕсли;
	
	Возврат СписокВыбора;

КонецФункции

