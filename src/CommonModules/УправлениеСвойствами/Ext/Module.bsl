				Если Форма.Команды.Найти("Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки) = Неопределено Тогда
					Команда 			= Форма.Команды.Добавить("Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки);
					Команда.Заголовок 	= "Промокод: " + Объект.Промокод;					
					Команда.Действие 	= "Подключаемый_ДекорацияФормы_Представление_Нажатие_Промокода";
				КонецЕсли;
				
				Кнопка = Форма.Элементы.Добавить("Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_Промокод);
				Кнопка.ИмяКоманды 				= "Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки;
				Кнопка.Заголовок 				= "Промокод: " + Объект.Промокод;
				Кнопка.ОтображениеФигуры    	= ОтображениеФигурыКнопки.Нет;				
				Если НЕ ЭтоМобильныйКлиент Тогда
					Кнопка.Шрифт 					= ШрифтыСтиля.ШрифтПодваловДокументов;
				КонецЕсли;
				Если (РольДоступна("ПолныеПрава") Или РольДоступна("ДобавлениеИзменениеДокументовПродажи")) Тогда
					КнопкаУдалить = Форма.Элементы.Добавить("Кнопка_Удалить_Промокод_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_Промокод);
