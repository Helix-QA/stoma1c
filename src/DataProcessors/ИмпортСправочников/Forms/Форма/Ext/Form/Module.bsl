// Импорт из Excel таблицы

// Получить список данных из строки Excel
&НаКлиенте
Функция ИзСтрокиExcel(ExcelЛист, НомерСтроки, КолСтолбцов)
	
	СписокПолей = Новый СписокЗначений;
	
	Для Столбец = 1 По КолСтолбцов Цикл
		СписокПолей.Добавить(ExcelЛист.Cells(НомерСтроки,Столбец).Text, ExcelЛист.Cells(НомерСтроки,Столбец).Text);
	КонецЦикла;
	
	Возврат СписокПолей;
	
КонецФункции

// Получаем наименования полей из первой строки 
&НаКлиенте
Функция ПолчитьПоляИзExcel()
	
	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.WorkBooks.Open(ФайлИмпорта);
		// Состояние("Обработка файла Microsoft Excel...");
		ExcelЛист = Excel.Sheets(1);
	Исключение
		ТекстИсключение=ОписаниеОшибки();
		ПоказатьПредупреждение(,"Немогу подключиться к файлу по причине: "+ТекстИсключение);
		Возврат неопределено;		 
	КонецПопытки;
	
	ColumnsCount = Excel.Cells.CurrentRegion.Columns.Count;		
	СписокКолонокФайла=ИзСтрокиExcel(ExcelЛист,1,ColumnsCount);
	
	Excel.WorkBooks.Close();
	Excel = 0;
	
	возврат СписокКолонокФайла;
	
КонецФункции

&НаКлиенте
// Загрузка реквизитов справочника из таблицы Excel
// 
Функция ЗагрузитьИзExcel()
	
	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.WorkBooks.Open(ФайлИмпорта);
		// Состояние("Обработка файла Microsoft Excel...");
		ExcelЛист = Excel.Sheets(1);
	Исключение
		ТекстИсключение = ОписаниеОшибки();
		ПоказатьПредупреждение(,"Немогу подключиться к файлу по причине: "+ТекстИсключение);
		Возврат неопределено;		 
	КонецПопытки;
	
	
	КолСтрок = Excel.Cells.CurrentRegion.Rows.Count;
	КолСтолбцов = Excel.Cells.CurrentRegion.Columns.Count;
	
	ИндексСтроки = 2;
	Коэфициент = 100 / КолСтрок;
	Коэф = Коэфициент;
	Если ЗагружаемыйСправочник = "Номенклатура" Тогда 
		ТекстСообщения = "Загрузка номенклатуры";
	Иначе 
		ТекстСообщения = "Загрузка клиентов";
	КонецЕсли;
	
	Пока ИндексСтроки <= КолСтрок Цикл
		СписокДанных = ИзСтрокиExcel(ExcelЛист, ИндексСтроки, КолСтолбцов);
		СтруктураРеквизитов = Новый Структура();
		
		Индекс = 0;
		Пока Индекс < Объект.ТаблицаСоответсвийПолей.Количество() Цикл
			
			Строка = Объект.ТаблицаСоответсвийПолей[Индекс];
			Реквизит = СтрЗаменить(Строка.РеквизитСправочника, " ", "");
			Реквизит = СтрЗаменить(Реквизит, "*", "");	
			
			Если Строка.КолонкаФайла <> "" Тогда
				Идентификатор = СписокКолонокФайла.НайтиПоЗначению(Строка.КолонкаФайла).ПолучитьИдентификатор();
				СтруктураРеквизитов.Вставить(Реквизит, СписокДанных[Идентификатор].Значение);
			Иначе   
				СтруктураРеквизитов.Вставить(Реквизит, "");
			КонецЕсли;	   
			
			Индекс = Индекс + 1;
			
		КонецЦикла;
		Если ЗагружаемыйСправочник = "Номенклатура" Тогда 
			Состояние(ТекстСообщения, ?(Цел(Коэф) < 1, 1, Цел(Коэф)), "Получение " + Строка(СтруктураРеквизитов.Наименование) + "...", БиблиотекаКартинок.Информация32); 			
		Иначе 
			Состояние(ТекстСообщения, ?(Цел(Коэф) < 1, 1, Цел(Коэф)), "Получение " + Строка(СтруктураРеквизитов.Фамилия) + " " + Строка(СтруктураРеквизитов.Имя) + " " + Строка(СтруктураРеквизитов.Отчество) + "...", БиблиотекаКартинок.Информация32); 
			// Приведем телефонный номер к установленному формату
			СписокПолей = Новый СписокЗначений;
			УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(?(СтруктураРеквизитов.Свойство("Телефон"), СтруктураРеквизитов.Телефон, ""), СписокПолей);			
			СтруктураТелефонногоНомера = ЗаполнитьСтруктуруТелефонногоНомера(?(СтруктураРеквизитов.Свойство("Телефон"), СтруктураРеквизитов.Телефон, ""), СписокПолей);
		КонецЕсли;		
		
		ЗаполнитьРеквизитыСправочника(СтруктураРеквизитов, Формат(СписокДанных), ВидМедицинскихКарт, СтруктураТелефонногоНомера);
		Коэф = Коэф + Коэфициент;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;		
	
	Excel.WorkBooks.Close();
	Excel = 0;
	
	Возврат Истина;
	
КонецФункции // ЗагрузитьИзExcel()


