Функция ПолучитьСписокСделок(ДатаСделок)
	       
	ДатаНачала = Дата('19700101') + ДатаСделок;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Ссылка КАК Ссылка,
	|	Сделки.ДатаСделки КАК ДатаСделки
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ДатаСделки > &ДатаНачала
	|	И НЕ Сделки.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСделки");
	
	Запрос.УстановитьПараметр("ДатаНачала"      , ДатаНачала);
	
	Результат = Запрос.Выполнить().Выгрузить();
		
	Возврат Результат;
	
