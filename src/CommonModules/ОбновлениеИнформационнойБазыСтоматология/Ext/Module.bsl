	// Заполняем предопределенные "ВидыЦен"
	ЗаполнитьПредопределенныеЭлементыВидовЦен();
	
	// Валюты
	СоздатьПредопределенныеЭлементыВалюты();
	// Создаем элемент в справочнике "Валюты"

	Если Константы.ВалютаУчета.Получить().Пустая() Тогда
		Константы.ВалютаУчета.Установить(Справочники.Валюты.НайтиПоКоду(643));
	Конецесли;

	Стр = Справочники.СтраныМира.НайтиПоНаименованию("БЕЛАРУСЬ");
	Если Стр.Пустая() Тогда
		Стр = Справочники.СтраныМира.СоздатьЭлемент();
