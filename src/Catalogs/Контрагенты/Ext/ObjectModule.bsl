// Процедура дополняет обращение новыми данными
//
Процедура АктуализироватьЗаявку(ЭтоНовый)
	
	ОбращенияПациента = Справочники.Заявки.ПолучитьЗаявкуПоНомеруТелефона(СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Телефон, ","));
	Если Не ЗначениеЗаполнено(ОбращенияПациента) И ЭтоНовый Тогда
		Заявка = Справочники.Заявки.СоздатьВходящуюЗаявку(,,,ЭтотОбъект.Фамилия, ЭтотОбъект.Имя,ЭтотОбъект.Отчество,ЭтотОбъект.Телефон,,,,,,,,,ЭтотОбъект.Ссылка,ЭтотОбъект.СтруктурнаяЕдиница,,,,,,Перечисления.СтатусыЗаявок.Принята);	
	ИначеЕсли Не ОбращенияПациента = Справочники.Заявки.ПустаяСсылка() И Не ЗначениеЗаполнено(ОбращенияПациента.ОсновнойКлиент) Тогда
		
		ОбращениеОбъект = ОбращенияПациента.ПолучитьОбъект();
		
		ОбращениеОбъект.ОсновнойКлиент  = ЭтотОбъект.Ссылка;
		ОбращениеОбъект.Фамилия 		= ЭтотОбъект.Фамилия;
		ОбращениеОбъект.Имя				= ЭтотОбъект.Имя;
		ОбращениеОбъект.Отчество 		= ЭтотОбъект.Отчество;
		ОбращениеОбъект.Наименование 	= СокрЛП(ЭтотОбъект.Фамилия + ?(ЗначениеЗаполнено(ЭтотОбъект.Фамилия), " ", "") + ЭтотОбъект.Имя + ?(ЗначениеЗаполнено(ЭтотОбъект.Имя), " ", "") + ЭтотОбъект.Отчество);
		
		Попытка
			ОбращениеОбъект.Записать();
		Исключение
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры   

