
#Область СлужебныйПрограммныйИнтерфейс

#Область v1

// Функция является основной точкой входа методов GET
//
Функция v1GET(Запрос)

	УстановитьПривилегированныйРежим(Истина);
	
	СоответствиеСЗаголовками = ПолучитьСоответствиеЗаголовков(Запрос);
	
	Метод      = НРег(Запрос.ПараметрыURL["metod"]);
	УИДКлиники = Запрос.ПараметрыURL["clinic_id"];     
	ApiKey     = СоответствиеСЗаголовками.Получить("apikey");
	UserToken  = СоответствиеСЗаголовками.Получить("usertoken");

	ВнешняяСистема     = Неопределено;
	СообщениеОбОшибке  = ПроверитьКлючПриложения(ApiKey, ВнешняяСистема);	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда		
		Возврат ПолучитьHTTPОтвет(СообщениеОбОшибке);
	КонецЕсли;
	
	СтруктурнаяЕдиница = ПолучитьСсылкуПоИдентификатору(УИДКлиники, СообщениеОбОшибке,, "СтруктурныеЕдиницы", 1055, Истина);
	Если СтруктурнаяЕдиница = Неопределено Тогда
		СтруктурнаяЕдиница = ПолучитьСтруктурнуюЕдиницуПоУИДКлиники(УИДКлиники, СообщениеОбОшибке);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда		
		Возврат ПолучитьHTTPОтвет(СообщениеОбОшибке);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(UserToken) Тогда
		ТекущийКлиент = РегистрыСведений.КлючиВнешнихСистем.ПолучитьКлиентаПоКлючу(UserToken);
	КонецЕсли;

	ПараметрыЗапроса = Запрос.ПараметрыЗапроса;
	
	repeater   = ПараметрыЗапроса.Получить("repeater");
	БазовыйURL = ?(repeater = Неопределено, Запрос.БазовыйURL, repeater);
	
	datetime    = ПараметрыЗапроса.Получить("datetime");
	start_date  = ПараметрыЗапроса.Получить("start_date");
	end_date    = ПараметрыЗапроса.Получить("end_date");
	service_id  = ПараметрыЗапроса.Получить("service_id");
	service_ids = ПолучитьМассив_service_ids(ПараметрыЗапроса);
	staff_id   	= ПараметрыЗапроса.Получить("staff_id");
	
	Если Метод = "book_services" Тогда
		Ответ1с = api_v1.book_services(СтруктурнаяЕдиница, datetime, staff_id);
	ИначеЕсли Метод = "book_staff" Тогда
		Ответ1с = api_v1.book_staff(СтруктурнаяЕдиница, datetime, service_ids, service_id, БазовыйURL, ApiKey,, ВнешняяСистема);
	ИначеЕсли Метод = "book_dates" Тогда
		Ответ1с = api_v1.book_dates(СтруктурнаяЕдиница, start_date, end_date, service_ids, service_id, staff_id, ВнешняяСистема);
	ИначеЕсли Метод = "book_times" Тогда
		Ответ1с = api_v1.book_times(СтруктурнаяЕдиница, datetime, service_ids, service_id, staff_id);
	ИначеЕсли Метод = "client" Тогда
		Ответ1с = api_v1.client(ТекущийКлиент);
	ИначеЕсли Метод = "auth_types" Тогда		
		Ответ1с = api_v1.auth_types(СтруктурнаяЕдиница)
	Иначе
		Ответ1с = ПолучитьСтруктуруВозвратаОшибки(1040);
	КонецЕсли;                                                            
	
	Попытка
		Возврат ПолучитьHTTPОтвет(Ответ1с);
	Исключение		
		СистемнаяОшибка = ОписаниеОшибки();	
		ЗаписьЖурналаРегистрации("API," + Метод, УровеньЖурналаРегистрации.Ошибка, , , СистемнаяОшибка);				
		Возврат ПолучитьHTTPОтвет(ПолучитьСтруктуруВозвратаОшибки(1000, СистемнаяОшибка));				
	КонецПопытки;
	
	
КонецФункции

// Функция является основной точкой входа методов POST
//
Функция v1POST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СоответствиеСЗаголовками = ПолучитьСоответствиеЗаголовков(Запрос);
	
	Метод      = НРег(Запрос.ПараметрыURL["metod"]);
	УИДКлиники = Запрос.ПараметрыURL["clinic_id"];
	ApiKey     = СоответствиеСЗаголовками.Получить("apikey");
	UserToken  = СоответствиеСЗаголовками.Получить("usertoken");
	
	Если Метод = "test_connect" Тогда
		КодПроверки = ЛичныйКабинет.ПолучитьКодПроверкиРубликации();
		Возврат ПолучитьHTTPОтвет(Новый Структура("Result, CheckCode", Истина, КодПроверки));
		
	КонецЕсли;
	СообщениеОбОшибке = "";
	СтруктурнаяЕдиница = ПолучитьСсылкуОбъектаПоУИД(УИДКлиники, "Справочники", "СтруктурныеЕдиницы");
	Если СтруктурнаяЕдиница = Неопределено Тогда 
		СтруктурнаяЕдиница = ПолучитьСтруктурнуюЕдиницуПоУИДКлиники(УИДКлиники, СообщениеОбОшибке, Ложь); 
	КонецЕсли;
	
	Если Метод <> "auth" И СтруктурнаяЕдиница = Неопределено Тогда 
		Возврат ПолучитьHTTPОтвет(ПолучитьСтруктуруВозвратаОшибки(1055));  
	КонецЕсли;
	
	ВнешняяСистема 	  = Неопределено;
	СообщениеОбОшибке = ПроверитьКлючПриложения(ApiKey, ВнешняяСистема);
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда
		Возврат ПолучитьHTTPОтвет(СообщениеОбОшибке);
	КонецЕсли;
	
	ТекущийКлиент = Неопределено;
	НомерТелефона = Неопределено;
	Пароль		  = Неопределено;
	Если Метод <> "auth" Тогда
		
		СообщениеОбОшибке = ПроверитьКлючКлиента(UserToken, ТекущийКлиент, НомерТелефона, Пароль);
		Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда
			Возврат ПолучитьHTTPОтвет(СообщениеОбОшибке);
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыJSON = ПолучитьПараметрыJSON(Запрос);

	last_name			= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "last_name");
	name			  	= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "name");
	second_name 		= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "second_name");
	phone   			= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "phone");
	email			  	= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "email");
	birthday   			= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "birthday");
	sex   				= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "sex");
	comment 			= ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "comment");
	
	Если Метод = "book_record" Тогда
		fullname	  = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "fullname");
		commercial 	  = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "commercial");
		record_array  = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "record_array");
		comment 	  = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "comment");
		notify_by_sms = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "notify_by_sms");
		
		Ответ1с       = api_v1.book_record(СтруктурнаяЕдиница, record_array, ТекущийКлиент, fullname,
						commercial, comment, ВнешняяСистема, НомерТелефона, notify_by_sms,, email, birthday);
	
	ИначеЕсли Метод = "auth" Тогда
		login 	 		  = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "login");
		confirmation_code = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "confirmation_code");
		auth_type		  = ПолучитьЗначениеИзСтруктуры(ПараметрыJSON, "auth_type");
		
		Ответ1с           = api_v1.auth(ApiKey, login, confirmation_code, name, last_name, second_name, birthday, email, СтруктурнаяЕдиница, auth_type);	
		
	Иначе                               
		Ответ1с = ПолучитьСтруктуруВозвратаОшибки(1040);
	КонецЕсли;
	
	Попытка
		Возврат ПолучитьHTTPОтвет(Ответ1с);
	Исключение		
		СистемнаяОшибка = ОписаниеОшибки();	
		ЗаписьЖурналаРегистрации("API," + Метод, УровеньЖурналаРегистрации.Ошибка, , , СистемнаяОшибка);				
		Возврат ПолучитьHTTPОтвет(ПолучитьСтруктуруВозвратаОшибки(1000, СистемнаяОшибка));				
	КонецПопытки;
		
КонецФункции

#Область МетодыПроверкиПередаваемыхПараметров

// Функция проводит аутентификацию приложения
// 
Функция ПроверитьКлючПриложения(ApiKey, ВнешняяСистема = Неопределено, ТипВнешнейСистемы = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(ApiKey) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1062);
	КонецЕсли;
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(ApiKey, ТипВнешнейСистемы);
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1063);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция проводит аутентификацию клиента
// 
Функция ПроверитьКлючКлиента(UserToken, Клиент, НомерТелефона = Неопределено, Пароль = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(UserToken) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1066);
	КонецЕсли;
	
	СтруктураДанных = РегистрыСведений.КлючиВнешнихСистем.ПолучитьДанныеКлючаВнешнейСистемы(UserToken);
	
	Если СтруктураДанных = Неопределено Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1067);
	Иначе		
		Клиент 			= СтруктураДанных.Клиент;
		НомерТелефона	= СтруктураДанных.НомерТелефона;
		Пароль			= СтруктураДанных.Пароль;		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Получить структурную единицу по УИДКлиники
//
// Параметры:
//  УидКлиники			 - 	 - 
//  СообщениеОбОшибке	 - 	 - 
//  КодОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктурнуюЕдиницуПоУИДКлиники(УидКлиники, СообщениеОбОшибке, ОбязательныйПараметр = Истина)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ
	|	И СтруктурныеЕдиницы.УникальныйИдентификаторСтруктурнойЕдиницы = &УникальныйИдентификаторСтруктурнойЕдиницы");
	Запрос.УстановитьПараметр("УникальныйИдентификаторСтруктурнойЕдиницы", УидКлиники); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Ссылка = ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	Если Ссылка = Неопределено И ОбязательныйПараметр = Истина Тогда
		СообщениеОбОшибке = ПолучитьСтруктуруВозвратаОшибки(1055);
	Иначе 
		СообщениеОбОшибке = Неопределено;	
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

