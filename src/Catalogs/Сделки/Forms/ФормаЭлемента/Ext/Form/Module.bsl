&НаСервере
// Процедура, обновляет выбора заявок
//
Процедура ОбновитьПараметрыВыбораЗаявки()
	
	МассивЗаявок = ПолучитьАктивныеЗаявкиКонтрагента(, Объект.Контрагент, Истина);
	
	ФиксированныйМассив = Новый ФиксированныйМассив(МассивЗаявок);
	
	Массив = Новый Массив;
	НовыеПараметрыВыбора = Новый  ПараметрВыбора("Отбор.Ссылка", ФиксированныйМассив);
	Массив.Добавить(НовыеПараметрыВыбора);

	Элементы.Заявка.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
	Элементы.Заявка.Видимость = ЗначениеЗаполнено(Объект.Заявка) ИЛИ ЗначениеЗаполнено(МассивЗаявок); 
		
КонецПроцедуры	

&НаКлиенте
// Процедура, обработчик события "СписокПричинОтказаВыбор".
//
Процедура СписокПричинОтказаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Элементы.ОткрытьПродажу.Видимость = Ложь;
	СтандартнаяОбработка = Ложь;
	СписокПричинОтказаВыборНаСервере(ВыбраннаяСтрока);
	УстановитьФокусЭлемента();
	
КонецПроцедуры

&НаСервере
// Процедура, продолжение обработчика события на сервере "СписокПричинОтказаВыбор".
//
Процедура СписокПричинОтказаВыборНаСервере(ВыбраннаяСтрока = Неопределено)
	
	Если ВидСделкиПредопределенный Тогда
		Элементы.ГруппаРеализация.Видимость = Ложь;
		Элементы.ОткрытьПродажу.Видимость 	= Ложь;
		
		ПричинаОтказа = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался");
	ИначеЕсли НЕ ВыбраннаяСтрока = Неопределено Тогда 	
		ПричинаОтказа = ЭтотОбъект.СписокПричинОтказа[ВыбраннаяСтрока].Значение;
	Иначе 
		Возврат;
	КонецЕсли;
	
	//СтруктураНаименований = Справочники.ВидыСделок.ПолучитьНаименованияЗавершающихЭтаповСделки(Объект.ВидСделки);
	//Элементы.РезультатСделки.Заголовок = СтруктураНаименований.НаименованиеЭтапаОтказ + Строка(ПричинаОтказа);
	
	Объект.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;
	Объект.ПричинаОтказа   	= ПричинаОтказа;
	Объект.ЭтапОтказа 		= ?(ЗначениеЗаполнено(Объект.ЭтапОтказа), Объект.ЭтапОтказа, Объект.ЭтапСделки);
	Объект.ЭтапСделки	   	= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
	
	ОбновитьЭтапыСделки();
	УстановитьВидимостьРезультатаСделки();
	УстановитьУсловноеОформмлениеСписка();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ИсточникИнформацииПриИзменении".
//
Процедура ИсточникИнформацииПриИзменении(Элемент)
	
	ТипДругойПациент = ПредопределенноеЗначение("Справочник.РекламныеИсточники.ДругойПациент");
	Элементы.ИсточникИнформацииЗначение.Видимость = (Объект.ИсточникИнформации = ТипДругойПациент);
	
	Если Объект.ИсточникИнформации = ТипДругойПациент Тогда
		Элементы.ИсточникИнформацииЗначение.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ИсточникИнформацииЗначениеНачалоВыбора".
//
Процедура ИсточникИнформацииЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОписаниеОповещения = Новый ОписаниеОповещения("ИсточникИнформацииЗначениеНачалоВыбораЗавершение", ЭтаФорма);
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты",,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Клиент источник информации начало выбора завершение.
// Завершение немодального открытия окна формы - Справочник Контрагенты - ФормаВыбораКлиенты
// Параметры:
//  Результат	 - 	 Результат Оповещения 
//  Параметры	 - 	 Параметры Оповещения 
//
Процедура ИсточникИнформацииЗначениеНачалоВыбораЗавершение(Результат, Параметры)  Экспорт
	
	ЗначениеКонтрагент = Результат;
	Если ЗначениеКонтрагент <> Неопределено Тогда
		Если ЗначениеКонтрагент <> Объект.Контрагент Тогда
			Объект.ИсточникИнформацииЗначение = ЗначениеКонтрагент;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Клиент не может быть источником информации для самого себя.
			                                                             |Следует выбрать другого клиента.'; 
																   |en = 'The client cannot be a source of information for himself.
																		 |You should choose another client.'"));
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

