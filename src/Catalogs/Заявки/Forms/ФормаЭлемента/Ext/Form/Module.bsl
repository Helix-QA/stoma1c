// Функция, проверить менеджера и записать форму.
//
Функция УстановитьСтатусИЗаписатьФорму()
	
	РезультатОперации = Новый Структура;
	РезультатОперации.Вставить("ОписаниеОшибки"		, "");
	РезультатОперации.Вставить("ВыполненоУспешно"	, Ложь);
	
	Объект.ОсновнойКлиент 	= ?(Объект.Ссылка.Пустая(), Неопределено, Объект.ОсновнойКлиент);	
	Объект.Статус 			= ?(Объект.Статус <> ЭтотОбъект.СтатусЗаявки, ЭтотОбъект.СтатусЗаявки, Объект.Статус);
	// Объект.ОсновнойМенеджер = ?(Объект.ОсновнойМенеджер <> ЭтотОбъект.ТекущийПользователь, ЭтотОбъект.ТекущийПользователь, Объект.ОсновнойМенеджер);		
	
	Попытка
		ЭтаФорма.Записать();
		РезультатОперации.ВыполненоУспешно = Истина;
	Исключение
		ТекстОшибки = НСтр("ru = 'Не удалось установить статус заявки. Текст ошибки: '") + ОписаниеОшибки();
		РезультатОперации.ОписаниеОшибки = ТекстОшибки;
	КонецПопытки;
	
	Если РезультатОперации.ВыполненоУспешно = Истина Тогда
		
		// Создаем оповещение других сеансов о заявке.
		УстановитьПривилегированныйРежим(Истина);
		
		НомерТекущегоСеанса	 = НомерСеансаИнформационнойБазы();
		ТекущиеСеансы		 = ПолучитьСеансыИнформационнойБазы();
		
		// Если активен только один сеанс (текущий) - никого не оповещаем.
		Если ТекущиеСеансы.Количество() > 1 Тогда
			
			СистемаВзаимодействияПодключена = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена() = Истина;
			
			Если Не СистемаВзаимодействияПодключена Тогда
				
				ПараметрыОповещения = Новый Массив;
				ПараметрыОповещения.Добавить(Объект.Ссылка);
				ПараметрыОповещения.Добавить(Объект.ОсновнойМенеджер);
				ПараметрыОповещения.Добавить(Объект.СтруктурнаяЕдиница);
				
			КонецЕсли;
			
			ПользователиОповещения = Новый Массив;
			
			Для Каждого Сеанс Из ТекущиеСеансы Цикл
				
				Если (Сеанс.ИмяПриложения = "1CV8C"
					Или Сеанс.ИмяПриложения = "WebClient") Тогда
				
					Если НомерТекущегоСеанса = Сеанс.НомерСеанса Тогда
						Продолжить;
					КонецЕсли;
					
					Если СистемаВзаимодействияПодключена Тогда
						ПользователиОповещения.Добавить(Сеанс.Пользователь);
					Иначе
						РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(
							Сеанс.НомерСеанса,,
							"ОбновленСтатусЗаявки",
							ТекущаяДатаСеанса(),,,,
							ПараметрыОповещения
						);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если СистемаВзаимодействияПодключена И ЗначениеЗаполнено(ПользователиОповещения) Тогда
				
				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("Ключ"					, "ОбновленСтатусЗаявки");
				ДанныеСообщения.Вставить("Заявка"				, Объект.Ссылка);
				ДанныеСообщения.Вставить("Сотрудник"			, ?(Объект.ОсновнойМенеджер.Пустая(), Неопределено, Объект.ОсновнойМенеджер));
				ДанныеСообщения.Вставить("СтруктурнаяЕдиница"	, ?(Объект.СтруктурнаяЕдиница.Пустая(), Неопределено, Объект.СтруктурнаяЕдиница));
				
				ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РезультатОперации;
	
КонецФункции

