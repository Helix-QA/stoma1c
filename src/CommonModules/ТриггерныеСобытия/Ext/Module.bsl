	|			ТОГДА ТаблицаПланируемыхДействийТриггера.Сообщение
	|		ИНАЧЕ ТаблицаПланируемыхДействийТриггера.Сообщение
	|	КОНЕЦ КАК Сообщение
	|ПОМЕСТИТЬ ТаблицаПланируемыхТриггеровИДатРегистрации
	|ИЗ
	|	ТаблицаПланируемыхДействийТриггера КАК ТаблицаПланируемыхДействийТриггера
	|		ПОЛНОЕ СОЕДИНЕНИЕ ЖурналЗапланированнойРегистрации КАК ЖурналЗапланированнойРегистрации
	|		ПО ТаблицаПланируемыхДействийТриггера.ТриггерноеСобытие = ЖурналЗапланированнойРегистрации.ТриггерноеСобытие
	|			И ТаблицаПланируемыхДействийТриггера.Контрагент = ЖурналЗапланированнойРегистрации.Контрагент
	|			И ТаблицаПланируемыхДействийТриггера.ИдентификаторДействия = ЖурналЗапланированнойРегистрации.ИдентификаторДействия
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЕСТЬNULL(ТаблицаПланируемыхДействийТриггера.ДействиеАктуально, ЛОЖЬ) = ЛОЖЬ
	|					И ЖурналЗапланированнойРегистрации.Контрагент ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПланируемыхТриггеровИДатРегистрации.ПериодОтбора КАК ПериодОтбора,
	|	ВЫБОР
	|		КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.ДатаОтсчета = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
	|		КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.СтатусКДействию = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Отклонено)
	|			ТОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.ДатаОтсчета
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.ПериодСобытияВид = ЗНАЧЕНИЕ(Перечисление.Периодичность.Час)
	|					ТОГДА ДОБАВИТЬКДАТЕ(ТаблицаПланируемыхТриггеровИДатРегистрации.ДатаОтсчета, ЧАС, ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.ПериодСобытия * ВЫБОР
	|								КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.МоментСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия)
	|									ТОГДА -1
	|								ИНАЧЕ 1
	|							КОНЕЦ)
	|				КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.ПериодСобытияВид = ЗНАЧЕНИЕ(Перечисление.Периодичность.Минута)
	|					ТОГДА ДОБАВИТЬКДАТЕ(ТаблицаПланируемыхТриггеровИДатРегистрации.ДатаОтсчета, МИНУТА, ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.ПериодСобытия * ВЫБОР
	|								КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.МоментСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия)
	|									ТОГДА -1
	|								ИНАЧЕ 1
	|							КОНЕЦ)
	|				ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|			КОНЕЦ
	|	КОНЕЦ КАК ДатаЗапланированная,
	|	ВЫБОР
	|		КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.СтатусКДействию = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Зарегистрировано)
	|				И ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.УсловиеСобытия В (ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники))
	|				И &ПризнакОтмены = ИСТИНА
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Отклонено)
	|		ИНАЧЕ ТаблицаПланируемыхТриггеровИДатРегистрации.СтатусКДействию
	|	КОНЕЦ КАК СтатусКДействию,
	|	ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие КАК ТриггерноеСобытие,
	|	ТаблицаПланируемыхТриггеровИДатРегистрации.Контрагент КАК Контрагент,
	|	ТаблицаПланируемыхТриггеровИДатРегистрации.ИдентификаторДействия КАК ИдентификаторДействия,
	|	ТаблицаПланируемыхТриггеровИДатРегистрации.Описание КАК Описание,
	|	ВЫБОР
	|		КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.СтатусКДействию = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Зарегистрировано)
	|				И ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.УсловиеСобытия В (ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники))
	|				И &ПризнакОтмены = ИСТИНА
	|			ТОГДА &ПосещениеОтменено
	|		ИНАЧЕ ТаблицаПланируемыхТриггеровИДатРегистрации.Сообщение
	|	КОНЕЦ КАК Сообщение,
	|	&ОбъектСобытия КАК ОбъектСобытия,
	|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке
	|ИЗ
	|	ТаблицаПланируемыхТриггеровИДатРегистрации КАК ТаблицаПланируемыхТриггеровИДатРегистрации
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ТаблицаПланируемыхТриггеровИДатРегистрации.СтатусКДействию = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
	|					И ТаблицаПланируемыхТриггеровИДатРегистрации.ТриггерноеСобытие.УсловиеСобытия В (ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники))
	|				ТОГДА &ПризнакОтмены = ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
		
КонецПроцедуры

// Процедура - Зарегистрировать планируемые события
//
// Параметры:
//  ТаблицаПланируемыхСобытий	 - 	 - 
//
Процедура ЗарегистрироватьПланируемыеСобытия(ЗНАЧ ТаблицаПланируемыхСобытий = Неопределено, РегистрацияНекондиционных = Ложь, ПланДействийТриггерногоСобытия = Неопределено)
	
	ДатаОтклонения = ТекущаяДатаСеанса();
	
	// Регистрация регламентных триггеров со статусом "Отклонено" по которым мы не получили актуальные данные
	Если ТаблицаПланируемыхСобытий = Неопределено И НЕ ПланДействийТриггерногоСобытия = Неопределено Тогда 
		Для Каждого СтрокаПлан Из ПланДействийТриггерногоСобытия Цикл 
			МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
			// Добавляем запись
			ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, СтрокаПлан);
			МенеджерЗаписиСобытия.Период 				= ДатаОтклонения;
			МенеджерЗаписиСобытия.ТриггерноеСобытие 	= СтрокаПлан.ТриггерноеСобытие;
			МенеджерЗаписиСобытия.Контрагент 			= Справочники.Контрагенты.ПустаяСсылка();
			МенеджерЗаписиСобытия.ОбъектСобытия 		= Неопределено;
			МенеджерЗаписиСобытия.ИдентификаторДействия = СтрокаПлан.ИдентификаторДействия;
			МенеджерЗаписиСобытия.РегистрацияПоПодписке	= Ложь;
			МенеджерЗаписиСобытия.Прочитать();
			Если НЕ МенеджерЗаписиСобытия.Выбран() Тогда
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, СтрокаПлан);
				МенеджерЗаписиСобытия.Период 				= ДатаОтклонения;
				МенеджерЗаписиСобытия.ТриггерноеСобытие 	= СтрокаПлан.ТриггерноеСобытие;
				МенеджерЗаписиСобытия.Контрагент 			= Справочники.Контрагенты.ПустаяСсылка();
				МенеджерЗаписиСобытия.ОбъектСобытия 		= Неопределено;
				МенеджерЗаписиСобытия.ИдентификаторДействия = СтрокаПлан.ИдентификаторДействия;
				МенеджерЗаписиСобытия.РегистрацияПоПодписке	= Ложь;
				МенеджерЗаписиСобытия.Статус 				= Перечисления.СтатусыРегистрацииСобытий.Отклонено;
				МенеджерЗаписиСобытия.Сообщение 			= НСтр("ru='Не обнаружено событий для срабатывания триггера на указанный период.';en='No events were detected for triggering the trigger for the specified period.'");
				МенеджерЗаписиСобытия.Записать();
			КонецЕсли;
		КонецЦикла;	
		Возврат;
	КонецЕсли;
	
	Для Каждого ПланируемоеСобытие Из ТаблицаПланируемыхСобытий Цикл
		МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
		Если ПланируемоеСобытие.СтатусКДействию = Перечисления.СтатусыРегистрацииСобытий.Запланировано Тогда  // необходимо запланировать
			Если ПланДействийТриггерногоСобытия = Неопределено Тогда 
				// Добавляем запись
				Если НЕ ЗначениеЗаполнено(ПланируемоеСобытие.ДатаЗапланированная) Тогда 
					Продолжить;
				КонецЕсли;				
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
				МенеджерЗаписиСобытия.Период = ПланируемоеСобытие.ДатаЗапланированная;			
				МенеджерЗаписиСобытия.Прочитать();
				Если НЕ МенеджерЗаписиСобытия.Выбран() Тогда
					ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
					МенеджерЗаписиСобытия.Период 	= ПланируемоеСобытие.ДатаЗапланированная;							
					МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Запланировано;
					МенеджерЗаписиСобытия.Описание 	= ПланируемоеСобытие.Описание;
					МенеджерЗаписиСобытия.Сообщение = ПланируемоеСобытие.Сообщение;				
					МенеджерЗаписиСобытия.Записать();
				ИначеЕсли МенеджерЗаписиСобытия.Статус = Перечисления.СтатусыРегистрацииСобытий.Отклонено Тогда 
					ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
					МенеджерЗаписиСобытия.Период 	= ПланируемоеСобытие.ДатаЗапланированная;							
					МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Запланировано;
					МенеджерЗаписиСобытия.Описание 	= ПланируемоеСобытие.Описание;
					МенеджерЗаписиСобытия.Сообщение = ПланируемоеСобытие.Сообщение;				
					МенеджерЗаписиСобытия.Записать();
				КонецЕсли;
			Иначе 
				Для Каждого СтрокаПлан Из ПланДействийТриггерногоСобытия Цикл 
					МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
					// Добавляем запись
					Если НЕ ЗначениеЗаполнено(ПланируемоеСобытие.ДатаЗапланированная) Тогда 
						Продолжить;
					КонецЕсли;				
					ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
					МенеджерЗаписиСобытия.Период 				= ПланируемоеСобытие.ДатаЗапланированная;
					МенеджерЗаписиСобытия.ИдентификаторДействия = СтрокаПлан.ИдентификаторДействия;
					МенеджерЗаписиСобытия.Прочитать();
					Если НЕ МенеджерЗаписиСобытия.Выбран() Тогда
						ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
						МенеджерЗаписиСобытия.Период 				= ПланируемоеСобытие.ДатаЗапланированная;
						МенеджерЗаписиСобытия.ИдентификаторДействия = СтрокаПлан.ИдентификаторДействия;
						МенеджерЗаписиСобытия.Статус 				= Перечисления.СтатусыРегистрацииСобытий.Запланировано;
						МенеджерЗаписиСобытия.Описание 				= СтрокаПлан.Описание;
						МенеджерЗаписиСобытия.Сообщение 			= СтрокаПлан.Сообщение;				
						МенеджерЗаписиСобытия.Записать();
					КонецЕсли;
				КонецЦикла;	
			КонецЕсли;
		ИначеЕсли ПланируемоеСобытие.СтатусКДействию = Перечисления.СтатусыРегистрацииСобытий.Отклонено Тогда // отклонить запланированное
			// Отклоняем запись как неактуальную
			Если НЕ ЗначениеЗаполнено(ПланируемоеСобытие.ПериодОтбора) И РегистрацияНекондиционных = Ложь Тогда 
				Продолжить;
			КонецЕсли;							
			ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
			МенеджерЗаписиСобытия.Период = ?(ЗначениеЗаполнено(ПланируемоеСобытие.ПериодОтбора), ПланируемоеСобытие.ПериодОтбора, ДатаОтклонения);
			МенеджерЗаписиСобытия.Прочитать();
			Если МенеджерЗаписиСобытия.Выбран() И МенеджерЗаписиСобытия.Статус = Перечисления.СтатусыРегистрацииСобытий.Запланировано Тогда // И РегистрацияНекондиционных = Ложь Тогда 
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
				МенеджерЗаписиСобытия.Период 	= ?(ЗначениеЗаполнено(ПланируемоеСобытие.ПериодОтбора) И РегистрацияНекондиционных, ПланируемоеСобытие.ПериодОтбора, ?(ПланируемоеСобытие.ДатаЗапланированная = Дата(1, 1, 1), ДатаОтклонения, ПланируемоеСобытие.ДатаЗапланированная));
				МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Отклонено;
				МенеджерЗаписиСобытия.Описание 	= ПланируемоеСобытие.Описание;
				МенеджерЗаписиСобытия.Сообщение = ПланируемоеСобытие.Сообщение;								
				МенеджерЗаписиСобытия.Записать();
			ИначеЕсли НЕ МенеджерЗаписиСобытия.Выбран() И РегистрацияНекондиционных = Истина Тогда 
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
				МенеджерЗаписиСобытия.Период 	= ?(ЗначениеЗаполнено(ПланируемоеСобытие.ПериодОтбора), ПланируемоеСобытие.ПериодОтбора, ДатаОтклонения);							
				МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Отклонено;
				МенеджерЗаписиСобытия.Описание 	= ПланируемоеСобытие.Описание;
				МенеджерЗаписиСобытия.Сообщение = ПланируемоеСобытие.Сообщение;				
				МенеджерЗаписиСобытия.Записать();
			КонецЕсли;
		Иначе 
			// Корректируем запись
			Если НЕ ЗначениеЗаполнено(ПланируемоеСобытие.ПериодОтбора) Тогда  
				Продолжить;
			КонецЕсли;							
			ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
			МенеджерЗаписиСобытия.Период = ПланируемоеСобытие.ПериодОтбора;
			МенеджерЗаписиСобытия.Прочитать();
			Если МенеджерЗаписиСобытия.Выбран() И МенеджерЗаписиСобытия.Статус = Перечисления.СтатусыРегистрацииСобытий.Запланировано Тогда 
				Если НЕ ЗначениеЗаполнено(ПланируемоеСобытие.ДатаЗапланированная) Тогда
					// Отклоняем запись как неактуальную
					ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
					МенеджерЗаписиСобытия.Период 	= ДатаОтклонения;
					МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Отклонено;
					МенеджерЗаписиСобытия.Описание 	= ПланируемоеСобытие.Описание;
					МенеджерЗаписиСобытия.Сообщение = ПланируемоеСобытие.Сообщение;								
					МенеджерЗаписиСобытия.Записать();
				ИначеЕсли ПланируемоеСобытие.ДатаЗапланированная <> ПланируемоеСобытие.ПериодОтбора И ПланируемоеСобытие.ДатаЗапланированная >= ТекущаяДатаСеанса() - 60*15 Тогда //+-15 минут
					// Обновляем запись
					ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
					МенеджерЗаписиСобытия.Период 	= ПланируемоеСобытие.ДатаЗапланированная;				
					МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Запланировано;
					МенеджерЗаписиСобытия.Описание 	= ПланируемоеСобытие.Описание;
					МенеджерЗаписиСобытия.Сообщение = ПланируемоеСобытие.Сообщение;								
					МенеджерЗаписиСобытия.Записать();
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Зарегистрировать ошибки регистрации события
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  ТаблицаДанныхОбъекта		 - 	 - 
//  СтрокаДействия				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  СообщениеОбОшибке			 - 	 - 
//
Процедура ЗарегистрироватьОшибкиРегистрацииСобытия(ДанныеТриггера
												, ТаблицаДанныхОбъекта = Неопределено
												, СтруктураСобытия = Неопределено
												, РегистрацияПоПодписке = Ложь
												, РегистрацияЗапланированных = Ложь
												, СообщениеОбОшибке
												, Статус = Неопределено
												, АктуальнаяДатаРегистрации = Неопределено)
	
	ДатаРегистрацииОшибки = ТекущаяДатаСеанса();
	Если СообщениеОбОшибке = НСтр("ru = 'Перенесено в связи с активностью текущего диалога.'") Тогда 
		ДатаРегистрацииОшибки = ДатаРегистрацииОшибки + (60*15);
	КонецЕсли;
	Если ЗначениеЗаполнено(АктуальнаяДатаРегистрации) Тогда 
		ДатаРегистрацииОшибки = АктуальнаяДатаРегистрации;
	КонецЕсли;	
	ЭтоОшибкаПолученияЗначенийПарметровШаблона = СтрНайти(СообщениеОбОшибке, "Ошибка при получении значений параметров для шаблона триггерного события:") <> 0 ИЛИ СтрНайти(СообщениеОбОшибке, "Error getting parameter values for the trigger event template:") <> 0;
	
	Если СтруктураСобытия = Неопределено Тогда 
		Если РегистрацияЗапланированных Тогда 
			Для Каждого ПланируемоеСобытие Из ДанныеТриггера.РеестрЗапланированных Цикл
				СтрокаПлан = ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(ПланируемоеСобытие.ИдентификаторДействия, "ИдентификаторДействия");
				Если СтрокаПлан <> Неопределено И СтрокаПлан.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки Тогда 
					Продолжить;
				КонецЕсли;	
				МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
				МенеджерЗаписиСобытия.Период = ПланируемоеСобытие.Период;
				МенеджерЗаписиСобытия.Прочитать();
				Если МенеджерЗаписиСобытия.Выбран() И МенеджерЗаписиСобытия.Статус = Перечисления.СтатусыРегистрацииСобытий.Запланировано Тогда 
					ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, ПланируемоеСобытие);
					МенеджерЗаписиСобытия.Период 	= ДатаРегистрацииОшибки;
					МенеджерЗаписиСобытия.Статус 	= ?(ЗначениеЗаполнено(Статус), Статус, Перечисления.СтатусыРегистрацииСобытий.ОшибкаРегистрации);
					МенеджерЗаписиСобытия.Сообщение	= СообщениеОбОшибке;
					МенеджерЗаписиСобытия.Записать();
				КонецЕсли;			
			КонецЦикла;
			Если ЭтоОшибкаПолученияЗначенийПарметровШаблона Тогда 
				ДанныеТриггера.ПланДействийТриггерногоСобытия = ДанныеТриггера.ПланДействийТриггерногоСобытия.Скопировать(Новый Структура("ВидДействия", Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки));
			Иначе 
				ДанныеТриггера.ПланДействийТриггерногоСобытия = ДанныеТриггера.ПланДействийТриггерногоСобытия.СкопироватьКолонки();
			КонецЕсли;	
		ИначеЕсли НЕ ТаблицаДанныхОбъекта = Неопределено Тогда 
			ПланДействийТриггерногоСобытия = ДанныеТриггера.ПланДействийТриггерногоСобытия.СкопироватьКолонки();
			Для Каждого РегистрируемоеСобытие Из ТаблицаДанныхОбъекта Цикл 
				Для Каждого СтрокаПлан Из ДанныеТриггера.ПланДействийТриггерногоСобытия Цикл 
					Если ЭтоОшибкаПолученияЗначенийПарметровШаблона И СтрокаПлан.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки Тогда 
						ЗаполнитьЗначенияСвойств(ПланДействийТриггерногоСобытия.Добавить(), СтрокаПлан);
						Продолжить;						
					КонецЕсли;
					МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
					МенеджерЗаписиСобытия.Период 				= ДатаРегистрацииОшибки;
					МенеджерЗаписиСобытия.ТриггерноеСобытие 	= ДанныеТриггера.ТриггерноеСобытие;
					МенеджерЗаписиСобытия.Контрагент 			= РегистрируемоеСобытие.Контрагент;
					МенеджерЗаписиСобытия.ОбъектСобытия 		= РегистрируемоеСобытие.ОбъектСобытия;
					МенеджерЗаписиСобытия.ИдентификаторДействия = СтрокаПлан.ИдентификаторДействия;
					МенеджерЗаписиСобытия.РегистрацияПоПодписке = РегистрацияПоПодписке;
					МенеджерЗаписиСобытия.Прочитать();
					Если НЕ МенеджерЗаписиСобытия.Выбран() Тогда 
						МенеджерЗаписиСобытия.Период 				= ДатаРегистрацииОшибки;
						МенеджерЗаписиСобытия.ТриггерноеСобытие 	= ДанныеТриггера.ТриггерноеСобытие;
						МенеджерЗаписиСобытия.Контрагент 			= РегистрируемоеСобытие.Контрагент;
						МенеджерЗаписиСобытия.ОбъектСобытия 		= РегистрируемоеСобытие.ОбъектСобытия;
						МенеджерЗаписиСобытия.ИдентификаторДействия = СтрокаПлан.ИдентификаторДействия;
						МенеджерЗаписиСобытия.РегистрацияПоПодписке = РегистрацияПоПодписке;
						МенеджерЗаписиСобытия.Статус 				= ?(ЗначениеЗаполнено(Статус), Статус, Перечисления.СтатусыРегистрацииСобытий.ОшибкаРегистрации);
						МенеджерЗаписиСобытия.Описание 				= СтрокаПлан.Описание;
						МенеджерЗаписиСобытия.Сообщение				= СообщениеОбОшибке;
						МенеджерЗаписиСобытия.Записать();
					КонецЕсли;			
				КонецЦикла;
			КонецЦикла;
			ДанныеТриггера.ПланДействийТриггерногоСобытия = ПланДействийТриггерногоСобытия;
		КонецЕсли;
	Иначе 
		Если РегистрацияЗапланированных И СтруктураСобытия.Свойство("СтрокаРеестра") Тогда 
			МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, СтруктураСобытия.СтрокаРеестра);
			МенеджерЗаписиСобытия.Период = СтруктураСобытия.СтрокаРеестра.Период;
			МенеджерЗаписиСобытия.Прочитать();
			Если МенеджерЗаписиСобытия.Выбран() И МенеджерЗаписиСобытия.Статус = Перечисления.СтатусыРегистрацииСобытий.Запланировано Тогда 
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, СтруктураСобытия.СтрокаРеестра);
				МенеджерЗаписиСобытия.Период 	= ДатаРегистрацииОшибки;
				МенеджерЗаписиСобытия.Статус 	= ?(ЗначениеЗаполнено(Статус), Статус, Перечисления.СтатусыРегистрацииСобытий.ОшибкаРегистрации);
				МенеджерЗаписиСобытия.Сообщение	= СообщениеОбОшибке;
				МенеджерЗаписиСобытия.Записать();
			КонецЕсли;			
		Иначе 	
			МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
			МенеджерЗаписиСобытия.Период 				= ДатаРегистрацииОшибки;
			МенеджерЗаписиСобытия.ТриггерноеСобытие 	= ДанныеТриггера.ТриггерноеСобытие;
			МенеджерЗаписиСобытия.Контрагент 			= СтруктураСобытия.СтрокаТаблицыДанных.Контрагент;
			МенеджерЗаписиСобытия.ОбъектСобытия 		= СтруктураСобытия.СтрокаТаблицыДанных.ОбъектСобытия;
			МенеджерЗаписиСобытия.ИдентификаторДействия = СтруктураСобытия.СтрокаПланДействий.ИдентификаторДействия;
			МенеджерЗаписиСобытия.РегистрацияПоПодписке = СтруктураСобытия.СтрокаТаблицыДанных.РегистрацияПоПодписке;
			МенеджерЗаписиСобытия.Прочитать();
			Если НЕ МенеджерЗаписиСобытия.Выбран() Тогда 
				МенеджерЗаписиСобытия.Период 				= ДатаРегистрацииОшибки;
				МенеджерЗаписиСобытия.ТриггерноеСобытие 	= ДанныеТриггера.ТриггерноеСобытие;
				МенеджерЗаписиСобытия.Контрагент 			= СтруктураСобытия.СтрокаТаблицыДанных.Контрагент;
				МенеджерЗаписиСобытия.ОбъектСобытия 		= СтруктураСобытия.СтрокаТаблицыДанных.ОбъектСобытия;
				МенеджерЗаписиСобытия.ИдентификаторДействия = СтруктураСобытия.СтрокаПланДействий.ИдентификаторДействия;
				МенеджерЗаписиСобытия.РегистрацияПоПодписке = СтруктураСобытия.СтрокаТаблицыДанных.РегистрацияПоПодписке;
				МенеджерЗаписиСобытия.Статус 				= ?(ЗначениеЗаполнено(Статус), Статус, Перечисления.СтатусыРегистрацииСобытий.ОшибкаРегистрации);
				МенеджерЗаписиСобытия.Описание 				= СтруктураСобытия.СтрокаПланДействий.Описание;
				МенеджерЗаписиСобытия.Сообщение				= СообщениеОбОшибке;
				МенеджерЗаписиСобытия.Записать();
			КонецЕсли;			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Зарегистрировать смену статусов клиентов
//
// Параметры:
//  ТаблицаУстановленныхСтатусов - 	 - 
//
Процедура ЗарегистрироватьСменуСтатусовКлиентов(ТаблицаУстановленныхСтатусов) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаУстановленныхСтатусов, "ТаблицаУстановленныхСтатусов");
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, Ложь);
	Запрос.УстановитьПараметр("ТекущаяДата"					, ТекущаяДатаСеанса());
	УстановитьПараметрыСообщенийДляТриггерныхДействий(Запрос);
	
	// Подготавливаем текст запроса
	ИнициализироватьТекстЗапросаДляРегистрацииСменыСтатусаКлиентовПерсональнымРегламентнымЗаданием(Запрос);
	
	ПакетныйРезультат 						= Запрос.ВыполнитьПакет();
	ТаблицаТриггеровТекущейРегистрации 		= ПакетныйРезультат[4].Выгрузить();
	ТаблицаДанныхЗапланированныхТриггеров	= ПакетныйРезультат[8].Выгрузить();
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();		
	
	Если НЕ ТаблицаТриггеровТекущейРегистрации = Неопределено И НЕ ТаблицаТриггеровТекущейРегистрации.Количество() = 0 Тогда
		МассивИсключительноРегламентныхТриггеров = Справочники.ТриггерныеСобытия.ПолучитьМассивТриггеров(, Ложь);		
		Для Каждого СтрокаТекущаяРегистрация Из ТаблицаТриггеровТекущейРегистрации Цикл 
			ПараметрыКлюча 			= Новый Структура("Период, Контрагент", СтрокаТекущаяРегистрация.Период, СтрокаТекущаяРегистрация.Контрагент);
			ПараметрыМассив 		= Новый Массив;
			ПараметрыМассив.Добавить(ПараметрыКлюча); 		
			КлючЗаписи 				= Новый("РегистрСведенийКлючЗаписи.СтатусыКонтрагентов", ПараметрыМассив);
			// Регистрируем текущие как по подписке
			ЗарегистрироватьСобытие(СтрокаТекущаяРегистрация, Истина, , КлючЗаписи, МассивИсключительноРегламентныхТриггеров);
		КонецЦикла;
	КонецЕсли;	
	
	// Регистрируем события со статусом "Запланировано",
	// которые должны будут в соответсвующий период активироваться регламентом,
	// а также отклоняем не актуальные строки по очевидным причинам (фильтрации по условиям в триггере будет происходить позже)
	ЗарегистрироватьПланируемыеСобытия(ТаблицаДанныхЗапланированныхТриггеров);
	
КонецПроцедуры

// Процедура - Инициализировать текст запроса для регистрации смены статуса клиентов персональным регламентным заданием
//
// Параметры:
//  Запрос	 - 	 - 
//
Процедура ИнициализироватьТекстЗапросаДляРегистрацииСменыСтатусаКлиентовПерсональнымРегламентнымЗаданием(Запрос)
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТаблицаУстановленныхСтатусов.Период КАК Период,
	               |	ВЫРАЗИТЬ(ТаблицаУстановленныхСтатусов.Контрагент КАК Справочник.Контрагенты) КАК Контрагент,
	               |	ТаблицаУстановленныхСтатусов.Статус КАК Статус
	               |ПОМЕСТИТЬ ТаблицаКонтрагентовСменившихСтатус
	               |ИЗ
	               |	ТаблицаУстановленныхСтатусов КАК ТаблицаУстановленныхСтатусов
	               |ГДЕ
	               |	ТаблицаУстановленныхСтатусов.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |	И ТаблицаУстановленныхСтатусов.Контрагент <> НЕОПРЕДЕЛЕНО
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТриггерныеСобытия.Ссылка КАК ТриггерноеСобытие,
	               |	НЕОПРЕДЕЛЕНО КАК Контрагент,
	               |	ЕСТЬNULL(ВЫРАЗИТЬ(ТриггерныеСобытия.Ссылка.ПереходНаЭтап КАК Перечисление.СтатусыКонтрагентов), ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)) КАК ПереходНаСтатус,
	               |	ТриггерныеСобытия.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ТриггерныеСобытия.Использование КАК Использование,
	               |	ТриггерныеСобытия.ВидДействия КАК ВидДействия,
	               |	ТриггерныеСобытия.Удалено КАК Удалено,
	               |	ТриггерныеСобытия.Ссылка.Активно КАК Активно,
	               |	ТриггерныеСобытия.Описание КАК Описание,
	               |	ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Зарегистрировано) КАК ПланируемыйСтатус
	               |ПОМЕСТИТЬ ТаблицаТриггеров
	               |ИЗ
	               |	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытия
	               |ГДЕ
	               |	ТриггерныеСобытия.Ссылка.ЭтоГруппа = ЛОЖЬ
	               |	И ТриггерныеСобытия.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |	И ТриггерныеСобытия.Ссылка.Активно = ИСТИНА
	               |	И ТриггерныеСобытия.Ссылка.УсловиеСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса)
	               |	И ТриггерныеСобытия.Ссылка.МоментСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТриггерныеСобытия.Ссылка,
	               |	НЕОПРЕДЕЛЕНО,
	               |	ЕСТЬNULL(ВЫРАЗИТЬ(ТриггерныеСобытия.Ссылка.ПереходНаЭтап КАК Перечисление.СтатусыКонтрагентов), ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)),
	               |	ТриггерныеСобытия.ИдентификаторДействия,
	               |	ТриггерныеСобытия.Использование,
	               |	ТриггерныеСобытия.ВидДействия,
	               |	ТриггерныеСобытия.Удалено,
	               |	ТриггерныеСобытия.Ссылка.Активно,
	               |	ТриггерныеСобытия.Описание,
	               |	ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
	               |ИЗ
	               |	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытия
	               |ГДЕ
	               |	ТриггерныеСобытия.Ссылка.ЭтоГруппа = ЛОЖЬ
	               |	И ТриггерныеСобытия.Ссылка.ПометкаУдаления = ЛОЖЬ
	               |	И ТриггерныеСобытия.Ссылка.Активно = ИСТИНА
	               |	И ТриггерныеСобытия.Ссылка.УсловиеСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса)
	               |	И ТриггерныеСобытия.Ссылка.МоментСобытия В (ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия), ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия))
	               |	И ТриггерныеСобытия.Ссылка.ПериодСобытияВид В (ЗНАЧЕНИЕ(Перечисление.Периодичность.Час), ЗНАЧЕНИЕ(Перечисление.Периодичность.Минута))
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаТриггеров.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ЕСТЬNULL(ТаблицаКонтрагентовСменившихСтатус.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент,
	               |	ЕСТЬNULL(ТаблицаКонтрагентовСменившихСтатус.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)) КАК СтатусКонтрагента,
	               |	ЕСТЬNULL(ТаблицаКонтрагентовСменившихСтатус.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК Период,
	               |	ТаблицаТриггеров.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ТаблицаТриггеров.Использование КАК Использование,
	               |	ТаблицаТриггеров.ВидДействия КАК ВидДействия,
	               |	ТаблицаТриггеров.Удалено КАК Удалено,
	               |	ТаблицаТриггеров.Активно КАК Активно,
	               |	ТаблицаТриггеров.Описание КАК Описание,
	               |	ТаблицаТриггеров.ПланируемыйСтатус КАК ПланируемыйСтатус
	               |ПОМЕСТИТЬ ТаблицаТриггеровИКонтрагентов
	               |ИЗ
	               |	ТаблицаТриггеров КАК ТаблицаТриггеров
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКонтрагентовСменившихСтатус КАК ТаблицаКонтрагентовСменившихСтатус
	               |		ПО ТаблицаТриггеров.Контрагент <> ТаблицаКонтрагентовСменившихСтатус.Контрагент
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА ТаблицаТриггеров.ПереходНаСтатус <> ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	               |				ТОГДА ТаблицаТриггеров.ПереходНаСтатус = ТаблицаКонтрагентовСменившихСтатус.Статус
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА ТаблицаТриггеров.ПланируемыйСтатус = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Зарегистрировано)
	               |				ТОГДА НАЧАЛОПЕРИОДА(ТаблицаКонтрагентовСменившихСтатус.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЖурналРегистрацииТриггерныхСобытий.Период КАК Период,
	               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
	               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК ОбъектСобытия,
	               |	ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ЖурналРегистрацииТриггерныхСобытий.Статус КАК Статус
	               |ПОМЕСТИТЬ ТаблицаОтработанныхТриггеров
	               |ИЗ
	               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
	               |ГДЕ
	               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие В
	               |			(ВЫБРАТЬ
	               |				ТаблицаТриггеровИКонтрагентов.ТриггерноеСобытие
	               |			ИЗ
	               |				ТаблицаТриггеровИКонтрагентов
	               |			СГРУППИРОВАТЬ ПО
	               |				ТаблицаТриггеровИКонтрагентов.ТриггерноеСобытие)
	               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент В
	               |			(ВЫБРАТЬ
	               |				ТаблицаТриггеровИКонтрагентов.Контрагент
	               |			ИЗ
	               |				ТаблицаТриггеровИКонтрагентов
	               |			ГДЕ
	               |				ТаблицаТриггеровИКонтрагентов.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка))
	               |	И ЖурналРегистрацииТриггерныхСобытий.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЖурналРегистрацииТриггерныхСобытий.Период,
	               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие,
	               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент,
	               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия,
	               |	ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия,
	               |	ЖурналРегистрацииТриггерныхСобытий.Статус
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаТриггеров.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ТаблицаТриггеров.Контрагент КАК Контрагент,
	               |	ТаблицаТриггеров.Период КАК Период,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.УсловиеСобытия КАК УсловиеСобытия,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПараметрСобытия КАК ПараметрСобытия,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.МоментСобытия КАК МоментСобытия,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПериодСобытияВид КАК ПериодСобытияВид,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПериодСобытия КАК ПериодСобытия,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ВремяСобытия КАК ВремяСобытия,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.СегментКонтрагентов КАК СегментКонтрагентов,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.СегментУслуг КАК СегментУслуг,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ВидСделки КАК ВидСделки,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ВидБонусногоСчета КАК ВидБонусногоСчета,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПереходСЭтапа КАК ПереходСЭтапа,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПереходНаЭтап КАК ПереходНаЭтап,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ТипПолиса КАК ТипПолиса,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.СтатусПациентаПриема КАК СтатусПациентаПриема,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.РезультатПриема КАК РезультатПриема,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.СтатусЗаписи КАК СтатусЗаписи,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ИсточникЗаписи КАК ИсточникЗаписи,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПричинаОтмены КАК ПричинаОтмены,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.Наименование КАК Наименование,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.КодСинхронизации КАК КодСинхронизации,
	               |	НЕОПРЕДЕЛЕНО КАК ПланДействийТриггерногоСобытия,
	               |	НЕОПРЕДЕЛЕНО КАК ТаблицаНекондиционныхДействий,
	               |	НЕОПРЕДЕЛЕНО КАК ПараметрыШаблона,
	               |	НЕОПРЕДЕЛЕНО КАК МассивНеобработанныхКонтрагентов
	               |ИЗ
	               |	ТаблицаТриггеровИКонтрагентов КАК ТаблицаТриггеров
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхТриггеров КАК ТаблицаОтработанныхТриггеров
	               |		ПО (НАЧАЛОПЕРИОДА(ТаблицаТриггеров.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(ТаблицаОтработанныхТриггеров.Период, ДЕНЬ))
	               |			И ТаблицаТриггеров.ТриггерноеСобытие = ТаблицаОтработанныхТриггеров.ТриггерноеСобытие
	               |			И ТаблицаТриггеров.Контрагент = ТаблицаОтработанныхТриггеров.Контрагент
	               |			И ТаблицаТриггеров.СтатусКонтрагента = ТаблицаОтработанныхТриггеров.ОбъектСобытия
	               |ГДЕ
	               |	ТаблицаОтработанныхТриггеров.Контрагент ЕСТЬ NULL
	               |	И ТаблицаТриггеров.ПланируемыйСтатус = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Зарегистрировано)
	               |	И ТаблицаТриггеров.Активно = ИСТИНА
	               |	И ТаблицаТриггеров.Использование = ИСТИНА
	               |	И ТаблицаТриггеров.ВидДействия <> ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.ПустаяСсылка)
	               |	И ТаблицаТриггеров.Удалено = ЛОЖЬ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТаблицаТриггеров.ТриггерноеСобытие,
	               |	ТаблицаТриггеров.Контрагент,
	               |	ТаблицаТриггеров.Период,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.УсловиеСобытия,
	               |	ТаблицаТриггеров.ТриггерноеСобытие.ПараметрСобытия,
