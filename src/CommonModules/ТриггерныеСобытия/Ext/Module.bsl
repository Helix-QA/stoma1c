						СтрокаДействия.Сообщение = НСтр("ru='Сценарий деактивирован!';en='Scenario deactivated!'");
						ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
						МассивНекондиционныхДействий.Добавить(СтрокаДействия);
						Продолжить; 
					ИначеЕсли НЕ СтрокаСценарий.Доступно Тогда 
						СтрокаДействия.Сообщение = НСтр("ru='Сценарий не доступен для данного триггерного события!';en='Scenario not available for this trigger event!'");
						ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
						МассивНекондиционныхДействий.Добавить(СтрокаДействия);
						Продолжить;
					ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаСценарий.ИмяМакетаПредопределенногоСценария) Тогда 
						СтрокаДействия.Сообщение = НСтр("ru='Произвольные сценарии не доступны для данного триггерного события!';en='Custom scripts are not available for this trigger event!'");
						ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
						МассивНекондиционныхДействий.Добавить(СтрокаДействия);
						Продолжить; 						
				    КонецЕсли;
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;
		
		// Проверка для действия "Повысить этап сделки"
		Если СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки Тогда 
			Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидСделки) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан вид сделки!';en='The type of transaction is not specified!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаДействия.ЭтапСделки) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан этап сделки!';en='The transaction stage was omitted!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			КонецЕсли;	
		КонецЕсли;
		
	КонецЦикла;
	
	// Логируем и отсеиваем некондиционные действия (2 этап: для всех триггеров)
	Для Каждого СтрокаНеактуальноеДействие Из МассивНекондиционныхДействий Цикл 
		ТаблицаПланаДействий.Удалить(СтрокаНеактуальноеДействие);
	КонецЦикла;
	// Дополняем стек некондиционных
	Если РегистрацияЗапланированных Тогда
		Для Каждого СтрокаНеактуальноеДействие Из ТаблицаНекондиционныхЗапланированныхДействий Цикл 
			ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаНеактуальноеДействие);
		КонецЦикла;
	КонецЕсли;
	ДанныеТриггера.ТаблицаНекондиционныхДействий = ТаблицаНекондиционныхДействий;
	// ЗарегистрироватьПланируемыеСобытия(ТаблицаНекондиционныхДействий, Истина);
	
	// Обновляем реестр запланированных
	Если РегистрацияЗапланированных Тогда
		РеестрЗапланированных = ДанныеТриггера.РеестрЗапланированных.СкопироватьКолонки();
		Для Каждого СтрокаДействия Из ТаблицаПланаДействий Цикл
			СтрокаЗапланированных = РеестрЗапланированных.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗапланированных, СтрокаДействия);
			СтрокаЗапланированных.Период 			= СтрокаДействия.ПериодОтбора;
			СтрокаЗапланированных.ТриггерноеСобытие = СтрокаДействия.ТриггерноеСобытие;
		КонецЦикла;
		ДанныеТриггера.РеестрЗапланированных 			= РеестрЗапланированных;
		ДанныеТриггера.МассивНеобработанныхКонтрагентов = РеестрЗапланированных.ВыгрузитьКолонку("Контрагент");		
	КонецЕсли;	
	
	ТаблицаПланаДействий.Свернуть("ТриггерноеСобытие, ИдентификаторДействия, Использование, ВидДействия, ВидАдресата, ВидАдресатаРезервный, Адресат, ОтправкаPush, ОтправкаPushWallet, ОтправкаMessenger, ОтправкаSMS, КаналСистемыСообщений, АккаунтВнешнейСистемы, АккаунтSMS, АккаунтEmail, ЗадачаРежимНапоминания, ВидСделки, ЭтапСделки, СоздаватьСделку, КоличествоГенерацийСделок, СценарийЧатБота, ШаблонСообщения, Описание");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаПланаДействий, "ТаблицаПланаДействий");
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТаблицаПланаДействий.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ТаблицаПланаДействий.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ТаблицаПланаДействий.Использование КАК Использование,
	               |	ТаблицаПланаДействий.ВидДействия КАК ВидДействия,
	               |	ТаблицаПланаДействий.ВидАдресата КАК ВидАдресата,
	               |	ТаблицаПланаДействий.ВидАдресатаРезервный КАК ВидАдресатаРезервный,
	               |	ТаблицаПланаДействий.Адресат КАК Адресат,
	               |	ТаблицаПланаДействий.ОтправкаPush КАК ОтправкаPush,
	               |	ТаблицаПланаДействий.ОтправкаPushWallet КАК ОтправкаPushWallet,
	               |	ТаблицаПланаДействий.ОтправкаMessenger КАК ОтправкаMessenger,
	               |	ТаблицаПланаДействий.ОтправкаSMS КАК ОтправкаSMS,
	               |	ТаблицаПланаДействий.КаналСистемыСообщений КАК КаналСистемыСообщений,
	               |	ТаблицаПланаДействий.АккаунтВнешнейСистемы КАК АккаунтВнешнейСистемы,
	               |	ТаблицаПланаДействий.АккаунтSMS КАК АккаунтSMS,
	               |	ТаблицаПланаДействий.АккаунтEmail КАК АккаунтEmail,
	               |	ТаблицаПланаДействий.ЗадачаРежимНапоминания КАК ЗадачаРежимНапоминания,
	               |	ТаблицаПланаДействий.ВидСделки КАК ВидСделки,
	               |	ТаблицаПланаДействий.ЭтапСделки КАК ЭтапСделки,
	               |	ТаблицаПланаДействий.СоздаватьСделку КАК СоздаватьСделку,
	               |	ТаблицаПланаДействий.КоличествоГенерацийСделок КАК КоличествоГенерацийСделок,
	               |	ТаблицаПланаДействий.СценарийЧатБота КАК СценарийЧатБота,
	               |	ВЫБОР
	               |		КОГДА ТаблицаПланаДействий.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки)
	               |				ИЛИ ТаблицаПланаДействий.ШаблонСообщения = ЗНАЧЕНИЕ(Справочник.ШаблоныСообщений.ПустаяСсылка)
	               |				ИЛИ ТаблицаПланаДействий.ШаблонСообщения = НЕОПРЕДЕЛЕНО
	               |			ТОГДА НЕОПРЕДЕЛЕНО
	               |		ИНАЧЕ ТаблицаПланаДействий.ШаблонСообщения
	               |	КОНЕЦ КАК ШаблонСообщения,
	               |	ТаблицаПланаДействий.Описание КАК Описание
	               |ПОМЕСТИТЬ ТаблицаАктуальногоПланаДействий
	               |ИЗ
	               |	ТаблицаПланаДействий КАК ТаблицаПланаДействий
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаАктуальногоПланаДействий.ТриггерноеСобытие КАК ТриггерноеСобытие,
	               |	ТаблицаАктуальногоПланаДействий.ИдентификаторДействия КАК ИдентификаторДействия,
	               |	ТаблицаАктуальногоПланаДействий.Использование КАК Использование,
	               |	ТаблицаАктуальногоПланаДействий.ВидДействия КАК ВидДействия,
	               |	ТаблицаАктуальногоПланаДействий.ВидАдресата КАК ВидАдресата,
	               |	ТаблицаАктуальногоПланаДействий.ВидАдресатаРезервный КАК ВидАдресатаРезервный,
	               |	ТаблицаАктуальногоПланаДействий.Адресат КАК Адресат,
	               |	ТаблицаАктуальногоПланаДействий.ОтправкаPush КАК ОтправкаPush,
	               |	ТаблицаАктуальногоПланаДействий.ОтправкаPushWallet КАК ОтправкаPushWallet,
	               |	ТаблицаАктуальногоПланаДействий.ОтправкаMessenger КАК ОтправкаMessenger,
	               |	ТаблицаАктуальногоПланаДействий.ОтправкаSMS КАК ОтправкаSMS,
	               |	ТаблицаАктуальногоПланаДействий.КаналСистемыСообщений КАК КаналСистемыСообщений,
	               |	ТаблицаАктуальногоПланаДействий.АккаунтВнешнейСистемы КАК АккаунтВнешнейСистемы,
	               |	ТаблицаАктуальногоПланаДействий.АккаунтSMS КАК АккаунтSMS,
	               |	ТаблицаАктуальногоПланаДействий.АккаунтEmail КАК АккаунтEmail,
	               |	ТаблицаАктуальногоПланаДействий.ЗадачаРежимНапоминания КАК ЗадачаРежимНапоминания,
	               |	ТаблицаАктуальногоПланаДействий.ВидСделки КАК ВидСделки,
	               |	ТаблицаАктуальногоПланаДействий.ЭтапСделки КАК ЭтапСделки,
	               |	ТаблицаАктуальногоПланаДействий.СоздаватьСделку КАК СоздаватьСделку,
	               |	ТаблицаАктуальногоПланаДействий.КоличествоГенерацийСделок КАК КоличествоГенерацийСделок,
	               |	ТаблицаАктуальногоПланаДействий.СценарийЧатБота КАК СценарийЧатБота,
	               |	ТаблицаАктуальногоПланаДействий.ШаблонСообщения КАК ШаблонСообщения,
	               |	ТаблицаАктуальногоПланаДействий.Описание КАК Описание,
	               |	ВЫРАЗИТЬ("""" КАК СТРОКА(1024)) КАК Сообщение,
	               |	ЕСТЬNULL(ШаблоныСообщений.Наименование, """") КАК Наименование,
	               |	ЕСТЬNULL(ШаблоныСообщений.СодержаниеМессенджер, """") КАК СодержаниеМессенджер,
	               |	ЕСТЬNULL(ШаблоныСообщений.Содержание, """") КАК Содержание,
	               |	ЕСТЬNULL(ШаблоныСообщений.СодержаниеPush, """") КАК СодержаниеPush,
	               |	ЕСТЬNULL(ШаблоныСообщений.ТекстHTML, """") КАК ТекстHTML,
	               |	ЕСТЬNULL(ШаблоныСообщений.ЗадачаОписание, """") КАК ЗадачаОписание,
	               |	ЕСТЬNULL(ШаблоныСообщений.ЗадачаВидВзаимодействия, ЗНАЧЕНИЕ(Справочник.ВидыВзаимодействий.ПустаяСсылка)) КАК ЗадачаВидВзаимодействия,
	               |	ЕСТЬNULL(ШаблоныСообщений.ЗадачаПериодВыполнения, 0) КАК ЗадачаПериодВыполнения,
	               |	ВЫБОР
	               |		КОГДА ТаблицаАктуальногоПланаДействий.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота)
	               |			ТОГДА ЕСТЬNULL(СценарииЧатБотов.ВремяОтправкиСообщенийС, ДАТАВРЕМЯ(1, 1, 1))
	               |		ИНАЧЕ ЕСТЬNULL(ШаблоныСообщений.SMSВремяНачалаОтправки, ДАТАВРЕМЯ(1, 1, 1))
	               |	КОНЕЦ КАК SMSВремяНачалаОтправки,
	               |	ВЫБОР
	               |		КОГДА ТаблицаАктуальногоПланаДействий.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота)
	               |			ТОГДА ЕСТЬNULL(СценарииЧатБотов.ВремяОтправкиСообщенийПо, ДАТАВРЕМЯ(1, 1, 1))
	               |		ИНАЧЕ ЕСТЬNULL(ШаблоныСообщений.SMSВремяОкончанияОтправки, ДАТАВРЕМЯ(1, 1, 1))
	               |	КОНЕЦ КАК SMSВремяОкончанияОтправки,
	               |	НЕОПРЕДЕЛЕНО КАК ТаблицаЗадействованныхПараметров,
	               |	НЕОПРЕДЕЛЕНО КАК ТаблицаЗначенийПараметров
	               |ИЗ
	               |	ТаблицаАктуальногоПланаДействий КАК ТаблицаАктуальногоПланаДействий
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	               |		ПО ТаблицаАктуальногоПланаДействий.ШаблонСообщения = ШаблоныСообщений.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СценарииЧатБотов КАК СценарииЧатБотов
	               |		ПО ТаблицаАктуальногоПланаДействий.СценарийЧатБота = СценарииЧатБотов.Ссылка";
	
	
	ТаблицаПланаДействий = Запрос.Выполнить().Выгрузить();
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
	Возврат ТаблицаПланаДействий;
	
КонецФункции

// Функция - Получить параметры чат бота
//
// Параметры:
//  ТаблицаПланаДействий - 	 - 
//  УсловиеСобытия		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыЧатБота(ТаблицаПланаДействий, УсловиеСобытия)

	ПараметрыЧатБота = Новый Структура;
	ПараметрыЧатБота.Вставить("РазрешенаРаботаСЧатБотом"				, Ложь);
	ПараметрыЧатБота.Вставить("ИспользуетсяРасширениеМессенджер"		, Ложь);
	ПараметрыЧатБота.Вставить("ТаблицаСценариев"						, Неопределено);
	
	Если НЕ ТаблицаПланаДействий.НайтиСтроки(Новый Структура("ВидДействия", Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота)).Количество() = 0 Тогда 
		ТаблицаВсехВариантовУсловийТриггерныхСобытий 	= ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
		КоллекцияВариантовУсловийТриггерныхСобытий 		= ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий, РазрешенаРаботаСЧатБотом", УсловиеСобытия, Истина));
		ПараметрыЧатБота.Вставить("РазрешенаРаботаСЧатБотом"					, КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0);
		Если ПараметрыЧатБота.РазрешенаРаботаСЧатБотом Тогда 
			ПараметрыЧатБота.Вставить("ИспользуетсяРасширениеМессенджер"		, ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер"));
		КонецЕсли;
		Если ПараметрыЧатБота.ИспользуетсяРасширениеМессенджер Тогда 
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ТриггерноеСобытие"	, УсловиеСобытия);
			Запрос.УстановитьПараметр("МассивСценариев"		, ТаблицаПланаДействий.Скопировать(Новый Структура("ВидДействия", Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота), "СценарийЧатБота").ВыгрузитьКолонку("СценарийЧатБота"));
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	СценарииЧатБотов.Ссылка КАК СценарииЧатБота,
			|	СценарииЧатБотов.ПометкаУдаления КАК ПометкаУдаления,
			|	СценарииЧатБотов.Используется КАК Используется,
			|	СценарииЧатБотов.ИмяМакетаПредопределенногоСценария КАК ИмяМакетаПредопределенногоСценария
			|ПОМЕСТИТЬ ТаблицаСценариев
			|ИЗ
			|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
			|ГДЕ
			|	СценарииЧатБотов.Ссылка В(&МассивСценариев)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	СценарииЧатБотов.Ссылка КАК СценарииЧатБота
			|ПОМЕСТИТЬ ТаблицаДоступныхСценариев
			|ИЗ
			|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
			|ГДЕ
			|	СценарииЧатБотов.ТриггерныеСобытия.ТриггерноеСобытие = &ТриггерноеСобытие
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаблицаСценариев.СценарииЧатБота КАК СценарииЧатБота,
			|	ТаблицаСценариев.ПометкаУдаления КАК ПометкаУдаления,
			|	ТаблицаСценариев.Используется КАК Используется,
			|	ВЫБОР
			|		КОГДА ТаблицаДоступныхСценариев.СценарииЧатБота ЕСТЬ NULL
			|			ТОГДА ЛОЖЬ
			|		ИНАЧЕ ИСТИНА
			|	КОНЕЦ КАК Доступно,
			|	ТаблицаСценариев.ИмяМакетаПредопределенногоСценария КАК ИмяМакетаПредопределенногоСценария
			|ИЗ
			|	ТаблицаСценариев КАК ТаблицаСценариев
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаДоступныхСценариев КАК ТаблицаДоступныхСценариев
			|		ПО ТаблицаСценариев.СценарииЧатБота = ТаблицаДоступныхСценариев.СценарииЧатБота";
			
			ПараметрыЧатБота.Вставить("ТаблицаСценариев", Запрос.Выполнить().Выгрузить());
		КонецЕсли;
	КонецЕсли;

	Возврат ПараметрыЧатБота;
	
КонецФункции

// Функция - Получить данные для регистрации события
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеДляРегистрацииСобытия(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	ТаблицаДанныхОбъекта = Неопределено;
	
	// События по клиентам
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентРегистрация Тогда
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПациентРегистрация(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);				
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентДеньРождения Тогда 
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ДеньРожденияПациента(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);				
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПосещениеКлиники(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_НепосещениеКлиники(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПотенциальныйНеСталНовым Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПотенциальныйНеСталНовым(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПациентСменаСтатуса(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентОкончаниеСрокаДействияСтраховогоПолиса Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПациентОкончаниеСрокаДействияСтраховогоПолиса(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
		
	//// События по картам		
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.КартыУстановкаКартыWalletНовомуКлиенту Тогда
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_УстановкаКартыWalletНовомуКлиенту(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);				
		
	// События по заявкам				
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЗаявкаНеОбработана(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
		
	//// События по сделкам
