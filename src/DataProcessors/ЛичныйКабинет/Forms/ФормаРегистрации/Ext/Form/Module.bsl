&НаСервере
// Процедура - Заполнить данные организации
// 
Процедура ЗаполнитьДанныеОрганизации(ВыбраннаяОрганизация)
	
	ЭтотОбъект.Организация             = ВыбраннаяОрганизация; 
	ЭтотОбъект.ОрганизацияНаименование = ЭтотОбъект.Организация.Наименование;
	ЭтотОбъект.ОрганизацияИНН          = ЭтотОбъект.Организация.ИНН;
	
	// Адрес = УправлениеКонтактнойИнформацией.ЗначенияКонтактнойИнформацииОбъекта(Организация, Перечисления.ТипыКонтактнойИнформации.Адрес);
	АдресЮридический = ПолучитьЮрридическийАдресОрганизацииСтруктурой(ЭтотОбъект.Организация);
	
	Если АдресЮридический <> Неопределено Тогда
		
		ЭтотОбъект.ОрганизацияАдресСтруктурой = Новый ФиксированнаяСтруктура(АдресЮридический);
		
		ЭтотОбъект.КонтактнаяИнформация[2].ЗначенияПолей = АдресЮридический.XML;
		ЭтотОбъект.КонтактнаяИнформация[2].Представление = АдресЮридический.Представление
		
	Иначе
		
		ЭтотОбъект.ОрганизацияАдресСтруктурой = Неопределено;
		
	КонецЕсли;
	
	Для Каждого СтрокаТК ИЗ ЭтотОбъект.Организация.КонтактнаяИнформация Цикл
		
		Если СтрокаТК.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
			
			ЭтотОбъект.КонтактнаяИнформация[0].Представление = СтрокаТК.Представление;
			ЭтотОбъект.КонтактнаяИнформация[0].ЗначенияПолей = СтрокаТК.ЗначенияПолей;
			
		ИначеЕсли СтрокаТК.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
			
			ЭтотОбъект.КонтактнаяИнформация[1].Представление = СтрокаТК.Представление;
			ЭтотОбъект.КонтактнаяИнформация[1].ЗначенияПолей = СтрокаТК.ЗначенияПолей;
	
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Выбрать файл через диалог
Процедура ДекорацияФайлАнкетыОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылка, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПопыткаУстановитьРасширениеРаботыСФайлами = Ложь;
	
	Попытка 
		
		#Если ВебКлиент Тогда
			
			Оповещение = Новый ОписаниеОповещения("ПодключениеРасширенияРаботыСФайламиЗавершение", ЭтотОбъект);
			НачатьПодключениеРасширенияРаботыСФайлами(Оповещение);
			
		#Иначе
			
			ДиалогВыбора                    = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
			ДиалогВыбора.ПолноеИмяФайла     = ?(НавигационнаяСсылка <> "выберите файл", НавигационнаяСсылка,"");
			ДиалогВыбора.Фильтр             = "(*.bmp;*.jpg;*.jpeg;*.png)|*.bmp;*.jpg;*.jpeg;*.png";
			ДиалогВыбора.МножественныйВыбор = Ложь;
			
			ДиалогВыбора.Показать(Новый ОписаниеОповещения("ВыборФайлаАнкетыЗавершение", ЭтотОбъект));

		#КонецЕсли
		
	Исключение
		
		#Если ВебКлиент Тогда
			
			ПопыткаУстановитьРасширениеРаботыСФайлами = Истина;
			Оповещение = Новый ОписаниеОповещения("УстановкуРасширенияРаботыСФайламиЗавершение", ЭтотОбъект);
			НачатьУстановкуРасширенияРаботыСФайлами(Оповещение);
			Возврат;
			
		#Иначе
			
			ПоказатьИнформациюОбОшибке(ИнформацияОбОшибке());
			
		#КонецЕсли

	КонецПопытки;
	
КонецПроцедуры

// Процедура - Установку расширения работы с файлами завершение
// 
// Параметры:
//  ДопПараметры - 	 - 
// 
&НаКлиенте
Процедура УстановкуРасширенияРаботыСФайламиЗавершение(ДопПараметры) Экспорт
	
	Оповещение = Новый ОписаниеОповещения("ПодключениеРасширенияРаботыСФайламиЗавершение", ЭтотОбъект);
	НачатьПодключениеРасширенияРаботыСФайлами(Оповещение);
		
КонецПроцедуры

// Процедура - Подключение расширения работы с файлами завершение
// 
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
// 
&НаКлиенте
Процедура ПодключениеРасширенияРаботыСФайламиЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Ложь Тогда
		
		#Если ВебКлиент Тогда
			
			Если ПопыткаУстановитьРасширениеРаботыСФайлами <> Истина Тогда
				
				ПопыткаУстановитьРасширениеРаботыСФайлами = Истина;
				Оповещение = Новый ОписаниеОповещения("УстановкуРасширенияРаботыСФайламиЗавершение", ЭтотОбъект);
				НачатьУстановкуРасширенияРаботыСФайлами(Оповещение);
				Возврат;
				
			Иначе
				
				ПоказатьПредупреждение(,"Не удалось установить рсширение работы с файлами");
				Возврат;
				
			КонецЕсли;
			
		#КонецЕсли

	КонецЕсли;
	
	ДиалогВыбора                    = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.ПолноеИмяФайла     = ?(НавигационнаяСсылка <> "выберите файл", НавигационнаяСсылка,"");
	ДиалогВыбора.Фильтр             = "(*.bmp;*.jpg;*.jpeg;*.png)|*.bmp;*.jpg;*.jpeg;*.png";
	ДиалогВыбора.МножественныйВыбор = Ложь;
	
	ДиалогВыбора.Показать(Новый ОписаниеОповещения("ВыборФайлаАнкетыЗавершение", ЭтотОбъект));
	
КонецПроцедуры

// Процедура - Выбор файла анкеты завершение
// 
// Параметры:
//  Результат	 - 	 - 
//  ДопПарамеры	 - 	 - 
// 
&НаКлиенте
Процедура ВыборФайлаАнкетыЗавершение(ПутьКФайлу, ДопПарамеры) Экспорт
	
	Если ЗначениеЗаполнено(ПутьКФайлу) Тогда
			
		Оповещение = Новый ОписаниеОповещения("СозданиеДвоичныхДанныхИзФайлаЗавершение", ЭтотОбъект, Новый Структура("ПутьКФайлу", ПутьКФайлу[0]));
		НачатьСозданиеДвоичныхДанныхИзФайла(Оповещение, ПутьКФайлу[0]); 
		
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Создание двоичных данных из файла завершение
// 
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
// 
&НаКлиенте
Процедура СозданиеДвоичныхДанныхИзФайлаЗавершение(ДвоичныеДанные, ДопПараметры) Экспорт
	
	Если ДвоичныеДанные <> Неопределено Тогда
		
		Если ДвоичныеДанные.Размер() > 5242880 Тогда
			
			ДвоичныеДанные = Неопределено;
			ФорматированноеПредупреждение("Размер файла не должен превышать 5Мб!");
			
		Иначе
			
			ЭтотОбъект.ДвоичныеДанныеФайлаАнкеты = ДвоичныеДанные; 
			ИмяФайла = Сред(ДопПараметры.ПутьКФайлу, СтрНайти(ДопПараметры.ПутьКФайлу,"\",НаправлениеПоиска.СКонца) + 1);
			Элементы.ДекорацияФайлАнкеты.Заголовок = Новый ФорматированнаяСтрока("Фотография(скриншот) анкеты: ", Новый ФорматированнаяСтрока(ИмяФайла,,,,ДопПараметры.ПутьКФайлу));
			
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры

