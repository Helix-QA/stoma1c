// Функция, вернет индекс имени элемента.
//
Функция ПолучитьИндексИмениЭлемента(Наименование)
	
	НомерСимвола = СтрНайти(Наименование, "_");
	Возврат ?(НомерСимвола > 0, Число(Прав(Наименование, СтрДлина(Наименование) - НомерСимвола)), Неопределено);
	
