		//|	НомерЗаказаПриема";
		
#КонецОбласти
		
	ИначеЕсли ТипЗнч(ОтборДокумент) = Тип("ДокументСсылка.Прием") Тогда
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПриемЛечение.Ссылка,
		|	ПриемЛечение.Зуб,
		|	ПриемЛечение.Номенклатура,
		|	СУММА(ПриемЛечение.КоличествоУпаковок) КАК Количество,
		|	СУММА(ПриемЛечение.Сумма) КАК Сумма,
		|	ПриемЛечение.Цена,
		|	ПриемЛечение.ПроцентСкидкиНаценки,
		|	ПриемЛечение.СуммаАвтоматическойСкидкиНаценки,
		|	ПриемЛечение.КлючСтроки
		|ИЗ
		|	Документ.Прием.Лечение КАК ПриемЛечение
		|ГДЕ
		|	ПриемЛечение.Ссылка = &ОтборДокумент
		|	И (ПриемЛечение.ДокументАванса = ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка)
		|			ИЛИ ПриемЛечение.ДокументАванса = ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка)
		|			ИЛИ ПриемЛечение.ДокументАванса = НЕОПРЕДЕЛЕНО)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриемЛечение.Ссылка,
		|	ПриемЛечение.Номенклатура,
		|	ПриемЛечение.Зуб,
		|	ПриемЛечение.Цена,
		|	ПриемЛечение.ПроцентСкидкиНаценки,
		|	ПриемЛечение.СуммаАвтоматическойСкидкиНаценки,
		|	ПриемЛечение.КлючСтроки";		
	КонецЕсли;	
	
	Запрос.УстановитьПараметр("ОтборПериод", ТекущаяДата());
	Запрос.УстановитьПараметр("ОтборДокумент", ОтборДокумент);
	Запрос.УстановитьПараметр("МассивУжеДобавленныхСтрок", ?(МассивУжеДобавленныхСтрок = Неопределено, Новый Массив, МассивУжеДобавленныхСтрок));
	
	УсловиеНоменклатураСотрудника = 
	"ВЫБРАТЬ
	|	УслугиСотрудника.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|ГДЕ
	|	УслугиСотрудника.Сотрудник = &Сотрудник
	|	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеНоменклатураСотрудника", УсловиеНоменклатураСотрудника);
	
	Запрос.УстановитьПараметр("Сотрудник", ЭтотОбъект.ОтборСотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ЭтотОбъект.ОтборСтруктурнаяЕдиница);
	
	РезЗапроса = Запрос.Выполнить().Выгрузить();
	ТаблицаУслугИТоваров.Очистить();
	Для Каждого СтрокаР ИЗ РезЗапроса Цикл
		НоваяСтрока = ТаблицаУслугИТоваров.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаР);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти  

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗадолженностей

//////////////////////////////////////////////////////////////////////////////////////////////
//////////////////// ПРОЦЕДУРЫ И ФУНКЦИИ ОБСЛУЖИВАНИЯ ТАБЛИЦЫ ЗАДОЛЖЕННОСТЕЙ /////////////////

&НаКлиенте
// Обработчик команды печати справки
//
Процедура ДобавитьУслугиВПрием(Команда)

	МассивВозврата = новый Массив;
	Для Каждого СтрокаТ ИЗ ТаблицаУслугИТоваров Цикл
		Если СтрокаТ.ПризнакВыбора Тогда
			МассивВозврата.Добавить(Новый Структура("КлючСтроки, Номенклатура", СтрокаТ.КлючСтроки, СтрокаТ.Номенклатура));
		КонецЕсли;
	КонецЦикла;
	ЭтаФорма.Закрыть(МассивВозврата);
	
КонецПроцедуры  

&НаКлиенте
// При изменении выбора состояния галочки флажков
//
Процедура ТаблицаЗадолженностейСнятьГалочки(Команда)	
	
	Для Каждого СтрокаТабличнойЧасти Из ТаблицаУслугИТоваров Цикл
		Если Элементы.ТаблицаДокументовПродажи.ПроверитьСтроку(СтрокаТабличнойЧасти.ПолучитьИдентификатор()) Тогда
			СтрокаТабличнойЧасти.ПризнакВыбора = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	СуммаВыбранныхСтрок = 0;
	
КонецПроцедуры

&НаКлиенте
// При изменении выбора состояния галочки флажков
//
Процедура ТаблицаЗадолженностейУстановитьГалочки(Команда)
	
	СуммаВыбранныхСтрок = 0;
	Для Каждого СтрокаТабличнойЧасти Из ТаблицаУслугИТоваров Цикл
		Если Элементы.ТаблицаДокументовПродажи.ПроверитьСтроку(СтрокаТабличнойЧасти.ПолучитьИдентификатор()) Тогда
			СтрокаТабличнойЧасти.ПризнакВыбора = Истина;
			СуммаВыбранныхСтрок = СуммаВыбранныхСтрок + СтрокаТабличнойЧасти.Сумма;
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
//
//
Процедура ПосчитатьСуммуВыбранныхСтрок()
	
	СуммаВыбранныхСтрок = 0;
	Для Каждого СтрокаТабличнойЧасти Из ТаблицаУслугИТоваров Цикл
		Если СтрокаТабличнойЧасти.ПризнакВыбора Тогда 
			СуммаВыбранныхСтрок = СуммаВыбранныхСтрок + СтрокаТабличнойЧасти.Сумма;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении"
//
Процедура ТаблицаДокументовПродажиПризнакВыбораПриИзменении(Элемент)

	ПосчитатьСуммуВыбранныхСтрок();	
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы

&НаКлиенте
// Обработчик вызова обновления таблицы задолженностей
//
Процедура ТаблицаЗадолженностейОбновить(Команда)		
	
	ОбновитьФормуСервер();
	
КонецПроцедуры

&НаКлиенте
// Отмена выбора
Процедура Отмена(Команда)
	Закрыть(Неопределено);
КонецПроцедуры

#КонецОбласти
