// Процедура очищает и заполняет ТЧ ДниРаботы сотрудниками.
//
Процедура ДобавитьСотрудниковНаСервере(ПоГруппеСотрудников = Неопределено)
	
	Если Не ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) ИЛИ Не ЗначениеЗаполнено(Объект.Период) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Структурная единица и месяц должны быть заполнены!'; en = 'Structural unit and month must be filled'"));
		Возврат;
	КонецЕсли;
	
	// Заполняем сотрудников
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Период", Объект.Период);
	Запрос.УстановитьПараметр("ПоГруппеСотрудников", ?(ЗначениеЗаполнено(ПоГруппеСотрудников), ПоГруппеСотрудников, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.Сотрудник КАК Сотрудник,
	|	НастройкиСотрудников.Сотрудник.Должность КАК Должность,	            
	|	НастройкиСотрудников.ДатаУвольнения КАК ДатаУвольнения
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НастройкиСотрудников.Сотрудник.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА НастройкиСотрудников.ДатаУвольнения > ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ТОГДА НастройкиСотрудников.ДатаУвольнения > &Период
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ПоГруппеСотрудников <> НЕОПРЕДЕЛЕНО
	|				ТОГДА НастройкиСотрудников.Сотрудник.Ссылка В ИЕРАРХИИ (&ПоГруппеСотрудников)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|УПОРЯДОЧИТЬ ПО
	|	НастройкиСотрудников.Сотрудник.Наименование";  
	
	РезультатТаблица = Запрос.Выполнить().Выгрузить();
	
	// Заполним значения в совпадающих колонках.
	Для Каждого СтрокаТЗ Из РезультатТаблица Цикл
		Если Объект.ДниРаботы.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЗ.Сотрудник)).Количество() = 0 Тогда
			НоваяСтрока = Объект.ДниРаботы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ,"Сотрудник, Должность");
		КонецЕсли;
	КонецЦикла;
	
	// Helix = ЗащитаСервер.СоздатьОбъект("Helix");
	Helix.ОбновитьПредставлениеДняВКолонках(Элементы.ДниРаботы, Новый Структура("Месяц", Объект.Период));
	
КонецПроцедуры

