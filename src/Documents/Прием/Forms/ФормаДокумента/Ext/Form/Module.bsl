	ЗначенияСФормы.Вставить("Реквизит"             , ДополнительныеПараметры.Реквизит);
	ЗначенияСФормы.Вставить("РеквизитИД"           , ДополнительныеПараметры.РеквизитИД);
	ЗначенияСФормы.Вставить("ПустоеПолеВыбор"      , ДополнительныеПараметры.ПустоеПолеВыбор);
	ЗначенияСФормы.Вставить("ПустоеПолеДобавить"   , ДополнительныеПараметры.ПустоеПолеДобавить);
	ЗначенияСФормы.Вставить("МассивВыбранныхЗубов" , МассивВыбранныхЗубов);
	ЗначенияСФормы.Вставить("ПривязанЗуб"          , ДополнительныеПараметры.ПривязанЗуб);
	ЗначенияСФормы.Вставить("СсылкаЭлемент"        , ДополнительныеПараметры.СсылкаЭлемент);
	ЗначенияСФормы.Вставить("ЗначениеРеквизита"    , ЗначениеРеквизита);
	
	ПослеВыбораЗначенияОбследования(ЗначенияСФормы);		
	
