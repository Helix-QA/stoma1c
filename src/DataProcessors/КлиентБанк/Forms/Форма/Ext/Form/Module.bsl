// Процедура - Выбрать файл загрузки выгрузки
//
// Параметры:
//  ЭтоВыгрузка	 - 	 - 
//
Процедура ВыбратьФайлЗагрузкиВыгрузки(ЭтоВыгрузка)
	
	Режим = РежимДиалогаВыбораФайла.Открытие;
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(Режим);
	ДиалогОткрытияФайла.ПолноеИмяФайла = Объект.ФайлВыгрузки;
	Фильтр = "Текстовый файл(*.txt)|*.txt";
	ДиалогОткрытияФайла.Фильтр = Фильтр;
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	ДиалогОткрытияФайла.Заголовок = НСтр("ru = 'Выберите файл'");
	
	ДиалогОткрытияФайла.Показать(Новый ОписаниеОповещения("ВыбратьФайлЗагрузкиВыгрузкиЗавершение", ЭтотОбъект, Новый Структура("ДиалогОткрытияФайла, ЭтоВыгрузка", ДиалогОткрытияФайла, ЭтоВыгрузка)));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбрать файл загрузки выгрузки завершение
//
// Параметры:
//  ВыбранныеФайлы			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыбратьФайлЗагрузкиВыгрузкиЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	ДиалогОткрытияФайла = ДополнительныеПараметры.ДиалогОткрытияФайла;
	ЭтоВыгрузка = ДополнительныеПараметры.ЭтоВыгрузка;

	Если (ВыбранныеФайлы <> Неопределено) Тогда
		
		Если ЭтоВыгрузка Тогда
			Объект.ФайлВыгрузки = ДиалогОткрытияФайла.ПолноеИмяФайла;
		Иначе 
			Объект.ФайлЗагрузки = ДиалогОткрытияФайла.ПолноеИмяФайла;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры 

