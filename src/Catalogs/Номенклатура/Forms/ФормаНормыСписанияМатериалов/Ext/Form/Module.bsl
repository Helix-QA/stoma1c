
#Область ОписаниеПеременных

&НаКлиенте
Перем ВопросЗадан; // Переменная - ВопросЗадан

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РазрешеноРедактирование = НЕ ПравоДоступа("Редактирование", Метаданные.РегистрыСведений.НормыСписанияМатериалов);
	
	ЭтаФорма.ТолькоПросмотр = РазрешеноРедактирование;
	Элементы.ТаблицаНормыСписанияМатериалов.ТолькоПросмотр = РазрешеноРедактирование;
		
	Если Параметры.Свойство("Номенклатура")
		И ЗначениеЗаполнено(Параметры.Номенклатура) 
		И ОбщегоНазначения.ПолучитьЗначениеРеквизита(Параметры.Номенклатура, "ТипНоменклатуры") = Перечисления.ТипыНоменклатуры.Услуга Тогда
		
		ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		ОтборСтруктурнаяЕдиница   = ТекущаяСтруктурнаяЕдиница;
		Номенклатура              = Параметры.Номенклатура; 	
		ТекущийСотрудник          = ПараметрыСеанса.ТекущийПользователь;
		
		ВидимостьЭлементов = Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
		Элементы.ГруппаПечатьТехКарты.Видимость             = ВидимостьЭлементов;
		Элементы.ГруппаНормыСписанияМатериалов.Видимость    = ВидимостьЭлементов; 
				                           			
		СписокСтруктурныхЕдиниц.ЗагрузитьЗначения(ПолучитьСписокСтруктурныхЕдиниц(ТекущаяСтруктурнаяЕдиница));
		
		ПриСозданииПриКопированииНаСервере();	
		
		Элементы.ГруппаВсплывающаяИндивидуальныеНормыСписания.Заголовок	= Строка(ТекущаяСтруктурнаяЕдиница);		
		
	КонецЕсли;  
	
	ОтборМассивВыбранныеЗначения = Новый Массив;
	ОтборМассивРазрешенныхТипов  = Новый Массив;
	
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Материал);		
	
	Если ЗначениеЗаполнено(ОтборМассивРазрешенныхТипов) Тогда
		
		ОтборСписокРазрешенныхТипов.ЗагрузитьЗначения(ОтборМассивРазрешенныхТипов);
		
		ПараметрВыбора   = Новый ПараметрВыбора("Отбор.ТипНоменклатуры", ОтборМассивРазрешенныхТипов);
		
		МассивПараметров = Новый Массив();
		МассивПараметров.Добавить(ПараметрВыбора);
		НовыеПараметры   = Новый ФиксированныйМассив(МассивПараметров);
		
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ОтборМассивВыбранныеЗначения) Тогда
		ОтборСписокВыбранныеЗначения.ЗагрузитьЗначения(ОтборМассивВыбранныеЗначения);
	КонецЕсли;  	
	
	ЗаполнитьНастройкиПодбораНоменклатуры();
	
КонецПроцедуры
       
&НаКлиенте
// Процедура - При при открытии
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
// 
Процедура ПриОткрытии(Отказ)
	
	Если НастройкиЗагружены = Ложь Тогда
		
		Если ТаблицаВыбранныхЗначенийИспользовать = Ложь Тогда
			ЭтотОбъект.ОтображатьДеревом = Ложь;
			СоздатьДинамическийСписокПодбораНоменклатур("ГруппаВыбораНоменклатура", ОтображениеТаблицы.Список,, Истина, "Список");
		Иначе
			ВидЦенМатериалов = ?(НЕ ЗначениеЗаполнено(ВидЦенМатериалов), ПредопределенноеЗначение("Справочник.ВидыЦен.Закупочная"), ВидЦенМатериалов);
			ЗаполнитьЗначенияПриВыбореМатериалов();
		КонецЕсли;
		
	КонецЕсли;   
	
	УстановитьВидимость();
	
КонецПроцедуры      

&НаКлиенте
// Процедура, обработчик события "Перед закрытием".
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы = Истина Или Модифицированность = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПередЗакрытиемНеЗадаватьВопрос Тогда
		
		Если ВопросЗадан <> Истина Тогда
			Оповещение = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект);
			ПоказатьВопрос(Оповещение, "Нормы списания были изменены. Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена);
		КонецЕсли;
		
		ВопросЗадан = Истина;
		
		Отказ = Истина;
		Возврат;
		
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
// Процедура, перед закрытием завершение.
//
Процедура ПередЗакрытиемЗавершение(Ответ, Параметры) Экспорт
	
	ВопросЗадан = Ложь;
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		МатериалыСохранены = СохранениеМатериалов();
		
		Если МатериалыСохранены = Истина Тогда
			
			ПередЗакрытиемНеЗадаватьВопрос = Истина;
			Закрыть(); 
			
		КонецЕсли;
		
	ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда
		
		ПередЗакрытиемНеЗадаватьВопрос = Истина;
		Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

  #Область ОбработкаСобытийЭлементовШапкиФормы

// Процедура - Печать тех карты нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ПечатьТехКартыНажатие(Элемент)
	
	Если Модифицированность = Истина Тогда
		
		Оповещение = Новый ОписаниеОповещения("ПечатьТехКартыНажатиеЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, "Данные были изменены. Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена);
		Возврат;
		
	КонецЕсли;
	ПараметрКоманды = Новый Массив;   
	ПараметрКоманды.Добавить(Номенклатура); 
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
	"Справочник.Номенклатура",
	"ТехнологическаяКарта",
	ПараметрКоманды,
	Номенклатура,
	Новый Структура("ОтборСтруктурнаяЕдиница", 
	?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), 
	                     ОтборСтруктурнаяЕдиница, 
	                     ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущаяСтруктурнаяЕдиница"))));	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик события "ПриИзменении"
//
Процедура ТипНормСписанияПриИзменении(Элемент)
	
	УстановитьВидимость();
	
	СписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм = ПолучитьСписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм();
	
	ОтборСтруктурнаяЕдиница = ?(ОбщиеНормыСписания, ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка"), ТекущаяСтруктурнаяЕдиница);
	
	Если Не ОбщиеНормыСписания Тогда 
		МассивСтрокНормСписания = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ТекущаяСтруктурнаяЕдиница));
		Если МассивСтрокНормСписания.Количество() = 0 Тогда
			ДополнитьТаблицуНормСписанияМатериалов(ТекущаяСтруктурнаяЕдиница, ТаблицаНормыСписанияМатериалов);
		КонецЕсли;
	КонецЕсли;
	
	ВывестиЭлементыНормыСписанияМатериалов(ОтборСтруктурнаяЕдиница);
	
	//Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Процедура - Скопировать нормы
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура СкопироватьНормы(Команда)
	
	МассивСЕСНормами = Новый Массив;
	Для Каждого СтрокаТЧ Из ТаблицаНормыСписанияМатериалов Цикл
		
		Если СтрокаТЧ.СтруктурнаяЕдиница <> ОтборСтруктурнаяЕдиница Тогда
			
			Если МассивСЕСНормами.Найти(СтрокаТЧ.СтруктурнаяЕдиница) = Неопределено Тогда
				МассивСЕСНормами.Добавить(СтрокаТЧ.СтруктурнаяЕдиница);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивСЕСНормами.Количество() <> 0 Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("СкопироватьНормыЗавершение", ЭтаФорма, Новый Структура("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница));
		ПараметрыОткрытия  = Новый Структура("Отбор", Новый Структура("Ссылка", МассивСЕСНормами));	
		ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаВыбора", ПараметрыОткрытия,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаНормыСписанияМатериалов

// Процедура - Таблица нормы списания материалов материал начало выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеВыбора		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловМатериалНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка   = Ложь;
	ТекущиеДанные          = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные;
	СтруктураПараметры     = Новый Структура();	
	МассивРазрешенныхТипов = Новый Массив;
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал"));
	
	СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов", МассивРазрешенныхТипов); 
	СтруктураПараметры.Вставить("Заголовок"                  , "Выберите материал");	   
	СтруктураПараметры.Вставить("ВидЦен"                     , ПредопределенноеЗначение("Справочник.ВидыЦен.Закупочная"));
	СтруктураПараметры.Вставить("СтруктурнаяЕдиница"         , ОтборСтруктурнаяЕдиница); 
	СтруктураПараметры.Вставить("ВключитьСнятыеСпродажи"     , Ложь);              	
	СтруктураПараметры.Вставить("ВыбранныеЗначения"			 , Номенклатура); 
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НоменклатураНачалоВыбораЗавершение", ЭтаФорма, Новый Структура("ТекущиеДанные", ТекущиеДанные));	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры", СтруктураПараметры,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов материал при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловМатериалПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Материал) Тогда
		
		ТекущиеДанные.ХарактеристикиИспользуются = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущиеДанные.Материал, "ИспользоватьПартии");
		
	Иначе
		
		ТекущиеДанные.Партия        = Неопределено;
		ТекущиеДанные.Упаковка      = Неопределено;
		ТекущиеДанные.СкладСписания = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов партия начало выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеВыбора		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловПартияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные; 
	Если ЗначениеЗаполнено(ТекущиеДанные.Материал) Тогда
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Владелец",ТекущиеДанные.Материал);
		ПараметрыОтбора.Вставить("СтруктурнаяЕдиница",ОбщегоНазначения.ТекущаяСтруктурнаяЕдиница());
		ПараметрыОтбора.Вставить("Номенклатура", ТекущиеДанные.Материал);			
		ПараметрыОтбора.Вставить("Дата", ТекущаяДата());
		ОписаниеОповещения = Новый ОписаниеОповещения("ТаблицаНормыСписанияМатериаловПартияНачалоВыбораЗавершение", ЭтаФорма, Новый Структура("ТекущиеДанные",ТекущиеДанные));
		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора",ПараметрыОтбора,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура -  Таблица нормы списания материалов партия автоподбор
//
Процедура ТаблицаНормыСписанияМатериаловПартияАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = СтрДлина(Текст) = 0;
	
	ТекущийМатериал = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные.Материал;
	
	Если СтрДлина(Текст) > 0 И ЗначениеЗаполнено(ТекущийМатериал) Тогда
		ДанныеВыбора = ПолучитьСписокПартий(Текст, ТекущийМатериал);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, получает список партий соответствующих указанному тексту поиска.
//
Функция ПолучитьСписокПартий(Текст = "", Материал)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПартииНоменклатуры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	|ГДЕ
	|	ПартииНоменклатуры.Владелец = &Владелец
	|	И ПартииНоменклатуры.Наименование ПОДОБНО &Текст");
	
	Запрос.УстановитьПараметр("Текст"	, "%" + Текст + "%");
	Запрос.УстановитьПараметр("Владелец", Материал);
	
	ДанныеВыбора = Новый СписокЗначений;
	ДанныеВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
	Возврат ДанныеВыбора;
	
КонецФункции

// Процедура - Партия начало выбора подключаемый завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловПартияНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено 
		И ТипЗнч(Результат) = Тип("Массив") 
		И Результат.Количество() <> 0 Тогда
		
		ТекущиеДанные      = Параметры.ТекущиеДанные;
		Партия             = Результат[0];
		
		Если ТекущиеДанные.Партия <> Партия Тогда
			
			ТекущиеДанные.Партия = Партия;
			
		КонецЕсли;
		Модифицированность = Истина;
		
	КонецЕсли;		
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов упаковка начало выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеВыбора		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловУпаковкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбработкаТабличныхЧастейКлиент.ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные, "Материал");	
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов упаковка при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловУпаковкаПриИзменении(Элемент)
	
	ТекущиеДанные				= Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные;
	ТекущиеДанные.СкладСписания = ?(ТекущиеДанные.СписыватьМатериал = 1, ТекущиеДанные.СкладСписания, Неопределено);
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов включать в стоимость услуги при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловВключатьВСтоимостьУслугиПриИзменении(Элемент)
	
	ТекущиеДанные        = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные; 
	ТекущиеДанные.ВидЦен = ?(ТекущиеДанные.ВключатьВСтоимостьУслуги = Истина, ТекущиеДанные.ВидЦен, Неопределено);
	
	Если ТекущиеДанные.ВключатьВСтоимостьУслуги = Истина И Не ЗначениеЗаполнено(ТекущиеДанные.ВидЦен) Тогда
		ТекущиеДанные.ВидЦен = ПредопределенноеЗначение("Справочник.ВидыЦен.Закупочная");
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов списывать материал при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловСписыватьМатериалПриИзменении(Элемент)
	
	ТекущиеДанные               = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные; 
	Если ТекущиеДанные.СписыватьМатериал = 1 Тогда
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.СкладСписания) Тогда
			ТекущиеДанные.СкладСписания = ?(ОбщиеНормыСписания, ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка"), ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОтборСтруктурнаяЕдиница, "ОсновнойСклад"));
		КонецЕсли;
	Иначе
		ТекущиеДанные.СкладСписания = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Таблица нормы списания материалов при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловПриИзменении(Элемент)
	
	Модифицированность = Истина;   
	
КонецПроцедуры

// Процедура - Таблица нормы списания материалов при начале редактирования
//
// Параметры:
//  Элемент		 - 	 - 
//  НоваяСтрока	 - 	 - 
//  Копирование	 - 	 - 
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		
		ТекущиеДанные                    = Элементы.ТаблицаНормыСписанияМатериалов.ТекущиеДанные;
		ТекущиеДанные.СтруктурнаяЕдиница = ОтборСтруктурнаяЕдиница;
		ТекущиеДанные.Количество         = 1;
		ТекущиеДанные.СписыватьМатериал  = 1;//?(Не ОбщиеНормыСписания, 1, 0);
		ТекущиеДанные.СкладСписания      = ?(Не ОбщиеНормыСписания, ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОтборСтруктурнаяЕдиница, "ОсновнойСклад"), ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка"));
				
		Если СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(ОтборСтруктурнаяЕдиница) <> Неопределено Тогда
			СписокСтруктурныхЕдиницБезНормСписания.Удалить(СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(ОтборСтруктурнаяЕдиница));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриОкончанииРедактирования".
//
Процедура ТаблицаНормыСписанияМатериаловПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ОбновитьБлокИндивидуальныхНормСписания();
	УстановитьВидимость();

КонецПроцедуры

// Процедура - Обработчик события "ПослеУдаления"
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловПослеУдаления(Элемент)
	
	Если Не ОбщиеНормыСписания 
		И ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ТекущаяСтруктурнаяЕдиница)).Количество() = 0 
		И СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(ТекущаяСтруктурнаяЕдиница) = Неопределено Тогда
		
		Оповещение = Новый ОписаниеОповещения("ТаблицаНормыСписанияМатериаловПослеУдаленияЗавершение", ЭтотОбъект, Новый Структура("СтруктурнаяЕдиница", ТекущаяСтруктурнаяЕдиница));
		ПоказатьВопрос(Оповещение, "Для " + ТекущаяСтруктурнаяЕдиница + " не будут использоваться нормы списания? ", РежимДиалогаВопрос.ДаНетОтмена);
		
	КонецЕсли;
	
	ОбновитьБлокИндивидуальныхНормСписания();
	УстановитьВидимость();

КонецПроцедуры    

// Процедура - обработчик оповещения.
//
&НаКлиенте
Процедура ТаблицаНормыСписанияМатериаловПослеУдаленияЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		СписокСтруктурныхЕдиницБезНормСписания.Добавить(?(Параметры.Свойство("СтруктурнаяЕдиница"), Параметры.СтруктурнаяЕдиница, ТекущаяСтруктурнаяЕдиница));
		ОбновитьБлокИндивидуальныхНормСписания();
		УстановитьВидимость();
		
	КонецЕсли;
	
КонецПроцедуры  

#Область УдалениеНормСписания

&НаКлиенте
// Процедура обработчик оповещения "ПослеУдаленияНормыСписания"
//
Процедура ПослеУдаленияНормыСписания(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УдалениеНормСписания();		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
// Процедура удаления норм списания из регистра.
//
Процедура УдалениеНормСписания()
		
	НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();	                                                          	
	НаборЗаписей.Отбор.Номенклатура.Установить(ЭтотОбъект.Номенклатура);	
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(ОтборСтруктурнаяЕдиница);
	НаборЗаписей.Записать(Истина);
	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, при создании при копировании на сервере.
//
Процедура ПриСозданииПриКопированииНаСервере(УслугаКопирования = Неопределено)
	
	Результат = ПолучитьНормыСписанияМатериалов(?(ЗначениеЗаполнено(УслугаКопирования), УслугаКопирования, Номенклатура), ОтборСтруктурнаяЕдиница);
	
	СписокСтруктурныхЕдиницБезНормСписания.ЗагрузитьЗначения(Результат.МассивСтруктурныхЕдиницНеИспользующихНормыСписания);
	
	Если Результат.ИндивидуальныеНормыСписания.Количество() = 0
		И СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(ТекущаяСтруктурнаяЕдиница) = Неопределено Тогда // заданы только общие
		
		ОбщиеНормыСписания = Истина;
		ОтборСтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	Иначе
		ОбщиеНормыСписания = Ложь;
	КонецЕсли;       		
	
	ТаблицаНормыСписанияМатериалов.Загрузить(Результат.НормыСписания);
	
	ВывестиЭлементыНормыСписанияМатериалов(ОтборСтруктурнаяЕдиница);
	СформироватьБлокИндивидуальныхНормСписания();	
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Печать тех карты нажатие завершение
//
// Параметры:
//  Ответ		 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ПечатьТехКартыНажатиеЗавершение(Ответ, Параметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ЗаписьРазрешена = Истина;
		
	ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда
		
		ЗаписьРазрешена = Ложь;
		
	КонецЕсли;
	
	Если ЗаписьРазрешена = Истина Тогда
		
		МатериалыСохранены      = СохранениеМатериалов();
		Если МатериалыСохранены = Истина Тогда
			
			ПараметрКоманды = Новый Массив;   
			ПараметрКоманды.Добавить(Номенклатура); 
			УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
			"Справочник.Номенклатура",
			"ТехнологическаяКарта",
			ПараметрКоманды,
			Номенклатура,
			Новый Структура("ОтборСтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница));	
			
		КонецЕсли;	
		
	ИначеЕсли ЗаписьРазрешена = Ложь Тогда
		
		ПараметрКоманды = Новый Массив;   
		ПараметрКоманды.Добавить(Номенклатура); 
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
		"Справочник.Номенклатура",
		"ТехнологическаяКарта",
		ПараметрКоманды,
		Номенклатура,
		Новый Структура("ОтборСтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница));
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте 
// Функция - Сохранение материалов
// 
// Возвращаемое значение:
//   - 
//
Функция СохранениеМатериалов(УслугаКопирования = Неопределено)
	
	ТаблицаНормыСписанияМатериалов.Сортировать("СтруктурнаяЕдиница");
	Для Каждого СтрокаТЧ Из ТаблицаНормыСписанияМатериалов Цикл   
				
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Материал) Тогда
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
				ПоказатьПредупреждение(, "Необходимо заполнить материал по клинике " + СтрокаТЧ.СтруктурнаяЕдиница);
			Иначе
				ПоказатьПредупреждение(, "Необходимо заполнить материал общих норм списания");
			КонецЕсли;
			Возврат Ложь;
			
		ИначеЕсли СтрокаТЧ.СписыватьМатериал = 1 
			И Не ЗначениеЗаполнено(СтрокаТЧ.СкладСписания) 
			И ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
			
			ПоказатьПредупреждение(, "Необходимо заполнить склад списания по клинике " + СтрокаТЧ.СтруктурнаяЕдиница + " по материалу " + СтрокаТЧ.Материал);
			Возврат Ложь;
			
		ИначеЕсли СтрокаТЧ.Количество = 0 Тогда
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
				ПоказатьПредупреждение(, "Количество материалов списания должно быть больше 0 по клинике " + СтрокаТЧ.СтруктурнаяЕдиница + " по материалу " + СтрокаТЧ.Материал);
			Иначе
				ПоказатьПредупреждение(, "Количество материалов списания должно быть больше 0 для общих норм списания по материалу " + СтрокаТЧ.Материал);
			КонецЕсли;
			
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(УслугаКопирования) Тогда
		
		СохранитьЗначенияВРегистрНормыСписанияМатериалов(УслугаКопирования);
	Иначе
		
		СохранитьЗначенияВРегистрНормыСписанияМатериалов();
		
	КонецЕсли;
	
	Модифицированность = Ложь;
	
	Возврат Истина;
	
КонецФункции

// Процедура - Получить нормы списания материалов
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Номенклатура		 - 	 - 
//
&НаСервереБезКонтекста
Функция ПолучитьНормыСписанияМатериалов(Номенклатура, СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ СтруктурныеЕдиницы
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НормыСписанияМатериалов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НормыСписанияМатериалов.Материал КАК Материал,
	|	НормыСписанияМатериалов.Упаковка КАК Упаковка,
	|	НормыСписанияМатериалов.Партия КАК Партия,
	|	НормыСписанияМатериалов.СкладСписания КАК СкладСписания,
	|	НормыСписанияМатериалов.Количество КАК Количество,
	|	НЕ НормыСписанияМатериалов.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(НормыСписанияМатериалов.СкладСписания) = ТИП(Справочник.Склады)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СписыватьМатериал,
	|	НормыСписанияМатериалов.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	НормыСписанияМатериалов.ВидЦен КАК ВидЦен,
	|	НормыСписанияМатериалов.Материал.ИспользоватьПартии КАК ХарактеристикиИспользуются,
	|	НормыСписанияМатериалов.НормыСписанияНеИспользуются КАК НормыСписанияНеИспользуются
	|ПОМЕСТИТЬ ВременнаяТаблица_НормыСписания
	|ИЗ
	|	РегистрСведений.НормыСписанияМатериалов КАК НормыСписанияМатериалов
	|ГДЕ
	|	НормыСписанияМатериалов.Номенклатура = &Номенклатура
	|	И НормыСписанияМатериалов.СтруктурнаяЕдиница В
	|			(ВЫБРАТЬ
	|				СтруктурныеЕдиницы.Ссылка
	|			ИЗ
	|				СтруктурныеЕдиницы)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Материал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВременнаяТаблица_НормыСписания.Материал КАК Материал,
	|	ВременнаяТаблица_НормыСписания.Упаковка КАК Упаковка,
	|	ВременнаяТаблица_НормыСписания.Партия КАК Партия,
	|	ВременнаяТаблица_НормыСписания.СкладСписания КАК СкладСписания,
	|	ВременнаяТаблица_НормыСписания.Количество КАК Количество,
	|	ВременнаяТаблица_НормыСписания.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	ВременнаяТаблица_НормыСписания.СписыватьМатериал КАК СписыватьМатериал,
	|	ВременнаяТаблица_НормыСписания.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	ВременнаяТаблица_НормыСписания.ВидЦен КАК ВидЦен,
	|	ВременнаяТаблица_НормыСписания.Материал.ИспользоватьПартии КАК ХарактеристикиИспользуются
	|ИЗ
	|	ВременнаяТаблица_НормыСписания КАК ВременнаяТаблица_НормыСписания
	|ГДЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НЕ ВременнаяТаблица_НормыСписания.НормыСписанияНеИспользуются
	|
	|УПОРЯДОЧИТЬ ПО
	|	Материал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВременнаяТаблица_НормыСписания.Материал КАК Материал,
	|	ВременнаяТаблица_НормыСписания.Упаковка КАК Упаковка,
	|	ВременнаяТаблица_НормыСписания.Партия КАК Партия,
	|	ВременнаяТаблица_НормыСписания.СкладСписания КАК СкладСписания,
	|	ВременнаяТаблица_НормыСписания.Количество КАК Количество,
	|	ВременнаяТаблица_НормыСписания.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	ВременнаяТаблица_НормыСписания.СписыватьМатериал КАК СписыватьМатериал,
	|	ВременнаяТаблица_НормыСписания.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	ВременнаяТаблица_НормыСписания.ВидЦен КАК ВидЦен,
	|	ВременнаяТаблица_НормыСписания.Материал.ИспользоватьПартии КАК ХарактеристикиИспользуются
	|ИЗ
	|	ВременнаяТаблица_НормыСписания КАК ВременнаяТаблица_НормыСписания
	|ГДЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|	И НЕ ВременнаяТаблица_НормыСписания.НормыСписанияНеИспользуются
	|
	|УПОРЯДОЧИТЬ ПО
	|	Материал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВременнаяТаблица_НормыСписания.Материал КАК Материал,
	|	ВременнаяТаблица_НормыСписания.Упаковка КАК Упаковка,
	|	ВременнаяТаблица_НормыСписания.Партия КАК Партия,
	|	ВременнаяТаблица_НормыСписания.СкладСписания КАК СкладСписания,
	|	ВременнаяТаблица_НормыСписания.Количество КАК Количество,
	|	ВременнаяТаблица_НормыСписания.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	|	ВременнаяТаблица_НормыСписания.СписыватьМатериал КАК СписыватьМатериал,
	|	ВременнаяТаблица_НормыСписания.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	|	ВременнаяТаблица_НормыСписания.ВидЦен КАК ВидЦен,
	|	ВременнаяТаблица_НормыСписания.Материал.ИспользоватьПартии КАК ХарактеристикиИспользуются
	|ИЗ
	|	ВременнаяТаблица_НормыСписания КАК ВременнаяТаблица_НормыСписания
	|ГДЕ
	|	НЕ ВременнаяТаблица_НормыСписания.НормыСписанияНеИспользуются
	|
	|УПОРЯДОЧИТЬ ПО
	|	Материал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	ВременнаяТаблица_НормыСписания КАК ВременнаяТаблица_НормыСписания
	|ГДЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница <> ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|	И НЕ ВременнаяТаблица_НормыСписания.НормыСписанияНеИспользуются
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблица_НормыСписания.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	ВременнаяТаблица_НормыСписания КАК ВременнаяТаблица_НормыСписания
	|ГДЕ
	|	ВременнаяТаблица_НормыСписания.НормыСписанияНеИспользуются = ИСТИНА");
	
	Запрос.УстановитьПараметр("Номенклатура"		, Номенклатура);	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
		
	Пакет = Запрос.ВыполнитьПакет();
	
	Структура = Новый Структура;                 	
	Структура.Вставить("ИндивидуальныеНормыСписания"						, Пакет[2].Выгрузить());
	Структура.Вставить("ОбщиеНормыСписания"									, Пакет[3].Выгрузить());
	Структура.Вставить("НормыСписания"										, Пакет[4].Выгрузить());   
	Структура.Вставить("МассивСтруктурныхЕдиниц"							, Пакет[5].Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница"));
	Структура.Вставить("МассивСтруктурныхЕдиницНеИспользующихНормыСписания"	, Пакет[6].Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница"));
	
	Возврат Структура;
	
КонецФункции

&НаСервереБезКонтекста
// Процедура - Получить нормы списания материалов
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Номенклатура		 - 	 - 
//
Функция ПолучитьНормыСписанияМатериаловДляКопирования(Номенклатура)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	НормыСписанияМатериалов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
				   |	НормыСписанияМатериалов.Материал КАК Материал,
	               |	НормыСписанияМатериалов.Упаковка КАК Упаковка,
	               |	НормыСписанияМатериалов.Партия КАК Партия,
	               |	НормыСписанияМатериалов.Количество КАК Количество,
	               |	ВЫБОР
	               |		КОГДА ТИПЗНАЧЕНИЯ(НормыСписанияМатериалов.СкладСписания) = ТИП(Справочник.Склады)
	               |			ТОГДА 1
	               |		ИНАЧЕ 0
	               |	КОНЕЦ КАК СписыватьМатериал,
	               |	НормыСписанияМатериалов.СкладСписания КАК СкладСписания,
	               |	НормыСписанияМатериалов.НеЗависитОтКоличестваУслуг КАК НеЗависитОтКоличестваУслуг,
	               |	НормыСписанияМатериалов.ВключатьВСтоимостьУслуги КАК ВключатьВСтоимостьУслуги,
	               |	НормыСписанияМатериалов.ВидЦен КАК ВидЦен, 
	               |	НормыСписанияМатериалов.НормыСписанияНеИспользуются КАК НормыСписанияНеИспользуются,
	               |	НормыСписанияМатериалов.Материал.ИспользоватьПартии КАК ХарактеристикиИспользуются
	               |ИЗ
	               |	РегистрСведений.НормыСписанияМатериалов КАК НормыСписанияМатериалов
	               |ГДЕ
	               |	НормыСписанияМатериалов.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Пакет = Запрос.ВыполнитьПакет();
	
	Результат = Новый Структура;                 	
	Результат.Вставить("НормыСписанияДляКопирования", Пакет[0].Выгрузить());
	
	Возврат Результат;
	
КонецФункции

// Функция - Получить список структурных единиц
//
// Параметры:
//  ТекущаяСтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
&НаСервереБезКонтекста
Функция ПолучитьСписокСтруктурныхЕдиниц(ТекущаяСтруктурнаяЕдиница)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА СтруктурныеЕдиницы.Ссылка = &ТекущаяСтруктурныеЕдиницы
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК Порядок,
	|	СтруктурныеЕдиницы.Наименование КАК Наименование
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок,
	|	Наименование");
	
	Запрос.УстановитьПараметр("ТекущаяСтруктурныеЕдиницы", ТекущаяСтруктурнаяЕдиница);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Процедура - Вывести элементы номы списания материалов
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//
&НаСервере
Процедура ВывестиЭлементыНормыСписанияМатериалов(СтруктурнаяЕдиница)
	
	ОтборПоСтруктурнойЕдинице = Новый ФиксированнаяСтруктура("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Элементы.ТаблицаНормыСписанияМатериалов.ОтборСтрок = ОтборПоСтруктурнойЕдинице;
	
КонецПроцедуры

// Процедура - Сохранить значения в регистр нормы списания материалов
//
&НаСервере
Процедура СохранитьЗначенияВРегистрНормыСписанияМатериалов(УслугаКопирования = Неопределено)
		
	СписокСтруктурныхЕдиницОбщие = СписокСтруктурныхЕдиниц;
	
	Если СписокСтруктурныхЕдиницОбщие.НайтиПоЗначению(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда
		СписокСтруктурныхЕдиницОбщие.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
	КонецЕсли;
	
	УдалитьИндивидуальныеНормыСписанияРавныеОбщим(ТаблицаНормыСписанияМатериалов);     
	
	Для Каждого СтрокаСписка Из СписокСтруктурныхЕдиницОбщие Цикл
		
		СтруктурнаяЕдиница   = СтрокаСписка.Значение;
		МассивНайденныхСтрок = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница));	
		
		НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
		//НаборЗаписей.Отбор.Калькуляция.Установить(ЭтотОбъект.ОтборКалькуляции);
		НаборЗаписей.Записать(Истина); 
				
		Для Каждого СтрокаДанных Из МассивНайденныхСтрок Цикл
			
			НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
			
			НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
			НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
			НаборЗаписей.Отбор.Материал.Установить(СтрокаДанных.Материал);
			НаборЗаписей.Отбор.Партия.Установить(СтрокаДанных.Партия); 
			
			НоваяСтрока                            = НаборЗаписей.Добавить(); 			
			НоваяСтрока.СтруктурнаяЕдиница         = СтруктурнаяЕдиница;
			НоваяСтрока.Номенклатура               = Номенклатура;
			НоваяСтрока.Материал                   = СтрокаДанных.Материал;
			НоваяСтрока.Партия                     = СтрокаДанных.Партия;
			Если ЗначениеЗаполнено(СтрокаДанных.СкладСписания) Тогда
				НоваяСтрока.СкладСписания          = СтрокаДанных.СкладСписания;
			Иначе
				Если СтрокаДанных.СписыватьМатериал = 1 Тогда
					НоваяСтрока.СкладСписания = Справочники.Склады.ПустаяСсылка();
				ИначеЕсли СтрокаДанных.СписыватьМатериал = 2 Тогда
					НоваяСтрока.СкладСписания = Справочники.Ресурсы.ПустаяСсылка();
				Иначе
					НоваяСтрока.СкладСписания = Справочники.Сотрудники.ПустаяСсылка();
				КонецЕсли;
			КонецЕсли;
			НоваяСтрока.Упаковка                    = СтрокаДанных.Упаковка;
			НоваяСтрока.НеЗависитОтКоличестваУслуг  = Не СтрокаДанных.НеЗависитОтКоличестваУслуг;    
			НоваяСтрока.Количество                  = СтрокаДанных.Количество;
			НоваяСтрока.ВключатьВСтоимостьУслуги    = СтрокаДанных.ВключатьВСтоимостьУслуги; 
			НоваяСтрока.ВидЦен                      = СтрокаДанных.ВидЦен;	
			НоваяСтрока.НормыСписанияНеИспользуются = ?(СтрокаДанных.Количество = 0, Истина, Ложь);  						
			НаборЗаписей.Записать(Истина);
			
		КонецЦикла;
					
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Сохранить значения в регистр нормы списания материалов
//
Процедура СохранитьСкопированныеЗначенияНормСписанияВРегистр(УслугаКопирования = Неопределено, СтруктурнаяЕдиница)	
		
	РезультатВыборки   = ПолучитьНормыСписанияМатериаловДляКопирования(УслугаКопирования);
	
	ТаблицаНормыСписанияМатериаловДляКопирования.Загрузить(РезультатВыборки.НормыСписанияДляКопирования);
	МассивНайденныхСтрок = ТаблицаНормыСписанияМатериаловДляКопирования.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница));				
	
	Для Каждого СтрокаДанных Из МассивНайденныхСтрок Цикл	  		                    
		
		НаборЗаписей = РегистрыСведений.НормыСписанияМатериалов.СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
		НаборЗаписей.Отбор.Материал.Установить(СтрокаДанных.Материал);			
		НаборЗаписей.Отбор.Партия.Установить(СтрокаДанных.Партия);
		
		НоваяСтрока                            = НаборЗаписей.Добавить();		
		НоваяСтрока.СтруктурнаяЕдиница         = СтруктурнаяЕдиница;
		НоваяСтрока.Номенклатура               = Номенклатура;
		НоваяСтрока.Материал                   = СтрокаДанных.Материал;
		НоваяСтрока.Партия                     = СтрокаДанных.Партия;
		Если ЗначениеЗаполнено(СтрокаДанных.СкладСписания) Тогда
			НоваяСтрока.СкладСписания          = СтрокаДанных.СкладСписания;
		Иначе 
			Если СтрокаДанных.СписыватьМатериал = 1 Тогда
				НоваяСтрока.СкладСписания = Справочники.Склады.ПустаяСсылка();
			Иначе
				НоваяСтрока.СкладСписания =	Справочники.Сотрудники.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
		НоваяСтрока.Упаковка                    = СтрокаДанных.Упаковка;		
		НоваяСтрока.НеЗависитОтКоличестваУслуг  = СтрокаДанных.НеЗависитОтКоличестваУслуг; 				
		НоваяСтрока.Количество                  = СтрокаДанных.Количество;
		НоваяСтрока.ВключатьВСтоимостьУслуги    = СтрокаДанных.ВключатьВСтоимостьУслуги; 
		НоваяСтрока.ВидЦен                      = СтрокаДанных.ВидЦен;	
		НоваяСтрока.НормыСписанияНеИспользуются = ?(СтрокаДанных.Количество = 0, Истина, Ложь);  		
		
		НаборЗаписей.Записать(Истина);
		
	КонецЦикла;
	
КонецПроцедуры


// Процедура - удаляет индивидуальные нормы списания, равные общим нормам списания.
//
&НаСервере
Процедура УдалитьИндивидуальныеНормыСписанияРавныеОбщим(ТаблицаНормыСписанияМатериалов)
	
	МассивУдаляемыхСтрок = Новый Массив;
	
	ТаблицаОбщихНормСписания = ТаблицаНормыСписанияМатериалов.Выгрузить(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка")));	
	
	Для Каждого СтрокаСписка Из СписокСтруктурныхЕдиниц Цикл    
		
		Если Не ЗначениеЗаполнено(СтрокаСписка.Значение) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктурнаяЕдиница   = СтрокаСписка.Значение;  		
		Если НЕ ЗаданыИндивидуальныеНормыСписанияНаСервере(СтруктурнаяЕдиница, ТаблицаОбщихНормСписания) Тогда // ТаблицаОбщихНормСписания
			МассивНайденныхСтрок = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница));	
			Для Каждого СтрокаМ Из МассивНайденныхСтрок Цикл
				МассивУдаляемыхСтрок.Добавить(СтрокаМ);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаМ Из МассивУдаляемыхСтрок Цикл
		ТаблицаНормыСписанияМатериалов.Удалить(СтрокаМ);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте 
// Функция - проверяет заданы ли индивидуальные нормы списания (отличные от общих).
//
Функция ЗаданыИндивидуальныеНормыСписания(СтруктурнаяЕдиница, ТаблицаОбщихНормСписания)
	
	// изменил клиентскую - измени серверную.	    
	ФлагОбщиеНормыСписания = Истина;

	Если СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(СтруктурнаяЕдиница) <> Неопределено Тогда
		Возврат Истина;      
	КонецЕсли;
	
	НормыСписанияСтруктурнойЕдиницы = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница));
	Если НормыСписанияСтруктурнойЕдиницы.Количество() = 0 Тогда
		Возврат НЕ ФлагОбщиеНормыСписания;
	КонецЕсли;         	
	
	Для Каждого СтрокаТЗ Из ТаблицаОбщихНормСписания Цикл
		
		СтруктураСоответствия = Новый Структура("СтруктурнаяЕдиница, Материал, Партия, Количество, ВидЦен, ВключатьВСтоимостьУслуги, Упаковка, НеЗависитОтКоличестваУслуг, СписыватьМатериал");
		ЗаполнитьЗначенияСвойств(СтруктураСоответствия, СтрокаТЗ, , "СтруктурнаяЕдиница");
		СтруктураСоответствия.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
		Если СтрокаТЗ.СписыватьМатериал = 1 Тогда
			СтруктураСоответствия.Вставить("СкладСписания", ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "ОсновнойСклад"));
		КонецЕсли;
		
		МассивНайденныхСтрок = ТаблицаНормыСписанияМатериалов.НайтиСтроки(СтруктураСоответствия);	
		Если МассивНайденныхСтрок.Количество() = 0 Тогда
			ФлагОбщиеНормыСписания = Ложь;	
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	// проверяем есть ли нормы списания, не включенные в общие.
	МассивМатериаловОбщихНормСписания = Новый Массив;
	Для Каждого ЭлементМ Из ТаблицаОбщихНормСписания Цикл
		МассивМатериаловОбщихНормСписания.Добавить(ЭлементМ.Материал);		
	КонецЦикла;
	
	Для Каждого ЭлементМ Из НормыСписанияСтруктурнойЕдиницы Цикл
		
		Если МассивМатериаловОбщихНормСписания.Найти(ЭлементМ.Материал) = Неопределено Тогда
			ФлагОбщиеНормыСписания = Ложь;	
			Прервать;
		КонецЕсли;   
		
	КонецЦикла;
	
	Возврат НЕ ФлагОбщиеНормыСписания;	
	   		
КонецФункции

