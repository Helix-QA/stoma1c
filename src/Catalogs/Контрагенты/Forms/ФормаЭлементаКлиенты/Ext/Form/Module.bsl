// Процедура - Взаимодействие SMS Отправить сервер.
//
Процедура ВзаимодействиеSMSPushОтправитьСервер()
	
	ОписаниеОшибки = "";
	
	ДокументSMSPushРассылкаСоздан = СоздатьДокументSMSPushРассылкаИОтправитьНаСервере(
		Объект.Ссылка, 
		ЭтотОбъект.ВзаимодействиеSMSНомерТелефона, 
		ЭтотОбъект.ВзаимодействиеSMSТекст, 
		ОписаниеОшибки,
		ЭтотОбъект.ТипСообщенияPushSMSМессенджер,
		ЭтотОбъект.ВнешняяСистемаМессенджера,
		ЭтотОбъект.ВнешняяСистемаМП,
		ЭтотОбъект.ВнешняяСистемаWallet,	
		ТипЗнч(ЭтотОбъект.ВзаимодействиеSMSНомерТелефона) = Тип("Строка"),
		ЭтаФорма.УникальныйИдентификатор); 
	
	Если ДокументSMSPushРассылкаСоздан = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	СформироватьИсториюВзаимодействияСКлиентом();
	
	ЭтотОбъект.ВзаимодействиеSMSТекст         = "";
	ЭтотОбъект.ВзаимодействиеSMSНомерТелефона = "";
	
	СнятьВидимостьВсплывающихГруппСервер("SMS");	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, создает документ  SMS/Push Рассылка и отправляет его.
//
Функция СоздатьДокументSMSPushРассылкаИОтправитьНаСервере(
		Получатель,
		НомерТелефона,
		Содержание,
		ОписаниеОшибки,
		ТипСобытия, 
		ВнешняяСистемаМессенджера, 
		ВНМП, 
		ВНWallet, 
		ПушНаНомерТелефона = Истина,
		УИДФормы)
	
	СтруктураПолучателя = Новый Структура("Получатель, Карта, НомерТелефона, СервисРассылки", Получатель);
	
	Если ПушНаНомерТелефона Тогда
		СтруктураПолучателя.НомерТелефона = НомерТелефона;	
	Иначе
		СтруктураПолучателя.Карта         = НомерТелефона;
	КонецЕсли;
	
	СтруктураПолучателя.СервисРассылки = ?(ПушНаНомерТелефона, ВНМП, ВНWallet);
	
	МассивСтруктурПолучателей = Новый_Массив(СтруктураПолучателя);
	
	Возврат Документы.РассылкаСообщений.СоздатьДокументSMSPushРассылкаИОтправить(
		МассивСтруктурПолучателей, 
		Содержание, 
		ОписаниеОшибки, 
		ТипСобытия, 
		ВнешняяСистемаМессенджера,
		ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница,
		УИДФормы);

КонецФункции

