// Вызывается при первоначальном заполнении базы.
//
Процедура ПервоначальноеЗаполнениеИБ() Экспорт
	
	Если Справочники.СтруктурныеЕдиницы.Выбрать().Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	// Обновляем список сервисов СМС рассылки
	Справочники.СервисыРассылки.УстановитьСервисSMSПоУмолчанию();
	
	// Шаблоны СМС
	Справочники.ШаблоныСообщений.ЗаполнитьПредопределенныеШаблоныSMS();
	
	// Создадим структуру папок Контрагентов
	Справочники.Контрагенты.ЗаполнитьПоУмолчанию(); 
	
	// Создадим структуру папок Сотрудников
	Справочники.Сотрудники.ЗаполнитьПоУмолчанию();
	
	// Создадим структуру папок Номенклатуры
	СоздатьПредопределенныеГруппыНоменклатуры();
	
	// Виды сделок
	ОбновитьПредопределнныеВидыСделок(); 
	
	//// Заполнение статей затрат.
	// ПрописатьВидыОперацийПредопределеннымСтатьям();
	
	// Создаем виды взаимодействий по умолчанию
