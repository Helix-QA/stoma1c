
#Область _____ОБРАБОТЧИКИ_СОБЫТИЙ_ФОРМЫ_____

&НаСервере
// Процедура, обработчик события ПриСозданииНаСервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Если ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП() = Истина Тогда
		Элементы.ЗаменитьМенеджераВСделках.Видимость = Ложь;
	КонецЕсли;
	
	ЗаполнениеЭлементовФормы();
	УстановитьВидмостьВсплывающейГруппы(ЭтотОбъект.Действие);
	 
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ПриЗакрытии.
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	// Задаем параметры закрытия формы.
	ПараметрыЗакрытияФормы = Новый Структура;
	ПараметрыЗакрытияФормы.Вставить("Действие", ЭтотОбъект.Действие);
	
	// Закрытие формы.
	Закрыть(ПараметрыЗакрытияФормы);
	
КонецПроцедуры

#КонецОбласти

#Область _ОБРАБОТЧИКИ_СОБЫТИЙ_ЭЛЕМЕНТОВ_ФОРМЫ_

&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора".
//
Процедура ДействиеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	УстановитьВидмостьВсплывающейГруппы(ВыбранноеЗначение);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ДействияДобавить".
//
Процедура ДействияДобавить(Команда)
	
	// УдалитьПустыеСтрокиСотрудников();
	НоваяСтрока = ЭтотОбъект.ТаблицаДействия.Добавить();	
	Элементы.ТаблицаДействия.ТекущаяСтрока = ЭтотОбъект.ТаблицаДействия.Индекс(НоваяСтрока);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ДействияУдалить".
//
Процедура ДействияУдалить(Команда)
	
	ТекущиеДанные = Элементы.ТаблицаДействия.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		ЭтотОбъект.ТаблицаДействия.Удалить(ТекущиеДанные);
		ЗаполнитьПроцентомСтрокиТЗ();

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команд "ПрименитьКВыделенным" и "ПрименитьКоВсем".
//
Процедура Применить(Команда)
	
	// Задаем параметры закрытия формы.
	ПараметрыЗакрытияФормы = Новый Структура;
	
	ПараметрыЗакрытияФормы.Вставить("Действие"			 , ЭтотОбъект.Действие);
	ПараметрыЗакрытияФормы.Вставить("ИмяВыбраннойКоманды", Команда.Имя);
	
	Если ЭтотОбъект.Действие = "Исполнитель" Тогда
		
		ПараметрыЗакрытияФормы.Вставить("ЗаменитьМенеджераВКлиенте", ЭтотОбъект.ЗаменитьМенеджераПоПродажамВКлиенте);
		ПараметрыЗакрытияФормы.Вставить("ЗаменитьМенеджераВСделках", ЭтотОбъект.ЗаменитьМенеджераВСделках);
		ПараметрыЗакрытияФормы.Вставить("ДанныеДействия"	 	   , ПолучениеТаблицыДействия());
		
	Иначе
		
		ПараметрыЗакрытияФормы.Вставить("ЗначениеДействия"	 , ЭтотОбъект.ЗначениеДействия);
	
	КонецЕсли;
	
	// Закрытие формы.
	Закрыть(ПараметрыЗакрытияФормы);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередОкончаниемРедактирования".
//
Процедура ТаблицаДействияПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	УдалитьПустыеСтрокиСотрудников();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеУдаления".
//
Процедура ТаблицаДействияПослеУдаления(Элемент)
	
	УдалитьПустыеСтрокиСотрудников();
	ЗаполнитьПроцентомСтрокиТЗ();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ТаблицаДействияПроцентПриИзменении(Элемент)
	
	СуммаПроцентов   = ЭтотОбъект.ТаблицаДействия.Итог("Пропорция");
	ОстатокПроцентов = 100 - СуммаПроцентов;
	
	ЭтотОбъект.ОстаточныйПроцентОтДеления 	  = ОстатокПроцентов;	
	Элементы.ОстаточныйПроцент.Видимость 	  = ОстатокПроцентов <> 0;		
	Элементы.ГруппаПрименитьОбщая.Доступность = ОстатокПроцентов = 0;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ТаблицаДействияСотрудникПриИзменении(Элемент)
	
	ЗаполнитьПроцентомСтрокиТЗ();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора".
//
Процедура ТаблицаДействияСотрудникОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	МассивСтрок = ЭтотОбъект.ТаблицаДействия.НайтиСтроки(Новый Структура("Сотрудник", ВыбранноеЗначение));
	Если МассивСтрок.Количество() > 0 Тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьПредупреждение(, НСтр("ru='Этот сотрудник уже есть в списке.';en='This employee already there is in the list.'"));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область _СЛУЖЕБНЫЕ_ПРОЦЕДУРЫ_И_ФУНКЦИИ_

&НаСервере
// Процедура, заполняет элементы формы из параметров открытия формы.
Процедура ЗаполнениеЭлементовФормы()
	
	Если Параметры.Свойство("Действие") Тогда
		ЭтотОбъект.Действие = Параметры.Действие;
	КонецЕсли;
	
	Если Параметры.Свойство("ВыделенныеЭлементы") Тогда
		Элементы.ПрименитьКВыделенным.Заголовок = НСтр("ru = 'Применить к выделенным ('; en = 'Apply to selected ('") + Параметры.ВыделенныеЭлементы + ")"; 
	КонецЕсли;
		
	Если ЭтотОбъект.Действие = "Исполнитель" Тогда
		
		// Заполнение таблицы значений ТаблицаДействия.
		Если Параметры.Свойство("ДанныеДействия") Тогда
			ДанныеДействия = ПолучитьИзВременногоХранилища(Параметры.ДанныеДействия);
			
			Для каждого СтрокаТЗ из ДанныеДействия Цикл
				ЗаполнитьЗначенияСвойств(ТаблицаДействия.Добавить(), СтрокаТЗ) 
			КонецЦикла;
			
			ЗаполнитьПроцентомСтрокиТЗ();
		КонецЕсли;
		
		// Установка параметра ЗаменитьМенеджераПоПродажамВКлиенте.
		Если Параметры.Свойство("ЗаменитьМенеджераВКлиенте") Тогда
			ЭтотОбъект.ЗаменитьМенеджераПоПродажамВКлиенте = Параметры.ЗаменитьМенеджераВКлиенте;
		КонецЕсли;
		
		// Установка параметра ЗаменитьМенеджераВСделках.
		Если Параметры.Свойство("ЗаменитьМенеджераВСделках") Тогда
			ЭтотОбъект.ЗаменитьМенеджераВСделках = Параметры.ЗаменитьМенеджераВСделках;
		КонецЕсли;
		
	Иначе
		
		// Заполнение поля ЗначениеДействия. 
		Если Параметры.Свойство("ЗначениеДействия") Тогда
			ЭтотОбъект.ЗначениеДействия = Параметры.ЗначениеДействия;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость групп и элементов.
//
Процедура УстановитьВидмостьВсплывающейГруппы(Знач ВыбранноеЗначение)
	
	Если ВыбранноеЗначение = "Исполнитель" Тогда
		
		ВидимостьТаблицыДействий(ВыбранноеЗначение);
		
	ИначеЕсли ВыбранноеЗначение = "ДатаВыполнения"
		ИЛИ  ВыбранноеЗначение = "ДатаНазначено" Тогда 
		
		ЭтотОбъект.ЗначениеДействия = Дата(01,01,0001);
		ВидимостьТаблицыДействий(ВыбранноеЗначение);
		
	ИначеЕсли ВыбранноеЗначение = "ВидВзаимодействия" Тогда
		
		ЭтотОбъект.ЗначениеДействия = ПредопределенноеЗначение("Справочник.ВидыВзаимодействий.ПустаяСсылка");		
		ВидимостьТаблицыДействий(ВыбранноеЗначение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, получение данных из ТаблицаДействия.
//
Функция ПолучениеТаблицыДействия()
		
	Возврат ПоместитьВоВременноеХранилище(ТаблицаДействия.Выгрузить(), Новый УникальныйИдентификатор); 
	
КонецФункции

&НаСервере
// Процедура, ЗаполнитьПроцентомСтрокиТЗ.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ЗаполнитьПроцентомСтрокиТЗ()
	
	Элементы.ОстаточныйПроцент.Видимость = Ложь;
	
	КолвоЭлементов = ЭтотОбъект.ТаблицаДействия.Количество();
	
	Если КолвоЭлементов > 0 Тогда
		
		Процентов  		   = Цел(100/КолвоЭлементов);
		НедостающийПроцент = 100 - (Процентов*КолвоЭлементов);
		
		Для Каждого СтрокаТЗ Из ЭтотОбъект.ТаблицаДействия Цикл
			СтрокаТЗ.Пропорция = Процентов;
		КонецЦикла;
		
		ЭтотОбъект.ОстаточныйПроцентОтДеления = НедостающийПроцент;
		Элементы.ОстаточныйПроцент.Видимость  = НедостающийПроцент > 0;
		Элементы.ГруппаПрименитьОбщая.Доступность = НедостающийПроцент = 0;
	Иначе
		Элементы.ГруппаПрименитьОбщая.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость таблицы действий.
//
Процедура ВидимостьТаблицыДействий(Знач ВыбранноеЗначение)
	
	Если ВыбранноеЗначение = "Исполнитель" Тогда
		
		Элементы.ГруппаПодДействия.Видимость 		= Ложь;
		Элементы.ГруппаКнопокДействия.Видимость		= Истина;
		Элементы.ТаблицаДействия.Видимость			= Истина;
		Элементы.ЗаглушкаДействие.Видимость 		= Истина;
		Элементы.ГруппаЗаменитьМенеджера.Видимость  = Истина;
		Элементы.ГруппаПрименитьОбщая.Доступность  	= ЗначениеЗаполнено(ЭтотОбъект.ТаблицаДействия);
		
	Иначе
		
		Элементы.ГруппаПодДействия.Видимость 		= Истина;
		Элементы.ГруппаКнопокДействия.Видимость 	= Ложь;
		Элементы.ТаблицаДействия.Видимость			= Ложь;
		Элементы.ЗаглушкаДействие.Видимость 		= Ложь;
		Элементы.ГруппаЗаменитьМенеджера.Видимость  = Ложь;
		Элементы.ГруппаПрименитьОбщая.Доступность  	= Истина;
	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, УдалитьПустыеСтрокиСотрудников.
//
Процедура УдалитьПустыеСтрокиСотрудников()
	
	МассивПустыхСтрок = ЭтотОбъект.ТаблицаДействия.НайтиСтроки(Новый Структура("Сотрудник", ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка")));
	Для Каждого СтрокаМассива Из МассивПустыхСтрок Цикл		
		ЭтотОбъект.ТаблицаДействия.Удалить(ЭтотОбъект.ТаблицаДействия.Индекс(СтрокаМассива));	
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти