// Функция - Проверить актуальность сообщения
//
// Параметры:
//  ДатаСообщения	 - 	 - 
//  КлючОбсуждения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьАктуальностьСообщения(ДатаСообщения, КлючОбсуждения)

	Если ЗначениеЗаполнено(ДатаСообщения) 
		И (СтрНачинаетсяС(КлючОбсуждения, "ОбновитьСогласованияСтраховыхУслуг")
		ИЛИ КлючОбсуждения = "ОбновленСтатусЗаявки"
		ИЛИ КлючОбсуждения = "ИзмененЭтапСделки" 
		ИЛИ КлючОбсуждения = "ДобавленаСделка" 
		ИЛИ КлючОбсуждения = "НеобходимоОбновитьКешНастроекПоОповещениямВзаимодействий" 
		ИЛИ КлючОбсуждения = "ЗакрытьФормуЗвонкаПациенту" 
		ИЛИ КлючОбсуждения = "ОбновитьЗадачуКанбан"
		ИЛИ КлючОбсуждения = "ОбновлениеРабочегоСтола") Тогда    
		
		//ПараметрыПользователя  = СтандартныеПодсистемыКлиентПовтИсп.ПараметрыРаботыКлиента(); 
		//ПоправкаКВремениСеанса = ?(ПараметрыПользователя.Свойство("ПоправкаКВремениСеанса"), ПараметрыПользователя.ПоправкаКВремениСеанса, 0);
		
		ВремяПроверки = ТекущаяДата() - 5*60;
		
		Возврат ДатаСообщения < ВремяПроверки;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

