	Если ЗначениеЗаполнено(Элемент) Тогда
		ДобавитьЭлемент(Элемент);
		Сегменты.СкомпоноватьПоСегменту(Объект.Ссылка, Результат, ДанныеРасшифровки);
	КонецЕсли;

