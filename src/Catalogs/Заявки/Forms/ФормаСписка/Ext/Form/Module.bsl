
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.ТекущийПользователь = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		
	УстановитьПривилегированныйРежим(Истина);
	                                          
	// Инициализируем настройки при первом открытии формы
	Если ХранилищеСистемныхНастроек.Загрузить("Справочник.Заявки.Форма.ФормаСписка/ТекущиеДанные") = Неопределено Тогда
		Настройки = Новый Соответствие;
		ХранилищеСистемныхНастроек.Сохранить("Справочник.Заявки.Форма.ФормаСписка/ТекущиеДанные", ,Настройки);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь); 
		
	// Механизм использования данной формы списка как формы выбора
	Элементы.Список.РежимВыбора = Параметры.РежимВыбора;
	Если Параметры.МножественныйВыбор <> Неопределено Тогда
		Элементы.Список.МножественныйВыбор = Параметры.МножественныйВыбор;
	КонецЕсли;    
	// Обход автоматического сохранения пользовательских настроек для разных режимов
	Если Параметры.РежимВыбора И Не ЗначениеЗаполнено(Параметры.КлючПользовательскихНастроек) Тогда
		Параметры.КлючПользовательскихНастроек = "РежимВыбора";
		Список.АвтоматическоеСохранениеПользовательскихНастроек = Ложь;
	КонецЕсли;	                                                                                    
	
КонецПроцедуры
	
&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОТБОРЫ_СПИСКА_ЗАЯВОК" Тогда 
		ИнициализироватьМеханизмФильтрацииДанных(Параметр.Отбор, Истина);
		
	ИначеЕсли ИмяСобытия = "ЗаписанаНоваяЗаявка" Тогда
		Элементы.Список.Обновить();
		
	ИначеЕсли ИмяСобытия = "ОбновленСтатусЗаявки" Тогда
		// Элементы.Список.Обновить();
		
	ИначеЕсли ИмяСобытия = "ОповещениеОНовыхЗаявках" Тогда
		// Элементы.Список.Обновить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события при загрузке данных из настроек на сервере.
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если Параметры.Свойство("ПараметрыОтбора") Тогда
		ОбновитьМеханизмФильтрацииДанных(Параметры.ПараметрыОтбора, Истина);
	Иначе
		ИнициализироватьМеханизмФильтрацииДанных(Параметры.Отбор, Истина);
	КонецЕсли;
	
	СоздатьУсловноеОформление();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура УстановитьФильтрНеобработанные(Команда)
	
	УстановитьФильтрПоСтатусу();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ОткрытьКанбан(Команда)
	
	ФормаКанбана = ПолучитьОткрытуюФорму("Справочник.Заявки.Форма.ФормаСпискаКанбан");
	
	ПараметрыОтбора = ПараметрыВыбранныхФильтровКлиент();
	
	Если ФормаКанбана = Неопределено Тогда
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ПараметрыОтбора", ПараметрыОтбора);
		
		ОткрытьФорму("Справочник.Заявки.Форма.ФормаСпискаКанбан", ПараметрыОткрытия);
		
	Иначе
		ФормаКанбана.Активизировать();
		ФормаКанбана.УстановитьОтбор(ПараметрыОтбора);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СоздатьСделку".
//
Процедура СоздатьЗаявку(Команда)
	
	ОткрытьФорму("Справочник.Заявки.Форма.ФормаЭлемента",,, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаСервереБезКонтекста
// Процедура, обработчик события "ПриПолученииДанныхНаСервере".
//
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Для Каждого Строка Из Строки Цикл
		
		Данные = Строка.Значение.Данные;
		
		Если ЗначениеЗаполнено(Данные.Обращение) И ТипЗнч(Данные.Обращение) = Тип("Строка") Тогда
			Данные.Обращение = "Обращение №" + ФормированиеПечатныхФорм.УдалитьЛидирующиеНулиИзНомераОбъекта(Данные.Обращение);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

