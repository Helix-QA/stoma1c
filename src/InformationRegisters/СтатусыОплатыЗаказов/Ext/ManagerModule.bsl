#Область СБП

// Функция - Получить заказы по документам
//
// Параметры:
//  СписокДокументов		 - 	 - 
//  ЭквайринговыйТерминал	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗаказыПоДокументам(СписокДокументов, ЭквайринговыйТерминал, НомерЗаказа = Неопределено) Экспорт
	
	МассивЗаказов = Новый Массив;
	
	Если ЗначениеЗаполнено(НомерЗаказа) Тогда
		МассивЗаказов.Добавить(НомерЗаказа);
		Цифры = "0123456789";
		Если ОбщегоНазначенияКлиентСервер.СтрокаСодержитТолькоДопустимыеСимволы(НомерЗаказа, Цифры) Тогда			
			МассивЗаказов.Добавить(Число(НомерЗаказа));
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.Основание КАК Основание,
	|	СтатусыОплатыЗаказов.ИдЗаказа КАК ИдЗаказа,
	|	СтатусыОплатыЗаказов.ИдентификаторQRКода КАК ИдентификаторQRКода
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Основание В(&СписокДокументов)
	|	И СтатусыОплатыЗаказов.ЭквайринговыйТерминал = &ЭквайринговыйТерминал
	|	И СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки > &ТекущаяДата
	|	И СтатусыОплатыЗаказов.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.Отказ)
	|	И &УсловиеНомерЗаказа");
	
	УсловиеНомерЗаказа = ?(ЗначениеЗаполнено(НомерЗаказа), "И СтатусыОплатыЗаказов.НомерЗаказа В (&МассивЗаказов)", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеНомерЗаказа", УсловиеНомерЗаказа);
	
	Запрос.УстановитьПараметр("СписокДокументов"		, СписокДокументов);
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал"	, ЭквайринговыйТерминал);
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("МассивЗаказов"			, МассивЗаказов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить не оплаченные заказы СБП
//
// Параметры:
//  НомерЗаказа	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНеОплаченныеЗаказыСБП(НомерЗаказа = Неопределено) Экспорт 
	
	//1). В первый час с момента генерации каждые 60 секунд.
	//2). Во второй и последующие часы с момента генерации раз в час к времени генерации, начиная с 60 попытки.
	//3). Через 24 часа с момента генерации раз в сутки, начиная с 83 попытки.
	
	МассивПлатежныхШлюзов = Новый Массив;
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПСбербанк);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПАльфабанк);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПСДМ);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПТинькофф);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.Сбербанк);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка КАК ТипБанка,
	|	СтатусыОплатыЗаказов.ИдЗаказа КАК ИдСБП,
	|	СтатусыОплатыЗаказов.ИдентификаторQRКода КАК ИдентификаторQRКода,
	|	СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <> ДАТАВРЕМЯ(1, 1, 1)
	|		И СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <= &ТекущаяДата
	|		И СтатусыОплатыЗаказов.КоличествоПопыток > 2 КАК Истекший,
	|	СтатусыОплатыЗаказов.ЭтоВозврат КАК ЭтоВозврат,
	|	СтатусыОплатыЗаказов.Основание КАК ВозвратОтПокупателя,
	|	СтатусыОплатыЗаказов.Сумма КАК СуммаВозвратаВРублях,
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК УИДВозврата,
	|	СтатусыОплатыЗаказов.Контрагент КАК Контрагент,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НЕОПРЕДЕЛЕНО КАК ПараметрыПШ,
	|	НЕОПРЕДЕЛЕНО КАК КассаОплаты,
	|	НЕОПРЕДЕЛЕНО КАК СтруктураВозврата
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка В(&МассивПлатежныхШлюзов)
	|	И (СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)
	|			ИЛИ СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.ОжидаетВозврата))
	|	И &УсловиеНомерЗаказа
	|	И (СтатусыОплатыЗаказов.ДатаПоследнейОбработки = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ &ЭтоРучнаяПроверка = ИСТИНА
	|			ИЛИ &ТекущаяДата < ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ЧАС, 1)
	|				И РАЗНОСТЬДАТ(СтатусыОплатыЗаказов.ДатаПоследнейОбработки, &ТекущаяДата, СЕКУНДА) >= 60
	|			ИЛИ &ТекущаяДата >= ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ЧАС, 1)
	|				И &ТекущаяДата < ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ДЕНЬ, 1)
	|				И РАЗНОСТЬДАТ(СтатусыОплатыЗаказов.ДатаПоследнейОбработки, &ТекущаяДата, МИНУТА) >= 60
	|			ИЛИ &ТекущаяДата >= ДОБАВИТЬКДАТЕ(СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа, ДЕНЬ, 1)
	|				И РАЗНОСТЬДАТ(СтатусыОплатыЗаказов.ДатаПоследнейОбработки, &ТекущаяДата, ЧАС) >= 24)");
		
	УсловиеНомерЗаказа = ?(ЗначениеЗаполнено(НомерЗаказа), "И СтатусыОплатыЗаказов.НомерЗаказа = &НомерЗаказа", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеНомерЗаказа", УсловиеНомерЗаказа);
	
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("МассивПлатежныхШлюзов"	, МассивПлатежныхШлюзов);
	Запрос.УстановитьПараметр("НомерЗаказа"				, НомерЗаказа);
	Запрос.УстановитьПараметр("ЭтоРучнаяПроверка"		, ЗначениеЗаполнено(НомерЗаказа));
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Обновить запись по заказу
//
// Параметры:
//  PaymentId	 - 	 - 
//  OrderId		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Процедура ОбновитьЗаписьПоЗаказу(НомерЗаказа, ТекстЗапроса = Неопределено, СтатусПлатежа = Неопределено, ДобавитьПопытку = Ложь, ДобавитьДатуОбработки = Ложь) Экспорт
	
	НаборЗаписей = РегистрыСведений.СтатусыОплатыЗаказов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.НомерЗаказа.Установить(НомерЗаказа);
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Выбран() Тогда
		
		Для Каждого Запись Из НаборЗаписей Цикл
			
			Запись.ПараметрыJSON			= ?(ЗначениеЗаполнено(ТекстЗапроса) , ТекстЗапроса , Запись.ПараметрыJSON);	
			Запись.Статус					= ?(ЗначениеЗаполнено(СтатусПлатежа), СтатусПлатежа, Запись.Статус);
			Запись.КоличествоПопыток		= ?(ДобавитьПопытку = Истина, Запись.КоличествоПопыток + 1, Запись.КоличествоПопыток);
			Запись.ДатаПоследнейОбработки	= ?(ДобавитьДатуОбработки = Истина, ТекущаяДатаСеанса(), Запись.ДатаПоследнейОбработки);
			
		КонецЦикла;
		
		НаборЗаписей.Записать();
				
	КонецЕсли;
	
КонецПроцедуры

// Функция - Получить последний заказ
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеПоследнегоЗаказа(ЭквайринговыйТерминал) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.Контрагент.Представление КАК КонтрагентПредставление,
	|	СтатусыОплатыЗаказов.СсылкаОплаты КАК СсылкаОплаты,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница.Представление КАК СтруктурнаяЕдиницаПредставление,
	|	СУММА(СтатусыОплатыЗаказов.Сумма) КАК Сумма,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница.Организация.Представление КАК ОрганизацияПредставление
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал = &ЭквайринговыйТерминал
	|	И СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)
	|	И ВЫБОР
	|			КОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки > &ТекущаяДата
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И СтатусыОплатыЗаказов.ЭтоВозврат = ЛОЖЬ
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница.Представление,
	|	СтатусыОплатыЗаказов.СсылкаОплаты,
	|	СтатусыОплатыЗаказов.Контрагент.Представление,
	|	СтатусыОплатыЗаказов.НомерЗаказа,
	|	СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа,
	|	СтатусыОплатыЗаказов.СтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа УБЫВ");
	
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал"	, ЭквайринговыйТерминал);
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();

	Возврат ?(Выборка.Следующий(), Выборка, Неопределено); 
		
КонецФункции

