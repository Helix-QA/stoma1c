
#Область ОбработчикиСобытий

// Процедура, обработчик события "ПередЗаписью"
//
Процедура ПередЗаписью(Отказ)         	
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	
	ПериодРаботы = ОбщегоНазначенияСтоматология.ПолучитьНаибольшееВремяРаботы(СтруктурнаяЕдиница);
	
	Если Дата(1,1,1) = ОкончаниеСмены Тогда 	     
		ОкончаниеСмены = ОкончаниеСмены + 23*60*60 + 59*60;
	КонецЕсли;
	
	Если НачалоСмены > ОкончаниеСмены и не НачалоДня(ОкончаниеСмены) = ОкончаниеСмены Тогда
		Отказ = Истина;
		ТекстСообщения = НСтр("ru = 'Время начала рабочей смены, больше времени окончания рабочей смены!'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;
	
	Если (НачалоСмены = ОкончаниеСмены) и (не НачалоДня(НачалоСмены) = НачалоСмены и не НачалоДня(ОкончаниеСмены) = ОкончаниеСмены) Тогда
		Отказ = Истина;
		ТекстСообщения = НСтр("ru = 'Не задана продолжительность рабочей смены!'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	ВремяНачалоСмены = Дата(01,01,01) + (НачалоСмены - НачалоДня(НачалоСмены));
	ВремяОкончанияСмены =  Дата(01,01,01) + (ОкончаниеСмены - НачалоДня(ОкончаниеСмены));
	
	Если не ЗначениеЗаполнено(ПериодРаботы.НачалоРаботы) и не ЗначениеЗаполнено(ПериодРаботы.ОкончаниеРаботы) Тогда
		Отказ = Истина;
		ТекстСообщения = (НСтр("ru = 'Для данной структурной единицы не установлено время работы.'"));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	Иначе
		Если ВремяНачалоСмены < ПериодРаботы.НачалоРаботы Тогда
			Отказ = Истина;
			ТекстСообщения = НСтр("ru = 'Время начала рабочей смены, меньше времени начала рабочего дня!'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		Если  ВремяОкончанияСмены > ПериодРаботы.ОкончаниеРаботы Тогда
			Отказ = Истина;
			ТекстСообщения = НСтр("ru = 'Время окончания рабочей смены, больше времени окончания рабочего дня!'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	
	Если ПроверитьНаличиеАналогичногоПериода() И НЕ ЭтотОбъект.ПометкаУдаления Тогда
		Отказ = Истина;
		ТекстСообщения = НСтр("ru = 'Данный период работы по структурной единице """+ Строка(СтруктурнаяЕдиница) +""" уже существует.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

