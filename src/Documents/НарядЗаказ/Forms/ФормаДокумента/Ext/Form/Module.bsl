#Область СсылкиНаОплату

&НаКлиенте
// Процедура - Ссылка на оплату
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СсылкаНаОплату(Команда)
	
	МассивПодстрок = СтрРазделить(Команда.Имя, "_", Ложь);
	
	НомерЗаказа = ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], Неопределено); 
	
	Если ЗначениеЗаполнено(НомерЗаказа) Тогда	
						
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("НомерЗаказа", НомерЗаказа);
		
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОтправкиПлатежейСБП", ПараметрыФормы,,,,, Новый ОписаниеОповещения("ГенерацияСсылкиЗавершение", ЭтотОбъект));
		
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить ссылку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОтменитьСсылку(Команда)
	
	МассивПодстрок	= СтрРазделить(Команда.Имя, "_", Ложь);	
	НомерЗаказа		= ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], Неопределено); 
	
	Если Не ЗначениеЗаполнено(НомерЗаказа) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден номер заказа");
		Возврат;
	КонецЕсли;
	
	Если ЭтаФорма.Модифицированность = Истина Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ был изменен, необходимо записать документ");
		Возврат;		
	КонецЕсли;
		
	ТекстВопроса = НСтр("ru='Отмена ссылки приведет к невозможности автоматической оплаты по этой ссылке.
						|Продолжить?';
						|en='Cancellation of the link will result in the inability to automatically pay for this link.
						|Continue?'");
	
	ЗаголовокВопроса	= НСтр("ru='Внимание!';en='Attention!'");
	ДопПараметры		= Новый Структура("НомерЗаказа", НомерЗаказа);
	ОписаниеОповещения	= Новый ОписаниеОповещения("ОтменитьСсылкуНаОплатуЗавершение", ЭтаФорма, ДопПараметры);
	
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет,,, ЗаголовокВопроса);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить ссылку на оплату завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ОтменитьСсылкуНаОплатуЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Да И ЗначениеЗаполнено(Параметры.НомерЗаказа) Тогда			
		ОтменитьСсылкуНаОплатуСервер(Параметры.НомерЗаказа);						
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Отменить ссылку на оплату сервер
//
// Параметры:
//  СсылкаНаОплату	 - 	 - 
//
Процедура ОтменитьСсылкуНаОплатуСервер(НомерЗаказа)
	
	ТаблицаЗаказа = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьНеОплаченныеЗаказыПоДокументу(, НомерЗаказа);
	
	Если ТаблицаЗаказа.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найдена ссылка на оплату");		
		Возврат;
	КонецЕсли;
		
	ИскомыйЗаказ = ТаблицаЗаказа[0];
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СсылкаНаОплату"			, ИскомыйЗаказ.СсылкаОплаты);
	СтруктураПараметров.Вставить("ТаблицаЗадолженностей"	, ТаблицаЗаказа);
	СтруктураПараметров.Вставить("ЭквайринговыйТерминал"	, ИскомыйЗаказ.ЭквайринговыйТерминал);
	СтруктураПараметров.Вставить("НомерЗаказа"				, НомерЗаказа);
	
	Результат = СсылкиНаОплатуИСБП.ОтменитьСсылкуНаОплату(СтруктураПараметров);
	
	Если Результат.ВыполненоУспешно Тогда		
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();
	Иначе		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения "ГенерацияСсылкиЗавершение".
//
Процедура ГенерацияСсылкиЗавершение(Результат, Контекст) Экспорт
	
	РезультатПолучен = Результат <> Неопределено;
	
	Если РезультатПолучен И Результат.ОбновитьИнформациюОСсылкахНаОплату Тогда
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();	
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
