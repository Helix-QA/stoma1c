// Процедура - Перенести присоединенные файлы клиентов
//
// Параметры:
//  Параметры	 - 	 - 
//
Процедура ПеренестиПрисоединенныеФайлыКлиентов(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Порция = 50; //файлы могут быть неприлиных размеров и при выполнении запроса не хватает памяти для получения результата запроса
	
	Пока Порция > 0 Цикл  
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Порция + "
		|	ПрисоединенныеФайлы.ПрисоединенныйФайл КАК ПрисоединенныйФайл,
		|	ПрисоединенныеФайлы.ХранимыйФайл КАК ХранимыйФайл
		|ИЗ
		|	РегистрСведений.ПрисоединенныеФайлы КАК ПрисоединенныеФайлы";
		
		ТаблицаПрисоединенныхФайловКлиентов = Запрос.Выполнить().Выгрузить();
		
		Порция = ТаблицаПрисоединенныхФайловКлиентов.Количество();
		
		Для Каждого СтрокаТЗ Из ТаблицаПрисоединенныхФайловКлиентов Цикл 
			Если ЗначениеЗаполнено(СтрокаТЗ.ПрисоединенныйФайл) Тогда 
				ДвоичныеДанные = СтрокаТЗ.ХранимыйФайл.Получить();
				
				НаборЗаписей = РегистрыСведений.ДвоичныеДанныеФайлов.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Файл.Установить(СтрокаТЗ.ПрисоединенныйФайл);
				
				ЗаписьНабора = НаборЗаписей.Добавить();
				ЗаписьНабора.Файл = СтрокаТЗ.ПрисоединенныйФайл;
				ЗаписьНабора.ДвоичныеДанныеФайла = Новый ХранилищеЗначения(ДвоичныеДанные, Новый СжатиеДанных(9));
				
				//ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
				НаборЗаписей.ОбменДанными.Загрузка = Истина;
				
				СтарыйНаборЗаписей = РегистрыСведений.ПрисоединенныеФайлы.СоздатьНаборЗаписей();
				СтарыйНаборЗаписей.Отбор.ПрисоединенныйФайл.Установить(СтрокаТЗ.ПрисоединенныйФайл);
				СтарыйНаборЗаписей.ОбменДанными.Загрузка = Истина;
				
				НачатьТранзакцию();
				Попытка
					НаборЗаписей.Записать();
					СтарыйНаборЗаписей.Записать();
					ЗафиксироватьТранзакцию();
				Исключение
					ОтменитьТранзакцию();
					Порция = Порция - 1;
				КонецПопытки;	
			КонецЕсли;	
		КонецЦикла;
	КонецЦикла;

	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;	
	
КонецПроцедуры

