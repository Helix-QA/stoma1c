  КонецЕсли;
    
  Элементы.ГруппаФормаКнопкаОтложить.Видимость   = ?(ЗначениеЗаполнено(Объект.РезультатПриема) Или Объект.Проведен, Ложь, Истина);      
  Элементы.ГруппаФормаКнопкаСохранить.Видимость  = Не Элементы.ГруппаФормаКнопкаОтложить.Видимость;
  
