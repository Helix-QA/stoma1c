// Процедура формирует блок индивидуальных норм списания.
//
Процедура СформироватьБлокИндивидуальныхНормСписания() 
	
	// удаляем ранее выведенные элементы
	МассивИменУдаляемыхЭлементов = Новый Массив;
	МассивИменУдаляемыхЭлементов.Добавить("_ГруппаСтрокаИндивидуальныхНормСписания");
	МассивИменУдаляемыхЭлементов.Добавить("_ВыборКлиники");
	МассивИменУдаляемыхЭлементов.Добавить("_ДекорацияСостояниеНормСписания");
	МассивИменУдаляемыхЭлементов.Добавить("_ЗадатьОбщиеНормыСписания");   
	
	Для Каждого ЭлементСписка Из СписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм Цикл
		ИДСтрокиДанных = ЭлементСписка.ПолучитьИдентификатор();   		
		Для Каждого ЭлементМ Из МассивИменУдаляемыхЭлементов Цикл      			
			УдаляемыйЭлемент = Элементы.Найти(ЭлементМ + "" + ИДСтрокиДанных);
			Если УдаляемыйЭлемент <> Неопределено Тогда
				Элементы.Удалить(УдаляемыйЭлемент);						
			КонецЕсли;			
		КонецЦикла;   		
	КонецЦикла;    
	
	// получаем заново список и выводим
	СписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм = ПолучитьСписокСтруктурныхЕдиницСОтметкойИндивидуальныхНормНаСервере();
	
	Для Каждого ЭлементСписка Из СписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм Цикл
		
		ИДСтрокиДанных = ЭлементСписка.ПолучитьИдентификатор();
		
		ЗаданыИндивидуальныеНормыСписания = ЭлементСписка.Картинка.Вид <> ВидКартинки.Пустая;
		
		ГруппаСтроки						= Элементы.Добавить("_ГруппаСтрокаИндивидуальныхНормСписания" + ИДСтрокиДанных, Тип("ГруппаФормы"), Элементы.Найти("ГруппаСтрокИндивидуальныхНормСписания"));
		ГруппаСтроки.Вид					= ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаСтроки.Группировка			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаСтроки.Отображение			= ОтображениеОбычнойГруппы.Нет;
		ГруппаСтроки.ОтображатьЗаголовок	= Ложь;
			
		КомандаВыборКлиники							= Элементы.Добавить("_ВыборКлиники" + ИДСтрокиДанных, Тип("ДекорацияФормы"), ГруппаСтроки);
		КомандаВыборКлиники.Заголовок				= ЭлементСписка;
		КомандаВыборКлиники.Шрифт					= Новый Шрифт("Arial", 10);
		КомандаВыборКлиники.Гиперссылка				= Истина;		
		КомандаВыборКлиники.Ширина					= 25;
		КомандаВыборКлиники.ЦветТекста				= ?(ЗаданыИндивидуальныеНормыСписания, WebЦвета.Зеленый, WebЦвета.Черный);
		КомандаВыборКлиники.ЦветФона					= ?(ЭлементСписка.Значение = ТекущаяСтруктурнаяЕдиница, Новый Цвет(240, 240, 240), WebЦвета.Белый);
		КомандаВыборКлиники.УстановитьДействие("Нажатие", "ВыбратьСтруктурнуюЕдиницу");
		
	КонецЦикла;
	
КонецПроцедуры

