// Функция, получает подсказку по виду карты.
//
Функция ПолучитьПодсказкуПоВидуКарты(ВидКарты)
	
	Если ВидКарты = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet") Тогда
		Возврат "Электронная";
	ИначеЕсли ВидКарты = ПредопределенноеЗначение("Перечисление.ВидыКарт.Штриховая") Тогда
		Возврат "Штриховая";
	Иначе
		Возврат "Магнитная";
	КонецЕсли;
	
