// Получить текущие задачи для пользователя определенных временем срабатывания 
//
Функция ПолучитьТекущиеЗадачиДляПользователяПоВремени(Пользователь) Экспорт
	
	ЗапросВыборка = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(СоставСегментов.Сегмент КАК Справочник.СегментыСотрудников) КАК Сегмент
	|ПОМЕСТИТЬ ТаблицаСегментовСотрудников
	|ИЗ
	|	РегистрСведений.СоставСегментов КАК СоставСегментов
	|ГДЕ
	|	СоставСегментов.ОбъектСегмента = &Исполнитель
	|
	|СГРУППИРОВАТЬ ПО
	|	СоставСегментов.Сегмент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 50
	|	Взаимодействие.Ссылка КАК Ссылка
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Исполнитель = &Исполнитель
	|	И Взаимодействие.ПометкаУдаления = ЛОЖЬ
	|	И Взаимодействие.Выполнена = ЛОЖЬ
	|	И Взаимодействие.НапоминаниеИспользовать = ИСТИНА
	|	И Взаимодействие.НапоминаниеДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|	И Взаимодействие.НапоминаниеДатаНачала < &ТекущаяДата
	|	И Взаимодействие.НапоминаниеДатаНачала > ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1)
	|	И Взаимодействие.ВариантНапоминания = ЗНАЧЕНИЕ(Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 50
	|	Взаимодействие.Ссылка
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Исполнитель В
	|			(ВЫБРАТЬ
	|				ТаблицаСегментовСотрудников.Сегмент
	|			ИЗ
	|				ТаблицаСегментовСотрудников)
	|	И Взаимодействие.ПометкаУдаления = ЛОЖЬ
	|	И Взаимодействие.Выполнена = ЛОЖЬ
	|	И Взаимодействие.НапоминаниеИспользовать = ИСТИНА
	|	И Взаимодействие.НапоминаниеДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|	И Взаимодействие.НапоминаниеДатаНачала < &ТекущаяДата
	|	И Взаимодействие.НапоминаниеДатаНачала > ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1)
	|	И Взаимодействие.ВариантНапоминания = ЗНАЧЕНИЕ(Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия)");	
	
	ЗапросВыборка.УстановитьПараметр("Исполнитель",	Пользователь);
	ЗапросВыборка.УстановитьПараметр("ТекущаяДата",	ТекущаяДатаСеанса());
	Задача = ЗапросВыборка.Выполнить().Выгрузить();
	
	Возврат Задача.ВыгрузитьКолонку("Ссылка");
	
КонецФункции

