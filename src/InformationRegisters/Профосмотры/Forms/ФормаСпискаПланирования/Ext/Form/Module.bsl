&НаКлиентеНаСервереБезКонтекста
// Функция - Вернуть конец дня даты
//
Функция ВернутьКонецДняДаты(Дата)
	
	Возврат ?(ЗначениеЗаполнено(Дата), КонецДня(Дата), Дата);
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСписка

&НаКлиенте
// Обработчик выбора строки в списке 
//
Процедура СписокПланаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)	
	
	Если ЭтоЗаписьНаПрием Тогда 
		Если Элемент.ТекущиеДанные.ВидОсмотра = ПредопределенноеЗначение("Перечисление.ВидыОсмотров.ОчередьНаЗапись") Тогда 
			СтандартнаяОбработка = Ложь;
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("ДатаНачала"              , Старт);
			ПараметрыФормы.Вставить("ДатаОкончания"           , Финиш);
			ПараметрыФормы.Вставить("Контрагент"              , Элемент.ТекущиеДанные.Контрагент);
			ПараметрыФормы.Вставить("Сотрудник"               , ?(ЗначениеЗаполнено(Сотрудник), Сотрудник, Элемент.ТекущиеДанные.Сотрудник));
			ПараметрыФормы.Вставить("Помещение"               , Помещение);    
			ПараметрыФормы.Вставить("ПричинаЗаписи"           , Элемент.ТекущиеДанные.ПричинаНаправления);
			ОткрытьФорму("Документ.Событие.ФормаОбъекта", ПараметрыФормы, ЭтаФорма);			
		КонецЕсли;
	Иначе 	
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные        = Элементы.СписокПлана.ТекущиеДанные;	
				
		ПараметрыФормы = Новый Структура; 	
		ПараметрыФормы.Вставить("Ключ", ПолучитьКлючЗаписи(ТекущиеДанные));
		
		ОткрытьФорму("РегистрСведений.Профосмотры.Форма.ФормаРедактированияЗаписиПлана", ПараметрыФормы);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик формы записи новго объекта
//
Процедура ОбработкаЗаписиНового(НовыйОбъект, Источник, СтандартнаяОбработка)
	
	Если ТипЗнч(НовыйОбъект.Ссылка) = Тип("ДокументСсылка.Событие") Тогда
		ЗаписьПоПланированиюОчереди(НовыйОбъект.Ссылка);
		Элементы.СписокПлана.Обновить();
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

