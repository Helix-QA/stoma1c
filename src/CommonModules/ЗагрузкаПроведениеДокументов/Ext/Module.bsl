// Процедура разбивает таблицу объектов по ключевому полю.
//
Процедура РазбитьТаблицуОбъектовПоКлючевомуПолю(РазбиваемаяТаблица, КлючевоеПоле, КоличествоТаблиц, МассивТаблиц, ГруппироватьПоКлючевомуПолю = Истина)
	
	МассивСгруппированыхТаблицКлючевыхПолей = Неопределено;
	
    Если ГруппироватьПоКлючевомуПолю Тогда 
    	Запрос 								= Новый Запрос;
    	Запрос.МенеджерВременныхТаблиц 		= УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(РазбиваемаяТаблица, "Таблица_Объектов");	
    	Запрос.Текст = "ВЫБРАТЬ
    	               |	Таблица_Объектов." + КлючевоеПоле + " КАК " + КлючевоеПоле + "
    	               |ИЗ
    	               |	Таблица_Объектов КАК Таблица_Объектов
    	               |
    	               |СГРУППИРОВАТЬ ПО
    	               |	Таблица_Объектов." + КлючевоеПоле + "";
    	
    	ТаблицаУникальныхЗаписей = Запрос.Выполнить().Выгрузить();
    	
    	Запрос.МенеджерВременныхТаблиц.Закрыть();			   
    	
    	ОбщееКоличествоУникальныхЗаписей = ТаблицаУникальныхЗаписей.Количество();
    Иначе 
    	ОбщееКоличествоУникальныхЗаписей = РазбиваемаяТаблица.Количество();
    КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
    Если КоличествоТаблиц < 1 ИЛИ ОбщееКоличествоУникальныхЗаписей < 1 Тогда 
    	Возврат;
    ИначеЕсли КоличествоТаблиц > 8 Тогда 
    	КоличествоТаблиц = 8;
    КонецЕсли;
    
    Если ОбщееКоличествоУникальныхЗаписей < КоличествоТаблиц Тогда 
    	КоличествоТаблиц = ОбщееКоличествоУникальныхЗаписей;
    КонецЕсли;	
	
	Если ГруппироватьПоКлючевомуПолю Тогда 
		МассивСгруппированыхТаблицКлючевыхПолей = Новый Массив;
		РазбитьТаблицуОбъектовПоКлючевомуПолю(ТаблицаУникальныхЗаписей, КлючевоеПоле, КоличествоТаблиц, МассивСгруппированыхТаблицКлючевыхПолей, Ложь);
		Запрос 								= Новый Запрос;
		Запрос.МенеджерВременныхТаблиц 		= УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(РазбиваемаяТаблица, "Таблица_Объектов");		
		Запрос.Текст = "ВЫБРАТЬ
		|	*
		|ИЗ
		|	Таблица_Объектов КАК Таблица_Объектов
		|ГДЕ
		|	Таблица_Объектов." + КлючевоеПоле + " В (&МассивКлючевыхПолей)";
		Для Каждого СгруппированнаяТаблица Из МассивСгруппированыхТаблицКлючевыхПолей Цикл
			ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));			
			Запрос.УстановитьПараметр("МассивКлючевыхПолей", СгруппированнаяТаблица.ВыгрузитьКолонку(КлючевоеПоле));
			МассивТаблиц.Добавить(Запрос.Выполнить().Выгрузить());  
		КонецЦикла;	
		Запрос.МенеджерВременныхТаблиц.Закрыть();
	Иначе 	
		КоличествоЗаписейДляПервойТаблицы 	= Цел(ОбщееКоличествоУникальныхЗаписей / КоличествоТаблиц);	
		
		Запрос 								= Новый Запрос;
		Запрос.МенеджерВременныхТаблиц 		= УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(РазбиваемаяТаблица, "Таблица_Объектов");
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Формат(КоличествоЗаписейДляПервойТаблицы, "ЧГ=0") + "
		|	Таблица_Объектов." + КлючевоеПоле + " КАК " + КлючевоеПоле + "
		|ПОМЕСТИТЬ Таблица_Объектов_1
		|ИЗ
		|	Таблица_Объектов КАК Таблица_Объектов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|	Таблица_Объектов КАК Таблица_Объектов
		|ГДЕ
		|	Таблица_Объектов." + КлючевоеПоле + " В
		|				(ВЫБРАТЬ
		|					Таблица_Объектов_1." + КлючевоеПоле + "
		|				ИЗ
		|					Таблица_Объектов_1 КАК Таблица_Объектов_1)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	*
		|ИЗ
		|Таблица_Объектов КАК Таблица_Объектов
		|ЛЕВОЕ СОЕДИНЕНИЕ Таблица_Объектов_1 КАК Таблица_Объектов_1
		|ПО (Таблица_Объектов." + КлючевоеПоле + " = Таблица_Объектов_1." + КлючевоеПоле + ")
		|ГДЕ
		|Таблица_Объектов_1." + КлючевоеПоле + " ЕСТЬ NULL";
		
		//|ВЫБРАТЬ
		//|	*
		//|ИЗ
		//|	Таблица_Объектов КАК Таблица_Объектов
		//|ГДЕ
		//|	НЕ Таблица_Объектов." + КлючевоеПоле + " В
		//|				(ВЫБРАТЬ
		//|					Таблица_Объектов_1." + КлючевоеПоле + "
		//|				ИЗ
		//|					Таблица_Объектов_1 КАК Таблица_Объектов_1)";
		
		РезультатПакетаЗапросов = Запрос.ВыполнитьПакет();
		Таблица_1 				= РезультатПакетаЗапросов[1].Выгрузить();
		Таблица_2 				= РезультатПакетаЗапросов[2].Выгрузить();
		
		Запрос.МенеджерВременныхТаблиц.Закрыть();			   
		
		МассивТаблиц.Добавить(Таблица_1);
		КоличествоТаблиц = КоличествоТаблиц - 1;
		
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
		
		Если КоличествоТаблиц > 0 Тогда 
			РазбитьТаблицуОбъектовПоКлючевомуПолю(Таблица_2, КлючевоеПоле, КоличествоТаблиц, МассивТаблиц, Ложь);
		КонецЕсли;	
	КонецЕсли;
				   
КонецПроцедуры

// Функция - Перенести напоминания по задачам
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПеренестиНапоминанияПоЗадачам(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт 
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ПеренестиНапоминанияПоЗадачамВФоне",
	ПараметрыПроцедуры,
	НСтр("ru='Перенос напоминаний по задачам.';en='Transfer reminders on tasks.'"));
	Возврат Результат;	
	
КонецФункции

// Процедура - Перенести напоминания по задачам в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ПеренестиНапоминанияПоЗадачамВФоне(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ТочкаНаВременнойШкале = ПараметрыЗадания.ТочкаНаВременнойШкале;	
	Для Каждого СтрокаТаблицыЗадач Из ПараметрыЗадания.ТаблицаЗадач Цикл 
		Если ЗначениеЗаполнено(СтрокаТаблицыЗадач.Задача) Тогда 
			ЗадачаОбъект                       = СтрокаТаблицыЗадач.Задача.ПолучитьОбъект();
			
			Если ПараметрыЗадания.ИмяКоманды = "ВсеНаЗавтра" Тогда
				ЗадачаОбъект.НапоминаниеДатаНачала = ТочкаНаВременнойШкале + 60*60*24;
				ЗадачаОбъект.ЗадачаНазначеннаяДата = ТочкаНаВременнойШкале + 60*60*24;
			ИначеЕсли ПараметрыЗадания.ИмяКоманды = "ВсеНаПослезавтра" Тогда
				ЗадачаОбъект.НапоминаниеДатаНачала = ТочкаНаВременнойШкале + 60*60*24*2;
				ЗадачаОбъект.ЗадачаНазначеннаяДата = ТочкаНаВременнойШкале + 60*60*24*2
			ИначеЕсли ПараметрыЗадания.ИмяКоманды = "ВсеНаНеделю"Тогда
				ЗадачаОбъект.НапоминаниеДатаНачала = ТочкаНаВременнойШкале + 60*60*24*7;
				ЗадачаОбъект.ЗадачаНазначеннаяДата = ТочкаНаВременнойШкале + 60*60*24*7;
			ИначеЕсли ПараметрыЗадания.ИмяКоманды = "ВсеНаМесяц" Тогда
				ЗадачаОбъект.НапоминаниеДатаНачала = ДобавитьМесяц(ТочкаНаВременнойШкале	, 1);
				ЗадачаОбъект.ЗадачаНазначеннаяДата = ДобавитьМесяц(ТочкаНаВременнойШкале	, 1);
			КонецЕсли;
			Попытка
				// ЗадачаОбъект.ОбменДанными.Загрузка = Истина;
				ЗадачаОбъект.Записать();
			Исключение
				
			КонецПопытки;	
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

