&НаСервере
// Процедура, отображает раздел внешних систем.
//
Процедура НастроитьРазделВнешнихСистем()
	
	Элементы.НастройкиПубликации.Видимость = Не ЭтотОбъект.РежимРаботыВМоделиСервиса;
		
	МассивИсключаемыхЭлементов = Новый Массив;
	МассивИсключаемыхЭлементов.Добавить(Элементы.ГруппаВнешниеСистемыЗаголовок);
	МассивИсключаемыхЭлементов.Добавить(Элементы.ГруппаВнешняяСистема_ДляКопирования);
	
	УдалитьПодчиненныеЭлементыГруппы(Элементы.ГруппаВнешниеСистемы, МассивИсключаемыхЭлементов);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Наименование КАК Наименование,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.Используется КАК Используется,
	|	ВнешниеСистемы.АвторизацияПоКодуБезСМС КАК АвторизацияПоКодуБезСМС
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.УправлениеВЛичномКабинете");
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	ЭтотОбъект.ТаблицаВнешнихСистем.Загрузить(Результат);
	ЭтотОбъект.ТаблицаСтруктурныхЕдиниц.Очистить();
	
	ГруппаВнешниеСистемы = Элементы.ГруппаВнешниеСистемы;
	Для Каждого СтрокаТЗ ИЗ ЭтотОбъект.ТаблицаВнешнихСистем Цикл
		
		Индекс 				  = ЭтотОбъект.ТаблицаВнешнихСистем.Индекс(СтрокаТЗ);
		ЭтоВиджетОнлайнЗаписи = СтрокаТЗ.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи;
		ПутьКДанным 		  = "ТаблицаВнешнихСистем[" + Индекс + "].";
		
		Если ЭтоВиджетОнлайнЗаписи Тогда
			
			МассивСтруктурныхЕдиниц 	   = ВернутьМассивСтруктурныхЕдиниц();
			ПараметрыВнешнейСистемы 	   = СтрокаТЗ.Ссылка.Параметры.Получить();
			ИспользуемыеСтруктурныеЕдиницы = Новый Массив;
			
			Если ПараметрыВнешнейСистемы <> Неопределено И ПараметрыВнешнейСистемы.Свойство("ИспользуемыеСтруктурныеЕдиницы") Тогда
				ИспользуемыеСтруктурныеЕдиницы = ПараметрыВнешнейСистемы.ИспользуемыеСтруктурныеЕдиницы;
			КонецЕсли;
			
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
				
				НоваяСтрока = ЭтотОбъект.ТаблицаСтруктурныхЕдиниц.Добавить();
				НоваяСтрока.Используется	   = ИспользуемыеСтруктурныеЕдиницы.Найти(СтруктурнаяЕдиница) <> Неопределено;
				НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
				НоваяСтрока.ВнешняяСистема 	   = СтрокаТЗ.Ссылка; 
				
			КонецЦикла;
			
		КонецЕсли;
		
		ГруппаСтроки = КопироватьГруппуФормы(Элементы.ГруппаВнешняяСистема_ДляКопирования, Индекс, ГруппаВнешниеСистемы);
		
		КопироватьЭлементФормы(Элементы.ПолеВнешняяСистемаКартинкаСтатуса_ДляКопирования, Индекс, ГруппаСтроки, ПутьКДанным + "КартинкаСтатуса");
		КопироватьЭлементФормы(Элементы.ПолеВнешняяСистемаНаименвоание_ДляКопирования   , Индекс, ГруппаСтроки, ПутьКДанным + "Наименование");
		
		КнопкаОткрытьНастройки = КопироватьКнопкуФормы(Элементы.ОткрытьНастройки_ДляКопирования, Индекс, ГруппаСтроки);
		КнопкаОткрытьНастройки.Видимость = ЭтоВиджетОнлайнЗаписи;
		
		ГруппаКнопки = КопироватьГруппуФормы(Элементы.ГруппаВнешняяСистемаАктиваци_ДляКопирования, Индекс, ГруппаСтроки);
		КопироватьКнопкуФормы(Элементы.ВнешняяСистемаАктивировать_ДляКопирования, Индекс, ГруппаКнопки);
		
		УстановитьСостояниеКнопкиАктивироватьВнешнююСистему(Индекс);
		
	КонецЦикла;
	
	Если Не ЭтотОбъект.РежимРаботыВМоделиСервиса Тогда
		
		Если ЭтотОбъект.ТаблицаВнешнихСистем.Количество() > 0 Тогда
			ПроверитьПубликациюИнформационнойБазы();
		КонецЕсли;
	
		ВнешняяПубликацияНастроена = ЛичныйКабинет.ВнешняяПубликацияНастроена();
		
		Элементы.НастройкиПубликации.Заголовок          = "Внешняя публикация" + ?(ВнешняяПубликацияНастроена, " ", " не ") + "настроена";
		Элементы.ГруппаВнешниеСистемыНастрйоки.ЦветФона = ?(ВнешняяПубликацияНастроена, Новый Цвет(224, 224, 224), Новый Цвет(25, 116, 206));
		Элементы.НастройкиПубликации.ЦветТекста         = ?(ВнешняяПубликацияНастроена, Новый Цвет(77, 77, 77), Новый Цвет(255, 255, 255));
	Иначе
		Элементы.ДекорацияЗаглушкаНастройкиВн.Видимость = Истина;
        Элементы.ГруппаВнешниеСистемыНастрйоки.ЦветФона = Новый Цвет(224, 224, 224);
		Элементы.НастройкиПубликации.ЦветТекста         = Новый Цвет(255, 255, 255);
	КонецЕсли;
	
	Элементы.ГруппаВнешниеСистемы.Видимость = ЭтотОбъект.ТаблицаВнешнихСистем.Количество() > 0;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает состояние кнопки активации внешней системы.
// 
Процедура УстановитьСостояниеКнопкиАктивироватьВнешнююСистему(Индекс)
	
	СтрокаТЧ = ЭтотОбъект.ТаблицаВнешнихСистем[Индекс];
	
	Элементы["ВнешняяСистемаАктивировать_" + Индекс].Заголовок  = ?(СтрокаТЧ.Используется, "Отключить", "Активировать");
	Элементы["ГруппаВнешняяСистемаАктиваци_" + Индекс].ЦветФона = ?(СтрокаТЧ.Используется, Новый Цвет(237, 237, 237), Новый Цвет(25, 116, 206));
	Элементы["ВнешняяСистемаАктивировать_" + Индекс].ЦветТекста = ?(СтрокаТЧ.Используется, Новый Цвет(77, 77, 77), Новый Цвет(255, 255, 255));
	
	ЭтотОбъект.ТаблицаВнешнихСистем[Индекс].КартинкаСтатуса = ?(СтрокаТЧ.Используется, БиблиотекаКартинок.УспешноОкей, Неопределено);
	
	КнопкаОткрытьНастройки = Элементы.Найти("ОткрытьНастройки_" + Индекс);
	Если КнопкаОткрытьНастройки <> Неопределено Тогда
		
		ЭтоВиджетОнлайнЗаписи = СтрокаТЧ.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи;
		
		КнопкаОткрытьНастройки.Видимость = СтрокаТЧ.Используется И ЭтоВиджетОнлайнЗаписи;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Внешняя система активировать
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура ВнешняяСистемаАктивировать(Команда)
	
	ВнешняяПубликацияНастроена = ЛичныйКабинет.ВнешняяПубликацияНастроена();
	
	Если Не ЭтотОбъект.РежимРаботыВМоделиСервиса И Не ВнешняяПубликацияНастроена Тогда
		
		ПараметрыФормы = Новый Структура("АктивацияПриложения", Истина);
		Оповещение 	   = Новый ОписаниеОповещения("НастройкаВнешнейПубликацииЗавершение",ЭтотОбъект, Новый Структура("АктивацияПриложения", Истина));
		ОткрытьФорму("Обработка.ЛичныйКабинет.Форма.ФормаНастройкиВнешнейПубликации", ПараметрыФормы, ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Возврат;
		
	Иначе
		
		ИдСтроки = ПолучитьИндексИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
		СтрокаТЧ = ЭтотОбъект.ТаблицаВнешнихСистем[ИдСтроки];
		
		СообщениеОбОшибке = Неопределено;
		Если Не ВнешняяСистемаАктивироватьНаСервере(ИдСтроки, Не СтрокаТЧ.Используется, СообщениеОбОшибке) Тогда
			ПоказатьПредупреждение(, СообщениеОбОшибке);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - При настройке внешней публикации на сервере
// 
// Параметры:
//  КодРезультата		 - 	 - 
//  СообщениеОбОшибке	 - 	 - 
// 
Функция ВнешняяСистемаАктивироватьНаСервере(ИдСтроки, Используется, СообщениеОбОшибке)
	
	СтрокаТЧ 	   		  = ЭтотОбъект.ТаблицаВнешнихСистем[ИдСтроки];
	ВнешняяСистема 		  = СтрокаТЧ.Ссылка;
	СоздатьВнешнююСистему = ВнешняяСистема.Синхронизирована = Ложь;
	
	ВнешняяСистемаИспользуется = СоздатьВнешнююСистему ИЛИ Используется;
	РезультатЗапроса 		   = ОбновитьВнешнююСистемуВ_CRM(ВнешняяСистема, ВнешняяСистемаИспользуется, ЭтотОбъект.УидСессии);
	
	Если (ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи) И РезультатЗапроса.ВыполненоУспешно Тогда
		
		МассивСтруктурныхЕдиниц = Новый Массив;
		Для Каждого Элемент Из ТаблицаСтруктурныхЕдиниц Цикл
			
			Если Элемент.Используется Тогда
				МассивСтруктурныхЕдиниц.Добавить(Элемент.СтруктурнаяЕдиница);
			КонецЕсли;
			
		КонецЦикла;
		
		Если СоздатьВнешнююСистему ИЛИ Используется Тогда
			РезультатЗапроса = ЗарегистироватьВиджет(ВнешняяСистема.КлючПриложения, МассивСтруктурныхЕдиниц);
		Иначе
			РезультатЗапроса = УдалитьРегистрациюВиджета(МассивСтруктурныхЕдиниц);
		КонецЕсли;
		
	КонецЕсли;
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		Справочники.ВнешниеСистемы.УстановитьСостояниеВнешнейСистеме(ВнешняяСистема, Используется, Истина);
		СтрокаТЧ.Используется = Используется;
		УстановитьСостояниеКнопкиАктивироватьВнешнююСистему(ИдСтроки);
		
		Возврат Истина;
	Иначе
		СообщениеОбОшибке = РезультатЗапроса.ОписаниеОшибки;
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик команды "ОткрытьНастройки".
// 
Процедура ОткрытьНастройки(Команда)
	
	Индекс = ПолучитьИндексИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
	ОткрытьНастройкиНаСервере(Индекс, ГруппаНастроекОткрыта);
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик команды "ОткрытьНастройки" на сервере.
// 
Процедура ОткрытьНастройкиНаСервере(Индекс, ГруппаНастроекОткрыта)
	
	Элементы.Переместить(Элементы.ГруппаНастройки, Элементы["ГруппаВнешняяСистема_" + Индекс], Элементы["ОткрытьНастройки_" + Индекс]);
	
	Если ГруппаНастроекОткрыта = Истина Тогда
		Элементы.ГруппаНастройки.Скрыть();
	Иначе
		
		СтрокаТЧ 			  = ЭтотОбъект.ТаблицаВнешнихСистем[Индекс];
		ТекущаяВнешняяСистема = СтрокаТЧ.Ссылка;
		ЭтоВиджетОнлайнЗаписи = СтрокаТЧ.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи;
		
		Элементы.ГруппаТипАвторизации.Видимость			  = Не ЭтоВиджетОнлайнЗаписи;
		Элементы.ГруппаТаблицаСтруктурныхЕдиниц.Видимость = ЭтоВиджетОнлайнЗаписи;
		
		Элементы.ГруппаНастройки.Показать();
		
		Элементы.АвторизацияПоКодуБезСМС.Заголовок = ?(СтрокаТЧ.АвторизацияПоКодуБезСМС, "Авторизация без СМС", "Авторизация с подтверждением по СМС");
		
	КонецЕсли;
	
	ГруппаНастроекОткрыта = Не Элементы.ГруппаНастройки.Скрыта();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СохранитьНастройки".
//
Процедура СохранитьНастройки(Команда)
	
	Если Не ЗначениеЗаполнено(ТекущаяВнешняяСистема) ИЛИ ЭтотОбъект.ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("Ссылка", ТекущаяВнешняяСистема)).Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СообщениеОбОшибке = СохранитьНастройкиВиджетаОнлайнЗаписиНаСервере();
	
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда
		ПоказатьПредупреждение(, СообщениеОбОшибке);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, регистрирует в reservi структурные единицы, которые должны быть в виджете онлайн записи.
//
Функция СохранитьНастройкиВиджетаОнлайнЗаписиНаСервере()
	
	МассивНайденныхСтрок		= ЭтотОбъект.ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("Ссылка", ТекущаяВнешняяСистема));
	СтрокаТЧ					= МассивНайденныхСтрок[0];
	ИдСтроки					= ЭтотОбъект.ТаблицаВнешнихСистем.Индекс(СтрокаТЧ);
	ТаблицаСЕ         			= ЭтотОбъект.ТаблицаСтруктурныхЕдиниц;	
	ВнешняяСистема 		  		= СтрокаТЧ.Ссылка;
	
	Используется 	  	 	= Ложь;
	ИспользуемыеСалоны 	 	= Новый Массив;
	НеИспользуемыеСалоны 	= Новый Массив;	
	СтрокаТЧ.Используется	= Используется;
	
	Для Каждого СтрокаТЗ Из ТаблицаСЕ Цикл
		
		Если СтрокаТЗ.ВнешняяСистема <> ВнешняяСистема Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаТЗ.Используется Тогда
			Используется = Истина;
			ИспользуемыеСалоны.Добавить(СтрокаТЗ.СтруктурнаяЕдиница);
		ИначеЕсли ТаблицаСЕ.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница, Используется", СтрокаТЗ.СтруктурнаяЕдиница, Истина)).Количество() = 0 Тогда 
			НеИспользуемыеСалоны.Добавить(СтрокаТЗ.СтруктурнаяЕдиница);
		КонецЕсли;
		
	КонецЦикла;
		
	СоздатьВнешнююСистему 	   = ВнешняяСистема.Синхронизирована = Ложь;
	ВнешняяСистемаИспользуется = СоздатьВнешнююСистему ИЛИ Используется;
	
	РезультатЗапроса = ОбновитьВнешнююСистемуВ_CRM(ВнешняяСистема, ВнешняяСистемаИспользуется, ЭтотОбъект.УидСессии);
	
	Если Не РезультатЗапроса.ВыполненоУспешно Тогда
		Возврат РезультатЗапроса.ОписаниеОшибки;
	КонецЕсли;
	
	Если ИспользуемыеСалоны.Количество() > 0 Тогда
		
		РезультатЗапроса = ЗарегистироватьВиджет(ВнешняяСистема.КлючПриложения, ИспользуемыеСалоны);
		
		Если Не РезультатЗапроса.ВыполненоУспешно Тогда
			Возврат РезультатЗапроса.ОписаниеОшибки;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НеИспользуемыеСалоны.Количество() > 0 Тогда
		
		Если Используется Тогда
			РезультатЗапроса = ЛичныйКабинет.УдалитьРегистрациюСтруктурныхЕдиницВиджета(НеИспользуемыеСалоны);
		Иначе
			РезультатЗапроса = УдалитьРегистрациюВиджета(НеИспользуемыеСалоны);
		КонецЕсли;
		
	КонецЕсли;
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		Справочники.ВнешниеСистемы.УстановитьСостояниеВнешнейСистеме(ВнешняяСистема, Используется, Истина);
		СтрокаТЧ.Используется = Используется;
		УстановитьСостояниеКнопкиАктивироватьВнешнююСистему(ИдСтроки);
		
		Элементы.ГруппаСохранитьНастройки.Видимость = Ложь;
		ЗаписатьИспользуемыеСалоныВПараметрыВнешнейСистемы(ВнешняяСистема, ИспользуемыеСалоны);
		
	Иначе
		Возврат РезультатЗапроса.ОписаниеОшибки;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ЗаписатьИспользуемыеСалоныВПараметрыВнешнейСистемы(ВнешняяСистема, ИспользуемыеСалоны)
	
	ВнешняяСистемаОбъект = ВнешняяСистема.ПолучитьОбъект();
	
	СтруктураПараметров = ВнешняяСистемаОбъект.Параметры.Получить();
	
	Если СтруктураПараметров = Неопределено Тогда
		СтруктураПараметров = Новый Структура;
	КонецЕсли;
	
	СтруктураПараметров.Вставить("ИспользуемыеСтруктурныеЕдиницы", ИспользуемыеСалоны);
	
	ВнешняяСистемаОбъект.Параметры = Новый ХранилищеЗначения(СтруктураПараметров);
	ВнешняяСистемаОбъект.Записать();
	
КонецПроцедуры


