&НаСервереБезКонтекста
// Функция возвращает группу клиентов
//
Функция ВернутьГруппуКлиентов()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиПользователей.Значение
	|ИЗ
	|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	|ГДЕ
	|	НастройкиПользователей.Пользователь = &Пользователь
	|	И НастройкиПользователей.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ОсновнаяГруппаКонтрагентов)");
	
	Запрос.УстановитьПараметр("Пользователь", ПараметрыСеанса.ТекущийПользователь);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Значение;
	Иначе 
		Возврат Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);
	КонецЕсли;
	
КонецФункции

&НаСервере
// Обновить информацию остатка лицевого счета клиента и задолженности 
//
Процедура ОбновитьИнформациюПоОстаткамЛСиЗадолженностям()
	Долг 					= РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Объект.Контрагент,, Объект.СтруктурнаяЕдиница);	
	ОстатокЛицевогоСчета    = 0;
	Если РежимРаботыЕдинаяСеть Тогда	
		ОстатокЛицевогоСчета 	= РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент,ТекущаяДата(),,,,Истина);	
	Иначе
		ОстатокЛицевогоСчета 	= РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент,ТекущаяДата(),,Объект.СтруктурнаяЕдиница,,Истина);	
	КонецЕсли;
	// Декорация задолженности контрагента
	Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
	Если Долг > 0 Тогда
		Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Долг пациента:";
		Элементы.ДекорацияДолг.Заголовок                = Формат(Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
