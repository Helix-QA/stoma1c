
#Область ОбработчикиСобытийФормы

&НаКлиенте
// Процедура, обарботчик события на сервере
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("ОбновитьСписок");
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВыбЦвет = "#efefef";
	Если ЗначениеЗаполнено(Объект.Цвет) Тогда
		Элементы.КнопкаЦвет.ЦветФона = ОбщегоназначенияКлиентСерверСтоматология.ПолучитьЦветRGB(Объект.Цвет);
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();

КонецПроцедуры

&НаКлиенте
// Процедура, обаработчик события "ПриОткрытии"
//
Процедура ПриОткрытии(Отказ)
	
	#Если ВебКлиент Тогда
		ЭтоВебКлиент = Истина;
	#Иначе
		ЭтоВебКлиент = Ложь;
	#КонецЕсли
	
	ПолеHTML = ПолучитьШапкуСтраницы();
	СформироватьКнопки();
	ПолеHTML = ПолеHTML + ПолучитьПодвалСтраницы();

КонецПроцедуры

#КонецОбласти

