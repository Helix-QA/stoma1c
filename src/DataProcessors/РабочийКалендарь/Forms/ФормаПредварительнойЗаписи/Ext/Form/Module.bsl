Процедура ПравкаВставить(Команда)	
	Если БуферОбмена.Буфер <> Неопределено И ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти) И НЕ ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда
		СоздатьСобытиеКопированием(БуферОбмена.Буфер, БуферОбмена.ПризнакВырезать);
		Оповестить("ИзмененоСобытие");
		Если БуферОбмена.ПризнакВырезать = Истина Тогда
			БуферОбмена.ПризнакВырезать  = Ложь;
			БуферОбмена.Буфер = Неопределено;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
// Процедура создание групповой записи копированием из существующей.
//
Процедура СоздатьСобытиеКопированием(СтруктураСобытия, Перенести = Ложь)
	
	ОбластьКалендаря = Элементы.ТабличныйДокумент.ТекущаяОбласть;
	Если ТипЗнч(СтруктураСобытия.ИндексВТЧ) <> Тип("Массив") Тогда
		НовыйМассив = Новый Массив;
		НовыйМассив.Добавить(СтруктураСобытия.ИндексВТЧ);
		СтруктураСобытия.ИндексВТЧ = НовыйМассив; 
	КонецЕсли;	
	// Высчитываем реквизиты события по переданной области
	Старт = ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / 4) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / 4) * 4 * 15 * 60;
	СтартДельта = СтруктураСобытия.Событие.Услуги[СтруктураСобытия.ИндексВТЧ[0]].ДатаНачала;		
	Если Перенести Тогда
		СобытиеОбъект = СтруктураСобытия.Событие.ПолучитьОбъект();
		Для Каждого ИндексСтрокиСобытия Из СтруктураСобытия.ИндексВТЧ Цикл
			СтрокаСобытия               = СобытиеОбъект.Услуги[ИндексСтрокиСобытия];
			СтрокаСобытия.ДатаНачала    = Старт + (СтрокаСобытия.ДатаНачала - СтартДельта);
			СтрокаСобытия.ДатаОкончания = Старт + (СтрокаСобытия.ДатаОкончания - СтартДельта);			
			СтрокаСобытия.Сотрудник     = ?(Не ОтборСотрудник.Пустая(), ОтборСотрудник, СтрокаСобытия.Сотрудник);
			СтрокаСобытия.Помещение     = СтрокаСобытия.Помещение;
		КонецЦикла;
	Иначе
		СобытиеОбъект      = СтруктураСобытия.Событие.ПолучитьОбъект().Скопировать();
		СобытиеОбъект.Дата = ТекущаяДата();
		СобытиеОбъект.Услуги.Очистить();
		Для Каждого ИндексСтрокиСобытия Из СтруктураСобытия.ИндексВТЧ Цикл
			СтрокаСобытия = СтруктураСобытия.Событие.Услуги[ИндексСтрокиСобытия];
			НоваяСтрока   = СобытиеОбъект.Услуги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСобытия);
			НоваяСтрока.ДатаНачала    = Старт + (НоваяСтрока.ДатаНачала - СтартДельта);
			НоваяСтрока.ДатаОкончания = Старт + (НоваяСтрока.ДатаОкончания - СтартДельта);
			НоваяСтрока.Сотрудник     = ?(Не ОтборСотрудник.Пустая(), ОтборСотрудник, НоваяСтрока.Сотрудник);
			НоваяСтрока.Помещение     = НоваяСтрока.Помещение;
		КонецЦикла;		
	КонецЕсли;	
	
	// Запускаем ОбработкаПроверкиЗаполнения.
	ЗаписьРазрешена = СобытиеОбъект.ПроверитьЗаполнение();	
	
	Если ЗаписьРазрешена = Истина Тогда		 
		
		Попытка
			СобытиеОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
			ВызватьИсключение;	
		КонецПопытки;
		
	КонецЕсли;
		
КонецПроцедуры

