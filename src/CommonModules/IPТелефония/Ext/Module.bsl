// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция BINOTEL_ТестированиеСервера(Сервер, Порт, key, secret, ОписаниеОшибки = "") Экспорт
	
	ТаблицаПараметров = Новый ТаблицаЗначений();
	ТаблицаПараметров.Колонки.Добавить("Ключ");
    ТаблицаПараметров.Колонки.Добавить("Значение");
	
	НоваяСтрока = ТаблицаПараметров.Добавить();
	НоваяСтрока.Ключ = "timestamp";
	НоваяСтрока.значение = 1390528860;
	
    СтрокаJSON = BINOTEL_ГенерацияSignature(key, secret, ТаблицаПараметров);
	
	Попытка
		
		СайтАдрес = ПреобразоватьАдресСервера(Сервер);
		
		Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());		
		HTTPЗапрос = Новый HTTPЗапрос("/api/3.0/stats/list-of-calls-per-day.json", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда				
				ОписаниеОшибки = ОписаниеОшибки + " (" + ОтветHTTP + ")";
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - BINOTEL событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция BINOTEL_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	requestType   = ?(ПараметрыJSON.Свойство("requestType"), ПараметрыJSON.requestType, Неопределено);	
	ПараметрыJSON = ?(ПараметрыJSON.Свойство("callDetails"), ПараметрыJSON.callDetails, ПараметрыJSON);
	
	УнифицированнаяСтруктураСобытия 					  = ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 		  = ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 			  = ?(ПараметрыJSON.Свойство("generalCallID"), ПараметрыJSON.generalCallID, Неопределено);
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие = Ложь;
		
	callType = ?(ПараметрыJSON.Свойство("callType"), ПараметрыJSON.callType, Неопределено);
	Если callType = "0" Тогда 
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   = ?(ПараметрыJSON.Свойство("internalNumber"), ПараметрыJSON.internalNumber, Неопределено);
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = ?(ПараметрыJSON.Свойство("externalNumber"), ПараметрыJSON.externalNumber, Неопределено);
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий;
	ИначеЕсли callType = "1" Тогда 
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom = ?(ПараметрыJSON.Свойство("internalNumber"), ПараметрыJSON.internalNumber, Неопределено);
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   = ?(ПараметрыJSON.Свойство("externalNumber"), ПараметрыJSON.externalNumber, Неопределено);
		УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий;
	КонецЕсли;
	
	disposition = ?(ПараметрыJSON.Свойство("disposition"), ПараметрыJSON.disposition, Неопределено); 
	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда  			
		
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= (disposition = "CONGESTION" 
																	ИЛИ disposition = "CHANUNAVAIL"
																	ИЛИ disposition = "BUSY"
																	ИЛИ disposition = "NOANSWER"
																	ИЛИ disposition = "CANCEL");
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;						
	КонецЕсли; 
		
	    startTime = ?(ПараметрыJSON.Свойство("startTime"), ПараметрыJSON.startTime, 0);
		waitsec   = ?(ПараметрыJSON.Свойство("waitsec"), ПараметрыJSON.waitsec, 0);
	    billsec   = ?(ПараметрыJSON.Свойство("billsec"), ПараметрыJSON.billsec, 0);
		
	Если requestType = "receivedTheCall" Тогда // receivedTheCall
		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 			= Перечисления.СтатусыЗвонка.Вызов;							
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 	= ТекущаяДатаСеанса();
		Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли requestType = "answeredTheCall" Тогда // answeredTheCall
		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= Перечисления.СтатусыЗвонка.Разговор;
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 			= ТекущаяДатаСеанса();			
		Возврат СобытиеЗвонокСоединение(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли requestType = "apiCallCompleted" Тогда // apiCallCompleted
		
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 	       = ?(УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий И УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.Завершен); 		
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова = МестноеВремя(Дата(1970, 01, 01) + startTime, ПолучитьЧасовойПоясИнформационнойБазы());
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 	   = ?(УнифицированнаяСтруктураСобытия.СтатусЗвонка = Перечисления.СтатусыЗвонка.Пропущен, Неопределено, МестноеВремя(Дата(1970, 01, 01) + startTime + waitsec, ПолучитьЧасовойПоясИнформационнойБазы()));			
		УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова  = МестноеВремя(Дата(1970, 01, 01) + startTime + waitsec + billsec, ПолучитьЧасовойПоясИнформационнойБазы());
		// УнифицированнаяСтруктураСобытия.ПринятДругимАбонентомГруппы = УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий И ПараметрыJSON.Свойство("disconnect_reason") И СтрЗаменить(ПараметрыJSON.Disconnect_Reason," ","") = 1100;
		Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);  
		
	Иначе		
		ОписаниеОшибки = "Функция не существует или не распознана.'";
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Функция - BINOTEL событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция BINOTEL_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	Результат = Истина;
	ФайлСсылка = Неопределено;
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено 
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ IPТелефонияПараметры.Свойство("Сервер") = Ложь 
		ИЛИ IPТелефонияПараметры.Свойство("Пароль") = Ложь 
		ИЛИ IPТелефонияПараметры.Свойство("Ключ") = Ложь Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
		
	КонецЕсли;
	
	ТаблицаПараметров = Новый ТаблицаЗначений();
	ТаблицаПараметров.Колонки.Добавить("Ключ");
	ТаблицаПараметров.Колонки.Добавить("Значение");
	
	НоваяСтрока = ТаблицаПараметров.Добавить();
	НоваяСтрока.Ключ = "generalCallID";
	НоваяСтрока.значение = ПараметрыJSON.generalCallID;
	
	СтрокаJSON = BINOTEL_ГенерацияSignature(IPТелефонияПараметры.Ключ, IPТелефонияПараметры.Пароль, ТаблицаПараметров);
	
	Попытка
		
		Сервер    = IPТелефонияПараметры.Сервер;
		СайтАдрес = ПреобразоватьАдресСервера(Сервер);
		
		Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());		
		HTTPЗапрос = Новый HTTPЗапрос("/api/3.0/stats/call-record.json", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда				
				ОписаниеОшибки = ОписаниеОшибки + " (" + ОтветHTTP + ")";
			КонецЕсли;
			
			Возврат Ложь;
			
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;	               
	
	Если СтруктураОтвета.КодСостояния = 200 Тогда 
		
		ОтветHTTP = РаскодироватьСтроку(СтруктураОтвета.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);	
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ОтветHTTP);
		ПараметрыОтветаJSON = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		ФайлСсылка = ?(ПараметрыОтветаJSON.Свойство("url"), ПараметрыОтветаJSON.url, Неопределено);		
		
	Иначе 
		Возврат Неопределено;
	КонецЕсли;	
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.generalCallID;
	УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка 		= ФайлСсылка;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
	
	ДобавитьОбновитьЗвонокВИсторию(ПараметрыJSON, УнифицированнаяСтруктураСобытия);
	
	Возврат Результат;
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция BINOTEL_ИсходящийЗвонокОсуществить(ПОIPТелефонии, ВнутреннийНомерТелефона, ВнешнийНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Пароль")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Ключ") Тогда
		
		ОписаниеОшибки = НСтр("ru= 'Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.';en= 'Error! It is necessary to configure the IP-telephony server in the connected equipment.'");
		Возврат Ложь;
		
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("externalNumber"	, ВнешнийНомерТелефона);
	СтруктураПараметров.Вставить("internalNumber"	, ВнутреннийНомерТелефона);
	СтруктураПараметров.Вставить("key"				, IPТелефонияПараметры.Ключ);
	СтруктураПараметров.Вставить("secret"			, IPТелефонияПараметры.Пароль);
	
	СтрокаJSON = КодироватьВJSON(СтруктураПараметров);
	
	Попытка
		
		Соединение = Новый HTTPСоединение("api.binotel.com", 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		HTTPЗапрос = Новый HTTPЗапрос("/api/4.0/calls/internal-number-to-external-number.json", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ОтветHTTP 		= СтруктураОтвета.ПолучитьТелоКакСтроку();
		
		Если СтруктураОтвета.КодСостояния <> 200 ИЛИ СтруктураОтвета.КодСостояния = 200 И СтрНайти(ОтветHTTP, """status"":""error""") <> 0 Тогда
			
			ОписаниеОшибки = НСтр("ru= 'Ошибка сервиса IP-телефонии: ';en= 'IP-telephony service error: '") + СтруктураОтвета.КодСостояния;
			
			Если ОтветHTTP <> "" Тогда
				ОписаниеОшибки = ОписаниеОшибки + " : " + ОтветHTTP;
			КонецЕсли;
			
			Возврат Ложь;
			
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция BINOTEL_ПолучениеФайлаЗаписиРазговора(ПОIPТелефонии, IDЗвонка, ОписаниеОшибки = "", СтруктураПереадресации = Неопределено) Экспорт
	
	АдресВоВременномХранилище = "";
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено 
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ IPТелефонияПараметры.Свойство("Сервер") = Ложь 
		ИЛИ IPТелефонияПараметры.Свойство("Пароль") = Ложь 
		ИЛИ IPТелефонияПараметры.Свойство("Ключ") = Ложь Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
		
	КонецЕсли;
	
	ТаблицаПараметров = Новый ТаблицаЗначений();
	ТаблицаПараметров.Колонки.Добавить("Ключ");
	ТаблицаПараметров.Колонки.Добавить("Значение");
	
	НоваяСтрока = ТаблицаПараметров.Добавить();
	НоваяСтрока.Ключ = "generalCallID";
	НоваяСтрока.значение = IDЗвонка;
	
	СтрокаJSON = BINOTEL_ГенерацияSignature(IPТелефонияПараметры.Ключ, IPТелефонияПараметры.Пароль, ТаблицаПараметров);
	
	Попытка
		
		Сервер    = IPТелефонияПараметры.Сервер;
		СайтАдрес = ПреобразоватьАдресСервера(Сервер);
		
		Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());		
		HTTPЗапрос = Новый HTTPЗапрос("/api/3.0/stats/call-record.json", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда				
				ОписаниеОшибки = ОписаниеОшибки + " (" + ОтветHTTP + ")";
			КонецЕсли;
			
			Возврат Ложь;
			
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;	               
	
	Если СтруктураОтвета.КодСостояния = 200 Тогда 
		ДвоичныеДанныеФайла = СтруктураОтвета.ПолучитьТелоКакДвоичныеДанные();
		АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла);
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат АдресВоВременномХранилище;
	
КонецФункции

// Функция - BINOTEL генерация signature
// 
Функция BINOTEL_ГенерацияSignature(key, secret, ТаблицаПараметров) Экспорт 
		
	СтрокаJSON = BINOTEL_ТаблицаПараметровВJSON(ТаблицаПараметров);
	
	signature = BINOTEL_ПолучитьMD5(secret + СтрокаJSON);
	
	НоваяСтрока = ТаблицаПараметров.Добавить();
	НоваяСтрока.Ключ = "signature";
	НоваяСтрока.значение = signature;
	
	НоваяСтрока = ТаблицаПараметров.Добавить();
	НоваяСтрока.Ключ = "key";
	НоваяСтрока.значение = key;
	
	Возврат BINOTEL_ТаблицаПараметровВJSON(ТаблицаПараметров); 
	
КонецФункции
 
// Функция - BINOTEL таблица параметров в JSON
// 
Функция BINOTEL_ТаблицаПараметровВJSON(ТаблицаПараметров)
		
	ТаблицаПараметров.Сортировать("Ключ");
	СтруктураПараметров = Новый Структура();
	
	Для Каждого СтрокаТЗ Из ТаблицаПараметров Цикл
		СтруктураПараметров.Вставить(СтрокаТЗ.Ключ, СтрокаТЗ.Значение);
	КонецЦикла;   
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет);	
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи); 
	ЗаписатьJSON(ЗаписьJSON, СтруктураПараметров); 
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Функция - BINOTEL получить m d5
// 
Функция BINOTEL_ПолучитьMD5(Текст) Экспорт
	
	ОбъектХеш = Новый ХешированиеДанных(ХешФункция.MD5);
	ОбъектХеш.Добавить(Текст);  	
	Возврат НРег(СтрЗаменить(ОбъектХеш.ХешСумма, " ", "")); 
	
КонецФункции

