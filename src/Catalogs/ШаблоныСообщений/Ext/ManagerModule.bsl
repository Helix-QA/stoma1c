// Функция - Получить шаблоны сообщений.
//
Функция ПолучитьШаблоныСообщений(ТипШаблона = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ШаблоныСообщений.Ссылка КАК Ссылка,
	|	ШаблоныСообщений.Наименование КАК Наименование,
	|	ШаблоныСообщений.Содержание КАК Содержание,
	|	ШаблоныСообщений.СодержаниеМессенджер КАК СодержаниеМессенджер
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	НЕ ШаблоныСообщений.ПометкаУдаления
	|	И НЕ ШаблоныСообщений.ЭтоГруппа
	|	И &УсловиеТипШаблона
	|
	|УПОРЯДОЧИТЬ ПО
	|	ШаблоныСообщений.Наименование");
	
	УсловиеТипШаблона = "";
	
	Если ТипШаблона = Перечисления.ТипыСобытий.Письмо Тогда
		УсловиеТипШаблона = "И (ВЫРАЗИТЬ(ШаблоныСообщений.ТекстHTML КАК СТРОКА(200))) <> """"";
	ИначеЕсли ТипШаблона = Перечисления.ТипыСобытий.SMS Тогда
		УсловиеТипШаблона = "И (ВЫРАЗИТЬ(ШаблоныСообщений.Содержание КАК СТРОКА(200))) <> """"";  
	ИначеЕсли ТипШаблона = Перечисления.ТипыСобытий.ПушУведомление Тогда
		УсловиеТипШаблона = "И (ВЫРАЗИТЬ(ШаблоныСообщений.СодержаниеPush КАК СТРОКА(200))) <> """"";  
	ИначеЕсли ТипШаблона = Перечисления.ТипыСобытий.Мессенджер Тогда
		УсловиеТипШаблона = "И (ВЫРАЗИТЬ(ШаблоныСообщений.СодержаниеМессенджер КАК СТРОКА(200))) <> """"";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеТипШаблона", УсловиеТипШаблона);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

