
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.ТекущийСотрудник = ПараметрыСеанса.ТекущийСотрудник;
	Элементы.ГруппаВыборИнтервалаЗаписи.Доступность = РольДоступна("СогласованиеСтраховыхУслуг");
	
	ЭтотОбъект.СтатусОтбор = Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования;
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтатусСогласования", ЭтотОбъект.СтатусОтбор, Истина);	
	
	ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события таблицы формы "СписокПриАктивизацииСтроки".
//
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанныеСписка = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанныеСписка <> Неопределено Тогда 
		
		Если ТекущиеДанныеСписка.РодительскаяГруппировкаСтроки <> Неопределено Тогда
			ЭтотОбъект.СтатусСогласования = ТекущиеДанныеСписка.СтатусСогласования;
		Иначе
			ЭтотОбъект.СтатусСогласования =	Неопределено;
		КонецЕсли;
		
		УстановитьАктивностьТумблеров();
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события элемента формы "СтатусОтборПриИзменении".
//
Процедура СтатусОтборПриИзменении(Элемент)
	
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтатусСогласования", ЭтотОбъект.СтатусОтбор, ЗначениеЗаполнено(ЭтотОбъект.СтатусОтбор));  
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события таблицы "СписокВыбор".
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		
		Если ЗначениеЗаполнено(Элемент.ТекущиеДанные.РодительскаяГруппировкаСтроки) Тогда
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборСогласованияЗавершение", ЭтотОбъект, Элемент.ТекущиеДанные.ИдентификаторСтроки); // Не убирать видидомость ИдентификаторСтроки. Это единственный реквизит для идентификации.
			
			ПараметрыФормы = ПолучитьСтруктуруСтроки(Элемент.ТекущиеДанные);
			ОткрытьФорму("РегистрСведений.СогласованияСтраховыхУслуг.Форма.ФормаСогласования", ПараметрыФормы, ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
			ОповеститьОбИзменении(Элемент.ТекущаяСтрока);
			
		Иначе
			ПоказатьЗначение(,Элемент.ТекущиеДанные.Прием); 
		КонецЕсли;	
 	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды формы "ИзменитьСтатусСогласования".
//
Процедура ИзменитьСтатусСогласования(Команда)
			
	НеактивныеЭлементы = Новый Массив;
	НеактивныеЭлементы.Добавить(Элементы.ГруппаСтатусОжидает);
	НеактивныеЭлементы.Добавить(Элементы.ГруппаСтатусСогласован);
	НеактивныеЭлементы.Добавить(Элементы.ГруппаСтатусОтказ);
	
	Если ТекущийЭлемент.Имя = "УстановитьСтатусОжидает" Тогда
		
		ЭтотОбъект.СтатусСогласования = ПредопределенноеЗначение("Перечисление.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования");
		АктивныйЭлемент = Элементы.ГруппаСтатусОжидает;
		
	ИначеЕсли ТекущийЭлемент.Имя = "УстановитьСтатусСогласован" Тогда
		
		ЭтотОбъект.СтатусСогласования = ПредопределенноеЗначение("Перечисление.СтатусыСогласованияСтраховыхУслуг.Согласован");
		АктивныйЭлемент = Элементы.ГруппаСтатусСогласован;
		
	ИначеЕсли ТекущийЭлемент.Имя = "УстановитьСтатусОтказ" Тогда
		
		ЭтотОбъект.СтатусСогласования = ПредопределенноеЗначение("Перечисление.СтатусыСогласованияСтраховыхУслуг.Отказ");
		АктивныйЭлемент = Элементы.ГруппаСтатусОтказ;
		
	КонецЕсли;
	
	ИндексЭлемента = НеактивныеЭлементы.Найти(АктивныйЭлемент);
	Если ИндексЭлемента <> Неопределено Тогда
		НеактивныеЭлементы.Удалить(ИндексЭлемента);
	КонецЕсли;
	
	ТекущиеДанныеСписка = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанныеСписка <> Неопределено Тогда 
		
		Если ТекущиеДанныеСписка.РодительскаяГруппировкаСтроки <> Неопределено Тогда
			
			ОбновитьЗаписьРегистра(Элементы.Список.ТекущаяСтрока, ЭтотОбъект.СтатусСогласования);
			ОповеститьОбИзменении(Элементы.Список.ТекущаяСтрока); 	
			ОповеститьОткрытыеФормы(ТекущиеДанныеСписка.ИдентификаторСтроки,,ТекущиеДанныеСписка.СтруктурнаяЕдиница);
			
		Иначе                                 
			
			ОбновитьЗаписиРегистраПоПриему(Элементы.Список.ТекущаяСтрока.Ключ);
			Элементы.Список.Обновить();
			ОповеститьОткрытыеФормы(,Элементы.Список.ТекущаяСтрока.Ключ); 
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Обязательно выполняется сначала запись, потом изменение тумблера.
	// Т.к. текущая строка переходит в неопределено.
	ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент, НеактивныеЭлементы);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура - Обновить запись регистра.
//
Процедура ОбновитьЗаписьРегистра(КлючЗаписи, знач СтатусСогласования, КомментарийСогласования = "")

	МенеджерЗаписи = РегистрыСведений.СогласованияСтраховыхУслуг.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, КлючЗаписи); 
	МенеджерЗаписи.Прочитать();
	
	МенеджерЗаписи.СтатусСогласования 	= СтатусСогласования;
	МенеджерЗаписи.Согласователь 		= ЭтотОбъект.ТекущийСотрудник;
	МенеджерЗаписи.ДатаСогласования 	= ТекущаяДатаСеанса();
	МенеджерЗаписи.Комментарий 			= КомментарийСогласования;
	
	Попытка
		МенеджерЗаписи.Записать();
	Исключение
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить записи регистра по приему.
//
Процедура ОбновитьЗаписиРегистраПоПриему(знач Прием)

	НаборЗаписей = РегистрыСведений.СогласованияСтраховыхУслуг.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Прием.Установить(Прием);
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда
		
		Для каждого ЗаписьНабора Из НаборЗаписей Цикл
			
			ЗаписьНабора.СтатусСогласования = СтатусСогласования;
			ЗаписьНабора.Согласователь = ЭтотОбъект.ТекущийСотрудник;
			ЗаписьНабора.ДатаСогласования = ТекущаяДатаСеанса();	
			
		КонецЦикла;
		
		НаборЗаписей.Записать();
		
	КонецЕсли;
	
КонецПроцедуры                         

&НаСервереБезКонтекста
// Функция - Получить структуру строки.
//
Функция ПолучитьСтруктуруСтроки(знач ДанныеФормыСтрока)
	          
	СтруктураПараметров = Новый Структура("СтруктурнаяЕдиница, Прием, ИдентификаторСтроки, Договор, Номенклатура, 
											|Контрагент, СтраховаяКомпания, Зуб, СтатусСогласования, 
											|ДатаОтправки, Ответственный, ДатаСогласования, Согласователь, Комментарий");
	ЗаполнитьЗначенияСвойств(СтруктураПараметров, ДанныеФормыСтрока);

	СтруктураПараметров.Вставить("РежимРедактировать", Истина);
	
	Возврат СтруктураПараметров;

КонецФункции

&НаКлиенте
// Процедура - Оповестить открытые формы.
//
Процедура ОповеститьОткрытыеФормы(ИдентификаторСтроки = Неопределено, ИзмененныйПрием = Неопределено, СтруктурнаяЕдиница = Неопределено)
	
	ПараметрыОповещения = Новый Структура();
	ПараметрыОповещения.Вставить("ИдентификаторСтроки", ИдентификаторСтроки);
	ПараметрыОповещения.Вставить("ИзмененныйПрием", ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(ИзмененныйПрием));
		
	ОповеситьНаСервере(ПараметрыОповещения, СтруктурнаяЕдиница);
	
КонецПроцедуры

&НаСервере
// Процедура - Оповесить на сервере.
//
Процедура ОповеситьНаСервере(Знач ПараметрыОповещения, СтруктурнаяЕдиница)

	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница)
		И ЗначениеЗаполнено(ПараметрыОповещения.ИзмененныйПрием) Тогда
		
		СтруктурнаяЕдиница = ПараметрыОповещения.ИзмененныйПрием.СтруктурнаяЕдиница;	
	КонецЕсли;
	
	ТекущиеСеансы = ПолучитьСеансыИнформационнойБазы();
	
	МассивСеансов 					  = Новый Массив;
	ПользователиОповещения 			  = Новый Массив;

	МассивПараметров = Новый Массив(); 
	Для каждого ЭлементСтруктуры Из ПараметрыОповещения Цикл
		МассивПараметров.Добавить(ЭлементСтруктуры.Значение);
	КонецЦикла;
	
	Для Каждого ТекущийСеанс Из ТекущиеСеансы Цикл
		
		Если ТекущийСеанс.ИмяПриложения = "1CV8C"
			ИЛИ ТекущийСеанс.ИмяПриложения = "WebClient" Тогда
			
			Если ИспользоватьСистемуВзаимодействия = Истина Тогда
				
				// Получаем сеансы, которые необходимо оповестить.
				МассивСеансов.Добавить(ТекущийСеанс.НомерСеанса);
				ПользователиОповещения.Добавить(ТекущийСеанс.Пользователь);
				
			Иначе	
								
				// Создаем оповещение через регистр сведений.
				РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(ТекущийСеанс.НомерСеанса,
				СтруктурнаяЕдиница,
				"ОбновитьСогласованияСтраховыхУслуг_" + Новый УникальныйИдентификатор(),
				ТекущаяДатаСеанса(), 
				60,,,
				МассивПараметров);  
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла; 
	
	Если ИспользоватьСистемуВзаимодействия = Истина
		И ПользователиОповещения.Количество() > 0 Тогда
		
		// Создаем оповещение через систему взаимодействия.
		ДанныеСообщения = Новый Структура;
		ДанныеСообщения.Вставить("Ключ", "ОбновитьСогласованияСтраховыхУслуг");
		ДанныеСообщения.Вставить("ПараметрыОповещения", ПараметрыОповещения);
		
		ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Выбор согласования завершение.
//
Процедура ВыборСогласованияЗавершение(Результат, ДопПараметры) Экспорт 
	
	Если ЗначениеЗаполнено(ДопПараметры)
		И Результат <> Неопределено Тогда 
		
		ОповеститьОткрытыеФормы(ДопПараметры,,Элементы.Список.ТекущиеДанные.СтруктурнаяЕдиница);
		ОбновитьЗаписьРегистра(Элементы.Список.ТекущаяСтрока, Результат.СтатусСогласования, Результат.КомментарийСогласования); 
		ОповеститьОбИзменении(Элементы.Список.ТекущаяСтрока); 
		
	КонецЕсли;	
	
КонецПроцедуры

 &НаКлиенте
// Процедура, изменяет видимость групп переключателей.
//
Процедура ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент = Неопределено, НеактивныйЭлемент = Неопределено, Активировать = Истина)
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент, НеактивныйЭлемент, Активировать, ЭтаФорма);
	
КонецПроцедуры

&НаСервере
// Процедура, изменяет видимость групп переключателей.
//
Процедура ИзменитьАктивностьПереключателяФормыНаСервере(АктивныйЭлемент = Неопределено, НеактивныйЭлемент = Неопределено, Активировать = Истина)
	
	УправлениеИнтерфейсамиСервер.ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент, НеактивныйЭлемент, Активировать, ЭтаФорма);
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает активность тумблеров.
//
Процедура УстановитьАктивностьТумблеров()
	
	НеактивныеЭлементы = Новый Массив;
	НеактивныеЭлементы.Добавить(Элементы.ГруппаСтатусОжидает);
	НеактивныеЭлементы.Добавить(Элементы.ГруппаСтатусСогласован);
	НеактивныеЭлементы.Добавить(Элементы.ГруппаСтатусОтказ);

	Если ЭтотОбъект.СтатусСогласования = Перечисления.СтатусыСогласованияСтраховыхУслуг.Согласован Тогда
		АктивныйЭлемент = Элементы.ГруппаСтатусСогласован;
	ИначеЕсли ЭтотОбъект.СтатусСогласования = Перечисления.СтатусыСогласованияСтраховыхУслуг.Отказ Тогда
		АктивныйЭлемент = Элементы.ГруппаСтатусОтказ;
	ИначеЕсли ЭтотОбъект.СтатусСогласования = Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования Тогда
		АктивныйЭлемент = Элементы.ГруппаСтатусОжидает;
	Иначе 
		АктивныйЭлемент = Неопределено;
	КонецЕсли;
	
	ИндексЭлемента = НеактивныеЭлементы.Найти(АктивныйЭлемент);
	Если ИндексЭлемента <> Неопределено Тогда
		НеактивныеЭлементы.Удалить(ИндексЭлемента);
	КонецЕсли;
	
	ИзменитьАктивностьПереключателяФормыНаСервере(АктивныйЭлемент, НеактивныеЭлементы);
		
КонецПроцедуры


#КонецОбласти