
#Область СлужебныйПрограммныйИнтерфейс

//
//
Процедура ПолучитьСтруктуруНастроекВидаБонусногоСчета(Знач ВидБонусногоСчета, СтруктураНастроекБС) Экспорт

	Если СтруктураНастроекБС = Неопределено ИЛИ ТипЗнч(СтруктураНастроекБС) <> Тип("Структура")Тогда 
		СтруктураНастроекБС = Новый Структура;
	ИначеЕсли ТипЗнч(СтруктураНастроекБС) = Тип("Структура") Тогда 
		СтруктураНастроекБС.Очистить();
	КонецЕсли;
	
	ВидБСЗаполнен = ЗначениеЗаполнено(ВидБонусногоСчета);
	
	СтруктураНастроекБС.Вставить("Именной"								, ?(ВидБСЗаполнен, ВидБонусногоСчета.Именной, Ложь));
	СтруктураНастроекБС.Вставить("НеОграниченПроцентомСписания"			, ?(ВидБСЗаполнен, ВидБонусногоСчета.НеОграниченПроцентомСписания, Истина));
	СтруктураНастроекБС.Вставить("ОграничениеНачисленийПоСрокуДействия"	, ?(ВидБСЗаполнен, ВидБонусногоСчета.ОграничениеНачисленийПоСрокуДействия, Перечисления.ТипыОграниченийСрокаДействия.Бессрочный));
	СтруктураНастроекБС.Вставить("ОграничениеПоСрокуДействия"			, ?(ВидБСЗаполнен, ВидБонусногоСчета.ОграничениеПоСрокуДействия, Перечисления.ТипыОграниченийСрокаДействия.Бессрочный));
	СтруктураНастроекБС.Вставить("ОграничениеСписанияПроцент"			, ?(ВидБСЗаполнен, ВидБонусногоСчета.ОграничениеСписанияПроцент, 0));
	СтруктураНастроекБС.Вставить("СегментНоменклатуры"					, ?(ВидБСЗаполнен, ВидБонусногоСчета.СегментНоменклатуры, Справочники.СегментыНоменклатуры.ПустаяСсылка()));
	СтруктураНастроекБС.Вставить("СрокДействия"							, ?(ВидБСЗаполнен, ВидБонусногоСчета.СрокДействия, 0));
	СтруктураНастроекБС.Вставить("СрокДействияДатойС"					, ?(ВидБСЗаполнен, ВидБонусногоСчета.СрокДействияДатойС, Дата(1,1,1)));
	СтруктураНастроекБС.Вставить("СрокДействияДатойПо"					, ?(ВидБСЗаполнен, ВидБонусногоСчета.СрокДействияДатойПо, Дата(1,1,1)));
	СтруктураНастроекБС.Вставить("СрокДействияНачислений"				, ?(ВидБСЗаполнен, ВидБонусногоСчета.СрокДействияНачислений, 0));
	СтруктураНастроекБС.Вставить("СрокДействияНачисленийТип"			, ?(ВидБСЗаполнен, ВидБонусногоСчета.СрокДействияНачисленийТип, Перечисления.Периодичность.День));
	СтруктураНастроекБС.Вставить("СрокДействияТип"						, ?(ВидБСЗаполнен, ВидБонусногоСчета.СрокДействияТип, Перечисления.Периодичность.День));
	СтруктураНастроекБС.Вставить("СуммаНачисленияВДеньРождения"			, ?(ВидБСЗаполнен, ВидБонусногоСчета.СуммаНачисленияВДеньРождения, 0));
	
КонецПроцедуры

//
//
Функция ВернутьВидыБонусныхСчетов() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВидыБонусныхСчетов.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ВидыБонусныхСчетов КАК ВидыБонусныхСчетов
	               |ГДЕ
	               |	НЕ ВидыБонусныхСчетов.ПометкаУдаления";
			
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция создает или возвращает существующий вид бонусного счета SKLLZZ.
//
Функция ПолучитьСоздатьВидБонусногоСчетаSKLLZZ(ВнешняяСистема) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыБонусныхСчетов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыБонусныхСчетов КАК ВидыБонусныхСчетов
	|ГДЕ
	|	НЕ ВидыБонусныхСчетов.ПометкаУдаления
	|	И ВидыБонусныхСчетов.ВнешняяСистема = &ВнешняяСистема";
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
		
		Если ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура") Тогда
			
			ВидБС = Справочники.ВидыБонусныхСчетов.СоздатьЭлемент();
			Если ПараметрыВнешнейСистемы.Свойство("ПакетУслугСоставУслуг") Тогда
				ВидБС.ПакетУслугСоставУслуг.Загрузить(ПараметрыВнешнейСистемы.ПакетУслугСоставУслуг);	
			КонецЕсли;
			
			ВидБС.Наименование 					= ПараметрыВнешнейСистемы.НаименованиеВидаБонусногоСчета;
			ВидБС.ОграничениеСписанияПроцент 	= ПараметрыВнешнейСистемы.ОграничениеСписанияПроцент;
			ВидБС.НеОграниченПроцентомСписания 	= ПараметрыВнешнейСистемы.НеОграниченПроцентомСписания;
			ВидБС.КурсОбмена 					= ПараметрыВнешнейСистемы.КурсОбмена;
			// ВидБС.Внешний 						= Истина;
			ВидБС.Именной 						= Истина;
			ВидБС.ВнешняяСистема 				= ВнешняяСистема;		
			ВидБС.ОграничениеПоСрокуДействия 	= Перечисления.ТипыОграниченийСрокаДействия.Бессрочный;
			ВидБС.ОграничениеНачисленийПоСрокуДействия 	= Перечисления.ТипыОграниченийСрокаДействия.Бессрочный;
			
			ВидБС.Записать();
			
			Возврат ВидБС.Ссылка;
			
		Иначе
			Возврат Неопределено;			
		КонецЕсли;
		
	Иначе
		
		ВыборкаЗапроса = РезультатЗапроса.Выбрать();
		Возврат ?(ВыборкаЗапроса.Следующий(), ВыборкаЗапроса.Ссылка, Справочники.ВидыБонусныхСчетов.ПустаяСсылка());
		
	КонецЕсли;
		
КонецФункции

#КонецОбласти