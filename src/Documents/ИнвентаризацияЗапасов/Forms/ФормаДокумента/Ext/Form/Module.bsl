// Процедура, заполняет табличную часть "Запасы" по остаткам склада.
//  Параметры:
//   Нет;
//
Процедура ЗаполнитьПоСправочникуОстатки(ПерезаполнитьЦены)
	
	Объект.Запасы.Очистить();
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	
	УстановитьЗначениеПараметраНастроек(ОтборИнвентаризации.Настройки, "Склад" , ТекОбъект.Склад);
	УстановитьЗначениеПараметраНастроек(ОтборИнвентаризации.Настройки, "Период", ПолучитьДатуОстатков(ТекОбъект));
	УстановитьЗначениеПараметраНастроек(ОтборИнвентаризации.Настройки, "СтруктурнаяЕдиница", ТекОбъект.СтруктурнаяЕдиница);
	
	СхемаКомпоновки = Документы.ИнвентаризацияЗапасов.ПолучитьМакет("ОтборПоСправочнику");
	
	МакетКомпоновки = ОбщегоНазначенияСтоматология.ПолучитьМакетКомпоновки(СхемаКомпоновки, ОтборИнвентаризации.Настройки);
	
	Запрос = ОбщегоНазначенияСтоматология.ПолучитьЗапросИзМакетаКомпоновки(МакетКомпоновки, "ЗаполнениеПоОтборам");
	
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = ТекОбъект.Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.КоличествоВБазовыхЕИ = Выборка.КоличествоУпаковокПоДаннымУчета;			
		КонецЦикла;
		
		ЗначениеВРеквизитФормы(ТекОбъект, "Объект");
		ПерезаполнитьЦены = Истина;
	КонецЕсли;
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ЗапасыНоменклатураПриИзменении(Элемент, СтрокаДанных = Неопределено)
	
	Если СтрокаДанных = Неопределено Тогда
		СтрокаДанных = Элементы.Запасы.ТекущиеДанные;
	КонецЕсли;
	
	СтрокаДанных.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаДанных.Номенклатура, "ИспользоватьПартии");
	СтрокаДанных.ЭтоСертификат = (ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаДанных.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"));
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
	СтруктураДанные.Вставить("Номенклатура", 		СтрокаДанных.Номенклатура);
	СтруктураДанные.Вставить("Упаковка", 			СтрокаДанных.Упаковка);
	СтруктураДанные.Вставить("КоличествоУпаковок",  СтрокаДанных.КоличествоУпаковок);
	СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);			
	СтрокаДанных.Цена = СтруктураДанные.Цена;    
	СтрокаДанных.Упаковка = СтруктураДанные.Упаковка;

	// получаем остаток по текущей строке
	ЗаполнитьУчетныеДанныеСтроки(Объект.Запасы.Индекс(СтрокаДанных));
	
	СтрокаДанных.КоличествоВБазовыхЕИ = СтрокаДанных.КоличествоУпаковокПоДаннымУчета;	
		
	Если НЕ ЗначениеЗаполнено(СтрокаДанных.КоличествоУпаковок) Тогда
		СтрокаДанных.КоличествоУпаковок = 1;
		ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаДанных);
	КонецЕсли;

	РассчитатьОтклонениеПоСтрокеТабличнойЧасти(СтрокаДанных);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаДанных);
	РассчитатьСуммуУчетаТабЧасти(СтрокаДанных);

	ОбновитьЗаголовкиТабЧастейНаСервере();

КонецПроцедуры

&НаСервере
// Процедура заполняет конкретную строку учетными данными
// 
Процедура ЗаполнитьУчетныеДанныеСтроки(ИндексСтроки)
	
	Если ИндексСтроки = -1 Тогда
		Возврат;
	Иначе	
		Попытка
			СтрокаТЧ = Объект.Запасы[ИндексСтроки];
		Исключение
			Возврат;
		КонецПопытки;
	КонецЕсли;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаЗатраты.Номенклатура КАК Номенклатура,
	|	ТаблицаЗатраты.Партия КАК Партия,
	|	ТаблицаЗатраты.Упаковка КАК Упаковка,
	|	ТаблицаЗатраты.Коэффициент КАК Коэффициент,
	|	ТаблицаЗатраты.Количество КАК Количество,
	|	ТаблицаЗатраты.Цена КАК Цена,                                             
	|	ТаблицаЗатраты.КоличествоУпаковок КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ИнвентаризацияЗапасов
	|ИЗ
	|	&ТаблицаЗатраты КАК ТаблицаЗатраты";   	
	
	ТЗ = Объект.Запасы.Выгрузить(Новый Структура("Номенклатура", СтрокаТЧ.Номенклатура));
	
	ТЗ.Колонки.Добавить("Коэффициент", Новый ОписаниеТипов("Число",, Новый КвалификаторыЧисла(10,3)));
	
	Для Каждого СтрокаДанных Из ТЗ Цикл
		СтрокаДанных.Коэффициент = ?(СтрокаДанных.Упаковка.Коэффициент <> 0, СтрокаДанных.Упаковка.Коэффициент, 1);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТаблицаЗатраты", ТЗ);
	
	Запрос.Выполнить(); 	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ИнвентаризацияЗапасовЗапасы.Номенклатура,
	|	ИнвентаризацияЗапасовЗапасы.Партия,
	|	ИнвентаризацияЗапасовЗапасы.Упаковка,
	|	ИнвентаризацияЗапасовЗапасы.Коэффициент,
	|	ИнвентаризацияЗапасовЗапасы.Количество,
	|	ИнвентаризацияЗапасовЗапасы.Цена,
	|	ИнвентаризацияЗапасовЗапасы.КоличествоУпаковок,
	|	ВложенныйЗапрос.КоличествоПоДаннымУчета,
	|	ВЫБОР
	|		КОГДА ИнвентаризацияЗапасовЗапасы.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ВложенныйЗапрос.КоличествоПоДаннымУчета
	|		ИНАЧЕ ВложенныйЗапрос.КоличествоПоДаннымУчета / ЕСТЬNULL(ИнвентаризацияЗапасовЗапасы.Коэффициент, 1)
	|	КОНЕЦ КАК КоличествоУпаковокПоДаннымУчета,
	|	ВЫБОР
	|		КОГДА ИнвентаризацияЗапасовЗапасы.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ВложенныйЗапрос.КоличествоПоДаннымУчета
	|		ИНАЧЕ ВложенныйЗапрос.КоличествоПоДаннымУчета / ЕСТЬNULL(ИнвентаризацияЗапасовЗапасы.Коэффициент, 1)
	|	КОНЕЦ КАК КоличествоВБазовыхЕИ
	|ИЗ
	|	ИнвентаризацияЗапасов КАК ИнвентаризацияЗапасовЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапасыОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыОстатки.Партия КАК Партия,
	|			СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоПоДаннымУчета
	|		ИЗ
	|			РегистрНакопления.ЗапасыНаСкладах.Остатки(
	|					&ДатаСреза,
	|					СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						И Склад = &Склад) КАК ЗапасыОстатки
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗапасыОстатки.Партия,
	|			ЗапасыОстатки.Номенклатура) КАК ВложенныйЗапрос
	|		ПО ИнвентаризацияЗапасовЗапасы.Номенклатура = ВложенныйЗапрос.Номенклатура
	|			И ИнвентаризацияЗапасовЗапасы.Партия = ВложенныйЗапрос.Партия";
	     	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	Запрос.УстановитьПараметр("Склад"				, Объект.Склад);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза"			, ПолучитьДатуОстатков(ТекОбъект)); 
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, Результат[0]);
	Иначе
		СтрокаТЧ.КоличествоПоДаннымУчета			= 0;
		СтрокаТЧ.КоличествоУпаковокПоДаннымУчета	= 0;   
	КонецЕсли;         	
	
	УпаковкаПоУмолчанию = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "УпаковкаПоУмолчанию");
	Если ЗначениеЗаполнено(УпаковкаПоУмолчанию)
		И Не ЗначениеЗаполнено(СтрокаТЧ.Упаковка) Тогда
		
		СтрокаТЧ.КоличествоУпаковокПоДаннымУчета = СтрокаТЧ.КоличествоУпаковокПоДаннымУчета / УпаковкаПоУмолчанию.Коэффициент;
		СтрокаТЧ.Упаковка						 = УпаковкаПоУмолчанию;
	// ИначеЕсли Не ЗначениеЗаполнено(УпаковкаПоУмолчанию) Тогда
	//	СтрокаТЧ.Упаковка = Справочники.УпаковкиНоменклатуры.ПустаяСсылка();
	КонецЕсли;			
	
	ОбщегоНазначения.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	
КонецПроцедуры 

