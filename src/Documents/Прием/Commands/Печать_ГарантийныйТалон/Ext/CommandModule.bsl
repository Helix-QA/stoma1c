
#Область ОбработчикиСобытий

&НаКлиенте
// Процедура - обработчик события "ОбработкаКоманды".
//
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ПараметрКоманды.Количество() = 1 Тогда 
		ПровестиДокумент(ПараметрКоманды[0]);
	КонецЕсли;
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.Прием", "ПФ_MXL_ГарантийныйТалон", ПараметрКоманды, Неопределено, Неопределено);
	
КонецПроцедуры

&НаСервере
Процедура ПровестиДокумент(ДокументСсылка)
	
	Если Не ДокументСсылка.Проведен Тогда
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;  
	
КонецПроцедуры

#КонецОбласти