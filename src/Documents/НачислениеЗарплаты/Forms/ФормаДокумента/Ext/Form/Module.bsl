// ОБЩИЕ ПРОЦЕДУРЫ

&НаСервере
// Процедура - обработчик команды формы "Рассчитать".
//
Процедура РассчитатьНаСервере()
	
	Документы.НачислениеЗарплаты.РассчитатьЗарплатуПоДокументу(Объект);
	
КонецПроцедуры

&НаСервере
// Процедура - обработчик команды формы "Рассчитать".
//
Процедура РассчитатьПоНачислениюНаСервере(ИдентификаторСтрокиТЧ)
	
	Если ТипЗнч(ИдентификаторСтрокиТЧ) = Тип("Число") Тогда
		СтрокаТЧ = Объект.РасчетЗарплаты.НайтиПоИдентификатору(ИдентификаторСтрокиТЧ);
	Иначе
		СтрокаТЧ = ИдентификаторСтрокиТЧ;
	КонецЕсли; 
	
	ЭлементыДляУдаления = Объект.Затраты.НайтиСтроки(Новый Структура("ВидНачисления", СтрокаТЧ.НачислениеУдержание));
	Для Каждого УдаляемыйЭлемент Из ЭлементыДляУдаления Цикл
		Объект.Затраты.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	ТаблицаРасшифровкиНачислений = Документы.НачислениеЗарплаты.РассчитатьЗарплатуПоНачислению(СтрокаТЧ.НачислениеУдержание, СтрокаТЧ.ПериодС, СтрокаТЧ.ПериодПо, ?(СтрокаТЧ.ВычисляетсяВручную, СтрокаТЧ, Неопределено));
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаРасшифровкиНачислений, Объект.Затраты);
	Объект.Затраты.Сортировать("Сотрудник, Дата, ВидНачисления");
	
	ИмяВремени = ?(СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф И СтрокаТЧ.НачислениеУдержание.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧас
			ИЛИ СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф И СтрокаТЧ.НачислениеУдержание.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования
			ИЛИ СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Оклад И СтрокаТЧ.НачислениеУдержание.ЗависимостьОтВыработки = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗависитОтВыработки И СтрокаТЧ.НачислениеУдержание.ТипПериодаНачисления = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоЧасам, "Часов", "Дней");
	// Если СтрокаТЧ.ВычисляетсяВручную Тогда
	//	СтрокаТЧ.Сумма = ТаблицаРасшифровкиНачислений.Итог("Сумма");
	// Иначе
		СтрокаТЧ.ЧасовПлан = 0; СтрокаТЧ.ДнейПлан = 0; СтрокаТЧ.ЧасовФакт = 0; СтрокаТЧ.ДнейФакт = 0;		
		СтрокаТЧ[ИмяВремени + "План"] = ?(ТаблицаРасшифровкиНачислений.Количество() > 0, ТаблицаРасшифровкиНачислений[0].План, 0);
		СтрокаТЧ[ИмяВремени + "Факт"] = ТаблицаРасшифровкиНачислений.Итог("Факт");
		СтрокаТЧ.База = ТаблицаРасшифровкиНачислений.Итог("База");
		СтрокаТЧ.Размер = ?(ТаблицаРасшифровкиНачислений.Количество() > 0, ТаблицаРасшифровкиНачислений[0].Размер, СтрокаТЧ.НачислениеУдержание.Размер);
		СтрокаТЧ.Сумма = ТаблицаРасшифровкиНачислений.Итог("Сумма");
	// КонецЕсли;
	
	Объект.СуммаДокумента = Объект.РасчетЗарплаты.Итог("Сумма") + Объект.ПрочиеНачисленияИУдержания.Итог("Сумма");	
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьТаблицуРасчетаДаннымиНачисления()
	
	Для Каждого СтрокаТЧ Из Объект.РасчетЗарплаты Цикл
		СтрокаТЧ.НУ_НачислениеУдержание 	= СтрокаТЧ.НачислениеУдержание.НачислениеУдержание;
		СтрокаТЧ.НУ_ТипНачисленияУдержания 	= СтрокаТЧ.НачислениеУдержание.ТипНачисленияУдержания;
		СтрокаТЧ.НУ_ЗависимостьОтВыработки 	= СтрокаТЧ.НачислениеУдержание.ЗависимостьОтВыработки;
		СтрокаТЧ.НУ_ТипПериодаНачисления 	= СтрокаТЧ.НачислениеУдержание.ТипПериодаНачисления;
		СтрокаТЧ.НУ_ТипТарифа 				= СтрокаТЧ.НачислениеУдержание.ТипТарифа;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ДополнитьТаблицуРасчетаДаннымиНачисления();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАвансы(Команда)
	
	ЗаполнитьАвансыНаСервере();	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАвансыНаСервере()
	
	// Заполнить таблицу "Авансы"
	МассивСотрудников = Новый Массив;
	Для Каждого СтрокаТЧ ИЗ Объект.РасчетЗарплаты Цикл
		МассивСотрудников.Добавить(СтрокаТЧ.Сотрудник);
	КонецЦикла;
	Для Каждого СтрокаТЧ ИЗ Объект.ПрочиеНачисленияИУдержания Цикл
		МассивСотрудников.Добавить(СтрокаТЧ.Сотрудник);
	КонецЦикла;
	
	Документы.НачислениеЗарплаты.ЗаполнитьТаблицуАвансов(Объект, Объект.СтруктурнаяЕдиница, НачалоМесяца(Объект.ДатаНачалаПериода), МассивСотрудников, Объект.Ссылка)
	
