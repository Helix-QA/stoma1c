// Функция, возвращает код стилизации колонок канбана.
//
Функция СформироватьКодСтилизацииКолонокКанбана(ДанныеСделок)
	
	КодСтилизацииКолонокКанбана = "";
	
	МассивТекстовКоманд = Новый Массив;
	
	ДанныеСделок.Сбросить();
	
	Пока ДанныеСделок.Следующий() Цикл
		
		Если ДанныеСделок.ИмяПредопределенногоЭтапа = "Успех" Тогда
			ЦветЭтапа		 = Новый Цвет(0, 185, 97);
			ЦветТекстаЭтапа	 = Новый Цвет(255, 255, 255);
			
		ИначеЕсли ДанныеСделок.ИмяПредопределенногоЭтапа = "Отказ" Тогда
			ЦветЭтапа		 = Новый Цвет(255, 50, 50);
			ЦветТекстаЭтапа	 = Новый Цвет(255, 255, 255);
			
		Иначе
			ЦветЭтапа		 = ?(ЗначениеЗаполнено(ДанныеСделок.ЦветЭтапа), ЗначениеИзСтрокиВнутр(ДанныеСделок.ЦветЭтапа), Новый Цвет(242, 242, 242));
			ЦветТекстаЭтапа	 = ОбщегоНазначенияСтоматология.ПолучитьЦветТекстаПоЦветуФона(ЦветЭтапа, Истина);
			
		КонецЕсли;
		
		ЦветЭтапаHTML	 = ПолучитьЦветДляHTML(ЦветЭтапа);
		ЦветТекстаHTML	 = ПолучитьЦветДляHTML(ЦветТекстаЭтапа);
		
		СтильЦветФонаЭтапа		 = "background:" + ЦветЭтапаHTML + ";";
		СтильЦветТекстаЭтапа	 = "color:" + ЦветТекстаHTML + ";";
		СтильЦветЗаливки		 = "fill:" + ЦветЭтапаHTML + ";";
		
		СтильКолонкиКанбана = СтильЦветФонаЭтапа + " " + СтильЦветТекстаЭтапа + " " + СтильЦветЗаливки;
		
		ТекстКоманды =
		"document.querySelector('.kanban-board[data-id=""" + XMLСтрока(ДанныеСделок.ЭтапСделки) + """] .kanban-board-header').style = '" + СтильКолонкиКанбана + "';";
		МассивТекстовКоманд.Добавить(ТекстКоманды);
		
	КонецЦикла;
	
	КодСтилизацииКолонокКанбана = СтрСоединить(МассивТекстовКоманд, Символы.ПС);
	
	Возврат КодСтилизацииКолонокКанбана;
	
КонецФункции

