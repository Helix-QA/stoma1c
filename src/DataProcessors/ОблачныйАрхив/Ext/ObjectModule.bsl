		Возврат Истина;
	Иначе
		Возврат "Версия агента ""1С Облачный Архив"", которую Вы сейчас используете отличается от актуальной: " + РекомендуемаяВерсия + ". Ваша версия агента: " + ВерсияАгента + "." + Символы.ПС +
				"Рекомендуем обновить агента." + Символы.ПС + 
				"Инструкцию по обновлению/установке можно получить по ссылке: http://backup.1C.ru/info/Instructions1CCloudBackup.docx"; 
	КонецЕсли;

КонецФункции

// Функция получает по HTTP данные
Функция		ПолучитьДанныеПоHTTP(АдресРесурса,ПутьЗапроса)  Экспорт
	
	Ошибка = Ложь; НаВозврат = "";
	
	HTTPСоединение = Новый HTTPСоединение(АдресРесурса);
	// Не работает на 8.2.15 и ранних версиях, поэтому запускается так, чтобы при запуски и компиляции не выдавать ошибку.
	Попытка
		КодПолучения = "
						|HTTPЗапрос = Новый HTTPЗапрос(ПутьЗапроса);
						|Результат = HTTPСоединение.Получить(HTTPЗапрос);
						|НаВозврат = Результат.ПолучитьТелоКакСтроку();
						|";
		Выполнить(КодПолучения);
	Исключение
		Ошибка = Истина;
	КонецПопытки;
	
	Если НаВозврат = "" И Ошибка Тогда
		
		Попытка
			ВремФайл = КаталогВременныхФайлов() + "/ОтветОтСайта.txt";
			HTTPСоединение.Получить(ПутьЗапроса,ВремФайл);
			ЧтениеФайла = Новый ЧтениеТекста(ВремФайл);
			Стр = ЧтениеФайла.ПрочитатьСтроку(); Результат = "";
			Пока Стр <> Неопределено Цикл
				Результат = Результат + Символы.ПС + Стр;
			    Стр = ЧтениеФайла.ПрочитатьСтроку();
			КонецЦикла;	
		
		    НаВозврат = Результат;
			// Удаляем файл
			
		Исключение
			Ошибка = Истина;
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат ?(Ошибка ИЛИ СокрЛП(НаВозврат) = "",Ложь,НаВозврат); 		
	
КонецФункции

#КонецОбласти

