// Процедура, устанавливает видимость меток.
//
Процедура УстановитьВидимостьМеток()

	Если ЗначениеЗаполнено(Объект.ПрограммаСтрахования) Тогда
		Элементы.ГруппаПрограммаСтрахования.Видимость = Истина; 
	КонецЕсли;
	
	ДанныеПрограммыСтрахования = ДанныеПрограммыСтрахования(Объект.ПрограммаСтрахования); 
	
	Элементы.ДекорацияПрограммаСтрахования.Заголовок 	= ДанныеПрограммыСтрахования.Текст;
	Элементы.ДекорацияПрограммаСтрахования.ЦветТекста 	= ДанныеПрограммыСтрахования.ЦветТекста;
	Элементы.ГруппаПрограммаСтрахования.ЦветФона 		= ДанныеПрограммыСтрахования.ЦветФона;
	
КонецПроцедуры  

