		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	УправленческийОстаткиИОбороты.СтруктурнаяЕдиница,
	УправленческийОстаткиИОбороты.Субконто1 КАК Номенклатура,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
				ТОГДА УправленческийОстаткиИОбороты.СуммаНачальныйОстатокДт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИмуществоНачОст,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
				ТОГДА УправленческийОстаткиИОбороты.СуммаКонечныйОстатокДт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИмуществоКонОст,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ИмуществоИзнос)
				ТОГДА УправленческийОстаткиИОбороты.СуммаНачальныйОстатокКт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИзносНачОст,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ИмуществоИзнос)
				ТОГДА УправленческийОстаткиИОбороты.СуммаКонечныйОстатокКт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИзносКонОст,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
				ТОГДА УправленческийОстаткиИОбороты.СуммаОборотДт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИмуществоУвСт,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
				ТОГДА УправленческийОстаткиИОбороты.СуммаОборотКт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИмуществоУмСт,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ИмуществоИзнос)
				ТОГДА УправленческийОстаткиИОбороты.СуммаОборотКт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИзносНач,
	СУММА(ВЫБОР
			КОГДА УправленческийОстаткиИОбороты.Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ИмуществоИзнос)
				ТОГДА УправленческийОстаткиИОбороты.СуммаОборотДт
			ИНАЧЕ 0
		КОНЕЦ) КАК ИзносСпис
ИЗ
	РегистрБухгалтерии.Управленческий.ОстаткиИОбороты(
			,
			,
			Период,
			,
			Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Имущество)
				ИЛИ Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ИмуществоИзнос),
			,
			) КАК УправленческийОстаткиИОбороты

СГРУППИРОВАТЬ ПО
	УправленческийОстаткиИОбороты.СтруктурнаяЕдиница,
	УправленческийОстаткиИОбороты.Субконто1</query>
