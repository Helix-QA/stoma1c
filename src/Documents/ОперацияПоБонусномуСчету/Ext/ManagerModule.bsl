#Область Проведение

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ОперацияПоБонусномуСчету.Дата КАК Период,
	|	ОперацияПоБонусномуСчету.БонусныйСчет КАК БонусныйСчет,
	|	ОперацияПоБонусномуСчету.Ссылка КАК ДокументНачисления,
	|	ОперацияПоБонусномуСчету.Сумма КАК Сумма,
	|	ОперацияПоБонусномуСчету.Содержание КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаНачислениеБонусов
	|ИЗ
	|	Документ.ОперацияПоБонусномуСчету КАК ОперацияПоБонусномуСчету
	|ГДЕ
	|	ОперацияПоБонусномуСчету.Ссылка = &Ссылка
	|	И ОперацияПоБонусномуСчету.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.НачислениеБонусныйСчет)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ОперацияПоБонусномуСчету.Дата КАК Период,
	|	ОперацияПоБонусномуСчету.БонусныйСчет КАК БонусныйСчет,
	|	ОперацияПоБонусномуСчету.Ссылка КАК ДокументНачисления,
	|	ОперацияПоБонусномуСчету.Сумма КАК Сумма,
	|	ОперацияПоБонусномуСчету.Содержание КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаСписаниеБонусов
	|ИЗ
	|	Документ.ОперацияПоБонусномуСчету КАК ОперацияПоБонусномуСчету
	|ГДЕ
	|	ОперацияПоБонусномуСчету.Ссылка = &Ссылка
	|	И ОперацияПоБонусномуСчету.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.СписаниеБонусныйСчет)";
				   
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	СформироватьТаблицаБонусныеСчета(ДокументСсылка, СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

