// Функция - возвращает цвет текста для указанного цвета фона.
//
// Параметры:
//  ЦветФона - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветТекстаПоЦветуФона(ЦветФона, ВернутьСтруктуру = Ложь) Экспорт
	
	RGBЦвет = ПолучитьRGBЦвет(ЦветФона,,, ВернутьСтруктуру);
		
	Если ЗначениеЗаполнено(RGBЦвет) Тогда
		
		// Если цвет белый.
		Если RGBЦвет.Красный = 255
			И RGBЦвет.Зеленый = 255
			И RGBЦвет.Синий = 255 Тогда
			
			ЦветТекста = Новый Цвет(128, 128, 128);
			
		ИначеЕсли (1 - (0.299 * RGBЦвет.Красный + 0.587 * RGBЦвет.Зеленый + 0.114 * RGBЦвет.Синий) / 255) > 0.5 Тогда
				
			ЦветТекста = Новый Цвет(250, 250, 250);
		Иначе
			ЦветТекста = Новый Цвет(64, 64, 64);
		КонецЕсли;
		
	Иначе
		ЦветТекста = Новый Цвет(64, 64, 64);
	КонецЕсли;
	
	Возврат ЦветТекста;
	
КонецФункции	

// Функция возвращает конвертированное значеие кода карты
//
Функция КонвертацияСистемСчисления(Код, ПервоеЧисло) Экспорт
	
	ЧислоHex = "";
	Если Код < 16 Тогда
		ЧислоHex = ЧислоHex + ОпределениеЦифрыHEXпоDEC(Код);
	Иначе	
		Пока Код > 15 Цикл 
			Остаток = Цел(Код/16);
			Код = Код - (Остаток * 16);
			Если (Код < 16) и (Остаток < 16) Тогда 
				КодКопия = код;
				ЧислоHex = ЧислоHex + ОпределениеЦифрыHEXпоDEC(КодКопия);
			КонецЕсли;
			Если Остаток < 16 Тогда 
				ОстатокКопия = Остаток;
				ЧислоHex = ЧислоHex + ОпределениеЦифрыHEXпоDEC(ОстатокКопия);
			Иначе 
				ЧислоHex = ЧислоHex + ОпределениеЦифрыHEXпоDEC(Код);
				Код = Остаток;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
	ДлинаЧисла = СтрДлина(ЧислоHex);
	КодHex = "";
	Пока ДлинаЧисла > 0 Цикл			   
		КодHex = КодHex + Сред(ЧислоHex,ДлинаЧисла,1);
		ДлинаЧисла = ДлинаЧисла - 1; 		
	КонецЦикла;
	
	а = ?(ПервоеЧисло, 2, 4);
	
	Пока СтрДлина(КодHex) < а Цикл
		КодHex = "0" + КодHex;
	КонецЦикла;
		
	Возврат КодHex;
	
КонецФункции 

// Функция возвращает число в шестнадцатеричной системе счисления
//
Функция ОпределениеЦифрыHEXпоDEC(Знак)
	
	Если Знак < 10 Тогда
	ИначеЕсли Знак = 10 Тогда 
		Знак = "A";		
	ИначеЕсли Знак = 11 Тогда
		Знак = "B";		
	ИначеЕсли  Знак = 12 Тогда
		Знак = "C";		
	ИначеЕсли Знак = 13 Тогда
		Знак = "D";		
	ИначеЕсли Знак = 14 Тогда
		Знак = "E";		
	ИначеЕсли Знак = 15 Тогда 
		Знак = "F";					
	КонецЕсли;
	
	Возврат Строка(Знак);
	
КонецФункции

