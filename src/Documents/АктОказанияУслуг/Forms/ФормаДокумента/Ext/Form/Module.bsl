 
 #Область ОбработчикиСобытийФормы

&НаКлиенте
// Обработчик кнопки заполнения таблицы только не оплачеными приемами
Процедура ЗаполнитьПоДокументам(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ПоказатьПредупреждение(, "Укажите контрагента!");
		Возврат;	
	КонецЕсли;
	
	ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьПоДокументамЗавершение", ЭтотОбъект), "Таблица будет перезаполнена. Продолжить?",РежимДиалогаВопрос.ДаНет);
	 
КонецПроцедуры

&НаКлиенте   
// Процедура - Заполнить по документам завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЗаполнитьПоДокументамЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если Объект.ОказанныеУслуги.Количество() = 0 ИЛИ РезультатВопроса = КодВозвратаДиалога.Да Тогда		
		ЗаполнитьТаблицуОказанныеУслуги(Объект.Контрагент,Истина);
		ПриемыПриИзменении(Неопределено);		 
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик кнопки заполнения таблицы всеми приемами
Процедура ЗаполнитьВсемиПриемами(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ПоказатьПредупреждение(, "Укажите контрагента!");
		Возврат;	
	КонецЕсли;
	
	ПоказатьВопрос(Новый ОписаниеОповещения("ВопросОПерезаполненииТаблицыЗавершение", ЭтотОбъект), "Таблица будет перезаполнена. Продолжить?",РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура ВопросОПерезаполненииТаблицыЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если Объект.ОказанныеУслуги.Количество() = 0 ИЛИ РезультатВопроса = КодВозвратаДиалога.Да Тогда		
		ЗаполнитьТаблицуОказанныеУслуги(Объект.Контрагент,Ложь);
		ПриемыПриИзменении(Неопределено);		 
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
