&НаСервереБезКонтекста
// Функция, возвращает массив структур, содержащий данные результата запроса.
//
Функция РезультатЗапросаВМассивСтруктур(РезультатЗапроса)
	
	Результат = Новый Массив;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИменаСвойств = Новый Массив;
	
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ИменаСвойств.Добавить(Колонка.Имя);
	КонецЦикла;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СтрокаДанных = Новый Структура(СтрСоединить(ИменаСвойств, ","));
		ЗаполнитьЗначенияСвойств(СтрокаДанных, Выборка);
		
		Результат.Добавить(СтрокаДанных);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает номер без лидирующих нулей.
//
Функция ПолучитьНомерНаПечать(Знач Номер)

	Пока Лев(Номер, 1)= "0" Цикл
		Номер = Сред(Номер, 2);
	КонецЦикла;
	
	Возврат Номер;

КонецФункции

&НаСервере
// Функция, возвращает данные.
//
Функция ПолучитьПредставлениеБлоков()
	
	ДанныеЗаявок = ПолучитьДанныеЗаявок();
	
	БлокиКанбана = Новый Массив;
	
	Пока ДанныеЗаявок.Следующий() Цикл
		
		Выборка = ДанныеЗаявок.Выбрать();
		
		БлокиЗаявок = Новый Массив;
		
		КоличествоБлоков = 0;
		
		Пока Выборка.Следующий() Цикл
			
			Если Не ЗначениеЗаполнено(Выборка.Ссылка) Тогда
				Продолжить;
			КонецЕсли;
			
			Если КоличествоБлоков = ЭтотОбъект.МаксимальноеКоличествоЗаявокВКолонке Тогда
				Прервать;
			КонецЕсли;
			
			БлокиЗаявок.Добавить(ПолучитьБлокЗаявкиДляФормированияКанбана(Выборка));
			КоличествоБлоков = КоличествоБлоков + 1;
			
		КонецЦикла;
		
		Количество = ?(КоличествоБлоков = 0, 0, Выборка.Количество());
		БлокиКанбана.Добавить(ПолучитьБлокКолонки(ДанныеЗаявок.Статус, БлокиЗаявок, Количество));
		
	КонецЦикла;
	
	ПредставлениеБлоковКанбана = СтрСоединить(БлокиКанбана, "," + Символы.ПС);
	
	Возврат ПредставлениеБлоковКанбана;
	
КонецФункции

