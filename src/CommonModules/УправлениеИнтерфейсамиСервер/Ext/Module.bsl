	МассивЦветов.Добавить(Новый Цвет(243, 190, 255));
	МассивЦветов.Добавить(Новый Цвет(204, 200, 249));
	
	Возврат МассивЦветов;

КонецФункции
	
#КонецОбласти

#Область ФормированиеИсторииВзаимодействияСКлиентом

// Функция, формирует и возвращает историю взаимодействия с контрагентом.
//
Функция СформироватьИсториюВзаимодействий(
	Форма, 
	ПараметрыДанных = Неопределено, 
	РежимПодробно   = Ложь,
	ВыводитьВсе     = Ложь) Экспорт 
			
	БлокЗапланированоВыведен = Ложь;
	БлокЗакрепленоВыведен	 = Ложь;
	БлокПросроченноВыведен	 = Ложь;
	ТекущаяДата              = Неопределено;
	ТекстHTML                = "";
	МассивСтрок              = Новый Массив;

	ТаблицаИсторииВзаимодействий = Форма.ИсторияВзаимодействий;
	
	// Добавление блока оповещения наличия задач у клиента.	
	Если ЗначениеЗаполнено(ПараметрыДанных) 
		И ПараметрыДанных.Свойство("СтатусКлиента") 
		И ПараметрыДанных.СтатусКлиента = Перечисления.СтатусыКонтрагентов.Потенциальный Тогда 
		
		НаличиеЗапланированныхЗадач = ТаблицаИсторииВзаимодействий.НайтиСтроки(Новый Структура("ТипСобытия, ТипВзаимодействия", "Задача", "Запланировано")).Количество() > 0; 
			
		БлокНаличияЗадачКлиента = ВывестиБлокНаличияЗадачКлиента(НаличиеЗапланированныхЗадач);		
		МассивСтрок.Добавить(БлокНаличияЗадачКлиента);
	КонецЕсли;
	
	КоличествоСобытий = ТаблицаИсторииВзаимодействий.Количество();
	ИндексКонец       = ?(ВыводитьВсе ИЛИ КоличествоСобытий - 1 < 20, КоличествоСобытий - 1, 20);
	
	ТегДиалогаОткрыт 				= Ложь; 
	ДанныеДиалога					= "";
	КоличествоСообщенийБезРазрыва 	= 1;
	
	Для Индекс = 0 По ИндексКонец Цикл
		
		СтрокаТЗ = ТаблицаИсторииВзаимодействий[Индекс];		
		
		ТипСобытия           	= СтрокаТЗ.ТипСобытия; 
		ТипВзаимодействия    	= СтрокаТЗ.ТипВзаимодействия;
		Взаимодействие			= СтрокаТЗ.Взаимодействие;
		ДатаНачалоДня        	= НачалоДня(СтрокаТЗ.Дата);
		ЭтоБлокЗапланировано 	= (ТипВзаимодействия = "Запланировано");
		ЭтоБлокЗакреплено		= (ТипВзаимодействия = "Закреплено");
		ЭтоБлокПросроченно      = (ТипВзаимодействия = "Просроченно");
		ЦветФона             	= ?(ЭтоБлокЗапланировано, "rgb(245, 245, 220)", "rgb(242, 242, 242)");
		
		Если ЭтоБлокЗакреплено И Не БлокЗакрепленоВыведен Тогда
			БлокИнформация = ВывестиДату(ТипВзаимодействия, СтрокаТЗ);
			МассивСтрок.Добавить(БлокИнформация);
			БлокЗакрепленоВыведен = Истина;
		КонецЕсли;
		
		Если ЭтоБлокЗапланировано И Не БлокЗапланированоВыведен Тогда
			БлокИнформация = ВывестиДату(ТипВзаимодействия, СтрокаТЗ);
			МассивСтрок.Добавить(БлокИнформация);
			БлокЗапланированоВыведен = Истина;
		КонецЕсли;
		
		Если ЭтоБлокПросроченно И Не БлокПросроченноВыведен Тогда
			БлокИнформация = ВывестиДату(ТипВзаимодействия, СтрокаТЗ);
			МассивСтрок.Добавить(БлокИнформация);
			БлокПросроченноВыведен = Истина;
		КонецЕсли; 
		
		Если Не СтрНайти(ТипСобытия, "Диалог") 
			И ТегДиалогаОткрыт  Тогда
			
			МассивСтрок.Добавить(ТекстHTML);
			МассивСтрок.Добавить(ДобавитьЗакрытиеДиалога(ДанныеДиалога));
			
			ТегДиалогаОткрыт = Ложь;
			КоличествоСообщенийБезРазрыва = 1;
			
		КонецЕсли;
		
		Если ЭтоБлокЗапланировано = Ложь И ЭтоБлокЗакреплено = Ложь И ЭтоБлокПросроченно = Ложь И (ТекущаяДата = Неопределено ИЛИ ТекущаяДата <> ДатаНачалоДня) Тогда  
			
			БлокДата = ВывестиДату(ДатаНачалоДня, СтрокаТЗ);
			МассивСтрок.Добавить(БлокДата);

			ТекущаяДата = ДатаНачалоДня;
			
		КонецЕсли;
		
		Если ТипСобытия = "ДатаРегистрацииКлиента" Тогда
			БлокРегистрацияКлиента = СформироватьБлокРегистрацияКлиента(Взаимодействие, ПараметрыДанных, СтрокаТЗ);
			МассивСтрок.Добавить(БлокРегистрацияКлиента);
		ИначеЕсли ТипСобытия = "ДатаРегистрацииЗаявки" Тогда			
			БлокРегистрацияЗаявки = СформироватьБлокРегистрацияЗаявки(Взаимодействие, СтрокаТЗ, ПараметрыДанных);
			МассивСтрок.Добавить(БлокРегистрацияЗаявки);
		ИначеЕсли ТипСобытия = "SMS" Тогда
			МассивСтрок.Добавить(СформироватьБлокSMS(СтрокаТЗ));
		ИначеЕсли ТипСобытия = "Письмо" Тогда
			МассивСтрок.Добавить(СформироватьБлокЭлектронноеПисьмо(СтрокаТЗ));
		ИначеЕсли ТипСобытия = "Заметка" Тогда
			МассивСтрок.Добавить(СформироватьБлокЗаметка(СтрокаТЗ));
		ИначеЕсли ТипСобытия = "Задача" Тогда
			МассивСтрок.Добавить(СформироватьБлокЗадача(СтрокаТЗ));
		ИначеЕсли ТипСобытия = "СтатусСделки" Тогда
			МассивСтрок.Добавить(СформироватьБлокСтатусСделки(СтрокаТЗ));
		ИначеЕсли СтрНайти(ТипСобытия, "Звонок") Тогда	
			МассивСтрок.Добавить(СформироватьБлокЗвонок(СтрокаТЗ, ТипСобытия));	
		ИначеЕсли ТипСобытия = "ДеньРожденияКлиента" 
			И ЗначениеЗаполнено(ПараметрыДанных) 
			И ПараметрыДанных.Свойство("ДатаРожденияКлиента") Тогда 	
			
			МассивСтрок.Добавить(СформироватьБлокДеньРожденияКлиента(ПараметрыДанных.ДатаРожденияКлиента));  
			
		ИначеЕсли ТипСобытия = "Событие" 
			Или ТипСобытия = "Прием"
			Или ТипСобытия = "НарядЗаказ"
			Или ТипСобытия = "ПланЛечения"
			Или ТипСобытия = "Обращение" Тогда
			
			МассивСтрок.Добавить(СформироватьБлокЗапись(СтрокаТЗ, ЭтоБлокЗапланировано));  
        ИначеЕсли ТипСобытия = "Профосмотр" Тогда		
			МассивСтрок.Добавить(СформироватьБлокПрофосмотр(СтрокаТЗ, ЭтоБлокЗапланировано)); 
		//ИначеЕсли ТипСобытия = "Обращение" Тогда		
		//	МассивСтрок.Добавить(СформироватьБлокОбращение(СтрокаТЗ));	
		ИначеЕсли СтрНайти(ТипСобытия, "Диалог") Тогда	
			
			КоличествоСообщенийБезРазрыва = КоличествоСообщенийБезРазрыва + 1;
			
			Если ТегДиалогаОткрыт = Ложь Тогда

				ТегДиалогаОткрыт 	= Истина;
				ДанныеДиалога 		= Новый Структура("ИдКлиента, ВнешняяСистема", СтрокаТЗ.Заметка, СтрокаТЗ.Взаимодействие);
				
				Если СтрокаТЗ.ТипВзаимодействия = "История" 
					И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
					СтильHtmlГраницаБлока 	= "border-color:#0cac09;";		
