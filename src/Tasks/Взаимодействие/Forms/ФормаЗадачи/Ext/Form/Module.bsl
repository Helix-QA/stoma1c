&НаСервере
// Процедура - Обновить видимость элементов.
//
Процедура ОбновитьВидимостьЭлементов(ОбновитьДоступность = Ложь)
	
	// Значения по умолчанию.
	Элементы.ГруппаПредметПростойЗадачи.Видимость = Объект.Ссылка.Пустая() ИЛИ НЕ ЗначениеЗаполнено(Объект.ЗадачаПредмет);
	
	Элементы.КнопкаПозвонить.Видимость = ЗначениеЗаполнено(ЭтотОбъект.Клиент) И IPТелефония.ПроверитьВозможностьЗвонкаНаДанномПК()
                                         И ЗначениеЗаполнено(УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ЭтотОбъект.Клиент, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента));
	Элементы.Контрагент.Видимость 		= НЕ ЗначениеЗаполнено(ЭтотОбъект.Клиент) И НЕ ЗначениеЗаполнено(Объект.Ссылка);									 
	Элементы.КнопкаКонтрагент.Видимость = ЗначениеЗаполнено(Объект.Ссылка) ИЛИ ЗначениеЗаполнено(ЭтотОбъект.Клиент);									 									
	
	// Если задача выполнена.
	Если ЭтотОбъект.ВзаимодействиеВыполнено Тогда
		
		Элементы.ГруппаПереключениеСостояния.ЦветФона   = Новый Цвет(25, 116, 206);
		Элементы.КнопкаПереключениеСостояния.ЦветТекста	= Новый Цвет(255, 255, 255);		
		Элементы.КнопкаПереключениеСостояния.Заголовок	= Нстр("ru = 'Выполнена'; en = 'Completed'");
		
		Если ЗначениеЗаполнено(Объект.ИсполнительФактический) Тогда
			Элементы.ИсполнительФактический.Заголовок = ПолучитьПредставлениеФИОСотрудника(Объект.ИсполнительФактический) + " (" + Объект.ДатаИсполнения +")";
			Элементы.ИсполнительФактический.Видимость = Истина;
		КонецЕсли;
				
	Иначе
		
		Элементы.ГруппаПереключениеСостояния.ЦветФона   = Новый Цвет(242, 242, 242);
		Элементы.КнопкаПереключениеСостояния.ЦветТекста	= Новый Цвет(77, 77, 77);		
		Элементы.КнопкаПереключениеСостояния.Заголовок	= Нстр("ru = 'Выполнить'; en = 'Run'");		
		
	КонецЕсли;
	
	// Для пустого ЗадачиПредмет.
	Элементы.ГруппаПредмет.Видимость    = ЗначениеЗаполнено(Объект.ЗадачаПредмет);
	// Элементы.ГруппаКонтрагент.Видимость = ЗначениеЗаполнено(Объект.Контрагент) И Не ЗначениеЗаполнено(Объект.Сделка);
	
	СформироватьКонтаргентаСтрокой(Элементы.КнопкаКонтрагент.Заголовок, Объект.Контрагент, ЭтотОбъект.СтатусКлиента);
	СформироватьПредметСтрокой(Элементы.КнопкаПредмет.Заголовок, Объект.ЗадачаПредмет);
	
	// Срок период.
	ЭтотОбъект.РежимПериода = ЗначениеЗаполнено(Объект.ЗадачаНазначеннаяДатаНачало);
	ПереключательСрокПериод();
	
	УстановитьЗаголовокФормы();
	
	Если ОбновитьДоступность Тогда
		УстановитьДоступностьЭлементовПоПравам();	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает доступность элементов формы.
//
Процедура УстановитьДоступностьЭлементовПоПравам()
	        // ПараметрыСеанса.ТекущийПользователь ПараметрыСеанса.ТекущийСотрудник
	ИсполнительЗадачи = ?(ЗначениеЗаполнено(Объект.ИсполнительФактический) И ЭтотОбъект.ВзаимодействиеВыполнено, Объект.ИсполнительФактический, Объект.Исполнитель);
	Если ТипЗнч(ИсполнительЗадачи) = Тип("СправочникСсылка.Сотрудники") Тогда 
		ЭтаЗадачаТекущегоПользователя = (ИсполнительЗадачи = ПараметрыСеанса.ТекущийСотрудник);
	Иначе 
		ЭтаЗадачаТекущегоПользователя = Ложь;
	КонецЕсли;
	
	Если ЭтотОбъект.ВзаимодействиеВыполнено
		И НЕ (РольДоступна(Метаданные.Роли.ПолныеПрава) 
		ИЛИ РольДоступна(Метаданные.Роли.ДобавлениеИзменениеКлиентов)) Тогда
		
		ОграничитьДоступЭлементов();
			
	КонецЕсли;
	
	Если ПравоДоступа("Редактирование", Метаданные.Задачи.Взаимодействие) = Ложь Тогда
		Элементы.КнопкаЗаписатьИЗакрыть.Доступность = Ложь;
	КонецЕсли;
	
	Если РольДоступна(Метаданные.Роли.ПолныеПрава) Тогда
		
		Возврат; // Без органичений.
		
	// ИначеЕсли РольДоступна(Метаданные.Роли.ИзменениеВыполнениеЗадачДругихПользователей) Тогда
	//	
	//	// Давать возможно заполнять описание у чужих задач, если оно пустое.
	//	Если НЕ ЭтаЗадачаТекущегоПользователя
	//		И ЗначениеЗаполнено(Объект.ЗадачаОписание) Тогда
	//		
	//		Элементы.ГруппаСтрокаОписаниеЗадачи.ТолькоПросмотр 	= Истина;
	//		
	//	КонецЕсли;
	//	
	//	// Изменение всех полей, кроме темы и предмета у чужих не выполненных задач.
	//	Если НЕ ЭтаЗадачаТекущегоПользователя
	//		И НЕ ЭтотОбъект.ВзаимодействиеВыполнено Тогда
	//		
	//		Элементы.ГруппаСтрокаТемаЗадачи.ТолькоПросмотр 		= Истина;
	//		Элементы.ГруппаПредмет.ТолькоПросмотр 				= Истина;
	//		
	//	КонецЕсли;
	//	
	//	Если ЭтотОбъект.ВзаимодействиеВыполнено Тогда
	//		Элементы.КнопкаПереключениеСостояния.Доступность 	= Ложь; // Не менять состояние, если уже выполнена задача.
	//	КонецЕсли;
		
	ИначеЕсли РольДоступна(Метаданные.Роли.БазовыеПрава) Тогда
				
		// Ограничение РЛС и видимое ограничение элементов на форме.
		Если НЕ ЭтаЗадачаТекущегоПользователя Тогда
			
			ОграничитьДоступЭлементов();
			Элементы.ВидВзаимодействияСправочникВыбор.Доступность = Ложь;
			Элементы.КнопкаЗаписатьИЗакрыть.Доступность			  = Ложь;
			Элементы.ГруппаСтрокаОписаниеЗадачи.ТолькоПросмотр 	  = Истина;
			
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, ОграничитьДоступЭлементов.
//
Процедура ОграничитьДоступЭлементов()
	
	// Ограничение элементов.
	Элементы.ГруппаСтрокаТемаЗадачи.ТолькоПросмотр 			= Истина;
	Элементы.ГруппаПериоды.ТолькоПросмотр 					= Истина;
	Элементы.ГруппаПредмет.ТолькоПросмотр 					= Истина;
	
	// Органичение кнопок.
	Элементы.КнопкаПереключениеСостояния.Доступность		= Ложь;
	Элементы.ВзаимодействиеРежимНапоминания.Доступность 	= Ложь;
	Элементы.ВзаимодействиеИсполнитель.Доступность			= Ложь;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает заголовок формы.
//
Процедура УстановитьЗаголовокФормы()
	
	ШаблонЗаголовка = "{Тема} ({ВидВзаимодействия}) {Состояние}";
	ШаблонЗаголовка = СтрЗаменить(ШаблонЗаголовка, "{Тема}"             , Объект.ЗадачаТема);
	ШаблонЗаголовка = СтрЗаменить(ШаблонЗаголовка, "{ВидВзаимодействия}", Строка(Объект.ВидВзаимодействия));
	
	Если Объект.Ссылка.Пустая() Тогда 
		ШаблонЗаголовка = СтрЗаменить(ШаблонЗаголовка, "{Состояние}", Нстр("ru = '(создание)'; en = '(creation)'"));
	Иначе
		ШаблонЗаголовка = СтрЗаменить(ШаблонЗаголовка, "{Состояние}", ?(Объект.Выполнена, Нстр("ru = '(выполнена)'; en = '(completed)'"), Нстр("ru = '(не выполнена)'; en = '(not completed)'")));
	КонецЕсли;	
	
	ЭтаФорма.Заголовок = ШаблонЗаголовка;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Записать сотрудника презентации на сервере
//
// Параметры:
//  КлиентСсылка				 - 	 - 
//  НазанчитьОсновногоМенеджера	 - 	 - 
//
Процедура ЗаписатьСотрудникаПрезентацииНаСервере(Знач КлиентСсылка, Знач НазанчитьОсновногоМенеджера = Ложь)
	
	КлиентОбъект = КлиентСсылка.ПолучитьОбъект();
	КлиентОбъект.СотрудникПрезентации = ПараметрыСеанса.ТекущийСотрудник;
	Если НазанчитьОсновногоМенеджера Тогда 
		КлиентОбъект.Менеджер = КлиентОбъект.СотрудникПрезентации;
	КонецЕсли;	
	Попытка
		КлиентОбъект.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Записать в журнал все параметры
//
Процедура ЗаписатьВЖурналВсеПараметры(Знач КонтрагентУказан)
	
	// Сформируем описание
	КомментарийОшибки = СтрШаблон(
	НСтр("ru='Нажатие на гиперссылку ""Дополнить информацию по клиенту"".
	|
	|Задача: %1
	|Клиент (ЗадачаПредмет) + его тип: %2
	|Статус клиента (на форме): %3
	|Статус клиента (текущий): %4
	|
	|Вид взаимодействия: %5
	|Взаимодействие состоялось:	%6
	|
	|Исполнитель: %7.';
	|en='Pressing on hyperlink ""Complement information on the the client"".
	|
	|Task: %1
	|Client Task + its type: %2
	|Status client on form: %3
	|Status client current: %4
	|Type of interactions: %5
	|
	|Interaction was held: %6
	|
	|Perpetrator: %7.'"),
	Строка(Объект.Ссылка),
	Строка(Объект.ЗадачаПредмет) + " (" + Строка(ТипЗнч(Объект.ЗадачаПредмет)) + ")",
	Строка(ЭтотОбъект.СтатусКлиента),
	Строка(ПолучитьСтатусКонтрагента(Объект.ЗадачаПредмет)),
	Строка(Объект.ВидВзаимодействия),
	?(Объект.ВзаимодействиеСостоялось, НСтр("ru = 'Да'; en = 'Yes'"), НСтр("ru = 'Нет'; en = 'No'")),
	Строка(Объект.Исполнитель));
	
	ЗаписатьВЖурналНаСервере(КомментарийОшибки, Объект.Ссылка, КонтрагентУказан);
	
КонецПроцедуры

