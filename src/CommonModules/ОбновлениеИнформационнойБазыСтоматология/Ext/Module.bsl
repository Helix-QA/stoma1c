	// Создаем значения по умолчанию справочника "ПричиныЗаписи"
	Справочники.ПричиныЗаписи.СоздатьЗначенияПоУмолчанию(); 
	
	// Создаем значения по умолчанию справочника "Специализации"
	Справочники.Специализации.СоздатьЗначенияПоУмолчанию(); 
	
	// Создаем значения по умолчанию справочника "Должности"
	Справочники.Должности.СоздатьЗначенияПоУмолчанию(); 
	
	// Заполнить виды контактной информации
	УстановитьСвойстваПредопределенныхВидовКонтактнойИнформации();
	
	// Заполняет справочник Степени родства
	ПрописатьОбратныеСтепениРодства();
	
	// Заполняем справочник классификатор услуг
