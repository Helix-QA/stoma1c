// Определяет по таблице скидок подарков количество подарков
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//  ТаблицаНеПрименяемыхПодарков - Таблица значений, служит для возврата не используемых подарков
//
Процедура ОпределитьКоличествоВыдачиКарт(ТаблицаСкидок, СтруктураПараметров)

	МассивСтрокТЗСкидокДляУдаления = Новый Массив;
	ТаблицаОбработанныхСкидокВыдачиКарт = ТаблицаСкидок.СкопироватьКолонки();	
	
	// Расчитываем кол-во и стоимость подарков
	Для каждого СтрокаТЧСкидки Из ТаблицаСкидок Цикл
		Если СтрокаТЧСкидки.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВыдачаКарты Тогда
			Если ТаблицаОбработанныхСкидокВыдачиКарт.НайтиСтроки(Новый Структура("СкидкаНаценка, ЗначениеСкидкиНаценкиОбъектом", СтрокаТЧСкидки.СкидкаНаценка, СтрокаТЧСкидки.ЗначениеСкидкиНаценкиОбъектом)).Количество() = 0 Тогда
				СтрокаТЧСкидки.Использовать				= Истина;
				СтрокаТЧСкидки.ЗначениеСкидкиНаценки	= 1;
				СтрокаТЧСкидки.Номенклатура				= Неопределено;
				СтрокаТЧСкидки.КлючСтроки				= Неопределено;
				НоваяСтрока = ТаблицаОбработанныхСкидокВыдачиКарт.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧСкидки);
			Иначе
				МассивСтрокТЗСкидокДляУдаления.Добавить(СтрокаТЧСкидки);
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;
	
	Для каждого СтрокаТЧСкидки Из МассивСтрокТЗСкидокДляУдаления Цикл
		ТаблицаСкидок.Удалить(СтрокаТЧСкидки); 
	КонецЦикла;
			
КонецПроцедуры

// Применяем скидку в строках ТЧ номенклатуры
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  ТабличнаяЧастьПодарки - табличная часть "Подарки" документа.
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//
Процедура ПрименитьСкидкиВТаблицеТоваров(
	ТаблицаСкидок,
	ТаблицаЗапасов,
	ТаблицаЛечения,
	ТаблицаУслуг, 
	ТаблицаПредыдщееСостояниеСкидок,
	ДокументОбъект)
	
	ЭтоНарядЗаказ = ТипЗнч(ДокументОбъект.Ссылка) = Тип("ДокументСсылка.НарядЗаказ");
    ЭтоПланЛечения = ТипЗнч(ДокументОбъект.Ссылка) = Тип("ДокументСсылка.ПланЛечения");
	
	Если ТаблицаЗапасов <> Неопределено Тогда
		Для Каждого СтрокаТЧ Из ТаблицаЗапасов Цикл
			
			СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
			СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;
			
			ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, НачислениеБонусами, Использовать", СтрокаТЧ.КлючСтроки, Ложь, Ложь, Истина));
			Для каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
				
				Если СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение = Истина Тогда // Значит могут быть выклчены или не вклчены
					
					Если ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0 // Эта скидка была раньше, значит берем ее состояние, если использование = ложь, пропускаем
						И ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, Использование, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, Ложь, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0
						
						ИЛИ ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() = 0
						И СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеВыклПоУмолчанию = Истина Тогда // Ранее не использовалась, 
						
						Продолжить;
					КонецЕсли;
					
				КонецЕсли;
				
				Если (СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма
					ИЛИ СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.СуммаНаДокумент
					ИЛИ СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент) Тогда
					
					СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки = СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки + СтрокаТЗСкидок.СуммаСкидки;
				ИначеЕсли СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВидЦен Тогда
					СтрокаТЧ.Цена	= СтрокаТЗСкидок.Цена;
					СтрокаТЧ.Сумма	= СтрокаТЗСкидок.Сумма;
					СтрокаТЧ.ВидЦен = СтрокаТЗСкидок.ЗначениеСкидкиНаценкиОбъектом;				
				КонецЕсли; 
				
			КонецЦикла;  
			
			// 279041. Если меняется клиент и скидка по нему не считалась, то может быть заполнен некорректный вид цен.
	//		Если НЕ ЗначениеЗаполнено(ТаблицаСкидокПоСтроке) И СтрокаТЧ.ВидЦен <> ДокументОбъект.ВидЦен Тогда
	//			СтрокаТЧ.ВидЦен = ДокументОбъект.ВидЦен;
	//			
	//			СтруктураДанные = Новый Структура();
	//			СтруктураДанные.Вставить("СтруктурнаяЕдиница", ДокументОбъект.СтруктурнаяЕдиница);
	//			СтруктураДанные.Вставить("Номенклатура", 	   СтрокаТЧ.Номенклатура);
	//			СтруктураДанные.Вставить("Упаковка",		   СтрокаТЧ.Упаковка);
	//			СтруктураДанные.Вставить("ДатаОбработки",	   ДокументОбъект.Дата);
	//			СтруктураДанные.Вставить("ВидЦен", 			   СтрокаТЧ.ВидЦен);
	//			СтрокаТЧ.Цена = Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураДанные);
	//
	//		КонецЕсли;
			
			// Оплата бонусами
			ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
			Для каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
				СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки = СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки 
																+ СтрокаТЗСкидок.СуммаСкидки;
			КонецЦикла;
			
			// Пересчитываем общий процент скидки
			СтрокаТЧ.ПроцентСкидкиНаценки = ?(СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок > 0, (СтрокаТЧ.СуммаРучнойСкидки + СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки) / (СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок) * 100, 0);
			
			// ограничиваем процент скидки 100%. приоритет отдан автоматическим скидкам.
			Если СтрокаТЧ.ПроцентСкидкиНаценки > 100 Тогда
				
				ПроцентРучнойСкидкиДО		= ?(СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок > 0, (СтрокаТЧ.СуммаРучнойСкидки) / (СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок) * 100, 0);
				СуммаРучнойСкидкиДО			= СтрокаТЧ.СуммаРучнойСкидки;
				СтрокаТЧ.СуммаРучнойСкидки	= ?(СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок - СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки > 0, СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок - СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки, 0); 
				ПроцентРучнойСкидки			= ?(СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок > 0, (СтрокаТЧ.СуммаРучнойСкидки) / (СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок) * 100, 0);
				
				ИспользуемаяВалюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Для строки № %1 процент ручной скидки уменьшен с %2 до %3, сумма ручной скидки уменьшена с %4 %5 до %6 %5'; en = 'For line №%1, the percentage of manual discounts is reduced from %2 to %3, the amount of manual discounts is reduced from %4 %5 to %6 %5'"), 
				СтрокаТЧ.НомерСтроки, 
				"" + ПроцентРучнойСкидкиДО + "% ", 
				"" + ПроцентРучнойСкидки + "% ", 
				СуммаРучнойСкидкиДО, 
				ИспользуемаяВалюта, 
				СтрокаТЧ.СуммаРучнойСкидки));
				
				СтрокаТЧ.ПроцентСкидкиНаценки = ?(СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок > 0, (СтрокаТЧ.СуммаРучнойСкидки + СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки) / (СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок) * 100, 0);
				
			КонецЕсли;		
			
		КонецЦикла;	
	КонецЕсли;
	
	Если ТаблицаЛечения <> Неопределено Тогда
		ПрименятьСкидкиПоПланамЛечения = ОбщегоНазначенияСтоматология.ПолучитьЗначениеКонстанты("ПрименятьСкидкиПоПланамЛечения");
		ЕстьКолонкаКоличествоУпаковокТЧЛечение = ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("КоличествоУпаковок") <> Неопределено;
		ЕслиКолонкаДокументАвансаТЧЛечение = ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("ДокументАванса") <> Неопределено;
		Для Каждого СтрокаТЧ Из ТаблицаЛечения Цикл			 			
				
			СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
			СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;			
			
			// Александра. Добавлена константа. Если она вкл,то скидки заполняем строго по документу аванса.
			Если ЕслиКолонкаДокументАвансаТЧЛечение = Истина Тогда
				Если ПрименятьСкидкиПоПланамЛечения = Истина И ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) Тогда
					
					СкидкиНаценкиДокументАванса = СтрокаТЧ.ДокументАванса.СкидкиНаценки.Выгрузить();    					
					ТЧСкидкиНаценкиПланаЛечения = СкидкиНаценкиДокументАванса.НайтиСтроки(Новый Структура("НоменклатураСкидки, КлючСтроки", СтрокаТЧ.Номенклатура, СтрокаТЧ.КлючСтроки));
					Если ЗначениеЗаполнено(ТЧСкидкиНаценкиПланаЛечения) Тогда						
						Для Каждого СтрокаТЧСкидкиНаценкиПланаЛечения Из ТЧСкидкиНаценкиПланаЛечения Цикл
							НоваяСтрока = ТаблицаСкидок.Добавить(); 
							НоваяСтрока.СкидкаНаценка = СтрокаТЧСкидкиНаценкиПланаЛечения.СкидкаНаценка;
							НоваяСтрока.Номенклатура = СтрокаТЧСкидкиНаценкиПланаЛечения.НоменклатураСкидки;
							НоваяСтрока.СуммаСкидки = СтрокаТЧСкидкиНаценкиПланаЛечения.Сумма;
							НоваяСтрока.ПризнакОплатыБонусом = СтрокаТЧСкидкиНаценкиПланаЛечения.ПризнакОплатыБонусом;
							НоваяСтрока.БонусныйСчет = СтрокаТЧСкидкиНаценкиПланаЛечения.БонусныйСчет;
							НоваяСтрока.Контрагент = СтрокаТЧСкидкиНаценкиПланаЛечения.Контрагент;
							НоваяСтрока.КлючСтроки = СтрокаТЧСкидкиНаценкиПланаЛечения.КлючСтроки;
							НоваяСтрока.Использовать = Истина;
							НоваяСтрока.НачислениеБонусами = ?(ЗначениеЗаполнено(СтрокаТЧСкидкиНаценкиПланаЛечения.БонусныйСчет), Истина, Ложь);							
							
							Если НЕ ЗначениеЗаполнено(НоваяСтрока.СпособПредоставленияСкидки) Тогда
								НоваяСтрока.СпособПредоставленияСкидки = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(НоваяСтрока.СкидкаНаценка, "СпособПредоставленияСкидки");		
							КонецЕсли;
							
							Если НЕ ЗначениеЗаполнено(НоваяСтрока.ЗначениеСкидкиНаценки) Тогда
								НоваяСтрока.ЗначениеСкидкиНаценки = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(НоваяСтрока.СкидкаНаценка, "ЗначениеСкидкиНаценки");		
							КонецЕсли;
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли; 
			// КонецДобавленного
			
			ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, НачислениеБонусами, Использовать", СтрокаТЧ.КлючСтроки, Ложь, Ложь, Истина));			
			
			Для каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
				
				Если СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение = Истина Тогда // Значит могут быть выклчены или не вклчены
					
					Если ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0 // Эта скидка была раньше, значит берем ее состояние, если использование = ложь, пропускаем
						И ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, Использование, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, Ложь, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0
						
						ИЛИ ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() = 0
						И СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеВыклПоУмолчанию = Истина Тогда // Ранее не использовалась, 
						
						Продолжить;
					КонецЕсли;
					
				КонецЕсли;                   												
				
				Если (СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма
					ИЛИ СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.СуммаНаДокумент
					ИЛИ СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент) Тогда
					
					// Александра. Добавлена константа. Если она вкл,то скидки заполняем строго по документу аванса.
					// если не меняем(применяем) скидки по плану лечения
					Если  (ЕслиКолонкаДокументАвансаТЧЛечение = Истина
						И ПрименятьСкидкиПоПланамЛечения = Истина И ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса)) Тогда
						
						СтрокаТЧ.СуммаРучнойСкидки = 0;
						Если ТипЗнч(СтрокаТЧ.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда
							ТЧЛеченияДокументаАванса = СтрокаТЧ.ДокументАванса.Лечение.Выгрузить(); 
						ИначеЕсли ТипЗнч(СтрокаТЧ.ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда
							ТЧЛеченияДокументаАванса = СтрокаТЧ.ДокументАванса.Запасы.Выгрузить();
						КонецЕсли;							
						СтрокаРучнойСкидкиДокументаАванса = ТЧЛеченияДокументаАванса.НайтиСтроки(Новый Структура("КлючСтроки, Номенклатура",СтрокаТЧ.КлючСтроки, СтрокаТЧ.Номенклатура));
						Если ЗначениеЗаполнено(СтрокаРучнойСкидкиДокументаАванса) Тогда
							СтрокаТЧ.СуммаРучнойСкидки = СтрокаРучнойСкидкиДокументаАванса[0].СуммаРучнойСкидки;
						КонецЕсли; 
						
						СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки = СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки + СтрокаТЗСкидок.СуммаСкидки;						
						
					КонецЕсли;
					
					// если меняем скидки по плану лечения					
					Если ПрименятьСкидкиПоПланамЛечения = Ложь 
						ИЛИ (ПрименятьСкидкиПоПланамЛечения = Истина 
							И ЭтоПланЛечения ИЛИ (ЕслиКолонкаДокументАвансаТЧЛечение = Истина
							И НЕ ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса))) Тогда
						
						СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки = СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки + СтрокаТЗСкидок.СуммаСкидки; 
						
					КонецЕсли;     									
					
					
				ИначеЕсли СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВидЦен Тогда
					СтрокаТЧ.Цена	= СтрокаТЗСкидок.Цена;
					СтрокаТЧ.Сумма	= СтрокаТЗСкидок.Сумма;
					СтрокаТЧ.ВидЦен = СтрокаТЗСкидок.ЗначениеСкидкиНаценкиОбъектом;				
