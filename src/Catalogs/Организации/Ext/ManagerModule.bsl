// Функция определяет значения реквизитов выбранной организации.
//
// Параметры:
//  Организация - СправочникСсылка.Организации - Ссылка на организацию
//
// Возвращаемое значение:
//	Структура - реквизиты выбранной организации
//
Функция ПолучитьРеквизитыОрганизации(Организация) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	Организации.Наименование КАК Наименование,
	                      |	ВЫРАЗИТЬ(Организации.ПолноеНаименование КАК СТРОКА(1000)) КАК ПолноеНаименование,
	                      |	Организации.ИНН КАК ИНН,
	                      |	Организации.КПП КАК КПП,
	                      |	Организации.КодПоОКПО КАК КодПоОКПО,
	                      |	Организации.ЮрФизЛицо КАК ЮрФизЛицо,
	                      |	Организации.ОГРН
	                      |ИЗ
	                      |	Справочник.Организации КАК Организации
	                      |ГДЕ
	                      |	Организации.Ссылка = &Организация");
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Представление = Выборка.Наименование;
		Наименование = Выборка.Наименование;
		ПолноеНаименование = Выборка.ПолноеНаименование;
		ИНН = Выборка.ИНН;
		КПП = Выборка.КПП;
		ОГРН = Выборка.ОГРН;
		КодПоОКПО = Выборка.КодПоОКПО;
		ЮрФизЛицо = Выборка.ЮрФизЛицо;
		// Если ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
		//	Свидетельство = "Свидетельство " + Выборка.СвидетельствоСерияНомер + " от " + Формат(Выборка.СвидетельствоДатаВыдачи, "ДФ=dd.MM.yyyy");
		// Иначе
		//	Свидетельство = "";
		// КонецЕсли;
	Иначе
		Представление = "";
		Наименование = "";
		ПолноеНаименование = "";
		ИНН = "";
		КПП = "";
		ОГРН = "";
		КодПоОКПО = "";
		ЮрФизЛицо = Перечисления.ЮрФизЛицо.ПустаяСсылка();
		// Свидетельство = "";
	КонецЕсли;
	
	СтруктураРеквизитов = Новый Структура("Представление, Наименование, ПолноеНаименование, ИНН, КПП, ОГРН, КодПоОКПО, ЮрФизЛицо, Свидетельство",
		Представление,
		Наименование,
		ПолноеНаименование,
		ИНН,
		КПП,
		ОГРН,
		КодПоОКПО,
		ЮрФизЛицо//,
		// Свидетельство
	);
	
	Возврат СтруктураРеквизитов;

КонецФункции // ПолучитьРеквизитыОрганизации()

// Функция, возвращает систему налообложения.
//
Функция ПолучитьСистемуНалогообложения(Организация) Экспорт
		
	Если Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда
		Возврат Перечисления.ТипыСистемНалогообложенияККТ.ОСН;
	ИначеЕсли Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
		Возврат Перечисления.ТипыСистемНалогообложенияККТ.УСНДоход;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция, возвращает кассира организации.
//
Функция ПолучитьКассираОрганизации(Организация) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.ФИОКассира КАК Кассир
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.Ссылка = &Организация
	|	И Организации.ФИОКассира <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)");
	
	Запрос.УстановитьПараметр("Организация", Организация);
	
	// Выборка = Запрос.Выполнить().Выбрать();
	//
	// Если Выборка.Следующий() Тогда
	//	Возврат Выборка.Кассир;
	// КонецЕсли;
	Возврат Запрос.Параметры.Организация.ФИОКассира;
	Возврат Неопределено;	
	
КонецФункции

