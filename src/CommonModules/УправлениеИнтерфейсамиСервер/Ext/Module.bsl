  
#Область СлужебныйПрограммныйИнтерфейс
  
// Процедура - Инициализация констант дополнительных расширений helix
//
Процедура ИнициализацияКонстантДополнительныхРасширенийHelix() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	УстановитьИспользованиеМессенджера();
	
КонецПроцедуры
 
// Процедура - Установить использование мессенджера
//
Процедура УстановитьИспользованиеМессенджера()
	
	Если ОбщегоНазначения.РазделениеВключено()
		И НЕ ОбщегоНазначения.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Константы.ИспользуетсяМессенджер.Установить(ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер"));
	
КонецПроцедуры

// Процедура установливает состояние элементов формы
// Параметры: Форма - форма интрефейса
// ПараметрОпределяющийСостояние - некий параметр, который передается функции возвращающей массив 
// реквизитов и их парамтеров, состояние которых необходимо изменить.
// Обязательные условия: 1. Форма должна быть формой некоего объекта.
//                      2. Менеджер данного объекта должен содержать функцию ПолучитьМассивСостоянияРеквизитов([ПараметрОпределяющийСостояние])
Процедура УстановкаСостоянийЭлементовФормы(Форма,ПараметрОпределяющийСостояние) Экспорт
	
	Элементы          = Форма.Элементы;
	МетаданныеОбъекта = Форма.Объект.Ссылка.Метаданные();
	МассивРеквизитов  = Документы[МетаданныеОбъекта.Имя].ПолучитьМассивСостоянияРеквизитов(ПараметрОпределяющийСостояние);
	
	// Проход по массиву переданных параметров управления
	Для Каждого ЭлементМ ИЗ МассивРеквизитов Цикл
		
		ПоискПоИмениРеквизитаОбъекта = Истина;
		РеквизитВидимость            = Истина;
		
		// Определяем режим поиска элемента формы
		Если ЭлементМ.Свойство("Тип") Тогда			  
			Если ЭлементМ.Тип = Тип("ПолеФормы") ИЛИ ЭлементМ.Тип = Тип("ГруппаФормы") Тогда
				ПоискПоИмениРеквизитаОбъекта = Ложь;
			КонецЕсли;		
		КонецЕсли;
		
		Если ЭлементМ.Свойство("Видимость") Тогда			  
			РеквизитВидимость = ЭлементМ.Видимость;	
		КонецЕсли;
		
		ЭлементыИзменения = Новый Массив;
		// Поиск элементы состояние которого необходимо установить
		Если ПоискПоИмениРеквизитаОбъекта Тогда
			
			// Если в параметрах указан реквизит объекта ищем по привязке элементы к объекту
			Для Каждого Элемент ИЗ Элементы Цикл				  
				Если (ТипЗнч(Элемент) = Тип("ПолеФормы") ИЛИ ТипЗнч(Элемент) = Тип("ТаблицаФормы")) И Элемент.ПутьКДанным = "Объект." + ЭлементМ.Имя Тогда				  
					ЭлементыИзменения.Добавить(Элемент);
				КонецЕсли;			  
			КонецЦикла;
		Иначе
			
			// Если указано просто имя элемента формы
			НайденныйЭлемент = Элементы.Найти(ЭлементМ.Имя);
			
			Если НЕ НайденныйЭлемент = Неопределено Тогда
				ЭлементыИзменения.Добавить(Элементы[ЭлементМ.Имя]);
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При установке состояния формы не обнаружен элмент:" +ЭлементМ.Имя);
			КонецЕсли;
		КонецЕсли;
		
		// Устанавливаем состояние найденных элементов
		Для Каждого Элемент ИЗ ЭлементыИзменения Цикл	
			
			// Установка видимости
			Элемент.Видимость = РеквизитВидимость;
			
			// Установка доступности
			Если ЭлементМ.Свойство("Доступность") И НЕ ЭлементМ.Доступность = Неопределено Тогда			  
				Элемент.Доступность = ЭлементМ.Доступность;	
			КонецЕсли;
			
			// Установка ТолькоПросмотр
			Если ЭлементМ.Свойство("ТолькоПросмотр") И НЕ ЭлементМ.ТолькоПросмотр = Неопределено  Тогда			  
				Элемент.ТолькоПросмотр = ЭлементМ.ТолькоПросмотр;	
			КонецЕсли;
			
			// Установить заголовок
			Если ЭлементМ.Свойство("Заголовок") И НЕ ЭлементМ.Заголовок = Неопределено Тогда
				Элемент.Заголовок = ЭлементМ.Заголовок;
			КонецЕсли;	
			
			// Установить ограничения типа
			Если ЭлементМ.Свойство("ОграничениеТипа") И НЕ ЭлементМ.ОграничениеТипа = Неопределено Тогда
				// Очистить реквизит если его предыдущий тип не совпадает с новым
				Если Не Элемент.ОграничениеТипа = ЭлементМ.ОграничениеТипа Тогда
					ИмяРеквизитаО = СтрЗаменить(Элемент.ПутьКДанным,"Объект.","");
					Если Форма.Объект.Свойство(ИмяРеквизитаО) 
					   И Форма.Объект[ИмяРеквизитаО] <> Неопределено 
					   И НЕ ЭлементМ.ОграничениеТипа.СодержитТип(ТипЗнч(Форма.Объект[ИмяРеквизитаО]))  Тогда
						Форма.Объект[ИмяРеквизитаО] = Неопределено;
					КонецЕсли;
				КонецЕсли;	
				Элемент.ОграничениеТипа = ЭлементМ.ОграничениеТипа;		
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Добавить в массив элементов параметры элемента состоянием которого необходимо управлять
//
Процедура ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,РеквизитИмя,РеквизитТип = Неопределено,Видимость = Истина,Доступность = Неопределено,ТолькоПросмотр = Неопределено,Заголовок = Неопределено,ОграничениеТипа = Неопределено) Экспорт
	
	ЭлементНайден = Ложь;
	// Ищем существующий элемент по имени реквизита в массиве
	Для Каждого ЭлементМ ИЗ МассивРеквизитов Цикл
		
		Если ЭлементМ.Имя = РеквизитИмя Тогда
			Если ЭлементМ.Свойство("Тип") Тогда
				ЭлементМ.Тип = РеквизитТип;
			КонецЕсли;	
			Если ЭлементМ.Свойство("Видимость") Тогда
				ЭлементМ.Видимость = Видимость;
			КонецЕсли;
			Если ЭлементМ.Свойство("Доступность") И НЕ Доступность = Неопределено Тогда
				ЭлементМ.Доступность = Доступность;
			КонецЕсли;	
			Если ЭлементМ.Свойство("ТолькоПросмотр") И НЕ ТолькоПросмотр = Неопределено Тогда
				ЭлементМ.ТолькоПросмотр = ТолькоПросмотр;
			КонецЕсли;	
			Если ЭлементМ.Свойство("Заголовок") И НЕ Заголовок = Неопределено Тогда
				ЭлементМ.Заголовок = Заголовок;
			КонецЕсли;	
			Если ЭлементМ.Свойство("ОграничениеТипа") И НЕ ОграничениеТипа = Неопределено Тогда
				ЭлементМ.ОграничениеТипа = ОграничениеТипа;
			КонецЕсли;	
			
			ЭлементНайден = Истина;
			Прервать;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	// Если элемент не найдем в массиве создаем его
	Если НЕ ЭлементНайден Тогда	
		МассивРеквизитов.Добавить(Новый Структура("Имя,Тип,Видимость,Доступность,ТолькоПросмотр,Заголовок,ОграничениеТипа",РеквизитИмя,РеквизитТип,Видимость,Доступность,ТолькоПросмотр,Заголовок,ОграничениеТипа));		
	КонецЕсли;
	
КонецПроцедуры

// Функция, выполняет поиск родителя в дереве
//
Функция НайтиРодителя(Знач Дерево, Знач Родитель) Экспорт
		
	НайденныеСтроки = ДанныеФормыВЗначение(Дерево, Тип("ДеревоЗначений")).Строки.НайтиСтроки(Новый Структура("Родитель", Родитель));
	
	Массив = Новый Массив;
	Для Каждого СтрокаТЧ из НайденныеСтроки Цикл
		Структра = Новый Структура("Артикул, Номенклатура, Родитель, ИндКартинки, Цена, Наименование, ЕдиницаИзмерения, ЭтоГруппа");
		ЗаполнитьЗначенияСвойств(Структра, СтрокаТЧ);
		Массив.Добавить(Структра);
	КонецЦикла;
	
	Возврат Массив;	
	
КонецФункции

#Область РаботаСЭлементамиФормы

// Процедура - Создание элемента кнопки.
//
// Параметры:
//  Форма					 - 	 -
//  ИмяЭлемента				 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  Заголовок				 - 	 -
//  Видимость				 - 	 -
//  ЦветФона				 - 	 -
//  РазмерШрифта			 - 	 -
//
Функция СозданиеЭлементаМеню(Форма, Знач ПараметрыЭлемента) Экспорт
	
	КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыЭлемента);
	
	ЭлементГруппа = СоздатьЭлементГруппа(Форма, ПараметрыЭлемента);
				
	ПараметрыКнопки = Новый Структура;
	Для Каждого Параметр Из ПараметрыЭлемента Цикл
		ПараметрыКнопки.Вставить(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	ПараметрыКнопки.Вставить("КомандаКнопки" , КомандаКнопки);
	ПараметрыКнопки.Вставить("ГруппаЭлемента", ЭлементГруппа);
	ПараметрыКнопки.Вставить("Видимость"     , Истина);
	
	ЭлементКнопка = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	
	Возврат КомандаКнопки;

КонецФункции

// Функция - Создание новой группы.
//
// Параметры:
//  Форма					 - 	 -
//  ИмяЭлемента				 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  Заголовок				 - 	 -
//  Видимость				 - 	 -
//  ЦветФона				 - 	 -
//  РазмерШрифта			 - 	 -
//
Функция СоздатьЭлементГруппа(Форма, ПараметрыГруппы, ПоискЭлемента = Истина) Экспорт
	
	Если Не СтрНачинаетсяС(ПараметрыГруппы.ИмяЭлемента, "Группа") Тогда
		ИмяЭлемента = "Группа" + ПараметрыГруппы.ИмяЭлемента;
	Иначе
		ИмяЭлемента = ПараметрыГруппы.ИмяЭлемента;
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементГруппа = Форма.Элементы.Найти(ИмяЭлемента);
	Иначе 
		ЭлементГруппа = Неопределено;
	КонецЕсли;
	
	Если ЭлементГруппа = Неопределено Тогда
		
		ЭлементГруппа = Форма.Элементы.Вставить(
		ИмяЭлемента,
		Тип("ГруппаФормы"),
		ПараметрыГруппы.ГруппаЭлемента,
		ПолучитьЗначениеПараметра(ПараметрыГруппы, "ЭлементВставки", Неопределено));
		
		ЭлементГруппа.Вид                      = ВидГруппыФормы.ОбычнаяГруппа;
		ЭлементГруппа.РастягиватьПоГоризонтали = Ложь;
		ЭлементГруппа.РастягиватьПоВертикали   = Ложь;
		ЭлементГруппа.ОтображатьЗаголовок	   = Ложь;
		ЭлементГруппа.Отображение       	   = ОтображениеОбычнойГруппы.Нет;
		ЭлементГруппа.Группировка              = ПолучитьЗначениеПараметра(ПараметрыГруппы, "Группировка"           , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
		ЭлементГруппа.ЦветФона                 = ПолучитьЗначениеПараметра(ПараметрыГруппы, "ЦветФона"              , ЭлементГруппа.ЦветФона);
		ЭлементГруппа.ГоризонтальныйИнтервал   = ПолучитьЗначениеПараметра(ПараметрыГруппы, "ГоризонтальныйИнтервал", ЭлементГруппа.ГоризонтальныйИнтервал);
		ЭлементГруппа.ВертикальныйИнтервал     = ПолучитьЗначениеПараметра(ПараметрыГруппы, "ВертикальныйИнтервал"  , ЭлементГруппа.ВертикальныйИнтервал);
		ЭлементГруппа.Ширина                   = ПолучитьЗначениеПараметра(ПараметрыГруппы, "ШиринаГруппы"          , ЭлементГруппа.Ширина);
		ЭлементГруппа.Доступность              = ПолучитьЗначениеПараметра(ПараметрыГруппы, "Доступность"           , ЭлементГруппа.Доступность);
		ЭлементГруппа.Заголовок                = ПолучитьЗначениеПараметра(ПараметрыГруппы, "Заголовок"             , ЭлементГруппа.Заголовок);
		ЭлементГруппа.ОтображатьЗаголовок      = ПолучитьЗначениеПараметра(ПараметрыГруппы, "ОтображатьЗаголовок"   , ЭлементГруппа.ОтображатьЗаголовок);
		ЭлементГруппа.ЦветТекстаЗаголовка      = ПолучитьЗначениеПараметра(ПараметрыГруппы, "ЦветТекстаЗаголовка"   , ЭлементГруппа.ЦветТекстаЗаголовка);
		ЭлементГруппа.Поведение                = ПолучитьЗначениеПараметра(ПараметрыГруппы, "Поведение"             , ЭлементГруппа.Поведение);
				
		ЭлементГруппа.ВертикальноеПоложениеВГруппе = ПолучитьЗначениеПараметра(
		ПараметрыГруппы,
		"ВертикальноеПоложениеВГруппе",
		ЭлементГруппа.ВертикальноеПоложениеВГруппе);
		ЭлементГруппа.ГоризонтальноеПоложениеВГруппе = ПолучитьЗначениеПараметра(
		ПараметрыГруппы,
		"ГоризонтальноеПоложениеВГруппе",
		ЭлементГруппа.ГоризонтальноеПоложениеВГруппе);
				
		Если ПараметрыГруппы.Свойство("РазмерШрифтаЗаголовка")
			И ПараметрыГруппы.РазмерШрифтаЗаголовка <> Неопределено Тогда
			
			ЭлементГруппа.ШрифтЗаголовка = Новый Шрифт(ЭлементГруппа.ШрифтЗаголовка,, ПараметрыГруппы.РазмерШрифтаЗаголовка);
		КонецЕсли;
		
	ИначеЕсли ЭлементГруппа.Родитель <> ПараметрыГруппы.ГруппаЭлемента
		ИЛИ (ПараметрыГруппы.Свойство("ПереместитьВКонец")
			 И ПараметрыГруппы.ПереместитьВКонец <> Неопределено
			 И ПараметрыГруппы.ПереместитьВКонец = Истина) Тогда
		
		Форма.Элементы.Переместить(ЭлементГруппа, ПараметрыГруппы.ГруппаЭлемента);
			 
	КонецЕсли;
		
	ЭлементГруппа.Видимость = ПолучитьЗначениеПараметра(ПараметрыГруппы, "Видимость", ЭлементГруппа.Видимость);
	
	Возврат ЭлементГруппа;
	
КонецФункции

// Функция - Создание команды элемента.
//
// Параметры:
//  ИмяОбработчикаНажатия	 - 	 -
//  ИмяЭлемента				 - 	 -
//  Форма					 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьКомандуЭлемента(Форма, ПараметрыКоманды) Экспорт
		
	КомандаКнопки = Форма.Команды.Найти("Команда" + ПараметрыКоманды.ИмяЭлемента);
	
	Если КомандаКнопки = Неопределено Тогда
		КомандаКнопки 	        = Форма.Команды.Добавить("Команда" + ПараметрыКоманды.ИмяЭлемента);
		КомандаКнопки.Действие  = ПараметрыКоманды.ИмяОбработчикаНажатия;
		КомандаКнопки.Подсказка = ПолучитьЗначениеПараметра(ПараметрыКоманды, "Подсказка", КомандаКнопки.Подсказка);
	Иначе 
		КомандаКнопки.Действие  = ПараметрыКоманды.ИмяОбработчикаНажатия;
		КомандаКнопки.Подсказка = ПолучитьЗначениеПараметра(ПараметрыКоманды, "Подсказка", КомандаКнопки.Подсказка);		
	КонецЕсли;
	
	Возврат КомандаКнопки;

КонецФункции

// Функция - Создать элемент кнопка.
//
// Параметры:
//  Заголовок			 - 	 -
//  ИмяЭлемента			 - 	 -
//  Картинка			 - 	 -
//  КнопкаОтображение	 - 	 -
//  КомандаКнопки		 - 	 -
//  РазмерШрифта		 - 	 -
//  Форма				 - 	 -
//  ЦветФона			 - 	 -
//  ЭлементГруппа		 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьЭлементКнопка(Форма, ПараметрыКнопки) Экспорт
		
	ЭлементКнопка = Форма.Элементы.Найти("Кнопка" + ПараметрыКнопки.ИмяЭлемента);
	
	Если ЭлементКнопка = Неопределено Тогда
		
		ЭлементКнопка = Форма.Элементы.Вставить(
		"Кнопка" + ПараметрыКнопки.ИмяЭлемента,
		Тип("КнопкаФормы"),
		ПараметрыКнопки.ГруппаЭлемента,
		ПолучитьЗначениеПараметра(ПараметрыКнопки, "ЭлементВставки", Неопределено));
		
		ЭлементКнопка.Отображение       = ПолучитьЗначениеПараметра(ПараметрыКнопки, "КнопкаОтображение", ЭлементКнопка.Отображение);
		ЭлементКнопка.ИмяКоманды        = ПараметрыКнопки.КомандаКнопки.Имя;
		ЭлементКнопка.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
		
		Если ПараметрыКнопки.Свойство("РазмерШрифта")
			И ПараметрыКнопки.РазмерШрифта <> Неопределено Тогда
			
			ЭлементКнопка.Шрифт = Новый Шрифт(ЭлементКнопка.Шрифт,, ПараметрыКнопки.РазмерШрифта);
		КонецЕсли;
		
		ЭлементКнопка.ГоризонтальноеПоложениеВГруппе = ПолучитьЗначениеПараметра(ПараметрыКнопки, "ГоризонтальноеПоложениеВГруппе", ЭлементКнопка.ГоризонтальноеПоложениеВГруппе); 
		
		Если ПараметрыКнопки.Свойство("Картинка")
			И ПараметрыКнопки.Картинка <> Неопределено Тогда
			
			ЭлементКнопка.Картинка          = ПараметрыКнопки.Картинка;
			ЭлементКнопка.ПоложениеКартинки = ПоложениеКартинкиКнопкиФормы.Право;
		КонецЕсли;
						
	КонецЕсли;
	
	// Если сменился заголовок/отображение элемента.
	ЭлементКнопка.Заголовок   = ПолучитьЗначениеПараметра(ПараметрыКнопки, "Заголовок"     , ЭлементКнопка.Заголовок);
	ЭлементКнопка.Доступность = ПолучитьЗначениеПараметра(ПараметрыКнопки, "Доступность"   , ЭлементКнопка.Доступность);
	ЭлементКнопка.Ширина      = ПолучитьЗначениеПараметра(ПараметрыКнопки, "ШиринаЭлемента", ЭлементКнопка.Ширина);
	ЭлементКнопка.Высота      = ПолучитьЗначениеПараметра(ПараметрыКнопки, "Высота"		   , ЭлементКнопка.Высота);
	ЭлементКнопка.Видимость   = ПолучитьЗначениеПараметра(ПараметрыКнопки, "Видимость"     , Истина);
	
	Если ПараметрыКнопки.Свойство("ШрифтЗачеркнутый")
		И ПараметрыКнопки.ШрифтЗачеркнутый <> Неопределено Тогда
		
		ЭлементКнопка.Шрифт = Новый Шрифт(ЭлементКнопка.Шрифт,,,,,, ПараметрыКнопки.ШрифтЗачеркнутый);
	КонецЕсли;
		
	Возврат ЭлементКнопка;
	
КонецФункции

// Функция - Создать элемент декорация.
//
// Параметры:
//  Форма					 - 	 -
//  ГруппаМеню				 - 	 -
//  ИмяЭлемента				 - 	 -
//  Видимость				 - 	 -
//  ЦветФона				 - 	 -
//  Группировка				 - 	 -
//  ГоризонтальныйИнтервал	 - 	 -
//  ВертикальныйИнтервал	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьЭлементДекорация(Форма, ПараметрыДекорации) Экспорт
	
	ЭлементДекорация = Форма.Элементы.Найти(ПараметрыДекорации.ИмяЭлемента);
	
	Если ЭлементДекорация = Неопределено Тогда
		
		ЭлементДекорация = Форма.Элементы.Добавить(ПараметрыДекорации.ИмяЭлемента, Тип("ДекорацияФормы"), ПараметрыДекорации.ГруппаЭлемента);
							
		ЭлементДекорация.ГоризонтальноеПоложениеВГруппе = ПолучитьЗначениеПараметра(ПараметрыДекорации, "ГоризонтальноеПоложениеЭлемента", ЭлементДекорация.ГоризонтальноеПоложениеВГруппе);
		ЭлементДекорация.ВертикальноеПоложениеВГруппе   = ПолучитьЗначениеПараметра(ПараметрыДекорации, "ВертикальноеПоложениеЭлемента"  , ЭлементДекорация.ВертикальноеПоложениеВГруппе);
		ЭлементДекорация.РастягиватьПоГоризонтали       = ПолучитьЗначениеПараметра(ПараметрыДекорации, "РастягиватьПоГоризонтали"       , ЭлементДекорация.РастягиватьПоГоризонтали);
		ЭлементДекорация.ЦветТекста                     = ПолучитьЗначениеПараметра(ПараметрыДекорации, "ЦветТекста"                     , ЭлементДекорация.ЦветТекста);
		ЭлементДекорация.ЦветФона                       = ПолучитьЗначениеПараметра(ПараметрыДекорации, "ЦветФона"                       , ЭлементДекорация.ЦветФона);
		ЭлементДекорация.Ширина	                        = ПолучитьЗначениеПараметра(ПараметрыДекорации, "Ширина"                       	 , ЭлементДекорация.Ширина);
		ЭлементДекорация.ЦветРамки                      = ЭлементДекорация.ЦветФона;
				
		Если ПараметрыДекорации.Свойство("Картинка")
			И ПараметрыДекорации.Картинка <> Неопределено Тогда
			
			ЭлементДекорация.Вид      = ВидДекорацииФормы.Картинка;
			ЭлементДекорация.Картинка = ПараметрыДекорации.Картинка;
		КонецЕсли;
		
		Если ПараметрыДекорации.Свойство("ОбработчикНажатия")
			И ПараметрыДекорации.ОбработчикНажатия <> Неопределено Тогда
			
			ЭлементДекорация.Гиперссылка = Истина;
			ЭлементДекорация.УстановитьДействие("Нажатие", ПараметрыДекорации.ОбработчикНажатия);
		КонецЕсли;
		
		Если ПараметрыДекорации.Свойство("ПереместитьВНачало")
			И ПараметрыДекорации.ПереместитьВНачало <> Неопределено
			И ПараметрыДекорации.ПереместитьВНачало = Истина
			И ПараметрыДекорации.ГруппаЭлемента.ПодчиненныеЭлементы.Количество() > 0 Тогда
			
			Форма.Элементы.Переместить(ЭлементДекорация, ПараметрыДекорации.ГруппаЭлемента, ПараметрыДекорации.ГруппаЭлемента.ПодчиненныеЭлементы[0]);
		КонецЕсли;
		
		Если ПараметрыДекорации.Свойство("РазмерШрифта")
			И ПараметрыДекорации.РазмерШрифта <> Неопределено Тогда
			
			ЭлементДекорация.Шрифт = Новый Шрифт(ЭлементДекорация.Шрифт,, ПараметрыДекорации.РазмерШрифта);
		КонецЕсли;
		
		Если ПараметрыДекорации.Свойство("ШрифтЖирный")
			И ПараметрыДекорации.ШрифтЖирный <> Неопределено Тогда
			
			ЭлементДекорация.Шрифт = Новый Шрифт(ЭлементДекорация.Шрифт,,, ПараметрыДекорации.ШрифтЖирный);
		КонецЕсли;
				
	КонецЕсли;
	
	// Если сменился заголовок элемента.
	ЭлементДекорация.Заголовок = ПолучитьЗначениеПараметра(ПараметрыДекорации, "Заголовок", ЭлементДекорация.Заголовок);
	ЭлементДекорация.Подсказка = ПолучитьЗначениеПараметра(ПараметрыДекорации, "Подсказка", ЭлементДекорация.Подсказка);
	
	Если ПараметрыДекорации.Свойство("Рамка")
		И ПараметрыДекорации.Рамка <> Неопределено
		И ПараметрыДекорации.Рамка = Истина Тогда
		
		ЭлементДекорация.Рамка                   = Новый Рамка(ТипРамкиЭлементаУправления.Одинарная, 3);
		ЭлементДекорация.Заголовок               = " " + СокрЛП(ЭлементДекорация.Заголовок) + Символы.НПП;	
		ЭлементДекорация.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
		
	КонецЕсли;
	
	// Постоянные значения:
	ЭлементДекорация.Высота = 1;
	
	Возврат ЭлементДекорация;
	
КонецФункции

// Функция - Создать элемент декорация.
//
// Параметры:
//  Форма					 - 	 -
//  ГруппаМеню				 - 	 -
//  ИмяЭлемента				 - 	 -
//  Видимость				 - 	 -
//  ЦветФона				 - 	 -
//  Группировка				 - 	 -
//  ГоризонтальныйИнтервал	 - 	 -
//  ВертикальныйИнтервал	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьЭлементПоле(Форма, ПараметрыПоля) Экспорт
		
	ИмяРеквизитаДанных = ПараметрыПоля.ИмяРеквизитаДанных;
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, ИмяРеквизитаДанных) Тогда
		
		МассивТипов      = Новый Массив;
		МассивРеквизитов = Новый Массив;
		
		МассивТипов.Добавить(ПараметрыПоля.ТипДанныхПоУмолчанию);
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяРеквизитаДанных, Новый ОписаниеТипов(МассивТипов)));
		
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
				
	КонецЕсли;
		
	ЭлементПоле = Форма.Элементы.Найти(ПараметрыПоля.ИмяЭлемента);
	
	Если ЭлементПоле = Неопределено Тогда
		
		ЭлементПоле = Форма.Элементы.Добавить(ПараметрыПоля.ИмяЭлемента, Тип("ПолеФормы"), ПараметрыПоля.ГруппаЭлемента);
		
		ЭлементПоле.ПутьКДанным              = ИмяРеквизитаДанных;
		ЭлементПоле.Вид                      = ВидПоляФормы.ПолеВвода;
		ЭлементПоле.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ЭлементПоле.РастягиватьПоГоризонтали = Ложь;
		ЭлементПоле.ПодсказкаВвода           = ПолучитьЗначениеПараметра(ПараметрыПоля, "ПодсказкаВвода", ЭлементПоле.ПодсказкаВвода);
		ЭлементПоле.Ширина                   = ПолучитьЗначениеПараметра(ПараметрыПоля, "ШиринаЭлемента", ЭлементПоле.Ширина);

		Если ПараметрыПоля.Свойство("ОбработчикПриИзменении")
			И ПараметрыПоля.ОбработчикПриИзменении <> Неопределено Тогда
			
			ЭлементПоле.УстановитьДействие("ПриИзменении", ПараметрыПоля.ОбработчикПриИзменении);
		КонецЕсли;
		
		Если ПараметрыПоля.Свойство("ОбработчикИзменениеТекстаРедактирования")
			И ПараметрыПоля.ОбработчикИзменениеТекстаРедактирования <> Неопределено Тогда
			
			ЭлементПоле.УстановитьДействие("ИзменениеТекстаРедактирования", ПараметрыПоля.ОбработчикИзменениеТекстаРедактирования);
		КонецЕсли;
		
		Если ПараметрыПоля.Свойство("ОбработчикОкончаниеВводаТекста")
			И ПараметрыПоля.ОбработчикОкончаниеВводаТекста <> Неопределено Тогда
			
			ЭлементПоле.УстановитьДействие("ОкончаниеВводаТекста", ПараметрыПоля.ОбработчикОкончаниеВводаТекста);
		КонецЕсли;

		Если ПараметрыПоля.Свойство("РазмерШрифта")
			И ПараметрыПоля.РазмерШрифта <> Неопределено Тогда
			
			ЭлементПоле.Шрифт = Новый Шрифт(ЭлементПоле.Шрифт,, ПараметрыПоля.РазмерШрифта);
		КонецЕсли;
				
	КонецЕсли;
	
	Возврат ЭлементПоле;
	
КонецФункции

// Функция - Создать элемент с видом флаг.
//
Функция СоздатьЭлементФлаг(Форма, ПараметрыПоля, ПоискЭлемента = Истина) Экспорт
	
	ИмяЭлемента = ПараметрыПоля.ИмяЭлемента; 
	
    Если ПоискЭлемента Тогда 
		ЭлементПоле = Форма.Элементы.Найти(ИмяЭлемента);
	Иначе 
		ЭлементПоле = Неопределено;
	КонецЕсли;
	
	Если ЭлементПоле = Неопределено Тогда
		
		ЭлементПоле = Форма.Элементы.Добавить(ПараметрыПоля.ИмяЭлемента, Тип("ПолеФормы"), ПараметрыПоля.ГруппаЭлемента);
		
		ЭлементПоле.ПутьКДанным              = ПараметрыПоля.ИмяРеквизитаДанных;
		ЭлементПоле.Вид                      = ВидПоляФормы.ПолеФлажка;
		ЭлементПоле.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ЭлементПоле.ВидФлажка                = ПолучитьЗначениеПараметра(ПараметрыПоля, "ВидФлажка", ЭлементПоле.ВидФлажка);
		ЭлементПоле.Подсказка           	 = ПолучитьЗначениеПараметра(ПараметрыПоля, "Подсказка", ЭлементПоле.Подсказка);
		ЭлементПоле.ТриСостояния             = ПолучитьЗначениеПараметра(ПараметрыПоля, "ТриСостояния", ЭлементПоле.ТриСостояния);
		
		ЭлементПоле.ГоризонтальноеПоложениеВГруппе = ПолучитьЗначениеПараметра(ПараметрыПоля, "ГоризонтальноеПоложениеЭлемента", ЭлементПоле.ГоризонтальноеПоложениеВГруппе);
		ЭлементПоле.ВертикальноеПоложениеВГруппе   = ПолучитьЗначениеПараметра(ПараметрыПоля, "ВертикальноеПоложениеЭлемента"  , ЭлементПоле.ВертикальноеПоложениеВГруппе);	
		
		Если ПараметрыПоля.Свойство("ОбработчикПриИзменении")
			И ПараметрыПоля.ОбработчикПриИзменении <> Неопределено Тогда
			
			ЭлементПоле.УстановитьДействие("ПриИзменении", ПараметрыПоля.ОбработчикПриИзменении);
		КонецЕсли;		
			
	КонецЕсли;
	
	Возврат ЭлементПоле;
	
КонецФункции

// Функция - Получить значение параметра элемента.
//
// Параметры:
//  ЗначениеПоУмолчанию	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ПолучитьЗначениеПараметра(ПараметрыЭлемента, ИскомыйПараметр, ЗначениеПоУмолчанию) Экспорт
		
	Если ПараметрыЭлемента.Свойство(ИскомыйПараметр)
		И ПараметрыЭлемента[ИскомыйПараметр] <> Неопределено Тогда
		
		Возврат ПараметрыЭлемента[ИскомыйПараметр];
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;

КонецФункции

// Процедура, копирует элементы формы рекурсивно.
//
Процедура КопироватьЭлементФормыРекурсивно(Форма, ЭлементИсточник, Родитель, ИдентификаторНовогоЭлемента, ИндексДанных = Неопределено) Экспорт
	
	Если ТипЗнч(ЭлементИсточник) = Тип("ГруппаФормы") Тогда
		
		ГруппаРодитель = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(Форма, ЭлементИсточник, ИдентификаторНовогоЭлемента, Родитель);
		
		Для Каждого Элемент Из ЭлементИсточник.ПодчиненныеЭлементы Цикл
			КопироватьЭлементФормыРекурсивно(Форма, Элемент, ГруппаРодитель, ИдентификаторНовогоЭлемента, ИндексДанных);
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ЭлементИсточник) = Тип("КнопкаФормы") Тогда
		
		УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(Форма, ЭлементИсточник, ИдентификаторНовогоЭлемента, Родитель);
		
	ИначеЕсли ТипЗнч(ЭлементИсточник) = Тип("ДекорацияФормы") Тогда
		
		УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(Форма, ЭлементИсточник, ИдентификаторНовогоЭлемента, Тип("ДекорацияФормы"), Родитель);
	Иначе
		ПутьКДанным = ?(ИндексДанных <> Неопределено, СтрЗаменить(ЭлементИсточник.ПутьКДанным, "[0]", "[" + ИндексДанных + "]"), Неопределено);
		
		УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(Форма, ЭлементИсточник, ИдентификаторНовогоЭлемента, Тип("ПолеФормы"), Родитель, ПутьКДанным);
		
	КонецЕсли;
	
КонецПроцедуры

// Функция, создает копию элемента формы.
//
Функция КопироватьЭлементФормы(Форма, ЭлементИсточник, ПрефиксИмениНовогоЭлемента, ТипЭлемента = Неопределено, Родитель, ПутьКДанным = Неопределено) Экспорт
	
	ИмяИсточника = ЭлементИсточник.Имя;
	
	Если СтрНайти(ИмяИсточника, "_") > 0 Тогда		
		ИмяИсточника = Лев(ИмяИсточника, СтрНайти(ИмяИсточника, "_"));
	КонецЕсли;
	
	Если ТипЭлемента = Неопределено Тогда
		ТипЭлемента = ТипЗнч(ЭлементИсточник);
	КонецЕсли;
	
	НовыйЭлемент     = Форма.Элементы.Добавить(ИмяИсточника + Формат(ПрефиксИмениНовогоЭлемента, "ЧН=; ЧГ="), ТипЭлемента, Родитель); 	
	НовыйЭлемент.Вид = ЭлементИсточник.Вид;
	
	Если ТипЭлемента = Тип("ПолеФормы") Тогда
		
		ЭтоПолеВвода 	= (ЭлементИсточник.Вид = ВидПоляФормы.ПолеВвода);
		ЭтоПолеКартинки = (ЭлементИсточник.Вид = ВидПоляФормы.ПолеКартинки);
		ЭтоПолеНадписи 	= (ЭлементИсточник.Вид = ВидПоляФормы.ПолеНадписи);
		ЭтоПолеФлажка	= (ЭлементИсточник.Вид = ВидПоляФормы.ПолеФлажка);
		
		Если ЭтоПолеВвода Тогда
			
			НовыйЭлемент.КнопкаВыбора              = ЭлементИсточник.КнопкаВыбора;
			НовыйЭлемент.КнопкаОткрытия            = ЭлементИсточник.КнопкаОткрытия;
			НовыйЭлемент.КнопкаОчистки             = ЭлементИсточник.КнопкаОчистки;
			НовыйЭлемент.КнопкаРегулирования       = ЭлементИсточник.КнопкаРегулирования;
			НовыйЭлемент.РедактированиеТекста      = ЭлементИсточник.РедактированиеТекста;
			НовыйЭлемент.КнопкаСпискаВыбора        = ЭлементИсточник.КнопкаСпискаВыбора;
			НовыйЭлемент.ШиринаВыпадающегоСписка   = ЭлементИсточник.ШиринаВыпадающегоСписка;
			НовыйЭлемент.ПодсказкаВвода            = ЭлементИсточник.ПодсказкаВвода;
			НовыйЭлемент.ПараметрыВыбора           = ЭлементИсточник.ПараметрыВыбора;
            НовыйЭлемент.ФормаВыбора               = ЭлементИсточник.ФормаВыбора;
			НовыйЭлемент.РежимВыбораИзСписка       = ЭлементИсточник.РежимВыбораИзСписка;
			НовыйЭлемент.КнопкаВыпадающегоСписка   = ЭлементИсточник.КнопкаВыпадающегоСписка;
			НовыйЭлемент.ОтображениеКнопкиВыбора   = ЭлементИсточник.ОтображениеКнопкиВыбора;
			НовыйЭлемент.АвтоОтметкаНезаполненного = ЭлементИсточник.АвтоОтметкаНезаполненного;
			НовыйЭлемент.ИсторияВыбораПриВводе	   = ЭлементИсточник.ИсторияВыбораПриВводе;
			НовыйЭлемент.ТолькоПросмотр	   		   = ЭлементИсточник.ТолькоПросмотр;
			НовыйЭлемент.ЦветТекстаЗаголовка   	   = ЭлементИсточник.ЦветТекстаЗаголовка;
			
			Если ЗначениеЗаполнено(ЭлементИсточник.Подсказка) Тогда 
				НовыйЭлемент.Подсказка            = ЭлементИсточник.Подсказка;
				НовыйЭлемент.ОтображениеПодсказки = ЭлементИсточник.ОтображениеПодсказки;
			КонецЕсли;
			
			Если ЭлементИсточник.СписокВыбора.Количество() > 0 Тогда 
								
				Для Каждого ЭлементС Из ЭлементИсточник.СписокВыбора Цикл
					НовыйЭлемент.СписокВыбора.Добавить(ЭлементС.Значение, ЭлементС.Представление);		
				КонецЦикла;
				
			КонецЕсли;	
			
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Открытие");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ОкончаниеВводаТекста");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Очистка");
			
		ИначеЕсли ЭтоПолеКартинки Тогда
			
			НовыйЭлемент.Рамка 			  		= ЭлементИсточник.Рамка;
			НовыйЭлемент.КартинкаЗначений 		= ЭлементИсточник.КартинкаЗначений;
			НовыйЭлемент.Гиперссылка      		= ЭлементИсточник.Гиперссылка;
			НовыйЭлемент.РастягиватьПоВертикали = ЭлементИсточник.РастягиватьПоВертикали;
			
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Нажатие");
			
		ИначеЕсли ЭтоПолеФлажка Тогда
			НовыйЭлемент.ШиринаЭлемента       = ЭлементИсточник.ШиринаЭлемента;
			НовыйЭлемент.ВидФлажка            = ЭлементИсточник.ВидФлажка;
		КонецЕсли;
		
		Если ЭтоПолеВвода ИЛИ ЭтоПолеНадписи ИЛИ ЭтоПолеКартинки Тогда
			
			НовыйЭлемент.ПоложениеЗаголовка       = ЭлементИсточник.ПоложениеЗаголовка;
			НовыйЭлемент.АвтоМаксимальнаяШирина   = ЭлементИсточник.АвтоМаксимальнаяШирина;
			НовыйЭлемент.АвтоМаксимальнаяВысота   = ЭлементИсточник.АвтоМаксимальнаяВысота;
			НовыйЭлемент.МаксимальнаяШирина       = ЭлементИсточник.МаксимальнаяШирина;
			НовыйЭлемент.МаксимальнаяВысота       = ЭлементИсточник.МаксимальнаяВысота;
			НовыйЭлемент.Шрифт                    = ЭлементИсточник.Шрифт;
			НовыйЭлемент.Ширина 				  = ЭлементИсточник.Ширина;
			НовыйЭлемент.Высота                   = ЭлементИсточник.Высота;
			НовыйЭлемент.РастягиватьПоГоризонтали = ЭлементИсточник.РастягиватьПоГоризонтали;
			
		КонецЕсли;
		
		Если ЭтоПолеВвода ИЛИ ЭтоПолеНадписи ИЛИ ЭтоПолеФлажка Тогда
			НовыйЭлемент.ПоложениеЗаголовка       = ЭлементИсточник.ПоложениеЗаголовка;
		КонецЕсли;
		
		// Копирование обработчиков
		Если ЭтоПолеВвода ИЛИ ЭтоПолеФлажка Тогда
			
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ПриИзменении");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ОбработкаВыбора");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "НачалоВыбора");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "АвтоПодбор");
			
			Попытка
				НовыйЭлемент.ФорматРедактирования = ЭлементИсточник.ФорматРедактирования;
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
	ИначеЕсли ТипЭлемента = Тип("ДекорацияФормы") Тогда
		
		НовыйЭлемент.Шрифт 					  = ЭлементИсточник.Шрифт;
		НовыйЭлемент.АвтоМаксимальнаяШирина   = ЭлементИсточник.АвтоМаксимальнаяШирина;
		НовыйЭлемент.АвтоМаксимальнаяВысота   = ЭлементИсточник.АвтоМаксимальнаяВысота;
		НовыйЭлемент.Ширина 				  = ЭлементИсточник.Ширина;
		НовыйЭлемент.Высота                   = ЭлементИсточник.Высота;
		НовыйЭлемент.РастягиватьПоГоризонтали = ЭлементИсточник.РастягиватьПоГоризонтали;
		НовыйЭлемент.РастягиватьПоВертикали   = ЭлементИсточник.РастягиватьПоВертикали;
		НовыйЭлемент.МаксимальнаяШирина       = ЭлементИсточник.МаксимальнаяШирина;
		НовыйЭлемент.МаксимальнаяВысота       = ЭлементИсточник.МаксимальнаяВысота;	
		НовыйЭлемент.Гиперссылка              = ЭлементИсточник.Гиперссылка;		
		НовыйЭлемент.Подсказка                = ЭлементИсточник.Подсказка;		
		
		Если ЭлементИсточник.Вид = ВидДекорацииФормы.Картинка Тогда
			НовыйЭлемент.Вид      = ЭлементИсточник.Вид;
			НовыйЭлемент.Картинка = ЭлементИсточник.Картинка;			
		КонецЕсли;	
		
		УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Нажатие");
		УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ОбработкаНавигационнойСсылки");
		
	КонецЕсли;
	
	Если ЭлементИсточник.Вид <> ВидДекорацииФормы.Картинка Тогда
		
		НовыйЭлемент.ГоризонтальноеПоложение = ЭлементИсточник.ГоризонтальноеПоложение;
		Если ЭлементИсточник.Вид <> ВидПоляФормы.ПолеКартинки Тогда
			НовыйЭлемент.ЦветФона            = ЭлементИсточник.ЦветФона;
		КонецЕсли;
		
	КонецЕсли;
	
	НовыйЭлемент.Заголовок 						= ЭлементИсточник.Заголовок;
	НовыйЭлемент.ГоризонтальноеПоложениеВГруппе = ЭлементИсточник.ГоризонтальноеПоложениеВГруппе;
    НовыйЭлемент.ВертикальноеПоложениеВГруппе   = ЭлементИсточник.ВертикальноеПоложениеВГруппе;
	НовыйЭлемент.ЦветТекста                     = ЭлементИсточник.ЦветТекста;
	НовыйЭлемент.Видимость 						= ЭлементИсточник.Видимость;
	
	Если ЗначениеЗаполнено(ПутьКДанным) Тогда
		НовыйЭлемент.ПутьКДанным = СтрЗаменить(ПутьКДанным, Символы.НПП, "");
	КонецЕсли;
	
	Возврат НовыйЭлемент;
	
КонецФункции

// Функция, создает копию кнопки формы.
//
Функция КопироватьКнопкуФормы(Форма, КнопкаИсточник, ПрефиксИмениНовойКнопки, Родитель, знач ОбработчикНажатия = Неопределено, знач НовыйЗаголовок = Неопределено, знач НоваяПодсказка = Неопределено, СоздаватьКоманду = Истина, Картинка = Неопределено) Экспорт
		
	ИмяИсточника     = КнопкаИсточник.Имя;	
	КомандаИсточника = Форма.Команды.Найти(КнопкаИсточник.ИмяКоманды);

	Если НЕ ЗначениеЗаполнено(ОбработчикНажатия) Тогда		
		ОбработчикНажатия = КомандаИсточника.Действие	
	КонецЕсли;
	
	Если СтрНайти(ИмяИсточника, "_") > 0 Тогда		
		ИмяИсточника = Лев(ИмяИсточника, СтрНайти(ИмяИсточника, "_")); 			
	КонецЕсли;
		
	ИмяНовойКнопки = ИмяИсточника + Формат(ПрефиксИмениНовойКнопки, "ЧН=; ЧГ=");
	
	Если СоздаватьКоманду Тогда
		
		КомандаФормы = Форма.Команды.Найти(ИмяНовойКнопки);
		Если КомандаФормы = Неопределено Тогда
			
			КомандаФормы           = Форма.Команды.Добавить(ИмяНовойКнопки);
			КомандаФормы.Действие  = ОбработчикНажатия;
			КомандаФормы.Заголовок = КомандаИсточника.Заголовок; 
			КомандаФормы.Подсказка = КомандаИсточника.Подсказка; 
			
		КонецЕсли;
		
	КонецЕсли;
	
	НоваяКнопка                        = Форма.Элементы.Добавить(ИмяНовойКнопки, Тип("КнопкаФормы"), Родитель);

	НоваяКнопка.Заголовок              = ?(ЗначениеЗаполнено(НовыйЗаголовок), НовыйЗаголовок, КнопкаИсточник.Заголовок);
	НоваяКнопка.ИмяКоманды             = ?(СоздаватьКоманду, ИмяНовойКнопки, КнопкаИсточник.ИмяКоманды);
	НоваяКнопка.ОтображениеФигуры      = КнопкаИсточник.ОтображениеФигуры;
	НоваяКнопка.Видимость              = КнопкаИсточник.Видимость;
	НоваяКнопка.ЦветТекста             = КнопкаИсточник.ЦветТекста;	
	НоваяКнопка.Шрифт                  = КнопкаИсточник.Шрифт; 
	НоваяКнопка.Картинка               = ?(Картинка <> Неопределено, Картинка, КнопкаИсточник.Картинка);
	НоваяКнопка.АвтоМаксимальнаяШирина = КнопкаИсточник.АвтоМаксимальнаяШирина;
	НоваяКнопка.Отображение            = КнопкаИсточник.Отображение;
    НоваяКнопка.Ширина                 = КнопкаИсточник.Ширина;
	НоваяКнопка.Высота				   = КнопкаИсточник.Высота;
	
	Если НоваяПодсказка <> Неопределено и ТипЗнч(КомандаФормы) = Тип("КомандаФормы") Тогда
		КомандаФормы.Подсказка = НоваяПодсказка;
		НоваяКнопка.ОтображениеПодсказки = ОтображениеПодсказки.Авто;
	КонецЕсли;
	
	Возврат НоваяКнопка;
	
КонецФункции

// Функция, создает копию группы формы.
//
Функция КопироватьГруппуФормы(Форма, ГруппаИсточник, ПрефиксИмениНовойГруппы, Родитель) Экспорт
	
	ИмяИсточника = ГруппаИсточник.Имя;
	
	Если СтрНайти(ИмяИсточника, "_") > 0 Тогда		
		ИмяИсточника = Лев(ИмяИсточника, СтрНайти(ИмяИсточника, "_")); 			
	КонецЕсли;
	
	ИмяНовойГруппы = ИмяИсточника + Формат(ПрефиксИмениНовойГруппы, "ЧН=; ЧГ=");
	
	НоваяГруппа                     = Форма.Элементы.Добавить(ИмяНовойГруппы, Тип("ГруппаФормы"), Родитель);
	
	НоваяГруппа.Вид                 = ГруппаИсточник.Вид;
	НоваяГруппа.Группировка         = ГруппаИсточник.Группировка;
	НоваяГруппа.Отображение         = ГруппаИсточник.Отображение;
	НоваяГруппа.ОтображатьЗаголовок = ГруппаИсточник.ОтображатьЗаголовок;
	НоваяГруппа.Ширина              = ГруппаИсточник.Ширина;
	НоваяГруппа.Высота              = ГруппаИсточник.Высота;
    НоваяГруппа.Заголовок           = ГруппаИсточник.Заголовок;
	НоваяГруппа.ЦветФона            = ГруппаИсточник.ЦветФона;
	
	НоваяГруппа.ВертикальныйИнтервал                = ГруппаИсточник.ВертикальныйИнтервал;
	НоваяГруппа.ГоризонтальныйИнтервал 				= ГруппаИсточник.ГоризонтальныйИнтервал;
	НоваяГруппа.ГоризонтальноеПоложениеПодчиненных  = ГруппаИсточник.ГоризонтальноеПоложениеПодчиненных;
    НоваяГруппа.ВертикальноеПоложениеПодчиненных    = ГруппаИсточник.ВертикальноеПоложениеПодчиненных;
    НоваяГруппа.РастягиватьПоГоризонтали            = ГруппаИсточник.РастягиватьПоГоризонтали;
    НоваяГруппа.РастягиватьПоВертикали              = ГруппаИсточник.РастягиватьПоВертикали;
	НоваяГруппа.ГоризонтальноеПоложениеВГруппе      = ГруппаИсточник.ГоризонтальноеПоложениеВГруппе;
	НоваяГруппа.ВертикальноеПоложениеВГруппе        = ГруппаИсточник.ВертикальноеПоложениеВГруппе;
	
	Если ГруппаИсточник.Поведение = ПоведениеОбычнойГруппы.Всплывающая Тогда
		
		НоваяГруппа.Поведение           = ГруппаИсточник.Поведение;
		НоваяГруппа.Видимость           = Истина;
		НоваяГруппа.ЦветТекстаЗаголовка = ГруппаИсточник.ЦветТекстаЗаголовка;
		НоваяГруппа.ШрифтЗаголовка      = ГруппаИсточник.ШрифтЗаголовка;
		
	КонецЕсли;
	
	Возврат НоваяГруппа;
	
КонецФункции

// Процедура, устанавилвает действие для элемента формы.
//
Процедура УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, ИмяДействия)
	
	Действие = ЭлементИсточник.ПолучитьДействие(ИмяДействия);
	
	Если ЗначениеЗаполнено(Действие) Тогда
		НовыйЭлемент.УстановитьДействие(ИмяДействия, Действие);
	КонецЕсли;
	
КонецПроцедуры

// Процедура, удаляет подчиненные элементы в родительской группе.
//
Процедура УдалитьПодчиненныеЭлементыГруппы(Форма, ГруппаРодитель, ИсключаемыеЭлементы) Экспорт
	
	Если ТипЗнч(ИсключаемыеЭлементы) = Тип("Массив") Тогда
		МассивИсключаемыхЭлементов = ИсключаемыеЭлементы;
	Иначе
		МассивИсключаемыхЭлементов = Новый Массив;
		МассивИсключаемыхЭлементов.Добавить(ИсключаемыеЭлементы);
	КонецЕсли;
	
	МассивУдаляемых = Новый Массив;
	Для Каждого Элемент Из ГруппаРодитель.ПодчиненныеЭлементы Цикл
		Если МассивИсключаемыхЭлементов.Найти(Элемент) = Неопределено Тогда
			МассивУдаляемых.Добавить(Элемент);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из МассивУдаляемых Цикл
		Форма.Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСДинамическимиМенюФормы

#Область СозданиеЭлементовДинамическогоМенюРасписанияЗанятий

// Функция - Создать динамическое меню формы Расписания занятий.
//
// Параметры:
//  ИмяМеню					 - имя меню.
//  Форма					 - 	 -
//  ГруппаРодитель			 - 	 -
//  МассивПривязанныхДанных	 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  ПараметрыОформления		 - 	 -
//  ВыборПоУмолчанию		 - 	 -
//  ТипДанныхПоУмолчанию	 - 	 -
//  ОгрКолЭлементов			 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьДинамическоеМенюФормыРасписанияЗанятий(
	ИмяМеню,
	Форма,
	ГруппаРодитель,
	МассивПривязанныхДанных,
	ИмяОбработчикаНажатия,
	ВыборПоУмолчанию     = Неопределено,
	Параметр0_Удалить    = Неопределено,
	Параметр1_Удалить    = Неопределено,
	ТипДанныхПоУмолчанию = Неопределено,
	Параметр2_Удалить    = Неопределено,
	ОгрКолЭлементов      = Неопределено,
	ПараметрыОформления  = Неопределено,
	ПересоздатьЭлемМеню  = Ложь,
	ТипМеню              = Неопределено) Экспорт
		
	ВыборПоУмолчаниюМасс = Неопределено;
	Если ВыборПоУмолчанию <> Неопределено Тогда
		Если Не ТипЗнч(ВыборПоУмолчанию) = Тип("Массив") Тогда
			ВыборПоУмолчаниюМасс = Новый Массив;
			ВыборПоУмолчаниюМасс.Добавить(ВыборПоУмолчанию);
		Иначе
			ВыборПоУмолчаниюМасс = ВыборПоУмолчанию;
		КонецЕсли;
	КонецЕсли;
	
	// Добавляем к структурам описания элемента меню доп. свойства.
	Для Каждого ОписаниеЭлементаМеню ИЗ МассивПривязанныхДанных Цикл
		
		ОписаниеЭлементаМеню.Вставить("ИмяЭлемента", Неопределено);
		
		Если Не ОписаниеЭлементаМеню.Свойство("Выбор") Тогда
			
			Если ВыборПоУмолчаниюМасс <> Неопределено
				И ВыборПоУмолчаниюМасс.Найти(ОписаниеЭлементаМеню.Значение) <> Неопределено Тогда
				
				ОписаниеЭлементаМеню.Вставить("Выбор", Истина);
			Иначе
				ОписаниеЭлементаМеню.Вставить("Выбор", Ложь);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;

	РазмерШрифта         = Неопределено;
	ШиринаЭлемента       = Неопределено;
	ШиринаГруппыЭлемента = Неопределено;
	ЦветТекста           = Неопределено;
	
	Если ЗначениеЗаполнено(ПараметрыОформления) Тогда
		
		ПараметрыОформления.Свойство("РазмерШрифта"        , РазмерШрифта);
		ПараметрыОформления.Свойство("ШиринаЭлемента"      , ШиринаЭлемента);
		ПараметрыОформления.Свойство("ШиринаГруппыЭлемента", ШиринаГруппыЭлемента);
		ПараметрыОформления.Свойство("ЦветТекста"          , ЦветТекста);
		
	КонецЕсли;
			
	ПарметрыМеню = Новый Структура;
	
	ПарметрыМеню.Вставить("ИмяМеню"              , ИмяМеню);
	ПарметрыМеню.Вставить("ИмяГруппы"            , ГруппаРодитель.Имя);
	ПарметрыМеню.Вставить("РазмерШрифта"         , ?(ЗначениеЗаполнено(РазмерШрифта), РазмерШрифта, 11));
	ПарметрыМеню.Вставить("ШиринаЭлемента"       , ШиринаЭлемента);
	ПарметрыМеню.Вставить("ШиринаГруппыЭлемента" , ШиринаГруппыЭлемента);
	ПарметрыМеню.Вставить("ЦветТекста"           , ?(ЦветТекста <> Неопределено, ЦветТекста, Новый Цвет(51, 102, 187)));
	ПарметрыМеню.Вставить("ЦветТекстаВыбранного" , Новый Цвет(77 , 77 , 77));
	ПарметрыМеню.Вставить("ЦветФона"             , Новый Цвет(255, 255, 255));
	ПарметрыМеню.Вставить("ЦветФонаВыбранного"   , Новый Цвет(242, 242, 242));
	ПарметрыМеню.Вставить("ПривязанныеДанные"    , МассивПривязанныхДанных);
	ПарметрыМеню.Вставить("ТипДанныхПоУмолчанию" , ТипДанныхПоУмолчанию);
	ПарметрыМеню.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПарметрыМеню.Вставить("ТипМеню"              , ТипМеню);
	ПарметрыМеню.Вставить("ВыборПоУмолчанию"     , ВыборПоУмолчанию);
	ПарметрыМеню.Вставить("ОгрКолЭлементов"      , ?(ЗначениеЗаполнено(ОгрКолЭлементов), ОгрКолЭлементов, 5));
	ПарметрыМеню.Вставить("ПересоздатьЭлемМеню"  , ПересоздатьЭлемМеню);
	
	// Создаем динамические элементы.
	СоздатьЭлементыВДинамическомМеню(Форма, ПарметрыМеню);
		
	// Помещаем настройки текущего меню во временное хранилищи и получаем его адрес.
	АдресХраненияНастроекМеню = ПоместитьВоВременноеХранилище(ПарметрыМеню, Форма.УникальныйИдентификатор);
	
	НовыйАдресСтруктурыАдресов  = Ложь;
	СтруктураАдресов            = Неопределено;
	
	// Получаем адрес хранения структуры адресов настроек меню.
	// По этому адресу извлекаем структуру содержащую адреса настроек каждой меню.
	АдресСтруктуррыАдресов = ХранилищеСистемныхНастроек.Загрузить("ПодсистемаДинамическогоМеню", "СтруктураХраненияАдресов" + Форма.УникальныйИдентификатор);
	Если АдресСтруктуррыАдресов <> Неопределено И ЭтоАдресВременногоХранилища(АдресСтруктуррыАдресов) = Истина Тогда
		СтруктураАдресов = ПолучитьИзВременногоХранилища(АдресСтруктуррыАдресов);
	КонецЕсли;
	
	// Если структура не обнаружено, значит это новое открытие формы.
	Если СтруктураАдресов = Неопределено Тогда
		СтруктураАдресов           = Новый Структура;
		НовыйАдресСтруктурыАдресов = Истина;
	КонецЕсли;
	
    // Добавляем адрес настроек текущего меню в структуру.
	Если СтруктураАдресов.Свойство(ИмяМеню) = Ложь Тогда
		СтруктураАдресов.Вставить(ИмяМеню,АдресХраненияНастроекМеню);
	Иначе
		СтруктураАдресов[ИмяМеню] = АдресХраненияНастроекМеню;
	КонецЕсли;
	
	// Сохраняем структуру адресов.
	Если НовыйАдресСтруктурыАдресов = Истина Тогда
		АдресСтруктуррыАдресов = ПоместитьВоВременноеХранилище(СтруктураАдресов, Форма.УникальныйИдентификатор);
		ХранилищеСистемныхНастроек.Сохранить("ПодсистемаДинамическогоМеню", "СтруктураХраненияАдресов" + Форма.УникальныйИдентификатор,АдресСтруктуррыАдресов);
	Иначе
		ПоместитьВоВременноеХранилище(СтруктураАдресов, АдресСтруктуррыАдресов);
	КонецЕсли;
	
	Возврат АдресХраненияНастроекМеню;
	
КонецФункции

// Процедура - Создать элементы в динамическом меню.
//
// Параметры:
//  Форма					 - 	 -
//  ГруппаРодитель			 - 	 -
//  ПараметрыОформления		 - 	 -
//  МассивПривязанныхДанных	 - 	 -
//
Процедура СоздатьЭлементыВДинамическомМеню(Форма, ПараметрыМеню)
	
	ИмяМеню                 = ПараметрыМеню.ИмяМеню;
	ГруппаРодитель          = Форма.Элементы[ПараметрыМеню.ИмяГруппы];
	МассивПривязанныхДанных = ПараметрыМеню.ПривязанныеДанные;
	ТипМеню   			    = ПараметрыМеню.ТипМеню;
	ОгрКолЭлементов         = ПараметрыМеню.ОгрКолЭлементов;
	ПересоздатьЭлемМеню     = ПараметрыМеню.ПересоздатьЭлемМеню;
	
	ИндексДанных = 0;
	ИндексГруппы = 0;
	
	ПредПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);

	// Если необходимо пересоздать меню - то удаляем все старые элементы.
	Если ПересоздатьЭлемМеню = Истина Тогда
		
		СозданиеЭлементовДинамическогоМенюУдалитьЭлементыМеню(ПредПараметрыМеню, Форма);
		
	КонецЕсли;
	
	// Создаем новые элементы меню.
	Для Каждого ОписаниеЭлементаМеню Из МассивПривязанныхДанных Цикл
		
		// Переход на новую строку, если в группе больше заданного числа элементов.
		Если Ост(ИндексДанных, ОгрКолЭлементов) = 0 Тогда
			
			// Создание подгруппы основного меню.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Группа_ME_" + ИмяМеню + "_ID_" + ИндексГруппы);
			ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРодитель);
			ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);

			ГруппаМеню   = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
			ИндексГруппы = ИндексГруппы + 1;
			
		КонецЕсли;
		
		// Создание группы элемента.
		НоваяГруппа = СозданиеЭлементовДинамическогоМенюОсновнаяГруппаЭлемента(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, ГруппаМеню, ИндексДанных);
		
		// Если это отбор и есть подчиненное меню.
		Если ТипМеню = "Отбор"
			И ОписаниеЭлементаМеню.Свойство("ИмяПодчиненногоМеню")
			И ЗначениеЗаполнено(ОписаниеЭлементаМеню.ИмяПодчиненногоМеню) Тогда
			
			// Создание элементов отбора динамического меню.
			СозданиеЭлементовДинамическогоМенюФормированиеМенюОтбора(
			Форма,
			ОписаниеЭлементаМеню,
			ПараметрыМеню,
			ПредПараметрыМеню,
			НоваяГруппа,
			ИндексДанных);
			
		КонецЕсли;

		// Если это элемент "Переключатель".
		Если СтрНайти(ОписаниеЭлементаМеню.Представление, "Переключатель") > 0 Тогда
			
			СозданиеЭлементовДинамическогоМенюЭлементПереключатель(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, НоваяГруппа, ИндексДанных);

		// Если это элемент "Список".
		ИначеЕсли СтрНайти(ОписаниеЭлементаМеню.Представление, "ОткрытьСписок") > 0 Тогда
			
			СозданиеЭлементовДинамическогоМенюЭлементСписок(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, НоваяГруппа, ИндексДанных);
			
		// Если это элемент "Декорация".
		ИначеЕсли СтрНайти(ОписаниеЭлементаМеню.Представление, "Декорация") > 0 Тогда
			
			СозданиеЭлементовДинамическогоМенюЭлементДекорация(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, НоваяГруппа, ИндексДанных);
			
		КонецЕсли;
				
		ИндексДанных = ИндексДанных + 1;
		
	КонецЦикла;

КонецПроцедуры

// Процедура - Создание элементов динамического меню удалить элементы меню.
//
// Параметры:
//  ПредПараметрыМеню	 - 	 -
//  Форма				 - 	 -
//
Процедура СозданиеЭлементовДинамическогоМенюУдалитьЭлементыМеню(ПредПараметрыМеню, Форма)
	
	// Удаление старых элементов меню.
	Если ПредПараметрыМеню <> Неопределено
		И ЗначениеЗаполнено(ПредПараметрыМеню.ПривязанныеДанные) Тогда
		
		Для Каждого ЭлементМ Из ПредПараметрыМеню.ПривязанныеДанные Цикл
			
			Форма.Команды.Удалить(Форма.Команды[ЭлементМ.ПривязанноеЗначение]);
			Форма.Элементы.Удалить(Форма.Элементы[ЭлементМ.Группа]);
			
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

// Функция - Создать группу элемента в динамическом меню.
//
// Параметры:
//  ГруппаМеню			 - 	 -
//  ИмяМеню				 - 	 -
//  ИндексДанных		 - 	 -
//  ОписаниеЭлементаМеню - 	 -
//  ПараметрыМеню		 - 	 -
//  ТипМеню				 - 	 -
//  Форма				 - 	 -
//  ШиринаЭлемента		 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СозданиеЭлементовДинамическогоМенюОсновнаяГруппаЭлемента(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, ГруппаМеню, ИндексДанных)
		
	// Создание группы элемента меню.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента"        , ГруппаМеню);
	ПараметрыГруппы.Вставить("Группировка"           , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
	ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Половинный);
	ПараметрыГруппы.Вставить("ШиринаГруппы"          , ПараметрыМеню.ШиринаГруппыЭлемента);
		
	Если ОписаниеЭлементаМеню.Свойство("Группа")
		И ЗначениеЗаполнено(ОписаниеЭлементаМеню.Группа) Тогда
		
		ПараметрыГруппы.Вставить("ИмяЭлемента", ОписаниеЭлементаМеню.Группа);
		
	ИначеЕсли Не ОписаниеЭлементаМеню.Свойство("Группа") Тогда
		
		Если ПараметрыМеню.ТипМеню = "Отбор" Тогда
			ПредставлениеГруппы = ПараметрыМеню.ИмяМеню;
		ИначеЕсли ОписаниеЭлементаМеню.Свойство("Код") Тогда
			ПредставлениеГруппы = "Переключатель" + ОписаниеЭлементаМеню.Код;
		Иначе
			ПредставлениеГруппы = ОписаниеЭлементаМеню.Представление;
		КонецЕсли;
		
		ПредставлениеГруппы = НормализоватьСтрокуПредставления(Строка(ПредставлениеГруппы));
		
		ПараметрыМеню.ПривязанныеДанные[ИндексДанных].Вставить("Группа", "Группа_ME_" + ПредставлениеГруппы);
		
		ПараметрыГруппы.Вставить("ИмяЭлемента", ПараметрыМеню.ПривязанныеДанные[ИндексДанных].Группа);
		
	КонецЕсли;
	
	НоваяГруппа = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);

	Возврат НоваяГруппа;

КонецФункции

// Процедура - Создать элементы динамического меню отбор.
//
// Параметры:
//  Форма				 - 	 -
//  ОписаниеЭлементаМеню - 	 -
//  ГруппаРодитель		 - 	 -
//  ИндексДанных		 - 	 -
//  НоваяГруппа			 - 	 -
//  ПараметрыМеню		 - 	 -
//
// Возвращаемое значение:
//   -
//
Процедура СозданиеЭлементовДинамическогоМенюФормированиеМенюОтбора(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, ПредПараметрыМеню, НоваяГруппа, ИндексДанных)
	
	ПредМассивЗначений    = ?(ПредПараметрыМеню <> Неопределено, ПредПараметрыМеню.ПривязанныеДанные[ИндексДанных].МассивЗначений, Неопределено);
	ПересоздатьЭлемОтбора = ?(ОписаниеЭлементаМеню.Свойство("ПересоздатьЭлемОтбора"), ОписаниеЭлементаМеню.ПересоздатьЭлемОтбора, Истина);
	
	// Добавление параметра видимости отборов/реквизита данных/реквизита данных состояния отборов.
	ФормированиеМенюОтбораДобавлениеРеквизитовДанных(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, ИндексДанных);

    ОсновнаяГруппаПодчМеню = Неопределено;
    КнопкаЗначение         = Неопределено;
	
	// Создание группы подчиненного меню/элементов выбранных значений.
	ФормированиеМенюОтбораСозданиеРодительскихЭлементов(
	Форма,
	ОписаниеЭлементаМеню,
	НоваяГруппа,
	ПараметрыМеню,
	ОсновнаяГруппаПодчМеню,
	КнопкаЗначение);
			
	// Удаление старых элементов отбора.
	Если ПредМассивЗначений <> Неопределено
		И ПересоздатьЭлемОтбора Тогда
		
		Для Каждого ЭлементМ Из ПредМассивЗначений Цикл

			ПривязанноеЗначение = ЭлементМ.ПривязанноеЗначение;
			
			Форма.Команды.Удалить(Форма.Команды[ПривязанноеЗначение]);
			Форма.Элементы.Удалить(Форма.Элементы[СтрЗаменить(ПривязанноеЗначение, "КомандаОтбор_ME_", "ГруппаОтбор_ME_")]);
			
		КонецЦикла;
		
	КонецЕсли;
			
	// Создание элементов подчиненного меню отбора.
	Если ЗначениеЗаполнено(ОписаниеЭлементаМеню.МассивЗначений) Тогда
		
		ФормированиеМенюОтбораСозданиеЭлементовОтбора(
		Форма,
		ОписаниеЭлементаМеню,
		ПараметрыМеню,
		ПредМассивЗначений,
		ОсновнаяГруппаПодчМеню,
		КнопкаЗначение);
		
	ИначеЕсли ОписаниеЭлементаМеню.Свойство("ПолеДопВвода")
		И ОписаниеЭлементаМеню.ПолеДопВвода Тогда
		
		// Создание кнопок Применить/Скрыть, дополнительного поля ввода.
		ФормированиеМенюОтбораСозданиеЭлементовОтбораДополнительныеЭлементыУправления(
		Форма,
		ОписаниеЭлементаМеню,
		ПараметрыМеню,
		Неопределено,
		ОсновнаяГруппаПодчМеню);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Формирование меню отбора добавление реквизитов данных.
//
// Параметры:
//  Форма				 - 	 -
//  ОписаниеЭлементаМеню - 	 -
//  ПараметрыМеню		 - 	 -
//  ИндексДанных		 - 	 -
//
Процедура ФормированиеМенюОтбораДобавлениеРеквизитовДанных(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, ИндексДанных)
	
	// Добавление параметра видимости отборов.	
	Если Не (ОписаниеЭлементаМеню.Свойство("ОткрытьМенюОтбора")
		И ОписаниеЭлементаМеню.ОткрытьМенюОтбора) Тогда
		
		ПараметрыМеню.ПривязанныеДанные[ИндексДанных].Вставить("Открыт", Ложь);
	Иначе
		ПараметрыМеню.ПривязанныеДанные[ИндексДанных].Вставить("Открыт"           , Истина);
		ПараметрыМеню.ПривязанныеДанные[ИндексДанных].Вставить("ОткрытьМенюОтбора", Ложь);
		
	КонецЕсли;
	
	// Реквизит данных.
	ИмяРеквизитаДанных = "ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню;
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, ИмяРеквизитаДанных) Тогда
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяРеквизитаДанных, Новый ОписаниеТипов("СписокЗначений")));
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
		
	КонецЕсли;
	
	// Реквизит данных состояния отборов.
	РеквизитДанныхСостоянияОтборов = "СостояниеОтборов";
	
	// Скрытие открытых отборов.
	СкрытиеОткрытыхОтборовДинамическогоМеню(ПараметрыМеню, Форма);
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, РеквизитДанныхСостоянияОтборов) Тогда
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить(Новый РеквизитФормы(РеквизитДанныхСостоянияОтборов, Новый ОписаниеТипов("ТаблицаЗначений")));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("ИмяМеню", Новый ОписаниеТипов("Строка"), РеквизитДанныхСостоянияОтборов));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Элемент", Новый ОписаниеТипов("Строка"), РеквизитДанныхСостоянияОтборов));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Выбор"  , Новый ОписаниеТипов("Булево"), РеквизитДанныхСостоянияОтборов));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Открыт" , Новый ОписаниеТипов("Булево"), РеквизитДанныхСостоянияОтборов));
		
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
	Иначе
		Форма[РеквизитДанныхСостоянияОтборов].Очистить();
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Формирование меню отбора формирование родительских элементов.
//
// Параметры:
//  Форма					 - 	 -
//  ОписаниеЭлементаМеню	 - 	 -
//  ГруппаРодитель			 - 	 -
//  НоваяГруппа				 - 	 -
//  ИмяМеню					 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  РазмерШрифта			 - 	 -
//  ОсновнаяГруппаПодчМеню	 - 	 -
//  ГруппаЗначениеОтбора	 - 	 -
//  КнопкаЗначение			 - 	 -
//
Процедура ФормированиеМенюОтбораСозданиеРодительскихЭлементов(
	Форма,
	ОписаниеЭлементаМеню,
	НоваяГруппа,
	ПараметрыМеню,
	ОсновнаяГруппаПодчМеню,
	КнопкаЗначение)
	
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	ЦветТекстаВыбранного  = ПараметрыМеню.ЦветТекстаВыбранного;
	ЦветФонаВыбранного    = ПараметрыМеню.ЦветФонаВыбранного;
	
	// Создание основной группы подчиненного меню.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента"              , НоваяГруппа.Родитель);
	ПараметрыГруппы.Вставить("ИмяЭлемента"                 , "Группа_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню);
	ПараметрыГруппы.Вставить("Группировка"                 , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал"      , ИнтервалМеждуЭлементамиФормы.Половинный);
	ПараметрыГруппы.Вставить("ВертикальныйИнтервал"        , ИнтервалМеждуЭлементамиФормы.Половинный);
	ПараметрыГруппы.Вставить("Заголовок"                   , " ");
	ПараметрыГруппы.Вставить("ОтображатьЗаголовок"         , Истина);
	ПараметрыГруппы.Вставить("РазмерШрифтаЗаголовка"       , 1);
	ПараметрыГруппы.Вставить("ЦветТекстаЗаголовка"         , ЦветФонаВыбранного);
	ПараметрыГруппы.Вставить("Поведение"                   , ПоведениеОбычнойГруппы.Всплывающая);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Низ);
	ПараметрыГруппы.Вставить("ЭлементВставки"              , НоваяГруппа);
		
	ОсновнаяГруппаПодчМеню = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	// Создание группы выбранных значений.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", НоваяГруппа);
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Значение_ME_" + ИмяМеню);
	ПараметрыГруппы.Вставить("Видимость"     , Ложь);
	
	ГруппаЗначениеОтбора = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	ИмяЭлемента = "Значение_ME_" + ИмяМеню + "_Тип_Переключатель";
	
	ПараметрыКоманды = Новый Структура("ИмяЭлемента, ИмяОбработчикаНажатия", ИмяЭлемента, ИмяОбработчикаНажатия);
	НоваяКоманда = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("ИмяЭлемента"   , ИмяЭлемента);
	ПараметрыКнопки.Вставить("КомандаКнопки" , НоваяКоманда);
	ПараметрыКнопки.Вставить("РазмерШрифта"  , РазмерШрифта);
	ПараметрыКнопки.Вставить("ГруппаЭлемента", ГруппаЗначениеОтбора);
	
	КнопкаЗначение = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	
	// Создание декорации выбранных значений.
	ПараметрыДекорации = Новый Структура;
	ПараметрыДекорации.Вставить("ГруппаЭлемента"               , ГруппаЗначениеОтбора);
	ПараметрыДекорации.Вставить("ИмяЭлемента"                  , "ДекорацияЗначение_ME_" + ИмяМеню);
	ПараметрыДекорации.Вставить("РазмерШрифта"                 , РазмерШрифта);
	ПараметрыДекорации.Вставить("ЦветТекста"                   , ЦветТекстаВыбранного);
	ПараметрыДекорации.Вставить("ВертикальноеПоложениеЭлемента", ВертикальноеПоложениеЭлемента.Низ);
	
	// КнопкаЗначение = СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
	
	// Создание декорации удаления выбранных значений.
	ПараметрыДекорации.Вставить("ИмяЭлемента"                    , "ДекорацияУдалитьЗначение_ME_" + ИмяМеню);
	ПараметрыДекорации.Вставить("Картинка"                       , БиблиотекаКартинок.Крестик);
	ПараметрыДекорации.Вставить("ОбработчикНажатия"              , ИмяОбработчикаНажатия);
	ПараметрыДекорации.Вставить("ГоризонтальноеПоложениеЭлемента", ГоризонтальноеПоложениеЭлемента.Право);
		
	ДекорацияОтборУдалить = СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
	
КонецПроцедуры

// Процедура - Формирование меню отбора создание элементов отбора.
//
// Параметры:
//  Форма					 - 	 -
//  ОписаниеЭлементаМеню	 - 	 -
//  ИмяМеню					 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  ОсновнаяГруппаПодчМеню	 - 	 -
//  КнопкаЗначение			 - 	 -
//  ОгрКолЭлементов			 - 	 -
//  ПредМассивЗначений		 - 	 -
//  РазмерШрифта			 - 	 -
//  ЦветФона				 - 	 -
//
Процедура ФормированиеМенюОтбораСозданиеЭлементовОтбора(
	Форма,
	ОписаниеЭлементаМеню,
	ПараметрыМеню,
	ПредМассивЗначений,
	ОсновнаяГруппаПодчМеню,
	КнопкаЗначение)
	
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	ОгрКолЭлементов       = ПараметрыМеню.ОгрКолЭлементов;
	ТипДанныхПоУмолчанию  = ПараметрыМеню.ТипДанныхПоУмолчанию;
	ВыборПоУмолчанию      = ПараметрыМеню.ВыборПоУмолчанию;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;	
	ЦветФона              = ПараметрыМеню.ЦветФона;
	ЦветФонаВыбранного    = ПараметрыМеню.ЦветФонаВыбранного;
		
	ИндексГруппы        = 0;
	ИндексЭлемента      = 0;
	КоличествоВыбранных = 0;
	
	Для Каждого ЭлементМ Из ОписаниеЭлементаМеню.МассивЗначений Цикл
				
		// Переход на новую строку, если в группе больше заданного числа элементов.
		Если Ост(ИндексЭлемента, ОгрКолЭлементов) = 0 Тогда
			
			// Создание подгруппы подчиненного меню.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ГруппаЭлемента", ОсновнаяГруппаПодчМеню);
			ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Группа_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню + "_ID_" + ИндексГруппы);
			ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
			
			ГруппаПодчМеню = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
			ИндексГруппы   = ИндексГруппы + 1;
			
		КонецЕсли;
		
		ИндексЭлемента = ИндексЭлемента + 1;
		
		ПредставлениеЭлемента = НормализоватьСтрокуПредставления(Строка(?(ЭлементМ.Свойство("Код"), ЭлементМ.Код, ЭлементМ.Значение)));
		ИмяЭлемента           = "Отбор_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню + "_Тип_" + ПредставлениеЭлемента;
		
		// Создание элемента отбора.
		ПараметрыЭлемента = Новый Структура;
		ПараметрыЭлемента.Вставить("ГруппаЭлемента"        , ГруппаПодчМеню);
		ПараметрыЭлемента.Вставить("ИмяЭлемента"           , ИмяЭлемента);
		ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия" , ИмяОбработчикаНажатия);
		ПараметрыЭлемента.Вставить("Заголовок"             , ЭлементМ.Представление);
		ПараметрыЭлемента.Вставить("Подсказка"             , ЭлементМ.Представление);
		ПараметрыЭлемента.Вставить("Видимость"             , ?(ЭлементМ.Свойство("Видимость"), ЭлементМ.Видимость, Истина));
		ПараметрыЭлемента.Вставить("ЦветФона"              , ЦветФона);
		ПараметрыЭлемента.Вставить("РазмерШрифта"          , РазмерШрифта - 1);
		ПараметрыЭлемента.Вставить("Картинка"              , БиблиотекаКартинок.Крестик);
		ПараметрыЭлемента.Вставить("КнопкаОтображение"     , ОтображениеКнопки.Текст);
		ПараметрыЭлемента.Вставить("Группировка"           , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
		ПараметрыЭлемента.Вставить("ГоризонтальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Половинный);
				
		КомандаОтбор = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
		
		// Привязка элемента к привязанным данным параметров меню.
		ЭлементМ.Вставить("ПривязанноеЗначение", КомандаОтбор.Имя);
		
		// Создание декорации представления элемента отбора.
		Если ЭлементМ.Свойство("ДекорацияПредставление")
			И ЗначениеЗаполнено(ЭлементМ.ДекорацияПредставление) Тогда
			
			ПараметрыЭлемента = Новый Структура;
			ПараметрыЭлемента.Вставить("ГруппаЭлемента"    , Форма.Элементы["Группа" + ИмяЭлемента]);
			ПараметрыЭлемента.Вставить("ИмяЭлемента"       , "ДекорацияПредставление" + ИмяЭлемента);
			ПараметрыЭлемента.Вставить("Картинка"          , ЭлементМ.ДекорацияПредставление);
			ПараметрыЭлемента.Вставить("ПереместитьВНачало", Истина);
			
			СоздатьЭлементДекорация(Форма, ПараметрыЭлемента);
						
		КонецЕсли;
		
		// Отображение значения выбора в меню отбора.
		Если Не ЗначениеЗаполнено(ВыборПоУмолчанию)
			И ЗначениеЗаполнено(ПредМассивЗначений)
			И ЭлементМ.Выбор = Ложь Тогда
			
			НайденноеЗначение = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ПредМассивЗначений, "Значение", ЭлементМ.Значение);
			Если НайденноеЗначение <> Неопределено Тогда
				ЭлементМ.Выбор = НайденноеЗначение.Выбор;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЭлементМ.Выбор = Истина
			И Не ЭлементМ.Свойство("ОтборРодитель") Тогда
			
			Если КоличествоВыбранных = 0 Тогда
				КнопкаЗначение.Заголовок = ЭлементМ.Представление;
			КонецЕсли;
			
			КоличествоВыбранных = КоличествоВыбранных + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Если КоличествоВыбранных > 0
		И Не ОписаниеЭлементаМеню.Открыт Тогда
		
		Если КоличествоВыбранных > 1 Тогда
			КнопкаЗначение.Заголовок = "(" + КоличествоВыбранных + ")";
		КонецЕсли;
		
		КнопкаЗначение.Родитель.Видимость = Истина;
		ОписаниеЭлементаМеню.Выбор 		  = Истина;
	Иначе
		КнопкаЗначение.Родитель.Видимость = Ложь;
	КонецЕсли;
	
	Если ОписаниеЭлементаМеню.Открыт Тогда
		
		Для Каждого ЭлементМ Из ОписаниеЭлементаМеню.МассивЗначений Цикл
			
			ЭлементОтбор = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение,"Команда","Кнопка")];
			
			Если ЭлементМ.Выбор = Истина Тогда
				
				ЭлементОтбор.Родитель.ЦветФона = ЦветФонаВыбранного;
				ЭлементОтбор.Отображение       = ОтображениеКнопки.КартинкаИТекст;
			Иначе
				ЭлементОтбор.Родитель.ЦветФона = ЦветФона;
				ЭлементОтбор.Отображение       = ОтображениеКнопки.Текст;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Создание кнопок Применить/Скрыть, дополнительного поля ввода.
	ФормированиеМенюОтбораСозданиеЭлементовОтбораДополнительныеЭлементыУправления(
	Форма,
	ОписаниеЭлементаМеню,
	ПараметрыМеню,
	ГруппаПодчМеню,
	ОсновнаяГруппаПодчМеню);
	
КонецПроцедуры

// Процедура - Формирование меню отбора создание элементов отбора дополнительные элементы управления.
//
// Параметры:
//  ГруппаПодчМеню			 - 	 -
//  ИмяМеню					 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  ОписаниеЭлементаМеню	 - 	 -
//  ОсновнаяГруппаПодчМеню	 - 	 -
//  РазмерШрифта			 - 	 -
//  ТипДанныхПоУмолчанию	 - 	 -
//  Форма					 - 	 -
//
Процедура ФормированиеМенюОтбораСозданиеЭлементовОтбораДополнительныеЭлементыУправления(
	Форма,
	ОписаниеЭлементаМеню,
	ПараметрыМеню,
	ГруппаПодчМеню,
	ОсновнаяГруппаПодчМеню)
	
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	ТипДанныхПоУмолчанию  = ПараметрыМеню.ТипДанныхПоУмолчанию;
	ЦветФона              = ПараметрыМеню.ЦветФона;
	
	// Создание подгруппы подчиненного меню.
	Если ГруппаПодчМеню = Неопределено Тогда
		
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ГруппаЭлемента", ОсновнаяГруппаПодчМеню);
		ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Группа_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню + "_ID_0");
		ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
		
		ГруппаПодчМеню = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
		
	КонецЕсли;
	
	// Создание поля дополнительного ввода.
	Если ОписаниеЭлементаМеню.Свойство("ПолеДопВвода")
		И ОписаниеЭлементаМеню.ПолеДопВвода = Истина Тогда
		
		ИмяЭлемента = "ПолеОтбор_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню + "_Тип_ПолеДопВвода";
		
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ГруппаЭлемента"   , ГруппаПодчМеню);
		ПараметрыГруппы.Вставить("ИмяЭлемента"      , ИмяЭлемента);
		ПараметрыГруппы.Вставить("ЦветФона"         , ЦветФона);
		ПараметрыГруппы.Вставить("ПереместитьВКонец", Истина);
		
		ГруппаПолеДопВвода = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
		ПараметрыПоля = Новый Структура;
		ПараметрыПоля.Вставить("ГруппаЭлемента"        , ГруппаПолеДопВвода);
		ПараметрыПоля.Вставить("ИмяЭлемента"           , ИмяЭлемента);
		ПараметрыПоля.Вставить("ИмяРеквизитаДанных"    , "ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню + "_Тип_ПолеДопВвода");
		ПараметрыПоля.Вставить("ТипДанныхПоУмолчанию"  , ТипДанныхПоУмолчанию);
		ПараметрыПоля.Вставить("ОбработчикПриИзменении", ИмяОбработчикаНажатия);
		ПараметрыПоля.Вставить("ПодсказкаВвода"        , НСтр("ru = 'Добавить'; en = 'Add'"));
		ПараметрыПоля.Вставить("РазмерШрифта"          , 9);
		ПараметрыПоля.Вставить("ШиринаЭлемента"        , 20);
					
		ПолеДопВвода = СоздатьЭлементПоле(Форма, ПараметрыПоля);
		
		// Добавление параметров выбора.
		Если ОписаниеЭлементаМеню.Свойство("ПараметрыВыбора") Тогда
			
			ПараметрыВыбора = Новый Массив;
			
			Для Каждого ПараметрВыбора Из ОписаниеЭлементаМеню.ПараметрыВыбора Цикл
				
				ИмяПараметраВыбора      = "Отбор." + ПараметрВыбора.Ключ;
				ЗначениеПараметраВыбора = ?(ТипЗнч(ПараметрВыбора.Значение) = Тип("Массив"), Новый ФиксированныйМассив(ПараметрВыбора.Значение), ПараметрВыбора.Значение);
				
				ПараметрыВыбора.Добавить(Новый ПараметрВыбора(ИмяПараметраВыбора, ЗначениеПараметраВыбора));		
				
			КонецЦикла;	
			
			ПолеДопВвода.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
			
		КонецЕсли;	
		
		// Добавление формы выбора.
		Если ОписаниеЭлементаМеню.Свойство("ФормаВыбора") Тогда
			
			ВидОбъектаМетаданных = ОбщегоНазначения.ВидОбъектаПоТипу(ТипДанныхПоУмолчанию);
			ОбъектМетаданных     = Метаданные.НайтиПоТипу(ТипДанныхПоУмолчанию);
			
			ПолеДопВвода.ФормаВыбора = ВидОбъектаМетаданных + "." + ОбъектМетаданных + "." + "Форма." + ОписаниеЭлементаМеню.ФормаВыбора;	
			
		КонецЕсли;	
		
	КонецЕсли;
	
	// Создание кнопки Применить отбор.
	ПараметрыЭлемента = Новый Структура;
	
	ПараметрыЭлемента.Вставить("ГруппаЭлемента"       , ГруппаПодчМеню);
	ПараметрыЭлемента.Вставить("ИмяЭлемента"          , "Применить_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню);
	ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПараметрыЭлемента.Вставить("Заголовок"            , НСтр("ru = 'Применить'; en = 'Apply'"));
	ПараметрыЭлемента.Вставить("Видимость"            , Ложь);
	ПараметрыЭлемента.Вставить("ЦветФона"             , Новый Цвет(166, 202, 240));
	ПараметрыЭлемента.Вставить("РазмерШрифта"         , РазмерШрифта);
	ПараметрыЭлемента.Вставить("ШиринаЭлемента"       , 9);
	ПараметрыЭлемента.Вставить("ПереместитьВКонец"    , Истина);
	
	КомандаПрименить = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
	
	// Создание кнопки Скрыть отбор.
	ПараметрыЭлемента.Вставить("ГруппаЭлемента", ГруппаПодчМеню);
	ПараметрыЭлемента.Вставить("ИмяЭлемента"   , "Скрыть_ME_" + ОписаниеЭлементаМеню.ИмяПодчиненногоМеню);
	ПараметрыЭлемента.Вставить("Заголовок"     , НСтр("ru = 'Скрыть'; en = 'Skip'"));
	ПараметрыЭлемента.Вставить("ШиринаЭлемента", 6);
	ПараметрыЭлемента.Вставить("Видимость"     , Истина);
	
	КомандаСкрыть = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
	   
	// Отображение отбора, скрытие переключателя.
	Если ОписаниеЭлементаМеню.Свойство("ОтборОткрыт")
		И ЗначениеЗаполнено(ОписаниеЭлементаМеню.ОтборОткрыт) Тогда
		
		ОсновнаяГруппаПодчМеню.Видимость = Истина;
		Форма.Элементы["Группа_ME_" + ИмяМеню].Родитель.Видимость = Ложь;
		Форма.Элементы[СтрЗаменить(КомандаСкрыть.Имя, "Команда", "Группа")].Видимость = Ложь;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Создание элементов в динамическом меню элемент переключатель.
//
// Параметры:
//  ОписаниеЭлементаМеню - 	 -
//  ПараметрыМеню		 - 	 -
//  Форма				 - 	 -
//  НоваяГруппа			 - 	 -
//  ГруппаЗначениеОтбора - 	 -
//  ИндексДанных		 - 	 -
//
Процедура СозданиеЭлементовДинамическогоМенюЭлементПереключатель(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, НоваяГруппа, ИндексДанных)
	
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	ШиринаЭлемента        = ПараметрыМеню.ШиринаЭлемента;
	ТипМеню               = ПараметрыМеню.ТипМеню;
	
 	ПредставлениеЭлемента = НормализоватьСтрокуПредставления(Строка(?(ОписаниеЭлементаМеню.Свойство("Код"), "Переключатель" + ОписаниеЭлементаМеню.Код, ОписаниеЭлементаМеню.Представление)));
	ИмяЭлемента           = "Переключатель_ME_" + ИмяМеню + "_Тип_" + ПредставлениеЭлемента + "_ID_" + ИндексДанных;
	
	// Создание команды элемента меню.
	ПараметрыКоманды = Новый Структура("ИмяЭлемента, ИмяОбработчикаНажатия", ИмяЭлемента, ИмяОбработчикаНажатия);
	
	Если ОписаниеЭлементаМеню.Свойство("Подсказка") Тогда
		ПараметрыКоманды.Вставить("Подсказка", ОписаниеЭлементаМеню.Подсказка);
	КонецЕсли;
	
	НоваяКоманда = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	// Создание кнопки элемента меню.
	ЗаголовокКнопки = ?(ОписаниеЭлементаМеню.Свойство("Заголовок") И ЗначениеЗаполнено(ОписаниеЭлементаМеню.Заголовок),
		                ОписаниеЭлементаМеню.Заголовок,
				        ?(ЗначениеЗаполнено(ОписаниеЭлементаМеню.Значение), ОписаниеЭлементаМеню.Значение, ""));
						
	ЭлементВставки  = ?(ТипМеню = "Отбор" И НоваяГруппа.ПодчиненныеЭлементы.Количество() > 0,
						НоваяГруппа.ПодчиненныеЭлементы[0],
						Неопределено);
						
	ВидимостьПереключателя = Истина;	
	Если ТипМеню = "Отбор" И ЗначениеЗаполнено(ОписаниеЭлементаМеню.МассивЗначений) Тогда 
		
		КоличествоВыбранных = 0;
		Для Каждого ЭлементМ Из ОписаниеЭлементаМеню.МассивЗначений Цикл 
			Если ЭлементМ.Выбор Тогда 
				КоличествоВыбранных = КоличествоВыбранных + 1;
			КонецЕсли;
		КонецЦикла;
		
		ВидимостьПереключателя = КоличествоВыбранных <> 1; 					
	КонецЕсли;	
					
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("ИмяЭлемента"   , ИмяЭлемента);
	ПараметрыКнопки.Вставить("Заголовок"     , ЗаголовокКнопки);
	ПараметрыКнопки.Вставить("КомандаКнопки" , НоваяКоманда);
	ПараметрыКнопки.Вставить("Видимость"     , ВидимостьПереключателя);
	ПараметрыКнопки.Вставить("РазмерШрифта"  , РазмерШрифта);
	ПараметрыКнопки.Вставить("ШиринаЭлемента", ?(ОписаниеЭлементаМеню.Свойство("ШиринаЭлемента"), ОписаниеЭлементаМеню.ШиринаЭлемента, ШиринаЭлемента));
	ПараметрыКнопки.Вставить("ГруппаЭлемента", НоваяГруппа);
	ПараметрыКнопки.Вставить("ЭлементВставки", ЭлементВставки);
	
	Если ОписаниеЭлементаМеню.Свойство("Доступность") Тогда
		ПараметрыКнопки.Вставить("Доступность", ОписаниеЭлементаМеню.Доступность);
	КонецЕсли;
	
	Если ОписаниеЭлементаМеню.Свойство("ШрифтЗачеркнутый") Тогда
		ПараметрыКнопки.Вставить("ШрифтЗачеркнутый", ОписаниеЭлементаМеню.ШрифтЗачеркнутый);
	КонецЕсли;
	
	НоваяКнопка = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	
	// Если этот элемент имеет доп параметр в заголовке.
	Если ОписаниеЭлементаМеню.Свойство("ДопПараметр")
		И ЗначениеЗаполнено(ОписаниеЭлементаМеню.ДопПараметр) Тогда
		
		ИндексДопПараметра = 0;
		
		НоваяГруппа.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
		НоваяГруппа.Группировка            = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		
		ПараметрыЭлемента = Новый Структура;
		ПараметрыЭлемента.Вставить("ГруппаМеню"  , НоваяГруппа);
		ПараметрыЭлемента.Вставить("РазмерШрифта", РазмерШрифта);
		ПараметрыЭлемента.Вставить("ИмяМеню"     , ИмяМеню);
		
		Для Каждого ЭлементМ Из ОписаниеЭлементаМеню.ДопПараметр Цикл
			
			ПараметрыЭлемента.Вставить("ДопПараметр", ЭлементМ);
			ПараметрыЭлемента.Вставить("Индекс"     , ИндексДопПараметра);
			
			СозданиеЭлементовДинамическогоМенюДопПараметрЭлемента(Форма, ПараметрыЭлемента);
			
			ИндексДопПараметра = ИндексДопПараметра + 1;
		КонецЦикла;
		
	КонецЕсли;
	
	ОписаниеЭлементаМеню.ИмяЭлемента = НоваяКнопка.Имя;
	ОписаниеЭлементаМеню.Вставить("ПривязанноеЗначение", НоваяКоманда.Имя);
	
	// Отображение элементов.
	Если ОписаниеЭлементаМеню.Выбор Тогда
		
		НоваяКнопка.ЦветТекста = ПараметрыМеню.ЦветТекстаВыбранного;
		НоваяГруппа.ЦветФона   = ?(ОписаниеЭлементаМеню.Свойство("ЦветГруппы"), ОписаниеЭлементаМеню.ЦветГруппы, ПараметрыМеню.ЦветФонаВыбранного);
	Иначе
		НоваяКнопка.ЦветТекста = ?(ОписаниеЭлементаМеню.Свойство("ЦветГруппы") И ОписаниеЭлементаМеню.ЦветГруппы = Новый Цвет(0, 112, 210), Новый Цвет(255, 255, 255), ПараметрыМеню.ЦветТекста);
		НоваяГруппа.ЦветФона   = ?(ОписаниеЭлементаМеню.Свойство("ЦветГруппы"), ОписаниеЭлементаМеню.ЦветГруппы, ПараметрыМеню.ЦветФона);
		
	КонецЕсли;

КонецПроцедуры


// Процедура - Создать элементы в динамическом меню доп параметр элемента.
//
// Параметры:
//  НоваяГруппа			 - 	 -
//  ОписаниеЭлементаМеню - 	 -
//  РазмерШрифта		 - 	 -
//  Форма				 - 	 -
//  ЦветТекстаВыбранного - 	 -
//
Процедура СозданиеЭлементовДинамическогоМенюДопПараметрЭлемента(Форма, ПараметрыЭлемента)
	
	ДопПараметр  = ПараметрыЭлемента.ДопПараметр;

	ПараметрыДекорации = Новый Структура("ГруппаЭлемента, ИмяЭлемента, РазмерШрифта",
	ПараметрыЭлемента.ГруппаМеню,
	"Декорация" + ?(ДопПараметр.Свойство("Наименование"), ДопПараметр.Наименование + "_ME_", "_ME_") + ПараметрыЭлемента.ИмяМеню + СтрЗаменить(ПараметрыЭлемента.ГруппаМеню.Имя, "Группа_ME_Переключатель", "_") + "_ДопПараметр_" + ПараметрыЭлемента.Индекс,
	ПараметрыЭлемента.РазмерШрифта);
	
	Если ДопПараметр.Свойство("Картинка") Тогда
		ПараметрыДекорации.Вставить("Картинка", ДопПараметр.Картинка);
	КонецЕсли;
	Если ДопПараметр.Свойство("ОбработчикНажатия") Тогда
		ПараметрыДекорации.Вставить("ОбработчикНажатия", ДопПараметр.ОбработчикНажатия);
	КонецЕсли;
	Если ДопПараметр.Свойство("ЦветЭлемента") Тогда
		ПараметрыДекорации.Вставить("ЦветФона", ДопПараметр.ЦветЭлемента);
	КонецЕсли;
	Если ДопПараметр.Свойство("ЦветТекста") Тогда
		ПараметрыДекорации.Вставить("ЦветТекста", ДопПараметр.ЦветТекста);
	КонецЕсли;
	Если ДопПараметр.Свойство("Значение") Тогда
		ПараметрыДекорации.Вставить("Заголовок", ДопПараметр.Значение);
	КонецЕсли;
	Если ДопПараметр.Свойство("Рамка") Тогда
		ПараметрыДекорации.Вставить("Рамка", ДопПараметр.Рамка);
	КонецЕсли;
	Если ДопПараметр.Свойство("Подсказка") Тогда
		ПараметрыДекорации.Вставить("Подсказка", ДопПараметр.Подсказка);
	КонецЕсли;
	
	ДекорацияДопПараметр = СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
	
КонецПроцедуры

// Процедура - Создание элементов в динамическом меню элемент список.
//
// Параметры:
//  ОписаниеЭлементаМеню - 	 -
//  ПараметрыМеню		 - 	 -
//  Форма				 - 	 -
//  НоваяГруппа			 - 	 -
//  ИндексДанных		 - 	 -
//
Процедура СозданиеЭлементовДинамическогоМенюЭлементСписок(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, НоваяГруппа, ИндексДанных)
		
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ТипДанныхПоУмолчанию  = ПараметрыМеню.ТипДанныхПоУмолчанию;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	
	// Реквизит данных.
	ИмяРеквизитаДанных = "ME_" + ИмяМеню;
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, ИмяРеквизитаДанных) Тогда
		
		МассивТипов      = Новый Массив;
		МассивРеквизитов = Новый Массив;
		
		МассивТипов.Добавить(ТипДанныхПоУмолчанию);
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяРеквизитаДанных , Новый ОписаниеТипов(МассивТипов)));
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
		
	КонецЕсли;
	
	ПредставлениеЭлемента = НормализоватьСтрокуПредставления(Строка(?(ОписаниеЭлементаМеню.Свойство("Код"), "ОткрытьСписок" + ОписаниеЭлементаМеню.Код, ОписаниеЭлементаМеню.Представление)));
	
	// Создание команды элемента списка.
	ПараметрыКоманды = Новый Структура("ИмяЭлемента, ИмяОбработчикаНажатия",
	"Открыть_ME_" + ИмяМеню + "_Тип_" + ПредставлениеЭлемента + "_ID_" + ИндексДанных,
	ИмяОбработчикаНажатия);
	
	НоваяКоманда = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	ЗаголовокКнопки = ?(ОписаниеЭлементаМеню.Свойство("Заголовок") И ЗначениеЗаполнено(ОписаниеЭлементаМеню.Заголовок),
						ОписаниеЭлементаМеню.Заголовок,
				        ?(ЗначениеЗаполнено(ОписаниеЭлементаМеню.Значение), ОписаниеЭлементаМеню.Значение, ""));
	
	// Создание кнопки элемента списка.
	ПараметрыКнопки = Новый Структура;
	
	ПараметрыКнопки.Вставить("Заголовок"        , ЗаголовокКнопки);
	ПараметрыКнопки.Вставить("ИмяЭлемента"      , "Открыть_ME_" + ИмяМеню + "_Тип_" + ПредставлениеЭлемента + "_ID_" + ИндексДанных);
	ПараметрыКнопки.Вставить("Картинка"         , БиблиотекаКартинок.СтрелкаВнизСплошная);
	ПараметрыКнопки.Вставить("КнопкаОтображение", ?(СтрНайти(ОписаниеЭлементаМеню.Представление, "ОткрытьСписокКнопка") > 0, ОтображениеКнопки.Картинка, ОтображениеКнопки.КартинкаИТекст));
	ПараметрыКнопки.Вставить("КомандаКнопки"    , НоваяКоманда);
	ПараметрыКнопки.Вставить("РазмерШрифта"     , РазмерШрифта);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"   , НоваяГруппа);
			
	НоваяКнопка = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	
	ОписаниеЭлементаМеню.ИмяЭлемента = НоваяКнопка.Имя;
	
	// Отображение элементов.
	Если ОписаниеЭлементаМеню.Выбор Тогда
		
		НоваяКнопка.Отображение = ОтображениеКнопки.КартинкаИТекст;
		НоваяКнопка.ЦветТекста  = ПараметрыМеню.ЦветТекстаВыбранного;
		НоваяГруппа.ЦветФона    = ?(ОписаниеЭлементаМеню.Свойство("ЦветГруппы"), ОписаниеЭлементаМеню.ЦветГруппы, ПараметрыМеню.ЦветФонаВыбранного);
	Иначе
		НоваяКнопка.Отображение = ОтображениеКнопки.Картинка;
		НоваяКнопка.ЦветТекста  = ПараметрыМеню.ЦветТекста;
		НоваяГруппа.ЦветФона    = ?(ОписаниеЭлементаМеню.Свойство("ЦветГруппы"), ОписаниеЭлементаМеню.ЦветГруппы, ПараметрыМеню.ЦветФона);
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Создание элементов в динамическом меню элемент список.
//
// Параметры:
//  ОписаниеЭлементаМеню - 	 -
//  ПараметрыМеню		 - 	 -
//  Форма				 - 	 -
//  НоваяГруппа			 - 	 -
//  ИндексДанных		 - 	 -
//
Процедура СозданиеЭлементовДинамическогоМенюЭлементДекорация(Форма, ОписаниеЭлементаМеню, ПараметрыМеню, НоваяГруппа, ИндексДанных)
		
	ИмяМеню = ПараметрыМеню.ИмяМеню;
	 	
	// Создание элемента декорация.
	ПараметрыДекорации = Новый Структура;
	
	ПараметрыДекорации.Вставить("ГруппаЭлемента", НоваяГруппа);
	ПараметрыДекорации.Вставить("ИмяЭлемента"   , "Декорация_ME_" + ИмяМеню + "_Тип_" + ОписаниеЭлементаМеню.Представление + "_ID_" + ИндексДанных);
	ПараметрыДекорации.Вставить("Заголовок"     , ОписаниеЭлементаМеню.Заголовок);
	ПараметрыДекорации.Вставить("РазмерШрифта"  , ?(ОписаниеЭлементаМеню.Свойство("РазмерШрифта"), ОписаниеЭлементаМеню.РазмерШрифта, ПараметрыМеню.РазмерШрифта));
	ПараметрыДекорации.Вставить("ШрифтЖирный"   , ?(ОписаниеЭлементаМеню.Свойство("ШрифтЖирный") , ОписаниеЭлементаМеню.ШрифтЖирный , Неопределено));
	ПараметрыДекорации.Вставить("Рамка"         , ?(ОписаниеЭлементаМеню.Свойство("Рамка")       , ОписаниеЭлементаМеню.Рамка       , Неопределено));
	ПараметрыДекорации.Вставить("ЦветФона"      , ПараметрыМеню.ЦветФонаВыбранного);
	ПараметрыДекорации.Вставить("ЦветТекста"    , ПараметрыМеню.ЦветТекстаВыбранного);
		
	НоваяДекорация = СоздатьЭлементДекорация(Форма, ПараметрыДекорации);

	ОписаниеЭлементаМеню.ИмяЭлемента = НоваяДекорация.Имя;
	
	// Отображение элемента.
	НоваяДекорация.ЦветТекста = ПараметрыМеню.ЦветТекстаВыбранного;
	НоваяГруппа.ЦветФона      = ?(ОписаниеЭлементаМеню.Свойство("ЦветГруппы"), ОписаниеЭлементаМеню.ЦветГруппы, ПараметрыМеню.ЦветФонаВыбранного);
	
КонецПроцедуры

