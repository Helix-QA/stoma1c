// Восстановить видимость колонок списка
Процедура ВостановитьВидимостьКолонок()
	
	Элементы.СписокПредмет.Видимость      = Истина;
    Элементы.СписокНаименование.Видимость = Истина;
	Элементы.СписокИсполнитель.Видимость  = Истина;
    Элементы.СписокАвтор.Видимость        = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеПроцедурыИФункции

&НаСервере
// Установить отбор для задач
Процедура УстановитьОтбор()
		
	ПараметрыОтбора = Новый Соответствие();
	ПараметрыОтбора.Вставить("ПоАвтору"		   , ПоАвтору);
	ПараметрыОтбора.Вставить("ЗадачаПредмет"   , Клиент);
	ПараметрыОтбора.Вставить("ПоИсполнителю"   , ПоИсполнителю);
	ПараметрыОтбора.Вставить("ПоказыватьЗадачи", ПоказыватьЗадачи);
	УстановитьОтборСписка(Список, ПараметрыОтбора);
	
КонецПроцедуры	

&НаСервереБезКонтекста
// Установить список отбора
Процедура УстановитьОтборСписка(Список, ПараметрыОтбора)
	
	Если ПараметрыОтбора["ПоАвтору"].Пустая() Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Список.Отбор, "ЗадачаАвтор");
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
			Список.Отбор, "ЗадачаАвтор", ПараметрыОтбора["ПоАвтору"],,,Истина);
	КонецЕсли;
	
	Если ПараметрыОтбора["ЗадачаПредмет"].Пустая() Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Список.Отбор, "ЗадачаПредмет");
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
			Список.Отбор, "ЗадачаПредмет", ПараметрыОтбора["ЗадачаПредмет"],,,Истина);
	КонецЕсли;
	
	Если  ПараметрыОтбора["ПоИсполнителю"] = Неопределено ИЛИ ПараметрыОтбора["ПоИсполнителю"].Пустая() Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Список.Отбор, "Исполнитель");
	Иначе	
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
			Список.Отбор, "Исполнитель", ВернутьМассивПользователейИГрупп(ПараметрыОтбора["ПоИсполнителю"]), ВидСравненияКомпоновкиДанных.ВСписке, , Истина);
	КонецЕсли;
		
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(Список.Отбор, "Выполнена");
	
	Если ПараметрыОтбора["ПоказыватьЗадачи"] <> 0 Тогда 
		
		Если ПараметрыОтбора["ПоказыватьЗадачи"] = 1 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
				Список.Отбор, "Выполнена", Истина,,,Истина);
		КонецЕсли;
		
		Если ПараметрыОтбора["ПоказыватьЗадачи"] = 2 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
				Список.Отбор, "Выполнена", Ложь,,,Истина);
		КонецЕсли;	
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВернутьМассивПользователейИГрупп(ЭлементСсылка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	&ЭлементСсылка КАК Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ГруппыПользователей.Ссылка
	|ИЗ
	|	Справочник.ГруппыПользователей КАК ГруппыПользователей
	|ГДЕ
	|	ГруппыПользователей.Состав.Пользователь = &ЭлементСсылка
	|	И ГруппыПользователей.ПометкаУдаления = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ГруппыПользователейСостав.Пользователь
	|ИЗ
	|	Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	|ГДЕ
	|	ГруппыПользователейСостав.Ссылка = &ЭлементСсылка
	|	И ГруппыПользователейСостав.Ссылка.ПометкаУдаления = ЛОЖЬ");
	
	Запрос.УстановитьПараметр("ЭлементСсылка", ЭлементСсылка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

&НаСервере
// Изменить статус задачи
Функция ПринятьКисполнениюОтменитьСервер(Задача,ПринятьКИсполнению)
	
	Если НЕ Задача.Выполнена Тогда
		
		ОбъектЗадачи = Задача.Ссылка.ПолучитьОбъект();
		ОбъектЗадачи.НапоминаниеИспользовать = ПринятьКИсполнению;
		ОбъектЗадачи.Записать();
		Возврат Истина;
		
	Иначе
		Возврат Ложь;
    КонецЕсли;

КонецФункции

#КонецОбласти
