&НаКлиенте
// Процедура, устанавливает видимость групп и элементов.
//
Процедура УстановитьВидмостьВсплывающейГруппы(Знач ВыбранноеЗначение)
	
	Если ВыбранноеЗначение = "Исполнитель" Тогда
		
		ВидимостьТаблицыДействий(ВыбранноеЗначение);
		
	ИначеЕсли ВыбранноеЗначение = "ДатаВыполнения"
		ИЛИ  ВыбранноеЗначение = "ДатаНазначено" Тогда 
		
		ЭтотОбъект.ЗначениеДействия = Дата(01,01,0001);
		ВидимостьТаблицыДействий(ВыбранноеЗначение);
		Элементы.ПодДействие.Видимость = Ложь;
		
	ИначеЕсли ВыбранноеЗначение = "ВидВзаимодействия"  Тогда
		
		ЭтотОбъект.ЗначениеДействия = ПредопределенноеЗначение("Перечисление.ВидыВзаимодействия.ПустаяСсылка");		
		ВидимостьТаблицыДействий(ВыбранноеЗначение);
		Элементы.ПодДействие.Видимость = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает видимость таблицы действий.
//
Процедура ВидимостьТаблицыДействий(Знач ВыбранноеЗначение)
	
	Если ВыбранноеЗначение = "Исполнитель" Тогда
		
		Элементы.ГруппаПодДействия.Видимость 	= Ложь;
		Элементы.ГруппаКнопокДействия.Видимость = Истина;
		Элементы.ТаблицаДействия.Видимость		= Истина;
		Элементы.ЗаглушкаДействие.Видимость 	= Истина;
		
	Иначе
		
		Элементы.ГруппаПодДействия.Видимость 	= Истина;
		Элементы.ГруппаКнопокДействия.Видимость = Ложь;
		Элементы.ТаблицаДействия.Видимость		= Ложь;
		Элементы.ЗаглушкаДействие.Видимость 	= Ложь;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура, ЗаполнитьПроцентомСтрокиТЗ.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ЗаполнитьПроцентомСтрокиТЗ()
	
	Элементы.ОстаточныйПроцент.Видимость = Ложь;
	
	КолвоЭлементов = ЭтотОбъект.ТаблицаДействия.Количество();
	
	Если КолвоЭлементов > 0 Тогда
		
		Процентов  		   = Цел(100/КолвоЭлементов);
		НедостающийПроцент = 100 - (Процентов*КолвоЭлементов);
		
		Для Каждого СтрокаТЗ Из ЭтотОбъект.ТаблицаДействия Цикл
			СтрокаТЗ.Пропорция = Процентов;
		КонецЦикла;
		
		Если НедостающийПроцент > 0 Тогда
			
			Элементы.ОстаточныйПроцент.Видимость  = Не Элементы.ОстаточныйПроцент.Видимость;
			ЭтотОбъект.ОстаточныйПроцентОтДеления = НедостающийПроцент;
			
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события команды на сервере "Применить".
//
Процедура ПрименитьНаСервере(ДопПараметры)
	
	Перем КоличествоВыделенныхСтрок;
	
	ДопПараметры.Свойство("КоличествоВыделенныхСтрок", КоличествоВыделенныхСтрок);
	
	УстановитьФокусЭлементаСервер();
	
	Если КоличествоВыделенныхСтрок > 1 Тогда
		
		ТЗДинамическогоСписка = Новый ТаблицаЗначений();
		ТЗДинамическогоСписка.Колонки.Добавить("Ссылка");
		
		ВыделенныеСтроки = Элементы.Список.ВыделенныеСтроки;
		Для Каждого ЭлементМассива Из ВыделенныеСтроки Цикл
			
			НоваяСтрока = ТЗДинамическогоСписка.Добавить();
			НоваяСтрока.Ссылка = ЭлементМассива;
			
		КонецЦикла;
		
	Иначе
		ТЗДинамическогоСписка = ПолучитьТаблицуЗначенийДинамическогоСписка();
	КонецЕсли;

	Если ЭтотОбъект.Действие = "Исполнитель" Тогда
		
		ИсполнителиРаспределитьВПропорции(ТЗДинамическогоСписка);
		
	ИначеЕсли ЭтотОбъект.Действие = "ДатаВыполнения" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				ОбъектЗадача 				  		= СтрокаТЗ.Ссылка.ПолучитьОбъект();
				ОбъектЗадача.ДатаИсполнения   		= ЭтотОбъект.ЗначениеДействия;
				ОбъектЗадача.Наименование	  		= ОбъектЗадача.ЗадачаТема + " (" + Строка(ОбъектЗадача.ВидВзаимодействияСправочник) + ")";
				ОбъектЗадача.ИсполнительФактический = ПараметрыСеанса.ТекущийСотрудник;
				ОбъектЗадача.Выполнена				= Истина;
				
				Если ОбъектЗадача.ПроверитьЗаполнение() Тогда
					
					Попытка
						ОбъектЗадача.Записать();	
					Исключение
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось записать задачу, по причине:';en='Succeeded writedown task for the reason:'") + ОписаниеОшибки());
					КонецПопытки;
					
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Выберите дату';en='Select date'"));
			Возврат;
			
		КонецЕсли;
		
	ИначеЕсли ЭтотОбъект.Действие = "ДатаНазначено" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				Если НЕ СтрокаТЗ.Ссылка.Выполнена Тогда
					
					ОбъектЗадача 				  		= СтрокаТЗ.Ссылка.ПолучитьОбъект();
					ОбъектЗадача.ЗадачаНазначеннаяДата	= ЭтотОбъект.ЗначениеДействия;
					
					Если ОбъектЗадача.ПроверитьЗаполнение() Тогда
						
						Попытка
							ОбъектЗадача.Записать();	
						Исключение
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось записать задачу, по причине:';en='Succeeded writedown task for the reason:'") + ОписаниеОшибки());
						КонецПопытки;
						
					КонецЕсли;

				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Выберите дату';en='Select date'"));
			Возврат;
		КонецЕсли;
		
	ИначеЕсли ЭтотОбъект.Действие = "ВидВзаимодействия" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				ОбъектЗадача 				   = СтрокаТЗ.Ссылка.ПолучитьОбъект();
				ОбъектЗадача.ВидВзаимодействия = ЭтотОбъект.ЗначениеДействия;
				ОбъектЗадача.Записать();
				
			КонецЦикла;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Выберите значение';en='Select value'"));
			Возврат;
		КонецЕсли;
		
	КонецЕсли;

	ОбновитьВсеОтборыФормы(Неопределено);
	ПолучитьПервоначальноеКоличествоЗадач();
			
КонецПроцедуры

&НаСервере
// Процедура, Распределяет мененеджеров в пропорции.
//
Процедура ИсполнителиРаспределитьВПропорции(Знач ТЗДинамическогоСписка)
	
	КоличествоСотрудников = ЭтотОбъект.ТаблицаДействия.Количество();
	
	Если КоличествоСотрудников <= 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ТипЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(3));
	
	ТЗСотрудников = ЭтотОбъект.ТаблицаДействия.Выгрузить();
	ТЗСотрудников.Колонки.Добавить("КоличествоЗадач"	, ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("ПроцентТекущий"		, ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("Дельта"				, ТипЧисло);
	
	ТЗКлиентовСотрудников = ТЗДинамическогоСписка.Скопировать(,"Ссылка");
	ТЗКлиентовСотрудников.Колонки.Добавить("Исполнитель");
	
	НачатьТранзакцию();
	
	Для Каждого СтрокаТЗ Из ТЗКлиентовСотрудников Цикл
		
		ПриоритетныйСотрудник = Неопределено;
		ПриоритетныйПроцент   = 0;
		
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			Если СтрокаСотрудников.Дельта >= ПриоритетныйПроцент Тогда
				
				ПриоритетныйСотрудник = СтрокаСотрудников.Сотрудник;
				ПриоритетныйПроцент   = СтрокаСотрудников.Дельта;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ОбъектКлиент = СтрокаТЗ.Ссылка.ПолучитьОбъект();
		ОбъектКлиент.Исполнитель = ПриоритетныйСотрудник;
		ОбъектКлиент.Записать();
		
		СтрокаТЗСотрудников = ТЗСотрудников.Найти(ПриоритетныйСотрудник);
		
		Если СтрокаТЗСотрудников <> Неопределено Тогда
			
			СтрокаТЗСотрудников.КоличествоЗадач = СтрокаТЗСотрудников.КоличествоЗадач + 1;
			СтрокаТЗСотрудников.ПроцентТекущий 	= СтрокаТЗСотрудников.КоличествоЗадач/ТЗСотрудников.Итог("КоличествоЗадач")*100; 
			СтрокаТЗСотрудников.Дельта 		    = СтрокаТЗСотрудников.Пропорция - СтрокаТЗСотрудников.ПроцентТекущий;
			
		КонецЕсли;
		
		// Обновляем данные в таблице значений.
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			СтрокаСотрудников.ПроцентТекущий 	   = СтрокаСотрудников.КоличествоЗадач/ТЗСотрудников.Итог("КоличествоЗадач")*100; 
			СтрокаСотрудников.Дельта 		       = СтрокаСотрудников.Пропорция - СтрокаСотрудников.ПроцентТекущий;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

