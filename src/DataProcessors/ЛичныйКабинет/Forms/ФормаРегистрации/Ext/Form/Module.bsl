&НаКлиенте
// Обработчик кнопки регистрации анкеты
Процедура ЗарегистрироватьДляПодтверждения(Команда)	
	
	ЭтотОбъект.ОрганизацияТелефон    = ЭтотОбъект.КонтактнаяИнформация[0].Представление;
	ЭтотОбъект.ОрганизацияТелефонXML = ЭтотОбъект.КонтактнаяИнформация[0].ЗначенияПолей;		
	ЭтотОбъект.ОрганизацияПочта      = ЭтотОбъект.КонтактнаяИнформация[1].Представление;
	ЭтотОбъект.ОрганизацияПочтаXML   = ЭтотОбъект.КонтактнаяИнформация[1].ЗначенияПолей;
	ЭтотОбъект.ОрганизацияАдрес      = ЭтотОбъект.КонтактнаяИнформация[2].Представление;
	ЭтотОбъект.ОрганизацияАдресXML   = ЭтотОбъект.КонтактнаяИнформация[2].ЗначенияПолей;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.КиИмя) Тогда
		
		ФорматированноеПредупреждение("На странице контактной информации не указано имя контактного лица!");
		Возврат; 
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.КиТелефон) Тогда
		
		ФорматированноеПредупреждение("На странице контактной информации не указан телефон контактного лица!");
		Возврат; 
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.КиПочта) Тогда
		
		ФорматированноеПредупреждение("На странице контактной информации не указана электронная почта контактного лица!");
		Возврат; 
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ОрганизацияНаименование) Тогда
		
		ФорматированноеПредупреждение("Укажите название организации!");
		Возврат; 
		
	КонецЕсли;
				
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ОрганизацияИНН) Тогда
		
		ФорматированноеПредупреждение("Укажите ИНН организации!");
		Возврат; 
		
	КонецЕсли;
				
	ПараметрыРегистрации = ЛичныйКабинет.ПолучитьПустуюСтруктуруДанныхРегистрацииАнкеты();
	
	ПараметрыРегистрации.КонтактноеЛицоИмя                    = ЭтотОбъект.КиИмя;
    ПараметрыРегистрации.КонтактноеЛицоТелефон                = ЭтотОбъект.КиТелефон;
	ПараметрыРегистрации.КонтактноеЛицоПочта                  = ЭтотОбъект.КиПочта;

	ПараметрыРегистрации.КлиникаТип                           = ЭтотОбъект.КлиникаТип;
    ПараметрыРегистрации.КлиникаНаименование                  = ЭтотОбъект.КлиникаНазвание;
    ПараметрыРегистрации.КлиникаГород                         = ЭтотОбъект.КлиникаГород;
	ПараметрыРегистрации.КлиникаРазмер                        = ЭтотОбъект.КлиникаПлощадь;
	
	ПараметрыРегистрации.ОрганизацияНаименование              = ЭтотОбъект.ОрганизацияНаименование;
	ПараметрыРегистрации.ОрганизацияАдресСтрокой              = ЭтотОбъект.ОрганизацияАдрес;
	ПараметрыРегистрации.ОрганизацияАдресXML                  = ЭтотОбъект.ОрганизацияАдресXML;
	ПараметрыРегистрации.ОрганизацияТелефон                   = ЭтотОбъект.ОрганизацияТелефон;
	ПараметрыРегистрации.ОрганизацияПочта                     = ЭтотОбъект.ОрганизацияПочта;
	ПараметрыРегистрации.ОрганизацияИНН                       = ЭтотОбъект.ОрганизацияИНН;

	ПараметрыРегистрации.ОрганизацияОтправительИД             = Строка(ЭтотОбъект.РегистрацияОтправитель.УникальныйИдентификатор());
    ПараметрыРегистрации.ОрганизацияОтправительПолноеИмя      = Строка(ЭтотОбъект.РегистрацияОтправитель);

	ПараметрыРегистрации.ПродуктРегистрационныйНомер          = СокрЛП(ЭтотОбъект.АвторизацияРегистрационныйНомер);
	ПараметрыРегистрации.ПродуктСкринАнкеты                   = ЭтотОбъект.ДвоичныеДанныеФайлаАнкеты;
	ПараметрыРегистрации.ПродуктПароль                        = ЭтотОбъект.АвторизацияПароль;
	
	УидИнфБазы = ЛичныйКабинет.ПолучитьУИДИнформационнойБазы();
	
	Если НЕ ЗначениеЗаполнено(УидИнфБазы) Тогда	
		УидИнфБазы = ЛичныйКабинет.УстановитьУИДИнформационнойБазы();	
	КонецЕсли;
	
	ПараметрыРегистрации.ПродуктУИДБазы         = УидИнфБазы;	
	ПараметрыРегистрации.ПродуктСЛКиспользуется = Истина; //ЛичныйКабинет.КлючЗащитыИспользуется();
				
	РезОперции  = ЛичныйКабинет.ЗарегистрироватьАнкетуПродукта(ПараметрыРегистрации);	
	Сообщение   = Неопределено;
	
	Если РезОперции.ВыполненоУспешно Тогда
		
		ЭтотОбъект.РегистрацияПринята = РезОперции.РегистрацияПринята;
		
		Если ЭтотОбъект.РегистрацияПринята Тогда
			
	        ЗаписатьДанныеПослеЗапрсаРегистрации(РезОперции.СтатусАнкетыКод, ЭтотОбъект.РегистрацияПринята);
			
			ВыполнитьВходвЛичныйКабинет();
						
		Иначе
			
			Сообщение = РезОперции.ОписаниеРезультата;
			
		КонецЕсли;	
		
	Иначе
		Сообщение = РезОперции.ОписаниеОшибки;
	КонецЕсли;
	
	Если Сообщение <> Неопределено Тогда
	    ФорматированноеПредупреждение(Сообщение);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Записать данные анкеты и дополнительные парамтеры в константу
Процедура ЗаписатьДанныеПослеЗапрсаРегистрации(КодСостояния, РегистрацияПринята)
	
	ДанныеАнкеты = ЛичныйКабинет.ПолучитьДанныеРегистрационнойАнкеты();
	
	Если ДанныеАнкеты = Неопределено Тогда		
		ДанныеАнкеты = ЛичныйКабинет.ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте(); 			
	КонецЕсли;
	
	Если НЕ ДанныеАнкеты.Свойство("ПродуктРегистрационныйНомер") Тогда
		ДанныеАнкеты = ЛичныйКабинет.ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте(); 
	КонецЕсли;
	
    ДанныеАнкеты.ПродуктРегистрационныйНомер                 = СокрЛП(ЭтотОбъект.АвторизацияРегистрационныйНомер);
	ДанныеАнкеты.РегистрацияПринята                          = РегистрацияПринята;
	ДанныеАнкеты.РегистрацияОтправитель                      = Строка(ЭтотОбъект.РегистрацияОтправитель.УникальныйИдентификатор());
	ДанныеАнкеты.РегистрацияПоследнийКодСостояния            = КодСостояния;
	ДанныеАнкеты.РегистрацияОповещениеОСтатусеВыполнено      = Ложь;

	ЛичныйКабинет.ЗаписатьДанныеРегистрационнойАнкеты(ДанныеАнкеты);	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Записать данные анкеты и дополнительные парамтеры в константу
Процедура ЗаписатьДанныеПослеПервогоВхода(РегистрационныйНомер)
	
	ТекущаяРегистрацияПродукта = ЛичныйКабинет.ДанныеПоСостояниюАнкетыПродукта(РегистрационныйНомер); 
		
	Если ТекущаяРегистрацияПродукта.ВыполненоУспешно = Истина Тогда
		
		ДанныеАнкеты = ЛичныйКабинет.ПолучитьДанныеРегистрационнойАнкеты();
		
		Если ДанныеАнкеты = Неопределено Тогда		
			ДанныеАнкеты = ЛичныйКабинет.ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте(); 			
		КонецЕсли;
		
		Если НЕ ДанныеАнкеты.Свойство("ПродуктРегистрационныйНомер") Тогда
			ДанныеАнкеты = ЛичныйКабинет.ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте(); 
		КонецЕсли;
		
		ДанныеАнкеты.ПродуктРегистрационныйНомер                 = СокрЛП(РегистрационныйНомер);
		ДанныеАнкеты.РегистрацияПринята                          = Истина;
		ДанныеАнкеты.РегистрацияПоследнийКодСостояния            = ТекущаяРегистрацияПродукта.СтатусРегистрацииКод;
		ДанныеАнкеты.РегистрацияОповещениеОСтатусеВыполнено      = Истина;
		
		ЛичныйКабинет.ЗаписатьДанныеРегистрационнойАнкеты(ДанныеАнкеты);	
		
	КонецЕсли;
	
КонецПроцедуры


