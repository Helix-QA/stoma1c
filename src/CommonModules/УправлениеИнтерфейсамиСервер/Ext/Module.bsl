	 ТаблицаОтказов.РастягиватьПоГоризонтали 	  	= Ложь;
	 ТаблицаОтказов.ГоризонтальныеЛинии 	 	  	= Ложь;
	 ТаблицаОтказов.ВертикальныеЛинии 		 	  	= Ложь;
	 ТаблицаОтказов.РежимВыделенияСтроки 	 	  	= РежимВыделенияСтрокиТаблицы.Строка;
	 ТаблицаОтказов.ПоложениеКоманднойПанели 	  	= ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	 ТаблицаОтказов.ГоризонтальнаяПолосаПрокрутки 	= ИспользованиеПолосыПрокрутки.НеИспользовать;
	 ТаблицаОтказов.ВертикальнаяПолосаПрокрутки	  	= ИспользованиеПолосыПрокрутки.НеИспользовать;
     ТаблицаОтказов.ВариантУправленияВысотой 		= ВариантУправленияВысотойТаблицы.ПоСодержимому;
	 ТаблицаОтказов.ЧередованиеЦветовСтрок 			= Истина;
	 
	 ЗначениеПричиныОтказа = Форма.Элементы.Добавить("ЗначениеПричиныОтказа_" + ИндексВиджета, Тип("ПолеФормы"), ТаблицаОтказов);
	 ЗначениеПричиныОтказа.ПутьКДанным = "ПричиныОтказов.Ссылка";
