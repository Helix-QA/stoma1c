			<field>ЭтоСклад</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Это склад</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Наименование</dataPath>
			<field>Наименование</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Склады.Ссылка КАК Склад,
	ИСТИНА КАК ЭтоСклад,
	Склады.Наименование КАК Наименование
ПОМЕСТИТЬ ВТСкладыСправочники
ИЗ
	Справочник.Склады КАК Склады
ГДЕ
	Склады.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
	И НЕ Склады.ЭтоГруппа

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	Сотрудники.Ссылка,
	ЛОЖЬ,
	Сотрудники.Ссылка.Наименование
ИЗ
	Справочник.Сотрудники КАК Сотрудники
ГДЕ
	Сотрудники.ДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
	И НЕ Сотрудники.ЭтоГруппа
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ВТСкладыСправочники.Склад КАК Склад,
	ВТСкладыСправочники.ЭтоСклад КАК ЭтоСклад,
	ВТСкладыСправочники.Наименование КАК Наименование
ИЗ
	ВТСкладыСправочники КАК ВТСкладыСправочники
{ГДЕ
	(ВЫБОР
			КОГДА &amp;ЭтоСклад &lt;&gt; ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
					И &amp;ЭтоСклад &lt;&gt; ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
				ТОГДА ВТСкладыСправочники.ЭтоСклад = &amp;ЭтоСклад
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}</query>
