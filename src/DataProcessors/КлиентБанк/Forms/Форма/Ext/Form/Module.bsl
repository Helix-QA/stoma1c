						3,
						НСтр("ru = 'Возможно, неверно указано значение в поле ""Налоговый период"" на закладке ""Реквизиты для перечисления налогов"".'")
					);
					УстановитьГотовность(СтрокаЭкспорта.Готовность, 4);
