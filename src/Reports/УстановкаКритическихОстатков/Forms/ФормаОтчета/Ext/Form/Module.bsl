#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктурнаяЕдиницаОтбор = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; 
	УстановитьВариантОтчета(СУчетомПарти);
	УстановитьПараметрыКомпоновкиОтчета();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СкомпоноватьДанныеРезультата()
	
    УстановитьПараметрВСКД();
	ЭтаФорма.СкомпоноватьРезультат();
	
КонецПроцедуры

&НаКлиенте
// Обработчик события ОбработкаРасшифровки элемента Результат.
//
Процедура РезультатОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)
		
	СтандартнаяОбработка = Ложь;
	СтруктураПараметров = ПолучитьДанныеРасшифровки(Расшифровка);
	
	Если СтруктураПараметров.Свойство("КоличествоБП") Тогда
		Количество = СтруктураПараметров.КоличествоБП;
		СтруктураПараметров.Удалить("КоличествоБП");
		СтруктураПараметров.Вставить("Количество", Количество);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("НоменклатураБП") Тогда
		Номенклатура = СтруктураПараметров.НоменклатураБП;
		СтруктураПараметров.Удалить("НоменклатураБП");
		СтруктураПараметров.Вставить("Номенклатура", Номенклатура);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("СкладБП") Тогда
		Склад = СтруктураПараметров.СкладБП;
		СтруктураПараметров.Удалить("СкладБП");
		СтруктураПараметров.Вставить("Склад", Склад);
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("СтруктурнаяЕдиница") И СтруктураПараметров.Свойство("Номенклатура") И СтруктураПараметров.Свойство("Склад") Тогда
		СуществованиеОбъекта = ПроверкаСуществованияЭлемента(СтруктураПараметров);
		Если СуществованиеОбъекта Тогда 
			Изменить(Неопределено);
		Иначе
			СозданиеЭлемента = Новый Структура("Номенклатура", СтруктураПараметров.Номенклатура);
			СозданиеЭлемента.Вставить("Партия", ?(СтруктураПараметров.Свойство("Партия"), СтруктураПараметров.Партия, ПредопределенноеЗначение("Справочник.ПартииНоменклатуры.ПустаяСсылка")));
			СозданиеЭлемента.Вставить("Склад", СтруктураПараметров.Склад);
			СозданиеЭлемента.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиницаОтбор);
			Оповещение = Новый ОписаниеОповещения("КритическиеОстаткиЗаписьЗавершение", ЭтотОбъект);

			ОткрытьФорму("РегистрСведений.КритическиеОстатки.Форма.ФормаЗаписи", СозданиеЭлемента,,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		КонецЕсли;	
	ИначеЕсли СтруктураПараметров.Свойство("Основной") И СтруктураПараметров.Основной <> NULL Тогда
		ОткрытьФорму(ВернутьПолноеИмяФормы(СтруктураПараметров.Основной, ПроверкаИерархии(Расшифровка)), Новый Структура("Ключ", СтруктураПараметров.Основной),,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		СкомпоноватьДанныеРезультата();
		ПроверкаФиксации();
	КонецЕсли;                             
	
КонецПроцедуры

&НаКлиенте
Процедура СтрЕдиницаОтборПриИзменении(Элемент)
	
	УстановитьПараметрВСКД();
	СкомпоноватьДанныеРезультата();
	ПроверкаФиксации();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - обработчик команды Добавить.
//
Процедура Добавить(Команда)
	
	Параметр = Новый Структура("ДобавлениеНового", Истина);
	Параметр.Вставить("СтруктурнаяЕдиница",СтруктурнаяЕдиницаОтбор); 
	Оповещение = Новый ОписаниеОповещения("КритическиеОстаткиЗаписьЗавершение", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.КритическиеОстатки.Форма.ФормаЗаписи", Параметр,,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс); 

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды Скопировать.
//
Процедура Скопировать(Команда)

	СтруктураПараметров = ПолучитьДанныеРасшифровки(Элементы.Результат.ТекущаяОбласть.Расшифровка);
	
	Если СтруктураПараметров.Свойство("КоличествоБП") Тогда
		Количество = СтруктураПараметров.КоличествоБП;
		СтруктураПараметров.Удалить("КоличествоБП");
		СтруктураПараметров.Вставить("Количество", Количество);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("НоменклатураБП") Тогда
		Номенклатура = СтруктураПараметров.НоменклатураБП;
		СтруктураПараметров.Удалить("НоменклатураБП");
		СтруктураПараметров.Вставить("Номенклатура", Номенклатура);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("СкладБП") Тогда
		Склад = СтруктураПараметров.СкладБП;
		СтруктураПараметров.Удалить("СкладБП");
		СтруктураПараметров.Вставить("Склад", Склад);
	КонецЕсли;
	
	Если Не (СтруктураПараметров.Свойство("СтруктурнаяЕдиница") И СтруктураПараметров.Свойство("Номенклатура") И СтруктураПараметров.Свойство("Склад")) Тогда
		Возврат;
	КонецЕсли;	
	Оповещение = Новый ОписаниеОповещения("КритическиеОстаткиЗаписьЗавершение", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.КритическиеОстатки.ФормаЗаписи", Новый Структура("ЗначенияЗаполнения", СтруктураПараметров),,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды Изменить.
//
Процедура Изменить(Команда)
	                           
	СтруктураПараметров = ПолучитьДанныеРасшифровки(Элементы.Результат.ТекущаяОбласть.Расшифровка);
	
	Если СтруктураПараметров.Свойство("КоличествоБП") Тогда
		Количество = СтруктураПараметров.КоличествоБП;
		СтруктураПараметров.Удалить("КоличествоБП");
		СтруктураПараметров.Вставить("Количество", Количество);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("НоменклатураБП") Тогда
		Номенклатура = СтруктураПараметров.НоменклатураБП;
		СтруктураПараметров.Удалить("НоменклатураБП");
		СтруктураПараметров.Вставить("Номенклатура", Номенклатура);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("СкладБП") Тогда
		Склад = СтруктураПараметров.СкладБП;
		СтруктураПараметров.Удалить("СкладБП");
		СтруктураПараметров.Вставить("Склад", Склад);
	КонецЕсли;
	
	Если Не (СтруктураПараметров.Свойство("СтруктурнаяЕдиница") И СтруктураПараметров.Свойство("Номенклатура") И СтруктураПараметров.Свойство("Склад")) Тогда
		Возврат;
	КонецЕсли;
	
	КлючЗаписиСтруктурой = ПолучитьКлючЗаписи(СтруктураПараметров);
	Если КлючЗаписиСтруктурой <> Неопределено Тогда
		ПараметрыМассив = Новый Массив;
		ПараметрыМассив.Добавить(КлючЗаписиСтруктурой);   		
		КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.КритическиеОстатки", ПараметрыМассив);
		
		Оповещение = Новый ОписаниеОповещения("КритическиеОстаткиЗаписьЗавершение", ЭтотОбъект);
		ОткрытьФорму("РегистрСведений.КритическиеОстатки.Форма.ФормаЗаписи", Новый Структура("Ключ, КомандаИзменить", КлючЗаписиРегистра, Истина),,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс); 
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды Удалить.
//
Процедура Удалить(Команда)
	
	СтруктураПараметров = ПолучитьДанныеРасшифровки(Элементы.Результат.ТекущаяОбласть.Расшифровка);
	
	Если СтруктураПараметров.Свойство("КоличествоБП") Тогда
		Количество = СтруктураПараметров.КоличествоБП;
		СтруктураПараметров.Удалить("КоличествоБП");
		СтруктураПараметров.Вставить("Количество", Количество);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("НоменклатураБП") Тогда
		Номенклатура = СтруктураПараметров.НоменклатураБП;
		СтруктураПараметров.Удалить("НоменклатураБП");
		СтруктураПараметров.Вставить("Номенклатура", Номенклатура);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("СкладБП") Тогда
		Склад = СтруктураПараметров.СкладБП;
		СтруктураПараметров.Удалить("СкладБП");
		СтруктураПараметров.Вставить("Склад", Склад);
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("Номенклатура") И СтруктураПараметров.Свойство("Склад") Тогда
		УдалитьНаСервере(СтруктураПараметров);
		СкомпоноватьДанныеРезультата();
		ПроверкаФиксации();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды Обновить.
//
Процедура Обновить(Команда)
	
	СкомпоноватьДанныеРезультата();
	ПроверкаФиксации();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды Печать.
//
Процедура Печать(Команда)
		
	Если Результат = Неопределено тогда
		Возврат;
	КонецЕсли;

	Результат.КоличествоЭкземпляров = 1;

	Если НЕ Результат.АвтоМасштаб И НЕ ЗначениеЗаполнено(Результат.ИмяПринтера) Тогда
		Результат.АвтоМасштаб = Истина;
	КонецЕсли;
	
	Результат.Напечатать(Ложь);

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды ОтображатьЗаголовок.
//
Процедура ОтображатьЗаголовок(Команда)
		
	Элементы.ОтображатьЗаголовок.Пометка = НЕ Элементы.ОтображатьЗаголовок.Пометка;
	УстановитьПараметрыКомпоновкиОтчета();
	
	Результат.ФиксацияСверху = 0;
	Результат.ФиксацияСлева = 0;
	
	СкомпоноватьДанныеРезультата();
	Если Элементы.ОтображатьЗаголовок.Пометка Тогда
		СдвинутьОбластьДляЗаголовка();
		Результат.ФиксацияСверху = 5;
		Результат.ФиксацияСлева = 1;
	Иначе
		Результат.ФиксацияСверху = 2;
		Результат.ФиксацияСлева = 1;
	КонецЕсли;
	
КонецПроцедуры     

