&НаКлиенте
// Процедура, обработчик события "ПриНажатии" поля формы "ИсторияВзаимодействия".
//
Процедура ИсторияВзаимодействияПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	// Элемент.Доступность = Ложь; // Прыгает вся история, зачем менять?
	ЭлементHTML 		= ДанныеСобытия.Element; 
	ДанныеСсылкиHTML 	= ДанныеСобытия.Anchor;
	Документ 			= Элемент.Документ;
	
	Попытка 
		
		Если ДанныеСсылкиHTML = Неопределено Тогда 				// Нажали в пустое место.	
			Возврат;	
		ИначеЕсли ДанныеСсылкиHTML.name = "more" Тогда
			СтандартнаяОбработка = Ложь;
			
			ЭтотОбъект.ВыводитьВсеВзаимодействия = Истина;
			СформироватьИсториюВзаимодействияСКлиентом();
						
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "note") Тогда  // редактировать заметку.
			
			СтандартнаяОбработка = Ложь;
			
			СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ДанныеСсылкиHTML.id);
			
			Если РольДоступнаКлиентСервер("ПолныеПрава")
				ИЛИ РольДоступнаКлиентСервер("ДобавлениеИзменениеКлиентов") Тогда
				
				МассивЭлементовHTML = ДанныеСсылкиHTML.getElementsByClassName("text-message");
				
				Если МассивЭлементовHTML.length > 0 Тогда
					РедактироватьЗаметку(МассивЭлементовHTML[0], СтрокаТЗ.Заметка, СтрокаТЗ);
				КонецЕсли;
								
			КонецЕсли;
			
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "call_comment") Тогда // редактировать коментарий звонка
			
			СтандартнаяОбработка = Ложь;
			
			МассивЭлементовHTML = ДанныеСсылкиHTML.getElementsByClassName("text-message");
			
			Если МассивЭлементовHTML.length > 0 Тогда
				РедактироватьЗаметкуЗвонок(МассивЭлементовHTML[0],  ДанныеСсылкиHTML.id);
			КонецЕсли;
	
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "profs") Тогда  // редактировать профосмотр.		
			
			СтандартнаяОбработка = Ложь;
			
			РедактироватьПрофосмотр(ДанныеСсылкиHTML);	
			
		ИначеЕсли СтрНайти(ЭлементHTML.className, "task") > 0 Тогда 
			СтандартнаяОбработка = Ложь;

			Ссылка = ПолучитьСсылкуНаЗадачуПоУид(Новый УникальныйИдентификатор(ЭлементHTML.id));
			ОбновитьФорму = ОтметитьЗадачуКакВыполненую(Ссылка);
			Если ОбновитьФорму Тогда
				УстановитьФильтрИсторииВзаимодействияНаСервере();	
			КонецЕсли; 
			
		ИначеЕсли СтрНайти(ЭлементHTML.className, "listen_call") Тогда // прослущать звонок	
				
			СтандартнаяОбработка = Ложь;
			
			СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ЭлементHTML.id);
			Сообщение = "";
			
			ДанныеВызова = ПолучитьДанныеИсторииВызова(СтрокаТЗ.Взаимодействие, Сообщение);
			
			Если Не ЗначениеЗаполнено(ДанныеВызова) Тогда 
				Если ЗначениеЗаполнено(Сообщение) Тогда 
					ПоказатьПредупреждение(,Сообщение);
				КонецЕсли;
				Возврат;
			ИначеЕсли ЗначениеЗаполнено(ДанныеВызова.ФайлЗаписи) Тогда					
				СсылкаНаФайл = ПолучитьСсылкуПоУид(ДанныеВызова.ФайлЗаписи.УникальныйИдентификатор(), ЭлементHTML.name);
				
				ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(СсылкаНаФайл);
				
				РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
				
			ИначеЕсли ЗначениеЗаполнено(ДанныеВызова.URLЗаписи) Тогда
				АктуальныйURLЗаписи = IPТелефонияКлиент.ПолучитьАктуальныйURLЗаписиROSTELECOMКлиент(ДанныеВызова.URLЗаписи, ДанныеВызова.IDЗвонка, ДанныеВызова.ОборудованиеТелефонии);
				НачатьЗапускПриложения(Новый ОписаниеОповещения("ИсторияВзаимодействияПослеОткрытияПриложенияЗаглушка", ЭтотОбъект), АктуальныйURLЗаписи);
   			Иначе
				Возврат;
			КонецЕсли;
			
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "open_dialog") Тогда  // Открыть диалог.
			
			СтандартнаяОбработка = Ложь;
			
			ИдКлиента 			= Лев(ДанныеСсылкиHTML.id, СтрНайти(ДанныеСсылкиHTML.id, "_") - 1);	
			UidВнешнейСистемы 	= Сред(ДанныеСсылкиHTML.id, СтрНайти(ДанныеСсылкиHTML.id, "_") + 1, СтрДлина(ДанныеСсылкиHTML.id));
			
			ПерейтиВЧат(ИдКлиента, UidВнешнейСистемы);
	
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "clip") Тогда // закрепить/открепить
			
			СтандартнаяОбработка = Ложь;
			
			СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ДанныеСсылкиHTML.id);
			
			ЗакрепитьОткрепитьЗаметку(СтрокаТЗ.ИДЗаметки, СтрНайти(ДанныеСсылкиHTML.name, "off"));
			СформироватьИсториюВзаимодействияСКлиентом();
	
		ИначеЕсли ЗначениеЗаполнено(ДанныеСобытия.Href) Тогда
			
			СтандартнаяОбработка = Ложь;
			ПерейтиПоНавигационнойСсылке(ДанныеСобытия.Href);
			
			
		Иначе
			СтандартнаяОбработка = Ложь;
		КонецЕсли;
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
	КонецПопытки;
	// Элемент.Доступность = Истина;
	
КонецПроцедуры

