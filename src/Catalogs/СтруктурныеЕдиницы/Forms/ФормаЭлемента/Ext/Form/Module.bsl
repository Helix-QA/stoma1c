Процедура СоздатьМенюПереключения()
	        	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("Основное", "ГруппаОсновное");
	СтруктураМеню.Вставить("Контакты", "ГруппаКонтактнаяИнформация");
	СтруктураМеню.Вставить("Онлайн"  , "ГруппаОнлайн");
