// Функция - Получить данные события занятие начало занятия
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//  ОбъектСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЗаписьНачалоПриема(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Запись"				, ОбъектСобытия);
		Запрос.УстановитьПараметр("МассивКонтрагентов"	, ДанныеТриггера.МассивНеобработанныхКонтрагентов);		
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПредварительнаяЗапись.Ссылка КАК Запись,
		|	ПредварительнаяЗапись.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ТаблицаЗаписей
		|ИЗ
		|	Документ.Событие КАК ПредварительнаяЗапись
		|ГДЕ
		|	ПредварительнаяЗапись.Проведен = ИСТИНА
		|	И ПредварительнаяЗапись.Ссылка = &Запись
		|	И ПредварительнаяЗапись.Контрагент В(&МассивКонтрагентов)
		|	И ПредварительнаяЗапись.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
		|	И ПредварительнаяЗапись.ТипСобытия = ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ПредварительнаяЗапись)
		|	И ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)
		|	И ПредварительнаяЗапись.ИсточникЗаписи = &ИсточникЗаписи
		|	И ПредварительнаяЗапись.Резерв = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаЗаписей.Запись КАК Запись,
		|	ТаблицаЗаписей.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ИтоговаяТаблицаЗаписей
		|ИЗ
		|	ТаблицаЗаписей КАК ТаблицаЗаписей
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ТаблицаЗаписей.Запись = ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		|			И ТаблицаЗаписей.Контрагент = ЖурналРегистрацииТриггерныхСобытий.Контрагент
		|			И (ВЫБОР
		|				КОГДА &РегистрацияЗапланированных
		|					ТОГДА ЖурналРегистрацииТриггерныхСобытий.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &РегистрацияЗапланированных
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЖурналРегистрацииТриггерныхСобытий.Контрагент ЕСТЬ NULL
		|		КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПредварительнаяЗапись.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПредварительнаяЗапись.Ссылка КАК Запись,
		|	ПредварительнаяЗапись.Контрагент КАК Контрагент,
		|	ПредварительнаяЗапись.Ссылка КАК ОбъектСобытия,
		|	ПредварительнаяЗапись.Врач КАК Сотрудник,
		|	ПредварительнаяЗапись.Статус КАК СтатусЗаписи,
		|	ПредварительнаяЗапись.Дата КАК ДатаВремяНачала,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВремяОкончания,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	Документ.Событие КАК ПредварительнаяЗапись
		|ГДЕ
		|	ПредварительнаяЗапись.Ссылка В
		|			(ВЫБРАТЬ
		|				ИтоговаяТаблицаЗаписей.Запись
		|			ИЗ
		|				ИтоговаяТаблицаЗаписей)
		|	И ПредварительнаяЗапись.Контрагент В
		|			(ВЫБРАТЬ
		|				ИтоговаяТаблицаЗаписей.Контрагент
		|			ИЗ
		|				ИтоговаяТаблицаЗаписей)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаВремяНачала";
			
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)",
			"ПредварительнаяЗапись.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ДанныеТриггера.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия Тогда
			Если ЗначениеЗаполнено(ДанныеТриггера.СтатусЗаписи) Тогда 
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)", "ПредварительнаяЗапись.Статус = &СтатусПредварительнойЗаписи");	
				Запрос.УстановитьПараметр("СтатусПредварительнойЗаписи", ДанныеТриггера.СтатусЗаписи);
			//Иначе 
			//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)", "ИСТИНА");	
			КонецЕсли;			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ИсточникЗаписи) И ТипЗнч(ДанныеТриггера.ИсточникЗаписи) = Тип("СправочникСсылка.ИсточникиЗаписей") Тогда
			Запрос.УстановитьПараметр("ИсточникЗаписи", ДанныеТриггера.ИсточникЗаписи);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.ИсточникЗаписи = &ИсточникЗаписи", "ИСТИНА");
		КонецЕсли;
		
		// Если ЗначениеЗаполнено(ДанныеТриггера.СегментУслуг) Тогда 
		//	Если ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.Номенклатура") Тогда 
		//		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗанятиеСоставЗанятия.Ссылка.Номенклатура В(&СегментУслуг)", "ЗанятиеСоставЗанятия.Ссылка.Номенклатура = &СегментУслуг");
		//		Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
		//	ИначеЕсли ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
		//		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗанятиеСоставЗанятия.Ссылка.Номенклатура В(&СегментУслуг)",
		//		"ЗанятиеСоставЗанятия.Ссылка.Номенклатура В
		//		|			(ВЫБРАТЬ
		//		|				СоставСегментов.ОбъектСегмента
		//		|			ИЗ
		//		|				РегистрСведений.СоставСегментов КАК СоставСегментов
