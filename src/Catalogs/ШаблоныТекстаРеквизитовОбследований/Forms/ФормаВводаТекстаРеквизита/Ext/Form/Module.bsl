#Область ОбработчикиКомандФормы

&НаКлиенте
// Завершить ввод текста, закрыть форму
//
Процедура Ок(Команда)  
	
	СтандартнаяОбработка = Ложь;
	ВыделенныеЗубы = ?(МассивВыделенныхЗубов <> Неопределено, МассивВыделенныхЗубов.ВыгрузитьЗначения(), Неопределено);
	Значение = Новый Структура("Зубы, Текст", ВыделенныеЗубы, ВводимыйТекст);
	Если Не ЗначениеЗаполнено(ВыделенныеЗубы) И Не ЗначениеЗаполнено(ВводимыйТекст) Тогда  
		Значение.Вставить("УдалитьРеквизит", Истина);
	КонецЕсли;
	Значение.Вставить("ИдентификаторБлокируемойФормы", Этаформа.УникальныйИдентификатор);
	Закрыть(Значение);
	
КонецПроцедуры

&НаКлиенте
// Передать в род. форму признак удаления реквизита
//
Процедура УдалитьРеквизит(Команда)
	Закрыть(Новый Структура("Зуб,Текст,УдалитьРеквизит",Неопределено,Неопределено,Истина));
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Обработчик выбора значения из списка
//
Процедура СписокШаблоновВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)	
	
	СтандартнаяОбработка = Ложь;
	Если ВыбраннаяСтрока <> Неопределено
		И Элемент.ТекущиеДанные <> Неопределено
		И НЕ Элемент.ТекущиеДанные.ЭтоГруппа Тогда
		
		ВводимыйТекст = ВводимыйТекст + ?(ВводимыйТекст <> "",". ","") + ПолучитьТекстШаблона(ВыбраннаяСтрока);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик перед началом добавления строки
//
Процедура СписокШаблоновПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	Если Группа Тогда
		ФормаГруппы = ПолучитьФорму("Справочник.ШаблоныТекстаРеквизитовОбследований.Форма.ФормаГруппы",Новый Структура("ЭтоГруппа",Истина),ЭтаФорма);
		ФормаГруппы.Объект.ПодчиненРеквизиту = ПодчиненРеквизиту;
		ФормаГруппы.Объект.ПодчиненДиагнозу  = ПодчиненДиагнозу;
		ФормаГруппы.СкрытьНеОсновныеЭлементы();
		ФормаГруппы.Открыть();
	Иначе	
		Основание     = Новый Структура("Родитель,ПодчиненРеквизиту,ТекстШаблона,ПодчиненДиагнозу,ОкрытИзСписка",Родитель,ПодчиненРеквизиту,ВводимыйТекст,ПодчиненДиагнозу, Истина);
		ФормаЭлемента = ПолучитьФорму("Справочник.ШаблоныТекстаРеквизитовОбследований.ФормаОбъекта",Новый Структура("Основание",Основание),ЭтаФорма);
		//ФормаЭлемента.СкрытьНеОсновныеЭлементы();
		ФормаЭлемента.Открыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
// При нажатии на форму подбора
//
Процедура ПодборЗубовПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если ДанныеСобытия.Element.parentNode = Неопределено Тогда 
		//МассивВыделенныхЗубов = Неопределено;
		Возврат;
	КонецЕсли;
		
	ДанныеЭлемента = ДанныеСобытия.Element.parentNode.id; //ДанныеСобытия.element.id;
	
	Если ДанныеЭлемента = "Switch" тогда
		МассивВыделенныхЗубов.Очистить();
		ТипЗубнойФормулы         = ?(ТипЗубнойФормулы = 1, 0, 1);
		SVGВыделенныйЗуб         = "var selectzub"; 
		SVGМассивВыделенныхЗубов = "var SelectedTeeth = [];";			
		УстановитьЗубнуюФормулу();
		ОбновитьSVGПодбор();
	КонецЕсли;

	Если ДанныеЭлемента = "МножественныйРежимВыделения" ИЛИ ДанныеЭлемента = "ОдиночныйРежимВыделения" тогда
		РазрешитьМножественныйВыбор = ДанныеЭлемента = "МножественныйРежимВыделения";
	КонецЕсли;

	Если ДанныеЭлемента = "Del" Тогда
		МассивВыделенныхЗубов.Очистить();
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеЭлемента) и Найти(ДанныеЭлемента, "Зуб") > 0  Тогда
		Зуб = ДанныеЭлемента;
		Если Найти(Зуб, "Зуб") > 0 Тогда
			Зуб = ПредопределенноеЗначение("Перечисление.Зубы."+Зуб);
		Иначе
			Возврат;
		КонецЕсли;
		
		Если РазрешитьМножественныйВыбор Тогда
			НайденныйЭл = МассивВыделенныхЗубов.НайтиПоЗначению(Зуб);
			Если НайденныйЭл <> Неопределено Тогда			
				МассивВыделенныхЗубов.Удалить(НайденныйЭл);
			Иначе
				МассивВыделенныхЗубов.Добавить(Зуб);				
			КонецЕсли;		
		Иначе
			
			Если МассивВыделенныхЗубов.Количество() > 0 и Зуб = МассивВыделенныхЗубов[0].Значение Тогда
				МассивВыделенныхЗубов.Очистить();
			Иначе
				МассивВыделенныхЗубов.Очистить();
				МассивВыделенныхЗубов.Добавить(Зуб);
			КонецЕсли;
			
		КонецЕсли;
		
		//ИскомаяЗакладка = ТалицаВводимогоТекста.НайтиСтроки(Новый Структура("ЗначениеЗакладки, ЗубЗначение", ПредЗакладка, ПредЗуб));
		//
		//Если ИскомаяЗакладка.Количество() > 0 Тогда
		//	ИскомаяЗакладка[0].ВводимыйТекст = ВводимыйТекст;
		//	ИскомаяЗакладка[0].ЗубЗначение = ПредЗуб;
		//ИначеЕсли ЗначениеЗаполнено(ВводимыйТекст) Тогда
		//	НоваяСтрока = ТалицаВводимогоТекста.Добавить();
		//	НоваяСтрока.ЗначениеЗакладки 		= ПредЗакладка;
		//	НоваяСтрока.ВводимыйТекст 	 		= ВводимыйТекст;
		//	НоваяСтрока.ЗубЗначение 	 		= ?( ЗначениеЗаполнено(ПредЗуб), ПредЗуб, Зуб);
		//	НоваяСтрока.РеквизитИдентификатор 	= Новый УникальныйИдентификатор;  
		//	
		//	НоваяСтрока.РеквизитЗначениеСтрокой = ВводимыйТекст;
		//	НоваяСтрока.РеквизитЗначение        = ВводимыйТекст;
		//	НоваяСтрока.Реквизит                = Неопределено;
		//	НоваяСтрока.ЗубИдентификатор        = Новый УникальныйИдентификатор;
		//	
		//	НашаЗакладка = Элементы.Найти(ПредЗакладка);
		//	НашаЗакладка.Заголовок = НашаЗакладка.Заголовок + "(" + Строка(?( ЗначениеЗаполнено(ПредЗуб), ПредЗуб, Зуб)) + ")";
		//КонецЕсли;
		//ПредЗуб = Зуб;
		//Если МассивВыделенныхЗубов.Количество() = 0 Тогда
		//	ПредЗуб = ПредопределенноеЗначение("Перечисление.Зубы.ПустаяСсылка");	
		//КонецЕсли;
		//ИскомаяЗакладка = ТалицаВводимогоТекста.НайтиСтроки(Новый Структура("ЗначениеЗакладки, ЗубЗначение", ПредЗакладка, ПредЗуб));
		//Если ИскомаяЗакладка.Количество() > 0 Тогда
		//	ВводимыйТекст = ИскомаяЗакладка[0].ВводимыйТекст;
		//Иначе
		//	ВводимыйТекст = "";
		//КонецЕсли; 
		//ОбновитьSVGПодбор();
	КонецЕсли;	


