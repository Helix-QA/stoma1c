// Процедура, устанавливает Структурную единицу существующим элемантам справочника.
//
Процедура ДобавитьСтруктурнуюЕдиницуВВидыНачислений() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиСотрудников.Сотрудник,
		|	НастройкиСотрудников.СтруктурнаяЕдиница
		|ИЗ
		|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников";
	ТаблицаНастройкиСотрудников = Запрос.Выполнить().Выгрузить();

	ВыборкаЭлементов = Справочники.НачисленияИУдержанияСотрудников.Выбрать();
	Пока ВыборкаЭлементов.Следующий() Цикл
		Если ТаблицаНастройкиСотрудников.Найти(ВыборкаЭлементов.Владелец, "Сотрудник") <> Неопределено и НЕ ВыборкаЭлементов.ЭтоГруппа Тогда
			ЭлементОбъект = ВыборкаЭлементов.ПолучитьОбъект();
			ЭлементОбъект.СтруктурнаяЕдиница = ТаблицаНастройкиСотрудников.Найти(ВыборкаЭлементов.Владелец, "Сотрудник").СтруктурнаяЕдиница;
			ЭлементОбъект.Записать();
		КонецЕсли;
	КонецЦикла;
	
