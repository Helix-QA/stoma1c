// Процедура - При записи
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка = Истина Тогда 
		Возврат;
	КонецЕсли;
	
	АктуализироватьЭтапыВидаСделки();
	АктуализироватьТриггерныеСобытия();
	
КонецПроцедуры



