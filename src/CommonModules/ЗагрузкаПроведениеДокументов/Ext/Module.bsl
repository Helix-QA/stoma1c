						НаборЗаписей.Отбор.Основание.Значение 		= ДокументРеализация.Ссылка;
						НаборЗаписей.Отбор.Основание.Использование 	= Истина;
						НаборЗаписей.ОбменДанными.Загрузка 			= Истина;
						НаборЗаписей.Записать(Истина);
					Исключение
