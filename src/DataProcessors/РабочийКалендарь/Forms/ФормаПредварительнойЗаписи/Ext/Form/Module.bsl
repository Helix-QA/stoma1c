#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура изменяет пометку кнопки День.
//
Процедура КомандаДень(Команда)	
	ПЗГрафикаРежимОтображения = 0;
	ПЗФильтрГрафикаОбновить   = Истина;
	// ОбновлениеСтраницыЖурналПредварительнойЗаписи(,Истина);

    УстановитьСтраницуМенеджера(Элементы.День);	
	ОбновитьГрафик(,Истина);	
КонецПроцедуры

&НаКлиенте
// Процедура изменяет пометку кнопки Неделя.
//
Процедура КомандаНеделя(Команда)
	ПЗГрафикаРежимОтображения = 1;
	УстановитьСтраницуМенеджера(Элементы.Неделя);	
	ОбновитьГрафик(,Истина);	
КонецПроцедуры

&НаКлиенте
// Процедура - Установить страницу менеджера.
//
Процедура УстановитьСтраницуМенеджера(ЭлементГруппировки)	
	Элементы.День.Пометка 			= Ложь;
	Элементы.Неделя.Пометка 		= Ложь;	
	ЭлементГруппировки.Пометка		= Истина;
	Если ЭлементГруппировки = Элементы.Неделя Тогда
		Элементы.ГруппаКоманднаяПанельДни.Видимость 	= Ложь;
		Элементы.ГруппаКоманднаяПанельНедели.Видимость  = Истина;
	Иначе
		Элементы.ГруппаКоманднаяПанельДни.Видимость 	= Истина;
		Элементы.ГруппаКоманднаяПанельНедели.Видимость  = Ложь;		
	КонецЕсли;	
	
	УстановитьЦветГруппыКнопки();
КонецПроцедуры

