&НаСервере
// При изменении выбора шаблона обследований, сервер
//
Процедура ШаблонОбследованияПриИзмененииСервер() 
	
	// Если шаблон не указан очистить документ обследования
	Если НЕ ЗначениеЗаполнено(Объект.ШаблонОбследования) Тогда
		HTMLПолеОбследование = "";
		Возврат;                                                                 
	Иначе
		HTMLПолеОбследование = СтрЗаменить(Объект.ШаблонОбследования.HTMLШаблон, "contenteditable=""true""", "contenteditable=""false"""); 
	КонецЕсли;
	
	// Заполнить таблицу реквизитов шаблона обследования
	ДОРеквизитыШаблонОбследования.Очистить();		
	Если ЗначениеЗаполнено(Объект.ШаблонОбследования) Тогда	
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ШаблоныОбследований.Параметр КАК Реквизит,
		|	ЗначенияПараметровОбследований.Ссылка КАК СписокВыбораЗначение,
		|	ЗначенияПараметровОбследований.Представление КАК СписокВыбораПредставление,
		|	ШаблоныОбследований.Параметр.ТипПараметра КАК РеквизитТип,
		|	ШаблоныОбследований.Параметр.АлгоритВычисления КАК АлгоритВычисления,
		|	ШаблоныОбследований.Параметр.ТипЗначения КАК ТипЗначения,
		|	ШаблоныОбследований.Параметр.ПривязкаКЗубам КАК ПривязкаКЗубам,
		|	ШаблоныОбследований.Параметр.ПодчиненРеквизиту КАК ПодчиненРеквизиту,
		|	ШаблоныОбследований.ПорядковыйНомер КАК ПорядковыйНомер
		|ИЗ
		|	Справочник.ШаблоныОбследований.СоответствияПараметрам КАК ШаблоныОбследований
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
		|		ПО ШаблоныОбследований.Параметр = ЗначенияПараметровОбследований.Владелец
		|ГДЕ
		|	ШаблоныОбследований.Ссылка = &Ссылка";		
		Запрос.УстановитьПараметр("Ссылка", Объект.ШаблонОбследования);	
		Результат     = Запрос.Выполнить();		
		ВыборкаЗаписи = Результат.Выбрать();		
		Пока ВыборкаЗаписи.Следующий() Цикл
			
			НоваяСтрока = ДОРеквизитыШаблонОбследования.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаЗаписи);
			НоваяСтрока.РеквизитИдентификатор = НоваяСтрока.Реквизит.УникальныйИдентификатор();
			ТипЗначенияСтрокой = "";
			Если Строка(ВыборкаЗаписи.ТипЗначения) = "Строка" 
			 ИЛИ Строка(ВыборкаЗаписи.ТипЗначения) = "Число" 
			 ИЛИ Строка(ВыборкаЗаписи.ТипЗначения) = "Булево"
			 ИЛИ Строка(ВыборкаЗаписи.ТипЗначения) = "Дата" 
			 ИЛИ Строка(ВыборкаЗаписи.ТипЗначения) = "Дополнительные значения характеристик" 
			 ИЛИ Строка(ВыборкаЗаписи.ТипЗначения) = "Динамический" Тогда
				ТипЗначенияСтрокой	= СтрЗаменить(ВыборкаЗаписи.ТипЗначения, " ", "");
			Иначе
				ТипЗначенияСтрокой = Строка(Метаданные.НайтиПотипу(ВыборкаЗаписи.ТипЗначения.Типы()[0]));
				Если ТипЗначенияСтрокой = "Пациенты, контрагенты" Тогда
					ТипЗначенияСтрокой = "Контрагенты";
				КонецЕсли;
			КонецЕсли;	  			
			НоваяСтрока.ТипЗначенияСтрокой = ТипЗначенияСтрокой;
		КонецЦикла;
	КонецЕсли;
	
	// Заполнить таблицу квалификаторов шаблонов
	ДОКвалификаторыРеквизитовОбследования.Очистить();	
	Если ЗначениеЗаполнено(Объект.ШаблонОбследования) Тогда		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ШаблоныОбследований.Параметр,
		|	ШаблоныОбследований.Параметр.ТипЗначения КАК ТипЗначения
		|ИЗ
		|	Справочник.ШаблоныОбследований.СоответствияПараметрам КАК ШаблоныОбследований
		|ГДЕ
		|	ШаблоныОбследований.Ссылка = &Ссылка";		
		Запрос.УстановитьПараметр("Ссылка", Объект.ШаблонОбследования);		
		Результат = Запрос.Выполнить();
		Выб       = Результат.Выбрать();		                                                        
		Пока Выб.Следующий() Цикл
			Если Выб.ТипЗначения.СодержитТип(Тип("Число")) Тогда
				НоваяСтрока          = ДОКвалификаторыРеквизитовОбследования.Добавить();
				НоваяСтрока.Параметр = Выб.Параметр;
				НоваяСтрока.Длина 	 = Выб.ТипЗначения.КвалификаторыЧисла.Разрядность;
				НоваяСтрока.Точность = Выб.ТипЗначения.КвалификаторыЧисла.РазрядностьДробнойЧасти;
			ИначеЕсли Выб.ТипЗначения.СодержитТип(Тип("Строка")) Тогда
				НоваяСтрока          = ДОКвалификаторыРеквизитовОбследования.Добавить();
				НоваяСтрока.Параметр = Выб.Параметр;
				НоваяСтрока.Длина 	 = Выб.ТипЗначения.КвалификаторыСтроки.Длина;
				НоваяСтрока.Точность = 1;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Обработчик HTML документа при окончании формирования
//
Процедура HTMLПолеОбследованиеДокументСформирован(Элемент) 
	
	// Если Элемент.Документ.body = Неопределено ИЛИ HTMLДокументОбследованиеБлокироватьСобытиеСформирован = Истина Тогда
	//	ОбновитьДинамическиеРеквизитыОбследования();
	//	Возврат 
	// КонецЕсли;	
	Если ЗначениеЗаполнено(HTMLПолеОбследование) Тогда    
		document = Элементы.HTMLПолеОбследование.Документ;
		// Заполнение одиночных реквизитов
		Для Каждого СтрокаТ Из ДОЗначенияРеквизитовОбследования Цикл
			ПараметрыРеквизита = ПолучитьПараметрыРеквизитаШаблонаОбследования(СтрокаТ.РеквизитИдентификатор);
			Если ПараметрыРеквизита <> Неопределено Тогда // И НЕ ПараметрыРеквизита.ПривязкаКЗубам 
				HtmlЭлемент = document.getElementById(СтрокаТ.РеквизитИдентификатор);
				Если HtmlЭлемент <> Неопределено Тогда		
					Если HtmlЭлемент.type = "checkbox" Тогда			
						HtmlЭлемент.checked = СтрокаТ.РеквизитЗначениеСтрокой;
					Иначе
						ПредставлениеЗуба = ?(ПараметрыРеквизита.ПривязкаКЗубам, ?(ЗначениеЗаполнено(СтрокаТ.ЗубЗначение), Строка(СтрокаТ.ЗубЗначение) + ", ", ""), "");
						HtmlЭлемент.innerHTML               = Строка(ПредставлениеЗуба) + Строка(СтрокаТ.РеквизитЗначениеСтрокой);
						HtmlЭлемент.parentElement.className = "element";
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;	
		// Заполнение списочных динамических реквизитов 
		МассивВыведенныеРеквизиты = Новый Массив;
		Для Каждого СтрокаТ Из ДОЗначенияРеквизитовОбследования Цикл
			ПараметрыРеквизита = ПолучитьПараметрыРеквизитаШаблонаОбследования(СтрокаТ.РеквизитИдентификатор);
			// Если это одиночный реквизит
			Если ПараметрыРеквизита <> Неопределено И МассивВыведенныеРеквизиты.Найти(ПараметрыРеквизита.Реквизит) = Неопределено Тогда // И ПараметрыРеквизита.ПривязкаКЗубам 
				МассивВыведенныеРеквизиты.Добавить(ПараметрыРеквизита.Реквизит);
				// Ищем первую строку
				HtmlЭлемент = Элементы.HTMLПолеОбследование.Документ.getElementById(СтрокаТ.РеквизитИдентификатор+",Addition");
				Если HtmlЭлемент <> Неопределено Тогда
					// Ищем все строки данных
					НайденныеСтроки = ДОЗначенияРеквизитовОбследования.НайтиСтроки(Новый Структура("Реквизит",ПараметрыРеквизита.Реквизит));
					Если НайденныеСтроки.Количество() > 0 Тогда 
						HTMLTable       = ПолучитьHTMLTableОбследование(HtmlЭлемент);	
						Если HTMLTable.rows.length = 1 Тогда
							Row1            = ПолучитьHTMLRowОбследование(HTMLTable.rows,0);
							Cell1           = ?(Row1 <> Неопределено, ПолучитьHTMLCellОбследование(Row1.cells,0),Неопределено);
							ЗаголовокСписка = ?(Cell1 <> Неопределено, Cell1.innerHTML,"");
							Cell1.innerHTML = "";
							// Цикл заполнения таблицы
							Для Каждого СтрокаТ2 ИЗ НайденныеСтроки Цикл
										
								// Подготовка данных
								ОсновнойИД             = СтрокаТ2.РеквизитИдентификатор;
								ДополнительныйИД       = СтрокаТ2.ЗубИдентификатор;
								ЗубПредставление       = ?(ПараметрыРеквизита.ПривязкаКЗубам, ?(ЗначениеЗаполнено(СтрокаТ2.ЗубЗначение),Строка(СтрокаТ2.ЗубЗначение) + ", ",""), "");
								ЗначениеПредставление  = ?(ЗначениеЗаполнено(СтрокаТ2.РеквизитЗначениеСтрокой),Строка(СтрокаТ2.РеквизитЗначениеСтрокой),"");
								// Вставляем строки
								NewRow                 = HTMLTable.insertRow(HTMLTable.rows.length - 1);
								NewCell                = NewRow.insertCell(0);
								NewCell.innerHTML      = ?(HTMLTable.rows.length = 2, ЗаголовокСписка, "");
								NewCell                = NewRow.insertCell(1);
								NewCell.innerHTML      = "<A id=" + ОсновнойИД + "," + ДополнительныйИД + " href=about:>" + ЗубПредставление + ЗначениеПредставление + "</A>";
								NewCell.className      = "element";						
							КонецЦикла;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;	
		// Обновить динамически вычисляемые реквизиты обследования
	    ОбновитьДинамическиеРеквизитыОбследования();
		HTMLДокументОбследованиеБлокироватьСобытиеСформирован = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик клика по HTML документу 
//
Процедура HTMLПолеОбследованиеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка, ЗубДляПодбора = Неопределено, ЗначениеРодительскогоРеквизита = Неопределено)
	
	СтандартнаяОбработка = Ложь;	
	Если ДанныеСобытия.Element <> Неопределено  Тогда
		
		СсылкаЭлемент = ПолучитьHTMLЭлементОбследование(ДанныеСобытия.Element);
		// Прервать если HTML не найден
		Если СсылкаЭлемент = Неопределено Тогда
			Возврат;
		КонецЕсли;	
		
		РеквизитИД              = СсылкаЭлемент.id;
	    Реквизит                = ПолучитьПараметрыРеквизитаШаблонаОбследования(РеквизитИД);
		
		Если Реквизит = Неопределено Тогда
			Возврат;
		КонецЕсли;	

		ЗначениеРеквизитаПред   = Реквизит.РеквизитЗначение;
		ЗначениеРеквизита       = Неопределено;	
		ПривязанЗуб             = Реквизит.ЗубЗначение;
		ПредставлениеЗначения   = Неопределено;
		ПустоеПолеВыбор         = "<выбрать...>";
		ПустоеПолеДобавить      = "<добавить...>";
		УдалитьРеквизит         = Ложь;

		МассивДанных            = Новый Массив;
		МассивВыбранныхЗубов    = Неопределено;
		
        // Превать если реквизит не найден либо он динамический
		Если НЕ ЗначениеЗаполнено(Реквизит) ИЛИ Реквизит.Динамический = Истина Тогда
			Возврат;
		КонецЕсли; 
			
		// Если тип реквизита Число	
		Если Реквизит.ЗначениеТип = "Число" Тогда					
			
			мсСтрКвалификаторы = ДОКвалификаторыРеквизитовОбследования.НайтиСтроки(Новый Структура("Параметр", Реквизит.Реквизит));
			Если мсСтрКвалификаторы.Количество() <> 0 Тогда
				Длина	 = мсСтрКвалификаторы[0].Длина;
				Точность = мсСтрКвалификаторы[0].Точность;
			Иначе
				Длина	 = 6;
				Точность = 1;
			КонецЕсли;	

			ОписаниеОповещения = Новый ОписаниеОповещения("HTMLПолеОбследованиеПриНажатииПсолеВводаЧисла", ЭтотОбъект, Новый Структура("ЗначениеРеквизитаПред, МассивДанных, ПустоеПолеВыбор", ЗначениеРеквизитаПред, МассивДанных, ПустоеПолеВыбор));
			ПоказатьВводЧисла(ОписаниеОповещения, ЗначениеРеквизитаПред,,Длина, Точность);	
			
		// Если тип реквизита Дата
		ИначеЕсли Реквизит.ЗначениеТип = "Дата" Тогда					
			
			СтруктураПараметров = Новый Структура("Дата",?(ЗначениеЗаполнено(ЗначениеРеквизитаПред),ЗначениеРеквизитаПред,ТекущаяДата()));
			ОписаниеОповещения = Новый ОписаниеОповещения("HTMLПолеОбследованиеПослеВыбораДаты", ЭтотОбъект, Новый Структура("ЗначениеРеквизитаПред, МассивДанных, ПустоеПолеВыбор", ЗначениеРеквизитаПред, МассивДанных, ПустоеПолеВыбор));
			ОткрытьФорму("ОбщаяФорма.ВыборДаты", СтруктураПараметров,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
			
				
		// Если тип реквизита ЗначенияПараметровОбследований
		ИначеЕсли Реквизит.ЗначениеТип = "ЗначенияПараметровОбследований" Тогда		
			
			ТекущееЗначение         = Неопределено;			
			СписокЗначенийПараметра = Новый СписокЗначений;
			ЗначениеРеквизитаПред   = Неопределено;		
			МассивСтрок             = ДОРеквизитыШаблонОбследования.НайтиСтроки(Новый Структура("Реквизит", Реквизит.Реквизит));
			Для Каждого СтрокаТ Из МассивСтрок Цикл			
				ЭлементСЗ = СписокЗначенийПараметра.Добавить(СтрокаТ.СписокВыбораЗначение, СтрокаТ.СписокВыбораПредставление);
				Если Строка(СтрокаТ.СписокВыбораЗначение) = СсылкаЭлемент.innerText Тогда
					ТекущееЗначение       = СтрокаТ.СписокВыбораЗначение;
					ЗначениеРеквизитаПред = ЭлементСЗ;
				КонецЕсли;
			КонецЦикла;		
			
			ОписаниеОповещения = Новый ОписаниеОповещения("HTMLПолеОбследованиеПриНажатииПослеВыбораИзСписка", ЭтотОбъект, 
										Новый Структура("МассивДанных, ПустоеПолеВыбор, ТекущееЗначение", МассивДанных, ПустоеПолеВыбор, ТекущееЗначение));
			ПоказатьВыборИзСписка(ОписаниеОповещения, СписокЗначенийПараметра,Элемент,ЗначениеРеквизитаПред);	
			
		ИначеЕсли Реквизит.ЗначениеТип = "Булево" Тогда			
			ЗначениеРеквизита     = СсылкаЭлемент.Checked;
			СтандартнаяОбработка  = Истина;		
			
			СтруктураДобавления = Новый Структура("ПредставлениеЗначения,ПривязанЗуб,ЗначениеРеквизита",Неопределено,Неопределено,ЗначениеРеквизита);
			МассивДанных.Добавить(СтруктураДобавления);
			
		// Если тип реквизита Строка	
		ИначеЕсли Реквизит.ЗначениеТип = "Строка" Тогда	
			ПодчиненДиагнозу = ПроверитьДиагнозНаПодчиненныеШаблоны(Реквизит.Реквизит, ЗначениеРодительскогоРеквизита);

			СоставнойПодборРежим = Реквизит.ПривязкаКЗубам;
			ПараметрыФормы = Новый Структура();
			ПараметрыФормы.Вставить("СоставнойПодборРежим"			, СоставнойПодборРежим);
			ПараметрыФормы.Вставить("Текст"							, Реквизит.РеквизитЗначениеСтрокой);
			ПараметрыФормы.Вставить("ПодчиненныйРеквизит"			, Реквизит.Реквизит);
            ПараметрыФормы.Вставить("ТипЗубнойФормулы"				, ТипЗубнойФормулы);
			ПараметрыФормы.Вставить("Зуб"							, ?(ЗубДляПодбора <> Неопределено,ЗубДляПодбора, ПривязанЗуб));
			ПараметрыФормы.Вставить("ПодчиненДиагнозу"				, ?(ПодчиненДиагнозу, ЗначениеРодительскогоРеквизита, Неопределено));
			ПараметрыФормы.Вставить("РазрешитьМножественныйВыбор"	, ?(ПривязанЗуб = Неопределено,Истина,Ложь));
            ПараметрыФормы.Вставить("ШаблонОбследования"			, Объект.ШаблонОбследования);
			ПараметрыФормы.Вставить("ПараметрыОбследования"			, ДОЗначенияРеквизитовОбследования);
			ПараметрыФормы.Вставить("Прием"							, Объект.Ссылка);
			
			//("СоставнойПодборРежим,Текст,ПодчиненныйРеквизит,ТипЗубнойФормулы,Зуб,ПодчиненДиагнозу,РазрешитьМножественныйВыбор,ШаблонОбследования,ПараметрыОбследования"
			//,СоставнойПодборРежим
			//,Реквизит.РеквизитЗначениеСтрокой
			//,Реквизит.Реквизит
			//,ТипЗубнойФормулы
			//,?(ЗубДляПодбора <> Неопределено,ЗубДляПодбора, ПривязанЗуб)
			//,?(ПодчиненДиагнозу, ЗначениеРодительскогоРеквизита, Неопределено)
			//,?(ПривязанЗуб = Неопределено,Истина,Ложь)
			//,Объект.ШаблонОбследования
			//,ДОЗначенияРеквизитовОбследования);
			//
			// Открыть форму подбора
			ДопПараметры = Новый Структура();
			ДопПараметры.Вставить("ЗначениеРеквизитаПред"	, ЗначениеРеквизитаПред);
			ДопПараметры.Вставить("СоставнойПодборРежим" 	, СоставнойПодборРежим);
			ДопПараметры.Вставить("МассивДанных"         	, МассивДанных);
			ДопПараметры.Вставить("Реквизит"             	, Реквизит);
			ДопПараметры.Вставить("РеквизитИД"           	, РеквизитИД);
			ДопПараметры.Вставить("ПустоеПолеВыбор"      	, ПустоеПолеВыбор);
			ДопПараметры.Вставить("ПустоеПолеДобавить"   	, ПустоеПолеДобавить);
			ДопПараметры.Вставить("МассивВыбранныхЗубов" 	, МассивВыбранныхЗубов);
			ДопПараметры.Вставить("ПривязанЗуб"          	, ПривязанЗуб);
			ДопПараметры.Вставить("СсылкаЭлемент"       	, СсылкаЭлемент);
			ДопПараметры.Вставить("ШаблонОбследования"   	, Объект.ШаблонОбследования);
			ДопПараметры.Вставить("ПараметрыОбследования"   , ДОЗначенияРеквизитовОбследования);
			
			// ДопПараметры = Новый Структура("ЗначениеРеквизитаПред, СоставнойПодборРежим, ПустоеПолеВыбор, МассивДанных, ПустоеПолеДобавить, СсылкаЭлемент", ЗначениеРеквизитаПред, СоставнойПодборРежим, ПустоеПолеВыбор, МассивДанных, ПустоеПолеДобавить, СсылкаЭлемент);
			ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытыШаблоныТекстаРеквизитовОбследованийСтрока", ЭтотОбъект, ДопПараметры);
			
			ОткрытьФорму("Справочник.ШаблоныТекстаРеквизитовОбследований.Форма.ФормаВводаТекстаРеквизита",ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
			
			// Подбор диагноза и зуба	
		ИначеЕсли Реквизит.ЗначениеТип = "Диагнозы" Тогда // И Реквизит.ПривязкаКЗубам = Истина
			
			ПараметрыФормы = Новый Структура("СоставнойПодборРежим, ТипЗубнойФормулы, ТекущаяСтрока, Зуб, РазрешитьМножественныйВыбор"
			,Реквизит.ПривязкаКЗубам
			,ТипЗубнойФормулы
			,ЗначениеРеквизитаПред
			,ПривязанЗуб
			,?(ПривязанЗуб = Неопределено, Истина, Ложь)); //1 = Истина			
			
			// Открыть форму подбора
			ДопПараметры = Новый Структура();
			ДопПараметры.Вставить("ЗначениеРеквизитаПред", ЗначениеРеквизитаПред);
			ДопПараметры.Вставить("СоставнойПодборРежим" , СоставнойПодборРежим);
			ДопПараметры.Вставить("МассивДанных"         , МассивДанных);
			ДопПараметры.Вставить("Реквизит"             , Реквизит);
			ДопПараметры.Вставить("РеквизитИД"           , РеквизитИД);
			ДопПараметры.Вставить("ПустоеПолеВыбор"      , ПустоеПолеВыбор);
			ДопПараметры.Вставить("ПустоеПолеДобавить"   , ПустоеПолеДобавить);
			ДопПараметры.Вставить("МассивВыбранныхЗубов" , МассивВыбранныхЗубов);
			ДопПараметры.Вставить("ПривязанЗуб"          , ПривязанЗуб);
			ДопПараметры.Вставить("СсылкаЭлемент"        , СсылкаЭлемент);
			ДопПараметры.Вставить("ЗначениеРеквизита"    , ЗначениеРеквизита); 		
			ДопПараметры.Вставить("ШаблонОбследования"   , Объект.ШаблонОбследования);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытыШаблоныТекстаРеквизитовОбследованийДиагнозы", ЭтотОбъект, ДопПараметры);
			
			ОткрытьФорму("Справочник.Диагнозы.ФормаВыбора", ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	

		Иначе 
			
			Если ЗначениеЗаполнено(Реквизит.ЗначениеТип) Тогда
				
				ДопПараметры = Новый Структура("ЗначениеРеквизитаПред, ПустоеПолеВыбор, СсылкаЭлемент, Реквизит", ЗначениеРеквизитаПред, ПустоеПолеВыбор, СсылкаЭлемент, Реквизит); 			
				Оповещение = Новый ОписаниеОповещения("ПослеВыбораЗначенияПараметра", ЭтотОбъект, ДопПараметры);
				ОткрытьФорму("Справочник." + Реквизит.ЗначениеТип + ".ФормаВыбора", Новый Структура("ТекущаяСтрока", ЗначениеРеквизитаПред),,,,, Оповещение)
				
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для заполняемого реквизита указан некорректный тип.");	
			КонецЕсли;

		КонецЕсли;
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура - HTMLПоле обследование при нажатии псоле ввода числа
//
// Параметры:
//  Число					 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура HTMLПолеОбследованиеПриНажатииПсолеВводаЧисла(Число, ДополнительныеПараметры) Экспорт
	
	ЗначениеРеквизитаПред = ДополнительныеПараметры.ЗначениеРеквизитаПред;
	МассивДанных = ДополнительныеПараметры.МассивДанных;
	ПустоеПолеВыбор = ДополнительныеПараметры.ПустоеПолеВыбор;
	ЗначениеРеквизита = ?(Число = Неопределено,ЗначениеРеквизитаПред, Число);
		
	ПредставлениеЗначения = ?(ЗначениеЗаполнено(ЗначениеРеквизита),Строка(ЗначениеРеквизита),ПустоеПолеВыбор);
	
	СтруктураДобавления = Новый Структура("ПредставлениеЗначения,ПривязанЗуб,ЗначениеРеквизита",ПредставлениеЗначения,Неопределено,ЗначениеРеквизита);
	МассивДанных.Добавить(СтруктураДобавления);

КонецПроцедуры

&НаКлиенте
// Процедура - HTMLПоле обследование после выбора даты
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура HTMLПолеОбследованиеПослеВыбораДаты(Результат, ДополнительныеПараметры) Экспорт
	
	ЗначениеРеквизитаПред = ДополнительныеПараметры.ЗначениеРеквизитаПред;
	МассивДанных = ДополнительныеПараметры.МассивДанных;
	ПустоеПолеВыбор = ДополнительныеПараметры.ПустоеПолеВыбор;
	
	
	Результат = Результат;
	Если НЕ Результат = Неопределено Тогда
		Результат = Формат(Результат,"ДФ=dd.MM.yyyy");
	Иначе
		Результат = ЗначениеРеквизитаПред;
	КонецЕсли;	 
	ПредставлениеЗначения = ?(ЗначениеЗаполнено(Результат),Строка(Результат),ПустоеПолеВыбор);
	СтруктураДобавления = Новый Структура("ПредставлениеЗначения,ПривязанЗуб,ЗначениеРеквизита",ПредставлениеЗначения,Неопределено,Результат);
	МассивДанных.Добавить(СтруктураДобавления);

КонецПроцедуры

&НаКлиенте
// Процедура - HTMLПоле обследование при нажатии после выбора из списка
//
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура HTMLПолеОбследованиеПриНажатииПослеВыбораИзСписка(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	МассивДанных = ДополнительныеПараметры.МассивДанных;
	ПустоеПолеВыбор = ДополнительныеПараметры.ПустоеПолеВыбор;
	ТекущееЗначение = ДополнительныеПараметры.ТекущееЗначение;
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Если ТекущееЗначение = Неопределено Тогда
			ЗначениеРеквизита = "";
		Иначе
			ЗначениеРеквизита = ТекущееЗначение;				
		КонецЕсли;
	Иначе 
		ЗначениеРеквизита = ВыбранныйЭлемент.Значение;
	КонецЕсли;
	ПредставлениеЗначения = ?(ЗначениеЗаполнено(ЗначениеРеквизита),Строка(ЗначениеРеквизита),ПустоеПолеВыбор);
	
	СтруктураДобавления = Новый Структура("ПредставлениеЗначения,ПривязанЗуб,ЗначениеРеквизита",ПредставлениеЗначения,Неопределено,ЗначениеРеквизита);
	МассивДанных.Добавить(СтруктураДобавления);
	
КонецПроцедуры 

&НаКлиенте 
// Процедура - После выбора значения параметра.
//
Процедура ПослеВыбораЗначенияПараметра(Результат, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) И ТипЗнч(Результат) = Тип("СправочникСсылка.Контрагенты") Тогда		
		
		УдалитьРеквизит = Ложь;                    
		МассивВыбранныхЗубов = Новый Массив; 
		ПривязанЗуб = Ложь;   
		ПустоеПолеДобавить = "";
		ПредставлениеЗначения = Строка(Результат);
		
		МассивДанных = Новый Массив;		
		ЗначениеРеквизита            = ?(Результат <> Неопределено,Результат, Параметры.ЗначениеРеквизитаПред);
		ПредставлениеЗначения        = ?(ЗначениеЗаполнено(ЗначениеРеквизита),Строка(ЗначениеРеквизита),Параметры.ПустоеПолеВыбор);		
		СтруктураДобавления = Новый Структура("ПредставлениеЗначения, ПривязанЗуб, ЗначениеРеквизита", ПредставлениеЗначения, Неопределено, ЗначениеРеквизита);
		МассивДанных.Добавить(СтруктураДобавления);		
		
		ЗначенияСФормы = Новый Структура();
		ЗначенияСФормы.Вставить("УдалитьРеквизит", УдалитьРеквизит);
		ЗначенияСФормы.Вставить("ПредставлениеЗначения", ПредставлениеЗначения);
		ЗначенияСФормы.Вставить("МассивДанных", МассивДанных);
		ЗначенияСФормы.Вставить("Реквизит", Параметры.Реквизит);
		ЗначенияСФормы.Вставить("РеквизитИД", Параметры.СсылкаЭлемент.id);
		ЗначенияСФормы.Вставить("ПустоеПолеВыбор", Параметры.ПустоеПолеВыбор);
		ЗначенияСФормы.Вставить("ПустоеПолеДобавить", ПустоеПолеДобавить);
		ЗначенияСФормы.Вставить("МассивВыбранныхЗубов", МассивВыбранныхЗубов);
		ЗначенияСФормы.Вставить("ПривязанЗуб", ПривязанЗуб);
		ЗначенияСФормы.Вставить("СсылкаЭлемент", Параметры.СсылкаЭлемент); 
		ЗначенияСФормы.Вставить("ЗначениеРеквизита",Параметры.ЗначениеРеквизитаПред); 
		ПослеВыбораЗначенияОбследования(ЗначенияСФормы);
		
	Иначе                                       
		МассивДанных = Новый Массив;              		
		ЗначениеРеквизита            = ?(Результат <> Неопределено,Результат, Параметры.ЗначениеРеквизитаПред);
		ПредставлениеЗначения        = ?(ЗначениеЗаполнено(ЗначениеРеквизита),Строка(ЗначениеРеквизита),Параметры.ПустоеПолеВыбор);
		
		СтруктураДобавления = Новый Структура("ПредставлениеЗначения, ПривязанЗуб, ЗначениеРеквизита", ПредставлениеЗначения, Неопределено, ЗначениеРеквизита);
		МассивДанных.Добавить(СтруктураДобавления);  
		
	КонецЕсли; 

КонецПроцедуры	

&НаСервереБезКонтекста 
// Функция, Проверить диагноз на подчиненные шаблоны.
//
Функция ПроверитьДиагнозНаПодчиненныеШаблоны(Реквизит, Диагноз)
	
	Запрос       = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ВЫБОР
	|		КОГДА ШаблоныТекстаРеквизитовОбследований.ПодчиненДиагнозу = &Диагноз
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Подчинен
	|ИЗ
	|	Справочник.ШаблоныТекстаРеквизитовОбследований КАК ШаблоныТекстаРеквизитовОбследований
	|ГДЕ
	|	НЕ ШаблоныТекстаРеквизитовОбследований.ПометкаУдаления
	|	И ШаблоныТекстаРеквизитовОбследований.ПодчиненРеквизиту = &ПодчиненРеквизиту
	|	И ШаблоныТекстаРеквизитовОбследований.ПодчиненДиагнозу = &Диагноз";
	
	Запрос.УстановитьПараметр("ПодчиненРеквизиту", Реквизит);
	Запрос.УстановитьПараметр("Диагноз", Диагноз);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Подчинен, Ложь);  
	
КонецФункции

&НаКлиенте
// Процедура - После выбора значения обследования
//
// Параметры:
//  ЗначенияСФормы	 - 	 - 
//
Процедура ПослеВыбораЗначенияОбследования(ЗначенияСФормы)
	
	// 02.11.2022 300103, убрал проверки на привязку к зубу, теперь для каждого диагноза
	// должна создаваться отдельная запись в регистре.
	// Установить значение параметра если оно изменилось
	Если НЕ ЗначенияСФормы.УдалитьРеквизит И ЗначенияСФормы.ПредставлениеЗначения <> ЗначенияСФормы.СсылкаЭлемент.innerText Тогда			
		Если ЗначенияСФормы.МассивДанных.Количество() = 0 Тогда
			
		Иначе
			
			//Модифицированность = Истина;
			ПервыйЭлемент      = Истина;
			// Получить признак первого добавления данных в реквизит
			ПервоеДобавлениеВРеквизит = ПолучитьЗначениеРеквизитаИзБуфераДанныхобследования(ЗначенияСФормы.СсылкаЭлемент.id).Количество() = 0;
			// Обработка массива введенных данных			
			Для Каждого ЭлементМ ИЗ ЗначенияСФормы.МассивДанных Цикл
				
				Если ЗначениеЗаполнено(ЭлементМ.ЗначениеРеквизита) Тогда
					ЕстьДубли = Ложь;
					Для Каждого ЭлементФК Из ДОЗначенияРеквизитовОбследования Цикл
						Если ЗначенияСФормы.Реквизит.Реквизит = ЭлементФК.Реквизит 
							И ЭлементМ.ЗначениеРеквизита = ЭлементФК.РеквизитЗначение 
							И ?(ЗначениеЗаполнено(ЭлементМ.ПривязанЗуб), ЭлементМ.ПривязанЗуб, ПредопределенноеЗначение("Перечисление.Зубы.ПустаяСсылка")) = ЭлементФК.ЗубЗначение Тогда
							ЕстьДубли = Истина;
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
					Если Не ЗначениеЗаполнено(ЭлементМ.ЗначениеРеквизита) Или ЕстьДубли Тогда
						ПервоеДобавлениеВРеквизит = Ложь;
						Продолжить;  
					КонецЕсли;
				КонецЕсли;
			
				// Добавление первой строки
				Если ПервыйЭлемент Тогда						
					Если НЕ ЗначенияСФормы.Реквизит.ЗначениеТип = "Булево" Тогда						
						Если ЗначенияСФормы.ПредставлениеЗначения <> ЗначенияСФормы.ПустоеПолеВыбор И ЭлементМ.ПредставлениеЗначения <> ЗначенияСФормы.ПустоеПолеДобавить Тогда					
							ЗначенияСФормы.СсылкаЭлемент.innerHTML               = ЭлементМ.ПредставлениеЗначения;
							ЗначенияСФормы.СсылкаЭлемент.parentElement.className = "element";
						Иначе			
							ЗначенияСФормы.СсылкаЭлемент.innerHTML               = ЗначенияСФормы.ПустоеПолеВыбор;
							ЗначенияСФормы.СсылкаЭлемент.parentElement.className = "add_element";		
						КонецЕсли;		
					КонецЕсли;
					Если ПервоеДобавлениеВРеквизит Тогда
						ОсновнойИД        = ПолучитьВедущийИдентификторРеквизитаОбследования(ЗначенияСФормы.РеквизитИД);
						// Подмена подчиненного идентификатора, для выбранного элемента
						ДополнительныйИД  = Новый УникальныйИдентификатор;
						// Если реквизит новый дописываем составной ИД
						ЗначенияСФормы.СсылкаЭлемент.id  = ОсновнойИД + "," + ДополнительныйИД;
						ЗначенияСФормы.РеквизитИД        = ЗначенияСФормы.СсылкаЭлемент.id;	
					КонецЕсли;
				КонецЕсли;
				
				// Добавление остальных строк
				Если ПервоеДобавлениеВРеквизит И НЕ ПервыйЭлемент Тогда				
					ОсновнойИД        = ПолучитьВедущийИдентификторРеквизитаОбследования(ЗначенияСФормы.РеквизитИД);
					// Подмена подчиненного идентификатора, для выбранного элемента
					ДополнительныйИД  = Новый УникальныйИдентификатор;
					ЗначенияСФормы.РеквизитИД        = ОсновнойИД + "," + ДополнительныйИД ;
					
					// Дополняем таблицу новой строке для последующего добавления
					HTMLTable           = ПолучитьHTMLTableОбследование(ЗначенияСФормы.СсылкаЭлемент);
					Если НЕ HTMLTable = Неопределено
						И НЕ HTMLTable.rows = Неопределено Тогда
						
						NewRow              = HTMLTable.insertRow(HTMLTable.rows.length);
						NewCell             = NewRow.insertCell(0);
						NewCell             = NewRow.insertCell(1);
						NewCell.innerHTML   = "<A id=" + ОсновнойИД + "," + ДополнительныйИД + " href=about:>" + ЭлементМ.ПредставлениеЗначения + "</A>";
						NewCell.className   = "element"; 
						
					КонецЕсли;
					
				Иначе
					ПервыйЭлемент = Ложь;
				КонецЕсли;
				
				// Добавить значение реквизита в буфер данных			
				ДобавитьЗначениеРеквизитаВБуферДанныхОбследование(ЗначенияСФормы.РеквизитИД, ЗначенияСФормы.Реквизит.Реквизит, ЭлементМ.ЗначениеРеквизита, ЭлементМ.ПривязанЗуб, ЭлементМ.ПредставлениеЗначения); 														
			КонецЦикла;
		
			// Если это реквизит с привязкой к зубам добавляем новую
			// строку к таблице реализующую список
			Если ПервоеДобавлениеВРеквизит Тогда
				ОсновнойИД = ПолучитьВедущийИдентификторРеквизитаОбследования(ЗначенияСФормы.РеквизитИД);
				// Дополняем таблицу новой строке для последующего добавления
				HTMLTable  = ПолучитьHTMLTableОбследование(ЗначенияСФормы.СсылкаЭлемент);
				Если НЕ HTMLTable.rows = Неопределено Тогда
					NewRow              = HTMLTable.insertRow(HTMLTable.rows.length);
					NewCell             = NewRow.insertCell(0);
					NewCell             = NewRow.insertCell(1);
					NewCell.innerHTML   = "<A id=" + ОсновнойИД + "," + "Addition" + " href=about:>" + ЗначенияСФормы.ПустоеПолеДобавить + "</A>";
					NewCell.className   = "add_element";
				КонецЕсли;
			КонецЕсли;	
		
			// Если это первый клиент по родительскому реквизиту
			Если ПервоеДобавлениеВРеквизит Тогда
				// Получить параметры подчиненных реквизитов
				ПараметрыПодчиненныхРеквизитов = ПолучитьПараметрыПодчиненныхРеквизитовОбследования(ЗначенияСФормы.Реквизит.Реквизит);
				Для Каждого СтрокаП ИЗ ПараметрыПодчиненныхРеквизитов Цикл
					Если НЕ ЗначениеЗаполнено(СтрокаП.РеквизитЗначение) ИЛИ ЗначенияСФормы.Реквизит.ПривязкаКЗубам Тогда 
						ШаблонЛечения = СтрокаП.Реквизит = ПредопределенноеЗначение("ПланВидовХарактеристик.ПараметрыОбследований.Лечение");
						// Получаем подчиненный Html элемент
						HtmlПодчиненногоРеквизита = Элементы.HTMLПолеОбследование.Документ.getElementById(СтрокаП.РеквизитИдентификатор + ?(СтрокаП.ПривязкаКЗубам Или ШаблонЛечения,",Addition",""));
