// Функция - Максимальный интервал работы структурной единицы
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция МаксимальныйИнтервалРаботыСтруктурнойЕдиницы(СтруктурнаяЕдиница, БратьМаксимальныйИнтервалТолькоЗаВыходные = Ложь) Экспорт

	ПервыйДень 	  = ?(БратьМаксимальныйИнтервалТолькоЗаВыходные = Истина, 6, 1);
	ПоследнийДень = 7;
	
	МаксПериод = Неопределено;
	
	Для А = ПервыйДень По ПоследнийДень Цикл
		
		ПериодРаботы = ВремяРаботыСтруктурнойЕдиницы(,СтруктурнаяЕдиница, А); 
		
		Если ПериодРаботы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если  МаксПериод = Неопределено ИЛИ ПериодРаботы.Продолжительность > МаксПериод.Продолжительность Тогда
			МаксПериод = ПериодРаботы;
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат МаксПериод;
	
КонецФункции

// Функция - Получить доступные кассы для СЕ
