// Процедура печати документов.
//
Процедура ДокументПечать(Команда)
	
	МассивДокументов = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		МассивДокументов.Добавить(Объект.Ссылка);
	КонецЕсли;
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "ПеремещениеЗапасов");
	Структура.Вставить("МассивДокументов", МассивДокументов);
	
	СписокПечатныхФорм = ПолучитьСписокПечати();
	Оповещение = Новый ОписаниеОповещения("ДокументПечатьОбработкаВыбора", ЭтотОбъект, Структура);	
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда	
		
		СтруктураВопроса = Новый Структура;
		СтруктураВопроса.Вставить("СписокПечатныхФорм", СписокПечатныхФорм);
		СтруктураВопроса.Вставить("Оповещение", Оповещение);
		ОповещениеДляВопроса = Новый ОписаниеОповещения("ПослеВопросаЗавершение", ЭтотОбъект, СтруктураВопроса);			
		ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны. Записать?", РежимДиалогаВопрос.ДаНет);
		
	Иначе	
		
		ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, Элементы.ФормаДокументаПечать);
		
	КонецЕсли;   				
	
КонецПроцедуры

&НаКлиенте
// Процедура После вопроса завврешение.
//
Процедура ПослеВопросаЗавершение(Результат, Параметры) Экспорт	
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Если ПроверитьЗаполнение() = Истина Тогда		
			ЭтаФорма.Записать(Новый Структура("РежимЗаписи",РежимЗаписиДокумента.Запись));			
		КонецЕсли; 		
		// ПоказатьВыборИзМеню(Параметры.Оповещение, Параметры.СписокПечатныхФорм, Элементы.ФормаДокументаПечать);		
	Иначе
		Возврат;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура печати.
//
Процедура ДокументПечатьОбработкаВыбора(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Значение = "НакладнаяНаПеремещениеПоТипуЦен" Тогда
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ВидЦен", ВидЦенПоУмолчаниюДляПечати());
		СтруктураПараметров.Вставить("Перемещение", "Перемещение");
		ПараметрыОповещения = Новый Структура("Результат, Параметры", Результат, Параметры);
		ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,, Новый ОписаниеОповещения("ОбработкаВыборФорматаЦены", ЭтотОбъект, ПараметрыОповещения), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
					
	Иначе
		УправлениеПечатьюКлиентСтоматология.ОбработкаКоманды(Результат, Параметры);	
	КонецЕсли;
		
КонецПроцедуры

