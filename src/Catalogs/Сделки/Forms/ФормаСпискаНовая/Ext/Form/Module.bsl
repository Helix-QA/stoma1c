	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_ПериодЗапланированнойЗадачи");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_ПериодЗапланированнойЗадачи");
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_ПериодЗапланированнойЗадачи");
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_ПериодЗапланированнойЗадачи");
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("СтандартныйПериод"));
	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, , Новый СтандартныйПериод, НСтр("ru = 'За весь период'; en = 'For all period'"));
																												
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																												
		
КонецПроцедуры

&НаСервере
// Процедура - Обновить значения фильтрации данных.
//
// Параметры:
//  ПараметрыОтбора				 - 	 - 
//  ОчиститьВсеФильтры			 - 	 - 
//  МассивИменОчищаемыхФильтров	 - 	 - 
//
Процедура ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора, ОчиститьВсеФильтры = Истина, МассивИменОчищаемыхФильтров = Неопределено)
	
	Если ОчиститьВсеФильтры Тогда 
		МассивИменОчищаемыхФильтров = Новый Массив();
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВидСделки");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Этап");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Менеджер");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Врач");		
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СотрудникРегистрации");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_РекламныйИсточник");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Тег");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Интерес");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПредварительнаяЗапись"); 		
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Задача"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_КаналПривлечения");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПризнакВыполненияСделки");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияСделки");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СозданаПериод");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ЗавершенаПериод"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПериодЗапланированнойЗадачи");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПричинаОтказа");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивИменОчищаемыхФильтров) Тогда 
		УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	КонецЕсли;
	
	СписокСтатусовПометокУдаления = Новый СписокЗначений;
	СписокСтатусовПометокУдаления.Добавить(Истина, , Ложь);
	УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияСделки", СписокСтатусовПометокУдаления, Истина);		
	
	// Отбор статус.
	Если ПараметрыОтбора.Свойство("ОчиститьОтборПоСтатусу") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.ОчиститьОтборПоСтатусу);
	КонецЕсли;
	
	// Отбор структурная единица.
	Если ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц);		
	Иначе 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	КонецЕсли;
	
	// Отбор вид сделки.
	Если ПараметрыОтбора.Свойство("МассивВидовСделок") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок);		
	КонецЕсли;

	// Отбор этапы сделки.
	Если ПараметрыОтбора.Свойство("МассивЭтапов") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов);		
	КонецЕсли;	
	
	// Отбор причина отказа.
	Если ПараметрыОтбора.Свойство("МассивПричинОтказов") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПричинаОтказа", ПараметрыОтбора.МассивПричинОтказов);		
	КонецЕсли;	
	
	// Отбор признак наличия назначенного приема.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияПредварительнойЗаписи") ИЛИ ПараметрыОтбора.Свойство("СписокСтатусовНаличияПредварительнойЗаписи") Тогда 
		Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияПредварительнойЗаписи") Тогда 
			МассивСтатусовНаличияПредварительнойЗаписи = Новый Массив();
			Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияПредварительнойЗаписи) 
				И ПараметрыОтбора.МассивСтатусовНаличияПредварительнойЗаписи[0] = "Нет назначенного приема" Тогда
				
				МассивСтатусовНаличияПредварительнойЗаписи.Добавить(Ложь);
			Иначе
				МассивСтатусовНаличияПредварительнойЗаписи.Добавить(Истина);		
			КонецЕсли;
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПредварительнаяЗапись", МассивСтатусовНаличияПредварительнойЗаписи);
		ИначеЕсли ЗначениеЗаполнено(ПараметрыОтбора.СписокСтатусовНаличияПредварительнойЗаписи) 
				И ПараметрыОтбора.СписокСтатусовНаличияПредварительнойЗаписи[0].Значение = Ложь Тогда
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПредварительнаяЗапись", ПараметрыОтбора.СписокСтатусовНаличияПредварительнойЗаписи); 
		КонецЕсли;
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор признак наличия задач.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач") Тогда 
		
		МассивСтатусовНаличияЗадач = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияЗадач) 
			И ПараметрыОтбора.МассивСтатусовНаличияЗадач[0] = "Нет задач" Тогда
			
			МассивСтатусовНаличияЗадач.Добавить(Ложь);
		Иначе
			МассивСтатусовНаличияЗадач.Добавить(Истина);		
		КонецЕсли;

		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", МассивСтатусовНаличияЗадач);
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор статусов сделки.
	Если ПараметрыОтбора.Свойство("МассивСтатусовСделок") Тогда
		
		МассивСтатусовСделок = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовСделок) 
			И ПараметрыОтбора.МассивСтатусовСделок[0] = "Нет" Тогда
			
			МассивСтатусовСделок.Добавить(Ложь);
		Иначе
			МассивСтатусовСделок.Добавить(Истина);		
		КонецЕсли;
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", МассивСтатусовСделок);
	
	КонецЕсли;

	// Отбор менеджеров.
	Если ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", ПараметрыОтбора.МассивМенеджеров);
	КонецЕсли;	
	
	// Отбор врач.
	Если ПараметрыОтбора.Свойство("МассивВрачей") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Врач", ПараметрыОтбора.МассивВрачей);
	КонецЕсли;	
	
	// Отбор период запланированной задачи
	Если ПараметрыОтбора.Свойство("ПериодПланирования") Тогда    	
		
		МассивПериодаЗапланированнойЗадачи = Новый Массив();
		МассивПериодаЗапланированнойЗадачи.Добавить(ПараметрыОтбора.ПериодПланирования);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", МассивПериодаЗапланированнойЗадачи);

	КонецЕсли;	
	
	// Отбор периода завершения сделки.
	Если ПараметрыОтбора.Свойство("ПериодСделки") Тогда    
		
		МассивПериодаЗавершенияСделки = Новый Массив();
		МассивПериодаЗавершенияСделки.Добавить(ПараметрыОтбора.ПериодСделки);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ЗавершенаПериод", МассивПериодаЗавершенияСделки);
		
	КонецЕсли;
	
	// Отбор канал привлечения.
	Если ПараметрыОтбора.Свойство("МассивКаналовПривлечения") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КаналПривлечения", ПараметрыОтбора.МассивКаналовПривлечения);
	КонецЕсли;	
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

&НаСервере
// Процедура, актуализировать данные списка согласно отборов.
//
Процедура АктуализироватьДанныеСпискаСогласноОтборов()
	
	СтруктураОтборов 				= ПолучитьСтруктуруЗначенийОтбора();
	
	ЗапросДляКоличества 			= ПолучитьЗапросДляПодсчетаКоличества(СтруктураОтборов);
	ЗапросДляДинамическогоСписка 	= ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов);
	
	// Цепляем наш запрос динамическому списку
	Список.ТекстЗапроса = ЗапросДляДинамическогоСписка.Текст;
	
	// Устанавливаем параметры динамическому списку
	Для Каждого ПараметрЗапроса Из ЗапросДляДинамическогоСписка.Параметры Цикл 
		Список.Параметры.УстановитьЗначениеПараметра(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);		
	КонецЦикла;
	
	ВыборкаДляКоличества = ЗапросДляКоличества.Выполнить().Выбрать();
	Если ВыборкаДляКоличества.Следующий() Тогда
		КоличествоСделок = ВыборкаДляКоличества.КоличествоСделок;
		УстановитьЗаголовокКоличествоЭлементовВСписке(КоличествоСделок);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, возвращает структуру отборов формы.
//
Функция ПолучитьСтруктуруЗначенийОтбора()
	
	// Метод "ПолучитьЗначенияФильтра" возвращает список активированных значений фильтра.
	// У полученного списка значений есть свойство "ДоступныеЗначения", в котором хранится список всех значений.
	// Таким образом мы одним методом за одну итерацию получаем 2 списка значений(с активированными значениями и всеми значениями).
	// Вариант отбора передается в свойстве "ДоступныеЗначения" в представлении у любого элемента списка.
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборСтатус"						, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус"));
	СтруктураОтборов.Вставить("ОтборСтруктурнаяЕдиница"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СтруктурнаяЕдиница"));
	СтруктураОтборов.Вставить("ОтборМенеджер"					, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Менеджер"));		
	СтруктураОтборов.Вставить("ОтборВрач"						, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Врач"));	
	СтруктураОтборов.Вставить("ОтборВидСделки"					, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ВидСделки"));	
	СтруктураОтборов.Вставить("ОтборЭтап"						, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Этап"));
	СтруктураОтборов.Вставить("ОтборСотрудникРегистрации"		, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СотрудникРегистрации"));
	СтруктураОтборов.Вставить("ОтборРекламныйИсточник"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_РекламныйИсточник"));
	СтруктураОтборов.Вставить("ОтборТег"						, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Тег"));
	СтруктураОтборов.Вставить("ОтборПредварительнаяЗапись"		, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПредварительнаяЗапись"));	
	СтруктураОтборов.Вставить("ОтборЗадача"	 					, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Задача"));		
	СтруктураОтборов.Вставить("ОтборЗавершена"					, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПризнакВыполненияСделки"));
	СтруктураОтборов.Вставить("ОтборДатаСоздания"				, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СозданаПериод"));
	СтруктураОтборов.Вставить("ОтборДатаЗавершенияСделки"		, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ЗавершенаПериод"));
	СтруктураОтборов.Вставить("ОтборДатаЗапланированнойЗадачи"	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПериодЗапланированнойЗадачи"));
	СтруктураОтборов.Вставить("ОтборПометкаУдаления"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПометкаУдаленияСделки"));
	СтруктураОтборов.Вставить("ОтборПричинаОтказа"				, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПричинаОтказа"));
	СтруктураОтборов.Вставить("ОтборКаналПривлечения"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_КаналПривлечения"));
	СтруктураОтборов.Вставить("ВидСделки"						, ЭтотОбъект.ОтборВидСделки);
	СтруктураОтборов.Вставить("ОтборСтатусПациента"				, ЭтотОбъект.ОтборСтатусПациента);
	
	Возврат СтруктураОтборов;
	
КонецФункции	

&НаСервере
// Функция, возвращает запрос с установленными параметрами, для подсчета количества.
//
Функция ПолучитьЗапросДляПодсчетаКоличества(СтруктураОтборов)
	    
	// Шаблон текста запроса без отборов (чистый) для подсчета кол-ва	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(Сделки.Ссылка) КАК КоличествоСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|		ПО Сделки.Ссылка = СделкиСведенияДляСписка.Сделка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Сделки.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Сделки.ВидСделки = &ОтборВидСделки
	|	И ВЫБОР
	|			КОГДА &ОтборСтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КонтрагентыСведенияДляСписка.Статус = &ОтборСтатусПациента
	|		КОНЕЦ
	|	И &УсловиеПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеМенеджер
	|	И &УсловиеВрач
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеТеги
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаЗавершенияСделки
	|	И &УсловиеДатаЗапланированнойЗадачи
	|	И &УсловиеОтборБезНазначенногоПриема
	|	И &УсловиеОтборБезЗадач
	|	И &УсловиеЭтап
	|	И &УсловиеЗавершена
	|	И &УсловиеПричинаОтказа";	
	
	// Отбор пометка удаления.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПометкаУдаления)
		И СтруктураОтборов.ОтборПометкаУдаления[0].Значение = Истина Тогда
		
		УсловиеПометкаУдаления = СтруктураОтборов.ОтборПометкаУдаления.ДоступныеЗначения[0].Представление + "Сделки.ПометкаУдаления = ИСТИНА";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", УсловиеПометкаУдаления);
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", "ИСТИНА");
	КонецЕсли;	

	// Отбор структурная единица.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Сделки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Если СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.Количество() <> 0 Тогда 
			ВариантОтбора = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление;
		Иначе 
			ВариантОтбора = "";
		КонецЕсли;			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", ВариантОтбора + "Сделки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)");			
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения());				
		// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор сотрудник регистрации.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации) Тогда
		УсловиеСотрудникРегистрации = СтруктураОтборов.ОтборСотрудникРегистрации.ДоступныеЗначения[0].Представление + "Сделки.Автор В (&ОтборСотрудникРегистрации)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
		Запрос.УстановитьПараметр("ОтборСотрудникРегистрации", СтруктураОтборов.ОтборСотрудникРегистрации.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор менеджер.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер) Тогда
		УсловиеМенеджер = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения[0].Представление + "Сделки.Менеджер В (&ОтборМенеджер)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", УсловиеМенеджер);
		Запрос.УстановитьПараметр("ОтборМенеджер", СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор врач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборВрач) Тогда
		УсловиеВрач = СтруктураОтборов.ОтборВрач.ДоступныеЗначения[0].Представление + "Сделки.Врач В (&ОтборВрач)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВрач", УсловиеВрач);
		Запрос.УстановитьПараметр("ОтборВрач", СтруктураОтборов.ОтборВрач.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВрач", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор рекламный источник.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник) Тогда
		УсловиеРекламныйИсточник = СтруктураОтборов.ОтборРекламныйИсточник.ДоступныеЗначения[0].Представление + "Сделки.ИсточникИнформации В (&ОтборРекламныйИсточник)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		Запрос.УстановитьПараметр("ОтборРекламныйИсточник", СтруктураОтборов.ОтборРекламныйИсточник.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", "ИСТИНА");
	КонецЕсли;
	
	// Отбор канал привлечения.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКаналПривлечения) Тогда
		УсловиеКаналПривлечения = СтруктураОтборов.ОтборКаналПривлечения.ДоступныеЗначения[0].Представление + "Сделки.КаналПривлечения В (&ОтборКаналПривлечения)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", УсловиеКаналПривлечения);
		Запрос.УстановитьПараметр("ОтборКаналПривлечения", СтруктураОтборов.ОтборКаналПривлечения.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", "ИСТИНА");
	КонецЕсли;
	
	// Отбор причина отказа.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПричинаОтказа) Тогда
		УсловиеПричинаОтказа = СтруктураОтборов.ОтборПричинаОтказа.ДоступныеЗначения[0].Представление + "Сделки.ПричинаОтказа В (&ОтборПричинаОтказа)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПричинаОтказа", УсловиеПричинаОтказа);
		Запрос.УстановитьПараметр("ОтборПричинаОтказа", СтруктураОтборов.ОтборПричинаОтказа.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПричинаОтказа", "ИСТИНА");
	КонецЕсли;
	
	// Отбор тег.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборТег) Тогда
		
		УсловиеТеги =  
		"Сделки.Контрагент В
		|  		(ВЫБРАТЬ
		|  			СправочникКонтрагентыТеги.Ссылка
		|  		ИЗ
		|  			Справочник.Контрагенты.Теги КАК СправочникКонтрагентыТеги
		|  		ГДЕ
		|  			" + СтруктураОтборов.ОтборТег.ДоступныеЗначения[0].Представление + "СправочникКонтрагентыТеги.Тег В (&ОтборТеги))";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", УсловиеТеги);
		Запрос.УстановитьПараметр("ОтборТеги", СтруктураОтборов.ОтборТег.ВыгрузитьЗначения());
		
	Иначе	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", "ИСТИНА");
	КонецЕсли;
	
	// Отбор дата создания сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаСоздания) Тогда   
		
		УсловиеДатаСоздания = "Сделки.ДатаСделки МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", УсловиеДатаСоздания);
		ДатаНачала = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
		
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", "ИСТИНА")	
	КонецЕсли;
	
	// Отбор дата завершения сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗавершенияСделки) Тогда   
		
		УсловиеДатаЗавершенияСделки = "Сделки.ДатаЗавершенияСделки МЕЖДУ &ДатаЗавершенияСделкиДатаНачала И &ДатаЗавершенияСделкиДатаОкончания";
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗавершенияСделки", УсловиеДатаЗавершенияСделки);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗавершенияСделки[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗавершенияСделки[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаЗавершенияСделкиДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),    ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаЗавершенияСделкиДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания), ДатаОкончания, Дата(3999,12,31)));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗавершенияСделки", "ИСТИНА");		
	КонецЕсли;
	
	// Отбор дата запланированной задачи.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗапланированнойЗадачи) Тогда
		Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПредварительнаяЗапись)
		И СтруктураОтборов.ОтборПредварительнаяЗапись[0].Значение = Ложь Тогда
			УсловиеДатаЗапланированнойЗадачи = "СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
			УсловиеОтборБезНазначенногоПриема = СтруктураОтборов.ОтборПредварительнаяЗапись.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
			УсловиеДатаЗапланированнойЗадачи = "(" + УсловиеДатаЗапланированнойЗадачи + ") ИЛИ (" + УсловиеОтборБезНазначенногоПриема + ")";
		Иначе 
			УсловиеДатаЗапланированнойЗадачи = "СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		КонецЕсли;
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания;

		// УсловиеДатаЗапланированнойЗадачи = "И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));	
		Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
		
	Иначе                               
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", "ИСТИНА");
	КонецЕсли;
	
	// Отбор признак наличия назначенного приема.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПредварительнаяЗапись)
		И СтруктураОтборов.ОтборПредварительнаяЗапись[0].Значение = Ложь Тогда
		
		УсловиеОтборБезНазначенногоПриема = СтруктураОтборов.ОтборПредварительнаяЗапись.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезНазначенногоПриема", УсловиеОтборБезНазначенногоПриема);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезНазначенногоПриема", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор признак выполнения задачи сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача)
		И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь Тогда
		
		УсловиеОтборБезЗадач = СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор этап сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление + "Сделки.ЭтапСделки В (&ОтборЭтап)");		
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ВыгрузитьЗначения());
	Иначе
		Если СтруктураОтборов.ОтборЭтап.ДоступныеЗначения.Количество() <> 0 Тогда 
			ВариантОтбора = СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление;
		Иначе 
			ВариантОтбора = "";
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", ВариантОтбора + "Сделки.ЭтапСделки В (&ОтборЭтап)");			
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения.ВыгрузитьЗначения());		
		// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");		
	КонецЕсли;
	
	// Отбор признак завершения сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗавершена)
		И СтруктураОтборов.ОтборЗавершена[0].Значение = Истина Тогда
		
		УсловиеЗавершена = СтруктураОтборов.ОтборЗавершена.ДоступныеЗначения[0].Представление + "Сделки.РезультатСделки <> ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", УсловиеЗавершена);
		
	ИначеЕсли ЗначениеЗаполнено(СтруктураОтборов.ОтборЗавершена)
		И СтруктураОтборов.ОтборЗавершена[0].Значение = Ложь Тогда			
		
		УсловиеЗавершена = СтруктураОтборов.ОтборЗавершена.ДоступныеЗначения[0].Представление + "Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", УсловиеЗавершена);
		
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", "ИСТИНА");
	КонецЕсли;
	
	// Отбор вид сделки.
	Запрос.УстановитьПараметр("ОтборВидСделки", СтруктураОтборов.ВидСделки);
	
	// Отбор статус пациента (новый / постоянный).
	Запрос.УстановитьПараметр("ОтборСтатусПациента", СтруктураОтборов.ОтборСтатусПациента);
	
	Возврат Запрос;
	
КонецФункции

&НаСервере
// Функция, возвращает запрос с установленными параметрами, для списка формы.
//
Функция ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов)
	
	// текст запроса без отборов (чистый)
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= 	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.ДатаСделки КАК ДатаСделки,
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.СуммаСделки КАК СуммаСделки,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.ИсточникИнформации КАК ИсточникИнформации,
	|	Сделки.КаналПривлечения КАК КаналПривлечения,
	|	Сделки.Менеджер КАК Менеджер,
	|	Сделки.Врач КАК Врач,
	|	Сделки.Автор КАК Автор,
	|	ВЫРАЗИТЬ(Сделки.ЭтапСделки.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа,
	|	СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись КАК ЗапланированнаяПредварительнаяЗапись,
	|	СделкиСведенияДляСписка.ЗапланированнаяЗадача КАК ЗапланированнаяЗадача,
	|	СделкиСведенияДляСписка.ПоследняяЗадача КАК ПоследняяЗадача,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.ПричинаОтказа КАК ПричинаОтказа,
	|	Сделки.ВидСделки.НаименованиеЭтапаУспех КАК НаименованиеЭтапаУспех,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	ВЫБОР
	|		КОГДА Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.Успех)
	|			ТОГДА Сделки.ВидСделки.НаименованиеЭтапаУспех
	|		КОГДА Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.Отказ)
	|			ТОГДА Сделки.ПричинаОтказа
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ЗавершающийЭтапПояснение,
	|	КонтрагентыСведенияДляСписка.Статус КАК СтатусПациента
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|		ПО Сделки.Ссылка = СделкиСведенияДляСписка.Сделка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Сделки.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Сделки.ВидСделки = &ОтборВидСделки
	|	И ВЫБОР
	|			КОГДА &ОтборСтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КонтрагентыСведенияДляСписка.Статус = &ОтборСтатусПациента
	|		КОНЕЦ
	|	И &УсловиеПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеМенеджер
	|	И &УсловиеВрач
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеТеги
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаЗавершенияСделки
	|	И &УсловиеДатаЗапланированнойЗадачи
	|	И &УсловиеОтборБезНазначенногоПриема
	|	И &УсловиеОтборБезЗадач
	|	И &УсловиеЭтап
	|	И &УсловиеЗавершена
	|	И &УсловиеПричинаОтказа";	
	
	// Отбор пометка удаления.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПометкаУдаления)
		И СтруктураОтборов.ОтборПометкаУдаления[0].Значение = Истина Тогда
		
		УсловиеПометкаУдаления = СтруктураОтборов.ОтборПометкаУдаления.ДоступныеЗначения[0].Представление + "Сделки.ПометкаУдаления = ИСТИНА";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", УсловиеПометкаУдаления);
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", "ИСТИНА");
	КонецЕсли;	

	// Отбор структурная единица.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Сделки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Если СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.Количество() <> 0 Тогда 
			ВариантОтбора = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление;
		Иначе 
			ВариантОтбора = "";
		КонецЕсли;			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", ВариантОтбора + "Сделки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)");			
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения());		
		// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор сотрудник регистрации.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации) Тогда
		УсловиеСотрудникРегистрации = СтруктураОтборов.ОтборСотрудникРегистрации.ДоступныеЗначения[0].Представление + "Сделки.Автор В (&ОтборСотрудникРегистрации)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
		Запрос.УстановитьПараметр("ОтборСотрудникРегистрации", СтруктураОтборов.ОтборСотрудникРегистрации.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор менеджер.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер) Тогда
		УсловиеМенеджер = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения[0].Представление + "Сделки.Менеджер В (&ОтборМенеджер)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", УсловиеМенеджер);
		Запрос.УстановитьПараметр("ОтборМенеджер", СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор врач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборВрач) Тогда
		УсловиеВрач = СтруктураОтборов.ОтборВрач.ДоступныеЗначения[0].Представление + "Сделки.Врач В (&ОтборВрач)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВрач", УсловиеВрач);
		Запрос.УстановитьПараметр("ОтборВрач", СтруктураОтборов.ОтборВрач.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВрач", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор рекламный источник.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник) Тогда
		УсловиеРекламныйИсточник = СтруктураОтборов.ОтборРекламныйИсточник.ДоступныеЗначения[0].Представление + "Сделки.ИсточникИнформации В (&ОтборРекламныйИсточник)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		Запрос.УстановитьПараметр("ОтборРекламныйИсточник", СтруктураОтборов.ОтборРекламныйИсточник.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", "ИСТИНА");
	КонецЕсли;
	
	// Отбор канал привлечения.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКаналПривлечения) Тогда
		УсловиеКаналПривлечения = СтруктураОтборов.ОтборКаналПривлечения.ДоступныеЗначения[0].Представление + "Сделки.КаналПривлечения В (&ОтборКаналПривлечения)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", УсловиеКаналПривлечения);
		Запрос.УстановитьПараметр("ОтборКаналПривлечения", СтруктураОтборов.ОтборКаналПривлечения.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", "ИСТИНА");
	КонецЕсли;
	
	// Отбор причина отказа.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПричинаОтказа) Тогда
		УсловиеПричинаОтказа = СтруктураОтборов.ОтборПричинаОтказа.ДоступныеЗначения[0].Представление + "Сделки.ПричинаОтказа В (&ОтборПричинаОтказа)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПричинаОтказа", УсловиеПричинаОтказа);
		Запрос.УстановитьПараметр("ОтборПричинаОтказа", СтруктураОтборов.ОтборПричинаОтказа.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПричинаОтказа", "ИСТИНА");
	КонецЕсли;
	
	// Отбор тег.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборТег) Тогда
		
		УсловиеТеги =  
		"Сделки.Контрагент В
		|  		(ВЫБРАТЬ
		|  			СправочникКонтрагентыТеги.Ссылка
		|  		ИЗ
		|  			Справочник.Контрагенты.Теги КАК СправочникКонтрагентыТеги
		|  		ГДЕ
		|  			"+СтруктураОтборов.ОтборТег.ДоступныеЗначения[0].Представление+"СправочникКонтрагентыТеги.Тег В (&ОтборТеги))";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", УсловиеТеги);
		Запрос.УстановитьПараметр("ОтборТеги", СтруктураОтборов.ОтборТег.ВыгрузитьЗначения());
		
	Иначе	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", "ИСТИНА");
	КонецЕсли;
	
	// Отбор дата создания сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаСоздания) Тогда   
		
		УсловиеДатаСоздания = "Сделки.ДатаСделки МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", УсловиеДатаСоздания);
		ДатаНачала = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));

	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", "ИСТИНА")
		
	КонецЕсли;
	
	// Отбор дата завершения сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗавершенияСделки) Тогда   
		
		УсловиеДатаЗавершенияСделки = "Сделки.ДатаЗавершенияСделки МЕЖДУ &ДатаЗавершенияСделкиДатаНачала И &ДатаЗавершенияСделкиДатаОкончания";
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗавершенияСделки", УсловиеДатаЗавершенияСделки);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗавершенияСделки[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗавершенияСделки[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаЗавершенияСделкиДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),    ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаЗавершенияСделкиДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания), ДатаОкончания, Дата(3999,12,31)));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗавершенияСделки", "ИСТИНА");		
	КонецЕсли;
	
	// Отбор дата запланированной задачи.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗапланированнойЗадачи) Тогда
		Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПредварительнаяЗапись)
		И СтруктураОтборов.ОтборПредварительнаяЗапись[0].Значение = Ложь Тогда
			УсловиеДатаЗапланированнойЗадачи = "СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
			УсловиеОтборБезНазначенногоПриема = СтруктураОтборов.ОтборПредварительнаяЗапись.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
			УсловиеДатаЗапланированнойЗадачи = "(" + УсловиеДатаЗапланированнойЗадачи + ") ИЛИ (" + УсловиеОтборБезНазначенногоПриема + ")";
		Иначе 
			УсловиеДатаЗапланированнойЗадачи = "СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		КонецЕсли;	
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания;

		// УсловиеДатаЗапланированнойЗадачи = "И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));	
		Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
		
	Иначе                               
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", "ИСТИНА");
	КонецЕсли;
	
	// Отбор признак наличия назначенного приема.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПредварительнаяЗапись)
		И СтруктураОтборов.ОтборПредварительнаяЗапись[0].Значение = Ложь Тогда
		
		УсловиеОтборБезНазначенногоПриема = СтруктураОтборов.ОтборПредварительнаяЗапись.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезНазначенногоПриема", УсловиеОтборБезНазначенногоПриема);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезНазначенногоПриема", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор без задач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача)
		И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь Тогда
		
		УсловиеОтборБезЗадач = СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", "ИСТИНА");
	КонецЕсли;

	// Отбор этап сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление + "Сделки.ЭтапСделки В (&ОтборЭтап)");		
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ВыгрузитьЗначения());
	Иначе
		Если СтруктураОтборов.ОтборЭтап.ДоступныеЗначения.Количество() <> 0 Тогда 
			ВариантОтбора = СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление;
		Иначе 
			ВариантОтбора = "";
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", ВариантОтбора + "Сделки.ЭтапСделки В (&ОтборЭтап)");			
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения.ВыгрузитьЗначения());		
		// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");		
	КонецЕсли;
	
	// Отбор завершения задачи сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗавершена)
		И СтруктураОтборов.ОтборЗавершена[0].Значение = Истина Тогда
		
		УсловиеЗавершена = СтруктураОтборов.ОтборЗавершена.ДоступныеЗначения[0].Представление + "Сделки.РезультатСделки <> ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", УсловиеЗавершена);
		
	ИначеЕсли ЗначениеЗаполнено(СтруктураОтборов.ОтборЗавершена)
		И СтруктураОтборов.ОтборЗавершена[0].Значение = Ложь Тогда			
		
		УсловиеЗавершена = СтруктураОтборов.ОтборЗавершена.ДоступныеЗначения[0].Представление + "Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", УсловиеЗавершена);
		
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор вид сделки.
	Запрос.УстановитьПараметр("ОтборВидСделки", СтруктураОтборов.ВидСделки);
	
	// Отбор статус пациента (новый / постоянный).
	Запрос.УстановитьПараметр("ОтборСтатусПациента", СтруктураОтборов.ОтборСтатусПациента);
	
	Возврат Запрос;
	
КонецФункции	

&НаСервереБезКонтекста
// Функция, возвращает пакет запроса с элементами для создания отборов.
//
Функция ПолучитьПакетЗапросаЗначенийДляОтборов(ТекущийПользователь)
	
	МассивСтруктурныхЕдиниц 	= Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ТекущийПользователь, "Массив");		
	МассивВидовСделок 			= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиниц);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивВидовСделок"		, МассивВидовСделок);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник"				, ТекущийПользователь);
	Запрос.УстановитьПараметр("ЛюбаяПричина"			, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.ЛюбаяПричина"));
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.ИсточникИнформации КАК ИсточникИнформации,
	|	Сделки.КаналПривлечения КАК КаналПривлечения,
	|	Сделки.Автор КАК Автор,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.Менеджер КАК Менеджер,
	|	Сделки.Врач КАК Врач
	|ПОМЕСТИТЬ ТаблицаСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.ИсточникИнформации,
	|	Сделки.КаналПривлечения,
	|	Сделки.Автор,
	|	Сделки.Менеджер,
	|	Сделки.ЭтапСделки,
	|	Сделки.Врач
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Менеджер
	|			ИЗ
	|				ТаблицаСделок)
	|	И Сотрудники.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Врач
	|			ИЗ
	|				ТаблицаСделок)
	|	И Сотрудники.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Автор
	|			ИЗ
	|				ТаблицаСделок)
	|	И Сотрудники.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РекламныеИсточники.Ссылка КАК Ссылка,
	|	РекламныеИсточники.Представление КАК Представление
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.ИсточникИнформации
	|			ИЗ
	|				ТаблицаСделок)
	|	И РекламныеИсточники.Ссылка <> ЗНАЧЕНИЕ(Справочник.РекламныеИсточники.ПустаяСсылка)
	|	И РекламныеИсточники.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Представление КАК Представление
	|ПОМЕСТИТЬ ТаблицаВидовСделок
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Ссылка В(&МассивВидовСделок)
	|	И ВидыСделок.ПометкаУдаления = ЛОЖЬ
	|	И (ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.Представление КАК Представление
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.ЭтапСделки
	|			ИЗ
	|				ТаблицаСделок
	|			СГРУППИРОВАТЬ ПО
	|				ТаблицаСделок.ЭтапСделки)
	|	И ЭтапыСделок.Ссылка <> ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|	И ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА ЭтапыСделок.Предопределенный
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЭтапыСделок.ВидСделки В
	|					(ВЫБРАТЬ
	|						ТаблицаВидовСделок.Ссылка КАК Ссылка
	|					ИЗ
	|						ТаблицаВидовСделок КАК ТаблицаВидовСделок)
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыСделок.Предопределенный,
	|	ЭтапыСделок.ВидСделки,
	|	ЭтапыСделок.НомерЭтапа,
	|	Ссылка УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Теги.Ссылка КАК Ссылка,
	|	Теги.Представление КАК Представление
	|ИЗ
	|	Справочник.Теги КАК Теги
	|ГДЕ
	|	Теги.ПометкаУдаления = ЛОЖЬ
	|	И Теги.Ссылка <> ЗНАЧЕНИЕ(Справочник.Теги.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СтатусыКлиентов.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СтатусыКлиентов.Ссылка) КАК Представление
	|ИЗ
	|	Перечисление.СтатусыКонтрагентов КАК СтатусыКлиентов
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыКлиентов.Порядок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СтруктурныеЕдиницы.Ссылка) КАК Представление
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Представление КАК Представление
	|ИЗ
	|	ТаблицаВидовСделок КАК ВидыСделок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПричиныОтказов.Ссылка КАК Ссылка,
	|	ПричиныОтказов.Представление КАК Представление
	|ИЗ
	|	Справочник.ПричиныОтказов КАК ПричиныОтказов
	|ГДЕ
	|	ПричиныОтказов.Ссылка <> &ЛюбаяПричина
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	КаналыПривлечения.Ссылка КАК Ссылка,
	|	КаналыПривлечения.Представление КАК Представление
	|ИЗ
	|	Справочник.КаналыПривлечения КАК КаналыПривлечения
	|ГДЕ
	|	КаналыПривлечения.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.КаналПривлечения
	|			ИЗ
	|				ТаблицаСделок)
	|	И КаналыПривлечения.Ссылка <> ЗНАЧЕНИЕ(Справочник.КаналыПривлечения.ПустаяСсылка)
	|	И КаналыПривлечения.ПометкаУдаления = ЛОЖЬ";
	
	Возврат Запрос.ВыполнитьПакет();
	        	
КонецФункции

#КонецОбласти

#Область ___________________ОБРАБОТЧИКИ_МЕХАНИЗМА_ФИЛЬТРАЦИИ_______________________

&НаСервере
// Процедура - Применить механизм фильтрации данных.
//
// Параметры:
//  ДанныеЭлементаФильтрации - 	 - 
//
Процедура ПрименитьМеханизмФильтрацииДанных(ДанныеЭлементаФильтрации) Экспорт
	
	МассивСтрокОбрабатываемыхФильтров = ТаблицаФильтров.НайтиСтроки(Новый Структура("Применен", Ложь));
	Для Каждого СтрокаФильтра ИЗ МассивСтрокОбрабатываемыхФильтров Цикл
		УправлениеИнтерфейсамиСервер.ОбновитьГруппуАктивированныхЗначенийФильтра(ЭтаФорма, СтрокаФильтра);
	КонецЦикла;
	
	АктуализироватьДанныеСпискаСогласноОтборов();	
	ЭтаФорма.ТекущийЭлемент = Элементы.Список;
		
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик нажатия элемента фильтрации данных.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОбработчикНажатияЭлементаФильтрацииДанных(Команда, ВыбранноеЗначение, СтандартнаяОбработка) Экспорт
	
	МассивИмен = СтрРазделить(Команда.Имя,"_");
	
	Если МассивИмен.Количество() <> 0 Тогда 
		
		Если МассивИмен[0] = "Удалить" Тогда
			
			РезультатОбновления = УправлениеИнтерфейсамиКлиент.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, Команда.Имя, , ВыбранноеЗначение);
			Если РезультатОбновления.Свойство("ДействиеЭлемента") И РезультатОбновления.ДействиеЭлемента = "ОбработкаВыбора" Тогда 
				Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда 
					СтандартнаяОбработка = Ложь;
					// ВыбранноеЗначение = Неопределено;
					// ЭлементФормы.ОбновитьТекстРедактирования(); 			
				КонецЕсли;
			КонецЕсли;
			
		Иначе
			
			ИсключаемыеФильтры = Новый Массив;
			ИсключаемыеФильтры.Добавить("ВидСделки");
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("Отбор"				, ПараметрыВыбранныхФильтров(Новый Структура));
			ПараметрыФормы.Вставить("ИмяКоманды"		, Команда.Имя);
			ПараметрыФормы.Вставить("ВыбранноеЗначение"	, ВыбранноеЗначение);
			ПараметрыФормы.Вставить("ИсключаемыеФильтры", ИсключаемыеФильтры);
			
			ОткрытьФорму("Справочник.Сделки.Форма.ФормаФильтры",
						 ПараметрыФормы,,,,,
						 Новый ОписаниеОповещения("ОткрытиеФильтровЗавершение", ЭтотОбъект),
						 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - получение сведений о выбранных фильтрах.
//
Функция ПараметрыВыбранныхФильтров(ПараметрыОтбора)
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Если Строка.КоличествоАктивированныхЗначений > 0 Тогда
			
			МассивДанных = ПолучениеЭлементовОтбора(Новый Массив, Строка.СписокЗначений, Строка.Наименование);
			
			Если Строка.Наименование = "Фильтр_Статус" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусов"			   				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусов_ВариантОтбора"				, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_СтруктурнаяЕдиница" Тогда
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц"					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ВидСделки" Тогда
				ПараметрыОтбора.Вставить("МассивВидовСделок"			  			, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВидовСделок_ВариантОтбора"			, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Этап" Тогда
				ПараметрыОтбора.Вставить("МассивЭтапов"			     				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивЭтапов_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Менеджер" Тогда
				ПараметрыОтбора.Вставить("МассивМенеджеров"				 			, МассивДанных);
				ПараметрыОтбора.Вставить("МассивМенеджеров_ВариантОтбора"			, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Врач" Тогда
				ПараметрыОтбора.Вставить("МассивВрачей"				 				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВрачей_ВариантОтбора"				, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_СотрудникРегистрации" Тогда
				ПараметрыОтбора.Вставить("МассивСотрудниковРегистрации"				 , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСотрудниковРегистрации_ВариантОтбора", Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_РекламныйИсточник" Тогда
				ПараметрыОтбора.Вставить("МассивРекламныхИсточников"			  	, МассивДанных);
				ПараметрыОтбора.Вставить("МассивРекламныхИсточников_ВариантОтбора"	, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_ПричинаОтказа" Тогда
				ПараметрыОтбора.Вставить("МассивПричинОтказов"			  			, МассивДанных);
				ПараметрыОтбора.Вставить("МассивПричинОтказов_ВариантОтбора"		, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_Тег" Тогда
				ПараметрыОтбора.Вставить("МассивТегов"								, МассивДанных);
				ПараметрыОтбора.Вставить("МассивТегов_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Интерес" Тогда
				ПараметрыОтбора.Вставить("МассивИнтересов"							, МассивДанных);
				ПараметрыОтбора.Вставить("МассивИнтересов_ВариантОтбора"			, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_КаналПривлечения" Тогда
				ПараметрыОтбора.Вставить("МассивКаналовПривлечения"				 	, МассивДанных);
				ПараметрыОтбора.Вставить("МассивКаналовПривлечения_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПредварительнаяЗапись" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияПредварительнойЗаписи"			   , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияПредварительнойЗаписи_ВариантОтбора", Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_Задача" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияЗадач"			   , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияЗадач_ВариантОтбора", Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПризнакВыполненияСделки" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовСделок"			     , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовСделок_ВариантОтбора", Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПометкаУдаленияСделки" Тогда
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления"			  , МассивДанных);
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления_ВариантОтбора", Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_СозданаПериод" Тогда
				ПараметрыОтбора.Вставить("ПериодСозданияСделки", МассивДанных);

			ИначеЕсли Строка.Наименование = "Фильтр_ПериодЗапланированнойЗадачи" Тогда
				ПараметрыОтбора.Вставить("ПериодПланирования", МассивДанных);

			ИначеЕсли Строка.Наименование = "Фильтр_ЗавершенаПериод" Тогда
				ПараметрыОтбора.Вставить("ПериодСделки", МассивДанных);	
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ПараметрыОтбора, Новый УникальныйИдентификатор);
	
КонецФункции

&НаСервереБезКонтекста
// Функция - ПолучениеЭлементовОтбора
Функция ПолучениеЭлементовОтбора(Массив, СписокЗначений, НаименованиеФильтра)
	
	Если НаименованиеФильтра = "Фильтр_СозданаПериод" 
		ИЛИ НаименованиеФильтра = "Фильтр_ЗавершенаПериод" 
		ИЛИ НаименованиеФильтра = "Фильтр_ПериодЗапланированнойЗадачи" Тогда
		
		Если СписокЗначений.Количество() > 0 Тогда
			ЗаданноеЗначение = СписокЗначений.Получить(0).Значение; 
			Массив.Добавить(ЗаданноеЗначение.ЗначениеФильтра);
		КонецЕсли;
		
	Иначе
		
		Если СписокЗначений.Количество() > 0 Тогда
			Для каждого Значение из СписокЗначений Цикл
				Если Значение.Значение.Выбран = Истина Тогда
					Массив.Добавить(Значение.Значение.ЗначениеФильтра);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Массив;
	
КонецФункции

&НаКлиенте
// Процедура - ОткрытиеФильтровЗавершение.
//
Процедура ОткрытиеФильтровЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытиеФильтровНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
// Процедура - ОткрытиеФильтровНаСервере.
//
Процедура ОткрытиеФильтровНаСервере(Результат)
	
	ПараметрыОтбора = ПолучитьИзВременногоХранилища(Результат);
	ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора, Истина);	
	
	// Сбрасываем фильтр по задачам после изменения фильтра.
	УстановитьОтображениеФильтровПоЗадачам(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОчиститьФильтры = Ложь)
	
	Для Каждого Строка из ТаблицаФильтров Цикл
		Строка.Инициализирован = Ложь;
	КонецЦикла;
	
	МассивИменОчищаемыхФильтров = Новый Массив();
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Этап");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СотрудникРегистрации");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_РекламныйИсточник");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_КаналПривлечения");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Тег");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПредварительнаяЗапись"); 	
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Задача"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПризнакВыполненияСделки"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СозданаПериод");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ЗавершенаПериод"); 
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПериодЗапланированнойЗадачи");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияСделки");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПричинаОтказа");	
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Менеджер");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Врач");
	
	УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);

	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов(ТекущийПользователь);	
	
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ВидСделки") Тогда
		ЭтотОбъект.ОтборВидСделки			 = ПараметрыОтбора.ВидСделки;
		Элементы.ИзменитьВидСделки.Заголовок = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭтотОбъект.ОтборВидСделки, "Наименование");
	КонецЕсли;
	
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ОтборСтатусПациента") Тогда
		ЭтотОбъект.ОтборСтатусПациента = ПараметрыОтбора.ОтборСтатусПациента;
		УстановитьОтображениеФильтраСтатусПациента(ЭтотОбъект);
	КонецЕсли;
	
	// Отбор статус.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусов");	
	ОбновитьДинамическоеМенюФильтрации_Статус(РезультатПакетногоЗапроса[8].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусов_ВариантОтбора"), ПараметрыОтбора.МассивСтатусов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусов, Истина,,, ВариантОтбора);		
	КонецЕсли;
	
	// Отбор структурная единица.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц");	
	ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[9].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц_ВариантОтбора"), ПараметрыОтбора.МассивСтруктурныхЕдиниц_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина,,, ВариантОтбора);		
	КонецЕсли;
	
	// Отбор этапы сделки.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивЭтапов");
	ОбновитьДинамическоеМенюФильтрации_Этап(РезультатПакетногоЗапроса[6].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивЭтапов_ВариантОтбора"), ПараметрыОтбора.МассивЭтапов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов, Истина,,, ВариантОтбора);	
	КонецЕсли;	
	
	// Отбор сотрудника регистрации.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСотрудниковРегистрации");
	ОбновитьДинамическоеМенюФильтрации_СотрудникРегистрации(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСотрудниковРегистрации_ВариантОтбора"), ПараметрыОтбора.МассивСотрудниковРегистрации_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СотрудникРегистрации", ПараметрыОтбора.МассивСотрудниковРегистрации, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор рекламного источника.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивРекламныхИсточников");
	ОбновитьДинамическоеМенюФильтрации_РекламныйИсточник(РезультатПакетногоЗапроса[4].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивРекламныхИсточников_ВариантОтбора"), ПараметрыОтбора.МассивРекламныхИсточников_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_РекламныйИсточник", ПараметрыОтбора.МассивРекламныхИсточников, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор причины отказа.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивПричинОтказов");
	ОбновитьДинамическоеМенюФильтрации_ПричинаОтказа(РезультатПакетногоЗапроса[11].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивПричинОтказов_ВариантОтбора"), ПараметрыОтбора.МассивПричинОтказов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПричинаОтказа", ПараметрыОтбора.МассивПричинОтказов, Истина,,, ВариантОтбора);	
	КонецЕсли;

	// Отбор тегов.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивТегов");
	ОбновитьДинамическоеМенюФильтрации_Тег(РезультатПакетногоЗапроса[7].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивТегов_ВариантОтбора"), ПараметрыОтбора.МассивТегов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Тег", ПараметрыОтбора.МассивТегов, Истина,,, ВариантОтбора);	
	КонецЕсли;

	// Отбор признак наличия назначенного приема.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияПредварительнойЗаписи");
	ОбновитьДинамическоеМенюФильтрации_ПредварительнаяЗапись(,УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовНаличияПредварительнойЗаписи_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовНаличияПредварительнойЗаписи_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПредварительнаяЗапись", ПараметрыОтбора.МассивСтатусовНаличияПредварительнойЗаписи, Истина,,, ВариантОтбора);
	КонецЕсли;
	
	// Отбор признак наличия задач.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач");
	ОбновитьДинамическоеМенюФильтрации_Задача(,УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовНаличияЗадач_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", ПараметрыОтбора.МассивСтатусовНаличияЗадач, Истина,,, ВариантОтбора);
	КонецЕсли;
	
	// Отбор статусов сделки.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовСделок"); 
	ОбновитьДинамическоеМенюФильтрации_ПризнакВыполненияСделки(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовСделок_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовСделок_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", ПараметрыОтбора.МассивСтатусовСделок, Истина,,, ВариантОтбора);
	КонецЕсли;

	// Отбор пометка удаления сделки.         
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления"); 
	ОбновитьДинамическоеМенюФильтрации_ПометкаУдаленияСделки(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления_ВариантОтбора"), ПараметрыОтбора.СписокСтатусовПометокУдаления_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияСделки", ПараметрыОтбора.СписокСтатусовПометокУдаления, Истина,,, ВариантОтбора);				
	КонецЕсли;
	
	// Отбор менеджеров.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивМенеджеров"); 
	ОбновитьДинамическоеМенюФильтрации_Менеджер(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивМенеджеров_ВариантОтбора"), ПараметрыОтбора.МассивМенеджеров_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", ПараметрыОтбора.МассивМенеджеров, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;	
	
	// Отбор врач.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВрачей"); 
	ОбновитьДинамическоеМенюФильтрации_Врач(РезультатПакетногоЗапроса[2].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВрачей_ВариантОтбора"), ПараметрыОтбора.МассивВрачей_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Врач", ПараметрыОтбора.МассивВрачей, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;	
	
	// Отбор периода создания сделки.	
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодСозданияСделки");
	ОбновитьДинамическоеМенюФильтрации_СозданаПериод(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СозданаПериод", ПараметрыОтбора.ПериодСозданияСделки);	
	КонецЕсли;	
	
	// Отбор период запланированной задачи
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодПланирования");
	ОбновитьДинамическоеМенюФильтрации_ПериодЗапланированнойЗадачи(, УстановитьОтбор);
	Если УстановитьОтбор Тогда    	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", ПараметрыОтбора.ПериодПланирования);
	КонецЕсли;	
	
	// Отбор периода завершения сделки.	
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодСделки");
	ОбновитьДинамическоеМенюФильтрации_ЗавершенаПериод(, УстановитьОтбор);
	Если УстановитьОтбор Тогда    
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ЗавершенаПериод", ПараметрыОтбора.ПериодСделки);
	КонецЕсли;
	
	// Отбор канал привлечения.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКаналовПривлечения"); 
	ОбновитьДинамическоеМенюФильтрации_КаналПривлечения(РезультатПакетногоЗапроса[12].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКаналовПривлечения_ВариантОтбора"), ПараметрыОтбора.МассивКаналовПривлечения_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КаналПривлечения", ПараметрыОтбора.МассивКаналовПривлечения, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;	
	
	ЗначениеОтбораПоЗадачам = СвойствоСтруктуры(ПараметрыОтбора, "ОтборПоЗадачам", 0);
	УстановитьОтображениеФильтровПоЗадачам(ЭтотОбъект, ЗначениеОтбораПоЗадачам = 3, ЗначениеОтбораПоЗадачам = 2, ЗначениеОтбораПоЗадачам = 1);
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

