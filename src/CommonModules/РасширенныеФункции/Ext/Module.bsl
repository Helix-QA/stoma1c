// Функция - Выгрузить дерево значений в таблицу
// 
Функция ВыгрузитьДеревоЗначенийВТаблицу(Дерево, ВыгружатьГруппы = Истина, Результат = Неопределено) Экспорт

	Если Результат = Неопределено Тогда
		Результат = Новый ТаблицаЗначений;
		Для каждого Колонка Из Дерево.Колонки Цикл
			Результат.Колонки.Добавить(Колонка.Имя, Колонка.ТипЗначения);
		КонецЦикла;		
	КонецЕсли; 
	
	Если НЕ (ВыгружатьГруппы = Ложь И Дерево.Строки.Количество() > 0)
			И ТипЗнч(Дерево) = Тип("СтрокаДереваЗначений") Тогда
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Дерево);
	КонецЕсли;
		
	Для каждого СтрокаДерева Из Дерево.Строки Цикл
		ВыгрузитьДеревоЗначенийВТаблицу(СтрокаДерева, ВыгружатьГруппы, Результат);
	КонецЦикла;
	
	Возврат Результат;

