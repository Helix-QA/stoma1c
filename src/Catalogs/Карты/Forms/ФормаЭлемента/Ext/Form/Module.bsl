КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура установки видимости элементов формы
//
Процедура УстановитьВидимостьДоступность()
		
	ЭлектроннаяКарта = Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet");
	
	Элементы.КартаКодКарты.ТолькоПросмотр      = ЭлектроннаяКарта;
	Элементы.КартаВнутреннийКодКарты.Видимость = НЕ ЭлектроннаяКарта;
	Элементы.КартаТипКода.ТолькоПросмотр 	   = ЭлектроннаяКарта;
	Элементы.КартаВидКарты.ТолькоПросмотр      = ЭлектроннаяКарта;
	
	Элементы.КартаСсылкаНаУстановку.Видимость  = ЭлектроннаяКарта;
	
	Элементы.ПризнакУстановки.Видимость = ЭлектроннаяКарта;
	
	Элементы.ОтправитьСсылку.Видимость  = ЭлектроннаяКарта;
	
	Элементы.КнопкаПечать.Видимость = НЕ ЭлектроннаяКарта;
	Элементы.ШаблонКарты.Видимость  = НЕ ЭлектроннаяКарта;
		
	Элементы.ГруппаУдаленияКарты.Видимость = Объект.КартаУдалена И ЭлектроннаяКарта И ЗначениеЗаполнено(ВнешняяСистемаWallet); 
	
	Элементы.ДекорацияКартинка.Подсказка = ПолучитьПодсказкуПоВидуКарты(Объект.ТипКода);
	Элементы.ДекорацияКартинка.Картинка  = ПолучитьПиктограммуПоВидуКарты(Объект.ТипКода);
	
	// Элементы.ВладелецКарты.ТолькоПросмотр = ЭлектроннаяКарта;
		
	Элементы.КартаВидКарты.СписокВыбора.Очистить();
	Элементы.КартаВидКарты.СписокВыбора.ЗагрузитьЗначения(ПолучитьМассивДоступныхВидовКарт(ЭлектроннаяКарта));
	
	Элементы.ДекорацияКартинка.РасширеннаяПодсказка.Заголовок = ПолучитьОписаниеПодсказки(Объект.ТипКода);
	
	Элементы.ГруппаУдалитьКарта.Видимость = ЭлектроннаяКарта;
		
КонецПроцедуры

