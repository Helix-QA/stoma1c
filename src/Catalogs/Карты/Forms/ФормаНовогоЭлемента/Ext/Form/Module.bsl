&НаСервереБезКонтекста
// Сформировать штрихкод формата EAN13
//
Функция СформироватьШтрихкодEAN13()
	
	Возврат РегистрыСведений.Штрихкоды.СформироватьШтрихкодEAN13();
	
КонецФункции 

&НаКлиенте
// Процедура, обрабатывает изменение типа кода карты.
//
Процедура УстановитьВидимостьДоступность()
	
	УстановитьТекущийВидКарты();
	
	ЭлектроннаяКарта = Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet");
	ШтриховаяКарта   = Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Штриховая");
	МагнитнаяКарта   = Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная");
	
	Если ЭлектроннаяКарта Тогда
		
		ПредВидКарты    = Объект.ВидКарты;
		Объект.ВидКарты = ЭтотОбъект.ВидКартыWalletПоУмолчанию;
		
	Иначе 
		
		Объект.ВидКарты = ПредВидКарты;
		
	Конецесли;
	
	Элементы.ВладелецКарты.ОграничениеТипа = Новый ОписаниеТипов(Новый_Массив(Тип("СправочникСсылка.Контрагенты"), Тип("СправочникСсылка.Сотрудники")));
	
	Элементы.ГруппаЭлектроннаяКарта.Видимость  = ВСНастроена;
	
	Элементы.КартаКодКарты.Видимость    	   = Не ЭлектроннаяКарта;
	Элементы.КартаКодКарты.ПодсказкаВвода      = ?(ШтриховаяКарта, "Штрихкод", "Заводской номер карты");
	
	Элементы.КартаКодКарты.АвтоВыборНезаполненного = Не ЭлектроннаяКарта;
	
	Элементы.КартаВнутреннийКодКарты.Видимость = Не ЭлектроннаяКарта;
	
	Если Объект.Ссылка.Пустая() Тогда
		Элементы.СгенерироватьКодКарты.Видимость = ШтриховаяКарта ИЛИ МагнитнаяКарта;
	Иначе
		Элементы.КартаКодКарты.МаксимальнаяШирина = 25;
	КонецЕсли;
		
	Элементы.ГруппаОтправить.Видимость = ЭлектроннаяКарта И ВСНастроена;
	Элементы.КартаВидКарты.Видимость   = Не ЭлектроннаяКарта Или ВСНастроена;
	
	Элементы.КартаДобавить.Доступность = Не ЭлектроннаяКарта Или ВСНастроена;
	
	МассивВидовКарт = ПолучитьМассивДоступныхВидовКарт(ЭлектроннаяКарта);
	
	Если МассивВидовКарт.Количество() > 0 Тогда 
		
		Элементы.КартаВидКарты.СписокВыбора.Очистить();
		Элементы.КартаВидКарты.СписокВыбора.ЗагрузитьЗначения(МассивВидовКарт);
		
	Иначе
		
		Элементы.КартаВидКарты.СписокВыбора.Очистить();
		Элементы.КартаВидКарты.СписокВыбора.Добавить(,"Не существует видов карт. Создайте вид карты.");
		
	КонецЕсли;
	
	Элементы.КартаВидКарты.КнопкаСоздания = Не ЭлектроннаяКарта Или ВСНастроена;
	
	УстановитьОтметкуНезаполненого(ЭлектроннаяКарта);
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает отметку незаполненого.
//
Процедура УстановитьОтметкуНезаполненого(ЭлектроннаяКарта)
		
	Если ЭлектроннаяКарта Тогда
		
		Элементы.КартаВидКарты.АвтоОтметкаНезаполненного = Истина;
		Элементы.ВладелецКарты.АвтоОтметкаНезаполненного = Истина;
		
	Иначе
		
		
		Элементы.КартаВидКарты.ОтметкаНезаполненного = Ложь;
		Элементы.ВладелецКарты.ОтметкаНезаполненного = Ложь;
		
		Элементы.КартаВидКарты.АвтоОтметкаНезаполненного = Неопределено;
		Элементы.ВладелецКарты.АвтоОтметкаНезаполненного = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает текущий вид карт.
//
Процедура УстановитьТекущийВидКарты()
	
	Элементы.ГруппаЭлектроннаяКарта.ЦветФона = Новый Цвет(255, 255, 255);
	Элементы.ГруппаМагнитнаяКарта.ЦветФона   = Новый Цвет(255, 255, 255);
	Элементы.ГруппаШтриховаяКарта.ЦветФона   = Новый Цвет(255, 255, 255);
	
	Если Объект.Ссылка.Пустая() Тогда
		
		Если Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet") Тогда	
			Элементы.ГруппаЭлектроннаяКарта.ЦветФона = Новый Цвет(195, 217, 246);	
		ИначеЕсли Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная") Тогда
			Элементы.ГруппаМагнитнаяКарта.ЦветФона = Новый Цвет(195, 217, 246);
		Иначе
			Элементы.ГруппаШтриховаяКарта.ЦветФона = Новый Цвет(195, 217, 246);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, возвращает массив доступных видов карт.
//
Функция ПолучитьМассивДоступныхВидовКарт(ЭлектроннаяКарта)
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыКарт.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыКарт КАК ВидыКарт
	|ГДЕ
	|	НЕ ВидыКарт.ПометкаУдаления
	|	И &УсловиеВидКарты");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеВидКарты", ?(ЭлектроннаяКарта, "И ВидыКарт.ИдентификаторПроекта <> 0", "И ВидыКарт.ИдентификаторПроекта = 0"));
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	       	
КонецФункции

&НаКлиенте
// Функция формирует наименование карты клиента
//
Функция СформироватьАвтоНаименование()
	 		
	СтрокаНаименования = "" +Объект.КодКарты + ", " + Объект.ВладелецКарты + " (" + Объект.ТипКода + ")";
			
	Возврат СтрокаНаименования;
	
КонецФункции 

&НаСервере
// Получить штрихкод 
//
Функция ПолученыШтрихкоды(ДанныеШтрикодов, ИмяСобытия)
	
	Модифицированность = Истина;
	
	Если ДанныеШтрикодов.Количество() > 0 Тогда
		Объект.ТипКода = Перечисления.ВидыКарт.Штриховая;
		Объект.КодКарты = ДанныеШтрикодов[ДанныеШтрикодов.Количество() - 1].Штрихкод;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции 

&НаСервереБезКонтекста
// Функция, возвращает внешнюю систему.
//
Функция ВСWalletНастроена()
	
	Если Не Константы.ИспользоватьWallet.Получить() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ВС = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);
	
	Возврат ЗначениеЗаполнено(ВС.КлючШифрования) И ЗначениеЗаполнено(ВС.ТокенДоступа); 
	
КонецФункции

&НаКлиенте
