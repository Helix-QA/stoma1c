// Функция выполняет создание и проведение документа ПоступлениеДС.
//
Функция СоздатьДокументПоступления(СтруктураЗаполнения, ОписаниеОшибки) 
			
	Попытка            		
		ДокументПоступления 					    = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
		
		ДокументПоступления.Дата               		= ТекущаяДатаСеанса();	
		ДокументПоступления.ВидОперации 			= Перечисления.ВидыОпераций.ВзносНаЛицевойСчет;
		ДокументПоступления.Статья                  = Справочники.СтатьиДоходовИРасходов.НайтиПоРеквизиту("ПоУмолчаниюДляОперации", ДокументПоступления.ВидОперации);	
		ДокументПоступления.Контрагент 				= СтруктураЗаполнения.Контрагент;
		ДокументПоступления.ЛицевойСчетКонтрагента 	= СтруктураЗаполнения.ВидЛицевогоСчета;
		Если НЕ ЗначениеЗаполнено(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница) Тогда 
			ВызватьИсключение "Не установлена текущая структурная единица!" + Символы.ПС;	
		КонецЕсли;	
		ДокументПоступления.СтруктурнаяЕдиница 		= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		Если НЕ ЗначениеЗаполнено(СтруктураЗаполнения.Касса) Тогда 
			ВызватьИсключение "Не установлена основная касса!" + Символы.ПС;	
		КонецЕсли;	
		ДокументПоступления.Касса              		= СтруктураЗаполнения.Касса;
		ДокументПоступления.СуммаДокумента 			= СтруктураЗаполнения.Сумма;
		ДокументПоступления.АвторДокумента 			= ПараметрыСеанса.ТекущийПользователь;
		
		Если СтруктураЗаполнения.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда 
			ДокументПоступления.ЭквайрингТерминал = СтруктураЗаполнения.ЭквайринговыйТерминал;
			ДокументПоступления.ЭквайрингВидПлатежнойКарты = СтруктураЗаполнения.ЭквайрингВидПлатежнойКарты;
			
			Если НЕ ЗначениеЗаполнено(ДокументПоступления.ЭквайрингТерминал) Тогда 
				ВызватьИсключение "Не установлен текущий эквайринговый терминал!" + Символы.ПС;	
			КонецЕсли;
			
			ДокументПоступления.ТипДенежныхСредств 		= СтруктураЗаполнения.ТипДенежныхСредств;
		ИначеЕсли СтруктураЗаполнения.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда 
			ДокументПоступления.ТипДенежныхСредств 		= СтруктураЗаполнения.ТипДенежныхСредств;
		КонецЕсли;
		
		ДокументПоступления.Записать(РежимЗаписиДокумента.Проведение);
		
		Возврат ДокументПоступления.Ссылка;		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();		
	КонецПопытки;
	
КонецФункции	

