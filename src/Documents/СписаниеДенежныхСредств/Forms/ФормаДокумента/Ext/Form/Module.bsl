			ШиринаДопПолей = ШиринаДопПолей + ?(ПолеСтатья.Видимость, ПолеСтатья.МаксимальнаяШирина, 0);
		
	
			КоррекцияШирины = ШиринаДопПолей / 25;
			ПолеДокумент.МаксимальнаяШирина = ПолеДокумент.МаксимальнаяШирина - ШиринаДопПолей - ?(КоррекцияШирины >= 1, (КоррекцияШирины * 2), 1);		
