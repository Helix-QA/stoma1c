
#Область ОбрабтчикиСобытийЭлементовФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("ОтработанноеВремя", "ГруппаОтработанноеВремя");
	СтруктураМеню.Вставить("Дополнительно"	  , "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	Объект.ДатаОтчета = Объект.Дата;
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПослеЗаписи" формы.
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ОтработанноеВремяПриИзменении(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)
	
	Объект.ДатаОтчета = Объект.Дата;
	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обработку нажатия кнопок динамического меню.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры

#КонецОбласти	

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура обработчик команды "ЗаполнитьПоГрафику".
//
Процедура ЗаполнитьПоГрафику(Команда)
	
	Если Объект.ОтработанноеВремя.Количество() > 0 Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьПоГрафикуОтвет", ЭтотОбъект)
					 , НСтр("ru='Таблица отработанного времени будет очищенна. Продолжить?';en='Spent table of time willbe cleared. Continue?'")
					 , РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнитьПоГрафикуНаСервере(Ложь);
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - Заполнить по графику ответ.
//
Процедура ЗаполнитьПоГрафикуОтвет(Результат, Параметры)  Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьПоГрафикуНаСервере();

КонецПроцедуры

&НаСервере
// Процедура заполнения отработанного времени по плану.
//
Процедура ЗаполнитьПоГрафикуНаСервере(ОчиститьОтработанноеВремя = Истина)
	
	Если ОчиститьОтработанноеВремя = Истина Тогда
		Объект.ОтработанноеВремя.Очистить();
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК Начало,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК Окончание
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|ГДЕ
	|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НачалоПериода(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) = &ДатаОтчета");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаОтчета", Объект.ДатаОтчета);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Запрос.Выполнить().Выгрузить(), Объект.ОтработанноеВремя);
	
КонецПроцедуры

&НаСервереБезКонтекста  
// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции 

#КонецОбласти