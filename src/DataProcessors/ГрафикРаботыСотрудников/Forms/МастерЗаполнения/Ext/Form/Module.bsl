&НаКлиенте
// Процедура - обработчик события "ПриИзменении" полей формы "ДатаНачала" и "ДатаОкончания"
//
Процедура ПериодПриИзменении(Элемент)
	
	Если Элемент.Имя = "ДатаНачала" Тогда
		
		Если НачалоМесяца(ДатаНачала) <> Объект.Период Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата начала периода должна быть в пределах установленного в графике месяца");
			ДатаНачала = ТекущаяДата();
		КонецЕсли;
		
		Если ДатаНачала < ТекущаяДата() Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата начала периода не должна быть меньше текущей даты");
			ДатаНачала = ТекущаяДата();
		КонецЕсли;
		
		Если ДатаНачала > ДатаОкончания Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата начала периода не должна превышать дату окончания периода");
			ДатаНачала = ТекущаяДата();
		КонецЕсли;
		
	ИначеЕсли Элемент.Имя = "ДатаОкончания" Тогда			
		
		Если КонецМесяца(ДатаОкончания) <> КонецМесяца(Объект.Период) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата окончания периода должна быть в пределах установленного в графике месяца");
			ДатаОкончания = КонецМесяца(Объект.Период);
		КонецЕсли;
		
		Если ДатаНачала > ДатаОкончания Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата окончания периода должна быть больше даты начала периода");
			ДатаОкончания = КонецМесяца(Объект.Период);
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

