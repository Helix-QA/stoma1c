&НаКлиенте
// Процедура, обрабатывает результат переноса заявки в другой блок.
//
Процедура ОбработатьРезультатПереносаЗаявки(РезультатОперации, ОбрабатыватьИзменение = Ложь)
	
	// Все прошло успешно, обновляем количество заявок в блоках.
	Если РезультатОперации.ВыполненоУспешно = Истина Тогда
		
		// Отображаем изменение сделки.
		Если РезультатОперации.Свойство("ОбновитьПредставлениеСделки") И РезультатОперации.ОбновитьПредставлениеСделки Тогда
			// Блок сделки обновится вместе с обновлением блока клиента - обработкой оповещения.
			// ОбновитьПредставлениеСделки(РезультатОперации.ИдентификаторЗаявки, РезультатОперации.ДанныеСделки);
		КонецЕсли;
		
		// Отображаем изменение сотрудника.
		Если РезультатОперации.Свойство("ОбновитьПредставлениеСотрудника") И РезультатОперации.ОбновитьПредставлениеСотрудника Тогда
			// Блок сотрудника скрыт.
			// ОбновитьПредставлениеСотрудника(РезультатОперации.ИдентификаторЗаявки, РезультатОперации.ДанныеСотрудника);
		КонецЕсли;
		
		// Оповещаем другие формы об изменении статуса заявки.
		//
		// Можем передать только заявку, проверка по сотруднику
		// и структурной единице в текущем сеансе не требуется.
		//
		// Оповещения, запущенные из этой же формы, не обрабатываются
		// в процедуре "ОбработкаОповещения" (во избежание лишних обновлений данных).
		// Если данные заявки необходимо обновить (например после создания клиента) - не передаем источник оповещения.
		Оповестить(
			"ОбновленСтатусЗаявки",
			РезультатОперации.Заявка,
			?(ОбрабатыватьИзменение = Истина, Неопределено, ЭтотОбъект)
		);
		
		ВывестиЗаявкуИзОчереди(РезультатОперации.ДанныеВыводимойЗаявки);
		ОбновитьКоличествоЗаявокВБлоках(РезультатОперации.ДанныеКоличества);
		
		Возврат;
		
	КонецЕсли;
	
	// Сообщаем об ошибке и отменяем визуальные последствия действия.
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОперации.ОписаниеОшибки);
	ОтменитьПеретаскиваниеЗаявки();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет представление сотрудника в блоке заявки.
// 
// Параметры:
//
// ИдентификаторЗаявки - строка - уникальный идентификатор заявки.
//
// ДанныеСотрудника - структура - содержит поля "ИдентификаторСотрудника" и "ПредставлениеСотрудника".
// ИдентификаторСотрудника - строка - уникальный идентификатор сотрудника.
// ПредставлениеСотрудника - строка - наименование сотрудника.
//
Процедура ОбновитьПредставлениеСотрудника(ИдентификаторЗаявки, ДанныеСотрудника)
	
