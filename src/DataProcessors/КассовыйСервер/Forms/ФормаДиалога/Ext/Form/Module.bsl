
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Документ", Документ);
	Параметры.Свойство("Статус"  , Статус);
	
	Если Не ЗначениеЗаполнено(Документ) Тогда
		Элементы.ГруппаОткрытьДокумент.Видимость = Ложь;
		Элементы.ГруппаОткрытьКлиента.Видимость  = Ложь;
	Иначе
		Клиент = Документ.Контрагент;
	КонецЕсли;
	
	Если НЕ Статус = Перечисления.СтатусыПробитияЧекаКассовымСервером.Ошибка Тогда
		Элементы.ГруппаПовторноеПробитие.Видимость = Ложь;		
	КонецЕсли;	
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик события "команды".
//
Процедура ОткрытьДокумент(Команда)
	
	ЭтаФорма.Закрыть();
	ПоказатьЗначение(, Документ);	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "команды".
//
Процедура ОткрытьКлиента(Команда)
	
	ЭтаФорма.Закрыть();
	ПоказатьЗначение(, Клиент);	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "команды".
//
Процедура Отмена(Команда)
	
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "команды".
//
Процедура ПовторитьПробитиеЧека(Команда)
	
	ОбновитьСтатусДокументаНаКассовомСервере(Документ);
	ЭтаФорма.Закрыть(Новый Структура("ОбновитьСписок", Истина));	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Процедура, обновляет данные в кассовой очереди.
//
Процедура ОбновитьСтатусДокументаНаКассовомСервере(Документ)
	
	УстановитьПривилегированныйРежим(Истина);
	
	МенеджерЗаписи = РегистрыСведений.ОчередьКассовогоСервера.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ДокументОплаты = Документ;
	МенеджерЗаписи.Прочитать();
	Если МенеджерЗаписи.Выбран() И МенеджерЗаписи.Статус = Перечисления.СтатусыПробитияЧекаКассовымСервером.Ошибка 
		И МенеджерЗаписи.НомерФискальногоЧека = 0 Тогда
		МенеджерЗаписи.КоличествоПопыток  = 0;
		МенеджерЗаписи.Статус             = Перечисления.СтатусыПробитияЧекаКассовымСервером.Ожидание;
		МенеджерЗаписи.ОшибкаПробитияЧека = "";
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
