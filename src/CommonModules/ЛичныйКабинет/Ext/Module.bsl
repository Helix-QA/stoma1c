
#Область СлужебныйПрограммныйИнтерфейс

#Область ХранилищеЛичногоКабинета

// Получить структуру данных хранения анкеты на клиенте
Функция ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте() Экспорт
	
	ДанныеАнкеты = Новый Структура; 
	
	// Флаг успешной идентификации програмного продукта при первом запуске
	ДанныеАнкеты.Вставить("ИдентификацияПрограммногоПродуктаВыполнена" ,Неопределено);
	
    ДанныеАнкеты.Вставить("ПродуктРегистрационныйНомер"   ,Неопределено);
	
	// Фдаг успешного принятия регистрации на провреку
	ДанныеАнкеты.Вставить("РегистрацияПринята"                     ,Неопределено);	
	ДанныеАнкеты.Вставить("РегистрацияПоследнийКодСостояния"       ,Неопределено);
	ДанныеАнкеты.Вставить("РегистрацияОповещениеОСтатусеВыполнено" ,Неопределено);
    ДанныеАнкеты.Вставить("РегистрацияОтправитель"                 ,Неопределено);
	
	ДанныеАнкеты.Вставить("ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса" ,Неопределено);
	
	Возврат ДанныеАнкеты; 
	
КонецФункции

// Функция - Личный кабинет создан
// 
// Возвращаемое значение:
//   - 
// 
Функция ЛичныйКабинетСоздан() Экспорт
	
  	 Возврат ПолучитьДанныеРегистрационнойАнкеты() <> Неопределено;
	
КонецФункции

// Функция - Получить регистрационный номер продукта
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьРегистрационныйНомерПродукта() Экспорт
	
	СтруктДанных = ПолучитьДанныеРегистрационнойАнкеты();
	
	Если СтруктДанных <> Неопределено 
		И СтруктДанных.Свойство("ПродуктРегистрационныйНомер")
		И ЗначениеЗаполнено(СтруктДанных.ПродуктРегистрационныйНомер) Тогда
		
		Возврат СтруктДанных.ПродуктРегистрационныйНомер;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Процедура - Записать код проверки рубликации
// 
Процедура ЗаписатьРегистрационныйНомер(РегистрационныйНомер) Экспорт
	
	ЗаписатьРеквизитВДанныеРегистрационнойАнкеты("ПродуктРегистрационныйНомер", РегистрационныйНомер);
	
КонецПроцедуры

// Функция, возвращает структуру данных анкеты продукта.
//
Функция ПолучитьСтруктуруДанныхРегистрационнойАнкеты() Экспорт
	
	ПараметрыРегистрации = ПолучитьДанныеРегистрационнойАнкеты();
	
	Если ПараметрыРегистрации = Неопределено Тогда
		ПараметрыРегистрации = ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте();
	КонецЕсли;
	
	Возврат ПараметрыРегистрации;
	
КонецФункции

// Функция, возвращает реквизит из структуры данных регистрационной анкеты.
//
Функция ПолучитьРеквизитИзДанныхРегистрационнойАнкеты(НаименованиеРеквизита) Экспорт
	
	ПараметрыРегистрации = ПолучитьДанныеРегистрационнойАнкеты();
	
	Если ПараметрыРегистрации <> Неопределено И ПараметрыРегистрации.Свойство(НаименованиеРеквизита) Тогда
		Возврат ПараметрыРегистрации[НаименованиеРеквизита];
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция вернет структуру данных анкеты продукта 
Функция ПолучитьДанныеРегистрационнойАнкеты() Экспорт
	
	СсылкаНаХранилище = Константы.ЛичныйКабинетХранилищеДанных.Получить();
	Если СсылкаНаХранилище <> Неопределено Тогда
		Возврат СсылкаНаХранилище.Получить();
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Процедура, записывает реквизит в структуру данных регистрационной анкеты.
//
Процедура ЗаписатьРеквизитВДанныеРегистрационнойАнкеты(НаименованиеРеквизита, Значение) Экспорт
	
	ПараметрыРегистрации = ПолучитьСтруктуруДанныхРегистрационнойАнкеты();
	
	Если ПараметрыРегистрации.Свойство(НаименованиеРеквизита) Тогда
		ПараметрыРегистрации[НаименованиеРеквизита] = Значение;
	Иначе
		ПараметрыРегистрации.Вставить(НаименованиеРеквизита, Значение);
	КонецЕсли;
	
	ЗаписатьДанныеРегистрационнойАнкеты(ПараметрыРегистрации);
	
КонецПроцедуры

// Процедура запишит структуру данных анкеты продукта
// в хранилище данных
Процедура ЗаписатьДанныеРегистрационнойАнкеты(СтруктураДанных) Экспорт
	
	Константы.ЛичныйКабинетХранилищеДанных.Установить(Новый ХранилищеЗначения(СтруктураДанных));
	
КонецПроцедуры

// Процедура - Очистить хранилище личного кабинета
// 
Процедура ОчиститьХранилищеЛичногоКабинета() Экспорт
	
	Константы.ЛичныйКабинетХранилищеДанных.Установить(Неопределено);

КонецПроцедуры

// Процедура - Записать код проверки рубликации
// 
Процедура ЗаписатьКодПроверкиРубликации(КодПроверкиРубликации) Экспорт
	
	ЗаписатьРеквизитВДанныеРегистрационнойАнкеты("КодПроверкиРубликации", КодПроверкиРубликации);
	
КонецПроцедуры

// Функция - Получить код проверки рубликации
// 
// Возвращаемое значение:
//   - 
// 
функция ПолучитьКодПроверкиРубликации() Экспорт 
		
	ПараметрыРегистрации = ПолучитьДанныеРегистрационнойАнкеты();
	
	Если НЕ ПараметрыРегистрации = Неопределено
		И ПараметрыРегистрации.Свойство("КодПроверкиРубликации") Тогда
		
		Возврат ПараметрыРегистрации.КодПроверкиРубликации;
	КонецЕсли;
	
КонецФункции

