&НаКлиенте
// Процедура - обработчик события ПриИзменении таблицы значений ввода Услуги, элемента НормаВремени.
//
Процедура УслугиНормаВремениПриИзменении(Элемент)
	
	Если Объект.Резерв Тогда 
		Объект.Услуги[0].ДатаОкончания = ДатаНачала + НормаВремени * 60;
		ДатаОкончания = ДатаНачала + НормаВремени * 60;
	Иначе 	
		ТекущаяСтрока = Элементы.Услуги.ТекущиеДанные;
		ТекущаяСтрока.НормаВремени = НормаВремени;
		ТекущаяСтрока.ДатаОкончания = ТекущаяСтрока.ДатаНачала + ТекущаяСтрока.НормаВремени * 60;
		ДатаОкончания = ДатаНачала + НормаВремени * 60;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриИзменении таблицы значений Услуги, элемента Время.
//
Процедура УслугиВремяПриИзменении(Элемент)
	
	ЭтоВремяНачала = Найти(Элемент.Имя, "ДатаНачала") <> 0;
	ЭтоЭлементТаблицы = Найти(Элемент.Имя, "Полем") = 0;
	
	ТекущаяСтрока = Элементы.Услуги.ТекущиеДанные;
	ВремяНачала	   = ?(ЭтоЭлементТаблицы, ТекущаяСтрока.ДатаНачала, ДатаНачала);
	ВремяОкончания = ?(ЭтоЭлементТаблицы, ТекущаяСтрока.ДатаОкончания, ДатаОкончания);
	
	Если Элемент <> Элементы.УслугиДатаНачалаПолем Тогда
		НомерСтроки = ТекущаяСтрока.НомерСтроки;
	Иначе
		НомерСтроки = 0;
	КонецЕсли;
	    
		
	Если ЭтоВремяНачала Тогда
		
		Если (НомерСтроки = 1 и ВремяОкончания <= ВремяНачала) или (НомерСтроки > 1 и ВремяОкончания < ВремяНачала) Тогда
			ВремяНачала = Дата("00010101");
		КонецЕсли;
		
		ТекущаяСтрока.ДатаНачала = ВремяНачала;
		ДатаНачала = ВремяНачала;
		
	Иначе
		
		Если (НомерСтроки = 1 и ВремяОкончания < ВремяНачала) или (НомерСтроки > 1 и ВремяОкончания <= ВремяНачала) Тогда 
			ВремяОкончания = Дата("00010101");
		КонецЕсли;
		
		ТекущаяСтрока.ДатаОкончания = ВремяОкончания;
		ДатаОкончания = ВремяОкончания;
		
	КонецЕсли;
	
	ТекущаяСтрока.НормаВремени = (ТекущаяСтрока.ДатаОкончания - ТекущаяСтрока.ДатаНачала) / 60;
	НормаВремени = (ДатаОкончания - ДатаНачала) / 60;
		
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события НачалоВыбора Таблицы Услуги элемента Номенклатура.
//
Процедура УслугиНоменклатураНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПризнакДобавитьСтрокуПриПодборе = Ложь;
	СтандартнаяОбработка = Ложь;
	
	Сегмент = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Элементы.Услуги.ТекущиеДанные.Сотрудник, Объект.СтруктурнаяЕдиница, "СегментыНоменклатуры");
	//мВидЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Элементы.Услуги.ТекущиеДанные.Сотрудник, Объект.СтруктурнаяЕдиница, "ВидЦен");
	ПараметрыФормыВыбора = Новый Структура;
	ПараметрыФормыВыбора.Вставить("ТекущаяСтрока", Элементы.Услуги.ТекущиеДанные.Номенклатура);
	ПараметрыФормыВыбора.Вставить("ВидЦен", Объект.ВидЦен);
	ПараметрыФормыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	ПараметрыФормыВыбора.Вставить("Дата", Объект.Дата); 
	
	Если ЗначениеЗаполнено(Сегмент) Тогда
		
		СтруктураПараметры     = Новый Структура();	
		МассивРазрешенныхТипов = Новый Массив;
		МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
		
		СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов"       , МассивРазрешенныхТипов); 
		СтруктураПараметры.Вставить("Заголовок"                         , "Выберите услугу");	   
		СтруктураПараметры.Вставить("Сегмент"                           , Сегмент);
		
		ДопПараметры = Новый Структура("ПризнакДобавитьСтрокуПриПодборе, Элемент", ПризнакДобавитьСтрокуПриПодборе, Элемент);
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораНоменклатурыИзФормПодбораИВыбора", ЭтотОбъект, ДопПараметры);
		ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры", СтруктураПараметры,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе 
		ДопПараметры = Новый Структура("ПризнакДобавитьСтрокуПриПодборе, Элемент", ПризнакДобавитьСтрокуПриПодборе, Элемент);
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораНоменклатурыИзФормПодбораИВыбора", ЭтотОбъект, ДопПараметры);
