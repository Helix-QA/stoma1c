#Область ФоновоеЗаданиеПолучениеДанных

&НаКлиенте
// Процедура - Подключаемый запустить фоновое задание при открытии.
//
Процедура Подключаемый_ЗапуститьФоновоеЗаданиеПриОткрытии()
	
	ЗапуститьФоновоеЗаданиеНаСервере();
	НачатьОжиданиеЗавершенияФоновогоЗаданияНаКлиенте();
	
КонецПроцедуры 

&НаСервере 
// Процедура - Запустить фоновое задание на сервере.
//
Процедура ЗапуститьФоновоеЗаданиеНаСервере()
	
	// Монопольный режим Или фоновое задание было запущено раньше, необходимо дождаться завершения.
  	Если МонопольныйРежим() Или (ФоновоеЗаданиеЗапущено И НЕ ЗаданиеВыполнено(ФоновоеЗаданиеИдентификатор)) Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяДатаСеанса = ТекущаяДатаСеанса();
	
	// Параметры обернем в структуру для их передачи через механизм ДлительныеОперации.
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
	ПараметрыПроцедуры.Вставить("ПериодРасчета"		, ОтборПериодЗначение);     
	ПараметрыПроцедуры.Вставить("ОтборПериодТип"	, ОтборПериодТип);
	
	НаименованиеЗадания = НСтр("ru='Обновление виджетов монитора руководителя';en='Update widget manager monitor'");
	
	Результат = ДлительныеОперации.ЗапуститьВыполнениеВФоне(
		УникальныйИдентификатор,
		"Обработки.МониторРуководителя.ПолучитьДанныеМонитора",
		ПараметрыПроцедуры,
		НаименованиеЗадания);
	
	ФоновоеЗаданиеАдресРезультата = Результат.АдресХранилища;
	ФоновоеЗаданиеИдентификатор   = Результат.ИдентификаторЗадания;
	
	// Если фоновое задание завершилось за время вызова, то данные уже получены
	Если Результат.ЗаданиеВыполнено Тогда
		ОбновитьОтображениеВиджетов();
		ФоновоеЗаданиеВыполнено = Истина;
		ФоновоеЗаданиеЗапущено = Ложь;
	Иначе
		// иначе начнем ожидания завершения фонового задания
		ФоновоеЗаданиеЗапущено = Истина;
	КонецЕсли;
	
	УправлениеФормой(ЭтаФорма);
	
КонецПроцедуры  

&НаКлиенте 
// Процедура - Начать ожидание завершения фонового задания на клиенте.
//
Процедура НачатьОжиданиеЗавершенияФоновогоЗаданияНаКлиенте()
	
	Если ФоновоеЗаданиеЗапущено Тогда
		// Начнем опрос окончания фонового задания
		ДлительныеОперацииКлиент.ИнициализироватьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
		ПодключитьОбработчикОжидания("Подключаемый_ПроверитьЗавершениеДлительнойОперации",
			ПараметрыОбработчикаОжидания.ТекущийИнтервал,
			Истина);
	КонецЕсли;
	
КонецПроцедуры
                                                                    
&НаКлиенте
// Процедура - Подключаемый проверить завершение длительной операции.
//
Процедура Подключаемый_ПроверитьЗавершениеДлительнойОперации()
	
	Если ФоновоеЗаданиеЗапущено Тогда
		
		Если ЗаданиеВыполнено(ФоновоеЗаданиеИдентификатор) Тогда
			// Данные расчитаны, обновим данные формы
			ФоновоеЗаданиеЗапущено = Ложь;
			ФоновоеЗаданиеВыполнено = Истина;
			ОбновитьОтображениеВиджетов();
			УправлениеФормой(ЭтотОбъект);
		Иначе
			// Продолжим ожидание
			ДлительныеОперацииКлиент.ОбновитьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
			ПодключитьОбработчикОжидания(
				"Подключаемый_ПроверитьЗавершениеДлительнойОперации",
				ПараметрыОбработчикаОжидания.ТекущийИнтервал,
				Истина);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервереБезКонтекста
// Функция - Задание выполнено.
//
// Параметры:
//  ИдентификаторЗадания - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаданиеВыполнено(ИдентификаторЗадания)
	
	Возврат ДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания);
	
КонецФункции

#КонецОбласти

#Область ОтображениеДанных

&НаСервере
// Процедура - Обновить отображение виджетов.
//
Процедура ОбновитьОтображениеВиджетов()
		
	// Получим подготовленные в фоновом задании данные и все необходимые настройки.
	ДанныеМонитора 		= ПолучитьИзВременногоХранилища(ФоновоеЗаданиеАдресРезультата);
	СоставВиджетов 		= Обработки.МониторРуководителя.СоставВиджетовПоУмолчанию();
	
	НомерВключенногоВиджета = 0;
	Для Каждого ЭлементСписка Из СоставВиджетов Цикл
		
		// Применим настройки к элементам-виджетам: выключим неиспользуемые и зададим порядок.
		ИмяВиджета = ОбщегоНазначения.ИмяЗначенияПеречисления(ЭлементСписка.Значение);
		ГруппаВиджета = Элементы.Найти(ИмяВиджета);
		Если ГруппаВиджета <> Неопределено Тогда
			ГруппаВиджета.Видимость = ЭлементСписка.Пометка;
		КонецЕсли;
				
		// Остальной цикл только для включенных виджетов.
		Если НЕ ЭлементСписка.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеВиджета = ДанныеМонитора.Получить(ЭлементСписка.Значение);
		
		ОтображатьСравненияСПредыдущимПериодом = ?(ОтборПериодТип = Перечисления.Периодичность.День
			Или ОтборПериодТип = перечисления.Периодичность.Неделя
			Или ОтборПериодТип = перечисления.Периодичность.Месяц,
			Истина, Ложь);
				
		// Обновим каждый включенный виджет.
		Если ЭлементСписка.Значение = Перечисления.ВиджетыМонитораРуководителя.Выручка Тогда
			ОбновитьВиджетВыручки(ДанныеВиджета);
		ИначеЕсли ЭлементСписка.Значение = Перечисления.ВиджетыМонитораРуководителя.Приемы Тогда
			ОбновитьВиджетПриемы(ДанныеВиджета);		
		ИначеЕсли ЭлементСписка.Значение = Перечисления.ВиджетыМонитораРуководителя.ЗагрузкаВрачей Тогда
			ОбновитьВиджетЗагрузкаВрачей(ДанныеВиджета);		
		ИначеЕсли ЭлементСписка.Значение = Перечисления.ВиджетыМонитораРуководителя.Коммуникации Тогда
			ОбновитьВиджетКоммуникации(ДанныеВиджета);
		ИначеЕсли ЭлементСписка.Значение = Перечисления.ВиджетыМонитораРуководителя.Регистратура Тогда
			ОбновитьВиджетРегистратура(ДанныеВиджета);
		ИначеЕсли ЭлементСписка.Значение = Перечисления.ВиджетыМонитораРуководителя.СтоимостьЧасаВрача Тогда
			ОбновитьВиджетСтоимостьЧасаВрача(ДанныеВиджета);	
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере 
// Процедура - Обновить виджет выручки.
//
// Параметры:
//  ДанныеВыручки	 - 	 - 
//
Процедура ОбновитьВиджетВыручки(ДанныеВыручки)
	
	#Область ____________ВиджетВыручка____________
	
	Если ДанныеВыручки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Шапка.
	Выборка = ДанныеВыручки.ДанныеШапкиВыручка.Выбрать(); 
	
	Валюта 		= ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	ДиаграммаОплачено.ФорматЗначенийВПодписях = СтрШаблон("ЧДЦ=0; ЧФ='Ч %1'", Валюта); 
	СуммаВсего 	= ?(Выборка.Следующий() , Выборка.Сумма, 0);	
		
	Элементы.ДекорацияОплаченоСумма.Заголовок = СтрШаблон("%1 %2", СуммаВсего, Валюта);
	
	Если ОтображатьСравненияСПредыдущимПериодом И СуммаВсего <> 0 Тогда
		                                                     
		Выборка = ДанныеВыручки.ДанныеШапкиВыручкаПредыдущий.Выбрать();
		Если Выборка.Следующий() Тогда
			СуммаВсегоВчера = Выборка.Сумма;
		Иначе
			СуммаВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(СуммаВсегоВчера = 0, 100, (СуммаВсего - СуммаВсегоВчера) / СуммаВсегоВчера * 100);
		Элементы.ДанныеВыручкиСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеВыручкиПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеВыручкиСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеВыручкиПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ВыручкаПроцент.Видимость = Истина;
	Иначе
		Элементы.ВыручкаПроцент.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
		
	ТаблицаРезультат = ДанныеВыручки.ДиаграммаОплачено.Выгрузить();
	ТаблицаРезультат.Сортировать("Сумма Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаОплачено.Обновление = Ложь;
	ДиаграммаОплачено.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
				
		Точка = ДиаграммаОплачено.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
			
			ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "Без сотрудника");	
			
			СерияДиаграммы 			= ДиаграммаОплачено.Серии.Добавить(ПредставлениеСотрудник); 
			Точка.Текст				= "Выручка";
			Точка.Значение			= СтрокаТЗ.Сумма;	
					
			ДиаграммаОплачено.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Сумма,,);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаОплачено, ЕстьДанныеДляОтображения);	
	ДиаграммаОплачено.Обновление = Истина;
		
	#КонецОбласти
	
	#Область ____________ВиджетОказано____________
	
	ДиаграммаОказано.ФорматЗначенийВПодписях = СтрШаблон("ЧДЦ=0; ЧФ='Ч %1'", Валюта);
	
	// Шапка
	Выборка = ДанныеВыручки.ДанныеШапкиОказано.Выбрать(); 
	
	СуммаВсего 	= ?(Выборка.Следующий(), Выборка.Сумма, 0);
	
	Элементы.ДекорацияОказаноСумма.Заголовок = СтрШаблон("%1 %2", СуммаВсего, Валюта);
	
	Если ОтображатьСравненияСПредыдущимПериодом И СуммаВсего <> 0 Тогда
		
		Выборка = ДанныеВыручки.ДанныеШапкиОказаноПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			СуммаВсегоВчера = Выборка.Сумма;
		Иначе
			СуммаВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(СуммаВсегоВчера = 0, 100, (СуммаВсего - СуммаВсегоВчера) / СуммаВсегоВчера * 100);
		Элементы.ДанныеОказаноСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеОказаноПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеОказаноСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеОказаноПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ОказаноПроцент.Видимость = Истина;
	Иначе
		Элементы.ОказаноПроцент.Видимость = Ложь;
	КонецЕсли;

	// Тело Диаграммы
		
	ТаблицаРезультат = ДанныеВыручки.ДиаграммаОказано.Выгрузить();
	ТаблицаРезультат.Сортировать("Сумма Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаОказано.Обновление = Ложь;
	ДиаграммаОказано.Очистить();

	Если ЕстьДанныеДляОтображения Тогда 
				
		Точка = ДиаграммаОказано.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
			
			ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "Без сотрудника");	
			
			СерияДиаграммы 			= ДиаграммаОказано.Серии.Добавить(ПредставлениеСотрудник); 
			Точка.Текст				= "Оказано";
			Точка.Значение			= СтрокаТЗ.Сумма;	
						
			ДиаграммаОказано.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Сумма,,);
			
		КонецЦикла;	
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаОказано, ЕстьДанныеДляОтображения);	
	ДиаграммаОказано.Обновление = Истина;
	
	#КонецОбласти
	
	#Область ____________ВиджетСреднийЧек____________
	
	ДиаграммаСреднийЧек.ФорматЗначенийВПодписях = СтрШаблон("ЧДЦ=0; ЧФ='Ч %1'", Валюта);	
	
	// Шапка
	Выборка = ДанныеВыручки.ДанныеШапкиСреднийЧек.Выбрать(); 
	
	СуммаВсего 	= ?(Выборка.Следующий(), Выборка.Сумма, 0);
	
	Элементы.ДекорацияНадписьСреднийЧекКоличество.Заголовок = СтрШаблон("%1 %2", СуммаВсего, Валюта);
	
	Если ОтображатьСравненияСПредыдущимПериодом И СуммаВсего <> 0 Тогда
		
		Выборка = ДанныеВыручки.ДанныеШапкиСреднийЧекПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			СуммаВсегоВчера = Выборка.Сумма;
		Иначе
			СуммаВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(СуммаВсегоВчера = 0, 100, (СуммаВсего - СуммаВсегоВчера) / СуммаВсегоВчера * 100);
		Элементы.СреднийСреднийЧекСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.СреднийЧекПроцентПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.СреднийСреднийЧекСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.СреднийЧекПроцентПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.СреднийЧекПроцент.Видимость = Истина;
	Иначе
		Элементы.СреднийЧекПроцент.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
		
	ТаблицаРезультат = ДанныеВыручки.ДиаграммаСреднийЧек.Выгрузить();
	ТаблицаРезультат.Сортировать("СреднийЧек Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаСреднийЧек.Обновление = Ложь;
	ДиаграммаСреднийЧек.Очистить();

	Если ЕстьДанныеДляОтображения Тогда 		
	
		Точка = ДиаграммаСреднийЧек.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
			
			ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "Без сотрудника");	
			
			СерияДиаграммы 			= ДиаграммаСреднийЧек.Серии.Добавить(ПредставлениеСотрудник); 
			Точка.Текст				= "Средний чек";
			Точка.Значение			= СтрокаТЗ.СреднийЧек;	
			
			ДиаграммаСреднийЧек.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.СреднийЧек,,);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаСреднийЧек, ЕстьДанныеДляОтображения);	
	ДиаграммаСреднийЧек.Обновление = Истина;
			
#КонецОбласти 

КонецПроцедуры

