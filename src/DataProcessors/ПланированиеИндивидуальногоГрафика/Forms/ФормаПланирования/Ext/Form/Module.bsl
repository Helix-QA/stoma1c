// Процедура - Сформировать текст периода
// 
Процедура СформироватьТекстПериода()
	
	КомандаВыбораПериода = ЭтаФорма.Команды.Найти("ВыбратьПериодПланирования");
	
	Если ОтборПериод.ДатаНачала = Дата(1,1,1) ИЛИ ОтборПериод.ДатаОкончания = Дата(1,1,1) Тогда 
		Элементы.ВыбратьПериодПланирования.Заголовок = "< не указан >";
		Если НЕ КомандаВыбораПериода = Неопределено Тогда 
			КомандаВыбораПериода.Подсказка = "Щелкните для выбора периода планирования";
		КонецЕсли;	
	Иначе
		Если ОтборПериод.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда 
			Элементы.ВыбратьПериодПланирования.Заголовок = Формат(ОтборПериод.ДатаНачала, "ДФ=dd.MM.yy") + " - " + Формат(ОтборПериод.ДатаОкончания, "ДФ=dd.MM.yy");
		Иначе 
			Элементы.ВыбратьПериодПланирования.Заголовок = Строка(ОтборПериод.Вариант);
		КонецЕсли;
		Если НЕ КомандаВыбораПериода = Неопределено Тогда 
			КомандаВыбораПериода.Подсказка = Элементы.ВыбратьПериодПланирования.Заголовок;
		КонецЕсли;			
	КонецЕсли;	
	
КонецПроцедуры

