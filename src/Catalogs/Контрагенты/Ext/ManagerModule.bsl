// Функция - Получить статус
//
Функция ПолучитьСтатус(Контрагент, Период = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Период", ?(Период = Неопределено, ТекущаяДатаСеанса(), Период));
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
	|	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус,
	|	СтатусыКонтрагентовСрезПоследних.Период КАК Период
	|ИЗ
	|	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(&Период, Контрагент = &Контрагент) КАК СтатусыКонтрагентовСрезПоследних
	|ГДЕ
	|	СтатусыКонтрагентовСрезПоследних.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)";
				   
	РезультатВыборка = Запрос.Выполнить().Выбрать();
	Если РезультатВыборка.Следующий() Тогда
		Возврат РезультатВыборка.Статус;
	Иначе
		Возврат Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
	КонецЕсли; 
	
КонецФункции

// Процедура - Установить статус
//
Процедура УстановитьСтатус(Контрагент, Статус = Неопределено, НаДату = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Статус) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ПолучитьСтатус(Контрагент, НаДату) = Статус Тогда
		Возврат;
	КонецЕсли; 
	
	МенеджерЗаписи = РегистрыСведений.СтатусыКонтрагентов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Контрагент = Контрагент;
	МенеджерЗаписи.Статус = ?(ЗначениеЗаполнено(Статус), Статус, Перечисления.СтатусыКонтрагентов.ПустаяСсылка());
	МенеджерЗаписи.Период = ?(ЗначениеЗаполнено(НаДату), НаДату, ТекущаяДатаСеанса());
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

// Функция - Получить данные ФИОКонтрагента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеФИОКонтрагента(Контрагент) Экспорт
	
	СтруктураФИО = Новый Структура;
	СтруктураФИО.Вставить("Фамилия"	, "");
	СтруктураФИО.Вставить("Имя"		, "");
	СтруктураФИО.Вставить("Отчество", "");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Имя КАК Имя,
	|	Контрагенты.Отчество КАК Отчество,
	|	Контрагенты.Фамилия КАК Фамилия
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка = &Контрагент";
	
	ВыборкаФИО = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаФИО.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(СтруктураФИО, ВыборкаФИО);
	КонецЕсли; 
		
	Возврат СтруктураФИО;
	
КонецФункции

// Функция, получает информацию из табличных частей справочника и формирует структуру.  
//
Функция ПолучитьИнформациюКонтрагента(Контрагент) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
	|	И КонтрагентыКонтактнаяИнформация.НомерТелефона <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.АдресЭП КАК АдресЭП
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКлиента)
	|	И КонтрагентыКонтактнаяИнформация.АдресЭП <> """"");
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	МассивТелефон 		= ПакетЗапросов[0].Выгрузить().ВыгрузитьКолонку("НомерТелефона");
	ТелефоныСтрокой		= СтроковыеФункцииКлиентСерверСтоматология.ПолучитьСтрокуИзМассиваПодстрок(МассивТелефон, ", ");
	
	МассивЕмайл 		= ПакетЗапросов[1].Выгрузить().ВыгрузитьКолонку("АдресЭП");
	АдресаЭПСтрокой		= СтроковыеФункцииКлиентСерверСтоматология.ПолучитьСтрокуИзМассиваПодстрок(МассивЕмайл, ", ");
		
	Структура = Новый Структура();
	Структура.Вставить("Контрагент"		, Контрагент);
	Структура.Вставить("Телефон"   		, ТелефоныСтрокой);
	Структура.Вставить("АдресЭП"   		, АдресаЭПСтрокой);
		
	Возврат Структура;
	
КонецФункции

// Функция - Получить email контрагента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьEmailКонтрагента(Контрагент) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	КонтрагентыКонтактнаяИнформация.АдресЭП КАК АдресЭП
	               |ИЗ
	               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	               |ГДЕ
	               |	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	               |	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	               |	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКлиента)
	               |	И КонтрагентыКонтактнаяИнформация.АдресЭП <> """"";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);    
	
	ВыборкаEmail = Запрос.Выполнить().Выбрать();
	Если ВыборкаEmail.Следующий() Тогда 
		Возврат СокрЛП(ВыборкаEmail.АдресЭП);
	Иначе 
	   	Возврат Null;
	КонецЕсли;
	
КонецФункции

// Функция, определяет, не запрещено ли обслуживание клиента.
//
Функция ОбслуживаниеКлиентаЗапрещено(Контрагент, СообщениеПользователю) Экспорт
	
	Если Контрагент.Теги.НайтиСтроки(Новый Структура("Тег", Справочники.Теги.ЗапретитьОбслуживание)).Количество() > 0 Тогда
		СообщениеПользователю = "Обслуживание клиента """ + СокрЛП(Контрагент) + """ запрещено!";
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Функция - Получить номер телефона для рассылки.
//
Функция ПолучитьНомерТелефонаДляРассылки(Контрагент, ВидКонтактнойИнформации) Экспорт
	
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("Вид"                   , ВидКонтактнойИнформации);
	ПараметрыПоиска.Вставить("НеУчаствоватьВРассылке", Ложь);
	
	НайденныеСтроки = Контрагент.КонтактнаяИнформация.НайтиСтроки(ПараметрыПоиска);
	НомерТелефона   = ?(ЗначениеЗаполнено(НайденныеСтроки), НайденныеСтроки[0].НомерТелефона, Неопределено);
	
	Возврат НомерТелефона;
	
КонецФункции

// Функция получения списка печатных форм.
