	             	  |				ТаблицаВидовСделокДляПродажи.ВидСделки
	             	  |			ИЗ
	             	  |				ТаблицаВидовСделокДляПродажи)
	             	  |	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	             	  |	И &УсловиеМенеджер					  
	             	  |	И Сделки.ПометкаУдаления = ЛОЖЬ
	             	  |	И Сделки.ЭтапСделки В
	             	  |			(ВЫБРАТЬ
	             	  |				ТаблицаЭтаповАктуальных.Ссылка
	             	  |			ИЗ
	             	  |				ТаблицаЭтаповАктуальных)
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             	  |	СделкиСведенияДляСписка.Сделка КАК Сделка
	             	  |ПОМЕСТИТЬ ТаблицаСделкиОжидаютАктивности
	             	  |ИЗ
	             	  |	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	             	  |ГДЕ
	             	  |	СделкиСведенияДляСписка.Сделка В
	             	  |			(ВЫБРАТЬ
	             	  |				ТаблицаСделок.Ссылка
	             	  |			ИЗ
	             	  |				ТаблицаСделок)
	             	  |	И НЕ СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ПометкаУдаления = ЛОЖЬ
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.Выполнена = ЛОЖЬ
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДатаНачало = ДАТАВРЕМЯ(1, 1, 1)
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаПериода И &ДатаОкончаниеПериода
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	СделкиСведенияДляСписка.Сделка
	             	  |
	             	  |ОБЪЕДИНИТЬ ВСЕ
	             	  |
	             	  |ВЫБРАТЬ
	             	  |	СделкиСведенияДляСписка.Сделка
	             	  |ИЗ
	             	  |	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	             	  |ГДЕ
	             	  |	СделкиСведенияДляСписка.Сделка В
	             	  |			(ВЫБРАТЬ
	             	  |				ТаблицаСделок.Ссылка
	             	  |			ИЗ
	             	  |				ТаблицаСделок)
	             	  |	И НЕ СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ПометкаУдаления = ЛОЖЬ
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.Выполнена = ЛОЖЬ
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДатаНачало <> ДАТАВРЕМЯ(1, 1, 1)
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДатаНачало >= &ДатаНачалаПериода
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата <= &ДатаОкончаниеПериода
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	СделкиСведенияДляСписка.Сделка
	             	  |
	             	  |ОБЪЕДИНИТЬ ВСЕ
	             	  |
	             	  |ВЫБРАТЬ
	             	  |	СделкиСведенияДляСписка.Сделка
	             	  |ИЗ
	             	  |	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	             	  |ГДЕ
	             	  |	СделкиСведенияДляСписка.Сделка В
	             	  |			(ВЫБРАТЬ
	             	  |				ТаблицаСделок.Ссылка
	             	  |			ИЗ
	             	  |				ТаблицаСделок)
	             	  |	И НЕ СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	СделкиСведенияДляСписка.Сделка					  
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             	  |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СделкиСведенияДляСписка.Сделка) КАК КоличествоБезАктивности
	             	  |ИЗ
	             	  |	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	             	  |ГДЕ
	             	  |	СделкиСведенияДляСписка.Сделка В
	             	  |			(ВЫБРАТЬ
	             	  |				ТаблицаСделок.Ссылка
	             	  |			ИЗ
	             	  |				ТаблицаСделок)
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
	             	  |	И СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             	  |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТаблицаСделкиОжидаютАктивности.Сделка) КАК КоличествоОжидающихАктивности
	             	  |ИЗ
	             	  |	ТаблицаСделкиОжидаютАктивности КАК ТаблицаСделкиОжидаютАктивности";
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	             	  |					ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	             	  |			ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	             	  |	И ", "");
		Если МассивСтруктурныхЕдиниц.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
			МассивСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
		КонецЕсли;		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "Сделки.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница)");
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", МассивСтруктурныхЕдиниц);
		
		//Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ДатаНачалаПериода"	, НачалоДня(ОтборПериодЗначение.ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончаниеПериода", КонецДня(ОтборПериодЗначение.ДатаОкончания));
	Если ЗначениеЗаполнено(ОтборСотрудники) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "(Сделки.Менеджер В(&МассивМенеджеров) ИЛИ Сделки.Менеджер = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка))");
		Запрос.УстановитьПараметр("МассивМенеджеров", ОтборСотрудники);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");
	КонецЕсли;	
	
	РезультатЗапроса 								= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваБезАктивности					= РезультатЗапроса[5].Выбрать();
	ВыборкаКоличестваОжидающихАктивности 			= РезультатЗапроса[6].Выбрать();
	
	Если ВыборкаКоличестваОжидающихАктивности.Следующий() Тогда
		КоличествоОжидающихАктивности = ВыборкаКоличестваОжидающихАктивности.КоличествоОжидающихАктивности;
	Иначе 
		КоличествоОжидающихАктивности = 0;		
	КонецЕсли;
	Элементы.ПерейтиСделкиОжидающиеАктивности.Заголовок 	= ?(КоличествоОжидающихАктивности > 0, Строка(КоличествоОжидающихАктивности) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Ожидает", КоличествоОжидающихАктивности) + Нстр("ru = ' активности'; en = ' activity'"), Нстр("ru='нет сделок с запланированной активностью';en='no deals with planned activity'")); // подготовить к переводу
	Элементы.ПерейтиСделкиОжидающиеАктивности.Доступность	= КоличествоОжидающихАктивности > 0;				
	// Элементы.ПерейтиКлиентыОжидающиеАктивности.ЦветТекста = ?(КоличествоОжидающихАктивности > 0, Новый Цвет(), Новый Цвет(242, 242, 242));					
		
	Если ВыборкаКоличестваБезАктивности.Следующий() Тогда
		КоличествоБезАктивности 							= ВыборкаКоличестваБезАктивности.КоличествоБезАктивности;		
	Иначе 	
		КоличествоБезАктивности 							= 0;		
	КонецЕсли;	
	Элементы.ПерейтиСделкиБезЗадач.Заголовок 		= Строка(КоличествоБезАктивности) + Нстр("ru=' без активности';en=' no activity'");
	Элементы.ПерейтиСделкиБезЗадач.Доступность 		= КоличествоБезАктивности > 0;					
	Элементы.ПерейтиСделкиБезЗадач.ЦветТекста 		= ?(КоличествоБезАктивности > 0, Новый Цвет(255, 0, 0), Новый Цвет(242, 242, 242));					
	// Элементы.ПерейтиСделкиБезЗадач.Видимость 		= КоличествоБезЗадач > 0;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить сведения по задачам
//
// Параметры:
//  ОтборСотрудники	 - 	 - 
//
Процедура ОбновитьСведенияПоЗадачам(ЗНАЧ ОтборСотрудники = Неопределено)
	
	Если ОтборСотрудники = Неопределено Тогда
		Если ОтборАдресатСведенийТип = "Мои" Тогда 
			ОтборСотрудники = Новый Массив;
			ОтборСотрудники.Добавить(ТекущийПользователь);
		ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
			ОтборСотрудники = СписокМенеджеровДляЗадач.ВыгрузитьЗначения();
		Иначе 	
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
			ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, СписокМенеджеровПоПродажам.ВыгрузитьЗначения()); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, ОтборСтруктурнаяЕдиница);
	Иначе
		МассивСтруктурныхЕдиниц 	= РегистрыСведений.НастройкиСотрудников.ПолучитьМестаРаботыСотрудника(ТекущийПользователь, "Массив");		
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, МассивСтруктурныхЕдиниц);
	КонецЕсли;	
		
	Запрос 			= Новый Запрос;
	Запрос.УстановитьПараметр("МассивДоступныхВидовСделок"	, МассивДоступныхВидовСделок);
	Запрос.УстановитьПараметр("МассивСотрудников"			, ОтборСотрудники);	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	Сотрудники.Ссылка КАК Исполнитель
	               |ПОМЕСТИТЬ ТаблицаИсполнителей
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.Ссылка В(&МассивСотрудников)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВидыСделок.Ссылка КАК ВидСделки
	               |ПОМЕСТИТЬ ТаблицаВидовСделок
	               |ИЗ
	               |	Справочник.ВидыСделок КАК ВидыСделок
	               |ГДЕ
	               |	ВидыСделок.Ссылка В(&МассивДоступныхВидовСделок)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	Взаимодействие.Ссылка КАК Взаимодействие,
	               |	Взаимодействие.Сделка КАК Сделка
	               |ПОМЕСТИТЬ ТаблицаЗадачиЗапланированные
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаИсполнителей КАК ТаблицаИсполнителей
	               |		ПО Взаимодействие.Исполнитель = ТаблицаИсполнителей.Исполнитель
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.Выполнена = ЛОЖЬ
	               |	И Взаимодействие.СтруктурнаяЕдиница = &ТекущаяСтруктурнаяЕдиница
	               |	И Взаимодействие.ЗадачаНазначеннаяДатаНачало = ДАТАВРЕМЯ(1, 1, 1)
	               |	И Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаПериода И &ДатаОкончаниеПериода
	               |	И Взаимодействие.Исполнитель <> НЕОПРЕДЕЛЕНО
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Сделка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Сделка
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаИсполнителей КАК ТаблицаИсполнителей
	               |		ПО Взаимодействие.Исполнитель = ТаблицаИсполнителей.Исполнитель
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.Выполнена = ЛОЖЬ
	               |	И Взаимодействие.СтруктурнаяЕдиница = &ТекущаяСтруктурнаяЕдиница
	               |	И Взаимодействие.ЗадачаНазначеннаяДатаНачало <> ДАТАВРЕМЯ(1, 1, 1)
	               |	И (Взаимодействие.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ДатаНачалаПериода И &ДатаОкончаниеПериода
	               |			ИЛИ Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаПериода И &ДатаОкончаниеПериода
	               |			ИЛИ &ДатаНачалаПериода >= Взаимодействие.ЗадачаНазначеннаяДатаНачало
	               |				И &ДатаОкончаниеПериода <= Взаимодействие.ЗадачаНазначеннаяДата)
	               |	И Взаимодействие.Исполнитель <> НЕОПРЕДЕЛЕНО
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Сделка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Взаимодействие.Ссылка КАК Взаимодействие,
	               |	Взаимодействие.Сделка КАК Сделка
	               |ПОМЕСТИТЬ ТаблицаЗадачиПросроченные
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаИсполнителей КАК ТаблицаИсполнителей
	               |		ПО Взаимодействие.Исполнитель = ТаблицаИсполнителей.Исполнитель
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.Выполнена = ЛОЖЬ
	               |	И Взаимодействие.СтруктурнаяЕдиница = &ТекущаяСтруктурнаяЕдиница
	               |	И Взаимодействие.ЗадачаНазначеннаяДата < &ТекущаяДата
	               |	И Взаимодействие.Исполнитель <> НЕОПРЕДЕЛЕНО
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Сделка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.Взаимодействие) КАК КоличествоНовыхЗадач
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ТаблицаЗадачиЗапланированные.Взаимодействие КАК Взаимодействие
	               |	ИЗ
	               |		ТаблицаЗадачиЗапланированные КАК ТаблицаЗадачиЗапланированные
	               |	ГДЕ
	               |		ТаблицаЗадачиЗапланированные.Сделка <> ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	               |		И ТаблицаЗадачиЗапланированные.Сделка.ВидСделки В
	               |				(ВЫБРАТЬ
	               |					ТаблицаВидовСделок.ВидСделки
	               |				ИЗ
	               |					ТаблицаВидовСделок)
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ТаблицаЗадачиЗапланированные.Взаимодействие
	               |	ИЗ
	               |		ТаблицаЗадачиЗапланированные КАК ТаблицаЗадачиЗапланированные
	               |	ГДЕ
	               |		ТаблицаЗадачиЗапланированные.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)) КАК ВложенныйЗапрос
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВложенныйЗапрос.Взаимодействие) КАК КоличествоПросроченныхЗадач
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ТаблицаЗадачиПросроченные.Взаимодействие КАК Взаимодействие
	               |	ИЗ
	               |		ТаблицаЗадачиПросроченные КАК ТаблицаЗадачиПросроченные
	               |	ГДЕ
	               |		ТаблицаЗадачиПросроченные.Сделка <> ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	               |		И ТаблицаЗадачиПросроченные.Сделка.ВидСделки В
	               |				(ВЫБРАТЬ
	               |					ТаблицаВидовСделок.ВидСделки
	               |				ИЗ
	               |					ТаблицаВидовСделок)
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ТаблицаЗадачиПросроченные.Взаимодействие
	               |	ИЗ
	               |		ТаблицаЗадачиПросроченные КАК ТаблицаЗадачиПросроченные
	               |	ГДЕ
	               |		ТаблицаЗадачиПросроченные.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)) КАК ВложенныйЗапрос";
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("ТекущаяСтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Взаимодействие.СтруктурнаяЕдиница = &ТекущаяСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;		
	Запрос.УстановитьПараметр("МассивСотрудников"			, ОтборСотрудники);		
	Запрос.УстановитьПараметр("ТекущаяДата"					, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("ДатаНачалаПериода"			, НачалоДня(ОтборПериодЗначение.ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончаниеПериода"		, КонецДня(ОтборПериодЗначение.ДатаОкончания));
		
	РезультатЗапроса 							= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваНовыхЗадач 				= РезультатЗапроса[4].Выбрать();
	ВыборкаКоличестваПросроченныхЗадач 			= РезультатЗапроса[5].Выбрать();
	
	Если ВыборкаКоличестваНовыхЗадач.Следующий() Тогда
		КоличествоНовыхЗадач = ВыборкаКоличестваНовыхЗадач.КоличествоНовыхЗадач;
	Иначе 
		КоличествоНовыхЗадач = 0;		
	КонецЕсли;
	Элементы.ПерейтиЗадачиНовые.Заголовок   = ?(КоличествоНовыхЗадач > 0, Строка(КоличествоНовыхЗадач) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Новая", КоличествоНовыхЗадач) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Задача", КоличествоНовыхЗадач), Нстр("ru='нет новых задач';en='not new tasks'")); // подготовить к переводу
	Элементы.ПерейтиЗадачиНовые.Доступность	= КоличествоНовыхЗадач > 0;				
	// Элементы.ПерейтиЗадачиНовые.ЦветТекста 			= ?(КоличествоНовыхЗадач > 0, Новый Цвет(), Новый Цвет(242, 242, 242));					
		
	Если ВыборкаКоличестваПросроченныхЗадач.Следующий() Тогда
		КоличествоПросроченныхЗадач = ВыборкаКоличестваПросроченныхЗадач.КоличествоПросроченныхЗадач;		
	Иначе 	
		КоличествоПросроченныхЗадач = 0;		
	КонецЕсли;	
	Элементы.ПерейтиЗадачиПросроченные.Заголовок 	= Строка(КоличествоПросроченныхЗадач) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Просроченная", КоличествоПросроченныхЗадач); // подготовить к переводу
	Элементы.ПерейтиЗадачиПросроченные.Доступность 	= КоличествоПросроченныхЗадач > 0;					
	Элементы.ПерейтиЗадачиПросроченные.ЦветТекста 	= ?(КоличествоПросроченныхЗадач > 0, Новый Цвет(255, 0, 0), Новый Цвет(242, 242, 242));					
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить сведения по сделкам
//
// Параметры:
//  ОтборСотрудники	 - 	 - 
//
Процедура ОбновитьСведенияПоСделкам(ЗНАЧ ОтборСотрудники = Неопределено)
	
	Если ОтборСотрудники = Неопределено ИЛИ ОтборАдресатСведенийТип = "Все" Тогда
		Если ОтборАдресатСведенийТип = "Мои" Тогда 
			ОтборСотрудники = Новый Массив;
			ОтборСотрудники.Добавить(ТекущийПользователь);
		ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина);				
		Иначе 	
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
			ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, Неопределено); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
		КонецЕсли;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, ОтборСтруктурнаяЕдиница);
	Иначе
		МассивСтруктурныхЕдиниц 	= РегистрыСведений.НастройкиСотрудников.ПолучитьМестаРаботыСотрудника(ТекущийПользователь, "Массив");		
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, МассивСтруктурныхЕдиниц);
	КонецЕсли;	
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивДоступныхВидовСделок", МассивДоступныхВидовСделок);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК ВидСделки
	|ПОМЕСТИТЬ ТаблицаВидовСделокДляПродажи
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Ссылка В(&МассивДоступныхВидовСделок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сделки.Ссылка) КАК КоличествоСделок,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	ЗНАЧЕНИЕ(Справочник.ПричиныОтказов.ПустаяСсылка) КАК ПричинаОтказа,
	|	СУММА(Сделки.СуммаСделки) КАК СуммаСделки
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.ВидСделки В
	|			(ВЫБРАТЬ
	|				ТаблицаВидовСделокДляПродажи.ВидСделки
	|			ИЗ
	|				ТаблицаВидовСделокДляПродажи)
	|	И НЕ Сделки.ЭтапСделки В (ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех), ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ), ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка))
	|	И &УсловиеМенеджер
	|	И Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.ВидСделки,
	|	Сделки.ЭтапСделки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сделки.Ссылка),
	|	Сделки.ВидСделки,
	|	Сделки.ЭтапСделки,
	|	ЕСТЬNULL(ВидыСделокПричиныОтказов.ПричинаОтказа, ЗНАЧЕНИЕ(Справочник.ПричиныОтказов.ПустаяСсылка)),
	|	СУММА(Сделки.СуммаСделки)
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыСделок.ПричиныОтказов КАК ВидыСделокПричиныОтказов
	|		ПО (Сделки.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ))
	|			И Сделки.ВидСделки = ВидыСделокПричиныОтказов.Ссылка
	|			И Сделки.ПричинаОтказа = ВидыСделокПричиныОтказов.ПричинаОтказа
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.ВидСделки В
	|			(ВЫБРАТЬ
	|				ТаблицаВидовСделокДляПродажи.ВидСделки
	|			ИЗ
	|				ТаблицаВидовСделокДляПродажи)
	|	И НЕ Сделки.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|	И Сделки.ЭтапСделки В (ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех), ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ))
	|	И Сделки.ДатаЗавершенияСделки МЕЖДУ &ДатаНачалаПериода И &ДатаОкончаниеПериода
	|	И &УсловиеМенеджер
	|	И Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НЕ Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.ВидСделки,
	|	Сделки.ЭтапСделки,
	|	ЕСТЬNULL(ВидыСделокПричиныОтказов.ПричинаОтказа, ЗНАЧЕНИЕ(Справочник.ПричиныОтказов.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.Менеджер КАК Менеджер,
	|	Сделки.Прием КАК Реализация
	|ПОМЕСТИТЬ ТаблицаУспешныхСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.ВидСделки В
	|			(ВЫБРАТЬ
	|				ТаблицаВидовСделокДляПродажи.ВидСделки
	|			ИЗ
	|				ТаблицаВидовСделокДляПродажи)
	|	И Сделки.ЭтапСделки = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех)
	|	И Сделки.ДатаЗавершенияСделки МЕЖДУ &ДатаНачалаПериода И &ДатаОкончаниеПериода
	|	И &УсловиеМенеджер
	|	И Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сделки.Прием <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.Ссылка,
	|	Сделки.Менеджер,
	|	Сделки.Прием
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Реализация.Сделка КАК Сделка,
	|	Реализация.Сделка.ВидСделки КАК ВидСделки,
	|	СУММА(Реализация.СуммаДокумента) КАК СуммаПродаж
	|ПОМЕСТИТЬ ТаблицаРеализацийПоСделкам
	|ИЗ
	|	Документ.Реализация КАК Реализация
	|ГДЕ
	|	Реализация.Сделка В
	|			(ВЫБРАТЬ
	|				ТаблицаУспешныхСделок.Сделка
	|			ИЗ
	|				ТаблицаУспешныхСделок)
	|
	|СГРУППИРОВАТЬ ПО
	|	Реализация.Сделка,
	|	Реализация.Сделка.ВидСделки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.ВидСделки КАК ВидСделки,
	|	СУММА(ВложенныйЗапрос.СуммаПродаж) КАК СуммаПродаж
	|ИЗ
	|	(ВЫБРАТЬ
	|		РеализацийПоСделкам.ВидСделки КАК ВидСделки,
	|		СУММА(РеализацийПоСделкам.СуммаПродаж) КАК СуммаПродаж
	|	ИЗ
	|		ТаблицаРеализацийПоСделкам КАК РеализацийПоСделкам
	|	
	|	СГРУППИРОВАТЬ ПО
	|		РеализацийПоСделкам.ВидСделки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТаблицаУспешныхСделок.Сделка.ВидСделки,
	|		СУММА(ТаблицаУспешныхСделок.Реализация.СуммаДокумента)
	|	ИЗ
	|		ТаблицаУспешныхСделок КАК ТаблицаУспешныхСделок
	|	ГДЕ
	|		НЕ ТаблицаУспешныхСделок.Сделка В
	|					(ВЫБРАТЬ
	|						ТаблицаРеализацийПоСделкам.Сделка
	|					ИЗ
	|						ТаблицаРеализацийПоСделкам)
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаУспешныхСделок.Сделка.ВидСделки) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.ВидСделки";
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "(ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	             	  |			ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	             	  |	И ", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;		
	Запрос.УстановитьПараметр("ДатаНачалаПериода"	, НачалоДня(ОтборПериодЗначение.ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончаниеПериода", КонецДня(ОтборПериодЗначение.ДатаОкончания));
	Если ЗначениеЗаполнено(ОтборСотрудники) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "(Сделки.Менеджер В(&МассивМенеджеров) ИЛИ Сделки.Менеджер = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка))");
		Запрос.УстановитьПараметр("МассивМенеджеров", ОтборСотрудники);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");
	КонецЕсли;	
	
	РезультатПакетаЗапросов 	= Запрос.ВыполнитьПакет();
	
	ТаблицаСведенийПоСделкам 	= РезультатПакетаЗапросов[1].Выгрузить();	
	ТаблицаПродажПоСделкам 		= РезультатПакетаЗапросов[4].Выгрузить();	
	
	СимвольныйКодЦелойчастиВалюты = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты(ТекущаяВалюта);
	Для Каждого СтрокаЭтапСделки Из ТаблицаВидовСделок Цикл 
		Если СтрокаЭтапСделки.ЭтапСделки = Справочники.ЭтапыСделок.Отказ И ЗначениеЗаполнено(СтрокаЭтапСделки.ТаблицаПричинОтказов) Тогда
			Для Каждого СтрокаПричина Из СтрокаЭтапСделки.ТаблицаПричинОтказов Цикл 
				МассивСтрок = ТаблицаСведенийПоСделкам.НайтиСтроки(Новый Структура("ВидСделки, ЭтапСделки, ПричинаОтказа", СтрокаЭтапСделки.ВидСделки, СтрокаЭтапСделки.ЭтапСделки, СтрокаПричина.ПричинаОтказа)); 
				ЭлементКоличествоСделок = СтрокаПричина.ЭлементКоличествоСделок;
				ЭлементСуммаСделок 		= СтрокаПричина.ЭлементСуммаСделок;
				ОбновитьСвойстваЭлементовЭтапаВоронки(СтрокаЭтапСделки, МассивСтрок, ТаблицаПродажПоСделкам, СимвольныйКодЦелойчастиВалюты, ЭлементКоличествоСделок, ЭлементСуммаСделок);
			КонецЦикла;	
		Иначе 
			МассивСтрок = ТаблицаСведенийПоСделкам.НайтиСтроки(Новый Структура("ВидСделки, ЭтапСделки", СтрокаЭтапСделки.ВидСделки, СтрокаЭтапСделки.ЭтапСделки)); 
			ЭлементКоличествоСделок 	= СтрокаЭтапСделки.ЭлементКоличествоСделок;
			ЭлементСуммаСделок 			= СтрокаЭтапСделки.ЭлементСуммаСделок;			
			ОбновитьСвойстваЭлементовЭтапаВоронки(СтрокаЭтапСделки, МассивСтрок, ТаблицаПродажПоСделкам, СимвольныйКодЦелойчастиВалюты, ЭлементКоличествоСделок, ЭлементСуммаСделок);
		КонецЕсли;
	КонецЦикла;	
		
КонецПроцедуры	

&НаСервере
// Процедура - Обновить свойства элементов этапа сделки
//
// Параметры:
//  СтрокаЭтапСделки				 - 	 - 
//  МассивСтрок						 - 	 - 
//  ТаблицаПродажПоСделкам			 - 	 - 
//  СимвольныйКодЦелойчастиВалюты	 - 	 - 
//  ЭлементКоличествоСделок			 - 	 - 
//  ЭлементСуммаСделок				 - 	 - 
//
Процедура ОбновитьСвойстваЭлементовЭтапаВоронки(СтрокаЭтапСделки, МассивСтрок, ТаблицаПродажПоСделкам, СимвольныйКодЦелойчастиВалюты, ЭлементКоличествоСделок, ЭлементСуммаСделок)

	Если МассивСтрок.Количество() = 0 Тогда 
		Элементы[ЭлементКоличествоСделок].Заголовок 	= Формат(0, "ЧН=0");// + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Сделка", 0);// подготовить к переводу
		Элементы[ЭлементКоличествоСделок].Доступность 	= Ложь;
		Элементы[ЭлементКоличествоСделок].ЦветТекста 	= Новый Цвет(239, 239, 239);			
		Элементы[ЭлементСуммаСделок].Заголовок 		= "0,00" + " " + СимвольныйКодЦелойчастиВалюты;
		Элементы[ЭлементСуммаСделок].Доступность 		= Ложь;			
	Иначе 
		Элементы[ЭлементКоличествоСделок].Заголовок 	= Формат(МассивСтрок[0].КоличествоСделок, "ЧДЦ=0; ЧН=0");// + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Сделка", МассивСтрок[0].КоличествоСделок); // подготовить к переводу
		Элементы[ЭлементКоличествоСделок].ЦветТекста 	= ?(МассивСтрок[0].КоличествоСделок > 0, Новый Цвет(), Новый Цвет(242, 242, 242));			
		Элементы[ЭлементКоличествоСделок].Доступность 	= ?(МассивСтрок[0].КоличествоСделок > 0, Истина, Ложь);
		Если СтрокаЭтапСделки.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда 
			СуммаПродаж = 0;				
			СтрокаСуммаПродаж = ТаблицаПродажПоСделкам.Найти(СтрокаЭтапСделки.ВидСделки, "ВидСделки");
			Если СтрокаСуммаПродаж <> Неопределено Тогда 
				СуммаПродаж = ?(ЗначениеЗаполнено(СтрокаСуммаПродаж.СуммаПродаж), СтрокаСуммаПродаж.СуммаПродаж, 0);
			КонецЕсли;	
		Иначе
			СуммаПродаж = МассивСтрок[0].СуммаСделки;								
		КонецЕсли;	
		Элементы[ЭлементСуммаСделок].Заголовок 		= ?(СуммаПродаж > 0, Формат(СуммаПродаж, "ЧДЦ=1; ЧН=0"), "0,00") + " " + СимвольныйКодЦелойчастиВалюты;			
		Элементы[ЭлементСуммаСделок].Доступность 		= Ложь;									
	КонецЕсли;	
	
КонецПроцедуры

