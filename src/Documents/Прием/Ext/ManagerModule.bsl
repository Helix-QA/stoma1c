// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Ложь;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_Квитанция") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_Квитанция", "Квитанция", СформироватьПечатнуюФорму_Квитанция(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_Квитанция"));
	КонецЕсли;
		
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_АктОВыполненныхРаботах") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_АктОВыполненныхРаботах", "Акт о выполненных работах", СформироватьПечатнуюФорму_АктОВыполненныхРаботах(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_АктОВыполненныхРаботах"));
	КонецЕсли; 
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_АктОВыполненныхРаботахБезСумм") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_АктОВыполненныхРаботахБезСумм", "Акт о выполненных работах (без сумм)", СформироватьПечатнуюФорму_АктОВыполненныхРаботахБезСумм(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_АктОВыполненныхРаботах"));
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_Справка") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_Справка", "Справка", СформироватьПечатнуюФорму_СправкаВНалоговую(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_Справка"));
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ТалонАмбулаторногоПациента") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_ТалонАмбулаторногоПациента", "Талон амбулаторного пациента", СформироватьПечатнуюФорму_ТалонАмбулаторногоПациента(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_ТалонАмбулаторногоПациента"));
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ГарантийныйТалон") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_ГарантийныйТалон", "Гарантийный талон", СформироватьПечатнуюФорму_ГарантийныйТалон(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_ГарантийныйТалон"));
	КонецЕсли; 
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_КонсультацияВрача") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_КонсультацияВрача", "Консультация врача", СформироватьПечатнуюФорму_КонсультацияВрача(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_КонсультацияВрача"));
	КонецЕсли;
	
КонецПроцедуры // Печать()

// Функция - Получить результат запроса
//
// Параметры:
//  ТекущийДокумент	 - 	 Текущий документ 
// 
Функция ПолучитьРезультатЗапроса(ТекущийДокумент)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Номер КАК Номер,
	|	Прием.Дата КАК Дата,
	|	Прием.СтруктурнаяЕдиница.Организация КАК Организация,
	|	Прием.Контрагент КАК Пациент,
	|	Прием.Сотрудник КАК Врач,
	|	Прием.СуммаДокумента КАК ОбщееИтогоСоСкидкой,
	|	Прием.СуммаОплачено КАК ИтогоОплачено,
	|	Прием.ПредварительнаяЗаписьНаСледующийПрием КАК ПредварительнаяЗапись,
	|	ВложенныйЗапрос.Диагноз КАК Диагноз
	|ИЗ
	|	Документ.Прием КАК Прием
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗначенияПараметровОбследований.Документ КАК Документ,
	|			ЗначенияПараметровОбследований.Значение КАК Диагноз
	|		ИЗ
	|			РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
	|		ГДЕ
	|			ЗначенияПараметровОбследований.Параметр = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ПараметрыОбследований.Диагноз)) КАК ВложенныйЗапрос
	|		ПО Прием.Ссылка = ВложенныйЗапрос.Документ
	|ГДЕ
	|	Прием.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НарядЗаказ.Номер,
	|	НарядЗаказ.Дата,
	|	НарядЗаказ.СтруктурнаяЕдиница.Организация,
	|	НарядЗаказ.Контрагент,
	|	НарядЗаказ.Сотрудник,
	|	НарядЗаказ.СуммаПродажи,
	|	НарядЗаказ.СуммаОплаченоПродажи,
	|	NULL,
	|	NULL
	|ИЗ
	|	Документ.НарядЗаказ КАК НарядЗаказ
	|ГДЕ
	|	НарядЗаказ.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПланЛечения.Номер,
	|	ПланЛечения.Дата,
	|	ПланЛечения.СтруктурнаяЕдиница.Организация,
	|	ПланЛечения.Контрагент,
	|	ПланЛечения.Сотрудник,
	|	ПланЛечения.СуммаДокумента,
	|	ПланЛечения.СуммаОплачено,
	|	NULL,
	|	NULL
	|ИЗ
	|	Документ.ПланЛечения КАК ПланЛечения
	|ГДЕ
	|	ПланЛечения.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реализация.Номер,
	|	Реализация.Дата,
	|	Реализация.СтруктурнаяЕдиница.Организация,
	|	Реализация.Контрагент,
	|	Реализация.Сотрудник,
	|	Реализация.СуммаДокумента,
	|	Реализация.СуммаОплачено,
	|	NULL,
	|	NULL
	|ИЗ
	|	Документ.Реализация КАК Реализация
	|ГДЕ
	|	Реализация.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(ПриемЛечение.НомерСтроки) КАК НомерСтроки,
	|	ПриемЛечение.Номенклатура КАК Услуга,
	|	СУММА(ПриемЛечение.КоличествоУпаковок) КАК Количество,
