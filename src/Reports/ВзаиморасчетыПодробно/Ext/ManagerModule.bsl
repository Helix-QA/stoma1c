
#Область СлужебныйПрограммныйИнтерфейс

// Процедура, выполняет формирование отчета по информации клиента
//
Процедура ВывестиАктОбОказанныхУслугах(Контрагент, СтруктурнаяЕдиница, ТабличныйДокумент, НачалоПериода, КонецПериода) Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Проверка, выбран ли клиент
	Если Контрагент = Справочники.Контрагенты.ПустаяСсылка() Тогда		
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru = 'Не выбран клиент!'");
		Сообщение.Сообщить();
		Возврат;		
	КонецЕсли;
	
	// Проверка, выбрана ли СтруктурнаяЕдиница
	Если СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка() Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.ТолькоПросмотр = Истина;
	Если не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	// Получение макета	
	Макет = Отчеты.ВзаиморасчетыПодробно.ПолучитьМакет("Макет");
	
	ЭтоСетьСтоматологий = (Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть);
	
	ЗапросОбщейИнформации = Новый Запрос;
	ЗапросОбщейИнформации.УстановитьПараметр("Клиент", Контрагент);
	ЗапросОбщейИнформации.УстановитьПараметр("ЭтоСеть", ЭтоСетьСтоматологий);
	ЗапросОбщейИнформации.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	ЗапросОбщейИнформации.УстановитьПараметр("НачалоПериода", НачалоПериода);
	ЗапросОбщейИнформации.УстановитьПараметр("КонецПериода", КонецПериода);
	
	ЗапросОбщейИнформации.Текст = ПолучитьЗапросОбщейИнформации();
	
	Пакеты = ЗапросОбщейИнформации.ВыполнитьПакет();
	ВыборкаПоДатам = Пакеты[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 	
	Остатки = Пакеты[1].Выбрать();
	
	Если Остатки.Следующий() ТОгда
		
		ОстатокНаНачало = Остатки.СуммаНачальныйОстаток;
		ОстатокНаКонец = Остатки.СуммаКонечныйОстаток;
	Иначе
		ОстатокНаНачало = 0;
		ОстатокНаКонец = 0;	
	КонецЕсли;
	
	//=============================================ВЫВОД ИСТОРИИ ВЫПОЛНЕННЫХ РАБОТ===============================================	
	Если ВыборкаПоДатам.Количество() > 0 Тогда
		ИтогоСуммаСкидки 	= 0;
		ИтогоСуммаСоСкидкой = 0;
		ИтогоОплачено 		= 0; 
		Область_Заголовок = Макет.ПолучитьОбласть("Заголовок");
		Если не ЗначениеЗаполнено(НачалоПериода) И не ЗначениеЗаполнено(КонецПериода) Тогда 
			Область_Заголовок.НайтиТекст("Взаиморасчеты за период с [НачалоПериода] по [КонецПериода]").Текст = "Взаиморасчеты за весь период";
		Иначе
			Область_Заголовок.Параметры.НачалоПериода = Формат(НачалоПериода, "ДФ=dd.MM.yyyy");
			Область_Заголовок.Параметры.КонецПериода = Формат(КонецПериода, "ДФ=dd.MM.yyyy");
		КонецЕсли;	
		
		Область_Заголовок.Параметры.Клиент = Контрагент;
		ТабличныйДокумент.Вывести(Область_Заголовок);
		Область_ШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
		Область_ШапкаТаблицы.Параметры.ДатаНомерЗуба = "Дата / № зуба";
		ТабличныйДокумент.Вывести(Область_ШапкаТаблицы);
		
		/// Выведем итоговую строку на начало периода.
		Область_ИтоговаяСтрока = Макет.ПолучитьОбласть("СтрокаГруппировкаИтоги");
		Если ОстатокНаНачало > 0 Тогда
			Область_ИтоговаяСтрока.Параметры.ДолгПередПациентом = ОстатокНаНачало;                         
			Область_ИтоговаяСтрока.Параметры.ВидДолга = "Долг перед пациентом на начало периода:";
		Иначе
			Область_ИтоговаяСтрока.Параметры.ДолгПациента = -ОстатокНаНачало;
			Область_ИтоговаяСтрока.Параметры.ВидДолга = "Долг пациента на начало периода:";
		КонецЕсли;
		ТабличныйДокумент.Вывести(Область_ИтоговаяСтрока);
		Область_СтрокаГруппировкаДолг = Макет.ПолучитьОбласть("СтрокаГруппировкаДолг");
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Клиент", Контрагент);
		Запрос.УстановитьПараметр("ЭтоСеть", ЭтоСетьСтоматологий);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		ПредыдущаяДата = Дата(1,1,1);
		Пока ВыборкаПоДатам.Следующий() Цикл
			ДатаЗаписи = ?(ВыборкаПоДатам.Дата = NULL, Дата(1,1,1), ВыборкаПоДатам.Дата);
			
			Если НачалоДня(ПредыдущаяДата) < НачалоДня(ДатаЗаписи) И ПредыдущаяДата > Дата(1,1,1) Тогда
				ТабличныйДокумент.Вывести(Область_СтрокаГруппировкаДолг);
			КонецЕсли;
			
			Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ДатаЗаписи)); 
			Запрос.УстановитьПараметр("КонецПериода", КонецДня(ДатаЗаписи));  
			Запрос.Текст = ПолучитьОстатки();
			Остатки = Запрос.Выполнить().Выбрать();
			Если Остатки.Следующий() Тогда
				Остаток = Остатки.СуммаКонечныйОстаток;
			Иначе 
				Остаток = 0;
			КонецЕсли;
			Если Остаток > 0 Тогда
				ДолгНадпись = "Долг перед пациентом на " + Формат(ДатаЗаписи, "ДФ=dd.MM.yyyy") + ":";
				Область_СтрокаГруппировкаДолг.Параметры.ДолгПередПациентом =  Остаток;
				Область_СтрокаГруппировкаДолг.Параметры.ДолгПациента = "";
			ИначеЕсли  Остаток = 0 Тогда
				ДолгНадпись = "Долг пациента на "  + Формат(ДатаЗаписи, "ДФ=dd.MM.yyyy") + ":";
				Область_СтрокаГруппировкаДолг.Параметры.ДолгПациента =  0;
				Область_СтрокаГруппировкаДолг.Параметры.ДолгПередПациентом = "";
			Иначе
				ДолгНадпись = "Долг пациента на "  + Формат(ДатаЗаписи, "ДФ=dd.MM.yyyy") + ":";
				Область_СтрокаГруппировкаДолг.Параметры.ДолгПациента =  - Остаток;
				Область_СтрокаГруппировкаДолг.Параметры.ДолгПередПациентом = "";
			КонецЕсли;
			Область_СтрокаГруппировкаДолг.Параметры.ДолгНадпись = ДолгНадпись;
			сч = 1;
			Результат = ВыборкаПоДатам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Результат.Следующий() Цикл		
				Если ТипЗнч(Результат.ДокументПродажи) = Тип("ДокументСсылка.Прием") 
					И ЗначениеЗаполнено(Результат.ДокументПродажи.ПолисМедСтрахования) Тогда
					
					Область_СтрокаГруппировкаПоДокументуПоСтрах= Макет.ПолучитьОбласть("СтрокаГруппировкаПоДокументуПоСтрах");
					Область_СтрокаГруппировкаПоДокументуПоСтрах.Параметры.Документ = Результат.ДокументПродажи;
					Область_СтрокаГруппировкаПоДокументуПоСтрах.Параметры.СтраховойПолис = Результат.ДокументПродажи.ПолисМедСтрахования;
					Если НачалоДня(ПредыдущаяДата) < НачалоДня(ДатаЗаписи) Тогда
						Область_СтрокаГруппировкаПоДокументуПоСтрах.Область(1,1,1,12).ГраницаСверху = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1); 
						Если  сч = 1 Тогда
							Область_СтрокаГруппировкаПоДокументуПоСтрах.Параметры.Дата =  ДатаЗаписи;
						Иначе 
							Область_СтрокаГруппировкаПоДокументуПоСтрах.Параметры.Дата =  "";
						КонецЕсли;
						ПредыдущаяДата = ДатаЗаписи;
					КонецЕсли;
					ТабличныйДокумент.Вывести(Область_СтрокаГруппировкаПоДокументуПоСтрах);
				Иначе
					Область_СтрокаГруппировкаПоДокументу = Макет.ПолучитьОбласть("СтрокаГруппировкаПоДокументу");
					Область_СтрокаГруппировкаПоДокументу.Параметры.Документ = Результат.ДокументПродажи;
					Область_СтрокаГруппировкаПоДокументу.Параметры.СуммаСкидкиПриема 	= Результат.Скидка_Сумма;
					Область_СтрокаГруппировкаПоДокументу.Параметры.СуммаСоСкидкойПриема = Результат.СтоимостьСоСкидкой;
					Область_СтрокаГруппировкаПоДокументу.Параметры.Оплачено 			= Результат.Оплачено;
					Если НачалоДня(ПредыдущаяДата) < НачалоДня(ДатаЗаписи) Тогда
						Область_СтрокаГруппировкаПоДокументу.Область(1,1,1,12).ГраницаСверху = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1); 
						Если  сч = 1 Тогда
							Область_СтрокаГруппировкаПоДокументу.Параметры.Дата =  ДатаЗаписи;
						Иначе 
							Область_СтрокаГруппировкаПоДокументу.Параметры.Дата =  "";
						КонецЕсли;
						ПредыдущаяДата = ДатаЗаписи;
					КонецЕсли;
					ТабличныйДокумент.Вывести(Область_СтрокаГруппировкаПоДокументу);
				КонецЕсли;
				ИтогоСуммаСкидки 	= ИтогоСуммаСкидки + Результат.Скидка_Сумма;
				ИтогоСуммаСоСкидкой = ИтогоСуммаСоСкидкой + Результат.СтоимостьСоСкидкой;
				ИтогоОплачено 		= ИтогоОплачено + Результат.Оплачено;
				
				ВыборкаПоУслугам = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаПоУслугам.Следующий() Цикл
					Если не ЗначениеЗаполнено(ВыборкаПоУслугам.Услуга) Тогда
						Продолжить;
					КонецЕсли;
					Область_СтрокаУслуга = Макет.ПолучитьОбласть("СтрокаУслуга");
					Область_СтрокаУслуга.Параметры.Услуга 			= ВыборкаПоУслугам.Услуга;
					Область_СтрокаУслуга.Параметры.Количество 		= ВыборкаПоУслугам.Количество;
					Если ТипЗнч(Результат.ДокументПродажи) = Тип("ДокументСсылка.Прием") 
						И ЗначениеЗаполнено(Результат.ДокументПродажи.ПолисМедСтрахования) Тогда
						Область_СтрокаУслуга.Параметры.СуммаСкидки 		= 0;
						Область_СтрокаУслуга.Параметры.СуммаСоСкидкой 	= 0;
						Область_СтрокаУслуга.Параметры.Оплачено 	    = 0;
					Иначе
						Область_СтрокаУслуга.Параметры.СуммаСкидки 		= ВыборкаПоУслугам.Скидка_Сумма;
						Область_СтрокаУслуга.Параметры.СуммаСоСкидкой 	= ВыборкаПоУслугам.СтоимостьСоСкидкой;
						Область_СтрокаУслуга.Параметры.Оплачено 	    = ВыборкаПоУслугам.Оплачено;
					КонецЕсли;
					СтрокаЗубы = "";
					Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") И ВыборкаПоУслугам.Услуга.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
						ВыборкаПоЗубам = ВыборкаПоУслугам.Выбрать(ОбходРезультатаЗапроса.Прямой);
						
						Пока ВыборкаПоЗубам.Следующий() Цикл
							Если ПустаяСтрока(СтрокаЗубы) Тогда 
								СтрокаЗубы = СтрокаЗубы + ВыборкаПоЗубам.НомерЗуба;
							Иначе 
								СтрокаЗубы = СтрокаЗубы + ", " + ВыборкаПоЗубам.НомерЗуба;
							КонецЕсли;
						КонецЦикла;	
						
						Область_СтрокаУслуга.Параметры.НомерЗуба = СтрокаЗубы;
					КонецЕсли;				
					Область_СтрокаУслуга.Параметры.КодУслуги = ВыборкаПоУслугам.КодУслуги;
					ТабличныйДокумент.Вывести(Область_СтрокаУслуга);
				КонецЦикла;
				сч = сч + 1;
			КонецЦикла;
			// ТабличныйДокумент.Вывести(Область_СтрокаГруппировкаДолг);		
		КонецЦикла;	
		
		ТабличныйДокумент.Вывести(Область_СтрокаГруппировкаДолг);
		
		Область_ПодвалТаблицы = Макет.ПолучитьОбласть("ПодвалТаблицы");
		Область_ПодвалТаблицы.Параметры.ИтогоСуммаСкидки 	= Формат(ИтогоСуммаСкидки, "ЧДЦ=2; ЧРД=.; ЧН=");
		Область_ПодвалТаблицы.Параметры.ИтогоСоСкидкой 		= Формат(ИтогоСуммаСоСкидкой, "ЧДЦ=2; ЧРД=.; ЧН=");
		Область_ПодвалТаблицы.Параметры.ИтогоОплачено 		= Формат(ИтогоОплачено, "ЧДЦ=2; ЧРД=.; ЧН=");
		ТабличныйДокумент.Вывести(Область_ПодвалТаблицы);
		
		/// Выведем итоговую строку на конец периода.
		Область_ИтоговаяСтрока = Макет.ПолучитьОбласть("СтрокаГруппировкаИтоги");
		Если ОстатокНаКонец >0 Тогда
			Область_ИтоговаяСтрока.Параметры.ДолгПередПациентом = ОстатокНаКонец;
			Область_ИтоговаяСтрока.Параметры.ВидДолга = "Долг перед пациентом на конец периода:";  
		Иначе
			Область_ИтоговаяСтрока.Параметры.ДолгПациента = -ОстатокНаКонец;
			Область_ИтоговаяСтрока.Параметры.ВидДолга = "Долг пациента на конец периода:";
		КонецЕсли;
		ТабличныйДокумент.Вывести(Область_ИтоговаяСтрока);
	КонецЕсли;
	
	// Секция -------------------- "История операций" -------------------
	
	ЗапросИсторияОпераций = Новый Запрос;
	ЗапросИсторияОпераций.УстановитьПараметр("Клиент", Контрагент);
	ЗапросИсторияОпераций.УстановитьПараметр("ЭтоСеть", ЭтоСетьСтоматологий);
	ЗапросИсторияОпераций.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	ЗапросИсторияОпераций.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Если КонецПериода = Дата(1,1,1) ИЛИ НЕ ЗначениеЗаполнено(КонецПериода) Тогда	
		ЗапросИсторияОпераций.УстановитьПараметр("КонецПериода", Дата(3999,1,1));
	Иначе
		ЗапросИсторияОпераций.УстановитьПараметр("КонецПериода", КонецПериода);	
	КонецЕсли;	
	
	ЗапросИсторияОпераций.Текст = ПолучитьЗапросИсторияОпераций();
	
	РезультатИсторияОпераций = ЗапросИсторияОпераций.Выполнить().Выбрать();
	
	Если РезультатИсторияОпераций.Количество() > 0 Тогда
		
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ШапкаИсторияОпераций"));
		
		// Итог нач.
		ДолгИтог = 0;
		АвансИтог = 0;
		ЛсИтог = 0;
		
		ОбластьИтоги = Макет.ПолучитьОбласть("СтрокаИтоги");
		Если НачалоПериода <> Дата(1,1,1) И ЗначениеЗаполнено(НачалоПериода) Тогда
			
			ЗапросНачИтог = Новый Запрос;
			ЗапросНачИтог.УстановитьПараметр("Клиент", Контрагент);
			ЗапросНачИтог.УстановитьПараметр("ЭтоСеть", ЭтоСетьСтоматологий);
			ЗапросНачИтог.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
			ЗапросНачИтог.УстановитьПараметр("НачалоПериода", Дата(1,1,1));
			ЗапросНачИтог.УстановитьПараметр("КонецПериода", НачалоПериода-1);		
			
			ЗапросНачИтог.Текст = ПолучитьЗапросИсторияОпераций();
			
			РезультатНачИтог = ЗапросНачИтог.Выполнить().Выгрузить();
			ДолгИтог = РезультатНачИтог.Итог("Долг");
			АвансИтог = РезультатНачИтог.Итог("Аванс");
			ЛсИтог = РезультатНачИтог.Итог("ЛицевойСчет");
			
			ОбластьИтоги.Параметры.НаПериод = "На начало периода:";	
			ОбластьИтоги.Параметры.ДолгИтог = ДолгИтог; 
			ОбластьИтоги.Параметры.АвансИтог = АвансИтог;
			ОбластьИтоги.Параметры.ЛсИтог = ЛсИтог;
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьИтоги);
		
		ОбластьСтрокаИстория = Макет.ПолучитьОбласть("СтрокаИсторяОпераций");
		Пока РезультатИсторияОпераций.Следующий() Цикл 
			
			ЗаполнитьЗначенияСвойств(ОбластьСтрокаИстория.Параметры, РезультатИсторияОпераций);
			Если СокрЛП(РезультатИсторияОпераций.Операция) = "Наличные" Тогда
				ОбластьСтрокаИстория.Параметры.Операция = "Оплата наличными";		
			ИначеЕсли СокрЛП(РезультатИсторияОпераций.Операция) = "Платежная карта" Тогда
				ОбластьСтрокаИстория.Параметры.Операция = "Оплата платежной картой";	
			ИначеЕсли СокрЛП(РезультатИсторияОпераций.Операция) = "Лицевой счет" Тогда	
				
				Если ТипЗнч(РезультатИсторияОпераций.Регистратор) = Тип("ДокументСсылка.НарядЗаказ") 
					Или ТипЗнч(РезультатИсторияОпераций.Регистратор) = Тип("ДокументСсылка.Поступление") Тогда 
					
					ЕстьДокументОснованияВРасшифровке = ЗначениеЗаполнено(ОбластьСтрокаИстория.Параметры.Регистратор.ДокументОснование);
					
				ИначеЕсли ТипЗнч(РезультатИсторияОпераций.Регистратор) = Тип("ДокументСсылка.ВозвратПоставщику") Тогда 
					
					ЕстьДокументОснованияВРасшифровке = ЗначениеЗаполнено(ОбластьСтрокаИстория.Параметры.Регистратор.ОснованиеВозврата);
					
				ИначеЕсли ТипЗнч(ОбластьСтрокаИстория.Параметры.Регистратор) = Тип("ДокументСсылка.СписаниеЗадолженности") Тогда
					ЕстьДокументОснованияВРасшифровке = ЗначениеЗаполнено(ОбластьСтрокаИстория.Параметры.Регистратор.РасшифрокаСписания[0].ДокументОснования);
					
				Иначе 
					
					Если ОбластьСтрокаИстория.Параметры.Регистратор.Метаданные().ТабличныеЧасти.Найти("РасшифровкаПлатежа") <> Неопределено Тогда 
						ЕстьДокументОснованияВРасшифровке = ЗначениеЗаполнено(ОбластьСтрокаИстория.Параметры.Регистратор.РасшифровкаПлатежа[0].ДокументОснования);	
					Иначе
						ЕстьДокументОснованияВРасшифровке = Ложь;
					КонецЕсли;
					
				КонецЕсли;	
				                                                                         	
				Если ТипЗнч(РезультатИсторияОпераций.Регистратор) = Тип("ДокументСсылка.ПеремещениеДенежныхСредств") Тогда
					
					ОбластьСтрокаИстория.Параметры.Операция = "Перемещение денежных средств";      
					
				ИначеЕсли РезультатИсторияОпераций.ЛицевойСчет <  0 И ЕстьДокументОснованияВРасшифровке = Ложь 
					И ТипЗнч(РезультатИсторияОпераций.Регистратор) = Тип("ДокументСсылка.СписаниеДенежныхСредств") 
					И РезультатИсторияОпераций.Регистратор.ВидОперации = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета Тогда					
					
					ОбластьСтрокаИстория.Параметры.Операция = "Возврат с лицевого счета";
					
				ИначеЕсли РезультатИсторияОпераций.ЛицевойСчет <  0 И ЕстьДокументОснованияВРасшифровке = Истина Тогда					
					
					ОбластьСтрокаИстория.Параметры.Операция = "Оплата с лицевого счета";
					
				КонецЕсли;
			КонецЕсли;  			
			
			ДолгИтог = ДолгИтог + РезультатИсторияОпераций.Долг;
			АвансИтог = АвансИтог + РезультатИсторияОпераций.Аванс;
			ЛсИтог = ЛсИтог + РезультатИсторияОпераций.ЛицевойСчет;
			
			ТабличныйДокумент.Вывести(ОбластьСтрокаИстория);
		КонецЦикла;
		
		// Итог кон.
		ОбластьИтоги = Макет.ПолучитьОбласть("СтрокаИтоги");
		ОбластьИтоги.Параметры.НаПериод = "На конец периода:";	
		ОбластьИтоги.Параметры.ДолгИтог = ДолгИтог; 
		ОбластьИтоги.Параметры.АвансИтог = АвансИтог;
		ОбластьИтоги.Параметры.ЛсИтог = ЛсИтог;		
		ТабличныйДокумент.Вывести(ОбластьИтоги);
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

