	Элементы.ФормаКнопкаЗаполнитьПоФакту.Видимость   = (Объект.ВидОперации = 0);
	Элементы.ФормаКнопкаЗаполнитьПоПриемам.Видимость = (Объект.ВидОперации = 1);
	
КонецПроцедуры

