
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.Текст						= ?(Параметры.Свойство("Текст")		, Параметры.Текст		, "");
	Элементы.ГруппаВыравнивание.Заголовок	= ?(Параметры.Свойство("Заголовок")	, Параметры.Заголовок	, "Редактирование поля");
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сохранить и закрыть
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СохранитьИЗакрыть(Команда)
	
	ВозвращаемыеПараметры = Новый Структура();
	ВозвращаемыеПараметры.Вставить("Текст", Текст);
	ЭтаФорма.Закрыть(ВозвращаемыеПараметры);
	
КонецПроцедуры

#КонецОбласти

