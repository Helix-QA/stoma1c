// Функция - Получить дату триггера
//
// Параметры:
//  ДанныеТриггера	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДатуТриггера(ДанныеТриггера, ПериодПланирования = Неопределено)
	
	Сутки = 86400;
	ТекущаяДатаВыполнения = ТекущаяДатаСеанса();
	
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники Тогда 
		ТекущаяДатаВыполнения = ТекущаяДатаВыполнения - (ДанныеТриггера.ПараметрСобытия * Сутки + Сутки);
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПотенциальныйНеСталНовым Тогда	
		ТекущаяДатаВыполнения = ТекущаяДатаВыполнения - (ДанныеТриггера.ПараметрСобытия * Сутки);
	КонецЕсли;
	
	Если ДанныеТриггера.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия ИЛИ
		ДанныеТриггера.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия Тогда
		
		Если ДанныеТриггера.ПериодСобытияВид = Перечисления.Периодичность.День Тогда 
			ПериодПланирования = (ДанныеТриггера.ПериодСобытия * 24 * 60 * 60);
		ИначеЕсли ДанныеТриггера.ПериодСобытияВид = Перечисления.Периодичность.Час Тогда
			ПериодПланирования = (ДанныеТриггера.ПериодСобытия * 60 * 60);
		ИначеЕсли ДанныеТриггера.ПериодСобытияВид = Перечисления.Периодичность.Минута Тогда
			ПериодПланирования = (ДанныеТриггера.ПериодСобытия * 60);
		Иначе 
			ПериодПланирования = 0;
		КонецЕсли;
		
		Если ДанныеТриггера.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия Тогда 
			Возврат ТекущаяДатаВыполнения + ПериодПланирования;
		ИначеЕсли ДанныеТриггера.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия Тогда	
			Возврат ТекущаяДатаВыполнения - ПериодПланирования;
		КонецЕсли;
	ИначеЕсли ДанныеТриггера.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия 
			И (ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана) Тогда
		Если ДанныеТриггера.ПериодСобытияВид = Перечисления.Периодичность.День Тогда
			ПериодПланирования = (ДанныеТриггера.ПериодСобытия * 24 * 60);
		ИначеЕсли ДанныеТриггера.ПериодСобытияВид = Перечисления.Периодичность.Час Тогда
			ПериодПланирования = (ДанныеТриггера.ПериодСобытия * 60);
		ИначеЕсли ДанныеТриггера.ПериодСобытияВид = Перечисления.Периодичность.Минута Тогда
			ПериодПланирования = ДанныеТриггера.ПериодСобытия;
		Иначе 
			ПериодПланирования = 0;
		КонецЕсли;
		ТекущаяДатаВыполнения = ТекущаяДатаВыполнения - (ПериодПланирования * 60);
		Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда 
			Возврат ?(ТекущаяДатаВыполнения > НачалоДня(ТекущаяДатаСеанса()), НачалоДня(ТекущаяДатаСеанса()), ТекущаяДатаВыполнения);
		Иначе 
			Возврат ?(ТекущаяДатаВыполнения > НачалоДня(ТекущаяДатаСеанса()) - Сутки, НачалоДня(ТекущаяДатаСеанса()) - Сутки, ТекущаяДатаВыполнения);
		КонецЕсли;	
	Иначе
		ПериодПланирования = 0;
		Возврат ТекущаяДатаВыполнения;
	КонецЕсли;	
	
КонецФункции

// Функция - Получить структуру контактной информации
//
// Параметры: ДанныеТриггера
//  ТаблицаДанныхОбъекта		 - 	 - 
//  ИнформироватьПоSMS	 - 	 - 
//  ИнформироватьПоEMail - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСтруктуруКонтактнойИнформации(ДанныеТриггера, ТаблицаДанныхОбъекта, СтруктураКонтактнойИнформации)
	                                              // Проверка триггеров 9034
												  
	ОтправитьСообщение 				= ЗначениеЗаполнено(ДанныеТриггера.ПланДействийТриггерногоСобытия)
										И НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.НайтиСтроки(Новый Структура("ВидДействия", Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение)).Количество() = 0;
		
	ИнформироватьПоEMail 			= НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо	, "ВидДействия") = Неопределено;
	АктивироватьЧатБота 			= НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота	, "ВидДействия") = Неопределено;	
	ИнформироватьКонтрагентаСобытия = НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВидыАдресатов.КонтрагентСобытия						, "ВидАдресата") = Неопределено;
	ИнформироватьВрачаПриема 		= НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВидыАдресатов.ВрачПриема								, "ВидАдресата") = Неопределено;
	ИнформироватьСотрудника		 	= НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВидыАдресатов.Сотрудник								, "ВидАдресата") = Неопределено;
	ИнформироватьКуратора		 	= НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия.Найти(Перечисления.ВидыАдресатов.Куратор									, "ВидАдресата") = Неопределено;
	
	Если НЕ ОтправитьСообщение И НЕ ИнформироватьПоEMail И НЕ АктивироватьЧатБота Тогда 
		Возврат СтруктураКонтактнойИнформации;
	КонецЕсли;	
	
	МВТ 	= Новый МенеджерВременныхТаблиц;
	Запрос 	= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("ТаблицаДанныхРегистрации"			, ТаблицаДанныхОбъекта.Скопировать(, "Контрагент, СтруктурнаяЕдиница"));
	Запрос.УстановитьПараметр("ТаблицаЗначенийПланДействий"			, ДанныеТриггера.ПланДействийТриггерногоСобытия.Скопировать(Новый Структура("ВидДействия", Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение), "ИдентификаторДействия, ВидАдресата, ВидАдресатаРезервный, Адресат"));
	Запрос.УстановитьПараметр("ТаблицаЗначенийПланДействийЧатБот"	, ДанныеТриггера.ПланДействийТриггерногоСобытия.Скопировать(Новый Структура("ВидДействия", Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота), "ИдентификаторДействия, ВидАдресата, ВидАдресатаРезервный, Адресат"));
	
	Запрос.Текст = 
	"ВЫБРАТЬ ТаблицаЗначенийПланДействий.*
	|ПОМЕСТИТЬ ПланДействий
	|ИЗ &ТаблицаЗначенийПланДействий КАК ТаблицаЗначенийПланДействий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ТаблицаЗначенийПланДействийЧатБот.*
	|ПОМЕСТИТЬ ПланДействийЧатБот
	|ИЗ &ТаблицаЗначенийПланДействийЧатБот КАК ТаблицаЗначенийПланДействийЧатБот	
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ТаблицаДанныхРегистрации.*
	|ПОМЕСТИТЬ ДанныеРегистрации
	|ИЗ &ТаблицаДанныхРегистрации КАК ТаблицаДанныхРегистрации";
	
	Запрос.Выполнить();
		
	Запрос 							= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МВТ;
		
	Запрос.УстановитьПараметр("Триггер"							, ДанныеТриггера.ТриггерноеСобытие);
	// Запрос.УстановитьПараметр("ТекущаяСтруктурнаяЕдиница"		, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ОтправитьСообщение"				, ОтправитьСообщение);	
	Запрос.УстановитьПараметр("ИнформироватьПоEMail"			, ИнформироватьПоEMail);
	Запрос.УстановитьПараметр("АктивироватьЧатБота"				, АктивироватьЧатБота);		
	Запрос.УстановитьПараметр("ИнформироватьКонтрагентаСобытия"	, ИнформироватьКонтрагентаСобытия);
	Запрос.УстановитьПараметр("ИнформироватьСотрудника"			, ИнформироватьСотрудника);		
	Запрос.УстановитьПараметр("ИнформироватьВрачаПриема"		, ИнформироватьВрачаПриема);		
	Запрос.УстановитьПараметр("ИнформироватьКуратора"			, ИнформироватьКуратора);		
	
	Если ИнформироватьВрачаПриема ИЛИ ИнформироватьСотрудника Тогда 
		Запрос.УстановитьПараметр("МассивВрачей"				, ПолучитьМассивВрачейДляИнформирования(ДанныеТриггера, ТаблицаДанныхОбъекта, ИнформироватьВрачаПриема, ИнформироватьСотрудника));		
	Иначе 
		Запрос.УстановитьПараметр("МассивВрачей"				, Новый Массив);		
	КонецЕсли;
	
#Область __________________ЗАПРОС_КОНТАКТНАЯ_ИНФОРМАЦИЯ_____________________
	
	Запрос.Текст 					= 
	"ВЫБРАТЬ
	|	ПланДействий.ВидАдресата КАК ВидАдресата,
	|	ПланДействий.ВидАдресатаРезервный КАК ВидАдресатаРезервный,
	|	ПланДействий.Адресат КАК Адресат,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.ИдентификаторДействия КАК ИдентификаторДействия,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.ОтправкаPush КАК ОтправкаPush,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.ОтправкаPushWallet КАК ОтправкаPushWallet,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.ОтправкаMessenger КАК ОтправкаMessenger,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.ОтправкаSMS КАК ОтправкаSMS,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.АккаунтВнешнейСистемы КАК АккаунтВнешнейСистемы,
	|	ВЫБОР
	|		КОГДА ТриггерныеСобытияНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS = ЗНАЧЕНИЕ(Справочник.СервисыРассылки.ПустаяСсылка)
	|				ИЛИ ТриггерныеСобытияНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS = НЕОПРЕДЕЛЕНО
	|			ТОГДА СервисSMSРассылкиПоУмолчанию.Значение
	|		ИНАЧЕ ТриггерныеСобытияНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS
	|	КОНЕЦ КАК АккаунтСервисаРассылкиSMS,
	|	ТриггерныеСобытияНастройкиКаналовУведомлений.КаналСистемыСообщений КАК КаналСистемыСообщений
	|ПОМЕСТИТЬ ТаблицаНастроекКаналовУведомлений
	|ИЗ
	|	Справочник.ТриггерныеСобытия.НастройкиКаналовУведомлений КАК ТриггерныеСобытияНастройкиКаналовУведомлений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланДействий КАК ПланДействий
	|		ПО ТриггерныеСобытияНастройкиКаналовУведомлений.ИдентификаторДействия = ПланДействий.ИдентификаторДействия,
	|	Константа.СервисSMSРассылкиПоУмолчанию КАК СервисSMSРассылкиПоУмолчанию
	|ГДЕ
	|	&ОтправитьСообщение
	|	И ТриггерныеСобытияНастройкиКаналовУведомлений.Ссылка = &Триггер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ТаблицаДанныхДляРегистрации.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|				ИЛИ ТаблицаДанныхДляРегистрации.СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|			ТОГДА ТаблицаДанныхДляРегистрации.Контрагент.СтруктурнаяЕдиница
	|		ИНАЧЕ ТаблицаДанныхДляРегистрации.СтруктурнаяЕдиница
	|	КОНЕЦ КАК СтруктурнаяЕдиница,
	|	ТаблицаДанныхДляРегистрации.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ТаблицаДанныхДляРегистрации
	|ИЗ
	|	ДанныеРегистрации КАК ТаблицаДанныхДляРегистрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВнешниеСистемы.Ссылка) КАК ВнешняяСистема,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ ТаблицаВнешнихСистем
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	&ОтправитьСообщение
	|	И ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВнешниеСистемы.Используется = ИСТИНА
	|	И ВнешниеСистемы.ТипВнешнейСистемы В (ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Wallet), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Chat2Desk))
	|
	|СГРУППИРОВАТЬ ПО
	|	ВнешниеСистемы.ТипВнешнейСистемы,
	|	ВнешниеСистемы.СтруктурнаяЕдиница
	|;
	|
