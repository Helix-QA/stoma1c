	Если Не ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо) Тогда
		ЭтотОбъект.ОтборВозрастОт = 0;
	КонецЕсли;
	
	УстановитьЗапросДинамическогоСписка();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора".
//
Процедура ОтборУслугаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоГруппа = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВыбранноеЗначение, "ЭтоГруппа");
	Если ЭтоГруппа = Истина Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Группа недоступна для отбора.");
		ВыбранноеЗначение = Неопределено;
		Возврат;
    КонецЕсли;	
	УстановитьМеткуИПараметрСписка("ОтборУслуга", Элемент.Родитель.Имя, ВыбранноеЗначение);
	ВыбранноеЗначение = Неопределено;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Нажатие".
//
Процедура ПредставлениДатаРегистрацииНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Диалог = Новый ДиалогРедактированияСтандартногоПериода;
	Диалог.Период = ОтборДатаРегистрации;
	Оповещение = Новый ОписаниеОповещения("ПредставлениДатаРегистрацииПриИзмененииЗавершение", ЭтотОбъект);
	Диалог.Показать(Оповещение);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения процедуры "ПредставлениДатаРегистрацииНажатие".
//
Процедура ПредставлениДатаРегистрацииПриИзмененииЗавершение(НовыйПериод, Параметры) Экспорт
	
	Если НовыйПериод = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(НовыйПериод)=Тип("СтандартныйПериод") Тогда
		ОтборДатаРегистрации = НовыйПериод;
	ИначеЕсли ТипЗнч(НовыйПериод)=Тип("Дата") Тогда
		ОтборДатаРегистрации.ДатаОкончания = НовыйПериод;
	КонецЕсли;
	
	ПредставлениеДатаРегистрации = РаботаСОтборами.ОбновитьПредставлениеПериода(ОтборДатаРегистрации, "Дата регистрации: ");
	
	#Если ВебКлиент Тогда
		ОбновитьОтображениеДанных();
	#КонецЕсли 
	
	УстановитьЗапросДинамическогоСписка();
	
КонецПроцедуры

&НаСервере
// Процедура - Установить метку и параметр списка.
//
Процедура УстановитьМеткуИПараметрСписка(ИмяПоляОтбораСписка, ГруппаРодительМетки, ВыбранноеЗначение, ПредставлениеЗначения = "")
	
	Если Не ЗначениеЗаполнено(ПредставлениеЗначения) Тогда
		ПредставлениеЗначения = Строка(ВыбранноеЗначение);
	КонецЕсли; 
	
	
	РаботаСОтборами.ПрикрепитьМеткуОтбора(ЭтотОбъект, ИмяПоляОтбораСписка, ГруппаРодительМетки, ВыбранноеЗначение, ПредставлениеЗначения,, ИмяПоляОтбораСписка);
	
	УстановитьЗапросДинамическогоСписка();
	
КонецПроцедуры

// Процедура - Установить запрос динамического списка
//
&НаСервере
Процедура УстановитьЗапросДинамическогоСписка(ОтборыЗаполнены = Истина, ОтборСтатусы = Неопределено)
		
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СправочникКонтрагенты.Ссылка КАК Ссылка,
	|	СправочникКонтрагенты.ПометкаУдаления КАК ПометкаУдаления,
	|	СправочникКонтрагенты.Родитель КАК Родитель,
	|	СправочникКонтрагенты.ЭтоГруппа КАК ЭтоГруппа,
	|	СправочникКонтрагенты.Код КАК Код,
	|	СправочникКонтрагенты.Наименование КАК Наименование,
	|	СправочникКонтрагенты.БанковскийСчетПоУмолчанию КАК БанковскийСчетПоУмолчанию,
	|	СправочникКонтрагенты.ВидЦен_Удалить КАК ВидЦен_Удалить,
	|	СправочникКонтрагенты.ДатаРегистрации КАК ДатаРегистрации,
	|	СправочникКонтрагенты.ДатаРожденияКлиента КАК ДатаРожденияКлиента,
	|	СправочникКонтрагенты.Имя КАК Имя,
	|	СправочникКонтрагенты.ИНН КАК ИНН,
	|	СправочникКонтрагенты.ИсточникИнформации КАК ИсточникИнформации,
	|	СправочникКонтрагенты.КодПоОКПО КАК КодПоОКПО,
	|	СправочникКонтрагенты.КодСинхронизации КАК КодСинхронизации,
	|	СправочникКонтрагенты.КПП КАК КПП,
	|	СправочникКонтрагенты.Куратор КАК Куратор,
	|	СправочникКонтрагенты.НаименованиеПолное КАК НаименованиеПолное,
	|	СправочникКонтрагенты.Отчество КАК Отчество,
	|	СправочникКонтрагенты.ПолКлиента КАК ПолКлиента,
	|	СправочникКонтрагенты.Профессия КАК Профессия,
	|	СправочникКонтрагенты.РеестровыйНомерОМС КАК РеестровыйНомерОМС,
	|	СправочникКонтрагенты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СправочникКонтрагенты.ТекущаяМедицинскаяКарта.КодБезНулей КАК ТекущаяМедицинскаяКарта,
	|	СправочникКонтрагенты.ТипКонтрагента КАК ТипКонтрагента,
	|	СправочникКонтрагенты.Фамилия КАК Фамилия,
	|	СправочникКонтрагенты.ЮрФизЛицо КАК ЮрФизЛицо,
	|	СправочникКонтрагенты.Предопределенный КАК Предопределенный,
	|	СправочникКонтрагенты.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
	|	ЛОЖЬ КАК НеЗаполненТелефон,
	|	КонтрагентыСведенияДляСписка.ДатаПоследнегоПриема КАК ДатаПоследнегоПриема,
	|	КонтрагентыСведенияДляСписка.ДатаПервогоПриема КАК ДатаПервогоПриема,
	|	КонтрагентыСведенияДляСписка.ДатаСледующегоПриема КАК ДатаСледующегоПриема,
	|	КонтрагентыСведенияДляСписка.КоличествоПриемов КАК КоличествоПриемов,
	|	ВЫБОР
	|		КОГДА СправочникКонтрагенты.ДатаРожденияКлиента <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ВЫБОР
	|					КОГДА ДЕНЬГОДА(&ТекущаяДата) > ДЕНЬГОДА(СправочникКонтрагенты.ДатаРожденияКлиента)
	|						ТОГДА РАЗНОСТЬДАТ(СправочникКонтрагенты.ДатаРожденияКлиента, &ТекущаяДата, ГОД)
	|					ИНАЧЕ (ВЫРАЗИТЬ(РАЗНОСТЬДАТ(СправочникКонтрагенты.ДатаРожденияКлиента, &ТекущаяДата, ГОД) КАК ЧИСЛО)) - 1
	|				КОНЕЦ
	|	КОНЕЦ КАК Возраст,
	|	ВЫБОР
	|		КОГДА СправочникКонтрагенты.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ + ВЫБОР
	|		КОГДА СправочникКонтрагенты.ПометкаУдаления
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ВариантКартинки,
	|	СправочникКонтрагенты.Телефон КАК Телефон,
	|	КонтрагентыСведенияДляСписка.Статус КАК СтатусПациента
	|ИЗ
	|	Справочник.Контрагенты КАК СправочникКонтрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО СправочникКонтрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	СправочникКонтрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|	И НЕ СправочникКонтрагенты.ЭтоГруппа
	|	И &УсловиеОтборРегистрацияДатаНачала
	|	И &УсловиеОтборРегистрацияДатаОкончания
	|	И &УсловиеОтборСалон
	|	И &УсловиеОтборПолКлиента
	|	И &УсловиеОтборРекламныйИсточник
	|	И &УсловиеОтборТелефон
	|	И &УсловиеОтборВозрастОт
	|	И &УсловиеОтборВозрастДо
	|	И &УсловиеОтборСтатус
	|	И &УсловиеОтборЛичныйВрач
	|	И &УсловиеОтборУслуга
	|	И &УсловиеОтборДатаПоследнегоПриема
	|	И &УсловиеОтборЭлектроннаяКарта
	|	И &УсловиеОтборМетки";
	
	МодифицироватьТекстЗапроса(ТекстЗапроса, Истина,, ОтборыЗаполнены, ОтборСтатусы);

КонецПроцедуры

&НаСервере
// Функция - Модифицировать текст запроса
//
Функция МодифицироватьТекстЗапроса(ТекстЗапроса, ЗапросСписка, Запрос = Неопределено, ОтборыЗаполнены = Истина, ОтборСтатусы = Неопределено)
	
	Если ОтборыЗаполнены = Истина Тогда
			
		УсловиеОтборРегистрацияДатаНачала    = "И СправочникКонтрагенты.ДатаРегистрации >= &ОтборРегистрацияДатаНачала";
		УсловиеОтборРегистрацияДатаОкончания = "И СправочникКонтрагенты.ДатаРегистрации <= &ОтборРегистрацияДатаОкончания";
		УсловиеОтборСалон                    = "И СправочникКонтрагенты.СтруктурнаяЕдиница В(&ОтборСалон)";
		Если ЗапросСписка = Истина Тогда
			УсловиеОтборСтатус = "И СправочникКонтрагенты.Ссылка В 
			|			(ВЫБРАТЬ
			|			    СтатусыКонтрагентов.Контрагент 
			|			ИЗ
			|	            РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, ) КАК СтатусыКонтрагентов
			|	        ГДЕ Статус В(&ОтборСтатус))";
			
		Иначе
			УсловиеОтборСтатус               = "И СтатусыКонтрагентов.Статус В(&ОтборСтатус)";
		КонецЕсли;
		УсловиеОтборПолКлиента	             = "И СправочникКонтрагенты.ПолКлиента В(&ОтборПолКлиента)";
		УсловиеОтборРекламныйИсточник        = "И СправочникКонтрагенты.ИсточникИнформации В(&ОтборРекламныйИсточник)";
		
		УсловиеОтборВозрастОт = "И СправочникКонтрагенты.ДатаРожденияКлиента <> ДАТАВРЕМЯ(1, 1, 1)
		|	И СправочникКонтрагенты.ДатаРожденияКлиента <= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ГОД, - &ОтборВозрастОт)";
		УсловиеОтборВозрастДо = "И СправочникКонтрагенты.ДатаРожденияКлиента <> ДАТАВРЕМЯ(1, 1, 1)
		|	И СправочникКонтрагенты.ДатаРожденияКлиента >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ГОД, - &ОтборВозрастДо)";
		
	
		УсловиеОтборПрием = "И СправочникКонтрагенты.Ссылка В
		|			(ВЫБРАТЬ
		|				Прием.Контрагент
		|			ИЗ
		|				Документ.Прием КАК Прием
		|			ГДЕ
		|				Прием.ВремяНачалаПриема Между &ОтборПриемДатаНачала И &ОтборПриемДатаОкончания
		|				И Прием.ПометкаУдаления = Ложь)";
		
		УсловиеОтборУслуга = "И СправочникКонтрагенты.Ссылка В
		|			(ВЫБРАТЬ
		|				ПриемЛечение.Ссылка.Контрагент
		|			ИЗ
		|				Документ.Прием.Лечение КАК ПриемЛечение
		|			ГДЕ
		|				ПриемЛечение.Номенклатура В(&ОтборУслуга)
		|				И ПриемЛечение.Ссылка.ПометкаУдаления = Ложь)"; 
		
		УсловиеОтборДатаПоследнегоПриема = "И КонтрагентыСведенияДляСписка.ДатаПоследнегоПриема Между &ОтборПриемДатаНачала И &ОтборПриемДатаОкончания";
		
		УсловиеОтборМетка = "И СправочникКонтрагенты.Ссылка В (ВЫБРАТЬ
		|							МеткиКлиентовСрезПоследних.Клиент КАК Клиент
		|					ИЗ
		|							РегистрСведений.МеткиКлиентов.СрезПоследних(&ТекущаяДата, Метка.ИспользоватьДляПациентов = ИСТИНА И Метка В (&ОтборМетка)) КАК МеткиКлиентовСрезПоследних)";
		
		МассивСалонов                   = ПолучитьМассивПараметров("ОтборСалон");
		МассивСтатусов                  = ?(ОтборСтатусы = Неопределено, ПолучитьМассивПараметров("ОтборСтатус"), ОтборСтатусы);
		МассивПоловКлиента              = ПолучитьМассивПараметров("ОтборПол");
		МассивРекламныйИсточник         = ПолучитьМассивПараметров("ОтборРекламныйИсточник");
		МассивОтборНаличиеТелефона      = ПолучитьМассивПараметров("НеЗаполненТелефон");
		МассивУслуг                     = ПолучитьМассивПараметров("ОтборУслуга");
		МассивЛичныйВрач   				= ПолучитьМассивПараметров("ОтборЛичныйВрач");	
		МассивМетка					    = ПолучитьМассивПараметров("ОтборМетка"); 
		
		Если ЗначениеЗаполнено(МассивОтборНаличиеТелефона) Тогда
			
			// Истина - телефон не заполнен
			Если МассивОтборНаличиеТелефона.Найти(Истина) <> Неопределено И МассивОтборНаличиеТелефона.Найти(Ложь) <> Неопределено Тогда
				УсловиеОтборТелефон = "";
			Иначе
					
				Если МассивОтборНаличиеТелефона.Найти(Истина) <> Неопределено Тогда 
					УсловиеОтборТелефон = "И НЕ СправочникКонтрагенты.Ссылка В(ВЫБРАТЬ
					|КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
					|ИЗ
					|Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
					|ГДЕ
					|КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента))";
					
				Иначе
					УсловиеОтборТелефон = "И СправочникКонтрагенты.Ссылка В(ВЫБРАТЬ
					|КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
					|ИЗ
					|Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
					|ГДЕ
					|КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента))";
					
				КонецЕсли;
							
			КонецЕсли;
			
		Иначе
			УсловиеОтборТелефон = "";
		КонецЕсли; 
		
		Если ОтборЭлектроннаяКарта Тогда
			
			УсловиеОтборЭлектроннаяКарта = "И СправочникКонтрагенты.Ссылка В
			|(ВЫБРАТЬ
			|	Карты.ВладелецКарты КАК ВладелецКарты
			|ИЗ
			|	Справочник.Карты КАК Карты
			|ГДЕ
			|	НЕ Карты.ПометкаУдаления
			|	И НЕ Карты.Заблокирована
			|	И Карты.ВладелецКарты ССЫЛКА Справочник.Контрагенты)";	
			
		Иначе
			
			УсловиеОтборЭлектроннаяКарта = "";
			
		КонецЕсли;
		
		УсловиеОтборЛичныйВрач                    = "И СправочникКонтрагенты.Куратор В(&ОтборЛичныйВрач)";
		// Если ЗначениеЗаполнено(МассивСотрудников) Тогда
		//	УсловиеОтборСотрудник =  "И СправочникКонтрагенты.Ссылка В
		//		|			(ВЫБРАТЬ
		//		|				ПредпочтенияКлиентовПоМастерам.Контрагент
		//		|			ИЗ
		//		|				РегистрСведений.ПредпочтенияКлиентовПоМастерам КАК ПредпочтенияКлиентовПоМастерам
		//		|			ГДЕ
		//		|				ПредпочтенияКлиентовПоМастерам.Сотрудник В (&ОтборСотрудник))";
		// Иначе
		//	УсловиеОтборСотрудник = "";
		// КонецЕсли;
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборРегистрацияДатаНачала"   , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала), УсловиеОтборРегистрацияДатаНачала, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборРегистрацияДатаОкончания", ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания), УсловиеОтборРегистрацияДатаОкончания, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборСалон"                   , ?(ЗначениеЗаполнено(МассивСалонов), УсловиеОтборСалон, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборСтатус"                  , ?(ЗначениеЗаполнено(МассивСтатусов), УсловиеОтборСтатус, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборПолКлиента"              , ?(ЗначениеЗаполнено(МассивПоловКлиента), УсловиеОтборПолКлиента, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборРекламныйИсточник"       , ?(ЗначениеЗаполнено(МассивРекламныйИсточник), УсловиеОтборРекламныйИсточник, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборВозрастОт"               , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастОт), УсловиеОтборВозрастОт, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборВозрастДо"               , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо), УсловиеОтборВозрастДо, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборЭлектроннаяКарта"        , УсловиеОтборЭлектроннаяКарта);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборТелефон"                 , УсловиеОтборТелефон);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборЛичныйВрач"              , ?(ЗначениеЗаполнено(МассивЛичныйВрач), УсловиеОтборЛичныйВрач, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборПрием"                   , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаНачала) Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаОкончания), УсловиеОтборПрием, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборУслуга"                  , ?(ЗначениеЗаполнено(МассивУслуг), УсловиеОтборУслуга, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборДатаПоследнегоПриема"    , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаНачала) Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаОкончания), УсловиеОтборДатаПоследнегоПриема, ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборМетки"    				  , ?(ЗначениеЗаполнено(МассивМетка), УсловиеОтборМетка, ""));
		
		Если ЗапросСписка = Ложь Тогда 
			
			Запрос.Текст = ТекстЗапроса;
			
			Запрос.УстановитьПараметр("ОтборРегистрацияДатаНачала"   , ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала);
			Запрос.УстановитьПараметр("ОтборРегистрацияДатаОкончания", ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания);
			Запрос.УстановитьПараметр("ОтборСалон"                   , МассивСалонов);
			Запрос.УстановитьПараметр("ОтборСтатус"                  , МассивСтатусов);
			Запрос.УстановитьПараметр("ОтборПолКлиента"              , МассивПоловКлиента);
			Запрос.УстановитьПараметр("ОтборРекламныйИсточник"       , МассивРекламныйИсточник);
			Запрос.УстановитьПараметр("ОтборВозрастОт"               , ЭтотОбъект.ОтборВозрастОт);
			Запрос.УстановитьПараметр("ОтборВозрастДо"               , ЭтотОбъект.ОтборВозрастДо);
			Запрос.УстановитьПараметр("ТекущаяДата"                  , ТекущаяДатаСеанса());
			Запрос.УстановитьПараметр("ОтборСотрудник"               , МассивЛичныйВрач);
			Запрос.УстановитьПараметр("ОтборПриемДатаНачала"         , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаНачала), ЭтотОбъект.ОтборДатаПриема.ДатаНачала, Дата(1,1,1)));
			Запрос.УстановитьПараметр("ОтборПриемДатаОкончания"      , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаОкончания), ЭтотОбъект.ОтборДатаПриема.ДатаОкончания, Дата(3999,12,31)));
			Запрос.УстановитьПараметр("ОтборУслуга"                  , МассивУслуг);
			Запрос.УстановитьПараметр("ОтборМетка"                   , МассивМетка);
						
		Иначе
			
			Список.ТекстЗапроса = ТекстЗапроса;	
			
			Если ЗначениеЗаполнено(МассивСтатусов) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборСтатус"                  , МассивСтатусов);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборРегистрацияДатаНачала"   , ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборРегистрацияДатаОкончания", ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивСалонов) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборСалон"                   , МассивСалонов);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивПоловКлиента) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборПолКлиента"              , МассивПоловКлиента);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивРекламныйИсточник) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборРекламныйИсточник"       , МассивРекламныйИсточник);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастОт) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборВозрастОт"               , ЭтотОбъект.ОтборВозрастОт);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборВозрастДо"               , ЭтотОбъект.ОтборВозрастДо);
			КонецЕсли;
			
			// Если ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастОт) Или ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
			// КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивЛичныйВрач) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборЛичныйВрач"               , МассивЛичныйВрач);
			КонецЕсли;

			Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаНачала) 
				Или ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаОкончания) Тогда
			   Список.Параметры.УстановитьЗначениеПараметра("ОтборПриемДатаНачала"             , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаНачала), ЭтотОбъект.ОтборДатаПриема.ДатаНачала, Дата(1,1,1)));
			   Список.Параметры.УстановитьЗначениеПараметра("ОтборПриемДатаОкончания"          , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаПриема.ДатаОкончания), ЭтотОбъект.ОтборДатаПриема.ДатаОкончания, Дата(3999,12,31)));
			КонецЕсли;

			Если ЗначениеЗаполнено(МассивУслуг) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборУслуга", МассивУслуг);
			КонецЕсли; 	 
			
			Если ЗначениеЗаполнено(МассивМетка) Тогда
				Список.Параметры.УстановитьЗначениеПараметра("ОтборМетка", МассивМетка);
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборРегистрацияДатаНачала"   , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборРегистрацияДатаОкончания", "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборСалон"                   , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборСтатус"                  , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборПолКлиента"              , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборРекламныйИсточник"       , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборВозрастОт"               , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборВозрастДо"               , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборЭлектроннаяКарта"        , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборТелефон"                 , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборЛичныйВрач"              , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборПрием"                   , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборУслуга"                  , "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборДатаПоследнегоПриема"    , "");  
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборМетки"    , "");
		
		Если ЗапросСписка = Ложь Тогда 		
			Запрос.Текст = ТекстЗапроса;
		Иначе	
			Список.ТекстЗапроса = ТекстЗапроса;	
			Список.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());

		КонецЕсли;
		
	КонецЕсли;

КонецФункции

&НаСервере
// Функция - Получить представление.
//
Функция ПолучитьПредставление(Заголовок, Количество, Цвет = Неопределено)
	
	ЭлементЗаголовок  = Новый ФорматированнаяСтрока(Заголовок, Новый Шрифт(, 11));
	// ЭлементКоличество = Новый ФорматированнаяСтрока(Строка(Количество), Новый Шрифт(, 12, Истина), ?(Цвет <> Неопределено, Цвет, Новый Цвет(77, 77, 77)));
	ЭлементКоличество = Новый ФорматированнаяСтрока(Строка(Количество), Новый Шрифт(, 12, Ложь), ?(Цвет <> Неопределено, Цвет, Новый Цвет(77, 77, 77)));
	
	ЭлементыСтроки = Новый Массив;
	ЭлементыСтроки.Добавить(ЭлементЗаголовок);
	ЭлементыСтроки.Добавить(ЭлементКоличество);
	
	Результат = Новый ФорматированнаяСтрока(ЭлементыСтроки);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
// Функция - Получить массив параметров.
//
Функция ПолучитьМассивПараметров(ИмяПоляОтбора)
	
	МассивОтбора = Новый Массив;
	
	СтрокиЗначенийОтбора = ЭтотОбъект.ДанныеМеток.НайтиСтроки(Новый Структура("ИмяПоляОтбора", ИмяПоляОтбора));
	
	Для Каждого СтрокаОтбора Из СтрокиЗначенийОтбора Цикл
		
		Если ТипЗнч(СтрокаОтбора.Метка) = Тип("СписокЗначений") Тогда
			Для Каждого ЗначениеСписка Из СтрокаОтбора.Метка Цикл
				МассивОтбора.Добавить(ЗначениеСписка.Значение);
			КонецЦикла;
		Иначе	
			МассивОтбора.Добавить(СтрокаОтбора.Метка);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивОтбора;
	
КонецФункции

