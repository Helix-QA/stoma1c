// Процедура, "Дата рождения при изменении".
//
Процедура ДатаРожденияПриИзменении(Элемент)
	
	Если Объект.ДатаРожденияКлиента > ТекущаяДата() ИЛИ Год(Объект.ДатаРожденияКлиента) < 1900 Тогда
		Объект.ДатаРожденияКлиента = Дата(1,1,1); 
		Текст = ?(Объект.ДатаРожденияКлиента > ТекущаяДата(), "Дата рождения не может быть больше текущей даты!", "Неверно указана дата рождения!"); 
		ПоказатьПредупреждение(, Текст,,"Внимание!");
	Иначе  	
		ПроверкаДублированияКлиента(Новый ОписаниеОповещения("ДатаРожденияПриИзмененииЗавершение", ЭтотОбъект)); 
	КонецЕсли;
	
