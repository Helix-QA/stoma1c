// Процедура, формирует поле HTML.
//
Процедура СформироватьКанбан()
	
	ЭтотОбъект.ТелефонияДоступна	 = Справочники.ТелефонныеАппараты.ПроверитьВозможностьЗвонкаНаДанномПК();
	ЭтотОбъект.МессенджерДоступен	 = ЭтотОбъект.ЭтоПолноправныйПользователь Или РольДоступна(Метаданные.Роли.ИспользованиеМессенджера);
	
	ПараметрыОграничений = Новый Структура;
	ПараметрыОграничений.Вставить("ТелефонияДоступна"	, ЭтотОбъект.ТелефонияДоступна);
	ПараметрыОграничений.Вставить("МессенджерДоступен"	, ЭтотОбъект.МессенджерДоступен);
	
	ДополнительныеСкрипты	 = Новый_Массив(ПолучитьКодОсновногоСкрипта());
	ДополнительныеСтили		 = Новый_Массив(ПолучитьКодДополнительныхСтилей());
	
	Канбан = ФормированиеКанбанДосок.ПолучитьHTMLКодКанбана(ПараметрыОграничений, ДополнительныеСкрипты, ДополнительныеСтили, ЭтотОбъект.МаксимальноеКоличествоЗаявокВКолонке);
	
