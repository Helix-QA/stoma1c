// Функция, обновляет электронные карты.
// 
Функция ОбновитьКарты(МассивДанныхДляОбновления, ВнешняяСистемаWallet) Экспорт

	ОтветСервера = ПолучитьСтруктуруВозврата();
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		
		ОбновитьКарты = Новый HTTPЗапрос("/v1/passes/", Заголовки); 
			
		ТекстJSON = СобратьJson(МассивДанныхДляОбновления);
		ТекстJSON = СтрЗаменить(ТекстJSON, "\\n", "\n"); 
		
		ОбновитьКарты.УстановитьТелоИзСтроки(ТекстJSON);
		
		Результат = Соединение.ВызватьHTTPМетод("PATCH", ОбновитьКарты);					
		
	Исключение	
		
		ОтветСервера.ОписаниеОшибки = ОписаниеОшибки();
		
		Возврат ОтветСервера;
		
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат, Истина); // если сериализовать в структуру крашится из-за id карты
	
	Если Результат.КодСостояния = 200 Тогда
		
		ОтветСервера.data    = ПараметрыJson["data"];
		ОтветСервера.Успешно = Истина;
		
		Возврат ОтветСервера;
		
	Иначе	
		
		ОтветСервера.ОписаниеОшибки = ПараметрыJson["error"]["message"];
		
		Возврат ОтветСервера;
		
	КонецЕсли;	
	
КонецФункции

// Функция, создает карту wallet.
// 
Функция СоздатьКартуWallet(ВнешняяСистемаWallet, ИдентификаторПроекта, ВладелецКарты) Экспорт
	
	РезультатСоздания = ПолучитьСтруктуруВозврата();
	
	ОтветСервера = ПолучитьДанныеПроекта(ИдентификаторПроекта, ВнешняяСистемаWallet);
	
	Если Не ОтветСервера.Успешно Тогда
		
		РезультатСоздания.ОписаниеОшибки = ОтветСервера.ОписаниеОшибки;					
		
		Возврат РезультатСоздания;	
		
	КонецЕсли;
	
   	ТелефонОбязателенДляЗаполнения = Ложь;
	
	ПолеНомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ОтветСервера.data.fields, "attribute", "phone_number");
	
	Если ЗначениеЗаполнено(ПолеНомерТелефона)
		И ПолеНомерТелефона.Свойство("required") Тогда
		
		ТелефонОбязателенДляЗаполнения = ПолеНомерТелефона.required; 	
		
	КонецЕсли;
	
	РезультатСоздания.СинхронизироватьНомерТелефона = НЕ ТелефонОбязателенДляЗаполнения;
		
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		ЗапросНаСозданиеКарты = Новый HTTPЗапрос("/v1/passes", Заголовки); 
		ЗапросНаСозданиеКарты.УстановитьТелоИзСтроки(ПолучитьТелоЗапроса(ВладелецКарты, ИдентификаторПроекта,,, ТелефонОбязателенДляЗаполнения));
		Результат = Соединение.ОтправитьДляОбработки(ЗапросНаСозданиеКарты);					
		
	Исключение	
		
		РезультатСоздания.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();	
		
		Возврат РезультатСоздания;
		
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат, Истина);
	
	Если Результат.КодСостояния = 201 Тогда
		
		РезультатСоздания.Успешно = Истина;
		РезультатСоздания.ВнутреннийКодКарты = ПараметрыJson["data"]["serial_number"];
		РезультатСоздания.КодКарты			 = ПараметрыJson["data"]["pass_number"];
		РезультатСоздания.Ссылка   			 = ПараметрыJson["data"]["link"];
		
		Возврат РезультатСоздания;
		
	Иначе
		
		РезультатСоздания.ОписаниеОшибки = "Wallet: " + ПараметрыJson["error"]["message"];
		Возврат РезультатСоздания;
		
	КонецЕсли;
	
КонецФункции

// Функция, обновляет карту wallet.
// 
Функция ОбновитьКартуWallet(Карта, ВнешняяСистемаWallet, СменаВладельца = Ложь, Аннулирована = Ложь) Экспорт
	
	РезультатОбновления = ПолучитьСтруктуруВозврата();
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		
		ЗапросНаОбновление = Новый HTTPЗапрос("/v1/passes/" + Карта.ВнутреннийКодКарты, Заголовки); 
		
		ЗапросНаОбновление.УстановитьТелоИзСтроки(ПолучитьТелоЗапроса(Карта.ВладелецКарты,,, СменаВладельца,, Аннулирована));
		Результат = Соединение.ВызватьHTTPМетод("PATCH", ЗапросНаОбновление);					
		
	Исключение	
		
		РезультатОбновления.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();
		Возврат РезультатОбновления;
		
	КонецПопытки;
	
	Если Результат.КодСостояния <> 200 Тогда
		
		ПараметрыJson = РазобратьJson(Результат);
		РезультатОбновления.ОписаниеОшибки = "Wallet: " + ПараметрыJson.error.message;
		Возврат РезультатОбновления;
		
	Иначе
		
		РезультатОбновления.Успешно = Истина;
		Возврат РезультатОбновления;
		
	КонецЕсли;
	
КонецФункции

// Функция, обновляет карту wallet.
//
Функция УдалитьКартуWallet(Карта, ВнешняяСистемаWallet) Экспорт
	
	РезультатУдаления = ПолучитьСтруктуруВозврата();
	
	Попытка
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.ИдентификаторКлиента);
		Заголовки.Вставить("Content-Type"   , "application/json");
		
		ЗапросНаУдаление = Новый HTTPЗапрос("/v1/passes/" + Карта.ВнутреннийКодКарты, Заголовки); 
		
		// ЗапросНаУдаление.УстановитьТелоИзСтроки(ПолучитьТелоЗапроса(Карта.ВладелецКарты));
		Результат = Соединение.ВызватьHTTPМетод("DELETE", ЗапросНаУдаление);					
		
	Исключение	
		
		РезультатУдаления.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();
		Возврат РезультатУдаления;
		
	КонецПопытки;
	
	Если Результат.КодСостояния <> 200 Тогда
		
		ПараметрыJson = РазобратьJson(Результат);
		РезультатУдаления.ОписаниеОшибки = "Wallet: " + ПараметрыJson.error.message;
		Возврат РезультатУдаления;
		
	Иначе
		
		РезультатУдаления.Успешно = Истина;
		Возврат РезультатУдаления;
		
	КонецЕсли;
	
КонецФункции 

// Функция, возвращает тело запроса для создания карты.
// 
Функция ПолучитьТелоЗапроса(ВладелецКарты, ИдентификаторПроекта = Неопределено, МассивВнутренныхКодов = Неопределено, СменаВладельца = Ложь, ТелефонОбязателенДляЗаполнения = Ложь, Аннулирована = Ложь)
	
	ВладелецКонтрагент = ТипЗнч(ВладелецКарты) = Тип("СправочникСсылка.Контрагенты");
	
	ТелоЗапросаСозданиеКарты = Новый Структура("project_id, fields", ИдентификаторПроекта);
	
	ДатаРождения = ?(ВладелецКонтрагент, ВладелецКарты.ДатаРожденияКлиента, ВладелецКарты.ДатаРождения);
	
	ТелоЗапросаОбновлениеКарты = Новый Структура("first_name, last_name");
	
	ТелоЗапросаОбновлениеКарты.first_name = ВладелецКарты.Имя;
	ТелоЗапросаОбновлениеКарты.last_name  = ВладелецКарты.Фамилия;
	
	Если ЗначениеЗаполнено(ДатаРождения) Тогда	
		ТелоЗапросаОбновлениеКарты.Вставить("birthdate", Формат(ДатаРождения, "ДФ=yyyy-MM-dd"));
	КонецЕсли;
	
	Если ВладелецКонтрагент Тогда
		КонтактнаяИнформация = Справочники.Контрагенты.ПолучитьКонтактнуюИнформациюКлиента(ВладелецКарты, Истина);  
	Иначе
		КонтактнаяИнформация = Справочники.Сотрудники.ПолучитьКонтактнуюИнформацию(ВладелецКарты, Истина); 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтактнаяИнформация.Email) Тогда
		ТелоЗапросаОбновлениеКарты.Вставить("email", КонтактнаяИнформация.Email);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтактнаяИнформация.Телефон) И ТелефонОбязателенДляЗаполнения Тогда
		НомерТелефонаВрем = ?(Лев(КонтактнаяИнформация.Телефон, 1) = "+", КонтактнаяИнформация.Телефон, "+" + КонтактнаяИнформация.Телефон);
		ТелоЗапросаОбновлениеКарты.Вставить("phone_number", НомерТелефонаВрем);
	КонецЕсли;
	
	Если Аннулирована = Истина Тогда
		ТелоЗапросаОбновлениеКарты.Вставить("voided", true);
	КонецЕсли;
	
	ТелоЗапросаСозданиеКарты.fields = ТелоЗапросаОбновлениеКарты;
	
	ИконкиУведомлений   = ПолучитьИконкиУведомлений();
	СимвольныйКодВалюты = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
	
	ДобавитьДанныеВОбновляемыеПоля(
		?(ЗначениеЗаполнено(ИдентификаторПроекта), ТелоЗапросаСозданиеКарты.fields, ТелоЗапросаОбновлениеКарты), 
		?(ВладелецКонтрагент, ВладелецКарты, ВладелецКарты.Контрагент), 
		ИконкиУведомлений, 
		СимвольныйКодВалюты, 
		СменаВладельца);
	
	Если ЗначениеЗаполнено(ИдентификаторПроекта) Тогда 
		
		Возврат СтрЗаменить(СобратьJson(ТелоЗапросаСозданиеКарты), "\\n", "\n");	
		
	Иначе 
		
		Возврат СтрЗаменить(СобратьJson(?(ЗначениеЗаполнено(МассивВнутренныхКодов), 
		Новый Структура("serial_numbers, fields", МассивВнутренныхКодов, ТелоЗапросаОбновлениеКарты), 
		ТелоЗапросаОбновлениеКарты)), "\\n", "\n");
		
	КонецЕсли;
	
КонецФункции

// Процедура, добавить данные в обновляемые поля.
// 
Процедура ДобавитьДанныеВОбновляемыеПоля(ПоляКарты, ВладелецКарты, ИконкиУведомлений, СимвольныйКодВалюты, СменаВладельца)
	
	ПоляКарты.Вставить("visits"   , "");
	ПоляКарты.Вставить("accounts" , "");
	ПоляКарты.Вставить("bonuses"  , "");
	ПоляКарты.Вставить("balance"  , "");
	ПоляКарты.Вставить("debt"	  , "");
		
	Если Не СменаВладельца Тогда
		ПоляКарты.Вставить("link", "");		
	КонецЕсли;
	
	ОбменДаннымиСерверСтоматология.ДобавитьЗапланированныеПриемыВОбновляемыеПоля(ПоляКарты.visits, ВладелецКарты, ИконкиУведомлений);
	ОбменДаннымиСерверСтоматология.ДобавитьЛицевыеСчетаВОбновляемыеПоля(ПоляКарты.accounts, ПоляКарты.balance, ВладелецКарты, ИконкиУведомлений, СимвольныйКодВалюты);
	ОбменДаннымиСерверСтоматология.ДобавитьБонусныеСчетаВОбновляемыеПоля(ПоляКарты.bonuses, ВладелецКарты, ИконкиУведомлений);
	ОбменДаннымиСерверСтоматология.ДобавитьЗадолженностьВОбновляемыеПоля(ПоляКарты.debt, ВладелецКарты);
		
	Если Не СменаВладельца Тогда
		ОбменДаннымиСерверСтоматология.ДобавитьСсылкуНаОнлайнЗаписьВОбновляемыеПоля(ПоляКарты.link);
	КонецЕсли;
		
КонецПРоцедуры

// Функция - Информировать по push wallet
// 
// Параметры:
//  Контрагент			 - 	 - 
//  ВнешняяСистемаWallet - 	 - 
//  Сообщение			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ЕстьКартыWallet(Контрагент) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Карты.ВнутреннийКодКарты КАК ВнутреннийКодКарты
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ВладелецКарты = &ВладелецКарты
	|	И НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Wallet)
	|	И Карты.ВнутреннийКодКарты <> """"");
	
	Запрос.УстановитьПараметр("ВладелецКарты", Контрагент);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, обновляет карты контрагента.
// 
Функция ОбновитьКартыКонтрагента(Контрагент, ВнешняяСистемаWallet, ОписаниеОшибки) Экспорт
	
	РезультатОбновления = Истина;
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Карты.ВнутреннийКодКарты КАК ВнутреннийКодКарты
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ВладелецКарты = &ВладелецКарты
	|	И НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Wallet)
	|	И Карты.ВнутреннийКодКарты <> """"");
	
	Запрос.УстановитьПараметр("ВладелецКарты", Контрагент);
	МассивВнутреннихКодов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВнутреннийКодКарты");
	
	Если ЗначениеЗаполнено(МассивВнутреннихКодов) Тогда
		
		// один на все карты
		ТелоЗапроса = ПолучитьТелоЗапроса(Контрагент,, МассивВнутреннихКодов);
		РезультатОбновления = ОбновитьМассивКарт(ТелоЗапроса, ВнешняяСистемаWallet, ОписаниеОшибки);		
		
	КонецЕсли;
	
	Возврат РезультатОбновления;
	
КонецФункции

// Функция, обновляет массив карт wallet.
// 
Функция ОбновитьМассивКарт(ТелоЗапроса, ВнешняяСистемаWallet, ОписаниеОшибки) Экспорт
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		
		ЗапросНаОбновление = Новый HTTPЗапрос("/v1/passes/by-fields", Заголовки); 
		ЗапросНаОбновление.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		Результат = Соединение.ВызватьHTTPМетод("PATCH", ЗапросНаОбновление);					
		
	Исключение	
		
		ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();
		Возврат Истина; // чтобы при обновлении клиента не вываливалось в отказ, если сервис не доступен.
		
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат, Истина);
	
	Если Результат.КодСостояния <> 200 Тогда	
		
		ОписаниеОшибки = "Wallet: " + ПараметрыJson["error"]["message"];	
		Возврат Ложь;
		
	Иначе
		
		Для Каждого РезультатОбновденияПоКарте Из ПараметрыJson["data"]	Цикл
			
			Если Не РезультатОбновденияПоКарте.Значение["success"] Тогда
				
				Если РезультатОбновденияПоКарте.Значение["error"]["code"] = "not_found" Тогда // карта не найдена, удаляем
					УдалитьЭлектроннуюКарту(РезультатОбновденияПоКарте.Ключ);			
					Продолжить;	
				КонецЕсли;
				
				ОписаниеОшибки = РезультатОбновденияПоКарте.Значение["error"]["message"];
				Возврат Ложь;	
				
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат Истина;
		
	КонецЕсли;
	
КонецФункции

// Процедура, удаляет карту.
//
Процедура УдалитьЭлектроннуюКарту(ВнутреннийКодКарты)
	
	УдаляемаяКарта = Справочники.Карты.НайтиПоРеквизиту("ВнутреннийКодКарты", ВнутреннийКодКарты);
	
	Если ЗначениеЗаполнено(УдаляемаяКарта) Тогда
		
		КартаОбъект = УдаляемаяКарта.ПолучитьОбъект();	
		КартаОбъект.УстановитьПометкуУдаления(Истина);
		
	КонецЕсли;
	
КонецПроцедуры

