										Если НЕ СтрокаМенеджерСотрудник = Неопределено Тогда
											ДополнительныеПараметрыСоздания.Вставить("ОператорОплаты", СтрокаМенеджерСотрудник.Ссылка);											
										КонецЕсли;
									КонецЕсли;
									// Создаем документ
									ПкоРко = СоздатьДокументОплаты(СтрокаВыборкаПоОплатам, ДополнительныеПараметрыСоздания, ПараметрыЗадания.ПараметрыЗагрузки, ТекстовыйНакопитель);
									// СуммаОплатыПКО 	= ДополнительныеПараметрыСоздания.СуммаОплатыПКО;
									// СуммаОплатыРКО 	= ДополнительныеПараметрыСоздания.СуммаОплатыРКО;									
									// ДатаОплатыРКО 	= ДополнительныеПараметрыСоздания.ДатаОплатыРКО;																		
								КонецЕсли;
							Иначе
								Если ЗначениеЗаполнено(СтрокаВыборкаПоОплатам.ПкоСсылка) Тогда
									ПкоРко = СтрокаВыборкаПоОплатам.ПкоСсылка.ПолучитьОбъект();	
									ПкоРко.УстановитьПометкуУдаления(Истина);								
								ИначеЕсли ЗначениеЗаполнено(СтрокаВыборкаПоОплатам.РкоСсылка) Тогда
									ПкоРко = СтрокаВыборкаПоОплатам.РкоСсылка.ПолучитьОбъект();	
									ПкоРко.УстановитьПометкуУдаления(Истина);	
								КонецЕсли;	
							КонецЕсли;
							
							// Если СуммаОплатыПКО > 0
							//	И СуммаОплатыРКО > 0
							//	И ЗначениеЗаполнено(ДатаОплатыРКО)
							//	И ДатаОплатыРКО < ЧленствоОбъект.СрокДействияДатой
							//	И ДатаОплатыРКО > ЧленствоОбъект.ДатаРучнойАктивации
