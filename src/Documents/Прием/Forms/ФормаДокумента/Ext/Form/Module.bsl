// Процедура - Обновить согласование услуги.
//
Процедура ОбновитьСогласованиеУслуги(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда 
		
		ЛечениеТекущиеДанные = ДопПараметры.ЛечениеТекущиеДанные;
		ЛечениеТекущиеДанные.СтатусСогласования 		= Результат.СтатусСогласования;
		ЛечениеТекущиеДанные.КомментарийСогласования 	= Результат.КомментарийСогласования;
		
		Если ЛечениеТекущиеДанные.СтатусСогласования <> ПредопределенноеЗначение("Перечисление.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования")
			И НЕ ЗначениеЗаполнено(ЛечениеТекущиеДанные.ДатаСогласования) Тогда 
			
			ЛечениеТекущиеДанные.ДатаСогласования = ТекущаяСервернаяДата();
			
		КонецЕсли;
		
		УстановитьВидимостьКнопкиЗаписатьИПровести();
		
