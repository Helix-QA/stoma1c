						Продолжить;
					КонецЕсли;
				Иначе 
					
					Если СтрЧислоВхождений(НРег(УровеньЗаполнения.Наименование),ФильтрДанные) = 0 Тогда
						Продолжить;
					КонецЕсли;
					
				КонецЕсли;			
			КонецЕсли;
			
			НоваяСтрока = ЭлементыЗаполнения.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,УровеньЗаполнения);
			
		КонецЦикла;	
		
	КонецЕсли;
	
КонецПроцедуры

