// Функция - Получить сделки по клиенту
//
// Параметры:
//  Контрагент						 - 	 - 
//  СтруктурнаяЕдиница				 - 	 - 
//  ПоВсемДоступнымДляПользователя	 - 	 - 
//  Врач							 - 	 - 
//  Прием							 - ДокументСсылка.Прием	 - Если передать ссылку на Прием и в приеме будет заполнена сделка - функция вернет только ее
//  ВернутьТаблицей					 - Булево	 - 
//  ПоВсемВрачам					 - Булево	 - 
//  РезультатСделки					 - ПеречислениеСсылка.РезультатыСделок	 - 
//										- Неопределено - Все
//										- ПустаяСсылка - Все незавершенные
//										- Значение - Все с переданным значением
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСделкиПоКлиенту(Контрагент
								, СтруктурнаяЕдиница 				= Неопределено
								, ПоВсемДоступнымДляПользователя 	= Истина
								, Врач 								= Неопределено
								, ЗНАЧ Специализация 				= Неопределено
								, Прием 							= Неопределено
								, ВернутьТаблицей 					= Ложь
								, ПоВсемВрачам 						= Ложь
								, РезультатСделки 					= Неопределено
								, Актуальные 						= Ложь
								, МенеджерВТ 						= Неопределено
								, ПолучатьЗапланированные 			= Истина
								, МассивСделокИсключения 			= Неопределено
								, ЗНАЧ ВидОсмотра 					= Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Сделка = Неопределено;
	Если ЗначениеЗаполнено(Прием) Тогда 
		Сделка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Прием, "Сделка");
		Если ЗначениеЗаполнено(Сделка) И ВернутьТаблицей = Ложь Тогда
			МассивСделок = Новый Массив;
			МассивСделок.Добавить(Сделка);
			Возврат МассивСделок;
		КонецЕсли;
	КонецЕсли;
	
	МассивСтруктурныхЕдиницДоступныхПользователю = Новый Массив;
	Если НЕ ЗначениеЗаполнено(Сделка) Тогда 
		Если ПоВсемДоступнымДляПользователя Тогда 
			МассивСтруктурныхЕдиницДоступныхПользователю = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник, "Массив");
			Если ЗначениеЗаполнено(СтруктурнаяЕдиница) И МассивСтруктурныхЕдиницДоступныхПользователю.Найти(СтруктурнаяЕдиница) = Неопределено Тогда 
				МассивСтруктурныхЕдиницДоступныхПользователю.Добавить(СтруктурнаяЕдиница);
			КонецЕсли;
		ИначеЕсли ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
			МассивСтруктурныхЕдиницДоступныхПользователю.Добавить(СтруктурнаяЕдиница);
		КонецЕсли;
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(МассивСтруктурныхЕдиницДоступныхПользователю) ИЛИ (НЕ ЗначениеЗаполнено(Врач) И НЕ ПоВсемВрачам) Тогда  
		МассивСтруктурныхЕдиницДоступныхПользователю = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц(, Истина);
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) И МассивСтруктурныхЕдиницДоступныхПользователю.Найти(СтруктурнаяЕдиница) = Неопределено Тогда 
			МассивСтруктурныхЕдиницДоступныхПользователю.Добавить(СтруктурнаяЕдиница);
		КонецЕсли;
		Если МассивСтруктурныхЕдиницДоступныхПользователю.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
			МассивСтруктурныхЕдиницДоступныхПользователю.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
		КонецЕсли;		
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(Врач) Тогда
		Врач = Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;
			
	// Инициализируем временную таблицу
	Если МенеджерВТ = Неопределено ИЛИ (НЕ ЗначениеЗаполнено(Врач) И НЕ ПоВсемВрачам) Тогда 
		ИнициализироватьВременнуюТаблицуСделокКонтрагента(МенеджерВТ, Контрагент, МассивСтруктурныхЕдиницДоступныхПользователю, Врач, ПоВсемВрачам);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Сделка КАК Сделка,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.Врач КАК Врач,
	|	Сделки.Прием КАК Прием,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	Сделки.СуммаСделки КАК СуммаСделки,
	|	Сделки.ЭтапОтказа КАК ЭтапОтказа,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.ЭтапУспеха КАК ЭтапУспеха,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.Специализация КАК Специализация,
	|	Сделки.ВидСделки = &ВидСделки
	|		И Сделки.ЭтапСделки.НомерЭтапа > 2 КАК Записан
	|ИЗ
	|	ТаблицаСделокПациента КАК Сделки
	|ГДЕ
	|	НЕ Сделки.ПометкаУдаления
	|	И Сделки.Врач = &Врач
	|	И Сделки.Сделка = &Сделка
	|	И Сделки.РезультатСделки = &РезультатСделки
	|	И &СделкиИсключения
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сделки.ДатаСделки";
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;	
	Запрос.УстановитьПараметр("ВидСделки", ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"));		
	
	Если ЗначениеЗаполнено(Сделка) Тогда 
		Запрос.УстановитьПараметр("Сделка", Сделка);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.РезультатСделки = &РезультатСделки", "ИСТИНА");		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Сделка = &Сделка", "ИСТИНА");
	КонецЕсли;
	
	Если Актуальные Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.РезультатСделки = &РезультатСделки", "Сделки.РезультатСделки <> ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.Отказ) И Сделки.РезультатСделки <> ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.Успех)");		
	ИначеЕсли РезультатСделки = Неопределено Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.РезультатСделки = &РезультатСделки", "ИСТИНА");
	Иначе
		Запрос.УстановитьПараметр("РезультатСделки", РезультатСделки);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивСделокИсключения) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &СделкиИсключения", "И НЕ Сделки.Сделка В (&МассивСделокИсключения)");
		Запрос.УстановитьПараметр("МассивСделокИсключения", МассивСделокИсключения);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &СделкиИсключения", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сделка) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Врач = &Врач", "ИСТИНА");
	ИначеЕсли ПоВсемВрачам Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Врач = &Врач", "ИСТИНА");
	Иначе 	
		Запрос.УстановитьПараметр("Врач", Врач);
		Если НЕ ЗначениеЗаполнено(Врач) И ЗначениеЗаполнено(Специализация) Тогда
			Если ВидОсмотра = Перечисления.ВидыОсмотров.Направление И РезультатСделки = Перечисления.РезультатыСделок.ПустаяСсылка() Тогда
				МассивСотрудников = Справочники.Сотрудники.ПолучитьМассивСотрудниковПоСпециализации(Специализация);
				МассивСотрудников.Добавить(Справочники.Сотрудники.ПустаяСсылка());
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Врач = &Врач", "Сделки.Врач В(&МассивВрачей) И Сделки.Специализация = &Специализация");
				Запрос.УстановитьПараметр("МассивВрачей", МассивСотрудников);				
			Иначе 	
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Врач = &Врач", "Сделки.Врач = &Врач И (Сделки.Специализация = &Специализация ИЛИ Сделки.Специализация = ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка))");
			КонецЕсли;	
			Запрос.УстановитьПараметр("Специализация", Специализация);
		КонецЕсли;	
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() И НЕ ЗначениеЗаполнено(Сделка) И ЗначениеЗаполнено(Врач) И НЕ ПоВсемВрачам Тогда
		Если НЕ ЗначениеЗаполнено(Специализация) Тогда 
			Специализация = Справочники.Сотрудники.ПолучитьОсновнуюСпециализациюСотрудника(Врач);
		КонецЕсли;	
		КоллекцияСделок = ПолучитьСделкиПоКлиенту(Контрагент
												, СтруктурнаяЕдиница
												, ПоВсемДоступнымДляПользователя
												, Справочники.Сотрудники.ПустаяСсылка()
												, Специализация										
												, Прием
												, ВернутьТаблицей
												, ПоВсемВрачам
												, РезультатСделки
												, Актуальные
												, МенеджерВТ
												, ПолучатьЗапланированные);
												
	Иначе
		КоллекцияСделок = Неопределено;												
		ТаблицаСделок = Запрос.Выполнить().Выгрузить();
		Если НЕ ПолучатьЗапланированные И ЗначениеЗаполнено(ТаблицаСделок) Тогда 
			// Отсекаем, сделки сгенерированные сегодня по направлениям и повторным приемам
			МассивУдаляемыхСтрок = Новый Массив;
			МассивЗапланированныхСделок = РегистрыСведений.Профосмотры.ПолучитьЗапланированыеСделки(ТекущаяДатаСеанса(), , Контрагент);
			Для Каждого СтрокаТЗСделка Из ТаблицаСделок Цикл 
				Если НЕ МассивЗапланированныхСделок.Найти(СтрокаТЗСделка.Сделка) = Неопределено Тогда
					МассивУдаляемыхСтрок.Добавить(СтрокаТЗСделка);
				КонецЕсли;	
			КонецЦикла;
			Для Каждого ЭлементСтрока Из МассивУдаляемыхСтрок Цикл 
				ТаблицаСделок.Удалить(ЭлементСтрока);
			КонецЦикла;	
		КонецЕсли;
		// Если после отсечения не осталось с нужным врачем - поищем сделку без врача
		Если НЕ ЗначениеЗаполнено(ТаблицаСделок) И НЕ ЗначениеЗаполнено(Сделка) И ЗначениеЗаполнено(Врач) И НЕ ПоВсемВрачам Тогда
			Если НЕ ЗначениеЗаполнено(Специализация) Тогда 
				Специализация = Справочники.Сотрудники.ПолучитьОсновнуюСпециализациюСотрудника(Врач);
			КонецЕсли;	
			КоллекцияСделок = ПолучитьСделкиПоКлиенту(Контрагент
													, СтруктурнаяЕдиница
													, ПоВсемДоступнымДляПользователя
													, Справочники.Сотрудники.ПустаяСсылка()
													, Специализация										
													, Прием
													, ВернутьТаблицей
													, ПоВсемВрачам
													, РезультатСделки
													, Актуальные
													, МенеджерВТ
													, ПолучатьЗапланированные);
			
		КонецЕсли;	
		
		Если КоллекцияСделок = Неопределено Тогда 
			Если ВернутьТаблицей Тогда 
				КоллекцияСделок = ТаблицаСделок;	
			Иначе 	
				КоллекцияСделок = ТаблицаСделок.ВыгрузитьКолонку("Сделка");	
			КонецЕсли;
		КонецЕсли;
		// Уничтожаем временную Таблицу
		Запрос.МенеджерВременныхТаблиц.Закрыть();		
	КонецЕсли;
	
	МенеджерВТ = Неопределено;
	
	Возврат КоллекцияСделок;
	
КонецФункции

// Функция - Получить завершенные сделки
//
// Параметры:
//  ДатаЗавершения		 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  Контрагент			 - 	 - 
//  Врач				 - 	 - 
//  ВидСделки			 - 			 - 
//  РезультатЗавершения	 - 			 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗавершенныеСделки(ДатаЗавершения 		= Неопределено
								, СтруктурнаяЕдиница 	= Неопределено
								, Контрагент 			= Неопределено
								, Врач 					= Неопределено
								, ВидСделки 			= Неопределено
								, РезультатЗавершения 	= Неопределено
								, ВернутьПоследнюю 		= Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сделки.Ссылка КАК Сделка
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сделки.ВидСделки = &ВидСделки
	|	И Сделки.Контрагент = &Контрагент
	|	И Сделки.Врач = &Врач
	|	И Сделки.РезультатСделки = &РезультатСделки
	|	И НАЧАЛОПЕРИОДА(Сделки.ДатаЗавершенияСделки, ДЕНЬ) = &ДатаЗавершенияСделки
	|	И Сделки.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сделки.ДатаЗавершенияСделки";
	
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		МассивСтруктурныхЕдиниц = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц(, Истина);
		Если МассивСтруктурныхЕдиниц.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
			МассивСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
		КонецЕсли;		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "Сделки.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница)");
	КонецЕсли; 
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, МассивСтруктурныхЕдиниц));
	
	Если НЕ ЗначениеЗаполнено(ВидСделки) Тогда
		МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, МассивСтруктурныхЕдиниц));		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.ВидСделки = &ВидСделки", "Сделки.ВидСделки В(&ВидСделки)");
	КонецЕсли;
	Запрос.УстановитьПараметр("ВидСделки", ?(ЗначениеЗаполнено(ВидСделки), ВидСделки, МассивВидовСделок));
	
	Если ЗначениеЗаполнено(Контрагент) Тогда 
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Сделки.Контрагент = &Контрагент", "");
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Врач) Тогда 
		Запрос.УстановитьПараметр("Врач", Врач);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Сделки.Врач = &Врач", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатЗавершения) Тогда 
		Запрос.УстановитьПараметр("РезультатСделки", РезультатЗавершения);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.РезультатСделки = &РезультатСделки", "Сделки.РезультатСделки <> ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)");
	КонецЕсли; 

	Если ЗначениеЗаполнено(ДатаЗавершения) Тогда 
		Запрос.УстановитьПараметр("ДатаЗавершенияСделки", НачалоДня(ДатаЗавершения));
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НАЧАЛОПЕРИОДА(Сделки.ДатаЗавершенияСделки, ДЕНЬ) = &ДатаЗавершенияСделки", "Сделки.ДатаЗавершенияСделки <> ДАТАВРЕМЯ(1,1,1)");
	КонецЕсли;
				
	Если ВернутьПоследнюю Тогда 
		ТаблицаСделок = Запрос.Выполнить().Выгрузить();
		Если ЗначениеЗаполнено(ТаблицаСделок) Тогда 
			Возврат ТаблицаСделок[ТаблицаСделок.Количество()-1].Сделка;
		Иначе 
			Возврат Справочники.Сделки.ПустаяСсылка();
		КонецЕсли;	
	Иначе 	
		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сделка");
	КонецЕсли;	
	
КонецФункции

// Процедура - Инициализировать временную таблицу сделок контрагента
//
// Параметры:
//  МенеджерВТ	 - 	 - 
//  Контрагент	 - 	 - 
//
Процедура ИнициализироватьВременнуюТаблицуСделокКонтрагента(МенеджерВТ, Контрагент, МассивСтруктурныхЕдиниц, Врач, ПоВсемВрачам) Экспорт 
	
	//---------------------------------------------
	МассивПараметровОтбора = Новый Массив;

	ПараметрыОтбораСЕ 			= Новый Структура;
	ПараметрыОтбораСЕ.Вставить("ШаблонУсловия"						, "&ОтборСтруктурнаяЕдиница");
	ПараметрыОтбораСЕ.Вставить("УсловиеОтбора"						, "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
	ПараметрыОтбораСЕ.Вставить("НаименованиеПараметра"				, "СтруктурнаяЕдиница");
	
	ПараметрыОтбораВидаСделок 	= Новый Структура;
	ПараметрыОтбораВидаСделок.Вставить("ШаблонУсловия"				, "&ОтборВидаСделок");	
	ПараметрыОтбораВидаСделок.Вставить("УсловиеОтбора"				, "Сделки.ВидСделки В(&МассивВидовСделок)");
	ПараметрыОтбораВидаСделок.Вставить("НаименованиеПараметра"		, "МассивВидовСделок");
	
	Если МассивСтруктурныхЕдиниц.Количество() = 1 Тогда
		ПараметрыОтбораСЕ.Вставить("ЗначениеПараметра"				, МассивСтруктурныхЕдиниц[0]);
		Если НЕ ЗначениеЗаполнено(Врач) И НЕ ПоВсемВрачам Тогда
			МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"), МассивСтруктурныхЕдиниц[0]);                                       
		Иначе 	
			МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиниц[0]);
		КонецЕсли;
		ПараметрыОтбораВидаСделок.Вставить("ЗначениеПараметра"		, МассивВидовСделок);
	Иначе
		ПараметрыОтбораСЕ.Вставить("УсловиеОтбора"					, "Сделки.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)");
		ПараметрыОтбораСЕ.Вставить("НаименованиеПараметра"			, "МассивСтруктурныхЕдиниц");
		ПараметрыОтбораСЕ.Вставить("ЗначениеПараметра"				, МассивСтруктурныхЕдиниц);
		Если НЕ ЗначениеЗаполнено(Врач) И НЕ ПоВсемВрачам Тогда
			МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"), МассивСтруктурныхЕдиниц);
		Иначе 				
			МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиниц);
		КонецЕсли;
		ПараметрыОтбораВидаСделок.Вставить("ЗначениеПараметра"		, МассивВидовСделок);
	КонецЕсли;	
	МассивПараметровОтбора.Добавить(ПараметрыОтбораСЕ);
	МассивПараметровОтбора.Добавить(ПараметрыОтбораВидаСделок);
	
	МенеджерВТ						= Новый МенеджерВременныхТаблиц;
	Запрос 							= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц 	= МенеджерВТ;
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.ПометкаУдаления КАК ПометкаУдаления,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.ДатаСделки КАК ДатаСделки,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.Врач КАК Врач,
	|	Сделки.Специализация КАК Специализация,
	|	Сделки.Прием КАК Прием,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.СуммаСделки КАК СуммаСделки,
	|	Сделки.ЭтапОтказа КАК ЭтапОтказа,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.ЭтапУспеха КАК ЭтапУспеха
	|ПОМЕСТИТЬ ТаблицаСделокПациента
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	&ОтборСтруктурнаяЕдиница
	|	И &ОтборВидаСделок
	|	И Сделки.Контрагент = &Контрагент";
	
	Для Каждого ЭлементКоллекции Из МассивПараметровОтбора Цикл 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, ЭлементКоллекции.ШаблонУсловия, ЭлементКоллекции.УсловиеОтбора);
		Если ЗначениеЗаполнено(ЭлементКоллекции.НаименованиеПараметра) Тогда 
			Запрос.УстановитьПараметр(ЭлементКоллекции.НаименованиеПараметра, ЭлементКоллекции.ЗначениеПараметра);
		КонецЕсли;	
	КонецЦикла;
	
	Запрос.Выполнить();
	
КонецПроцедуры

// Функция - Получить сделку по записи на прием
//
// Параметры:
//  Запись	 - 	 - 
//  Прием	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСделкуПоЗаписиНаПрием(Запись = Неопределено, Прием = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(Запись) Тогда 
		Возврат ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Запись, "Сделка");
	ИначеЕсли ЗначениеЗаполнено(Прием) Тогда
		Если НЕ ПривилегированныйРежим() Тогда 
			УстановитьПривилегированныйРежим(Истина);
		КонецЕсли;	
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("СсылкаНаПрием", Прием);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Событие.Сделка КАК Сделка
		|ИЗ
		|	Документ.Событие КАК Событие
		|ГДЕ
		|	Событие.СсылкаНаПрием = &СсылкаНаПрием";
		
		ВыборкаСделки = Запрос.Выполнить().Выбрать();
		Возврат ?(ВыборкаСделки.Следующий(), ВыборкаСделки.Сделка, Неопределено);
	Иначе 
		Возврат Неопределено;	
	КонецЕсли;
	
КонецФункции

// Функция - Получить сделки по продлению членства пакета услуг
//
// Параметры:
//  ЧленствоПакетУслуг	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСделкиПоПродлениюЧленстваПакетаУслуг(ЧленствоПакетУслуг, ПоВсемДоступнымДляПользователя = Истина) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(ЧленствоПакетУслуг) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	МассивСтруктурныхЕдиницДоступныхПользователю = Неопределено;
	Если ПоВсемДоступнымДляПользователя Тогда 
		МассивСтруктурныхЕдиницДоступныхПользователю = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник, "Массив");
		Если МассивСтруктурныхЕдиницДоступныхПользователю.Найти(ТекущаяСтруктурнаяЕдиница) = Неопределено Тогда 
			МассивСтруктурныхЕдиницДоступныхПользователю.Добавить(ТекущаяСтруктурнаяЕдиница);
		КонецЕсли;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Сделки.Ссылка КАК Сделка
	               |ИЗ
	               |	Справочник.Сделки КАК Сделки
	               |ГДЕ
	               |	Сделки.ПометкаУдаления = ЛОЖЬ
	               |	И Сделки.ЧленствоПакетУслуг = &ЧленствоПакетУслуг
	               |	И &ОтборСтруктурнаяЕдиница
	               |	И Сделки.ВидСделки В(&МассивВидовСделок)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Сделки.ДатаСделки";
	
	Запрос.УстановитьПараметр("ЧленствоПакетУслуг", ЧленствоПакетУслуг);
	Если ЗначениеЗаполнено(МассивСтруктурныхЕдиницДоступныхПользователю) Тогда
		Если МассивСтруктурныхЕдиницДоступныхПользователю.Количество() = 1 Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборСтруктурнаяЕдиница", "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница", МассивСтруктурныхЕдиницДоступныхПользователю[0]);
			МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиницДоступныхПользователю[0]);
			Запрос.УстановитьПараметр("МассивВидовСделок", МассивВидовСделок);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборСтруктурнаяЕдиница", "Сделки.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)");	
			Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиницДоступныхПользователю);			
			МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиницДоступныхПользователю);
			Запрос.УстановитьПараметр("МассивВидовСделок", МассивВидовСделок);			
		КонецЕсли;	
	ИначеЕсли ЗначениеЗаполнено(ТекущаяСтруктурнаяЕдиница) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборСтруктурнаяЕдиница", "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ТекущаяСтруктурнаяЕдиница);
		МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, ТекущаяСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("МассивВидовСделок", МассивВидовСделок);					
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборСтруктурнаяЕдиница", "ИСТИНА");
		МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок();
		Запрос.УстановитьПараметр("МассивВидовСделок", МассивВидовСделок);							
	КонецЕсли;	
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сделка");	
	
КонецФункции

// Функция - Получить не завершенные сделки по записям без приемов
//
// Параметры:
//  НачалоПериода		 - 	 - 
//  КонецПериода		 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНеЗавершенныеСделкиПоЗаписямБезПриемов(НачалоПериода
													, КонецПериода
													, СтруктурнаяЕдиница = Неопределено) Экспорт

	Если НЕ ЗначениеЗаполнено(НачалоПериода) Тогда 
		НачалоПериода = НачалоДня(ТекущаяДатаСеанса()) - 86400;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(КонецПериода) Тогда 
		КонецПериода = ТекущаяДатаСеанса();
	КонецЕсли;
	
	МассивСтруктурныхЕдиниц = Новый Массив;
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		Если ТипЗнч(СтруктурнаяЕдиница) = Тип("СправочникСсылка.СтруктурныеЕдиницы") Тогда 
			МассивСтруктурныхЕдиниц.Добавить(СтруктурнаяЕдиница);
		ИначеЕсли ТипЗнч(СтруктурнаяЕдиница) = Тип("Массив") Тогда 
			МассивСтруктурныхЕдиниц = СтруктурнаяЕдиница;
		КонецЕсли;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериодаПроверки"	, НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериодаПроверки"	, КонецПериода);
	Запрос.УстановитьПараметр("ПредопреленныйВидСделки"	, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОкончен) КАК СтатусПредварительнойЗаписи
	|ПОМЕСТИТЬ СтатусыПредварительнойЗаписи
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СтатусПредварительнойЗаписи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументСобытие.Ссылка КАК ПредварительнаяЗапись,
	|	ДокументСобытие.Дата КАК ДатаНачалаПриема,
	|	ДокументСобытие.Резерв КАК Резерв,
	|	ДокументСобытие.СсылкаНаПрием КАК СсылкаНаПрием,
	|	ДокументСобытие.Статус КАК Статус,
	|	ДокументСобытие.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ДокументСобытие.ТипСобытия КАК ТипСобытия,
	|	ДокументСобытие.Сделка КАК Сделка
	|ПОМЕСТИТЬ ТаблицаЗаписейПоДате
	|ИЗ
	|	Документ.Событие КАК ДокументСобытие
	|ГДЕ
	|	ДокументСобытие.Проведен
	|	И ДокументСобытие.Дата > &НачалоПериодаПроверки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЗаписейПоДате.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
	|	ТаблицаЗаписейПоДате.ДатаНачалаПриема КАК ДатаНачалаПриема,
	|	ТаблицаЗаписейПоДате.СсылкаНаПрием КАК СсылкаНаПрием,
	|	ТаблицаЗаписейПоДате.Статус КАК Статус,
	|	ТаблицаЗаписейПоДате.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаЗаписейПоДате.Сделка КАК Сделка
	|ПОМЕСТИТЬ ТаблицаЗавершенныхПриемов
	|ИЗ
	|	ТаблицаЗаписейПоДате КАК ТаблицаЗаписейПоДате
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СтатусыПредварительнойЗаписи КАК СтатусыПредварительнойЗаписи
	|		ПО ТаблицаЗаписейПоДате.Статус = СтатусыПредварительнойЗаписи.СтатусПредварительнойЗаписи
	|ГДЕ
	|	ТаблицаЗаписейПоДате.ДатаНачалаПриема <= &КонецПериодаПроверки
	|	И ТаблицаЗаписейПоДате.Резерв = ЛОЖЬ
	|	И ТаблицаЗаписейПоДате.ТипСобытия = ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ПредварительнаяЗапись)
	|	И ТаблицаЗаписейПоДате.Сделка <> ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|	И &УсловиеСтруктурнаяЕдиница
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Сделка,
	|	СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.Врач КАК Врач,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	ТаблицаЗавершенныхПриемов.Статус КАК Статус
	|ИЗ
	|	ТаблицаЗавершенныхПриемов КАК ТаблицаЗавершенныхПриемов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сделки КАК Сделки
	|		ПО ТаблицаЗавершенныхПриемов.Сделка = Сделки.Ссылка
	|			И ТаблицаЗавершенныхПриемов.СтруктурнаяЕдиница = Сделки.СтруктурнаяЕдиница
	|ГДЕ
	|	Сделки.ВидСделки = &ПредопреленныйВидСделки
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";
	
	Если ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) Тогда
		Если МассивСтруктурныхЕдиниц.Количество() = 1 Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ТаблицаЗаписейПоДате.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница", МассивСтруктурныхЕдиниц[0]);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ТаблицаЗаписейПоДате.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница)");
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница", МассивСтруктурныхЕдиниц);
		КонецЕсли;	
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	Возврат Запрос.Выполнить().Выгрузить();
													
КонецФункции

// Функция, возвращает актуальную сделку контрагента.
//
Функция ПолучитьАктуальнуюСделкуКлиента(Контрагент, СтруктурнаяЕдиница = Неопределено, БезЗаявок = Ложь) Экспорт
	
	ВидСделки = Неопределено;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сделки.Ссылка КАК Сделка
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сделки.ВидСделки = &ВидСделки
	|	И Сделки.Контрагент = &Контрагент
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	|	И НЕ Сделки.ПометкаУдаления
	|	И &УсловиеБезЗаявок
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сделки.ДатаСделки УБЫВ");
	
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		МассивСтруктурныхЕдиниц = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц(, Истина);
		Если МассивСтруктурныхЕдиниц.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
			МассивСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
		КонецЕсли;		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "Сделки.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница)");
	КонецЕсли; 
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, МассивСтруктурныхЕдиниц));
	
	Если НЕ ЗначениеЗаполнено(ВидСделки) Тогда
		МассивВидовСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, МассивСтруктурныхЕдиниц));		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.ВидСделки = &ВидСделки", "Сделки.ВидСделки В(&ВидСделки)");
	КонецЕсли;
	Запрос.УстановитьПараметр("ВидСделки", ?(ЗначениеЗаполнено(ВидСделки), ВидСделки, МассивВидовСделок));
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	УсловиеБезЗаявок 			= ?(БезЗаявок, "И Сделки.Заявка = ЗНАЧЕНИЕ(Справочник.Заявки.ПустаяСсылка)", "");
	Запрос.Текст              	= СтрЗаменить(Запрос.Текст, "И &УсловиеБезЗаявок", УсловиеБезЗаявок);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Сделка; 
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция, проверяет наличие актуальных сделок по контрагенту.
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НаличиеАктуальныхСделокПоКлиенту(СтруктурнаяЕдиница = Неопределено
										, ВидыСделок = Неопределено
										, Контрагент
										, РезультатСделки = Неопределено) Экспорт
	
	КоллекцияСделок = ПолучитьСделкиПоКлиенту(Контрагент, СтруктурнаяЕдиница, , , , , ЗначениеЗаполнено(ВидыСделок), Истина, РезультатСделки);
	Если НЕ ЗначениеЗаполнено(КоллекцияСделок) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидыСделок) Тогда 
		Если ТипЗнч(ВидыСделок) = Тип("Массив") Тогда
			ЕстьСделки = Ложь;
			Для Каждого ЭлементВидСделки Из ВидыСделок Цикл 
				МассивСделок = КоллекцияСделок.НайтиСтроки(Новый Структура("ВидСделки", ЭлементВидСделки));
				Если НЕ МассивСделок.Количество() = 0 Тогда
					ЕстьСделки = Истина;
					Прервать;
				КонецЕсли;	
			КонецЦикла;
			Возврат ЕстьСделки;
		ИначеЕсли ТипЗнч(ВидыСделок) = Тип("СправочникСсылка.ВидыСделок") Тогда 
			Возврат НЕ КоллекцияСделок.НайтиСтроки(Новый Структура("ВидСделки", ВидыСделок)).Количество() = 0;
		КонецЕсли;
	Иначе 
		Возврат ЗначениеЗаполнено(КоллекцияСделок);
	КонецЕсли;
	
КонецФункции

// Функция - Получить актуальный этап сделки
//
// Параметры:
//  Сделка		 - 	 - 
//  ВидСделки	 - 	 - 
//  Пациент		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАктуальныйЭтапВоронки(Сделка = Неопределено, ВидСделки, Пациент = Неопределено, СтатусПЗ = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	ТаблицаПриемов = Новый ТаблицаЗначений;
	ТаблицаАктуальныхЗаписей = Новый ТаблицаЗначений;
	Если ЗначениеЗаполнено(Сделка) Тогда	
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Сделка", Сделка);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Событие.Ссылка КАК ПредварительнаяЗапись,
		|	Событие.Дата КАК Дата,
		|	Событие.ДатаСоздания КАК ДатаСоздания,
		|	Событие.Статус КАК Статус,
		|	Событие.Сделка КАК Сделка,
		|	Событие.Проведен КАК Проведен,
		|	Событие.ПометкаУдаления КАК ПометкаУдаления
		|ПОМЕСТИТЬ ТаблицаПредварительныхЗаписейВоронки
		|ИЗ
		|	Документ.Событие КАК Событие
		|ГДЕ
		|	Событие.Сделка = &Сделка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПредварительныхЗаписейВоронки.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
		|	ТаблицаПредварительныхЗаписейВоронки.Дата КАК Дата,
		|	ТаблицаПредварительныхЗаписейВоронки.ДатаСоздания КАК ДатаСоздания,
		|	ТаблицаПредварительныхЗаписейВоронки.Статус КАК Статус,
		|	ТаблицаПредварительныхЗаписейВоронки.Сделка КАК Сделка
		|ИЗ
		|	ТаблицаПредварительныхЗаписейВоронки КАК ТаблицаПредварительныхЗаписейВоронки
		|ГДЕ
		|	НЕ ТаблицаПредварительныхЗаписейВоронки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемНеСостоялся), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен))
		|	И ТаблицаПредварительныхЗаписейВоронки.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПредварительныхЗаписейВоронки.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
		|	ТаблицаПредварительныхЗаписейВоронки.Дата КАК Дата,
		|	ТаблицаПредварительныхЗаписейВоронки.ДатаСоздания КАК ДатаСоздания,
		|	ТаблицаПредварительныхЗаписейВоронки.Статус КАК Статус,
		|	ТаблицаПредварительныхЗаписейВоронки.Сделка КАК Сделка
		|ИЗ
		|	ТаблицаПредварительныхЗаписейВоронки КАК ТаблицаПредварительныхЗаписейВоронки
		|ГДЕ
		|	ТаблицаПредварительныхЗаписейВоронки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемНеСостоялся), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен))
		|	И ТаблицаПредварительныхЗаписейВоронки.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПредварительныхЗаписейВоронки.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
		|	ТаблицаПредварительныхЗаписейВоронки.Дата КАК Дата,
		|	ТаблицаПредварительныхЗаписейВоронки.ДатаСоздания КАК ДатаСоздания,
		|	ТаблицаПредварительныхЗаписейВоронки.Статус КАК Статус,
		|	ТаблицаПредварительныхЗаписейВоронки.Сделка КАК Сделка
		|ИЗ
		|	ТаблицаПредварительныхЗаписейВоронки КАК ТаблицаПредварительныхЗаписейВоронки
		|ГДЕ
		|	ТаблицаПредварительныхЗаписейВоронки.ПометкаУдаления
		|	И ТаблицаПредварительныхЗаписейВоронки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.НеПодтверждена), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.Подтверждена))
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументПрием.Дата КАК Дата,
		|	ДокументПрием.Ссылка КАК Прием,
		|	ДокументПрием.Сделка КАК Сделка,
		|	ДокументПрием.РезультатПриема КАК РезультатПриема,
		|	ДокументПрием.ДокументОснование КАК ДокументОснование
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ДокументПрием.Проведен
		|	И ДокументПрием.Сделка = &Сделка
		|	И ВЫБОР
		|			КОГДА НЕ ВЫРАЗИТЬ(ДокументПрием.ДокументОснование КАК Документ.Событие) ЕСТЬ NULL
		|				ТОГДА НЕ ВЫРАЗИТЬ(ДокументПрием.ДокументОснование КАК Документ.Событие).Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемНеСостоялся), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен))
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата";
		
		РезультатПакетногоЗапроса 	= Запрос.ВыполнитьПакет();
		ТаблицаАктуальныхЗаписей 	= РезультатПакетногоЗапроса[1].Выгрузить();
		ТаблицаОтмененныхЗаписей 	= РезультатПакетногоЗапроса[2].Выгрузить();
		ТаблицаУдаленныхЗаписей 	= РезультатПакетногоЗапроса[3].Выгрузить();		
		ТаблицаПриемов 				= РезультатПакетногоЗапроса[4].Выгрузить(); 
	КонецЕсли;
	
	Если ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
		Если НЕ ТаблицаПриемов.Количество() = 0 Тогда
			Возврат Справочники.ЭтапыСделок.Успех;
		КонецЕсли;	
		Если НЕ ТаблицаАктуальныхЗаписей.Количество() = 0 Тогда
			СтатусПЗ = ТаблицаАктуальныхЗаписей[ТаблицаАктуальныхЗаписей.Количество() - 1].Статус;			
			Если ТаблицаАктуальныхЗаписей[ТаблицаАктуальныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда 
				Возврат Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 4);
			ИначеЕсли ТаблицаАктуальныхЗаписей[ТаблицаАктуальныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.ПриемОтменен
				ИЛИ ТаблицаАктуальныхЗаписей[ТаблицаАктуальныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда 
				Возврат Справочники.ЭтапыСделок.Отказ;
			ИначеЕсли ЗначениеЗаполнено(Сделка)
				И (СтатусПЗ = Перечисления.СтатусыСобытия.ПациентОжидает ИЛИ СтатусПЗ = Перечисления.СтатусыСобытия.ПриемНачат ИЛИ СтатусПЗ = Перечисления.СтатусыСобытия.ПриемОкончен)
				И ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сделка, "ЭтапСделки") = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 4) Тогда 
				Возврат Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 4);
			Иначе 
				Возврат Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 3);
			КонецЕсли;
		КонецЕсли;	
		Если ЗначениеЗаполнено(Сделка)
			И ЗначениеЗаполнено(ТаблицаОтмененныхЗаписей)
			И (ТаблицаОтмененныхЗаписей[ТаблицаОтмененныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.ПриемОтменен
			ИЛИ ТаблицаОтмененныхЗаписей[ТаблицаОтмененныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся) Тогда
			
			СтатусПЗ = ТаблицаОтмененныхЗаписей[ТаблицаОтмененныхЗаписей.Количество() - 1].Статус;
			Возврат Справочники.ЭтапыСделок.Отказ;
		ИначеЕсли ЗначениеЗаполнено(Сделка)
			И ЗначениеЗаполнено(ТаблицаУдаленныхЗаписей)
			И (ТаблицаУдаленныхЗаписей[ТаблицаУдаленныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.НеПодтверждена
			ИЛИ ТаблицаУдаленныхЗаписей[ТаблицаУдаленныхЗаписей.Количество() - 1].Статус = Перечисления.СтатусыСобытия.Подтверждена) Тогда
			
			СтатусПЗ = ТаблицаУдаленныхЗаписей[ТаблицаУдаленныхЗаписей.Количество() - 1].Статус;
			Возврат Справочники.ЭтапыСделок.Отказ;
		Иначе 	
			Возврат Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделки, 3);
		КонецЕсли;	
	КонецЕсли;

	Возврат Неопределено;
	
КонецФункции	

// Функция возвращает сделку по заявке.
//
Функция ПолучитьСделкуПоЗаявке(Заявка, СделкаИсключение = Неопределено) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сделки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.Заявка = &Заявка
	|	И НЕ Сделки.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сделки.ДатаСделки УБЫВ");
	
	Запрос.УстановитьПараметр("Заявка", Заявка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции	

// Процедура - Инициализировать сделку согласно предмета
//
// Параметры:
//  ЗадачаПредмет	 - 	 - 
//  Сделка			 - 	 - 
//
Процедура ИнициализироватьСделкуСогласноПредмета(СтруктурнаяЕдиница, Контрагент, ЗадачаПредмет, Сделка) Экспорт
	
	Если ЗначениеЗаполнено(Сделка) Тогда 
		Возврат;
	КонецЕсли;
	             
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Сделки.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Сделки КАК Сделки
	               |ГДЕ
	               |	Сделки.ПометкаУдаления = ЛОЖЬ
	               |	И Сделки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница				   
	               |	И &УсловиеПоискаСделки
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Сделки.ДатаСделки УБЫВ";
	
	Если ЗначениеЗаполнено(ЗадачаПредмет) И ТипЗнч(ЗадачаПредмет) = Тип("ДокументСсылка.ПланЛечения") Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоискаСделки", "Сделки.ПланЛечения = &ПланЛечения");
		Запрос.УстановитьПараметр("ПланЛечения", ЗадачаПредмет);
	ИначеЕсли ЗначениеЗаполнено(ЗадачаПредмет) И ТипЗнч(ЗадачаПредмет) = Тип("СправочникСсылка.Заявки") Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоискаСделки", "Сделки.Заявка = &Заявка");
		Запрос.УстановитьПараметр("Заявка", ЗадачаПредмет);
	ИначеЕсли ЗначениеЗаполнено(Контрагент) Тогда
		Возврат;
		//Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоискаСделки", "Сделки.Контрагент = &Контрагент");
		//Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе 
		Возврат;
	КонецЕсли;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);

	ВыборкаСделка = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаСделка.Следующий() Тогда 
		Сделка = ВыборкаСделка.Ссылка;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Установить этап сделке
//
// Параметры:
//  Сделка				 - 	 - 
//  Этап				 - 	 - 
//  ВключитьБизнесЛогику - 	 - 
//
Процедура УстановитьЭтапСделке(Сделка
							, Этап
							, ВключитьБизнесЛогику 	= Ложь
							, ЛечащийВрач 			= Неопределено
							, СтатусПЗ 				= Неопределено
							, ПричинаОтказа 		= Неопределено
							, Описание 				= ""
							, СтруктурнаяЕдиница 	= Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Сделка_Объект = Сделка.ПолучитьОбъект();
	Если Сделка_Объект.ЭтапСделки = Этап Тогда 
		Возврат;
	КонецЕсли;	
	Если Этап 							= Справочники.ЭтапыСделок.Успех Тогда 
		Сделка_Объект.РезультатСделки 	= Перечисления.РезультатыСделок.Успех;
		Сделка_Объект.ЭтапУспеха		= Сделка_Объект.ЭтапСделки;
		Сделка_Объект.ЭтапСделки		= Справочники.ЭтапыСделок.Успех;
		Сделка_Объект.ПричинаОтказа   	= Неопределено;
		Прием = Документы.Прием.ПолучитьПоследнийПриемПоСделке(Сделка);
		Если Сделка_Объект.Прием <> Прием Тогда		
			Сделка_Объект.Прием 		= Прием;
		КонецЕсли;
	ИначеЕсли Этап 						= Справочники.ЭтапыСделок.Отказ Тогда	
		Сделка_Объект.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;
		Сделка_Объект.ЭтапОтказа		= Сделка_Объект.ЭтапСделки;
		Сделка_Объект.ЭтапСделки		= Справочники.ЭтапыСделок.Отказ;
		Если ЗначениеЗаполнено(ПричинаОтказа) И ТипЗнч(ПричинаОтказа) = Тип("СправочникСсылка.ПричиныОтказов") Тогда 
			Сделка_Объект.ПричинаОтказа = ПричинаОтказа;
		Иначе 	
			Сделка_Объект.ПричинаОтказа = ПолучитьПричинуОтказаСделки(Сделка, Сделка_Объект.ВидСделки, СтатусПЗ, ПричинаОтказа);
		КонецЕсли;	
	Иначе 
		Сделка_Объект.ЭтапСделки 		= Этап;		
	КонецЕсли;
	Если ЛечащийВрач <> Неопределено Тогда
		Сделка_Объект.Врач = ЛечащийВрач;
	КонецЕсли;
	Если СтруктурнаяЕдиница <> Неопределено Тогда
		Сделка_Объект.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
	КонецЕсли;
	Если ЗначениеЗаполнено(Описание) Тогда 
		Сделка_Объект.Описание = Сделка_Объект.Описание + ?(ЗначениеЗаполнено(СокрЛП(Сделка_Объект.Описание)), Символы.ПС, "") + Описание;
	КонецЕсли;		
	Попытка
		Сделка_Объект.ОбменДанными.Загрузка = НЕ ВключитьБизнесЛогику;			
		Сделка_Объект.Записать();
	Исключение
		МетаданныеСправочника 			= Метаданные.Справочники.Сделки;
		ПредставлениеСправочника 		= МетаданныеСправочника.Представление();
		
		// Сформируем комментарий			
		ШаблонКомментария = НСтр("ru = 'Не удалось установить этап сделке
		|по причине: %1'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонКомментария,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		// Запишем в журнал
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Изменение сделки'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,
		МетаданныеСправочника,,
		Комментарий);
		
		ВызватьИсключение Комментарий;
	КонецПопытки;	
	
КонецПроцедуры

// Процедура - Сменить врача в сделке
//
// Параметры:
//  Сделка				 - 	 - 
//  ЛечащийВрач			 - 	 - 
//  ВключитьБизнесЛогику - 	 - 
//
Процедура СменитьВрачаВСделке(Сделка, ЛечащийВрач, ВключитьБизнесЛогику = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Сделка_Объект = Сделка.ПолучитьОбъект();
	Если Сделка_Объект.Врач = ЛечащийВрач Тогда 
		Возврат;
	КонецЕсли;	
	Сделка_Объект.Врач = ЛечащийВрач;
	Попытка
		Сделка_Объект.ОбменДанными.Загрузка = НЕ ВключитьБизнесЛогику;			
		Сделка_Объект.Записать();
	Исключение
		МетаданныеСправочника 			= Метаданные.Справочники.Сделки;
		ПредставлениеСправочника 		= МетаданныеСправочника.Представление();
		
		// Сформируем комментарий			
		ШаблонКомментария = НСтр("ru = 'Не удалось сменить врача в сделке
		|по причине: %1'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонКомментария,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		// Запишем в журнал
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Изменение сделки'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,
		МетаданныеСправочника,,
		Комментарий);
		
		ВызватьИсключение Комментарий;
	КонецПопытки;	
	
КонецПроцедуры

// Функция - Получить причину отказа сделки
//
// Параметры:
//  Сделка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПричинуОтказаСделки(Сделка, ВидСделки = Неопределено, СтатусПЗ = Неопределено, ПричинаОтказа = Неопределено) Экспорт

	Если ЗначениеЗаполнено(ПричинаОтказа) Тогда 
		Возврат Справочники.ПричиныОтказов.ИнициализироватьПричинуОтказа(ПричинаОтказа, Истина);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидСделки) Тогда 
		ВидСделки = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сделка, "ВидСделки");
	КонецЕсли;
	
	Если ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
		Если НЕ ЗначениеЗаполнено(СтатусПЗ) Тогда 
			ПредварительнаяЗапись = Документы.Событие.ПолучитьПредварительнуюЗаписьПоСделке(Сделка, СтатусПЗ);
		КонецЕсли;
		Если СтатусПЗ = Перечисления.СтатусыСобытия.ПриемОтменен Тогда 
			Возврат ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался");
		ИначеЕсли СтатусПЗ = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда 
			Возврат ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентНеПришел"); 
		Иначе 
			Возврат Неопределено;
		КонецЕсли;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Сделка", Сделка);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Событие.ПричинаОтмены КАК ПричинаОтмены
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.Проведен
	|	И Событие.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	|	И Событие.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Событие.Дата УБЫВ";
	
	ВыборкаПричиныОтмены = Запрос.Выполнить().Выбрать();
	ПричинаОтмены = ?(ВыборкаПричиныОтмены.Следующий(), ВыборкаПричиныОтмены.ПричинаОтмены, Неопределено);
	Если ЗначениеЗаполнено(ПричинаОтмены) Тогда 
		Возврат Справочники.ПричиныОтказов.ИнициализироватьПричинуОтказа(ПричинаОтмены, Истина);
	Иначе 	
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

// Функция - Получить сокращенное наименование врача
//
// Параметры:
//  Сделка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСокращенноеНаименованиеВрача(Сделка = Неопределено, Врач = Неопределено) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(Сделка) И НЕ ЗначениеЗаполнено(Врач) Тогда 
		Возврат "";
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(Врач) Тогда 
		Врач = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Сделка, "Врач");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Врач) Тогда 
		Возврат "";
	КонецЕсли;
	
	Возврат Справочники.Сотрудники.ПолучитьСокращенноеНаименованиеСотрудника(, Врач);	
	
КонецФункции

// Функция - Допустим отказ согласно текущего этапа
// 
// Возвращаемое значение:
//   - 
//
Функция ДопустимОтказСогласноТекущегоЭтапа(Сделка, ВидСделкиПредопределенный = Неопределено) Экспорт 
	
	ДоступностьОтказа = Истина;
	Если НЕ ЗначениеЗаполнено(Сделка) Тогда 
		Возврат ДоступностьОтказа;
	КонецЕсли;
	
	Если ВидСделкиПредопределенный = Неопределено ИЛИ НЕ ТипЗнч(ВидСделкиПредопределенный) = Тип("Булево") Тогда 
		ВидСделкиПредопределенный = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сделка, "ВидСделки") = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"); 
	КонецЕсли;	
	
	Если ВидСделкиПредопределенный Тогда 
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Сделка", Сделка);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СделкиИсторияИзмененияЭтапов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сделки.ИсторияИзмененияЭтапов КАК СделкиИсторияИзмененияЭтапов
		|ГДЕ
		|	СделкиИсторияИзмененияЭтапов.Ссылка = &Сделка
		|	И (СделкиИсторияИзмененияЭтапов.ПереходСЭтапа.НомерЭтапа > 2
		|			ИЛИ СделкиИсторияИзмененияЭтапов.ПереходНаЭтап.НомерЭтапа > 2)";
		
		Возврат Запрос.Выполнить().Пустой() ИЛИ НЕ ЗначениеЗаполнено(Документы.Событие.ПолучитьПредварительнуюЗаписьПоСделке(Сделка));
	Иначе 
		Возврат ДоступностьОтказа;
	КонецЕсли;	
	
КонецФункции

// Процедура - Обработка получения полей представления
//
// Параметры:
//  Поля				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
    Поля.Добавить("Наименование");
	Поля.Добавить("ПометкаУдаления");
	Поля.Добавить("Примечание");
	
КонецПроцедуры

// Процедура - Обработка получения представления
//
// Параметры:
//  Данные				 - 	 - 
//  Представление		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	СтандартнаяОбработка 		= Ложь;
	Если Данные.ПометкаУдаления = Истина Тогда 
		Представление 			= Данные.Наименование + НСтр("ru= ' (удалена)';en= ' (deleted)'");
	Иначе 	
		Представление 			= Данные.Наименование + ?(ЗначениеЗаполнено(СокрЛП(Данные.Примечание)), " (" + СокрЛП(Данные.Примечание) + ")", "");
	КонецЕсли;
	
КонецПроцедуры

// Функция - Вернуть признак первичного пациента
//
// Параметры:
//  СделкаОбъект - 	 - 
//  ВидСделки	 - 	 - 
//  Контрагент	 - 	 - 
//  ДатаСделки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьПризнакПервичногоПациента(СделкаОбъект 	= Неопределено
										, ВидСделки 	= Неопределено
										, Контрагент 	= Неопределено
										, ДатаСделки 	= Неопределено) Экспорт
	
	ВидСделки 	= ?(СделкаОбъект = Неопределено, ВидСделки	, СделкаОбъект.ВидСделки);
	Контрагент 	= ?(СделкаОбъект = Неопределено, Контрагент	, СделкаОбъект.Контрагент);
	ДатаСделки 	= ?(СделкаОбъект = Неопределено, ?(ЗначениеЗаполнено(ДатаСделки), ДатаСделки, ТекущаяДатаСеанса()), СделкаОбъект.ДатаСделки);
	ДатаСделки 	= ?(НЕ ЗначениеЗаполнено(ДатаСделки) ИЛИ НачалоДня(ДатаСделки) = НачалоДня(ТекущаяДатаСеанса()), ТекущаяДатаСеанса(), ДатаСделки) + (60*60);
	
	СтатусПациента = Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
	Если НЕ ЗначениеЗаполнено(Контрагент) ИЛИ НЕ ЗначениеЗаполнено(ВидСделки) Тогда 
		Возврат СтатусПациента;
	КонецЕсли;
	
	Запрос       = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка"		, ?(СделкаОбъект = Неопределено, Справочники.Сделки.ПустаяСсылка(), СделкаОбъект.Ссылка));		
	Запрос.УстановитьПараметр("ВидСделки"	, ВидСделки);	
	Запрос.УстановитьПараметр("Контрагент"	, Контрагент);
	Запрос.УстановитьПараметр("ДатаСделки"	, ДатаСделки); 
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Продажи.Регистратор) КАК КоличествоПриемов
	|ИЗ
	|	РегистрНакопления.Продажи КАК Продажи
	|ГДЕ
	|	Продажи.Контрагент = &Контрагент
	|	И Продажи.Период < &ДатаСделки
	|	И Продажи.Регистратор ССЫЛКА Документ.Прием
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сделки.Ссылка) КАК КоличествоСделок,
	|	Сделки.ВидСделки КАК ВидСделки
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.ВидСделки = &ВидСделки
	|	И Сделки.Контрагент = &Контрагент
	|	И Сделки.ДатаСделки <= &ДатаСделки
	|	И Сделки.Ссылка <> &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.ВидСделки";
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;		
	
	РезультатПакетногоЗапроса 	= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваПриемов 	= РезультатПакетногоЗапроса[0].Выбрать();
	ВыборкаКоличестваСделок 	= РезультатПакетногоЗапроса[1].Выбрать();
	
	Если ВыборкаКоличестваПриемов.Следующий() Тогда
		СтатусПациента = ?(ВыборкаКоличестваПриемов.КоличествоПриемов > 0, Перечисления.СтатусыКонтрагентов.Постоянный, Перечисления.СтатусыКонтрагентов.Первичный);
		Если СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный И ВыборкаКоличестваСделок.Следующий() Тогда 
			СтатусПациента = ?(ВыборкаКоличестваСделок.КоличествоСделок > 0, Перечисления.СтатусыКонтрагентов.Постоянный, Перечисления.СтатусыКонтрагентов.Первичный);
		КонецЕсли;	
	Иначе
		Если ВыборкаКоличестваСделок.Следующий() Тогда
			СтатусПациента = ?(ВыборкаКоличестваСделок.КоличествоСделок > 0, Перечисления.СтатусыКонтрагентов.Постоянный, Перечисления.СтатусыКонтрагентов.Первичный);
		Иначе 
			СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный;		
		КонецЕсли;	
	КонецЕсли;

	Возврат СтатусПациента;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция, формирует и возвращает наиемнование сделки.
// 
// Возвращаемое значение:
//   Наименование - Строка - Наименование сделки. 
//
Функция СоздатьНаименованиеСделки(Сделка) Экспорт
	
	Возврат СокрЛП(Строка(Сделка.ВидСделки))
				+ " № " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Сделка.Код, "");
				//+ ?(ЗначениеЗаполнено(СокрЛП(Сделка.Примечание)), " (" + СокрЛП(Сделка.Примечание) + ")", "");
	
КонецФункции

// Функция - Инициализировать сокращенное наименование сделки
//
// Параметры:
//  Сделка						 - 	 - 
//  ДобавлятьВрача				 - 	 - 
//  ТолькоЕслиЗаполненПрефикс	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСокращенноеНаименованиеСделки(Сделка
													, ДобавлятьВрача = Ложь
													, ВрачКакПрефикс = Ложь
													, ТолькоЕслиЗаполненПрефикс = Ложь
													, СтруктураНаименованияВида = Неопределено
													, НаименованиеСокращенноеВрача = "") Экспорт
	
	Наименование = "";
	
	Если ТипЗнч(Сделка) = Тип("СправочникОбъект.Сделки") Тогда 
		ВидСделки 		= Сделка.ВидСделки;
		Код 			= Сделка.Код;
		Врач 			= Сделка.Врач;
		Специализация 	= Сделка.Специализация;
	ИначеЕсли ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда
		ДанныеСделки 	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Сделка, "Код, ВидСделки, Врач, НаименованиеСокращенное, Специализация");
		ВидСделки 		= ДанныеСделки.ВидСделки;
		Код 			= ДанныеСделки.Код;
		Врач 			= ДанныеСделки.Врач;
		Специализация 	= ДанныеСделки.Специализация;		
	ИначеЕсли ТипЗнч(Сделка) = Тип("Структура") Тогда 
		ВидСделки 		= ?(Сделка.Свойство("ВидСделки")	, Сделка.ВидСделки		, Неопределено);
		Код 			= ?(Сделка.Свойство("Код")			, Сделка.Код			, Неопределено);
		Врач 			= ?(Сделка.Свойство("Врач")			, Сделка.Врач			, Неопределено);
		Специализация	= ?(Сделка.Свойство("Специализация"), Сделка.Специализация	, Неопределено);		
	Иначе 
		Возврат Наименование;
	КонецЕсли;	
		
	Если ЗначениеЗаполнено(ВидСделки) Тогда
		Если НЕ ЗначениеЗаполнено(СтруктураНаименованияВида) Тогда 
			СтруктураНаименованияВида = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ВидСделки, "Наименование, Префикс");
		КонецЕсли;	
		Если ТолькоЕслиЗаполненПрефикс И НЕ ЗначениеЗаполнено(СтруктураНаименованияВида.Префикс) И НЕ ТипЗнч(Сделка) = Тип("СправочникОбъект.Сделки") Тогда
			Возврат "";
		КонецЕсли;	
		Если НЕ ЗначениеЗаполнено(СтруктураНаименованияВида.Префикс) Тогда
			СтруктураНаименованияВида.Префикс = Справочники.ВидыСделок.ПолучитьПрефиксВоронкиПоНаименованию(СтруктураНаименованияВида.Наименование);
		КонецЕсли;
		Наименование = СтруктураНаименованияВида.Префикс + ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(Код, Истина, Истина);
		Если ДобавлятьВрача Тогда 
			Если ЗначениеЗаполнено(Врач) Тогда
				Если НЕ ЗначениеЗаполнено(СокрЛП(НаименованиеСокращенноеВрача)) Тогда 
					НаименованиеСокращенноеВрача = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Врач, "НаименованиеСокращенное");
				КонецЕсли;	
				Если НЕ ЗначениеЗаполнено(НаименованиеСокращенноеВрача) Тогда 
					НаименованиеСокращенноеВрача = Справочники.Сотрудники.ПолучитьСокращенноеНаименованиеСотрудника(, Врач);	
				КонецЕсли;
			ИначеЕсли ЗначениеЗаполнено(Специализация) Тогда
				НаименованиеСокращенноеВрача = СокрЛП(Строка(Специализация));
			КонецЕсли;
			Если ЗначениеЗаполнено(СокрЛП(НаименованиеСокращенноеВрача)) Тогда
				Если ВрачКакПрефикс Тогда 
					Наименование = СокрЛП(НаименованиеСокращенноеВрача) + " " + Наименование;
				Иначе 	
					Наименование = Наименование + " " + СокрЛП(НаименованиеСокращенноеВрача);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Наименование;
	
КонецФункции

// Процедура - Конвертация сделок новый пациент
//
// Параметры:
//  ИнициализироватьВидСделки	 - 	 - 
//
Процедура КонвертацияСделокНовыйПациент(ИнициализироватьВидСделки = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	

	ВидСделок__НовыеПациенты = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	Если НЕ ЗначениеЗаполнено(ВидСделок__НовыеПациенты) ИЛИ ИнициализироватьВидСделки Тогда 
		Справочники.ВидыСделок.ИнициализироватьПредопределенныйВид_ПервичныйПовторныйПациент(ВидСделок__НовыеПациенты);
	КонецЕсли;	
	
	ПричинаОтказа_КлиентНеПришел 	= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентНеПришел");
    ПричинаОтказа_КлиентОтказался 	= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался");
	
	Если ЗначениеЗаполнено(ВидСделок__НовыеПациенты) Тогда 
		Этап1 = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделок__НовыеПациенты, 1);
		Этап2 = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделок__НовыеПациенты, 2);
		Этап3 = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделок__НовыеПациенты, 3);
		Этап4 = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ВидСделок__НовыеПациенты, 4);
	Иначе 
		Возврат;
	КонецЕсли;
	
	МассивЭтапов = Новый Массив;
	ТаблицаЭтапов = ПолучитьРанееСозданныеЭтапы(ВидСделок__НовыеПациенты);
	МассивСтрок = ТаблицаЭтапов.НайтиСтроки(Новый Структура("НомерЭтапа", 2));
	Для Каждого СтрокаМассива Из МассивСтрок Цикл 
		МассивЭтапов.Добавить(СтрокаМассива.Этап);
	КонецЦикла;	
	МассивСтрок = ТаблицаЭтапов.НайтиСтроки(Новый Структура("НомерЭтапа", 4));
	Для Каждого СтрокаМассива Из МассивСтрок Цикл 
		МассивЭтапов.Добавить(СтрокаМассива.Этап);
	КонецЦикла;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВидСделки"	, ВидСделок__НовыеПациенты);
	Запрос.УстановитьПараметр("МассивЭтапов", МассивЭтапов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.Наименование КАК Наименование,
	|	Сделки.ПометкаУдаления КАК ПометкаУдаления,
	|	Сделки.ДатаСделки КАК ДатаСделки,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.Врач КАК Врач,
	|	Сделки.ПричинаОтказа КАК ПричинаОтказа,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.ЭтапОтказа КАК ЭтапОтказа,
	|	Сделки.ЭтапОтказа.НомерЭтапа КАК ЭтапОтказаНомерЭтапа,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
