&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере" формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("СтруктурнаяЕдиница") Тогда 
		Объект.СтруктурнаяЕдиница = Параметры.СтруктурнаяЕдиница;
	КонецЕсли;
	
	Если  Параметры.Свойство("МассивИндексовСотрудников") Тогда 
		Индекс = 0;
		Для Каждого Идентификатор Из Параметры.МассивИндексовСотрудников Цикл
			СтрокаТЧ = ТаблицаСотрудники.Добавить();
			СтрокаТЧ.Идентификатор = Идентификатор;
			СтрокаТЧ.Сотрудник = Параметры.МассивСотрудников[Индекс];
			Индекс = Индекс + 1;
		КонецЦикла;
	КонецЕсли;
	
	Если Параметры.Свойство("Период") Тогда 
		Если ЗначениеЗаполнено(Параметры.Период) Тогда
			ДатаНачала = ?(НачалоМесяца(Параметры.Период) < ТекущаяДата(), ТекущаяДата(), НачалоМесяца(Параметры.Период)) ;
			ДатаОкончания = КонецМесяца(Параметры.Период);
		КонецЕсли;
		Объект.Период = Параметры.Период;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПериодыРаботы.НачалоСмены КАК НачалоСмены,
	|	ПериодыРаботы.ОкончаниеСмены КАК ОкончаниеСмены,
	|	ПериодыРаботы.Ссылка КАК Наименование,
	|	0 КАК ИндексКартинки
	|ИЗ
	|	Справочник.ПериодыРаботы КАК ПериодыРаботы
	|ГДЕ
	|	(НЕ ПериодыРаботы.ПометкаУдаления)
	|	И ПериодыРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	НачалоСмены,
	|	ОкончаниеСмены УБЫВ";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	
	ПериодыРаботы.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Элементы.ДобавитьПериод.Доступность = (ПериодыРаботы.Количество() > 0);
	
КонецПроцедуры

#КонецОбласти

