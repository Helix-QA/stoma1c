// Процедура, создает строку элементов расшифровки платежа.
//
Процедура СоздатьСтрокуЭлементовРасшифровки(Индекс)
	
	ВидыОпераций = Перечисления.ВидыОпераций;
	
	ИмяТЧ = "";
	Если Объект.ВидОперации = ВидыОпераций.ПрочееСписание Тогда
		ИмяТЧ = "Затраты";
	Иначе
		ИмяТЧ = "РасшифровкаПлатежа"
	КонецЕсли;	
	
	ИспользоватьАвансы = Константы.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Получить() И Объект.ВидОперации = ВидыОпераций.ВозвратОплатыКлиенту;
	
	ГруппаНовыхЭл                         = Элементы.Добавить("Строка" + ИмяТЧ + "_" + Индекс, Тип("ГруппаФормы"), Элементы["ГруппаСтроки" + ИмяТЧ]);
	ГруппаНовыхЭл.Вид                     = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНовыхЭл.Группировка             = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	ГруппаНовыхЭл.Отображение             = ОтображениеОбычнойГруппы.Нет;
	ГруппаНовыхЭл.Ширина				  = 114;
	ГруппаНовыхЭл.ОтображатьЗаголовок     = Ложь;
	ГруппаНовыхЭл.РастягиватьПоГоризонтали = Неопределено; // Неопределено
	
	ДекорацияНомерСтроки				  = Элементы.Добавить(ИмяТЧ + "ДекорацияНомер_" + Индекс, Тип("ДекорацияФормы"), ГруппаНовыхЭл);
	ДекорацияНомерСтроки.Заголовок        = Индекс + 1;
	ДекорацияНомерСтроки.Ширина			  = 2;  	
	
	Если ИмяТЧ = "Затраты" Тогда
	
		ПолеСтатья					 		 	= Элементы.Добавить(ИмяТЧ + "Статья_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
		ПолеСтатья.Вид				 		 	= ВидПоляФормы.ПолеВвода;
		ПолеСтатья.ПутьКДанным		 		 	= "Объект." + ИмяТЧ + "[" + Индекс +"].СтатьяЗатрат";
		ПолеСтатья.РастягиватьПоГоризонтали		= Неопределено;
		ПолеСтатья.АвтоМаксимальнаяШирина   	= Ложь;
