&НаКлиенте
// Процедура обработчик события "ПриОткрытии" формы
//
Процедура ПриОткрытии(Отказ)
	
	HTMLДокументОбследованиеБлокироватьСобытиеСформирован = Ложь;
	
	// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		ПоддерживаемыеТипыВО.Добавить("СчитывательМагнитныхКарт");		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования 
		
	// Обновить зубную формулу 
	ОбновитьДокумент();
	// Обновить подбор в зубной формуле
	ОбновитьSVGПодбор();	
	
	Если ЗначениеЗаполнено(Объект.Контрагент) И Не Объект.Ссылка.Пустая() Тогда
		// Подключить обработчик проверки напоминания
		ПодключитьОбработчикОжидания("ПроверитьТекущиеНапоминанияПоКлиентуОбработчикТаймера", 5, Истина);  
	КонецЕсли;

	// Подключить обработчик вызова фомы подбора услуг документа аванса
	Если ЗначениеЗаполнено(ОснованиеЗаполнения) Тогда
		 ПодключитьОбработчикОжидания("ОткрытьФормуПодбораУслугДокументаАванса", 1, Истина);
	КонецЕсли;
	   
	Если Объект.Ссылка.Пустая() Тогда 	
		Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
			ПодключитьОбработчикОжидания("ПроверитьТекущиеНапоминанияПоКлиентуОбработчикТаймера", 5, Истина);		
		ИначеЕсли НЕ ЗначениеЗаполнено(Объект.ДокументОснование) Тогда  
			ЭтаФорма.ТекущийЭлемент = Элементы.Контрагент;
		Иначе 
			ЭтаФорма.Модифицированность = Истина;	
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Контрагент) И ИнформированияПоДнюРожденияКонтрагента.Информировать Тогда
		ПоказатьПредупреждение(, ИнформированияПоДнюРожденияКонтрагента.СообщениеИнформирования, 15, "Информирование о дне рождения клиента");
	КонецЕсли;
		
	Элементы.ТаблицаЛечение.Ширина		= ?(Элементы._ПодборНоменклатурУслуги.Видимость, 0, 151);
	Элементы.УслугиПодборЗубов.Ширина	= ?(Элементы._ПодборНоменклатурУслуги.Видимость, 1, 150);
	Элементы.ТаблицаТовары.Ширина		= ?(Элементы._ПодборНоменклатур.Видимость, 0, 151);
	
	// Установим сортировку подборов по полю из настроек.	
	ИзменитьСортировкуПодбора(ЭтотОбъект._ПодборНоменклатур, ЭтотОбъект.ПолеСортировкиЗапасов, "Возр");
	ИзменитьСортировкуПодбора(ЭтотОбъект._ПодборНоменклатурУслуги, ЭтотОбъект.ПолеСортировкиУслуг, "Возр");
	
	// Временные реквизиты результата лечения.
	ФормаРезультатПриема 		    = Объект.РезультатПриема;
	ФормаПрофосмотрИспользовать     = Объект.ПрофосмотрИспользовать;
	ФормаПрофосмотрИнтервал 	    = Объект.ПрофосмотрИнтервал;
	ФормаПовторныйПриемИспользовать = Объект.ПовторныйПриемИспользовать;
	ФормаПовторныйПриемИнтервал     = Объект.ПовторныйПриемИнтервал; 
	ФормаИнтервалПередПриемом       = Объект.ИнтервалПередПриемом;

	// Настройка группы результата лечения.
	НастройкаГруппыРезультатаСервер();

	ОформлениеКнопокПриема();
	
КонецПроцедуры

&НаКлиенте
// Перед записью данных на клиенте
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи <> Неопределено И ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
		// Если Объект.Проведен И ЗначениеЗаполнено(Объект.РезультатПриема) Тогда 
		
		СотрудникИЭМК  = Объект.Сотрудник;
		КонтрагентИЭМК = Объект.Контрагент;
		ЛечениеИЭМК    = Объект.Лечение;
		РезультатПроверкиИЭМК = ИнтеграцияИЭМК.ПроверитьВСИЭМК(СотрудникИЭМК, КонтрагентИЭМК, ЛечениеИЭМК); 
		
		Если ЗначениеЗаполнено(РезультатПроверкиИЭМК) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСтоматология.ПроверкаИЭМК(РезультатПроверкиИЭМК, Объект);
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Объект.РезультатПриема) Тогда 
			Если Элементы.ГруппаРезультатЛечения.Скрыта() Тогда 
				Элементы.ГруппаРезультатЛечения.Показать();
			КонецЕсли;	
			Отказ = Истина;
			Возврат;
		КонецЕсли; 	
		
	КонецЕсли;	
	
	Результат = ПередЗаписьюПроверкаСтатусовНоменклатуры();
	
	Если Не Результат Тогда
		
		Отказ = Истина;
				
	КонецЕсли;	
	
	Если Объект.РезультатПриема <> 0 И Отказ = Ложь И Не ЗначениеЗаполнено(Объект.ВремяОкончанияПриема) Тогда
		Объект.ВремяОкончанияПриема = ОбщегоНазначенияКлиент.ДатаСеанса();
	КонецЕсли;
		
КонецПроцедуры 

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере"
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// перенесено в модуль объекта.
	// Для Каждого СтрокаЗапасы из Объект.Запасы Цикл				
	//	Если СтрокаЗапасы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
	//	   И СтрокаЗапасы.Номенклатура.ИспользоватьПартии
	//	   И СтрокаЗапасы.Партия.Пустая() Тогда	
	//	   
	//	   Отказ = Истина;
	//	   Сообщить("В строке № " + СтрокаЗапасы.НомерСтроки + " табличной части " + """" + "Запасы" + """" + " не заполнено поле " + """"+ "Характеристика, серия" + """");
	//	КонецЕсли; 		
	// КонецЦикла;
	
	//Если ДОДокументИзменен Тогда
	ТекущийОбъект.ПроцентЗаполненияОбследования = ПолучитьПроцентЗаполненияДокументаОбследование();
	//КонецЕсли; 
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ТаблицаУдаленныхСтрок", ТаблицаУдаленныхСтрок);
	
	Если НЕ ЗначениеЗаполнено(ТекущийОбъект.Сделка) Тогда 
		ТекущийОбъект.Сделка = ЭтаФорма.ТекущаяСделка;
	КонецЕсли;
	
	// Прокидываем вид и этап генериуемой сделки
	Если ТекущийОбъект.Ссылка.Пустая() И НЕ ЗначениеЗаполнено(ТекущийОбъект.Сделка) Тогда 
		МассивВыбранныхДляГенерации = ТаблицаДоступныхВидовСделок.НайтиСтроки(Новый Структура("Выбран", Истина));
		Если МассивВыбранныхДляГенерации.Количество() > 0 Тогда 
			Если ЗначениеЗаполнено(МассивВыбранныхДляГенерации[0].ВидСделки) Тогда 
				ТекущийОбъект.ДополнительныеСвойства.Вставить("ВидСделкиГенерации", МассивВыбранныхДляГенерации[0].ВидСделки);
				МассивВыбранныхЭтапов = МассивВыбранныхДляГенерации[0].ТаблицаЭтапов.НайтиСтроки(Новый Структура("Выбран", Истина));
				Если МассивВыбранныхЭтапов.Количество() > 0 Тогда 
					Если ЗначениеЗаполнено(МассивВыбранныхЭтапов[0].Этап) Тогда 
						ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтапСделкиГенерации", МассивВыбранныхЭтапов[0].Этап);
					КонецЕсли;	
				ИначеЕсли МассивВыбранныхДляГенерации[0].ТаблицаЭтапов.Количество() > 0 Тогда 
					ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтапСделкиГенерации", МассивВыбранныхДляГенерации[0].ТаблицаЭтапов[0].Этап);
				Иначе 	
					ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтапСделкиГенерации", Неопределено);
				КонецЕсли;
				ТекущийОбъект.ДополнительныеСвойства.Вставить("ОбновитьВиджетСделки", Истина);
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда
	 
		// Сохраняем список временых реквизитов - Лечение
		ВременноХранениеВиртуальныхРкЛечение = Объект.Лечение.Выгрузить(,"
		|КлючСтроки,
		|НомерСтроки, 
		|СтатусСогласования,
		|ДатаОтправки,
		|ДатаСогласования,
		|Согласователь,
		|ТребуетсяСогласование,
		|КомментарийСогласования"); 
		
		// Восстановить значение виртуальных реквизитов - Лечение
		Для А = 0 По ВременноХранениеВиртуальныхРкЛечение.Количество() - 1 Цикл 
			
			СтрокаЛечения = Объект.Лечение[А];
			ЗаполнитьЗначенияСвойств(СтрокаЛечения, ВременноХранениеВиртуальныхРкЛечение[А]);
			
			Если ЗначениеЗаполнено(СтрокаЛечения.СтатусСогласования) Тогда
				ВременноХранениеВиртуальныхРкЛечение[А].ДатаОтправки = ?(ЗначениеЗаполнено(СтрокаЛечения.ДатаОтправки), СтрокаЛечения.ДатаОтправки, ТекущаяДатаСеанса());			
			КонецЕсли;
			
		КонецЦикла;
		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ТаблицаСогласованийУслуг", ВременноХранениеВиртуальныхРкЛечение);
		
	КонецЕсли; 

	Если ЭтаФорма.Модифицированность = Истина И ЗначениеЗаполнено(ФормаРезультатПриема) Тогда 
		Если ФормаРезультатПриема = 1 Тогда 
			ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр;
		Иначе 
			ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием;			
		КонецЕсли;
		НСтрока = НаправленияНаКонсультацию.НайтиСтроки(Новый Структура("ВидОсмотра", ВидОсмотра));
		Если Не ЗначениеЗаполнено(НСтрока) Тогда 
			ДобавитьСтрокуВНаправленияНаКонсультацию(ВидОсмотра);
		КонецЕсли;
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НаправленияНаКонсультацию", ЭтотОбъект.НаправленияНаКонсультацию);
	КонецЕсли;	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);
		Если ЗначениеЗаполнено(ВнешняяСистема) И ТекущийОбъект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
			Если ДОЗначенияРеквизитовОбследования.НайтиСтроки(Новый Структура("Реквизит", ПланыВидовХарактеристик.ПараметрыОбследований.Диагноз)).Количество() = 0 Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("ИЭМК: У пациента не заполнен диагноз.");		
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	
	Если ЭтотОбъект.ДокументРазблокированПослеОплаты И ЭтаФорма.Модифицированность = Истина Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ИзмененПослеОплаты", Истина);
	КонецЕсли;
		
КонецПроцедуры

