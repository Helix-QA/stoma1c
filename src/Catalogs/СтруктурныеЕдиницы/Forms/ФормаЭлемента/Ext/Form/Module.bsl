&НаСервере
// Получает все подчиненные файлы.
//
// Параметры:
//   ВладелецФайла - ЛюбаяСсылка - владелец файла.
//
// Возвращаемое значение:
//   Массив из СправочникСсылка.Файлы - массив файлов.
//
Функция ПолучитьВсеПодчиненныеФайлы(ВладелецФайла, Описание)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Файлы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Файлы КАК Файлы
	|ГДЕ
	|	Файлы.ВладелецФайла = &ВладелецФайла
	|	И НЕ Файлы.ПометкаУдаления
	|	И (ВЫРАЗИТЬ(Файлы.Описание КАК СТРОКА(100))) = &Описание");
	
	Запрос.УстановитьПараметр("ВладелецФайла", ВладелецФайла);
	Запрос.УстановитьПараметр("Описание"     , Описание);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Функция, вернет индекс имени элемента.
//
Функция ПолучитьИндексИмениЭлемента(Наименование)
	
	НомерСимвола = СтрНайти(Наименование, "_");
	Возврат ?(НомерСимвола > 0, Число(Прав(Наименование, СтрДлина(Наименование) - НомерСимвола)), Неопределено);
	
КонецФункции

// Процедура - Удалить картинку
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура УдалитьКартинку(Команда)
	
	Индекс = ПолучитьИндексИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
	
	Если Индекс = 7 Тогда
		МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(Объект.Ссылка, "ЛоготипМагазина");
		ФайлКартинки		 = ?(МассивФайловКартинок.Количество() > 0, МассивФайловКартинок[0], Неопределено);
	Иначе
		ФайлКартинки = ЭтотОбъект.ФайлыКартинок.Получить(Индекс - 1).Значение;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ФайлКартинки) Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ВопросОбУдаленииКартинкиЗавершение", ЭтотОбъект, ФайлКартинки);
	ПоказатьВопрос(Оповещение, "Вы действительно хотите удалить картинку?", РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

