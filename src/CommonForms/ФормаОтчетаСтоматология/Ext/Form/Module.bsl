// Функция группирует таблицу остатков
//
Функция ПодготовимТаблицуЗапасов(ТаблицаКритическихОстатков)
	
	Если ТаблицаКритическихОстатков.Колонки.Найти("Номенклатура") <> Неопределено Тогда
		ТаблицаКритическихОстатков.Свернуть("Номенклатура", "Обеспечение, КоличествоУпаковокОбеспечения");		
		ТаблицаКритическихОстатков.Колонки.Добавить("Упаковка", 	Новый ОписаниеТипов("СправочникСсылка.УпаковкиНоменклатуры"));  // упаковка по умолчанию
		ТаблицаКритическихОстатков.Колонки.Добавить("СтавкаНДС", 	Новый ОписаниеТипов("ПеречислениеСсылка.СтавкиНДС"));
		Для Каждого СтрокаТаблицы Из ТаблицаКритическихОстатков Цикл 
			Если ЗначениеЗаполнено(СтрокаТаблицы.Номенклатура) и НЕ СтрокаТаблицы.Номенклатура.ЭтоГруппа Тогда
				СтрокаТаблицы.Упаковка 						= СтрокаТаблицы.Номенклатура.УпаковкаПоУмолчанию;
				СтрокаТаблицы.КоличествоУпаковокОбеспечения = ?(СтрокаТаблицы.Номенклатура.УпаковкаПоУмолчанию.Коэффициент = 0, СтрокаТаблицы.Обеспечение / 1, СтрокаТаблицы.Обеспечение / СтрокаТаблицы.Номенклатура.УпаковкаПоУмолчанию.Коэффициент);
				СтрокаТаблицы.СтавкаНДС 					= СтрокаТаблицы.Номенклатура.СтавкаНДС;
			КонецЕсли;			
		КонецЦикла;
		
		Возврат ТаблицаКритическихОстатков;
	КонецЕсли;
	
КонецФункции

