// Процедура, обработчик события "ПриИзменении"
//
Процедура РасходыНоменклатураПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Услуги.ТекущиеДанные;	
	
	// Проверка на статус "в продаже".
	ВПродаже = ПолучитьСтатусНоменклатуры(СтрокаТабличнойЧасти.Номенклатура, Объект.СтруктурнаяЕдиница, Объект.Дата);
	Если НЕ ВПродаже Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Номенклатура %1 снята с продаж!"), СтрокаТабличнойЧасти.Номенклатура);
		СтрокаТабличнойЧасти.Номенклатура = Неопределено;
		Возврат;
		
	КонецЕсли;	
		
	Если ПроверитьПрименениеВидовНалов(СтрокаТабличнойЧасти.Номенклатура) Тогда
		 СтрокаТабличнойЧасти.Номенклатура = Неопределено;
		 Возврат;
	КонецЕсли;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
	СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);	
		
	СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	СтрокаТабличнойЧасти.Упаковка = СтруктураДанные.Упаковка;
	Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.КоличествоУпаковок) Тогда
		СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
	КонецЕсли;
	
	ИдентификаторыНовойСтроки = СтрокаТабличнойЧасти.ПолучитьИдентификатор();
	
    ЗаполнитьРеквизитыСтрокиТаблицыУслугиПриИзмененииНоменклатурыНаСервере(ИдентификаторыНовойСтроки);
		
	Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
		СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);		
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыСтрокиТаблицыУслугиПриИзмененииНоменклатурыНаСервере(ИдентификаторыНовойСтроки)
	
	СтрокаТабличнойЧасти = Объект.Услуги.НайтиПоИдентификатору(ИдентификаторыНовойСтроки);
	
	Если ЗначениеЗаполнено(Объект.Сотрудник) Тогда
		
		Объект.ВидЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаПоПути(Объект.СтруктурнаяЕдиница, "ВидЦенРеализации");
		ПеремВидЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Объект.Сотрудник, Объект.СтруктурнаяЕдиница , "ВидЦен");
		Если ПеремВидЦен.Пустая() Тогда
			СтрокаТабличнойЧасти.ВидЦен = Объект.ВидЦен;
		Иначе
			СтрокаТабличнойЧасти.ВидЦен = ПеремВидЦен;
			Объект.ВидЦен = ПеремВидЦен;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
		СтрокаТабличнойЧасти.СкидкиЗапрещены = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "СкидкиЗапрещены");	
		
		Если СтрокаТабличнойЧасти.СкидкиЗапрещены = Истина Тогда
			СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
			СтрокаТабличнойЧасти.СуммаРучнойСкидки = 0;
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

