&НаКлиенте
// Обработчик события ОбработкаРасшифровки элемента ТабличныйДокумент.
//
Процедура ИнформацияПоклиентуОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)
	
	// Клик по пиктограмме печати документа
	Если ТипЗнч(Расшифровка)=Тип("Строка") И Расшифровка = "ПечатьОтчета" Тогда
		СтандартнаяОбработка = Ложь;
		ИнформацияКлиента.Напечатать(РежимИспользованияДиалогаПечати.Использовать);
	КонецЕсли;
		
	// Клик по пиктограмме ПерейтиВзаиморасчеты
	Если  ТипЗнч(Расшифровка)=Тип("Структура") И Расшифровка.Свойство("ОткрытьВзаиморасчетыКонтрагента") Тогда
		СтандартнаяОбработка=Ложь;
		ПараметрыФормы = Новый Структура("Контрагент", Расшифровка.ОткрытьВзаиморасчетыКонтрагента);
		ОткрытьФорму("Отчет.ВзаиморасчетыПодробно.Форма.ФормаОтчета", ПараметрыФормы);
	КонецЕсли;
	
	// Клик по "Акт по выполненным работам"
	Если ТипЗнч(Расшифровка)=Тип("Структура") И Расшифровка.Свойство("Контрагент") Тогда
		СтандартнаяОбработка=Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент", Расшифровка.Контрагент);
		ОткрытьФорму("Отчет.ВзаиморасчетыПодробно.Форма.ФормаОтчета", ПараметрыФормы);
	КонецЕсли;
	
	// Клик по "Печать талона"
	Если ТипЗнч(Расшифровка)= Тип("Структура") И Расшифровка.Свойство("ОткрытьПечатьТалона") Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("Контрагент", Расшифровка.ОткрытьПечатьТалона);
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
		"Обработка.РабочийКалендарь",
		"МакетПечатьТалона",
		ПараметрыКоманды,
		Неопределено,
		Неопределено
		);
	КонецЕсли;
	
	// Если ТипЗнч(Расшифровка) = Тип("Структура") И Расшифровка.Свойство("СсылкаНаEmail") Тогда
	//	СтандартнаяОбработка   = Ложь;
	//	Расшифровка            = ИнформацияКлиента.ТекущаяОбласть.Расшифровка;			
	//	ПараметрыПисьма        = Новый Структура;
	//	ПараметрыПисьма.Вставить("Кому", Расшифровка.СсылкаНаEmail);	
	//	ОткрытьФорму("ОбщаяФорма.РедактированиеНовогоПисьма", ПараметрыПисьма);		
	Если ТипЗнч(Расшифровка) = Тип("Структура") И Расшифровка.Свойство("СсылкаНаЗапись") Тогда			
		СтандартнаяОбработка = Ложь;
		Параметр             = Новый Структура("Ключ", Расшифровка.СсылкаНаЗапись);
		Форма                = ПолучитьФорму("Документ.Событие.ФормаОбъекта", Параметр);
		Форма.Открыть();	
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("Структура") И Расшифровка.Свойство("ДеньКалендаря") Тогда			
		СтандартнаяОбработка = Ложь;
		Объект.Дата          = НачалоДня(Расшифровка.ДеньКалендаря);
		ПЗГрафикаРежимОтображения = 0;
		ОбновитьТаблицуСотрудников();
		ОбщегоНазначенияКлиентСтоматология.РазвернутьДерево(Элементы.ДеревоСотрудников, ДеревоСотрудниковРучн);
	КонецЕсли;
	
	// Обработка создания документа писание задолженности
	Если ТипЗнч(Расшифровка) = Тип("Структура") И Расшифровка.Свойство("ОткрытьСписаниеДолга") Тогда
		СтандартнаяОбработка=Ложь;
		ПараметрыФормы = Новый Структура("Основание", Расшифровка.ДокументСсылка);
		ОткрытьФорму("Документ.СписаниеЗадолженности.ФормаОбъекта", ПараметрыФормы);
	КонецЕсли;
	
КонецПроцедуры	

////////////////////////////// ОБРАБОТЧИКИ ЛЕВОЙ ПАНЕЛИ "ОБСЛУЖИВАЕМЫЕ КЛИЕНТЫ"/////////////////////////

