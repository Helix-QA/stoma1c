&НаКлиенте
// Процедура - Редактировать цены завершение
//
// Параметры:
//  СтруктураЦены			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура РедактироватьЦеныЗавершение(СтруктураЦены, ДополнительныеПараметры) Экспорт
	
	// 3. Перезаполняем табличную часть "Запасы" если были внесены изменения в форме "Цены и Валюта".
	Если ТипЗнч(СтруктураЦены) = Тип("Структура") И СтруктураЦены.БылиВнесеныИзменения Тогда
		
		Объект.ВидЦен = СтруктураЦены.ВидЦен;
		
		// Пересчитываем цены по виду цен.					
		Если СтруктураЦены.ПерезаполнитьЦены Тогда			
			ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Лечение");		
		КонецЕсли;
		
	КонецЕсли;
	
	// Сформируем надпись цены и валюты.
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);
	Элементы.ЦеныИВалютаНадпись.Заголовок = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи);

КонецПроцедуры

&НаСервере
// Функция обрабатывает код карты, полученный от внешнего оборудования
//
Функция ПолученКодКарты(КодКарты, ДанныеДорожек)
	
	Если ТипЗнч(ДанныеДорожек) = Тип("Массив")
		И ДанныеДорожек.Количество() > 1
		И ДанныеДорожек[1] <> Неопределено
		И Не ПустаяСтрока(ДанныеДорожек[1]) Тогда
		ДанныеКарты = ДанныеДорожек[1];
		
		ДанныеПоКарте = Справочники.Карты.ПолучитьДанныеМагнитнойКарты(ДанныеКарты);
		Если ДанныеПоКарте <> Неопределено Тогда
			Объект.Контрагент       = ДанныеПоКарте.ВладелецКарты;
			Объект.КартаКонтрагента = ДанныеПоКарте;			
			Возврат Истина;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Карта клиента со штриховым кодом "+ДанныеКарты+" не найдена");
			Возврат Ложь;
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Указана неверная карта или произошла ошибка при считывании карты.
		|Повторите считывание или считайте другую карту'"));
		Возврат Ложь;
	КонецЕсли;
	
	// Возврат Истина;
	
КонецФункции

&НаКлиенте
// При начале выбора сотрудника
Процедура СотрудникНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)	
	
	СтандартнаяОбработка = Ложь;
	ДатаДокумента = ?(Объект.Дата = Дата(1,1,1), ТекущаяДата(), Объект.Дата); 
	мПараметрыВыбора = Новый Структура;
	мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	мПараметрыВыбора.Вставить("ТекущаяСтрока"     , Объект.Сотрудник);
	мПараметрыВыбора.Вставить("ОтбиратьВрачей"    , Истина);
	мПараметрыВыбора.Вставить("ДатаДокумента"     , ДатаДокумента);
	
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", мПараметрыВыбора,,,,, 
					Новый ОписаниеОповещения("СотрудникНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
