&НаСервере
// Процедура изменияет статус документу "Событие" на указанный.
//
Процедура ИзменитьСтатусСобытия(Событие, СтатусСобытия, Интервал)	
	
	// ОбъектСобытие        = Событие.ПолучитьОбъект();
	// Если НЕ СтатусСобытия = Неопределено Тогда 
	//	ОбъектСобытие.Статус = СтатусСобытия;
	// КонецЕсли;	
	// Если Подтверждена Тогда 
	//	ОбъектСобытие.ТелефонныйЗвонок = НЕ ОбъектСобытие.ТелефонныйЗвонок;
	// КонецЕсли;	
	// ОбъектСобытие.Записать(РежимЗаписиДокумента.Проведение);
	
	ОбъектСобытие = Событие.ПолучитьОбъект();
	
	СобытиеЗакрыто = 	Событие.Статус = Перечисления.СтатусыСобытия.ПриемОкончен
	ИЛИ Событие.Статус = Перечисления.СтатусыСобытия.ПриемОтменен 
	ИЛИ Событие.Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся;
	
	Если НЕ СтатусСобытия = Неопределено Тогда
		
		Если СобытиеЗакрыто И ОбъектСобытие.Статус <> СтатусСобытия Тогда
			// И НЕ (СтатусСобытия = Перечисления.СтатусыСобытия.НеПодтверждена
			//		ИЛИ СтатусСобытия = Перечисления.СтатусыСобытия.Подтверждена) Тогда
			
			ОбъектСобытие.Статус = СтатусСобытия;
		ИначеЕсли НЕ СобытиеЗакрыто Тогда
			ОбъектСобытие.Статус = СтатусСобытия;
		КонецЕсли;
		
	КонецЕсли;  
	
	Если СтатусСобытия = Перечисления.СтатусыСобытия.НеПодтверждена Тогда 
		ОбъектСобытие.ТелефонныйЗвонок = Ложь;
	ИначеЕсли СтатусСобытия = Перечисления.СтатусыСобытия.Подтверждена  Тогда
		ОбъектСобытие.ТелефонныйЗвонок = Истина;
	КонецЕсли;    
			
	Попытка
		ОбъектСобытие.Записать(РежимЗаписиДокумента.Проведение);	
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки; 
		
	Если СтатусСобытия = Перечисления.СтатусыСобытия.ПациентОжидает Тогда 
		
		ДанныеСобытия = Документы.Событие.ПолучитьПродолжительностьСобытия(ОбъектСобытие.Ссылка);		
		Пациент  = ?(ДанныеСобытия.Свойство("Контрагент"), ДанныеСобытия.Контрагент, Неопределено);		
		
		Если ЗначениеЗаполнено(Пациент) Тогда 
			// Получаем события +/- 1 час. 236529.
			МассивСобытий = Документы.Событие.ВернутьСобытияЗаУказанныйПериод(
								ДанныеСобытия.ДатаНачала - 3600,
								ДанныеСобытия.ДатаОкончания + 3600, 
								ОбъектСобытие.СтруктурнаяЕдиница,,,
								ОбъектСобытие.Ссылка,
								Перечисления.СтатусыСобытия.Подтверждена, 
								Пациент).ВыгрузитьКолонку("Событие");
			
			Документы.Событие.ИзменитьСтатусПредварительныхЗаписейВПланировщике(МассивСобытий, СтатусСобытия);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 
	
