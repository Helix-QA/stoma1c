
#Область ОбработчикиСобытийФормы

&НаКлиенте
// Обработчик внешних оповещений формы 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИЗМЕНЕН_СТАТУС_РЕГИСТРАЦИОННОЙ_АНКЕТЫ" Тогда
		ОбновитьСостояниеЭлементовФормы();
	КонецЕсли;		
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Обновить состояние элементов формы
//
Процедура ОбновитьСостояниеЭлементовФормы()
	ДанныеАнкеты = ПолучитьДанныеРегАнкеты();
	Если ДанныеАнкеты <> Неопределено Тогда
		ДанныеАнкеты.Свойство("АнкетаСтатус"                 ,РегистрацияПродуктаСтатус);
		ДанныеАнкеты.Свойство("АнкетаСостояниеПоддержки"     ,РегистрацияПродуктаСостояниеПоддержки);
		ДанныеАнкеты.Свойство("АнкетаДатаОкончанияПоддержки" ,РегистрацияПродуктаДатаОкончанияПоддержки);
		Элементы.ДекорацияРегистрацияПрограммногоПродукта.Заголовок = "Открыть анкету";
		Если ДанныеАнкеты.АнкетаПодтверждена = Ложь Тогда
			Элементы.РегистрацияПродуктаСтатус.ЦветТекста = WebЦвета.Красный;
		Иначе
			Элементы.РегистрацияПродуктаСтатус.ЦветТекста = WebЦвета.ТемноЗеленый;
		КонецЕсли;
	Иначе
		РегистрацияПродуктаСтатус                                   = "Не зарегистрирован.";
		РегистрацияПродуктаСостояниеПоддержки                       = "Техническая поддержка недоступна.";
		Элементы.ДекорацияРегистрацияПрограммногоПродукта.Заголовок = "Зарегистрировать сейчас";
		Элементы.РегистрацияПродуктаСтатус.ЦветТекста               = WebЦвета.Красный;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезконтекста
// Получить данные рег. анкеты 
//
Функция ПолучитьДанныеРегАнкеты()
	Возврат Обработки.РегистрацияПрограммногоПродукта.ПолучитьДанныеРегистрационнойАнкеты();
КонецФункции

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик события "ТелеграмБот"
//
Процедура ТелеграмБот(Команда)
	ЗапуститьПриложение("https://t.me/stoma1c_support_bot");
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "УсловияОказанияТехническойПоддержки"
//
Процедура УсловияОказанияТехническойПоддержки(Команда)
	     	
	ФормаТехПоддержка = ПолучитьФорму("ОбщаяФорма.ФормаУсловияОказанияТехническойПоддержки", );
	ФормаТехПоддержка.Открыть();
	     	
КонецПроцедуры

&НаКлиенте
Процедура РегистрацияПродуктаОбновить(Команда)
	РегистрацияПродуктаОбновитьНаСервере();
КонецПроцедуры

 #КонецОбласти

&НаСервере
Процедура РегистрацияПродуктаОбновитьНаСервере()
	Обработки.РегистрацияПрограммногоПродукта.ОбновитьДанныеАнкетыПродуктаСВебСервиса();
	ОбновитьСостояниеЭлементовФормы();
КонецПроцедуры

#КонецОбласти
