&НаСервере
// Функция - Сформирвоать блок полисы
//
// Параметры:
//  ВыводитьБлок - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформирвоатьБлокПолисы(ВыводитьБлок = Ложь)
	
	Полисы = "";
	СтрокаПолисов = 
	"<tr valign='middle'>
	|            <td class='left_col ' td align='left'>
	|            </td>
	|            <td class='center_colnew' style='vertical-align: middle;'>
	|                <a class='content'href='{НавигационнаяСсылка}'>{Полис}</a>
	|            </td>
	|        </tr>
	|        <tr>
	|            <td colspan='3' style='height: 8px;'>
	|            </td>
	|        </tr>"; 	
	
	МассивПолисов = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(Контрагент, ТекущаяДата());
	
	Если МассивПолисов.Количество() <> 0 Тогда 
		
		Для Каждого СтраховойПолис Из МассивПолисов Цикл 
			
			ВыводитьБлок = Истина;
			
			ТипПолиса = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАббревиатуруТипаПолиса(СтраховойПолис.ТипПолиса);
			СтрокаПолис = ТипПолиса + ":  " + Строка(СтраховойПолис.СтраховаяКомпания) + "  № " + СтраховойПолис.СерияПолиса + "-" + СтраховойПолис.НомерПолиса + "  действителен с: "+ Формат(СтраховойПолис.ДанаНачала, "ДФ=dd.MM.yyyy") + " по " + Формат(СтраховойПолис.ДатаОкончания, "ДФ=dd.MM.yyyy") + ".    ";
			СуммаОказанныхУслуг = ПолучитьСуммуОказанныхУслугПоПолису(СтраховойПолис);			
			Если СтраховойПолис.ЛимитПолиса = 0 Тогда 
				ЛимитПолиса = "Сумма, оказанных услуг по полису: " + Формат(СуммаОказанныхУслуг, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				СтрокаПолис = СтрокаПолис + ЛимитПолиса;
			Иначе 
				ЛимитПолиса = "Лимит: " + Формат(СтраховойПолис.ЛимитПолиса, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				Если СтраховойПолис.ЛимитПолиса - СуммаОказанныхУслуг >= 0 Тогда 
					ОстатокПоЛимиту = "Остаток по лимиту: " + Формат(СтраховойПолис.ЛимитПолиса - СуммаОказанныхУслуг, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				Иначе 
					ОстатокПоЛимиту = "Остаток по лимиту: " + Формат(0, "ЧЦ=15; ЧДЦ=2; ЧН=") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				КонецЕсли;
				СтрокаПолис = СтрокаПолис + ЛимитПолиса + "    " + ОстатокПоЛимиту;   								
			КонецЕсли;
			
			НоваяСтрокаПолиса = СтрЗаменить(СтрокаПолисов    , "{Полис}"			  , СтрокаПолис);
			НоваяСтрокаПолиса = СтрЗаменить(НоваяСтрокаПолиса, "{НавигационнаяСсылка}", ПолучитьНавигационнуюСсылку(СтраховойПолис));
			
			Полисы = Полисы + НоваяСтрокаПолиса;			
			
		КонецЦикла;
		
	КонецЕсли;   
	
	Возврат Полисы;
	
КонецФункции

