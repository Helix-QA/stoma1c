				ИндексСтроки 	= Форма.Информация_По_Оплате.Индекс(СтрокаТЗ);
								
				//  Создаем группу для кнопки --------------------------------------------------------------------------------------------		
				Группа_Кнопки_ТипОплаты = Форма.Элементы.Добавить("Группа_Кнопки_ТипОплаты_" + ИндексСтроки, Тип("ГруппаФормы"), ГруппаРодитель);
				Группа_Кнопки_ТипОплаты.Вид 												= ВидГруппыФормы.ОбычнаяГруппа;
				Группа_Кнопки_ТипОплаты.Заголовок 											= Группа_Кнопки_ТипОплаты.Имя;
				Группа_Кнопки_ТипОплаты.Отображение 										= ОтображениеОбычнойГруппы.Нет;
				Группа_Кнопки_ТипОплаты.Группировка 										= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				Группа_Кнопки_ТипОплаты.ОтображатьЗаголовок 								= Ложь;
				Группа_Кнопки_ТипОплаты.ЦветФона 											= ?(СтрокаТЗ.СуммаОплачено < 0, Новый Цвет(255, 230, 230), Новый Цвет(208, 235, 194));
					
				Если Форма.Команды.Найти("Подключаемый_Открыть_Субъект_Оплаты_" + ИндексСтроки) = Неопределено Тогда
					Команда 			= Форма.Команды.Добавить("Подключаемый_Открыть_Субъект_Оплаты_" + ИндексСтроки);
					Команда.Заголовок 	= СформироватьПредставлениеЭлемента(Форма, СтрокаТЗ, ЭлементРодитель);
					Команда.Подсказка 	= Строка(НРег(СтрокаТЗ.ТипДенежныхСредств)) + " " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") +  " " + Валюта;
					Команда.Действие 	= "Подключаемый_ДекорацияФормы_Представление_Нажатие";
				КонецЕсли;
				
				Кнопка = Форма.Элементы.Добавить("Кнопка_Открыть_Субъект_Оплаты_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_ТипОплаты);
				Кнопка.ИмяКоманды 				= "Подключаемый_Открыть_Субъект_Оплаты_" + ИндексСтроки;
				Кнопка.Заголовок 				= СформироватьПредставлениеЭлемента(Форма, СтрокаТЗ, ЭлементРодитель);;
				Кнопка.ОтображениеФигуры    	= ОтображениеФигурыКнопки.Нет;
				Кнопка.Картинка					= ?(ОбщегоНазначения.ЕстьРеквизитФормы(СтрокаТЗ, "ОплатаПоСсылке"), ПолучитьКартинкуПШ(СтрокаТЗ.ОплатаПоСсылке), Кнопка.Картинка);
				Кнопка.Отображение				= ОтображениеКнопки.КартинкаИТекст;
				// Кнопка.ЦветТекста 				= ЦветаСтиля.ТекстВторостепеннойНадписи;
				Если НЕ ЭтоМобильныйКлиент Тогда
					Кнопка.Шрифт 					= ШрифтыСтиля.ШрифтПодваловДокументов;
				КонецЕсли;
				
				// Добавляем кнопку удаления для оплаты в счет зарплаты только для пользователй 
				// с полными правами или с ролью "ДобавлениеИзменениеДокументовПродажи".
				Если (РольДоступна("ПолныеПрава") Или РольДоступна("ДобавлениеИзменениеДокументовПродажи"))
					И ТипЗнч(Ссылка) = Тип("ДокументСсылка.Визит")  Тогда
					
					Если СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ВСчетЗарплаты Тогда 
						
						КнопкаУдалить = Форма.Элементы.Добавить("Кнопка_Удалить_ОплатуВСчетЗарплаты_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_ТипОплаты);
						
						Если Форма.Команды.Найти("Подключаемый_Удалить_ОплатуВСчетЗарплаты_" + ИндексСтроки) = Неопределено Тогда
							КомандаУдалить 				= Форма.Команды.Добавить("Подключаемый_Удалить_ОплатуВСчетЗарплаты_" + ИндексСтроки);
							КомандаУдалить.Заголовок 	= "Удалить оплату в счет зарплаты";
							КомандаУдалить.Подсказка 	= КомандаУдалить.Заголовок;					   
							КомандаУдалить.Действие		= "Подключаемый_Удалить_ОплатуВСчетЗарплаты_Нажатие";
							КомандаУдалить.ИзменяетСохраняемыеДанные = Истина;
						КонецЕсли;
						
						КнопкаУдалить.ИмяКоманды 				= "Подключаемый_Удалить_ОплатуВСчетЗарплаты_" + ИндексСтроки;
						КнопкаУдалить.Заголовок 					= "Удалить оплату в счет зарплаты";
						КнопкаУдалить.Отображение				= ОтображениеКнопки.Картинка;
						КнопкаУдалить.ОтображениеФигуры    		= ОтображениеФигурыКнопки.Нет;
						КнопкаУдалить.Картинка					= БиблиотекаКартинок.УдалениеДанных16;
						
					ИначеЕсли СтрокаТЗ.ИдентификаторФискальнойЗаписи = ""
						И (СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат
						Или СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет) Тогда
						 							
						КнопкаУдалить = Форма.Элементы.Добавить("Кнопка_Удалить_ОплатуПодарочнымСертификатомЛицевымСчетом_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_ТипОплаты);
						
						Если Форма.Команды.Найти("Подключаемый_Удалить_ОплатуПодарочнымСертификатомЛицевымСчетом_" + ИндексСтроки) = Неопределено Тогда
							КомандаУдалить 				= Форма.Команды.Добавить("Подключаемый_Удалить_ОплатуПодарочнымСертификатомЛицевымСчетом_" + ИндексСтроки);
							КомандаУдалить.Заголовок 	= ?(СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,
																	"Удалить оплату подарочным сертификатом", "Удалить оплату лицевым счетом");
							КомандаУдалить.Подсказка 	= КомандаУдалить.Заголовок;					   
							КомандаУдалить.Действие		= "Подключаемый_Удалить_ОплатуПодарочнымСертификатомЛицевымСчетом_Нажатие";
							КомандаУдалить.ИзменяетСохраняемыеДанные = Истина;
						КонецЕсли;
						
						КнопкаУдалить.ИмяКоманды 				= "Подключаемый_Удалить_ОплатуПодарочнымСертификатомЛицевымСчетом_" + ИндексСтроки;
						КнопкаУдалить.Заголовок 				= ?(СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,
																	"Удалить оплату подарочным сертификатом", "Удалить оплату лицевым счетом");
						КнопкаУдалить.Отображение				= ОтображениеКнопки.Картинка;
						КнопкаУдалить.ОтображениеФигуры    		= ОтображениеФигурыКнопки.Нет;
						КнопкаУдалить.Картинка					= БиблиотекаКартинок.УдалениеДанных16;  
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;  
			
			#Область СОЗДАНИЕ_ЭЛЕМЕНТОВ_ПО_ПРОМОКОДУ       		
			
			Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.Визит") И Объект.Промокод <> "" Тогда
				// Использован промокод  
				
				Группа_Кнопки_Промокод = Форма.Элементы.Добавить("Группа_Кнопки_Промокод", Тип("ГруппаФормы"), ГруппаРодитель);
				Группа_Кнопки_Промокод.Вид 				   = ВидГруппыФормы.ОбычнаяГруппа;
				Группа_Кнопки_Промокод.Заголовок 		   = Группа_Кнопки_Промокод.Имя;
				Группа_Кнопки_Промокод.Отображение 		   = ОтображениеОбычнойГруппы.Нет;
				Группа_Кнопки_Промокод.Группировка 		   = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				Группа_Кнопки_Промокод.ОтображатьЗаголовок = Ложь;
				Группа_Кнопки_Промокод.ЦветФона 		   = Новый Цвет(208, 235, 194);
				
				Если Форма.Элементы.Найти("Информация_По_Оплате") = Неопределено Тогда
					ИндексСтроки = 0;
				Иначе
					КоличествоОплат = Форма.Информация_По_Оплате.Количество();
					ИндексСтроки = ?(КоличествоОплат > 0, КоличествоОплат, ИндексСтроки); 
				КонецЕсли;
				
				Если Форма.Команды.Найти("Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки) = Неопределено Тогда
					Команда 			= Форма.Команды.Добавить("Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки);
					Команда.Заголовок 	= "Промокод: " + Объект.Промокод;					
					Команда.Действие 	= "Подключаемый_ДекорацияФормы_Представление_Нажатие_Промокода";
				КонецЕсли;
				
				Кнопка = Форма.Элементы.Добавить("Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_Промокод);
				Кнопка.ИмяКоманды 				= "Подключаемый_Открыть_Субъект_Промокода_" + ИндексСтроки;
				Кнопка.Заголовок 				= "Промокод: " + Объект.Промокод;
				Кнопка.ОтображениеФигуры    	= ОтображениеФигурыКнопки.Нет;				
				Если НЕ ЭтоМобильныйКлиент Тогда
					Кнопка.Шрифт 					= ШрифтыСтиля.ШрифтПодваловДокументов;
				КонецЕсли;
				Если (РольДоступна("ПолныеПрава") Или РольДоступна("ДобавлениеИзменениеДокументовПродажи")) И Объект.НомерЧекаККМ = 0 Тогда
					КнопкаУдалить = Форма.Элементы.Добавить("Кнопка_Удалить_Промокод_" + ИндексСтроки, Тип("КнопкаФормы"), Группа_Кнопки_Промокод);
					Если Форма.Команды.Найти("Подключаемый_Удалить_Промокод_" + ИндексСтроки) = Неопределено Тогда
						КомандаУдалить 				= Форма.Команды.Добавить("Подключаемый_Удалить_Промокод_" + ИндексСтроки);
						КомандаУдалить.Заголовок 	= "Удалить промокод";
						КомандаУдалить.Подсказка 	= КомандаУдалить.Заголовок;					   
						КомандаУдалить.Действие		= "Подключаемый_Удалить_Промокод_Нажатие";
						КомандаУдалить.ИзменяетСохраняемыеДанные = Истина;
					КонецЕсли;
					КнопкаУдалить.ИмяКоманды 				= "Подключаемый_Удалить_Промокод_" + ИндексСтроки;
					КнопкаУдалить.Заголовок 				= "Удалить промокод";
					КнопкаУдалить.Отображение				= ОтображениеКнопки.Картинка;
					КнопкаУдалить.ОтображениеФигуры    		= ОтображениеФигурыКнопки.Нет;
					КнопкаУдалить.Картинка					= БиблиотекаКартинок.УдалениеДанных16; 
				КонецЕсли;
				
			КонецЕсли;
			
			#КонецОбласти
			
			Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Визит") Тогда
				
				Если Форма.СуммаОплаченоПоРегистру > 0 Тогда
					
					//  Возврат--------------------------------------------------------------------------------------------		
					Группа_Кнопки_ВозвратОплаты = Форма.Элементы.Добавить("Группа_Кнопки_ВозвратОплаты", Тип("ГруппаФормы"), ГруппаРодитель);
					Группа_Кнопки_ВозвратОплаты.Вид									= ВидГруппыФормы.ОбычнаяГруппа;
					Группа_Кнопки_ВозвратОплаты.Заголовок							= Группа_Кнопки_ВозвратОплаты.Имя;
					Группа_Кнопки_ВозвратОплаты.Отображение							= ОтображениеОбычнойГруппы.Нет;
					Группа_Кнопки_ВозвратОплаты.Группировка							= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
					Группа_Кнопки_ВозвратОплаты.ОтображатьЗаголовок					= Ложь;
					Группа_Кнопки_ВозвратОплаты.ЦветФона							= Новый Цвет(255,0,0);
					Группа_Кнопки_ВозвратОплаты.ГоризонтальноеПоложениеВГруппе		= ГоризонтальноеПоложениеЭлемента.Право;
					Группа_Кнопки_ВозвратОплаты.ГоризонтальноеПоложениеПодчиненных	= ГоризонтальноеПоложениеЭлемента.Право;				
					
					Команда = Форма.Команды.Найти("Подключаемый_Возврат");
					
					Если Команда = Неопределено Тогда
						Команда 			= Форма.Команды.Добавить("Подключаемый_Возврат");
						Команда.Заголовок 	= "Возврат";
						Команда.Подсказка 	= "Возврат";
						Команда.Действие 	= "Подключаемый_Возврат";
					Иначе
						Команда.Подсказка   = СокрЛП("Возврат");
					КонецЕсли;
					
					Кнопка = Форма.Элементы.Добавить("Кнопка_Возврата_Визита", Тип("КнопкаФормы"), Группа_Кнопки_ВозвратОплаты);
					Кнопка.ИмяКоманды 				= "Подключаемый_Возврат";
					Кнопка.Заголовок 				= СокрЛП("Возврат");
					Кнопка.ОтображениеФигуры    	= ОтображениеФигурыКнопки.Нет;
					Кнопка.ЦветТекста 				= Новый Цвет(255,255,255);
					Если НЕ ЭтоМобильныйКлиент Тогда
						Кнопка.Шрифт = Новый Шрифт("Arial", 11);
					КонецЕсли;
					
				КонецЕсли;
				
				//  Создаем декорацию --------------------------------------------------------------------------------------------		
				Декорация_ДляОтступа = Элементы.Добавить("Декорация_ДляОтступа_динам", Тип("ДекорацияФормы"), ГруппаРодитель);
				Декорация_ДляОтступа.Вид 					        = ВидДекорацииФормы.Надпись;
				Декорация_ДляОтступа.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
				Декорация_ДляОтступа.Шрифт 				            = Новый Шрифт("Arial", 11);
				Декорация_ДляОтступа.АвтоМаксимальнаяШирина 	    = Ложь;
				КоличествоОплат = Форма.Информация_По_Оплате.Количество();
				
				Если Форма.Объект.Статус = Перечисления.СтатусыВизитов.Окончен Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 58;
				КонецЕсли;
				Если (Форма.Объект.Статус = Перечисления.СтатусыВизитов.Окончен
					Или Форма.Объект.Статус = Перечисления.СтатусыВизитов.КлиентПришел) И КоличествоОплат = 2 Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 25;
				ИначеЕсли (Форма.Объект.Статус = Перечисления.СтатусыВизитов.Окончен
					Или Форма.Объект.Статус = Перечисления.СтатусыВизитов.КлиентПришел) И КоличествоОплат = 1 Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 45;
				ИначеЕсли (Форма.Объект.Статус = Перечисления.СтатусыВизитов.Окончен
					Или Форма.Объект.Статус = Перечисления.СтатусыВизитов.КлиентПришел) И КоличествоОплат = 3 Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 7;
				//ИначеЕсли (Форма.Объект.Статус = Перечисления.СтатусыВизитов.Окончен
				//	Или Форма.Объект.Статус = Перечисления.СтатусыВизитов.КлиентПришел) И КоличествоОплат >= 4 Тогда
				//	Декорация_ДляОтступа.Видимость = Ложь;					
				КонецЕсли;
				
				Если  Форма.Объект.Статус = Перечисления.СтатусыВизитов.КлиентПришел Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 36;				   
				КонецЕсли;
				//Если  Форма.Объект.Статус = Перечисления.СтатусыВизитов.КлиентПришел И  Заголовок = "Оплачено полностью:" Тогда
				//	Декорация_ДляОтступа.Видимость = Ложь;
				//КонецЕсли;
				
				
				Если Форма.Объект.Продажа Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 60;
				КонецЕсли;
				
				Если Форма.Объект.Продажа И КоличествоОплат = 2 Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 25;
				ИначеЕсли Форма.Объект.Продажа и КоличествоОплат = 1 Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 45;
				ИначеЕсли Форма.Объект.Продажа и КоличествоОплат = 3 Тогда
					Декорация_ДляОтступа.МаксимальнаяШирина = 7;
				//ИначеЕсли Форма.Объект.Продажа и КоличествоОплат >= 4 Тогда
				//	Декорация_ДляОтступа.Видимость = Ложь;					
				КонецЕсли;
				
				Декорация_ДляОтступа.РастягиватьПоГоризонтали = Истина;				
				
			КонецЕсли;
			
			Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Визит") Тогда
				Если Не ЗначениеЗаполнено(Форма.Объект.Контрагент)
