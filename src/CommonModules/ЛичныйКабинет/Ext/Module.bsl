// Функция - Выполнить POSTЗапрос
// 
// Параметры:
//  Метод		 - 	 - 
//  ТекстЗапроса - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВыполнитьPOSTЗапрос(Метод, ТекстЗапроса, ДопЗаголовки = Неопределено, Параметры = Неопределено, ОбработатьРезультат = Истина)
	
	Если Параметры = Неопределено Тогда
		Параметры = ПараметрыПодклчюенияК_API_CRM();
	КонецЕсли;
	
	Соединение = Новый HTTPСоединение(
	Параметры.АдресСервера,, 
	Параметры.Пользователь,
	Параметры.Пароль);
		
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language", "ru");	
	
	Если ДопЗаголовки <> Неопределено Тогда
		
		Для Каждого Заголовок ИЗ ДопЗаголовки Цикл		
			ЗаголовкиHTTP.Вставить(Заголовок.Ключ, Заголовок.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	// /CRM/hs/api/v1/
	HTTPЗапрос = Новый HTTPЗапрос(Параметры.АдресПубликации + Метод, ЗаголовкиHTTP);		
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		

    ВозвращаемыйРезультат = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если ОбработатьРезультат = Истина Тогда 
		Возврат РазобратьJson(ВозвращаемыйРезультат);
	Иначе
		Возврат ВозвращаемыйРезультат;
	КонецЕсли;
		
КонецФункции

// Функция - Выполнить PUTЗапрос
// 
// Параметры:
//  Метод		 - 	 - 
//  ТекстЗапроса - 	 - 
//  ДопЗаголовки - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВыполнитьPUTЗапрос(Метод, ТекстЗапроса, ДопЗаголовки = Неопределено, Параметры = Неопределено)
	
	Если Параметры = Неопределено Тогда
		Параметры = ПараметрыПодклчюенияК_API_CRM();
	КонецЕсли;
	
	Соединение = Новый HTTPСоединение(
	Параметры.АдресСервера,, 
	Параметры.Пользователь,
	Параметры.Пароль);
		
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language", "ru");	
	
	Если ДопЗаголовки <> Неопределено Тогда
		
		Для Каждого Заголовок ИЗ ДопЗаголовки Цикл		
			ЗаголовкиHTTP.Вставить(Заголовок.Ключ, Заголовок.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	// /CRM/hs/api/v1/
	HTTPЗапрос = Новый HTTPЗапрос(Параметры.АдресПубликации + Метод, ЗаголовкиHTTP);		
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		

    ВозвращаемыйРезультат = Соединение.ВызватьHTTPМетод("PUT", HTTPЗапрос);
	
	Возврат РазобратьJson(ВозвращаемыйРезультат);
		
КонецФункции

// Функция - Выполнить GETЗапрос
// 
// Параметры:
//  Метод		 - 	 - 
//  ДопЗаголовки - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВыполнитьGETЗапрос(Метод, ДопЗаголовки = Неопределено, Параметры = Неопределено, ВозвратДвоичныхДанных = Ложь)
	
	Если Параметры = Неопределено Тогда
		Параметры = ПараметрыПодклчюенияК_API_CRM();
	КонецЕсли;
	
	Соединение = Новый HTTPСоединение(
	Параметры.АдресСервера,, 
	Параметры.Пользователь,
	Параметры.Пароль);
		
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language", "ru");	
	
	Если ДопЗаголовки <> Неопределено Тогда                     
		
		Для Каждого Заголовок ИЗ ДопЗаголовки Цикл		
			ЗаголовкиHTTP.Вставить(Заголовок.Ключ, Заголовок.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	// /CRM/hs/api/v1/
	HTTPЗапрос = Новый HTTPЗапрос(Параметры.АдресПубликации + Метод, ЗаголовкиHTTP);				
		
    ВозвращаемыйРезультат = Соединение.Получить(HTTPЗапрос);
	
	Возврат ?(ВозвратДвоичныхДанных, ВозвращаемыйРезультат.ПолучитьТелоКакДвоичныеДанные(), РазобратьJson(ВозвращаемыйРезультат));
		
КонецФункции

// Функция - Обработать стандартный результат HTTPЗапроса
// 
// Параметры:
//  РезультатЗапроса - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса)
	
	РезультатаОперции                     = СтруктураСтандартынхПараметровРезОперации();	
	РезультатаОперции.ПараметрыРезультата = РезультатЗапроса.parameters;
	
	Если РезультатЗапроса.parameters.result = Истина Тогда
		
		Если ЗначениеЗаполнено(РезультатЗапроса.parameters) Тогда
			РезультатаОперции.ВыполненоУспешно = РезультатЗапроса.parameters.result;
		КонецЕсли;
		
	Иначе
		
		РезультатаОперции.КодОшибки       = РезультатЗапроса.errors.code;
		РезультатаОперции.ОписаниеОшибки  = РезультатЗапроса.errors.message;
		
		Если РезультатаОперции.КодОшибки <> 1074 Тогда
			
			ДанныеИсключения = Новый Структура("Описание,ИмяМодуля,НомерСтроки,ИсходнаяСтрока,Причина",
			РезультатЗапроса.errors.message,
			"МодульОбщегоНазначения.ЛичныйКабинет");	
			
			ЗаписатьОшибкуВЖурналРегистрации(ДанныеИсключения);
			
		КонецЕсли;
	
	КонецЕсли;

	Возврат РезультатаОперции;
	
КонецФункции

// Функция - Обработать исключение при выполнении HTTPЗапроса
//
// Параметры:
//  ДанныеИсключения - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбработатьИсключениеПриВыполненииHTTPЗапроса(ДанныеИсключения, ТекстОшибки = "")
	
	РезультатаОперции = СтруктураСтандартынхПараметровРезОперации();
	
	Описание = СтрШаблон(
	"Описание: %1
	|ИмяМодуля: %2
	|НомерСтроки: %3
	|ИсходнаяСтрока: %4
	|Причина: %5",
	ДанныеИсключения.Описание,
	ДанныеИсключения.ИмяМодуля,
	ДанныеИсключения.НомерСтроки,
	ДанныеИсключения.ИсходнаяСтрока,
	ДанныеИсключения.Причина);
	
	РезультатаОперции.КодОшибки       = 400;
	РезультатаОперции.ОписаниеОшибки  = ?(ЗначениеЗаполнено(ТекстОшибки), ТекстОшибки, Описание);
	
	ЗаписатьОшибкуВЖурналРегистрации(ДанныеИсключения);
			
	Возврат РезультатаОперции;
		
КонецФункции

// Процедура - Записать ошибку в журнал регистрации
// 
// Параметры:
//  ДанныеОшибки - 	 - 
// 
Процедура ЗаписатьОшибкуВЖурналРегистрации(ДанныеОшибки)
	
	Описание = СтрШаблон(
	"Описание: %1
	|ИмяМодуля: %2
	|НомерСтроки: %3
	|ИсходнаяСтрока: %4
	|Причина: %5",
	ДанныеОшибки.Описание,
	ДанныеОшибки.ИмяМодуля,
	ДанныеОшибки.НомерСтроки,
	ДанныеОшибки.ИсходнаяСтрока,
	ДанныеОшибки.Причина);
	
	ЗаписьЖурналаРегистрации(
	"API CRM",
	УровеньЖурналаРегистрации.Ошибка,,,
	Описание);
	
КонецПроцедуры

