&НаСервере
// Процедура - устанавливает видимость реквизитов в зависимости от хозяйственной операции.
//
Процедура УстановитьВидимость()
	
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда		
		ЭтаФорма.Заголовок = "Перемещение наличных денежных средств";		
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		
		ЭтаФорма.Заголовок = "Перемещение безналичных денежных средств";
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда		
		ЭтаФорма.Заголовок = "Перемещение денежных средств по лицевым счетам";  
	Иначе
		ЭтаФорма.Заголовок = "Перемещение денежных средств";
	КонецЕсли;	
		
	Если Объект.Ссылка.Пустая() Тогда
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + "(создание)";
	КонецЕсли;
		
	// Установка состояния элементов формы
	УправлениеИнтерфейсамиСервер.УстановкаСостоянийЭлементовФормы(ЭтаФорма, Объект);
	ИсточникДенежныхСредствПриИзмененииСервер();
	ПриемникДенежныхСредствПриИзмененииСервер();
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "АвтоПодбор"
//
Процедура СтруктурнаяЕдиницаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ДанныеВыбора = ПолучитьДоступныеСтруктурныеЕдиницы(Текст);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция возвращает доступные структурные единицы
//
Функция ПолучитьДоступныеСтруктурныеЕдиницы(СтрокаПоиска)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.Ссылка В(&МассивСсылок)
	|	И &УсловиеСтрокаПоиска");
	
	Запрос.УстановитьПараметр("МассивСсылок", ОбщегоНазначенияСтоматология.ДоступныеСтруктурныеЕдиницы());
	Запрос.УстановитьПараметр("СтрокаПоиска", "%" + СтрокаПоиска + "%");
	
	УсловиеСтрокаПоиска = ?(СтрДлина(СтрокаПоиска) >= 2, "И СтруктурныеЕдиницы.Наименование ПОДОБНО &СтрокаПоиска", "");
	Запрос.Текст		= СтрЗаменить(Запрос.Текст, "И &УсловиеСтрокаПоиска", УсловиеСтрокаПоиска);
	
    МассивСтруктурныхЕдиниц = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
    
    СписокСтруктурныхЕдиниц = Новый СписокЗначений;
    СписокСтруктурныхЕдиниц.ЗагрузитьЗначения(МассивСтруктурныхЕдиниц);
	
	Возврат СписокСтруктурныхЕдиниц;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора".
//
Процедура СтруктурнаяЕдиницаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ЭтоПользователь"			   , Истина);
	СтруктураПараметров.Вставить("Ссылка"					   , ОбщегоНазначенияСтоматология.ДоступныеСтруктурныеЕдиницы()); 
	СтруктураПараметров.Вставить("ВидСравненияКомпоновкиДанных", ВидСравненияКомпоновкиДанных.ВСписке);
	
	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаВыбора", СтруктураПараметров, Элементы.СтруктурнаяЕдиница);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора".
//
Процедура СтруктурнаяЕдиницаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ВыбранноеЗначение  <> Объект.СтруктурнаяЕдиница Тогда
		
		Объект.Касса 			  = Неопределено;
		Объект.БанковскийСчет 	  = Неопределено;
		Объект.ЭквайрингТерминал  = Неопределено;
		Объект.СтруктурнаяЕдиница = ВыбранноеЗначение;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти