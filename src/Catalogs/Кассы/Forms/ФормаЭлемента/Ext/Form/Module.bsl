&НаКлиенте
// Процедура, обработчик описания оповещения ОбработкаВыбораЭквайринга 
//
Процедура ОбработкаВыбораЭквайринга(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	МассивНайденныхСтрок = Объект.ЭквайринговыеТерминалы.НайтиСтроки(Новый Структура("ЭквайринговыйТерминал", ВыбранноеЗначение));
	
	Для Каждого СтрокаМассива из МассивНайденныхСтрок Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Терминал уже выбран в табличной части!'; en = 'The terminal is already selected at table!'"));				
		Возврат;	
	КонецЦикла;
	
	КассаТерминала = ПолучитьКассуТерминала(ВыбранноеЗначение, Объект.Ссылка);
	
	Если КассаТерминала <> Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Терминал уже выбран в другой кассе!'; en = 'The terminal is already selected at another cash desk!'"));
		Возврат;		
	КонецЕсли;
	
	СтрокаЭквайринга = Объект.ЭквайринговыеТерминалы.Добавить();
	СтрокаЭквайринга.ЭквайринговыйТерминал = ВыбранноеЗначение;
	
	Ид = СтрокаЭквайринга.ПолучитьИдентификатор();
	ВывестиЭквайрингНаФорму(Ид);
	
	Модифицированность = Истина;
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды удалить эквайринговый терминал из ТЧ
//
Процедура УдалитьЭквайринговыйТерминал(Команда)
	
	Идентификатор = ИдентификаторЭлемента(ТекущийЭлемент.Имя);
	СтрокаТЧ = Объект.ЭквайринговыеТерминалы.НайтиПоИдентификатору(Идентификатор);
	Если СтрокаТЧ <> Неопределено Тогда
		
		Объект.ЭквайринговыйТерминал = ?(СтрокаТЧ.Основной, Неопределено, Объект.ЭквайринговыйТерминал); 
		Объект.ЭквайринговыеТерминалы.Удалить(СтрокаТЧ);
		УдалитьЭквайринговыйТерминалНаФорме(Идентификатор);
		Модифицированность = Истина;
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик команды удалить эквайринговый терминал с формы
//
Процедура УдалитьЭквайринговыйТерминалНаФорме(Идентификатор)
	
	МассивУдаляемых = Новый Массив;
	
	УдаляемыйЗаголовокЭквайринга = Элементы.Найти("ГруппаЭквайринг_"+Идентификатор);
	УдаляемаяКнопкаЗакрытьЭквайринг = Элементы.Найти("ГруппаЗакрытьЭквайринг_"+Идентификатор);
	
	Если УдаляемыйЗаголовокЭквайринга = Неопределено ИЛИ УдаляемаяКнопкаЗакрытьЭквайринг = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.Удалить(УдаляемыйЗаголовокЭквайринга);
	Элементы.Удалить(УдаляемаяКнопкаЗакрытьЭквайринг);
КонецПроцедуры

&НаСервере
// Процедура, отображает ТЧ Эквайринговые терминалы на форму
//
Процедура ВывестиТЧЭквайринговыеТерминалы()
	
	Для каждого СтрокаТЧ Из Объект.ЭквайринговыеТерминалы Цикл
		
		ВывестиЭквайрингНаФорму(СтрокаТЧ.ПолучитьИдентификатор());	
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, выводит эквайринг на форму
//
Процедура ВывестиЭквайрингНаФорму(Идентификатор)
	
	ДанныеЭквайринговогоТерминала = Объект.ЭквайринговыеТерминалы.НайтиПоИдентификатору(Идентификатор);
	
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормыРекурсивно(ЭтаФорма,Элементы.ГруппаЭквайринг_,Элементы.ГруппаВсеЭквайрингиВертикальная,Идентификатор);
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормыРекурсивно(ЭтаФорма,Элементы.ГруппаЗакрытьЭквайринг_,Элементы.ГруппаЗакрытьВсеЭквайрингиВертикальная,Идентификатор);
	
	ЭлементЭквайринговыйТерминал = Элементы.Найти("ЭквайринговыйТерминал_" + Идентификатор);
	
	Если ЭлементЭквайринговыйТерминал <> Неопределено Тогда
		
		ЭлементЭквайринговыйТерминал.Заголовок = Строка(ДанныеЭквайринговогоТерминала.ЭквайринговыйТерминал);
		Если ДанныеЭквайринговогоТерминала.Основной Тогда
			ЭлементЭквайринговыйТерминал.Шрифт = Новый Шрифт(,,Истина,,,,);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Вывести динамические элементы ТЧ
//
Процедура ВывестиДинамическиеЭлементыТЧ()
	
	Объект.ЭквайринговыеТерминалы.Сортировать("ЭквайринговыйТерминал Возр"); 
	Объект.Секции.Сортировать("СегментНоменклатуры Возр");
	
	ВывестиТЧСегменты();
	ВывестиТЧЭквайринговыеТерминалы(); 

КонецПроцедуры

&НаСервереБезКонтекста
// Функция получения Идентификатора элемента на форме
//
Функция ИдентификаторЭлемента(Имя)

	мИмени = СтрРазделить(Имя,"_");
	Если мИмени.Количество()>1 Тогда
		Возврат Число(мИмени[1]);
	Иначе
		Возврат -1;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура - Структурная единица начало выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеВыбора		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура СтруктурнаяЕдиницаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаВыбора",Новый Структура("Отбор", Новый Структура("ПометкаУдаления, Организация", Ложь, Объект.Организация)), Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте                                                                             
// Процедура - отображение Дополнительно.
//
Процедура СкрытьПоказатьДополнительно(Команда)
	Элементы.ГруппаДополнительно.Видимость = Не Элементы.ГруппаДополнительно.Видимость;
КонецПроцедуры

&НаКлиенте   
// Процедура дабвления сегмента секции.
//
Процедура ДобавитьСегментСекции(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаВыбораСегмента",ЭтотОбъект);
	ОткрытьФорму("Справочник.СегментыНоменклатуры.ФормаВыбора",Новый Структура("Отбор", Новый Структура("ПометкаУдаления",Ложь)),ЭтотОбъект,,,,ОписаниеОповещения);
КонецПроцедуры  

&НаКлиенте 
// Процедура - ОбработкаВыборкаСегмента.
//
Процедура ОбработкаВыбораСегмента(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;		
	КонецЕсли;
	
	МассивНайденныхСтрок = Объект.Секции.НайтиСтроки(Новый Структура("СегментНоменклатуры", ВыбранноеЗначение));
	
	Для Каждого СтрокаМассива из МассивНайденныхСтрок Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Сегмент уже выбран в табличной части!'; en = 'The segment is already selected at table!'"));				
		Возврат;	
	КонецЦикла;
	
	СтрокаСегмента = Объект.Секции.Добавить();
	СтрокаСегмента.СегментНоменклатуры = ВыбранноеЗначение;
	СтрокаСегмента.НомерСекции = 1;
	
	Модифицированность = Истина;  
	
	Ид = СтрокаСегмента.ПолучитьИдентификатор();
	ВывестиСегментНаФорму(Ид);

КонецПроцедуры 

&НаСервере
// Процедура, выводит эквайринг на форму
//
Процедура ВывестиСегментНаФорму(Идентификатор)
	
	ДанныеСегмента = Объект.Секции.НайтиПоИдентификатору(Идентификатор);
	ИндексДанных   = Объект.Секции.Индекс(ДанныеСегмента);
	
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормыРекурсивно(ЭтаФорма,Элементы.ГруппаНаименованияСегмента_,
	Элементы.ГруппаСегментВертикальная,Идентификатор);
	
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормыРекурсивно(ЭтаФорма,Элементы.ГруппаНомерУдалитьСегмент_, 
	Элементы.ГруппаВертикальнаяНомерУдалитьСегмент,Идентификатор,ИндексДанных);
	
	ЭлементСегмент = Элементы.Найти("Сегмент_" + Идентификатор);
	
	Если ЭлементСегмент <> Неопределено Тогда
		
		ЭлементСегмент.Заголовок = Строка(ДанныеСегмента.СегментНоменклатуры);	
		
	КонецЕсли;
	
КонецПроцедуры   

&НаКлиенте   
// Процедура - Открыть сегмент секции.
//
Процедура ОткрытьСегментСекции(Команда)
	
	Ид = ИдентификаторЭлемента(ТекущийЭлемент.Имя);
	ДанныеЭлемента = Объект.Секции.НайтиПоИдентификатору(Ид);
	
	Если ДанныеЭлемента = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьЗначение(,ДанныеЭлемента.СегментНоменклатуры);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Удалить сегмент секции.
//
Процедура УдалитьСегментСекции(Команда)
	Идентификатор = ИдентификаторЭлемента(ТекущийЭлемент.Имя);
	СтрокаТЧ = Объект.Секции.НайтиПоИдентификатору(Идентификатор);
	
	Если СтрокаТЧ <> Неопределено Тогда
		
		Объект.Секции.Удалить(СтрокаТЧ);
		УдалитьСегментНаФорме(Идентификатор);
		Модифицированность = Истина;
		ОбновитьСегменты();
		
	КонецЕсли;	
КонецПроцедуры

&НаСервере
// Процедура, обновляет эквайринговые терминалы на форме
Процедура ОбновитьСегменты()
	
	Для Каждого СтрокаТЧ Из Объект.Секции Цикл
		
		УдалитьСегментНаФорме(СтрокаТЧ.ПолучитьИдентификатор());	
		
	КонецЦикла;
	
	ВывестиТЧСегменты();
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик команды удалить сегмент с формы
//
Процедура УдалитьСегментНаФорме(Идентификатор)
	
	УдаляемоеНаименованиеСегмента = Элементы.Найти("ГруппаНаименованияСегмента_" + Идентификатор);
	УдаляемаяКнопкаЗакрытьСегмент = Элементы.Найти("ГруппаНомерУдалитьСегмент_"  + Идентификатор);
	
	Если УдаляемоеНаименованиеСегмента = Неопределено ИЛИ УдаляемаяКнопкаЗакрытьСегмент = Неопределено Тогда
		
		Возврат;   
		
	КонецЕсли;
		
	Элементы.Удалить(УдаляемоеНаименованиеСегмента);
	Элементы.Удалить(УдаляемаяКнопкаЗакрытьСегмент);
	
КонецПроцедуры   

&НаСервере
// Процедура, отображает ТЧ Эквайринговые терминалы на форму
//
Процедура ВывестиТЧСегменты()
	
	Для каждого СтрокаТЧ Из Объект.Секции Цикл
		
		ВывестиСегментНаФорму(СтрокаТЧ.ПолучитьИдентификатор());	
		
	КонецЦикла;
	
КонецПроцедуры
	
#КонецОбласти

#КонецОбласти


