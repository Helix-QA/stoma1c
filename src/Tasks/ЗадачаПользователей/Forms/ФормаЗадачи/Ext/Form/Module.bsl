#Область ОбработчикиСобытийФормы

&НаСервере
// При создании формы на сервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Если это новая задача
	Если Объект.Ссылка.Пустая() Тогда
		
		Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		
		Если НЕ ЗначениеЗаполнено(Объект.ЗадачаПредмет) Тогда
			Объект.ЗадачаПредмет = ?(Параметры.Свойство("Предмет"),Параметры.Предмет,Неопределено);
		КонецЕсли;
		
		Если Объект.ЗадачаПредмет = Неопределено ИЛИ Объект.ЗадачаПредмет.Пустая() Тогда
			Объект.ЗадачаНазначеннаяДатаВыполнения = ТекущаяДата();
		ИначеЕсли ТипЗнч(Объект.ЗадачаПредмет) = Тип("ДокументСсылка.Взаимодействие") Тогда 	
			Объект.ЗадачаНазначеннаяДатаВыполнения = Объект.ЗадачаПредмет.НапоминаниеДатаНачала;
		КонецЕсли;        		
		
		Если Параметры.Свойство("Контрагент") Тогда
			Объект.ЗадачаПредмет = Параметры.Контрагент;			 
		КонецЕсли;
		
		Элементы.ФормаКнопкаВыполнить.Доступность  = Ложь;
		Элементы.ФормаКнопкаПрекратить.Доступность = Ложь;
		
	ИначеЕсли Объект.Выполнена Тогда
		
		ЭтаФорма.ТолькоПросмотр                         = Истина;
		Элементы.ГруппаПараметрыНапоминания.Доступность = Ложь;
		Элементы.ФормаКнопкаПрекратить.Доступность      = Ложь;
		
	КонецЕсли;
	
	// Установка представления предмета задачи
	ПредметПредставление = ?(Объект.ЗадачаПредмет = Неопределено ИЛИ Объект.ЗадачаПредмет.Пустая(),"Нет предмета задачи.",Строка(Объект.ЗадачаПредмет));
		
	// Установка информации об авторе
	Элементы.ИнформацияАвтор.Заголовок = "Создана: "+Объект.ЗадачаАвтор.Наименование+", "+Строка(Объект.Дата);
	
	// Заполнение списка режимов напоминания
	ЗаполнитьСписокВыбораРежимаНапоминания();
	
	//// Сохранение вводимых значений
	// СохранениеВводимыхЗначений.ЗаполнитьСписокВыбора(ЭтаФорма, ЭлементыДляСохранения(), ЭтаФорма.ИмяФормы);

КонецПроцедуры

&НаКлиенте
// Обработчик открытия формы на клиенте
Процедура ПриОткрытии(Отказ)
	
	// Установить текущий выбранный режим напоминания
	Для Каждого Элемент ИЗ Элементы.РежимНапоминания.СписокВыбора Цикл
		
		Если Элемент.Значение.Режим = Объект.НапоминаниеРежим  Тогда
			
			Если Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЧерезУказанноеВремя") Тогда 
				
				 Если Элемент.Значение.Интервал =  Объект.НапоминаниеДатаНачала - Объект.Дата Тогда
					 
					 РежимНапоминания = Элемент.Значение;
					 Прервать;
					 
				 КонецЕсли;
				 
			 ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия") Тогда
				 
				     РежимНапоминания            = Элемент.Значение;
					 НапоминаниеИнтервалДоНачала = Объект.ЗадачаНазначеннаяДатаВыполнения - Объект.НапоминаниеДатаНачала;					 				
					 Прервать;
					 
			 Иначе
				 
				 РежимНапоминания = Элемент.Значение;
				 Прервать;
				 
			 КонецЕсли;
			 
		КонецЕсли;
		
	КонецЦикла;
	
	// Заполнить список выбора времени напоминания 
	МассивПериодов = Новый Массив;
    СтруктураВремени               = ОбщегоНазначенияСтоматология.ПолучитьВремяРаботыСтруктурнойЕдиницы(Объект.НапоминаниеДатаНачала, Объект.СтруктурнаяЕдиница);
	СтруктураВремени.ДатаНачала    = ?(ЗначениеЗаполнено(СтруктураВремени.ДатаНачала),СтруктураВремени.ДатаНачала,Дата("00010101080000"));
	СтруктураВремени.ДатаОкончания = ?(ЗначениеЗаполнено(СтруктураВремени.ДатаОкончания),СтруктураВремени.ДатаОкончания,Дата("00010101220000"));
	
	МассивПериодов.Добавить(СтруктураВремени);	
	СписокВеремени = РаботаСДиалогами.ВернутьСписокВремени(МассивПериодов                       , Истина);	
	
	Элементы.ВремяНапоминания.СписокВыбора.Очистить();
	Для Каждого Элемент ИЗ СписокВеремени Цикл	
		
	     Элементы.ВремяНапоминания.СписокВыбора.Добавить(Элемент.Значение,Элемент.Представление);
		 
	КонецЦикла;
	
	// Настройка отображения элементов режима напоминания
	Если Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия") Тогда
		
		Элементы.ИнтервалДоНапоминания.Видимость = Истина;
		Элементы.ДатаНапоминания.Видимость       = Ложь;
		Элементы.ВремяНапоминания.Видимость      = Ложь;
			
	ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ВУказанноеВремя") Тогда 	
		
	    Элементы.ИнтервалДоНапоминания.Видимость = Ложь;
		Элементы.ДатаНапоминания.Видимость       = Истина;
		Элементы.ВремяНапоминания.Видимость      = Истина;
								
	ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ПоСобытию") Тогда 
		
		Элементы.ИнтервалДоНапоминания.Видимость = Ложь;
		Элементы.ВремяНапоминания.Видимость      = Ложь;
		Элементы.ДатаНапоминания.Видимость       = Ложь;
				
    ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЧерезУказанноеВремя") Тогда 
		
		Элементы.ИнтервалДоНапоминания.Видимость = Ложь;
		Элементы.ВремяНапоминания.Видимость      = Ложь;
		Элементы.ДатаНапоминания.Видимость       = Ложь;
			
    КонецЕсли;
	
	// ФормаКлиент = ПолучитьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты");
	// ФормаЗадачи = ПолучитьФорму("Задача.ЗадачаПользователей.Форма.ФормаСписка");
	// Если ФормаКлиент.Открыта() Тогда
	//	
	// КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Обработчик перед записью формы на клиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия") Тогда
		
		Если НапоминаниеИнтервалДоНачала = 0 Тогда
			
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите через какое время необходимо напомнить!");
			
		КонецЕсли;

		Объект.НапоминаниеДатаНачала = Объект.ЗадачаНазначеннаяДатаВыполнения - НапоминаниеИнтервалДоНачала;
			
	ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ВУказанноеВремя") Тогда 	
		
		Если Объект.НапоминаниеДатаНачала = НачалоДня(Объект.НапоминаниеДатаНачала) Тогда
			
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите время предупреждения!");
			
		КонецЕсли;
												
    КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ЗаписанаЗадачаПользователя", Объект.Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область СпециальныеОбработчики   

&НаКлиенте
// Обработчик открытия формы кэш списка вводимых значений
Процедура Подключаемый_ОбработчикКэшЛист(Элемент, ДанныеВыбора, СтандартнаяОбработка) Экспорт
	
	// СтандартнаяОбработка = Ложь;
	// СохранениеВводимыхЗначенийКлиент.ОбработчикВызоваФормыРедактированияКэшСписка(Элемент,ЭтаФорма);
	
