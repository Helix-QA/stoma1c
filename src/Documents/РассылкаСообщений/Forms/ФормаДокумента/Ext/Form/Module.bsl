// Процедура, устанавливает видимость элементов формы.
//
Процедура УстановитьСостояниеЭлементовФормы(Форма)
	
	ЦветФонаАктивнойГруппы		 = Новый Цвет(25, 116, 206);
	ЦветФонаНеактивнойГруппы	 = Новый Цвет(242, 242, 242);
	
	ЦветТекстаАктивнойГруппы	 = Новый Цвет(255, 255, 255);
	ЦветТекстаНеактивнойГруппы	 = Новый Цвет(77, 77, 77);
	
	ЭтоСообщениеВМессенджер	 = (Форма.Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер"));
	ЭтоPushУведомление		 = (Форма.Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление"));
	ЭтоSMS					 = (Форма.Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS"));
	
	Форма.Элементы.ГруппаБаланса.Видимость			 = ЭтоSMS;
	Форма.Элементы.Транслитерация.Видимость			 = ЭтоSMS;
	Форма.Элементы.СтатусВведенныхСимволов.Видимость = ЭтоSMS;
	Форма.Элементы.ОбновитьСтатусСообщения.Видимость = ЭтоSMS;
	
	Форма.Элементы.ГруппаОтправкаСообщенийWhatsApp.Видимость = ЭтоСообщениеВМессенджер;
	
	Если ЭтоСообщениеВМессенджер Тогда
		ДоступныеСервисыРассылки = Форма.ДоступныеСервисыРассылки.Мессенджер;
		
	ИначеЕсли ЭтоPushУведомление Тогда
		ДоступныеСервисыРассылки = Форма.ДоступныеСервисыРассылки.Push;
		
	ИначеЕсли ЭтоSMS Тогда
		ДоступныеСервисыРассылки = Форма.ДоступныеСервисыРассылки.SMS;
		
	Иначе
		ДоступныеСервисыРассылки = Новый Массив;
		
	КонецЕсли;
	
	Форма.Элементы.ПолучателиСервисРассылки.СписокВыбора.ЗагрузитьЗначения(ДоступныеСервисыРассылки);
	
	Форма.Элементы.ГруппаОтправкаМессенджер.Видимость	 = Форма.ДоступнаОтправкаМессенджер;
	Форма.Элементы.ГруппаОтправкаPush.Видимость			 = Форма.ДоступнаОтправкаPush;
	Форма.Элементы.ГруппаОтправкаSMS.Видимость			 = Форма.ДоступнаОтправкаSMS;
	
	Если Форма.ДоступнаОтправкаМессенджер Тогда
		Форма.Элементы.ГруппаОтправкаМессенджер.ЦветФона			 = ?(ЭтоСообщениеВМессенджер, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
		Форма.Элементы.УстановитьТипОтправкиМессенджер.ЦветТекста	 = ?(ЭтоСообщениеВМессенджер, ЦветТекстаАктивнойГруппы, ЦветТекстаНеактивнойГруппы);
	КонецЕсли;
	
	Если Форма.ДоступнаОтправкаPush Тогда
		Форма.Элементы.ГруппаОтправкаPush.ЦветФона			 = ?(ЭтоPushУведомление, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
		Форма.Элементы.УстановитьТипОтправкиPush.ЦветТекста	 = ?(ЭтоPushУведомление, ЦветТекстаАктивнойГруппы, ЦветТекстаНеактивнойГруппы);
	КонецЕсли;
	
	Если Форма.ДоступнаОтправкаSMS Тогда
		Форма.Элементы.ГруппаОтправкаSMS.ЦветФона			 = ?(ЭтоSMS, ЦветФонаАктивнойГруппы, ЦветФонаНеактивнойГруппы);
		Форма.Элементы.УстановитьТипОтправкиSMS.ЦветТекста	 = ?(ЭтоSMS, ЦветТекстаАктивнойГруппы, ЦветТекстаНеактивнойГруппы);
	КонецЕсли;
	
	Форма.ОтправкаМессенджер = ЭтоСообщениеВМессенджер;
	Форма.ОтправкаPush		 = ЭтоPushУведомление;
	Форма.ОтправкаSMS		 = ЭтоSMS;
	
	Форма.Элементы.ГруппаИнициироватьОтправкуСообщений.Видимость = (ЭтоСообщениеВМессенджер И Форма.MessengerОтправитьВсем);
	
КонецПроцедуры

