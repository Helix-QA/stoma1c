

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
// 
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если  ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	Если Объект.СтруктурнаяЕдиница.Пустая() Тогда
		 Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;        
		 Объект.ТипКассы 		   = Перечисления.ТипыКасс.ОперационнаяКасса;
	КонецЕсли;
	
	// Подсистема запрета редактирования ключевых реквизитов объектов
	// ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтаФорма);
	// ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтаФорма);
		
	Если Объект.ВидыОплат.Количество() = 0 Тогда
		
		// Заполнение ТБ доступных видов оплат
		ЗапросВидовОплат = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТипыОплат.Ссылка КАК ВидОплаты
		|ИЗ
		|	Перечисление.ТипыДенежныхСредств КАК ТипыОплат
		|ГДЕ
		|	ТипыОплат.Ссылка <> ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхсредств.Безналичные)");
		
		Объект.ВидыОплат.Загрузить(ЗапросВидовОплат.Выполнить().Выгрузить());
		
	КонецЕсли;
	ИспользоватьФР = Не Объект.ИспользоватьБезПодключенияОборудования;
	
	УстановитьСотсояниеЭлементов();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
    ВывестиДинамическиеЭлементыТЧ();
	
КонецПроцедуры

