		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПартииТоваровОстаткиИОбороты.Регистратор КАК ДокументДвижения,
	ПартииТоваровОстаткиИОбороты.ДокументПоступления,
	ПартииТоваровОстаткиИОбороты.СтруктурнаяЕдиница,
	ПартииТоваровОстаткиИОбороты.Номенклатура,
	ПартииТоваровОстаткиИОбороты.Склад,
	ПартииТоваровОстаткиИОбороты.Партия,
	ПартииТоваровОстаткиИОбороты.КоличествоНачальныйОстаток,
	ПартииТоваровОстаткиИОбороты.КоличествоКонечныйОстаток,
	ПартииТоваровОстаткиИОбороты.КоличествоОборот,
	ПартииТоваровОстаткиИОбороты.КоличествоПриход,
	ПартииТоваровОстаткиИОбороты.КоличествоРасход,
	ПартииТоваровОстаткиИОбороты.СтоимостьНачальныйОстаток,
	ПартииТоваровОстаткиИОбороты.СтоимостьКонечныйОстаток,
	ПартииТоваровОстаткиИОбороты.СтоимостьОборот,
	ПартииТоваровОстаткиИОбороты.СтоимостьПриход,
	ПартииТоваровОстаткиИОбороты.СтоимостьРасход,
	ПартииТоваровОстаткиИОбороты.ПериодСекунда,
	ПартииТоваровОстаткиИОбороты.ПериодМинута,
	ПартииТоваровОстаткиИОбороты.ПериодЧас,
	ПартииТоваровОстаткиИОбороты.ПериодДень,
	ПартииТоваровОстаткиИОбороты.ПериодНеделя,
	ПартииТоваровОстаткиИОбороты.ПериодДекада,
	ПартииТоваровОстаткиИОбороты.ПериодМесяц,
	ПартииТоваровОстаткиИОбороты.ПериодКвартал,
	ПартииТоваровОстаткиИОбороты.ПериодПолугодие,
	ПартииТоваровОстаткиИОбороты.ПериодГод,
	ВЫБОР
		КОГДА ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент &gt; 0
			ТОГДА ВЫРАЗИТЬ(ПартииТоваровОстаткиИОбороты.КоличествоКонечныйОстаток / ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокКонечныйОстаток,
	ВЫБОР
		КОГДА ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент &gt; 0
			ТОГДА ВЫРАЗИТЬ(ПартииТоваровОстаткиИОбороты.КоличествоНачальныйОстаток / ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокНачальныйОстаток,
	ВЫБОР
		КОГДА ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент &gt; 0
			ТОГДА ВЫРАЗИТЬ(ПартииТоваровОстаткиИОбороты.КоличествоРасход / ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокРасход,
	ВЫБОР
		КОГДА ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент &gt; 0
			ТОГДА ВЫРАЗИТЬ(ПартииТоваровОстаткиИОбороты.КоличествоПриход / ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокПриход,
	ВЫБОР
		КОГДА ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент &gt; 0
			ТОГДА ВЫРАЗИТЬ(ПартииТоваровОстаткиИОбороты.КоличествоОборот / ПартииТоваровОстаткиИОбороты.Номенклатура.УпаковкаДляОтчета.Коэффициент КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК КоличествоУпаковокОборот
ИЗ
	РегистрНакопления.ПартииТоваров.ОстаткиИОбороты(, {(КОНЕЦПЕРИОДА(&amp;КонецПериода, ДЕНЬ))}, Авто, , ) КАК ПартииТоваровОстаткиИОбороты</query>
	</dataSet>
