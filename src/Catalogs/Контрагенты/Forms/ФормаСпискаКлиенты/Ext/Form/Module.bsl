&НаКлиенте
// Процедура - Отбор возраст от окончание ввода текста.
//
Процедура ОтборВозрастОтОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Возраст = Число(Текст);
	
	Если ЗначениеЗаполнено(Возраст)
		И ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо) 
		И Возраст > ЭтотОбъект.ОтборВозрастДо Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не верно введен отбор Возраст: значение должено быть меньше либо равно " + ЭтотОбъект.ОтборВозрастДо);
		// Неявный вызов перезаписи значения.
		ЭтотОбъект.ОтборВозрастОт = ЭтотОбъект.ОтборВозрастОт;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отбор возраст от при изменении.
//
Процедура ОтборВозрастОтПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастДо) 
		И ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастОт) Тогда
		
		ЭтотОбъект.ОтборВозрастДо = 99;
		
	КонецЕсли;
	
	УстановитьЗапросДинамическогоСписка();

	
КонецПроцедуры

&НаКлиенте
// Процедура - Отбор возраст до окончание ввода текста.
//
Процедура ОтборВозрастДоОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Возраст = Число(Текст);
	
	Если ЗначениеЗаполнено(Возраст)
		И ЗначениеЗаполнено(ЭтотОбъект.ОтборВозрастОт)
		И Возраст < ЭтотОбъект.ОтборВозрастОт Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не верно введен отбор Возраст: значение должено быть больше либо равно " + ЭтотОбъект.ОтборВозрастОт);
		// Неявный вызов перезаписи значения.
		ЭтотОбъект.ОтборВозрастДо = ЭтотОбъект.ОтборВозрастДо;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

