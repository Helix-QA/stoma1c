
#Область ОбработчикиСобытий

&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере" формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Подсистема запрета редактирования ключевых реквизитов объектов
	ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтаФорма, ЭтаФорма.Элементы.ГруппаДляКнопкиЗапрета);
	
	ЭтотОбъект.ОтображниеКода						= ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");			
	ЭтотОбъект.ДрайверОборудованияКассовогоСервера	= ПолучитьДрайверКассовогоСервера();
	ЭтотОбъект.КлючСохраненияПоложенияОкна			= Новый УникальныйИдентификатор();
	ЭтотОбъект.Касса								= ?(Объект.Ссылка.Пустая() = Ложь, Справочники.Кассы.ПолучитьКассуПоЭквайринговомуТерминалу(Объект.Ссылка), Неопределено);
	
	Объект.ТипФискализации = ?(Не ЗначениеЗаполнено(Объект.ТипФискализации), Перечисления.ТипыФискализации.НеФискализировать, Объект.ТипФискализации);
		
	Если РольДоступна("ПолныеПрава") = Ложь И РольДоступна("ДобавлениеИзменениеБазовойНСИ") = Ложь И РольДоступна("ДобавлениеИзменениеДокументовПоОплате") = Ложь Тогда		
		Элементы.ГруппаИнформация.Доступность                       = Ложь;
		Элементы.ГруппаДополнительно.Доступность                    = Ложь;
		Элементы.ГруппаБанка.Доступность                    		= Ложь;	
		Элементы.ГруппаПереключательТипЭквайринга.Доступность		= Ложь;
		Элементы.ИспользоватьБезПодключенияОборудования.Доступность = Истина; 			
	КонецЕсли;
		
	ОбработатьИзменениеТипаФискализации(ЭтаФорма, Объект.ТипФискализации);
	ЗаполнитьПараметрыПлатежногоШлюза();
	
	Если Не Объект.Ссылка.Пустая() Тогда	
		ЭтаФорма.АвтоЗаголовок = Ложь;
		ЭтаФорма.Заголовок = Объект.Наименование + " (эквайринг)";                  
	КонецЕсли;
	
	Если Объект.ТипФискализации = Перечисления.ТипыФискализации.КассовыйСервер Тогда
		ЗаполнитьСписокВыбораКассовогоСервера(Объект.ТипФискализации, Объект.Организация, Элементы.КассовыйСервер);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьОплатыПоСсылке(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПередЗаписью" формы.
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)

	Если ПустаяСтрока(Объект.Наименование) Тогда
		Объект.Наименование = СформироватьАвтоНаименование();
	КонецЕсли;
		
	ЭтоСбербанк			= Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.Сбербанк");
	ЭтоАльфаБанкСБП		= Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПАльфаБанк");
	ЭтоТинькоффСБП		= Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПТинькофф");
	РайффайзенБанкСБП	= Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПРайффайзенБанк");
	ЭтоСберБанкСБП      = Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПСбербанк");
	ЭтоСбербанкПлатиQR  = Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СбербанкПлатиQR");
	ЭтоСДМСБП			= Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПСДМ");
	
	Если Объект.ТипЭквайринга = ПредопределенноеЗначение("Перечисление.ТипыЭквайринговыхТерминалов.Онлайн") И Не ЗначениеЗаполнено(Объект.ТипБанка) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для использования онлайн эквайрингов необходимо заполнить платежный шлюз.");
		Отказ = Истина;
		
	ИначеЕсли (ЭтоАльфаБанкСБП ИЛИ РайффайзенБанкСБП ИЛИ (Объект.ИспользоватьОплатуПоСсылке И ЭтоСбербанк)) 
		И (Не ЗначениеЗаполнено(ЭтотОбъект.ЛогинБанка) ИЛИ Не ЗначениеЗаполнено(ЭтотОбъект.ПарольБанка) ИЛИ Не ЗначениеЗаполнено(ЭтотОбъект.UrlRedirect)) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить логин банка, пароль банка и url переадресации.");
		Отказ = Истина;
					
	ИначеЕсли (ЭтоТинькоффСБП ИЛИ ЭтоСДМСБП) И (Не ЗначениеЗаполнено(КлючТерминалаТинькофф) ИЛИ Не ЗначениеЗаполнено(СекретныйКлючТинькофф)) Тогда
		
		СообщениеПользователю = СтрШаблон("Для использования оплаты по ссылке необходимо заполнить ключ терминала и %1", ?(ЭтоСДМСБП, "пароль ключа.", "секретный ключ.")); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеПользователю);
		Отказ = Истина;
		
	ИначеЕсли ЭтоСберБанкСБП И Не ЗначениеЗаполнено(ЭтотОбъект.IDТерминала) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для использования СБП СберБанк необходимо заполнить ID терминала.");
		Отказ = Истина;		
		
	ИначеЕсли ЭтоСДМСБП И ОбщегоНазначенияКлиентСервер.СтрокаСодержитТолькоДопустимыеСимволы(КлючТерминалаТинькофф, "0123456789") = Ложь Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ключ терминала для СДМ банка должен содержать только числовые значения.");
		Отказ = Истина;	
		
	ИначеЕсли ЭтоСбербанкПлатиQR И (Не ЗначениеЗаполнено(ЭтотОбъект.IDТерминала) ИЛИ Не ЗначениеЗаполнено(ЭтотОбъект.IDQR)) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для использования Сбербанк Плати QR необходимо заполнить ID терминала и ID QR.");
		Отказ = Истина;	
		
	КонецЕсли;	
	
	Если Объект.ТипФискализации <> ПредопределенноеЗначение("Перечисление.ТипыФискализации.НеФискализировать")
		И Объект.ТипФискализации <> ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВСбербанке")
		И Объект.ТипФискализации <> ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВТинькофф")
		И Объект.ТипФискализации <> ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВСДМБанке")
		И Не ЗначениеЗаполнено(Объект.КассовыйСервер) Тогда
		
		Если Объект.ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.КассовыйСервер") Тогда
			Перем_ТипФискализации = "кассовый сервер.";	
		Иначе 
			Перем_ТипФискализации = "онлайн кассу.";
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните " + Перем_ТипФискализации);
		Отказ = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервер".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ТекущийОбъект.Ссылка.Пустая() = Ложь Тогда
		
		Если ТекущийОбъект.ТипФискализации = Перечисления.ТипыФискализации.КассовыйСервер Тогда
			
			ПараметрыКассовогоСервера	= ТекущийОбъект.КассовыйСервер.Параметры.Получить();
			КассаКассовогоСервера		= ?(ТипЗнч(ПараметрыКассовогоСервера) = Тип("Структура") И ПараметрыКассовогоСервера.Свойство("КассаОплаты"), ПараметрыКассовогоСервера.КассаОплаты, Неопределено);
			
			Если ЭтотОбъект.Касса <> КассаКассовогоСервера Тогда			
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Не удалось записать. Эквайринговый терминал привязан к кассе, которая не принадлежит кассе выбранного кассового сервера - %1.", Строка(КассаКассовогоСервера)));
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			
		ИначеЕсли ТекущийОбъект.ТипФискализации = Перечисления.ТипыФискализации.ОнлайнКасса Тогда
			
			КассаПО = ПолучитьКассуПодключаемогоОборудования(ТекущийОбъект.КассовыйСервер);
			
			Если КассаПО <> Неопределено И КассаПО <> ЭтотОбъект.Касса Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Не удалось записать. Эквайринговый терминал привязан к кассе, которая не принадлежит кассе выбранной онлайн кассы - %1.", Строка(КассаПО)));
				Отказ = Истина;
				Возврат;	
			КонецЕсли;
			
		Иначе
			
			КассаЭТ = ПолучитьКассуЭквайринга(ТекущийОбъект.Ссылка);
			
			Если КассаЭТ <> Неопределено И КассаЭТ <> ЭтотОбъект.Касса Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Не удалось записать. Эквайринговый терминал привязан в другой кассе - %1.", Строка(КассаЭТ)));
				Отказ = Истина;
				Возврат;	
			КонецЕсли;		
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(АдресШаблона) Тогда
		ТекущийОбъект.Шаблон = Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(АдресШаблона));
	КонецЕсли;
	
	СохранитьПараметрыПлатежногоШлюза(ТекущийОбъект);
	
КонецПроцедуры

&НаСервере
// Процедура - обработчик события "ПослеЗаписиНаСервере" формы.
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
		
	// подсистема запрета редактирования ключевых реквизитов объектов	
	ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтаФорма);
	
	Если ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк 
		ИЛИ ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф 
		ИЛИ ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк
		ИЛИ ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк
		ИЛИ ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR
		ИЛИ ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
		
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.СистемаБыстрыхПлатежей, Ложь); 
		
		Если Не ЗначениеЗаполнено(ВнешняяСистема) Тогда
			Возврат;
		КонецЕсли;
		
		ОбновитьВнешнююСистему(ВнешняяСистема);
		
		Если ТекущийОбъект.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк Тогда
			ПрокинутьВебХукВСБП();
		КонецЕсли;
		
	КонецЕсли;		
	
	ДобавитьВКассуЭквайринговыйТерминал();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - обработчик события "НачалоВыбораИзСписка" поля "Наименование".
//
Процедура НаименованиеНачалоВыбораИзСписка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СформироватьАвтоНаименование();
	ПоказатьВыборИзСписка(Новый ОписаниеОповещения("НаименованиеНачалоПослеВыбора", ЭтотОбъект), Элементы.Наименование.СписокВыбора, Элемент);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Наименование начало после выбора
//
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура НаименованиеНачалоПослеВыбора(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент <> Неопределено Тогда
		Объект.Наименование = ВыбранныйЭлемент.Значение;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Использовать без подключения оборудования при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ИспользоватьБезПодключенияОборудованияПриИзменении(Элемент)
	
	Элементы.ВнешнееОборудование.Доступность = Не Объект.ИспользоватьБезПодключенияОборудования;
	
КонецПроцедуры  

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура БанковскийСчетНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФорму("Справочник.БанковскиеСчета.ФормаВыбора", Новый Структура("Отбор", Новый Структура("Владелец", Объект.Организация)), Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура БанковскийСчетПриИзменении(Элемент)
		
	СформироватьАвтоНаименование();
	
КонецПроцедуры 

&НаКлиенте
// Процедура - Организация при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ОрганизацияПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.КассовыйСервер) и ЗначениеЗаполнено(Объект.Организация) Тогда
		ОрганизацияКассовогоСервера = ПолучитьЗначенияРеквизитовПоСсылке(ОбъекТ.КассовыйСервер, "Организация");
		
		Если Объект.Организация <> ОрганизацияКассовогоСервера Тогда
			Объект.КассовыйСервер = Неопределено;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выбранная организация не соответствует раннее выбранному кассовому серверу, пожалуйста заполните кассовый сервер.");
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Тип банка при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ТипБанкаПриИзменении(Элемент)
	
	Если Объект.ТипБанка <> ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.Сбербанк") Тогда
		
		Объект.ИспользоватьОплатуПоСсылке = Ложь;
		
	КонецЕсли;
		
	УстановитьВидимостьОплатыПоСсылке();
	
	ЭтотОбъект.ТестовыйРежим = Ложь;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Эквайрер при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ЭквайрерПриИзменении(Элемент)
	СформироватьАвтоНаименование();
КонецПроцедуры

&НаКлиенте
// Процедура - Кассовый сервер начало выбора
//
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеВыбора		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура КассовыйСерверНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ЗаполнитьСписокВыбораКассовогоСервера(Объект.ТипФискализации, Объект.Организация, Элементы.КассовыйСервер);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Кассовый сервер авто подбор
//
// Параметры:
//  Элемент					 - 	 - 
//  Текст					 - 	 - 
//  ДанныеВыбора			 - 	 - 
//  ПараметрыПолученияДанных - 	 - 
//  Ожидание				 - 	 - 
//  СтандартнаяОбработка	 - 	 - 
//
Процедура КассовыйСерверАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если СтрДлина(Текст) > 2 Тогда
		ДанныеВыбора = ПолучитьКассовыеСервераПоДрайверуОборудования(Объект.ТипФискализации, Объект.Организация, Текст);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Кассовый сервер при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура КассовыйСерверПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(Объект.КассовыйСервер) Тогда
		ЭтотОбъект.Касса = Неопределено;
	ИначеЕсли Объект.ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.КассовыйСервер") Тогда
		ЭтотОбъект.Касса = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.КассовыйСервер, "Касса");
	Иначе		
		ЭтотОбъект.Касса = ПолучитьКассуПодключаемогоОборудования(Объект.КассовыйСервер);		
