		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Событие.Ссылка КАК Ссылка,
	Событие.Ссылка КАК Количество,
	Событие.ВерсияДанных КАК ВерсияДанных,
	Событие.ПометкаУдаления КАК ПометкаУдаления,
	Событие.Номер КАК Номер,
	Событие.Дата КАК Дата,
	Событие.Проведен КАК Проведен,
	Событие.АвторДокумента КАК АвторДокумента,
	Событие.ВидЦен КАК ВидЦен,
	Событие.Врач КАК Врач,
	Событие.ВремяНапоминанияДоЗаписи КАК ВремяНапоминанияДоЗаписи,
	Событие.ДатаСоздания КАК ДатаСоздания,
	Событие.ДатаОкончания КАК ДатаОкончания,
	Событие.ИдентификаторДиалога КАК ИдентификаторДиалога,
	ВЫБОР
		КОГДА Событие.ИсточникЗаписи = ЗНАЧЕНИЕ(Справочник.ИсточникиЗаписей.ПустаяСсылка)
			ТОГДА "Администратор"
		ИНАЧЕ Событие.ИсточникЗаписи
	КОНЕЦ КАК ИсточникЗаписи,
	Событие.КартаКлиента КАК КартаКлиента,
	Событие.КодСинхронизации КАК КодСинхронизации,
	Событие.Комментарий КАК Комментарий,
	Событие.Контрагент КАК Контрагент,
	Событие.ОснованиеРезерва КАК ОснованиеРезерва,
	Событие.ПеренесённаяПредварительнаяЗапись КАК ПеренесённаяПредварительнаяЗапись,
	Событие.ПолисМедСтрахования КАК ПолисМедСтрахования,
	Событие.ПричинаОтмены КАК ПричинаОтмены,
	Событие.Резерв КАК Резерв,
	Событие.Сделка КАК Сделка,
	Событие.СсылкаНаПрием КАК СсылкаНаПрием,
	Событие.Статус КАК Статус,
	Событие.СтатусПациента КАК СтатусПациента,
	Событие.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	Событие.ТелефонныйЗвонок КАК ТелефонныйЗвонок,
	Событие.ТипСобытия КАК ТипСобытия,
	Событие.УИД КАК УИД,
	Событие.ЦветФонаРезерва КАК ЦветФонаРезерва
ИЗ
	Документ.Событие КАК Событие
ГДЕ
	НЕ Событие.СсылкаНаПрием ЕСТЬ NULL
	И Событие.СсылкаНаПрием.ВремяОкончанияПриема МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И Событие.СсылкаНаПрием.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
	И Событие.Проведен = ИСТИНА</query>
