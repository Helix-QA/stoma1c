		ЭтотОбъект.ЭтапыСделок.Сдвинуть(ИндексСтроки, 1);
		ОбновитьДинамическиеЭлементы();
	КонецЕсли;
	
	ЭтаФорма.ТекущийЭлемент = Элементы["Наименование_" + КоличествоДляСмещения];  
	
