// Процедура - обработчик события "ОбработкаВыбора"
//
Процедура ВыданныеАвансыДокументОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	Если ВыбранноеЗначение <> Неопределено Тогда		
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда	
			Счетчик = 0;
			Для Каждого ЭлементМ Из ВыбранноеЗначение Цикл
				ВыданныеАвансыДокументОбработкаВыбораЗавершение(ЭлементМ, Счетчик);	
			КонецЦикла;  	
		Иначе 
			СуммаВыбранногоДокумента     = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВыбранноеЗначение,"СуммаДокумента");
			СтруктураВыбранногоДокумента = Новый Структура("ДокументОснования, СуммаДокумента", ВыбранноеЗначение, СуммаВыбранногоДокумента);	
			ВыданныеАвансыДокументОбработкаВыбораЗавершение(СтруктураВыбранногоДокумента);             
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте  
// Процедура - Выданные авансы обработка выбора завершение
//
// Параметры:
//  ВыбранноеЗначение	 - 	 - 
//  Счетчик				 - 	 - 
//
Процедура ВыданныеАвансыДокументОбработкаВыбораЗавершение(ВыбранноеЗначение, Счетчик = 0)
	
	РазрешитьДобавление = Истина;
	// Проверка существования строки с выбранными данными
	Для Каждого СтрокаТ ИЗ Объект.ВыданныеАвансы Цикл
		Если СтрокаТ.Документ = ВыбранноеЗначение.ДокументОснования Тогда
			СтрокаТ.Сумма       = ВыбранноеЗначение.СуммаДокумента; 
			РазрешитьДобавление = Ложь;
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	// Есди добавление данных в строку разрешено
	Если РазрешитьДобавление = Истина Тогда
		ОбрабатываемаяСтрока = Неопределено;
		Если Счетчик = 0 Тогда
			ОбрабатываемаяСтрока = Элементы.ВыданныеАвансы.ТекущиеДанные;
		Иначе
			ОбрабатываемаяСтрока = Объект.ВыданныеАвансы.Добавить();
		КонецЕсли;	
		
		ОбрабатываемаяСтрока.Документ = ВыбранноеЗначение.ДокументОснования;
		ОбрабатываемаяСтрока.Сумма    = ВыбранноеЗначение.СуммаДокумента;
		
		Счетчик = Счетчик + 1;
	КонецЕсли;
	
КонецПроцедуры

