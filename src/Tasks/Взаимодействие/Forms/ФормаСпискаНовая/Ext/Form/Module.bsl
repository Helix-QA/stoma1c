// Процедура, выполняет обновление конкретного занятия
//
Процедура ОбновитьЗанятиеПланировщика(Планировщик, Задача, Переключатель)
	
	ВесьДень = Ложь;
	ВремяНачала    = Задача.ЗадачаНазначеннаяДата;
	ВремяОкончания = Задача.ЗадачаНазначеннаяДата + 3600;
	
	Если НачалоДня(Задача.ЗадачаНазначеннаяДата) = Задача.ЗадачаНазначеннаяДата Тогда
		ВесьДень = Истина;
		Для Каждого СтрокаМ из Планировщик.ШкалаВремени.Элементы[0].Метки Цикл
			Если НачалоДня(СтрокаМ.Дата) = Задача.ЗадачаНазначеннаяДата Тогда
				ВремяНачала    = СтрокаМ.Дата;
				ВремяОкончания = СтрокаМ.Дата + 3600;					 
			КонецЕсли;				
		КонецЦикла;			
	КонецЕсли;
	
	ЭлементПланировщика = Планировщик.Элементы.Найти(Задача);
	Если ЭлементПланировщика = Неопределено Тогда
		ЭлементПланировщика = Планировщик.Элементы.Добавить(ВремяНачала, ВремяОкончания);		 
	Иначе
		ЭлементПланировщика.Начало = ВремяНачала; 
		ЭлементПланировщика.Конец  = ВремяОкончания;
	КонецЕсли;
	ЭлементПланировщика.Текст    = ?(ВесьДень, "", Формат(ВремяНачала, "ДФ=HH:mm"))+" "+Задача.ЗадачаТема;
	ЭлементПланировщика.Значение = Задача;	
	ЭлементПланировщика.ЦветФона = ?(НачалоДня(ВремяНачала) < НачалоДня(ТекущаяДата()), WebЦвета.СветлоКоралловый, ?(Задача.Выполнена, WebЦвета.БледноЗеленый, Новый Цвет()));	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает цвет текста от передаваемого цвета фона.
//
Функция ПолучитьЦветТекстаПоФону(ЦветФона)
	
	Если (ЦветФона.Зеленый + ЦветФона.Красный + ЦветФона.Синий) > 383 Тогда
		Возврат Новый Цвет(60,60,60);		
	Иначе
		Возврат Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецФункции

