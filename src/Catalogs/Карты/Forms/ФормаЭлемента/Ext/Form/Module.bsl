// Функция, возвращает описание подсказки.
//
Функция ПолучитьОписаниеПодсказки(ТипКарты)
	
	ЭлектроннаяКарта = ТипКарты = Перечисления.ВидыКарт.Wallet;
	
	МассивСтрок = Новый Массив();
	МассивСтрок.Добавить(?(ЭлектроннаяКарта, "Электронная", Строка(ТипКарты)) + Символы.ПС);
	
	Если ЭлектроннаяКарта Тогда
		
		ВСНастроена = ЗначениеЗаполнено(ВнешняяСистемаWallet.ТокенДоступа) И ЗначениеЗаполнено(ВнешняяСистемаWallet.КлючШифрования);
		
		МассивСтрок.Добавить(?(ВСНастроена, "  ", ""));
		
		ДопОписание = Новый ФорматированнаяСтрока(?(ВСНастроена, "Настроить", "Подключить"),, ?(ВСНастроена, Новый Цвет(28, 85, 174), Новый Цвет(255, 0, 0)),, "Ссылка"); 
		
		МассивСтрок.Добавить(ДопОписание);
		
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(МассивСтрок);
	
КонецФункции

&НаКлиенте
// Процедура, обработчик команды "УдалитьКарту".
//
Процедура УдалитьКарту(Команда)
	
	Если Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet") И ЗначениеЗаполнено(ВнешняяСистемаWallet) Тогда 
		
		ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("ПослеВопросаУдаленияКарты", ЭтаФорма);
		
		ТекстВопроса = "Электронная карта будет безвозвратно удалена. Продолжить?";
		
		ПоказатьВопрос(ОписаниеОповещенияПослеВопроса, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , , НСтр("ru='Внимание!';en='Attention!'"));
		
	Иначе
		
		ПометитьНаУдалениеНаСервере();
		
		Оповестить("ИзмененаКарта");
		
		ЭтаФорма.Модифицированность = Ложь;
		ЭтаФорма.Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
// Процедура, обработчик команды "УдалитьКартуНаСервере".
//
Процедура ПометитьНаУдалениеНаСервере()
	
	КартаОбъект = Объект.Ссылка.ПолучитьОбъект();
	КартаОбъект.УстановитьПометкуУдаления(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После вопроса удаления карты
//
Процедура ПослеВопросаУдаленияКарты(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		РезультатУдаления = УдалитьКартуНаСервере();
	    Если РезультатУдаления.Успешно Тогда
			Оповестить("ИзмененаКарта");
			ЭтаФорма.Записать();
			ЭтаФорма.Модифицированность = Ложь;
			ЭтаФорма.Закрыть();
		ИначеЕсли ЗначениеЗаполнено(РезультатУдаления.ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(РезультатУдаления.ОписаниеОшибки);	
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ДекорацияКартинкаРасширеннаяПодсказкаОбработкаНавигационнойСсылки".
//
Процедура ДекорацияКартинкаРасширеннаяПодсказкаОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ВСWallet = ПолучитьВнешнююСистемуWallet();
	
	Если ЗначениеЗаполнено(ВСWallet) Тогда
		ПараметрыФормы = Новый Структура("Ключ", ВСWallet);
	Иначе
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", Новый Структура("ТипВнешнейСистемы", ПредопределенноеЗначение("Перечисление.ТипыВнешнихСистем.Wallet")));
	КонецЕсли;
	
	ОткрытьФорму("Справочник.ВнешниеСистемы.ФормаОбъекта", ПараметрыФормы,,,,,, ?(ЗначениеЗаполнено(ВСWallet), РежимОткрытияОкнаФормы.Независимый, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс));	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
