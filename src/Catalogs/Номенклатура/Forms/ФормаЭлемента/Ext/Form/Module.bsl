	Если НеобходимоЗаписатьОбъектВРегистр Тогда
		МассивСтруктурныхЕдиниц = Новый Массив;
		МассивСтруктурныхЕдиниц.Добавить(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		РегистрыСведений.РеквизитыОбъектов.СоздатьЗаписиВРегистреРеквизитыОбъектов(
			Объект.Ссылка, МассивСтруктурныхЕдиниц, "ОнлайнЗапись", Истина);
	КонецЕсли;
	
	Справочники.Номенклатура.ЗаполнитьДеревоНоменклатур(Объект, ЭтотОбъект.ДеревоУслуг);
	
