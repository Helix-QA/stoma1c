// Функция - Запись разговора доступна по ролям
//
// Параметры:
//  УИДЗвонка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаписьРазговораДоступнаПоРолям(УИДЗвонка)
	
	СотрудникСсылка = Неопределено;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИсторияВызовов.Пользователь КАК Пользователь,
	|	ИсторияВызовов.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.IDЗвонка = &IDЗвонка");
	
	Запрос.УстановитьПараметр("IDЗвонка", УИДЗвонка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Пользователь = Выборка.Пользователь;	
	    Контрагент   = Выборка.Контрагент;
	Иначе
		Пользователь = Неопределено;
		Контрагент   = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Пользователь) И ТипЗнч(Пользователь) = Тип("СправочникСсылка.Сотрудники") Тогда
		СотрудникСсылка = Пользователь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СотрудникСсылка) И ЗначениеЗаполнено(Контрагент) И ТипЗнч(Контрагент) = Тип("СправочникСсылка.Сотрудники") Тогда
		СотрудникСсылка = Контрагент;
	КонецЕсли;
	
	Возврат РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ЧтениеЗаписейРазговоров") ИЛИ СотрудникСсылка = ПараметрыСеанса.ТекущийПользователь;	
	
КонецФункции

#КонецОбласти
	
// Функция - Параметры меню формы.
//
// Параметры:
//  АдресаХраненияДанных - 	 -
//  ИмяМеню				 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню) Экспорт
	
	// Получаем саму структуру адресов.
	СтруктураАдресов = ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма);
	
	// Получаем настройки.
	Если СтруктураАдресов <> Неопределено
		И СтруктураАдресов.Свойство(ИмяМеню) Тогда
		
		Возврат ПолучитьИзВременногоХранилища(СтруктураАдресов[ИмяМеню]);
	КонецЕсли;	
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Получить структуру адресов из временного хранилища.
//
Функция ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма) Экспорт
	
	СтруктураАдресов = Неопределено;
	
	// Получаем адрес структуры хранения адресов.
	АдресСтруктурыАдресов = ХранилищеСистемныхНастроек.Загрузить("ПодсистемаДинамическогоМеню", "СтруктураХраненияАдресов" + ?(ТипЗнч(Форма) = Тип("УправляемаяФорма"), Форма.УникальныйИдентификатор, Форма));
	
	Если АдресСтруктурыАдресов <> Неопределено
		И ЭтоАдресВременногоХранилища(АдресСтруктурыАдресов) = Истина Тогда
		
		// Получаем саму структуру адресов.
		СтруктураАдресов = ПолучитьИзВременногоХранилища(АдресСтруктурыАдресов);
				
	КонецЕсли;
	
	Возврат СтруктураАдресов;
	
КонецФункции	

// Процедура - Удалить параметры динамического меню формы.
//
// Параметры:
//  Форма			 - 	 -
//  СписокИменМеню	 - 	 -
//  ВсеПараметры	 - 	 -
//
Процедура УдалитьПараметрыДинамическогоМенюФормы(Форма, МассивИменМеню = Неопределено, УдалитьВсеПараметры = Ложь) Экспорт
	
	// Получаем структуру адресов.
	СтруктураАдресов = ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма);
	
	// Получаем настройки.
	Если СтруктураАдресов <> Неопределено Тогда
		
		Если УдалитьВсеПараметры Тогда
			
			Для Каждого ЭлементСтруктуры Из СтруктураАдресов Цикл
				УдалитьИзВременногоХранилища(ЭлементСтруктуры.Значение);
			КонецЦикла;
			
		ИначеЕсли ЗначениеЗаполнено(МассивИменМеню) Тогда
			
			Для Каждого ИмяМеню Из МассивИменМеню Цикл
				УдалитьИзВременногоХранилища(СтруктураАдресов[ИмяМеню]);
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#Область ОбработчикиЭлементовДинамическогоМенюРасписанияЗанятий

// Обработчик нажатия по элементу меню отбора.
Функция ОбработчикНажатияСпискаДинамическогоМеню(Форма, КомандаИмя) Экспорт
	
	ИмяРеквизитаДанных     = "ME_" + ИмяДинамическогоМенюФормыИзЭлемента(КомандаИмя);
	ИмяКнопкиПредставления = СтрЗаменить(КомандаИмя, "КомандаОткрыть_","КнопкаОткрыть_" );
	ПривязанныеДанные      = ДанныеПривязанныеКЭлементуДинамическогоМеню(Форма.УникальныйИдентификатор, ИмяКнопкиПредставления);
	
	Если ПривязанныеДанные.Свойство("СписокЗначений")
		И Не ЗначениеЗаполнено(ПривязанныеДанные.СписокЗначений) Тогда
		
		Возврат Неопределено;
		
	ИначеЕсли ПривязанныеДанные.Свойство("ИмяПодчиненногоМеню")
		И ЗначениеЗаполнено(ПривязанныеДанные.ИмяПодчиненногоМеню) Тогда
		
		ГруппаПодчМеню = Форма.Элементы["Группа" + ПривязанныеДанные.ИмяПодчиненногоМеню];
		ГруппаПодчМеню.Видимость = Истина;
		
	КонецЕсли;
	
	Возврат Новый Структура("ИмяРеквизитаДанных, ИмяКнопкиПредставления, ПривязанныеДанные", ИмяРеквизитаДанных, ИмяКнопкиПредставления, ПривязанныеДанные);
	
КонецФункции

// Процедура - Обработчик нажатия списка завершение.
//
// Параметры:
//  Форма		 - 	 -
//  СтруктДанных - 	 -
//
Процедура ОбработчикНажатияСпискаДинамическогоМенюЗавершение(Форма, СтруктДанных) Экспорт
	
	ИмяКнопкиПредставления = СтруктДанных.ИмяКнопкиПредставления;
	
	Если СтрНайти(ИмяКнопкиПредставления, "ОткрытьСписокКнопка") > 0 Тогда
		
		Форма.Элементы[ИмяКнопкиПредставления].Заголовок   = Неопределено;
		Форма.Элементы[ИмяКнопкиПредставления].Отображение = ОтображениеКнопки.Картинка;
	Иначе
		Форма.Элементы[ИмяКнопкиПредставления].Заголовок   = СтруктДанных.РезультатПредставление;
		
	КонецЕсли;
	
	// Сохраняем во временный реквизит выбранное значение.
	Форма[СтруктДанных.ИмяРеквизитаДанных] = СтруктДанных.РезультатЗначение;
	
КонецПроцедуры

// Функция - При выборе элемента меню.
//
// Параметры:
//  ЭлементИмя	 - 	 -
//
Функция ОбработчикЭлементаДинамическогоМенюПриНажатии(Форма, ЭлементИмя, ОбновитьПланировщик = Истина) Экспорт
	
	ИмяМеню       = ИмяДинамическогоМенюФормыИзЭлемента(ЭлементИмя);
	ПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, СтрЗаменить(ИмяМеню, "Подчиненное",""));
	ИндексДанных  = ИндексПривязкиДанныхЭлементаМеню(ЭлементИмя);
	ИндексДанных  = ?(ИндексДанных = Неопределено, 0, ИндексДанных);
			
	// Если это элемент переключатель.
	Если СтрНайти(ЭлементИмя, "_Тип_Переключатель") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаПереключатель(ИмяМеню, ИндексДанных, ОбновитьПланировщик, ПараметрыМеню, Форма, ЭлементИмя);
				
	// Если это элемет списка.
	ИначеЕсли СтрНайти(ЭлементИмя, "_Тип_ОткрытьСписок") > 0  Тогда
		
		ОбработчикПриНажатииЭлементаОтбораСписок(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма, ЭлементИмя);
		
	// Если элемент отбора - кнопка Отбор.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаОтбор") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаОтбора(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма, ЭлементИмя);
		ОбновитьПланировщик = Ложь;
		
	// Если элемент отбора - кнопка Применить.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаПрименить") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаОтбораПрименить(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма);
		
	// Если элемент отбора - кнопка Скрыть.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаСкрыть") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаОтбораСкрыть(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма);
		ОбновитьПланировщик = Ложь;
		
		Возврат ОбновитьПланировщик;
				
	// Если это элемент значения отборов.
	ИначеЕсли СтрНайти(ЭлементИмя, "УдалитьЗначение") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаОтбораУдалить(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма);
		
	// Если это поле ввода в меню отбора, выбор нового значения из источника данных.
	ИначеЕсли СтрНайти(ЭлементИмя, "ПолеДопВвода") Тогда
		
		ОбработчикПриНажатииЭлементаОтбораПолеДопВвода(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма, ЭлементИмя);
		ОбновитьПланировщик = Ложь;
		
	КонецЕсли;
	
	// Применение к элементам меню соответствующего оформления.
	ОбработкаНажатияЭлементаДинамическогоМенюПрименениеОформления(ПараметрыМеню, Форма, ЭлементИмя);
	
	// Сохраняем проведенные изменения.
	// Получаем адрес структуры хранения адресов и структуру адресов.
	СтруктураАдресов = ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма);
	
	Если СтруктураАдресов <> Неопределено И СтруктураАдресов.Свойство(ИмяМеню) Тогда
		ПоместитьВоВременноеХранилище(ПараметрыМеню, СтруктураАдресов[ИмяМеню]);
	КонецЕсли;

	Возврат ОбновитьПланировщик;
	
КонецФункции

// Процедура - Обработчик при нажатии элемента отбора переключатель.
//
// Параметры:
//  ИмяМеню				 - 	 -
//  ИндексДанных		 - 	 -
//  ОбновитьПланировщик	 - 	 -
//  ПараметрыМеню		 - 	 -
//  Форма				 - 	 -
//  ЭлементИмя			 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаПереключатель(ИмяМеню, ИндексДанных, ОбновитьПланировщик, Знач ПараметрыМеню, Знач Форма, ЭлементИмя)
			
	ПривязанныеДанные = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	
	// Сбросить пред. выбор и установить выбор группы.
	Для Каждого ЭлементМ Из ПараметрыМеню.ПривязанныеДанные Цикл
		
		Если ЭлементМ.Группа = ПривязанныеДанные.Группа Тогда
			ЭлементМ.Выбор = ?(ЭлементМ.Выбор И ЭлементМ.Свойство("СбросПриПовторномНажатии"), Ложь, Истина);
		ИначеЕсли СтрНайти(ЭлементМ.Группа, "Декорация") = 0 Тогда
			ЭлементМ.Выбор = Ложь;
		КонецЕсли;
		
	КонецЦикла;

	// Скрытие открытых отборов.
	СкрытиеОткрытыхОтборовДинамическогоМеню(ПараметрыМеню, Форма, ИмяМеню);
	
	// Если это элемент меню отбора.
	Если ПараметрыМеню.ТипМеню = "Отбор" Тогда
		
		ОбработкаНажатияЭлементаПереключательМенюОтбор(ИмяМеню, ПараметрыМеню, ПривязанныеДанные, Форма, ЭлементИмя);
		ОбновитьПланировщик = Ложь;
	КонецЕсли;
	
	// При изменении переключателя Периода обновить значение времени.
	Если ПривязанныеДанные.Представление = "ПереключательДень" Тогда
		
		Дата = Форма.Объект.Дата;
		
		Форма.Элементы.ОткрытьКалендарь.Заголовок = Формат(Дата, "ДЛФ=Д");
		
		Форма.ОтборПериод.Вариант       = ВариантСтандартногоПериода.ПроизвольныйПериод;
		Форма.ОтборПериод.ДатаНачала    = НачалоДня(Дата);
		Форма.ОтборПериод.ДатаОкончания = КонецДня(Дата);
		
	ИначеЕсли ПривязанныеДанные.Представление = "ПереключательНеделя" Тогда
		
		Дата          = Форма.Объект.Дата;
		ДатаНачала    = НачалоНедели(Дата);
		ДатаОкончания = КонецНедели(Дата);
		
		Форма.Элементы.ОткрытьКалендарь.Заголовок = Формат(ДатаНачала, "ДЛФ=Д") + " - " + Формат(ДатаОкончания, "ДЛФ=Д");
		
		Форма.ОтборПериод.Вариант       = ВариантСтандартногоПериода.ПроизвольныйПериод;
		Форма.ОтборПериод.ДатаНачала    = ДатаНачала;
		Форма.ОтборПериод.ДатаОкончания = ДатаОкончания;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Обработка нажатия элемента переключатель меню отбор.
//
// Параметры:
//  ИмяМеню				 - 	 -
//  ПараметрыМеню		 - 	 -
//  ПривязанныеДанные	 - 	 -
//  Форма				 - 	 -
//  ЭлементИмя			 - 	 -
//
Процедура ОбработкаНажатияЭлементаПереключательМенюОтбор(ИмяМеню, ПараметрыМеню, ПривязанныеДанные, Форма, ЭлементИмя)
	
	Если Не ЗначениеЗаполнено(ПривязанныеДанные.МассивЗначений)
		И Не (ПривязанныеДанные.Свойство("ПолеДопВвода")
			  И ПривязанныеДанные.ПолеДопВвода = Истина) Тогда
		
		ПривязанныеДанные.Выбор = Ложь;
		Возврат;
	КонецЕсли;
	
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", СтрЗаменить(ИмяМеню, "Подчиненное","")));

	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора         = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт  = Не СтрокаСостоянияОтбора.Открыт;
	Иначе
		СтрокаСостоянияОтбора         = Форма.СостояниеОтборов.Добавить();
		СтрокаСостоянияОтбора.ИмяМеню = ИмяМеню;
		СтрокаСостоянияОтбора.Элемент = ПривязанныеДанные.ИмяЭлемента;
		СтрокаСостоянияОтбора.Открыт  = Истина;
		
	КонецЕсли;
	
	// Обновление меню отбора перед открытием/закрытием.
	КоличествоВыбранных = 0;
	ИмяПодчиненногоМеню = ПривязанныеДанные.ИмяПодчиненногоМеню;
	
	РеквизитДанных = Форма["ME_" + ИмяПодчиненногоМеню];
	РеквизитДанных.Очистить();
	
	Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
				
		ЭлементОтбор = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение, "Команда", "Кнопка")];
		
		Если ЭлементМ.Выбор = Истина Тогда
			
			РеквизитДанных.Добавить(ЭлементМ.ПривязанноеЗначение);
			
			ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФонаВыбранного;
			ЭлементОтбор.Отображение       = ОтображениеКнопки.КартинкаИТекст;
			
			КоличествоВыбранных = КоличествоВыбранных + 1;
		Иначе
			ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФона;
			ЭлементОтбор.Отображение       = ОтображениеКнопки.Текст;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если КоличествоВыбранных > 0 Тогда
		
		ПривязанныеДанные.Выбор     = Истина;
		СтрокаСостоянияОтбора.Выбор = Истина;
		Форма.Элементы["ГруппаЗначение_ME_" + ИмяМеню].Видимость = Не СтрокаСостоянияОтбора.Открыт;
		Форма.Элементы[ПривязанныеДанные.ИмяЭлемента].Видимость  = (СтрокаСостоянияОтбора.Открыт ИЛИ (Не СтрокаСостоянияОтбора.Открыт И КоличествоВыбранных <> 1));
	Иначе
		ПривязанныеДанные.Выбор     = СтрокаСостоянияОтбора.Открыт;
		СтрокаСостоянияОтбора.Выбор = Ложь;
		Форма.Элементы["ГруппаЗначение_ME_" + ИмяМеню].Видимость = Ложь;
		Форма.Элементы[ПривязанныеДанные.ИмяЭлемента].Видимость  = Истина;
		
	КонецЕсли;

	// Разврачиваем/сворачиваем группу с меню отборов.
	Если СтрокаСостоянияОтбора.Открыт Тогда
		Форма.Элементы["Группа_ME_" + ИмяПодчиненногоМеню].Показать();
	Иначе
		Форма.Элементы["Группа_ME_" + ИмяПодчиненногоМеню].Скрыть();
	КонецЕсли;
	
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяПодчиненногоМеню].Видимость = Ложь;
	Форма.Элементы["ГруппаСкрыть_ME_" + ИмяПодчиненногоМеню].Видимость    = Истина;
	
КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора список.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаОтбораСписок(ИмяМеню, ИндексДанных, Знач ПараметрыМеню, Знач Форма, ЭлементИмя)
	
	// Скрытие открытых отборов.
	СкрытиеОткрытыхОтборовДинамическогоМеню(ПараметрыМеню, Форма);

	ПривязанныеДанные = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	
	// Сбросить пред. выбор и установить выбор группы.
	Для Каждого ЭлементМ Из ПараметрыМеню.ПривязанныеДанные Цикл
		
		ЭлементМ.Выбор = (ЭлементМ.Свойство("Группа") И ЭлементМ.Группа = ПривязанныеДанные.Группа);
		
	КонецЦикла;
	
	ПривязанныеДанные.Выбор = Истина;
	
	// Если это кнопка списка.
	Если СтрНайти(ЭлементИмя, "СписокКнопка") > 0
		И ПривязанныеДанные.Свойство("ИмяПереключателя")
		И ЗначениеЗаполнено(ПривязанныеДанные.ИмяПереключателя) Тогда
		
		ПривязанныеДанные.Выбор = Ложь;
		
		Переключатель          = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ПараметрыМеню.ПривязанныеДанные,"Представление", ПривязанныеДанные.ИмяПереключателя);
		Переключатель.Значение = Форма["ME_" + ИмяМеню];
		Переключатель.Выбор    = Истина;
		
	// Если это обычный переключатель список.
	Иначе
		ПривязанныеДанные.Значение = Форма["ME_" + ИмяМеню];
		
		Если ПривязанныеДанные.Свойство("Заголовок") Тогда
			ПривязанныеДанные.Заголовок = ПривязанныеДанные.СписокЗначений.НайтиПоЗначению(ПривязанныеДанные.Значение).Представление;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаОтбора(ИмяМеню, ИндексДанных, Знач ПараметрыМеню, Знач Форма, ЭлементИмя)
		
	ПривязанныеДанные = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	РеквизитДанных    = Форма["ME_" + ИмяДинамическогоМенюФормыИзЭлемента(ЭлементИмя)];
	ЭлементКоманда    = СтрЗаменить(ЭлементИмя, "Кнопка", "Команда");
	ЭлементОтбор      = Форма.Элементы[ЭлементИмя];
	НайденныйЭлемент  = РеквизитДанных.НайтиПоЗначению(ЭлементКоманда);
	
	ДобавитьРеквизитДанных = (НайденныйЭлемент = Неопределено);
	
	Если ДобавитьРеквизитДанных Тогда
		
		РеквизитДанных.Добавить(ЭлементКоманда);
		ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФонаВыбранного;
		ЭлементОтбор.Отображение       = ОтображениеКнопки.КартинкаИТекст;
	Иначе
		РеквизитДанных.Удалить(НайденныйЭлемент);
		ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФона;
		ЭлементОтбор.Отображение       = ОтображениеКнопки.Текст;
	КонецЕсли;
	
	Если ПривязанныеДанные.Свойство("НаличиеГруппОтборов")
		И ПривязанныеДанные.НаличиеГруппОтборов = Истина Тогда
		
		МассивЗначенийОтборов = ПривязанныеДанные.МассивЗначений;
		НайденноеЗначение     = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(МассивЗначенийОтборов, "ПривязанноеЗначение", ЭлементКоманда);
		
		Если НайденноеЗначение.Свойство("ОтборРодитель")
			И ЗначениеЗаполнено(НайденноеЗначение.ОтборРодитель) Тогда
						
			ОтборРодительПоискПодчиненныхРекурсивно(Форма, ПараметрыМеню, МассивЗначенийОтборов, ДобавитьРеквизитДанных, НайденноеЗначение.ОтборРодитель, РеквизитДанных);
			
		КонецЕсли;
						
	КонецЕсли;
	
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяМеню].Видимость = Истина;
	Форма.Элементы["ГруппаСкрыть_ME_" + ИмяМеню].Видимость    = Ложь;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора, найти подчиненных рекурсивно.
//
// Параметры:
//  Форма					 - 	 -
//  ПараметрыМеню			 - 	 -
//  МассивЗначенийОтборов	 - 	 -
//  ДобавитьРеквизитДанных	 - 	 -
//  ОтборРодитель			 - 	 -
//  РеквизитДанных			 - 	 -
//
Процедура ОтборРодительПоискПодчиненныхРекурсивно(Форма, ПараметрыМеню, МассивЗначенийОтборов, ДобавитьРеквизитДанных, ОтборРодитель, РеквизитДанных)
		
	Для Каждого ЭлементМ Из МассивЗначенийОтборов Цикл
		
		Если ЭлементМ.Свойство("ОтборПодчинен")
			И ЭлементМ.ОтборПодчинен = ОтборРодитель Тогда
						
			Если ЭлементМ.Свойство("ОтборРодитель")
				И ЗначениеЗаполнено(ЭлементМ.ОтборРодитель) Тогда
				
				ОтборРодительПоискПодчиненныхРекурсивно(Форма, ПараметрыМеню, МассивЗначенийОтборов, ДобавитьРеквизитДанных, ЭлементМ.ОтборРодитель, РеквизитДанных);
			КонецЕсли;
			
			НайденныйЭлемент = РеквизитДанных.НайтиПоЗначению(ЭлементМ.ПривязанноеЗначение);
			ЭлементОтбор     = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение, "Команда", "Кнопка")];
			
			Если НайденныйЭлемент = Неопределено
				И ДобавитьРеквизитДанных = Истина Тогда
				
				РеквизитДанных.Добавить(ЭлементМ.ПривязанноеЗначение);
				ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФонаВыбранного;
				ЭлементОтбор.Отображение       = ОтображениеКнопки.КартинкаИТекст;
				
			ИначеЕсли НайденныйЭлемент <> Неопределено
				И ДобавитьРеквизитДанных = Ложь Тогда
				
				РеквизитДанных.Удалить(НайденныйЭлемент);
				ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФона;
				ЭлементОтбор.Отображение       = ОтображениеКнопки.Текст;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора применить.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаОтбораПрименить(ИмяМеню, ИндексДанных, Знач ПараметрыМеню, Знач Форма)
			
	// Сохранение данных в хранилище из реквизита формы.
	ИмяРеквизитаДанных    = "ME_" + ИмяМеню;
	ПривязанныеДанные     = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	КнопкаЗначение        = Форма.Элементы["КнопкаЗначение_ME_" + СтрЗаменить(ИмяМеню, "Подчиненное","") + "_Тип_Переключатель"];
	КоличествоВыбранных   = 0;
	ПредставлениеЗначения = "";
	
	Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
		
		Если Форма[ИмяРеквизитаДанных].НайтиПоЗначению(ЭлементМ.ПривязанноеЗначение) <> Неопределено Тогда
			
			ЭлементМ.Выбор = Истина;
			
			Если Не ЭлементМ.Свойство("ОтборРодитель") Тогда
				
				Если КоличествоВыбранных = 0 Тогда
					ПредставлениеЗначения = ЭлементМ.Представление;
				КонецЕсли;
				
				КоличествоВыбранных = КоличествоВыбранных + 1;
			КонецЕсли;
			
		Иначе
			ЭлементМ.Выбор = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	// Отображение фильтра выбранных.
	ВидимостьПереключателя = Истина;
	
	Если КоличествоВыбранных > 0 Тогда
		
		ПривязанныеДанные.Выбор = Истина;
		
		Если КоличествоВыбранных = 1 Тогда
			
			ВидимостьПереключателя   = Ложь;
			КнопкаЗначение.Заголовок = ПредставлениеЗначения;
		Иначе
			КнопкаЗначение.Заголовок = "(" + КоличествоВыбранных + ")";
		КонецЕсли;
	Иначе
		ПривязанныеДанные.Выбор = Ложь;
	КонецЕсли;
		
	КнопкаЗначение.Родитель.Видимость = ПривязанныеДанные.Выбор;
	
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", СтрЗаменить(ИмяМеню, "Подчиненное","")));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора        = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт = Ложь;
		СтрокаСостоянияОтбора.Выбор  = ПривязанныеДанные.Выбор;
		
	КонецЕсли;
		
	// Видимость элементов.
	Форма.Элементы[ПривязанныеДанные.ИмяЭлемента].Видимость   = ВидимостьПереключателя;
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяМеню].Видимость = Ложь;
	Форма.Элементы["ГруппаСкрыть_ME_" + ИмяМеню].Видимость    = Истина;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора скрыть.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаОтбораСкрыть(Знач ИмяМеню, ИндексДанных, Знач ПараметрыМеню, Знач Форма)
			
	ИмяМеню         = СтрЗаменить(ИмяМеню, "Подчиненное","");
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", ИмяМеню));
		
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора        = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт = Ложь;
				
		Если СтрокаСостоянияОтбора.Выбор Тогда
			
			КоличествоВыбранных = 0;
			ПривязанныеДанные   = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
			
			Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
				
				Если ЭлементМ.Выбор Тогда
					КоличествоВыбранных = КоличествоВыбранных + 1;
				КонецЕсли;
				
			КонецЦикла;

			ЭлементПереключатель            = Форма.Элементы[СтрокаСостоянияОтбора.Элемент];
			ЭлементПереключатель.ЦветТекста = ПараметрыМеню.ЦветТекстаВыбранного;
			ЭлементПереключатель.Видимость  = КоличествоВыбранных <> 1;
			
			Форма.Элементы["ГруппаЗначение_ME_" + ИмяМеню].Видимость = Истина;
			Форма.Элементы["Группа_ME_" + ИмяМеню].ЦветФона          = ПараметрыМеню.ЦветФонаВыбранного;
		Иначе
			ЭлементПереключатель            = Форма.Элементы[СтрокаСостоянияОтбора.Элемент];
			ЭлементПереключатель.ЦветТекста = ПараметрыМеню.ЦветТекста;
			ЭлементПереключатель.Видимость  = Истина;
			
			Форма.Элементы["ГруппаЗначение_ME_" + ИмяМеню].Видимость = Ложь;
			Форма.Элементы["Группа_ME_" + ИмяМеню].ЦветФона          = ПараметрыМеню.ЦветФона;
			
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора удалить.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаОтбораУдалить(ИмяМеню, ИндексДанных, Знач ПараметрыМеню, Знач Форма)
		
	ПривязанныеДанные = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	ПривязанныеДанные.Выбор = Ложь;
		
	// Обновление меню отбора.
	РеквизитДанных = Форма["ME_" + ПривязанныеДанные.ИмяПодчиненногоМеню];
	РеквизитДанных.Очистить();
	
	Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
		
		Если ЭлементМ.Выбор = Истина Тогда
			
			// Обнуляем отбор.
			ЭлементМ.Выбор = Ложь;
			ЭлементОтбор   = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение,"Команда","Кнопка")];
			ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФона;
			ЭлементОтбор.Отображение       = ОтображениеКнопки.Текст;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Форма.Элементы[ПривязанныеДанные.ИмяЭлемента].Видимость  = Истина;
	Форма.Элементы["ГруппаЗначение_ME_" + ИмяМеню].Видимость = Ложь;

	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", ИмяМеню));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора        = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт = Ложь;
		СтрокаСостоянияОтбора.Выбор  = Ложь;
		
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора поле доп ввода.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаОтбораПолеДопВвода(ИмяМеню, ИндексДанных, ПараметрыМеню, Форма, ЭлементИмя)
		
	ИмяРеквизитаДанных = СтрЗаменить(ЭлементИмя, "ПолеОтбор_", "");
	НовоеЗначение      = Форма[ИмяРеквизитаДанных];
	ПривязанныеДанные  = ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	
	// Добавляем новый выбранный элемент, если его нет, в массив данных.
	СуществующиеДанные = НайтиВМассивеПривязанныхДанныхПоЗначению(ПривязанныеДанные.МассивЗначений, НовоеЗначение);
	
	Если СуществующиеДанные = Неопределено Тогда
		
		Представление = Неопределено;
		Если ТипЗнч(НовоеЗначение) = Тип("СправочникСсылка.Контрагенты") Тогда
			
			Представление = Справочники.Контрагенты.ПредставлениеФИОКонтрагента(НовоеЗначение);
			
		ИначеЕсли ТипЗнч(НовоеЗначение) = Тип("СправочникСсылка.Сотрудники") Тогда
			
			Представление = Справочники.Сотрудники.ПредставлениеФИОСотрудника(НовоеЗначение);
		Иначе
			Представление = Строка(НовоеЗначение);
		КонецЕсли;
		
		СтруктураЗначений = Новый Структура;
		СтруктураЗначений.Вставить("Значение"     , НовоеЗначение);
		СтруктураЗначений.Вставить("Представление", Представление);
		СтруктураЗначений.Вставить("Выбор"        , Ложь);
		СтруктураЗначений.Вставить("Код"          , НовоеЗначение.Ссылка.УникальныйИдентификатор());
		
		ПривязанныеДанные.МассивЗначений.Добавить(СтруктураЗначений);
		ПривязанныеДанные.Вставить("ПересоздатьЭлемОтбора", Ложь);
		ПривязанныеДанные.Вставить("ОткрытьМенюОтбора"    , Истина);
		
		// Создать заново элементы меню отбора.
		СоздатьЭлементыВДинамическомМеню(Форма, ПараметрыМеню);
		
		СуществующиеДанные = НайтиВМассивеПривязанныхДанныхПоЗначению(ПривязанныеДанные.МассивЗначений, НовоеЗначение);
		
	КонецЕсли;
	
	// Добавляем выбранный элемент в реквизит данных.
	Форма[ИмяРеквизитаДанных] = Неопределено;
	
	РеквизитДанных = Форма["ME_" + ИмяМеню];
	ЭлементКоманда = СуществующиеДанные.ПривязанноеЗначение;
	
	Если РеквизитДанных.НайтиПоЗначению(ЭлементКоманда) = Неопределено Тогда
		РеквизитДанных.Добавить(ЭлементКоманда);
	КонецЕсли;
	
	// Выделяем выбранные элементы в меню отбора.
	Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
		
		Если РеквизитДанных.НайтиПоЗначению(ЭлементМ.ПривязанноеЗначение) <> Неопределено Тогда
			
			ЭлементОтбор = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение, "Команда", "Кнопка")];
			
			ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФонаВыбранного;
			ЭлементОтбор.Отображение       = ОтображениеКнопки.КартинкаИТекст;
			
		КонецЕсли;
		
	КонецЦикла;
		
	// Устанавливаем состояние отбора на форме.
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", СтрЗаменить(ИмяМеню, "Подчиненное","")));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора         = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт  = Истина;
		СтрокаСостоянияОтбора.Выбор   = Ложь;
	Иначе
		СтрокаСостоянияОтбора         = Форма.СостояниеОтборов.Добавить();
		СтрокаСостоянияОтбора.ИмяМеню = СтрЗаменить(ИмяМеню, "Подчиненное","");
		СтрокаСостоянияОтбора.Элемент = ПривязанныеДанные.ИмяЭлемента;
		СтрокаСостоянияОтбора.Выбор   = Ложь;
		
	КонецЕсли;
	
	Форма.Элементы["Группа_ME_" + ИмяМеню].Видимость          = Истина;
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяМеню].Видимость = Истина;
	Форма.Элементы["ГруппаСкрыть_ME_" + ИмяМеню].Видимость    = Ложь;

КонецПроцедуры

// Процедура - Обработка нажатия элемента динамического меню применение оформления.
//
// Параметры:
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработкаНажатияЭлементаДинамическогоМенюПрименениеОформления(ПараметрыМеню, Форма, ЭлементИмя)
		
	Для Каждого ОписаниеЭлементаМеню Из ПараметрыМеню.ПривязанныеДанные Цикл
		
		Если СтрНайти(ОписаниеЭлементаМеню.Представление,"Декорация") > 0
			И Не (ЗначениеЗаполнено(ОписаниеЭлементаМеню.ИмяЭлемента)
				  ИЛИ СтрНачинаетсяС(ОписаниеЭлементаМеню.ИмяЭлемента, "Кнопка")) Тогда
			Продолжить;
		КонецЕсли;
				
		ЭлМеню       = Форма.Элементы[ОписаниеЭлементаМеню.ИмяЭлемента];
		ГруппаЭлМеню = Форма.Элементы[ОписаниеЭлементаМеню.Группа];
		
		Если ОписаниеЭлементаМеню.Выбор = Истина Тогда
			
			ЭлМеню.ЦветТекста  = ПараметрыМеню.ЦветТекстаВыбранного;
			
			Если СтрНайти(ОписаниеЭлементаМеню.Представление,"Список") > 0 Тогда
				ЭлМеню.Отображение = ОтображениеКнопки.КартинкаИТекст;
			КонецЕсли;
			
			// Заливка фона группы кнопки.
			Если СтрНачинаетсяС(ОписаниеЭлементаМеню.ИмяЭлемента,"Кнопка") Тогда
				ГруппаЭлМеню.ЦветФона  = ПараметрыМеню.ЦветФонаВыбранного;
			КонецЕсли;
		Иначе
			ЭлМеню.ЦветТекста  = ПараметрыМеню.ЦветТекста;
			
			Если СтрНайти(ОписаниеЭлементаМеню.Представление,"Список") > 0 Тогда
				ЭлМеню.Отображение = ОтображениеКнопки.Картинка;
			КонецЕсли;
			
			// Заливка фона группы кнопки.
			Если СтрНачинаетсяС(ОписаниеЭлементаМеню.ИмяЭлемента,"Кнопка") Тогда
				ГруппаЭлМеню.ЦветФона  = ПараметрыМеню.ЦветФона;
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрНайти(ЭлементИмя, "_Тип_ОткрытьСписок") > 0 Тогда
			
			Если ТипЗнч(ОписаниеЭлементаМеню.Значение) = Тип("Структура")
				И ОписаниеЭлементаМеню.Значение.Свойство("Заголовок") Тогда
				
				ЭлМеню.Заголовок = ОписаниеЭлементаМеню.Значение.Заголовок;
				
			ИначеЕсли ОписаниеЭлементаМеню.Свойство("Заголовок") Тогда
				
				ЭлМеню.Заголовок = ОписаниеЭлементаМеню.Заголовок;
			Иначе	
				ЭлМеню.Заголовок = ОписаниеЭлементаМеню.Значение;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

// Процедура - Скрытие открытых отборов динамического меню.
//
// Параметры:
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура СкрытиеОткрытыхОтборовДинамическогоМеню(ПараметрыМеню, Форма, ИмяТекущегоМеню = "")
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, "СостояниеОтборов") Тогда
		Возврат;
	КонецЕсли;
		
	Для Каждого СтрокаСостоянияОтбора Из Форма.СостояниеОтборов Цикл
		
		ИмяМенюОтбора = СтрокаСостоянияОтбора.ИмяМеню;
		
		Если Не (ИмяМенюОтбора <> ИмяТекущегоМеню
			И СтрокаСостоянияОтбора.Открыт) Тогда
			
			Продолжить;
		КонецЕсли;
		
		СтрокаСостоянияОтбора.Открыт = Ложь;
		
		Если СтрокаСостоянияОтбора.Выбор Тогда
			
			Форма.Элементы["ГруппаЗначение_ME_" + ИмяМенюОтбора].Видимость = Истина;
			Форма.Элементы["Группа_ME_" + ИмяМенюОтбора].ЦветФона          = ПараметрыМеню.ЦветФонаВыбранного;
			Форма.Элементы[СтрокаСостоянияОтбора.Элемент].ЦветТекста       = ПараметрыМеню.ЦветТекстаВыбранного;
		Иначе
			Форма.Элементы["Группа_ME_" + ИмяМенюОтбора].ЦветФона          = ПараметрыМеню.ЦветФона;
			Форма.Элементы[СтрокаСостоянияОтбора.Элемент].ЦветТекста       = ПараметрыМеню.ЦветТекста;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция - Найти в массиве привязанных данных по значению.
//
// Параметры:
//  МассивДанных - 	 -
//  Значение	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция НайтиВМассивеПривязанныхДанныхПоЗначению(МассивДанных, Значение)
	
	Для Каждого ЭлементМ ИЗ МассивДанных Цикл
		
		Если ЭлементМ.Значение = Значение Тогда
			Возврат ЭлементМ;
		КонецЕсли;
		
	КонецЦикла;

	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

#Область ОбработчикиЭлементовДинамическогоМенюВсплывающихГрупп

// Процедура - Обработчик элемента динамического меню всплывающей группы при нажатии
//
// Параметры:
//  Форма				 - 	 - 
//  ЭлементИмя			 - 	 - 
//  ОбновитьПланировщик	 - 	 - 
//
Процедура ОбработчикЭлементаДинамическогоМенюВсплывающейГруппыПриНажатии(Форма, ЭлементИмя, ОбновитьДинамическоеМеню = Ложь, ДопПараметры = Неопределено) Экспорт
	
	ДопПараметры  = ?(ДопПараметры = Неопределено, Новый Структура, ДопПараметры);
	ИмяМеню       = ИмяДинамическогоМенюФормыИзЭлемента(ЭлементИмя);	
	ПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	ДопПараметры.Вставить("ИмяМеню", ИмяМеню);
	
	// Если элемент - кнопка Предпоказ.
	Если СтрНайти(ЭлементИмя, "КнопкаПредпоказ") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаВсплывающейГруппыПредпоказ(Форма, ПараметрыМеню, ИмяМеню);
		
	// Если элемент - кнопка Применить.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаПрименить") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаВсплывающейГруппыПрименить(Форма, ПараметрыМеню, ИмяМеню);
		ОбновитьДинамическоеМеню = Истина;
		
	// Если элемент отбора - кнопка Отбор.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаОтбор") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаВсплывающейГруппыОтбор(Форма, ПараметрыМеню, ИмяМеню, ЭлементИмя);
		Возврат;	
		
	// Если элемент - поде Добавить.
	ИначеЕсли СтрНайти(ЭлементИмя, "ПолеДобавить") > 0 Тогда
		
		ОбработчикПриАктивизацииЭлементаВсплывающейГруппыДобавить(Форма, ПараметрыМеню, ИмяМеню, ДопПараметры);
		Возврат;
		
	// Если элемент - кнопка Добавить.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаДобавить") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаВсплывающейГруппыДобавить(Форма, ПараметрыМеню, ИмяМеню);
		ОбновитьДинамическоеМеню = Истина;
		
		// Если элемент - кнопка Добавить.
	ИначеЕсли СтрНайти(ЭлементИмя, "КнопкаРедактировать") > 0 Тогда
		
		ОбработчикПриНажатииЭлементаВсплывающейГруппыРедактировать(Форма, ПараметрыМеню, ИмяМеню, ДопПараметры);
		Возврат;
		
	КонецЕсли;
	
	// Сохраняем проведенные изменения.		
	// Получаем структуру адресов.
	СтруктураАдресов = ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма);
	
	Если СтруктураАдресов <> Неопределено И СтруктураАдресов.Свойство(ИмяМеню) Тогда
		ПоместитьВоВременноеХранилище(ПараметрыМеню, СтруктураАдресов[ИмяМеню]);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора применить.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаВсплывающейГруппыПредпоказ(Знач Форма, Знач ПараметрыМеню, ИмяМеню)
			
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", ИмяМеню));

	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора         = НайденныеСтроки[0];
		// СтрокаСостоянияОтбора.Открыт  = Не СтрокаСостоянияОтбора.Открыт;
		СтрокаСостоянияОтбора.Открыт  = Истина;
	Иначе
		СтрокаСостоянияОтбора         = Форма.СостояниеОтборов.Добавить();
		СтрокаСостоянияОтбора.ИмяМеню = ИмяМеню;
		СтрокаСостоянияОтбора.Открыт  = Истина;
		
	КонецЕсли;

	// Обновление меню отбора перед открытием/закрытием.	
	РеквизитДанных = Форма["ME_" + ИмяМеню];
	РеквизитДанных.Очистить();
	
	Для Каждого ЭлементМ Из ПараметрыМеню.ПривязанныеДанные Цикл
				
		ЭлементОтбор = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение,"Команда","Кнопка")];
		
		Если ЭлементМ.Выбор = Истина Тогда
			
			РеквизитДанных.Добавить(ЭлементМ.ПривязанноеЗначение);
			
			ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФонаВыбранного;
		Иначе
			ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФона;
		КонецЕсли;
		
	КонецЦикла;
	
	Форма.Элементы["Группа_ME_" + ИмяМеню + "Всплывающая"].Показать();
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяМеню].Видимость = Ложь;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора применить.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаВсплывающейГруппыПрименить(Знач Форма, Знач ПараметрыМеню, ИмяМеню)
			
	// Сохранение данных в хранилище из реквизита формы.
	ИмяРеквизитаДанных    = "ME_" + ИмяМеню;
	ПредставлениеЗначения = "";
	КоличествоВыбранных   = 0;
	
	Для Каждого ЭлементМ Из ПараметрыМеню.ПривязанныеДанные Цикл
		
		ЭлементМ.Выбор = Форма[ИмяРеквизитаДанных].НайтиПоЗначению(ЭлементМ.ПривязанноеЗначение) <> Неопределено;		
		
		Если ЭлементМ.Выбор = Истина Тогда 
			КоличествоВыбранных = КоличествоВыбранных + 1;
		КонецЕсли;	
			
	КонецЦикла;
	
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", СтрЗаменить(ИмяМеню, "Подчиненное","")));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора        = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт = Ложь;
		
	КонецЕсли;
	
	// Видимость элементов.
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяМеню].Видимость         = Ложь;
	Форма.Элементы["ГруппаПредпоказДобавить_ME_" + ИмяМеню].Видимость = Не ЗначениеЗаполнено(КоличествоВыбранных);

	Форма.Элементы["Группа_ME_" + ИмяМеню + "Всплывающая"].Скрыть();
	Форма[ПараметрыМеню.РеквизитОбновления] = Истина;
	Форма.Модифицированность = Истина;
		
КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаВсплывающейГруппыОтбор(Знач Форма, Знач ПараметрыМеню, ИмяМеню, ЭлементИмя)
		
	РеквизитДанных   = Форма["ME_" + ИмяМеню];
	ЭлементКоманда   = СтрЗаменить(ЭлементИмя,"Кнопка","Команда");
	ЭлементОтбор     = Форма.Элементы[ЭлементИмя];
	НайденныйЭлемент = РеквизитДанных.НайтиПоЗначению(ЭлементКоманда);
	
	ДобавитьРеквизитДанных = (НайденныйЭлемент = Неопределено);
	
	Если ДобавитьРеквизитДанных Тогда
		
		РеквизитДанных.Добавить(ЭлементКоманда);
		ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФонаВыбранного;
	Иначе
		РеквизитДанных.Удалить(НайденныйЭлемент);
		ЭлементОтбор.Родитель.ЦветФона = ПараметрыМеню.ЦветФона;
		
	КонецЕсли;
		
	Форма.Элементы["ГруппаПрименить_ME_" + ИмяМеню].Видимость = Истина;
	// Форма.Элементы["ГруппаСкрыть_ME_" + ИмяМеню].Видимость    = Ложь;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора применить.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//
Процедура ОбработчикПриАктивизацииЭлементаВсплывающейГруппыДобавить(Знач Форма, Знач ПараметрыМеню, ИмяМеню, ДопПараметры)
					
	// Видимость элементов.
	КнопкаДобавитьВидимость = Истина;
	
	Если ЗначениеЗаполнено(ДопПараметры)
		И ДопПараметры.Свойство("ТекстРедактирования") Тогда 
		
		КнопкаДобавитьВидимость = ЗначениеЗаполнено(ДопПараметры.ТекстРедактирования);

		Форма["ME_" + ИмяМеню + "_Тип_ПолеВвода"] = ДопПараметры.ТекстРедактирования; 
		
	КонецЕсли;	
	
	Форма.Элементы["ГруппаДобавить_ME_" + ИмяМеню].Видимость = КнопкаДобавитьВидимость;	
	Форма.ТекущийЭлемент = Форма.Элементы["ПолеДобавить_ME_" + ИмяМеню + "_Тип_ПолеВвода"];
	Форма[ПараметрыМеню.РеквизитОбновления] = Истина;
	Форма.Модифицированность = Истина;
	
КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаВсплывающейГруппыДобавить(Знач Форма, Знач ПараметрыМеню, ИмяМеню)
	
	ИмяРеквизитаДанных = "ME_" + ИмяМеню + "_Тип_ПолеВвода"; 
	
	Если ПараметрыМеню.ТипДанныхПоУмолчанию = Тип("СправочникСсылка.Теги") Тогда 
		
		НовыйОбъект = Справочники.Теги.СоздатьЭлемент();
		
	ИначеЕсли ПараметрыМеню.ТипДанныхПоУмолчанию = Тип("СправочникСсылка.Интересы") Тогда 	
		
		НовыйОбъект = Справочники.Интересы.СоздатьЭлемент();	
		
	КонецЕсли;
	
	НовыйОбъект.Наименование = Форма[ИмяРеквизитаДанных];   
	
	Попытка
		НовыйОбъект.Записать();	
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru = 'Не удалось добавить элемент!'; en = 'Failed to add item!'"));	
	КонецПопытки;	
	
	ПараметрыДанных = Новый Структура;
	ПараметрыДанных.Вставить("Значение", НовыйОбъект.Ссылка);
	ПараметрыДанных.Вставить("Код"     , НовыйОбъект.Ссылка.УникальныйИдентификатор());
	ПараметрыДанных.Вставить("Выбор"   , Истина);	
	
	ПараметрыМеню.ПривязанныеДанные.Добавить(ПараметрыДанных);	
	ПараметрыМеню.Вставить("ОткрытьМеню", Истина);
	
	Форма[ИмяРеквизитаДанных] = Неопределено;
	Форма.Элементы["ГруппаПредпоказДобавить_ME_" + ИмяМеню].Видимость = Ложь;
	Форма.Элементы["ГруппаДобавить_ME_" + ИмяМеню].Видимость          = Ложь;

КонецПроцедуры

// Процедура - Обработчик при нажатии элемента отбора.
//
// Параметры:
//  ИмяМеню			 - 	 -
//  ИндексДанных	 - 	 -
//  ПараметрыМеню	 - 	 -
//  Форма			 - 	 -
//  ЭлементИмя		 - 	 -
//
Процедура ОбработчикПриНажатииЭлементаВсплывающейГруппыРедактировать(Знач Форма, Знач ПараметрыМеню, ИмяМеню, ДопПараметры)
		
	Если ПараметрыМеню.ТипДанныхПоУмолчанию = Тип("СправочникСсылка.Теги") Тогда 
		
		ДопПараметры.Вставить("ОткрытьФормуСписка", "Справочник.Теги.ФормаСписка");
		
	ИначеЕсли ПараметрыМеню.ТипДанныхПоУмолчанию = Тип("СправочникСсылка.Интересы") Тогда 	
		
		ДопПараметры.Вставить("ОткрытьФормуСписка", "Справочник.Интересы.ФормаСписка");
		
	КонецЕсли;
	
	ПараметрыМеню.Вставить("ОткрытьМеню", Истина);

КонецПроцедуры

#КонецОбласти

#Область СнятьУстановитьВыборВДинамическомМенюФормы

// Процедура - Установить выбор в динамическом меню формы.
//
Процедура УстановитьВыборВДинамическомМенюФормы(Форма, ИмяМеню, ЗначениеВыбора, ПредварительноСброситьВыбор = Ложь) Экспорт
		
	ПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);	
		
	Если ТипЗнч(ЗначениеВыбора) <> Тип("Массив") Тогда 
		МассивЗначенийВыбора = Новый Массив;
		МассивЗначенийВыбора.Добавить(ЗначениеВыбора);
	Иначе
		МассивЗначенийВыбора = ЗначениеВыбора; 
	КонецЕсли;	
	
	Отказ = Ложь;
	
	// Если это меню отбор.
	Если ПараметрыМеню.ТипМеню = "Отбор" Тогда 		
		УстановкаВыбораВДинамическомМенюОтбора(Форма, ИмяМеню, МассивЗначенийВыбора, ПараметрыМеню, ПредварительноСброситьВыбор, Отказ);
	Иначе
		Отказ = Истина;
	КонецЕсли;	
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;	
	
	// Применение к элементам меню соответствующего оформления.
	ОбработкаНажатияЭлементаДинамическогоМенюПрименениеОформления(ПараметрыМеню, Форма, "");
	
	// Сохраняем проведенные изменения.
	// Получаем структуру адресов.
	СтруктураАдресов = ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма);
	
	Если СтруктураАдресов <> Неопределено И СтруктураАдресов.Свойство(ИмяМеню) Тогда
		ПоместитьВоВременноеХранилище(ПараметрыМеню, СтруктураАдресов[ИмяМеню]);
	КонецЕсли;
	
	
КонецПроцедуры

// Процедура - Установить выбор в динамическом меню отбора.
//
Процедура УстановкаВыбораВДинамическомМенюОтбора(Форма, ИмяМеню, МассивЗначенийВыбора, ПараметрыМеню, ПредварительноСброситьВыбор, Отказ = Ложь)
		
	ПривязанныеДанные     = ПараметрыМеню.ПривязанныеДанные[0];
	КнопкаЗначение        = Форма.Элементы["КнопкаЗначение_ME_" + ИмяМеню + "_Тип_Переключатель"];
	КоличествоВыбранных   = 0;
	ПредставлениеЗначения = "";
	
	Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
		
		// Поиск привязанных данных по переданному значению.
		Если МассивЗначенийВыбора.Найти(ЭлементМ.Значение) <> Неопределено Тогда 
			ЭлементМ.Выбор = Истина;
		// Если предварительно необходимо снять отбор фильтра.
		ИначеЕсли ПредварительноСброситьВыбор Тогда 
			ЭлементМ.Выбор = Ложь;		
		КонецЕсли;					
		
		Если ЭлементМ.Выбор Тогда
			
			Если КоличествоВыбранных = 0 Тогда
				ПредставлениеЗначения = ЭлементМ.Представление;
			КонецЕсли;
			
			КоличествоВыбранных = КоличествоВыбранных + 1;
		КонецЕсли;
		
	КонецЦикла;	
	
	Если КоличествоВыбранных = 0 Тогда 
		Отказ = Истина;
		Возврат;
	КонецЕсли;	
	
	// Отображение фильтра выбранных.
	ПривязанныеДанные.Выбор = Истина;
	ВидимостьПереключателя  = Истина;					
	
	Если КоличествоВыбранных = 1 Тогда
		
		ВидимостьПереключателя   = Ложь;
		КнопкаЗначение.Заголовок = ПредставлениеЗначения;
	Иначе
		КнопкаЗначение.Заголовок = "(" + КоличествоВыбранных + ")";
	КонецЕсли;
	
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", ИмяМеню));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора        = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт = Ложь;
		СтрокаСостоянияОтбора.Выбор  = Истина;
		
	КонецЕсли;
	
	// Видимость элементов.
	Форма.Элементы[ПривязанныеДанные.ИмяЭлемента].Видимость = ВидимостьПереключателя;
	КнопкаЗначение.Родитель.Видимость = Истина;

КонецПроцедуры	

// Процедура - Снять выбор в динамическом меню формы.
//
Процедура СнятьВыборВДинамическомМенюФормы(Форма, МассивИменМеню = Неопределено) Экспорт
	
	// Получаем структуру адресов.
	СтруктураАдресов = ПолучитьСтруктуруАдресовИзВременногоХранилища(Форма);
	
	Если СтруктураАдресов = Неопределено Тогда
		Возврат;
	КонецЕсли;		 
	
	Для Каждого ЭлементСтруктуры Из СтруктураАдресов Цикл
		
		Если Не ЗначениеЗаполнено(МассивИменМеню)
			ИЛИ (ЗначениеЗаполнено(МассивИменМеню) 
			     И МассивИменМеню.Найти(ЭлементСтруктуры.Ключ) <> Неопределено) Тогда  
				 
			ИмяМеню = ЭлементСтруктуры.Ключ;
			Адрес   = ЭлементСтруктуры.Значение;
			
			ПараметрыМеню = ПолучитьИзВременногоХранилища(Адрес);
			
			// Если это меню отбор.
			Если ПараметрыМеню.ТипМеню = "Отбор" Тогда 			
				СнятиеВыбораВДинамическомМенюОтбора(Форма, ИмяМеню, ПараметрыМеню);
			Иначе
				Продолжить;
			КонецЕсли;	
			
			// Применение к элементам меню соответствующего оформления.
			ОбработкаНажатияЭлементаДинамическогоМенюПрименениеОформления(ПараметрыМеню, Форма, "");

			ПоместитьВоВременноеХранилище(ПараметрыМеню, Адрес);
	
		КонецЕсли;
					
	КонецЦикла;		
	
КонецПроцедуры

// Процедура - Установить выбор в динамическом меню отбора.
//
Процедура СнятиеВыбораВДинамическомМенюОтбора(Форма, ИмяМеню, ПараметрыМеню)
		
	ПривязанныеДанные = ПараметрыМеню.ПривязанныеДанные[0];
	КнопкаЗначение    = Форма.Элементы["КнопкаЗначение_ME_" + ИмяМеню + "_Тип_Переключатель"];
	
	// Сброс отборов фильтра.
	Для Каждого ЭлементМ Из ПривязанныеДанные.МассивЗначений Цикл
		ЭлементМ.Выбор = Ложь;
	КонецЦикла;	
	
	ПривязанныеДанные.Выбор = Ложь;
	
	НайденныеСтроки = Форма.СостояниеОтборов.НайтиСтроки(Новый Структура("ИмяМеню", ИмяМеню));
	
	Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
		
		СтрокаСостоянияОтбора        = НайденныеСтроки[0];
		СтрокаСостоянияОтбора.Открыт = Ложь;
		СтрокаСостоянияОтбора.Выбор  = Ложь;
		
	КонецЕсли;
	
	// Видимость элементов.
	Форма.Элементы[ПривязанныеДанные.ИмяЭлемента].Видимость = Истина;	
	КнопкаЗначение.Родитель.Видимость = Ложь;
	КнопкаЗначение.Заголовок          = "";
	
КонецПроцедуры	

#КонецОбласти

// Функция - Индекс привязки данных к элементу меню.
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ИндексПривязкиДанныхЭлементаМеню(ИмяЭлементаМеню) Экспорт
	
	ИндексВх = СтрНайти(ИмяЭлементаМеню, "_ID_");
	Если ИндексВх > 0 Тогда
		Возврат Число(Сред(ИмяЭлементаМеню,ИндексВх + 4));
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Имя меню из элемента меню.
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ИмяДинамическогоМенюФормыИзЭлемента(ИмяЭлементаМеню) Экспорт
	
	ИндексНч = СтрНайти(ИмяЭлементаМеню, "_ME_");
	ИндексКон = СтрНайти(ИмяЭлементаМеню, "_",, ИндексНч + 4);

	Если ИндексНч > 0 Тогда
		Возврат Сред(ИмяЭлементаМеню,ИндексНч + 4,ИндексКон - (ИндексНч + 4));
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Элемент формы по имени элемента.
//
// Параметры:
//  Форма			 - 	 -
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ЭлементФормыПоИмениЭлемента(Форма, ИмяЭлементаМеню) Экспорт
	
	Если СтрНайти(ИмяЭлементаМеню, "КомандаНазад_ME") > 0 Тогда
		Возврат Форма.Элементы[СтрЗаменить(ИмяЭлементаМеню, "КомандаНазад_ME", "Поле_ME")];
	ИначеЕсли СтрНайти(ИмяЭлементаМеню, "КомандаВперед_ME") > 0 Тогда
	    Возврат Форма.Элементы[СтрЗаменить(ИмяЭлементаМеню, "КомандаВперед_ME", "Поле_ME")];
	ИначеЕсли СтрНайти(ИмяЭлементаМеню, "Команда") > 0 Тогда
		Возврат Форма.Элементы[СтрЗаменить(ИмяЭлементаМеню, "Команда", "Кнопка")];
	Иначе
		Возврат Форма.Элементы[ИмяЭлементаМеню];
    КонецЕсли;
	
КонецФункции

// Функция - Данные привязанные к элементу меню.
//
// Параметры:
//  АдресХраненияДанных	 - 	 -
//  ИмяЭлементаМеню		 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ДанныеПривязанныеКЭлементуДинамическогоМеню(Форма, ИмяЭлементаМеню) Экспорт
	
	ИмяМеню       = ИмяДинамическогоМенюФормыИзЭлемента(ИмяЭлементаМеню);
	ИндексДанных  = ИндексПривязкиДанныхЭлементаМеню(ИмяЭлементаМеню);
	ПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	Если СтрНайти(ИмяЭлементаМеню, "Список") > 0 Тогда
		Возврат ПараметрыМеню.ПривязанныеДанные[ИндексДанных];
	Иначе
		Возврат ПараметрыМеню.ПривязанныеДанные[ИндексДанных].Значение;
	КонецЕсли;
		
КонецФункции

// Функция - Данные выбранного элемента меню.
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ПараметрВыбораДинамическогоМеню(знач Форма, ИмяМеню, ИмяПараметра) Экспорт
	
	ПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	Если ПараметрыМеню <> Неопределено Тогда
		
		Для Каждого ЭлементМ ИЗ ПараметрыМеню.ПривязанныеДанные Цикл
			
			Если ЭлементМ.Выбор = Истина Тогда
				
				ЗначениеПараметра = Неопределено;
				ЭлементМ.Свойство(ИмяПараметра, ЗначениеПараметра);
				Возврат ЗначениеПараметра;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Неопределено;

КонецФункции

// Функция - Данные выбранного элемента меню.
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ЗначениеВыбораДинамическогоМеню(знач Форма, ИмяМеню) Экспорт
	
	ПараметрыМеню = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	Если ПараметрыМеню <> Неопределено Тогда
		
		Для Каждого ЭлементМ ИЗ ПараметрыМеню.ПривязанныеДанные Цикл
			
			Если ЭлементМ.Выбор = Истина Тогда
				Возврат ЭлементМ.Значение;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Неопределено;

КонецФункции

// Функция - Доступные значения выбора динамического меню.
//
// Параметры:
//  ИмяМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ДоуступныеЗначенияВыбораДинамическогоМеню(Форма, ИмяМеню) Экспорт
	
	МассивВозврата = Новый Массив;
	ПараметрыМеню  = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	Если Не ЗначениеЗаполнено(ПараметрыМеню) Тогда
		Возврат МассивВозврата;
	КонецЕсли;
	
	// Если это меню переключателя.
	Если ПараметрыМеню.ТипМеню <> "Отбор" Тогда
		
		Для Каждого ЭлементМ Из ПараметрыМеню.ПривязанныеДанные Цикл
			
			Если ЗначениеЗаполнено(ЭлементМ.Значение)
				И Не (ЭлементМ.Свойство("Доступность") И ЭлементМ.Доступность = Ложь) Тогда
				
				МассивВозврата.Добавить(ЭлементМ.Значение);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
			
	Возврат МассивВозврата;
	
КонецФункции

// Функция - Все значения выбора динамического меню.
//
// Параметры:
//  ИмяМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ВсеЗначенияВыбораДинамическогоМеню(Форма, ИмяМеню, ВсеЗначения = Ложь) Экспорт
	
	МассивВозврата = Новый Массив;
	ПараметрыМеню  = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	Если Не ЗначениеЗаполнено(ПараметрыМеню) Тогда
		Возврат МассивВозврата;
	КонецЕсли;
	
	// Если это меню переключателя.
	Если ПараметрыМеню.ТипМеню <> "Отбор" Тогда
		
		Для Каждого ЭлементМ ИЗ ПараметрыМеню.ПривязанныеДанные Цикл
			
			Если ЭлементМ.Выбор = Истина ИЛИ ВсеЗначения Тогда
				
				МассивВозврата.Добавить(ЭлементМ.Значение);
			КонецЕсли;
			
		КонецЦикла;
		
	// Если это меню отбора.
	Иначе
		Для Каждого ЭлементМ ИЗ ПараметрыМеню.ПривязанныеДанные Цикл
			
			Если ЭлементМ.Свойство("ИмяПодчиненногоМеню")
				И ЭлементМ.Свойство("МассивЗначений")
				И ЗначениеЗаполнено(ЭлементМ.МассивЗначений) Тогда
				
				Если НЕ ВсеЗначения Тогда
					
					Для Каждого ЭлементЗнч ИЗ ЭлементМ.МассивЗначений Цикл
						Если ЭлементЗнч.Выбор = Истина
							И Не ЭлементЗнч.Свойство("ОтборРодитель") Тогда
							МассивВозврата.Добавить(ЭлементЗнч.Значение);
						КонецЕсли;
					КонецЦикла;
				Иначе
					Для Каждого ЭлементЗнч ИЗ ЭлементМ.МассивЗначений Цикл
						Если Не ЭлементЗнч.Свойство("ОтборРодитель") Тогда
							МассивВозврата.Добавить(ЭлементЗнч.Значение);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Возврат МассивВозврата;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
			
	Возврат МассивВозврата;
	
КонецФункции

// Функция - Данные выбранного элемента всплывающего меню.
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ЗначениеВыбораВсплывающегоДинамическогоМеню(Форма, ИмяМеню) Экспорт
	
	ПараметрыМеню  = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	
	Если Не ЗначениеЗаполнено(ПараметрыМеню) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МассивВозврата = Новый Массив;
	
	Для Каждого ЭлементМ Из ПараметрыМеню.ПривязанныеДанные Цикл
		
		Если ЭлементМ.Выбор = Истина Тогда		
			МассивВозврата.Добавить(ЭлементМ.Значение);
		КонецЕсли;
		
	КонецЦикла;

	Возврат МассивВозврата;
	
КонецФункции

// Функция - Это элемент быстрого выбора.
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ЭтоЭлементБыстрогоВыбора(ИмяЭлементаМеню) Экспорт
    Возврат СтрНайти(ИмяЭлементаМеню, "_ID_Еще") = 0;
КонецФункции

#КонецОбласти

#Область ОбработчикиОтображенияВсплывающихГрупп

// Процедура - Заполнить значения структуры данных всплывающих групп.
// 
Процедура СформироватьРеквизитСтруктурыДанныхВсплывающихГрупп(Форма, ПараметрыВидимости) Экспорт
		
	// Реквизит данных состояния отборов.
	РеквизитДанныхВсплывающихГрупп = "ВидимостьВсплывающихГрупп";
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитОбъекта(РеквизитДанныхВсплывающихГрупп, , Форма) Тогда
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить(Новый РеквизитФормы(РеквизитДанныхВсплывающихГрупп, Новый ОписаниеТипов()));
		
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
		
	КонецЕсли;
	
	Форма.ВидимостьВсплывающихГрупп = ПараметрыВидимости; 
	
КонецПроцедуры

// Процедура - Заполнить значения структуры данных всплывающих групп.
// 
Процедура ДобавитьЗначениеВРеквизитСтруктурыДанныхВсплывающихГрупп(Форма, КлючПараметра, ЗначениеПараметра = Ложь) Экспорт
	
	Форма.ВидимостьВсплывающихГрупп.Вставить(КлючПараметра, ЗначениеПараметра);
		
КонецПроцедуры

// Процедура - Установить видимость всплывающих групп.
// 
// Параметры:
//  ИмяВзаимодействия	 - 	 - 
//  Видимость			 - 	 - 
// 
Процедура УстановитьВидимостьВсплывающихГрупп(Форма, Знач ИмяЭлемента, Знач ИндексЭлемента = Неопределено) Экспорт
	
	ИндексЭлемента = ?(ЗначениеЗаполнено(ИндексЭлемента), "_" + ИндексЭлемента, ""); 
	
	Форма.ВидимостьВсплывающихГрупп[ИмяЭлемента + ИндексЭлемента] = Истина; 
	
	ИмяВсплывающейГруппы = "Группа" + ИмяЭлемента + "Всплывающая" + ИндексЭлемента;
	
	Форма.Элементы[ИмяВсплывающейГруппы].Показать();	
	
КонецПроцедуры

// Процедура - Снять видимость всплывающих групп на сервере.
// 
// Параметры:
//  ИмяВзаимодействия	 - 	 - 
//  Видимость			 - 	 - 
// 
Процедура СнятьВидимостьВсплывающихГрупп(Форма, Знач ИмяЭлемента) Экспорт
	
	Форма.ВидимостьВсплывающихГрупп[ИмяЭлемента] = Ложь; 
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОтображенияПереключателей

// Процедура, изменяет видимость элементов переключателей.
//
Процедура ИзменитьАктивностьПереключателяФормы(
	АктивныйЭлемент    = Неопределено,
	НеактивныеЭлементы = Неопределено,
	Активировать       = Истина,
	Форма              = Неопределено,
	ЭлементФокуса      = Неопределено,
	ТемаОформления     = 1) Экспорт
	
	ЦветТекста              = Новый Цвет(77 , 77 , 77);  // Черный.
	ЦветТекстаАктивирован   = Новый Цвет(255, 255, 255); // Белый.
	ЦветТекстаНеАктивирован = Новый Цвет(192, 192, 192); // Серый.
	ЦветФона                = Новый Цвет(242, 242, 242); // Светло-серый.
	
	// Тема оформления переключателей по умолчанию.
	Если Не ЗначениеЗаполнено(ТемаОформления) ИЛИ ТемаОформления = 1 Тогда  
		ЦветФонаАктивирован = Новый Цвет(25, 116, 206); // Синий.
		
	ИначеЕсли ТемаОформления = 2 Тогда	
		ЦветФонаАктивирован = Новый Цвет(225, 40, 40); // Красный.
		
	ИначеЕсли ТемаОформления = 3 Тогда
		ЦветФонаАктивирован	  = Новый Цвет(242, 242, 242); // Светло-серый.
		ЦветФона			  = Новый Цвет(255, 255, 255);
		ЦветТекстаАктивирован = Новый Цвет(0, 0, 0);
		ЦветТекста 			  = Новый Цвет(51, 102, 187);
	ИначеЕсли ТемаОформления = 4 Тогда
		ЦветФонаАктивирован	  	= Новый Цвет(75 , 202, 129);
		ЦветФона			  	= Новый Цвет(235, 235, 237);
		ЦветТекстаНеАктивирован	= Новый Цвет(77 , 77 , 77);
	КонецЕсли;
	
	Если АктивныйЭлемент <> Неопределено Тогда
		
		ПереданаКнопка = ТипЗнч(АктивныйЭлемент) <> Тип("ГруппаФормы");
		
		АктивнаяГруппа = ?(Не ПереданаКнопка, АктивныйЭлемент, АктивныйЭлемент.Родитель);
		АктивнаяГруппа.ЦветФона = ?(Активировать, ЦветФонаАктивирован, ЦветФона);
		АктивныйЭлемент.Ширина	= ?(ПереданаКнопка, 3, АктивныйЭлемент.Ширина);
		
		АктивнаяКнопка = ?(ТипЗнч(АктивныйЭлемент) = Тип("ГруппаФормы"), АктивныйЭлемент.ПодчиненныеЭлементы[0], АктивныйЭлемент);
		АктивнаяКнопка.ЦветТекста = ?(Активировать, ЦветТекстаАктивирован, ЦветТекстаНеАктивирован);
		АктивнаяКнопка.Шрифт 	  = ?(ПереданаКнопка, Новый Шрифт("Arial", 11), АктивнаяКнопка.Шрифт);
		
	КонецЕсли;
	
	Если НеактивныеЭлементы <> Неопределено Тогда
		
		Если ТипЗнч(НеактивныеЭлементы) <> Тип("Массив") Тогда
			МассивНеактивныхЭлементов = Новый Массив;
			МассивНеактивныхЭлементов.Добавить(НеактивныеЭлементы);
		Иначе
			МассивНеактивныхЭлементов = НеактивныеЭлементы;
		КонецЕсли;
		
		Для Каждого НеактивныйЭлемент Из МассивНеактивныхЭлементов Цикл
			
			ПереданаКнопка = ТипЗнч(НеактивныйЭлемент) <> Тип("ГруппаФормы");
			
			НеАктивнаяГруппа = ?(Не ПереданаКнопка, НеактивныйЭлемент, НеактивныйЭлемент.Родитель);
			НеАктивнаяГруппа.ЦветФона = ЦветФона;
			НеактивныйЭлемент.Ширина  = ?(ПереданаКнопка, 3, НеактивныйЭлемент.Ширина);
			
			НеактивнаяКнопка = ?(ТипЗнч(НеактивныйЭлемент) = Тип("ГруппаФормы"), НеактивныйЭлемент.ПодчиненныеЭлементы[0], НеактивныйЭлемент);
			НеактивнаяКнопка.ЦветТекста = ЦветТекста;
			НеактивнаяКнопка.Шрифт 	    = ?(ПереданаКнопка, Новый Шрифт("Arial", 11), НеактивнаяКнопка.Шрифт);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если Форма <> Неопределено
		И ЭлементФокуса <> Неопределено Тогда
		
		Форма.ТекущийЭлемент = ЭлементФокуса;
	КонецЕсли;
	
КонецПроцедуры

