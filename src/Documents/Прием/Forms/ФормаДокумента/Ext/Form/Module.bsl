// Процедура - Обновить согласования страховых услуг.
//
Процедура ОбновитьСогласованияСтраховыхУслуг(ПараметрыОповещения)
		
	Если ЗначениеЗаполнено(ПараметрыОповещения.ИзмененныйПрием) Тогда
		
		Если Объект.Ссылка = ПараметрыОповещения.ИзмененныйПрием Тогда
			ЗаполнитьДополнительныеРеквизитыТаблицыЛечения();
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(ПараметрыОповещения.ИдентификаторСтроки) Тогда
		НайденныеСтроки = Объект.Лечение.НайтиСтроки(Новый Структура("КлючСтроки", ПараметрыОповещения.ИдентификаторСтроки));
		Если НайденныеСтроки.Количество() > 0 Тогда 
			СтруктураОтбора = Новый Структура();
			СтруктураОтбора.Вставить("ИдентификаторСтроки", ПараметрыОповещения.ИдентификаторСтроки);
			Выборка = РегистрыСведений.СогласованияСтраховыхУслуг.Выбрать(СтруктураОтбора); 
			Если Выборка.Следующий() Тогда
				НайденныеСтроки[0].СтатусСогласования	 = Выборка.СтатусСогласования;
				НайденныеСтроки[0].ДатаОтправки		 	 = Выборка.ДатаОтправки;
				НайденныеСтроки[0].ДатаСогласования		 = Выборка.ДатаСогласования;
				НайденныеСтроки[0].Согласователь		 = Выборка.Согласователь;
				НайденныеСтроки[0].КомментарийСогласования = Выборка.Комментарий;
			КонецЕсли;
		КонецЕсли;
			
	КонецЕсли;

	УстановитьВидимостьКнопкиЗаписатьИПровести();
	
КонецПроцедуры

&НаСервере
// Процедура - Установить видимость кнопки записать и провести.
//
Процедура УстановитьВидимостьКнопкиЗаписатьИПровести()

	Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда
		
		ДоступностьКнопки = Истина;
		Для каждого СтрокаЛечения Из Объект.Лечение Цикл 
			
			Если СтрокаЛечения.СтатусСогласования = Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования
				ИЛИ СтрокаЛечения.СтатусСогласования = Перечисления.СтатусыСогласованияСтраховыхУслуг.Отказ Тогда
				
				ДоступностьКнопки = Ложь;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Элементы.ФормаКнопкаРезультатПриема.Доступность 	= ДоступностьКнопки;
		Элементы.ГруппаФормаКнопкаСогласовать.Видимость 	= Объект.Лечение.НайтиСтроки(Новый Структура("СтатусСогласования", Перечисления.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования)).Количество() > 0;		
	Иначе 
		Элементы.ФормаКнопкаРезультатПриема.Доступность 	= Истина;
		Элементы.ГруппаФормаКнопкаСогласовать.Видимость 	= Ложь;	
	КонецЕсли;
	
КонецПроцедуры

