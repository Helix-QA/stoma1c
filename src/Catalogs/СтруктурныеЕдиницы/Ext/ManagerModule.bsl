
#Область СлужебныйПрограммныйИнтерфейс

// Функция возвращает СЕ по оранизации.
// Если у Организации несколько СЕ - возвращает Неопределенно
//
Функция ВернутьСтруктурныеЕдиницыОрганизации(Организация = Неопределено) Экспорт  
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &Организация <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	|					И &Организация <> НЕОПРЕДЕЛЕНО
	|				ТОГДА СтруктурныеЕдиницы.Организация = &Организация
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";	
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");	 
	
КонецФункции   

// Функция, получить массив структурных единиц сотрудника.
// 
Функция ПолучитьМассивСтруктурныхЕдиницСотрудника(Сотрудник) Экспорт
	
	Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Пользователи") Тогда
		Сотрудник = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник,"Сотрудник");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|	И СтруктурныеЕдиницы.Ссылка В
	|			(ВЫБРАТЬ
	|				СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|			ИЗ
	|				Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиДоступныеСтруктурныеЕдиницы
	|			ГДЕ
	|				СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = &Сотрудник)
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтруктурныеЕдиницы.Наименование"); 	
		
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция, возвращает текстовое представления графика работы стоматологии
//
Функция ПолучитьПредставленияГрафикаРаботы(СтруктурнаяЕдиница) Экспорт
	
	ПредставленияГрафикаРаботы = "";
	
	СписокДнейНедели = Новый СписокЗначений;
	СписокДнейНедели.Добавить(1, "Пн");
	СписокДнейНедели.Добавить(2, "Вт");
	СписокДнейНедели.Добавить(3, "Ср");
	СписокДнейНедели.Добавить(4, "Чт");
	СписокДнейНедели.Добавить(5, "Пт");
	СписокДнейНедели.Добавить(6, "Сб");
	СписокДнейНедели.Добавить(7, "Вс");
	
	ГрафикРаботы = Новый ТаблицаЗначений;
	ГрафикРаботы.Колонки.Добавить("МассивДнейНедели", Новый ОписаниеТипов("Массив"));
	ГрафикРаботы.Колонки.Добавить("НачалоРаботы", Новый ОписаниеТипов("Дата"));
	ГрафикРаботы.Колонки.Добавить("ОкончаниеРаботы", Новый ОписаниеТипов("Дата"));
	
	// Схлопываем дни с одинаковым временем
	Для Каждого СтрокаРасписаниеРаботы Из СтруктурнаяЕдиница.РасписаниеРаботы Цикл
		ДеньДобавлен = Ложь;
		Для Каждого СтрокаТЗ Из ГрафикРаботы Цикл
			Если СтрокаРасписаниеРаботы.Активность И СтрокаТЗ.НачалоРаботы = СтрокаРасписаниеРаботы.НачалоРаботы И СтрокаТЗ.ОкончаниеРаботы = СтрокаРасписаниеРаботы.ОкончаниеРаботы Тогда
				СтрокаТЗ.МассивДнейНедели.Добавить(ДеньНедели(СтрокаРасписаниеРаботы.ДеньНедели));
				ДеньДобавлен = Истина;
			КонецЕсли;
		КонецЦикла;
		Если СтрокаРасписаниеРаботы.Активность И ДеньДобавлен = Ложь Тогда
			СтрокаТЗ = ГрафикРаботы.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаРасписаниеРаботы);
			СтрокаТЗ.МассивДнейНедели.Добавить(ДеньНедели(СтрокаРасписаниеРаботы.ДеньНедели));
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из ГрафикРаботы Цикл
		ПредставлениеПериода = ""; а = 0;
		Для а = 0 По СтрокаТЗ.МассивДнейНедели.Количество()-1 Цикл
			Если а-1 >= 0 И СтрокаТЗ.МассивДнейНедели[а-1] = (СтрокаТЗ.МассивДнейНедели[а] - 1)
					И а+1 <= СтрокаТЗ.МассивДнейНедели.Количество()-1 И (СтрокаТЗ.МассивДнейНедели[а] + 1) = СтрокаТЗ.МассивДнейНедели[а+1] Тогда
				ПредставлениеПериода = ПредставлениеПериода + ?(Сред(ПредставлениеПериода, СтрДлина(ПредставлениеПериода)) <> "-", "-", "");
			Иначе
				ПредставлениеПериода = ПредставлениеПериода + ?(ПредставлениеПериода <> "" И Сред(ПредставлениеПериода, СтрДлина(ПредставлениеПериода)) <> "-", ",", "") + СписокДнейНедели.НайтиПоЗначению(СтрокаТЗ.МассивДнейНедели[а]).Представление;
			КонецЕсли;
		КонецЦикла;
		ПредставленияГрафикаРаботы = ПредставленияГрафикаРаботы + ?(ПредставленияГрафикаРаботы <> "", ", ", "") + 
				ПредставлениеПериода + ": " + Формат(СтрокаТЗ.НачалоРаботы, "ДФ=HH:mm") + "-" + Формат(СтрокаТЗ.ОкончаниеРаботы, "ДФ=HH:mm");
	КонецЦикла;
	
	Возврат ПредставленияГрафикаРаботы;
	
КонецФункции

// Функция - Получить таблицу сервисов рассылок для структурных единиц
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуСервисовРассылокДляСтруктурныхЕдиниц() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнешниеСистемы.Ссылка КАК ВнешняяСистема,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ВнешниеСистемы.Ссылка) КАК Представление
	|ПОМЕСТИТЬ ТаблицаВнешнихСистем
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВнешниеСистемы.Используется = ИСТИНА
	|	И ВнешниеСистемы.ТипВнешнейСистемы В (ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Wallet), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА СтруктурныеЕдиницы.СервисSMSРассылки = ЗНАЧЕНИЕ(Справочник.СервисыРассылки.ПустаяСсылка)
	|				ИЛИ СтруктурныеЕдиницы.СервисSMSРассылки = НЕОПРЕДЕЛЕНО
	|			ТОГДА СервисSMSРассылкиПоУмолчанию.Значение
	|		ИНАЧЕ СтруктурныеЕдиницы.СервисSMSРассылки
	|	КОНЕЦ КАК АккаунтСервисаРассылкиSMS,
	|	ВЫБОР
	|		КОГДА ТаблицаВнешнихСистемPushWallet.СтруктурнаяЕдиница ЕСТЬ NULL
	|				И ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.СтруктурнаяЕдиница ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ОтправкаPushWallet,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаВнешнихСистемPushWallet.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемPushWallet.ВнешняяСистема
	|		КОГДА НЕ ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.ВнешняяСистема
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ВнешниеСистемы.ПустаяСсылка)
	|	КОНЕЦ КАК АккаунтВнешнейСистемыPushWallet,
	|	ВЫБОР
	|		КОГДА ТаблицаВнешнихСистемGreenApi.СтруктурнаяЕдиница ЕСТЬ NULL
	|				И ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.СтруктурнаяЕдиница ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ОтправкаMessenger,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаВнешнихСистемGreenApi.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемGreenApi.ВнешняяСистема
	|		КОГДА НЕ ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.ВнешняяСистема
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ВнешниеСистемы.ПустаяСсылка)
	|	КОНЕЦ КАК АккаунтВнешнейСистемы
	|ИЗ
	|	Константа.СервисSMSРассылкиПоУмолчанию КАК СервисSMSРассылкиПоУмолчанию,
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаВнешнихСистем КАК ТаблицаВнешнихСистемPushWallet
	|		ПО (ТаблицаВнешнихСистемPushWallet.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Wallet))
	|			И СтруктурныеЕдиницы.Ссылка = ТаблицаВнешнихСистемPushWallet.СтруктурнаяЕдиница
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаВнешнихСистем КАК ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ
	|		ПО (ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Wallet))
	|			И (ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаВнешнихСистем КАК ТаблицаВнешнихСистемGreenApi
	|		ПО (ТаблицаВнешнихСистемGreenApi.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi))
	|			И СтруктурныеЕдиницы.Ссылка = ТаблицаВнешнихСистемGreenApi.СтруктурнаяЕдиница
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаВнешнихСистем КАК ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ
	|		ПО (ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi))
	|			И (ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА ТаблицаВнешнихСистемPushWallet.СтруктурнаяЕдиница ЕСТЬ NULL
	|				И ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.СтруктурнаяЕдиница ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаВнешнихСистемPushWallet.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемPushWallet.ВнешняяСистема
	|		КОГДА НЕ ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемPushWalletПоЛюбойСЕ.ВнешняяСистема
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ВнешниеСистемы.ПустаяСсылка)
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаВнешнихСистемGreenApi.СтруктурнаяЕдиница ЕСТЬ NULL
	|				И ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.СтруктурнаяЕдиница ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаВнешнихСистемGreenApi.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемGreenApi.ВнешняяСистема
	|		КОГДА НЕ ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.ВнешняяСистема ЕСТЬ NULL
	|			ТОГДА ТаблицаВнешнихСистемGreenApiПоЛюбойСЕ.ВнешняяСистема
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ВнешниеСистемы.ПустаяСсылка)
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА СтруктурныеЕдиницы.СервисSMSРассылки = ЗНАЧЕНИЕ(Справочник.СервисыРассылки.ПустаяСсылка)
	|				ИЛИ СтруктурныеЕдиницы.СервисSMSРассылки = НЕОПРЕДЕЛЕНО
	|			ТОГДА СервисSMSРассылкиПоУмолчанию.Значение
	|		ИНАЧЕ СтруктурныеЕдиницы.СервисSMSРассылки
	|	КОНЕЦ,
	|	СтруктурныеЕдиницы.Ссылка";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция, выполняет возврат всех структурных единиц
//
Функция ВернутьМассивСтруктурныхЕдиниц(Знач МассивРазрешенных = Неопределено, ПолучатьУдаленные = Ложь) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|	И НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница");

	Если ПолучатьУдаленные Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НЕ СтруктурныеЕдиницы.ПометкаУдаления", "");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("МассивРазрешенных", МассивРазрешенных);
	
	УсловиеСтруктурнаяЕдиница = ?(ЗначениеЗаполнено(МассивРазрешенных), "И СтруктурныеЕдиницы.Ссылка В (&МассивРазрешенных)", "");
	Запрос.Текст              = СтрЗаменить(Запрос.Текст, "И &УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");	
	
КонецФункции

// Функция, выполняет возврат всех структурных единиц
//
Функция ВернутьМассивСтруктурныхЕдиницСтоматология(Знач МассивРазрешенных = Неопределено, ПолучатьУдаленные = Ложь) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|	И НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница");
	
	Если ПолучатьУдаленные Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НЕ СтруктурныеЕдиницы.ПометкаУдаления", "");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("МассивРазрешенных", МассивРазрешенных);
	
	УсловиеСтруктурнаяЕдиница = ?(ЗначениеЗаполнено(МассивРазрешенных), "И СтруктурныеЕдиницы.Ссылка В (&МассивРазрешенных)", "");
	Запрос.Текст              = СтрЗаменить(Запрос.Текст, "И &УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");	
	
КонецФункции

// Функция - Вернуть региональные настройки
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
