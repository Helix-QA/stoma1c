&НаСервереБезКонтекста
// Функция - Получить список сотрудников.
// 
// 
Функция ПолучитьСписокДолжностей(ВременныйСписокСотрудников = Неопределено)
	
	ТаблицаДолжностей = ПолучитьТаблицуДолжностей(ВременныйСписокСотрудников);
	ТаблицаДолжностей.Сортировать("КоличествоСотрудников Убыв",);
	СписокДолжностей = Новый СписокЗначений;
	
	// Заполнение списка сотрудников.
	Отступ = "    ";
	СписокДолжностей.Добавить("Все", "Все",,БиблиотекаКартинок.ПапкаНовая);	// Все.
	
	Для Каждого СтрокаДолжность Из ТаблицаДолжностей Цикл
		
		Если СтрокаДолжность.КоличествоСотрудников > 0 Тогда
			СписокДолжностей.Добавить(
			СтрокаДолжность.Должность,
			Отступ+Строка(СтрокаДолжность.Должность) + "(" + Строка(СтрокаДолжность.КоличествоСотрудников) + ")",,
			БиблиотекаКартинок.РеквизитКартинка);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СписокДолжностей;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Получить список сотрудников.
// 
// 
Функция ПолучитьСписокРолей(ВременныйСписокСотрудников = Неопределено)
	
	ТаблицаРолей = ПолучитьТаблицуРолей(ВременныйСписокСотрудников);
	ТаблицаРолей.Сортировать("КоличествоСотрудников Убыв",);
	СписокРолей = Новый СписокЗначений;
	
	// Заполнение списка сотрудников.
	Отступ = "    ";
	СписокРолей.Добавить("Все", "Все",,БиблиотекаКартинок.ПапкаНовая);	// Все.
	
	Для Каждого СтрокаРоль Из ТаблицаРолей Цикл
		
		Если СтрокаРоль.КоличествоСотрудников > 0 Тогда
			СписокРолей.Добавить(
			СтрокаРоль.Роль,
			Отступ+Строка(СтрокаРоль.Роль) + "(" + Строка(СтрокаРоль.КоличествоСотрудников) + ")",,
			БиблиотекаКартинок.РеквизитКартинка);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СписокРолей;
	
КонецФункции

&НаСервере
// Функция - Получить таблицу сотрудников.
// 
// Параметры:
//  ДатаВремяНачала						 - 	 -
//  ДатаВремяОкончания					 - 	 -
// 
// Возвращаемое значение:
//   -
// 
Функция ЗаполнитьСорудниковСогласноОтборов(ИсключаемыйОтбор = Неопределено, ВременныйСписокСотрудников = Неопределено, ЗаполнитьВеменнуюТаблицу = Ложь)
		
	Запрос = новый ЗАпрос;
	ЗАпрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО Сотрудники.Ссылка = НастройкиСотрудников.Сотрудник
	|ГДЕ
	|	НЕ Сотрудники.ЭтоГруппа
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сотрудники.Должность = &Должность
	|	И Сотрудники.Роль = &Роль
	|	И Сотрудники.Ссылка В ИЕРАРХИИ(&Сотрудник)
	|	И ВЫБОР
	|			КОГДА &ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 31, 23, 59, 59)
	|					И НастройкиСотрудников.ДатаПриема <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА НастройкиСотрудников.ДатаПриема <= &ДатаОкончания
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|					И НастройкиСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА НастройкиСотрудников.ДатаУвольнения >= &ДатаНачала
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";  
		
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаНачала"		    , ОтборПериод.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания"		, ОтборПериод.ДатаОкончания);
	
	Если ИсключаемыйОтбор <> ОтборСотрудник И ТипЗнч(ОтборСотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда
		Запрос.УстановитьПараметр("Сотрудник", ОтборСотрудник);
		ОтборСотрдуникТекстом = Строка(ОтборСотрудник); 
	Иначе	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сотрудники.Ссылка В ИЕРАРХИИ(&Сотрудник)", "Истина"); 
		ОтборСотрдуникТекстом = "Все";
	КонецЕсли;
		
	Если ИсключаемыйОтбор <> ОтборСотрудникДолжность И ТипЗнч(ОтборСотрудникДолжность) = Тип("СправочникСсылка.Должности") Тогда
		Запрос.УстановитьПараметр("Должность", ОтборСотрудникДолжность);
		ОтборДолжностьТекстом = Строка(ОтборСотрудникДолжность); 
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сотрудники.Должность = &Должность", "Истина"); 
		ОтборДолжностьТекстом = "Все";
	КонецЕсли;
		
	Если ИсключаемыйОтбор <> ОтборСотрудникРоль И ТипЗнч(ОтборСотрудникРоль) = Тип("ПеречислениеСсылка.РольПользователя") Тогда
		Запрос.УстановитьПараметр("Роль", ОтборСотрудникРоль);
		ОтборРольТекстом = Строка(ОтборСотрудникРоль);
	Иначе	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сотрудники.Роль = &Роль", "Истина"); 
		ОтборРольТекстом = "Все";
	КонецЕсли;
	
	Если ЗаполнитьВеменнуюТаблицу = Истина Тогда
		ВременныйСписокСотрудников = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");	
	Иначе
		СписокСотрудниковПоОтборам.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник")); 
		
		Элементы.ОткрытьСписокСотрудники.Заголовок 	= ОтборСотрдуникТекстом;	
		Элементы.ОтменитьОтборПоСотруднику.Видимость = Элементы.ОткрытьСписокСотрудники.Заголовок <> "Все";
		
		Элементы.ОткрытьСписокДолжности.Заголовок 	= ОтборДолжностьТекстом;
		Элементы.ОтменитьОтборПоДолжности.Видимость = Элементы.ОткрытьСписокДолжности.Заголовок <> "Все";
		
		Элементы.ОткрытьСписокРоли.Заголовок 	= ОтборРольТекстом;
		Элементы.ОтменитьОтборПоРоли.Видимость 	= Элементы.ОткрытьСписокРоли.Заголовок <> "Все";
	КонецЕсли;
	
КонецФункции 

