// Обработчик команды печати предварительной записи    
//
Процедура ПечатьПредварительнойЗаписи(Команда)
	
	ПараметрыПостроения = Новый Структура("ВыбранныеСотрудники, ВыбранныеПомещения, СтраницаМенеджера, РазрешениеЭкрана, СтруктурнаяЕдиница, Дата, РазрешитьСмещениеГрафика, УчитыватьГрафикРаботыСотрудников, НаВсюФорму");
	ПараметрыПостроения.СтраницаМенеджера					=	ПолучитьСтраницуМенеджера();
	ПараметрыПостроения.СтруктурнаяЕдиница					=	Объект.СтруктурнаяЕдиница;
	ПараметрыПостроения.Дата								=	Объект.Дата;
	ПараметрыПостроения.РазрешитьСмещениеГрафика			=   Истина;
	ПараметрыПостроения.РазрешениеЭкрана					=   РазрешениеЭкрана;
	ПараметрыПостроения.УчитыватьГрафикРаботыСотрудников 	= 	НЕ ПЗОтборПоСотрудникамРежимФильтра = 0;
	ПараметрыПостроения.НаВсюФорму			             	= 	НЕ ПЗПанельФильтраВидимость;
	ПараметрыПостроения.ВыбранныеСотрудники 				=	ВернутьОтборПоСотрудникам();
	ПараметрыПостроения.ВыбранныеПомещения 					=	ВернутьОтборПоПомещениям();
	ПараметрыПостроения.Вставить("ВыводитьКартинки", Ложь);
	ПараметрыПостроения.Вставить("МассивСотрудниковИОбластей", МассивСотрудниковИОбластей);
	ПараметрыПостроения.Вставить("ИнтервалГрафикаЗанятий", ИнтервалГрафика);
	ПараметрыПостроения.Вставить("Сотрудник", ПЗФиьтрГрафикаТекущаяСтрока);
	
	Если ПЗГрафикаРежимОтображения = 0 Тогда
		ПараметрыПостроения.Вставить("Режим", "День");
	ИначеЕсли ПЗГрафикаРежимОтображения = 1 Тогда
		ПараметрыПостроения.Вставить("Режим", "Неделя");
	КонецЕсли;	
	
	ОткрытьФорму("Отчет.ПредварительнаяЗаписьДляПечати.Форма", ПараметрыПостроения, ЭтаФорма, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
// Процедура заполняет табличный документ.
//
Процедура ОбновлениеСтраницыЖурналПредварительнойЗаписи(РазрешитьСмещениеГрафика = Истина,ОбновитьПанельДни = Ложь)
	
	// Создаем структуру с параметрами построения графика.
	ПараметрыПостроения = Новый Структура();
	
	ПараметрыПостроения.Вставить("ВыбранныеСотрудники"             	, Неопределено);	
	ПараметрыПостроения.Вставить("ВыбранныеПомещения"              	, Неопределено);	
	ПараметрыПостроения.Вставить("СтраницаМенеджера"               	, ПолучитьСтраницуМенеджера());	
	ПараметрыПостроения.Вставить("РазрешениеЭкрана"                	, РазрешениеЭкрана);	
	ПараметрыПостроения.Вставить("СтруктурнаяЕдиница"              	, Объект.СтруктурнаяЕдиница);	
	ПараметрыПостроения.Вставить("Дата"                            	, Объект.Дата);	
	ПараметрыПостроения.Вставить("РазрешитьСмещениеГрафика"        	, РазрешитьСмещениеГрафика);	
	ПараметрыПостроения.Вставить("УчитыватьГрафикРаботыСотрудников"	, Не ПЗОтборПоСотрудникамРежимФильтра = 0);	
	ПараметрыПостроения.Вставить("НаВсюФорму"                      	, Не ПЗПанельФильтраВидимость);		
	ПараметрыПостроения.Вставить("ОтмененныеЗаписи"         		, РежимПросмотраОтмененных);	
	
	#Если Не ВебКлиент Тогда
		ПараметрыПостроения.Вставить("ВыводитьКартинки", Истина);
	#КонецЕсли	
	
	// Серверная процедура обновления страницы.
	ПЗРасшифровкаТекущейОбласти = Неопределено;
	МассивСотрудниковИОбластей  = Новый Массив;
	
	ОбновлениеСтраницыЖурналПредварительнойЗаписиСервер(ПараметрыПостроения, ОбновитьПанельДни, МассивСотрудниковИОбластей);	
	
	Если ПЗФильтрГрафикаОбновить
		И ПЗПанельФильтраВидимость Тогда
		
		Если ПЗФильтраГрафикаРежим = 0 Тогда
			ОбщегоНазначенияКлиентСтоматология.РазвернутьДерево(Элементы.ДеревоСотрудников, ДеревоСотрудниковРучн);
		ИначеЕсли ПЗФильтраГрафикаРежим = 1 Тогда
			ОбщегоНазначенияКлиентСтоматология.РазвернутьДерево(Элементы.ДеревоПомещений, ДеревоПомещений);
		КонецЕсли;
		
		ПЗФильтрГрафикаОбновить = Ложь;
		
	КонецЕсли;
	
	ОбновлениеСтраницыЖурналПредварительнойЗаписиПодключениеОбработчикаВыделенияСотрудников(ПараметрыПостроения);
		
	СтраницаЖурналПредварительнойЗаписиОбновлена = Истина;
	ТабличныйДокументПриАктивизацииОбласти(Неопределено);
	
	УстановитьЦветГруппыКнопки();
	
КонецПроцедуры

