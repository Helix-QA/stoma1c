&НаСервере
// Функция - Сформировать блок приеиы
//
// Параметры:
//  ВыводитьБлок	 - 	 - 
//  ВыборкаПриемы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокПриеиы(ВыводитьБлок = Ложь, ВыборкаПриемы)
	
	АктСверкиВзаиморасчетов =
	"<tr valign='middle'>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author '></p>
	|                </td>
	|                <td class='right_col' align='left'>
	|                     <a title='' class='author' id = 'ЭтоДолг' style = 'cursor: pointer; color: rgb(159, 101, 0)' >Акт сверки взаиморасчетов</a>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{СуммаИтого}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{ОплаченоИтого}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{СписаноИтого}</p>
	|                </td>
	|            </tr>";
	
	СтрокаПриема = 
	"<tr>
	|		    	<td colspan='3' style='height: 8px;'>
	|                </td>
	|            </tr>
	|				<tr valign='middle'>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{Дата}</p>
	|                </td>
	|                <td class='right_col' align='left'>
	|                    <a title='' class='author' href='{НавигационнаяСсылка}'>{Прием}</a>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{СтраховаяКомпания}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{СуммаДокумента}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{ОплаченоПоДокументы}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{СписаноПоДокументы}</p>
	|                </td>
	|            </tr>
	|{СтрокаУслуга}";
	
	СтрокаУслуга = "<tr valign='middle'>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='left'>
	|                    <a title='' class='author' href='{НавигационнаяСсылкаУслуга}'>{Услуга}</a>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'>{ПроцентСкидки}</p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|                <td class='right_col' align='right'>
	|                    <p title='' class='author'></p>
	|                </td>
	|            </tr>"; 
	
	Строка = СтрЗаменить(СтрокаПриема, "{СтрокаУслуга}", СтрокаУслуга );	
	
	СтрокаИсторииПриемов = "";
	ПроцентСкидки = "";
	Услуги = "";
	Если ВыборкаПриемы.Количество() > 0 Тогда
		
		СуммаИтого         = 0;
		СуммаОплаченоИтого = 0;
		СуммаСписаноИтого  = 0;
		
		СтруктураРасшифровкиОткрытьАктОбОказанныхУслугах = Новый Структура;
		СтруктураРасшифровкиОткрытьАктОбОказанныхУслугах.Вставить("Контрагент", Контрагент);
		СтруктураРасшифровкиОткрытьАктОбОказанныхУслугах.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		ОткрытьАктОбОказанныхУслугах = СтруктураРасшифровкиОткрытьАктОбОказанныхУслугах;
		
		Пока ВыборкаПриемы.Следующий() Цикл
			
			ВыводитьБлок = Истина;
			
			СуммаИтого 		   = СуммаИтого         + ВыборкаПриемы.Сумма;
			СуммаОплаченоИтого = СуммаОплаченоИтого + ВыборкаПриемы.Оплачено;
			СуммаСписаноИтого  = СуммаСписаноИтого  + ВыборкаПриемы.Списано;		
			
		КонецЦикла;	
		
		СуммаИтого 	  = Формат(СуммаИтого, "ЧДЦ=2; ЧРД=.; ЧН=");
		ОплаченоИтого = Формат(СуммаОплаченоИтого, "ЧДЦ=2; ЧРД=.; ЧН=");
		СписаноИтого  = Формат(СуммаСписаноИтого, "ЧДЦ=2; ЧРД=.; ЧН=");		
		
		ВыборкаПриемы.Сбросить();
		Пока ВыборкаПриемы.Следующий() Цикл
			
			Дата 				= ВыборкаПриемы.Дата;
			Прием 				= ?(ТипЗнч(ВыборкаПриемы.ДокументПродажи.Ссылка) = Тип("ДокументСсылка.Прием"), Формат(ВыборкаПриемы.Дата, "ДФ=HH:mm") + ", Врач: " + Строка(ВыборкаПриемы.Сотрудник), Формат(ВыборкаПриемы.Дата, "ДФ=HH:mm"));
			ПолисМедСтрахования = ВыборкаПриемы.ПолисМедСтрахования;
			СтраховаяКомпания   = ?(ЗначениеЗаполнено(ПолисМедСтрахования), Строка(ПолисМедСтрахования.СтраховаяКомпания)
			                        + ", полис №" + ПолисМедСтрахования.НомерПолиса + "-" + ПолисМедСтрахования.СерияПолиса + " до: " 
			                        + Формат(ПолисМедСтрахования.ДатаОкончания, "ДФ='dd MMMM yyyy'"), "");
			СуммаДокумента 		= Формат(ВыборкаПриемы.Сумма, "ЧДЦ=2; ЧРД=.");
			ОплаченоПоДокументу = Формат(ВыборкаПриемы.Оплачено, "ЧДЦ=2; ЧРД=.");
			СписаноПоДокументу  = Формат(ВыборкаПриемы.Списано, "ЧДЦ=2; ЧРД=.");
			РасшифровкаПриема   = ВыборкаПриемы.ДокументПродажи;			
			
			ВыборкаПоУслугам = ВыборкаПриемы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоУслугам.СледующийПоЗначениюПоля("Услуга") Цикл
				Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") Тогда
					
					ПроцентСкидки = "";
					СтрокаЗуб = "";
					СкидкаСредняя = 0;
					СуммаБезСкидкиПоУслуге = 0;
					СуммаСоСкидкойПоУслуге = 0;
					Пока ВыборкаПоУслугам.СледующийПоЗначениюПоля("НомерЗуба") Цикл 
						СуммаБезСкидкиПоУслуге = СуммаБезСкидкиПоУслуге + ВыборкаПоУслугам.СуммаБезСкидки;
						СуммаСоСкидкойПоУслуге = СуммаСоСкидкойПоУслуге + ВыборкаПоУслугам.СуммаСоСкидкой;
						Если СтрокаЗуб = "" Тогда
							СтрокаЗуб = Строка(?(ВыборкаПоУслугам.НомерЗуба = Перечисления.Зубы.ВсяПолость, "", ВыборкаПоУслугам.НомерЗуба));
						Иначе 
							СтрокаЗуб = СтрокаЗуб + ?(ЗначениеЗаполнено(?(ВыборкаПоУслугам.НомерЗуба = Перечисления.Зубы.ВсяПолость, "", ВыборкаПоУслугам.НомерЗуба)), ", ", "") + Строка(?(ВыборкаПоУслугам.НомерЗуба = Перечисления.Зубы.ВсяПолость, "", ВыборкаПоУслугам.НомерЗуба));
						КонецЕсли;
					КонецЦикла;
					Если СуммаБезСкидкиПоУслуге - СуммаСоСкидкойПоУслуге = 0 Тогда
						Услуга = ?(ЗначениеЗаполнено(СтрокаЗуб), СтрокаЗуб + ": ", "") + Строка(ВыборкаПоУслугам.Услуга);
					Иначе
						Если СуммаБезСкидкиПоУслуге <> 0 и СуммаСоСкидкойПоУслуге <> 0 и СуммаБезСкидкиПоУслуге <> Неопределено Тогда
							СкидкаСредняя =  (СуммаБезСкидкиПоУслуге - СуммаСоСкидкойПоУслуге) / СуммаБезСкидкиПоУслуге * 100;
						КонецЕсли;
						Услуга = ?(ЗначениеЗаполнено(СтрокаЗуб), Строка(СтрокаЗуб) + ": ", "") + Строка(ВыборкаПоУслугам.Услуга);
						СкидкаОкр = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(СкидкаСредняя, Перечисления.ПорядкиОкругления.Окр0_1, Истина);			   
						ПроцентСкидки = "-" + СкидкаОкр + "%";
					КонецЕсли;				   
					
					НоваяСтрокаУслуги = СтрЗаменить(СтрокаУслуга     , "{Услуга}", Услуга);
					НоваяСтрокаУслуги = СтрЗаменить(НоваяСтрокаУслуги, "{ПроцентСкидки}", ПроцентСкидки);
					НоваяСтрокаУслуги = СтрЗаменить(НоваяСтрокаУслуги, "{НавигационнаяСсылкаУслуга}", ПолучитьНавигационнуюСсылку(ВыборкаПоУслугам.Услуга.Ссылка));
					Услуги = Услуги + НоваяСтрокаУслуги;			
					
				КонецЕсли;				
				
			КонецЦикла;				
			
			НоваяСтрокаИсторииПриемов = СтрЗаменить(СтрокаПриема			 , "{Дата}"			            , Формат(Дата, "ДЛФ=Д"));
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{Прием}"	                , Прием);
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{НавигационнаяСсылка}"      , ПолучитьНавигационнуюСсылку(ВыборкаПриемы.ДокументПродажи.Ссылка));
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{СтраховаяКомпания}"        , СтраховаяКомпания);
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{СуммаДокумента}"           , СуммаДокумента);
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{ОплаченоПоДокументы}"      , ОплаченоПоДокументу);
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{СписаноПоДокументы}"       , СписаноПоДокументу);
			НоваяСтрокаИсторииПриемов = СтрЗаменить(НоваяСтрокаИсторииПриемов, "{СтрокаУслуга}"             , Услуги);
			
			СтрокаИсторииПриемов = СтрокаИсторииПриемов + НоваяСтрокаИсторииПриемов;   
			
			Услуги = "";
		КонецЦикла;  		
		АктСверкиВзаиморасчетов = СтрЗаменить(АктСверкиВзаиморасчетов, "{СуммаИтого}"        , СуммаИтого);
		АктСверкиВзаиморасчетов = СтрЗаменить(АктСверкиВзаиморасчетов, "{ОплаченоИтого}"     , ОплаченоИтого);
		АктСверкиВзаиморасчетов = СтрЗаменить(АктСверкиВзаиморасчетов, "{СписаноИтого}"      , СписаноИтого);
		СтрокаИсторииПриемов    = АктСверкиВзаиморасчетов + СтрокаИсторииПриемов;
	КонецЕсли;	
	
	Возврат СтрокаИсторииПриемов; 
	
КонецФункции

&НаСервере
