	// КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ДокументРеестра.ОкончаниеПериода) Тогда
		ПоказатьСообщение("РегистрацияПакетовИО_НеЗаполненаДатаОтчетногоПериода");
		Отказ = Истина;
	КонецЕсли; 
	
	Возврат Отказ;
КонецФункции

&НаСервере
Процедура ОбновитьЗарегистрированныеФайлы(МассивФайловДляПроверкиРегистрации)
	
	СоответствиеФайлЗарегистрирован = ОпределитьЗарегистрированныеФайлы(МассивФайловДляПроверкиРегистрации);
	
	Для каждого ЭлементСоответствия Из СоответствиеФайлЗарегистрирован Цикл
		УзелДерева = Неопределено;
		Пока ОбщегоНазначенияКлиентСервер.ОбходДерева_Следующий(ЭтотОбъект.ДеревоСформированныеФайлы, УзелДерева) Цикл
			Если УзелДерева.СсылкаФайл = ЭлементСоответствия.Ключ Тогда
				УзелДерева.Зарегистрирован = ЭлементСоответствия.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Функция ОпределитьЗарегистрированныеФайлы(МассивФайлов)
	
	СоответствиеВозврат = Новый Соответствие;
	Запрос = Новый Запрос;
	Запрос.Текст = 
			"ВЫБРАТЬ
			|	РегистрацияПакетовИнформационногоОбмена.ФайлОбмена
			|ИЗ
			|	РегистрСведений.РегистрацияПакетовИнформационногоОбмена КАК РегистрацияПакетовИнформационногоОбмена
			|ГДЕ
			|	РегистрацияПакетовИнформационногоОбмена.ФайлОбмена В(&Файлы)";
			
	Запрос.УстановитьПараметр("Файлы", МассивФайлов);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ФайлОбмена");
	Для каждого Файл Из МассивФайлов Цикл
		Поиск = Результат.Найти(Файл);
		Если Поиск = Неопределено Тогда
			Зарегистрирован = Ложь;
		Иначе
			Зарегистрирован = Истина;
		КонецЕсли; 
		СоответствиеВозврат.Вставить(Файл, Зарегистрирован);
	КонецЦикла; 
	
	Возврат СоответствиеВозврат;
	
КонецФункции

&НаСервере
Процедура ОпределитьКоличествоПакетовОбмена()
	
	СледНомер = РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ПолучитьСледующийНомерПакетаОтчетногоПериода(
																ДокументРеестра.НачалоПериода,
																ДокументРеестра.СтруктурнаяЕдиница.Организация,
																ДокументРеестра.Контрагент
															);
															
	ЭтотОбъект.КоличествоСформированныхПакетов = СледНомер - 1;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьДанныеОФайлахДокумента()
	
	МассивФайловДокумента = РаботаСФайламиСлужебныйВызовСервераСтоматология.ПолучитьВсеПодчиненныеФайлы(ЭтотОбъект.ДокументРеестра);
	ВременныйКаталог = КаталогВременныхФайлов();
	МассивФайловДляУдаления = Новый Массив();
	МассивФайловДляПроверкиРегистрации = Новый Массив();
	
	Для Каждого ФайлСсылка Из МассивФайловДокумента Цикл
		
		Если ФайлСсылка.ПометкаУдаления = Ложь Тогда
			// Получим только не помеченные на удаление
			// получим только архивы не помеченные на удаление.
			ОбщиеДанныеОФайле = РаботаСФайламиСлужебныйВызовСервераСтоматология.ДанныеФайлаИДвоичныеДанные2(ФайлСсылка);
			ДанныеОФайле = ОбщиеДанныеОФайле.ДанныеФайла;
			Если ВРег(ДанныеОФайле.Расширение) = "ZIP" Тогда
				АдресФайла = РаботаСФайламиСлужебныйВызовСервераСтоматология.ПолучитьНавигационнуюСсылкуДляОткрытия2(ДанныеОФайле.Версия);
				
				ПутьКФайлуАрхива = ВременныйКаталог + ДанныеОФайле.ПолноеНаименованиеВерсии;
				ОбщиеДанныеОФайле.ДвоичныеДанные.Записать(ПутьКФайлуАрхива);
				МассивФайловДляУдаления.Добавить(ПутьКФайлуАрхива);
				
				ИмяПапкиДляСоздания = СтрЗаменить(ДанныеОФайле.ПолноеНаименованиеВерсии,".ZIP","");
				ИмяПапкиДляСоздания = СтрЗаменить(ИмяПапкиДляСоздания,".zip","");
				
				// проверка возможности распаковки /////////////////////////////////
				ПутьРаспаковки = ВременныйКаталог + ИмяПапкиДляСоздания;
				Архив = РаспаковатьАрхив(ПутьКФайлуАрхива, ПутьРаспаковки);
				Если Архив = Неопределено Тогда
					Продолжить;
				КонецЕсли; 
				МассивФайловДляУдаления.Добавить(ПутьРаспаковки);
				///////////////////////////////////////////////////////////////////////////////
				
				// проверим является ли файл внешним
				Входящий = ПроверитьИмяФайлаНаОтправителяИОтчетныйПериод(
																							ИмяПапкиДляСоздания,
																							Неопределено,
																							ДокументРеестра.Контрагент,
																							ДокументРеестра.СтруктурнаяЕдиница.Организация,
																							ДокументРеестра.НачалоПериода
																						);
				// заполним дерево по архиву
				АрхивУИ = Новый УникальныйИдентификатор;
				ДобавитьУзелДерева(ДанныеОФайле.ПолноеНаименованиеВерсии,
									"",
									АдресФайла,
									ДанныеОФайле.Расширение,
									АрхивУИ,
									ФайлСсылка,
									Входящий
								);
				МассивФайловДляПроверкиРегистрации.Добавить(ФайлСсылка);
				
				Для каждого ЭлементАрхива Из Архив.Элементы Цикл
					ФайлУИ = Новый УникальныйИдентификатор;
					ДвоичныеДанныеФайла = Новый ДвоичныеДанные(ПутьРаспаковки + "\" + ЭлементАрхива.Имя);
					Файл_Адрес = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, ЭтотОбъект.УникальныйИдентификатор);
					ДобавитьУзелДерева(ЭлементАрхива.Имя,
										АрхивУИ,
										Файл_Адрес,
										ЭлементАрхива.Расширение,
										ФайлУИ,
										ФайлСсылка,
										Входящий
									);
				КонецЦикла; 
			КонецЕсли; // если архив
		КонецЕсли; // если не удален
	КонецЦикла;
	
	УдалитьФайлыПоМассивуПутей(МассивФайловДляУдаления);
	
	ОбновитьЗарегистрированныеФайлы(МассивФайловДляПроверкиРегистрации);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьУзелДерева(ИмяФайла, РодительУИ, АдресВХранилище, Расширение, УИ, ФайлСсылка = Неопределено, Входящий = Ложь)
	
	КартинкаОтображения = БиблиотекаКартинок.ПиктограммаФайла_XML;
	Если ВРег(Расширение) = "ZIP" Тогда
		КартинкаОтображения = БиблиотекаКартинок.ПиктограммаФайла_WinRar;
	КонецЕсли; 
	
	Стр = Новый Структура("ИмяФайла, Родитель, АдресХранилища, Картинка, УникальныйИдентификатор, СсылкаФайл, Прикреплен, Входящий",
							ИмяФайла,
							Строка(РодительУИ),
							АдресВХранилище,
							КартинкаОтображения,
							Строка(УИ),
							ФайлСсылка,
							ЗначениеЗаполнено(ФайлСсылка),
							Входящий
						);
	НовыйУзел = ОбходИерархии_СоздатьУзелДерева(
																Стр,
																ЭтотОбъект.ДеревоСформированныеФайлы,
																"УникальныйИдентификатор"
															);
	ЗаполнитьЗначенияСвойств(НовыйУзел, Стр);
	
КонецПроцедуры

&НаСервере
Процедура СформироватьФайлыОбменаСервер()
	Отказ = ПроверкаЗаполнения();
	Если Отказ = Ложь Тогда
		ИмяАрхива = ПолучитьИмяФайлаИнформационногоОбмена(
																"ZIP",
																Неопределено,
																ДокументРеестра.СтруктурнаяЕдиница.Организация,
																ДокументРеестра.Контрагент,
																ДокументРеестра.НачалоПериода
															) + ".ZIP";
		ВременныйКаталог = КаталогВременныхФайлов();
		ПутьКАрхиву = ВременныйКаталог + ИмяАрхива;
		
		АрхивДляОтправки = Новый ЗаписьZipФайла(ПутьКАрхиву);
		
		// файл мед помощи
		Объект_ZL_LIST = СоздатьОбъект_ZL_LIST(ДокументРеестра);
		Если Объект_ZL_LIST = Неопределено Тогда
			Возврат;
		КонецЕсли; 
		// файл ПД
		Объект_PERS_LIST = СоздатьОбъект_PERS_LIST(ДокументРеестра);
		Если Объект_PERS_LIST = Неопределено Тогда
			Возврат;
		КонецЕсли; 
		
		ИмяФайла_ZL_LIST = Объект_ZL_LIST.ZGLV.FILENAME +".XML";
		ПутьКФайлу_ZL_LIST = ВременныйКаталог + ИмяФайла_ZL_LIST;

		СведенияОМедПомощи = Новый ЗаписьXML; 
		ПараметрыЗаписиXML = Новый ПараметрыЗаписиXML("windows-1251", "1.0", Ложь); 
		СведенияОМедПомощи.ОткрытьФайл(ПутьКФайлу_ZL_LIST, ПараметрыЗаписиXML); 
		СведенияОМедПомощи.ЗаписатьОбъявлениеXML(); 
		ФабрикаXDTO.ЗаписатьXML(СведенияОМедПомощи, Объект_ZL_LIST); 
		СведенияОМедПомощи.Закрыть();
		
		ДвоичныеДанныеФайла = Новый ДвоичныеДанные(ПутьКФайлу_ZL_LIST);
		Объект_ZL_LIST_Адрес = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, ЭтотОбъект.УникальныйИдентификатор);
		// дополним архив
		АрхивДляОтправки.Добавить(ПутьКФайлу_ZL_LIST); 
		
		
		ИмяФайла_PERS_LIST = Объект_PERS_LIST.ZGLV.FILENAME +".XML";
		ПутьКФайлу_PERS_LIST = ВременныйКаталог + ИмяФайла_PERS_LIST;

		СведенияОМедПомощи = Новый ЗаписьXML; 
		ПараметрыЗаписиXML = Новый ПараметрыЗаписиXML("windows-1251", "1.0", Ложь); 
		СведенияОМедПомощи.ОткрытьФайл(ПутьКФайлу_PERS_LIST, ПараметрыЗаписиXML); 
		СведенияОМедПомощи.ЗаписатьОбъявлениеXML(); 
		ФабрикаXDTO.ЗаписатьXML(СведенияОМедПомощи, Объект_PERS_LIST); 
		СведенияОМедПомощи.Закрыть();
		
		ДвоичныеДанныеФайла = Новый ДвоичныеДанные(ПутьКФайлу_PERS_LIST);
		Объект_PERS_LIST_Адрес = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, ЭтотОбъект.УникальныйИдентификатор);
		// дополним архив
		АрхивДляОтправки.Добавить(ПутьКФайлу_PERS_LIST); 
		
		АрхивДляОтправки.Записать();
		
		ДвоичныеДанныеФайла = Новый ДвоичныеДанные(ПутьКАрхиву);
		АрхивАдрес = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, ЭтотОбъект.УникальныйИдентификатор);
		
		// заполним дерево
		АрхивУИ = Новый УникальныйИдентификатор;
		ДобавитьУзелДерева(ИмяАрхива, "", АрхивАдрес, "ZIP", АрхивУИ);
		ДобавитьУзелДерева(ИмяФайла_ZL_LIST, АрхивУИ, Объект_ZL_LIST_Адрес, "XML", Новый УникальныйИдентификатор);
		ДобавитьУзелДерева(ИмяФайла_PERS_LIST, АрхивУИ, Объект_PERS_LIST_Адрес, "XML", Новый УникальныйИдентификатор);
		
		Попытка
			УдалитьФайлы(ПутьКАрхиву);
			УдалитьФайлы(ПутьКФайлу_ZL_LIST);
			УдалитьФайлы(ПутьКФайлу_PERS_LIST);
		Исключение
			Сообщение_ = Новый СообщениеПользователю;
			Сообщение_.Текст = ОписаниеОшибки();
			Сообщение_.Сообщить();
		КонецПопытки;
		
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция СохранитьФайл_Сервер(ИмяАрхива, АдресВХранилище)
	
	ФайлОбмена_ = Справочники.Файлы.ПустаяСсылка();
	
	Попытка
	
		// заново формируем архив
		ВременныйКаталог = КаталогВременныхФайлов();
		ПутьКАрхиву = ВременныйКаталог + ИмяАрхива;
		ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(АдресВХранилище);
		ДвоичныеДанныеФайла.Записать(ПутьКАрхиву);
		
		// если проблемы с архивом или архив пустой
		Если ПустаяСтрока(ИмяАрхива) ИЛИ ПустаяСтрока(ПутьКАрхиву) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		ЭтоВебКлиент = Ложь;
			
		Файл_Архив = Новый Файл(ПутьКАрхиву);
		СведенияОФайле_ = РаботаСФайламиКлиентСервер.СведенияОФайле("ФайлСВерсией", Файл_Архив);
		СведенияОФайле_.АдресВременногоХранилищаФайла = АдресВХранилище;
		ФайлОбмена_ = РаботаСФайламиСлужебныйВызовСервера.СоздатьФайлСВерсией(
																	ДокументРеестра.Ссылка,
																	СведенияОФайле_
																);
																
		
							
		УдалитьФайлы(ПутьКАрхиву);
	Исключение
		Сообщение_ = Новый СообщениеПользователю;
		Сообщение_.Текст = ОписаниеОшибки();
		Сообщение_.Сообщить();
	КонецПопытки;
	
	Возврат ФайлОбмена_;
	
КонецФункции

&НаСервере
Функция РегистрацияПакета_Сервер(СсылкаФайл, Входящий)
	
	Если ЭтотОбъект.ДокументРеестра.Проведен = Ложь Тогда
		ПоказатьСообщение("РегистрацияПакетовИО_РегистрацияПакетовСейчасНевозможна");
		Возврат Ложь;
	КонецЕсли;
	
	Если Входящий Тогда
		ИсходящийЗарегистрирован = РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ПроверитьРегистрациюДокумента(
																				ЭтотОбъект.ДокументРеестра, Ложь);
		Если ИсходящийЗарегистрирован = Ложь Тогда
			ПоказатьСообщение("РегистрацияПакетовИО_РегистрацияОтветаСейчасНевозможна");
			Возврат Ложь;
		КонецЕсли; 
	КонецЕсли; 

	// Попытка
		НачатьТранзакцию();
		
		РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.РегистрацияПакетаОбмена(
																		ЭтотОбъект.ДокументРеестра.НачалоПериода,
																		ЭтотОбъект.ДокументРеестра,
																		СсылкаФайл,
																		Входящий
																	);
													
		// пересчитываем количество пакетов
		ОпределитьКоличествоПакетовОбмена();
		
		ЗафиксироватьТранзакцию();
	// Исключение
//		ОтменитьТранзакцию();
		// Возврат Ложь;
	// КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ОтменаРегистрации_Сервер(Период, НомерПакета, Источник, Получатель, Входящий)
	
	Если Входящий = Ложь Тогда
		ВходящийЗарегистрирован = РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ПроверитьРегистрациюДокумента(
																				ЭтотОбъект.ДокументРеестра, Истина);
		Если ВходящийЗарегистрирован Тогда
			ПоказатьСообщение("РегистрацияПакетовИО_ОтменаРегистрацииСейчасНевозможна");
			Возврат Ложь;
		КонецЕсли; 
	КонецЕсли; 
	
	Попытка
		НачатьТранзакцию();
		
		// отменяем регистрацию пакета
		РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ОтменаРегистрацииПакетаОбмена(
																					Период,
																					НомерПакета,
																					Источник,
																					Получатель,
																					Входящий
																				);
		
		ОпределитьКоличествоПакетовОбмена();
 		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ОтменаРегистрацииФайла_Сервер(Файл, Входящий)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РегистрацияПакетовИнформационногоОбмена.НомерПакета,
		|	РегистрацияПакетовИнформационногоОбмена.Период,
		|	РегистрацияПакетовИнформационногоОбмена.Источник,
		|	РегистрацияПакетовИнформационногоОбмена.Получатель
		|ИЗ
		|	РегистрСведений.РегистрацияПакетовИнформационногоОбмена КАК РегистрацияПакетовИнформационногоОбмена
		|ГДЕ
		|	РегистрацияПакетовИнформационногоОбмена.ФайлОбмена = &ФайлОбмена";
	Запрос.УстановитьПараметр("ФайлОбмена", Файл);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Входящий = Ложь Тогда
			ВходящийЗарегистрирован = РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ПроверитьРегистрациюДокумента(
																					ЭтотОбъект.ДокументРеестра, Истина);
			Если ВходящийЗарегистрирован Тогда
				ПоказатьСообщение("РегистрацияПакетовИО_ОтменаРегистрацииСейчасНевозможна");
				Возврат Ложь;
			КонецЕсли; 
		КонецЕсли; 
		// отменяем регистрацию пакета
		РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ОтменаРегистрацииПакетаОбмена(
																			Выборка.Период,
																			Выборка.НомерПакета,
																			Выборка.Источник,
																			Выборка.Получатель,
																			Входящий
																		);
	КонецЦикла;
		
	Возврат Истина;
	
КонецФункции

