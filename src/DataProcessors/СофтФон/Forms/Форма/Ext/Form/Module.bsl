		                      |	ВложенныйЗапрос.Фамилия,
		                      |	ВложенныйЗапрос.Имя,
		                      |	ВложенныйЗапрос.Отчество");
	Запрос.УстановитьПараметр("Поиск", "%"+СтрокаПоиска+"%");
	Результат = Запрос.Выполнить().Выгрузить();
	СписокКонтрагентов = Новый СписокЗначений;
	Для Каждого НайденныйЭлемент Из Результат Цикл
		СписокКонтрагентов.Добавить(НайденныйЭлемент.Ссылка);		
	КонецЦикла;			 	
	
	Возврат СписокКонтрагентов; 	
	
КонецФункции

