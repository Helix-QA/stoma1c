
#Область ПрограммныйИнтерфейс

// Функция - Кассовый сервер используется
// 
// Возвращаемое значение:
//   - 
//
Функция КассовыйСерверИспользуется(Организация = Неопределено) Экспорт
	
	Возврат ЗначениеЗаполнено(ПодключаемоеОборудованиеКассовыйСервер.ИспользуемыйВСистемеКассовыйСервер(Организация));
	
КонецФункции

// Функция, получить используемый кассовый сервер и кассу.
//
Функция ПолучитьИспользуемыйКассовыйСерверИКассу(Организация) Экспорт
	
	ПолученныйКассовыйСервер = ПодключаемоеОборудованиеКассовыйСервер.ИспользуемыйВСистемеКассовыйСервер(Организация);
	
	Если ЗначениеЗаполнено(ПолученныйКассовыйСервер) Тогда
		
		ПараметрыСервера = МенеджерОборудованияВызовСервера.ПолучитьПараметрыУстройства(ПолученныйКассовыйСервер);
		Касса = ?(ПараметрыСервера <> Неопределено И ПараметрыСервера.Свойство("КассаОплаты"), ПараметрыСервера.КассаОплаты, Неопределено);
		
	КонецЕсли;
	
	Возврат Новый Структура("КассовыйСервер, Касса", ПолученныйКассовыйСервер, Касса);
	
КонецФункции

// Функция, получить используемый кассовый сервер по кассе.
//
Функция ПолучитьКассовыйСерверПоКассе(Касса) Экспорт
	
	Возврат ПодключаемоеОборудованиеКассовыйСервер.ПолучитьКассовыйСерверПоКассе(Касса);
	
КонецФункции

// Функция - Получить дату отбора из очереди кассового сервера
//
// Параметры:
//  КассаОплаты	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДатуОтбораИзОчередиКассовогоСервера(КассаОплаты) Экспорт
	
	ТекущаяКассоваяСмена = Документы.КассоваяСмена.ПолучитьСостояниеКассовойСмены(КассаОплаты);	
	Возврат ?(ТекущаяКассоваяСмена = Неопределено, НачалоДня(ТекущаяДатаСеанса()), ТекущаяКассоваяСмена.НачалоКассовойСмены);	

КонецФункции

// Функция - В текущем сеансе разрешено использвоание кассового сервера
// 
// Возвращаемое значение:
//   - 
//
Функция ВТекущемСеансеРазрешенЗапускКассовогоСервера() Экспорт
	
	ВСистемеРазрешено = КассовыйСервер.КассовыйСерверИспользуется();
	
	РабочееМесто = КассовыйСерверПовтИсп.ПолучитьРабочееМестоКассовогоСервера();
	
	Возврат ВСистемеРазрешено = Истина И ПараметрыСеанса.РабочееМестоКлиента = РабочееМесто; 
	
КонецФункции

