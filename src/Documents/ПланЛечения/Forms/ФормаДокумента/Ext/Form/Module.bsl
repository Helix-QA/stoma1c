 &НаСервере 
// Функция Проверить вхождение номенклатуры в сегмент по согласованию.
//
Функция ПроверитьВхождениеВНоменклатуруСогласования(НоменклатураСтроки)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НоменклатураСегмента.Сегмент КАК Сегмент
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|ГДЕ
	|	НоменклатураСегмента.Номенклатура = &Номенклатура");
	Запрос.УстановитьПараметр("Номенклатура", НоменклатураСтроки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.Сегмент = ?(ЗначениеЗаполнено(ОтборСегментУслугПоСогласованию), ОтборСегментУслугПоСогласованию, Неопределено) Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
КонецФункции

&НаКлиенте
// Изменение номера приема.
//
Процедура ВыборНомераПриемаОбщаяКоманда(Команда)
	
	НомерКоманды = СтрЗаменить(Команда.Имя,"ВыборНомераПриема","");

	Для Каждого ЭлементГруппы Из Элементы.ГруппаНомераПриема.ПодчиненныеЭлементы Цикл
		// ЭлементГруппы.Пометка = Ложь;
		
		Если ТипЗнч(ЭлементГруппы) = Тип("КнопкаФормы") Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементГруппы.ЦветФона = Новый Цвет(242, 242, 242);
		ЭлементГруппы.ПодчиненныеЭлементы[0].ЦветТекста =  Новый Цвет(77, 77, 77);	
	КонецЦикла;
	
	// Элементы["НомерПриема"+НомерКоманды].Пометка = Истина;	
	Элементы["ГруппаНомерПриема_" + НомерКоманды].ЦветФона = Новый Цвет(25 , 116, 206);
	Элементы["ГруппаНомерПриема_" + НомерКоманды].ПодчиненныеЭлементы[0].ЦветТекста = Новый Цвет(255 , 255, 255);
	
	
	Если НомерКоманды = "Все" Тогда
		Элементы.ТаблицаЛечение.ОтборСтрок = Неопределено;
		Объект.Лечение.Сортировать("НомерПриема Возр"); 
		НомерПриемаПодбор = 0;
	Иначе
		Элементы.ТаблицаЛечение.ОтборСтрок = Новый ФиксированнаяСтруктура("НомерПриема", Число(НомерКоманды));
		НомерПриемаПодбор = НомерКоманды;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПередНачаломИзменения"
//
Процедура ТаблицаУслугиПередНачаломИзменения(Элемент, Отказ)
	
	Если Элемент.ТекущийЭлемент.Имя = "ТаблицаЛечениеПроцентСкидкиНаценки" Тогда		
		Если РазрешенаУстановкаСкидки(Элемент.ТекущиеДанные) Тогда
			ПроцентСкидки = ?(Элемент.ТекущиеДанные.Количество * Элемент.ТекущиеДанные.Цена <> 0, 
			Окр(100 * Элемент.ТекущиеДанные.СуммаРучнойСкидки / (Элемент.ТекущиеДанные.Количество * Элемент.ТекущиеДанные.Цена) , 2), 0);
			
			СтруктураЗаполнения = Новый Структура("ПроцентСкидки, МаксимальнаяРучнаяСкидка", ПроцентСкидки, ЭтотОбъект.МаксимальнаяРучнаяСкидка);  
			Описание = Новый ОписаниеОповещения("ПослеОткрытияФормыУстановкиРучнойСкидки", ЭтаФорма);
			ОткрытьФорму("ОбщаяФорма.ФормаУстановкиРучнойСкидки", СтруктураЗаполнения,,,,, Описание, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 		
		КонецЕсли; 
		Отказ = Истина;
	Иначе 
		Отказ = Ложь;		
	КонецЕсли;
	
КонецПроцедуры 
	
&НаКлиенте
// Процедура - обработчик события "ПередУдалением"
//
Процедура ТаблицаЛечениеПередУдалением(Элемент, Отказ)
	
	Если ЗначениеЗаполнено(Элемент.ТекущиеДанные.Прием) Тогда
		Если ТипЗнч(Элемент.ТекущиеДанные.Прием) = Тип("ДокументСсылка.Прием") Тогда 
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Данная строка не может быть удалена, так как находящаяся в ней номенклатура уже проведенна в документе " + Строка(Элемент.ТекущиеДанные.Прием);
			Сообщение.Поле = "Объект.Лечение[" + Строка(Элемент.ТекущиеДанные.НомерСтроки - 1) + "].Прием";
			Сообщение.УстановитьДанные(Объект);
			Сообщение.Сообщить();
			Отказ = Истина;
		ИначеЕсли ТипЗнч(Элемент.ТекущиеДанные.Прием) = Тип("ДокументСсылка.НарядЗаказ") Тогда
			СтруктураРезультата = НарядЗаказОформленПриемом(Элемент.ТекущиеДанные.Прием, Элемент.ТекущиеДанные.КлючСтроки);
			Если СтруктураРезультата.ПроведенаВПриеме Тогда 
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Данная строка не может быть удалена, так как находящаяся в ней номенклатура уже проведенна в документе " + СтруктураРезультата.СтрокаДокумент;
				Сообщение.Поле = "Объект.Лечение[" + Строка(Элемент.ТекущиеДанные.НомерСтроки - 1) + "].Прием";
				Сообщение.УстановитьДанные(Объект);
				Сообщение.Сообщить();
				Отказ = Истина;
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция определяет проведена ли услуга в Приеме
//
Функция НарядЗаказОформленПриемом(НарядЗаказ, КлючСтроки)
	
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("ПроведенаВПриеме", Ложь);
	СтруктураРезультата.Вставить("СтрокаДокумент", "");
	СтрокаТЧ_ЗапасыНЗ = НарядЗаказ.Запасы.Найти(КлючСтроки, "КлючСтроки");
	Если СтрокаТЧ_ЗапасыНЗ <> Неопределено Тогда 
		Если ЗначениеЗаполнено(СтрокаТЧ_ЗапасыНЗ.Прием) Тогда 
			СтруктураРезультата.Вставить("ПроведенаВПриеме", Истина);
			СтруктураРезультата.Вставить("СтрокаДокумент", Строка(СтрокаТЧ_ЗапасыНЗ.Прием));
		КонецЕсли;	
	КонецЕсли;
	
	Возврат СтруктураРезультата;
	
КонецФункции

&НаКлиенте
// Обработчик при начале редактирования данных таблицы.
//
Процедура ТаблицаУслугиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)	
	
	Если НоваяСтрока Тогда
		Элемент.ТекущиеДанные.КлючСтроки  = Новый УникальныйИдентификатор;
		Если Не Копирование Тогда
			МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
			Если МассивЗубов.Количество() = 0 Тогда
				Элемент.ТекущиеДанные.Зуб       = ОбщиеПараметры.Перечисление_Зубы_ВсяПолость;
			Иначе
				Элемент.ТекущиеДанные.Зуб		= МассивЗубов[0];
			КонецЕсли;
		КонецЕсли;
		Элемент.ТекущиеДанные.НомерПриема = НомерПриемаПодбор;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
