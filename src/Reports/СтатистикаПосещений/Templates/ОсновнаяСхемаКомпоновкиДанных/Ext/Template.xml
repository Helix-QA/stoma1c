		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Прием.Контрагент КАК Пациент,
	Прием.Контрагент.Телефон КАК Телефон,
	Прием.ПолисМедСтрахования.СтраховаяКомпания КАК СтраховаяКомпания,
	Прием.Сотрудник КАК Врач,
	МАКСИМУМ(Прием.Контрагент.ДатаРегистрации) КАК ДатаРегистрации,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Прием.Ссылка) КАК КоличествоПосещений,
	МИНИМУМ(Прием.Дата) КАК ДатаПервогоПосещения,
	МАКСИМУМ(Прием.Дата) КАК ДатаПоследнегоПосещения,
	СУММА(Прием.СуммаДокумента) КАК Оказано,
	СУММА(Прием.СуммаОплачено) КАК Оплачено,
	МАКСИМУМ(Прием.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиница,
	Прием.Ассистент КАК Ассистент,
	Прием.СтатусПациента КАК СтатусПриема
ИЗ
	Документ.Прием КАК Прием
ГДЕ
	НЕ Прием.ПометкаУдаления
	И Прием.Проведен
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
					ИЛИ &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА Прием.Дата &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
					ИЛИ &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА Прием.Дата &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}

СГРУППИРОВАТЬ ПО
	Прием.Контрагент,
	Прием.Контрагент.Телефон,
	Прием.Сотрудник,
	Прием.ПолисМедСтрахования.СтраховаяКомпания,
	Прием.Ассистент,
	Прием.СтатусПациента</query>
