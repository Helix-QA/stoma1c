//  Элемент	 - 	 - 
//
Процедура Подключаемый_ОбработкаНажатияДинамическойКнопкиЗапрещенияРассылкиМессенджер(Элемент)	
	
	ИндексСтроки = Число(Сред(Элемент.Имя, СтрДлина("ЗапретРассылки_")+1));
	НеУчаствоватьВРассылке = Не ЭтотОбъект.КонтактыМессенджеров[ИндексСтроки].НеУчаствоватьВРассылке;
	ЭтаФорма.КонтактыМессенджеров[ИндексСтроки].НеУчаствоватьВРассылке = НеУчаствоватьВРассылке;	
	Элемент.Картинка = ПолучитьКартинку(НеУчаствоватьВРассылке);
	Элемент.Подсказка = ПолучитьПодсказку(НеУчаствоватьВРассылке);
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Подключаемый перейти к диалогу
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ПерейтиКДиалогу(Элемент)	
	
	Если Объект.Ссылка.Пустая() Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаОЗаписиКлиента", ЭтотОбъект, Новый Структура("ВыполнитьДействие, Элемент", "ПерейтиКДиалогу", Элемент));
		ПоказатьВопрос(Оповещение, "Для перехода в мессенджер необходимо произвести запись нового клиента. Записать?", РежимДиалогаВопрос.ДаНет);
	Иначе
		
		Если Модифицированность И Не ЭтаФорма.Записать() Тогда
			Возврат;
		КонецЕсли;
		
		ИндексСтроки = Число(Сред(Элемент.Имя, СтрДлина("ПерейтиКДиалогу_")+1));
		ДанныеКИ     = ЭтотОбъект.КонтактнаяИнформация[ИндексСтроки];
		
		ПредставлениеНомераТелефона = ДанныеКИ.Представление;
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, " ", "");
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, "(", "");
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, ")", "");
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, "+", "");
		
		Если НЕ ЗначениеЗаполнено(ПредставлениеНомераТелефона) Тогда
			ОбщегоНазначения.СообщитьПользователю("Пустой номер телефона клиента");
			Возврат;
		КонецЕсли;
	
		ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Ссылка, ТекущаяСтруктурнаяЕдиница, Истина, ПредставлениеНомераТелефона);
					
		Если ДанныеВнешнихСистемМессенджера.Количество() = 0 Тогда
			Возврат;
		ИначеЕсли ДанныеВнешнихСистемМессенджера.Количество() = 1 Тогда
			Подключаемый_ПерейтиКДиалогуЗавершение(ДанныеВнешнихСистемМессенджера[0],Неопределено);
			Возврат;
		КонецЕсли;

		ОписаниеОповещения = Новый ОписаниеОповещения("Подключаемый_ПерейтиКДиалогуЗавершение", ЭтотОбъект);
	
		ПоказатьВыборИзМеню(ОписаниеОповещения, ДанныеВнешнихСистемМессенджера, Элемент);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура Подключаемый_ПерейтиКДиалогуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Идентификатор = Результат.Значение.Идентификатор;
	ВнешняяСистема= Результат.Значение.ВнешняяСистема;
	
	ОписаниеОшибки = "";
	
	ИдСообщения = УстановитьОжиданиеСообщения(Идентификатор,ВнешняяСистема,ОписаниеОшибки,Объект.Ссылка,Результат.Значение.НомерМессенджера);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ДанныеКанала = Новый Структура;
	ДанныеКанала.Вставить("ИдКлиента"		, Идентификатор);
	ДанныеКанала.Вставить("ВнешняяСистема"	, ВнешняяСистема);
	ДанныеКанала.Вставить("ИдСообщения"		, ИдСообщения);
	
	ПараметрыОткрытия = Новый Структура("ДанныеКанала", ДанныеКанала);
	
	Оповестить("ОткрытьДиалог", ПараметрыОткрытия);
	ОткрытьФорму("Обработка.Мессенджер_Стоматология.Форма", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

