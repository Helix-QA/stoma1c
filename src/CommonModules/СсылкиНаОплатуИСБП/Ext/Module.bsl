// Функция - Получить номер заказа
//
// Параметры:
//  Основание	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНомерЗаказа(Основание)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.Основание КАК Основание,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СтатусыОплатыЗаказов.НомерЗаказа) КАК Количество
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Основание = &Основание
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатусыОплатыЗаказов.Основание");
	
	Запрос.УстановитьПараметр("Основание", Основание);	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Количество + 1, 1);
	
КонецФункции

