// Функция - Записать дополнительные параметры
//
// Параметры:
//  ОбъектСобытие			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаписатьДополнительныеПараметры(ОбъектСобытие, ДополнительныеПараметры)

	ДиалогID 							= "";								
	СценарийЧатБота 					= Неопределено;
	ПеренесённаяПредварительнаяЗапись 	= Неопределено;
	
	ЕстьПараметрыСценария 				= НЕ ДополнительныеПараметры = Неопределено
											И ТипЗнч(ДополнительныеПараметры) = Тип("Структура")
											И ДополнительныеПараметры.Свойство("СценарийЧатБота");
	Если ЕстьПараметрыСценария Тогда 
		СценарийЧатБота 				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "СценарийЧатБота"	, Неопределено);
		ДиалогID 						= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ДиалогID"		, "");
		Если ДополнительныеПараметры.Свойство("ДанныеСценария") Тогда 
			ПеренесённаяПредварительнаяЗапись = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры.ДанныеСценария, "ПредварительнаяЗапись", Неопределено);
			Если НЕ ЗначениеЗаполнено(ПеренесённаяПредварительнаяЗапись) Тогда 
				ПеренесённаяПредварительнаяЗапись = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры.ДанныеСценария, "Запись", Неопределено);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ЗначениеЗаполнено(ПеренесённаяПредварительнаяЗапись) Тогда 
		ОбъектСобытие.ПеренесённаяПредварительнаяЗапись = ПеренесённаяПредварительнаяЗапись;	
	КонецЕсли;	
	ОбъектСобытие.ИдентификаторДиалога 	= ДиалогID;	
	
	Возврат ЕстьПараметрыСценария;
	
КонецФункции

Функция ПолучитьЗаявку(Клиент
					, ФИОКлиента = ""
					, ИсточникИнформации
					, СтруктурнаяЕдиница
					, ВнешняяСистема
					, НомерТелефона) Экспорт
	
	Попытка
		
		ДанныеЗаполнения = Новый Структура();
		ДанныеЗаполнения.Вставить("ДатаСоздания"      , ТекущаяДатаСеанса());
		ДанныеЗаполнения.Вставить("ОсновнойКлиент"    , Клиент);
		ДанныеЗаполнения.Вставить("РекламныйИсточник" , ИсточникИнформации);	
		ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		ДанныеЗаполнения.Вставить("ВнешняяСистема"    , ВнешняяСистема); 
		//ДанныеЗаполнения.Вставить("Статус"            , Перечисления.СтатусыЗаявок.Принята);
		ДанныеЗаполнения.Вставить("НомерТелефона"     , НомерТелефона);
		
		Если ЗначениеЗаполнено(ФИОКлиента) Тогда 
			ФИО = ОбщегоНазначения.ВернутьФИОКлиента(ФИОКлиента);
			ДанныеЗаполнения.Вставить("Фамилия" , ФИО.Фамилия); 
			ДанныеЗаполнения.Вставить("Имя"     , ФИО.Имя); 
			ДанныеЗаполнения.Вставить("Отчество", ФИО.Отчество);
		ИначеЕсли ЗначениеЗаполнено(Клиент) Тогда 
			СтруктураФИО = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Клиент, "Фамилия, Имя, Отчество");
			ДанныеЗаполнения.Вставить("Фамилия" , СтруктураФИО.Фамилия); 
			ДанныеЗаполнения.Вставить("Имя"     , СтруктураФИО.Имя); 
			ДанныеЗаполнения.Вставить("Отчество", СтруктураФИО.Отчество);
		Иначе 	
			Наименование = Клиент.Наименование;
			Если ЗначениеЗаполнено(СокрЛП(Наименование)) Тогда 
				ФИО = ОбщегоНазначения.ВернутьФИОКлиента(Наименование);
				ДанныеЗаполнения.Вставить("Фамилия" , ФИО.Фамилия); 
				ДанныеЗаполнения.Вставить("Имя"     , ФИО.Имя); 
				ДанныеЗаполнения.Вставить("Отчество", ФИО.Отчество);
			КонецЕсли;
		КонецЕсли;
		
		ЗаявкаОбъект = Справочники.Заявки.ПолучитьЗаявкуПоНомеруТелефона(НомерТелефона);
		
		Если Не ЗначениеЗаполнено(ЗаявкаОбъект) Тогда
			ЗаявкаОбъект = Справочники.Заявки.СоздатьЭлемент();	
		КонецЕсли;

		ЗаявкаОбъект.Заполнить(ДанныеЗаполнения);
		ЗаявкаОбъект.Записать();
			
		Возврат ЗаявкаОбъект.Ссылка;
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции
																																	
