Процедура ЗаполнитьСорудниковСогласноОтборов(ИсключаемыйОтбор = Неопределено, ВременныйСписокСотрудников = Неопределено)

	#Область СтарыйЗапро
	//ЗАпрос.Текст = 
	//"ВЫБРАТЬ РАЗРЕШЕННЫЕ
