// Процедура копирует все вложения из указанного письма
//
Процедура ПеренестиВложенияИзДругогоПисьма(ПисьмоОснование)
	
	Если ТипЗнч(ПисьмоОснование) = Тип("ДокументСсылка.ЭлектронноеПисьмоВходящее")
		ИЛИ ТипЗнч(ПисьмоОснование) = Тип("ДокументСсылка.ЭлектронноеПисьмоИсходящее") Тогда
		
		ПересылаемыеВложения = УправлениеЭлектроннойПочтой.ПолучитьВложенияЭлектронногоПисьма(ПисьмоОснование);
		
		ТаблицаВложений = ДанныеФормыВЗначение(Вложения, Тип("ТаблицаЗначений"));
		
		Для Каждого СтрокаПересылаемогоВложения Из ПересылаемыеВложения Цикл
			СтрокаВложения = ТаблицаВложений.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаВложения, СтрокаПересылаемогоВложения);
			СтрокаВложения.Расположение = 1;	// из двоичных данных другого вложения
		КонецЦикла;
		
		ЗначениеВДанныеФормы(ТаблицаВложений, Вложения);
		
	КонецЕсли;

КонецПроцедуры

