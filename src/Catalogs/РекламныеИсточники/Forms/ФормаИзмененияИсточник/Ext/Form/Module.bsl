
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Источник") Тогда 
		ЭтотОбъект.Источник =  Параметры.Источник;
	КонецЕсли;
	Если (Источник = ПредопределенноеЗначение("Справочник.РекламныеИсточники.ДругойПациент")) Тогда
		Элементы.ИсточникЗначение.Видимость = Истина;
	КонецЕсли;
	Если Параметры.Свойство("ИсточникЗначение") Тогда 
		ЭтотОбъект.ИсточникЗначение =  Параметры.ИсточникЗначение;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Перед закрытием.
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	СтандратнаяОбработка = Ложь;
	Закрыть(Новый Структура("Источник, ИсточникЗначение", Источник, ИсточникЗначение));
	
КонецПроцедуры

#КонецОбласти

#Область ОбработкаСобытийЭлементовФормы

&НаКлиенте
// Процедура - Источник при изменении.
//
Процедура ИсточникПриИзменении(Элемент)
	
	Если (Источник = ПредопределенноеЗначение("Справочник.РекламныеИсточники.ДругойПациент")) Тогда
		Элементы.ИсточникЗначение.Видимость = Истина;
	Иначе
		Закрыть(Новый Структура("Источник, ИсточникЗначение", Источник, ИсточникЗначение));
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура - Источник значение при изменении.
//
Процедура ИсточникЗначениеПриИзменении(Элемент)
	
	Закрыть(Новый Структура("Источник, ИсточникЗначение", Источник, ИсточникЗначение));
	
КонецПроцедуры

#КонецОбласти
