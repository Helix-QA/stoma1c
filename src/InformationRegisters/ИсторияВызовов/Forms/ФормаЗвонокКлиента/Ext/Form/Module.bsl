&НаСервере
// Процедура - Инициализировать номер телефона клиента
//
Процедура ИнициализироватьПараметрыТелефонногоЗвонка()
	
	Если ТаблицаАктивныхПользователей.НайтиСтроки(Новый Структура("ВнутреннийНомер", СНомерТелефона)).Количество() <> 0 Тогда 
		// Это переадресация с внутреннего номера
	Иначе 	
		НомерТелефонаКлиента = СНомерТелефона;
	КонецЕсли;
		
	ПараметрыТелефонногоЗвонка = Новый Структура("ДатаВремяЗвонка, ПиктограммаЗвонка, НачалоРазговора, ОкончаниеЗвонка, URLЗаписи, ФайлЗаписи, Заявка, КоллтрекингНомер, Заметка, ВнутреннийНомерСотрудника", Дата(1,1,1), 0, Дата(1,1,1), Дата(1,1,1), "", Справочники.Файлы.ПустаяСсылка(), Справочники.Заявки.ПустаяСсылка(), "");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ИсторияВызовов.Заявка КАК Заявка,
	|	ВЫБОР
	|		КОГДА ИсторияВызовов.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Исходящий)
	|			ТОГДА ИсторияВызовов.ПользовательSip
	|		ИНАЧЕ ИсторияВызовов.НомерТелефона
	|	КОНЕЦ КАК НомерТелефонаКлиента,
	|	ВЫБОР
	|		КОГДА ИсторияВызовов.НачалоРазговора = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ИсторияВызовов.НачалоВызова
	|		ИНАЧЕ ИсторияВызовов.НачалоРазговора
	|	КОНЕЦ КАК ДатаВремяЗвонка,
	|	ВЫБОР
	|		КОГДА ИсторияВызовов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Пропущен)
	|			ТОГДА 2
	|		КОГДА ИсторияВызовов.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Исходящий)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПиктограммаЗвонка,
	|	ИсторияВызовов.ПользовательSip КАК ПользовательSip,
	|	ИсторияВызовов.НомерТелефона КАК НомерТелефона,
	|	ИсторияВызовов.НачалоРазговора КАК НачалоРазговора,
	|	ИсторияВызовов.ОкончаниеЗвонка КАК ОкончаниеЗвонка,
	|	ИсторияВызовов.КоллтрекингНомер КАК КоллтрекингНомер,
	|	ИсторияВызовов.URLЗаписи КАК URLЗаписи,
	|	ИсторияВызовов.ФайлЗаписи КАК ФайлЗаписи,
	|	ИсторияВызовов.Заметка КАК Заметка,
	|	ИсторияВызовов.ВнутреннийНомерСотрудника КАК ВнутреннийНомерСотрудника
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.ОборудованиеТелефонии = &ОборудованиеТелефонии
	|	И ИсторияВызовов.IDЗвонка = &IDЗвонка");
	
	Запрос.УстановитьПараметр("ОборудованиеТелефонии"	, ПОIPТелефонии);
	Запрос.УстановитьПараметр("IDЗвонка"				, IDЗвонка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(ПараметрыТелефонногоЗвонка, Выборка);		
		
		Если НЕ ЗначениеЗаполнено(НомерТелефонаКлиента) Тогда
			
			ЭтоAtsAm   		 = ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсAtsAm;
			ЭтоITOOLABS      = ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS;
			ЭтоCoMagic 		 = ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсCoMagic;
			ЭтоBINOTEL		 = ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсBINOTEL;
			
			Если ЭтоAtsAm ИЛИ ЭтоCoMagic ИЛИ ЭтоITOOLABS ИЛИ ЭтоBINOTEL Тогда
				НомерТелефонаКлиента = Выборка.НомерТелефона;
			ИначеЕсли ЗначениеЗаполнено(Выборка.НомерТелефонаКлиента) И СтрДлина(Выборка.НомерТелефонаКлиента) > 4 Тогда 
				НомерТелефонаКлиента = Выборка.НомерТелефонаКлиента;
			Иначе 
				НомерТелефонаКлиента = Макс(Выборка.ПользовательSip, Выборка.НомерТелефона);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Формируем представление и варианты номера телефона
	СформироватьПредставлениеИСписокВариантовНомера(НомерТелефонаКлиента, ПреобразованныйНомерТелефона, СписокВариантовНомераТелефона);
	
	// Получаем структуру блокировки номера, если был заблокирован
	ПолучитьСтруктуруБлокировкиНомера(СтруктураБлокировкиНомера, СписокВариантовНомераТелефона);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Получить структуру блокировки номера
//
// Параметры:
//  СтруктураБлокировкиНомера		 - 	 - 
//  СписокВариантовНомераТелефона	 - 	 - 
//
Процедура ПолучитьСтруктуруБлокировкиНомера(СтруктураБлокировкиНомера, Знач СписокВариантовНомераТелефона)
	
	СтруктураБлокировкиНомера = Неопределено;
	
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= "ВЫБРАТЬ
	             	  |	ЗаблокированныеНомераТелефонов.НомерТелефонаАбонента,
	             	  |	ЗаблокированныеНомераТелефонов.ПричинаБлокировки,
	             	  |	ЗаблокированныеНомераТелефонов.АвторБлокировки
	             	  |ИЗ
	             	  |	РегистрСведений.ЗаблокированныеНомераТелефонов КАК ЗаблокированныеНомераТелефонов
	             	  |ГДЕ
	             	  |	ЗаблокированныеНомераТелефонов.НомерТелефонаАбонента В(&МассивНомеровТелефонаАбонента)";
	
	Запрос.УстановитьПараметр("МассивНомеровТелефонаАбонента", СписокВариантовНомераТелефона.ВыгрузитьЗначения());
	
	ВыборкаЗаблокированных = Запрос.Выполнить().Выбрать();
	Если ВыборкаЗаблокированных.Следующий() Тогда
		СтруктураБлокировкиНомера = Новый Структура("НомерТелефонаАбонента, ПричинаБлокировки, АвторБлокировки");
		ЗаполнитьЗначенияСвойств(СтруктураБлокировкиНомера, ВыборкаЗаблокированных);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Сформировать представление и список вариантов номера
//
// Параметры:
//  НомерТелефона					 - 	 - 
//  ПреобразованныйНомерТелефона	 - 	 - 
//  СписокВариантовНомераТелефона	 - 	 - 
//
Процедура СформироватьПредставлениеИСписокВариантовНомера(Знач НомерТелефона, ПреобразованныйНомерТелефона, СписокВариантовНомераТелефона)
	
	НомерТелефона = СокрЛП(НомерТелефона);	
	СписокВариантовНомераТелефона.Очистить();
	СписокВариантовНомераТелефона.Добавить(НомерТелефона);
	УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(НомерТелефона, Новый СписокЗначений);
	СписокВариантовНомераТелефона.Добавить(НомерТелефона);
	
	Если ЗначениеЗаполнено(НомерТелефона) Тогда 
		
		Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон);
		
		Если Объект_XDTO_Телефон <> Неопределено Тогда
			
			СписокВариантовНомераТелефона.Добавить(Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			СписокВариантовНомераТелефона.Добавить(Объект_XDTO_Телефон.Представление);
			
			КодСтраны = Константы.СтранаУчета.Получить().Код;
			// КодСтраны = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Страна.Код;
			
			Если КодСтраны = "804" Тогда
				СписокВариантовНомераТелефона.Добавить("38"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокВариантовНомераТелефона.Добавить("+38" + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			ИначеЕсли КодСтраны = "051" Тогда
				СписокВариантовНомераТелефона.Добавить("374"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокВариантовНомераТелефона.Добавить("+374" + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);	
			Иначе
				СписокВариантовНомераТелефона.Добавить("0"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокВариантовНомераТелефона.Добавить("8"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокВариантовНомераТелефона.Добавить("7"  + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокВариантовНомераТелефона.Добавить("+7" + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			КонецЕсли;	
		КонецЕсли;
		
	КонецЕсли;
	
	ПреобразованныйНомерТелефона = НомерТелефона;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить структуру клиента по номеру телефона
//
// Параметры:
//  СписокВариантовНомераТелефона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуруКлиентаПоНомеруТелефона(СписокВариантовНомераТелефона)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 	
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Контрагент,
		|	КонтрагентыКонтактнаяИнформация.Ссылка.Наименование КАК Наименование,
		|	ВЫРАЗИТЬ(КонтрагентыКонтактнаяИнформация.Ссылка.НаименованиеПолное КАК Строка(1000)) КАК НаименованиеПолное,
		|	КонтрагентыКонтактнаяИнформация.Ссылка.Куратор КАК Куратор,
		|	КонтрагентыКонтактнаяИнформация.Ссылка.ДатаРожденияКлиента КАК ДатаРожденияКлиента
		|ПОМЕСТИТЬ ТаблицаКонтрагентов
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
		|	И КонтрагентыКонтактнаяИнформация.НомерТелефона В(&МассивНомеровТелефонов)
		|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ 
		|	Сделки.Контрагент КАК Контрагент,
		|	Сделки.Контрагент.Наименование КАК КонтрагентНаименование,
		|	ВЫРАЗИТЬ(Сделки.Контрагент.НаименованиеПолное КАК Строка(1000)) КАК КонтрагентНаименованиеПолное,
		|	Сделки.Контрагент.Куратор КАК КонтрагентКуратор,
		|	Сделки.Контрагент.ДатаРожденияКлиента КАК КонтрагентДатаРожденияКлиента
		|ИЗ
		|	Справочник.Сделки КАК Сделки
		|ГДЕ
		|	Сделки.ВходящийНомерТелефона В(&МассивНомеровТелефонов)
		|	И НЕ Сделки.Ссылка.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ 
		|	Событие.Контрагент КАК Контрагент,
		|	Событие.Контрагент.Наименование КАК КонтрагентНаименование,
		|	ВЫРАЗИТЬ(Событие.Контрагент.НаименованиеПолное КАК Строка(1000)) КАК КонтрагентНаименованиеПолное,
		|	Событие.Контрагент.Куратор КАК КонтрагентКуратор,
		|	Событие.Контрагент.ДатаРожденияКлиента КАК КонтрагентДатаРожденияКлиента
		|ИЗ
		|	Документ.Событие КАК Событие
		|ГДЕ
		|	Событие.ВходящийНомерТелефона В(&МассивНомеровТелефонов)
		|	И НЕ Событие.Ссылка.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаКонтрагентов.Контрагент КАК Контрагент,
		|	ТаблицаКонтрагентов.Наименование КАК Наименование,
		|	ТаблицаКонтрагентов.НаименованиеПолное КАК НаименованиеПолное,
		|	ТаблицаКонтрагентов.Куратор КАК Куратор,
		|	ЕСТЬNULL(СтатусыКонтрагентовСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)) КАК СтатусКонтрагента,
		|	ТаблицаКонтрагентов.ДатаРожденияКлиента КАК ДатаРожденияКлиента
		|ПОМЕСТИТЬ ТаблицаКонтрагентовСоСтатусами
		|ИЗ
		|	ТаблицаКонтрагентов КАК ТаблицаКонтрагентов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
		|				,
		|				Контрагент В
		|					(ВЫБРАТЬ
		|						ВТКонтрагенты.Контрагент
		|					ИЗ
		|						ТаблицаКонтрагентов КАК ВТКонтрагенты)) КАК СтатусыКонтрагентовСрезПоследних
		|		ПО ТаблицаКонтрагентов.Контрагент = СтатусыКонтрагентовСрезПоследних.Контрагент";
	

	
	Запрос.УстановитьПараметр("МассивНомеровТелефонов", СписокВариантовНомераТелефона.ВыгрузитьЗначения());

	МассивТаблиц = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	ТаблицаКонтрагентов 			= МассивТаблиц[1].Выгрузить();

	СписокКонтрагентов 				= Новый СписокЗначений;
	СписокКонтрагентов_Временный 	= Новый СписокЗначений;
	СтруктураКлиента 				= Новый Структура;
	
	Для Каждого СтрокаТаблицы Из ТаблицаКонтрагентов Цикл 
		Если ЗначениеЗаполнено(СтрокаТаблицы.Контрагент) И СписокКонтрагентов_Временный.НайтиПоЗначению(СтрокаТаблицы.Контрагент) = Неопределено Тогда
			СписокКонтрагентов.Добавить(Новый Структура("КонтрагентСсылка, Наименование, НаименованиеПолное, СтатусКонтрагента, Куратор, ДатаРожденияКлиента, ПредставлениеДатыРожденияСтрокой", СтрокаТаблицы.Контрагент, СтрокаТаблицы.Наименование, СтрокаТаблицы.НаименованиеПолное, СтрокаТаблицы.СтатусКонтрагента, СтрокаТаблицы.Куратор, СтрокаТаблицы.ДатаРожденияКлиента, ""));
			СписокКонтрагентов_Временный.Добавить(СтрокаТаблицы.Контрагент);
		КонецЕсли;
	КонецЦикла;	
	
	СтруктураКлиента.Вставить("СписокКонтрагентов", СписокКонтрагентов);
	
	СписокКонтрагентов_Временный.Очистить();
	
	Возврат СтруктураКлиента;

КонецФункции	

&НаСервереБезКонтекста
// Процедура - Добавить необрабатываемый номер
//
// Параметры:
//  Номер	 - 	 - 
//
Процедура ДобавитьНеобрабатываемыйНомер(Знач НомерТелефона, Знач ПричинаБлокировки = "")
	
	УстановитьПривилегированныйРежим(Истина);
	
