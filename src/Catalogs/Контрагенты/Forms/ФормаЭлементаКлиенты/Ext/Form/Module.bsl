//
//
Процедура ПроверкаДублированияКлиента(Знач Оповещение)
	
	Если (ПредупреждениеДублирование <> Неопределено И ПредупреждениеДублирование = Истина) И Оповещение <> Неопределено Тогда
		ВыполнитьОбработкуОповещения(Оповещение);
		Возврат;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Фамилия) И ЗначениеЗаполнено(Объект.Имя) И ЗначениеЗаполнено(Объект.Отчество) И ЗначениеЗаполнено(Объект.ДатаРожденияКлиента) Тогда	
		
		Поля = "Фамилия;Имя;Отчество;ДатаРожденияКлиента";
		
		МассивКлиентов = ПроверитьНаДублированиеКлиентаПоля(Поля);
		Если МассивКлиентов <> Неопределено И МассивКлиентов.Количество() > 0 Тогда
        	Результат = Неопределено;

        	ПоказатьВопрос(Новый ОписаниеОповещения("ПроверкаДублированияКлиентаЗавершение", ЭтотОбъект, Новый Структура("МассивКлиентов, Оповещение", МассивКлиентов, Оповещение)), "Клиент с такими данными уже существует, открыть существующего клиента ?", РежимДиалогаВопрос.ДаНет);
            Возврат;                                       

		КонецЕсли;
		
	КонецЕсли;  
	
	ВыполнитьОбработкуОповещения(Оповещение);
	
КонецПроцедуры

