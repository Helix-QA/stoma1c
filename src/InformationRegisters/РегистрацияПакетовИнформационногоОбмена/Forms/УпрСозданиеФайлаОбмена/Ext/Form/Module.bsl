												ИмяФайла,
												"",
												АдресХранилища
											);
	
КонецФункции

&НаСервере
Процедура ДобавитьФайлОбмена_Сервер(ИмяБезРасширения, Расширение, АдресВХранилище)
	
	МассивФайловДляУдаления = Новый Массив();
	
	ИмяАрхива = ИмяБезРасширения + "." + Расширение;
	
	Попытка
		РезультатПроверки = ПроверитьИмяФайлаНаОтправителяИОтчетныйПериод(
																					ИмяБезРасширения,
																					Неопределено,
																					ДокументРеестра.Контрагент,
																					ДокументРеестра.СтруктурнаяЕдиница.Организация,
																					ДокументРеестра.НачалоПериода
																				);
		Если РезультатПроверки = Ложь Тогда
			Параметры_ = Новый Структура();
			Параметры_.Вставить("ИмяАрхива",ИмяАрхива);
			Параметры_.Вставить("Контрагент",ДокументРеестра.Контрагент);
			Параметры_.Вставить("Организация",ДокументРеестра.СтруктурнаяЕдиница.Организация);
			ПоказатьСообщение("РегистрацияПакетовИО_ФайлНеПрошелПроверку",Параметры_);
			Возврат;
		КонецЕсли; 
		// заново формируем архив
		ВременныйКаталог = КаталогВременныхФайлов();
		ПутьКАрхиву = ВременныйКаталог + ИмяАрхива;
		ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(АдресВХранилище);
		ДвоичныеДанныеФайла.Записать(ПутьКАрхиву);
		МассивФайловДляУдаления.Добавить(ПутьКАрхиву);
		
		// если проблемы с архивом или архив пустой
		Если ПустаяСтрока(ИмяАрхива) ИЛИ ПустаяСтрока(ПутьКАрхиву) Тогда
			ВызватьИсключение "не удалось получить архив";
		КонецЕсли;
		
		ИмяПапкиДляСоздания = СтрЗаменить(ИмяАрхива,".ZIP","");
		ИмяПапкиДляСоздания = СтрЗаменить(ИмяПапкиДляСоздания,".zip","");
		
		// проверка возможности распаковки /////////////////////////////////
		ПутьРаспаковки = ВременныйКаталог + ИмяПапкиДляСоздания;
		Архив = РаспаковатьАрхив(ПутьКАрхиву, ПутьРаспаковки);
		Если Архив = Неопределено Тогда
			Возврат;
		КонецЕсли; 
		МассивФайловДляУдаления.Добавить(ПутьРаспаковки);
		////////////////////////////////////////////////////////////////////////
		
		// заполним дерево по архиву
		АрхивУИ = Новый УникальныйИдентификатор;
		ДобавитьУзелДерева(ИмяАрхива,
							"",
							АдресВХранилище,
							"ZIP",
							АрхивУИ,
							,
							Истина
						);
		
		Для каждого ЭлементАрхива Из Архив.Элементы Цикл
			ФайлУИ = Новый УникальныйИдентификатор;
			ДвоичныеДанныеФайла = Новый ДвоичныеДанные(ПутьРаспаковки + "\" + ЭлементАрхива.Имя);
			Файл_Адрес = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, ЭтотОбъект.УникальныйИдентификатор);
			ДобавитьУзелДерева(ЭлементАрхива.Имя,
								АрхивУИ,
								Файл_Адрес,
								ЭлементАрхива.Расширение,
								ФайлУИ,
								,
								Истина
							);
		
		КонецЦикла; 
		
	Исключение
		Сообщение_ = Новый СообщениеПользователю;
		Сообщение_.Текст = ОписаниеОшибки();
		Сообщение_.Сообщить();
	КонецПопытки;
	
	УдалитьФайлыПоМассивуПутей(МассивФайловДляУдаления);
	
КонецПроцедуры

&НаСервере
Функция УдалитьФайлОбмена_Сервер(СсылкаФайл, Прикреплен, Зарегистрирован, Входящий)
	
	Попытка
		НачатьТранзакцию();
		
		Если Зарегистрирован Тогда
			Ответ = ОтменаРегистрацииФайла_Сервер(СсылкаФайл, Входящий);
			Если Ответ = Ложь Тогда
				ОтменитьТранзакцию();
				Возврат Ложь;
			КонецЕсли; 
			ОпределитьКоличествоПакетовОбмена();
		КонецЕсли;
		
		Если Прикреплен Тогда
			ФайлОбъект = СсылкаФайл.ПолучитьОбъект();
			ФайлОбъект.УстановитьПометкуУдаления(Истина);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Сообщение_ = Новый СообщениеПользователю;
		Сообщение_.Текст = ОписаниеОшибки();
		Сообщение_.Сообщить();
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
КонецФункции


#КонецОбласти

