// Процедура - Подключаемый декорация формы представление нажатие
// 
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура Подключаемый_Кабинеты_Представление_Нажатие(Элемент)

	МассивПодстрок	= СтрРазделить(Элемент.Имя, "_", Ложь);
	ИДСтрокиДанных	= ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], Неопределено); 
	
	Если ИДСтрокиДанных = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаДанных = ЭтотОбъект.КабинетыСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
	
	Если СтрокаДанных <> Неопределено Тогда
		Если СтрокаДанных.Основное = Истина Тогда
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтрокаДанных.Помещение));
		Иначе
			СписокВариантов = Новый СписокЗначений;
			СписокВариантов.Добавить("Открыть", "Открыть");
			СписокВариантов.Добавить("НазначитьОсновным", "Назначить основным");
			
			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("ИДСтроки", ИДСтрокиДанных);
			ДопПараметры.Вставить("Помещение", СтрокаДанных.Помещение);
			ДопПараметры.Вставить("Сотрудник", СтрокаДанных.Сотрудник);
			ДопПараметры.Вставить("Основное", СтрокаДанных.Основное);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВариантаДействияСКабинетом", ЭтотОбъект, ДопПараметры);
			ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВариантов, Элемент);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор варианта действия с кассой.
// 
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ВыборВариантаДействияСКабинетом(ВыбранныйЭлемент, ДопПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбранныйЭлемент.Значение = "Открыть" Тогда
		
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ДопПараметры.Помещение));
		
	ИначеЕсли ВыбранныйЭлемент.Значение = "НазначитьОсновным" Тогда
		
		ОсновнойКабинетУстановлен = УстановитьСтатусОсновногоКабинета(ДопПараметры.Помещение, ДопПараметры.Сотрудник, Истина);
		
		Если ОсновнойКабинетУстановлен Тогда
			// Сброс по всем строкам
			Для Каждого СтрокаТ ИЗ ЭтотОбъект.КабинетыСуществующие Цикл
				
					ДПараметры = Новый Структура;
					ДПараметры.Вставить("Помещение", СтрокаТ.Помещение);
					ДПараметры.Вставить("Сотрудник", СтрокаТ.Сотрудник);
					ДПараметры.Вставить("Основное", СтрокаТ.Основное);
					
					СтрокаТ.Основное = УстановитьОсновнойКабинетВЛожь(ДПараметры);
					Элементы["КабинетыПредставление_" + СтрокаТ.ПолучитьИдентификатор()].Заголовок = СтрокаТ.Помещение;
					
			КонецЦикла;
			
			СтрокаДанных = ЭтотОбъект.КабинетыСуществующие.НайтиПоИдентификатору(ДопПараметры.ИДСтроки);
			
			Если УстановитьСтатусОсновногоКабинета(СтрокаДанных.Помещение, СтрокаДанных.Сотрудник, Истина) Тогда
				СтрокаДанных.Основное = Истина;			
				Элементы["КабинетыПредставление_" + ДопПараметры.ИДСтроки].Заголовок = "" + СтрокаДанных.Помещение + " (Основной)";
				ЭтаФорма.Модифицированность = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	МассивРодителей = Новый Массив();
	МассивРодителей.Добавить("ГруппаКабинетыСуществующие");
	УправлениеСвойствамиСтоматология.ОтображениеДополнительнойИнформации(МассивРодителей);
	
КонецПроцедуры 

&НаСервере
Функция УстановитьСтатусОсновногоКабинета(Помещение, Сотрудник, Основной = Истина)
	
	Попытка
		ЗаписьОсновногоКабинета = РегистрыСведений.СвязкаПомещениеСотрудник.СоздатьМенеджерЗаписи();
		ЗаписьОсновногоКабинета.Помещение = Помещение;
		ЗаписьОсновногоКабинета.Сотрудник = Сотрудник;
		ЗаписьОсновногоКабинета.Основное  = Основной;
		ЗаписьОсновногоКабинета.Записать();		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать кабинет. " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция УстановитьОсновнойКабинетВЛожь(ДПараметры)
	
	Попытка
		ЗаписьОсновногоКабинета = РегистрыСведений.СвязкаПомещениеСотрудник.СоздатьМенеджерЗаписи();
		ЗаписьОсновногоКабинета.Помещение = ДПараметры.Помещение;
		ЗаписьОсновногоКабинета.Сотрудник = ДПараметры.Сотрудник;
		ЗаписьОсновногоКабинета.Основное  = Ложь;
		ЗаписьОсновногоКабинета.Записать();		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		Возврат Истина;
		
	КонецПопытки;
	
	Возврат Ложь;
		
КонецФункции

