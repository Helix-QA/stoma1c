&НаКлиенте 
// Процедура - Статья расходов при изменении продолжение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СтатьяРасходовПриИзмененииПродолжение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ПерезаполнятьВсеТаблицы  = РезультатВопроса = КодВозвратаДиалога.Нет;
	
	ПоказатьВопрос(Новый ОписаниеОповещения("СтатьяРасходовПриИзмененииЗавершение", ЭтотОбъект, Новый Структура("ПерезаполнятьВсеТаблицы", ПерезаполнятьВсеТаблицы)), "Перезаполнять заполненные значения?",РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте   
// Процедура - Статья расходов при изменении завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СтатьяРасходовПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ПерезаполнятьВсеТаблицы = ДополнительныеПараметры.ПерезаполнятьВсеТаблицы;
	ПерезаполнятьЗаполненные = РезультатВопроса = КодВозвратаДиалога.Да;    
	
	Если Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаЗапасы.Видимость ИЛИ ПерезаполнятьВсеТаблицы Тогда
		Для Каждого СтрокаТ ИЗ Объект.Запасы Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатьяЗатрат) ИЛИ ПерезаполнятьЗаполненные = Истина Тогда
				СтрокаТ.СтатьяЗатрат = Объект.СтатьяЗатрат;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	Если Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаРасходы.Видимость ИЛИ ПерезаполнятьВсеТаблицы Тогда
		Для Каждого СтрокаТ ИЗ Объект.Расходы Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатьяЗатрат) ИЛИ ПерезаполнятьЗаполненные = Истина Тогда
				СтрокаТ.СтатьяЗатрат = Объект.СтатьяЗатрат;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	Если Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаОплаты.Видимость ИЛИ ПерезаполнятьВсеТаблицы Тогда
		Для Каждого СтрокаТ ИЗ Объект.Оплаты Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТ.СтатьяЗатрат) ИЛИ ПерезаполнятьЗаполненные = Истина Тогда
				СтрокаТ.СтатьяЗатрат = Объект.СтатьяЗатрат;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;

КонецПроцедуры

