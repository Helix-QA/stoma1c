// Функция, проверяет возможность использования sms рассылки.
// 
Функция ПроверитьВозможностьИспользованияSMSРассылки()
	
	СервисSMSРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	Если ЗначениеЗаполнено(СервисSMSРассылки) Тогда 
		Результат = Справочники.СервисыРассылки.ПолучитьБалансАккаунтаSMS(СервисSMSРассылки);
		Если Не Результат.Ошибка И Результат.Баланс > 0 Тогда
			Возврат Истина;
		Иначе
			ОписаниеОшибки = СервисSMSРассылки.Наименование + ". " + Результат.ОписаниеОшибки;
			Возврат Ложь;
		КонецЕсли;
	Иначе
		ОписаниеОшибки = НСтр("Не выбран сервис рассылки по умолчанию");
		Возврат Ложь;
	КонецЕсли;
	
