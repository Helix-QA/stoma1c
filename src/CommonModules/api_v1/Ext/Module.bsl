#КонецОбласти

// Функция, возвращает структуру с заголовками запроса в нижнем регистре.
//
Функция ПолучитьСоответствиеЗаголовков(Запрос)
	
	СоответствиеСЗаголовками = Новый Соответствие;
	
	Для Каждого Заголовок Из Запрос.Заголовки Цикл
		
		Если НРег(Заголовок.Ключ) = "connection" ИЛИ НРег(Заголовок.Ключ) = "host" ИЛИ НРег(Заголовок.Ключ) = "content-length" Тогда
			Продолжить;
		КонецЕсли;
		
		СоответствиеСЗаголовками.Вставить(НРег(Заголовок.Ключ), Заголовок.Значение);
		
	КонецЦикла;
	
	Возврат СоответствиеСЗаголовками;
	
КонецФункции

// Функция, возвращает ссылку по УИД.
//
Функция ПолучитьСсылкуОбъектаПоУИД(УИД, ВидОбъекта, ИмяОбъекта)
	
	Попытка
		Выполнить("ВидОбъекта = " + ВидОбъекта);
		Ссылка = ВидОбъекта[ИмяОбъекта].ПолучитьСсылку(Новый УникальныйИдентификатор(УИД));
		Если Ссылка.ПолучитьОбъект() = Неопределено Тогда
			Ссылка = Неопределено;
		КонецЕсли;
	Исключение
		Ссылка = Неопределено;
	КонецПопытки;
	
	Возврат Ссылка;
	
КонецФункции

// Функция, возвращает HTTPОтвет. 
//
Функция ПолучитьHTTPОтвет(Ответ1с, КодОтвета = Неопределено)
	
	КодОтвета = ?(КодОтвета = Неопределено, 200, КодОтвета);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, Ответ1С);
	мОтвет = ЗаписьJSON.Закрыть();
	HTTPОтвет = Новый HTTPСервисОтвет(КодОтвета);
	HTTPОтвет.УстановитьТелоИзСтроки(мОтвет);
	HTTPОтвет.Заголовки["Content-Type"] = "application/json";
	
	Возврат HTTPОтвет;
	
КонецФункции

// Функция, возвращает структуру возврата ошибки. 
//
Функция ПолучитьСтруктуруВозвратаОшибки(КодОшибки = Неопределено, ОписаниеОшибки = "", ВернутьПустуюСтруктуру = Ложь)
	
	Если ВернутьПустуюСтруктуру Тогда
		Возврат Новый Структура("code, message", 0, "");
	КонецЕсли;
	
	СтруктураОшибки = Новый Структура("code, message", КодОшибки, ПолучитьОписаниеОшибки(КодОшибки, ОписаниеОшибки));
	Возврат Новый Структура("Parameters, Errors",, СтруктураОшибки);
	
КонецФункции

// Функция, возвращает описание ошибки по коду.
//
Функция ПолучитьОписаниеОшибки(КодОшибки, ДополнительноеОписание = "") Экспорт
	
