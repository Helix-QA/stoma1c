	ПараметрыЧека.Касса                   = ЭтотОбъект.Касса;  
	ПараметрыЧека.Количество              = 1;  
	ПараметрыЧека.СуммаКОплате            = ПараметрыОплаты.СуммаВзноса;
	ПараметрыЧека.СуммаОплачено           = ПараметрыОплаты.СуммаВзноса;
	ПараметрыЧека.ТипЧека                 = 0;
	ПараметрыЧека.ВидНалога               = ВидНалога;
