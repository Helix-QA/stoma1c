Исключение
	
	ИнформацияОбОшибке = ИнформацияОбОшибке(); 
	Комментарий = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
	ЗаписьЖурналаРегистрации(
	НСтр("ru = 'Создание пациента в ИЭМК.'",
	ОбщегоНазначения.КодОсновногоЯзыка()),
	УровеньЖурналаРегистрации.Ошибка,,,
	Комментарий);
	
	РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(КонтрАгентДляОтправки, "404", Комментарий, "",Строка(КонтрАгентДляОтправки.УникальныйИдентификатор()),КоличествоПопытокПодключения, ТекущаяДатаСеанса());
КонецПопытки;

КонецПроцедуры

// Функция возвращает признак находится ли данный пациент в системе ИЭМК.
//
Функция ПроверитьПациентаИЭМК(КонтрАгентДляОтправки, guid, idLPU, Демо) Экспорт

	ПутьКФайлу = ПолучитьИмяВременногоФайла("xml");
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();

	Запись.ЗаписатьНачалоЭлемента("tem:GetPatient");
	
	    Запись.ЗаписатьНачалоЭлемента("tem:guid");
		Запись.ЗаписатьТекст(guid);
		Запись.ЗаписатьКонецЭлемента();
	
		Запись.ЗаписатьНачалоЭлемента("tem:idLPU");
		Запись.ЗаписатьТекст(idLPU);
		Запись.ЗаписатьКонецЭлемента();
	
		Запись.ЗаписатьНачалоЭлемента("tem:patient");
		
			Запись.ЗаписатьНачалоЭлемента("emk:IdPatientMIS");
			Запись.ЗаписатьТекст(Строка(КонтрАгентДляОтправки.УникальныйИдентификатор()));
			Запись.ЗаписатьКонецЭлемента();

	    Запись.ЗаписатьКонецЭлемента();
	
	Запись.ЗаписатьКонецЭлемента();
	
	СтрокаXML = Запись.Закрыть(); 
		
	СтрокаSOAP = "<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:tem=""http://tempuri.org/"" xmlns:ser=""http://schemas.microsoft.com/2003/10/Serialization/"" xmlns:emk=""http://schemas.datacontract.org/2004/07/EMKService.Data.Dto"">
	| <soapenv:Header/>
	| <soapenv:Body>
	|"
	+СтрокаXML+
	"
	| </soapenv:Body>
	|</soapenv:Envelope>";

// Описываем заголовки HTTP-запроса

Заголовки = Новый Соответствие;

Заголовки.Вставить("Content-Type", "text/xml;charset=UTF-8");
Заголовки.Вставить("SOAPAction", "http://tempuri.org/IPixService/GetPatient");

Если Демо Тогда
	АдресСтенда = "b2b-demo.n3health.ru";
Иначе
	АдресСтенда = "b2b.n3health.ru";
КонецЕсли;

Соединение = Новый HTTPСоединение(АдресСтенда,,,,,5,Новый ЗащищенноеСоединениеOpenSSL()); 
// Получаем текст корневой страницы через POST-запрос.

HTTPЗапрос = Новый HTTPЗапрос("/emk/PixService.svc", Заголовки);
HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаSOAP);

Попытка
	Результат = Соединение.ВызватьHTTPМетод("POST", HTTPЗапрос);	
	
	Ответ = Результат.ПолучитьТелоКакСтроку();	

	ЧтениеXML = Новый ЧтениеXML;	
	
	// Загрузить XML из строки
	ЧтениеXML.УстановитьСтроку(Ответ);	

	УИДПациентаВИЭМК = "";

	// Перебор узлов	
	Пока ЧтениеXML.Прочитать() Цикл
	
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			Если ЧтениеXML.ЛокальноеИмя = "IdGlobal" Тогда
				ЧтениеXML.Прочитать();
				УИДПациентаВИЭМК = ЧтениеXML.Значение;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла;

	ЧтениеXML.Закрыть(); 
	
Исключение
	
	ИнформацияОбОшибке = ИнформацияОбОшибке(); 
	Комментарий = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
	ЗаписьЖурналаРегистрации(
	НСтр("ru = 'Проврка пациента в ИЭМК.'",
	ОбщегоНазначения.КодОсновногоЯзыка()),
	УровеньЖурналаРегистрации.Ошибка,,,
	Комментарий);
	
	Возврат "Ошибка:" + ИнформацияОбОшибке;

КонецПопытки;

Возврат УИДПациентаВИЭМК;

КонецФункции

// Процедура производит запись приема в ИЭМК.
//
Процедура СоздатьПриемВИЭМК(ПриемДляОтправки, guid, idLPU, КоличествоПопыток, УидВИЭМК, Демо) Экспорт
	
	УИДПациентаВИЭМК = ПроверитьПациентаИЭМК(ПриемДляОтправки.Контрагент, guid, idLPU, Демо);
	
	Если Лев(УИДПациентаВИЭМК, 6) = "Ошибка" Тогда
		РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ПриемДляОтправки.Контрагент, "404", УИДПациентаВИЭМК, "",Строка(ПриемДляОтправки.Контрагент.УникальныйИдентификатор()),, ТекущаяДатаСеанса());
		Возврат	
	КонецЕсли;

	УидВИЭМКПривема = УидВИЭМК;
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		ЧасовойПоясОД = Константы.ЧасовойПоясОбластиДанных.Получить();
		ЧасовойПоясБазы = "+" + Формат(СмещениеСтандартногоВремени(ЧасовойПоясОД)/60/60, "ЧЦ=2; ЧВН=; ЧГ=")+":00";
	Иначе
		ЧасовойПоясБазы = "+" + Формат(СмещениеСтандартногоВремени(ЧасовойПояс())/60/60, "ЧЦ=2; ЧВН=; ЧГ=")+":00";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УИДПациентаВИЭМК) Тогда
		СоздатьПациентаВИЭМК(ПриемДляОтправки.Контрагент, guid, idLPU,, "", Демо);
		УИДПациентаВИЭМК = ПроверитьПациентаИЭМК(ПриемДляОтправки.Контрагент, guid, idLPU, Демо);
	ИначеЕсли Не ЗначениеЗаполнено(УидВИЭМКПривема) Тогда
		УИДПриема = Строка(ПриемДляОтправки.УникальныйИдентификатор());
		УидВИЭМКПривема = ПроверитьПриемИЭМК(УИДПациентаВИЭМК, УИДПриема, guid, idLPU, Демо);
	КонецЕсли;
	
	КоличествоПопытокПодключения = КоличествоПопыток + 1;
	Если Лев(УидВИЭМКПривема, 6) = "Ошибка" Тогда
		РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ПриемДляОтправки, "404", УидВИЭМКПривема,,Строка(ПриемДляОтправки.УникальныйИдентификатор()), КоличествоПопытокПодключения, ТекущаяДатаСеанса());
		Возврат	
	КонецЕсли;
	
	ПациентИмеетСнНИЛС = Ложь;
	ДокументФизЛицаСуществует = Ложь;
	ДокументФизЛицо = РегистрыСведений.ДокументыФизическихЛиц.ДокументыУдостоверяющиеЛичностьФизлица(ПриемДляОтправки.Контрагент, ТекущаяДатаСеанса(),, Истина);
	Если ДокументФизЛицо.Количество() > 0 Тогда
		Для Каждого Элемент Из ДокументФизЛицо Цикл
			Если ЗначениеЗаполнено(Элемент.Номер) И Элемент.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.СНИЛС Тогда
				ПациентИмеетСнНИЛС = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	ОбследованиеПациента = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ПриемДляОтправки.Контрагент, ПриемДляОтправки);
	Если Не ЗначениеЗаполнено(ОбследованиеПациента) Или ОбследованиеПациента.Найти("Диагноз").Количество() = 0 Тогда	
		РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ПриемДляОтправки.Контрагент, "404", "Не заполнен диагноз!", "",Строка(ПриемДляОтправки.Контрагент.УникальныйИдентификатор()),КоличествоПопытокПодключения, ТекущаяДатаСеанса());
		Возврат;
	КонецЕсли;
	
	Если Не Демо Тогда
		ПодписьОрганизации = Подпись(ПриемДляОтправки.Организация);
	    ПодписьСотрудника  = Подпись(ПриемДляОтправки.Организация, ПриемДляОтправки.Сотрудник);
	КонецЕсли;
	
	ЗначениеПараметровОбследования = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ПриемДляОтправки.Контрагент, ПриемДляОтправки);
	ПараметрыОбследованияСтрокой = "";
	Для Каждого ЭлементПараметра Из  ЗначениеПараметровОбследования Цикл
		ПараметрыОбследованияСтрокой = ПараметрыОбследованияСтрокой + ЭлементПараметра.РеквизитИмя + ": " + ЭлементПараметра.РеквизитЗначение + Символы.ПС;
	КонецЦикла;
	ПараметрыОбследованияСтрокой = Лев(ПараметрыОбследованияСтрокой, СтрДлина(ПараметрыОбследованияСтрокой) - 1);
	
	Для Каждого Элемент Из ПриемДляОтправки.Сотрудник.СпецилазацииСотрудника Цикл
		Если Элемент.Основная Тогда
			Специальность = Элемент.Специализация.СпециализацияПоКлассификаторуИЭМК.КодОИД;	
		КонецЕсли;	
	КонецЦикла;
	
	ДокументФизЛицо = РегистрыСведений.ДокументыФизическихЛиц.ДокументыУдостоверяющиеЛичностьФизлица(ПриемДляОтправки.Сотрудник, ТекущаяДатаСеанса(),, Истина);
	
	ДокументФизЛицаСуществует = Ложь;
	Если ДокументФизЛицо.Количество() > 0 Тогда
		Для Каждого Элемент Из ДокументФизЛицо Цикл
			Если ЗначениеЗаполнено(Элемент.Номер) И Элемент.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.СНИЛС Тогда
				ДокументФизЛицаСуществует = Истина; 
				Прервать;
			КонецЕсли;
		КонецЦикла; 
	КонецЕсли;
	
	Если Не ДокументФизЛицаСуществует Тогда
		РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ПриемДляОтправки, "404", УИДПациентаВИЭМК, "",Строка(ПриемДляОтправки.Контрагент.УникальныйИдентификатор()),, ТекущаяДатаСеанса());
		Возврат;                           
	КонецЕсли;
		
	ПутьКФайлу = ПолучитьИмяВременногоФайла("xml");
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	
	Если УидВИЭМК = "" Тогда
		Запись.ЗаписатьНачалоЭлемента("AddCase");
		Запись.ЗаписатьАтрибут("xmlns", "http://tempuri.org/");
		// Запись.ЗаписатьСоответствиеПространстваИмен("xmlns", "http://tempuri.org/");
	Иначе
		Запись.ЗаписатьНачалоЭлемента("UpdateCase");
		Запись.ЗаписатьАтрибут("xmlns", "http://tempuri.org/");
	КонецЕсли;
	
			Запись.ЗаписатьНачалоЭлемента("guid");
			Запись.ЗаписатьТекст(guid);
			Запись.ЗаписатьКонецЭлемента();
	
			Запись.ЗаписатьНачалоЭлемента("caseDto");
			Запись.ЗаписатьСоответствиеПространстваИмен("d4p1", "http://schemas.datacontract.org/2004/07/N3.EMK.Dto.Case");
			Запись.ЗаписатьСоответствиеПространстваИмен("i", "http://www.w3.org/2001/XMLSchema-instance");
			Запись.ЗаписатьАтрибут("i:type", "d4p1:CaseAmb");
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:OpenDate");
				Запись.ЗаписатьТекст(Формат(ПриемДляОтправки.ВремяНачалаПриема, "ДФ=гггг-ММ-ддTЧЧ:мм:сс") + ЧасовойПоясБазы);
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:CloseDate");
				Запись.ЗаписатьТекст(Формат(ПриемДляОтправки.ВремяОкончанияПриема, "ДФ=гггг-ММ-ддTЧЧ:мм:сс") + ЧасовойПоясБазы);
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:HistoryNumber");
				Запись.ЗаписатьТекст(Строка(ПриемДляОтправки.Номер));
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:IdCaseMis");
				Запись.ЗаписатьТекст(Строка(ПриемДляОтправки.УникальныйИдентификатор()));
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:IdCaseAidType");
				Запись.ЗаписатьТекст("6");
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:IdPaymentType");
				Если ЗначениеЗаполнено(ПриемДляОтправки.ПолисМедСтрахования) Тогда
					Если ПриемДляОтправки.ПолисМедСтрахования.ТипПолиса = Перечисления.ТипыПолиса.ОбязательноеМедицинскоеСтрахование Тогда
				Запись.ЗаписатьТекст("1");
					Иначе
				Запись.ЗаписатьТекст("4");
					КонецЕсли;
				Иначе
				Запись.ЗаписатьТекст("5");
				КонецЕсли;
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:Confidentiality");
				Запись.ЗаписатьТекст("1");
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:DoctorConfidentiality");
				Запись.ЗаписатьТекст("1");
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:CuratorConfidentiality");
				Запись.ЗаписатьТекст("1");
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:IdLpu");
				Запись.ЗаписатьТекст(idLPU);
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:IdCaseResult");
				Если ПриемДляОтправки.РезультатПриема = 1 Тогда
				Запись.ЗаписатьТекст("5");
				Иначе
				Запись.ЗаписатьТекст("2");
				КонецЕсли;
				Запись.ЗаписатьКонецЭлемента();
	
				Запись.ЗаписатьНачалоЭлемента("d4p1:Comment");
				Запись.ЗаписатьТекст(Лев(ПараметрыОбследованияСтрокой, 999));
				Запись.ЗаписатьКонецЭлемента();    
				
				///////////////////////////////////////////////// Информация о враче /////////////////////////////////////////////////////
				Запись.ЗаписатьНачалоЭлемента("d4p1:DoctorInCharge");
				Запись.ЗаписатьСоответствиеПространстваИмен("d5p1", "http://schemas.datacontract.org/2004/07/N3.EMK.Dto");
	
					Запись.ЗаписатьНачалоЭлемента("d5p1:Person");
	
						Запись.ЗаписатьНачалоЭлемента("d5p1:HumanName");
	
							Запись.ЗаписатьНачалоЭлемента("d5p1:GivenName");
							Запись.ЗаписатьТекст(СокрЛП(ПриемДляОтправки.Сотрудник.Имя));
							Запись.ЗаписатьКонецЭлемента();
	
							Если ЗначениеЗаполнено(ПриемДляОтправки.Сотрудник.Отчество) Тогда
							Запись.ЗаписатьНачалоЭлемента("d5p1:MiddleName");
							Запись.ЗаписатьТекст(СокрЛП(ПриемДляОтправки.Сотрудник.Отчество));
							Запись.ЗаписатьКонецЭлемента();
							КонецЕсли;
	
							Запись.ЗаписатьНачалоЭлемента("d5p1:FamilyName");
							Запись.ЗаписатьТекст(СокрЛП(ПриемДляОтправки.Сотрудник.Фамилия));
							Запись.ЗаписатьКонецЭлемента();
	
						Запись.ЗаписатьКонецЭлемента();
	
						Если ЗначениеЗаполнено(ПриемДляОтправки.Сотрудник.ДатаРождения) Тогда
						Запись.ЗаписатьНачалоЭлемента("d5p1:Birthdate");
						Запись.ЗаписатьТекст(Формат(ПриемДляОтправки.Сотрудник.ДатаРождения, "ДФ=гггг-ММ-ддTЧЧ:мм:сс") + ЧасовойПоясБазы);
						Запись.ЗаписатьКонецЭлемента();
						КонецЕсли;
	
						Запись.ЗаписатьНачалоЭлемента("d5p1:IdPersonMis");
						Запись.ЗаписатьТекст(Строка(ПриемДляОтправки.Сотрудник.УникальныйИдентификатор()));
						Запись.ЗаписатьКонецЭлемента();
	
						// Документы врача
	
						Если ДокументФизЛицаСуществует Тогда
		        	
						Запись.ЗаписатьНачалоЭлемента("d5p1:Documents");
							Если ДокументФизЛицо.Количество() > 0 Тогда
								Для Каждого ЭлМассива Из ДокументФизЛицо Цикл
									Если ЗначениеЗаполнено(ЭлМассива.Номер) И ЭлМассива.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.СНИЛС Тогда
							Запись.ЗаписатьНачалоЭлемента("d5p1:IdentityDocument");
							
								Запись.ЗаписатьНачалоЭлемента("d5p1:DocN");
								Запись.ЗаписатьТекст(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(ЭлМассива.Номер)));
								Запись.ЗаписатьКонецЭлемента();
						
								Запись.ЗаписатьНачалоЭлемента("d5p1:IdDocumentType");
								Запись.ЗаписатьТекст("223");
								Запись.ЗаписатьКонецЭлемента();
						
