#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область СлужебныеПроцедурыИФункции
	
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АвансовыйОтчетПотраченно.Ссылка КАК Ссылка,
	|	ЗНАЧЕНИЕ(Документ.СписаниеДенежныхСредств.ПустаяСсылка) КАК ДокументОснования,
	|	АвансовыйОтчетПотраченно.Ссылка.Сотрудник КАК Сотрудник,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	АвансовыйОтчетПотраченно.Ссылка.Дата КАК Период,
	|	АвансовыйОтчетПотраченно.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	АвансовыйОтчетПотраченно.Сумма КАК Стоимость
	|ПОМЕСТИТЬ ТаблицаРасчетыСПодотчетниками
	|ИЗ
	|	(ВЫБРАТЬ
	|		АвансовыйОтчетЗапасы.Ссылка КАК Ссылка,
	|		АвансовыйОтчетЗапасы.Сумма КАК Сумма
	|	ИЗ
	|		Документ.АвансовыйОтчет.Запасы КАК АвансовыйОтчетЗапасы
	|	ГДЕ
	|		АвансовыйОтчетЗапасы.Ссылка = &Ссылка
	|		И АвансовыйОтчетЗапасы.Сумма > 0
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		АвансовыйОтчетРасходы.Ссылка,
	|		АвансовыйОтчетРасходы.Сумма
	|	ИЗ
	|		Документ.АвансовыйОтчет.Расходы КАК АвансовыйОтчетРасходы
	|	ГДЕ
	|		АвансовыйОтчетРасходы.Ссылка = &Ссылка
	|		И АвансовыйОтчетРасходы.Сумма > 0
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		АвансовыйОтчетОплаты.Ссылка,
	|		АвансовыйОтчетОплаты.Сумма
	|	ИЗ
	|		Документ.АвансовыйОтчет.Оплаты КАК АвансовыйОтчетОплаты
	|	ГДЕ
	|		АвансовыйОтчетОплаты.Ссылка = &Ссылка
	|		И АвансовыйОтчетОплаты.Сумма > 0) КАК АвансовыйОтчетПотраченно
	|ГДЕ
	|	АвансовыйОтчетПотраченно.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АвансовыйОтчет.Ссылка КАК Документ,
	|	АвансовыйОтчет.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА АвансовыйОтчет.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	|			ТОГДА АвансовыйОтчет.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ АвансовыйОтчет.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	АвансовыйОтчет.Контрагент КАК Контрагент,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	АвансовыйОтчет.Ссылка.Дата КАК Период,
	|	АвансовыйОтчет.Сумма КАК Сумма,
	|	АвансовыйОтчет.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыСКонтрагентами
	|ИЗ
	|	Документ.АвансовыйОтчет.Оплаты КАК АвансовыйОтчет
	|ГДЕ
	|	АвансовыйОтчет.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АвансовыйОтчетЗапасы.НомерСтроки КАК НомерСтроки,
	|	АвансовыйОтчетЗапасы.Ссылка КАК Документ,
	|	АвансовыйОтчетЗапасы.Склад КАК Склад,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	АвансовыйОтчетЗапасы.Ссылка.Дата КАК Период,
	|	АвансовыйОтчетЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	АвансовыйОтчетЗапасы.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА АвансовыйОтчетЗапасы.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	АвансовыйОтчетЗапасы.Количество КАК Количество,
	|	АвансовыйОтчетЗапасы.Сумма КАК Сумма,
	|	АвансовыйОтчетЗапасы.Цена КАК Цена,
	|	АвансовыйОтчетЗапасы.Упаковка КАК Упаковка
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасы
	|ИЗ
	|	Документ.АвансовыйОтчет.Запасы КАК АвансовыйОтчетЗапасы
	|ГДЕ
	|	АвансовыйОтчетЗапасы.Ссылка = &Ссылка
	|	И НЕ АвансовыйОтчетЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(АвансовыйОтчетЗапасы.НомерСтроки) КАК НомерСтроки,
	|	АвансовыйОтчетЗапасы.Ссылка.Дата КАК Период,
	|	АвансовыйОтчетЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы) КАК СчетДт,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Подотчет) КАК СчетКт,
	|	АвансовыйОтчетЗапасы.Номенклатура КАК СубконтоДт1,
	|	АвансовыйОтчетЗапасы.Склад КАК СубконтоДт2,
	|	NULL КАК СубконтоДт3,
	|	NULL КАК СубконтоДт4,
	|	АвансовыйОтчетЗапасы.Ссылка.Сотрудник КАК СубконтоКт1,
	|	СУММА(АвансовыйОтчетЗапасы.Сумма) КАК Сумма,
	|	АвансовыйОтчетЗапасы.Количество КАК Количество,
	|	""Авансовый отчет"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.АвансовыйОтчет.Запасы КАК АвансовыйОтчетЗапасы
	|ГДЕ
	|	АвансовыйОтчетЗапасы.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансовыйОтчетЗапасы.Ссылка.Дата,
	|	АвансовыйОтчетЗапасы.Ссылка.СтруктурнаяЕдиница,
	|	АвансовыйОтчетЗапасы.Номенклатура,
	|	АвансовыйОтчетЗапасы.Ссылка.Сотрудник,
	|	АвансовыйОтчетЗапасы.Склад,
	|	АвансовыйОтчетЗапасы.Количество
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СУММА(АвансовыйОтчетРасходы.НомерСтроки),
	|	АвансовыйОтчетРасходы.Ссылка.Дата,
	|	АвансовыйОтчетРасходы.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыПрочие),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Подотчет),
	|	АвансовыйОтчетРасходы.СтатьяЗатрат,
	|	АвансовыйОтчетРасходы.Специализация,
	|	NULL,
	|	NULL,
	|	АвансовыйОтчетРасходы.Ссылка.Сотрудник,
	|	СУММА(АвансовыйОтчетРасходы.Сумма),
	|	NULL,
	|	""Авансовый отчет""
	|ИЗ
	|	Документ.АвансовыйОтчет.Расходы КАК АвансовыйОтчетРасходы
	|ГДЕ
	|	АвансовыйОтчетРасходы.Ссылка = &Ссылка
	|	И АвансовыйОтчетРасходы.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансовыйОтчетРасходы.Ссылка.Дата,
	|	АвансовыйОтчетРасходы.Ссылка.СтруктурнаяЕдиница,
	|	АвансовыйОтчетРасходы.Ссылка.Сотрудник,
	|	АвансовыйОтчетРасходы.Специализация,
	|	АвансовыйОтчетРасходы.СтатьяЗатрат
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СУММА(АвансовыйОтчетРасходы.НомерСтроки),
	|	АвансовыйОтчетРасходы.Ссылка.Дата,
	|	АвансовыйОтчетРасходы.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыСебестоимость),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Подотчет),
	|	АвансовыйОтчетРасходы.Специализация,
	|	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка),
	|	АвансовыйОтчетРасходы.Ссылка.Сотрудник,
	|	АвансовыйОтчетРасходы.СтатьяЗатрат,
	|	АвансовыйОтчетРасходы.Сотрудник,
	|	СУММА(АвансовыйОтчетРасходы.Сумма),
	|	NULL,
	|	""Авансовый отчет""
	|ИЗ
	|	Документ.АвансовыйОтчет.Расходы КАК АвансовыйОтчетРасходы
	|ГДЕ
	|	АвансовыйОтчетРасходы.Ссылка = &Ссылка
	|	И АвансовыйОтчетРасходы.Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансовыйОтчетРасходы.Ссылка.Дата,
	|	АвансовыйОтчетРасходы.Ссылка.СтруктурнаяЕдиница,
	|	АвансовыйОтчетРасходы.Ссылка.Сотрудник,
	|	АвансовыйОтчетРасходы.Специализация,
	|	АвансовыйОтчетРасходы.СтатьяЗатрат,
	|	АвансовыйОтчетРасходы.Сотрудник
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СУММА(АвансовыйОтчетОплаты.НомерСтроки),
	|	АвансовыйОтчетОплаты.Ссылка.Дата,
	|	АвансовыйОтчетОплаты.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Подотчет),
	|	АвансовыйОтчетОплаты.Контрагент,
	|	NULL,
	|	NULL,
	|	NULL,
	|	АвансовыйОтчетОплаты.Ссылка.Сотрудник,
	|	СУММА(АвансовыйОтчетОплаты.Сумма),
	|	NULL,
	|	""Авансовый отчет""
	|ИЗ
	|	Документ.АвансовыйОтчет.Оплаты КАК АвансовыйОтчетОплаты
	|ГДЕ
	|	АвансовыйОтчетОплаты.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансовыйОтчетОплаты.Ссылка.Дата,
	|	АвансовыйОтчетОплаты.Ссылка.СтруктурнаяЕдиница,
	|	АвансовыйОтчетОплаты.Контрагент,
	|	АвансовыйОтчетОплаты.Ссылка.Сотрудник";
		
	Запрос.УстановитьПараметр("Ссылка"            , ДокументСсылкаОприходованиеЗапасов);
	Запрос.УстановитьПараметр("ИспользоватьПартии", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьПартии);
	
	Запрос.ВыполнитьПакет();
	
	СформироватьТаблицаРасчетыСПодотчетниками(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства);
	СформироватьТаблицаВзаиморасчетыСКонтрагентами(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства);
	СформироватьТаблицаЗапасыНаСкладах(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства);
	СформироватьТаблицаПартииТоваров(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства);
	СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства);
	СформироватьТаблицаУстановкаЦен(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства);	
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыСПодотчетниками(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства)
	
    Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РасчетыСПодотчетниками.Ссылка,	
	|	РасчетыСПодотчетниками.ДокументОснования,
	|	РасчетыСПодотчетниками.Период,
	|	РасчетыСПодотчетниками.СтруктурнаяЕдиница,
	|	РасчетыСПодотчетниками.Сотрудник,
	|	РасчетыСПодотчетниками.ВидДвижения,
	|	СУММА(РасчетыСПодотчетниками.Стоимость) КАК Сумма
	|ИЗ
	|	ТаблицаРасчетыСПодотчетниками КАК РасчетыСПодотчетниками
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСПодотчетниками.Ссылка,	
	|	РасчетыСПодотчетниками.ДокументОснования,	
	|	РасчетыСПодотчетниками.Период,
	|	РасчетыСПодотчетниками.СтруктурнаяЕдиница,
	|	РасчетыСПодотчетниками.Сотрудник,
	|	РасчетыСПодотчетниками.ВидДвижения";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() > 0 Тогда		
		Авансы = ВернутьВыданныеАвансыПоДокументу(РезультатЗапроса[0].Ссылка);
		Если Авансы.Количество() > 0 Тогда 
			Если Авансы.Количество() = 1 Тогда 
				РезультатЗапроса[0].ДокументОснования = Авансы[0].Документ;
			Иначе
				// подготовим таблицу
				ТаблицаДляДвижений = РезультатЗапроса.Скопировать();
				ТаблицаДляДвижений.Очистить();
				ПотраченнаяСумма = РезультатЗапроса[0].Сумма;
				Для Каждого СтрокаАвансы Из Авансы Цикл
					Если ПотраченнаяСумма > 0 Тогда 
						Если СтрокаАвансы.Сумма < ПотраченнаяСумма ИЛИ СтрокаАвансы.Сумма = ПотраченнаяСумма Тогда 
							НоваяСтрока = ТаблицаДляДвижений.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, РезультатЗапроса[0]);
							НоваяСтрока.Сумма 				= СтрокаАвансы.Сумма;
							НоваяСтрока.ДокументОснования 	= СтрокаАвансы.Документ;
							ПотраченнаяСумма = ПотраченнаяСумма - СтрокаАвансы.Сумма;
						Иначе 
							НоваяСтрока = ТаблицаДляДвижений.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, РезультатЗапроса[0]);
							НоваяСтрока.Сумма 				= ПотраченнаяСумма;
							НоваяСтрока.ДокументОснования 	= СтрокаАвансы.Документ;
							ПотраченнаяСумма = ПотраченнаяСумма - НоваяСтрока.Сумма;							
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				РезультатЗапроса = ТаблицаДляДвижений;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	РезультатЗапроса.Колонки.Удалить("Ссылка");
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПодотчетниками", РезультатЗапроса);	
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗапасыНаСкладах(ДокументСсылкаОприходованиеЗапасов, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
