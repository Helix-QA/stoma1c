// Процедура, создает элементы виджета, всплывающую группу.
//
Процедура СоздатьГруппуОткрытьСделку(Форма, Сделка, ГруппаРодитель, ИндексВиджета)
	
	ГруппаВсплывающая = Форма.Элементы.Добавить("ГруппаВсплывающаяСделка_" + ИндексВиджета, Тип("ГруппаФормы"), ГруппаРодитель);
	ГруппаВсплывающая.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВсплывающая.Поведение			  = ПоведениеОбычнойГруппы.Всплывающая;
	ГруппаВсплывающая.Заголовок			  = " ";	
	ГруппаВсплывающая.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаВсплывающая.Отображение         = ОтображениеОбычнойГруппы.Нет;
	ГруппаВсплывающая.ШрифтЗаголовка	  = Новый Шрифт(,1);
	ГруппаВсплывающая.ВертикальноеПоложениеВГруппе 		 = ВертикальноеПоложениеЭлемента.Низ;
	ГруппаВсплывающая.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Лево;
	ГруппаВсплывающая.ВертикальныйИнтервал				 = ИнтервалМеждуЭлементамиФормы.Половинный;	
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"  		 , "ГруппаОткрытьСделкуГоризонталь_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("Группировка"  		 , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("ВертикальныйИнтервал"  , ИнтервалМеждуЭлементамиФормы.Нет);
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		 , ГруппаВсплывающая);
	ГруппаОткрытьСделкуВертикаль = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);	
	
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда 
		// Создаем команду кнопки.
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "Подключаемый_ОткрытьСделку");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ОткрытьСделку_" + ИндексВиджета);
		КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
		
		// Создаем кнопку.
		ПараметрыКнопки = Новый Структура;
		ПараметрыКнопки.Вставить("Заголовок"   	 	 , НСтр("ru = 'Открыть сделку'; en = 'Open a deal'"));
		ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "ОткрытьСделку_" + ИндексВиджета);
		ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
		ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
		ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
		ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаОткрытьСделкуВертикаль);
		КнопкаСделки = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
		
		// Создаем всплывающую группу.
		ГруппаВсплывающаяВидСделки = Форма.Элементы.Добавить("ГруппаВсплывающаяВидСделки_" + ИндексВиджета, Тип("ГруппаФормы"), ГруппаРодитель);
		ГруппаВсплывающаяВидСделки.Вид            = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаВсплывающаяВидСделки.Поведение	  = ПоведениеОбычнойГруппы.Всплывающая;
		ГруппаВсплывающаяВидСделки.Заголовок	  = " ";	
		ГруппаВсплывающаяВидСделки.Группировка    = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаВсплывающаяВидСделки.Отображение    = ОтображениеОбычнойГруппы.Нет;
		ГруппаВсплывающаяВидСделки.ШрифтЗаголовка = Новый Шрифт(,1);
		ГруппаВсплывающаяВидСделки.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
		ГруппаВсплывающаяВидСделки.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Лево;
		ГруппаВсплывающаяВидСделки.ВертикальныйИнтервал =  ИнтервалМеждуЭлементамиФормы.Половинный;
		
		ВидыСделок = Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Сделка.ВидСделки.ТипСделки);
		
		ИндексВида = 0;
		Для Каждого ВидСделки Из ВидыСделок Цикл
			
			// Создаем команду кнопки.
			ПараметрыКоманды = Новый Структура;
			ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "Подключаемый_СменитьВидСделки");
			ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "СменитьВидСделки_" + ИндексВида + "_" + ИндексВиджета);
			КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
			
			// Создаем кнопку.
			ПараметрыКнопки = Новый Структура;
			ПараметрыКнопки.Вставить("Заголовок"   	 	 , ВидСделки.Наименование);
			ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "СменитьВидСделки_" + ИндексВида + "_" + ИндексВиджета);
			ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
			ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
			ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
			ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВсплывающаяВидСделки);	
			КнопкаСделки = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
			
			ИндексВида = ИндексВида + 1;
			
		КонецЦикла;
		
		// Создание декорации.
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"   , "ДекорацияИнтервалСумма_" + ИндексВиджета);
		ПараметрыДекорации.Вставить("ГруппаЭлемента", ГруппаОткрытьСделкуВертикаль);
		ПараметрыДекорации.Вставить("РазмерШрифта"  , 3);			
		ДекорацияИнтервал = СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
		
		// Создаем команду кнопки.
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "Подключаемый_СменитьСделку");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "СменитьСделку_" + ИндексВиджета);
		КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
		
		// Создаем кнопку.
		ПараметрыКнопки = Новый Структура;
		ПараметрыКнопки.Вставить("Заголовок"   	 	 , НСтр("ru = 'Сменить сделку'; en = 'Change deal'"));
		ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "СменитьСделку_" + ИндексВиджета);
		ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
		ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
		ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
		ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаОткрытьСделкуВертикаль);
		
		КнопкаСделки = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
		
		// Создаем элементы суммы сделки.
		СоздатьЭлементыСуммыСделки(Форма, ИндексВиджета, Сделка, ГруппаВсплывающая);
	КонецЕсли;

КонецПроцедуры

// Процедура, создает элементы виджета, элементы суммы сделки. 
Процедура СоздатьЭлементыСуммыСделки(Форма, ИндексВиджета, Сделка, ГруппаРодитель)
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"  		 , "ГруппаИзменитьСуммуГоризонталь_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("Группировка"  		 , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		 , ГруппаРодитель);
	ГруппаИзменитьСуммуГоризонталь = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);		
	
	// Создаем команду кнопки.
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "Подключаемый_заголовокСуммы");
	ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ЗаголовокСуммыСделки_" + ИндексВиджета);
	КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	// Создаем кнопку.
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("Заголовок"   	 	 , НСтр("ru = 'Сумма сделки   :'; en = 'Sum deal   :'"));
	ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "ЗаголовокСуммыСделки_" + ИндексВиджета);
	ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
	ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаИзменитьСуммуГоризонталь);	
	КнопкаСделки = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	
	// Создаем поле ввода и реквизит.
	ПараметрыПоля = Новый Структура;
	ПараметрыПоля.Вставить("ГруппаЭлемента"        , ГруппаИзменитьСуммуГоризонталь);
	ПараметрыПоля.Вставить("ИмяЭлемента"           , "СуммаСделкиИзменить_" + ИндексВиджета);
	ПараметрыПоля.Вставить("ИмяРеквизитаДанных"    , "ПолеВводаСуммыСделки");
	ПараметрыПоля.Вставить("ТипДанныхПоУмолчанию"  , Тип("Число"));
	ПараметрыПоля.Вставить("РазмерШрифта"          , 10);
	ПараметрыПоля.Вставить("ШиринаЭлемента"        , 4);
	ПараметрыПоля.Вставить("ОбработчикПриИзменении", "Подключаемый_ПолеВводаСуммыСделкиПриИзменении");
	
	ПолеДопВвода = СоздатьЭлементПоле(Форма, ПараметрыПоля);
	
КонецПроцедуры

#Область ОбработчикиДинамическихЭлементовВиджета
// Обработчики нажатия динамических элементов виджета и обновления сделки.

// Процедура, обновляет этап сделки.
//
// Параметры:
//	Сделка 		- ссылка - изменяемая сделка.
//	ИндексЭтапа - число  - индекс этап.
//
Процедура ОбновитьЭтапСделки(Сделка, ИндексЭтапа) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Сделка) ИЛИ ИндексЭтапа = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не заполнены входящие данные'; en = 'Incoming data is not filled'"));
		Возврат;		
	КонецЕсли;
	
	ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(Сделка.ВидСделки);
	МассивЭтапов  = ТаблицаЭтапов.НайтиСтроки(Новый Структура("НомерЭтапа", ИндексЭтапа + 1));	
	
	Если МассивЭтапов.Количество() > 0 Тогда
		
		Прием 	  = Неопределено; // Сделка.Прием;
		
		ОбъектСделка  = Сделка.ПолучитьОбъект();
		ОбъектСделка.ЭтапСделки 	 		= МассивЭтапов[0].ЭтапСделки;
		ОбъектСделка.РезультатСделки 		= Неопределено;
		ОбъектСделка.ЭтапОтказа 			= Неопределено;
		ОбъектСделка.ДатаЗавершенияСделки 	= Неопределено;
		ОбъектСделка.ПричинаОтказа 			= Неопределено;
		// ОбъектСделка.Прием				= Неопределено;
		
		Если ЗначениеЗаполнено(Прием) Тогда
			ДокументПрием = Прием.ПолучитьОбъект();
			ДокументПрием.Сделка = Неопределено;
		КонецЕсли;
		
		Попытка
			ОбъектСделка.Записать();
			Если ЗначениеЗаполнено(Прием) Тогда
				ДокументПрием.Записать(?(ДокументПрием.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
			КонецЕсли
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обновляет результат сделки успех, а так же обновляет сделку в реализации.
//
// Параметры:
//	Сделка 		- Ссылка - элемент справочника сделка. Сделка для изменения.
//	Прием 	- Ссылка - документ реализация. Прием для изменения.
//
Процедура ОбновитьЭтапУспех(Сделка, Прием) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Сделка) ИЛИ НЕ ЗначениеЗаполнено(Прием) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не заполнены входящие данные'; en = 'Incoming data is not filled'"));
		Возврат;	
	КонецЕсли;
	
	ОбъектСделка  = Сделка.ПолучитьОбъект();
	ОбъектСделка.РезультатСделки = Перечисления.РезультатыСделок.Успех;
	ОбъектСделка.ЭтапУспеха		 = ОбъектСделка.ЭтапСделки;
	ОбъектСделка.ЭтапСделки		 = Справочники.ЭтапыСделок.Успех;
	ОбъектСделка.ПричинаОтказа   = Неопределено;
	
	Если ОбъектСделка.Прием <> Прием Тогда		
		
		ОбъектСделка.Прием = Прием;
		
		Попытка
			ОбъектСделка.Записать();	
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось записать сделку по причине:'; en = 'Failed to write a deal due to:'") + ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
	
	Если Прием.Сделка <> Сделка Тогда
		УстановитьПривилегированныйРежим(Истина);
		ДокументПрием = Прием.ПолучитьОбъект();
		ДокументПрием.Сделка = Сделка;
		
		Попытка
			ДокументПрием.Записать(?(ДокументПрием.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось записать реализацию по причине:'; en = 'Failed to write a sale due to:'") + ОписаниеОшибки()); 
		КонецПопытки;
		
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обновляет причину отказа в сделке.
//
// Параметры:
// 	Форма 			- управляемая форма - форма объекта.
//	ПричинаОтказа 	- Ссылка  			- элемент справочника, причины отказов.
//	ИмяЭлемента 	- Строка 			- имя нажатого элемента виджета(имя нажатой таблицы отказов).
// 
Процедура ОбновитьПричинуОтказа(Форма, знач ПричинаОтказа, знач ИмяЭлемента) Экспорт
	
	Если Не ЗначениеЗаполнено(ПричинаОтказа) ИЛИ НЕ ЗначениеЗаполнено(ИмяЭлемента) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не заполнены входящие данные'; en = 'Incoming data is not filled'"));
		Возврат;
	КонецЕсли;
	
	ИндексВиджета 	= ПолучитьИндексСтроки(ИмяЭлемента, Ложь);
	Если Форма.ТаблицаСделок.Количество() = 0 Тогда
		ЭлементСписка = Форма.СписокВидовСделок.НайтиПоИдентификатору(ИндексВиджета);
		Если ЭлементСписка <> Неопределено Тогда 
			НоваяСделка   	= Справочники.Сделки.СоздатьЭлемент();		
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("Контрагент"					, Форма.Объект.Контрагент);
			ДанныеЗаполнения.Вставить("ЧленствоПакетУслуг"			, Форма.Объект.Ссылка);
			ДанныеЗаполнения.Вставить("ВидСделки"					, ЭлементСписка.Значение);
			ДанныеЗаполнения.Вставить("ЭтапСделки"					, Справочники.ЭтапыСделок.Отказ);
			ДанныеЗаполнения.Вставить("ЭтапОтказа"					, Справочники.ВидыСделок.ПолучитьСтартовыйЭтапВидаСделки(ЭлементСписка.Значение));
			ДанныеЗаполнения.Вставить("ДатаСделки"					, ТекущаяДатаСеанса());
			ДанныеЗаполнения.Вставить("КаналПривлечения"  			, Форма.Объект.Контрагент.КаналПривлечения); 
			ДанныеЗаполнения.Вставить("ИсточникИнформации"			, Форма.Объект.Контрагент.ИсточникИнформации);
			ДанныеЗаполнения.Вставить("ИсточникИнформацииЗначение"	, Форма.Объект.Контрагент.ИсточникИнформацииЗначение);
			ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"			, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
			ДанныеЗаполнения.Вставить("ПричинаОтказа"				, ПричинаОтказа);
			ДанныеЗаполнения.Вставить("ДатаЗавершенияСделки"		, Неопределено);
			ДанныеЗаполнения.Вставить("Прием"					, Неопределено);
			
			НоваяСделка.Заполнить(ДанныеЗаполнения);
			НоваяСделка.ЭтапОтказа 			= Справочники.ЭтапыСделок.Отказ;	
			НоваяСделка.ЭтапСделки		 	= Справочники.ЭтапыСделок.Отказ;
			НоваяСделка.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;			
			НоваяСделка.ПричинаОтказа	 	= ПричинаОтказа;
			
			Попытка
				НоваяСделка.Записать();
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось создать сделку '; en = 'Failed to create a deal '") + ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли;
		Элементы = Форма.Элементы;
		Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость = НЕ Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость;
		Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость   	   = НЕ Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость;
		// Элементы["КнопкаТекущийЭтап_" + ИндексВиджета].Заголовок   = "Отказ: " + НоваяСделка.ПричинаОтказа;
		Возврат;
	Иначе 	
		Сделка 		= Форма.ТаблицаСделок[ИндексВиджета].Сделка;
	КонецЕсли;
	Прием 	  	= Сделка.Прием;
	
	ОбъектСделка  	= Сделка.ПолучитьОбъект();
	ОбъектСделка.РезультатСделки 		= Перечисления.РезультатыСделок.Отказ;
	Если ЗначениеЗаполнено(ОбъектСделка.ЭтапСделки) И НЕ ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбъектСделка.ЭтапСделки, "Предопределенный") Тогда 
		ОбъектСделка.ЭтапОтказа 		= ОбъектСделка.ЭтапСделки;
	ИначеЕсли НЕ ЗначениеЗаполнено(ОбъектСделка.ЭтапОтказа) Тогда 
		ОбъектСделка.ЭтапОтказа 		= Справочники.ВидыСделок.ПолучитьСтартовыйЭтапВидаСделки(ОбъектСделка.ВидСделки);
	КонецЕсли;	
	ОбъектСделка.ЭтапСделки		 		= Справочники.ЭтапыСделок.Отказ;
	ОбъектСделка.ПричинаОтказа	 	  	= ПричинаОтказа;
	ОбъектСделка.ДатаЗавершенияСделки 	= Неопределено;
	ОбъектСделка.Прием				= Неопределено;
	
	Если ЗначениеЗаполнено(Прием) Тогда
		ДокументПрием = Прием.ПолучитьОбъект();
		ДокументПрием.Сделка = Неопределено;
	КонецЕсли;
	
	Попытка
		
		ОбъектСделка.Записать();
		Если ЗначениеЗаполнено(Прием) Тогда
			ДокументПрием.Записать(?(ДокументПрием.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		КонецЕсли;
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
	
	Элементы = Форма.Элементы;
	Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость = НЕ Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость;
	Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость   	   = НЕ Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость;
	Элементы["КнопкаТекущийЭтап_" + ИндексВиджета].Заголовок   = НСтр("ru = 'Отказ: '; en = 'Denial: '") + ОбъектСделка.ПричинаОтказа;
	
КонецПроцедуры

// Фукнция, изменяет вид сделки из виджета.
//
// Параметры:
// 	Сделка 			 - Ссылка - изменяемая сделка.
//	ИндексВидаСделки - Число  - индекс вида сделки, который соответсвует индексу строки экспортной функци.
//	ТекстОшибки 	 - Строка - текст ошибки. 
// 
Процедура ИзменитьВидСделки(Сделка, ВыбранныйВидСделки, ТекстОшибки) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Сделка) ИЛИ НЕ ЗначениеЗаполнено(ВыбранныйВидСделки) Тогда		
		ТекстОшибки = НСтр("ru = 'Не заполнены входящие данные!'; en = 'Incoming data is not filled!'");
		Возврат;	
	КонецЕсли;
	
	Если Сделка.ВидСделки = ВыбранныйВидСделки Тогда
		ТекстОшибки = НСтр("ru = 'Выбранная сделка уже содержит этот вид.'; en = 'The selected deal already contains this type.'");
		Возврат;		
	КонецЕсли;
	
	ОбъектСделка = Сделка.ПолучитьОбъект();
	ОбъектСделка.ВидСделки 				= ВыбранныйВидСделки;
	ОбъектСделка.ЭтапСделки 			= Справочники.ВидыСделок.ПолучитьСтартовыйЭтапВидаСделки(ВыбранныйВидСделки);
	ОбъектСделка.РезультатСделки 		= Неопределено;
	ОбъектСделка.ЭтапОтказа 			= Неопределено;
	ОбъектСделка.ДатаЗавершенияСделки 	= Неопределено;
	ОбъектСделка.ПричинаОтказа 			= Неопределено;
	// ОбъектСделка.Прием				= Неопределено;
	ОбъектСделка.Наименование 			= Неопределено;
	
	// Если ЗначениеЗаполнено(Прием) Тогда
	//	ДокументПрием = Прием.ПолучитьОбъект();
	//	ДокументПрием.Сделка = Неопределено;
	// КонецЕсли;
	
	Попытка
		
		ОбъектСделка.Записать();		
		// Если ЗначениеЗаполнено(Прием) Тогда
		//	ДокументПрием.Записать(?(ДокументПрием.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		// КонецЕсли;
		
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
КонецПроцедуры

// Процедура, изменяет сумму сделки из виджета.
//
// Параметры:
// 	Сделка - Ссылка - изменяемая сделка.
//	Сумма  - Число  - новая сумма сделки.
//
Процедура ИзменитьСуммуСделки(Сделка, Сумма) Экспорт
	
	Если Не ЗначениеЗаполнено(Сделка) ИЛИ Сумма = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не заполнены входящие данные'; en = 'Incoming data is not filled'"));
		Возврат;
	КонецЕсли;
	
	ОбъектСделка = Сделка.ПолучитьОбъект();
	ОбъектСделка.СуммаСделки = Сумма;
	
	Попытка
		ОбъектСделка.Записать();		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ПалтираЦветов

// Процедура, обновить палитру цветов.
//
Процедура ОбновитьПалитруЦветов(Форма) Экспорт
	
	МассивЦветов = ПолучитьМассивЦветов();
	
	ИндексЭлемента     = 0;
	ИндексГруппы 	   = 0;
	СчетчикОграничения = 0;	
	Для Каждого ЭлементМассива Из МассивЦветов Цикл
		
		Если СчетчикОграничения = 0
			ИЛИ СчетчикОграничения = 3 Тогда
			
			// Создание группы.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаСтрокаПалтирыЦветов_" + ИндексГруппы);
			ПараметрыГруппы.Вставить("ГруппаЭлемента", Форма.Элементы.ВсплывающаяПалтира);
			ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
			ГруппаСтрокаПалтирыЦветов = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
			ИндексГруппы 	   = ИндексГруппы + 1;
			СчетчикОграничения = 0;
	
		КонецЕсли;
		
		// Создаем команду кнопки.
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ВыбратьЦвет");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "Цвет_" + ИндексЭлемента + "_" + ИндексГруппы);
		КомандаКнопки =  СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
		
		// Создаем кнопку выбора цвета.
		КнопкаФормы_Этап_Цвет = Форма.Элементы.Добавить("КнопкаВыбораЦвета_" + ИндексЭлемента + "_" + ИндексГруппы, Тип("КнопкаФормы"), ГруппаСтрокаПалтирыЦветов);
		КнопкаФормы_Этап_Цвет.Отображение = ОтображениеКнопки.Картинка;	
		КнопкаФормы_Этап_Цвет.ИмяКоманды  = КомандаКнопки.Имя;
		КнопкаФормы_Этап_Цвет.ЦветФона 	  = ЭлементМассива;
		
		ИндексЭлемента 	   = ИндексЭлемента + 1;
		СчетчикОграничения = СчетчикОграничения + 1;
		
	КонецЦикла;
	
КонецПроцедуры

