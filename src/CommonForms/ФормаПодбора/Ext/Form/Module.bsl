&НаКлиенте
Функция ПолучитьЦенуНоменклатуры(ТекущиеДанные)
	
	Цена = 0;
	Если ИспользуютсяЦены ИЛИ ИспользуютсяСкидкиНаценки Тогда			
		
		Если НЕ ТекущиеДанные.Упаковка.Пустая() Тогда
			Коэффициент = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущиеДанные.Упаковка, "Коэффициент");
		Иначе
			Коэффициент = 1;
		КонецЕсли;
		
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("ДатаОбработки", 		Период);
		СтруктураДанные.Вставить("СтруктурнаяЕдиница",	СтруктурнаяЕдиница);
		СтруктураДанные.Вставить("ВидЦен", 				ВидЦен);
		СтруктураДанные.Вставить("Номенклатура", 		ТекущиеДанные.Номенклатура);
		СтруктураДанные.Вставить("Коэффициент", 		Коэффициент);
		СтруктураДанные.Вставить("СтавкаНДС", 			ПолучитьСтавкуНДСНоменклатуры(ТекущиеДанные.Номенклатура, СтруктурнаяЕдиница)); // ТекущиеДанные.СтавкаНДС);			
		СтруктураДанные.Вставить("Упаковка", 			ТекущиеДанные.Упаковка);
		СтруктураДанные.Вставить("Сотрудник", 			?(ЗначениеЗаполнено(ТекущиеДанные.Сотрудник), ТекущиеДанные.Сотрудник, СотрудникПоУмолчанию));
		
		Цена = Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураДанные);
		
	КонецЕсли;
	
	Возврат Цена;
	
КонецФункции

&НаКлиенте
Процедура НайтиНоменклатуру(Команда)
	
	ПараметрыПоиска = Новый Структура();
	// Параметр, текущий реквизит поиска (по текущему элементу таблицы подбора) 
	Если Элементы.СписокЗапасов.ТекущийЭлемент<>Неопределено Тогда 	
		ПараметрыПоиска.Вставить("РеквизитПоиска",СтрЗаменить(Элементы.СписокЗапасов.ТекущийЭлемент.Заголовок," ",""));
	КонецЕсли;
	Оповещение = Новый ОписаниеОповещения("ПослеПоискаНоменклатуры", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ФормаПоискаНоменклатуры", ПараметрыПоиска,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
КонецПроцедуры 

&НаКлиенте
// Процедура, Обработчик события "ПослеПоискаНоменклатуры"
//
Процедура ПослеПоискаНоменклатуры(Результат, ДопПараметры) Экспорт
	
    Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если НЕ ПустаяСтрока(Результат.СтрокаПоиска) Тогда
			СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПоискАктивен", Истина);
			Если Результат.ПолеПоиска = "Цена" Тогда
				СписокЗапасов.Параметры.УстановитьЗначениеПараметра("СтрокаПоиска", Число(Результат.СтрокаПоиска));
			Иначе
				СписокЗапасов.Параметры.УстановитьЗначениеПараметра("СтрокаПоиска", "%"+Результат.СтрокаПоиска+"%");
			КонецЕсли;
			Если Результат.ПутьПоиска = "Вподчиненных" ИЛИ Результат.ПутьПоиска = "ВоВсехГруппах" Тогда
				СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПодчиненныеЭлементы", Истина);
			Иначе
				СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПодчиненныеЭлементы", Ложь);
			КонецЕсли;
			МодифицироватьЗапрос(Результат, ЭтаФорма.РевизитПоле);
			ЭтаФорма.Элементы.ОтменитьПоискНоменклатуры.Доступность = Истина;
		КонецЕсли;
	Иначе
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПоискАктивен", Ложь);
		ЭтаФорма.Элементы.ОтменитьПоискНоменклатуры.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере                                                                                                                                       
Процедура МодифицироватьЗапрос(АдресЗапасовВХранилище, Поле)
	
	Если АдресЗапасовВХранилище.ПутьПоиска = "ВоВсехГруппах" Тогда
		СписокЗапасов.Параметры.УстановитьЗначениеПараметра("Группа", Справочники.Номенклатура.ПустаяСсылка());
	КонецЕсли;
	
	ЧастьЗапроса1 = "ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	НоменклатураСписок.Код,
	|	НоменклатураСписок.Артикул,
	|	НоменклатураСписок.Наименование КАК Наименование,
	|	СУММА(Остатки.КоличествоОстаток) КАК Остаток,
	|	НоменклатураСписок.Ссылка КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1) КАК Цена,
	|	НоменклатураСписок.СтавкаНДС
	|ИЗ
	|	Справочник.Номенклатура КАК НоменклатураСписок
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(
	|				,
	|				СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					И Склад = &Склад) КАК Остатки
	|		ПО НоменклатураСписок.Ссылка = Остатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&НаДату,
	|				СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					И ВидЦен = &ВидЦен
	|					И Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|					И Актуальность = ИСТИНА) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО НоменклатураСписок.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &НетТипаНоменклатуры
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НоменклатураСписок.ТипНоменклатуры В (&ТипНоменклатуры)
	|		КОНЕЦ
	|	И НЕ НоменклатураСписок.ЭтоГруппа
	|	И ВЫБОР
	|			КОГДА &ПоискАктивен
	|					И &СтрокаПоиска <> """"
	|				ТОГДА ВЫБОР
	|							КОГДА &ПодчиненныеЭлементы
	|								ТОГДА НоменклатураСписок.Родитель В ИЕРАРХИИ (&Группа)
	|							ИНАЧЕ НоменклатураСписок.Родитель = &Группа
	|						КОНЕЦ
	|					 ";
	
	Если АдресЗапасовВХранилище.ПолеПоиска = "Цена" Тогда
		ЧастьЗапроса2 = "	И ЦеныНоменклатурыСрезПоследних."+АдресЗапасовВХранилище.ПолеПоиска+" = &СтрокаПоиска
		|		";
	ИначеЕсли АдресЗапасовВХранилище.ПолеПоиска = "СтавкаНДС" Тогда
		Если АдресЗапасовВХранилище.СтрокаПоиска = "Без НДС" Тогда
			ЧастьЗапроса2 = "	И НоменклатураСписок."+АдресЗапасовВХранилище.ПолеПоиска+" = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.БезНДС)
			|		";
		ИначеЕсли АдресЗапасовВХранилище.СтрокаПоиска = "0%" Тогда
			ЧастьЗапроса2 = "	И НоменклатураСписок."+АдресЗапасовВХранилище.ПолеПоиска+" = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС0)
			|		";
		ИначеЕсли АдресЗапасовВХранилище.СтрокаПоиска = "10%" Тогда 
			ЧастьЗапроса2 = "	И НоменклатураСписок."+АдресЗапасовВХранилище.ПолеПоиска+" = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС10)
			|		";
		ИначеЕсли АдресЗапасовВХранилище.СтрокаПоиска = "18%" Тогда 
			ЧастьЗапроса2 = "	И НоменклатураСписок."+АдресЗапасовВХранилище.ПолеПоиска+" = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС18)
			|		";
		КонецЕсли;
	Иначе
		ЧастьЗапроса2 = "	И НоменклатураСписок."+АдресЗапасовВХранилище.ПолеПоиска+" Подобно &СтрокаПоиска
		|		";
	КонецЕсли;
	
	ЧастьЗапроса3 = "			ИНАЧЕ НоменклатураСписок.Ссылка В ИЕРАРХИИ (&Группа)
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	НоменклатураСписок.Код,
	|	НоменклатураСписок.Наименование,
	|	НоменклатураСписок.Ссылка,
	|	НоменклатураСписок.СтавкаНДС,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1),
	|	НоменклатураСписок.Артикул";
	
	СписокЗапасов.ТекстЗапроса = ЧастьЗапроса1 + ЧастьЗапроса2 + ЧастьЗапроса3;				 
	
	Поле = АдресЗапасовВХранилище.ПолеПоиска;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьПоиск(Команда)
	
	СписокЗапасов.Параметры.УстановитьЗначениеПараметра("ПоискАктивен", Ложь);
	ЭтаФорма.Элементы.ОтменитьПоискНоменклатуры.Доступность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобранныеЗапасыПартияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтрокаТабличнойЧасти = Элементы.ОтобранныеЗапасы.ТекущиеДанные;
	ЗначениеОтбора = Новый Структура("Владелец", СтрокаТабличнойЧасти.Номенклатура);
	ПараметрыВыбораСписка = Новый Структура("Отбор", ЗначениеОтбора);
	ПараметрыВыбораСписка.Вставить("Склад", Склад);
	ПараметрыВыбораСписка.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	ПараметрыВыбораСписка.Вставить("Дата", Период);
	ПараметрыВыбораСписка.Вставить("МножественныйВыбор", Ложь);
	Если ПодборДляПоступленияНаСклад Тогда
		ПараметрыВыбораСписка.Вставить("ОтборПоПартиям", Истина);
	Иначе
		ПараметрыВыбораСписка.Вставить("Фильтр", Истина);
	КонецЕсли;
	
	ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", ПараметрыВыбораСписка,,,,, 
	Новый ОписаниеОповещения("ОтобранныеЗапасыПартияНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобранныеЗапасыПартияНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	СтрокаТабличнойЧасти = ДополнительныеПараметры.СтрокаТабличнойЧасти;

	Если Результат <> Неопределено и Результат.Количество() <> 0 Тогда
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Партия", Результат[0]);
		НайденныеСтроки = ОтобранныеЗапасы.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтроки.Количество() > 0 Тогда		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Серийный номер уже был указан в документе!");		
		Иначе	
			СтрокаТабличнойЧасти.Партия = Результат[0];
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗапасыИерархияПриАктивизацииСтроки(Элемент)
	
	Если Элементы.ЗапасыИерархия.ТекущиеДанные <> Неопределено Тогда
		Группа = Элементы.ЗапасыИерархия.ТекущиеДанные.Ссылка;
	Иначе 
		Группа = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
	КонецЕсли;
	ОбновитьСписокНоменклатуры();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения"
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование"
		И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			// Преобразуем предварительно к ожидаемому формату
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			
			ПолученыШтрихкоды(Данные);
		КонецЕсли;
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обработку полученных штрихкодов
//
Процедура ПолученыШтрихКоды(ДанныеШтрикодов)
	
	Если ДанныеШтрикодов.Количество() > 0 Тогда
		ДанныеПоШтрихкодам = ОбщегоНазначенияСтоматология.ВернутьНоменклатуруПоШтрихкоду(ДанныеШтрикодов[0].Штрихкод);
		Если ДанныеПоШтрихкодам <> Неопределено Тогда
			Если ТипЗнч(ДанныеПоШтрихкодам.Объект) = Тип("СправочникСсылка.Номенклатура") Тогда
				Группа = ПолучитьРодителяЭлемента(ДанныеПоШтрихкодам.Объект);
				ВыборПоШтрихКоду = Истина;
				Элементы.ЗапасыИерархия.ТекущаяСтрока = Группа;
				Элементы.СписокЗапасов.ТекущаяСтрока = ДанныеПоШтрихкодам.Объект;
				ВыборПоШтрихКоду = Ложь;
				ОбновитьСписокНоменклатуры();
				СписокТоваровВыбор(Элементы.СписокЗапасов, ДанныеПоШтрихкодам.Объект, Неопределено, Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

