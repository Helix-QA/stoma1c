// Функция - Получает данные выделенной области табличного документа
// 
// 
Функция ПолучитьДанныеВыделеннойОбластиГрафикПериодовРаботыТабДок(ИмяОбласти)
	
	Позиция = СтрНайти(ИмяОбласти,"C");
