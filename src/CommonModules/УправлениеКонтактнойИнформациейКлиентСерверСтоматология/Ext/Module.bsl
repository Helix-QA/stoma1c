//  Возвращает массив структур с информацией о частях адреса согласно приказу ФНС ММВ-7-1/525 от 31.08.2011.
//
// Возвращаемое значение:
//      Массив - содержит структуры - описания.
//
Функция ТипыОбъектовАдресацииАдресаРФ() Экспорт
	
	Результат = Новый Массив;
	
	// Код, Наименование, Тип, Порядок, КодФИАС
	// Тип: 1 - владение, 2 - здание, 3 - помещение.
	
	Результат.Добавить(СтрокаОбъектаАдресации("1010", НСтр("ru='Дом';en='House'"),          1, 1, 2));
	Результат.Добавить(СтрокаОбъектаАдресации("1020", НСтр("ru='Владение';en='Ownership'"),     1, 2, 1));
	Результат.Добавить(СтрокаОбъектаАдресации("1030", НСтр("ru='Домовладение';en='House ownership'"), 1, 3, 3));
	
	Результат.Добавить(СтрокаОбъектаАдресации("1050", НСтр("ru='Корпус';en='Housing'"),     2, 1));
	Результат.Добавить(СтрокаОбъектаАдресации("1060", НСтр("ru='Строение';en='Structure'"),   2, 2, 1));
	Результат.Добавить(СтрокаОбъектаАдресации("1080", НСтр("ru='Литера';en='Letter'"),     2, 3, 3));
	Результат.Добавить(СтрокаОбъектаАдресации("1070", НСтр("ru='Сооружение';en='Construction'"), 2, 4, 2));
	Результат.Добавить(СтрокаОбъектаАдресации("1040", НСтр("ru='Участок';en='Plot'"),    2, 5));
	
	Результат.Добавить(СтрокаОбъектаАдресации("2010", НСтр("ru='Квартира';en='Apartment'"),  3, 1));
	Результат.Добавить(СтрокаОбъектаАдресации("2030", НСтр("ru='Офис';en='Office'"),      3, 2));
	Результат.Добавить(СтрокаОбъектаАдресации("2040", НСтр("ru='Бокс';en='Boxing'"),      3, 3));
	Результат.Добавить(СтрокаОбъектаАдресации("2020", НСтр("ru='Помещение';en='Placement'"), 3, 4));
	Результат.Добавить(СтрокаОбъектаАдресации("2050", НСтр("ru='Комната';en='Room'"),   3, 5));
	Результат.Добавить(СтрокаОбъектаАдресации("2060", НСтр("ru='Этаж';en='Floor'"),   3, 6));
	//  Наши сокращения для поддержки обратной совместимости при парсинге.
	Результат.Добавить(СтрокаОбъектаАдресации("2010", НСтр("ru='кв.';en='ap.'"),       3, 6));
	Результат.Добавить(СтрокаОбъектаАдресации("2030", НСтр("ru='оф.';en='of.'"),       3, 7));
	
	// Уточняющие объекты
	Результат.Добавить(СтрокаОбъектаАдресации("10100000", НСтр("ru='Почтовый индекс';en='Postal index'")));
	Результат.Добавить(СтрокаОбъектаАдресации("10200000", НСтр("ru='Адресная точка';en='Address point'")));
	Результат.Добавить(СтрокаОбъектаАдресации("10300000", НСтр("ru='Садовое товарищество';en='Garden partnership'")));
	Результат.Добавить(СтрокаОбъектаАдресации("10400000", НСтр("ru='Элемент улично-дорожной сети, планировочной структуры дополнительного адресного элемента';en='Element of the road network the planning structure of the additional element'")));
	Результат.Добавить(СтрокаОбъектаАдресации("10500000", НСтр("ru='Промышленная зона';en='Industrial zone'")));
	Результат.Добавить(СтрокаОбъектаАдресации("10600000", НСтр("ru='Гаражно-строительный кооператив';en='Garage-building society'")));
