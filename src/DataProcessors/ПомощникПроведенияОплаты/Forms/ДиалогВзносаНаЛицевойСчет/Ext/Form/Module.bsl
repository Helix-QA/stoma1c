// Процедура - Завершить редактирования поля ввода суммы.
//
Процедура ЗавершитьРедактированияПоляВводаСуммы(ПолеВвода)
	
	ОтключитьОбработчикОжидания("ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы");	
	ПрефиксПоля			= ИндексСтрокиДанныхДерваПоИменеиЭлемента(ПолеВвода.Имя);
	КнопкаПредСуммы		= ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля);	
	ТекущиеДанные		= СтрокаДанныхДереваПоИменеиЭлемента(ПолеВвода.Имя, "ВидыОплат");	
	
	Если ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей") Тогда
		ТекущееПолеВводаСБП = ПолеВвода;
	КонецЕсли;
	
	ПолеВвода.Видимость = Ложь;
	
	Если ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей") Тогда
		ТекущееПолеВводаСБП = ПолеВвода;
	КонецЕсли;
	
	Если ТекущиеДанные.Внесено > 0 Тогда
		
		КнопкаПредСуммы.Заголовок     = Формат(ТекущиеДанные.Внесено,"ЧДЦ=2");
		КнопкаПредСуммы.Видимость     = Истина;
		
		КнопкаПрименияСуммы           = ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля);
		КнопкаПрименияСуммы.Видимость = Ложь;
		
		КнопкаУдаленияСуммы           = ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля);
		КнопкаУдаленияСуммы.Видимость = Истина;
		
	Иначе
		
		КнопкаПредСуммы.Заголовок     = "0,00";
		КнопкаПредСуммы.Видимость     = Ложь;
		
		КнопкаПрименияСуммы           = ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля);
		КнопкаПрименияСуммы.Видимость = Ложь;
		
		КнопкаУдаленияСуммы           = ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля);
		КнопкаУдаленияСуммы.Видимость = Ложь;
		
	КонецЕсли;
	
	Если ТекущееПолеВВодаСуммыОплаты = ПредПолеВВодаСуммыОплаты Тогда
		ТекущееПолеВВодаСуммыОплаты = Неопределено;
	КонецЕсли;
	
	ПредПолеВВодаСуммыОплаты = Неопределено;
	
	ЭтаФорма.ТекущийЭлемент = Элементы.Внести;
					
КонецПроцедуры 

