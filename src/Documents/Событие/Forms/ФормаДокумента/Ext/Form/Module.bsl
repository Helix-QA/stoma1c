// Процедура, обработчик события "ОбработкаОповещения"
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		// Если ИмяСобытия = "TracksData" Тогда
		//	Результат = Неопределено;			
		//	// Если НЕ ДанныеКлиента = Неопределено Тогда				
		//	//	Объект.Контрагент   = ДанныеКлиента.Клиент;
		//	//	Объект.КартаКлиента = ДанныеКлиента.КартаКлиента;
		//	//	Модифицированность = Истина;
		//	// КонецЕсли;
		// КонецЕсли;
	ИначеЕсли ИмяСобытия = "ВыборНоменклатуры" И Источник = ЭтаФорма Тогда
		Если ПризнакДобавитьСтрокуПриПодборе Тогда
			Элементы.Услуги.СкопироватьСтроку();
		КонецЕсли;		
		Элементы.Услуги.ТекущиеДанные.Номенклатура = Параметр;
		УслугиНоменклатураПриИзменении(Неопределено);
		ПризнакДобавитьСтрокуПриПодборе = Истина;
	КонецЕсли;
	
	Если ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА" Тогда
		ВывестиНезавершенныеНарядЗаказы();
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьСтруктурныеЕдиницыСотрудника" Тогда
		УстановитьПараметрыВыбораСотрудникаНаСервере();
	КонецЕсли;
	
	Если ИмяСобытия = "ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ" Тогда
		ЭтаФорма.Прочитать();
		ОбновитьВиджетСделки();
	КонецЕсли;  
	
	Если ИмяСобытия = "ОБНОВИТЬ_СТАТУС_И_ВИДЖЕТ_СДЕЛКИ" И Параметр = Объект.Сделка Тогда
		ЭтаФорма.Прочитать();		
		ОбновитьВиджетСделки(, , Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик перед записью данных формы.
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	УстановитьОбязательныеПоля();
	
	// Если создаем нового пациента то проверяем поля нового пациента на заполнение
	Если ПризнакСозданияНовогоПациента = Истина Тогда
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект.Фамилия_НовыйПациент) И Не ЗначениеЗаполнено(ЭтотОбъект.Имя_НовыйПациент)
			И Не ЗначениеЗаполнено(ЭтотОбъект.Отчество_НовыйПациент) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Невозможно создать нового пациента. Не заполнено наименование!",,,, Отказ);
			Возврат;
			
		ИначеЕсли НЕ ЗначениеЗаполнено(Родитель_НовыйПациент) Тогда
			
			ПризнакСозданияНовогоПациента = Истина;
			Ссылка_НовыйПациент = ?(Ссылка_НовыйПациент <> Неопределено И ЗначениеЗаполнено(Ссылка_НовыйПациент), Ссылка_НовыйПациент, ПолучитьСсылкуНаНовогоПациента());
			
			// Определяем куда записать нового пациента
			МассивГруппКлиентов = ПолучитьГруппуНовогоПациента();
			
			Если Не ЗначениеЗаполнено(МассивГруппКлиентов) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отсутствуют группы для создания пациента",,,, Отказ);
				Возврат;
			Иначе
				Родитель_НовыйПациент = МассивГруппКлиентов[0];
			КонецЕсли;
			
		КонецЕсли;
		// Если создаем нового пациента 
		Если Элементы.Контрагент.АвтоОтметкаНезаполненного = Истина Тогда
			Элементы.Контрагент.АвтоОтметкаНезаполненного = Ложь;
		КонецЕсли;
				
	КонецЕсли; 
	
	// Проверяем заполнение обязательных полей 	
	Для Каждого ЭлементФормы Из Элементы Цикл
		Если ТипЗнч(ЭлементФормы) = Тип("ПолеФормы")
			И ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода
			И ЭлементФормы.АвтоОтметкаНезаполненного = Истина Тогда
			
			ИмяЭлемента = ЭлементФормы.Заголовок;
			Если ЭлементФормы.ТекстРедактирования = "" Тогда
				
				Если ЭлементФормы.Имя = "Контрагент" Тогда
					
					ИмяЭлемента = НСтр("ru = 'Пациент'; en = 'Patient'");
					
				ИначеЕсли ЭлементФормы.Имя = "УслугиПричинаЗаписиПолем" Тогда
					
					ИмяЭлемента = НСтр("ru = 'Причина записи'; en = 'Reason for entry'");
					
				ИначеЕсли ЭлементФормы.Имя = "УслугиСотрудникПолем" Тогда	
					
					ИмяЭлемента = НСтр("ru = 'Врач'; en = 'Doctor'");
					
				ИначеЕсли ЭлементФормы.Имя = "УслугиПомещениеПолем" Тогда
					
					ИмяЭлемента = НСтр("ru = 'Кабинет'; en = 'Cabinet'");
					
				Иначе
					Если ЗначениеЗаполнено(ЭлементФормы.Заголовок) Тогда
						ИмяЭлемента = ЭлементФормы.Заголовок;
					Иначе
						ИмяЭлемента = ЭлементФормы.Имя;	
					КонецЕсли;
				КонецЕсли;
				
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, ЭлементФормы.Имя) И ЗначениеЗаполнено(Объект[ЭлементФормы.Имя]) Тогда 					
					Продолжить;	
				КонецЕсли;
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Не заполнено поле %1!';en='Not is filled field %1!'"), ИмяЭлемента));
				Отказ = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// Проверка на работу врача в указанное время
	Если ПризнакИзмененияВремениВрачей = Ложь Тогда	
		НеобходимВопрос = Ложь;
		НесколькоВрачейВПриеме = ВернутьКонстантуНесколькоВрачейВОдномПриеме();
		
		Если НЕ НесколькоВрачейВПриеме ИЛИ (НесколькоВрачейВПриеме И Объект.Услуги.Количество() <= 2) Тогда
			// Делаем время рабочим для текущего врача
		
			ВремяРабочее = ПроверитьВхождениеИнтервалаВРабочееВремяСотрудника(Объект.Услуги[0].ДатаНачала,Объект.Услуги[0].ДатаНачала,Объект.Услуги[0].ДатаОкончания,Объект.Услуги[0].Сотрудник,Объект.СтруктурнаяЕдиница);	 			
			Если НЕ ВремяРабочее И ЗначениеЗаполнено(Объект.Услуги[0].Сотрудник) Тогда
				
				НеобходимВопрос = Истина;
				УслугиКоличествоСтрок = Объект.Услуги.Количество();	
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ВремяНачала"				, Объект.Услуги[0].ДатаНачала);
				ДополнительныеПараметры.Вставить("ВремяОкончания"			, Объект.Услуги[УслугиКоличествоСтрок-1].ДатаОкончания);
				ДополнительныеПараметры.Вставить("Сотрудник"				, Объект.Услуги[0].Сотрудник);
				ДополнительныеПараметры.Вставить("НесколькоВрачейВПриеме"	, Ложь); // Если 1 строка в ТЧ, но НесколькоВрачей = Истина, то всеравно ставим на Ложь.
				
				// Формируем вопрос для сообщения:
				Вопрос = "Выбранное время не является рабочим для сотрудника "+Объект.Услуги[0].Сотрудник+". Отметить выбранный период рабочим и продолжить?";
			КонецЕсли;
		Иначе
			ТаблицаУслуги = Объект.Услуги;
			МассивВремениДляИзменения = ИзменениеРабочегоВремениДляНесколькихВрачей(ТаблицаУслуги);
			
			// Если не нужно изменять время, не изменяем его
			Если МассивВремениДляИзменения.Количество() <> 0 Тогда 
				НеобходимВопрос = Истина;
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ДополнительныеПараметры", МассивВремениДляИзменения);
		   		ДополнительныеПараметры.Вставить("НесколькоВрачейВПриеме"	, Истина);
				
				// Формируем вопрос для сообщения:
				ЭлементСообщения = "";
				ИтераторМассив = 0;
				Для Каждого ЭлементСообщенияИзМассива Из МассивВремениДляИзменения Цикл
					ЭлементСообщения = ЭлементСообщения+"с "+Формат(ЭлементСообщенияИзМассива.ВремяНачала,"ДЛФ=T")+" по "+Формат(ЭлементСообщенияИзМассива.ВремяОкончания,"ДЛФ=T")+" для сотрудника "+ЭлементСообщенияИзМассива.ФИО+?(ИтераторМассив = МассивВремениДляИзменения.ВГраница(),". ",", ")  ;
					ИтераторМассив = ИтераторМассив + 1;	
				КонецЦикла;
			
				Вопрос = "Выбранное время не является рабочим "+ЭлементСообщения+"Отметить выбранный период рабочим и продолжить?";
			КонецЕсли;
		КонецЕсли;
		
		Если НеобходимВопрос Тогда
			ДополнительныеПараметры.Вставить("СтруктурнаяЕдиница"		, Объект.СтруктурнаяЕдиница);
			Оповещение = Новый ОписаниеОповещения("ИзменениеРабочегоВремениПриРедактированииПриема", ЭтотОбъект, ДополнительныеПараметры);
			ПоказатьВопрос(Оповещение, Вопрос, РежимДиалогаВопрос.ДаНет);
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	ВидСделки = ПолучитьВидСделкиДляГенерации(Объект.Ссылка, Объект.Сделка, ЭтаФорма.ТекущаяСделка, ТаблицаДоступныхВидовСделок);
	Если ЗначениеЗаполнено(ВидСделки) И ЗначениеЗаполнено(Объект.Контрагент) И НЕ ЗначениеЗаполнено(ЭтотОбъект.КаналПривлечения) Тогда
		ОбращениеПациента = Неопределено;
		Если ПервичнаяСделкаБезОбращения(Объект.СтруктурнаяЕдиница, ВидСделки, Объект.Контрагент, , ОбращениеПациента) Тогда
			// Спрашиваем канал привлечения
			ОповещениеВыбораКаналаПривлечения = Новый ОписаниеОповещения("ПослеВыбораКаналаПривлечения", ЭтотОбъект, Новый Структура("ФормированиеПриема", ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗаписи, "ФормированиеПриема", Ложь)));
			ОткрытьФорму("Справочник.КаналыПривлечения.ФормаВыбора", , ЭтотОбъект, , , ,ОповещениеВыбораКаналаПривлечения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			Отказ = Истина;
			Возврат;
		ИначеЕсли ЗначениеЗаполнено(ОбращениеПациента) Тогда 
			ПараметрыЗаписи.Вставить("ЗаявкаСинхронизации", ОбращениеПациента);
		КонецЕсли;
	ИначеЕсли НЕ ЗначениеЗаполнено(Объект.Контрагент) И НЕ ЗначениеЗаполнено(ЭтотОбъект.КаналПривлечения) И ЗначениеЗаполнено(Ссылка_НовыйПациент) И НЕ СсылкаСуществует(Ссылка_НовыйПациент) Тогда	
		// Спрашиваем канал привлечения
		ОповещениеВыбораКаналаПривлечения = Новый ОписаниеОповещения("ПослеВыбораКаналаПривлечения", ЭтотОбъект, Новый Структура("ФормированиеПриема", ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗаписи, "ФормированиеПриема", Ложь)));
		ОткрытьФорму("Справочник.КаналыПривлечения.ФормаВыбора", , ЭтотОбъект, , , ,ОповещениеВыбораКаналаПривлечения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
