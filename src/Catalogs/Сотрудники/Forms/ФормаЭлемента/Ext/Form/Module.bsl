#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Элементы.Код.Видимость          = ?(ОтображниеКода, Истина, Ложь);
	Элементы.Код.ПоложениеЗаголовка = ?(ОтображниеКода, ПоложениеЗаголовкаЭлементаФормы.Авто, ПоложениеЗаголовкаЭлементаФормы.Нет);
	
	Если НЕ ПравоДоступа("Изменение", Метаданные.РегистрыСведений.НастройкиСотрудников) Тогда
		//Элементы.ДоступныеСтруктурныеЕдиницы.Доступность = Ложь;
		Элементы.НастройкиСотрудников_new.Доступность    = Ложь;
	КонецЕсли;
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
		Элементы.ПользовательИБ.Доступность = РольДоступна("ПолныеПрава");
	ИначеЕсли НЕ ПравоДоступа("Администрирование", Метаданные) И НЕ РольДоступна("ПолныеПрава") Тогда
		Элементы.ПользовательИБ.Доступность = Ложь;
	КонецЕсли;	
	
	ЭтотОбъект.УидСессии = ЛичныйКабинет.УидТекущейСессии();
	ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего =  Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.МобильноеПриложениеУправляющего, Ложь);

	ЭтотОбъект.РедактированиеРазрешено   = ПравоДоступа("Редактирование", Метаданные.Справочники.Сотрудники);
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Если Не Объект.Ссылка.Пустая() Тогда
		// Места работы сотрудников
		ЗаполнитьСписокСтоматологий();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.ДоступныеСтруктурныеЕдиницы) И ЗначениеЗаполнено(ЭтотОбъект.ТекущаяСтруктурнаяЕдиница) Тогда
		
		НоваяСтрока = ДоступныеСтруктурныеЕдиницы.Добавить();
		НоваяСтрока.СтруктурнаяЕдиница = ЭтотОбъект.ТекущаяСтруктурнаяЕдиница;
		УстановитьНастройкиСотрудникаПоУмолчанию(ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
		
	КонецЕсли;
	
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Объект, "СтраницаДополнительныеРеквизиты");	
	
	КонтактнаяИнформацияПриСозданииПриЧтенииНаСервере(Параметры.ЗначенияЗаполнения);

	ОбновитьЦветФонаДолжности();
	
	Для Каждого СтрокаТ Из Объект.СпецилазацииСотрудника Цикл
		СформироватьЭлементыСтрокиСпециализации(СтрокаТ);
	КонецЦикла;
		
	ОбновитьЭлементыГруппы("ГруппаМестаРаботыВыбранные");
		
	ПриИзмененииКартинки();
	
	ПриСозданииПриЧтенииНаСервере();
	СформироватьДинамическиеЭлементыНастроек();	
	
	// Заполнение дерева онлайн записи
	СоздатьДеревоСтруктурныхЕдиницДляОнлайнЗаписи();
	ЭтотОбъект.ОнлайнЗапись = СотрудникДоступенДляОнлайнЗаписи();
	ВывестиСсылкуНаСотрудника();
	
	УстановитьВидимостьЭлементов();
	ОбновитьТабличныеЧастиСотрудника();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();  
	
 КонецПроцедуры

&НаСервере
// Процедура - При чтении на сервере.
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ЭтотОбъект.НомерТелефона = ПолучитьНомерТелефонаСотрудника(ТекущийОбъект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзмененаДолжность" И Параметр = Объект.Должность Тогда
		ОбновитьЦветФонаДолжности();
	ИначеЕсли ИмяСобытия = "ОбновленыУдостоверения" Тогда
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаУдостоверенияЛичностиСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);
	ИначеЕсли ИмяСобытия = "ОбновленыКабинеты" Тогда
		
		Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
			ОбновитьДополнительныеРеквизиты();
		КонецЕсли;
		
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаКабинетыСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);  
			
	ИначеЕсли ИмяСобытия = "Запись_Файл" Тогда
		Если Параметр.Свойство("ВладелецФайла") И Параметр.ВладелецФайла = Объект.Ссылка ИЛИ НЕ Параметр.Свойство("ВладелецФайла") Тогда
			Если Параметр.Свойство("ЭтоНовый") И Параметр.ЭтоНовый Тогда
				Если ТипЗнч(Источник) = Тип("Массив") Тогда
					ИзображениеДляПроверки = Источник[0];
				Иначе
					ИзображениеДляПроверки = Источник;
				КонецЕсли;
				Объект.ФайлКартинки = ИзображениеДляПроверки;			
				Модифицированность = Истина; 			
			КонецЕсли;
			ПриИзмененииКартинки();
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "Запись_Пользователи" Тогда
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаПользовательИБСуществующий");
		
		Если Параметр.Свойство("ВходВПрограммуРазрешен", Ложь) Тогда 
			ДоступКИБ = Параметр.ВходВпрограммуРазрешен;
			УстановитьВидимостьЭлементов();
		КонецЕсли;
		
		ОтображениеДополнительнойИнформации(МассивРодителей);
		Если ЗначениеЗаполнено(Элементы.ГруппаПользовательИБСуществующий.ПодчиненныеЭлементы) Тогда
			Элементы.КнопкаДобавитьПользователяИБ.Видимость = Ложь;	
		КонецЕсли;
		СформироватьДинамическиеЭлементыНастроек(Ложь);
		
	ИначеЕсли ИмяСобытия = "ВыполненВходВЛК" Тогда
		
		НомерТелефонаТекущий 	= ПолучитьНомерТелефонаСотрудника(Объект.Ссылка);
		АвторизацияСКодом = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭтотОбъект.ВнешняяСистемаМобильногоПриложения, "АвторизацияСКодом");
		
	ИначеЕсли ИмяСобытия = "ОбновленыПромокоды" Тогда	
		
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаПромокодыСуществующие");
		
		ОтображениеДополнительнойИнформации(МассивРодителей);
		
	КонецЕсли;
	
	// Обработчик механизма "Свойства".
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
		ОбновитьДополнительныеРеквизиты();
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура, обновляет элементы дополнительных реквизитов.
//
Процедура ОбновитьДополнительныеРеквизиты()
	
	УправлениеСвойствами.ОбновитьЭлементыДополнительныхРеквизитов(ЭтаФорма, РеквизитФормыВЗначение("Объект"));
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗаписью"
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	ТекстОшибки = "";  
	Если ЗначениеЗаполнено(Объект.ИНН) И Не СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(СокрЛП(Объект.ИНН)) Тогда
		ТекстОшибки = ТекстОшибки + "ИНН должен состоять только из цифр." + Символы.ПС;  
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ИНН) И СтрДлина(СокрЛП(Объект.ИНН)) < 12 Тогда
		ТекстОшибки = ТекстОшибки + "ИНН физического лица должен состоять из 12 цифр." + Символы.ПС;  
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Объект.Ссылка, "ИНН", "Объект", Отказ);
		Элементы.ИНН.ОтметкаНезаполненного = Истина;
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ТекстОшибки;
		Сообщение.Поле  = "ИНН";
		Сообщение.ПутьКДанным = "Объект";
		Сообщение.КлючДанных  = Объект.Ссылка;
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

	Если ДоступныеСтруктурныеЕдиницы.Количество() = 0 Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите место работы сотрудника!");
	Иначе
		Для Каждого строка из ДоступныеСтруктурныеЕдиницы Цикл
			Если не ЗначениеЗаполнено(строка.СтруктурнаяЕдиница) Тогда
				Отказ = Истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В табличной части ""Структурные единицы"" не заполнена структурная единица!");
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Объект.Роль = ПредопределенноеЗначение("Перечисление.РольПользователя.Врач") Или Объект.Роль = ПредопределенноеЗначение("Перечисление.РольПользователя.ГлавныйВрач") Тогда
		ВнешняяСистемаИЭМК = ПроверитьВСИЭМК();                                                                                
	Иначе
		ВнешняяСистемаИЭМК = "";
	КонецЕсли;
	
	Если ВнешняяСистемаИЭМК = "2" Тогда
		Текст = "У сотрудника: " + Строка(Объект.НаименованиеСокращенное) + " не заполнено представление должности по ИЭМК. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("СозданиеСвязиСКлассификаторомДолжностейЗавершение", ЭтотОбъект), Текст, РежимДиалогаВопрос.ДаНет);
		Отказ = Истина;
	КонецЕсли;
	
	Если ВнешняяСистемаИЭМК = "4" Тогда
		Текст = "У сотрудника: " + Строка(Объект.НаименованиеСокращенное) + " не заполнено представление основной специализации по ИЭМК. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("СозданиеСвязиСКлассификаторомСпециализацийЗавершение", ЭтотОбъект), Текст, РежимДиалогаВопрос.ДаНет);
		Отказ = Истина;
	КонецЕсли;
	
	Для Каждого СтрокаТЗ Из ДоступныеСтруктурныеЕдиницы Цикл
			
		СтрокиНастроек = НастройкиСотрудников_new.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтрокаТЗ.СтруктурнаяЕдиница));	
		Если Не ЗначениеЗаполнено(СтрокиНастроек) Тогда 
			Продолжить;
		КонецЕсли; 
		
		Для Каждого Строка Из СтрокиНастроек Цикл
			Строка.ДатаПриема 		= СтрокаТЗ.ДатаПриема;
			Строка.ДатаУвольнения 	= СтрокаТЗ.ДатаУвольнения;
		КонецЦикла;
		
	КонецЦикла 
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере"
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("НастройкиСотрудников"	, НастройкиСотрудников.Выгрузить());
	ТекущийОбъект.ДополнительныеСвойства.Вставить("НастройкиСотрудников_new", НастройкиСотрудников_new.Выгрузить());
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ДоступныеСтруктурныеЕдиницы", ДоступныеСтруктурныеЕдиницы.Выгрузить());
    ТекущийОбъект.ДополнительныеСвойства.Вставить("ДоступныеЖурналыПриемов"	, ДоступныеЖурналыПриемов.Выгрузить());
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ДоступныеКассы"			, ДоступныеКассы.Выгрузить());
	
	Если ДоступКИБ И НЕ ТекущийОбъект.ЭтоПользовательИБ Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("УстановитьЭтоПользовательИБ"	, Истина);		
	КонецЕсли;
	
	// Обработчик механизма "Контактная информация". 
	КонтактнаяИнформацияПередЗаписьюНаСервере(ТекущийОбъект);
		
	НаборЗаписей = РегистрыСведений.СвязкаПомещениеСотрудник.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.Сотрудник.Установить(Объект.Ссылка); 
	
	Для Каждого СтрокаТЗ Из ЭтотОбъект.КабинетыСуществующие Цикл
		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Помещение = СтрокаТЗ.Помещение;
		НоваяЗапись.Сотрудник = СтрокаТЗ.Сотрудник;
		НоваяЗапись.Основное  = СтрокаТЗ.Основное;
				
	КонецЦикла; 
	
	НаборЗаписей.Записать();
    // Обработчик механизма "Свойства".
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);      
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Ссылка) И Объект.ФайлКартинки <> ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущийОбъект.Ссылка, "ФайлКартинки") Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ИзменитьАватарСотрудника", Истина);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриЗаписиНаСервере".
//
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ТекущийОбъект.Роль <> Перечисления.РольПользователя.Врач
		И ТекущийОбъект.Роль <> Перечисления.РольПользователя.ГлавныйВрач Тогда
		Возврат;
	КонецЕсли;
	
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	ОбработкаТабличныхЧастейКлиент.ЗаполнитьМассивВыбранныхСтруктурныхЕдиниц(
		ЭтотОбъект.ПодборСтруктурныеЕдиницы.ПолучитьЭлементы(), 
		МассивВыбранныхСтруктурныхЕдиниц);
	
	РегистрыСведений.РеквизитыОбъектов.СоздатьЗаписиВРегистреРеквизитыОбъектов(
		Объект.Ссылка,
		МассивВыбранныхСтруктурныхЕдиниц, 
		"ОнлайнЗаписьСотрудник", 
		Истина);
		
	// Обновляем аватар сотрудника.
	Если ТекущийОбъект.ФайлКартинки <> ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущийОбъект.Ссылка, "ФайлКартинки") Тогда
		РегистрыСведений.АктивныеПользователиМессенджер.ОбновитьАватарСотрудника(ТекущийОбъект.Ссылка, ТекущийОбъект.ФайлКартинки);
	КонецЕсли;	
	
	// Обновляем аватар сотрудника.
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ИзменитьАватарСотрудника")
		И ТекущийОбъект.ДополнительныеСвойства.ИзменитьАватарСотрудника = Истина Тогда
		
		РегистрыСведений.АктивныеПользователиМессенджер.ОбновитьАватарСотрудника(ТекущийОбъект.Ссылка, ТекущийОбъект.ФайлКартинки);
	КонецЕсли;
	
КонецПроцедуры

