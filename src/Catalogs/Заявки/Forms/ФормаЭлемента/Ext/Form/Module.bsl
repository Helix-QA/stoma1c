// Процедура, устанавливает обязательные поля.
//
Процедура УстановитьОбязательныеПоля() 
	
	СтруктураОбязательныеПоля = ВернутьЗначениеКонстантыОбязательныеПоля();
		
	Если СтруктураОбязательныеПоля = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбязательныеПоля = Неопределено;
	
	Если Объект.Ссылка.Пустая() 
		И ТипЗнч(СтруктураОбязательныеПоля) = Тип("Структура") Тогда
		
		СтруктураОбязательныеПоля.Свойство("ОбязательныеПоляДляНовых", ОбязательныеПоля);		
		
	КонецЕсли;
	
	Если ОбязательныеПоля = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Для Каждого ОбязательноеПоле Из ОбязательныеПоля Цикл
		
		Если Лев(ОбязательноеПоле.Ключ, 6) <> "ЗАЯВКА" Тогда 
			Продолжить;	
		КонецЕсли;	
		
		ИзмененноеОбязательноеПоле = СтрЗаменить(ОбязательноеПоле.Ключ, "ЗАЯВКА_", "");
		
		Если СтрЗаменить(ИзмененноеОбязательноеПоле, Прав(ИзмененноеОбязательноеПоле, 1), "") = "ПредставлениеКИ_" И ОбязательноеПоле.Значение = Истина Тогда 
			
			КоличествоЭлементовКИ = Элементы.КонтактнаяИнформация.ПодчиненныеЭлементы.Количество();
			ИндексЭлементаКИ = 0;
			
			Пока КоличествоЭлементовКИ <> 0 Цикл
				
				ТекЭлемент = Элементы.Найти(СтрЗаменить(ИзмененноеОбязательноеПоле, Прав(ИзмененноеОбязательноеПоле, 1), "") + ИндексЭлементаКИ);
				
				Если ТекЭлемент <> Неопределено Тогда 
					
					Если(ОбязательноеПоле.Ключ = "ЗАЯВКА_ПредставлениеКИ_0" И ТекЭлемент.Подсказка = "Телефон") 
						ИЛИ (ОбязательноеПоле.Ключ = "ЗАЯВКА_ПредставлениеКИ_1" И ТекЭлемент.Подсказка = "Адрес электронной почты")
						ИЛИ (ОбязательноеПоле.Ключ = "ЗАЯВКА_ПредставлениеКИ_2" И ТекЭлемент.Подсказка = "Адрес") Тогда
						
						ТекЭлемент.АвтоОтметкаНезаполненного = Истина;
					КонецЕсли;
					
					КоличествоЭлементовКИ = КоличествоЭлементовКИ - 1;
					
				КонецЕсли;
				
				ИндексЭлементаКИ = ИндексЭлементаКИ + 1;
				
			КонецЦикла;
			
		Иначе
									
			ТекЭлемент = Элементы.Найти(ИзмененноеОбязательноеПоле);
			Если ТекЭлемент <> Неопределено Тогда 
				ТекЭлемент.АвтоОтметкаНезаполненного = ОбязательноеПоле.Значение;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

