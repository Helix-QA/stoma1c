// Функция - Сбербанк получить параметры операции для возврата
//
// Параметры:
//  ПараметрыJSON	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_ПолучитьПараметрыОперацииДляВозврата(ПараметрыJSON, СуммаВозвратаВРублях)
	
	СтруктураВозврата = Новый Структура("operation_id, auth_code");
	
	Попытка
		ПараметрыJSON = ДекодироватьИзJSON(ПараметрыJSON);
		
		Для Каждого СтрокаОперации Из ПараметрыJSON.order_operation_params Цикл
			
			Если НРег(СтрокаОперации.operation_type) = НРег("PAY") И СтрокаОперации.operation_sum >= СуммаВозвратаВРублях*100 Тогда
				ЗаполнитьЗначенияСвойств(СтруктураВозврата, СтрокаОперации);
				Возврат СтруктураВозврата;
			КонецЕсли;
			
		КонецЦикла;
		
	Исключение
		Возврат СтруктураВозврата;
	КонецПопытки;
	
	Возврат СтруктураВозврата;
		
КонецФункции

