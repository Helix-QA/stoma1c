// Процедура - Установить картинку статуса
//
// Параметры:
//  Состояние	 - 	 - 
//  Видимость	 - 	 - 
//
&НаКлиенте
Процедура УстановитьКартинкуСтатуса(Состояние, Видимость)
	
	Элементы.СтатусОперации.Видимость = Видимость;
	
	Если Состояние = 0 Тогда
		Элементы.СтатусОперации.Картинка = БиблиотекаКартинок.Ожидание32;
	ИначеЕсли Состояние = 1 Тогда
		Элементы.СтатусОперации.Картинка = БиблиотекаКартинок.ВнешнееОборудованиеККТ32;
	ИначеЕсли Состояние = 2 Тогда
		Элементы.СтатусОперации.Картинка = БиблиотекаКартинок.Предупреждение32;
	ИначеЕсли Состояние = 3 Тогда
		Элементы.СтатусОперации.Картинка = БиблиотекаКартинок.ОткрытьКассовуюСмену32;
	ИначеЕсли Состояние = 4 Тогда
		Элементы.СтатусОперации.Картинка = БиблиотекаКартинок.ZОтчет32;
	КонецЕсли;
		
КонецПроцедуры

// Процедура - Отобразить состояние кассовой смены
//
// Параметры:
//  СостояниеКассовойСмены	 - 	 - 
//
&НаКлиенте
Процедура ОтобразитьСостояниеКассовойСмены(СостояниеКассовойСмены)
	
	Если СостояниеКассовойСмены <> Неопределено Тогда
		
		Если НЕ СостояниеКассовойСмены.СтатусыКассовойСмены = ПредопределенноеЗначение("Перечисление.СтатусыКассовойСмены.Открыта") Тогда
			
			Элементы.ДекорацияОжиданиеОткрытияКассовойСмены.Видимость = Истина;
			ЭтотОбъект.ДатаКассовйСмены                               = СостояниеКассовойСмены.ОкончаниеКассовойСмены;
			Элементы.ДатаКассовойСмены.ЦветТекста                     = WebЦвета.Красный;
			Элементы.ДатаКассовойСмены.Заголовок                      = НСтр("ru = 'Смена закрыта'; en = 'Shift is closed'");
			
		Иначе
			
			Элементы.ДекорацияОжиданиеОткрытияКассовойСмены.Видимость = Ложь;
			ЭтотОбъект.ДатаКассовйСмены                               = СостояниеКассовойСмены.НачалоКассовойСмены;
			Элементы.ДатаКассовойСмены.ЦветТекста                     = WebЦвета.Черный;
			Элементы.ДатаКассовойСмены.Заголовок                      = НСтр("ru = 'Смена открыта'; en = 'Shift is open'");
			
		КонецЕсли;
		
	Иначе
		
		Элементы.ДекорацияОжиданиеОткрытияКассовойСмены.Видимость = Истина;
		ЭтотОбъект.ДатаКассовйСмены                               = Неопределено;
		Элементы.ДатаКассовойСмены.ЦветТекста                     = WebЦвета.Красный;
		Элементы.ДатаКассовойСмены.Заголовок                      = НСтр("ru = 'Смена закрыта'; en = 'Shift is closed'");
		
	КонецЕсли;
		
КонецПроцедуры

