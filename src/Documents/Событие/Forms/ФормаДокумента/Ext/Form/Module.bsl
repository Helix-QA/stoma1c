// Процедура, При изменение даты визита на сервере.
//
Процедура ПриИзменениеДатыВизитаНаСервере(НачалоПериода)
	
	Элементы.ПредставлениеВремяНачалаВизита.Заголовок = Формат(НачалоПериода, "ДЛФ=DD") + " (" + Формат(НачалоПериода, "ДФ=ддд") + ")";
	
	Для Каждого СтрокаТЧ Из Объект.Услуги Цикл
		СтрокаТЧ.ДатаНачала = НачалоДня(НачалоПериода) + (СтрокаТЧ.ДатаНачала - НачалоДня(СтрокаТЧ.ДатаНачала));
		СтрокаТЧ.ДатаОкончания = НачалоДня(НачалоПериода) + (СтрокаТЧ.ДатаОкончания - НачалоДня(СтрокаТЧ.ДатаОкончания));
	КонецЦикла;
	ДатаНачала = Дата(Год(НачалоПериода), Месяц(НачалоПериода), День(НачалоПериода), Час(ДатаНачала), Минута(ДатаНачала), Секунда(ДатаНачала));
	ДатаОкончания = Дата(Год(НачалоПериода), Месяц(НачалоПериода), День(НачалоПериода), Час(ДатаОкончания), Минута(ДатаОкончания), Секунда(ДатаОкончания));
	Объект.Дата = ДатаНачала; // НачалоПериода
	ЗаполнитьСписокВремениНачалаУслуг(Элементы.УслугиДатаНачалаПолем, 0);
	СоздатьДинамическиеЭлементыГруппыЗапись();
	
КонецПроцедуры	

