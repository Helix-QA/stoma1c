
#Область ОбработчикиСобытий

&НаКлиенте 
// Процедура, Обработчик события "ОбработкаКоманды"
//
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПечатнаяФорма = ПолучитьПечатнуюФормуМедКарты(ПараметрКоманды[0]);
	
	Если Не ЗначениеЗаполнено(ПечатнаяФорма) Тогда
		ТекстСообщенияОбОшибке = "У данного вида медицинской карты не заполено поле печатной формы!";
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияОбОшибке);
		Возврат;
	КонецЕсли;	
	
	ПечатнаяФормаОртодонтическогоПациента = Ложь; 
	Если ПечатнаяФорма = ПредопределенноеЗначение("Перечисление.ПечатныеФормыМедицинскихКарт.МедицинскаяКартаОртодонтическогоПациента") Тогда
		ПечатнаяФормаОртодонтическогоПациента = Истина;	
	КонецЕсли; 
	
	Если ПечатнаяФормаОртодонтическогоПациента = Ложь Тогда 	
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Справочник.МедицинскиеКарты", "ПечатьМедКарты", ПараметрКоманды, ПараметрыВыполненияКоманды.Источник, Неопределено);
	Иначе   
		ОткрытьФорму("Справочник.МедицинскиеКарты.Форма.ФормаОртодонтическогоПациента", Новый Структура("Ключ", ПараметрКоманды[0]), , Истина);						
	КонецЕсли; 
	
КонецПроцедуры   

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере 
// Функция, "ПолучитьПечатнуюФормуМедКарты" 
//
Функция ПолучитьПечатнуюФормуМедКарты(Ссылка)

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыМедицинскихКарт.ПечатнаяФорма КАК ПечатнаяФорма
	|ИЗ
	|	Справочник.МедицинскиеКарты КАК МедицинскиеКарты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыМедицинскихКарт КАК ВидыМедицинскихКарт
	|		ПО МедицинскиеКарты.ВидМедицинскойКарты = ВидыМедицинскихКарт.Ссылка
	|ГДЕ
	|	МедицинскиеКарты.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат ?(Выборка.Следующий(), Выборка.ПечатнаяФорма, Неопределено);
	
КонецФункции  

#КонецОбласти