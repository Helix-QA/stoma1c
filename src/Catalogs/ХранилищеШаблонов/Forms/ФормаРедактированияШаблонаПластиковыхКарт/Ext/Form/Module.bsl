// Обработчик кнопки добавления картинки
Процедура ДобавитьКартинку(Команда)
		
	ПолеШаблон            = ПолеТабличногоДокумента.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка);       
	Индекс                = ПолеТабличногоДокумента.Рисунки.Индекс(ПолеШаблон); 	
		
	ПолеТабличногоДокумента.Рисунки[Индекс].Расположить(ПолеТабличногоДокумента.Область("R2C2"));
	ПолеТабличногоДокумента.Рисунки[Индекс].Высота = 30;
	ПолеТабличногоДокумента.Рисунки[Индекс].Ширина = 30;
	ПолеТабличногоДокумента.Рисунки[Индекс].Линия  = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);

КонецПроцедуры

