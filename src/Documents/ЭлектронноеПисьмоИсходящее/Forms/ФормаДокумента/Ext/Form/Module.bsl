&НаКлиенте
Процедура СписокШаблоновВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если НЕ ПисьмоОтправлено Тогда
		ПриВыбореШаблона(ВыбраннаяСтрока, СтандартнаяОбработка);
	Иначе
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СписокШаблоновПриАктивизацииСтроки(Элемент)
	
	Документ = Элементы.ПолеПредпросмотраШаблона.Документ;
	
	Если Документ.readyState = "complete" Тогда
		Документ.body.innerHTML = ПолучитьТекстHTMLШаблона(Элемент.ТекущаяСтрока);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриВыбореШаблона(ВыбранныйШаблонПисьма, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранныйШаблонПисьма) <> Тип("СправочникСсылка.ШаблоныЭлектронныхПисем") Тогда
		
		Возврат;
		
	ИначеЕсли ВыбранныйШаблонПисьма.ЭтоГруппа Тогда
		
		СтандартнаяОбработка = Истина;
		Объект.ТекстHTML = "";
		
	Иначе
		
		СтандартнаяОбработка = Ложь;
		ВыбранныйШаблон = ВыбранныйШаблонПисьма;
		Объект.ТекстHTML = ВыбранныйШаблонПисьма.ТекстHTML;
		
		ОбработатьИзменяемыеЗначения();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеПредпросмотраШаблонаДокументСформирован(Элемент)
	
	Документ = Элементы.ПолеПредпросмотраШаблона.Документ;
	Документ.body.innerHTML = ПолучитьТекстHTMLШаблона(Элементы.СписокШаблонов.ТекущаяСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ВложенияПриАктивизацииСтроки(Элемент)
	
	ВыбраноВложение = Элемент.ТекущиеДанные <> Неопределено;
	
	// Элементы командной панели
	Элементы.ВложенияОткрытьВложение.Доступность = ВыбраноВложение;
	Элементы.ВложенияУдалитьВложение.Доступность = ?(ПисьмоОтправлено, Ложь, ВыбраноВложение);
	
	// Элементы контекстного меню
	Элементы.КонтекстноеМенюОткрытьВложение.Доступность = ВыбраноВложение;
	Элементы.КонтекстноеМенюУдалитьВложение.Доступность = ?(ПисьмоОтправлено, Ложь, ВыбраноВложение);
	
КонецПроцедуры

//////////////////////////////////////////////////////////////////////////////
// ОПЕРАЦИИ С ВЛОЖЕНИЯМИ ПИСЬМА

&НаСервере
// Процедура записывает вложения письма в зависимости от их расположения
//
Процедура ЗаписатьВложения()
	
	Для Каждого Стр Из Вложения Цикл
		
		Размер = 0;
		ИмяФайла = Стр.ИмяФайла;
		Письмо = Объект.Ссылка;
		
		Если Стр.Расположение = 4 Тогда
			// из временного хранилища
			Стр.Ссылка = УправлениеЭлектроннойПочтой.ЗаписатьВложениеЭлектронногоПисьмаИзВременногоХранилища(Письмо, Стр.ИмяФайлаНаКомпьютере, ИмяФайла, Размер);
			
		ИначеЕсли Стр.Расположение = 3 Тогда
			// из файла на сервере
			
		ИначеЕсли Стр.Расположение = 1 Тогда
			// из двоичных данных другого вложения
			
			Если ПереноситьВложения Тогда
				РаботаСФайламиВызовСервера.СкопироватьФайлВПриложенных(Стр.Ссылка, Объект.Ссылка);
			КонецЕсли;
			
		ИначеЕсли Стр.Расположение = 0 Тогда
			// перезаписать вложение
			
		КонецЕсли;
		
		Стр.Расположение = 0;
		
	КонецЦикла;	
	
	// Удалим удаленные вложения
	Для Каждого УдаленноеВложение Из УдаленныеВложения Цикл
		ОбъектВложение = УдаленноеВложение.Значение.ПолучитьОбъект();
		ОбъектВложение.Удалить();
	КонецЦикла;
	
КонецПроцедуры

