 
#Область ОбработчикиСобытийФормы 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если  ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	ЗначениеОтбора = Параметры.ВладелецПараметра;	
	Если ЗначениеОтбора <> ПланыВидовХарактеристик.ПараметрыОбследований.ПустаяСсылка() Тогда		
		ЭО                = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));	
		ЭО.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Владелец");
		ЭО.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭО.ПравоеЗначение = ЗначениеОтбора;
		ЭО.Использование  = Истина;	
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
		
КонецПроцедуры

#КонецОбласти