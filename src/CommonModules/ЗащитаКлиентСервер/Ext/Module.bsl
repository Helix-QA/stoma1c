
#Область СлужебныйПрограммныйИнтерфейс

// Функция получает значения запрашиваемых параметров из строки параметров,
// хранимых в константе
//
// ИмяПараметра - строка. Должна быть передана в таком виде, в котором она записывается в строке параметров:
// 				  "host" - имя компьютера для подключения; "port" - номер порта
//
Функция ПолучитьЗначениеИзСтрокиПараметровПодключения(ИмяПараметра, Разделитель = ";") Экспорт
	
	ИмяПараметра = ИмяПараметра + "=";
	СтрокаПараметров = ОбщегоНазначенияСтоматология.ПолучитьЗначениеКонстанты("ПараметрыСоединенияСЛК");
	
	// Обрезаем все что идет до нужного параметра
	СтрокаПараметров = Прав(СтрокаПараметров, СтрДлина(СтрокаПараметров) - (Найти(СтрокаПараметров, ИмяПараметра) - 1));
	
	// Обрезаем все что идет после нужного параметра
	КонецПараметра = Найти(СтрокаПараметров, Разделитель);
	Если КонецПараметра > 0 Тогда
		СтрокаПараметров = Лев(СтрокаПараметров, КонецПараметра);
	КонецЕсли;
	
	// Срезаем лишнее, оставляя только значение параметра
	ЗначениеПараметра = СтрЗаменить(СтрЗаменить(СтрокаПараметров, Разделитель, ""), ИмяПараметра, "");
	
	Если ИмяПараметра = "host=" Тогда
		Возврат ?(СокрЛП(ЗначениеПараметра) = "", "localhost", ЗначениеПараметра);
	ИначеЕсли ИмяПараметра = "port=" Тогда
		Возврат ?(СокрЛП(ЗначениеПараметра) = "", "9099", ЗначениеПараметра);
	КонецЕсли;
	
КонецФункции

// Возвращает Истина, если текст ошибки говорит о том,
// что имеет место несоответствие версий между СерверомСЛК и ВнешнейКомпонентой
//
Функция ЭтоОшибкаОНесоответствииВерсий(Знач ВходнойПараметр) Экспорт
	
	Если ТипЗнч(ВходнойПараметр) = Тип("Строка") Тогда
		ТекстОшибки = ВходнойПараметр;
	ИначеЕсли ТипЗнч(ВходнойПараметр) = Тип("Структура") Тогда
		ТекстОшибки = ВходнойПараметр.ТекстПредупреждения;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Если Найти(ТекстОшибки, "Версия сервера") <> 0 И Найти(ТекстОшибки, "не соответствует версии клиента") <> 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции //ЭтоОшибкаОРазныхВерсияхСервераСЛКИВнешнейКомпоненты

////////////////////////////////////////////////////////////////////////////////
//
// Функция ЭтоОшибкаОбОтсутствииСервера
//
// Описание: Возвращает Истина, если текст ошибки говорит о том,
// 			что на данном компьютере не обнаружен сервер СЛК
//
//
// Параметры
//			ВходнойПараметр - Структура, Строка - структура, возвращаемая функцией запуска СЛК или строка,
//							  содержащая текст ошибки.
//
// Возвращаемое значение: Булево
//
Функция ЭтоОшибкаОбОтсутствииСервера(Знач ВходнойПараметр) Экспорт
	
	Если ТипЗнч(ВходнойПараметр) = Тип("Строка") Тогда
		ТекстОшибки = ВходнойПараметр;
	ИначеЕсли ТипЗнч(ВходнойПараметр) = Тип("Структура") Тогда
		ТекстОшибки = ВходнойПараметр.ТекстПредупреждения;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Найти(ТекстОшибки, "Не обнаружен установленный сервер на") <> 0;
	
КонецФункции //ЭтоОшибкаОбОтсутствииСервера

#КонецОбласти
