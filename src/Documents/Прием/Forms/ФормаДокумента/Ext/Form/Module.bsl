// Процедура настройки группы результат проведения приема
//
Процедура НастройкаГруппыРезультатаСервер() 
	
	Если НЕ Элементы.ГруппаСсылкаНаНаправление.ПодчиненныеЭлементы.Количество() > 0 Тогда
		Элементы.ГруппаСанация.Видимость    = ФормаРезультатПриема = 1;
		Элементы.ГруппаПрофосмотр.Видимость = ФормаРезультатПриема = 2; 
