
#Область СлужебныйПрограммныйИнтерфейс

// Получает массив автозаполнений в файле
//  Параметры:Файл - ссылка на объект файла
//			ФайлОснование - файл, на основании которого был создан Файл. Ссылка на шаблон файла.
//			ВладелецФайла - ссылка на владельца файла, на основании которого следует производить подстановку данных
//  Возвращает:массив замен в формате "какое поле заменить"-"какую строку заменить"-"на что заменить"
Функция ПолучитьМассивАвтозаполненийШаблона(Файл, Шаблон, ВладелецФайла, ПоказзыватьПредупреждения = Истина) Экспорт
	
	СтрокаОшибки = "";
	МассивДанныеЗамен = Новый Массив;
	
	Для Каждого ДанныеДляЗамены Из Шаблон.ДанныеДляАвтозаполнения Цикл
			
		ДанныеВладельцаФайлаДляАвтозаполнения = Новый Структура("НомерСтроки, ТипЗаменяемойСтроки, ЗаменяемоеЗначение, ТипЗначенияЗамены, ЗначениеЗамены, ЗначениеЗаменыБезФормата, ТипЗаменыПустогоЗначения, ЗначениеЗаменыНезаполненного, КоличествоСимволовПрочерков");
		ЗаполнитьЗначенияСвойств(ДанныеВладельцаФайлаДляАвтозаполнения, ДанныеДляЗамены);
		ЗначениеРеквизита = Неопределено;
		
		Попытка
			Если ДанныеДляЗамены.ТипЗначенияЗамены = Истина И Лев(ДанныеДляЗамены.ЗначениеЗамены, 1) = """" И Прав(ДанныеДляЗамены.ЗначениеЗамены, 1) = """" Тогда
				ЗначениеРеквизита = Сред(ДанныеДляЗамены.ЗначениеЗамены, 2, СтрДлина(ДанныеДляЗамены.ЗначениеЗамены) - 1);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Истина Тогда
				Выражение = СтрЗаменить(ДанныеДляЗамены.ЗначениеЗамены, "Договоры", "ВладелецФайла");
				РезультатОбработки = Null;
				Выполнить(Выражение);
				Если РезультатОбработки = Null Тогда
					ВызватьИсключение("При выполнении выражения результат не был возвращен");
				Иначе 
					ЗначениеРеквизита = РезультатОбработки;
				КонецЕсли;
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ДопРеквизиты") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеДопРеквизитаДляЗамены(Файл, ДанныеДляЗамены.ЗначениеЗамены, ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ДопКонтактнаяИнформация") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеКонтактнаяИнформацияДляЗамены(Файл, ДанныеДляЗамены.ЗначениеЗамены, ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ДопУдостоверенияЛичности") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеДокументыФизическихЛицДляЗамены(Файл, ДанныеДляЗамены.ЗначениеЗамены, ВладелецФайла);				
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Номер договора") > 0 Тогда
				ЗначениеРеквизита = ПолучитьНомерБезПрефикса(Файл, ДанныеДляЗамены.ЗначениеЗамены, ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Дата договора") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "Договоры.Дата", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Врач") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "Договоры.Врач", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Автор документа") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "Договоры.АвторДокумента", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Комментарий") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "Договоры.Комментарий", ВладелецФайла);
			// --------------------------------------------------------------------------------ПАЦИЕНТ--------------------------------------------------------------------------------------					
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Фамилия") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.Фамилия", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Имя") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.Имя", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Отчество") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.Отчество", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ФИО") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.Наименование", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Дата рождения") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.ДатаРожденияКлиента", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пол") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.ПолКлиента", ВладелецФайла);	
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Телефон") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.Телефон", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Адрес") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьАдресКлиента(ВладелецФайла, "Контрагент");
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Паспортные данные") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьПаспортныеДанныеКлиента(ВладелецФайла, "Контрагент");
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Куратор") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.Куратор", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Номер мед. карты") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Емайл") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЕмайлКлиента(ВладелецФайла, "Контрагент"); 
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ИНН") > 0 И (Найти(ДанныеДляЗамены.ЗначениеЗамены, "Пациент") > 0 ИЛИ Найти(ДанныеДляЗамены.ЗначениеЗамены, "Клиент")) > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.Контрагент.ИНН", ВладелецФайла);
				
				// ------------------------------------------------------------------------ЗАКОННЫЙ ПРЕДСТАВИТЕЛЬ------------------------------------------------------------------------------	
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Фамилия") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.Фамилия", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Имя") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.Имя", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Отчество") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.Отчество", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ФИО") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.Наименование", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Дата рождения") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.ДатаРожденияКлиента", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Телефон") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.Телефон", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Адрес") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьАдресКлиента(ВладелецФайла, "ЗаконныйПредставитель");
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Паспортные данные") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьПаспортныеДанныеКлиента(ВладелецФайла, "ЗаконныйПредставитель");
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Куратор") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.Куратор", ВладелецФайла);
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Номер мед. карты") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.ТекущаяМедицинскаяКарта.КодБезНулей", ВладелецФайла);		
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Номер мед. карты") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЕмайлКлиента(ВладелецФайла, "ЗаконныйПредставитель"); 
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "ИНН") > 0 И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Законный представитель") > 0 Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, "ВладелецФайла.ЗаконныйПредставитель.ИНН", ВладелецФайла);
				
				// ------------------------------------------------------------------------ОРГАНИЗАЦИЯ------------------------------------------------------------------------------------------
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь И Найти(ДанныеДляЗамены.ЗначениеЗамены, "Организация") > 0 Тогда
				
				Если Найти(ДанныеДляЗамены.ЗначениеЗамены, "Наименование юр. лица") > 0 Тогда
					ЗначениеРеквизита = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаПоПути(ВладелецФайла,"СтруктурнаяЕдиница.Организация.ПолноеНаименование"); 
					ЗначениеРеквизита = ?(ЗначениеРеквизита = "",ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаПоПути(ВладелецФайла,"СтруктурнаяЕдиница.Организация.Наименование"),ЗначениеРеквизита); 
				Иначе
					ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполненияОрганизации(ДанныеДляЗамены.ЗначениеЗамены, ВладелецФайла);
				КонецЕсли;
				
				// -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------								
			ИначеЕсли ДанныеДляЗамены.ТипЗначенияЗамены = Ложь Тогда
				ЗначениеРеквизита = ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, ДанныеДляЗамены.ЗначениеЗамены, ВладелецФайла);
			КонецЕсли; 
			
			Если ПустаяСтрока(ЗначениеРеквизита) Тогда
				
				Если ДанныеВладельцаФайлаДляАвтозаполнения.ТипЗаменыПустогоЗначения Тогда
					
					ЗначениеРеквизита = СтрСоединить(Новый Массив(ДанныеВладельцаФайлаДляАвтозаполнения.КоличествоСимволовПрочерков + 1), "_");	
					
				Иначе 
					
					ЗначениеРеквизита = ДанныеВладельцаФайлаДляАвтозаполнения.ЗначениеЗаменыНезаполненного;
					
				КонецЕсли; 
				
			КонецЕсли;
				
		Исключение
			СтрокаОшибки = СтрокаОшибки + ДанныеДляЗамены.ЗначениеЗамены + 
			?(ИнформацияОбОшибке().Описание <> "", ", Ошибка: " + ИнформацияОбОшибке().Описание, "") + Символы.ВК;
		КонецПопытки;
		
		ДанныеВладельцаФайлаДляАвтозаполнения.ЗначениеЗамены = ?(ЗначениеЗаполнено(ДанныеДляЗамены.ФорматЗначенияЗамены), 
				Формат(ЗначениеРеквизита, ДанныеДляЗамены.ФорматЗначенияЗамены), Строка(ЗначениеРеквизита));
		ДанныеВладельцаФайлаДляАвтозаполнения.ЗначениеЗаменыБезФормата = ЗначениеРеквизита;
		МассивДанныеЗамен.Добавить(ДанныеВладельцаФайлаДляАвтозаполнения);
		
	КонецЦикла;
		
	// Если ЗначениеЗаполнено(СтрокаОшибки) И ПоказзыватьПредупреждения Тогда
	//	Сообщить("Следующие реквизиты правила автозаполнения заданы некорректно:" + Символы.ВК + СтрокаОшибки);
	// КонецЕсли;
	//
	Возврат МассивДанныеЗамен;
	
КонецФункции

// Возвращает двоичные данные файла
// Параметры:Файл - ссылка на файл, двоичные данные которого необходимо получить
Функция ПолучитьДвоичныеДанныеФайла(Файл) Экспорт
	
	Если Файл.ТекущаяВерсия.Пустая() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТекущаяВерсия = Файл.ТекущаяВерсия.ПолучитьОбъект();	
	Если ТекущаяВерсия.ТипХраненияФайла = Перечисления.ТипыХраненияФайлов.ВТомахНаДиске Тогда
    	Если НЕ ТекущаяВерсия.Том.Пустая() Тогда
        	ПолныйПуть = ФайловыеФункции.ПолныйПутьТома(ТекущаяВерсия.Том) + ТекущаяВерсия.ПутьКФайлу; 
            Попытка
            	ДвоичныеДанныеФайла = Новый ДвоичныеДанные(ПолныйПуть);
			Исключение
				ВызватьИсключение(НСтр("ru = 'Ошибка получения данных файла """ + Файл.Наименование + """.'"));
			КонецПопытки;
		Иначе
			ВызватьИсключение(НСтр("ru = 'Ошибка получения данных файла """ + Файл.Наименование + """.'"));
		КонецЕсли;
	ИначеЕсли ТекущаяВерсия.ТипХраненияФайла = Перечисления.ТипыХраненияФайлов.ВИнформационнойБазе Тогда
		ДвоичныеДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(ТекущаяВерсия.Ссылка).ДвоичныеДанные;
		// ДвоичныеДанныеФайла = ТекущаяВерсия.ФайлХранилище.Получить();
	Иначе
		ВызватьИсключение(НСтр("ru = 'Ошибка получения данных файла """ + Файл.Наименование + """.'"));
	КонецЕсли;
	
	Возврат ДвоичныеДанныеФайла;
	
КонецФункции

// Получает настройки, связанные с автозаполнением файлов
// Параметры:
//			ФайлСсылка - ссылка на объект типа Файл
//			Документ - ссылка на Вн, Вх или Исх документ - владелец файла
// Возвращает:
//			Структура
//				ДвоичныеДанныеФайла - двоичные данные последней версии файла
//				РасширениеФайла - расширение последней версии файла
//				МассивЗамен - массив структур в формате "какое поле заменить"-"какую строку заменить"-"на что заменить"
//				ОснованиеСозданияФайла - ссылка на файл-шаблон, если параметр ФайлСсылка был создан из шаблона	
 Функция ПолучитьНастройкиАвтозаполненияШаблоновФайлов(Знач ФайлСсылка, Знач Шаблон, Знач ВладелецФайла) Экспорт
	
	Если Шаблон = Неопределено Тогда
		Шаблон = ВладелецФайла.ШаблонДоговора;
	КонецЕсли;
	Если ФайлСсылка = Неопределено Тогда
		ФайлСсылка = Шаблон.ШаблонФайла;
	КонецЕсли;
		
	МассивЗамен = ПолучитьМассивАвтозаполненийШаблона(ФайлСсылка, Шаблон, ВладелецФайла);
	ДвоичныеДанныеФайла = ПолучитьДвоичныеДанныеФайла(ФайлСсылка);
	РасширениеФайла = ?(ФайлСсылка.ТекущаяВерсияРасширение = "", НРег(ФайлСсылка.Расширение), НРег(ФайлСсылка.ТекущаяВерсияРасширение));
		
	ДанныеВозврата = Новый Структура("ДвоичныеДанныеФайла, РасширениеФайла, МассивЗамен", ДвоичныеДанныеФайла, РасширениеФайла, МассивЗамен);
	
	Возврат ДанныеВозврата;
	
КонецФункции

