// Переопределяет стандартное представление ссылки.
//
Процедура ПолучитьПредставлениеДокумента(Источник, Данные, Представление, СтандартнаяОбработка) Экспорт
	
	Если // ПараметрыСеанса.ОбменДаннымиВключен = Истина
		 Данные.Номер = Null
		ИЛИ НЕ ЗначениеЗаполнено(Данные.Ссылка) Тогда
		
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Состояние = "";
	Если Данные.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)';en='(deleted)'");
	ИначеЕсли Данные.Свойство("Проведен") И НЕ Данные.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)';en='(not held)'");
	КонецЕсли;
			
	Если ТипЗнч(Источник) = Тип("ДокументМенеджер.ЧекКоррекции") и Данные.ЭтоСторно = Истина Тогда
		Состояние = Нстр("ru = '(сторно)'; en = '(storno)'") + Состояние;
	КонецЕсли;   
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru='%1 %2 от %3 %4';en=' %1 %2 from %3 %4'"),
		?(ЗначениеЗаполнено(Представление), Представление, Данные.Ссылка.Метаданные().Представление()),
		?(Данные.Свойство("Номер"), ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Данные.Номер, ""), ""),
		Формат(Данные.Дата, "ДЛФ=D"),
		Состояние);
	
КонецПроцедуры

// Переопределяет стандартное представление ссылки.
//
Процедура ПолучитьПредставлениеПолейСправочника(Источник, Поля, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	Поля.Добавить("Ссылка");
	Поля.Добавить("Наименование");
	Поля.Добавить("ПометкаУдаления");
	
КонецПроцедуры // ПолучитьПредставлениеДокумента()

// Переопределяет стандартное представление ссылки.
//
Процедура ПолучитьПредставлениеСправочника(Источник, Данные, Представление, СтандартнаяОбработка) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Данные.Ссылка) ИЛИ НЕ ЗначениеЗаполнено(Данные.Наименование) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Состояние = "";
	Если Данные.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)';en='(deleted)'");
	КонецЕсли;
		
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		?(ЗначениеЗаполнено(Состояние),НСтр("ru='%1 %2';en=' %1 %2'"), НСтр("ru='%1%2';en=' %1 %2'")),
		?(ЗначениеЗаполнено(Представление), Представление, Данные.Наименование),
		Состояние);
	
КонецПроцедуры // ПолучитьПредставлениеДокумента()

#КонецОбласти

