// Процедура - Заполнить реквизит вид взаимодействия справочник
//
Процедура ЗаполнитьРеквизитВидВзаимодействияСправочник() Экспорт
	
	Если НЕ ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП() Тогда 
		Возврат;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВидыВзаимодействий.Ссылка КАК Ссылка,
	|	ВидыВзаимодействий.Наименование КАК Наименование,
	|	ВидыВзаимодействий.ВидВзаимодействия КАК ВидВзаимодействия,
	|	ВидыВзаимодействий.Предопределенный КАК Предопределенный
	|ИЗ
	|	Справочник.ВидыВзаимодействий КАК ВидыВзаимодействий";
	
	ТаблицаВидовВзаимодействий = Запрос.Выполнить().Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗадачаИсполнителя.Ссылка КАК Ссылка,
	|	ЗадачаИсполнителя.БизнесПроцесс КАК БизнесПроцесс,
	|	ЗадачаИсполнителя.ТочкаМаршрута КАК ТочкаМаршрута,
	|	ЗадачаИсполнителя.ВидВзаимодействия КАК ВидВзаимодействия,
	|	ЗадачаИсполнителя.ВидВзаимодействияСправочник КАК ВидВзаимодействияСправочник,
	|	ВЫБОР
	|		КОГДА ЗадачаИсполнителя.Выполнена = ЛОЖЬ
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндексСортировки,
	|	ВЫБОР
	|		КОГДА ЗадачаИсполнителя.Дата < ЗадачаИсполнителя.ЗадачаНазначеннаяДата
	|			ТОГДА ЗадачаИсполнителя.Дата
	|		ИНАЧЕ ЗадачаИсполнителя.ЗадачаНазначеннаяДата
	|	КОНЕЦ КАК ДатаСортировки
	|ИЗ
	|	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИндексСортировки,
	|	ДатаСортировки УБЫВ";
	
	ВыборкаЗадача = Запрос.Выполнить().Выбрать();
	Пока ВыборкаЗадача.Следующий() Цикл 
		Если НЕ ЗначениеЗаполнено(ВыборкаЗадача.ВидВзаимодействияСправочник) И ЗначениеЗаполнено(ВыборкаЗадача.ВидВзаимодействия) Тогда
			МассивСтрок = ТаблицаВидовВзаимодействий.НайтиСтроки(Новый Структура("Предопределенный, ВидВзаимодействия", Истина, ВыборкаЗадача.ВидВзаимодействия));	
			Если НЕ МассивСтрок.Количество() = 0 Тогда 
				Задача_Объект 								= ВыборкаЗадача.Ссылка.ПолучитьОбъект();
				Задача_Объект.ВидВзаимодействияСправочник 	= МассивСтрок[0].Ссылка;
				Задача_Объект.ДополнительныеСвойства.Вставить("ЭтоОбновлениеИнформационнойБазы", Истина);
				Задача_Объект.ОбменДанными.Загрузка 		= Истина;				
				Попытка
					Задача_Объект.Записать();
				Исключение
					
				КонецПопытки;
			Иначе        
				МассивСтрок = ТаблицаВидовВзаимодействий.НайтиСтроки(Новый Структура("ВидВзаимодействия", ВыборкаЗадача.ВидВзаимодействия));
				Если НЕ МассивСтрок.Количество() = 0 Тогда 
					Задача_Объект 								= ВыборкаЗадача.Ссылка.ПолучитьОбъект();
					Задача_Объект.ВидВзаимодействияСправочник 	= МассивСтрок[0].Ссылка;
					Задача_Объект.ДополнительныеСвойства.Вставить("ЭтоОбновлениеИнформационнойБазы", Истина);
					Задача_Объект.ОбменДанными.Загрузка 		= Истина;
					Попытка
						Задача_Объект.Записать();
					Исключение
						
					КонецПопытки;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура, обновляет данные в регистре сведений "Контрагенты сведения для списка".
//
Процедура ОбновитьСведенияОЗадачахВРегистре(Контрагент) Экспорт
	
	Если Не ЗначениеЗаполнено(Контрагент) Тогда 
		Возврат;
	КонецЕсли;	
	
	ПоследняяЗадача = Неопределено;
	ПоследняяЗадачаПредставление = Неопределено;
	СледующаяЗадача = Неопределено;
	СледующаяЗадачаПредставление = Неопределено;
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Взаимодействие.Ссылка КАК ПоследняяЗадача,
	|	Взаимодействие.ЗадачаТема КАК ЗадачаТема,
	|	Взаимодействие.ЗадачаОписание КАК ЗадачаОписание,
	|	Взаимодействие.ДатаИсполнения КАК ДатаИсполнения
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Выполнена
	|	И Взаимодействие.Контрагент = &Контрагент
	|	И НЕ Взаимодействие.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Взаимодействие.ЗадачаНазначеннаяДата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Взаимодействие.Ссылка КАК СледующаяЗадача,
	|	Взаимодействие.ЗадачаТема КАК ЗадачаТема,
	|	Взаимодействие.ЗадачаОписание КАК ЗадачаОписание,
	|	Взаимодействие.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	НЕ Взаимодействие.Выполнена
	|	И Взаимодействие.Контрагент = &Контрагент
	|	И НЕ Взаимодействие.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Взаимодействие.ЗадачаНазначеннаяДата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтрагентыСведенияДляСписка.ПоследняяЗадача КАК ПоследняяЗадача,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача
	|ИЗ
	|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.Контрагент = &Контрагент");

	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ТаблицаПоследняяЗадача 	= ПакетЗапросов[0].Выгрузить();
	ТаблицаСледующаяЗадача 	= ПакетЗапросов[1].Выгрузить();
	ТаблицаТекущихЗадач 	= ПакетЗапросов[2].Выгрузить();
	
	БылиЗадачи = ЗначениеЗаполнено(ТаблицаТекущихЗадач) И (ЗначениеЗаполнено(ТаблицаТекущихЗадач[0].ПоследняяЗадача) ИЛИ ЗначениеЗаполнено(ТаблицаТекущихЗадач[0].СледующаяЗадача));
	ОбновитьДанныеВРегистре = Ложь;
	
	Если ТаблицаПоследняяЗадача.Количество() > 0 Тогда
		
		ОбновитьДанныеВРегистре = Истина;
		
		ПоследняяЗадача = ТаблицаПоследняяЗадача[0].ПоследняяЗадача;
		
		ПоследняяЗадачаТема = СокрЛП(ТаблицаПоследняяЗадача[0].ЗадачаТема);
		ПоследняяЗадачаОписание = СокрЛП(ТаблицаПоследняяЗадача[0].ЗадачаОписание);
		
		ПоследняяЗадачаПредставление = "" + ТаблицаПоследняяЗадача[0].ДатаИсполнения
										+ ?(ЗначениеЗаполнено(ПоследняяЗадачаТема), " " + ПоследняяЗадачаТема, "") 
										+ ?(ЗначениеЗаполнено(ПоследняяЗадачаОписание), " " + ПоследняяЗадачаОписание, "");
		
	КонецЕсли;
	
	Если ТаблицаСледующаяЗадача.Количество() > 0 Тогда
		
		ОбновитьДанныеВРегистре = Истина;
		
		СледующаяЗадача = ТаблицаСледующаяЗадача[0].СледующаяЗадача;
		
		СледующаяЗадачаТема = СокрЛП(ТаблицаСледующаяЗадача[0].ЗадачаТема);
		СледующаяЗадачаОписание = СокрЛП(ТаблицаСледующаяЗадача[0].ЗадачаОписание);
		
		СледующаяЗадачаПредставление = "" + ТаблицаСледующаяЗадача[0].ЗадачаНазначеннаяДата 
										+ ?(ЗначениеЗаполнено(СледующаяЗадачаТема), " " + СледующаяЗадачаТема, "") 
										+ ?(ЗначениеЗаполнено(СледующаяЗадачаОписание), " " + СледующаяЗадачаОписание, "");
		
	КонецЕсли;

	Если ОбновитьДанныеВРегистре ИЛИ БылиЗадачи Тогда
		
		ОбновляемыеДанные = Новый Структура;
		ОбновляемыеДанные.Вставить("ПоследняяЗадача"				, ПоследняяЗадача);
		ОбновляемыеДанные.Вставить("ПоследняяЗадачаПредставление"	, ПоследняяЗадачаПредставление);
		ОбновляемыеДанные.Вставить("СледующаяЗадача"				, СледующаяЗадача);
		ОбновляемыеДанные.Вставить("СледующаяЗадачаПредставление"	, СледующаяЗадачаПредставление);
		
		РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьНеобходимыеДанныеВСведенияхДляСписка(Контрагент, ОбновляемыеДанные);
		
	КонецЕсли;
			
КонецПроцедуры

// Процедура, обновляет данные в регистре сведений "Сделки сведения для списка".
//
Процедура ОбновитьЗадачиВРегистре(Сделка) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Сделка) Тогда
		Возврат;
	КонецЕсли;	
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
	|	Взаимодействие.Ссылка КАК ПоследняяЗадача
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Выполнена
	|	И НЕ Взаимодействие.ПометкаУдаления
	|	И Взаимодействие.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Взаимодействие.ЗадачаНазначеннаяДата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ 
	|	Взаимодействие.Ссылка КАК ЗапланированнаяЗадача
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	НЕ Взаимодействие.Выполнена
	|	И НЕ Взаимодействие.ПометкаУдаления
	|	И Взаимодействие.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Взаимодействие.ЗадачаНазначеннаяДата УБЫВ");
	
	Запрос.УстановитьПараметр("Сделка", Сделка);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ТаблицаПоследняяЗадача 		 = ПакетЗапросов[0].Выгрузить();
	ТаблицаЗапланированнаяЗадача = ПакетЗапросов[1].Выгрузить();
	
	НоваяЗапись = РегистрыСведений.СделкиСведенияДляСписка.СоздатьМенеджерЗаписи();
	НоваяЗапись.Сделка = Сделка;
	НоваяЗапись.Прочитать();
	
	// В случае если запись в регистре не обнаружена - создаем новую запись.
	Если Не НоваяЗапись.Выбран() Тогда
		НоваяЗапись.Сделка = Сделка;
	КонецЕсли;
	
	НоваяЗапись.ПоследняяЗадача 	  = ?(ТаблицаПоследняяЗадача.Количество() > 0, ТаблицаПоследняяЗадача[0].ПоследняяЗадача, Неопределено);
	НоваяЗапись.ЗапланированнаяЗадача = ?(ТаблицаЗапланированнаяЗадача.Количество() > 0, ТаблицаЗапланированнаяЗадача[0].ЗапланированнаяЗадача, Неопределено);
	
	Попытка
		НоваяЗапись.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось обновить данные в регистре, о задачах.';en='Not succeeded refresh data in the register about tasks.'"));
	КонецПопытки;
	
КонецПроцедуры

// Функция - Инициализировать реквизиты взаимодействия
//
// Параметры:
//  ЗадачаОбъект - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьРеквизитыВзаимодействия(ЗадачаОбъект) Экспорт 
	
	СтруктураЗадачи = Новый Структура;
	
	// Получим метаданные задачи
	МетаданныеЗадачи = ЗадачаОбъект.Метаданные();
	
	// Заполним стандартные реквизиты
	Для Каждого РеквизитЗадачи Из МетаданныеЗадачи.СтандартныеРеквизиты Цикл 
		СтруктураЗадачи.Вставить(РеквизитЗадачи.Имя, ЗадачаОбъект[РеквизитЗадачи.Имя]);
	КонецЦикла;
	
	// Заполним рукотворные реквизиты
	Для Каждого РеквизитЗадачи Из МетаданныеЗадачи.Реквизиты Цикл 
		СтруктураЗадачи.Вставить(РеквизитЗадачи.Имя, ЗадачаОбъект[РеквизитЗадачи.Имя]);
	КонецЦикла;
	
	// Заполним реквизиты адресации
	СтруктураЗадачи.Вставить(МетаданныеЗадачи.РеквизитыАдресации.Исполнитель.Имя, ЗадачаОбъект[МетаданныеЗадачи.РеквизитыАдресации.Исполнитель.Имя]);
	
	СтруктураЗадачи.Вставить("ЗадачаСсылка", ЗадачаОбъект.Ссылка);
	
	Возврат СтруктураЗадачи;
	
КонецФункции

// Функция - Инициализировать дополнительные свойства взаимодействия
//
// Параметры:
//  ЗадачаОбъект - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьДополнительныеСвойстваВзаимодействия(ЗадачаОбъект) Экспорт
	
	СтруктураДополнительныеСвойстваЗадачи = Новый Структура;
	
	// Заполним стандартные реквизиты
	Для Каждого ДополнительноеСвойство Из ЗадачаОбъект.ДополнительныеСвойства Цикл 
		СтруктураДополнительныеСвойстваЗадачи.Вставить(ДополнительноеСвойство.Ключ, ДополнительноеСвойство.Значение);
	КонецЦикла;
	
	Возврат СтруктураДополнительныеСвойстваЗадачи;	
	
КонецФункции

// Процедура, заполняет контрагента и сделку в задачах, связанных с заявкой.
//
Процедура ОбновитьЗадачиПоЗаявке(Заявка, Контрагент, Сделка) Экспорт
	
	Если Не (ЗначениеЗаполнено(Заявка) И ЗначениеЗаполнено(Контрагент)) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.Ссылка КАК Ссылка,
	|	Взаимодействие.Контрагент КАК Контрагент,
	|	Взаимодействие.Сделка КАК Сделка
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.ЗадачаПредмет = &Заявка
	|	И НЕ Взаимодействие.ПометкаУдаления
	|	И НЕ Взаимодействие.Выполнена");
	
	Запрос.УстановитьПараметр("Заявка", Заявка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Контрагент) И ЗначениеЗаполнено(Выборка.Сделка) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Выборка.Контрагент = Контрагент И Выборка.Сделка = Сделка Тогда
			Продолжить;
		КонецЕсли;
		
		ЗадачаОбъект			= Выборка.Ссылка.ПолучитьОбъект();
		ЗадачаОбъект.Контрагент	= Контрагент;
		ЗадачаОбъект.Сделка		= Сделка;
		
		Попытка
			ЗадачаОбъект.Записать();
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
		КонецПопытки;
		
	КонецЦикла;
	
	ОбновитьСведенияОЗадачахВРегистре(Контрагент);
	ОбновитьЗадачиВРегистре(Сделка);
	
КонецПроцедуры

// Проверяет есть ли у пользователя задачи.
//
Функция ПроверитьЕстьЛиУПользователяЗадачи(Пользователь) Экспорт
	
	Запрос = Новый Запрос(ТекстЗапросаНаПолучениеЗадачПользователя(1));
	
	Запрос.УстановитьПараметр("Исполнитель", Пользователь.Сотрудник);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, возвращает текст запроса.
//
Функция ТекстЗапросаНаПолучениеЗадачПользователя(КоличествоВыбираемыхЗадач = 50)
	
	Возврат СтрШаблон(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ %1
	|	Взаимодействие.Ссылка КАК Ссылка
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Выполнена = ЛОЖЬ
	|	И Взаимодействие.НапоминаниеИспользовать = ИСТИНА
	|	И Взаимодействие.ПометкаУдаления = ЛОЖЬ
	|	И Взаимодействие.Исполнитель В
	|			(ВЫБРАТЬ
	|				Сотрудники.Ссылка КАК Исполнитель
	|			ИЗ
	|				Справочник.Сотрудники КАК Сотрудники
	|			ГДЕ
	|				Сотрудники.Ссылка = &Исполнитель
	|		
	|			ОБЪЕДИНИТЬ ВСЕ
	|		
	|			ВЫБРАТЬ
	|				СоставСегментов.Сегмент
	|			ИЗ
	|				РегистрСведений.СоставСегментов КАК СоставСегментов
	|			ГДЕ
	|				СоставСегментов.ОбъектСегмента = &Исполнитель)
	|	И ВЫБОР
	|			КОГДА ГОД(Взаимодействие.НапоминаниеДатаНачала) <> 1
	|				ТОГДА ВЫБОР
	|						КОГДА &ТекущаяДата > Взаимодействие.НапоминаниеДатаНачала
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ЛОЖЬ
	|					КОНЕЦ
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ", КоличествоВыбираемыхЗадач);  		
	
КонецФункции

#КонецОбласти
