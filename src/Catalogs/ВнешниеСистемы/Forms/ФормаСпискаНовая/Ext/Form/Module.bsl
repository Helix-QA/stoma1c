// Функция, возвращает заголовок для группы раздела.
//
Функция ПолучитьЗаголовокРаздела(Раздел)
	
	Если Раздел = "МобильныеПриложения" Тогда
		Возврат НСтр("ru = 'Мобильные приложения'; en = 'Mobile applications'");
	ИначеЕсли Раздел = "ИсточникиЛидов" Тогда
		Возврат НСтр("ru = 'Источники лидов'; en = 'Sources of leads'");
	ИначеЕсли Раздел = "СквознаяАналитика" Тогда
		Возврат НСтр("ru = 'Сквозная аналитика'; en = 'End-to-end analytics'");
	ИначеЕсли Раздел = "ЭлектронныеКарты" Тогда
		Возврат НСтр("ru = 'Электронные карты'; en = 'Electronic cards'");
	ИначеЕсли Раздел = "ОнлайнЗапись" Тогда
		Возврат НСтр("ru = 'Онлайн-запись'; en = 'Online recording'");
	ИначеЕсли Раздел = "Мессенджеры" Тогда
		Возврат НСтр("ru = 'Мессенджеры'; en = 'Messengers'");
	ИначеЕсли Раздел = "Телефония" Тогда
		Возврат НСтр("ru = 'Телефония'; en = 'Telephony'");
	ИначеЕсли Раздел = "Прочее" Тогда
		Возврат НСтр("ru = 'Прочее'; en = 'Other'");
	Иначе
		Возврат Раздел;
	КонецЕсли;	
	
КонецФункции

