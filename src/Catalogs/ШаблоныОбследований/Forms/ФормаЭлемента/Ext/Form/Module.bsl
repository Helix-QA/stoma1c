// Процедура, обработчик события "HTMLВставитьТаблицуЗавершение"
//
Процедура HTMLВставитьТаблицуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	HTMLДокумент       = Элементы.HTMLШаблон.Документ;
	Если НЕ Результат = Неопределено Тогда
		НоваяТаблица             = СоздатьHTMLЭлемент("table");
		НоваяТаблица.width       = "" +Результат.РазмерПоШирине +"%";	
		НоваяТаблица.border      = Результат.ТолщинаЛиний; 
		НоваяТаблица.cellpadding = 0;
		НоваяТаблица.cellspacing = 0;
		НоваяТаблица.align       = "center";
		НоваяТаблица.borderColor = "black";
		Если Результат.ЗаголовокТаблицы <> "" Тогда		
			НоваяТаблица.createCaption();
			НоваяТаблица.caption.innerText = Результат.ЗаголовокТаблицы;		
		КонецЕсли;		
		Для ИндексСтроки = 1 По Результат.КолСтрок Цикл		
			НоваяСтрока = НоваяТаблица.insertRow();			
			Для ИндексСтолб = 1 По Результат.КолКолонок Цикл				
				НоваяЯчейка                = НоваяСтрока.insertCell();
				НоваяЯчейка.innerText      = Символы.НПП;
				НоваяЯчейка.width          = Строка(Окр(100/Результат.КолКолонок)) + "%";
				НоваяЯчейка.style.wordWrap = "break-word";				
			КонецЦикла;			
		КонецЦикла;		
		
		//HTMLОбластьВставки           = Элементы.HTMLШаблон.Документ.selection.createrange();
		//HTMLТекущийЭлемент           = Элементы.HTMLШаблон.Документ.elementFromPoint(HTMLОбластьВставки.offsetLeft, HTMLОбластьВставки.offsetTop);		
		//HTMLТекущийЭлемент.innerHTML = НоваяТаблица.outerHTML;	
		Выделение = HTMLДокумент.getSelection().getRangeAt(0);
		Узел = Выделение.createContextualFragment(НоваяТаблица.outerHTML);
		Выделение.insertNode(Узел);
	КонецЕсли;
	
КонецПроцедуры

