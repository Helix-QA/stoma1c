	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ДокументУдостоверяющийЛичность",	"Паспорт (XXXX XXXXXX, кем выдан, ДД.ММ.ГГГГ)", ОписаниеТиповСтрока200, ОписаниеТиповСтрока200);
	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ИсточникИнформации", "Рекламный источник", ОписаниеТиповСтрока100, ОписаниеТиповРекламныеИсточники);
	
	// ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Теги", "Теги*", ОписаниеТиповСтрока200, ОписаниеТиповСтрока200);
	
	// ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Заметки", "Заметки*", ОписаниеТиповСтрока200, ОписаниеТиповСтрока200);
	// ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ДатаЗаметки", "Дата заметки", ОписаниеТиповСтрока25, ОписаниеТиповДата);
	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НомерКарты", "Номер амбулаторной карты", ОписаниеТиповСтрока200, ОписаниеТиповСтрока200);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ВидМедицинскойКарты", "Вид медицинской карты", ОписаниеТиповСтрока100, ОписаниеТиповВидыМедицинскихКарт);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ДатаРегистрацииМедКарты", "Дата регистрации мед. карты", ОписаниеТиповСтрока100, ОписаниеТиповДатаВремя);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ДатаЗавершенияМедКарты", "Дата закрытия мед. карты", ОписаниеТиповСтрока100, ОписаниеТиповДатаВремя);
	                              
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Комментарий", "Комментарий", ОписаниеТиповСтрока200, ОписаниеТиповСтрока200);
	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "СтраховаяКомпания", "Страховая компания", ОписаниеТиповСтрока100, ОписаниеТиповКонтрагенты);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ТипПолиса", "Тип полиса", ОписаниеТиповСтрока100, ОписаниеТиповТипыПолиса);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "СерияПолиса", "Серия полиса", ОписаниеТиповСтрока100, ОписаниеТиповСтрока100);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НомерПолиса", "Номер полиса", ОписаниеТиповСтрока100, ОписаниеТиповСтрока100);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НачалоДействияПолиса", "Начало действия полиса", ОписаниеТиповСтрока100, ОписаниеТиповДатаВремя);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "КонецДействияПолиса", "Конец действия полиса", ОписаниеТиповСтрока100, ОписаниеТиповДатаВремя);
	
КонецПроцедуры

// Процедура - Сопоставить загружаемые данные из внешнего источника.
//
// Параметры:
//  ПараметрыСопоставления	 - 	 - 
//  АдресРезультата			 - 	 - 
//
Процедура СопоставитьЗагружаемыеДанныеИзВнешнегоИсточника(ПараметрыСопоставления, АдресРезультата) Экспорт
	
	ТаблицаСопоставленияДанных	= ПараметрыСопоставления.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	НастройкиЗагрузкиДанных		= ПараметрыСопоставления.НастройкиЗагрузкиДанных;
	ОбновлятьДанные				= НастройкиЗагрузкиДанных.ОбновлятьСуществующие;
	
	// ТаблицаСопоставленияДанных - Тип ДанныеФормыКоллекция
	Для каждого СтрокаТаблицыФормы Из ТаблицаСопоставленияДанных Цикл
		
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.Телефон, СтрокаТаблицыФормы.Телефон_ВходящиеДанные);
		Если ЗначениеЗаполнено(СтрокаТаблицыФормы.Телефон) Тогда
			МассивТелефонов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТаблицыФормы.Телефон, ",",Истина, Истина);
		КонецЕсли;
		
		// Контрагент 
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьКонтрагента(СтрокаТаблицыФормы.Клиент, СтрокаТаблицыФормы.Контрагент_КодСинхронизации, СтрокаТаблицыФормы.КонтрагентНаименование, МассивТелефонов, ПараметрыСопоставления.НастройкиЗагрузкиДанных.ПоискПоПолю);
		
		ЭтаСтрокаСопоставлена = ЗначениеЗаполнено(СтрокаТаблицыФормы.Клиент);
		
		// Родитель по наименованию
		ЗначениеПоУмолчанию = ПолучитьГруппуКлиенты();// Справочники.Контрагенты.ПустаяСсылка();
		ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Клиент, "Родитель", СтрокаТаблицыФормы.Родитель_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьРодителя("Контрагенты", СтрокаТаблицыФормы.Родитель, СтрокаТаблицыФормы.Родитель_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		// КИ (Юр. адрес, факт. адрес, адрес ЭП, телефон)
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.АдресФакт, СтрокаТаблицыФормы.АдресФакт_ВходящиеДанные);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.АдресЭП, СтрокаТаблицыФормы.АдресЭП_ВходящиеДанные);
		
		// Пол
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьПолФизическогоЛица(СтрокаТаблицыФормы.ПолКлиента, СтрокаТаблицыФормы.ПолКлиента_ВходящиеДанные);
		
		// ДатаРождения
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.Контрагент_ДатаРожденияКлиента, СтрокаТаблицыФормы.Контрагент_ДатаРожденияКлиента_ВходящиеДанные);
		
		// ДатаРегистрации
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.Контрагент_ДатаРегистрации, СтрокаТаблицыФормы.Контрагент_ДатаРегистрации_ВходящиеДанные);
		
		//// ДатаЗаметки
		// ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.ДатаЗаметки, СтрокаТаблицыФормы.ДатаЗаметки_ВходящиеДанные);
		
		// ДокументУдостоверяющийЛичность
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.ДокументУдостоверяющийЛичность, СтрокаТаблицыФормы.ДокументУдостоверяющийЛичность_ВходящиеДанные);
		
		// Комментарий
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.Комментарий, СтрокаТаблицыФормы.Комментарий_ВходящиеДанные);
		
		// Номер карты
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.НомерКарты, СтрокаТаблицыФормы.НомерКарты_ВходящиеДанные);
		
		// ВидМедицинскойКарты
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьВидМедицинскойКарты(СтрокаТаблицыФормы.ВидМедицинскойКарты, СтрокаТаблицыФормы.ВидМедицинскойКарты_ВходящиеДанные);
		
		// ДатаЗавершенияМедКарты
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.ДатаЗавершенияМедКарты, СтрокаТаблицыФормы.ДатаЗавершенияМедКарты_ВходящиеДанные);
		
		// Дата регистрации мед карты
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.ДатаРегистрацииМедКарты, СтрокаТаблицыФормы.ДатаРегистрацииМедКарты_ВходящиеДанные);
		
		
		// Полис страхования.
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьТипПолиса(СтрокаТаблицыФормы.ТипПолиса, СтрокаТаблицыФормы.ТипПолиса_ВходящиеДанные, Перечисления.ТипыПолиса.ДобровольноеМедицинскоеСтрахование);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.НачалоДействияПолиса, СтрокаТаблицыФормы.НачалоДействияПолиса_ВходящиеДанные);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.КонецДействияПолиса, СтрокаТаблицыФормы.КонецДействияПолиса_ВходящиеДанные);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.СерияПолиса, СтрокаТаблицыФормы.СерияПолиса_ВходящиеДанные);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.НомерПолиса, СтрокаТаблицыФормы.НомерПолиса_ВходящиеДанные);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьКонтрагента(СтрокаТаблицыФормы.СтраховаяКомпания,, СтрокаТаблицыФормы.СтраховаяКомпания_ВходящиеДанные,, 0);
		
		ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы);
		
		ЗагрузкаДанныхИзВнешнегоИсточника.ПрогрессСопоставленияДанных(ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицыФормы), РазмерТаблицыДанных);
		
	КонецЦикла;
	
	Если НастройкиЗагрузкиДанных.ПоискПоПолю = 0 Тогда // Сопоставляли по Наименованию
		ТаблицаСопоставленияДанных.Сортировать("КонтрагентНаименование");
	ИначеЕсли НастройкиЗагрузкиДанных.ПоискПоПолю = 1 Тогда // Сопоставляли по телефону

	Иначе  // по коду синхронизации
		ТаблицаСопоставленияДанных.Сортировать("Контрагент_КодСинхронизации");		
	КонецЕсли;	
	ПоместитьВоВременноеХранилище(ТаблицаСопоставленияДанных, АдресРезультата);
	
КонецПроцедуры

// Процедура - Проверить корректность данных в строке таблицы.
//
// Параметры:
//  СтрокаТаблицыФормы			 - 	 - 
//  ПолноеИмяОбъектаЗаполнения	 - 	 - 
//
Процедура ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения = "") Экспорт
	
	СтрокаТаблицыФормы._СтрокаСопоставлена = ЗначениеЗаполнено(СтрокаТаблицыФормы.Клиент);
	
	ИмяСлужебногоПоля = ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна();
	
	СтрокаТаблицыФормы[ИмяСлужебногоПоля] = СтрокаТаблицыФормы._СтрокаСопоставлена
											ИЛИ (НЕ СтрокаТаблицыФормы._СтрокаСопоставлена И НЕ ПустаяСтрока(СтрокаТаблицыФормы.КонтрагентНаименование));
	
КонецПроцедуры

// Процедура - Обработать подготовленные данные.
//
// Параметры:
//  СтруктураДанных				 - 	 - 
//  ФоновоеЗаданиеАдресХранилища - 	 - 
//
Процедура ОбработатьПодготовленныеДанные(СтруктураДанных, ФоновоеЗаданиеАдресХранилища = "") Экспорт
	
	НастройкиОбновленияСвойств	= СтруктураДанных.НастройкиЗагрузкиДанных.НастройкиОбновленияСвойств;
	ОбновлятьСуществующие		= СтруктураДанных.НастройкиЗагрузкиДанных.ОбновлятьСуществующие;
	СоздаватьЕслиНеСопоставлено = СтруктураДанных.НастройкиЗагрузкиДанных.СоздаватьЕслиНеСопоставлено;
	ПоискПоПолю 				= СтруктураДанных.НастройкиЗагрузкиДанных.ПоискПоПолю;
	ТаблицаСопоставленияДанных	= СтруктураДанных.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	КоличествоЗаписейТранзакции	= 0;
	ТранзакцияОткрыта			= Ложь;
	
	Попытка
		
		ЕстьДатаЗаметки = ТаблицаСопоставленияДанных.Колонки.Найти("ДатаЗаметки") <> Неопределено;
		Для каждого СтрокаТаблицы Из ТаблицаСопоставленияДанных Цикл
			
			Если НЕ ТранзакцияОткрыта 
				И КоличествоЗаписейТранзакции = 0 Тогда
				
				НачатьТранзакцию();
				ТранзакцияОткрыта = Истина;
				
			КонецЕсли;
			
			ЗагрузкаВПриложениеВозможна = СтрокаТаблицы[ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна()];
			
			СогласованноеСостояниеСтроки = (СтрокаТаблицы._СтрокаСопоставлена И ОбновлятьСуществующие) 
				ИЛИ (НЕ СтрокаТаблицы._СтрокаСопоставлена И СоздаватьЕслиНеСопоставлено);
			
			Если ЗагрузкаВПриложениеВозможна И СогласованноеСостояниеСтроки Тогда
				
				КоличествоЗаписейТранзакции = КоличествоЗаписейТранзакции + 1;
				
				Если СтрокаТаблицы._СтрокаСопоставлена Тогда
					ЭлементСправочника = СтрокаТаблицы.Клиент.ПолучитьОбъект();
					ПолКлиентаДоЗаполнения = ЭлементСправочника.ПолКлиента;
					// ЗаполнитьЗначенияСвойств(ЭлементСправочника, СтрокаТаблицы, НастройкиОбновленияСвойств.ИменаПолейОбновляемые, НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению);
					ЗаполнитьЗначенияСвойств(ЭлементСправочника, СтрокаТаблицы);
				Иначе
					ИндексТекущий = ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицы);
					Если ИндексТекущий > 0 Тогда 
						ПредыдущаяСтрока = ТаблицаСопоставленияДанных[ИндексТекущий - 1];
						Если ПоискПоПолю = 0 Тогда // Сопоставляли по Наименованию
							СоздаватьНовый = НЕ СокрЛП(СтрокаТаблицы.КонтрагентНаименование) = СокрЛП(ПредыдущаяСтрока.КонтрагентНаименование);  
						ИначеЕсли ПоискПоПолю = 1 Тогда // Сопоставляли по телефону
							СоздаватьНовый = Истина;
						Иначе  // по коду синхронизации
							СоздаватьНовый = НЕ СокрЛП(СтрокаТаблицы.Контрагент_КодСинхронизации) = СокрЛП(ПредыдущаяСтрока.Контрагент_КодСинхронизации);  
						КонецЕсли;	
					Иначе
						СоздаватьНовый 		= Истина;
						ПредыдущаяСтрока 	= Неопределено;
					КонецЕсли;
					
					Если СоздаватьНовый Тогда 
						ЭлементСправочника = Справочники.Контрагенты.СоздатьЭлемент();
						ЭлементСправочника.Заполнить(Новый Структура("ТекстЗаполнения, Родитель", СтрокаТаблицы.КонтрагентНаименование, СтрокаТаблицы.Родитель));
					Иначе 
						// ЭлементСправочника = ЭлементСправочника;
					КонецЕсли;	
					ЗаполнитьЗначенияСвойств(ЭлементСправочника, СтрокаТаблицы, , ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СтандартныеИменаПолейНеподлежащихОбновлению(СтруктураДанных.НастройкиЗагрузкиДанных));					
					
					// Если в excel файле указаны группы, туда и загружается.
					Если ЗначениеЗаполнено(СтрокаТаблицы.Родитель_ВходящиеДанные) Тогда  
						
						// Разбить строку на подстроки
						Группа = Неопределено;
						
						МассивСлов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(СтрокаТаблицы.Родитель_ВходящиеДанные, "|");
						РодительВерхнегоУровня = ?(ЗначениеЗаполнено(ЭлементСправочника.Родитель), ЭлементСправочника.Родитель, Неопределено);
						Для Каждого РодительНаименование Из МассивСлов Цикл
							
							Если ЗначениеЗаполнено(РодительНаименование) Тогда
								
								Группа = НайтиСоздатьГруппу(РодительНаименование, РодительВерхнегоУровня);
								РодительВерхнегоУровня = Группа;
								
							КонецЕсли;
							
						КонецЦикла;
						
						ЭлементСправочника.Родитель = Группа;
						
					КонецЕсли;
					
				КонецЕсли;
				
				// Код синхронизаци
				Если ЗначениеЗаполнено(СтрокаТаблицы.Контрагент_КодСинхронизации) Тогда
					ЭлементСправочника.КодСинхронизации = СтрокаТаблицы.Контрагент_КодСинхронизации;
				КонецЕсли;
				
				// Заполняем данные по контактой информации
				ЗаполнениеКонтактнойИнформации(СтрокаТаблицы, ЭлементСправочника);
				
				// Заполнение даты регистрации.
				Если ЗначениеЗаполнено(СтрокаТаблицы.Контрагент_ДатаРегистрации) Тогда
					ЭлементСправочника.ДатаРегистрации = СтрокаТаблицы.Контрагент_ДатаРегистрации;		
				КонецЕсли;
				
				// Дата рождения
				Если ЗначениеЗаполнено(СтрокаТаблицы.Контрагент_ДатаРожденияКлиента) Тогда
					ЭлементСправочника.ДатаРожденияКлиента = СтрокаТаблицы.Контрагент_ДатаРожденияКлиента;
				КонецЕсли;
							
				// Заполнение рекламного источника.			
				ЗаполнениеРекламногоИсточника(СтрокаТаблицы.ИсточникИнформации_ВходящиеДанные, ЭлементСправочника);
			
			//	// Заполнение таблицы Теги.
			//	ЗаполнениеТегов(СтрокаТаблицы.Теги_ВходящиеДанные, ЭлементСправочника);
				
				Если ЗначениеЗаполнено(СтрокаТаблицы.НомерКарты) Тогда
					
					Если ЗначениеЗаполнено(ЭлементСправочника.Ссылка) Тогда
						СсылкаНаКлиента = ЭлементСправочника.Ссылка;
					Иначе
						ЭлементСправочника.УстановитьСсылкуНового(Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор));		
						СсылкаНаКлиента = ЭлементСправочника.ПолучитьСсылкуНового();
					КонецЕсли;
					
					// Заполнение медицинской карты.
					МедКарта = ЗаполнитьМедицинскуюКарту(СтрокаТаблицы.НомерКарты, СтрокаТаблицы.ВидМедицинскойКарты, СтрокаТаблицы.ДатаРегистрацииМедКарты, СтрокаТаблицы.ДатаЗавершенияМедКарты, СсылкаНаКлиента, ЭлементСправочника.Наименование);
					ЭлементСправочника.ТекущаяМедицинскаяКарта = МедКарта;
					
				КонецЕсли;
				
				// При обновлении клиентов и при отсутствии данной колони в экселе перезатирает пол клиента на Неопределено.
				Если ПолКлиентаДоЗаполнения <> Неопределено Тогда
					Если ЭлементСправочника.ПолКлиента <> ПолКлиентаДоЗаполнения И НЕ ЗначениеЗаполнено(ЭлементСправочника.ПолКлиента) Тогда
						ЭлементСправочника.ПолКлиента = ПолКлиентаДоЗаполнения;
					КонецЕсли;
				КонецЕсли;
				
				// Запись нового клиента.
				ЭлементСправочника.Записать();					
				
				Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Клиент) Тогда 
					СтрокаТаблицы.Клиент = ЭлементСправочника.Ссылка;
				КонецЕсли;
				
			//	// Заполнение таблицы Заметки.
			//	ЗаполнениеЗаметок(СтрокаТаблицы, ЭлементСправочника.Ссылка, ЕстьДатаЗаметки);
							
				// Заполнение данных Паспорта	
				ЗаполнениеПаспортныхДанных(СтрокаТаблицы.ДокументУдостоверяющийЛичность, ЭлементСправочника.Ссылка);
				
				// Заполнение полисов страхования.
				СформироватьПолисыСтрахования(СтрокаТаблицы);

			КонецЕсли;
			
			ИндексТекущейстроки = ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицы) + 1;
			ТекстПрогресса      = СтрШаблон(НСтр("ru ='Обработано %1 из %2 строк...'"), ИндексТекущейстроки, РазмерТаблицыДанных);
			ПроцентВыполнения   = Окр(ИндексТекущейстроки * 100 / РазмерТаблицыДанных);
			
			ДлительныеОперации.СообщитьПрогресс(ПроцентВыполнения, ТекстПрогресса);
			
			Если ТранзакцияОткрыта
				И КоличествоЗаписейТранзакции > ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.МаксимумЗаписейВОднойТранзакции() Тогда
				
				ЗафиксироватьТранзакцию();
				ТранзакцияОткрыта = Ложь;
				КоличествоЗаписейТранзакции = 0;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ТранзакцияОткрыта 
			И КоличествоЗаписейТранзакции > 0 Тогда
			
			ЗафиксироватьТранзакцию();
			ТранзакцияОткрыта = Ложь;
			
		КонецЕсли;
		
	Исключение
		// Сообщить(ЭлементСправочника.Ссылка, ЭлементСправочника.КодСинхронизации);
		ЗаписьЖурналаРегистрации(Нстр("ru='Загрузка данных'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.Контрагенты, , ОписаниеОшибки());
		ОтменитьТранзакцию();
		
	КонецПопытки;
	
КонецПроцедуры

// Процедура - Заполнение паспортных данных.
//
// Параметры:
//  ДокументСтрокой			 - 	 - 
//  ЭлементСправочникаСсылка - 	 - 
//
Процедура ЗаполнениеПаспортныхДанных(ДокументСтрокой, ЭлементСправочникаСсылка)
	
	Если ЗначениеЗаполнено(ДокументСтрокой) Тогда
		МассивДанныхПаспорта = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ДокументСтрокой, ",");
		НомерСтрокиДанных = 1;
		Серия = "";
		Номер = "";
		КемВыдан = "";
		ДатаВыдачи = Дата(1,1,1);
		Для Каждого СтрокаДанных Из МассивДанныхПаспорта Цикл
			// Серия XXXX Код XXXXXX
			СтрокаДанных = СокрЛП(СтрокаДанных);
			Если НомерСтрокиДанных = 1 Тогда
				ПозицияПробела = Найти(СтрокаДанных, " ");
				Серия = Сред(СтрокаДанных, 1, ПозицияПробела);
				Если ЗначениеЗаполнено(Серия) Тогда 
					Номер = СтрЗаменить(СтрокаДанных, Серия, "");
				Иначе
					Номер = СтрокаДанных;
				КонецЕсли;	
				// Кем выдан
			ИначеЕсли НомерСтрокиДанных = 2 Тогда
				КемВыдан = СтрокаДанных;
				// Дата выдачи
			ИначеЕсли НомерСтрокиДанных = 3 Тогда
				ДатаВыдачи = ПривестиКТипуДата(СтрокаДанных);
				Если ДатаВыдачи = Неопределено Тогда					
					ДатаВыдачи = Дата(1,1,1);					
				КонецЕсли;
			КонецЕсли;
			НомерСтрокиДанных = НомерСтрокиДанных + 1;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(Серия) ИЛИ ЗначениеЗаполнено(Номер) ИЛИ ЗначениеЗаполнено(КемВыдан) ИЛИ ЗначениеЗаполнено(ДатаВыдачи) Тогда
			
			НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Физлицо.Установить(ЭлементСправочникаСсылка);
			ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ;
			НаборЗаписей.Отбор.ВидДокумента.Установить(ВидДокумента);
			НаборЗаписей.Прочитать();
			НаборЗаписей.Очистить(); 
			НаборЗаписей.Записать();
			СтрокаН = НаборЗаписей.Добавить();
			СтрокаН.Период = ТекущаяДата();
			СтрокаН.ВидДокумента = ВидДокумента;
			СтрокаН.Физлицо = ЭлементСправочникаСсылка; 
			СтрокаН.КемВыдан = КемВыдан;
			СтрокаН.Номер = Номер;
			СтрокаН.Серия = Серия;
			СтрокаН.ДатаВыдачи = ДатаВыдачи;
			СтрокаН.ЯвляетсяДокументомУдостоверяющимЛичность = Истина;
			// СтрокаН.Основной = Истина;
			СтрокаН.Представление = ""
			+ ВидДокумента
			+ ?(ЗначениеЗаполнено(Серия), Серия + " ", "")
			+ ?(ЗначениеЗаполнено(Номер), Номер + " ", "")
			+ ?(ЗначениеЗаполнено(КемВыдан), ", " + КемВыдан + " ", "")
			+ ?(ДатаВыдачи <> Дата(1,1,1), ", " + Строка(ДатаВыдачи) + " ", "");
			
			НаборЗаписей.Записать(Истина);		
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Заполнение рекламного источника.
//
// Параметры:
//  РекламныйИсточникСтрокой - 	 - 
//  ЭлементСправочника		 - 	 - 
//
Процедура ЗаполнениеРекламногоИсточника(РекламныйИсточникСтрокой, ЭлементСправочника)
	
	РекламныйИсточникСтрокой = СокрЛП(РекламныйИсточникСтрокой);
	Если ЗначениеЗаполнено(РекламныйИсточникСтрокой) Тогда 
		
		РекламныйИсточникСсылка = Справочники.РекламныеИсточники.ПолучитьРекламныйИсточник(РекламныйИсточникСтрокой);
		
		Если ЗначениеЗаполнено(РекламныйИсточникСсылка) Тогда
			Если ЗначениеЗаполнено(ЭлементСправочника.ИсточникИнформации) И РекламныйИсточникСсылка.ПометкаУдаления Тогда
			Иначе 	
				ЭлементСправочника.ИсточникИнформации = РекламныйИсточникСсылка;
			КонецЕсли;	
		Иначе 	
			
			НовыйРекламныйИсточник = Справочники.РекламныеИсточники.СоздатьЭлемент();
			НовыйРекламныйИсточник.Наименование = РекламныйИсточникСтрокой;
			НовыйРекламныйИсточник.Записать();
			
			ЭлементСправочника.ИсточникИнформации = НовыйРекламныйИсточник.Ссылка;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Заполнение тегов.
//
// Параметры:
//  ТегиСтрокой			 - 	 - 
//  ЭлементСправочника	 - 	 - 
//
Процедура ЗаполнениеТегов(ТегиСтрокой, ЭлементСправочника)
	
	Если ЗначениеЗаполнено(ТегиСтрокой) Тогда
		
		ЭлементСправочника.Теги.Очистить();
		МассивТеги = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ТегиСтрокой, ",");
		
		Для Каждого Тег Из МассивТеги Цикл
			
			НайденныйТег = Справочники.Теги.НайтиПоНаименованию(Тег); 
			Если НЕ ЗначениеЗаполнено(НайденныйТег) Тогда
				
				НовыйТег = Справочники.Теги.СоздатьЭлемент();
				НовыйТег.Наименование = СокрЛП(Тег);
				Попытка
					НовыйТег.Записать();
					НайденныйТег = НовыйТег.Ссылка;
				Исключение
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка при записи элемента справочника Теги. Строка: " + Тег + Символы.ПС + ОписаниеОшибки());	
				КонецПопытки;
			КонецЕсли;	
			
			СтрокаТег = ЭлементСправочника.Теги.Добавить();
			СтрокаТег.Тег = НайденныйТег;
			
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

// Процедура - Заполнение заметок.
//
// Параметры:
//  ЗаметкиСтрокой			 - 	 - 
//  ЭлементСправочникаСсылка - 	 - 
//
Процедура ЗаполнениеЗаметок(СтрокаТаблицы, ЭлементСправочникаСсылка, ЕстьДатаЗаметки = Ложь)
	
	ЗаметкиСтрокой = СтрокаТаблицы.Заметки_ВходящиеДанные;
	Если ЗначениеЗаполнено(ЗаметкиСтрокой) Тогда
		МассивЗаметки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ЗаметкиСтрокой, ",");
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Заметки.Объект КАК Объект,
		|	Заметки.АктивностьЗаметки КАК АктивностьЗаметки,
		|	Заметки.Автор КАК Автор,
		|	Заметки.ИД КАК ИД,
		|	Заметки.Заметка КАК Заметка,
		|	Заметки.Период КАК Период
		|ИЗ
		|	РегистрСведений.Заметки КАК Заметки
		|ГДЕ
		|	(ВЫРАЗИТЬ(Заметки.Объект КАК Справочник.Контрагенты)) = &Объект
		|	И ВЫРАЗИТЬ(Заметки.Заметка КАК СТРОКА(500)) В (&МассивЗаметки)";
		
		Запрос.УстановитьПараметр("МассивЗаметки", МассивЗаметки);
		Запрос.УстановитьПараметр("Объект"       , ЭлементСправочникаСсылка);
		
		ТаблицаЗаметкиКлиента = Запрос.Выполнить().Выгрузить();
		
		Для Каждого ТекстЗаметки Из МассивЗаметки Цикл
			
			СтруктураОтбора = Новый Структура();
			СтруктураОтбора.Вставить("Объект" , ЭлементСправочникаСсылка); 
			СтруктураОтбора.Вставить("Заметка", ТекстЗаметки); 
			
			Если ЕстьДатаЗаметки И ЗначениеЗаполнено(СтрокаТаблицы.ДатаЗаметки) Тогда 
				СтруктураПоиска = Новый Структура("Заметка, Период", ТекстЗаметки, СтрокаТаблицы.ДатаЗаметки);
			Иначе
				СтруктураПоиска = Новый Структура("Заметка", ТекстЗаметки);
			КонецЕсли;	
			НайденныеСтроки = ТаблицаЗаметкиКлиента.НайтиСтроки(СтруктураПоиска);
			
			Если НайденныеСтроки.Количество() > 0 Тогда						
				СтруктураОтбора.Вставить("АктивностьЗаметки", НайденныеСтроки[0].АктивностьЗаметки); 
				СтруктураОтбора.Вставить("Автор"			, НайденныеСтроки[0].Автор); 
				СтруктураОтбора.Вставить("Период"			, НайденныеСтроки[0].Период); 
				СтруктураОтбора.Вставить("ИД"				, НайденныеСтроки[0].ИД);
			Иначе
				СтруктураОтбора.Вставить("АктивностьЗаметки", Истина);
				СтруктураОтбора.Вставить("Автор"			, ПараметрыСеанса.ТекущийПользователь);
				СтруктураОтбора.Вставить("Период"			, ?(ЕстьДатаЗаметки И ЗначениеЗаполнено(СтрокаТаблицы.ДатаЗаметки), СтрокаТаблицы.ДатаЗаметки, ?(ЗначениеЗаполнено(СтрокаТаблицы.Контрагент_ДатаРегистрации), СтрокаТаблицы.Контрагент_ДатаРегистрации, ТекущаяДатаСеанса())));
				СтруктураОтбора.Вставить("ИД"				, Новый УникальныйИдентификатор);					
			КонецЕсли;
			
			ОбъектРегистрСведенийЗаметка = РегистрыСведений.Заметки.СоздатьНаборЗаписей();
			ОбъектРегистрСведенийЗаметка.ОбменДанными.Загрузка = Истина;
			
			ОбъектРегистрСведенийЗаметка.Отбор.ИД.Установить(СтруктураОтбора.ИД);
			ЗаполнитьЗначенияСвойств(ОбъектРегистрСведенийЗаметка.Добавить(), СтруктураОтбора);
			ОбъектРегистрСведенийЗаметка.Записать(Истина);
			
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

// Процедура - Заполнение номера карты.
//
// Параметры:
//  НомерКарты			 - 	 - 
//  ЭлементСправочника	 - 	 - 
//
Процедура ЗаполнениеНомераКарты(НомерКарты, ЭлементСправочника)
	
	Если ЗначениеЗаполнено(НомерКарты) Тогда
		
		КартаСсылка = Справочники.Карты.НайтиПоРеквизиту("КодКарты", НомерКарты);
		
		Если ЗначениеЗаполнено(КартаСсылка) Тогда
			КартаОбъект = КартаСсылка.ПолучитьОбъект();
		Иначе
			КартаОбъект = Справочники.Карты.СоздатьЭлемент();
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(КартаОбъект.ВладелецКарты) Тогда
			КартаОбъект.ВладелецКарты = ЭлементСправочника.Ссылка; 
			КартаОбъект.КодКарты = НомерКарты; 
			КартаОбъект.ТипКода = Перечисления.ВидыКарт.Магнитная;
			Если КартаОбъект.ДатаОткрытия = Дата(1,1,1) Тогда
				КартаОбъект.ДатаОткрытия = ТекущаяДата();
			КонецЕсли;
		КонецЕсли;
		
		СтрокаНаименования = ?(ЗначениеЗаполнено(НомерКарты), НомерКарты + ", ", "") + ЭлементСправочника.Наименование + " (Магнитная)";
		КартаОбъект.Наименование = СтрокаНаименования;

		// ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;
		КартаОбъект.Записать();
		// ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;
		
		Если Не ЗначениеЗаполнено(КартаОбъект.Ссылка) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка при записи карты клиента " + ЭлементСправочника.Наименование + " № " + НомерКарты + Символы.ПС + ОписаниеОшибки());	 
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Заполнение контактной информации.
//
// Параметры:
//  СтрокаТаблицы		 - 	 - 
//  ЭлементСправочника	 - 	 - 
//
Процедура ЗаполнениеКонтактнойИнформации(СтрокаТаблицы, ЭлементСправочника)
	
	Клиент_КонтактнаяИнформация = ЭлементСправочника.КонтактнаяИнформация;
	
	Если НЕ ПустаяСтрока(СтрокаТаблицы.АдресФакт) Тогда
		
		Объект_XDTO_Адрес = ПолучитьСтруктуру_XDTO(СтрокаТаблицы.АдресФакт, Перечисления.ТипыКонтактнойИнформации.Адрес);
		
		Если Объект_XDTO_Адрес <> Неопределено Тогда
			
			// Найти в КИ существующий Адрес
			Представление = Объект_XDTO_Адрес.Представление;
			
			НайденныеСтроки = Клиент_КонтактнаяИнформация.НайтиСтроки(Новый Структура("Представление, Тип", Представление, Перечисления.ТипыКонтактнойИнформации.Адрес));
			Если НайденныеСтроки.Количество() = 0 Тогда
				ЗаполнитьАдрес(ЭлементСправочника, Объект_XDTO_Адрес , Справочники.ВидыКонтактнойИнформации.АдресКлиента);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(СтрокаТаблицы.Телефон) Тогда  
				
		МассивТелефонов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТаблицы.Телефон, ",",Истина, Истина);
		Для Каждого Телефон Из МассивТелефонов Цикл  
			
			СписокПолей = Новый СписокЗначений;
			УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Телефон, СписокПолей);
			
			Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(СокрЛП(Телефон), Перечисления.ТипыКонтактнойИнформации.Телефон);
			
			Если Объект_XDTO_Телефон <> Неопределено Тогда
				
				// Найти в КИ существующий телефон
				// НомерТелефона = Объект_XDTO_Телефон.Состав.Номер;
				НомерТелефона = Объект_XDTO_Телефон.Состав.КодСтраны + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер;				
				НайденныеСтроки = Клиент_КонтактнаяИнформация.НайтиСтроки(Новый Структура("НомерТелефона, Тип", НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон));
				Если НайденныеСтроки.Количество() = 0 Тогда
					ЗаполнитьТелефон(ЭлементСправочника, Объект_XDTO_Телефон, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;	
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(СтрокаТаблицы.АдресЭП) Тогда
		
		МассивАдресЭП = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТаблицы.АдресЭП, ",",Истина, Истина);
		Для Каждого АдресЭП Из МассивАдресЭП Цикл 
			
			Объект_XDTO_Email = ПолучитьСтруктуру_XDTO(СокрЛП(АдресЭП), Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
			
			Если Объект_XDTO_Email <> Неопределено  Тогда
				
				// Найти в КИ существующий АдресЭлектроннойПочты
				Представление = Объект_XDTO_Email.Представление;
				
				НайденныеСтроки = Клиент_КонтактнаяИнформация.НайтиСтроки(Новый Структура("Представление, Тип", Представление, Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
				Если НайденныеСтроки.Количество() = 0 Тогда
					ЗаполнитьEmail(ЭлементСправочника, Объект_XDTO_Email, Справочники.ВидыКонтактнойИнформации.EmailКлиента);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;	
		
	КонецЕсли;

КонецПроцедуры

