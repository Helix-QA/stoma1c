&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора"
//
Процедура КонтрагентОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ВыбранноеЗначение = "СоздатьНовогоКлиента" Тогда		
		ДобавитьИВыбратьКонтрагента();
		ВыбранноеЗначение = Объект.ЗадачаПредмет;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "АвтоПодбор"
//
Процедура КонтрагентАвтоПодбор(Элемент, Текст, ДанныеВыбора, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если не ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
	ДанныеВыбора         = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(Текст, 10, Истина, Истина);
	ИскомыйКлиент		 = Текст;
	
КонецПроцедуры

&НаКлиенте
// Обработчик декорации создания  ПЗ на след. прием
//
Процедура ДекорацияПЗНаСледующийприемНажатие(Элемент)
	
	// Если предварительная запись еще не создана откр. форму создания
	Если НЕ ЗначениеЗаполнено(Объект.ПредварительнаяЗаписьНаСледующийПрием) Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент"              ,Объект.ЗадачаПредмет);
		ПараметрыФормы.Вставить("ИмяКонтрагента"          ,Объект.ВходящийЗвонокАбонент);
		ПараметрыФормы.Вставить("ТелефонКонтрагента"      ,Объект.ВходящийЗвонокНомерТелефона);
		ПараметрыФормы.Вставить("ЗакрытьПриСозданииЗаписи",Истина);
		
		ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаПредварительнойЗаписи");
		ОткрытьФорму(ИмяФормыПланировщика, ПараметрыФормы,,,,,Новый ОписаниеОповещения("ДекорацияПЗНаСледующийприемНажатиеЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	Иначе
		// Если предварительная запись создана открываем форму доккумента
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Объект.ПредварительнаяЗаписьНаСледующийПрием));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Телефонный номер обработка автоподбора
//
Процедура ТелефонАвтоПодбор(Элемент, Текст, ДанныеВыбора, Ожидание, СтандартнаяОбработка)
	
	Если не ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем список номеров и клиентов
	СписокНомеров = ПолучитьСписокТелефонныхНомеров(Текст);
	
	Если СписокНомеров.Количество() = 1 Тогда
		
		Объект.ВходящийЗвонокНомерТелефона = СписокНомеров[0].Значение.НомерТелефона;
		Объект.ВходящийЗвонокАбонент       = Строка(СписокНомеров[0].Значение.Клиент);
		Объект.ЗадачаПредмет               = СписокНомеров[0].Значение.Клиент;

	ИначеЕсли  СписокНомеров.Количество() > 1 Тогда

		ПоказатьВыборИзСписка(Новый ОписаниеОповещения("ТелефонАвтоПодборЗавершение", ЭтотОбъект), СписокНомеров, Элемент,СписокНомеров[0]);
		
    КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Телефон авто подбор завершение
//
// Параметры:
//  ВыбранноеЗначение		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ТелефонАвтоПодборЗавершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
		
	Если ВыбранноеЗначение <> Неопределено Тогда
		
		Объект.ВходящийЗвонокНомерТелефона = ВыбранноеЗначение.Значение.НомерТелефона;
		Объект.ВходящийЗвонокАбонент       = Строка(ВыбранноеЗначение.Значение.Клиент);
		Объект.ЗадачаПредмет               = ВыбранноеЗначение.Значение.Клиент;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти  

#Область ОбработчикКомандФормы

&НаКлиенте
// Процедура, обработчик события нажатие кнопки "ДобавитьКлиента"
//
Процедура ДобавитьКлиента(Команда)
	
	ОсновнаяПапкаКлиентов = Неопределено; 
	
	СписокФИО = ОбщегоНазначенияКлиент.СтрокаВСписок(Объект.ВходящийЗвонокАбонент," ");
	СтруктураЗаполнения = Новый структура;
	Для А = 0 По СписокФИО.Количество()-1 Цикл
		
		Если А = 0 Тогда
			СтруктураЗаполнения.Вставить("Фамилия",СписокФИО[А].Значение);
		ИначеЕсли А = 1 Тогда
			СтруктураЗаполнения.Вставить("Имя",СписокФИО[А].Значение);
		ИначеЕсли А = 2 Тогда
			СтруктураЗаполнения.Вставить("Отчество",СписокФИО[А].Значение);
		КонецЕсли;
		
	КонецЦикла;
			
	ГруппаКлиентов = ОбщегоНазначенияСтоматология.ВернутьГруппуКлиентов();  
	СтруктураЗаполнения.Вставить("Родитель", ?(ЗначениеЗаполнено(ГруппаКлиентов), ГруппаКлиентов, ГруппаКонтрагентов)); 
	  
	ОписаниеОповещения = Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтаФорма);
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", СтруктураЗаполнения,,,,, ОписаниеОповещения);   
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "ЗаписатьИЗакрыть"
//
Процедура ЗаписатьИЗакрыть(Команда)
	
	Отказ = ЭтаФорма.Записать();
	Если Отказ Тогда
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СпециальныеОбработчики

&НаКлиенте
// Обработчик открытия формы кэш списка вводимых значений
//
Процедура Подключаемый_ОбработчикКэшЛист(Элемент, ДанныеВыбора, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура("ИдентификаторПоля", ЭтаФорма.ИмяФормы + "." +Элемент.Имя); 
	
	ОткрытьФорму("ОбщаяФорма.ФормаРедактированияСохраняемыхЗначений",
	ПараметрыФормы,,,,,
	Новый ОписаниеОповещения("Подключаемый_ОбработчикКэшЛистЗавершение", ЭтотОбъект), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	// СохранениеВводимыхЗначенийКлиент.ОбработчикВызоваФормыРедактированияКэшСписка(Элемент,ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора банковского счета
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
