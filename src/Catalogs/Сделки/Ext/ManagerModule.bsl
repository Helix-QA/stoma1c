		Сделка_Объект.ВидСделки 				= ВидСделок__ПервичныйПовторныйПациент;
		Сделка_Объект.Наименование 				= СоздатьНаименованиеСделки(Сделка_Объект);		
		Сделка_Объект.НаименованиеСокращенное 	= ИнициализироватьСокращенноеНаименованиеСделки(Сделка_Объект
																								, 
																								, 
																								, 
																								, СтруктураНаименованияВида
																								, СтрокаДанныеСделки.ВрачНаименованиеСокращенное);	
		
		Если СтрокаДанныеСделки.ЭтапОтказаНомерЭтапа = 1 ИЛИ СтрокаДанныеСделки.ЭтапОтказаНомерЭтапа = 3 Тогда 
			Сделка_Объект.ЭтапОтказа = Этап1;			
		ИначеЕсли СтрокаДанныеСделки.ЭтапОтказаНомерЭтапа = 2 ИЛИ СтрокаДанныеСделки.ЭтапОтказаНомерЭтапа = 4 Тогда
			Если СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда 
				Сделка_Объект.ЭтапОтказа = Этап4;			
			Иначе 
				Сделка_Объект.ЭтапОтказа = Этап3;			
			   КонецЕсли;
		КонецЕсли;
		Если СтрокаДанныеСделки.ЭтапУспехаНомерЭтапа = 1 ИЛИ СтрокаДанныеСделки.ЭтапУспехаНомерЭтапа = 3 Тогда 
			Сделка_Объект.ЭтапУспеха = Этап1;			
		ИначеЕсли СтрокаДанныеСделки.ЭтапУспехаНомерЭтапа = 2 ИЛИ СтрокаДанныеСделки.ЭтапУспехаНомерЭтапа = 4 Тогда
			Если СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда 
				Сделка_Объект.ЭтапУспеха = Этап4;			
			Иначе 
				Сделка_Объект.ЭтапУспеха = Этап3;			
			   КонецЕсли;
		КонецЕсли;
		   
		ЗаписатьИзменениеСтатусаВПредварительнойЗаписи 	= Ложь;
		СтатусПредварительнойЗаписи 					= СтрокаДанныеСделки.Статус;
		ОчиститьЗапланированнуюЗапись 					= Ложь;
		Если СтрокаДанныеСделки.ЭтапСделкиНомерЭтапа = 1 ИЛИ (СтрокаДанныеСделки.ЭтапСделкиНомерЭтапа = 3 И ЗначениеЗаполнено(СтрокаДанныеСделки.СсылкаНаПрием)) Тогда 
			Сделка_Объект.ЭтапСделки = Этап1;			
		ИначеЕсли СтрокаДанныеСделки.ЭтапСделкиНомерЭтапа = 2 ИЛИ СтрокаДанныеСделки.ЭтапСделкиНомерЭтапа = 4 ИЛИ (СтрокаДанныеСделки.ЭтапСделкиНомерЭтапа = 3 И НЕ ЗначениеЗаполнено(СтрокаДанныеСделки.СсылкаНаПрием)) Тогда
			Если СтрокаДанныеСделки.ДатаПриема < ДатаНачалоДня
				И ((НЕ СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.ПриемНачат И НЕ СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.ПриемОкончен) ИЛИ НЕ ЗначениеЗаполнено(СтрокаДанныеСделки.СсылкаНаПрием)) Тогда
				Сделка_Объект.РезультатСделки 		= Перечисления.РезультатыСделок.Отказ;
				Сделка_Объект.ЭтапСделки 			= Справочники.ЭтапыСделок.Отказ;
				Сделка_Объект.ЭтапУспеха 			= Справочники.ЭтапыСделок.ПустаяСсылка();							
				Сделка_Объект.ДатаЗавершенияСделки 	= ?(ЗначениеЗаполнено(Сделка_Объект.ДатаЗавершенияСделки), Сделка_Объект.ДатаЗавершенияСделки, СтрокаДанныеСделки.ДатаПриема);				
				Если СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда 
					Сделка_Объект.ПричинаОтказа 	= ?(ЗначениеЗаполнено(Сделка_Объект.ПричинаОтказа), Сделка_Объект.ПричинаОтказа, ПричинаОтказа_КлиентОтказался);
				Иначе
					Сделка_Объект.ПричинаОтказа 	= ПричинаОтказа_КлиентНеПришел;
					Если НЕ СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся И ЗначениеЗаполнено(СтрокаДанныеСделки.ПредварительнаяЗапись) Тогда
						ЗаписатьИзменениеСтатусаВПредварительнойЗаписи = Истина;
						СтатусПредварительнойЗаписи = Перечисления.СтатусыСобытия.ПриемНеСостоялся;
					КонецЕсли;	
				КонецЕсли;
				ОчиститьЗапланированнуюЗапись 		= ЗначениеЗаполнено(СтрокаДанныеСделки.ЗапланированнаяПредварительнаяЗапись);
			ИначеЕсли ЗначениеЗаполнено(СтрокаДанныеСделки.СсылкаНаПрием) И СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда	
				Сделка_Объект.РезультатСделки 		= Перечисления.РезультатыСделок.Успех;
				Сделка_Объект.ЭтапСделки 			= Справочники.ЭтапыСделок.Успех;
				Сделка_Объект.ЭтапУспеха 			= Справочники.ЭтапыСделок.Успех;											
				Сделка_Объект.ДатаЗавершенияСделки 	= ?(ЗначениеЗаполнено(Сделка_Объект.ДатаЗавершенияСделки), Сделка_Объект.ДатаЗавершенияСделки, СтрокаДанныеСделки.ДатаПриема);				
				ОчиститьЗапланированнуюЗапись 		= ЗначениеЗаполнено(СтрокаДанныеСделки.ЗапланированнаяПредварительнаяЗапись);				
			Иначе 	
				Если СтрокаДанныеСделки.Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда 
					Сделка_Объект.ЭтапСделки 		= Этап4;			
				Иначе 
					Сделка_Объект.ЭтапСделки 		= Этап3;			
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ЗаписатьИзменениеСтатусаВПредварительнойЗаписи Тогда 
			Запись_Объект 				= СтрокаДанныеСделки.ПредварительнаяЗапись.ПолучитьОбъект();
			Запись_Объект.Статус 		= СтатусПредварительнойЗаписи;
		КонецЕсли;
			
		Если ОчиститьЗапланированнуюЗапись Тогда
			СтрокаДанныеСделки.ЗапланированнаяПредварительнаяЗапись = Документы.Событие.ПустаяСсылка();
			НаборЗаписей 				= РегистрыСведений.СделкиСведенияДляСписка.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Сделка.Установить(СтрокаДанныеСделки.Сделка);
			ЗаписьНабора 										= НаборЗаписей.Добавить();
			ЗаписьНабора.Сделка 								= СтрокаДанныеСделки.Сделка;
			ЗаписьНабора.ВидСделки 								= СтрокаДанныеСделки.ВидСделки;
			ЗаписьНабора.Номер 									= СтрокаДанныеСделки.Номер;
			ЗаписьНабора.ЗапланированнаяПредварительнаяЗапись 	= Документы.Событие.ПустаяСсылка();
			ЗаписьНабора.ЗапланированнаяЗадача 					= СтрокаДанныеСделки.ЗапланированнаяЗадача;
			ЗаписьНабора.ПоследняяЗадача 						= СтрокаДанныеСделки.ПоследняяЗадача;
			ЗаписьНабора.ПерваяДляВрача 						= СтрокаДанныеСделки.ПерваяДляВрача;
		КонецЕсли;

		НачатьТранзакцию();
		Попытка
			Если ЗаписатьИзменениеСтатусаВПредварительнойЗаписи Тогда 
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Запись_Объект);
			ИначеЕсли СтрокаДанныеСделки.РезультатСделки = Перечисления.РезультатыСделок.ПустаяСсылка() И СтрокаДанныеСделки.ЭтапСделкиНомерЭтапа = 3 И ЗначениеЗаполнено(СтрокаДанныеСделки.СсылкаНаПрием) Тогда 
				МассивСтрок = ТаблицаПриемов.НайтиСтроки(Новый Структура("Сделка", СтрокаДанныеСделки.Сделка));
				Для Каждого ЭлементКоллекции Из МассивСтрок Цикл 
					Если ЗначениеЗаполнено(ЭлементКоллекции.Прием) Тогда 
						Прием_Объект 		= ЭлементКоллекции.Прием.ПолучитьОбъект();
						Прием_Объект.Сделка = Справочники.Сделки.ПустаяСсылка();
						Попытка
							ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Прием_Объект);
						Исключение
							
						КонецПопытки;							
					КонецЕсли;	
				КонецЦикла;	
				МассивСтрок = ТаблицаЗаписей.НайтиСтроки(Новый Структура("Сделка", СтрокаДанныеСделки.Сделка));
				Для Каждого ЭлементКоллекции Из МассивСтрок Цикл 
					Если ЗначениеЗаполнено(ЭлементКоллекции.ПредварительнаяЗапись) Тогда 
						Запись_Объект 		= ЭлементКоллекции.ПредварительнаяЗапись.ПолучитьОбъект();
						Запись_Объект.Сделка = Справочники.Сделки.ПустаяСсылка();
						Попытка
							ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Запись_Объект);
						Исключение
							
						КонецПопытки;							
					КонецЕсли;	
				КонецЦикла;	
			КонецЕсли;
			Если ОчиститьЗапланированнуюЗапись Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			КонецЕсли;			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Сделка_Объект);
			ЗафиксироватьТранзакцию();			
		Исключение
			ОтменитьТранзакцию();
			ШаблонКомментария = НСтр("ru = 'Ошибка конвертации сделки ""%1"" 
			|по причине: %2'");
		
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																				, СтрокаДанныеСделки.Наименование
																				, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
									, УровеньЖурналаРегистрации.Ошибка
									, МетаданныеСправочника
									,
									, Комментарий);
		КонецПопытки;	
	КонецЦикла;
	
	// Удаляем вид сделки
	ВидСделка_Объект = ВидСделок__ПостоянныеПациенты.ПолучитьОбъект();
	ВидСделка_Объект.ИмяПредопределенныхДанных = "";
	ВидСделка_Объект.ПометкаУдаления = Истина;
	Попытка
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ВидСделка_Объект);
	Исключение
		МетаданныеСправочника = Метаданные.Справочники.ВидыСделок;		
		ШаблонКомментария = НСтр("ru = 'Ошибка деактивации вида сделки ""%1"" 
		|по причине: %2'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, ВидСделка_Объект.Наименование
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
								, УровеньЖурналаРегистрации.Ошибка
								, МетаданныеСправочника
								,
								, Комментарий);
	КонецПопытки;	
	
КонецПроцедуры

// Функция - Получить ранее созданные этапы
//
// Параметры:
//  ВидСделки	 - 	 - 
//  Удалены		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьРанееСозданныеЭтапы(ВидСделки, Удалены = Истина)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидСделки"		, ВидСделки);
	Запрос.УстановитьПараметр("ПометкаУдаления"	, Удалены);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сделки.ЭтапСделки КАК ЭтапСделки
	|ПОМЕСТИТЬ ТаблицаЭтапов
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сделки.ЭтапОтказа
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сделки.ЭтапУспеха
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка КАК Этап,
	|	ЭтапыСделок.Наименование КАК Наименование,
	|	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа,
	|	ЭтапыСделок.Предопределенный КАК Предопределенный
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаЭтапов.ЭтапСделки
	|			ИЗ
	|				ТаблицаЭтапов)
	|	И ЭтапыСделок.ПометкаУдаления = &ПометкаУдаления
	|	И ЭтапыСделок.ВидСделки = &ВидСделки
	|	И ЭтапыСделок.Предопределенный = ЛОЖЬ";
	
	Возврат Запрос.Выполнить().Выгрузить();	
	
КонецФункции

// Функция - Получить данные по сделкам для сквозной аналитики.
//
Функция ПолучитьДанныеПоСделкамДляСквознойАналитики(ТипВнешнейСистемы) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТипВнешнейСистемы) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтекИзмененийСтатусовСквознойАналитики.Объект КАК Объект,
	|	СтекИзмененийСтатусовСквознойАналитики.ВнешняяСистема КАК ВнешняяСистема,
	|	СтекИзмененийСтатусовСквознойАналитики.Статус КАК Статус,
	|	СтекИзмененийСтатусовСквознойАналитики.ЭтапСделки КАК ЭтапСделки,
	|	СтекИзмененийСтатусовСквознойАналитики.ДатаИзменения КАК ДатаИзменения
	|ПОМЕСТИТЬ ВТСтекССА
	|ИЗ
	|	РегистрСведений.СтекИзмененийСтатусовСквознойАналитики КАК СтекИзмененийСтатусовСквознойАналитики
	|ГДЕ
	|	СтекИзмененийСтатусовСквознойАналитики.ВнешняяСистема.ТипВнешнейСистемы = &ТипВнешнейСистемы
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Объект
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТСтекССА.Объект КАК Объект,
	|	ЕСТЬNULL(Сделки.Ссылка, ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)) КАК Сделка
	|ПОМЕСТИТЬ ВТСделкиИзСтекаССА
	|ИЗ
	|	ВТСтекССА КАК ВТСтекССА
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сделки КАК Сделки
	|		ПО (Сделки.Заявка = ВТСтекССА.Объект)
	|ГДЕ
	|	ВТСтекССА.Объект ССЫЛКА Справочник.Заявки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТСтекССА.Объект,
	|	Сделки.Ссылка
	|ИЗ
	|	ВТСтекССА КАК ВТСтекССА
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сделки КАК Сделки
	|		ПО (Сделки.Ссылка = ВТСтекССА.Объект)
	|			И (НЕ Сделки.ПометкаУдаления)
	|ГДЕ
	|	ВТСтекССА.Объект ССЫЛКА Справочник.Сделки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Сделка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТСтекССА.Объект КАК Объект,
	|	ВТСтекССА.ВнешняяСистема КАК ВнешняяСистема,
	|	ВТСтекССА.ВнешняяСистема.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВТСтекССА.Статус КАК Статус,
	|	ВТСтекССА.ДатаИзменения КАК ДатаИзменения,
	|	ЕСТЬNULL(ВТСтекССА.Объект.communication_id, 0) КАК communication_id,
	|	ЕСТЬNULL(ВТСтекССА.Объект.communication_type, 0) КАК communication_type,
	|	ЕСТЬNULL(Сделки.Ссылка, ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)) КАК Сделка,
	|	Сделки.Наименование КАК СделкаНаименование,
	|	Сделки.Код КАК СделкаКод,
	|	Сделки.ДатаСделки КАК СделкаДатаСделки,
	|	Сделки.Описание КАК СделкаОписание,
	|	Сделки.Заявка КАК Заявка,
	|	ЕСТЬNULL(Сделки.Прием.СуммаДокумента, 0) КАК ПриемСуммаДокумента,
	|	Сделки.СуммаСделки КАК СуммаСделки,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.Автор КАК СделкаАвтор,
	|	Сделки.Автор.Код КАК СделкаАвторКод,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.Контрагент.Наименование КАК КонтрагентНаименование,
	|	Сделки.Контрагент.НаименованиеПолное КАК КонтрагентНаименованиеПолное,
	|	Сделки.Контрагент.Код КАК КонтрагентКод,
	|	Сделки.Контрагент.ДатаРегистрации КАК КонтрагентДатаРегистрации,
	|	Сделки.Менеджер КАК Менеджер,
	|	Сделки.Менеджер.Наименование КАК МенеджерНаименование,
	|	Сделки.Менеджер.Код КАК МенеджерКод,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ВидСделки.Наименование КАК ВидСделкиНаименование,
	|	Сделки.ВидСделки.Код КАК ВидСделкиКод
	|ИЗ
	|	ВТСделкиИзСтекаССА КАК ВТСделкиИзСтекаССА
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтекССА КАК ВТСтекССА
	|		ПО ВТСделкиИзСтекаССА.Объект = ВТСтекССА.Объект
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сделки КАК Сделки
	|		ПО ВТСделкиИзСтекаССА.Сделка = Сделки.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаИзменения");
	
	Запрос.УстановитьПараметр("ТипВнешнейСистемы", ТипВнешнейСистемы);
	
	Возврат Запрос.Выполнить().Выгрузить();	
	
КонецФункции

// Функция - Получить таблицу истории изменений этапов сделки.
//
Функция ПолучитьТаблицуИсторииИзмененийЭтаповСделки(Сделка) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СделкиИсторияИзмененияЭтапов.Дата КАК Дата,
	|	СделкиИсторияИзмененияЭтапов.ПереходСЭтапа КАК ПереходСЭтапа,
	|	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап КАК ПереходНаЭтап,
	|	СделкиИсторияИзмененияЭтапов.ПереходСЭтапа.Наименование КАК ПереходСЭтапаНаименование,
	|	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап.Наименование КАК ПереходНаЭтапНаименование
	|ИЗ
	|	Справочник.Сделки.ИсторияИзмененияЭтапов КАК СделкиИсторияИзмененияЭтапов
	|ГДЕ
	|	СделкиИсторияИзмененияЭтапов.Ссылка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата");
	
	Запрос.УстановитьПараметр("Сделка", Сделка);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

