// Процедура - Сохранить новую длительность приема сервер
//
Процедура СохранитьИлиУдалитьДлительностиПриемаНаСервере(НоваяДлительность = Неопределено, УдаляемаяДлительность = Неопределено)
	
	Если НЕ УдаляемаяДлительность = Неопределено Тогда
		УдаляемыйЭлемент = Элементы.Найти("ГруппаВыводаКнопокДлительности_" + УдаляемаяДлительность);
