	ВыводитьБлокСкидки                	  = Ложь;   
	
	УстановитьПривилегированныйРежим(Истина);  
	
	ТекстHTML = 
	"<html>
	|<meta http-equiv='X-UA-Compatible' content='IE=8' <head>
	|<title></title>
	|<style type='text/css'>
	//|    .left_col { background-color: #ffffff; vertical-align: top; padding-top: 5px; width: 5%; }	
