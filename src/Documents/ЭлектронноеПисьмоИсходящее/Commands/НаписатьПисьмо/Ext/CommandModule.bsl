	 
#Область СлужебныеПроцедурыИФункции	 
	 
&НаСервере
Функция ПолучитьСтруктуруПараметровФормы(ПараметрСсылка)
	
	СтруктураПараметровФормы = Новый Структура;
	ПереноситьВложения = Ложь;
	
	Если ТипЗнч(ПараметрСсылка) = Тип("ДокументСсылка.ЭлектронноеПисьмоИсходящее") Тогда
		
		СтруктураПараметровФормы = Новый Структура("Предмет, Команда", ПараметрСсылка, "Переслать");
		ПереноситьВложения = Истина;
		
	ИначеЕсли ТипЗнч(ПараметрСсылка) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		СтруктураПараметровФормы = Новый Структура("Предмет, ЭтоГруппа", ПараметрСсылка, ПараметрСсылка.ЭтоГруппа);
			
	КонецЕсли;
	
	ЗначенияЗаполнения = Новый Структура("ЗначенияЗаполнения, ПереноситьВложения", СтруктураПараметровФормы, ПереноситьВложения);
	
	Возврат ЗначенияЗаполнения;
	
КонецФункции// ПолучитьСтруктуруПараметровФормы(ПараметрСсылка)

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыФормы = ПолучитьСтруктуруПараметровФормы(ПараметрКоманды);
	
	ОткрыватьФорму = Истина;
	
	Если ТипЗнч(ПараметрыФормы) = Тип("Структура") Тогда
		
		ЗначенияЗаполнения = Неопределено;
		
		Если ПараметрыФормы.Свойство("ЗначенияЗаполнения", ЗначенияЗаполнения) Тогда
			
			Если ТипЗнч(ЗначенияЗаполнения) = Тип("Структура") Тогда
				
				Если ЗначенияЗаполнения.Свойство("ЭтоГруппа") Тогда				
					
					ОткрыватьФорму = Не ЗначенияЗаполнения.ЭтоГруппа;
					
				КонецЕсли;
			
			КонецЕсли;		
		
		КонецЕсли;
		
	КонецЕсли;	
	
	Если ОткрыватьФорму Тогда
			
		ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.ФормаОбъекта", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти