// Процедура - Обновить все отборы формы
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//
Процедура ОбновитьВсеОтборыФормы(ПараметрыОтбора)
	
	МассивИменМеню = Новый Массив();
	МассивИменМеню.Добавить("МенюОтборСтатусЗадачи");
	МассивИменМеню.Добавить("МенюОтборВидВзаимодействия");
	МассивИменМеню.Добавить("МенюОтборЭтап");
	МассивИменМеню.Добавить("МенюОтборИсполнитель");
	МассивИменМеню.Добавить("МенюОтборКтоВыполнил");
	МассивИменМеню.Добавить("МенюОтборКонтрагенты");
	МассивИменМеню.Добавить("МенюОтборСделки");
	
	УправлениеИнтерфейсамиСервер.СнятьВыборВДинамическомМенюФормы(ЭтаФорма, МассивИменМеню);
	Если ТипЗнч(ПараметрыОтбора) = Тип("Структура") И ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборИсполнитель", ПараметрыОтбора.МассивМенеджеров, Истина);
	КонецЕсли;	
	Если ТипЗнч(ПараметрыОтбора) = Тип("Структура") И ПараметрыОтбора.Свойство("МассивСтатусовЗадач") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборСтатусЗадачи", ПараметрыОтбора.МассивСтатусовЗадач, Истина);
	КонецЕсли;		
	ПолучитьЗначенияОтборов();
	
КонецПроцедуры

