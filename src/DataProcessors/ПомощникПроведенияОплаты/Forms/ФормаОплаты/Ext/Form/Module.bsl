// Процедура - Обработчик нажатия кнопка представление суммы
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ОбработчикНажатияКнопкаПрименитьРедактированиеСуммы(Элемент)

	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	
	ПолеВвода = ВидыОплатСтрокаПолеВводаСуммы(ПрефиксПоля);
	
	ТекущиеДанные = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	
	Если ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат") Тогда
		ЗавершитьВводСерииСертификата(ПолеВвода);
	ИначеЕсли ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет") Тогда
		ЗавершитьВводВидаЛицевогоСчета(ПолеВвода);	
	Иначе	
		ЗавершитьРедактированиеПоляВводаСуммы(ПолеВвода);
	КонецЕсли;

КонецПроцедуры

// Процедура - Обработчик нажатия кнопка удалить сумму
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ОбработчикНажатияКнопкаУдалитьСумму(Элемент)

	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	
	ТекущиеДанные = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	ТекущиеДанные.Внесено             = 0;
    ТекущиеДанные.ОплачиваемаяСумма   = 0;
	ТекущиеДанные.ВводСерииСертификата = Неопределено;
    ТекущиеДанные.Сертификат           = Неопределено;	
    ТекущиеДанные.СертификатПартия     = Неопределено;
	
	ПолеВвода = ВидыОплатСтрокаПолеВводаСуммы(ПрефиксПоля);
	
	ЗавершитьРедактированиеПоляВводаСуммы(ПолеВвода);
			
КонецПроцедуры

&НаКлиенте
// Процедура - Проверить возможность оплаты СБП
//
Процедура ПроверитьВозможностьОплатыСБП(СтрокаВыбраннойОплаты, Элемент)
	
	ЭтоВозврат = ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Возврат");
	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	ПолеРедСуммы = ВидыОплатСтрокаПолеВводаСуммы(ПрефиксПоля);
	
	Если Не ЗначениеЗаполнено(СтрокаВыбраннойОплаты.Контрагент) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Клиент не заполнен");
		Возврат;
	КонецЕсли;
		
	Если ЭтотОбъект.ОплатаСумма = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сумма для оплаты равна нулю");
		Возврат;
	КонецЕсли;          
		
	СтруктураПараметров = ПолучитьПараметрыДляПроверки(СтрокаВыбраннойОплаты.ЭквайринговыйТерминал);
	
	Если СтруктураПараметров.МассивЗадолженностей.Количество() = 0 И Не ЭтоВозврат Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет выбранных документов задолженности");
		Возврат;
	КонецЕсли;
			
	Если СтруктураПараметров.СсылкаСформированаПоДругомуШлюзу Тогда 		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураПараметров.ОписаниеОшибки);
		Возврат;				
	КонецЕсли;
	
	Если ЭтоВозврат Тогда
		СтрокаВыбраннойОплаты.Внесено = СтрокаВыбраннойОплаты.МаксСуммаСписания;
		ЗавершитьРедактированиеПоляВводаСуммы(ПолеРедСуммы);	
	ИначеЕсли СтруктураПараметров.СсылкаПолучена Тогда	
		ОткрытьФормуСБП(СтруктураПараметров);		
	Иначе
		ВводСуммыОплаты(Элемент);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Получить параметры для проверки
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыДляПроверки(СбпЭквайринговыйТерминал)
	
	ДокументыЗадолженности = Новый Массив;
	Для Каждого СтрокаТЧ из ТаблицаЗадолженностей Цикл
		Если СтрокаТЧ.ПризнакВыбора Тогда
			ДокументыЗадолженности.Добавить(СтрокаТЧ.ДокументЗадолженности);
		КонецЕсли;		
	КонецЦикла;
	
	Выборка			= РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьСсылкуНаОплату(ДокументыЗадолженности, СбпЭквайринговыйТерминал);
	СсылкаПолучена	= Выборка <> Неопределено;			
	СсылкаСформированаПоДругомуШлюзу = СсылкаПолучена И Выборка.СсылкаЭТ <> СбпЭквайринговыйТерминал;
	
	ОписаниеОшибки	= "";
	Если СсылкаСформированаПоДругомуШлюзу Тогда
		ОписаниеОшибки = СтрШаблон("Ссылка уже сформирована по эквайринговому терминалу: %1, для продажи: %2. 
		|Необходимо либо отменить существующую ссылку либо выбрать другую продажу", Выборка.ЭквайринговыйТерминал, Выборка.Основание);
	КонецЕсли;
			
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("МассивЗадолженностей"				, ПолучитьМассивВыбранныхЗадолженностей());
	СтруктураПараметров.Вставить("ТипБанка"							, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СбпЭквайринговыйТерминал, "ТипБанка"));	
	СтруктураПараметров.Вставить("СсылкаСформированаПоДругомуШлюзу"	, СсылкаСформированаПоДругомуШлюзу);
	СтруктураПараметров.Вставить("ОписаниеОшибки"                   , ОписаниеОшибки);
	СтруктураПараметров.Вставить("СсылкаПолучена"                   , СсылкаПолучена);
	СтруктураПараметров.Вставить("НомерЗаказа"                   	, ?(СсылкаПолучена, Выборка.НомерЗаказа, Неопределено));
	  
	Возврат СтруктураПараметров;
	
КонецФункции

&НаСервере
// Функция - Получить массив выбранных задолженностей
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивВыбранныхЗадолженностей()
	
	МассивСтрок = ПолучитьВыбранныеСтрокиДереваЗадолженностиСервер();
	
	МассивЗадолженностей = Новый Массив;
	Для Каждого СтрокаТЧ из МассивСтрок Цикл
					
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ДокументЗадолженности", СтрокаТЧ.ДокументЗадолженности);
		СтруктураПараметров.Вставить("Задолженность"		, СтрокаТЧ.Задолженность);
		СтруктураПараметров.Вставить("Оплачено"				, СтрокаТЧ.Оплачено);
		СтруктураПараметров.Вставить("СуммаДокумента"		, СтрокаТЧ.СуммаДокумента);
		
		МассивЗадолженностей.Добавить(СтруктураПараметров);		
		
	КонецЦикла;
	
	Возврат МассивЗадолженностей;
	
КонецФункции

&НаКлиенте
// Процедура - Открыть форму СБП
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
//
Процедура ОткрытьФормуСБП(СтруктураПараметров)
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораСБП", ЭтотОбъект, СтруктураПараметров);
	ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОтправкиПлатежейСБП", СтруктураПараметров,,,,, ОписаниеОповещения);	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора СБП
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыбораСБП(Результат, ДополнительныеПараметры) Экспорт	
	
	РезультатПолучен = Результат <> Неопределено;
		
	Если РезультатПолучен И Результат.ОбновитьИнформациюОСсылкахНаОплату И Не Результат.ОтменаСсылки И ЭтаФорма.Открыта() Тогда
		
		ПреобразоватьДокументыРеализацииПослеОплатыПоСБП(ДополнительныеПараметры);
	
		ЭтаФорма.Закрыть(Новый Структура("ОперацияВыполнена, ОплатаВыполнена", Истина, Истина));	
		
	ИначеЕсли ТекущееПолеВводаСБП <> Неопределено Тогда	
		
		ОбработчикНажатияКнопкаУдалитьСумму(ТекущееПолеВводаСБП);
		
	КонецЕсли;
				
КонецПроцедуры

&НаСервере
// Процедура - Преобразовать документы реализации после оплаты по СБП
//
// Параметры:
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПреобразоватьДокументыРеализацииПослеОплатыПоСБП(ДополнительныеПараметры)

	МассивСтрокОплатыБонусами = ПолучитьСтрокиСВнесеннойОплатойСервер(Перечисления.ТипыДенежныхСредств.БонусныйСчет);
	Если МассивСтрокОплатыБонусами.Количество() = 0 Тогда // При смешанной оплате бонусными счетами
		Возврат;
	КонецЕсли; 
	
	МассивЗадолженностей      = ДополнительныеПараметры.МассивЗадолженностей;
	СуммаОплаты               = ДополнительныеПараметры.СуммаОплаты;
	МассивСтрокОплатыБонусами = ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(МассивСтрокОплатыБонусами,"Контрагент,ОплачиваемаяСумма,БонусныйСчет");	
	
	МассивРедактируемыхРеализаций = Новый Массив;
	
	//Главный цикл перебора оплачиваемых документов
	Для Каждого СтрокаЗадолженности ИЗ МассивЗадолженностей Цикл			
		Если СтрокаЗадолженности.Задолженность > 0 Тогда			
			
			ДокументЗадолженности = СтрокаЗадолженности.ДокументЗадолженности;
			РеализацияОбъект      = ДокументЗадолженности.ПолучитьОбъект();	
			
			ИмяТЧ = ВернутьИмяТабличнойЧастиДляНачисленияБонусов(РеализацияОбъект);
			 
			Если ИмяТЧ = "" Тогда
				Продолжить;		
			КонецЕсли; 
			
			// Списание суммы, оплачиваемой по СБП 
			ОстатокЗадолженности  = ?(СтрокаЗадолженности.Задолженность > СуммаОплаты, СтрокаЗадолженности.Задолженность - СуммаОплаты, 0);
			СуммаОплаты           = ?(СтрокаЗадолженности.Задолженность < СуммаОплаты, СуммаОплаты - СтрокаЗадолженности.Задолженность, 0);

			Если ОстатокЗадолженности > 0 И СуммаОплаты = 0 Тогда 
				//Цикл перебора видов оплаты
				Для Каждого СтрокаОплаты ИЗ МассивСтрокОплатыБонусами Цикл				
						
					//Если вид оплаты содержит средства для оплаты
					Если ОстатокЗадолженности > 0 
						И СтрокаОплаты.ОплачиваемаяСумма > 0 Тогда					
						
						ОстатокСуммыПлатежа  = ?(СтрокаОплаты.ОплачиваемаяСумма >= ОстатокЗадолженности, ОстатокЗадолженности, СтрокаОплаты.ОплачиваемаяСумма);
						
						СуммаДоступнаяДляОплатыБонуснымСчетом = УправлениеМаркетинговымиАкциями.ПолучитьСуммуДоступнуюДляОплатыБонуснымСчетомВРеализацииПриеме(ДокументЗадолженности, СтрокаОплаты.БонусныйСчет);
						ДоступноКОплате = ?(ОстатокСуммыПлатежа > СуммаДоступнаяДляОплатыБонуснымСчетом, СуммаДоступнаяДляОплатыБонуснымСчетом, ОстатокСуммыПлатежа);
						
						СтрокаТЧ 					  = РеализацияОбъект.СкидкиНаценки.Добавить();
						СтрокаТЧ.БонусныйСчет  		  = СтрокаОплаты.БонусныйСчет;
						СтрокаТЧ.Использование 		  = Истина;
						СтрокаТЧ.КлючСтроки	   		  = РеализацияОбъект[ИмяТЧ][0].КлючСтроки;
						СтрокаТЧ.Контрагент	   		  = СтрокаОплаты.Контрагент;
						СтрокаТЧ.НоменклатураСкидки   = РеализацияОбъект[ИмяТЧ][0].Номенклатура;
						СтрокаТЧ.ПризнакОплатыБонусом = Истина;
						СтрокаТЧ.Сумма				  = ДоступноКОплате;
						
						Обработки.ПомощникПроведенияОплаты.ПересчитатьМаркетинговыеАкцииСтарая(РеализацияОбъект);							
						
						ОстатокЗадолженности           = ОстатокЗадолженности - ДоступноКОплате;
						СтрокаОплаты.ОплачиваемаяСумма = СтрокаОплаты.ОплачиваемаяСумма - ДоступноКОплате;	
						
					КонецЕсли;		
				КонецЦикла;
				
				МассивРедактируемыхРеализаций.Добавить(РеализацияОбъект);
			КонецЕсли;
			
		КонецЕсли;	
	КонецЦикла;

	Счетчик = 0;	
	//Проведение созданных документов
	Для Каждого ДокРеализации Из МассивРедактируемыхРеализаций Цикл
				
		ДокРеализации.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		ДокРеализации.Записать(РежимЗаписиДокумента.Проведение);
		
		//Подмена значения в массиве на ссылку
		МассивРедактируемыхРеализаций[Счетчик] = ДокРеализации.Ссылка;
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Функция - Завершить ввод суммы оплаты СБП
//
// Параметры:
//  СтрокаДанных - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Процедура ЗавершитьВводСуммыОплатыСБП(СтрокаВыбраннойОплаты)
	
	СтрокиОплатСБонусныхСчетов = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.БонусныйСчет"));
	СуммаОплаченнаяБонусами = 0;     
	
	Для Каждого СтрокаБонуса Из СтрокиОплатСБонусныхСчетов Цикл
		 СуммаОплаченнаяБонусами = СуммаОплаченнаяБонусами + СтрокаБонуса.Внесено; 
	 КонецЦикла;
	 
	Если СтрокаВыбраннойОплаты.Внесено = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Внесенная сумма должна быть больше нуля");
		Возврат;
	КонецЕсли;	
	
	// СтрокаВыбраннойОплаты.Внесено = ?(СтрокаВыбраннойОплаты.Внесено > ЭтотОбъект.ОплатаСумма, ЭтотОбъект.ОплатаСумма, СтрокаВыбраннойОплаты.Внесено);
	
	СтруктураПараметров = ПолучитьПараметрыДляПроверки(СтрокаВыбраннойОплаты.ЭквайринговыйТерминал);
	
	СтруктураПараметров.Вставить("КассаОплаты"				, СтрокаВыбраннойОплаты.КассаОплаты);
	СтруктураПараметров.Вставить("Контрагент"				, СтрокаВыбраннойОплаты.Контрагент);
	СтруктураПараметров.Вставить("СтруктурнаяЕдиница"		, ЭтотОбъект.СтруктурнаяЕдиница);
	СтруктураПараметров.Вставить("Организация"				, ЭтотОбъект.Организация);
	СтруктураПараметров.Вставить("ЭквайринговыйТерминал"	, СтрокаВыбраннойОплаты.ЭквайринговыйТерминал);
	СтруктураПараметров.Вставить("СуммаОплаты"				, СтрокаВыбраннойОплаты.Внесено);
	
	ОткрытьФормуСБП(СтруктураПараметров);
	
КонецПроцедуры

#Область РедактированиеВводаСуммы

// Процедура - Активизировать поле ввод суммы оплаты
// 
// Параметры:
//  ПрефиксПоля	 - 	 - 
// 
&НаКлиенте
Процедура НачатьРедактированияПоляВводаСуммы(ПолеВвода)
	
	ОтключитьОбработчикОжидания("ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы");
		
	Если ПредПолеВВодаСуммыОплаты <> Неопределено Тогда		
		ЗавершитьРедактированиеПоляВводаСуммы(ПредПолеВВодаСуммыОплаты);		
	КонецЕсли;

	ТекущиеДанные = СтрокаДанныхДереваПоИмениЭлемента(ПолеВвода.Имя, "ВидыОплат");
	
	СуммаОжидаемогоПлатежа = ЭтотОбъект.ОплатаСумма -  ЭтотОбъект.ОплатаВнесено;

	Если ТекущиеДанные.МаксСуммаСписания = - 1 Тогда
		СуммаДоступнаяДляВнесения = СуммаОжидаемогоПлатежа;
	Иначе
		СуммаДоступнаяДляВнесения  = ?(ТекущиеДанные.МаксСуммаСписания > СуммаОжидаемогоПлатежа, СуммаОжидаемогоПлатежа, ТекущиеДанные.МаксСуммаСписания);
	КонецЕсли;
	
	Если ТекущиеДанные.Внесено = 0 Тогда	
		ТекущиеДанные.Внесено = СуммаДоступнаяДляВнесения;
	КонецЕсли;
	
	ТекущееПолеВВодаСуммыОплаты           = ПолеВвода;	
	ТекущееПолеВВодаСуммыОплаты.Видимость = Истина;

	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(ПолеВвода.Имя);
	
	КнопкаПредСуммы = ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля);
    КнопкаПредСуммы.Видимость = Ложь;
	
	КнопкаПримененияСуммы           = ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля);
	КнопкаПримененияСуммы.Видимость = Истина;

	КнопкаУдаленияСуммы           = ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля);
	КнопкаУдаленияСуммы.Видимость = Ложь;

	ВнесеноПередРедактированием = ТекущиеДанные.Внесено;
	
	ПодключитьОбработчикОжидания("ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы",0.1, Истина);
		 
КонецПроцедуры

// Процедура - Завершить редактирования поля ввода суммы
// 
// Параметры:
//  ПолеВвода	 - 	 - 
// 
&НаКлиенте
Процедура ЗавершитьРедактированиеПоляВводаСуммы(ПолеВвода)
	
	Если ПолеВвода = Неопределено ИЛИ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОтключитьОбработчикОжидания("ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы");
	
	ПолеВвода.Видимость = Ложь;
	
	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(ПолеВвода.Имя);
	
	КнопкаПредСуммы = ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля);
	
	ТекущиеДанные = СтрокаДанныхДереваПоИмениЭлемента(ПолеВвода.Имя, "ВидыОплат");
	
	Если ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.СистемаБыстрыхПлатежей") Тогда
		ТекущееПолеВводаСБП = ПолеВвода;
	КонецЕсли;
		
	ОплатаСуммаПриИзменении(ТекущиеДанные);
	
	Если ТекущиеДанные.Внесено > 0 Тогда
		
		КнопкаПредСуммы.Заголовок     = Формат(ТекущиеДанные.Внесено,"ЧДЦ=2");
		КнопкаПредСуммы.Видимость     = Истина;
		
		КнопкаПрименияСуммы           = ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля);
		КнопкаПрименияСуммы.Видимость = Ложь;
		
		КнопкаУдаленияСуммы           = ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля);
		КнопкаУдаленияСуммы.Видимость = Истина;
		
	Иначе
		
		КнопкаПредСуммы.Заголовок     = "0,00";
		КнопкаПредСуммы.Видимость     = Ложь;
		
		КнопкаПрименияСуммы           = ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля);
		КнопкаПрименияСуммы.Видимость = Ложь;
		
		КнопкаУдаленияСуммы           = ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля);
		КнопкаУдаленияСуммы.Видимость = Ложь;

	КонецЕсли;
	
	Если ТекущееПолеВВодаСуммыОплаты = ПредПолеВВодаСуммыОплаты Тогда
		ТекущееПолеВВодаСуммыОплаты = Неопределено;
	КонецЕсли;
	
	ПредПолеВВодаСуммыОплаты = Неопределено;
	
	ЭтаФорма.ТекущийЭлемент = Элементы.Оплатить;
	
КонецПроцедуры

&НаКлиенте
// При изменении значения суммы оплаты  
Процедура ОплатаСуммаПриИзменении(ТекущиеДанные)
	
	ВнесеноПослеРедактирования = ТекущиеДанные.Внесено;
	Разница                    = ВнесеноПослеРедактирования - ?(ВнесеноПередРедактированием <> Неопределено, ВнесеноПередРедактированием, 0);			
	
	Если ТекущиеДанные.МаксСуммаСписания <> -1
		И  ТекущиеДанные.Внесено > ТекущиеДанные.МаксСуммаСписания Тогда	
		
		Если ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет") Тогда				
			
			ТекстСообщения = "Счет ограничен суммой списания, не более: " + ТекущиеДанные.МаксСуммаСписания + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(); 				
			ПоказатьОповещениеПользователя("Оплата",,ТекстСообщения, БиблиотекаКартинок.Ошибка32, СтатусОповещенияПользователя.Важное); 
			
		КонецЕсли;	
		
		ТекущиеДанные.Внесено = ТекущиеДанные.Внесено - Разница;
		
	КонецЕсли;
	
	РассчитатьРазмерОплаты(ТекущиеДанные);
	
	ОбновитьФорму("ОБНОВИТЬ_ВИДЫ_ОПЛАТ");	
  
КонецПроцедуры

&НаКлиенте
// Процедура - производит расчет размера оплаты вновь добавляемой или изменяемой строки табличной части "Оплата".
// 
Процедура РассчитатьРазмерОплаты(ТекущиеДанные)
		
	СтрокаОплаты             = ТекущиеДанные;
	СуммаОжидаемогоПлатежа   = ЭтотОбъект.ОплатаСумма - ЭтотОбъект.ОплатаВнесено;	
	
	ЭтотОбъект.ОплатаВнесено = СуммаВнесенныхВидовОплат();	
	УстановитьДоступностьЦветФонаОплатить();

	// РАСЧЕТ СУММЫ СДАЧИ
	Разность = ОплатаВнесено - ОплатаСумма;
	
	Если Разность > 0 Тогда 
		
		Если ТекущиеДанные.ТипДенежныхСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные") Тогда
			
			ЭтотОбъект.ОплатаСдача = Разность;			
			
		Иначе
		
			ТекущиеДанные.Внесено = ТекущиеДанные.Внесено - Разность;
			ЭтотОбъект.ОплатаВнесено = СуммаВнесенныхВидовОплат();	
			
		КонецЕсли;
		
	Иначе
		
		ЭтотОбъект.ОплатаСдача = 0;
		
	КонецЕсли;
	
	ТекущиеДанные.ОплачиваемаяСумма = ТекущиеДанные.Внесено - ЭтотОбъект.ОплатаСдача;
	
КонецПроцедуры

// Процедура - Обработчик таймера контроля потери фокуса поля ввода суммы
// 
&НаКлиенте
Процедура ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы()
	
	Если ТекущееПолеВВодаСуммыОплаты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Первое срабатываение
	Если ПредПолеВВодаСуммыОплаты = Неопределено Тогда
		
		ПредПолеВВодаСуммыОплаты = ТекущееПолеВВодаСуммыОплаты;
		ЭтаФорма.ТекущийЭлемент  = ТекущееПолеВВодаСуммыОплаты;
	
	КонецЕсли;
	
	// Поле все еще в фокусе ввода
	Если ПредПолеВВодаСуммыОплаты <> Неопределено 
		И ПредПолеВВодаСуммыОплаты.Видимость = Истина 
		И ЭтаФорма.ТекущийЭлемент = ПредПолеВВодаСуммыОплаты Тогда
		
		ПодключитьОбработчикОжидания("ОбработчикТаймераКонтроляПотериФокусаПоляВводаСуммы",0.2, Истина);
		
    // Поле перестало быть в фокусе ввода
	ИначеЕсли ПредПолеВВодаСуммыОплаты <> Неопределено 
		И ПредПолеВВодаСуммыОплаты.Видимость = Истина Тогда
		
		ЗавершитьРедактированиеПоляВводаСуммы(ПредПолеВВодаСуммыОплаты);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область РедактированиеВводаСерииСертификата

// Процедура - Начать ввод серии сертификата
// 
&НаКлиенте
Процедура НачатьВводСерииСертификата(Элемент)
	
	СтрокаВыбраннойОплаты = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	
	Если ЭтотОбъект.ОплатаВнесено >= ЭтотОбъект.ОплатаСумма
		И СтрокаВыбраннойОплаты.Внесено = 0 Тогда 
		ПоказатьОповещениеПользователя("Оплата",,"Сумма оплаты полностью покрывает сумму документа. Новый вид оплаты не может быть добавлен.", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 			
		Возврат
	КонецЕсли;		
	
	ПрефиксПоля    = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	ПолеВводаСерии = ВидыОплатСтрокаПолеВводаСерииСертификата(ПрефиксПоля);
			
	ПолеВводаСерии.Видимость = Истина;
	
	ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксПоля).Видимость         = Ложь;	
	ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля).Видимость            = Ложь;	
	ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля).Видимость = Истина;
    ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля).Видимость                 = Истина;

	ТекущееПолеВводаСерииСертификата = ПолеВводаСерии;
	
	ПодключитьОбработчикОжидания("НачатьРедактированиеПоляСерииСертификата",0.1, Истина);
		
КонецПроцедуры

// Процедура - Начать редактирование поля серии сертификата
// 
&НаКлиенте
Процедура НачатьРедактированиеПоляСерииСертификата() 
	
	ЭтаФорма.ТекущийЭлемент = ТекущееПолеВводаСерииСертификата;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения ввода серии сертификата.
//
Процедура ЗавершитьВводСерииСертификата(Элемент, ЭтоУдаление = Ложь)
	
	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	
	ТекущиеДанные = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	
	Если ЗначениеЗаполнено(ТекущиеДанные.СертификатПартия) Тогда
		
		ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксПоля).Видимость         = Истина;	
		ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля).Видимость            = Истина;	
		ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля).Видимость = Ложь;
		ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля).Видимость                 = Истина;
		
		ОплатаСуммаПриИзменении(ТекущиеДанные);

	Иначе
		
		Если ЭтоУдаление = Истина Тогда
			
			ТекущиеДанные.ВводСерииСертификата = Неопределено;
			ВидыОплатСтрокаПолеВводаСерииСертификата(ПрефиксПоля).Видимость           = Ложь;
			ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксПоля).Видимость         = Истина;	
			ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля).Видимость            = Ложь;	
			ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля).Видимость = Ложь;
			ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля).Видимость                 = Ложь;
			
			ОплатаСуммаПриИзменении(ТекущиеДанные);

		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ПолеВводаСерииСертификата_ПриИзменении(Элемент)
	
	ТекущиеДанные   = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");	
	СписокУточнения = ПолучитьСписокСертификатовПоСерии(ТекущиеДанные.ВводСерииСертификата, Контрагент, СтруктурнаяЕдиница);
	
	Если СписокУточнения.Количество() > 1 Тогда
		
		Если ТекущееПолеВводаСерииСертификата = Неопределено Тогда
			ТекущееПолеВводаСерииСертификата = Элемент;
			ПодключитьОбработчикОжидания("ПоказатьВыборСертификатаИзСписка", 0.1, Истина);
		Иначе
			
			ДопПараметры = Новый Структура("Элемент", Элемент);
			Оповещение   = Новый ОписаниеОповещения("ВыборСертификатаЗавершение", ЭтотОбъект, ДопПараметры);
			ПоказатьВыборИзМеню(Оповещение, СписокУточнения, Элемент);
			
			ТекущееПолеВводаСерииСертификата = Неопределено;
			
		КонецЕсли;
		
		Возврат;
		
	ИначеЕсли СписокУточнения.Количество() > 0 Тогда
		ВыполнитьОбработкуОповещения(Новый ОписаниеОповещения("ВыборСертификатаЗавершение",ЭтотОбъект, Новый Структура("Элемент", Элемент)), СписокУточнения[0]);
	Иначе
		Элемент.ЦветРамки = WebЦвета.Красный;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик ожидания.
//
Процедура ПоказатьВыборСертификатаИзСписка()
	
	Если ТекущееПолеВводаСерииСертификата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПолеВводаСерииСертификата_ПриИзменении(ТекущееПолеВводаСерииСертификата);
	
КонецПроцедуры

&НаКлиенте
// Функция, возвращает список доступных для выбора сертификатов.
//
Функция ПолучитьСписокСертификатовПоСерии(СерияСертификата, Контрагент, СтруктурнаяЕдиница)
	
	ДанныеСертификата               = ПолучитьСертификат(СерияСертификата, Ложь, Контрагент, СтруктурнаяЕдиница);
	МассивСертификатовДляИсключения = ПолучитьСертификатыПроданныеВОплачиваемыхДокументах(ДокументыЗадолженности.ВыгрузитьЗначения(), СерияСертификата, Контрагент, СтруктурнаяЕдиница);

	Счетчик = 0;
	Для Каждого ЭлементМассива Из ДанныеСертификата Цикл
		
		Если МассивСертификатовДляИсключения.Найти(ЭлементМассива.Сертификат) <> Неопределено Тогда
			ДанныеСертификата.Удалить(Счетчик);
			Счетчик = Счетчик + 1;
            Продолжить;
		КонецЕсли;
		
		Использован = ПроверитьИспользованиеСертификата(ЭлементМассива.Сертификат, ЭлементМассива.Партия);
		Если Использован = Истина Тогда
			ДанныеСертификата.Удалить(Счетчик);
		КонецЕсли;
			
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
	СписокУточнения = Новый СписокЗначений;
	
	Если Не ЗначениеЗаполнено(ДанныеСертификата) Тогда
		ПоказатьОповещениеПользователя("Оплата",, "Сертификат не найден", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);
	Иначе
		Для Каждого ЭлементМ ИЗ ДанныеСертификата Цикл
			Если ЭлементМ.Использовать Тогда
				СписокУточнения.Добавить(ЭлементМ, ЭлементМ.Представление);
			Иначе
				ПоказатьОповещениеПользователя("Оплата",, ЭлементМ.ОписаниеПроверки, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат СписокУточнения;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает найденные сертификаты.
//
Функция ПолучитьСертификат(ШтрихкодСерияСертифката, ВводСоСканера, Контрагент, СтруктурнаяЕдиница)
	
	ДанныеСертификатов = ЛицевыеСчетаИСертификатыСервер.ПолучитьДанныеВсехСертификатовПоШтрихкодуИлиСерииПроверитьПригодность(
		ШтрихкодСерияСертифката,
		ВводСоСканера,
		Контрагент,
		СтруктурнаяЕдиница);
	
	Возврат ДанныеСертификатов;
	
КонецФункции

&НаСервере
// Функция - Проверить использование сертификата
//
Функция ПроверитьИспользованиеСертификата(Сертификат, Партия)
	
	СтрокаСертификата = НайтиВДеревеДоступныхВидовОплатСервер(
		Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,
		,,
		Партия,,
		Истина);
	
	Если СтрокаСертификата <> Неопределено И СтрокаСертификата.Внесено > 0 Тогда
		 Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает сертификаты, проданные в оплачевыемых документах.
//
Функция ПолучитьСертификатыПроданныеВОплачиваемыхДокументах(Знач МассивДокументов, СерияСертификата, Контрагент, СтруктурнаяЕдиница)
	
	Если МассивДокументов.Количество() > 0 Тогда
			
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СертификатыОбороты.Сертификат КАК Сертификат
		|ИЗ
		|	РегистрНакопления.Сертификаты.Обороты(
		|			,
		|			,
		|			Авто,
		|			СерийныйНомер = &СерийныйНомер
		|				И Контрагент = &Контрагент
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СертификатыОбороты
		|ГДЕ
		|	СертификатыОбороты.Регистратор В(&МассивРегистраторов)
		|	И СертификатыОбороты.СуммаПриход > 0";
		Запрос.УстановитьПараметр("МассивРегистраторов", МассивДокументов);
		Запрос.УстановитьПараметр("СерийныйНомер"      , СерияСертификата);
		Запрос.УстановитьПараметр("Контрагент"         , Контрагент);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница" , СтруктурнаяЕдиница);

		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сертификат");

	Иначе
		Возврат Новый Массив;
	КонецЕсли;
	
КонецФункции

// Процедура - Уточнить выбор сертификата завершение
// 
&НаКлиенте
Процедура ВыборСертификатаЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		НайденныйУзел = НайтиВДеревеДоступныхВидовОплат(ЭтотОбъект.ВидыОплат, ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат"),,
			Результат.Значение.Партия);
		
		Если ЗначениеЗаполнено(НайденныйУзел) Тогда		
			ПоказатьОповещениеПользователя("Оплата",,"Данный сертифкат уже добавлен в виды оплат!", БиблиотекаКартинок.Предупреждение32,
				СтатусОповещенияПользователя.Важное);
			ДопПараметры.Элемент.ЦветРамки = WebЦвета.Красный;
			Возврат;		
		КонецЕсли;        		
		
		ДобавитьВыбранныйСертификатВВидыОплат(Результат.Значение);
		
		ЗавершитьВводСерииСертификата(ДопПараметры.Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВводВидаЛицевогоСчета

// Процедура - Начать ввод вида лицевого счета
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура НачатьВводВидаЛицевогоСчета(Элемент)
	
	ПрефиксПоля    = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);
	ПолеВводаСерии = ВидыОплатСтрокаПолеВыбораВидаЛицевогоСчета(ПрефиксПоля);
			
	ПолеВводаСерии.Видимость = Истина;
	
	ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксПоля).Видимость         = Ложь;	
	ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля).Видимость            = Ложь;	
	ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля).Видимость = Истина;
    ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля).Видимость                 = Истина;

	Попытка
		Если ПолеВводаСерии.ПодсказкаВвода = "Выберите вид лицевого счета" Тогда
			МассивОтбораВременный = Новый Массив;
			ОрганизацияОтбора = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущаяКасса, "Организация");
			МассивОтбораВременный.Добавить(Новый ПараметрВыбора("Отбор.Организация"	, ОрганизацияОтбора)); 
			МассивОтбораВременный.Добавить(Новый ПараметрВыбора("Отбор.Ссылка"	    , ПолучитьМассивНеИспользуемыхВидовЛицевыхСчет(ОрганизацияОтбора))); 
			ПолеВводаСерии.ПараметрыВыбора = Новый ФиксированныйМассив(МассивОтбораВременный);
		КонецЕсли;   
	Исключение КонецПопытки;
	
	ТекущееПолеВводаСерииСертификата = ПолеВводаСерии;
	
КонецПроцедуры

&НаСервере
// Функция возвращает массив используемых видов лицевых счетов.
//
Функция ПолучитьМассивНеИспользуемыхВидовЛицевыхСчет(Организация)
	
	МассивИспользуемыхВидовЛицевыхСчетов = Новый Массив;
	
	Для Каждого СтрокаВерхУровня Из ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл 		
		Если СтрокаВерхУровня.ТипДенежныхСредств <> ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет") Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Строка Из СтрокаВерхУровня.ПолучитьЭлементы() Цикл
			Если ЗначениеЗаполнено(Строка.ЛицевойСчет) Тогда
				МассивИспользуемыхВидовЛицевыхСчетов.Добавить(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Строка.ЛицевойСчет, "ВидЛицевогоСчета"));
			КонецЕсли;			
		КонецЦикла;   		
	КонецЦикла;
	        	
	Возврат ПолучитьМассивВидовЛицевыхСчетов(Организация, МассивИспользуемыхВидовЛицевыхСчетов);
	
КонецФункции 

&НаСервере
// Функция возвращает массив видоы лицевых счетов.
//
Функция ПолучитьМассивВидовЛицевыхСчетов(Организация, МассивИсключения)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыЛицевыхСчетов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыЛицевыхСчетов КАК ВидыЛицевыхСчетов
	|ГДЕ
	|	ВидыЛицевыхСчетов.ПометкаУдаления = ЛОЖЬ
	|	И ВидыЛицевыхСчетов.Внешний = ЛОЖЬ
	|	И НЕ ВидыЛицевыхСчетов.Ссылка В (&МассивИсключения)
	|	И (ВидыЛицевыхСчетов.НеВестиУчетВРазрезеОрганизаций
	|			ИЛИ ВидыЛицевыхСчетов.Организация = &Организация)");
	
	Запрос.УстановитьПараметр("МассивИсключения", МассивИсключения);
	Запрос.УстановитьПараметр("Организация"		, Организация);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Процедура - Завершить ввод вида лицевого счета
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ЗавершитьВводВидаЛицевогоСчета(Элемент)
	
	ПрефиксПоля = ИндексСтрокиДанныхДереваПоИмениЭлемента(Элемент.Имя);

	ТекущиеДанные = СтрокаДанныхДереваПоИмениЭлемента(Элемент.Имя, "ВидыОплат");
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ВыборВидаЛицевогоСчета) Тогда
		
		ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксПоля).Видимость         = Истина;	
		ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля).Видимость            = Истина;	
		ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля).Видимость = Ложь;
		ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля).Видимость                 = Истина;
		
		ЛицевойСчетКонтрагента = ВернутьЛицевойСчетКонтрагента(
									ЭтотОбъект.Контрагент,
									ТекущиеДанные.ВыборВидаЛицевогоСчета,
									ТекущаяКасса);

		Если ЛицевойСчетКонтрагента = Неопределено Тогда
			ТекущиеДанные.ЛицевойСчет = СоздатьЛицевойСчетКлиента(
											ЭтотОбъект.Контрагент,
											ТекущиеДанные.ВыборВидаЛицевогоСчета, 
											ТекущаяКасса);
		Иначе
			ТекущиеДанные.ЛицевойСчет = ЛицевойСчетКонтрагента;										
		КонецЕсли;
		

		ТекущиеДанные.Представление = ПолучитьПредставлениеЛицевогоСчета(ТекущиеДанные.ЛицевойСчет);					
						
		СуммаОжидаемогоПлатежа     = ЭтотОбъект.ОплатаСумма -  ЭтотОбъект.ОплатаВнесено;			
		ТекущиеДанные.Внесено      = СуммаОжидаемогоПлатежа;
		ТекущиеДанные.Контрагент   = ЭтотОбъект.Контрагент;
		ТекущиеДанные.КассаОплаты  = ЭтотОбъект.ТекущаяКасса;

	Иначе
		
		ТекущиеДанные.ВводСерииСертификата = Неопределено;
		ВидыОплатСтрокаПолеВыбораВидаЛицевогоСчета(ПрефиксПоля).Видимость         = Ложь;
		ВидыОплатСтрокаКнопкаНаименованияВидаОплат(ПрефиксПоля).Видимость         = Истина;	
		ВидыОплатСтрокаКнопкаПредставленияСуммы(ПрефиксПоля).Видимость            = Ложь;	
		ВидыОплатСтрокаКнопкаПримененияРедактированияСуммы(ПрефиксПоля).Видимость = Ложь;
		ВидыОплатСтрокаКнопкаУдаленияСуммы(ПрефиксПоля).Видимость                 = Ложь;

	КонецЕсли;
	
	ОплатаСуммаПриИзменении(ТекущиеДанные);
		
КонецПроцедуры

