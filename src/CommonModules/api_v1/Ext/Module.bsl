// Функция, возвращает таблицу сотрудников с нормой времени для последовательного выполнения массива услуг.
// 
Функция ПолучитьСотрудниковСпособныхОказатьМассивУслуг(СтруктурнаяЕдиница, МассивУслуг, ДатаСреза)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыСотрудников.Объект КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА НастройкиСотрудников.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.Розничная)
	|		ИНАЧЕ НастройкиСотрудников.ВидЦен
	|	КОНЕЦ КАК ВидЦен,
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ПОМЕСТИТЬ ТаблицаСотрудниковИУслуг
	|ИЗ
	|	РегистрСведений.РеквизитыОбъектов КАК РеквизитыСотрудников
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО РеквизитыСотрудников.СтруктурнаяЕдиница = НастройкиСотрудников.СтруктурнаяЕдиница
	|			И РеквизитыСотрудников.Объект = НастройкиСотрудников.Сотрудник
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыОбъектов КАК РеквизитыНоменклатуры
	|			ПО УслугиСотрудника.СтруктурнаяЕдиница = РеквизитыНоменклатуры.СтруктурнаяЕдиница
	|				И УслугиСотрудника.Номенклатура = РеквизитыНоменклатуры.Объект
	|				И (РеквизитыНоменклатуры.Реквизит = ""ОнлайнЗапись"")
	|		ПО РеквизитыСотрудников.Объект = УслугиСотрудника.Сотрудник
	|ГДЕ
	|	НЕ РеквизитыСотрудников.Объект.ЭтоГруппа
	|	И НЕ РеквизитыСотрудников.Объект.ПометкаУдаления
	|	И РеквизитыСотрудников.Значение = ИСТИНА
	|	И РеквизитыСотрудников.Реквизит = ""ОнлайнЗаписьСотрудник""
	|	И РеквизитыСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыСотрудников.Объект ССЫЛКА Справочник.Сотрудники
	|	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И УслугиСотрудника.Номенклатура.НормаВремени > 0
	|	И УслугиСотрудника.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И РеквизитыНоменклатуры.Значение = ИСТИНА
	|	И УслугиСотрудника.Номенклатура В(&МассивУслуг)
	|	И (ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|			ИЛИ ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаСотрудниковИУслуг.Сотрудник КАК Сотрудник,
	|	ТаблицаСотрудниковИУслуг.Номенклатура КАК Номенклатура,
	|	ТаблицаСотрудниковИУслуг.НормаВремени КАК НормаВремени
	|ПОМЕСТИТЬ ТаблицаСотрудниковИУслуг2
	|ИЗ
	|	ТаблицаСотрудниковИУслуг КАК ТаблицаСотрудниковИУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаСреза, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЦеныСрезПоследних
	|		ПО ТаблицаСотрудниковИУслуг.Номенклатура = ЦеныСрезПоследних.Номенклатура
	|			И ТаблицаСотрудниковИУслуг.ВидЦен = ЦеныСрезПоследних.ВидЦен
	|ГДЕ
	|	(ЕСТЬNULL(ЦеныСрезПоследних.Цена, 0) <> 0
	|			ИЛИ ТаблицаСотрудниковИУслуг.Номенклатура.Бесплатно)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСотрудниковИУслуг2.Сотрудник КАК Сотрудник,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТаблицаСотрудниковИУслуг2.Номенклатура) КАК КоличествоДоступныхНоменклатур,
	|	СУММА(ТаблицаСотрудниковИУслуг2.НормаВремени) КАК ОбщаяНормаВремени
	|ПОМЕСТИТЬ ТаблицаСотрудниковСОбщейНормойВремени
	|ИЗ
	|	ТаблицаСотрудниковИУслуг2 КАК ТаблицаСотрудниковИУслуг2
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаСотрудниковИУслуг2.Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	|	ТаблицаСотрудников.Сотрудник.ПредставлениеДляОнлайнЗаписи КАК Наименование,
	|	ТаблицаСотрудников.Сотрудник.Должность КАК Должность,
	|	ТаблицаСотрудников.Сотрудник.Должность.Наименование КАК ДолжностьНаименование,
	|	ВЫРАЗИТЬ(ТаблицаСотрудников.Сотрудник.ОписаниеДляСайтаHTML КАК СТРОКА(1000)) КАК ОписаниеДляСайтаHTML,
	|	ТаблицаСотрудников.Сотрудник.APIВес КАК Вес,
	|	ТаблицаСотрудников.Сотрудник.ФайлКартинки.Расширение КАК РасширениеФото,
	|	ТаблицаСотрудников.Сотрудник.ФайлКартинки.Размер КАК РазмерФото,
	|	ТаблицаСотрудников.ОбщаяНормаВремени КАК НормаВремени
	|ИЗ
	|	ТаблицаСотрудниковСОбщейНормойВремени КАК ТаблицаСотрудников
	|ГДЕ
	|	ТаблицаСотрудников.КоличествоДоступныхНоменклатур = &КоличествоНоменклатур");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	 , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза"         	 , ДатаСреза);
	Запрос.УстановитьПараметр("МассивУслуг" 	  	 , МассивУслуг);
	Запрос.УстановитьПараметр("КоличествоНоменклатур", МассивУслуг.Количество());
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция, возвращает таблицу сотрудников с минимальной нормой времени.
// 
Функция ПолучитьСотрудниковСНормойВремени(СтруктурнаяЕдиница, МассивУслуг, ДатаСреза)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыСотрудников.Объект КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА НастройкиСотрудников.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
