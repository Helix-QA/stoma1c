&НаКлиенте
// Процедура, обрабочик события кнопки "Побор".
//
Процедура ПоказатьСкрытьПодбор(Команда) 
	
	Если Элементы.Найти("_ПодборНоменклатурУслуги") <> Неопределено Тогда
		СкрытьПодборНаСервере("Услуги");
		Если Элементы._ПодборНоменклатурУслуги.Видимость Тогда 
			Элементы._ПодборНоменклатурУслуги.Обновить();
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ТаблицаЛечение.Ширина		= ?(Элементы._ПодборНоменклатурУслуги.Видимость, 0, 151);
	Элементы.УслугиПодборЗубов.Ширина	= ?(Элементы._ПодборНоменклатурУслуги.Видимость, 1, 150);
	
КонецПроцедуры     

&НаСервере
// Процедура, выполняет установку видимости подбора.
//
Процедура СкрытьПодборНаСервере(Тип, Видимость = Неопределено)
	
	Если Тип = "Услуги" Тогда
		
		Отображать = ?(Видимость = Неопределено, Не Элементы.ГруппаПодборУслугиОбщая.Видимость, Видимость);
		Элементы.ГруппаПодборУслугиОбщая.Видимость       = Отображать;		
		Элементы._ПодборНоменклатурУслуги.Видимость      = Отображать;
		Если Видимость = Неопределено Тогда
			ОбщегоНазначения.СохранитьНастройкуПользователяВХранилищеСистемныхНастроек("ОтображатьПодборУслугиВПланеЛечения", 
			Элементы.ГруппаПодборУслугиОбщая.Видимость);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура печати.
//
Процедура ДокументПечать(Команда)
	
	МассивДокументов = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		МассивДокументов.Добавить(Объект.Ссылка);
	КонецЕсли;
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "ПланЛечения");
	Структура.Вставить("МассивДокументов", МассивДокументов);
	
	СписокПечатныхФорм = ПолучитьСписокПечати();
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораДокументаПечати", ЭтотОбъект, Структура);	
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка)
		ИЛИ ЭтаФорма.Модифицированность = Истина Тогда	
		
		СтруктураВопроса = Новый Структура;
		СтруктураВопроса.Вставить("СписокПечатныхФорм", СписокПечатныхФорм);
		СтруктураВопроса.Вставить("Оповещение", Оповещение);
		ОповещениеДляВопроса = Новый ОписаниеОповещения("ПослеВопросаЗавершение", ЭтотОбъект, СтруктураВопроса);			
		ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны или были изменены. Записать?", РежимДиалогаВопрос.ДаНет);
		
	Иначе	
		
		ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, Элементы.ФормаДокументаПечать);
		
	КонецЕсли;   				
	
КонецПроцедуры

