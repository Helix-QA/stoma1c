Функция ВыполнитьPostЗапросКPaymo(Параметры)
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();  
	
	HTTPСоединение = Новый HTTPСоединение("paymo.ru",,,,,, ЗащищенноеСоединение); 
