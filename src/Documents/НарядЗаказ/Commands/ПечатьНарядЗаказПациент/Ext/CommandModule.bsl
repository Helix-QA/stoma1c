
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаКоманды".
//
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если УправлениеПечатьюКлиентСтоматология.ПроверитьДокументыПроведены(ПараметрКоманды) Тогда
	
		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
			"Документ.НарядЗаказ",
			"ПФ_MXL_НарядЗаказПациент",
			ПараметрКоманды,
			Неопределено,
			Новый Структура("Тип", "НарядЗаказ")
		);
	
	КонецЕсли;
	
КонецПроцедуры // ОбработкаКоманды()

#КонецОбласти