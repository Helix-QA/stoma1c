// Процедура - Установить видимость элементов КОРП.
//
Процедура УстановитьВидимостьЭлементовКОРП()
	
	// Ограничение видимости элементов для версии ПРОФ.
	Если Не ЭтотОбъект.ЭтоВерсияКОРП = Истина Тогда
		
		Элементы.ОтборБезСделок.Видимость        = Ложь;
		Элементы.Фильтр_Этап.Видимость           = Ложь;
		Элементы.Фильтр_Сделка.Видимость         = Ложь;
		Элементы.ГруппаСделкаЭтапСумма.Видимость = Ложь;
		
		Элементы.ДобавитьНового.Отображение = ОтображениеКнопки.Текст;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура, устанавливает количество потенциальных клиенов без сделок и без задач.
//
Процедура УстановитьКоличествоНеЗадйествованныхПотенциальныхКлиентов()
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборМенеджер", УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Менеджер"));
	
	СписокМенеджеров = СтруктураОтборов.ОтборМенеджер;
	Если НЕ ЗначениеЗаполнено(СписокМенеджеров) Тогда
		МассивМенеджеров = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения;
	КонецЕсли;
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ТаблицаПотенциальныеКлиенты
	|ИЗ
	|	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
	|			,
	|				 (Контрагент.Менеджер В (&МассивМенеджеров)
	|					ИЛИ Контрагент.МенеджерОтделаСервиса В (&МассивМенеджеров))) КАК СтатусыКонтрагентовСрезПоследних
	|ГДЕ
	|	СтатусыКонтрагентовСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыСведенияДляСписка.Контрагент) КАК КоличествоБезЗадач
	|ИЗ
	|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.Контрагент В
	|			(ВЫБРАТЬ
	|				ТаблицаПотенциальныеКлиенты.Контрагент
	|			ИЗ
	|				ТаблицаПотенциальныеКлиенты)
	|	И КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыСведенияДляСписка.Контрагент) КАК КоличествоБезСделок
	|ИЗ
	|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.Контрагент В
	|			(ВЫБРАТЬ
	|				ТаблицаПотенциальныеКлиенты.Контрагент
	|			ИЗ
	|				ТаблицаПотенциальныеКлиенты)
	|	И КонтрагентыСведенияДляСписка.ТекущаяСделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
	|ПОМЕСТИТЬ КонтрагентыЗадачаНазначеннаяДата
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	НЕ Контрагенты.ЭтоГруппа
	|	И КонтрагентыСведенияДляСписка.Контрагент В
	|			(ВЫБРАТЬ
	|				ТаблицаПотенциальныеКлиенты.Контрагент
	|			ИЗ
	|				ТаблицаПотенциальныеКлиенты)
	|	И НЕ КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыЗадачаНазначеннаяДата.Ссылка) КАК КоличествоПросроченныхЗадач
	|ИЗ
	|	КонтрагентыЗадачаНазначеннаяДата КАК КонтрагентыЗадачаНазначеннаяДата
	|ГДЕ
	|	КонтрагентыЗадачаНазначеннаяДата.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи");
	
	// Отбор структурная единица.
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборСтруктурнаяЕдиница", УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СтруктурнаяЕдиница"));	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Контрагент.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	Запрос.УстановитьПараметр("МассивМенеджеров"					, МассивМенеджеров);	
	Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"     , Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи"  , ТекущаяДатаСеанса() - 1);	
	РезультатЗапроса 								= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваБезЗадач 						= РезультатЗапроса[1].Выбрать();
	ВыборкаКоличестваБезСделок 						= РезультатЗапроса[2].Выбрать();	
	ВыборкаКоличествоПросроченныхЗадач 				= РезультатЗапроса[4].Выбрать();
	
	Если ВыборкаКоличестваБезЗадач.Следующий() Тогда
		КоличествоБезЗадач = ВыборкаКоличестваБезЗадач.КоличествоБезЗадач;
	Иначе 
		КоличествоБезЗадач = 0;		
	КонецЕсли;
	Элементы.ОтборБезЗадач.Заголовок  = ПолучитьСколонениеКлиентаПоЧислу(КоличествоБезЗадач) + НСтр("ru=' без задач';en=' without tasks'");
	Элементы.ОтборБезЗадач.Видимость  = ?(КоличествоБезЗадач = 0, Ложь, Истина);
	
	Если ВыборкаКоличестваБезСделок.Следующий() Тогда
		КоличествоБезСделок = ВыборкаКоличестваБезСделок.КоличествоБезСделок;
	Иначе 
		КоличествоБезСделок = 0;		
	КонецЕсли;
	Элементы.ОтборБезСделок.Заголовок = ПолучитьСколонениеКлиентаПоЧислу(КоличествоБезСделок) + НСтр("ru=' без сделок';en=' without deals'");
	Элементы.ОтборБезСделок.Видимость = ?(КоличествоБезСделок = 0, Ложь, Истина);
	
	Если ВыборкаКоличествоПросроченныхЗадач.Следующий() Тогда
		КоличествоПросроченныхЗадач = ВыборкаКоличествоПросроченныхЗадач.КоличествоПросроченныхЗадач;
	Иначе 
		КоличествоПросроченныхЗадач = 0;		
	КонецЕсли;	
	Элементы.ОтборПросроченныхЗадач.Заголовок = ПолучитьСколонениеКлиентаПоЧислу(КоличествоПросроченныхЗадач) + НСтр("ru=' с просроченными задачами';en='with expired tasks'");
	Элементы.ОтборПросроченныхЗадач.Видимость = ?(КоличествоПросроченныхЗадач = 0, Ложь, Истина);
	
	Элементы.ЗаглушкаСделкиЗадачи.Видимость     = ?(КоличествоБезСделок = 0 И КоличествоБезЗадач = 0 И КоличествоПросроченныхЗадач = 0, Ложь, Истина);
	Элементы.ГруппаОтборыСделкиЗадачи.Видимость = Элементы.ЗаглушкаСделкиЗадачи.Видимость;
	
КонецПроцедуры

