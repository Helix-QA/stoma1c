// Процедура получает количество строк в динамическом списке .
//
Процедура УстановитьЗаголовокКоличествоЭлементовВСписке(КоличествоКлиентов)
	
	УстановитьЗаголовкиДополнительныхОтборов();
		
	Строка = СтрокаСЧислом(Нстр("ru = '; сделка;;  сделки;  сделок;  сделки'; en = '; deal;;;; deals'"),
	КоличествоКлиентов,
	ВидЧисловогоЗначения.Количественное,
	НСтр("ru='L=ru'; en='L=en'")); 
	
	Элементы.КоличествоЭлементовВСписке.Заголовок = "(" + Формат(КоличествоКлиентов, НСтр("ru = 'ЧН=Нет';en = 'ЧН=No'")) + " " + Строка + ")";	
	
КонецПроцедуры

