
#Область СлужебныеПроцедурыИФункции 

#Область МетодыGET

#Область book_services

// Функция возвращает список услуг, доступных для бронирования.
//
Функция book_services(СтруктурнаяЕдиница, datetime, staff_id, ДляЧатБота = Ложь) Экспорт

	СтруктураОшибки = Неопределено;
	
	ДатаСреза = ПолучитьИПроверитьДату(datetime, СтруктураОшибки);
	Сотрудник = ПолучитьСсылкуПоИдентификатору(staff_id, СтруктураОшибки, Истина, "Сотрудники", 1050);
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	ДатаСрезаЗаполнена = ЗначениеЗаполнено(ДатаСреза);
	ДатаСреза 		   = ПолучитьДатуСреза(ДатаСреза, ДатаСрезаЗаполнена);
	СотрудникПередан   = ЗначениеЗаполнено(Сотрудник);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыОбъектов.Объект КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА НастройкиСотрудников.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.Розничная)
	|		ИНАЧЕ НастройкиСотрудников.ВидЦен
	|	КОНЕЦ КАК ВидЦен
	|ПОМЕСТИТЬ ТаблицаРаботающиеСотрудникиСВидомЦен
	|ИЗ
	|	РегистрСведений.РеквизитыОбъектов КАК РеквизитыОбъектов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО РеквизитыОбъектов.Объект = НастройкиСотрудников.Сотрудник
	|ГДЕ
	|	НЕ РеквизитыОбъектов.Объект.ПометкаУдаления
	|	И РеквизитыОбъектов.Значение = ИСТИНА
	|	И РеквизитыОбъектов.Реквизит = ""ОнлайнЗаписьСотрудник""
	|	И РеквизитыОбъектов.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыОбъектов.Объект ССЫЛКА Справочник.Сотрудники
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И (ВЫРАЗИТЬ(РеквизитыОбъектов.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|			ИЛИ ВЫРАЗИТЬ(РеквизитыОбъектов.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач))
	|	И &УсловиеСотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыОбъектов.Объект КАК Номенклатура
	|ПОМЕСТИТЬ ВременнаяТаблицаДоступныхНоменклатур
	|ИЗ
	|	РегистрСведений.РеквизитыОбъектов КАК РеквизитыОбъектов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&ДатаСреза, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
	|		ПО РеквизитыОбъектов.Объект = СтатусыНоменклатурыСрезПоследних.Номенклатура
	|ГДЕ
	|	РеквизитыОбъектов.Объект ССЫЛКА Справочник.Номенклатура
	|	И НЕ РеквизитыОбъектов.Объект.ПометкаУдаления
	|	И РеквизитыОбъектов.Объект.НормаВремени <> 0
	|	И НЕ РеквизитыОбъектов.Объект.ЭтоГруппа
	|	И РеквизитыОбъектов.Объект.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И РеквизитыОбъектов.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыОбъектов.Значение = ИСТИНА
	|	И РеквизитыОбъектов.Реквизит = ""ОнлайнЗапись""
	|	И ЕСТЬNULL(СтатусыНоменклатурыСрезПоследних.ВПродаже, ИСТИНА) = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница КАК СетеваяЦена,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ПОМЕСТИТЬ ВременнаяТаблицаНоменклатура
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаСреза,
	|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И ВидЦен В
	|					(ВЫБРАТЬ
	|						ТаблицаРаботающиеСотрудникиСВидомЦен.ВидЦен
	|					ИЗ
	|						ТаблицаРаботающиеСотрудникиСВидомЦен)
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						ВременнаяТаблицаДоступныхНоменклатур.Номенклатура
	|					ИЗ
	|						ВременнаяТаблицаДоступныхНоменклатур)) КАК ЦеныНоменклатурыСрезПоследних
	|ГДЕ
	|	ЦеныНоменклатурыСрезПоследних.Цена <> 0
	|	И НЕ ЦеныНоменклатурыСрезПоследних.Номенклатура.Бесплатно
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ВременнаяТаблицаДоступныхНоменклатур.Номенклатура,
	|	ЛОЖЬ,
	|	0
	|ИЗ
	|	ВременнаяТаблицаДоступныхНоменклатур КАК ВременнаяТаблицаДоступныхНоменклатур
	|ГДЕ
	|	ВременнаяТаблицаДоступныхНоменклатур.Номенклатура.Бесплатно
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(УслугиСотрудника.Номенклатура.НаименованиеПолное КАК СТРОКА(300))) = """"
	|			ТОГДА УслугиСотрудника.Номенклатура.Наименование
	|		ИНАЧЕ ВЫРАЗИТЬ(УслугиСотрудника.Номенклатура.НаименованиеПолное КАК СТРОКА(300))
	|	КОНЕЦ КАК Наименование,
	|	ВЫБОР
	|		КОГДА УслугиСотрудника.НормаВремени <> 0
	|			ТОГДА УслугиСотрудника.НормаВремени
	|		ИНАЧЕ УслугиСотрудника.Номенклатура.НормаВремени
	|	КОНЕЦ КАК НормаВремениПоСотруднику,
	|	УслугиСотрудника.Номенклатура.НормаВремени КАК НормаВремени,
	|	ВЫБОР
	|		КОГДА НЕ УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи.ПометкаУдаления
	|			ТОГДА УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Категория,
	|	УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи.Наименование КАК КатегорияНаименование,
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	ВЫРАЗИТЬ(УслугиСотрудника.Номенклатура.ОписаниеДляОнлайнЗаписи КАК СТРОКА(1000)) КАК Комментарий
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаРаботающиеСотрудникиСВидомЦен КАК ТаблицаРаботающиеСотрудникиСВидомЦен
	|		ПО УслугиСотрудника.Сотрудник = ТаблицаРаботающиеСотрудникиСВидомЦен.Сотрудник
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаНоменклатура КАК ВременнаяТаблицаНоменклатура
	|		ПО УслугиСотрудника.Номенклатура = ВременнаяТаблицаНоменклатура.Номенклатура
	|ГДЕ
	|	УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И &УсловиеУслугиСотрудника
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи.ИндексСортировки = 0
	|				ИЛИ УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи = ЗНАЧЕНИЕ(Справочник.ГруппыОнлайнЗаписи.ПустаяСсылка)
	|				ИЛИ УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи.ПометкаУдаления
	|			ТОГДА 999999
	|		ИНАЧЕ УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи.ИндексСортировки
	|	КОНЕЦ,
	|	УслугиСотрудника.Номенклатура.ГруппаОнлайнЗаписи.Наименование,
	|	ВЫБОР
	|		КОГДА УслугиСотрудника.Номенклатура.ИндексСортировки = 0
	|			ТОГДА 999999
	|		ИНАЧЕ УслугиСотрудника.Номенклатура.ИндексСортировки
	|	КОНЕЦ,
	|	УслугиСотрудника.Номенклатура.Наименование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаРаботающиеСотрудникиСВидомЦен.Сотрудник КАК Сотрудник
	|ИЗ
	|	ТаблицаРаботающиеСотрудникиСВидомЦен КАК ТаблицаРаботающиеСотрудникиСВидомЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаНоменклатура.Номенклатура КАК Номенклатура,
	|	ВременнаяТаблицаНоменклатура.СетеваяЦена КАК СетеваяЦена,
	|	ВременнаяТаблицаНоменклатура.Цена КАК Цена
	|ИЗ
	|	ВременнаяТаблицаНоменклатура КАК ВременнаяТаблицаНоменклатура");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза"		  , ДатаСреза);
	Запрос.УстановитьПараметр("Сотрудник"		  , Сотрудник);
	
	УсловиеСотрудник = ?(СотрудникПередан, "И РеквизитыОбъектов.Объект = &Сотрудник", "");
	Запрос.Текст     = СтрЗаменить(Запрос.Текст, "И &УсловиеСотрудник", УсловиеСотрудник);
	
	УсловиеУслугиСотрудника = ?(СотрудникПередан, "И УслугиСотрудника.Сотрудник = &Сотрудник", "");
	Запрос.Текст     = СтрЗаменить(Запрос.Текст, "И &УсловиеУслугиСотрудника", УсловиеУслугиСотрудника);
	
	ПакетЗапросов 	   = Запрос.ВыполнитьПакет();
	ТаблицаУслуг 	   = ПакетЗапросов[3].Выгрузить();
	ТаблицаСотрудников = ПакетЗапросов[4].Выгрузить();
	ТаблицаВидовЦен    = ПакетЗапросов[5].Выгрузить();
	
	ТаблицаМаксИнтерваловСотрудников = РегистрыСведений.СвободныеИнтервалыСотрудников.ПолучитьМаксимальныйИнтервалПоСотрудникам(
		СтруктурнаяЕдиница,
		ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник"),
		?(ДатаСрезаЗаполнена, ДатаСреза, Неопределено));
		
	ТаблицаДобавленныхУслуг = Новый ТаблицаЗначений;
	ТаблицаДобавленныхУслуг.Колонки.Добавить("Номенклатура");
	ТаблицаДобавленныхУслуг.Колонки.Добавить("СтрокаНоменклатуры");
	
	Для Каждого СтрокаТЧ Из ТаблицаУслуг Цикл
		
		Если ТаблицаДобавленныхУслуг.НайтиСтроки(Новый Структура("Номенклатура", СтрокаТЧ.Номенклатура)).Количество() = 0 Тогда
			
			МассивСтрок = ТаблицаМаксИнтерваловСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Если МассивСтрок.Количество() > 0 И МассивСтрок[0].МаксимальнаяДлительность >= СтрокаТЧ.НормаВремениПоСотруднику Тогда
				
				НоваяСтрока = ТаблицаДобавленныхУслуг.Добавить();
				НоваяСтрока.Номенклатура 	   = СтрокаТЧ.Номенклатура;
				НоваяСтрока.СтрокаНоменклатуры = СтрокуТаблицыЗначенийВСтруктуру(СтрокаТЧ, "Номенклатура,Наименование,Категория,КатегорияНаименование,НормаВремени,НормаВремениПоСотруднику,Комментарий");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаОдновременныхУслуг 		  = Неопределено;
	
	МассивУслуг 	 = Новый Массив;
	ИндексСортировки = 0;
	Для Каждого СтрокаТЧ Из ТаблицаДобавленныхУслуг Цикл
		
		МассивОдновременныхУслуг = Новый Массив;
		МассивУслуг.Добавить(ПолучитьСтруктуруУслуги(СтрокаТЧ.СтрокаНоменклатуры, СотрудникПередан, ТаблицаВидовЦен, МассивОдновременныхУслуг, ИндексСортировки, ДляЧатБота));
		ИндексСортировки = ИндексСортировки + 1;
		
	КонецЦикла;
	
	Возврат Новый Структура("Parameters, Errors", МассивУслуг, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция, возвращает структуру услуги.
// 
Функция ПолучитьСтруктуруУслуги(СтрокаТЧ, СотрудникПередан, ТаблицаВидовЦен, МассивОдновременныхУслуг, ИндексСортировки, ДляЧатБота = Ложь)
	
	СтруктураЦен = ПолучитьЦеныНоменклатуры(СтрокаТЧ.Номенклатура, ТаблицаВидовЦен);
	
	ДанныеУслуги = Новый Структура;
	Если ДляЧатБота Тогда 
		ДанныеУслуги.Вставить("service"	, СтрокаТЧ.Номенклатура);
	КонецЕсли;		
	ДанныеУслуги.Вставить("id"		  		, Строка(СтрокаТЧ.Номенклатура.УникальныйИдентификатор()));
	ДанныеУслуги.Вставить("title"	  		, СтрокаТЧ.Наименование);
	ДанныеУслуги.Вставить("category"  		, ПолучитьСтруктуру_id_title(СтрокаТЧ.Категория, СтрокаТЧ.КатегорияНаименование, Истина));
	ДанныеУслуги.Вставить("price_min" 		, СтруктураЦен.МинимальнаяЦена);
	ДанныеУслуги.Вставить("price_max" 		, СтруктураЦен.МаксимальнаяЦена);
	ДанныеУслуги.Вставить("comment"   		, СтрокаТЧ.Комментарий);
	ДанныеУслуги.Вставить("active"	  		, Истина);
	ДанныеУслуги.Вставить("length"    		, ?(СотрудникПередан, СтрокаТЧ.НормаВремениПоСотруднику, СтрокаТЧ.НормаВремени));
	
	Если Не СотрудникПередан Тогда
		
		ДанныеУслуги.Вставить("ServicesAtSameTime", Новый Массив);
		
		Для Каждого ОдновременнаяУслуга Из МассивОдновременныхУслуг Цикл
			ДанныеУслуги.ServicesAtSameTime.Добавить(Строка(ОдновременнаяУслуга.УникальныйИдентификатор()));
		КонецЦикла;
		
	КонецЕсли;
	
	ДанныеУслуги.Вставить("sort_index", ИндексСортировки);
	
	Возврат ДанныеУслуги;
	
КонецФункции

#КонецОбласти

#Область book_staff

// Функция, возвращает список сотрудников доступных для бронирования.
// 
Функция book_staff(СтруктурнаяЕдиница, datetime, service_ids, service_id, БазовыйURL = "", ApiKey = "", ДляЧатБота = Ложь, ВнешняяСистема = Неопределено) Экспорт
	
	СтруктураОшибки = Неопределено;
	
	МассивУслуг = ПолучитьМассивУслугПоИдентификаторам(service_ids, service_id, СтруктураОшибки);
	ДатаСреза   = ПолучитьИПроверитьДату(datetime, СтруктураОшибки);
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	
	ДатаСрезаЗаполнена 			 = ЗначениеЗаполнено(ДатаСреза);
	ДатаСреза 		   			 = ПолучитьДатуСреза(ДатаСреза, ДатаСрезаЗаполнена, СтруктурнаяЕдиница);
	ПроверятьВремяДействияУслуги = МассивУслуг.Количество() = 1;
	
	Если МассивУслуг.Количество() > 1 Тогда
		ТаблицаСотрудников = ПолучитьСотрудниковСпособныхОказатьМассивУслуг(СтруктурнаяЕдиница, МассивУслуг, ДатаСреза);
	Иначе
		ТаблицаСотрудников = ПолучитьСотрудниковСНормойВремени(СтруктурнаяЕдиница, МассивУслуг, ДатаСреза);
	КонецЕсли;
	
	МассивСотрудников = Новый Массив;
	
	ТаблицаДоступныхДнейПоСотрудникам = Новый ТаблицаЗначений;
	ТаблицаДоступныхДнейПоСотрудникам.Колонки.Добавить("Сотрудник");
	ТаблицаДоступныхДнейПоСотрудникам.Колонки.Добавить("ДоступныйДень");
	ТаблицаДоступныхДнейПоСотрудникам.Колонки.Добавить("СтрокаСДаннымиСотрудника");
	
	Если ТаблицаСотрудников.Количество() > 0 Тогда
		
		ТаблицаИнтервалов = ПолучитьСвободныеИнтервалы(
			СтруктурнаяЕдиница, 
			ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник"),, 
			?(ДатаСрезаЗаполнена, ДатаСреза, Неопределено),,
			Не ДатаСрезаЗаполнена,
		    ВнешняяСистема);
		
		Для Каждого СтрокаТЧ Из ТаблицаИнтервалов Цикл
			
			СтрокаСДаннымиСотрудника = ТаблицаСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник))[0];
			МинНормаВремени 		 = СтрокаСДаннымиСотрудника.НормаВремени;
			
			Если СтрокаТЧ.Длительность >= МинНормаВремени
				И ТаблицаДоступныхДнейПоСотрудникам.НайтиСтроки(Новый Структура("Сотрудник, ДоступныйДень", СтрокаТЧ.Сотрудник, СтрокаТЧ.ДеньИнтервала)).Количество() = 0 
				И НачалоДня(ДатаСреза) <= НачалоДня(СтрокаТЧ.ДеньИнтервала) Тогда
				
				НоваяСтрока 			  			 = ТаблицаДоступныхДнейПоСотрудникам.Добавить();
				НоваяСтрока.Сотрудник 	  			 = СтрокаТЧ.Сотрудник;
				НоваяСтрока.ДоступныйДень 			 = СтрокаТЧ.ДеньИнтервала;
				НоваяСтрока.СтрокаСДаннымиСотрудника = СтрокаСДаннымиСотрудника;
			КонецЕсли;
			
		КонецЦикла;
		
		МассивДобавленныхСотрудников = Новый Массив;
		Для Каждого СтрокаТЗ Из ТаблицаДоступныхДнейПоСотрудникам Цикл
			
			Если МассивДобавленныхСотрудников.Найти(СтрокаТЗ.Сотрудник) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			МассивСтрокПоСотруднику   = ТаблицаДоступныхДнейПоСотрудникам.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЗ.Сотрудник));
			МассивДоступныхДней 	  = Новый Массив;
			КоличествоДобавленныхДней = 0;
			
			Для Каждого СтрокаДоступныйДень Из МассивСтрокПоСотруднику Цикл
				
				МассивДоступныхДней.Добавить(СтрокаДоступныйДень.ДоступныйДень);
				
				КоличествоДобавленныхДней = КоличествоДобавленныхДней + 1;
				
				Если КоличествоДобавленныхДней = 3 Тогда
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			МассивСотрудников.Добавить(ПолучитьСтруктуруСотрудника(СтруктурнаяЕдиница, СтрокаТЗ.СтрокаСДаннымиСотрудника, БазовыйURL, ApiKey, МассивДоступныхДней, ДляЧатБота));
			МассивДобавленныхСотрудников.Добавить(СтрокаТЗ.Сотрудник);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если МассивСотрудников.Количество() = 0 И МассивУслуг.Количество() > 1 Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1080);
	КонецЕсли;
	
	Возврат Новый Структура("Parameters, Errors", МассивСотрудников, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция, возвращает структуру сотрудника.
// 
Функция ПолучитьСтруктуруСотрудника(СтруктурнаяЕдиница, СтрокаТЧ, БазовыйURL = "", ApiKey = "", МассивДоступныхДней, ДляЧатБота = Ложь) Экспорт
	
	АдресКартинки = Неопределено;
	Если ЗначениеЗаполнено(СтрокаТЧ.РасширениеФото) Тогда
		АдресКартинки = "" + БазовыйURL + "/files/" + ApiKey + "/" + Строка(СтрокаТЧ.Сотрудник.УникальныйИдентификатор()) + "-" + Формат(СтрокаТЧ.РазмерФото, "ЧГ=") + "." + СтрокаТЧ.РасширениеФото;
	КонецЕсли;
	
	ДанныеСотрудника = Новый Структура;
	Если ДляЧатБота Тогда 
		ДанныеСотрудника.Вставить("staff"  		, СтрокаТЧ.Сотрудник);
	КонецЕсли;	
	ДанныеСотрудника.Вставить("id"  		  	, Строка(СтрокаТЧ.Сотрудник.УникальныйИдентификатор()));
	ДанныеСотрудника.Вставить("name" 		  	, СтрокаТЧ.Наименование);
	ДанныеСотрудника.Вставить("specialization"	, ПолучитьСтруктуру_id_title(СтрокаТЧ.Должность, СтрокаТЧ.ДолжностьНаименование, Истина));
	ДанныеСотрудника.Вставить("weight"        	, СтрокаТЧ.Вес);
	ДанныеСотрудника.Вставить("information"   	, ПолучитьЗначениеРеквизита(СтрокаТЧ.Сотрудник, "ОписаниеДляСайтаHTML"));
	ДанныеСотрудника.Вставить("avatar"        	, АдресКартинки);
	ДанныеСотрудника.Вставить("upcoming_dates"	, МассивДоступныхДней);
	
	
	ДанныеСотрудника.Вставить("ratings"       , Новый Массив);
	ДанныеСотрудника.Вставить("comments_count", 0);
			
	Возврат ДанныеСотрудника;
	
КонецФункции

#КонецОбласти

#Область book_dates

// Функция возвращает список дат, доступных для бронирования.
// 
Функция book_dates(СтруктурнаяЕдиница, start_date, end_date, service_ids, service_id, staff_id, ВнешняяСистема) Экспорт
	
	СтруктураОшибки = Неопределено;
	
	НачалоПериода = ПолучитьНачалоПериода(start_date, СтруктураОшибки, Истина, Истина);
	КонецПериода  = ПолучитьКонецПериода(end_date	, СтруктураОшибки, Истина);
	МассивУслуг	  = ПолучитьМассивУслугПоИдентификаторам(service_ids, service_id, СтруктураОшибки);
	Сотрудник 	  = ПолучитьСсылкуПоИдентификатору(staff_id, СтруктураОшибки, Истина, "Сотрудники", 1050);
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	ПроверятьВремяДействияУслуги = МассивУслуг.Количество() = 1;
	МассивДоступныхДней 		 = Новый Массив;
	ТаблицаСотрудников  		 = ПолучитьСотрудниковСНормойВремени2(СтруктурнаяЕдиница, Сотрудник, МассивУслуг, ТекущаяДатаСеанса());
	
	Если ТаблицаСотрудников.Количество() > 0 Тогда
		
		ВремТаблицаСотрудников = ТаблицаСотрудников.Скопировать(,"Сотрудник");
		ВремТаблицаСотрудников.Свернуть("Сотрудник");
		
		МассивСотрудников = ВремТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник");
		ТаблицаИнтервалов = ПолучитьСвободныеИнтервалы(СтруктурнаяЕдиница, МассивСотрудников,, НачалоПериода, КонецПериода,, ВнешняяСистема);
		
		Если ПроверятьВремяДействияУслуги Тогда
			ДатаВПродажеДо = ПолучитьДатуОкончанияПродажиНоменклатуры(СтруктурнаяЕдиница, МассивУслуг[0]);
		КонецЕсли;
		
		Для Каждого СтрокаТЧ Из ТаблицаИнтервалов Цикл
			
			Если ПроверятьВремяДействияУслуги И ЗначениеЗаполнено(ДатаВПродажеДо) И НачалоДня(ДатаВПродажеДо) <= СтрокаТЧ.ДеньИнтервала Тогда
				Прервать;
			КонецЕсли;
			
			МассивСтрок = ТаблицаСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Если Не ЗначениеЗаполнено(МассивУслуг) ИЛИ МассивСтрок.Количество() = МассивУслуг.Количество() Тогда
				
				Если ЗначениеЗаполнено(МассивУслуг) Тогда
					
					МинНормаВремени = 0;
					Для Каждого НайденнаяСтрока Из МассивСтрок Цикл
						МинНормаВремени = МинНормаВремени + НайденнаяСтрока.НормаВремениПоСотруднику;
					КонецЦикла;
					
				Иначе
					МинНормаВремени = МассивСтрок[0].НормаВремениПоСотруднику;
				КонецЕсли;
				
				Если МассивДоступныхДней.Найти(СтрокаТЧ.ДеньИнтервала) = Неопределено
					И СтрокаТЧ.Длительность >= МинНормаВремени Тогда
					
					МассивДоступныхДней.Добавить(СтрокаТЧ.ДеньИнтервала);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Новый Структура("Parameters, Errors", МассивДоступныхДней, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция - Re book dates
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  start_date			 - 	 - 
//  end_date			 - 	 - 
//  service_ids			 - 	 - 
//  service_id			 - 	 - 
//  staff_id			 - 	 - 
//  ВнешняяСистема		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция re_book_dates(СтруктурнаяЕдиница
					, start_date
					, end_date
					, service_ids
					, service_id
					, staff_id
					, ВнешняяСистема					
					, reason_entry_id
					, duration = 0) Экспорт

	
	СтруктураОшибки = Неопределено;
	
	НачалоПериода 	= ПолучитьНачалоПериода(start_date, СтруктураОшибки, Истина, Истина);
	КонецПериода  	= ПолучитьКонецПериода(end_date	, СтруктураОшибки, Истина);
	МассивУслуг	  	= ПолучитьМассивУслугПоИдентификаторам(service_ids, service_id, СтруктураОшибки);
	Сотрудник 	  	= ПолучитьСсылкуПоИдентификатору(staff_id, СтруктураОшибки, Истина, "Сотрудники", 1050);
	ПричинаЗаписи	= ПолучитьСсылкуПоИдентификатору(reason_entry_id	, СтруктураОшибки	,		, "ПричиныЗаписи"	, 1130);
	Длительность	= duration;
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	ПроверятьВремяДействияУслуги = МассивУслуг.Количество() = 1;
	МассивДоступныхДней 		 = Новый Массив;
	ТаблицаСотрудников  		 = ПолучитьСотрудниковСНормойВремениДляПерезаписи(СтруктурнаяЕдиница, Сотрудник, МассивУслуг);
	
	Если ТаблицаСотрудников.Количество() > 0 Тогда
		
		ВремТаблицаСотрудников = ТаблицаСотрудников.Скопировать(,"Сотрудник");
		ВремТаблицаСотрудников.Свернуть("Сотрудник");
		
		МассивСотрудников = ВремТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник");
		ТаблицаИнтервалов = ПолучитьСвободныеИнтервалы(СтруктурнаяЕдиница, МассивСотрудников,, НачалоПериода, КонецПериода,, ВнешняяСистема);
		
		Если ПроверятьВремяДействияУслуги Тогда
			ДатаВПродажеДо = ПолучитьДатуОкончанияПродажиНоменклатуры(СтруктурнаяЕдиница, МассивУслуг[0]);
		КонецЕсли;
		
		Для Каждого СтрокаТЧ Из ТаблицаИнтервалов Цикл
			
			Если ПроверятьВремяДействияУслуги И ЗначениеЗаполнено(ДатаВПродажеДо) И НачалоДня(ДатаВПродажеДо) <= СтрокаТЧ.ДеньИнтервала Тогда
				Прервать;
			КонецЕсли;
			
			МассивСтрок = ТаблицаСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Если Не ЗначениеЗаполнено(МассивУслуг) ИЛИ МассивСтрок.Количество() = МассивУслуг.Количество() Тогда
				
				Если ЗначениеЗаполнено(МассивУслуг) Тогда
					
					МинНормаВремени = 0;
					Для Каждого НайденнаяСтрока Из МассивСтрок Цикл
						МинНормаВремени = МинНормаВремени + НайденнаяСтрока.НормаВремениПоСотруднику;
					КонецЦикла;
				ИначеЕсли ЗначениеЗаполнено(Длительность) Тогда 
					МинНормаВремени = Длительность;
				Иначе
					МинНормаВремени = МассивСтрок[0].НормаВремениПоСотруднику;
				КонецЕсли;
				
				Если МассивДоступныхДней.Найти(СтрокаТЧ.ДеньИнтервала) = Неопределено
					И СтрокаТЧ.Длительность >= МинНормаВремени Тогда
					
					МассивДоступныхДней.Добавить(СтрокаТЧ.ДеньИнтервала);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Новый Структура("Parameters, Errors", МассивДоступныхДней, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция - Получить конец периода
//
// Параметры:
//  end_date			 - 	 - 
//  СтруктураОшибки		 - 	 - 
//  ОбязательныйПараметр - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКонецПериода(end_date, СтруктураОшибки, ОбязательныйПараметр = Ложь) Экспорт
	
	КонецПериода = Неопределено;
	
	Если ЗначениеЗаполнено(end_date) Тогда
		Если ТипЗнч(end_date) = Тип("Строка") Тогда 
			КонецПериода = ПолучитьДату(end_date);
		ИначеЕсли ТипЗнч(end_date) = Тип("Дата") Тогда 
			КонецПериода = end_date;
		Иначе 
			КонецПериода = Неопределено;
		КонецЕсли;		
		
		Если НЕ ЗначениеЗаполнено(КонецПериода) Тогда
			СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(1054);
		КонецЕсли;
		
	ИначеЕсли ОбязательныйПараметр Тогда
		СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(1052);
	КонецЕсли;
	
	Возврат КонецПериода
	
КонецФункции

