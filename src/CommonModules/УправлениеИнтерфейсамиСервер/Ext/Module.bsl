	КнопкаВыводаОчисткиПериода.ЦветТекста 											= ?(СтрокаФильтр.СписокЗначений[0].Значение.ЗначениеФильтра = Новый СтандартныйПериод, Новый Цвет(65, 137, 199), Новый Цвет());
