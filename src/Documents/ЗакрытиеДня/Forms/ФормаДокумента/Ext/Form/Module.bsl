
#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик события ПриСозданииНаСервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Обработчик подсистемы "Дополнительные отчеты и обработки"
	ДополнительныеОтчетыИОбработкиСтоматология.ПриСозданииНаСервере(ЭтаФорма);
	
	СтруктураМеню = Новый Структура;
	
	СтруктураМеню.Вставить("ЗакрытиеБонусныхСчетов"                , "ГруппаЗакрытиеБонусныхСчетов");
    СтруктураМеню.Вставить("ГруппаСписаниеНачисленийБонусныхСчетов", "ГруппаСписаниеНачисленийБонусныхСчетов");
	//СтруктураМеню.Вставить("Дополнительно"                         , "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Статус = Перечисления.СтатусыРабочегоДня.Закрыт;
	КонецЕсли;
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
		
КонецПроцедуры //ПриСозданииНаСервере()

&НаСервере
// Обработчик события "ПослеЗаписиНаСервере".
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
КонецПроцедуры

&НаСервере
// Обработчик события "ПриЧтенииНаСервере".
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
КонецПроцедуры

&НаКлиенте
// Обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	ОбновитьЗаголовкиТабЧастей();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Процедура - обновляет заголоки табличных частей.
// 
Процедура ОбновитьЗаголовкиТабЧастей()
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Выбор" табличной части "ЗакрытиеБонусныхСчетов".
//
Процедура ЗакрытиеБонусныхСчетовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
		
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ЗакрытиеБонусныхСчетовБонусныйСчет" Тогда
		ОткрытьФорму("Справочник.БонусныеСчета.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.БонусныйСчет));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Выбор" табличной части "СписаниеНачисленийБонусныхСчетов".
//
Процедура СписаниеНачисленийБонусныхСчетовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
		
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ЗакрытиеБонусныхСчетовБонусныйСчет" Тогда
		ОткрытьФорму("Справочник.БонусныеСчета.ФормаОбъекта", Новый Структура("Ключ", Элемент.ТекущиеДанные.БонусныйСчет));
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикикомандФормы

&НаКлиенте
// Процедура - Скрыть показать дополнительно
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СкрытьПоказатьДополнительно(Команда)
	
	Элементы.ГруппаДополнительно.Видимость = НЕ Элементы.ГруппаДополнительно.Видимость;
	
КонецПроцедуры

#КонецОбласти