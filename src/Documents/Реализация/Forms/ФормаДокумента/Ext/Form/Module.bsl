// Процедура, завершение пробития чека на ФР.
//
Процедура ПробитьЧекЗавершение(РезультатВыполнения, Параметры) Экспорт
	
	Если РезультатВыполнения.Результат Тогда		
		// Установить полученное значение номера чека реквизиту документа.
		Если РезультатВыполнения.ВыходныеПараметры <> Неопределено Тогда
			// Объект.НомерСменыККМ = РезультатВыполнения.ВыходныеПараметры[0];
			Если Параметры.ТипЧека Тогда
				  			
				НомерФискальногоЧека = РезультатВыполнения.ВыходныеПараметры[1];
				// ПодключенаКассаLifePay = ПодключенаКассаLifePay(Объект.Касса);
				// Если ПодключенаКассаLifePay = Истина Тогда
				//	НомерВходящегоДокумента = РезультатВыполнения.ВыходныеПараметры[7];
				// ИначеЕсли ПодключенаКассаCloudKassir(Объект.Касса) Тогда
				//	НомерВходящегоДокумента = РезультатВыполнения.ВыходныеПараметры[7];
				// ИначеЕсли ОбщегоНазначения.ПодключенаКассаЭвотор(Объект.Касса) Тогда
				//	НомерФискализацииЭвотор = РезультатВыполнения.ВыходныеПараметры[7];
				// КонецЕсли;  
				
				// запись номера с префиксом (для Топ Стречинга)
				// СтруктураДанныхПрефикса = ПолучитьПризнакЗаписыватьНомерЧекаСПрефиксомВНомерВходящегоДокумента(Объект.Касса); 
				// Если СтруктураДанныхПрефикса.ЗаписыватьНомерЧекаСПрефиксомВНомерВходящегоДокумента Тогда // и Префикс <> ""   					
				//	Объект.НомерВходящегоДокумента = "" + СтруктураДанныхПрефикса.Префикс + "" + НомерФискальногоЧека; 
				// КонецЕсли; 
				// ----------------------------------------------
				
				// Если ФискальныеОперации не был записан - произошла ошибка при записи.
				Если РезультатВыполнения.ВыходныеПараметры.Количество() > 8 Тогда
					ПараметрыФискализации = РезультатВыполнения.ВыходныеПараметры[8];
					Если НЕ ПараметрыФискализации.ОперацияЗаписана Тогда
						МенеджерОборудованияВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации);
					КонецЕсли;
					Если НЕ ПустаяСтрока(ПараметрыФискализации.ЧекКоррекцииСторно)
						И НЕ ПараметрыФискализации.ЧекКоррекцииСторно.ОперацияЗаписана Тогда
						МенеджерОборудованияВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации.ЧекКоррекцииСторно);
					КонецЕсли;
				КонецЕсли;       

			Иначе
				НомерНефискальногоЧека = РезультатВыполнения.ВыходныеПараметры[1];
			КонецЕсли;			
		КонецЕсли;
		
	Иначе 		
		ТекстСообщения = НСтр("ru='При печати чека произошла ошибка.
		|Чек не напечатан на фискальном регистраторе.
		|Дополнительное описание:
		|%ДополнительноеОписание%';
		|en='With print check happened mistake.
		|Check not printedby on fiscal registrar.
		|Additional description:
		|%ДополнительноеОписание%'");
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", РезультатВыполнения.ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);                                         		
	КонецЕсли;
	
	УстановитьДоступностьПечатиЧека();
	
КонецПроцедуры

