// Процедура - Изменение данных законного представителя
// Завершение немодального открытия окна "ПоказатьВопрос()" 
// Параметры:
//  РезультатВопроса - Ответ на вопрос
//  Параметры	     - Параметры вопроса 
//
Процедура ИзменениеДанныхЗаконногоПредставителяЗавершение(РезультатВопроса, Параметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да  Тогда  
		КлючСтруктурой = Новый Структура("Контрагент, Родственник", Объект.Контрагент, Параметры);	
		ПараметрыМассив = Новый Массив;
		ПараметрыМассив.Добавить(КлючСтруктурой);   		
		КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.РодственныеСвязи", ПараметрыМассив);
		ОткрытьФорму("РегистрСведений.РодственныеСвязи.Форма.ФормаЗаписиБыстрая", Новый Структура("Ключ", КлючЗаписиРегистра),,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);// РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаТоварыНоменклатураАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
