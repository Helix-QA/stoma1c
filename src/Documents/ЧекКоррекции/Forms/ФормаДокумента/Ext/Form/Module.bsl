&НаКлиенте
// Процедура обработчик события "ПриИзменении".
//
Процедура СтруктурнаяЕдиницаНеприменениеККТПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
		Объект.Организация = ПолучитьОрганизациюСтруктурнойЕдиницы(Объект.СтруктурнаяЕдиница);
	Иначе
		Объект.Организация = Неопределено;
	КонецЕсли;
	
	Объект.Касса = Неопределено;
	
КонецПроцедуры    

