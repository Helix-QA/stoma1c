
#Область СлужебныйПрограммныйИнтерфейс

// Процедура - При начале работы системы
//
Процедура ПриНачалеРаботыСистемы() Экспорт
	
	//ПараметрыКлиента = СтандартныеПодсистемыКлиент.ПараметрыРаботыКлиентаПриЗапуске();
	//ЛичныйКабинет.ПриНачалеРаботыСистемы(ПараметрыКлиента);	
	Если НЕ СтандартныеПодсистемыКлиент.ПараметрыРаботыКлиентаПриЗапуске().Свойство("НеобходимоОбновлениеПараметровРаботыПрограммы") Тогда 
		ЛичныйКабинет.ПриНачалеРаботыСистемы();
	КонецЕсли;
	ПодключитьОбработчикОжидания("ОбработчикОжиданияОтложенногоВызоваПроверкиРегистрацииАнкетыПродукта",60, Истина);
	ПодключитьОбработчикОжидания("ОбработчикОжиданияОповещенияОРегистрацииПрограммногопродукта"		   ,60, Истина);
	ПодключитьОбработчикОжидания("ОбработчикОжиданияПроверкаНеобходимостиПополненияБалансаСмсСервиса"  ,40, Истина);
	ПодключитьОбработчикОжидания("ОбработчикОжиданияПроверкаВозможностиПолученияПодарка" 	   		   ,60, Истина);
	ПодключитьОбработчикОжидания("ОбработчикОжиданияПроверкаНаличияСчетовДляОплаты" 	   		       ,120, Истина);
	
КонецПроцедуры

