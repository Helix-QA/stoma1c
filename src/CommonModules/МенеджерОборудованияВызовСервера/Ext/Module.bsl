// Процедура, выводит область клиента.
//
Процедура ВывестиОбластьКлиента(ТабДок, Макет, ШиринаПречека, Клиент, ОблПодвал = Неопределено)
	
	ОблКлиент  = Макет.ПолучитьОбласть("ИнформацияПоКлиенту" + ШиринаПречека);
	ОблПодпись = Макет.ПолучитьОбласть("Подпись" + ШиринаПречека);
	
	ОблКлиент.Параметры.Клиент = Клиент;
	ТабДок.Вывести(ОблКлиент);
	Если ОблПодвал <> Неопределено Тогда
		ТабДок.Вывести(ОблПодвал);
	КонецЕсли;
	ТабДок.Вывести(ОблПодпись);
	Если ОблПодвал <> Неопределено Тогда
		ТабДок.Вывести(ОблПодвал);
	КонецЕсли;
	
КонецПроцедуры

