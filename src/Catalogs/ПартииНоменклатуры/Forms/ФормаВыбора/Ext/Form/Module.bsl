
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если  ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	ПодборСерийников = Ложь;
	// Отбор по владельцу. Обязателен!
	Если Параметры.Свойство("Владелец") И ЗначениеЗаполнено(Параметры.Владелец) Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Владелец", Параметры.Владелец, Истина, ВидСравненияКомпоновкиДанных.Равно);
		Если Параметры.Владелец.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда 
			ПодборСерийников = Истина;
		КонецЕсли;	
	Иначе
		Отказ = Истина;
	КонецЕсли;
	// Отбор по структурной единице
	Если Параметры.Свойство("СтруктурнаяЕдиница") Тогда
		Список.Параметры.УстановитьЗначениеПараметра("СтруктурнаяЕдиница", Параметры.СтруктурнаяЕдиница);
	Иначе
		Список.Параметры.УстановитьЗначениеПараметра("СтруктурнаяЕдиница", Неопределено);
	КонецЕсли;
    // Отбор по периоду
    Если Параметры.Свойство("Дата") Тогда
	    Список.Параметры.УстановитьЗначениеПараметра("Период", КонецДня(Параметры.Дата));
	Иначе
		Список.Параметры.УстановитьЗначениеПараметра("Период", ТекущаяДата());
	КонецЕсли;	
	// Отбор по складу
	Если Параметры.Свойство("Склад") Тогда		
		Список.Параметры.УстановитьЗначениеПараметра("Склад", Параметры.Склад);	
		Элементы.ОстатокНаСкладе.Видимость        = Истина;
        Элементы.ОстатокСуммаСертификат.Видимость = Ложь;	
		Если НЕ Параметры.Свойство("НеКонтролироватьОстаткиПоСкладу") Тогда
			ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОстаткоКоличествоСклад", 0, Истина, ВидСравненияКомпоновкиДанных.Больше);
			ЭтаФорма.Заголовок = "Выбор серии имеющейся в наличии"
		КонецЕсли;
	ИначеЕсли Параметры.Свойство("ОтборСерииСертификата") Тогда		
		ОтборСерииСертификата = Истина;
		Список.Параметры.УстановитьЗначениеПараметра("Склад", Неопределено);		
		Элементы.ОстатокНаСкладе.Видимость        = Ложь;
        Элементы.ОстатокСуммаСертификат.Видимость = Истина;
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОстатокСуммаСертификат", 0, Истина, ВидСравненияКомпоновкиДанных.Больше);
	Иначе
		Список.Параметры.УстановитьЗначениеПараметра("Склад", Неопределено);
		Фильтр = Истина;
	КонецЕсли;	
	// Отбор по контрагенту владельцу	
	Если Параметры.Свойство("Контрагент") Тогда
	    Список.Параметры.УстановитьЗначениеПараметра("КонтрагентВладелец", Параметры.Контрагент);
	Иначе
		Список.Параметры.УстановитьЗначениеПараметра("КонтрагентВладелец", Неопределено);
	КонецЕсли;	

	Если (Параметры.Свойство("МножественныйВыбор") И Параметры.МножественныйВыбор = Истина) ИЛИ ПодборСерийников Тогда
		Элементы.Список.РежимВыделения = РежимВыделенияТаблицы.Множественный;
	Иначе
		Элементы.Список.РежимВыделения = РежимВыделенияТаблицы.Одиночный;
	КонецЕсли;
	
	Если Параметры.Свойство("МножественныйВыборСтрок") И Параметры.МножественныйВыборСтрок = Ложь Тогда
		Элементы.Список.РежимВыделения = РежимВыделенияТаблицы.Одиночный;
	КонецЕсли;	
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ФильтрПриИзменении(Элемент)
	
	Если Фильтр Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОстаткоКоличествоСклад", 0, Ложь, ВидСравненияКомпоновкиДанных.Больше);
	Иначе
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ОстаткоКоличествоСклад", 0, Истина, ВидСравненияКомпоновкиДанных.Больше);
	КонецЕсли;
	Элементы.Список.Обновить();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Выбор"
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ЭтаФорма.Закрыть(Элементы.Список.ВыделенныеСтроки);
		
КонецПроцедуры

#КонецОбласти                  

#Область ОбработчикиКомандФормы    

&НаКлиенте
// Процедура, обработчик события команды "Выбор"
//
Процедура Выбор(Команда)
	
	ЭтаФорма.Закрыть(Элементы.Список.ВыделенныеСтроки);
	
КонецПроцедуры

#КонецОбласти  