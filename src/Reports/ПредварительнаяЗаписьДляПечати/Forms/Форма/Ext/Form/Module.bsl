// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Функция ВернутьНомерНеделиМесяца(Знач Дата)
	
	НомерНедели = 1;
	Для а = 1 По День(КонецМесяца(Дата)) Цикл
		Если НачалоНедели(НачалоМесяца(Дата) + (а - 1) * 24 * 60 * 60) <> НачалоНедели(НачалоМесяца(Дата) + (а - 1 - 1) * 24 * 60 * 60) Тогда
			НомерНедели = НомерНедели + 1;
		КонецЕсли;		
		Если НачалоНедели(НачалоМесяца(Дата) + (а - 1) * 24 * 60 * 60) <= Дата И Дата <= КонецНедели(НачалоМесяца(Дата) + (а - 1) * 24 * 60 * 60) Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат НомерНедели;
	
КонецФункции

