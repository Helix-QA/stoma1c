// Процедура, ОбновитьСделку.
//
Процедура ОбновитьСделку(ИмяКоманды, Контрагент)
	
	Если СтрНайти(ИмяКоманды, "КомандаЭтап") > 0 Тогда		
		
		ИндексВиджета 	= ПолучитьИндексСтроки(ИмяКоманды, Ложь);
		ИндексЭтапа     = ПолучитьИндексСтроки(ИмяКоманды);
		НайденнаяСделка = ЭтотОбъект.ТаблицаСделок[ИндексВиджета].Сделка;

		УправлениеИнтерфейсамиСервер.ОбновитьЭтапСделки(НайденнаяСделка, ИндексЭтапа);
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() 
		И ЭтотОбъект.Статус <> Перечисления.СтатусыКонтрагентов.Потенциальный Тогда
		
		ЭтотОбъект.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный;
		// ОбновитьОформлениеКнопкиСтатусаКлиента();
		
	Иначе 
		
		ЭтотОбъект.Статус = Справочники.Контрагенты.ПолучитьСтатус(Объект.Ссылка);
