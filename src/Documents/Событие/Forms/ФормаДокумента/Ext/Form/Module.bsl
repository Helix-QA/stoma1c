// Процедура - Заполнить интервали длительности приема.
//
Процедура ЗаполнитьИнтервалиДлительностиПриема()
	
	Если Объект.Услуги.Количество() = 1 Тогда
		ТекущаяНормаВремени = Объект.Услуги[0].НормаВремени;
	Иначе
		ТекущаяНормаВремени = (Объект.Услуги[Объект.Услуги.Количество()-1].ДатаОкончания - Объект.Услуги[0].ДатаНачала) / 60;
	КонецЕсли;
			
	СписокИнтерваловДлительностиПриема.ЗагрузитьЗначения(РегистрыСведений.ДлительностиПриемов.ВернутьДлительностиПриемов(Истина));
	СписокИнтерваловДлительностиПриема.Вставить(0, Неопределено);
	
	Если НЕ СписокИнтерваловДлительностиПриема.НайтиПоЗначению(ТекущаяНормаВремени) = Неопределено Тогда
		СписокИнтерваловДлительностиПриема[0].Значение = "N";
	Иначе
		СписокИнтерваловДлительностиПриема[0].Значение = ТекущаяНормаВремени;
		СохранитьИлиУдалитьДлительностиПриемаНаСервере(ТекущаяНормаВремени);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Установить время длительности
//
Процедура УстановитьВремяДлительности(Команда)
	
	Если СписокИнтерваловДлительностиПриема[0].Значение <> "N" Тогда
		УдалитьЭтуДлительностьПриема(Команда);
		
		Если СписокИнтерваловДлительностиПриема[0].Значение = "N" Тогда
			
			// Скроем поле ввода если не завершили ввод времени, но нажали на созданную кнопку.
			
			ПолеВводаДлительность = Элементы.Найти("НовыйЭлементДлительностиПриема");	
			Если НЕ ПолеВводаДлительность = Неопределено Тогда
				ПолеВводаДлительность.Видимость = Ложь;
			КонецЕсли;
			
			КнопкаСохраненияДлительности = Элементы.Найти("СохранитьЭлементДлительностиПриема");
			Если НЕ КнопкаСохраненияДлительности = Неопределено Тогда
				КнопкаСохраненияДлительности.Видимость = Ложь;
			КонецЕсли;
			
		КонецЕсли;		
			
	Иначе
		ДлительностьНаТекущейКнопке = Число(СтрРазделить(ТекущийЭлемент.Имя, "_", Ложь)[1]);	
		
		ПолеВводаНовыйЭлементДлительностиПриема = Элементы.Найти("НовыйЭлементДлительностиПриема");
		Если НЕ ПолеВводаНовыйЭлементДлительностиПриема = Неопределено Тогда
			ПолеВводаНовыйЭлементДлительностиПриема.Видимость = Ложь;
		КонецЕсли;
		
		КнопкаСохранитьЭлементДлительностиПриема = Элементы.Найти("СохранитьЭлементДлительностиПриема");
		Если НЕ КнопкаСохранитьЭлементДлительностиПриема = Неопределено Тогда
			КнопкаСохранитьЭлементДлительностиПриема.Видимость = Ложь;	
		КонецЕсли;
		
		ИзменитьЭлементДлительностиПриема(ДлительностьНаТекущейКнопке, Неопределено, Ложь, ?(Элементы.Найти("ГруппаВыводаКнопокДлительности_0") = Неопределено, Неопределено, 0));
		ПересчетВремениОказанияУслуг(ДлительностьНаТекущейКнопке);
		
	КонецЕсли;
	
КонецПроцедуры

