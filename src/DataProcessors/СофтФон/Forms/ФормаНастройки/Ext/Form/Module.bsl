	Диалог.МножественныйВыбор = Ложь;
	Диалог.Показать(Новый ОписаниеОповещения("tbRingtoneNameНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура("Диалог", Диалог)));  
	
