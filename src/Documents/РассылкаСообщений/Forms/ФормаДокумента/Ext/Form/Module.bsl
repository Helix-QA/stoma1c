
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.РасширениеМессенджераПодключено = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") = Истина;
	
	Если Объект.ВидОперации.Пустая() Тогда
		Объект.ВидОперации = Перечисления.ВидОперацииОтправкаSMS.МассоваяРассылкаSMS;
	КонецЕсли;
	
	Элементы.ПолучателиПолучатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Если Не Объект.Ссылка.Пустая() И Объект.Проведен = Истина Тогда
		
		ЭтаФорма.ТолькоПросмотр							 = Истина;
		Элементы.ГруппаОтправкаSMS.Доступность			 = Ложь;
		Элементы.ГруппаОтправкаPush.Доступность			 = Ложь;
		Элементы.ГруппаОтправкаМессенджер.Доступность	 = Ложь;
		Элементы.ПолучателиГруппаКнопок.Доступность		 = Ложь;
		Элементы.ГруппаОтправлять.Доступность			 = Ложь;
		Элементы.БалансSMS.Доступность					 = Ложь;
		// Элементы.ГруппаОстановкаРассылки.Видимость     = Документы.РассылкаСообщений.НаличиеНеотправленныхСообщений(Объект.Ссылка);
		
		Элементы.ФормаКнопкаПровестиИЗакрыть.ЦветТекста		 = Новый Цвет(242, 242, 242);
		Элементы.ГруппаФормаКнопкаПровестиИЗакрыть.ЦветФона	 = Новый Цвет(166, 202, 240);
		
		ПрочитатьСтатусыСообщений();
		
		ОбновитьДанныеТаблицыПолучателей();
		УстановитьВидимостьНастроекСервисовРассылки();
		
	Иначе
		
		УстановитьВидимостьНастроекСервисовРассылки();
		
		Если Параметры.Свойство("Получатели")
			И ЗначениеЗаполнено(Параметры.Получатели) Тогда
			
			Для Каждого СтруктураПолучателя Из Параметры.Получатели Цикл
				
				НоваяСтрока                = Объект.Получатели.Добавить();
				НоваяСтрока.КлючСтроки     = Новый УникальныйИдентификатор();
				НоваяСтрока.Получатель     = СтруктураПолучателя.Получатель;
				НоваяСтрока.НомерТелефона  = СтруктураПолучателя.НомерТелефона;
				НоваяСтрока.СервисРассылки = ?(ЭтотОбъект.ДоступнаОтправкаSMS, ЭтотОбъект.ДоступныеСервисыРассылки.SMS[0], Неопределено);
				НоваяСтрока.ТипОтправки    = "sms";
				НоваяСтрока.Активность     = ЭтотОбъект.ДоступнаОтправкаSMS;
				
			КонецЦикла;
			
			Объект.Получатели.Сортировать("Получатель");
			ЗаполнитьПредставлениеКоличестваПолучателей();
			
		ИначеЕсли ЗначениеЗаполнено(Объект.Получатели) Тогда
			ОбновитьДанныеТаблицыПолучателей();	
			
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьСтатусВведеныхСимволов(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗаписью".
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Ссылка.Пустая() Тогда
		
		// Проверка наличия получателей.
		НайденныеСтроки = Объект.Получатели.НайтиСтроки(Новый Структура("Активность", Истина));
		Если НайденныеСтроки.Количество() = 0 Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Нет получателей сообщения'; en='No message recipients'"));
			Возврат;
		КонецЕсли;
		
		// Удаление неактивных строк.
		Индекс = 0;
		Пока Индекс < Объект.Получатели.Количество() Цикл
			
			СтрокаТ = Объект.Получатели[Индекс];
			Если Не СтрокаТ.Активность Тогда
				Объект.Получатели.Удалить(СтрокаТ);
				Продолжить;
			КонецЕсли;	
			
			Индекс = Индекс + 1;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - обработчик события ПередЗаписьюНаСервере формы.
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ТекущийОбъект.Ссылка.Пустая() Тогда
		
		ЗаполнитьПредставлениеКоличестваПолучателей();
		
		Если ЭтотОбъект.ОтправкаМессенджер
			И ЗначениеЗаполнено(ЭтотОбъект.ДоступныеСервисыРассылки.МессенджерОтправкаПервым) Тогда
			
			ПроверитьВозможностьОтправкиMessengerПередЗаписью(Отказ);	
		КонецЕсли;	
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - обработчик события ПослеЗаписиНаСервере формы.
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбновитьДанныеТаблицыПолучателей();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПослеЗаписи формы.
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ОбновитьИсториюВзаимодействияКонтрагента");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура УстановитьТипОтправкиМессенджер(Команда)
	
	Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер");
	УстановитьСостояниеЭлементовФормы(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Объект.Получатели) Тогда
		ЗаполнитьТаблицуПолучателей();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура УстановитьТипОтправкиPush(Команда)
	
	Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление");
	УстановитьСостояниеЭлементовФормы(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Объект.Получатели) Тогда
		ЗаполнитьТаблицуПолучателей();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура УстановитьТипОтправкиSMS(Команда)
	
	Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS");
	УстановитьСостояниеЭлементовФормы(ЭтотОбъект);
	
	ОбновитьСтатусВведеныхСимволов(ЭтотОбъект);
	
