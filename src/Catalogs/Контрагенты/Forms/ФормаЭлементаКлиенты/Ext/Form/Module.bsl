// Процедура "После вопроса о продолжении удаления скидки".
//
Процедура ПослеВопросаОПродолженииУдаленияСкидки(Ответ, ДопПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);	
		СтрокаДанных   = ЭтаФорма.СкидкиСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
		
		Если СтрокаДанных <> Неопределено Тогда
			
			СкидкаУдалена = УдалитьСкидку(Объект.Ссылка, СтрокаДанных.Скидка);
			
			Если СкидкаУдалена Тогда
				МассивРодителей = Новый Массив();
				МассивРодителей.Добавить("ГруппаСкидкиСуществующие");
				ОтображениеДополнительнойИнформации(МассивРодителей);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения.
//
Процедура ПослеВопросаОЗаписиКлиента(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Результат = ЭтаФорма.Записать();
		
		Если Результат Тогда
			
			Если Параметры.ВыполнитьДействие = "ЗаписьНаПрием" Тогда
				СоздатьПриемНаКлиенте();
			ИначеЕсли Параметры.ВыполнитьДействие = "СозданиеПланаЛечения" Тогда
				СоздатьПланЛеченияНаКлиенте();
			ИначеЕсли Параметры.ВыполнитьДействие = "ДобавитьПредварительнуюЗапись" Тогда
				ОткрытьЖурналЗаписиПоКлиенту(Объект.Ссылка);
			ИначеЕсли Параметры.ВыполнитьДействие = "СоздатьSMS" Тогда
				СоздатьSMSРассылкуНаКлиенте();
	        ИначеЕсли Параметры.ВыполнитьДействие = "СоздатьПисьмо" Тогда
				СоздатьПисьмоНаКлиенте(); 
			 ИначеЕсли Параметры.ВыполнитьДействие = "ОтправитьПоПочте" Тогда
				ОтправитьПоПочте(Параметры.ИндексЭлемента);
			ИначеЕсли Параметры.ВыполнитьДействие = "ПерейтиКДиалогу" Тогда
				Подключаемый_ПерейтиКДиалогу(Параметры.Элемент);
			КонецЕсли;
			
		КонецЕсли;
		
КонецЕсли;

КонецПроцедуры  

