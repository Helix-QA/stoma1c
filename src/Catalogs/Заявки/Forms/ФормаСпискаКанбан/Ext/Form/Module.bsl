Функция ПолучитьБлокКолонки(Статус, БлокиЗаявок, КоличествоЗаявок)
	
	ИмяСтатуса					 = XMLСтрока(Статус);
	ПредставлениеСтатуса		 = Статус;
	// КоличествоЗаявок			 = БлокиЗаявок.Количество() - 1; // Отнимаем единицу, т.к. в массив блоков добавлена кнопка перехода в список.
