
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

#Область Проведение

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылкаПланЛечения, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	&ВидДвижения,
	|	ПланЛеченияЛечение.КлючСтроки,
	|	ПланЛеченияЛечение.НомерПриема,
	|	ПланЛеченияЛечение.Ссылка.Дата КАК Период,
	|	ПланЛеченияЛечение.Зуб,
	|	ПланЛеченияЛечение.Номенклатура,
	|	ПланЛеченияЛечение.Ссылка.СтруктурнаяЕдиница,
	|	ПланЛеченияЛечение.Ссылка.Контрагент,
	|	СУММА(ПланЛеченияЛечение.Количество) КАК Количество,
	|	СУММА(ПланЛеченияЛечение.Сумма) КАК Сумма,
	|	ПланЛеченияЛечение.Ссылка
	|ПОМЕСТИТЬ ВременнаяТаблицаПланЛечения
	|ИЗ
	|	Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
	|ГДЕ
	|	ПланЛеченияЛечение.Ссылка = &Ссылка
	|	И НЕ ПланЛеченияЛечение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Отвергнут)
	|	И ВЫБОР
	|			КОГДА ПланЛеченияЛечение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Закрыт)
	|				ТОГДА НЕ ПланЛеченияЛечение.Прием = ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланЛеченияЛечение.КлючСтроки,
	|	ПланЛеченияЛечение.Номенклатура,
	|	ПланЛеченияЛечение.Ссылка,
	|	ПланЛеченияЛечение.Ссылка.СтруктурнаяЕдиница,
	|	ПланЛеченияЛечение.Ссылка.Контрагент,
	|	ПланЛеченияЛечение.Ссылка.Дата,
	|	ПланЛеченияЛечение.Зуб,
	|	ПланЛеченияЛечение.НомерПриема";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаПланЛечения);
	Запрос.УстановитьПараметр("ВидДвижения", ВидДвиженияНакопления.Приход);
	
	Запрос.ВыполнитьПакет();
	
	СформироватьТаблицаПланЛечения(ДокументСсылкаПланЛечения, СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаПланЛечения(ДокументСсылкаРеализация, СтруктураДополнительныеСвойства)
	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблицаПланЛечения.КлючСтроки,
	|	ВременнаяТаблицаПланЛечения.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаПланЛечения.Контрагент,
	|	ВременнаяТаблицаПланЛечения.НомерПриема,
	|	ВременнаяТаблицаПланЛечения.Зуб,
	|	ВременнаяТаблицаПланЛечения.Номенклатура,
	|	ВременнаяТаблицаПланЛечения.Ссылка КАК ПланЛечения,
	|	ВременнаяТаблицаПланЛечения.Количество,
	|	ВременнаяТаблицаПланЛечения.Сумма,
	|	ВременнаяТаблицаПланЛечения.Период,
	|	ВременнаяТаблицаПланЛечения.ВидДвижения
	|ИЗ
	|	ВременнаяТаблицаПланЛечения КАК ВременнаяТаблицаПланЛечения";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПланыЛечения", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры	

#КонецОбласти

#Область ДополнительныеПроцедурыФункции

// Вернуть ФИО ответственного лица организации
Функция ВернутьФИООтветственныеЛицаОрганизации(Организация)
	
	Запрос = Новый запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОтветственныеЛицаСрезПоследних.Сотрудник.Наименование КАК ФИО,
	|	ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица  КАК ТипОтветственногоЛица
	|ИЗ
	|	РегистрСведений.ОтветственныеЛица.СрезПоследних(
	|			,
	|			ТипОтветственногоЛица = ЗНАЧЕНИЕ(Перечисление.ТипыОтветственныхЛиц.ГлавныйБухгалтер)
	|				ИЛИ ТипОтветственногоЛица = ЗНАЧЕНИЕ(Перечисление.ТипыОтветственныхЛиц.Руководитель)
	|					И Организация = &Организация) КАК ОтветственныеЛицаСрезПоследних");
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция возвращает остаток указанной услуги по регистру "Планы лечения".
//
Функция ОстатокУслугПоПлануЛечения(Номенклатура, Контрагент, Зуб, СтруктурнаяЕдиница) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПланыЛеченияОстатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрНакопления.ПланыЛечения.Остатки(&ТекущаяДата, ) КАК ПланыЛеченияОстатки
	|ГДЕ
	|	ПланыЛеченияОстатки.Номенклатура = &Номенклатура
	|	И ПланыЛеченияОстатки.Контрагент = &Контрагент
	|	И ПланыЛеченияОстатки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ПланыЛеченияОстатки.Зуб = &Зуб");
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.УстановитьПараметр("Зуб", Зуб);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Количество;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции	

#КонецОбласти

#Область Печать

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ПланЛечения") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_ПланЛечения", "План лечения финансовый", СформироватьПечатнуюФормуПланЛечения(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ПланЛеченияМед") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_ПланЛеченияМед", "План лечения медицинский", СформироватьПечатнуюФормуПланЛеченияМедицинский(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
КонецПроцедуры // Печать()

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ФОРМИРОВАНИЯ ПЕЧАТНЫХ ФОРМ
// Функция, возвращающая табличный документ "Счет на оплату" для печати
//
Функция СформироватьПечатнуюФормуПланЛечения(МассивОбъектов, ОбъектыПечати)
	
	Если ИспользуетсяПользовательскийМакет("ПФ_MXL_ПланЛечения") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Внимание используется пользовательский макет печати. Рекомендуется использовать оригинальный макет.");
	КонецЕсли;
	ТабДокумент   = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПФ_MXL_ПланЛечения";
	Макет = УправлениеПечатью.ТабличныйДокументПоДвоичнымДанным(УправлениеПечатью.МакетПечатнойФормы("Документ.ПланЛечения.ПФ_MXL_ПланЛечения"));
	
	ПервыйДокумент    = Истина;
	
	Для Каждого Объект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент    = Ложь;
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;	
		
		ЭтоСтоматологическиеУслуги = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник); 
			
		ЗапросШапка = Новый Запрос;
		ЗапросШапка.УстановитьПараметр("ТекущийДокумент", Объект.Ссылка);
		ЗапросШапка.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетНаОплату.Номер КАК Номер,
		|	СчетНаОплату.Дата КАК Дата,
		|	СчетНаОплату.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
		|	СчетНаОплату.СуммаДокумента КАК СуммаДокумента,
		|	СчетНаОплату.СтруктурнаяЕдиница.Организация КАК Организация,
		|	СчетНаОплату.Контрагент КАК Получатель,
		|	СчетНаОплату.Сотрудник КАК Поставщик,
		|	СчетНаОплату.Ссылка
		|ИЗ
		|	Документ.ПланЛечения КАК СчетНаОплату
		|ГДЕ
		|	СчетНаОплату.Ссылка = &ТекущийДокумент";
		Шапка = ЗапросШапка.Выполнить().Выбрать();
		Шапка.Следующий();
		
		ЗапросУслуги = Новый Запрос;
		ЗапросУслуги.УстановитьПараметр("Ссылка", Объект.Ссылка);
		ЗапросУслуги.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПланЛеченияЛечение.Зуб КАК Зуб,
		|	ПланЛеченияЛечение.Номенклатура КАК Номенклатура,
		|	СУММА(ПланЛеченияЛечение.Сумма) КАК Сумма,
		|	СУММА(ЕСТЬNULL(ПланЛеченияЛечение.Количество, 0)) КАК Количество,
		|	ПланЛеченияЛечение.НомерПриема КАК НомерПриема,
		|	ЕСТЬNULL(ПланЛеченияЛечение.Цена, 0) КАК Цена,
		|	ПланЛеченияЛечение.СтавкаНДС КАК СтавкаНДС,
		|	СУММА(ПланЛеченияЛечение.СуммаНДС) КАК СуммаНДС,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ПланЛеченияЛечение.Количество * ПланЛеченияЛечение.Цена - ПланЛеченияЛечение.Сумма = 0
		|				ТОГДА 0
		|			ИНАЧЕ ВЫБОР
		|					КОГДА ПланЛеченияЛечение.Количество * ПланЛеченияЛечение.Цена / 100 <> 0
		|						ТОГДА (ПланЛеченияЛечение.Количество * ПланЛеченияЛечение.Цена - ПланЛеченияЛечение.Сумма) / (ПланЛеченияЛечение.Количество * ПланЛеченияЛечение.Цена / 100)
		|				КОНЕЦ
		|		КОНЕЦ) КАК ПроцентСкидкиНаценки,
		|	СУММА(ПланЛеченияЛечение.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
		|	ПланЛеченияЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг КАК Артикул,
		|	ПланЛеченияЛечение.НомерСтроки КАК НомерСтроки,
		|	СУММА(ПланЛеченияЛечение.Цена * ПланЛеченияЛечение.Количество) КАК СуммаБезСкидки
		|ИЗ
		|	Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
		|ГДЕ
		|	ПланЛеченияЛечение.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПланЛеченияЛечение.Зуб,
		|	ПланЛеченияЛечение.Номенклатура,
		|	ПланЛеченияЛечение.НомерПриема,
		|	ПланЛеченияЛечение.СтавкаНДС,
		|	ПланЛеченияЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг,
		|	ПланЛеченияЛечение.Цена,
		|	ПланЛеченияЛечение.НомерСтроки
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ
		|	СУММА(Сумма),
		|	СУММА(Количество),
		|	СУММА(СуммаНДС),
		|	СУММА(ПроцентСкидкиНаценки),
		|	СУММА(СуммаАвтоматическойСкидкиНаценки),
		|	СУММА(СуммаБезСкидки)
		|ПО
		|	НомерПриема,
		|	Номенклатура"; 	
		
		ТаблицаЛечение 			= ЗапросУслуги.Выполнить().Выгрузить();
		ВыборкаТаблицаЛечение 	= ЗапросУслуги.Выполнить();
		
		// Вывод реквизитов организации
		Если Макет.Области.Найти("РеквизитыОрганизации") <> Неопределено Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("РеквизитыОрганизации");
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "ПредставлениеОрганизации") Тогда 
				ПолноеПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, Шапка.Дата), "ПолноеНаименование,");
				ПредставлениеОрганизации       = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Шапка.Организация, "Наименование");
				ОбластьМакета.Параметры.ПредставлениеОрганизации = ?(ЗначениеЗаполнено(ПолноеПредставлениеОрганизации), ПолноеПредставлениеОрганизации, ПредставлениеОрганизации); 			
			КонецЕсли;
			
			ФактАдрес = Шапка.Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, "Вид");
			ЮрАдрес   = Шапка.Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Вид");
			
			Если ЕстьПараметрОбласти(ОбластьМакета.Параметры, "АдресОрганизации") Тогда
				
				Если НЕ ФактАдрес = Неопределено Тогда
					Адрес = ФактАдрес.Представление;
				ИначеЕсли НЕ ЮрАдрес = Неопределено Тогда
					Адрес = ЮрАдрес.Представление;
				КонецЕсли;
 
				ОбластьМакета.Параметры.АдресОрганизации = ?(ЗначениеЗаполнено(Адрес), Адрес, ""); 
			КонецЕсли;
			
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		
		ВидыВыводимойКИ = Новый Массив;
		ВидыВыводимойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации);
		ВидыВыводимойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ФаксОрганизации);
		ВидыВыводимойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.EmailОрганизации);
		
		Для Каждого ВидКонтактнойИнформации Из ВидыВыводимойКИ Цикл
			
			СтрокаКИ = Шапка.Организация.КонтактнаяИнформация.Найти(ВидКонтактнойИнформации, "Вид");		
