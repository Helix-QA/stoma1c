
#Область ОбработчикиСобытий

&НаКлиенте
// Процедура, обработчик команды
//
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	МассивЛабораторий = ВернутьМассивЛабораторий(ПараметрКоманды);	
	ПараметрыФормы = Новый Структура("СписокЛабораторий, Документ", МассивЛабораторий, ПараметрКоманды);
	ОткрытьФорму("Документ.НарядЗаказ.Форма.ФормаСозданияПоступления", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
		
КонецПроцедуры

&НаСервере
// Функция, возвращает массив лабораторий
//
Функция ВернутьМассивЛабораторий(НарядЗаказ)
	
	ТаблицаЛабораторий = НарядЗаказ.Запасы.Выгрузить(,"Лаборатория");
	ТаблицаЛабораторий.Свернуть("Лаборатория");
	Возврат ТаблицаЛабораторий.ВыгрузитьКолонку("Лаборатория");
	
КонецФункции

#КонецОбласти