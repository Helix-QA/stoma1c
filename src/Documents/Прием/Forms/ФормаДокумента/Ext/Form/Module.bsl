// Загрузить значения парамтеров шаблона из регистра храрения
//
Процедура ПолучитьДанныеДокументаОбследования()
	НаборЗаписей = РегистрыСведений.ЗначенияПараметровОбследований.СоздатьНаборЗаписей();	
	НаборЗаписей.Отбор.Документ.Установить(Объект.Ссылка);	
	НаборЗаписей.Отбор.ШаблонОбследования.Установить(Объект.ШаблонОбследования);
	НаборЗаписей.Прочитать();	
	ДОЗначенияРеквизитовОбследования.Очистить();
	
	// Для реквизита типа "Строка" в значение сохранен обрезанный до 100 символов текст (293291).
	
	Для Каждого Запись Из НаборЗаписей Цикл
		
		КодМКБ10 = ?(ТипЗнч(Запись.Значение) = Тип("СправочникСсылка.Диагнозы"), ОбщегоНазначения.ПолучитьЗначениеРеквизита(Запись.Значение, "Код"), "");
		
		НоваяСтрока                        = ДОЗначенияРеквизитовОбследования.Добавить();
		НоваяСтрока.Реквизит               = Запись.Параметр;	
		НоваяСтрока.РеквизитИдентификатор  = Запись.Параметр.УникальныйИдентификатор();
		НоваяСтрока.РеквизитЗначение       = ?(ТипЗнч(Запись.Значение) = Тип("Строка"), Запись.ЗначениеСтрокой, Запись.Значение);
		НоваяСтрока.РеквизитЗначениеСтрокой = "" + ?(Запись.ЗначениеСтрокой <> "", Запись.ЗначениеСтрокой, Запись.Значение) + 
												   ?(ЗначениеЗаполнено(КодМКБ10), " ("+СокрЛП(КодМКБ10)+")", "");
		НоваяСтрока.ЗубЗначение            = Запись.Зуб;
		НоваяСтрока.ЗубИдентификатор       = Новый УникальныйИдентификатор;//?(НоваяСтрока.Реквизит.ПривязкаКЗубам, Новый УникальныйИдентификатор,"");
	КонецЦикла;			
КонецПроцедуры

&НаСервере
Функция ПолучитьПроцентЗаполненияДокументаОбследование()
	
	// Получаем кол. реквизитов
	ВременнаяТаблицаРеквизиты = ДОРеквизитыШаблонОбследования.Выгрузить();
    ВременнаяТаблицаРеквизиты.Свернуть("Реквизит");
	Если ВременнаяТаблицаРеквизиты.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;	
	
	// Получаем кол. заполненных реквизитов
	ВременнаяТаблицаЗаполнение = ДОЗначенияРеквизитовОбследования.Выгрузить();
	ВременнаяТаблицаЗаполнение.Свернуть("Реквизит");
	
	Возврат (100 * ВременнаяТаблицаЗаполнение.Количество()) / ВременнаяТаблицаРеквизиты.Количество();
	
КонецФункции

