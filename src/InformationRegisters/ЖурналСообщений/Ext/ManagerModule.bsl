	//
	// Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	// Запрос.УстановитьПараметр("ИдСообщения"   , ИдСообщения);
	//
	// Выборка = Запрос.Выполнить().Выбрать();
	//
	// Если Выборка.Следующий() Тогда	
	//	                 
	//	МенеджерЗаписи = РегистрыСведений.ЖурналСообщений.СоздатьМенеджерЗаписи();
	//	
	//	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);	
	//	
	//	МенеджерЗаписи.Прочитать();
	//	МенеджерЗаписи.Прочитано = Истина;
	//	МенеджерЗаписи.Записать();
	//	
	// КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	НаборЗаписейСообщения = СоздатьНаборЗаписей();
	НаборЗаписейСообщения.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
	НаборЗаписейСообщения.Отбор.ИдСообщения.Установить(ИдСообщения);
	НаборЗаписейСообщения.Прочитать();

	Если НЕ НаборЗаписейСообщения.Количество() = 0 Тогда 
