// Процедура - Подключаемый открыть заявку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Подключаемый_ОткрытьЗаявку(Команда) Экспорт

	Индекс 			= Число(СтрЗаменить(Команда.Имя, "Кнопка_ОткрытьЗаявку_", ""));	
	ЗаявкаСсылка	= СтруктураКлиента.СписокЗаявок[Индекс].Значение.ЗаявкаСсылка;
	
	ОткрытьФорму("Справочник.Заявки.ФормаОбъекта", Новый Структура("Ключ, IDЗвонка, ПОIPТелефонии", ЗаявкаСсылка, IDЗвонка, ПОIPТелефонии));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить заявку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьЗаявку(Команда)

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ПОIPТелефонии"				, ПОIPТелефонии);	
	ПараметрыФормы.Вставить("IDЗвонка"					, IDЗвонка);
	ПараметрыФормы.Вставить("НомерТелефона"				, ПреобразованныйНомерТелефона);
	ПараметрыФормы.Вставить("КоллтрекингНомер"			, ПараметрыТелефонногоЗвонка.КоллтрекингНомер);
	ПараметрыФормы.Вставить("ИсточникЗаписи"			, "Телефон");

	ЗначениеЗаполнения = Новый Структура();
	ЗначениеЗаполнения.Вставить("ДатаСоздания"			, ТекущаяДата());
	ЗначениеЗаполнения.Вставить("ДобавитьНомерТелефона"	, Истина);
	ЗначениеЗаполнения.Вставить("НомерТелефона"			, ПреобразованныйНомерТелефона);
	ЗначениеЗаполнения.Вставить("РекламнаяПлощадка"		, ВернутьРекламнуюПлощадку(ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка));
	
	ПОIPТелефонииCallTouch = ПулучитьПОIPТелефонииCallTouch();
	
	Если ЗначениеЗаполнено(ПОIPТелефонииCallTouch) Тогда 
		
		ПараметрыЗвонка = IPТелефония.CallTouch_ПолучитьИнформациюОПосетителеСайта(ПОIPТелефонииCallTouch, НомерТелефонаКлиента);	
		
		Если ЗначениеЗаполнено(ПараметрыЗвонка) Тогда			
			Если ПОIPТелефонии <> ПОIPТелефонииCallTouch Тогда
				Если ПараметрыЗвонка.Свойство("callid") Тогда    
					ПараметрыЗвонка.callid = IDЗвонка;
				Иначе 
					ПараметрыЗвонка.Добавить("callid", IDЗвонка);
				КонецЕсли;
			КонецЕсли;
			
			СквознаяАналитикаДобавитьЗапись(ПараметрыЗвонка);
			
			ДанныеСквознойАналитики = ПолучитьДанныеСквознойАналитики(IDЗвонка);
			
			Если ЗначениеЗаполнено(ДанныеСквознойАналитики) Тогда 
				
				РекламныйИсточник = РекламныйИсточникПоНаименованию(ДанныеСквознойАналитики.source);
				
				ЗначениеЗаполнения.Вставить("РекламныйИсточник", ?(ЗначениеЗаполнено(РекламныйИсточник), РекламныйИсточник, СоздатьРекламныйИсточник(ДанныеСквознойАналитики.source)));
				ЗначениеЗаполнения.Вставить("ga_cid"	       , ДанныеСквознойАналитики.gcid);
				ЗначениеЗаполнения.Вставить("utm_campaign"     , ДанныеСквознойАналитики.utm_campaign);
				ЗначениеЗаполнения.Вставить("utm_content"      , ДанныеСквознойАналитики.utm_content);
				ЗначениеЗаполнения.Вставить("utm_medium"       , ДанныеСквознойАналитики.utm_medium);
				ЗначениеЗаполнения.Вставить("utm_source"       , ДанныеСквознойАналитики.utm_source);
				ЗначениеЗаполнения.Вставить("utm_term"	       , ДанныеСквознойАналитики.utm_term);
				ЗначениеЗаполнения.Вставить("ym_cid"	       , ДанныеСквознойАналитики.yaClientId);	
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли; 
	
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначениеЗаполнения);
	
	ОткрытьФорму("Справочник.Заявки.ФормаОбъекта", ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

