	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндКартинки,
	|	СписокНоменклатуры.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СписокНоменклатуры.НормаВремени КАК НормаВремени,
	|	СписокНоменклатуры.УпаковкаПоУмолчанию КАК УпаковкаПоУмолчанию,
	|	СписокНоменклатуры.ИспользоватьПартии КАК ИспользоватьПартии,
	|	ВЫБОР
	|		КОГДА СписокНоменклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоСертификат,
	|	СписокНоменклатуры.Наименование КАК Наименование,
	|	СписокНоменклатуры.Бесплатно КАК Бесплатно,
	|	СписокНоменклатуры.ЭтоГруппа КАК ЭтоГруппа,
	|	СписокНоменклатуры.СкидкиЗапрещены КАК СкидкиЗапрещены,
	|	СписокНоменклатуры.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК СписокНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУслугиПоДоговору КАК ВТУслугиПоДоговору
	|		ПО СписокНоменклатуры.Ссылка = ВТУслугиПоДоговору.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(
	|				&ОтборНаДату,
	|				СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница
	|					И ВЫБОР
	|						КОГДА НЕ &ОтборСклад = НЕОПРЕДЕЛЕНО
	|							ТОГДА Склад = &ОтборСклад
	|					КОНЕЦ
	|					И &ОтображатьКоличество
	|					И Номенклатура В
	|						(ВЫБРАТЬ
	|							СтатусыНоменклатуры.Номенклатура КАК Номенклатура
	|						ИЗ
	|							СтатусыНоменклатуры КАК СтатусыНоменклатуры)) КАК ЗапасыОстатки
	|		ПО СписокНоменклатуры.Ссылка = ЗапасыОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныНоменклатуры КАК ЦеныНоменклатуры
	|		ПО СписокНоменклатуры.Ссылка = ЦеныНоменклатуры.Номенклатура
	|ГДЕ
	|	СписокНоменклатуры.Ссылка В
	|			(ВЫБРАТЬ
	|				ЦеныНоменклатуры.Номенклатура КАК НоменклатураСсылка
	|			ИЗ
	|				ЦеныНоменклатуры КАК ЦеныНоменклатуры)";
	
	// БЛОК - Условие сегментов
	
	УсловиеСегментов = 
	"И Номенклатура.Ссылка В
	|	(ВЫБРАТЬ
	|		НоменклатураСегмента.Номенклатура КАК Номенклатура
	|	ИЗ
	|		РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|	ГДЕ
	|		НоменклатураСегмента.Сегмент = &СегментСотрудника)";	
	
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "И &УсловиеСегментов", ?(ОтброПоСегментам, УсловиеСегментов, ""));
	
	// БЛОК - Настройки подбора по полису
	
	УсловиеУслугиПоДоговору = 
	"И ВЫБОР КОГДА Номенклатура.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Услуга) Тогда Номенклатура.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТУслугиПоДоговору.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ВТУслугиПоДоговору КАК ВТУслугиПоДоговору) ИНАЧЕ Истина КОНЕЦ";
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "И &УсловиеУслугиПоДоговору", ?(ВывестиДанныеПоДоговоруПолиса, УсловиеУслугиПоДоговору, ""));
	
	// БЛОК - Услуги сотрудника
	
	УсловиеУслугиСотрудника = "";
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		
		Если ЭтоПрием Тогда 
			УсловиеУслугиСотрудника =  
			"И (Номенклатура.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Набор) Или Номенклатура.Ссылка В
			|(ВЫБРАТЬ
			|	УслугиСотрудника.Номенклатура
			|ИЗ
			|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
			|ГДЕ
			|	УслугиСотрудника.Сотрудник = &Сотрудник
			|	И УслугиСотрудника.СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница
			|	И НЕ УслугиСотрудника.Номенклатура.ПометкаУдаления))";
		Иначе 
			УсловиеУслугиСотрудника =  
			"И (Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
			| Или Номенклатура.Ссылка В
			|(ВЫБРАТЬ
			|	УслугиСотрудника.Номенклатура
			|ИЗ
			|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
			|ГДЕ
			|	УслугиСотрудника.Сотрудник = &Сотрудник
			|	И УслугиСотрудника.СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница
			|	И НЕ УслугиСотрудника.Номенклатура.ПометкаУдаления))";

		КонецЕсли;
		
	КонецЕсли;
	
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "И &УсловиеУслугиСотрудника", УсловиеУслугиСотрудника);
	
	УсловиеТипы 	 			 = ?(ОтборМассивТипов, "И Номенклатура.ТипНоменклатуры В (&ОтборМассивТипов)", "И Истина");
	ЗапросТекст 	 			 = СтрЗаменить(ЗапросТекст, "И &УсловиеТипы", УсловиеТипы);
	
	Возврат ЗапросТекст;
		
КонецФункции

&НаСервере
// Процедура, выполняет установку условного оформления
//
Процедура УстановитьУсловноеОформлениеСписка(ПодборНоменклатур, СписокНеиспользуемыхГрупп, ИзменениеЦветаПоПолису = Ложь)
	
	ПодборНоменклатур.УсловноеОформление.Элементы.Очистить();
	// Перекраска слова "Бесплатно"	
	ЭлементУФ = ПодборНоменклатур.УсловноеОформление.Элементы.Добавить();  	
	
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));	
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Бесплатно"); 
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
	ЭлементОтбора.ПравоеЗначение = Истина;                                              
	ЭлементОтбора.Использование = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru= 'беспл.'; en = 'free'"));
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(190,160,30));
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ГоризонтальноеПоложение", ГоризонтальноеПоложение.Право);	
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Цена");
	ПолеОформления.Использование = Истина; 
	
	// Перекраска страховых услуг по согласованию
	Если ИзменениеЦветаПоПолису Тогда
	
		ЭлементУФ = ПодборНоменклатур.УсловноеОформление.Элементы.Добавить();  	
		
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));	
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ПолисСогласование"); 
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.Всегда");                                              
		ЭлементОтбора.Использование = Истина;

		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255,120,255));	
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Цена");
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Номенклатура");
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Артикул");
		ПолеОформления.Использование = Истина;
			
		// Перекраска страховых услуг по превышению количества
		
		ЭлементУФ = ПодборНоменклатур.УсловноеОформление.Элементы.Добавить();  	
		
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));	
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ПолисСогласование"); 
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении");                                              
		ЭлементОтбора.Использование = Истина;

		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255,143,143));	
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Цена");
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Номенклатура");
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Артикул");
		ПолеОформления.Использование = Истина;

	КонецЕсли;
	
	///////
		
	ЭлементУФ = ПодборНоменклатур.УсловноеОформление.Элементы.Добавить();
	
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));	
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ЭтоГруппа"); 
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; 
	ЭлементОтбора.ПравоеЗначение = Истина;                                              
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Текст", "");
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Цена");
	ПолеОформления.Использование = Истина;
	
	Если СписокНеиспользуемыхГрупп.Количество() > 0 Тогда
		ЭлементУФ = ПодборНоменклатур.УсловноеОформление.Элементы.Добавить();
		
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Видимость" , Ложь);
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Отображать" , Ложь);
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
		
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Номенклатура");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение = СписокНеиспользуемыхГрупп; 
		ЭлементОтбора.Использование  = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обновляет количество номенклатуры
//
Процедура СкладПриИзмененииДинамическогоСпискаПодбор(Форма, Объект, МассивТипов, ОтображатьКоличество = Ложь, ИмяЭлементаДляРазмещения, ПолучитьХарактеристикиПолиса = Ложь) Экспорт
		
	УстановитьПараметрыДинамическогоСписка(Форма, Объект, МассивТипов, ОтображатьКоличество, , ИмяЭлементаДляРазмещения, ПолучитьХарактеристикиПолиса);		
	
КонецПроцедуры 

&НаСервере
// Процедура, выполянет установку параметров выбора номенклатуры.
//
Процедура УстановитьПараметрыВыбораНоменклатуры(Форма, МассивТипов) Экспорт 
	
	СегментСотрудника  = Форма._ПодборСегментНоменклатуры;
	
	Если ЗначениеЗаполнено(СегментСотрудника) Тогда
			
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	НоменклатураСегмента.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|ГДЕ
		|	НоменклатураСегмента.Сегмент = &СегментСотрудника");
		
		Запрос.УстановитьПараметр("СегментСотрудника" , СегментСотрудника);
		
		МассивНоменклатур = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
		
		Массив = Новый Массив;
		НовыйПараметр  = Новый ПараметрВыбора("Отбор.ТипНоменклатуры", МассивТипов);
		Массив.Добавить(НовыйПараметр);
		НовыйПараметр  = Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивНоменклатур));
		Массив.Добавить(НовыйПараметр); 		
		Форма.Элементы.ЗапасыНоменклатура.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);	
	Иначе
		
		Массив = Новый Массив;
		НовыйПараметр = Новый ПараметрВыбора("Отбор.ТипНоменклатуры", МассивТипов);
		Массив.Добавить(НовыйПараметр);
		Форма.Элементы.ЗапасыНоменклатура.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
		
	КонецЕсли;  	
	
КонецПроцедуры

