#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Процедура, Запись по планированию очереди
//
Процедура ЗаписьПоПланированиюОчереди(СобытиеСсылка)
	
	Сотрудник = ?(СобытиеСсылка.Услуги.Количество() > 0, СобытиеСсылка.Услуги[0].Сотрудник, Справочники.Сотрудники.ПустаяСсылка());
	Если НЕ Сотрудник.Пустая() Тогда 
		НоваяЗапись = РегистрыСведений.Профосмотры.СоздатьМенеджерЗаписи();
		
		НоваяЗапись.ВидОсмотра          	= Перечисления.ВидыОсмотров.ОчередьНаЗапись;
		НоваяЗапись.Период              	= ТекущаяДата(); 
		НоваяЗапись.СтруктурнаяЕдиница  	= СобытиеСсылка.СтруктурнаяЕдиница;
		НоваяЗапись.Контрагент          	= СобытиеСсылка.Контрагент;
		НоваяЗапись.Сотрудник           	= Сотрудник;
		НоваяЗапись.АвторЗаписи         	= ПараметрыСеанса.ТекущийПользователь;
		НоваяЗапись.ДатаЗапланированная 	= СобытиеСсылка.Дата;
		НоваяЗапись.Статус              	= Перечисления.СтатусыПрофосмотров.Согласился;
		НоваяЗапись.ПредварительнаяЗапись 	= СобытиеСсылка;	
		НоваяЗапись.Записать(Ложь);	
	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
// Функция - Получить ключ записи.
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКлючЗаписи(ТекущиеДанные)
	
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("СтруктурнаяЕдиница"	, ТекущиеДанные.СтруктурнаяЕдиница);
	СтруктураОтбора.Вставить("Сотрудник"			, ТекущиеДанные.Сотрудник);
	СтруктураОтбора.Вставить("ВидОсмотра"			, ТекущиеДанные.ВидОсмотра);
	СтруктураОтбора.Вставить("Контрагент"			, ТекущиеДанные.Контрагент);
	СтруктураОтбора.Вставить("Период"				, ТекущиеДанные.Период);
	
	МассивСтруктураЗаписи = Новый Массив;
	МассивСтруктураЗаписи.Добавить(СтруктураОтбора);

	Возврат Новый("РегистрСведенийКлючЗаписи.Профосмотры", МассивСтруктураЗаписи); 
	
КОнецФункции

#КонецОбласти


