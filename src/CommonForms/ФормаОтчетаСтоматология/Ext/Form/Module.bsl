// Функция возвращает массив складов
//
Функция ВернутьМассивСкладов(ТаблицаСкладов)

	МассивСкладов = Новый Массив;
	Если ТаблицаСкладов.Колонки.Найти("Склад") <> Неопределено Тогда
		ТаблицаСкладов.Свернуть("Склад");
		НайденнаяСтрока = ТаблицаСкладов.Найти(Неопределено);
		Если НайденнаяСтрока <> Неопределено Тогда 
			ТаблицаСкладов.Удалить(НайденнаяСтрока);
		КонецЕсли;	
		МассивСкладов = ТаблицаСкладов.ВыгрузитьКолонку("Склад");
	КонецЕсли;	
	
	Возврат МассивСкладов;
	
