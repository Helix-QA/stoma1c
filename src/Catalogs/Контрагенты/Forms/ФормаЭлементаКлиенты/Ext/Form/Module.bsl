	СокращенныйТекстЗаметки = ЭлементHTML.innerHTML;
	
	СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ИдЗвонка);
	
	ТекстЗаметки = ПолучитьПолныйТекстЗаметкиЗвонка(СтрокаТЗ.Взаимодействие, Объект.Ссылка, СокращенныйТекстЗаметки);
	
	ОткрытьФорму("РегистрСведений.Заметки.Форма.ФормаРедактированияЗаметки", Новый Структура("ТекстЗаметки", ТекстЗаметки),,,,, Обработчик, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

