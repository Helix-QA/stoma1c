Процедура ПозвонитьПоТелефону(НомерТелефона)
	
	НомерТелефона = СтроковыеФункцииКлиентСервер.ЗаменитьОдниСимволыДругими("()_- ", НомерТелефона, "");
	
	// по умолчанию используем "tel"
	ИмяПротокола = "tel";

	#Если НЕ ВебКлиент Тогда
		ДоступноеИмяПротокола = ПрограммаТелефонииУстановлена();
		Если ДоступноеИмяПротокола = Неопределено Тогда
			СтрокаСПредупреждением = Новый ФорматированнаяСтрока(
					НСтр("ru='Для совершения звонка требуется установить программу телефонии, например';en='For making call required install a telephony program forexample'"),
					 " ", Новый ФорматированнаяСтрока("Skype",,,, "http://www.skype.com"), ".");
			ПоказатьПредупреждение(Неопределено, СтрокаСПредупреждением);
			Возврат;
		ИначеЕсли НЕ ПустаяСтрока(ДоступноеИмяПротокола) Тогда
			ИмяПротокола = ДоступноеИмяПротокола;
		КонецЕсли;
	#КонецЕсли
	
	СтрокаЗапуска = ИмяПротокола + ":" + НомерТелефона;
	
	Оповещение = Новый ОписаниеОповещения("СовершитьЗвонок", ЭтотОбъект, СтрокаЗапуска);
	ТекстСообщения = НСтр("ru='Для совершения звонка необходимо установить расширение работы с файлами.';en='For making call is necessary install expansion work with files.'");
	ОбщегоНазначенияКлиент.ПоказатьВопросОбУстановкеРасширенияРаботыСФайлами(Оповещение, ТекстСообщения);
	
КонецПроцедуры

// Процедура - Преобразовать номер телефона
//
// Параметры:
//  Представление	 - 	 - 
//  СписокПолей		 - 	 - 
//
Процедура ПреобразоватьНомерТелефона(Представление, СписокПолей) Экспорт
	
	СтруктураРезультата = ОбщегоНазначенияСтоматология.ВернутьНастройкиПараметровУчета();
	
	Если ЗначениеЗаполнено(СтруктураРезультата.СтранаУчета) Тогда		
		Если СтруктураРезультата.Код = "643" Тогда	// Для РФ		
			ПреобразоватьДля_РФ(Представление, СписокПолей, СтруктураРезультата);			
		ИначеЕсли СтруктураРезультата.Код = "804" Тогда // Для Украины
			ПреобразоватьДля_Украины(Представление, СписокПолей, СтруктураРезультата);			
		Иначе 
			ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);
		КонецЕсли;
	Иначе 
		ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Преобразовать для РФ
//
// Параметры:
//  Представление		 - 	 - 
//  СписокПолей			 - 	 - 
//  СтруктураРезультата	 - 	 - 
//
Процедура ПреобразоватьДля_РФ(Представление, СписокПолей, СтруктураРезультата)
	
	ТелефонПредставление = СокрЛП(Представление);	
	СписокПолей.Очистить();
	КодСтраны     = "";
	КодГорода     = "";
	НомерТелефона = "";
	Добавочный    = "";
	Комментарий   = "";
	
	// Вычислим код страны
	Если СтруктураРезультата.ФорматТелНомера = 0 ИЛИ СтруктураРезультата.ФорматТелНомера = 1 Тогда 
		КодСтраны = "+7";
	ИначеЕсли СтруктураРезультата.ФорматТелНомера = 2 ИЛИ СтруктураРезультата.ФорматТелНомера = 3 Тогда 
		КодСтраны = "8";
	КонецЕсли;	
	
	// Уберем код страны, если есть для правильного анализа
	Если Найти(ТелефонПредставление, "+7 (") <> 0 Тогда 
		ТелефонПредставление = Сред(ТелефонПредставление, 3);
	ИначеЕсли Найти(ТелефонПредставление, "8 (") <> 0 Тогда 	
		ТелефонПредставление = Сред(ТелефонПредставление, 2);		
	КонецЕсли;
	
	// Оставим одни лишь цифры
	НомерТелефона_ТолькоЦифры = ВернутьТелефонТолькоЦифрами(ТелефонПредставление);
	
	Если СтрДлина(НомерТелефона_ТолькоЦифры) = 6 ИЛИ СтрДлина(НомерТелефона_ТолькоЦифры) = 7 Тогда 
		ПравильныйНомер = Истина;
	ИначеЕсли СтрДлина(НомерТелефона_ТолькоЦифры) = 10 Тогда
		ПравильныйНомер = Истина;
	ИначеЕсли СтрДлина(НомерТелефона_ТолькоЦифры) = 11 Тогда
		Если Лев(НомерТелефона_ТолькоЦифры, 1) = "7" ИЛИ Лев(НомерТелефона_ТолькоЦифры, 1) = "8" Тогда 
			НомерТелефона_ТолькоЦифры = Сред(НомерТелефона_ТолькоЦифры, 2, 10);
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;
	Иначе 
		ПравильныйНомер = Ложь;
	КонецЕсли;
	
	Если ПравильныйНомер Тогда
		Если СтрДлина(НомерТелефона_ТолькоЦифры) = 6 ИЛИ СтрДлина(НомерТелефона_ТолькоЦифры) = 7 Тогда
			НомерТелефона = НомерТелефона_ТолькоЦифры;
		Иначе 			
			МассивКодов = ВернутьМассивТрехЗначныхКодовДляРФ();
			Если МассивКодов.Найти(Сред(НомерТелефона_ТолькоЦифры, 1, 3)) = Неопределено Тогда
				Если Лев(НомерТелефона_ТолькоЦифры, 1) = "9" Тогда // это мобильный
					КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 3);
					НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 4, 7);
				Иначе 						                       // это 4-х значный код города
					КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 4);
					НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 5, 6);
				КонецЕсли;
			Иначе                                                  // это 3-х значный код города
				КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 3);
				НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 4, 7);
			КонецЕсли;
		КонецЕсли;
		// ----------------------Проверим комментарий--------------------------
		Поз = Найти(ТелефонПредставление, ", ");
		Если Поз <> 0 Тогда
			// вырежем комментарий
			Комментарий = СокрЛП(Сред(ТелефонПредставление, Поз + 2));
		КонецЕсли;	
		// ---------------------Поправим представление-------------------------
		Представление = СокрЛП(КодСтраны);				
		Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + "(" + СокрЛП(КодГорода) + ")";				
		Если Не ПустаяСтрока(НомерТелефона) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + ?(ПравильныйНомер = Ложь, СокрЛП(НомерТелефона), ПривестиНомерТелефонаКЧитаемомуВиду(НомерТелефона, СтруктураРезультата.ФорматТелНомера));
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Добавочный) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + "доб. " + СокрЛП(Добавочный);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Комментарий) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + СокрЛП(Комментарий);
		КонецЕсли;
		// --------------------------------------------------------------------
		
		СписокПолей.Добавить(?(КодСтраны = "8", КодСтраны, ВернутьТелефонТолькоЦифрами(КодСтраны)), "КодСтраны");
		СписокПолей.Добавить(КодГорода,     "КодГорода");
		СписокПолей.Добавить(НомерТелефона, "НомерТелефона");
		СписокПолей.Добавить(Добавочный,    "Добавочный");
		СписокПолей.Добавить(Комментарий,   "Комментарий");		
	Иначе 
		ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Преобразовать для украины
//
// Параметры:
//  Представление		 - 	 - 
//  СписокПолей			 - 	 - 
//  СтруктураРезультата	 - 	 - 
//
Процедура ПреобразоватьДля_Украины(Представление, СписокПолей, СтруктураРезультата)
	
	ТелефонПредставление = СокрЛП(Представление);	
	СписокПолей.Очистить();
	КодСтраны     = "";
	КодГорода     = "";
	НомерТелефона = "";
	Добавочный    = "";
	Комментарий   = "";
	
	// Вычислим код страны
	КодСтраны = "+38";
	
	// Уберем код страны, если есть для правильного анализа
	Если Найти(ТелефонПредставление, "+38 (") <> 0 Тогда 
		ТелефонПредставление = Сред(ТелефонПредставление, 4);
	КонецЕсли;
	
	// Оставим одни лишь цифры
	НомерТелефона_ТолькоЦифры = ВернутьТелефонТолькоЦифрами(ТелефонПредставление);
	
	Если СтрДлина(НомерТелефона_ТолькоЦифры) = "9" Тогда
		Если Лев(НомерТелефона_ТолькоЦифры, 1) <> "0" Тогда 
			НомерТелефона_ТолькоЦифры = "0" + НомерТелефона_ТолькоЦифры;
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;	
	ИначеЕсли СтрДлина(НомерТелефона_ТолькоЦифры) = 10 Тогда
		Если Лев(НомерТелефона_ТолькоЦифры, 1) = "0" Тогда
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;	
	ИначеЕсли СтрДлина(НомерТелефона_ТолькоЦифры) = 11 Тогда
		Если Сред(НомерТелефона_ТолькоЦифры, 2, 1) = "0" Тогда 
			НомерТелефона_ТолькоЦифры = Сред(НомерТелефона_ТолькоЦифры, 2, 10);
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;
	ИначеЕсли СтрДлина(НомерТелефона_ТолькоЦифры) = 12 Тогда
		Если Сред(НомерТелефона_ТолькоЦифры, 1, 2) = "38" Тогда 
			НомерТелефона_ТолькоЦифры = Сред(НомерТелефона_ТолькоЦифры, 3, 10);
			ПравильныйНомер = Истина;
		Иначе 
			ПравильныйНомер = Ложь;
		КонецЕсли;	
	Иначе 
		ПравильныйНомер = Ложь;
	КонецЕсли;
	
	Если ПравильныйНомер Тогда 
		МассивКодов = ВернутьМассивМобильныхТрехЗначныхКодовДляУкраины();
		Если МассивКодов.Найти(Сред(НомерТелефона_ТолькоЦифры, 1, 3)) = Неопределено Тогда
			КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 3);
			НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 4, 7);
		Иначе                                                  // это мобильный
			КодГорода 		= Сред(НомерТелефона_ТолькоЦифры, 1, 3);
			НомерТелефона 	= Сред(НомерТелефона_ТолькоЦифры, 4, 7);
		КонецЕсли;
		// ----------------------Проверим комментарий--------------------------
		Поз = Найти(ТелефонПредставление, ", ");
		Если Поз <> 0 Тогда
			// вырежем комментарий
			Комментарий = СокрЛП(Сред(ТелефонПредставление, Поз + 2));
		КонецЕсли;	
		// ------------------- Поправим представление ------------------------
		Представление = СокрЛП(КодСтраны);				
		Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + "(" + СокрЛП(КодГорода) + ")";				
		Если Не ПустаяСтрока(НомерТелефона) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + СокрЛП(НомерТелефона);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Добавочный) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + "доб. " + СокрЛП(Добавочный);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Комментарий) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + СокрЛП(Комментарий);
		КонецЕсли;
		// --------------------------------------------------------------------
		
		СписокПолей.Добавить(ВернутьТелефонТолькоЦифрами(КодСтраны), "КодСтраны");
		СписокПолей.Добавить(КодГорода,     "КодГорода");
		СписокПолей.Добавить(НомерТелефона, "НомерТелефона");
		СписокПолей.Добавить(Добавочный,    "Добавочный");
		СписокПолей.Добавить(Комментарий,   "Комментарий");
		
	Иначе 
		ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);
	КонецЕсли;	
	
КонецПроцедуры

