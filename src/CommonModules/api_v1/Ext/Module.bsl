// Функция, создает запись в регистре "КлючиВнешнихСистем".
//
Функция ЗаписатьUserToken(ВнешняяСистема, НомерТелефона, Клиент, КодПодтверждения = "", Пароль = Неопределено)
	
	УИД 	  = Новый УникальныйИдентификатор();
	UserToken = СтрЗаменить(Строка(ПолучитьMD5(Строка(УИД))), " ", "");
	
	НаборЗаписей = РегистрыСведений.КлючиВнешнихСистем.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
	НаборЗаписей.Отбор.НомерТелефона.Установить(НомерТелефона);
	
	НоваяЗапись                  = НаборЗаписей.Добавить();
	НоваяЗапись.ВнешняяСистема 	 = ВнешняяСистема;
	НоваяЗапись.НомерТелефона  	 = НомерТелефона;
	НоваяЗапись.Клиент	 	  	 = Клиент;
	НоваяЗапись.КлючКлиента	 	 = UserToken;
	НоваяЗапись.КодПодтверждения = КодПодтверждения;
	НоваяЗапись.Статус 		     = Перечисления.СтатусыКлючейВнешнихСистем.Подтвержден;
	НоваяЗапись.Пароль			 = Пароль;
	
	НаборЗаписей.Записать();
	
	Возврат UserToken;
	
КонецФункции

// Функция, возвращает значение из структуры по ключу.
//
Функция ПолучитьЗначениеИзСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	Если ТипЗнч(Структура) = Тип("Структура") Тогда
		Возврат ?(Структура.Свойство(Ключ), Структура[Ключ], ЗначениеПоУмолчанию);
	Иначе
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
КонецФункции

