// Процедура - Установить отбор по пользователю sip
//
// Параметры:
//  СозданиеНаСервере	 - 	 - 
//
Процедура УстановитьОтборПоПользователюSip(Знач СозданиеНаСервере = Ложь)
	
	// Сформируем текст пользователя или группы SIP	
	Если ЗначениеЗаполнено(ОтборПользовательSIP) Тогда 
		Элементы.ОтборПользовательSip.Заголовок 		= СокрЛП(ОтборПользовательSIP.ВнутреннийНомер) + " - " + СокрЛП(ОтборПользовательSIP.Наименование);
		//Элементы.ГруппаОтбораПользователяSip.ЦветФона 	= Новый Цвет(188, 231, 201);		
	Иначе 
		Элементы.ОтборПользовательSip.Заголовок 		= "Все пользователи";
		//Элементы.ГруппаОтбораПользователяSip.ЦветФона 	= Новый Цвет(240, 240, 240);
	КонецЕсли;
	
	Элементы.ОтборПользовательSip.Ширина = Цел(СтрДлина(Элементы.ОтборПользовательSip.Заголовок) * 0.93);
	Элементы.ОтборПользовательSip.Ширина = ?(Элементы.ОтборПользовательSip.Ширина < 17, 17, Элементы.ОтборПользовательSip.Ширина);	
	
	ГруппаОтбора_ИЛИ = ОтборыСписковКлиентСервер.ДобавитьИлиПолучитьГруппаЭлементовОтбораСписка(Список, ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(ГруппаОтбора_ИЛИ, "НомерТелефона"				, СписокНомеров, ЗначениеЗаполнено(СписокНомеров), ВидСравненияКомпоновкиДанных.ВСписке);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(ГруппаОтбора_ИЛИ, "ПользовательSip"			, СписокНомеров, ЗначениеЗаполнено(СписокНомеров), ВидСравненияКомпоновкиДанных.ВСписке);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(ГруппаОтбора_ИЛИ, "ВнутреннийНомерСотрудника"	, СписокНомеров, ЗначениеЗаполнено(СписокНомеров), ВидСравненияКомпоновкиДанных.ВСписке);
	
	Если СозданиеНаСервере = Ложь Тогда 
		АктуализироватьКоличествоНеОбработанныхЗвонков();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Актуализировать количество не обработанных звонков
//
Процедура АктуализироватьКоличествоНеОбработанныхЗвонков()
	
	КоличествоНеОбработанныхЗвонков = ВернутьКоличествоНеОбработанныхЗвонков(ОтборПериод, СписокНомеров);
	Если КоличествоНеОбработанныхЗвонков = 0 Тогда 
		//	Элементы.Отбор_ПропущенныеЗвонки.Заголовок = "Пропущенные";
		//Иначе 
		//	Элементы.Отбор_ПропущенныеЗвонки.Заголовок = Новый ФорматированнаяСтрока("Пропущенные ", Новый ФорматированнаяСтрока("(Без ответа " + Строка(КоличествоНеОбработанныхЗвонков) + ")", , Новый Цвет(255, 0, 0)));
		Элементы.Отбор_БезОтвета.Заголовок = "Без ответа";
	Иначе 
		Элементы.Отбор_БезОтвета.Заголовок = "Без ответа (" + Строка(КоличествоНеОбработанныхЗвонков) + ")";
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Вернуть количество не обработанных звонков
//
// Параметры:
//  ОтборПериод		 - 	 - 
//  СписокНомеров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьКоличествоНеОбработанныхЗвонков(Знач ОтборПериод, Знач СписокНомеров)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	СУММА(1) КАК КоличествоНеОбработанных
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.НеОбработан = ИСТИНА
	|	И ВЫБОР
	|			КОГДА ИсторияВызовов.НачалоРазговора = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИсторияВызовов.НачалоВызова >= &ПериодНачало
	|						И ИсторияВызовов.НачалоВызова <= &ПериодКонец
	|			ИНАЧЕ ИсторияВызовов.НачалоРазговора >= &ПериодНачало
	|					И ИсторияВызовов.НачалоРазговора <= &ПериодКонец
	|		КОНЕЦ
	|	И (ИсторияВызовов.НомерТелефона В (&МассивНомеров)
	|			ИЛИ ИсторияВызовов.ПользовательSip В (&МассивНомеров)
	|			ИЛИ ИсторияВызовов.ВнутреннийНомерСотрудника В (&МассивНомеров))";
	
	Запрос.УстановитьПараметр("ПериодНачало"	, ОтборПериод.ДатаНачала);
	Запрос.УстановитьПараметр("ПериодКонец"		, ?(ЗначениеЗаполнено(ОтборПериод.ДатаОкончания), ОтборПериод.ДатаОкончания, Дата(2999, 1, 1)));
	
	Если СписокНомеров.Количество() = 0 Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И (ИсторияВызовов.НомерТелефона В (&МассивНомеров)
	               |			ИЛИ ИсторияВызовов.ПользовательSip В (&МассивНомеров)
				   |			ИЛИ ИсторияВызовов.ВнутреннийНомерСотрудника В (&МассивНомеров))", "");
	Иначе 
		Запрос.УстановитьПараметр("МассивНомеров", СписокНомеров.ВыгрузитьЗначения());
	КонецЕсли;
	
	РезультатаЗапроса = Запрос.Выполнить().Выбрать();	
	
	Если РезультатаЗапроса.Следующий() Тогда 
		Возврат РезультатаЗапроса.КоличествоНеОбработанных;
	Иначе 
		Возврат 0;
	КонецЕсли;
	
КонецФункции

