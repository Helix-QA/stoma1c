#Область РаботаСДинамическимиСписками

// Установить группировку по полю для динамического списка
//
Функция УстановитьГруппировкуСписка(Список,ИмяПоля,ТипДополнения = Неопределено)Экспорт
	
	ЭлементГруппировки =  Новый ПолеКомпоновкиДанных(ИмяПоля);

	// Ищем существует ли поле группировки
	Для Каждого Элемент ИЗ Список.Группировка.Элементы Цикл
		
		// Если существует задаем параметры
		Если Элемент.Поле = ЭлементГруппировки Тогда
					
			 Элемент.Использование = Истина;
			 Элемент.ТипДополнения = ?(ТипДополнения <> Неопределено,ТипДополнения,ТипДополненияПериодаКомпоновкиДанных.БезДополнения);
			 Возврат Истина;
			 
	    КонецЕсли;
				
	КонецЦикла;	
	
	// Если поле не существует создаем его...
	Попытка
		
	    НовыйЭлемент               = Список.Группировка.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
        НовыйЭлемент.Поле          = ЭлементГруппировки;
        НовыйЭлемент.Использование = Истина;
		НовыйЭлемент.ТипДополнения = ?(ТипДополнения <> Неопределено,ТипДополнения,ТипДополненияПериодаКомпоновкиДанных.БезДополнения);

  	    Возврат Истина;

    Исключение
	    Возврат Ложь;
	КонецПопытки;
	
КонецФункции   

// Снять все группировки для динамического списка или указанное поле группировки
//
Процедура СнятьГруппировкуСписка(Список,ИмяПоля = Неопределено)Экспорт
	
	ЭлементГруппировки = Неопределено;
	Если  ИмяПоля <> Неопределено Тогда
	    ЭлементГруппировки =  Новый ПолеКомпоновкиДанных(ИмяПоля);
    КонецЕсли;
	
	Для Каждого Элемент ИЗ Список.Группировка.Элементы Цикл
		
		// Снимаем все группировки
		Если ЭлементГруппировки = Неопределено Тогда
			
			 Элемент.Использование = Ложь;
		// Снимаем определенную группировку	 
        ИначеЕсли Элемент.Поле = ЭлементГруппировки Тогда
					
			 Элемент.Использование = Ложь;
			 Возврат;
			 
	   КонецЕсли;
				
	КонецЦикла;	

КонецПроцедуры 

#КонецОбласти

// Предлагает пользователю установить расширение работы с файлами в веб-клиенте.
// При этом инициализирует параметр сеанса ПредлагатьУстановкуРасширенияРаботыСФайлами.
//
// Процедура предназначена для использования в начале участков кода, в которых ведется работа с файлами.
// Например:
//
//    ПредложитьУстановкуРасширенияРаботыСФайлами("Для печати документа необходимо установить 
//				расширение работы с файлами");
//    // далее располагается код печати документа
//    //...
//
// Параметры
//  Сообщение  - Строка - текст сообщения. Если не указан, то выводится текст по умолчанию.
//   
Процедура ПредложитьУстановкуРасширенияРаботыСФайлами(Сообщение = Неопределено) Экспорт
	
	#Если Не ВебКлиент И НЕ МобильныйКлиент Тогда
		Возврат;  // только в веб клиенте этот код работает		
	#КонецЕсли
	
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("ПредложитьУстановкуРасширенияРаботыСФайламиЗавершение", ЭтотОбъект, Сообщение));
	
КонецПроцедуры // ПредложитьУстановкуРасширенияРаботыСФайлами

Процедура ПредложитьУстановкуРасширенияРаботыСФайламиЗавершение(Подключено, Параметры)  Экспорт
	
	Если Подключено Тогда
		Возврат; // если расширение и так уже есть, незачем про него спрашивать
	КонецЕсли;	
	
	ПредлагатьУстановку = ОбщегоНазначенияКлиентПовтИсп.ПолучитьПредлагатьУстановкуРасширенияРаботыСФайлами();
	
	Если ПредлагатьУстановку = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	// тут надо показать диалог
	ПараметрыФормы = Новый Структура("Сообщение", Параметры);
	
	ОткрытьФорму("ОбщаяФорма.ВопросОбУстановкеРасширенияРаботыСФайлами",ПараметрыФормы,,,,, Новый ОписаниеОповещения("ПредложитьУстановкуРасширенияРаботыСФайламиЗавершение2", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

Процедура ПредложитьУстановкуРасширенияРаботыСФайламиЗавершение2(КодВозврата, Параметры)  Экспорт
	
	Если КодВозврата = Неопределено Тогда
		КодВозврата = Истина;
	КонецЕсли;
	
	ПредлагатьУстановку = КодВозврата;
	ОбщегоНазначения.СохранитьПредлагатьУстановкуРасширенияРаботыСФайлами(ПредлагатьУстановку);
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры

// Начальная процедура работы с загрузкой данных из выписки
// 
// Праметры:
//		- ЗагруженныеДокументы - Массив - список загруженных документов
// 
// Возвращает:
// 		Булево - Истина - если загрузка произведена и ложь, если пользователь отказался
//			или произошла ошибка загрузки
Процедура ЗагрузитьДанныеИзФайлаВыписки(
		ИдентификаторФормы = Неопределено,
		ИмяФайла = "",
		Организация = Неопределено,
		БанковскийСчет = Неопределено,
		СтатьяДДСВходящий = Неопределено,
		СтатьяДДСИсходяший = Неопределено,
		ПроводитьЗагружаемые = Ложь,
		ЗаполнятьДолгиАвтоматически = Ложь,
		Программа = "",
		Кодировка = "Windows",
		ВерсияФормата = "1.02") Экспорт
		
	СтатьяДДСВходящий = ?(ЗначениеЗаполнено(СтатьяДДСВходящий), СтатьяДДСВходящий, ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтКлиента"));
	СтатьяДДСИсходяший = ?(ЗначениеЗаполнено(СтатьяДДСИсходяший), СтатьяДДСИсходяший, ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаПоставщику"));
		
	ЗагруженныеДокументы   = Новый Массив;
	АдресВХранилище        = "";
	Результат              = Ложь;
	ПутьДоФайла1           = "kl_to_1c.txt";
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("АдресФайлаКОбработке"			, АдресВХранилище);
	ПараметрыОповещения.Вставить("ПутьДоФайла"					, ПутьДоФайла1);
	ПараметрыОповещения.Вставить("Организация"					, Организация);
	ПараметрыОповещения.Вставить("БанковскийСчетОрганизации"	, БанковскийСчет);
	ПараметрыОповещения.Вставить("СтатьяДДСВходящий"			, СтатьяДДСВходящий);
	ПараметрыОповещения.Вставить("СтатьяДДСИсходяший"			, СтатьяДДСИсходяший);
	ПараметрыОповещения.Вставить("ПроводитьЗагружаемые"			, ПроводитьЗагружаемые);
	ПараметрыОповещения.Вставить("ЗаполнятьДолгиАвтоматически"	, ЗаполнятьДолгиАвтоматически);
	ПараметрыОповещения.Вставить("Программа"					, Программа);
	ПараметрыОповещения.Вставить("Кодировка"					, Кодировка);
	ПараметрыОповещения.Вставить("ВерсияФормата"				, ВерсияФормата);
	
	Если ПодключитьРасширениеРаботыСФайлами() Тогда
		
		Диалог                  = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		
		Диалог.Заголовок        = НСтр("ru='Выберите файл для загрузки...'");
		Диалог.Фильтр           = НСтр("ru='Файлы обмена с 1С (*.txt)|*.txt|Все файлы (*.*)|*.*'");
		Диалог.ПолноеИмяФайла   = ИмяФайла;
		Результат               = Диалог.Выбрать();
		ИмяФайла                = Диалог.ПолноеИмяФайла;
		ПутьДоФайла1            = Диалог.ПолноеИмяФайла;
		
		Если НЕ Результат Тогда
			Возврат;
		КонецЕсли;
		
		Файл = Новый Файл(ПутьДоФайла1);
		
		Если НЕ Файл.Существует() Тогда
			ПоказатьПредупреждение(Неопределено,НСтр("ru='Файл не существует'"));
			Возврат;
		КонецЕсли;
		
		Если НЕ Файл.ЭтоФайл() Тогда
			ПоказатьПредупреждение(Неопределено,НСтр("ru='Файл не выбран'"));
			Возврат;
		КонецЕсли;
		
		// Чтобы в дальнейшем проверить на отказ от передачи файла
		Если Файл.Размер() = 0 Тогда
			ПоказатьПредупреждение(Неопределено,НСтр("ru='Выбран пустой файл'"));
			Возврат;
		КонецЕсли;
		
		Файл = Новый ТекстовыйДокумент();
		Если Кодировка = "DOS" Тогда
			Файл.Прочитать(ПутьДоФайла1, "cp866");
		Иначе
			Файл.Прочитать(ПутьДоФайла1);
		КонецЕсли;
		
		ТекстФайла = Файл.ПолучитьТекст();
		
		// Пользователь отказался от передачи файла
		Если СтрДлина(ТекстФайла) = 0 Тогда
			Возврат;
		КонецЕсли;
		
		ПараметрыОповещения.ПутьДоФайла = ПутьДоФайла1;
		ПараметрыОповещения.АдресФайлаКОбработке = ПоместитьВоВременноеХранилище(ТекстФайла, ИдентификаторФормы);	
		
	Иначе		
		ПараметрыДиалога			 = Новый ПараметрыДиалогаПомещенияФайлов;
		ПараметрыДиалога.Заголовок	 = НСтр("ru='Выберите файл для загрузки...'");
		ПараметрыДиалога.Фильтр		 = НСтр("ru='Файлы обмена с 1С|*.txt|Все файлы|*.*'");
		
		Оповещение = Новый ОписаниеОповещения("ЗагрузитьДанныеИзФайлаВыпискиПослеПомещения", ЭтотОбъект, ПараметрыОповещения);
		НачатьПомещениеФайлаНаСервер(Оповещение,,, АдресВХранилище, ПараметрыДиалога, ИдентификаторФормы); 
		Возврат;

	КонецЕсли;
		
	ЗагрузитьДанныеИзФайлаВыпискиЗавершение(ПараметрыОповещения);
	
КонецПроцедуры

//Процедура ЗагрузитьДанныеИзФайлаВыпискиПослеПомещения(Результат, Адрес, ВыбранноеИмяФайла, Параметры) Экспорт
Процедура ЗагрузитьДанныеИзФайлаВыпискиПослеПомещения(Результат, Параметры) Экспорт

	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат.ПомещениеФайлаОтменено Тогда
		Возврат;
	КонецЕсли;
	
	Параметры.АдресФайлаКОбработке = Результат.Адрес;
	ЗагрузитьДанныеИзФайлаВыпискиЗавершение(Параметры);
	
КонецПроцедуры

Процедура ЗагрузитьДанныеИзФайлаВыпискиЗавершение(мПараметры)

	Состояние(
		НСтр("ru='Загружается файл выписки'"),
		,
		НСтр("ru='Производится загрузка файла выписки'"),
		БиблиотекаКартинок.ДлительнаяОперация48
	);
	
	ОткрытьФорму("Обработка.КлиентБанк.Форма.ФормаЗагрузка", мПараметры);

КонецПроцедуры

Процедура ПроверкаИЭМК(РезультатПроверкиИЭМК, ПриемДляОтправки) Экспорт

	Если РезультатПроверкиИЭМК = "1" Или РезультатПроверкиИЭМК = "3" Тогда
		Текст = "ИЭМК: У сотрудника: " + Строка(ПриемДляОтправки.Сотрудник) + " не заполнена оснавная специализация. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхСотрудникаЗавершение", ЭтотОбъект, ПриемДляОтправки.Сотрудник), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если РезультатПроверкиИЭМК = "2" Тогда
		Текст = "ИЭМК: У сотрудника: " + Строка(ПриемДляОтправки.Сотрудник) + " не заполнено представление должности по ИЭМК. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхСотрудникаЗавершение", ЭтотОбъект, ПриемДляОтправки.Сотрудник), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если РезультатПроверкиИЭМК = "4" Тогда
		Текст = "ИЭМК: У сотрудника: " + Строка(ПриемДляОтправки.Сотрудник) + " не заполнено представление основной специализации по ИЭМК. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхСотрудникаЗавершение", ЭтотОбъект, ПриемДляОтправки.Сотрудник), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если РезультатПроверкиИЭМК = "5" Тогда
		Текст = "ИЭМК: У пациента: " + Строка(ПриемДляОтправки.Контрагент) + " должны быть заполнены обязательные поля: Имя, Фамилия, Дата рождения. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхКлиентаЗавершение", ЭтотОбъект, ПриемДляОтправки.Контрагент), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если РезультатПроверкиИЭМК = "6" Тогда
		Текст = "ИЭМК: У сотрудника: " + Строка(ПриемДляОтправки.Сотрудник) + " должны быть заполнены обязательные поля: Имя, Фамилия. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхСотрудникаЗавершение", ЭтотОбъект, ПриемДляОтправки.Сотрудник), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если РезультатПроверкиИЭМК = "8" Тогда
		Текст = "ИЭМК: У законного представителя пациента: " + Строка(ПриемДляОтправки.Контрагент) + " должны быть заполнены обязательные поля: Имя, Фамилия, Дата рождения. Открыть элемент справочника?";		
		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхКлиентаЗавершение", ЭтотОбъект, ПриемДляОтправки.Контрагент), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
	Если ТипЗнч(РезультатПроверкиИЭМК) = Тип("СправочникСсылка.Контрагенты") Тогда
		Текст = "ИЭМК: У пациента: " + Строка(ПриемДляОтправки.Контрагент) + " указан законный представитель: " + Строка(РезультатПроверкиИЭМК) + ". У которого не заполнены реквизиты документа определяющего право представлять пациента. Открыть элемент справочника?";		
		ДополнительныеНастройки = Новый Структура("Контрагент, Родственник", ПриемДляОтправки.Контрагент, РезультатПроверкиИЭМК);
 		ПоказатьВопрос(Новый ОписаниеОповещения("ИзменениеДанныхЗаконногоПредставителяЗавершение", ЭтотОбъект, ДополнительныеНастройки), Текст, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;

КонецПроцедуры

// Процедура - Изменение данных клиента
// Завершение немодального открытия окна "ПоказатьВопрос()" 
// Параметры:
//  РезультатВопроса - Ответ на вопрос
