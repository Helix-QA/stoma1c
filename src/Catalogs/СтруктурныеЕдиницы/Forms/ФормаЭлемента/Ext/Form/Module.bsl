// Проверка ввода времени работы стоматологии
//
&НаКлиенте
Процедура ВремяНачалаРаботыПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ВремяНачалаРаботы) И ЗначениеЗаполнено(Объект.ВремяОкончанияРаботы) Тогда
		
		Если Объект.ВремяОкончанияРаботы < Объект.ВремяНачалаРаботы Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Неверно введено время работы стоматологии. Время окончания работы должно быть больше чем время начала работы.");
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры // ВремяНачалаРаботыПриИзменении(Элемент)

// Создание списка значений веремени
//
&НаКлиенте
Процедура ВремяНачалаРаботыНачалоВыбораИзСписка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	МассивПериодов = Новый Массив;
	
	ПериодРаботы = Новый Структура("ДатаНачала, ДатаОкончания");
	ПериодРаботы.ДатаНачала = Дата("00010101000000");
	ПериодРаботы.ДатаОкончания = Дата("00010101235959");
	МассивПериодов.Добавить(ПериодРаботы);
	
	СписокВремени = РаботаСДиалогами.ВернутьСписокВремениДляНачалаРаботы(МассивПериодов,Ложь,30);
	
	НачальноеЗначение = СписокВремени.НайтиПоЗначению(Объект.ВремяНачалаРаботы);
	
	ПоказатьВыборИзСписка(Новый ОписаниеОповещения("ВремяНачалаРаботыПослеВыбораИзСписка", ЭтотОбъект, Новый Структура("Элемент", Элемент)), СписокВремени, Элемент, НачальноеЗначение); 	

КонецПроцедуры

&НаКлиенте 
// Процедура - Время начала работы после выбора из списка
//
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВремяНачалаРаботыПослеВыбораИзСписка(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Элемент = ДополнительныеПараметры.Элемент;
	Если ВыбранныйЭлемент <> Неопределено Тогда
		Объект.ВремяНачалаРаботы = ВыбранныйЭлемент.Значение;
		ВремяНачалаРаботыПриИзменении(Элемент);
	КонецЕсли;

КонецПроцедуры 

