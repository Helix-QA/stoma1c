
#Область СлужебныйПрограммныйИнтерфейс

// Получить величину задолженности по указанному документу
Функция ПолучитьЗадолженностьПоДокументу(
	ДокументСсылка,
	ВРазрезеКонтрагента = Неопределено,
	НеУчитываютсяДвижения = Неопределено,
	БезУчетаСписанияЗадолженности = Ложь) Экспорт
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Прием")
		ИЛИ ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Реализация")
		ИЛИ ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		ЗапросВыборка       = Новый Запрос;
		ЗапросВыборка.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.ДокументРеализации,
		|	ИСТИНА КАК ПризнакВыбора,
		|	- ВложенныйЗапрос.Сумма КАК Сумма
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВзаиморасчетыСКонтрагентамиОбороты.ДокументРеализации КАК ДокументРеализации,
		|		СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаОборот) КАК Сумма
		|	ИЗ
		|		РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
		|				,
		|				,
		|				Авто,
		|				ДокументРеализации = &ДокументСсылка
		|					И ВЫБОР
		|						КОГДА &Контрагент <> НЕОПРЕДЕЛЕНО
		|							ТОГДА Контрагент = &Контрагент
		|						ИНАЧЕ ИСТИНА
		|					КОНЕЦ) КАК ВзаиморасчетыСКонтрагентамиОбороты
		|	ГДЕ
		|		ВЫБОР
		|				КОГДА НЕ &НеУчитыватьДвиженияДокумента = НЕОПРЕДЕЛЕНО
		|					ТОГДА НЕ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор = &НеУчитыватьДвиженияДокумента
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ
		|		И ВЫБОР
		|				КОГДА &БезУчетаСписанияЗадолженности
		|					ТОГДА НЕ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.СписаниеЗадолженности
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВзаиморасчетыСКонтрагентамиОбороты.ДокументРеализации) КАК ВложенныйЗапрос";
		
		ЗапросВыборка.УстановитьПараметр("ДокументСсылка"               ,ДокументСсылка);
		ЗапросВыборка.УстановитьПараметр("Контрагент"                   ,ВРазрезеКонтрагента);
		ЗапросВыборка.УстановитьПараметр("НеУчитыватьДвиженияДокумента" ,НеУчитываютсяДвижения);
		ЗапросВыборка.УстановитьПараметр("БезУчетаСписанияЗадолженности",БезУчетаСписанияЗадолженности);

		РезВыборки = ЗапросВыборка.Выполнить().Выбрать();		
		Возврат ?(РезВыборки.Следующий() ,РезВыборки.Сумма, 0);		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.НарядЗаказ") И Константы.НарядЗаказУвеличиваетЗадолженность.Получить() Тогда
        ЗапросВыборка       = Новый Запрос;
		ЗапросВыборка.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.ДокументАванса,
		|	ИСТИНА КАК ПризнакВыбора,
		|	- ВложенныйЗапрос.Сумма  КАК Сумма
		|ИЗ
		|	(ВЫБРАТЬ
		|		СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаОборот) КАК Сумма,
		|		ВзаиморасчетыСКонтрагентамиОбороты.ДокументАванса КАК ДокументАванса
		|	ИЗ
		|		РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
		|				,
		|				,
		|				Авто,
		|				ДокументАванса = &ДокументСсылка
		|					И ВЫБОР
		|						КОГДА &Контрагент <> НЕОПРЕДЕЛЕНО
		|							ТОГДА Контрагент = &Контрагент
		|						ИНАЧЕ ИСТИНА
		|					КОНЕЦ) КАК ВзаиморасчетыСКонтрагентамиОбороты
		|	ГДЕ
		|		ВЫБОР
		|				КОГДА НЕ &НеУчитыватьДвиженияДокумента = НЕОПРЕДЕЛЕНО
		|					ТОГДА НЕ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор = &НеУчитыватьДвиженияДокумента
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ
		|		И ВЫБОР
		|				КОГДА &БезУчетаСписанияЗадолженности
		|					ТОГДА НЕ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.СписаниеЗадолженности
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВзаиморасчетыСКонтрагентамиОбороты.ДокументАванса) КАК ВложенныйЗапрос";
		
		ЗапросВыборка.УстановитьПараметр("ДокументСсылка"               ,ДокументСсылка);
		ЗапросВыборка.УстановитьПараметр("Контрагент"                   ,ВРазрезеКонтрагента);
		ЗапросВыборка.УстановитьПараметр("НеУчитыватьДвиженияДокумента" ,НеУчитываютсяДвижения);
		ЗапросВыборка.УстановитьПараметр("БезУчетаСписанияЗадолженности",БезУчетаСписанияЗадолженности);

		РезВыборки = ЗапросВыборка.Выполнить().Выбрать();		
		Возврат ?(РезВыборки.Следующий() ,РезВыборки.Сумма, 0);

	Иначе	
		ЗапросВыборка       = Новый Запрос;
		ЗапросВыборка.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.Сумма, 0)) КАК Сумма
		|ИЗ
		|	(ВЫБРАТЬ
		|		СУММА(ВЫБОР
		|				КОГДА (СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаПоставщику) ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтклиента)) 
		|					ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма
		|				ИНАЧЕ -СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма
		|			КОНЕЦ) КАК Сумма
		|	ИЗ
		|		Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
		|	ГДЕ
		|		СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен = ИСТИНА
		|		И (СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументОснования
		|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументАванса = &ДокументОснования)
		|		И ВЫБОР
		|				КОГДА НЕ &НеУчитыватьДвиженияДокумента = НЕОПРЕДЕЛЕНО
		|					ТОГДА НЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка = &НеУчитыватьДвиженияДокумента
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ
		|		И (СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтклиента)
		|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаПоставщику)
		|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыклиенту))
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		СУММА(ПоступлениеДенежныхСредствРасшифровкаПлатежа.Сумма)
		|	ИЗ
		|		Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
		|	ГДЕ
		|		ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен = ИСТИНА
		|		И (ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументОснования
		|				ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументАванса = &ДокументОснования)
		|		И ВЫБОР
		|				КОГДА НЕ &НеУчитыватьДвиженияДокумента = НЕОПРЕДЕЛЕНО
		|					ТОГДА НЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка = &НеУчитыватьДвиженияДокумента
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ
		|		И (ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтклиента)
		|				ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика)
		|				ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыклиенту))) КАК ВложенныйЗапрос";
		ЗапросВыборка.УстановитьПараметр("ДокументОснования"           ,ДокументСсылка);
		ЗапросВыборка.УстановитьПараметр("НеУчитыватьДвиженияДокумента",НеУчитываютсяДвижения);

		РезВыборки = ЗапросВыборка.Выполнить().Выбрать();

		Если НЕ ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.НарядЗаказ") Тогда			
			Если РезВыборки.Следующий() Тогда
				Возврат ДокументСсылка.СуммаДокумента - РезВыборки.Сумма;
			Иначе
				Возврат ДокументСсылка.СуммаДокумента;
			КонецЕсли;
		Иначе
			Если РезВыборки.Следующий() Тогда
				Возврат ДокументСсылка.СуммаПродажи - РезВыборки.Сумма;
			Иначе
				Возврат ДокументСсылка.СуммаПродажи;
			КонецЕсли;		
		КонецЕсли;

	КонецЕсли;

КонецФункции

// Получить величину задолженности по указанному контрагенту
Функция ДанныеПоВзаиморасчетамДляКонтрагента(
	Контрагент,
	КонецПериода                    = Неопределено,
	СтруктурнаяЕдиница              = Неопределено,
	ТолькоСЗадолженностьюПередНами  = Истина,
	ВключаяАвансы                   = Ложь,
	ИсключитьРегистратор            = Неопределено,
	Договор                         = Неопределено,
	Организация                     = Неопределено) Экспорт
	
	МассивСтруктурныхЕдиниц = Новый Массив;	
	МассивОрганизаций = Новый Массив();		
	Если ЗначениеЗаполнено(Организация) Тогда
		
		Если Организация.ЭтоГоловнаяОрганизация Тогда
			
			МассивОрганизаций = Справочники.Организации.ПолучитьПодчиненныеГоловнойОрганизации(Организация); 		
			ЗапросСтрЕд = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
			|ГДЕ
			|	СтруктурныеЕдиницы.Организация.ГоловнаяОрганизация.Ссылка = &Ссылка
			|	ИЛИ СтруктурныеЕдиницы.Организация.Ссылка = &Ссылка");	
			ЗапросСтрЕд.УстановитьПараметр("Ссылка", Организация);			
			МассивСтруктурныхЕдиниц = ЗапросСтрЕд.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
			
		КонецЕсли;
		МассивОрганизаций.Добавить(Организация);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) И ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда		
		МассивСтруктурныхЕдиниц.Добавить(СтруктурнаяЕдиница);	
	КонецЕсли;
	
	ЗапросВыборка       = Новый Запрос;
	ЗапросВыборка.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.ДокументРеализации КАК ДокументРеализации,
	|	ВложенныйЗапрос.ДокументАванса КАК ДокументАванса,
	|	ВложенныйЗапрос.ЭтоАванс КАК ЭтоАванс,
	|	ВложенныйЗапрос.СуммаДокумента КАК СуммаДокумента,
	|	ВложенныйЗапрос.Задолженность КАК Задолженность,
	|	ВложенныйЗапрос.Оплачено КАК Оплачено
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации
	|			ИНАЧЕ ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса
	|		КОНЕЦ КАК ДокументРеализации,
	|		ВЫБОР
	|			КОГДА &ВключаяАвансы = ИСТИНА
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса
	|		КОНЕЦ КАК ДокументАванса,
	|		ВЫБОР
	|			КОГДА &ВключаяАвансы = ИСТИНА
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ЭтоАванс
	|		КОНЕЦ КАК ЭтоАванс,
	|		ВЫБОР
	|			КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации.СуммаДокумента
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса <> НЕОПРЕДЕЛЕНО
	|						ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса.СуммаДокумента
	|				КОНЕЦ
	|		КОНЕЦ КАК СуммаДокумента,
	|		СУММА(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаОборот) * -1 КАК Задолженность,
	|		СУММА(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаПриход) КАК Оплачено
	|	ИЗ
	|		РегистрНакопления.ВзаиморасчетыСКонтрагентами.ОстаткиИОбороты(
	|				,
	|				&КонецПериода,
	|				Авто,
	|				,
	|				&УсловиеСтруктурнаяЕдиница
	|					И ВЫБОР
	|						КОГДА &ТолькоСЗадолженностьюПередНами = ИСТИНА
	|							ТОГДА НЕ ДокументРеализации = НЕОПРЕДЕЛЕНО
	|									ИЛИ НЕ ДокументАванса = НЕОПРЕДЕЛЕНО
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	|					И Контрагент = &Контрагент
	|					И ВЫБОР
	|						КОГДА НЕ &Договор = НЕОПРЕДЕЛЕНО
	|								И НЕ &Договор = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	|							ТОГДА Договор = &Договор
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	|					И &УсловиеОрганизация) КАК ВзаиморасчетыСКонтрагентамиОстаткиИОбороты
	|	ГДЕ
	|		ВЫБОР
	|				КОГДА &ИсключитьРегистратор <> НЕОПРЕДЕЛЕНО
	|					ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Регистратор <> &ИсключитьРегистратор
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВЫБОР
	|			КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации
	|			ИНАЧЕ ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса
	|		КОНЕЦ,
	|		ВЫБОР
	|			КОГДА &ВключаяАвансы = ИСТИНА
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса
	|		КОНЕЦ,
	|		ВЫБОР
	|			КОГДА &ВключаяАвансы = ИСТИНА
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ЭтоАванс
	|		КОНЕЦ,
	|		ВЫБОР
	|			КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации.СуммаДокумента
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса <> НЕОПРЕДЕЛЕНО
	|						ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса.СуммаДокумента
	|				КОНЕЦ
	|		КОНЕЦ) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ТолькоСЗадолженностьюПередНами = ИСТИНА
	|				ТОГДА ВложенныйЗапрос.Задолженность > 0
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументРеализации
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	ЗапросВыборка.УстановитьПараметр("КонецПериода"                   ,КонецПериода);
	ЗапросВыборка.УстановитьПараметр("Контрагент"                     ,Контрагент);
	ЗапросВыборка.УстановитьПараметр("МассивСтруктурныхЕдиниц"        ,МассивСтруктурныхЕдиниц);
	ЗапросВыборка.УстановитьПараметр("ТолькоСЗадолженностьюПередНами" ,ТолькоСЗадолженностьюПередНами);
	ЗапросВыборка.УстановитьПараметр("ВключаяАвансы"                  ,ВключаяАвансы);
	ЗапросВыборка.УстановитьПараметр("ИсключитьРегистратор"           ,?(ЗначениеЗаполнено(ИсключитьРегистратор), ИсключитьРегистратор, Неопределено));
	ЗапросВыборка.УстановитьПараметр("Договор"                        ,Договор);
	ЗапросВыборка.УстановитьПараметр("МассивОрганизаций"              ,МассивОрганизаций);
	
	УсловиеСтруктурнаяЕдиница = ?(МассивСтруктурныхЕдиниц.Количество() > 0, "СтруктурнаяЕдиница В (&МассивСтруктурныхЕдиниц)", "ИСТИНА");
	ЗапросВыборка.Текст = СтрЗаменить(ЗапросВыборка.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
	
	УсловиеОрганизация = ?(МассивОрганизаций.Количество() > 0, "Организация В (&МассивОрганизаций)", "ИСТИНА");
	ЗапросВыборка.Текст = СтрЗаменить(ЗапросВыборка.Текст, "&УсловиеОрганизация", УсловиеОрганизация); 	
	
	Возврат ЗапросВыборка.Выполнить().Выгрузить();
	
КонецФункции

// Получить сумму остатка по взаиморасчетам с контрагентом
Функция ПолучитьОстатокПоВзаиморасчетамСконтрагентом(
	Контрагент,
	Период				= Неопределено,
	СтруктурнаяЕдиница	= Неопределено) Экспорт	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	-ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток КАК Задолженность
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
	|			&Период,
	|			Контрагент = &Контрагент
	|				И ВЫБОР
	|					КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|							И НЕ &СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|						ТОГДА СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК ВзаиморасчетыСКонтрагентамиОстатки";
				   
	Запрос.УстановитьПараметр("Контрагент"        ,Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Период"            ,Период);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
	     Возврат Выборка.Задолженность;
	 Иначе
		 Возврат 0;
	КонецЕсли;
	
КонецФункции									

// Получить сумму остаток по лицевому счету по взаиморасчетам с контрагентом
Функция ПолучитьОстатокЛицевойСчетПоВзаиморасчетамСконтрагентом(
	Контрагент,
	Период				= Неопределено,
	СтруктурнаяЕдиница	= Неопределено) Экспорт	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВЫБОР
	|			КОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса = НЕОПРЕДЕЛЕНО
	|					И ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументРеализации = НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаПриход - ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаРасход
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Остаток
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.ОстаткиИОбороты(
	|			,
	|			&Период,
	|			Авто,
	|			,
	|			Контрагент = &Контрагент
	|				И ВЫБОР
	|					КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|							И НЕ &СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|						ТОГДА СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК ВзаиморасчетыСКонтрагентамиОстаткиИОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Контрагент";
				   
	Запрос.УстановитьПараметр("Контрагент",Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Период",Период);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
	     Возврат Выборка.Остаток;
	 Иначе
		 Возврат 0;
	КонецЕсли;

КонецФункции	

// Получить документы оплаты, для указанного документ реализации
Функция ПолучитьДокументыОплатыПоДокументуРеализации(
	ДокументРеализации,
	ТипДенежныхСредств = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзаиморасчетыСКонтрагентамиОбороты.Регистратор КАК ДокументОплаты,
	|	СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход) КАК СуммаОплаты
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(, , Авто, ДокументРеализации = &ДокументРеализации) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|ГДЕ
	|	ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход > 0
	|	И ВЫБОР
	|			КОГДА &ТипДенежныхСредств <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор.ТипДенежныхСредств = &ТипДенежныхСредств
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОбороты.Регистратор");
	Запрос.УстановитьПараметр("ДокументРеализации",ДокументРеализации);
    Запрос.УстановитьПараметр("ТипДенежныхСредств",ТипДенежныхСредств);	
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Получить сумму оплаты по документу
Функция ПолучитьСуммуОплатыПоДокументу(ДокументОснования, ИсключитьРегистратор = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход), 0) КАК СуммаПриход
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(, , Авто, ДокументРеализации = &Основание) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|ГДЕ
	|	(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход > 0
	|			ИЛИ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.СписаниеДенежныхСредств
	|				И ВзаиморасчетыСКонтрагентамиОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту))
	|	И ВЫБОР
	|			КОГДА &ИсключитьРегистратор <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор <> &ИсключитьРегистратор
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ");
	
	Запрос.УстановитьПараметр("Основание"			, ДокументОснования);
	Запрос.УстановитьПараметр("ИсключитьРегистратор", ИсключитьРегистратор); // документ регистратор
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.СуммаПриход, 0);
	
КонецФункции

// Функция получает сумму оплаты по документу возврата от пациента.
//
Функция ПолучитьСуммуОплатПоДокументуВозврата(ДокументВозврата, НеУчитыватьДвижения = Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ДокументыОплаты
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
	|	И ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументВозврата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументВозврата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход, 0)) * -1 КАК СуммаПриход
	|ИЗ
	|	ДокументыОплаты КАК ДокументыОплаты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(, , Регистратор, ) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|		ПО ДокументыОплаты.Ссылка = ВзаиморасчетыСКонтрагентамиОбороты.Регистратор
	|ГДЕ
	|	ВзаиморасчетыСКонтрагентамиОбороты.Регистратор В (ДокументыОплаты.Ссылка)
	|	И ВЫБОР
	|			КОГДА &ИсключитьРегистратор <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор <> &ИсключитьРегистратор
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ДокументВозврата"    , ДокументВозврата);
	Запрос.УстановитьПараметр("ИсключитьРегистратор", НеУчитыватьДвижения);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.СуммаПриход, 0);
	
КонецФункции

// Получить документы оплаты, для указанного документ реализации
Функция ВернутьСтруктуруОплатыПоДокументу(ДокументРеализации) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзаиморасчетыСКонтрагентамиОбороты.Период КАК ДатаПлатежа,
	|	ВзаиморасчетыСКонтрагентамиОбороты.Регистратор КАК ДокументОплаты,
	|	СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход) КАК СуммаОплачено,
	|	ВЫБОР
	|		КОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.Прием
	|			ТОГДА ""Зачет аванса""
	|		КОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.СписаниеЗадолженности
	|			ТОГДА ""Списание задолженности""
	|		ИНАЧЕ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор.ТипДенежныхСредств
	|	КОНЕЦ КАК ТипДенежныхСредств,
	|	ВЫРАЗИТЬ(ВзаиморасчетыСКонтрагентамиОбороты.Регистратор КАК Документ.ПоступлениеДенежныхСредств).ОплатаПоСсылке КАК ОплатаПоСсылке
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(, , Регистратор, ДокументРеализации = &ДокументРеализации) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОбороты.Регистратор,
	|	ВЫБОР
	|		КОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.Прием
	|			ТОГДА ""Зачет аванса""
	|		КОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.СписаниеЗадолженности
	|			ТОГДА ""Списание задолженности""
	|		ИНАЧЕ ВзаиморасчетыСКонтрагентамиОбороты.Регистратор.ТипДенежныхСредств
	|	КОНЕЦ,
	|	ВзаиморасчетыСКонтрагентамиОбороты.Период");
	
	Запрос.УстановитьПараметр("ДокументРеализации", ДокументРеализации);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

