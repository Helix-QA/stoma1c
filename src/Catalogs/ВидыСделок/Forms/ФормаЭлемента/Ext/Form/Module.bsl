

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЕстьПравоРедактировать 			= ПравоДоступа("Редактирование", Объект.Ссылка.Метаданные());
	ЗаблокироватьИзменениеЭтапов 	= Объект.Предопределенный И Объект.Ссылка = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	
	// Определяем режим отображения структурных единиц применения
	ОпределитьРежимОтображенияСпискаСтруктурныхЕдиниц();
	
	//// Определяем режим отображения статусов пациента применения
	//ОпределитьРежимОтображенияСпискаСтатусовПациентов();
	
	// Устанавливаем видимость элементам в зависимости от режима отображения
	УстановитьВидимостьЭлементамСпискаСтруктурныхЕдиниц();
	
	//// Устанавливаем видимость элементам в зависимости от режима отображения
	//УстановитьВидимостьЭлементамСпискаСтатусовПациентов();
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		ТЗЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(Объект.Ссылка);
		
		Для Каждого СтрокаТЗ Из ТЗЭтапов Цикл
			
			НоваяСтрока = ЭтотОбъект.ЭтапыСделок.Добавить();	
			НоваяСтрока.Цвет         =  СтрокаТЗ.ЭтапСделки.ЦветЭтапа;
			НоваяСтрока.Наименование =  СтрокаТЗ.ЭтапСделки.Наименование;
			НоваяСтрока.Ссылка		 =  СтрокаТЗ.ЭтапСделки;
			
		КонецЦикла;
		//// Реквизит "ТипСделки" был добавлен в справочник позже. Он обязателен к заполнению. Для предопределенного элемента справочника
		//// заполним его при открытии, несмотря на то что так делать крайне неправильно.
		//Если Объект.Предопределенный И Объект.ИмяПредопределенныхДанных = "ПродажаЧленства" Тогда
		//	Если НЕ ЗначениеЗаполнено(Объект.ТипСделки) ИЛИ Объект.ТипСделки = Перечисления.ТипыСделок.Продление Тогда 
		//		Объект.ТипСделки = Перечисления.ТипыСделок.Продажа;
		//	КонецЕсли;	
		//КонецЕсли;	
	КонецЕсли;
	
	НоваяСтрока = ЭтапыСделок.Добавить();
	УправлениеИнтерфейсамиСервер.ОбновитьПалитруЦветов(ЭтаФорма);	
	СоздатьЭлементыТаблицы();
	
	ОтобразитьДопустимыеПричиныОтказа(Истина);
	
	ЗаблокироватьЭлементыДляПредопреленныхОбъектов();
	
	ИнициализироватьСписокСтруктурныхЕдиниц();
	
	//ИнициализироватьСписокСтатусовПациентов();
	
	Для Каждого СтрокаСЕПрименения Из Объект.СтруктурныеЕдиницыПрименения Цикл 
		СтрокаСЕПрименения.ПоУмолчанию = ЗначениеЗаполнено(СтрокаСЕПрименения.СтруктурнаяЕдиница) И СтрокаСЕПрименения.СтруктурнаяЕдиница = Объект.СтруктурнаяЕдиница;
	КонецЦикла;	
	
	ЗаблокироватьЭлементыПоПравамДоступаОбъекта();
	
	ЭтаФорма.ТекущийЭлемент = Элементы.ФормаКнопкаСохранитьИЗакрыть;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаСервере
// Процедура - Перед записью на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ЭтапыСделок", ЭтапыСделок.Выгрузить());
	
	ТаблицаПримененияСЕ = ТекущийОбъект.СтруктурныеЕдиницыПрименения.Выгрузить(, "СтруктурнаяЕдиница");
	ТаблицаПримененияСЕ.Свернуть("СтруктурнаяЕдиница");
	Если ТаблицаПримененияСЕ.Количество() > 1 Тогда 
		ПустаяСтрокаСЕ = ТаблицаПримененияСЕ.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), "СтруктурнаяЕдиница");
		Если ПустаяСтрокаСЕ <> Неопределено Тогда 
			ТаблицаПримененияСЕ.Удалить(ПустаяСтрокаСЕ);
		КонецЕсли;	
	КонецЕсли;
	ТекущийОбъект.СтруктурныеЕдиницыПрименения.Загрузить(ТаблицаПримененияСЕ);
	
	//ТаблицаПримененияСтатусов = ТекущийОбъект.СтатусыПациентовПрименения.Выгрузить(, "СтатусПациента");
	//ТаблицаПримененияСтатусов.Свернуть("СтатусПациента");
	//Если ТаблицаПримененияСтатусов.Количество() > 1 Тогда 
	//	ПустаяСтрокаСтатуса = ТаблицаПримененияСтатусов.Найти(Перечисления.СтатусыКонтрагентов.ПустаяСсылка(), "СтатусПациента");
	//	Если ПустаяСтрокаСтатуса <> Неопределено Тогда 
	//		ТаблицаПримененияСтатусов.Удалить(ПустаяСтрокаСтатуса);
	//	КонецЕсли;	
	//КонецЕсли;
	//ТекущийОбъект.СтатусыПациентовПрименения.Загрузить(ТаблицаПримененияСтатусов);
	
	Если ТекущийОбъект.ПричиныОтказов.Количество() > 0 Тогда
		Если НЕ ТекущийОбъект.ПричиныОтказов.Найти(ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.ЛюбаяПричина")) = Неопределено Тогда 
			ТекущийОбъект.ПричиныОтказов.Очистить();
		Иначе 
			ТаблицаПричинОтказов = СгруппироватьПричиныОтказа(ТекущийОбъект);	
			//Если НЕ ЗначениеЗаполнено(ТаблицаПричинОтказов) Тогда
			//	Отказ = Истина;
			//	ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Укажите причину отказа';en='Specify the reason for refusal'")
			//	, 
			//	, "Объект.ПричиныОтказов[0].ПричинаОтказа");
			//	Возврат;
			//КонецЕсли;		
			ТекущийОбъект.ПричиныОтказов.Загрузить(ТаблицаПричинОтказов);
		КонецЕсли;			
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Сгруппировать причины отказа
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СгруппироватьПричиныОтказа(ТекущийОбъект)

	ТаблицаПричинОтказов = ТекущийОбъект.ПричиныОтказов.Выгрузить(, "ПричинаОтказа");
	ТаблицаПричинОтказов.Свернуть("ПричинаОтказа");
	ПустаяСтрокаПричины = ТаблицаПричинОтказов.Найти(Справочники.ПричиныОтказов.ПустаяСсылка(), "ПричинаОтказа");
	Если ПустаяСтрокаПричины <> Неопределено Тогда 
		ТаблицаПричинОтказов.Удалить(ПустаяСтрокаПричины);
	КонецЕсли;	

	Возврат ТаблицаПричинОтказов;
	
КонецФункции

