// Процедура, Переименовать параметры шаблонов сообщений
//
Процедура ПереименоватьПараметрыШаблоновСообщений() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ШаблоныСообщений.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	НЕ ШаблоныСообщений.ЭтоГруппа");  
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл  
		РезультатСМС = "";
		РезультатЗадача = ""; 
		РезультатПисьмо = "";
		ШаблонСообщения = Выборка.Ссылка.ПолучитьОбъект(); 
		МассивПараметровСМС    = ПолучитьМассивПараметровИзШаблона(ШаблонСообщения.Содержание, "{}");
		МассивПараметровЗадача = ПолучитьМассивПараметровИзШаблона(ШаблонСообщения.ЗадачаОписание, "{}"); 
		МассивПараметровПисьма = ПолучитьМассивПараметровИзШаблона(ШаблонСообщения.ТекстHTML, "{}");
		Для Каждого ПараметрСМС Из МассивПараметровСМС Цикл
			Если ПараметрСМС = "ПолныйАдресСтруктурнойЕдиницы" Тогда
				РезультатСМС = "{ПолныйАдресКлиники}";
			ИначеЕсли ПараметрСМС = "КороткийАдресСтруктурнойЕдиницы" Тогда
				РезультатСМС = "{КороткийАдресКлиники}";
			ИначеЕсли ПараметрСМС = "СайтСтруктурнойЕдиницы" Тогда
				РезультатСМС = "{СайтКлиники}";  
			ИначеЕсли ПараметрСМС = "ФамилияКонтрагента" Тогда
				РезультатСМС = "{ФамилияПациента}";
			ИначеЕсли ПараметрСМС = "ИмяКонтрагента" Тогда
				РезультатСМС = "{ИмяПациента}"; 
			ИначеЕсли ПараметрСМС = "ОтчествоКонтрагента" Тогда
				РезультатСМС = "{ОтчествоПациента}";
			ИначеЕсли ПараметрСМС = "НаименованиеКонтрагента" Тогда
				РезультатСМС = "{ФИОПациента}";
			ИначеЕсли ПараметрСМС = "ДатаРожденияКлиента" Тогда
				РезультатСМС = "{ДатаРожденияПациента}"; 
			ИначеЕсли ПараметрСМС = "СтруктурнаяЕдиницаПоЛистуОжидания"	Тогда
				РезультатСМС = "{КлиникаПоЛистуОжидания}";
			ИначеЕсли ПараметрСМС = "СтруктурнаяЕдиницаЗаписи" Тогда
				РезультатСМС = "{КлиникаЗаписи}"; 
			ИначеЕсли ПараметрСМС = "СтруктурнаяЕдиницаПриема" Тогда
				РезультатСМС = "{КлиникаПриема}";
			Иначе
				РезультатСМС = "{" + ПараметрСМС + "}";
			КонецЕсли;
			
			Если РезультатСМС <> Неопределено Тогда
				ШаблонСообщения.Содержание = СтрЗаменить(ШаблонСообщения.Содержание, "{" + ПараметрСМС + "}", РезультатСМС);
			КонецЕсли; 		
		КонецЦикла;	
		
		Для Каждого ПараметрЗадача Из МассивПараметровЗадача Цикл
			Если ПараметрЗадача = "ПолныйАдресСтруктурнойЕдиницы" Тогда
				РезультатЗадача = "{ПолныйАдресКлиники}";
