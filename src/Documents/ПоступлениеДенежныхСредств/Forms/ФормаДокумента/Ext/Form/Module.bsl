// Процедура - Общий обработчик заполнения по акту завершение
// Завершение немодального открытия окна формы - Документ Акт оказания услуг - ФормаВыбора
// Параметры:
//  Результат	 - 	 Результат Оповещения 
//  Параметры	 - 	 Параметры Оповещения  
//   
&НаКлиенте
Процедура ОбщийОбработчикЗаполненияПоАктуЗавершение(Результат, Параметры)  Экспорт
	
	Команда = Параметры;

	Если ЗначениеЗаполнено(Результат) Тогда
		Если Команда.Имя = "ДобавитьПоАктуВсемиПриемами" Тогда
			ЗаполнитьТаблицуРасшифровкиПоАктуОказанияуслуг(Результат,Ложь,Ложь);
		ИначеЕсли Команда.Имя = "ДобавитьПоАктуТолькоНеОплаченными" Тогда
			ЗаполнитьТаблицуРасшифровкиПоАктуОказанияуслуг(Результат,Ложь,Истина);
		ИначеЕсли Команда.Имя = "ЗаполнитьПоАктуВсемиПриемами" Тогда			
			ЗаполнитьТаблицуРасшифровкиПоАктуОказанияуслуг(Результат,Истина,Ложь);
		ИначеЕсли Команда.Имя = "ЗаполнитьПоАктуТолькоНеОплаченными" Тогда
			ЗаполнитьТаблицуРасшифровкиПоАктуОказанияуслуг(Результат,Истина,Истина);
		КонецЕсли;
	КонецЕсли;	
	Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("Сумма");

КонецПроцедуры

&НаСервере
// Процедура заполняет таблицу расшифровки по указанным параметрам
//
Процедура ЗаполнитьТаблицуРасшифровкиПоАктуОказанияуслуг(АктЗаполнения,Перезаполнить,ТолькоНеОплаченные)
	
	Если Перезаполнить Тогда
	     Объект.РасшифровкаПлатежа.Очистить();
    КонецЕсли;	
	Для Каждого СтрокаТЧ ИЗ АктЗаполнения.ОказанныеУслуги Цикл	
		Если НЕ ТолькоНеОплаченные ИЛИ СтрокаТЧ.ДокументОснования.СуммаОплачено < СтрокаТЧ.ДокументОснования.СуммаДокумента Тогда
			НоваяСтрока = Объект.РасшифровкаПлатежа.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

