	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{Заголовок}"     		 , Нстр("ru='Редактировать заметку';en='Edit note'"));
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{Заметка}"	     		 , Нстр("ru='Заметка';en='Note'"));	
	
	// СобытиеЗакреплено = (СтрокаТЗ.ТипВзаимодействия = "Закреплен");
