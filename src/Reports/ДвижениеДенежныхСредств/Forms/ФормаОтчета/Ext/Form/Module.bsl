
#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - обработчик нажатия на кнопку "Сформировать".
//
Процедура СформироватьВыполнить()
	
	СформироватьОтчет();
	
КонецПроцедуры

&НаСервере
// Процедура выводит движения по регистру бухгалтерии.
//
Процедура СформироватьОтчет()
	
	СтруктурныеЕдиницы.Очистить();
	ТабличныйДокументОтчет.Очистить();
	СписокГруппировки.Очистить();
	
	ВысотаОтчета = 0;
	Первый = Истина;

	ВсегоНачОст = 0;
	ВсегоКонОст = 0;
	ВсегоТД = 0;
	ВсегоФД = 0;
	Процент = 0;
		
	///////////////////// Отбор по стр. ед. ////////////////////
	
	Если ЭтаФорма.СтруктурныеЕдиницыИспользование И ЭтаФорма.СтруктурныеЕдиницыОтбор.Количество() > 0 Тогда
		
		ЗапросСтрЕд = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		                           |	СтруктурныеЕдиницы.Ссылка КАК СтрЕд
		                           |ИЗ
		                           |	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		                           |ГДЕ
		                           |	НЕ СтруктурныеЕдиницы.ПометкаУдаления
		                           |	И СтруктурныеЕдиницы.Ссылка В(&Ссылка)
		                           |
		                           |УПОРЯДОЧИТЬ ПО
		                           |	СтруктурныеЕдиницы.Наименование");
								   
		ЗапросСтрЕд.УстановитьПараметр("Ссылка",ЭтаФорма.СтруктурныеЕдиницыОтбор);
		СтруктурныеЕдиницы.Загрузить(ЗапросСтрЕд.Выполнить().Выгрузить());

		
		//Для Каждого СтрЕдОтбор Из ЭтаФорма.СтруктурныеЕдиницыОтбор Цикл
		//	
		//	НС = СтруктурныеЕдиницы.Добавить();
		//	НС.СтрЕд = СтрЕдОтбор.Значение;
		//	
		//КонецЦикла;
		
		НС = СтруктурныеЕдиницы.Вставить(0); 
		НС.СтрЕд = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
		
	Иначе
		
		ЗапросСтрЕд = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтруктурныеЕдиницы.Ссылка КАК СтрЕд
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|ГДЕ
		|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	СтруктурныеЕдиницы.Наименование");
		
		СтруктурныеЕдиницы.Загрузить(ЗапросСтрЕд.Выполнить().Выгрузить());
		НС = СтруктурныеЕдиницы.Вставить(0);
		НС.СтрЕд = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
		
	КонецЕсли;	
	
	//////////////////// Отбор по Кассам (влияет на стр.ед.) /////////////////
	
	Если СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 Тогда 
		
		ЗапросСтрЕдПоКасса = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ЗапросСтрЕд.СтруктурнаяЕдиница КАК СтрЕд 
		|ИЗ
		|	(ВЫБРАТЬ
		|		Кассы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|	ИЗ
		|		Справочник.Кассы КАК Кассы
		|	ГДЕ
		|		Кассы.Ссылка В(&СчетКассаОтбор)
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		СтруктурныеЕдиницы.Ссылка
		|	ИЗ
		|		Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|	ГДЕ
		|		СтруктурныеЕдиницы.Организация В
		|				(ВЫБРАТЬ
		|					БанковскиеСчета.Владелец
		|				ИЗ
		|					Справочник.БанковскиеСчета КАК БанковскиеСчета
		|				ГДЕ
		|					БанковскиеСчета.Ссылка В (&СчетКассаОтбор))) КАК ЗапросСтрЕд
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗапросСтрЕд.СтруктурнаяЕдиница.Наименование");
		
		ЗапросСтрЕдПоКасса.УстановитьПараметр("СчетКассаОтбор", СчетКассаОтбор);
		
		СтруктурныеЕдиницы.Очистить();
		СтруктурныеЕдиницы.Загрузить(ЗапросСтрЕдПоКасса.Выполнить().Выгрузить());
		НС = СтруктурныеЕдиницы.Вставить(0);
		НС.СтрЕд = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	
	КонецЕсли;
	
	
	/////////////// ОСНОВНОЙ ЦИКЛ ПО СТР.ЕД. ////////////////////////////////////////////////
	
	Для Каждого СтрокаСтрЕд ИЗ СтруктурныеЕдиницы Цикл
		
		ТабличныйДокумент.Очистить();	
		ИтогДС = 0;
		ИтогП = 0;
		ИтогР = 0;
		КонтрольнаяЦифра = 0;
		СтруктурнаяЕдиница = СтрокаСтрЕд.СтрЕд;
		
		Макет 				= Отчеты.ДвижениеДенежныхСредств.ПолучитьМакет("Макет");
		ОбластьЗаголовок 	= Макет.ПолучитьОбласть("Заголовок");
		ОбластьШапка 		= Макет.ПолучитьОбласть("ШапкаТаблицы");
		ОбластьОстаток 		= Макет.ПолучитьОбласть("Остаток");
		ОбластьРаздел 		= Макет.ПолучитьОбласть("Раздел");
		ОбластьИтогРаздел 	= Макет.ПолучитьОбласть("ИтогРаздел");
		
		Если ЭтаФорма.ПериодИспользование Тогда
			ОбластьЗаголовок.Параметры.Период = ЭтаФорма.Период;
		Иначе
			ОбластьЗаголовок.Параметры.Период = "";
		КонецЕсли;
	
		ОбластьЗаголовок.Параметры.ТекСтрЕд = ?(СтруктурнаяЕдиница.Пустая(), "ВСЕГО", СтруктурнаяЕдиница);
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		// ОСТАТКИ -----------------------------------------------------------------------------------------------
		
		ЗапросОстатки = Новый Запрос;
		ЗапросОстатки.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	УправленческийОстаткиИОбороты.СуммаНачальныйОстатокДт,
		|	УправленческийОстаткиИОбороты.СуммаКонечныйОстатокДт
		|ИЗ
		|	РегистрБухгалтерии.Управленческий.ОстаткиИОбороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			Период,
		|			,
		|			Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)
		|				ИЛИ Счет = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк),
		|			,
		|			"+ ?(ЗначениеЗаполнено(СтруктурнаяЕдиница),"СтруктурнаяЕдиница = &СтруктурнаяЕдиница","") 
		+ ?(ЗначениеЗаполнено(СтруктурнаяЕдиница) И СчетКассаИспользование И СчетКассаОтбор.Количество() > 0, " И ", "")
		+ ?(СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 ,"Субконто1 В (&СчетКасса)","")+") КАК УправленческийОстаткиИОбороты";
		//+ ?(ЗначениеЗаполнено(СчетКасса),"Субконто1 = &СчетКасса","")+") КАК УправленческийОстаткиИОбороты";
				
		
		Если ЭтаФорма.ПериодИспользование Тогда
			
			ЗапросОстатки.УстановитьПараметр("НачалоПериода", Период.ДатаНачала);	
			Если НЕ ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
				ЗапросОстатки.УстановитьПараметр("КонецПериода", Дата(3999, 1, 1));		
			Иначе	
				ЗапросОстатки.УстановитьПараметр("КонецПериода", Период.ДатаОкончания);	
			КонецЕсли;	
			
		Иначе
			ЗапросОстатки.УстановитьПараметр("НачалоПериода", '00010101');	
			ЗапросОстатки.УстановитьПараметр("КонецПериода", '00010101');	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			ЗапросОстатки.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);	
		КонецЕсли;		
		
		Если СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 Тогда
			ЗапросОстатки.УстановитьПараметр("СчетКасса", СчетКассаОтбор);	
		КонецЕсли;	
		
		РезультатОстатки = ЗапросОстатки.Выполнить().Выбрать();
		ЕстьОстатки = РезультатОстатки.Следующий();
		ОбластьОстаток.Параметры.СтрокаОстаток = "ОСТАТОК НА НАЧАЛО";
		Если ЕстьОстатки Тогда
			ОбластьОстаток.Параметры.Остаток = РезультатОстатки.СуммаНачальныйОстатокДт;
			КонтрольнаяЦифра = КонтрольнаяЦифра + РезультатОстатки.СуммаНачальныйОстатокДт; 	
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			Процент = ?(ВсегоНачОст = 0, 0, Окр(ОбластьОстаток.Параметры.Остаток/ВсегоНачОст * 100,2));
		Иначе
			ВсегоНачОст = ОбластьОстаток.Параметры.Остаток;	
		КонецЕсли;	
		
		ОбластьОстаток.Параметры.Процент = ?(Процент = 0, "", Строка(Процент) +" %");
		
		ТабличныйДокумент.Вывести(ОбластьОстаток);	
		
		
		// ------------------------------------------------- ПРИХОД ТД -------------------------------------------
		
		ОбластьШапка.Параметры.Раздел = "ТЕКУЩАЯ ДЕЯТЕЛЬНОСТЬ";
		ТабличныйДокумент.Вывести(ОбластьШапка);	
		ОбластьРаздел.Параметры.СтрокаРаздел = "Приход";
		ТабличныйДокумент.Вывести(ОбластьРаздел);
		
		// Оплаты от покупателей авансом -------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПокупателиПоАвансам)", "Оплаты от покупателей авансом");
		
		// Оплаты от покупателей ---------------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Покупатели) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Эквайринг)", "Оплаты от покупателей");
		
		// Возвраты от поставщиков  ------------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики)", "Возвраты от поставщиков");
		
		// Возвраты от подотчетников -----------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Подотчет)", "Возвраты от подотчетников");
		
		// Возвраты зарплаты -------------------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Зарплата)", "Возвраты зарплаты");
		
		// Прочие доходы -----------------------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ДоходыПрочие) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Служебный)", "Прочие доходы");      
		
		
		// ------------------------------------------------- РАСХОД ТД -------------------------------------------
		
		ОбластьРаздел.Параметры.СтрокаРаздел = "Расход";
		ТабличныйДокумент.Вывести(ОбластьРаздел);
		
		// Оплаты поставщикам ------------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Поставщики)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Оплаты поставщикам");
		
		// Выдача денежных средств подотчетникам -----------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Подотчет)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Выдача денежных средств подотчетникам");
		
		// Выдача зарплаты ---------------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Зарплата)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Выдача зарплаты");
		
		// Оплата налогов ----------------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Налоги)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Оплата налогов");
		
		// Возвраты покупателям ----------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Покупатели) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПокупателиПоАвансам)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Возвраты покупателям");
		
		// Прочие расходы ----------------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыПрочие) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Служебный) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыРаспределенные)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Прочие расходы");		
		
		
		// ------------------------------------------------- ИТОГ ТД ---------------------------------------------
		
		ОбластьИтогРаздел.Параметры.СтрокаРаздел = "ТЕКУЩАЯ ДЕЯТЕЛЬНОСТЬ:";
		ОбластьИтогРаздел.Параметры.Итог = ИтогДС;
		ОбластьИтогРаздел.Параметры.ИтогП = ИтогП;
		ОбластьИтогРаздел.Параметры.ИтогР = ИтогР;
		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			Процент = ?(ВсегоТД = 0, 0, Окр(ОбластьИтогРаздел.Параметры.Итог/ВсегоТД * 100,2));
		Иначе
			ВсегоТД = ОбластьИтогРаздел.Параметры.Итог;	
		КонецЕсли;	
		
		ОбластьИтогРаздел.Параметры.Процент = ?(Процент = 0, "", Строка(Процент) +" %");
		
		ТабличныйДокумент.Вывести(ОбластьИтогРаздел);
		КонтрольнаяЦифра = КонтрольнаяЦифра + ИтогДС;
		ИтогДС = 0;
		ИтогП = 0;
		ИтогР = 0;	
		
		
		// ------------------------------------------------- ПРИХОД ФД -------------------------------------------
		ОбластьШапка.Параметры.Раздел = "ФИНАНСОВАЯ ДЕЯТЕЛЬНОСТЬ";
		ТабличныйДокумент.Вывести(ОбластьШапка);		
		ОбластьРаздел.Параметры.СтрокаРаздел = "Приход";
		ТабличныйДокумент.Вывести(ОбластьРаздел);
		
		// Получение займа ---------------------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Займы)", "Получение займа");
		
		// Взносы участников -------------------------------------------------------------------------------------
		ВывестиСтатьюДСПриход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Участники)", "Взносы участников");
		
		
		// ------------------------------------------------- РАСХОД ФД -------------------------------------------
		
		ОбластьРаздел.Параметры.СтрокаРаздел = "Расход";
		ТабличныйДокумент.Вывести(ОбластьРаздел);
		
		// Возврат или выдача займа ------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Займы)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) ИЛИ СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Возврат или выдача займа");
		
		// Выплата дивидендов ------------------------------------------------------------------------------------
		ВывестиСтатьюДСРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Участники)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)", "Выплата дивидендов");
		
		
		// ------------------------------------------------- ИТОГ ФД ---------------------------------------------
		
		ОбластьИтогРаздел.Параметры.СтрокаРаздел = "ФИНАНСОВАЯ ДЕЯТЕЛЬНОСТЬ:";
		ОбластьИтогРаздел.Параметры.Итог = ИтогДС;
		ОбластьИтогРаздел.Параметры.ИтогП = ИтогП;
		ОбластьИтогРаздел.Параметры.ИтогР = ИтогР;	
		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			Процент = ?(ВсегоФД = 0, 0, Окр(ОбластьИтогРаздел.Параметры.Итог/ВсегоФД * 100,2));
		Иначе
			ВсегоФД = ОбластьИтогРаздел.Параметры.Итог;	
		КонецЕсли;	
		
		ОбластьИтогРаздел.Параметры.Процент = ?(Процент = 0, "", Строка(Процент) +" %");

		ТабличныйДокумент.Вывести(ОбластьИтогРаздел);
		КонтрольнаяЦифра = КонтрольнаяЦифра + ИтогДС;	
		ИтогДС = 0;
		ИтогП = 0;
		ИтогР = 0;
		
		// ------------------------------------------------- ПЕРЕМЕЩЕНИЕ -----------------------------------------
		
		ОбластьШапка.Параметры.Раздел = "ВНУТРЕННИЕ ПЕРЕМЕЩЕНИЯ";
		ТабличныйДокумент.Вывести(ОбластьШапка);	
		
		// Перемещения между кассами -----------------------------------------------------------------------------
		ВывестиСтатьюДСПриходРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)", "Перемещения между кассами");
				
		// Перемещения между счетами -----------------------------------------------------------------------------
		ВывестиСтатьюДСПриходРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Перемещения между счетами");
				
		//// Сдача наличных в банк ---------------------------------------------------------------------------------
		//ВывестиСтатьюДСПриходРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		//, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)", "Сдача наличных в банк");
		//		
		//// Получение наличных в банке ----------------------------------------------------------------------------
		//ВывестиСтатьюДСПриходРасход(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)"
		//, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Получение наличных в банке");
		
		// Перемещение из кассы в банк ---------------------------------------------------------------------------------
		ВывестиСтатьюДСПриходРасходПП(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)", "Перемещение из кассы в банк");
				
		// Перемещение из банка в кассу ----------------------------------------------------------------------------
		ВывестиСтатьюДСПриходРасходПП(Макет, "СчетДт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса)"
		, "СчетКт = ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк)", "Перемещение из банка в кассу");
		

		
		
		// ------------------------------------------------- ИТОГ ПЕРЕМЕЩЕНИЕ ------------------------------------
		
		ОбластьИтогРаздел.Параметры.СтрокаРаздел = "ДЕНЬГИ В ПУТИ:";
		ОбластьИтогРаздел.Параметры.Итог = ИтогП-ИтогР;
		ОбластьИтогРаздел.Параметры.ИтогП = ИтогП;
		ОбластьИтогРаздел.Параметры.ИтогР = ИтогР;
		ОбластьИтогРаздел.Параметры.Процент = "";
		ТабличныйДокумент.Вывести(ОбластьИтогРаздел);
		КонтрольнаяЦифра = КонтрольнаяЦифра + ИтогП-ИтогР;	

		
		// ------------------------------------------------- ИТОГИ ОБЩИЕ -----------------------------------------
		
		ОбластьОстаток.Параметры.СтрокаОстаток = "ОСТАТОК НА КОНЕЦ";
		ОбластьОстаток.Параметры.Остаток = КонтрольнаяЦифра;		
		
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			Процент = ?(ВсегоКонОст = 0, 0, Окр(ОбластьОстаток.Параметры.Остаток/ВсегоКонОст * 100,2));
		Иначе
			ВсегоКонОст = ОбластьОстаток.Параметры.Остаток;	
		КонецЕсли;	
		
		ОбластьОстаток.Параметры.Процент = ?(Процент = 0, "", Строка(Процент) +" %");
		
		ТабличныйДокумент.Вывести(ОбластьОстаток);			
		
		
		ОбластьОстаток.Параметры.СтрокаОстаток = "КОНТРОЛЬНАЯ ЦИФРА";
		Если ЕстьОстатки Тогда
			ОбластьОстаток.Параметры.Остаток = РезультатОстатки.СуммаКонечныйОстатокДт;
		Иначе
			ОбластьОстаток.Параметры.Остаток = 0;	
		КонецЕсли;		
		ОбластьОстаток.Параметры.Процент = "";
		ТабличныйДокумент.Вывести(ОбластьОстаток);			
		
		Если Первый Тогда
			ВысотаОтчета = ТабличныйДокумент.ВысотаТаблицы + 1;
			ТабличныйДокументОтчет.Вывести(ТабличныйДокумент.ПолучитьОбласть(1,1,ВысотаОтчета,2));
			Первый = Ложь;
			ОбластьИтог = ТабличныйДокумент.ПолучитьОбласть(1,3,ВысотаОтчета,4);
		Иначе
			ТабличныйДокументОтчет.Присоединить(ТабличныйДокумент.ПолучитьОбласть(1,3,ВысотаОтчета,4));
		КонецЕсли;	
		
	КонецЦикла;
	
	ТабличныйДокументОтчет.Присоединить(ОбластьИтог);

	/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	ТабличныйДокументОтчет.ФиксацияСверху = 5;
	ТабличныйДокументОтчет.ФиксацияСлева =  2;
	
	НачГр = 0;
	КонГр = 0;
	Для Каждого ГруппировкаСтрока Из СписокГруппировки Цикл
		
		Если ГруппировкаСтрока.Пометка Тогда
			НачГр = ГруппировкаСтрока.Значение;
		Иначе
			КонГр = ГруппировкаСтрока.Значение;
			Если НачГр <> КонГр  Тогда
				ТабличныйДокументОтчет.Область(НачГр+1,,КонГр,).Сгруппировать();
			КонецЕсли;	
		КонецЕсли;
		
	КонецЦикла;	
	
	ТабличныйДокументОтчет.ПоказатьУровеньГруппировокСтрок(0);

КонецПроцедуры

&НаСервере
Процедура ВывестиСтатьюДСПриход(Макет, УсловиеДт, УсловиеКт, СтатьяДС)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	УправленческийОборотыСтатьи.СубконтоДт2 КАК Статья,
	|	СУММА(ЕСТЬNULL(УправленческийОборотыДтКт.СуммаОборот, 0)) КАК СуммаОборот
	|ИЗ
	|	РегистрБухгалтерии.Управленческий.ОборотыДтКт(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Период,
	|"+ УсловиеДт +",
	|,
	|"+ УсловиеКт +",
	|			,
	|			) КАК УправленческийОборотыСтатьи
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Управленческий.ОборотыДтКт(
	|				&НачалоПериода,
	|				&КонецПериода,
	|				Период,
	|"+ УсловиеДт +",
	|,
	|"+ УсловиеКт +",
	|			,"+ ?(ЗначениеЗаполнено(СтруктурнаяЕдиница),"СтруктурнаяЕдиница = &СтруктурнаяЕдиница","") 
				  + ?(ЗначениеЗаполнено(СтруктурнаяЕдиница) И СчетКассаИспользование И СчетКассаОтбор.Количество() > 0, " И ", "")	
				  + ?(СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 ,"СубконтоДт1 В (&СчетКасса)","")+") КАК УправленческийОборотыДтКт
	|		ПО УправленческийОборотыСтатьи.СубконтоДт2 = УправленческийОборотыДтКт.СубконтоДт2
	|
	//|"+ ?(СчетКассаИспользование И СчетКассаОтбор.Количество() > 0," ГДЕ УправленческийОборотыДтКт.СубконтоДт1 В (&СчетКасса) ","") +"  
	|
	|СГРУППИРОВАТЬ ПО
	|	УправленческийОборотыСтатьи.СубконтоДт2
	|УПОРЯДОЧИТЬ ПО
	|	Статья
	|ИТОГИ
	|	СУММА(СуммаОборот)
	|ПО
	|	ОБЩИЕ,
	|	Статья";
	
	
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);	
	КонецЕсли;		
	
	Если СчетКассаИспользование И СчетКассаОтбор.Количество() > 0 Тогда
		Запрос.УстановитьПараметр("СчетКасса", СчетКассаОтбор);	
	КонецЕсли;	
	
	Если ЭтаФорма.ПериодИспользование Тогда
		
		Запрос.УстановитьПараметр("НачалоПериода", Период.ДатаНачала);	
		Если НЕ ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
			Запрос.УстановитьПараметр("КонецПериода", Дата(3999, 1, 1));		
		Иначе	
			Запрос.УстановитьПараметр("КонецПериода", Период.ДатаОкончания);	
		КонецЕсли;	
		
	Иначе
		Запрос.УстановитьПараметр("НачалоПериода", '00010101');	
		Запрос.УстановитьПараметр("КонецПериода", '00010101');	
	КонецЕсли;
	
	
	ВыборкаИтог = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаИтог.Следующий();
	
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка1");
	ОбластьСтрока.Параметры.Статья = СтатьяДС;
	ОбластьСтрока.Параметры.Приход = ВыборкаИтог.СуммаОборот;
	ТабличныйДокумент.Вывести(ОбластьСтрока);			
	
	Если Первый Тогда
		СписокГруппировки.Добавить(ТабличныйДокумент.ВысотаТаблицы,,Истина);	
	КонецЕсли;

	
	ИтогДС = ИтогДС + ?(ЗначениеЗаполнено(ВыборкаИтог.СуммаОборот), ВыборкаИтог.СуммаОборот, 0);
	ИтогП = ИтогП + ?(ЗначениеЗаполнено(ВыборкаИтог.СуммаОборот), ВыборкаИтог.СуммаОборот, 0);
	
	ВыборкаСтатьи = ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
	Пока ВыборкаСтатьи.Следующий() Цикл		

		ОбластьСтрока = Макет.ПолучитьОбласть("Строка2");
		ОбластьСтрока.Параметры.Статья = ВыборкаСтатьи.Статья;
		ОбластьСтрока.Параметры.Приход = ВыборкаСтатьи.СуммаОборот;
		ТабличныйДокумент.Вывести(ОбластьСтрока);			
		
	КонецЦикла;
	
	Если Первый Тогда
		СписокГруппировки.Добавить(ТабличныйДокумент.ВысотаТаблицы,,Ложь);	
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере
