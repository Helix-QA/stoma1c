// Функция - Получить данные события запись смена статуса сотрудником клиники
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЗаписьСменаСтатусаСотрудникомКлиники(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Запись"				, ОбъектСобытия);
		Запрос.УстановитьПараметр("МассивКонтрагентов"	, ДанныеТриггера.МассивНеобработанныхКонтрагентов);		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПредварительнаяЗапись.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПредварительнаяЗапись.Ссылка КАК Запись,
		|	ПредварительнаяЗапись.Контрагент КАК Контрагент,
		|	ПредварительнаяЗапись.Ссылка КАК ОбъектСобытия,
		|	ПредварительнаяЗапись.Врач КАК Сотрудник,
		|	ПредварительнаяЗапись.Статус КАК СтатусЗаписи,
		|	ПредварительнаяЗапись.Дата КАК ДатаВремяНачала,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВремяОкончания,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	Документ.Событие КАК ПредварительнаяЗапись
		|ГДЕ
		|	ПредварительнаяЗапись.Ссылка = &Запись
		|	И ПредварительнаяЗапись.ТипСобытия = ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ПредварительнаяЗапись)
		|	И ПредварительнаяЗапись.Контрагент В(&МассивКонтрагентов)
		|	И ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)
		|	И ПредварительнаяЗапись.Статус = &ПереходНаСтатус
		|	И ПредварительнаяЗапись.ИсточникЗаписи = &ИсточникЗаписи
		|	И ПредварительнаяЗапись.Резерв = ЛОЖЬ";		
			
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)",
			"ПредварительнаяЗапись.Контрагент В
			|			(ВЫБРАТЬ
			|				КонтрагентыСегмента.Контрагент
			|			ИЗ
			|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
			|			ГДЕ
			|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ИсточникЗаписи) И ТипЗнч(ДанныеТриггера.ИсточникЗаписи) = Тип("СправочникСсылка.ИсточникиЗаписей") Тогда
			Запрос.УстановитьПараметр("ИсточникЗаписи", ДанныеТриггера.ИсточникЗаписи);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПредварительнаяЗапись.ИсточникЗаписи = &ИсточникЗаписи", "ИСТИНА");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СтатусЗаписи) Тогда 
			Запрос.УстановитьПараметр("ПереходНаСтатус", ДанныеТриггера.СтатусЗаписи);
