// Процедура, обработчик события "ПриИзменении".
// 
Процедура НормаВремениПриИзменении(Элемент)
	
	Число = 0;
	Если НЕ ЭтотОбъект.НормаВремени = "0" Тогда
		
		Попытка
			Если ЗначениеЗаполнено(ЭтотОбъект.НормаВремени) Тогда
				Число = Число(ЭтотОбъект.НормаВремени);
			Иначе
				Число = 0;
			КонецЕсли;
			
		Исключение
			ЭтотОбъект.НормаВремени = "0";
		КонецПопытки;
		
	КонецЕсли;
	
	Объект.НормаВремени = Число;

	Модифицированность = Истина;
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

