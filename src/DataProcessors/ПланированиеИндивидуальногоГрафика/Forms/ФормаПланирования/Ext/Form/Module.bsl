// Пометить на удаление выбранные занятие 
// 
Процедура КомандаТабДокументУдалить(Команда)
	
	НомерОперации = НомерПоследнейОперацииВОчередиБуфера() + 1;
	
	Если ЗначениеЗаполнено(ИдТекущегоЭлементаHTML) Тогда 
		СтрокаБуфера = СтрокаБуфераФомированияПоИдентификатору(ИдТекущегоЭлементаHTML);
		
		Если СтрокаБуфера <> Неопределено Тогда
			Если СтрокаБуфера.Операция = "Создать" Тогда
				БуферФормирования.Удалить(СтрокаБуфера);
			Иначе
				
				Данные = ПроверитьНаличиеВизита(СтрокаБуфера.Сотрудник, СтрокаБуфера.Дата, СтрокаБуфера.ИнтервалыРаботы, ОтборСтруктурнаяЕдиница);
				Если Данные = Ложь Тогда
					
					СтрокаБуфера.Операция              = "Удалить";
					СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
				Иначе
					
					Интервал = Формат(Данные.НачалоРаботы, "ДЛФ=DD") + " с " + Формат(Данные.НачалоРаботы, "ДФ=HH:мм") + " по " + Формат(Данные.ОкончаниеРаботы, "ДФ=HH:мм");
					Текст = "В интервале " + Интервал + " созданы визиты. Удаление интервала невозможно.";
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
					Возврат;
					
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		// Обновление отображения плана
		ОбновитьОтображениеПланирования(Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Пометить на удаление за указный период
// 
Процедура КомандаТабДокументУдалитьЗаПериод(Команда)
	
	Если ЗначениеЗаполнено(ИдТекущегоЭлементаHTML) Тогда 
		СтрокаБуфераОбразец       = СтрокаБуфераФомированияПоИдентификатору(ИдТекущегоЭлементаHTML);
		НомерДняНеделиДляУдаления = ДеньНедели(СтрокаБуфераОбразец.Дата);
		НомерОперации             = НомерПоследнейОперацииВОчередиБуфера() + 1;
		Индекс                    = 0;
		Пока Индекс < БуферФормирования.Количество() Цикл
			СтрокаБуфера = БуферФормирования[Индекс]; 
			
			Если ДеньНедели(СтрокаБуфера.Дата) = НомерДняНеделиДляУдаления
				И СравнитьСтрокиБуфераФормирования(СтрокаБуфераОбразец, СтрокаБуфера) Тогда
				
				Если СтрокаБуфера.Операция = "Создать" Тогда
					БуферФормирования.Удалить(СтрокаБуфера);
					Продолжить;
				Иначе
					
					Данные = ПроверитьНаличиеВизита(СтрокаБуфера.Сотрудник, СтрокаБуфера.Дата, СтрокаБуфера.ИнтервалыРаботы, ОтборСтруктурнаяЕдиница);
					Если Данные = Ложь Тогда
						
						СтрокаБуфера.Операция              = "Удалить";
						СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
						
					Иначе
						
						Интервал = Формат(Данные.НачалоРаботы, "ДЛФ=DD") + " с " + Формат(Данные.НачалоРаботы, "ДФ=HH:мм") + " по " + Формат(Данные.ОкончаниеРаботы, "ДФ=HH:мм");
						Текст = "В интервале " + Интервал + " созданы визиты. Удаление интервала невозможно.";
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
						
					КонецЕсли;

				КонецЕсли;		
			КонецЕсли;
			Индекс = Индекс + 1;
		КонецЦикла;
		// Обновление отображения плана
		ОбновитьОтображениеПланирования(Ложь);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Пометить на удаление все занятия
// 
Процедура КомандаТабДокументУдалитьВсе(Команда)
	
	Если ЗначениеЗаполнено(ИдТекущегоЭлементаHTML) Тогда 
		
		СтрокаБуфераОбразец       = СтрокаБуфераФомированияПоИдентификатору(ИдТекущегоЭлементаHTML);
		НомерОперации             = НомерПоследнейОперацииВОчередиБуфера() + 1;
		Индекс                    = 0;
		Пока Индекс < БуферФормирования.Количество() Цикл
			СтрокаБуфера = БуферФормирования[Индекс]; 
					
			Если СравнитьСтрокиБуфераФормирования(СтрокаБуфераОбразец, СтрокаБуфера) Тогда
				
				Если СтрокаБуфера.Операция = "Создать" Тогда
					БуферФормирования.Удалить(СтрокаБуфера);
					Продолжить;
				Иначе
					Данные = ПроверитьНаличиеВизита(СтрокаБуфера.Сотрудник, СтрокаБуфера.Дата, СтрокаБуфера.ИнтервалыРаботы, ОтборСтруктурнаяЕдиница);
					Если Данные = Ложь Тогда
						
						СтрокаБуфера.Операция              = "Удалить";
						СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
						
					Иначе
						
						Интервал = Формат(Данные.НачалоРаботы, "ДЛФ=DD") + " с " + Формат(Данные.НачалоРаботы, "ДФ=HH:мм") + " по " + Формат(Данные.ОкончаниеРаботы, "ДФ=HH:мм");
						Текст = "В интервале " + Интервал + " созданы визиты. Удаление интервала невозможно.";
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
						
					КонецЕсли;

				КонецЕсли;		
			КонецЕсли;
			Индекс = Индекс + 1;
		КонецЦикла;
		// Обновление отображения плана
		ОбновитьОтображениеПланирования(Ложь);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Обработчик кнопки отмены последней операции
// 
Процедура КомандаОтменитьПоследнююОперацию(Команда)
	
	НомерОперации = НомерПоследнейОперацииВОчередиБуфера();
	Если НомерОперации > 0 Тогда
		
		НайденныеСтроки = БуферФормирования.НайтиСтроки(Новый Структура("НомерОчередиОперации",НомерОперации));
		Для Каждого СтрокаБуфера ИЗ НайденныеСтроки Цикл
			Если СтрокаБуфера.Операция = "Создать" Тогда				
				БуферФормирования.Удалить(СтрокаБуфера);
			ИначеЕсли СтрокаБуфера.Операция = "Удалить" Тогда	
				СтрокаБуфера.Операция             = "";
				СтрокаБуфера.НомерОчередиОперации = 0;
				СтрокаБуфера.Скрыть               = Ложь;
			КонецЕсли;
		КонецЦикла;
		
		// Обновление отображения плана
		ОбновитьОтображениеПланирования(Ложь);
	КонецЕсли;
	
КонецПроцедуры

