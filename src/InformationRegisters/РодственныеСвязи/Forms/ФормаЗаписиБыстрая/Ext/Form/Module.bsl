
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("СозданиеИзСобытия") И Параметры.СозданиеИзСобытия = Истина Тогда
		
		Параметры.Свойство("ВыбранныйКлиент"	, Запись.Контрагент);
		Параметры.Свойство("Фамилия"			, ЭтотОбъект.Фамилия);
		Параметры.Свойство("Имя"				, ЭтотОбъект.Имя);
		Параметры.Свойство("Отчество"			, ЭтотОбъект.Отчество);
		Параметры.Свойство("ПолНовогоКлиента"	, ЭтотОбъект.ПолНовогоКлиента);
		Параметры.Свойство("ДатаРождения"		, ЭтотОбъект.ДатаРождения);
		Параметры.Свойство("НомерТелефона"		, ЭтотОбъект.Телефон);
		
		Элементы.Телефон.Доступность				 = Ложь;
		Элементы.СуществующийРодственник.Видимость	 = Ложь;
		
	КонецЕсли;
	
	СтепеньРодстваПредставление = Запись.СтепеньРодства.Наименование;
	 	
	Если Параметры.Свойство("Контрагент") И ЗначениеЗаполнено(Параметры.Контрагент) Тогда
		
		Запись.Контрагент = Параметры.Контрагент;
		
		Если НЕ ЗначениеЗаполнено(Параметры.Контрагент.ПолКлиента) 
			И Параметры.Свойство("ПолКонтрагента") 
			И ЗначениеЗаполнено(Параметры.ПолКонтрагента) Тогда
			ЭтотОбъект.ПолНовогоКлиента = Параметры.ПолКонтрагента;
		КонецЕсли;

	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Запись.Контрагент) и ЗначениеЗаполнено(Запись.Родственник) Тогда 
		Элементы.ГруппаУдалитьРодственника.Видимость = Истина;
		РодственникДоИзменения = Запись.Родственник;
	КонецЕсли;
	
	Если Параметры.Свойство("ВернутьСтруктуруСвязи") И ЗначениеЗаполнено(Параметры.ВернутьСтруктуруСвязи) Тогда
		ЭтаФорма.ВернутьСтруктуруСвязи = Параметры.ВернутьСтруктуруСвязи;
	КонецЕсли;
	
	Если Не Запись.Родственник.Ссылка.Пустая() ИЛИ (Параметры.ЗначенияЗаполнения.Свойство("Родственник") И ЗначениеЗаполнено(Параметры.ЗначенияЗаполнения.Родственник)) Тогда
		ЭтотОбъект.СуществующийРодственник			  = Истина;
		Элементы.СуществующийРодственник.Доступность  = Ложь;
		Элементы.ГруппаСозданиеРодственника.Видимость = Ложь;
		Элементы.Родственник.Видимость				  = Истина;
		
		//// Для нормально работы создания родств. связей из Ф.Док. Событие
		// Если Параметры.ЗначенияЗаполнения.Свойство("Родственник") = Истина
		//	И ЗначениеЗаполнено(Параметры.ЗначенияЗаполнения.Родственник) Тогда
		//	
		//		Запись.Родственник = Параметры.ЗначенияЗаполнения.Родственник;
		//	
		// КонецЕсли;
		//
		// Если Параметры.Свойство("ПолКонтрагента") = Истина
		//	И ЗначениеЗаполнено(Параметры.ПолКонтрагента) Тогда
		//	
		//		ПолНовогоКлиента = Параметры.ПолКонтрагента;
		//		
		// КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - При открытии.
//
Процедура ПриОткрытии(Отказ)
		
	УстановитьВидимостьПолейРодственника();

КонецПроцедуры


&НаКлиенте
// Процедура, обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	ВыполнитьПроверкуПередЗаписью(Отказ);
	
	Если Не Отказ И Не СуществующийРодственник Тогда
		Запись.Родственник = СоздатьРодственника();
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура СохранитьРодственника(Команда)
	
	Если Записать() Тогда
		Оповестить("ОбновленаРодственнаяСвязь");
		Закрыть(Запись.Родственник);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура УдалитьРодственника(Команда)
	
	УдалитьРодственникаНаСервере();	
	Оповестить("ОбновленаРодственнаяСвязь");
	Закрыть();

КонецПроцедуры 

#КонецОбласти

#Область ОбработкаСобытийЭлементовФормы

&НаКлиенте
// Процедура - Степень родства начало выбора.
//
Процедура СтепеньРодстваНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	СписокВыбора = ПолучитьСписокВыбораСтепенейРодства();
	Результат = Неопределено;

	ПоказатьВыборИзСписка(Новый ОписаниеОповещения("СтепеньРодстваНачалоВыбораЗавершение", ЭтотОбъект), СписокВыбора, Элемент, СписокВыбора.НайтиПоЗначению(Запись.СтепеньРодства));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Степень родства начало выбора.
//
Процедура ОбратнаяСтепеньРодстваНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	Если НЕ ЗначениеЗаполнено(СтепеньРодстваПредставление) И НЕ ЗначениеЗаполнено(Запись.СтепеньРодства) Тогда Возврат; КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	СписокВыбораОбратный = ПолучитьСписокВыбораОбратныхСтепенейРодства(СтепеньРодстваПредставление);
	Результат = Неопределено;

	ПоказатьВыборИзСписка(Новый ОписаниеОповещения("ОбратнаяСтепеньРодстваНачалоВыбораЗавершение", ЭтотОбъект), СписокВыбораОбратный, Элемент, СписокВыбораОбратный.НайтиПоЗначению(ОбратнаяСтепеньРодства));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Существующий родственник при изменении.
//
Процедура СуществующийРодственникПриИзменении(Элемент)
	
	УстановитьВидимостьПолейРодственника();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, выполняет проверки перед записью.
//
Процедура ВыполнитьПроверкуПередЗаписью(Отказ)
	
	Если Не ЗначениеЗаполнено(Запись.СтепеньРодства) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не указана степень родства.';en='Degree of kinship is not specified.'"));
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запись.Родственник) И Запись.Контрагент = Запись.Родственник Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Клиент не может являться сам себе родственником!';en='Client cannot be a relative to myself!'"));
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Запись.Контрагент, "ПолКлиента"))
		И НЕ ЗначениеЗаполнено(ЭтотОбъект.ПолНовогоКлиента) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='У клиента %1 не заполнен пол. Определить обратную родственную связь нельзя.';en='Client %1 is not full gender. It is impossible to determine the inverse kinship.'"), Запись.Контрагент));	
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если СуществующийРодственник Тогда
		Если Не ЗначениеЗаполнено(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Запись.Родственник, "ПолКлиента")) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='У клиента %1 не заполнен пол. Определить обратную родственную связь нельзя.';en='Client %1 is not full gender. It is impossible to determine the inverse kinship.'"), Запись.Родственник));	
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	Иначе
		Если Не ЗначениеЗаполнено(ПолНовогоКлиента) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не заполнен пол нового клиента. Определить обратную родственную связь нельзя.';en='Gender of new client is not specified. It is impossible to determine reverse relationship.'"));
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	КонецЕсли;
		
	ОбратнаяСтепеньРодства = Справочники.СтепеньРодства.ПолучитьОбратнуюСтепеньРодства(Запись.СтепеньРодства, ?(СуществующийРодственник, ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Запись.Родственник, "ПолКлиента"), ПолНовогоКлиента));
	Если Не ЗначениеЗаполнено(ОбратнаяСтепеньРодства) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='В настройках степени родства не указано обратное родство!';en='In the degrees kinship settings reverse kinship is not specified!'"));
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);
	Если ЗначениеЗаполнено(ВнешняяСистема) И Запись.ЗаконныйПредставитель И Не ЗначениеЗаполнено(Запись.РеквизитыДокументаЗаконногоПредставителя) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='ИЭМК: У законного представителя не заполнены реквизиты документа определяющего право представлять пациента!';en='The legal representative has not filled out the requesits of the document defining the right to represent the patient!'"));
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить список выбора степеней родства.
//
Функция ПолучитьСписокВыбораСтепенейРодства()
	
	СписокВыбора = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СтепеньРодства.Ссылка КАК Ссылка,
	               |	ПРЕДСТАВЛЕНИЕ(СтепеньРодства.Ссылка) КАК КемПриходится
	               |ИЗ
	               |	Справочник.СтепеньРодства КАК СтепеньРодства
	               |ГДЕ
	               |	СтепеньРодства.ПометкаУдаления = ЛОЖЬ";
	Результат = Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() Цикл
		СписокВыбора.Добавить(Результат.Ссылка, Результат.КемПриходится);
	КонецЦикла;
	
	Возврат СписокВыбора;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Получить список выбора степеней родства.
//
Функция ПолучитьСписокВыбораОбратныхСтепенейРодства(ПрямаяРодственнаяСвязь)
	
	СписокВыбораОбратный = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СтепеньРодства.ОбратнаяСвязьМуж.Представление КАК ОбратнаяСвязьМужПредставление,
	               |	СтепеньРодства.ОбратнаяСвязьЖен.Представление КАК ОбратнаяСвязьЖенПредставление,
	               |	СтепеньРодства.ОбратнаяСвязьЖен.Ссылка КАК ОбратнаяСвязьЖенСсылка,
	               |	СтепеньРодства.ОбратнаяСвязьМуж.Ссылка КАК ОбратнаяСвязьМужСсылка
	               |ИЗ
	               |	Справочник.СтепеньРодства КАК СтепеньРодства
	               |ГДЕ
	               |	СтепеньРодства.ПометкаУдаления = ЛОЖЬ
	               |	И СтепеньРодства.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Наименование", ПрямаяРодственнаяСвязь);
	Результат = Запрос.Выполнить().Выбрать();
	Результат.Следующий();
	
	СписокВыбораОбратный.Добавить(Результат.ОбратнаяСвязьМужСсылка, ПрямаяРодственнаяСвязь+" / "+Результат.ОбратнаяСвязьМужПредставление);
	СписокВыбораОбратный.Добавить(Результат.ОбратнаяСвязьЖенСсылка, ПрямаяРодственнаяСвязь+" / "+Результат.ОбратнаяСвязьЖенПредставление);
	
	Возврат СписокВыбораОбратный;
	
КонецФункции

&НаКлиенте
// Процедура - Установить видимость полей родственника.
//
Процедура УстановитьВидимостьПолейРодственника()
	
	Элементы.ГруппаСозданиеРодственника.Видимость = Не СуществующийРодственник;
	Элементы.Родственник.Видимость				  = СуществующийРодственник;
	Элементы.РеквизитыДокументаЗаконногоПредставителя.Видимость = Запись.ЗаконныйПредставитель;

КонецПроцедуры

