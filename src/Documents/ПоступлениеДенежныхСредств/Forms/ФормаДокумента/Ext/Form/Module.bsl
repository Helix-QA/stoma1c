// Функция - возвращает массив параметров товаров.
//
Функция ПолучитьМассивПараметровТовары(ДокументОснования, Сумма)
	
	ОплаченоПоДокументу = 0;
	Если ЗначениеЗаполнено(ДокументОснования) Тогда
		Если ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.НарядЗаказ") Тогда
			ОплаченоПоДокументу = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОснования, "СуммаОплаченоПродажи") - Сумма;
		ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("СуммаОплачено", ДокументОснования.Метаданные()) = Истина Тогда 
			ОплаченоПоДокументу = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОснования, "СуммаОплачено") - Сумма;
		КонецЕсли;
	КонецЕсли;
	
	МассивТоваровДокумента = Обработки.ПомощникПроведенияОплаты.ПолучитьМассивПараметровТоваровККТ(
																	ДокументОснования,
																	ОплаченоПоДокументу,
																	Сумма,
																	Объект.Касса);
																	
	Возврат МассивТоваровДокумента;
		
КонецФункции

