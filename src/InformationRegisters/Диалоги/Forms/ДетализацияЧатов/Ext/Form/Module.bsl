
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформлениеСделок();
	ИнициализироватьМеханизмФильтрацииДанных();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды формы.
//
Процедура ПерейтиВЧат(Команда = Неопределено)
	
	ТекущиеДанные = Элементы.СписокЧатов.ТекущиеДанные;
	
	Если Элементы.СписокЧатов.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Идентификатор = ТекущиеДанные.Идентификатор;
	ВнешняяСистема = ТекущиеДанные.ВнешняяСистема;
	
	ИдСообщения = ПолучитьИдОжидающегоСообщения(Идентификатор, ВнешняяСистема);
	
	ДанныеКанала = Новый Структура;
	ДанныеКанала.Вставить("ИдКлиента"		, Идентификатор);
	ДанныеКанала.Вставить("ИдСообщения"		, ИдСообщения);
	ДанныеКанала.Вставить("ВнешняяСистема"	, ВнешняяСистема);
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ДанныеКанала", ДанныеКанала);
	
	ФормаМессенджера = Неопределено;
	
	Окна = ПолучитьОкна();
	
	Для Каждого ОкноКлиентскогоПриложения Из Окна Цикл
		Для Каждого Форма Из ОкноКлиентскогоПриложения.Содержимое Цикл
			Если Форма.ИмяФормы = "Обработка.Мессенджер_Стоматология.Форма.ФормаЧатаНовая" Тогда
				ФормаМессенджера = Форма;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если ФормаМессенджера = Неопределено Тогда
		ОткрытьФорму("Обработка.Мессенджер_Стоматология.Форма.ФормаЧатаНовая", ПараметрыОткрытия);
	Иначе
		Оповестить("ОткрытьДиалог", ПараметрыОткрытия);
		ФормаМессенджера.Активизировать();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "Выбор".
//
Процедура СписокЧатовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если Поле = Элементы.СписокЧатовОбъектИдентификации И ЗначениеЗаполнено(ТекущиеДанные.ОбъектИдентификации) Тогда
		ПоказатьЗначение(, ТекущиеДанные.ОбъектИдентификации);
		
	ИначеЕсли Поле = Элементы.СписокЧатовОператор И ЗначениеЗаполнено(ТекущиеДанные.Оператор) Тогда
		ПоказатьЗначение(, ТекущиеДанные.Оператор);
		
	ИначеЕсли Поле = Элементы.СписокЧатовВнешняяСистема Тогда
		ПоказатьЗначение(, ТекущиеДанные.ВнешняяСистема);
		
	ИначеЕсли Поле = Элементы.СписокЧатовЭтапСделки Тогда
		ПоказатьЗначение(, ТекущиеДанные.Сделка);
		
	Иначе
		ПерейтиВЧат();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, обработчик события "ПриПолученииДанныхНаСервере".
//
Процедура СписокЧатовПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Для Каждого СтрокаСписка Из Строки Цикл
		
		ДанныеСтроки = СтрокаСписка.Значение.Данные;
		
		ДанныеСтроки.ДлительностьДиалогаПредставление		 = ПолучитьПредставлениеВремениДляСписка(ДанныеСтроки.ДлительностьДиалога);
		ДанныеСтроки.ВремяДоПервогоОтветаПредставление		 = ПолучитьПредставлениеВремениДляСписка(ДанныеСтроки.ВремяДоПервогоОтвета);
		ДанныеСтроки.ОбщееВремяОтветовПредставление			 = ПолучитьПредставлениеВремениДляСписка(ДанныеСтроки.ОбщееВремяОтветов);
		ДанныеСтроки.СреднееВремяОтветаПредставление		 = ПолучитьПредставлениеВремениДляСписка(ДанныеСтроки.СреднееВремяОтвета);
		ДанныеСтроки.МаксимальноеВремяОтветаПредставление	 = ПолучитьПредставлениеВремениДляСписка(ДанныеСтроки.МаксимальноеВремяОтвета);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиМеханизмаФильтрацииДанных

#Область ИнициализацияМеханизмаФильтрацииДанных

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ИнициализироватьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОбновитьСписок = Ложь)
	
	// Обновляем отборы согласно параметров, переданных из другой формы	и уходим	
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ОчиститьВсеОтборы") И ПараметрыОтбора.ОчиститьВсеОтборы = Истина Тогда
		ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора); // Перешли из монитора при уже открытой текущей формы
		Возврат;
	КонецЕсли;
	
	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов();	
	
	// Отбор внешняя система.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВнешнихСистем");	
	ОбновитьДинамическоеМенюФильтрации_ВнешняяСистема(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВнешнихСистем_ВариантОтбора"), ПараметрыОтбора.МассивВнешнихСистем_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВнешняяСистема", ПараметрыОтбора.МассивВнешнихСистем, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор оператор.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивОператоров");	
	ОбновитьДинамическоеМенюФильтрации_Оператор(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивОператоров_ВариантОтбора"), ПараметрыОтбора.МассивОператоров_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Оператор", ПараметрыОтбора.МассивОператоров, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор статус.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусов");	
	ОбновитьДинамическоеМенюФильтрации_Статус(СтатусыДиалогов(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусов_ВариантОтбора"), ПараметрыОтбора.МассивСтатусов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусов, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	Если ОбновитьСписок Тогда 
		АктуализироватьДанныеСпискаСогласноОтборов();	
	КонецЕсли; 	
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает массив статусов диалогов.
//
Функция СтатусыДиалогов()
	
	СтатусыДиалогов = Новый Массив;
	СтатусыДиалогов.Добавить("Диалог завершен");
	СтатусыДиалогов.Добавить("Оператор ответил");
	СтатусыДиалогов.Добавить("Ожидает ответа");
	
	Возврат СтатусыДиалогов;
	
КонецФункции

&НаСервере
// Процедура, инициализировать фильтр статус.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_ВнешняяСистема(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра	
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru = 'Внешняя система'; en = 'External system'"));	
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_ВнешняяСистема");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_ВнешняяСистема");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_ВнешняяСистема");	
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_ВнешняяСистема");	
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_ВнешняяСистема");	
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("СправочникСсылка.ВнешниеСистемы"));
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений);
	
	// Обновляем элементы фильтрации для текущего фильтра	
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																														
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр статус.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Оператор(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра	
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru = 'Оператор'; en = 'Operator'"));	
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_Оператор");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_Оператор");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_Оператор");	
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_Оператор");	
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_Оператор");	
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений, Справочники.Сотрудники.ПустаяСсылка(), НСтр("ru = '<не назначен>'; en = '<not specified>'"));
	
	// Обновляем элементы фильтрации для текущего фильтра	
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																														
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр статус.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Статус(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра	
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru = 'Статус диалога'; en = 'Dialog status'"));	
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("Строка"));
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений);
	
	// Обновляем элементы фильтрации для текущего фильтра	
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																														
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить значения фильтрации данных.
//
// Параметры:
//  ПараметрыОтбора				 - 	 - 
//  ОчиститьВсеФильтры			 - 	 - 
//  МассивИменОчищаемыхФильтров	 - 	 - 
//
Процедура ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора, ОчиститьВсеФильтры = Истина, МассивИменОчищаемыхФильтров = Неопределено)
	
	Если ОчиститьВсеФильтры Тогда 
		МассивИменОчищаемыхФильтров = Новый Массив();
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ВнешняяСистема");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Оператор");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивИменОчищаемыхФильтров) Тогда 
		УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	КонецЕсли;
	
	// Отбор внешняя система.
	Если ПараметрыОтбора.Свойство("МассивВнешнихСистем") Тогда
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВнешняяСистема", ПараметрыОтбора.МассивВнешнихСистем);
	КонецЕсли;
	
	// Отбор оператор.
	Если ПараметрыОтбора.Свойство("МассивОператоров") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Оператор", ПараметрыОтбора.МассивОператоров);
	КонецЕсли;
	
	// Отбор статус.
	Если ПараметрыОтбора.Свойство("МассивСтатусов") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусов);
	КонецЕсли;
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

&НаСервере
// Процедура, актуализировать данные списка согласно отборов.
//
Процедура АктуализироватьДанныеСпискаСогласноОтборов()
	
	СтруктураОтборов 				= ПолучитьСтруктуруЗначенийОтбора();
	ЗапросДляДинамическогоСписка 	= ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов);
	
	// Цепляем наш запрос динамическому списку
	СписокЧатов.ТекстЗапроса = ЗапросДляДинамическогоСписка.Текст;
	
	// Устанавливаем параметры динамическому списку
	Для Каждого ПараметрЗапроса Из ЗапросДляДинамическогоСписка.Параметры Цикл 
		СписокЧатов.Параметры.УстановитьЗначениеПараметра(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция, возвращает структуру отборов формы.
//
Функция ПолучитьСтруктуруЗначенийОтбора()
	
	// Метод "ПолучитьЗначенияФильтра" возвращает список активированных значений фильтра.
	// У полученного списка значений есть свойство "ДоступныеЗначения", в котором хранится список всех значений.
	// Таким образом мы одним методом за одну итерацию получаем 2 списка значений(с активированными значениями и всеми значениями).
	// Вариант отбора передается в свойстве "ДоступныеЗначения" в представлении у любого элемента списка.
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборВнешняяСистема"	, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ВнешняяСистема"));
	СтруктураОтборов.Вставить("ОтборОператор"		, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Оператор"));
	СтруктураОтборов.Вставить("ОтборСтатус"			, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус"));
	
	Возврат СтруктураОтборов;
	
КонецФункции	

&НаСервере
// Функция, возвращает запрос с установленными параметрами, для списка формы.
//
Функция ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов)
	
	// текст запроса без отборов (чистый)
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= 	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.ИдКлиента КАК Идентификатор,
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	КонтактыМессенджеров.ОбъектИдентификации КАК ОбъектИдентификации,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК ПоследнееСообщениеОтКлиента,
	|	Диалоги.ИнициированКлиентом КАК ИнициированКлиентом,
	|	РАЗНОСТЬДАТ(ДАТАВРЕМЯ(1, 1, 1), Диалоги.ВремяДоПервогоОтвета, СЕКУНДА) КАК ВремяДоПервогоОтвета,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(30)) КАК ВремяДоПервогоОтветаПредставление,
	|	Диалоги.ДатаПоследнегоСообщения КАК ДатаПоследнегоСообщения,
	|	Диалоги.КоличествоСообщений КАК КоличествоСообщений,
	|	ВЫБОР
	|		КОГДА ГОД(Диалоги.ОбщееВремяОтветов) > 10
	|			ТОГДА 999999999
	|		ИНАЧЕ РАЗНОСТЬДАТ(ДАТАВРЕМЯ(1, 1, 1), Диалоги.ОбщееВремяОтветов, СЕКУНДА)
	|	КОНЕЦ КАК ОбщееВремяОтветов,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(30)) КАК ОбщееВремяОтветовПредставление,
	|	ВЫБОР
	|		КОГДА ГОД(Диалоги.МаксимальноеВремяОтвета) > 10
	|			ТОГДА 999999999
	|		ИНАЧЕ РАЗНОСТЬДАТ(ДАТАВРЕМЯ(1, 1, 1), Диалоги.МаксимальноеВремяОтвета, СЕКУНДА)
	|	КОНЕЦ КАК МаксимальноеВремяОтвета,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(30)) КАК МаксимальноеВремяОтветаПредставление,
	|	ВЫБОР
	|		КОГДА Диалоги.Окончание <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ""Диалог завершен""
	|		КОГДА Диалоги.ПоследнееСообщениеОтКлиента
	|			ТОГДА ""Ожидает ответа""
	|		ИНАЧЕ ""Оператор ответил""
	|	КОНЕЦ КАК Статус,
	|	ВЫБОР
	|		КОГДА Диалоги.КоличествоОтветов = 0
	|			ТОГДА 0
	|		КОГДА ГОД(Диалоги.ОбщееВремяОтветов) > 10
	|			ТОГДА 999999999
	|		ИНАЧЕ РАЗНОСТЬДАТ(ДАТАВРЕМЯ(1, 1, 1), Диалоги.ОбщееВремяОтветов, СЕКУНДА) / Диалоги.КоличествоОтветов
	|	КОНЕЦ КАК СреднееВремяОтвета,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(30)) КАК СреднееВремяОтветаПредставление,
	|	ВЫБОР
	|		КОГДА Диалоги.ДатаПоследнегоСообщения <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА РАЗНОСТЬДАТ(Диалоги.Начало, Диалоги.ДатаПоследнегоСообщения, СЕКУНДА)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ДлительностьДиалога,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(30)) КАК ДлительностьДиалогаПредставление,
	|	ВЫБОР
	|		КОГДА Диалоги.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi)
	|			ТОГДА 0
	|		КОГДА Диалоги.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.VkontakteApi)
	|			ТОГДА 1
	|		КОГДА Диалоги.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.telegram)
	|			ТОГДА 2
	|		КОГДА Диалоги.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.viber)
	|			ТОГДА 3
	|	КОНЕЦ КАК ИндексКартинкиМессенджера,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК Сделка,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки КАК ЭтапСделки,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ВидСделки КАК ВидСделки,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ЦветЭтапа КАК ЦветЭтапа
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|			ПО (КонтактыМессенджеров.ОбъектИдентификации ССЫЛКА Справочник.Контрагенты)
	|				И ((ВЫРАЗИТЬ(КонтактыМессенджеров.ОбъектИдентификации КАК Справочник.Контрагенты)) = КонтрагентыСведенияДляСписка.Контрагент)
	|		ПО (КонтактыМессенджеров.Идентификатор = Диалоги.ИдКлиента)
	|			И (КонтактыМессенджеров.ВнешняяСистема = Диалоги.ВнешняяСистема)
	|ГДЕ
	|	Диалоги.КоличествоСообщений > 0
	|	И &УсловиеВнешняяСистема
	|	И &УсловиеОператор
	|	И &УсловиеСтатус";				  
	
	// Отбор внешняя система.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборВнешняяСистема) Тогда
		УсловиеВнешняяСистема = СтруктураОтборов.ОтборВнешняяСистема.ДоступныеЗначения[0].Представление + "Диалоги.ВнешняяСистема В (&ОтборВнешняяСистема)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВнешняяСистема", УсловиеВнешняяСистема);
		Запрос.УстановитьПараметр("ОтборВнешняяСистема", СтруктураОтборов.ОтборВнешняяСистема.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВнешняяСистема", "ИСТИНА");
	КонецЕсли;
	
	// Отбор внешняя система.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборОператор) Тогда
		УсловиеОператор = СтруктураОтборов.ОтборОператор.ДоступныеЗначения[0].Представление + "Диалоги.Оператор В (&ОтборОператор)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОператор", УсловиеОператор);
		Запрос.УстановитьПараметр("ОтборОператор", СтруктураОтборов.ОтборОператор.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОператор", "ИСТИНА");
	КонецЕсли;
	
	// Отбор внешняя система.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтатус) Тогда
		УсловиеСтатус = СтруктураОтборов.ОтборСтатус.ДоступныеЗначения[0].Представление +
		"	ВЫБОР
		|		КОГДА Диалоги.Окончание <> ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА ""Диалог завершен""
		|		КОГДА Диалоги.ПоследнееСообщениеОтКлиента
		|			ТОГДА ""Ожидает ответа""
		|		ИНАЧЕ ""Оператор ответил""
		|	КОНЕЦ В (&ОтборСтатус)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", УсловиеСтатус);
		Запрос.УстановитьПараметр("ОтборСтатус", СтруктураОтборов.ОтборСтатус.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", "ИСТИНА");
	КонецЕсли;
	
	Возврат Запрос;
	
КонецФункции	

&НаСервереБезКонтекста
// Функция, возвращает пакет запроса с элементами для создания отборов.
//
Функция ПолучитьПакетЗапросаЗначенийДляОтборов()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Представление КАК Представление
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистем)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АктивныеПользователиМессенджер.Пользователь.Ссылка КАК Ссылка,
	|	АктивныеПользователиМессенджер.Пользователь.Представление КАК Представление
	|ИЗ
	|	РегистрСведений.АктивныеПользователиМессенджер КАК АктивныеПользователиМессенджер
	|ГДЕ
	|	НЕ АктивныеПользователиМессенджер.Пользователь.ПометкаУдаления
	|	И АктивныеПользователиМессенджер.Пользователь <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)");
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистем", Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера());
	
	Возврат Запрос.ВыполнитьПакет();
	        	
КонецФункции

#КонецОбласти

