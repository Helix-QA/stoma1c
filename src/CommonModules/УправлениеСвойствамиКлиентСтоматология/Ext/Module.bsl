// Функция - Получить данные элемента
//
// Параметры:
//  Форма	 - 	 - 
//  Элемент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеЭлемента(Знач Форма, Знач Элемент) Экспорт
		
	Если СтрНачинаетсяС(Элемент.Имя, "УдостоверенияЛичностиСуществующие") Тогда 
		
		ИмяТаблицы 				= "УдостоверенияЛичностиСуществующие"; 
		ИДСтрокиДанных = Число(СтрРазделить(Элемент.Имя, "_")[1]);
		ДанныеЭлемента 			= Форма.УдостоверенияЛичностиСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "МестоРаботыВыбранные_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "МестоРаботыУдалить_") Тогда 
		
		ИмяТаблицы 				= "МестаРаботы";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "МестоРаботыВыбранные_"), СтрДлина("МестоРаботыВыбранные_"), СтрДлина("МестоРаботыУдалить_")) + 1));
		ДанныеЭлемента 			= ?(Форма.Объект.Свойство("ДоступныеСтруктурныеЕдиницы") И Форма.Объект.ДоступныеСтруктурныеЕдиницы.Количество() >= ИндексСтроки + 1, Форма.Объект.ДоступныеСтруктурныеЕдиницы[ИндексСтроки], Форма.ДоступныеСтруктурныеЕдиницы[ИндексСтроки]);
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ЖурналыПриемовВыбранные_") Тогда 
		
		ИмяТаблицы 				= "МестаРаботы";		
		ИндексСтроки			= Число(СтрРазделить(Элемент.Имя, "_")[1]);
		ДанныеЭлемента 			= ?(Форма.Объект.Свойство("ДоступныеЖурналыПриемов"), Форма.Объект.ДоступныеЖурналыПриемов[ИндексСтроки], Форма.ДоступныеЖурналыПриемов[ИндексСтроки]);
	
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ДоступнаяКассаВыбранные_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "ДоступнаяКассаУдалить_") Тогда 
		
		ИмяТаблицы 				= "ДоступныеКассы";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "ДоступнаяКассаВыбранные_"), СтрДлина("ДоступнаяКассаВыбранные_"), СтрДлина("ДоступнаяКассаУдалить_")) + 1));
		ДанныеЭлемента 			= Форма.ДоступныеКассы[ИндексСтроки];
	
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ПолисКонтрагента") Тогда
		
		ИмяТаблицы 				= "ПолисыСуществующие";	
		ИДСтрокиДанных = Число(СтрРазделить(Элемент.Имя, "_")[1]);
		ДанныеЭлемента 			= Форма.ПолисыСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "СкидкиСуществующие") Тогда
		
		ИмяТаблицы 				= "СкидкиСуществующие";		
		ИДСтрокиДанных = Число(СтрРазделить(Элемент.Имя, "_")[1]);
		ДанныеЭлемента 			= Форма.СкидкиСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "_ДобавитьСтрокуТабличнойЧасти_") = 0 Тогда
		
		ИмяТаблицы 				= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_ДобавитьСтрокуТабличнойЧасти_") + СтрДлина("_ДобавитьСтрокуТабличнойЧасти_"));
		ИндексСтроки 			= Неопределено;
		ДанныеЭлемента 			= Неопределено;
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "_УдалитьСтроку_ТЧ_") = 0 Тогда 
		
		ИмяТЧ_Индекс_Строкой 	= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_УдалитьСтроку_ТЧ_") + СтрДлина("_УдалитьСтроку_ТЧ_"));
		ИмяТаблицы 				= Лев(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") - 1);
		ИндексСтроки 			= Число(Сред(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") + 1));
		ДанныеЭлемента 			= Форма.Объект[ИмяТаблицы][ИндексСтроки];
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "ПолеФормы_") = 0 И НЕ СтрНайти(Элемент.Имя, "_ТЧ_") = 0 Тогда
		
		ИмяТЧ_Индекс_Строкой 	= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_ТЧ_") + СтрДлина("_ТЧ_"));
		ИмяТаблицы 				= Лев(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") - 1);
		ИндексСтроки 			= Число(Сред(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") + 1));
		ДанныеЭлемента 			= Форма.Объект[ИмяТаблицы][ИндексСтроки];
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "ПолеРедактирование_") = 0 И НЕ СтрНайти(Элемент.Имя, "_ТЧ_") = 0 Тогда
		
		ИмяТЧ_Индекс_Строкой 	= Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_ТЧ_") + СтрДлина("_ТЧ_"));
		ИмяТаблицы 				= Лев(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") - 1);
		ИндексСтроки 			= Число(Сред(ИмяТЧ_Индекс_Строкой, СтрНайти(ИмяТЧ_Индекс_Строкой, "_") + 1));
		ДанныеЭлемента 			= Форма.Объект[ИмяТаблицы][ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Лицевой_Бонусный_Счет_Контрагента_") Тогда
		
		ИмяТаблицы 				= "ТаблицаЛицевыхБонусныхСчетов";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Лицевой_Бонусный_Счет_Контрагента_") + 1));
		ДанныеЭлемента 			= Форма.ТаблицаЛицевыхБонусныхСчетов[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "РодственникиСуществующие_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "Родственники_Редактировать_") Тогда 
		
		ИмяТаблицы 				= "РодственникиСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, ?(СтрНачинаетсяС(Элемент.Имя, "РодственникиСуществующие_"), СтрДлина("РодственникиСуществующие_"), СтрДлина("Родственники_Редактировать_")) + 1));
		ДанныеЭлемента 			= Форма.РодственникиСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ПользователиИБСуществующие_") Тогда 
		
		ИмяТаблицы 				= "ПользователиИБСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ПользователиИБСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.ПользователиИБСуществующие[ИндексСтроки];
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "Основание_") = 0 Тогда
		
		ИндексСтроки 			= Число(Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_") + 1));
		ДанныеЭлемента 			= Форма.Объект.РасшифровкаПлатежа[ИндексСтроки];
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "КабинетыУдалить_") = 0 Тогда
		
		ИмяТаблицы 				= "КабинетыУдалить";
		МассивПодстрок			= СтрРазделить(Элемент.Имя, "_", Ложь);
		ИндексСтроки			= ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], -1);
		ДанныеЭлемента 			= Форма.КабинетыСуществующие.НайтиПоИдентификатору(ИндексСтроки);
		
	ИначеЕсли НЕ СтрНайти(Элемент.Имя, "КабинетыСуществующие_") = 0 Тогда
		
		ИмяТаблицы 				= "КабинетыСуществующие";
		МассивПодстрок			= СтрРазделить(Элемент.Имя, "_", Ложь);
		ИндексСтроки			= ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], -1); 
		ДанныеЭлемента 			= Форма.КабинетыСуществующие.НайтиПоИдентификатору(ИндексСтроки);   
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ДекорацияФормы_УдалениеИнтервала_") Тогда 
		
		ИмяТаблицы 				= "ОтборИнтервалыРаботы";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ДекорацияФормы_УдалениеИнтервала_") + 1));
		ДанныеЭлемента 			= Форма.ОтборИнтервалыРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ВыборНачалаИнтервала_") Тогда 
		
		ИмяТаблицы 				= "ОтборИнтервалыРаботы";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_ВыборНачалаИнтервала_") + 1));
		ДанныеЭлемента 			= Форма.ОтборИнтервалыРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_ВыборОкончанияИнтервала_") Тогда 
		
		ИмяТаблицы 				= "ОтборИнтервалыРаботы";				
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_ВыборОкончанияИнтервала_") + 1));
		ДанныеЭлемента 			= Форма.ОтборИнтервалыРаботы[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Подключаемый_Открыть_Субъект_Оплаты_") Тогда
		
		ИмяТаблицы 				= "Информация_По_Оплате";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Подключаемый_Открыть_Субъект_Оплаты_") + 1));
		ДанныеЭлемента 			= Форма.Информация_По_Оплате[ИндексСтроки];  	
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ДолгиСуществующие_") Тогда
		
		ИмяТаблицы 				= "ДолгиСуществующие";
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ДолгиСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.ДолгиСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "КартыСуществующие_") Тогда
		
		ИмяТаблицы 				= "КартыСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("КартыСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.КартыСуществующие[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "БудущееСобытие_") Тогда
		
		ИмяТаблицы 				= "БудущиеСобытия";
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("БудущееСобытие_") + 1));
		ДанныеЭлемента 			= Форма.БудущиеСобытия[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ПромокодыСуществующие_") Тогда
		ИмяТаблицы 				= "ПромокодыСуществующие";		
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ПромокодыСуществующие_") + 1));
		ДанныеЭлемента 			= Форма.ПромокодыСуществующие[ИндексСтроки];
		
	Иначе 
		
		ИмяТаблицы 		= "";
		ДанныеЭлемента 	= Неопределено;
		
	КонецЕсли;
	
	Возврат Новый Структура("ИмяТаблицы, ИндексСтроки, ДанныеЭлемента", ИмяТаблицы, ИндексСтроки, ДанныеЭлемента);

	
КонецФункции

// Функция - Получить данные элемента виджета сделки
//
// Параметры:
//  Форма	 - 	 - 
//  Элемент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеЭлементаВиджетаСделки(Знач Форма, Знач Элемент) Экспорт
	
	Если СтрНачинаетсяС(Элемент.Имя, "ВыбратьВидГенерируемойСделки_") Тогда 
		
		ИмяТаблицы 				= "ТаблицаДоступныхВидовСделок";
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ВыбратьВидГенерируемойСделки_") + 1));
		ДанныеЭлемента 			= Форма.ТаблицаДоступныхВидовСделок[ИндексСтроки];
		
	ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "ВыбратьЭтапГенерируемойСделки_") Тогда
		
		ИмяТаблицы 				= "ТаблицаДоступныхВидовСделок";
		ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("ВыбратьЭтапГенерируемойСделки_") + 1));
		ДанныеЭлемента 			= Форма.Таблица_Задачи_БП_CRM[ИндексСтроки];
		
	//ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Флаг_Выполнения_НеВыполненнойЗадачи_Поле_") Тогда
	//	
	//	ИмяТаблицы 				= "Таблица_Задачи_БП_CRM";		
	//	ИндексСтроки			= Число(Сред(Элемент.Имя, СтрДлина("Флаг_Выполнения_НеВыполненнойЗадачи_Поле_Индекс_") + 1));
	//	ДанныеЭлемента 			= Форма.Таблица_Задачи_БП_CRM[ИндексСтроки];
	//	
	//ИначеЕсли СтрНачинаетсяС(Элемент.Имя, "Действие_ВыполненаяЗадача_Картинка_Индекс_") ИЛИ СтрНачинаетсяС(Элемент.Имя, "Действие_НеВыполненаяЗадача_Картинка_Индекс_") Тогда
