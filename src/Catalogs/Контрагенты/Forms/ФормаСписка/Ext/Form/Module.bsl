
#Область ОбработчикиСобытийФормы

&НаСервере 
// Процедура, Обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ОтборПоКонтрагенту") Тогда 

		Элементы.ГруппаСоздать.Видимость                                 = Ложь; 
		Элементы.ГруппаСоздатьКонтагента.Видимость                       = Истина; 
		Элементы.СписокКонтекстноеМенюГруппаСоздать.Видимость            = Ложь;   
		Элементы.СписокКонтекстноеМенюГруппаСоздатьКонтрагента.Видимость = Истина;
		
		ГруппаЭлементовОтбора           = Список.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаЭлементовОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;	
		
		СписокТиповПациентов = Новый СписокЗначений;
		СписокТиповПациентов.Добавить(Перечисления.ТипыКонтрагентов.Клиенты);
		СписокТиповПациентов.Добавить(Перечисления.ТипыКонтрагентов.КорпоративныеКонтрагенты);  
		СписокТиповПациентов.Добавить(Перечисления.ТипыКонтрагентов.ПустаяСсылка());
		
		Если Параметры.Свойство("ОтборПоСтраховымКомпаниям") Тогда
			ИскомыйЭлемент = Справочники.Контрагенты.НайтиПоНаименованию("Страховые компании",Истина);
			Если ИскомыйЭлемент.Пустая() Тогда
				Справочники.Контрагенты.ЗаполнитьПоУмолчанию();
			КонецЕсли;
			Элементы.Список.Отображение = ОтображениеТаблицы.Список;
			СписокТиповПациентов.Добавить(Перечисления.ТипыКонтрагентов.ГосОрган);   
			СписокТиповПациентов.Добавить(Перечисления.ТипыКонтрагентов.Лаборатория); 
			СписокТиповПациентов.Добавить(Перечисления.ТипыКонтрагентов.Поставщик);			
		КонецЕсли;  	
		
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ТипКонтрагента", СписокТиповПациентов, Истина, ВидСравненияКомпоновкиДанных.НеВСписке, ГруппаЭлементовОтбора);	
		
		// Скрываем группы с пациентами	
		ЭлементОформления = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
		
		ЭлементОформления = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Видимость" , Истина);
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Отображать", Истина);
		
		ОтборПоГруппе                = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборПоГруппе.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Ссылка");
		ОтборПоГруппе.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВИерархии;
		ОтборПоГруппе.ПравоеЗначение = ПолучитьГруппыСКонтрагентами(Параметры.Свойство("ОтборПоСтраховымКомпаниям"));   
				
		// Настраиваем отображение
		Элементы.Список.ОтображатьКорень = Ложь;
		ЭтаФорма.Заголовок = ?(Параметры.Свойство("ОтборПоСтраховымКомпаниям"), "Страховые компании", "Контрагенты");
			
	КонецЕсли;    
	
	// СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Справочники.Контрагенты, НастройкиЗагрузкиДанных, ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы
 
&НаКлиенте
// Процедура, Обработчик события "СписокПриАктивизацииСтроки"
//
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	Если Элементы.Список.ТекущиеДанные <> Неопределено И Элементы.Список.ТекущийЭлемент = Неопределено Тогда 
		 ПодключитьОбработчикОжидания("ПрограммноеНажатиеКнопки", 0.1, Истина);
	КонецЕсли;
	
 КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте 
// Обработчик события "СоздатьКонтрагента".
//
Процедура СоздатьКонтрагента(Команда) 
	
	НазваниеФормы = "ФормаЭлемента";  
	СоздатьЭлементСправочникаКонтрагенты(НазваниеФормы);
	
КонецПроцедуры

&НаКлиенте 
// Обработчик события "СоздатьГруппуКонтрагента".
//
Процедура СоздатьГруппуКонтрагента(Команда) 
	
	НазваниеФормы = "ФормаГруппы"; 
	СоздатьЭлементСправочникаКонтрагенты(НазваниеФормы);
	
КонецПроцедуры 

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Функция - возвращает список групп с контрагентами для скрытия групп с пациентами
// 
Функция ПолучитьГруппыСКонтрагентами(ТолькоСтраховые = Ложь)
	
	Запрос = Новый Запрос;
	
	Если ТолькоСтраховые Тогда

		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Контрагенты.Родитель КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.СтраховаяКомпания)
		|	И НЕ Контрагенты.ЭтоГруппа
		|	И НЕ Контрагенты.ПометкаУдаления		
		|
		|СГРУППИРОВАТЬ ПО
		|	Контрагенты.Родитель";
		
	Иначе	
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Контрагенты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ЭтоГруппа = ИСТИНА
		|	И НЕ Контрагенты.ТипКонтрагента В (ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты),
		|									   ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.КорпоративныеКонтрагенты),
		|									   ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.ПустаяСсылка))";
		
	КонецЕсли;	

	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();	
	СписокГруппСКонтрагентами = Новый СписокЗначений;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокГруппСКонтрагентами.Добавить(ВыборкаДетальныеЗаписи.Ссылка);			
	КонецЦикла;
	
	Возврат СписокГруппСКонтрагентами;
	
КонецФункции  
	
&НаКлиенте
// СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
//
Процедура ПоказатьПомощникЗагрузкиДанныхИзВнешнегоИсточника()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузкаДанныхИзВнешнегоИсточникаОбработкаРезультата", ЭтотОбъект, НастройкиЗагрузкиДанных);
	
	НастройкиЗагрузкиДанных.Вставить("ИмяМакетаСШаблоном", "ЗагрузкаИзФайла");
	НастройкиЗагрузкиДанных.Вставить("ОписаниеСтрокиВыбора", Новый Структура("ПолноеИмяОбъектаМетаданных, Тип", "Контрагенты", "ПрикладнаяЗагрузка"));
	
	ЗагрузкаДанныхИзВнешнегоИсточникаКлиент.ПоказатьФормуЗагрузкиДанныхИзВнешнегоИсточника(НастройкиЗагрузкиДанных, ОписаниеОповещения, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте 
// Процедура, Обработчик события "ЗагрузкаДанныхИзВнешнегоИсточника"
//
Процедура ЗагрузкаДанныхИзВнешнегоИсточника(Команда)
	
	ПоказатьПомощникЗагрузкиДанныхИзВнешнегоИсточника();
	
КонецПроцедуры

&НаКлиенте 
// Процедура, Обработчик события "ЗагрузкаДанныхИзВнешнегоИсточникаОбработкаРезультата"
//
Процедура ЗагрузкаДанныхИзВнешнегоИсточникаОбработкаРезультата(РезультатЗагрузки, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(РезультатЗагрузки) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если РезультатЗагрузки.ОписаниеДействия = "ИзменитьСпособЗагрузкиДанныхИзВнешнегоИсточника" Тогда
	
		ЗагрузкаДанныхИзВнешнегоИсточника.ИзменитьСпособЗагрузкиДанныхИзВнешнегоИсточника(НастройкиЗагрузкиДанных.ИмяФормыЗагрузкиДанныхИзВнешнихИсточников);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузкаДанныхИзВнешнегоИсточникаОбработкаРезультата", ЭтотОбъект, НастройкиЗагрузкиДанных);
		ЗагрузкаДанныхИзВнешнегоИсточникаКлиент.ПоказатьФормуЗагрузкиДанныхИзВнешнегоИсточника(НастройкиЗагрузкиДанных, ОписаниеОповещения, ЭтотОбъект);
		
	ИначеЕсли РезультатЗагрузки.ОписаниеДействия = "ОбработатьПодготовленныеДанные" Тогда
		
		ДлительнаяОперация = ЗапуститьОбработкуПодготовленныхДанных(РезультатЗагрузки);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
		
		ПараметрыОжидания.ОповещениеПользователя.Показать = Истина;
		ПараметрыОжидания.ОповещениеПользователя.Текст = НСтр("ru='Контрагенты'");
		ПараметрыОжидания.ОповещениеПользователя.Пояснение = НСтр("ru='Загрузка данных завершена.'");
		ПараметрыОжидания.ОповещениеПользователя.НавигационнаяСсылка = Окно.ПолучитьНавигационнуюСсылку();
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Новый ОписаниеОповещения("ЗавершениеОбработкиПодготовленныхДанных", ЭтотОбъект), ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, "ЗапуститьОбработкуПодготовленныхДанных" 
//
Функция ЗапуститьОбработкуПодготовленныхДанных(РезультатЗагрузки)
	
	ИмяПроцедуры = "Справочники.Контрагенты.ОбработатьПодготовленныеДанные";
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("НастройкиЗагрузкиДанных"   , РезультатЗагрузки.НастройкиЗагрузкиДанных);
	ПараметрыПроцедуры.Вставить("ТаблицаСопоставленияДанных", ДанныеФормыВЗначение(РезультатЗагрузки.ТаблицаСопоставленияДанных, Тип("ТаблицаЗначений")));
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Подсистема ЗагрузкаДанныхИзВнешнегоИсточника: Выполнение серверного метода загрузки результата'");
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте 
// Процедура, "ЗавершениеОбработкиПодготовленныхДанных"
//
Процедура ЗавершениеОбработкиПодготовленныхДанных(Результат, ДополнительныеПараметры) Экспорт
	
	Элементы.Список.Обновить();
	
КонецПроцедуры
// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника

&НаКлиенте 
// Процедура, обработчик события "СоздатьЭлементСправочникаКонтрагенты" 
//
Процедура СоздатьЭлементСправочникаКонтрагенты(НазваниеФормы)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	ЭлементОтбора = Неопределено;
	Если ТекущиеДанные <> Неопределено Тогда 
		// Первый параметр поставила "родитель", так как если передать "тип контрагента", тогда дополнительно будет создаваться еще и группа, 
		// получится что на каждого нового контрагента новая группа (поиск в группы в модуле объекта осуществляется с типом клиент от того группа не находится и создается новая)
		Если ЭтаФорма.Заголовок = "Страховые компании" Тогда
			ЭлементОтбора = Новый Структура("ТипКонтрагента", ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.СтраховаяКомпания"));
		Иначе	
			Если НазваниеФормы = "ФормаГруппы" И ЗначениеЗаполнено(ТекущиеДанные.Ссылка) И ТекущиеДанные.Свойство("Родитель") Тогда
				ТекущиеДанные.Родитель = ТекущиеДанные.Ссылка; 
			КонецЕсли;	
			Если ТекущиеДанные.Свойство("Родитель") И ЗначениеЗаполнено(ТекущиеДанные.Родитель) Тогда
				ЭлементОтбора = Новый Структура("Родитель", ТекущиеДанные.Родитель);  
			ИначеЕсли ТекущиеДанные.Свойство("ТипКонтрагента") И ЗначениеЗаполнено(ТекущиеДанные.ТипКонтрагента) Тогда
				ЭлементОтбора = Новый Структура("ТипКонтрагента", ТекущиеДанные.ТипКонтрагента);		
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ЭтаФорма.Заголовок = "Страховые компании" Тогда
		ЭлементОтбора = Новый Структура("ТипКонтрагента", ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.СтраховаяКомпания"));
	КонецЕсли;	
	
	ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения, ЭтоГруппа", ЭлементОтбора, НазваниеФормы = "ФормаГруппы"); 	
	ОткрытьФорму("Справочник.Контрагенты.Форма."+НазваниеФормы, ПараметрыОткрытия, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
	
КонецПроцедуры 
 
&НаКлиенте 
// Процедура, обработчик события "ПрограммноеНажатиеКнопки"
//
Процедура ПрограммноеНажатиеКнопки()
	
	ОбъектShell = Новый COMОбъект("Wscript.Shell");
	ОбъектShell.SendKeys("{DOWN}");
	
КонецПроцедуры

#КонецОбласти