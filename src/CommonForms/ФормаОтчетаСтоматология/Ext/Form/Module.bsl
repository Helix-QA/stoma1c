// Функция добавляет в массив ставку НДС
// 
Функция ДобавитьСтавкуНДС(МассивЗапасовПоСкладу, ВидОбеспечения)
	
	Для Каждого ЭлементМассива Из МассивЗапасовПоСкладу Цикл 
		Если ЗначениеЗаполнено(ЭлементМассива.Номенклатура) Тогда 
			ЭлементМассива.Вставить("СтавкаНДС", ЭлементМассива.Номенклатура.СтавкаНДС);                                                                          			
			Если ВидОбеспечения = "ЗаказПоставщику" ИЛИ ВидОбеспечения = "ПеремещениеЗапасов" Тогда
				// ничего не делаем
			Иначе 	
				ЭлементМассива.КоличествоУпаковокОбеспечения = ?(ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию.Коэффициент = 0, ЭлементМассива.Обеспечение / 1, ЭлементМассива.Обеспечение / ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию.Коэффициент);
				Если НЕ ЭлементМассива.Свойство("Упаковка") Тогда
					ЭлементМассива.Вставить("Упаковка", ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию);
				Иначе 
					ЭлементМассива.Упаковка = ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию;
				КонецЕсли;				
			КонецЕсли;	
		КонецЕсли;		
	КонецЦикла;	
	
	Возврат МассивЗапасовПоСкладу;
	
КонецФункции

