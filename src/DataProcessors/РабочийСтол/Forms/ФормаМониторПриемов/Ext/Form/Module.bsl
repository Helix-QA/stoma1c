// Функция - Получить структуру реквизитов формы
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуруРеквизитовФормы() Экспорт
	
	СтруктураРеквизитов = Новый Структура();
	
	РеквизитыФормы = ЭтаФорма.ПолучитьРеквизиты();
	
	Для Каждого РеквизитФормы Из РеквизитыФормы Цикл 
		Если РеквизитФормы.Имя = "Объект" Тогда 
			Продолжить;
		ИначеЕсли РеквизитФормы.ТипЗначения.СодержитТип(Тип("ДинамическийСписок")) Тогда 
			Продолжить;
		ИначеЕсли РеквизитФормы.ТипЗначения.СодержитТип(Тип("ТаблицаЗначений")) Тогда	
			Продолжить;
		Иначе 
			СтруктураРеквизитов.Вставить(РеквизитФормы.Имя, ЭтаФорма[РеквизитФормы.Имя]);
		КонецЕсли;	
	КонецЦикла;
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

