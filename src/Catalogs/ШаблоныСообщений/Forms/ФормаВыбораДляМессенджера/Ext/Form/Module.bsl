&НаКлиенте
// Процедура, обновляет поле предпросмотра шаблона.
//
Процедура ОбновитьПолеПредпросмотра(СписокЭлемент)
	
	Если СписокЭлемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СписокЭлемент.ТекущиеДанные.ЭтоГруппа = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.ПолеПредпросмотра.Документ.readyState = "complete" Тогда
		Элементы.ПолеПредпросмотра.Документ.getElementById("field").innerHtml = СписокЭлемент.ТекущиеДанные.СодержаниеМессенджерHTML;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
