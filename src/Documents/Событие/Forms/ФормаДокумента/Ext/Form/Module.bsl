// Функция, возвращает ссылку на событие основаннное на переносе текущей записи.
//
Функция ПолучитьПредварительнуюЗаписьОтмененногоСобытия(ПредварительнаяЗапись)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Событие.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.Проведен
	|	И НЕ Событие.ПометкаУдаления
	|	И Событие.ПеренесённаяПредварительнаяЗапись = &ПеренесённаяПредварительнаяЗапись");
	Запрос.УстановитьПараметр("ПеренесённаяПредварительнаяЗапись", ПредварительнаяЗапись);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

