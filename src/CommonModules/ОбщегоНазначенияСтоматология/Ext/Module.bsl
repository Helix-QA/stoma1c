//
//
Функция ВернутьТаблицуСтатусовНарядЗаказов(МассивДокументов) Экспорт
	
	ТаблицаДокументов = Новый ТаблицаЗначений;
	ТаблицаДокументов.Колонки.Добавить("НарядЗаказ");
	ТаблицаДокументов.Колонки.Добавить("СтатусПоОстаткам");
	
	Для Каждого ЭлементМассива Из МассивДокументов Цикл 
		НоваяСтрока = ТаблицаДокументов.Добавить();
		НоваяСтрока.НарядЗаказ 			= ЭлементМассива;
		НоваяСтрока.СтатусПоОстаткам 	= "";
	КонецЦикла;
	
	// ТаблицаДокументов.ЗагрузитьКолонку(МассивДокументов, "НарядЗаказ");		
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	НарядЗаказыОстатки.НарядЗаказ КАК НарядЗаказ
	               |ИЗ
	               |	РегистрНакопления.НарядЗаказы.Остатки(
	               |			,
	               |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |				И НарядЗаказ В (&МассивДокументов)) КАК НарядЗаказыОстатки
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	НарядЗаказыОстатки.НарядЗаказ";
				   
	Запрос.УстановитьПараметр("МассивДокументов"	, МассивДокументов);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ?(МассивДокументов.Количество() > 0, МассивДокументов[0].СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));
	
	ТаблицаОткрытыхНЗ = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТаблицаДокументов Из ТаблицаДокументов Цикл 
		Если ТаблицаОткрытыхНЗ.Найти(СтрокаТаблицаДокументов.НарядЗаказ) = Неопределено Тогда 
			СтрокаТаблицаДокументов.СтатусПоОстаткам = "Закрыт";
		Иначе 
			СтрокаТаблицаДокументов.СтатусПоОстаткам = "Открыт";
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаДокументов;
	
КонецФункции

