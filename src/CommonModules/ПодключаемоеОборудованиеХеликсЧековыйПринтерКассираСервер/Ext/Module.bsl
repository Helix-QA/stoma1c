
#Область СлужебныйПрограммныйИнтерфейс

// Функция осуществляет закрытие ранее открытого чека.
//
Функция ЗакрытьЧек(ОбъектДрайвера, Параметры, ПараметрыПодключения, ТаблицаОплат, ВыходныеПараметры) Экспорт

	Результат = Истина;
	СтрокаЛога = "";

	СуммаНаличнойОплаты     = 0;
	СуммаБезналичнойОплаты1 = 0;
	СуммаБезналичнойОплаты2 = 0;
	СуммаАвансом		    = 0;

	Для ИндексОплаты = 0 По ТаблицаОплат.Количество() - 1 Цикл
		Если ТаблицаОплат[ИндексОплаты].ТипОплаты = Перечисления.ТипыОплатыККТ.Наличные Тогда
			СуммаНаличнойОплаты = СуммаНаличнойОплаты + ТаблицаОплат[ИндексОплаты].Сумма;
		ИначеЕсли ТаблицаОплат[ИндексОплаты].ТипОплаты = Перечисления.ТипыОплатыККТ.Электронно Тогда
			СуммаБезналичнойОплаты1 = СуммаБезналичнойОплаты1 + ТаблицаОплат[ИндексОплаты].Сумма;
		ИначеЕсли ТаблицаОплат[ИндексОплаты].ТипОплаты = Перечисления.ТипыОплатыККТ.Предоплата Тогда
			СуммаАвансом = СуммаАвансом + ТаблицаОплат[ИндексОплаты].Сумма;   
		Иначе
			СуммаБезналичнойОплаты2 = СуммаБезналичнойОплаты2 + ТаблицаОплат[ИндексОплаты].Сумма;
		КонецЕсли;
	КонецЦикла;
	
	ЭтоУкраина = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки().Код = "804";
	
	Если Не ПараметрыПодключения.ЧекОткрыт Тогда
		ВыходныеПараметры.Очистить();
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить(НСтр("ru='Чек не был открыт';en='Check not was isopen'"));
		Результат = Ложь;
	Иначе
		Если ПараметрыПодключения.ФискальныйЧек Тогда
			СтрокаЛога = СтрокаЛога + ПолучитьСловоСУчетомЯзыка("ИТОГО", ЭтоУкраина) + ": " + Формат(ПараметрыПодключения.ИтогЧека, "ЧЦ=15; ЧДЦ=2; ЧН=0; ЧГ=0") + Символы.ПС;
			СтрокаЛога = СтрокаЛога + НСтр("ru='Оплачено наличными'; en='Cash'") + ": "      + СуммаНаличнойОплаты + Символы.ПС;
			СтрокаЛога = СтрокаЛога + НСтр("ru='Оплачено безналичными 1';en='Paid cashless 1'") + ": " + СуммаБезналичнойОплаты1 + Символы.ПС;
			СтрокаЛога = СтрокаЛога + НСтр("ru='Оплачено безналичными 2';en='Paid cashless 2'") + ": " + СуммаБезналичнойОплаты2 + Символы.ПС;
			СтрокаЛога = СтрокаЛога + НСтр("ru='Оплачено авансом';en='Paid in advanced'") + ": " + СуммаАвансом + Символы.ПС;
			//СтрокаЛога = СтрокаЛога + НСтр("ru='Сдача';en='Surrender'") + ": "
			//                        + Строка(СуммаНаличнойОплаты
			//                               + СуммаБезналичнойОплаты1
			//                               + СуммаБезналичнойОплаты2
			//                               - ПараметрыПодключения.ИтогЧека) + Символы.ПС;
		КонецЕсли;
		СтрокаЛога = СтрокаЛога + "===== "
		                        + ?(ПараметрыПодключения.ФискальныйЧек,
		                            НСтр("ru='Закрытие фискального чека';en='Closing fiscal check'"),
		                            НСтр("ru='Закрытие нефискального чека';en='Closing nonfiscal check'"))
		                        + " =====" + Символы.ПС;
		ПараметрыПодключения.ЧекОткрыт = Ложь;
		
		ТабДок = Параметры.ТабличныйДокумент;
		Макет  = Параметры.Макет;
		ОблИтого         = Макет.ПолучитьОбласть("ИнформацияИтого");
		ОблИтого1        = Макет.ПолучитьОбласть("ИнформацияИтого1");
		ОблИтогоОпл      = Макет.ПолучитьОбласть("ИнформацияИтогоОплата");
		ОблПодвал        = Макет.ПолучитьОбласть("Подвал");
		
		ОблИтого.Параметры.Всего = Формат(ПараметрыПодключения.ИтогЧека, "ЧЦ=15; ЧДЦ=2; ЧН=0; ЧГ=0");
		ТабДок.Вывести(ОблИтого);
		
		Для ИндексОплаты = 0 По ТаблицаОплат.Количество() - 1 Цикл
			Если ТаблицаОплат[ИндексОплаты].Сумма > 0 Тогда
				ОблИтогоОпл.Параметры.ОплатаНал = ТаблицаОплат[ИндексОплаты].Сумма;
				ВидОблаты = НСтр("ru='Безналичная оплата'; en='Card'; uk ='Безготівковий розрахунок'");
				Если ТаблицаОплат[ИндексОплаты].ТипОплаты = Перечисления.ТипыОплатыККТ.Наличные Тогда
					ВидОблаты = НСтр("ru='Наличная оплата'; en='Cash'; uk ='Готівка'");
				ИначеЕсли ТаблицаОплат[ИндексОплаты].ТипОплаты = Перечисления.ТипыОплатыККТ.Электронно Тогда
					ВидОблаты = НСтр("ru='Платежная карта'; en='Card'; uk ='Платіжна картка'");
				ИначеЕсли ТаблицаОплат[ИндексОплаты].ТипОплаты = Перечисления.ТипыОплатыККТ.Предоплата Тогда
					ВидОблаты = НСтр("ru='Авансом'; en='Advanced'; uk ='Авансом'");
				КонецЕсли;	
				//ВидОблаты = ПолучитьСловоСУчетомЯзыка(ВидОблаты, ЭтоУкраина);
				
				ОблИтогоОпл.Параметры.Оплата = ВидОблаты + ":";
				ТабДок.Вывести(ОблИтогоОпл);
			КонецЕсли;
		КонецЦикла;		
		//ОблИтого.Параметры.ОплатаНал    = СуммаНаличнойОплаты + СуммаБезналичнойОплаты1 + СуммаБезналичнойОплаты2;
		//ОблИтого.Параметры.ОплатаБезНал = СуммаБезналичнойОплаты1;
		//ОблИтого1.Параметры.СуммаСдачи = СуммаНаличнойОплаты + СуммаБезналичнойОплаты1 + СуммаБезналичнойОплаты2 - ПараметрыПодключения.ИтогЧека;
		//ТабДок.Вывести(ОблИтого1);
		
		Для Каждого СтрокаПодвала Из Параметры.ТаблицаПодвалЧека Цикл
			ОблПодвал.Параметры.ТекстПодвала = СокрЛП(СтрокаПодвала);   
			Попытка
				ОблПодвал.Области.Подвал.ГоризонтальноеПоложение = ?(СтрНайти(СтрокаПодвала, МенеджерОборудованияВызовСервера.ПолучитьСловоСУчетомЯзыка("ФИО: ")) <> 0, ГоризонтальноеПоложение.Лево, ГоризонтальноеПоложение.Центр);
			Исключение КонецПопытки;
			ТабДок.Вывести(ОблПодвал);
		КонецЦикла;
		
		ТабДок.ПолеСверху = 0.5;
		ТабДок.ПолеСнизу  = 0.5;
		ТабДок.ПолеСлева  = 0.1;
		ТабДок.ПолеСправа = 0.1;
		ТабДок.РазмерКолонтитулаСверху = 0.5;
		ТабДок.РазмерКолонтитулаСнизу = 0.5;	
			
	КонецЕсли;

	ПараметрыПодключения.СтрокаЛога = ПараметрыПодключения.СтрокаЛога + СтрокаЛога;
	Возврат Результат;

КонецФункции

// Функция осуществляет печать фискальной строки.
//
Функция НапечататьФискальнуюСтроку(ОбъектДрайвера, Параметры, ПараметрыПодключения,
                                   Наименование, Количество, Цена, ПроцентСкидки, Сумма,
                                   НомерСекции, СтавкаНДС, ВыходныеПараметры, СуммаВключаетНДС = Истина, СуммаНДС = 0)  Экспорт
								   
								   // процент скидки предаваемый в параметрах не исп

	Результат  = ПараметрыПодключения.ЧекОткрыт;
	СтрокаЛога = "";

	Если Не ПараметрыПодключения.ЧекОткрыт Тогда
		ВыходныеПараметры.Очистить();
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить(НСтр("ru='Чек не был открыт';en='Check not was isopen'"));

	Иначе
		
		ТабДок = Параметры.ТабличныйДокумент;
		Макет  = Параметры.Макет;
		
		ОблТовара        = Макет.ПолучитьОбласть("ИнформацияОТоваре");
		ОблСумма         = Макет.ПолучитьОбласть("ИнформацияПоСумме");
		ОблСкидка        = Макет.ПолучитьОбласть("ИнформацияПоСкидке");    
		
		//Если Параметры.Свойство("ОтображатьЛоготип") И Параметры.ОтображатьЛоготип 
		//	И Параметры.Свойство("ЛоготипОрганизации") И ЗначениеЗаполнено(Параметры.ЛоготипОрганизации)
		//	И Параметры.Свойство("ТабличныйДокумент") И Параметры.Свойство("Макет") Тогда 
		//	
		//	МенеджерОборудованияВызовСервера.ВывестиОбластьЛоготипа(Параметры.ТабличныйДокумент, Параметры.Макет, Параметры);
		//КонецЕсли;             
		
		ЭтоУкраина  = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки().Код = "804";
		ФорматЧисла = "ЧЦ=15; ЧДЦ=2; ЧН=0; ЧГ=0";
		
		// Печать строки чека
		СтрокаЛога = ".............................." + Символы.ПС;
		СтрокаЛога = СтрокаЛога + Наименование + Символы.ПС;
		СтрокаЛога = СтрокаЛога + Строка(Количество) + " * " + Строка(Цена) + " = " + Формат(Количество*Цена, ФорматЧисла) + Символы.ПС;

		СкидкаНаценка = Сумма - ?(СуммаВключаетНДС, 0, СуммаНДС) - Цена*Количество;
		
		Если Цена > 0 Тогда
			ПроцентСкидки = Окр(СкидкаНаценка * -1/(Цена*Количество) * 100, 1, РежимОкругления.Окр15как20);		
		Иначе
			ПроцентСкидки = 0;
		КонецЕсли;
		Если СкидкаНаценка < 0 Тогда		
			СтрокаЛога = СтрокаЛога + ПолучитьСловоСУчетомЯзыка("Скидка", ЭтоУкраина) + ": " + Формат(-СкидкаНаценка, ФорматЧисла)
			           + " (" + ПроцентСкидки + "%)" + Символы.ПС;
		ИначеЕсли СкидкаНаценка > 0 Тогда		   
			СтрокаЛога = СтрокаЛога + ПолучитьСловоСУчетомЯзыка("Наценка", ЭтоУкраина) + ": " + Формат(СкидкаНаценка, ФорматЧисла)
			           + " (" + ПроцентСкидки + "%)" + Символы.ПС;
		КонецЕсли;
		СтрокаЛога = СтрокаЛога + ПолучитьСловоСУчетомЯзыка("Отдел", ЭтоУкраина) + ": №" + НомерСекции + Символы.ПС;
		Если ЗначениеЗаполнено(СтавкаНДС) и СтавкаНДС > 0 Тогда
			СтрокаЛога = СтрокаЛога + ПолучитьСловоСУчетомЯзыка("НДС", ЭтоУкраина) + ": " + Формат(СуммаНДС, ФорматЧисла) + 
					" (" + СтавкаНДС + "%)" + Символы.ПС;
		КонецЕсли;
		СтрокаЛога = СтрокаЛога + ".............................." + Символы.ПС;
		ПараметрыПодключения.ИтогЧека = ПараметрыПодключения.ИтогЧека + Сумма;
		
		//////////////////////////////////////
		ОблТовара.Параметры.Товар = СокрЛП(Наименование);
		ТабДок.Вывести(ОблТовара);
		ОблСумма.Параметры.ТекстСуммы = Строка(Количество) + " * " + Формат(Цена, ФорматЧисла) + " = " + Формат(Количество*Цена, ФорматЧисла);
		ТабДок.Вывести(ОблСумма);
		
		//СкидкаНаценка = Цена*Количество / СкидкаНаценка  * -1;
		
		Если СкидкаНаценка < 0 Тогда
			ОблСкидка.Параметры.ТекстСкидки = ПолучитьСловоСУчетомЯзыка("Скидка", ЭтоУкраина) + ": " + Формат(-СкидкаНаценка, ФорматЧисла)
			           + " (" + ПроцентСкидки + "%)" + Символы.ПС;
			ТабДок.Вывести(ОблСкидка);
		ИначеЕсли СкидкаНаценка > 0 Тогда
			ОблСкидка.Параметры.ТекстСкидки = ПолучитьСловоСУчетомЯзыка("Наценка", ЭтоУкраина) + ": " + Формат(СкидкаНаценка, ФорматЧисла)
					   + " (" + ПроцентСкидки + "%)" + Символы.ПС;
			ТабДок.Вывести(ОблСкидка);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтавкаНДС) и СтавкаНДС > 0 Тогда
			ОблСумма.Параметры.ТекстСуммы = ПолучитьСловоСУчетомЯзыка("НДС", ЭтоУкраина) + ": " + Формат(СуммаНДС, ФорматЧисла) + 
					" (" + СтавкаНДС + "%)" + Символы.ПС ;
			ТабДок.Вывести(ОблСумма);
		КонецЕсли;    	
		
	КонецЕсли;

	ПараметрыПодключения.СтрокаЛога = ПараметрыПодключения.СтрокаЛога + СтрокаЛога;
	Возврат Результат;

КонецФункции

