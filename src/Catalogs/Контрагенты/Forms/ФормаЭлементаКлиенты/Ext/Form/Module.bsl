&НаКлиенте
// Процедура - Процедура обработки нажатия динамической кнопки.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ПроцедураОбработкиНажатияДинамическойКнопки(Элемент)	
	
	ИндексСтроки      = Число(Сред(Элемент.Имя, СтрДлина("РазрешитьЗапретитьРассылку_")+1));// Цел(Прав(Элемент.имя, 1));
	ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке = Не ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке;
	Элемент.Картинка  = ПолучитьКартинку(ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке);
	Элемент.Подсказка = ПолучитьПодсказку(ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке);
	
	Модифицированность = Истина;
	
КонецПроцедуры

