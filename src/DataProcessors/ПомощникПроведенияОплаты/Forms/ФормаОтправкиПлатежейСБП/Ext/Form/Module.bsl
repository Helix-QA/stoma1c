// Процедура, отправляет ссылку на установку карты.
//
Процедура РазослатьСсылку()
		
	Если ЭтотОбъект.ОтправитьВМессенджер Тогда
		ОтправитьСсылкуНаОплатуНаСервере("Мессенджер", ЭтотОбъект.СсылкаНаОплату);	
	КонецЕсли;
	
	Если ЭтотОбъект.ОтправитьПоSMS Тогда
		ОтправитьСсылкуНаОплатуНаСервере("SMS", ЭтотОбъект.СсылкаНаОплату);
	КонецЕсли;
	
	Если ЭтотОбъект.ОтправитьPushУведомлением Тогда
		ОтправитьСсылкуНаОплатуНаСервере("Push", ЭтотОбъект.СсылкаНаОплату);
	КонецЕсли;
	
	Если ЭтотОбъект.ОтправитьПоEmail Тогда
		ОтправитьСообщениеEmailНаСервере(ЭтотОбъект.СсылкаНаОплату);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, отправляет ссылку на установку карты.
//
Процедура ОтправитьСсылкуНаОплатуНаСервере(СервисРассылки, СсылкаНаОплату)
			
	ПолучателиСообщения = Новый Массив();
	ПолучателиСообщения.Добавить(Новый Структура("Получатель", ЭтотОбъект.Контрагент));
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("Получатели"         , ПолучателиСообщения);
	ПараметрыРассылки.Вставить("Содержание"         , ПолучитьСодержаниеСообщения());
	ПараметрыРассылки.Вставить("СтруктурнаяЕдиница" , ЭтотОбъект.СтруктурнаяЕдиница);
	
	Если СервисРассылки = "SMS" Тогда
		ПараметрыРассылки.Вставить("ОтправкаSMS", Истина);
	КонецЕсли;
	
	Если СервисРассылки = "Мессенджер" Тогда
		ПараметрыРассылки.Вставить("ОтправкаMessenger"	 , Истина);
		ПараметрыРассылки.Вставить("ИнициироватьОтправку", Истина);
	КонецЕсли;
	
	Если СервисРассылки = "Push" Тогда
		ПараметрыРассылки.Вставить("ОтправкаPush", Истина);
	КонецЕсли;
	
	ПараметрыРассылки.Вставить("ОтправитьНемедленно", Истина);
	
	ОписаниеОшибки = "";
	
	УстановитьПривилегированныйРежим(Истина);
	
	Документы.РассылкаСообщений.СоздатьДокументРассылкаСообщений(ПараметрыРассылки, ОписаниеОшибки);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
//Процедура, отправляет сообщение email.
//
Процедура ОтправитьСообщениеEmailНаСервере(СсылкаНаОплату)
	
	ОписаниеОшибки = "";
	
	СоздатьДокументИсходящееПисьмоОтправитьПисьмоНаСервере(
		ЭтотОбъект.Контрагент, 
		ЭтотОбъект.АдресЭП,
		"Оплата по ссылке",
		ПолучитьСодержаниеСообщения(),
		Неопределено,
		ОписаниеОшибки
	);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

