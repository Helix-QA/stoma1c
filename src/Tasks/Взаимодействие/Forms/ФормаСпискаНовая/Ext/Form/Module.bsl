&НаКлиенте
// Процедура - удаляет задачу.
//
Процедура Удалить(Команда)
	
	ЭлементПланировщика = ?(Элементы.План.ВыделенныеЭлементы.Количество() > 0, Элементы.План.ВыделенныеЭлементы[0], Неопределено);
	
	Если ЭлементПланировщика <> Неопределено Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьЗаписьЗавершение", ЭтотОбъект, ЭлементПланировщика);
		
		ПроверкаПометкиНаУдаление = ПроверитьНаПометку(ЭлементПланировщика.Значение);
		Если ПроверкаПометкиНаУдаление Тогда
			ПоказатьВопрос(ОписаниеОповещения, "Снять с """ + Строка(ЭлементПланировщика.Значение) + """ пометку на удаление?", РежимДиалогаВопрос.ДаНет);	
		Иначе
			ПоказатьВопрос(ОписаниеОповещения, "Пометить """ + Строка(ЭлементПланировщика.Значение) + """ на удаление?", РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, УдалитьЗаписьЗавершение.
//
Процедура УдалитьЗаписьЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УдалитьЗапись(ДопПараметры.Значение);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - проверяет удалена ли задача.
// 
Функция  ПроверитьНаПометку(Задача) 	
	
	Возврат Задача.ПометкаУдаления;
	
КонецФункции

&НаСервере
// Процедура - помечает на удаление задачу.
// 
Процедура УдалитьЗапись(Задача) 	
	
	ЗадачаОбъект                 = Задача.ПолучитьОбъект();
	Если ЗадачаОбъект.ПометкаУдаления Тогда
		ЗадачаОбъект.ПометкаУдаления = Ложь;	
	Иначе
		ЗадачаОбъект.ПометкаУдаления = Истина;
	КонецЕсли;
	ЗадачаОбъект.Записать();

КонецПроцедуры

&НаКлиенте
// Процедура - редактирование задачи.
//
Процедура Редактировать(Команда)
	ЭлементПланировщика = ?(Элементы.План.ВыделенныеЭлементы.Количество() > 0, Элементы.План.ВыделенныеЭлементы[0], Неопределено);

	Если ЭлементПланировщика <> Неопределено Тогда

		СсылкаНаЭлементСправочника = ЭлементПланировщика.Значение;
		ПараметрыФормы = Новый Структура("Ключ", СсылкаНаЭлементСправочника);
		ОткрытьФорму("Задача.Взаимодействие.ФормаОбъекта", ПараметрыФормы,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);			
	
	КонецЕсли;
	
КонецПроцедуры

