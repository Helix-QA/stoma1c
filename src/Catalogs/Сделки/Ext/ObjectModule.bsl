
#Область ОбработчикиСобытий

// Процедура - Обработка заполнения.
//
// Параметры:
//  ДанныеЗаполнения	 - 	 - 
//  ТекстЗаполнения		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ТекущийПользователь 		  = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.Автор 			  = ТекущийПользователь;
	ЭтотОбъект.Менеджер 		  = ТекущийПользователь;
	ЭтотОбъект.ДатаСделки 		  = ТекущаяДатаСеанса();
	ЭтотОбъект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения)
		И ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		
		ЭтотОбъект.ВидСделки      	  	= ?(ДанныеЗаполнения.Свойство("ВидСделки")     	 	, ДанныеЗаполнения.ВидСделки     	  	, ЭтотОбъект.ВидСделки);
		ЭтотОбъект.ДатаСделки         	= ?(ДанныеЗаполнения.Свойство("ДатаСделки")        	, ДанныеЗаполнения.ДатаСделки        	, ТекущаяДатаСеанса());
		ЭтотОбъект.Заявка             	= ?(ДанныеЗаполнения.Свойство("Заявка")            	, ДанныеЗаполнения.Заявка            	, ЭтотОбъект.Заявка);
		ЭтотОбъект.Контрагент         	= ?(ДанныеЗаполнения.Свойство("Контрагент")        	, ДанныеЗаполнения.Контрагент        	, ЭтотОбъект.Контрагент);
		//ЭтотОбъект.ЧленствоПакетУслуг = ?(ДанныеЗаполнения.Свойство("ЧленствоПакетУслуг")	, ДанныеЗаполнения.ЧленствоПакетУслуг	, ЭтотОбъект.ЧленствоПакетУслуг);
		ЭтотОбъект.СтруктурнаяЕдиница 	= ?(ДанныеЗаполнения.Свойство("СтруктурнаяЕдиница")	, ДанныеЗаполнения.СтруктурнаяЕдиница	, ЭтотОбъект.СтруктурнаяЕдиница);
		ЭтотОбъект.ЭтапСделки 		  	= ?(ДанныеЗаполнения.Свойство("ЭтапСделки")		 	, ДанныеЗаполнения.ЭтапСделки		  	, ЭтотОбъект.ЭтапСделки);
		                                                                                                                          	
		ЭтотОбъект.КаналПривлечения				 = ?(ДанныеЗаполнения.Свойство("КаналПривлечения")			, ДанныеЗаполнения.КаналПривлечения				, ЭтотОбъект.КаналПривлечения);
		ЭтотОбъект.КаналПривлеченияЗначение		 = ?(ДанныеЗаполнения.Свойство("КаналПривлеченияЗначение")	, ДанныеЗаполнения.КаналПривлеченияЗначение		, ЭтотОбъект.КаналПривлеченияЗначение);
		ЭтотОбъект.РезультатСделки				 = ?(ДанныеЗаполнения.Свойство("РезультатСделки")			, ДанныеЗаполнения.РезультатСделки				, ЭтотОбъект.РезультатСделки);
		ЭтотОбъект.ИсточникИнформации			 = ?(ДанныеЗаполнения.Свойство("ИсточникИнформации")		, ДанныеЗаполнения.ИсточникИнформации			, ЭтотОбъект.ИсточникИнформации);
		ЭтотОбъект.ИсточникИнформацииЗначение	 = ?(ДанныеЗаполнения.Свойство("ИсточникИнформацииЗначение"), ДанныеЗаполнения.ИсточникИнформацииЗначение	, ЭтотОбъект.ИсточникИнформацииЗначение);
		ЭтотОбъект.СуммаСделки					 = ?(ДанныеЗаполнения.Свойство("СуммаСделки")				, ДанныеЗаполнения.СуммаСделки					, ЭтотОбъект.СуммаСделки);
		ЭтотОбъект.КодСинхронизации				 = ?(ДанныеЗаполнения.Свойство("КодСинхронизации")			, ДанныеЗаполнения.КодСинхронизации				, ЭтотОбъект.КодСинхронизации);
		ЭтотОбъект.Автор						 = ?(ДанныеЗаполнения.Свойство("Автор")						, ДанныеЗаполнения.Автор						, ТекущийПользователь);
		ЭтотОбъект.Менеджер						 = ?(ДанныеЗаполнения.Свойство("Менеджер")					, ДанныеЗаполнения.Менеджер						, ТекущийПользователь);
		ЭтотОбъект.Врач							 = ?(ДанныеЗаполнения.Свойство("Врач")						, ДанныеЗаполнения.Врач							, ЭтотОбъект.Врач);
		ЭтотОбъект.Специализация				 = ?(ДанныеЗаполнения.Свойство("Специализация")				, ДанныеЗаполнения.Специализация				, ЭтотОбъект.Специализация);		
		ЭтотОбъект.Прием						 = ?(ДанныеЗаполнения.Свойство("Прием")						, ДанныеЗаполнения.Прием						, ЭтотОбъект.Прием);
		ЭтотОбъект.ПредыдущийПрием				 = ?(ДанныеЗаполнения.Свойство("ПредыдущийПрием")			, ДанныеЗаполнения.ПредыдущийПрием				, ЭтотОбъект.ПредыдущийПрием);		
		ЭтотОбъект.Описание						 = ?(ДанныеЗаполнения.Свойство("Описание")  		 		, ДанныеЗаполнения.Описание						, ЭтотОбъект.Описание);
		ЭтотОбъект.КурсЛечения					 = ?(ДанныеЗаполнения.Свойство("КурсЛечения")				, ДанныеЗаполнения.КурсЛечения					, ЭтотОбъект.КурсЛечения);
		ЭтотОбъект.Лечение						 = ?(ДанныеЗаполнения.Свойство("Лечение")					, ДанныеЗаполнения.Лечение						, ЭтотОбъект.Лечение);
		ЭтотОбъект.СтатусПациента      	  		 = ?(ДанныеЗаполнения.Свойство("СтатусПациента")     	 	, ДанныеЗаполнения.СтатусПациента     	  		, ЭтотОбъект.СтатусПациента);
		ЭтотОбъект.ВходящийНомерТелефона    	 = ?(ДанныеЗаполнения.Свойство("ВходящийНомерТелефона")  	, ДанныеЗаполнения.ВходящийНомерТелефона    	, ЭтотОбъект.ВходящийНомерТелефона);
		
		Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Наименование) 
			И ДанныеЗаполнения.Свойство("СформироватьНаименование") 
			И ДанныеЗаполнения.СформироватьНаименование
			И ЗначениеЗаполнено(ЭтотОбъект.ВидСделки) Тогда 
			
			Если НЕ ЗначениеЗаполнено(Код) Тогда	
				ЭтотОбъект.УстановитьНовыйКод();		
			КонецЕсли;
			ЭтотОбъект.Наименование = Справочники.Сделки.СоздатьНаименованиеСделки(ЭтотОбъект);		
		КонецЕсли;	
	КонецЕсли;
	
	// Пробуем получить заявку пациента
	ИнициализироватьЗаявкуПациента();
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Специализация) Тогда 
		Если ЗначениеЗаполнено(ЭтотОбъект.Врач) Тогда 
			ЭтотОбъект.Специализация = Справочники.Сотрудники.ПолучитьОсновнуюСпециализациюСотрудника(ЭтотОбъект.Врач);
		КонецЕсли;	
	КонецЕсли;
	
	// Установить статусы пациента 
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.СтатусПациента) Тогда
		ЭтотОбъект.СтатусПациента = Справочники.Сделки.ВернутьПризнакПервичногоПациента(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - При копировании
//
// Параметры:
//  ОбъектКопирования	 - 	 - 
//
Процедура ПриКопировании(ОбъектКопирования)
	
	ЭтотОбъект.Автор 				= ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ДатаЗавершенияСделки = Дата(1,1,1);
	ЭтотОбъект.ДатаСделки 			= ТекущаяДатаСеанса();
	ЭтотОбъект.ПричинаОтказа 		= Неопределено;
	ЭтотОбъект.Прием 				= Неопределено;
	ЭтотОбъект.РезультатСделки 		= Перечисления.РезультатыСделок.ПустаяСсылка();
	ЭтотОбъект.ЭтапОтказа 			= Неопределено;
	ЭтотОбъект.ЭтапУспеха 			= Неопределено;
	Если ЗначениеЗаполнено(ОбъектКопирования.ЭтапСделки) И ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОбъектКопирования.ЭтапСделки, "Предопределенный") Тогда 
		ЭтотОбъект.ЭтапСделки 		= Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ОбъектКопирования.ВидСделки, 1);
	КонецЕсли;	
	ЭтотОбъект.НаименованиеСокращенное = "";
	ЭтотОбъект.КурсЛечения 			= Неопределено;
	ЭтотОбъект.Лечение 				= Неопределено;
	ЭтотОбъект.СтатусПациента 		= Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
	
КонецПроцедуры

