// Процедура - устанавливает виды оплат на странице "Оплата".
//
Процедура УстановитьВидыОплатСервер(ОчищатьДеревоОплат = Ложь)
	
	ЭквайринговыйТерминал = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыйТерминалПоУмолчанию(Касса);
	
	Если ОчищатьДеревоОплат = Истина Тогда
		
		ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Очистить();
		ЭтотОбъект.Сумма = 0;   		
	КонецЕсли;
		
	Если Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(Касса, Перечисления.ТипыДенежныхСредств.Наличные) Тогда
		
		УстановитьВидОплатыНаличными();  		
	КонецЕсли;		
	
	Если НЕ ЭквайринговыйТерминал.Пустая()
		И Справочники.Кассы.ПолучитьПризнакИспользованияВидаОплатыПоКассе(Касса, Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта) Тогда 
		
		УстановитьВидОплатыПлатежнойКартой();
	КонецЕсли;	   	
	
	УстановитьВидОплатыСБП_И_СсылокНаОплату();
	
	ЭлементыДерева = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы();
	Если ЭлементыДерева.Количество() > 0 Тогда
		Элементы.ГруппаОплата.Видимость = Истина;
		Элементы.ГруппаНетДоступныхВидовОплат.Видимость = Ложь;
		Если ЭлементыДерева[0].ПолучитьЭлементы().Количество() > 0 Тогда
			ЭлементыДерева.Вставить(0).Представление = "Заглушка";
		КонецЕсли;
	Иначе
		Элементы.ГруппаОплата.Видимость = Ложь;
		Элементы.ГруппаНетДоступныхВидовОплат.Видимость = Истина;
	КонецЕсли;
	
	СоздатьДинаимческуюТаблицуДоступныхВидовОплат();
	
КонецПроцедуры

&НаСервере
// Процедура - Построить динаимческую таблицу задолженностей.
//
Процедура СоздатьДинаимческуюТаблицуДоступныхВидовОплат()
	
	УдалитьДинаимеческиеЭлементыТаблицыДоступныхВидовОплат();
	
	ОсновнаяГруппа = ВидыОплатРодительскаяГруппаФормы();
	
	Для Каждого ВидОплатыВрУр ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл
		
		НомерСтрокиВрУр = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Индекс(ВидОплатыВрУр);	
		
		Если ВидОплатыВрУр.ПолучитьЭлементы().Количество() = 0 Тогда
			
			Если НомерСтрокиВрУр = 0 Тогда
				
				Если ВидОплатыВрУр.Представление = "Заглушка" Тогда
					
					Элементы.ГруппаВидыОплатЗаголовокГруппировки_0.Видимость = Ложь;
					Продолжить;
					
				Иначе
					
					Элементы.ГруппаВидыОплатЗаголовокГруппировки_0.Видимость = Истина;
					
				КонецЕсли;
				
				Если ВидОплатыВрУр.Внесено = 0 Тогда
					
					Элементы.ДекорацияНаименованиеГруппировкиВидовОплат_0.Видимость = Ложь;
					Элементы.КнопкаВидыОплатаНаименованиеСтрока_0.Заголовок         = ВидОплатыВрУр.Представление;
					Элементы.ПолеВидыОплатВводСуммыСтрока_0.Видимость               = Ложь;
					Элементы.КнопкаВидыОплатПредставлениеСуммыСтрока_0.Видимость    = Ложь;
					Элементы.КнопкаВидыОплатПрименитьеСуммуСтрока_0.Видимость       = Ложь;
					Элементы.КнопкаВидыОплатУдалитьСуммуСтрока_0.Видимость          = Ложь;
					Элементы.ПолеВыбораВидаЛицевогоСчета_0.Видимость                = Ложь;
					
				КонецЕсли;
				
			Иначе
				
				СоздатьСтрокуДинаимческойТаблицыДоступныхВидовОплат(
				ОсновнаяГруппа,
				ВидОплатыВрУр.ПолучитьИдентификатор(),
				НомерСтрокиВрУр, 
				-1,
				ВидОплатыВрУр.Представление,
				Неопределено);
				
			КонецЕсли;
			
		Иначе
						
			ГруппаГруппировкиСтрок = СоздатьГруппировкуВидовОплат(ОсновнаяГруппа, НомерСтрокиВрУр, ВидОплатыВрУр.Представление);
						
			Для Каждого ВидОплатыНижУр ИЗ ВидОплатыВрУр.ПолучитьЭлементы() Цикл
				
				НомерСтрокиНижУр = ВидОплатыВрУр.ПолучитьЭлементы().Индекс(ВидОплатыНижУр);					
				
				Картинка = ?(ЗначениеЗаполнено(ВидОплатыНижУр.ЭквайринговыйТерминал), ПолучитьКартинкуСоответствияТипуШлюза(ВидОплатыНижУр.ЭквайринговыйТерминал), Неопределено);
				
				
				СоздатьСтрокуДинаимческойТаблицыДоступныхВидовОплат(
				ГруппаГруппировкиСтрок,
				ВидОплатыНижУр.ПолучитьИдентификатор(),
				"" + НомерСтрокиВрУр,
				НомерСтрокиНижУр,
				ВидОплатыНижУр.Представление,
				ВидОплатыВрУр.Представление,
				Картинка);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция - Создать группировку видов оплат.
// 
Функция СоздатьГруппировкуВидовОплат(ОсновнаяГруппа, НомерСтрокиДан, ЗаголовокГруппы)
	
	ГруппаГруппировкиВерхняя = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатЗаголовокГруппировки_0,
	НомерСтрокиДан,
	ОсновнаяГруппа);
	
	ДекорацияЗаголовка =  УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ДекорацияНаименованиеГруппировкиВидовОплат_0, 
	НомерСтрокиДан,
	Тип("ДекорацияФормы"),
	ГруппаГруппировкиВерхняя);
	
	ДекорацияЗаголовка.Заголовок = ЗаголовокГруппы;
	ДекорацияЗаголовка.Видимость = Истина;
	
	ГруппаГруппировкиНижняя = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатГруппировка_0,
	НомерСтрокиДан,
	ГруппаГруппировкиВерхняя);
	
	Возврат ГруппаГруппировкиНижняя;
	
КонецФункции

&НаСервере
// Процедура - Удалить динаимеческие элементы состав занятия.
//
Процедура УдалитьДинаимеческиеЭлементыТаблицыДоступныхВидовОплат()
	
	ОснованаяГруппа = ВидыОплатРодительскаяГруппаФормы();
	
	Индекс = ОснованаяГруппа.ПодчиненныеЭлементы.Количество() - 1;
	Пока Индекс > 0  Цикл
		
		Элементы.Удалить(ОснованаяГруппа.ПодчиненныеЭлементы[Индекс]);		
		Индекс = Индекс - 1;
		
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
// Функция - Виды оплат родительская группа формы.
// 
Функция ВидыОплатРодительскаяГруппаФормы()
	
	Возврат Элементы.ГруппаДинамическаяТабДоступныхВидовОплат;
	
