// Процедура - Формирование чека ФРПосле оплаты
// 
// Параметры:
//  МассивДокОплаты	 - 	 - 
//  МассивОплат		 - 	 - 
// 
Функция ФормированиеЧекаФРФиксацияОплаты(ОписаниеОшибки, МассивДокументовОплаты = Неопределено, БезОплаты = Ложь)
	
	Если МассивДокументовОплаты = Неопределено Тогда
		МассивДокументовОплаты = Новый Массив;
	КонецЕсли;
	
	ОперацияПроведенаУспешно = Ложь;
	ДанныеФискальныхЧеков    = Неопределено;
	
	Если ИспользоватьСтаруюСистемуФормированияДляФРдляККТ(ЭтотОбъект.ТекущаяКасса) = Ложь Тогда
		ФормированиеЧека = ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляККТ(, МассивДокументовОплаты);
	Иначе
		ФормированиеЧека = ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляФР(МассивДокументовОплаты);
	КонецЕсли;
	
	Если ФормированиеЧека.Результат Тогда
		
		ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ЭтотОбъект.ТекущаяКасса);
		
		Если ИдентификаторУстройстваФР <> Неопределено Тогда
						
			Если ФормированиеЧека.Свойство("ФискальныйЧек") Тогда
				
				Контекст = Новый Структура();
				Контекст.Вставить("ТипЧека", Истина);	
				
				Оповещение            = Новый ОписаниеОповещения("ПробитьЧекЗавершение"            , ЭтотОбъект, Контекст);
				ПослеОткрытияЧека     = Новый ОписаниеОповещения("ПечатьЧека_ПослеОткрытияЧека"    , ЭтотОбъект, Контекст);
				ПослеОшибкиПечатиЧека = Новый ОписаниеОповещения("ПечатьЧека_ПослеОшибкиПечатиЧека", ЭтотОбъект, Контекст);
				
				ОбщиеПараметры = ФормированиеЧека.ФискальныйЧек;
				МенеджерОборудованияКлиент.НачатьФискализациюЧекаНаФискальномУстройстве(Оповещение, УникальныйИдентификатор, ОбщиеПараметры, ИдентификаторУстройстваФР, , ПослеОткрытияЧека, ПослеОшибкиПечатиЧека);		
				
				Если ЗначениеЗаполнено(ОшибкаПечатиЧека) Тогда
					Возврат Неопределено; 
				КонецЕсли;
				
			КонецЕсли;	
			
			// Если был фискальный чек, то нефискальный чек напечатается после завершения фискального.
			Если ФормированиеЧека.Свойство("НефискальныйЧек") 
				И НЕ ЗначениеЗаполнено(ОшибкаПечатиЧека) Тогда
				
				ТекстЧека  = ФормированиеЧека.НефискальныйЧек;
				Контекст   = Новый Структура();
				Контекст.Вставить("ТипЧека", Ложь);
				Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект, Контекст);
				МенеджерОборудованияКлиент.НачатьПечатьТекста(Оповещение, УникальныйИдентификатор, ТекстЧека, ИдентификаторУстройстваФР);
				
				Если ЗначениеЗаполнено(ОшибкаПечатиЧека) Тогда
					Возврат Неопределено; 
				КонецЕсли;   
				
			КонецЕсли;			
			
		Иначе
			
			ОписаниеОшибки = НСтр("ru = 'Ошибка получения идентификатора устройства.' ; en = 'Error getting the device ID'");// ФормированиеЧека.ОписаниеОшибки;
			ТекстСообщения = НСтр("ru='При проведение оплаты произошла ошибка."
			"Дополнительное описание: %ДополнительноеОписание%';en='With holding payment happened mistake. Additional description: %ДополнительноеОписание%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			
			Возврат Неопределено;
			
		КонецЕсли;
		
	Иначе
		
		ОписаниеОшибки = ФормированиеЧека.ОписаниеОшибки;
		ТекстСообщения = НСтр("ru='При проведение оплаты произошла ошибка."
		"Дополнительное описание: %ДополнительноеОписание%';en='With holding payment happened mistake. Additional description: %ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);			
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ДрайверОборудования = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ИдентификаторУстройстваФР, "ДрайверОборудования"); 
	
	// Печать копии чека(не фискальный)
	Если ЗначениеЗаполнено(НомерФискальногоЧека) 
		И ПечатьКопииЧека = Истина Тогда
			
		ПечатьКопииЧека(ИдентификаторУстройстваФР);
		
	КонецЕсли;
	
	ДанныеВозврата = Новый Структура;  	
	ДанныеВозврата.Вставить("НомерФискальногоЧека"			, ЭтотОбъект.НомерФискальногоЧека);
	ДанныеВозврата.Вставить("НомерНеФискальногоЧека"		, ЭтотОбъект.НомерНефискальногоЧека);
	ДанныеВозврата.Вставить("НомерВходящегоДокумента"		, ЭтотОбъект.НомерВходящегоДокумента);
	ДанныеВозврата.Вставить("ИдентификаторФискальнойЗаписи"	, ЭтотОбъект.ИдентификаторФискальнойЗаписи);
		
	НомерФискальногоЧека			= 0;
	НомерНефискальногоЧека			= 0;
	ИдентификаторФискальнойЗаписи	= Неопределено;
	ОшибкаПечатиЧека				= "";

	Возврат ДанныеВозврата;
	
КонецФункции

#Область ОбработчикиПроцессаПечатиЧека

&НаКлиенте
// Процедура, обработчик описания оповещения.
// 
Процедура ПечатьЧека_ПослеОткрытияЧека(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
	
	ШапкаЧека = ПараметрыВыполнения.ВходныеПараметры;
	
	Если ПараметрыВыполнения.НомерСмены <> 0 Тогда
		ШапкаЧека.НомерСмены = ПараметрыВыполнения.НомерСмены;
	КонецЕсли;
	
	Если ПараметрыВыполнения.НомерЧека <> 0 Тогда
		ШапкаЧека.НомерЧека = ПараметрыВыполнения.НомерЧека;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ПараметрыВыполнения.ОповещениеПродолжения, ПараметрыВыполнения);
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения.
// 
Процедура ПечатьЧека_ПослеОшибкиПечатиЧека(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт

	ШапкаЧека = ПараметрыВыполнения.ВходныеПараметры;
	ШапкаЧека.НомерЧека = ШапкаЧека.НомерЧека + 1000000;

КонецПроцедуры

&НаКлиенте
// Процедура, завершение пробития чека на ФР.
// 
Процедура ПробитьЧекЗавершение(РезультатВыполнения, Параметры) Экспорт
	
	Если РезультатВыполнения.Результат Тогда
		
		// Установить полученное значение номера чека реквизиту документа.
		Если РезультатВыполнения.ВыходныеПараметры <> Неопределено Тогда
			Если Параметры.ТипЧека Тогда
				Если РезультатВыполнения.Свойство("ИдентификаторУстройства")
					И ЗначениеЗаполнено(РезультатВыполнения.ИдентификаторУстройства)
					И ТипЗнч(РезультатВыполнения.ИдентификаторУстройства) = Тип("СправочникСсылка.ПодключаемоеОборудование")
					И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(РезультатВыполнения.ИдентификаторУстройства, "ТипОборудования")
						= ПредопределенноеЗначение("Перечисление.ТипыПодключаемогоОборудования.ККТ") Тогда
					
					НомерФискальногоЧека = РезультатВыполнения.ВыходныеПараметры[1];
				Иначе
					НомерФискальногоЧека = РезультатВыполнения.ДополнительныеПараметры.НомерЧека;	
				КонецЕсли;
			Иначе
				НомерНефискальногоЧека = РезультатВыполнения.ВыходныеПараметры[1];
			КонецЕсли;	
			Если РезультатВыполнения.ВыходныеПараметры.Количество() = 8 Тогда
				НомерВходящегоДокумента = РезультатВыполнения.ВыходныеПараметры[7];	
			КонецЕсли;  
			// Если ФискальныеОперации не был записан - произошла ошибка при записи.
			Если РезультатВыполнения.ВыходныеПараметры.Количество() > 8 Тогда
				ПараметрыФискализации = РезультатВыполнения.ВыходныеПараметры[8];
				ИдентификаторФискальнойЗаписи = ПараметрыФискализации.ИдентификаторФискальнойЗаписи;
				Если НЕ ПараметрыФискализации.ОперацияЗаписана Тогда
					МенеджерОборудованияВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации);
				КонецЕсли;
				Если НЕ ПустаяСтрока(ПараметрыФискализации.ЧекКоррекцииСторно)
					И НЕ ПараметрыФискализации.ЧекКоррекцииСторно.ОперацияЗаписана Тогда
					МенеджерОборудованияВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации.ЧекКоррекцииСторно);
				КонецЕсли;
			КонецЕсли;

		КонецЕсли;
		
	Иначе 		
		
		ТекстСообщения = НСтр("ru='При печати чека произошла ошибка.
								|Чек не напечатан на фискальном регистраторе.
								|Дополнительное описание:
								|%ДополнительноеОписание%';en='With print check happened mistake.
								|Check not printedby on fiscal registrar.
								|Additional description:
								|%ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", РезультатВыполнения.ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОшибкаПечатиЧека = РезультатВыполнения.ОписаниеОшибки;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПодготовкаДанныхЧека

&НаСервере
// Функция - Подготовить параметры чека на печать.
// 
// Возвращаемое значение:
//   - 
//
Функция ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляККТ(БезОплаты = Ложь, МассивДокументовОплаты = Неопределено)
	
	Если МассивДокументовОплаты = Неопределено Тогда
		МассивДокументовОплаты = Новый Массив;	
	КонецЕсли;	
	
	ВсеДокументы = ПолучитьДокументыЗадолженностиСервер(Истина);
	ВидНалога    = ?(ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("ВидНалога"		, ВсеДокументы[0].Метаданные()), ВсеДокументы[0].ВидНалога, Неопределено);
	Организация  = ?(ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Организация"	, ВсеДокументы[0].Метаданные()), ВсеДокументы[0].Организация, ВсеДокументы[0].СтруктурнаяЕдиница.Организация);

	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();	
	
	ПараметрыЧека.ВидОперации             = ЭтотОбъект.ВидОперации;
	ПараметрыЧека.СтруктурнаяЕдиница      = СтруктурнаяЕдиница;
	ПараметрыЧека.Организация             = Организация;
	ПараметрыЧека.Сотрудник               = Сотрудник;
	ПараметрыЧека.Клиент                  = Контрагент;
	ПараметрыЧека.Дата                    = ДатаПродажи;
	ПараметрыЧека.Касса                   = ТекущаяКасса;
	ПараметрыЧека.Количество              = 1;	
	ПараметрыЧека.СуммаОплачено           = ?(БезОплаты = Ложь, ЭтотОбъект.ОплатаВнесено - ЭтотОбъект.ОплатаСдача, 0);
	ПараметрыЧека.ВыводитьЧекНаБумагу     = ЭтотОбъект.ЧекПечатать;
    ПараметрыЧека.ЭлектроннаяПочтаКлиента = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту, ЭтотОбъект.ЧекККТКонтактыКлиентаПочта  , Неопределено);
	ПараметрыЧека.НомерТелефонаКлиента    = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон, ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон, Неопределено);

	ПараметрыЧека.МассивПараметровТовары  = ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ(); 		
	
	АвансПоДокументамОплаты = 0; 
	ПараметрыЧека.МассивПараметровОплаты  = ?(БезОплаты = Ложь, ПолучитьМассивОплатФискальногоЧекаОплатыПродажи(АвансПоДокументамОплаты), Неопределено);
	// включаем только авансы фактической оплаты (убраны предоплаты)
		
	СуммаКОплатеПоТаблицеТоваров = 0;
	Для Каждого ЭлементМ Из ПараметрыЧека.МассивПараметровТовары Цикл
		 СуммаКОплатеПоТаблицеТоваров = СуммаКОплатеПоТаблицеТоваров + ЭлементМ.СтоимостьСоСкидкой;
	 КонецЦикла;
	 
	 ПараметрыЧека.СуммаКОплате = СуммаКОплатеПоТаблицеТоваров;      
	
	Если АвансПоДокументамОплаты > 0 Тогда
		ПараметрыЧека.МассивПараметровОплаты.Вставить(0, Новый Структура("ТипОплаты,Сумма", Перечисления.ТипыДенежныхСредств.Аванс, АвансПоДокументамОплаты));	
	КонецЕсли;

	ПараметрыЧека.ВидНалога              = ВидНалога; 
	ПараметрыЧека.ТипЧека                = ?(ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа") = Истина, 0, 1);
	
	ПараметрыЧека.МассивДокументовОснований = ОбщегоНазначенияСтоматология.ДобавитьВМассив(МассивДокументовОплаты, ВсеДокументы, Истина);
	
	// Если массив оплат пуст, возвращаем структуру без фискальных и нефискальных чеков.
	// Чек могут оплатить на счет в "1С:Отель", в таком случае ничего пробивать не надо.
	Если НЕ ПараметрыЧека.МассивПараметровОплаты = Неопределено
		И ПараметрыЧека.МассивПараметровОплаты.Количество() = 0 Тогда
		ФормированиеЧека = Новый Структура("Результат", Истина);		
	Иначе	
		ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека);	
	КонецЕсли;
	
	Возврат ФормированиеЧека;
	
КонецФункции

&НаСервере
// Функция, возвращает массив товаров на печать
//
Функция ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ()
	
	МассивТоваров = Новый Массив;
			
	Для Каждого СтрокаТЧ Из ТаблицаЗадолженностей Цикл
		
		Если Не СтрокаТЧ.ПризнакВыбора Тогда
			Продолжить;
		КонецЕсли;	
		          				
		Если ТипЗнч(СтрокаТЧ.ДокументЗадолженности) = Тип("ДокументСсылка.НарядЗаказ")
			ИЛИ ТипЗнч(СтрокаТЧ.ДокументЗадолженности) = Тип("ДокументСсылка.ПланЛечения") Тогда
			// Это Аванс.	
			
			СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
			
			СтрокаТовара.Номенклатура           = Неопределено;
			СтрокаТовара.Наименование           = НСтр("ru = 'Аванс от:'") + " " + Контрагент;
			СтрокаТовара.СтоимостьБезСкидки     = ОплатаВнесено;
			СтрокаТовара.СуммаСкидки            = 0;
			СтрокаТовара.СтоимостьСоСкидкой     = ОплатаВнесено;
			СтрокаТовара.Количество             = 1;
			СтрокаТовара.СтавкаНДС              = СтавкаНДСОрганизацииАванс;
			СтрокаТовара.СуммаНДС               = Ценообразование.РассчитатьСуммуНДС(ОплатаВнесено, СтавкаНДСОрганизацииАванс);
			СтрокаТовара.НомерСекции            = 2;
			СтрокаТовара.Штрихкод               = null;
			СтрокаТовара.СуммаОплачено			= ОплатаВнесено;
			СтрокаТовара.ЭтоОплатаКредита       = Ложь;  
		
			МассивТоваров.Добавить(СтрокаТовара);
			
		Иначе
			
			Если ПолучитьСуммуОплатыПоДокументуЗадолженности(СтрокаТЧ.ДокументЗадолженности) = 0 Тогда
				Продолжить;
			КонецЕсли;

			МассивТоваровДокумента = Обработки.ПомощникПроведенияОплаты.ПолучитьМассивПараметровТоваровККТ(
																			СтрокаТЧ.ДокументЗадолженности,
																			СтрокаТЧ.Оплачено,
																			ПолучитьСуммуОплатыПоДокументуЗадолженности(СтрокаТЧ.ДокументЗадолженности),
																			ЭтотОбъект.ТекущаяКасса);
																			
			ОбщегоНазначенияСтоматология.ДобавитьВМассив(МассивТоваров, МассивТоваровДокумента);																			
		КонецЕсли;
		
	КонецЦикла;
	
	// УпорядочитьПоДате(МассивТоваров);
	
	Возврат МассивТоваров;
	
КонецФункции

// Функция - Подготовить параметры чека на печать.
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляФР(МассивДокументовОплаты = Неопределено)
	
	Если МассивДокументовОплаты = Неопределено Тогда
		МассивДокументовОплаты = Новый Массив;
	КонецЕсли;
	
	ВсеДокументы = ПолучитьДокументыЗадолженностиСервер(Истина);
	ВидНалога    = ?(ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("ВидНалога"		, ВсеДокументы[0].Метаданные()), ВсеДокументы[0].ВидНалога, Неопределено);
	Организация  = ?(ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Организация"	, ВсеДокументы[0].Метаданные()), ВсеДокументы[0].Организация, ВсеДокументы[0].СтруктурнаяЕдиница.Организация);

	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	
	ПараметрыЧека.ВидОперации            = ЭтотОбъект.ВидОперации;
	ПараметрыЧека.СтруктурнаяЕдиница     = СтруктурнаяЕдиница;
	ПараметрыЧека.Организация            = Организация;
	ПараметрыЧека.Сотрудник              = Сотрудник;
	ПараметрыЧека.Клиент                 = Контрагент;
	ПараметрыЧека.Дата                   = ДатаПродажи;
	ПараметрыЧека.Касса                  = ТекущаяКасса;
	ПараметрыЧека.Количество             = 1;
	// ПараметрыЧека.СуммаКОплате           = ЭтотОбъект.ОплатаСумма;
	ПараметрыЧека.СуммаОплачено          = ЭтотОбъект.ОплатаВнесено - ЭтотОбъект.ОплатаСдача;
	ПараметрыЧека.СтоимостьБезСкидки     = ЭтотОбъект.ОплатаВнесено - ЭтотОбъект.ОплатаСдача;
	
	// ККТ-ые пар-ы
	ПараметрыЧека.ВидНалога              = ВидНалога; 	
	ПараметрыЧека.ВыводитьЧекНаБумагу    = Этотобъект.ЧекПечатать;
    ПараметрыЧека.ЭлектроннаяПочтаКлиента = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту, ЭтотОбъект.ЧекККТКонтактыКлиентаПочта, Неопределено);
	ПараметрыЧека.НомерТелефонаКлиента    = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон, ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон, Неопределено);

	ПараметрыЧека.МассивПараметровТовары = ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляФР();
	АвансПоДокументамОплаты = 0;
	ПараметрыЧека.МассивПараметровОплаты = ПолучитьМассивОплатФискальногоЧекаОплатыПродажи(АвансПоДокументамОплаты);	
	
	Если АвансПоДокументамОплаты > 0 Тогда
		ПараметрыЧека.МассивПараметровОплаты.Вставить(0, Новый Структура("ТипОплаты,Сумма", Перечисления.ТипыДенежныхСредств.Аванс, АвансПоДокументамОплаты));	
	КонецЕсли;   
	
	ПараметрыЧека.СуммаКОплате           = ЭтотОбъект.ОплатаВнесено - ЭтотОбъект.ОплатаСдача;
	
	Если ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа")
		или ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтКлиента") Тогда    		
		ПараметрыЧека.Наименование = НСтр("ru='Оплата от:';en='Payment from:'") + " " + Контрагент;
		ПараметрыЧека.ТипЧека = 0;		
	Иначе		
		ПараметрыЧека.Наименование = НСтр("ru='Возврат оплаты:';en='Refund payment:'") + " " + Контрагент;	
		ПараметрыЧека.ТипЧека = 1;
	КонецЕсли;	
	
	ПараметрыЧека.МассивДокументовОснований = ОбщегоНазначенияСтоматология.ДобавитьВМассив(МассивДокументовОплаты, ВсеДокументы, Истина);
	
   	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоИНеФискальногоЧекаФР(ПараметрыЧека);	

	Возврат ФормированиеЧека;
	
КонецФункции

&НаСервере
// Функция, возвращает массив товаров на печать
//
Функция ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляФР()
		
	МассивТоваров = Новый Массив;
	Для Каждого СтрокаТЧ Из ТаблицаЗадолженностей Цикл
		
		ДокументЗадолженности = СтрокаТЧ.ДокументЗадолженности; 		
		
		Организация      = ?(ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Организация", ДокументЗадолженности.Метаданные()),
								ДокументЗадолженности.Организация,
								ДокументЗадолженности.СтруктурнаяЕдиница.Организация);
	    СуммаВключаетНДС = Истина; 
		
		Если Не СтрокаТЧ.ПризнакВыбора Тогда
			Продолжить;
		КонецЕсли;	
		
		Если ПолучитьСуммуОплатыПоДокументуЗадолженности(СтрокаТЧ.ДокументЗадолженности) = 0 Тогда
			Продолжить;
		КонецЕсли; 
					
			СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
			
			СтрокаТовара.Номенклатура           = Справочники.Номенклатура.ПустаяСсылка();
			СтрокаТовара.Наименование           = "" + ДокументЗадолженности.Метаданные().Имя + " №:" 
													+ ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(ДокументЗадолженности.Номер, СтруктурнаяЕдиница.Организация.Префикс)
													+ НСтр("ru = ' - Оплата'; en = ' -Payment'");
			СтрокаТовара.СтоимостьБезСкидки     = ОплатаВнесено - ОплатаСдача; // ОплаченоПоДок - СтрокаТЧ.Оплачено;
			СтрокаТовара.СтоимостьСоСкидкой     = ОплатаВнесено - ОплатаСдача; // ОплаченоПоДок - СтрокаТЧ.Оплачено;
			СтрокаТовара.СуммаСкидки            = 0;
			СтрокаТовара.Количество             = 1;
			СтрокаТовара.ЭтоОплатаКредита       = Ложь;// ВыполняетсяПостоплатаРеализации(ДокументЗадолженности, СтрокаТЧ.Оплачено = 0);
			СтрокаТовара.СуммаВключаетНДС		= СуммаВключаетНДС;
			
			Если ЗначениеЗаполнено(Организация) Тогда
				СтрокаТовара.СтавкаНДС			= ?(Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая, Организация.СтавкаНДС, Перечисления.СтавкиНДС.БезНДС);
				СтрокаТовара.СуммаНДС  			= Цел(Ценообразование.РассчитатьСуммуНДС(СтрокаТовара.СтоимостьБезСкидки , СтрокаТовара.СтавкаНДС));
			КонецЕсли;
			
			МассивТоваров.Добавить(СтрокаТовара);	
		
	КонецЦикла;
	
	Возврат МассивТоваров;
	
КонецФункции

// Функция - Получить массив оплат на печать
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция ПолучитьМассивОплатФискальногоЧекаОплатыПродажи(Аванс = 0)
	
	МассивСтрокДереваОплата = ПолучитьСтрокиСВнесеннойОплатойСервер();
	
	МассивОплат = Новый Массив;		
	Для Каждого СтрокаТ ИЗ МассивСтрокДереваОплата Цикл	
		
		Если СтрокаТ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.БонусныйСчет Тогда
			Продолжить;
		КонецЕсли;

		Если СтрокаТ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет  // свернуть все авансы
			ИЛИ СтрокаТ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс
			ИЛИ СтрокаТ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
			Аванс = Аванс + СтрокаТ.ОплачиваемаяСумма;
		Иначе
			ПараметрыТипаОплаты = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиПлатежаЧека();
			ПараметрыТипаОплаты.ТипОплаты = СтрокаТ.ТипДенежныхСредств;
			ПараметрыТипаОплаты.Сумма     = СтрокаТ.ОплачиваемаяСумма;		
			МассивОплат.Добавить(ПараметрыТипаОплаты);
		КонецЕсли;
		
	КонецЦикла;	

	Возврат МассивОплат;	
КонецФункции

// Функция - Получить сумму оплаты по документу задолженности
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция ПолучитьСуммуОплатыПоДокументуЗадолженности(ДокументЗадолженности)
	
	Если ЭтотОбъект.РасшифровкаОплатыПоДокументам <> Неопределено Тогда
		
	    СтрокаОплаты = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ЭтотОбъект.РасшифровкаОплатыПоДокументам,"ДокументЗадолженности",ДокументЗадолженности);
		
		Если СтрокаОплаты <> Неопределено Тогда
			Возврат СтрокаОплаты.СуммаОплаты;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

#КонецОбласти

// Процедура - Печать копии чека
// 
&НаКлиенте
Процедура ПечатьКопииЧека(ИдентификаторУстройстваФР)
	
	ФормированиеЧека = ПодготовитьПараметрыНеФискальногоЧекаНаПечать();
	
	ТекстЧека  = ФормированиеЧека.ДанныеЧека;
	Контекст   = Новый Структура();
	Контекст.Вставить("ТипЧека", Ложь);
	Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект, Контекст);
	
	Для а = 1 По ПечатьКопииЧекаКоличество Цикл	
		МенеджерОборудованияКлиент.НачатьПечатьТекста(Оповещение, УникальныйИдентификатор, ТекстЧека, ИдентификаторУстройстваФР);			
	КонецЦикла;
	
КонецПроцедуры

// Функция - Подготовить параметры чека на печать
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция ПодготовитьПараметрыНеФискальногоЧекаНаПечать()
	
	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	
	ПараметрыЧека.СтруктурнаяЕдиница     = СтруктурнаяЕдиница;
	ПараметрыЧека.Организация            = Организация;
	ПараметрыЧека.Сотрудник              = Сотрудник;
	ПараметрыЧека.Клиент                 = Контрагент;
	ПараметрыЧека.Дата                   = ДатаПродажи;
	ПараметрыЧека.Количество             = 1;
	ПараметрыЧека.Касса                  = ТекущаяКасса;	
	ПараметрыЧека.МассивПараметровОплаты = ПолучитьМассивОплатФискальногоЧекаОплатыПродажи();	
	ПараметрыЧека.МассивПараметровТовары = ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ(); 
	ПараметрыЧека.ТипЧека                = ?(ЭтотОбъект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа") = Истина, 0, 1);
		
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияНеФискальногоЧека(ПараметрыЧека);	

	Возврат ФормированиеЧека;
	
КонецФункции

#КонецОбласти

#Область ПечатьПречека

&НаКлиенте
// Обработчик команды печати пречека
Процедура Пречек(Команда)
	
	МассивДокументов = Новый Массив();
	Для Каждого СтрокаТЧ из ТаблицаЗадолженностей Цикл
		Если СтрокаТЧ.ПризнакВыбора Тогда
			МассивДокументов.Добавить(СтрокаТЧ.ДокументЗадолженности);
		КонецЕсли;
	КонецЦикла;

	МассивСтрокДереваОплата = ПолучитьСтрокиСВнесеннойОплатой();
	
	МассивОплат = Новый Массив();
	Для Каждого СтрокаТЧ Из МассивСтрокДереваОплата Цикл
		
		СтруктураОплат = Новый Структура("ТипДенежныхРедств, Внесено", СтрокаТЧ.ТипДенежныхСредств, СтрокаТЧ.ОплачиваемаяСумма);
		МассивОплат.Добавить(СтруктураОплат);   
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(МассивДокументов) Тогда
		МенеджерОборудованияКлиент.ПечатьПречека(МассивДокументов, МассивОплат, ?(Команда = "ПриПробитииЧека", Истина, Ложь));
	Иначе
		ПоказатьОповещениеПользователя("Печать пречека",, "Не выбраны документы для печати!", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);
	КонецЕсли;
	
КонецПроцедуры  

#КонецОбласти

#КонецОбласти

