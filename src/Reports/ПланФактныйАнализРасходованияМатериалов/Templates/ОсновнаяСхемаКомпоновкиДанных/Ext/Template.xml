		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПриемМатериалы.Ссылка КАК ДокументПродажи,
	ПриемМатериалы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ПриемМатериалы.Склад КАК Склад,
	ПриемМатериалы.Услуга КАК Услуга,
	ПриемМатериалы.Материал КАК Материал,
	ПриемМатериалы.Партия КАК Партия,
	ПриемМатериалы.Сотрудник КАК Сотрудник,
	ПриемМатериалы.Ссылка.Контрагент КАК Пациент,
	ПриемМатериалы.Материал.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ЧАС) КАК ПериодЧас,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ДЕНЬ) КАК ПериодДень,
	ДЕНЬНЕДЕЛИ(ПриемМатериалы.Ссылка.Дата) КАК ПериодНеделя,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, КВАРТАЛ) КАК ПериодКвартал,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ПОЛУГОДИЕ) КАК ПериодПолугодие,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ГОД) КАК ПериодГод,
	СУММА(ПриемМатериалы.Количество) КАК КоличествоФакт,
	МатериалыПлан.КоличествоПлан КАК КоличествоПлан
ИЗ
	Документ.Прием.Материалы КАК ПриемМатериалы
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ПродажиОбороты.Номенклатура КАК Услуга,
			НормыСписанияМатериалов.Материал КАК Материал,
			ПродажиОбороты.ДокументПродажи КАК ДокументПродажи,
			ПродажиОбороты.КоличествоОборот * (НормыСписанияМатериалов.Количество * ЕСТЬNULL(НормыСписанияМатериалов.Упаковка.Коэффициент, 1)) КАК КоличествоПлан
		ИЗ
			РегистрНакопления.Продажи.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Авто, ) КАК ПродажиОбороты
				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НормыСписанияМатериалов КАК НормыСписанияМатериалов
				ПО ПродажиОбороты.Номенклатура = НормыСписанияМатериалов.Номенклатура
		ГДЕ
			ПродажиОбороты.КоличествоОборот &gt; 0) КАК МатериалыПлан
		ПО ПриемМатериалы.Услуга = МатериалыПлан.Услуга
			И ПриемМатериалы.Материал = МатериалыПлан.Материал
			И ПриемМатериалы.Ссылка = МатериалыПлан.ДокументПродажи
ГДЕ
	ПриемМатериалы.Ссылка.Проведен = ИСТИНА
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
					ИЛИ &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ПриемМатериалы.Ссылка.Дата &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
					ИЛИ &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ПриемМатериалы.Ссылка.Дата &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}

СГРУППИРОВАТЬ ПО
	ПриемМатериалы.Ссылка,
	ПриемМатериалы.Ссылка.СтруктурнаяЕдиница,
	ПриемМатериалы.Склад,
	ПриемМатериалы.Услуга,
	ПриемМатериалы.Материал,
	ПриемМатериалы.Партия,
	ПриемМатериалы.Сотрудник,
	ПриемМатериалы.Ссылка.Контрагент,
	ПриемМатериалы.Материал.ЕдиницаИзмерения,
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ЧАС),
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ДЕНЬ),
	ДЕНЬНЕДЕЛИ(ПриемМатериалы.Ссылка.Дата),
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, МЕСЯЦ),
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, КВАРТАЛ),
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ПОЛУГОДИЕ),
	НАЧАЛОПЕРИОДА(ПриемМатериалы.Ссылка.Дата, ГОД),
	МатериалыПлан.КоличествоПлан</query>
	</dataSet>
