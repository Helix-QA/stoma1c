
#Область СлужебныйПрограммныйИнтерфейс

#Область РаботаСДинамическимиМенюФормы

// Функция - Имя меню из элемента меню
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИмяМенюИзЭлементаМеню(ИмяЭлементаМеню) Экспорт	
	Возврат УправлениеИнтерфейсамиСервер.ИмяДинамическогоМенюФормыИзЭлемента(ИмяЭлементаМеню);
КонецФункции
																			
// Функция - Данные привязанные к элементу меню
//
// Параметры:
//  ИмяМеню			 - 	 - 
//  ИмяЭлементаМеню	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДанныеПривязанныеКЭлементуДинамическогоМеню(Форма, ИмяЭлементаМеню) Экспорт	
	Возврат УправлениеИнтерфейсамиСервер.ДанныеПривязанныеКЭлементуДинамическогоМеню(Форма, ИмяЭлементаМеню);	
КонецФункции

// Функция - Это элемент быстрого выбора
//
// Параметры:
//  ИмяЭлементаМеню	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЭтоЭлементБыстрогоВыбора(ИмяЭлементаМеню) Экспорт
    Возврат СтрНайти(ИмяЭлементаМеню, "_ID_Еще") = 0;	
КонецФункции

// Функция - Имя реквизита по имени элемента
//
// Параметры:
//  ИмяЭлемента	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИмяРеквизитаДанныхПоИмениЭлемента(ИмяЭлемента) Экспорт
	Возврат СтрЗаменить(ИмяЭлемента, "Поле_", "");
КонецФункции

// Функция - Имя реквизита представления по имени элемента
//
// Параметры:
//  ИмяЭлемента	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИмяРеквизитаПредставленияПоИмениЭлемента(ИмяЭлемента) Экспорт
	Возврат СтрЗаменить(ИмяЭлемента, "Поле_", "") + "_Представление";
КонецФункции

// Процедура - Обработчик элемента начало выбора
//
// Параметры:
//  Форма				 - 	 - 
//  Элемент				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработчикЭлементаНачалоВыбора(Форма, Элемент, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	ТипПериода           = Сред(Элемент.Имя, СтрНайти(Элемент.Имя, "_Тип_") + 5);
	ТипПериода           = Лев(ТипПериода, СтрНайти(ТипПериода, "_") - 1);
	
	НачалоПериода = ТекущаяДата();
	
	Если НачалоПериода = '00010101' тогда
		НачалоПериода = ФункцииОтчетовКлиентСервер.НачалоПериодаОтчета("Перечисление.ДоступныеПериодыОтчета.День", ОбщегоНазначенияКлиент.ДатаСеанса());
	КонецЕсли;
	
	Если ТипПериода = "ВыборПериодаДень" Тогда
		ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День");
	ИначеЕсли ТипПериода = "ВыборПериодаНеделя" Тогда
		ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Неделя");
	ИначеЕсли ТипПериода = "ВыборПериодаМесяц" Тогда
		ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Месяц");
	КонецЕсли;
	
	// Выбор периода из выпадающего списка.
	РезультатВыбора = ВыбратьПериодИзВыпадающегоСписка(Форма, Элемент, ВидПериода, НачалоПериода, ВариантСтандартногоПериода.ПроизвольныйПериод, Неопределено);
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяДата = ФункцииОтчетовКлиентСервер.НачалоПериодаОтчета(ВидПериода, РезультатВыбора.Значение);
	Если ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.День") Тогда
		Форма[ИмяРеквизитаДанныхПоИмениЭлемента(Элемент.Имя)] = Новый СтандартныйПериод(ВыбраннаяДата, КонецДня(ВыбраннаяДата));  
	ИначеЕсли ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Неделя") Тогда                        
		Форма[ИмяРеквизитаДанныхПоИмениЭлемента(Элемент.Имя)] = Новый СтандартныйПериод(ВыбраннаяДата, КонецНедели(ВыбраннаяДата));
	ИначеЕсли ВидПериода = ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Месяц") Тогда
		Форма[ИмяРеквизитаДанныхПоИмениЭлемента(Элемент.Имя)] = Новый СтандартныйПериод(ВыбраннаяДата, КонецМесяца(ВыбраннаяДата));   
	КонецЕсли;   
	
	Форма[ИмяРеквизитаПредставленияПоИмениЭлемента(Элемент.Имя)] = РезультатВыбора.Представление;                                  
	
КонецПроцедуры

// Процедура - Обработчик кнопки переключения периода
//
// Параметры:
//  Форма	 - 	 - 
//  Команда	 - 	 - 
//
Процедура ОбработчикКнопкиПереключенияПериода(Форма, Команда) Экспорт
	
	ТипПериода           = Сред(Команда.Имя, СтрНайти(Команда.Имя, "_Тип_") + 5);
	ТипПериода           = Лев(ТипПериода, СтрНайти(ТипПериода, "_") - 1);
	
	ТипКнопки            = ?(СтрНайти(Команда.Имя, "КомандаНазад_ME") > 0, "Назад", "Вперед");
	
	ИмяРеквизитаДанных    = ?(ТипКнопки = "Назад",ИмяРеквизитаДанныхПоИмениЭлемента(СтрЗаменить(Команда.Имя, "КомандаНазад_","" )), ИмяРеквизитаДанныхПоИмениЭлемента(СтрЗаменить(Команда.Имя, "КомандаВперед_","" ))); 
    ИмяРеквизиатДанныПредставления = ИмяРеквизитаДанных + "_Представление";	
	ТекущийПериод        = Форма[ИмяРеквизитаДанных];
	
	Если ТипКнопки = "Назад" Тогда
		
		Если ТипПериода = "ВыборПериодаДень" Тогда
			
			Форма[ИмяРеквизитаДанных] = Новый СтандартныйПериод(ТекущийПериод.ДатаНачала - 86400, ТекущийПериод.ДатаОкончания - 86400);
 			
		ИначеЕсли ТипПериода = "ВыборПериодаНеделя" Тогда
			
			Форма[ИмяРеквизитаДанных] = Новый СтандартныйПериод(ТекущийПериод.ДатаНачала - 604800, ТекущийПериод.ДатаОкончания - 604800);

		ИначеЕсли ТипПериода = "ВыборПериодаМесяц" Тогда
			
			Форма[ИмяРеквизитаДанных] = Новый СтандартныйПериод(ДобавитьМесяц(ТекущийПериод.ДатаНачала, - 1), КонецМесяца(ДобавитьМесяц(ТекущийПериод.ДатаОкончания, -1)));

		КонецЕсли;		
	Иначе
		
		Если ТипПериода = "ВыборПериодаДень" Тогда
			
			Форма[ИмяРеквизитаДанных] = Новый СтандартныйПериод(ТекущийПериод.ДатаНачала + 86400, ТекущийПериод.ДатаОкончания + 86400);

		ИначеЕсли ТипПериода = "ВыборПериодаНеделя" Тогда
			
			Форма[ИмяРеквизитаДанных] = Новый СтандартныйПериод(ТекущийПериод.ДатаНачала + 604800, ТекущийПериод.ДатаОкончания + 604800);

		ИначеЕсли ТипПериода = "ВыборПериодаМесяц" Тогда
			
			Форма[ИмяРеквизитаДанных] = Новый СтандартныйПериод(ДобавитьМесяц(ТекущийПериод.ДатаНачала, 1), КонецМесяца(ДобавитьМесяц(ТекущийПериод.ДатаОкончания, 1)));
			
		КонецЕсли;	
	КонецЕсли;

	Если ТипПериода = "ВыборПериодаДень" Тогда
		
		Форма[ИмяРеквизиатДанныПредставления] = Формат(Форма[ИмяРеквизитаДанных].ДатаНачала,"ДФ='dd MMMM yyyy, dddd'");
			
	ИначеЕсли ТипПериода = "ВыборПериодаНеделя" Тогда
		
		Форма[ИмяРеквизиатДанныПредставления] = Строка(Форма[ИмяРеквизитаДанных]);
				
	ИначеЕсли ТипПериода = "ВыборПериодаМесяц" Тогда
		
		Форма[ИмяРеквизиатДанныПредставления] =  Формат(Форма[ИмяРеквизитаДанных].ДатаНачала,"ДФ='MMMM yyyy'" );
			
	КонецЕсли;
	
КонецПроцедуры

#Конецобласти

#Область ОбработчикиОтображенияПереключателей

// Процедура, изменяет видимость элементов переключателей.
//
Процедура ИзменитьАктивностьПереключателяФормы(
	АктивныйЭлемент    = Неопределено, 
	НеактивныеЭлементы = Неопределено, 
	Активировать       = Истина, 
	Форма              = Неопределено, 
	ЭлементФокуса      = Неопределено,
	ТемаОформления     = 1) Экспорт
	
	ЦветТекста              = Новый Цвет(77 , 77 , 77);  // Черный.
	ЦветТекстаАктивирован   = Новый Цвет(255, 255, 255); // Белый.
	ЦветТекстаНеАктивирован = Новый Цвет(192, 192, 192); // Серый.
	ЦветФона                = Новый Цвет(242, 242, 242); // Светло-серый.
	
	Если Не ЗначениеЗаполнено(ТемаОформления) ИЛИ ТемаОформления = 1 Тогда
		ЦветФонаАктивирован = Новый Цвет(25, 116, 206); // Синий.
		
	ИначеЕсли ТемаОформления = 2 Тогда
		ЦветФонаАктивирован = Новый Цвет(225, 40, 40); // Красный.
		
	ИначеЕсли ТемаОформления = 3 Тогда
		ЦветФонаАктивирован	  = Новый Цвет(242, 242, 242); // Светло-серый.
		ЦветФона			  = Новый Цвет(255, 255, 255);
		ЦветТекстаАктивирован = Новый Цвет(0, 0, 0);
		ЦветТекста 			  = Новый Цвет(51, 102, 187);
	ИначеЕсли ТемаОформления = 4 Тогда
		//ЦветФонаАктивирован	  	= Новый Цвет(75 , 202, 129);
		ЦветФонаАктивирован	  	= Новый Цвет(25, 116, 206);
		
		ЦветФона			  	= Новый Цвет(235, 235, 237);
		ЦветТекстаНеАктивирован	= Новый Цвет(77 , 77 , 77);
	КонецЕсли;	
		
	Если АктивныйЭлемент <> Неопределено Тогда
		
		ПереданаКнопка = ТипЗнч(АктивныйЭлемент) <> Тип("ГруппаФормы");
		
		АктивнаяГруппа = ?(Не ПереданаКнопка, АктивныйЭлемент, АктивныйЭлемент.Родитель);
		АктивнаяГруппа.ЦветФона = ?(Активировать, ЦветФонаАктивирован, ЦветФона);
		АктивныйЭлемент.Ширина	= ?(ПереданаКнопка, 3, АктивныйЭлемент.Ширина);
		
		Если ПереданаКнопка Тогда
			АктивныйЭлемент.ЦветТекста = ?(Активировать, ЦветТекстаАктивирован, ЦветТекстаНеАктивирован);
			АктивныйЭлемент.Шрифт 	   = Новый Шрифт("Arial", 11);
		Иначе
			Для Каждого АктивныйПодчиненныйЭлемент Из АктивныйЭлемент.ПодчиненныеЭлементы Цикл			
				АктивныйПодчиненныйЭлемент.ЦветТекста = ?(Активировать, ЦветТекстаАктивирован, ЦветТекстаНеАктивирован);		
			КонецЦикла;	
		КонецЕсли;
		
	КонецЕсли;
	
	Если НеактивныеЭлементы <> Неопределено Тогда
		
		Если ТипЗнч(НеактивныеЭлементы) <> Тип("Массив") Тогда
			МассивНеактивныхЭлементов = Новый Массив;
			МассивНеактивныхЭлементов.Добавить(НеактивныеЭлементы);
		Иначе
			МассивНеактивныхЭлементов = НеактивныеЭлементы;
		КонецЕсли;
		
		Для Каждого НеактивныйЭлемент Из МассивНеактивныхЭлементов Цикл
			
			ПереданаКнопка = ТипЗнч(НеактивныйЭлемент) <> Тип("ГруппаФормы");
			
			НеАктивнаяГруппа = ?(Не ПереданаКнопка, НеактивныйЭлемент, НеактивныйЭлемент.Родитель);
			НеАктивнаяГруппа.ЦветФона = ЦветФона;
			НеактивныйЭлемент.Ширина  = ?(ПереданаКнопка, 3, НеактивныйЭлемент.Ширина);
			
			Если ПереданаКнопка Тогда
				НеактивныйЭлемент.ЦветТекста = ЦветТекста;
				НеактивныйЭлемент.Шрифт 	 = Новый Шрифт("Arial", 11);			
			Иначе
				Для Каждого НеактивныйЭлементПодчиненныйЭлемент Из НеактивныйЭлемент.ПодчиненныеЭлементы Цикл			
					НеактивныйЭлементПодчиненныйЭлемент.ЦветТекста = ЦветТекста;		
				КонецЦикла;		
			КонецЕсли;
					
		КонецЦикла;
		
	КонецЕсли;
	
	Если Форма <> Неопределено
		И ЭлементФокуса <> Неопределено Тогда
		
		Форма.ТекущийЭлемент = ЭлементФокуса;
	КонецЕсли;
	
КонецПроцедуры

