	ДекорацияЗаглушка2.ЦветТекста 												= Новый Цвет(255, 255, 255);
	ДекорацияЗаглушка2.ГоризонтальноеПоложение   								= ГоризонтальноеПоложениеЭлемента.Лево;
	ДекорацияЗаглушка2.РастягиватьПоГоризонтали 								= Истина;
