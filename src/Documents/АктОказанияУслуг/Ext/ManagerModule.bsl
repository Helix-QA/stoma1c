#Область СлужебныеПроцедурыИФункции
////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_СтатистикаУслуг") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_СтатистикаУслуг", "Статистика предоставленных услуг", СформироватьПечатнуюФормуСтатистикаУслуг(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_Акт") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_Акт", "Акт оказанных услуг", СформироватьПечатнуюФормуАкт(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_СчетНаОплату") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПФ_MXL_СчетНаОплату", "Счет на оплату", СформироватьПечатнуюФормуСчетНаОплату(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СчетФактура") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СчетФактура", "Счет фактура", СформироватьПечатнуюФормуСчетФактура(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
КонецПроцедуры // Печать()

// Функция формирует печатную форму Акта
//
Функция СформироватьПечатнуюФормуАкт(МассивОбъектов, ОбъектыПечати)
	
	ТабДокумент 		               = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати    = "ПАРАМЕТРЫ_ПЕЧАТИ_ПФ_MXL_Акт";
	Макет 		                       = УправлениеПечатью.МакетПечатнойФормы("Документ.АктОказанияУслуг.ПФ_MXL_Акт");
	
	// Из стандартной кнопки печати приходит тип ссылка
	Если Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(МассивОбъектов)) Тогда
		СсылкаНаДокумент = МассивОбъектов;
		МассивОбъектов = Новый массив;
		МассивОбъектов.Добавить(СсылкаНаДокумент);
	КонецЕсли;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		ЗапросШапка = Новый Запрос;
		ЗапросШапка.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
		ЗапросШапка.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	АктОказанияУслуг.Номер КАК Номер,
		|	АктОказанияУслуг.Дата КАК Дата,
		|	АктОказанияУслуг.СуммаДокумента КАК СуммаДокумента,
		|	АктОказанияУслуг.Контрагент КАК Получатель,
		|	АктОказанияУслуг.ОписаниеУслуги КАК ОписаниеУслуги,
		|	АктОказанияУслуг.Организация.ПолноеНаименование КАК Поставщик,
		|	АктОказанияУслуг.Организация КАК Организация,
		|	АктОказанияУслуг.Организация.Префикс КАК Префикс
		|ИЗ
		|	Документ.АктОказанияУслуг КАК АктОказанияУслуг
		|ГДЕ
		|	АктОказанияУслуг.Ссылка = &ТекущийДокумент";
		Шапка = ЗапросШапка.Выполнить().Выбрать();
		Шапка.Следующий();
		
		ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
		ОбластьМакета.Параметры.ТекстЗаголовка = ФормированиеПечатныхФорм.СформироватьЗаголовокДокумента(Шапка, "Акт");	
		ТабДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                   = Макет.ПолучитьОбласть("Поставщик");
		СведенияОПоставщике                             = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, Шапка.Дата);
		ПредставлениеПоставщика                         = СведенияОПоставщике.ПолноеНаименование + ", ИНН/КПП " + СведенияОПоставщике.ИНН + ?(Не ПустаяСтрока(СведенияОПоставщике.КПП), "/" + СведенияОПоставщике.КПП, "") + ?(Не ПустаяСтрока(СведенияОПоставщике.ЮридическийАдрес), ", " + СведенияОПоставщике.ЮридическийАдрес, "");  
		ОбластьМакета.Параметры.ПредставлениеПоставщика = ПредставлениеПоставщика;
		ТабДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                   = Макет.ПолучитьОбласть("Покупатель");	
		СведенияОПолучателе                             = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Получатель, Шапка.Дата);
		ПредставлениеПолучателя                         = СведенияОПолучателе.ПолноеНаименование + ", ИНН/КПП " + СведенияОПолучателе.ИНН + ?(Не ПустаяСтрока(СведенияОПолучателе.КПП), "/" + СведенияОПолучателе.КПП, "") + ?(Не ПустаяСтрока(СведенияОПолучателе.ЮридическийАдрес), ", " + СведенияОПолучателе.ЮридическийАдрес, "");  
		ОбластьМакета.Параметры.ПредставлениеПолучателя = ПредставлениеПолучателя;	
		ТабДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                       = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ОбластьСтроки                       = Макет.ПолучитьОбласть("Строка");	
		ТабДокумент.Вывести(ОбластьМакета);
		ОбластьСтроки.Параметры.НомерСтроки = 1;
		ОбластьСтроки.Параметры.Товар 		= ?(Шапка.ОписаниеУслуги = "", "Оказание медицинских услуг", Шапка.ОписаниеУслуги);
		ОбластьСтроки.Параметры.Количество  = 1;
		ОбластьСтроки.Параметры.Цена		= Шапка.СуммаДокумента;
		ОбластьСтроки.Параметры.Сумма 		= Шапка.СуммаДокумента;
		ОбластьСтроки.Параметры.ЕдиницаИзмерения = "шт";
		ТабДокумент.Вывести(ОбластьСтроки);
		
		ОбластьМакета                 = Макет.ПолучитьОбласть("Итого");
		ОбластьМакета.Параметры.Всего = ФормированиеПечатныхФорм.ФорматСумм(Шапка.СуммаДокумента);
		ТабДокумент.Вывести(ОбластьМакета);
		
		СуммаКПрописи                          = Шапка.СуммаДокумента;
		ОбластьМакета                          = Макет.ПолучитьОбласть("СуммаПрописью");
		ОбластьМакета.Параметры.ИтоговаяСтрока = "Всего оказано услуг на сумму: " + ФормированиеПечатныхФорм.СформироватьСуммуПрописью(СуммаКПрописи);//ФормированиеПечатныхФорм.СуммаРубКоп(СуммаКПрописи, ,);//Формат(СуммаКПрописи, "ЧЦ = 15, ЧДЦ = 2") + " руб." ;
		ТабДокумент.Вывести(ОбластьМакета);	
		ОбластьМакета                          = Макет.ПолучитьОбласть("Подписи");
		Таблица       = ВернутьФИООтветственныеЛицаОрганизации(Шапка.Организация);	
		Руководитель = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.Руководитель    , "ТипОтветственногоЛица");		
		ОбластьМакета.Параметры.ФИОРуководителя = ?(Руководитель <> Неопределено, Руководитель.ФИО, "");
		ОбластьМакета.Параметры.Должность = ?(Руководитель <> Неопределено, Руководитель.Должность, "");
		ТабДокумент.Вывести(ОбластьМакета);
	
	КонецЦикла;
	
	Возврат ТабДокумент;
	
КонецФункции

// Функция формирует печатную форму Акта
//
Функция СформироватьПечатнуюФормуСчетНаОплату(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент 		                 = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати    = "ПАРАМЕТРЫ_ПЕЧАТИ_ПФ_MXL_СчетНаОплату";
	Макет 		                             = УправлениеПечатью.МакетПечатнойФормы("Документ.АктОказанияУслуг.ПФ_MXL_СчетНаОплату");
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемЛечение.Ссылка КАК Ссылка,
	|	ПриемЛечение.СуммаАвтоматическойСкидкиНаценки КАК СуммаАвтоматическойСкидкиНаценки,
	|	ПриемЛечение.Сумма КАК Сумма,
	|	ПриемЛечение.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ПриемЛечение.КоличествоУпаковок * ПриемЛечение.Цена КАК СуммаБезСкидки,
	|	ПриемЛечение.КоличествоУпаковок * ПриемЛечение.Цена - ПриемЛечение.Сумма КАК СуммаСкидки
	|ПОМЕСТИТЬ УслугиТовары
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЗапасы.Ссылка,
	|	ПриемЗапасы.СуммаАвтоматическойСкидкиНаценки,
	|	ПриемЗапасы.Сумма,
	|	ПриемЗапасы.ПроцентСкидкиНаценки,
	|	ПриемЗапасы.КоличествоУпаковок * ПриемЗапасы.Цена,
	|	ПриемЗапасы.КоличествоУпаковок * ПриемЗапасы.Цена - ПриемЗапасы.Сумма
	|ИЗ
	|	Документ.Прием.Запасы КАК ПриемЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АктОказанияУслугОказанныеУслуги.Ссылка КАК Ссылка,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Дата КАК ДатаДокумента,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Контрагент КАК Контрагент,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Организация КАК Организация,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Организация.Префикс КАК Префикс,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Номер КАК Номер,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Организация.БанковскийСчетПоУмолчанию КАК БанковскийСчет,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.ОписаниеУслуги КАК ОписаниеУслуги,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.СуммаДокумента КАК СуммаДокумента,
	|	СУММА(УслугиТовары.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
	|	СУММА(УслугиТовары.Сумма) КАК Сумма,
	|	СУММА(УслугиТовары.ПроцентСкидкиНаценки) КАК ПроцентСкидкиНаценки,
	|	СУММА(УслугиТовары.СуммаБезСкидки) КАК СуммаБезСкидки,
	|	СУММА(УслугиТовары.СуммаСкидки) КАК СуммаСкидки
	|ИЗ
	|	Документ.АктОказанияУслуг.ОказанныеУслуги КАК АктОказанияУслугОказанныеУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиТовары КАК УслугиТовары
	|		ПО АктОказанияУслугОказанныеУслуги.ДокументОснования = УслугиТовары.Ссылка
	|ГДЕ
	|	АктОказанияУслугОказанныеУслуги.Ссылка В(&МассивОбъектов)
	|
	|СГРУППИРОВАТЬ ПО
	|	АктОказанияУслугОказанныеУслуги.Ссылка,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Дата,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Контрагент,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Организация,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Организация.Префикс,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Номер,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.Организация.БанковскийСчетПоУмолчанию,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.ОписаниеУслуги,
	|	АктОказанияУслугОказанныеУслуги.Ссылка.СуммаДокумента";
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);	
	Выборка = Запрос.Выполнить().Выбрать();	
	Таблица = Запрос.Выполнить().Выгрузить();
	ПервыйДокумент = Истина;
	ЕстьСкидки = Таблица.Итог("ПроцентСкидкиНаценки") <> 0 ИЛИ Таблица.Итог("СуммаАвтоматическойСкидкиНаценки") <> 0;
	
	Пока Выборка.СледующийПоЗначениюПоля("Ссылка") Цикл	
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент        = Ложь;	
		НомерСтрокиНачало     = ТабличныйДокумент.ВысотаТаблицы + 1;		
		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Организация, Выборка.ДатаДокумента, ,Выборка.БанковскийСчет);
		СведенияОбКонтрагенте = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Контрагент, Выборка.ДатаДокумента, ,);
		
		ОбластьМакета = Макет.ПолучитьОбласть("ЗаголовокСчета");
		Если ЗначениеЗаполнено(СведенияОбОрганизации.Банк) Тогда
			ОбластьМакета.Параметры.БанкПолучателяПредставление = СведенияОбОрганизации.Банк.Наименование + " " + СведенияОбОрганизации.Банк.Город;
		КонецЕсли; 
		ОбластьМакета.Параметры.ИНН                              = СведенияОбОрганизации.ИНН;
		ОбластьМакета.Параметры.КПП                              = СведенияОбОрганизации.КПП;
		ОбластьМакета.Параметры.ПредставлениеПоставщика          = СведенияОбОрганизации.ПолноеНаименование;
		ОбластьМакета.Параметры.БИКБанкаПолучателя               = СведенияОбОрганизации.БИК;
		ОбластьМакета.Параметры.СчетБанкаПолучателяПредставление = СведенияОбОрганизации.КоррСчет;
		ОбластьМакета.Параметры.СчетПолучателяПредставление      = СведенияОбОрганизации.НомерСчета;	
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		Если Выборка.ДатаДокумента < Дата('20110101') Тогда
			НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Выборка.Номер, Выборка.Префикс);
		Иначе
			НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Выборка.Номер, Истина, Истина);
		КонецЕсли;			
		ОбластьМакета                          = Макет.ПолучитьОбласть("Заголовок");
		ОбластьМакета.Параметры.ТекстЗаголовка = "Счет на оплату № "
		+ НомерДокумента
		+ " от "
		+ Формат(Выборка.ДатаДокумента, "ДФ=""dd MMMM yyyy""");		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Поставщик");
		ОбластьМакета.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации,"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет"); 
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Покупатель");
		ОбластьМакета.Параметры.ПредставлениеПолучателя = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбКонтрагенте, "ПолноеНаименование,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		Если  ЕстьСкидки Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицыСоСкидкой");
			ОбластьСтроки = Макет.ПолучитьОбласть("СтрокаСоСкидкой");
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицы");
			ОбластьСтроки = Макет.ПолучитьОбласть("Строка");
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьМакета);			
		
		ОбластьСтроки.Параметры.НомерСтроки = 1;
		ОбластьСтроки.Параметры.Запас 		= Выборка.ОписаниеУслуги;
		ОбластьСтроки.Параметры.Количество  = 1;
		Сумма = Выборка.СуммаДокумента;
		Если  ЕстьСкидки Тогда
			ОбластьСтроки.Параметры.СуммаБезСкидки = Выборка.СуммаБезСкидки;
			ОбластьСтроки.Параметры.Скидка         = Выборка.СуммаСкидки;
			ОбластьСтроки.Параметры.Цена           = Выборка.СуммаБезСкидки;
			ОбластьСтроки.Параметры.Сумма          = Сумма;
		Иначе
			ОбластьСтроки.Параметры.Цена 		= Сумма;
			ОбластьСтроки.Параметры.Сумма 		= Сумма;
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьСтроки);
		
		ОбластьМакета                 = Макет.ПолучитьОбласть("Итого");
		ОбластьМакета.Параметры.Всего = ФормированиеПечатныхФорм.ФорматСумм(Сумма);
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		Количество = 1;
		ОбластьМакета = Макет.ПолучитьОбласть("СуммаПрописью");
		СуммаКПрописи = Сумма;
		ОбластьМакета.Параметры.ИтоговаяСтрока = "Всего оказано услуг 1"
		+ ", на сумму "
		+ ФормированиеПечатныхФорм.СуммаРубКоп(СуммаКПрописи, ,);		
		ОбластьМакета.Параметры.СуммаПрописью = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(СуммаКПрописи,
		Константы.ВалютаУчета.Получить());		
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		ОбластьМакета = Макет.ПолучитьОбласть("ПодвалСчета");		
		Таблица       = ВернутьФИООтветственныеЛицаОрганизации(Выборка.Организация);	
		Бухгалтер    = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер, "ТипОтветственногоЛица");
		Руководитель = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.Руководитель    , "ТипОтветственногоЛица");		
		ОбластьМакета.Параметры.ФИОБухгалтера = ?(Бухгалтер <> Неопределено   , Бухгалтер.ФИО, "");
		ОбластьМакета.Параметры.ФИОРуководителя = ?(Руководитель <> Неопределено, Руководитель.ФИО, "");	
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, Выборка.Ссылка);	
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Функция формирует печатную форму Счета-фактуры.
//
Функция СформироватьПечатнуюФормуСчетФактура(МассивОбъектов, ОбъектыПечати) 
	
	ТабличныйДокумент 		                 = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати    = "ПАРАМЕТРЫ_ПЕЧАТИ_ПФ_MXL_СчетФактура1137";
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	
	Если МассивОбъектов[0].Дата < Дата(2012,4,1,0,0,0) Тогда
		Макет = УправлениеПечатью.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_СчетФактура451");
		НовыйМакет = Ложь;
	Иначе
		Макет = УправлениеПечатью.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_СчетФактура1137");
		НовыйМакет = Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АктОказанияУслуг.Ссылка КАК Ссылка,
	|	АктОказанияУслуг.Дата КАК Дата,
	|	АктОказанияУслуг.Контрагент КАК Контрагент,
	|	АктОказанияУслуг.Организация КАК Организация,
	|	АктОказанияУслуг.Организация.Префикс КАК Префикс,
	|	АктОказанияУслуг.Номер,
	|	АктОказанияУслуг.Организация.БанковскийСчетПоУмолчанию КАК БанковскийСчет,
	|	АктОказанияУслуг.ОписаниеУслуги КАК ОписаниеУслуги,
	|	АктОказанияУслуг.СуммаДокумента КАК СуммаДокумента
	|ИЗ
	|	Документ.АктОказанияУслуг КАК АктОказанияУслуг
	|ГДЕ
	|	АктОказанияУслуг.Ссылка В(&МассивОбъектов)
	|
	|СГРУППИРОВАТЬ ПО
	|	АктОказанияУслуг.Ссылка,
	|	АктОказанияУслуг.Дата,
	|	АктОказанияУслуг.Контрагент,
	|	АктОказанияУслуг.Организация,
	|	АктОказанияУслуг.Организация.Префикс,
	|	АктОказанияУслуг.Номер,
	|	АктОказанияУслуг.Организация.БанковскийСчетПоУмолчанию,
	|	АктОказанияУслуг.ОписаниеУслуги,
	|	АктОказанияУслуг.СуммаДокумента";
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);	
	Выборка = Запрос.Выполнить().Выбрать();	
	ПервыйДокумент = Истина;
	
	Пока Выборка.СледующийПоЗначениюПоля("Ссылка") Цикл		
		СведенияОПоставщике   = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Организация, Выборка.Дата, ,);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		СведенияОбОрганизации = Новый Структура;
		ЗаполнитьРеквизитыШапкиСчетФактура(Выборка, СведенияОбОрганизации, Макет, ТабличныйДокумент, НовыйМакет);
		ЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабличныйДокумент.Вывести(ЗаголовокТаблицы);
		
		ОбластьСтрока  = Макет.ПолучитьОбласть("Строка");
		ОбластьСтрока.Параметры.Заполнить(Выборка);
		ОбластьСтрока.Параметры.ТоварНаименование =  Выборка.ОписаниеУслуги;
		ОбластьСтрока.Параметры.Количество = 1;
		СуммаДокумента = Выборка.СуммаДокумента;
		ОбластьСтрока.Параметры.СуммаБезНДС = СуммаДокумента;
		ОбластьСтрока.Параметры.СуммаСНДС = СуммаДокумента;
		ОбластьСтрока.Параметры.Цена = СуммаДокумента;
		ОбластьСтрока.Параметры.Акциз = "Без акциза";
		ОбластьСтрока.Параметры.СтавкаНДС = "Без НДС";
		ОбластьСтрока.Параметры.СуммаНДС = "Без НДС";
		ОбластьСтрока.Параметры.ЕдиницаИзмерения = "шт";
		ОбластьСтрока.Параметры.ЕдиницаИзмеренияКод = "796";
		ПроставитьПрочеркиВПустыеПоляСтрокиСчетФактура(ОбластьСтрока);
		ТабличныйДокумент.Вывести(ОбластьСтрока);	
		ОбластьПодвала = Макет.ПолучитьОбласть("Подвал");
		ЗаполнитьРеквизитыПодвалаСчетФактура(Выборка, СведенияОбОрганизации, СуммаДокумента, Макет, ТабличныйДокумент, НовыйМакет);
		
		Возврат  ТабличныйДокумент;
	КонецЦикла;   
	
КонецФункции // СформироватьПечатнуюФормуСчетФактура()

// Функция формирует печатную форму статистки услуг.
//
Функция СформироватьПечатнуюФормуСтатистикаУслуг(МассивОбъектов, ОбъектыПечати)
	
	ТабДок 		               = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПФ_MXL_СтатистикаУслуг";
	ТабДок.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.АктОказанияУслуг.ПФ_MXL_СтатистикаУслуг");
	ПервыйДокумент = Истина;

	// Из стандартной кнопки печати приходит тип ссылка
	Если Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(МассивОбъектов)) Тогда
		СсылкаНаДокумент = МассивОбъектов;
		МассивОбъектов = Новый массив;
		МассивОбъектов.Добавить(СсылкаНаДокумент);
	КонецЕсли;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент        = Ложь;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования КАК ПриемСтоматолога,
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования.Контрагент КАК ФИО_Пациента,
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования.Дата КАК ДатаУслуги,
		|	СУММА(АктОбОказанныхУслугахОказаниеУслуг.Сумма) КАК Стоимость,
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования.ПолисМедСтрахования КАК ПолисМедСтрахования
		|ИЗ
		|	Документ.АктОказанияУслуг.ОказанныеУслуги КАК АктОбОказанныхУслугахОказаниеУслуг
		|ГДЕ
		|	АктОбОказанныхУслугахОказаниеУслуг.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования.Контрагент,
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования,
		|	АктОбОказанныхУслугахОказаниеУслуг.ДокументОснования.Дата
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФИО_Пациента,
		|	ДатаУслуги
		|ИТОГИ
		|	СУММА(Стоимость)
		|ПО
		|	ОБЩИЕ,
		|	ФИО_Пациента,
		|	ПриемСтоматолога
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗначенияПараметровОбследований.Документ КАК Документ,
		|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
		|	ЗначенияПараметровОбследований.Зуб КАК Зуб,
		|	ЗначенияПараметровОбследований.Значение КАК Диагноз,
		|	ЕСТЬNULL(ВЫРАЗИТЬ(ЗначенияПараметровОбследований.Значение КАК Справочник.Диагнозы).Код, """") КАК КодДиагноза,
		|	ЕСТЬNULL(ВЫРАЗИТЬ(ЗначенияПараметровОбследований.Значение КАК Справочник.Диагнозы).Наименование, """") КАК НаименованиеДиагноза
		|ИЗ
		|	РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
		|ГДЕ
		|	ЗначенияПараметровОбследований.Документ В(&ДокументыОснования)
		|	И ТИПЗНАЧЕНИЯ(ЗначенияПараметровОбследований.Значение) = ТИП(Справочник.Диагнозы)
		|	И НЕ ЗначенияПараметровОбследований.Параметр ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗначенияПараметровОбследований.Документ,
		|	ЗначенияПараметровОбследований.ШаблонОбследования,
		|	ЗначенияПараметровОбследований.Зуб,
		|	ЗначенияПараметровОбследований.Значение,
		|	ЕСТЬNULL(ВЫРАЗИТЬ(ЗначенияПараметровОбследований.Значение КАК Справочник.Диагнозы).Код, """"),
		|	ЕСТЬNULL(ВЫРАЗИТЬ(ЗначенияПараметровОбследований.Значение КАК Справочник.Диагнозы).Наименование, """")";		
		
		Запрос.УстановитьПараметр("Ссылка"            , ТекущийДокумент);
		Запрос.УстановитьПараметр("ДокументыОснования", ТекущийДокумент.ОказанныеУслуги.ВыгрузитьКолонку("ДокументОснования"));
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		
		ОбластьЗаголовок            = Макет.ПолучитьОбласть("Заголовок");
		ОбластьПодвал               = Макет.ПолучитьОбласть("Подвал");
		ОбластьШапкаТаблицы         = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ОбластьПодвалТаблицы        = Макет.ПолучитьОбласть("ПодвалТаблицы");
		ОбластьОбщийИтог            = Макет.ПолучитьОбласть("ОбщиеИтоги");
		ОбластьФИО_Пациента         = Макет.ПолучитьОбласть("ФИО_Пациента"); 
		ОбластьСкидка     			= Макет.ПолучитьОбласть("Скидка");
		ОбластьЗуб                  = Макет.ПолучитьОбласть("Зуб");
		ОбластьДетальныхЗаписей     = Макет.ПолучитьОбласть("Детали");
		
		//ТабДок.Очистить(); 
		ПредставлениеОрагнизации                         = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ТекущийДокумент.Организация, ТекущийДокумент.Дата,);
		НаименованиеСтраховой                            = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ТекущийДокумент.Контрагент , ТекущийДокумент.Дата,);
		ОбластьЗаголовок.Параметры.Организация           = ?(ЗначениеЗаполнено(ПредставлениеОрагнизации.ПолноеНаименование), ПредставлениеОрагнизации.ПолноеНаименование, ПредставлениеОрагнизации.Представление);
		ОбластьЗаголовок.Параметры.НаименованиеСтраховой = ?(ЗначениеЗаполнено(НаименованиеСтраховой.ПолноеНаименование), НаименованиеСтраховой.ПолноеНаименование, НаименованиеСтраховой.Представление);
		ОбластьЗаголовок.Параметры.НомерДок              = ТекущийДокумент.Номер;
		ОбластьЗаголовок.Параметры.ОписаниеУслуги        = ТекущийДокумент.ОписаниеУслуги;  		
		ТабДок.Вывести(ОбластьЗаголовок);
		ТабДок.Вывести(ОбластьШапкаТаблицы);
		
		ВыборкаОбщийИтог = РезультатЗапроса[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВыборкаДиагнозы  = РезультатЗапроса[1].Выгрузить();
		ВыборкаОбщийИтог.Следующий();	
		ОбластьОбщийИтог.Параметры.Заполнить(ВыборкаОбщийИтог);
		НомерПоПорядку      = 0;
		ВыборкаФИО_Пациента = ВыборкаОбщийИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФИО_Пациента");	
		Пока ВыборкаФИО_Пациента.Следующий() Цикл
			
			ОбластьФИО_Пациента.Параметры.Заполнить(ВыборкаФИО_Пациента);
			ВыборкаПриемСтоматолога = ВыборкаФИО_Пациента.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ПриемСтоматолога");
			Пока ВыборкаПриемСтоматолога.Следующий() Цикл
				
				// Подготовка данных по приему
				ТЧЛечение = ВыборкаПриемСтоматолога.ПриемСтоматолога.Лечение.Выгрузить();				 
				ТЧЛечение.Свернуть("Номенклатура, Цена, Зуб", "КоличествоУпаковок, Сумма");
				ТЧЛечение.Колонки.Добавить("ПредставлениеДиагноза", Новый ОписаниеТипов("Строка")); 
				
				Диагнозы = ВыборкаДиагнозы.НайтиСтроки(Новый Структура("Документ", ВыборкаПриемСтоматолога.ПриемСтоматолога));
				СтрокаДиагноз = "";
				Для Каждого СтрокаЛ Из ТЧЛечение Цикл 
					ПредставлениеДиагноза = "";
					Если ЗначениеЗаполнено(СтрокаЛ.Зуб) И НЕ СтрокаЛ.Зуб = Перечисления.Зубы.ВсяПолость Тогда  
						ЗубИзСтрокиЛечение = СтрокаЛ.Зуб;
					Иначе
						ЗубИзСтрокиЛечение = Перечисления.Зубы.ПустаяСсылка();
					КонецЕсли;					
					ДиагнозыВыбранногоЗуба = ВыборкаДиагнозы.НайтиСтроки(Новый Структура("Документ, Зуб", ВыборкаПриемСтоматолога.ПриемСтоматолога, ЗубИзСтрокиЛечение));  
					Если ЗначениеЗаполнено(ДиагнозыВыбранногоЗуба) Тогда 
						Для Каждого СтрокаТ Из ДиагнозыВыбранногоЗуба Цикл
							ПредставлениеДиагноза = ?(ЗначениеЗаполнено(ПредставлениеДиагноза), ПредставлениеДиагноза+", ", ПредставлениеДиагноза) + СокрЛП(СтрокаТ.КодДиагноза) + 
							?(ЗначениеЗаполнено(СтрокаТ.НаименованиеДиагноза), "; "  + Строка(СтрокаТ.НаименованиеДиагноза), ""); 
							Если Диагнозы.Найти(СтрокаТ) <> Неопределено Тогда
								Диагнозы.Удалить(Диагнозы.Найти(СтрокаТ));	
							КонецЕсли;
						КонецЦикла;	
						СтрокаЛ.ПредставлениеДиагноза = ПредставлениеДиагноза;  								
					КонецЕсли; 					
				КонецЦикла;
				
				Если ЗначениеЗаполнено(Диагнозы) Тогда
					Для Каждого СтрокаД Из Диагнозы Цикл
						СтрокаДиагноз = ?(Не ЗначениеЗаполнено(СтрокаДиагноз), СтрокаДиагноз, СтрокаДиагноз + ", ") +
						СокрЛП(СтрокаД.КодДиагноза) + ?(ЗначениеЗаполнено(СтрокаД.НаименованиеДиагноза), "; "  + Строка(СтрокаД.НаименованиеДиагноза), "");							
					КонецЦикла;						
				КонецЕсли; 
				
				НомерПоПорядку   = НомерПоПорядку + 1;  
				ОбластьЗуб.Параметры.Заполнить(ВыборкаПриемСтоматолога);
				//ОбластьЗуб.Параметры.Полис          = Строка(ВыборкаПриемСтоматолога.ПриемСтоматолога.ПолисМедСтрахования.СерияПолиса) +"/" + Строка(ВыборкаПриемСтоматолога.ПриемСтоматолога.ПолисМедСтрахования.НомерПолиса);
				// 243950.  
				СтруктураПолиса = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ВыборкаПриемСтоматолога.ПолисМедСтрахования, "СерияПолиса, НомерПолиса, НомерГарантийногоПисьма, ДатаГарантийногоПисьма");
				
				ПредставлениеПолиса = ?(ЗначениеЗаполнено(СтруктураПолиса.СерияПолиса), СтруктураПолиса.СерияПолиса + "/", "") +
				?(ЗначениеЗаполнено(СтруктураПолиса.НомерПолиса), СтруктураПолиса.НомерПолиса, "");
				НомерДата = ?(ЗначениеЗаполнено(СтруктураПолиса.НомерГарантийногоПисьма), СтруктураПолиса.НомерГарантийногоПисьма, "") + 
				?(ЗначениеЗаполнено(СтруктураПолиса.ДатаГарантийногоПисьма), " от " + Формат(СтруктураПолиса.ДатаГарантийногоПисьма, "ДФ=dd.MM.yyyy"), "");  
				
				ОбластьЗуб.Параметры.Полис          = ПредставлениеПолиса;							
				ОбластьЗуб.Параметры.НомерДатаГ     = НомерДата;				
				ОбластьЗуб.Параметры.КодДиагноза    = СтрокаДиагноз;
				ОбластьЗуб.Параметры.Номер          = НомерПоПорядку; 
				ОбластьЗуб.Параметры.Врач           = ВыборкаПриемСтоматолога.ПриемСтоматолога.Сотрудник;
				ТабДок.Вывести(ОбластьЗуб, 1);
				
				ТабДок.НачатьГруппуСтрок();	
				
				Для Каждого СтрокаТ ИЗ ТЧЛечение Цикл 
					СтруктураНоменклатуры = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтрокаТ.Номенклатура, "Наименование, НаименованиеПолное, КодНоменклатурыМедицинскиУслуг, КодУслуги");   
					НаименованиеНоменклатуры = ?(ЗначениеЗаполнено(СтруктураНоменклатуры.НаименованиеПолное), СтруктураНоменклатуры.НаименованиеПолное, ?(ЗначениеЗаполнено(СтруктураНоменклатуры.Наименование), СтруктураНоменклатуры.Наименование, ""));
					ОбластьДетальныхЗаписей.Параметры.НаименованиеУслуги = НаименованиеНоменклатуры; 
					ОбластьДетальныхЗаписей.Параметры.КодУслуги          = ?(ЗначениеЗаполнено(СтруктураНоменклатуры.КодНоменклатурыМедицинскиУслуг), СтруктураНоменклатуры.КодНоменклатурыМедицинскиУслуг, СтруктураНоменклатуры.КодУслуги);
					ОбластьДетальныхЗаписей.Параметры.Стоимость          = СтрокаТ.Сумма;
					ОбластьДетальныхЗаписей.Параметры.ЦенаУслуги         = СтрокаТ.Цена; 
					ОбластьДетальныхЗаписей.Параметры.НомерЗуба          = Строка(СтрокаТ.Зуб);
					ОбластьДетальныхЗаписей.Параметры.КоличествоУслуг    = СтрокаТ.КоличествоУпаковок;
					ОбластьДетальныхЗаписей.Параметры.КодДиагноза    	 = ?(ЗначениеЗаполнено(СтрокаТ.ПредставлениеДиагноза), СтрокаТ.ПредставлениеДиагноза, "");
					ТабДок.Вывести(ОбластьДетальныхЗаписей,1);	
				КонецЦикла;
				ТабДок.ЗакончитьГруппуСтрок();
			КонецЦикла;
			
			ТабДок.Вывести(ОбластьФИО_Пациента, ВыборкаФИО_Пациента.Уровень());
		КонецЦикла;
		ТабДок.Вывести(ОбластьОбщийИтог, ВыборкаОбщийИтог.Уровень()); 
		
		Скидка = 0;
		Если ТекущийДокумент.Договор.ПроцентСкидки <> 0 Тогда
            Скидка = ВыборкаОбщийИтог.Стоимость/ 100 * ТекущийДокумент.Договор.ПроцентСкидки; 
			ОбластьСкидка.Параметры.Скидка 	= Скидка;
			ОбластьСкидка.Параметры.Итого	= ВыборкаОбщийИтог.Стоимость - Скидка; 	
			ТабДок.Вывести(ОбластьСкидка);                       
		КонецЕсли;
		
		ТабДок.Вывести(ОбластьПодвалТаблицы);
		Таблица                                  = ВернутьФИООтветственныеЛицаОрганизации(ТекущийДокумент.Организация);	
		Бухгалтер                                = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер, "ТипОтветственногоЛица");
		Руководитель                             = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.Руководитель    , "ТипОтветственногоЛица");		
		ОбластьПодвал.Параметры.ФИОБухгалтера    = ?(Бухгалтер <> Неопределено   , Бухгалтер.ФИО, "");
		ОбластьПодвал.Параметры.ФИОРуководителя  = ?(Руководитель <> Неопределено, Руководитель.ФИО, "");
		ОбластьПодвал.Параметры.Итого            = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(?(ВыборкаОбщийИтог.Стоимость <> Неопределено, ВыборкаОбщийИтог.Стоимость - Скидка,0));	
		ОбластьПодвал.Параметры.СообщениеПодвала = ?(Скидка = 0 , "ИТОГО по Реестру:", "ИТОГО  к оплате:");
		ТабДок.Вывести(ОбластьПодвал);

	КонецЦикла;
	
	Возврат ТабДок;
	
КонецФункции

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("ПФ_MXL_Акт", "Акт оказанных услуг", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_СтатистикаУслуг", "Статистика предоставленных услуг", , БиблиотекаКартинок.Документ);
	Список.Добавить("СчетФактура", "Счет фактура", , БиблиотекаКартинок.Документ);
	Список.Добавить("ПФ_MXL_СчетНаОплату", "Счета на оплату", , БиблиотекаКартинок.Документ);
		
	Возврат Список;
	
КонецФункции

// Процедура заполнения реквизитов шапки Счет-фактуры.
//
// Параметры:
//	ДанныеПечати - ВыборкаИзРезультатаЗапроса - Данные шапки документа
//	Макет - Макет ТОРГ-12
//	ТабличныйДокумент - Табличный документ
//
Процедура ЗаполнитьРеквизитыШапкиСчетФактура(ДанныеПечати, СведенияОПоставщике, Макет, ТабличныйДокумент, НовыйМакет)
	
	СведенияОПоставщике = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Организация, ДанныеПечати.Дата);
	СведенияОПокупателе = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Контрагент, ДанныеПечати.Дата);
	СведенияОГрузоотправителе = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Организация, ДанныеПечати.Дата);
	СведенияОГрузополучателе = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Контрагент,  ДанныеПечати.Дата);
	
	ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
	ОбластьМакета.Параметры.Заполнить(ДанныеПечати);
	ОбластьМакета.Параметры.Номер = "Счет-фактура № " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(ДанныеПечати.Номер, ДанныеПечати.Префикс)
	+ " от " + Формат(ДанныеПечати.Дата, "ДФ='дд ММММ гггг'")+ " г.";
	
	// Выводим данные о поставщике.
	ОбластьМакета.Параметры.ПредставлениеПоставщика = "Продавец: "
	+ СведенияОПоставщике.ОфициальноеНаименование
	+ " ("
	+ ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПоставщике, "ПолноеНаименование")
	+ ")";
	ОбластьМакета.Параметры.АдресПоставщика = "Адрес: " + ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПоставщике, "ЮридическийАдрес");
	
	КПП = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПоставщике, "КПП,", Ложь);
	ОбластьМакета.Параметры.ИННПоставщика = "ИНН/КПП продавца: " 
	+ ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПоставщике, "ИНН", Ложь)
	+ ?(Не ПустаяСтрока(КПП), "/" + КПП, "");
	
	// Выводим данные грузоотправителя.	
	ПредставлениеГрузоотправителя = "Грузоотправитель и его адрес: ";
	ПредставлениеГрузоотправителя = ПредставлениеГрузоотправителя + СведенияОГрузоотправителе.ПолноеНаименование + ?(Не ПустаяСтрока(СведенияОГрузоотправителе.ЮридическийАдрес), ", " + СведенияОГрузоотправителе.ЮридическийАдрес, "");
	ОбластьМакета.Параметры.ПредставлениеГрузоотправителя = ПредставлениеГрузоотправителя;
	
	// Выводим данные грузополучателя и покупателя.
	ПредставлениеГрузополучателя = "Грузополучатель и его адрес: ";
	ПредставлениеГрузополучателя = ПредставлениеГрузополучателя + СведенияОГрузополучателе.ПолноеНаименование + ?(Не ПустаяСтрока(СведенияОГрузополучателе.ЮридическийАдрес), ", " + СведенияОГрузополучателе.ЮридическийАдрес, "");
	ОбластьМакета.Параметры.ПредставлениеГрузополучателя = ПредставлениеГрузополучателя;
	
	ОбластьМакета.Параметры.ПоДокументу = "К платежно-расчетному документу № ";
	ОбластьМакета.Параметры.ПоДокументу = ОбластьМакета.Параметры.ПоДокументу + "-- от --";    //?
	
	ОбластьМакета.Параметры.ПредставлениеПокупателя = "Покупатель: " 
	+ ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПокупателе, "ПолноеНаименование", Ложь);
	ОбластьМакета.Параметры.АдресПокупателя = "Адрес: "
	+ ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПокупателе, "ЮридическийАдрес", Ложь);
	
	КПП = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПокупателе, "КПП,", Ложь);	
	ОбластьМакета.Параметры.ИННПокупателя = "ИНН/КПП покупателя: "
	+ ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПокупателе, "ИНН,", Ложь)
	+ ?(Не ПустаяСтрока(КПП), "/" + КПП, "");
	
	Если НовыйМакет Тогда
		ОбластьМакета.Параметры.Валюта = "Валюта: наименование, код Российский рубль, 643";
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьМакета);
	
КонецПроцедуры // ЗаполнитьРеквизитыШапкиСчетФактура()

// Процедура заполнения реквизитов подвала Счет-фактуры.
//
// Параметры:
//	ДанныеПечати - ВыборкаИзРезультатаЗапроса - Данные шапки документа
//	ИтоговыеСуммы - Структура - Структура итоговых сумм документа
//	Макет - Макет ТОРГ-12
//	ТабличныйДокумент - Табличный документ
//
Процедура ЗаполнитьРеквизитыПодвалаСчетФактура(ДанныеПечати, СведенияОбОрганизации, СуммаДокумента, Макет, ТабличныйДокумент, НовыйМакет)
	
	ОбластьИтого = Макет.ПолучитьОбласть("Итого");
	ОбластьИтого.Параметры.ИтогоСуммаНДС = "Без НДС";
	ОбластьИтого.Параметры.ИтогоВсего = СуммаДокумента;
	
	Если НовыйМакет Тогда
		ОбластьИтого.Параметры.ИтогоСуммаБезНДС = СуммаДокумента;
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьИтого);
	
	ОбластьПодвала = Макет.ПолучитьОбласть("Подвал");
	Таблица       = ВернутьФИООтветственныеЛицаОрганизации(ДанныеПечати.Организация);	
	Бухгалтер    = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер, "ТипОтветственногоЛица");
	Руководитель = Таблица.НАйти(Перечисления.ТипыОтветственныхЛиц.Руководитель    , "ТипОтветственногоЛица");		
	ОбластьПодвала.Параметры.ФИОГлавногоБухгалтера = ?(Бухгалтер <> Неопределено   , Бухгалтер.ФИО, "");
	ОбластьПодвала.Параметры.ФИОРуководителя   = ?(Руководитель <> Неопределено, Руководитель.ФИО, "");
	
	ТабличныйДокумент.Вывести(ОбластьПодвала);
	
КонецПроцедуры // ЗаполнитьРеквизитыПодвалаСчетФактура()

// Функция возвращает данные ответственного лица организации.
//
Функция ВернутьФИООтветственныеЛицаОрганизации(Организация)
	
	Запрос = Новый запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	ОтветственныеЛицаСрезПоследних.Сотрудник.Наименование КАК ФИО,
	                      |	ОтветственныеЛицаСрезПоследних.Должность КАК Должность,
	                      |	ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица КАК ТипОтветственногоЛица
	                      |ИЗ
	                      |	РегистрСведений.ОтветственныеЛица.СрезПоследних(
	                      |			,
	                      |			ТипОтветственногоЛица = ЗНАЧЕНИЕ(Перечисление.ТипыОтветственныхЛиц.ГлавныйБухгалтер)
	                      |				ИЛИ ТипОтветственногоЛица = ЗНАЧЕНИЕ(Перечисление.ТипыОтветственныхЛиц.Руководитель)
	                      |					И Организация = &Организация) КАК ОтветственныеЛицаСрезПоследних");
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Проставляет прочерки в незаполненных полях печатной формы счета-фактуры
//
Процедура ПроставитьПрочеркиВПустыеПоляСтрокиСчетФактура(ОбластьМакета)
	
	Для т = 0 По ОбластьМакета.Параметры.Количество() - 1 Цикл
		
		ТекПараметр = ОбластьМакета.Параметры.Получить(т);
		Если НЕ ЗначениеЗаполнено(ТекПараметр) Тогда
			ОбластьМакета.Параметры.Установить(т, "--");
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // ПроставитьПрочеркиВПустыеПоля()

// Получает Счет на оплату по документу реестра
//
// Параметры:
//  ДокументРеестра  - ДокументСсылка.РеестрОказаннойПомощи - ссылка на документ
//						чей счет необходимо получитьи.
//
// Возвращаемое значение:
//   ДокументСсылка.СчетНаОплатуКлиенту   - счет, по которому оплатил клиент.
//
Функция ПолучитьСчетРеестра(Знач ДокументРеестра) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.АктОказанияУслуг.ОказанныеУслуги КАК АктОказанияУслугОказанныеУслуги
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
	|		ПО АктОказанияУслугОказанныеУслуги.ДокументОснования = ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования
	|ГДЕ
	|	АктОказанияУслугОказанныеУслуги.Ссылка = &ДокументРеестра";

	Запрос.УстановитьПараметр("ДокументРеестра", ДокументРеестра);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ?(РезультатЗапроса.Пустой(), Неопределено, РезультатЗапроса.Выгрузить()[0].Ссылка);
	
КонецФункции

#КонецОбласти

#КонецЕсли