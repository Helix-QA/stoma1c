// Процедура - Установить вид оплаты лицевым счетом
// 
Процедура УстановитьВидОплатыЛицевымСчетомДляОплаты()
	
    ЭтоПродажа   = ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа;	
    ДеревоОплаты = ВидыОплат.ПолучитьЭлементы();
    
    // Получаем виды лицевых счетов и их баланс
    // Если это единая сеть брать для всех СЕ	
   	Если Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть Тогда
		ОстаткиНаЛС = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент, ТекущаяДатаСеанса(), , , , , Истина);			
	Иначе	
		ОстаткиНаЛС = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент, ТекущаяДатаСеанса(), , СтруктурнаяЕдиница, , , Истина);		
	КонецЕсли;

    СуммаОстаткаНаЛС = ?(ТипЗнч(ОстаткиНаЛС) = Тип("Число"), ОстаткиНаЛС, ОстаткиНаЛС.Итог("СуммаОстаток"));		
    
    Если СуммаОстаткаНаЛС > 0 Тогда 		
    	
    	СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.ЛицевойСчет);		
    	
    	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
    		
    		ЭлементДереваЛС                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
    		ЭлементДереваЛС.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет; 
    		ЭлементДереваЛС.Представление      = "Лицевые счета";
    		ЭлементДереваЛС.ВидЛицевогоСчета   = Справочники.ВидыЛицевыхСчетов.ПустаяСсылка();
    		ЭлементДереваЛС.СертификатПартия   = Справочники.ПартииНоменклатуры.ПустаяСсылка();
    		
    	Иначе
    		ЭлементДереваЛС = СущВидыОплатВерхУр[0];
    	КонецЕсли;
 
    	ОбщаяСуммаПоСчетам = 0;		
    	
    	Для Каждого СтрокаТЧ Из ОстаткиНаЛС Цикл	
    		
    		Если ЭтоПродажа = Ложь 
    			Или СтрокаТЧ.СуммаОстаток <> 0 Тогда
    			
    			Наименование = ?(ЗначениеЗаполнено(СтрокаТЧ.ВидСчета), СтрокаТЧ.ВидСчета.Наименование, "Общий");
				
    			ДопустимыйОстатокДляОплаты = 0;
				Если ЭтоПродажа = Истина Тогда
					
					ОплачиваемыеДокументы = ПолучитьДокументыЗадолженностиСервер(Истина);					
					ДопустимыйОстатокДляОплаты = СтрокаТЧ.СуммаОстаток;
					Если СтрокаТЧ.ВидСчета.ОграничиватьСуммуСписанияСоСчета
						И ЗначениеЗаполнено(СтрокаТЧ.ЛицевойСчет.ПроцентОграниченияСуммыСписанияСоСчета) Тогда
						
						ДопустимыйОстатокДляОплаты = (СтрокаТЧ.ВидСчета.ПроцентОграниченияСуммыСписанияСоСчета / 100) * ДопустимыйОстатокДляОплаты;
						
					КонецЕсли;
					
				КонецЕсли;	
				
    			// Получаем уже выбранную сумма по данному виду счета
    			СуммаИспользовано  = СуммаВнесенныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.ЛицевойСчет, СтрокаТЧ.ВидСчета,,,,СтрокаТЧ.Контрагент);			
    			СущВидыОплатНижнУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.ЛицевойСчет, СтрокаТЧ.ВидСчета,,,,,,,,, СтрокаТЧ.Контрагент);
    			
    			Если НЕ ЗначениеЗаполнено(СущВидыОплатНижнУр) Тогда
    				НоваяСтрока = ЭлементДереваЛС.ПолучитьЭлементы().Добавить();
    				НоваяСтрока.СертификатПартия   = Справочники.ПартииНоменклатуры.ПустаяСсылка();

    			Иначе
    				НоваяСтрока = СущВидыОплатНижнУр[0];
    			КонецЕсли;

    			НоваяСтрока.ВидЛицевогоСчета             = СтрокаТЧ.ВидСчета;
    			НоваяСтрока.Контрагент	        	     = СтрокаТЧ.Контрагент;
    			НоваяСтрока.ТипДенежныхСредств           = Перечисления.ТипыДенежныхСредств.ЛицевойСчет; 
    			НоваяСтрока.МаксСуммаСписания            = ДопустимыйОстатокДляОплаты;
    			НоваяСтрока.ОстатокСредств               = СтрокаТЧ.СуммаОстаток - СуммаИспользовано;			
    			НоваяСтрока.НаименованиеВидаОплаты       = Наименование;
    			НоваяСтрока.Представление                = "" + Наименование + ?(Контрагент <> СтрокаТЧ.Контрагент, " [" + СтрокаТЧ.Контрагент 
					+ ", " + РегистрыСведений.РодственныеСвязи.ОпределитьРодство(Контрагент, СтрокаТЧ.Контрагент) + "]", "") 
					+ " (" + Формат(НоваяСтрока.ОстатокСредств,"ЧДЦ=2; ЧН=0,00") + ")";					
    			НоваяСтрока.КассаОплаты                  = ЭтотОбъект.ТекущаяКасса;
    				
    			ОбщаяСуммаПоСчетам = ОбщаяСуммаПоСчетам + НоваяСтрока.ОстатокСредств;
    			
    		КонецЕсли;
    		
    	КонецЦикла;		
    	
    	// Установка заголовка лицевым счетам
    	ЭлементДереваЛС.ОстатокСредств  = ОбщаяСуммаПоСчетам;
    		
    КонецЕсли;
	
КонецПроцедуры	

&НаСервере
// Процедура - Установить вид оплаты лицевым счетом
// 
Процедура УстановитьВидОплатыЛицевымСчетомДляВозврата()
		
	ДеревоОплаты = ВидыОплат.ПолучитьЭлементы();
			
	Если Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть Тогда
		ОстаткиНаЛС = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент, ТекущаяДатаСеанса(), , , , , Истина);			
	Иначе	
		ОстаткиНаЛС = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент, ТекущаяДатаСеанса(), , СтруктурнаяЕдиница, , , Истина);		
	КонецЕсли;

    СуммаОстаткаНаЛС = ?(ТипЗнч(ОстаткиНаЛС) = Тип("Число"), ОстаткиНаЛС, ОстаткиНаЛС.Итог("СуммаОстаток"));
		
	СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(
							Перечисления.ТипыДенежныхСредств.ЛицевойСчет,
							Справочники.ВидыЛицевыхСчетов.ПустаяСсылка());		
	
	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
		
		ЭлементДереваЛС                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
		ЭлементДереваЛС.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет; 
		ЭлементДереваЛС.Представление      = "Лицевые счета";  
		
	Иначе
		ЭлементДереваЛС = СущВидыОплатВерхУр[0];
	КонецЕсли;
	
	ОбщаяСуммаПоСчетам = 0;		
	
	Если ТипЗнч(ОстаткиНаЛС) = Тип("ТаблицаЗначений") Тогда
			
		Для Каждого СтрокаТЧ ИЗ ОстаткиНаЛС Цикл
			
			Наименование = ?(ЗначениеЗаполнено(СтрокаТЧ.ВидСчета), СтрокаТЧ.ВидСчета.Наименование, "Общий");

			// Получаем уже выбранную сумма по данному виду счета
			СуммаИспользовано = СуммаВнесенныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.ЛицевойСчет, СтрокаТЧ.ВидСчета);
			
			СущВидыОплатНижнУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.ЛицевойСчет, СтрокаТЧ.ВидСчета,,,,,,,,,СтрокаТЧ.Контрагент);
			
			Если НЕ ЗначениеЗаполнено(СущВидыОплатНижнУр) Тогда
				НоваяСтрока = ЭлементДереваЛС.ПолучитьЭлементы().Добавить();
			Иначе
				НоваяСтрока = СущВидыОплатНижнУр[0];
			КонецЕсли;
			
			НоваяСтрока.ВидЛицевогоСчета             = СтрокаТЧ.ВидСчета;
			НоваяСтрока.Контрагент	        	     = СтрокаТЧ.Контрагент;
			НоваяСтрока.ТипДенежныхСредств           = Перечисления.ТипыДенежныхСредств.ЛицевойСчет; 
			
			НоваяСтрока.МаксСуммаСписания            = -1;
			НоваяСтрока.ОстатокСредств               = СтрокаТЧ.СуммаОстаток + СуммаИспользовано;
			
			НоваяСтрока.НаименованиеВидаОплаты       = Наименование;
			НоваяСтрока.Представление                = "" + Наименование + ?(Контрагент <> СтрокаТЧ.Контрагент, 
			" [" + СтрокаТЧ.Контрагент + ", " + РегистрыСведений.РодственныеСвязи.ОпределитьРодство(СтрокаТЧ.Контрагент, Контрагент) + "]", "");					
			
			НоваяСтрока.Контрагент                   = ЭтотОбъект.Контрагент;
			НоваяСтрока.КассаОплаты                  = ЭтотОбъект.ТекущаяКасса;
			
		КонецЦикла;		
		
	КонецЕсли;
		
КонецПроцедуры	

&НаСервере
// Процедура - Установить вид оплаты аванс
// 
Процедура УстановитьВидОплатыАвансом()
	
	ОстатокАванса = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокАвансаПоКонтрагенту(Контрагент, ТекущаяДатаСеанса(), СтруктурнаяЕдиница);
			
	Если ЗначениеЗаполнено(ОстатокАванса) Тогда
		
		СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.Аванс,,,,,,,, "Авансы");		
    	
    	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
    		
    		ЭлементДереваЛС                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
    		ЭлементДереваЛС.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс; 
    		ЭлементДереваЛС.Представление      = "Авансы";
    		    		
    	Иначе
    		ЭлементДереваЛС = СущВидыОплатВерхУр[0];
    	КонецЕсли;

		СуммаИспользовано = СуммаВнесенныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.Аванс);
		
		СуществВидыОплат = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.Аванс);
		
		Если НЕ ЗначениеЗаполнено(СуществВидыОплат) Тогда
			ЭлементДерева = ЭлементДереваЛС.ПолучитьЭлементы().Добавить();
		Иначе
			ЭлементДерева = СуществВидыОплат[0];
		КонецЕсли;
			
		ЭлементДерева.ТипДенежныхСредств      = Перечисления.ТипыДенежныхСредств.Аванс;	
		ЭлементДерева.ОстатокСредств          = ОстатокАванса - СуммаИспользовано;
		ЭлементДерева.МаксСуммаСписания       = ЭлементДерева.ОстатокСредств;
		ЭлементДерева.Контрагент	          = Контрагент;
		ЭлементДерева.Представление           = "Аванс (" + Формат(ЭлементДерева.ОстатокСредств, "ЧДЦ=2; ЧН=0,00") + ")" ;	
		ЭлементДерева.КассаОплаты             = ЭтотОбъект.ТекущаяКасса;
		
	КонецЕсли;
	
КонецПроцедуры

