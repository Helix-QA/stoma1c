&НаКлиенте
// Процедура - Критические остатки запись завершение.
//
// Параметры:
//  РезультатОтвета	 - 	 - 
//  ДопПараметры	 - 	 - 
//
Процедура КритическиеОстаткиЗаписьЗавершение(РезультатОтвета, ДопПараметры)  Экспорт
	
	Если ТипЗнч(РезультатОтвета) = Тип("Структура") Тогда
		
		ФормаЗаписана = Ложь;
		РезультатОтвета.Свойство("ФормаЗаписана", ФормаЗаписана);
		
		Если ФормаЗаписана <> Неопределено
			И ФормаЗаписана Тогда
			СкомпоноватьДанныеРезультата();
			ПроверкаФиксации();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВариантОтчета(СУчетомПарти)
	
	СхемаКомпоновкиДанных = РеквизитФормыВЗначение("Отчет").ЭтотОбъект.СхемаКомпоновкиДанных;
	Варианты = СхемаКомпоновкиДанных.ВариантыНастроек;
	СтруктураВариантов = Новый Структура();
    Для Каждого ЭлементВариантов ИЗ Варианты Цикл
        СтруктураВариантов.Вставить(ЭлементВариантов.Имя,ЭлементВариантов.Настройки);
	КонецЦикла; 
	Если СУчетомПарти = Ложь Тогда
		Настройки = СтруктураВариантов.СУчетомПартий;
	Иначе
		Настройки = СтруктураВариантов.БезУчетаПартий;
	КонецЕсли;
	ЭлементыПараметраДанных = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы;
	ЭлементыПараметраДанных.Найти("СтруктурнаяЕдиница").Значение = СтруктурнаяЕдиницаОтбор;
	ЭлементыПараметраДанных.Найти("СтруктурнаяЕдиница").Использование = Истина;
	
	Отчет.КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);
	
КонецПроцедуры

