&НаКлиенте
// Обработчик перед началом выбора значения номенклатуры
//
Процедура ЛечениеНоменклатураНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка   = Ложь;	
	Если НЕ ЗначениеЗаполнено(Объект.ДокументОснования) Тогда
		СтруктураПараметры     = Новый Структура();	
		МассивРазрешенныхТипов = Новый Массив;
		МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
		
		СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов"          , МассивРазрешенныхТипов); 
		СтруктураПараметры.Вставить("Заголовок"                            , "Выберите товар");	  
		СтруктураПараметры.Вставить("СтруктурнаяЕдиница"                   , Объект.СтруктурнаяЕдиница);   
		СтруктураПараметры.Вставить("Дата"                                 , Объект.Дата);
		СтруктураПараметры.Вставить("БуферВыбранныхЗначенийИспользовать"   , Ложь);
		
		ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры",
		СтруктураПараметры,,,,,
		Новый ОписаниеОповещения("ЛечениеНоменклатураНачалоВыбораЗавершение", ЭтотОбъект), 
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - После выбора услуги
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЛечениеНоменклатураНачалоВыбораЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
		Элементы.Лечение.ТекущиеДанные.Номенклатура = РезультатВыбора.Номенклатура;
		ЛечениеНоменклатураПриИзменении(Неопределено);
	КонецЕсли; 	
	
КонецПроцедуры

&НаКлиенте
// Обработчик при изменении значения номенклатуры 
//
Процедура ЛечениеНоменклатураПриИзменении(Элемент)	
	
	СтрокаТабличнойЧасти = Элементы.Лечение.ТекущиеДанные;	
	СтруктураДанные      = Новый Структура();
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);
	СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);	
	СтруктураДанные               = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);	
	СтрокаТабличнойЧасти.Цена     = СтруктураДанные.Цена;	
	Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.КоличествоУпаковок) Тогда
		СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
		СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС
	КонецЕсли;	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
	РассчитатьСуммуВСтрокеТабличнойЧасти("Лечение");
	
КонецПроцедуры


&НаКлиенте
// Обработчик при изменении значения количества  
//
Процедура ЛечениеКоличествоПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы["Лечение"].ТекущиеДанные;
	
	Если СтрокаТЧ.КоличествоУпаковок = 0 Тогда
		СтрокаТЧ.КоличествоУпаковок = 1;
	КонецЕсли;
	
	МаксимальноеКоличествоУпаковок = ПолучитьМаксимальноеКоличествоДляВозврата(Объект.ДокументОснования, СтрокаТЧ.КлючСтроки, Ложь, Объект.Ссылка);
	
	Если СтрокаТЧ.КоличествоУпаковок > МаксимальноеКоличествоУпаковок Тогда
		СтрокаТЧ.КоличествоУпаковок = МаксимальноеКоличествоУпаковок;
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТЧ);
	
	РассчитатьСуммуВСтрокеТабличнойЧасти("Лечение");
	
КонецПроцедуры

&НаКлиенте
// Обработчик при изменении значения цена  
//
Процедура ЛечениеЦенаПриИзменении(Элемент)
	РассчитатьСуммуВСтрокеТабличнойЧасти("Лечение");
КонецПроцедуры

&НаКлиенте
// Обработчик при изменении значения суммы 
//
Процедура ЛечениеСуммаПриИзменении(Элемент)
	СтрокаТабличнойЧасти = Элементы["Лечение"].ТекущиеДанные;
	ОбработкаТабличныхЧастейКлиент.ПриИзмененииСуммыВТабличнойЧасти(СтрокаТабличнойЧасти);	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПослеДобавленияСтрокиВТабличнуюЧасть(ИмяТаблицы,СтрокаЗапаса)
	
	// Дополнить таблицу запаса
	ЗначениеОбъект       = РеквизитФормыВЗначение("Объект");
	СтрокаДанныхПриемник = ЗначениеОбъект[ИмяТаблицы].Найти(СтрокаЗапаса.КлючСтроки, "КлючСтроки");	
	Если СтрокаДанныхПриемник = Неопределено Тогда		
		НоваяСтрока = Объект[ИмяТаблицы].Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЗапаса);	
	КонецЕсли; 	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект[ИмяТаблицы]);	
	// Дополнить таблицу скидок наценок
	СтруктураПоиска = Новый Структура("КлючСтроки, НоменклатураСкидки", СтрокаЗапаса.КлючСтроки, СтрокаЗапаса.Номенклатура);  	
	МассивСтрок     = Объект.ДокументОснования.СкидкиНаценки.НайтиСтроки(СтруктураПоиска);	
	Для каждого СтрокаМС из МассивСтрок Цикл
		НоваяСтрока = Объект.СкидкиНаценки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаМС);		
	КонецЦикла;	
	Объект.СуммаДокумента = Объект.Запасы.Итог("Всего")+ Объект.Лечение.Итог("Всего");	
	// Установить состояние формы
	УстановкаСостоянияЭлементовФормы();
	
КонецПроцедуры

&НаСервере
// Функция выполняет пересчет автоматических скидок в документе.
//
// Возвращаемое значение:
//  Булево - Истина, если автоматические скидки были рассчитаны.
//
Процедура ТабличныеЧастиПересчетПослеИзменений(ИмяТаблицы)
	
	мСуммаЗапасыБезСкидок  = Ценообразование.ПолучитьСуммуДокументаБезСкидки(Объект.Запасы);	
	мСуммаЛечениеБезСкидок = Ценообразование.ПолучитьСуммуДокументаБезСкидки(Объект.Лечение);
	СтруктураПараметров      = Новый Структура;
	СтруктураПараметров.Вставить("СуммаДокумента"  , мСуммаЗапасыБезСкидок + мСуммаЛечениеБезСкидок);
	СтруктураПараметров.Вставить("Получатель"      , Объект.Контрагент);
	СтруктураПараметров.Вставить("УчитыватьНДС"    , Истина);
	СтруктураПараметров.Вставить("ВидЦен"		   , Объект.ВидЦен);
	СтруктураПараметров.Вставить("ДатаСкидок"    , ?(Объект.Ссылка.Пустая() = Истина, ТекущаяДата(), Объект.Дата));
	// Формирование общей временной таблицы
	ВременнаяТаблица = Объект.Запасы.Выгрузить();
	Для Каждого СтрокаТ ИЗ Объект.Лечение Цикл
		НоваяСтрокаТ = ВременнаяТаблица.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаТ,СтрокаТ);
	КонецЦикла;
	// Расчет значений скидок/подарков по сводной таблице
	ЗначениеОбъект = РеквизитФормыВЗначение("Объект");
	
	// УправлениеМаркетинговымиАкциями.РассчитатьСкидкиПриПродаже(ЗначениеОбъект, ТаблицаЗапасы, ТаблицаЛечение, Неопределено, "СкидкиНаценки", "Подарки",,, СтруктураПараметров);
	ЗначениеВРеквизитФормы(ЗначениеОбъект, "Объект");	
	Для Каждого СтрокаТЧ Из Объект[ИмяТаблицы] Цикл
		// Возврат значения атоматической скидки из временной таблицы
		НайденныеСтроки                           = ВременнаяТаблица.НайтиСтроки(Новый Структура("КлючСтроки",СтрокаТЧ.КлючСтроки)); 
		СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки = ?(НайденныеСтроки.Количество()>0,НайденныеСтроки[0].СуммаАвтоматическойСкидкиНаценки,0);	
		// Пересчитываем сумму строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТЧ);
		// Пересчитываем сумму НДС строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТЧ);
		// Пересчитываем всего строки ТЧ
		ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТЧ);	
	КонецЦикла;	
	
	// Получаем временную таблицу из таблиц лечение и запасы
	ВременнаТаблица = Объект.Лечение.Выгрузить(,"ДокументАванса,Всего");
	Для Каждого СтрокаТ ИЗ Объект.Запасы Цикл
		НоваяСтрока = ВременнаТаблица.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТ);
	КонецЦикла;
	// Сворачиваем по документу аванса
	ВременнаТаблица.Свернуть("ДокументАванса","Всего");
	ИндексСтроки = 0;
	Пока ИндексСтроки < Объект.УчтенныеАвансы.Количество() Цикл
		СтрокаТЧ = Объект.УчтенныеАвансы[ИндексСтроки];
		НайденныеСтроки = ВременнаТаблица.НайтиСтроки(Новый Структура("ДокументАванса",СтрокаТЧ.ДокументАванса));  
		Если НайденныеСтроки.Количество() > 0 Тогда
			Если СтрокаТЧ.СуммаАванса > НайденныеСтроки[0].Всего Тогда
				СтрокаТЧ.СуммаАванса = НайденныеСтроки[0].Всего;
			КонецЕсли;	
			ИндексСтроки = ИндексСтроки + 1;
		Иначе	
		   Объект.УчтенныеАвансы.Удалить(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
