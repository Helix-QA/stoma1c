&НаКлиентеНаСервереБезКонтекста
// Функция - Получить вид сделки для генерации
//
// Параметры:
//  Запись						 - 	 - 
//  СделкаЗаписи				 - 	 - 
//  ТекущаяСделка				 - 	 - 
//  ТаблицаДоступныхВидовСделок	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВидСделкиДляГенерации(Запись, СделкаЗаписи, ТекущаяСделка, ЗНАЧ ТаблицаДоступныхВидовСделок)
	
	Если Запись.Пустая() И НЕ ЗначениеЗаполнено(СделкаЗаписи) И НЕ ЗначениеЗаполнено(ТекущаяСделка) Тогда 
		МассивВыбранныхДляГенерации = ТаблицаДоступныхВидовСделок.НайтиСтроки(Новый Структура("Выбран", Истина));
		Если МассивВыбранныхДляГенерации.Количество() > 0 Тогда 
			Возврат МассивВыбранныхДляГенерации[0].ВидСделки;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Первичная сделка без обращения
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  ВидСделки			 - 	 - 
//  Контрагент			 - 	 - 
//  ДатаСделки			 - 	 - 
//  ЗаявкаКлиента		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПервичнаяСделкаБезОбращения(СтруктурнаяЕдиница, ВидСделки, Контрагент, ДатаСделки = Неопределено, ЗаявкаКлиента = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(ДатаСделки) Тогда 
		ДатаСделки = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ПризнакПервичнойСделки = Справочники.Сделки.ВернутьПризнакПервичногоПациента(, ВидСделки, Контрагент, ДатаСделки);
	Если ПризнакПервичнойСделки = Перечисления.СтатусыКонтрагентов.Первичный Тогда 
		ЗаявкаКлиента = Справочники.Заявки.ПолучитьЗаявкуКонтрагента(Контрагент, , СтруктурнаяЕдиница, Истина);
		Если НЕ ЗначениеЗаполнено(ЗаявкаКлиента) Тогда
			МассивНомеровТелефона = Справочники.Контрагенты.ПолучитьМассивНомеровТелефонаКонтрагента(Контрагент);
			ЗаявкаКлиента = Справочники.Заявки.ПолучитьЗаявкуПоНомеруТелефона(МассивНомеровТелефона, , СтруктурнаяЕдиница, Истина);	
		КонецЕсли;	
		Возврат НЕ ЗначениеЗаполнено(ЗаявкаКлиента); 
	КонецЕсли;	
	
	Возврат Ложь;
	
КонецФункции	

&НаСервере
// Процедура, ОбновитьВиджетСделки.
//
Процедура ОбновитьВиджетСделки(ОбновитьВиджетГенерации = Ложь, АктуализироватьДанные = Истина, ОбновитьСтатус = Ложь) Экспорт 
	// Процедура экспортная т.к. вызывается из расширения журнала записи.
	Если ОбновитьВиджетГенерации Тогда 
		УправлениеИнтерфейсамиСервер.ОбновитьВиджетВыбораВидаГенерируемойСделки(ЭтаФорма, Неопределено, Неопределено, АктуализироватьДанные);
	Иначе 
		УправлениеИнтерфейсамиСервер.ОбновитьВиджетСделки(ЭтаФорма, Объект.Контрагент, Объект.Сделка, АктуализироватьДанные);		
	КонецЕсли;
	Если ОбновитьСтатус Тогда 
		УстановитьСвойстваЭлементамПодтвержденияЗаписи();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик нажати динамического элемента виджета выбор вида сделки
//
// Параметры:
//  ИмяКоманды	 - 	 - 
//
Процедура ОбработчикНажатиДинамическогоЭлементаВиджетаВыборВидаСделки(Команда) Экспорт
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаВиджетаСделки(ЭтотОбъект, Команда);
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		
		Врач = Неопределено;
		Если НЕ Объект.Услуги.Количество() = 0 Тогда 
			Врач = Объект.Услуги[0].Сотрудник;
		КонецЕсли;
		
		ВыбранныйВидСделки 	= Неопределено;
		ВыбранныйЭтап 		= Неопределено; 
		МассивСтрок = ТаблицаДоступныхВидовСделок.НайтиСтроки(Новый Структура("Выбран", Истина));
		Если МассивСтрок.Количество() > 0 Тогда 
			ВыбранныйВидСделки = МассивСтрок[0].ВидСделки;
			МассивСтрок = МассивСтрок[0].ТаблицаЭтапов.НайтиСтроки(Новый Структура("Выбран", Истина));
			Если МассивСтрок.Количество() > 0 Тогда 
				ВыбранныйЭтап = МассивСтрок[0].Этап;
			КонецЕсли;				
		КонецЕсли;
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент"					, Объект.Контрагент);
		ПараметрыФормы.Вставить("Врач"							, Врач);
		ПараметрыФормы.Вставить("ВыбратьВидГенерируемойСделки"	, Истина);
		ПараметрыФормы.Вставить("ВыбранныйВидСделки"			, ВыбранныйВидСделки);
		ПараметрыФормы.Вставить("ВыбранныйЭтап"					, ВыбранныйЭтап);
		                                                
		ОткрытьФорму("Справочник.Сделки.Форма.ФормаВиджета"
					, ПараметрыФормы
					, ЭтаФорма,,,
					, Новый ОписаниеОповещения("ВыборВидаГенерируемойСделки", ЭтотОбъект, Новый Структура("ВыбранныйВидСделки, ВыбранныйЭтап", ВыбранныйВидСделки, ВыбранныйЭтап))
					, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;

КонецПроцедуры

