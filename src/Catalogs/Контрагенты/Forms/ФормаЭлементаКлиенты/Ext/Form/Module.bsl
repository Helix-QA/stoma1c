	Возврат ?(Флаг, НСтр("ru='Рассылка запрещена';en='Newsletter is prohibited'"), НСтр("ru='Рассылка разрешена';en='Newsletter is allowed'"));
	
КонецФункции

&НаСервере
// Функция возвращает таблицу типов контактной информации в порядке по умолчанию
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Стандартный порядок типов контактной информации для отображения в интерфейсе
//
Функция ПорядокТиповКИ()
	
	ПорядокТиповКИ = Новый ТаблицаЗначений;
	ПорядокТиповКИ.Колонки.Добавить("Тип"	 , Новый ОписаниеТипов("ПеречислениеСсылка.ТипыКонтактнойИнформации"));
	ПорядокТиповКИ.Колонки.Добавить("Порядок", Новый ОписаниеТипов("Число"));
	
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Телефон			   , 1);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, 2);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Адрес				   , 3);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Факс				   , 4);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Skype				   , 5);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.СоциальнаяСеть	   , 6);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.МобильноеПриложение  , 7);
	
	Возврат ПорядокТиповКИ;
	
КонецФункции

