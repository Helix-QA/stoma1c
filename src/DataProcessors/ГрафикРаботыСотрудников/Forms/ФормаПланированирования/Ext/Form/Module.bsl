// Функция - Список шаблонов содержит структуру интервалов
// 
// Возвращаемое значение:
//   - 
// 
Функция СписокШаблоновСодержитСтруктуруИнтервалов()
	
	СписокШаблоновПуст 		= СписокШаблонов.Количество() = 0;
	ЕстьПопадание 			= Ложь;
	ИндексШаблона 			= Неопределено;
	Информация 				= "";
	ИнтервалыСформированы 	= Истина;
	СовпадаетПоКоличеству 	= Истина;
	МассивСовпавших 		= Новый Массив;
	
	// Проверим сформированы ли интервалы
	Если НЕ ФормированиеИнтерваловЗавершено(Ложь) Тогда 
		ИнтервалыСформированы = Ложь;
		Информация = "Формирование интервалов работы в панели не завершено. Сохранение шаблона не возможно.";
	КонецЕсли;
	
	// Начинаем сравнение
	Если НЕ СписокШаблоновПуст И ИнтервалыСформированы Тогда
		
		Для Каждого Шаблон Из СписокШаблонов Цикл
			
			// Проверяем на совпадение по количеству
			Если НЕ Шаблон.Значение.Количество() = ОтборИнтервалыРаботы.Количество() Тогда 
				СовпадаетПоКоличеству = Ложь;
				Продолжить;
			Иначе 
				СовпадаетПоКоличеству = Истина;
			КонецЕсли;
			
			// Дальше проверяем на совпадение
			Для Каждого ИнтервалШаблона Из Шаблон.Значение Цикл 
				
				ИнтервалСовпал = Ложь;
				Для Каждого ИнтервалСписка Из ОтборИнтервалыРаботы Цикл 
					Если ИнтервалСписка.Значение.НачалоРаботы = ИнтервалШаблона.Значение.НачалоРаботы И ИнтервалСписка.Значение.ОкончаниеРаботы = ИнтервалШаблона.Значение.ОкончаниеРаботы Тогда 
						ИнтервалСовпал = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				Если ИнтервалСовпал Тогда
					МассивСовпавших.Добавить(ИнтервалШаблона.Значение);
				Иначе
					МассивСовпавших.Очистить();
					Прервать;
				КонецЕсли;	
				
			КонецЦикла;
			
			Если МассивСовпавших.Количество() = Шаблон.Значение.Количество() Тогда 
				ЕстьПопадание = Истина;
				ИндексШаблона = СписокШаблонов.Индекс(Шаблон);
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Новый Структура("Успех, ИндексШаблона, Информация", ЕстьПопадание, ИндексШаблона, Информация);
	
КонецФункции

