// Функция - Выполнить операцию по платежной карте.
//
Функция ВыполнитьОперациюПоПлатежнойКарте(ОписаниеОшибки = Неопределено)
	
	СтрокиОплаты  = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта"));
	ДанныеПлатежа = Неопределено;
	
	Если ЗначениеЗаполнено(СтрокиОплаты) Тогда
		
		ФрПодключен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Касса                , "ИспользоватьБезПодключенияОборудования") = Ложь;
		ЭтПодклчюен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭквайринговыйТерминал, "ИспользоватьБезПодключенияОборудования") = Ложь;
		
		Если ЗначениеЗаполнено(ЭквайринговыйТерминал) И ФрПодключен И ЭтПодклчюен Тогда    
			
			СсылкаНаобрудованиеФР = ПолучитьФРКассы(Касса);
			ДанныеПлатежа         = МенеджерОборудованияКлиент.ВыполнитьПоступлениеПлатежаЭквайринг(
																	ЭквайринговыйТерминал, 
																	СсылкаНаобрудованиеФР, 
																	ЭтаФорма.УникальныйИдентификатор,
																	СтрокиОплаты[0].Внесено,
																	ОписаниеОшибки);       
			
		Иначе
			Возврат Новый Структура("НомерКарты, СсылочныйНомер, НомерЧека", Неопределено, Неопределено, Неопределено);
		КонецЕсли;
		
	Конецесли;
	
	Возврат ДанныеПлатежа;
	
КонецФункции

