&НаСервереБезКонтекста
// Функция - Получить список доступных мест работы
//
// Параметры:
//  ТЧ_МестаРаботы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокДоступныхПромокодов(Знач ТаблицаПромокодов)
	
	СписокДоступныхПромокодовДляВыбора = Новый СписокЗначений;
	
	МассивДобавленныхПромокодов = ТаблицаПромокодов.Выгрузить().ВыгрузитьКолонку("ПромокодСсылка");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Промокоды.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Промокоды КАК Промокоды
	|ГДЕ
	|	Промокоды.Реферальный
	|	И НЕ Промокоды.ПометкаУдаления
	|	И НЕ Промокоды.Ссылка В (&МассивСсылок)
	|	И НЕ Промокоды.Владельцы");
	
	Запрос.УстановитьПараметр("МассивСсылок", МассивДобавленныхПромокодов);
	
	МассивДобавляемыхПромокодов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Для Каждого ЭлементМассива Из МассивДобавляемыхПромокодов Цикл
		СписокДоступныхПромокодовДляВыбора.Добавить(ЭлементМассива, Строка(ЭлементМассива),, БиблиотекаКартинок.Реквизит);
	КонецЦикла;	
	
	Возврат СписокДоступныхПромокодовДляВыбора;
	
КонецФункции

&НаКлиенте 
// Процедура - Завершения выбора промокода.
//
Процедура ЗавершениеВыбораПромокода(ВыбранныйЭлемент, Параметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда 
		
		Возврат;
		
	ИначеЕсли ЗначениеЗаполнено(ВыбранныйЭлемент.Значение) Тогда 
		
		НоваяСтрока		 		 	 = ЭтотОбъект.ПромокодыСуществующие.Добавить();
		НоваяСтрока.ПромокодСсылка	 = ВыбранныйЭлемент.Значение;
		НоваяСтрока.Промокод		 = ЗаписатьИПолучитьПромокод(Объект.Ссылка, ВыбранныйЭлемент.Значение);
		НоваяСтрока.Активен			 = Истина;
		
		Оповестить("ОбновленыПромокоды"); 
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
