&НаСервере
// Процедура, Получить высоту SVG подбора
//
Процедура ПолучитьВысотуSVGПодпора();
	
	РазрешениеЭкрана = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьТекущееРазрешениеЭкрана();
	ШиринаЭкрана	 = Сред(РазрешениеЭкрана, 1, Найти(РазрешениеЭкрана, "*") - 1);
	
	Если ШиринаЭкрана = "1280" Тогда 
		ВысотаSVGПодбора = "83px";
		ЭтаФорма.Масштаб = 88;
	ИначеЕсли ШиринаЭкрана = "1360" Тогда 
		ВысотаSVGПодбора = "85px";
		ЭтаФорма.Масштаб = 94;
	ИначеЕсли ШиринаЭкрана = "1366" Тогда 
		ВысотаSVGПодбора = "85px";
		ЭтаФорма.Масштаб = 94;
	ИначеЕсли ШиринаЭкрана = "1400" Тогда 
		ВысотаSVGПодбора = "93px";		
		ЭтаФорма.Масштаб = 95;
	ИначеЕсли ШиринаЭкрана = "1440" Тогда 
		ВысотаSVGПодбора = "95px";	
	ИначеЕсли ШиринаЭкрана = "1600" Тогда 
		ВысотаSVGПодбора = "94px";		
	ИначеЕсли ШиринаЭкрана = "1680" Тогда 
		ВысотаSVGПодбора = "95px";     
	ИначеЕсли ШиринаЭкрана = "1920" Тогда 
		ВысотаSVGПодбора = "95px";		  
	Иначе
		ВысотаSVGПодбора = "135px";
	КонецЕсли;	

КонецПроцедуры

&НаСервере
// Создать динамические элементы.
//
Процедура СоздатьДинамическиеКнопки(СтруктураМеню)
	
	ОснГруппа = Элементы.ГруппаОбследование;
	Пока ОснГруппа.ПодчиненныеЭлементы.Количество() > 1 Цикл
		Элементы.Удалить(ОснГруппа.ПодчиненныеЭлементы[1]);
	КонецЦикла;
	
	Индекс = 0;

	Для Каждого Элемент Из СтруктураМеню Цикл
		НоваяГруппа             = Элементы.Добавить("ГруппаКнопок_" + Индекс, Тип("ГруппаФормы"), ОснГруппа);
		НоваяГруппа.Вид 		= ВидГруппыФормы.ОбычнаяГруппа;
		НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная; 
		НоваяГруппа.РастягиватьПоГоризонтали = Истина;
		//НоваяГруппа.ПодчиненныеЭлементы = ГоризонтальноеПоложениеЭлемента.Центр;
				
		НоваяГруппа.ОтображатьЗаголовок = Ложь;
		
		ЗначениеОбследования = ТалицаВводимогоТекста.НайтиСтроки(Новый Структура("Реквизит",Элемент.ЗначениеМеню));
		
		ЗаголовокЗуб = "";
		Если ЗначениеЗаполнено(ЗначениеОбследования) Тогда
			Для Каждого ЭлМассив Из ЗначениеОбследования Цикл
				Если ЗначениеЗаполнено(ЭлМассив.ЗубЗначение) Тогда
					Если СтрНайти(ЗаголовокЗуб, Строка(ЭлМассив.ЗубЗначение)) = 0 Тогда
						ЗаголовокЗуб = ЗаголовокЗуб + "(" + Строка(ЭлМассив.ЗубЗначение) + ")";
					КонецЕсли;
				Иначе                                                                  
					Если СтрНайти(ЗаголовокЗуб, "(*)") = 0 Тогда
						ЗаголовокЗуб = ЗаголовокЗуб + "(*)";                               
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// Добавим кнопку переключателя
		НовыйЭлемент_Кнопка 					= Элементы.Добавить(СтроковыеФункцииКлиентСервер.ЗаменитьОдниСимволыДругими(" ,",Элемент.ЗначениеМеню.Наименование, ""), Тип("КнопкаФормы"), НоваяГруппа);
		НовыйЭлемент_Кнопка.Заголовок 			= СокрЛП(Элемент.ЗначениеМеню.Наименование) + ЗаголовокЗуб; 
		Если СтрДлина(НовыйЭлемент_Кнопка.Заголовок) > 20 Тогда
			НовыйЭлемент_Кнопка.ВысотаЗаголовка = 2;
		КонецЕсли;
		НовыйЭлемент_Кнопка.ЦветТекста 			= Новый Цвет(51, 51, 51);
		НовыйЭлемент_Кнопка.Шрифт 				= Новый Шрифт("Arial", 10);
		НовыйЭлемент_Кнопка.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
		НовыйЭлемент_Кнопка.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
		НовыйЭлемент_Кнопка.РастягиватьПоГоризонтали = Истина;
		// Добавим команду
		НоваяКоманда 							= Команды.Найти(СтроковыеФункцииКлиентСервер.ЗаменитьОдниСимволыДругими(" ,",Элемент.ЗначениеМеню.Наименование, ""));
		Если НоваяКоманда = Неопределено Тогда 
			НоваяКоманда 						= Команды.Добавить(СтроковыеФункцииКлиентСервер.ЗаменитьОдниСимволыДругими(" ,",Элемент.ЗначениеМеню.Наименование, ""));
			НоваяКоманда.Действие 				= "Подключаемый_ОткрытьЭлементОбследования";				
		КонецЕсли;
		НовыйЭлемент_Кнопка.ИмяКоманды 			= НоваяКоманда.Имя;
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере 
// Процедура - Заблокировать записи по приему.
//
// Параметры:
//  Прием	 - 	 - 
//
Процедура ЗаблокироватьЗаписиПоПриему(Прием, Отказ)
	
	 Если ЗначениеЗаполнено(Прием) Тогда 
			
		Запрос = новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗначенияПараметровОбследований.Документ КАК Документ,
		|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
		|	ЗначенияПараметровОбследований.Параметр КАК Параметр,
		|	ЗначенияПараметровОбследований.Зуб КАК Зуб,
		|	ЗначенияПараметровОбследований.Значение КАК Значение,
		|	ЗначенияПараметровОбследований.ПорядковыйНомер КАК ПорядковыйНомер,
		|	ЗначенияПараметровОбследований.ЗначениеСтрокой КАК ЗначениеСтрокой
		|ИЗ
		|	РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
		|ГДЕ
		|	ЗначенияПараметровОбследований.Документ = &Прием";
		
		Запрос.УстановитьПараметр("Прием", Прием);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если Не РезультатЗапроса.Пустой() Тогда 
			
			Выборка = РезультатЗапроса.Выбрать();			
			РегистрСв = РегистрыСведений.ЗначенияПараметровОбследований;
			
			Пока Выборка.Следующий() Цикл	
				СтруктураСтроки = Новый Структура;
				
				СтруктураСтроки.Вставить("Документ"				, Выборка.Документ);
				СтруктураСтроки.Вставить("ШаблонОбследования"	, Выборка.ШаблонОбследования);
				СтруктураСтроки.Вставить("Параметр"				, Выборка.Параметр);
				СтруктураСтроки.Вставить("Зуб"					, Выборка.Зуб);
				СтруктураСтроки.Вставить("Значение"				, Выборка.Значение);
				
				Попытка
					ЗаблокироватьДанныеДляРедактирования(РегистрСв.СоздатьКлючЗаписи(СтруктураСтроки),, Этаформа.УникальныйИдентификатор);	
				Исключение 
					ОбщегоНазначения.СообщитьПользователю(ИнформацияОбОшибке().Причина.Описание);
					Отказ = Истина;
					Прервать;
				КонецПопытки;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
	
&НаКлиенте
// Процедура - Подключаемый открыть элемент обследования
//
Процедура Подключаемый_ОткрытьЭлементОбследования(Элемент)
	
	ИскомаяЗакладка = ТалицаВводимогоТекста.НайтиСтроки(Новый Структура("ЗначениеЗакладки, ЗубЗначение", ПредЗакладка, ПредЗуб));
	Если ИскомаяЗакладка.Количество() > 0 Тогда
		ИскомаяЗакладка[0].ВводимыйТекст = ВводимыйТекст;
	ИначеЕсли ЗначениеЗаполнено(ВводимыйТекст) Тогда
		НоваяСтрока = ТалицаВводимогоТекста.Добавить();
		НоваяСтрока.ЗначениеЗакладки 		= ПредЗакладка;
		НоваяСтрока.ВводимыйТекст 	 		= ВводимыйТекст;
        НоваяСтрока.РеквизитИдентификатор 	= Новый УникальныйИдентификатор;  

		НоваяСтрока.ЗубЗначение 	 		= Элемент.ЗубЗначение; 
		НоваяСтрока.РеквизитЗначениеСтрокой = Элемент.РеквизитЗначениеСтрокой;
		НоваяСтрока.РеквизитЗначение        = Элемент.РеквизитЗначение;
		НоваяСтрока.Реквизит                = Элемент.Реквизит;
		НоваяСтрока.ЗубИдентификатор        = Элемент.ЗубИдентификатор;
					
	КонецЕсли;
	ПредЗакладка = Элемент.Имя;
	ИскомаяЗакладка = ТалицаВводимогоТекста.НайтиСтроки(Новый Структура("ЗначениеЗакладки", ПредЗакладка));
	ВводимыйТекст = "";
	Если ИскомаяЗакладка.Количество() > 0 Тогда
		Для Каждого ЭлМассива Из ИскомаяЗакладка Цикл 
			Если Не ЗначениеЗаполнено(ЭлМассива.ЗубЗначение) Тогда
				ВводимыйТекст = ЭлМассива.ВводимыйТекст;              
			КонецЕсли; 
		КонецЦикла;
	КонецЕсли; 
	
	МассивЗаголовков = СтруктураМеню.НайтиСтроки(Новый Структура("ЗначениеБезПробелов", Строка(ПредЗакладка)));
	Если ЗначениеЗаполнено(МассивЗаголовков) Тогда
		ЭтаФорма.Заголовок = Строка(МассивЗаголовков[0].ЗначениеМеню);
	КонецЕсли;
	
	УстановитьАктивнуюЗакладку(Строка(ПредЗакладка));
	МассивВыделенныхЗубов.Очистить();
	ОбновитьSVGПодбор();
	
КонецПроцедуры

&НаСервере 
// Процедура - устанавливает активную закладку
//
Процедура УстановитьАктивнуюЗакладку(Закладка);
	
	// Убираем выделение групп.
	Для каждого Группа Из Элементы.ГруппаОбследование.ПодчиненныеЭлементы Цикл
		Если Группа.Имя <> "ДекорацияЗаглушка" Тогда
			Группа.ЦветФона = Новый Цвет(242, 242, 242);
			Для каждого Кнопка Из Группа.ПодчиненныеЭлементы Цикл
				Кнопка.ЦветТекста = Новый Цвет(77, 77, 77);
			КонецЦикла;                
		КонецЕсли;
	КонецЦикла;
	
	// Устанавливаем выделение выбранной группы метода авторизации.
	Элементы.Найти(Закладка).Родитель.ЦветФона = Новый Цвет(25 , 116, 206);
	Элементы.Найти(Закладка).ЦветТекста = Новый Цвет(255, 255, 255); 
	
	МассивЗаголовков = СтруктураМеню.НайтиСтроки(Новый Структура("ЗначениеБезПробелов", Строка(Закладка)));
    Если ЗначениеЗаполнено(МассивЗаголовков) Тогда
		ИскомаяЗакладка = Строка(МассивЗаголовков[0].ЗначениеМеню);
		Элементы.ГруппаПодборЗубов.Видимость = ПланыВидовХарактеристик.ПараметрыОбследований.НайтиПоНаименованию(ИскомаяЗакладка).ПривязкаКЗубам;
	КонецЕсли;
	
КонецПроцедуры


