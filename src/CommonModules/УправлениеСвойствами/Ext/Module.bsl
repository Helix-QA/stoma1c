					Команда.Подсказка 	= Команда.Заголовок;
					Команда.Действие 	= "Подключаемый_Оплатить_Визит";
				Иначе
					Команда.Подсказка   = СокрЛП(ЗаголовокКнопкиОплаты);
				КонецЕсли;
				
				Кнопка = Форма.Элементы.Добавить("Кнопка_Оплаты_Визита", Тип("КнопкаФормы"), Группа_Кнопки_Оплаты);
				Кнопка.ИмяКоманды 				= "Подключаемый_Оплатить_Визит";
				Кнопка.Заголовок 				= СокрЛП(ЗаголовокКнопкиОплаты);
				Кнопка.ОтображениеФигуры    	= ОтображениеФигурыКнопки.Нет;
				Кнопка.ЦветТекста				= Новый Цвет(0,0,0);
