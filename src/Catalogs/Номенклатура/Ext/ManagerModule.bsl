	РедактируемыеРеквизиты = Новый Массив;
	
	РедактируемыеРеквизиты.Добавить("ТипНоменклатуры");
	РедактируемыеРеквизиты.Добавить("ЕдиницаИзмерения");
	РедактируемыеРеквизиты.Добавить("ИспользоватьПартии");
	РедактируемыеРеквизиты.Добавить("Комментарий");
	РедактируемыеРеквизиты.Добавить("Номинал");
	// РедактируемыеРеквизиты.Добавить("ВидНоминала");
	РедактируемыеРеквизиты.Добавить("Периодичность");
	РедактируемыеРеквизиты.Добавить("СтавкаНДС");
	// РедактируемыеРеквизиты.Добавить("УпаковкаДляОтчета");
	// РедактируемыеРеквизиты.Добавить("УпаковкаПоУмолчанию");
	РедактируемыеРеквизиты.Добавить("НормаВремени");
	РедактируемыеРеквизиты.Добавить("ТипСрокаДействия");
	РедактируемыеРеквизиты.Добавить("КоличествоПериодовДействия");
	РедактируемыеРеквизиты.Добавить("ДатаОкончанияДействия");	
	// РедактируемыеРеквизиты.Добавить("ВидСертификата");
	РедактируемыеРеквизиты.Добавить("ЭтоИменнойСертификат");
	РедактируемыеРеквизиты.Добавить("СертификатМногоразовоеИспользование");
	РедактируемыеРеквизиты.Добавить("Гарантия");
    РедактируемыеРеквизиты.Добавить("СкидкиЗапрещены");
	РедактируемыеРеквизиты.Добавить("Специализация");
	РедактируемыеРеквизиты.Добавить("ВПродаже");
	
	Возврат РедактируемыеРеквизиты;
	
КонецФункции

// Функция расширенного отбора номенклатур
// Возврат значений: Артикул, Номенклатура, Родитель, Цена, ИндКартинки, ЕдиницаИзмерения,НормаВремени
Функция ОтборНоменклатур(ОтборДата = Неопределено,
	                     ОтборСтруктурнаяЕдиница = Неопределено,
						 ОтборСегмент = Неопределено,
						 ОтборСписокРазрешенныхТипов = Неопределено,
						 ОтборВидЦен = Неопределено,
						 ОтборТолькоРеализованныхСертификатов = Неопределено,
						 ПараметрыФильтра = Неопределено,
						 ОтборТолькоПоНаименованию = Ложь,
						 ОтборТолькоПоАртикулу = Ложь,
						 ОтборСегментПоСогласованию = Неопределено,
						 ОтборВПродаже = Истина,
						 ОтборПоДоговоруПолиса = Неопределено,
						 ПолисМедСтрахования = Неопределено) Экспорт
	
	ОтборПоНаименованию = Неопределено;	
	Если ЗначениеЗаполнено(ПараметрыФильтра) Тогда
		ОтборПоНаименованию = ПараметрыФильтра;
	КонецЕсли;
	
	// Подготовка массива отбора по сегментам
	ОтборСегментМассив = Неопределено;
	Если ОтборСегмент <> Неопределено И НЕ ОтборСегмент = Справочники.СегментыНоменклатуры.ПустаяСсылка() Тогда
		Если ТипЗнч(ОтборСегмент) = Тип("Массив") ИЛИ ТипЗнч(ОтборСегмент) = Тип("СписокЗначений") Тогда
			ОтборСегментМассив = ОтборСегмент;
		Иначе	
			ОтборСегментМассив = Новый Массив;
			ОтборСегментМассив.Добавить(ОтборСегмент);
		КонецЕсли;
	Иначе
		ОтборСегментМассив = Новый Массив;
		ОтборСегментМассив.Добавить("Все");
	КонецЕсли;
	
	ОтборДоговорПоПолисуМассив = Новый Массив;
	Если ОтборПоДоговоруПолиса = Неопределено ИЛИ ОтборПоДоговоруПолиса = Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда
		ОтборДоговорПоПолисуМассив.Добавить("Отсутствует");		
	Иначе
		ОтборДоговорПоПолисуМассив.Добавить(ОтборПоДоговоруПолиса);	
	КонецЕсли;

	ПодсчетКоличестваОказанныхУслугПоПолису = Новый Массив;
	Если ПолисМедСтрахования = Неопределено ИЛИ ПолисМедСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПустаяСсылка() Тогда
		ПодсчетКоличестваОказанныхУслугПоПолису.Добавить("Отсутствует");		
	Иначе
		ПодсчетКоличестваОказанныхУслугПоПолису.Добавить(ПолисМедСтрахования);	
	КонецЕсли;
	
	
	ОтборВПродаже = ?(ОтборВПродаже = Истина, Истина, Ложь);
	
	// Запрос к справочнику номенклатур
	ВыборкаНоменклатур      = Новый Запрос;
	ВыборкаНоменклатур.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапросЛечение.Номенклатура КАК ЛечениеНоменклатура,
	|	СУММА(ВложенныйЗапросЛечение.Количество) КАК ЛечениеКоличество
	|ПОМЕСТИТЬ ВТОказаноПоПолису
	|ИЗ
	|	Документ.Прием КАК Прием
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СУММА(ПриемЛечение.Количество) КАК Количество,
	|			ПриемЛечение.Номенклатура КАК Номенклатура,
	|			ПриемЛечение.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.Прием.Лечение КАК ПриемЛечение
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ПриемЛечение.Номенклатура,
	|			ПриемЛечение.Ссылка) КАК ВложенныйЗапросЛечение
	|		ПО Прием.Ссылка = ВложенныйЗапросЛечение.Ссылка
	|ГДЕ
	|	Прием.ПолисМедСтрахования В(&ПолисМедСтрахования)
	|	И НЕ ""Отсутствует"" В (&ПолисМедСтрахования)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапросЛечение.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура КАК Номенклатура,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Согласование КАК Согласование,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Количество КАК Количество,
	|	ДоговорыКонтрагентовУслугиПоДоговору.КоличествоПриПревышении КАК КоличествоПриПревышении,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.КоличествоЗубов, 0) КАК КоличествоЗубов,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.КоличествоВПриеме, 0) КАК КоличествоВПриеме,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.НаименованиеОграничения, """") КАК НаименованиеОграничения
	|ПОМЕСТИТЬ ВТУслугиПоДоговору
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов.ОграничениеЗубов КАК ДоговорыКонтрагентовОграничениеЗубов
	|		ПО ДоговорыКонтрагентовУслугиПоДоговору.Ссылка = ДоговорыКонтрагентовОграничениеЗубов.Ссылка
	|			И ДоговорыКонтрагентовУслугиПоДоговору.КлючСтроки = ДоговорыКонтрагентовОграничениеЗубов.КлючСтроки
	|ГДЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Ссылка В(&СсылкаДоговорПоПолису)
	|	И НЕ ""Отсутствует"" В (&СсылкаДоговорПоПолису)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СписокНоменклатуры.Артикул КАК Артикул,
	|	СписокНоменклатуры.Ссылка КАК Номенклатура,
	|	СписокНоменклатуры.Родитель КАК Родитель,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1) КАК Цена,
	|	ВЫБОР
	|		КОГДА СписокНоменклатуры.Ссылка.ЭтоГруппа = ИСТИНА
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА СписокНоменклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор)
	|					ТОГДА 4
	|				ИНАЧЕ 2
	|			КОНЕЦ
	|	КОНЕЦ КАК ИндКартинки,
	|	СписокНоменклатуры.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СписокНоменклатуры.НормаВремени КАК НормаВремени,
	|	СписокНоменклатуры.УпаковкаПоУмолчанию КАК Упаковка,
	|	СписокНоменклатуры.СкидкиЗапрещены КАК СкидкиЗапрещены,
	|	СписокНоменклатуры.Наименование КАК Наименование,
	|	ВЫБОР
	|		КОГДА &СегментПоСогласованию <> НЕОПРЕДЕЛЕНО
	|			ТОГДА ВЫБОР
	|					КОГДА ОтборНоменклатураСегмента.Сегмент = &СегментПоСогласованию
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НоменклатураПоСогласованию,
	|	СписокНоменклатуры.Бесплатно КАК Бесплатно,
	|	ВТУслугиПоДоговору.Согласование КАК ПолисСогласование,
	|	ВТУслугиПоДоговору.Количество КАК ПолисКоличество,
	|	ВТУслугиПоДоговору.КоличествоПриПревышении КАК ПолисКоличествоПриПревышении,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТУслугиПоДоговору.Количество, НЕОПРЕДЕЛЕНО) = 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПолисНеограничено,
	|	ВТУслугиПоДоговору.КоличествоЗубов КАК КоличествоЗубов,
	|	ВТУслугиПоДоговору.КоличествоВПриеме КАК КоличествоВПриеме,
	|	ВТУслугиПоДоговору.НаименованиеОграничения КАК НаименованиеОграничения
	|ИЗ
	|	Справочник.Номенклатура КАК СписокНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&НаДату,
	|				Актуальность = ИСТИНА
	|					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					И ВидЦен = &ВидЦен
	|					И Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО СписокНоменклатуры.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			НоменклатураСегмента.Сегмент КАК Сегмент,
	|			НоменклатураСегмента.Номенклатура КАК Номенклатура
	|		ИЗ
	|			РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|		ГДЕ
	|			НоменклатураСегмента.Сегмент В(&Сегмент)
	|			И НЕ ""Все"" В (&Сегмент)
	|			И ВЫБОР
	|					КОГДА НЕ &СписокРазрешенныхТипов ЕСТЬ NULL
	|						ТОГДА НоменклатураСегмента.Номенклатура.ТипНоменклатуры В (&СписокРазрешенныхТипов)
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК ОтборНоменклатураСегмента
	|		ПО СписокНоменклатуры.Ссылка = ОтборНоменклатураСегмента.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&НаДату, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
	|		ПО (СтатусыНоменклатурыСрезПоследних.Номенклатура = СписокНоменклатуры.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОказаноПоПолису КАК ВТОказаноПоПолису
	|		ПО СписокНоменклатуры.Ссылка = ВТОказаноПоПолису.ЛечениеНоменклатура.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУслугиПоДоговору КАК ВТУслугиПоДоговору
	|		ПО СписокНоменклатуры.Ссылка = ВТУслугиПоДоговору.Номенклатура
	|ГДЕ
	|	(""Все"" В (&Сегмент)
	|			ИЛИ СписокНоменклатуры.Ссылка В (ОтборНоменклатураСегмента.Номенклатура))
	|	И НЕ СписокНоменклатуры.ПометкаУдаления
	|	И СписокНоменклатуры.ЭтоГруппа = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА НЕ &СписокРазрешенныхТипов ЕСТЬ NULL
	|				ТОГДА СписокНоменклатуры.ТипНоменклатуры В (&СписокРазрешенныхТипов)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ВПродаже = ЛОЖЬ
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЕСТЬNULL(СтатусыНоменклатурыСрезПоследних.ВПродаже, ИСТИНА)
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ТолькоПроданныеСертификаты
	|					И СписокНоменклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|				ТОГДА СписокНоменклатуры.Ссылка В
	|						(ВЫБРАТЬ
	|							СертификатыОстатки.Сертификат
	|						ИЗ
	|							РегистрНакопления.Сертификаты.Остатки КАК СертификатыОстатки
	|						СГРУППИРОВАТЬ ПО
	|							СертификатыОстатки.Сертификат
	|						ИМЕЮЩИЕ
	|							СУММА(СертификатыОстатки.СуммаОстаток) > 0)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборНаименование <> """"
	|				ТОГДА ВЫБОР
	|						КОГДА &ОтборТолькоПоНаименованию
	|							ТОГДА СписокНоменклатуры.Наименование ПОДОБНО &ОтборНаименование
	|						КОГДА &ОтборТолькоПоАртикулу
	|							ТОГДА СписокНоменклатуры.Артикул ПОДОБНО &ОтборПоАртикулу
	|						ИНАЧЕ СписокНоменклатуры.Артикул ПОДОБНО &ОтборПоАртикулу
	|								ИЛИ СписокНоменклатуры.Наименование ПОДОБНО &ОтборНаименование
	|					КОНЕЦ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И &УсловиеУслугиПоДоговору
	|
	|СГРУППИРОВАТЬ ПО
	|	СписокНоменклатуры.Ссылка,
	|	СписокНоменклатуры.Родитель,
	|	СписокНоменклатуры.ЕдиницаИзмерения,
	|	СписокНоменклатуры.НормаВремени,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1),
	|	СписокНоменклатуры.Артикул,
	|	СписокНоменклатуры.УпаковкаПоУмолчанию,
	|	СписокНоменклатуры.СкидкиЗапрещены,
	|	СписокНоменклатуры.Наименование,
	|	ВЫБОР
	|		КОГДА &СегментПоСогласованию <> НЕОПРЕДЕЛЕНО
	|			ТОГДА ВЫБОР
	|					КОГДА ОтборНоменклатураСегмента.Сегмент = &СегментПоСогласованию
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА СписокНоменклатуры.Ссылка.ЭтоГруппа = ИСТИНА
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА СписокНоменклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор)
	|					ТОГДА 4
	|				ИНАЧЕ 2
	|			КОНЕЦ
	|	КОНЕЦ,
	|	СписокНоменклатуры.Бесплатно,
	|	ВТУслугиПоДоговору.Согласование,
	|	ВТУслугиПоДоговору.Количество,
	|	ВТУслугиПоДоговору.КоличествоПриПревышении,
	|	ВТУслугиПоДоговору.КоличествоЗубов,
	|	ВТУслугиПоДоговору.КоличествоВПриеме,
	|	ВТУслугиПоДоговору.НаименованиеОграничения
	|
	|УПОРЯДОЧИТЬ ПО
	|	Артикул,
	|	СписокНоменклатуры.Наименование";
	
	УсловиеУслугиПоДоговору = 
	"И ВЫБОР КОГДА СписокНоменклатуры.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Услуга) Тогда СписокНоменклатуры.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТУслугиПоДоговору.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ВТУслугиПоДоговору КАК ВТУслугиПоДоговору)ИНАЧЕ ИСТИНА КОНЕЦ";
	ВыборкаНоменклатур.Текст = СтрЗаменить(ВыборкаНоменклатур.Текст, "И &УсловиеУслугиПоДоговору", ?(ЗначениеЗаполнено(ПолисМедСтрахования), УсловиеУслугиПоДоговору, ""));

	ВыборкаНоменклатур.УстановитьПараметр("ОтборТолькоПоАртикулу"               , ОтборТолькоПоАртикулу);
	ВыборкаНоменклатур.УстановитьПараметр("ОтборТолькоПоНаименованию"           , ОтборТолькоПоНаименованию);
	ВыборкаНоменклатур.УстановитьПараметр("Сегмент"                             , ОтборСегментМассив);
	ВыборкаНоменклатур.УстановитьПараметр("ВПродаже"							, ОтборВПродаже);                           
	ВыборкаНоменклатур.УстановитьПараметр("ОтборПоАртикулу"                   	, ?(ЗначениеЗаполнено(ОтборПоНаименованию)       , "%" + ОтборПоНаименованию + "%", ""));
	ВыборкаНоменклатур.УстановитьПараметр("ОтборНаименование"                   , ?(ЗначениеЗаполнено(ОтборПоНаименованию)       , "%" + ОтборПоНаименованию + "%",""));	
	ВыборкаНоменклатур.УстановитьПараметр("СписокРазрешенныхТипов"              , ?(ЗначениеЗаполнено(ОтборСписокРазрешенныхТипов) И ОтборСписокРазрешенныхТипов.Количество() > 0 ,ОтборСписокРазрешенныхТипов,NULL));
	ВыборкаНоменклатур.УстановитьПараметр("СтруктурнаяЕдиница"                  , ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница)   , ОтборСтруктурнаяЕдиница, Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("ВидЦен"                              , ?(ЗначениеЗаполнено(ОтборВидЦен)               , ОтборВидЦен, Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("НаДату"                			    , ?(ЗначениеЗаполнено(ОтборДата)                 , ОтборДата, Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("ТолькоПроданныеСертификаты"			, ?(ЗначениеЗаполнено(ОтборТолькоРеализованныхСертификатов),ОтборТолькоРеализованныхСертификатов,ЛОжь));                           
	ВыборкаНоменклатур.УстановитьПараметр("СегментПоСогласованию"				, ?(ЗначениеЗаполнено(ОтборСегментПоСогласованию),ОтборСегментПоСогласованию,Неопределено));                           
	ВыборкаНоменклатур.УстановитьПараметр("СсылкаДоговорПоПолису"				, ОтборДоговорПоПолисуМассив);
	ВыборкаНоменклатур.УстановитьПараметр("ПолисМедСтрахования"					, ПодсчетКоличестваОказанныхУслугПоПолису);
	
	Возврат ВыборкаНоменклатур.Выполнить().Выгрузить();	
	
КонецФункции	

// Функция расширенного отбора номенклатур
// Возврат значений: Артикул, Номенклатура, Родитель, Цена, ИндКартинки, ЕдиницаИзмерения,НормаВремени
Функция ОтборНоменклатурПоУслугамСотрудника(
	ОтборДата = Неопределено,
	ОтборСтруктурнаяЕдиница = Неопределено,						 
	ОтборВидЦен = Неопределено,						 
	ОтборСотрудник = Истина,
	ОтборСегмент = Неопределено, 
	ОтборСегментУслугПоСогласованию = Неопределено,
	ОтборПоДоговоруПолиса = Неопределено,
	ПолисМедСтрахования = Неопределено) Экспорт
	
	ОтборДоговорПоПолисуМассив = Новый Массив;
	Если ОтборПоДоговоруПолиса = Неопределено ИЛИ ОтборПоДоговоруПолиса = Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда
		ОтборДоговорПоПолисуМассив.Добавить("Отсутствует");		
	Иначе
		ОтборДоговорПоПолисуМассив.Добавить(ОтборПоДоговоруПолиса);	
	КонецЕсли;
	
	ПодсчетКоличестваОказанныхУслугПоПолису = Новый Массив;
	Если ПолисМедСтрахования = Неопределено ИЛИ ПолисМедСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПустаяСсылка() Тогда
		ПодсчетКоличестваОказанныхУслугПоПолису.Добавить("Отсутствует");		
	Иначе
		ПодсчетКоличестваОказанныхУслугПоПолису.Добавить(ПолисМедСтрахования);	
	КонецЕсли;
	
	
	// Запрос к справочнику номенклатур
	ВыборкаНоменклатур      = Новый Запрос;	
	ВыборкаНоменклатур.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НоменклатураСегмента.Сегмент КАК Сегмент,
	|	НоменклатураСегмента.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТУслугиСегмента
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|ГДЕ
	|	&СегментЗаполнен
	|	И НоменклатураСегмента.Сегмент = &ОтборСегмент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапросЛечение.Номенклатура КАК ЛечениеНоменклатура,
	|	СУММА(ВложенныйЗапросЛечение.Количество) КАК ЛечениеКоличество
	|ПОМЕСТИТЬ ВТОказаноПоПолису
	|ИЗ
	|	Документ.Прием КАК Прием
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СУММА(ПриемЛечение.Количество) КАК Количество,
	|			ПриемЛечение.Номенклатура КАК Номенклатура,
	|			ПриемЛечение.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.Прием.Лечение КАК ПриемЛечение
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ПриемЛечение.Номенклатура,
	|			ПриемЛечение.Ссылка) КАК ВложенныйЗапросЛечение
	|		ПО Прием.Ссылка = ВложенныйЗапросЛечение.Ссылка
	|ГДЕ
	|	Прием.ПолисМедСтрахования В(&ПолисМедСтрахования)
	|	И НЕ ""Отсутствует"" В (&ПолисМедСтрахования)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапросЛечение.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НоменклатураСегмента.Сегмент КАК Сегмент,
	|	НоменклатураСегмента.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТУслугиСегментаУслугПоСогласованию
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|ГДЕ
	|	&СегментУслугПоСогласованиюЗаполнен
	|	И НоменклатураСегмента.Сегмент = &ОтборСегментУслугПоСогласованию
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура КАК Номенклатура,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Согласование КАК Согласование,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Количество КАК Количество,
	|	ДоговорыКонтрагентовУслугиПоДоговору.КоличествоПриПревышении КАК КоличествоПриПревышении,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.КоличествоЗубов, 0) КАК КоличествоЗубов,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.КоличествоВПриеме, 0) КАК КоличествоВПриеме,
	|	ЕСТЬNULL(ДоговорыКонтрагентовОграничениеЗубов.НаименованиеОграничения, """") КАК НаименованиеОграничения
	|ПОМЕСТИТЬ ВТУслугиПоДоговору
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов.ОграничениеЗубов КАК ДоговорыКонтрагентовОграничениеЗубов
	|		ПО ДоговорыКонтрагентовУслугиПоДоговору.Ссылка = ДоговорыКонтрагентовОграничениеЗубов.Ссылка
	|			И ДоговорыКонтрагентовУслугиПоДоговору.КлючСтроки = ДоговорыКонтрагентовОграничениеЗубов.КлючСтроки
	|ГДЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Ссылка В(&СсылкаДоговорПоПолису)
	|	И НЕ ""Отсутствует"" В (&СсылкаДоговорПоПолису)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	УслугиСотрудника.Номенклатура.Родитель КАК Родитель,
	|	УслугиСотрудника.Номенклатура.ЭтоГруппа КАК ЭтоГруппа,
	|	УслугиСотрудника.Номенклатура.Наименование КАК Наименование,
	|	УслугиСотрудника.Номенклатура.Артикул КАК Артикул,
	|	УслугиСотрудника.Номенклатура.Бесплатно КАК Бесплатно,
	|	УслугиСотрудника.Номенклатура.НормаВремени КАК НормаВремени,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ВЫБОР
	|		КОГДА НЕ УслугиСотрудника.Номенклатура.ЭтоГруппа
	|			ТОГДА 2
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ИндКартинки,
	|	ВТУслугиПоДоговору.Согласование КАК ПолисСогласование,
	|	ВТУслугиПоДоговору.Количество КАК ПолисКоличество,
	|	ВТУслугиПоДоговору.КоличествоПриПревышении КАК ПолисКоличествоПриПревышении,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТУслугиПоДоговору.Количество, НЕОПРЕДЕЛЕНО) = 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПолисНеограничено,
	|	ВТУслугиПоДоговору.КоличествоЗубов КАК КоличествоЗубов,
	|	ВТУслугиПоДоговору.КоличествоВПриеме КАК КоличествоВПриеме,
	|	ВТУслугиПоДоговору.НаименованиеОграничения КАК НаименованиеОграничения,
	|	УслугиСотрудника.Номенклатура.СкидкиЗапрещены КАК СкидкиЗапрещены
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&НаДату,
	|				ВидЦен = &ВидЦен
	|					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					И Актуальность = ИСТИНА) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО УслугиСотрудника.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыНоменклатуры.СрезПоследних КАК СтатусыНоменклатурыСрезПоследних
	|		ПО УслугиСотрудника.Номенклатура = СтатусыНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОказаноПоПолису КАК ВТОказаноПоПолису
	|		ПО УслугиСотрудника.Номенклатура = ВТОказаноПоПолису.ЛечениеНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУслугиПоДоговору КАК ВТУслугиПоДоговору
	|		ПО УслугиСотрудника.Номенклатура = ВТУслугиПоДоговору.Номенклатура
	|ГДЕ
	|	УслугиСотрудника.Сотрудник = &Сотрудник
	|	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И (СтатусыНоменклатурыСрезПоследних.ВПродаже ЕСТЬ NULL
	|			ИЛИ СтатусыНоменклатурыСрезПоследних.ВПродаже = ИСТИНА)
	|	И ВЫБОР
	|			КОГДА &СегментЗаполнен
	|				ТОГДА УслугиСотрудника.Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТУслугиСегмента.Номенклатура
	|						ИЗ
	|							ВТУслугиСегмента)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &СегментУслугПоСогласованиюЗаполнен
	|				ТОГДА УслугиСотрудника.Номенклатура В
	|						(ВЫБРАТЬ
	|							ВТУслугиСегментаУслугПоСогласованию.Номенклатура
	|						ИЗ
	|							ВТУслугиСегментаУслугПоСогласованию)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И &УсловиеУслугиПоДоговору
	|	И НЕ УслугиСотрудника.Номенклатура.ПометкаУдаления";
	
	УсловиеУслугиПоДоговору = 
	"И УслугиСотрудника.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТУслугиПоДоговору.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ВТУслугиПоДоговору КАК ВТУслугиПоДоговору)";
	ВыборкаНоменклатур.Текст = СтрЗаменить(ВыборкаНоменклатур.Текст, "И &УсловиеУслугиПоДоговору", ?(ЗначениеЗаполнено(ПолисМедСтрахования), УсловиеУслугиПоДоговору, ""));

	ВыборкаНоменклатур.УстановитьПараметр("СтруктурнаяЕдиница" , ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница)   , ОтборСтруктурнаяЕдиница, Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("ВидЦен"             , ?(ЗначениеЗаполнено(ОтборВидЦен)               , ОтборВидЦен            , Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("НаДату"             , ?(ЗначениеЗаполнено(ОтборДата)                 , ОтборДата              , Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("Сотрудник"		   , ?(ЗначениеЗаполнено(ОтборСотрудник)            , ОтборСотрудник         , Неопределено));                           	
	ВыборкаНоменклатур.УстановитьПараметр("СегментЗаполнен"    , ЗначениеЗаполнено(ОтборСегмент));	
	ВыборкаНоменклатур.УстановитьПараметр("ОтборСегмент"	   , ОтборСегмент);    
	ВыборкаНоменклатур.УстановитьПараметр("СегментУслугПоСогласованиюЗаполнен", ЗначениеЗаполнено(ОтборСегментУслугПоСогласованию));	
	ВыборкаНоменклатур.УстановитьПараметр("ОтборСегментУслугПоСогласованию"   , ОтборСегментУслугПоСогласованию);
	ВыборкаНоменклатур.УстановитьПараметр("СсылкаДоговорПоПолису"				, ОтборДоговорПоПолисуМассив);
	ВыборкаНоменклатур.УстановитьПараметр("ПолисМедСтрахования"					, ПодсчетКоличестваОказанныхУслугПоПолису);
	
	Возврат ВыборкаНоменклатур.Выполнить().Выгрузить();	
	
КонецФункции

// Функция расширенного отбора номенклатур
// Возврат значений: Артикул, Номенклатура, Родитель, Цена, ИндКартинки, ЕдиницаИзмерения,НормаВремени
Функция ОтборНоменклатурЗубнаяФормула(ОтборДата = Неопределено,ОтборСтруктурнаяЕдиница = Неопределено,ОтборСостояние,ОтборВидЦен = Неопределено) Экспорт
	
	// Запрос к справочнику номенклатур
	ВыборкаНоменклатур       = Новый Запрос;
	ВыборкаНоменклатур.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СписокНоменклатуры.Ссылка.Артикул КАК Артикул,
	|	СписокНоменклатуры.Ссылка КАК Номенклатура,
	|	СписокНоменклатуры.Ссылка.Родитель КАК Родитель,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1) КАК Цена,
	|	ВЫБОР
	|		КОГДА СписокНоменклатуры.Ссылка.ЭтоГруппа = ИСТИНА
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндКартинки,
	|	СписокНоменклатуры.Ссылка.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СписокНоменклатуры.Ссылка.НормаВремени КАК НормаВремени
	|ИЗ
	|	Справочник.Номенклатура.ОбластиЗубнойФормулы КАК СписокНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&НаДату,
	|				Актуальность = ИСТИНА
	|					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					И ВидЦен = &ВидЦен
	|					И Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО СписокНоменклатуры.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|ГДЕ
	|	НЕ СписокНоменклатуры.Ссылка.ПометкаУдаления
	|	И СписокНоменклатуры.Ссылка.ЭтоГруппа = ЛОЖЬ
	|	И СписокНоменклатуры.СостояниеЗубнойФормулы = &ОтборСостояние
	|
	|СГРУППИРОВАТЬ ПО
	|	СписокНоменклатуры.Ссылка,
	|	СписокНоменклатуры.Ссылка.Родитель,
	|	СписокНоменклатуры.Ссылка.ЕдиницаИзмерения,
	|	СписокНоменклатуры.Ссылка.НормаВремени,
	|	ВЫБОР
	|		КОГДА СписокНоменклатуры.Ссылка.ЭтоГруппа = ИСТИНА
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ,
	|	СписокНоменклатуры.Ссылка.Артикул,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1)
	|АВТОУПОРЯДОЧИВАНИЕ";
      
	ВыборкаНоменклатур.УстановитьПараметр("ОтборСостояние"                      , ОтборСостояние);
	ВыборкаНоменклатур.УстановитьПараметр("СтруктурнаяЕдиница"                  , ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница)   , ОтборСтруктурнаяЕдиница, Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("ВидЦен"                              , ?(ЗначениеЗаполнено(ОтборВидЦен)               , ОтборВидЦен, Неопределено));
	ВыборкаНоменклатур.УстановитьПараметр("НаДату"                			    , ?(ЗначениеЗаполнено(ОтборДата)                 , ОтборДата, Неопределено));
	Возврат ВыборкаНоменклатур.Выполнить().Выгрузить();	
	
КонецФункции	

// Функция - Получить остаток сертификата
//
// Параметры:
//  Сертификат		 - 	 - 
//  СерийныйНомер	 - 	 - 
//  Дата			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОстатокСертификата(Сертификат, СерийныйНомер, Знач Дата = Неопределено) Экспорт
	
	Если Дата = Неопределено Тогда
		Дата = ТекущаяДата();
	КонецЕсли;
	
	ЗапросСертификат = Новый Запрос(
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	СертификатыОстатки.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.Сертификаты.Остатки(
	|			&ТекДата,
	|			 Сертификат = &Сертификат
	|				И СерийныйНомер = &СерийныйНомер) КАК СертификатыОстатки");
	
	ЗапросСертификат.УстановитьПараметр("Сертификат", Сертификат);
	ЗапросСертификат.УстановитьПараметр("СерийныйНомер", СерийныйНомер);
	ЗапросСертификат.УстановитьПараметр("ТекДата", КонецДня(Дата));
	
	РезультатОстаток = ЗапросСертификат.Выполнить().Выгрузить();
	Если РезультатОстаток.Количество() > 0 Тогда
		Возврат РезультатОстаток[0].СуммаОстаток;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
КонецФункции

// Функция, возвращает цены номенклатуры.
//
Функция ПолучитьЦеныНомеклатуры(Номенклатура,
								СтруктурнаяЕдиница 	 	   = Неопределено,
								ВидЦен 				 	   = Неопределено,
								Знач ПериодНачало 	 	   = Неопределено,
								Знач ПериодОкончание 	   = Неопределено,
								РасширенноеЦенообразование = Истина) Экспорт
	
	СтруктурнаяЕдиница 		   = ?(СтруктурнаяЕдиница = Неопределено, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, СтруктурнаяЕдиница);
	ИспользоватьОтборПоВремени = ?(РасширенноеЦенообразование, ПериодНачало <> Неопределено, Ложь);
	ДатаПериод 				   = ПериодНачало;
	ДобавитьДень			   = ИспользоватьОтборПоВремени И ЗначениеЗаполнено(ПериодОкончание) И День(ПериодНачало) <> День(ПериодОкончание);
	ПериодНачалоТолькоВремя    = Дата(1,1,1) + ?(ЗначениеЗаполнено(ПериодНачало), (ПериодНачало - НачалоДня(ПериодНачало)), 0);
	ПериодОкончаниеТолькоВремя = Дата(1,1,1) + ?(ЗначениеЗаполнено(ПериодОкончание), (ПериодОкончание - НачалоДня(ПериодОкончание)), 0) + ?(ДобавитьДень, 86400, 0);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
	|	ЦеныНоменклатурыСрезПоследних.Упаковка КАК Упаковка,
	|	ЦеныНоменклатурыСрезПоследних.ДеньНедели КАК ДеньНедели,
	|	ЦеныНоменклатурыСрезПоследних.ВремяНачала КАК ВремяНачала,
	|	ЦеныНоменклатурыСрезПоследних.ВремяОкончания КАК ВремяОкончания,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ЦеныНоменклатурыСрезПоследних.ВидЦен.Наименование КАК Наименование
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаПериод,
	|			Номенклатура = &Номенклатура
	|				И Актуальность
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И &ВидЦен
	|				И &ИспользоватьОтборПоВремени) КАК ЦеныНоменклатурыСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование,
	|	Упаковка,
	|	ДеньНедели,
	|	ВремяНачала");
	
	Запрос.УстановитьПараметр("Номенклатура"	  		  , Номенклатура);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		  , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ВидЦен"			  		  , ВидЦен);
	Запрос.УстановитьПараметр("ДатаПериод"			  	  , ДатаПериод);
	Запрос.УстановитьПараметр("ИспользоватьОтборПоВремени", ИспользоватьОтборПоВремени);
	Запрос.УстановитьПараметр("ПериодНачалоТолькоВремя"	  , ПериодНачалоТолькоВремя);
	Запрос.УстановитьПараметр("ПериодОкончаниеТолькоВремя", ПериодОкончаниеТолькоВремя);

	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ВидЦен", ?(ВидЦен = Неопределено, "Истина", "ВидЦен = &ВидЦен"));
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДатаПериод", ?(ДатаПериод = Неопределено, "", "&ДатаПериод"));
	
	Если ИспользоватьОтборПоВремени Тогда
		
		УсловиеОтбораПоВремени =
		"И ВЫБОР
		|	КОГДА Номенклатура.РасширенноеВременноеЦенообразование = ИСТИНА
		|		ТОГДА (ДеньНедели = ДЕНЬНЕДЕЛИ(&ДатаПериод)
		|				ИЛИ ДеньНедели = 0
		|				ИЛИ ДеньНедели = 8 И ДЕНЬНЕДЕЛИ(&ДатаПериод) Между 1 И 5
		|				ИЛИ ДеньНедели = 9 И ДЕНЬНЕДЕЛИ(&ДатаПериод) Между 6 И 7)
		|				И &УсловиеПериодОкончания
		|				И (ВремяОкончания > &ПериодНачалоТолькоВремя
		|					ИЛИ ВремяОкончания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
		|	ИНАЧЕ ИСТИНА
		|КОНЕЦ";
		
		УсловиеПериодОкончания = ?(ЗначениеЗаполнено(ПериодОкончание), "И (ВремяНачала < &ПериодОкончаниеТолькоВремя ИЛИ ВремяНачала = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))", "");
		УсловиеОтбораПоВремени = СтрЗаменить(УсловиеОтбораПоВремени, "И &УсловиеПериодОкончания", УсловиеПериодОкончания);
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ИспользоватьОтборПоВремени", УсловиеОтбораПоВремени);
		
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ИспользоватьОтборПоВремени", "");
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// При изменении основной цены продажи на форме элемента установим ее основной
//
Процедура УстановитьЦенуНоменклатуры(Номенклатура, ВидЦен, Упаковка, СтруктурнаяЕдиница, Цена, РасширенноеЦенообразование = Неопределено) Экспорт
	
	НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
	НоваяЦена.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
	НоваяЦена.Номенклатура       = Номенклатура;
	НоваяЦена.ВидЦен             = ВидЦен;
	НоваяЦена.Цена               = Цена;
	НоваяЦена.Упаковка           = Упаковка;
	НоваяЦена.Период             = ТекущаяДата();
	НоваяЦена.Автор              = ПараметрыСеанса.ТекущийПользователь;
	Если Не РасширенноеЦенообразование = Неопределено Тогда
		НоваяЦена.ДеньНедели 	 = РасширенноеЦенообразование.ДеньНедели;
		НоваяЦена.ВремяНачала 	 = РасширенноеЦенообразование.ВремяНачала;
		НоваяЦена.ВремяОкончания = РасширенноеЦенообразование.ВремяОкончания;
	КонецЕсли;
	НоваяЦена.Записать();
	
КонецПроцедуры // УстановитьИзменитьОсновнуюЦенуПродажи()

// Функция, возвращает неиспользуемые группы, которые не нужно отображать в динамических списках.
//
Функция ПолучитьНеиспользуемыеГруппы(
		СтруктурнаяЕдиница,
		Дата,
		МассивТипов,
		СегментСотрудника = Неопределено,
		Сотрудник = Неопределено,
		ДоговорПоПолису = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже
	|ПОМЕСТИТЬ СтасусыНоменклатуры
	|ИЗ
	|	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&Дата, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТУслугиПоДоговору
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|ГДЕ
	|	ДоговорыКонтрагентовУслугиПоДоговору.Ссылка = &СсылкаДоговорПоПолису
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(СписокНоменклатуры.Ссылка) КАК Номенклатура,
	|	СписокНоменклатуры.Родитель КАК Родитель
	|ИЗ
	|	Справочник.Номенклатура КАК СписокНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ СтасусыНоменклатуры КАК СтасусыНоменклатуры
	|		ПО СписокНоменклатуры.Ссылка = СтасусыНоменклатуры.Номенклатура
	|ГДЕ
	|	НЕ СписокНоменклатуры.ПометкаУдаления
	|	И НЕ СписокНоменклатуры.ЭтоГруппа
	|	И &УсловиеОтбораПоСегментам
	|	И &УсловиеМассивТипов
	|	И ЕСТЬNULL(СтасусыНоменклатуры.ВПродаже, ИСТИНА)
	|	И &УсловиеУслугиСотрудника
	|	И &УсловиеУслугиПоДоговору
	|
	|СГРУППИРОВАТЬ ПО
	|	СписокНоменклатуры.Родитель");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"    , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Дата"                  , Дата);
	Запрос.УстановитьПараметр("МассивТипов"			  , МассивТипов);
	Запрос.УстановитьПараметр("СегментСотрудника"	  , СегментСотрудника);
	Запрос.УстановитьПараметр("СсылкаДоговорПоПолису" , ДоговорПоПолису);
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда 
		Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	КонецЕсли;
	
	УсловиеМассивТипов 				  	  = ?(ЗначениеЗаполнено(МассивТипов), "И СписокНоменклатуры.ТипНоменклатуры В (&МассивТипов)", "");
	Запрос.Текст	   					  = СтрЗаменить(Запрос.Текст, "И &УсловиеМассивТипов", УсловиеМассивТипов);
			
	Если ЗначениеЗаполнено(СегментСотрудника) Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СегментСотрудника.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТаблицаНоменклатурПоСегментам
		|ИЗ
		|	РегистрСведений.НоменклатураСегмента КАК СегментСотрудника
		|ГДЕ
		|	СегментСотрудника.Сегмент = &СегментСотрудника
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|" + Запрос.Текст;
		
		УсловиеОтбораПоСегментам = 
		"И СписокНоменклатуры.Ссылка В
		|	(ВЫБРАТЬ
		|		ТаблицаНоменклатурПоСегментам.Номенклатура
		|	ИЗ
		|		ТаблицаНоменклатурПоСегментам)";
		
	Иначе
		УсловиеОтбораПоСегментам = "";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеОтбораПоСегментам", УсловиеОтбораПоСегментам);
	
	УсловиеУслугиСотрудника = ""; 
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		УсловиеУслугиСотрудника =  
		"И (СписокНоменклатуры.ТипНоменклатуры <> Значение(Перечисление.ТипыНоменклатуры.Услуга) Или СписокНоменклатуры.Ссылка В
		|(ВЫБРАТЬ
		|	УслугиСотрудника.Номенклатура
		|ИЗ
		|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
		|ГДЕ
		|   УслугиСотрудника.Сотрудник = &Сотрудник
		|	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И НЕ УслугиСотрудника.Номенклатура.ПометкаУдаления))";
	КонецЕсли;

	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеУслугиСотрудника", УсловиеУслугиСотрудника);

	// БЛОК - Настройки подбора по полису		
	УсловиеУслугиПоДоговору = 
	"И ВЫБОР КОГДА СписокНоменклатуры.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Услуга) Тогда СписокНоменклатуры.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТУслугиПоДоговору.Номенклатура КАК Номенклатура
	|			ИЗ
	|				ВТУслугиПоДоговору КАК ВТУслугиПоДоговору)ИНАЧЕ ИСТИНА КОНЕЦ";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеУслугиПоДоговору", ?(ЗначениеЗаполнено(ДоговорПоПолису), УсловиеУслугиПоДоговору, ""));
	
	ТаблицаНоменклатуры = Запрос.Выполнить().Выгрузить();	
	
	ПодборНоменклатурИсточникГрупп_ = Новый ДеревоЗначений;
	ПодборНоменклатурИсточникГрупп_.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	ЗапросГрупп = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа = ИСТИНА
	|	И НЕ Номенклатура.ПометкаУдаления
	|	И Номенклатура.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				Справочник.Номенклатура.Родитель
	|			ИЗ
	|				Справочник.Номенклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка ИЕРАРХИЯ
	|АВТОУПОРЯДОЧИВАНИЕ");
	
	ВыборкаГрупп = ЗапросГрупп.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	ЗаполнитьИсточникГруппПодбора(ВыборкаГрупп, ПодборНоменклатурИсточникГрупп_.Строки);
	ПустаяГруппа = ПодборНоменклатурИсточникГрупп_.Строки.Добавить();
	
	ПодборНоменклатурИсточникЭлементов_ = Новый ТаблицаЗначений;
	ПодборНоменклатурИсточникЭлементов_.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ПодборНоменклатурИсточникЭлементов_.Колонки.Добавить("Родитель"    , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	Для Каждого СтрокаТЧ из ТаблицаНоменклатуры Цикл
		ЗаполнитьЗначенияСвойств(ПодборНоменклатурИсточникЭлементов_.Добавить(), СтрокаТЧ);
	КонецЦикла;
	
	ПодборНоменклатуры_ = Новый ДеревоЗначений;
	ПодборНоменклатуры_.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ПодборНоменклатуры_.Колонки.Добавить("Родитель"	   , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ПодборНоменклатуры_.Колонки.Добавить("ЭтоГруппа"   , Новый ОписаниеТипов("Булево"));
	
	СписокНеиспользуемыхГрупп = Новый Массив;
	ЗаполнитьСписокПодбора(
		ПодборНоменклатурИсточникГрупп_.Строки,
		ПодборНоменклатурИсточникЭлементов_, 
		ПодборНоменклатуры_, 
		ПодборНоменклатуры_, 
		СписокНеиспользуемыхГрупп);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа
	|	И (НЕ Номенклатура.Ссылка В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						Справочник.Номенклатура.Родитель
	|					ИЗ
	|						Справочник.Номенклатура)
	|			ИЛИ Номенклатура.ПометкаУдаления)");
	
	Результат = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЧ Из Результат Цикл
		СписокНеиспользуемыхГрупп.Добавить(СтрокаТЧ.Ссылка);
	КонецЦикла;
	
	Возврат СписокНеиспользуемыхГрупп;
	
КонецФункции

// Процедура, рекурсивно заполняет дерева подбора номенклатур.
//
Процедура ЗаполнитьСписокПодбора(ИсточникГрупп, ИсточникНоменклатуры, ЭлементЗаполнения, ДеревоПодбора, СписокНеиспользуемыхГрупп)
	
	Для Каждого УровеньЗаполнения ИЗ ИсточникГрупп Цикл
		
		Если ЗначениеЗаполнено(УровеньЗаполнения.Номенклатура) Тогда
			НоваяСтрокаГруппы              = ЭлементЗаполнения.Строки.Добавить();
			НоваяСтрокаГруппы.Номенклатура = УровеньЗаполнения.Номенклатура;
			НоваяСтрокаГруппы.ЭтоГруппа    = Истина;
		Иначе
			НоваяСтрокаГруппы = ДеревоПодбора;
		КонецЕсли;
		
		ЗаполнитьСписокПодбора(УровеньЗаполнения.Строки, ИсточникНоменклатуры, НоваяСтрокаГруппы, ДеревоПодбора, СписокНеиспользуемыхГрупп);
		НоменклатураПоРодителю = ИсточникНоменклатуры.НайтиСтроки(Новый Структура("Родитель", УровеньЗаполнения.Номенклатура));
		
		// Заполняем номенклатуры
		Для Каждого СтрокаН ИЗ НоменклатураПоРодителю Цикл
			НоваяСтрока = НоваяСтрокаГруппы.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаН);
		КонецЦикла;
		
		// Удаляем узел группы если он не содержит элементы
		Если НоваяСтрокаГруппы.Строки.Количество() = 0 И Не ТипЗнч(НоваяСтрокаГруппы) = Тип("ДеревоЗначений") Тогда
			СписокНеиспользуемыхГрупп.Добавить(НоваяСтрокаГруппы.Номенклатура);
			ЭлементЗаполнения.Строки.Удалить(НоваяСтрокаГруппы);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, рекурсивно заполняет источник групп.
//
Процедура ЗаполнитьИсточникГруппПодбора(ВыборкаГрупп, УровеньЗаполнения)
	
	Для Каждого УровеньОбхода Из ВыборкаГрупп.Строки Цикл
		НоваяСтрока = УровеньЗаполнения.Добавить();
		ЗаполнитьИсточникГруппПодбора(УровеньОбхода, НоваяСтрока.Строки);
		НоваяСтрока.Номенклатура = УровеньОбхода.Ссылка;
	КонецЦикла;
	
КонецПроцедуры

// Функция, возвращает номенклатуру по группе, сотруднику и стр. ед.
//
Функция ПолучитьНоменклатуруПоГруппе(Папка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СправочникНоменклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК СправочникНоменклатура
		|ГДЕ
		|	НЕ СправочникНоменклатура.ПометкаУдаления
		|	И СправочникНоменклатура.ЭтоУслуга
		|	И НЕ СправочникНоменклатура.ЭтоГруппа
		|	И СправочникНоменклатура.Ссылка В ИЕРАРХИИ (&Папка)";
	
	Запрос.УстановитьПараметр("Папка", Папка);
		
	Возврат Запрос.Выполнить().Выгрузить();
		
	
КонецФункции

