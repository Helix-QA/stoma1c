// ВСПОМОГАТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

// Функция возвращает таблицу реквизитов, зависимых от хозяйственной операции документа.
//
Функция ПолучитьМассивСостоянияРеквизитов(ОбъектФормы) Экспорт
	
	МассивРеквизитов = Новый Массив;
	
	// Состояния реквизитов по умолчанию
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаПлатежнаяКарта",Тип("ГруппаФормы"),Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаВыплатаЗП",Тип("ГруппаФормы"),Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ЭквайрингТерминал",,Ложь); 
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаСертификат",Тип("ГруппаФормы"),Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СертификатСерийныйНомер",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ЛицевойСчетКонтрагента",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчет",,Ложь); 
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Касса",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.ДокументОснования",,Истина);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.Сотрудник",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Контрагент",,,,,"Пациент",Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаИнформация",Тип("ГруппаФормы"),Истина);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"НомерВходящегоДокумента",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ДатаВходящегоДокумента",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.ВидНалога",,Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаЗатраты",Тип("ГруппаФормы"),Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Выгодоприобретатель",,Ложь);

	// Состояние реквизитов в зависимости типа ден. средств
	Если ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Касса");
	ИначеЕсли ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		 
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчет"); 
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента"); 
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"НомерВходящегоДокумента",,?(ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику, Ложь, Истина));
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ДатаВходящегоДокумента",,?(ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику, Ложь,Истина));	 
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Касса");
	ИначеЕсли ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаПлатежнаяКарта",Тип("ГруппаФормы"),Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ЭквайрингТерминал",,Истина);
	ИначеЕсли ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ЛицевойСчетКонтрагента");
	ИначеЕсли ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаСертификат",Тип("ГруппаФормы"),Истина);
		Если ОбъектФормы.Сертификат.ИспользоватьПартии Тогда
			УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СертификатСерийныйНомер",,Истина);
		КонецЕсли;
	КонецЕсли;
	
	// Состояние реквизитов в зависимости от вида операции
	Если ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента Тогда		
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Истина);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту
		ИЛИ ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту Тогда
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Истина);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыСтраховойКомпании Тогда	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Контрагент",,,,,"Страховая компания",Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.ДокументАванса",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Истина);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику Тогда	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Контрагент",,,,,"Поставщик",Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"РасшифровкаПлатежа.ДокументАванса",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаИнформация",Тип("ГруппаФормы"),Ложь);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.СдачаНаличныхВБанк Тогда				
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента");
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Контрагент",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаИнформация",Тип("ГруппаФормы"),Ложь);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВыбытиеВКассу Тогда				
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчет",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента",,Истина);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"Контрагент",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ГруппаИнформация",Тип("ГруппаФормы"),Ложь);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета Тогда				
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ЛицевойСчетКонтрагента");
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"БанковскийСчетКонтрагента",,Ложь);
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"СтатьяВТаблице",,Ложь);
	ИначеЕсли ОбъектФормы.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику Тогда		
