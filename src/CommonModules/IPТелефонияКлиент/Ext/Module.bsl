
#Область СлужебныйПрограммныйИнтерфейс

// Функция - Исходящий звонок осуществить по контрагенту
// 
// Параметры:
//  Контрагент		 - 	 - 
//  НомерТелефонаКонтрагента	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Процедура ИсходящийЗвонокОсуществитьПоКонтрагенту(Контрагент = Неопределено, НомерТелефонаКонтрагента = Неопределено, ОписаниеОшибки = "") Экспорт
	
	Сотрудник = ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущийСотрудник");
	
	IPТелефонияОборудование = Неопределено;
	мМассивДоступныхУстройств = МенеджерОборудованияВызовСервера.ПолучитьСписокОборудования("IPТелефония");
	НомерТелефонаКонтрагент = ?(ЗначениеЗаполнено(НомерТелефонаКонтрагента), НомерТелефонаКонтрагента, Контрагент);
	
	ПараметрыОповещения = Новый Структура("IPТелефонияОборудование, Сотрудник, НомерТелефонаКонтрагент, Контрагент, ОписаниеОшибки", IPТелефонияОборудование, Сотрудник, НомерТелефонаКонтрагент, Контрагент, ОписаниеОшибки);
	
	МассивДоступныхУстройств = Новый Массив;
	
	Если мМассивДоступныхУстройств.Количество() >= 2 Тогда
		
		СтруктурнаяЕдиница = ОбщегоНазначения.ТекущаяСтруктурнаяЕдиница();
		
		Для Каждого СтрокаМ из мМассивДоступныхУстройств Цикл
			Если Не СтрокаМ.Параметры = Неопределено И СтрокаМ.Параметры.Свойство("СтруктурнаяЕдиница") Тогда
				Если  СтрокаМ.Параметры.СтруктурнаяЕдиница = СтруктурнаяЕдиница Тогда
					Если СтрокаМ.ОбработчикДрайвера <> ПредопределенноеЗначение("Перечисление.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсCallTouch") Тогда  
						МассивДоступныхУстройств.Добавить(СтрокаМ);
					КонецЕсли;
				КонецЕсли;				
			Иначе
				МассивДоступныхУстройств.Добавить(СтрокаМ);
			КонецЕсли;			
		КонецЦикла		
	Иначе	
		МассивДоступныхУстройств = мМассивДоступныхУстройств;
	КонецЕсли;
	
	Если МассивДоступныхУстройств.Количество() = 0 Тогда
		ОписаниеОшибки = "Не обнаружено подключаемое оборудование IP-телефонии!";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	ИначеЕсли МассивДоступныхУстройств.Количество() = 1 Тогда
		ПараметрыОповещения.IPТелефонияОборудование = МассивДоступныхУстройств[0].Ссылка;
	ИначеЕсли МассивДоступныхУстройств.Количество() >= 2 Тогда
		СписокДоступныхУстройств = Новый СписокЗначений;
		Для каждого ЭлементТЧ Из МассивДоступныхУстройств Цикл
			СписокДоступныхУстройств.Добавить(ЭлементТЧ, ЭлементТЧ.Наименование);
		КонецЦикла; 
		Оповещение = Новый ОписаниеОповещения("ИсходящийЗвонокОсуществитьПоКонтрагентуЗавершение", ЭтотОбъект, ПараметрыОповещения);
		ОткрытьФорму("ОбщаяФорма.ВыборИзСписка", Новый Структура("Заголовок, СписокЗначений", "Выберите устройство IP-телефонии", СписокДоступныхУстройств),,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Возврат;
	КонецЕсли;
	
	ИсходящийЗвонокОсуществитьПоКонтрагентуЗавершение(Новый Структура("Ссылка", ПараметрыОповещения.IPТелефонияОборудование), ПараметрыОповещения);	
	
КонецПроцедуры

Процедура ИсходящийЗвонокОсуществитьПоКонтрагентуЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	Иначе
		Параметры.IPТелефонияОборудование = Результат.Ссылка;
	КонецЕсли;
	
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаПоПути(Параметры.IPТелефонияОборудование, "ДрайверОборудования.ОбработчикДрайвера") = ПредопределенноеЗначение("Перечисление.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикВедисофтПростыеЗвонки") Тогда
		// Получение номера телефона сотрудника
		МассивТелефонныхАппаратовСотрудника = IPТелефония.ПолучитьСтруктуруВнутреннегоНомераПоПользователю(Параметры.Сотрудник);
		Если МассивТелефонныхАппаратовСотрудника.Количество() = 0 Тогда
			ОписаниеОшибки = "Менеджер '" + Параметры.Сотрудник + "' не в сети или внутренний номер телефона не зарегистрирован.";
			Возврат;
		ИначеЕсли Не ЗначениеЗаполнено(МассивТелефонныхАппаратовСотрудника[0].НомерТелефона) Тогда
			ОписаниеОшибки = "Внутренний номер телефона на менеджера '" + Параметры.Сотрудник + "' не зарегистрирован.";
			Возврат;			
		КонецЕсли;
		
		РезультатКоманды = ПростыеЗвонки_ИсходящийЗвонокОсуществить(МассивТелефонныхАппаратовСотрудника[0].НомерТелефона, Параметры.НомерТелефонаКонтрагент, Параметры.ОписаниеОшибки);
	Иначе
		РезультатКоманды = IPТелефония.ИсходящийЗвонокОсуществить(Параметры.IPТелефонияОборудование, Параметры.Сотрудник, Параметры.НомерТелефонаКонтрагент, Параметры.Сотрудник, Параметры.Контрагент, Параметры.ОписаниеОшибки);
	КонецЕсли;

	Если РезультатКоманды <> Истина И ЗначениеЗаполнено(Параметры.ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Параметры.ОписаниеОшибки);
	КонецЕсли; 
	
КонецПроцедуры

Процедура ПереадресацияЗвонкаОбработкаОповещения(мПараметры) Экспорт
	
	ОткрытьФорму("Справочник.ТелефонныеАппараты.Форма.ФормаПереадресации", мПараметры, , , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

Процедура ОткрытьСписокПропущенныхЗвонков(ДополнительныеПараметры) Экспорт
	
	ДополнительныеПараметры.Вставить("ОтборПериод"							, Новый СтандартныйПериод(ВариантСтандартногоПериода.Сегодня));
	ДополнительныеПараметры.Вставить("ОтборТипЗвонка"						, 2);			
	ДополнительныеПараметры.Вставить("ОтобразитьПользовательскийВидФормы"	, Истина);		
	ОткрытьФорму("РегистрСведений.ИсторияВызовов.ФормаСписка", ДополнительныеПараметры, , ДополнительныеПараметры.КлючОповещения);
	
КонецПроцедуры

Процедура СоздатьНовогоКлиентаОповещение(Параметры) Экспорт
		
	Телефон                 = Параметры.НомерТелефона;
	XML_Телефон				= УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(Телефон, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента"));
	Представление_Телефон 	= УправлениеКонтактнойИнформациейСлужебныйВызовСервера.СтрокаСоставаКонтактнойИнформации(XML_Телефон); 
	СтруктураЗаполнения = Новый Структура();
	СтруктураЗаполнения.Вставить("ТелефонКлиента"			, Представление_Телефон); 
	ФормаЭлементаКонтакт = ПолучитьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", , , "IPТелефония_СоздатьПотенциальногоКлиента_" + Телефон);
	МассивСтрокТелефона = ФормаЭлементаКонтакт.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон")));
	НоваяСтрока		= ?(МассивСтрокТелефона.Количество() > 0, МассивСтрокТелефона[0], ФормаЭлементаКонтакт.КонтактнаяИнформация.Добавить());
	НоваяСтрока.Тип	= ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон");
	НоваяСтрока.Вид = ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента");
	НоваяСтрока.Представление = Телефон;
	НоваяСтрока.ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(Телефон, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента"));
	ФормаЭлементаКонтакт.Модифицированность = Истина;
	
	ФормаЭлементаКонтакт.Открыть();
	
КонецПроцедуры

Процедура ОткрытьФормуЗвонкаОповещение(Параметры) Экспорт
	
	ОткрытьФорму("РегистрСведений.ИсторияВызовов.Форма.ФормаЗвонокКлиента", Параметры,, Параметры.IDЗвонка);
	
КонецПроцедуры

// Процедура - При начале работы системы
// 
Процедура ПриНачалеРаботыСистемы(ПараметрыРаботыКлиента) Экспорт
	
	Если ПараметрыРаботыКлиента.Свойство("НачальноеЗаполнениеДанных") 
		И Не ПараметрыРаботыКлиента.НачальноеЗаполнениеДанных Тогда 
		Если (ПараметрыРаботыКлиента.Свойство("РазделениеВключено") И ПараметрыРаботыКлиента.РазделениеВключено)
			И НЕ(ПараметрыРаботыКлиента.Свойство("ДоступноИспользованиеРазделенныхДанных") И ПараметрыРаботыКлиента.ДоступноИспользованиеРазделенныхДанных) Тогда
			Возврат;
		КонецЕсли;	    
		
		Если IPТелефония.ПроверитьВозможностьЗвонкаНаДанномПК() Тогда
			
			ПодключитьОбработчикОжидания("ОбработчикОжиданияОбновитьПоследнююАктивность", 10, Истина);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#Область РосТелеком

// Функция - Получить актуальный URLЗаписи ROSTELECOMКлиент
//
// Параметры:
//  ИсходныйURLЗаписи	 - 	 - 
//  IDЗвонка			 - 	 - 
//  ПОIPТелефонии		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАктуальныйURLЗаписиROSTELECOMКлиент(Знач ИсходныйURLЗаписи, Знач IDЗвонка, Знач ПОIPТелефонии) Экспорт
		
	Если Не IPТелефония.ЭтоОбработчикДрайвераПереданнойПОIPТелефонии(ПОIPТелефонии, ПредопределенноеЗначение("Перечисление.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM")) Тогда
		Возврат ИсходныйURLЗаписи;
	КонецЕсли;		
	
	ВнешнийIPКлиента = ПолучитьВнешнийIPАдресКлиент();
	
	Если Не ЗначениеЗаполнено(ВнешнийIPКлиента) Тогда
		Возврат ИсходныйURLЗаписи;
	КонецЕсли;
	
	Возврат IPТелефония.ПолучитьАктуальныйURLЗаписиROSTELECOMСервер(ИсходныйURLЗаписи, IDЗвонка, ВнешнийIPКлиента);
	
КонецФункции

// Функция - Получить внешний IP-Адрес.
// 
Функция ПолучитьВнешнийIPАдресКлиент() Экспорт
	
	IPАдрес = "";
	#Если Не ВебКлиент Тогда
	Попытка
		
		// http://ip-api.com/json/
		Соединение = Новый HTTPСоединение("ip-api.com");
		HTTPЗапрос = Новый HTTPЗапрос("json");				
		
		РезультатЗапроса = Соединение.Получить(HTTPЗапрос);
		РезультатЗапроса = РазобратьJsonКлиент(РезультатЗапроса);
		
		Если РезультатЗапроса.Свойство("status") И РезультатЗапроса.status = "success"
			И РезультатЗапроса.Свойство("query") И ЗначениеЗаполнено(РезультатЗапроса.query) Тогда
			
			IPАдрес = РезультатЗапроса.query
		КонецЕсли;
		
	Исключение
	КонецПопытки;
	#КонецЕсли
	Возврат IPАдрес;
	
КонецФункции

// Функция - Разобрать параметры JSON.
//
Функция РазобратьJsonКлиент(Запрос)
	#Если Не ВебКлиент Тогда
	Попытка
		
		ТекстJSON  = Запрос.ПолучитьТелоКакСтроку();
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		
		Возврат ПрочитатьJSON(ЧтениеJSON);
		
	Исключение
		
		ВызватьИсключение СтрШаблон(НСтр("ru = 'Ошибка: %1. Исходный текст JSON: %2';en= 'Error: %1. Source text JSON: %2'"), ОписаниеОшибки(), ТекстJSON);
		
	КонецПопытки;
	#КонецЕсли
КонецФункции

#КонецОбласти

