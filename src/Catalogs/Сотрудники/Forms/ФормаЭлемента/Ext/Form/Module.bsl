// Процедура, включает/отключает доступ к мобильному расписанию.
// 
Функция ИзменитьДоступКМобильномуПриложению(СообщениеОбОшибке, ДоступКРасписанию, ВнешняяСистема, ТипВнешнейСистемы)
	
	Если ДоступКРасписанию Тогда
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект.НомерТелефона) Тогда
			СообщениеОбОшибке = "Необходимо заполнить номер телефона";
			Возврат Ложь;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ВнешняяСистема)
			И Не СоздатьВнешнююСистему(СообщениеОбОшибке, ВнешняяСистема, ТипВнешнейСистемы) Тогда
			Возврат Ложь;	
		КонецЕсли;
		
		Если Не ВнешняяСистема.Используется
			И Не ВключитьВнешнююСистему(СообщениеОбОшибке, ВнешняяСистема) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Возврат ЗаписатьСотрудникаВнешнейСистемы(СообщениеОбОшибке,, ВнешняяСистема);
		
	Иначе
		
		Возврат ЗаписатьСотрудникаВнешнейСистемы(СообщениеОбОшибке, Ложь, ВнешняяСистема);
		
	КонецЕсли;	
	
КонецФункции

&НаСервере
// Функция - Создать внешнюю систему
// 
Функция СоздатьВнешнююСистему(СообщениеОбОшибке = Неопределено, ВнешняяСистема, ТипВнешнейСистемы)
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.СоздатьВнешнююСистему(ТипВнешнейСистемы,, Истина);
	
	РезультатЗапроса = ЛичныйКабинет.СоздатьВнешнююСистемуВ_CRM(ВнешняяСистема, ЭтотОбъект.УидСессии);
	
	Если Не РезультатЗапроса.ВыполненоУспешно Тогда	
		
		Справочники.ВнешниеСистемы.УстановитьСостояниеВнешнейСистеме(ВнешняяСистема, Ложь, Ложь);		
		СообщениеОбОшибке = РезультатЗапроса.ОписаниеОшибки;
		
	КонецЕсли;
	
	Возврат РезультатЗапроса.ВыполненоУспешно;
	
КонецФункции

&НаСервере
// Функция, включает внешнюю систему.
// 
Функция ВключитьВнешнююСистему(СообщениеОбОшибке = Неопределено, ВнешняяСистема)
	
	РезультатЗапроса = ЛичныйКабинет.ОбновитьВнешнююСистемуВ_CRM(ВнешняяСистема, Истина, ЭтотОбъект.УидСессии);		
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда		
		Справочники.ВнешниеСистемы.УстановитьСостояниеВнешнейСистеме(ВнешняяСистема, Истина, Истина);				
	Иначе	
		СообщениеОбОшибке = РезультатЗапроса.ОписаниеОшибки;	
	КонецЕсли;
	
	Возврат РезультатЗапроса.ВыполненоУспешно;
	
КонецФункции

