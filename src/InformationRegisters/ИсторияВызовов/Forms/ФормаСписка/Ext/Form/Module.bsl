// Функция - Вернуть список структурных единиц
//
// Параметры:
//  ОтборПользовательSIP - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьСписокСтруктурныхЕдиниц(Знач ОтборСтруктурнаяЕдиница)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
	               |	СтруктурныеЕдиницы.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	               |ГДЕ
	               |	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	               |	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ";
	
	ТаблицаСтруктурныхЕдиниц 	= Запрос.Выполнить().Выгрузить();
	
	СписокСтруктурныхЕдиниц 	= Новый СписокЗначений;
	Представление 				= "Все клиники";											
	Картинка 					= БиблиотекаКартинок.Реквизит;
	СписокСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), Представление, Справочники.СтруктурныеЕдиницы.ПустаяСсылка() = ОтборСтруктурнаяЕдиница, Картинка);											
	Для Каждого СтрокаТаблицыСтруктурныхЕдиниц Из ТаблицаСтруктурныхЕдиниц Цикл
		Представление 		= СокрЛП(СтрокаТаблицыСтруктурныхЕдиниц.Наименование);											
		СписокСтруктурныхЕдиниц.Добавить(СтрокаТаблицыСтруктурныхЕдиниц.Ссылка, Представление, СтрокаТаблицыСтруктурныхЕдиниц.Ссылка = ОтборСтруктурнаяЕдиница, Картинка);											
	КонецЦикла;	
	
	Возврат СписокСтруктурныхЕдиниц;
	
КонецФункции	

&НаСервереБезКонтекста
// Функция - Вернуть список телефонных аппаратов
//
// Параметры:
//  ОтборПользовательSIP - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьСписокТелефонныхАппаратов(Знач ОтборПользовательSIP)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТелефонныеАппараты.Ссылка КАК Ссылка,
	|	ТелефонныеАппараты.Родитель КАК Родитель,
	|	ТелефонныеАппараты.ЭтоГруппа КАК ЭтоГруппа,
	|	ТелефонныеАппараты.Наименование КАК Наименование,
	|	ВЫБОР
	|		КОГДА ТелефонныеАппараты.ЭтоГруппа
	|			ТОГДА ЕСТЬNULL(ВложенныйЗапрос.ИндексСортировки, ТелефонныеАппараты.ВнутреннийНомер)
	|		ИНАЧЕ ЕСТЬNULL(ВложенныйЗапрос.ИндексСортировки, """")
	|	КОНЕЦ КАК ИндексСортировки,
	|	ЕСТЬNULL(ТелефонныеАппараты.ВнутреннийНомер, """") КАК ВнутреннийНомер
	|ИЗ
	|	Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
	|			ТелефонныеАппараты.Ссылка КАК ТелефонныйАппарат,
	|			ТелефонныеАппараты.ВнутреннийНомер КАК ВнутреннийНомер,
	|			ТелефонныеАппараты.Родитель.ВнутреннийНомер КАК ИндексСортировки
	|		ИЗ
	|			Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|		ГДЕ
	|			ТелефонныеАппараты.ПометкаУдаления = ЛОЖЬ
	|			И ТелефонныеАппараты.ВнутреннийНомер <> """"
	|			И ТелефонныеАппараты.ЭтоГруппа = ЛОЖЬ) КАК ВложенныйЗапрос
	|		ПО ТелефонныеАппараты.Ссылка = ВложенныйЗапрос.ТелефонныйАппарат
	|ГДЕ
	|	ТелефонныеАппараты.ПометкаУдаления = ЛОЖЬ
	|	И ТелефонныеАппараты.ВнутреннийНомер <> """"
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИндексСортировки,
	|	ВнутреннийНомер";
	
	ТаблицаПользователей = Запрос.Выполнить().Выгрузить();
	
	СписокПользователей = Новый СписокЗначений;
	СтруктураЗначения 	= Новый Структура("ТелефонныйАппарат, Родитель, ЭтоГруппа, ВнутреннийНомер, ВнутреннийНомерРодителя",
										   Справочники.ТелефонныеАппараты.ПустаяСсылка(), Справочники.ТелефонныеАппараты.ПустаяСсылка(), Ложь, "", "");
										   
	СписокПользователей.Добавить(СтруктураЗначения, "Все пользователи", Не ЗначениеЗаполнено(ОтборПользовательSIP), БиблиотекаКартинок.ВариантыОтчетовДоступныеВсемПользователям);											
	
	Для Каждого СтрокаТаблицыПользователей Из ТаблицаПользователей Цикл
		
		Если СтрокаТаблицыПользователей.ЭтоГруппа И НЕ ЗначениеЗаполнено(СтрокаТаблицыПользователей.ВнутреннийНомер) Тогда 
			Продолжить;
		КонецЕсли;	
		
		СтруктураЗначения 	= Новый Структура("ТелефонныйАппарат, Родитель, ЭтоГруппа, ВнутреннийНомер, ВнутреннийНомерРодителя",
											   СтрокаТаблицыПользователей.Ссылка, СтрокаТаблицыПользователей.Родитель, СтрокаТаблицыПользователей.ЭтоГруппа, СтрокаТаблицыПользователей.ВнутреннийНомер, СтрокаТаблицыПользователей.ИндексСортировки);
		Представление 		= ?(СтрокаТаблицыПользователей.ЭтоГруппа, "", ?(ЗначениеЗаполнено(СтрокаТаблицыПользователей.Родитель), Символы.Таб, "")) + СокрЛП(СтрокаТаблицыПользователей.ВнутреннийНомер) + " - " + СокрЛП(СтрокаТаблицыПользователей.Наименование);											
		Картинка 			= ?(СтрокаТаблицыПользователей.ЭтоГруппа, БиблиотекаКартинок.Папка, БиблиотекаКартинок.РеквизитКартинка);
		СписокПользователей.Добавить(СтруктураЗначения, Представление, СтрокаТаблицыПользователей.Ссылка = ОтборПользовательSIP, Картинка);											
		
	КонецЦикла;	
	
	Возврат СписокПользователей;
	
КонецФункции	

