#Область ОбработчикиСобытийЭлементовФормы

&НаСервере
// Обработчик события "ПриСозданииНаСервере" объекта.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	Если Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		Объект.ДатаНачала = ТекущаяДатаСеанса();
	КонецЕсли;
	ЭтаФорма.ТолькоПросмотр = Истина;
	Элементы.Приемы.Видимость = Не Объект.Ссылка.Пустая();
	Приемы.Параметры.УстановитьЗначениеПараметра("КурсЛечения", Объект.Ссылка);
	Приемы.Параметры.УстановитьЗначениеПараметра("Контрагент" , Объект.Контрагент);
    РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);

КонецПроцедуры 

&НаСервере
// Обработчик события "ПриЧтенииНаСервере" объекта.
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
КонецПроцедуры

&НаСервере
// Обработчик события "ПослеЗаписиНаСервере" объекта.
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Процедура - Контрагент при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ДатаНачала = ?(Не ЗначениеЗаполнено(Объект.ДатаНачала), Неопределено, Объект.ДатаНачала);
		Объект.СтатусПациента = ПолучитьСтатусКлиента(Объект.Контрагент, ДатаНачала); 
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедцрыИФункции

// Функция - Получить статус клиента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
&НаСервереБезКонтекста
Функция ПолучитьСтатусКлиента(Контрагент, ДатаНачала) 
	
	Возврат РегистрыСведений.СтатусыКонтрагентов.ПолучитьСтатусКлиента(Контрагент, ДатаНачала);
	
КонецФункции

#КонецОбласти