// Процедура - обработчик команды открытия формы планирования
//
Процедура ДобавитьВОчередьИзПредварительнойЗаписи(Команда)
	
	// Открыть форму создания направления
	ПараметрыФормы = Новый Структура;
	Если ПЗРасшифровкаТекущейОбласти <> Неопределено Тогда
		
		Если ВыводитьОповещениеОНерабочемДнеКлиники(ПЗРасшифровкаТекущейОбласти.Дата,"ДобавитьВОчередь")Тогда
			Возврат;
		КонецЕсли;
		
		ПараметрыФормы.Вставить("ДатаНачалаПериода", ПЗРасшифровкаТекущейОбласти.Дата);
		ПараметрыФормы.Вставить("ДатаОкончанияПериода", ПЗРасшифровкаТекущейОбласти.Дата);
		
		Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) Тогда 
			Если ТипЗнч(ПЗРасшифровкаТекущейОбласти.Сотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда 
				ПараметрыФормы.Вставить("Сотрудник", ПЗРасшифровкаТекущейОбласти.Сотрудник);
			ИначеЕсли ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники") Тогда 
				ПараметрыФормы.Вставить("Сотрудник", ПЗФиьтрГрафикаТекущаяСтрока);
			КонецЕсли;
		ИначеЕсли ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники") Тогда 
			ПараметрыФормы.Вставить("Сотрудник", ПЗФиьтрГрафикаТекущаяСтрока);
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПараметрыФормы.ДатаНачалаПериода) Тогда
		ПараметрыФормы.ДатаНачалаПериода = Объект.Дата;		
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(ПараметрыФормы.ДатаОкончанияПериода) Тогда
		ПараметрыФормы.ДатаНачалаПериода = Объект.Дата;		
	КонецЕсли;
	
	ПараметрыФормы.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	
	ОткрытьФорму("РегистрСведений.Профосмотры.Форма.ФормаЗаписиВЛистОжидания", ПараметрыФормы, ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
КонецПроцедуры

