// Процедура, обработчик события "ПриИзменении" на сервере.
// 
Процедура ОнлайнЗаписьПриИзмененииНаСервере()
	
	ЭтоУслуга = (Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга);
	
	Элементы.ГруппаНастройкаОнлайнЗаписи.Видимость    = ЭтотОбъект.ОнлайнЗапись И ВернутьМассивСтруктурныхЕдиниц().Количество() > 1;
	Элементы.ГруппаНастройкиОнлайнЗаписи.Видимость    = ЭтотОбъект.ОнлайнЗапись;
	Элементы.ОписаниеДляОнлайнЗаписи.Видимость        = ЭтотОбъект.ОнлайнЗапись;
	Элементы.ГруппаОнлайнЗаписиИДеревоУслуг.Видимость = ЭтотОбъект.ОнлайнЗапись;
    Элементы.ГруппаОнлайнЗаписи.Видимость		   	  = ЭтотОбъект.ОнлайнЗапись;
	Если ЭтотОбъект.ОнлайнЗапись Тогда
		СоздатьДеревоСтруктурныхЕдиниц(Истина);
		ЗаполнитьДеревоУслуг();
	Иначе
		ОбработкаТабличныхЧастейКлиент.УстановитьНачальноеСостояниеФлагов(
			ЭтотОбъект.ПодборСтруктурныеЕдиницы.ПолучитьЭлементы(), 
			Неопределено, Неопределено, Ложь);
	КонецЕсли;
	ВывестиСсылкуНаТоварИЛИУслугу();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Выбор".
// 
Процедура ДеревоУслугВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДеревоУслуг.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
		
		ПереместитьВверх = (Поле = Элементы.ПереместитьВверх);
		ПереместитьВниз  = (Поле = Элементы.ПереместитьВниз);
		
		Если ПереместитьВверх ИЛИ ПереместитьВниз Тогда
			
			СтрокаРодитель = Неопределено;
			
			Если ЗначениеЗаполнено(ТекущиеДанные.Родитель) Тогда	
				
				ПолучитьСтрокуРодительРекурсивно(ТекущиеДанные.Родитель, ДеревоУслуг, СтрокаРодитель);
				Если СтрокаРодитель = Неопределено Тогда
					Возврат;
				КонецЕсли;
				
			Иначе
				СтрокаРодитель = ЭтотОбъект.ДеревоУслуг;
			КонецЕсли;
			
			ЭлементыРодителя = СтрокаРодитель.ПолучитьЭлементы();
			ТекущийИндекс    = ЭлементыРодителя.Индекс(ТекущиеДанные);
			
			Если ТекущийИндекс = 0 И ПереместитьВверх ИЛИ ТекущийИндекс = ЭлементыРодителя.Количество() - 1 И ПереместитьВниз Тогда
				Возврат;
			КонецЕсли;
			
			ПоследнийИндекс = ?(ЭлементыРодителя.Количество() - 1 >= ТекущийИндекс + 1, ТекущийИндекс + 1, ТекущийИндекс);
			
			Для Индекс = 0 По ПоследнийИндекс Цикл
				
				Если Индекс = ТекущийИндекс Тогда
					
					Услуга 				  = ЭлементыРодителя[Индекс].Услуга;
					НовыйИндексСортировки = ?(ПереместитьВверх, Индекс - 1, Индекс + 1) + 1;
					ЭлементыРодителя[Индекс].ИндексСортировки = НовыйИндексСортировки;
					
					ЭлементыРодителя.Сдвинуть(ТекущийИндекс, ?(ПереместитьВверх, -1, 1));
					
					ДобавитьЗаписьИзменений(Услуга, НовыйИндексСортировки);
					
				ИначеЕсли ПереместитьВверх И Индекс = ТекущийИндекс - 1 Тогда
					
					ЭлементыРодителя[Индекс].ИндексСортировки = ЭлементыРодителя[Индекс].ИндексСортировки + 1;
					ДобавитьЗаписьИзменений(ЭлементыРодителя[Индекс].Услуга, ЭлементыРодителя[Индекс].ИндексСортировки);
					
				ИначеЕсли ПереместитьВниз И Индекс = ТекущийИндекс + 1 Тогда
					
					ЭлементыРодителя[Индекс - 1].ИндексСортировки = ЭлементыРодителя[Индекс].ИндексСортировки - 1;
					ДобавитьЗаписьИзменений(ЭлементыРодителя[Индекс - 1].Услуга, ЭлементыРодителя[Индекс - 1].ИндексСортировки);
					
				ИначеЕсли ЭлементыРодителя[Индекс].ИндексСортировки <> Индекс + 1 Тогда
					
					ЭлементыРодителя[Индекс].ИндексСортировки = Индекс + 1;
					ДобавитьЗаписьИзменений(ЭлементыРодителя[Индекс].Услуга, Индекс + 1);
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если ЭтотОбъект.ТаблицаИзменяемыхНоменклатур.Количество() > 0 Тогда
				ЗаписатьИзмененияСпискаНоменклатурДляОнлайнЗаписи();
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, добавляет в таблицу записи с индексами сотрировки.
// 
Процедура ДобавитьЗаписьИзменений(Услуга, ИндексСортировки)
	
	Если Объект.Ссылка = Услуга Тогда
		Объект.ИндексСортировки 			 = ИндексСортировки;
		ЗаписатьИндексСортировкиНоменклатуры = Истина;
	Иначе
		
		МассивСтрок = ЭтотОбъект.ТаблицаИзменяемыхНоменклатур.НайтиСтроки(Новый Структура("Услуга", Услуга));
		
		СтрокаТаблицы = ?(МассивСтрок.Количество() > 0, МассивСтрок[0], ЭтотОбъект.ТаблицаИзменяемыхНоменклатур.Добавить());
		СтрокаТаблицы.Услуга 		   = Услуга;
		СтрокаТаблицы.ИндексСортировки = ИндексСортировки;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - Получить строку родитель рекурсивно
//
// Параметры:
//  ТекущиеДанныеРодитель	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Процедура ПолучитьСтрокуРодительРекурсивно(ТекущиеДанныеРодитель, ДеревоУслугНом, СтрокаДереваНом)
	
	Для Каждого СтрокаДерева Из ДеревоУслугНом.ПолучитьЭлементы() Цикл				
				
		Если СтрокаДерева.ЭтоГруппа Тогда
			ПолучитьСтрокуРодительРекурсивно(ТекущиеДанныеРодитель, СтрокаДерева, СтрокаДереваНом);
		Иначе
			Прервать;
		КонецЕсли;
		
		Если СтрокаДереваНом <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		Если СтрокаДерева.Услуга = ТекущиеДанныеРодитель Тогда
			СтрокаДереваНом = СтрокаДерева;
			Прервать;
		КонецЕсли;		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Процедура, записывает в номенклатуры индексы сортировки.
// 
Процедура ЗаписатьИзмененияСпискаНоменклатурДляОнлайнЗаписи()
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.ТаблицаИзменяемыхНоменклатур Цикл
		
		Попытка
			УслугаОбъект = СтрокаТЧ.Услуга.ПолучитьОбъект();
			УслугаОбъект.ИндексСортировки = СтрокаТЧ.ИндексСортировки;
			УслугаОбъект.Записать();
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппаОнлайнЗаписиПриИзменении(Элемент)
	
	Объект.ИндексСортировки = 0;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) И ЭтотОбъект.ОнлайнЗапись Тогда
		ЗаполнитьДеревоУслуг(Истина);
	КонецЕсли;
	
КонецПроцедуры

