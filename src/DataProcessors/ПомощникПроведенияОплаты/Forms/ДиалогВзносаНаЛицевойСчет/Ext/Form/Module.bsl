&НаСервере
// Процедура - Построить динаимческую таблицу задолженностей.
//
Процедура ПостроитьДинамическиеЭлементы(ТипЭлемента)
	
	УдалитьДинамическиеЭлементы(ТипЭлемента);
	
	Индекс = 1;
	
	Если ТипЭлемента = "Касса" Тогда 
		
		// по 4 кассы в одной строке
		КолКассВСтроке				= 4;
		КолВыведенныхВСтрокуКасс	= 1;
		НомерСтрокиКассы			= 0;
		ФлагНоваяСтрока				= Ложь;
		
		Пока Индекс < ЭтотОбъект.ДоступныеКассы.Количество() Цикл
			
			ДанныеПоКассе = ЭтотОбъект.ДоступныеКассы[Индекс];
			ПостроитьЭлементыВыбораКассы(ДанныеПоКассе, Индекс, НомерСтрокиКассы, ФлагНоваяСтрока);
			ФлагНоваяСтрока = Ложь;
			
			Индекс = Индекс + 1;
			КолВыведенныхВСтрокуКасс = КолВыведенныхВСтрокуКасс + 1;
			Если КолВыведенныхВСтрокуКасс = КолКассВСтроке Тогда
				КолВыведенныхВСтрокуКасс	= 0;
				НомерСтрокиКассы			= НомерСтрокиКассы + 1; 
				ФлагНоваяСтрока				= Истина;
			КонецЕсли;			
			
		КонецЦикла;
		
		Если ЭтотОбъект.ДоступныеКассы.Количество() > 0 Тогда
			
			УстановитьСостояниеКнопкиВыбораКассы(Элементы.ГруппаКассаОплатыКнопка_0, Элементы.КассаОплаты_0);
			
		Иначе
			
			Элементы.КассаОплаты_0.Заголовок = "Нет доступных касс";
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить динаимеческие элементы состав занятия.
//
Процедура УдалитьДинамическиеЭлементы(ТипЭлемента)
	
	ОснованаяГруппа = РодительскаяГруппа(ТипЭлемента);
	
	Индекс = ОснованаяГруппа.ПодчиненныеЭлементы.Количество() - 1;
	Пока Индекс > 0  Цикл
		
		Элементы.Удалить(ОснованаяГруппа.ПодчиненныеЭлементы[Индекс]);
		
		Индекс = Индекс - 1;
		
	КонецЦикла;  
	
КонецПроцедуры

&НаСервере
// Процедура - Построить строку динамической таблицы задолженностей.
//
Процедура ПостроитьЭлементыВыбораКассы(ДаныеКассы, ИндексДанных, НомерСтроки = 0, ФлагНоваяСтрока)
	
	НомерСтрокиДан   = ИндексДанных;  
	ОсновнаяГруппа   = РодительскаяГруппа("Касса");
	
	Если ФлагНоваяСтрока Тогда
		
		ПодгруппаНовойСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
		ЭтаФорма,
		Элементы.Найти("ГруппаКассаОплатыСтроки_" + Строка(НомерСтроки - 1)), 
		НомерСтроки,
		ОсновнаяГруппа);
		
		ПодгруппаСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
		ЭтаФорма,
		Элементы.Найти("ГруппаКассаОплаты_0"), 
		НомерСтрокиДан,
		ПодгруппаНовойСтроки); 
		
	Иначе
		
		ГруппаСтроки = Элементы.Найти("ГруппаКассаОплатыСтроки_" + Строка(НомерСтроки));

		ПодгруппаСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
		ЭтаФорма,
		Элементы.Найти("ГруппаКассаОплаты_0"), 
		НомерСтрокиДан,
		ГруппаСтроки);  
		
	КонецЕсли;
	
	ПодгруппаКнопки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.Найти("ГруппаКассаОплатыКнопка_0"), 
	НомерСтрокиДан,
	ПодгруппаСтроки);
	
	КнопкаВыбораКассы = УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.Найти("КассаОплаты_0"),  
	НомерСтрокиДан,
	ПодгруппаКнопки,,
	ДаныеКассы.Касса.Наименование);   	
	
	УстановитьСостояниеКнопкиВыбораКассы(ПодгруппаКнопки, КнопкаВыбораКассы);
	
КонецПроцедуры

&НаСервере
// Процедура - Установить состояние кнопки выбора кассы.
//
Процедура УстановитьСостояниеКнопкиВыбораКассы(ГруппаКнопки, КнопкаВыбора)
	
	ИндексДанных = ИндексСтрокиДанныхПоИмениЭлемента(ГруппаКнопки.Имя);
	
	ДанныеКассы       = ЭтотОбъект.ДоступныеКассы[ИндексДанных];  
	ЭтоВыбраннаяКасса = ДанныеКассы.Касса = ЭтотОбъект.Касса;  
	
	КнопкаВыбора.Доступность = НЕ ЭтоВыбраннаяКасса И ДанныеКассы.КассаДоступна;
	ГруппаКнопки.ЦветФона    = ?(ЭтоВыбраннаяКасса, Новый Цвет(242, 242, 242), Новый Цвет(255, 255, 255));// Новый Цвет(242, 242, 242) 	
	КнопкаВыбора.ЦветТекста  = ?(ЭтоВыбраннаяКасса,  Новый Цвет(77, 77, 77), Новый Цвет(51, 102, 187));  
	КнопкаВыбора.Шрифт       = ?(ЭтоВыбраннаяКасса, Новый Шрифт(КнопкаВыбора.Шрифт, , 11), Новый Шрифт(КнопкаВыбора.Шрифт, , 11)); 	
	КнопкаВыбора.Заголовок   = ДанныеКассы.Касса.Наименование;
	КнопкаВыбора.Вид         = ВидКнопкиФормы.ОбычнаяКнопка;
	
КонецПроцедуры

