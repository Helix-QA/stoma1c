
#Область СлужебныеПроцедурыИФункции

// Формирует таблицу данных документа.
//
// Параметры:
//	ДокументСсылка - ДокументСсылка.ПриходДенежныхСредствПлан - Текущий документ
//	СтруктураДополнительныеСвойства - ДополнительныеСвойства - Дополнительные свойства документа
//	
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
    Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПеремещениеДенежныхСредств.Дата КАК Период,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПеремещениеДенежныхСредств.ТипДенежныхСредств КАК ТипДенежныхСредств,
	|	ПеремещениеДенежныхСредств.ИсточникСписанияСредств КАК ИсточникДенежныхСредств,
	|	ПеремещениеДенежныхСредств.СуммаДокумента КАК Сумма,
	|	ПеремещениеДенежныхСредств.СтатьяРасходов КАК СтатьяРасходов
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредства
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И НЕ ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхсредств.ЛицевойСчет)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ПеремещениеДенежныхСредств.Дата,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница,
	|	ПеремещениеДенежныхСредств.ТипДенежныхСредств,
	|	ПеремещениеДенежныхСредств.ПриемникЗачисленияСредств,
	|	ПеремещениеДенежныхСредств.СуммаДокумента,
	|	ПеремещениеДенежныхСредств.СтатьяРасходов
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И НЕ ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхсредств.ЛицевойСчет)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПеремещениеДенежныхСредств.Дата КАК Период,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПеремещениеДенежныхСредств.ИсточникВидЛицевогоСчета КАК ВидСчета,
	|	ПеремещениеДенежныхСредств.ИсточникСписанияСредств КАК Контрагент,
	|	ПеремещениеДенежныхСредств.СуммаДокумента КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредстваНаЛицевыхСчетах
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхсредств.ЛицевойСчет)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ПеремещениеДенежныхСредств.Дата,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница,
	|	ПеремещениеДенежныхСредств.ПриемникВидЛицевогоСчета,
	|	ПеремещениеДенежныхСредств.ПриемникЗачисленияСредств,
	|	ПеремещениеДенежныхСредств.СуммаДокумента
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхсредств.ЛицевойСчет)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПеремещениеДенежныхСредств.Дата КАК Период,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ПеремещениеДенежныхСредств.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА ПеремещениеДенежныхСредств.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ ПеремещениеДенежныхСредств.Организация
	|	КОНЕЦ КАК Организация,
	|	ПеремещениеДенежныхСредств.ИсточникСписанияСредств КАК Контрагент,
	|	ПеремещениеДенежныхСредств.СуммаДокумента КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыКонтрагентов
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)
	|	И ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ПеремещениеДенежныхСредств.Дата,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ПеремещениеДенежныхСредств.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА ПеремещениеДенежныхСредств.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ ПеремещениеДенежныхСредств.Организация
	|	КОНЕЦ,
	|	ПеремещениеДенежныхСредств.ПриемникЗачисленияСредств,
	|	ПеремещениеДенежныхСредств.СуммаДокумента
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)
	|	И ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПеремещениеДенежныхСредств.Дата КАК Период,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) КАК СчетДт,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Касса) КАК СчетКт,
	|	ПеремещениеДенежныхСредств.ПриемникЗачисленияСредств КАК СубконтоДт1,
	|	ВЫБОР
	|		КОГДА ПеремещениеДенежныхСредств.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА ПеремещениеДенежныхСредств.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПеремещениемеждуКассами)
	|	КОНЕЦ КАК СубконтоДт2,
	|	ПеремещениеДенежныхСредств.ИсточникСписанияСредств КАК СубконтоКт1,
	|	ВЫБОР
	|		КОГДА ПеремещениеДенежныхСредств.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА ПеремещениеДенежныхСредств.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПеремещениемеждуКассами)
	|	КОНЕЦ КАК СубконтоКт2,
	|	ПеремещениеДенежныхСредств.СуммаДокумента КАК Сумма,
	|	""Перемещение денежных средств"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеДенежныхСредств.Дата,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Банк),
	|	ПеремещениеДенежныхСредств.ПриемникЗачисленияСредств,
	|	ВЫБОР
	|		КОГДА ПеремещениеДенежныхСредств.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА ПеремещениеДенежныхСредств.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПеремещениемеждуСчетами)
	|	КОНЕЦ,
	|	ПеремещениеДенежныхСредств.ИсточникСписанияСредств,
	|	ВЫБОР
	|		КОГДА ПеремещениеДенежныхСредств.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА ПеремещениеДенежныхСредств.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПеремещениемеждуСчетами)
	|	КОНЕЦ,
	|	ПеремещениеДенежныхСредств.СуммаДокумента,
	|	""Перемещение денежных средств""
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеДенежныхСредств.Дата,
	|	ПеремещениеДенежныхСредств.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПокупателиПоАвансам),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПокупателиПоАвансам),
	|	ПеремещениеДенежныхСредств.ПриемникЗачисленияСредств,
	|	ПеремещениеДенежныхСредств.ПриемникВидЛицевогоСчета,
	|	ПеремещениеДенежныхСредств.ИсточникСписанияСредств,
	|	ПеремещениеДенежныхСредств.ИсточникВидЛицевогоСчета,
	|	ПеремещениеДенежныхСредств.СуммаДокумента,
	|	""Перемещение денежных средств""
	|ИЗ
	|	Документ.ПеремещениеДенежныхСредств КАК ПеремещениеДенежныхСредств
	|ГДЕ
	|	ПеремещениеДенежныхСредств.Ссылка = &Ссылка
	|	И ПеремещениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);	
	Запрос.ВыполнитьПакет();
	
	СформироватьТаблицаДенежныеСредства(СтруктураДополнительныеСвойства);
	СформироватьТаблицаДенежныеСредстваНаЛицевыхСчетах(СтруктураДополнительныеСвойства);
	СформироватьТаблицаВзаиморасчетыСКонтрагентами(СтруктураДополнительныеСвойства);
	СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаДенежныеСредства(СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.ВидДвижения КАК ВидДвижения,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаДокумента.ТипДенежныхСредств КАК ТипДенежныхСредств,
	|	ТаблицаДокумента.ИсточникДенежныхСредств КАК БанковскийСчетКасса,
	|	ТаблицаДокумента.Сумма КАК Сумма,
	|	ТаблицаДокумента.СтатьяРасходов КАК Статья
	|ИЗ
	|	ВременнаяТаблицаДенежныеСредства КАК ТаблицаДокумента
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДенежныеСредства", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаДенежныеСредства()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаДенежныеСредстваНаЛицевыхСчетах(СтруктураДополнительныеСвойства)
	
    Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДенежныеСредстваНаЛицевыхСчетах.НомерСтроки,
	|	ДенежныеСредстваНаЛицевыхСчетах.Период,
	|	ДенежныеСредстваНаЛицевыхСчетах.СтруктурнаяЕдиница,
	|	ДенежныеСредстваНаЛицевыхСчетах.Контрагент,
	|	ДенежныеСредстваНаЛицевыхСчетах.ВидДвижения,
	|	ДенежныеСредстваНаЛицевыхСчетах.ВидСчета,
	|	ДенежныеСредстваНаЛицевыхСчетах.Сумма
	|ИЗ
	|	ВременнаяТаблицаДенежныеСредстваНаЛицевыхСчетах КАК ДенежныеСредстваНаЛицевыхСчетах
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДенежныеСредстваНаЛицевыхСчетах.НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДенежныеСредстваНаЛицевыхСчетах", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаВзаиморасчетыСКонтрагентами(СтруктураДополнительныеСвойства)
	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	ТаблицаВзаиморасчетыСКонтрагентами.НомерСтроки КАК НомерСтроки,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ВидДвижения КАК ВидДвижения,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Период КАК Период,
	|	ТаблицаВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Контрагент КАК Контрагент,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Организация КАК Организация,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Сумма КАК Сумма
	|ИЗ
	|	ВременнаяТаблицаВзаиморасчетыКонтрагентов КАК ТаблицаВзаиморасчетыСКонтрагентами
	|ГДЕ
	|	ТаблицаВзаиморасчетыСКонтрагентами.Сумма <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаВзаиморасчетыСКонтрагентами", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры	

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблицаУправленческий.Период,
	|	ВременнаяТаблицаУправленческий.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаУправленческий.СчетДт,
	|	ВременнаяТаблицаУправленческий.СчетКт,
	|	ВременнаяТаблицаУправленческий.СубконтоДт1,
	|	ВременнаяТаблицаУправленческий.СубконтоДт2,
	|	ВременнаяТаблицаУправленческий.СубконтоКт1,
	|	ВременнаяТаблицаУправленческий.СубконтоКт2,
	|	СУММА(ВременнаяТаблицаУправленческий.Сумма) КАК Сумма,
	|	ВременнаяТаблицаУправленческий.Содержание
	|ИЗ
	|	ВременнаяТаблицаУправленческий КАК ВременнаяТаблицаУправленческий
	|
	|СГРУППИРОВАТЬ ПО
	|	ВременнаяТаблицаУправленческий.Период,
	|	ВременнаяТаблицаУправленческий.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаУправленческий.СчетДт,
	|	ВременнаяТаблицаУправленческий.СчетКт,
	|	ВременнаяТаблицаУправленческий.СубконтоДт1,
	|	ВременнаяТаблицаУправленческий.СубконтоДт2,
	|	ВременнаяТаблицаУправленческий.СубконтоКт1,
	|	ВременнаяТаблицаУправленческий.СубконтоКт2,
	|	ВременнаяТаблицаУправленческий.Содержание";
	
	РезультатЗапроса = Запрос.Выполнить();	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаУправленческий", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры


