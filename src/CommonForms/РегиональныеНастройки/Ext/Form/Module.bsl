// Процедура - Подключаемый ожидание длительной операции
//
Процедура Подключаемый_ОжиданиеДлительнойОперации()
	
	// Обновим статус
	Состояние = СостояниеФоновогоЗадания(ПараметрыДлительнойОперации.ИдентификаторЗадания);
	Если Не ПустаяСтрока(Состояние.Ошибка) Тогда
		// Завершено с ошибкой, сообщим и вернемся на первую страницу.
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Состояние.Ошибка);
		Возврат;
	ИначеЕсли Состояние.Завершено Тогда
		ТекстОписанияОчистки = НСтр("ru='Формат телефонных номеров успешно обновлен.';en='Format telephone numbers successfully updated.'");
		Состояние(НСтр("ru='Завершение...';en='Completion'"), 100, , БиблиотекаКартинок.Информация32);
		ПоказатьПредупреждение( , ТекстОписанияОчистки, , НСтр("ru = 'Сообщение пользователю'; en = 'Message to user'"));
		Элементы.ПрименитьФорматТелефонныхНомеров.Доступность = Истина;
		Возврат;
	КонецЕсли;
	
	// Процесс продолжается
	Если ТипЗнч(Состояние.Прогресс) = Тип("Структура") Тогда
		Состояние(Состояние.Прогресс.Текст, Состояние.Прогресс.Процент, Состояние.Прогресс.ДополнительныеПараметры.ТипОбъекта + ": " + Состояние.Прогресс.ДополнительныеПараметры.НаименованиеОбъекта, БиблиотекаКартинок.Информация32);	
	КонецЕсли;
	ПодключитьОбработчикОжидания("Подключаемый_ОжиданиеДлительнойОперации", 0.1, Истина);
	
КонецПроцедуры

