&НаКлиенте
// Процедура - Вставить из файла обработка
//
// Параметры:
//  Описание - 	 - 
//
Процедура ВставитьИзФайлаОбработка(Описание)
	
	ИдентификаторФайла = Новый УникальныйИдентификатор;
	
	Фильтр = НСтр("ru = 'Все картинки (*.bmp;*.gif;*.png;*.jpeg;*.dib;*.rle;*.tif;*.jpg;*.ico;*.wmf;*.emf)|*.bmp;*.gif;*.png;*.jpeg;*.dib;*.rle;*.tif;*.jpg;*.ico;*.wmf;*.emf"
	+ "|Все файлы(*.*)|*.*"
	+ "|Формат bmp(*.bmp*;*.dib;*.rle)|*.bmp;*.dib;*.rle"
	+ "|Формат GIF(*.gif*)|*.gif"
	+ "|Формат JPEG(*.jpeg;*.jpg)|*.jpeg;*.jpg"
	+ "|Формат PNG(*.png*)|*.png"
	+ "|Формат TIFF(*.tif)|*.tif"
	+ "|Формат icon(*.ico)|*.ico"
	+ "|Формат метафайл(*.wmf;*.emf)|*.wmf;*.emf'");
	
	РаботаСФайламиКлиент.ДобавитьФайлы(Объект.Ссылка, ИдентификаторФайла, Фильтр,,, Описание);
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить записать параметры внешней системы
//
Процедура ЗаполнитьЛогоСЕВРезерви()
	
	Попытка
		Соединение = Новый HTTPСоединение("reservi.ru/4.0/",);
		
		УИД = СтрЗаменить(Объект.Ссылка.УникальныйИдентификатор(), "-", "");
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("salons[]", УИД);
		Заголовки.Вставить("Content-Type","application/json");
		Заголовки.Вставить("state", "fastinit");
		Заголовки.Вставить("ver", "2.053");
		Запрос = Новый HTTPЗапрос("https://reservi.ru/4.0/?salons%5B%5D=" + УИД + "&state=fastinit&ver=2.053");
		
		Результат = Соединение.Получить(Запрос);
		ТекстJSON  = Результат.ПолучитьТелоКакСтроку(); 
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON, Истина );
		ИнфоОСТруктурнойЕдинице = Новый Соответствие;
		ИнфоОСТруктурнойЕдинице = ПараметрыJSON.Получить("data");
		ИнфоОСуществовании = Новый Соответствие;
		ИнфоОСуществовании = ИнфоОСТруктурнойЕдинице.Получить("fastinit");
		
		Если Тип(ИнфоОСуществовании) <> Тип("Массив") Или ИнфоОСуществовании.Количество() = 0  Тогда
			
			ИспользуемыеСтруктурныеЕдиницы = Новый Массив;
			ИспользуемыеСтруктурныеЕдиницы.Добавить(Объект.Ссылка);
			
			ВнешняяСистемаReservi		= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи);
			ПараметрыВнешнейСистемы 	= ВнешняяСистемаReservi.Параметры.Получить();
			МассивФайловКартинок 		= ПолучитьВсеПодчиненныеФайлы(Объект.Ссылка, "ЛоготипМагазина");
			ФайлКартинки		 		= ?(МассивФайловКартинок.Количество() > 0, МассивФайловКартинок[0], Неопределено);
			
			Если ЗначениеЗаполнено(ФайлКартинки) Тогда
				
				ЛичныйКабинет.РегистрацияСтруктурныхЕдиницВиджета(ИспользуемыеСтруктурныеЕдиницы);
				
			КонецЕсли;
			
		КонецЕсли;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

