		// КонецЕсли;
		
		Если ТипЗнч(Параметры) = Тип("Структура") И Параметры.Свойство("Ширина") И Параметры.Ширина = 80 Тогда
			ТабДок.Область("C15:C15").ШиринаКолонки = 8;
		ИначеЕсли ТипЗнч(Параметры) = Тип("Структура") И Параметры.Свойство("Ширина") И Параметры.Ширина = 100 Тогда
			ТабДок.Область("C15:C15").ШиринаКолонки = 18;
		КонецЕсли;
		
		Возврат ТабДок;
		
	Иначе
		
		Пречек = "";
		Для Индекс = 1 По ТабДок.КоличествоСтрок() Цикл
			ПреЧек = ПреЧек + ТабДок.ПолучитьСтроку(Индекс) + ?(Индекс = ТабДок.КоличествоСтрок(), "", Символ(13) + Символ(10));
		КонецЦикла;
		
		Возврат ПреЧек;
		
	КонецЕсли;
	
