// Функция определяет количество потоков.
//
Функция ОпределитьКоличествоПотоков(ОбщееКоличествоДокументов, ПараметрыПроводимыхДокументов)
	
	КоличествоПотоков = 1;
	Если ПараметрыПроводимыхДокументов.КоличествоПотоков = "Авто" Тогда 
		Если ПараметрыПроводимыхДокументов.ИмяДокумента = "ЧленствоПакетУслуг" И ЕстьПроведенныеДокументыЗакрытияДней() Тогда 
			Возврат 1;
		Иначе 
			Если ОбщееКоличествоДокументов < 100 Тогда
				КоличествоПотоков = 1;
			ИначеЕсли ОбщееКоличествоДокументов >= 100 И ОбщееКоличествоДокументов < 400 Тогда
				КоличествоПотоков = 2;
			ИначеЕсли ОбщееКоличествоДокументов >= 400 И ОбщееКоличествоДокументов < 4000 Тогда
				КоличествоПотоков = 4;
			Иначе 	
				КоличествоПотоков = 8;
			КонецЕсли;	
		КонецЕсли;	
	Иначе 
		КоличествоПотоков = Число(ПараметрыПроводимыхДокументов.КоличествоПотоков);
	КонецЕсли;
	
	Если ОбщееКоличествоДокументов < КоличествоПотоков Тогда 
		КоличествоПотоков = 1;
	КонецЕсли;
	
	ПараметрыПроводимыхДокументов.КоличествоПотоков = Строка(КоличествоПотоков);
	
	Возврат КоличествоПотоков;
	
КонецФункции

// Функция проверяет наличие проведенных документов "Закрытие дня".
//
Функция ЕстьПроведенныеДокументыЗакрытияДней()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗакрытиеДня.Ссылка) КАК Ссылка
	               |ИЗ
	               |	Документ.ЗакрытиеДня КАК ЗакрытиеДня
	               |ГДЕ
	               |	ЗакрытиеДня.Проведен = ИСТИНА";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если РезультатЗапроса.Количество() = 0 Тогда 
		Возврат Ложь;
	Иначе 
		Если РезультатЗапроса[0].Ссылка > 0 Тогда 
			Возврат Истина;
		Иначе 
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	// Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции

// Функция возвращет количество не проведенных документов.
//  
Функция ПолучитьКоличествоНеПроведенныхДокументы(ПараметрыЗадания)
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДокументПроведения.Ссылка) КАК Ссылка
	               |ИЗ
	               |	Документ.&ДОКУМЕНТ КАК ДокументПроведения
	               |ГДЕ
				   |	ДокументПроведения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
				   |	И ДокументПроведения.Проведен = ЛОЖЬ
				   |	И ДокументПроведения.ПометкаУдаления = ЛОЖЬ"
				   +?(ЗначениеЗаполнено(ПараметрыЗадания.ПериодПроведения.ДатаНачала)," И ДокументПроведения.Дата >= &НачалоПериода", "")
				   +?(ЗначениеЗаполнено(ПараметрыЗадания.ПериодПроведения.ДатаОкончания)," И ДокументПроведения.Дата <= &КонецПериода", "")	+ "";
				   
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДОКУМЕНТ", ПараметрыЗадания.ИмяДокумента);
	
	ЗапросДокументы = Новый Запрос(ТекстЗапроса);
	ЗапросДокументы.УстановитьПараметр("СтруктурнаяЕдиница"	, ПараметрыЗадания.СтруктурнаяЕдиница);
	ЗапросДокументы.УстановитьПараметр("НачалоПериода"		, ПараметрыЗадания.ПериодПроведения.ДатаНачала);
	ЗапросДокументы.УстановитьПараметр("КонецПериода"		, ПараметрыЗадания.ПериодПроведения.ДатаОкончания);
	
	РезультатЗапроса = ЗапросДокументы.Выполнить().Выгрузить();
	// Возврат РезультатЗапроса.Количество() = 0  
	
	Если РезультатЗапроса.Количество() = 0 Тогда 
		Возврат 0;
	Иначе 
		Возврат РезультатЗапроса[0].Ссылка; 
	КонецЕсли;
	
КонецФункции

