&НаСервере
// Процедура, ОбновитьЭтапыСделки.
//
Процедура ОбновитьЭтапыСделки()
	
	ОчиститьГруппуЭтапыСделки();
	
	ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(Объект.ВидСделки);
	
	Если ТаблицаЭтапов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуЭтапыСделок(ТаблицаЭтапов);
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка)
		И НЕ ЗначениеЗаполнено(Объект.ЭтапСделки) Тогда
		
		Объект.ЭтапСделки = ЭтотОбъект.ЭтапыСделок[0].Ссылка;
	КонецЕсли;
	
	ПустойЦвет = Новый Цвет();
	Если Объект.РезультатСделки = Перечисления.РезультатыСделок.Отказ Тогда 
		ТекущийПредзавершающийЭтап = ?(ЗначениеЗаполнено(Объект.ЭтапОтказа), Объект.ЭтапОтказа, Объект.ЭтапСделки);
	ИначеЕсли Объект.РезультатСделки = Перечисления.РезультатыСделок.Успех Тогда 
		ТекущийПредзавершающийЭтап = ?(ЗначениеЗаполнено(Объект.ЭтапУспеха), Объект.ЭтапУспеха, Объект.ЭтапСделки);
	Иначе 
		ТекущийПредзавершающийЭтап = Объект.ЭтапСделки;
	КонецЕсли;	
	НомерТекущегоЭтапа 	= ?(ЗначениеЗаполнено(ТекущийПредзавершающийЭтап), Макс(ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущийПредзавершающийЭтап, "НомерЭтапа"), 1), 1);
	Индекс 				= 0;
	ДопустимОтказ 		= ?(ВидСделкиПредопределенный, Справочники.Сделки.ДопустимОтказСогласноТекущегоЭтапа(Объект.Ссылка, ВидСделкиПредопределенный), Истина);
	
	Для Каждого СтрокаТЗ Из ТаблицаЭтапов Цикл
		
		ЭтапСделки 	= СтрокаТЗ.ЭтапСделки;
		// ТекущийЭтап = Объект.ЭтапСделки = СтрокаТЗ.ЭтапСделки;
		
		ГруппаЭтапа = Элементы.Добавить("ГруппаЭтап_" + Индекс, Тип("ГруппаФормы"), Элементы.ГруппаЭтапыСделки);
		ГруппаЭтапа.Вид                 	 				= ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаЭтапа.Группировка         	 				= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		ГруппаЭтапа.Отображение         	 				= ОтображениеОбычнойГруппы.Нет;
		ГруппаЭтапа.ОтображатьЗаголовок 	 				= Ложь;
		ГруппаЭтапа.РастягиватьПоГоризонтали 				= Истина;
		ГруппаЭтапа.Ширина					 				= 20;
		ГруппаЭтапа.Высота					 				= 1;
		ГруппаЭтапа.РастягиватьПоВертикали 					= Ложь;
		ГруппаЭтапа.ВертикальноеПоложениеПодчиненных 		= ВертикальноеПоложениеЭлемента.Центр;
		
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЭтапСделки" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
		ПараметрыДекорации.Вставить("Картинка"					, ?(НЕ ЗначениеЗаполнено(Объект.РезультатСделки) И СтрокаТЗ.НомерЭтапа = НомерТекущегоЭтапа, БиблиотекаКартинок.ЧекБоксПолный, БиблиотекаКартинок.Пустая));
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 0;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
		КнопкаЭтапа = Элементы.Добавить("КнопкаЭтап_" + Индекс, Тип("КнопкаФормы"), ГруппаЭтапа);
		КнопкаЭтапа.Заголовок				 				= ЭтапСделки.Наименование;
		КнопкаЭтапа.ОтображениеФигуры		 				= ОтображениеФигурыКнопки.Нет;
		КнопкаЭтапа.ИмяКоманды				 				= "ИзменитьЭтап";
		КнопкаЭтапа.РастягиватьПоГоризонтали 				= Истина;
		КнопкаЭтапа.Фигура 									= ФигураКнопки.Овал;
		КнопкаЭтапа.Отображение								= ОтображениеКнопки.Текст;			
		КнопкаЭтапа.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЭтапСделки_Пустая" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
		ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.Пустая);
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 0;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
		Если ВидСделкиПредопределенный Тогда
			Если ЗначениеЗаполнено(Объект.РезультатСделки) Тогда
				Если Объект.РезультатСделки = Перечисления.РезультатыСделок.Успех Тогда 
					КнопкаЭтапа.Доступность 	= Ложь;
				Иначе 
					КнопкаЭтапа.Доступность 	= ДопустимОтказ И (СтрокаТЗ.НомерЭтапа = 1 ИЛИ СтрокаТЗ.НомерЭтапа = 2);
				КонецЕсли;	
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 1 ИЛИ СтрокаТЗ.НомерЭтапа = 2 Тогда
				КнопкаЭтапа.Доступность 		= НомерТекущегоЭтапа < 3;
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 3 Тогда 
				КнопкаЭтапа.Доступность 		= Ложь;
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 4 Тогда 	
				КнопкаЭтапа.Доступность 		= НомерТекущегоЭтапа > 2;
			КонецЕсли;
		КонецЕсли;
		
		РезультатСделкиУспех = (Объект.РезультатСделки = Перечисления.РезультатыСделок.Успех);
		
		Если (Индекс + 1) <= НомерТекущегоЭтапа Тогда 
			//ИЛИ (ЗначениеЗаполнено(Объект.РезультатСделки) И РезультатСделкиУспех) Тогда
			
			Если НЕ ЗначениеЗаполнено(ЭтапСделки.ЦветЭтапа)
				ИЛИ ЗначениеИзСтрокиВнутр(ЭтапСделки.ЦветЭтапа) = Новый Цвет() Тогда
				
				Цвет =	Новый Цвет(0,112,210);
			Иначе
				Цвет = ЗначениеИзСтрокиВнутр(ЭтапСделки.ЦветЭтапа);
			КонецЕсли;
			
			ГруппаЭтапа.ЦветФона   = Цвет;
			КнопкаЭтапа.ЦветТекста = ПолучитьЦветТекстаПоФону(ГруппаЭтапа.ЦветФона);
		Иначе
			ГруппаЭтапа.ЦветФона   = Новый Цвет(238,241,246); // бледно серый
			КнопкаЭтапа.ЦветТекста = Новый Цвет(117,117,117); // бледно серый			
		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
		
КонецПроцедуры

