Процедура ПолучитьВысотуSVGПодпора();
	
	РазрешениеЭкрана = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьТекущееРазрешениеЭкрана();
	ШиринаЭкрана	 = Сред(РазрешениеЭкрана, 1, Найти(РазрешениеЭкрана, "*") - 1);
	
	Если ШиринаЭкрана = "1280" Тогда 
		ВысотаSVGПодбора = "125px";
		ЭтаФорма.Масштаб = 88;
	ИначеЕсли ШиринаЭкрана = "1360" Тогда 
		ВысотаSVGПодбора = "65px";
		ЭтаФорма.Масштаб = 94;
	ИначеЕсли ШиринаЭкрана = "1366" Тогда 
		ВысотаSVGПодбора = "65px";
		ЭтаФорма.Масштаб = 94;
	ИначеЕсли ШиринаЭкрана = "1400" Тогда 
		ВысотаSVGПодбора = "120px";		
		ЭтаФорма.Масштаб = 95;
	ИначеЕсли ШиринаЭкрана = "1440" Тогда 
		ВысотаSVGПодбора = "110px";	
	ИначеЕсли ШиринаЭкрана = "1600" Тогда 
		ВысотаSVGПодбора = "114px";		
	ИначеЕсли ШиринаЭкрана = "1680" Тогда 
		ВысотаSVGПодбора = "135px";     
	ИначеЕсли ШиринаЭкрана = "1920" Тогда 
		ВысотаSVGПодбора = "135px";		  
	Иначе
		ВысотаSVGПодбора = "135px";
	КонецЕсли;	

КонецПроцедуры

