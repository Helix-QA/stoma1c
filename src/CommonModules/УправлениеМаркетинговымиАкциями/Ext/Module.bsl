				ПроцентРучнойСкидки			= ?(СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок > 0, (СтрокаТЧ.СуммаРучнойСкидки) / (СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок) * 100, 0);
				
				ИспользуемаяВалюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Для строки № %1 процент ручной скидки уменьшен с %2 до %3, сумма ручной скидки уменьшена с %4 %5 до %6 %5'; en = 'For line №%1, the percentage of manual discounts is reduced from %2 to %3, the amount of manual discounts is reduced from %4 %5 to %6 %5'"), 
