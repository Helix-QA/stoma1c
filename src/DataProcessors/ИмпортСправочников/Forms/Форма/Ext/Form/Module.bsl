
////////////////////////////////////////////////////////////////////////////////
// Процесс подготовкм к импорту

&НаКлиенте
// Процедура - обработчик события "ПриОткрытии"
//
Процедура ПриОткрытии(Отказ)
	
	ФлагРазрешенияИмпорта = Ложь;
	СимволРазделитель = ";";
	ЗагружаемыйСправочник = "Пациенты";
	ВыбратьСправочник();
	ЗаполнитьТаблицуСоответствий();

КонецПроцедуры

&НаКлиенте
// Обработчик события выбора заполняемого справочника
// 
Процедура ВыборСправочникаПриИзменении(Элемент)	
	
	ВыбратьСправочник();
	ЗаполнитьТаблицуСоответствий();
	
КонецПроцедуры

&НаСервере
// Выбрать заполняемый справочник
//
Процедура ВыбратьСправочник()
	
	Объект.ТаблицаСоответсвийПолей.Очистить();
	Элементы.Декорация1.Заголовок = "";
	
	Если ЗагружаемыйСправочник = "Номенклатура" Тогда
		
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиЗагрузкиНоменклатуры;
		
		ВыборПапкиСправочника = Справочники.Номенклатура.ПустаяСсылка();
		// заполняем список наименований реквизитов заполняемого справочника
		СписокРеквизитовСправочника.Очистить();
		СписокРеквизитовСправочника.Добавить("Наименование");
		СписокРеквизитовСправочника.Добавить("Группа");
		СписокРеквизитовСправочника.Добавить("Артикул");
		СписокРеквизитовСправочника.Добавить("Цена");
		СписокРеквизитовСправочника.Добавить("Штрихкод");
		СписокРеквизитовСправочника.Добавить("Комментарий");
		СписокРеквизитовСправочника.Добавить("Норма времени");
		СписокРеквизитовСправочника.Добавить("Упаковка по умолчанию");
		СписокРеквизитовСправочника.Добавить("Коэффициент упаковки по умолчанию");
		СписокРеквизитовСправочника.Добавить("Цена за упаковку по умолчанию");
	Иначе	                          
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаНастройкиЗагрузкиКлиентов;
		
		ВыборПапкиСправочника = Справочники.Контрагенты.ПустаяСсылка();
		// заполняем список наименований реквизитов заполняемого справочника
		СписокРеквизитовСправочника.Очистить();
		СписокРеквизитовСправочника.Добавить("Номер амбулаторной карты");
		СписокРеквизитовСправочника.Добавить("Группа");
		СписокРеквизитовСправочника.Добавить("ФИО");
		СписокРеквизитовСправочника.Добавить("Фамилия");
		СписокРеквизитовСправочника.Добавить("Имя");
		СписокРеквизитовСправочника.Добавить("Отчество");
		СписокРеквизитовСправочника.Добавить("Дата рождения");
		СписокРеквизитовСправочника.Добавить("Дата регистрации");
		СписокРеквизитовСправочника.Добавить("Пол");
		СписокРеквизитовСправочника.Добавить("Адрес");
		СписокРеквизитовСправочника.Добавить("Телефон");
		СписокРеквизитовСправочника.Добавить("Email");
		СписокРеквизитовСправочника.Добавить("Комментарий");
		СписокРеквизитовСправочника.Добавить("Серия полиса");
		СписокРеквизитовСправочника.Добавить("Номер полиса");
		СписокРеквизитовСправочника.Добавить("Начало действия полиса");
		СписокРеквизитовСправочника.Добавить("Конец действия полиса");
		СписокРеквизитовСправочника.Добавить("Код синхронизации"); 
		СписокРеквизитовСправочника.Добавить("Метки *");
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поля "ПоискПоТипу".
//
Процедура ПоискПоТипуПриИзменении(Элемент)
	
	ЗаполнитьТаблицуСоответствий();
	
КонецПроцедуры

&НаКлиенте
// Заполнение колонок таблицы соответствий,колонка реквизиты справочника
//
Процедура ЗаполнитьТаблицуСоответствий()
	
	Объект.ТаблицаСоответсвийПолей.Очистить();
	
	ИндексЗначения = 0;
	Пока ИндексЗначения < СписокРеквизитовСправочника.Количество() Цикл		
		Строка = Объект.ТаблицаСоответсвийПолей.Добавить();
		Строка.РеквизитСправочника = СписокРеквизитовСправочника[ИндексЗначения].Значение;
		Если ПоискПоТипу = 1 И СписокРеквизитовСправочника[ИндексЗначения].Значение = "Наименование" Тогда 
			Строка.ОтметкаНезаполненного = Истина;
		ИначеЕсли ПоискПоТипу = 3 И СписокРеквизитовСправочника[ИндексЗначения].Значение = "Артикул" Тогда		
			Строка.ОтметкаНезаполненного = Истина;
		Иначе 
			Строка.ОтметкаНезаполненного = Ложь;
		КонецЕсли;			
		ИндексЗначения = ИндексЗначения + 1;
	КонецЦикла;
	
	ФлагРазрешенияИмпорта = Истина;
	
КонецПроцедуры	

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора"
//
Процедура ВыборФайлаИмпортаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ВыборФайла(Элемент);
		
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении"
//
Процедура ВыборФайлаИмпортаПриИзменении(Элемент)
	
	ЧитаемыйФайл = Новый Файл(ФайлИмпорта);
	
	ЧитаемыйФайл.НачатьПроверкуСуществования(Новый ОписаниеОповещения("ВыборФайлаИмпортаПослеПроверки", ЭтотОбъект, Новый Структура("ЧитаемыйФайл", ЧитаемыйФайл)));
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборФайлаИмпортаПослеПроверки(ПроверкаПройдена, ДополнительныеПараметры) Экспорт
	
	ЧитаемыйФайл = ДополнительныеПараметры.ЧитаемыйФайл;
	
	Если НЕ ПроверкаПройдена И НЕ ДополнительныеПараметры.Свойство("ПроверкаНаКаталогЗавершилась")
		//Если каталог
		ИЛИ ПроверкаПройдена И ДополнительныеПараметры.Свойство("ПроверкаНаКаталогЗавершилась") Тогда
		ПоказатьПредупреждение(,"Выберите файл загрузки."); 
	ИначеЕсли НЕ ДополнительныеПараметры.Свойство("ПроверкаНаКаталогЗавершилась") Тогда
		ЧитаемыйФайл.НачатьПроверкуЭтоКаталог(Новый ОписаниеОповещения("ВыборФайлаИмпортаПослеПроверки", ЭтотОбъект, Новый Структура("ЧитаемыйФайл, ПроверкаНаКаталогЗавершилась", ЧитаемыйФайл, Истина)));
		Возврат;
	Иначе
		ВыборФайлаИмпортаПриИзмененииЗавершение(ЧитаемыйФайл);
	КонецЕсли; 
	
КонецПроцедуры  

&НаКлиенте
Процедура ВыборФайлаИмпортаПриИзмененииЗавершение(ЧитаемыйФайл)
	
	Расширение = нРег(ЧитаемыйФайл.Расширение);
	
	Если нРег(Расширение) = ".xls" ИЛИ нРег(Расширение) = ".xlsx" Тогда
		
		ТипФайлаИмпорта = "EXCEL";
		элементы.СимволРазделитель.Видимость = Ложь;
	ИначеЕсли нРег(Расширение) = ".csv" Тогда
		
		ТипФайлаИмпорта = "TEXT";	
		элементы.СимволРазделитель.Видимость = Истина;
	КонецЕсли;
	
	Если ПолучитьПоляФайла() = Истина Тогда
		Элементы.ТаблицаСоответствияПолейПолеКолФайла.СписокВыбора.ЗагрузитьЗначения(СписокКолонокФайла.ВыгрузитьЗначения());
		// ЗаполнитьТаблицуСоответствий();
	Иначе 
		ПоказатьПредупреждение(,"Оперция прервана импорт не возможен !");
		Элементы.Декорация1.Заголовок = "";
	КонецЕсли;	
	
	Элементы.Декорация1.Заголовок = ФайлИмпорта;

КонецПроцедуры

&НаКлиенте
// Открывает диалог выбора файла
//
Процедура ВыборФайла(Элемент)	
	
	ДиалогВыбораФайла =	Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	ДиалогВыбораФайла.Фильтр = "Файл импорта (*.csv;*.xls;*.xlsx)|*.csv;*.xls;*.xlsx";
	
	ДиалогВыбораФайла.Заголовок						=	"Выберите файл";
	ДиалогВыбораФайла.ПредварительныйПросмотр		=	Ложь;
	ДиалогВыбораФайла.ИндексФильтра					=	0;
	ДиалогВыбораФайла.ПолноеИмяФайла				=	ФайлИмпорта;
	ДиалогВыбораФайла.ПроверятьСуществованиеФайла	=	Истина;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыборФайлаЗавершение", ЭтотОбъект, Новый Структура("ДиалогВыбораФайла, Элемент", ДиалогВыбораФайла, Элемент));

	ДиалогВыбораФайла.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборФайлаЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	ДиалогВыбораФайла = ДополнительныеПараметры.ДиалогВыбораФайла;
	Элемент = ДополнительныеПараметры.Элемент;

	Если (ВыбранныеФайлы <> Неопределено) Тогда
		ФайлИмпорта = ДиалогВыбораФайла.ПолноеИмяФайла;
	КонецЕсли;
	
	ВыборФайлаИмпортаПриИзменении(Элемент);

КонецПроцедуры

&НаКлиенте
//
//
Процедура СимволРазделительПриИзменении(Элемент)
	
	Если ПолучитьПоляФайла()=Истина Тогда
		Элементы.ТаблицаСоответствияПолейПолеКолФайла.СписокВыбора.ЗагрузитьЗначения(СписокКолонокФайла.ВыгрузитьЗначения());
		ЗаполнитьТаблицуСоответствий();
	Иначе 
		ПоказатьПредупреждение(,"Оперция прервана импорт не возможен !");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Создаем и заполняем новый элемент справочника
//
Процедура ЗаполнитьРеквизитыСправочника(СтруктураРеквизитов, ИсходнаяСтрокаДанных, ВидМедицинскихКарт, СтруктураТелефонногоНомера = Неопределено)
	
	Если СтруктураРеквизитов.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ненайдено соответствий наименований реквизитов и полей файла");
		Возврат;
	КонецЕсли;		 
	
	Попытка		

		
		Если ЗагружаемыйСправочник = "Номенклатура" Тогда
			
#Область _____________________________________________________СОЗДАНИЕ_ОБЪЕКТА_СПРАВОЧНИКА_НОМЕНКЛАТУРА_____________________________________________________________		
			
			// Получаем значения реквизитов
			Наименование 					= ВернутьЗначениеРевизита("Наименование",	СтруктураРеквизитов);
			Артикул 						= ВернутьЗначениеРевизита("Артикул",		СтруктураРеквизитов);
			Цена 							= ВернутьЗначениеРевизита("Цена",			СтруктураРеквизитов);
			Штрихкод 						= ВернутьЗначениеРевизита("Штрихкод",		СтруктураРеквизитов);
			Комментарий 					= ВернутьЗначениеРевизита("Комментарий",	СтруктураРеквизитов);
			НормаВремени 	 				= ВернутьЗначениеРевизита("НормаВремени", СтруктураРеквизитов);
			УпаковкаПоУмолчанию 			= ВернутьЗначениеРевизита("УпаковкаПоУмолчанию", СтруктураРеквизитов);
			КоэффициентУпаковкиПоУмолчанию 	= ВернутьЗначениеРевизита("КоэффициентУпаковкиПоУмолчанию", СтруктураРеквизитов);
			ЦенаЗаУпаковкуПоУмолчанию		= ВернутьЗначениеРевизита("ЦенаЗаУпаковкуПоУмолчанию", СтруктураРеквизитов);
			
			//// Ищем существование номеклатуры
			// СсылкаНомеклатуры = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина, ВыборПапкиСправочника);
			
			// Определяем существование номеклатуры.
			Если ПоискПоТипу = 1 Тогда
				СсылкаНомеклатуры = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
				// ИначеЕсли ПоискПоТипу = 2 Тогда
				//	ЗаписьШтрихкода = РегистрыСведений.Штрихкоды.ПолучитьДанныеПоШтрихкодам(Штрихкод);
				//	Если ЗаписьШтрихкода.Свойство("Объект") Тогда
				//		СсылкаНомеклатуры = ЗаписьШтрихкода.Объект;
				//	Иначе
				//		СсылкаНомеклатуры = Справочники.Номенклатура.ПустаяСсылка();
				//	КонецЕсли;
			ИначеЕсли ПоискПоТипу = 3 Тогда
				Если НЕ ПустаяСтрока(Артикул) Тогда
					СсылкаНомеклатуры = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", Артикул);
				Иначе
					СсылкаНомеклатуры = Справочники.Номенклатура.ПустаяСсылка();
				КонецЕсли;
			КонецЕсли;
			
			Если СсылкаНомеклатуры = Справочники.Номенклатура.ПустаяСсылка() Тогда
				
				НовыйЭлемент = Справочники.Номенклатура.СоздатьЭлемент();
				НовыйЭлемент.Родитель 				= ВыборПапкиСправочника;  
				НовыйЭлемент.Наименование 			= Наименование;
				НовыйЭлемент.НаименованиеПолное 	= Наименование;
				НовыйЭлемент.ТипНоменклатуры 		= ВыборПапкиСправочника.ТипНоменклатуры;
				НовыйЭлемент.Комментарий 			= Комментарий;
			Иначе
				НовыйЭлемент = СсылкаНомеклатуры.ПолучитьОбъект();
			КонецЕсли;
			
			Если Артикул <> Неопределено Тогда
				НовыйЭлемент.Артикул = Артикул;
			КонецЕсли;
			
			НовыйЭлемент.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
			
			Если  ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда					
				НовыйЭлемент.СтавкаНДС = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.СтавкаНДС;					
			Иначе					
				НовыйЭлемент.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;			
			КонецЕсли;		
			НовыйЭлемент.НормаВремени =  НормаВремени;
			НовыйЭлемент.Записать();
			// Запись упаковки номеклатуры.
			Если ?(ЗначениеЗаполнено(КоэффициентУпаковкиПоУмолчанию), КоэффициентУпаковкиПоУмолчанию <> "0", Ложь) И ?(ЗначениеЗаполнено(УпаковкаПоУмолчанию), УпаковкаПоУмолчанию <> "", Ложь) Тогда
				НоваяУпаковкаПоУмолчанию = Справочники.УпаковкиНоменклатуры.СоздатьЭлемент();
				НоваяУпаковкаПоУмолчанию.Наименование = УпаковкаПоУмолчанию;
				НоваяУпаковкаПоУмолчанию.Владелец = НовыйЭлемент.Ссылка;
				НоваяУпаковкаПоУмолчанию.Коэффициент = ?(КоэффициентУпаковкиПоУмолчанию <> "", КоэффициентУпаковкиПоУмолчанию, 1); 
				НоваяУпаковкаПоУмолчанию.Записать();
				НовыйЭлемент.УпаковкаПоУмолчанию = НоваяУпаковкаПоУмолчанию.Ссылка;
				// Запись цены за упаковку
				Если ЦенаЗаУпаковкуПоУмолчанию <> Неопределено  Тогда
					НоваяЦена = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
					НоваяЦена.Автор = ПараметрыСеанса.ТекущийПользователь;	
					НоваяЦена.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
					НоваяЦена.ВидЦен = НомеклатураТипЦен;
					НоваяЦена.Номенклатура = НовыйЭлемент.Ссылка;
					НоваяЦена.Цена = ?(ТипЗнч(ЦенаЗаУпаковкуПоУмолчанию) = Тип("Строка"), СтрЗаменить(ЦенаЗаУпаковкуПоУмолчанию, " ", ""), ЦенаЗаУпаковкуПоУмолчанию);				
					НоваяЦена.Упаковка = НоваяУпаковкаПоУмолчанию.Ссылка;
					НоваяЦена.Период = ТекущаяДата();
					НоваяЦена.Записать();
				КонецЕсли;           
			КонецЕсли;
			НовыйЭлемент.Записать();
			
			// запись цены номеклатуры	
			Если Цена <> Неопределено Тогда						  		 
				НоваяЦена = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
				НоваяЦена.Автор 				= ПараметрыСеанса.ТекущийПользователь;	
				НоваяЦена.СтруктурнаяЕдиница 	= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
