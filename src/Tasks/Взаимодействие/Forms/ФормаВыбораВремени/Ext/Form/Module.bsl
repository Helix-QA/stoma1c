&НаСервереБезКонтекста
// Процедура, выполняет окрашивание области 
//
Процедура ЗадатьЦветФонаВыходныхДней(Планировщик, ДатаНачала, ДатаОкончания)
	
	ДатаДень = ДатаНачала;      
	Пока ДатаДень < ДатаОкончания Цикл					
		Если ДеньНедели(ДатаДень) = 6 ИЛИ ДеньНедели(ДатаДень) = 7 Тогда
			НовыйИнтервал = Планировщик.ИнтервалыФона.Добавить(НачалоДня(ДатаДень), КонецДня(ДатаДень));
			НовыйИнтервал.Цвет = WebЦвета.ТусклоРозовый;			
		КонецЕсли;                    			
		ДатаДень = ДатаДень + 86400;		
	КонецЦикла;   	
	
КонецПроцедуры

#КонецОбласти
