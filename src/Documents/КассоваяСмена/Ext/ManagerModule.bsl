// Функция, возвращает последнюю кассовую смену.
//
Функция ПолучитьПоследнююКассовуюСмену(Касса) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КассоваяСмена.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.Проведен
	|	И КассоваяСмена.Касса = &Касса
	|
	|УПОРЯДОЧИТЬ ПО
	|	КассоваяСмена.НачалоКассовойСмены УБЫВ");
	
	Запрос.УстановитьПараметр("Касса", Касса);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Функция - Получить текущую открытую кассовую смену
//
// Параметры:
//  Касса	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТекущуюОткрытуюКассовуюСмену(Касса) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КассоваяСмена.Ссылка КАК КассоваяСмена
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.Проведен
	|	И КассоваяСмена.Касса = &Касса
	|	И КассоваяСмена.СтатусыКассовойСмены = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта)
	|
	|УПОРЯДОЧИТЬ ПО
	|	КассоваяСмена.Дата УБЫВ,
	|	КассоваяСмена УБЫВ";
	
	Запрос.УстановитьПараметр("Касса", Касса);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	ОписаниеКассовойСмены = Неопределено;
	Если Выборка.Следующий() Тогда	
		Возврат Выборка.КассоваяСмена;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция возвращает структуру, характеризующую состояние последней кассовой смены по кассе ККМ.
//
Функция ПолучитьСостояниеКассовойСмены(Касса) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КассоваяСмена.Номер КАК НомерКассовойСмены,
	|	КассоваяСмена.Ссылка КАК КассоваяСмена,
	|	КассоваяСмена.Касса КАК Касса,
	|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК НаличностьВКассе,
	|	КассоваяСмена.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	КассоваяСмена.СтатусыКассовойСмены КАК СтатусыКассовойСмены,
	|	КассоваяСмена.НачалоКассовойСмены КАК НачалоКассовойСмены,
	|	КассоваяСмена.ОкончаниеКассовойСмены  КАК ОкончаниеКассовойСмены,
	|	ВЫБОР
	|		КОГДА КассоваяСмена.СтатусыКассовойСмены = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта)
	|			ТОГДА КассоваяСмена.НачалоКассовойСмены
	|		ИНАЧЕ КассоваяСмена.ОкончаниеКассовойСмены
	|	КОНЕЦ КАК ДатаИзмененияСтатуса
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредства.Остатки(, БанковскийСчетКасса = &Касса) КАК ДенежныеСредства
	|		ПО КассоваяСмена.Касса = ДенежныеСредства.БанковскийСчетКасса
	|ГДЕ
	|	КассоваяСмена.Проведен
	|	И КассоваяСмена.Касса = &Касса
	|
	|УПОРЯДОЧИТЬ ПО
	|	КассоваяСмена.Дата УБЫВ,
	|	КассоваяСмена УБЫВ");
	
	Запрос.УстановитьПараметр("Касса", Касса);
	
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	ОписаниеКассовойСмены = Неопределено;
	Если Выборка.Следующий() Тогда	
		ОписаниеКассовойСмены = ПолучитьСтруктуруОписанияКассовойСмены();
		ЗаполнитьЗначенияСвойств(ОписаниеКассовойСмены, Выборка);
	КонецЕсли;	
	
	Возврат ОписаниеКассовойСмены;
	
КонецФункции // ПолучитьСостояниеКассовойСмены()

// Функция проверяет состояние кассовой смены на дату. Если смена не открыта - возвращаеся описание ошибки.
//
Функция СменаОткрыта(КассоваяСмена, Дата, ОписаниеОшибки = "") Экспорт
	
	СменаОткрыта = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КассоваяСмена.НачалоКассовойСмены КАК НачалоКассовойСмены,
	|	КассоваяСмена.ОкончаниеКассовойСмены КАК ОкончаниеКассовойСмены
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.Проведен
	|	И КассоваяСмена.Ссылка = &КассоваяСмена";
	
	Запрос.УстановитьПараметр("КассоваяСмена", КассоваяСмена);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		
	Иначе
		
		ОписаниеОшибки = НСтр("ru='Кассовая смена не открыта';en='Cash change not isopen'");
		СменаОткрыта = Ложь;
		
	КонецЕсли;
	
	Возврат СменаОткрыта;
	
КонецФункции // СменаОткрыта()

// Функция - Открыть кассовую смену
//
// Параметры:
//  Касса			 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОткрытьКассовуюСмену(Касса, ОписаниеОшибки = "") Экспорт
	
	ДатаОткрытияКассовойСмены = ТекущаяДатаСеанса();
	Результат                 = Ложь;
	ТекущаяКассоваяСмена      = ПолучитьСостояниеКассовойСмены(Касса);
	
	Если ТекущаяКассоваяСмена = Неопределено 
		ИЛИ ТекущаяКассоваяСмена.СтатусыКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта Тогда
		
		НоваяКассоваяСмена = Документы.КассоваяСмена.СоздатьДокумент();
		НоваяКассоваяСмена.Заполнить(Новый Структура("Касса", Касса));
		
		НоваяКассоваяСмена.Дата                   = ДатаОткрытияКассовойСмены;
		НоваяКассоваяСмена.СтруктурнаяЕдиница	  = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		НоваяКассоваяСмена.СтатусыКассовойСмены   = Перечисления.СтатусыКассовойСмены.Открыта;
		НоваяКассоваяСмена.НачалоКассовойСмены    = ДатаОткрытияКассовойСмены;
		НоваяКассоваяСмена.ОкончаниеКассовойСмены = Неопределено;
		
		Если НоваяКассоваяСмена.ПроверитьЗаполнение() Тогда
			НоваяКассоваяСмена.Записать(РежимЗаписиДокумента.Проведение);
			Результат	   = Истина;
		Иначе
			Результат      = Ложь;
			ОписаниеОшибки = НСтр("ru='Произошла ошибка при открытии новой смены: ';en='There was a mistake with opening new shifts:'") +  ОписаниеОшибки();
		КонецЕсли;
		
	ИначеЕсли ТекущаяКассоваяСмена <> Неопределено 
		И ТекущаяКассоваяСмена.СтатусыКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта Тогда 
		
		ВремяСМоментаОткрытия = ТекущаяДата() - ТекущаяКассоваяСмена.НачалоКассовойСмены;
		Если ВремяСМоментаОткрытия >= 86400 Тогда
			Результат      = Ложь;
			ОписаниеОшибки = НСтр("ru='Запрещено открытие новой смены! Предварительно необходимо выполнить закрытие текущей кассовой смены.';
								  |en='Prohibited opening new shifts! Pre is necessary to run the current cashier shifts.'");
		Иначе
			Результат      = Ложь;
			ОписаниеОшибки = НСтр("ru='Запрещено открытие новой смены! С момента открытия текущей кассовой смены не истекло 24 часа.';
								  |en='Prohibited opening new shifts! Since the discoveries of the current cash shifts not expired 24 hours.'");
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Результат;	 
	
КонецФункции

// Функция - Закрыть кассовую смену
//
// Параметры:
//  Касса			 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗакрытьКассовуюСмену(Касса, ОписаниеОшибки = "", ВремяЗакрытияСмены = Неопределено) Экспорт
	
	Если ВремяЗакрытияСмены = Неопределено Тогда
		ДатаЗакрытияКассовойСмены = ТекущаяДата(); 
	Иначе
		ДатаЗакрытияКассовойСмены = НачалоДня(ТекущаяДата()) + Час(ВремяЗакрытияСмены) * 60 * 60 + Минута(ВремяЗакрытияСмены) * 60;  
	КонецЕсли;
	Результат                 = Ложь;
	ТекущаяКассоваяСмена      = ПолучитьСостояниеКассовойСмены(Касса);
	
	Если ТекущаяКассоваяСмена <> Неопределено И ТекущаяКассоваяСмена.СтатусыКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта Тогда
		
		КассоваяСменаОбъект                        = ТекущаяКассоваяСмена.КассоваяСмена.ПолучитьОбъект();
		КассоваяСменаОбъект.СтатусыКассовойСмены   = Перечисления.СтатусыКассовойСмены.Закрыта;
		КассоваяСменаОбъект.ОкончаниеКассовойСмены = ДатаЗакрытияКассовойСмены;
		Попытка
			КассоваяСменаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Результат = Истина;
		Исключение
			
			Результат = Ложь;
			
			ОписаниеОшибки = НСтр("ru='При закрытии кассовой смены произошла ошибка.
			                      |Дополнительное описание:
								  |%ДополнительноеОписание%';
								  |en='With closing cash register.
								  |Additional description:
								  |%ДополнительноеОписание%'");
			
			ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%ДополнительноеОписание%", ИнформацияОбОшибке().Описание);
			
		КонецПопытки;		
	Иначе		
		ОписаниеОшибки = НСтр("ru='Попытка закрыть, не открытую смену!!';en='Attempt close not open shift!!'");		
	КонецЕсли;
	
	Возврат Результат; 
	
КонецФункции

