							КонецЦикла;	
						Запись.ЗаписатьКонецЭлемента();
					Запись.ЗаписатьКонецЭлемента();
				Запись.ЗаписатьКонецЭлемента();	
			КонецЦикла;
			
			Запись.ЗаписатьНачалоЭлемента("proformaInvoiceSumInfo"); 
				Запись.ЗаписатьНачалоЭлемента("total");
				Если Акт.Договор.ПроцентСкидки <> 0 Тогда
					ОбщаяСумма = (Акт.СуммаДокумента + СуммаНДС)*(100 - Акт.Договор.ПроцентСкидки) / 100;
				Иначе
					ОбщаяСумма = Акт.СуммаДокумента + СуммаНДС;	
				КонецЕсли;
				Запись.ЗаписатьТекст(Формат(ОбщаяСумма, "ЧДЦ=4; ЧРД=.; ЧГ="));
				Запись.ЗаписатьКонецЭлемента();
	        Запись.ЗаписатьКонецЭлемента();

			Запись.ЗаписатьНачалоЭлемента("acceptanceCertificateInfo"); 
            	Запись.ЗаписатьНачалоЭлемента("total");
				Запись.ЗаписатьТекст(Формат(ОбщаяСумма, "ЧДЦ=4; ЧРД=.; ЧГ="));
				Запись.ЗаписатьКонецЭлемента();
				
  				Запись.ЗаписатьНачалоЭлемента("totalWithVat"); 
				Запись.ЗаписатьТекст(Формат(ОбщаяСумма + СуммаНДС, "ЧДЦ=4; ЧРД=.; ЧГ="));
				Запись.ЗаписатьКонецЭлемента();
				
				Запись.ЗаписатьНачалоЭлемента("totalVat"); 
				Запись.ЗаписатьТекст(Формат(СуммаНДС, "ЧДЦ=4; ЧРД=.; ЧН=0.0000; ЧГ="));
				Запись.ЗаписатьКонецЭлемента();
			Запись.ЗаписатьКонецЭлемента();
			
			Запись.ЗаписатьНачалоЭлемента("totalSum"); 
			Запись.ЗаписатьТекст(Формат(Акт.СуммаДокумента + СуммаНДС, "ЧДЦ=4; ЧРД=.; ЧГ="));
			Запись.ЗаписатьКонецЭлемента();			
			
			Запись.ЗаписатьНачалоЭлемента("totalVAT"); 
			Запись.ЗаписатьТекст(Формат(СуммаНДС, "ЧДЦ=4; ЧРД=.; ЧН=0.0000; ЧГ="));
			Запись.ЗаписатьКонецЭлемента();			
			
			Запись.ЗаписатьНачалоЭлемента("totalSumWithVAT"); 
			Запись.ЗаписатьТекст(Формат(Акт.СуммаДокумента + СуммаНДС, "ЧДЦ=4; ЧРД=.; ЧГ="));
			Запись.ЗаписатьКонецЭлемента();
			
			Запись.ЗаписатьНачалоЭлемента("totalDiscountSum"); 
			Запись.ЗаписатьТекст(Формат(?(Акт.Договор.ПроцентСкидки <> 0,Акт.СуммаДокумента/ 100 * Акт.Договор.ПроцентСкидки, 0), "ЧДЦ=4; ЧРД=.; ЧГ="));
			Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьКонецЭлемента();
	Запись.ЗаписатьКонецЭлемента();
	Запись.Закрыть(); 

	Возврат ПутьКФайлу;
	
