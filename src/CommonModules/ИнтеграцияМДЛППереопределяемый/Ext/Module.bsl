// Выполняет действия при изменении количества в таблице Товары.
//
// Параметры:
//  Объект - ДокументСсылка - Документ, в которой произошло событие,
//  ТекущаяСтрока - СтрокаТабличнойЧасти - строка таблицы товаров,
//  ПараметрыЗаполнения - Структура - см. функцию ИнтеграцияМДЛПКлиентСервер.ПараметрыЗаполненияТабличнойЧасти.
//
Процедура ПриИзмененииКоличества(Объект, ТекущаяСтрока, ПараметрыЗаполнения) Экспорт
	
	// _Демо
	Если ПараметрыЗаполнения.ПересчитатьКоличествоУпаковок Тогда
		ТекущаяСтрока.КоличествоУпаковок = ТекущаяСтрока.Количество;
	КонецЕсли;
	Если ПараметрыЗаполнения.ПересчитатьСумму Тогда
		ТекущаяСтрока.Сумма = ТекущаяСтрока.Количество * ТекущаяСтрока.Цена;
	КонецЕсли;
	// Конец _Демо
	
КонецПроцедуры

// Заполняет реквизит "Серия" в товарной табличной части
//
// Параметры:
//  Объект - ДокументОбъект, ДанныеФормыКоллекция
//  ИмяТабличнойЧасти - Строка - Товарная табличная часть документа;
//  СтрокиКОбработке - Массив - Массив строк табличной части;
//  ПараметрыУказанияСерий - Структура - Параметры указания серий, формируется в модулях менеджеров документов.
//  Результат - Структура - см. ИнтеграцияМДЛП.ПустойРезультатЗаполненияСерий(), 
//  Нужно заполнить информацию об ошибках и результате операции.
//
Процедура ЗаполнитьСгенерироватьСерии(Объект, ИмяТабличнойЧасти, СтрокиКОбработке = Неопределено, ПараметрыУказанияСерий = Неопределено, Результат) Экспорт
	
	// _Демо
	ТабличнаяЧасть = Объект[ИмяТабличнойЧасти];
	Таблица = ТабличнаяЧасть.Выгрузить(СтрокиКОбработке, "НомерСтроки, Номенклатура, Серия, НомерСерии, ГоденДо");
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.Номенклатура КАК Номенклатура,
	|	Таблица.Серия КАК Серия,
	|	Таблица.НомерСерии КАК НомерСерии,
	|	Таблица.ГоденДо КАК ГоденДо
	|ПОМЕСТИТЬ ТаблицаТовары
	|ИЗ
	|	&Таблица КАК Таблица
	|ГДЕ
	|	Таблица.Серия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.НомерСтроки  КАК НомерСтроки,
	|	Таблица.Номенклатура КАК Номенклатура,
	|	Серии.Ссылка         КАК Серия,
	|	Таблица.НомерСерии   КАК НомерСерии,
	|	Таблица.ГоденДо      КАК ГоденДо
	|ИЗ
	|	ТаблицаТовары КАК Таблица
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		Справочник.ПартииНоменклатуры КАК Серии
	|	ПО
	|		Серии.Владелец = Таблица.Номенклатура
	|		И Серии.НомерСерии = Таблица.НомерСерии
	|		И Серии.ГоденДо = Таблица.ГоденДо
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Таблица.Номенклатура КАК Владелец,
	|	Таблица.НомерСерии   КАК НомерСерии,
	|	Таблица.ГоденДо      КАК ГоденДо
	|ИЗ
	|	ТаблицаТовары КАК Таблица
	|	ЛЕВОЕ СОЕДИНЕНИЕ
	|		Справочник.ПартииНоменклатуры КАК Серии
	|	ПО
	|		Серии.Владелец = Таблица.Номенклатура
	|		И Серии.НомерСерии = Таблица.НомерСерии
	|		И Серии.ГоденДо = Таблица.ГоденДо
	|ГДЕ
	|	Серии.Ссылка ЕСТЬ NULL
	|");
	Запрос.УстановитьПараметр("Таблица", Таблица);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ТаблицаНовыхСерий = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
	ТаблицаНовыхСерий.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	ТаблицаНовыхСерий.Индексы.Добавить("Владелец, НомерСерии, ГоденДо");
	Для Каждого ТекущаяСтрока Из ТаблицаНовыхСерий Цикл
		Если Не ЗначениеЗаполнено(ТекущаяСтрока.Владелец)
		 Или Не ЗначениеЗаполнено(ТекущаяСтрока.НомерСерии)
		 Или Не ЗначениеЗаполнено(ТекущаяСтрока.ГоденДо) Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			ДанныеЗаполнения = Новый Структура("Владелец, НомерСерии, ГоденДо");
			ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ТекущаяСтрока);
			НоваяСерия = Справочники.ПартииНоменклатуры.СоздатьЭлемент();
			НоваяСерия.Заполнить(ДанныеЗаполнения);
			НоваяСерия.Записать();
			ТекущаяСтрока.Серия = НоваяСерия.Ссылка;
		Исключение
			ТекстСообщения = НСтр("ru = 'Не удалось сгенерировать серию по причине: %1'");
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Результат.Ошибка,
				"Объект.Товары",
				ТекстСообщения,
				Неопределено);
		КонецПопытки;
	КонецЦикла;
	
	Выборка = РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Не ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка",, НСтр("ru = 'Номенклатура'"), Выборка.НомерСтроки, НСтр("ru = 'Товары'"));
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Результат.Ошибка,
				ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Объект.Товары", Выборка.НомерСтроки, "Номенклатура"),
				ТекстСообщения,
				Неопределено);
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Выборка.НомерСерии) Или Не ЗначениеЗаполнено(Выборка.ГоденДо) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
				"Колонка",
				"Корректность",
				НСтр("ru = 'Номер серии'"),
				Выборка.НомерСтроки, НСтр("ru = 'Товары'"),
				НСтр("ru = 'Для генерации серии нужно запросить информацио об упаковках.'"));
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Результат.Ошибка,
				ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Объект.Товары", Выборка.НомерСтроки, "НомерСерии"),
				ТекстСообщения,
				Неопределено);
			Продолжить;
		КонецЕсли;
		
		СтрокаТовары = ТабличнаяЧасть.Получить(Выборка.НомерСтроки - 1);
		
		Если ЗначениеЗаполнено(Выборка.Серия) Тогда
			СтрокаТовары.Серия = Выборка.Серия;
			Результат.ЕстьЗаполненныеСтроки = Истина;
		Иначе
			ПараметрыПоиска = Новый Структура;
			ПараметрыПоиска.Вставить("Владелец", Выборка.Номенклатура);
			ПараметрыПоиска.Вставить("НомерСерии", Выборка.НомерСерии);
			ПараметрыПоиска.Вставить("ГоденДо", Выборка.ГоденДо);
			НайденныеСтроки = ТаблицаНовыхСерий.НайтиСтроки(ПараметрыПоиска);
			Если НайденныеСтроки.Количество() > 0 Тогда
				СтрокаТовары.Серия = НайденныеСтроки[0].Серия;
				Результат.ЕстьЗаполненныеСтроки = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	// Конец _Демо
	
КонецПроцедуры

