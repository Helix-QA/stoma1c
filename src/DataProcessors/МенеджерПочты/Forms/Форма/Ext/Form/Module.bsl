// Процедура обновляет список писем в соответствии с выбранной папкой
//
Процедура ОбновитьСписокПисем()
	
	ОбновитьСписокПисемНаСервере(Элементы.ПанельУправления.ТекущаяСтрока);
	
КонецПроцедуры

&НаСервере
// Процедура обновляет список писем в соответствии с выбранной папкой
//
Процедура ОбновитьСписокПисемНаСервере(ИдентификаторТекущейПапки)
	
	ТекущаяПапкаПисем = ДеревоУчетныхЗаписей.НайтиПоИдентификатору(ИдентификаторТекущейПапки);
	
	Если ТекущаяПапкаПисем = Неопределено Тогда 
		ИзменитьЭлементОтбораСписка(СписокПисем, "УчетнаяЗапись", Неопределено, Истина,,);
		Возврат; 
	КонецЕсли;
	
	Родитель = ТекущаяПапкаПисем.ПолучитьРодителя();
	
	Если Родитель = Неопределено Тогда
		
		ИзменитьЭлементОтбораСписка(СписокПисем, "УчетнаяЗапись", Неопределено, Истина,,);
		
	Иначе
		
		ИзменитьЭлементОтбораСписка(СписокПисем, "УчетнаяЗапись", ТекущаяПапкаПисем.УчетнаяЗапись, Истина,,);
		
		Если Найти(ТекущаяПапкаПисем.Наименование, "Входящие") = 1 Тогда
			
			ИзменитьЭлементОтбораСписка(СписокПисем, "ТипПисьма", 0, Истина,,Ложь);
			ИзменитьЭлементОтбораСписка(СписокПисем, "ПометкаУдаления", Ложь, Истина,,Ложь);
			
			Если ОтборСпискаПисем = "Обработанные" ИЛИ ОтборСпискаПисем = "Необработанные" Тогда
				ИзменитьЭлементОтбораСписка(СписокПисем, "Обработано", ОтборСпискаПисем = "Обработанные", Истина, , Ложь);
			ИначеЕсли ОтборСпискаПисем = "Непрочитанные" Тогда
				ИзменитьЭлементОтбораСписка(СписокПисем, "Рассмотрено", Ложь, Истина, , Ложь);
			КонецЕсли;
			
			ОбновитьОтображаемоеКоличествоПисемВыбраннойПапки(ТекущаяПапкаПисем);
			
		ИначеЕсли Найти(ТекущаяПапкаПисем.Наименование, "Исходящие") = 1 Тогда
			
			ИзменитьЭлементОтбораСписка(СписокПисем, "ТипПисьма", 1, Истина,,Ложь);
			ИзменитьЭлементОтбораСписка(СписокПисем, "Статус", 0, Истина,,Ложь);
			ИзменитьЭлементОтбораСписка(СписокПисем, "ПометкаУдаления", Ложь, Истина,,Ложь);
			
			ОбновитьОтображаемоеКоличествоПисемВыбраннойПапки(ТекущаяПапкаПисем);
			
		ИначеЕсли ТекущаяПапкаПисем.Наименование = "Отправленные" Тогда
			
			ИзменитьЭлементОтбораСписка(СписокПисем, "ТипПисьма", 1, Истина,,Ложь);
			ИзменитьЭлементОтбораСписка(СписокПисем, "Статус", 1, Истина,,Ложь);
			ИзменитьЭлементОтбораСписка(СписокПисем, "ПометкаУдаления", Ложь, Истина,,Ложь);
			
		ИначеЕсли ТекущаяПапкаПисем.Наименование = "Удаленные" Тогда
			
			ИзменитьЭлементОтбораСписка(СписокПисем, "ПометкаУдаления", Истина, Истина,,Ложь);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры // ОбновитьСписокПисемНаСервере()

&НаСервере
// Функция осуществляет установку или снятие пометки удаления электронных писем
//
Функция УстановитьПометкуНаУдаление(МассивСтрокПисем)
	
	ВыполненоУспешно = Ложь;
	Для Каждого СтрокаПисьма Из МассивСтрокПисем Цикл
		
		Попытка
			
			ПисьмоОбъект = СтрокаПисьма.Ссылка.ПолучитьОбъект();
			ПисьмоОбъект.ПометкаУдаления = НЕ ПисьмоОбъект.ПометкаУдаления;
			ПисьмоОбъект.Записать();
			
			// Функция вернет "Истина" если хотя бы одно письмо обработано успешно
			ВыполненоУспешно = Истина;
			
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат ВыполненоУспешно;
	
КонецФункции

&НаСервереБезКонтекста
// Процедура производит установку важности электронного письма
//
Процедура ИзменитьВажностьПисьмаНаСервере(Знач МассивПисем, Параметр)
	
	Если Параметр = 2 Тогда
		НоваяВажностьПисьма = Перечисления.ВариантыВажностиЗадачи.Высокая;
	ИначеЕсли Параметр = 0 Тогда
		НоваяВажностьПисьма = Перечисления.ВариантыВажностиЗадачи.Низкая;
	Иначе
		НоваяВажностьПисьма = Перечисления.ВариантыВажностиЗадачи.Обычная;
	КонецЕсли;
	
	Для Каждого ПисьмоСсылка Из МассивПисем Цикл
		
		Если ПисьмоСсылка.Важность = НоваяВажностьПисьма Тогда
			Продолжить;
		КонецЕсли;
		
		ПисьмоОбъект = ПисьмоСсылка.ПолучитьОбъект();
		ПисьмоОбъект.Важность = НоваяВажностьПисьма;
		ПисьмоОбъект.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
