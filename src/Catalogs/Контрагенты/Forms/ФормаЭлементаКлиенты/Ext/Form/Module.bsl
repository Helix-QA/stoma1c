// Функция, возвращает признак доступности отправки в мессенджер.
//
Функция ПолучитьПризнакДоступностиОтправкиВМессенджер(Клиент, МассивНомеров)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтактыМессенджеров.ВнешняяСистема КАК ВнешняяСистема,
	|	КонтактыМессенджеров.Идентификатор КАК Идентификатор
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|ГДЕ
	|	КонтактыМессенджеров.ОбъектИдентификации = &ОбъектИдентификации
	|	И КонтактыМессенджеров.ВнешняяСистема.СтруктурнаяЕдиница В(&СтруктурныеЕдиницы)
	|	И КонтактыМессенджеров.ВнешняяСистема.Используется
	|	И НЕ КонтактыМессенджеров.ВнешняяСистема.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ВнешниеСистемы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi)
	|	И ВнешниеСистемы.СтруктурнаяЕдиница В(&СтруктурныеЕдиницы)
	|	И ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("ОбъектИдентификации"	, Клиент);
	Запрос.УстановитьПараметр("СтруктурныеЕдиницы"	, Новый_Массив(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Справочники.СтруктурныеЕдиницы.ПустаяСсылка()));
	
	Результат = Запрос.ВыполнитьПакет();
	
	// Нашелся контакт мессенджера.
	Если ЗначениеЗаполнено(Результат[0].Выгрузить()) Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Есть внешняя система GreenApi и есть хотя бы 1 номер для отправки.
	Если ЗначениеЗаполнено(Результат[1].Выгрузить()) И ЗначениеЗаполнено(МассивНомеров) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

