//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПриемЗавершен(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	Запрос.УстановитьПараметр("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Прием"				, ОбъектСобытия);

		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументПрием.Ссылка КАК Прием,
		|	ДокументПрием.Ссылка КАК ОбъектСобытия,
		|	ДокументПрием.Контрагент КАК Контрагент,
		|	ДокументПрием.Сотрудник КАК Сотрудник,
		|	ДокументПрием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
