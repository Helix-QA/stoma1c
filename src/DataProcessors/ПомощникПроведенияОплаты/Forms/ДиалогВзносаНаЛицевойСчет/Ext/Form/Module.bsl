// Функция, рекурсивного поиска в дереве доступных видов оплаты.
//
Функция ПолучитьСтрокиСВнесеннойОплатой(
	ТипДенСредств = Неопределено,
	ЛицевойСчет = Неопределено,								 
	ЭквайрингНомерПлатежнойКарты = Неопределено,
