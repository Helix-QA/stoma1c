// Функция - Отправить сообщение в мессенджер
//
// Параметры:
//  Контрагент		 - 	 - 
//  НомерТелефона	 - 	 - 
//  Сообщение		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОтправитьСообщениеВМессенджер(Контрагент, НомерТелефона, Содержание, СтруктурнаяЕдиница, ОписаниеОшибки)
		
	ВнешняяСистемаМессенджера = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.GreenApi,, СтруктурнаяЕдиница);
	
	Если Не ЗначениеЗаполнено(ВнешняяСистемаМессенджера) Тогда
		ОписаниеОшибки = "Не найдена внешняя система";
		Возврат Ложь;
	КонецЕсли;
		
	ПолучателиСообщения = Новый Массив();
	ПолучателиСообщения.Добавить(Новый Структура("Получатель, НомерТелефона", Контрагент, НомерТелефона));
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("Получатели"          , ПолучателиСообщения);
	ПараметрыРассылки.Вставить("Содержание"          , Содержание);
	ПараметрыРассылки.Вставить("СтруктурнаяЕдиница"  , СтруктурнаяЕдиница); 
	ПараметрыРассылки.Вставить("ВнешняяСистема"      , ВнешняяСистемаМессенджера);
	ПараметрыРассылки.Вставить("ОтправкаMessenger"	 , Истина);
	ПараметрыРассылки.Вставить("ИнициироватьОтправку", Истина);	
	ПараметрыРассылки.Вставить("ОтправитьНемедленно" , Истина);
		
	Возврат Документы.РассылкаСообщений.СоздатьДокументРассылкаСообщений(ПараметрыРассылки, ОписаниеОшибки);
	
КонецФункции

// Функция - Отправить письмо на почту
//
// Параметры:
//  Контрагент			 - 	 - 
//  email				 - 	 - 
//  Сообщение			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  ОписаниеОшибки		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОтправитьПисьмоНаПочту(Контрагент, email, Сообщение, СтруктурнаяЕдиница, УчетнаяЗапись, ОписаниеОшибки)
	
	 СтруктураДокумента = Новый Структура();
	 СтруктураДокумента.Вставить("Дата"						, ТекущаяДатаСеанса());
	 СтруктураДокумента.Вставить("УчетнаяЗапись"			, УчетнаяЗапись);
	 СтруктураДокумента.Вставить("ОтправительПредставление"	, УчетнаяЗапись.АдресЭлектроннойПочты);
	 СтруктураДокумента.Вставить("Тема"						, "Ваш код подтверждения");
	 СтруктураДокумента.Вставить("НазначениеЗадачи"			, "ОтправкаКодаПодтверждения");
	 СтруктураДокумента.Вставить("Контрагент"				, Контрагент);
	 СтруктураДокумента.Вставить("ТекстHTML"				, Сообщение);
	 СтруктураДокумента.Вставить("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
	 СтруктураДокумента.Вставить("ТипТекста"				, Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст);
	 СтруктураДокумента.Вставить("Важность"					, Перечисления.ВариантыВажностиЗадачи.Обычная);
	 СтруктураДокумента.Вставить("ЕстьВложения"				, Ложь);
	 СтруктураДокумента.Вставить("АвторДокумента"			, ПараметрыСеанса.ТекущийПользователь);
	
	 СообщениеИсходящееОбъект	= Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
	 ЗаполнитьЗначенияСвойств(СообщениеИсходящееОбъект, СтруктураДокумента);
	
	 НовыйПолучатель				= СообщениеИсходящееОбъект.ПолучателиПисьма.Добавить();
	 НовыйПолучатель.Контакт    	= Контрагент;
	 НовыйПолучатель.Адрес		    = email;
	 НовыйПолучатель.Представление	= ?(ЗначениеЗаполнено(Контрагент), Строка(Контрагент), Неопределено);
	
	 Результат = Документы.ЭлектронноеПисьмоИсходящее.ВыполнитьОтправкуПисьма(СообщениеИсходящееОбъект, ОписаниеОшибки);	
	
	Возврат Результат; // Результат;
	
КонецФункции

