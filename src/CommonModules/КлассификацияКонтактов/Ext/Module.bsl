// Процедура создает элементы отображения интересов в форме объекта
//
// Параметры:
//  Форма	 - 	 - 
Процедура ОбновитьОблакоИнтересов(Форма, ОбъектДанных = Неопределено, УдалениеРазрешено = Истина) Экспорт
	
	Элементы = Форма.Элементы;
	Если ОбъектДанных = Неопределено Тогда
		Объект = Форма.Объект;
	Иначе
		Объект = ОбъектДанных;
	КонецЕсли;
	
	МассивУдаляемых = Новый Массив;
	Для Каждого ЭлементИнтерес Из Элементы.ОблакоИнтересов.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементИнтерес.Имя, 16) = "СтрокаИнтересов_" И НЕ ЭлементИнтерес.Имя = "СтрокаИнтересов_1" Тогда
			МассивУдаляемых.Добавить(ЭлементИнтерес);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементИнтерес Из Элементы.СтрокаИнтересов_1.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементИнтерес.Имя, 8) = "Интерес_" Тогда
			МассивУдаляемых.Добавить(ЭлементИнтерес);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементИнтерес Из МассивУдаляемых Цикл
		Элементы.Удалить(ЭлементИнтерес);
	КонецЦикла;
	
	ЭтоФормаИнтерфейсаРецепциониста = Форма.ИмяФормы = "Обработка.РабочийСтол.Форма.ФормаИнтерфейсРецепциониста";
	
	МаксДлинаПервойСтроки    = ?(ЭтоФормаИнтерфейсаРецепциониста, 61 + 24, 45);
	МаксДлинаСтроки          = ?(ЭтоФормаИнтерфейсаРецепциониста, МаксДлинаПервойСтроки, 45);
	НомерЭлемента            = 0;
	НомерСтрокиЭлементов     = 1;
	ТекущаяДлинаСтроки       = 0;
	ГруппаИнтересов          = Элементы.СтрокаИнтересов_1;
	
	ВозможностьРедактирования = ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты);
	
	// Получим таблицу Интересов
	ТаблицаИнтересов = ПолучитьТаблицуИнтересов(Объект);
	
	Для Каждого СтрокаИнтересов Из ТаблицаИнтересов Цикл //Для Каждого СтрокаТегов Из Объект.Теги Цикл
		
		НомерЭлемента = НомерЭлемента + 1;		
		ПредставлениеИнтереса = Строка(СтрокаИнтересов.Интерес);
		
		Если ЭтоФормаИнтерфейсаРецепциониста Тогда 
			Если СтрДлина(ПредставлениеИнтереса) > 45 Тогда
				ПредставлениеИнтереса = Лев(ПредставлениеИнтереса, 45) + "...";
				ДлинаИнтереса = 45 + 1;
			Иначе
				ДлинаИнтереса = СтрДлина(ПредставлениеИнтереса) + 2;
			КонецЕсли;
		Иначе 	
			Если СтрДлина(ПредставлениеИнтереса) > 35 Тогда
				ПредставлениеИнтереса = Лев(ПредставлениеИнтереса, 35) + "...";
				ДлинаИнтереса = 35 + 1;
			Иначе
				ДлинаИнтереса = СтрДлина(ПредставлениеИнтереса) + 2;
			КонецЕсли;
		КонецЕсли;	
		
		ТекущаяДлинаСтроки = ТекущаяДлинаСтроки + ДлинаИнтереса;
		
		// Добавим новую группу
		Если (НомерСтрокиЭлементов = 1 И ТекущаяДлинаСтроки > МаксДлинаПервойСтроки)
			ИЛИ (НомерСтрокиЭлементов > 1 И ТекущаяДлинаСтроки > МаксДлинаСтроки)  Тогда 
			
			ТекущаяДлинаСтроки   = ДлинаИнтереса;
			НомерСтрокиЭлементов = НомерСтрокиЭлементов + 1;
			
			ГруппаИнтересов                         	= Элементы.Добавить("СтрокаИнтересов_" + НомерСтрокиЭлементов, Тип("ГруппаФормы"), ?(НомерСтрокиЭлементов = 1, Элементы.ПерваяСтрока, Элементы.ОблакоИнтересов));
			ГруппаИнтересов.Вид                     	= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаИнтересов.Группировка             	= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаИнтересов.ОтображатьЗаголовок     	= Ложь;
			ГруппаИнтересов.Отображение             	= ОтображениеОбычнойГруппы.Нет;
			ГруппаИнтересов.РастягиватьПоГоризонтали 	= Ложь;
			ГруппаИнтересов.Ширина 						= МаксДлинаСтроки;
			ГруппаИнтересов.РастягиватьПоВертикали  	= Ложь;
			ГруппаИнтересов.Высота                  	= 1;
		КонецЕсли;
		
		КомпонентыИнтереса = Новый Массив;
		КомпонентыИнтереса.Добавить(Новый ФорматированнаяСтрока(ПредставлениеИнтереса + " "));
		Если УдалениеРазрешено Тогда
			КомпонентыИнтереса.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.ОчиститьДанные, , , , СтрокаИнтересов.УИД_Интереса));
		КонецЕсли;			
		         
	    // Добавим интерес
		ЭлементИнтерес                          = Элементы.Добавить("Интерес_" + НомерЭлемента, Тип("ДекорацияФормы"), ГруппаИнтересов);
		ЭлементИнтерес.Вид                      = ВидДекорацииФормы.Надпись;
		ЭлементИнтерес.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыИнтереса, Новый Шрифт(, 12), ЦветаСтиля.ТекстВторостепеннойНадписи);
		ЭлементИнтерес.Подсказка                = Строка(СтрокаИнтересов.Интерес);
		ЭлементИнтерес.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Центр;
		ЭлементИнтерес.МаксимальнаяШирина       = ДлинаИнтереса;
		ЭлементИнтерес.АвтоМаксимальнаяШирина 	= Ложь;
		Если УдалениеРазрешено = Истина Тогда
			ЭлементИнтерес.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ИнтересОбработкаНавигационнойСсылки");		
		КонецЕсли;
		ЭлементИнтерес.Доступность 				= ВозможностьРедактирования;
		ПредыдущийЭлементИнтерес 				= ЗначениеЗаполнено(СтрокаИнтересов.Интерес);
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Обновить облако интересов контрагента
//
// Параметры:
//  Форма				 - 	 - 
//  Контрагент			 - 	 - 
//  УдалениеРазрешено	 - 	 - 
//
Процедура ОбновитьОблакоИнтересовКонтрагента(Форма, Контрагент = Неопределено, УдалениеРазрешено = Истина) Экспорт
	
	// Актуализируем теги
	Если ЗначениеЗаполнено(Контрагент) Тогда 
		Форма.Интересы.Загрузить(Контрагент.Интересы.Выгрузить());
	КонецЕсли;	
		
	Элементы = Форма.Элементы;
	
	// Очищаем облако интересов
	МассивУдаляемых = Новый Массив;
	Для Каждого ЭлементИнтерес Из Элементы.ОблакоИнтересов.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементИнтерес.Имя, 16) = "СтрокаИнтересов_" И НЕ ЭлементИнтерес.Имя = "СтрокаИнтересов_1" Тогда
			МассивУдаляемых.Добавить(ЭлементИнтерес);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементИнтерес Из Элементы.СтрокаИнтересов_1.ПодчиненныеЭлементы Цикл
		Если Лев(ЭлементИнтерес.Имя, 8) = "Интерес_" Тогда
			МассивУдаляемых.Добавить(ЭлементИнтерес);
		КонецЕсли;
	КонецЦикла;
	Для Каждого ЭлементИнтерес Из МассивУдаляемых Цикл
		Элементы.Удалить(ЭлементИнтерес);
	КонецЦикла;
	
	ЭтоФормаБП_ПродажаЧленства = Форма.ИмяФормы = "БизнесПроцесс.ПродажаЧленства_КОРП.Форма.ФормаБизнесПроцесса";
	
	МаксДлинаПервойСтроки    = ?(ЭтоФормаБП_ПродажаЧленства, 42, 45);
	МаксДлинаСтроки          = ?(ЭтоФормаБП_ПродажаЧленства, МаксДлинаПервойСтроки, 45);
	НомерЭлемента            = 0;
	НомерСтрокиЭлементов     = 1;
	ТекущаяДлинаСтроки       = 0;
	ГруппаИнтересов          = Элементы.СтрокаИнтересов_1;
	
	ВозможностьРедактирования = ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты);
	
	//// Получим таблицу Интересов
	//ТаблицаИнтересов = ПолучитьТаблицуИнтересов(Объект);
	
	Для Каждого СтрокаИнтересов Из Форма.Интересы Цикл //Для Каждого СтрокаТегов Из Объект.Теги Цикл
		
		ИндексИнтереса 		= Форма.Интересы.Индекс(СтрокаИнтересов);
		УИД_Интереса 		= "ИнтересИД_" + СтрокаИнтересов.ПолучитьИдентификатор();
		
		НомерЭлемента = НомерЭлемента + 1;		
		ПредставлениеИнтереса = Строка(СтрокаИнтересов.Интерес);
		
		Если ЭтоФормаБП_ПродажаЧленства Тогда 
			Если СтрДлина(ПредставлениеИнтереса) > 35 Тогда
				ПредставлениеИнтереса = Лев(ПредставлениеИнтереса, 35) + "...";
				ДлинаИнтереса = 35 + 1;
			Иначе
				ДлинаИнтереса = СтрДлина(ПредставлениеИнтереса) + 2;
			КонецЕсли;
		Иначе 	
			Если СтрДлина(ПредставлениеИнтереса) > 35 Тогда
				ПредставлениеИнтереса = Лев(ПредставлениеИнтереса, 35) + "...";
				ДлинаИнтереса = 35 + 1;
			Иначе
				ДлинаИнтереса = СтрДлина(ПредставлениеИнтереса) + 2;
			КонецЕсли;
		КонецЕсли;	
		
		ТекущаяДлинаСтроки = ТекущаяДлинаСтроки + ДлинаИнтереса;
		
		// Добавим новую группу
		Если (НомерСтрокиЭлементов = 1 И ТекущаяДлинаСтроки > МаксДлинаПервойСтроки)
			ИЛИ (НомерСтрокиЭлементов > 1 И ТекущаяДлинаСтроки > МаксДлинаСтроки)  Тогда 
			
			ТекущаяДлинаСтроки   = ДлинаИнтереса;
			НомерСтрокиЭлементов = НомерСтрокиЭлементов + 1;
			
			ГруппаИнтересов                         	= Элементы.Добавить("СтрокаИнтересов_" + НомерСтрокиЭлементов, Тип("ГруппаФормы"), ?(НомерСтрокиЭлементов = 1, Элементы.ПерваяСтрока, Элементы.ОблакоИнтересов));
			ГруппаИнтересов.Вид                     	= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаИнтересов.Группировка             	= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаИнтересов.ОтображатьЗаголовок     	= Ложь;
			ГруппаИнтересов.Отображение             	= ОтображениеОбычнойГруппы.Нет;
			ГруппаИнтересов.РастягиватьПоГоризонтали 	= Ложь;
			ГруппаИнтересов.Ширина 						= МаксДлинаСтроки;
			ГруппаИнтересов.РастягиватьПоВертикали  	= Ложь;
			ГруппаИнтересов.Высота                  	= 1;
		КонецЕсли;
		
		КомпонентыИнтереса = Новый Массив;
		КомпонентыИнтереса.Добавить(Новый ФорматированнаяСтрока(ПредставлениеИнтереса + " "));
		Если УдалениеРазрешено Тогда
			КомпонентыИнтереса.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.ОчиститьДанные, , , , УИД_Интереса));
		КонецЕсли;			
		         
	    // Добавим интерес
		ЭлементИнтерес                          = Элементы.Добавить("Интерес_" + ИндексИнтереса, Тип("ДекорацияФормы"), ГруппаИнтересов);
		ЭлементИнтерес.Вид                      = ВидДекорацииФормы.Надпись;
		ЭлементИнтерес.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыИнтереса, Новый Шрифт(, 12), ЦветаСтиля.ТекстВторостепеннойНадписи);
		ЭлементИнтерес.Подсказка                = Строка(СтрокаИнтересов.Интерес);
		ЭлементИнтерес.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Центр;
		ЭлементИнтерес.МаксимальнаяШирина       = ДлинаИнтереса;
		ЭлементИнтерес.АвтоМаксимальнаяШирина 	= Ложь;
		Если УдалениеРазрешено = Истина Тогда
			ЭлементИнтерес.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ИнтересОбработкаНавигационнойСсылки");		
		КонецЕсли;
		ЭлементИнтерес.Доступность 				= ВозможностьРедактирования;
		ПредыдущийЭлементИнтерес 				= ЗначениеЗаполнено(СтрокаИнтересов.Интерес);
	КонецЦикла;
	
КонецПроцедуры

// Процедура создает элементы отображения заметок в форме объекта
//
Процедура ОбновитьОблакоЗаметок(Форма, ОбъектДанных = Неопределено, ТолькоАктивные = Ложь) Экспорт
	
	Элементы = Форма.Элементы;
	Если ОбъектДанных = Неопределено Тогда
		Объект = Форма.Объект;
	Иначе
		Объект = ОбъектДанных;
	КонецЕсли;
	
	Если ОбщегоНазначения.НаличиеЭлементаФормы(Форма, "СтрокаЗаметок") Тогда  
		
		ПодчиненныеЭлементы = Элементы.СтрокаЗаметок.ПодчиненныеЭлементы;	
		КоличествоСтрок 	= ПодчиненныеЭлементы.Количество();
		
		Пока КоличествоСтрок <> 0 Цикл 
			
			Форма.Элементы.Удалить(ПодчиненныеЭлементы[0]);	
			КоличествоСтрок = КоличествоСтрок - 1;
			
		КонецЦикла;
		
	КонецЕсли; 
	
	Если ОбщегоНазначения.НаличиеЭлементаФормы(Форма, "СтрокаЗаметокАрхив") Тогда
		
		ПодчиненныеЭлементы = Элементы.СтрокаЗаметокАрхив.ПодчиненныеЭлементы;	
		КоличествоСтрок 	= ПодчиненныеЭлементы.Количество();
		
		Пока КоличествоСтрок <> 0 Цикл 
			
			Форма.Элементы.Удалить(ПодчиненныеЭлементы[0]);	
			КоличествоСтрок = КоличествоСтрок - 1;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|*
	|ПОМЕСТИТЬ ВТ_ТабличнаяЧасть
	|ИЗ
	|&ТЗ КАК ТЗ";
	Запрос.УстановитьПараметр("ТЗ", Объект.Заметки.Выгрузить());
	Запрос.Выполнить();
	
	ЗапросТМП = Новый Запрос(
	"ВЫБРАТЬ
	|	КонтрагентыЗаметки.НомерСтроки КАК НомерСтроки,
	|	КонтрагентыЗаметки.Активность КАК Активность,
	|	КонтрагентыЗаметки.Заметка КАК Заметка,
	|	КонтрагентыЗаметки.Автор КАК Автор,
	|	КонтрагентыЗаметки.Дата КАК Дата
	|ИЗ
	|	ВТ_ТабличнаяЧасть КАК КонтрагентыЗаметки
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ТолькоАктивные
	|				ТОГДА КонтрагентыЗаметки.Активность = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Активность УБЫВ,
	|	Дата УБЫВ");
	ЗапросТМП.УстановитьПараметр("ТолькоАктивные", ТолькоАктивные);
	ЗапросТМП.МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;					  
	ТаблицаЗаметки = ЗапросТМП.Выполнить().Выгрузить();
	
	ЭтоФормаЗаметок = СтрНайти(Форма.ИмяФормы, "ФормаЗаметокВОкне") > 0;
	
	Если СтрНайти(Форма.ИмяФормы, "ФормаЭлементаКлиентыНовая") > 0
		ИЛИ ЭтоФормаЗаметок Тогда
		
		Для Каждого СтрокаЗаметки Из ТаблицаЗаметки Цикл
			
			ПредставлениеЗаметки = ?(ТолькоАктивные, """" + СтрЗаменить(СтрокаЗаметки.Заметка, Символы.ПС, " ") + """", """" + Строка(СтрокаЗаметки.Заметка)) + """"; 
			Автор = УправлениеПечатью.ВернутьФИО(СтрокаЗаметки.Автор) + ", " + Формат(СтрокаЗаметки.Дата,"ДФ='dd.MM.yyyy, HH:mm'");
			
			КомпонентыЗаметки = Новый Массив;
			КомпонентыЗаметки.Добавить(?(СтрокаЗаметки.Активность, Новый ФорматированнаяСтрока(ПредставлениеЗаметки + " ", Новый Шрифт(,,,Истина)), 
			Новый ФорматированнаяСтрока(ПредставлениеЗаметки + " ", Новый Шрифт(,,,Истина,, Истина), ЦветаСтиля.НедоступныеДанныеЦвет)));
			
			КомпонентыЗаметкиАвтора = Новый Массив;
			КомпонентыЗаметкиАвтора.Добавить(?(СтрокаЗаметки.Активность, Новый ФорматированнаяСтрока(Автор + " ", Новый Шрифт(,,,Истина), Новый Цвет(160,160,160)), 
			Новый ФорматированнаяСтрока(Автор + " ", Новый Шрифт(,,,Истина,, Истина), ЦветаСтиля.НедоступныеДанныеЦвет)));
			
			Если ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты) 
				И НЕ ЭтоФормаЗаметок Тогда
				
				Если Не ТолькоАктивные Тогда 
					КомпонентыЗаметкиАвтора.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Редактировать_16х16,,,, "РедактированиеЗаметкиИД_" + Строка(СтрокаЗаметки.НомерСтроки - 1)));
				КонецЕсли;
				Картинка = ?(СтрокаЗаметки.Активность, БиблиотекаКартинок.Корзина_16х16, БиблиотекаКартинок.ВосстановитьДанные);
				КомпонентыЗаметкиАвтора.Добавить(Новый ФорматированнаяСтрока(Картинка,,,, "ЗаметкаИД_" + Строка(СтрокаЗаметки.НомерСтроки - 1)));
				
			КонецЕсли;		
			
			// Создание группы.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаСтрокаЗаметкиГоризонталь_" + Строка(СтрокаЗаметки.НомерСтроки));
			ПараметрыГруппы.Вставить("ГруппаЭлемента", ?(СтрокаЗаметки.Активность, Элементы.СтрокаЗаметок, Элементы.СтрокаЗаметокАрхив));
			ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
			ГруппаЭтапы = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
			
			Если НЕ ЭтоФормаЗаметок Тогда
				
				// Отступ.
				ЭлементЗаметка                          = Элементы.Добавить("ЗаметкаОтступ_" + Строка(СтрокаЗаметки.НомерСтроки), Тип("ДекорацияФормы"), ГруппаЭтапы);
				ЭлементЗаметка.Вид                      = ВидДекорацииФормы.Надпись;
				ЭлементЗаметка.Ширина					= ?(СтрокаЗаметки.Активность, 5, 0);

			КонецЕсли;
			
			// Заметка.
			ЭлементЗаметка                          = Элементы.Добавить("Заметка_" + Строка(СтрокаЗаметки.НомерСтроки), Тип("ДекорацияФормы"), ГруппаЭтапы);
			ЭлементЗаметка.Вид                      = ВидДекорацииФормы.Надпись;
			ЭлементЗаметка.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыЗаметки);
			ЭлементЗаметка.ЦветФона                 = ЦветаСтиля.ЦветФонаФормы;
			ЭлементЗаметка.РастягиватьПоГоризонтали = Истина;
			
			// Автор дата.
			ЭлементЗаметка                          = Элементы.Добавить("ЗаметкаАвтор_" + Строка(СтрокаЗаметки.НомерСтроки), Тип("ДекорацияФормы"), ?(СтрокаЗаметки.Активность, Элементы.СтрокаЗаметок, Элементы.СтрокаЗаметокАрхив));
			ЭлементЗаметка.Вид                      = ВидДекорацииФормы.Надпись;
			ЭлементЗаметка.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыЗаметкиАвтора);
			ЭлементЗаметка.Подсказка                = ?(ТолькоАктивные, Строка(СтрокаЗаметки.Автор) + ", " + Формат(СтрокаЗаметки.Дата,"ДФ='dd.MM.yyyy, HH:mm'"), Строка(СтрокаЗаметки.Заметка));
			ЭлементЗаметка.РастягиватьПоГоризонтали = Истина;
			ЭлементЗаметка.АвтоМаксимальнаяШирина 	= Ложь;
			ЭлементЗаметка.МаксимальнаяШирина 		= 60;
			ЭлементЗаметка.ГоризонтальноеПоложение	= ГоризонтальноеПоложениеЭлемента.Право;
			ЭлементЗаметка.ВертикальноеПоложение	= ВертикальноеПоложениеЭлемента.Верх;
			
			ЭлементЗаметка.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ЗаметкаОбработкаНавигационнойСсылки");		
			
		КонецЦикла;
		
	Иначе
			
		Для Каждого СтрокаЗаметки Из ТаблицаЗаметки Цикл
			
			ПредставлениеЗаметки = ?(ТолькоАктивные, """" + СтрЗаменить(СтрокаЗаметки.Заметка, Символы.ПС, " ") + """", 
			"""" + Строка(СтрокаЗаметки.Заметка) + """" + Символы.ПС + "    " + СтрокаЗаметки.Автор + ", " + Формат(СтрокаЗаметки.Дата,"ДФ='dd MMMM yyyy, HH:mm'"));
			
			КомпонентыЗаметки = Новый Массив;
			КомпонентыЗаметки.Добавить(?(СтрокаЗаметки.Активность, Новый ФорматированнаяСтрока(ПредставлениеЗаметки + " ", Новый Шрифт(,,,Истина)), 
			Новый ФорматированнаяСтрока(ПредставлениеЗаметки + " ", Новый Шрифт(,,,Истина,, Истина), ЦветаСтиля.НедоступныеДанныеЦвет)));
			
			Если ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты) Тогда 
				Если Не ТолькоАктивные Тогда 
					КомпонентыЗаметки.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Редактировать_16х16, , , , "РедактированиеЗаметкиИД_" + Строка(СтрокаЗаметки.НомерСтроки - 1)));
				КонецЕсли;
				КомпонентыЗаметки.Добавить(Новый ФорматированнаяСтрока(?(СтрокаЗаметки.Активность, БиблиотекаКартинок.ОткрепитьСобытие, БиблиотекаКартинок.ВосстановитьДанные), , , , "ЗаметкаИД_" + Строка(СтрокаЗаметки.НомерСтроки - 1)));
			КонецЕсли;
			
			ЭлементЗаметка                          = Элементы.Добавить("Заметка_" + Строка(СтрокаЗаметки.НомерСтроки), Тип("ДекорацияФормы"), Элементы.СтрокаЗаметок);
			ЭлементЗаметка.Вид                      = ВидДекорацииФормы.Надпись;
			ЭлементЗаметка.Заголовок                = Новый ФорматированнаяСтрока(КомпонентыЗаметки);
			ЭлементЗаметка.Подсказка                = ?(ТолькоАктивные, Строка(СтрокаЗаметки.Автор) + ", " + Формат(СтрокаЗаметки.Дата,"ДФ='dd MMMM yyyy, HH:mm'"), Строка(СтрокаЗаметки.Заметка));
			ЭлементЗаметка.ЦветФона                 = ЦветаСтиля.ЦветФонаФормы;
			ЭлементЗаметка.РастягиватьПоГоризонтали = Истина;		
			ЭлементЗаметка.АвтоМаксимальнаяШирина 	= Ложь;
			ЭлементЗаметка.МаксимальнаяШирина 		= 54;			
			ЭлементЗаметка.ВертикальноеПоложение	= ВертикальноеПоложениеЭлемента.Верх;
			
			ЭлементЗаметка.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_ЗаметкаОбработкаНавигационнойСсылки");		
			
		КонецЦикла;
		
	КонецЕсли;		
	
	Если Не ПравоДоступа("Редактирование", Метаданные.Справочники.Контрагенты) Тогда
		Элементы.НоваяЗаметка.ТолькоПросмотр = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события "ОбработкаНавигационнойСсылки" для поля значения заметки в форме объекта
//
// Параметры:
//  Форма				 - форма объекта
//  Элемент				 - элемент формы - значение тега
//  НавигационнаяСсылка	 - строка - навигационная ссылка содержащая ИД тега
//  СтандартнаяОбработка - булево - стандартная обработка навигационной ссылки
Процедура ЗаметкаОбработкаНавигационнойСсылки(Форма, ОбъектДанных = Неопределено, НавигационнаяСсылка, СтандартнаяОбработка) Экспорт
	
	Если Лев(НавигационнаяСсылка, 10) <> "ЗаметкаИД_" Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбъектДанных = Неопределено Тогда
		
		Объект = Форма.Объект;
		Форма.Модифицированность = Истина;
		
		Попытка
			Форма.ЗаблокироватьДанныеФормыДляРедактирования();	
		Исключение
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Операция не может быть выполнена из-за несоответствия версии или отсутствия записи базы данных (возможно, запись была изменена или удалена)!");
		КонецПопытки;
		
	Иначе
		Объект = ОбъектДанных.ПолучитьОбъект();
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ЗаметкаИД = Сред(НавигационнаяСсылка, 11);
	ЭлементСписка = Объект.Заметки.Получить(ЗаметкаИД);
	ЭлементСписка.Активность = НЕ ЭлементСписка.Активность;
	
	Если ОбъектДанных = Неопределено Тогда 
		ОбновитьОблакоЗаметок(Форма);
	Иначе  	
		
		Попытка
			Объект.Записать();	
		Исключение
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Операция не может быть выполнена из-за несоответствия версии или отсутствия записи базы данных (возможно, запись была изменена или удалена)!");
		КонецПопытки;
	
		ОбновитьОблакоЗаметок(Форма, ОбъектДанных, Истина);
	КонецЕсли;
	
КонецПроцедуры

// Процедура помещает новую заметку в табличную часть
//
Процедура ПоместитьЗаметкуВТабличнуюЧасть(Форма, ОбъектДанных = Неопределено) Экспорт
	 	
	Если НЕ ЗначениеЗаполнено(Форма.НоваяЗаметка) Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбъектДанных = Неопределено Тогда
		Объект = Форма.Объект;
		Форма.ЗаблокироватьДанныеФормыДляРедактирования();
	Иначе
		Объект = ОбъектДанных.ПолучитьОбъект();
	КонецЕсли;
	 	
	НоваяСтрока = Объект.Заметки.Добавить();
	НоваяСтрока.Активность = Истина;
	НоваяСтрока.Заметка = Форма.НоваяЗаметка;
	НоваяСтрока.Автор = ОбщегоНазначения.ПолучитьЗначениеПараметровСеанса("ТекущийПользователь");
	НоваяСтрока.Дата = ТекущаяДата();
	
	Если ОбъектДанных = Неопределено Тогда 
		Форма.Модифицированность = Истина; 			
		ОбновитьОблакоЗаметок(Форма);
	Иначе 
		Объект.Записать();
		ОбновитьОблакоЗаметок(Форма, ОбъектДанных, Истина);
	КонецЕсли;
	
	Форма.НоваяЗаметка = Неопределено;   

КонецПроцедуры


#КонецОбласти

