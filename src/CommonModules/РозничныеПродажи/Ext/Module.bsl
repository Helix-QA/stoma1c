// ПРОЧЕЕ
    
// Возвращает сумму документа с учетом НДС
//
// Параметры:
// Запасы          - тч документа для подсчета суммы документа
// ЦенаВключаетНДС - Признак включения НДС в цену документа
//
// Возвращаемое значение:
// Число
// Сумма документа с учетом НДС
//
Функция ПолучитьСуммуДокумента(Знач Запасы, Знач ЦенаВключаетНДС) Экспорт
	
	СуммаДокумента = Запасы.Итог("Сумма");
	
	Если Не ЦенаВключаетНДС Тогда
		СуммаДокумента = СуммаДокумента + Запасы.Итог("СуммаНДС");
	КонецЕсли;
	
	Возврат СуммаДокумента;
	
КонецФункции // ПолучитьСуммуДокумента()

// Функция - Проверить использование ф рв кассе
//
// Параметры:
//  Касса	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьИспользованиеФРвКассе(Касса, РабочееМесто = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(РабочееМесто) Тогда
		РабочееМесто = ПараметрыСеанса.РабочееМестоКлиента;
	КонецЕсли;
	
	Возврат МенеджерОборудованияВызовСервера.ПроверитьИспользованиеФРвКассе(Касса, РабочееМесто);
	
КонецФункции

#КонецОбласти

#КонецЕсли
