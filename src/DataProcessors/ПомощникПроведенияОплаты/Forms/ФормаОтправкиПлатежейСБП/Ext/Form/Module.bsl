// Функция - Получить содержание сообщения
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСодержаниеСообщения()
	
	СодержаниеСообщения = ШаблонДляОтправкиСсылкиНаОплату;
	
	СодержаниеСообщения = СтрЗаменить(СодержаниеСообщения, "{СсылкаНаОплату}"		, СсылкаНаОплату);
	СодержаниеСообщения = СтрЗаменить(СодержаниеСообщения, "{ПредставлениеКлиента}"	, ОбщегоНазначения.ПолучитьЗначениеРеквизита(Контрагент, "Наименование"));
	СодержаниеСообщения = СтрЗаменить(СодержаниеСообщения, "{ПредставлениеКлуба}"	, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "Наименование"));
	СодержаниеСообщения = СтрЗаменить(СодержаниеСообщения, "{СуммаОплаты}"			, СуммаОплаты);
	СодержаниеСообщения = СтрЗаменить(СодержаниеСообщения, "{ВремяОкончанияСсылки}"	, ?(ЗначениеЗаполнено(ВремяДействителенДо), Формат(ЭтотОбъект.ВремяДействителенДо,"ДФ='dd.MM.yyyy ЧЧ:мм'"), ""));
	
	Возврат СодержаниеСообщения;
	
