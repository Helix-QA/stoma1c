// Процедура ТаблицаЛечениеНомерПриемаПриИзменении.
//
Процедура ТаблицаЛечениеНомерПриемаПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ТаблицаЛечение.ТекущиеДанные;
	Если ТекущаяСтрока.НомерПриема <= 0 Тогда
		ТекущаяСтрока.НомерПриема = 1;
	КонецЕсли;
	НомерКоманды = ТекущаяСтрока.НомерПриема;
	
	Для Каждого ЭлементГруппы Из Элементы.ГруппаНомераПриема.ПодчиненныеЭлементы Цикл
		// ЭлементГруппы.Пометка = Ложь;
		
		Если ТипЗнч(ЭлементГруппы) = Тип("КнопкаФормы") Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементГруппы.ЦветФона = Новый Цвет(242, 242, 242);
		ЭлементГруппы.ПодчиненныеЭлементы[0].ЦветТекста =  Новый Цвет(77, 77, 77);	
	КонецЦикла;     
	
	// Элементы["НомерПриема" + ?(НомерКоманды > 15, "Все", НомерКоманды)].Пометка = Истина;
	НомерЭлемента = ?(НомерКоманды > 20, "Все", НомерКоманды);	
	Элементы["ГруппаНомерПриема_" + НомерЭлемента].ЦветФона = Новый Цвет(25 , 116, 206);
	Элементы["ГруппаНомерПриема_" + НомерЭлемента].ПодчиненныеЭлементы[0].ЦветТекста = Новый Цвет(255 , 255, 255);
	
	
	Если НомерКоманды > 0 И НомерКоманды <= 20 Тогда 
		Элементы.ТаблицаЛечение.ОтборСтрок = Новый ФиксированнаяСтруктура("НомерПриема", НомерКоманды);
		НомерПриемаПодбор = НомерКоманды;
	ИначеЕсли НомерКоманды > 20 Тогда  
		Элементы.ТаблицаЛечение.ОтборСтрок = Неопределено;
		Объект.Лечение.Сортировать("НомерПриема Возр"); 
		НомерПриемаПодбор = 0;
	КонецЕсли;
	
КонецПроцедуры

