Функция СформироватьБлокОсновнаяИнформация(ВыводитьБлок = Ложь, ОбщаяИнформация) 
	
	ОсновнаяИнформация =
	"<table>
	|        <tr>
	|            <td colspan='3'>
	|                <p class='date'>Основная информация</p>
	|            </td>
	|        </tr>
	|        <td valign = 'top'>
	|            <table cellpadding='0' cellspacing='0' align='left'>  
	|{ДатаРождения}  
	|{Адрес}                
	|{Телефон} 
	|{Емайл}                
	|{МедКарта}
	|{Прочее}
	|            </table>
	|        </td>  
	|        <td  valign = 'top'>  
	|            <table cellpadding='0' cellspacing='0' align='right'>
	|{ПервоеПосещение}  
	|{ПоследнееПосещение}                
	|{Долг} 
	|{ЛицевойСчет}
	|{СуммаАвансов}
	|            </table>
	|        </td>         
	|    </table>";
	
	ЭтоВрач = (ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач);
	
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{ДатаРождения}"      , СформироватьБлокДатаРождения(ВыводитьБлок));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{Адрес}"             , СформироватьБлокАдрес(ВыводитьБлок, ЭтоВрач));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{Телефон}"           , СформироватьБлокТелефон(ВыводитьБлок, ЭтоВрач));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{Емайл}"             , СформироватьБлокЕмайл(ВыводитьБлок, ЭтоВрач));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{Прочее}"            , СформироватьБлокПрочее(ВыводитьБлок));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{МедКарта}"          , СформироватьБлокМедКарта(ВыводитьБлок));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{ПервоеПосещение}"   , СформироватьБлокПервоеПосещение(ВыводитьБлок, ОбщаяИнформация));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{ПоследнееПосещение}", СформироватьБлокПоследнееПосещение(ВыводитьБлок, ОбщаяИнформация));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{Долг}"              , СформироватьБлокДолг(ВыводитьБлок, ОбщаяИнформация));
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{ЛицевойСчет}"       , СформироватьБлокЛицевойСчет(ВыводитьБлок, ОбщаяИнформация)); 
	ОсновнаяИнформация = СтрЗаменить(ОсновнаяИнформация, "{СуммаАвансов}"      , СформироватьБлокСуммаАвансов(ВыводитьБлок, ОбщаяИнформация)); 
	
	Возврат ОсновнаяИнформация;	
	
КонецФункции

