// Процедура - Установить свойства элементам фильтров
//
Процедура УстановитьСвойстваЭлементамФильтров()
	
	Элементы.Группа3.Видимость 											= НЕ ЗначениеЗаполнено(Объект.УсловиеСобытия) ИЛИ НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана;
	Элементы.СегментКонтрагентов.Видимость 								= НЕ ЗначениеЗаполнено(Объект.УсловиеСобытия) ИЛИ НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана;
	
	// Свойства элементов фильтра Структурная единица
	РазрешенОтборПоСтруктурнымЕдиницам 									= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоСтруктурнымЕдиницам(Объект.УсловиеСобытия);	
	Элементы.ГруппаДоступностьЧленствПакетов.Видимость 					= РазрешенОтборПоСтруктурнымЕдиницам;
	
	// Свойства элементов фильтра Источник записи
	РазрешенОтборПоИсточникамЗаписи 									= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоИсточникамЗаписи(Объект.УсловиеСобытия);	
	Элементы.ДекорацияЗаголовокИсточникЗаписи.Видимость 				= РазрешенОтборПоИсточникамЗаписи;
	Элементы.ИсточникЗаписи.Видимость 									= РазрешенОтборПоИсточникамЗаписи;
	//Элементы.ИсточникЗаписи.ОграничениеТипа 							= Новый ОписаниеТипов("СправочникСсылка.ИсточникиЗаписей");
	
	// Свойства элементов фильтра онлайн-продажа
	РазрешенОтборПоПоПризнакуОнлайнПродажа								= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоПризнакуОнлайнПродажа(Объект.УсловиеСобытия);	
	Элементы.ДекорацияЗаголовокФильтраПоПризнакуОнлайПродажа.Видимость 	= РазрешенОтборПоПоПризнакуОнлайнПродажа;
	Элементы.ГруппаКнопокФильтрацииПоПризнакуОнлайПродажа.Видимость 	= РазрешенОтборПоПоПризнакуОнлайнПродажа;
	
	// Свойства элементов фильтра по услугам		
	РазрешенОтборПоСегментуУслуг 										= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоСегментуУслуг(Объект.УсловиеСобытия);
	Элементы.ГруппаУслугаСегментУслуг.Видимость 						= РазрешенОтборПоСегментуУслуг;
	Элементы.СегментУслуг.Видимость 									= РазрешенОтборПоСегментуУслуг;
	Элементы.ДекорацияЗаголовокФильтраПоУслуге.Заголовок 				= ПолучитьЗаголовокФильтраПоУслугам();
	
	ОбновитьСвойстваЭлементовВыбораУслугиСегментаУслуг();	
	ОбновитьСвойстваЭлементовВыбораПризнакаОнлайнПродажа();
	
КонецПроцедуры

&НаСервере
// Функция - Получить заголовок фильтра по услугам
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗаголовокФильтраПоУслугам();
	
	ЗаголовокФильтра = "";
	Если Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием Тогда		
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаСотрудникомКлиники ИЛИ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаПациентом Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеПереносДатыВремени Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеЗаменаИнструктора Тогда 
		ЗаголовокФильтра = "Услуга занятия:";				
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеКлиентНеПрибыл Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеКлиентПрибыл Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеОтменено Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеСписаниеУслугиКлиентПрибыл Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеСписаниеУслугиПоНеявке Тогда 
		ЗаголовокФильтра = "Услуга занятия:";
	Иначе 
		ЗаголовокФильтра = "Услуга:";
	КонецЕсли;
	
	Возврат ЗаголовокФильтра;
	
КонецФункции

&НаСервере
Процедура ОбновитьСвойстваЭлементовВыбораПризнакаОнлайнПродажа(ОписаниеТипаПризнака = "")
	
	Если Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоИсточникамЗаписи(Объект.УсловиеСобытия) Тогда
		Элементы.ИсточникЗаписи.ОграничениеТипа 							= Новый ОписаниеТипов("СправочникСсылка.ИсточникиЗаписей");
		Объект.ИсточникЗаписи												= Элементы.ИсточникЗаписи.ОграничениеТипа.ПривестиЗначение(Объект.ИсточникЗаписи);
	ИначеЕсли Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоПризнакуОнлайнПродажа(Объект.УсловиеСобытия) Тогда
		Если ЗначениеЗаполнено(ОписаниеТипаПризнака) Тогда
			Если ОписаниеТипаПризнака = "ПустаяСсылка" Тогда 
				Объект.ИсточникЗаписи 										= Перечисления.ТипыФискализации.ПустаяСсылка();
			Иначе 	
				Объект.ИсточникЗаписи 										= Перечисления.ТипыФискализации[ОписаниеТипаПризнака];
			КонецЕсли;
			ЭтаФорма.Модифицированность = Истина;
		ИначеЕсли НЕ ЗначениеЗаполнено(Объект.ИсточникЗаписи) ИЛИ Объект.ИсточникЗаписи = Неопределено ИЛИ ТипЗнч(Объект.ИсточникЗаписи) <> Тип("ПеречислениеСсылка.ТипыФискализации") Тогда 
			Объект.ИсточникЗаписи 											= Перечисления.ТипыФискализации.ПустаяСсылка();
		КонецЕсли;
		Если Объект.ИсточникЗаписи = Перечисления.ТипыФискализации.ОнлайнКасса Тогда 
			
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Да.ЦветТекста 		= Новый Цвет(255, 255, 255);
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Нет.ЦветТекста 		= Новый Цвет();
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Неважно.ЦветТекста 	= Новый Цвет();
			
			Элементы.ГруппаКнопкиДа.ЦветФона 								= Новый Цвет(25, 116, 206);
			Элементы.ГруппаКнопкиНет.ЦветФона 								= Новый Цвет(242, 242, 242);
			Элементы.ГруппаКнопкиНеважно.ЦветФона 							= Новый Цвет(242, 242, 242);
			
		ИначеЕсли Объект.ИсточникЗаписи = Перечисления.ТипыФискализации.НеФискализировать Тогда 
			
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Да.ЦветТекста 		= Новый Цвет();
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Нет.ЦветТекста 		= Новый Цвет(255, 255, 255);
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Неважно.ЦветТекста 	= Новый Цвет();
			
			Элементы.ГруппаКнопкиДа.ЦветФона 								= Новый Цвет(242, 242, 242);
			Элементы.ГруппаКнопкиНет.ЦветФона 								= Новый Цвет(25, 116, 206);
			Элементы.ГруппаКнопкиНеважно.ЦветФона 							= Новый Цвет(242, 242, 242);
			
		ИначеЕсли Объект.ИсточникЗаписи = Перечисления.ТипыФискализации.ПустаяСсылка() Тогда 
			
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Да.ЦветТекста 		= Новый Цвет();
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Нет.ЦветТекста 		= Новый Цвет();
			Элементы.ФильтроватьПоПризнакуОнлайПродажа_Неважно.ЦветТекста 	= Новый Цвет(255, 255, 255);
			
			Элементы.ГруппаКнопкиДа.ЦветФона 								= Новый Цвет(242, 242, 242);
			Элементы.ГруппаКнопкиНет.ЦветФона 								= Новый Цвет(242, 242, 242);
			Элементы.ГруппаКнопкиНеважно.ЦветФона 							= Новый Цвет(25, 116, 206);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить свойства элементов выбора услуги сегмента услуг
//
// Параметры:
//  ОписаниеТипаФильтра	 - 	 - 
//
Процедура ОбновитьСвойстваЭлементовВыбораУслугиСегментаУслуг(ОписаниеТипаФильтра = Неопределено)
	
	Если ОписаниеТипаФильтра = Неопределено Тогда 
		Если ЗначениеЗаполнено(Объект.СегментУслуг) ИЛИ Объект.СегментУслуг <> Неопределено Тогда
			Если НЕ Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоСегментуУслуг(Объект.УсловиеСобытия) Тогда 
				Объект.СегментУслуг 							= Неопределено;
				Объект.СегментУслуг 							= Элементы.СегментУслуг.ОграничениеТипа.ПривестиЗначение();
			КонецЕсли;	
			Если ТипЗнч(Объект.СегментУслуг) = Тип("СправочникСсылка.Номенклатура") Тогда 
				Если Объект.СегментУслуг = Неопределено Тогда 
					Элементы.СегментУслуг.ОграничениеТипа 		= Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
				КонецЕсли;
				Элементы.ГруппаКнопкиСегментУслуг.ЦветФона 		= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(239, 239, 239)	, Новый Цвет(229, 229, 229));
				Элементы.ФильтроватьПоСегментуУслуг.ЦветТекста 	= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(115, 115, 115)	, Новый Цвет(115, 115, 115));
				Элементы.ГруппаКнопкиУслуга.ЦветФона 			= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(25, 116, 206)	, Новый Цвет(242, 242, 242));
				Элементы.ФильтроватьПоУслуге.ЦветТекста 		= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(255, 255, 255)	, Новый Цвет(115, 115, 115));
				
				Элементы.СегментУслуг.ПодсказкаВвода 			= "Укажите услугу";
				
			ИначеЕсли ТипЗнч(Объект.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
				Если Объект.СегментУслуг = Неопределено Тогда 
					Элементы.СегментУслуг.ОграничениеТипа 		= Новый ОписаниеТипов("СправочникСсылка.СегментыНоменклатуры");
				КонецЕсли;
				Элементы.ГруппаКнопкиСегментУслуг.ЦветФона 		= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(25, 116, 206)	, Новый Цвет(229, 229, 229));
				Элементы.ФильтроватьПоСегментуУслуг.ЦветТекста 	= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(255, 255, 255)	, Новый Цвет(115, 115, 115));
				Элементы.ГруппаКнопкиУслуга.ЦветФона 			= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(239, 239, 239)	, Новый Цвет(242, 242, 242));
				Элементы.ФильтроватьПоУслуге.ЦветТекста 		= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(115, 115, 115)	, Новый Цвет(115, 115, 115));
				
				Элементы.СегментУслуг.ПодсказкаВвода 			= "Укажите сегмент услуг";
			КонецЕсли;
		Иначе 
			Элементы.СегментУслуг.ОграничениеТипа 				= Новый ОписаниеТипов("СправочникСсылка.СегментыНоменклатуры");
			Объект.СегментУслуг 								= Элементы.СегментУслуг.ОграничениеТипа.ПривестиЗначение();
			
			Элементы.ГруппаКнопкиСегментУслуг.ЦветФона 			= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(25, 116, 206)	, Новый Цвет(229, 229, 229));
			Элементы.ФильтроватьПоСегментуУслуг.ЦветТекста 		= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(255, 255, 255)	, Новый Цвет(115, 115, 115));
			Элементы.ГруппаКнопкиУслуга.ЦветФона 				= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(239, 239, 239)	, Новый Цвет(242, 242, 242));
			Элементы.ФильтроватьПоУслуге.ЦветТекста 			= ?(Элементы.ГруппаУслугаСегментУслуг.Доступность	, Новый Цвет(115, 115, 115)	, Новый Цвет(115, 115, 115));
			
			Элементы.СегментУслуг.ПодсказкаВвода 				= "Укажите сегмент услуг";			
		КонецЕсли;
	Иначе 
		Элементы.СегментУслуг.ОграничениеТипа 					= ОписаниеТипаФильтра;
		Если НЕ Элементы.СегментУслуг.ОграничениеТипа.СодержитТип(ТипЗнч(Объект.СегментУслуг)) Тогда 
			Объект.СегментУслуг 								= ОписаниеТипаФильтра.ПривестиЗначение();
		КонецЕсли;
		ОбновитьСвойстваЭлементовВыбораУслугиСегментаУслуг();
		ЭтаФорма.ТекущийЭлемент = Элементы.СегментУслуг;
	КонецЕсли;	
	Элементы.СегментУслуг.ОтметкаНезаполненного 				= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоСегментуУслуг(Объект.УсловиеСобытия, Истина);
	Элементы.СегментУслуг.АвтоОтметкаНезаполненного 			= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоСегментуУслуг(Объект.УсловиеСобытия, Истина);
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства элементам периода активации
//
Процедура УстановитьСвойстваЭлементамПериодаАктивации()
	
	Если НЕ ЗначениеЗаполнено(Объект.МоментСобытия) ИЛИ Объект.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия Тогда 
		Элементы.ГруппаПериодСобытия.Видимость = Ложь;
		Если ЭтоВерсияКОРП Тогда 
			Элементы.ГруппаВремяСобытия.Видимость 	= Справочники.ТриггерныеСобытия.ЭтоИсключительноРегламентноеСобытие(Объект.УсловиеСобытия) И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана;
			Элементы.ВыборВремениСтарта.Видимость 	= Элементы.ГруппаВремяСобытия.Видимость И НЕ Элементы.ВремяСобытия.Видимость;
			Элементы.Декорация4.Видимость 			= Элементы.ГруппаВремяСобытия.Видимость И НЕ Элементы.ВремяСобытия.Видимость;		
		КонецЕсли;	
		Элементы.ПериодСобытия.МинимальноеЗначение 	= 0;
		Элементы.МоментСобытия.Ширина 				= 0;
		Элементы.МоментСобытия.МаксимальнаяШирина 	= 0;
	Иначе
		Элементы.ГруппаВремяСобытия.Видимость 		= ?(Объект.ПериодСобытияВид = Перечисления.Периодичность.День, Истина, Ложь);
		Элементы.ВыборВремениСтарта.Видимость 		= ?(Объект.ПериодСобытияВид = Перечисления.Периодичность.День, Истина, Ложь) И НЕ Элементы.ВремяСобытия.Видимость;
		Элементы.Декорация4.Видимость 				= ?(Объект.ПериодСобытияВид = Перечисления.Периодичность.День, Истина, Ложь) И НЕ Элементы.ВремяСобытия.Видимость;		
		Элементы.ГруппаПериодСобытия.Видимость 		= Истина;
		Элементы.Декорация1.Заголовок = ?(Объект.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия, "за", "через");
		Элементы.ПериодСобытия.МинимальноеЗначение 	= 1;	
		Элементы.МоментСобытия.Ширина 				= 29;
		Элементы.МоментСобытия.МаксимальнаяШирина 	= 29;		
	КонецЕсли;
	
	Если Элементы.ВыборВремениСтарта.Видимость Тогда 
		Элементы.ВыборВремениСтарта.Заголовок 		= Формат(Объект.ВремяСобытия, "ДФ=HH:mm; ДП=00:00");
		Если Час(Объект.ВремяСобытия) = 0 И Минута(Объект.ВремяСобытия) = 0 Тогда 
			Элементы.ГруппаКнопкиВыборВремениСтарта.ЦветФона 	= Новый Цвет(243, 243, 243);
			Элементы.ВыборВремениСтарта.ЦветТекста 				= Новый Цвет();
		Иначе 
			Элементы.ГруппаКнопкиВыборВремениСтарта.ЦветФона 	= Новый Цвет(25, 116, 206);
			Элементы.ВыборВремениСтарта.ЦветТекста 				= Новый Цвет(255, 255, 255);
		КонецЕсли;
	КонецЕсли;
	
	//Элементы.ПериодСобытия.Заголовок = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("День", Объект.ПериодСобытия);
	Для Каждого ЭлементСписка Из Элементы.ПериодСобытияВид.СписокВыбора Цикл 
		ЭлементСписка.Представление = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(XMLСтрока(ЭлементСписка.Значение), Объект.ПериодСобытия, ?(ЭлементСписка.Значение = Перечисления.Периодичность.День, "", "Родительный"));
	КонецЦикла;
	
	Элементы.ДекорацияПояснениеОбластиСтарт.Видимость = Ложь;
	
	УстановитьСвойстваЭлементамСтатусаПредварительнойЗаписи();
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства элементам периода параметра
//
Процедура УстановитьСвойстваЭлементамПериодаПараметра()
	
	ЭлементМинута = Элементы.ПериодСобытияВидПараметр.СписокВыбора.НайтиПоЗначению(Перечисления.Периодичность.Минута);
	Если ЭлементМинута <> Неопределено И Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана Тогда
		//Элементы.ПериодСобытияВидПараметр.СписокВыбора.Удалить(ЭлементМинута);
	ИначеЕсли ЭлементМинута = Неопределено И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана Тогда 
		Элементы.ПериодСобытияВидПараметр.СписокВыбора.Добавить(Перечисления.Периодичность.Минута);
	КонецЕсли;
	
	ЭлементДень = Элементы.ПериодСобытияВидПараметр.СписокВыбора.НайтиПоЗначению(Перечисления.Периодичность.День);
	Если ЭлементДень = Неопределено И Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда
		Элементы.ПериодСобытияВидПараметр.СписокВыбора.Вставить(0, Перечисления.Периодичность.День); 
	КонецЕсли;
	
	Для Каждого ЭлементСписка Из Элементы.ПериодСобытияВидПараметр.СписокВыбора Цикл 
		ЭлементСписка.Представление = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(XMLСтрока(ЭлементСписка.Значение), Объект.ПериодСобытия, "Родительный", , Истина);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства элементам выбора статусов клиентов
//
Процедура УстановитьСвойстваЭлементамВыбораСтатусовКлиентов()
	
	// Свойства элементов фильтра по статусам клиентов		
	РазрешенОтборПоСтатусамКлиентов									= Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса;
	РазрешенОтборПоВидуСделок 										= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоВидуСделок(Объект.УсловиеСобытия);	
	Элементы.ПереходСЭтапа.Видимость 								= РазрешенОтборПоСтатусамКлиентов ИЛИ РазрешенОтборПоВидуСделок;
	Элементы.ПереходНаЭтап.Видимость 								= РазрешенОтборПоСтатусамКлиентов ИЛИ РазрешенОтборПоВидуСделок;
	
	Если РазрешенОтборПоСтатусамКлиентов Тогда
		Элементы.ПереходСЭтапа.СписокВыбора.Очистить();
		Элементы.ПереходНаЭтап.СписокВыбора.Очистить();				
		Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.ПустаяСсылка(), "С любого статуса"	, Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.ПустаяСсылка());
		Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.ПустаяСсылка(), "На любой статус"		, Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.ПустаяСсылка());
		Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Потенциальный, "Со статуса """ + Строка(Перечисления.СтатусыКонтрагентов.Потенциальный) + """", Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.Потенциальный);
		Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Потенциальный, "На статус """ + Строка(Перечисления.СтатусыКонтрагентов.Потенциальный) + """", Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.Потенциальный);
		Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Первичный, "Со статуса """ + Строка(Перечисления.СтатусыКонтрагентов.Первичный) + """", Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.Первичный);
		Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Первичный, "На статус """ + Строка(Перечисления.СтатусыКонтрагентов.Первичный) + """", Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.Первичный);
		Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Постоянный, "Со статуса """ + Строка(Перечисления.СтатусыКонтрагентов.Постоянный) + """", Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.Постоянный);
		Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Постоянный, "На статус """ + Строка(Перечисления.СтатусыКонтрагентов.Постоянный) + """", Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.Постоянный);
		Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.НеВернувшийся, "Со статуса """ + Строка(Перечисления.СтатусыКонтрагентов.НеВернувшийся) + """", Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.НеВернувшийся);
		Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.НеВернувшийся, "На статус """ + Строка(Перечисления.СтатусыКонтрагентов.НеВернувшийся) + """", Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.НеВернувшийся);
		Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Отказ, "Со статуса """ + Строка(Перечисления.СтатусыКонтрагентов.Отказ) + """", Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.Отказ);
		Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.Отказ, "На статус """ + Строка(Перечисления.СтатусыКонтрагентов.Отказ) + """", Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.Отказ);
		
		Если Элементы.ПереходСЭтапа.СписокВыбора.НайтиПоЗначению(Объект.ПереходСЭтапа) = Неопределено Тогда 
			Объект.ПереходСЭтапа = Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
		КонецЕсли;	
		Если Элементы.ПереходНаЭтап.СписокВыбора.НайтиПоЗначению(Объект.ПереходНаЭтап) = Неопределено Тогда 
			Объект.ПереходНаЭтап = Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
		КонецЕсли;	
	КонецЕсли;
	
	Если НЕ РазрешенОтборПоСтатусамКлиентов И НЕ РазрешенОтборПоВидуСделок Тогда 
		Объект.ПереходСЭтапа 				= Неопределено;
		Объект.ПереходНаЭтап 				= Неопределено;
		Элементы.ПереходСЭтапа.Видимость 	= Ложь;
		Элементы.ПереходНаЭтап.Видимость 	= Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства элементам выбора вида сделок
//
Процедура УстановитьСвойстваЭлементамВыбораВидаСделок()
	
	// Свойства элементов фильтра по видам сделок		
	РазрешенОтборПоВидуСделок 										= Справочники.ТриггерныеСобытия.ИспользуетсяОтборПоВидуСделок(Объект.УсловиеСобытия);
	РазрешенОтборПоСтатусамКлиентов									= Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса;	
	Элементы.ВидСделки.Видимость 									= РазрешенОтборПоВидуСделок;
	Элементы.ПереходСЭтапа.Видимость 								= РазрешенОтборПоВидуСделок ИЛИ РазрешенОтборПоСтатусамКлиентов;
	Элементы.ПереходНаЭтап.Видимость 								= (РазрешенОтборПоВидуСделок ИЛИ РазрешенОтборПоСтатусамКлиентов) И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана;
	
	Если РазрешенОтборПоВидуСделок Тогда 
		Если ЗначениеЗаполнено(Объект.ВидСделки) Тогда
			Элементы.ПереходСЭтапа.СписокВыбора.Очистить();
			Элементы.ПереходНаЭтап.СписокВыбора.Очистить();				
			МассивЭтапов = Справочники.ЭтапыСделок.ВернутьМассивЭтаповВидаСделки(Объект.ВидСделки, Истина);
			Если НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда 
				Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Справочники.ЭтапыСделок.ПустаяСсылка(), "С любого этапа"	, Объект.ПереходСЭтапа = Справочники.ЭтапыСделок.ПустаяСсылка());
				Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Справочники.ЭтапыСделок.ПустаяСсылка(), "На любой этап"	, Объект.ПереходНаЭтап = Справочники.ЭтапыСделок.ПустаяСсылка());
			КонецЕсли;	
			Для К = 0 По МассивЭтапов.Количество() - 1 Цикл
				Если Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда 
					Элементы.ПереходСЭтапа.СписокВыбора.Добавить(МассивЭтапов[К], "На этапе """ + Строка(К + 1) + ". " + Строка(МассивЭтапов[К]) + """", МассивЭтапов[К] = Объект.ПереходСЭтапа);
				Иначе 	
					Элементы.ПереходСЭтапа.СписокВыбора.Добавить(МассивЭтапов[К], "С этапа """ + Строка(К + 1) + ". " + Строка(МассивЭтапов[К]) + """", МассивЭтапов[К] = Объект.ПереходСЭтапа);
				КонецЕсли;	
				Элементы.ПереходНаЭтап.СписокВыбора.Добавить(МассивЭтапов[К], "На этап """ + Строка(К + 1) + ". " + Строка(МассивЭтапов[К]) + """", МассивЭтапов[К] = Объект.ПереходНаЭтап);			
			КонецЦикла;
			Если Элементы.ПереходСЭтапа.СписокВыбора.НайтиПоЗначению(Объект.ПереходСЭтапа) = Неопределено Тогда 
				Объект.ПереходСЭтапа = Справочники.ЭтапыСделок.ПустаяСсылка();
			КонецЕсли;	
			Если Элементы.ПереходНаЭтап.СписокВыбора.НайтиПоЗначению(Объект.ПереходНаЭтап) = Неопределено Тогда 
				Объект.ПереходНаЭтап = Справочники.ЭтапыСделок.ПустаяСсылка();
			КонецЕсли;	
			
			Элементы.ПереходСЭтапа.Видимость 								= РазрешенОтборПоВидуСделок;
			Элементы.ПереходНаЭтап.Видимость 								= РазрешенОтборПоВидуСделок И НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе;
		Иначе 
			Элементы.ПереходСЭтапа.СписокВыбора.Очистить();
			Элементы.ПереходНаЭтап.СписокВыбора.Очистить();
			Если НЕ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда 			
				Элементы.ПереходСЭтапа.СписокВыбора.Добавить(Справочники.ЭтапыСделок.ПустаяСсылка(), "С любого этапа"	, Объект.ПереходСЭтапа = Справочники.ЭтапыСделок.ПустаяСсылка());
				Элементы.ПереходНаЭтап.СписокВыбора.Добавить(Справочники.ЭтапыСделок.ПустаяСсылка(), "На любой этап"	, Объект.ПереходНаЭтап = Справочники.ЭтапыСделок.ПустаяСсылка());		
			КонецЕсли;
			Элементы.ПереходСЭтапа.Видимость 								= Ложь;
			Элементы.ПереходНаЭтап.Видимость 								= Ложь;
		КонецЕсли;
	КонецЕсли;

	Если НЕ РазрешенОтборПоСтатусамКлиентов И НЕ РазрешенОтборПоВидуСделок Тогда 
		Объект.ПереходСЭтапа 				= Неопределено;
		Объект.ПереходНаЭтап 				= Неопределено;
		Элементы.ПереходСЭтапа.Видимость 	= Ложь;
		Элементы.ПереходНаЭтап.Видимость 	= Ложь;
	КонецЕсли;
	
	Если Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда
		ПараметрыОтображенияЭлементов = ИнициализироватьСтруктуруПараметровОтрисовки();		
		Для Каждого СтрокаДействие Из Объект.Действия Цикл 
			Если СтрокаДействие.Удалено Тогда 
				Продолжить;
			КонецЕсли;
			
			УстановитьСвойстваЭлементамДействийПоСделкам(, Объект.Действия.Индекс(СтрокаДействие), ПараметрыОтображенияЭлементов);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

