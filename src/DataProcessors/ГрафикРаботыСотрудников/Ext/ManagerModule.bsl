#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

	#Область СлужебныеПроцедурыИФункции
	
	// Функция вернет день недеи прописью
	// Параметры:
	// НомерДняНедели - Номер дня недели
	Функция ДеньНеделиПрописью(НомерДняНедели) Экспорт
		Если НомерДняНедели = 1 Тогда
			Возврат "Понедельник";
		ИначеЕсли НомерДняНедели = 2 Тогда
			Возврат "Вторник";
		ИначеЕсли НомерДняНедели = 3 Тогда
			Возврат "Среда";
		ИначеЕсли НомерДняНедели = 4 Тогда
			Возврат "Четверг";
		ИначеЕсли НомерДняНедели = 5 Тогда
			Возврат "Пятница";
		ИначеЕсли НомерДняНедели = 6 Тогда
			Возврат "Суббота";
		ИначеЕсли НомерДняНедели = 7 Тогда
			Возврат "Воскресенье";
		КонецЕсли;	
	КонецФункции
	
	// Получить представление времени с минутами в формате надстрочных символов 
	//
	Функция ПредставлениеВремениСНадстрочнымиСимволами(ДатаВремя, МассивНадстрочныхСимволов = Неопределено) Экспорт
		
		Возврат "" + Час(ДатаВремя) + ":" + ?(Минута(ДатаВремя) <= 9, "0" + Минута(ДатаВремя), Минута(ДатаВремя));
		
	КонецФункции
	
	// Вернет конвертированные минуты в часы и остаток минут
	//
	Функция КонвертироватьМинутыВЧасы(Минуты) Экспорт
		
		Часы  = Цел(Минуты / 60);
		Минут = Минуты - (Часы * 60);
		
		Возврат ?(Часы > 0 ,"" + Часы + " ч.","") + ?(Минут > 0 ,"" + Минут + " м.","");
		
	КонецФункции
	
	// Представление ФИО
	//
	Функция ПредставлениеФИО(Сотрудник) Экспорт
		
		Если ЗначениеЗаполнено(Сотрудник.Фамилия) ИЛИ ЗначениеЗаполнено(Сотрудник.Имя) Тогда 
			Возврат ?(ЗначениеЗаполнено(Сотрудник.Фамилия), Сотрудник.Фамилия + " ","")
			+ ?(ЗначениеЗаполнено(Сотрудник.Имя),Лев(Сотрудник.Имя, 1) + ". ","")
			+ ?(ЗначениеЗаполнено(Сотрудник.Отчество),Лев(Сотрудник.Отчество, 1) + ". ", "");
		Иначе
			Возврат Сотрудник.Наименование;
		КонецЕсли;	
		
	КонецФункции
	
	// Получить представление интервалов времени
	//
	Функция ПредставлениеИнтервалаВремени(СписокИнтервала) Экспорт
		
		МассивНадстрочныхСимволов = Неопределено;
		СуммМинут                 = 0;
		Для Каждого ЭлементС ИЗ СписокИнтервала Цикл
			НачалоПредст           	= Формат(ЭлементС.Значение.НачалоРаботы		, "ДФ=HH:mm"); //ПредставлениеВремениСНадстрочнымиСимволами(ЭлементС.Значение.НачалоРаботы, МассивНадстрочныхСимволов);
			КонецПредст            	= Формат(ЭлементС.Значение.ОкончаниеРаботы	, "ДФ=HH:mm"); //ПредставлениеВремениСНадстрочнымиСимволами(ЭлементС.Значение.ОкончаниеРаботы, МассивНадстрочныхСимволов);
			КоличествоМинут 		= Цел((ЭлементС.Значение.ОкончаниеРаботы - ЭлементС.Значение.НачалоРаботы) / 60);		
			ВремяИнтервала 			= ?(КоличествоМинут > 60, Строка(КонвертироватьМинутыВЧасы(КоличествоМинут)), Строка(КоличествоМинут) + " мин.");
			ЭлементС.Представление 	= НачалоПредст + "-" + КонецПредст + " (" + ВремяИнтервала + ")";
			СуммМинут              = СуммМинут + Цел((ЭлементС.Значение.ОкончаниеРаботы - ЭлементС.Значение.НачалоРаботы) / 60);	
		КонецЦикла;
		
		СуммаВремени  = КонвертироватьМинутыВЧасы(СуммМинут);
		Если ЗначениеЗаполнено(СуммаВремени) Тогда
			Возврат Строка(СписокИнтервала);
			//ИначеЕсли СуммМинут = 0 Тогда 
			//    Возврат Строка(СписокИнтервала);
		Иначе 	
			Возврат "";
		КонецЕсли;	
		
	КонецФункции
	
	// Получить представление интервалов времени
	//
	Функция ПолучитьПредставлениеСпискаИнтервалов(СписокИнтервала) Экспорт
		
		ПредставлениеСпискаИнтервалов = "";
		КоличествоИнтервалов = СписокИнтервала.Количество();
		Для Каждого ЭлементС ИЗ СписокИнтервала Цикл
			ТегПереносаСтроки 		= ?(СписокИнтервала.Индекс(ЭлементС) + 1 = КоличествоИнтервалов, "", "<br>");
			ПредставлениеСпискаИнтервалов = ПредставлениеСпискаИнтервалов + ЭлементС.Представление + ТегПереносаСтроки;                         
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ПредставлениеСпискаИнтервалов) Тогда
			Возврат ПредставлениеСпискаИнтервалов;
		Иначе
			Возврат Неопределено;
		КонецЕсли;	
		
	КонецФункции
	
	#Область Печать
	
	Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"ПланированиеГрафикаРаботыСотрудников", НСтр("ru = 'График работы сотрудников'"),
		ПечатьГрафикаРаботыСотрудников(ПараметрыПечати));
		
	КонецПроцедуры
	
	Функция ПечатьГрафикаРаботыСотрудников(ПараметрыПечати)  
		
		
		ТабДок = Новый ТабличныйДокумент;
		
		ТабДок.Очистить();
		ТабДокумент = Новый ТабличныйДокумент;
		Макет = Обработки.ГрафикРаботыСотрудников.ПолучитьМакет("ПланированиеГрафикаРаботыСотрудников");
		
		ТабДокументШапка = Новый ТабличныйДокумент;
		ТабДокументШапка.Очистить();
		
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьЗаголовок");
		
		ОбластьМакета.Параметры.ГрафикЕдиница	= "График работы сотрудников " + ПараметрыПечати.ОтборСтруктурнаяЕдиница;
		ОбластьМакета.Параметры.Период			= "Период c " + Формат(ПараметрыПечати.ОтборПериод.ДатаНачала, "ДФ='dd MMMM yyyy'") + " по " + Формат(ПараметрыПечати.ОтборПериод.ДатаОкончания, "ДФ='dd MMMM yyyy'");
		Табдок.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьСотрудникШапка");
		ТабДокументШапка.Вывести(ОбластьМакета);
		ТабДок.Присоединить(ТабДокументШапка);
		
		ДатаПром = НачалоДня(ПараметрыПечати.ОтборПериод.ДатаНачала);
		Пока ДатаПром <= ПараметрыПечати.ОтборПериод.ДатаОкончания Цикл
			
			Если ДеньНедели(ДатаПром) = 6 или  ДеньНедели(ДатаПром) = 7  тогда
				ОбластьМакета = Макет.ПолучитьОбласть("ОбласьШапкаДеньВ");
			иначе
				ОбластьМакета = Макет.ПолучитьОбласть("ОбластьДеньШапка");
			Конецесли;
			
			ОбластьМакета.Параметры.День= Формат(ДатаПром,"ДФ=dd.MM.yy") + символы.ПС + ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьДеньНедели(ДеньНедели(ДатаПром));
			ТабДок.Присоединить(ОбластьМакета);
			
			ДатаПром= ДатаПром+ 60*60*24;
			
		КонецЦикла;
		
		ТабДокументСотрудникиДни = Новый ТабличныйДокумент;
		
		ТабДокументСотрудникиДни.Очистить();
		Для каждого СтрокаСотрудника Из ПараметрыПечати.ГрафикПериодовРаботы  Цикл //ГрафикПериодовРаботы
			
			Если ТипЗнч(ПараметрыПечати.ОтборСотрудникДолжность) = Тип("СправочникСсылка.Сотрудники") Тогда
				Если СтрокаСотрудника.Сотрудник = ПараметрыПечати.ОтборСотрудникДолжность тогда
					ОбластьМакета = Макет.ПолучитьОбласть("ОбластьСотрудникСтрока");
					ОбластьМакета.Параметры.Сотрудник = СтрокаСотрудника.Сотрудник;
					ОбластьМакета.Параметры.Должность = СтрокаСотрудника.Должность;
					ТабДокументСотрудникиДни.Вывести(ОбластьМакета);
				КонецЕсли;
				
			ИначеЕсли ТипЗнч(ПараметрыПечати.ОтборСотрудникДолжность) = Тип("СправочникСсылка.Должности") Тогда
				Если СтрокаСотрудника.Должность = ПараметрыПечати.ОтборСотрудникДолжность тогда
					ОбластьМакета = Макет.ПолучитьОбласть("ОбластьСотрудникСтрока");
					ОбластьМакета.Параметры.Сотрудник = СтрокаСотрудника.Сотрудник;
					ОбластьМакета.Параметры.Должность = СтрокаСотрудника.Должность;
					ТабДокументСотрудникиДни.Вывести(ОбластьМакета);
				КонецЕсли;
				
			Иначе
				ОбластьМакета = Макет.ПолучитьОбласть("ОбластьСотрудникСтрока");
				ОбластьМакета.Параметры.Сотрудник = СтрокаСотрудника.Сотрудник;
				ОбластьМакета.Параметры.Должность = СтрокаСотрудника.Должность;
				ТабДокументСотрудникиДни.Вывести(ОбластьМакета);
			КонецЕсли;
			
		КонецЦикла;
		
		ТабДокумент.Присоединить(ТабДокументСотрудникиДни);
		
		//
		ТабДокументДни= Новый ТабличныйДокумент;
		ТабДокументДни.Очистить();
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьДеньСтрока");
		
		Для каждого СтрокаДня Из ПараметрыПечати.ГрафикПериодовРаботы Цикл
			
			Если ТипЗнч(ПараметрыПечати.ОтборСотрудникДолжность) = Тип("СправочникСсылка.Сотрудники") Тогда
				Если СтрокаДня.Сотрудник = ПараметрыПечати.ОтборСотрудникДолжность тогда
					ТабДокументДни=ЗаполнитьДни(ОбластьМакета, ТабДокументДни, СтрокаДня, ПараметрыПечати);
				КонецЕсли;
				
			ИначеЕсли ТипЗнч(ПараметрыПечати.ОтборСотрудникДолжность) = Тип("СправочникСсылка.Должности") Тогда
				Если СтрокаДня.Должность = ПараметрыПечати.ОтборСотрудникДолжность тогда
					ТабДокументДни=ЗаполнитьДни(ОбластьМакета, ТабДокументДни, СтрокаДня, ПараметрыПечати);
				КонецЕсли;
			Иначе
				ТабДокументДни=ЗаполнитьДни(ОбластьМакета, ТабДокументДни, СтрокаДня, ПараметрыПечати);
			КонецЕсли;
			
		КонецЦикла;
		
		ТабДокумент.Присоединить(ТабДокументДни);
		ТабДок.Вывести( ТабДокумент);	
		
		ТабДок.ФиксацияСверху	= 4;
		ТабДок.ФиксацияСлева	= 2;
		
		ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		
		Возврат ТабДок;	
		
	КонецФункции
	
	Функция ЗаполнитьДни(ОбластьМакета, ТабДокументДни, СтрокаДня, ПараметрыПечати) 
		
		ДатаПром = НачалоДня(ПараметрыПечати.ОтборПериод.ДатаНачала);
		ФлагПервыйОбход = Истина;
		Пока ДатаПром <= ПараметрыПечати.ОтборПериод.ДатаОкончания Цикл
			
			ОбластьМакета.параметры.День = СтрокаДня["Период"+СтрЗаменить(Формат(ДатаПром,"ДФ=dd.MM.yyyy"),".","")];
			Если ФлагПервыйОбход Тогда
				ТабДокументДни.Вывести(ОбластьМакета);
			Иначе
				ТабДокументДни.Присоединить(ОбластьМакета);
			КонецЕсли;  	
			
			ФлагПервыйОбход = ложь;
			
			ДатаПром = ДатаПром+ 60*60*24;
			
		КонецЦикла;
		
		Возврат ТабДокументДни;
		
	КонецФункции
	
	#КонецОбласти
	
	
	#КонецОбласти
	
#КонецЕсли