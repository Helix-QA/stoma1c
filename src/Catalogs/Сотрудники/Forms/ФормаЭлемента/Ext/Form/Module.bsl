&НаКлиенте
// Процедура - Открыть форму ввода доп информации.
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборСпециализацииЗавершение(Результат, Параметр) Экспорт
		
	Если ЗначениеЗаполнено(Результат) Тогда
		
		НайденнаяСтрока = Объект.СпецилазацииСотрудника.НайтиСтроки(Новый Структура ("Специализация", Результат));

		Если ЗначениеЗаполнено(НайденнаяСтрока) Тогда
			ПоказатьПредупреждение(,"Данная специализация уже добавлена!");
		Иначе
			ВыборСпециализацииЗавершениеСервер(Результат);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Выбор специализации завершение сервер.
//
// Параметры:
//  Результат	 - 	 - 
//
Процедура ВыборСпециализацииЗавершениеСервер(Результат)
	
	НоваяСтрока			      = Объект.СпецилазацииСотрудника.Добавить();
	НоваяСтрока.Специализация = Результат;	
	НоваяСтрока.Основная 	  = Объект.СпецилазацииСотрудника.Количество() = 1;	
	
	СформироватьЭлементыСтрокиСпециализации(НоваяСтрока);
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте                                                          
// Процедура - Подключаемый декорация формы представление нажатие.
// 
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура Подключаемый_ПредставлениеСпециализацияНажатие(Элемент)
	
	СтрокаДанных = Объект.СпецилазацииСотрудника.НайтиПоИдентификатору(ИдентификаторСтрокиДанныхПоИмениЭлемента(Элемент.Имя));
	
	Если СтрокаДанных.Основная Тогда
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(СтрокаДанных.Специализация));
	Иначе
		
		СписокВариантов = Новый СписокЗначений;
		СписокВариантов.Добавить("Открыть", "Открыть");
		СписокВариантов.Добавить("НазначитьОсновной", "Назначить основной");
		
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ИДСтроки", ИдентификаторСтрокиДанныхПоИмениЭлемента(Элемент.Имя));
		ДопПараметры.Вставить("Специализация", Объект.СпецилазацииСотрудника.НайтиПоИдентификатору(ИдентификаторСтрокиДанныхПоИмениЭлемента(Элемент.Имя)));
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВариантаДействияСоСпециализацией", ЭтотОбъект, ДопПараметры);
		ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВариантов, Элемент);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Выбор варианта действия с кассой.
// 
// Параметры:
//  ВыбранныйЭлемент		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ВыборВариантаДействияСоСпециализацией(ВыбранныйЭлемент, ДопПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбранныйЭлемент.Значение = "Открыть" Тогда
		
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ДопПараметры.Специализация.Специализация));
		
	ИначеЕсли ВыбранныйЭлемент.Значение = "НазначитьОсновной" Тогда
		// Сброс по всем строкам
		Для Каждого СтрокаТ ИЗ Объект.СпецилазацииСотрудника Цикл
			СтрокаТ.Основная = Ложь;
			Элементы["СпециализацияПредставление_" + СтрокаТ.ПолучитьИдентификатор()].Заголовок = СтрокаТ.Специализация;
		КонецЦикла;
		
		СтрокаДанных          = Объект.СпецилазацииСотрудника.НайтиПоИдентификатору(ДопПараметры.ИДСтроки);
		СтрокаДанных.Основная = Истина;
		
		Элементы["СпециализацияПредставление_" + ДопПараметры.ИДСтроки].Заголовок = "" + СтрокаДанных.Специализация + " (Основная)";
		
		ЭтаФорма.Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
// Процедура - Удалить строку специализация.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура УдалитьСтрокуСпециализация(Команда)
	
	УдалитьСтрокуСпециализацияСервер();
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить строку специализация сервер.
//
Процедура УдалитьСтрокуСпециализацияСервер()
	
	ИДСтроки = ИдентификаторСтрокиДанныхПоИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
	Объект.СпецилазацииСотрудника.Удалить(Объект.СпецилазацииСотрудника.НайтиПоИдентификатору(ИДСтроки));
	ЭтаФорма.Модифицированность = Истина;
	
	МассивУдаляемыхЭлементов = Новый Массив;
	
	Для Каждого Элемент Из Элементы.ГруппаСпециализацииСуществующие.ПодчиненныеЭлементы Цикл
		МассивУдаляемыхЭлементов.Добавить(Элемент);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из МассивУдаляемыхЭлементов Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Объект.СпецилазацииСотрудника) Тогда
		
		НайденныеСтроки = Объект.СпецилазацииСотрудника.НайтиСтроки(Новый Структура("Основная", Истина));
		
		Если НЕ ЗначениеЗаполнено(НайденныеСтроки) Тогда
			Объект.СпецилазацииСотрудника[0].Основная = Истина;	
		КонецЕсли;
	КонецЕсли;
		
	Для Каждого СтрокаТ Из Объект.СпецилазацииСотрудника Цикл
		СформироватьЭлементыСтрокиСпециализации(СтрокаТ);	
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область МестаРаботыИНастройкаСотрудников

&НаКлиенте
// Процедура - Подбор места работы сотрудника выгружать обработка.
//
Процедура ОбновитьМестаРаботыСотрудника()
	
	ОбработкаТабличныхЧастейКлиент.УстановитьФлагиНаСтруктурныеЕдиницы(ЭтаФорма, "ПодборМестаРаботыСотрудника");
	ЭтаФорма.Модифицированность = Истина;
	
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	
	ТекущиеДанные = Элементы.ПодборМестаРаботыСотрудника.ТекущиеДанные;
	
	Если ТекущиеДанные.Выгружать = 1 И ДоступныеСтруктурныеЕдиницы.НайтиСтроки(
		Новый Структура("СтруктурнаяЕдиница", ТекущиеДанные.СтруктурнаяЕдиница)).Количество() = 0 Тогда
		
		СтрокаТЧ 				 	= ДоступныеСтруктурныеЕдиницы.Вставить(0);
		СтрокаТЧ.СтруктурнаяЕдиница = ТекущиеДанные.СтруктурнаяЕдиница;
		
		Если ТекущиеДанные.ИндКартинки = 3 Тогда
			СтрокаТЧ.ПометкаУдаления   = Истина;
		КонецЕсли;
		
	ИначеЕсли ТекущиеДанные.Выгружать = 0 Тогда
		
		СЕНаУдаление = ДоступныеСтруктурныеЕдиницы.НайтиСтроки(
		Новый Структура("СтруктурнаяЕдиница", ТекущиеДанные.СтруктурнаяЕдиница));
		
		Для каждого CE из СЕНаУдаление Цикл 
			ДоступныеСтруктурныеЕдиницы.Удалить(CE);
		КонецЦикла;
		
	КонецЕсли;
		
	ОбновитьЭлементыГруппы("ГруппаМестаРаботыВыбранные");
	
	// Обновить структурные единицы онлайн-записи.
	СоздатьДеревоСтруктурныхЕдиницДляОнлайнЗаписи();
	
КонецПроцедуры 

&НаКлиенте
// Процедура -  обновляет подбор доступных журналов приемов сотрудника.
