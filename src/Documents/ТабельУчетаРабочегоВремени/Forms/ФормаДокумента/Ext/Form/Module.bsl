&НаКлиенте
Процедура ДиалогПользователю_ДобавлениеСотрудниковЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(ТаблицаНовыхСотрудников, Объект.ДниРаботы);		
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура заполняет данными ТЧ ДниРаботы по регистру работы сотрудников
//
// Параметры:
// 		ИмяРегистраВремяРаботыСотрудников  - Строка, имя регистра работы сотрудников
//
Процедура ЗаполнитьПоРегиструРаботыСотрудников(ИмяРегистраВремяРаботыСотрудников)
	
	Запрос       = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
		|	ВремяРаботыСотрудников.Сотрудник,
		|	НАЧАЛОПЕРИОДА(ВремяРаботыСотрудников.ДатаВремяНачала, ДЕНЬ) КАК Дата,
		|	СУММА(ВремяРаботыСотрудников.Минуты) КАК Минуты
		|ИЗ
		|	РегистрСведений." + ИмяРегистраВремяРаботыСотрудников + " КАК ВремяРаботыСотрудников
		|
		|ГДЕ
		|	ВремяРаботыСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ВремяРаботыСотрудников.ДатаВремяНачала >= &ПериодОт
		|	И ВремяРаботыСотрудников.ДатаВремяНачала <= &ПериодПо
		|
		|СГРУППИРОВАТЬ ПО
		|	ВремяРаботыСотрудников.Сотрудник,
		|	НАЧАЛОПЕРИОДА(ВремяРаботыСотрудников.ДатаВремяНачала, ДЕНЬ)";
		
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ПериодОт"          , НачалоМесяца(Объект.Период));
	Запрос.УстановитьПараметр("ПериодПо"          , КонецМесяца(Объект.Период));

	Результат = Запрос.Выполнить().Выгрузить();
	
	// Очищаем значение колонок дней
	Для Каждого СтрокаТЧ Из Объект.ДниРаботы Цикл
		Для а = 1 По 31 Цикл
			СтрокаТЧ["День" + а] = Неопределено;
		КонецЦикла;
		СтрокаТЧ.ВсегоЧасов = Неопределено;
		СтрокаТЧ.ВсегоДней = Неопределено;
	КонецЦикла;

	// Заполняем табель работы по времени работы сотрудников
	Для Каждого СтрокаРезультат Из Результат Цикл
		СтрокаТЧ = Объект.ДниРаботы.НайтиСтроки(Новый Структура("Сотрудник", СтрокаРезультат.Сотрудник));
		Если СтрокаТЧ.Количество() > 0 Тогда
			СтрокаТЧ[0]["День" + День(СтрокаРезультат.Дата)] = Цел(СтрокаРезультат.Минуты / 60) + (СтрокаРезультат.Минуты - Цел(СтрокаРезультат.Минуты / 60) * 60) / 60;
		КонецЕсли;
	КонецЦикла;
	
	// Пересчитаем итоги в табеле по сотрудникам
	Для Каждого СтрокаТЧ Из Объект.ДниРаботы Цикл
		ПересчитатьИтогиСтрокиДниРаботы(СтрокаТЧ);
	КонецЦикла;	    
		
КонецПроцедуры

&НаКлиенте
// Процедура - Установить доступность видимость элементов
