// Функция создает папки справочника "Сотрудники" по умолчанию.
//
Процедура ЗаполнитьПоУмолчанию() Экспорт
	
	// Создаем группы элементов в справочнике "Сотрудники"
	ИскомыйЭлемент = Справочники.Сотрудники.НайтиПоНаименованию("Руководство", Истина);
	Если ИскомыйЭлемент.Пустая() Тогда
		Руководство = Справочники.Сотрудники.СоздатьГруппу();
		Руководство.Наименование = "Руководство";
		Руководство.Записать();
	КонецЕсли;
	
	ИскомыйЭлемент = Справочники.Сотрудники.НайтиПоНаименованию("Врачи", Истина);
	Если ИскомыйЭлемент.Пустая() Тогда
		Врачи = Справочники.Сотрудники.СоздатьГруппу();
		Врачи.Наименование = "Врачи";
		Врачи.Записать();
	КонецЕсли;  
	
	ИскомыйЭлемент = Справочники.Сотрудники.НайтиПоНаименованию("Регистратура", Истина);
	Если ИскомыйЭлемент.Пустая() Тогда
		Регистратура = Справочники.Сотрудники.СоздатьГруппу();
		Регистратура.Наименование = "Регистратура";
		Регистратура.Записать();
	КонецЕсли;
	
	ИскомыйЭлемент = Справочники.Сотрудники.НайтиПоНаименованию("Уволенные сотрудники", Истина);
	Если ИскомыйЭлемент.Пустая() Тогда
		УволенныеСотрудники = Справочники.Сотрудники.СоздатьГруппу();
		УволенныеСотрудники.Наименование = "Уволенные сотрудники";
		УволенныеСотрудники.Записать();
	КонецЕсли; 
	
КонецПроцедуры

// Функция - Отбор сотрудников для приема
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокВрачейДляПриема(СтруктураПараметров) Экспорт
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СправочникСотрудники.Ссылка КАК Сотрудник
		|ИЗ
		|	Справочник.Сотрудники КАК СправочникСотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		|		ПО СправочникСотрудники.Ссылка = НастройкиСотрудников.Сотрудник
		|			И (НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		|ГДЕ
		|	СправочникСотрудники.ЭтоГруппа = ЛОЖЬ
		|	И (СправочникСотрудники.Ссылка В
		|				(ВЫБРАТЬ
		|					СвязкаПомещениеСотрудник.Сотрудник
		|				ИЗ
		|					РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник
		|				ГДЕ
		|					СвязкаПомещениеСотрудник.Помещение.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		|			ИЛИ НЕ СправочникСотрудники.Ссылка В
		|					(ВЫБРАТЬ
		|						СвязкаПомещениеСотрудник.Сотрудник
		|					ИЗ
		|						РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник))
		|	И СправочникСотрудники.ПометкаУдаления = ЛОЖЬ
		|	И (НастройкиСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
		|			ИЛИ НастройкиСотрудников.ДатаУвольнения > &Дата)
		|	И (НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
		|			ИЛИ НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач)
		|			ИЛИ &ЭтоАссистент)
		|	И СправочникСотрудники.Ссылка <> &Сотрудник
		|	И СправочникСотрудники.Служебный = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	СправочникСотрудники.Ссылка,
		|	СправочникСотрудники.Представление";
	
	Если СтруктураПараметров.Свойство("ЭтоАссистент") Тогда
		
		ТекстЗамены = "ИЛИ НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Ассистент)";
		
	Иначе
		
		ТекстЗамены = "";
		
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИЛИ &ЭтоАссистент", ТекстЗамены);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктураПараметров.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Дата"				, СтруктураПараметров.Дата);
	Запрос.УстановитьПараметр("Сотрудник"			, СтруктураПараметров.Сотрудник);
	
	ФиксированныйМассив = Новый ФиксированныйМассив(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник"));
	Возврат ФиксированныйМассив;
	
КонецФункции

