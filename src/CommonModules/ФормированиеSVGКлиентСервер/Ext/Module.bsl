// Процедура, формирует ДЗФ
//
Функция СформироватьЗубнуюФормулу(ТаблицаСтатусов = Неопределено, Детская = Ложь) Экспорт
	
	SVG  = ""; 
	
	Если НЕ ТаблицаСтатусов = Неопределено Тогда
		ТаблицаСтатусов.Сортировать("Зуб, СтатусЗуба УБЫВ");			
	КонецЕсли;
	
	Если Детская Тогда 		
		МассивЗубов = ОбщегоНазначенияСтоматология.ПолучитьМассивЗубов(Истина);
		
		Для Каждого СтрокаМассива из МассивЗубов Цикл		
			Статус = 0;
			Если Не ТаблицаСтатусов = Неопределено Тогда
				НайденныеСтроки = ТаблицаСтатусов.НайтиСтроки(Новый Структура("Зуб", СтрокаМассива));
				Если НайденныеСтроки.Количество() > 0 Тогда
					Статус = Число(НайденныеСтроки[0].СтатусЗуба);				
				КонецЕсли;
				SVG = SVG + ПолучитьSVGЗубДФ(Строка(СтрокаМассива), Статус);
			КонецЕсли; 		
		КонецЦикла;
	Иначе
		МассивЗубов = ОбщегоНазначенияСтоматология.ПолучитьМассивЗубов(Ложь);
		
		Для Каждого СтрокаМассива из МассивЗубов Цикл		
			Статус = 0;
			Если Не ТаблицаСтатусов = Неопределено Тогда
				НайденныеСтроки = ТаблицаСтатусов.НайтиСтроки(Новый Структура("Зуб", СтрокаМассива));
				Если НайденныеСтроки.Количество() > 0 Тогда
					Статус = Число(НайденныеСтроки[0].СтатусЗуба);						
				КонецЕсли;
				SVG = SVG + ПолучитьSVGЗуб(Строка(СтрокаМассива), Статус);
			КонецЕсли; 		
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат SVG + ПолучитьПодвалSVG();
		
КонецФункции

