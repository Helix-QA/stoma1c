		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СобытиеУслуги.Ссылка КАК ПредварительнаяЗапись,
	СобытиеУслуги.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	СобытиеУслуги.Ссылка.Контрагент КАК Пациент,
	СобытиеУслуги.Ссылка.Статус КАК Статус,
	СобытиеУслуги.Ссылка.ПричинаОтмены КАК ПричинаОтмены,
	СобытиеУслуги.ДатаНачала КАК ДатаНачала,
	СобытиеУслуги.Сотрудник КАК Врач,
	СобытиеУслуги.Номенклатура КАК Услуга,
	СобытиеУслуги.Помещение КАК Помещение,
	СобытиеУслуги.Ссылка.ТелефонныйЗвонок КАК Подтверждена,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СобытиеУслуги.Ссылка) КАК Количество,
	Прием.Ссылка КАК Прием,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ЧАС) КАК ПериодЧас,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ДЕНЬ) КАК ПериодДень,
	ДЕНЬНЕДЕЛИ(СобытиеУслуги.Ссылка.Дата) КАК ПериодНеделя,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, КВАРТАЛ) КАК ПериодКвартал,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ПОЛУГОДИЕ) КАК ПериодПолугодие,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ГОД) КАК ПериодГод,
	СУММА(Прием.СуммаДокумента) КАК ПриемСумма,
	СУММА(Прием.СуммаОплачено) КАК ПриемОплачено,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Прием.Ссылка) КАК КоличествоПриемов,
	СобытиеУслуги.Ссылка.АвторДокумента КАК АвторПредварительнойЗаписи,
	СУММА(ВЫБОР
			КОГДА Прием.СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный)
				ТОГДА 1
			ИНАЧЕ 0
		КОНЕЦ) КАК ЭтоПервичнаяЗапись
ИЗ
	Документ.Событие.Услуги КАК СобытиеУслуги
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Прием КАК Прием
		ПО СобытиеУслуги.Ссылка = Прием.ДокументОснование
ГДЕ
	СобытиеУслуги.Ссылка.Проведен = ИСТИНА
	И СобытиеУслуги.НомерСтроки = 1
	И ВЫБОР
			КОГДА &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(2000, 1, 1)
				ТОГДА СобытиеУслуги.ДатаНачала &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(2000, 1, 1)
				ТОГДА СобытиеУслуги.ДатаНачала &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;МеткаПациента &lt;&gt; ЗНАЧЕНИЕ(Справочник.Метки.ПустаяСсылка)
				ТОГДА СобытиеУслуги.Ссылка.Контрагент В
						(ВЫБРАТЬ
							МеткиКлиентовСрезПоследних.Клиент
						ИЗ
							РегистрСведений.МеткиКлиентов.СрезПоследних КАК МеткиКлиентовСрезПоследних
						ГДЕ
							МеткиКлиентовСрезПоследних.Метка = &amp;МеткаПациента)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;МеткаПредварительнойЗаписи &lt;&gt; ЗНАЧЕНИЕ(Справочник.Метки.ПустаяСсылка)
				ТОГДА СобытиеУслуги.Ссылка В
						(ВЫБРАТЬ
							МеткиКлиентовСрезПоследних.Клиент
						ИЗ
							РегистрСведений.МеткиКлиентов.СрезПоследних КАК МеткиКлиентовСрезПоследних
						ГДЕ
							МеткиКлиентовСрезПоследних.Метка = &amp;МеткаПредварительнойЗаписи)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА Прием.Ссылка ЕСТЬ NULL 
				ТОГДА ИСТИНА
			ИНАЧЕ Прием.Проведен = ИСТИНА
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	СобытиеУслуги.Ссылка,
	СобытиеУслуги.Ссылка.СтруктурнаяЕдиница,
	СобытиеУслуги.Ссылка.Контрагент,
	СобытиеУслуги.Ссылка.Статус,
	СобытиеУслуги.Ссылка.ПричинаОтмены,
	СобытиеУслуги.ДатаНачала,
	СобытиеУслуги.Сотрудник,
	СобытиеУслуги.Номенклатура,
	СобытиеУслуги.Помещение,
	СобытиеУслуги.Ссылка.ТелефонныйЗвонок,
	Прием.Ссылка,
	СобытиеУслуги.Ссылка.АвторДокумента,
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ЧАС),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ДЕНЬ),
	ДЕНЬНЕДЕЛИ(СобытиеУслуги.Ссылка.Дата),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, МЕСЯЦ),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, КВАРТАЛ),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ПОЛУГОДИЕ),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ГОД)</query>
	</dataSet>
