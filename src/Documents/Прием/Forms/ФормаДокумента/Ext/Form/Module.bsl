// Процедура - обработчик события "ПриИзменении" объект поле "Сотрудник"
//
Процедура СотрудникПриИзменении(Элемент)	
	
	Если ЗначениеЗаполнено(Объект.Сотрудник) Тогда
		
		ЭтоСтоматологическиеУслугиПред  = ЭтоСтоматологическиеУслуги;
		ЭтоСтоматологическиеУслуги      = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник);
		ШаблонОбследованияПред          = Объект.ШаблонОбследования;
		
		// При несовпадении признаком запрос на продолжение
		Если НЕ ЭтоСтоматологическиеУслугиПред = ЭтоСтоматологическиеУслуги И (Объект.Лечение.Количество() > 0 ИЛИ Объект.Запасы.Количество() > 0)  Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("СотрудникПриИзмененииОчиститьТЧЛечениеЗапасы", ЭтотОбъект, Новый Структура("ЭтоСтоматологическиеУслугиПред,ЭтоСтоматологическиеУслуги,ШаблонОбследованияПред", ЭтоСтоматологическиеУслугиПред,ЭтоСтоматологическиеУслуги,ШаблонОбследованияПред)), 
			"Специализация выбранного сотрудника не соответсвует текущей специализации приема. Обследование и табличные части будут очишены. Продолжить?",РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
		
		СотрудникПриИзмененииПродолжение(ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги, ШаблонОбследованияПред) ;
		Возврат;
		
	КонецЕсли;	
	
	СотрудникПред = Объект.Сотрудник;
	
	ОбновитьВиджетСделки();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сотрудник при изменении после вопроса очистить ТЧ
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СотрудникПриИзмененииОчиститьТЧЛечениеЗапасы(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ЭтоСтоматологическиеУслугиПред = ДополнительныеПараметры.ЭтоСтоматологическиеУслугиПред;
	ЭтоСтоматологическиеУслуги     = ДополнительныеПараметры.ЭтоСтоматологическиеУслуги;
	ШаблонОбследованияПред         = ДополнительныеПараметры.ШаблонОбследования;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Объект.Лечение.Очистить();
		Объект.Запасы.Очистить();
	Иначе
		Объект.Сотрудник           = СотрудникПред;
		ЭтоСтоматологическиеУслуги = ЭтоСтоматологическиеУслугиПред;
		Возврат;
	КонецЕсли;
	
	СотрудникПриИзмененииПродолжение(ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги,ШаблонОбследованияПред);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сотрудник при изменении продолжение
//
// Параметры:
//  ЭтоСтоматологическиеУслугиПред	 - 	 - 
//  ЭтоСтоматологическиеУслуги		 - 	 - 
//  ШаблонОбследованияПред			 - 	 - 
//
Процедура СотрудникПриИзмененииПродолжение(ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги,ШаблонОбследованияПред)
	
	Если ИспользоватьНесколькоВрачейВОдномПриеме() Тогда 
		Если Объект.Лечение.Количество() > 0 Тогда 		
			ТекстВопроса =  ПолучитьТекстВопроса();
			Если ТекстВопроса <> "" Тогда
				ПоказатьВопрос(Новый ОписаниеОповещения("СотрудникПриИзмененииПродолжениеПослеВопросаПерезаполнениеВрача", ЭтотОбъект, 
								Новый Структура("ШаблонОбследованияПред, ЭтоСтоматологическиеУслуги, ЭтоСтоматологическиеУслугиПред", ШаблонОбследованияПред, ЭтоСтоматологическиеУслуги, ЭтоСтоматологическиеУслугиПред)), 
								ТекстВопроса,РежимДиалогаВопрос.ДаНет,0,,"Вопроса");
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Серверные операции
	СотрудникПриИзмененииПродолжениеЗавершение(ШаблонОбследованияПред, ЭтоСтоматологическиеУслуги, ЭтоСтоматологическиеУслугиПред);

КонецПроцедуры

&НаКлиенте
// Процедура - Сотрудник при изменении продолжение после вопроса перезаполнение врача
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СотрудникПриИзмененииПродолжениеПослеВопросаПерезаполнениеВрача(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ШаблонОбследованияПред = ДополнительныеПараметры.ШаблонОбследованияПред;
	ЭтоСтоматологическиеУслуги = ДополнительныеПараметры.ЭтоСтоматологическиеУслуги;
	ЭтоСтоматологическиеУслугиПред = ДополнительныеПараметры.ЭтоСтоматологическиеУслугиПред;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда 
		Для Каждого СтрокаТЧЛечение Из Объект.Лечение Цикл 
			Если СтрокаТЧЛечение.Сотрудник = Врач Тогда 
				СтрокаТЧЛечение.Сотрудник = Объект.Сотрудник;
			КонецЕсли;
		КонецЦикла;				
	КонецЕсли;					
	
	СотрудникПриИзмененииПродолжениеЗавершение(ШаблонОбследованияПред, ЭтоСтоматологическиеУслуги, ЭтоСтоматологическиеУслугиПред);

КонецПроцедуры

&НаКлиенте
// Процедура - Сотрудник при изменении продолжение завершение
//
// Параметры:
//  ШаблонОбследованияПред			 - 	 - 
//  ЭтоСтоматологическиеУслуги		 - 	 - 
//  ЭтоСтоматологическиеУслугиПред	 - 	 - 
//
Процедура СотрудникПриИзмененииПродолжениеЗавершение(Знач ШаблонОбследованияПред, Знач ЭтоСтоматологическиеУслуги, Знач ЭтоСтоматологическиеУслугиПред)
	
	СотрудникПриИзмененииСервер();		
	// Перезаполнение деревьев подбора
	// При изменении выбранного шаблона обследования
	Если ШаблонОбследованияПред <> Объект.ШаблонОбследования Тогда
		ШаблонОбследованияПриИзменении(Неопределено);
	КонецЕсли;
	// Обновить документ 
	Если ЭтоСтоматологическиеУслуги
		И (НЕ ЭтоСтоматологическиеУслугиПред = ЭтоСтоматологическиеУслуги) Тогда
		ОбновитьДокумент();	
	КонецЕсли; 	
	
	СотрудникПред = Объект.Сотрудник;
	
	ЗаполнитьПараметрыВыбораСтруктурныхЕдиниц();
	
	ОбновитьВиджетСделки();

КонецПроцедуры

&НаСервере
// Процедура - обработчик события "ПриИзменении" объект поле "Сотрудник"
//
Процедура СотрудникПриИзмененииСервер()
	
	// Получить специализацию текущего сотрудника
    // Получаем шаблон по умолчанию	
	Объект.ШаблонОбследования       = ШаблонОбследованияПациента();		
	Объект.ВидЦен                   = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
	// Выполняем заполнение поля Цена табличной части документа исходя из вида цены
	Ценообразование.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы");	
	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл		
		СтрокаТч.ВидЦен = Объект.ВидЦен; 			
		СтруктураДанные = Новый Структура("ВидЦен, Номенклатура", Объект.ВидЦен, СтрокаТЧ.Номенклатура);
		ЗаполнитьЗначенияСвойств(СтруктураДанные, СтрокаТЧ); 
		СтрокаТЧЦена = Ценообразование.ПолучитьЦенуСертификата(СтруктураДанные);
		Если СтрокаТЧЦена <> Неопределено Тогда
			СтрокаТч.Цена = СтрокаТЧЦена;
		КонецЕсли;			
	КонецЦикла;
		 
	Объект.Ассистент = РегистрыСведений.НастройкиСотрудников.ПолучитьАссистентаСотрудника(Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
	
	// Перерасчет всех сумм и автоматических скидок
	// ТабличныеЧастиПересчетПослеИзменений("Запасы");	
	// ТабличныеЧастиПересчетПослеИзменений("Лечение");
	ПересчетТабличныхЧастейФормы();
	// Обновление таблиц УслугиПодбор и ТоварыПодбор
	ОбновлениеНоменклатурыВТаблицахПодбора(Неопределено);
	// Вызвать обработчик отображения формы
	НастройкаФормыСервер("ПРИ_ИЗМЕНЕНИИ_СОТРУДНИКА");
	
КонецПроцедуры	

&НаКлиенте
// Запрос пользователю о перезаполнении врачей в ТЧ
Функция ПолучитьТекстВопроса()
	
	ТекстВопроса = "";
	
	ЕстьНеЗаполненыеСтроки 	= Ложь;
	ЕстьЗаполненыеИзШапки 	= Ложь;
	Для Каждого СтрокаТЧЛечение Из Объект.Лечение Цикл 
		Если НЕ ЗначениеЗаполнено(СтрокаТЧЛечение.Сотрудник) Тогда 
			ЕстьНеЗаполненыеСтроки = Истина;					
		КонецЕсли;	
		Если СтрокаТЧЛечение.Сотрудник = Врач И ЗначениеЗаполнено(Врач) Тогда 
			ЕстьЗаполненыеИзШапки = Истина;					
		КонецЕсли;
	КонецЦикла;
	Если ЕстьНеЗаполненыеСтроки Тогда 
		Если ЕстьЗаполненыеИзШапки Тогда
			Возврат "Перезаполнить врача в табличной части ""Лечение""?"; 
		Иначе 
			Возврат "Заполнить врача в табличной части ""Лечение""?";
		КонецЕсли;	
	Иначе
		Если ЕстьЗаполненыеИзШапки Тогда 
			Возврат "Перезаполнить врача в табличной части ""Лечение"", ранее взятого из шапки?";
		Иначе 	
			// ничего не делаем
			Возврат ТекстВопроса;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекстВопроса;
	
КонецФункции	

&НаКлиенте
// Процедура обработчик команды вызывает форму настройки и редактирования цен.
//
Процедура РедактироватьЦены(Результат = Неопределено, Параметры = Неопределено) Экспорт
	
	Если Параметры = Истина Тогда
		Параметры = Ложь;
	КонецЕсли;		
	
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураЦены = Результат;
	
	Если ТипЗнч(СтруктураЦены) <> Тип("Структура") Тогда
		
		// 1. Формируем структуру параметров для заполнения формы "Цены и Валюта"
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ВидЦен"			, Объект.ВидЦен);
		СтруктураПараметров.Вставить("ПерезаполнитьЦены",	Ложь);
		
		// 2. Открвыаем форму "Цены и Валюта".
		ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,, Новый ОписаниеОповещения("РедактироватьЦены", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	Иначе
		
		// 3. Перезаполняем табличную часть "Запасы" и "Лечение" если были внесены изменения в форме "Цены и Валюта".
		Если СтруктураЦены.БылиВнесеныИзменения Тогда
			
			Объект.ВидЦен 			= СтруктураЦены.ВидЦен;
				
			// Пересчитываем цены по виду цен					
			Если СтруктураЦены.ПерезаполнитьЦены И (Объект.Запасы.Количество() <> 0 ИЛИ Объект.Лечение.Количество() <> 0) Тогда
				ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы");
				ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Лечение");
				ТабличныеЧастиПересчетПослеИзменений("Лечение");
			КонецЕсли;	
						
			Модифицированность = Истина;
			
		КонецЕсли;
		
		РедактироватьЦеныНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

 &НаСервере
// Процедура, обработчик настройки и редактирования цен на сервере
//
Процедура РедактироватьЦеныНаСервере()
	
	Объект.СуммаДокумента = Объект.Запасы.Итог("Всего") + Объект.Лечение.Итог("Всего");
	ОтобразитьИнформациюПоОплате();
	
	// Сформируем надпись
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);	
	ВидЦенНадпись = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи, Ложь);
		
