				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)", "ДокументПрием.Лечение.Номенклатура = &СегментУслуг");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			ИначеЕсли ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)",
				"ДокументПрием.Лечение.Номенклатура В
				|			(ВЫБРАТЬ
				|				НоменклатураСегмента.Номенклатура
				|			ИЗ
				|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
				|			ГДЕ
				|				НоменклатураСегмента.Сегмент = &СегментУслуг)");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			КонецЕсли;	
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
