//
//
Функция ВернутьТелефонТолькоЦифрами(Строка) Экспорт
	
  СтрокаЧисел = "";

   Для Индекс = 1 По СтрДлина(Строка) Цикл
   
      Символ = Сред(Строка, Индекс, 1); // Перебираем все сиволы из нашей строки

      Если КодСимвола(Символ) >= 48 И КодСимвола(Символ) <= 57 Тогда // Код нуля - 48, код 9-ки - 57
         СтрокаЧисел = СтрокаЧисел + Символ;
      КонецЕсли;
   
   КонецЦикла;

   Возврат СтрокаЧисел;	
	
	
КонецФункции

// Проверяет мобильный или городской номер телефона
//
Функция ЭтоГородскойРФ(Строка) Экспорт
	
	Если СтрДлина(Строка) = 11 Тогда
		Возврат ?(Сред(Строка, 2, 1) = "9", Ложь, Истина);		
	Иначе
		Возврат ?(Сред(Строка, 5, 1) = "9", Ложь, Истина);
	КонецЕсли;
		
КонецФункции

