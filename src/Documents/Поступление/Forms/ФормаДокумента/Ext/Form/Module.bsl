// Процедура, обработчик события "НачалоВыбора".
//
Процедура ДокументОснованиеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДокументОснованиеЗавершениеВыбора", ЭтотОбъект);
	
	ПараметрыОтбора   = Новый Структура("ПометкаУдаления", Ложь);
	ПараметрыОткрытия = Новый Структура("Отбор", ПараметрыОтбора);  
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		
		Если ПолучитьПризнакКонтрагентЭтоЛаборатория(Объект.Контрагент) Тогда
			ОткрытьФорму("Документ.НарядЗаказ.Форма.ФормаВыбора", 
						ПараметрыОткрытия,
						ЭтотОбъект,,,,
						ОписаниеОповещения,
						РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Иначе
			ОткрытьФорму("Документ.ЗаказПоставщику.Форма.ФормаВыбора", 
						ПараметрыОткрытия,
						ЭтотОбъект,,,,
						ОписаниеОповещения,
						РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
		
	Иначе
		
		ОткрытьФорму("Документ.ЗаказПоставщику.Форма.ФормаВыбора", 
						ПараметрыОткрытия,
						ЭтотОбъект,,,,
						ОписаниеОповещения,
						РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

