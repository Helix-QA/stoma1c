
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДатаОтображения = ТекущаяДата();
	ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	Параметры.Свойство("Дата"               , ЭтотОбъект.ОтборДата);
	Параметры.Свойство("Сотрудник"          , ОтборСотрудник);
	Параметры.Свойство("ВсегдаПоказыватьЗадачиСотрудника" , ВсегдаПоказыватьЗадачиСотрудника);
	
	Если не ЗначениеЗаполнено(ОтборСотрудник) тогда
		ОтборСотрудник          = ПараметрыСеанса.ТекущийСотрудник;
	КОнецЕсли;
	
	ПереключательСтраниц 	= 1;
	Период.ДатаНачала     	= НачалоДня(ОтборДата);
	Период.ДатаОкончания    = КонецДня(ОтборДата);
	
	ОбновитьПланировщикСервер();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ПереключательПриИзменении(Элемент)
	
	Если ПереключательСтраниц = 1 Тогда
		Период.ДатаНачала = НачалоДня(Период.ДатаНачала);
		Период.ДатаОкончания = КонецДня(Период.ДатаНачала);
		Элементы.ОтборРежимПоСотруднику.Доступность = Истина;
		ОтборРежимПоСотруднику = 0;
	ИначеЕсли ПереключательСтраниц = 2 Тогда
		Период.ДатаНачала = НачалоНедели(Период.ДатаНачала);
		Период.ДатаОкончания = КонецНедели(Период.ДатаНачала);
		Элементы.ОтборРежимПоСотруднику.Доступность = Ложь;
		ОтборРежимПоСотруднику = 0;
	ИначеЕсли ПереключательСтраниц = 3 Тогда
		Период.ДатаНачала = НачалоМесяца(Период.ДатаНачала);
		Период.ДатаОкончания = КонецМесяца(Период.ДатаНачала);
		Элементы.ОтборРежимПоСотруднику.Доступность = Ложь;
		ОтборРежимПоСотруднику = 0;
	КонецЕсли;
	
	ОбновитьПланировщикСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборРежимПоСотрудникуПриИзменении(Элемент)
	
	
	
	ОбновитьПланировщикСервер();
	
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийПоляПланировщикаПлан

&НаКлиенте
Процедура ПланировщикПередСозданием(Элемент, Начало, Конец, Значения, Текст, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ДатаВремяНачала = Начало;
	Если НЕ ПереключательСтраниц = 3 Тогда
		Если ВыбраноЗначениеВесьДень(Конец, ОтборСтруктурнаяЕдиница) Тогда 
			ДатаВремяНачала = НачалоДня(ДатаВремяНачала);
		КонецЕсли;	
	КонецЕсли;	
	ЭтаФорма.Закрыть(Новый Структура("ДатаВремяНачала, ДатаВремяОкончания, Сотрудник", ДатаВремяНачала, Конец, ?(Значения <> Неопределено, Значения.Получить("Сотрудник"), Неопределено)));
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Выбрано значение весь день
//
// Параметры:
//  ПериодКонец				 - 	 - 
//  ОтборСтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВыбраноЗначениеВесьДень(ПериодКонец, Знач ОтборСтруктурнаяЕдиница)
	
	Флаг = Ложь;
	
	МаксПериодРаботы = Справочники.СтруктурныеЕдиницы.МаксимальныйИнтервалРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница);		
	Если МаксПериодРаботы <> Неопределено Тогда
		ДатаОкончания = ОбщегоНазначенияСтоматология.СложитьДатуИВремя(НачалоДня(ПериодКонец), МаксПериодРаботы.ОкончаниеРаботы);
		Если ПериодКонец > ДатаОкончания Тогда 
			Флаг = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Флаг;	
				
КонецФункции

&НаКлиенте
Процедура ПланПриАктивизации(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПланВыбор(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПланПриСменеТекущегоПериодаОтображения(Элемент, ТекущиеПериодыОтображения, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;

КонецПроцедуры

&НаКлиенте
Процедура ПланПередНачаломБыстрогоРедактирования(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если Элемент.ВыделенныеЭлементы.Количество() > 0 Тогда
		ОткрытьФорму("Задача.ЗадачаИсполнителя.ФормаОбъекта", Новый Структура("Ключ", Элемент.ВыделенныеЭлементы[0].Значение.Задача),,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	 
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПериодВперед(Команда)
	
	Если ПереключательСтраниц = 1 Тогда
		Период.ДатаНачала = НачалоДня(Период.ДатаНачала + 60*60*24);
		Период.ДатаОкончания = КонецДня(Период.ДатаНачала);
	ИначеЕсли ПереключательСтраниц = 2 Тогда
		Период.ДатаНачала = НачалоНедели(Период.ДатаНачала + 60*60*24*7);
		Период.ДатаОкончания = КонецНедели(Период.ДатаНачала);
	ИначеЕсли ПереключательСтраниц = 3 Тогда
		Период.ДатаНачала = НачалоМесяца(ДобавитьМесяц(Период.ДатаНачала, 1));
		Период.ДатаОкончания = КонецМесяца(Период.ДатаНачала);
	КонецЕсли;
		
	ОбновитьПланировщикСервер();

КонецПроцедуры

&НаКлиенте
Процедура ПериодНазад(Команда)

	
	Если ПереключательСтраниц = 1 Тогда
		Период.ДатаНачала = НачалоДня(Период.ДатаНачала - 60*60*24);
		Период.ДатаОкончания = КонецДня(Период.ДатаНачала);
	ИначеЕсли ПереключательСтраниц = 2 Тогда
		Период.ДатаНачала = НачалоНедели(Период.ДатаНачала - 60*60*24*7);
		Период.ДатаОкончания = КонецНедели(Период.ДатаНачала);
	ИначеЕсли ПереключательСтраниц = 3 Тогда
		Период.ДатаНачала = НачалоМесяца(ДобавитьМесяц(Период.ДатаНачала, -1));
		Период.ДатаОкончания = КонецМесяца(Период.ДатаНачала);
	КонецЕсли;
		
	ОбновитьПланировщикСервер();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Провести обновление заполнения плана занятий
Процедура ОбновитьПланировщикСервер()
	
	МассивЗадач     = Неопределено; 		
	МассивСотрудников = Неопределено;
	МассивИзмерений   = Неопределено;
	Массивданных      = Неопределено;

	Планировщик.ОтображатьПеренесенныеЗаголовки   			= Не ПереключательСтраниц = 3;
	Планировщик.КратностьПериодическогоВарианта   			= ?(ПереключательСтраниц = 3, 7, 1);	
	Планировщик.ШкалаВремени.Элементы[0].Видимость 			= Не ПереключательСтраниц = 3;			
	Планировщик.ШкалаВремени.Элементы[1].Видимость 			= ПереключательСтраниц = 3;
	Планировщик.ШкалаВремени.Положение            		    = ?(ПереключательСтраниц = 3, ПоложениеШкалыВремени.Верх, ПоложениеШкалыВремени.Лево);
	Планировщик.ОтображатьПеренесенныеЗаголовкиШкалыВремени = ПереключательСтраниц = 3;			
	Планировщик.ВыравниватьГраницыЭлементовПоШкалеВремени   = ПереключательСтраниц = 3;

	Планировщик.ИнтервалыФона.Очистить();
	
	МассивПериодов = Новый Массив;	
		
	Если ПереключательСтраниц = 3 Тогда		
		ДатаОкончания = Период.ДатаОкончания + (35 - День(Период.ДатаОкончания)) * 86400;
		МассивПериодов.Добавить(Новый Структура("Начало, Конец",Период.ДатаНачала, Период.ДатаОкончания));
	Иначе
		ДатаДень 			= Период.ДатаНачала;
		ДатаОкончания 		= Период.ДатаОкончания;
		МаксПериодРаботы 	= Справочники.СтруктурныеЕдиницы.МаксимальныйИнтервалРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница);		
		Пока ДатаДень < Период.ДатаОкончания Цикл
			
			ВремяРаботыСЕ = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница, ДеньНедели(ДатаДень));	
			// ДатаНачала    = ОбщегоНазначения.СложитьДатуИВремя(ДатаДень, ?(ВремяРаботыСЕ.НачалоРаботы = КонецДня(ВремяРаботыСЕ.НачалоРаботы),Дата(0001,01,01,00,00,00) ,ВремяРаботыСЕ.НачалоРаботы));
			// ДатаОкончания = ОбщегоНазначения.СложитьДатуИВремя(ДатаДень, ВремяРаботыСЕ.ОкончаниеРаботы);			
			
			Если МаксПериодРаботы <> Неопределено Тогда
				ДатаНачала 		= ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ДатаДень, ?(МаксПериодРаботы.НачалоРаботы = КонецДня(МаксПериодРаботы.НачалоРаботы), Дата(0001,01,01,00,00,00), МаксПериодРаботы.НачалоРаботы));
				ДатаОкончания 	= ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ДатаДень, МаксПериодРаботы.ОкончаниеРаботы);
			Иначе
				ДатаНачала    	= ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ДатаДень, ?(ВремяРаботыСЕ.НачалоРаботы = КонецДня(ВремяРаботыСЕ.НачалоРаботы), Дата(0001,01,01,00,00,00), ВремяРаботыСЕ.НачалоРаботы));
				ДатаОкончания 	= ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ДатаДень, ВремяРаботыСЕ.ОкончаниеРаботы);			
			КонецЕсли;
			
			Если ДатаОкончания + 3600 < КонецДня(ДатаОкончания) Тогда
				 ДатаОкончания = ДатаОкончания + 3600;
			ИначеЕсли (КонецДня(ДатаОкончания) - ДатаОкончания) > 0 Тогда
				 ДатаОкончания = ДатаОкончания + (КонецДня(ДатаОкончания) - ДатаОкончания - 59);
			КонецЕсли;
			
			МассивПериодов.Добавить(Новый Структура("Начало, Конец",ДатаНачала, ДатаОкончания));
			
			НоваяМетка = Планировщик.ШкалаВремени.Элементы[0].Метки.Добавить(ДатаОкончания - ?(Минута(ДатаОкончания) = 0,3600, Минута(ДатаОкончания) * 60));
			НоваяМетка.ЦветЛинии = Новый Цвет(164,164,164);
			НоваяМетка.Текст     = Нстр("ru = 'Весь день'; en = 'Entire day'");
			
			НовыйИнтервал = Планировщик.ИнтервалыФона.Добавить(ДатаОкончания - 3600, ДатаОкончания);
			НовыйИнтервал.Цвет = WebЦвета.ЦианСветлый;
										
			ДатаДень = ДатаДень + 86400;
		КонецЦикла; 		
	КонецЕсли;
	
	// Покрасим рабочее время.
	// Если ОтборРежимПоСотруднику = 0 Тогда
	//	Планировщик.ЦветФона = Новый Цвет(244,244,244);

	//	ДатаДень = Период.ДатаНачала;
	//	Пока ДатаДень < Период.ДатаОкончания Цикл
	//		
	//		ТаблицаИнтервалов = РегистрыСведений.ВремяРаботыСотрудниковПлан.ПолучитьИнтервалыРаботыСотрудника(ДатаДень,
	//		ОтборСотрудник,
	//		ОтборСтруктурнаяЕдиница);
	//		Для Каждого Строка из ТаблицаИнтервалов Цикл																										
	//			НовыйИнтервал = Планировщик.ИнтервалыФона.Добавить(Строка.ДатаВремяНачала, Строка.ДатаВремяОкончания);
	//			НовыйИнтервал.Цвет = WebЦвета.Белый;
	//		КонецЦикла;
	//		
	//		ДатаДень = ДатаДень + 86400;
	//		
	//	КонецЦикла;
	// Иначе
		Планировщик.ЦветФона = WebЦвета.Белый;
	// КОнецЕсли;
	
	ЗадатьЦветФонаВыходныхДней(Планировщик, Период.ДатаНачала, ДатаОкончания);
	
	МассивСотрудников = РегистрыСведений.ВремяРаботыСотрудниковПлан.СотрудникиРаботающиевУказанныйПериод(
	Период.ДатаНачала,
	Период.ДатаОкончания,
	ОтборСтруктурнаяЕдиница,,?(ОтборРежимПоСотруднику = 0,ОтборСотрудник,Неопределено));

	Если МассивСотрудников.Количество() = 0 Тогда
		Если ВсегдаПоказыватьЗадачиСотрудника Тогда 
			МассивСотрудников.Добавить(ОтборСотрудник);
		Иначе 
			МассивСотрудников.Добавить(Нстр("ru = 'Не рабочий день'; en = 'Not working day'"));
		КонецЕсли;	
	КОнецЕсли;
	
	// Заполняем массив измерений
	Если ПереключательСтраниц = 1 ИЛИ ОтборРежимПоСотруднику Тогда
		
		МассивИзмерений    = Новый Массив;
		СтруктураИзмерения = Новый Структура("Ключ,Элементы","Сотрудник",МассивСотрудников);
		МассивИзмерений.Добавить(СтруктураИзмерения);
		
	КонецЕсли;
	
	// Получаем массив даннх заполнения
	Массивданных = РасширениеПланировщикаСервер.ДанныеЗаполненияПланировщикаЗадачами(Период.ДатаНачала,
	Период.ДатаОкончания,МассивСотрудников);
			
	// Заполнение планировщика
	РасширениеПланировщикаСервер.ЗаполнениеПланировщика(Планировщик, МассивПериодов, МассивИзмерений, Массивданных);
	
КонецПроцедуры

