	ПолеКалендаря.Рамка 							= Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
	ПолеКалендаря.ГоризонтальноеПоложениеВГруппе	= ГоризонтальноеПоложениеЭлемента.Лево;
	ПолеКалендаря.ВертикальноеПоложениеВГруппе 		= ВертикальноеПоложениеЭлемента.Верх;
	ПолеКалендаря.Ширина							= 16;
	ПолеКалендаря.Высота 							= 9;
	ПолеКалендаря.АвтоМаксимальнаяШирина			= Ложь;
	ПолеКалендаря.МаксимальнаяШирина 				= 82;
	ПолеКалендаря.АвтоМаксимальнаяВысота			= Ложь;
	ПолеКалендаря.МаксимальнаяВысота 				= 9;
	ПолеКалендаря.РастягиватьПоГоризонтали			= Истина;
	ПолеКалендаря.РастягиватьПоВертикали			= Истина;
	
	ПолеКалендаря.УстановитьДействие("ПриИзменении", "ОбработчикНажатияЭлементаФильтрацииДанных");
	
	СтрокаФильтр.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра = ПолеКалендаря.Имя;
	
	СтрокаФильтр.Инициализирован 	= Истина;
	СтрокаФильтр.Актуализирован 	= Истина;
	
КонецПроцедуры

// Процедура - Обновить элементы выбора значения
//
// Параметры:
//  Форма		 - 	 - 
//  СтрокаФильтр - 	 - 
//
Процедура ОбновитьЭлементыВыбораЗначения(Форма, СтрокаФильтр)
	
	ИдентификаторФильтра 	= СтрокаФильтр.ПолучитьИдентификатор();
	
	ПолеВыбораЗначениеФильтра = Форма.Элементы.Добавить("Выбрать_ЗначениеФильтра_" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("ПолеФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра]);
	ПолеВыбораЗначениеФильтра.Вид 													= ВидПоляФормы.ПолеВвода;	
	ЗаполнитьЗначенияСвойств(ПолеВыбораЗначениеФильтра, СтрокаФильтр.ПараметрыПолеВыбора);	
	ПолеВыбораЗначениеФильтра.ПутьКДанным 											= "ТаблицаФильтров[" + Форма.ТаблицаФильтров.Индекс(СтрокаФильтр) + "].РеквизитПолеВыбора";	
	ПолеВыбораЗначениеФильтра.Заголовок 											= СтрокаФильтр.Представление;	
	ПолеВыбораЗначениеФильтра.ПоложениеЗаголовка 									= ПоложениеЗаголовкаЭлементаФормы.Нет;	
	// ПолеВыбораЗначениеФильтра.КнопкаВыпадающегоСписка 								= ?(СтрокаФильтр.ПараметрыПолеВыбора.РежимВыбораИзСписка, Истина, Ложь);			
	// ПолеВыбораЗначениеФильтра.КнопкаВыбора 											= ?(СтрокаФильтр.ПараметрыПолеВыбора.РежимВыбораИзСписка, Ложь, Истина);
	ПолеВыбораЗначениеФильтра.КнопкаОчистки 										= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаРегулирования 									= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаОткрытия 										= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаСоздания 										= Ложь;
	ПолеВыбораЗначениеФильтра.ИсторияВыбораПриВводе 								= ИсторияВыбораПриВводе.НеИспользовать;
	Если СтрокаФильтр.ПараметрыПолеВыбора.РежимВыбораИзСписка И НЕ СтрокаФильтр.ПараметрыПолеВыбора.СписокВыбора = Неопределено Тогда
		Если ТипЗнч(СтрокаФильтр.ПараметрыПолеВыбора.СписокВыбора) = Тип("СписокЗначений") Тогда 
			ПолеВыбораЗначениеФильтра.СписокВыбора = СтрокаФильтр.ПараметрыПолеВыбора.СписокВыбора;
		ИначеЕсли ТипЗнч(СтрокаФильтр.ПараметрыПолеВыбора.СписокВыбора) = Тип("Массив") Тогда
			ПолеВыбораЗначениеФильтра.СписокВыбора.Загрузить(СтрокаФильтр.ПараметрыПолеВыбора.СписокВыбора);
		КонецЕсли;
	ИначеЕсли СтрокаФильтр.СписокЗначений.Количество() <> 0	Тогда 
		Для Каждого ЭлементСпискаВыбора Из СтрокаФильтр.СписокЗначений Цикл
			Если ПолеВыбораЗначениеФильтра.СписокВыбора.НайтиПоЗначению(ЭлементСпискаВыбора.Значение.ЗначениеФильтра) = Неопределено Тогда 
				ПолеВыбораЗначениеФильтра.СписокВыбора.Добавить(ЭлементСпискаВыбора.Значение.ЗначениеФильтра, ЭлементСпискаВыбора.Представление);
			КонецЕсли;	
		КонецЦикла;
	КонецЕсли;	
	ПолеВыбораЗначениеФильтра.РастягиватьПоГоризонтали 								= Истина;
	ПолеВыбораЗначениеФильтра.ЦветФона 												= Новый Цвет(250, 250, 250);
	// ПолеВыбораЗначениеФильтра.Шрифт 												= Новый Шрифт("Arial", 11);
	ПолеВыбораЗначениеФильтра.ГоризонтальноеПоложениеВГруппе 						= ГоризонтальноеПоложениеЭлемента.Лево;
	ПолеВыбораЗначениеФильтра.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Верх;
	
	ПолеВыбораЗначениеФильтра.ОграничениеТипа 	= СтрокаФильтр.ОписаниеТипаЗначения;
	// СтрокаФильтр.РеквизитПолеВыбора = СтрокаФильтр.ОписаниеТипаЗначения.ПривестиЗначение();
	
	ПолеВыбораЗначениеФильтра.УстановитьДействие("ОбработкаВыбора"					, "ОбработчикНажатияЭлементаФильтрацииДанных");
	
	// ЭлементСпискаЗначенияФильтра.Значение.ИмяКнопкиЗначенияФильтра 				= КнопкаЗначениеФильтра.Имя;
	
	ДекорацияРазделитель = Форма.Элементы.Добавить("ДекорацияРазделитель_ЗначениеФильтра_" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("ДекорацияФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра]);
	ДекорацияРазделитель.Вид 														= ВидДекорацииФормы.Надпись;
	ДекорацияРазделитель.Заголовок                  								= "";
	ДекорацияРазделитель.Гиперссылка 												= Ложь;
	ДекорацияРазделитель.ЦветТекста 												= Новый Цвет(255, 255, 255);
	// ДекорацияРазделитель.Ширина 													= 1;
	ДекорацияРазделитель.Шрифт 														= Новый Шрифт("Arial", 1);
	ДекорацияРазделитель.РастягиватьПоГоризонтали 									= Ложь;
	ДекорацияРазделитель.РастягиватьПоВертикали 									= Ложь;
	ДекорацияРазделитель.ГоризонтальноеПоложениеВГруппе 							= ГоризонтальноеПоложениеЭлемента.Лево;	
	ДекорацияРазделитель.ГоризонтальноеПоложение 									= ГоризонтальноеПоложениеЭлемента.Лево;
	ДекорацияРазделитель.ВертикальноеПоложениеВГруппе 								= ВертикальноеПоложениеЭлемента.Верх;
	ДекорацияРазделитель.ВертикальноеПоложение 										= ВертикальноеПоложениеЭлемента.Верх;
	
КонецПроцедуры

// Процедура - Обновить элементы выбора диапазона числовых значений
//
// Параметры:
//  Форма		 - 	 - 
//  СтрокаФильтр - 	 - 
//
Процедура ОбновитьЭлементыВыбораДиапазонаЧисловыхЗначений(Форма, СтрокаФильтр)
	
	ИдентификаторФильтра 	= СтрокаФильтр.ПолучитьИдентификатор();
	
	ПолеВыбораЗначениеФильтра = Форма.Элементы.Добавить("Выбрать_ЗначениеФильтра_НачалоДиапазона" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("ПолеФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра]);
	ПолеВыбораЗначениеФильтра.Вид 													= ВидПоляФормы.ПолеВвода;	
