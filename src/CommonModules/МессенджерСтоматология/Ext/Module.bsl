#Область Обработчики_Instagram

// Функция, отправляет сообщение клиенту.
//
Функция ОтправитьСообщениеКлиентуInstagram(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона = Неопределено, ИдКанала = "")
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВыполненоУспешно", Ложь);
	СтруктураВозврата.Вставить("ОписаниеОшибки"  , "");
	СтруктураВозврата.Вставить("ИдСообщения"     , "");
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы)
		ИЛИ ТипЗнч(ПараметрыВнешнейСистемы) <> Тип("Структура")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("ApiToken")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("ИдОператора")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("UrlApi") Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не заполнены параметры внешней системы."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Клиент) Тогда		
		ПараметрыКлиента = ПолучитьПараметрыОбъектаИдентификации(Клиент, ВнешняяСистема);
	Иначе
		ПараметрыКлиента = Неопределено;		
	КонецЕсли;
	
	Если ПараметрыКлиента = Неопределено Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не найден контакт мессенджера."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	РезультатОперации = Instagram_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы);
	
	// Если сообщение отправлено.
	Если РезультатОперации.ВыполненоУспешно Тогда
		
		СтруктураВозврата.ВыполненоУспешно = Истина;
		СтруктураВозврата.ИдСообщения      = РезультатОперации.ИдСообщения;
		
		// Добавляем отправленное сообщенте в регистр.
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
			ПараметрыКлиента.ИдКлиента,
			РезультатОперации.ИдСообщения,,
			РезультатОперации.ИдКанала,
			ТекстСообщения,
			Истина,
			Перечисления.Мессенджеры.instagram,
			Ложь,
			ТекущаяДатаСеанса(),
			ВнешняяСистема,
			//// ПараметрыКлиента.ОператорСообщения
		);
		
		// Оповещаем сотрудников о новом отправленном сообщении.
		ОповеститьСотрудниковОНовомСообщении(РезультатОперации.ИдСообщения,, ПараметрыКлиента.ИдКлиента,, ВнешняяСистема);		
	
	ИначеЕсли РезультатОперации.Свойство("ОписаниеОшибки") Тогда // Если есть расшифровка ошибки, то вернем ее
		СтруктураВозврата.ОписаниеОшибки = РезультатОперации.ОписаниеОшибки;
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке.";
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция, получает данные клиента в Instagram.
//
Функция ПолучитьДанныеКлиента_Instagram(Идентификатор, ПараметрыВнешнейСистемы) Экспорт
	
	HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	HTTPЗапрос = Новый HTTPЗапрос("/v11.0/" + Идентификатор + "?access_token=" + ПараметрыВнешнейСистемы.ApiToken);
	
	Попытка
		Ответ = HTTPСоединение.Получить(HTTPЗапрос);
		
		СтруктураОтвета = ДекодироватьИзJSON((Ответ.ПолучитьТелоКакСтроку()));
		
		Если СтруктураОтвета.Свойство("error") Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		ПозицияРазделителяИмени = СтрНайти(СтруктураОтвета.name, " ");
		
		Если ПозицияРазделителяИмени Тогда
			Имя		= Лев(СтруктураОтвета.name, ПозицияРазделителяИмени - 1);
			Фамилия	= Сред(СтруктураОтвета.name, ПозицияРазделителяИмени + 1);
		Иначе
			Имя		= СтруктураОтвета.name;
			Фамилия = "";
		КонецЕсли;
		
		ДанныеКлиента = Новый Структура;
		ДанныеКлиента.Вставить("Имя"	, Имя);
		ДанныеКлиента.Вставить("Фамилия", Фамилия);
		ДанныеКлиента.Вставить("Фото"	, СтруктураОтвета.profile_pic);
		
		Возврат ДанныеКлиента;
		
	Исключение
		Возврат Неопределено;
		
	КонецПопытки;
	
КонецФункции

