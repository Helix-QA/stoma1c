// Процедура - Обработка получения полей представления
//
// Параметры:
//  Поля				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Поля.Добавить("Номер");
	Поля.Добавить("Ссылка");
	Поля.Добавить("Выполнена");
	Поля.Добавить("Наименование");
	//Поля.Добавить("РегламентнаяЗадача");		
	Поля.Добавить("ПометкаУдаления");	
	
КонецПроцедуры

// Процедура - Обработка получения представления
//
// Параметры:
//  Данные				 - 	 - 
//  Представление		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если Данные.Номер = Null ИЛИ НЕ ЗначениеЗаполнено(Данные.Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Состояние = "";
	Если Данные.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удалена)'; en='(deleted)'");
	ИначеЕсли Данные.Выполнена Тогда 
		Состояние = НСтр("ru='(выполнена)'; en='(done)'");
	Иначе 
		Состояние = НСтр("ru='(не выполнена)'; en='(not done)'");
	КонецЕсли;
	
	Представление = ?(ЗначениеЗаполнено(Данные.Наименование), СокрЛП(Строка(Данные.Наименование)), НСтр("ru = '< Наименование задачи >'; en = '< Name task >'")) + " " + Состояние;
	
	
КонецПроцедуры

#КонецОбласти

