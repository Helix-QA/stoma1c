// Функция, возвращает представление даты.
//
Функция ПолучитьПредставлениеДаты(Дата)
	
	Если Не ЗначениеЗаполнено(Дата) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Если НачалоДня(Дата) = НачалоДня(ТекущаяДата) Тогда
		// Сегодня - показываем время.
		Возврат Формат(Дата, "ДФ=''' сегодня в ''ЧЧ:мм'");
		
	ИначеЕсли НачалоГода(Дата) = НачалоГода(ТекущаяДата) Тогда
		// В этом году - не показывам год.
		Возврат Формат(Дата, "ДФ=' от d MMMM'")
		
	Иначе
		Возврат Формат(Дата, "ДФ=' от d MMMM yyyy'")
		
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает данные блока сделки (представление и родительский блок).
//
Функция ПолучитьДанныеБлокаСделки(Сделка, СтруктураОтбора, ПараметрыПолученияСделкиИзОчереди = Неопределено)
	
	ДанныеСделки = ПолучитьДанныеСделки(СтруктураОтбора, Сделка);
	
	Если Не ЗначениеЗаполнено(ДанныеСделки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеКоличества		 = ПолучитьКоличествоСделокВКолонках(СтруктураОтбора);
	ДанныеВыводимойСделки	 = ПолучитьДанныеВыводимойСделки(СтруктураОтбора, ПараметрыПолученияСделкиИзОчереди);
	
	Результат = Новый Структура;
	Результат.Вставить("БлокСделки"				, ПолучитьБлокСделки(ДанныеСделки));
	Результат.Вставить("ПредставлениеКолонки"	, XMLСтрока(ДанныеСделки.ЭтапСделки));
	Результат.Вставить("ДанныеКоличества"		, ДанныеКоличества);
	Результат.Вставить("ДанныеВыводимойСделки"	, ДанныеВыводимойСделки);
	
	Возврат Результат
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает количество сделок в каждой колонке канбана.
//
Функция ПолучитьКоличествоСделокВКолонках(Знач СтруктураОтборов)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	КОЛИЧЕСТВО(Сделки.Ссылка) КАК КоличествоСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|		ПО Сделки.Ссылка = СделкиСведенияДляСписка.Сделка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Сделки.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|	И ВЫБОР
	|			КОГДА &СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КонтрагентыСведенияДляСписка.Статус = &СтатусПациента
	|		КОНЕЦ
	|	И &ОтборПоСсылке
	|	И &УсловиеПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеМенеджер
	|	И &УсловиеВрач
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаЗавершенияСделки
	|	И &УсловиеДатаЗапланированнойЗадачи
	|	И &УсловиеОтборБезНазначенногоПриема
	|	И &УсловиеОтборБезЗадач
	|	И &УсловиеЭтап
	|	И &УсловиеЗавершена
	|	И &УсловиеПричинаОтказа
	|	И &УсловиеИсключаемыеСделки
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.ЭтапСделки");
	
	ПрименитьУсловияФильтрации(Запрос, СтруктураОтборов);
	
	Результат = Новый Соответствие;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(XMLСтрока(Выборка.ЭтапСделки), Выборка.КоличествоСделок);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

