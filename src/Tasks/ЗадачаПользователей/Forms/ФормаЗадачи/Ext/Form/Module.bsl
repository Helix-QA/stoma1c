#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Обработка нажатия по гиперссылке предмет задачи
Процедура ПредметНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПоказатьЗначение(,Объект.ЗадачаПредмет);
	
КонецПроцедуры

&НаКлиенте
// Обработчик записи и закрытия формы
Процедура ЗаписатьИЗакрыть(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		Записать();
		Закрыть(Истина);		
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик выполнения задачи
Процедура ВыполнитьЗадачу(Команда)
		
	Объект.ДатаИсполнения = ТекущаяДата();
	Объект.Выполнена      = Истина;
	
    ЗаписатьИЗакрыть(Неопределено);
	ОповеститьОбИзменении(ПредопределенноеЗначение("Задача.ЗадачаПользователей.ПустаяСсылка"));
	ОповеститьОбИзменении(ПредопределенноеЗначение("Документ.Взаимодействие.ПустаяСсылка"));
	Оповестить("ЗадачаПользователя",Объект.Ссылка);
	Оповестить("ИзменениеСпискаВзаимодействий");

КонецПроцедуры

&НаКлиенте
// Обработчик прекращения напоминания
Процедура Прекратить(Команда)
	
	Объект.НапоминаниеИспользовать = Ложь;
    ЗаписатьИЗакрыть(Неопределено);

	ОповеститьОбИзменении(Объект.Ссылка);
	Оповестить("ЗадачаПользователя",Объект.Ссылка);

КонецПроцедуры

&НаКлиенте
// При изменении даты напоминания
Процедура ДатаНапоминанияПриИзменении(Элемент)
	
	// Перезаполнить список выбора времени напоминания 
	МассивПериодов                 = Новый Массив;
	СтруктураВремени               = ОбщегоНазначенияСтоматология.ПолучитьВремяРаботыСтруктурнойЕдиницы(Объект.НапоминаниеДатаНачала, Объект.СтруктурнаяЕдиница);
	СтруктураВремени.ДатаНачала    = ?(ЗначениеЗаполнено(СтруктураВремени.ДатаНачала),СтруктураВремени.ДатаНачала,Дата("00010101080000"));
	СтруктураВремени.ДатаОкончания = ?(ЗначениеЗаполнено(СтруктураВремени.ДатаОкончания),СтруктураВремени.ДатаОкончания,Дата("00010101220000"));
	
	МассивПериодов.Добавить(СтруктураВремени);	
	СписокВеремени = РаботаСДиалогами.ВернутьСписокВремени(МассивПериодов, Истина);	
	
	Элементы.ВремяНапоминания.СписокВыбора.Очистить();
	Для Каждого Элемент ИЗ СписокВеремени Цикл	
		
	     Элементы.ВремяНапоминания.СписокВыбора.Добавить(Элемент.Значение,Элемент.Представление);
		 
	КонецЦикла;

КонецПроцедуры

&НаСервере
// Заполнить список выбора режима напоминания
Процедура ЗаполнитьСписокВыбораРежимаНапоминания(ЗаполнитьПоУмолчанию = Истина)
	
	Элементы.РежимНапоминания.СписокВыбора.Очистить();
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,-1),"Не напоминать");
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЗаВремяОтносительноСобытия,0),"Относительно срока");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ВУказанноеВремя,0),"В указанное время");
	
	Если Объект.ЗадачаПредмет <> Неопределено И ТипЗнч(Объект.ЗадачаПредмет)=Тип("СправочникСсылка.Контрагенты") Тогда
		
		Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ПоСобытию,0),"По посещению клиента");
		
	КонецЕсли;
	
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,300),"через 5 минут");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,600),"через 10 минут");
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,900),"через 15 минут");
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,1200),"через 30 минут");     
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,3600),"через 1 час");
	Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,7200),"через 2 часа");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,14400),"через 4 часа");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,28800),"через 8 часов");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,86400),"через 1 день");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,172800),"через 2 дня");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,259200),"через 3 дня");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,604800),"через 1 неделю");
    Элементы.РежимНапоминания.СписокВыбора.Добавить(Новый Структура("Режим,Интервал",Перечисления.ВариантыНапоминаний.ЧерезУказанноеВремя,1209600),"через 2 недели");

	
	// Если Объект.НапоминаниеИспользовать = Истина Тогда  
	//	РежимНапоминания = -1;
	// КонецЕсли;
	//
	
	
	// Проверка существования значения режима в списке
	Если Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия") Тогда 

		Интервал = Объект.ЗадачаНазначеннаяДатаВыполнения - Объект.НапоминаниеДатаНачала;
		Если элементы.ИнтервалДоНапоминания.СписокВыбора.НайтиПоЗначению(Интервал) = Неопределено Тогда
			       
		     ИнтервалМин = Цел( Интервал / 60);
			 Элементы.ИнтервалДоНапоминания.СписокВыбора.Добавить(Интервал, Строка(ИнтервалМин)+" минут");

	    КонецЕсли;
		
	 // Если указаное время напоминания не существует в списке, добавить это время в список выбора
	 ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ВУказанноеВремя") Тогда
		 
		 Если Элементы.ВремяНапоминания.СписокВыбора.НайтиПоЗначению(Объект.НапоминаниеДатаНачала) = Неопределено Тогда
			 
			  Элементы.ВремяНапоминания.СписокВыбора.Добавить(Объект.НапоминаниеДатаНачала,Формат(Объект.НапоминаниеДатаНачала,"ДФ=ЧЧ:мм"));
			  Элементы.ВремяНапоминания.СписокВыбора.СортироватьПоЗначению();
		 
		 КонецЕсли;	 
		  
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработка изменения режима напоминания
Процедура РежимНапоминанияПриИзменении(Элемент)
	
	Объект.НапоминаниеРежим = РежимНапоминания.Режим;
	
	Если Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЗаВремяОтносительноСобытия") Тогда
		
		Элементы.ИнтервалДоНапоминания.Видимость = Истина;
		Элементы.ДатаНапоминания.Видимость       = Ложь;
		Элементы.ВремяНапоминания.Видимость      = Ложь;
			
	ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ВУказанноеВремя") Тогда 	
		
	    Элементы.ИнтервалДоНапоминания.Видимость = Ложь;
		Элементы.ДатаНапоминания.Видимость       = Истина;
		Элементы.ВремяНапоминания.Видимость      = Истина;
						
		Объект.НапоминаниеДатаНачала = ТекущаяДата();
		
	ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ПоСобытию") Тогда 
		
		Элементы.ИнтервалДоНапоминания.Видимость = Ложь;
		Элементы.ВремяНапоминания.Видимость      = Ложь;
		Элементы.ДатаНапоминания.Видимость       = Ложь;
		
	    Объект.НапоминаниеДатаНачала = Дата(0001,01,01,0,0,0);
		
    ИначеЕсли Объект.НапоминаниеРежим = ПредопределенноеЗначение("Перечисление.ВариантыНапоминаний.ЧерезУказанноеВремя") Тогда 
		
		Элементы.ИнтервалДоНапоминания.Видимость = Ложь;
		Элементы.ВремяНапоминания.Видимость      = Ложь;
		Элементы.ДатаНапоминания.Видимость       = Ложь;
		
		объект.НапоминаниеДатаНачала = Объект.Дата+ РежимНапоминания.Интервал; 
			
    КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик выбора исполнителя
Процедура ИсполнительНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Оповещение = Новый ОписаниеОповещения("ИсполнительНачалоВыбораЗавершение", ЭтотОбъект);
	ОткрытьФорму("Задача.ЗадачаПользователей.Форма.ФормаВыбораИсполнителя",
	Новый Структура("Ключ",Объект.Исполнитель),,,,,
	Оповещение, 
	РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры                 

&НаКлиенте
// Процедура - После открытия формы выбора исполнителя
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ИсполнительНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		Объект.Исполнитель = ?(Результат <> Неопределено,Результат,Объект.Исполнитель);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик изменения флага разрешения обработки напоминания
Процедура НапоминатьПриИзменении(Элемент)
	
	Элементы.ГруппаПараметрыНапоминания.Доступность = Объект.НапоминаниеИспользовать;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

#КонецОбласти

