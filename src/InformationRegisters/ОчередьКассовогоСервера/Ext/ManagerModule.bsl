// Функция - Получить документ для оплаты из очереди
// Доработка Юля
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВсеНеОплаченныеДокументИзОчередиДляТекущегоСеанса(ДатаНачалаОтбора = Неопределено, Организация = Неопределено, Касса = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВсеСеансы           = ПолучитьСеансыИнформационнойБазы();
	НомераВсехСеансовИБ = Новый Массив;
	
	Для Каждого Сеанс ИЗ ВсеСеансы Цикл
		НомераВсехСеансовИБ.Добавить(Сеанс.НомерСеанса);
	КонецЦикла;
	
	НомерТекущегоСеансаИБ = НомерСеансаИнформационнойБазы();	

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ОчередьКассовогоСервера.ДокументОплаты КАК ДокументОплаты
	|ИЗ
	|	РегистрСведений.ОчередьКассовогоСервера КАК ОчередьКассовогоСервера
	|ГДЕ
	|	ОчередьКассовогоСервера.НомерФискальногоЧека = 0
	|	И ВЫБОР
	|			КОГДА &ДатаНачалаОтбора <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ОчередьКассовогоСервера.ДатаПоступления >= &ДатаНачалаОтбора
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ОчередьКассовогоСервера.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПробитияЧекаКассовымСервером.Ожидание)
	|	И ВЫБОР
	|			КОГДА &ОрганизацияОтбор = НЕОПРЕДЕЛЕНО
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ОчередьКассовогоСервера.ДокументОплаты.Организация = &ОрганизацияОтбор
	|		КОНЕЦ
	|	И &УсловиеКасса
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОчередьКассовогоСервера.ДокументОплаты
	|ИЗ
	|	РегистрСведений.ОчередьКассовогоСервера КАК ОчередьКассовогоСервера
	|ГДЕ
	|	ОчередьКассовогоСервера.НомерФискальногоЧека = 0
	|	И ВЫБОР
	|			КОГДА &ДатаНачалаОтбора <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ОчередьКассовогоСервера.ДатаПоступления >= &ДатаНачалаОтбора
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И (ОчередьКассовогоСервера.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПробитияЧекаКассовымСервером.Пробивается)
	|			ИЛИ ОчередьКассовогоСервера.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПробитияЧекаКассовымСервером.Ошибка))
	|	И ОчередьКассовогоСервера.НомерСеансаИБ = &НомерТекущегоСеансаИБ
	|	И ВЫБОР
	|			КОГДА &ОрганизацияОтбор = НЕОПРЕДЕЛЕНО
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ОчередьКассовогоСервера.ДокументОплаты.Организация = &ОрганизацияОтбор
	|		КОНЕЦ
	|	И &УсловиеКасса
	|	И ОчередьКассовогоСервера.КоличествоПопыток < 4
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОчередьКассовогоСервера.ДокументОплаты
	|ИЗ
	|	РегистрСведений.ОчередьКассовогоСервера КАК ОчередьКассовогоСервера
	|ГДЕ
	|	ОчередьКассовогоСервера.НомерФискальногоЧека = 0
	|	И ВЫБОР
	|			КОГДА &ДатаНачалаОтбора <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ОчередьКассовогоСервера.ДатаПоступления >= &ДатаНачалаОтбора
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И (ОчередьКассовогоСервера.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПробитияЧекаКассовымСервером.Пробивается)
	|			ИЛИ ОчередьКассовогоСервера.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПробитияЧекаКассовымСервером.Ошибка))
	|	И НЕ ОчередьКассовогоСервера.НомерСеансаИБ = &НомерТекущегоСеансаИБ
	|	И НЕ ОчередьКассовогоСервера.НомерСеансаИБ В (&НомераВсехСеансовИБ)
	|	И ВЫБОР
	|			КОГДА &ОрганизацияОтбор = НЕОПРЕДЕЛЕНО
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ОчередьКассовогоСервера.ДокументОплаты.Организация = &ОрганизацияОтбор
	|		КОНЕЦ
	|	И &УсловиеКасса
	|	И ОчередьКассовогоСервера.КоличествоПопыток < 4
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументОплаты");
	
	УсловиеКасса = 
	"И ОчередьКассовогоСервера.ДокументОплаты.Касса = &КассаОтбор";	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеКасса", ?(ЗначениеЗаполнено(Касса), УсловиеКасса, ""));	
	
	Запрос.УстановитьПараметр("ДатаНачалаОтбора"     , ?(ЗначениеЗаполнено(ДатаНачалаОтбора), ДатаНачалаОтбора, Неопределено));
	Запрос.УстановитьПараметр("НомерТекущегоСеансаИБ", НомерТекущегоСеансаИБ); 
	Запрос.УстановитьПараметр("НомераВсехСеансовИБ"  , НомераВсехСеансовИБ); 
	Запрос.УстановитьПараметр("ОрганизацияОтбор"     , Организация);
	Запрос.УстановитьПараметр("КассаОтбор"           , Касса);
	                                               
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументОплаты");
	
КонецФункции

