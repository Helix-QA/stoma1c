			УсловиеОтборБезЗадач = СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)";	
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", "ИСТИНА");
	КонецЕсли;
		
	// Отбор без сделок.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСделка)
		И СтруктураОтборов.ОтборСделка[0].Значение = Ложь Тогда
		
		УсловиеОтборБезСделок = СтруктураОтборов.ОтборСделка.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.ТекущаяСделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезСделок", УсловиеОтборБезСделок);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезСделок", "ИСТИНА");
	КонецЕсли;
		
	// Отбор этап сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.ТекущийЭтапСделки В (&ОтборЭтап)");		
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");		
	КонецЕсли;
			
	Возврат Запрос;
	
КонецФункции	

&НаСервереБезКонтекста
// Функция, возвращает пакет запроса с элементами для создания отборов.
//
Функция ПолучитьПакетЗапросаЗначенийДляОтборов(ТекущийПользователь)
	
	МассивСтруктурныхЕдиниц 	= Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ТекущийПользователь, "Массив");		
	МассивВидовСделок 			= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиниц);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивВидовСделок"	, МассивВидовСделок);
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ТекущийПользователь"	, ПараметрыСеанса.ТекущийСотрудник);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И Сотрудники.Служебный = ЛОЖЬ
	|	И (Сотрудники.Ссылка = &ТекущийПользователь
	|			ИЛИ Сотрудники.Роль В (ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура), ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Управляющий)))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РекламныеИсточники.Ссылка КАК Ссылка,
	|	РекламныеИсточники.Представление КАК Представление
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.Ссылка <> ЗНАЧЕНИЕ(Справочник.РекламныеИсточники.ПустаяСсылка)
	|	И РекламныеИсточники.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.Представление КАК Представление
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	|	И ЭтапыСделок.ВидСделки В(&МассивВидовСделок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Теги.Ссылка КАК Ссылка,
	|	Теги.Представление КАК Представление
	|ИЗ
	|	Справочник.Теги КАК Теги
	|ГДЕ
	|	НЕ Теги.ПометкаУдаления
	|	И Теги.Ссылка <> ЗНАЧЕНИЕ(Справочник.Теги.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница) КАК Представление
	|ИЗ
	|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиДоступныеСтруктурныеЕдиницы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК Сотрудники
	|		ПО СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = Сотрудники.СтруктурнаяЕдиница
	|			И СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = Сотрудники.Сотрудник
	|ГДЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = &ТекущийПользователь
	|	И ВЫБОР
	|			КОГДА ЕСТЬNULL(Сотрудники.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) = ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Сотрудники.ДатаУвольнения > &ТекущаяДата
	|		КОНЕЦ
	|	И СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
	|	И СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ЭтоГруппа = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РекламныеИсточники.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.ПометкаУдаления = ЛОЖЬ";
	
	Возврат Запрос.ВыполнитьПакет();
		        	
КонецФункции


#КонецОбласти

