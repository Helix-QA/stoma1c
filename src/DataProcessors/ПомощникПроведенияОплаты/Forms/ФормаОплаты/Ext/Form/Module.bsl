// Процедура - проверяет таблицу задолженности.
//   
Функция ТаблицаЗадолженностейИзменена()
	
	Флаг = Ложь;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
		
		// В зависимости от типа операции получаем исходные данные
		Если ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа Тогда
			
			Если ЭтоВзносАванса = Истина Тогда
				ЗапросПоЗадолженности = ПолучитьИсточникДанныхВзносАвансаДляТаблицыЗадолженностей();
			Иначе
			    ЗапросПоЗадолженности = ПолучитьИсточникДанныхПоПродажамДляТаблицыЗадолженностей();
			КонецЕсли;

		ИначеЕсли ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Возврат Тогда
			ЗапросПоЗадолженности = ПолучитьИсточникДанныхПоВозвратамДляТаблицыЗадолженностей();
		КонецЕсли;
		
		ТаблицаЗадолженностейОбновленная = ЗапросПоЗадолженности.Выгрузить();
		
		МассивВыбранныхЗадолженностей = ТаблицаЗадолженностей.НайтиСтроки(Новый Структура("ПризнакВыбора", Истина));
		Для Каждого ЭлементМ Из МассивВыбранныхЗадолженностей Цикл 
			МассивВрем = ТаблицаЗадолженностейОбновленная.НайтиСтроки(Новый Структура("ДокументЗадолженности", ЭлементМ.ДокументЗадолженности));
			Если МассивВрем.Количество() = 0 Тогда
				Флаг = Истина;
				Прервать;
			КонецЕсли;
			СуммаЗадолженности = 0;
			Для Каждого ЭлементМВрем Из МассивВрем Цикл
				СуммаЗадолженности = СуммаЗадолженности + ЭлементМВрем.Задолженность;
			КонецЦикла;
			Если СуммаЗадолженности <> ЭлементМ.Задолженность Тогда
				Флаг = Истина;
				Прервать;
			КонецЕсли;				
		КонецЦикла;		

	КонецЕсли;	 	
	
	Возврат Флаг;
	
КонецФункции     

