		Стр.Код = "112";
		Стр.КодАльфа2 = "BY";
		Стр.КодАльфа3 = "BLR";
		Стр.НаименованиеПолное = "Республика Беларусь";
		// Стр.ТелефонныйКод = "+375";
		// Стр.ВалютаУчета = Справочники.Валюты.НайтиПоКоду(974);
		Стр.Записать();
	КонецЕсли;	
	
	Стр = Справочники.СтраныМира.НайтиПоНаименованию("КАЗАХСТАН");
	Если Стр.Пустая() Тогда
		Стр = Справочники.СтраныМира.СоздатьЭлемент();
		Стр.Наименование = "КАЗАХСТАН";
		Стр.Код = "398";
		Стр.КодАльфа2 = "KZ";
		Стр.КодАльфа3 = "KAZ";
		Стр.НаименованиеПолное = "Республика Казахстан";
		// Стр.ТелефонныйКод = "+7";
		// Стр.ВалютаУчета = Справочники.Валюты.НайтиПоКоду(398);
		Стр.Записать();
