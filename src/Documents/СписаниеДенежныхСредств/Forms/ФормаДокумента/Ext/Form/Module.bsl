// Функция - Контрагент это клиент
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьТипыКонтрагентовПоВидуОперации(ВидОперации, ТипДенежныхСредств)
	
	Массив = Новый Массив;
	
	Если ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика 
		Или ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику Тогда
		
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.Поставщик);
		 
	ИначеЕсли ВидОперации = Перечисления.ВидыОпераций.ВозвратЗайма Тогда
		
    	 Массив.Добавить(Перечисления.ТипыКонтрагентов.Поставщик);
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.Клиенты);
		 Массив.Добавить(Перечисления.ТипыКонтрагентов.КорпоративныеКонтрагенты);

	Иначе
		
		Массив.Добавить(Перечисления.ТипыКонтрагентов.Клиенты);
		
	КонецЕсли;
	
	Возврат Массив;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик команды ДобавитьИВыбратьКонтрагента
//
Процедура ДобавитьИВыбратьКонтрагента(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ГруппаКлиентов    = ВернутьГруппуКлиентов();  
	ПараметрыОткрытия.Вставить("Родитель", ГруппаКлиентов);
	ПараметрыОткрытия.Вставить("ТекстЗаполнения", ИскомыйКлиент);  
	ПараметрыЗаполнения = Новый Структура("Основание", ПараметрыОткрытия);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьИВыбратьКонтрагентаЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", ПараметрыЗаполнения,,,,,ОписаниеОповещения);
	
КонецПроцедуры 

