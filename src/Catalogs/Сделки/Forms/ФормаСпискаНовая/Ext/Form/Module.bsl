&НаКлиенте
// Процедура, заполняет процентом строки табличной части.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ЗаполнитьПроцентомСтрокиТЗ()
	
	Элементы.ОстаточныйПроцент.Видимость = Ложь;
	
	КолвоЭлементов = ЭтотОбъект.ТаблицаДействия.Количество();
	ЭтотОбъект.ОстаточныйПроцентОтДеления = 0;
	Если КолвоЭлементов > 0 Тогда
		
		Процентов  		   = Цел(100/КолвоЭлементов);
		НедостающийПроцент = 100 - (Процентов*КолвоЭлементов);
		
		Для Каждого СтрокаТЗ Из ЭтотОбъект.ТаблицаДействия Цикл
			СтрокаТЗ.Пропорция = Процентов;
		КонецЦикла;
		
		ЭтотОбъект.ОстаточныйПроцентОтДеления = НедостающийПроцент;
		Элементы.ОстаточныйПроцент.Видимость  = НедостающийПроцент > 0;
		Элементы.ГруппаПрименитьОбщая.Доступность = НедостающийПроцент = 0;
		
	Иначе
		Элементы.ГруппаПрименитьОбщая.Доступность = Ложь;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик команды на сервере "Применить".
//
Процедура ПрименитьНаСервере(ДопПараметры)
	
	Если ЗначениеЗаполнено(ДопПараметры) Тогда
		
		ТЗДинамическогоСписка = Новый ТаблицаЗначений();
		ТЗДинамическогоСписка.Колонки.Добавить("Сделка");
		ТЗДинамическогоСписка.Колонки.Добавить("Контрагент");
		ТЗДинамическогоСписка.Колонки.Добавить("ДатаСделки");
		ТЗДинамическогоСписка.Колонки.Добавить("Менеджер");
		ТЗДинамическогоСписка.Колонки.Добавить("ЗапланированнаяЗадача");
		
		ВыделенныеСтроки = Элементы.Список.ВыделенныеСтроки;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СделкиСведенияДляСписка.Сделка КАК Сделка,
		|	СделкиСведенияДляСписка.ЗапланированнаяЗадача КАК ЗапланированнаяЗадача
		|ИЗ
		|	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
		|ГДЕ
		|	СделкиСведенияДляСписка.Сделка В(&МассивСделок)";
		Запрос.УстановитьПараметр("МассивСделок", ВыделенныеСтроки);
		ТЗЗадачСделок = Запрос.Выполнить().Выгрузить();
			
		Для Каждого ЭлементМассива Из ВыделенныеСтроки Цикл
						
			НоваяСтрока = ТЗДинамическогоСписка.Добавить();
			НоваяСтрока.Сделка		 = ЭлементМассива;
			НоваяСтрока.Контрагент	 = ЭлементМассива.Контрагент;
			НоваяСтрока.ДатаСделки	 = ЭлементМассива.ДатаСделки;
			НоваяСтрока.Менеджер	 = ЭлементМассива.Менеджер;
			
			СтрокаТЗ = ТЗЗадачСделок.Найти(ЭлементМассива, "Сделка");
			Если СтрокаТЗ <> Неопределено
				И ЗначениеЗаполнено(СтрокаТЗ.ЗапланированнаяЗадача) Тогда
				
				НоваяСтрока.ЗапланированнаяЗадача = СтрокаТЗ.ЗапланированнаяЗадача;
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		ТЗДинамическогоСписка = ПолучитьТаблицуЗначенийДинамическогоСписка();
	КонецЕсли;

	УстановитьФокусЭлементаСервер();
	
	Если ЭтотОбъект.Действие = "Менеджера" Тогда
		
		МенеджерыРаспределитьВПропорции(ТЗДинамическогоСписка);
		
	ИначеЕсли ЭтотОбъект.Действие = "КаналПривлечения" Тогда
		
		Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
			
			ОбъектСделка 				  = СтрокаТЗ.Сделка.ПолучитьОбъект();
			ОбъектСделка.КаналПривлечения = ЭтотОбъект.ЗначениеДействия;
			ОбъектСделка.Записать();
			
		КонецЦикла;
		
	ИначеЕсли ЭтотОбъект.Действие = "РекламныйИсточник" Тогда
		
		Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
			
			ОбъектСделка 					= СтрокаТЗ.Сделка.ПолучитьОбъект();
			ОбъектСделка.ИсточникИнформации = ЭтотОбъект.ЗначениеДействия;
			ОбъектСделка.Записать();
			
		КонецЦикла;
		
	ИначеЕсли ЭтотОбъект.Действие = "ВидСделки" Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ВидСделки)
			И ЗначениеЗаполнено(ЭтотОбъект.ЗначениеДействия) Тогда
			
			Для Каждого СтрокаТЗ Из ТЗДинамическогоСписка Цикл
				
				ОбъектСделка = СтрокаТЗ.Сделка.ПолучитьОбъект();
				ОбъектСделка.ВидСделки 		 = ЭтотОбъект.ВидСделки;
				ОбъектСделка.ЭтапСделки 	 = ЭтотОбъект.ЗначениеДействия;
				ОбъектСделка.РезультатСделки = Неопределено;
				ОбъектСделка.ПричинаОтказа   = Неопределено;
				ОбъектСделка.ЭтапОтказа		 = Неопределено;
				ОбъектСделка.Записать();
				
			КонецЦикла;
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Заполните все поля!'; en = 'Fill in all the fields!'"));
			Возврат;
			
		КонецЕсли;

	КонецЕсли;
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Строка.Инициализирован = Ложь;
	КонецЦикла;

	ОбновитьЗначенияФильтрацииДанных(Новый Структура);
				
КонецПроцедуры

&НаСервере
// Процедура, Распределяет мененеджеров в пропорции.
//
Процедура МенеджерыРаспределитьВПропорции(Знач ТЗДинамическогоСписка)
	
	КоличествоСотрудников = ЭтотОбъект.ТаблицаДействия.Количество();
	
	Если КоличествоСотрудников <= 0 Тогда		
		Возврат;
	КонецЕсли;
	
	ТипЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(3));
	
	ТЗСотрудников = ЭтотОбъект.ТаблицаДействия.Выгрузить();
	ТЗСотрудников.Колонки.Добавить("КоличествоСделок", ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("ПроцентТекущий"	 , ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("Дельта"			 , ТипЧисло);
	
	ТЗСделок = ТЗДинамическогоСписка.Скопировать(,"Сделка, ЗапланированнаяЗадача");
	
	Для Каждого СтрокаТЗ Из ТЗСделок Цикл
		
		ПриоритетныйСотрудник = Неопределено;
		ПриоритетныйПроцент   = 0;
		
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			Если СтрокаСотрудников.Дельта >= ПриоритетныйПроцент Тогда
				
				ПриоритетныйСотрудник = СтрокаСотрудников.Сотрудник;
				ПриоритетныйПроцент   = СтрокаСотрудников.Дельта;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ПриоритетныйСотрудник) Тогда
			
			ОбъектСделка = СтрокаТЗ.Сделка.ПолучитьОбъект();
			ОбъектСделка.Менеджер = ПриоритетныйСотрудник;
			ОбъектСделка.Записать();
			
			// Обновить исполнителя в не завершенных задачах.
			Если ЭтотОбъект.ЗаменитьИсполнителяВНеЗавершенныхЗадачах
				И ЗначениеЗаполнено(СтрокаТЗ.ЗапланированнаяЗадача) Тогда
				
				ОбъектЗадача = СтрокаТЗ.ЗапланированнаяЗадача.ПолучитьОбъект();
				ОбъектЗадача.Исполнитель = ПриоритетныйСотрудник;
				ОбъектЗадача.Записать();
				
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаТЗСотрудников = ТЗСотрудников.Найти(ПриоритетныйСотрудник);
		СтрокаТЗСотрудников.КоличествоСделок = СтрокаТЗСотрудников.КоличествоСделок + 1;
		
		// Обновляем данные в таблице значений.
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			СтрокаСотрудников.ПроцентТекущий = СтрокаСотрудников.КоличествоСделок/ТЗСотрудников.Итог("КоличествоСделок")*100; 
			СтрокаСотрудников.Дельта 		 = СтрокаСотрудников.Пропорция - СтрокаСотрудников.ПроцентТекущий;
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Обновить менеджера в клиенте.
	Если ЭтотОбъект.ЗаменитьМенеджераПоПродажамВКлиенте Тогда
		
		ТЗКонтрагентов = ТЗДинамическогоСписка.Скопировать(,"Контрагент");
		ТЗКонтрагентов.Свернуть("Контрагент");
		
		Для Каждого СтрокаТЗ Из ТЗКонтрагентов Цикл
			Если ЗначениеЗаполнено(СтрокаТЗ.Контрагент) Тогда
				
				ТЗСделок = ТЗДинамическогоСписка.Скопировать(Новый Структура("Контрагент", СтрокаТЗ.Контрагент), "Сделка, ДатаСделки");
				ТЗСделок.Сортировать("ДатаСделки");
				КоличествоСстрокТЗ = ТЗСделок.Количество();
				
				Если КоличествоСстрокТЗ > 0 Тогда
					МенеджерПоследнейСделки = ТЗСделок[КоличествоСстрокТЗ-1].Сделка.Менеджер;
					Если ЗначениеЗаполнено(МенеджерПоследнейСделки) Тогда
						
						КонтрагентОбъект = СтрокаТЗ.Контрагент.ПолучитьОбъект();
						КонтрагентОбъект.Менеджер = МенеджерПоследнейСделки;
						КонтрагентОбъект.Записать();
						
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

