#Область Files

// Функция возвращает файл в двоичных данных.
// 
Функция FilesGET(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ИмяФайла 			= Запрос.ПараметрыURL["ИмяФайла"];
	ДвоичныеДанныеФайла = Неопределено;
	Отказ 				= Ложь;
	
	Если ИмяФайла = "get_default" Тогда
		ДвоичныеДанныеФайла = БиблиотекаКартинок.ФотоПоУмолчанию.ПолучитьДвоичныеДанные();
		
	ИначеЕсли ИмяФайла = "get_icon" Тогда
		ДвоичныеДанныеФайла = БиблиотекаКартинок.СменаКлиники.ПолучитьДвоичныеДанные();
	Иначе
		
		
		Попытка
						
			ИдентификаторСсылки = Новый УникальныйИдентификатор(Сред(ИмяФайла, 1, 36));
			Сотрудник = ПолучитьСсылкуОбъектаПоУИД(ИдентификаторСсылки, "Справочники", "Сотрудники");
			
			Если Сотрудник = Неопределено Тогда
				ФайлКартинки = ПолучитьСсылкуОбъектаПоУИД(ИдентификаторСсылки, "Справочники", "Файлы");
				Если ФайлКартинки = Неопределено Тогда
					Отказ = Истина;
				КонецЕсли;	
			Иначе
				ФайлКартинки = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник, "ФайлКартинки");
			КонецЕсли;
			
			Если Не Отказ Тогда
				ДвоичныеДанныеФайла = ПолучитьФайлКартинки(ФайлКартинки);
				Если ДвоичныеДанныеФайла = Неопределено Тогда
					Отказ = Истина; 
				КонецЕсли;
			КонецЕсли;
			
		Исключение
			Отказ = Истина;
		КонецПопытки;
		
	КонецЕсли;	
		
	Ответ = Новый HTTPСервисОтвет(?(Отказ, 404, 200));
	Если Не Отказ Тогда
		Ответ.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанныеФайла);
		Ответ.Заголовки["Content-Type"] = "image";
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

