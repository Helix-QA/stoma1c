&НаКлиенте
Процедура ПрочитатьПравилаОбмена(Команда)
	
    АдресФайлаПравилВХранилище = "";
	ИмяФайлаДляРасширения = "";
	
	Если ЭтоКлиент Тогда
		Оповещение = Новый ОписаниеОповещения("ПрочитатьПравилаОбменаЗавершение", ЭтаФорма);
		НачатьПомещениеФайла(Оповещение, АдресФайлаПравилВХранилище, ИмяФайлаПравил, Ложь, УникальныйИдентификатор);
		Возврат;
	Иначе
		
		Если ПустаяСтрока(Объект.ИмяФайлаПравилОбмена) Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Выберите файл правил обмена.'"));
			Возврат;
		КонецЕсли;
		ПрочитатьПравилаОбменаФрагмент(ИмяфайлаДляРасширения); 
	КонецЕсли;	 
	
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьПравилаОбменаЗавершение(Результат, Адрес, ИмяФайлаПравил, ДополнительныеПараметры) Экспорт
	
	Если Не Результат Тогда
		Возврат;
	КонецЕсли;  
	
	АдресФайлаПравилВХранилище = Адрес;
	ПрочитатьПравилаОбменаФрагмент(ИмяФайлаПравил);
		
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьПравилаОбменаФрагмент(Знач ИмяфайлаДляРасширения)
	
	Объект.ФлагОшибки = Ложь;
	
	Состояние(НСтр("ru = 'Выполняется чтение правил обмена. Пожалуйста, подождите...'"));
	ВыполнитьЗагрузкуПравилОбмена(АдресФайлаПравилВХранилище, ИмяфайлаДляРасширения);
	
	Если Не Объект.ФлагОшибки Тогда
		
		ПравилаЗагружены = Истина;
		
	Иначе
		
		ПравилаЗагружены = Ложь;
		
	КонецЕсли;

КонецПроцедуры

