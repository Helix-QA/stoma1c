&НаКлиенте
// Процедура - Выбрать
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Выбрать(Команда)
	
	Если НРег(Команда.Имя) = "ок" Тогда
		
		СтруктураВозврата = Новый Структура;

		СтруктураВозврата.Вставить("ТипЗаменяемойСтроки"	 		, ТипЗаменяемойСтроки);
		СтруктураВозврата.Вставить("ЗаменяемоеЗначение"		 		, ЗаменяемоеЗначение);
		СтруктураВозврата.Вставить("ТипЗначенияЗамены" 		 		, ТипЗначенияЗамены);
		СтруктураВозврата.Вставить("ЗначениеЗамены"			 		, ЗначениеЗамены);
		СтруктураВозврата.Вставить("ФорматЗначенияЗамены"	 		, ФорматЗначенияЗамены);
		СтруктураВозврата.Вставить("ТипРеквизитаЗамены"	 	 		, ТипРеквизитаЗамены);
		СтруктураВозврата.Вставить("КэшСписокаПолей"	 	 		, КэшСписокаПолей);
        СтруктураВозврата.Вставить("ТипЗаменыПустогоЗначения"		, ТипЗаменыПустогоЗначения);
		СтруктураВозврата.Вставить("ЗначениеЗаменыНезаполненного"	, ЗначениеЗаменыНезаполненного);
		СтруктураВозврата.Вставить("КоличествоСимволовПрочерков" 	, КоличествоСимволовПрочерков);
		Модифицированность = Ложь;
		ОповеститьОЗаписиНового(СтруктураВозврата);
		Закрыть(СтруктураВозврата);
	Иначе
		Модифицированность = Ложь;
		Закрыть(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
