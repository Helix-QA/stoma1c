//
Процедура УстановитьСвойстваЭлементамАккаунтаСообщения(Знач ЭлементФормы = Неопределено, ИндексСтроки, ПараметрыОтображенияЭлементов = Неопределено) Экспорт
	
	// Актуализируем параметры отрисовки
	Если ПараметрыОтображенияЭлементов = Неопределено Тогда 
		ПараметрыОтображенияЭлементов 	= ИнициализироватьСтруктуруПараметровОтрисовки(Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение, ИндексСтроки);
		МассивАктуальныхСтрок 			= Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь));		
		ПараметрыОтображенияЭлементов.Вставить("ЭтоПерваяАктуальнаяСтрока", ?(МассивАктуальныхСтрок.Количество() = 0, Истина, ИндексСтроки = Объект.Действия.Индекс(МассивАктуальныхСтрок[0])));
	КонецЕсли;
	
