Процедура ПечатьПредварительнойЗаписи(Команда)
	
	// СтруктураПараметры = Новый Структура;	
	// Если Элементы.День.Пометка Тогда
	//     СтруктураПараметры.Вставить("Режим", "День");
	// Иначе
	//     СтруктураПараметры.Вставить("Режим", "Неделя");
	// КонецЕсли;	
	// СтруктураПараметры.Вставить("Дата"     , Объект.Дата);
	// СтруктураПараметры.Вставить("Сотрудник", ОтборСотрудник);
	// ОткрытьФорму("Отчет.ПредварительнаяЗаписьДляПечати.Форма", СтруктураПараметры, ЭтаФорма, УникальныйИдентификатор);

	ПараметрыПостроения = Новый Структура("ВыбранныеСотрудники, ВыбранныеПомещения, СтраницаМенеджера, РазрешениеЭкрана, СтруктурнаяЕдиница, Дата, РазрешитьСмещениеГрафика, УчитыватьГрафикРаботыСотрудников, НаВсюФорму");
	
	Если Элементы.День.Пометка Тогда
	     ПараметрыПостроения.Вставить("Режим", "День");
	Иначе
	     ПараметрыПостроения.Вставить("Режим", "Неделя");
	КонецЕсли;	

	ПараметрыПостроения.СтраницаМенеджера					=	ПолучитьСтраницуМенеджера();
	ПараметрыПостроения.СтруктурнаяЕдиница					=	Объект.СтруктурнаяЕдиница;
	ПараметрыПостроения.Дата								=	Объект.Дата;
	ПараметрыПостроения.РазрешитьСмещениеГрафика			=   Истина;
	ПараметрыПостроения.РазрешениеЭкрана					=   РазрешениеЭкрана;
	ПараметрыПостроения.УчитыватьГрафикРаботыСотрудников 	= 	Ложь;
	ПараметрыПостроения.НаВсюФорму			             	= 	Истина;
	ВыбранныеСотрудники = Новый Массив;  
	Если ЗначениеЗаполнено(СпециализацияВрача) Тогда 
		МассивСотрудников = ПолучитьМассивВрачейПоСпециализации(СпециализацияВрача);
		Если ЗначениеЗаполнено(МассивСотрудников) Тогда
			Для Каждого	Сотрудник Из МассивСотрудников Цикл
				ВыбранныеСотрудники.Добавить(Сотрудник);
			КонецЦикла;
		Иначе 
			ВыбранныеСотрудники.Добавить("Все")
		КонецЕсли;
	Иначе
		ВыбранныеСотрудники.Добавить(?(Не ОтборСотрудник.Пустая(), ОтборСотрудник, "Все"));
	КонецЕсли;
	ВыбранныеПомещения = Новый Массив; 
	ВыбранныеПомещения.Добавить("Все");
	ПараметрыПостроения.ВыбранныеСотрудники 				=	ВыбранныеСотрудники;
	ПараметрыПостроения.ВыбранныеПомещения 					=	ВыбранныеПомещения;
	ПараметрыПостроения.Вставить("ВыводитьКартинки", Ложь);
	ПараметрыПостроения.Вставить("ИнтервалГрафикаЗанятий", ИнтервалГрафикаЗанятий);
	ПараметрыПостроения.Вставить("Сотрудник", ОтборСотрудник);
	ПараметрыПостроения.Вставить("МассивСотрудниковИОбластей", Неопределено);
	ОткрытьФорму("Отчет.ПредварительнаяЗаписьДляПечати.Форма", ПараметрыПостроения, ЭтаФорма, УникальныйИдентификатор);
	
КонецПроцедуры

