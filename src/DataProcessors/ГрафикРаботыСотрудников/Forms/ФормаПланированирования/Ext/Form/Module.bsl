&НаСервере
// Функция - Получает структуру параметров печати
// 
// 
Функция ПолучитьПараметрыПечати()

	СтруктураПараметров = новый Структура;
	СтруктураПараметров.Вставить("ОтборСтруктурнаяЕдиница",ОтборСтруктурнаяЕдиница);
	СтруктураПараметров.Вставить("ОтборПериод",ОтборПериод);
	СтруктураПараметров.Вставить("ОтборСотрудникДолжность",ОтборСотрудникДолжность);
	
	МассивГрафикПериодовРаботы = новый Массив;
	
	НомерСтрокиТабДок = 2;
	Пока НомерСтрокиТабДок <= ГрафикПериодовРаботыТабДок.ВысотаТаблицы Цикл
		СтруктураСтроки = новый Структура;
		
		ИД_Сотрудник = ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтрокиТабДок,Символы.НПП,"")+"C2").Текст;
		ТекСотрудник = НайтиСотрудникаПоИД(ИД_Сотрудник);
		
		СтруктураСтроки.Вставить("Сотрудник",ТекСотрудник);
		СтруктураСтроки.Вставить("Должность",ТекСотрудник.должность);
		ДатаПром = НачалоДня(ОтборПериод.ДатаНачала);
		Пока ДатаПром <= ОтборПериод.ДатаОкончания Цикл
			НомерКолонки = 5+(НачалоДня(ДатаПром) - НачалоДня(ОтборПериод.ДатаНачала))/(24*60*60);
			СтруктураСтроки.Вставить("Период"+СтрЗаменить(Формат(ДатаПром,"ДФ=dd.MM.yyyy"),".",""), ГрафикПериодовРаботыТабДок.Область(СтрЗаменить("R"+Строка(НомерСтрокиТабДок)+"C"+Строка(НомерКолонки)+":"+"R"+Строка(НомерСтрокиТабДок)+"C"+Строка(НомерКолонки),Символы.НПП,"")).Текст);		
			
			ДатаПром = ДатаПром+ 60*60*24;
			
		КонецЦикла;
		
		МассивГрафикПериодовРаботы.Добавить(СтруктураСтроки);
		НомерСтрокиТабДок = НомерСтрокиТабДок + 2;
	КонецЦикла;
	
	СтруктураПараметров.Вставить("ГрафикПериодовРаботы",МассивГрафикПериодовРаботы);
	
	Возврат СтруктураПараметров;
	
КонецФункции

#КонецОбласти

