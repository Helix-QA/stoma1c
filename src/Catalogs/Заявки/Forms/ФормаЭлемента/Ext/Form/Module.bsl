	ПараметрыФормы.Вставить("ВыборКлиента"  , Истина);
	ПараметрыФормы.Вставить("ЗаголовокФормы", НСтр("ru='Список дублей по номеру телефона и электронной почте клиента';en='List duplicates by phone number and email client'"));
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты", ПараметрыФормы,,,,, Оповещение);

