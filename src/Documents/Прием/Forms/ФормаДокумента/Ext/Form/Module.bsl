// Процедура, Обработчик события "ПослеОткрытияФормыПодбораНоменклатуры"
//
Процедура ПослеОткрытияФормыПодбораНоменклатуры(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ПредставлениеСписка = "";
		// Прдварительно удалить строки с текущим ключем номенклатуры
		ТабличныеЧастиУдалитьСтроки("Материалы", Параметры.ТекущиеДанные.КлючСтроки);	
		Для Каждого СтрокаМ ИЗ Результат Цикл		
			НоваяСтрока                     = Объект.Материалы.Добавить();
			НоваяСтрока.КлючСтроки          = Параметры.ТекущиеДанные.КлючСтроки;
			НоваяСтрока.Услуга              = Параметры.ТекущиеДанные.Номенклатура;
			НоваяСтрока.Материал            = СтрокаМ.Номенклатура;
			НоваяСтрока.КоличествоУпаковок  = СтрокаМ.Количество;
			Коэффициент = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаМ.Упаковка, "Коэффициент");
			НоваяСтрока.Количество          = СтрокаМ.Количество * ?(ЗначениеЗаполнено(Коэффициент),Коэффициент, 1);
			НоваяСтрока.Упаковка            = СтрокаМ.Упаковка;
			НоваяСтрока.Склад               = СтрокаМ.Склад;
			НоваяСтрока.Сотрудник           = Объект.Сотрудник;		
			НоваяСтрока.Партия              = СтрокаМ.Партия;
			ПредставлениеСписка             = ПредставлениеСписка + НоваяСтрока.Материал + ";"; 
		КонецЦикла;	
		Параметры.ТекущиеДанные.МатериалыПредставление = ПредставлениеСписка; 
		Если Параметры.Свойство("ИмяТаблицы") И Параметры.ИмяТаблицы = "ТаблицаЛечение" Тогда
			ПроставитьПредстваленияМатериалов();
			ЭтаФорма.Модифицированность = Истина; 
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

