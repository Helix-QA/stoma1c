&НаКлиенте
// Процедура, обработчик оповещения.
// 
Процедура ОбработкаИсключительнойСитуацииПечатиЧекаНаФРЗавершение(ОтветФормы, ДопПараметры) Экспорт
	
	ДанныефискальныхЧеков = Новый Структура("НомерФискальногоЧека, НомерНеФискальногоЧека", ОтветФормы, ОтветФормы);
	
	Если ОтветФормы <> Неопределено Тогда
		
		Если ТипЗнч(ОтветФормы) = Тип("Число") Тогда								
			ЗавершающийЭтапОперацииОплаты(Истина, ДанныефискальныхЧеков, ДопПараметры.ДанныеПлатежаПоКарте, ДопПараметры.МассивДокОплаты);		
		ИначеЕсли ТипЗнч(ОтветФормы) = Тип("Строка") И	ОтветФормы = "ПРОБИТЬ_ЧЕК" Тогда
			ПослеКонтроляИспользованияКассовойСмены(ДопПараметры.ИспользованиеКассовойСменыРазрешено, ДопПараметры.ПараметрыИспользованияКассовойСмены, ДопПараметры.ОписаниеОшибки, Истина, ДопПараметры.МассивДокОплаты, ДопПараметры.ДанныеПлатежаПоКарте);
		Иначе
			ЗавершающийЭтапОперацииОплаты(Ложь, ДанныефискальныхЧеков, ДопПараметры.ДанныеПлатежаПоКарте, ДопПараметры.МассивДокОплаты);
		КонецЕсли;
		
	Иначе		
		ЗавершающийЭтапОперацииОплаты(Ложь, ДанныефискальныхЧеков, ДопПараметры.ДанныеПлатежаПоКарте, ДопПараметры.МассивДокОплаты);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - После контроля использования кассовой смены
// 
// Параметры:
//  ИспользованиеКассовойСменыРазрешено	 - 	 - 
//  ПараметрыИспользованияКассовойСмены	 - 	 - 
//  ОписаниеОшибки						 - 	 - 
// 
Процедура ПослеКонтроляИспользованияКассовойСмены(
	ИспользованиеКассовойСменыРазрешено,
	ПараметрыИспользованияКассовойСмены,
	ОписаниеОшибки,
	ПовторноеПробитие = Ложь, 
	МассивДокОплаты = Неопределено,
	ДанныеПлатежаПоКарте = Неопределено) Экспорт 
	
	Если ТипЗнч(ОписаниеОшибки) <> Тип("Строка") Тогда
		ОписаниеОшибки = "";
	КонецЕсли;	
	
	Если ИспользованиеКассовойСменыРазрешено = Ложь Тогда
		ПоказатьОповещениеПользователя("Оплата",, "Оплата запрещена: " + ОписаниеОшибки, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 
		Возврат;
	КонецЕсли;
	
	ОперацияРазрешена 					= ИспользованиеКассовойСменыРазрешено;
	ОперацияОплатыПроведеноУспешно      = Ложь;
	ОшибкаПриОплатеПлатежнойКартой		= Ложь;
	
	// Операция оплаты разрешена
	Если ОперацияРазрешена И Не ПовторноеПробитие Тогда	
		
		ОписаниеОшибки                 = Неопределено;	
		
		МассивДокОплаты = ОперацияОплатыСервер(ОписаниеОшибки);
		
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			
			ОперацияОплатыПроведеноУспешно = Ложь; 
			
		Иначе     		
			
			ОперацияОплатыПроведеноУспешно = Истина;
			ОписаниеОшибки                 = Неопределено;
			
			СтрокиОплатыСертификатом       = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат"));
			СтрокиОплатыЛицевымСчетом      = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет"));
			СтрокиБезОплаты				   = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПустаяСсылка"));
			
			БезОплаты					   = ЗначениеЗаполнено(СтрокиБезОплаты);
			ВнесенаОплатаСертификатом      = ЗначениеЗаполнено(СтрокиОплатыСертификатом);
			ВнесенаОплатаЛицевымСчетом     = ЗначениеЗаполнено(СтрокиОплатыЛицевымСчетом);
			НеПробиватьЧек                 = ЭтоВзносАванса = Истина И (ВнесенаОплатаЛицевымСчетом = Истина Или ВнесенаОплатаСертификатом = Истина);			
			
			Если ОперацияОплатыПроведеноУспешно = Истина 
				И ВыполнятьОперациюПоПлатежнойКарте() = Истина Тогда				
				
				ДанныеПлатежаПоКарте           = ВыполнитьОперациюПоПлатежнойКарте(ОписаниеОшибки);
				ОперацияОплатыПроведеноУспешно = НЕ ЗначениеЗаполнено(ОписаниеОшибки) И ЗначениеЗаполнено(ДанныеПлатежаПоКарте);
				ОшибкаПриОплатеПлатежнойКартой = НЕ ОперацияОплатыПроведеноУспешно;
			КонецЕсли;
			
			Если ПараметрыИспользованияКассовойСмены.ВыполнятьОперациюНаФискальнике = Истина 
				И ОперацияОплатыПроведеноУспешно = Истина Тогда				
				
				Если ОперацияОплатыПроведеноУспешно = Истина Тогда
					
					Если НЕ НеПробиватьЧек Тогда
						
						ДанныефискальныхЧеков          = ФормированиеЧекаФРФиксацияОплаты(ОписаниеОшибки, МассивДокОплаты, БезОплаты);
						ОперацияОплатыПроведеноУспешно = НЕ ЗначениеЗаполнено(ОписаниеОшибки) И ЗначениеЗаполнено(ДанныефискальныхЧеков);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;   
	Иначе 
		
		ДанныефискальныхЧеков          = ФормированиеЧекаФРФиксацияОплаты(ОписаниеОшибки);								
		ОперацияОплатыПроведеноУспешно = НЕ ЗначениеЗаполнено(ОписаниеОшибки) И ЗначениеЗаполнено(ДанныефискальныхЧеков);
		
	КонецЕсли;	
		
	ПослеКонтроляИспользованияКассовойСменыПродолжение(
		ОперацияОплатыПроведеноУспешно, 
		НеПробиватьЧек, 
		ОшибкаПриОплатеПлатежнойКартой, 
		ДанныефискальныхЧеков, 
		ДанныеПлатежаПоКарте, 
		МассивДокОплаты, 
		ИспользованиеКассовойСменыРазрешено, 
		ПараметрыИспользованияКассовойСмены, 
		ОписаниеОшибки);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После контроля использования кассовой смены продолжение
//
Процедура ПослеКонтроляИспользованияКассовойСменыПродолжение(
		ОперацияОплатыПроведеноУспешно,
		НеПробиватьЧек, 
		ОшибкаПриОплатеПлатежнойКартой,
		ДанныефискальныхЧеков,
		ДанныеПлатежаПоКарте,
		МассивДокОплаты, 
		ИспользованиеКассовойСменыРазрешено,
		ПараметрыИспользованияКассовойСмены,
		ОписаниеОшибки)

		Если ОперацияОплатыПроведеноУспешно = Истина Тогда
			
			Если ОплатаСдача > 0 И Не НеЗачислятьСдачуНаЛицевойСчет Тогда
				
				Заголовок = ?(РежимЗачисленияСдачи = 0, "Зачислить сдачу на лицевой счет?", "Зачислить сдачу в счет аванса?");
				
				ДопПараметры = Новый Структура;
				ДопПараметры.Вставить("ОперацияОплатыПроведеноУспешно"	, ОперацияОплатыПроведеноУспешно);
				ДопПараметры.Вставить("ДанныефискальныхЧеков"			, ДанныефискальныхЧеков);
				ДопПараметры.Вставить("ДанныеПлатежаПоКарте"			, ДанныеПлатежаПоКарте);
				ДопПараметры.Вставить("МассивДокОплаты"					, МассивДокОплаты);
				ДопПараметры.Вставить("РежимЗачисленияСдачи"			, РежимЗачисленияСдачи);  			
				
				Оповещение = Новый ОписаниеОповещения("ПослеВопросаОЗачисленииСдачиНаЛицСчет", ЭтотОбъект, ДопПараметры);		
				
				ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаВопросОЗачисленииСдачи", 
					Новый Структура("Заголовок", Заголовок),,,,,
					Оповещение, 
					РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
			Иначе						
				ЗавершающийЭтапОперацииОплаты(
					ОперацияОплатыПроведеноУспешно, 
					ДанныефискальныхЧеков, 
					ДанныеПлатежаПоКарте,
					МассивДокОплаты);
					
			КонецЕсли;
			
			Если ПечатьКвитанции
				И НЕ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Возврат") Тогда
				МассивОплачиваемыхДокументов = ПолучитьВыбранныеДокументыЗадолженности();
				Для К = 1 По ПечатьКвитанций_Количество Цикл			
					Если МассивОплачиваемыхДокументов.Количество() > 0 Тогда
						СтруктураОплаты = Новый Структура;
						СтруктураОплаты.Вставить("ID_Транзакции", ID_Транзакции);
						УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Документ.Прием", "ПФ_MXL_Квитанция", МассивОплачиваемыхДокументов, Неопределено);			
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			Если ПечатьАктаОвыполненыхРаботах
				И НЕ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Возврат") Тогда
				
				УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.Прием", "ПФ_MXL_АктОВыполненныхРаботах", 
				ПолучитьВыбранныеДокументыЗадолженности(), Неопределено, Неопределено);		
			КонецЕсли;     
			
		ИначеЕсли Не ОшибкаПриОплатеПлатежнойКартой Тогда 
			
			ДопПараметры = Новый Структура("ИспользованиеКассовойСменыРазрешено, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки, ДанныеПлатежаПоКарте, МассивДокОплаты", 
			ИспользованиеКассовойСменыРазрешено, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки, ДанныеПлатежаПоКарте, МассивДокОплаты);
			ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаИсключительнойСитуацииПечатиЧекаНаФРЗавершение", ЭтотОбъект, ДопПараметры);
			ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ОбработкаИсключительнойСитуацииПечатиЧекаНаФР", 
			Новый Структура("ДокументПродажиСсылка, Касса", Неопределено, ТекущаяКасса),,,,,
			ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			
		Иначе
			
			ЗавершающийЭтапОперацииОплаты(ОперацияОплатыПроведеноУспешно, ДанныефискальныхЧеков, ДанныеПлатежаПоКарте, МассивДокОплаты);	
			
		КонецЕсли; 

КонецПроцедуры

#КонецОбласти

///////////////////////////////////////////// РАБОТА С НАПРАВЛЕНИЯМИ К ВРАЧАМ ////////////////////////////////

&НаСервере
// Процедура обновляет список направлений созданных на основании документов задолженности
Процедура ОбновитьСписокНаправленийКВрачам()
	
	// Очищаем ранее созданные элементы
	Пока Элементы.ГруппаНеОбработанныеНаправленияКВрачам.ПодчиненныеЭлементы.Количество()>0 Цикл		
		Элементы.Удалить(Элементы.ГруппаНеОбработанныеНаправленияКВрачам.ПодчиненныеЭлементы[0]);		
	КонецЦикла; 
	Пока Элементы.ГруппаНеОбработанныеПовторныеПриемы.ПодчиненныеЭлементы.Количество()>0 Цикл		
		Элементы.Удалить(Элементы.ГруппаНеОбработанныеПовторныеПриемы.ПодчиненныеЭлементы[0]);		
	КонецЦикла;
	СписокНаправленийКВрачам.Очистить();
	
	ОтборДокументы      = ПолучитьДокументыЗадолженностиСервер(Ложь);	
	ЗапросВыборка       = Новый Запрос;
	ЗапросВыборка.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВложенныйЗапрос.Контрагент КАК Контрагент,
	|	ЕСТЬNULL(ВложенныйЗапрос.Сотрудник, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК Сотрудник,
	|	ЕСТЬNULL(ВложенныйЗапрос.ФИО, """") КАК ФИО,
	|	ВложенныйЗапрос.ВидОсмотра КАК ВидОсмотра,
	|	ВложенныйЗапрос.ДатаЗапланированная КАК ДатаЗапланированная,
	|	ВложенныйЗапрос.Статус КАК Статус,
	|	ВложенныйЗапрос.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
	|	ВложенныйЗапрос.ДокументСсылка КАК ДокументСсылка,
	|	ВложенныйЗапрос.ПричинаНаправления КАК ПричинаНаправления,
	|	ВложенныйЗапрос.Специализация КАК Специализация,
	|	ВложенныйЗапрос.СпециализацияПредставление КАК СпециализацияПредставление
	|ИЗ
	|	(ВЫБРАТЬ
	|		Профосмотры.Период КАК Период,
	|		Профосмотры.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		Профосмотры.Контрагент КАК Контрагент,
	|		Профосмотры.Сотрудник КАК Сотрудник,
	|		Профосмотры.ВидОсмотра КАК ВидОсмотра,
	|		Профосмотры.ДатаЗапланированная КАК ДатаЗапланированная,
	|		Профосмотры.Статус КАК Статус,
	|		Профосмотры.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
	|		Профосмотры.Прием КАК ДокументСсылка,
	|		Профосмотры.ПричинаНаправления КАК ПричинаНаправления,
	|		Профосмотры.Специализация КАК Специализация,
	|		Профосмотры.Специализация.Представление КАК СпециализацияПредставление,
	|		ВЫБОР
	|			КОГДА Профосмотры.Сотрудник.НаименованиеСокращенное = """"
	|				ТОГДА Профосмотры.Сотрудник.Наименование
	|			ИНАЧЕ Профосмотры.Сотрудник.НаименованиеСокращенное
	|		КОНЕЦ КАК ФИО
	|	ИЗ
	|		РегистрСведений.Профосмотры КАК Профосмотры
	|	ГДЕ
	|		Профосмотры.Прием = &ОтборДокумент
	|		И Профосмотры.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Направление)
	|	И ВложенныйЗапрос.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Период,
	|	ВложенныйЗапрос.СтруктурнаяЕдиница,
	|	ВложенныйЗапрос.Контрагент,
	|	ВложенныйЗапрос.Сотрудник,
	|	ВложенныйЗапрос.ФИО,
	|	ВложенныйЗапрос.ВидОсмотра,
	|	ВложенныйЗапрос.ДатаЗапланированная,
	|	ВложенныйЗапрос.Статус,
	|	ВложенныйЗапрос.ПредварительнаяЗапись,
	|	ВложенныйЗапрос.ДокументСсылка,
	|	ВложенныйЗапрос.ПричинаНаправления,
	|	ВложенныйЗапрос.Специализация,
	|	ВложенныйЗапрос.СпециализацияПредставление
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПрофосмотрыСрезПоследних.Период КАК Период,
	|		ПрофосмотрыСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		ПрофосмотрыСрезПоследних.Контрагент КАК Контрагент,
	|		ПрофосмотрыСрезПоследних.Сотрудник КАК Сотрудник,
	|		ПрофосмотрыСрезПоследних.ВидОсмотра КАК ВидОсмотра,
	|		ПрофосмотрыСрезПоследних.ДатаЗапланированная КАК ДатаЗапланированная,
	|		ПрофосмотрыСрезПоследних.Статус КАК Статус,
	|		ПрофосмотрыСрезПоследних.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
	|		ПрофосмотрыСрезПоследних.Прием КАК ДокументСсылка,
	|		ПрофосмотрыСрезПоследних.ПричинаНаправления КАК ПричинаНаправления,
	|		ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка) КАК Специализация,
	|		"""" КАК СпециализацияПредставление,
	|		ВЫБОР
	|			КОГДА ПрофосмотрыСрезПоследних.Сотрудник.НаименованиеСокращенное = """"
	|				ТОГДА ПрофосмотрыСрезПоследних.Сотрудник.Наименование
	|			ИНАЧЕ ПрофосмотрыСрезПоследних.Сотрудник.НаименованиеСокращенное
	|		КОНЕЦ КАК ФИО
	|	ИЗ
	|		РегистрСведений.Профосмотры.СрезПоследних(
	|				,
	|				Прием = &ОтборДокумент
	|					И ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.ПовторныйПрием)
	|					И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован)) КАК ПрофосмотрыСрезПоследних) КАК ВложенныйЗапрос";	
	
	Для Каждого ЭлементМ ИЗ ОтборДокументы Цикл 		
		// Выполнение запроса отдельно по каждому документу НЕОБХОДИМО
		// потому, что отбор производиться по реквизиту Прием, а не по измерению!, из-за
		// чего не удается произвести отбор по массиву документов
		ЗапросВыборка.УстановитьПараметр("ОтборДокумент", ЭлементМ);            
		РезВыборки             = ЗапросВыборка.Выполнить().Выгрузить();
		Для Каждого СтрокаТ ИЗ РезВыборки Цикл
			// Заполняем буферную таблицу 			
			НоваяСтрока = СписокНаправленийКВрачам.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТ); 
		КонецЦикла; 	
	КонецЦикла;  
    МассивПовторныхприемов = СписокНаправленийКВрачам.НайтиСтроки(Новый Структура("ВидОсмотра", Перечисления.ВидыОсмотров.ПовторныйПрием)); 
	МассивНаправлений      = СписокНаправленийКВрачам.НайтиСтроки(Новый Структура("ВидОсмотра", Перечисления.ВидыОсмотров.Направление));

	// Создание основных группировок
	Если МассивНаправлений.Количество() > 0 Тогда
		// Размещение группировок
		ГруппаЛевая_Направления                         = Элементы.Добавить("ГруппаНЛ_" + Строка(1),Тип("ГруппаФормы"), Элементы.ГруппаНеОбработанныеНаправленияКВрачам);
		ГруппаЛевая_Направления.Вид                     = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаЛевая_Направления.Отображение             = ОтображениеОбычнойГруппы.Нет;
		ГруппаЛевая_Направления.ОтображатьЗаголовок     = Ложь;  
		ГруппаЛевая_Направления.ВертикальныйИнтервал    = ИнтервалМеждуЭлементамиФормы.Полуторный;
		ГруппаЛевая_Направления.Группировка             = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаЛевая_Направления.Ширина                  = 30;
		
		ГруппаПравая_Направления                        = Элементы.Добавить("ГруппаНП_" + Строка(1),Тип("ГруппаФормы"), Элементы.ГруппаНеОбработанныеНаправленияКВрачам);
		ГруппаПравая_Направления.Вид                    = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаПравая_Направления.Отображение            = ОтображениеОбычнойГруппы.Нет;
		ГруппаПравая_Направления.ОтображатьЗаголовок    = Ложь;  
		ГруппаПравая_Направления.Группировка            = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаПравая_Направления.РастягиватьПоВертикали = Истина;
		
	КонецЕсли; 
	
	Если МассивПовторныхприемов.Количество() > 0 Тогда
		// Размещение группировок
		ГруппаЛевая_ПовтПрием                           = Элементы.Добавить("ГруппаПовторныеПприемыЛев_" + Строка(1),Тип("ГруппаФормы"), Элементы.ГруппаНеОбработанныеПовторныеПриемы);
		ГруппаЛевая_ПовтПрием.Вид                       = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаЛевая_ПовтПрием.Отображение               = ОтображениеОбычнойГруппы.Нет;
		ГруппаЛевая_ПовтПрием.ОтображатьЗаголовок       = Ложь;  
		ГруппаЛевая_ПовтПрием.ВертикальныйИнтервал      = ИнтервалМеждуЭлементамиФормы.Полуторный;
		ГруппаЛевая_ПовтПрием.Группировка               = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаЛевая_ПовтПрием.Ширина                    = 30;
		
		ГруппаПравая_ПовтПрием                          = Элементы.Добавить("ГруппаПовторныеПприемыПрав_" + Строка(1),Тип("ГруппаФормы"), Элементы.ГруппаНеОбработанныеПовторныеПриемы);
		ГруппаПравая_ПовтПрием.Вид                      = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаПравая_ПовтПрием.Отображение              = ОтображениеОбычнойГруппы.Нет;
		ГруппаПравая_ПовтПрием.ОтображатьЗаголовок      = Ложь;  
		ГруппаПравая_ПовтПрием.Группировка              = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаПравая_ПовтПрием.РастягиватьПоВертикали   = Истина;
			
	КонецЕсли; 

	// Создание декораций отображения
	Идентификатор = 0;
	Для Каждого СтрокаТ ИЗ СписокНаправленийКВрачам Цикл   
		
		ГруппаЛевая  = ?(СтрокаТ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием, ГруппаЛевая_ПовтПрием, ГруппаЛевая_Направления); 
		ГруппаПравая = ?(СтрокаТ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием, ГруппаПравая_ПовтПрием, ГруппаПравая_Направления);  
		фИОВрача = "";
		Если СтрокаТ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда
			ДатаЗапланированная = Формат(СтрокаТ.ДатаЗапланированная, "ДЛФ=DD");
			фИОВрача = СтрокаТ.ФИО + " на " + Лев(ДатаЗапланированная, СтрДлина(ДатаЗапланированная) - 2) +".";
		Иначе 
			фИОВрача = ?(ЗначениеЗаполнено(СтрокаТ.ФИО), СтрокаТ.ФИО, СтрокаТ.СпециализацияПредставление);
		КонецЕсли;
		
		// Декорация заголовка
		НовыйДек                              = Элементы.Добавить("ДекорацияН_"+Строка(Идентификатор),Тип("ДекорацияФормы"), ГруппаЛевая);
		НовыйДек.Вид                          = ВидДекорацииФормы.Надпись;
		НовыйДек.Гиперссылка                  = Ложь;
		НовыйДек.Заголовок                    = ?(СтрокаТ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием, "Повторный прием к ", "Направление к ") + фИОВрача; 
		НовыйДек.Шрифт 					      = Новый Шрифт(НовыйДек.Шрифт, , 9);
		НовыйДек.МаксимальнаяШирина           = 35;
		НовыйДек.Ширина                       = 35;  
		
		ГруппаКнопок                          = Элементы.Добавить("ГруппаКнопок_" + Строка(Идентификатор), Тип("ГруппаФормы"), ГруппаПравая);
		ГруппаКнопок.Вид                      = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаКнопок.Отображение              = ОтображениеОбычнойГруппы.Нет;
		ГруппаКнопок.ОтображатьЗаголовок      = Ложь;
		ГруппаКнопок.Группировка              = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда; 
		
		// Декорация "Записать"
		НовыйДек = Элементы.Добавить("ДекорацияЗ_"+Строка(Идентификатор),Тип("ДекорацияФормы"), ГруппаКнопок);
		НовыйДек.Вид                          = ВидДекорацииФормы.Надпись;
		НовыйДек.Гиперссылка                  = Истина;
		НовыйДек.РастягиватьПоГоризонтали     = Истина;  
		НовыйДек.УстановитьДействие("Нажатие", "ОбработчикНажатияДекорацийНаправленийЗаписать");
		НовыйДек.ГоризонтальноеПоложение      = ГоризонтальноеПоложениеЭлемента.Право;
		НовыйДек.Шрифт 					      = Новый Шрифт(НовыйДек.Шрифт, , 9);
		НовыйДек.Заголовок                    = "Записать";
		НовыйДек.ЦветТекста                   = WebЦвета.Синий; 
		НовыйДек.Высота                       = 1;
		
		// Декорация "Позже"
		НовыйДек = Элементы.Добавить("ДекорацияП_"+Строка(Идентификатор),Тип("ДекорацияФормы"), ГруппаКнопок);
		НовыйДек.Вид                          = ВидДекорацииФормы.Надпись;
		НовыйДек.Гиперссылка                  = Истина;
		НовыйДек.РастягиватьПоГоризонтали     = Истина;
		НовыйДек.УстановитьДействие("Нажатие", "ОбработчикНажатияДекорацийНаправленийПозже");
		НовыйДек.ГоризонтальноеПоложение      = ГоризонтальноеПоложениеЭлемента.Право;  
		НовыйДек.Шрифт 					      = Новый Шрифт(НовыйДек.Шрифт, , 9);
		НовыйДек.Заголовок                    = "Позже";
		НовыйДек.ЦветТекста                   = WebЦвета.Золотой; 
		НовыйДек.Высота                       = 1;
		
		// Декорация "Отказ"
		НовыйДек = Элементы.Добавить("ДекорацияО_"+Строка(Идентификатор),Тип("ДекорацияФормы"), ГруппаКнопок);
		НовыйДек.Вид                          = ВидДекорацииФормы.Надпись;
		НовыйДек.Гиперссылка                  = Истина;
		НовыйДек.РастягиватьПоГоризонтали     = Истина;
		НовыйДек.УстановитьДействие("Нажатие", "ОбработчикНажатияДекорацийНаправленийОтказ");
		НовыйДек.ГоризонтальноеПоложение      = ГоризонтальноеПоложениеЭлемента.Право;   
		НовыйДек.Шрифт 					      = Новый Шрифт(НовыйДек.Шрифт, , 9);
		НовыйДек.Заголовок                    = "Отказ";
		НовыйДек.ЦветТекста                   = WebЦвета.Красный;
		НовыйДек.Высота                       = 1;
		
		Идентификатор = Идентификатор + 1;
		
	КонецЦикла; 

	// Элементы.ГруппаОбщееПоОплате.Доступность = НЕ Элементы.ГруппаНеОбработанныеНаправленияКВрачам.ПодчиненныеЭлементы.Количество() > 0;
	
КонецПроцедуры

&НаКлиенте
// Обработчик нажатия 
Процедура ОбработчикНажатияДекорацийНаправленийЗаписать(Элемент)
	
	НомерСтроки = Число(СтрЗаменить(Элемент.Имя,"ДекорацияЗ_",""));
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Контрагент"              , СписокНаправленийКВрачам[НомерСтроки].Контрагент);
	ПараметрыФормы.Вставить("Сотрудник"               , СписокНаправленийКВрачам[НомерСтроки].Сотрудник); 
	ПараметрыФормы.Вставить("ОтборПоСотруднику"       , СписокНаправленийКВрачам[НомерСтроки].Сотрудник);
	ПараметрыФормы.Вставить("Дата"                    , СписокНаправленийКВрачам[НомерСтроки].ДатаЗапланированная);
	ПараметрыФормы.Вставить("СпециализацияВрача"      , СписокНаправленийКВрачам[НомерСтроки].Специализация); 
	ПараметрыФормы.Вставить("ЗакрытьПриСозданииЗаписи", Истина);
	
	ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаПредварительнойЗаписи");
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработчикНажатияЗаписиНаПриемЗавершение", ЭтотОбъект, Новый Структура("НомерСтроки", НомерСтроки));
	ОткрытьФорму(ИмяФормыПланировщика, ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры  

&НаКлиенте
// Процедура - Обработчик нажатия записи на прием завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
 Процедура ОбработчикНажатияЗаписиНаПриемЗавершение(Результат, ДополнительныеПараметры) Экспорт
	 
	 Если Результат = Неопределено Тогда
	     Возврат;
	 КонецЕсли;	 
	 НомерСтроки = ДополнительныеПараметры.НомерСтроки; 
	 Статус      = ПредопределенноеЗначение("Перечисление.СтатусыПрофосмотров.Согласился");
	 СписокНаправленийКВрачам[НомерСтроки].ПредварительнаяЗапись = Результат;
	 Если СписокНаправленийКВрачам[НомерСтроки].ПредварительнаяЗапись <> Неопределено Тогда   	 
		 СоздатьЗаписиВРегистреПрофосмотры(НомерСтроки, Статус); 
		 ОбновитьСписокНаправленийКВрачам();
	 КонецЕсли;  
	 
 КонецПроцедуры 
 
 &НаСервере
// Процедура, Обработчик события "СоздатьЗаписиВРегистреПрофосмотры".
//
Процедура СоздатьЗаписиВРегистреПрофосмотры(НомерСтроки, Статус)
	
	НаборЗаписей                                        = РегистрыСведений.Профосмотры.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Значение                  = СписокНаправленийКВрачам[НомерСтроки].Период; 
	НаборЗаписей.Отбор.Период.Использование             = Истина;
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Значение      = СписокНаправленийКВрачам[НомерСтроки].СтруктурнаяЕдиница;
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Использование = Истина;
	НаборЗаписей.Отбор.Контрагент.Значение              = СписокНаправленийКВрачам[НомерСтроки].Контрагент; 
	НаборЗаписей.Отбор.Контрагент.Использование         = Истина; 
	Если ЗначениеЗаполнено(СписокНаправленийКВрачам[НомерСтроки].Сотрудник) Тогда
		НаборЗаписей.Отбор.Сотрудник.Значение           = СписокНаправленийКВрачам[НомерСтроки].Сотрудник;   
		НаборЗаписей.Отбор.Сотрудник.Использование      = Истина;
	КонецЕсли;
	НаборЗаписей.Отбор.ВидОсмотра.Значение              = СписокНаправленийКВрачам[НомерСтроки].ВидОсмотра;
	НаборЗаписей.Отбор.ВидОсмотра.Использование         = Истина;
	НаборЗаписей.Прочитать(); 
	
	Если НаборЗаписей.Количество() > 0 Тогда 	
		НоваяЗапись        = НаборЗаписей[0];
		НоваяЗапись.Статус = Статус;
		Если ЗначениеЗаполнено(СписокНаправленийКВрачам[НомерСтроки].ПредварительнаяЗапись) Тогда			
			 СтруктураДлительности = Документы.Событие.ПолучитьПродолжительностьСобытия(СписокНаправленийКВрачам[НомерСтроки].ПредварительнаяЗапись);
			 НоваяЗапись.ПредварительнаяЗапись = СписокНаправленийКВрачам[НомерСтроки].ПредварительнаяЗапись;
			 НоваяЗапись.ДатаЗапланированная   = СтруктураДлительности.ДатаНачала;
			 НоваяЗапись.Длительность          = СтруктураДлительности.Длительность; 
			 Если Не ЗначениеЗаполнено(НаборЗаписей[0].Сотрудник) Тогда  
				НоваяЗапись.Сотрудник = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СписокНаправленийКВрачам[НомерСтроки].ПредварительнаяЗапись, "Врач"); 
			 КонецЕсли;			 
		КонецЕсли; 	
		НаборЗаписей.Записать();	
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
