	Форма.Элементы.РедактироватьШаблонСообщенияPush.Видимость		= Форма.ЭтотОбъект.ОтправитьPushУведомлением;
	Форма.Элементы.РедактироватьШаблонСообщенияEmail.Видимость		= Форма.ЭтотОбъект.ОтправитьПоEmail;
	Форма.Элементы.РедактироватьШаблонСообщенияСМС.Видимость		= Форма.ЭтотОбъект.ОтправитьПоSMS;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Редактировать шаблон сообщения
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура РедактироватьШаблонСообщения(Элемент)
	
	Если Не ЗначениеЗаполнено(СсылкаНаОплату) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сперва необходимо сгенерировать ссылку на оплату");
		Возврат;
	КонецЕсли;
	
	ПараметрыСтруктурой = Новый Структура("ШаблонДляОтправкиСсылкиНаОплату", ШаблонДляОтправкиСсылкиНаОплату);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеРедактированияШаблонаСообщения", ЭтотОбъект);	
	ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаРедактированияШаблонаСообщения", ПараметрыСтруктурой,,,,, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После редактирования шаблона сообщения
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ПослеРедактированияШаблонаСообщения(Результат, ДопПараметры) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") 
		И Результат.Свойство("ШаблонДляОтправкиСсылкиНаОплату") 
		И ЭтотОбъект.ШаблонДляОтправкиСсылкиНаОплату <> Результат.ШаблонДляОтправкиСсылкиНаОплату Тогда
		
		ЭтотОбъект.ШаблонДляОтправкиСсылкиНаОплату = Результат.ШаблонДляОтправкиСсылкиНаОплату;
		ИзмененТекстСообщения = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить требуемые параметры ПШ
//
Процедура ЗаполнитьТребуемыеПараметрыПШ()
	
	ПараметрыПШ = ЭтотОбъект.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
	
	Если ТипЗнч(ПараметрыПШ) = Тип("Структура") И ПараметрыПШ.Свойство("ШаблонДляОтправкиСсылкиНаОплату") Тогда
		ЭтотОбъект.ШаблонДляОтправкиСсылкиНаОплату = ПараметрыПШ.ШаблонДляОтправкиСсылкиНаОплату;
	Иначе
		ЭтотОбъект.ШаблонДляОтправкиСсылкиНаОплату = "Ссылка на оплату: {СсылкаНаОплату}";
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Записать параметры ПШ
//
// Параметры:
//  ЭквайринговыйТерминал			 - 	 - 
//  ШаблонДляОтправкиСсылкиНаОплату	 - 	 - 
//
Процедура ЗаписатьПараметрыПШ(ЭквайринговыйТерминал, ШаблонДляОтправкиСсылкиНаОплату)
	
	ОбъектЭТ = ЭквайринговыйТерминал.ПолучитьОбъект();
	
	Если ОбъектЭТ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыПШ = ОбъектЭТ.ПараметрыПлатежногоШлюза.Получить();
	
	Если ПараметрыПШ = Неопределено Тогда
		ПараметрыПШ = Новый Структура();
	КонецЕсли;

	ПараметрыПШ.Вставить("ШаблонДляОтправкиСсылкиНаОплату", ШаблонДляОтправкиСсылкиНаОплату);
	
	ОбъектЭТ.ПараметрыПлатежногоШлюза = Новый ХранилищеЗначения(ПараметрыПШ);

	Попытка
		ОбъектЭТ.Записать();
	Исключение
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти
