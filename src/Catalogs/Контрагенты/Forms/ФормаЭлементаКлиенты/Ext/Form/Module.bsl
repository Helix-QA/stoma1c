// Функция, возвращает значение константы.
// 
// Возвращаемое значение:
//   - Структура - Значение, хранящееся в константе. 
//
Функция ВернутьЗначениеКонстантыОбязательныеПоля()
	
	ХранилищеЗначений = Константы.ОбязательныеПоляКлиенты.Получить();	
	СтруктураОбязательныеПоля = ХранилищеЗначений.Получить();
	ОбязательныеПоля = Неопределено;
	
	Если СтруктураОбязательныеПоля = Неопределено Тогда
		Возврат ОбязательныеПоля;
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() ИЛИ КонецДня(Объект.ДатаРегистрации) = КонецДня(ТекущаяДатаСеанса()) Тогда		
		СтруктураОбязательныеПоля.Свойство("ОбязательныеПоляДляНовых", ОбязательныеПоля);		
	Иначе		
		СтруктураОбязательныеПоля.Свойство("ОбязательныеПоляДляВсех", ОбязательныеПоля);		
	КонецЕсли;
	
	Возврат ОбязательныеПоля;
	
КонецФункции

