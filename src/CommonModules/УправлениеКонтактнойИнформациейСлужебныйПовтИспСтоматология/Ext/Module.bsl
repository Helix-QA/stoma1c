// Процедура - Преобразовать телефонные номера организаций
//
Процедура ПреобразоватьТелефонныеНомераОрганизаций(КоличествоОбъектов, Индекс, СтруктураРезультата)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	ОрганизацииКонтактнаяИнформация.Ссылка КАК Организация
	               |ИЗ
	               |	Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	               |ГДЕ
	               |	НЕ ОрганизацииКонтактнаяИнформация.Ссылка.ПометкаУдаления
	               |	И &УсловиеОрганизация
	               |	И (ОрганизацииКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	               |			ИЛИ ОрганизацииКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Факс))
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ОрганизацииКонтактнаяИнформация.Ссылка
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ОрганизацииКонтактнаяИнформация.Ссылка.Наименование";
	
	Если ЗначениеЗаполнено(СтруктураРезультата.СтруктурнаяЕдиница) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОрганизация", "ЛОЖЬ");
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОрганизация", "ИСТИНА");
	КонецЕсли;
	
	ВыборкаСсылка = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСсылка.Следующий() Цикл 
		Индекс = Индекс + 1;	
		Прогресс = Цел(100 * Индекс / КоличествоОбъектов);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Преобразование формата телефонных номеров...';en='Convert phone numbers...'"), Новый Структура("ТипОбъекта, НаименованиеОбъекта", "Организация", Строка(ВыборкаСсылка.Организация)));						
		ОтредактироватьФорматТелефонаОбъекта(ВыборкаСсылка.Организация, , СтруктураРезультата);		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Отредактировать формат телефона объекта
//
// Параметры:
//  Ссылка					 - 	 - 
//  ЗаполнитьРеквизитОбъекта - 	 - 
//
Процедура ОтредактироватьФорматТелефонаОбъекта(Ссылка, Знач ЗаполнитьРеквизитОбъекта = Ложь, СтруктураРезультата)
	
	ПростоТелефон 							= "";
	ПредставлениеТелефона 					= "";
	РеквизитОбъектаТелефон 					= "";
	НеобходимоЗаписатьОбъект 				= Ложь;
	
	ОбъектКИ 								= Ссылка.ПолучитьОбъект();
	
	Для Каждого СтрокаКИ Из ОбъектКИ.КонтактнаяИнформация Цикл 
		Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон ИЛИ СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Факс Тогда 
			Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(СтрокаКИ, СтруктураРезультата);
			Если Объект_XDTO_Телефон = Неопределено Тогда
				Продолжить;
			Иначе
			    НеобходимоЗаписатьОбъект = Истина;
			КонецЕсли;	
			// Заполняем телефон
			СтрокаКИ.НомерТелефона 					= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
			СтрокаКИ.НомерТелефонаБезКодов 			= СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
			СтрокаКИ.НомерТелефонаБезКодаСтраны 	= СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
			СтрокаКИ.НомерТелефонаПоследниеЦифры 	= Прав(СокрЛП(Объект_XDTO_Телефон.Состав.Номер), 4);			
			СтрокаКИ.Представление					= СокрЛП(Объект_XDTO_Телефон.Представление);
			СтрокаКИ.ЗначенияПолей					= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
			Если ЗаполнитьРеквизитОбъекта Тогда 
				Если НЕ ЗначениеЗаполнено(ПредставлениеТелефона) Тогда 
					ПредставлениеТелефона 	= СтрокаКИ.Представление;
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(ПростоТелефон) Тогда 
					ПростоТелефон 			= СтрокаКИ.НомерТелефона;
				КонецЕсли;					
				Если НЕ ЗначениеЗаполнено(РеквизитОбъектаТелефон) И СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон И (СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКлиента ИЛИ СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента) Тогда 
					РеквизитОбъектаТелефон 	= СтрокаКИ.Представление;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если ЗаполнитьРеквизитОбъекта И НеобходимоЗаписатьОбъект Тогда
		Если ЗначениеЗаполнено(РеквизитОбъектаТелефон) Тогда 
			ОбъектКИ.Телефон 				= РеквизитОбъектаТелефон;
		Иначе 
			ОбъектКИ.Телефон 				= ПредставлениеТелефона;
		КонецЕсли;
	КонецЕсли;
	Если НеобходимоЗаписатьОбъект Тогда 
		Попытка
			ОбъектКИ.ДополнительныеСвойства.Вставить("ЭтоИзменениеФорматаТелефонныхНомеров", Истина);
			ОбъектКИ.Записать();
			Если ЗаполнитьРеквизитОбъекта И ЗначениеЗаполнено(ПростоТелефон) Тогда 
				МенеджерЗаписи = РегистрыСведений.КонтрагентыСведенияДляСписка.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Контрагент = ОбъектКИ.Ссылка;
				МенеджерЗаписи.Прочитать();
				МенеджерЗаписи.Телефон = ПростоТелефон;
				МенеджерЗаписи.Записать();
			КонецЕсли;
		Исключение
			
		КонецПопытки;	
	КонецЕсли;
	
КонецПроцедуры

// Функция - Получить структуру XDTO телефона
//
// Параметры:
//  Телефон	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуру_XDTO(СтрокаКИ, СтруктураРезультата)
	
	Объект_XDTO = Неопределено;
	Если ЗначениеЗаполнено(СтрокаКИ.ЗначенияПолей) Тогда 
		Объект_XDTO = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияИзXML(СтрокаКИ.ЗначенияПолей, СтрокаКИ.Тип);
	ИначеЕсли ЗначениеЗаполнено(СтрокаКИ.НомерТелефона) И СтрДлина(СокрЛП(СтрокаКИ.НомерТелефона)) > 9 Тогда
		НомерТелефона = СтрокаКИ.НомерТелефона;
	ИначеЕсли ЗначениеЗаполнено(СтрокаКИ.Представление) Тогда
		НомерТелефона = СтрокаКИ.Представление;
	Иначе 	
		Возврат Неопределено;
	КонецЕсли;	
	
	Если Объект_XDTO = Неопределено Тогда
		Объект_XDTO = УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOПоПредставлению(НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон);
	Иначе
		Если СтруктураРезультата.Код = "643" Тогда
			Если (СтруктураРезультата.ФорматТелНомера = 0 ИЛИ СтруктураРезультата.ФорматТелНомера = 4) И Объект_XDTO.Состав.КодСтраны <> "7" Тогда
				Если ЗначениеЗаполнено(СтрокаКИ.НомерТелефона) И СтрДлина(СокрЛП(СтрокаКИ.НомерТелефона)) > 9 Тогда
					НомерТелефона = СтрокаКИ.НомерТелефона;
				ИначеЕсли ЗначениеЗаполнено(СтрокаКИ.Представление) Тогда
					НомерТелефона = СтрокаКИ.Представление;
				Иначе 	
					Возврат Неопределено;					
				КонецЕсли;
				Комментарий = Объект_XDTO.Комментарий;
				Добавочный = Объект_XDTO.Состав.Добавочный;
				Объект_XDTO = УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOПоПредставлению(НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон);
				Объект_XDTO.Комментарий = Комментарий;				
				Объект_XDTO.Состав.Добавочный = Добавочный;
				
				//Объект_XDTO.Представление = "";
				//Объект_XDTO.Состав.КодСтраны = "7";
				//ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO);
				//Объект_XDTO = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияИзXML(ЗначенияПолей, СтрокаКИ.Тип);
			ИначеЕсли СтруктураРезультата.ФорматТелНомера = 1 И Объект_XDTO.Состав.КодСтраны <> "8" Тогда 
				Если ЗначениеЗаполнено(СтрокаКИ.НомерТелефона) И СтрДлина(СокрЛП(СтрокаКИ.НомерТелефона)) > 9 Тогда
					НомерТелефона = СтрокаКИ.НомерТелефона;
				ИначеЕсли ЗначениеЗаполнено(СтрокаКИ.Представление) Тогда
					НомерТелефона = СтрокаКИ.Представление;
				Иначе 	
					Возврат Неопределено;					
				КонецЕсли;
				Комментарий = Объект_XDTO.Комментарий;
				Добавочный = Объект_XDTO.Состав.Добавочный;				
				Объект_XDTO = УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOПоПредставлению(НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон);				
				Объект_XDTO.Комментарий = Комментарий;				
				Объект_XDTO.Состав.Добавочный = Добавочный;
				
				//Объект_XDTO.Представление = "";				
				//Объект_XDTO.Состав.КодСтраны = "8";			
				//ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO);
				//Объект_XDTO = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияИзXML(ЗначенияПолей, СтрокаКИ.Тип);
			ИначеЕсли (СтруктураРезультата.ФорматТелНомера = 0 ИЛИ СтруктураРезультата.ФорматТелНомера = 4) И Объект_XDTO.Состав.КодСтраны = "7" Тогда	
				Если ЗначениеЗаполнено(СтрокаКИ.НомерТелефона) И СтрДлина(СокрЛП(СтрокаКИ.НомерТелефона)) > 9 Тогда
					НомерТелефона = СтрокаКИ.НомерТелефона;
				ИначеЕсли ЗначениеЗаполнено(СтрокаКИ.Представление) Тогда
					НомерТелефона = СтрокаКИ.Представление;
				Иначе 	
					Возврат Неопределено;					
				КонецЕсли;
				Комментарий = Объект_XDTO.Комментарий;
				Добавочный = Объект_XDTO.Состав.Добавочный;
				Объект_XDTO = УправлениеКонтактнойИнформациейСлужебныйСтоматология.КонтактнаяИнформацияXDTOПоПредставлению(НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон);
				Объект_XDTO.Комментарий = Комментарий;				
				Объект_XDTO.Состав.Добавочный = Добавочный;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(Объект_XDTO.Состав.Номер) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Объект_XDTO;
	
КонецФункции

