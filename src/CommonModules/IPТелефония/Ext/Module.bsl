// Функция - Вернуть описание ошибки
// 
// Параметры:
//  СтруктураОтвета		 - 	 - 
//  ВидФатальнойОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВернутьОписаниеОшибки(СтруктураОтвета, ОшибкаПереадресации = "")
	
	ОтветHTTP 	   = СтруктураОтвета.ПолучитьТелоКакСтроку();
	
	ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
	Если СтруктураОтвета.КодСостояния >= 400 И СтруктураОтвета.КодСостояния < 500 Тогда 
		ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Ошибки 4XX говорят о неправильном запросе - в широком смысле
	 													|Может быть неправильный адрес, ошибка аутентификации, плохой формат запроса
	 													|Подробнее смотри http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html#sec10.4";
	ИначеЕсли СтруктураОтвета.КодСостояния >= 500 И СтруктураОтвета.КодСостояния < 600 Тогда 
		ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Ошибки 5XX говорят о проблемах на сервере (возможно, прокси-сервер)
	 													|Это может быть программная ошибка, нехватка памяти, ошибка конфигурации и т.д.
	 													|Подробнее смотри http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html#sec10.5";
	ИначеЕсли СтруктураОтвета.КодСостояния >= 300 И СтруктураОтвета.КодСостояния < 400  Тогда
		ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + ОшибкаПереадресации;
	КонецЕсли;
	Если ТипЗнч(ОтветHTTP) = Тип("ЧтениеJSON") Тогда 
		ПараметрыJSON  = ?(ОтветHTTP <> "", ДекодироватьИзJSON(ОтветHTTP), Новый Структура);
		Если ПараметрыJSON.Свойство("Message") Тогда
			ОписаниеОшибки = ОписаниеОшибки + " (" + ПараметрыJSON.Message + ")";
		КонецЕсли;		
	КонецЕсли;	
	
	Возврат ОписаниеОшибки;
	
КонецФункции

// Функция - Проверить возможность звонка на данном ПК
// 
// Возвращаемое значение:
//   - 
