&НаКлиенте
// Открыть форму оплаты 
//
Процедура КнопкаОплата(Команда)	
	
	СвойстваОплаты = Элементы.ТаблицаТекущиеКлиенты.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(Контрагент) ИЛИ (СвойстваОплаты <> Неопределено И СвойстваОплаты.Свойство("ВремяЗаписи") 
		И СвойстваОплаты.ВремяЗаписи > Дата(1,1,1)) Тогда	
		ПараметрыОплаты = Новый Структура;
		ПараметрыОплаты.Вставить("СтруктурнаяЕдиница"                , Объект.СтруктурнаяЕдиница);
		ПараметрыОплаты.Вставить("Касса"                             , Касса);
		ПараметрыОплаты.Вставить("ДатаПродажи"                       , ТекущаяДата());
		ПараметрыОплаты.Вставить("ВидОперации"                       , ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа"));
		ПараметрыОплаты.Вставить("Контрагент"                        , ?(Контрагент.Пустая(), СвойстваОплаты.Клиент, Контрагент));
		ПараметрыОплаты.Вставить("ЗакрытьФормуАвтоматически"         , Истина);		
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОплаты", ПараметрыОплаты, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	КонецЕсли;
	
КонецПроцедуры

