// Процедура, Заполнить список времени начала услуг.
//
// Параметры:
//  Элемент						 - 	 - 
//  СписокДополнительныхЗначений - 	 - 
//
Процедура ЗаполнитьСписокВремениНачалаУслуг(Элемент, СтрокаТЧ) Экспорт
	
	Элемент.СписокВыбора.Очистить();
	МассивПериодов = Новый Массив;
	МассивПериодов.Добавить(ОбщегоНазначенияСтоматология.ПолучитьВремяРаботыСтруктурнойЕдиницы(НачалоДня(ДатаНачала), Объект.СтруктурнаяЕдиница));
	
	ИнтервалВремени = ОпределнениеИнтервалаВремени(ИнтервалГрафика);

	СписокВремени = УправлениеСвойствамиСтоматология.ВернутьСписокВремениНаСервере(МассивПериодов, Истина, ИнтервалВремени);
	
	Для Каждого ПредставлениеВремени Из СписокВремени Цикл
		Элемент.СписокВыбора.Добавить(ПредставлениеВремени.Значение, ПредставлениеВремени.Представление);
	КонецЦикла;
	
	Если Элемент.СписокВыбора.НайтиПоЗначению(ДатаНачала) = Неопределено Тогда
		Элемент.СписокВыбора.Добавить(ДатаНачала, Формат(ДатаНачала, "ДФ=ЧЧ:мм"));
	КонецЕсли;
	
	Элемент.СписокВыбора.СортироватьПоЗначению();
	
КонецПроцедуры

