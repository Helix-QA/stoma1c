			Комментарий 		= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария, ?(ЭтоСозданиеСделки, "Создание сделки отменено!", "Изменение реквизитов сделки отменено!"));
		
	    	СделкаАналог 		= ВыборкаАналогичнойСделки.Сделка;
