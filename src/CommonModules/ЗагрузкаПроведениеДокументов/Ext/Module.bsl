							//	И (ДокументРеализация.СуммаДокумента + СуммаОплатыРКО) = СуммаОплатыПКО Тогда
							//	
							//	ЧленствоОбъект.СрокДействияДатой 	= ДатаОплатыРКО;
							//	ЧленствоОбъект.СрокДействияТип 		= Перечисления.Периодичность.День;
							//	ЧленствоОбъект.СрокДействия 		= Цел((ДатаОплатыРКО - НачалоДня(ЧленствоОбъект.ДатаРучнойАктивации)) / 86400);
							//	
							//	Попытка
							//		ЗаписатьДокумент(ЧленствоОбъект, , , Истина);
							//	Исключение
							//		
							//	КонецПопытки;	
							// КонецЕсли;							
							
	#КонецОбласти
	
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				
	#Область Создание_рассрочки
				
				// РАССРОЧКА КОНТРАКТА//
				Если ТаблицаРассрочка.Количество() > 0 Тогда
					Если ТаблицаРассрочка.Итог("СуммаПлатежаПлан") < СтрокаВыборкаПоКонтрактам.СуммаКонтракта Тогда
						НСР 					= ТаблицаРассрочка.Добавить();  
						НСР.ДатаПлатежаПлан 	= СтрокаВыборкаПоКонтрактам.ДатаПродажи;
						НСР.СуммаПлатежаПлан 	= СтрокаВыборкаПоКонтрактам.СуммаКонтракта - ТаблицаРассрочка.Итог("СуммаПлатежаПлан");						
					КонецЕсли;	
					НаборЗаписей                               = РегистрыСведений.СхемыРассрочек.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Основание.Значение      = ДокументРеализация.Ссылка;
					НаборЗаписей.Отбор.Основание.Использование = Истина;
					ДатаПредыдущегоПлатежа = Дата('2001.01.01 01:01:01'); 
					
					ДатыПлатежа 	= Новый СписокЗначений;
					НомерПлатежа 	= 1;
					Для Каждого СтрокаРассрочка ИЗ ТаблицаРассрочка Цикл
						Если СтрокаРассрочка.СуммаПлатежаПлан > 0 Тогда
							НоваяЗапись                = НаборЗаписей.Добавить();
							НоваяЗапись.Период         = СтрокаВыборкаПоКонтрактам.ДатаПродажи;
							НоваяЗапись.ДатаПлатежа    = ?(ДатыПлатежа.НайтиПоЗначению(СтрокаРассрочка.ДатаПлатежаПлан) <> Неопределено, СтрокаРассрочка.ДатаПлатежаПлан + 60*60*24*НомерПлатежа, СтрокаРассрочка.ДатаПлатежаПлан);
							НоваяЗапись.Основание      = ДокументРеализация.Ссылка;
