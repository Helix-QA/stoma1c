// Функция - Получить массив периодов работы.
// 
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСписокПериодовРаботы(СтруктурнаяЕдиница)
	
	ИнтервалыВремени = Справочники.ПериодыРаботы.ПолучитьМассивПериодовРаботы(СтруктурнаяЕдиница); 
	СписокПериодов   = Новый СписокЗначений;
	
	Для Каждого Интервал Из ИнтервалыВремени Цикл
		
		ЗначениеПериода      = Новый Структура("НачалоРаботы, ОкончаниеРаботы", Интервал.НачалоСмены, Интервал.ОкончаниеСмены);
		ПредставлениеПериода = ОбщегоНазначенияКлиентСерверСтоматология.ПолучитьПредставлениеИнтервала(ЗначениеПериода);
		
		СписокВложение = Новый СписокЗначений;
		СписокВложение.Добавить(ЗначениеПериода, ПредставлениеПериода);
		СписокПериодов.Добавить(СписокВложение, ПредставлениеПериода);	
				
	КонецЦикла;	
	
	СписокПериодов.Добавить("Отпуск");
	СписокПериодов.Добавить("Больничный");
	
	Возврат СписокПериодов;

КонецФункции

&НаСервере
// Процедура - Установить доступность отбору интервалы работы
// 
Процедура УстановитьДоступностьОтборуИнтервалыРаботы()
	
	Если ОтборПериод.ДатаНачала = Дата(1,1,1) Тогда 
		Элементы.ИнтервалыРаботыПредст.Доступность 		= Ложь;
		Элементы.ОтборСотрудник.Доступность 			= Ложь;
		Элементы.ОтборСтруктурнаяЕдиница.Доступность 	= Ложь;
	Иначе 
		Элементы.ИнтервалыРаботыПредст.Доступность 		= Истина;
		Элементы.ОтборСотрудник.Доступность 			= Истина;
		Элементы.ОтборСтруктурнаяЕдиница.Доступность 	= Истина;
	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
// Вернуть сумму интервалов времени в минутах
// 
Функция СуммаИнтерваловВМинутах(СписокИнтервала)
	
	СуммМинут                 = 0;
	Для Каждого ЭлементС ИЗ СписокИнтервала Цикл
		СуммМинут = СуммМинут + Цел((ЭлементС.Значение.ОкончаниеРаботы - ЭлементС.Значение.НачалоРаботы) / 60);	
	КонецЦикла;
	
	Возврат СуммМинут;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Вернуть время работы структурной единицы
// 
// Возвращаемое значение:
//   - 
// 
Функция ВернутьВремяРаботыСтруктурнойЕдиницы(знач ОтборСтруктурнаяЕдиница = Неопределено)
	
	СтруктурнаяЕдиница            = ?(Не ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, ОтборСтруктурнаяЕдиница);
	Возврат Новый ФиксированныйМассив(РабочиеДниСтруктурнойЕдиницы(СтруктурнаяЕдиница));	

КонецФункции

&НаКлиенте
// Процедура - Заполнить элемент планирования
// 
// Параметры:
//  ВыбраннаяДата	 - 	 - 
//  СписокИнтервалов - 	 - 
// 
Процедура ЗаполнитьЭлементПланирования(ВыбраннаяДата, СписокИнтервалов)
	
	РезультатПланированияРазовый.Очистить();
	
	Если ТипРабочегоВремени = ПредопределенноеЗначение("Перечисление.ТипыРабочегоВремени.Больничный") Тогда
	    ИнтервалыРаботыПредст = "Больничный";
		СуммаРабочегоВремени  = 0;
    ИначеЕсли ТипРабочегоВремени = ПредопределенноеЗначение("Перечисление.ТипыРабочегоВремени.Отпуск") Тогда
	    ИнтервалыРаботыПредст = "Отпуск";
		СуммаРабочегоВремени  = 0;
	Иначе
		ИнтервалыРаботыПредст = ПолучитьПредставлениеСпискаИнтервалов(СписокИнтервалов);
		СуммаРабочегоВремени  = СуммаИнтерваловВМинутах(СписокИнтервалов);
	КонецЕсли;
	
	НоваяСтрока                       = РезультатПланированияРазовый.Добавить();
	НоваяСтрока.Дата                  = ВыбраннаяДата; 
	НоваяСтрока.ИнтервалыРаботы       = СписокИнтервалов;
	НоваяСтрока.ИнтервалыРаботыПредст = ИнтервалыРаботыПредст;
	НоваяСтрока.СуммаРабочегоВремени  = СуммаРабочегоВремени;
	НоваяСтрока.Сотрудник             = ОтборСотрудник;
	НоваяСтрока.ТипРабочегоВремени    = ТипРабочегоВремени;
	
	ПослеЗакрытияФормыСозданияОповещение(РезультатПланированияРазовый, Неопределено);
	
КонецПроцедуры

&НаКлиенте
// Функция - Получить дату выделенной области
// 
// Параметры:
//  Расшифровка	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьДатуВыделеннойОбласти(Знач Расшифровка)
	
	СтартоваяДата        = Неопределено;
	
	Если Лев(Расшифровка, 1) = "+" Тогда
		Если Лев(Расшифровка, 3) = "+Дн" Тогда			 
			ОписаниеОбл          = ОписаниеОбласти(Прав(Расшифровка,СтрДлина(Расшифровка) - 3));
			СтартоваяДата        = ОписаниеОбл.Дата;										
		КонецЕсли;	
	Иначе 
		СтрокаБуфера 	= СтрокаБуфераФомированияПоИдентификатору(Расшифровка);
		СтартоваяДата 	= СтрокаБуфера.Дата
	КонецЕсли;
	
	Возврат СтартоваяДата;
	
КонецФункции

&НаКлиенте
// Процедура - HTMLПанель планирования
// 
// Параметры:
//  Элемент				 - 	 - 
//  ДанныеСобытия		 - 	 - 
//  СтандартнаяОбработка - 	 - 
// 
Процедура HTMLПанельПланирования(Элемент, ДанныеСобытия, СтандартнаяОбработка)

	Попытка
		
		Если ДанныеСобытия <> Неопределено 
			И ЗначениеЗаполнено(HTMLПанельПланирования) Тогда
			
			propertyName = Элементы.HTMLПанельПланирования.Документ.getElementById("propertyName");
			ИдТекущегоЭлементаHTML = ДанныеСобытия.element.id;
			
			Если propertyName.innertext = "КОНТЕКСТНОЕ_МЕНЮ" Тогда  // обработка контекстного меню
				
				Если ЗначениеЗаполнено(ИдТекущегоЭлементаHTML) Тогда 
					
					СтартоваяДата 	= ПолучитьДатуВыделеннойОбласти(ИдТекущегоЭлементаHTML);
					ДатаТекущегоЭлементаHTML = СтартоваяДата;
					ДнПрописью 		= ДеньНеделиПрописью(ДеньНедели(СтартоваяДата), , Истина);
					Элементы.ТабДокументПланированияКонтекстноеМенюКнопкаСкопироватьДеньСПредыдущейНедели.Заголовок = ДнПрописью;
					Элементы.ТабДокументПланированияКонтекстноеМенюКнопкаСкопироватьДеньСПредыдущейНедели.Картинка = БиблиотекаКартинок[ДеньНеделиПрописью(ДеньНедели(СтартоваяДата))];
					Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьЗаПериод.Картинка 		= БиблиотекаКартинок[ДеньНеделиПрописью(ДеньНедели(СтартоваяДата))];
					
					СтрокаБуфера = СтрокаБуфераФомированияПоИдентификатору(ИдТекущегоЭлементаHTML);
					Если СтрокаБуфера <> Неопределено Тогда
						НомерДняНеделиДляУдаления = ДеньНедели(СтрокаБуфера.Дата);
						ДнПрописью                = ДеньНеделиПрописью(НомерДняНеделиДляУдаления, Истина);
						Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьЗаПериод.Заголовок = "По """ + ДнПрописью + """";
						Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьЗаПериод.Доступность = Истина;
						// Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьВсе.Доступность = Истина;						
					Иначе
						Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьЗаПериод.Заголовок = "За период";
						Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьЗаПериод.Доступность = Ложь;
						// Элементы.ТабДокументПланаЗанятийКонтекстноеМенюКомандаТабДокументУдалитьВсе.Доступность = Ложь;			
					КонецЕсли;
					
					Элементы.ТабДокументПланаЗанятийКонтекстноеМенюГруппаУдалить.Доступность 		= Истина;
					Элементы.ТабДокументПланированияКонтекстноеМенюГруппаСкопировать.Доступность 	= Истина;
				Иначе
					Элементы.ТабДокументПланаЗанятийКонтекстноеМенюГруппаУдалить.Доступность 		= Ложь;
					Элементы.ТабДокументПланированияКонтекстноеМенюГруппаСкопировать.Доступность 	= Ложь;		
				КонецЕсли;
				
				propertyName.innertext = "";
				
			Иначе 	
				
				Если ЗначениеЗаполнено(ИдТекущегоЭлементаHTML) Тогда
					Если Лев(ИдТекущегоЭлементаHTML, 1) = "+" Тогда // обработка добавления
						
						// Если НЕ ФормированиеИнтерваловЗавершено() Тогда 
						// 	Возврат;
						// КонецЕсли;
						
						ПериодЗаполнения     = Новый СтандартныйПериод(ОтборПериод.ДатаНачала, ОтборПериод.ДатаОкончания);
						СтартоваяДата        = Неопределено;
						
						Если Лев(ИдТекущегоЭлементаHTML, 3) = "+Дн" Тогда
							
							ОписаниеОбл = ОписаниеОбласти(Прав(ИдТекущегоЭлементаHTML, СтрДлина(ИдТекущегоЭлементаHTML) - 3));		
							
							Если ОписаниеОбл <> Неопределено Тогда
								СтартоваяДата = ОписаниеОбл.Дата;
								ДатаТекущегоЭлементаHTML = СтартоваяДата;
							Иначе
								Возврат;
							КонецЕсли;
							
						КонецЕсли;	
						
						ИнтервалыСформированы = ФормированиеИнтерваловЗавершено(Ложь);
						
						// Если заполнены все отборы - заполним элемент разово без открытия формы создания
						Если ЗначениеЗаполнено(ОтборСотрудник) И ИнтервалыСформированы И ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда
							
							ПроверитьВхождениеИнтерваловВГрафикРаботыСЕ(СтартоваяДата);
							
							// иначе - откроем форму создания	
						Иначе
							
							ИнтервалыРаботы = ОтборИнтервалыРаботы.Скопировать();
							Если НЕ ИнтервалыСформированы Тогда
								ИнтервалыРаботы.Очистить();
							КонецЕсли;
							
							ПараметрыПланирования = Новый Структура;	
							ПараметрыПланирования.Вставить("ПериодЗаполнения"   , ПериодЗаполнения);
							ПараметрыПланирования.Вставить("СтартоваяДата"      , СтартоваяДата);
							ПараметрыПланирования.Вставить("Сотрудник"          , ОтборСотрудник);
							ПараметрыПланирования.Вставить("ИнтервалыРаботы"	, ИнтервалыРаботы);
							
							Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияФормыСозданияОповещение", ЭтотОбъект);
							ОткрытьФорму("Обработка.ПланированиеИндивидуальногоГрафика.Форма.ФормаСоздания",ПараметрыПланирования, ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);			
							
						КонецЕсли;
					Иначе 
						СтрокаБуфера = СтрокаБуфераФомированияПоИдентификатору(ИдТекущегоЭлементаHTML);
						Если СтрокаБуфера <> Неопределено Тогда 
							Если СтрНайти(ДанныеСобытия.Element.className, "STAFFER") > 0 Тогда  // обработка открытия сотрудника
								Если ЗначениеЗаполнено(СтрокаБуфера.Сотрудник) Тогда
									ПоказатьЗначение(,СтрокаБуфера.Сотрудник);
								КонецЕсли;
								// ИначеЕсли ДанныеСобытия.Element.className = "ROOM" Тогда // обработка открытия помещения
								// 	Если ЗначениеЗаполнено(СтрокаБуфера.Помещение) Тогда
								// 		ПоказатьЗначение(,СтрокаБуфера.Помещение);
								// 	КонецЕсли;
							КонецЕсли;
						КонецЕсли;		
					КонецЕсли;	 
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;	
		
	Исключение
	КОнецПопытки;
	
	// ЭтаФорма.ТекущийЭлемент = Элементы.ФормаКомандаСформировать;
	
КонецПроцедуры

