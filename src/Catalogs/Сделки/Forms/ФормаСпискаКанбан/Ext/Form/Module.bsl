// Функция, возвращает запрос с установленными параметрами, для списка формы.
//
Функция ЗапросПолученияДанных(СтруктураОтборов, Сделка = Неопределено, ИсключаемыеСделки = Неопределено)
	
	// Текст запроса без отборов (чистый).
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЭтапыСделок.Ссылка КАК ЭтапСделки,
	|	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа
	|ПОМЕСТИТЬ ЭтапыСделок
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ВидСделки В(&ВидСделки)
	|	И НЕ ЭтапыСделок.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка,
	|	999999
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ИмяПредопределенныхДанных = ""Отказ""
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка,
	|	999998
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ИмяПредопределенныхДанных = ""Успех""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.НаименованиеСокращенное КАК ПредставлениеСделки,
	|	Сделки.ПометкаУдаления КАК ПометкаУдаления,
	|	Сделки.ДатаСделки КАК ДатаСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.Контрагент КАК Клиент,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.Контрагент) КАК ПредставлениеКлиента,
	|	Сделки.Контрагент.Телефон КАК НомерТелефона,
	|	Сделки.ПричинаОтказа КАК ПричинаОтказа,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.ПричинаОтказа) КАК ПричинаОтказаНаименование,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.ИсточникИнформации) КАК ПредставлениеРекламногоИсточника,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.КаналПривлечения) КАК ПредставлениеКаналаПривлечения,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.КаналПривлеченияЗначение) КАК ПредставлениеЗначенияКаналаПривлечения,
	|	Сделки.Менеджер КАК Куратор,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.Менеджер) КАК ПредставлениеКуратора,
	|	Сделки.Врач КАК Врач,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.Врач) КАК ПредставлениеВрача,
	|	Сделки.Примечание КАК Примечание,
	|	Сделки.Описание КАК Комментарий,
	|	ПРЕДСТАВЛЕНИЕ(Сделки.Специализация) КАК ПредставлениеСпециализации,
	|	Сделки.ПредыдущийПрием <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка) КАК ЭтоПовторныйПрием,
	|	КонтрагентыСведенияДляСписка.Статус КАК СтатусПациента
	|ПОМЕСТИТЬ ДанныеСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|		ПО Сделки.Ссылка = СделкиСведенияДляСписка.Сделка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Сделки.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|	И ВЫБОР
	|			КОГДА &СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КонтрагентыСведенияДляСписка.Статус = &СтатусПациента
	|		КОНЕЦ
	|	И &ОтборПоСсылке
	|	И &УсловиеПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеМенеджер
	|	И &УсловиеВрач
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаЗавершенияСделки
	|	И &УсловиеДатаЗапланированнойЗадачи
	|	И &УсловиеОтборБезНазначенногоПриема
	|	И &УсловиеОтборБезЗадач
	|	И &УсловиеЭтап
	|	И &УсловиеЗавершена
	|	И &УсловиеПричинаОтказа
	|	И &УсловиеИсключаемыеСделки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(Взаимодействие.Ссылка) КАК КоличествоЗадач,
	|	Взаимодействие.Сделка КАК Сделка
	|ПОМЕСТИТЬ ЗадачиКоличество
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Сделка В
	|			(ВЫБРАТЬ
	|				ДанныеСделок.Сделка
	|			ИЗ
	|				ДанныеСделок КАК ДанныеСделок)
	|	И НЕ Взаимодействие.ПометкаУдаления
	|	И НЕ Взаимодействие.Выполнена
	|
	|СГРУППИРОВАТЬ ПО
	|	Взаимодействие.Сделка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Профосмотры.Сделка КАК Сделка,
	|	МАКСИМУМ(Профосмотры.НаправившийВрач) КАК НаправившийВрач
	|ПОМЕСТИТЬ НаправившиеВрачи
	|ИЗ
	|	РегистрСведений.Профосмотры КАК Профосмотры
	|ГДЕ
	|	Профосмотры.Сделка В
	|			(ВЫБРАТЬ
	|				ДанныеСделок.Сделка
	|			ИЗ
	|				ДанныеСделок КАК ДанныеСделок)
	|
	|СГРУППИРОВАТЬ ПО
	|	Профосмотры.Сделка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЭтапыСделок.ЭтапСделки КАК ЭтапСделки,
	|	ЭтапыСделок.ЭтапСделки.Наименование КАК НаименованиеЭтапа,
	|	ЭтапыСделок.ЭтапСделки.ЦветЭтапа КАК ЦветЭтапа,
	|	ЭтапыСделок.ЭтапСделки.ИмяПредопределенныхДанных КАК ИмяПредопределенногоЭтапа,
	|	ДанныеСделок.Сделка КАК Сделка,
	|	ДанныеСделок.ПредставлениеСделки КАК ПредставлениеСделки,
	|	ДанныеСделок.ПометкаУдаления КАК ПометкаУдаления,
	|	ДанныеСделок.ДатаСделки КАК ДатаСделки,
	|	ДанныеСделок.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	ДанныеСделок.Клиент КАК Клиент,
	|	ДанныеСделок.ПредставлениеКлиента КАК ПредставлениеКлиента,
	|	ДанныеСделок.НомерТелефона КАК НомерТелефона,
	|	ДанныеСделок.ПричинаОтказа КАК ПричинаОтказа,
	|	ДанныеСделок.ПричинаОтказаНаименование КАК ПричинаОтказаНаименование,
	|	ДанныеСделок.ПредставлениеРекламногоИсточника КАК ПредставлениеРекламногоИсточника,
	|	ДанныеСделок.ПредставлениеКаналаПривлечения КАК ПредставлениеКаналаПривлечения,
	|	ДанныеСделок.ПредставлениеЗначенияКаналаПривлечения КАК ПредставлениеЗначенияКаналаПривлечения,
	|	ДанныеСделок.Куратор КАК Куратор,
	|	ДанныеСделок.ПредставлениеКуратора КАК ПредставлениеКуратора,
	|	ДанныеСделок.Врач КАК Врач,
	|	ДанныеСделок.ПредставлениеВрача КАК ПредставлениеВрача,
	|	ДанныеСделок.Примечание КАК Примечание,
	|	ДанныеСделок.Комментарий КАК Комментарий,
	|	ДанныеСделок.ПредставлениеСпециализации КАК ПредставлениеСпециализации,
	|	ДанныеСделок.ЭтоПовторныйПрием КАК ЭтоПовторныйПрием,
	|	ЗадачиКоличество.КоличествоЗадач КАК КоличествоЗадач,
	|	НаправившиеВрачи.НаправившийВрач.НаименованиеСокращенное КАК НаправившийВрач,
	|	ДанныеСделок.СтатусПациента КАК СтатусПациента
	|ИЗ
	|	ЭтапыСделок КАК ЭтапыСделок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеСделок КАК ДанныеСделок
	|			ЛЕВОЕ СОЕДИНЕНИЕ ЗадачиКоличество КАК ЗадачиКоличество
	|			ПО ДанныеСделок.Сделка = ЗадачиКоличество.Сделка
	|			ЛЕВОЕ СОЕДИНЕНИЕ НаправившиеВрачи КАК НаправившиеВрачи
	|			ПО ДанныеСделок.Сделка = НаправившиеВрачи.Сделка
	|		ПО ЭтапыСделок.ЭтапСделки = ДанныеСделок.ЭтапСделки
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыСделок.НомерЭтапа,
	|	ДатаСделки УБЫВ
	|ИТОГИ ПО
	|	ЭтапСделки");
	
	ПрименитьУсловияФильтрации(Запрос, СтруктураОтборов, Сделка, ИсключаемыеСделки);
	
	Возврат Запрос;
	
КонецФункции	

&НаСервереБезКонтекста
// Процедура, применяет условия фильтрации к запросу получения данных.
//
Процедура ПрименитьУсловияФильтрации(Запрос, СтруктураОтборов, Сделка = Неопределено, ИсключаемыеСделки = Неопределено)
	
	// Отбор по текущему виду сделки.
	Запрос.УстановитьПараметр("ВидСделки", СтруктураОтборов.ВидСделки);
	
	// Отбор по статусу пациента (новый / постоянный).
	Запрос.УстановитьПараметр("СтатусПациента", СтруктураОтборов.ОтборСтатусПациента);
	
	// Устанавливаем отбор по ссылке для получения данных конкретной сделки.
	Если ЗначениеЗаполнено(Сделка) Тогда
		УсловиеСсылка	 = "Сделки.Ссылка = &Ссылка";
		Запрос.Текст	 = СтрЗаменить(Запрос.Текст, "&ОтборПоСсылке", УсловиеСсылка);
		Запрос.Текст	 = СтрЗаменить(Запрос.Текст, "ЛЕВОЕ СОЕДИНЕНИЕ ДанныеСделок", "ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеСделок");
		Запрос.УстановитьПараметр("Ссылка", Сделка);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСсылке", "ИСТИНА");
	КонецЕсли;
	
	// Получение первой в очереди на вывод сделки (связано с ограничением - вывод первых 15 сделок в колонку).
	Если ЗначениеЗаполнено(ИсключаемыеСделки) Тогда
		
		УсловиеИсключаемыеСделки =
		"НЕ Сделки.Ссылка В(&ИсключаемыеСделки)
		|
		|УПОРЯДОЧИТЬ ПО 
		|	ДатаСделки УБЫВ";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеИсключаемыеСделки", УсловиеИсключаемыеСделки);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБРАТЬ РАЗРЕШЕННЫЕ", "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЛЕВОЕ СОЕДИНЕНИЕ ДанныеСделок", "ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеСделок");
		
		Запрос.УстановитьПараметр("ИсключаемыеСделки", ИсключаемыеСделки);
		
		УсловиеЭтап	 = "Сделки.ЭтапСделки = &ЭтапСделки";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", УсловиеЭтап);
		Запрос.УстановитьПараметр("ЭтапСделки", СтруктураОтборов.ЭтапСделки);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеИсключаемыеСделки", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап"				, "ИСТИНА");		
		
	КонецЕсли;
	
	// Отбор пометка удаления.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПометкаУдаления)
		И СтруктураОтборов.ОтборПометкаУдаления[0].Значение = Истина Тогда
		
		УсловиеПометкаУдаления = СтруктураОтборов.ОтборПометкаУдаления.ДоступныеЗначения[0].Представление + "Сделки.ПометкаУдаления = ИСТИНА";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", УсловиеПометкаУдаления);
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор структурная единица.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Сделки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Если СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.Количество() <> 0 Тогда 
			ВариантОтбора = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление;
		Иначе 
			ВариантОтбора = "";
		КонецЕсли;			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", ВариантОтбора + "Сделки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)");			
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения());		
		// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор сотрудник регистрации.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации) Тогда
		УсловиеСотрудникРегистрации = СтруктураОтборов.ОтборСотрудникРегистрации.ДоступныеЗначения[0].Представление + "Сделки.Автор В (&ОтборСотрудникРегистрации)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
		Запрос.УстановитьПараметр("ОтборСотрудникРегистрации", СтруктураОтборов.ОтборСотрудникРегистрации.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор менеджер.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер) Тогда
		УсловиеМенеджер = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения[0].Представление + "Сделки.Менеджер В (&ОтборМенеджер)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", УсловиеМенеджер);
		Запрос.УстановитьПараметр("ОтборМенеджер", СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор врач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборВрач) Тогда
		УсловиеВрач = СтруктураОтборов.ОтборВрач.ДоступныеЗначения[0].Представление + "Сделки.Врач В (&ОтборВрач)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВрач", УсловиеВрач);
		Запрос.УстановитьПараметр("ОтборВрач", СтруктураОтборов.ОтборВрач.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеВрач", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор рекламный источник.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник) Тогда
		УсловиеРекламныйИсточник = СтруктураОтборов.ОтборРекламныйИсточник.ДоступныеЗначения[0].Представление + "Сделки.ИсточникИнформации В (&ОтборРекламныйИсточник)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		Запрос.УстановитьПараметр("ОтборРекламныйИсточник", СтруктураОтборов.ОтборРекламныйИсточник.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", "ИСТИНА");
	КонецЕсли;
	
	// Отбор канал привлечения.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКаналПривлечения) Тогда
		УсловиеКаналПривлечения = СтруктураОтборов.ОтборКаналПривлечения.ДоступныеЗначения[0].Представление + "Сделки.КаналПривлечения В (&ОтборКаналПривлечения)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", УсловиеКаналПривлечения);
		Запрос.УстановитьПараметр("ОтборКаналПривлечения", СтруктураОтборов.ОтборКаналПривлечения.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", "ИСТИНА");
	КонецЕсли;
	
	// Отбор причина отказа.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПричинаОтказа) Тогда
		УсловиеПричинаОтказа = СтруктураОтборов.ОтборПричинаОтказа.ДоступныеЗначения[0].Представление + "Сделки.ПричинаОтказа В (&ОтборПричинаОтказа)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПричинаОтказа", УсловиеПричинаОтказа);
		Запрос.УстановитьПараметр("ОтборПричинаОтказа", СтруктураОтборов.ОтборПричинаОтказа.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПричинаОтказа", "ИСТИНА");
	КонецЕсли;
	
	// Отбор дата создания сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаСоздания) Тогда   
		
		УсловиеДатаСоздания = "Сделки.ДатаСделки МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", УсловиеДатаСоздания);
		ДатаНачала = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));

	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", "ИСТИНА")
		
	КонецЕсли;
	
	// Отбор дата завершения сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗавершенияСделки) Тогда   
		
		УсловиеДатаЗавершенияСделки = "Сделки.ДатаЗавершенияСделки МЕЖДУ &ДатаЗавершенияСделкиДатаНачала И &ДатаЗавершенияСделкиДатаОкончания";
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗавершенияСделки", УсловиеДатаЗавершенияСделки);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗавершенияСделки[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗавершенияСделки[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаЗавершенияСделкиДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),    ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаЗавершенияСделкиДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания), ДатаОкончания, Дата(3999,12,31)));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗавершенияСделки", "ИСТИНА");		
	КонецЕсли;
	
	// Отбор дата запланированной задачи.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗапланированнойЗадачи) Тогда
		Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПредварительнаяЗапись)
		И СтруктураОтборов.ОтборПредварительнаяЗапись[0].Значение = Ложь Тогда
			УсловиеДатаЗапланированнойЗадачи = "СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
			УсловиеОтборБезНазначенногоПриема = СтруктураОтборов.ОтборПредварительнаяЗапись.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
			УсловиеДатаЗапланированнойЗадачи = "(" + УсловиеДатаЗапланированнойЗадачи + ") ИЛИ (" + УсловиеОтборБезНазначенногоПриема + ")";
		Иначе 
			УсловиеДатаЗапланированнойЗадачи = "СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		КонецЕсли;	
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания;

		// УсловиеДатаЗапланированнойЗадачи = "И СделкиСведенияДляСписка.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));	
		Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
		
	Иначе                               
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", "ИСТИНА");
	КонецЕсли;
	
	// Отбор признак наличия назначенного приема.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПредварительнаяЗапись)
		И СтруктураОтборов.ОтборПредварительнаяЗапись[0].Значение = Ложь Тогда
		
		УсловиеОтборБезНазначенногоПриема = СтруктураОтборов.ОтборПредварительнаяЗапись.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезНазначенногоПриема", УсловиеОтборБезНазначенногоПриема);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезНазначенногоПриема", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор без задач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача)
		И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь Тогда
		
		УсловиеОтборБезЗадач = СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление + "СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка) И СделкиСведенияДляСписка.Сделка.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", "ИСТИНА");
	КонецЕсли;
	
	// Отбор завершения задачи сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗавершена)
		И СтруктураОтборов.ОтборЗавершена[0].Значение = Истина Тогда
		
		УсловиеЗавершена = СтруктураОтборов.ОтборЗавершена.ДоступныеЗначения[0].Представление + "Сделки.РезультатСделки <> ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", УсловиеЗавершена);
		
	ИначеЕсли ЗначениеЗаполнено(СтруктураОтборов.ОтборЗавершена)
		И СтруктураОтборов.ОтборЗавершена[0].Значение = Ложь Тогда			
		
		УсловиеЗавершена = СтруктураОтборов.ОтборЗавершена.ДоступныеЗначения[0].Представление + "Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)";			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", УсловиеЗавершена);
		
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЗавершена", "ИСТИНА");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает пакет запроса с элементами для создания отборов.
//
Функция ПолучитьПакетЗапросаЗначенийДляОтборов(ТекущийСотрудник)
	
	МассивСтруктурныхЕдиниц 	= Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ТекущийСотрудник, "Массив");		
	МассивВидовСделок 			= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиниц);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивВидовСделок"	, МассивВидовСделок);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ЛюбаяПричина"		, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.ЛюбаяПричина"));
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.ИсточникИнформации КАК ИсточникИнформации,
	|	Сделки.КаналПривлечения КАК КаналПривлечения,
	|	Сделки.Автор КАК Автор,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.Менеджер КАК Менеджер,
	|	Сделки.Врач КАК Врач
	|ПОМЕСТИТЬ ТаблицаСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.ИсточникИнформации,
	|	Сделки.КаналПривлечения,
	|	Сделки.Автор,
	|	Сделки.Менеджер,
	|	Сделки.ЭтапСделки,
	|	Сделки.Врач
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Менеджер
	|			ИЗ
	|				ТаблицаСделок)
	|	И Сотрудники.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Врач
	|			ИЗ
	|				ТаблицаСделок)
	|	И Сотрудники.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Автор
	|			ИЗ
	|				ТаблицаСделок)
	|	И Сотрудники.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РекламныеИсточники.Ссылка КАК Ссылка,
	|	РекламныеИсточники.Представление КАК Представление
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.ИсточникИнформации
	|			ИЗ
	|				ТаблицаСделок)
	|	И РекламныеИсточники.Ссылка <> ЗНАЧЕНИЕ(Справочник.РекламныеИсточники.ПустаяСсылка)
	|	И РекламныеИсточники.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Представление КАК Представление
	|ПОМЕСТИТЬ ТаблицаВидовСделок
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Ссылка В(&МассивВидовСделок)
	|	И ВидыСделок.ПометкаУдаления = ЛОЖЬ
	|	И (ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.Представление КАК Представление
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.ЭтапСделки
	|			ИЗ
	|				ТаблицаСделок
	|			СГРУППИРОВАТЬ ПО
	|				ТаблицаСделок.ЭтапСделки)
	|	И ЭтапыСделок.Ссылка <> ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|	И ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА ЭтапыСделок.Предопределенный
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЭтапыСделок.ВидСделки В
	|					(ВЫБРАТЬ
	|						ТаблицаВидовСделок.Ссылка КАК Ссылка
	|					ИЗ
	|						ТаблицаВидовСделок КАК ТаблицаВидовСделок)
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыСделок.Предопределенный,
	|	ЭтапыСделок.ВидСделки,
	|	ЭтапыСделок.НомерЭтапа,
	|	Ссылка УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Теги.Ссылка КАК Ссылка,
	|	Теги.Представление КАК Представление
	|ИЗ
	|	Справочник.Теги КАК Теги
	|ГДЕ
	|	Теги.ПометкаУдаления = ЛОЖЬ
	|	И Теги.Ссылка <> ЗНАЧЕНИЕ(Справочник.Теги.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СтатусыКлиентов.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СтатусыКлиентов.Ссылка) КАК Представление
	|ИЗ
	|	Перечисление.СтатусыКонтрагентов КАК СтатусыКлиентов
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыКлиентов.Порядок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СтруктурныеЕдиницы.Ссылка) КАК Представление
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Представление КАК Представление
	|ИЗ
	|	ТаблицаВидовСделок КАК ВидыСделок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПричиныОтказов.Ссылка КАК Ссылка,
