
&НаКлиенте
Перем ИскомыйКлиент;

#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	
	РежимРаботыЕдинаяСеть 					= Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть; 
	ИспользоватьБезПодключенияОборудования 	= ?(ЗначениеЗаполнено(Объект.Касса), Объект.Касса.ИспользоватьБезПодключенияОборудования, Ложь);	
	ККТ                                     = Объект.Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;
		
	// Элементы.ГруппаРасшифровка.Ширина             = ?(Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта, 134, 140);
	// Элементы.ГруппаРасшифровкаДинамические.Ширина = ?(Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта, 134, 140);
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("Расшифровка"  , "ГруппаРасшифровка");	
	СтруктураМеню.Вставить("Дополнительно", "ГруппаДополнительно");	
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	ЭтотОбъект.ЗаблокироватьРедактирование = ЗначениеЗаполнено(Объект.НомерЧекаККМ);
	
	СоздатьЭлементыРасшифровкиПлатежа();
	УстановитьВидимость();
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
		РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);		
	КонецЕсли;
	
	НастройкаШириныЭлементовФормы();	

КонецПроцедуры

// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
	Иначе
		Элементы.ГруппаСостояниеОбъекта.Видимость = Ложь;	
	КонецЕсли; 
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

КонецПроцедуры

// Процедура - После записи на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);	
		
КонецПроцедуры

&НаКлиенте
// Обработчик после записи формы на клиенте
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	УстановитьВидимость(); 
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВзносНаЛицевойСчет") Тогда
		Оповестить("ПРОВЕДЕН_ВЗНОС_НА_ЛИЦЕВОЙ_СЧЕТ");
	КонецЕсли;
	// Оповестить динамические списки
	МассивТипов = Новый Массив;
	Для Каждого СтрокаТ ИЗ Объект.РасшифровкаПлатежа Цикл
		Если ЗначениеЗаполнено(СтрокаТ.ДокументОснования) И МассивТипов.Найти(ТипЗнч(СтрокаТ.ДокументОснования)) = Неопределено Тогда
			ОповеститьОбИзменении(СтрокаТ.ДокументОснования);
			МассивТипов.Добавить(ТипЗнч(СтрокаТ.ДокументОснования));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗакрытием" формы
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	// Прверить наопминания для клиентов
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ПроверитьТекущиеНапоминанияПоПосещениямСтоматология(Объект.Контрагент);
	КонецЕсли;			
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОсновныхЭлементовУправления

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Статья".
//
Процедура СтатьяПриИзменении(Элемент)	
	
	Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл	
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Статья) ИЛИ Объект.СтатьяВТаблице = Ложь Тогда 
			СтрокаТЧ.Статья = Объект.Статья;
		КонецЕсли;
	КонецЦикла;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтКлиента") Тогда
		СоздатьЭлементыРасшифровкиПлатежа();
	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
// Обработчик изменения типа денежных средств
//
Процедура ТипДенежныхСредствПриИзменении(Элемент)
    УстановитьВидимость();
	НастройкаШириныЭлементовФормы();	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля Касса.
//
Процедура КассаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	мПараметрыВыбора = Новый Структура;
	мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("КассаНачалоВыбораЗавершение", ЭтотОбъект); 
	ОткрытьФорму("Справочник.Кассы.ФормаВыбора", мПараметрыВыбора,,,,,ОписаниеОповещения , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Касса начало выбора завершение
//
// Параметры:
//  ВыбранноеЗначение		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура КассаНачалоВыбораЗавершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	
	Если ВыбранноеЗначение <> Неопределено Тогда 
		Объект.Касса = ВыбранноеЗначение;
		ККТ = ОпределитьТипОборудования(Объект.Касса);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля Касса.
//
Процедура КассаПриИзменении(Элемент)
	
	ККТ = ОпределитьТипОборудования(Объект.Касса);
		
КонецПроцедуры

 &НаКлиенте
