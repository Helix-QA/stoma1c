
#Область ОписаниеПеременных

&НаКлиенте
Перем ИскомыйКлиент;     

#КонецОбласти

#Область ОбработчикиСобытийФоры

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.ЗначенияЗаполнения.Свойство("Контрагент") Тогда 
		Объект.ЗадачаПредмет = Параметры.ЗначенияЗаполнения.Контрагент;
	КонецЕсли;
	
	// Обработчик подсистемы "Дополнительные отчеты и обработки"
	ДополнительныеОтчетыИОбработкиСтоматология.ПриСозданииНаСервере(ЭтаФорма);	
	
	Объект.ВидОперации   = ?(Параметры.Свойство("ВидОперации"),Параметры.ВидОперации,Объект.ВидОперации);
	Объект.ЗадачаПредмет = ?(Параметры.Свойство("Клиент"),Параметры.Клиент,Объект.ЗадачаПредмет);
	Объект.ВходящийЗвонокАбонент = Объект.ЗадачаПредмет;
    Объект.ВходящийЗвонокНомерТелефона = Объект.ЗадачаПредмет.Телефон;
	// Установка заголовка
	ЭтаФорма.Заголовок = Строка(Объект.ВидОперации);
		
	// Установка информации об авторе
	Элементы.ИнформацияАвтор.Заголовок = "Создано: " + Формат(Объект.Дата, "ДФ='дд ММММ ""в"" ЧЧ:мм, '") + Объект.АвторДокумента.Наименование;
//"Создано: "+Объект.АвторДокумента.Наименование+", "+Строка(Объект.Дата);
		
	// Сохранение вводимых значений
	СохранениеВводимыхЗначений.ЗаполнитьСписокВыбора(ЭтаФорма, ЭлементыДляСохранения(), ЭтаФорма.ИмяФормы);

	ГруппаКонтрагентов = Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);	
	
	Если Параметры.Свойство("Основание") И ЗначениеЗаполнено(Параметры.Основание) И ТипЗнч(Параметры.Основание) = Тип("Структура")
		И Объект.ВидОперации = Перечисления.ВидыОперацийВзаимодействия.ТелефонныйЗвонокВходящий Тогда
		
			Параметры.Основание.Свойство("ВходящийЗвонокАбонент"      ,Объект.ВходящийЗвонокАбонент);
			Параметры.Основание.Свойство("ВходящийЗвонокНомерТелефона",Объект.ВходящийЗвонокНомерТелефона);
			Параметры.Основание.Свойство("ИсточникИнформации"         ,Объект.ИсточникИнформации);
			
	КонецЕсли;	
		
	Если ЗначениеЗаполнено(Объект.ПредварительнаяЗаписьНаСледующийПрием) Тогда	
		Элементы.ДекорацияПЗНаСледующийприем.Заголовок = СформироватьПредставлениеПЗ(Объект.ПредварительнаяЗаписьНаСледующийПрием);
	КонецЕсли;
	Элементы.СтруктурнаяЕдиницаНадпись.Заголовок = Объект.СтруктурнаяЕдиница;
	
КонецПроцедуры

&НаКлиенте
// Обработчик при открытии формы на клиенте
//
Процедура ПриОткрытии(Отказ)
	
    ОбновитьОтображениеДанных();	
	
	Если Объект.ИсточникИнформации = ПредопределенноеЗначение("Справочник.РекламныеИсточники.ДругойПациент") Тогда
		Элементы.ИсточникИнформацииКлиент.Видимость = Истина;
	Иначе
		Элементы.ИсточникИнформацииКлиент.Видимость = Ложь;
	КонецЕсли;	

КонецПроцедуры

&НаСервере
// Обработчик при записи на сервре 
//
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Сохранение вводимых значений
	СохранениеВводимыхЗначений.ОбновитьСпискиВыбора(ЭтаФорма, ЭлементыДляСохранения(), ЭтаФорма.ИмяФормы);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиЭлементовФормы

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура КонтрагентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура("ТекущаяСтрока", Объект.ЗадачаПредмет);
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты", ПараметрыОткрытия,,,,,Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры  

&НаКлиенте 
// Процедура, Обработчик события "СтруктурнаяЕдиницаНадписьНажатие". 
//
Процедура СтруктурнаяЕдиницаНадписьНажатие(Элемент)  
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ЭтоПользователь", Истина);
    СтруктураПараметров.Вставить("Ссылка", ОбщегоНазначенияСтоматология.ДоступныеСтруктурныеЕдиницы()); 
	СтруктураПараметров.Вставить("ВидСравненияКомпоновкиДанных", ВидСравненияКомпоновкиДанных.ВСписке);
	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаВыбора", СтруктураПараметров,,,,,Новый ОписаниеОповещения("СтруктурнаяЕдиницаНадписьНажатиеЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		

КонецПроцедуры

&НаКлиенте 
// Процедура, Обработчик события "КонтрагентПриИзменении" элемента.
//
Процедура КонтрагентПриИзменении(Элемент) 
	
	ОбновитьТелефонныйНомерПоКлиенту(); 
	
КонецПроцедуры  

&НаКлиенте 
