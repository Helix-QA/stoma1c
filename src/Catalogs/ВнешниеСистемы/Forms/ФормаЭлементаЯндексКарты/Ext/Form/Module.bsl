// Процедура - удаляет рубрику и перестраивает динамические элементы.
//
Процедура УдалитьЭлементыНаСервере(ИмяКоманды)
	
	ИндексСтроки = СтрРазделить(ИмяКоманды,"_")[1];
	ЯндексИдентификаторРубрики.Удалить(ИндексСтроки);
	УдалитьДинамическиеЭлементы(Элементы.ГруппаРубрики, Элементы.ГруппаРубрика_Шаблон);
	ПостроитьДинамическиеЭлементы();
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
// Процедура - удаляет динамические элементы.
//
Процедура УдалитьДинамическиеЭлементы(ГруппаДляУдаления, ШаблонГруппы)
	
	МассивУдаляемых = Новый Массив;
	
	Для Каждого ЭлементГруппы Из ГруппаДляУдаления.ПодчиненныеЭлементы Цикл
		Если ЭлементГруппы <> ШаблонГруппы Тогда
			МассивУдаляемых.Добавить(ЭлементГруппы);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементФормы Из МассивУдаляемых Цикл
		Элементы.Удалить(ЭлементФормы);  
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - создает динамические элементы.
//
Процедура ПостроитьДинамическиеЭлементы()
	
	Счетчик = 0;
	Для Каждого СтрокаТ Из ЯндексИдентификаторРубрики Цикл
		
		ГруппаФормы				 			= УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(ЭтаФорма, Элементы.ГруппаРубрика_Шаблон, Счетчик, Элементы.ГруппаРубрики);
		ДекорацияФормы			 			= УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(ЭтаФорма, Элементы.ДекорацияРубрика_Шаблон, Счетчик,, ГруппаФормы); 
		КнопкаФормы				 			= УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(ЭтаФорма, Элементы.УдалитьРубрику_Шаблон, Счетчик, ГруппаФормы); 
		Если СтрДлина(СтрокаТ.Представление) > 31 Тогда
			ДекорацияФормы.Ширина			= 23;
			ДекорацияФормы.Высота			= 1;
		КонецЕсли;
		ДекорацияФормы.Заголовок 			= СтрокаТ.Представление;
		КнопкаФормы.Доступность				= ПравоДоступа("Редактирование", Метаданные.Справочники.СтруктурныеЕдиницы);
		
		Счетчик 							= Счетчик + 1;
		
	КонецЦикла;
	Элементы.КомандаПодобратьИдентификаторРубрики.Доступность = ПравоДоступа("Редактирование", Метаданные.Справочники.СтруктурныеЕдиницы);
	Если ЯндексИдентификаторРубрики.Количество() = 3 Тогда
		Элементы.КомандаПодобратьИдентификаторРубрики.Видимость = Ложь;
	Иначе
		Элементы.КомандаПодобратьИдентификаторРубрики.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - подбирает идентификаторы рубрик.
