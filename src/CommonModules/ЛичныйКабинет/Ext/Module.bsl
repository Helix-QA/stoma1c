				ПараметрыСтруктурнойЕдиницы = Новый Структура("id", СтрЕдиница.УникальныйИдентификаторСтруктурнойЕдиницы); 
			КонецЕсли;	
			МассивПараметровСтруктурныхЕдиниц.Добавить(ПараметрыСтруктурнойЕдиницы);
			
