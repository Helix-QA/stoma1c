// Функция, возвращает данные видов сделок.
//
Функция ПолучитьДанныеВидовСделок()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка КАК Ссылка,
	|	ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыСделок.СтруктурныеЕдиницыПрименения КАК ВидыСделокСтруктурныеЕдиницыПрименения
	|ГДЕ
	|	НЕ ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка.ПометкаУдаления
	|	И ВидыСделокСтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница В (&СтруктурнаяЕдиница, ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ИмяЭлемента, ИндексЭлемента = Истина)
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	КонецЕсли;
	
КонецФункции

