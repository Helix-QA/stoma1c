
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

#Область Проведение

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПриемТовары.Ссылка КАК Документ,
	|	ПриемТовары.Ссылка.Дата КАК Период,
	|	ПриемТовары.Ссылка.Склад КАК Склад,
	|	ПриемТовары.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПриемТовары.Ссылка.Контрагент КАК Контрагент,
	|	ПриемТовары.НомерСтроки КАК НомерСтроки,
	|	ПриемТовары.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА ПриемТовары.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	ПриемТовары.Количество КАК Количество,
	|	ПриемТовары.СтавкаНДС КАК СтавкаНДС,
	|	ПриемТовары.Сумма КАК Сумма
	|ПОМЕСТИТЬ ТаблицаЗапасыНаСкладах
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПриемЗапасы.Ссылка КАК Ссылка,
	|		ПриемЗапасы.НомерСтроки КАК НомерСтроки,
	|		ПриемЗапасы.Номенклатура КАК Номенклатура,
	|		ПриемЗапасы.Партия КАК Партия,
	|		ПриемЗапасы.Количество КАК Количество,
	|		ПриемЗапасы.СтавкаНДС КАК СтавкаНДС,
	|		ПриемЗапасы.Всего КАК Сумма
	|	ИЗ
	|		Документ.Прием.Запасы КАК ПриемЗапасы
	|	ГДЕ
	|		ПриемЗапасы.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПриемПодарки.Ссылка,
	|		ПриемПодарки.НомерСтроки,
	|		ПриемПодарки.Номенклатура,
	|		NULL,
	|		ПриемПодарки.Количество,
	|		ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.БезНДС),
	|		0
	|	ИЗ
	|		Документ.Прием.Подарки КАК ПриемПодарки
	|	ГДЕ
	|		ПриемПодарки.Ссылка = &Ссылка
	|		И ПриемПодарки.Использование = ИСТИНА) КАК ПриемТовары
	|ГДЕ
	|	ПриемТовары.Ссылка = &Ссылка
	|	И ПриемТовары.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ПриемСкидкиНаценки.Ссылка.Дата КАК Период,
	|	ПриемСкидкиНаценки.БонусныйСчет КАК БонусныйСчет,
	|	ПриемСкидкиНаценки.Ссылка КАК ДокументНачисления,
	|	ВЫБОР
	|		КОГДА &СуммаОплачено < ПриемСкидкиНаценки.Ссылка.СуммаДокумента
	|				И ПриемСкидкиНаценки.Ссылка.СуммаДокумента > 0
	|			ТОГДА ПриемСкидкиНаценки.Сумма * &СуммаОплачено / ПриемСкидкиНаценки.Ссылка.СуммаДокумента
	|		ИНАЧЕ ПриемСкидкиНаценки.Сумма
	|	КОНЕЦ КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаНачислениеБонусов
	|ИЗ
	|	Документ.Прием.СкидкиНаценки КАК ПриемСкидкиНаценки
	|ГДЕ
	|	ПриемСкидкиНаценки.Ссылка = &Ссылка
	|	И ПриемСкидкиНаценки.Использование = ИСТИНА
	|	И ПриемСкидкиНаценки.ПризнакОплатыБонусом = ЛОЖЬ
	|	И ПриемСкидкиНаценки.СкидкаНаценка.НачислениеБонусами = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПриемСкидкиНаценки.Ссылка.Дата КАК Период,
	|	ПриемСкидкиНаценки.БонусныйСчет КАК БонусныйСчет,
	|	NULL КАК ДокументНачисления,
	|	ПриемСкидкиНаценки.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаСписаниеБонусов
	|ИЗ
	|	Документ.Прием.СкидкиНаценки КАК ПриемСкидкиНаценки
	|ГДЕ
	|	ПриемСкидкиНаценки.Ссылка = &Ссылка
	|	И ПриемСкидкиНаценки.Использование = ИСТИНА
	|	И ПриемСкидкиНаценки.ПризнакОплатыБонусом = ИСТИНА
	|	И ПриемСкидкиНаценки.Сумма > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемПродажи.Ссылка КАК ДокументПродажи,
	|	ПриемПродажи.Дата КАК Период,
	|	ПриемПродажи.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПриемПродажи.Сотрудник КАК Сотрудник,
	|	ПриемПродажи.Ассистент КАК Ассистент,
	|	ПриемПродажи.ЗубнойТехник КАК ЗубнойТехник,
	|	ПриемПродажи.Ссылка.Контрагент КАК Контрагент,
	|	ВЫБОР
	|		КОГДА ПриемПродажи.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|		ИНАЧЕ ПриемПродажи.Ссылка.Склад
	|	КОНЕЦ КАК Склад,
	|	ПриемПродажи.НомерСтроки КАК НомерСтроки,
	|	ПриемПродажи.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА ПриемПродажи.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	ПриемПродажи.Количество КАК Количество,
	|	ПриемПродажи.СтоимостьБезСкидки КАК СтоимостьБезСкидки,
	|	ПриемПродажи.Стоимость КАК Стоимость,
	|	ВЫБОР
	|		КОГДА НЕ ПриемПродажи.Ссылка.ПолисМедСтрахования = ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяСсылка)
	|			ТОГДА ПриемПродажи.Ссылка.ПолисМедСтрахования.СтраховаяКомпания
	|		ИНАЧЕ ПриемПродажи.Ссылка.Контрагент
	|	КОНЕЦ КАК КонтрагентПлательщик,
	|	ПриемПродажи.НомерЗуба КАК НомерЗуба,
	|	ПриемПродажи.УЕТ КАК КоличествоУЕТ,
	|	ПриемПродажи.Ссылка.КартаКонтрагента КАК КартаКонтрагента
	|ПОМЕСТИТЬ ВременнаяТаблицаПродажи
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПриемЗапасы.Ссылка.Дата КАК Дата,
	|		ПриемЗапасы.Ссылка КАК Ссылка,
	|		ПриемЗапасы.Ссылка.Сотрудник КАК Сотрудник,
	|		ПриемЗапасы.НомерСтроки КАК НомерСтроки,
	|		ПриемЗапасы.Номенклатура КАК Номенклатура,
	|		ПриемЗапасы.Партия КАК Партия,
	|		ПриемЗапасы.Количество КАК Количество,
	|		ПриемЗапасы.Цена * ПриемЗапасы.КоличествоУпаковок КАК СтоимостьБезСкидки,
	|		ПриемЗапасы.Сумма КАК Стоимость,
	|		NULL КАК НомерЗуба,
	|		ПриемЗапасы.Ссылка.Ассистент КАК Ассистент,
	|		ПриемЗапасы.ЗубнойТехник КАК ЗубнойТехник,
	|		NULL КАК УЕТ
	|	ИЗ
	|		Документ.Прием.Запасы КАК ПриемЗапасы
	|	ГДЕ
	|		ПриемЗапасы.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПриемЛечение.Ссылка.Дата,
	|		ПриемЛечение.Ссылка,
	|		ВЫБОР
	|			КОГДА НЕ НесколькоВрачейВОдномПриеме.Значение
	|					ИЛИ ПриемЛечение.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|				ТОГДА ПриемЛечение.Ссылка.Сотрудник
	|			ИНАЧЕ ПриемЛечение.Сотрудник
	|		КОНЕЦ,
	|		ПриемЛечение.НомерСтроки,
	|		ПриемЛечение.Номенклатура,
	|		NULL,
	|		ПриемЛечение.Количество,
	|		ПриемЛечение.Цена * ПриемЛечение.КоличествоУпаковок,
	|		ПриемЛечение.Сумма,
	|		ПриемЛечение.Зуб,
	|		ПриемЛечение.Ссылка.Ассистент,
	|		ПриемЛечение.ЗубнойТехник,
	|		ПриемЛечение.УЕТ
	|	ИЗ
	|		Документ.Прием.Лечение КАК ПриемЛечение,
	|		Константа.НесколькоВрачейВОдномПриеме КАК НесколькоВрачейВОдномПриеме
	|	ГДЕ
	|		ПриемЛечение.Ссылка = &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПриемЛечение.Ссылка.Дата,
	|		ПриемЛечение.Рекламация.Ссылка,
	|		ПриемЛечение.Рекламация.Сотрудник,
	|		ПриемЛечение.НомерСтроки,
	|		ПриемЛечение.Номенклатура,
	|		NULL,
	|		ПриемЛечение.Количество * -1,
	|		ПриемЛечение.Цена * ПриемЛечение.КоличествоУпаковок * -1,
	|		ПриемЛечение.Сумма * -1,
	|		ПриемЛечение.Зуб,
	|		ПриемЛечение.Ссылка.Ассистент,
	|		ПриемЛечение.ЗубнойТехник,
	|		ПриемЛечение.УЕТ
	|	ИЗ
	|		Документ.Прием.Лечение КАК ПриемЛечение
	|	ГДЕ
	|		ПриемЛечение.Ссылка = &Ссылка
	|		И ПриемЛечение.Рекламация <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПриемПодарки.Ссылка.Дата,
	|		ПриемПодарки.Ссылка,
	|		ПриемПодарки.Ссылка.Сотрудник,
	|		ПриемПодарки.НомерСтроки,
	|		ПриемПодарки.Номенклатура,
	|		NULL,
	|		ПриемПодарки.КоличествоУпаковок,
	|		0,
	|		0,
	|		NULL,
	|		ПриемПодарки.Ссылка.Ассистент,
	|		NULL,
	|		NULL
	|	ИЗ
	|		Документ.Прием.Подарки КАК ПриемПодарки
	|	ГДЕ
	|		ПриемПодарки.Ссылка = &Ссылка
	|		И ПриемПодарки.Использование = ИСТИНА) КАК ПриемПродажи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	СторнированиеДокументовАванса.Ссылка.Дата КАК Период,
	|	ВЫБОР
	|		КОГДА НЕ СторнированиеДокументовАванса.Ссылка.ПолисМедСтрахования = ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяСсылка)
	|			ТОГДА СторнированиеДокументовАванса.Ссылка.ПолисМедСтрахования.СтраховаяКомпания
	|		ИНАЧЕ СторнированиеДокументовАванса.Ссылка.Контрагент
	|	КОНЕЦ КАК Контрагент,
	|	СторнированиеДокументовАванса.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА СторнированиеДокументовАванса.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА СторнированиеДокументовАванса.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ СторнированиеДокументовАванса.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	NULL КАК Ссылка,
	|	СторнированиеДокументовАванса.ДокументАванса КАК ДокументАванса,
	|	-СУММА(СторнированиеДокументовАванса.Сумма) КАК Сумма,
	|	NULL КАК ЭтоАванс,
	|	СторнированиеДокументовАванса.Ссылка.ПолисМедСтрахования.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыКонтрагентов
	|ИЗ
	|	(ВЫБРАТЬ
	|		СУММА(ПриемЛечение.Сумма) КАК Сумма,
	|		ПриемЛечение.ДокументАванса КАК ДокументАванса,
	|		ПриемЛечение.Ссылка КАК Ссылка
	|	ИЗ
	|		Документ.Прием.Лечение КАК ПриемЛечение,
	|		Константа.НарядЗаказУвеличиваетЗадолженность КАК НарядЗаказУвеличиваетЗадолженность,
	|		Константа.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов КАК УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов
	|	ГДЕ
	|		ПриемЛечение.Ссылка = &Ссылка
	|		И ПриемЛечение.ДокументАванса В(&ДокументыАвансов)
	|		И ПриемЛечение.ДокументАванса ССЫЛКА Документ.НарядЗаказ
	|		И НарядЗаказУвеличиваетЗадолженность.Значение = ИСТИНА
	|		И (ПриемЛечение.Рекламация = НЕОПРЕДЕЛЕНО
	|				ИЛИ ПриемЛечение.Рекламация = ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка))
	|		И УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Значение = ИСТИНА
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ПриемЛечение.ДокументАванса,
	|		ПриемЛечение.Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		СУММА(ПриемЗапасы.Сумма),
	|		ПриемЗапасы.ДокументАванса,
	|		ПриемЗапасы.Ссылка
	|	ИЗ
	|		Документ.Прием.Запасы КАК ПриемЗапасы,
	|		Константа.НарядЗаказУвеличиваетЗадолженность КАК НарядЗаказУвеличиваетЗадолженность,
	|		Константа.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов КАК УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов
	|	ГДЕ
	|		ПриемЗапасы.Ссылка = &Ссылка
	|		И ПриемЗапасы.ДокументАванса В(&ДокументыАвансов)
	|		И ПриемЗапасы.ДокументАванса ССЫЛКА Документ.НарядЗаказ
	|		И НарядЗаказУвеличиваетЗадолженность.Значение = ИСТИНА
	|		И УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Значение = ИСТИНА
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ПриемЗапасы.ДокументАванса,
	|		ПриемЗапасы.Ссылка) КАК СторнированиеДокументовАванса
	|ГДЕ
	|	СторнированиеДокументовАванса.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	СторнированиеДокументовАванса.ДокументАванса,
	|	СторнированиеДокументовАванса.Ссылка.Дата,
	|	СторнированиеДокументовАванса.Ссылка.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА СторнированиеДокументовАванса.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА СторнированиеДокументовАванса.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ СторнированиеДокументовАванса.Ссылка.Организация
