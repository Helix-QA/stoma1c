// Функция - Получить таблицу с эквайрингом для возврата
//
// Параметры:
//  ВозвратОтПокупателя	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуСЭквайрингомДляВозврата(ВозвратОтПокупателя) Экспорт
	
	МассивТиповБанка = Новый Массив;
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПАльфаБанк);	
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПТинькофф);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПСбербанк);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR);
	МассивТиповБанка.Добавить(Перечисления.ПлатежныеШлюзы.СБПСДМ);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.Ссылка КАК ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.Наименование КАК Наименование,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка КАК ТипБанка,
	|	СтатусыОплатыЗаказов.Сумма КАК Сумма
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Основание В
	|			(ВЫБРАТЬ
	|				ВозвратОтПокупателя.ДокументОснования
	|			ИЗ
	|				Документ.ВозвратОтПокупателя КАК ВозвратОтПокупателя
	|			ГДЕ
	|				ВозвратОтПокупателя.Ссылка = &Основание)
	|	И СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.Оплачено)
	|	И СтатусыОплатыЗаказов.ЭквайринговыйТерминал.ТипБанка В(&МассивТиповБанка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа");
	
	Запрос.УстановитьПараметр("Основание"		, ВозвратОтПокупателя);
	Запрос.УстановитьПараметр("МассивТиповБанка", МассивТиповБанка);
	
	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции

