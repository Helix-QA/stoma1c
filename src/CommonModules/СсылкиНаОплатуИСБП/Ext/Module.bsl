//   - 
//
Функция СформироватьСтруктуруДанных(СтруктураПараметров)
	
	ТаблицаЗадолженностей	= СтруктураПараметров.ТаблицаЗадолженностей;
	Сумма					= СтруктураПараметров.СуммаОплаты;
	ПараметрыПШ				= СтруктураПараметров.ПараметрыПШ;
	Контрагент				= СтруктураПараметров.Контрагент;
	email					= СтруктураПараметров.АдресЭПКонтрагента;
	
	СтруктураДанных = Новый Структура();
	Сумма = Формат(Сумма, "ЧРД=.; ЧГ=");                  // сумма в копейках.
	СтруктураДанных.Вставить("amount", Сумма);     // стоимость товара в валюте оплаты (amountcurr)
	СтруктураДанных.Вставить("amountcurr", "RUB"); // валюта, в которой задана стоимость товара (amount)
	СтруктураДанных.Вставить("paysys", "MBC");     // VISA/MasterCard
	ДатаЗаказа  = ТекущаяДатаСеанса();
	ЭтоРеализация = ТипЗнч(ТаблицаЗадолженностей[0].ДокументЗадолженности) = Тип("ДокументСсылка.Реализация");
	НомерЗаказа = СформироватьНомерЗаказаСБП();
	НомерЗаказа = СтрЗаменить(НомерЗаказа, ":", "");
	СтруктураДанных.Вставить("number", НомерЗаказа); // уникальный внутренний номер заказа магазина
	
	Описание      = "";
	ПервыйЭлемент = Истина;
	Массивitems = Новый Массив;
	
	Если ЭтоРеализация Тогда
		Для Каждого Основание Из ТаблицаЗадолженностей Цикл 
			Для Каждого СтрокаТЧ Из Основание.ДокументЗадолженности.Запасы Цикл 
				
				Если Не ПервыйЭлемент Тогда
					Описание = Описание + ", "	
				КонецЕсли;		
				НаименованиеНоменкалтуры = ПолучитьЗначенияРеквизитовПоСсылке(СтрокаТЧ.Номенклатура, "Наименование");
				Описание = НаименованиеНоменкалтуры + " x" + СтрокаТЧ.Количество;			
				
				СтруктураТовара = Новый Структура;
				СтруктураТовара.Вставить("title", НаименованиеНоменкалтуры); 
				СтруктураТовара.Вставить("price", Строка(СтрокаТЧ.Цена));
				СтруктураТовара.Вставить("qty", Строка(СтрокаТЧ.Количество));
				Массивitems.Добавить(СтруктураТовара);			
				
				ПервыйЭлемент = Ложь;
				
			КонецЦикла;
		КонецЦикла;
		
	Иначе 
		Описание = "Взнос на лицевой счет";
	КонецЕсли;
	
	Описание = СформироватьОписаниеЗаказа(Описание);
	Описание = СтрЗаменить(Описание, ":", "");
	Описание = КодироватьСтроку(Описание, СпособКодированияСтроки.КодировкаURL);
	
	СтруктураДанных.Вставить("description", Описание); // текстовое описание заказа, представленное в виде URL-encoded строки (минимум – 6 символов) 
	СтруктураДанных.Вставить("validity", "");	
	
	first_name = ?(ЗначениеЗаполнено(Контрагент.Имя), Контрагент.Имя, Контрагент.Наименование);
	СтруктураДанных.Вставить("first_name", first_name);  // имя плательщика
	last_name = ?(ЗначениеЗаполнено(Контрагент.Имя) И ЗначениеЗаполнено(Контрагент.Фамилия), Контрагент.Фамилия, "");
	middle_name = ?(ЗначениеЗаполнено(Контрагент.Имя) И ЗначениеЗаполнено(Контрагент.Отчество), Контрагент.Отчество, "");
	СтруктураДанных.Вставить("last_name"  , last_name);    // Фамилия плательщика
	СтруктураДанных.Вставить("middle_name", middle_name);  // отчество  плательщика

	Если ЗначениеЗаполнено(email) Тогда
		СтруктураДанных.Вставить("email", email);
		СтруктураДанных.Вставить("notify_email", 0);
	КонецЕсли;
	
	СтруктураДанных.Вставить("backURL", ""); //  URL возврата на сайт магазина после оплаты			
	СтруктураДанных.Вставить("account", ПараметрыПШ.ЛицевойСчетАпекс);  //номер счёта магазина в Системе paygateway (сообщается при регистрации и отображается в Личном кабинете владельца магазина)
			
	Для Каждого Элемент Из СтруктураДанных Цикл
		signature = ?(ЗначениеЗаполнено(signature), signature + ":" + Элемент.Значение, Элемент.Значение); 
	КонецЦикла;
	
	// если в лк в настройках MD5
	signature = signature + ":" +  ПараметрыПШ.СекретныйКлюч1Апекс + ":" + ПараметрыПШ.СекретныйКлюч2Апекс; 
	Если ПараметрыПШ.Свойство("HMACАпекс") И ПараметрыПШ.HMACАпекс Тогда
		signature = ОбщегоНазначения.ПолучитьХешСумму(ПараметрыПШ.СекретныйКлюч1Апекс +  ПараметрыПШ.СекретныйКлюч2Апекс, signature, "sha256");
	Иначе
		signature = ПолучитьMD5(signature);
	КонецЕсли;	
	signature = Строка(signature);
	СтруктураДанных.Вставить("signature", signature);
	
	Структураfiscal_data = Новый Структура; 		
	Массивfiscal_data = Новый Массив; 
	Структураfiscal_data.Вставить("items", Массивitems);
	Массивfiscal_data.Добавить(Структураfiscal_data);
	СтруктураДанных.Вставить("fiscal_data", Массивfiscal_data);	
	
	Возврат СтруктураДанных;
	
КонецФункции

// Функция, формирует описание заказа
Функция СформироватьОписаниеЗаказа(Описание)
	
	Описание = СтрЗаменить(Описание, "%", "");
	Описание = СтрЗаменить(Описание, "+", "");
	
	Возврат Лев(СокрЛП(Описание), 128); 
	
КонецФункции

