// Процедура, Обработчик события "ПолучитьДисконтнуюКартуКонтрагента".
//
Процедура ПолучитьДисконтнуюКартуКонтрагента(РежимНастройки = Неопределено)
	
	Если Объект.Контрагент.Пустая() Тогда 
		Объект.КартаКонтрагента = Неопределено;
		Элементы.КартаКонтрагента.СписокВыбора.Очистить();
	Иначе 	
		МассивДисконтныхКарт = ВернутьАктуальныеДисконтныеКартыКлиента(Объект.Контрагент);
		Если МассивДисконтныхКарт <> Неопределено Тогда 
			// Заполнение списка выбора
			Элементы.КартаКонтрагента.СписокВыбора.ЗагрузитьЗначения(МассивДисконтныхКарт);
			Если МассивДисконтныхКарт.Количество() > 0 И РежимНастройки = "ШАПКА" Тогда
				Объект.КартаКонтрагента = МассивДисконтныхКарт[0];
			КонецЕсли;
		Иначе 
			Объект.КартаКонтрагента = Неопределено;
			Элементы.КартаКонтрагента.СписокВыбора.Очистить();
		КонецЕсли;		
	КонецЕсли;

