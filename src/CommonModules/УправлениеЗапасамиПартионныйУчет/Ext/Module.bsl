		//	ЕИ = Справочники.КлассификаторЕдиницИзмерения.ПолучитьНаименованиеЕдиницыИзмеренияНоменклатуры(СтрокаНоменклатуры.Номенклатура,"шт");
		//	
		//	ТекстОшибки = "Остатка " + СтрокаНоменклатуры.Номенклатура + """ "+СтрокаПартия+" на складе " + СтрокаНоменклатуры.Склад + " в структурной единице " + СтрокаНоменклатуры.СтруктурнаяЕдиница
		//			+ ?(ЗначениеЗаполнено(СтрокаНоменклатуры.ОснованиеВозврата), " с основанием " + СтрокаНоменклатуры.ОснованиеВозврата, "") + " недостаточно.
		//			|		Остаток " + КоличествоДосупнойНоменклатуры +" " + ЕИ + "; Требуется " + СтрокаНоменклатуры.Количество + " " + ЕИ +"; Не хватает " + (ОсталосьВернутьКоличество) + " " + ЕИ;
