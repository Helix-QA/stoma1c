// Функция - Проверить корректность заполнения поля сортировки
// 
Функция ПроверитьКорректностьЗаполненияПоляСортировки(ЭтоУслуги, НаименованиеПоля)
	
	Если НЕ ЗначениеЗаполнено(НаименованиеПоля) ИЛИ НЕ ЗначениеЗаполнено(ЭтоУслуги) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗначениеКорректно = (НаименованиеПоля = "Наименование" ИЛИ
						(НаименованиеПоля = "Цена" И ЭтотОбъект.ОтображатьЦену) ИЛИ
						(НаименованиеПоля = "Артикул" И ЭтотОбъект.ОтображатьАртикул) ИЛИ
						(НаименованиеПоля = "Количество" И ЭтотОбъект.ОтображатьОстаток));
		 
	Если ЭтоУслуги И ЗначениеКорректно Тогда
		Возврат Истина;
	ИначеЕсли НЕ ЭтоУслуги И (ЗначениеКорректно ИЛИ (НаименованиеПоля = "Количество" И ЭтотОбъект.ОтображатьОстаток)) Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

