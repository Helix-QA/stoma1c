// Функция осуществляет подключение устройства.
//
// Параметры:
//  ОбъектДрайвера   - <*>
//           - ОбъектДрайвера драйвера торгового оборудования.
//
// Возвращаемое значение:
//  <Булево> - Результат работы функции.
//
Функция ПодключитьУстройство(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт

	Результат = Истина;
	ВыходныеПараметры = Новый Массив;
	ВыходныеПараметры.Добавить("HelixGatWriter6000F");
	ВыходныеПараметры.Добавить(Новый Массив());
	ВыходныеПараметры[1].Добавить("ReadCard");
	
	ОбъектДрайвера.Server 		= Параметры.Сервер;	
	ОбъектДрайвера.Port         = Параметры.Порт;
	ОбъектДрайвера.StartOfFrame = Параметры.НачалоФрэйма;
	ОбъектДрайвера.EndOfFrame   = Параметры.КонецФрэйма;
	ОбъектДрайвера.Password     = Параметры.Пароль;
	ОбъектДрайвера.ClientName   = "HelixGatWriter6000F";	
	
	ОбъектДрайвера.InitializeEvents();
	ОбъектДрайвера.ConnectGantner();
	
	Возврат Результат;

КонецФункции

