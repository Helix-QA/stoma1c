&НаСервере
// Функция разбивает строку на подстроки в списке
//
Функция СтрокаВСписок(Строка,Разделитель = ",")
	
	ПоследнийЭлементПуст=Ложь;
	Стр=Строка;
	Список = Новый СписокЗначений;
	Длина = СтрДлина(Разделитель)-1;
	Пока СтрДлина(Стр)>0 Цикл
		РазделительКоличество = Найти(Стр,Разделитель);
		Если РазделительКоличество > 0 Тогда
			ВрСтр = СокрЛП(Лев(Стр,РазделительКоличество - 1));
			Стр = СокрЛП(Прав(Стр,СтрДлина(Стр) - РазделительКоличество - Длина));
			Если СтрДлина(Стр)=0 Тогда
				ПоследнийЭлементПуст=Истина;
			КонецЕсли;
		Иначе
			// последняя
			ВрСтр = СокрЛП(Стр);
			Стр = "";
		КонецЕсли;
		
		Если (Лев(ВрСтр,1) = """") И (Прав(ВрСтр,1) = """") Тогда
			ВрСтр = Сред(ВрСтр,2,СтрДлина(ВрСтр)-2);
		КонецЕсли;
		
		Список.Добавить(ВрСтр);
	КонецЦикла;
	
	Если ПоследнийЭлементПуст Тогда
		Список.Добавить("");
	КонецЕсли;	  
	
	Возврат(Список)
КонецФункции

&НаСервере
// Функция приводит текстовый формат представления даты к типу дата, поддерживаемые маски ####.##.##., ##.##.####
//
Функция ПривестиКТипуДата(СтрПредст)
	
	Если СтрДлина(СтрПредст) < 8 Тогда
		Возврат Неопределено;	
	КонецЕсли;	
	Попытка 
		
		СписокЗн = СтрокаВСписок(СтрПредст,".");
		
		Если СписокЗн.Количество() = 0 Тогда
			Возврат Неопределено;
		Иначе
			
			Если СтрДлина(СписокЗн[0]) > 2 Тогда
				Возврат Дата(СписокЗн[0] + Формат(СписокЗн[1], "ЧЦ=2; ЧВН=") + Формат(СписокЗн[2], "ЧЦ=2; ЧВН="));
			Иначе
				Возврат Дата(Формат(СписокЗн[2], "ЧЦ=2; ЧВН=") + Формат(СписокЗн[1], "ЧЦ=2; ЧВН=") + СписокЗн[0]);
			КонецЕсли;
		КонецЕсли;	
	Исключение
		Возврат Неопределено;
	КонецПопытки;	  
	
КонецФункции	

// Функция ищет значение перечисления по передеанной строке(поддержка поиска по подстрокам)
//
&НаСервере
Функция ПолчитьТипПол(СтрПредст,ПеречислениеОбъект)
	
	СтрПредст=СтрЗаменить(СтрПредст,".","");
	Индекс=0;
	Пока Индекс<ПеречислениеОбъект.Количество() Цикл
		
		Зн=Формат(ПеречислениеОбъект[Индекс]);
		Если Найти(НРег(Зн),НРег(СтрПредст))<>0 Тогда
			Возврат ПеречислениеОбъект[Индекс];
		КонецЕсли;	
		
		Индекс=Индекс+1;
	КонецЦикла;
	
	Возврат Неопределено;
КонецФункции	  

&НаСервере
// Функция возвращает Истина, если в строке содержится только число
// и Ложь, если это не так
//
Функция ПроверитьСтрокуНаЧисло(НашаСтрока)
	
	Если СтрДлина(СокрЛП(НашаСтрока)) <> 0 Тогда 
		ЕстьЦифры = Ложь;
		ЕстьБуквы = Ложь;
		Для К = 1 По СтрДлина(СокрЛП(НашаСтрока)) Цикл 
			Если Найти("0123456789", Сред(НашаСтрока, К, 1)) <> 0 Тогда 
				ЕстьЦифры = Истина;
			Иначе 
				ЕстьБуквы = Истина;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;		
	
	Если ЕстьЦифры И ЕстьБуквы Тогда 
		Возврат Ложь;
	ИначеЕсли ЕстьЦифры И НЕ ЕстьБуквы Тогда 
		Возврат Истина;
	ИначеЕсли НЕ ЕстьЦифры И ЕстьБуквы Тогда 
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
//
//
Функция ЗаполнитьСтруктуруТелефонногоНомера(Телефон, СписокПолей)
	
	СтруктураТелефонногоНомера = Новый Структура;
	СтруктураТелефонногоНомера.Вставить("Представление");
	СтруктураТелефонногоНомера.Вставить("ЗначенияПолей");
	СтруктураТелефонногоНомера.Вставить("НомерТелефона");
	СтруктураТелефонногоНомера.Вставить("НомерТелефонаБезКодов");
	
	Для Каждого ЭлементСписка Из СписокПолей Цикл 
		Если ЭлементСписка.Представление = "КодСтраны" Тогда 
			ЗначенияПолейКодСтраны = ?(ЗначениеЗаполнено(ЭлементСписка.Значение), ЭлементСписка.Представление + "=" + Строка(ЭлементСписка.Значение), "");
			КодСтраны = Строка(ЭлементСписка.Значение); 
		КонецЕсли;
		Если ЭлементСписка.Представление = "КодГорода" Тогда 
			ЗначенияПолейКодГорода = ?(ЗначениеЗаполнено(ЭлементСписка.Значение), ЭлементСписка.Представление + "=" + Строка(ЭлементСписка.Значение), "");
			КодГорода = Строка(ЭлементСписка.Значение);
		КонецЕсли;
		Если ЭлементСписка.Представление = "НомерТелефона" Тогда
			ЗначенияПолейНомерТелефона = ?(ЗначениеЗаполнено(ЭлементСписка.Значение), ЭлементСписка.Представление + "=" + Строка(ЭлементСписка.Значение), "");
			НомерТелефона = Строка(ЭлементСписка.Значение);
		КонецЕсли;
		Если ЭлементСписка.Представление = "Добавочный" Тогда
			ЗначенияПолейДобавочный = ?(ЗначениеЗаполнено(ЭлементСписка.Значение), ЭлементСписка.Представление + "=" + Строка(ЭлементСписка.Значение), "");
		КонецЕсли;	
		Если ЭлементСписка.Представление = "Комментарий" Тогда
			ЗначенияПолейКомментарий = ?(ЗначениеЗаполнено(ЭлементСписка.Значение), ЭлементСписка.Представление + "=" + Строка(ЭлементСписка.Значение), "");
		КонецЕсли;	
		
	КонецЦикла;
	
	СтруктураТелефонногоНомера.Представление 			= ""+Телефон;	
	СтруктураТелефонногоНомера.ЗначенияПолей 			= ""+ЗначенияПолейКодСтраны + Символы.ПС + ЗначенияПолейКодГорода + Символы.ПС + ЗначенияПолейНомерТелефона + Символы.ПС + ЗначенияПолейДобавочный + Символы.ПС + ЗначенияПолейКомментарий;
	СтруктураТелефонногоНомера.НомерТелефона 			= ""+КодСтраны + КодГорода + НомерТелефона;
	СтруктураТелефонногоНомера.НомерТелефонаБезКодов 	= ""+НомерТелефона;
	
	Возврат СтруктураТелефонногоНомера;
	
КонецФункции

