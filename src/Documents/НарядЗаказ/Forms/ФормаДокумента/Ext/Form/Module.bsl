// При начале выбора номенклатуры
//
Процедура ЗапасыНоменклатураНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	СтруктураПараметры     = Новый Структура();	
	МассивРазрешенныхТипов = Новый Массив;
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));	
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Запас"));
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор"));
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал"));

	СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов"          	, МассивРазрешенныхТипов); 
	СтруктураПараметры.Вставить("Заголовок"                            	, "Выберите услугу и товары");	  
	СтруктураПараметры.Вставить("СтруктурнаяЕдиница"                   	, Объект.СтруктурнаяЕдиница);   
	СтруктураПараметры.Вставить("Дата"                                 	, Объект.Дата);
	СтруктураПараметры.Вставить("ВидЦен"                            	, Объект.ВидЦен);
	СтруктураПараметры.Вставить("БуферВыбранныхЗначенийИспользовать"   	, Ложь);
	СтруктураПараметры.Вставить("Сегмент"								, СегментНоменклатуры); 
	СтруктураПараметры.Вставить("ДоговорПолисаМедСтрахования"		    , ЭтотОбъект._ПодборДоговорПолиса);
	СтруктураПараметры.Вставить("ПолисМедСтрахования"		    		, Объект.ПолисМедСтрахования);
	СтруктураПараметры.Вставить("ВозвращатьДанныеПоДоговоруПолиса"		, Истина);
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры",
	// Новый Структура("Владелец", Объект.Ссылка)
	СтруктураПараметры,,,,,
	Новый ОписаниеОповещения("ЗапасыНоменклатураНачалоВыбораЗавершение", ЭтотОбъект), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора запасов
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЗапасыНоменклатураНачалоВыбораЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда		
		Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(РезультатВыбора.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор") Тогда
			СоставНабора = ОбщегоНазначенияСтоматология.ПолучитьСоставНабора(РезультатВыбора.Номенклатура);
			ПерваяСтока = Истина;
			Для Каждого СтрокаТЧ из СоставНабора Цикл
				Если Не ПерваяСтока Тогда
					Элементы.Запасы.ДобавитьСтроку();
				КонецЕсли;
				Элементы.Запасы.ТекущиеДанные.Номенклатура = СтрокаТЧ.Номенклатура;
				Элементы.Запасы.ТекущиеДанные.КоличествоУпаковок   = СтрокаТЧ.Количество;
				Элементы.Запасы.ТекущиеДанные.Количество   = СтрокаТЧ.Количество;
				ЗапасыНоменклатураПриИзменении(Неопределено);
				ПерваяСтока = Ложь;
			КонецЦикла;
		Иначе			
			Элементы.Запасы.ТекущиеДанные.Номенклатура = РезультатВыбора.Номенклатура;
			// ЗапасыНоменклатураПриИзменении(Неопределено);	
			ИдентификаторыНовыхСтрок = Элементы.Запасы.ТекущиеДанные.ПолучитьИдентификатор();	
			ЗапасыНоменклатураПриИзменении(Неопределено, ИдентификаторыНовыхСтрок, Истина);	
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ЗапасыНоменклатураПриИзменении(Элемент,ИдентификаторыНовыхСтрок = Неопределено,ПересчетТЧПослеизменения = Ложь)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;	
	Если ИдентификаторыНовыхСтрок = Неопределено Тогда
		ИдентификаторыНовыхСтрок = СтрокаТабличнойЧасти.ПолучитьИдентификатор();
	КонецЕсли;	
	ИдентификаторыИзмененныхСтрок = ИдентификаторыНовыхСтрок;	
	ИдентификаторыСтрок = Неопределено;
	Если ТипЗнч(ИдентификаторыИзмененныхСтрок) = Тип("Массив") Тогда
		ИдентификаторыСтрок = ИдентификаторыИзмененныхСтрок;
	Иначе
		ИдентификаторыСтрок = Новый Массив;
		ИдентификаторыСтрок.Добавить(ИдентификаторыИзмененныхСтрок);
	КонецЕсли;	 
	Для Каждого ЭлИдентификаторСтроки ИЗ ИдентификаторыСтрок Цикл 
		// Получаем строку ТЧ
		СтрокаТабличнойЧасти = Объект.Запасы.НайтиПоИдентификатору(ЭлИдентификаторСтроки);	
		// Получить закупочную цену	
		СтрокаТабличнойЧасти.Упаковка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "УпаковкаПоумолчанию");	
		СтруктураДанные               = Новый Структура();
		СтруктураДанные.Вставить("СтруктурнаяЕдиница",  Объект.СтруктурнаяЕдиница);
		СтруктураДанные.Вставить("ДатаОбработки",	 	Объект.Дата);
		СтруктураДанные.Вставить("ВидЦен", 				?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидЦен), СтрокаТабличнойЧасти.ВидЦен, Объект.ВидЦен));	
		СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
		СтруктураДанные.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);		
		СтруктураДанныеЗакупки = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
		
		// Получить цену продажи
		СтруктураДанные.ВидЦен = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидЦенПродажи),СтрокаТабличнойЧасти.ВидЦенПродажи, Объект.ВидЦенПродажи);
		СтруктураДанные.Вставить("Сотрудник", Объект.Сотрудник);	
		СтруктураДанныеПродажи = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
		
		// Установка значений реквизитов строки
		СтрокаТабличнойЧасти.Упаковка      = СтруктураДанныеЗакупки.Упаковка;
		СтрокаТабличнойЧасти.Цена          = СтруктураДанныеЗакупки.Цена;
		СтрокаТабличнойЧасти.ЦенаПродажи   = СтруктураДанныеПродажи.Цена;
		СтрокаТабличнойЧасти.ВидЦен        = Объект.ВидЦен;
		СтрокаТабличнойЧасти.ВидЦенПродажи = Объект.ВидЦенПродажи;
		СтрокаТабличнойЧасти.Статус        = ПредопределенноеЗначение("Перечисление.СтатусыНарядЗаказа.Заказано"); 
		
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.КлючСтроки) Тогда
			СтрокаТабличнойЧасти.КлючСтроки = Новый УникальныйИдентификатор;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.КоличествоУпаковок) Тогда
			СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
			СтрокаТабличнойЧасти.СтавкаНДС = ?(ЗначениеЗаполнено(СтруктураДанные.СтавкаНДС),СтруктураДанные.СтавкаНДС, ПредопределенноеЗначение("Перечисление.СтавкиНДС.БезНДС"));
		КонецЕсли;
		СтрокаТабличнойЧасти.СкидкиЗапрещены = СкидкиЗапрещены(СтрокаТабличнойЧасти.Номенклатура);
		Если СтрокаТабличнойЧасти.СкидкиЗапрещены Тогда
			СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
		КонецЕсли;
		
		ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
		СтрокаТабличнойЧасти.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "ИспользоватьПартии");	
		
		РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	
		РассчитатьСуммуПродажиВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
		
	КонецЦикла;
	ПересчитатьАвтоматическиеСкидкиИОбновитьЗаголовкиТабЧастей();//	ПересчитатьАвтоматическиеСкидки();
	
КонецПроцедуры	

