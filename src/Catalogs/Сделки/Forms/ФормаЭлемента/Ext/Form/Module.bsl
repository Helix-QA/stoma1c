
&НаКлиенте
Перем ПредупреждениеДублирование; // Переменная для хранения данных о дублировании записи

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.ТекущийПользователь       	= ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница 	= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Элементы.ДекорацияВалюта.Заголовок 		= ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты(, Истина);
			
	Если Параметры.Свойство("ВидСделки") Тогда
		Объект.ВидСделки = Параметры.ВидСделки;
	КонецЕсли;
	
	ВремСписокФильтрацииИсторииВзаимодействия = ХранилищеСистемныхНастроек.Загрузить("Справочники.Сделки.Форма.ФормаЭлемента", "НастройкиФильтрации");	
	ОбщегоНазначенияКлиентСерверСтоматология.ЗаполнитьСписокФильтрацииИсторииВзаимодействияПоУмолчанию(СписокФильтрацииИсторииВзаимодействия,, ВремСписокФильтрацииИсторииВзаимодействия, Объект.Ссылка);	
		
	ФильтрПрименен = ФильтрПрименен(СписокФильтрацииИсторииВзаимодействия);	
	Элементы.ОчиститьФильтры.Видимость	= ФильтрПрименен;
	Элементы.ПоказатьФильтры.Картинка	= ?(ФильтрПрименен, БиблиотекаКартинок.ФильтрУстановлен, БиблиотекаКартинок.ФильтрНеУстановлен);
	
	ОбновитьДекорациюПовторногоПриема();
	ОбновитьДекорациюНаправившегоВрача();
	ОбновитьДанныеПоКлиенту();
	
	ИнициализироватьОграничениеТипаМенеджера();
	
	УстановитьВидимостьЗначенияКаналаПривлечения(ЭтотОбъект);
	
	Элементы.Специализация.Видимость 	= НЕ ЗначениеЗаполнено(Объект.Врач);
	Элементы.ПланЛечения.Видимость 		= ЗначениеЗаполнено(Объект.ПланЛечения);
	
КонецПроцедуры

&НаСервере
// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// Контактная информация
	УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервереСделки(ЭтотОбъект, ТекущийОбъект.Контрагент);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	// Для обновления представления ссылки конрагента после записи.
	ОповеститьОбИзменении(Тип("СправочникСсылка.Контрагенты"));

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	КомментарийПроверки = "";
	ПроверитьБизнесЛогикуСоздания(КомментарийПроверки, Отказ);
	Если ЗначениеЗаполнено(КомментарийПроверки) Тогда 
		Если ЗначениеЗаполнено(СделкаАналог) Тогда 
			ПоказатьВопрос(Новый ОписаниеОповещения("ВыполнитьОткрытиеСделкиАналога", ЭтотОбъект, СделкаАналог)
						, КомментарийПроверки + Символы.ПС + Символы.ПС + "Открыть существующую сделку?"
						, РежимДиалогаВопрос.ДаНет
						, 
						, КодВозвратаДиалога.Да
						, "Вопрос пользователю");
		Иначе 
			ПоказатьПредупреждение(, КомментарийПроверки, , "Сообщение пользователю");
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выполнить открытие сделки аналога
//
// Параметры:
//  РезультатОтвета			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыполнитьОткрытиеСделкиАналога(РезультатОтвета, ДополнительныеПараметры) Экспорт 
	
	Если РезультатОтвета = Неопределено Тогда 
		Возврат;		
	КонецЕсли;	
	
	Если РезультатОтвета = КодВозвратаДиалога.Да И ЗначениеЗаполнено(ДополнительныеПараметры) Тогда 
		ПоказатьЗначение(, ДополнительныеПараметры);
		ЭтаФорма.Модифицированность = Ложь;
		ЭтаФорма.Закрыть();		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Проверить бизнес логику создания
//
Процедура ПроверитьБизнесЛогикуСоздания(Комментарий, Отказ = Ложь)
	
	Справочники.Сделки.ПроверитьБизнесЛогикуСоздания(ЭтотОбъект, СделкаАналог, Комментарий, , Отказ);
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ИнтерактивнаяЗапись", Истина);
	ТекущийОбъект.Примечание = СокрЛП(ТекущийОбъект.Примечание);
	ОбновитьДанныеКлиента(ТекущийОбъект);

КонецПроцедуры

&НаСервере
// Процедура - При записи на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ТекущийОбъект.ДополнительныеСвойства, "ЭтапЗаписьПодтверждена", Ложь) Тогда 
		ПараметрыЗаписи.Вставить("ЭтапЗаписьПодтверждена", Истина);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
	Оповестить("ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ", Объект.Ссылка);
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗаписи, "ЭтапЗаписьПодтверждена", Ложь) Тогда
		Оповестить("ОБНОВИТЬ_СТАТУС_И_ВИДЖЕТ_СДЕЛКИ", Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
		
	Если ИмяСобытия = "ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ" Тогда
		
		ЭтаФорма.Прочитать();
		ОбновитьВидимостьЭтаповВнеКонтекста();

	ИначеЕсли ИмяСобытия = "СозданИзмененСервисSMSРассылки" Тогда
		
		ВзаимодействиеSMSНастроитьСервисЗавершение(Параметр);
		
	ИначеЕсли ИмяСобытия = "СозданаИзмененаУчетнаяЗапись" Тогда
		
		ВзаимодействиеПисьмоНастроитьАккаунтЗавершение(Параметр);
		
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьИсториюВзаимодействияКонтрагента" Тогда
		Если ЗначениеЗаполнено(Параметр) И ТипЗнч(Параметр) = Тип("Структура") Тогда 
			Если Параметр.Свойство("Сделка") И Параметр.Сделка = Объект.Ссылка Тогда
				ЭтаФорма.Прочитать();
				ОбновитьВидимостьЭтаповВнеКонтекста();				
				ОбновитьИсториюВзаимодействияСКлиентом(, Истина);
				// УстановитьФильтрИсторииВзаимодействияНаСервере();
			КонецЕсли;
		КонецЕсли;	
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, ОбновитьВидимостьЭтаповВсеКонтекста.
//
Процедура ОбновитьВидимостьЭтаповВнеКонтекста()
	
	ОбновитьЭтапыСделки();
	УстановитьВидимостьРезультатаСделки();

КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ОбработкаПроверкиЗаполненияНаСервере".
//
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// КонтактнаяИнформация
	УправлениеКонтактнойИнформациейСтоматология.ОбработкаПроверкиЗаполненияНаСервере(ЭтотОбъект, Отказ);
	// Конец КонтактнаяИнформация	
	
	// Проверка заполнения настроенных обязательных полей.
	ОбязательныеПоля = Константы.ОбязательныеПоляСделки.Получить().Получить();
	
	Если ЗначениеЗаполнено(ОбязательныеПоля) Тогда
		
		Для Каждого ДанныеПоля Из ОбязательныеПоля Цикл
			
			Если ДанныеПоля.Обязательно = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(Объект[ДанныеПоля.Поле]) Тогда
				ТекстСообщения = СтрШаблон(НСтр("ru = 'Поле ""%1"" не заполнено'"), ДанныеПоля.ПредставлениеПоля);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "Объект." + ДанныеПоля.Поле,, Отказ);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура - Врач при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ВрачПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Врач) Тогда 
		Объект.Специализация = ПолучитьСпециализациюВрача(Объект.Врач);
	КонецЕсли;	
	
	Элементы.Специализация.Видимость = НЕ ЗначениеЗаполнено(Объект.Врач);
	
КонецПроцедуры

