		Если СтруктураПереопределенияБазы <> Неопределено Тогда
			Факт = ?(ПоЧасам, СтруктураПереопределенияБазы.ЧасовФакт, СтруктураПереопределенияБазы.ДнейФакт);
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодПо, , , ,
					, Факт, , СтруктураПереопределенияБазы.Размер, СтруктураПереопределенияБазы.Размер * Факт);
			Возврат;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	РабочееВремяСотрудниковОбороты.ПериодДень КАК Дата,
		               |	РабочееВремяСотрудниковОбороты.Сотрудник,
		               |	РабочееВремяСотрудниковОбороты.СтруктурнаяЕдиница,
		               |	РабочееВремяСотрудниковОбороты.ДнейОборот КАК ДнейФакт,
		               |	ВЫБОР
		               |		КОГДА &УсловиеПродажи = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасДо)
		               |			ТОГДА ВЫБОР
		               |					КОГДА РабочееВремяСотрудниковОбороты.ЧасовОборот < &СуммаПродаж
		               |						ТОГДА РабочееВремяСотрудниковОбороты.ЧасовОборот
		               |					ИНАЧЕ &СуммаПродаж
		               |				КОНЕЦ
		               |		КОГДА &УсловиеПродажи = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасСверх)
		               |			ТОГДА РабочееВремяСотрудниковОбороты.ЧасовОборот - &СуммаПродаж
		               |		ИНАЧЕ РабочееВремяСотрудниковОбороты.ЧасовОборот
		               |	КОНЕЦ КАК ЧасовФакт,
		               |	ЕСТЬNULL(ПродажиОбороты.СтоимостьОборот, 0) КАК СтоимостьОборот
		               |ИЗ
		               |	РегистрНакопления.РабочееВремяСотрудников.Обороты(
		               |			&НачалоПериода,
		               |			&КонецПериода,
		               |			Авто,
		               |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		               |				И Сотрудник = &Сотрудник
		               |				И Врач = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК РабочееВремяСотрудниковОбороты
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи.Обороты(
		               |				&НачалоПериода,
		               |				&КонецПериода,
		               |				Авто,
		               |				СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		               |					И ВЫБОР
		               |						КОГДА &СегментНоменклатуры <> ЗНАЧЕНИЕ(Справочник.СегментыНоменклатуры.ПустаяСсылка)
		               |							ТОГДА Номенклатура В
		               |									(ВЫБРАТЬ
		               |										РегистрСведений.НоменклатураСегмента.Номенклатура
		               |									ИЗ
		               |										РегистрСведений.НоменклатураСегмента
		               |									ГДЕ
		               |										РегистрСведений.НоменклатураСегмента.Сегмент = &СегментНоменклатуры)
		               |						ИНАЧЕ ИСТИНА
		               |					КОНЕЦ) КАК ПродажиОбороты
		               |		ПО РабочееВремяСотрудниковОбороты.Сотрудник = ПродажиОбороты.Сотрудник
		               |ГДЕ
		               |	ВЫБОР
		               |			КОГДА &УсловиеПродажи = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ЕслиСуммаПродажи)
		               |				ТОГДА ВЫБОР
		               |						КОГДА &ТипСравнения = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.Больше)
		               |							ТОГДА ЕСТЬNULL(ПродажиОбороты.СтоимостьОборот, 0) >= &СуммаПродаж
		               |						КОГДА &ТипСравнения = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.Меньше)
		               |							ТОГДА ЕСТЬNULL(ПродажиОбороты.СтоимостьОборот, 0) < &СуммаПродаж
		               |					КОНЕЦ
		               |			КОГДА &УсловиеПродажи = ЗНАЧЕНИЕ(Перечисление.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасСверх)
		               |				ТОГДА РабочееВремяСотрудниковОбороты.ЧасовОборот > &СуммаПродаж
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ";
		
		Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(ПериодС));
		Запрос.УстановитьПараметр("КонецПериода", КонецДня(ПериодПо));
		Запрос.УстановитьПараметр("ПоЧасам", ПоЧасам);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", НачислениеУдержание.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("Сотрудник", НачислениеУдержание.Владелец);
		Запрос.УстановитьПараметр("СегментНоменклатуры", НачислениеУдержание.СегментНоменклатуры);
		Запрос.УстановитьПараметр("УсловиеПродажи", НачислениеУдержание.УсловиеПродажи);
		Запрос.УстановитьПараметр("ТипСравнения", НачислениеУдержание.ТипСравнения);
		Запрос.УстановитьПараметр("СуммаПродаж", НачислениеУдержание.СуммаПродаж);		
		
		Выборка = Запрос.Выполнить().Выбрать();
				
		Пока Выборка.Следующий() Цикл
			Факт = ?(ПоЧасам, Выборка.ЧасовФакт, Выборка.ДнейФакт);
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, Выборка.Дата, , , ,
					, Факт, , НачислениеУдержание.Размер, НачислениеУдержание.Размер * Факт);			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры // РасчетПоТарифу()

// Производится расчет ЗП при установленной виде начисления "Оклад"
//
Процедура РасчетыПоОкладу(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы = Неопределено)
	
	Если НачислениеУдержание.ЗависимостьОтВыработки	 = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.НеЗависитОтВыработки Тогда
				
		Если СтруктураПереопределенияБазы <> Неопределено Тогда
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодПо, , , ,
							СтруктураПереопределенияБазы.ДнейПлан, СтруктураПереопределенияБазы.ДнейФакт, , СтруктураПереопределенияБазы.Размер, ?(СтруктураПереопределенияБазы.ДнейПлан <> 0, СтруктураПереопределенияБазы.Размер * СтруктураПереопределенияБазы.ДнейФакт / СтруктураПереопределенияБазы.ДнейПлан, 0));
			Возврат;
		КонецЕсли;
		
		МассивДниМесяца = Новый Массив;
		МассивДниНачисленияВМесяце = Новый Массив;
		ДатаРасчетаОкладаС = ?(Месяц(НачислениеУдержание.НачалоПериода) >= Месяц(ПериодС), НачислениеУдержание.НачалоПериода, НачалоМесяца(ПериодС));
		ДатаРасчетаОкладаПо = ?(ЗначениеЗаполнено(НачислениеУдержание.КонецПериода), КонецДня(НачислениеУдержание.КонецПериода), КонецМесяца(ПериодПо));
		ПроверяемаяДата = ДатаРасчетаОкладаС;			
		Пока ПроверяемаяДата <= ДатаРасчетаОкладаПо ИЛИ МассивДниМесяца.Количество() > 0 Цикл
			МассивДниМесяца.Добавить(ПроверяемаяДата);
			Если ПроверяемаяДата >= ПериодС И ПроверяемаяДата <= ПериодПо Тогда
				МассивДниНачисленияВМесяце.Добавить(ПроверяемаяДата);
			КонецЕсли;
			Если Месяц(ПроверяемаяДата) <> Месяц(ПроверяемаяДата + 60 * 60 * 24) Тогда
				Для Каждого ЭлементМассива Из МассивДниНачисленияВМесяце Цикл
					ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ЭлементМассива, , , ,
					МассивДниМесяца.Количество(), 1, , НачислениеУдержание.Размер, НачислениеУдержание.Размер * 1 / МассивДниМесяца.Количество());
				КонецЦикла;
				
				// при округлении образовалась погрешность, прибавляем к последнему дню
				Если МассивДниНачисленияВМесяце.Количество() > 1 И НачислениеУдержание.Размер <> Окр(НачислениеУдержание.Размер / МассивДниМесяца.Количество(), 2) * МассивДниМесяца.Количество() Тогда 
					ТаблицаРасшифровкиНачислений[ТаблицаРасшифровкиНачислений.Количество()-1].Сумма = ТаблицаРасшифровкиНачислений[ТаблицаРасшифровкиНачислений.Количество()-1].Сумма + НачислениеУдержание.Размер - Окр(НачислениеУдержание.Размер / МассивДниМесяца.Количество(), 2) * МассивДниМесяца.Количество();
				КонецЕсли;

				МассивДниМесяца.Очистить();
				МассивДниНачисленияВМесяце.Очистить();					
			КонецЕсли;
			ПроверяемаяДата = ПроверяемаяДата + 60*60*24;
		КонецЦикла;
		
	Иначе
		
		ПоЧасам = НачислениеУдержание.ТипПериодаНачисления = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоЧасам;
		
		Если СтруктураПереопределенияБазы <> Неопределено Тогда
			План = ?(ПоЧасам, СтруктураПереопределенияБазы.ЧасовПлан, СтруктураПереопределенияБазы.ДнейПлан);
			Факт = ?(ПоЧасам, СтруктураПереопределенияБазы.ЧасовФакт, СтруктураПереопределенияБазы.ДнейФакт);
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодПо, , , ,
									План, Факт, , НачислениеУдержание.Размер, ?(План <> 0, НачислениеУдержание.Размер * Факт / План, 0));
			Возврат;
		КонецЕсли;		
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	ЕСТЬNULL(ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница, РабочееВремяСотрудниковФакт.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиница,
		               |	ЕСТЬNULL(ВремяРаботыСотрудниковПлан.Сотрудник, РабочееВремяСотрудниковФакт.Сотрудник) КАК Сотрудник,
		               |	ЕСТЬNULL(ВремяРаботыСотрудниковПлан.Дата, РабочееВремяСотрудниковФакт.ПериодДень) КАК Дата,
		               |	ЕСТЬNULL(ВремяРаботыСотрудниковПлан.ЧасовПлан, 0) КАК ЧасовПлан,
		               |	ЕСТЬNULL(ВремяРаботыСотрудниковПлан.ДнейПлан, 0) КАК ДнейПлан,
		               |	ЕСТЬNULL(РабочееВремяСотрудниковФакт.ЧасовОборот, 0) КАК ЧасовФакт,
		               |	ЕСТЬNULL(РабочееВремяСотрудниковФакт.ДнейОборот, 0) КАК ДнейФакт
		               |ИЗ
		               |	(ВЫБРАТЬ
		               |		ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |		ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
		               |		НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ) КАК Дата,
		               |		СУММА(ВремяРаботыСотрудниковПлан.Минуты / 60) КАК ЧасовПлан,
		               |		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ)) КАК ДнейПлан
		               |	ИЗ
		               |		РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
		               |	ГДЕ
		               |		ВремяРаботыСотрудниковПлан.ДатаВремяНачала МЕЖДУ НАЧАЛОПЕРИОДА(&НачалоПериода, МЕСЯЦ) И КОНЕЦПЕРИОДА(&КонецПериода, МЕСЯЦ)
		               |		И ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
		               |		И ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		               |	
		               |	СГРУППИРОВАТЬ ПО
		               |		ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница,
		               |		ВремяРаботыСотрудниковПлан.Сотрудник,
		               |		НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)) КАК ВремяРаботыСотрудниковПлан
		               |		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РабочееВремяСотрудников.Обороты(
		               |				&НачалоПериода,
		               |				&КонецПериода,
		               |				Авто,
		               |				Сотрудник = &Сотрудник
		               |					И Врач = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		               |					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК РабочееВремяСотрудниковФакт
		               |		ПО ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = РабочееВремяСотрудниковФакт.СтруктурнаяЕдиница
		               |			И ВремяРаботыСотрудниковПлан.Сотрудник = РабочееВремяСотрудниковФакт.Сотрудник
		               |			И ВремяРаботыСотрудниковПлан.Дата = РабочееВремяСотрудниковФакт.ПериодДень
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Дата";
		
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", НачислениеУдержание.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("Сотрудник", 			НачислениеУдержание.Владелец);
		Запрос.УстановитьПараметр("НачалоПериода", 		НачалоДня(ПериодС));
		Запрос.УстановитьПараметр("КонецПериода", 		КонецДня(ПериодПо));

		Выборка = Запрос.Выполнить().Выбрать();
					
		План = 0;
		Пока Выборка.Следующий() Цикл
			План = План + ?(ПоЧасам, Выборка.ЧасовПлан, Выборка.ДнейПлан);
		КонецЦикла;
		Выборка.Сбросить();
		СуммаНачислено = 0;
		ФактИтог = 0;
		Индекс = 0;
		ИндексПоследнейСтрокиССуммой = 0;
		Пока Выборка.Следующий() Цикл
			Факт = ?(ПоЧасам, Выборка.ЧасовФакт, Выборка.ДнейФакт);
			ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, Выборка.Дата, , , ,
							План, Факт, , НачислениеУдержание.Размер, НачислениеУдержание.Размер * ?(План <> 0, Факт / План, 0));			
			СуммаНачислено = СуммаНачислено + Окр(НачислениеУдержание.Размер * ?(План <> 0, Факт / План, 0), 2);
			ФактИтог = ФактИтог + Факт; 
			ИндексПоследнейСтрокиССуммой = ?(Факт = 0 Или План = 0, ИндексПоследнейСтрокиССуммой, Индекс);
			Индекс = Индекс + 1;
		КонецЦикла;
		
		// при округлении образовалась погрешность, прибавляем к последнему дню
		Если Выборка.Количество() > 1 И Окр(НачислениеУдержание.Размер * ?(План <> 0, ФактИтог / План, 0), 2) <> СуммаНачислено Тогда 
			ИндексСпогрешностью = ТаблицаРасшифровкиНачислений.Количество() - Выборка.Количество() + ИндексПоследнейСтрокиССуммой; 
			ТаблицаРасшифровкиНачислений[ИндексСпогрешностью].Сумма = ТаблицаРасшифровкиНачислений[ИндексСпогрешностью].Сумма + Окр(НачислениеУдержание.Размер * ?(План <> 0, ФактИтог / План, 0), 2) - СуммаНачислено;
		КонецЕсли;

		
	КонецЕсли;         

КонецПроцедуры // РасчетПоОкладу()

// Функция расчета заработной платы для значения "Удержание"
//
Процедура РасчетыПоУдержанию(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодС, ПериодПо, СтруктураПереопределенияБазы = Неопределено)
	
	Если СтруктураПереопределенияБазы <> Неопределено Тогда
		ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодПо, , , , , , 
							СтруктураПереопределенияБазы.База, СтруктураПереопределенияБазы.Размер, СтруктураПереопределенияБазы.Размер * СтруктураПереопределенияБазы.База);
		Возврат;
	КонецЕсли;
	
	ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, ПериодПо, , , , , , 
						1, -НачислениеУдержание.Размер,  1 * -НачислениеУдержание.Размер);
	
КонецПроцедуры

// Процедура добавляет расшифровку начисления в ТЧ Затраты
//
//		РасшифровкаНачисления - выборка результатов запроса, содержащая расшифровку начисления,
//								либо Число - если не нужно выводить расшифровку по строкам;
//		СтрокаПараметры - ссылка на элемент справочника начислений/удержаний;
//		
//		Через параметр СуммаЗатрат процедура может вернуть общую сумму начисления
//				(актуально для начислений вида "процент от продаж", где для исключения разницы, возникающей при округлениях,
//				 в ТЧ РасчетЗарплаты по начислению пишется сумма, полученная в данной процедуре)
//
Процедура ДобавитьРасшифровкуНачисленияВЗатраты(ТаблицаРасшифровкиНачислений, НачислениеУдержание, Дата = Неопределено, Документ = Неопределено, Контрагент = Неопределено, Номенклатура = Неопределено, План = 0, Факт = 0, База = 0, Размер = 0, Сумма = 0)
	
	// Если Сумма <> 0 Тогда
		
		НоваяСтрока = ТаблицаРасшифровкиНачислений.Добавить();
		
		НоваяСтрока.Дата 			= Дата;
		НоваяСтрока.Документ 		= Документ;
		НоваяСтрока.Контрагент 		= Контрагент;
		НоваяСтрока.Номенклатура 	= Номенклатура;
		НоваяСтрока.Сотрудник 		= НачислениеУдержание.Владелец;
		НоваяСтрока.ВидНачисления   = НачислениеУдержание;
		НоваяСтрока.План 			= План;
		НоваяСтрока.Факт 			= Факт;
		НоваяСтрока.База 			= База;
		НоваяСтрока.Размер 			= Размер;
		НоваяСтрока.Сумма			= Сумма; 
		
	// КонецЕсли;
	
КонецПроцедуры

// Функция рассчитывает и возвращает базу, если в начислении процент от части суммы.
//
Функция РасчетБазыПоНачислению(НачислениеУдержание, База)

	Если База > 0 И НачислениеУдержание.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Процент 
		И НачислениеУдержание.УсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ОтЧастиСуммы Тогда
		
		ВидСравненияУсловия = НачислениеУдержание.ТипСравненияУсловиеСумма;
		СуммаОт     		= НачислениеУдержание.УсловиеСуммаОт;
		СуммаДо  		    = НачислениеУдержание.УсловиеСуммаДо;  
		
		Если ВидСравненияУсловия = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Больше Тогда  		
			Если База > СуммаОт Тогда
				НоваяБаза = База - СуммаОт;
				Возврат ?(НоваяБаза < 0, 0, НоваяБаза);				
			Иначе
				Возврат 0;					
			КонецЕсли; 		
		КонецЕсли;  
		
		Если ВидСравненияУсловия = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Меньше Тогда 					
			Если База <= СуммаДо Тогда 
				Возврат База;
			Иначе 
				Возврат СуммаДо; 			
			КонецЕсли; 		
		КонецЕсли;
		
		Если ВидСравненияУсловия = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Между Тогда 
			
			Если База >= СуммаОт И База <= СуммаДо Тогда
				Возврат База;
			ИначеЕсли База < СуммаОт Тогда
				Возврат 0;
			ИначеЕсли База > СуммаДо Тогда
				Возврат СуммаДо;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли; 
	
	Возврат База;		
	
КонецФункции

#КонецОбласти

#КонецЕсли
