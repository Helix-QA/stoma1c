//
Процедура Подключаемый_ОткрытьНастройкиУведомленийPush_ВыполнитьКоманду(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Команда, ТекущаяСтруктурнаяЕдиница);
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("ТипКанала"									, "Push");
		ПараметрыФормы.Вставить("ТекущаяСтруктурнаяЕдиница"					, ТекущаяСтруктурнаяЕдиница);
		Если НЕ СтруктураДанныеЭлемента.СтрокаНастройкиКаналовУведомлений = Неопределено Тогда 
			ПараметрыФормы.Вставить("ИдентификаторДействия"					, СтруктураДанныеЭлемента.СтрокаНастройкиКаналовУведомлений.ИдентификаторДействия);
		Иначе 
			ПараметрыФормы.Вставить("ИдентификаторДействия"					, СтруктураДанныеЭлемента.ДанныеЭлемента.ИдентификаторДействия);
		КонецЕсли;
		ПараметрыФормы.Вставить("ПараметрыДействия"							, СтрокуТаблицыЗначенийВСтруктуру(СтруктураДанныеЭлемента.ДанныеЭлемента, ИменаКолонокТаблицыДействий()));		
