&НаСервере
// Процедура сохраняет настройки формы.
//
Процедура СохранитьНастройкиФормы()
	
	СтруктураНастроек = Новый Структура;
	СтруктураНастроек.Вставить("ПоискПоТипу", 						ПоискПоТипу);
	СтруктураНастроек.Вставить("СоздаватьНенайденнуюНоменклатуру", 	СоздаватьНенайденнуюНоменклатуру);
	СтруктураНастроек.Вставить("ПапкаДляНовыйНоменклатуры", 		ПапкаДляНовыйНоменклатуры);
	СтруктураНастроек.Вставить("ПометкаКнопкиНастройка", 			Элементы.ФормаНастройки.Пометка);
	                                                  
	ХранилищеНастроекДанныхФорм.Сохранить("ОбработкаИмпортТабличныхЧастей", "СтруктураНастроек", СтруктураНастроек);
	
КонецПроцедуры

&НаКлиенте
// Процедура загружает настройки формы.
//
Процедура ЗагрузитьНастройкиФормы()
	
	СтруктураНастроек = ПолучитьЗначениеНастроекФормы();
	
	НачтройкиОбнаружены = Истина;
	Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		НачтройкиОбнаружены = Ложь;
	Иначе
		НачтройкиОбнаружены = Истина;
	КонецЕсли;
	
	// Установим сохраненные значения
	Если НачтройкиОбнаружены И  СтруктураНастроек.Свойство("ПоискПоТипу") Тогда
		ПоискПоТипу = СтруктураНастроек.ПоискПоТипу;
	КонецЕсли;
	Если НачтройкиОбнаружены И  СтруктураНастроек.Свойство("СоздаватьНенайденнуюНоменклатуру") Тогда
		СоздаватьНенайденнуюНоменклатуру = СтруктураНастроек.СоздаватьНенайденнуюНоменклатуру;
	КонецЕсли;
	Если НачтройкиОбнаружены И  СтруктураНастроек.Свойство("ПапкаДляНовыйНоменклатуры") Тогда
		ПапкаДляНовыйНоменклатуры = СтруктураНастроек.ПапкаДляНовыйНоменклатуры;
	КонецЕсли;
	Если НачтройкиОбнаружены И  СтруктураНастроек.Свойство("ПометкаКнопкиНастройка") Тогда
		Элементы.ФормаНастройки.Пометка = СтруктураНастроек.ПометкаКнопкиНастройка;
		Элементы.ГруппаНастройки.Видимость = СтруктураНастроек.ПометкаКнопкиНастройка;
	КонецЕсли;
	
КонецПроцедуры

