// Функция, возвращает список значений кассовых серверов по драйверу аоборудования.
//
Функция ПолучитьКассовыеСервераПоДрайверуОборудования(ТипФискализации, Организация, ТекстПоиска = "")
	
	ДрайверыОборудования = Новый Массив;
	
	Если ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.КассовыйСервер") Тогда
		ДрайверыОборудования.Добавить(Справочники.ДрайверыОборудования.ДрайверКассовогоСервера);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПодключаемоеОборудование.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	|ГДЕ
	|	ПодключаемоеОборудование.ДрайверОборудования В(&ДрайверыОборудования)
	|	И НЕ ПодключаемоеОборудование.ПометкаУдаления
	|	И &УсловиеАвтоПодбора
	|	И &УсловиеОрганизация
	|	И ПодключаемоеОборудование.УстройствоИспользуется");
	
	Запрос.УстановитьПараметр("ТекстПоиска"			, "%" + ТекстПоиска + "%");
	Запрос.УстановитьПараметр("ДрайверыОборудования", ДрайверыОборудования);
	Запрос.УстановитьПараметр("Организация"         , Организация);
	
	УсловиеАвтоПодбора = ?(ЗначениеЗаполнено(ТекстПоиска), "И ПодключаемоеОборудование.Наименование ПОДОБНО &ТекстПоиска", "");
	Запрос.Текст 	   = СтрЗаменить(Запрос.Текст, "И &УсловиеАвтоПодбора", УсловиеАвтоПодбора);
	
	УсловиеОрганизация = ?(ЗначениеЗаполнено(Организация), "И ПодключаемоеОборудование.Организация = &Организация", "");
	Запрос.Текст 	   = СтрЗаменить(Запрос.Текст, "И &УсловиеОрганизация", УсловиеОрганизация);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.ЗагрузитьЗначения(Результат.ВыгрузитьКолонку("Ссылка"));
	
	Возврат СписокЗначений;
	
КонецФункции

