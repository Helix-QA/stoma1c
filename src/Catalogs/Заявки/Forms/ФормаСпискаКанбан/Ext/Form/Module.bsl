// Функция, возвращает количество заявок в каждой колонке канбана.
//
Функция ПолучитьКоличествоЗаявокВКолонках(СтруктураОтборов)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Заявки.Статус КАК Статус,
	|	КОЛИЧЕСТВО(Заявки.Ссылка) КАК КоличествоЗаявок
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	&УсловиеПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеСтатус
	|	И &УсловиеМенеджер
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаОбработки
	|	И &УсловиеСтатусПациента
	|	И &ОтборПоСсылке
	|	И &УсловиеИсключаемыеЗаявки
	|
	|СГРУППИРОВАТЬ ПО
	|	Заявки.Статус");
	
	ПрименитьУсловияФильтрации(Запрос, СтруктураОтборов);
	
	Результат = Новый Структура;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(XMLСтрока(Выборка.Статус), Выборка.КоличествоЗаявок);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает данные заявки.
//
Функция ПолучитьДанныеЗаявки(СтруктураОтбора, Заявка = Неопределено, ИсключаемыеЗаявки = Неопределено)
	
	Запрос = ЗапросПолученияДанных(СтруктураОтбора, Заявка, ИсключаемыеЗаявки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КолонкиРезультата = Новый Массив;
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		КолонкиРезультата.Добавить(Колонка.Имя);
	КонецЦикла;
	
	// Запрос с итогом по статусу заявки.
	ВыборкаПоСтатусу = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПоСтатусу.Следующий();
	
	Выборка = ВыборкаПоСтатусу.Выбрать();
	Выборка.Следующий();
	
	ДанныеЗаявки = Новый Структура(СтрСоединить(КолонкиРезультата, ","));
	ЗаполнитьЗначенияСвойств(ДанныеЗаявки, Выборка);
	
	Возврат ДанныеЗаявки;
	
КонецФункции

