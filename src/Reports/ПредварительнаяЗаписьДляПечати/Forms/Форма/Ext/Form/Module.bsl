// Вернет область для заполения предварительной записи
//
Функция ПолучитьОбласть(ДатаНачала, ДатаОкончания, ИндексСотрудника)
	
	НомерСтолбца =?(ИндексСотрудника = Неопределено, ?(Режим = "Неделя",ДеньНедели(ДатаНачала),1),ИндексСотрудника);
	Час          = Час(ДатаНачала);
    Минута       = Минута(ДатаНачала);
	Длительность = (ДатаОкончания-ДатаНачала)/60;

    ПараметрыОбласти = ТаблицаОбластей.НайтиСтроки(Новый Структура("Час,НомерСтолбца",Час,НомерСтолбца));	
	
	Если  ПараметрыОбласти.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе 
		область  = ТабличныйДокумент.Область(ПараметрыОбласти[0].ИмяОбласти);
	КонецЕсли;
	
	Смещение = (Минута/15);
	Высота   = Окр(((Длительность/15)-1)+Смещение, 0);
	
	область = ТабличныйДокумент.Область((область.Низ-(область.Низ-область.Верх))+Высота,область.Лево,область.Верх+Смещение,область.Право);	
	область.Объединить();
	
	Линия = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная,1);
	область.Обвести(Линия,Линия,Линия,Линия);
	
	Возврат область;	
		
КонецФункции

