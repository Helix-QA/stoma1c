			КонецЕсли;
			
			СотрудникОбъект.ДоступныеКассы.Очистить();
			ВыборкаСтруктурки = ВыборкаСотрудник.Выбрать();
			
			Пока ВыборкаСтруктурки.Следующий() Цикл
