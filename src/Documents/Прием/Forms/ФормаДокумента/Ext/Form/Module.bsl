// Процедура - Удалить промокод.
//
Процедура УдалитьПромокод(Параметры = Неопределено)
	
	Объект.Промокод = "";    
	ЭтотОбъект.Записать(Новый Структура("РежимЗаписи", ?(Объект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись)));
	СуммаОплаченоПоРегистру = ?(Объект.Ссылка.Пустая(), 
								0, 
								РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОплатыПоДокументу(Объект.Ссылка));
	Элементы.ГруппаИнформацияПоОплатеПодробно.Видимость  = Истина;
	ОтобразитьИнформациюПоОплате();	
	ПересчитатьАвтоматическиеСкидки();
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

