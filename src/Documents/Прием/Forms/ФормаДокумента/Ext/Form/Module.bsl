				КонецЕсли;
				
			КонецЕсли;
			
			Если СтруктураПараметров.ПолисНеограничено = Истина Тогда
				
				Если СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ + СтруктураПараметров.КоличествоЗубовВсего > СтруктураПараметров.КоличествоЗубов Тогда								
					ОписаниеОшибки = "Ограничение на количество зубов. Доступно зубов: "+ СтруктураПараметров.КоличествоЗубов;
					Возврат; 
				КонецЕсли; 
				
			Иначе
				
				Если СтруктураПараметров.ПолисКоличество <= СтруктураПараметров.КоличествоНоменклатурыВТЧ + СтруктураПараметров.КоличествоВсего Тогда			
					ОписаниеОшибки = "Ограничение по количеству услуг. Всего доступно: " + СтруктураПараметров.ПолисКоличество;
					Возврат; 				
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;  
		
	Иначе
		
		Если СтруктураПараметров.ПолисНеограничено = Ложь			
			И СтруктураПараметров.ПолисКоличество <= СтруктураПараметров.КоличествоНоменклатурыВТЧ + СтруктураПараметров.КоличествоВсего Тогда			
			
			ОписаниеОшибки = "Ограничение по количеству услуг. Всего доступно: " + СтруктураПараметров.ПолисКоличество;
			Возврат; 		
		КонецЕсли;
		
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить после согласования.
//
Процедура ДобавитьПослеСогласования(КоличествоНоменклатурыВТЧ, КоличествоВсего, ПодборДанные, СтруктураПараметров)
	
	Если ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.НеТребуется") Тогда  
		
		СтруктураПараметров.СогласованиеПриПревышении = Ложь;
		ДобавитьИзменитьУслугуПриНажатииВПодбореЗавершение(СтруктураПараметров);
		
	Иначе
		
		Если КоличествоНоменклатурыВТЧ + КоличествоВсего >= ПодборДанные.ПолисКоличествоПриПревышении Тогда
			
			ПараметрыФормы = Новый Структура();
			ПараметрыФормы.Вставить("ПолисМедСтрахования"	, Объект.ПолисМедСтрахования);	
			ПараметрыФормы.Вставить("Номенклатура"			, СтруктураПараметров.ПодборДанные.Номенклатура);
			ПараметрыФормы.Вставить("Зуб"					, СтруктураПараметров.ЭлементМЗуб);
			ПараметрыФормы.Вставить("СтатусСогласования"	, ПредопределенноеЗначение("Перечисление.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования"));			
			ПараметрыФормы.Вставить("Контрагент"			, Объект.Контрагент);
			
			РезультатФормы = ОткрытьФормуМодально("РегистрСведений.СогласованияСтраховыхУслуг.Форма.ФормаСогласования",ПараметрыФормы, ЭтаФорма);
			
			Если РезультатФормы <> Неопределено Тогда 
				
				СтруктураПараметров.СогласованиеПриПревышении = ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении");
				СтруктураПараметров.РезультатВопроса = ПредопределенноеЗначение("Перечисление.СтатусыСогласованияСтраховыхУслуг.ОжидаетСогласования");
				СтруктураПараметров.Вставить("КомментарийСогласования", РезультатФормы.КомментарийСогласования);
				ДобавитьИзменитьУслугуПриНажатииВПодбореЗавершение(СтруктураПараметров);
				
			КонецЕсли; 
			
		Иначе 
			
			СтруктураПараметров.СогласованиеПриПревышении = Ложь;
			ДобавитьИзменитьУслугуПриНажатииВПодбореЗавершение(СтруктураПараметров);
			
		КонецЕсли;				
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Функция - Вернуть количество номенклатуры ВТЧЛечение.
//
Функция ВернутьКоличествоНоменклатурыВТЧЛечение(Номенклатура) 
			
	СтрокаТЧ = Объект.Лечение.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
	
	Результат = 0;
	Если ЗначениеЗаполнено(СтрокаТЧ) Тогда
	
		Для Каждого Строка Из СтрокаТЧ Цикл
			Результат = Результат + Строка.КоличествоУпаковок;		
		КонецЦикла;
	
	КонецЕсли;

	Возврат Результат;
		
КонецФункции

&НаКлиенте
Процедура Подключаемый_ПодборТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПодборДанные = Элементы._ПодборНоменклатур.ТекущиеДанные;
	Если ПодборДанные = Неопределено
		Или ПодборДанные.ЭтоГруппа Тогда		
		Возврат;
	КонецЕсли;
	
	Если ПроверитьПрименениеВидовНалогов(ПодборДанные.Номенклатура) Тогда
		Возврат;
	КонецЕсли;                      
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Номенклатура", ПодборДанные.Номенклатура);

	Строки = Объект.Запасы.НайтиСтроки(СтруктураОтбора);
	
	Если Строки.Количество() > 0 Тогда
		
		Строки[0].КоличествоУпаковок = Строки[0].КоличествоУпаковок + 1;
		Строки[0].Количество = Строки[0].Количество + 1 * ?(ЗначениеЗаполнено(Строки[0].Упаковка), ВернутьКоэффициентУпаковкиНоменклатуры(Строки[0].Упаковка), 1);
		
	Иначе	
		НоваяСтрока                          = Объект.Запасы.Добавить();
		НоваяСтрока.КлючСтроки               = Новый УникальныйИдентификатор;
		НоваяСтрока.Номенклатура             = ПодборДанные.Номенклатура;
		НоваяСтрока.СкидкиЗапрещены          = ПодборДанные.СкидкиЗапрещены; 
		Элементы.ТаблицаТовары.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();		
	КонецЕсли; 
	
	ЗапасыНоменклатураПриИзменении(Неопределено, Истина);
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	Модифицированность = Истина;
	
	#Если не ВебКлиент Тогда
		Системнаяинформация = Новый Системнаяинформация;
		Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 
			WSHShell = Новый COMОбъект("WScript.Shell");
			WSHShell.SendKeys("+{TAB}");
		КонецЕсли;
	#Конецесли

КонецПроцедуры

