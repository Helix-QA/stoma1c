		Отбор = Новый Структура("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		ОткрытьФорму("Справочник.Кассы.ФормаВыбора", Новый Структура("Отбор", Отбор),,,,,Новый ОписаниеОповещения("ПриемникДенежныхСредствНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

