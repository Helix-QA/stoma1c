// Процедура, Обработчик события "ОбработчикНажатияЗаписиНаПрием"
//
Процедура ОбработчикНажатияЗаписиНаПрием(Элемент)
	
	Если Объект.Ссылка.Пустая() Тогда 
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи",РежимЗаписиДокумента.Запись));
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;	
		НомерСтроки = Число(СтрЗаменить(Элемент.Имя, "ДекорацияНаправления_",""));
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент"              , Объект.Контрагент);
		ПараметрыФормы.Вставить("Сотрудник"               , НаправленияНаКонсультацию[НомерСтроки].Сотрудник); 
		Если Дата(НаправленияНаКонсультацию[НомерСтроки].ДатаЗапланированная) <> Дата(1,1,1) Тогда
			ПараметрыФормы.Вставить("Дата"                , НаправленияНаКонсультацию[НомерСтроки].ДатаЗапланированная); 
		КонецЕсли;
		ПараметрыФормы.Вставить("СпециализацияВрача"      , НаправленияНаКонсультацию[НомерСтроки].Специализация); 
		ПараметрыФормы.Вставить("ЗакрытьПриСозданииЗаписи", Истина);
		
		Если ЗначениеЗаполнено(ПараметрыФормы.Сотрудник) Тогда
			ПараметрыФормы.Вставить("ПереключательПериода", ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Неделя"));
		КонецЕсли; 
		
		Если НаправленияНаКонсультацию[НомерСтроки].НаправленКСпециалисту = Ложь Тогда
			НаправленияНаКонсультацию[НомерСтроки].НаправленКСпециалисту = Истина;		 
		КонецЕсли;	 
		ОбновитьТекущуюЗаписьВРегистреПрофосмотры(НомерСтроки); 
		
		ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаПредварительнойЗаписи");	
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработчикНажатияЗаписиНаПриемЗавершение", ЭтотОбъект, Новый Структура("НомерСтроки", НомерСтроки));
		ОткрытьФорму(ИмяФормыПланировщика, ПараметрыФормы,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры
 
&НаКлиенте
// Процедура - Обработчик нажатия записи на прием завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОбработчикНажатияЗаписиНаПриемЗавершение(Результат, ДополнительныеПараметры) Экспорт
	 
	 Если Результат = Неопределено Тогда
		 Возврат;
	 КонецЕсли;	 
	 
	 НомерСтроки = ДополнительныеПараметры.НомерСтроки;
	 НаправленияНаКонсультацию[НомерСтроки].ПредварительнаяЗапись = Результат; 
	 НаправленияНаКонсультацию[НомерСтроки].НаправленКСпециалисту = Истина;
	 НаправленияНаКонсультацию[НомерСтроки].Статус                = ПредопределенноеЗначение("Перечисление.СтатусыПрофосмотров.Согласился");
	 НаправленияНаКонсультацию[НомерСтроки].ПЗДатаСоздания        = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Результат, "Дата");
	 ОбновитьТекущуюЗаписьВРегистреПрофосмотры(НомерСтроки, Истина);   
	 
	 Если Элементы.ГруппаРезультатЛечения.Скрыта() Тогда 		
		 Элементы.ГруппаРезультатЛечения.Показать();
	 КонецЕсли;  
	  
КонецПроцедуры
 
&НаКлиенте 
// Процедура, Обработчик события "ОбработчикОткрытьПредварительнуюЗапись"
//
Процедура ОбработчикОткрытьПредварительнуюЗапись(Элемент)
	
	НомерСтроки = Число(СтрЗаменить(Элемент.Имя, "ДекорацияПредварительнойЗаписи_",""));
	ПоказатьЗначение(, НаправленияНаКонсультацию[НомерСтроки].ПредварительнаяЗапись);
	 
КонецПроцедуры  

&НаКлиенте 
// Процедура, Обработчик события "АвтоПодборВрача"
//
Процедура АвтоПодборВрача(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка) 
	
	СтандартнаяОбработка = Ложь;
	Строка      = СтрРазделить(Элемент.Имя, "_");
	ИмяЭлемента = ?(ЗначениеЗаполнено(Строка), Строка[0], "");
	
	Если ИмяЭлемента = "ВрачГигиенист" Тогда
		Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Гигиена");
	ИначеЕсли ИмяЭлемента = "ВрачТерапевт" Тогда
		Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Терапия");		
	ИначеЕсли ИмяЭлемента = "ВрачОртопед" Тогда
		Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Ортопедия");
	ИначеЕсли ИмяЭлемента = "ВрачОртодонт" Тогда 
		Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Ортодонтия");
	ИначеЕсли ИмяЭлемента = "ВрачПародонтолог" Тогда  
		Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Парадонтология");
	ИначеЕсли ИмяЭлемента = "ВрачХирург" Тогда  
		Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Хирургия");
	КонецЕсли;
	
	ДанныеВыбора = ПолучитьМассивВрачейПоСпециализации(Специализация); 
	
КонецПроцедуры  	

&НаСервереБезКонтекста
// Функция - Получить список значений врачей по специализации
//
// Параметры:
//  Специализация	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивВрачейПоСпециализации(Специализация)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СотрудникиСпецилазацииСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|ГДЕ
	|	СотрудникиСпецилазацииСотрудника.Специализация = &Специализация
	|	И НЕ СотрудникиСпецилазацииСотрудника.Ссылка.ПометкаУдаления
	|	И НЕ СотрудникиСпецилазацииСотрудника.Ссылка.ЭтоГруппа");
	
	Запрос.УстановитьПараметр("Специализация", Специализация);
	СписокЗначений = Новый СписокЗначений;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий()Цикл   
		СписокЗначений.Добавить(Выборка.ссылка);
	КонецЦикла;
	Возврат СписокЗначений;  
	
КонецФункции  

&НаСервере
// Выгрузить таблицу значений парамтеров в регистр хранения данных
//
Процедура ЗаписатьДанныеДокументаОбследования(ТекущийОбъект = Неопределено)	
	
	Если ТекущийОбъект <> Неопределено Тогда	
		Прием 				= ТекущийОбъект.Ссылка; 
		ШаблонОбследования 	= ТекущийОбъект.ШаблонОбследования; 
		Дата 				= ТекущийОбъект.Дата;
	Иначе
		Прием 				= Объект.Ссылка; 
		ШаблонОбследования 	= Объект.ШаблонОбследования; 
		Дата 				= Объект.Дата;
  	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.ЗначенияПараметровОбследований.СоздатьНаборЗаписей();	
	НаборЗаписей.Отбор.Документ.Установить(Прием);	
	НаборЗаписей.Прочитать();	
	НаборЗаписей.Очистить();
	НаборЗаписей.Записать();	
	НаборЗаписей = РегистрыСведений.ЗначенияПараметровОбследований.СоздатьНаборЗаписей();	
	НаборЗаписей.Отбор.Документ.Установить(Прием);	
	НаборЗаписей.Отбор.ШаблонОбследования.Установить(ШаблонОбследования);
	НаборЗаписей.Прочитать();	
	
	// Для реквизита типа "Строка" в значение сохраняем обрезанный текст,
	// т.к. если больше 397 символов выдает ошибку (293291).
	
	Для Каждого СтрокаТ Из ДОЗначенияРеквизитовОбследования Цикл
		НоваяЗапись                    = НаборЗаписей.Добавить();		
		НоваяЗапись.Период             = Дата;		
		НоваяЗапись.Документ           = Прием;	
		НоваяЗапись.ШаблонОбследования = ШаблонОбследования;
		НоваяЗапись.Параметр           = СтрокаТ.Реквизит; 
		НоваяЗапись.Значение           = ?(ТипЗнч(СтрокаТ.РеквизитЗначение) = Тип("Строка"), Сред(СтрокаТ.РеквизитЗначение, 1, 100), СтрокаТ.РеквизитЗначение);
		НоваяЗапись.ЗначениеСтрокой    = ?(ТипЗнч(СтрокаТ.РеквизитЗначение) = Тип("СправочникСсылка.Диагнозы"), СтрокаТ.РеквизитЗначение, СтрокаТ.РеквизитЗначениеСтрокой);
		НоваяЗапись.Зуб                = СтрокаТ.ЗубЗначение;
		НоваяЗапись.ПорядковыйНомер    = ПолучитьПорядковыйНомерРеквизитаШаблонаОбследования(СтрокаТ.Реквизит);
	КонецЦикла;	
	НаборЗаписей.Записать();
	
	ДОДокументИзменен = Ложь;
	
	Если ЗначениеЗаполнено(ИдентификаторБлокируемойФормы) Тогда
    	РазблокироватьДанныеДляРедактирования(, ИдентификаторБлокируемойФормы);                      
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Получить реквизит шаблона
//
Функция ПолучитьПорядковыйНомерРеквизитаШаблонаОбследования(Реквизит)
    // Получить основной идетификтор реквизита
	НайденныеСтроки = ДОРеквизитыШаблонОбследования.НайтиСтроки(Новый Структура("Реквизит",Реквизит));
	Если НайденныеСтроки.Количество() > 0 Тогда		
		Возврат НайденныеСтроки[0].ПорядковыйНомер; 
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаСервере
// Процедура, Обработчик события "ОбновитьТекущуюЗаписьВРегистреПрофосмотры".
//
Процедура ОбновитьТекущуюЗаписьВРегистреПрофосмотры(Индекс, ОбновитьНаправления = Ложь)
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		ЭтаФорма.Записать();
	КонецЕсли;	
	
	СтрокаТЧ = НаправленияНаКонсультацию[Индекс];
	
	СтрокаТЧ.Период                                     = ?(ЗначениеЗаполнено(СтрокаТЧ.Период), СтрокаТЧ.Период, ТекущаяДата()); 
	НаборЗаписей                                        = РегистрыСведений.Профосмотры.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Значение                  = СтрокаТЧ.Период; 
	НаборЗаписей.Отбор.Период.Использование             = Истина;
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Значение      = Объект.СтруктурнаяЕдиница;
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Использование = Истина;
	НаборЗаписей.Отбор.Контрагент.Значение              = Объект.Контрагент; 
	НаборЗаписей.Отбор.Контрагент.Использование         = Истина; 
	НаборЗаписей.Отбор.ВидОсмотра.Значение              = СтрокаТЧ.ВидОсмотра;
	НаборЗаписей.Отбор.ВидОсмотра.Использование         = Истина;
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() = 0 Тогда
		Если СтрокаТЧ.НаправленКСпециалисту Тогда
			НоваяЗапись                     = НаборЗаписей.Добавить(); 
			ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТЧ); 
			НоваяЗапись.СтруктурнаяЕдиница  = Объект.СтруктурнаяЕдиница;
			НоваяЗапись.Контрагент          = Объект.Контрагент;
			НоваяЗапись.Прием               = Объект.Ссылка;
			НоваяЗапись.АвторЗаписи         = ПараметрыСеанса.ТекущийСотрудник;
			НоваяЗапись.Статус              = Перечисления.СтатусыПрофосмотров.Запланирован;
			Если НоваяЗапись.ВидОсмотра     = Перечисления.ВидыОсмотров.Направление Тогда 
				НоваяЗапись.НаправившийВрач = Объект.Сотрудник; 
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник) Тогда  
				НоваяЗапись.Сотрудник = СтрокаТЧ.Сотрудник; 
			КонецЕсли; 	
			НаборЗаписей.Записать(); 
			Если ЗначениеЗаполнено(НаборЗаписей) И НаборЗаписей[0].ВидОсмотра = Перечисления.ВидыОсмотров.Повторныйприем Тогда 
				// Ищем следующую запись данного пациента к этому же врачу, если есть то перерисуем результат приема для отображения этой записи 
				ПредвариетльнаяЗапись = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НаборЗаписей.ДополнительныеСвойства, "ПредварительнаяЗапись");
				Если ЗначениеЗаполнено(ПредвариетльнаяЗапись) Тогда  
					ОбновитьНаправления = Истина; 
				КонецЕсли;			
			КонецЕсли; 
		Иначе
			Возврат;
		КонецЕсли;
	Иначе  
		НоваяЗапись = НаборЗаписей[0];
		Если СтрокаТЧ.НаправленКСпециалисту = Ложь И НЕ ЗначениеЗаполнено(НоваяЗапись.ПредварительнаяЗапись) Тогда 		
			Если НоваяЗапись.ВидОсмотра = Перечисления.ВидыОсмотров.Повторныйприем ИЛИ НоваяЗапись.ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр Тогда
				НаправленияНаКонсультацию.Удалить(Индекс);
			КонецЕсли;	 
			Если ЗначениеЗаполнено(НоваяЗапись.Сделка) Тогда
				СделкаИзЗаписи                       = НоваяЗапись.Сделка.ПолучитьОбъект();
				СделкаИзЗаписи.ПометкаУдаления       = Истина;
				СделкаИзЗаписи.ОбменДанными.Загрузка = Истина;
				СделкаИзЗаписи.Записать();
			КонецЕсли;
			НаборЗаписей.Удалить(НаборЗаписей[0]); 
			НаборЗаписей.Записать(); 			
		Иначе 
			Если Не ЗначениеЗаполнено(СтрокаТЧ.ПредварительнаяЗапись) И НоваяЗапись.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда
				НоваяЗапись.Длительность        = СтрокаТЧ.Длительность;
				НоваяЗапись.ДатаЗапланированная = СтрокаТЧ.ДатаЗапланированная;
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаТЧ.ПредварительнаяЗапись) Тогда
				СтруктураДлительности             = Документы.Событие.ПолучитьПродолжительностьСобытия(СтрокаТЧ.ПредварительнаяЗапись);
				НоваяЗапись.ПредварительнаяЗапись = СтрокаТЧ.ПредварительнаяЗапись;
				НоваяЗапись.ДатаЗапланированная   = СтруктураДлительности.ДатаНачала;
				НоваяЗапись.Длительность          = СтруктураДлительности.Длительность; 
				НоваяЗапись.Статус                = Перечисления.СтатусыПрофосмотров.Согласился; 
				Если НоваяЗапись.ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр И Не ЗначениеЗаполнено(НоваяЗапись.Сделка) Тогда 
					НоваяЗапись.Сделка           = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТЧ.ПредварительнаяЗапись, "Сделка")
				КонецЕсли;
				Если Не ЗначениеЗаполнено(НоваяЗапись.Сотрудник) И Не ЗначениеЗаполнено(СтрокаТЧ.Сотрудник) Тогда 
					НоваяЗапись.Сотрудник         = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТЧ.ПредварительнаяЗапись, "Врач");
				КонецЕсли;
			КонецЕсли;									  
			Если НЕ ЗначениеЗаполнено(НоваяЗапись.Сотрудник) Тогда
				НоваяЗапись.Сотрудник             = СтрокаТЧ.Сотрудник; 					
			КонецЕсли; 
			Если НоваяЗапись.ВидОсмотра = Перечисления.ВидыОсмотров.Направление И НЕ ЗначениеЗаполнено(НоваяЗапись.НаправившийВрач) Тогда 
				НоваяЗапись.НаправившийВрач       = СтрокаТЧ.НаправившийВрач;
			КонецЕсли; 
			Если НоваяЗапись.ДатаЗапланированная <> СтрокаТЧ.ДатаЗапланированная Тогда
				НоваяЗапись.ДатаЗапланированная = СтрокаТЧ.ДатаЗапланированная;
			КонецЕсли;
			НоваяЗапись.Комментарий               = СтрокаТЧ.Комментарий;
			НаборЗаписей.Записать();			
		КонецЕсли; 
	КонецЕсли;
	
	Если ОбновитьНаправления Тогда 
		ОбновитьСписокНаправленийНаКонсультацию();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере 
// Процедура, Обработчик события "ДобавитьСтрокуВНаправленияНаКонсультацию".
//
Процедура ДобавитьСтрокуВНаправленияНаКонсультацию(ВидОсмотра) 
	
	Если ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда
		ДатаЗапланированная = ВернутьДатуСледующегоПриемаПриОкончании(Объект.Дата, ЭтотОбъект.ФормаПовторныйПриемИнтервал, ЭтотОбъект.ФормаИнтервалПередПриемом);
	Иначе 
		ДатаЗапланированная = ДобавитьМесяц(Объект.Дата, Объект.ПрофосмотрИнтервал);
	КонецЕсли;
	
	СтрокаТЧ                       = НаправленияНаКонсультацию.Добавить();
	СтрокаТЧ.НаправленКСпециалисту = ?(ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием, ФормаПовторныйПриемИспользовать, ФормаПрофосмотрИспользовать);
	СтрокаТЧ.ВидОсмотра            = ВидОсмотра;
	СтрокаТЧ.Сотрудник             = Объект.Сотрудник;
	Если ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда
		СтрокаТЧ.Длительность      = ДлительностьПриема;
	КонецЕсли;
	СтрокаТЧ.Период                = ТекущаяДата(); 
	Если ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр Тогда
		СтрокаТЧ.Комментарий       = ПрофосмотрКомментарий;	
	Иначе
		СтрокаТЧ.Комментарий       = КомментарийПовторногоПриема;
	КонецЕсли;	
	СтрокаТЧ.ДатаЗапланированная   = ДатаЗапланированная;
	
КонецПроцедуры	

#Область СсылкиНаОплату

&НаКлиенте
// Процедура - Ссылка на оплату
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СсылкаНаОплату(Команда)
	
	МассивПодстрок = СтрРазделить(Команда.Имя, "_", Ложь);
	
	НомерЗаказа = ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], Неопределено); 
	
	Если ЗначениеЗаполнено(НомерЗаказа) Тогда	
						
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("НомерЗаказа", НомерЗаказа);
		
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОтправкиПлатежейСБП", ПараметрыФормы,,,,, Новый ОписаниеОповещения("ГенерацияСсылкиЗавершение", ЭтотОбъект));
		
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить ссылку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОтменитьСсылку(Команда)
	
	МассивПодстрок	= СтрРазделить(Команда.Имя, "_", Ложь);	
	НомерЗаказа		= ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], Неопределено); 
	
	Если Не ЗначениеЗаполнено(НомерЗаказа) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найден номер заказа");
		Возврат;
	КонецЕсли;
	
	Если ЭтаФорма.Модифицированность = Истина Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ был изменен, необходимо записать документ");
		Возврат;		
	КонецЕсли;
		
	ТекстВопроса = НСтр("ru='Отмена ссылки приведет к невозможности автоматической оплаты по этой ссылке.
						|Продолжить?';
						|en='Cancellation of the link will result in the inability to automatically pay for this link.
						|Continue?'");
	
	ЗаголовокВопроса	= НСтр("ru='Внимание!';en='Attention!'");
	ДопПараметры		= Новый Структура("НомерЗаказа", НомерЗаказа);
	ОписаниеОповещения	= Новый ОписаниеОповещения("ОтменитьСсылкуНаОплатуЗавершение", ЭтаФорма, ДопПараметры);
	
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет,,, ЗаголовокВопроса);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить ссылку на оплату завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ОтменитьСсылкуНаОплатуЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Да И ЗначениеЗаполнено(Параметры.НомерЗаказа) Тогда			
		ОтменитьСсылкуНаОплатуСервер(Параметры.НомерЗаказа);						
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Отменить ссылку на оплату сервер
//
// Параметры:
//  СсылкаНаОплату	 - 	 - 
//
Процедура ОтменитьСсылкуНаОплатуСервер(НомерЗаказа)
	
	ТаблицаЗаказа = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьНеОплаченныеЗаказыПоДокументу(, НомерЗаказа);
	
	Если ТаблицаЗаказа.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найдена ссылка на оплату");		
		Возврат;
	КонецЕсли;
		
	ИскомыйЗаказ = ТаблицаЗаказа[0];
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СсылкаНаОплату"			, ИскомыйЗаказ.СсылкаОплаты);
	СтруктураПараметров.Вставить("ТаблицаЗадолженностей"	, ТаблицаЗаказа);
	СтруктураПараметров.Вставить("ЭквайринговыйТерминал"	, ИскомыйЗаказ.ЭквайринговыйТерминал);
	СтруктураПараметров.Вставить("НомерЗаказа"				, НомерЗаказа);
	
	Результат = СсылкиНаОплатуИСБП.ОтменитьСсылкуНаОплату(СтруктураПараметров);
	
	Если Результат.ВыполненоУспешно Тогда		
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();
	Иначе		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения "ГенерацияСсылкиЗавершение".
//
Процедура ГенерацияСсылкиЗавершение(Результат, Контекст) Экспорт
	
	РезультатПолучен = Результат <> Неопределено;
	
	Если РезультатПолучен И Результат.ОбновитьИнформациюОСсылкахНаОплату Тогда
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();	
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Процедура - Обновить информацию по использованию ссылки на оплату клиент
//
// Параметры:
//  ЭтаФорма - 	 - 
//
Процедура ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер()
	
	СсылкиНаОплатуИСБП.ОбновитьИнформациюПоИспользованиюСсылкиНаОплату(ЭтаФорма);

КонецПроцедуры

