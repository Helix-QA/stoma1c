&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля "ВидОперации".
//
Процедура ВидОперацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекущаяОперация = Объект.ВидОперации;
КонецПроцедуры

&НаСервере
// Процедура - обработчик события на сервере "ПриИзменении" поля "ВидОперации".
//
Процедура ВидОперацииПриИзмененииСервер()
		
	Если ТекущаяОперация <> Объект.ВидОперации Тогда	
		Если Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОтПодотчетника Тогда
			Объект.БанковскийСчет              = Неопределено;
			Объект.БанковскийСчетКонтрагента   = Неопределено;
			Объект.Касса	                   = Неопределено;	
			Если НЕ (Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента
				ИЛИ Объект.ВидОперации  = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет) Тогда
				Объект.Контрагент                   = Неопределено;
				Объект.ЛицевойСчетКонтрагента       = Неопределено;
				Объект.ЭквайрингВидПлатежнойКарты   = Неопределено;
				Объект.ЭквайрингНомерПлатежнойКарты = Неопределено;
			КонецЕсли;
		КонецЕсли;
		Объект.Статья = Справочники.СтатьиДоходовИРасходов.ПолучитьСтатьюПоУмолчаниюДляОперации(Объект.ВидОперации);
		Для Каждого ЭлементТЧ Из Объект.РасшифровкаПлатежа Цикл 
			ЭлементТЧ.Статья = Объект.Статья;		
		КонецЦикла;
		// Пересчет суммы коммии банка
		Если Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеОтЭквайера Тогда
			ПроцентКомиссии                    = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.ЭквайрингТерминал, "ПроцентКомиссии");
			Объект.ЭквайрингСуммаКомиссииБанка = (Объект.СуммаДокумента * ПроцентКомиссии) / (100 - ПроцентКомиссии);
		ИначеЕсли Объект.ЭквайрингСуммаКомиссииБанка <> 0 Тогда
			Объект.ЭквайрингСуммаКомиссииБанка = 0;
		КонецЕсли;	
		
		// Зачищаем таблицу расшифровки
		Объект.РасшифровкаПлатежа.Очистить();	
		СтрокаТаблицы        = Объект.РасшифровкаПлатежа.Добавить();
		СтрокаТаблицы.Сумма  = Объект.СуммаДокумента;	
		СтрокаТаблицы.Статья = Объект.Статья;
		
	КонецЕсли;	
	УстановитьВидимость();
	УстановитьДоступностьПечатиЧека();
	
КонецПроцедуры // ВидОперацииПриИзмененииСервер()

&НаКлиенте
// Перед началом выбора контрагента
Процедура КонтрагентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВзносУчредителя")
		ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратНалога") Тогда
		
		СтруктураПараметры = Новый Структура;
				
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбора",СтруктураПараметры,,,,, Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект));
		
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика")
		ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратЗайма") Тогда
		
		СтруктураПараметры = Новый Структура;
		Массив = Новый Массив;
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Поставщик"));
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Клиенты"));
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.КорпоративныеКонтрагенты"));
		
		СтруктураПараметры = Новый Структура("Отбор", Новый Структура("ТипКонтрагента", Новый ФиксированныйМассив(Массив)));	
		
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбора",СтруктураПараметры,,,,, Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект));
		
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОтПодотчетника") Тогда
		
		ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора",,,,,, Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект));
		
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтСтраховойКомпании") Тогда
		
		СтруктураПараметры = Новый Структура;
		Массив = Новый Массив;
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.СтраховаяКомпания"));
		
		СтруктураПараметры = Новый Структура("Отбор", Новый Структура("ТипКонтрагента", Новый ФиксированныйМассив(Массив)));	
		
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбора",СтруктураПараметры,,,,, Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект));
	
	Иначе	
		
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты",,,,,, Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Объект.Контрагент = Результат;
		КонтрагентПриИзмененииСервер();
		ТекущийКонтрагент = Результат;		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поля контрагент
//
Процедура КонтрагентПриИзменении(Элемент)
	КонтрагентПриИзмененииСервер();
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ПроверитьТекущиеНапоминанияПоПосещениямСтоматология(Объект.Контрагент);
    КонецЕсли;	
КонецПроцедуры

&НаСервере
// При изменении контрагента, сервер
Процедура КонтрагентПриИзмененииСервер()
	
	Если ТекущийКонтрагент <> Объект.Контрагент Тогда
		Объект.БанковскийСчетКонтрагента    = Неопределено;
		// Объект.ЛицевойСчетКонтрагента       = Неопределено;
		Объект.ЭквайрингВидПлатежнойКарты   = Неопределено;
		Объект.ЭквайрингНомерПлатежнойКарты = Неопределено;
		Объект.Договор                      = Неопределено;
		// Установка банковского счета контрагента по умолчанию(при указанных условиях)
		Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
			И НЕ Объект.ВидОперации    = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет	
			И ЗначениеЗаполнено(Объект.Контрагент) Тогда	
			Объект.БанковскийСчетКонтрагента = Объект.Контрагент.БанковскийСчетПоУмолчанию;
		КонецЕсли; 
		ОбновитьИнформациюПоОстаткамЛСиЗадолженностям();
		Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Контрагент) 
			И ?(ТипЗнч(Объект.Контрагент) = Тип("СправочникСсылка.Контрагенты") 
			И Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Ложь, Истина);
	КонецЕсли;
	
КонецПроцедуры

