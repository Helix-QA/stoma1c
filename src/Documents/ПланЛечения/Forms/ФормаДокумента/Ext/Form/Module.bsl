	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ПараметрыФормы = Новый Структура("Контрагент", Объект.Контрагент);
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ДиалогВзносаНаЛицевойСчет", ПараметрыФормы, ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе 
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сначала необходимо выбрать пациента";
		Сообщение.Поле = "Объект.Контрагент";
		Сообщение.УстановитьДанные(Объект);
		Сообщение.Сообщить();
