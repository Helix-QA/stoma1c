#Область Рассылка

&НаСервере
// Процедура, заполняет сервисы рассылки.
//
Процедура ЗаполнитьСервисыРассылки()
	
	ЭтотОбъект.НомерТелефона 	= ПолучитьКонтактныеДанныеКонтрагента("Телефон");
	ЭтотОбъект.АдресЭП			= ПолучитьКонтактныеДанныеКонтрагента("АдресЭлектроннойПочты");
	
	ВнешняяСистемаМессенджер	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.GreenApi);
	//ВнешняяСистемаМобПриложение	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента);
		
	Элементы.ГруппаМессенджер.Видимость	= ЗначениеЗаполнено(ВнешняяСистемаМессенджер) И ЗначениеЗаполнено(НомерТелефона);
	Элементы.ГруппаEmail.Видимость		= ЗначениеЗаполнено(ЭтотОбъект.АдресЭП) И ПроверитьВозможностьИспользованияEmailРассылки();
	Элементы.ГруппаSMS.Видимость		= ЗначениеЗаполнено(НомерТелефона) И ПроверитьВозможностьИспользованияSMSРассылки();
	//Элементы.ГруппаPush.Видимость		= ЗначениеЗаполнено(ВнешняяСистемаМобПриложение) И ЗначениеЗаполнено(НомерТелефона) И РегистрыСведений.КлючиВнешнихСистем.КонтрагентЗарегистрированДляВнешнейСистемы(Контрагент, Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента);
		
КонецПроцедуры

&НаСервере
// Функция, проверяет возможность использования sms рассылки.
//
Функция ПроверитьВозможностьИспользованияSMSРассылки()
	
	СервисSMSРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	
	Если Не ЗначениеЗаполнено(СервисSMSРассылки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	БалансАккаунтаSMS = Справочники.СервисыРассылки.ПолучитьБалансАккаунтаSMS(СервисSMSРассылки);
	
	Возврат БалансАккаунтаSMS.Ошибка = Ложь И ТипЗнч(БалансАккаунтаSMS.Баланс) = Тип("Число") И БалансАккаунтаSMS.Баланс > 0;
	
КонецФункции

&НаСервере
// Функция, проверяет возможность использования eamil рассылки.
//
Функция ПроверитьВозможностьИспользованияEmailРассылки()

	ДоступныеУчетныеЗаписи = Новый СписокЗначений;
	УправлениеЭлектроннойПочтой.ПолучитьДоступныеУчетныеЗаписиДляОтправки(ДоступныеУчетныеЗаписи);
	
	УчетнаяЗапись = ?(ДоступныеУчетныеЗаписи.Количество() > 0, ДоступныеУчетныеЗаписи[0].Значение, Неопределено);		
	
	Возврат ЗначениеЗаполнено(УчетнаяЗапись);
	
