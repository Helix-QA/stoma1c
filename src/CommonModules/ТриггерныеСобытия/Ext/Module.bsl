Процедура Процедура_ОбработкаГруппаСтрока_ТЧ_Действия(Форма, Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов)
	
	Если НЕ ИндексСтроки = Неопределено Тогда
		Форма.УстановитьСвойстваЭлементамСтрокиДействий(Элемент, ИндексСтроки, ПараметрыОтображенияЭлементов);
		Элемент.Подсказка = "";
	КонецЕсли;

КонецПроцедуры	

Процедура Процедура_ОбработкаПоля_Использование(Форма, Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов)
	
	Если НЕ ИндексСтроки = Неопределено Тогда
		Элемент.ПутьКДанным = "Объект.Действия[" + Строка(ИндексСтроки) + "].Использование";
	КонецЕсли;
	
	Форма.УстановитьСвойстваЭлементамСтрокиДействий(Элемент, ИндексСтроки, ПараметрыОтображенияЭлементов);
	
	Элемент.ПоложениеЗаголовка = ?(ПараметрыОтображенияЭлементов.ЭтоПерваяАктуальнаяСтрока, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
	Элемент.Подсказка = ?(СтрокаТаблицы.Использование = Истина, Нстр("ru = 'Выполняется'; en = 'Hold true'"), Нстр("ru = 'Не выполняется'; en = 'Not running'"));
	
КонецПроцедуры

Процедура Процедура_ОбработкаПоля_ВидДействия(Форма, Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ПараметрыОтображенияЭлементов)
	
	Если НЕ ИндексСтроки = Неопределено Тогда
		Элемент.ПутьКДанным = "Объект.Действия[" + ИндексСтроки + "].ВидДействия";
	КонецЕсли;
	
	Форма.УстановитьСвойстваЭлементамСтрокиДействий(Элемент, ИндексСтроки, ПараметрыОтображенияЭлементов);
	
	Элемент.КнопкаВыпадающегоСписка = Истина;						
	Элемент.ПоложениеЗаголовка 	= ?(ПараметрыОтображенияЭлементов.ЭтоПерваяАктуальнаяСтрока, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
	Элемент.Подсказка 			= Нстр("ru = 'Вариант инициируемого действия'; en = 'Option of the action to initiate'");
	
