		//|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		//|			ПланЛеченияЛечение.Ссылка КАК Ссылка,
		//|			ПланЛеченияЛечение.Зуб КАК Зуб,
		//|			СУММА(ПланЛеченияЛечение.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
		//|			ПланЛеченияЛечение.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
		//|			ПланЛеченияЛечение.Номенклатура КАК Номенклатура,
		//|			ПланЛеченияЛечение.НомерПриема КАК НомерПриема,
		//|			ПланЛеченияЛечение.Цена КАК Цена
		//|		ИЗ
		//|			Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
		//|		ГДЕ
		//|			ПланЛеченияЛечение.Ссылка = &ОтборДокумент
		//|		
		//|		СГРУППИРОВАТЬ ПО
		//|			ПланЛеченияЛечение.Ссылка,
		//|			ПланЛеченияЛечение.Зуб,
		//|			ПланЛеченияЛечение.ПроцентСкидкиНаценки,
		//|			ПланЛеченияЛечение.Номенклатура,
		//|			ПланЛеченияЛечение.НомерПриема,
		//|			ПланЛеченияЛечение.Цена) КАК ВложенныйЗапрос
		//|		ПО ПланыЛеченияОстатки.ПланЛечения = ВложенныйЗапрос.Ссылка
		//|			И ПланыЛеченияОстатки.Номенклатура = ВложенныйЗапрос.Номенклатура
		//|			И ПланыЛеченияОстатки.Зуб = ВложенныйЗапрос.Зуб
		//|			И ПланыЛеченияОстатки.НомерПриема = ВложенныйЗапрос.НомерПриема
		//|ГДЕ
		//|	ВложенныйЗапрос.Ссылка = &ОтборДокумент
		//|	И ПланыЛеченияОстатки.КоличествоОстаток > 0
		//|
		//|СГРУППИРОВАТЬ ПО
		//|	ПланыЛеченияОстатки.ПланЛечения,
		//|	ПланыЛеченияОстатки.Номенклатура,
		//|	ПланыЛеченияОстатки.Зуб,
		//|	ПланыЛеченияОстатки.НомерПриема,
		//|	ВложенныйЗапрос.Цена,
		//|	ВложенныйЗапрос.ПроцентСкидкиНаценки,
		//|	ВложенныйЗапрос.СуммаАвтоматическойСкидкиНаценки
		//|
		//|УПОРЯДОЧИТЬ ПО
		//|	НомерЗаказаПриема";
		
#КонецОбласти

	ИначеЕсли ТипЗнч(ОтборДокумент) = Тип("ДокументСсылка.НарядЗаказ") Тогда
		Запрос       = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	УслугиСотрудника.Номенклатура КАК Номенклатура
		               |ПОМЕСТИТЬ ВТУслугиСотрудника
		               |ИЗ
		               |	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
		               |ГДЕ
		               |	УслугиСотрудника.Сотрудник = &Сотрудник
		               |	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		               |
		               |ИНДЕКСИРОВАТЬ ПО
		               |	Номенклатура
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	НарядЗаказОстатки.НарядЗаказ КАК НарядЗаказ,
		               |	НарядЗаказОстатки.НомерЗаказа КАК НомерЗаказаПриема,
		               |	НарядЗаказОстатки.НомерЗуба КАК Зуб,
		               |	НарядЗаказОстатки.Номенклатура КАК Номенклатура,
		               |	НарядЗаказОстатки.Количество КАК Количество,
		               |	ДокументНарядЗаказ.ЦенаПродажи КАК Цена,
		               |	ДокументНарядЗаказ.СуммаПродажи КАК Сумма,
		               |	ДокументНарядЗаказ.Партия КАК Партия,
		               |	НарядЗаказОстатки.КлючСтроки КАК КлючСтроки,
		               |	НарядЗаказОстатки.Номенклатура.КодУслуги КАК КодУслуги
		               |ИЗ
		               |	(ВЫБРАТЬ
		               |		НарядЗаказы.НарядЗаказ КАК НарядЗаказ,
		               |		НарядЗаказы.НомерЗаказа КАК НомерЗаказа,
		               |		НарядЗаказы.НомерЗуба КАК НомерЗуба,
		               |		НарядЗаказы.Номенклатура КАК Номенклатура,
		               |		СУММА(ВЫБОР
		               |				КОГДА НарядЗаказы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		               |					ТОГДА НарядЗаказы.Количество
		               |				ИНАЧЕ -НарядЗаказы.Количество
		               |			КОНЕЦ) КАК Количество,
		               |		НарядЗаказы.КлючСтроки КАК КлючСтроки
		               |	ИЗ
		               |		РегистрНакопления.НарядЗаказы КАК НарядЗаказы
		               |	ГДЕ
		               |		НарядЗаказы.НарядЗаказ = &ОтборДокумент
		               |	
		               |	СГРУППИРОВАТЬ ПО
		               |		НарядЗаказы.КлючСтроки,
		               |		НарядЗаказы.Номенклатура,
		               |		НарядЗаказы.НарядЗаказ,
		               |		НарядЗаказы.НомерЗаказа,
		               |		НарядЗаказы.НомерЗуба) КАК НарядЗаказОстатки
		               |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		               |			НарядЗаказЗапасы.Ссылка КАК Ссылка,
		               |			НарядЗаказЗапасы.Партия КАК Партия,
		               |			СУММА(НарядЗаказЗапасы.ЦенаПродажи) КАК ЦенаПродажи,
		               |			СУММА(НарядЗаказЗапасы.СуммаПродажи) КАК СуммаПродажи,
		               |			НарядЗаказЗапасы.КлючСтроки КАК КлючСтроки
		               |		ИЗ
		               |			Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
		               |		ГДЕ
		               |			НарядЗаказЗапасы.Ссылка = &ОтборДокумент
		               |		
		               |		СГРУППИРОВАТЬ ПО
		               |			НарядЗаказЗапасы.КлючСтроки,
		               |			НарядЗаказЗапасы.Партия,
		               |			НарядЗаказЗапасы.Ссылка) КАК ДокументНарядЗаказ
		               |		ПО НарядЗаказОстатки.КлючСтроки = ДокументНарядЗаказ.КлючСтроки
		               |ГДЕ
		               |	НарядЗаказОстатки.Количество > 0
		               |	И НЕ НарядЗаказОстатки.КлючСтроки В (&МассивУжеДобавленныхСтрок)
		               |	И ВЫБОР
		               |			КОГДА НарядЗаказОстатки.Номенклатура.ЭтоУслуга
		               |				ТОГДА НарядЗаказОстатки.Номенклатура В
		               |						(ВЫБРАТЬ
		               |							Т.Номенклатура
		               |						ИЗ
		               |							ВТУслугиСотрудника КАК Т)
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ";
		
