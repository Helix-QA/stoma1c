// Процедура - Сжать ширину кнопок сделок
//
Процедура СжатьШиринуКнопокСделок(Форма, ГруппаРодительВиджет, ПоместитьПлюс = Ложь) 
	
	СвободноеКоличествоСимволов = 0;
	КоличествоОбрезаемыхКнопок = 0;		
	ШиринаПлюса = ?(ПоместитьПлюс = Истина, 1, 0);	
	ЛишнееКоличествоСимволов = Новый Массив;
	
	ДопустимаяШирина = ?(НЕ СтрНайти(ГруппаРодительВиджет.Имя, "Архив") = 0, 20, 22 - ШиринаПлюса);
	
	Для Каждого ГруппаТелоСделки Из ГруппаРодительВиджет.ПодчиненныеЭлементы Цикл
		
		КолвоСимволовКнопокСделки = 0;
		СтруктураЗначение = 0;
		КолвоВидимыхКнопок = 0;
		Для Каждого ЭлементТелаСделки Из ГруппаТелоСделки.ПодчиненныеЭлементы Цикл				
			
			Если ТипЗнч(ЭлементТелаСделки) = Тип("КнопкаФормы") И ЭлементТелаСделки.Видимость = Истина Тогда 
				КолвоСимволовКнопокСделки = КолвоСимволовКнопокСделки + Цел(СтрДлина(ЭлементТелаСделки.Заголовок) / 1.2); // Делим на 1.2 для усреднения ширины
				КолвоВидимыхКнопок = КолвоВидимыхКнопок + 1;
			КонецЕсли;
			
		КонецЦикла;
		
		СвободноеКоличествоСимволов = СвободноеКоличествоСимволов + ?(КолвоСимволовКнопокСделки < ДопустимаяШирина, (ДопустимаяШирина - КолвоСимволовКнопокСделки), 0);				 		
		СтруктураЗначение = ?(КолвоСимволовКнопокСделки > ДопустимаяШирина, КолвоСимволовКнопокСделки - ДопустимаяШирина, СтруктураЗначение); 
		
		ЛишнееКоличествоСимволов.Добавить(Новый Структура("КолвоСимволов, КолвоКнопок", СтруктураЗначение, КолвоВидимыхКнопок));		
		КоличествоОбрезаемыхКнопок = КоличествоОбрезаемыхКнопок + ?(СтруктураЗначение = 0, 0, 1);
		
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(КоличествоОбрезаемыхКнопок) Тогда
		
		ДобавочноеКоличествоСимволов = Цел(СвободноеКоличествоСимволов / КоличествоОбрезаемыхКнопок);
		
		Для ИтераторСтруктура = 0 По ЛишнееКоличествоСимволов.Количество()-1 Цикл
			
			Если НЕ ЛишнееКоличествоСимволов[ИтераторСтруктура].КолвоСимволов = 0 Тогда				
				НоваяШирина = ?(ЛишнееКоличествоСимволов[ИтераторСтруктура].КолвоСимволов < ДобавочноеКоличествоСимволов, 0, ДопустимаяШирина + ДобавочноеКоличествоСимволов - ШиринаПлюса);					
				ДелительНовойШирины = ЛишнееКоличествоСимволов[ИтераторСтруктура].КолвоКнопок;					
				ГруппаРодительВиджет.ПодчиненныеЭлементы[ИтераторСтруктура].Ширина = ?(НоваяШирина = 0, 0, Цел(НоваяШирина / ДелительНовойШирины));	
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;	
	
КонецПроцедуры

// Процедура, СоздатьВсплывающуюГруппу.
//
Процедура СоздатьВсплывающуюГруппу(Форма, ГруппаВиджет, Сделка, ИндексВиджета)
	
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда 
		Если НЕ ЗначениеЗаполнено(Сделка.ЭтапСделки.ЦветЭтапа)
			ИЛИ ЗначениеИзСтрокиВнутр(Сделка.ЭтапСделки.ЦветЭтапа) = Новый Цвет() Тогда
			
			ЦветЭтапа = Новый Цвет(214, 234, 255);
		Иначе		
			ЦветЭтапа = ЗначениеИзСтрокиВнутр(Сделка.ЭтапСделки.ЦветЭтапа);
		КонецЕсли;
	Иначе 
		ЦветЭтапа = Новый Цвет(255, 250, 205);
	КонецЕсли;

	ГруппаВсплывающая = Форма.Элементы.Добавить("ГруппаВсплывающая_" + ИндексВиджета, Тип("ГруппаФормы"), ГруппаВиджет);
	ГруппаВсплывающая.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВсплывающая.Поведение			  = ПоведениеОбычнойГруппы.Всплывающая;
	ГруппаВсплывающая.Заголовок			  = " ";	
	ГруппаВсплывающая.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаВсплывающая.Отображение         = ОтображениеОбычнойГруппы.Нет;
	ГруппаВсплывающая.ЦветТекстаЗаголовка = ЦветЭтапа;
	ГруппаВсплывающая.ШрифтЗаголовка	  = Новый Шрифт(,1);
	ГруппаВсплывающая.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;

КонецПроцедуры

// Функция - Создать группу контейнер сделок
//
Функция СоздатьГруппуКонтейнерСделок(Форма, ИндексГруппы, СделкаПомещенаВАрхив = Ложь)
	
	ИмяКонтейнера = "ГруппаВиджетСделкиКонтейнер_" + ?(СделкаПомещенаВАрхив, "Архив_", "") + ИндексГруппы;		
	ГруппаКонтейнерСделок = Форма.Элементы.Найти(ИмяКонтейнера);
	
	Если ГруппаКонтейнерСделок = Неопределено Тогда
		
		ГруппаЭлемента = ?(СделкаПомещенаВАрхив, Форма.Элементы.Найти("ГруппаСвертываемаяАрхивСделок"), Неопределено);
		
		ПараметрыГруппаКонтейнерСделок = Новый Структура;
		ПараметрыГруппаКонтейнерСделок.Вставить("ИмяЭлемента"  		 		, ИмяКонтейнера);
		ПараметрыГруппаКонтейнерСделок.Вставить("Группировка"  		 		, ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
		ПараметрыГруппаКонтейнерСделок.Вставить("ГоризонтальныйИнтервал"	, ИнтервалМеждуЭлементамиФормы.Авто);
		ПараметрыГруппаКонтейнерСделок.Вставить("ОтображатьЗаголовок"		, Ложь);
		ПараметрыГруппаКонтейнерСделок.Вставить("Заголовок"					, "");
		ПараметрыГруппаКонтейнерСделок.Вставить("Видимость"					, Истина);
		ПараметрыГруппаКонтейнерСделок.Вставить("ГруппаЭлемента"			, ?(НЕ ГруппаЭлемента = Неопределено, ГруппаЭлемента, Форма.Элементы.ВиджетСделки)); 
		ПараметрыГруппаКонтейнерСделок.Вставить("Ширина"		        	, ?(СделкаПомещенаВАрхив, 30, Неопределено));
	
		ГруппаКонтейнерСделок = СоздатьЭлементГруппа(Форма, ПараметрыГруппаКонтейнерСделок);
		
	КонецЕсли;
	
	Возврат ГруппаКонтейнерСделок;
	
КонецФункции

// Функция, возвращает цвет текста от передаваемого цвета фона.
//
Функция ПолучитьЦветТекстаПоФону(ЦветФона) Экспорт
	
	Если (ЦветФона.Зеленый + ЦветФона.Красный + ЦветФона.Синий) > 383 Тогда
		Возврат Новый Цвет(60,60,60);		
	Иначе
		Возврат Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецФункции

// Процедура, ОчиститьГруппуЭтапыСделки.
//
Процедура ОчиститьГруппуВиджетСделки(Форма) Экспорт
		
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из Форма.Элементы.ВиджетСделки.ПодчиненныеЭлементы Цикл
		Если ГруппаЭлементов.Имя = "ВиджетВыбораВидаГенерируемойСделки" Тогда 
			Продолжить;
		КонецЕсли;	
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Форма.Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Очистить группу виджет выбора вида генерируемой сделки
//
// Параметры:
//  Форма	 - 	 - 
//
Процедура ОчиститьГруппуВиджетВыбораВидаГенерируемойСделки(Форма)
	
	Если Форма.Элементы.Найти("ВиджетВыбораВидаГенерируемойСделки") <> Неопределено Тогда 
		УдаляемыеЭлементы = Новый Массив;
		
		Для Каждого ГруппаЭлементов Из Форма.Элементы.ВиджетВыбораВидаГенерируемойСделки.ПодчиненныеЭлементы Цикл
			УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
		КонецЦикла;
		
		Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
			Форма.Элементы.Удалить(УдаляемыйЭлемент);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

// Функция, возвращает идентификатор строки данных по имени элемента.
//  
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ИмяЭлемента, ИндексЭлемента = Истина)
	
	// Если ИндексЭлемента Тогда
	//	НомерСимвола = СтрНайти(ИмяЭлемента,"_");
	//	Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	// Иначе
	//	НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
	//	Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	// КонецЕсли;
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		
		Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Сред(ИмяЭлемента, НомерСимвола + 1, 2)) Тогда
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 2));
		Иначе		
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));	
		КонецЕсли;		
		
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1));
	КонецЕсли;

КонецФункции

// Процедура, добавляет кнопку для создания новой сделки.
//
Процедура СоздатьКнопкуДобавитьСделку(Форма, ИспользоватьЗаголовок, РодительскаяГруппа = Неопределено)
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"  		 , "ГруппаДобавитьСделку");
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		 , ?(РодительскаяГруппа = Неопределено, Форма.Элементы.ВиджетСделки, РодительскаяГруппа));
	ПараметрыГруппы.Вставить("ЦветФона"				 , Новый Цвет(254, 254, 254));
	ПараметрыГруппы.Вставить("Группировка"  		 , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
 	ГруппаДобавитьСделку = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	// Создаем команду кнопки.
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатиДинамическогоЭлементаВиджета");
	ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "СоздатьСделку");
	КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	// Создаем кнопку.
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "СоздатьСделку");
	
	Если ИспользоватьЗаголовок Тогда
		ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Картинка);	
		ПараметрыКнопки.Вставить("Картинка"	 		 , БиблиотекаКартинок.ПлюсСерый);
	Иначе	
		ПараметрыКнопки.Вставить("Заголовок" 		 , НСтр("ru = '+ Создать сделку'; en = '+ Create a deal'"));
	КонецЕсли;
	
	ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
	ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаДобавитьСделку);		
	
	КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
		
КонецПроцедуры

// Процедура, добавляет кнопку для выбора сделок из архива.
//
Процедура СоздатьГруппуАрхивСделок(Форма)
	
	ПараметрыГруппаАрхивСделок = Новый Структура;
	ПараметрыГруппаАрхивСделок.Вставить("ИмяЭлемента"  		 		, "ГруппаСвертываемаяАрхивСделок");
	ПараметрыГруппаАрхивСделок.Вставить("Группировка"  		 		, ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппаАрхивСделок.Вставить("ГоризонтальныйИнтервал"	, ИнтервалМеждуЭлементамиФормы.Авто);
	ПараметрыГруппаАрхивСделок.Вставить("ОтображатьЗаголовок"		, Ложь);
	ПараметрыГруппаАрхивСделок.Вставить("Заголовок"					, " ");
	ПараметрыГруппаАрхивСделок.Вставить("Видимость"					, Ложь);
	ПараметрыГруппаАрхивСделок.Вставить("ГруппаЭлемента"			, Форма.Элементы.ВиджетСделки);
	ПараметрыГруппаАрхивСделок.Вставить("Поведение"					, ПоведениеОбычнойГруппы.Свертываемая);
	
	ГруппаКонтейнерСделок = СоздатьЭлементГруппа(Форма, ПараметрыГруппаАрхивСделок);
	
КонецПроцедуры

// Процедура - Создать кнопку просмотра свертываемой группы сделок
//
Процедура СоздатьКнопкуПросмотраАрхиваСделок(Форма, ЗаголовокКнопки = Неопределено, ГруппаРодитель = Неопределено)
	
	// Создаем команду кнопки.
