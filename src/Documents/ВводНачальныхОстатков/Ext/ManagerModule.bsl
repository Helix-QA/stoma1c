// Процедура производит запись номинала партии сертификата.
//
Процедура ЗаписатьНоминалСертификатаПриПродаже(ДокументСсылкаВводОстатков) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	ВводНачальныхОстатковСерийныеНомераСертификатов.Партия КАК Партия,
	                      |	ВводНачальныхОстатковСерийныеНомераСертификатов.Сумма КАК Цена
	                      |ИЗ
	                      |	Документ.ВводНачальныхОстатков.СерийныеНомераСертификатов КАК ВводНачальныхОстатковСерийныеНомераСертификатов
	                      |ГДЕ
	                      |	ВводНачальныхОстатковСерийныеНомераСертификатов.Ссылка = &Ссылка
	                      |	И ВводНачальныхОстатковСерийныеНомераСертификатов.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	                      |	И ВводНачальныхОстатковСерийныеНомераСертификатов.ВидНоминала");
						  
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаВводОстатков);
	СписокЗапасов = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаЗапасов Из СписокЗапасов Цикл
		Партия = СтрокаЗапасов.Партия.ПолучитьОбъект();
		Партия.Номинал = СтрокаЗапасов.Цена;
		Партия.Записать();
	КонецЦикла;
	
КонецПроцедуры

