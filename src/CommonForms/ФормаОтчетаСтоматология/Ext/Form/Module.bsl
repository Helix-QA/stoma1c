// Процедура - Отправить по почте
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура ОтправитьПоПочте(Команда)
	
	ОтображениеСостояния = Элементы.ОтчетТабличныйДокумент.ОтображениеСостояния;
	Если ОтображениеСостояния.Видимость = Истина
		И ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.Неактуальность Тогда
		
		ТекстВопроса = НСтр("ru='Отчет не сформирован. Сформировать?';en='Report not formed. To form'");
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ОтправитьПоЭлектроннойПочтеЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Да);
        Возврат;
		
	КонецЕсли;
	
	ОтправитьПоЭлектроннойПочтеФрагмент();

КонецПроцедуры

&НаКлиенте
// Процедура - Отправить по электронной почте завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОтправитьПоЭлектроннойПочтеЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	СформироватьНепосредственно();
	
	ОтправитьПоЭлектроннойПочтеФрагмент();
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Отправить по электронной почте фрагмент
//
Процедура ОтправитьПоЭлектроннойПочтеФрагмент()
	
	ТабличныеДокументы = Новый СписокЗначений;
	ТабличныеДокументы.Добавить(ЭтаФорма.ОтчетТабличныйДокумент, ЭтаФорма.ОтчетНаименованиеТекущегоВарианта);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТабличныеДокументы", ТабличныеДокументы);
	ПараметрыФормы.Вставить("Тема"              , ЭтаФорма.ОтчетНаименованиеТекущегоВарианта);
	ПараметрыФормы.Вставить("Заголовок"         , СтрШаблон(НСтр("ru = 'Отправка отчета ""%1"" по почте'"),ЭтаФорма.ОтчетНаименованиеТекущегоВарианта));
	ПараметрыФормы.Вставить("МассивПолучателей" , ПолучитьМассивКонтрагентовИзРезультата()); 
	
	ОткрытьФорму("ОбщаяФорма.ОтправкаТабличныхДокументовПоПочте", ПараметрыФормы, , );
	
КонецПроцедуры

// Функция - Получить массив контрагентов из результата
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция ПолучитьМассивКонтрагентовИзРезультата()
	
	МассивКонтрагентов = Новый Массив;
	МассивДанныхКонтрагентов = Новый Массив;
	
	Если ЗначениеЗаполнено(ОтчетДанныеРасшифровки) Тогда
		ДанныеРасшифровкиХранилища = ПолучитьИзВременногоХранилища(ОтчетДанныеРасшифровки);
		Если ДанныеРасшифровкиХранилища <> Неопределено Тогда
			Для Каждого ЭлементДанныеРасшифровкиХранилища Из ДанныеРасшифровкиХранилища.Элементы Цикл
				Если ТипЗнч(ЭлементДанныеРасшифровкиХранилища) = Тип("ЭлементРасшифровкиКомпоновкиДанныхПоля") Тогда
					Для Каждого ЭлементПоля Из ЭлементДанныеРасшифровкиХранилища.ПолучитьПоля() Цикл
						Если СтрНайти(Строка(ЭлементПоля.Значение), "Объект не найден") = 0
							И ((ПравоДоступа("Просмотр", Метаданные.Справочники.Контрагенты) И ТипЗнч(ЭлементПоля.Значение) = Тип("СправочникСсылка.Контрагенты")) 
							ИЛИ (ПравоДоступа("Просмотр", Метаданные.Справочники.Сотрудники) И ТипЗнч(ЭлементПоля.Значение) =  Тип("СправочникСсылка.Сотрудники"))) 
							И ЭлементПоля.Значение.ЭтоГруппа = Ложь И МассивКонтрагентов.Найти(ЭлементПоля.Значение) = Неопределено Тогда
							Если ЗначениеЗаполнено(ЭлементПоля.Значение) Тогда
								МассивКонтрагентов.Добавить(ЭлементПоля.Значение);
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;	
	Возврат МассивКонтрагентов;
	
КонецФункции

&НаСервере
// Функция, возварщает массив контрагентов из результата для пушей.
//
Функция ПолучитьМассивКонтрагентовИзРезультатаДляПушей()
	
	МассивКонтрагентов = Новый Массив;	
	Если ЗначениеЗаполнено(ОтчетДанныеРасшифровки) Тогда
		ДанныеРасшифровкиХранилища = ПолучитьИзВременногоХранилища(ОтчетДанныеРасшифровки);
		Если  ДанныеРасшифровкиХранилища <> Неопределено Тогда
			Для Каждого ЭлементДанныеРасшифровкиХранилища Из ДанныеРасшифровкиХранилища.Элементы Цикл
				Если ТипЗнч(ЭлементДанныеРасшифровкиХранилища) = Тип("ЭлементРасшифровкиКомпоновкиДанныхПоля") Тогда
					Для Каждого ЭлементПоля Из ЭлементДанныеРасшифровкиХранилища.ПолучитьПоля() Цикл
						
						Контрагент = ЭлементПоля.Значение;
						Если ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") И Контрагент.ЭтоГруппа = Ложь И МассивКонтрагентов.Найти(Контрагент) = Неопределено Тогда
							МассивКонтрагентов.Добавить(Контрагент);
						КонецЕсли;
						
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивКонтрагентов;
	
КонецФункции

