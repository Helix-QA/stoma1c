
#Область СлужебныйПрограммныйИнтерфейс

// Возвращает остаток от деления
//
// Параметры:
//  Число1 - Число, числитель.
//  Число2 - Число, знаменатель.
//
// Возвращаемое значение:
//  Число, оостаток от деления.
//
Функция ТекущаяСервернаяДатаНаСервере() Экспорт

	Возврат ТекущаяДатаСеанса();

КонецФункции

&НаСервере
// Функция возвращает группу клиентов
//
Функция ВернутьГруппуКлиентов() Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	                      |	НастройкиПользователей.Значение
	                      |ИЗ
	                      |	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	                      |ГДЕ
	                      |	НастройкиПользователей.Пользователь = &Пользователь
	                      |	И НастройкиПользователей.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                      |	И НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ОсновнаяГруппаКонтрагентов)");
	Запрос.УстановитьПараметр("Пользователь", ПараметрыСеанса.ТекущийПользователь);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Значение;
	Иначе 
		Возврат  Неопределено;
	КонецЕсли;
	
КонецФункции

// Процедура, выполняет обновление состояние кассы
//
Функция ОбновитьСостояниеКассыИзменение(СтруктураПроверки) Экспорт
	
	СтруктураСостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(СтруктураПроверки.Касса); 	
	СтатусСмены = ?(СтруктураСостояниеКассовойСмены <> Неопределено, Строка(СтруктураСостояниеКассовойСмены.СтатусыКассовойСмены), "");
	
	Если СтатусСмены <> СтруктураПроверки.СтатусСмены Тогда
		СтруктураВозврата = Новый Структура("Изменять", Истина);	
		СтруктураВозврата.Вставить("СтатусСмены"	, СтатусСмены);
		СтруктураВозврата.Вставить("ВремяИзменения" , ?(СтруктураСостояниеКассовойСмены <> Неопределено, 
														Формат(СтруктураСостояниеКассовойСмены.ДатаИзмененияСтатуса,"ДФ='dd MMMM ""в ""ЧЧ:мм'"),
														Неопределено));
	Иначе
		СтруктураВозврата = Новый Структура("Изменять", Ложь);
	КонецЕсли;	
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция выполняет поиск контрагентов
//
Функция НайтиКонтрагентовПоСтроке(
	СтрокаПоиска,
	РазмерПорции = 200,
	ВПапкеКлиентов = Ложь,
	ДобавлятьЭлементСоздания = Ложь,
	ВыводитьНомерТелефона = Истина,
	ВыводитьНомерМедКарты = Истина,
	ПереноситьЭлементПоиска = Ложь,
	ТипКонтрагента = Неопределено,
	ВыводитьВсе = Ложь,
	ВернутьВыборкуЗапроса = Ложь) Экспорт
	 	
	СтрокаПоиска = СокрЛ(СтрокаПоиска);
	Если СокрЛ(СтрокаПоиска) = "" ИЛИ СтрДлина(СтрокаПоиска) < 3 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Для роли врач вывод номера телефона запрещен
	Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач Тогда 		
		ВыводитьНомерТелефона = Ложь; 
	КонецЕсли;
	
	СтрокаПоиска = СокрЛ(СтрокаПоиска);
	СтрокаПоиска = ?(Лев(СтрокаПоиска, 1) = "+", Сред(СтрокаПоиска, 2), СтрокаПоиска);
	
	Если Не ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// =======================АНАЛИЗ ВВЕДЕННЫХ СИМВОЛОВ=======================
	НаличиеЦифр    = Ложь;
	КоличествоЦифр = 0;
	НаличиеБукв    = Ложь;
	КоличествоБукв = 0;
	
	Для Индекс = 1 По СтрДлина(СтрокаПоиска) Цикл 
		
		Если Найти("0123456789", Сред(СтрокаПоиска, Индекс, 1)) <> 0 Тогда 
			НаличиеЦифр = Истина;
			КоличествоЦифр = КоличествоЦифр + 1;
		Иначе 
			НаличиеБукв = Истина;
			КоличествоБукв = КоличествоБукв + 1;
		КонецЕсли;
		
	КонецЦикла;	
	
	Если Не ЗначениеЗаполнено(ТипКонтрагента) Тогда
		ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты;
	КонецЕсли;		
	
	// ============ВЫБОРКА ДАННЫХ НА ОСНОВЕ АНАЛИЗА ВВЕДЕННЫХ СИМВОЛОВ=============	
	Если НаличиеБукв И Не НаличиеЦифр Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 20
		|	ВложенныйЗапрос.Ссылка КАК Ссылка,
		|	МИНИМУМ(ВложенныйЗапрос.Индекс) КАК Индекс,
		|	ВложенныйЗапрос.Фамилия КАК Фамилия,
		|	ВложенныйЗапрос.Имя КАК Имя,
		|	ВложенныйЗапрос.Отчество КАК Отчество,
		|	ВложенныйЗапрос.ТекущаяМедицинскаяКартаКод КАК ТекущаяМедицинскаяКартаКод,
		|	ВложенныйЗапрос.ДатаРождения КАК ДатаРождения,
		|	ВложенныйЗапрос.Телефон КАК Телефон
		|ИЗ
		|	(ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка КАК Ссылка,
		|		1 КАК Индекс,
		|		Контрагенты.Фамилия КАК Фамилия,
		|		Контрагенты.Имя КАК Имя,
		|		Контрагенты.Отчество КАК Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей КАК ТекущаяМедицинскаяКартаКод,
		|		Контрагенты.ДатаРожденияКлиента КАК ДатаРождения,
		|		Контрагенты.Телефон КАК Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.Фамилия ПОДОБНО &Поиск
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		2,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.Имя ПОДОБНО &Поиск
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		3,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.Отчество ПОДОБНО &Поиск
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка,
		|		4,
		|		Контрагенты.Фамилия,
		|		Контрагенты.Имя,
		|		Контрагенты.Отчество,
		|		Контрагенты.ТекущаяМедицинскаяКарта.КодБезНулей,
		|		Контрагенты.ДатаРожденияКлиента,
		|		Контрагенты.Телефон
		|	ИЗ
		|		Справочник.Контрагенты КАК Контрагенты
		|	ГДЕ
		|		Контрагенты.ЭтоГруппа = ЛОЖЬ
		|		И Контрагенты.ПометкаУдаления = ЛОЖЬ
		|		И Контрагенты.ТипКонтрагента В(&ТипКонтрагента)
		|		И Контрагенты.Наименование ПОДОБНО &СтрокаПоискаНаименование) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Ссылка,
		|	ВложенныйЗапрос.Фамилия,
		|	ВложенныйЗапрос.Имя,
		|	ВложенныйЗапрос.Отчество,
		|	ВложенныйЗапрос.ТекущаяМедицинскаяКартаКод,
		|	ВложенныйЗапрос.ДатаРождения,
		|	ВложенныйЗапрос.Телефон
		|
		|УПОРЯДОЧИТЬ ПО
		|	Индекс,
		|	Фамилия,
		|	Имя,
		|	Отчество";
				
	ИначеЕсли НаличиеЦифр И Не НаличиеБукв Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ ПЕРВЫЕ 20
		|	ВложенныйЗапрос.Ссылка КАК Ссылка,
		|	МИНИМУМ(ВложенныйЗапрос.Индекс) КАК Индекс,
		|	ВложенныйЗапрос.Фамилия КАК Фамилия,
		|	ВложенныйЗапрос.Имя КАК Имя,
		|	ВложенныйЗапрос.Отчество КАК Отчество,
		|	ВложенныйЗапрос.Телефон КАК Телефон,
		|	ВложенныйЗапрос.ТекущаяМедицинскаяКартаКодБезНулей КАК ТекущаяМедицинскаяКартаКод,
		|	ВложенныйЗапрос.ДатаРожденияКлиента КАК ДатаРождения
		|ИЗ
		|	(ВЫБРАТЬ ПЕРВЫЕ 20
		|		Контрагенты.Ссылка КАК Ссылка,
		|		1 КАК Индекс,
		|		Контрагенты.Фамилия КАК Фамилия,
		|		Контрагенты.Имя КАК Имя,
		|		Контрагенты.Отчество КАК Отчество,
		|		Контрагенты.Телефон КАК Телефон,
