// Процедура, обновляет колличество введенных символов.
//
Процедура ОбновитьСтатусВведеныхСимволов(Форма)
	
	Если Форма.Объект.Тип <> ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
		Возврат;
	КонецЕсли;
	
	Текст = Форма.Объект.Содержание;
	Если ЗначениеЗаполнено(Текст) Тогда
		Текст = НРег(Текст);
	КонецЕсли;	
	
	РазмерностьСообщения = ?(СтрДлина(Текст) > 160, 153, 160); // 1-sms это 160 символов, если больше 160 символов, тогда 1 sms = 153
	КоличествоСМС = 0;
	
	РусскиеСимволы = "йцукенгшщзхъфывапролджэячсмитьбюё@_$^~`№";
	Для а = 1 По СтрДлина(РусскиеСимволы) Цикл
		Если Найти(Текст, Сред(РусскиеСимволы, а, 1)) > 0 Тогда
			РазмерностьСообщения = ?(СтрДлина(Текст) > 70, 67, 70); // 1-sms это 70 символов, если больше 70 символов, тогда 1 sms = 67
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	КоличествоСМС = Цел(СтрДлина(Текст) / РазмерностьСообщения) + ?(СтрДлина(Текст) % РазмерностьСообщения > 0, 1, 0);
	
	Форма.СтатусВведенныхСимволов = "" + "Введено " + СтрДлина(Текст) + " символов. " + КоличествоСМС + " sms";
	
КонецПроцедуры

