// Работа с WSh Shell 

// + Функция возвращает сообщение выводимое в StdOut процесса после выполнения команды черз WSh Shell
Функция		СТДПолучитьСообщениеУПроцесса(Процесс)	Экспорт

	СТДСообщение = "";
	
	КолИтераций = 0;
	Пока НЕ Процесс.StdOut.AtEndOfStream Цикл КолИтераций = КолИтераций + 1; Если КолИтераций > 50 Тогда Прервать; КонецЕсли;
		СТДСообщение = СТДСообщение + Символы.ПС + Процесс.StdOut.ReadLine();
	КонецЦикла;
	
	Возврат СокрЛП(СТДСообщение);
	
КонецФункции

// + Функция возвращает ошибку процесса после выполнения команды черз WSh Shell
Функция		СТДПолучитьОшибкуУПроцесса(Процесс) Экспорт

	СТДСообщение = "";
	
	КолИтераций = 0;
	Пока НЕ Процесс.StdERR.AtEndOfStream Цикл КолИтераций = КолИтераций + 1; Если КолИтераций > 50 Тогда Прервать; КонецЕсли;
		СТДСообщение = СТДСообщение + Символы.ПС + Процесс.StdERR.ReadLine();
	КонецЦикла;
	
	Возврат СокрЛП(СТДСообщение);
	
КонецФункции

