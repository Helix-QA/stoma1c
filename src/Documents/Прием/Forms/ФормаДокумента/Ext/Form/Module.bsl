// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции 

&НаСервере
// Процедура конфигурирования формы
//
Процедура НастройкаФормыСервер(РежимНастройки = "ПРИ_ЗАПУСКЕ")
	
	// ПРИ ИЗМЕНЕНИИ ВЫБОРА СОТРУДНИКА
	Если РежимНастройки = "ПРИ_ЗАПУСКЕ" ИЛИ РежимНастройки = "ПРИ_ИЗМЕНЕНИИ_СОТРУДНИКА" Тогда
		// Настройка обследования
		 НастройкаОбследованияСервер(НЕ Объект.Ссылка.Пустая() И РежимНастройки = "ПРИ_ЗАПУСКЕ");	
		// Установить состояние формы в зависимости от признака стоматологических услуг
		Если ЭтоСтоматологическиеУслуги Тогда
			Элементы._ЗубнаяФормула.Видимость           = Истина;
			Элементы.ГруппаУслугиПодборЗубов.Видимость  = Истина;
            Элементы.ТаблицаЛечениеЗуб.Видимость        = Истина;
			// Загрузка статусов зубов	
			ЗагрузитьСтатусыЗубов(?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса()));
			// Формирование меню истории
			СформироватьМенюИстории();	
		Иначе
			Элементы._ЗубнаяФормула.Видимость           = Ложь;
			Элементы.ГруппаУслугиПодборЗубов.Видимость = Ложь;
            Элементы.ТаблицаЛечениеЗуб.Видимость       = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	// Настройка шапки и дополнительных вкладок
	Если РежимНастройки = "ПРИ_ЗАПУСКЕ" ИЛИ РежимНастройки = "ШАПКА" Тогда
		ПолучитьДисконтнуюКартуКонтрагента(РежимНастройки);
		Если РежимНастройки = "ПРИ_ЗАПУСКЕ" Тогда
		   	Элементы._Авансы.Видимость = Объект.УчтенныеАвансы.Количество() > 0;
		ИначеЕсли ЭтоСтоматологическиеУслуги = Ложь Тогда
			СформироватьМенюИстории(); // Иначе выполянется выше по коду.
		КонецЕсли;
		// Загрузка статусов и зубной формулы   
		Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
			ТипЗубнойФормулы = ПолучитьТипЗубнойФормулы(Объект.Контрагент, Объект.Дата, Объект.Ссылка);	 
		Иначе
			ТипЗубнойФормулы = 0;
		КонецЕсли;
		УстановитьЗубнуюФормулу(); 		
		ЗагрузитьСтатусыЗубов(?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Дата, ТекущаяДатаСеанса()));
		ЗубнаяФормулаSVGBody = ФормированиеSVGКлиентСервер.СформироватьЗубнуюФормулу(СтатусыЗубов, ?(ТипЗубнойФормулы = 1, Истина, Ложь));	
		SVGМассивСтатусовЗубов                       = "var status = '';";
		SVGМассивОбластей                            = "var ColorStatus = ''";
		Если ТипЗубнойФормулы = 1 Тогда
			ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовокДФ").ПолучитьТекст();
		Иначе
			ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовок").ПолучитьТекст();
		КонецЕсли;
		// формирование меню областей
		СформироватьМенюОбластей(ЗубнаяФормулаSVG);	
		// Заполнить список выбора зубов
		Элементы.ТаблицаЛечениеЗуб.СписокВыбора.ЗагрузитьЗначения(СоздатьСписокВыбораЗубов(ЭтотОбъект.ТипЗубнойФормулы));
		
		Элементы._Подарки.Видимость                   = Объект.Подарки.Количество() >0;
		// Элементы.КонтрагентСтраховойПолис.Доступность = Ложь;
		Элементы.КонтрагентСтраховойПолис.СписокВыбора.Очистить();	
		// Проверка существования страховых полисов и настройка элементов
		// Загрузить полисы
		МассивПолисов = ПолучитьСтраховыеПолисыКонтрагента(Объект.Контрагент, Объект.Дата);
		Если ПредВыбранныйКонтрагент = Объект.Контрагент Тогда
			Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда 
				Если МассивПолисов.Найти(Объект.ПолисМедСтрахования) = Неопределено Тогда 
					МассивПолисов.Добавить(Объект.ПолисМедСтрахования);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// Если у пациента имеются страховые полисы
		ИзменитьВидЦен = Ложь;
		Если МассивПолисов.Количество() > 0 Тогда	
			// Элементы.КонтрагентСтраховойПолис.Доступность = Истина;
			// Заполнение списка выбора
			Элементы.КонтрагентСтраховойПолис.СписокВыбора.ЗагрузитьЗначения(МассивПолисов);
			Если (НЕ РежимНастройки = "ПРИ_ЗАПУСКЕ" И ((ПредВыбранныйКонтрагент <> Объект.Контрагент) ИЛИ Не ЗначениеЗаполнено(Объект.ПолисМедСтрахования)))  
				ИЛИ (НЕ ЗначениеЗаполнено(Объект.Ссылка) И Не ЗначениеЗаполнено(Объект.ПолисМедСтрахования)) Тогда			
				Объект.ПолисМедСтрахования = МассивПолисов[0];

				Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда
					СтраховаяКомпанияСсылка = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.ПолисМедСтрахования, "СтраховаяКомпания");
					СтраховаяКомпанияВидЦен = ?(НЕ ЗначениеЗаполнено(СтраховаяКомпанияСсылка), Неопределено, 
												ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтраховаяКомпанияСсылка, "ВидЦен_Удалить"));
					Если ЗначениеЗаполнено(СтраховаяКомпанияВидЦен) Тогда 
						Объект.ВидЦен = СтраховаяКомпанияВидЦен; // Объект.ПолисМедСтрахования.СтраховаяКомпания.ВидЦен_Удалить;
					КонецЕсли;
				КонецЕсли;
					
			// ИначеЕсли МассивПолисов.Количество() > 1 И (НЕ РежимНастройки = "ПРИ_ЗАПУСКЕ"  ИЛИ НЕ ЗначениеЗаполнено(Объект.Ссылка)) Тогда
			//	ИзменитьВидЦен = Истина;
			КонецЕсли;		
			// Элементы.КонтрагентСтраховойПолис.Доступность = Истина;
		Иначе
			Если НЕ РежимНастройки = "ПРИ_ЗАПУСКЕ" Тогда 
				ИзменитьВидЦен = Истина;
			КонецЕсли;
		КонецЕсли;
			
		Если ИзменитьВидЦен Тогда
	
			Объект.ПолисМедСтрахования = Неопределено;
			ВидЦенВр                   = КонтрагентСтраховойПолисОчисткаСервер(Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
			Если НЕ Объект.ВидЦен = ВидЦенВр И ЗначениеЗаполнено(ВидЦенВр) Тогда
				Объект.ВидЦен = ВидЦенВр;
			КонецЕсли;
			
		КонецЕсли;
		Если Не Элементы.Найти("ФормаДокументОплатить") = Неопределено Тогда
			Элементы.ФормаДокументОплатить.Доступность = Не ЗначениеЗаполнено(Объект.ПолисМедСтрахования);
		КонецЕсли;
		// Получить шаблон обследования
		Если ПредВыбранныйКонтрагент <> Объект.Контрагент Тогда
			ШаблонОбследованияПред    = Объект.ШаблонОбследования;
			Объект.ШаблонОбследования = ШаблонОбследованияПациента();
			Если ШаблонОбследованияПред <> Объект.ШаблонОбследования Тогда
				ШаблонОбследованияПриИзмененииСервер();
			КонецЕсли;
		КонецЕсли;
		
		// Если пред. выбранный контрагент не равен текущему пересчитать ТЧ
		Если НЕ ПредВыбранныйКонтрагент = Объект.Контрагент ИЛИ НЕ ПредВыбранныйСтраховойПолис = Объект.ПолисМедСтрахования Тогда
			// ТабличныеЧастиПересчетПослеИзменений("Запасы");
			// ТабличныеЧастиПересчетПослеИзменений("Лечение"); 
			ПересчетТабличныхЧастейФормы();	
			Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда 			
				СтруктураПолис = ВернутьВидЦеныИДоговорПоПолису(Объект.ПолисМедСтрахования); 	
				ЭтотОбъект._ПодборДоговорПолиса = ?(ЗначениеЗаполнено(СтруктураПолис.Договор), СтруктураПолис.Договор, Справочники.ДоговорыКонтрагентов.ПустаяСсылка());			
			Иначе
				ЭтотОбъект._ПодборДоговорПолиса = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
			КонецЕсли;
			
			ОбновлениеНоменклатурыВТаблицахПодбора("Полис"); 
			
		КонецЕсли;
		// Установка видимости у надписи под зубами с гиперсылками "Открыть" и "ДобавитьУслуги"
		УстановитьВидимостьНадписиСНезавершеннымиПланамиЛечения();
		// Восстановление строк представления материалов
		Если РежимНастройки = "ПРИ_ЗАПУСКЕ" Тогда 
			ПроставитьПредстваленияМатериалов();
		КонецЕсли;
		Если РежимНастройки = "ШАПКА" Тогда
			УправлениеИнтерфейсамиСервер.ОбновитьВиджетСделки(ЭтаФорма, Объект.Контрагент, Объект.Сделка);
			СформироватьБлокСДолгомИОстаткомНаЛСПациента();
		КонецЕсли;	
	КонецЕсли;	
	Элементы._Подарки.Видимость = Объект.Подарки.Количество() > 0;
	
	ОтобразитьМеткуПолиса();
	
КонецПроцедуры

&НаСервере
// Установить представления материалов
//
Процедура ПроставитьПредстваленияМатериалов()   
	
	Для Каждого СтрокаЛечение Из Объект.Лечение Цикл
		СписокМатериалов = Объект.Материалы.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаЛечение.КлючСтроки));
		ПредставлениеСписка = "";
		Для Каждого СтрокаМатериала Из СписокМатериалов Цикл
			ПредставлениеСписка = ПредставлениеСписка + СтрокаМатериала.Материал + ";";
		КонецЦикла;
		СтрокаЛечение.МатериалыПредставление = ПредставлениеСписка;
	КонецЦикла;	
	
КонецПроцедуры

 &НаСервере
// Процедура обновляет номенклатуру в таблицах подбора
//
Функция ОбновлениеНоменклатурыВТаблицахПодбора(РеквизитИзменений = Неопределено)
		
	ИзменилсяПолис = ?(РеквизитИзменений = "Полис", Истина, Ложь);
	
	// Установть отбор по сегменту
	ОтборСегментНоменклатурыПред = _ПодборСегментНоменклатуры;
	УстановитьОтборСегментНоменклатуры(Объект.ПолисМедСтрахования, Объект.СтруктурнаяЕдиница, Объект.Сотрудник);
	
