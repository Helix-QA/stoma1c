// Функция - Получить идентификатор конференции по ссылке
//
// Параметры:
//  СсылкаНаКонференцию	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьИдентификаторКонференцииПоСсылке(СсылкаНаКонференцию)
	
	ИдентификаторКонференции = "";

	МассивЧастейСсылки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СсылкаНаКонференцию, "/");
	Если МассивЧастейСсылки.Количество() = 0 Тогда 
		ИдентификаторКонференции = "";
	Иначе 
		Если СтрДлина(МассивЧастейСсылки[МассивЧастейСсылки.Количество() - 1]) = 9 Тогда 
			ИдентификаторКонференции = МассивЧастейСсылки[МассивЧастейСсылки.Количество() - 1];
		ИначеЕсли МассивЧастейСсылки.Количество() > 1 И СтрДлина(МассивЧастейСсылки[МассивЧастейСсылки.Количество() - 2]) = 9 Тогда
			ИдентификаторКонференции = МассивЧастейСсылки[МассивЧастейСсылки.Количество() - 2];
		ИначеЕсли МассивЧастейСсылки.Количество() > 2 И СтрДлина(МассивЧастейСсылки[МассивЧастейСсылки.Количество() - 3]) = 9 Тогда
			ИдентификаторКонференции = МассивЧастейСсылки[МассивЧастейСсылки.Количество() - 3];
		Иначе 
			ИдентификаторКонференции = "";
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат СокрЛП(ИдентификаторКонференции);
	
КонецФункции

// Функция - Вернуть статус клиента
//
// Параметры:
//  Контрагент	 - 	 - 
//  Период		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьСтатусКлиента(Контрагент, Период)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СтатусыКонтрагентов.Статус КАК Статус
	               |ИЗ
	               |	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
	               |ГДЕ
	               |	СтатусыКонтрагентов.Период = &Период
	               |	И СтатусыКонтрагентов.Контрагент = &Контрагент";
	
	Запрос.УстановитьПараметр("Период"		, Период);
	Запрос.УстановитьПараметр("Контрагент"	, Контрагент);
	
	ВыборкаСтатусов = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаСтатусов.Следующий() Тогда 
		Возврат ВыборкаСтатусов.Статус;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;		
	
КонецФункции

