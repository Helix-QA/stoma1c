&НаСервере
Процедура ЗаполнитьРасшифровку(ИдРасшифровки)
	
	ИнфРасшифровка.Очистить();
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	ВЫБОР
	                      |		КОГДА х_ИсторияЗвонков.Клиент = НЕОПРЕДЕЛЕНО
	                      |			ТОГДА х_ИсторияЗвонков.НомерТелефона
	                      |		ИНАЧЕ х_ИсторияЗвонков.Клиент.Наименование
	                      |	КОНЕЦ КАК Представление,
	                      |	х_ИсторияЗвонков.Период КАК Дата,
	                      |	х_ИсторияЗвонков.НомерТелефона,
	                      |	х_ИсторияЗвонков.Клиент,
	                      |	х_ИсторияЗвонков.ИсходящийЗвонок,
	                      |	х_ИсторияЗвонков.Пропущен,
	                      |	х_ИсторияЗвонков.Статус,
	                      |	ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), СЕКУНДА, РАЗНОСТЬДАТ(х_ИсторияЗвонков.НачалоРазговора, х_ИсторияЗвонков.ОкончаниеРазговора, СЕКУНДА)) КАК Длительность
	                      |ИЗ
	                      |	РегистрСведений.ИсторияЗвонковУдалить КАК х_ИсторияЗвонков
	                      |ГДЕ
	                      |	х_ИсторияЗвонков.Группировка = &Группировка
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Дата УБЫВ");
	Запрос.УстановитьПараметр("Группировка", ИдРасшифровки);
	Результат = Запрос.Выполнить().Выгрузить();
	Счетчик = 0;
	Если Результат.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ из Результат Цикл
		НоваяСтрока = ИнфРасшифровка.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);		
		Если СтрокаТЧ.Пропущен Тогда
			Статус = "пропущен";
		ИначеЕсли ЗначениеЗаполнено(СтрокаТЧ.Длительность) Тогда
			Если ЗначениеЗаполнено(Минута(СтрокаТЧ.Длительность)) Тогда
				Статус = ""+?(Секунда(СтрокаТЧ.Длительность)<10, "  ","")+(Минута(СтрокаТЧ.Длительность)+?(ЗначениеЗаполнено(Секунда(СтрокаТЧ.Длительность)), 1, 0))+" мин.";
			Иначе
				Статус = ""+?(Секунда(СтрокаТЧ.Длительность)<10, "  ","")+Секунда(СтрокаТЧ.Длительность)+" сек.";
			КонецЕсли;
			// Статус = Формат(СтрокаТЧ.Длительность, "ДФ=mm:ss");
		Иначе
			Статус = "    "+СтрокаТЧ.Статус;
		КонецЕсли;
		
		Надпись = ЭтаФорма.Элементы.Добавить("Надпись" + Счетчик, Тип("ДекорацияФормы"), Элементы.Группа4);
		Надпись.Заголовок = Формат(СтрокаТЧ.Дата, "ДФ=HH:mm") + "    "+Статус;
		Надпись.РастягиватьПоГоризонтали = Истина;
		// Надпись.Шрифт = Шрифт;
		Надпись.РастягиватьПоВертикали = Ложь;
		Надпись.РастягиватьПоГоризонтали = Истина;
		Надпись.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Лево;		
		Счетчик = Счетчик + 1;
	КонецЦикла;	

	ИнфПредставление = Результат[0].Представление;
	Элементы.ЗаголовокВызова.Заголовок = ?(Результат[0].ИсходящийЗвонок, "Исходящие вызовы", "Входящие вызовы");
	Элементы.ДатаВызовов.Заголовок = Формат(Результат[0].Дата, "ДФ=dd.MM.yyyy");
	
	Если ЗначениеЗаполнено(Результат[0].Клиент) Тогда
		Элементы.НовыйКонтакт.Видимость = Ложь;
		Элементы.ДобавитьККонтакту.Видимость = Ложь;
	Иначе
		Элементы.НовыйКонтакт.Видимость = Истина;
		Элементы.ДобавитьККонтакту.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьРасшифровку()
	
	Для а = 0 по ИнфРасшифровка.Количество() - 1 Цикл
		Элементы.Удалить(Элементы["Надпись"+а]); 		
	КонецЦикла;
	ИнфРасшифровка.Очистить();
	
КонецПроцедуры

