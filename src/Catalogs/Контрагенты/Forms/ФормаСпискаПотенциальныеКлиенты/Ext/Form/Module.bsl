&НаСервере
// Процедура, устанавливает заголовки дополнительных отборов "кол-во без сделок" и "кол-во с просроченными задачами".
//
Процедура УстановитьЗаголовкиДополнительныхОтборов()
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборМенеджер", УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Менеджер"));
	
	СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения();
	Если НЕ ЗначениеЗаполнено(СписокМенеджеров) Тогда
		 СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения.ВыгрузитьЗначения();
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыСведенияДляСписка.Контрагент КАК Контрагент,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК ТекущаяСделка,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача
	|ПОМЕСТИТЬ СведенияКонтрагентов
	|ИЗ
	|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.Контрагент.ПометкаУдаления = ЛОЖЬ
	|	И КонтрагентыСведенияДляСписка.Контрагент.ЭтоГруппа = ЛОЖЬ
	|	И КонтрагентыСведенияДляСписка.Контрагент.Куратор В(&МассивМенеджеров)
	|	И КонтрагентыСведенияДляСписка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыСведенияДляСписка.Контрагент) КАК КоличествоБезЗадач
	|ИЗ
	|	СведенияКонтрагентов КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыСведенияДляСписка.Контрагент) КАК КоличествоБезСделок
	|ИЗ
	|	СведенияКонтрагентов КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыСведенияДляСписка.Контрагент КАК Ссылка,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
	|ПОМЕСТИТЬ КонтрагентыЗадачаНазначеннаяДата
	|ИЗ
	|	СведенияКонтрагентов КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	НЕ КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыЗадачаНазначеннаяДата.Ссылка) КАК КоличествоПросроченныхЗадач
	|ИЗ
	|	КонтрагентыЗадачаНазначеннаяДата КАК КонтрагентыЗадачаНазначеннаяДата
	|ГДЕ
	|	КонтрагентыЗадачаНазначеннаяДата.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи");
	
	Запрос.УстановитьПараметр("МассивМенеджеров"					, СписокМенеджеров);	
	Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"     , Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи"  , НачалоДня(ТекущаяДатаСеанса()) - 1);	
	РезультатЗапроса 								= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваБезЗадач 						= РезультатЗапроса[1].Выбрать();
	ВыборкаКоличестваБезСделок 						= РезультатЗапроса[2].Выбрать();	
	ВыборкаКоличествоПросроченныхЗадач 				= РезультатЗапроса[4].Выбрать();
	
	Если ВыборкаКоличестваБезЗадач.Следующий() Тогда
		КоличествоБезЗадач = ВыборкаКоличестваБезЗадач.КоличествоБезЗадач;
	Иначе 
		КоличествоБезЗадач = 0;		
	КонецЕсли;
	Элементы.ОтборБезЗадач.Заголовок  = ПолучитьСколонениеКлиентаПоЧислу(КоличествоБезЗадач) + НСтр("ru=' без задач';en=' without tasks'");
	Элементы.ОтборБезЗадач.Видимость  = ?(КоличествоБезЗадач = 0, Ложь, Истина);
	
	Если ВыборкаКоличестваБезСделок.Следующий() Тогда
		КоличествоБезСделок = ВыборкаКоличестваБезСделок.КоличествоБезСделок;
	Иначе 
		КоличествоБезСделок = 0;		
	КонецЕсли;
	Элементы.ОтборБезСделок.Заголовок = ПолучитьСколонениеКлиентаПоЧислу(КоличествоБезСделок) + НСтр("ru=' без сделок';en=' without deals'");
	Элементы.ОтборБезСделок.Видимость = ?(КоличествоБезСделок = 0, Ложь, Истина);
	
	Если ВыборкаКоличествоПросроченныхЗадач.Следующий() Тогда
		КоличествоПросроченныхЗадач = ВыборкаКоличествоПросроченныхЗадач.КоличествоПросроченныхЗадач;
	Иначе 
		КоличествоПросроченныхЗадач = 0;		
	КонецЕсли;	
	Элементы.ОтборПросроченныхЗадач.Заголовок = ПолучитьСколонениеКлиентаПоЧислу(КоличествоПросроченныхЗадач) + НСтр("ru=' с просроченными задачами';en=' with expired tasks'");
	Элементы.ОтборПросроченныхЗадач.Видимость = ?(КоличествоПросроченныхЗадач = 0, Ложь, Истина);
	
	Элементы.ЗаглушкаСделкиЗадачи.Видимость     = ?(КоличествоБезСделок = 0 И КоличествоБезЗадач = 0 И КоличествоПросроченныхЗадач = 0, Ложь, Истина);
	Элементы.ГруппаОтборыСделкиЗадачи.Видимость = Элементы.ЗаглушкаСделкиЗадачи.Видимость;

	
КонецПроцедуры

#КонецОбласти
