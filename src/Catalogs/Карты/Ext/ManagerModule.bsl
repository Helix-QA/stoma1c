
#Область СлужебныеПроцедурыИФункции

// Функция проверяет на возможность добавдения записи в регистр
// 
Функция ПроверитьНаличиеШтрихКода(ТекСсылка, КодКарты) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1 РАЗРЕШЕННЫЕ
	|	Штрихкоды.Штрихкод,
	|	Штрихкоды.Объект,
	|	Штрихкоды.Упаковка,
	|	Штрихкоды.Объект.Наименование КАК ОбъектПредставление,
	|	Штрихкоды.Упаковка.Наименование КАК УпаковкаПредставление
	|ИЗ
	|	РегистрСведений.Штрихкоды КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Штрихкод = &Штрихкод
	|	И Штрихкоды.Объект <> &ТекСсылка";
	
	Запрос.УстановитьПараметр("Штрихкод" , КодКарты);
	Запрос.УстановитьПараметр("ТекСсылка", ТекСсылка); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ОписаниеОшибки = НСтр("ru='Такой штрихкод уже назначен для объекта %Объект%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%Объект%", """" + Выборка.ОбъектПредставление + """"
		                            + ?(ЗначениеЗаполнено(Выборка.Упаковка), " """ + НСтр("ru='в упаковке'") + " " + Выборка.УпаковкаПредставление + """", ""));
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;
		Сообщение.Поле = "Запись.Штрихкод";
		Сообщение.Сообщить();
		Возврат Истина;
	Иначе Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Функция возвращает данные штрихкода по владельцу карты
// 
Функция ПолучитьДанныеШтрихкода(КартаКлиента) Экспорт 
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	Штрихкоды.Штрихкод
	                      |ИЗ
	                      |	РегистрСведений.Штрихкоды КАК Штрихкоды
	                      |ГДЕ
	                      |	Штрихкоды.Объект = &КартаКлиента");
	Запрос.УстановитьПараметр("КартаКлиента", КартаКлиента);
	Выборка = ЗАпрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Штрихкод;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция возвращает данные владельца магнитной карты
// 
Функция ПолучитьДанныеМагнитнойКарты(КодКарты) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Карты.Ссылка КАК Карта
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.КодКарты = &КодКарты
	|	И НЕ Карты.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("КодКарты", КодКарты);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Карта;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция возвращает данные владельца магнитной карты или ключа
// 
Функция ПолучитьДанныеМагнитнойКартыКлюча(КодКарты) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Карты.Ссылка КАК Карта,
	|	Карты.ВладелецКарты КАК ВладелецКарты,
	|	Карты.ПометкаУдаления КАК ПометкаУдаления,
	|	Карты.Заблокирована КАК Заблокирована
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.КодКарты = &КодКарты
	|	И НЕ Карты.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("КодКарты", КодКарты);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Новый Структура("Карта, ВладелецКарты, ПометкаУдаления, Заблокирована", 
				Выборка.Карта, Выборка.ВладелецКарты, Выборка.ПометкаУдаления, Выборка.Заблокирована);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Фукция проверяет на возможность добавления элемента справочника
// 
Функция ПроверитьНаличиеМагнитногоКода(ТекСсылка, КодКарты) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1 РАЗРЕШЕННЫЕ
	|	Карты.КодКарты,
	|	Карты.ВладелецКарты КАК Объект
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.КодКарты = &КодКарты
	|	И Карты.Ссылка <> &КартаКлиента";
	
	Запрос.УстановитьПараметр("КодКарты"    , КодКарты);
	Запрос.УстановитьПараметр("КартаКлиента", ТекСсылка); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ОписаниеОшибки = НСтр("ru='Такой код карты уже назначен для клиента %Объект%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%Объект%", """" + Выборка.Объект + """");		                           
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;	
		Сообщение.Сообщить();
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
	
КонецФункции

// Функция - Проверить наличие кода
//
// Параметры:
//  ТекущаяСсылкаНаКарту - 	 - 
//  КодКарты			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьНаличиеКодаВСистеме(ТекущаяСсылкаНаКарту, ТипКода, КодКарты, ВнутрКодКарты) Экспорт
		
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("ЕстьКодВБазе", Ложь);
	СтруктураРезультата.Вставить("КартаКлиента"			, Неопределено);
	СтруктураРезультата.Вставить("ПредставлениеКарты"	, Неопределено);
	СтруктураРезультата.Вставить("Клиент"				, Неопределено);
	СтруктураРезультата.Вставить("ПредставлениеКлиента"	, Неопределено);
	СтруктураРезультата.Вставить("КодКарты"				, Неопределено);
	СтруктураРезультата.Вставить("Заблокирована"		, Неопределено);
	СтруктураРезультата.Вставить("ПометкаУдаления"		, Неопределено);
	
	ЕстьКодВБазе = Ложь;
	
	Если СокрЛП(КодКарты) <> "" Тогда 
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	Карты.Ссылка КАК Карта
		|ИЗ
		|	Справочник.Карты КАК Карты
		|ГДЕ
		|	Карты.Ссылка <> &КартаКлиента
		|	И Карты.КодКарты = &КодКарты";
		
		Запрос.УстановитьПараметр("КодКарты" 	, СокрЛП(КодКарты));
		Запрос.УстановитьПараметр("КартаКлиента", ТекущаяСсылкаНаКарту); 
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ЕстьКодВБазе = Истина;
			СтруктураРезультата.Вставить("ЕстьКодВБазе"			, Истина);
			СтруктураРезультата.Вставить("КартаКлиента"			, Выборка.Карта);
			СтруктураРезультата.Вставить("ПредставлениеКарты"	, Строка(Выборка.Карта));
			СтруктураРезультата.Вставить("Клиент"				, Выборка.Карта.ВладелецКарты);
			СтруктураРезультата.Вставить("ПредставлениеКлиента"	, СокрЛП(Строка(Выборка.Карта.ВладелецКарты)));
			СтруктураРезультата.Вставить("КодКарты"				, СокрЛП(Выборка.Карта.КодКарты));
			СтруктураРезультата.Вставить("Заблокирована"		, Выборка.Карта.Заблокирована);
			СтруктураРезультата.Вставить("ПометкаУдаления"		, Выборка.Карта.ПометкаУдаления);
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЕстьКодВБазе И СокрЛП(ВнутрКодКарты) <> "" Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	Карты.Ссылка КАК Карта
		|ИЗ
		|	Справочник.Карты КАК Карты
		|ГДЕ
		|	Карты.Ссылка <> &КартаКлиента
		|	И Карты.ВнутреннийКодКарты = &КодКарты";
		
		Запрос.УстановитьПараметр("КодКарты" 	, СокрЛП(ВнутрКодКарты));
		Запрос.УстановитьПараметр("КартаКлиента", ТекущаяСсылкаНаКарту); 
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ЕстьКодВБазе = Истина;
			СтруктураРезультата.Вставить("ЕстьКодВБазе"			, Истина);
			СтруктураРезультата.Вставить("КартаКлиента"			, Выборка.Карта);
			СтруктураРезультата.Вставить("ПредставлениеКарты"	, Строка(Выборка.Карта));
			СтруктураРезультата.Вставить("Клиент"				, Выборка.Карта.ВладелецКарты);
			СтруктураРезультата.Вставить("ПредставлениеКлиента"	, СокрЛП(Строка(Выборка.Карта.ВладелецКарты)));
			СтруктураРезультата.Вставить("КодКарты"				, СокрЛП(Выборка.Карта.ВнутреннийКодКарты));
			СтруктураРезультата.Вставить("Заблокирована"		, Выборка.Карта.Заблокирована);
			СтруктураРезультата.Вставить("ПометкаУдаления"		, Выборка.Карта.ПометкаУдаления);
		КонецЕсли;
	
	КонецЕсли;	
	
	Возврат СтруктураРезультата;
	
КонецФункции

// Получить все карты клиента, можно укзать тип карты
// 
Функция ПолучитьКартыКлиента(
	Клиент, 
	ВидКарты = Неопределено, 
	ТипКода = Неопределено, 
	КоличествоЗаписей = Неопределено, 
	Заблокирована = Неопределено, 
	ИсключитьКарту = Неопределено, 
	ПометкаУдаления = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ &Количество
	|	Карты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ВладелецКарты = &ВладелецКарты
	|	И ВЫБОР
	|			КОГДА &ВидКарты <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Карты.ВидКарты = &ВидКарты
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И (&ТипКода = НЕОПРЕДЕЛЕНО
	|			ИЛИ Карты.ТипКода = &ТипКода)
	|	И (&Заблокирована = НЕОПРЕДЕЛЕНО
	|			ИЛИ Карты.Заблокирована = &Заблокирована)
	|	И (&ИсключитьКарту = НЕОПРЕДЕЛЕНО
	|			ИЛИ Карты.Ссылка <> &ИсключитьКарту)
	|	И (&ПометкаУдаления = НЕОПРЕДЕЛЕНО
	|			ИЛИ Карты.ПометкаУдаления = &ПометкаУдаления)");
		
	Запрос.УстановитьПараметр("ВладелецКарты"  , Клиент);
	Запрос.УстановитьПараметр("ВидКарты"       , ВидКарты);
    Запрос.УстановитьПараметр("ТипКода"        , ТипКода);
	Запрос.УстановитьПараметр("Заблокирована"  , Заблокирована);
	Запрос.УстановитьПараметр("ИсключитьКарту" , ИсключитьКарту);
	Запрос.УстановитьПараметр("ПометкаУдаления", ПометкаУдаления);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Количество", ?(ЗначениеЗаполнено(КоличествоЗаписей), СтрШаблон("ПЕРВЫЕ %1", КоличествоЗаписей), ""));
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция создает карту клиента с указанными параметрами и возвращает ссылку на нее. 
// По умолчанию создается штриховая карта с кодом генерируемым автоматически.
Функция СоздатьКартуКлиента(
	Клиент,
	ВидКарты           = Неопределено,
	ТипКода            = Неопределено,
	КодКарты           = Неопределено,
	ВнутреннийКодКарты = Неопределено,
	Заблокирована      = Ложь,
	ВнешнийИсточник    = Ложь,
	СсылкаНаУстановку  = Неопределено) Экспорт
		
	НоваяКарта                    = Справочники.Карты.СоздатьЭлемент();
	НоваяКарта.ВладелецКарты      = Клиент;
	НоваяКарта.ВидКарты           = ВидКарты;
	НоваяКарта.ТипКода            = ?(ЗначениеЗаполнено(ТипКода), ТипКода, Перечисления.ВидыКарт.Штриховая);
	НоваяКарта.ДатаОткрытия       = ТекущаяДата();
	НоваяКарта.КодКарты           = ?(ЗначениеЗаполнено(КодКарты), КодКарты, РегистрыСведений.Штрихкоды.СформироватьШтрихкодEAN13());
	НоваяКарта.ВнутреннийКодКарты = ВнутреннийКодКарты;
    НоваяКарта.Заблокирована      = Заблокирована;
	НоваяКарта.Наименование       = ПолучитьНаименованиеКарты(НоваяКарта);
	НоваяКарта.СсылкаНаУстановкуКарты = СсылкаНаУстановку;
	
	Если ВнешнийИсточник Тогда
		НоваяКарта.ДополнительныеСвойства.Вставить("ВнешнийИсточник");
	КонецЕсли;
	
	НоваяКарта.Записать();
		
	Возврат НоваяКарта.Ссылка;
	
КонецФункции

// Функция вернет наименование карты по шаблону
Функция ПолучитьНаименованиеКарты(КартаОбъект) Экспорт
	
	Возврат ""+КартаОбъект.КодКарты +", " +КартаОбъект.ВладелецКарты + " (" + КартаОбъект.ТипКода + ")";
	
КонецФункции

// Функция, возвращает карту клиента.
// 
Функция ПолучитьКартуКлиента(Клиент) Экспорт
	
	Если Не ЗначениеЗаполнено(Клиент) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Карты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ВладелецКарты = &ВладелецКарты");
	
	Запрос.УстановитьПараметр("ВладелецКарты", Клиент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Функция, возвращает карту wallet клиента.
// 
Функция ПолучитьКартыWalletКлиента(Клиент, ИсключаемыеКарты = Неопределено) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Карты.Ссылка КАК Карта
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ВладелецКарты = &ВладелецКарты
	|	И НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Wallet)
	|	И НЕ Карты.ВнутреннийКодКарты = """"
	|	И &ФильтрПоКартам");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ФильтрПоКартам", ?(ЗначениеЗаполнено(ИсключаемыеКарты), "И Не Карты.Ссылка В (&ИсключаемыеКарты)", ""));
	
	Запрос.УстановитьПараметр("ВладелецКарты"   , Клиент);
	Запрос.УстановитьПараметр("ИсключаемыеКарты", ИсключаемыеКарты);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Карта");
	
КонецФункции

// Функция - Получить сотрудника по карте
// 
// Параметры:
//  КодКарты - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьКартуПоКоду(Знач КодКарты = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Карты.Ссылка КАК Ссылка,
	               |	Карты.Заблокирована КАК Заблокирована,
	               |	Карты.ВладелецКарты КАК Сотрудник
	               |ИЗ
	               |	Справочник.Карты КАК Карты
	               |ГДЕ
	               |	НЕ Карты.ПометкаУдаления
	               |	И НЕ ВЫРАЗИТЬ(Карты.ВладелецКарты КАК Справочник.Сотрудники) ЕСТЬ NULL
	               |	И Карты.КодКарты ПОДОБНО &КодКарты";
	
	Запрос.УстановитьПараметр("КодКарты", СокрЛП(КодКарты));			   
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция, отправляет push wallet
// 
// Параметры:
//  СерийныйНомерКарты	 - 	 - 
//  ВнешняяСистемаWallet - 	 - 
//  Сообщение			 - 	 - 
// 
Функция ОтправитьPushWallet(МассивСообщений, ЭтоГрупповаяРассылка = Ложь) Экспорт
	
	ОтветСервера = ПолучитьСтруктуруВозврата();
	ВнешняяСистемаWallet = МассивСообщений[0].СервисРассылки;
	
	Попытка
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Заголовки  = Новый Соответствие;
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		Push = Новый HTTPЗапрос("/v1/passes", Заголовки);
		Push.УстановитьТелоИзСтроки(СобратьJson(ПолучитьТелоЗапросаМассовойРассылки(МассивСообщений, ЭтоГрупповаяРассылка)));
		Результат = Соединение.ВызватьHTTPМетод("PATCH", Push);
		ОтветСоответствие = РазобратьJson(Результат, Истина);
		
	Исключение	
		ОтветСервера.ОписаниеОшибки = ОписаниеОшибки();
		Возврат ОтветСервера;
		
	КонецПопытки;
	
	Если Результат.КодСостояния = 200 Тогда
		
		ОтветСервера.Успешно = Истина;
		ОтветСервера.status	 = 200;
		ОтветСервера.data	 = ОтветСоответствие["data"];
		
		Возврат ОтветСервера;
		
	Иначе
		ПараметрыJson = РазобратьJson(Результат);
		ОтветСервера.ОписаниеОшибки = ОтветСоответствие["error"]["message"];
		Возврат ОтветСервера;
		
	КонецЕсли;
	
КонецФункции

// Функция - Разобрать json
// 
// Параметры:
//  РезультатЗапроса - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция РазобратьJson(РезультатЗапроса, ПрочитатьВСоответствие = Ложь)
	
	ТекстJSON  = РезультатЗапроса.ПолучитьТелоКакСтроку();	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON, ПрочитатьВСоответствие);
	
	Возврат ПараметрыJSON;
	
КонецФункции

// Функция - Собрать json
// 
// Параметры:
//  ТелоЗапроса	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция СобратьJson(ТелоЗапроса)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, ТелоЗапроса);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Функция, возвращает структуру возврата.
// 
Функция ПолучитьСтруктуруВозврата()
	
	СтруктураВозврата =  Новый Структура("КодКарты, ВнутреннийКодКарты, ОписаниеОшибки, Ссылка, status, id, data");
	
	СтруктураВозврата.Вставить("Успешно", Ложь);
	СтруктураВозврата.Вставить("СинхронизироватьНомерТелефона", Истина);
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция, возвращает признак участия клиента в рассылке.
// 
Функция КлиентУчаствуетВРассылкеWallet(Клиент) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Карты.Ссылка КАК Карта
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ВладелецКарты = &ВладелецКарты
	|	И НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Wallet)");
		
	Запрос.УстановитьПараметр("ВладелецКарты", Клиент);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, возвращает ссылку на установку карты wallet.
// 
Функция ПолучитьСсылкуНаУстановкуКартыWallet(СерийныйНомерКарты, ВнешняяСистема) Экспорт
	
	ОтветСервера = ПолучитьСтруктуруВозврата();
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистема),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистема.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистема.КлючШифрования);
		
		ЗапросНаПолучениеКарты = Новый HTTPЗапрос("/v1/passes/" + СерийныйНомерКарты, Заголовки); 
		Результат = Соединение.Получить(ЗапросНаПолучениеКарты);					
		
	Исключение	
		
		ОтветСервера.ОписаниеОшибки = ОписаниеОшибки();
		Возврат ОтветСервера;
		
	КонецПопытки;
	
	Если Результат.КодСостояния = 200 Тогда
		
		ОтветСервера.Успешно = Истина;	
		ПараметрыJson        = РазобратьJson(Результат);
		ОтветСервера.Ссылка	 = ПараметрыJson.data.link; 
		
		Возврат ОтветСервера;
		
	Иначе	
		
		ПараметрыJson               = РазобратьJson(Результат);
		ОтветСервера.ОписаниеОшибки = ПараметрыJson.error.message;
		
		Возврат ОтветСервера;
		
	КонецЕсли;

	
КонецФункции

// Функция - возращает номер выданной карты.
// 
Функция ПолучитьНомерВыданнойКарты(ВладелецКарты, ВидКарты) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Карты.КодКарты КАК НомерКарты,
	|	Карты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ПометкаУдаления = ЛОЖЬ
	|	И Карты.Заблокирована = ЛОЖЬ
	|	И Карты.ВидКарты = &ВидКарты
	|	И Карты.ВладелецКарты = &ВладелецКарты");
	
	Запрос.УстановитьПараметр("ВидКарты"		, ВидКарты);
	Запрос.УстановитьПараметр("ВладелецКарты"	, ВладелецКарты);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат ?(Результат.Количество() = 0, Неопределено, Результат[0].НомерКарты);
	
КонецФункции

// Функция, обрабатывает вебхук.
// 
Функция ОбработатьВебХук(ВнешняяСистема, ПараметрыJSON) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// вытягиваем карту по ид или коду.
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Карты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	&ФильтрПоВнутреннемуКодуКартыИлиКодуКарты");
	
	МассивСобытий = Новый_Массив("PassRegistered", "PassUnregistered");
	
	// Для событий PassRegistered и PassUnregistered серийный номер карты прилетает в свойстве pass_serial_number
	
	ИмяСвойства = ?(МассивСобытий.Найти(ПараметрыJSON.event) <> Неопределено, "pass_serial_number", "serial_number");
	
	Запрос.УстановитьПараметр("ВнутреннийКодКарты", ПараметрыJSON.data[ИмяСвойства]);
	
	Если ПараметрыJSON.event = "PassCreated" Тогда
		
		ТекстФильтра = "Карты.ВнутреннийКодКарты = &ВнутреннийКодКарты Или Карты.КодКарты = &КодКарты";
		
		Запрос.УстановитьПараметр("КодКарты", ПараметрыJSON.data.pass_number);
		
	Иначе
		
		ТекстФильтра = "Карты.ВнутреннийКодКарты = &ВнутреннийКодКарты";
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ФильтрПоВнутреннемуКодуКартыИлиКодуКарты", ТекстФильтра);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Карта = ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);

	
	Если ЗначениеЗаполнено(Карта) Тогда
		
		КартаОбъект = Карта.ПолучитьОбъект();
		
		Если ПараметрыJSON.event = "PassRegistered" Тогда
			
			КартаОбъект.КоличествоУстановок = КартаОбъект.КоличествоУстановок + 1;				
			
		ИначеЕсли ПараметрыJSON.event = "PassUnregistered" Тогда
			
			КартаОбъект.КоличествоУстановок = КартаОбъект.КоличествоУстановок - 1;
			
		ИначеЕсли ПараметрыJSON.event = "PassUpdated" Тогда
			
			Если Карта.ПометкаУдаления = Ложь И ПараметрыJSON.data.Свойство("changes") И ПараметрыJSON.data.changes.Свойство("voided") И ПараметрыJSON.data.changes.voided = Истина Тогда 
				
				КартаОбъект.КартаУдалена = Истина;
				КартаОбъект.ПометкаУдаления = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
		Попытка
			
			КартаОбъект.ДополнительныеСвойства.Вставить("ВидЭлектроннойКарты"	, "Wallet");
			КартаОбъект.ДополнительныеСвойства.Вставить("ЭтоНовый"				, Ложь);			
			КартаОбъект.Записать();
			
		Исключение
			
			Возврат ПолучитьСтруктуруОшибки(5004, ОписаниеОшибки());	
			
		КонецПопытки;
		
	Иначе
				
		Если ПараметрыJSON.event = "PassCreated" Тогда // создание карты 
			
			НомерТелефона = ПараметрыJSON.data.fields.phone_number;
			АдресЭП       = ПараметрыJSON.data.fields.email;
			Имя           = ПараметрыJSON.data.fields.first_name;
			Фамилия       = ПараметрыJSON.data.fields.last_name;
			ДатаРождения  = ПараметрыJSON.data.fields.birthdate;
			
			СсылкаНаУстановку    = ПараметрыJSON.data.link;
			КодКарты 		     = ПараметрыJSON.data.pass_number;
			ВнутреннийКодКарты   = ПараметрыJSON.data.serial_number;
			ИдентификаторПроекта = ПараметрыJSON.data.project_id;
			
			ВидКарты = ПолучитьВидКартыWalletПоИдентификатору(ИдентификаторПроекта);
			
			Если Не ЗначениеЗаполнено(ВидКарты) Тогда
				
				ОписаниеОшибки = "";
				
				ВидКарты = СоздатьВидКарты(ИдентификаторПроекта, ВнешняяСистема, ОписаниеОшибки);
				
				Если Не ЗначениеЗаполнено(ВидКарты) Тогда
					
					Возврат ПолучитьСтруктуруОшибки(5003, "Не удалось создать вид карты. " + ОписаниеОшибки);	
					
				КонецЕсли;
				
			КонецЕсли;
			
			Клиент = Неопределено;
			
			Если ЗначениеЗаполнено(НомерТелефона) Тогда
				
				Клиент = Справочники.Контрагенты.ПолучитьКонтрагентаПоНомеруТелефона(НомерТелефона);
				
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(Клиент) И ЗначениеЗаполнено(АдресЭП) Тогда
				
				Клиент = Справочники.Контрагенты.ПолучитьКонтрагентаПоEmail(АдресЭП);
				
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(Клиент) Тогда
				
				Попытка
					
					Клиент = Справочники.Контрагенты.СоздатьКлиента(
					Фамилия,
					Имя,, 
					НомерТелефона, 
					АдресЭП,,
					ДатаРождения
					);
					
				Исключение
					
					Возврат ПолучитьСтруктуруОшибки(5005, ОписаниеОшибки());
					
				КонецПопытки;
				
			КонецЕсли;
			
			Попытка
				
				СоздатьКартуКлиента(Клиент, ВидКарты, Перечисления.ВидыКарт.Wallet, КодКарты, ВнутреннийКодКарты,, Истина, СсылкаНаУстановку); 
				
			Исключение
				
				Возврат ПолучитьСтруктуруОшибки(5006, ОписаниеОшибки());
				
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Новый Структура("Result", Истина);
	
КонецФункции

// Функция, возвращает вид карты по идентификатору.
// 
Функция ПолучитьВидКартыWalletПоИдентификатору(ИдентификаторПроекта)
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыКарт.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыКарт КАК ВидыКарт
	|ГДЕ
	|	ВидыКарт.ИдентификаторПроекта = &ИдентификаторПроекта");	
	
	Запрос.УстановитьПараметр("ИдентификаторПроекта", ИдентификаторПроекта);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Функция, создает и возвращает ссылку на вид карты.
// 
Функция СоздатьВидКарты(ИдентификаторПроекта, ВнешняяСистемаWallet, ОписаниеОшибки)
	
	РезультатЗапроса = ПолучитьДанныеПроекта(ИдентификаторПроекта, ВнешняяСистемаWallet);		
	
	Если РезультатЗапроса.Успешно Тогда
		
		Попытка
			
			ВидКартыОбъект = Справочники.ВидыКарт.СоздатьЭлемент();
			ВидКартыОбъект.Наименование = РезультатЗапроса.data.name;
			ВидКартыОбъект.ИдентификаторПроекта = ИдентификаторПроекта;
			ВидКартыОбъект.ТипКода = Перечисления.ВидыКарт.Wallet;
			
			ВидКартыОбъект.Записать();
			
		Исключение
			
			ОписаниеОшибки = ОписаниеОшибки();
			
			Возврат Неопределено;
			
		КонецПопытки;
		
		Возврат ВидКартыОбъект.Ссылка;
		
	Иначе
		
		ОписаниеОшибки = РезультатЗапроса.ОписаниеОшибки;
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КонецФункции

// Функция, возвращает структуру ошибки.
// 
Функция ПолучитьСтруктуруОшибки(КодОшибки, ОписаниеОшибки)
	
	Возврат Новый Структура("Result, Error, ErrorMessage", Ложь, КодОшибки, ОписаниеОшибки);		
	
КонецФункции

// Функция, возвращает данные проекта Wallet.
// 
Функция ПолучитьДанныеПроекта(ИдентификаторПроекта, ВнешняяСистемаWallet)
	
	РезультатЗапроса = ПолучитьСтруктуруВозврата();
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
				
		Запрос = Новый HTTPЗапрос("/v1/projects/" + ИдентификаторПроекта, Заголовки); 
		
		Результат = Соединение.Получить(Запрос);					
		
	Исключение	
		
		РезультатЗапроса.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();	
		
		Возврат РезультатЗапроса;
		
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат);
	
	Если Результат.КодСостояния = 200 Тогда
			
		РезультатЗапроса.Успешно = Истина;
		РезультатЗапроса.data	 = ПараметрыJson.data;
		
		Возврат РезультатЗапроса;
		
	Иначе
		
		РезультатЗапроса.ОписаниеОшибки = "Wallet: " + ПараметрыJson.error.message;
		
		Возврат РезультатЗапроса;
		
	КонецЕсли;		
	
КонецФункции

// Функция, обновляет ВебХук.
// 
Функция ОбновитьВебХук(ВнешняяСистемаWallet, ВебХукИД, ОбработчикСобытия) Экспорт
	
	РезультатОбновления = ПолучитьСтруктуруВозврата();
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		
		ЗапросНаИзменениеХука = Новый HTTPЗапрос("/v1/webhooks/" + ВебХукИД, Заголовки); 
		
		ЗапросНаИзменениеХука.УстановитьТелоИзСтроки(СобратьJson(Новый Структура("url", ОбработчикСобытия)));
		
		Результат = Соединение.ВызватьHTTPМетод("PATCH", ЗапросНаИзменениеХука);					
		
	Исключение	
		
		РезультатОбновления.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();		
		Возврат РезультатОбновления;
		
	КонецПопытки;
		
	Если Результат.КодСостояния = 200 Тогда
		
		РезультатОбновления.Успешно = Истина;		
		Возврат РезультатОбновления;
		
	Иначе
		
		ПараметрыJson = РазобратьJson(Результат);
		
		РезультатОбновления.ОписаниеОшибки = "Wallet: " + ПараметрыJson.error.message;
		Возврат РезультатОбновления;
		
	КонецЕсли;		
	
КонецФункции

// Функция, регистрирует ВебХук.
// 
Функция УстановитьВебХук(ВнешняяСистемаWallet, ИмяВебХука, Событие, ОбработчикСобытия, ИдПроектов = Неопределено, Глобальный = Истина) Экспорт
	
	РезультатСоздания = ПолучитьСтруктуруВозврата();
	
	Попытка		
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВнешняяСистемаWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВнешняяСистемаWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВнешняяСистемаWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		
		ТелоЗапроса = Новый Структура("event, url, global", Событие, ОбработчикСобытия, Глобальный);
		
		Если Не Глобальный Тогда
			ТелоЗапроса.Вставить("projects", ИдПроектов); 		
		КонецЕсли;
		
		ЗапросНаСозданиеВебХука = Новый HTTPЗапрос("/v1/webhooks", Заголовки); 
		ЗапросНаСозданиеВебХука.УстановитьТелоИзСтроки(СобратьJson(ТелоЗапроса));
		Результат = Соединение.ОтправитьДляОбработки(ЗапросНаСозданиеВебХука);					
		
	Исключение	
		
		РезультатСоздания.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();	
		
		Возврат РезультатСоздания;
		
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат);
	
	Если Результат.КодСостояния = 201 Тогда
			
		РезультатСоздания.Успешно = Истина;
		РезультатСоздания.id	  = ПараметрыJson.data.id;
		
		Возврат РезультатСоздания;
		
	Иначе
		
		РезультатСоздания.ОписаниеОшибки = "Wallet: " + ПараметрыJson.error.message;
		Возврат РезультатСоздания;
		
	КонецЕсли;		
	
КонецФункции

// Процедура, выполняет синхронизацию видов карт.
// 
Процедура СинхронизироватьВидыКарт(ВидыКарт) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|  ВидыКарт.Ссылка КАК Ссылка,
	|  ВидыКарт.ИдентификаторПроекта КАК ИдентификаторПроекта
	|ИЗ
	|  Справочник.ВидыКарт КАК ВидыКарт
	|ГДЕ
	|  ВидыКарт.ИдентификаторПроекта В(&МассивИдентификаторов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|  ВидыКарт.Ссылка КАК Ссылка,
	|  ВидыКарт.ИдентификаторПроекта КАК ИдентификаторПроекта
	|ИЗ
	|  Справочник.ВидыКарт КАК ВидыКарт
	|ГДЕ
	|  ВидыКарт.ИдентификаторПроекта <> 0
	|  И НЕ ВидыКарт.ИдентификаторПроекта В (&МассивИдентификаторов)
	|  И НЕ ВидыКарт.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("МассивИдентификаторов", ВидыКарт.ВыгрузитьЗначения());
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	СуществующиеКарты = РезультатЗапроса[0].Выгрузить();
	НенайденныеКарты  = РезультатЗапроса[1].Выгрузить();
	
	Если ЗначениеЗаполнено(СуществующиеКарты) Или ЗначениеЗаполнено(НенайденныеКарты) Тогда
		
		// обновить существующие виды карт
		Для Каждого ВидКарты Из СуществующиеКарты Цикл
			
			ВидКартыОбъект = ВидКарты.Ссылка.ПолучитьОбъект();
			ВидКартыОбъект.Наименование = ВидыКарт.НайтиПоЗначению(ВидКарты.ИдентификаторПроекта).Представление;
			ВидКартыОбъект.ПометкаУдаления = Ложь;
			ВидКартыОбъект.Записать();
			
		КонецЦикла;
		
		// пометить на удаление ненайденные карты
		Для Каждого ВидКарты Из НенайденныеКарты Цикл
			
			ВидКартыОбъект = ВидКарты.Ссылка.ПолучитьОбъект();
			ВидКартыОбъект.УстановитьПометкуУдаления(Истина);  
			
		КонецЦикла;
		
	КонецЕсли;
	
	МассивСуществующихВидовКарт = СуществующиеКарты.ВыгрузитьКолонку("ИдентификаторПроекта");
	
	// добавить новые виды карт
	Для Каждого ВидКарты Из ВидыКарт Цикл
		
		Если МассивСуществующихВидовКарт.Найти(ВидКарты.Значение) = Неопределено Тогда
			
			ВидКартыОбъект = Справочники.ВидыКарт.СоздатьЭлемент();
			
			ВидКартыОбъект.ИдентификаторПроекта = ВидКарты.Значение;
			ВидКартыОбъект.Наименование = ВидКарты.Представление;
			ВидКартыОбъект.ТипКода = Перечисления.ВидыКарт.Wallet;
			ВидКартыОбъект.Именная = Истина;
			
			ВидКартыОбъект.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция, создает проект электронной карты.
// 
Функция СоздатьПроектWallet(ВСWallet, ИмяПроекта, Нумератор, Сертификат) Экспорт
	
	РезультатЗапроса = ПолучитьСтруктуруВозврата();
		
	Попытка
		
		Соединение = Новый HTTPСоединение(ПолучитьАдресAPI(ВСWallet),,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , ВСWallet.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", ВСWallet.КлючШифрования);
		Заголовки.Вставить("Content-Type"   , "application/json");
		Запрос = Новый HTTPЗапрос("/v1/projects", Заголовки);
		Запрос.УстановитьТелоИзСтроки(СобратьJson(ПолуТелоЗапросаСозданияПроекта(ИмяПроекта, Нумератор, Сертификат)));
		Результат = Соединение.ОтправитьДляОбработки(Запрос);					
		
	Исключение	
		
		РезультатЗапроса.ОписаниеОшибки = "Wallet: " + ОписаниеОшибки();		
		Возврат РезультатЗапроса;
	
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат);
	
	Если Результат.КодСостояния = 201 Тогда
		
		РезультатЗапроса.Успешно = Истина;
		РезультатЗапроса.id      = ПараметрыJson.data.id;
		Возврат РезультатЗапроса;
				
	Иначе
		
		РезультатЗапроса.ОписаниеОшибки = "Wallet: " + ПараметрыJson.error.message;		
		Возврат РезультатЗапроса;
		
	КонецЕсли;		
	
КонецФункции

// Функция, возвращает тело запроса на создание проекта.
// 
Функция ПолуТелоЗапросаСозданияПроекта(ИмяПроекта, Нумератор, Сертификат)
	
	ПараметрыJson = Новый Структура;
	ПараметрыJson.Вставить("name"			, ИмяПроекта);
	ПараметрыJson.Вставить("numerator_id"	, Нумератор);
	ПараметрыJson.Вставить("integrations"	, Новый_Массив("Stoma1c"));
