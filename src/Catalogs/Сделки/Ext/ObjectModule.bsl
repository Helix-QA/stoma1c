// Процедура - Инициализировать дополнительные свойства объекта
//
Процедура ИнициализироватьДополнительныеСвойстваОбъекта()
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Ссылка) Тогда			
		ЭтотОбъект.ДополнительныеСвойства.Вставить("СделкаСоздана"				, Истина);
	ИначеЕсли НЕ ЭтотОбъект.Ссылка.ЭтапСделки = ЭтотОбъект.ЭтапСделки Тогда 
		ЭтотОбъект.ДополнительныеСвойства.Вставить("СделкаИзменена"				, Истина);
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ИзмененЭтап"				, Истина);
		Если ЭтотОбъект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты")
			И ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ЭтотОбъект.ВидСделки, 4) Тогда 
			ЭтотОбъект.ДополнительныеСвойства.Вставить("ЭтапЗаписьПодтверждена"	, Истина);
		КонецЕсли;
	ИначеЕсли НЕ ЭтотОбъект.ПометкаУдаления И ЭтотОбъект.Ссылка.ПометкаУдаления Тогда
		ЭтотОбъект.ДополнительныеСвойства.Вставить("СделкаИзменена"				, Истина);
	ИначеЕсли ЭтотОбъект.ПометкаУдаления И НЕ ЭтотОбъект.Ссылка.ПометкаУдаления Тогда
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ПометкаУдаленияУстановлена"	, Истина);
	КонецЕсли;		
	
	// По флагу завершим все связанные задачи
	Если НЕ ЭтотОбъект.ПометкаУдаления Тогда 
		Если НЕ (ЭтотОбъект.Ссылка.РезультатСделки = Перечисления.РезультатыСделок.Отказ ИЛИ ЭтотОбъект.Ссылка.РезультатСделки = Перечисления.РезультатыСделок.Успех) 
			И (ЭтотОбъект.РезультатСделки = Перечисления.РезультатыСделок.Отказ ИЛИ ЭтотОбъект.РезультатСделки = Перечисления.РезультатыСделок.Успех) Тогда 
			ДополнительныеСвойства.Вставить("ЗавершитьВсеСвязанныеЗадачи", Истина);
		КонецЕсли;
	
		Если ЭтотОбъект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
			ЭтапСделкиЗаписан = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ЭтотОбъект.ВидСделки, 3);
			Если НЕ ЭтотОбъект.Ссылка.ЭтапСделки = ЭтапСделкиЗаписан И ЭтотОбъект.ЭтапСделки = ЭтапСделкиЗаписан Тогда 
				ДополнительныеСвойства.Вставить("ЗавершитьВсеСвязанныеЗадачи", Истина);
				ДополнительныеСвойства.Вставить("ЗадачаОписание", "Выполнена автоматически в момент записи на прием.");
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Инициализировать стек статусов сквозной аналитики
//
Процедура ИнициализироватьСтекСтатусовСквознойАналитики()

#Область Аналитика_Calltouch	
	
	ВнешниеСистемыCalltouch = Справочники.ВнешниеСистемы.ПолучитьВнешниеСистемы(Перечисления.ТипыВнешнихСистем.Calltouch);
		
	Для Каждого ВС Из ВнешниеСистемыCalltouch Цикл
		
		Если ЭтотОбъект.ДополнительныеСвойства.Свойство("СделкаИзменена") Тогда
			Если ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
				РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Ссылка, Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась, ВС.Ссылка);
			ИначеЕсли ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда
				РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Ссылка, Перечисления.СтатусыСквознойАналитики.СделкаСостоялась, ВС.Ссылка);
			Иначе
				РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Ссылка, Перечисления.СтатусыСквознойАналитики.СделкаСменаЭтапа, ВС.Ссылка);
			КонецЕсли;
		ИначеЕсли ЭтотОбъект.ДополнительныеСвойства.Свойство("СделкаСоздана") Тогда
			РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Ссылка, Перечисления.СтатусыСквознойАналитики.СделкаСоздана, ВС.Ссылка);
			
			//ИначеЕсли ЭтотОбъект.ДополнительныеСвойства.Свойство("ПометкаУдаленияИзменена") Тогда
			//	
			//	Если ЭтотОбъект.ПометкаУдаления тогда
			//		РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Заявка, Перечисления.СтатусыСквознойАналитики.СделкаНеСоздана);		
			//	Иначе
			//		РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Заявка, Перечисления.СтатусыСквознойАналитики.СделкаСоздана);	
			//	КонецЕсли;	
		КонецЕсли;	
		
	КонецЦикла;

#КонецОбласти	

#Область Аналитика_CoMagic

	ВнешниеСистемыCoMagic = Справочники.ВнешниеСистемы.ПолучитьВнешниеСистемы(Перечисления.ТипыВнешнихСистем.CoMagic);
	
	Если ЗначениеЗаполнено(ВнешниеСистемыCoMagic) Тогда
		
		УдалитьТекущийЭтапИзСтека = Ложь;
		
		ОбъектСА = ?(ЗначениеЗаполнено(ЭтотОбъект.Заявка), ЭтотОбъект.Заявка, ЭтотОбъект.Ссылка);
		СтатусВСтекеСА = РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ВернутьСтатусОбъектаПоСсылке(ОбъектСА);

		Если НЕ СтатусВСтекеСА = Неопределено Тогда		
			УдалитьТекущийЭтапИзСтека = Истина;	
		КонецЕсли;
		
		НовыйСтатусСА = Неопределено;
		Если ЭтотОбъект.ДополнительныеСвойства.Свойство("СделкаИзменена") Тогда			
			
			Если ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
				НовыйСтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась;
			ИначеЕсли ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда
				НовыйСтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаСостоялась;
			Иначе
				НовыйСтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаСменаЭтапа;
			КонецЕсли;
			
		ИначеЕсли ЭтотОбъект.ДополнительныеСвойства.Свойство("СделкаСоздана") Тогда			
			НовыйСтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаСоздана;			
		ИначеЕсли ЭтотОбъект.ДополнительныеСвойства.Свойство("ПометкаУдаленияУстановлена") Тогда						
			НовыйСтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаУдалена;			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НовыйСтатусСА) Тогда
			
			Для Каждого ВС Из ВнешниеСистемыCoMagic Цикл
				
				Если УдалитьТекущийЭтапИзСтека Тогда
					РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.УдалитьЗаписьПоЗаявке(ОбъектСА, ВС.Ссылка, СтатусВСтекеСА);
				КонецЕсли;
				
				РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ОбъектСА, НовыйСтатусСА, ВС.Ссылка);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;

#КонецОбласти

#Область Аналитика_ЯндексМетрика

	ВнешняяСистемаЯндексМетрика = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.ЯндексМетрика, Истина);
	
	Если ЗначениеЗаполнено(ВнешняяСистемаЯндексМетрика) И
		ЗначениеЗаполнено(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВнешняяСистемаЯндексМетрика, "ТокенДоступа")) Тогда
		
		СтатусСА = Неопределено;
		
		Если ЭтотОбъект.ДополнительныеСвойства.Свойство("СделкаИзменена") Тогда
			
			Если ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
				СтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаНеСостоялась;
			ИначеЕсли ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда
				СтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаСостоялась;
			Иначе
				СтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаСменаЭтапа;
			КонецЕсли;
			
		ИначеЕсли ЭтотОбъект.ДополнительныеСвойства.Свойство("СделкаСоздана") Тогда
			
			СтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаСоздана;
		
		ИначеЕсли ЭтотОбъект.ДополнительныеСвойства.Свойство("ПометкаУдаленияУстановлена") Тогда
			
			СтатусСА = Перечисления.СтатусыСквознойАналитики.СделкаУдалена;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтатусСА) Тогда
			РегистрыСведений.СтекИзмененийСтатусовСквознойАналитики.ДобавитьЗапись(ЭтотОбъект.Ссылка, СтатусСА, ВнешняяСистемаЯндексМетрика);	
		КонецЕсли;
		
	КонецЕсли;	

#КонецОбласти	
	
КонецПроцедуры

// Процедура - Инициализировать заявку пациента
//
Процедура ИнициализироватьЗаявкуПациента() Экспорт 

	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Заявка) Тогда
		Если ЭтотОбъект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
			Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда 
				МассивСтатусов = Новый Массив;
				МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.НеОбработана);
				МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ПропущенныйЗвонок);
				МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ОтвеченныйЗвонок);
				МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ОтвеченныйДиалог);
				МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.Перезвонить);
				МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.Отклонена);
				ЭтотОбъект.Заявка = Справочники.Заявки.ПолучитьЗаявкуКонтрагента(ЭтотОбъект.Контрагент, МассивСтатусов, ЭтотОбъект.СтруктурнаяЕдиница);
			КонецЕсли;	
		Иначе 	
			МассивЗаявок = Справочники.Заявки.ПолучитьМассивАктуальныхЗаявокКонтрагента(,ЭтотОбъект.Контрагент);
			Если МассивЗаявок.Количество() > 0 Тогда
				ЭтотОбъект.Заявка = МассивЗаявок[0];
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

// Процедура - Синхронизировать объект с заявкой
//
Процедура СинхронизироватьОбъектСЗаявкой()
	
	// Синхронизации в данной транзакции еще не было. Начинаем.
	Если НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ЗаявкаСинхронизации") Тогда
		ЗаявкаКлиента = Неопределено;
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ЗаявкаСинхронизации", ЗаявкаКлиента);
		Если ЭтотОбъект.Ссылка.Пустая() И НЕ ЗначениеЗаполнено(ЭтотОбъект.Заявка) И ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "НеобходимаГенерацияЗаявки", Ложь) Тогда
			// Выше поискали. Не нашли. И просят создать заявку.
			ЭтотОбъект.КаналПривлечения 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "КаналПривлечения"			, ЭтотОбъект.КаналПривлечения);
			ЭтотОбъект.КаналПривлеченияЗначение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "КаналПривлеченияЗначение"	, ЭтотОбъект.КаналПривлеченияЗначение);
			СсылкаНовойЗаявки 					= Справочники.Заявки.ПолучитьСсылку(Новый УникальныйИдентификатор);
			ЭтотОбъект.ДополнительныеСвойства.Вставить("ЗаявкаСинхронизации", СсылкаНовойЗаявки);
			ЭтотОбъект.Заявка 					= СсылкаНовойЗаявки;				
		ИначеЕсли ЭтотОбъект.Ссылка.Пустая() И НЕ ЗначениеЗаполнено(ЭтотОбъект.Заявка) И ЗначениеЗаполнено(ЭтотОбъект.Контрагент) И ЭтотОбъект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда
			// Еще не искали. Поищем.
			ЗаявкаКлиента = Справочники.Заявки.ПолучитьЗаявкуКонтрагента(ЭтотОбъект.Контрагент, , ЭтотОбъект.СтруктурнаяЕдиница, Истина);
			
			Если НЕ ЗначениеЗаполнено(ЗаявкаКлиента) Тогда
				МассивНомеровТелефона = Справочники.Контрагенты.ПолучитьМассивНомеровТелефонаКонтрагента(ЭтотОбъект.Контрагент);
				ЗаявкаКлиента = Справочники.Заявки.ПолучитьЗаявкуПоНомеруТелефона(МассивНомеровТелефона, , ЭтотОбъект.СтруктурнаяЕдиница, Истина);	
			КонецЕсли;	
			
			Если НЕ ЗначениеЗаполнено(ЗаявкаКлиента) Тогда 
				Возврат;
			КонецЕсли;
			
			// Вроде бы наша заявка
			ЭтотОбъект.Заявка = ЗаявкаКлиента;
			ЭтотОбъект.ДополнительныеСвойства.Вставить("ЗаявкаСинхронизации", ЗаявкаКлиента);
		ИначеЕсли ЭтотОбъект.Ссылка.Пустая() И ЗначениеЗаполнено(ЭтотОбъект.Заявка) И ЗначениеЗаполнено(ЭтотОбъект.Контрагент) И ЭтотОбъект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
			ЭтотОбъект.ДополнительныеСвойства.Вставить("ЗаявкаСинхронизации", ЭтотОбъект.Заявка);
		КонецЕсли;	
		
		// Синхронизации проведена. Фиксируем результаты.		
	ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.ЗаявкаСинхронизации) И ОбщегоНазначения.СсылкаСуществует(ЭтотОбъект.ДополнительныеСвойства.ЗаявкаСинхронизации) Тогда
		// Если заявку нашли ранее обработчика "ПередЗаписью" и передали через доп. свойства
		Если ЭтотОбъект.Ссылка.Пустая() И НЕ ЗначениеЗаполнено(ЭтотОбъект.Заявка) Тогда 
			ЭтотОбъект.Заявка = ЭтотОбъект.ДополнительныеСвойства.ЗаявкаСинхронизации;
			Возврат;
		КонецЕсли;	
		ДанныеЗаявки = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЭтотОбъект.ДополнительныеСвойства.ЗаявкаСинхронизации, "Статус, СтруктурнаяЕдиница"); 
		Если НЕ ДанныеЗаявки.Статус = Перечисления.СтатусыЗаявок.Принята ИЛИ НЕ ДанныеЗаявки.СтруктурнаяЕдиница = ЭтотОбъект.СтруктурнаяЕдиница Тогда 
			ЗаявкаОбъект 					= ЭтотОбъект.ДополнительныеСвойства.ЗаявкаСинхронизации.ПолучитьОбъект();
			ЗаявкаОбъект.Статус 			= Перечисления.СтатусыЗаявок.Принята;
			ЗаявкаОбъект.ОсновнойКлиент 	= ЭтотОбъект.Контрагент;
			ЗаявкаОбъект.СтруктурнаяЕдиница = ЭтотОбъект.СтруктурнаяЕдиница;
			ЗаявкаОбъект.АктуализироватьНаименованиеОбращения(Истина);
			ОбсужденияСервер.ДобавитьСообщение("Статус: " + Строка(ЗаявкаОбъект.Ссылка.Статус) + " -> " + Строка(ЗаявкаОбъект.Статус) 
												+ Символы.ПС + "Сотрудник: " + Строка(ПараметрыСеанса.ТекущийСотрудник),ЗаявкаОбъект.Ссылка,, Истина);
			ЗаявкаОбъект.ОбменДанными.Загрузка = Истина;
			Попытка
				ЗаявкаОбъект.Записать();
 			Исключение
				ШаблонКомментария = НСтр("ru = 'Не удалось синхронизировать сделку с заявкой ""%1"". Ошибка при записи заявки
				|по причине: %2'");
				
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонКомментария,
				ЭтотОбъект.ДополнительныеСвойства.ЗаявкаСинхронизации,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				
				ЗаписьЖурналаРегистрации(
				"Сделки.Синхронизация сделки с заявкой",
				УровеньЖурналаРегистрации.Предупреждение,
				Метаданные.Справочники.Заявки,,
				Комментарий);
				
				//ВызватьИсключение;
			КонецПопытки;	
		КонецЕсли;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "НеобходимаГенерацияЗаявки", Ложь) И ДополнительныеСвойства.Свойство("ЗаявкаСинхронизации") И НЕ ОбщегоНазначения.СсылкаСуществует(ДополнительныеСвойства.ЗаявкаСинхронизации) Тогда	
		// Создаем заявку
		ДанныеЗаполнения = ЗначениеИзСтрокиВнутр(ЗначениеВСтрокуВнутр(ЭтотОбъект.ДополнительныеСвойства));
		ДанныеЗаполнения.Вставить("СсылкаНовойЗаявки"		, ДополнительныеСвойства.ЗаявкаСинхронизации);
		ДанныеЗаполнения.Вставить("Автор"					, ПараметрыСеанса.ТекущийСотрудник);
		ДанныеЗаполнения.Вставить("ДатаСоздания"			, ЭтотОбъект.ДатаСделки);
		ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"		, ЭтотОбъект.СтруктурнаяЕдиница);
		ДанныеЗаполнения.Вставить("ОсновнойКлиент"			, ЭтотОбъект.Контрагент);		
 		ДанныеЗаполнения.Вставить("РекламнаяПлощадка"		, ЭтотОбъект.КаналПривлечения);		
		ДанныеЗаполнения.Вставить("КаналПривлеченияЗначение", ЭтотОбъект.КаналПривлеченияЗначение);		
		ДанныеЗаполнения.Вставить("ОсновнойМенеджер"		, ?(ЗначениеЗаполнено(ЭтотОбъект.Менеджер), ЭтотОбъект.Менеджер, ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭтотОбъект.Контрагент, "Куратор")));
		ДанныеЗаполнения.Вставить("Статус"					, Перечисления.СтатусыЗаявок.Принята);		
		ДанныеЗаполнения.Вставить("ИнтерактивнаяЗапись"		, Истина);
		ДанныеЗаполнения.Вставить("СформироватьНаименование", Истина);		
		ДанныеЗаполнения.Вставить("ВходящийНомерТелефона"	, ЭтотОбъект.ВходящийНомерТелефона);
		
		НоваяЗаявка = Справочники.Заявки.СоздатьНовуюЗаявку(ДанныеЗаполнения, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Синхронизировать объект с задачей
//
Процедура СинхронизироватьОбъектСЗадачей()
	
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	СтатусКлиента = РегистрыСведений.СтатусыКонтрагентов.СтатусКонтрагента(Контрагент);
	Если СтатусКлиента <> Перечисления.СтатусыКонтрагентов.Потенциальный Тогда 
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Контрагент"			, Контрагент);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	Взаимодействие.Ссылка КАК Ссылка
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	|	И Взаимодействие.Выполнена = ЛОЖЬ
	|	И Взаимодействие.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Взаимодействие.Контрагент = &Контрагент
	|	И Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Взаимодействие.Дата УБЫВ";
	
	ВыборкаЗадачи = Запрос.Выполнить().Выбрать();
	Если ВыборкаЗадачи.Следующий() Тогда 
		Если ЗначениеЗаполнено(ВыборкаЗадачи.Ссылка) Тогда 
			Задача_Объект = ВыборкаЗадачи.Ссылка.ПолучитьОбъект();
			Задача_Объект.Сделка = Ссылка;
			Задача_Объект.ДополнительныеСвойства.Вставить("НеИнициализироватьСделку", Истина);
			Задача_Объект.ОбменДанными.Загрузка = Истина;
			Попытка
				Задача_Объект.Записать();
			Исключение
				
			КонецПопытки;	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, оповещает другие сеансы об изменении сделки.
//
Процедура ОповеститьСеансыОбИзмененииСделки(КлючОповещения)
	
	УстановитьПривилегированныйРежим(Истина);
	
	НомерТекущегоСеанса	 = НомерСеансаИнформационнойБазы();
	ТекущиеСеансы		 = ПолучитьСеансыИнформационнойБазы();
	
	// Если активен только один сеанс (текущий) - никого не оповещаем.
	Если ТекущиеСеансы.Количество() > 1 Тогда
		
		СистемаВзаимодействияПодключена = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена() = Истина;
		
		Если Не СистемаВзаимодействияПодключена Тогда
			
			ПараметрыОповещения = Новый Массив;
			ПараметрыОповещения.Добавить(ЭтотОбъект.Ссылка);
			ПараметрыОповещения.Добавить(ЭтотОбъект.ВидСделки);
			
		КонецЕсли;
		
		ПользователиОповещения = Новый Массив;
		
		Для Каждого Сеанс Из ТекущиеСеансы Цикл
			
			Если (Сеанс.ИмяПриложения = "1CV8C"
				Или Сеанс.ИмяПриложения = "WebClient") Тогда
				
				Если НомерТекущегоСеанса = Сеанс.НомерСеанса Тогда
					// Текущий сеанс оповещаем с клиента.
					Продолжить;
				КонецЕсли;
				
				Если СистемаВзаимодействияПодключена Тогда
					ПользователиОповещения.Добавить(Сеанс.Пользователь);
				Иначе
					РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(
						Сеанс.НомерСеанса,,
						КлючОповещения,
						ТекущаяДатаСеанса(),,,,
						ПараметрыОповещения
					);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если СистемаВзаимодействияПодключена И ЗначениеЗаполнено(ПользователиОповещения) Тогда
			
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("Ключ"		, КлючОповещения);
			ДанныеСообщения.Вставить("Сделка"	, ЭтотОбъект.Ссылка);
			ДанныеСообщения.Вставить("ВидСделки", ?(ЗначениеЗаполнено(ЭтотОбъект.ВидСделки), ЭтотОбъект.ВидСделки, Неопределено));
			
			ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
