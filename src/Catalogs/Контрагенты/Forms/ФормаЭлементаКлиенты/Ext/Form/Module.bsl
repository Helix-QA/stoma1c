// Функция, возвращает цвета бизнес процессов.
//
Функция ПолучитьСоответствиеЦветовИСтатусовКлиентов()
	
	СоответствиеЦветовИСтатусовКлиентов = Новый Соответствие();                                                           
	СоответствиеЦветовИСтатусовКлиентов.Вставить(Перечисления.СтатусыКонтрагентов.Потенциальный	, Новый Цвет(3  , 156, 253)); // Голубой
	СоответствиеЦветовИСтатусовКлиентов.Вставить(Перечисления.СтатусыКонтрагентов.Первичный    	, Новый Цвет(0  , 112, 210)); // Синий
	СоответствиеЦветовИСтатусовКлиентов.Вставить(Перечисления.СтатусыКонтрагентов.Постоянный   	, Новый Цвет(136, 191, 136)); // Зеленый
	СоответствиеЦветовИСтатусовКлиентов.Вставить(Перечисления.СтатусыКонтрагентов.НеВернувшийся	, Новый Цвет(152, 59 , 69));  // Бордовый
	СоответствиеЦветовИСтатусовКлиентов.Вставить(Перечисления.СтатусыКонтрагентов.Отказ     	, Новый Цвет(255, 0  , 0));
	
	СоответствиеЦветовИСтатусовКлиентов.Вставить(Перечисления.СтатусыКонтрагентов.ПустаяСсылка(), Новый Цвет());
		
	Возврат СоответствиеЦветовИСтатусовКлиентов;
		
КонецФункции

