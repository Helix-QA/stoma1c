// Функция проверяет наличие бонусов не начисляемых при наличии скидок.
//
Функция ЕстьБонусыНеНачисляемыеПриНаличииСкидки(ТаблицаСкидок)
	
	Для Каждого СтрокаТЗ Из ТаблицаСкидок Цикл
		Если ЗначениеЗаполнено(СтрокаТЗ.СкидкаНаценка)
			И НЕ СтрокаТЗ.СкидкаНаценка.ЭтоГруппа
			И СтрокаТЗ.СкидкаНаценка.НачислениеБонусами
			И СтрокаТЗ.СкидкаНаценка.НеНачислятьБонусПриНаличииСкидки Тогда
			
			Возврат Истина;
		КонецЕсли;		
	КонецЦикла;
	
	Возврат Ложь;  	
		
КонецФункции

// Предварительно применяем скидку в строках ТЧ номенклатуры.
//
Процедура ПредварительноПрименитьСкидкиВТаблицеТоваров(
	ТаблицаСкидокВременная,
	ТаблицаЗапасы, 
	ТаблицаЛечение,
	ТаблицаУслуги,
	ТаблицаПредыдщееСостояниеСкидок)
	
	Если ТаблицаЗапасы <> Неопределено Тогда
		// Применяем скидку в строках ТЧ номенклатуры
		Для Каждого СтрокаТЧ Из ТаблицаЗапасы Цикл
			
			СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
			СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;
			
			// Скидки
			ТаблицаСкидокВременнаяПоСтроке = ТаблицаСкидокВременная.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, НачислениеБонусами, Использовать", СтрокаТЧ.КлючСтроки, Ложь, Ложь, Истина));
			Для каждого СтрокаТЗСкидок Из ТаблицаСкидокВременнаяПоСтроке Цикл
				СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
				СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;
				
				Если СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение = Истина Тогда // Значит могут быть выклчены или не вклчены
					
					Если ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0 // Эта скидка была раньше, значит берем ее состояние, если использование = ложь, пропускаем
