КонецФункции

#Область Comagic

// Функция, получает вебхуки с сервиса CoMagic.
//
Функция CoMagic_v2POST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВыполненоУспешно		= Истина;
	ВремяОкончанияОперации	= Неопределено;
	ОписаниеДляЛогирования	= ""; 
	ТранзакцияНачата		= Ложь;
	
	Попытка
		
		ТекстJSON     = Запрос.ПолучитьТелоКакСтроку();
		ЧтениеJSON    = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);
		
		ApiKey         = Сред(Запрос.ОтносительныйURL, 13, СтрДлина(Запрос.ОтносительныйURL));
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(ApiKey, Перечисления.ТипыВнешнихСистем.CoMagic);
		
		// Логирование
		ЗначениеКонстантыЛогироватьСобытие = Константы.ЛогироватьHTTP.Получить();
		ЛогироватьСобытие = (ЗначениеКонстантыЛогироватьСобытие > 0);	
		ВремяНачалаОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		Если ЛогироватьСобытие Тогда			
			UIDЗапроса     = Новый УникальныйИдентификатор();
			HTTPЗапросЛога = Запрос;
			ДатаЛога       = ТекущаяДатаСеанса();
			ТипЗапроса     = Перечисления.HTTPСервисы.Analytics;
			HTTPШаблон     = "CoMagic_v2";
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ВнешняяСистема) Тогда
			Возврат Новый HTTPСервисОтвет(500);
		КонецЕсли;
		
		Метод = ?(ПараметрыJSON.Свойство("method"), ПараметрыJSON.method, Неопределено); 
		
		Если ЗначениеЗаполнено(Метод) Тогда
			
			// Проверка валидности ключа приложения.
			Если Метод = "key_validity" Тогда
				
				ЗначениеВозврата = Новый HTTPСервисОтвет(200);
				
				ВремяОкончанияОперации	= ТекущаяУниверсальнаяДатаВМиллисекундах();					
				ВремяВыполнения			= (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
				СтатусСобытия			= Перечисления.СтатусыЗапросов.Выполнен;	 
				КодВозврата				= 200;
				
				ЛогироватьСобытие	= ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЗначениеКонстантыЛогироватьСобытие, СтатусСобытия, ВремяВыполнения);
							
			// Получение ключа Api.	
			ИначеЕсли Метод = "set_dataapi_key" Тогда
				
				dataapi_key = ?(ПараметрыJSON.Свойство("dataapi_key"), ПараметрыJSON.dataapi_key, Неопределено); 
				
				Если Не ЗначениеЗаполнено(dataapi_key) Тогда
					
					ЗначениеВозврата = Новый HTTPСервисОтвет(400, "Не заполнено значение dataapi");
					
					Если ЛогироватьСобытие Тогда						
						СтатусСобытия			= Перечисления.СтатусыЗапросов.ЗавершенСОшибками;						
						ОписаниеДляЛогирования	= ЗначениеВозврата.ПолучитьТелоКакСтроку();
						КодОтвета				= 400;													
					КонецЕсли;
					
				Иначе
					
					// Записываем ключ api во внешнюю систему.
					ОбъектВнешнейСистемы    = ВнешняяСистема.ПолучитьОбъект();	
					
					Если НЕ ОбъектВнешнейСистемы = Неопределено Тогда	
						
						ПараметрыВнешнейСистемы = ОбъектВнешнейСистемы.Параметры.Получить();
						
						Если НЕ ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура") Тогда
							ПараметрыВнешнейСистемы = Новый Структура;
						КонецЕсли;	
						
						Если ПараметрыВнешнейСистемы.Свойство("Токен") Тогда           
							ПараметрыВнешнейСистемы.Токен = dataapi_key;
						Иначе
							ПараметрыВнешнейСистемы.Вставить("Токен", dataapi_key);
						КонецЕсли;
						
						ОбъектВнешнейСистемы.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы); 
						
						Попытка
							ОбъектВнешнейСистемы.Записать();
						Исключение
							ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Ошибка записи внешней системы при выполнении метода Comagic dataapi_key."
																					, УровеньЖурналаРегистрации.Ошибка,
																					, ВнешняяСистема
																					, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
						КонецПопытки;
						
						КодОтвета			= 200;
						ЗначениеВозврата	= Новый HTTPСервисОтвет(200);
						СтатусСобытия		= Перечисления.СтатусыЗапросов.Выполнен;
						
					Иначе
						
						КодОтвета			= 500;
						ЗначениеВозврата	= Новый HTTPСервисОтвет(500, "Ошибка записи внешней системы.");
						СтатусСобытия		= Перечисления.СтатусыЗапросов.ОшибкаВнешнейСистемы;
						
					КонецЕсли;
					
					ВремяОкончанияОперации	= ТекущаяУниверсальнаяДатаВМиллисекундах();
					ВремяВыполнения			= (ВремяОкончанияОперации - ВремяНачалаОперации)/1000; 
					ЛогироватьСобытие		= ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЗначениеКонстантыЛогироватьСобытие, СтатусСобытия, ВремяВыполнения);
					
				КонецЕсли;
				
			Иначе
				
				ЗначениеВозврата = Новый HTTPСервисОтвет(400, "Не заполнено значение метода.");
				
				Если ЛогироватьСобытие Тогда					
					СтатусСобытия			= Перечисления.СтатусыЗапросов.ЗавершенСОшибками;						
					ОписаниеДляЛогирования	= ЗначениеВозврата.ПолучитьТелоКакСтроку();
					КодОтвета				= 400;													
				КонецЕсли;
				
			КонецЕсли;
						
		Иначе
			
			communication_id  	= ?(ПараметрыJSON.Свойство("communication_id"), ПараметрыJSON.communication_id, Неопределено);
			communication_type	= ?(ПараметрыJSON.Свойство("communication_type"), ПараметрыJSON.communication_type	, Неопределено);
			НомерТелефона 	  	= ?(ПараметрыJSON.Свойство("phone"), ПараметрыJSON.phone, Неопределено);
			НомерТелефона 	  	= ?(Не ЗначениеЗаполнено(НомерТелефона) И ПараметрыJSON.Свойство("visitor_phone_number"), ПараметрыJSON.visitor_phone_number, НомерТелефона);
			АдресЭП        	  	= ?(ПараметрыJSON.Свойство("email"), ПараметрыJSON.email, Неопределено);
			АдресЭП        	  	= ?(Не ЗначениеЗаполнено(АдресЭП) И ПараметрыJSON.Свойство("visitor_email"), ПараметрыJSON.visitor_email, АдресЭП);
			НаправлениеЗвонка 	= ?(ПараметрыJSON.Свойство("direction"), ПараметрыJSON.direction, Неопределено);
			
			Если Не ЗначениеЗаполнено(communication_id) Тогда
				Возврат Новый HTTPСервисОтвет(400, "Не заполнен communication_id");
			КонецЕсли;
			
			Если ЗначениеЗаполнено(НаправлениеЗвонка) И НаправлениеЗвонка = "out" Тогда
				Возврат Новый HTTPСервисОтвет(200, "Исходящий звонок");
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(НомерТелефона) И Не ЗначениеЗаполнено(АдресЭП) Тогда
				Возврат Новый HTTPСервисОтвет(400, "Не заполнен номер телефона и адрес электронной почты");
			КонецЕсли;
			
			Клиент = Неопределено;
			Заявка = Неопределено;
			
			Если ЗначениеЗаполнено(НомерТелефона) Тогда
				Клиент = Справочники.Контрагенты.ПолучитьКонтрагентаПоНомеруТелефона(НомерТелефона);
				Если Не ЗначениеЗаполнено(Клиент) Тогда
					Заявка = ПолучитьЗаявкуПоНомеруТелефона(НомерТелефона);
				КонецЕсли;	
			КонецЕсли;
			
			communication_type = ПолучитьТипОбращения(communication_type);
			КаналПривлечения   = ПолучитьКаналПривлечения(communication_type);
			
			Если (Не ЗначениеЗаполнено(Клиент) И Не ЗначениеЗаполнено(Заявка)) ИЛИ КаналПривлечения = Справочники.КаналыПривлечения.ЛидФорма Тогда
				
				campaign_name			= ?(ПараметрыJSON.Свойство("campaign_name")		, ПараметрыJSON.campaign_name		, Неопределено);
				ИмяСобытия				= ?(ПараметрыJSON.Свойство("notification_name")	, ПараметрыJSON.notification_name	, Неопределено);
				ВремяСозданияСтрокой	= ?(ПараметрыJSON.Свойство("notification_time")	, ПараметрыJSON.notification_time	, Неопределено);
				ДоменноеИмя				= ?(ПараметрыJSON.Свойство("site_domain_name")	, ПараметрыJSON.site_domain_name	, Неопределено);
				ИмяКлиента				= ?(ПараметрыJSON.Свойство("name")				, ПараметрыJSON.name				, Неопределено);
				ФамилияКлиента			= ?(ПараметрыJSON.Свойство("last_name")			, ПараметрыJSON.last_name			, Неопределено);
				МассивСообщений			= ?(ПараметрыJSON.Свойство("messages")			, ПараметрыJSON.messages			, Неопределено);
				Сообщение				= ?(ПараметрыJSON.Свойство("message")			, ПараметрыJSON.message				, Неопределено);					
				utm_campaign			= ?(ПараметрыJSON.Свойство("utm_campaign")		, ПараметрыJSON.utm_campaign		, Неопределено);
				utm_content				= ?(ПараметрыJSON.Свойство("utm_content")		, ПараметрыJSON.utm_content			, Неопределено);
				utm_medium				= ?(ПараметрыJSON.Свойство("utm_medium")		, ПараметрыJSON.utm_medium			, Неопределено);
				utm_source				= ?(ПараметрыJSON.Свойство("utm_source")		, ПараметрыJSON.utm_source			, Неопределено);
				eq_utm_source			= ?(ПараметрыJSON.Свойство("eq_utm_source")		, ПараметрыJSON.eq_utm_source		, Неопределено);
				utm_term				= ?(ПараметрыJSON.Свойство("utm_term")			, ПараметрыJSON.utm_term			, Неопределено);
								
				Если ТипЗнч(communication_id) = Тип("Число") Тогда
					communication_id = Формат(communication_id, "ЧГ=");	
				КонецЕсли;
				
				НачатьТранзакцию();
				ТранзакцияНачата = Истина;
				
				УстановитьБлокировку("Справочник.Заявки", "communication_id", communication_id);

				Если Не ЗначениеЗаполнено(ИмяКлиента) Тогда
					ИмяКлиента = ?(ЗначениеЗаполнено(НомерТелефона), НомерТелефона, АдресЭП);
				КонецЕсли;	
				
				ПараметрыВС = ВнешняяСистема.Параметры.Получить();
				Если ТипЗнч(ПараметрыВС) = Тип("Структура") И ЗначениеЗаполнено(ПараметрыВС) И ПараметрыВС.Свойство("МассивСтруктурныхЕдиниц") Тогда			
					МассивСтруктурныхЕдиниц = ПараметрыВС.МассивСтруктурныхЕдиниц;			
				КонецЕсли;	
				
				СтруктурнаяЕдиница = Неопределено;
				
				Если ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) И ТипЗнч(МассивСтруктурныхЕдиниц) = Тип("Массив") И ЗначениеЗаполнено(ДоменноеИмя) Тогда
					
					Для Каждого ЭлементМ Из МассивСтруктурныхЕдиниц Цикл
						
						Если ДоменноеИмя = ЭлементМ.ДоменноеИмя Тогда
							СтруктурнаяЕдиница = ЭлементМ.СтруктурнаяЕдиница;
							Прервать;
						КонецЕсли;
						
					КонецЦикла;	
					
				КонецЕсли;	
				
				Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
					СтруктурнаяЕдиница = ВнешняяСистема.СтруктурнаяЕдиница;
				КонецЕсли;	
				
				ВремяСоздания = ПолучитьДатуИзСтрокиCoMagic(ВремяСозданияСтрокой);
				
				ПараметрыUTM = Новый Структура();
				ПараметрыUTM.Вставить("source", ?(ЗначениеЗаполнено(eq_utm_source), eq_utm_source, utm_source));
				ПараметрыUTM.Вставить("medium", utm_medium);
				ПараметрыUTM.Вставить("campaign", utm_campaign);
				ПараметрыUTM.Вставить("content", utm_content);
				ПараметрыUTM.Вставить("term", utm_term);
				
				Комментарий = "" + ИмяСобытия + ?(ЗначениеЗаполнено(Сообщение), ?(ЗначениеЗаполнено(ИмяСобытия), Символы.ПС, "") + Сообщение, "");
				
				РекламныйИсточникПоМеткамUTM = Справочники.РекламныеИсточники.ПолучитьРекламныйИсточникПоПараметрамЗаявки(ПараметрыUTM);
				Если РекламныйИсточникПоМеткамUTM = Неопределено Тогда
					РекламныйИсточник = Справочники.РекламныеИсточники.ПолучитьРекламныйИсточник(?(ЗначениеЗаполнено(campaign_name), campaign_name, utm_source), Истина);
				Иначе
					РекламныйИсточник = РекламныйИсточникПоМеткамUTM;
				КонецЕсли;
				
				ЗаявкаCoMagic = ПолучитьЗаявкуКлиентаComagic(communication_id);
				
				Если ЗаявкаCoMagic <> Неопределено Тогда
					
					ЗаявкаОбъект					= ЗаявкаCoMagic.ПолучитьОбъект();					
					ЗаявкаОбъект.utm_source   		= ?(ЗначениеЗаполнено(ПараметрыUTM.source) И Не ЗначениеЗаполнено(ЗаявкаОбъект.utm_source)		, ПараметрыUTM.source	, ЗаявкаОбъект.utm_source);
					ЗаявкаОбъект.utm_medium   		= ?(ЗначениеЗаполнено(ПараметрыUTM.medium) И Не ЗначениеЗаполнено(ЗаявкаОбъект.utm_medium)		, ПараметрыUTM.medium  	, ЗаявкаОбъект.utm_medium);
					ЗаявкаОбъект.utm_campaign 		= ?(ЗначениеЗаполнено(ПараметрыUTM.campaign) И Не ЗначениеЗаполнено(ЗаявкаОбъект.utm_campaign)	, ПараметрыUTM.campaign	, ЗаявкаОбъект.utm_campaign);
					ЗаявкаОбъект.utm_content  		= ?(ЗначениеЗаполнено(ПараметрыUTM.content) И Не ЗначениеЗаполнено(ЗаявкаОбъект.utm_content)	, ПараметрыUTM.content 	, ЗаявкаОбъект.utm_content);
					ЗаявкаОбъект.utm_term     		= ?(ЗначениеЗаполнено(ПараметрыUTM.term) И Не ЗначениеЗаполнено(ЗаявкаОбъект.utm_term)			, ПараметрыUTM.term    	, ЗаявкаОбъект.utm_term);
					ЗаявкаОбъект.РекламныйИсточник	= ?(ЗначениеЗаполнено(РекламныйИсточник) И Не ЗначениеЗаполнено(ЗаявкаОбъект.РекламныйИсточник)	, РекламныйИсточник		, ЗаявкаОбъект.РекламныйИсточник);
					
					Попытка
						ЗаявкаОбъект.Записать();
						ЗафиксироватьТранзакцию();
						ОписаниеОтвета = "Заявка с таким communication_id обновлена.";
					Исключение
						ОтменитьТранзакцию();
						ОписаниеОтвета = СтрШаблон("Не удалось обновить заявку по причине %1", ОписаниеОшибки());
					КонецПопытки;
					
					Возврат Новый HTTPСервисОтвет(200, ОписаниеОтвета);
					
				КонецЕсли;
				
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ОнлайнЗаявка", Истина);
				
				// Создаем входящую заявку.
				Заявка = Справочники.Заявки.СоздатьВходящуюЗаявку(
				communication_id,
				communication_type,
				ВремяСоздания,,
				ИмяКлиента,
				ФамилияКлиента,
				НомерТелефона,
				АдресЭП,
				РекламныйИсточник,
				КаналПривлечения,,
				Комментарий,
				ПараметрыUTM,
				ВнешняяСистема,,
				Клиент,
				СтруктурнаяЕдиница,,
				ДополнительныеПараметры);
				
			КонецЕсли;		
			
			КодОтвета				= 200;
			ВремяОкончанияОперации	= ТекущаяУниверсальнаяДатаВМиллисекундах();
			ВремяВыполнения			= (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
			СтатусСобытия			= Перечисления.СтатусыЗапросов.Выполнен;	
			
			ЛогироватьСобытие		= ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЗначениеКонстантыЛогироватьСобытие, СтатусСобытия, ВремяВыполнения);
			
			ЗначениеВозврата		= Новый HTTPСервисОтвет(200);
			
		КонецЕсли;
		
	Исключение
		
		ВыполненоУспешно		= Ложь;		
		КодОтвета				= 400;
		СтатусСобытия			= Перечисления.СтатусыЗапросов.ЗавершенСОшибками;		
		ОписаниеДляЛогирования	= ОписаниеОшибки();
		
		ЗначениеВозврата		= Новый HTTPСервисОтвет(400, ОписаниеДляЛогирования);
		
	КонецПопытки;
	
	// Логирование.
	Если ЛогироватьСобытие Тогда
		
		ВремяОкончанияОперации = ?(ЗначениеЗаполнено(ВремяОкончанияОперации), ВремяОкончанияОперации, ТекущаяУниверсальнаяДатаВМиллисекундах());
		ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
		
		РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
		HTTPЗапросЛога, 
		ДатаЛога, 
		UIDЗапроса, 
		ТипЗапроса, 
		HTTPШаблон, 
		СтатусСобытия, 
		ВремяВыполнения, 
		ВнешняяСистема, 
		ApiKey, 
		ОписаниеДляЛогирования, 
		, 
		,
		КодОтвета); 								
		
	КонецЕсли;
	
	Если ТранзакцияНачата Тогда
		Если ВыполненоУспешно Тогда
			ЗафиксироватьТранзакцию();
		Иначе
			ОтменитьТранзакцию();
		КонецЕсли;
	КонецЕсли;

	Возврат ЗначениеВозврата;
	
КонецФункции

// Функция, возвращает Истина если заявка с таким номером телефона уже существует.
//
Функция ПолучитьЗаявкуПоНомеруТелефона(Знач НомерТелефона)
	
	МассивНомеровТелефонов = Новый Массив;
	МассивНомеровТелефонов.Добавить(НомерТелефона);
	НомерБезПлюса = СтрЗаменить(НомерТелефона, "+", "");
	МассивНомеровТелефонов.Добавить(НомерБезПлюса);
	МассивНомеровТелефонов.Добавить("7" + Сред(НомерБезПлюса, 2));
	МассивНомеровТелефонов.Добавить("8" + Сред(НомерБезПлюса, 2));
	МассивНомеровТелефонов.Добавить("+7" + Сред(НомерБезПлюса, 2));
	МассивНомеровТелефонов.Добавить("+8" + Сред(НомерБезПлюса, 2));
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЗаявкиКонтактнаяИнформация.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Заявки.КонтактнаяИнформация КАК ЗаявкиКонтактнаяИнформация
	|ГДЕ
	|	НЕ ЗаявкиКонтактнаяИнформация.Ссылка.ПометкаУдаления
	|	И ЗаявкиКонтактнаяИнформация.Ссылка.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.CoMagic)
	|	И ЗаявкиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|	И (ЗаявкиКонтактнаяИнформация.НомерТелефона В (&МассивНомеровТелефонов)
	|			ИЛИ ВЫРАЗИТЬ(ЗаявкиКонтактнаяИнформация.Представление КАК СТРОКА(200)) В (&МассивНомеровТелефонов))";
	
	Запрос.УстановитьПараметр("МассивНомеровТелефонов", МассивНомеровТелефонов);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Возврат ?(РезультатЗапроса.Следующий(), РезультатЗапроса.Ссылка, Справочники.Заявки.ПустаяСсылка());
	
КонецФункции

// Фукнция, возвращает тип обращения CoMajic
//
Функция ПолучитьТипОбращения(communication_type)
	
	ТипОбращения = Перечисления.ТипыОбращенийCoMagic.ПустаяСсылка();
	
	Если communication_type = "call" Тогда 
		ТипОбращения = Перечисления.ТипыОбращенийCoMagic.call;
	ИначеЕсли communication_type = "chat" Тогда 
		ТипОбращения = Перечисления.ТипыОбращенийCoMagic.chat;	
	ИначеЕсли communication_type = "goal" Тогда 
		ТипОбращения = Перечисления.ТипыОбращенийCoMagic.goal;	
	ИначеЕсли communication_type = "offline_message" Тогда 
		ТипОбращения = Перечисления.ТипыОбращенийCoMagic.offline_message;	
	КонецЕсли;	
	
	Возврат ТипОбращения;
	
КонецФункции

// Функция, возвращает канал привлечения.
//
Функция ПолучитьКаналПривлечения(ТипОбращения)
	
	КаналПривлечения = Перечисления.ТипыОбращенийCoMagic.ПустаяСсылка();
	
	Если ТипОбращения = Перечисления.ТипыОбращенийCoMagic.call Тогда 
		КаналПривлечения = Справочники.КаналыПривлечения.ВходящийЗвонок;
	ИначеЕсли ТипОбращения = Перечисления.ТипыОбращенийCoMagic.chat Тогда 
		КаналПривлечения = Справочники.КаналыПривлечения.ЧатСКлиентом;	
	ИначеЕсли ТипОбращения = Перечисления.ТипыОбращенийCoMagic.goal Тогда 
		КаналПривлечения = Справочники.КаналыПривлечения.ЛовецЛидов;	
	ИначеЕсли ТипОбращения = Перечисления.ТипыОбращенийCoMagic.offline_message Тогда 
		КаналПривлечения = Справочники.КаналыПривлечения.ЛидФорма;	
	КонецЕсли;	
	
	Возврат КаналПривлечения;
	
КонецФункции	

// Функция, возвращает заявку клиента CoMagic.
//
Функция ПолучитьЗаявкуКлиентаComagic(communication_id)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Заявки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	НЕ Заявки.ПометкаУдаления
	|	И Заявки.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.CoMagic)
	|	И Заявки.communication_id = &communication_id");
	
	Запрос.УстановитьПараметр("communication_id" , communication_id);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

#КонецОбласти

// Процедура, устанавливает блокировку.
Процедура УстановитьБлокировку(БлокируемыйДокумент, РеквизитБлокировки, ЗначениеРеквизита)
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(БлокируемыйДокумент);
	ЭлементБлокировки.УстановитьЗначение(РеквизитБлокировки, ЗначениеРеквизита);
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	Блокировка.Заблокировать();
	
КонецПроцедуры

#КонецОбласти
