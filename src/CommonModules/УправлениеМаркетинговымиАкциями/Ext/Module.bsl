
#Область СлужебныйПрограммныйИнтерфейс

// Процедура рассчитывает скидки в документе.
//
// Параметры:
//  ДокументОбъект             - документ, для которого рассчитываем скидки,
//  ТабличнаяЧастьНоменклатуры - табличная часть номенклатуры документа,
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  СтруктураПараметров        - структура, содержащая дополнительные параметря, необходимые для расчета скидок.
//
Процедура РассчитатьСкидкиПриПродаже(
	ДокументОбъект,
	ИмяТабличнойЧастиЗапасы			= Неопределено, 
	ИмяТабличнойЧастиЛечение		= Неопределено, 
	ИмяТабличнойЧастиУслуги			= Неопределено, 
	ИмяТЧСкидки,
	ИмяТЧПодарки,
	ТаблицаОплатыБонусами			= Неопределено, 
	ТаблицаПредыдщееСостояниеСкидок = Неопределено,
	СтруктураПараметров) Экспорт

	Перем ДатаСкидок;
	Перем ТаблицаСкидокЗаменяемая;
	
	Если СтруктураПараметров = Неопределено Тогда
		СтруктураПараметров = Новый Структура;
	КонецЕсли;
	
	ЭтоНарядЗаказ = СтруктураПараметров.Свойство("ЭтоНарядЗаказ");
	
	Если Не ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы)
		И Не ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение)
		И Не ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) Тогда
		
		Возврат;
	КонецЕсли;	

	// не пересчитываем автоматические скидки в документах, которые были ранее оплачены
	Если НЕ СтруктураПараметров.Свойство("ОплатаБонуснымСчетом")
		И ДокументОбъект.Метаданные().Реквизиты.Найти("СуммаОплачено") <> Неопределено
		И ДокументОбъект.СуммаОплачено <> 0 Тогда 
		
		// Возврат;
	КонецЕсли;
		
	// Подготовка дополнительных параметров
	Если СтруктураПараметров.Свойство("ДатаСкидок") = Ложь Тогда
		Если ЗначениеЗаполнено(ДокументОбъект.Дата) Тогда
			СтруктураПараметров.Вставить("ДатаСкидок", ДокументОбъект.Дата);
		Иначе
			СтруктураПараметров.Вставить("ДатаСкидок", ТекущаяДатаСеанса());
		КонецЕсли;
	КонецЕсли;    
	
	Если СтруктураПараметров.Свойство("ДатаСкидок") 
		И СтруктураПараметров.ДатаСкидок > ДокументОбъект.Дата Тогда
		
		СтруктураПараметров.ДатаСкидок = ДокументОбъект.Дата;
		
	КонецЕсли;
	
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("СтруктурнаяЕдиница", МетаданныеДокумента) Тогда
		СтруктурнаяЕдиница = ДокументОбъект.СтруктурнаяЕдиница;
	ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Касса", МетаданныеДокумента) Тогда
		СтруктурнаяЕдиница = ДокументОбъект.Касса.СтруктурнаяЕдиница;
	ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Склад", МетаданныеДокумента) Тогда
		СтруктурнаяЕдиница = ДокументОбъект.Склад.СтруктурнаяЕдиница;
	КонецЕсли;

	СтруктураПараметров.Вставить("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);	
	СтруктураПараметров.Вставить("Организация"			, Справочники.Организации.ПустаяСсылка());
	
	МассивНеИспользуемыхСкидок = Новый Массив;
	Если ИмяТЧСкидки <> "" Тогда
		Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТЧСкидки] Цикл 
			Если СтрокаТЧ.Использование = Ложь Тогда 
				МассивНеИспользуемыхСкидок.Добавить(СтрокаТЧ.СкидкаНаценка);
			КонецЕсли;	
		КонецЦикла;
	КонецЕсли;
	
	СтруктураПараметров.Вставить("МассивНеиспользуемыхСкидок", МассивНеИспользуемыхСкидок);

	// Подготовка ТЧ объекта
	Если ИмяТЧСкидки <> "" Тогда
		ДокументОбъект[ИмяТЧСкидки].Очистить();
	КонецЕсли;
	
	Если ИмяТЧПодарки <> "" Тогда
		ДокументОбъект[ИмяТЧПодарки].Очистить();
	КонецЕсли;

	Если ТаблицаПредыдщееСостояниеСкидок = Неопределено Тогда
		ТаблицаПредыдщееСостояниеСкидок = Новый ТаблицаЗначений;
		ТаблицаПредыдщееСостояниеСкидок.Колонки.Добавить("КлючСтроки"	, Новый ОписаниеТипов("УникальныйИдентификатор"));
		ТаблицаПредыдщееСостояниеСкидок.Колонки.Добавить("Использование", Новый ОписаниеТипов("Булево"));
		ТаблицаПредыдщееСостояниеСкидок.Колонки.Добавить("СкидкаНаценка", Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
		ТаблицаПредыдщееСостояниеСкидок.Колонки.Добавить("Номенклатура" , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	КонецЕсли;

	Если ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) Тогда
		Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТабличнойЧастиЗапасы] Цикл
			
			СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
			СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;
			СтрокаТЧ.Сумма								= СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок;
			СтрокаТЧ.Всего								= СтрокаТЧ.Сумма; 
			
			Если ЭтоНарядЗаказ = Истина Тогда
				СтрокаТЧ.СуммаПродажи					= СтрокаТЧ.ЦенаПродажи * СтрокаТЧ.КоличествоУпаковок;
				СтрокаТЧ.ВсегоПродажи					= СтрокаТЧ.СуммаПродажи; 	
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение) Тогда
		ЕстьКоличествоУпаковокВТЧЛечение = ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("КоличествоУпаковок") <> Неопределено;
		Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТабличнойЧастиЛечение] Цикл
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "Рекламация") 
				И ЗначениеЗаполнено(СтрокаТЧ.Рекламация) Тогда
				Продолжить;
			КонецЕсли; 
			
			СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
			СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;
			СтрокаТЧ.Сумма								= СтрокаТЧ.Цена * ?(ЕстьКоличествоУпаковокВТЧЛечение = Истина, СтрокаТЧ.КоличествоУпаковок, СтрокаТЧ.Количество);
			СтрокаТЧ.Всего								= СтрокаТЧ.Сумма;
		КонецЦикла;
	КонецЕсли;

	Если ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) Тогда
		Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТабличнойЧастиУслуги] Цикл
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "Рекламация") 
				И ЗначениеЗаполнено(СтрокаТЧ.Рекламация) Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаТЧ.ПроцентСкидкиНаценки				= 0;
			СтрокаТЧ.СуммаАвтоматическойСкидкиНаценки	= 0;
			СтрокаТЧ.Сумма								= СтрокаТЧ.Цена * СтрокаТЧ.КоличествоУпаковок;
			СтрокаТЧ.Всего								= СтрокаТЧ.Сумма;
		КонецЦикла;
	КонецЕсли;
	
	РазрешитьСкидки = ВернутьПризнакДоступностиСкидок(ДокументОбъект);
	Если РазрешитьСкидки = Ложь Тогда 	
		Если ИмяТЧСкидки <> "" Тогда
			ДокументОбъект[ИмяТЧСкидки].Очистить();
		КонецЕсли;
		Возврат;
	КонецЕсли;

	// Получаем действующие применяемые скидки
	ТаблицаСкидок = ЗапросПоСкидкам(
			ДокументОбъект,
			?(ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) , ДокументОбъект[ИмяТабличнойЧастиЗапасы] , Неопределено),
			?(ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение), ДокументОбъект[ИмяТабличнойЧастиЛечение], Неопределено),
			?(ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) , ДокументОбъект[ИмяТабличнойЧастиУслуги] , Неопределено),
			СтруктураПараметров,
			ТаблицаОплатыБонусами);
			
	// Расчитываем сумму скидки и заполняем нову цену по номенклатуре
	РасчитатьСуммуСкидкиИНовыеЦеныНоменклатурыНаСкидкиПоВидуЦен(ТаблицаСкидок, СтруктураПараметров);
	
	// Высчитываем сумму скидки назначенну суммой или процентом (!!! ориентировочно, далее вытеснением сумма может измениться если вид умножение или превышенна граница скидки)
	РаспределитьСкидкуСуммойПроцентомПоНоменклатуре(ТаблицаСкидок, СтруктураПараметров);

	// Высчитываем сумму скидки на документ по позиции номенклатуры
	РаспределитьСкидкуНаДокументПоНоменклатуре(
		ТаблицаСкидок, 
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) , ДокументОбъект[ИмяТабличнойЧастиЗапасы] , Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение), ДокументОбъект[ИмяТабличнойЧастиЛечение], Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) , ДокументОбъект[ИмяТабличнойЧастиУслуги] , Неопределено),
		СтруктураПараметров);

	// Высчитываем количество подарков, их стоимость и удаляем те, на которых комплект не полный.
	ОпределитьКоличествоСтоимостьПодарков(
		ТаблицаСкидок, 
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) , ДокументОбъект[ИмяТабличнойЧастиЗапасы] , Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение), ДокументОбъект[ИмяТабличнойЧастиЛечение], Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) , ДокументОбъект[ИмяТабличнойЧастиУслуги] , Неопределено),
		СтруктураПараметров,
		ДокументОбъект);	

	// Высчитываем количество выдачи карт, их стоимость и удаляем те, на которых комплект не полный.
	ОпределитьКоличествоВыдачиКарт(ТаблицаСкидок, СтруктураПараметров);	
	
	// Дополняем массив неиспользуемых скидок, которые по умолчанию отключены
	Если ИмяТЧСкидки <> "" Тогда
		Для каждого СтрокаТЗСкидок Из ТаблицаСкидок Цикл
			
			Если СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение = Истина Тогда // Значит могут быть выклчены или не вклчены
				
				Если ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0 // Эта скидка была раньше, значит берем ее состояние, если использование = ложь, пропускаем
					И ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, Использование, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, Ложь, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0
					ИЛИ ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() = 0
					И СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеВыклПоУмолчанию = Истина Тогда // Ранее не использовалась, 
					
					СтрокаТЗСкидок.ПредыдщееСостояниеИспользование = Ложь;
				Иначе
					СтрокаТЗСкидок.ПредыдщееСостояниеИспользование = Истина;
					
					Если СтруктураПараметров.МассивНеиспользуемыхСкидок.Найти(СтрокаТЗСкидок.СкидкаНаценка) = Неопределено Тогда 
						СтруктураПараметров.МассивНеиспользуемыхСкидок.Добавить(СтрокаТЗСкидок.СкидкаНаценка);
					КонецЕсли;
				КонецЕсли;
				
			Иначе
				СтрокаТЗСкидок.ПредыдщееСостояниеИспользование = Истина;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;

	// Расчет скидок и применяем вытеснение скидок по группам (автоматические скидки, согласно маркетинговым акциям)
	РасчитатьПрименитьВытеснениСложныхСкидокПоГруппам(ТаблицаСкидок, СтруктураПараметров, "ТолькоСкидки");

	// Добавляем погашение суммы бонусами и пересчитываем сумму бонусов.
	Если ТаблицаОплатыБонусами <> Неопределено Тогда
		
		ТаблицаСкидокВрем = ТаблицаСкидок.СкопироватьКолонки("НомерСтроки, КлючСтроки, СкидкаНаценка, Номенклатура, БонусныйСчет, ПризнакОплатыБонусом, СуммаСкидки, Контрагент");
		ТаблицаСкидокВрем.Колонки.Номенклатура.Имя	= "НоменклатураСкидки";
		ТаблицаСкидокВрем.Колонки.СуммаСкидки.Имя	= "Сумма";
		Для Каждого СтрокаТЗСкидок Из ТаблицаСкидок Цикл
			Если СтрокаТЗСкидок.ПредыдщееСостояниеИспользование	= Истина 
				И СтрокаТЗСкидок.Использовать = Истина 
				И СтрокаТЗСкидок.НачислениеБонусами = Ложь 
				И СтрокаТЗСкидок.ПризнакОплатыБонусом = Ложь 
				И Не СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок Тогда
				
				НоваяСтрока = ТаблицаСкидокВрем.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗСкидок);
				НоваяСтрока.НоменклатураСкидки = СтрокаТЗСкидок.Номенклатура;
				НоваяСтрока.Сумма			   = СтрокаТЗСкидок.СуммаСкидки;
			КонецЕсли;
		КонецЦикла;
		
		ТаблицаВозможнаяОплатаТоваровБонусами = ЗапросПоОплатеБонусами(
													ДокументОбъект, 
													?(ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) , ДокументОбъект[ИмяТабличнойЧастиЗапасы].Выгрузить() , Неопределено),
													?(ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение), ДокументОбъект[ИмяТабличнойЧастиЛечение].Выгрузить(), Неопределено),
													?(ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) , ДокументОбъект[ИмяТабличнойЧастиУслуги].Выгрузить() , Неопределено),
													ТаблицаСкидокВрем);		
													
		СтруктураПараметров.Вставить("ТаблицаВозможныхОплатБонусами", ТаблицаВозможнаяОплатаТоваровБонусами);
		
		// Расчитываем бонусы.
		РасчитатьПрименитьОплатуБонусами(ТаблицаСкидок, ТаблицаВозможнаяОплатаТоваровБонусами, ТаблицаОплатыБонусами);
		
		// Оплата бонусами.
		Если ИмяТабличнойЧастиЗапасы <> Неопределено Тогда
			Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТабличнойЧастиЗапасы] Цикл
				СуммаОплатыБонусами = 0;
				
				ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
				Для Каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
					СуммаОплатыБонусами = СуммаОплатыБонусами + СтрокаТЗСкидок.СуммаСкидки;
				КонецЦикла;
					
				ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, НачислениеБонусами, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
				Для каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
					СтрокаТЗСкидок.Сумма = СтрокаТЗСкидок.Сумма - СуммаОплатыБонусами;
				КонецЦикла;
				
			КонецЦикла;
		КонецЕсли;
		Если ИмяТабличнойЧастиЛечение <> Неопределено Тогда
			Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТабличнойЧастиЛечение] Цикл
				СуммаОплатыБонусами = 0;
				
				ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
				Для Каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
					СуммаОплатыБонусами = СуммаОплатыБонусами + СтрокаТЗСкидок.СуммаСкидки;
				КонецЦикла;
				
				ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, НачислениеБонусами, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
				Для каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
					СтрокаТЗСкидок.Сумма = СтрокаТЗСкидок.Сумма - СуммаОплатыБонусами;
				КонецЦикла;
				
			КонецЦикла;
		КонецЕсли;
		Если ИмяТабличнойЧастиУслуги <> Неопределено Тогда
			Для Каждого СтрокаТЧ Из ДокументОбъект[ИмяТабличнойЧастиУслуги] Цикл
				СуммаОплатыБонусами = 0;
				
				ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, ПризнакОплатыБонусом, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
				Для Каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
					СуммаОплатыБонусами = СуммаОплатыБонусами + СтрокаТЗСкидок.СуммаСкидки;
				КонецЦикла;
				
				ТаблицаСкидокПоСтроке = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, НачислениеБонусами, Использовать", СтрокаТЧ.КлючСтроки, Истина, Истина));
				Для каждого СтрокаТЗСкидок Из ТаблицаСкидокПоСтроке Цикл
					СтрокаТЗСкидок.Сумма = СтрокаТЗСкидок.Сумма - СуммаОплатыБонусами;
				КонецЦикла;
				
			КонецЦикла;
		КонецЕсли;      
		
	КонецЕсли;
	
	// до обработки "групп" удаляем бонусы не применяемые при наличиии скидки.
	МассивБонусовНеНачисляемыхПриНаличииСкидки	= Новый Массив;
	Если ЕстьБонусыНеНачисляемыеПриНаличииСкидки(ТаблицаСкидок) Тогда
		ТаблицаСкидокВременная						= ТаблицаСкидок.Скопировать();	
		ТабличнаяЧастьЗапасыДокументаВременная		= ?(ИмяТабличнойЧастиЗапасы <> Неопределено	, ДокументОбъект[ИмяТабличнойЧастиЗапасы].Выгрузить(), Неопределено);
		ТабличнаяЧастьЛечениеДокументаВременная		= ?(ИмяТабличнойЧастиЛечение <> Неопределено, ДокументОбъект[ИмяТабличнойЧастиЛечение].Выгрузить(), Неопределено);
		ТабличнаяЧастьУслугиДокументаВременная		= ?(ИмяТабличнойЧастиУслуги <> Неопределено	, ДокументОбъект[ИмяТабличнойЧастиУслуги].Выгрузить(), Неопределено);
					
		ПредварительноПрименитьСкидкиВТаблицеТоваров(
				ТаблицаСкидокВременная,
				ТабличнаяЧастьЗапасыДокументаВременная, 
				ТабличнаяЧастьЛечениеДокументаВременная,
				ТабличнаяЧастьУслугиДокументаВременная,
				ТаблицаПредыдщееСостояниеСкидок);
				
		Если ИмяТЧСкидки <> "" Тогда
			ТабличнаяЧастьСкидкиНаценкиДокументаВременная = ДокументОбъект[ИмяТЧСкидки].Выгрузить();
			РасчитатьПрименитьВытеснениСложныхСкидокПоГруппам(ТаблицаСкидокВременная, СтруктураПараметров, "ТолькоБонусы");
			ПрименитьСкидкиВТаблицеТоваров(
							ТаблицаСкидокВременная,
							ТабличнаяЧастьЗапасыДокументаВременная,
							ТабличнаяЧастьЛечениеДокументаВременная,
							ТабличнаяЧастьУслугиДокументаВременная,
							ТаблицаПредыдщееСостояниеСкидок,
							ДокументОбъект);
			ЗаполнитьТЧСкидокНаценок(ТаблицаСкидокВременная, ТабличнаяЧастьСкидкиНаценкиДокументаВременная, ТаблицаПредыдщееСостояниеСкидок);
			МассивБонусовНеНачисляемыхПриНаличииСкидки = ПолучитьМассивБонусовНеНачисляемыхПриНаличииСкидки(ТабличнаяЧастьСкидкиНаценкиДокументаВременная, ТабличнаяЧастьЗапасыДокументаВременная, ТабличнаяЧастьЛечениеДокументаВременная);	
		КонецЕсли;	
	КонецЕсли;
	
	 // Перерасчет бонусов и применяем вытеснение скидок по группам (автоматические скидки, согласно маркетинговым акциям)
	 // так же удаляются бонусы не начисляемые при скидке
	РасчитатьПрименитьВытеснениСложныхСкидокПоГруппам(ТаблицаСкидок, СтруктураПараметров, "ТолькоБонусы", МассивБонусовНеНачисляемыхПриНаличииСкидки);
	
	// Применяем скидку в строках ТЧ номенклатуры
		ПрименитьСкидкиВТаблицеТоваров(
		ТаблицаСкидок, 
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) , ДокументОбъект[ИмяТабличнойЧастиЗапасы] , Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение), ДокументОбъект[ИмяТабличнойЧастиЛечение], Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) , ДокументОбъект[ИмяТабличнойЧастиУслуги] , Неопределено),
		ТаблицаПредыдщееСостояниеСкидок,
		ДокументОбъект);
		
	ПересчитатьСуммуНачислениеБонусами(
		ТаблицаСкидок, 
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЗапасы) , ДокументОбъект[ИмяТабличнойЧастиЗапасы] , Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиЛечение), ДокументОбъект[ИмяТабличнойЧастиЛечение], Неопределено),
		?(ЗначениеЗаполнено(ИмяТабличнойЧастиУслуги) , ДокументОбъект[ИмяТабличнойЧастиУслуги] , Неопределено),
		ДокументОбъект);

	// Заполнение скидок в ТЧ скидки наценки
	Если ИмяТЧСкидки <> "" Тогда
		ЗаполнитьТЧСкидокНаценок(ТаблицаСкидок, ДокументОбъект[ИмяТЧСкидки], ТаблицаПредыдщееСостояниеСкидок);
		// удаляются ранее
		// УдалитьБонусыНеНачисляемыеПриНаличииСкидки(ДокументОбъект[ИмяТЧСкидки], ДокументОбъект[ИмяТЧНоменклатуры], ТаблицаОплатыБонусами);	
		// удаляются в запросе получения скидок
		// УдалитьБонусыНеНачисляемыеПриОплатеБонусами(ДокументОбъект[ИмяТЧСкидки], ТаблицаОплатыБонусами, СтруктураПараметров);		
	КонецЕсли;	
	
	// Заполнение скидок в ТЧ подарки
	Если ИмяТЧПодарки <> "" Тогда
		ЗаполнитьТЧПодарков(ТаблицаСкидок, ДокументОбъект[ИмяТЧПодарки], ТаблицаПредыдщееСостояниеСкидок);
	КонецЕсли;	 

КонецПроцедуры // РассчитатьСкидкиПриПродаже()

// Процедура - Выполнить начисление скидки на лицевой счет после оплаты
//
// Параметры:
//  ДокументРеализации	 - 	 - 
//
Процедура УстановитьБонусныйСчетНачисленияВСкидках(
	ДокументОбъект,
	ИмяТЧСкидки,
	Контрагент,
	КартаКонтрагента, 
	Отказ) Экспорт  
	
	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого СтрокаТЧ ИЗ ДокументОбъект[ИмяТЧСкидки] Цикл
		
		Промокод = СтрокаТЧ.СкидкаНаценка.Промокод;
		Если СтрокаТЧ.Сумма <> 0 Тогда
			ИспользуемыйКонтрагент = ?(ЗначениеЗаполнено(СтрокаТЧ.Контрагент), СтрокаТЧ.Контрагент, Контрагент);
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СкидкаНаценка)
				И СтрокаТЧ.СкидкаНаценка.НачислениеБонусами = ИСТИНА
				И ЗначениеЗаполнено(СтрокаТЧ.БонусныйСчет.ВладелецБонусногоСчета) 
				И СтрокаТЧ.БонусныйСчет.ВладелецБонусногоСчета <> ?(СтрокаТЧ.БонусныйСчет.Именной, Контрагент, КартаКонтрагента) ТОГДА
				
				СтрокаТЧ.БонусныйСчет = Неопределено;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СкидкаНаценка)
				И СтрокаТЧ.СкидкаНаценка.НачислениеБонусами = Истина
				И (НЕ ЗначениеЗаполнено(СтрокаТЧ.БонусныйСчет)       
				ИЛИ (СтрокаТЧ.СкидкаНаценка.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.БонусРефералу И ЗначениеЗаполнено(Промокод)))
				И СтрокаТЧ.Использование = Истина Тогда
				
				Если СтрокаТЧ.СкидкаНаценка.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.БонусРефералу И ЗначениеЗаполнено(Промокод) Тогда
					Реферал = РегистрыСведений.Промокоды.ПолучитьРефералаПоПромокоду(ДокументОбъект.Промокод);
					ИспользуемыйКонтрагент 		 = ?(ЗначениеЗаполнено(Реферал), Реферал, Контрагент);
					КартаКонтрагента = ПолучитьКарту(ИспользуемыйКонтрагент);      
				КонецЕсли;
			
				Запрос = Новый Запрос;
				Запрос.УстановитьПараметр("ТекущаяДата"			, ?(НЕ ЗначениеЗаполнено(ДокументОбъект.Дата) ИЛИ НачалоДня(ДокументОбъект.Дата) = НачалоДня(ТекущаяДата()), ТекущаяДата(), ДокументОбъект.Дата));
				Запрос.УстановитьПараметр("Контрагент"			, ИспользуемыйКонтрагент);
				Запрос.УстановитьПараметр("КартаКонтрагента"	, КартаКонтрагента);
				Запрос.УстановитьПараметр("ВидБонусногоСчета"	, СтрокаТЧ.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом);
				Запрос.Текст = 
				"ВЫБРАТЬ РАЗРЕШЕННЫЕ
				|	БонусныеСчета.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник.БонусныеСчета КАК БонусныеСчета
				|ГДЕ
				|	БонусныеСчета.ПометкаУдаления = ЛОЖЬ
				|	И БонусныеСчета.Закрыт = ЛОЖЬ
				|	И БонусныеСчета.ВидБонусногоСчета = &ВидБонусногоСчета
				|	И ВЫБОР
				|			КОГДА БонусныеСчета.Именной = ИСТИНА
				|				ТОГДА БонусныеСчета.ВладелецБонусногоСчета = &Контрагент
				|			ИНАЧЕ БонусныеСчета.ВладелецБонусногоСчета = &КартаКонтрагента
				|		КОНЕЦ
				|	И (&ТекущаяДата МЕЖДУ БонусныеСчета.СрокДействияНачало И КОНЕЦПЕРИОДА(БонусныеСчета.СрокДействияКонец, ДЕНЬ)
				|			ИЛИ &ТекущаяДата >= БонусныеСчета.СрокДействияНачало
				|				И БонусныеСчета.СрокДействияКонец = ДАТАВРЕМЯ(1, 1, 1))
				|
				|УПОРЯДОЧИТЬ ПО
				|	БонусныеСчета.СрокДействияКонец УБЫВ";
				ВыборкаБонусныеСчета = Запрос.Выполнить().Выбрать();
				
				Если ВыборкаБонусныеСчета.Следующий() Тогда
					СтрокаТЧ.БонусныйСчет = ВыборкаБонусныеСчета.Ссылка;
				Иначе
					
					БонусныйСчетОбъект = Справочники.БонусныеСчета.СоздатьЭлемент();
					БонусныйСчетОбъект.Заполнить(СтрокаТЧ.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом);
					ЗаполнитьЗначенияСвойств(БонусныйСчетОбъект, СтрокаТЧ.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом, "НеОграниченПроцентомСписания");
					БонусныйСчетОбъект.ВладелецБонусногоСчета	= ?(БонусныйСчетОбъект.Именной, ИспользуемыйКонтрагент, КартаКонтрагента);
					БонусныйСчетОбъект.Наименование				= Справочники.БонусныеСчета.СформироватьНаименование(БонусныйСчетОбъект.Код, БонусныйСчетОбъект.Именной, БонусныйСчетОбъект.ВладелецБонусногоСчета);
					БонусныйСчетОбъект.Записать();
					СтрокаТЧ.БонусныйСчет = БонусныйСчетОбъект.Ссылка;
					
					Если БонусныйСчетОбъект.Именной = Ложь И НЕ ЗначениеЗаполнено(КартаКонтрагента) Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'При начислении бонуса на неименной бонусный счет, необходимо указание дисконтной карты!'; en = 'When crediting a bonus to an unnamed bonus account, you must specify a discount card!'"));
						Отказ = Истина;
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли; 
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

// Функция, возвращает сумму, доступную для оплаты бонусным счетом в массиве реализаций/приемов.
//
Функция ПолучитьСуммуДоступнуюДляОплатыБонуснымСчетомВМассивеРеализацийПриемов(МассивДокументов, БонусныйСчет) Экспорт
	
	СуммаОстатокПоРег = ПолучитьОстатокНаБонусномСчете(БонусныйСчет);
	ОбщаяСумма   	  = 0;
	
	Для Каждого ДокументСсылка Из МассивДокументов Цикл
		
		СуммаДостПоВизиту = ПолучитьСуммуДоступнуюДляОплатыБонуснымСчетомВРеализацииПриеме(
								ДокументСсылка, 
								БонусныйСчет,
								СуммаОстатокПоРег);
		
		Если ОбщаяСумма + СуммаДостПоВизиту > СуммаОстатокПоРег Тогда
			Возврат СуммаОстатокПоРег;
		КонецЕсли;
		
		ОбщаяСумма = ОбщаяСумма + СуммаДостПоВизиту;
		
	КонецЦикла;
	
	Возврат ОбщаяСумма;
	
КонецФункции

// Функция, возвращает сумму, доступную для оплаты бонусным счетом.
//
Функция ПолучитьСуммуДоступнуюДляОплатыБонуснымСчетомВРеализацииПриеме(
	ДокументСсылка, 
	БонусныйСчет, 
	СуммаОстатокПоРег = Неопределено) Экспорт
	
	СуммаСОграничением = ПолучитьСуммуДоступнуюДляОплатыСчетом(ДокументСсылка, БонусныйСчет);
	
	Если СуммаОстатокПоРег = Неопределено Тогда
		СуммаОстатокПоРег = ПолучитьОстатокНаБонусномСчете(БонусныйСчет);
	КонецЕсли;
	
	Если СуммаСОграничением > СуммаОстатокПоРег Тогда
		СуммаСОграничением = СуммаОстатокПоРег;
	КонецЕсли;
	
	// Из Api в эту функцию передается объект реализации, который ещё не записан.
	// На этот случай делаю проверку, чтобы на этой функции косяк не вылетал. Баст.
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Реализация")
		Или ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Прием") Тогда
		СуммаНачисленияНаБонусныйСчет = РегистрыНакопления.БонусныеСчета.ПолучитьНачисленнуюСуммуБонусногоСчетаПоРеализации(ДокументСсылка, БонусныйСчет);
	Иначе
		СуммаНачисленияНаБонусныйСчет = 0;
	КонецЕсли;
	
	СуммаСОграничением = ?(СуммаСОграничением - СуммаНачисленияНаБонусныйСчет > 0, СуммаСОграничением - СуммаНачисленияНаБонусныйСчет, 0);
	
	Возврат СуммаСОграничением;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция - Получить сумму доступную для оплаты счетом.
//
// Параметры:
//  РеализацияСсылка - 	 - 
//  ЛицевойСчет		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСуммуДоступнуюДляОплатыСчетом(ДокументСсылка, БонусныйСчет) Экспорт
	
	Если ТипЗнч(БонусныйСчет) = Тип("СправочникСсылка.БонусныеСчета") Тогда
		ПакетУслугСоставУслуг = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(БонусныйСчет, "ВидБонусногоСчета").ПакетУслугСоставУслуг;
	Иначе
		ПакетУслугСоставУслуг = БонусныйСчет.ПакетУслугСоставУслуг;
	КонецЕсли;                  	
	
	НайденныеСкидкиНаценки = ДокументСсылка.СкидкиНаценки.НайтиСтроки(Новый Структура("ПризнакОплатыБонусом", Истина));
	
	ОплаченоБонусом		= 0;
	СуммаСОграничением	= 0;
	Для Каждого СтрокаСкидкиНаценки Из НайденныеСкидкиНаценки Цикл
		Если СтрокаСкидкиНаценки.БонусныйСчет = БонусныйСчет Тогда
			ОплаченоБонусом = ОплаченоБонусом + СтрокаСкидкиНаценки.Сумма;
		КонецЕсли;
	КонецЦикла;
	
	Если ПакетУслугСоставУслуг.Количество() > 0 Тогда
		
		Для Каждого СтрокаИзВидаБС Из ПакетУслугСоставУслуг Цикл
			
			НайденныеСтрокиЗапасов = Новый Массив;
			НайденныеСтроки = Новый Массив;

			Если ТипЗнч(СтрокаИзВидаБС.УслугаСегмент) = Тип("СправочникСсылка.Номенклатура") Тогда
				
				Если ЗначениеЗаполнено(СтрокаИзВидаБС.ВидЦены) Тогда
					СтруктураПоиска = Новый Структура("Номенклатура, ВидЦен", СтрокаИзВидаБС.УслугаСегмент, СтрокаИзВидаБС.ВидЦены); 
				Иначе
					СтруктураПоиска = Новый Структура("Номенклатура", СтрокаИзВидаБС.УслугаСегмент);
				КонецЕсли;
				Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы", ДокументСсылка.Метаданные()) = Истина Тогда
					ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
						НайденныеСтроки, 
						ДокументСсылка.Запасы.НайтиСтроки(СтруктураПоиска));
				КонецЕсли;
				Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", ДокументСсылка.Метаданные()) = Истина Тогда
					ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
						НайденныеСтроки,
						ДокументСсылка.Лечение.НайтиСтроки(СтруктураПоиска));
				КонецЕсли; 
				Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", ДокументСсылка.Метаданные()) = Истина Тогда
					ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
						НайденныеСтроки, 
						ДокументСсылка.Услуги.НайтиСтроки(СтруктураПоиска));
				КонецЕсли;    			
				
			ИначеЕсли ТипЗнч(СтрокаИзВидаБС.УслугаСегмент) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
				Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы", ДокументСсылка.Метаданные()) = Истина Тогда
					Для Каждого СтрокаИзЗапасов ИЗ ДокументСсылка.Запасы Цикл
						Если РегистрыСведений.НоменклатураСегмента.СегментСодержитОбъект(СтрокаИзВидаБС.УслугаСегмент, СтрокаИзЗапасов.Номенклатура) = Истина
							И (СтрокаИзЗапасов.ВидЦен = СтрокаИзВидаБС.ВидЦены
							ИЛИ НЕ ЗначениеЗаполнено(СтрокаИзВидаБС.ВидЦены)) Тогда
							
							НайденныеСтроки.Добавить(СтрокаИзЗапасов);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", ДокументСсылка.Метаданные()) = Истина Тогда
					Для Каждого СтрокаИзЛечение ИЗ ДокументСсылка.Лечение Цикл
						Если РегистрыСведений.НоменклатураСегмента.СегментСодержитОбъект(СтрокаИзВидаБС.УслугаСегмент, СтрокаИзЛечение.Номенклатура) = Истина
							И (СтрокаИзЛечение.ВидЦен = СтрокаИзВидаБС.ВидЦены
							ИЛИ НЕ ЗначениеЗаполнено(СтрокаИзВидаБС.ВидЦены)) Тогда
							
							НайденныеСтроки.Добавить(СтрокаИзЛечение);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", ДокументСсылка.Метаданные()) = Истина Тогда
					Для Каждого СтрокаИзУслуги ИЗ ДокументСсылка.Услуги Цикл
						Если РегистрыСведений.НоменклатураСегмента.СегментСодержитОбъект(СтрокаИзВидаБС.УслугаСегмент, СтрокаИзУслуги.Номенклатура) = Истина
							И (СтрокаИзУслуги.ВидЦен = СтрокаИзВидаБС.ВидЦены
							ИЛИ НЕ ЗначениеЗаполнено(СтрокаИзВидаБС.ВидЦены)) Тогда
							
							НайденныеСтроки.Добавить(СтрокаИзУслуги);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;			
			
			ОграничениеПоНоменклатуре = 0;
			Для Каждого СтрокаДокумента Из НайденныеСтроки Цикл
				
				Если СтрокаИзВидаБС.ПроцентСписания > 0 Тогда
					ОграничениеПоНоменклатуре = СтрокаДокумента.Всего / 100 * СтрокаИзВидаБС.ПроцентСписания;
				Иначе   					
					Если Не БонусныйСчет.ВидБонусногоСчета.НеОграниченПроцентомСписания
						И БонусныйСчет.ВидБонусногоСчета.ОграничениеСписанияПроцент > 0 Тогда
						ОграничениеПоНоменклатуре = СтрокаДокумента.Всего / 100 * БонусныйСчет.ВидБонусногоСчета.ОграничениеСписанияПроцент;
					Иначе
						ОграничениеПоНоменклатуре = СтрокаДокумента.Всего;
					КонецЕсли;
				КонецЕсли;
				
				СуммаСОграничением = СуммаСОграничением + ОграничениеПоНоменклатуре;
			КонецЦикла;
			
		КонецЦикла;
		
	Иначе
		ВидБонусногоСчета = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(БонусныйСчет, "ВидБонусногоСчета");
		СтруктураДанныхВидаБонусногоСчета = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ВидБонусногоСчета, "НеОграниченПроцентомСписания, ОграничениеСписанияПроцент");
		НеОграниченПроцентомСписания = СтруктураДанныхВидаБонусногоСчета.НеОграниченПроцентомСписания;
		ОграничениеСписанияПроцент   = СтруктураДанныхВидаБонусногоСчета.ОграничениеСписанияПроцент;
		
		СуммаСОграничением = 0;
		Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы", ДокументСсылка.Метаданные()) = Истина Тогда
			СуммаСОграничением = СуммаСОграничением + ДокументСсылка.Запасы.Итог("Всего");
		КонецЕсли;
		Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", ДокументСсылка.Метаданные()) = Истина Тогда
			СуммаСОграничением = СуммаСОграничением + ДокументСсылка.Лечение.Итог("Всего");
		КонецЕсли;
		Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", ДокументСсылка.Метаданные()) = Истина Тогда
			СуммаСОграничением = СуммаСОграничением + ДокументСсылка.Услуги.Итог("Всего");
		КонецЕсли;  
		
		Если НЕ НеОграниченПроцентомСписания = Истина Тогда
			СуммаСОграничением = СуммаСОграничением / 100 * ОграничениеСписанияПроцент;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СуммаСОграничением - ОплаченоБонусом;
	
КонецФункции

// Функция, возвращает остаток на бонусном счете.
//
Функция ПолучитьОстатокНаБонусномСчете(БонусныйСчет)
	
	Возврат РегистрыНакопления.БонусныеСчета.ПолучитьОстатокНаБонусномСчетеВладельца(БонусныйСчет, ТекущаяДатаСеанса());
	
КонецФункции

// Процедура получает ближайший день рождения для расчета скидок
//
// Параметры:
//  Получатель - физическое лицо получатель скидки
//
// Возвращаемое значение:
//  ДатаРождения - ближайшая дата Дня рождения получателя.
//
Функция ПолучитьБлижайшийДеньРождения(Получатель)
	
	Перем ДатаРождения;
	ДатаРождения = Дата('00010101000000');
	
	мТекущаяДата = ТекущаяДатаСеанса();
	
	Если ТипЗнч(Получатель) = Тип("СправочникСсылка.Контрагенты") Тогда
		Если ЗначениеЗаполнено(Получатель.ДатаРожденияКлиента) Тогда
		
			Если Не (Месяц(Получатель.ДатаРожденияКлиента) = 2 И День(Получатель.ДатаРожденияКлиента) = 29) Тогда
				ДатаТекущегоГода= Дата(Год(мТекущаяДата), Месяц(Получатель.ДатаРожденияКлиента), День(Получатель.ДатаРожденияКлиента));
			Иначе
				ДатаТекущегоГода= Дата(Год(мТекущаяДата), 3, 1);
			КонецЕсли;
			ДатаПредыдущегоГода = ДобавитьМесяц(ДатаТекущегоГода, -12);
			ДатаСледующегоГода  = ДобавитьМесяц(ДатаТекущегоГода, 12);
			
			Если мТекущаяДата < ДатаТекущегоГода Тогда
				Разность = ДатаТекущегоГода - мТекущаяДата;
			Иначе
				Разность = мТекущаяДата - ДатаТекущегоГода;
			КонецЕсли;
			
			Если Разность > (мТекущаяДата - ДатаПредыдущегоГода) Тогда
				ДатаРождения = ДатаПредыдущегоГода
			ИначеЕсли Разность > (ДатаСледующегоГода - мТекущаяДата) Тогда
				ДатаРождения = ДатаСледующегоГода;
			Иначе
				ДатаРождения = ДатаТекущегоГода;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДатаРождения;
	
КонецФункции // ПолучитьБлижайшийДеньРождения()

// Возвращает массив получателей скидки 
//
// Параметры
//  Получатель  - Контрагент или физическое лицо
//
// Возвращаемое значение:
//   Массив
//
Функция ПолучитьМассивСегментовПолучателя(Получатель)

	СегментовПолучателя = Новый Массив;
	
	Если ЗначениеЗаполнено(Получатель) Тогда
		
		// Добавляем все сегменты, в которые входит контрагент
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	КонтрагентыСегмента.Сегмент КАК Сегмент
			|ИЗ
			|	РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
			|ГДЕ
			|	КонтрагентыСегмента.Контрагент = &Контрагент";
		Запрос.УстановитьПараметр("Контрагент", Получатель);
		Для Каждого ЭлементМассива Из Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сегмент") Цикл
			СегментовПолучателя.Добавить(ЭлементМассива);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СегментовПолучателя;

КонецФункции

// Функция возвращает дерево значений, выгруженное из результата запроса по скидкам.
//
// Параметры:
//  ДокументОбъект - Документ в котором рассчитываем автоматические скидки
//  ТаблицаТоваров - Таблица значений в которую выгружена таблица товаров из документа
//  ДатаСкидок - дата, на которую необходимо рассчитать скидки.
//  СтруктураПараметров - Параметры для расчета
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//  ЕстьТЧПодарки - булево, определяет необходимость расчета скидок подарков
//
// Возвращаемое значение:
//  ДеревоЗначений.
//
Функция ЗапросПоСкидкам(
	ДокументОбъект,
	ТаблицаЗапасов			= Неопределено,
	ТаблицаЛечения			= Неопределено,
	ТаблицаУслуг 			= Неопределено,  
	СтруктураПараметров, 
	ТаблицаОплатыБонусами)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	СоздатьЗапросМенеджераВременныхТаблиц(
					Запрос,
					СтруктураПараметров,
					ТаблицаЗапасов,
					ТаблицаЛечения,
					ТаблицаУслуг,
					ДокументОбъект);    
					
	Результат = Запрос.Выполнить(); 
	
	КонтрагентИРодственники = Новый Массив;
	Если ЗначениеЗаполнено(СтруктураПараметров.Получатель) Тогда
		РодственникиКлиентаТЧ	= РегистрыСведений.РодственныеСвязи.РодственникиКлиента(СтруктураПараметров.Получатель,, Истина);
		РодственникиКлиента		= РодственникиКлиентаТЧ.ВыгрузитьКолонку("Родственник");
		РодственникиКлиента.Добавить(СтруктураПараметров.Получатель);  
		КонтрагентИРодственники = КонтрагентИРодственники(СтруктураПараметров.Получатель);

	Иначе
		РодственникиКлиента = Новый Массив;
	КонецЕсли;                                                  
	
	МоментВремениПредыдущегоПриема = ?(ДокументОбъект.Ссылка.Пустая(), СтруктураПараметров.ДатаСкидок, Новый Граница(ДокументОбъект.Ссылка.МоментВремени(), ВидГраницы.Исключая));
	
	Запрос.УстановитьПараметр("ДокументСсылка"       		, ДокументОбъект.Ссылка);
	Запрос.УстановитьПараметр("ДатаСкидок"           		, СтруктураПараметров.ДатаСкидок);
	Запрос.УстановитьПараметр("ДатаСкидокВремя"      		, Дата(1, 1, 1) + (СтруктураПараметров.ДатаСкидок - НачалоДня(СтруктураПараметров.ДатаСкидок)));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"   		, СтруктураПараметров.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДеньРождения"         		, ПолучитьБлижайшийДеньРождения(СтруктураПараметров.Получатель));
	Запрос.УстановитьПараметр("Получатель"           		, СтруктураПараметров.Получатель);
	Запрос.УстановитьПараметр("КартаКонтрагента"     		, СтруктураПараметров.Карта);
	Запрос.УстановитьПараметр("КлиентРекламныйИсточник"		, Ложь);
	Запрос.УстановитьПараметр("Организация"					, СтруктураПараметров.Организация);
	Запрос.УстановитьПараметр("РодственникиКлиента"			, РодственникиКлиента);
    Запрос.УстановитьПараметр("МассивКонтрагентов"			, КонтрагентИРодственники);
	Запрос.УстановитьПараметр("ПромокодыИспользуются"		, ?(ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Прием") ИЛИ ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Реализация"), ЗначениеЗаполнено(ДокументОбъект.Промокод), Ложь));
	Запрос.УстановитьПараметр("ВидПромокода"				, ?(ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Прием") ИЛИ ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Реализация"), РегистрыСведений.Промокоды.ПолучитьВидПромокода(ДокументОбъект.Промокод), Неопределено));	
	Запрос.УстановитьПараметр("МоментВремени"               , МоментВремениПредыдущегоПриема);
	Запрос.Текст = ПолучитьТекстЗапросаСкидок();	
	
	Если КонтрагентИРодственники.Количество() > 1 Тогда  
		УсловиеПолучателя = ?(ЗначениеЗаполнено(СтруктураПараметров.Получатель), "Контрагент В(&МассивКонтрагентов)", "КартаКонтрагента = &КартаКонтрагента");	
	Иначе
		УсловиеПолучателя = ?(ЗначениеЗаполнено(СтруктураПараметров.Получатель), "Контрагент = &Получатель", "КартаКонтрагента = &КартаКонтрагента");
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПолучателя", УсловиеПолучателя);
	
	МассивВидовБонусныхСчетовНеНачисляемыхПриОплате = ПолучитьМассивВидовБонусныхСчетовНеНачисляемыхПриОплатеБонусами(ТаблицаОплатыБонусами);
	УсловиеБонусныеСчетаНеНачисляемыеПриОплате = ?(Не ЗначениеЗаполнено(МассивВидовБонусныхСчетовНеНачисляемыхПриОплате),
	"",
	"
	|И	ВЫБОР
	|		КОГДА ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.НачислениеБонусами = ИСТИНА
	|			И ТИПЗНАЧЕНИЯ(ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом) = ТИП(Справочник.ВидыБонусныхСчетов)
	|			И ВЫРАЗИТЬ(ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом КАК Справочник.ВидыБонусныхСчетов).НеНачислятьПриОплатеБонусами = ИСТИНА
	|		ТОГДА НЕ ВЫРАЗИТЬ(ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом КАК Справочник.ВидыБонусныхСчетов) В (&МассивВидовБонусныхСчетовНеНачисляемыхПриОплате)
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ"
	);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеБонусныеСчетаНеНачисляемыеПриОплате", УсловиеБонусныеСчетаНеНачисляемыеПриОплате);
	Запрос.УстановитьПараметр("МассивВидовБонусныхСчетовНеНачисляемыхПриОплате", МассивВидовБонусныхСчетовНеНачисляемыхПриОплате);	
	
	ТаблицаСкидок = Запрос.Выполнить().Выгрузить();     	
	                 
	ТаблицаСкидок.Колонки.Добавить("СуммаСкидки" , Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15,2)));
	ТаблицаСкидок.Колонки.Добавить("Использовать", Новый ОписаниеТипов("Булево"));
	ТаблицаСкидок.Колонки.Добавить("ПредыдщееСостояниеИспользование", Новый ОписаниеТипов("Булево"));
		
		Возврат ТаблицаСкидок; 	
	
КонецФункции // ЗапросПоСкидкам()

// Процедура создает запрос менеджер временных таблиц.
//
Процедура СоздатьЗапросМенеджераВременныхТаблиц(
	Запрос, 
	СтруктураПараметров,
	ТаблицаЗапасов		= Неопределено,
	ТаблицаЛечения		= Неопределено,
	ТаблицаУслуг 		= Неопределено,  
	ДокументОбъект) 
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;	
	Если ТаблицаЗапасов <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаЗапасы"	, ТаблицаЗапасов) КонецЕсли;
	Если ТаблицаЛечения <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаЛечения", ТаблицаЛечения) КонецЕсли;
	Если ТаблицаУслуг   <> Неопределено	Тогда Запрос.УстановитьПараметр("ТаблицаУслуг"	, ТаблицаУслуг)	  КонецЕсли;
	
	ЕстьКолонкаКоличествоУпаковокТЧЛечение = Ложь;
	Если ТаблицаЛечения <> Неопределено Тогда 
		ЕстьКолонкаКоличествоУпаковокТЧЛечение = ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("КоличествоУпаковок") <> Неопределено;
	КонецЕсли;
	
	ЭтоНарядЗаказ = СтруктураПараметров.Свойство("ЭтоНарядЗаказ");

	СтрокаОбъединение = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";	
	
	СтрокаРазделение = "
	|
	|;
	|///////////////////////////////////////////
	|";   	
	
	СтрокаПоместить = "	
	|ПОМЕСТИТЬ ТаблицаТовары
	|";	 
	
	МассивТекст = Новый Массив;
	
	// добавляем во временные таблицы. 	
	Если ТаблицаЗапасов <> Неопределено Тогда
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЗапасы.НомерСтроки,
		|	ТаблицаЗапасы.КлючСтроки,
		|	ТаблицаЗапасы.Номенклатура,
		|	ТаблицаЗапасы.КоличествоУпаковок,
		|	ТаблицаЗапасы.Упаковка,
		|	ТаблицаЗапасы.Количество,
		|	ТаблицаЗапасы.ВидЦен,"
		+ ?(ЭтоНарядЗаказ = Истина, 
			" ТаблицаЗапасы.ЦенаПродажи КАК Цена,", 
			" ТаблицаЗапасы.Цена КАК Цена,")	
		+ ?(ЭтоНарядЗаказ = Истина, 
			" ТаблицаЗапасы.СуммаПродажи КАК Сумма", 
			" ТаблицаЗапасы.Сумма КАК Сумма")	
		+ "
		|ПОМЕСТИТЬ ТаблицаЗапасы
		|ИЗ
		|	&ТаблицаЗапасы КАК ТаблицаЗапасы";	
		
		МассивТекст.Добавить(Текст);
	КонецЕсли;
	
	Если ТаблицаЛечения <> Неопределено Тогда
		
		Если ТаблицаЗапасов <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаРазделение);
		КонецЕсли;             		
		
		Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ 
		|	ТаблицаЛечения.НомерСтроки,
		|	ТаблицаЛечения.КлючСтроки,
		|	ТаблицаЛечения.Номенклатура,"
		+ ?(ЕстьКолонкаКоличествоУпаковокТЧЛечение = Истина, 
			" ТаблицаЛечения.КоличествоУпаковок КАК КоличествоУпаковок,", 
			" ТаблицаЛечения.Количество КАК КоличествоУпаковок,")	
		+ "
		|	ТаблицаЛечения.Упаковка,
		|	ТаблицаЛечения.Количество,
		|	ТаблицаЛечения.ВидЦен,
		|	ТаблицаЛечения.Цена,
		|	ТаблицаЛечения.Сумма 
		|ПОМЕСТИТЬ ТаблицаЛечения
		|ИЗ
		|	&ТаблицаЛечения КАК ТаблицаЛечения
		|&СтрокаУсловие";
		
		Если ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("ДокументАванса") <> Неопределено Тогда
						
			Текст = СтрЗаменить(Текст, "&СтрокаУсловие", "Где
			| Выбор Когда &ПрименятьСкидкиПоПланамЛечения = Истина Тогда ТаблицаЛечения.ДокументАванса = Неопределено Иначе Истина Конец");
			Запрос.УстановитьПараметр("ПрименятьСкидкиПоПланамЛечения", ОбщегоНазначенияСтоматология.ПолучитьЗначениеКонстанты("ПрименятьСкидкиПоПланамЛечения"));
		Иначе
			Текст = СтрЗаменить(Текст, "&СтрокаУсловие", "");
		КонецЕсли;
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;
	
	Если ТаблицаУслуг <> Неопределено Тогда
		
		Если ТаблицаЗапасов <> Неопределено 
			Или ТаблицаЛечения <> Неопределено Тогда
			
			МассивТекст.Добавить(СтрокаРазделение);
		КонецЕсли;     
		
		Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаУслуг.НомерСтроки,
		|	ТаблицаУслуг.КлючСтроки,
		|	ТаблицаУслуг.Номенклатура,
		|	ТаблицаУслуг.КоличествоУпаковок,
		|	ТаблицаУслуг.Упаковка,
		|	ТаблицаУслуг.Количество,
		|	ТаблицаУслуг.ВидЦен,
		|	ТаблицаУслуг.Цена,
		|	ТаблицаУслуг.Сумма
		|ПОМЕСТИТЬ ТаблицаУслуг
		|ИЗ
		|	&ТаблицаУслуг КАК ТаблицаУслуг";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;   
	
	// формируем запрос "объединение".
	МассивТекст.Добавить(СтрокаРазделение);
	Если ТаблицаЗапасов <> Неопределено Тогда
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЗапасы.НомерСтроки,
		|	ТаблицаЗапасы.КлючСтроки,
		|	ТаблицаЗапасы.Номенклатура,
		|	ТаблицаЗапасы.КоличествоУпаковок,
		|	ТаблицаЗапасы.Упаковка,
		|	ТаблицаЗапасы.Количество,
		|	ТаблицаЗапасы.ВидЦен,
		|	ТаблицаЗапасы.Цена,
		|	ТаблицаЗапасы.Сумма
		|ПОМЕСТИТЬ ТаблицаТовары
		|ИЗ
		|	ТаблицаЗапасы КАК ТаблицаЗапасы";
		
		МассивТекст.Добавить(Текст);
	КонецЕсли;
	   	
	Если ТаблицаЛечения <> Неопределено Тогда
		
		Если ТаблицаЗапасов <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаОбъединение);
		КонецЕсли;  
		
		Текст =
		"ВЫБРАТЬ " + ?(ТаблицаЗапасов = Неопределено, "РАЗРЕШЕННЫЕ", "") + " 
		|	ТаблицаЛечения.НомерСтроки,
		|	ТаблицаЛечения.КлючСтроки,
		|	ТаблицаЛечения.Номенклатура,
		|	ТаблицаЛечения.КоличествоУпаковок,
		|	ТаблицаЛечения.Упаковка,
		|	ТаблицаЛечения.Количество,
		|	ТаблицаЛечения.ВидЦен,
		|	ТаблицаЛечения.Цена,
		|	ТаблицаЛечения.Сумма"  
		+ ?(ТаблицаЗапасов = Неопределено, СтрокаПоместить, "")	
		+ "
		|ИЗ
		|	ТаблицаЛечения КАК ТаблицаЛечения";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;
	
	Если ТаблицаУслуг <> Неопределено Тогда
		
		Если ТаблицаЗапасов <> Неопределено 
			Или ТаблицаЛечения <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаОбъединение);
		КонецЕсли;  
		
		Текст =
		"ВЫБРАТЬ " + ?(ТаблицаЗапасов = Неопределено И ТаблицаЛечения = Неопределено, "РАЗРЕШЕННЫЕ", "") + " 
		|	ТаблицаУслуг.НомерСтроки,
		|	ТаблицаУслуг.КлючСтроки,
		|	ТаблицаУслуг.Номенклатура,
		|	ТаблицаУслуг.КоличествоУпаковок,
		|	ТаблицаУслуг.Упаковка,
		|	ТаблицаУслуг.Количество,
		|	ТаблицаУслуг.ВидЦен,
		|	ТаблицаУслуг.Цена,
		|	ТаблицаУслуг.Сумма"   
		+ ?(ТаблицаЗапасов = Неопределено И ТаблицаЛечения = Неопределено, СтрокаПоместить, "")	
		+ "
		|ИЗ
		|	ТаблицаУслуг КАК ТаблицаУслуг";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;   	
	
	Текст = "
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ первые 1 * 
	|ПОМЕСТИТЬ ТаблицаТоварыПерваяСтрока
	|	ИЗ ТаблицаТовары
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ * ИЗ ТаблицаТовары";	
	
	МассивТекст.Добавить(Текст);
	
	Запрос.Текст = СтрСоединить(МассивТекст, Символы.ПС);
	
КонецПроцедуры

// Функция возвращает текст запроса получения скидок.
//
Функция ПолучитьТекстЗапросаСкидок()
	
Возврат
"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка КАК СкидкаНаценка,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ПорядокПрименения КАК ПорядокПрименения,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.УсловиеПредоставленияСкидки КАК УсловиеПредоставленияСкидки,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ВидСравненияУсловия КАК ВидСравненияУсловия,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеУсловия КАК ЗначениеУсловия,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.СпособПредоставленияСкидки КАК СпособПредоставленияСкидки,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ЗначениеСкидкиНаценкиОбъектом КАК ЗначениеСкидкиНаценкиОбъектом,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.НачислениеБонусами КАК НачислениеБонусами,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.СегментБазыРасчетаСкидки КАК СегментБазыРасчетаСкидки,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.СегментНоменклатуры КАК СегментНоменклатуры,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ОбъектСкидки КАК ОбъектСкидки,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ОбъектНакопления КАК ОбъектНакопления,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ПериодНакопления КАК ПериодНакопления,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ПериодНакопленияТип КАК ПериодНакопленияТип,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.СкидкаНаЕдиныйКомплект КАК СкидкаНаЕдиныйКомплект,
|	ДействиеСкидокНаценокСрезПоследних.КоличествоПрименений КАК КоличествоПрименений,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
|	ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.НеСуммироватьЛицевыеСчетаРодственников КАК НеСуммироватьЛицевыеСчетаРодственников
|ПОМЕСТИТЬ ДействующиеСкидки
|ИЗ
|	РегистрСведений.ДействиеСкидокНаценок.СрезПоследних(
|			&ДатаСкидок,
|			СтруктурнаяЕдиница В (&СтруктурнаяЕдиница, ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))
|				И СкидкаНаценка.ПометкаУдаления = ЛОЖЬ
|				И (НАЧАЛОПЕРИОДА(ДатаНачала, ДЕНЬ) <= &ДатаСкидок
|					ИЛИ ДатаНачала = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
|				И (КОНЕЦПЕРИОДА(ДатаОкончания, ДЕНЬ) >= &ДатаСкидок
|					ИЛИ ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))) КАК ДействиеСкидокНаценокСрезПоследних
|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СкидкиНаценки.Получатели КАК СкидкиНаценкиПолучатели
|		ПО ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка = СкидкиНаценкиПолучатели.Ссылка
|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СкидкиНаценки.ВремяПоДнямНедели КАК СкидкиНаценкиВремяПоДнямНедели
|		ПО ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка = СкидкиНаценкиВремяПоДнямНедели.Ссылка
|			И (СкидкиНаценкиВремяПоДнямНедели.Выбран = ИСТИНА)
|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСегмента КАК СоставСегментов
|		ПО (СкидкиНаценкиПолучатели.Получатель = СоставСегментов.Сегмент)
|			И (СоставСегментов.Контрагент = &Получатель)
|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Карты КАК Карты
|		ПО (СкидкиНаценкиПолучатели.Получатель = Карты.ВидКарты)
|			И (Карты.Ссылка = &КартаКонтрагента)
|			И (Карты.Заблокирована = ЛОЖЬ)
|ГДЕ
|	ДействиеСкидокНаценокСрезПоследних.Актуальность = ИСТИНА
|	И (СкидкиНаценкиВремяПоДнямНедели.ДеньНедели ЕСТЬ NULL
|			ИЛИ СкидкиНаценкиВремяПоДнямНедели.Выбран
|				И ДЕНЬНЕДЕЛИ(СкидкиНаценкиВремяПоДнямНедели.ДеньНедели) = ДЕНЬНЕДЕЛИ(&ДатаСкидок)
|				И (&ДатаСкидокВремя >= СкидкиНаценкиВремяПоДнямНедели.ВремяНачала
|					ИЛИ СкидкиНаценкиВремяПоДнямНедели.ВремяНачала = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
|				И (&ДатаСкидокВремя <= СкидкиНаценкиВремяПоДнямНедели.ВремяОкончания
|					ИЛИ СкидкиНаценкиВремяПоДнямНедели.ВремяОкончания = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)))
|	И ВЫБОР
|			КОГДА НЕ &КлиентРекламныйИсточник
|					И ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ПустаяСсылка)
|				ТОГДА ИСТИНА
|			КОГДА НЕ &КлиентРекламныйИсточник
|					И ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка.ТипПолучателя = ЗНАЧЕНИЕ(Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов)
|				ТОГДА СкидкиНаценкиПолучатели.Получатель = &Получатель
|			КОГДА НЕ &КлиентРекламныйИсточник
