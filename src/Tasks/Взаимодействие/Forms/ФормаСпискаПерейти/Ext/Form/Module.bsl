	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_СтруктурнаяЕдиница");
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_СтруктурнаяЕдиница");
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_СтруктурнаяЕдиница");
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));	
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений, Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), Нстр("ru = '<не указана>'; en = '<not specified>'"));
	
	// Обновляем элементы фильтрации для текущего фильтра
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																												
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает пакет запроса с элементами для создания отборов.
//
Функция ПолучитьПакетЗапросаЗначенийДляОтборов()
	
	МассивСтруктурныхЕдиниц 	= Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник, "Массив");		
	МассивВидовСделок 			= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(, МассивСтруктурныхЕдиниц);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивВидовСделок"		, МассивВидовСделок);
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц"	, МассивСтруктурныхЕдиниц);
	Запрос.УстановитьПараметр("ТекущийСотрудник"		, ПараметрыСеанса.ТекущийСотрудник);	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.Представление КАК Представление
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	НЕ ЭтапыСделок.ПометкаУдаления
	|	И ЭтапыСделок.ВидСделки В(&МассивВидовСделок)
	|	И ЭтапыСделок.Ссылка <> ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыСделок.НомерЭтапа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Сотрудники.Ссылка) КАК Представление
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
	|		ПО Сотрудники.ИдентификаторПользователяИБ = Пользователи.ИдентификаторПользователяИБ
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И (Сотрудники.Роль В (ЗНАЧЕНИЕ(Перечисление.РольПользователя.АдминистраторБазыДанных), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура), ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Управляющий))
	|			ИЛИ Пользователи.РольПользователя В (ЗНАЧЕНИЕ(Перечисление.РольПользователя.АдминистраторБазыДанных), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура), ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель), ЗНАЧЕНИЕ(Перечисление.РольПользователя.Управляющий))
	|			ИЛИ Сотрудники.Ссылка = &ТекущийСотрудник)
	|
	|СГРУППИРОВАТЬ ПО
	|	Сотрудники.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сотрудники.Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВидыВзаимодействий.Ссылка КАК Ссылка,
	|	ВидыВзаимодействий.Представление КАК Представление
	|ИЗ
	|	Справочник.ВидыВзаимодействий КАК ВидыВзаимодействий
	|ГДЕ
	|	НЕ ВидыВзаимодействий.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Представление КАК Представление
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.ПометкаУдаления = ЛОЖЬ
	|	И ВидыСделок.Ссылка В(&МассивВидовСделок)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СтатусыКлиентов.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СтатусыКлиентов.Ссылка) КАК Представление
	|ИЗ
	|	Перечисление.СтатусыКонтрагентов КАК СтатусыКлиентов
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыКлиентов.Порядок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СотрудникиМестаРаботы.Ссылка КАК Ссылка,
	|	СотрудникиМестаРаботы.Представление КАК Представление
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СотрудникиМестаРаботы
	|ГДЕ
	|	СотрудникиМестаРаботы.Ссылка В(&МассивСтруктурныхЕдиниц)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
	|	СтруктурныеЕдиницы.Представление КАК Представление
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление";
		
	Возврат Запрос.ВыполнитьПакет(); 
	
КонецФункции

