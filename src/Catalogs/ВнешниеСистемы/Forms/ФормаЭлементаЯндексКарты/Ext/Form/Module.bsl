Процедура КомандаПодобратьИдентификаторРубрики(Команда)
	
	Если ЯндексИдентификаторРубрики.Количество() = 3 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя выбирать больше трех рубрик!");
	Иначе
		ОткрытьФорму("Справочник.СтруктурныеЕдиницы.Форма.ФормаВыбораИдентификатораРубрики");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработка оповещения.
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Значение" Тогда
		
		Если ЗначениеЗаполнено(Параметр) Тогда
			ПолучитьИдентификаторИзХранилища(Параметр);
		КонецЕсли;  
		
	КонецЕсли;
	
	Если ИмяСобытия = "Запись_Файл" Тогда
		
		Если Параметр.Свойство("ВладелецФайла") И Параметр.ВладелецФайла = СтруктурнаяЕдиница Тогда
			ОтобразитьКартинки();
			Если ТипЗнч(Источник) = Тип("Массив") Тогда
				ИзображениеДляПроверки = Источник[0];
			Иначе
				ИзображениеДляПроверки = Источник;
			КонецЕсли;
			ЭтотОбъект.ФайлКартинки = ИзображениеДляПроверки;
			ПриИзмененииКартинки();
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаСервере 
// Процедура - получает идентификатор рубрики из временного хранилища.
//
Процедура ПолучитьИдентификаторИзХранилища(АдресВХранилище)
	
	//НастройкиЯндексКарты = Объект.Ссылка.НастройкиЯндексКарты.Получить();
	ЭтаФорма.Модифицированность = Истина;
	
	Для Счетчик = ЯндексИдентификаторРубрики.Количество() по 2 Цикл
		
		Если ЯндексИдентификаторРубрики.Количество() = Счетчик Тогда
			Стр 						= ЯндексИдентификаторРубрики.Добавить();
			Стр.Значение 				= АдресВХранилище;
			Стр.Представление           = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(АдресВХранилище, "_")[1];
			ИД 							= Стр.ПолучитьИдентификатор(); 
			УдалитьДинамическиеЭлементы(Элементы.ГруппаРубрики, Элементы.ГруппаРубрика_Шаблон);
			ПостроитьДинамическиеЭлементы();
			Возврат
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СохранитьКак".
//
Процедура СохранитьКак(Команда)
	
	Индекс 		 = ПолучитьИндексИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
	ФайлКартинки = ЭтотОбъект.ФайлыКартинок.Получить(Индекс - 1).Значение;
	
	ДанныеФайла = ПолучитьДанныеФайла(ФайлКартинки, УникальныйИдентификатор);
	Если ДанныеФайла <> Неопределено Тогда 	
		РаботаСФайламиСлужебныйКлиент.СохранитьКак(Неопределено, ДанныеФайла, УникальныйИдентификатор);
	КонецЕсли;
	
