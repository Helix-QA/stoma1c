// Процедура, заполняет таблицу - динамический реквизит формы "Причины октазов".
//
Процедура ЗаполнитьТаблицуПричинОтказов(Форма, ВидСделки = Неопределено, ПричиныПредопределены = Ложь) Экспорт
	
	Справочники.ПричиныОтказов.ИнициализироватьКоллекциюПричинОтказов(Форма, ВидСделки, ПричиныПредопределены);

КонецПроцедуры

// Процедура, СоздатьКнопкиВиджета.
//
Процедура СоздатьВиджет(Форма, Сделка, ИндексВиджета, ИндексКонтейнера,СделкаПомещенаВАрхив)
	
	Элементы = Форма.Элементы;

	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда
		ДанныеСделки 		= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Сделка, "Наименование, Код, ВидСделки, Врач, Специализация");
		ВидСделки 			= ДанныеСделки.ВидСделки;
		Врач 				= ДанныеСделки.Врач;
		Специализация 		= ДанныеСделки.Специализация;
		ВыводитьВрача 		= (Форма.ИмяФормы = "Справочник.Заявки.Форма.ФормаЭлемента" ИЛИ Форма.ИмяФормы = "Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты");
		ЗаголовокСделки 	= Справочники.Сделки.ИнициализироватьСокращенноеНаименованиеСделки(ДанныеСделки
																								, ВыводитьВрача
																								, Истина
																								, Истина);
		
		Если НЕ ЗначениеЗаполнено(ЗаголовокСделки) Тогда 
	   		НаименованиеСделки = ?(ЗначениеЗаполнено(ДанныеСделки.Наименование), ДанныеСделки.Наименование, Справочники.Сделки.СоздатьНаименованиеСделки(Сделка));
									
			НаименованиеСокращенноеВрача = "";
			Если ВыводитьВрача И ЗначениеЗаполнено(Врач) Тогда 
				НаименованиеСокращенноеВрача = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Врач, "НаименованиеСокращенное");
				Если НЕ ЗначениеЗаполнено(НаименованиеСокращенноеВрача) Тогда 
					НаименованиеСокращенноеВрача = Справочники.Сотрудники.ПолучитьСокращенноеНаименованиеСотрудника(, Врач);	
				КонецЕсли;	
			КонецЕсли;
			ЗаголовокСделки = ?(ЗначениеЗаполнено(НаименованиеСокращенноеВрача), НаименованиеСокращенноеВрача + " ", "") + НаименованиеСделки;					
		КонецЕсли;							
	Иначе		
		ЗаголовокСделки = "+ " + Сделка.Наименование;
		ВидСделки = Сделка;
		Врач = Неопределено;
	КонецЕсли;
	
	ДанныеЗавершающихЭтапов = Справочники.ВидыСделок.ПолучитьНаименованияЗавершающихЭтаповСделки(ВидСделки);
	                        
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"  		 				, "ГруппаТелоВиджета_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("Группировка"  		 				, ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
	ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал"				, ИнтервалМеждуЭлементамиФормы.Нет);
	
	// Создание группы.
	ГруппаКонтейнерСделок = СоздатьГруппуКонтейнерСделок(Форма, ИндексКонтейнера, СделкаПомещенаВАрхив);	
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаКонтейнерСделок);		
	
 	ГруппаВиджет = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
		
	Если ГруппаВиджет.Родитель.Имя = "ВиджетСделки" ИЛИ 
		(НЕ СтрНайти(ГруппаВиджет.Родитель.Имя, "Контейнер") = 0 И ГруппаВиджет.Родитель.Родитель.Имя = "ВиджетСделки") Тогда
		
		// Создаем всплывающую группу, обработчика нажатия на сделку. 
		СоздатьГруппуОткрытьСделку(Форма, Сделка, ГруппаВиджет, ИндексВиджета);
	КонецЕсли;
	
	// Создаем команду кнопки.
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда 	
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатиДинамическогоЭлементаВиджета");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "Сделка_" + ИндексВиджета);
		КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	Иначе 
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатиДинамическогоЭлементаВиджета");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ТекущийЭтап_" + ИндексВиджета);
		КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	КонецЕсли;

	// Создаем кнопку.
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("Заголовок"   	 	 , ЗаголовокСделки);
	ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "Сделка_" + ИндексВиджета);
	ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
	ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
	ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВиджет);		
	
	КнопкаСделки = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	КнопкаСделки.РастягиватьПоГоризонтали = Истина;	

	СоздатьВсплывающуюГруппу(Форма, ГруппаВиджет, Сделка, ИндексВиджета);
	
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") И ЗначениеЗаполнено(Сделка.РезультатСделки) Тогда
		
		ЦветТекстаКнопки = Новый Цвет(255, 255, 255);
		
		КнопкаСделки.Родитель.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Центр;
		КнопкаСделки.Шрифт = Новый Шрифт(КнопкаСделки.Шрифт,, 10);
		
		Если Сделка.РезультатСделки = Перечисления.РезультатыСделок.Успех Тогда			
						       
			ЦветЭтапа = Новый Цвет(72, 193, 123);
		
			Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ЗадачаСсылка.Взаимодействие") // ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ЧленствоПакетУслуг")
				ИЛИ Сделка.ДатаЗавершенияСделки > ТекущаяДатаСеанса()-60*5 Тогда // Показываем сделку в течении 5 минут.
					
				Если ЗначениеЗаполнено(Сделка.Прием) Тогда					
					НомерПродажи 	= ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Сделка.Прием.Номер, "");
					ЗаголовокЭтапа  = НСтр("ru = 'Прием №'; en = 'Reception №'") + НомерПродажи;
				Иначе
					ЗаголовокЭтапа  = НСтр("ru = '(Прием не указан)'; en = '(No reception specified)'");// Строка(Сделка.РезультатСделки);
				КонецЕсли;
						
				// Создаем команду кнопки.	
				ПараметрыКоманды = Новый Структура();
				ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатиДинамическогоЭлементаВиджета");
				ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ТекущийЭтап_" + ИндексВиджета);
				КомандаКнопки =  СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
				
				// Создаем кнопку.
				ПараметрыКнопки = Новый Структура;
				ПараметрыКнопки.Вставить("Заголовок"   	 	 , ДанныеЗавершающихЭтапов.НаименованиеЭтапаУспех);
				ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "ТекущийЭтап_" + ИндексВиджета);
				ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
				ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
				ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
				Если НЕ ЗначениеЗаполнено(Сделка.Прием) Тогда
					ПараметрыКнопки.Вставить("ЦветТекста"  	 , Новый Цвет(255, 0, 0));
				КонецЕсли;	
				ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВиджет);		
				
				КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
				КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;	
				КнопкаЭтапа.ЦветТекста = ЦветТекстаКнопки;
				
				// Создаем команду кнопки.	
				ПараметрыКоманды = Новый Структура();
				ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатиДинамическогоЭлементаВиджета");
				ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ОткрытьПродажу_" + ИндексВиджета);
				КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
				
				// Создаем кнопку.
				ПараметрыКнопки = Новый Структура;
				ПараметрыКнопки.Вставить("Заголовок"   	 	 , ЗаголовокЭтапа);
				ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "ОткрытьПродажу_" + ИндексВиджета);
				ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
				ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
				ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
				ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВиджет);		
				
				КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
				КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;	
				КнопкаЭтапа.ЦветТекста = ЦветТекстаКнопки;
				
			Иначе
				
				Если ЗначениеЗаполнено(Сделка.Прием) Тогда					
					НомерПродажи 	= ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Сделка.Прием.Номер, "");
					ЗаголовокСделки = ЗаголовокСделки + " " + НСтр("ru = 'Прием №'; en = 'Reception №'") + НомерПродажи;
				Иначе
					ЗаголовокСделки = ЗаголовокСделки + " " + Строка(Сделка.РезультатСделки);
				КонецЕсли;				

			КонецЕсли;
		
		Иначе					
			
			ЦветЭтапа = Новый Цвет(246, 110, 110);
			
			Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ЗадачаСсылка.Взаимодействие") // ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ЧленствоПакетУслуг")
				ИЛИ Сделка.ДатаЗавершенияСделки > ТекущаяДатаСеанса()-60*5 Тогда // Показываем сделку в течении 5 минут.
				
	            ЗаголовокЭтапа = ?(ЗначениеЗаполнено(Сделка.ПричинаОтказа), Строка(Сделка.ПричинаОтказа), НСтр("ru = 'Не выбрано'; en = 'Not chosen'"));
				
				// Создаем команду кнопки.	
				ПараметрыКоманды = Новый Структура();
				ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатиДинамическогоЭлементаВиджета");
				ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ТекущийЭтап_" + ИндексВиджета);
				КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
				
				// Создаем кнопку.
				ПараметрыКнопки = Новый Структура;
				Если ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда
					ПараметрыКнопки.Вставить("Заголовок"   	 , ?(ЗначениеЗаполнено(Сделка.ПричинаОтказа), Строка(Сделка.ПричинаОтказа), НСтр("ru = 'Не выбрано'; en = 'Not chosen'")));
				Иначе 
					ПараметрыКнопки.Вставить("Заголовок"   	 , ДанныеЗавершающихЭтапов.НаименованиеЭтапаОтказ);
				КонецЕсли;	
				ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "ТекущийЭтап_" + ИндексВиджета);
				ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
				ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
				ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
				ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВиджет);		
				
				КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
				КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;	
				КнопкаЭтапа.ЦветТекста = ЦветТекстаКнопки;
				
				Если НЕ ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты") Тогда 
					// Создаем команду кнопки.	
					ПараметрыКоманды = Новый Структура();
					ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
					ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ИзменитьЭтапОтказ_" + ИндексВиджета);
					КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
					
					// Создаем кнопку.
					ПараметрыКнопки = Новый Структура;
					ПараметрыКнопки.Вставить("Заголовок"   	 	 , ЗаголовокЭтапа);
					ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "ПараметрыКоманды" + ИндексВиджета);
					ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
					ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
					ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
					ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВиджет);		
					
					КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
					КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;	
					КнопкаЭтапа.ЦветТекста = ЦветТекстаКнопки;
				КонецЕсли;
			Иначе
				
				ЗаголовокСделки = ЗаголовокСделки + " " + ?(ЗначениеЗаполнено(Сделка.ПричинаОтказа), Строка(Сделка.ПричинаОтказа), НСтр("ru = 'Не выбрано'; en = 'Not chosen'"));

			КонецЕсли;
			
		КонецЕсли;	
		
		КнопкаСделки.Заголовок = ЗаголовокСделки;
		
	ИначеЕсли ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда 
		
		Если НЕ ЗначениеЗаполнено(Сделка.ЭтапСделки.ЦветЭтапа)
			ИЛИ ЗначениеИзСтрокиВнутр(Сделка.ЭтапСделки.ЦветЭтапа) = Новый Цвет() Тогда
			
			ЦветЭтапа = Новый Цвет(214, 234, 255);
		Иначе		
			ЦветЭтапа = ЗначениеИзСтрокиВнутр(Сделка.ЭтапСделки.ЦветЭтапа);
		КонецЕсли;
		
		ЦветТекстаКнопки = ПолучитьЦветТекстаПоФону(ЦветЭтапа);
		ЗаголовокЭтапа 	 = ?(ЗначениеЗаполнено(Сделка.ЭтапСделки), Сделка.ЭтапСделки, НСтр("ru = 'Сделка'; en = 'Deal'"));
		
		// Создаем команду кнопки.	
		ПараметрыКоманды = Новый Структура();
