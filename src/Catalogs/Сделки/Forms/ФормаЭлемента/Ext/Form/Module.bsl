&НаКлиенте
// Процедура, обработчик команды "РезультатСделкиУспешно".
//
Процедура РезультатСделкиУспешно(Команда)

	Если Объект.РезультатСделки = ПредопределенноеЗначение("Перечисление.РезультатыСделок.Успех") Тогда 
		Если ЗначениеЗаполнено(Объект.Прием) Тогда 
			ПоказатьЗначение(,Объект.Прием); 
		Иначе 
			ВыбратьРеализацию(Неопределено);
		КонецЕсли;	
	Иначе 	
		НачатьФиксациюЗавершающегоЭтапа("Успех");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "РезультатСделкиОтказ".
//
Процедура РезультатСделкиОтказ(Команда)
	
	НачатьФиксациюЗавершающегоЭтапа("Отказ");
	
КонецПроцедуры

&НаКлиенте
// Процедура - Начать фиксацию завершающего этапа
//
// Параметры:
//  ИмяЗавершающегоЭтапа - 	 - 
//
Процедура НачатьФиксациюЗавершающегоЭтапа(ИмяЗавершающегоЭтапа)
	
	Если Объект.Ссылка.Пустая() Тогда
		ОповещениеПослеЗаписи = Новый ОписаниеОповещения("ОткрытьФормуРезлультатаСделкиПослеЗаписи", ЭтотОбъект, Новый Структура("ИмяЗавершающегоЭтапа", ИмяЗавершающегоЭтапа));
		ПоказатьВопрос(ОповещениеПослеЗаписи
				, НСтр("ru='Для продолжения необходимо произвести запись сделки. Записать?';en='To continue, you must record the transaction. Write down?'")
				, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да
				, НСтр("ru='Вопрос пользователю';en='Question to the user'"));
		
	ИначеЕсли ИмяЗавершающегоЭтапа = "Успех" Тогда 
		Если ВидСделкиПредопределенный Тогда
			Возврат;
		КонецЕсли;	
	ИначеЕсли ИмяЗавершающегоЭтапа = "Отказ" Тогда 
		Если ВидСделкиПредопределенный Тогда
			Если НЕ ЗначениеЗаполнено(Объект.РезультатСделки) ИЛИ НЕ ЗначениеЗаполнено(Объект.ПричинаОтказа) Тогда 
				СписокПричинОтказаВыборНаСервере();
				Возврат;				
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	ОткрытьФормуРезлультатаСделки(ИмяЗавершающегоЭтапа);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Открыть форму резлуьтата сделки после записи.
//
Процедура ОткрытьФормуРезлультатаСделкиПослеЗаписи(РезультатОтвета, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если РезультатОтвета = КодВозвратаДиалога.Да
		И ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ИмяЗавершающегоЭтапа", ""))
		И ЭтаФорма.Записать() Тогда
		
		НачатьФиксациюЗавершающегоЭтапа(ДополнительныеПараметры.ИмяЗавершающегоЭтапа);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Открыть форму резлуьтата сделки.
//
Процедура ОткрытьФормуРезлультатаСделки(ИмяЗавершающегоЭтапа)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ФормаРезультатСделкиЗавершение", ЭтотОбъект); 
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Контрагент"			, Объект.Контрагент);
	ПараметрыФормы.Вставить("Сделка"				, Объект.Ссылка);
	ПараметрыФормы.Вставить("ИмяЗавершающегоЭтапа"	, ИмяЗавершающегоЭтапа);
	
	ОткрытьФорму("Справочник.Сделки.Форма.ФормаРезультатаСделки", ПараметрыФормы, ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик асинхронного события "ФормаРезультатСделкиЗавершение". 
//
Процедура ФормаРезультатСделкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ЗаполнитьЗначенияСвойств(Объект, Результат);
		ОбновитьЭтапыСделки();
		УстановитьВидимостьРезультатаСделки();
		
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "ВыбратьРеализацию".
//
Процедура ВыбратьРеализацию(Команда)
		
	НовоеОповещение = Новый ОписаниеОповещения("ВыбратьРеализациюЗавершение", ЭтотОбъект);
	
	МассивСделок = Новый Массив();
	МассивСделок.Добавить(Объект.Ссылка);
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Контрагент", 			  Объект.Контрагент);
	ПараметрыФормы.Вставить("ВключатьПакетИЧленство", Истина);
	ПараметрыФормы.Вставить("РеализацияБезСделки"	, Истина);
	ПараметрыФормы.Вставить("МассивСделок"			, МассивСделок);
	
	ОткрытьФорму("Документ.Прием.ФормаВыбора", ПараметрыФормы,,,,,НовоеОповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
// Процедура, ВыбратьРеализациюЗавершение.
//
Процедура ВыбратьРеализациюЗавершение(Результат, ДопПараметры) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Возврат;		
	КонецЕсли;
	
	Объект.Прием = Результат;
	РезультатСделкиУспешноНаСервере();
	УстановитьФокусЭлементаСервер();	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "СоздатьРеализацию".
//
Процедура СоздатьРеализацию(Команда)
	
	Структура = Новый Структура();
	Структура.Вставить("Контрагент"			, Объект.Контрагент);
	Структура.Вставить("Сделка"	   			, Объект.Ссылка);
	ПараметрыФормы  = Новый Структура("ЗначенияЗаполнения", Структура);	
	НовоеОповещение = Новый ОписаниеОповещения("СоздатьРеализациюЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.Прием.Форма.ФормаДокумента",ПараметрыФормы,,,,,НовоеОповещение);
	
КонецПроцедуры

&НаСервере
// Процедура, СоздатьРеализациюЗавершение.
//
Процедура СоздатьРеализациюЗавершение(Результат, ДопПараметры) Экспорт
	
	Объект.Прием = ПолучитьПоследнююПродажуПоСделке(Объект.Ссылка);
	Если ЗначениеЗаполнено(Объект.Прием) Тогда
		РезультатСделкиУспешноНаСервере();
		УстановитьФокусЭлементаСервер();		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ОткрытьНастройкаОбязательныеПоля".
//
Процедура ОткрытьНастройкаОбязательныеПоля(Команда)
	
