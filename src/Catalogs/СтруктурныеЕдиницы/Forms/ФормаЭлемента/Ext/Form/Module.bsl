КонецПроцедуры

&НаСервере
// Процедура - Вопрос об удалении картинки завершение на сервере
//
// Параметры:
//  ФайлКартинки - 	 - 
//
Процедура ВопросОбУдаленииКартинкиЗавершениеНаСервере(ФайлКартинки)
	
	ФайлКартинкиОбъект = ФайлКартинки.ПолучитьОбъект();
	ФайлКартинкиОбъект.УстановитьПометкуУдаления(Истина);
	ОтобразитьКартинки();
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
// Процедура, отображает картинки номенклатуры.
//
Процедура ОтобразитьКартинки()
	
	ЭтотОбъект.ФайлыКартинок.Очистить();
	
	МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(Объект.Ссылка, "КартинкаЯндексСалон");
	
	Для Индекс = 1 По 6 Цикл
		
		Если МассивФайловКартинок.Количество() >= Индекс Тогда
			ФайлКартинки = МассивФайловКартинок[Индекс - 1];
			ЭтотОбъект["АдресКартинки" + Индекс] = ПолучитьНавигационнуюСсылкуКартинки(ФайлКартинки, ЭтаФорма.УникальныйИдентификатор);
			ЭтотОбъект.ФайлыКартинок.Добавить(ФайлКартинки);
		КонецЕсли;
		
		Элементы["ПолеКартинки_" + Индекс].Видимость = МассивФайловКартинок.Количество() >= Индекс;
		
	КонецЦикла;
	
	Элементы.ГруппаКнопкиДобавитьКартинку.Видимость = (ЭтотОбъект.ФайлыКартинок.Количество() <= 5);
	
	ГруппаРодитель = ?(ЭтотОбъект.ФайлыКартинок.Количество() > 2, Элементы.ГруппаСтрокаСКартинками_2, Элементы.ГруппаСтрокаСКартинками_1);
	Элементы.Переместить(Элементы.ГруппаКнопкиДобавитьКартинку, ГруппаРодитель);

	МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(Объект.Ссылка, "ЛоготипМагазина");
	МассивФайловКартинокЗаполнен = МассивФайловКартинок.Количество() > 0;
	Если МассивФайловКартинокЗаполнен Тогда
		ЭтотОбъект.ЛоготипМагазина = ПолучитьНавигационнуюСсылкуКартинки(МассивФайловКартинок[0], ЭтаФорма.УникальныйИдентификатор);
	КонецЕсли;
	Элементы.ПолеКартинки_7.Видимость	      = МассивФайловКартинокЗаполнен;
	Элементы.ГруппаДобавитьЛого.Видимость = НЕ МассивФайловКартинокЗаполнен;
	
КонецПроцедуры

// Процедура - Сохранить как
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура СохранитьКак(Команда)
	
	Индекс = ПолучитьИндексИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
	
	Если Индекс = 7 Тогда
		МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(Объект.Ссылка, "ЛоготипМагазина");
		ФайлКартинки		 = ?(МассивФайловКартинок.Количество() > 0, МассивФайловКартинок[0], Неопределено);
	Иначе
		ФайлКартинки = ЭтотОбъект.ФайлыКартинок.Получить(Индекс - 1).Значение;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ФайлКартинки) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = ПолучитьДанныеФайла(ФайлКартинки, УникальныйИдентификатор);
	Если ДанныеФайла <> Неопределено Тогда 	
		РаботаСФайламиСлужебныйКлиент.СохранитьКак(Неопределено, ДанныеФайла, УникальныйИдентификатор);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция возвращает навигационную ссылку картинки
//
Функция ПолучитьНавигационнуюСсылкуКартинки(ФайлКартинки, ИдентификаторФормы)
	
	СсылкаНаДвоичныеДанные = РаботаСФайламиВызовСервераСтоматология.СсылкаНаДвоичныеДанныеФайла(ФайлКартинки, ИдентификаторФормы);
	Возврат ?(СсылкаНаДвоичныеДанные = Неопределено, "", СсылкаНаДвоичныеДанные);
	
КонецФункции

// Процедура - Добавить логотип
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ДобавитьЛоготип(Команда)
	
	# Если НЕ ВебКлиент Тогда
		Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
			Оповещение = Новый ОписаниеОповещения("ВопросОЗаписиОбъектаЗавершение", ЭтотОбъект, Новый Структура("Описание", "ЛоготипМагазина"));
