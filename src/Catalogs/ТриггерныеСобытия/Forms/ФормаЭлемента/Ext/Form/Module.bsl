				ТекстВопроса = НСтр("ru='Данное действие зарегистрировано в ""Журнале событий триггера"". Удаление этого действия в данном триггерном событии не приведет к удалению соответствующих записей в журнале событий. После удаления - регистрация данного действия прекратится.';en='This action is registered in the ""trigger event Log"". Deleting this action in this trigger will not delete the corresponding entries in the event log. After deletion, the registration of this action will stop.'") + Символы.ПС +
								НСтр("ru='Продолжить удаление?';en='Proceed with removal?'");
			Иначе 
				ТекстВопроса = НСтр("ru='Удалить данное действие в триггерном событии?';en='Delete this action in a trigger event?'");
