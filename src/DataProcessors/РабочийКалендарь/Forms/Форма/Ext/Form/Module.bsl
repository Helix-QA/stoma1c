// Функция - Сформировать блок запись
//
// Параметры:
//  ВыводитьБлок - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокЗаписейЛистаОжидания(ВыводитьБлок = Ложь, ТаблицаЛистОжидания)
	
	СтрокиЗаписейЛистаОжидания = "";
	
	СтрокаЗаписиЛистаОжидания =
	"<tr valign='middle'>
	|            <td class='center_colnew1' style='vertical-align: middle;' width='85%'>
	|                <p class='content'><a href='{АдресВХранилище}' id='ЭтоЛистОжидания'>{Запись}</a> </p>
	|            </td>
	|			 <td class='center_colnew1' style='vertical-align: middle; color:#000000;' align='center' width='15%'>     
	|               
	|            </td>
	|        </tr>
	|        <tr>
	|            <td colspan='3' style='height: 8px;'>
	|            </td>
	|        </tr>";
	
	Для Каждого СтрокаТЗ Из ТаблицаЛистОжидания Цикл
		
		ВыводитьБлок = Истина;
		СтрокаЗапись = Формат(СтрокаТЗ.ДатаЗапланированная,"ДФ='гггг, ддд, дд ММММ'")+ ", "+ СтрокаТЗ.СтруктурнаяЕдиница + ", " + СтрокаТЗ.Сотрудник + ", " + СтрокаТЗ.ВидОсмотра;
		
		СтруктураЗаписи = Новый Структура();
		СтруктураЗаписи.Вставить("Период"			 ,СтрокаТЗ.Период);
		СтруктураЗаписи.Вставить("СтруктурнаяЕдиница",СтрокаТЗ.СтруктурнаяЕдиница);
		СтруктураЗаписи.Вставить("Контрагент"		 ,СтрокаТЗ.Контрагент);
		СтруктураЗаписи.Вставить("Сотрудник"		 ,СтрокаТЗ.Сотрудник);
		СтруктураЗаписи.Вставить("ВидОсмотра"		 ,СтрокаТЗ.ВидОсмотра);
		
		МассивСтруктураЗаписи = Новый Массив;
		МассивСтруктураЗаписи.Добавить(СтруктураЗаписи);
		КлючЗаписи = Новый ("РегистрСведенийКлючЗаписи.Профосмотры", МассивСтруктураЗаписи);
		
		АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(КлючЗаписи, Новый УникальныйИдентификатор);
		
		НоваяСтрокаЗаписиЛистаОжидания = СтрЗаменить(СтрокаЗаписиЛистаОжидания     , "{АдресВХранилище}", АдресВоВременномХранилище); 
		НоваяСтрокаЗаписиЛистаОжидания = СтрЗаменить(НоваяСтрокаЗаписиЛистаОжидания, "{Запись}" 		, СтрокаЗапись);
		
		СтрокиЗаписейЛистаОжидания = СтрокиЗаписейЛистаОжидания + НоваяСтрокаЗаписиЛистаОжидания;
		
	КонецЦикла;
	
	Возврат СтрокиЗаписейЛистаОжидания;
	
КонецФункции

&НаСервере
// Функция - Сформировать блок основная информация
//
// Параметры:
//  ВыводитьБлок	 - 	 - 
//  ОбщаяИнформация	 - 	 - 
