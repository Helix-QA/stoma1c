// Процедура - Позвонить клиенту
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПозвонитьКлиенту(Команда)
	
	ОписаниеОшибки = "";
	КонтрагентСсылка = Неопределено;
	Если ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) Тогда 
		КонтрагентСсылка = СтруктураКлиента.СписокКонтрагентов[0].Значение.КонтрагентСсылка;
	КонецЕсли;
	Если ЗначениеЗаполнено(КонтрагентСсылка) ИЛИ ЗначениеЗаполнено(НомерТелефонаКлиента) Тогда 
		IPТелефонияКлиент.ИсходящийЗвонокОсуществитьПоКонтрагенту(КонтрагентСсылка, НомерТелефонаКлиента, ОписаниеОшибки);
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

