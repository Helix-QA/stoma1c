// Функция возвращает слово с учетом языка.
//
Функция ПолучитьСловоСУчетомЯзыка(Слово, ЭтоУкраина)
	
	Возврат МенеджерОборудованияВызовСервера.ПолучитьСловоСУчетомЯзыка(Слово, ЭтоУкраина);
	
КонецФункции

// Функция осуществляет печать нефискальной строки.
//
Функция НапечататьНефискальнуюСтроку(ОбъектДрайвера, Параметры, ПараметрыПодключения, СтрокаТекста, ВыходныеПараметры) Экспорт

	Результат = Истина;

	ТабДок = Параметры.ТабличныйДокумент;
	Макет  = Параметры.Макет;
	
	ОблТовара = Макет.ПолучитьОбласть("ИнформацияОТоваре");
	
	ОблТовара.Параметры.Товар = СтрокаТекста;
	
	ТабДок.Вывести(ОблТовара);

	
	ПараметрыПодключения.СтрокаЛога = ПараметрыПодключения.СтрокаЛога + СтрокаТекста + Символы.ПС;

	Возврат Результат;

КонецФункции

// Функция осуществляет открытие нового чека.
//
Функция ОткрытьЧек(ОбъектДрайвера, Параметры, ПараметрыПодключения, ЧекВозврата, ФискальныйЧек, ВыходныеПараметры) Экспорт

	Результат  = Истина;
	СтрокаЛога = "";
	ЭтоУкраина = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки().Код = "804";

	мНомерСмены = 1;
	//мНомерЧека  = ?(Параметры.Свойство("ПоследнийНомерЧека"), Параметры.ПоследнийНомерЧека + 1, 1);
	
	Если ФискальныйЧек Тогда
		УстановитьПривилегированныйРежим(Истина);
		Попытка
			
			ОбъектПодклОборудования = Параметры.Идентификатор.ПолучитьОбъект();
			НастройкиДо = ОбъектПодклОборудования.Параметры.Получить();
			Если ТипЗнч(НастройкиДо) = Тип("Структура") И НастройкиДо.Свойство("ПоследнийНомерЧека") Тогда
				НастройкиДо.ПоследнийНомерЧека = НастройкиДо.ПоследнийНомерЧека + 1;
			Иначе
				Если Не ТипЗнч(НастройкиДо) = Тип("Структура") Тогда
					НастройкиДо = Новый Структура;
				КонецЕсли;				
				НастройкиДо.Вставить("ПоследнийНомерЧека", 1);
			КонецЕсли;
			ОбъектПодклОборудования.Параметры = Новый ХранилищеЗначения(НастройкиДо);
			
			мНомерЧека  = НастройкиДо.ПоследнийНомерЧека;
			
			ОбъектПодклОборудования.Записать();      		
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка наращивания номера чека для %1. Описание ошибки: %2'"), Параметры.Идентификатор, ОписаниеОшибки));
		КонецПопытки;
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	ТабДок = Новый ТабличныйДокумент;
	Если ЭтоУкраина Тогда
		Макет = Справочники.ДрайверыОборудования.ПолучитьМакет("ЧекWinPrint_UA");
	Иначе
		Макет = Справочники.ДрайверыОборудования.ПолучитьМакет("ЧекWinPrint");
	КонецЕсли;
	
	//ОблРазделение = МенеджерОборудованияСервер.ПолучитьОбластьМакета("Разделение");
	
	Если ФискальныйЧек Тогда
		
		Если Параметры.Свойство("ОтображатьЛоготип") И Параметры.ОтображатьЛоготип 
			И Параметры.Свойство("ЛоготипОрганизации") И ЗначениеЗаполнено(Параметры.ЛоготипОрганизации) Тогда 
			
			ВывестиОбластьЛоготипа(ТабДок, Макет, Параметры);
		КонецЕсли;              
		
		ОблРазделение    = Макет.ПолучитьОбласть("Разделение");
		ОблЗаголовка     = Макет.ПолучитьОбласть("Заголовок");
		ОблДопИнформации = Макет.ПолучитьОбласть("ДопИнформация");
		                 		
		СтрокаЛога = СтрокаЛога + "===== " + ?(ЧекВозврата, ПолучитьСловоСУчетомЯзыка("Открытие чека возврата", ЭтоУкраина), ПолучитьСловоСУчетомЯзыка("Открытие чека продажи", ЭтоУкраина)) + " =====" + Символы.ПС;
		
		СтрокаЛога = СтрокаЛога + "=====" + ?(ФискальныйЧек, "== " + ПолучитьСловоСУчетомЯзыка("Фискальный режим", ЭтоУкраина), " " + ПолучитьСловоСУчетомЯзыка("Нефискальный режим", ЭтоУкраина)) + "=====" + Символы.ПС;
		
		СтрокаЛога = СтрокаЛога + ПолучитьСловоСУчетомЯзыка("Кассир", ЭтоУкраина) + ": " + ОбщегоНазначенияСтоматология.ТекущийПользователь() + Символы.ПС; 
		
		СтрокаЛога = СтрокаЛога + НСтр("ru='№ чека';en='№ check'")   + ": " + Формат(мНомерЧека,  "ЧЦ=4; ЧН=0; ЧВН=")
		+ "    "
		+ "№" + ПолучитьСловоСУчетомЯзыка("смены", ЭтоУкраина) + ": " + Формат(мНомерСмены, "ЧЦ=4; ЧН=0; ЧВН=") + Символы.ПС;
		
		НомерСмены = мНомерСмены;
		НомерЧека  = мНомерЧека;
		
		// Заполнение выходных параметров
		ВыходныеПараметры.Добавить(НомерСмены);
		ВыходныеПараметры.Добавить(НомерЧека);
		ВыходныеПараметры.Добавить(0);
		ВыходныеПараметры.Добавить(ТекущаяДатаСеанса());
		
		ПараметрыПодключения.Вставить("ФискальныйЧек", ФискальныйЧек);
		ПараметрыПодключения.Вставить("ЧекОткрыт"    , Истина);
		ПараметрыПодключения.Вставить("ИтогЧека"     , 0);
		
		ПараметрыПодключения.СтрокаЛога = ПараметрыПодключения.СтрокаЛога + СтрокаЛога;
		
		// заполняем шапку таблицы
		Для Каждого СтрокаШапки Из Параметры.ТаблицаШапкаЧека Цикл
			ОблЗаголовка.Параметры.ТекстЗаголовка = СокрЛП(СтрокаШапки);
			ТабДок.Вывести(ОблЗаголовка);
		КонецЦикла;
		ОблДопИнформации.Параметры.ТекстДопИнформации = ПолучитьСловоСУчетомЯзыка("Кассир", ЭтоУкраина) + ": " + ОбщегоНазначенияСтоматология.ТекущийПользователь();
		ТабДок.Вывести(ОблДопИнформации);
		
		Если ПользователиСлужебныйПовтИсп.ЯзыкИнтерфейсаАнглийский() Тогда
			ДопИнфКНомеруЧека = Параметры.Префикс + "/" + Формат(ТекущаяДата(),"ДФ=yyyy") + "/";
		Иначе
			ДопИнфКНомеруЧека = "";
		КонецЕсли;
		
		ОблДопИнформации.Параметры.ТекстДопИнформации = СтрШаблон(НСтр("ru='%2 №: %1';en='%2 # %1'"), 
																	ДопИнфКНомеруЧека + Формат(мНомерЧека, "ЧЦ=4; ЧВН=; ЧГ=0"),
																	?(ПользователиСлужебныйПовтИсп.ЯзыкИнтерфейсаАнглийский(), ?(ЧекВозврата, "Credit note", "Invoice"), "Чек"));
																	
		//ОблДопИнформации.Параметры.ТекстДопИнформации = "Чек №: " + Формат(НомерЧека, "ЧЦ=11; ЧВН=; ЧГ=0");
		ТабДок.Вывести(ОблДопИнформации);
		
		ОблДопИнформации.Параметры.ТекстДопИнформации = Формат(ТекущаяДата(),"ДЛФ=DT");
		ТабДок.Вывести(ОблДопИнформации);
		ТабДок.Вывести(ОблРазделение);
	Иначе
		// Заполнение выходных параметров
		ВыходныеПараметры.Добавить(мНомерСмены);
		ВыходныеПараметры.Добавить(мНомерЧека);
		ВыходныеПараметры.Добавить(0);
		ВыходныеПараметры.Добавить(ТекущаяДатаСеанса());  
	КонецЕсли;
	
	Параметры.Вставить("ТабличныйДокумент"	, ТабДок);
	Параметры.Вставить("Макет"				, Макет);
	
	Возврат Результат;

КонецФункции

// Функция получает последний номер чека.
//
Функция ПолучитьПоследнийНомерЧека(Параметры) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Попытка    
		ОбъектПодклОборудования = Параметры.Идентификатор.ПолучитьОбъект();
		Настройки = ОбъектПодклОборудования.Параметры.Получить();
		Возврат Настройки.ПоследнийНомерЧека;
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка чтения номера чека для %1. Описание ошибки: %2'"), Параметры.Идентификатор, ОписаниеОшибки));
		Возврат Неопределено;
	КонецПопытки;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции        

#КонецОбласти
