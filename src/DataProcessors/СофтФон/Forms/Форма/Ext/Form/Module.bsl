// Процедура, выполняет добавление звонка в историю
//
Процедура ДобавитьЗвонокВИсториюВхЗвонок(Параметры)
	
	Пропущен = ?(ЗначениеЗаполнено(Параметры.ДатаНачалаРазговора), Ложь, Истина);
	
	СписокЗвонков = ВернутьСписокЗвонков(20, Параметры.Пользователь);
	
	Количество = 1;
	
	Если СписокЗвонков.Количество() = 0 Тогда
		Группировка = Новый УникальныйИдентификатор();
		Количество = 1;
	Иначе		
		Для а = 0 по СписокЗвонков.Количество() - 1 Цикл
			Если СписокЗвонков[а].НомерТелефона = Параметры.Телефон
				и СписокЗвонков[а].Пропущен = Пропущен и Не СписокЗвонков[а].ИсходящийЗвонок Тогда
				Количество = Количество + 1;
				Группировка = СписокЗвонков[а].Группировка;
			ИначеЕсли а = 0 Тогда
				Группировка = Новый УникальныйИдентификатор();
				Количество = 1;
				Прервать;
			Иначе
				Прервать;
			КонецЕсли;			
		КонецЦикла;
	КонецЕсли;
	
	Если Количество > 1 Тогда		
		Для а = 0 По Количество - 2 Цикл			
			МенеджерЗаписи = РегистрыСведений.ИсторияЗвонковУдалить.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, СписокЗвонков[а]);
			МенеджерЗаписи.Прочитать();	
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.КоличествоЗвонков = Количество;
				МенеджерЗаписи.Записать();
			КонецЕсли;
		КонецЦикла; 		
	КонецЕсли;
	
	
	Дата = ?(ЗначениеЗаполнено(Параметры.ДатаНачалаРазговора), Параметры.ДатаНачалаРазговора, ?(ЗначениеЗаполнено(Параметры.ДатаОкончанияРазговора), Параметры.ДатаОкончанияРазговора, ВернутьСерверноеВремя()));
	НаборЗаписей = РегистрыСведений.ИсторияЗвонковУдалить.СоздатьНаборЗаписей();
	
	нТелефон = Параметры.Телефон;
	Если ЗначениеЗаполнено(Параметры.Клиент) Тогда
		СтруктураВозврата = ВернутьАбонемента(Параметры.Телефон);
		нТелефон = СтруктураВозврата.НомерТелефона;
	КонецЕсли;
	
	
	НаборЗаписей.Отбор.Клиент.Установить(Параметры.Клиент);
	НаборЗаписей.Отбор.Период.Установить(Дата);
	НаборЗаписей.Отбор.ПользовательSip.Установить(Параметры.Пользователь);
	НаборЗаписей.Отбор.НомерТелефона.Установить(нТелефон);
	
	НоваяСтрока = НаборЗаписей.Добавить();
	НоваяСтрока.НомерТелефона = нТелефон;
	НоваяСтрока.Клиент = Параметры.Клиент;
	НоваяСтрока.ИсходящийЗвонок = Ложь;
	НоваяСтрока.НачалоРазговора = Дата;
	НоваяСтрока.ОкончаниеРазговора = Параметры.ДатаОкончанияРазговора;
	НоваяСтрока.ПользовательSip = Параметры.Пользователь;
	НоваяСтрока.Период = Дата;
	НоваяСтрока.Статус = Параметры.Статус;
	НоваяСтрока.Пропущен = Пропущен;
	НоваяСтрока.Группировка = Группировка;
	НоваяСтрока.КоличествоЗвонков = Количество;
	НаборЗаписей.Записать();  	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВернутьСписокЗвонков(Порция, Пользователь)
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ "+Порция+"
	                      |	х_ИсторияЗвонков.Период КАК Период,
	                      |	х_ИсторияЗвонков.ПользовательSip,
	                      |	х_ИсторияЗвонков.НомерТелефона,
	                      |	х_ИсторияЗвонков.Клиент,
	                      |	х_ИсторияЗвонков.ИсходящийЗвонок,
	                      |	х_ИсторияЗвонков.НачалоРазговора,
	                      |	х_ИсторияЗвонков.ОкончаниеРазговора,
	                      |	х_ИсторияЗвонков.Пропущен,
	                      |	х_ИсторияЗвонков.Статус,
	                      |	х_ИсторияЗвонков.Группировка,
	                      |	х_ИсторияЗвонков.КоличествоЗвонков
	                      |ИЗ
	                      |	РегистрСведений.ИсторияЗвонковУдалить КАК х_ИсторияЗвонков
	                      |ГДЕ
	                      |	НАЧАЛОПЕРИОДА(х_ИсторияЗвонков.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Период, ДЕНЬ)
	                      |	И х_ИсторияЗвонков.ПользовательSip = &ПользовательSip
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Период УБЫВ");
	Запрос.УстановитьПараметр("Период", 		 ВернутьСерверноеВремя());
	Запрос.УстановитьПараметр("ПользовательSip", Пользователь);
	Возврат Запрос.Выполнить().Выгрузить();		
	
КонецФункции

&НаСервереБезКонтекста
// Процедура, выполняет добавление звонка в историю
//
Процедура ДобавитьЗвонокВИсторию(Клиент, Дата, Телефон, Пользователь, СтатусИсходящегоЗвонка)
	
	СписокЗвонков = ВернутьСписокЗвонков(20, Пользователь);
	
	Количество = 1;
	
	Если СписокЗвонков.Количество() = 0 Тогда
		Группировка = Новый УникальныйИдентификатор();
		Количество = 1;
	Иначе		
		Для а = 0 по СписокЗвонков.Количество() - 1 Цикл
			Если СписокЗвонков[а].НомерТелефона = Телефон и СписокЗвонков[а].ИсходящийЗвонок  Тогда
				Количество = Количество + 1;
				Группировка = СписокЗвонков[а].Группировка;
			ИначеЕсли а = 0 Тогда
				Группировка = Новый УникальныйИдентификатор();
				Количество = 1;
				Прервать;
			Иначе
				Прервать;
			КонецЕсли;			
		КонецЦикла;
	КонецЕсли;
	
	Если Количество > 1 Тогда		
		Для а = 0 По Количество - 2 Цикл			
			МенеджерЗаписи = РегистрыСведений.ИсторияЗвонковУдалить.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи, СписокЗвонков[а]);
			МенеджерЗаписи.Прочитать();	
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.КоличествоЗвонков = Количество;
				МенеджерЗаписи.Записать();
			КонецЕсли;
		КонецЦикла; 		
	КонецЕсли; 
	
	Дата = ?(ЗначениеЗаполнено(Дата), Дата, ВернутьСерверноеВремя());
	НаборЗаписей = РегистрыСведений.ИсторияЗвонковУдалить.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Клиент.Установить(Клиент);
	НаборЗаписей.Отбор.Период.Установить(Дата);
	НаборЗаписей.Отбор.ПользовательSip.Установить(Пользователь);
	НаборЗаписей.Отбор.НомерТелефона.Установить(Телефон);
	
	НоваяСтрока = НаборЗаписей.Добавить();
	НоваяСтрока.НомерТелефона = Телефон;
	НоваяСтрока.Клиент = Клиент;
	НоваяСтрока.ИсходящийЗвонок = Истина;
	НоваяСтрока.НачалоРазговора = Дата;
	НоваяСтрока.ОкончаниеРазговора = ВернутьСерверноеВремя();
	НоваяСтрока.ПользовательSip = Пользователь;
	НоваяСтрока.Период = Дата;
	НоваяСтрока.Группировка = Группировка;
	НоваяСтрока.КоличествоЗвонков = Количество;
	НоваяСтрока.Статус = СтатусИсходящегоЗвонка;
	НоваяСтрока.Пропущен = Ложь;
	НаборЗаписей.Записать();	
		
КонецПроцедуры

