
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Контрагент") Тогда
		Запись.Физлицо = Параметры.Контрагент;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запись.ВидДокумента) И ЗначениеЗаполнено(Запись.Физлицо) Тогда 
		Элементы.ГруппаУдалитьДокумент.Видимость = Истина;
	КонецЕсли;
	
	ЗаполнитьСписокВыбораВидаДокумента();
	УстановитьВидимостьРеквизитов(Истина);
	
КонецПроцедуры

&НаСервере 
// Процедура - Перед записью на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Запись.ВидДокумента.Пустая() Тогда
		
		ТекстОшибки = "Не выбран вид документа."; 
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,"ВидДокументаПостоянная",,Отказ);
		
	КонецЕсли;  
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Удалить документ.
//
Процедура УдалитьДокумент(Команда)
	
	УдалитьДокументНаСервере();	
	Оповестить("ОбновленыУдостоверения");
	Закрыть();

КонецПроцедуры

&НаКлиенте
// Процедура - Сохранить новый документ.
//
Процедура СохранитьНовыйДокумент(Команда)
	
	Если СохранитьДокументНаСервере() Тогда
		Закрыть();
		Оповестить("ОбновленыУдостоверения"); 
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Функция - Документ существует
//
// Параметры:
//  Физлицо		 - 	 - 
//  ВидДокумента - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДокументСуществует(Физлицо, ВидДокумента)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДокументыФизическихЛиц.Представление КАК Представление
		|ИЗ
		|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
		|ГДЕ
		|	ДокументыФизическихЛиц.Физлицо = &Физлицо
		|	И ДокументыФизическихЛиц.ВидДокумента = &ВидДокумента";
	
	Запрос.УстановитьПараметр("ВидДокумента", ВидДокумента);
	Запрос.УстановитьПараметр("Физлицо", Физлицо);
	
	Выборка = Запрос.Выполнить();
	Возврат Выборка.Пустой();
	
КонецФункции

&НаСервере
// Процедура - Удалить документ на сервере.
//
Процедура УдалитьДокументНаСервере()
	
	МенеджерЗаписи = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ВидДокумента = Запись.ВидДокумента;
	МенеджерЗаписи.Физлицо      = Запись.Физлицо;	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		МенеджерЗаписи.Удалить();
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
// Процедура - Удалить документ на сервере.
//
Функция СохранитьДокументНаСервере()
	
	Попытка
		Возврат ЭтаФорма.Записать();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());	
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции 

&НаКлиенте
// Процедура - обработчик события "ПриИзменении"
//
Процедура ВидДокументаПостояннаяПриИзменении(Элемент)
	
	Если ЯвляетсяУдостоверениемЛичности(Запись.Физлицо, Запись.ВидДокумента) Тогда
		Запись.ЯвляетсяДокументомУдостоверяющимЛичность = Истина;
	КонецЕсли;
	
	УстановитьВидимостьРеквизитов(); 
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость реквизитов формы.
//
// Параметры:
//  Нет.
//
Процедура УстановитьВидимостьРеквизитов(ПриСоздании = Ложь)
	
	Если Запись.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.СНИЛС Тогда
		Элементы.СерияПостоянная.Доступность 		    = Ложь;
		Элементы.КодПодразделенияПостоянная.Доступность = Ложь;
		Запись.Серия 									= "";
		Запись.КодПодразделения							= "";
		Запись.КемВыдан = "Пенсионный фонд Российской Федерации";
	Иначе
		Элементы.СерияПостоянная.Доступность 		    = Истина;
		Элементы.КодПодразделенияПостоянная.Доступность = Истина;
		
		Если Не ПриСоздании Тогда 
			Запись.КемВыдан = ""; 
		КонецЕсли;
		
	КонецЕсли;
				
КонецПроцедуры

&НаСервере
// Процедура - Заполнить список выбора вида документа
//
Процедура ЗаполнитьСписокВыбораВидаДокумента()
	
	Элементы.ВидДокументаПостоянная.СписокВыбора.Очистить();
	СписокВыбора = Справочники.ВидыДокументовФизическихЛиц.ПолучитьМассивВидов();
	Для каждого Вид Из СписокВыбора Цикл
	
		Элементы.ВидДокументаПостоянная.СписокВыбора.Добавить(Вид);
	
	КонецЦикла;
	
КонецПроцедуры 

&НаСервереБезКонтекста
// Функция, возвращает булево значение ресурса регистра.
//
Функция ЯвляетсяУдостоверениемЛичности(Физлицо, ВидДокумента)
	
	Возврат РегистрыСведений.ДокументыФизическихЛиц.ЯвляетсяУдостоверениемЛичности(Физлицо, ВидДокумента);
	
КонецФункции

#КонецОбласти
