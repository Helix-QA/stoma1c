	<restrictionTemplate>
		<name>Документ_ПеремещениеДен</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица 
   Где ТекущаяТаблица.СтруктурнаяЕдиница  В (ВЫБРАТЬ
			ДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		ИЗ
			Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК ДоступныеСтруктурныеЕдиницы
		ГДЕ
			ДоступныеСтруктурныеЕдиницы.Ссылка = &amp;ТекущийСотрудник)</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>Документ_СписаниеДен</name>
		<condition>ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица,
Справочник.Пользователи КАК Пользователи 
ГДЕ Пользователи.Ссылка = &amp;ТекущийПользователь
	И ВЫБОР
			КОГДА Пользователи.РольПользователя = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура)
				ТОГДА ТекущаяТаблица.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета)
						ИЛИ ТекущаяТаблица.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
						ИЛИ ТекущаяТаблица.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ТекущаяТаблица.СтруктурнаяЕдиница В (ВЫБРАТЬ
			ДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		ИЗ
			Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК ДоступныеСтруктурныеЕдиницы
		ГДЕ
			ДоступныеСтруктурныеЕдиницы.Ссылка = &amp;ТекущийСотрудник)
</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>ДокументыОказанияУслуг</name>
		<condition>   ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица 
   Где ТекущаяТаблица.СтруктурнаяЕдиница в (ВЫБРАТЬ
			ДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		ИЗ
			Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК ДоступныеСтруктурныеЕдиницы
		ГДЕ
			ДоступныеСтруктурныеЕдиницы.Ссылка = &amp;ТекущийСотрудник)
и
ВЫБОР
			КОГДА ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач) В
					(ВЫБРАТЬ
						Пользователи.РольПользователя
					ИЗ
						Справочник.Пользователи КАК Пользователи
					ГДЕ
						Пользователи.Ссылка = &amp;ТекущийПользователь)
				ТОГДА ВЫБОР
						КОГДА ТекущаяТаблица.Сотрудник В
								(ВЫБРАТЬ
									Пользователи.Сотрудник
								ИЗ
									Справочник.Пользователи КАК Пользователи
								ГДЕ
									Пользователи.Ссылка = &amp;ТекущийПользователь)
							ТОГДА ИСТИНА
						ИНАЧЕ ЛОЖЬ
					КОНЕЦ
			ИНАЧЕ ИСТИНА
		КОНЕЦ</condition>
	</restrictionTemplate>
	<restrictionTemplate>
		<name>ЛицевойСчет</name>
		<condition>
   ТекущаяТаблица ИЗ #ТекущаяТаблица КАК ТекущаяТаблица 
   Где ТекущаяТаблица.СтруктурнаяЕдиница в
     ( ВЫБРАТЬ
 СтруктурныеЕдиницы.Ссылка
 
ИЗ
 Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы,
 Константы КАК Константы
ГДЕ
 ВЫБОР
   КОГДА Константы.РежимРаботыСетиСтоматологий.Ссылка = ЗНАЧЕНИЕ(Перечисление.РежимРаботыСетиСтоматологий.Обособленно)
    ТОГДА СтруктурныеЕдиницы.Ссылка В
      (ВЫБРАТЬ
