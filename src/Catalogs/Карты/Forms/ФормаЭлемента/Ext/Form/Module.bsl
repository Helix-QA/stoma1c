&НаКлиенте
// Процедура, обработчик события "НачалоВыбораИзСписка" элемента "Наименование"
//
Процедура НаименованиеНачалоВыбораИзСписка(Элемент, СтандартнаяОбработка)
	БлокировкаИзмНаименования = Ложь;
	СтандартнаяОбработка = Ложь;

	СформироватьАвтоНаименование();
	ВыбранныйЭлемент = Неопределено;

	ПоказатьВыборИзСписка(Новый ОписаниеОповещения("НаименованиеНачалоВыбораИзСпискаЗавершение", ЭтотОбъект), Элементы.Наименование.СписокВыбора, Элемент);
	 
КонецПроцедуры

