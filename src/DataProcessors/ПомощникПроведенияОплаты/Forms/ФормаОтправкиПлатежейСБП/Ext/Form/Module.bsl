&НаКлиенте                                                         
// Процедура, копирует ссылку оплаты в буфер.
//
Процедура СкопироватьСсылкуОПлатыВБуфер(СсылкаОплаты)
	
	ОбъектHtml = Новый COMОбъект("htmlfile");
	ОбъектHtml.ParentWindow.ClipboardData.Setdata("Text", СсылкаОплаты);  
	ПоказатьОповещениеПользователя("Внимание", ,"Ссылка на оплату скопирована в буфер обмена. " + СсылкаОплаты, БиблиотекаКартинок.КопированиеСтрок);	
	
