// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПриема(Прием, СтатусВизита, Запланировано = Ложь)
	
	Представление = "";
		
	Состояние = "";
	Если Прием.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)'");
	ИначеЕсли НЕ Прием.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)'");
	КонецЕсли;
	
	Статус = "Прием";
	ДатаДокумента = "в " + Формат(Прием.ВремяНачалаПриема, "ДФ=HH:мм") + ?(Запланировано, ", " + Формат(Прием.ВремяНачалаПриема, "ДЛФ=DD"), "");
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 %2 %3'"),
	Статус,
	ДатаДокумента,
	Состояние);
	
	Возврат Представление;
	
КонецФункции

