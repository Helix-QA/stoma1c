// Функция - Получить данные события прием завершен продолжает лечение
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПриемЗавершенПродолжаетЛечение(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	Запрос.УстановитьПараметр("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Прием"				, ОбъектСобытия);

		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументПрием.Ссылка КАК Прием,
		|	ДокументПрием.Контрагент КАК Контрагент,
		|	ДокументПрием.Сотрудник КАК Сотрудник,
		|	ДокументПрием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ ТаблицаПриемов
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ДокументПрием.Проведен
		|	И ДокументПрием.Ссылка = &Прием
		|	И ДокументПрием.РезультатПриема = 2
		|	И ДокументПрием.Контрагент В(&СегментКонтрагентов)
		|	И ДокументПрием.СтатусПациента = &СтатусПациентаПриема
		|	И ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПриемов.Прием КАК Прием,
		|	ТаблицаПриемов.Контрагент КАК Контрагент,
		|	ТаблицаПриемов.Сотрудник КАК Сотрудник,
		|	ТаблицаПриемов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ ТаблицаПриемовКРегистрации
		|ИЗ
		|	ТаблицаПриемов КАК ТаблицаПриемов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ТаблицаПриемов.Контрагент = ЖурналРегистрацииТриггерныхСобытий.Контрагент
		|			И ТаблицаПриемов.Прием = ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		|ГДЕ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПриемовКРегистрации.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаПриемовКРегистрации.Прием КАК Прием,
		|	ТаблицаПриемовКРегистрации.Контрагент КАК Контрагент,
		|	ТаблицаПриемовКРегистрации.Прием КАК ОбъектСобытия,
		|	ТаблицаПриемовКРегистрации.Сотрудник КАК Сотрудник,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаПриемовКРегистрации КАК ТаблицаПриемовКРегистрации
		|
		|СГРУППИРОВАТЬ ПО
		|	ТаблицаПриемовКРегистрации.СтруктурнаяЕдиница,
		|	ТаблицаПриемовКРегистрации.Контрагент,
		|	ТаблицаПриемовКРегистрации.Сотрудник,
		|	ТаблицаПриемовКРегистрации.Прием,
		|	ТаблицаПриемовКРегистрации.Прием";		
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Контрагент В(&СегментКонтрагентов)",
			"ДокументПрием.Контрагент В
			|			(ВЫБРАТЬ
			|				КонтрагентыСегмента.Контрагент
			|			ИЗ
			|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
			|			ГДЕ
			|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СтатусПациентаПриема) Тогда 
			Запрос.УстановитьПараметр("СтатусПациентаПриема", ДанныеТриггера.СтатусПациентаПриема);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.СтатусПациента = &СтатусПациентаПриема", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментУслуг) Тогда 
			Если ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.Номенклатура") Тогда 
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)", "ДокументПрием.Лечение.Номенклатура = &СегментУслуг");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			ИначеЕсли ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)",
				"ДокументПрием.Лечение.Номенклатура В
				|			(ВЫБРАТЬ
				|				НоменклатураСегмента.Номенклатура
				|			ИЗ
				|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
				|			ГДЕ
				|				НоменклатураСегмента.Сегмент = &СегментУслуг)");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			КонецЕсли;	
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДокументПрием.Ссылка КАК Прием,
		|	ДокументПрием.Контрагент КАК Контрагент,
		|	ДокументПрием.Сотрудник КАК Сотрудник,
		|	ДокументПрием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ ТаблицаПриемов
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ДокументПрием.Проведен = ИСТИНА
		|	И НАЧАЛОПЕРИОДА(ДокументПрием.ВремяОкончанияПриема, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|	И ДокументПрием.РезультатПриема = 2
		|	И ДокументПрием.Контрагент В(&СегментКонтрагентов)
		|	И ДокументПрием.СтатусПациента = &СтатусПациентаПриема
		|	И (ЧАС(ДокументПрием.ВремяОкончанияПриема) <> 0
