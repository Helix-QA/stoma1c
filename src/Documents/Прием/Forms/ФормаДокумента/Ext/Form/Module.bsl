// Процедура - Результат приема при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура РезультатПриемаПриИзменении(Элемент)
	
	ЭтаФорма.Модифицированность = Истина;
	НастройкаГруппыРезультатаСервер();
	Если Элементы.ГруппаСсылкаНаНаправление.ПодчиненныеЭлементы.Количество() > 0 Тогда 	
		ЗаголвокФормы                       = Элементы.ГруппаСсылкаНаНаправление.ПодчиненныеЭлементы.ГруппаПрофосмотр0.Заголовок;
		Элементы.ГруппаСанация.Видимость    = ФормаРезультатПриема = 1;
		Элементы.ГруппаПрофосмотр.Видимость = ФормаРезультатПриема = 2;  
	Иначе 	
		Если Объект.РезультатПриема = 2 Тогда
			ФормаПрофосмотрИспользовать = Ложь;
		КонецЕсли; 	
		 
		Если ФормаРезультатПриема = 2 Тогда 
			ФормаПовторныйПриемИспользовать = Истина;
		КонецЕсли; 
		
		Если Элементы.ГруппаРезультатЛечения.Скрыта() Тогда 		
			Элементы.ГруппаРезультатЛечения.Показать();
		КонецЕсли;   
		
		ОчиститьСообщения();  
	КонецЕсли;
	
	Объект.РезультатПриема = ФормаРезультатПриема;
	ОформлениеКнопокПриема();
	
КонецПроцедуры

