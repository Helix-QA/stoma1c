	ЭтаФорма.ТекущийЭлемент = Элементы["КнопкаТекущийЭтап_" + ИндексГурппы];
	
КонецПроцедуры

&НаКлиенте
// Процедура, создает новую сделку клиенту.
//
Процедура СоздатьСделку(Клиент, ВидСделки)
	
	Если НЕ ЗначениеЗаполнено(Клиент)
		И НЕ ЗначениеЗаполнено(ВидСделки) Тогда
		Возврат;
	КонецЕсли;

	СоздатьСделкуНаСервере(ВидСделки, Клиент);	
		
КонецПроцедуры

&НаСервере
// Процедура - Создать сделку на сервере.
//
// Параметры:
//  ВидСделки			 - 	 - 
//  Клиент				 - 	 - 
//  ЧленствоПакетУслуг	 - 	 - 
//
Процедура СоздатьСделкуНаСервере(Знач ВидСделки, Знач Клиент)

	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("Контрагент"	,Клиент);
	ДанныеЗаполнения.Вставить("ВидСделки"	,ВидСделки);
	ДанныеЗаполнения.Вставить("ЭтапСделки"	,Справочники.ВидыСделок.ПолучитьСтартовыйЭтапВидаСделки(ВидСделки));
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.ЭтапСделки) Тогда
		ПричинаНеУказаныЭтапы = НСтр("ru='Для данного вида сделки не указаны этапы.';en='No stages are specified for this type of transaction'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось создать сделку по причине: ';en='Failed to create deal for the reason:'") + Символы.ПС + ПричинаНеУказаныЭтапы);
		Возврат;
	КонецЕсли;		
	ДанныеЗаполнения.Вставить("ДатаСделки"	,ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("КаналПривлечения"  ,Объект.КаналПривлечения); 
	ДанныеЗаполнения.Вставить("ИсточникИнформации",Объект.ИсточникИнформации);
	ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница",ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
	ДанныеЗаполнения.Вставить("ИсточникИнформацииЗначение",Объект.ИсточникИнформацииЗначение);
	
	НоваяСделка = Справочники.Сделки.СоздатьЭлемент();		
	НоваяСделка.Заполнить(ДанныеЗаполнения);
	
	Попытка
		
		НоваяСделка.Записать();
		// ОбновитьВиджетИСтатусКонтрагента();
		
	Исключение
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось создать сделку по причине: ';en='Failed to create deal for the reason:'") + ОписаниеОшибки());
		
	КонецПопытки;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция, ПолучитьПоследнююПродажуПоСделке.
//
Функция ПолучитьПоследнююПродажуПоСделке(Сделка)
	
	Если НЕ ЗначениеЗаполнено(Сделка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Прием.Ссылка КАК Продажа
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Прием.Дата УБЫВ";
	Запрос.УстановитьПараметр("Сделка", Сделка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ЗначениеВозврата = ?( Выборка.Следующий(), Выборка.Продажа, Неопределено);
	
	Возврат ЗначениеВозврата;
		
КонецФункции

&НаКлиенте
// Процедура, ПоказатьСделкиАрхива.
