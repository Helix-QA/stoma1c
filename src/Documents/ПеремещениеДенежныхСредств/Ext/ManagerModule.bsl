// Функция возвращает таблицу реквизитов, зависимых от хозяйственной операции документа.
//
Функция ПолучитьМассивСостоянияРеквизитов(ОбъектФормы) Экспорт
	
	МассивРеквизитов = Новый Массив;
	
	// Состояния реквизитов по умолчанию
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ИсточникВидЛицевогоСчета",,Ложь);
    УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ПриемникВидЛицевогоСчета",,Ложь);
	
	// Состояние реквизитов в зависимости типа ден. средств
	Если ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
		
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ИсточникСписанияСредств",,,,,"Касса",Новый ОписаниеТипов("СправочникСсылка.Кассы"));	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ПриемникЗачисленияСредств",,,,,"Касса",Новый ОписаниеТипов("СправочникСсылка.Кассы"));	
		
	ИначеЕсли ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		 
		
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ИсточникСписанияСредств",,,,,"Счет",Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ПриемникЗачисленияСредств",,,,,"Счет",Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));	
		
	ИначеЕсли ОбъектФормы.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
		
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ИсточникСписанияСредств",,,,,"Пациент",Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));	
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ПриемникЗачисленияСредств",,,,,"Пациент",Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));	

		Если Константы.ИспользоватьВидыЛицевыхСчетов.Получить() Тогда
			УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ИсточникВидЛицевогоСчета",,Истина);
			УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов,"ПриемникВидЛицевогоСчета",,Истина);		
		КонецЕсли;
		
	КонецЕсли;
		
	Возврат МассивРеквизитов;
	
КонецФункции // ПолучитьМассивыРеквизитов()

// Получить массив обязательных для заполнения реквизитов реквизитов
Процедура ПолучитьМассивыОбязательныхРеквизитов(ДокументОбъект,МассивОбязательныхРеквизитов) Экспорт
	
	МассивОбязательныхРеквизитов.Добавить("ТипДенежныхСредств");
	МассивОбязательныхРеквизитов.Добавить("ИсточникСтруктурнаяЕдиница");
	МассивОбязательныхРеквизитов.Добавить("ПриемникСтруктурнаяЕдиница");
	МассивОбязательныхРеквизитов.Добавить("ИсточникСписанияСредств");
	МассивОбязательныхРеквизитов.Добавить("ПриемникЗачисленияСредств");
	МассивОбязательныхРеквизитов.Добавить("СуммаДокумента");

	// Состояние реквизитов в зависимости от типа денежных средств
	Если ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
		
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда		 
		
	ИначеЕсли ДокументОбъект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда	
		
		Если Константы.ИспользоватьВидыЛицевыхСчетов.Получить() Тогда
			МассивОбязательныхРеквизитов.Добавить("ИсточникВидЛицевогоСчета");
			МассивОбязательныхРеквизитов.Добавить("ПриемникВидЛицевогоСчета");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

