// Процедура - Изменить структурную единицу на сервере.
//
Процедура ИзменитьСтруктурнуюЕдиницуНаСервере(Знач Результат)
	
	Если Объект.СтруктурнаяЕдиница <> Результат Тогда
		
		Объект.Услуги.Очистить();
		НоваяСтрокаОбъектУслуги = Объект.Услуги.Добавить();
		НоваяСтрокаОбъектУслуги.ДатаНачала    = ТекущаяДатаСеанса();
		НоваяСтрокаОбъектУслуги.ДатаОкончания = НоваяСтрокаОбъектУслуги.ДатаНачала + 3600;
		НоваяСтрокаОбъектУслуги.НормаВремени  = (НоваяСтрокаОбъектУслуги.ДатаОкончания - НоваяСтрокаОбъектУслуги.ДатаНачала) / 60;

		Объект.СтруктурнаяЕдиница = Результат;
		Элементы.ВыбратьСтруктурнуюЕдиницу.Заголовок = Объект.СтруктурнаяЕдиница;
		ОбновитьНадписи();
		ОбновитьПолисыМедицинскогоСтрахования();		
		ВывестиНезавершенныеНарядЗаказы();
		
	КонецЕсли;

КонецПроцедуры

