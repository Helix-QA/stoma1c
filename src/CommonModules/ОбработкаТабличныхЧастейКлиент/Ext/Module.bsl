// Процедура, заполняет дерево структурных единиц.
//
Процедура ЗаполнитьДеревоСтруктурныхЕдиниц(МассивСтруктурныхЕдиниц, ЭлементЗаполнения, Форма, 
	СоответствиеИндексамКартинок = Неопределено, ОтображатьПервыйУровеньДерева, ОбъектОграничения)
	
	Если МассивСтруктурныхЕдиниц.Количество() > 1 ИЛИ ОтображатьПервыйУровеньДерева Тогда
		
		НоваяСтрока              	   = ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
		НоваяСтрока.СтруктурнаяЕдиница = "Все клиники";
		НоваяСтрока.ЭтоГруппа		   = Истина;
		
		Если СоответствиеИндексамКартинок <> Неопределено 
			И ТипЗнч(СоответствиеИндексамКартинок) = Тип("Соответствие") Тогда
			
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл	
				НоваяСтрокаГруппы              		 = НоваяСтрока.ПолучитьЭлементы().Добавить();
				НоваяСтрокаГруппы.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
				НоваяСтрокаГруппы.ЭтоГруппа			 = Ложь;
				
				Индекс 						  		 = СоответствиеИндексамКартинок.Получить(СтруктурнаяЕдиница);
				НоваяСтрокаГруппы.ИндКартинки 		 = ?(Индекс = Неопределено, 1, Индекс);	
			КонецЦикла;
			
		Иначе
			
			Для Каждого СтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл	
				НоваяСтрокаГруппы              		 = НоваяСтрока.ПолучитьЭлементы().Добавить();
				НоваяСтрокаГруппы.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
				НоваяСтрокаГруппы.ЭтоГруппа			 = Ложь;
				НоваяСтрокаГруппы.ИндКартинки 		 = 1;	
			КонецЦикла;
			
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

// Функция, рекурсивно устанавливает флаги на группы.
//
Функция УстановитьНачальноеСостояниеФлагов(ДанныеДерева, МассивСтруктурныхЕдиниц, КоличествоСтруктурныхЕдиниц, 
	УстановитьЗначениеВсехФлагов = Неопределено, ДоступныеКассы = Ложь, НаименованиеКолонки = Неопределено) Экспорт
	
	КоличествоВыбранныхСтрок = 0;
	Колонка = ?(ЗначениеЗаполнено(НаименованиеКолонки), НаименованиеКолонки, "Выгружать");	
	Для Каждого УровеньДерева ИЗ ДанныеДерева Цикл
		
		Если УровеньДерева.ЭтоГруппа Тогда
			
			УровеньДерева[Колонка] = УстановитьНачальноеСостояниеФлагов(УровеньДерева.ПолучитьЭлементы(), МассивСтруктурныхЕдиниц, КоличествоСтруктурныхЕдиниц, УстановитьЗначениеВсехФлагов, ДоступныеКассы, НаименованиеКолонки);
			
		Иначе
			
			УстановитьФлагиВИстину = УстановитьЗначениеВсехФлагов = Истина;
			
			Если УстановитьЗначениеВсехФлагов = Ложь Тогда
				
				УровеньДерева[Колонка] = Ложь;	
				
			ИначеЕсли МассивСтруктурныхЕдиниц <> Неопределено ИЛИ УстановитьФлагиВИстину Тогда
				
				Если ДоступныеКассы = Истина Тогда
					УровеньДерева[Колонка]  = УстановитьФлагиВИстину ИЛИ МассивСтруктурныхЕдиниц.Найти(УровеньДерева.Касса) <> Неопределено;
				Иначе
					Если Колонка = "Выгружать" Тогда
						УровеньДерева[Колонка] = УстановитьФлагиВИстину ИЛИ МассивСтруктурныхЕдиниц.Найти(УровеньДерева.СтруктурнаяЕдиница) <> Неопределено;	
					КонецЕсли;	
				КонецЕсли;
				
			КонецЕсли;
			
			КоличествоВыбранныхСтрок = КоличествоВыбранныхСтрок + УровеньДерева[Колонка];
			
		КонецЕсли;
		
	КонецЦикла;
		
	Если КоличествоВыбранныхСтрок <> 0 И КоличествоВыбранныхСтрок = КоличествоСтруктурныхЕдиниц Тогда
		Возврат 1;
	ИначеЕсли КоличествоВыбранныхСтрок > 0 Тогда
		Возврат 2;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Процедура, обработчик события "ПриИзменении".
//
Процедура УстановитьФлагиНаСтруктурныеЕдиницы(Форма, ТипПодбора = "ПодборСтруктурныеЕдиницы", НаименованиеКолонки = Неопределено) Экспорт
	
	Если ТипПодбора = "ПодборСтруктурныеЕдиницы" Тогда
		ТекущиеДанные = Форма.Элементы.ПодборСтруктурныеЕдиницы.ТекущиеДанные;
	ИначеЕсли ТипПодбора = "ПодборМестаРаботыСотрудника" Тогда
		ТекущиеДанные = Форма.Элементы.ПодборМестаРаботыСотрудника.ТекущиеДанные;
	ИначеЕсли ТипПодбора = "ПодборЖурналыПриемовСотрудника" Тогда
		ТекущиеДанные = Форма.Элементы.ПодборЖурналыПриемовСотрудника.ТекущиеДанные;
	Иначе
		ТекущиеДанные = Форма.Элементы.ПодборДоступныеКассы.ТекущиеДанные;
	КонецЕсли;
	
	Колонка = ?(ЗначениеЗаполнено(НаименованиеКолонки), НаименованиеКолонки, "Выгружать"); 
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные[Колонка] = ?(ТекущиеДанные[Колонка] = 2, 0, ТекущиеДанные[Колонка]);
	
	Если ТекущиеДанные.ЭтоГруппа Тогда
		
		Для Каждого СтрокаДерева Из ТекущиеДанные.ПолучитьЭлементы() Цикл
			СтрокаДерева[Колонка] = ТекущиеДанные[Колонка];
		КонецЦикла;
		
	Иначе
		
		ГруппаСтруктурныхЕдиниц = ТекущиеДанные.ПолучитьРодителя();
		
		Если ГруппаСтруктурныхЕдиниц <> Неопределено Тогда
			
			МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
			ДоступныеКассы = (ТипПодбора = "ПодборДоступныеКассы");
			ЗаполнитьМассивВыбранныхСтруктурныхЕдиниц(ГруппаСтруктурныхЕдиниц.ПолучитьЭлементы(), МассивВыбранныхСтруктурныхЕдиниц, ДоступныеКассы, НаименованиеКолонки);
			КоличествоСтруктурныхЕдиниц = ГруппаСтруктурныхЕдиниц.ПолучитьЭлементы().Количество();
			
			Если МассивВыбранныхСтруктурныхЕдиниц.Количество() = КоличествоСтруктурныхЕдиниц Тогда
				ГруппаСтруктурныхЕдиниц[Колонка] = 1;
			ИначеЕсли МассивВыбранныхСтруктурныхЕдиниц.Количество() > 0 Тогда
				ГруппаСтруктурныхЕдиниц[Колонка] = 2;
			Иначе
				ГруппаСтруктурныхЕдиниц[Колонка] = 0;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Рекурсивный метод обхода дерева и выбора структурных единиц, установленных в Истину
//
Функция ЗаполнитьМассивВыбранныхСтруктурныхЕдиниц(ДанныеДерева, МассивВыбранныхСтруктурныхЕдиниц, ДоступныеКассы = Ложь, НаименованиеКолонки = Неопределено) Экспорт
	
	Колонка = ?(ЗначениеЗаполнено(НаименованиеКолонки), НаименованиеКолонки, "Выгружать"); 
	
	Для Каждого УровеньДерева ИЗ ДанныеДерева Цикл
		
		ЗаполнитьМассивВыбранныхСтруктурныхЕдиниц(УровеньДерева.ПолучитьЭлементы(), МассивВыбранныхСтруктурныхЕдиниц, ДоступныеКассы, НаименованиеКолонки);
		
		Если НЕ УровеньДерева.ЭтоГруппа
			И УровеньДерева[Колонка] Тогда
			
			Если ДоступныеКассы = Ложь Тогда 
				МассивВыбранныхСтруктурныхЕдиниц.Добавить(УровеньДерева.СтруктурнаяЕдиница);
			Иначе
				МассивВыбранныхСтруктурныхЕдиниц.Добавить(УровеньДерева.Касса);
			КонецЕсли;
			ЕстьДобавленныеЕлементы = Истина;

		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции

&НаСервере
// Процедура, выполянет создание дерева доступных касс.
//
Процедура СоздатьДеревоДоступныхКасс(Форма, ОбъектОграничения, МассивКасс, МассивДоступныхКасс, 
	СоответствиеИндексамКартинок, ЗаполнитьПервыйУровеньДерева = Ложь) Экспорт
	
	ЭлементДерево            = Форма.ПодборДоступныеКассы;
	ПервыйУровеньДерева 	 = ЭлементДерево.ПолучитьЭлементы();
	ПервоначальноеЗаполнение = ПервыйУровеньДерева.Количество() = 0;
	
	Если ПервоначальноеЗаполнение Тогда
				
		ЗаполнитьДеревоКасс(МассивКасс, ЭлементДерево, Форма, ЗаполнитьПервыйУровеньДерева, СоответствиеИндексамКартинок);
		МассивВыбранныхКасс = МассивДоступныхКасс;
		
	Иначе
		
		ДанныеДерева = ПервыйУровеньДерева[0].ПолучитьЭлементы();
		
		ДобавленыеСтруктурныеЕдиницы = Новый Массив;
		
		Для Каждого СтрокаДерева Из ДанныеДерева Цикл
			
			Если МассивКасс.Найти(СтрокаДерева.Касса) = Неопределено Тогда
				ДанныеДерева.Удалить(СтрокаДерева);
			Иначе
				МассивДоступныхКасс.Добавить(СтрокаДерева.Касса);
			КонецЕсли;
			
		КонецЦикла;
		
		Если СоответствиеИндексамКартинок <> Неопределено
			И ТипЗнч(СоответствиеИндексамКартинок) = Тип("Соответствие") Тогда
			
			Для Каждого Касса Из МассивКасс Цикл	
				Если МассивДоступныхКасс.Найти(Касса) = Неопределено Тогда
					НоваяСтрока             	   = ДанныеДерева.Вставить(0);
					НоваяСтрока.Касса       	   = Касса;
					
					Индекс 						   = СоответствиеИндексамКартинок.Получить(Касса);
					НоваяСтрока.ИндКартинки 	   = ?(Индекс = Неопределено, 1, Индекс);
				КонецЕсли;	
			КонецЦикла;
			
		Иначе
			
			Для Каждого Касса Из МассивКасс Цикл
				Если МассивДоступныхКасс.Найти(Касса) = Неопределено Тогда
					НоваяСтрока 				   = ДанныеДерева.Вставить(0);
					НоваяСтрока.Касса	 		   = Касса;
					НоваяСтрока.ИндКартинки 	   = 1;	
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
		МассивВыбранныхКасс = Неопределено;
		
	КонецЕсли;
	КоличествоКасс = МассивКасс.Количество();
	УстановитьНачальноеСостояниеФлагов(ЭлементДерево.ПолучитьЭлементы(), МассивВыбранныхКасс, КоличествоКасс,, Истина);
	
КонецПроцедуры

// Процедура, заполняет дерево касс.
//
Процедура ЗаполнитьДеревоКасс(МассивКасс, ЭлементЗаполнения, Форма, ЗаполнитьПервыйУровеньДерева = Ложь, СоответствиеИндексамКартинок = Неопределено)
	
	Если МассивКасс.Количество() > 0 Или ЗаполнитьПервыйУровеньДерева = Истина Тогда
		
		НоваяСтрока              	    = ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Касса               = "Все кассы";
		НоваяСтрока.ЭтоГруппа		    = Истина;
		
		Если СоответствиеИндексамКартинок <> Неопределено 
			И ТипЗнч(СоответствиеИндексамКартинок) = Тип("Соответствие") Тогда
			
			Для Каждого Касса Из МассивКасс Цикл
				
				НоваяСтрокаГруппы             = НоваяСтрока.ПолучитьЭлементы().Добавить();
				НоваяСтрокаГруппы.Касса       = Касса;
				НоваяСтрокаГруппы.ЭтоГруппа   = Ложь;
				
				Индекс 						  = СоответствиеИндексамКартинок.Получить(Касса);
				НоваяСтрокаГруппы.ИндКартинки = ?(Индекс = Неопределено, 1, Индекс);
				
			КонецЦикла;
			
		Иначе
			
			Для Каждого Касса Из МассивКасс Цикл
				
				НоваяСтрокаГруппы             = НоваяСтрока.ПолучитьЭлементы().Добавить();
				НоваяСтрокаГруппы.Касса       = Касса;
				НоваяСтрокаГруппы.ЭтоГруппа   = Ложь;
				НоваяСтрокаГруппы.ИндКартинки = 1;
				
			КонецЦикла;
			
		КонецЕсли;
		
		
	//	
	//ИначеЕсли МассивКасс.Количество() = 1 Тогда
	//	
	//	НоваяСтрокаГруппы              	= ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
	//	НоваяСтрокаГруппы.Касса         = МассивКасс[0];
	//	НоваяСтрокаГруппы.ЭтоГруппа     = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, рекурсивно устанавливает флаги в дереве.
//
Процедура РекурсивноУстановитьФлагиВДереве(Дерево, ИмяКолонкиЭлемента, ИмяКолонкиФлага, ТаблицаИзмененныхЗначений) Экспорт
	
	ТекущиеДанные = Дерево.ТекущиеДанные;
	
	Если ТекущиеДанные.ЭтоГруппа Тогда
		
		Если ТекущиеДанные[ИмяКолонкиФлага] = 2 Тогда
			ТекущиеДанные[ИмяКолонкиФлага] = 0;
		КонецЕсли; 
		
		УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонкиЭлемента, ИмяКолонкиФлага, ТаблицаИзмененныхЗначений);
		УстановитьФлагиНаГруппы(ТекущиеДанные, Истина, ИмяКолонкиЭлемента, ИмяКолонкиФлага);
		
	Иначе
		
		Если ТекущиеДанные[ИмяКолонкиФлага] = 2 Тогда
			ТекущиеДанные[ИмяКолонкиФлага] = 0;
		КонецЕсли;
		
		ИзменитьВыбранныеРесурсы(ТекущиеДанные, ТаблицаИзмененныхЗначений, ИмяКолонкиЭлемента);
		УстановитьФлагиНаГруппы(ТекущиеДанные,, ИмяКолонкиЭлемента, ИмяКолонкиФлага);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет установку флагов на элменеты.
//
Процедура УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонкиЭлемента, ИмяКолонкиФлага, ТаблицаИзмененныхЗначений)
	
	ДанныеДерева = ТекущиеДанные.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из ДанныеДерева Цикл
		
		СтрокаДерева[ИмяКолонкиФлага] = ТекущиеДанные[ИмяКолонкиФлага];
		
		Если СтрокаДерева.ЭтоГруппа Тогда
			УстановитьФлагиНаЭлементы(СтрокаДерева, ИмяКолонкиЭлемента, ИмяКолонкиФлага, ТаблицаИзмененныхЗначений);
		Иначе
			ИзменитьВыбранныеРесурсы(СтрокаДерева, ТаблицаИзмененныхЗначений, ИмяКолонкиЭлемента);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает флаги на группы.
//
Процедура УстановитьФлагиНаГруппы(ТекущиеДанные, ЭтоРодитель = Ложь, ИмяКолонкиЭлемента, ИмяКолонкиФлага)
	
	Если ЭтоРодитель Тогда
		Родитель = ТекущиеДанные;
	Иначе
		Родитель = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	Если Родитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДерева = Родитель.ПолучитьЭлементы();
	
	КоличествоВыбранных = 0;
	Для Каждого СтрокаДерева Из ДанныеДерева Цикл
		Если СтрокаДерева[ИмяКолонкиФлага] = 1 Тогда
			КоличествоВыбранных = КоличествоВыбранных + 1;
		ИначеЕсли СтрокаДерева[ИмяКолонкиФлага] = 2 Тогда
			КоличествоВыбранных = -1;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоВыбранных = ДанныеДерева.Количество() Тогда
		Родитель[ИмяКолонкиФлага] = 1;
	ИначеЕсли КоличествоВыбранных = 0 Тогда
		Родитель[ИмяКолонкиФлага] = 0;
	Иначе
		Родитель[ИмяКолонкиФлага] = 2;
	КонецЕсли;		
	
	УстановитьФлагиНаГруппы(Родитель,, ИмяКолонкиЭлемента, ИмяКолонкиФлага);
	
КонецПроцедуры

&НаКлиенте
// Процедура, изменяет таблицу выбранных ресурсов.
//
Процедура ИзменитьВыбранныеРесурсы(СтрокаДерева, ТаблицаИзмененныхЗначений, ИмяКолонкиЭлемента)
	
	МассивСтрок = ТаблицаИзмененныхЗначений.НайтиСтроки(Новый Структура(ИмяКолонкиЭлемента, СтрокаДерева[ИмяКолонкиЭлемента]));
	
	Если МассивСтрок.Количество() > 0 Тогда
		МассивСтрок[0][ИмяКолонкиЭлемента] = СтрокаДерева[ИмяКолонкиЭлемента];
	Иначе
		НоваяСтрока = ТаблицаИзмененныхЗначений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДерева);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает флаги на группы при первоночальном построение дерева.
//
Процедура УстановитьНачальныеФлагиНаГруппы(Родитель, ИмяКолонки) Экспорт
	
	ДанныеДерева = Родитель.ПолучитьЭлементы();
	
	КоличествоВыбранных = 0;
	Для Каждого СтрокаДерева из ДанныеДерева Цикл
		
		Если СтрокаДерева.ЭтоГруппа Тогда
			УстановитьНачальныеФлагиНаГруппы(СтрокаДерева, ИмяКолонки);			
		КонецЕсли;
		
		Если КоличествоВыбранных <> -1 Тогда
			Если СтрокаДерева[ИмяКолонки] = 1 Тогда
				КоличествоВыбранных = КоличествоВыбранных + 1;
			ИначеЕсли СтрокаДерева[ИмяКолонки] = 2 Тогда
				КоличествоВыбранных = -1;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Если КоличествоВыбранных = ДанныеДерева.Количество() Тогда
		Родитель[ИмяКолонки] = 1;
	ИначеЕсли КоличествоВыбранных = 0 Тогда
		Родитель[ИмяКолонки] = 0;
	Иначе
		Родитель[ИмяКолонки] = 2;
	КонецЕсли;			
	
КонецПроцедуры

