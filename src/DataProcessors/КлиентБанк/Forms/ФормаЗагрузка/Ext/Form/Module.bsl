// Процедура - обработчик команды ЗагрузкаОбновить.
//
&НаКлиенте
Процедура ЗагрузкаОбновитьВыполнить(Команда)
	
	Если НЕ ПроверитьЗаполнениеРеквизитовФормы() Тогда		
		Возврат;	
	КонецЕсли;
	
	ПрочитатьДанныеИзФайла(Неопределено);
	
КонецПроцедуры // ЗагрузкаОбновитьВыполнить()

// Процедура - обработчик команды Загрузить.
//
&НаКлиенте
Процедура ЗагрузитьВыполнить(Команда)
	
	ОчиститьСообщения();	
	Если НЕ ПроверитьЗаполнениеРеквизитовФормы() Тогда		
		Возврат;		
	КонецЕсли;	
	Если Объект.Загрузка.Количество() > 0 Тогда		
		ЗагрузитьДанныеИзФайла();		
		Если РасширениеРаботыСФайламиПодключено Тогда			
			ТекстПредупреждения = ЗаполнитьДокументыНаИмпорт(ПотокЧтения.ПолучитьТекст()); // Обновление таблицы.
			Если ЗначениеЗаполнено(ТекстПредупреждения) Тогда
				ПоказатьПредупреждение(Неопределено,ТекстПредупреждения);
			КонецЕсли;		
		КонецЕсли;		
		ПоказатьПредупреждение(Неопределено,НСтр("ru = 'Загрузка платежных документов завершена.'"));	
		ОповеститьОбИзменении(ПредопределенноеЗначение("Документ.ПоступлениеДенежныхСредств.ПустаяСсылка"));
		ОповеститьОбИзменении(ПредопределенноеЗначение("Документ.СписаниеДенежныхСредств.ПустаяСсылка"));
	Иначе		
		ПоказатьПредупреждение(Неопределено,НСтр("ru = 'Список документов для загрузки пуст.'"));		
	КонецЕсли;
	
КонецПроцедуры // ЗагрузитьВыполнить()

