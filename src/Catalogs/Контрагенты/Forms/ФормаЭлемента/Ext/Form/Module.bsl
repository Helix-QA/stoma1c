#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображатьКод = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	
	Элементы.Код.Видимость          = ОтображатьКод;
	Элементы.Код.ПоложениеЗаголовка = ?(ОтображатьКод, ПоложениеЗаголовкаЭлементаФормы.Авто, ПоложениеЗаголовкаЭлементаФормы.Нет);
		
	Если Параметры.Свойство("ЗначенияЗаполнения") И Параметры.ЗначенияЗаполнения.Свойство("ТипКонтрагента") Тогда  
		Объект.ТипКонтрагента = Параметры.ЗначенияЗаполнения.ТипКонтрагента;
		Элементы.ТипКонтрагента.ТолькоПросмотр = Объект.ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания;
	КонецЕсли;
	
	Если Параметры.Свойство("Родитель") Тогда
		Объект.Родитель = Параметры.Родитель;
	КонецЕсли;
	
	ЮрЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
	
	УстановитьВидимостьРеквизитов();	
	
	//// Обработчик механизма "Контактная информация".
	//УправлениеКонтактнойИнформацией.ПриСозданииНаСервере(ЭтаФорма, Объект, "ГруппаКонтактнаяИнформация");
	
	// Контактная информация
	КонтактнаяИнформацияСервер.ПриСозданииПриЧтенииНаСервере(ЭтаФорма, Объект);
		
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Объект, "СтраницаДополнительныеРеквизиты");	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
	Если Не Объект.Ссылка.Пустая() И Объект.ТипКонтрагента <> Перечисления.ТипыКонтрагентов.Клиенты Тогда
		Элементы.ГруппаДоговорыКонтрагентов.Видимость = Истина;
		ВывестиДоговорыКонтрагентов();
	Иначе
		Элементы.ГруппаДоговорыКонтрагентов.Видимость = Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ТипКонтрагента) Тогда // И НЕ ЗначениеЗаполнено(Объект.ЭтоНеСтраховаяКомпания) 
		
		Если Объект.ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания Тогда
			Элементы.ГруппаМетка.Видимость = Истина;

			Если ЗначениеЗаполнено(Объект.ЦветФонаМетки) Тогда
				Элементы.УстановкаЦвет.ЦветФона = ЗначениеИзСтрокиВнутр(Объект.ЦветФонаМетки);	
			КонецЕсли;
			
			Элементы.УстановкаЦвет.Заголовок = Объект.КраткоеНаименование; 
			
			Объект.ЭтоНеСтраховаяКомпания = Ложь;
			ПараметрыОпций = Новый Структура("Контрагент", Объект.Ссылка);
			УстановитьПараметрыФункциональныхОпцийФормы(ПараметрыОпций);
		Иначе
			Объект.ЭтоНеСтраховаяКомпания = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	ИзменитьАктивностьПереключателяФормыНаСервере(Элементы.ГруппаДоговорыДействующие, Элементы.ГруппаДоговорыАрхив);
	
	ПроверитьИННиКППиОКПО(СтруктураДляПроверкиИННиКППиОКПО(ЭтаФорма, Истина, Истина,Истина), ЭтаФорма);
	
	ВнешняяСистемаКС = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.КонтурСтрахование, Истина);
	Если ЗначениеЗаполнено(ВнешняяСистемаКС) Тогда
		Элементы.ИдентификаторКонтурСтрахование.Видимость = Истина;                
	КонецЕсли;                                        
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
		
	Если ЗначениеЗаполнено(Объект.Родитель) и ЭтоПапкаКлиентов(Объект.Родитель) и (Не Объект.ЭтоГруппа) Тогда 
	
		ЭтаФорма.Закрыть();
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда // откроем форму существующего элемента.  						
			ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты",  Новый Структура("Ключ", Объект.Ссылка));  
		Иначе // если это новый элемент, тогда открываем форму нового клиента.   			
			ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты",  Новый Структура("ТекущийРодитель", Объект.Родитель));  
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	//// Обработчик механизма "Контактная информация".
	//УправлениеКонтактнойИнформацией.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	
	// КонтактнаяИнформация
	КонтактнаяИнформацияСервер.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Конец КонтактнаяИнформация

	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
		
	Если ТекущийОбъект.ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания Тогда
		ТекущийОбъект.ЭтоНеСтраховаяКомпания = Ложь;
	Иначе
		ТекущийОбъект.ЭтоНеСтраховаяКомпания = Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// Обработчик механизма "Свойства".
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
		ОбновитьДополнительныеРеквизиты();
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьИнформациюОДоговорах" И Параметр = Объект.Ссылка Тогда
		ВывестиДоговорыКонтрагентов();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды "ДобавитьСтрокуДоговора".
//
Процедура ДобавитьСтрокуДоговора(Команда)
	
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.ФормаОбъекта", Новый Структура("Контрагент", Объект.Ссылка), ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события Выполнить команды РедактироватьСоставСвойств.
//
Процедура Подключаемый_СвойстваВыполнитьКоманду(Команда)
	
