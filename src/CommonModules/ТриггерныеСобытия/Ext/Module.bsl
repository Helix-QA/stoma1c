#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	Сделки.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	Сделки.Ссылка.Контрагент КАК Контрагент,
		               |	Сделки.Ссылка КАК ОбъектСобытия,
		               |	Сделки.Ссылка.ВидСделки КАК ВидСделки,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ТаблицаСделок
		               |ИЗ
		               |	Справочник.Сделки.ИсторияИзмененияЭтапов КАК Сделки
		               |ГДЕ
		               |	Сделки.Ссылка.ПометкаУдаления = ЛОЖЬ
		               |	И Сделки.Ссылка.ВидСделки = &ВидСделки
		               |	И Сделки.Ссылка.Контрагент В(&СегментКонтрагентов)
		               |	И НАЧАЛОПЕРИОДА(Сделки.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |	И Сделки.ПереходСЭтапа = &ПереходСЭтапа
		               |	И Сделки.ПереходНаЭтап = &ПереходНаЭтап
		               |	И Сделки.Ссылка.Контрагент.ОбезличенныйКлиент = ЛОЖЬ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Сделки.Ссылка.СтруктурнаяЕдиница,
		               |	Сделки.Ссылка,
		               |	Сделки.Ссылка.Контрагент,
		               |	Сделки.Ссылка.ВидСделки
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК Сделка
		               |ПОМЕСТИТЬ ТаблицаОтработанныхСделок
		               |ИЗ
		               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |ГДЕ
		               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		               |	И ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия В
		               |			(ВЫБРАТЬ
		               |				ТаблицаСделок.ОбъектСобытия
		               |			ИЗ
		               |				ТаблицаСделок)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ТаблицаСделок.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ТаблицаСделок.Контрагент КАК Контрагент,
		               |	ТаблицаСделок.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаСделок.ВидСделки КАК ВидСделки,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаСделок КАК ТаблицаСделок
		               |ГДЕ
		               |	НЕ ТаблицаСделок.ОбъектСобытия В
		               |				(ВЫБРАТЬ
		               |					ТаблицаОтработанныхСделок.Сделка
		               |				ИЗ
		               |					ТаблицаОтработанныхСделок)";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Ссылка.Контрагент В(&СегментКонтрагентов)",
			"Сделки.Ссылка.Контрагент В
			|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
			|				ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты)
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов И НЕ ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты) ЕСТЬ NULL)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Ссылка.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидСделки) Тогда
			Запрос.УстановитьПараметр("ВидСделки", ДанныеТриггера.ВидСделки);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Ссылка.ВидСделки = &ВидСделки", "ИСТИНА");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ПереходСЭтапа) Тогда 
			Запрос.УстановитьПараметр("ПереходСЭтапа", ДанныеТриггера.ПереходСЭтапа);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.ПереходСЭтапа = &ПереходСЭтапа", "ИСТИНА");
