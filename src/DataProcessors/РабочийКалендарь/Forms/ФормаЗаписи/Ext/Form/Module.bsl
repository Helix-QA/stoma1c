// Процедура - обработчик команды открытия формы списка планирования
//
Процедура ЗаписатьИзОчереди(Команда)
	
	Область = Элементы.ТабличныйДокумент.ТекущаяОбласть;
	
	Если ВыводитьОповещениеОНерабочемДнеКлиники(ПЗРасшифровкаТекущейОбласти.Дата,"ЗаписатьИзОчереди")Тогда		
		Возврат;		
	КонецЕсли;
	
	Сотрудник = Неопределено;
	
	ДатаСлотаНачало = ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / 4) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / 4) * 4 * 15 * 60;
	ДатаСлотаОкончание = ДатаСлотаНачало + (Область.Низ - Область.Верх + 1) / 4 * 60 * 60;
	
	Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) Тогда 
		Если ТипЗнч(ПЗРасшифровкаТекущейОбласти.Сотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда 
			Сотрудник = ПЗРасшифровкаТекущейОбласти.Сотрудник;
		ИначеЕсли ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники") Тогда 
			Сотрудник = ПЗФиьтрГрафикаТекущаяСтрока;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники") Тогда 
		Сотрудник = ПЗФиьтрГрафикаТекущаяСтрока;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("ДатаСлотаНачало, ДатаСлотаОкончание", ДатаСлотаНачало, ДатаСлотаОкончание);
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		ОткрытьЛистОжиданияПациентов(Сотрудник, ДатаСлотаНачало, ПараметрыОткрытия, Истина);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды Вырезать.
//
Процедура ПравкаВырезать(Команда)
	
	Если НЕ ПЗРасшифровкаТекущейОбласти = Неопределено И ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие)
		И ПолучитьПризнакБлокировкиСтрокиВТЧУслуги(ПЗРасшифровкаТекущейОбласти.Событие, ПЗРасшифровкаТекущейОбласти.ИндексВТЧ) = Ложь Тогда
		// Проверка статуса записи
		СтатусСобытия = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ПЗРасшифровкаТекущейОбласти.Событие, "Статус");	
		Если СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемНеСостоялся")
			ИЛИ СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемОкончен")
			ИЛИ СтатусСобытия = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемОтменен") Тогда
			ПоказатьПредупреждение(,"Статус записи: """ + СтатусСобытия + """ эту запись нельзя вырезать!");
			Возврат;
		КонецЕсли;		
		БуферОбмена.ПризнакВырезать = Истина;
		БуферОбмена.Буфер           = Новый Структура("Событие, ИндексВТЧ", ПЗРасшифровкаТекущейОбласти.Событие, ПЗРасшифровкаТекущейОбласти.ИндексВТЧ);
	КонецЕсли;
	
КонецПроцедуры 

