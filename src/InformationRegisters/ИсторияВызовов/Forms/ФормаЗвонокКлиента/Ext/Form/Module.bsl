// Процедура - Отменить прием завершение
//
Процедура ОтменитьПриемЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		СобытиеОбъект = ДопПараметры.Событие.ПолучитьОбъект();
		СобытиеОбъект.ПричинаОтмены = Результат;
		СобытиеОбъект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.ПриемОтменен");
		СобытиеОбъект.Записать(); 
		УстановитьВидимостьЭлементовФормы();
	КонецЕсли;
	
КонецПроцедуры

