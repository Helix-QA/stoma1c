
#Область ОбработчикиСобытий

// Процедура, обработчик события "ПередЗаписью"
//
Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураРеквизитов = Новый Структура("ЭтоНовый, КодДоИзменения", НЕ ЗначениеЗаполнено(ЭтотОбъект.Ссылка), Ссылка.КодКарты);
	
	ЭтотОбъект.ДополнительныеСвойства.Вставить("КартаДоИзменения", СтруктураРеквизитов);
	
	ЭтоНоваяКартаWallet = ЭтоНовый() И ТипКода = Перечисления.ВидыКарт.Wallet;
	ОбновитьКарту 	    = Не ЭтоНовый() И ТипКода = Перечисления.ВидыКарт.Wallet 
	И ВладелецКарты <> Ссылка.ВладелецКарты И ЗначениеЗаполнено(ЭтотОбъект.ВнутреннийКодКарты); // сменился владелец, обновляем карту
	
	Если Не ПометкаУдаления И Не ЭтотОбъект.ДополнительныеСвойства.Свойство("ВнешнийИсточник") Тогда   
		
		Если ЭтоНоваяКартаWallet Или ОбновитьКарту Тогда
			
			ВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.Wallet);
			
			Если Не (ЗначениеЗаполнено(ВнешняяСистемаWallet.ТокенДоступа) И ЗначениеЗаполнено(ВнешняяСистемаWallet.КлючШифрования)) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не найдена или не настроена внешняя система ""Wallet""",,,, Отказ);
				Возврат;
			КонецЕсли;
			
			Если ЭтоНоваяКартаWallet Тогда
				
				Результат = Справочники.Карты.СоздатьКартуWallet(ВнешняяСистемаWallet, ВидКарты.ИдентификаторПроекта, ЭтотОбъект.ВладелецКарты);
				
				ВнутреннийКодКарты     = Результат.ВнутреннийКодКарты;
				КодКарты		       = Результат.КодКарты;
				СсылкаНаУстановкуКарты = Результат.Ссылка;
				
			Иначе // обновляем карту
				
				Результат = Справочники.Карты.ОбновитьКартуWallet(ЭтотОбъект, ВнешняяСистемаWallet, Истина);
				
			КонецЕсли; 
			
			Если ЗначениеЗаполнено(Результат.ОписаниеОшибки) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
			КонецЕсли;
			
			Отказ = Не Результат.Успешно; 
			
			ЭтотОбъект.Наименование = ?(Не Отказ, Строка(ЭтотОбъект.КодКарты) +", " + Строка(ЭтотОбъект.ВладелецКарты) + " (" + ЭтотОбъект.ТипКода + ")", "");	
			
			
			Если Результат.СинхронизироватьНомерТелефона Тогда
				ЭтотОбъект.ДополнительныеСвойства.Вставить("СинхронизироватьНомерТелефона");
			КонецЕсли;  
			
		ИначеЕсли ТипКода = Перечисления.ВидыКарт.Штриховая И ЗначениеЗаполнено(КодКарты) Тогда 
			
			Отказ = Справочники.Карты.ПроверитьНаличиеШтрихКода(Ссылка, КодКарты);  			
			
		ИначеЕсли ТипКода = Перечисления.ВидыКарт.Магнитная
			И ЗначениеЗаполнено(КодКарты) Тогда
			
			Отказ = Справочники.Карты.ПроверитьНаличиеМагнитногоКода(Ссылка, КодКарты);
			
		КонецЕсли;	
		
	КонецЕсли;
	
	// Карта создана через виджет Wallet,
	// отправляем данные владельца для обновления полей карты.
	
	Если ЭтоНоваяКартаWallet = Истина
		И ЭтотОбъект.ДополнительныеСвойства.Свойство("ВнешнийИсточник")
		И ЭтотОбъект.ДополнительныеСвойства.ВнешнийИсточник = Истина Тогда
		
		ВнешняяСистемаWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.Wallet);
		
		Если ЗначениеЗаполнено(ВнешняяСистемаWallet.ТокенДоступа) И ЗначениеЗаполнено(ВнешняяСистемаWallet.КлючШифрования) Тогда
			
			Результат = Справочники.Карты.ОбновитьКартуWallet(ЭтотОбъект, ВнешняяСистемаWallet, Ложь);
			ЭтотОбъект.ДополнительныеСвойства.Вставить("СинхронизироватьНомерТелефона");

		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обработчик события "ПриЗаписи" элемента справочника
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка = Истина Тогда		
		 Возврат;		 
	КонецЕсли;
	
	Если ПометкаУдаления И ТипКода = Перечисления.ВидыКарт.Штриховая Тогда 		
		
		НаборЗаписей = РегистрыСведений.Штрихкоды.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Объект.Использование = Истина;
		НаборЗаписей.Отбор.Объект.Значение      = Ссылка;
		НаборЗаписей.Записать();
		
	ИначеЕсли Не ПометкаУдаления И (ТипКода = Перечисления.ВидыКарт.Штриховая
										Или ТипКода = Перечисления.ВидыКарт.Wallet) Тогда
		
		Если ЗначениеЗаполнено(КодКарты) Тогда
			Отказ = Справочники.Карты.ПроверитьНаличиеШтрихКода(Ссылка, КодКарты);
		КонецЕсли;
		
		// очистка данных из регистра
		НаборЗаписей = РегистрыСведений.Штрихкоды.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Объект.Установить(Ссылка);
		НаборЗаписей.Записать(); 
		
		Если ЗначениеЗаполнено(КодКарты) Тогда
			// добавление данных в регистр
			НоваяЗапись = НаборЗаписей.Добавить();	
			НоваяЗапись.Объект   = Ссылка;
			НоваяЗапись.Штрихкод = СокрЛП(КодКарты);
			НаборЗаписей.Записать();
		КонецЕсли; 

	ИначеЕсли Не ПометкаУдаления
		И ТипКода = Перечисления.ВидыКарт.Магнитная
		И ЗначениеЗаполнено(КодКарты) Тогда
		
		Отказ = Справочники.Карты.ПроверитьНаличиеМагнитногоКода(Ссылка, КодКарты);
		
	КонецЕсли;
	
	// Номер телефона не синхронизировался при создании/обновлении карты,
	// синхронизируем через регламент
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("СинхронизироватьНомерТелефона") Тогда
		
		КонтактнаяИнформация = Справочники.Контрагенты.ПолучитьКонтактнуюИнформациюКлиента(ЭтотОбъект.ВладелецКарты, Истина);
		
		Если ЗначениеЗаполнено(КонтактнаяИнформация.Телефон) Тогда		
			
			НомерТелефонаВрем = ?(Лев(КонтактнаяИнформация.Телефон, 1) = "+", КонтактнаяИнформация.Телефон, "+" + КонтактнаяИнформация.Телефон); 
			РегистрыСведений.СтекОбновленияЭлектронныхКарт.ДобавитьЗаписьВСтек(ЭтотОбъект.Ссылка, "phone_number", НомерТелефонаВрем);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
			
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	
	Если ТипДанныхЗаполнения = Тип("Структура") Тогда 
		
		Если ДанныеЗаполнения.Свойство("ЭтоРегистрацияПосещения") Тогда  
			
			ВладелецКарты = ДанныеЗаполнения.ВладелецКарты;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ТипКода = Перечисления.ВидыКарт.Wallet Тогда
		
		Если ПроверяемыеРеквизиты.Найти("ВладелецКарты") = Неопределено Тогда
			ПроверяемыеРеквизиты.Добавить("ВладелецКарты");			
		КонецЕсли;
		
		Если ПроверяемыеРеквизиты.Найти("ВидКарты") = Неопределено Тогда
			ПроверяемыеРеквизиты.Добавить("ВидКарты");			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
