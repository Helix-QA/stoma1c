		ДанныеНомера.Вставить("Идентификатор"	, СтрокаКИ.ПолучитьИдентификатор());
		ДанныеНомера.Вставить("НомерТелефона"	, НомерТелефона);
		ДанныеНомера.Вставить("ИзмененныйНомер"	, "");
		
		ЭтотОбъект.ИзменяемыеТелефоныМессенджера.Добавить(ДанныеНомера);
		
	КонецЦикла;
	
