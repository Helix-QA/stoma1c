// Процедура, Обработчик события "ПослеОткрытияФормыУстановкиРучнойСкидки".
//
Процедура ПослеОткрытияФормыУстановкиРучнойСкидки(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда		
		Если Результат.ЗаполнитьВсеСтроки Тогда 
			Для Каждого СтрокаТЧ Из Объект.Лечение Цикл
				Если РазрешенаУстановкаСкидки(СтрокаТЧ) Тогда
					СтрокаТЧ.ПроцентСкидкиНаценки = Результат.ПроцентСкидки;
					ОбработкаТабличныхЧастейКлиент.ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(СтрокаТЧ, Истина);
					ТабличныеЧастиРассчитатьСуммуВСтроке(СтрокаТЧ);
				КонецЕсли;
			КонецЦикла;		
		Иначе 
			ТекущаяСтрока                      = Элементы.ТаблицаЛечение.ТекущиеДанные;
			ТекущаяСтрока.ПроцентСкидкиНаценки = Результат.ПроцентСкидки;
			ОбработкаТабличныхЧастейКлиент.ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(ТекущаяСтрока, Истина);
			ТабличныеЧастиРассчитатьСуммуВСтроке(ТекущаяСтрока);			
		КонецЕсли;
		ПересчитатьАвтоматическиеСкидкиИОбновитьЗаголовкиТабЧастей();
	КонецЕсли;   
	
КонецПроцедуры

