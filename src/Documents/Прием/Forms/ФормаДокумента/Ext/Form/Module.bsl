&НаСервереБезКонтекста
// Процедура закрывает доступ рекламаторам
//
Процедура ИнициализацияДоступаРекламаторам(Режим, 
	                                       ЭтоВыборДокумента = Ложь, 
										   ВыбранныйПрием = Неопределено,
										   МассивДокументов_ = Неопределено,
										   Контрагент,
										   АвторДокумента, 
										   СтруктурнаяЕдиница,
										   УникальныйИдентификаторДоступа)
	
	УстановитьПривилегированныйРежим(Истина);
	МассивДокументов = Новый Массив;
	Если ЭтоВыборДокумента Тогда
		// Получим все приемы контрагента для формы выбора
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Прием.Ссылка КАК ДокументПрием
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	НЕ Прием.ПометкаУдаления
		|	И Прием.Проведен
		|	И Прием.Контрагент = &Контрагент
		|	И Прием.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
		
		Запрос.УстановитьПараметр("Контрагент"        , Контрагент);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		
		МассивДокументов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументПрием");	
	Иначе
		МассивДокументов = МассивДокументов_;
		// Получим все приемы контрагента из реквизита "Рекламация" табличной части "Лечение" документа Прием
		// Для Каждого СтрокаТЧ Из Объект.Лечение Цикл 
		//	Если ЗначениеЗаполнено(СтрокаТЧ.Рекламация) Тогда 
		//		МассивДокументов.Добавить(СтрокаТЧ.Рекламация);
		//	КонецЕсли;	
		// КонецЦикла;	
	КонецЕсли;                                               
	СтруктураПараметров = Новый Структура;                 
	СтруктураПараметров.Вставить("Режим"                         , Режим);
	СтруктураПараметров.Вставить("СтруктурнаяЕдиница"            , СтруктурнаяЕдиница);
	СтруктураПараметров.Вставить("АвторДокумента"                , АвторДокумента);
	СтруктураПараметров.Вставить("МассивДокументов"              , МассивДокументов);
	СтруктураПараметров.Вставить("ВыбранныйДокумент"             , ВыбранныйПрием);
	СтруктураПараметров.Вставить("УникальныйИдентификаторДоступа", УникальныйИдентификаторДоступа);		
	РегистрыСведений.Рекламаторы.ИнициализацияДоступаРекламаторам(СтруктураПараметров);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры	

&НаСервере
// Процедура устанавливает видимость колонки "Рекламация"
//
Функция ИнициализацияВидимостиКолонкиРекламация(ТЧ_Лечение);
	
	ЕстьРекламация = Ложь;
	Для Каждого ЭлементыТЧ Из ТЧ_Лечение Цикл
		Если ЗначениеЗаполнено(ЭлементыТЧ.Рекламация) Тогда 
			ЕстьРекламация = Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат ЕстьРекламация;

КонецФункции

&НаКлиенте
// Процедура, обработчик события ОбработкаОповещения
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			ПолученыШтрихкоды(Данные);
		ИначеЕсли ИмяСобытия = "TracksData" Тогда
			Если Параметр[1] = Неопределено Тогда
				Если ПолученКодКарты(Параметр[0], Параметр[0]) Тогда 
					КонтрагентПриИзменении(Неопределено);
				КонецЕсли;	
			Иначе
				Если ПолученКодКарты(Параметр[0], Параметр[1][1]) Тогда 
					КонтрагентПриИзменении(Неопределено);
				КонецЕсли;	
			КонецЕсли;
		ИначеЕсли ИмяСобытия = "DataCollectionTerminal" Тогда
			ПолученыШтрихкоды(Параметр);
		КонецЕсли;
	КонецЕсли;
	// Конец ВнешнееОборудование 
	
	Если Источник = "ВнешнееОборудование" И ИмяСобытия = "НеизвестныеШтрихкоды" 
			И УникальныйИдентификатор = Параметр.ФормаВладелецУникальныйИдентификатор Тогда
		ПолученыШтрихкоды(Параметр.ЗарегистрированныеШтрихкоды);
	КонецЕсли;
		
	Если ИмяСобытия = "ФлагПодбора" Тогда
		ОткрыватьПодбор = Не Параметр;
	ИначеЕсли ИмяСобытия = "ЗАПИСЬ_В_РЕГИСТР_ПРОФОСМОТРЫ" Тогда
	 
	ИначеЕсли ИмяСобытия = "ИЗМЕНЕН_СТАТУС_ПЛАНА_ЛЕЧЕНИЯ" Тогда
		УстановитьВидимостьНадписиСНезавершеннымиПланамиЛечения();
	КонецЕсли;	
	Если ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА_АВАНСА" Тогда
		ЭтаФорма.Прочитать();
	КонецЕсли;			
	
	Если ИмяСобытия = "ОбновитьСогласованияСтраховыхУслуг" Тогда
		ОбновитьСогласованияСтраховыхУслуг(Параметр);
	КонецЕсли;	
		
	Если ИмяСобытия = "ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ" Тогда
		ЭтаФорма.Прочитать();
		ОбновитьВиджетСделки();
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьИнформациюОСсылкахНаОплату" И ТипЗнч(Параметр) = Тип("Массив") И Параметр.Найти(Объект.Ссылка) <> Неопределено Тогда
		
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();
		
	ИначеЕсли ИмяСобытия = "СБП_УспешнаяОплата" Тогда
		
		ОбсужденияСистемыВзаимодействияКлиент.ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметр);	
		
	КонецЕсли;
	
КонецПроцедуры

