	Если ЗначениеЗаполнено(ВыбранноеЗначение) И ЗначениеЗаполнено(Объект.Сделка) И НЕ Объект.Ссылка.Пустая() Тогда 
		Если НЕ ВрачСоответствуетСделке(ВыбранноеЗначение, Объект.Сделка) Тогда 
			СтандартнаяОбработка = Ложь;
			ВыбранноеЗначение = Объект.Услуги[СтруктураДанныхЭлемента.ИндексСтроки].Сотрудник;
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Выбранный врач не соответствует врачу, указанному в сделке!'"), , "Объект.Услуги[" + Формат(СтруктураДанныхЭлемента.ИндексСтроки, "ЧН=0; ЧГ=0") + "].Сотрудник");
