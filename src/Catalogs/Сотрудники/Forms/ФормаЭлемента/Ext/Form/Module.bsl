&НаСервере
// Функция - Получить параметры свойств полей КИ
//
// Параметры:
//  ВладелецКИ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыСвойствПолейКИ(Знач ВладелецКИ)
	
	ПараметрыСвойствПолейКИ = Новый Структура("Надпись_МаксимальнаяШирина, Представление_МаксимальнаяШирина_БезКомм, Представление_МаксимальнаяШирина_СКомм, Комментарий_МаксимальнаяШирина, ТолькоПросмотр");
	
	Если ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.Сотрудники") Тогда 
		
		Если РольДоступна(Метаданные.Роли.ПолныеПрава) ИЛИ РольДоступна(Метаданные.Роли.ДобавлениеИзменениеКлиентов) ИЛИ НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
			КИ_ТолькоПросмотр = Ложь;
		Иначе 
			КИ_ТолькоПросмотр = Истина;
		КонецЕсли;	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 9;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 40;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 29;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 9;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= КИ_ТолькоПросмотр;
		
	ИначеЕсли ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.Сотрудники") Тогда	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 6;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 41;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 31;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 8;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= Ложь;
		
	ИначеЕсли ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.СтруктурныеЕдиницы") Тогда	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 13;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 79;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 58;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 19;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= Ложь;
		
	ИначеЕсли ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.Организации") Тогда	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 10;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 46;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 35;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 9;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= Ложь;
		
	КонецЕсли;
	
	Возврат ПараметрыСвойствПолейКИ;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьКонтактнуюИнформациюВидВыбран(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("Вид", ВыбранныйЭлемент.Значение);
	
	НайденныеСтроки = ЭтаФорма.СвойстваВидовКонтактнойИнформации.НайтиСтроки(Отбор);
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СвойстваВида = НайденныеСтроки[0];
	
	ДобавитьКонтактнуюИнформациюСервер(ВыбранныйЭлемент.Значение);

КонецПроцедуры

&НаСервере
// Процедура - Добавить контактную информацию сервер
//
// Параметры:
//  ДобавляемыйВид				 - 	 - 
//  УстановитьВыводВФормеВсегда	 - 	 - 
//
Процедура ДобавитьКонтактнуюИнформациюСервер(ДобавляемыйВид, УстановитьВыводВФормеВсегда = Ложь) Экспорт
	
	МассивСтрок   			= ЭтаФорма.КонтактнаяИнформация.НайтиСТроки(Новый Структура("Вид", ДобавляемыйВид));
	ТекущийВидКИУжеДобавлен = МассивСтрок.Количество() > 0;
	ИндексВставки 			= ?(ТекущийВидКИУжеДобавлен, ЭтаФорма.КонтактнаяИнформация.Индекс(МассивСтрок[МассивСтрок.Количество() - 1]) + 1, ЭтаФорма.КонтактнаяИнформация.Количество());
	
	ДанныеКИ = ЭтаФорма.КонтактнаяИнформация.Вставить(ИндексВставки);
	
	Если Объект.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ДобавляемыйВид)).Количество() = 0 Тогда
		Объект.КонтактнаяИнформация.Добавить();
	Иначе
		Объект.КонтактнаяИнформация.Вставить(ИндексВставки);
	КонецЕсли;
	ДанныеКИ.Вид = ДобавляемыйВид;
	ДанныеКИ.Тип = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДобавляемыйВид, "Тип"); // под вопросом
	
	ОбновитьЭлементыКонтактнойИнформации();
	ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы["ПредставлениеКИ_" + ИндексВставки];
	  	
КонецПроцедуры

&НаКлиенте
