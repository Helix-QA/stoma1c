#Область ФильтрацияДанныхИсторииВзаимодействия

&НаКлиенте 
// Процедура - Показать фильтры.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПоказатьФильтры(Команда)  
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
	ПараметрыФормы.Вставить("СписокФильтрацииИсторииВзаимодействия", СписокФильтрацииИсторииВзаимодействия);
	
	ФормаФильтровОписаниеОповещения = Новый ОписаниеОповещения("ВыборФильтровИсторииВзаимодействияЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаФильтровИсторииВзаимодействия", ПараметрыФормы,,,,, ФормаФильтровОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс); 
		
КонецПроцедуры

&НаСервере 
// Процедура - Выбор фильтров истории взаимодействия завершение.
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ВыборФильтровИсторииВзаимодействияЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	СписокФильтрацииИсторииВзаимодействия = Результат;	
	
	Если НЕ Объект.Ссылка.Пустая() Тогда		
		ОбновитьИсториюВзаимодействияСКлиентом();
	КонецЕсли;
	
	ФильтрПрименен = ФильтрПрименен(СписокФильтрацииИсторииВзаимодействия);	
	Элементы.ОчиститьФильтры.Видимость	= ФильтрПрименен;
	Элементы.ПоказатьФильтры.Картинка	= ?(ФильтрПрименен, БиблиотекаКартинок.ФильтрУстановлен, БиблиотекаКартинок.ФильтрНеУстановлен);
	
	ОбщегоНазначения.ХранилищеСистемныхНастроекСохранить("Справочники.Сделки.Форма.ФормаЭлемента", "НастройкиФильтрации", СписокФильтрацииИсторииВзаимодействия);
		
КонецПроцедуры

&НаКлиенте 
// Процедура - Декорация фильтры очистить нажатие.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ОчиститьФильтры(Команда)
	
	ОбщегоНазначенияКлиентСерверСтоматология.ЗаполнитьСписокФильтрацииИсторииВзаимодействияПоУмолчанию(СписокФильтрацииИсторииВзаимодействия,,, Объект.Ссылка);	

	Элементы.ОчиститьФильтры.Видимость	= Ложь;
	Элементы.ПоказатьФильтры.Картинка	= БиблиотекаКартинок.ФильтрНеУстановлен;
	
	ОбщегоНазначения.ХранилищеСистемныхНастроекСохранить("Справочники.Сделки.Форма.ФормаЭлемента", "НастройкиФильтрации", СписокФильтрацииИсторииВзаимодействия);

	Если НЕ Объект.Ссылка.Пустая() Тогда		
		ОбновитьИсториюВзаимодействияСКлиентом();
	КонецЕсли;
	
КонецПроцедуры

