						НовыйПолучатель.СервисРассылки 	= СтрокаНомераТелефона.АккаунтСервисаРассылкиSMS;
					Иначе 
						РассылкаЗапрещена = Истина;
					КонецЕсли;					
				КонецЕсли;
			КонецЕсли;	
		Иначе 	
