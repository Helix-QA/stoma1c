	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаСотрудникомКлиники Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЗаписьСменаСтатусаСотрудникомКлиники(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаПациентом Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЗаписьСменаСтатусаПациентом(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЗаписьНачалоПриема(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);						
	
	// События по приемам
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершенПродолжаетЛечение Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПриемЗавершенПродолжаетЛечение(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);	
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПриемЗавершен(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
		
	// События по планам лечения
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПланЛеченияСозданиеПланаЛечения Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ПланЛеченияСозданиеПланаЛечения(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
		
	// События по продажам и оплатам
	
		
	// События по лицевым счетам
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетВзнос Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЛицевойСчетВзнос(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);			
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетСписание Тогда	
		ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЛицевойСчетСписание(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);				
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетКритическийОстатокСредств Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЛицевойСчетКритическийОстатокСредств(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);			
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетОкончаниеСрокаДействия Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_ЛицевойСчетОкончаниеСрокаДействия(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
	//	
	//// События по бонусным счетам
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.БонусныйСчетНачисление Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_БонусныйСчетНачисление(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);			
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.БонусныйСчетСписание Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_БонусныйСчетСписание(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);				
	// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.БонусныйСчетОкончаниеСрокаДействия Тогда	
	//	ТаблицаДанныхОбъекта = ПолучитьДанныеСобытия_БонусныйСчетОкончаниеСрокаДействия(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);		
	
	КонецЕсли;
	
	Возврат ТаблицаДанныхОбъекта;
	
КонецФункции

// Процедура - Актуализировать запланированные события после фильтрации
//
// Параметры:
//  ДанныеТриггера		 - 	 - 
//  ОбъектСобытия		 - 	 - 
//  ТаблицаДанныхОбъекта - 	 - 
//
Процедура АктуализироватьЗапланированныеСобытияПослеФильтрации(ДанныеТриггера, ОбъектСобытия, ТаблицаДанныхОбъекта)
	
	Если НЕ ТаблицаДанныхОбъекта = Неопределено Тогда 
		МассивНеКорректныхДанных = Новый Массив;
		// Проверяем прошли ли запланированные строчки через систему фильтрации
		Для Каждого СтрокаТаблицыДанных Из ТаблицаДанныхОбъекта Цикл
			Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса Тогда 
				МассивСтрокРеестра = ДанныеТриггера.РеестрЗапланированных.НайтиСтроки(Новый Структура("ТриггерноеСобытие, ДатаСменыСтатуса, Контрагент", ДанныеТриггера.ТриггерноеСобытие, СтрокаТаблицыДанных.ДатаСменыСтатуса, СтрокаТаблицыДанных.Контрагент));
			// ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияВыписаноНаправление ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияПрофосмотр Тогда	
			//	МассивСтрокРеестра = ДанныеТриггера.РеестрЗапланированных.НайтиСтроки(Новый Структура("ТриггерноеСобытие, ИсточникСобытия, ОбъектСобытия", ДанныеТриггера.ТриггерноеСобытие, СтрокаТаблицыДанных.ОбъектСобытия, СтрокаТаблицыДанных.ОбъектСобытия));								
			Иначе 	
				МассивСтрокРеестра = ДанныеТриггера.РеестрЗапланированных.НайтиСтроки(Новый Структура("ТриггерноеСобытие, ОбъектСобытия, Контрагент", ДанныеТриггера.ТриггерноеСобытие, ОбъектСобытия, СтрокаТаблицыДанных.Контрагент));
			КонецЕсли;	
			Если МассивСтрокРеестра.Количество() = 0 Тогда
				МассивНеКорректныхДанных.Добавить(СтрокаТаблицыДанных);
			Иначе
				Для Каждого СтрокаМассива Из МассивСтрокРеестра Цикл 
					СтрокаМассива.Подтверждено = Истина;
				КонецЦикла;	
			КонецЕсли;	
		КонецЦикла;
		// Подчищаем некорректные строки, если есть
		Для Каждого НекорректнаяСтрока Из МассивНеКорректныхДанных Цикл 
			ТаблицаДанныхОбъекта.Удалить(НекорректнаяСтрока);
		КонецЦикла;
	КонецЕсли;
	// Меняем статус у непройденных фильтрацию
	Для Каждого СтрокаЗапланированных Из ДанныеТриггера.РеестрЗапланированных Цикл 
		Если НЕ СтрокаЗапланированных.Подтверждено Тогда 
			// Меняем статус с "Запланировано" на "Отклонено"
			МенеджерЗаписиСобытия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, СтрокаЗапланированных);
			МенеджерЗаписиСобытия.Прочитать();
			Если МенеджерЗаписиСобытия.Выбран() И МенеджерЗаписиСобытия.Статус = Перечисления.СтатусыРегистрацииСобытий.Запланировано Тогда 
				ЗаполнитьЗначенияСвойств(МенеджерЗаписиСобытия, СтрокаЗапланированных);
				МенеджерЗаписиСобытия.Статус 	= Перечисления.СтатусыРегистрацииСобытий.Отклонено;
				// Пока закоментил, поля "СтатусЗантия" в Событии нет.
				// Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбъектСобытия, "СтатусЗанятия") <> Перечисления.СтатусыЗанятия.Запланировано Тогда 
				//	МенеджерЗаписиСобытия.Сообщение = СтрШаблон(НСтр("ru='Отклонено, по причине того, что занятие находится в статусе: %1';en='Rejected, due to the fact that the occupation is in the status: %1'"), Строка(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбъектСобытия, "СтатусЗанятия")));
				// Иначе 	
					МенеджерЗаписиСобытия.Сообщение = НСтр("ru='Отклонено, согласно правил фильтрации, указанных в триггере.';en='Rejected, according to the filter rules specified in the trigger.'");
				// КонецЕсли;
				МенеджерЗаписиСобытия.Записать();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Функция - Получить актуальные триггеры
//
// Параметры:
//  Источник - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАктуальныеТриггеры(ОбъектСобытия)
	
	ДатаСобытия 				= Неопределено;
	ОбъектСобытияИсточник 		= ОбъектСобытия;
	МассивГибридныхТриггеров 	= Новый Массив;
	ПризнакОтмены 				= Ложь;
	
	Если ТипЗнч(ОбъектСобытия) = Тип("СправочникОбъект.Контрагенты") Тогда
		
#Область ___________________ИСТОЧНИК_СПРАВОЧНИК_КОНТРАГЕНТЫ____________________
		
		Если ОбъектСобытия.ЭтоГруппа ИЛИ ОбъектСобытия.ПометкаУдаления Тогда 
			Возврат Неопределено;			
		ИначеЕсли НачалоДня(ОбъектСобытия.ДатаРегистрации) = НачалоДня(ТекущаяДатаСеанса()) Тогда 
			ОбъектСобытия 		= ОбъектСобытия.Ссылка;
			ДатаСобытия			= ОбъектСобытия.ДатаРегистрации;			
			МассивГибридныхТриггеров.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентРегистрация);
		КонецЕсли;
		
#КонецОбласти

