// Получить документы оплаты с видом операции оплата от клиента по документу реализации или оказания услуг 
Функция ПолучитьДокументыОплатыПоДокументуРеализации(ДокументОснованияСсылка,СтруктурнаяЕдиница = Неопределено, ВидОперации = Неопределено) Экспорт
	
	ЗапросВыборка = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоступлениеРасшифровкаПлатежа.Ссылка
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеРасшифровкаПлатежа
	|ГДЕ
	|	ПоступлениеРасшифровкаПлатежа.ДокументОснования = &ДокументСсылка
	|	И ПоступлениеРасшифровкаПлатежа.Ссылка.Проведен = ИСТИНА
	|	И ВЫБОР
	|			КОГДА НЕ &ВидОперации = НЕОПРЕДЕЛЕНО
	|				ТОГДА ПоступлениеРасшифровкаПлатежа.Ссылка.ВидОперации = &ВидОперации
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоступлениеРасшифровкаПлатежа.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументСсылка
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен = ИСТИНА
	|	И ВЫБОР
	|			КОГДА НЕ &ВидОперации = НЕОПРЕДЕЛЕНО
	|				ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = &ВидОперации
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка");	
	ЗапросВыборка.УстановитьПараметр("ДокументСсылка"    ,ДокументОснованияСсылка);
    ЗапросВыборка.УстановитьПараметр("СтруктурнаяЕдиница",СтруктурнаяЕдиница);	
	ЗапросВыборка.УстановитьПараметр("ВидОперации"       ,ВидОперации);
	
	Возврат  ЗапросВыборка.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

 // Функция вернет остатко на ЛС клиента
 //
Функция ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент
	                                              ,Период = Неопределено
	                                              ,НеУчитыватьРегистратор = Неопределено
												  ,СтруктурнаяЕдиница = Неопределено
												  ,ВидСчета = Неопределено
												  ,ВозвратТолькоСуммы = Ложь) Экспорт
												  
	Возврат РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент,Период,НеУчитыватьРегистратор,СтруктурнаяЕдиница,ВидСчета,ВозвратТолькоСуммы);	
КонецФункции

// Функция вернет остатко денежных средств по переданным параметрам
Функция ПолучитьОстаткоДенежныхСредств(Период = Неопределено	                               
									  ,БанковскийСчетКасса  = Неопределено
									  ,НеУчитываемыйРегистратор = Неопределено) Экспорт
									  
	Возврат РегистрыНакопления.ДенежныеСредства.ПолучитьОстаткоДенежныхСредств(Период,БанковскийСчетКасса,НеУчитываемыйРегистратор);								  
КонецФункции

#КонецОбласти