&НаКлиенте
// Процедура  - обработчик команды "ОтчетПоВыручке".
//
Процедура ОтчетПоВыручке(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СформироватьАвтоматически"	, Истина);
	ПараметрыФормы.Вставить("НачалоПериода"            	, НачалоДня(ТекущаяДата()));
	ПараметрыФормы.Вставить("КонецПериода"             	, КонецДня(ТекущаяДата()));
	ПараметрыФормы.Вставить("КлючВарианта"				, ВернутьВариантОтчета());
	
	Если ДанныеПоКассам.Количество() > 0 Тогда
		ПараметрыФормы.Вставить("ДанныеПоКассам"		, ДанныеПоКассам[0].Касса);	
	КонецЕсли;
	
	ОткрытьФорму("Отчет.ОтчетПоВыручке.Форма", ПараметрыФормы);
	
КонецПроцедуры

