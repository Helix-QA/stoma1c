// Функция вернет следующий рабочий день
// 
Функция СледующийРабочийДень()
	
	Если ВремяПланирования.Количество() > 0 Тогда
		СтрокаДанных  = ВремяПланирования[ВремяПланирования.Количество() - 1];
		СледующаяДата = СтрокаДанных.Дата + 86400;
		Счетчик       = 0;
		Пока ПроверитьВхождениеПериодаВРабочиеДни(СледующаяДата) = Ложь Цикл			
			СледующаяДата = СледующаяДата + 86400;
			// Проверка антизацикливания
			Счетчик = Счетчик + 1;
			Если Счетчик = 7 Тогда
				Возврат Неопределено;
			КонецЕсли;	
		КонецЦикла;
		Возврат СледующаяДата;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

