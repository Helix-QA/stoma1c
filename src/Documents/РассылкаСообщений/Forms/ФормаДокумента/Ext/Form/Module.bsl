// Процедура - Обновить данные таблицы получателей.
//
Процедура ОбновитьДанныеТаблицыПолучателей()
	
	Для Каждого СтрокаТ Из Объект.Получатели Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТ.СервисРассылки) Тогда
			Продолжить;
		КонецЕсли;	
		
		СтрокаТ.Активность = Истина;
		
		Если ТипЗнч(СтрокаТ.СервисРассылки) = Тип("СправочникСсылка.СервисыРассылки") Тогда
			СтрокаТ.ТипОтправки = "sms";
			
		ИначеЕсли СтрокаТ.СервисРассылки.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet Тогда
			СтрокаТ.ТипОтправки = "pushWallet";
			
		Иначе
			СтрокаТ.ТипОтправки = "messenger";
			
		КонецЕсли;	
		
	КонецЦикла;
	
	ЗаполнитьПредставлениеКоличестваПолучателей();

КонецПроцедуры

&НаСервере
// Процедура - Установить видимость настроек сервисов рассылки.
//
Процедура УстановитьВидимостьНастроекСервисовРассылки()
	
	// Заполнение доступными сервисами рассылки.
	ЭтотОбъект.ДоступныеСервисыРассылки = ПолучитьДоступныеСервисыРассылкиСообщений(Объект.СтруктурнаяЕдиница);
	
	ЭтотОбъект.ДоступнаОтправкаМессенджер	 = ЗначениеЗаполнено(ЭтотОбъект.ДоступныеСервисыРассылки.Мессенджер);
	ЭтотОбъект.ДоступнаОтправкаPush			 = ЗначениеЗаполнено(ЭтотОбъект.ДоступныеСервисыРассылки.Push);
	ЭтотОбъект.ДоступнаОтправкаSMS			 = ЗначениеЗаполнено(ЭтотОбъект.ДоступныеСервисыРассылки.SMS);
	
	Элементы.ДополнительнаяИнформацияОРассылке.Видимость = Объект.Ссылка.Пустая() Или Не Объект.Проведен;
	Элементы.ГруппаКоманднаяПанельСообщение.Видимость	 = Объект.Ссылка.Пустая() Или Не Объект.Проведен;
	
	Если Не ЗначениеЗаполнено(Объект.Тип) Тогда
		
		Если ЭтотОбъект.ДоступнаОтправкаМессенджер Тогда
			Объект.Тип = Перечисления.ТипыСобытий.Мессенджер;
			
		ИначеЕсли ЭтотОбъект.ДоступнаОтправкаPush Тогда
			Объект.Тип = Перечисления.ТипыСобытий.ПушУведомление;
			
		ИначеЕсли ЭтотОбъект.ДоступнаОтправкаSMS Тогда
			Объект.Тип = Перечисления.ТипыСобытий.SMS;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Тип) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Нет доступных сервисов рассылки сообщений'"));
	КонецЕсли;
	
	Если Объект.Тип = Перечисления.ТипыСобытий.SMS Тогда
		ОбновитьБалансАккаунтаSMS();
	КонецЕсли;
	
	Элементы.КоличествоПолучателей.Заголовок = ВернутьПредставлениеКоличестваПолучателей(Объект.Получатели.Количество());
	
	УстановитьСостояниеЭлементовФормы(ЭтотОбъект);
	
КонецПроцедуры

