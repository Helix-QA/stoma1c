&НаСервере
// Процедура, выполняет установку видимости подбора.
//
Процедура СкрытьПодборНаСервере(Тип, Видимость = Неопределено)
	
	Если Тип = "Услуги" Тогда
		
		Отображать = ?(Видимость = Неопределено, Не Элементы.ГруппаПодборУслуги.Видимость, Видимость);
		Элементы.ГруппаПодборУслуги.Видимость       		= Отображать;
		Элементы.УслугиСкрытьПодбор.Пометка         		= Отображать;
		Элементы._ПодборНоменклатурУслуги.Видимость 		= Отображать;
		Элементы.ГруппаКоманднаяПанельПодборУслуг.Видимость	= Отображать;
				
		Если Видимость = Неопределено Тогда
			ОбщегоНазначения.СохранитьНастройкуПользователяВХранилищеСистемныхНастроек("ОтображатьПодборУслугиВПриеме", 
				Элементы.ГруппаПодборУслуги.Видимость);
		КонецЕсли;

	Иначе
		
		Отображать = ?(Видимость = Неопределено, Не Элементы.ГруппаПодборТовары.Видимость, Видимость);
		Элементы.ГруппаПодборТовары.Видимость 					= Отображать;
		Элементы.ЗапасыСкрытьПодбор.Пометка   					= Отображать;
		Элементы._ПодборНоменклатур.Видимость 					= Отображать;
		Элементы.ГруппаКоманднаяПанельПодборЗапасов.Видимость	= Отображать;
		
		Если Видимость = Неопределено Тогда
			ОбщегоНазначения.СохранитьНастройкуПользователяВХранилищеСистемныхНастроек("ОтображатьПодборТоварыВПриеме", 
				Элементы.ГруппаПодборТовары.Видимость);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик нажатия команды КомандаПредварительнаяЗапись 
//
Процедура КомандаПредварительнаяЗапись(Команда)
	
	ОснованиеПриема = Объект.ДокументОснование;
	
	Если ТипЗнч(ОснованиеПриема) = Тип("ДокументСсылка.Событие") Тогда
		ОткрытьФорму("Документ.Событие.ФормаОбъекта", Новый Структура("Ключ", ОснованиеПриема));
	КонецЕсли;

КонецПроцедуры

#Область ФункцииИПроцедурыПодбора

&НаКлиенте
// Процедура, обработчик события "Выбор"
//
Процедура Подключаемый_ПодборУслугиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПодборДанные = Элементы._ПодборНоменклатурУслуги.ТекущиеДанные;
	Если ПодборДанные = Неопределено
		Или ПодборДанные.ЭтоГруппа Тогда
		СтандартнаяОбработка = Истина;
		Возврат;
	КонецЕсли;
	
	// Проверка на вид налога.
	Если ПроверитьПрименениеВидовНалогов(ПодборДанные.Номенклатура) Тогда
		Возврат;
	КонецЕсли;
	
	Количество = 1;	
	МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
	Если МассивЗубов.Количество() = 0 Тогда
		МассивЗубов.Добавить(ОбщиеПараметры.Перечисление_Зубы_ВсяПолость);
	КонецЕсли;
		
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ПодборДанные.Номенклатура, "ТипНоменклатуры") 
			= ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор") Тогда
		МассивНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьСоставНабора(ПодборДанные.Номенклатура);
	Иначе
		МассивНоменклатуры = Новый Массив;
		ПолисСогласование = ?(ПодборДанные.Свойство("ПолисСогласование"), ПодборДанные.ПолисСогласование, Неопределено);
		ПолисКоличество = ?(ПодборДанные.Свойство("ПолисКоличество"), ПодборДанные.ПолисКоличество, Неопределено);
		ПолисКоличествоПриПревышении = ?(ПодборДанные.Свойство("ПолисКоличествоПриПревышении"), ПодборДанные.ПолисКоличествоПриПревышении, Неопределено);
		ПолисНеограничено = ?(ПодборДанные.Свойство("ПолисНеограничено"), ПодборДанные.ПолисНеограничено, Неопределено);
		МассивНоменклатуры.Добавить(Новый Структура("Номенклатура, Количество, ПолисСогласование, ПолисКоличество, ПолисНеограничено", ПодборДанные.Номенклатура, 1, ПолисСогласование, ПолисКоличество, ПолисНеограничено));
	КонецЕсли; 
	
	Если МассивНоменклатуры.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	// Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) И ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса) Тогда
		// ПроверкаУслугНаСогласованностьПоПолису(МассивНоменклатуры, ПодборДанные, МассивЗубов, Неопределено); 
	// Иначе	
		ДобавитьИзменитьУслугуПриНажатииВПодборе(МассивНоменклатуры, ПодборДанные, МассивЗубов, Неопределено);
	// КонецЕсли;
	
КонецПроцедуры
  
&НаКлиенте
// Процедура - Проверка услуг на согласованность по полису.
//
Процедура ПроверкаУслугНаСогласованностьПоПолису(МассивНоменклатуры, ПодборДанные, МассивЗубов, ПередаваемыеПараметры = Неопределено)
		
	ПереходИзДругойПроцедуры = Ложь;
	СогласованиеПриПревышении = Неопределено;
	// ПосчитатьПоПриемам = Ложь;
	Если ЗначениеЗаполнено(ПередаваемыеПараметры) И ТипЗнч(ПередаваемыеПараметры) = Тип("Структура") Тогда		
		// Переход к добавлению в ТЧ через форму подбора номенклатуры
		// или после ручного заполнения номенклатуры
		
		ПроцедураПерехода = ?(ПередаваемыеПараметры.Свойство("ПроцедураПерехода"), ПередаваемыеПараметры.ПроцедураПерехода, Неопределено);
		ПараметрыПерехода = ?(ПередаваемыеПараметры.Свойство("ПараметрыПерехода"), ПередаваемыеПараметры.ПараметрыПерехода, Неопределено);			
		ПередаваемыеПараметры = Новый Структура("ПроцедураПерехода, ПараметрыПерехода, ПолисСогласование", ПроцедураПерехода, ПараметрыПерехода, ПодборДанные.ПолисСогласование);	
		ПереходИзДругойПроцедуры = Истина;	
		
	Иначе
		// Переход к добавлению в ТЧ через подбор	
		ПередаваемыеПараметры = Новый Структура("МассивНоменклатуры, ПодборДанные, МассивЗубов, ПолисСогласование, ПроцедураПерехода, СогласованиеПриПревышении",
												МассивНоменклатуры, ПодборДанные, МассивЗубов, ПодборДанные.ПолисСогласование, "ВыборЧерезПодбор", СогласованиеПриПревышении);	
		
	КонецЕсли;
	
	КоличествоНоменклатурыВТЧ = ВернутьКоличествоНоменклатурыВТЧЛечение(ПодборДанные.Номенклатура);	
				
	Если (ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении") 
			И (ПодборДанные.ПолисКоличествоПриПревышении - КоличествоНоменклатурыВТЧ) >= 1)
		ИЛИ ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.НеТребуется") Тогда
		
		ПередаваемыеПараметры.Вставить("СогласованиеПриПревышении", Ложь);			
		ДобавлениеИзменениеУслугИзПодбораЗавершение(КодВозвратаДиалога.Да, ПередаваемыеПараметры);
		
		Возврат;
		
	КонецЕсли;
		
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить(КодВозвратаДиалога.Да		, "Согласовано");
	СписокКнопок.Добавить(КодВозвратаДиалога.Нет	, "Не согласовано");
	СписокКнопок.Добавить(КодВозвратаДиалога.Отмена	, "Отмена");	
	
	ПередаваемыеПараметры.Вставить("СогласованиеПриПревышении", Неопределено);
	
	Оповещение = Новый ОписаниеОповещения("ДобавлениеИзменениеУслугИзПодбораЗавершение", ЭтотОбъект, ПередаваемыеПараметры);
	
	Если ПодборДанные.ПолисСогласование <> ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.НеТребуется") Тогда
		
	//	Если НЕ ПодборДанные.ПолисНеограничено Тогда
	//		Остаток = ПодборДанные.ПолисКоличество - КоличествоУслугиВТЧ;
	//		ВтораяЧастьСообщения = ". Остаток по услуге: "+ Строка(Остаток) + " ед.";
	//	Иначе
	//		ВтораяЧастьСообщения = "!";	
	//	КонецЕсли;
	//	
	//	ПоказатьВопрос(Оповещение, "По данной услуге требуется согласование со страховой компанией" + ВтораяЧастьСообщения, СписокКнопок);
	//		
	// ИначеЕсли ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении") Тогда
		
		ПередаваемыеПараметры.СогласованиеПриПревышении = ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении");
		
		// Если НЕ ПодборДанные.ПолисНеограничено Тогда
		//	Остаток = ПодборДанные.ПолисКоличествоПриПревышении - КоличествоУслугиВТЧ; // - ПодборДанные.ПолисКоличество
		//	ВтораяЧастьСообщения = ". Остаток по услуге: "+ Строка(Остаток) + " ед.";
		// Иначе
		//	ВтораяЧастьСообщения = "!";	
		// КонецЕсли;
		
		// ПоказатьВопрос(Оповещение, "Лимит оказания услуги превышен. Требуется согласование со страховой компанией" + ВтораяЧастьСообщения, СписокКнопок); 	
		
	
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("ПолисМедСтрахования", Объект.ПолисМедСтрахования);	
		ПараметрыФормы.Вставить("Номенклатура", ПодборДанные.Номенклатура);
		
		ОткрытьФорму("РегистрСведений.СогласованияСтраховыхУслуг.Форма.ФормаСогласования", ПараметрыФормы, ЭтаФорма,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура - Добавление изменение услуг из подбора завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ДобавлениеИзменениеУслугИзПодбораЗавершение(Результат, Параметры) Экспорт

	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Результат = КодВозвратаДиалога.Да ИЛИ Результат = КодВозвратаДиалога.Нет Тогда
		
		Если Параметры.Свойство("ПроцедураПерехода") Тогда
					
			Если Параметры.ПроцедураПерехода = "ВыборЧерезФорму" Тогда
				ДанныеПоПолису = Новый Структура("Результат, ПолисСогласование, СогласованиеПриПревышении",
												?(Результат = КодВозвратаДиалога.Да, Истина, Ложь),
												Параметры.ПолисСогласование,
												Параметры.СогласованиеПриПревышении);
				
				ТаблицаУслугиНоменклатураНачалоВыбораЗавершение_ДобавлениеПослеСогласования(Параметры.ПараметрыПерехода, ДанныеПоПолису);  // ДанныеПоПолису
				
			ИначеЕсли Параметры.ПроцедураПерехода = "ЗаполнениеУслугиВручную" Тогда
				
				ДанныеПоПолису = Новый Структура("Результат, ПолисСогласование, СогласованиеПриПревышении",
												?(Результат = КодВозвратаДиалога.Да, Истина, Ложь),
												Параметры.ПолисСогласование,
												Параметры.СогласованиеПриПревышении);
				
				ТаблицаУслугиНоменклатураПриИзмененииСервер(Параметры.ПараметрыПерехода.ИдентификаторыНовыхСтрок, Параметры.ПараметрыПерехода.ПересчетТЧПослеизменения, ДанныеПоПолису);
				
			ИначеЕсли Параметры.ПроцедураПерехода = "ВыборЧерезПодбор" Тогда
				
				ДобавитьИзменитьУслугуПриНажатииВПодборе(Параметры.МассивНоменклатуры, Параметры.ПодборДанные, Параметры.МассивЗубов,
														?(Результат = КодВозвратаДиалога.Да, Истина, Ложь), Параметры.СогласованиеПриПревышении);	
			КонецЕсли;
			
		Иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить изменить услугу при нажатии в подборе
//
// Параметры:
//  МассивНоменклатуры	 - 	 - 
//
Процедура ДобавитьИзменитьУслугуПриНажатииВПодборе(МассивНоменклатуры, ПодборДанные, МассивЗубов, РезультатВопроса = Неопределено, СогласованиеПриПревышении = Неопределено)
	
	ИспользуетсяПолисМедСтрахования = ЗначениеЗаполнено(Объект.ПолисМедСтрахования) И ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса);
	ИдентификаторыНовыхСтрок = Новый Массив; 
	ОписаниеОшибки = "";  
	
	Если ИспользуетсяПолисМедСтрахования Тогда
		МассивСтруктурСКоличествомПоПолису = ПолучитьКоличествоПоПолису(Объект.ПолисМедСтрахования, Объект.Ссылка);
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из МассивНоменклатуры Цикл	
	
		Для Каждого ЭлементМЗуб Из МассивЗубов Цикл
			
			СтруктураПараметров = Новый Структура();
			СтруктураПараметров.Вставить("ИдентификаторыНовыхСтрок", 	ИдентификаторыНовыхСтрок);
			СтруктураПараметров.Вставить("ПодборДанные", 				ПодборДанные);
			СтруктураПараметров.Вставить(	"Номенклатура",                СтрокаТЧ.Номенклатура);
			СтруктураПараметров.Вставить("РезультатВопроса", 			РезультатВопроса);
			СтруктураПараметров.Вставить("СогласованиеПриПревышении", 	СогласованиеПриПревышении);
			СтруктураПараметров.Вставить("СтрокаТЧ", 					СтрокаТЧ);
			СтруктураПараметров.Вставить("ЭлементМЗуб", 				ЭлементМЗуб);
				
			Если ИспользуетсяПолисМедСтрахования Тогда 				
			
				КоличествоЗубовВсего = 0;
				КоличествоВсего = 0;
				
				Для каждого СтрокаМассива Из МассивСтруктурСКоличествомПоПолису Цикл
					Если СтрокаМассива.Номенклатура = ПодборДанные.Номенклатура Тогда
						
						КоличествоЗубовВсего = СтрокаМассива.КоличествоЗубов;
						КоличествоВсего = СтрокаМассива.Количество;
						
					КонецЕсли;
				КонецЦикла;
				
				СтруктураПараметровПоПолису = Новый Структура();
				СтруктураПараметровПоПолису.Вставить("ЭлементМЗуб", 		ЭлементМЗуб);
				СтруктураПараметровПоПолису.Вставить("КоличествоНоменклатурыВТЧ", ВернутьКоличествоНоменклатурыВТЧЛечение(ПодборДанные.Номенклатура));
				СтруктураПараметровПоПолису.Вставить("КоличествоЗубовСНомненклатуройВТЧ", ПолучитьКоличествоЗубовСНомненклатурой(ПодборДанные.Номенклатура));
				
				СтруктураПараметровПоПолису.Вставить("КоличествоЗубов", 	ПодборДанные.КоличествоЗубов);
				СтруктураПараметровПоПолису.Вставить("КоличествоВПриеме", 	ПодборДанные.КоличествоВПриеме);
				СтруктураПараметровПоПолису.Вставить("Номенклатура", 		ПодборДанные.Номенклатура);
				СтруктураПараметровПоПолису.Вставить("ПолисНеограничено", 	ПодборДанные.ПолисНеограничено);
				СтруктураПараметровПоПолису.Вставить("ПолисКоличество", 	ПодборДанные.ПолисКоличество);
				СтруктураПараметровПоПолису.Вставить("КоличествоЗубовВсего",КоличествоЗубовВсего);
				СтруктураПараметровПоПолису.Вставить("КоличествоВсего", 	КоличествоВсего);
				
				ПроверитьУслугуНаСогласованностьПоПолису(СтруктураПараметровПоПолису, ОписаниеОшибки);
				Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
					ПоказатьПредупреждение(,ОписаниеОшибки);	 
					Прервать;
				Иначе
					ДобавитьПослеСогласования(СтруктураПараметровПоПолису.КоличествоНоменклатурыВТЧ, СтруктураПараметровПоПолису.КоличествоВсего, ПодборДанные, СтруктураПараметров);	
				КонецЕсли;
			Иначе
				ДобавитьИзменитьУслугуПриНажатииВПодбореЗавершение(СтруктураПараметров);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	 
	Если ИдентификаторыНовыхСтрок.Количество() > 0 Тогда 
		Если МассивНоменклатуры.Количество() > 1 Тогда   
			ТаблицаУслугиНоменклатураПриИзмененииСервер(ИдентификаторыНовыхСтрок, Истина, Неопределено);	
		Иначе	
			ТаблицаУслугиНоменклатураПриИзменении(Неопределено, ИдентификаторыНовыхСтрок, Истина);
		КонецЕсли;
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	ОбновитьSVGПодбор();
	Модифицированность = Истина;
	
	#Если не ВебКлиент Тогда
		Системнаяинформация = Новый Системнаяинформация;
		Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 
			WSHShell = Новый COMОбъект("WScript.Shell");
			WSHShell.SendKeys("{TAB}");
		КонецЕсли;
	#Конецесли
		
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить изменить услугу при нажатии в подборе завершение.
//
Процедура ДобавитьИзменитьУслугуПриНажатииВПодбореЗавершение(СтруктураПараметров)
	
	ИдентификаторыНовыхСтрок  = СтруктураПараметров.ИдентификаторыНовыхСтрок;
	ПодборДанные			  = СтруктураПараметров.ПодборДанные;
	РезультатВопроса		  = СтруктураПараметров.РезультатВопроса;
	СогласованиеПриПревышении = СтруктураПараметров.СогласованиеПриПревышении;
	// СтрокаТЧ				  = СтруктураПараметров.СтрокаТЧ;
	ЭлементМЗуб				  = СтруктураПараметров.ЭлементМЗуб;
	НачальноеКоличество 	  = ?(ТипЗнч(СтруктураПараметров.СтрокаТЧ) = Тип("Структура") И СтруктураПараметров.СтрокаТЧ.Свойство("Количество")
	                               И СтруктураПараметров.СтрокаТЧ.Количество > 0, СтруктураПараметров.СтрокаТЧ.Количество, 1);
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Номенклатура"  	, СтруктураПараметров.Номенклатура);
	СтруктураОтбора.Вставить("Зуб"           	, ЭлементМЗуб);
	СтруктураОтбора.Вставить("ДокументАванса"	, Неопределено);
	СтруктураОтбора.Вставить("Рекламация"		, ПредопределенноеЗначение("Документ.Прием.ПустаяСсылка")); 
	
	Если НЕ(ПодборДанные.ПолисСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.НеТребуется")
		ИЛИ СогласованиеПриПревышении = Ложь) Тогда
		// Без согласования и когда не дошли до порога при привышении, игнорируем поиск по типу согласования,
		// после ищем по типу согласования, что бы добавлять отдельной строкой согласованную номенклатуру.
		
		СтруктураОтбора.Вставить("ТребуетсяСогласование", ПодборДанные.ПолисСогласование);	
		
	КонецЕсли;
	
	Строки = Объект.Лечение.НайтиСтроки(СтруктураОтбора);
	
	Если Строки.Количество() > 0 Тогда
		
		Строки[0].КоличествоУпаковок = Строки[0].КоличествоУпаковок + НачальноеКоличество;
		Строки[0].Количество 		 = Строки[0].Количество + НачальноеКоличество;
		ИдентификаторыНовыхСтрок.Добавить(Строки[0].ПолучитьИдентификатор());
		СтрокаДляПолиса = Строки[0];
		
	Иначе			
		Если Элементы.ТаблицаЛечение.ТекущиеДанные <> Неопределено
			И НЕ ЗначениеЗаполнено(Элементы.ТаблицаЛечение.ТекущиеДанные.Номенклатура) Тогда					
			
			Элементы.ТаблицаЛечение.ТекущиеДанные.Номенклатура    = СтруктураПараметров.Номенклатура;;
			Элементы.ТаблицаЛечение.ТекущиеДанные.СкидкиЗапрещены = ПодборДанные.СкидкиЗапрещены;							
			Элементы.ТаблицаЛечение.ТекущиеДанные.КлючСтроки      = Новый УникальныйИдентификатор;
			
			Если НЕ ЗначениеЗаполнено(Элементы.ТаблицаЛечение.ТекущиеДанные.Сотрудник) Тогда 
				Элементы.ТаблицаЛечение.ТекущиеДанные.Сотрудник = Объект.Сотрудник;
			КонецЕсли; 
			
			СтрокаДляПолиса = Элементы.ТаблицаЛечение.ТекущиеДанные;
			
		Иначе 			
			
			НоваяСтрока                           = Объект.Лечение.Добавить();
			НоваяСтрока.КлючСтроки                = Новый УникальныйИдентификатор;
			НоваяСтрока.Номенклатура              = СтруктураПараметров.Номенклатура;;
			НоваяСтрока.СкидкиЗапрещены           = ПодборДанные.СкидкиЗапрещены;
			
			Если ТипЗнч(СтруктураПараметров.СтрокаТЧ) = Тип("Структура") Тогда
				Количество = СтруктураПараметров.СтрокаТЧ.Количество;
			Иначе
				Количество = 1;
			КонецЕсли;
			
			НоваяСтрока.КоличествоУпаковок        = Количество;
			НоваяСтрока.Количество		          = Количество;
			НоваяСтрока.Сотрудник 				  = Объект.Сотрудник;
			НоваяСтрока.Зуб                       = ЭлементМЗуб;
			Если СтруктураПараметров.Свойство("КомментарийСогласования") Тогда
				НоваяСтрока.КомментарийСогласования = СтруктураПараметров.КомментарийСогласования;	
			КонецЕсли;
			
			СтрокаДляПолиса = НоваяСтрока; 
			
			Элементы.ТаблицаЛечение.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор(); 
			
		КонецЕсли;					
		ИдентификаторыНовыхСтрок.Добавить(Элементы.ТаблицаЛечение.ТекущиеДанные.ПолучитьИдентификатор());	
	КонецЕсли;
	
	Если ПодборДанные.Свойство("ПолисСогласование") Тогда	
		СтрокаДляПолиса.ТребуетсяСогласование = ПодборДанные.ПолисСогласование;			
	КонецЕсли;
	
	Если НЕ СогласованиеПриПревышении = Неопределено И СогласованиеПриПревышении = Ложь 
		И НЕ СтрокаДляПолиса.ТребуетсяСогласование = ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.Всегда") Тогда
		
		СтрокаДляПолиса.ТребуетсяСогласование = Неопределено;
		
	КонецЕсли;
	
	Если НЕ РезультатВопроса = Неопределено И ЗначениеЗаполнено(СтрокаДляПолиса.ТребуетсяСогласование) Тогда 
		СтрокаДляПолиса.СтатусСогласования	 = РезультатВопроса;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Проверить услугу на согласованность по полису.
//
Процедура ПроверитьУслугуНаСогласованностьПоПолису(СтруктураПараметров, ОписаниеОшибки)
	
	// Образец структуры обязательных полей.
	// ЭлементМЗуб
	// КоличествоНоменклатурыВТЧ 
	// КоличествоЗубовСНомненклатуройВТЧ
	// КоличествоЗубов
	// КоличествоВПриеме
	// Номенклатура
	// ПолисНеограничено
	// ПолисКоличество
	// КоличествоЗубовВсего
	// КоличествоВсего
		
	Если СтруктураПараметров.КоличествоЗубов > 0 Тогда
		
		Если СтруктураПараметров.ЭлементМЗуб = ВсяПолость Тогда
			
			ОписаниеОшибки = "Ограничение на количество зубов. Выберите зуб.";
			Возврат;   
			
		Иначе   
			
			Если СтруктураПараметров.КоличествоВПриеме > 0
				И СтруктураПараметров.КоличествоВПриеме <= СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ Тогда
				
				МассивСтрок = Объект.Лечение.НайтиСтроки(Новый Структура("Номенклатура, Зуб", СтруктураПараметров.Номенклатура, СтруктураПараметров.ЭлементМЗуб));
				Если СтруктураПараметров.КоличествоВПриеме = СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ
					И МассивСтрок.Количество() = 0 Тогда
					
					ОписаниеОшибки = "Ограничение на количество зубов в приеме. Доступно не более: " + СтруктураПараметров.КоличествоВПриеме;
					Возврат; 
				КонецЕсли;
				
			КонецЕсли;
			
			Если СтруктураПараметров.ПолисНеограничено = Истина Тогда
				
				Если СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ + СтруктураПараметров.КоличествоЗубовВсего > СтруктураПараметров.КоличествоЗубов Тогда								
					ОписаниеОшибки = "Ограничение на количество зубов. Доступно зубов: "+ СтруктураПараметров.КоличествоЗубов;
					Возврат; 
				КонецЕсли; 
				
			Иначе
				
				Если СтруктураПараметров.ПолисКоличество <= СтруктураПараметров.КоличествоНоменклатурыВТЧ + СтруктураПараметров.КоличествоВсего Тогда			
					ОписаниеОшибки = "Ограничение по количеству услуг. Всего доступно: " + СтруктураПараметров.ПолисКоличество;
					Возврат; 				
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;  
		
	Иначе
		
		Если СтруктураПараметров.ПолисНеограничено = Ложь			
			И СтруктураПараметров.ПолисКоличество <= СтруктураПараметров.КоличествоНоменклатурыВТЧ + СтруктураПараметров.КоличествоВсего Тогда			
			
			ОписаниеОшибки = "Ограничение по количеству услуг. Всего доступно: " + СтруктураПараметров.ПолисКоличество;
			Возврат; 		
		КонецЕсли;
		
	КонецЕсли;
			
КонецПроцедуры

