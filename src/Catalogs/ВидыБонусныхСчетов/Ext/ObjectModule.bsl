
#Область ОбработчикиСобытий 

// Процедура - обработчик события "ОбработкаПроверкиЗаполнения".
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

	Если ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный  
		Или ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокДействия_С_По Тогда
		
		НепроверяемыеРеквизиты = Новый Массив;
		НепроверяемыеРеквизиты.Добавить("СрокДействия");
		ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
	КонецЕсли;	
	
	Если ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный Тогда
		
		НепроверяемыеРеквизиты = Новый Массив;
		НепроверяемыеРеквизиты.Добавить("СрокДействияНачислений");
		ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
		
	КонецЕсли;     
	
КонецПроцедуры

// Процедура - обработчик события "ПередЗаписью" объекта
//
Процедура ПередЗаписью(Отказ)
	
	УстановитьНастройкиОграничений();
	
КонецПроцедуры



#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//
//
Процедура УстановитьНастройкиОграничений()
	
	Если НеОграниченПроцентомСписания Тогда 
		ОграничениеСписанияПроцент = 0;
	ИначеЕсли ОграничениеСписанияПроцент = 0 Тогда 
		НеОграниченПроцентомСписания = Истина;
	КонецЕсли;		
	
	// -----------------------------Ограничение срока действия бонусного счета--------------------------------
	
	// Бессрочный
	Если ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный  Тогда		
		СрокДействия 		= 0;
		СрокДействияТип 	= Перечисления.Периодичность.ПустаяСсылка();
		СрокДействияДатойС 	= Дата(1,1,1);
		СрокДействияДатойПо = Дата(1,1,1);		
	// Срок действия с.. по..
	ИначеЕсли ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокДействия_С_По Тогда		
		СрокДействия 		= 0;
		СрокДействияТип 	= Перечисления.Периодичность.ПустаяСсылка();		
	// Срок ограничен периодом	
	ИначеЕсли ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокОграниченПериодом Тогда		
		СрокДействияДатойС 	= Дата(1,1,1);
		СрокДействияДатойПо = Дата(1,1,1);		
	КонецЕсли;
	
	// -----------------------Ограничение срока действия начислений бонусного счета--------------------------
	
	// Бессрочный
	Если ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный Тогда		
		СрокДействияНачислений 		= 0;
		СрокДействияНачисленийТип 	= Перечисления.Периодичность.ПустаяСсылка();		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
