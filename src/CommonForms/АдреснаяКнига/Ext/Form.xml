		<Attribute name="СписокКлиентов" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Список клиентов</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<UseAlways>
				<Field>~СписокКлиентов.CRM_Email</Field>
				<Field>СписокКлиентов.Email</Field>
				<Field>СписокКлиентов.Ссылка</Field>
				<Field>СписокКлиентов.УчаствуетВРассылке</Field>
				<Field>СписокКлиентов.ЭтоКлиент</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СправочникКонтрагенты.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА СправочникКонтрагенты.Родитель.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
			ТОГДА ВложенныйЗапрос.УчаствуетВРассылке
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК УчаствуетВРассылке,
	ВЫБОР
		КОГДА СправочникКонтрагенты.Родитель.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоКлиент,
	ВложенныйЗапрос.Email КАК Email
ИЗ
	Справочник.Контрагенты КАК СправочникКонтрагенты
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			Email.Представление КАК Email,
			Email.Ссылка КАК Контрагент,
			НЕ ЕСТЬNULL(Email.НеУчаствоватьВРассылке, ЛОЖЬ) КАК УчаствуетВРассылке
		ИЗ
			Справочник.Контрагенты.КонтактнаяИнформация КАК Email
		ГДЕ
			Email.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
			И НЕ ПОДСТРОКА(ЕстьNull(Email.Представление, ""), 1, 500) ПОДОБНО "") КАК ВложенныйЗапрос
		ПО СправочникКонтрагенты.Ссылка = ВложенныйЗапрос.Контрагент
ГДЕ
	СправочникКонтрагенты.ПометкаУдаления = ЛОЖЬ
	И СправочникКонтрагенты.ЭтоГруппа = ЛОЖЬ
	И НЕ ВложенныйЗапрос.Email ЕСТЬ NULL</QueryText>
				<MainTable>Catalog.Контрагенты</MainTable>
