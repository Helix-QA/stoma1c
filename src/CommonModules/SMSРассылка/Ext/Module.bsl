// Функция - Фоновое задание запустить
//
// Параметры:
//  ПланОбмена					 - 	 - 
//  УникальныйИдентификаторФормы - 	 - 
// Возвращаемое значение:
//   - 
Функция ПроверитьБалансСмсСервисаИПредложитьПополнение() Экспорт
		
	Если ТекущийПользовательИмеетПравоНаРаботуССмсСервисами() = Ложь Тогда		
		Возврат Неопределено;
	КонецЕсли;
	
	ИдентификаторЗадания = Новый УникальныйИдентификатор; 
	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, ИдентификаторЗадания);
	
	Результат = Новый Структура;
	Результат.Вставить("Статус"                      , Неопределено);
	Результат.Вставить("ИдентификаторЗадания"        , ИдентификаторЗадания);
	Результат.Вставить("АдресРезультата"             , АдресРезультата);
	Результат.Вставить("КраткоеПредставлениеОшибки"  , "");
	Результат.Вставить("ПодробноеПредставлениеОшибки", "");

	Попытка			
		ПроверитьБалансСмсСервисаДлительнаяОперация(Новый Структура, АдресРезультата);
		Результат.Статус = "Выполнено";			
	Исключение	   	
		Результат.Статус = "Ошибка";
		Результат.КраткоеПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Результат.ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Результат;
		
КонецФункции

// Процедура - Проверить необходимость предложения пополнения баланса смс сервиса helix
//
// Параметры:
//  СтруктураПараметров		 - 	 - 
//  АдресХранилищаРезультата - 	 - 
//
Процедура ПроверитьБалансСмсСервисаДлительнаяОперация(СтруктураПараметров, АдресХранилищаРезультата = Неопределено) Экспорт
	
	СервисСмс = Константы.СервисSMSРассылкиПоУмолчанию.Получить();     
	
	Если ЗначениеЗаполнено(СервисСмс) 
		И СервисСмс.ИмяОбработки = "СервисHelixSMS" Тогда
		
		Баланс = Неопределено;
		
		Попытка
			Баланс = Справочники.СервисыРассылки.ПолучитьБалансАккаунтаSMS(СервисСмс);
		Исключение			
			ЗаписатьОшибкуВЖурналРегистрации(ИнформацияОбОшибке());			
		КонецПопытки;
		
		Если Баланс <> Неопределено
			И ЗначениеЗаполнено(Баланс.Баланс) Тогда
			
			РезультатаОперции = ПолучитьПредложениеДляПополенияБалансаСмсСервиса(СервисСмс);							
			МинимальныйБаланс = 1000;
			
			Если РезультатаОперции.ВыполненоУспешно = Истина Тогда
				
				Если РезультатаОперции.ПараметрыРезультата <> Неопределено Тогда
					
					РезультатаОперции.ПараметрыРезультата.Вставить("ТекущийБаланс",Баланс.Баланс);		
					МинимальныйБаланс = РезультатаОперции.ПараметрыРезультата.min_balance;
					
				КонецЕсли;
				
				ПоместитьВоВременноеХранилище(РезультатаОперции.ПараметрыРезультата, АдресХранилищаРезультата);  
				
			КонецЕсли;		
			
			// Если это проверка пополнения баланса
			Если СтруктураПараметров = Неопределено
				ИЛИ Не СтруктураПараметров.Свойство("НеКонтролироватьДатаПоследнегоСчета")
				ИЛИ СтруктураПараметров.НеКонтролироватьДатаПоследнегоСчета = Ложь Тогда
								
				Если Баланс.Баланс <= МинимальныйБаланс Тогда  
					
					ДанныеСервиса = ПолучитьДанныеСмсСервиса();
					
					Если ДанныеСервиса <> Неопределено
						И ДанныеСервиса.Свойство("ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса")
						И ЗначениеЗаполнено(ДанныеСервиса.ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса) Тогда
						
						Период = (НачалоДня(ТекущаяДата()) - НачалоДня(ДанныеСервиса.ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса)) / 86400;
						
						Если Период < 3 Тогда
							
							ПоместитьВоВременноеХранилище(Неопределено, АдресХранилищаРезультата);
							Возврат;	
						КонецЕсли;
						
					КонецЕсли;
					
				Иначе
					ПоместитьВоВременноеХранилище(Неопределено, АдресХранилищаРезультата);
					Возврат;
				КонецЕсли;
				
			КонецЕсли;
									
		КонецЕсли;
		
	Иначе	
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилищаРезультата);
	КонецЕсли;
	
КонецПроцедуры

// Функция - Текущий пользователь имеет право на работу с смс сервисами
// 
// Возвращаемое значение:
//   - 
//
Функция ТекущийПользовательИмеетПравоНаРаботуССмсСервисами()
	
	РольПользователя = ПараметрыСеанса.ТекущийПользователь.РольПользователя;
	
	Если РольПользователя = Перечисления.РольПользователя.Руководитель
		ИЛИ РольПользователя = Перечисления.РольПользователя.Управляющий 
		ИЛИ РольДоступна("Администрирование") 
		ИЛИ РольДоступна("ПолныеПрава")            
		ИЛИ РольДоступна("ДобавлениеИзменениеSMSРассылки") Тогда           
		
		Возврат Истина;
	КонецЕсли;
		
	Возврат Ложь;

КонецФункции

// Процедура - Записать ошибку в журнал регистрации
//
// Параметры:
//  ДанныеОшибки - 	 - 
//
Процедура ЗаписатьОшибкуВЖурналРегистрации(ДанныеОшибки)
	
	Описание = "Описание: " + ДанныеОшибки.Описание + "
	|ИмяМодуля: " + ДанныеОшибки.ИмяМодуля + "
	|НомерСтроки: " + ДанныеОшибки.НомерСтроки + "
	|ИсходнаяСтрока: " + ДанныеОшибки.ИсходнаяСтрока + "
	|Причина: " + ДанныеОшибки.Причина;
	
	ЗаписьЖурналаРегистрации(
	"API CRM",
	УровеньЖурналаРегистрации.Ошибка,,,
	Описание);
	
КонецПроцедуры

// Функция вернет структуру данных смс сервиса 
Функция ПолучитьДанныеСмсСервиса() Экспорт
	
	СсылкаНаХранилище = Константы.ДанныеСмсСервисаХранилищеДанных.Получить();
	
	Если СсылкаНаХранилище <> Неопределено Тогда
		
		Возврат СсылкаНаХранилище.Получить();
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Процедура запишит структуру данных смс сервиса
// в хранилище данных
Процедура ЗаписатьДанныеСмсСервиса(СтруктураДанных) Экспорт
	
	Константы.ДанныеСмсСервисаХранилищеДанных.Установить(Новый ХранилищеЗначения(СтруктураДанных));
	
КонецПроцедуры

// Получить структуру данных хранения смс сервиса на клиенте
Функция ПолучитьПустуюСтруктуруДанныхСмсСервисаДляХраненияНаКлиенте() Экспорт
	
	ДанныеСервиса = Новый Структура("ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса" ,Неопределено);
	
	Возврат ДанныеСервиса; 
	
КонецФункции

