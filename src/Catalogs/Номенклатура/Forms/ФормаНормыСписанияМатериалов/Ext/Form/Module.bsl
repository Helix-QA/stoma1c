&НаСервере
// Процедура - Заполнить значения при выборе материалов
//
Процедура ЗаполнитьЗначенияПриВыбореМатериалов()
	
	ВыбранныеЗначения = ОтборСписокВыбранныеЗначения.ВыгрузитьЗначения();
	
	СоздатьДинамическийСписокПодбораНоменклатур("ГруппаПодборНоменклатура",, Не ЭтотОбъект.ПакетУслугСоставОпределяетсяПриПродаже);	
	
	Если ВыбранныеЗначения <> Неопределено Тогда  
		
		Если ТипЗнч(ВыбранныеЗначения) = Тип("СправочникСсылка.Номенклатура") Тогда
			ЭтотОбъект.НоменклатураНачальногоПозиционирования = ВыбранныеЗначения;
			// Если используется буфер выбранных значений и передан массив значений.
		ИначеЕсли ТипЗнч(ВыбранныеЗначения) = Тип("Массив") И МножественныйВыборИспользовать Тогда
			
			Для Каждого СтрокаМ ИЗ ВыбранныеЗначения Цикл
				
				НоваяСтрока = ТаблицаНормыСписанияМатериалов.Добавить();
				НоваяСтрока.Количество = 1;
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаМ);
				НоваяСтрока.ХарактеристикиИспользуются = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаМ.Номенклатура, "ИспользоватьПартии");
				
			КонецЦикла;
			
			Если ВыбранныеЗначения.Количество() > 0 Тогда
				
				Если ВыбранныеЗначения[0].Свойство("Услуга") Тогда
					Услуга = ВыбранныеЗначения[0].Услуга; 
				ИначеЕсли ВыбранныеЗначения[0].Свойство("Номенклатура") Тогда
					Услуга = ВыбранныеЗначения[0].Номенклатура;	
				КонецЕсли;
				Клиент = ?(ВыбранныеЗначения[0].Свойство("Клиент"), ВыбранныеЗначения[0].Клиент, Неопределено);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли; 	

КонецПроцедуры
	
&НаКлиенте
// Процедура, обработчик команды "НастройкиПодбора"
//
