&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	БуферОбмена             = Новый Структура("Буфер, ПризнакВырезать");
	ПЗФильтрГрафикаОбновить = Истина;
	Если ЗначениеЗаполнено(Константы.ДатаДемоРежима.Получить()) Тогда
		Объект.Дата = Константы.ДатаДемоРежима.Получить();
	Иначе
		Объект.Дата = ТекущаяДата();
	КонецЕсли;
	
	ИспользуетсяРасширениеМессенджер = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер");
	Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	ЗначениеНастройки = ПользователиСтоматология.ПолучитьЗначениеПоУмолчаниюПользователя(ПараметрыСеанса.ТекущийПользователь, "ОсновнаяКасса", Объект.СтруктурнаяЕдиница);				
	Если ЗначениеЗаполнено(ЗначениеНастройки) Тогда
		Касса = ЗначениеНастройки;
	Иначе	
		Касса =  Объект.СтруктурнаяЕдиница.ОсновнаяКасса;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	ГруппаКонтрагентов = Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);
	УстановитьПривилегированныйРежим(Ложь);
	ТаблицаЗадачи.Параметры.УстановитьЗначениеПараметра("Отработано", ?(Элементы.ТаблицаЗадачиКнопкаАктивные.Пометка, Ложь, Истина));
	ТаблицаЗадачи.Параметры.УстановитьЗначениеПараметра("Исполнитель", ПараметрыСеанса.ТекущийСотрудник);
	МассивГруппПользователей = Справочники.ГруппыПользователей.ПолучитьМассивГруппПользователей(ПараметрыСеанса.ТекущийПользователь);
	ТаблицаЗадачи.Параметры.УстановитьЗначениеПараметра("МассивГруппПользователей", МассивГруппПользователей);	
	ТаблицаЗадачи.Параметры.УстановитьЗначениеПараметра("ЗадачаНазначеннаяДатаВыполнения", ТекущаяДата());	

	УстановитьВидимостьКнопокПереходаВМессенджер(ЭтотОбъект);

	Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.СестраХозяйка Тогда
		Элементы.ГруппаЛеваяКолонка.Видимость = Ложь;
		Элементы.ГруппаКлиент.Видимость = Ложь;
		Элементы.ИнформацияКлиента.Видимость = Ложь;
		Элементы.ГруппаОтчетыЗапасы.Видимость = Истина;
		Элементы.ГруппаДействия.Видимость = Ложь;
		Элементы.ГруппаОтчеты.Видимость = Ложь;
		Элементы.ГруппаКасса.Видимость = Ложь;
	ИначеЕсли ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Бухгалтер Тогда
		Элементы.ГруппаЛеваяКолонка.Видимость = Ложь;
		Элементы.ГруппаКлиент.Видимость = Ложь;
		Элементы.ИнформацияКлиента.Видимость = Ложь;    
		Элементы.ИсторияВзаимодействия.Видимость = Ложь;
		Элементы.ГруппаОтчетыБухгалтера.Видимость = Истина;
		Элементы.ГруппаДействия.Видимость = Ложь;
		Элементы.ГруппаОтчеты.Видимость = Ложь;
		Элементы.ГруппаКасса.Видимость = Ложь;
	ИначеЕсли ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач  или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач Тогда
		Элементы.ГруппаОтчетыВрача.Видимость = Истина;
	КонецЕсли; 
	
	ЕстьДоступКУправлениюКассовойСменой = (РольДоступна("ДобавлениеИзменениеДокументовПоОплате")
									   ИЛИ РольДоступна("ДобавлениеИзменениеДокументовПоПродажамТоваров")
									   ИЛИ РольДоступна("ПолныеПрава"));
	
	Элементы.ГруппаУправлениеКассовойСменой.Видимость = ЕстьДоступКУправлениюКассовойСменой;
	
	ЭтаФорма.Заголовок = "Рабочий стол";
	
	// Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач Тогда		
	//	Элементы.ЖурналПЗОтборПоСотрудникамРежимФильтра.СписокВыбора.Очистить();
	//	Элементы.ЖурналПЗОтборПоСотрудникамРежимФильтра.СписокВыбора.Добавить(0, "Моя запись");
	//	
	//	НеОтображатьОбщееРасписание = Пользователи.ПолучитьЗначениеПраваПользователя("НеОтображатьОбщееРасписание");
	//	Если НеОтображатьОбщееРасписание = Ложь Тогда			
	//		Элементы.ЖурналПЗОтборПоСотрудникамРежимФильтра.СписокВыбора.Добавить(1, "Общая запись");
	//	КонецЕсли;	
	//	ЭтоВрач = Истина;
	//	Врач = ПараметрыСеанса.ТекущийПользователь.Сотрудник;
	// КонецЕсли;
	// --------------------------------------------------------------
	// СформироватьКнопкиСменыСЕ();  
	Если Параметры.Свойство("Контрагент") Тогда 
		Контрагент = Параметры.Контрагент; 
		ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Контрагент, Объект.СтруктурнаяЕдиница);
	КонецЕсли;
		
	ЭтотОбъект.ЦветаЭлементов = Новый Структура;
	
	ЦветаЭлементов.Вставить("ЦветФона"                   , Новый Цвет(255, 255, 255));
	ЦветаЭлементов.Вставить("ЦветФонаВыбранного"         , Новый Цвет(218, 230, 244));
	ЦветаЭлементов.Вставить("ЦветТекста"                 , Новый Цвет(51,  102, 187));
	ЦветаЭлементов.Вставить("ЦветТекстаВыбранного"       , Новый Цвет(64,  64,  64));
	ЦветаЭлементов.Вставить("ЦветТекстаНеактивногоВизита", Новый Цвет(128, 128, 128));
	ЦветаЭлементов.Вставить("ЦветРамкиАктивногоВизита"   , WebЦвета.Красный);
	
	УстановитьВидимостьЭлементовНаСогласованиеСтраховой();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ПриОткрытии(Отказ)
	
	ВыполнятьАктивизациюСтрокиТекущихКлиентов     = Истина;
	ВводПриемаЧерезКонтекстноеМеню                = Ложь;
	СтраницаРаботаСКлиентомОбновлена              = Ложь;
	СтраницаЖурналПредварительнойЗаписиОбновлена  = Ложь;
	ТаблицаОбслуживаниеКлиентовПерваяАктивация    = Ложь;
	ТаблицаНЕ_ОбслуживаниеКлиентовПерваяАктивация = Ложь;
	ПЗРасшифровкаСтатусовОбновить                 = Истина;
	РазрешениеЭкрана                              = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьТекущееРазрешениеЭкрана();
	// Позиционирование на тек. страницу рабочего стола
	Если ЗначениеЗаполнено(ТекущаяСтраницаРабочегоСтола) И НЕ Элементы.Найти(ТекущаяСтраницаРабочегоСтола) = Неопределено Тогда
		Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы[ТекущаяСтраницаРабочегоСтола];
	Иначе
		Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаРабочийСтол;
	КонецЕсли;	
	// Обновление текущей страницы рабочего стола
	Если Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаРабочийСтол Тогда
		ОбновлениеСтраницыРаботаСклиентом(Истина);
	КонецЕсли;	
	#Если ВебКлиент Тогда
		ПодготовитьДанныеДляВыводаИнформацииПоКлиенту(КлиентДляОткрытия, Объект.СтруктурнаяЕдиница, ИнформацияКлиента, ШиринаИнформацииПоКлиенту, РазрешениеЭкрана);
	#КонецЕсли
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ЗаполнитьДанныеПоКонтрагенту(Контрагент);
	КонецЕсли;	
	// МеханизмВнешнегоОборудования
	МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиентаБезМодальногоВызова(Новый ОписаниеОповещения("ОбновитьРабочееМестоКлиентаЗавершение", ЭтотОбъект));
	// Конец МеханизмВнешнегоОборудования 
		
	СписокОборудования = МенеджерОборудованияВызовСервера.ПолучитьСписокОборудования("ЭквайринговыйТерминал");
	Если СписокОборудования.Количество() = 0 Тогда
		Элементы.ГруппаЭквайринговыйТерминал.Видимость = Ложь;
	КонецЕсли;
	
	ПодключенСофтфон = ПодключенСофтфон();
	Элементы.ОткрытьСофтФон.Видимость = ПодключенСофтфон;
	Элементы.ГруппаВзаимодействия.Видимость = ПодключенСофтфон;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик оповещения формы.
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзмененаДолжность" ИЛИ ИмяСобытия = "ИзмененоПомещение" ИЛИ ИмяСобытия = "ОБНОВИТЬ_ГРАФИК_ПЗ"  Тогда
		ПЗФильтрГрафикаОбновить = Истина;
		
	ИначеЕсли ИмяСобытия = "ПросмотретьИнформациюОКонтрагенте" И ЗначениеЗаполнено(Параметр) 
		И ТипЗнч(Параметр) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		ЭтотОбъект.Контрагент = Параметр;
		ЗаполнитьДанныеПоКонтрагенту(ЭтотОбъект.Контрагент);
		
	ИначеЕсли ИмяСобытия = "ИзмененаСтруктурнаяЕдиница" Тогда
		Объект.СтруктурнаяЕдиница = Параметр.ТекущаяСтруктурнаяЕдиница;
		Если Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаРабочийСтол Тогда
			ОбновлениеСтраницыРаботаСклиентом();
		ИначеЕсли Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаПредварительнаяЗапись Тогда
			ПЗФильтрГрафикаОбновить = Истина;
		КонецЕсли;		
	ИначеЕсли ИмяСобытия = "ИзмененаСтруктурнаяЕдиницаВЗакладках" Тогда
		СтраницаРаботаСКлиентомОбновлена = Ложь;
		ПриСозданииНаСервере(Ложь, Истина);
		ПриОткрытии(Ложь);
		
	ИначеЕсли ИмяСобытия = "ОткрытиеЗакрытиеКассовойСмены" И Касса = Параметр.Касса Тогда
		СостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Касса);
		СменаОткрыта = ?(СостояниеКассовойСмены <> Неопределено, СостояниеКассовойСмены.СменаОткрыта, Ложь);
		ОбновлениеСтраницыРаботаСклиентом();
		
	ИначеЕсли ИмяСобытия = "ПРОВЕДЕН_ВЗНОС_НА_ЛИЦЕВОЙ_СЧЕТ"
		ИЛИ ИмяСобытия = "ПРОВЕДЕН_ВОЗВРАТ_С_ЛИЦЕВОГО_СЧЕТА" Тогда
		ОбновлениеСтраницыРаботаСклиентом(Ложь);
		
	ИначеЕсли ИмяСобытия = "ОбновлениеРабочегоСтола" Тогда
		
		ТаблицаОбслуживаниеКлиентовПерваяАктивация = Ложь;
		
		Если ЗначениеЗаполнено(Параметр) И ТипЗнч(Параметр) = Тип("Структура") И Параметр.Свойство("ДатаСобытия") Тогда
			ДатаПриема = Параметр.ДатаСобытия; 
			Если НачалоДня(Объект.Дата) <= ДатаПриема И КонецДня(Объект.Дата) >= ДатаПриема Тогда
				ОбновлениеСтраницыРаботаСклиентом(Истина);
			КонецЕсли;
		Иначе
			ОбновлениеСтраницыРаботаСклиентом(Истина);
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ОбновитьРабочийСтол" Тогда	
		
		ТаблицаОбслуживаниеКлиентовПерваяАктивация = Ложь;
		ОбновлениеСтраницыРаботаСклиентом(Истина);
		
	КонецЕсли;
	
	Если ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА" ИЛИ ИмяСобытия = "ПРОВЕДЕНА_ОПЛАТА_ДОКУМЕНТА" Тогда 
		// После обновления Открытых приемов не выбираем автоматом на раб.стол из списка 1-го, только если не он сам выбран на рабочем столе 
		Если Элементы.ТаблицаТекущиеКлиенты.Видимость = Истина
			И ДеревоТекущихКлиентов.ПолучитьЭлементы().Количество() <> 0
			И ДеревоТекущихКлиентов.ПолучитьЭлементы()[0].Клиент <> Контрагент Тогда 
			ТаблицаОбслуживаниеКлиентовПерваяАктивация = Ложь;
		КонецЕсли;
		ОбновлениеСтраницыРаботаСклиентом(Истина);	
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьСогласованияСтраховыхУслуг"
		ИЛИ ИмяСобытия = "ПоказатьОповещениеУслугиНаСогласование" Тогда 
		
		УстановитьВидимостьЭлементовНаСогласованиеСтраховой();
	КонецЕсли;
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование"
		И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			// Преобразуем предварительно к ожидаемому формату
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			
			ПолученыШтрихкоды(Данные);
		КонецЕсли;
	КонецЕсли;
	
	Если Источник = "ВнешнееОборудование"
		И ВводДоступен() Тогда
		Если ИмяСобытия = "TracksData" Тогда
			Если Параметр[1] = Неопределено Тогда
				ПолученКодКарты(Параметр[0], Параметр[0]);
			Иначе
				ПолученКодКарты(Параметр[0], Параметр[1][1]);
			КонецЕсли;
			КонтрагентПриИзменении(Неопределено);
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере  
// Процедура, обработчик события "ПередЗагрузкойДанныхИзНастроекНаСервере"
//
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	Если ЭтоВрач Тогда
		Настройки.Удалить("ПЗОтборПоСотрудникамРежимФильтра");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
// Обработчик переключения между страницами рабочего стола 
//
Процедура ГлобальнаяГруппаПриСменеСтраницы(Элемент, ТекущаяСтраница)
	ТекущаяСтраницаРабочегоСтола = ТекущаяСтраница.Имя;
	Если НЕ СтраницаРаботаСКлиентомОбновлена И Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаРабочийСтол Тогда
		ОбновлениеСтраницыРаботаСклиентом(Истина);
	КонецЕсли;	
КонецПроцедуры

