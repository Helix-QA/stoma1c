			Если ПкоРко.РасшифровкаПлатежа.Количество() = 0 Тогда 
				НС 										= ПкоРко.РасшифровкаПлатежа.Добавить();
				НС.Основание 							= ?(ДокументВозвратТовара <> Неопределено, ?(ЗначениеЗаполнено(ДокументВозвратТовара.Ссылка), ДокументВозвратТовара.Ссылка, ДокументВозвратТовара.ПолучитьСсылкуНового()), ПараметрыСоздания.РеализацияСсылка);
				НС.Сумма 								= СтруктураОплаты.СуммаОплаты;
			Иначе
				ПкоРко.РасшифровкаПлатежа[0].Основание 	= ?(ДокументВозвратТовара <> Неопределено, ?(ЗначениеЗаполнено(ДокументВозвратТовара.Ссылка), ДокументВозвратТовара.Ссылка, ДокументВозвратТовара.ПолучитьСсылкуНового()), ПараметрыСоздания.РеализацияСсылка);
				ПкоРко.РасшифровкаПлатежа[0].Сумма 		= СтруктураОплаты.СуммаОплаты;	
