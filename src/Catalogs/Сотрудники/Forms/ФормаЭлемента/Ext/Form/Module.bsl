Функция ЗаписатьИПолучитьПромокод(Владелец, Вид)
	
	Возврат РегистрыСведений.Промокоды.ЗаписатьИПолучитьРеферальныйКод(Владелец, Вид);
	
КонецФункции

#КонецОбласти

&НаСервере
// Процедура выполняет заполнение списка стоматологий
//
Процедура ЗаполнитьСписокСтоматологий()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ПометкаУдаления КАК ПометкаУдаления
	|ПОМЕСТИТЬ втДоступныеСтруктурныеЕдиницы
	|ИЗ
	|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиДоступныеСтруктурныеЕдиницы
	|ГДЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = &Сотрудник
	|	И НЕ СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ЭтоГруппа
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сотрудники.Сотрудник КАК Сотрудник,
	|	Сотрудники.ВидЦен КАК ВидЦен,
	|	Сотрудники.ОсновнойШаблонОбследований КАК ОсновнойШаблонОбследований,
	|	Сотрудники.РазрешитьПриемНесколькихПациентов КАК РазрешитьПриемНесколькихПациентов,
	|	Сотрудники.Ассистент КАК Ассистент,
	|	Сотрудники.МаксимальнаяРучнаяСкидка КАК МаксимальнаяРучнаяСкидка,
	|	Сотрудники.ДатаПриема КАК ДатаПриема,
	|	Сотрудники.ДатаУвольнения КАК ДатаУвольнения
	|ПОМЕСТИТЬ втНастройкиСотрудника
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Сотрудник = &Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	втДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	втДоступныеСтруктурныеЕдиницы.ПометкаУдаления КАК ПометкаУдаления,
	|	Сотрудники.Сотрудник КАК Сотрудник,
	|	Сотрудники.ВидЦен КАК ВидЦен,
	|	Сотрудники.ОсновнойШаблонОбследований КАК ОсновнойШаблонОбследований,
	|	Сотрудники.РазрешитьПриемНесколькихПациентов КАК РазрешитьПриемНесколькихПациентов,
	|	Сотрудники.Ассистент КАК Ассистент,
	|	Сотрудники.МаксимальнаяРучнаяСкидка КАК МаксимальнаяРучнаяСкидка,
	|	Сотрудники.ДатаПриема КАК ДатаПриема,
	|	Сотрудники.ДатаУвольнения КАК ДатаУвольнения
	|ИЗ
	|	втДоступныеСтруктурныеЕдиницы КАК втДоступныеСтруктурныеЕдиницы
	|		ЛЕВОЕ СОЕДИНЕНИЕ втНастройкиСотрудника КАК Сотрудники
	|		ПО втДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = Сотрудники.СтруктурнаяЕдиница");
	
	Запрос.УстановитьПараметр("Сотрудник", Объект.Ссылка);
	
	ТаблицаНастроекСотрудника = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЗ из ТаблицаНастроекСотрудника Цикл
		
		НоваяСтрока = ДоступныеСтруктурныеЕдиницы.Добавить();
		НоваяСтрока.СтруктурнаяЕдиница 		= СтрокаТЗ.СтруктурнаяЕдиница;
		НоваяСтрока.ПометкаУдаления 		= СтрокаТЗ.ПометкаУдаления;
		НоваяСтрока.ДатаПриема			 	= СтрокаТЗ.ДатаПриема;
		НоваяСтрока.ДатаУвольнения 			= СтрокаТЗ.ДатаУвольнения;
		
	КонецЦикла;
	
	ЭтотОбъект.НастройкиСотрудников_new.Загрузить(ТаблицаНастроекСотрудника);
	
КонецПроцедуры

&НаСервере
// Процедура формирует поля настроек для сотрудника
//
Процедура СформироватьДинамическиеЭлементыНастроек(ДляСотрудника = Истина)
	
	МассивНастроек = Новый Массив;	
	Если ДляСотрудника Тогда
		МассивНастроек.Добавить("ВидЦен");
		МассивНастроек.Добавить("ОсновнойШаблонОбследований");
		МассивНастроек.Добавить("Ассистент");
		МассивНастроек.Добавить("МаксимальнаяРучнаяСкидка");
	КонецЕсли;
	
	Если ЭтотОбъект.ПользователиИБСуществующие.Количество() > 0  Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		ПользовательИБ = ЭтотОбъект.ПользователиИБСуществующие[0].Пользователь;	
		Объект.ИдентификаторПользователяИБ = Новый УникальныйИдентификатор(ПользовательИБ.ИдентификаторПользователяИБ);
		ПрежнийИдПользователя = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.Ссылка,"ИдентификаторПользователяИБ");
		Если Объект.ИдентификаторПользователяИБ <> ПрежнийИдПользователя Тогда
			ЭтаФорма.Записать();
		КонецЕсли;
	
		РесурсыПользователя = Новый Массив;
		
		ФИОПользователя = ПользовательИБ.Наименование;
		Элементы.ФИОПользователя.Гиперссылка = Истина;	
		ДоступКИБ = ПользовательИБ.ЭтоПользовательИБ;
		
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли;

	Для Каждого Настройка Из МассивНастроек Цикл
		
		Если РесурсыПользователя <> Неопределено И РесурсыПользователя.Найти(ПланыВидовХарактеристик.НастройкиПользователей.НайтиПоНаименованию(Настройка)) <> Неопределено Тогда
			РесурсыНастройки = РесурсыПользователя.Получить(РесурсыПользователя.Найти(ПланыВидовХарактеристик.НастройкиПользователей.НайтиПоНаименованию(Настройка)));
			ЗаголовокЭлемента = РесурсыНастройки.Наименование;
			ТипЭлемента = РесурсыНастройки.ТипЗначения;
			Настройка = СтрЗаменить(Настройка, " ", "");
		Иначе
			РесурсыНастройки = Метаданные.РегистрыСведений.НастройкиСотрудников.Ресурсы[Настройка];
			ЗаголовокЭлемента = РесурсыНастройки.Представление();	
			ТипЭлемента = РесурсыНастройки.Тип;
		КонецЕсли;
		
		ГруппаНастройкаНаФорме = Элементы.Добавить("ГруппаНастройка_" + Настройка, Тип("ГруппаФормы"), Элементы.ГруппаНастрокиСотрудников);
		ГруппаНастройкаНаФорме.Вид		   = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаНастройкаНаФорме.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		ГруппаНастройкаНаФорме.Отображение = ОтображениеОбычнойГруппы.Нет;		
		ГруппаНастройкаНаФорме.ОтображатьЗаголовок = Ложь;
		ГруппаНастройкаНаФорме.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить(Новый РеквизитФормы("НастройкаСотрудника_" + Настройка, ТипЭлемента));
		                  
		// Добавляем реквизит.
		ЭтаФорма.ИзменитьРеквизиты(МассивРеквизитов);
		
		// Заполнить реквизит.
		
		ДоступнаяСтруктурнаяЕдиница = ПолучитьТекущуюИлиДоступнуюСЕ();
		
		Если ЗначениеЗаполнено(ДоступнаяСтруктурнаяЕдиница) Тогда
			СтрокаНастроек = ЭтотОбъект.НастройкиСотрудников_new.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ДоступнаяСтруктурнаяЕдиница))[0];
			ЭтотОбъект["НастройкаСотрудника_" + Настройка] = СтрокаНастроек[Настройка];
		КонецЕсли;
		
		ПолеНастройка = Элементы.Добавить("ПолеНастройка_" + Настройка, Тип("ПолеФормы"), ГруппаНастройкаНаФорме);
		ПолеНастройка.ПутьКДанным              = "НастройкаСотрудника_" + Настройка;
		ПолеНастройка.Вид                      = ВидПоляФормы.ПолеВвода;
		ПолеНастройка.Заголовок				   = ЗаголовокЭлемента;
		ПолеНастройка.АвтоМаксимальнаяШирина   = Ложь;
		ПолеНастройка.РастягиватьПоГоризонтали = Истина;
		ПолеНастройка.ГоризонтальноеПоложение  = ГоризонтальноеПоложениеЭлемента.Лево;
		ПолеНастройка.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Лево; 
		
		Если Настройка = "МаксимальнаяРучнаяСкидка" Тогда						
			ПолеНастройка.Подсказка 		       = "Максимальное значение скидки 99,99 %";
			ПолеНастройка.МаксимальнаяШирина	   = 5;
			ПолеНастройка.Ширина              	   = 5;
			ПолеНастройка.РастягиватьПоГоризонтали = Ложь;
			ПолеНастройка.ГоризонтальноеПоложение  = ГоризонтальноеПоложениеЭлемента.Лево;
			
			ДекорацияПроцент = Элементы.Добавить("ДекорацияПроцент_" + Настройка, Тип("ДекорацияФормы"),ГруппаНастройкаНаФорме); 
			ДекорацияПроцент.Заголовок 		          = " %";
			ДекорацияПроцент.РастягиватьПоГоризонтали = Истина;
		КонецЕсли;
		
		ПолеНастройка.УстановитьДействие("ПриИзменении", "ПолеНастройка_ШаблонПриИзменении");
		ПолеНастройка.УстановитьДействие("НачалоВыбора", "ПолеНастройка_ШаблонНачалоВыбора");
		
		ГруппаНастройкаВсплывающая = Элементы.Добавить("ГруппаНастройкаВсплывающая_" + Настройка, Тип("ГруппаФормы"), ГруппаНастройкаНаФорме);
		ГруппаНастройкаВсплывающая.Вид 							= ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаНастройкаВсплывающая.Поведение   					= ПоведениеОбычнойГруппы.Всплывающая;
		ГруппаНастройкаВсплывающая.Группировка 					= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаНастройкаВсплывающая.Заголовок   					= " ";
		ГруппаНастройкаВсплывающая.ОтображатьЗаголовок 			= Истина;
		ГруппаНастройкаВсплывающая.ЦветТекстаЗаголовка 			= Новый Цвет(255, 255, 255);
		ГруппаНастройкаВсплывающая.ШрифтЗаголовка      			= Новый Шрифт(ГруппаНастройкаВсплывающая.ШрифтЗаголовка,, 1);
		ГруппаНастройкаВсплывающая.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
		
		ДекорацияФормыПредставлениеВсплывающая = Элементы.Добавить("ДекорацияПредставлениеВсплывающая_" + Настройка, Тип("ДекорацияФормы"), ГруппаНастройкаВсплывающая);
		ДекорацияФормыПредставлениеВсплывающая.Вид 					    = ВидДекорацииФормы.Надпись;
		ДекорацияФормыПредставлениеВсплывающая.Заголовок                = ЗаголовокЭлемента;
		ДекорацияФормыПредставлениеВсплывающая.ЦветТекста 			    = Новый Цвет(25, 116, 206);
		ДекорацияФормыПредставлениеВсплывающая.Ширина 	  			    = 25;
		ДекорацияФормыПредставлениеВсплывающая.ГоризонтальноеПоложение  = ГоризонтальноеПоложениеЭлемента.Лево;
		ДекорацияФормыПредставлениеВсплывающая.Шрифт					= Новый Шрифт(ДекорацияФормыПредставлениеВсплывающая.Шрифт,, 11);
		
		ТаблицаНастроек = Элементы.Добавить("НастройкиСотрудников_" + Настройка, Тип("ТаблицаФормы"), ГруппаНастройкаВсплывающая);
		ТаблицаНастроек.ПутьКДанным              = "НастройкиСотрудников_new";
		ТаблицаНастроек.Отображение              = ОтображениеТаблицы.Список;
		ТаблицаНастроек.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ТаблицаНастроек.Ширина                   = 60;
		ТаблицаНастроек.РастягиватьПоГоризонтали = Ложь;
		ТаблицаНастроек.РастягиватьПоВертикали   = Ложь;
		ТаблицаНастроек.ГоризонтальныеЛинии      = Ложь;
		ТаблицаНастроек.ЦветРамки                = Новый Цвет(255, 255, 255);
		ТаблицаНастроек.Шапка                    = Ложь;
		ТаблицаНастроек.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
		
		ТаблицаНастроек.УстановитьДействие("ПриАктивизацииСтроки", "Подключаемый_НастройкиСотрудниковПриАктивизацииСтроки");
		
		ЭлементСтруктурнаяЕдиница = Элементы.Добавить("НастройкиСотрудниковСтруктурнаяЕдиница_" + Настройка, Тип("ПолеФормы"), ТаблицаНастроек);
		ЭлементСтруктурнаяЕдиница.ПутьКДанным              = "НастройкиСотрудников_new.СтруктурнаяЕдиница";
		ЭлементСтруктурнаяЕдиница.Вид                      = ВидПоляФормы.ПолеВвода;
		ЭлементСтруктурнаяЕдиница.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ЭлементСтруктурнаяЕдиница.РастягиватьПоГоризонтали = Ложь;
		ЭлементСтруктурнаяЕдиница.Ширина				   = 30;
		ЭлементСтруктурнаяЕдиница.ТолькоПросмотр           = Истина; 
				
		ЭлементНастройка = Элементы.Добавить("НастройкиСотрудниковЗначение_" + Настройка, Тип("ПолеФормы"), ТаблицаНастроек);
		ЭлементНастройка.ПутьКДанным              = "НастройкиСотрудников_new." + Настройка;
		ЭлементНастройка.Вид                      = ВидПоляФормы.ПолеВвода;
		ЭлементНастройка.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ЭлементНастройка.РастягиватьПоГоризонтали = Ложь;
			
		ЭлементНастройка.УстановитьДействие("ПриИзменении", "Подключаемый_НастройкиСотрудникаПриИзменении");
		ЭлементНастройка.УстановитьДействие("НачалоВыбора", "ПолеНастройка_ШаблонНачалоВыбора");
		
		Если Настройка = "ОсновнойШаблонОбследований" Тогда
			
			ПолеНастройка.Заголовок = "Шаблон обследований";
				
		КонецЕсли;	
		
		КомандаЕще = Элементы.Добавить("КомандаНажатияЕще_" + Настройка, Тип("КнопкаФормы"), ГруппаНастройкаНаФорме);
		КомандаЕще.Вид 					    = ВидКнопкиФормы.ОбычнаяКнопка;
		КомандаЕще.Заголовок                = "Еще";
		КомандаЕще.ИмяКоманды 				= "КомандаНажатиеЕще";
		КомандаЕще.ОтображениеФигуры		= ОтображениеФигурыКнопки.Нет;
		КомандаЕще.ЦветТекста				= Новый Цвет(25,116,206);
		КомандаЕще.Шрифт					= Новый Шрифт(,,,,Истина);

	КонецЦикла;
	
	Элементы.ГруппаНастройка_Шаблон.Видимость = Ложь;

КонецПроцедуры

&НаСервере
// Процедура выполняет заполнение настроек по умолчанию. 
//
Процедура УстановитьНастройкиСотрудникаПоУмолчанию(СтруктурнаяЕдиница)
	
	СтруктураНастроек = Новый Структура("ВидЦен, РазрешитьПриемНесколькихПациентов, ОсновнойШаблонОбследований, МаксимальнаяРучнаяСкидка",
	Справочники.ВидыЦен.ПустаяСсылка(), Ложь, Справочники.ШаблоныОбследований.ПустаяСсылка(), 0);
	
	Если ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг() Тогда
		ШаблонПоУмолчанию = ПолучитьШаблонОсмотраСтоматолога();
        СтруктураНастроек.ОсновнойШаблонОбследований = ?(ЗначениеЗаполнено(ШаблонПоУмолчанию), ШаблонПоУмолчанию, СтруктураНастроек.ОсновнойШаблонОбследований);
	КонецЕсли;	
	
	СтрокаНастроек = ЭтотОбъект.НастройкиСотрудников_new.Добавить();
	СтрокаНастроек.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
	
 	Для Каждого НастройкаПоУмолчанию Из СтруктураНастроек Цикл
				
		СтрокаНастроек[НастройкаПоУмолчанию.Ключ] = НастройкаПоУмолчанию.Значение;
		
	КонецЦикла;
	
КонецПроцедуры

