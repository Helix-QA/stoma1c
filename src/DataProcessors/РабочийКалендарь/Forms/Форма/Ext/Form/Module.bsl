	ТекстHTML = СтрЗаменить(ТекстHTML, "{ФИО}"   			    , ЭтотОбъект.Контрагент.Наименование);
	ТекстHTML = СтрЗаменить(ТекстHTML, "{НавигационнаяСсылка}"  , ПолучитьНавигационнуюСсылку(ЭтотОбъект.Контрагент.Ссылка));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ОсновнаяИнформация}"   , ?(ВыводитьБлокОсновнаяИнформация   , ОсновнаяИнформация   , ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ПредварительнаяЗапись}", ?(ВыводитьБлокПредварительнаяЗапись, ПредварительнаяЗапись, ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ПринадлежитСегментам}" , ?(ВыводитьБлокПринадлежитСегментам , ПринадлежитСегментам , ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{СтраховыеПолисы}"      , ?(ВыводитьБлокСтраховыеПолисы      , СтраховыеПолисы      , ""));     
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Скидки}"               , ?(ВыводитьБлокСкидки               , Скидки               , ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ЛистОжидания}"         , ?(ВыводитьБлокЛистОжидания         , ЛистОжидания         , ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ПланыЛечения}"         , ?(ВыводитьБлокПланыЛечения         , ПланыЛечения         , ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ИсторияПриемов}"       , ?(ВыводитьБлокИсторияПриемов       , ИсторияПриемов       , ""));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{НарядЗаказы}"          , ?(ВыводитьБлокНарядЗаказы          , НарядЗаказы          , ""));
		
	ИсторияВзаимодействия = ТекстHTML;
	
КонецПроцедуры

