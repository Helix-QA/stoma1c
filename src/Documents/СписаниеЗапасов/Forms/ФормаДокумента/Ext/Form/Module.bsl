&НаКлиенте
Процедура УстановитьДоступностьЭлементов(ТипСтр = "СправочникСсылка.")
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоСкладу") Тогда
		ТипСтр = ТипСтр + "Склады";
		Элементы.Склад.Заголовок = "Склад";
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоСотруднику") Тогда
		ТипСтр = ТипСтр + "Сотрудники";
		Элементы.Склад.Заголовок = "Персонал";
	Иначе
		Возврат;
	КонецЕсли;
	
	Элементы.Склад.ОграничениеТипа = Новый ОписаниеТипов(ТипСтр);
	Элементы.ЗапасыСклад.ОграничениеТипа = Новый ОписаниеТипов(ТипСтр);
	
