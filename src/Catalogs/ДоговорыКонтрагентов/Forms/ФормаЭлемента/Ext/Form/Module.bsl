// Процедура, обработчик события формы "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Не ЗначениеЗаполнено(Объект.Наименование) Тогда
		Объект.Наименование = СтрШаблон(НСтр("ru = 'Договор № %1 от %2 c %3'"),
		СокрЛП(Объект.НомерДоговора),
		СокрЛП(Строка(Формат(Объект.ДатаДоговора, "ДФ=dd.MM.yyyy"))), 
		СокрЛП(Объект.Контрагент)); 
	КонецЕсли;
	
КонецПроцедуры

&НаСервере 
// Процедура, обработчик события формы "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ДеревоВТаблицу(ТекущийОбъект);
	
	// Проверка на заполненность "При превышении" в необходимых строках	
	МассивСтрокиСПревышением = ТекущийОбъект.УслугиПоДоговору.НайтиСтроки(Новый Структура("Согласование, КоличествоПриПревышении", Перечисления.ТипыСогласованийУслугСтраховойКомпании.ПриПревышении, 0));
	Для Каждого ПроверяемаяСтрока Из МассивСтрокиСПревышением Цикл	
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено количество при превышении в строке с номенклатурой: " + ПроверяемаяСтрока.Номенклатура);
		Отказ = Истина; 
		
	КонецЦикла;	
	
КонецПроцедуры

