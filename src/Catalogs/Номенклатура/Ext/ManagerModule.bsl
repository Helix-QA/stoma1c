
#Область СлужебныеПроцедурыИФункции

// Процедура печати элемента справочника.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	//ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТехнологическаяКарта") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"ТехнологическаяКарта",
		"Технологическая карта",
		СформироватьПечатнуюФормуТехнологическойКарты(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
		
	КонецЕсли;
	
КонецПроцедуры 

// Функция - Сформировать печатную форму технологической карты
//
// Параметры:
//  ОбъектПечати	 - 	 - 
//  ОбъектыПечати	 - 	 - 
//  ПараметрыПечати	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьПечатнуюФормуТехнологическойКарты(ОбъектПечати, ОбъектыПечати, ПараметрыПечати)
	
	Макет = УправлениеПечатью.ПолучитьМакет("Справочник.Номенклатура.ТехнологическаяКарта");
	Если ПараметрыПечати.Свойство("ОтборСтруктурнаяЕдиница") Тогда 
		
		ОтборСтруктурнаяЕдиница = ПараметрыПечати.ОтборСтруктурнаяЕдиница;
		
		Если ОтборСтруктурнаяЕдиница.Пустая() Тогда
			ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		КонецЕсли;
		
	Иначе
		ОтборСтруктурнаяЕдиница = Неопределено;
	КонецЕсли;	
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ТехнологическаяКарта";
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;

	Для Каждого ТекущийОбъект Из ОбъектПечати Цикл
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		Руководитель = ПолучитьОтветственноеЛицо(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация, Перечисления.ТипыОтветственныхЛиц.Руководитель);
		Организация  = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
		
		ОбластьМакета = Макет.ПолучитьОбласть("ШапкаФормы");
		ОбластьМакета.Параметры.НаименованиеОрганизации = ?(ЗначениеЗаполнено(Организация), Организация.ПолноеНаименование(), Неопределено);
		ОбластьМакета.Параметры.ПолеУслуга      		= Строка(ТекущийОбъект.ТипНоменклатуры)+": ";
		ОбластьМакета.Параметры.ДолжностьРуководителя 	= Руководитель.Должность;
		ОбластьМакета.Параметры.ФИОРуководителя 		= Руководитель.ФИО;
		ОбластьМакета.Параметры.ДатаТехКарты 			= ТекущаяДата();	
		ОбластьМакета.Параметры.Услуга      			= ТекущийОбъект.Наименование;	
		ОбластьМакета.Параметры.РозничнаяЦена 			= ПолучитьЦенуНоменклатуры(ТекущийОбъект.Ссылка,, Справочники.УпаковкиНоменклатуры.ПустаяСсылка(), ПредопределенноеЗначение("Справочник.ВидыЦен.Розничная"));
		
		ТабДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("СтрокаТаблицы");
		ОбластьМакетаСтруктурнаяЕдиница = Макет.ПолучитьОбласть("СтруктурнаяЕдиница");
		
		Индекс	= 0;
		Итог	= 0;
		
		Если ОтборСтруктурнаяЕдиница = Неопределено Тогда  // эта ветка не используется. вызывается с отбором по СЕ
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	НормыСписанияМатериалов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			|	НормыСписанияМатериалов.Материал КАК Материал,
			|	НормыСписанияМатериалов.СкладСписания КАК СкладСписания,
			|	НормыСписанияМатериалов.Партия КАК Партия,
			|	НормыСписанияМатериалов.Количество КАК Количество,
			|	НормыСписанияМатериалов.Упаковка КАК Упаковка
			|ИЗ
			|	РегистрСведений.НормыСписанияМатериалов КАК НормыСписанияМатериалов
			|ГДЕ
			|	НормыСписанияМатериалов.Номенклатура = &Номенклатура
			|	И ВЫБОР
			|			КОГДА &ОтборПоСЕ = ИСТИНА
			|				ТОГДА НормыСписанияМатериалов.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
			|			ИНАЧЕ ИСТИНА
			|		КОНЕЦ
			|ИТОГИ ПО
			|	СтруктурнаяЕдиница");
			
			Запрос.УстановитьПараметр("Номенклатура"	  , ТекущийОбъект);
			Запрос.УстановитьПараметр("ОтборПоСЕ"		  , ?(ОтборСтруктурнаяЕдиница = Неопределено, Ложь, Истина));
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаСтруктурнаяЕдиница = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаСтруктурнаяЕдиница.Следующий() Цикл
				
				ОбластьМакетаСтруктурнаяЕдиница.Параметры.СтруктурнаяЕдиница = ВыборкаСтруктурнаяЕдиница.СтруктурнаяЕдиница;
				ТабДокумент.Вывести(ОбластьМакетаСтруктурнаяЕдиница);
				
				ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицы");
				ТабДокумент.Вывести(ОбластьМакета);
				
				ОбластьМакета = Макет.ПолучитьОбласть("СтрокаТаблицы");
				
				Выборка = ВыборкаСтруктурнаяЕдиница.Выбрать();
				
				Пока Выборка.Следующий() Цикл 
					Индекс = Индекс + 1;
					ОбластьМакета.Параметры.Номер = Индекс;
					ОбластьМакета.Параметры.Наименование = Выборка.Материал;
					ОбластьМакета.Параметры.ЕдиницаИзмерения = Выборка.Материал.ЕдиницаИзмерения;
					
					Если ЗначениеЗаполнено(Выборка.Упаковка) Тогда
						Количество = Выборка.Упаковка.Коэффициент * Выборка.Количество;
					Иначе
						Количество = Выборка.Количество;
					КонецЕсли;	
					ОбластьМакета.Параметры.Количество = Количество;
					ОбластьМакета.Параметры.Себестоимость = ПолучитьЦенуНоменклатуры(Выборка.Материал, Количество, Выборка.Упаковка, ПредопределенноеЗначение("Справочник.ВидыЦен.Закупочная"));
					
					Итог = Итог + ОбластьМакета.Параметры.Себестоимость;
					ТабДокумент.Вывести(ОбластьМакета);
				КонецЦикла;
				
			КонецЦикла;
			
		Иначе
			
			ТаблицаНормСписания = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(ОбъектПечати[0], ОтборСтруктурнаяЕдиница);
			
			ОбластьМакетаСтруктурнаяЕдиница.Параметры.СтруктурнаяЕдиница = "" + ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), ОтборСтруктурнаяЕдиница, "Общие нормы списания")+ "" + ?(ТаблицаНормСписания.Количество() = 0, " (нормы списания не используются)", "");
			
			ТабДокумент.Вывести(ОбластьМакетаСтруктурнаяЕдиница);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицы");
			ТабДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("СтрокаТаблицы"); 
			ВидЦены = ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница.ВидЦенРеализации), ОтборСтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Закупочная);
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ТаблицаНормСписания"	, ТаблицаНормСписания);
			Запрос.УстановитьПараметр("ДатаОбработки"		, ТекущаяДатаСеанса());
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
			Запрос.УстановитьПараметр("ВидЦен"				, ВидЦены);	
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ТаблицаНормСписания.Материал КАК Материал,
			|	ТаблицаНормСписания.Упаковка КАК Упаковка
			|ПОМЕСТИТЬ ВременнаяТаблицаНормСписания
			|ИЗ
			|	&ТаблицаНормСписания КАК ТаблицаНормСписания
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВременнаяТаблицаНормСписания.Материал КАК Номенклатура,
			|	ЦеныНоменклатурыСрезПоследних.Упаковка КАК Упаковка,
			|	ЦеныНоменклатурыСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК Цена
			|ИЗ
			|	ВременнаяТаблицаНормСписания КАК ВременнаяТаблицаНормСписания
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
			|				&ДатаОбработки,
			|				Актуальность = ИСТИНА
			|					И (СтруктурнаяЕдиница = &СтруктурнаяЕдиница
			|						ИЛИ СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))
			|					И ВидЦен = &ВидЦен) КАК ЦеныНоменклатурыСрезПоследних
			|		ПО ВременнаяТаблицаНормСписания.Материал = ЦеныНоменклатурыСрезПоследних.Номенклатура
			|
			|УПОРЯДОЧИТЬ ПО
			|	ВременнаяТаблицаНормСписания.Материал,
			|	ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент";
			
			ТаблицаЦен = Запрос.Выполнить().Выгрузить();      
			
			Для Каждого СтрокаТЗ Из ТаблицаНормСписания Цикл
				Индекс = Индекс + 1;
				ОбластьМакета.Параметры.Номер = Индекс;
				ОбластьМакета.Параметры.Наименование		= СтрокаТЗ.Материал;
				ОбластьМакета.Параметры.ЕдиницаИзмерения	= ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТЗ.Материал, "ЕдиницаИзмерения");
				
				Количество = ?(ЗначениеЗаполнено(СтрокаТЗ.Упаковка), СтрокаТЗ.Упаковка.Коэффициент * СтрокаТЗ.Количество, СтрокаТЗ.Количество);
				
				ОбластьМакета.Параметры.Количество			= Количество;
				//ОбластьМакета.Параметры.Себестоимость		= ПолучитьЦенуНоменклатуры(СтрокаТЗ.Материал, Количество, СтрокаТЗ.Упаковка, ПредопределенноеЗначение("Справочник.ВидыЦен.Закупочная"));
				
				СтруктураПараметров = Новый Структура;
				СтруктураПараметров.Вставить("Номенклатура"			, СтрокаТЗ.Материал);
				СтруктураПараметров.Вставить("Упаковка"				, СтрокаТЗ.Упаковка);
				СтруктураПараметров.Вставить("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
				
				ТаблицаЦенМатериала = ТаблицаЦен.Скопировать(Новый Структура("Номенклатура", СтрокаТЗ.Материал));
				
				Цена = Ценообразование.ВозвратитьЦенуУпаковкиИзТаблицыЦен(ТаблицаЦенМатериала, СтруктураПараметров);
				//Цена = Ценообразование.ОкруглитьЦену(Цена, ВидЦены.ПорядокОкругления, ВидЦены.ОкруглятьВБольшуюСторону);
				
				ОбластьМакета.Параметры.Себестоимость	=  Цена * СтрокаТЗ.Количество;// * Количество;      
					
				Итог = Итог + ОбластьМакета.Параметры.Себестоимость;
				ТабДокумент.Вывести(ОбластьМакета);
			КонецЦикла;        		
			
		КонецЕсли;
		
	КонецЦикла;
	ОбластьМакета = Макет.ПолучитьОбласть("ИтоговаяСтрокаТаблицы");
	ОбластьМакета.Параметры.Итог = Итог;
	ТабДокумент.Вывести(ОбластьМакета);
	
	
	ОбластьМакета = Макет.ПолучитьОбласть("ПодвалФормы");
	ОбластьМакета.Параметры.ДолжностьРуководителя = Руководитель.Должность;
	ОбластьМакета.Параметры.ФИОРуководителя = Руководитель.ФИО;
	ОбластьМакета.Параметры.ФИОБухгалтера = ПолучитьОтветственноеЛицо(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация, Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер).ФИО;
	
	ТабДокумент.Вывести(ОбластьМакета);
	
	ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	
	//УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, ОбъектПечати);
	
	Возврат ТабДокумент;
	
КонецФункции 

// Функция - Получить ответственное лицо
//
// Параметры:
//  Организация				 - 	 - 
//  ТипОтветственногоЛица	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОтветственноеЛицо(Организация, ТипОтветственногоЛица)
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОтветственныеЛицаСрезПоследних.Сотрудник,
	|	ОтветственныеЛицаСрезПоследних.Должность
	|ИЗ
	|	РегистрСведений.ОтветственныеЛица.СрезПоследних КАК ОтветственныеЛицаСрезПоследних
	|ГДЕ
	|	ОтветственныеЛицаСрезПоследних.Организация = &Организация
	|	И ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица = &ТипОтветственногоЛица");
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ТипОтветственногоЛица", ТипОтветственногоЛица);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Новый Структура("ФИО, Должность", Результат.Сотрудник, Результат.Должность);
	Иначе
		Возврат Новый Структура("ФИО, Должность", "", "");
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЦенуНоменклатуры(Ссылка, Количество = 1, Упаковка, ВидЦен, СтруктурнаяЕдиница = Неопределено) Экспорт
	
	СтруктурнаяЕдиница = ?(СтруктурнаяЕдиница = Неопределено, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, СтруктурнаяЕдиница);
	
	ЗапросЦенаНоменклатуры = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ЦеныНоменклатурыСрезПоследних.Упаковка КАК Упаковка,
	|	ЦеныНоменклатурыСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			,
	|			Актуальность = ИСТИНА
	|				И ВидЦен = &ВидЦен
	|				И Номенклатура = &Ссылка
	|				И (СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					ИЛИ СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка))) КАК ЦеныНоменклатурыСрезПоследних");
	
	ЗапросЦенаНоменклатуры.УстановитьПараметр("Ссылка"			  , Ссылка);
	ЗапросЦенаНоменклатуры.УстановитьПараметр("ВидЦен"			  , ВидЦен);
	ЗапросЦенаНоменклатуры.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Результат = ЗапросЦенаНоменклатуры.Выполнить().Выгрузить();
	
	СтрокаТЧ = Результат.Найти(Упаковка, "Упаковка");
	Если СтрокаТЧ <> Неопределено Тогда
		Если ЗначениеЗаполнено(СтрокаТЧ.Упаковка) Тогда
			Возврат (СтрокаТЧ.Цена / СтрокаТЧ.Упаковка.Коэффициент) * ?(Количество > 0, Количество, 1)
		Иначе
			Возврат СтрокаТЧ.Цена * ?(Количество > 0, Количество, 1);
		КонецЕсли;
	ИначеЕсли Результат.Количество() > 0 Тогда
		Если ЗначениеЗаполнено(Результат[0].Упаковка) Тогда
			Возврат (Результат[0].Цена / Результат[0].Упаковка.Коэффициент) * ?(Количество > 0, Количество, 1);
		Иначе
			Возврат Результат[0].Цена * ?(Количество > 0, Количество, 1);
		КонецЕсли;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Функция возвращает список имен «ключевых» реквизитов.
//
Функция ПолучитьБлокируемыеРеквизитыОбъекта() Экспорт
	
	Результат = Новый Массив;
	Результат.Добавить("ТипНоменклатуры");
	
	Возврат Результат;
	
КонецФункции // ПолучитьБлокируемыеРеквизитыОбъекта()

