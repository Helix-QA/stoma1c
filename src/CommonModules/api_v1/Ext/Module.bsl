#Область auth

// Функция осуществляет авторизацию в системе
// 
Функция auth(ApiKey, НомерТелефона, КодПодтверждения, Имя, Фамилия, Отчество, ДатаРождения, email, СтруктурнаяЕдиница, ТипАвторизации = Неопределено) Экспорт		
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(ApiKey);
	
	Если НЕ ЗначениеЗаполнено(НомерТелефона) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1064);
	КонецЕсли;
	
	НомерТелефона		 = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона);
	ТестовыйПользователь = ?(НомерТелефона = "70000000000", Истина, Ложь);
	
	Контрагент = ПолучитьКонтрагентаПоНомеруТелефона(НомерТелефона);
	
	СтруктураКлючаКлиента = РегистрыСведений.КлючиВнешнихСистем.ПолучитьПоследнююЗаписьОКлючеКлиента(ВнешняяСистема, НомерТелефона);
	СтатусКлюча 		  = ?(СтруктураКлючаКлиента <> Неопределено, СтруктураКлючаКлиента.Статус, Неопределено);
	
	Если СтатусКлюча = Перечисления.СтатусыКлючейВнешнихСистем.ОжиданиеПодтверждения
		И СтруктураКлючаКлиента.КодДействителенДо < ТекущаяДатаСеанса()
		И ЗначениеЗаполнено(КодПодтверждения) Тогда
		
		Возврат ПолучитьСтруктуруВозвратаОшибки(1068);
	КонецЕсли;
	
	ОтключитьПодтверждениеОнлайнЗаписи = (ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи 
											И ВнешняяСистема.АвторизацияПоКодуБезСМС)
										ИЛИ ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ПроДокторов;
	
	Если ОтключитьПодтверждениеОнлайнЗаписи
		ИЛИ (СтатусКлюча = Перечисления.СтатусыКлючейВнешнихСистем.ОжиданиеПодтверждения
		И ЗначениеЗаполнено(КодПодтверждения)) Тогда
		
		Если НЕ ОтключитьПодтверждениеОнлайнЗаписи
			И КодПодтверждения <> СокрЛП(СтруктураКлючаКлиента.КодПодтверждения) Тогда
			Возврат ПолучитьСтруктуруВозвратаОшибки(1065);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Контрагент) И ЗначениеЗаполнено(email) И Не ДанныйEmailИспользуется(Контрагент, email) Тогда
			
			Попытка
				КонтрагентОбъект = Контрагент.ПолучитьОбъект();
				ЗаполнитьАдресЭлектроннойПочты(КонтрагентОбъект, email);
				КонтрагентОбъект.Записать();
				Контрагент = КонтрагентОбъект.Ссылка;
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
		Контрагент 		 = ?(ЗначениеЗаполнено(Контрагент), Контрагент, СоздатьКлиента(НомерТелефона, СтруктурнаяЕдиница, Фамилия, Имя, Отчество, email, ДатаРождения,, ВнешняяСистема));
		
		КодПодтверждения = ?(ОтключитьПодтверждениеОнлайнЗаписи, "", СтруктураКлючаКлиента.КодПодтверждения);
		UserToken 		 = ЗаписатьUserToken(?(ОтключитьПодтверждениеОнлайнЗаписи, ВнешняяСистема, СтруктураКлючаКлиента.ВнешняяСистема), НомерТелефона, Контрагент, КодПодтверждения);
		
		Возврат Новый Структура("Parameters, Errors", Новый Структура("UserToken", UserToken), ПолучитьСтруктуруВозвратаОшибки(,, Истина));
		
	Иначе
		
		Если ТестовыйПользователь Тогда
			НовыйКодПодтверждения = "123456";
		Иначе
			НовыйКодПодтверждения = СгенерироватьКодПодтверждения(ВнешняяСистема);
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.КлючиВнешнихСистем.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
		НаборЗаписей.Отбор.НомерТелефона.Установить(НомерТелефона);
		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.ВнешняяСистема 	  = ВнешняяСистема;
		НоваяЗапись.НомерТелефона  	  = НомерТелефона;
		НоваяЗапись.Клиент	 	  	  = Контрагент;
		НоваяЗапись.КодПодтверждения  = НовыйКодПодтверждения;
		НоваяЗапись.Статус 		      = Перечисления.СтатусыКлючейВнешнихСистем.ОжиданиеПодтверждения;
		НоваяЗапись.КодДействителенДо = ТекущаяДатаСеанса() + 3600;
		
		ТипАвторизацииМессенджер = ТипАвторизации <> Неопределено И НРег(ТипАвторизации) = "whats_app";
		ТипАвторизацииПочта      = ТипАвторизации <> Неопределено И НРег(ТипАвторизации) = "email";
		Сообщение				 = "Ваш код подтверждения: " + НовыйКодПодтверждения;
		
		Если Не ТестовыйПользователь Тогда		
			
			Если ТипАвторизацииМессенджер Тогда
				
				ОписаниеОшибки    = "";
				Контрагент = ?(ЗначениеЗаполнено(Контрагент), Контрагент, СоздатьКлиента(НомерТелефона, СтруктурнаяЕдиница, Фамилия, Имя, Отчество, email, ДатаРождения,, ВнешняяСистема));
				
				РезультатОтправки = ОтправитьСообщениеВМессенджер(Контрагент, НомерТелефона, Сообщение, СтруктурнаяЕдиница, ОписаниеОшибки);
				
				Если НЕ РезультатОтправки Тогда
					Возврат ПолучитьСтруктуруВозвратаОшибки(1120, ?(ЗначениеЗаполнено(ОписаниеОшибки), ОписаниеОшибки, ""));
				КонецЕсли;
				
			ИначеЕсли ТипАвторизацииПочта Тогда
				
				Если Не ЗначениеЗаполнено(email) Тогда //  И Не УправлениеЭлектроннойПочтой.ЭлектроннаяПочтаВведенаВерно(email)
					Возврат ПолучитьСтруктуруВозвратаОшибки(1128, "Не передана электронная почта");	
				КонецЕсли;
				
				УчетнаяЗаписьЭлПочты = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
				
				Если УчетнаяЗаписьЭлПочты.ИспользоватьДляОтправки = Ложь Тогда
					Возврат ПолучитьСтруктуруВозвратаОшибки(1128, "Не заполнена учетная запись");	
				КонецЕсли;
				
				ОписаниеОшибки    = "";
				РезультатОтправки = ОтправитьПисьмоНаПочту(Контрагент, email, Сообщение, СтруктурнаяЕдиница, УчетнаяЗаписьЭлПочты, ОписаниеОшибки);
				
				Если НЕ РезультатОтправки Тогда
					Возврат ПолучитьСтруктуруВозвратаОшибки(1128, ?(ЗначениеЗаполнено(ОписаниеОшибки), ОписаниеОшибки, ""));
				КонецЕсли;
				
			Иначе				
				
				ОписаниеОшибки = "";
				Результат = СоздатьИПровестиДокументSMSРассылка(Контрагент, НомерТелефона, Сообщение, ОписаниеОшибки, СтруктурнаяЕдиница);
				
				Если Не Результат Тогда
					Возврат ПолучитьСтруктуруВозвратаОшибки(1110, ОписаниеОшибки);
				КонецЕсли;			
				
			КонецЕсли;
			
		КонецЕсли;
		
		НаборЗаписей.Записать();
		
		Возврат Новый Структура("Parameters, Errors", Новый Структура("sent_SMS, confirmation_code", Истина, НовыйКодПодтверждения), ПолучитьСтруктуруВозвратаОшибки(,, Истина));
		
	КонецЕсли;
	
КонецФункции

// Функция генерирует случайное число от 1000 до 9999
// 
Функция СгенерироватьКодПодтверждения(ВнешняяСистема) Экспорт
	
	ГенераторСлучайныхЧисел  = Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());
	НижняяГраница   = 1000;
	ВрехнаяяГраница = 9999;
	
	Возврат Формат(ГенераторСлучайныхЧисел.СлучайноеЧисло(НижняяГраница, ВрехнаяяГраница), "ЧГ=0");
	
КонецФункции

// Функция возвращает хеш строки
// 
Функция ПолучитьMD5(Текст) Экспорт
	
	ОбъектХеш = Новый ХешированиеДанных(ХешФункция.MD5);
	ОбъектХеш.Добавить(Текст);
	Возврат ОбъектХеш.ХешСумма;

