	СтрЕдиницаОтбор = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;	
		
КонецПроцедуры

&НаСервере
// Процедура, выполняет заполнение списока документов
//
Процедура ЗаполнитьСписокДокументов(МассивСтатусов = Неопределено, НомерЗаказа = Неопределено)
	
	Если МассивСтатусов = Неопределено Тогда
		МассивСтатусов = Новый Массив;
	КонецЕсли;
	
	Если Не НомерЗаказа = Неопределено Тогда
		НомерВыделеннойСтроки = НомерЗаказа;
	КонецЕсли;
	
	СписокДокументов.Очистить();
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	НарядЗаказЗапасы.Ссылка,
	                      |	НарядЗаказЗапасы.Лаборатория,
	                      |	НарядЗаказЗапасы.Ссылка.Контрагент,
	                      |	НарядЗаказЗапасы.Ссылка.Сотрудник,
	                      |	НарядЗаказЗапасы.Ссылка.Статус КАК СтатусДокумента,
	                      |	НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница,
	                      |	НарядЗаказЗапасы.Номенклатура,
	                      |	НарядЗаказЗапасы.ДатаЗаказа,
	                      |	НарядЗаказЗапасы.ДатаВыполнения,
	                      |	НарядЗаказЗапасы.СуммаПродажи,
	                      |	НарядЗаказЗапасы.НомерЗаказа КАК НомерЗаказа,
	                      |	НарядЗаказЗапасы.Сумма КАК СуммаЗакупки,
	                      |	НарядЗаказЗапасы.Статус,
	                      |	НарядЗаказЗапасы.Ссылка.Дата КАК Дата,
	                      |	НарядЗаказЗапасы.НомерСтроки КАК НомерСтроки,
	                      |	ВЫБОР
	                      |		КОГДА НарядЗаказЗапасы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыНарядЗаказа.Заказано)
	                      |			ТОГДА 0
	                      |		ИНАЧЕ ВЫБОР
	                      |				КОГДА НарядЗаказЗапасы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыНарядЗаказа.ВРаботе)
	                      |					ТОГДА 1
	                      |				ИНАЧЕ 2
	                      |			КОНЕЦ
	                      |	КОНЕЦ КАК Картинка,
	                      |	ВЫБОР
	                      |		КОГДА НарядЗаказЗапасы.НомерЗаказа В (&МассивФлагов)
	                      |			ТОГДА ИСТИНА
	                      |		ИНАЧЕ ЛОЖЬ
	                      |	КОНЕЦ КАК Флаг,
	                      |	НарядЗаказЗапасы.Зуб
	                      |ИЗ
	                      |	Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
	                      |ГДЕ
	                      |	НарядЗаказЗапасы.Ссылка.Проведен
	                      |	И ВЫБОР
	                      |			КОГДА НЕ &СтрЕдиницаОтбор = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	                      |				ТОГДА НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница = &СтрЕдиницаОтбор
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |	И ВЫБОР
	                      |			КОГДА НЕ &ЛабораторияОтбор = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	                      |				ТОГДА НарядЗаказЗапасы.Лаборатория = &ЛабораторияОтбор
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |	И ВЫБОР
	                      |			КОГДА НЕ &КонтрагентОтбор = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	                      |				ТОГДА НарядЗаказЗапасы.Ссылка.Контрагент = &КонтрагентОтбор
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |	И ВЫБОР
	                      |			КОГДА НЕ &ВрачОтбор = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	                      |				ТОГДА НарядЗаказЗапасы.Ссылка.Сотрудник = &ВрачОтбор
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |	И ВЫБОР
	                      |			КОГДА &СтатусДокументаОтбор
	                      |				ТОГДА НарядЗаказЗапасы.Ссылка.Статус = &СтатусДокумента
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |	И ВЫБОР
	                      |			КОГДА НЕ &СтатусОтбор = ЗНАЧЕНИЕ(Перечисление.СтатусыНарядЗаказа.ПустаяСсылка)
	                      |				ТОГДА НарядЗаказЗапасы.Статус = &СтатусОтбор
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |	И НарядЗаказЗапасы.НомерЗаказа ПОДОБНО &НомерЗаказа
	                      |	И ВЫБОР
	                      |			КОГДА НЕ &ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
	                      |				ТОГДА НарядЗаказЗапасы.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	НомерЗаказа");
						  
	Запрос.УстановитьПараметр("СтрЕдиницаОтбор",СтрЕдиницаОтбор);
	Запрос.УстановитьПараметр("КонтрагентОтбор",КонтрагентОтбор);
	Запрос.УстановитьПараметр("ЛабораторияОтбор", ЛабораторияОтбор);
	Запрос.УстановитьПараметр("ВрачОтбор", ВрачОтбор);
	Запрос.УстановитьПараметр("СтатусДокументаОтбор", ?(СтатусДокументаОтбор = 0, Ложь, Истина));
	Запрос.УстановитьПараметр("СтатусДокумента", ?(СтатусДокументаОтбор=1, Ложь, Истина));
	Запрос.УстановитьПараметр("СтатусОтбор", СтатусОтбор);
	Запрос.УстановитьПараметр("НомерЗаказа", СокрЛ(СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("МассивФлагов", МассивСтатусов);
	Запрос.УстановитьПараметр("ДатаНачала", Период.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", Период.ДатаОкончания);
	Результат = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЧ из Результат Цикл
		НоваяСтрока = СписокДокументов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);		
	КонецЦикла;
	Если ЗначениеЗаполнено(НомерВыделеннойСтроки) Тогда
		НайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("НомерЗаказа", НомерВыделеннойСтроки));
		Если НайденныеСтроки.Количество() > 0 Тогда
			Элементы.СписокДокументов.ТекущаяСтрока = НайденныеСтроки[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

