// Процедура, создает исходящее электронное письмо.
//
Процедура ОтправитьПоПочте(ИндексЭлемента)
	
	ДанныеКИ     = ЭтотОбъект.КонтактнаяИнформация[ИндексЭлемента];

	Если Не ЗначениеЗаполнено(ДанныеКИ.Представление) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='У клиента не задан адрес электронной почты';en='Client does not have set email address of mail'"));
		Возврат;
	КонецЕсли;
	
	Если ДанныеКИ.НеУчаствоватьВРассылке = Истина Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='У клиента запрещена рассылка электронных писем';en='Client is prohibited newsletter electronic of letters'"));
		Возврат;
	КонецЕсли;    
	
	СписокАдресовЭП = Новый Массив;
	СписокАдресовЭП.Добавить(ДанныеКИ.Представление);
	
	ПараметрыПисьма = Новый Структура("Получатель,АдресЭП", Объект.Ссылка, ДанныеКИ.Представление);
	
	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыПисьма,,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры
	
