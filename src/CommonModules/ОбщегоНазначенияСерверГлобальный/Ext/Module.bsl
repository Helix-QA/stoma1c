
#Область СлужебныеПроцедурыИФункции

// Функция возвращает информацию о приеме по указанному документу оплаты.
//
Функция ПерейтиЛицевыеСчета_ВернутьПриемПоДокументуОплаты(ДокументОплаты, ДокументАванса = Неопределено) Экспорт
	
	Текст = "";
	
	Если ЗначениеЗаполнено(ДокументАванса) Тогда
		
		Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") ИЛИ ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Прием") Тогда
			
			   Текст = "" +ДокументОплаты;
				
			ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.НарядЗаказ") или ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПланЛечения") ТОгда
				
			   Текст = "" +ДокументАванса;
			   
		КОнецЕсли;
		
	Иначе
		
		Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда
			
			Текст = "" + ДокументОплаты.ВидОперации;
			
			ТабДокументов = Новый ТаблицаЗначений();
			ТабДокументов.Колонки.Добавить("ДокументОснования");
			Для каждого Строка из ДокументОплаты.РасшифровкаПлатежа ЦИкл
				НовСТрока = ТабДокументов.Добавить();
				НовСТрока.ДокументОснования = Строка.ДокументОснования;
			КонецЦикла;
			ТабДокументов.Свернуть("ДокументОснования");
			
			Если ТабДОкументов.Количество()  = 1 Тогда
				Текст = ТабДокументов[0].ДокументОснования;
			
			ИначеЕсли ТабДОкументов.Количество() > 1  Тогда
				Для Каждого СТрока Из ТабДокументов Цикл
					Текст = Текст + СТрока.ДокументОснования+", ";
				КонецЦикла;
				Текст = Лев(Текст,СтрДлина(Текст)-1);
			КонецЕсли; 
		
			
		ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
			
			Текст = "" +ДокументОплаты.ВидОперации;
			
			Если ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования) = Тип("ДокументСсылка.Прием") Тогда
				Текст = "Возврат оплаты приема от " +ФОрмат(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования.Дата, "ДЛФ=DD" );
			КонецЕсли;
					
		Иначе
			//Возврат "Зачисление бонуса по приему от "+ФОрмат(ДокументОплаты.Дата, "ДЛФ=DD" );
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти