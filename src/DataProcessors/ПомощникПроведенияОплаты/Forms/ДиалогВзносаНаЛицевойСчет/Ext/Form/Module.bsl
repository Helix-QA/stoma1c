// Функция выполняет создание и проведение документа ПоступлениеДС
//
Функция ОперацияОплатыСервер(СтруктураЗаполнения, ОписаниеОшибки)  
	
	МассивДокОплаты				= Новый Массив;
	МассивДокОплатыСертификатом = Новый Массив;
	
	МассивСтрокДереваОплата = ПолучитьСтрокиСВнесеннойОплатойСервер();
	
	МассивСтрокДереваОплата = ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(
																				МассивСтрокДереваОплата,
																				"ТипДенежныхСредств,Внесено,Сертификат,ЛицевойСчет,");
	
	Для Каждого ВидОплаты Из МассивСтрокДереваОплата Цикл 
		
		СтруктураЗаполнения = Новый Структура;
		СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница"    	 , ЭтотОбъект.СтруктурнаяЕдиница);
		СтруктураЗаполнения.Вставить("Контрагент"                , ЭтотОбъект.Контрагент);
		СтруктураЗаполнения.Вставить("Касса"                 	 , ЭтотОбъект.Касса);
		СтруктураЗаполнения.Вставить("Сумма"                 	 , ВидОплаты.Внесено);
		СтруктураЗаполнения.Вставить("ВидЛицевогоСчета"      	 , ЭтотОбъект.ВидЛицевогоСчета);
		// СтруктураЗаполнения.Вставить("ЛицевойСчетКонтрагента", ЭтотОбъект.ЛицевойСчетКонтрагента);
		СтруктураЗаполнения.Вставить("ЭквайринговыйТерминал" 	 , ЭтотОбъект.ЭквайринговыйТерминал);
		СтруктураЗаполнения.Вставить("ЭквайрингВидПлатежнойКарты", "");
		СтруктураЗаполнения.Вставить("ТипДенежныхСредств"   	 , ВидОплаты.ТипДенежныхСредств);
		
		ДокументСсылка = СоздатьДокументПоступления(СтруктураЗаполнения, ОписаниеОшибки);
		
		Если ЗначениеЗаполнено(ДокументСсылка) Тогда
			МассивДокОплаты.Добавить(ДокументСсылка);			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Новый Структура("МассивДокОплаты, МассивДокОплатыСертификатом", МассивДокОплаты, МассивДокОплатыСертификатом);	
	
КонецФункции
			
