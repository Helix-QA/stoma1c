			УидВИЭМКПривема = ПроверитьПриемИЭМК(УИДПациентаВИЭМК, УИДПриема, guid, idLPU, Демо);
		КонецЕсли;
		
		РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ПриемДляОтправки, Результат.КодСостояния, Ответ, УидВИЭМКПривема,Строка(ПриемДляОтправки.УникальныйИдентификатор()), КоличествоПопытокПодключения, ТекущаяДатаСеанса());
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке(); 
		Комментарий = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Создание пациента в ИЭМК.'",
		ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,,,
		Комментарий);
		
		РегистрыСведений.ЖурналОбменаИЭМК.ДобавитьЗапись(ПриемДляОтправки, "404", Комментарий, УидВИЭМКПривема, Строка(ПриемДляОтправки.УникальныйИдентификатор()), КоличествоПопытокПодключения, ТекущаяДатаСеанса());
		
	КонецПопытки;
	
КонецПроцедуры

// Процедура производит проверку приема в ИЭМК.
//
Функция ПроверитьПриемИЭМК(КонтрАгентДляОтправки, УИДПриема, guid, idLPU, Демо) Экспорт

	ПараметрыЗапроса = "{
	|""resourceType"": ""Parameters"",
	|""parameter"": [{
	|""name"": ""patients"",
	|""valueString"": """ + КонтрАгентДляОтправки  + """
	|},
	|{
	|""name"": ""count"",
	|""valueString"": 1
	|}
	|]
	|}";

	
// Описываем заголовки HTTP-запроса

	Если Демо Тогда
		АдресСтенда = "b2b-demo.n3health.ru";
	Иначе
		АдресСтенда = "b2b.n3health.ru";
	КонецЕсли;

	HTTPСоединение = Новый HTTPСоединение(АдресСтенда,,,,,5, Новый ЗащищенноеСоединениеOpenSSL());
	
	ЗаголовкиHTTP  = Новый Соответствие; 
	ЗаголовкиHTTP.Вставить("Content-Type","application/json");
	Авторизация = "N3 "+ guid;
	ЗаголовкиHTTP.Вставить("Authorization", Авторизация);
	
	HTTPЗапрос  = Новый HTTPЗапрос("/fhirproxy2/fhir/Encounter/_search", ЗаголовкиHTTP);	
	мДатаНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	HTTPЗапрос.УстановитьТелоИзСтроки(?(ЗначениеЗаполнено(ПараметрыЗапроса), ПараметрыЗапроса, ""));
	
	Попытка
		
		Запрос = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		мДатаКонца = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ВремяВыполненияЗапроса = (мДатаКонца - мДатаНачала) /1000;
		
		
		Ответ = Запрос.ПолучитьТелоКакСтроку();	
		
		ЧтениеXML = Новый ЧтениеXML;	
		
		// Загрузить XML из строки
		ЧтениеXML.УстановитьСтроку(Ответ);	
		
		УИДВПриеме = "";
		ЗакончитьЦикл = Ложь;
		
		ТипОтвета = Запрос.Заголовки.Получить("Content-Type");
		
		Если СтрНайти( ТипОтвета, "xml") > 0 Тогда 
			Пока ЧтениеXML.Прочитать() Цикл
				Если ЧтениеXML.КоличествоАтрибутов() > 0 Тогда
					Пока ЧтениеXML.ПрочитатьАтрибут() Цикл
						// Обработка атрибута
						Если ЧтениеXML.Имя = "value" И Не ЕстьНеЦифры(ЧтениеXML.Значение) И ЧтениеXML.КонтекстПространствИмен.Глубина = 5 Тогда
							УИДВПриеме = ЧтениеXML.Значение;
						КонецЕсли;
						Если ЧтениеXML.Имя = "value" И ЧтениеXML.Значение = "days" Тогда   
							УИДВПриеме = "";
						КонецЕсли;
						Если ЧтениеXML.Имя = "value" И ЧтениеXML.Значение = УИДПриема Тогда
							ЗакончитьЦикл = Истина;
						КонецЕсли;
					КонецЦикла
				КонецЕсли;
				Если ЗакончитьЦикл Тогда 
					Прервать;
				КонецЕсли;                  
			КонецЦикла;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке(); 
		Комментарий = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Проврка приема в ИЭМК.'",
		ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,,,
		Комментарий);
		
		Возврат "Ошибка:" + ИнформацияОбОшибке;
		
		
	КонецПопытки;

Возврат УИДВПриеме;

КонецФункции

// Функция определяет наличие не цифр в строке.
//
Функция ЕстьНеЦифры(Знач СтрокаПроверки) Экспорт


	Если ТипЗнч(СтрокаПроверки) <> Тип("Строка") Тогда
		Возврат Истина;
	КонецЕсли;
	
	СтрокаПроверки = СокрЛП(СтрокаПроверки);
	Длина = СтрДлина(СтрокаПроверки);
	
	Для а = 1 По Длина Цикл
		Если Найти("0123456789", Сред(СтрокаПроверки, а, 1)) = 0 Тогда
			Возврат Истина;
		КонецЕсли; 
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции 

// Функция устанавливает код диагноза по МКБ10.
//
Функция УстановитьКодПоМКБ10(МКБ10) Экспорт

	КодМКБ10 = СтроковыеФункцииКлиентСерверСтоматология.ТранслитерацияРусАнгл(МКБ10);
    КодМКБ10 = СтрЗаменить(КодМКБ10, " ", "");
	МассивМКБ = СтроковыеФункцииКлиентСерверСтоматология.РазложитьСтрокуВМассивПодстрок(КодМКБ10, ";");
	Макет = Справочники.Диагнозы.ПолучитьМакет("КлассификаторДиагнозовПоИЭМК");
	ОбластьТабДокумента = Макет.ПолучитьОбласть("МКБ");
	
	МассивМКБИЭМК = Новый Массив;
	
	Для Каждого Элемент Из МассивМКБ Цикл
		
		Строка = СтрЗаменить( Элемент, Символы.НПП, ""); 
		
		Если Сред(Строка, 2, 1) = "O" Тогда
			Строка = Сред(Строка, 1, 1) + "0" + Прав(Строка, СтрДлина(Строка) - 2);
		КонецЕсли;
		
		ЭлементНайден = Ложь;
		
		Для НомерСтроки = 1 По ОбластьТабДокумента.ВысотаТаблицы Цикл
			Ячейка = "R" + Формат(НомерСтроки, "ЧГ=0") + "C1";
			МКБ10 = Макет.Область(Ячейка).Текст;
			Если МКБ10 = Элемент Тогда
				МассивМКБИЭМК.Добавить(МКБ10);
				ЭлементНайден = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		////////////// Если не нашли полное соответствие ищем без последнего символа ////////////////////////////
		Если Не ЭлементНайден Тогда
			КодМКБ102Вар = Лев(Элемент, СтрДлина(Элемент) - 1);
			
			Для НомерСтроки = 1 По ОбластьТабДокумента.ВысотаТаблицы Цикл
				Ячейка = "R" + Формат(НомерСтроки, "ЧГ=0") + "C1";
				МКБ10 = Макет.Область(Ячейка).Текст;
				Если МКБ10 = КодМКБ102Вар Тогда
					МассивМКБИЭМК.Добавить(МКБ10);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивМКБИЭМК;
	
КонецФункции 

// Процедура - Проверка связи с классификатором должностей
//
Функция ПроверитьВСИЭМК(Сотрудник, Контрагент, Лечение) Экспорт
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);  
		
	Если Не ЗначениеЗаполнено(ВнешняяСистема) Или Контрагент.ТипКонтрагента <> Перечисления.ТипыКонтрагентов.Клиенты Тогда 
		Возврат "";
	КонецЕсли;

	// Если Прием.ВремяОкончанияПриема < Прием.ВремяНачалаПриема Тогда
	//	Возврат "9";
	// КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Сотрудник.Имя) Или Не ЗначениеЗаполнено(Сотрудник.Фамилия) Тогда
		Возврат "6";
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Контрагент.Имя) Или Не ЗначениеЗаполнено(Контрагент.Фамилия) Или Не ЗначениеЗаполнено(Контрагент.ДатаРожденияКлиента) Тогда
		Возврат "5";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сотрудник.Должность) И Не ЗначениеЗаполнено(Сотрудник.Должность.ДолжностьПоКлассификаторуИЭМК) Тогда
		Возврат "2";
	КонецЕсли;
	
	ЗаконныеПредставители = РегистрыСведений.РодственныеСвязи.РодственникиКлиента(Контрагент);
	ЗаконныйПредставитель = Неопределено;
	Если ЗаконныеПредставители.Количество() > 0 Тогда
		ЗаконныйПредставитель = ЗаконныеПредставители[0].Родственник;
		Если ЗначениеЗаполнено(ЗаконныйПредставитель) И Не ЗначениеЗаполнено(ЗаконныеПредставители[0].РеквизитыДокументаЗаконногоПредставителя) Тогда
			Возврат ЗаконныйПредставитель;
		КонецЕсли;
	КонецЕсли;
				
	Если ЗначениеЗаполнено(ЗаконныйПредставитель) 
		И (Не ЗначениеЗаполнено(ЗаконныйПредставитель.Имя) 
		Или Не ЗначениеЗаполнено(ЗаконныйПредставитель.Фамилия) 
		Или Не ЗначениеЗаполнено(ЗаконныйПредставитель.ДатаРожденияКлиента)) Тогда
			Возврат "8";
	КонецЕсли;
	
	СНИЛСПациента = РегистрыСведений.ДокументыФизическихЛиц.ДокументыУдостоверяющиеЛичностьФизлица(Контрагент, ТекущаяДатаСеанса(), Истина, Истина);
	
	//Если СНИЛСПациента.Количество() = 0 Тогда
	//	Возврат "10";
	//КонецЕсли;
	
	Если Сотрудник.СпецилазацииСотрудника.Количество() > 0 Тогда
		Для Каждого Элемент Из Сотрудник.СпецилазацииСотрудника Цикл
			Если Элемент.Основная И Не ЗначениеЗаполнено(Элемент.Специализация.СпециализацияПоКлассификаторуИЭМК) Тогда
				Возврат "4";
			ИначеЕсли Элемент.Основная И ЗначениеЗаполнено(Элемент.Специализация.СпециализацияПоКлассификаторуИЭМК) Тогда
				ТекстОшибки = "";
				Для Каждого Элемент Из Лечение Цикл
					КодВИЭМК = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Элемент.Номенклатура, "НоменклатураМедицинскихУслуг");
					Если Не ЗначениеЗаполнено(КодВИЭМК) Тогда
						ТекстОшибки = ТекстОшибки + "ИЭМК: У услуги: " + Строка(Элемент.Номенклатура) + " не заполнен реквизит НМУ (Номенклатура медецинских услуг). Данные не будут переданы в ИЭМК." + Символы.ПС;
					КонецЕсли;
				КонецЦикла;
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
					Возврат "Ошибка";
				КонецЕсли;
				Возврат "";
			КонецЕсли;
		КонецЦикла;
		Возврат "3";
	Иначе
		Возврат "1";
	КонецЕсли;

КонецФункции        

Функция Подпись(Организация, Сотрудник = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СертификатыКлючейЭлектроннойПодписиИШифрования.Ссылка КАК Ссылка,
		|	СертификатыКлючейЭлектроннойПодписиИШифрования.Программа КАК Программа,
		|	СертификатыКлючейЭлектроннойПодписиИШифрования.ДанныеСертификата КАК ДанныеСертификата,
		|	СертификатыКлючейЭлектроннойПодписиИШифрования.ПарольСертификата КАК ПарольСертификата
		|ИЗ
		|	Справочник.СертификатыКлючейЭлектроннойПодписиИШифрования КАК СертификатыКлючейЭлектроннойПодписиИШифрования
		|ГДЕ
		|	СертификатыКлючейЭлектроннойПодписиИШифрования.Организация = &Организация
		|	И СертификатыКлючейЭлектроннойПодписиИШифрования.Фамилия = &Фамилия";
		//|	И СертификатыКлючейЭлектроннойПодписиИШифрования.Пользователь = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		Запрос.УстановитьПараметр("Фамилия", Сотрудник.Фамилия); 
	Иначе
		Запрос.УстановитьПараметр("Фамилия", ""); 
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		
		ПараметрыСоздания = ЭлектроннаяПодписьСлужебный.ПараметрыСозданияМенеджераКриптографии();
		ПараметрыСоздания.Программа = Результат.Программа;
		ПараметрыСоздания.ОписаниеОшибки = Новый Структура;
		
		МенеджерКриптографии = ЭлектроннаяПодписьСлужебный.МенеджерКриптографии("Подписание", ПараметрыСоздания);
		
		Пароль = Результат.ПарольСертификата;
		
		Если ЗначениеЗаполнено(Пароль) Тогда
			МенеджерКриптографии.ПарольДоступаКЗакрытомуКлючу = Пароль;		
		КонецЕсли;
		
		СертификатКриптографии = Новый СертификатКриптографии(Результат.ДанныеСертификата.Получить());
		
		ДанныеПодписи = МенеджерКриптографии.Подписать(СертификатКриптографии.Выгрузить(), СертификатКриптографии);
		Подпись = СтрЗаменить(СтрЗаменить(Base64Строка(ДанныеПодписи),Символы.ПС, ""), Символы.ВК, "");
		Возврат ?(ЗначениеЗаполнено(Подпись), Подпись, Неопределено);
				
	КонецЕсли;

	Возврат Неопределено;
	
КонецФункции

#КонецОбласти
