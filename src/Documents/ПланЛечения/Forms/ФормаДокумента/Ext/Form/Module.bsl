&НаСервере
// Процедура, выполняет получение макета ЗФ
//
Процедура УстановитьЗубнуюФормулу()
	
	Если ТипЗубнойФормулы = 1 Тогда
		mSvg  = ПолучитьОбщийМакет("SVGПодборДетский").ПолучитьТекст();
	Иначе
		mSvg  = ПолучитьОбщийМакет("SVGПодборВзрослый").ПолучитьТекст();
	КонецЕсли;
	mHTML = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст();
	Svg = СтрЗаменить(mHTML, "SVGElement", mSvg);
	Svg = СтрЗаменить(Svg, "document.getElementById('Layer_1').setAttributeNS(null, 'height', window.innerHeight+'px')", "document.getElementById('Layer_1').setAttributeNS(null, 'height', (window.innerHeight - 15)+'px')");
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет картинку подбора зубов
//
Процедура ОбновитьSVGПодбор(СортироватьТЧ = Ложь)
	// Если СортироватьТЧ Тогда	
	//	Объект.Лечение.Сортировать("НомерПриема Возр");
	// КонецЕсли;
	Если МассивВыделенныхЗубов.Количество() > 0 Тогда
		мЗуб = СтрЗаменить(Строка(МассивВыделенныхЗубов[0].Значение), "Зуб", "");
		Svg  = СтрЗаменить(Svg, SVGВыделенныйЗуб, "var selectzub = '"+мЗуб+"';");	
		SVGВыделенныйЗуб = "var selectzub = '"+мЗуб+"';";
	Иначе
		Svg  = СтрЗаменить(Svg, SVGВыделенныйЗуб, "var selectzub;");	
		SVGВыделенныйЗуб = "var selectzub;";
	КонецЕсли;
	
	Если МножественныйРежимВыделения Тогда
		Svg = СтрЗаменить(Svg, "var FlagSinglSelect = true;", "var FlagSinglSelect = false;");
	КонецЕсли;
	
	мМассив = "mas='";
	Для Каждого строкаТЧ из Объект.Лечение Цикл
		Если Найти(мМассив, Строка(строкаТЧ.зуб)) = 0 и Не строкаТЧ.зуб = ПредопределенноеЗначение("Перечисление.Зубы.ВсяПолость") Тогда
			мМассив = мМассив + СтрокаТЧ.Зуб +",";
		КонецЕсли;
	КонецЦикла;
	Если СтрДлина(мМассив) > 5 Тогда
		мМассив = Сред(мМассив, 1, СтрДлина(мМассив)-1);
	КонецЕсли;
	мМассив = мМассив + "';";
	Svg = СтрЗаменить(Svg, SVGМассивЛечащихсяЗубов, мМассив);
	SVGМассивЛечащихсяЗубов = мМассив;
	
	мМассив = "var SelectedTeeth = [";
	Для Каждого строкаТЧ из МассивВыделенныхЗубов Цикл
		мМассив = мМассив + "'Цвет"+строкаТЧ.Значение+"',";		
	КонецЦикла;
	Если СтрДлина(мМассив) > 21 Тогда
		мМассив = Сред(мМассив, 1, СтрДлина(мМассив)-1);
	КонецЕсли;
	мМассив = мМассив + "];";
	Svg = СтрЗаменить(Svg, SVGМассивВыделенныхЗубов, мМассив);
	SVGМассивВыделенныхЗубов = мМассив;	
	
	УслугиПодборЗубов = Svg;	
	
КонецПроцедуры 

&НаСервере
// Процедура, выполнеяет загрузку состояний и статусов зубной формулы
//
Процедура ЗагрузитьСтатусыЗубов(Дата)
	
	УсловиеДата = "&Дата";

	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Запрос = Новый запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		                      |	ЗубнаяФормулаСрезПоследних.Зуб КАК Зуб,
		                      |	ВЫБОР
		                      |		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		                      |			ТОГДА ""0""
		                      |		ИНАЧЕ ВЫБОР
