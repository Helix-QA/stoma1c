
#Область СлужебныйПрограммныйИнтерфейс

// Функция, возвращает норму времени номенклатуры.
//
// Параметры:
//  Номенклатура		 - 	 - 
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНормуВремениНоменклатуры(Номенклатура, Сотрудник, СтруктурнаяЕдиница) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда 
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|ГДЕ
	|	УслугиСотрудника.Сотрудник = &Сотрудник
	|	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И УслугиСотрудника.Номенклатура = &Номенклатура");
	
	Запрос.УстановитьПараметр("Сотрудник"         , Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Номенклатура"      , Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.НормаВремени;
	Иначе 
		Возврат ОбщегоНазначения.ПолучитьЗначениеРеквизита(Номенклатура, "НормаВремени");
	КонецЕсли;
	
КонецФункции

// Функция, проверяет, может ли оказать услугу переданный сотрудник.
//
// Параметры:
//  Услуга				 - 	 - 
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция УслугаДоступнаДляСотрудника(Услуга, Сотрудник, СтруктурнаяЕдиница = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	УслугиСотрудника.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|ГДЕ
	|	УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И УслугиСотрудника.Сотрудник = &Сотрудник
	|	И УслугиСотрудника.Номенклатура = &Номенклатура");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));
	Запрос.УстановитьПараметр("Сотрудник"         , Сотрудник);
	Запрос.УстановитьПараметр("Номенклатура"      , Услуга);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции	

// Функция, возвращает сотрудников, оказывающих услугу.
//
// Параметры:
//  СтруктурнаяЕдиница		 - 	 - 
//  Номенклатура			 - 	 - 
//  ИсключаемыеСотрудники	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСотрудниковОказывающихУслугу(СтруктурнаяЕдиница, Номенклатура, ИсключаемыеСотрудники = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыОбъектов КАК РеквизитыСотрудников
	|		ПО УслугиСотрудника.Сотрудник = РеквизитыСотрудников.Объект
	|			И УслугиСотрудника.СтруктурнаяЕдиница = РеквизитыСотрудников.СтруктурнаяЕдиница
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
	|		ПО (ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).ИдентификаторПользователяИБ = Пользователи.ИдентификаторПользователяИБ)
	|ГДЕ
	|	УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И УслугиСотрудника.Номенклатура = &Номенклатура
	|	И НЕ УслугиСотрудника.Сотрудник В (&ИсключаемыеСотрудники)
	|	И НЕ УслугиСотрудника.Сотрудник.ПометкаУдаления
	|	И РеквизитыСотрудников.Значение = ИСТИНА
	|	И РеквизитыСотрудников.Реквизит = ""ОнлайнЗаписьСотрудник""
	|	И РеквизитыСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыСотрудников.Объект ССЫЛКА Справочник.Сотрудники
	|	И Пользователи.РольПользователя = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|	И Пользователи.ЭтоПользовательИБ
	|	И НЕ Пользователи.Недействителен
	|	И НЕ Пользователи.Служебный");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	 , СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Номенклатура"	  	 , Номенклатура);
	Запрос.УстановитьПараметр("ИсключаемыеСотрудники", ИсключаемыеСотрудники);
	
	УсловиеИсключаемыеСотрудники = ?(ЗначениеЗаполнено(ИсключаемыеСотрудники), "И НЕ УслугиСотрудника.Сотрудник В (&ИсключаемыеСотрудники)", "");
	Запрос.Текст 				 = СтрЗаменить(Запрос.Текст, "И &УсловиеИсключаемыеСотрудники", УсловиеИсключаемыеСотрудники);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

#КонецОбласти