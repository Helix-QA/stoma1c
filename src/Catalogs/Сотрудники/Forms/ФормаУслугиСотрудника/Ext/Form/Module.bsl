// Функция, возвращает таблицу мест работы
//
Функция ПолучитьМестаРаботы()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.Сотрудник В(&Сотрудник)");
	
	Если Сотрудник.ЭтоГруппа = Истина Тогда
		// Если выбрана группа, получаем сотрудников которые в нее входят.
		Запрос.УстановитьПараметр("Сотрудник", ПолучитьСотрудниковГруппы(Сотрудник));
	Иначе
		Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();	
	
КонецФункции

