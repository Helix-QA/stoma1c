// Функция - Сформировать структуру параметров.
//
// Параметры:
//  НаименованиеПараметра				 - 	 - 
//  ПредставлениеПараметра				 - 	 - 
//  РеквизитПараметра					 - 	 - 
//  ОсновнаяТаблицаОбъекта				 - 	 - 
//  ВидОсновнойТаблицыОбъекта			 - 	 - 
//  ОбъектПараметра						 - 	 - 
//  ПредставлениеОсновнойТаблицаОбъекта	 - 	 - 
//  ИзОсновнойТаблицы					 - 	 - 
//  ФорматПараметра						 - 	 - 
//  ИнициализированВИсходнойТаблице		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьСтруктуруПараметров(
	НаименованиеПараметра,
	ПредставлениеПараметра,
	РеквизитПараметра,
	ОсновнаяТаблицаОбъекта,
	ВидОсновнойТаблицыОбъекта,
	ОбъектПараметра,
	ПредставлениеОсновнойТаблицаОбъекта,
	ИзОсновнойТаблицы,
	ФорматПараметра,
	ИнициализированВИсходнойТаблице)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НаименованиеПараметра"              , НаименованиеПараметра);
	СтруктураПараметров.Вставить("ПредставлениеПараметра"             , ПредставлениеПараметра);
	СтруктураПараметров.Вставить("РеквизитПараметра"                  , РеквизитПараметра);
	СтруктураПараметров.Вставить("ОсновнаяТаблицаОбъекта"             , ОсновнаяТаблицаОбъекта);
	СтруктураПараметров.Вставить("ВидОсновнойТаблицыОбъекта"          , ВидОсновнойТаблицыОбъекта);
	СтруктураПараметров.Вставить("ОбъектПараметра"                    , ОбъектПараметра);
	СтруктураПараметров.Вставить("ПредставлениеОсновнойТаблицаОбъекта", ПредставлениеОсновнойТаблицаОбъекта);
	СтруктураПараметров.Вставить("ИзОсновнойТаблицы"                  , ИзОсновнойТаблицы);
	СтруктураПараметров.Вставить("ФорматПараметра"                    , ФорматПараметра);
	СтруктураПараметров.Вставить("ИнициализированВИсходнойТаблице"    , ИнициализированВИсходнойТаблице);
	
	Возврат СтруктураПараметров;
	
КонецФункции

// Функция - Шаблон используется в триггерных событиях
//
// Параметры:
//  ШаблонСообщений	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ШаблонИспользуетсяВТриггерныхСобытиях(ШаблонСообщений) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ШаблонСообщений) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	               |	ТриггерныеСобытияДействия.Ссылка КАК Шаблон
	               |ИЗ
	               |	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытияДействия
	               |ГДЕ
	               |	ТриггерныеСобытияДействия.ШаблонСообщения = &ШаблонСообщения";
	
	Запрос.УстановитьПараметр("ШаблонСообщения", ШаблонСообщений);
	
	ВыборкаШаблон = Запрос.Выполнить().Выбрать();

	Возврат ВыборкаШаблон.Следующий();
	
КонецФункции

// Функция - Вернуть массив некорректных параметров
//
// Параметры:
//  Содержание	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьМассивНекорректныхПараметров(Содержание) Экспорт 
	
	МассивНеКорректныхПараметров = Новый Массив;
	СимволНачалаПараметра = 1;
	СимволКонцаПараметра = 1;
	Пока СимволНачалаПараметра <> 0 ИЛИ СимволКонцаПараметра <> 0 Цикл 
		СимволНачалаПараметра = СтрНайти(Содержание, "{");
		Если СимволНачалаПараметра <> 0 Тогда 
			СимволКонцаПараметра = СтрНайти(Содержание, "}", , СимволНачалаПараметра);
			Если СимволКонцаПараметра <> 0 И СимволКонцаПараметра > СимволНачалаПараметра Тогда
				НекорректныйПараметр = Сред(Содержание, СимволНачалаПараметра, (СимволКонцаПараметра - СимволНачалаПараметра) + 1);
				Содержание = СтрЗаменить(Содержание, НекорректныйПараметр, "");
				МассивНеКорректныхПараметров.Добавить(НекорректныйПараметр);
			Иначе
				НекорректныйПараметр = Сред(Содержание, СимволНачалаПараметра, 1);								
				Содержание = СтрЗаменить(Содержание, НекорректныйПараметр, "");				
				МассивНеКорректныхПараметров.Добавить(НекорректныйПараметр);
			КонецЕсли;
		Иначе 
			СимволКонцаПараметра = СтрНайти(Содержание, "}");
			Если СимволКонцаПараметра <> 0 Тогда
				НекорректныйПараметр = Сред(Содержание, СимволКонцаПараметра, 1);				
				Содержание = СтрЗаменить(Содержание, НекорректныйПараметр, "");				
				МассивНеКорректныхПараметров.Добавить(НекорректныйПараметр);
			КонецЕсли;
		КонецЕсли;		
	КонецЦикла;	
	
	Возврат МассивНеКорректныхПараметров;
	
КонецФункции

// Процедура - Актуализировать параметры шаблона
//
// Параметры:
//  Шаблон	 - 	 - 
//
Процедура АктуализироватьПараметрыШаблона(Шаблон) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Шаблон) Тогда 
		Возврат;
	КонецЕсли;
	
	НеобходимоЗаписать = Ложь;
	
	ШаблонОбъект 					= Шаблон.ПолучитьОбъект();
	ТаблицаВсехПараметров 			= ОбщегоНазначенияПовтИсп.ПолучитьТаблицуПараметровВсехПодставляемыхРеквизитов();
	Содержание_Проверочное 			= ШаблонОбъект.Содержание;
	ПарсерHTML 						= Новый ЧтениеHTML;
	ПарсерHTML.УстановитьСтроку(ШаблонОбъект.ТекстHTML);
	ПостроительDOM 					= Новый ПостроительDOM;
	ДокументHTML 					= ПостроительDOM.Прочитать(ПарсерHTML);
	Если ДокументHTML.Тело = Неопределено Тогда 
		ТекстHTML_Проверочное 		= "";
	Иначе 	
		ТекстHTML_Проверочное 		= ДокументHTML.Тело.ТекстовоеСодержимое;
	КонецЕсли;	
	ЗадачаОписание_Проверочное 		= ШаблонОбъект.ЗадачаОписание;
	
	Для Каждого СтрокаТаблицы Из ТаблицаВсехПараметров Цикл
		Содержание_Проверочное 		= СтрЗаменить(Содержание_Проверочное	, СтрокаТаблицы.НаименованиеПараметра, ""); 
		ТекстHTML_Проверочное 		= СтрЗаменить(ТекстHTML_Проверочное		, СтрокаТаблицы.НаименованиеПараметра, ""); 
		ЗадачаОписание_Проверочное 	= СтрЗаменить(ЗадачаОписание_Проверочное, СтрокаТаблицы.НаименованиеПараметра, ""); 
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(СокрЛП(Содержание_Проверочное)) Тогда 
		МассивНеКорректныхПараметров = ВернутьМассивНекорректныхПараметров(Содержание_Проверочное);
		Для Каждого НекорректныйПараметр Из МассивНеКорректныхПараметров Цикл 
			ШаблонОбъект.Содержание = СтрЗаменить(ШаблонОбъект.Содержание, НекорректныйПараметр, "");
			НеобходимоЗаписать = Истина;
		КонецЦикла;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СокрЛП(ТекстHTML_Проверочное)) Тогда 
		МассивНеКорректныхПараметров = ВернутьМассивНекорректныхПараметров(ТекстHTML_Проверочное);
		Для Каждого НекорректныйПараметр Из МассивНеКорректныхПараметров Цикл 
			ШаблонОбъект.ТекстHTML = СтрЗаменить(ШаблонОбъект.ТекстHTML, НекорректныйПараметр, ""); 
			НеобходимоЗаписать = Истина;			
		КонецЦикла;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СокрЛП(ЗадачаОписание_Проверочное)) Тогда 
		МассивНеКорректныхПараметров = ВернутьМассивНекорректныхПараметров(ЗадачаОписание_Проверочное);
		Для Каждого НекорректныйПараметр Из МассивНеКорректныхПараметров Цикл 
			ШаблонОбъект.ЗадачаОписание = СтрЗаменить(ШаблонОбъект.ЗадачаОписание, НекорректныйПараметр, ""); 
			НеобходимоЗаписать = Истина;			
		КонецЦикла;	
	КонецЕсли;
	
	Если НеобходимоЗаписать Тогда 
		Попытка
			ШаблонОбъект.ОбменДанными.Загрузка = Истина;
			ШаблонОбъект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЕсли;
	
КонецПроцедуры

// Функция - Инициализировать шаблон сообщения
//
// Параметры:
//  НаименованиеШаблона	 - 	 - 
//  ГенерироватьШаблон	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьШаблонСообщения(НаименованиеШаблона, НаименованиеРодителя = "", ГенерироватьШаблон = Истина) Экспорт

	НаименованиеШаблона = СокрЛП(НаименованиеШаблона);
	Если НЕ ЗначениеЗаполнено(НаименованиеШаблона) Тогда 
		Возврат ПустаяСсылка();
	КонецЕсли;	

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НаименованиеШаблонаТочноеПопадание"	, СокрЛ(НаименованиеШаблона));		
	Запрос.УстановитьПараметр("НаименованиеШаблона"					, СокрЛ(НаименованиеШаблона) + "%");
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВложенныйЗапрос.Ссылка КАК ШаблонСообщения,
	|	ВложенныйЗапрос.Ссылка.Родитель КАК Родитель
	|ИЗ
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|		ШаблоныСообщений.Ссылка КАК Ссылка,
	|		1 КАК Приоритет
	|	ИЗ
	|		Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|	ГДЕ
	|		ШаблоныСообщений.Наименование ПОДОБНО &НаименованиеШаблонаТочноеПопадание
	|		И ШаблоныСообщений.ПометкаУдаления = ЛОЖЬ
	|	
	|	ОБЪЕДИНИТЬ
	|	
	|	ВЫБРАТЬ ПЕРВЫЕ 1
	|		ШаблоныСообщений.Ссылка,
	|		2
	|	ИЗ
	|		Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|	ГДЕ
	|		ШаблоныСообщений.Наименование ПОДОБНО &НаименованиеШаблона
	|		И ШаблоныСообщений.ПометкаУдаления = ЛОЖЬ
	|	
	|	УПОРЯДОЧИТЬ ПО
	|		Приоритет) КАК ВложенныйЗапрос
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВложенныйЗапрос.Приоритет";
	
	ВыборкаШаблона = Запрос.Выполнить().Выбрать();
	Если ВыборкаШаблона.Следующий() Тогда
		Если ЗначениеЗаполнено(СокрЛП(НаименованиеРодителя)) Тогда 
			ГруппаШаблонов = ИнициализироватьГруппуШаблонов(НаименованиеРодителя);
			Если ГруппаШаблонов <> ВыборкаШаблона.Родитель Тогда 
				ПоместитьШаблонВГруппу(ГруппаШаблонов, ВыборкаШаблона.ШаблонСообщения);
			КонецЕсли;	
		КонецЕсли;			
		Возврат ВыборкаШаблона.ШаблонСообщения;
	ИначеЕсли ГенерироватьШаблон Тогда 
		Возврат СоздатьШаблонСообщения(НаименованиеШаблона, НаименованиеРодителя);
	Иначе 	
		Возврат ПустаяСсылка();
	КонецЕсли;	
	
КонецФункции

// Функция - Инициализировать группу шаблонов
//
// Параметры:
//  НаименованиеРодителя - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьГруппуШаблонов(НаименованиеРодителя)
	
	Если НЕ ЗначениеЗаполнено(СокрЛП(НаименованиеРодителя)) Тогда 
		Возврат ПустаяСсылка();
	КонецЕсли;	
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НаименованиеГруппыШаблоновТочноеПопадание"	, СокрЛ(НаименованиеРодителя));		
	Запрос.УстановитьПараметр("НаименованиеГруппыШаблонов"					, СокрЛ(НаименованиеРодителя) + "%");
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВложенныйЗапрос.Ссылка КАК ГруппаШаблонов
	|ИЗ
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|		ШаблоныСообщений.Ссылка КАК Ссылка,
	|		1 КАК Приоритет
	|	ИЗ
	|		Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|	ГДЕ
	|		ШаблоныСообщений.Наименование ПОДОБНО &НаименованиеГруппыШаблоновТочноеПопадание
	|		И ШаблоныСообщений.ПометкаУдаления = ЛОЖЬ
	|		И ШаблоныСообщений.ЭтоГруппа = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ
	|	
	|	ВЫБРАТЬ ПЕРВЫЕ 1
	|		ШаблоныСообщений.Ссылка,
	|		2
	|	ИЗ
	|		Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|	ГДЕ
	|		ШаблоныСообщений.Наименование ПОДОБНО &НаименованиеГруппыШаблонов
	|		И ШаблоныСообщений.ПометкаУдаления = ЛОЖЬ
	|		И ШаблоныСообщений.ЭтоГруппа = ИСТИНА
	|	
	|	УПОРЯДОЧИТЬ ПО
	|		Приоритет) КАК ВложенныйЗапрос
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВложенныйЗапрос.Приоритет";
	
	ВыборкаГруппыШаблонов = Запрос.Выполнить().Выбрать();
	Если ВыборкаГруппыШаблонов.Следующий() Тогда
		Возврат ВыборкаГруппыШаблонов.ГруппаШаблонов;
	Иначе
		Попытка
			Группа_Объект 				= СоздатьГруппу();
			Группа_Объект.Наименование 	= СокрЛ(НаименованиеРодителя);
			Если НЕ ЗначениеЗаполнено(Группа_Объект.Код) Тогда 
				Группа_Объект.УстановитьНовыйКод();
			КонецЕсли;
			// Сохраняем группу
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Группа_Объект);
			Возврат Группа_Объект.Ссылка;
		Исключение
			Возврат ПустаяСсылка();
		КонецПопытки;
	КонецЕсли;
	
КонецФункции

// Процедура - Поместить шаблон в группу
//
// Параметры:
//  ГруппаСегментов		 - 	 - 
//  СегментНоменклатуры	 - 	 - 
//
Процедура ПоместитьШаблонВГруппу(ГруппаШаблонов, ШаблонСообщения)
	
	Попытка	
		Шаблон_Объект = ШаблонСообщения.ПолучитьОбъект();	
		Шаблон_Объект.Родитель = ГруппаШаблонов;
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Шаблон_Объект);
	Исключение
		
	КонецПопытки;
	
КонецПроцедуры

// Функция - Создать шаблон сообщения
//
// Параметры:
//  НаименованиеШаблона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьШаблонСообщения(НаименованиеШаблона, НаименованиеРодителя = "")

	Если СокрЛП(НаименованиеШаблона) = "Рекомендации после установки временной пломбы" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеУстановкиВременнойПломбы(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации после установки постоянной пломбы" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеУстановкиПостояннойПломбы(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации после гигиены" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеГигиены(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации после отбеливания" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеОтбеливания(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации после удаления зуба" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеУдаленияЗуба(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации после Синус-лифтинг" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеСинусЛифтинг(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендация после имплантации" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПослеИмплантации(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации по уходу за брекет системой" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПоУходуЗаБрекетСистемой(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Рекомендации по уходу за элайнерами" Тогда 
		Возврат ИнициализироватьШаблонСообщения_РекомендацииПоУходуЗаЭлайнерами(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Как ваше самочувствие после операции?" Тогда 
		Возврат ИнициализироватьШаблонСообщения_КакВашеСамочувствиеПослеОперации(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Создание предварительной записи" Тогда 
		Возврат ИнициализироватьШаблонСообщения_СозданиеПредварительнойЗаписи(НаименованиеШаблона, НаименованиеРодителя);
	ИначеЕсли СокрЛП(НаименованиеШаблона) = "Напоминание о записи за 2 часа" Тогда 
		Возврат ИнициализироватьШаблонСообщения_НапоминаниеОЗаписиЗа2Часа(НаименованиеШаблона, НаименованиеРодителя);
		
	Иначе 
		Возврат ПустаяСсылка();
	КонецЕсли;	
	
КонецФункции	

#Область ГЕНЕРАЦИЯ_ШАБЛОНОВ_РЕКОМЕНДАЦИЙ

// Функция - Инициализировать шаблон сообщения рекомендации после установки временной пломбы
//
// Параметры:
//  НаименованиеШаблона	 - 	 - 
//  НаименованиеРодителя - 	 - 
//  ВремяСобытия		 - 	 - 
//  ВернутьОбъект		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьШаблонСообщения_РекомендацииПослеУстановкиВременнойПломбы(НаименованиеШаблона, НаименованиеРодителя = "", ВремяСобытия = Неопределено, ВернутьОбъект = Ложь)

	ШаблонСообщения_Объект 								= СоздатьЭлемент();
	ШаблонСообщения_Объект.Наименование 				= СокрЛП(НаименованиеШаблона);
	ШаблонСообщения_Объект.ДатаСоздания 				= ТекущаяДатаСеанса();
	ШаблонСообщения_Объект.SMSВремяНачалаОтправки 		= ?(ЗначениеЗаполнено(ВремяСобытия), ВремяСобытия, Дата('0001.01.01 08:00:00'));
	ШаблонСообщения_Объект.SMSВремяОкончанияОтправки 	= Дата('0001.01.01 20:00:00');
	ШаблонСообщения_Объект.Автор 						= ПараметрыСеанса.ТекущийСотрудник;
	ШаблонСообщения_Объект.Родитель 					= ИнициализироватьГруппуШаблонов(НаименованиеРодителя);	
	
	ШаблонСообщения_Объект.СодержаниеМессенджерHTML 	= "%7B%D0%98%D0%BC%D1%8F%D0%9F%D0%B0%D1%86%D0%B8%D0%B5%D0%BD%D1%82%D0%B0%7D&nbsp;%7B%D0%9E%D1%82%D1%87%D0%B5%D1%81%D1%82%D0%B2%D0%BE%D0%9F%D0%B0%D1%86%D0%B8%D0%B5%D0%BD%D1%82%D0%B0%7D,%20%D0%92%D0%B0%D0%BC%20%D1%83%D1%81%D1%82%D0%B0%D0%BD%D0%BE%D0%B2%D0%BB%D0%B5%D0%BD%D0%B0%20%D0%B2%D1%80%D0%B5%D0%BC%D0%B5%D0%BD%D0%BD%D0%B0%D1%8F%20%D0%BF%D0%BB%D0%BE%D0%BC%D0%B1%D0%B0.%20%3Cdiv%3E%3Cbr%3E%3C/div%3E%D0%A1%D0%BB%D0%B5%D0%B4%D1%83%D0%B9%D1%82%D0%B5%20%D1%80%D0%B5%D0%BA%D0%BE%D0%BC%D0%B5%D0%BD%D0%B4%D0%B0%D1%86%D0%B8%D1%8F%D0%BC%20%D0%B4%D0%BE%D0%BA%D1%82%D0%BE%D1%80%D0%B0:%3Cdiv%3E%3Cbr%3E%3C/div%3E%3Cimg%20alt=%22%E2%9C%85%22%20class=%22emojioneemoji%22%20src=%22https://cdn.jsdelivr.net/emojione/assets/3.1/png/32/2705.png%22%3E&nbsp;%D0%92%D0%BE%D0%B7%D0%B4%D0%B5%D1%80%D0%B6%D0%B8%D1%82%D0%B5%D1%81%D1%8C%20%D0%BE%D1%82%20%D0%BF%D1%80%D0%B8%D0%B5%D0%BC%D0%B0%20%D0%BB%D1%8E%D0%B1%D0%BE%D0%B9%20%D0%BF%D0%B8%D1%89%D0%B8%20%D0%B2%20%D1%82%D0%B5%D1%87%D0%B5%D0%BD%D0%B8%D0%B5%2030%20%D0%BC%D0%B8%D0%BD%D1%83%D1%82";
	ШаблонСообщения_Объект.СодержаниеМессенджерHTML 	= РаскодироватьСтроку(ШаблонСообщения_Объект.СодержаниеМессенджерHTML, СпособКодированияСтроки.URLВКодировкеURL);
	
	Если ВернутьОбъект Тогда 
		ШаблонСообщения_Объект.СодержаниеМессенджер = ПолучитьТекстИзHTMLКода(ШаблонСообщения_Объект.СодержаниеМессенджерHTML);
		Возврат ШаблонСообщения_Объект;
	КонецЕсли;
	
	Попытка
		Если НЕ ЗначениеЗаполнено(ШаблонСообщения_Объект.Код) Тогда 
			ШаблонСообщения_Объект.УстановитьНовыйКод();
		КонецЕсли;
		// Сохраняем шаблон
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ШаблонСообщения_Объект);			
		Возврат ШаблонСообщения_Объект.Ссылка;
	Исключение
		МетаданныеСправочника 									= Метаданные.Справочники.ШаблоныСообщений;		
		ШаблонКомментария = НСтр("ru = 'Не удалось инициализировать шаблон сообщения ""%1""
		|по причине: %2'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, НаименованиеШаблона
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Предупреждение,
		МетаданныеСправочника,,
		Комментарий);
		
		Возврат ПустаяСсылка();
	КонецПопытки;
	
КонецФункции

// Функция - Инициализировать шаблон сообщения рекомендации после установки постоянной пломбы
//
// Параметры:
//  НаименованиеШаблона	 - 	 - 
//  НаименованиеРодителя - 	 - 
//  ВремяСобытия		 - 	 - 
//  ВернутьОбъект		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьШаблонСообщения_РекомендацииПослеУстановкиПостояннойПломбы(НаименованиеШаблона, НаименованиеРодителя = "", ВремяСобытия = Неопределено, ВернутьОбъект = Ложь)

	ШаблонСообщения_Объект 								= СоздатьЭлемент();
	ШаблонСообщения_Объект.Наименование 				= СокрЛП(НаименованиеШаблона);
	ШаблонСообщения_Объект.ДатаСоздания 				= ТекущаяДатаСеанса();
	ШаблонСообщения_Объект.SMSВремяНачалаОтправки 		= ?(ЗначениеЗаполнено(ВремяСобытия), ВремяСобытия, Дата('0001.01.01 08:00:00'));
	ШаблонСообщения_Объект.SMSВремяОкончанияОтправки 	= Дата('0001.01.01 20:00:00');
