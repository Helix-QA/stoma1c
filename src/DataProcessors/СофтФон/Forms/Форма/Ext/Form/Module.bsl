&НаКлиенте
Функция ПолучитьИнформациюЗвонка(ИдЗвонка)
	
	ИнфоЗвонка = СофтФон.GetCallInfo(ИдЗвонка);
	Счетчик = 0;
	Структура = Новый Структура("НомерТелефона, Состояние, Входящий, Завершен");
	Для Каждого СтрокаТЧ из ИнфоЗвонка Цикл
		Если Счетчик = 0 Тогда
			Структура.Вставить("НомерТелефона", СтрокаТЧ);
		ИначеЕсли Счетчик = 1 Тогда
			Структура.Вставить("Состояние", СтрокаТЧ);	
		ИначеЕсли Счетчик = 2 Тогда
			Структура.Вставить("Входящий", ?(СтрокаТЧ = "True", Истина, Ложь));	
		ИначеЕсли Счетчик = 3 Тогда
			Структура.Вставить("Завершен", ?(СтрокаТЧ = "True", Истина, Ложь));						
		ИначеЕсли Счетчик = 4 Тогда
			Структура.Вставить("ИдЗвонка", СтрокаТЧ);						
		КонецЕсли;
		Счетчик = Счетчик + 1;
	КонецЦикла; 	
	ИнфоКлиента = ВернутьАбонемента(Структура.НомерТелефона);
	Структура.Вставить("ИнфоКлиента", ИнфоКлиента);		
	
	Возврат Структура;	
	
КонецФункции

