// Функция, отправляет сообщение через API VK и возвращает структуру с параметрами результата.
//
Функция ОтправитьСообщениеКлиентуViber(ТекстСообщения, Клиент, ВнешняяСистема, НомерТелефона = Неопределено, ИдКанала = "")
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВыполненоУспешно", Ложь);
	СтруктураВозврата.Вставить("ОписаниеОшибки"  , "");
	СтруктураВозврата.Вставить("ИдСообщения"     , "");
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы)
		ИЛИ ТипЗнч(ПараметрыВнешнейСистемы) <> Тип("Структура")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("ApiToken")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("ИдОператора")
		ИЛИ Не ПараметрыВнешнейСистемы.Свойство("UrlApi") Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не заполнены параметры внешней системы."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Клиент) Тогда		
		ПараметрыКлиента = ПолучитьПараметрыОбъектаИдентификации(Клиент, ВнешняяСистема);
	Иначе
		ПараметрыКлиента = Неопределено;
	КонецЕсли;
	
	Если ПараметрыКлиента = Неопределено Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не удалось отправить сообщение. Не найден контакт мессенджера."; 	
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	РезультатОперации = Viber_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы);
	
	// Если сообщение отправлено.
	Если РезультатОперации.ВыполненоУспешно Тогда
		
		СтруктураВозврата.ВыполненоУспешно = Истина;
		СтруктураВозврата.ИдСообщения      = РезультатОперации.ИдСообщения;
		
		// Добавляем отправленное сообщение в регистр.
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
			ПараметрыКлиента.ИдКлиента,
			РезультатОперации.ИдСообщения,,,
			ТекстСообщения,
			Истина,
			Перечисления.Мессенджеры.viber,
			Ложь,
			ТекущаяДатаСеанса(),
			ВнешняяСистема
		);
		
		// Оповещаем сотрудников о новом отправленном сообщении.
		ОповеститьСотрудниковОНовомСообщении(РезультатОперации.ИдСообщения,, ПараметрыКлиента.ИдКлиента,, ВнешняяСистема);		
	
	ИначеЕсли РезультатОперации.Свойство("ОписаниеОшибки") Тогда // Если есть расшифровка ошибки, то вернем ее
		СтруктураВозврата.ОписаниеОшибки = РезультатОперации.ОписаниеОшибки;
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке.";
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область HttpService

// Функция - отправить сообщение ChatApi.
//
Функция ChatApi_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения = Неопределено, ОписаниеОшибки = "") Экспорт
	
	Попытка

		Если ЗначениеЗаполнено(Вложения) Тогда
			
			ИдКлиента = ПараметрыКлиента.ИдКлиента;
			ИдКанала  = ПараметрыВнешнейСистемы.ChannelId;
			ИмяМетода = "/instance" + ИдКанала + "/sendFile?token=" + ПараметрыВнешнейСистемы.ApiToken;			
			
			Если ТипЗнч(Вложения) = Тип("Массив") И Вложения.Количество() > 0 Тогда
				
				ПарамтерыЗапроса = Новый Структура();
				ПарамтерыЗапроса.Вставить("chatId"	, ИдКлиента);
				ПарамтерыЗапроса.Вставить("caption"	, ТекстСообщения);
				ПарамтерыЗапроса.Вставить("body"	, Вложения[0].ДанныеФайла);
				ПарамтерыЗапроса.Вставить("filename", Вложения[0].ИмяФайла);
				
				РезультатЗапроса = ChatApi_ВыполнитьPOSTЗапрос(ИмяМетода, ПараметрыВнешнейСистемы, ПарамтерыЗапроса);
				
				Если РезультатЗапроса.Свойство("sent") И РезультатЗапроса.sent = Истина Тогда
					
					ИдСообщения = РезультатЗапроса.id;
					ИдСообщения = ?(ТипЗнч(ИдСообщения) = Тип("Число"), Формат(ИдСообщения, "ЧГ="), ИдСообщения);
					ИдСообщения = СокрЛП(ИдСообщения);
					
					РезультатОперации = Новый Структура;
					РезультатОперации.Вставить("ВыполненоУспешно"	, Истина);
					РезультатОперации.Вставить("ИдСообщения"		, ИдСообщения);
					РезультатОперации.Вставить("ИдКанала"			, ИдКанала);
					РезультатОперации.Вставить("Вложения"			, "*Отправлен файл: " + Вложения[0].ИмяФайла + "*");
					
				Иначе
					РезультатОперации = Новый Структура("ВыполненоУспешно", Ложь);
					ОписаниеОшибки	  = ?(РезультатЗапроса.Свойство("message") И ЗначениеЗаполнено(РезультатЗапроса.message), РезультатЗапроса.message, "");

				КонецЕсли;

			Иначе
				РезультатОперации = Новый Структура("ВыполненоУспешно", Ложь);
				ОписаниеОшибки	  = "Массив вложений не заполнен";
			КонецЕсли;	
			
		Иначе
			
			ИдКлиента = ПараметрыКлиента.ИдКлиента;
			ИдКанала  = ПараметрыВнешнейСистемы.ChannelId;
			ИмяМетода = "/instance" + ИдКанала + "/sendMessage?token=" + ПараметрыВнешнейСистемы.ApiToken;			
			
			ПарамтерыЗапроса = Новый Структура();
			ПарамтерыЗапроса.Вставить("chatId", ИдКлиента);
			ПарамтерыЗапроса.Вставить("body"  , ТекстСообщения);
			
			РезультатЗапроса = ChatApi_ВыполнитьPOSTЗапрос(ИмяМетода, ПараметрыВнешнейСистемы, ПарамтерыЗапроса);

			
			Если РезультатЗапроса.Свойство("sent") И РезультатЗапроса.sent = Истина Тогда
				
				ИдСообщения = РезультатЗапроса.id;
				ИдСообщения = ?(ТипЗнч(ИдСообщения) = Тип("Число"), Формат(ИдСообщения, "ЧГ="), ИдСообщения);
				ИдСообщения = СокрЛП(ИдСообщения);
				
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно", Истина);
				РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
				РезультатОперации.Вставить("ИдКанала"        , ИдКанала);
				
			Иначе
				РезультатОперации = Новый Структура("ВыполненоУспешно", Ложь);
				ОписаниеОшибки	  = ?(РезультатЗапроса.Свойство("message") И ЗначениеЗаполнено(РезультатЗапроса.message), РезультатЗапроса.message, "");
				
			КонецЕсли;
			
		КонецЕсли;	
		
	Исключение
		РезультатОперации = Новый Структура("ВыполненоУспешно", Ложь);
		ОписаниеОшибки    = "Возникла исключительная ошибка при отправке сообщения: " + ОписаниеОшибки();
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - выполнить POST запрос ChatApi.
//
Функция ChatApi_ВыполнитьPOSTЗапрос(ИмяМетода, ПараметрыВнешнейСистемы, ПарамтерыЗапроса)
	
	ТекстЗапроса = СобратьJson(ПарамтерыЗапроса);
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	
	HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, ЗащищенноеСоединение); 
	
	ЗаголовкиHTTP = Новый Соответствие;
	ЗаголовкиHTTP.Вставить("Authorization", ПараметрыВнешнейСистемы.ApiToken);		
	ЗаголовкиHTTP.Вставить("Content-Type" , "application/json");
	
	HTTPЗапрос = Новый HTTPЗапрос(ИмяМетода, ЗаголовкиHTTP);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);
	
	РезультатЗапроса = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	РезультатЗапроса = РазобратьJson(РезультатЗапроса);
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - Chat api выполнить GETЗапрос
//
// Параметры:
//  ИмяМетода	 - 	 - 
//  Параметры	 - 	 - 
//  ДопЗаголовки - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ChatApi_ВыполнитьGETЗапрос(ИмяМетода, Параметры = Неопределено, ДопЗаголовки = Неопределено)
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language", "ru");
	
	Если ДопЗаголовки <> Неопределено Тогда
		
		Для Каждого ЗаголовокЗначение ИЗ ДопЗаголовки Цикл		
			ЗаголовкиHTTP.Вставить(ЗаголовокЗначение.Ключ, ЗаголовокЗначение.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	HTTPСоединение = Новый HTTPСоединение("api.chat-api.com",,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
	Если Параметры <> Неопределено Тогда 
		ПараметрыЗапроса = "";
		Для Каждого ПараметрЗапроса Из Параметры Цикл
			ПараметрыЗапроса = ПараметрыЗапроса + ?(Не ЗначениеЗаполнено(ПараметрыЗапроса), "?", "&") + ПараметрЗапроса.Ключ + "=" + ПараметрЗапроса.Значение;			
		КонецЦикла;
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос(ИмяМетода + ПараметрыЗапроса, ЗаголовкиHTTP);
	
	РезультатЗапроса = HTTPСоединение.Получить(HTTPЗапрос);
	РезультатЗапроса = РазобратьJson(РезультатЗапроса);
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - отправить сообщение GreenApi.
//
Функция GreenApi_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения = Неопределено, ОписаниеОшибки = "") Экспорт
	
	Попытка
		
		Если СтрНайти(ПараметрыВнешнейСистемы.UrlApi, "chat-api") Тогда
			Возврат ChatApi_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения, ОписаниеОшибки);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Вложения) Тогда
			
			Если ТипЗнч(Вложения) = Тип("Массив") И Вложения.Количество() > 0 Тогда
				
				СсылкаНаФайл = ЗагрузитьФайлВХранилищеИПолучитьСсылку(Вложения[0]);
				
				Если Не ЗначениеЗаполнено(СсылкаНаФайл) Тогда
					
					ОписаниеОшибки = "При отправке файла произошла ошибка.";// + Символы.ПС + ОшибкаЗагрузкиФайла;
					
					РезультатОперации = Новый Структура;
					РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
					РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
					
					Возврат РезультатОперации;
					
				КонецЕсли;
				
				Сервер	= "api.green-api.com/waInstance" + ПараметрыВнешнейСистемы.ChannelId + "/SendFileByUrl/" + ПараметрыВнешнейСистемы.ApiToken;
				Таймаут	= 5;
				
				Соединение = Новый HTTPСоединение(Сервер,,,,, Таймаут, Новый ЗащищенноеСоединениеOpenSSL);
				
				Заголовки = Новый Соответствие;
				Заголовки.Вставить("Content-Type", "application/json");
				
				АдресРесурса = "";
				
				Запрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
				
				ПараметрыЗапроса = Новый Структура;
				ПараметрыЗапроса.Вставить("chatId"	, ПараметрыКлиента.ИдКлиента);
				ПараметрыЗапроса.Вставить("caption"	, ТекстСообщения);
				ПараметрыЗапроса.Вставить("urlFile"	, СсылкаНаФайл);
				ПараметрыЗапроса.Вставить("fileName", Вложения[0].ИмяФайла);
				
				ТелоЗапроса = КодироватьВJSON(ПараметрыЗапроса);
				
				Запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
				
				Ответ			 = Соединение.ОтправитьДляОбработки(Запрос);
				ТелоОтвета		 = Ответ.ПолучитьТелоКакСтроку();
				СтруктураОтвета	 = ДекодироватьИзJSON(ТелоОтвета);
				
				Если ТипЗнч(СтруктураОтвета) = Тип("Структура") Тогда
					
					Если СтруктураОтвета.Свойство("idMessage") Тогда
						
						РезультатОперации = Новый Структура;
						РезультатОперации.Вставить("ВыполненоУспешно"	, Истина);
						РезультатОперации.Вставить("ИдСообщения"		, СтруктураОтвета.idMessage);
						РезультатОперации.Вставить("ИдКанала"			, ПараметрыВнешнейСистемы.ChannelId);
						РезультатОперации.Вставить("Вложения"			, СсылкаНаФайл);
						
					Иначе
						
						ОписаниеОшибки = "Ошибка отправки сообщения.";
						
						Если СтруктураОтвета.Свойство("message") И ЗначениеЗаполнено(СтруктураОтвета.message) Тогда
							ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Текст ошибки: " + СтруктураОтвета.message;
						КонецЕсли;
						
						ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Ответ сервера: " + ТелоОтвета;
						
						РезультатОперации = Новый Структура;
						РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
						РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
						
					КонецЕсли;
					
				Иначе
					
					ОписаниеОшибки = "Не удалось отправить сообщение." + Символы.ПС + "Ответ сервера: " + ТелоОтвета;
					
					РезультатОперации = Новый Структура;
					РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
					РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
					
				КонецЕсли;
				
			Иначе
				
				ОписаниеОшибки = "Ошибка отправки файла. Не удалось получить данные файла.";
				
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
				
			КонецЕсли;	
			
		Иначе
			
			Сервер	= "api.green-api.com/waInstance" + ПараметрыВнешнейСистемы.ChannelId + "/SendMessage/" + ПараметрыВнешнейСистемы.ApiToken;
			Таймаут	= 5;
			
			Соединение = Новый HTTPСоединение(Сервер,,,,, Таймаут, Новый ЗащищенноеСоединениеOpenSSL);
			
			Заголовки = Новый Соответствие;
			Заголовки.Вставить("Content-Type", "application/json");
			
			АдресРесурса = "";
			
			Запрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("chatId", ПараметрыКлиента.ИдКлиента);
			ПараметрыЗапроса.Вставить("message", ТекстСообщения);
			
			ТелоЗапроса = КодироватьВJSON(ПараметрыЗапроса);
			
			Запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
			
			Ответ			 = Соединение.ОтправитьДляОбработки(Запрос);
			ТелоОтвета		 = Ответ.ПолучитьТелоКакСтроку();
			СтруктураОтвета	 = ДекодироватьИзJSON(ТелоОтвета);
			
			Если ТипЗнч(СтруктураОтвета) = Тип("Структура") Тогда
				
				Если СтруктураОтвета.Свойство("idMessage") Тогда
					
					РезультатОперации = Новый Структура;
					РезультатОперации.Вставить("ВыполненоУспешно", Истина);
					РезультатОперации.Вставить("ИдСообщения"     , СтруктураОтвета.idMessage);
					РезультатОперации.Вставить("ИдКанала"        , ПараметрыВнешнейСистемы.ChannelId);
					
				Иначе
					
					ОписаниеОшибки = "Ошибка отправки сообщения.";
					
					Если СтруктураОтвета.Свойство("message") И ЗначениеЗаполнено(СтруктураОтвета.message) Тогда
						ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Текст ошибки: " + СтруктураОтвета.message;
					КонецЕсли;
					
					ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Ответ сервера: " + ТелоОтвета;
					
					РезультатОперации = Новый Структура;
					РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
					РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
					
				КонецЕсли;
				
			Иначе
				
				ОписаниеОшибки = "Не удалось отправить сообщение." + Символы.ПС + "Ответ сервера: " + ТелоОтвета;
				
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
				
			КонецЕсли;
			
		КонецЕсли;	
		
	Исключение
		
		ОписаниеОшибки = "Ошибка отправки. Текст ошибки: " + ОписаниеОшибки();
		
		РезультатОперации = Новый Структура;
		РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
		РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
		
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция, создает подписку на webhook GreenApi.
