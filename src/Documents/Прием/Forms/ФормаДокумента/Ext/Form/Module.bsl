// Функция, проверяет статусы номенклатуры.
//
Функция ПередЗаписьюПроверкаСтатусовНоменклатуры()
	
	Для Каждого СтрокаЗапас Из Объект.Запасы Цикл
		
		Номенклатура = СтрокаЗапас.Номенклатура;
		
		// Проверка статуса номенклатуры. 
		ВПродаже = ПолучитьСтатусНоменклатуры(Номенклатура, Объект.СтруктурнаяЕдиница, Объект.Дата);
		
		Если Не ВПродаже Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Номенклатура ""%1"" снята с продаж!';en='Nomenclature ""%1"" filmed with of sales!'"), СокрЛП(Номенклатура)));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Смена даты документа невозможна, так как в документе присутствует номенклатура, снятая с продаж!';en='Change dates of the document is not possible since how the document contains a nomenclature taken from of sales!'"));
			Возврат Ложь;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Для Каждого СтрокаЛечение Из Объект.Лечение Цикл
		
		Номенклатура = СтрокаЛечение.Номенклатура;
		
		// Проверка статуса номенклатуры. 
		ВПродаже = ПолучитьСтатусНоменклатуры(Номенклатура, Объект.СтруктурнаяЕдиница, Объект.Дата);
		
		Если Не ВПродаже Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Номенклатура ""%1"" снята с продаж!';en='Nomenclature ""%1"" filmed with of sales!'"), СокрЛП(Номенклатура)));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Смена даты документа невозможна, так как в документе присутствует номенклатура, снятая с продаж!';en='Change dates of the document is not possible since how the document contains a nomenclature taken from of sales!'"));
			Возврат Ложь;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат Истина;
	
