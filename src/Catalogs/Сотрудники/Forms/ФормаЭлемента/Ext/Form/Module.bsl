		КонецЦикла;
		
	Иначе 
		
		МассивВыбранныхЖурналовПриемов = Новый Массив;
		
		Для Каждого СтрокаТЧ Из ДоступныеЖурналыПриемов Цикл 
			МассивВыбранныхЖурналовПриемов.Добавить(СтрокаТЧ.СтруктурнаяЕдиница);
		КонецЦикла;
		
		Для Каждого СтрокаМ Из МассивВыбранныхЖурналовПриемов Цикл 			
			
			Если МассивВыбранныхСтруктурныхЕдиниц.Найти(СтрокаМ) <> Неопределено Тогда
				МассивНайтденыхСтрок = ДоступныеЖурналыПриемов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтрокаМ));
				
				Если МассивНайтденыхСтрок.Количество() > 0 Тогда
					ДоступныеЖурналыПриемов.Удалить(ДоступныеЖурналыПриемов.Индекс(МассивНайтденыхСтрок[0]));	
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры 

