// Функция возвращает макет слип чека по наименованию макета
//
Функция ПолучитьПречекКассира(Знач СписокДокументов = Неопределено, Параметры) Экспорт
	
	
	ЭтоУкраина = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки().Код = "804";
	Ширина 	   = ПолучитьШиринуПречека(Параметры.ИспользоватьФР, Параметры.ШиринаЧекаФР);
	ТабДок     = ?(Параметры.ИспользоватьФР, Новый ТекстовыйДокумент, Новый ТабличныйДокумент);
	Макет      = ПолучитьМакетПречека(Параметры.ИспользоватьФР, ЭтоУкраина);
	
	Клиент = ?(СписокДокументов = Неопределено Или ТипЗнч(СписокДокументов[0]) = Тип("ДокументСсылка.ВводНачальныхОстатков"), Параметры.Клиент, СписокДокументов[0].Контрагент);
	
	ОблЗаголовка     = Макет.ПолучитьОбласть("Заголовок" + Ширина);
	ОблДата          = Макет.ПолучитьОбласть("ИнформацияПоЧеку" + Ширина);
	ОблРазделение    = Макет.ПолучитьОбласть("Разделение" + Ширина);
	НомерЧека        = Макет.ПолучитьОбласть("НомерЧека" + Ширина);
	ОблСтрЕд         = Макет.ПолучитьОбласть("ИнформацияПоСтруктрнойЕдинице" + Ширина);
	ОблТовара        = Макет.ПолучитьОбласть("ИнформацияОТоваре" + Ширина);
	ОблСумма         = Макет.ПолучитьОбласть("ИнформацияПоСумме" + Ширина);
	ОблСкидка        = Макет.ПолучитьОбласть("ИнформацияПоСкидке" + Ширина);
	ОбщийИтог        = Макет.ПолучитьОбласть("ИнформацияОбщийИтог" + Ширина);
	ОблПодвал        = Макет.ПолучитьОбласть("Подвал" + Ширина);
	ОбластьВидыОплат = Макет.ПолучитьОбласть("ВидОплаты" + Ширина);
	ОблЛицевойСчет 	 = Макет.ПолучитьОбласть("ЛицевойСчет" + Ширина);
	ОблШапкаЛС   	 = Макет.ПолучитьОбласть("ШапкаЛицевогоСчета" + Ширина);
	ОблКомментарий	 = Макет.ПолучитьОбласть("Комментарий" + Ширина);
	ОблСотрудник	 = Макет.ПолучитьОбласть("ИнформацияПоМастеру" + Ширина);
	
	Попытка
		ОблСтол		= Макет.ПолучитьОбласть("ИнформацияПоСтолу" + Ширина);
	Исключение
		ОблСтол		= Неопределено;
	КонецПопытки;
	
	Если Не Параметры.ИспользоватьФР И Параметры.Свойство("ЛоготипОрганизации") И ЗначениеЗаполнено(Параметры.ЛоготипОрганизации) Тогда
		ВывестиОбластьЛоготипа(ТабДок, Макет, Параметры);
	КонецЕсли;
	
	мОбщийИтог     = 0;
	мОплаченоРанее = 0;
	ТабДок.Вывести(ОблЗаголовка);
	
	СтруктурнаяЕдиница = Неопределено;
	
	Если Параметры.Свойство("ТаблицаШапкаЧека") Тогда
		Для Каждого СтрокаШапки Из Параметры.ТаблицаШапкаЧека Цикл
			Если ЗначениеЗаполнено(СокрЛП(СтрокаШапки)) Тогда
				ОблЗаголовка.Параметры.ТекстЗаголовка = СокрЛП(СтрокаШапки);
				ТабДок.Вывести(ОблЗаголовка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ОблДата.Параметры.Дата  = ТекущаяДатаСеанса();
	ОблДата.Параметры.Время = Формат(ТекущаяДатаСеанса(),"ДЛФ=T");
	ТабДок.Вывести(ОблДата);
	
	Если НЕ ОбщегоНазначенияПовтИсп.ЭтоСеансРегламентногоЗадания() И ЗначениеЗаполнено(ПараметрыСеанса.ТекущийПользователь) Тогда
		ОблДопИнформации = Макет.ПолучитьОбласть("ДопИнформация" + Ширина);
		ОблДопИнформации.Параметры.ТекстДопИнформации = ПараметрыСеанса.ТекущийПользователь;
		ТабДок.Вывести(ОблДопИнформации);
	КонецЕсли;
	
	ТабДок.Вывести(ОблРазделение);
		
	Если СписокДокументов = Неопределено Тогда
		
		СтруктурнаяЕдиница = Параметры.СтруктурнаяЕдиница;
		
		Если Параметры.Свойство("ВыводитьСтруктурнуюЕдиницу")
			И Параметры.ВыводитьСтруктурнуюЕдиницу = Истина Тогда
			
			ОблСтрЕд.Параметры.СтруктурнаяЕдиница = Параметры.СтруктурнаяЕдиница;
			ТабДок.Вывести(ОблСтрЕд);
			
		КонецЕсли;    		
						
		Для Каждого СтрокаТЧ из Параметры.МассивПараметровТовары Цикл
			ОблТовара.Параметры.Товар = СокрЛП(СтрокаТЧ.Наименование);			
			ТабДок.Вывести(ОблТовара);		
			ОблСумма.Параметры.ТекстСуммы = Строка(СтрокаТЧ.Количество) + " * " + Формат(СтрокаТЧ.СтоимостьСоСкидкой/СтрокаТЧ.Количество, "ЧЦ=12; ЧДЦ=2; ЧН=0,00; ЧГ=0") + " = " + Формат(СтрокаТЧ.СтоимостьСоСкидкой, "ЧЦ=15; ЧДЦ=2; ЧН=0,00; ЧГ=0");
			
			ТабДок.Вывести(ОблСумма);
			мОбщийИтог = мОбщийИтог + СтрокаТЧ.СтоимостьСоСкидкой;
		КонецЦикла;
		
	Иначе
		
		// Сортировка документов по дате.
		ТаблицаДокументов = Новый ТаблицаЗначений;
		ТаблицаДокументов.Колонки.Добавить("Дата");
		ТаблицаДокументов.Колонки.Добавить("Документ");
		
		Для Каждого Элемент Из СписокДокументов Цикл
			
			НоваяСтрока = ТаблицаДокументов.Добавить();
			НоваяСтрока.Дата 	 = Элемент.Дата;
			НоваяСтрока.Документ = Элемент.Ссылка;
			
		КонецЦикла;
		
		ТаблицаДокументов.Сортировать("Дата Возр");
		
		МассивДокументов = ТаблицаДокументов.ВыгрузитьКолонку("Документ");
		//
		
		Для Каждого Документ Из МассивДокументов Цикл
			
			НомерЧека.Параметры.НомерЧека = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Документ.Номер, Неопределено);
			НомерЧека.Параметры.Дата = Документ.Дата;
			
			ТабДок.Вывести(НомерЧека);
			
			СтруктурнаяЕдиница = Документ.СтруктурнаяЕдиница;
			
			Если Параметры.Свойство("ВыводитьСтруктурнуюЕдиницу")
				И Параметры.ВыводитьСтруктурнуюЕдиницу = Истина Тогда
				
				ОблСтрЕд.Параметры.СтруктурнаяЕдиница = Документ.СтруктурнаяЕдиница;
				ТабДок.Вывести(ОблСтрЕд);
				
			КонецЕсли;     	
			
			// Если Параметры.Свойство("ИспользоватьСтолы") И Параметры.ИспользоватьСтолы И ОблСтол <> Неопределено И ТипЗнч(Документ) = Тип("ДокументСсылка.Реализация") Тогда
			//	
			//	ОблСтол.Параметры.Стол = "Стол: " + ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Документ, "Стол");
			//	ТабДок.Вывести(ОблСтол);
			//	
			// КонецЕсли; 
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	РеализацияЗапасы.Номенклатура КАК Номенклатура,
			|	РеализацияЗапасы.Номенклатура.Наименование КАК Наименование,
			|	РеализацияЗапасы.Номенклатура.НаименованиеПолное КАК НаименованиеПолное,
			|	РеализацияЗапасы.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
			|	РеализацияЗапасы.КоличествоУпаковок КАК Количество,
			|	РеализацияЗапасы.Цена КАК Цена,
			|	РеализацияЗапасы.Сумма КАК Сумма,
			|	РеализацияЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
			|	РеализацияЗапасы.СуммаАвтоматическойСкидкиНаценки КАК СуммаАвтоматическойСкидкиНаценки,
			|	РеализацияЗапасы.СтавкаНДС.Ставка КАК СтавкаНДС,
			|	РеализацияЗапасы.Сотрудник КАК Сотрудник,
			|	РеализацияЗапасы.Партия КАК Партия,
			|	РеализацияЗапасы.Номенклатура.Подразделение КАК Подразделение,
			|	РеализацияЗапасы.Всего КАК Всего
			|ИЗ
			|	Документ.Реализация.Запасы КАК РеализацияЗапасы
			|ГДЕ
			|	РеализацияЗапасы.Ссылка = &Ссылка
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	""Взнос на лиц. счет: "" + ПоступлениеДенежныхСредств.Контрагент.Наименование,
			|	"""",
			|	"""",
			|	NULL,
			|	1,
			|	ПоступлениеДенежныхСредств.СуммаДокумента,
			|	ПоступлениеДенежныхСредств.СуммаДокумента,
			|	0,
			|	0,
			|	NULL,
			|	ПоступлениеДенежныхСредств.Сотрудник,
			|	ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка),
			|	"""",
			|	ПоступлениеДенежныхСредств.СуммаДокумента
			|ИЗ
			|	Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
			|ГДЕ
			|	ПоступлениеДенежныхСредств.Ссылка = &Ссылка
			|
			|УПОРЯДОЧИТЬ ПО
			|	Подразделение
			|ИТОГИ ПО
			|	Подразделение");
			
			Запрос.УстановитьПараметр("Ссылка", Документ);
			
			ВыборкаИтоги = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Итог = 0;
			
			Пока ВыборкаИтоги.Следующий() Цикл
				
				Если ЗначениеЗаполнено(ВыборкаИтоги.Подразделение) Тогда
					ОблПодвал.Параметры.ТекстПодвала = ВыборкаИтоги.Подразделение;
					ТабДок.Вывести(ОблПодвал);
					ОблПодвал.Параметры.ТекстПодвала = "";
				КонецЕсли;			
				
				Выборка = ВыборкаИтоги.Выбрать();				
				Пока Выборка.Следующий() Цикл
					
					Если НЕ ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
						Продолжить;
					КонецЕсли;
					
					
					ФорматЧисла = "ЧЦ=15; ЧДЦ=2; ЧН=0,00; ЧГ=0";
					
					НаименованиеНоменклатуры = ?(ЗначениеЗаполнено(Выборка.НаименованиеПолное), СокрЛП(Выборка.НаименованиеПолное), СокрЛП(Выборка.Наименование));
					
					ОблТовара.Параметры.Товар = НаименованиеНоменклатуры + ?(ЗначениеЗаполнено(Выборка.Партия), " ("+Выборка.Партия+")", "");
					ТабДок.Вывести(ОблТовара);
					
					Если ЗначениеЗаполнено(Выборка.Сотрудник)
						И (Выборка.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга) Тогда
						
						ПредставлениеСотрудника = " (" + Справочники.Сотрудники.ПредставлениеФИОСотрудника(Выборка.Сотрудник) + ")";
						
						ОблСотрудник.Параметры.Сотрудник = ПредставлениеСотрудника;
						ТабДок.Вывести(ОблСотрудник);
					
					КонецЕсли;
					
					ОблСумма.Параметры.ТекстСуммы = Строка(Выборка.Количество) + " * " + Формат(Выборка.Цена, ФорматЧисла) + " = " + Формат(Выборка.Количество * Выборка.Цена, ФорматЧисла);
					
					ТабДок.Вывести(ОблСумма);
					СкидкаНаценка = Выборка.Сумма - Выборка.Цена*Выборка.Количество;
					
					КоэфСкидки = Выборка.Цена*Выборка.Количество / 100;
					КоэфСкидки = ?(КоэфСкидки = 0, 1, КоэфСкидки);
					ПроцентСкидки = Окр(СкидкаНаценка * -1/КоэфСкидки , 2, РежимОкругления.Окр15как20);
					
					Если СкидкаНаценка < 0 Тогда
						ОблСкидка.Параметры.ТекстСкидки = ПолучитьСловоСУчетомЯзыка("Скидка", ЭтоУкраина) + " (" + ПроцентСкидки + "%)" + ": " + Формат(СкидкаНаценка, ФорматЧисла);
						ТабДок.Вывести(ОблСкидка);
					ИначеЕсли СкидкаНаценка > 0 Тогда
						ОблСкидка.Параметры.ТекстСкидки = ПолучитьСловоСУчетомЯзыка("Наценка", ЭтоУкраина) + " (" + ПроцентСкидки + "%)" + ": " + Формат(-СкидкаНаценка, ФорматЧисла);
						ТабДок.Вывести(ОблСкидка);
					КонецЕсли;
					
					Если Не Выборка.СтавкаНДС = Null и Выборка.СтавкаНДС > 0 Тогда
						ОблСумма.Параметры.ТекстСуммы = ПолучитьСловоСУчетомЯзыка("НДС", ЭтоУкраина) + ": " + Выборка.СтавкаНДС + "%" + Символы.ПС;
						ТабДок.Вывести(ОблСумма);
					КонецЕсли;
					
					Итог = Итог + Выборка.Всего;
					мОбщийИтог = мОбщийИтог + Выборка.Всего;
					
				КонецЦикла;
				
			КонецЦикла;
			
			// Если Не ТипЗнч(Документ) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
			//	мОплаченоРанее = мОплаченоРанее + РегистрыНакопления.Оплаты.ПолучитьСуммуОплатыПоДокументу(Документ);
			// КонецЕсли;
			
			ВывестиИтог(ТабДок, Макет, Ширина, Итог, ОблРазделение);
			
		КонецЦикла;
		
	КонецЕсли;
	
	ОбщийИтог.Параметры.Всего = Формат(мОбщийИтог, "ЧЦ=15; ЧДЦ=2; ЧН=0,00; ЧГ=0");

	ТабДок.Вывести(ОбщийИтог);
	ТабДок.Вывести(ОблРазделение);	

	Если Параметры.Свойство("СтруктураОплаты") Тогда
		Если Параметры.СтруктураОплаты = Неопределено Тогда
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СУММА(ПоступлениеДенежныхСредствРасшифровкаПлатежа.Сумма) КАК Сумма,
			|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств КАК Вид
			|ИЗ
			|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
			|ГДЕ
			|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Основание В(&Реализация)
			|	И ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
			|
			|СГРУППИРОВАТЬ ПО
			|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	СУММА(СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма),
			|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств
			|ИЗ
			|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
			|ГДЕ
			|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
			|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Основание В(&Реализация)
			|
			|СГРУППИРОВАТЬ ПО
			|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств");
			
			Запрос.УстановитьПараметр("Реализация", СписокДокументов);
			
			ТипыОплат = Запрос.Выполнить().Выгрузить();
			
			Для Каждого СтрокаТЧ из ТипыОплат Цикл
				ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, СтрокаТЧ.Вид, СтрокаТЧ.Сумма, ЭтоУкраина);
			КонецЦикла;
			Если ТипыОплат.Количество() > 0 Тогда
				ТабДок.Вывести(ОблРазделение);
			КонецЕсли;
			
		Иначе
			
			мВнесено     = 0;			
			Для Каждого СтрокаТЧ из Параметры.СтруктураОплаты Цикл
				
				ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, СтрокаТЧ.ТипДенежныхСредств, СтрокаТЧ.Внесено, ЭтоУкраина);
				
				мВнесено = мВнесено + СтрокаТЧ.Внесено;
				Если СтрокаТЧ.Свойство("ЧекПробит") И СтрокаТЧ.ЧекПробит Тогда
					мОплаченоРанее = мОплаченоРанее - мВнесено; 
				КонецЕсли;
				
			КонецЦикла;
			
			Если мОплаченоРанее > 0 Тогда
				ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, "Оплачено ранее: ", мОплаченоРанее, ЭтоУкраина);
			КонецЕсли;
			мОбщийИтог = мОбщийИтог - мОплаченоРанее; 
			Если мОбщийИтог < мВнесено Тогда
				ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, "Сдача: ", (мВнесено - мОбщийИтог), ЭтоУкраина);
			ИначеЕсли мОбщийИтог > мВнесено Тогда
				ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, "Долг: ", (мОбщийИтог - мВнесено), ЭтоУкраина);
			КонецЕсли;
			
			ТабДок.Вывести(ОблРазделение);
			
		КонецЕсли;
		
		Если Параметры.Свойство("ВыводитьОстаткиНаЛицевыхСчетах")
			И Параметры.ВыводитьОстаткиНаЛицевыхСчетах Тогда 
			ВывестиЛицевыеСчетаВПречек(Клиент, СтруктурнаяЕдиница, ТабДок, ОблЛицевойСчет, ОблШапкаЛС, ОблРазделение);
		КонецЕсли;
		
		ВывестиОбластьКлиента(ТабДок, Макет, Ширина, Клиент, ОблПодвал);
		
		Если Параметры.Свойство("ВыводитьКомментарий")
			И Параметры.ВыводитьКомментарий = Истина Тогда
			
			// ТабДок.Вывести(ОблРазделение);
			ОблКомментарий.Параметры.Комментарий = Документ.Комментарий;
			ТабДок.Вывести(ОблКомментарий);
			// ТабДок.Вывести(ОблРазделение);
			
		КонецЕсли;
		
		Для Каждого СтрокаПодвала Из Параметры.ТаблицаПодвалЧека Цикл
			ОблПодвал.Параметры.ТекстПодвала = СокрЛП(СтрокаПодвала);
			ТабДок.Вывести(ОблПодвал); 	
		КонецЦикла;
		
	Иначе		
		
		Для Каждого СтрокаТЧ из Параметры.МассивПараметровОплаты Цикл
			ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, СтрокаТЧ.ТипОплаты, СтрокаТЧ.Сумма, ЭтоУкраина);
		КонецЦикла;
		
		Если Параметры.Свойство("ВыводитьОстаткиНаЛицевыхСчетах")
			И Параметры.ВыводитьОстаткиНаЛицевыхСчетах Тогда
			ВывестиЛицевыеСчетаВПречек(Клиент, СтруктурнаяЕдиница, ТабДок, ОблЛицевойСчет, ОблШапкаЛС, ОблРазделение);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВернутьОтформатированныйТабличныйДокументИлиПречек(ТабДок, Параметры, Истина);	
		
КонецФункции      

// Процедуры выводить область видов оплаты.
//
Процедура ВывестиОбластьВидыОплат(ТабДок, ОбластьВидыОплат, ВидОплаты, СуммаОплаты, ЭтоУкраина)
	
	ОбластьВидыОплат.Параметры.ВидОплаты = ПолучитьСловоСУчетомЯзыка(ВидОплаты, ЭтоУкраина);
	ОбластьВидыОплат.Параметры.Сумма 	 = Формат(СуммаОплаты, "ЧЦ=15; ЧДЦ=2; ЧН=0,00; ЧГ=0");
	ТабДок.Вывести(ОбластьВидыОплат);
	
КонецПроцедуры

// Функция - получает слово с учетом языка.
//
Функция ПолучитьСловоСУчетомЯзыка(ВидОплаты, ЭтоУкраина = Неопределено) Экспорт
	
	Если ЭтоУкраина = Неопределено Тогда
		ЭтоУкраина = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки().Код = "804";
	КонецЕсли;
	
	Если ЭтоУкраина Тогда
		// Для україномовних хлопцев)
		Если ВидОплаты = "Отдел" Тогда
			Возврат "Відділ";
		ИначеЕсли ВидОплаты = "Кассир" Тогда
			Возврат "Касир";
		ИначеЕсли ВидОплаты = "Возврат оплаты: " Тогда
			Возврат "Повернення оплати: ";
		ИначеЕсли ВидОплаты = "Открытие чека возврата" Тогда
			Возврат "Відкриття чека повернення";
		ИначеЕсли ВидОплаты = "Открытие чека продажи" Тогда
			Возврат "Відкриття чека продажу";
		ИначеЕсли ВидОплаты = "Фискальный режим" Тогда
			Возврат "Фіскальний режим";
		ИначеЕсли ВидОплаты = "Нефискальный режим" Тогда
			Возврат "Нефіскальний режим";
		ИначеЕсли ВидОплаты = "смены" Тогда
			Возврат "зміни";
		ИначеЕсли ВидОплаты = "Скидка" Тогда
			Возврат "Знижка";
		ИначеЕсли ВидОплаты = "Наценка" Тогда
			Возврат "Націнка";
		ИначеЕсли ВидОплаты = "НДС" Тогда
			Возврат "ПДВ";
		ИначеЕсли ВидОплаты = "Оплачено ранее: " Тогда
			Возврат "Оплачено раніше: ";
		ИначеЕсли ВидОплаты = "Сдача: " Тогда
			Возврат "Решта: ";
		ИначеЕсли ВидОплаты = "Долг: " Тогда
			Возврат "Борг: ";
		ИначеЕсли ВидОплаты = "ИТОГО" Тогда
			Возврат "РАЗОМ";
		ИначеЕсли ВидОплаты = "Продажа №" Тогда
			Возврат "Продаж №";
		ИначеЕсли ВидОплаты = "(Пакет услуг)" Тогда
			Возврат "(Пакет послуг)";
		ИначеЕсли ВидОплаты = "(Членство)" Тогда
			Возврат "(Членство)";
		ИначеЕсли ВидОплаты = "неогр." Тогда
			Возврат "необм.";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.Наличные ИЛИ ВидОплаты = "Наличная оплата" Тогда
			Возврат "Готівка";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
			Возврат "Особовий рахунок";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.Безналичные ИЛИ ВидОплаты = "Безналичная оплата" Тогда
			Возврат "Безготівковий розрахунок";
		// ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.БонусныйСчет Тогда
		//	Возврат "Бонусний рахунок";
		// ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.КорпоративныйДоговор Тогда
		//	Возврат "Корпоративний договір";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта ИЛИ ВидОплаты = "Платежная карта" Тогда
			Возврат "Платіжна картка";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
			Возврат "Подарунковий сертифікат"; 
		ИначеЕсли ВидОплаты = "Взнос на лицевой счет" Тогда
			Возврат "Тренування";    
		ИначеЕсли ВидОплаты = "Оплата от:" Тогда
			Возврат "Тренування:";  
		ИначеЕсли ВидОплаты = "Возврат с лицевого счета" Тогда
			Возврат "Тренування:";  
		ИначеЕсли ВидОплаты = "Аванс от: " Тогда
			Возврат "Аванс від: ";  
		Иначе
			Возврат "";
		КонецЕсли;
		
	ИначеЕсли ПользователиСлужебныйПовтИсп.ЯзыкИнтерфейсаАнглийский() Тогда
		
		Если ВидОплаты = "Отдел" Тогда
			Возврат "Department";
		ИначеЕсли ВидОплаты = "Кассир" Тогда
			Возврат "Cashier";
		ИначеЕсли ВидОплаты = "Возврат оплаты: " Тогда
			Возврат "Payment refund: ";
		ИначеЕсли ВидОплаты = "Открытие чека возврата" Тогда
			Возврат "Opening of the refund receipt";
		ИначеЕсли ВидОплаты = "Открытие чека продажи" Тогда
			Возврат "Opening of the sale receipt";
		ИначеЕсли ВидОплаты = "Фискальный режим" Тогда
			Возврат "Fiscal mode";
		ИначеЕсли ВидОплаты = "Нефискальный режим" Тогда
			Возврат "Non-fiscal mode";
		ИначеЕсли ВидОплаты = "смены" Тогда
			Возврат "shift";
		ИначеЕсли ВидОплаты = "Скидка" Тогда
			Возврат "Discount";
		ИначеЕсли ВидОплаты = "Наценка" Тогда
			Возврат "Mark-up";
		ИначеЕсли ВидОплаты = "НДС" Тогда
			Возврат "VAT";
		ИначеЕсли ВидОплаты = "Оплачено ранее: " Тогда
			Возврат "Paid earlier: ";
		ИначеЕсли ВидОплаты = "Сдача: " Тогда
			Возврат "Change: ";
		ИначеЕсли ВидОплаты = "Долг: " Тогда
			Возврат "Debt: ";
		ИначеЕсли ВидОплаты = "ИТОГО" Тогда
			Возврат "TOTAL";
		ИначеЕсли ВидОплаты = "Продажа №" Тогда
			Возврат "Sale №";
		ИначеЕсли ВидОплаты = "(Пакет услуг)" Тогда
			Возврат "(Package of services)";
		ИначеЕсли ВидОплаты = "(Членство)" Тогда
			Возврат "(Membership)";
		ИначеЕсли ВидОплаты = "неогр." Тогда
			Возврат "unlim.";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.Наличные ИЛИ ВидОплаты = "Наличная оплата" Тогда
			Возврат "Cash funds";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
			Возврат "Personal account";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.Безналичные ИЛИ ВидОплаты = "Безналичная оплата" Тогда
			Возврат "Cashless funds";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.БонусныйСчет Тогда
			Возврат "Bonus account";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта ИЛИ ВидОплаты = "Платежная карта" Тогда
			Возврат "Payment card";
		ИначеЕсли ВидОплаты = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
			Возврат "Gift certificate"; 
		ИначеЕсли ВидОплаты = "Взнос на лицевой счет" Тогда
			Возврат "Personal account fee";    
		ИначеЕсли ВидОплаты = "Оплата от:" Тогда
			Возврат "Payment from:";  
		ИначеЕсли ВидОплаты = "Возврат с лицевого счета" Тогда
			Возврат "Personal account refund:";  
		ИначеЕсли ВидОплаты = "ФИО: " Тогда
			Возврат "Member: ";  
		ИначеЕсли ВидОплаты = "Аванс от: " Тогда
			Возврат "Advance payment from: ";  


		Иначе
			Возврат "";
		КонецЕсли;		
		
	Иначе
		Возврат "" + ВидОплаты;
	КонецЕсли;
	
КонецФункции

