		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	КонтрагентыСписок.Ссылка КАК Контрагент,
	ВЫБОР
		КОГДА КонтрагентыСписок.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА ДЕНЬГОДА(&amp;ТекущаяДата) &gt; ДЕНЬГОДА(КонтрагентыСписок.ДатаРожденияКлиента)
						ТОГДА РАЗНОСТЬДАТ(КонтрагентыСписок.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД)
					ИНАЧЕ (ВЫРАЗИТЬ(РАЗНОСТЬДАТ(КонтрагентыСписок.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД) КАК ЧИСЛО)) - 1
				КОНЕЦ
		ИНАЧЕ 0
	КОНЕЦ КАК Возраст,
	МЕСЯЦ(КонтрагентыСписок.ДатаРожденияКлиента) = МЕСЯЦ(&amp;ТекущаяДата)
		И ДЕНЬ(КонтрагентыСписок.ДатаРожденияКлиента) = ДЕНЬ(&amp;ТекущаяДата) КАК ДеньРожденияСегодня,
	КонтрагентыСписок.ДатаРожденияКлиента КАК ДатаРожденияКлиента,
	МЕСЯЦ(КонтрагентыСписок.ДатаРожденияКлиента) = МЕСЯЦ(&amp;ТекущаяДата)
		И НЕДЕЛЯ(КонтрагентыСписок.ДатаРожденияКлиента) = НЕДЕЛЯ(&amp;ТекущаяДата) КАК ДеньРожденияЭтаНеделя,
	МЕСЯЦ(КонтрагентыСписок.ДатаРожденияКлиента) = МЕСЯЦ(&amp;ТекущаяДата) КАК ДеньРожденияЭтотМесяц,
	КонтрагентыСписок.ДатаРегистрации КАК ДатаРегистрации
ПОМЕСТИТЬ ВТКонтрагенты
ИЗ
	Справочник.Контрагенты КАК КонтрагентыСписок
ГДЕ
	НЕ КонтрагентыСписок.ПометкаУдаления
	И НЕ КонтрагентыСписок.ЭтоГруппа
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	МеткиКлиентовСрезПоследних.Клиент КАК Пациент,
	МеткиКлиентовСрезПоследних.Метка КАК Метка
ПОМЕСТИТЬ ВТМетки
ИЗ
	РегистрСведений.МеткиКлиентов.СрезПоследних КАК МеткиКлиентовСрезПоследних
ГДЕ
	МеткиКлиентовСрезПоследних.Клиент ССЫЛКА Справочник.Контрагенты
	И НЕ МеткиКлиентовСрезПоследних.Метка.ПометкаУдаления
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус
ПОМЕСТИТЬ ВТСтатусы
ИЗ
	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(,) КАК СтатусыКонтрагентовСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	КонтрагентыСписок.Контрагент КАК Контрагент,
	КонтрагентыСписок.Возраст КАК Возраст,
	КонтрагентыСписок.ДеньРожденияЭтотМесяц КАК ДеньРожденияЭтотМесяц,
	КонтрагентыСписок.ДатаРегистрации КАК ДатаРегистрации,
	ПолисыМедицинскогоСтрахования.Ссылка КАК ПолисМедицинскогоСтрахования,
	МеткиПациентов.Метка КАК Метка,
	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус
ИЗ
	ВТКонтрагенты КАК КонтрагентыСписок
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПолисыМедицинскогоСтрахования КАК ПолисыМедицинскогоСтрахования
		ПО КонтрагентыСписок.Контрагент = ПолисыМедицинскогоСтрахования.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ ВТМетки КАК МеткиПациентов
		ПО КонтрагентыСписок.Контрагент = МеткиПациентов.Пациент
		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусы КАК СтатусыКонтрагентовСрезПоследних
		ПО КонтрагентыСписок.Контрагент = СтатусыКонтрагентовСрезПоследних.Контрагент</query>
	</dataSet>
