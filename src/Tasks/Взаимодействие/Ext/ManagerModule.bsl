	//КонецЕсли;	
	
КонецПроцедуры

// Функция - Инициализировать задачу сделки
//
// Параметры:
//  Сделка				 - 	 - 
//  ВидОсмотра			 - 	 - 
//  ПараметрыЗадачи		 - 	 - 
//  ВключитьБизнесЛогику - 	 - 
//  ВозвращатьОбъект	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьЗадачуСделки(Сделка
									, ВидОсмотра = Неопределено
									, ПараметрыЗадачи = Неопределено
									, ВключитьБизнесЛогику = Ложь
									, ВозвращатьОбъект = Ложь) Экспорт
									
	// Проверка переданных параметров									
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.Сделки") Тогда 
		ДанныеСделки = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Сделка, "СтруктурнаяЕдиница, Контрагент, Врач, Специализация, ПредыдущийПрием");
	ИначеЕсли ТипЗнч(Сделка) = Тип("СправочникОбъект.Сделки") ИЛИ ТипЗнч(Сделка) = Тип("Структура") Тогда	
		ДанныеСделки = Сделка;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;	
	
	Если ТипЗнч(ДанныеСделки) = Тип("Структура") Тогда
		Если НЕ ДанныеСделки.Свойство("СтруктурнаяЕдиница") Тогда 
			ДанныеСделки.Вставить("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		КонецЕсли;	
		Если НЕ ДанныеСделки.Свойство("Контрагент") Тогда 
			ДанныеСделки.Вставить("Контрагент", Неопределено);
		КонецЕсли;	
		Если НЕ ДанныеСделки.Свойство("Врач") Тогда 
			ДанныеСделки.Вставить("Врач", Неопределено);
		КонецЕсли;
		Если НЕ ДанныеСделки.Свойство("Специализация") Тогда 
			ДанныеСделки.Вставить("Специализация", Неопределено);
		КонецЕсли;		
		Если НЕ ДанныеСделки.Свойство("ПредыдущийПрием") Тогда 
			ДанныеСделки.Вставить("ПредыдущийПрием", Неопределено);
		КонецЕсли;			
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ДанныеСделки.Контрагент) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	// Формируем параметры заполнения	
	ДанныеЗаполненияЗадачи = ИнициализироватьСтруктуруДанныхЗаполнения();
	
	Если ЗначениеЗаполнено(ДанныеСделки.Врач) Тогда 
		СокращенноеНаименованиеВрача = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДанныеСделки.Врач, "НаименованиеСокращенное");
	Иначе 
		СокращенноеНаименованиеВрача = НСтр("ru='врачу';en='doctor'");
	КонецЕсли;	
	Если ЗначениеЗаполнено(ДанныеСделки.ПредыдущийПрием) Тогда 
		ДатаВремяПрошлогоПриема = Формат(ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДанныеСделки.ПредыдущийПрием, "ВремяНачалаПриема"), "ДФ='dd MMMM yyyy ''в'' HH:mm'");
	Иначе 
		ДатаВремяПрошлогоПриема = Дата(1,1,1);
	КонецЕсли;
	
	// Структурная единица
	СтруктурнаяЕдиница = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "СтруктурнаяЕдиница", Неопределено);	
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("СтруктурнаяЕдиница"        , СтруктурнаяЕдиница);
	Иначе 
	    ДанныеЗаполненияЗадачи.Вставить("СтруктурнаяЕдиница"        , ДанныеСделки.СтруктурнаяЕдиница);
	КонецЕсли;
	// Контрагент
	Контрагент = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "Контрагент", Неопределено);	
	Если ЗначениеЗаполнено(Контрагент) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("Контрагент"         		, Контрагент);
	Иначе 
	    ДанныеЗаполненияЗадачи.Вставить("Контрагент"                , ДанныеСделки.Контрагент);
	КонецЕсли;
	// Вид взаимодействия	
	ВидВзаимодействия = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "ВидВзаимодействия", Неопределено);
	Если ЗначениеЗаполнено(ВидВзаимодействия) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("ВидВзаимодействия"         , ВидВзаимодействия);
	Иначе 
		ДанныеЗаполненияЗадачи.Вставить("ВидВзаимодействия"         , Перечисления.ВидыВзаимодействия.ЗвонокИсходящий);
	КонецЕсли;	
	ДанныеЗаполненияЗадачи.Вставить("ВидВзаимодействияСправочник"	, Справочники.ВидыВзаимодействий.ВернутьВидВзаимодействия(ДанныеЗаполненияЗадачи.ВидВзаимодействия));
	// Исполнитель
	Исполнитель = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "Исполнитель", Неопределено);
	Если ЗначениеЗаполнено(Исполнитель) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("Исполнитель"               , Исполнитель);
	Иначе 
		ДанныеПациента = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ДанныеСделки.Контрагент, "Куратор, СотрудникРегистрации");
		Если ЗначениеЗаполнено(ДанныеПациента.Куратор) Тогда 
			ДанныеЗаполненияЗадачи.Вставить("Исполнитель"           , ДанныеПациента.Куратор);
		ИначеЕсли ЗначениеЗаполнено(ДанныеПациента.СотрудникРегистрации) Тогда 
			СотрудникРегистрацииСлужебный = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДанныеПациента.СотрудникРегистрации, "Служебный");
			Если СотрудникРегистрацииСлужебный = Ложь Тогда 
				ДанныеЗаполненияЗадачи.Вставить("Исполнитель"       , ДанныеПациента.СотрудникРегистрации);
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполненияЗадачи.Исполнитель) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("Исполнитель"               , ПараметрыСеанса.ТекущийСотрудник);
	КонецЕсли;
	// Назначенная дата
	ЗадачаНазначеннаяДата = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "ЗадачаНазначеннаяДата", Неопределено);	
	Если ЗначениеЗаполнено(ЗадачаНазначеннаяДата) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("ЗадачаНазначеннаяДата"     , ЗадачаНазначеннаяДата);
	Иначе 
		ДанныеЗаполненияЗадачи.Вставить("ЗадачаНазначеннаяДата"     , ТекущаяДатаСеанса());
	КонецЕсли;
	// Тема задачи
	ЗадачаТема = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "ЗадачаТема", Неопределено);	
	Если ЗначениеЗаполнено(ЗадачаТема) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     			, ЗадачаТема);
	Иначе
		Если ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр Тогда  
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     		, НСтр("ru='Записать пациента на профосмотр';en='Book a patient for a checkup'"));
		ИначеЕсли ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда	
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     		, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Записать на повторный приём к врачу %1';en='Book a patient for follow-up %1'"), ?(ЗначениеЗаполнено(СокрЛП(СокращенноеНаименованиеВрача)), СокрЛП(СокращенноеНаименованиеВрача), Строка(ДанныеСделки.Врач))));
		ИначеЕсли ВидОсмотра = Перечисления.ВидыОсмотров.Направление Тогда
			Если ЗначениеЗаполнено(ДанныеСделки.Врач) Тогда 
				ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     	, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Записать к %1';en='Write to %1'"), ?(ЗначениеЗаполнено(СокрЛП(СокращенноеНаименованиеВрача)), СокрЛП(СокращенноеНаименованиеВрача), Строка(ДанныеСделки.Врач))));			
			ИначеЕсли ЗначениеЗаполнено(ДанныеСделки.Специализация) Тогда 
				ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     	, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Записать к %1';en='Write to %1'"), Строка(ДанныеСделки.Специализация)));			
			Иначе 
				ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     	, НСтр("ru='Записать по направлению';en='Record by direction'"));			
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполненияЗадачи.ЗадачаТема) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"     			, НСтр("ru='Новая задача';en='New task'"));
	КонецЕсли;
	// Описание задачи
	ЗадачаОписание = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "ЗадачаОписание", Неопределено);	
	Если ЗначениеЗаполнено(ЗадачаОписание) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"     		, ЗадачаОписание);
	ИначеЕсли ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр Тогда  
		ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"     		, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Записать пациента на профосмотр к врачу %1';en='Register a patient for a medical examination %1'"), ?(ЗначениеЗаполнено(СокрЛП(СокращенноеНаименованиеВрача)), СокрЛП(СокращенноеНаименованиеВрача), Строка(ДанныеСделки.Врач))));
	ИначеЕсли ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда
		Если ЗначениеЗаполнено(ДанныеСделки.ПредыдущийПрием) Тогда
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"     	, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Прошлый приём %1';en='The patient must be booked for the next appointment. The last visit was %1'"), ДатаВремяПрошлогоПриема));
		Иначе 
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"     	, НСтр("ru='Продолжает лечение.';en='Continues treatment.'") + Символы.ПС + НСтр("ru='Необходимо записать пациента на следующий приём.';en='The patient must be booked for the next appointment.'"));
		КонецЕсли;
	ИначеЕсли ВидОсмотра = Перечисления.ВидыОсмотров.Направление Тогда
		НаправившийВрач = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "НаправившийВрач", Неопределено);
		Если ЗначениеЗаполнено(НаправившийВрач) Тогда
			СокращенноеНаименованиеВрача = ОбщегоНазначения.ПолучитьЗначениеРеквизита(НаправившийВрач, "НаименованиеСокращенное");
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"     	, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='По направлению %1';en='In direction %1'"), ?(ЗначениеЗаполнено(СокрЛП(СокращенноеНаименованиеВрача)), СокрЛП(СокращенноеНаименованиеВрача), Строка(НаправившийВрач))));
		Иначе 
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"     	, НСтр("ru='По направлению';en='In direction'"));
		КонецЕсли;	
	КонецЕсли;
	СделкаЗадачи = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадачи, "Сделка", Неопределено);	
	Если ЗначениеЗаполнено(СделкаЗадачи) Тогда 
		ДанныеЗаполненияЗадачи.Вставить("Сделка"     				, СделкаЗадачи);
	КонецЕсли;
	ДанныеЗаполненияЗадачи.Вставить("Выполнена"                  	, Ложь);
	
	// Наполняем задачу
	НоваяЗадача = Задачи.Взаимодействие.СоздатьЗадачу();	
	НоваяЗадача.Заполнить(ДанныеЗаполненияЗадачи);	
	ЗаполнитьПараметрыНапоминания(НоваяЗадача, Новый Структура("ЗадачаРежимНапоминания", -1));	
		
	Если ВозвращатьОбъект Тогда 
		Возврат НоваяЗадача;
	Иначе 
		Попытка
			НоваяЗадача.ОбменДанными.Загрузка = НЕ ВключитьБизнесЛогику;			
			НоваяЗадача.Записать();
			Возврат НоваяЗадача.Ссылка;
		Исключение
			Возврат Неопределено;	
		КонецПопытки;
	КонецЕсли;	
	
КонецФункции

// Функция - Инициализировать структуру данных заполнения
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСтруктуруДанныхЗаполнения() Экспорт
	
	ДанныеЗаполненияЗадачи = Новый Структура;
	ДанныеЗаполненияЗадачи.Вставить("СтруктурнаяЕдиница"          	, Неопределено);	
	ДанныеЗаполненияЗадачи.Вставить("Контрагент"                 	, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("ВидВзаимодействия"          	, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("ВидВзаимодействияСправочник"	, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("Исполнитель"                	, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("ЗадачаНазначеннаяДата"      	, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("ЗадачаНазначеннаяДатаНачало"  	, Неопределено);	
	ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"                 	, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"				, Неопределено);     
	ДанныеЗаполненияЗадачи.Вставить("Сделка"						, Неопределено);
	ДанныеЗаполненияЗадачи.Вставить("Выполнена"                  	, Ложь);
	
	Возврат ДанныеЗаполненияЗадачи;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция возвращает таблицу реквизитов, зависимых от хозяйственной операции документа.
//
Функция ПолучитьМассивСостоянияРеквизитов(ОбъектФормы) Экспорт
	
	МассивРеквизитов = Новый Массив;
	
	// Состояния реквизитов по умолчанию
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "КнопкаПриступитьВыполнитьЗадачу"		, Тип("КнопкаФормы"));
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "КнопкаЗаписатьИЗакрыть"				, Тип("КнопкаФормы"));
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "РедактироватьСодержание"				, Тип("КнопкаФормы"), Истина);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "КнопкаВыбратьДатуИВремя"				, Тип("КнопкаФормы"));
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "КнопкаНизкийПриоритет"				, Тип("КнопкаФормы"), Ложь);		
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "КнопкаСреднийПриоритет"				, Тип("КнопкаФормы"), Ложь);		
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "КнопкаВысокийПриоритет"				, Тип("КнопкаФормы"), Ложь);					
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "ГруппаДатаВремяПланирования"			, Тип("ГруппаФормы"), Ложь, , Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "ГруппаЗаписьНаТренировку"			, Тип("ГруппаФормы"), Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "ГруппаОформлениеПродажи"				, Тип("ГруппаФормы"), Ложь);
	УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВМассивСостоянияРеквизитов(МассивРеквизитов, "ГруппаПричинаОтказа"					, Тип("ГруппаФормы"), Ложь);
