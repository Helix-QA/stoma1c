// Процедура - Отобразить допустимые причины отказа
//
// Параметры:
//  СозданиеФормы	 - 	 - 
//  УдалитьЭлементы	 - 	 - 
//
Процедура ОтобразитьДопустимыеПричиныОтказа(СозданиеФормы = Ложь, УдалитьЭлементы = Истина)
	
	ЛюбаяПричина = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.ЛюбаяПричина");
	Если СозданиеФормы И НЕ ЗаблокироватьИзменениеЭтапов Тогда
		НоваяСтрока = Объект.ПричиныОтказов.Добавить();
		Если Объект.ПричиныОтказов.Количество() = 1 Тогда
			НоваяСтрока.ПричинаОтказа = ЛюбаяПричина;
			НоваяСтрока = Объект.ПричиныОтказов.Добавить();			
		КонецЕсли;	
	КонецЕсли;
	
	Если УдалитьЭлементы Тогда 
		ГруппаРазмещенияПричинОтказа = Элементы.Найти("ГруппаЭтапаИПричинОтказов");
		Если НЕ ГруппаРазмещенияПричинОтказа = Неопределено Тогда 
			УдалитьЭлементыГруппы(ГруппаРазмещенияПричинОтказа);
		КонецЕсли;
	КонецЕсли;
	
	УказанаЛюбаяПричина = НЕ Объект.ПричиныОтказов.НайтиСтроки(Новый Структура("ПричинаОтказа", ЛюбаяПричина)).Количество() = 0;
	МассивНеЗадействованныхПричинОтказа = ПолучитьМассивНеЗадействованныхПричинОтказа(Объект.ПричиныОтказов.Выгрузить().ВыгрузитьКолонку("ПричинаОтказа"));
	
	Для Каждого СтрокаТЧ Из Объект.ПричиныОтказов Цикл
		ИндексСтроки = Объект.ПричиныОтказов.Индекс(СтрокаТЧ);
		СоздатьСтрокуОтказаИВыбораПричины(ИндексСтроки, МассивНеЗадействованныхПричинОтказа, УказанаЛюбаяПричина, ЛюбаяПричина);		
	КонецЦикла;

КонецПроцедуры

&НаСервере
// Функция - Получить массив не задействованных причин отказа
//
// Параметры:
//  МассивУказанныхПричин	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивНеЗадействованныхПричинОтказа(МассивУказанныхПричин)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивУказанныхПричин", МассивУказанныхПричин);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПричиныОтказов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПричиныОтказов КАК ПричиныОтказов
	|ГДЕ
	|	НЕ ПричиныОтказов.Ссылка В (&МассивУказанныхПричин)
	|	И ПричиныОтказов.ПометкаУдаления = ЛОЖЬ";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

&НаСервере
// Процедура - Создать строку отказа и выбора причины
//
// Параметры:
//  ИндексСтроки - 	 - 
//
Процедура СоздатьСтрокуОтказаИВыбораПричины(ИндексСтроки, МассивНеЗадействованныхПричинОтказа, УказанаЛюбаяПричина, ЛюбаяПричина)
	
	ИндекстСтрокой 									= Формат(ИндексСтроки, "ЧДЦ=0; ЧН=0; ЧГ=0");
	
	ГруппаНовыхЭл                       			= Элементы.Добавить("СтрокаТаблицыОтказов_" + ИндекстСтрокой, Тип("ГруппаФормы"), Элементы.ГруппаЭтапаИПричинОтказов);
	ГруппаНовыхЭл.Вид                  	 			= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНовыхЭл.Группировка           			= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаНовыхЭл.Отображение           			= ОтображениеОбычнойГруппы.Нет;
	ГруппаНовыхЭл.ОтображатьЗаголовок   			= Ложь;
	ГруппаНовыхЭл.ГоризонтальныйИнтервал			= ИнтервалМеждуЭлементамиФормы.Половинный;
	ГруппаНовыхЭл.ВертикальноеПоложениеПодчиненных 	= ВертикальноеПоложениеЭлемента.Центр;
	Если ЗаблокироватьИзменениеЭтапов Тогда 
		ГруппаНовыхЭл.ТолькоПросмотр 				= Истина;
	Иначе 	
		ГруппаНовыхЭл.Доступность 					= ?(УказанаЛюбаяПричина, ?(Объект.ПричиныОтказов[ИндексСтроки].ПричинаОтказа = ЛюбаяПричина ИЛИ Объект.ПричиныОтказов[ИндексСтроки].ПричинаОтказа = Справочники.ПричиныОтказов.ПустаяСсылка(), Истина, Ложь), Истина);
	КонецЕсли;	
	
	// Создаем заглушку
	ДекорацияФормы_Заглушка = Элементы.Добавить("ЗаглушкаОтказов_" + ИндекстСтрокой, Тип("ДекорацияФормы"), ГруппаНовыхЭл);
	ДекорацияФормы_Заглушка.Вид 				   	= ВидДекорацииФормы.Надпись;
	ДекорацияФормы_Заглушка.Заголовок 			   	= 0;
	ДекорацияФормы_Заглушка.ЦветТекста 				= Новый Цвет(255, 255, 255);
	ДекорацияФормы_Заглушка.Ширина                	= 2;	
	ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина 	= Ложь;
	ДекорацияФормы_Заглушка.МаксимальнаяШирина     	= 2;
	ДекорацияФормы_Заглушка.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
	ДекорацияФормы_Заглушка.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	
	// Создаем поле выбора причины отказа.
	ПричинаОтказа                    				= Элементы.Добавить("ПричинаОтказа_" + ИндекстСтрокой, Тип("ПолеФормы"), ГруппаНовыхЭл);
	ПричинаОтказа.Вид                				= ВидПоляФормы.ПолеВвода;
	ПричинаОтказа.ПоложениеЗаголовка 				= ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПричинаОтказа.Заголовок 						= НСтр("ru='Отказ';en='Refusal'");
	ПричинаОтказа.ЦветТекстаЗаголовка 				= Новый Цвет(255, 0, 0);
	ПричинаОтказа.ПодсказкаВвода     				= НСтр("ru='Укажите причину отказа';en='Specify the reason for refusal'");		
	ПричинаОтказа.ПутьКДанным        				= "Объект.ПричиныОтказов[" + ИндекстСтрокой + "].ПричинаОтказа";
	ПричинаОтказа.АвтоМаксимальнаяШирина 			= Ложь;
	ПричинаОтказа.МаксимальнаяШирина     			= 42;
	ПричинаОтказа.Шрифт 							= ?(УказанаЛюбаяПричина, ?(Объект.ПричиныОтказов[ИндексСтроки].ПричинаОтказа = ЛюбаяПричина ИЛИ Объект.ПричиныОтказов[ИндексСтроки].ПричинаОтказа = Справочники.ПричиныОтказов.ПустаяСсылка(), Новый Шрифт, Новый Шрифт(,,,,, Истина)), Новый Шрифт);
	ПричинаОтказа.УстановитьДействие("ПриИзменении", "ДобавитьВыборНовойПричны");
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", МассивНеЗадействованныхПричинОтказа));
	ПричинаОтказа.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	
	Если ЗначениеЗаполнено(Объект.ПричиныОтказов[ИндексСтроки].ПричинаОтказа) Тогда
		// Создаем кнопку удаления.
		КнопкаУдаления                  			= Элементы.Добавить("УдалитьПричинуОтказа_" + ИндекстСтрокой, Тип("КнопкаФормы"), ГруппаНовыхЭл);
		КнопкаУдаления.Отображение     	    		= ОтображениеКнопки.Картинка;
		КнопкаУдаления.ОтображениеФигуры 			= ОтображениеФигурыКнопки.Нет;
		КнопкаУдаления.ИмяКоманды      	    		= "УдалитьПричинуОтказа";    	
		КнопкаУдаления.Доступность 					= НЕ ЗаблокироватьИзменениеЭтапов;
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Заблокировать элементы для предопреленных объектов
//
Процедура ЗаблокироватьЭлементыДляПредопреленныхОбъектов()
	
	Элементы.ТипСделки.ТолькоПросмотр = Объект.Предопределенный;
	
	Элементы.СтраницыДоступностиПоСтатусамПациентов.ТолькоПросмотр 	= Объект.Предопределенный;
	Элементы.СтатусыПациентовПрименения.ТолькоПросмотр 				= Объект.Предопределенный;
	Элементы.СтатусыПациентовПримененияУдаление.Видимость 			= НЕ Объект.Предопределенный;
	Элементы.СтатусыПациентовПримененияУдаление.Доступность			= НЕ Объект.Предопределенный;	
	Элементы.КнопкаДобавитьСтатус.Видимость 						= НЕ Объект.Предопределенный;
	Элементы.УстановитьПоУмолчаниюСтатусы.Доступность				= НЕ Объект.Предопределенный;
	Элементы.ПереключательПолеСтатус.Доступность 					= НЕ Объект.Предопределенный;
	Элементы.ПереключательСписокСтатусов.Доступность 				= НЕ Объект.Предопределенный;
	
	Если ЗаблокироватьИзменениеЭтапов Тогда 
		Элементы.ГруппаЭтапы.ТолькоПросмотр 						= Истина;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Заблокировать элементы по правам доступа объекта
//
Процедура ЗаблокироватьЭлементыПоПравамДоступаОбъекта()
	
	Если НЕ ПравоДоступа("Редактирование", Объект.Ссылка.Метаданные()) Тогда
    	Элементы.ПереключательСписок.Доступность 						= Ложь;
		Элементы.ПереключательПоле.Доступность 							= Ложь;
		Элементы.СтруктурныеЕдиницыПрименения.ТолькоПросмотр 			= Истина;
		Элементы.УстановитьПоУмолчанию.Доступность 						= Ложь;
		Элементы.СтруктурныеЕдиницыПримененияУдаление.Доступность 		= Ложь;
		
		Элементы.ПереключательСписокСтатусов.Доступность 				= Ложь;
		Элементы.ПереключательПолеСтатус.Доступность 					= Ложь;
		Элементы.СтатусыПациентовПрименения.ТолькоПросмотр 				= Истина;
		Элементы.УстановитьПоУмолчаниюСтатусы.Доступность 				= Ложь;
		Элементы.СтатусыПациентовПримененияУдаление.Доступность 		= Ложь;
		
		Элементы.ГруппаЭтапы.Доступность 								= Ложь;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Определить режим отображения списка структурных единиц
//
Процедура ОпределитьРежимОтображенияСпискаСтруктурныхЕдиниц()
	
	// По умолчанию
	РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле";
	
	Если Объект.СтруктурныеЕдиницыПрименения.Количество() > 1 Тогда
		РежимОтображенияСпискаСтруктурныхЕдиниц = "Список";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Определить режим отображения списка статусов пациентов
//
Процедура ОпределитьРежимОтображенияСпискаСтатусовПациентов()
	
	// По умолчанию
	РежимОтображенияСпискаСтатусовПациента = "Поле";
	
	Если Объект.СтатусыПациентовПрименения.Количество() > 1 Тогда
		РежимОтображенияСпискаСтатусовПациента = "Список";
