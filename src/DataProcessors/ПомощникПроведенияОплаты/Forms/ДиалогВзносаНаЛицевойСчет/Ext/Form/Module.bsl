// Процедура - Расставить приоритет печати чека
//
Процедура РасставитьПриоритетПечатиЧека()
	
		Если ЗначениеЗаполнено(Этотобъект.Касса) Тогда
		ПриоритетЭлектронногоЧека = Этотобъект.Касса.ПриоритетЭлектронногоЧека; //0 - выключен, 1 -  Email, Телефон, 2 - Email. 	 
	КонецЕсли;
	
	ЭтотОбъект.ЧекПечатать = ПриоритетЭлектронногоЧека = 0; 
	
	Если ПриоритетЭлектронногоЧека = 0 Тогда                                        //0 - выключен.
		
		Элементы.ГруппаКонтактыКлиентаТелефон.Видимость			= Ложь;
		Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость 	= Истина;
		ЭтотОбъект.ЧекККОтправитьНаТелефон 						= Ложь;
		
		Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Ложь;
		Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Истина;
		ЭтотОбъект.ЧекККОтправитьНаПочту 						= Ложь;
		
	ИначеЕсли ПриоритетЭлектронногоЧека = 1 Тогда                                  	//1 -  Email, Телефон. 
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЧекККТПочта) Тогда         
			
			Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Истина;
			Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККОтправитьНаПочту 						= Истина;
			
		ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект.ЧекККТТелефон) Тогда
			
			Элементы.ГруппаКонтактыКлиентаТелефон.Видимость			= Истина;
			Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККОтправитьНаТелефон 						= Истина;
		Иначе 
			ЭтотОбъект.ЧекПечатать = Истина; 
		КонецЕсли;
		
	ИначеЕсли ПриоритетЭлектронногоЧека = 2 Тогда                                    //2 - Email.
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ЧекККТПочта) Тогда	
			Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Истина;
			Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККОтправитьНаПочту 						= Истина;
		Иначе 
			ЭтотОбъект.ЧекПечатать = Истина; 
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

