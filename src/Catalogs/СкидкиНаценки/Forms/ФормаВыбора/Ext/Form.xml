			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникСкидкиНаценки.Родитель,
	СправочникСкидкиНаценки.Ссылка,
	СправочникСкидкиНаценки.Наименование,
	ВЫБОР
		КОГДА СправочникСкидкиНаценки.ЭтоГруппа
			ТОГДА ВЫБОР
					КОГДА СправочникСкидкиНаценки.ВариантСовместногоПримененияСкидокНаценок = ЗНАЧЕНИЕ(Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Сложение)
						ТОГДА 0
					КОГДА СправочникСкидкиНаценки.ВариантСовместногоПримененияСкидокНаценок = ЗНАЧЕНИЕ(Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Умножение)
						ТОГДА 2
					КОГДА СправочникСкидкиНаценки.ВариантСовместногоПримененияСкидокНаценок = ЗНАЧЕНИЕ(Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Максимум)
						ТОГДА 4
					КОГДА СправочникСкидкиНаценки.ВариантСовместногоПримененияСкидокНаценок = ЗНАЧЕНИЕ(Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Минимум)
						ТОГДА 8
				КОНЕЦ + ВЫБОР
					КОГДА СправочникСкидкиНаценки.ПометкаУдаления
						ТОГДА 1
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА СправочникСкидкиНаценки.СпособПредоставленияСкидки = ЗНАЧЕНИЕ(Перечисление.СпособПредоставленияСкидки.Процент)
					ТОГДА ВЫБОР
							КОГДА СправочникСкидкиНаценки.ЗначениеСкидкиНаценки &lt; 0
								ТОГДА 16
							ИНАЧЕ 14
						КОНЕЦ
				КОГДА СправочникСкидкиНаценки.СпособПредоставленияСкидки = ЗНАЧЕНИЕ(Перечисление.СпособПредоставленияСкидки.Сумма)
					ТОГДА ВЫБОР
							КОГДА СправочникСкидкиНаценки.ЗначениеСкидкиНаценки &lt; 0
								ТОГДА 20
							ИНАЧЕ 22
						КОНЕЦ
				КОГДА СправочникСкидкиНаценки.СпособПредоставленияСкидки = ЗНАЧЕНИЕ(Перечисление.СпособПредоставленияСкидки.Подарок)
					ТОГДА 18
			КОНЕЦ + ВЫБОР
				КОГДА СправочникСкидкиНаценки.ПометкаУдаления
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК Картинка,
	СправочникСкидкиНаценки.ПорядокПрименения,
	СправочникСкидкиНаценки.ТипПолучателя
ИЗ
	Справочник.СкидкиНаценки КАК СправочникСкидкиНаценки
ГДЕ
	ВЫБОР
			КОГДА &amp;СтруктурнаяЕдиница &lt;&gt; НЕОПРЕДЕЛЕНО
					И &amp;СтруктурнаяЕдиница &lt;&gt; ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
				ТОГДА СправочникСкидкиНаценки.Ссылка В
						(ВЫБРАТЬ
							ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка
						ИЗ
							РегистрСведений.ДействиеСкидокНаценок.СрезПоследних(, СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
								И ВЫБОР
									КОГДА &amp;ТекущаяДата &lt;&gt; НЕОПРЕДЕЛЕНО
										ТОГДА (ГОД(ДатаНачала) = 1
												ИЛИ ДатаНачала &lt;= &amp;ТекущаяДата)
												И (ГОД(ДатаОкончания) = 1
													ИЛИ ДатаОкончания &gt;= &amp;ТекущаяДата)
									ИНАЧЕ ИСТИНА
								КОНЕЦ) КАК ДействиеСкидокНаценокСрезПоследних
						СГРУППИРОВАТЬ ПО
							ДействиеСкидокНаценокСрезПоследних.СкидкаНаценка)
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВЫБОР
			КОГДА &amp;ПравоНазначения &lt;&gt; НЕОПРЕДЕЛЕНО
				ТОГДА ВЫБОР
						КОГДА СправочникСкидкиНаценки.ТипПолучателя = 2
							ТОГДА ВЫБОР
									КОГДА СправочникСкидкиНаценки.ПравоНазначения = 0
										ТОГДА &amp;ПравоНазначения = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель)
									КОГДА СправочникСкидкиНаценки.ПравоНазначения = 1
										ТОГДА &amp;ПравоНазначения = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель)
												ИЛИ &amp;ПравоНазначения = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Регистратура)
									ИНАЧЕ ЛОЖЬ
								КОНЕЦ
						ИНАЧЕ ИСТИНА
					КОНЕЦ
			ИНАЧЕ ИСТИНА
		КОНЕЦ</QueryText>
