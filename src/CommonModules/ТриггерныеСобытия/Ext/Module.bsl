// Процедура - Получить массив корректных электронных адресов
//
// Параметры:
//  МассивСтрокКлиентаСEmail - 	 - 
//  МассивEmail				 - 	 - 
//
Процедура ПолучитьКорректныеЭлектронныеАдреса(Получатель, МассивСтрокКлиентаСEmail, ТаблицаКонтактов, РассылкаЗапрещена = Ложь)
	
	ТаблицаКонтактов.Очистить();
	
	Для Каждого СтрокаEmailКлиента Из МассивСтрокКлиентаСEmail Цикл 
		Если ЗначениеЗаполнено(СтрокаEmailКлиента.Представление) И ЭлектроннаяПочтаКорректна(СтрокаEmailКлиента.Представление) Тогда 
			Если НЕ СтрокаEmailКлиента.НеУчаствоватьВРассылке Тогда 			
				НовыйПолучатель = ТаблицаКонтактов.Добавить();
				НовыйПолучатель.Получатель 		= Получатель;
				НовыйПолучатель.Адрес 			= СокрЛП(СтрокаEmailКлиента.Представление);
			Иначе 
				РассылкаЗапрещена = Истина;
			КонецЕсли;								
		КонецЕсли;
	КонецЦикла;	
	
	РассылкаЗапрещена = ТаблицаКонтактов.Количество() = 0 И РассылкаЗапрещена;
	
КонецПроцедуры

// Функция проверяет корректность адреса электронной почты
//
// Параметры:
//  ОбъектКИ	 - ОбъектXDTO	 - объект XDTO контактной информации
//  ИмяРеквизита - строка	 - имя реквизита формы, с которым будет связано сообщение об ошибке
// 
// Возвращаемое значение:
//  Булево - признак корректности
//
Функция ЭлектроннаяПочтаКорректна(ЭлектроннаяПочтаКлиента)
	
	СтрокаОшибки = "";
	
	Попытка
		Результат = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(ЭлектроннаяПочтаКлиента);
		Если Результат.Количество() > 1 Тогда
			СтрокаОшибки = Нстр("ru='Допускается ввод только одного адреса электронной почты';en='Allowed input only one addresses email of mail'");
		КонецЕсли;
	Исключение
		СтрокаОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат ПустаяСтрока(СтрокаОшибки);
	
КонецФункции

// Процедура - Инициализировать параметры шаблона
//
// Параметры:
//  ПараметрыШаблона - 	 - 
//  ДанныеТриггера	 - 	 - 
//
Процедура ИнициализироватьПараметрыШаблона(ДанныеТриггера, ПараметрыРегистрации, ТаблицаДанныхОбъекта, РегистрацияВФоне = Ложь)
	
	// Инициализируем таблицу параметров, которые мы использовали в шаблоне
	ТаблицаВсехПараметров 				= ОбщегоНазначенияПовтИсп.ПолучитьТаблицуПараметровВсехПодставляемыхРеквизитов();
	ТаблицаЗадействованныхПараметров 	= ТаблицаВсехПараметров.СкопироватьКолонки();
	Для Каждого СтрокаТаблицы Из ТаблицаВсехПараметров Цикл
		Для Каждого СтрокаПланДействия Из ДанныеТриггера.ПланДействийТриггерногоСобытия Цикл
			Если СтрокаПланДействия.ШаблонСообщения = Неопределено Тогда 
				Продолжить;				
			КонецЕсли;
			Если СтрокаПланДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение Тогда
				Если СтрНайти(СтрокаПланДействия.СодержаниеМессенджер, СтрокаТаблицы.НаименованиеПараметра) <> 0 Тогда 
					ЗаполнитьЗначенияСвойств(ТаблицаЗадействованныхПараметров.Добавить(), СтрокаТаблицы);
				КонецЕсли;					
				Если СтрНайти(СтрокаПланДействия.Содержание, СтрокаТаблицы.НаименованиеПараметра) <> 0 Тогда 
					ЗаполнитьЗначенияСвойств(ТаблицаЗадействованныхПараметров.Добавить(), СтрокаТаблицы);
				КонецЕсли;
				Если СтрНайти(СтрокаПланДействия.СодержаниеPush, СтрокаТаблицы.НаименованиеПараметра) <> 0 Тогда 
					ЗаполнитьЗначенияСвойств(ТаблицаЗадействованныхПараметров.Добавить(), СтрокаТаблицы);
				КонецЕсли;					
			ИначеЕсли СтрокаПланДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
				Если СтрНайти(СтрокаПланДействия.ТекстHTML, СтрокаТаблицы.НаименованиеПараметра) <> 0 Тогда 
					ЗаполнитьЗначенияСвойств(ТаблицаЗадействованныхПараметров.Добавить(), СтрокаТаблицы);
				КонецЕсли;	
			ИначеЕсли СтрокаПланДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру Тогда 
				Если СтрНайти(СтрокаПланДействия.ЗадачаОписание, СтрокаТаблицы.НаименованиеПараметра) <> 0 Тогда 
					ЗаполнитьЗначенияСвойств(ТаблицаЗадействованныхПараметров.Добавить(), СтрокаТаблицы);
				КонецЕсли;	
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;	
	
	// Формируем текст запроса. Получаем таблицу значений.
	Если ТаблицаЗадействованныхПараметров.Количество() <> 0 Тогда
		ТаблицаЗадействованныхПараметров.Свернуть("НаименованиеПараметра, ПредставлениеПараметра, РеквизитПараметра, ОсновнаяТаблицаОбъекта, ВидОсновнойТаблицыОбъекта, ОбъектПараметра, ПредставлениеОсновнойТаблицаОбъекта, ИзОсновнойТаблицы, ФорматПараметра, ИнициализированВИсходнойТаблице");		
		Для Каждого СтрокаПланДействия Из ДанныеТриггера.ПланДействийТриггерногоСобытия Цикл
			СтрокаПланДействия.ТаблицаЗадействованныхПараметров = ТаблицаЗадействованныхПараметров;
		КонецЦикла;
		
		ТаблицаОбъектовПараметра = ТаблицаЗадействованныхПараметров.Скопировать(Новый Структура("ИнициализированВИсходнойТаблице", Ложь), "ОсновнаяТаблицаОбъекта, ВидОсновнойТаблицыОбъекта");
		ТаблицаОбъектовПараметра.Свернуть("ОсновнаяТаблицаОбъекта, ВидОсновнойТаблицыОбъекта");
		// Если нужно получить актуальные данные итогового регистра - обновим их в итоговом в принудительном порядке
		РегистрацияВФоне = Ложь;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаДанныхОбъекта, "ТаблицаДанныхОбъекта");
		ТекстЗапроса = Запрос.Текст;		
		// Генерируем таблицы для получения значений параметров
		Для Каждого СтрокаОбъектПараметр Из ТаблицаОбъектовПараметра Цикл
			Если ТаблицаОбъектовПараметра.Индекс(СтрокаОбъектПараметр) = 0 Тогда 
				ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ" + Символы.ПС;
			Иначе 
				ТекстЗапроса = ТекстЗапроса + ";" + Символы.ПС + Символы.ПС + "////////////////////////////////////////////////////////////////////////////////" + Символы.ПС + "ВЫБРАТЬ" + Символы.ПС;
			КонецЕсли;
			ТекстЗапроса = ТекстЗапроса + Символы.Таб + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + ".Ссылка КАК Ссылка" + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + "," + Символы.ПС;
			Если СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта = "Контрагенты" Тогда
				ТекстЗапроса = ТекстЗапроса + Символы.Таб + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + ".Наименование КАК НаименованиеКонтрагента" + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + "," + Символы.ПС;
				// ТекстЗапроса = ТекстЗапроса + Символы.Таб + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + ".НаименованиеСокращенное КАК НаименованиеКонтрагентаСокращенное" + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + "," + Символы.ПС;
			КонецЕсли;
			МассивПсевдонимов = Новый Массив;
			МассивПараметров = ТаблицаЗадействованныхПараметров.НайтиСтроки(Новый Структура("ОсновнаяТаблицаОбъекта, ВидОсновнойТаблицыОбъекта", СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта, СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта));
			Для Каждого ЭлементМассива Из МассивПараметров Цикл
				Если ЭлементМассива.НаименованиеПараметра = "{НаименованиеКонтрагентаСокращенное}" ИЛИ ЭлементМассива.НаименованиеПараметра = "{Email}" ИЛИ ЭлементМассива.НаименованиеПараметра = "{СсылкаНаОценкуИОтзыв}" ИЛИ ЭлементМассива.НаименованиеПараметра = "{СсылкаНаИнформациюОЗаписиНаЗанятие}" Тогда 
					Продолжить;
				КонецЕсли;
				Если НЕ МассивПсевдонимов.Найти(?(ЭлементМассива.ИзОсновнойТаблицы, СтрСоединить(СтрРазделить(ЭлементМассива.НаименованиеПараметра, " {}")) + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта, ЭлементМассива.РеквизитПараметра)) = Неопределено Тогда 
					Продолжить;
				КонецЕсли;
				МассивПсевдонимов.Добавить(?(ЭлементМассива.ИзОсновнойТаблицы, СтрСоединить(СтрРазделить(ЭлементМассива.НаименованиеПараметра, " {}")) + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта, ЭлементМассива.РеквизитПараметра));				
				// Если ЭлементМассива.НаименованиеПараметра = "{СсылкаНаОценкуИОтзыв}" Тогда 
				//	ТекстЗапроса = ТекстЗапроса + Символы.Таб + """" + " КАК " + СтрСоединить(СтрРазделить(ЭлементМассива.НаименованиеПараметра, " {}")) + ?(МассивПараметров.Найти(ЭлементМассива) = МассивПараметров.Количество() - 1, "", ",") + Символы.ПС
				// Иначе 
					ТекстЗапроса = ТекстЗапроса + Символы.Таб + ?(ЭлементМассива.ИзОсновнойТаблицы, ЭлементМассива.ВидОсновнойТаблицыОбъекта + ЭлементМассива.ОсновнаяТаблицаОбъекта, ЭлементМассива.ОбъектПараметра) + "." + ЭлементМассива.РеквизитПараметра + " КАК " + ?(ЭлементМассива.ИзОсновнойТаблицы, СтрСоединить(СтрРазделить(ЭлементМассива.НаименованиеПараметра, " {}")) + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта, ЭлементМассива.РеквизитПараметра) + ?(МассивПараметров.Найти(ЭлементМассива) = МассивПараметров.Количество() - 1, "", ",") + Символы.ПС
				// КонецЕсли;	
			КонецЦикла;
			Если Прав(СокрЛП(ТекстЗапроса), 1) = "," Тогда 
				ТекстЗапроса = Лев(СокрЛП(ТекстЗапроса), СтрНайти(СокрЛП(ТекстЗапроса), ",", НаправлениеПоиска.СКонца) - 1) + Символы.ПС;
			КонецЕсли;	
			ТекстЗапроса = ТекстЗапроса + "ПОМЕСТИТЬ " + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + Символы.ПС;
			ТекстЗапроса = ТекстЗапроса + "ИЗ" + Символы.ПС + Символы.Таб + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + "." + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + " КАК " + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + Символы.ПС;
			ТекстЗапроса = ТекстЗапроса + "ГДЕ" + Символы.ПС + Символы.Таб + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + ".Ссылка В" + 
				?(СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта = "Контрагенты", "(ВЫБРАТЬ ТаблицаДанныхОбъекта.Контрагент ИЗ ТаблицаДанныхОбъекта)", "(ВЫБРАТЬ ТаблицаДанныхОбъекта.ОбъектСобытия ИЗ ТаблицаДанныхОбъекта)") + Символы.ПС;
		КонецЦикла;
		Если ТаблицаОбъектовПараметра.Количество() <> 0 Тогда 
			ТекстЗапроса = ТекстЗапроса + ";" + Символы.ПС + Символы.ПС + "////////////////////////////////////////////////////////////////////////////////" + Символы.ПС;
		КонецЕсли;	
		ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ" + Символы.ПС + Символы.Таб + "*" + Символы.ПС + "ИЗ" + Символы.ПС + Символы.Таб + "ТаблицаДанныхОбъекта КАК ТаблицаДанныхОбъекта" + Символы.ПС;
		// Цепляем левым соединением все сгенерированные таблицы к основной для получения общей таблицы значений
		Для Каждого СтрокаОбъектПараметр Из ТаблицаОбъектовПараметра Цикл
			ТекстЗапроса = ТекстЗапроса + "ЛЕВОЕ СОЕДИНЕНИЕ " + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + " КАК " + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + Символы.ПС + Символы.Таб + 
					"ПО ТаблицаДанныхОбъекта." + ?(СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта = "Контрагенты", "Контрагент", "ОбъектСобытия") + " = " + СтрокаОбъектПараметр.ВидОсновнойТаблицыОбъекта + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + ".Ссылка" + СтрокаОбъектПараметр.ОсновнаяТаблицаОбъекта + Символы.ПС;
		КонецЦикла;	
		Запрос.Текст = ТекстЗапроса;
		// Получаем таблицу значений
		Попытка
			ТаблицаЗначенийПараметров = Запрос.Выполнить().Выгрузить();
			СтрокаПараметраСсылкаНаОценкуИОтзыв = ТаблицаЗадействованныхПараметров.Найти("{СсылкаНаОценкуИОтзыв}", "НаименованиеПараметра");
			Если НЕ СтрокаПараметраСсылкаНаОценкуИОтзыв = Неопределено Тогда
				Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеПроведеноКлиентПрибыл Тогда 
					ТаблицаЗначенийПараметров.Колонки.Добавить("СсылкаНаОценкуИОтзыв", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(900)));
				Иначе 
					ТаблицаЗадействованныхПараметров.Удалить(СтрокаПараметраСсылкаНаОценкуИОтзыв);
				КонецЕсли;	
			КонецЕсли;
			СтрокаПараметраСсылкаНаИнформациюОЗаписи = ТаблицаЗадействованныхПараметров.Найти("{СсылкаНаИнформациюОЗаписиНаЗанятие}", "НаименованиеПараметра");
			Если НЕ СтрокаПараметраСсылкаНаИнформациюОЗаписи = Неопределено Тогда
				Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема Тогда 
					ТаблицаЗначенийПараметров.Колонки.Добавить("СсылкаНаИнформациюОЗаписиНаЗанятие", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(900)));
				Иначе 
					ТаблицаЗадействованныхПараметров.Удалить(СтрокаПараметраСсылкаНаИнформациюОЗаписи);
				КонецЕсли;	
			КонецЕсли;
			
			Для Каждого СтрокаПланДействия Из ДанныеТриггера.ПланДействийТриггерногоСобытия Цикл
				СтрокаПланДействия.ТаблицаЗначенийПараметров = ТаблицаЗначенийПараметров;
			КонецЦикла;
		Исключение
			// Пишем в журнал регистрации триггерных событий
			СообщениеОбОшибке = НСтр("ru='Ошибка при получении значений параметров для шаблона триггерного события:';en='Error getting parameter values for the trigger event template:'") + Символы.ПС + Символы.ПС + ОписаниеОшибки();			
			ЗарегистрироватьОшибкиРегистрацииСобытия(ДанныеТриггера, ТаблицаДанныхОбъекта, , ПараметрыРегистрации.РегистрацияПоПодписке, ПараметрыРегистрации.РегистрацияЗапланированных, СообщениеОбОшибке);
			// Пишем в системный журнал
			ЗаписьЖурналаРегистрации("РегистрацияТриггерныхСобытий.ПолучениеЗначенийПараметровДляШаблона", УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.ТриггерныеСобытия, ДанныеТриггера.ТриггерноеСобытие, СообщениеОбОшибке + Символы.ПС + "Фиксация: " + Строка(ТекущаяДатаСеанса()) + Символы.ПС + "Триггерное событие: " + Строка(ДанныеТриггера.ТриггерноеСобытие));									
		КонецПопытки;
		Запрос.МенеджерВременныхТаблиц.Закрыть();
	КонецЕсли;	
	
КонецПроцедуры

// Функция - Инициализировать параметры SMSОбъекта
//
// Параметры:
//  ДанныеТриггера	 - 	 - 
//  ДанныеОбъекта	 - 	 - 
//  МассивНомеров	 - 	 - 
//  Период			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПараметрыSMSОбъекта(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра = Неопределено, ТаблицаКонтактов, Период)
	
	ДатаОтправки = ?(ЗначениеЗаполнено(Период), Период, ТекущаяДатаСеанса());
	ПараметрыSMSОбъекта = Новый Структура;
	ПараметрыSMSОбъекта.Вставить("Период"						, Период);
	ПараметрыSMSОбъекта.Вставить("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);		
	ПараметрыSMSОбъекта.Вставить("СтруктурнаяЕдиница"			, ДанныеОбъекта.СтруктурнаяЕдиница);	
	ПараметрыSMSОбъекта.Вставить("ВидОперации"					, Перечисления.ВидОперацииОтправкаSMS.ОтправкаSMSПолучателю);	
	ПараметрыSMSОбъекта.Вставить("СервисSMSРассылки"			, СтрокаПланДействий.АккаунтSMS);
	ПараметрыSMSОбъекта.Вставить("Тип"							, Перечисления.ТипыСобытий.SMS);
	// ПараметрыSMSОбъекта.Вставить("КаналСистемыСообщений"		, СтрокаПланДействий.КаналСистемыСообщений);
	ПараметрыSMSОбъекта.Вставить("Содержание"					, СтрокаПланДействий.Содержание);
	ВремяНачалаТекущейОтправки 		= НачалоДня(ДатаОтправки) + (Час(СтрокаПланДействий.SMSВремяНачалаОтправки) * 60 * 60) + (Минута(СтрокаПланДействий.SMSВремяНачалаОтправки) * 60);
	ВремяОкончанияТекущейОтправки 	= НачалоДня(ДатаОтправки) + (Час(СтрокаПланДействий.SMSВремяОкончанияОтправки) * 60 * 60) + (Минута(СтрокаПланДействий.SMSВремяОкончанияОтправки) * 60);
	
	Если (СтрокаПланДействий.SMSВремяНачалаОтправки = Дата(1, 1, 1) И СтрокаПланДействий.SMSВремяОкончанияОтправки = Дата(1, 1, 1)) 
		ИЛИ (ДатаОтправки >= ВремяНачалаТекущейОтправки И ДатаОтправки <= ВремяОкончанияТекущейОтправки) Тогда 
		ПараметрыSMSОбъекта.Вставить("ОтправитьНемедленно"		, Ложь); // ИСТИНА
		ПараметрыSMSОбъекта.Вставить("ДатаОтправки"				, ДатаОтправки);
	ИначеЕсли ДатаОтправки < ВремяНачалаТекущейОтправки	Тогда 
		ПараметрыSMSОбъекта.Вставить("ОтправитьНемедленно"		, Ложь);
		ПараметрыSMSОбъекта.Вставить("ДатаОтправки"				, ВремяНачалаТекущейОтправки);
	Иначе 
		ПараметрыSMSОбъекта.Вставить("ОтправитьНемедленно"		, Ложь);
		ПараметрыSMSОбъекта.Вставить("ДатаОтправки"				, ВремяНачалаТекущейОтправки + (24 * 60 * 60));
	КонецЕсли;	
	ПараметрыSMSОбъекта.Вставить("Комментарий"					, "Сформирован автоматически по триггеру: " + Символы.ПС + ДанныеТриггера.Наименование);
	ПараметрыSMSОбъекта.Вставить("ПараметрЖурналаРегистрации"	, "РассылкаСообщений." + ДанныеТриггера.Наименование);	
	ПараметрыSMSОбъекта.Вставить("ДанныеТриггера"				, ДанныеТриггера);	
	ПараметрыSMSОбъекта.Вставить("ДанныеОбъекта"				, ДанныеОбъекта);
	ПараметрыSMSОбъекта.Вставить("ДанныеДействия"				, СтрокаПланДействий);			
	ПараметрыSMSОбъекта.Вставить("ТаблицаКонтактов"				, ТаблицаКонтактов);	
	ПараметрыSMSОбъекта.Вставить("ПараметрыРегистрацииТриггера"	, СформироватьПараметрыРегистрацииТриггерногоСобытия(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра, ПараметрыSMSОбъекта));	
	
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентДеньРождения Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ПоздравлениеСДнемРождения");	
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОПосещенииКлиники");	
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОНепосещенииКлиники");	
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием Тогда
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОЗаписиПациетаНаПрием");			
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеКлиентПрибыл Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОПрибытииКлиентаНаЗанятие");			
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеОтменено Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОбОтменеЗанятия");			
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеКлиентНеПрибыл Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОНеПрибытииКлиенатНаЗанятие");			
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПродажаПлатежПоРассрочке Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОбОчередномПлатежеПоРассрочке");			
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПродажаОплатаПолная ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПродажаОплатаЧастичная Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОбОплате");
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.Продажа Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОбПродаже");
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетВзнос ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетСписание Тогда 
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформированиеОИзмененииБаланса");				
	КонецЕсли;
	
	Если ТипЗнч(ДанныеОбъекта.ОбъектСобытия) = Тип("ДокументСсылка.Событие") Тогда 
		ПараметрыSMSОбъекта.Вставить("ДокументОснование", ДанныеОбъекта.ОбъектСобытия);
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетВзнос ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетСписание Тогда
		ПараметрыSMSОбъекта.Вставить("ДокументОснование", ДанныеОбъекта.ОбъектСобытия);
	КонецЕсли;
	
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема
		И СтрокаПланДействий.ТаблицаЗначенийПараметров <> Неопределено И НЕ СтрокаПланДействий.ТаблицаЗначенийПараметров.Колонки.Найти("СсылкаНаИнформациюОЗаписиНаЗанятие") = Неопределено Тогда
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "НапоминаниеОЗаписи");
	ИначеЕсли ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием
		И СтрокаПланДействий.ТаблицаЗначенийПараметров <> Неопределено И НЕ СтрокаПланДействий.ТаблицаЗначенийПараметров.Колонки.Найти("СсылкаНаИнформациюОЗаписиНаЗанятие") = Неопределено Тогда
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформироватьОПодтвержденииЗанятия");	
	КонецЕсли;
	
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеПроведеноКлиентПрибыл
		И СтрокаПланДействий.ТаблицаЗначенийПараметров <> Неопределено И НЕ СтрокаПланДействий.ТаблицаЗначенийПараметров.Колонки.Найти("СсылкаНаОценкуИОтзыв") = Неопределено Тогда
		ПараметрыSMSОбъекта.Вставить("НазначениеЗадачи"				, "ИнформироватьОбОценкеЗанятия");		
	КонецЕсли;
	
	Возврат ПараметрыSMSОбъекта;
	
КонецФункции	

// Функция - Инициализировать параметры email объекта
//
// Параметры:
//  ДанныеТриггера	 - 	 - 
//  ДанныеОбъекта	 - 	 - 
//  МассивEmail		 - 	 - 
//  Период			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПараметрыEmailОбъекта(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра = Неопределено, ТаблицаКонтактов, Период)
	
	Если ОбщегоНазначенияПовтИсп.ЭтоСеансРегламентногоЗадания() Тогда 
		Пользователь = ОбщегоНазначенияПовтИсп.ПолучитьСлужебногоСотрудника();
	Иначе 
		Пользователь = ПараметрыСеанса.ТекущийСотрудник;
	КонецЕсли;
	
	ПараметрыEmailОбъекта = Новый Структура;
	ПараметрыEmailОбъекта.Вставить("Период"							, Период);
	ПараметрыEmailОбъекта.Вставить("ТриггерноеСобытие"				, ДанныеТриггера.ТриггерноеСобытие);			
	ПараметрыEmailОбъекта.Вставить("СтруктурнаяЕдиница"				, ДанныеОбъекта.СтруктурнаяЕдиница); // ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;	
	ПараметрыEmailОбъекта.Вставить("АвторДокумента"					, Пользователь);		
	ПараметрыEmailОбъекта.Вставить("УчетнаяЗапись"					, СтрокаПланДействий.АккаунтEmail);	
	ПараметрыEmailОбъекта.Вставить("Кодировка"						, "utf-8");		
	ПараметрыEmailОбъекта.Вставить("ЕстьВложения"					, Ложь);		
	ПараметрыEmailОбъекта.Вставить("Важность"						, Перечисления.ВариантыВажностиЗадачи.Обычная);
	ПараметрыEmailОбъекта.Вставить("Тема"							, СтрокаПланДействий.Наименование);
	ПараметрыEmailОбъекта.Вставить("ТекстHTML"						, ИнициализироватьСодержаниеСПараметрами(СтрокаПланДействий.ТекстHTML, СтрокаПланДействий, ДанныеОбъекта));
	ПараметрыEmailОбъекта.Вставить("ТипТекста"						, Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст);
	ПараметрыEmailОбъекта.Вставить("Ответственный"					, Пользователь);
	ПараметрыEmailОбъекта.Вставить("ОтправительПредставление"		, ?(ЗначениеЗаполнено(СтрокаПланДействий.АккаунтEmail.ИмяПользователя), СтрокаПланДействий.АккаунтEmail.ИмяПользователя + " <" + СтрокаПланДействий.АккаунтEmail.АдресЭлектроннойПочты + ">", СтрокаПланДействий.АккаунтEmail.АдресЭлектроннойПочты));
	ПараметрыEmailОбъекта.Вставить("ПараметрЖурналаРегистрации"		, "ЭлектронноеПисьмоИсходящее." + ДанныеТриггера.Наименование);	
	ПараметрыEmailОбъекта.Вставить("ДанныеТриггера"					, ДанныеТриггера);	
	ПараметрыEmailОбъекта.Вставить("ДанныеОбъекта"					, ДанныеОбъекта);
	ПараметрыEmailОбъекта.Вставить("ДанныеДействия"					, СтрокаПланДействий);		
	ПараметрыEmailОбъекта.Вставить("ТаблицаКонтактов"				, ТаблицаКонтактов);	
	ПараметрыEmailОбъекта.Вставить("ПараметрыРегистрацииТриггера"	, СформироватьПараметрыРегистрацииТриггерногоСобытия(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра, ПараметрыEmailОбъекта));	
	
	Возврат ПараметрыEmailОбъекта;
	
КонецФункции	

// Функция - Инициализировать параметры диалога чат бота
//
// Параметры:
//  ДанныеТриггера		 - 	 - 
//  ДанныеОбъекта		 - 	 - 
//  СтрокаПланДействий	 - 	 - 
//  СтрокаРеестра		 - 	 - 
//  ТаблицаКонтактов	 - 	 - 
//  Период				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПараметрыДиалогаЧатБота(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра = Неопределено, ТаблицаКонтактов, Период)
	
	ДатаСтарта = ?(ЗначениеЗаполнено(Период), Период, ТекущаяДатаСеанса());
	ПараметрыДиалогаЧатБота = Новый Структура;
	ПараметрыДиалогаЧатБота.Вставить("Период"							, Период);
	ПараметрыДиалогаЧатБота.Вставить("ТриггерноеСобытие"				, ДанныеТриггера.ТриггерноеСобытие);		
	ПараметрыДиалогаЧатБота.Вставить("СтруктурнаяЕдиница"				, ДанныеОбъекта.СтруктурнаяЕдиница);
	ПараметрыДиалогаЧатБота.Вставить("СценарийЧатБота"					, СтрокаПланДействий.СценарийЧатБота);
	ПараметрыДиалогаЧатБота.Вставить("ЗапускСценарияНеобходимоПеренести", Ложь);
	
	// ПараметрыДиалогаЧатБота.Вставить("СервисSMSРассылки"			, СтрокаПланДействий.АккаунтSMS);
	// ПараметрыSMSОбъекта.Вставить("КаналСистемыСообщений"		, СтрокаПланДействий.КаналСистемыСообщений);
	ВремяНачалаТекущейОтправки 		= НачалоДня(ДатаСтарта) + (Час(СтрокаПланДействий.SMSВремяНачалаОтправки) * 60 * 60) + (Минута(СтрокаПланДействий.SMSВремяНачалаОтправки) * 60);
	ВремяОкончанияТекущейОтправки 	= НачалоДня(ДатаСтарта) + (Час(СтрокаПланДействий.SMSВремяОкончанияОтправки) * 60 * 60) + (Минута(СтрокаПланДействий.SMSВремяОкончанияОтправки) * 60);
	
	Если (СтрокаПланДействий.SMSВремяНачалаОтправки = Дата(1, 1, 1) И СтрокаПланДействий.SMSВремяОкончанияОтправки = Дата(1, 1, 1)) 
		ИЛИ (ДатаСтарта >= ВремяНачалаТекущейОтправки И ДатаСтарта <= ВремяОкончанияТекущейОтправки) Тогда 
		ПараметрыДиалогаЧатБота.Вставить("АктивироватьНемедленно"		, Ложь); // ИСТИНА
		ПараметрыДиалогаЧатБота.Вставить("ДатаСтарта"					, ДатаСтарта);
	ИначеЕсли ДатаСтарта < ВремяНачалаТекущейОтправки	Тогда 
		ПараметрыДиалогаЧатБота.Вставить("АктивироватьНемедленно"		, Ложь);
		ПараметрыДиалогаЧатБота.Вставить("ДатаСтарта"					, ВремяНачалаТекущейОтправки);
		ПараметрыДиалогаЧатБота.Вставить("ЗапускСценарияНеобходимоПеренести", Истина);		
	Иначе 
		ПараметрыДиалогаЧатБота.Вставить("АктивироватьНемедленно"		, Ложь);
		ПараметрыДиалогаЧатБота.Вставить("ДатаСтарта"					, ВремяНачалаТекущейОтправки + (24 * 60 * 60));
		ПараметрыДиалогаЧатБота.Вставить("ЗапускСценарияНеобходимоПеренести", Истина);			
	КонецЕсли;

	ПараметрыДиалогаЧатБота.Вставить("Комментарий"						, "{Активирован автоматически} по триггеру: " + Символы.ПС + ДанныеТриггера.Наименование);
	ПараметрыДиалогаЧатБота.Вставить("ПараметрЖурналаРегистрации"		, "Активация чат-бота." + ДанныеТриггера.Наименование);	
	ПараметрыДиалогаЧатБота.Вставить("ДанныеТриггера"					, ДанныеТриггера);	
	ПараметрыДиалогаЧатБота.Вставить("ДанныеСценария"					, ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ДанныеОбъекта));
	ПараметрыДиалогаЧатБота.Вставить("ДанныеДействия"					, СтрокаПланДействий);			
	ПараметрыДиалогаЧатБота.Вставить("ТаблицаКонтактов"					, ТаблицаКонтактов);	
	ПараметрыДиалогаЧатБота.Вставить("ПараметрыРегистрацииТриггера"		, СформироватьПараметрыРегистрацииТриггерногоСобытия(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра, ПараметрыДиалогаЧатБота));	
	
	Возврат ПараметрыДиалогаЧатБота;
	
КонецФункции	

// Функция - Инициализировать параметры объекта задача
//
// Параметры:
//  ДанныеТриггера							 - 	 - 
//  ДанныеОбъекта							 - 	 - 
//  ТаблицаВремениРаботыСтруктурнойЕдиницы	 - 	 - 
//  Период									 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПараметрыОбъектаЗадача(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра = Неопределено, ТаблицаВремениРаботыСтруктурнойЕдиницы, Период)
	
	Если ОбщегоНазначенияПовтИсп.ЭтоСеансРегламентногоЗадания() Тогда 
		Пользователь = ОбщегоНазначенияПовтИсп.ПолучитьСлужебногоСотрудника();
	Иначе 
		Пользователь = ПараметрыСеанса.ТекущийСотрудник;
	КонецЕсли;
	
	ПараметрыОбъектаЗадача = Новый Структура;
	ПараметрыОбъектаЗадача.Вставить("Период"						, Период);
	ПараметрыОбъектаЗадача.Вставить("ТриггерноеСобытие"				, ДанныеТриггера.ТриггерноеСобытие);	
	ПараметрыОбъектаЗадача.Вставить("СтруктурнаяЕдиница"			, ДанныеОбъекта.СтруктурнаяЕдиница); // ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ПараметрыОбъектаЗадача.Вставить("ЗадачаАвтор"					, Пользователь); 
	Если СтрокаПланДействий.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник ИЛИ СтрокаПланДействий.ВидАдресата = Перечисления.ВидыАдресатов.СегментСотрудников Тогда 
		ПараметрыОбъектаЗадача.Вставить("Исполнитель"				, СтрокаПланДействий.Адресат);
	ИначеЕсли СтрокаПланДействий.ВидАдресата = Перечисления.ВидыАдресатов.ВрачПриема Тогда 
		ПараметрыОбъектаЗадача.Вставить("Исполнитель"				, ДанныеОбъекта.Сотрудник);
	ИначеЕсли СтрокаПланДействий.ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда 
		Если ЗначениеЗаполнено(ДанныеОбъекта.Контрагент) Тогда
			Менеджер = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДанныеОбъекта.Контрагент, "Куратор");
			Если ЗначениеЗаполнено(Менеджер) Тогда 
				ПараметрыОбъектаЗадача.Вставить("Исполнитель"		, Менеджер);
			КонецЕсли;
		КонецЕсли;
		Если НЕ ПараметрыОбъектаЗадача.Свойство("Исполнитель") Тогда 
			ПараметрыОбъектаЗадача.Вставить("Исполнитель"			, СтрокаПланДействий.Адресат);
		КонецЕсли;
	КонецЕсли;
	ПараметрыОбъектаЗадача.Вставить("ВидВзаимодействияСправочник"	, СтрокаПланДействий.ЗадачаВидВзаимодействия);	
	ПараметрыОбъектаЗадача.Вставить("ВидВзаимодействия"				, ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаПланДействий.ЗадачаВидВзаимодействия, "ВидВзаимодействия"));		
	ПараметрыОбъектаЗадача.Вставить("Контрагент"					, ДанныеОбъекта.Контрагент);
	ПараметрыОбъектаЗадача.Вставить("ЗадачаПредмет"					, ДанныеОбъекта.ОбъектСобытия);			
	ПараметрыОбъектаЗадача.Вставить("ЗадачаТема"					, СтрокаПланДействий.Наименование);		
	ПараметрыОбъектаЗадача.Вставить("Наименование"					, ПараметрыОбъектаЗадача.ЗадачаТема + " (" + Строка(ПараметрыОбъектаЗадача.ВидВзаимодействияСправочник) + ")");			
	ПараметрыОбъектаЗадача.Вставить("ЗадачаОписание"				, ИнициализироватьСодержаниеСПараметрами(СтрокаПланДействий.ЗадачаОписание, СтрокаПланДействий, ДанныеОбъекта));
	ПараметрыОбъектаЗадача.Вставить("ЗадачаРежимНапоминания"		, СтрокаПланДействий.ЗадачаРежимНапоминания);	
	
	СтрокаВремяРаботы = ТаблицаВремениРаботыСтруктурнойЕдиницы.Найти(ДанныеОбъекта.СтруктурнаяЕдиница, "СтруктурнаяЕдиница");
	Если СтрокаВремяРаботы = Неопределено ИЛИ (СтрокаВремяРаботы.НачалоРаботы = Дата(1,1,1) И СтрокаВремяРаботы.ОкончаниеРаботы = Дата(1,1,1)) Тогда 
		ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДатаНачало"	, НачалоДня(ТекущаяДатаСеанса()) + (Час(ДанныеТриггера.ВремяСобытия)*60*60) + (Минута(ДанныеТриггера.ВремяСобытия)*60));
		ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДата"			, КонецДня(ПараметрыОбъектаЗадача.ЗадачаНазначеннаяДатаНачало + (?(СтрокаПланДействий.ЗадачаПериодВыполнения < 1, 1, СтрокаПланДействий.ЗадачаПериодВыполнения) - 1) * 24 * 60 * 60));	
	Иначе 
		Если СтрокаВремяРаботы.НачалоРаботы >= Дата(1,1,1) + (Час(ДанныеТриггера.ВремяСобытия)*60*60) + (Минута(ДанныеТриггера.ВремяСобытия)*60) Тогда 
			ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДатаНачало"	, НачалоДня(ТекущаяДатаСеанса()) + (Час(СтрокаВремяРаботы.НачалоРаботы)*60*60) + (Минута(СтрокаВремяРаботы.НачалоРаботы)*60));
		// ИначеЕсли СтрокаВремяРаботы.ОкончаниеРаботы <= Дата(1,1,1) + (Час(ДанныеТриггера.ВремяСобытия)*60*60) + (Минута(ДанныеТриггера.ВремяСобытия)*60) Тогда
		//	ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДатаНачало"	, НачалоДня(ТекущаяДатаСеанса()) + (Час(СтрокаВремяРаботы.ОкончаниеРаботы)*60*60) + (Минута(СтрокаВремяРаботы.ОкончаниеРаботы)*60));
		Иначе 	
			ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДатаНачало"	, НачалоДня(ТекущаяДатаСеанса()) + (Час(ДанныеТриггера.ВремяСобытия)*60*60) + (Минута(ДанныеТриггера.ВремяСобытия)*60));
		КонецЕсли;
		Если СтрокаВремяРаботы.ОкончаниеРаботы <= КонецДня(Дата(1,1,1) + (?(СтрокаПланДействий.ЗадачаПериодВыполнения < 1, 1, СтрокаПланДействий.ЗадачаПериодВыполнения) - 1) * 24 * 60 * 60) Тогда 
			ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДата"			, НачалоДня(ТекущаяДатаСеанса()) + ((?(СтрокаПланДействий.ЗадачаПериодВыполнения < 1, 1, СтрокаПланДействий.ЗадачаПериодВыполнения) - 1) * 24 * 60 * 60) + (Час(СтрокаВремяРаботы.ОкончаниеРаботы)*60*60) + (Минута(СтрокаВремяРаботы.ОкончаниеРаботы)*60));
		Иначе 
			ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДата"			, КонецДня(ПараметрыОбъектаЗадача.ЗадачаНазначеннаяДатаНачало + (?(СтрокаПланДействий.ЗадачаПериодВыполнения < 1, 1, СтрокаПланДействий.ЗадачаПериодВыполнения) - 1) * 24 * 60 * 60));	
		КонецЕсли;
		Если НачалоДня(ПараметрыОбъектаЗадача.ЗадачаНазначеннаяДатаНачало) = НачалоДня(ПараметрыОбъектаЗадача.ЗадачаНазначеннаяДата) И ПараметрыОбъектаЗадача.ЗадачаНазначеннаяДата - ПараметрыОбъектаЗадача.ЗадачаНазначеннаяДатаНачало = СтрокаВремяРаботы.ОкончаниеРаботы - СтрокаВремяРаботы.НачалоРаботы Тогда  	
			ПараметрыОбъектаЗадача.Вставить("ЗадачаНазначеннаяДата"			, НачалоДня(ТекущаяДатаСеанса()));
			ПараметрыОбъектаЗадача.Удалить("ЗадачаНазначеннаяДатаНачало");
		КонецЕсли;	
	КонецЕсли;	
	ПараметрыОбъектаЗадача.Вставить("ПараметрЖурналаРегистрации"	, "Взаимодействие." + ДанныеТриггера.Наименование);	
	ПараметрыОбъектаЗадача.Вставить("ДанныеТриггера"				, ДанныеТриггера);	
	ПараметрыОбъектаЗадача.Вставить("ДанныеОбъекта"					, ДанныеОбъекта);
	ПараметрыОбъектаЗадача.Вставить("ДанныеДействия"				, СтрокаПланДействий);	
	ПараметрыОбъектаЗадача.Вставить("ПараметрыРегистрацииТриггера"	, СформироватьПараметрыРегистрацииТриггерногоСобытия(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра, ПараметрыОбъектаЗадача));	
	
	Возврат ПараметрыОбъектаЗадача;
	
КонецФункции	

// Функция - Инициализировать параметры объекта сделка
//
// Параметры:
//  ПараметрыОбъектаДействия - 	 - 
//  ДанныеТриггера			 - 	 - 
//  ДанныеОбъекта			 - 	 - 
//  СозданиеСделки			 - 	 - 
//  Период					 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьПараметрыОбъектаСделка(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра = Неопределено, СозданиеСделки = Ложь, Период)
	
	Если ОбщегоНазначенияПовтИсп.ЭтоСеансРегламентногоЗадания() Тогда 
		Пользователь = ОбщегоНазначенияПовтИсп.ПолучитьСлужебногоСотрудника();
	Иначе 
		Пользователь = ПараметрыСеанса.ТекущийСотрудник;
	КонецЕсли;
	
	ПараметрыОбъектаДействия = Новый Структура;
	ПараметрыОбъектаДействия.Вставить("Период"						, Период);
	ПараметрыОбъектаДействия.Вставить("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);		
	ПараметрыОбъектаДействия.Вставить("ВидСделки"					, СтрокаПланДействий.ВидСделки);
	ПараметрыОбъектаДействия.Вставить("ДатаСделки"					, ПараметрыОбъектаДействия.Период);
	ПараметрыОбъектаДействия.Вставить("Контрагент"					, ДанныеОбъекта.Контрагент);
	Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПланЛеченияСозданиеПланаЛечения Тогда 
		ПараметрыОбъектаДействия.Вставить("ПланЛечения"				, ДанныеОбъекта.ПланЛечения);
		ПараметрыОбъектаДействия.Вставить("Врач"					, ДанныеОбъекта.Сотрудник);
	КонецЕсли;	
	Если СтрокаПланДействий.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда 
		ПараметрыОбъектаДействия.Вставить("Реализация"				, ДанныеОбъекта.ОбъектСобытия);
		ПараметрыОбъектаДействия.Вставить("РезультатСделки"			, Перечисления.РезультатыСделок.Успех);
		ПараметрыОбъектаДействия.Вставить("ДатаЗавершенияСделки"	, ПараметрыОбъектаДействия.Период);
		ПараметрыОбъектаДействия.Вставить("СуммаДокумента"			, ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДанныеОбъекта.ОбъектСобытия, "СуммаДокумента"));
	ИначеЕсли СтрокаПланДействий.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
		// ПараметрыОбъектаДействия.Вставить("ПричинаОтказа"		, ДанныеТриггера.);
		ПараметрыОбъектаДействия.Вставить("РезультатСделки"			, Перечисления.РезультатыСделок.Отказ);
		ПараметрыОбъектаДействия.Вставить("ДатаЗавершенияСделки"	, ПараметрыОбъектаДействия.Период);			
	КонецЕсли;	
	Если ЗначениеЗаполнено(ДанныеОбъекта.СтруктурнаяЕдиница) Тогда 
		ПараметрыОбъектаДействия.Вставить("СтруктурнаяЕдиница"		, ДанныеОбъекта.СтруктурнаяЕдиница); 
	Иначе 
		ПараметрыОбъектаДействия.Вставить("СтруктурнаяЕдиница"		, Справочники.ВидыСделок.ПолучитьСтруктурнуюЕдиницуПримененияВидаСделки(СтрокаПланДействий.ВидСделки)); 
	КонецЕсли;	
	ПараметрыОбъектаДействия.Вставить("ЭтапСделки"					, СтрокаПланДействий.ЭтапСделки);
	ПараметрыОбъектаДействия.Вставить("Автор"						, Пользователь);
	ПараметрыОбъектаДействия.Вставить("Менеджер"					, ДанныеОбъекта.Контрагент.Куратор);
	ПараметрыОбъектаДействия.Вставить("Описание"					, "");	
	Если СозданиеСделки Тогда 
		ПараметрыОбъектаДействия.Вставить("Описание"				, "Сделка сгенерирована автоматически триггерным событием: " + СокрЛП(Строка(ДанныеТриггера.ТриггерноеСобытие)));
	ИначеЕсли СтрокаПланДействий.ЭтапСделки = Справочники.ЭтапыСделок.Успех ИЛИ СтрокаПланДействий.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
		ПараметрыОбъектаДействия.Вставить("Описание"				, "Сделка завершена автоматически триггерным событием: " + СокрЛП(Строка(ДанныеТриггера.ТриггерноеСобытие)));
	КонецЕсли;
	
	ПараметрыОбъектаДействия.Вставить("ПараметрЖурналаРегистрации"	, "Сделки." + ДанныеТриггера.Наименование);	
	ПараметрыОбъектаДействия.Вставить("ДанныеТриггера"				, ДанныеТриггера);	
	ПараметрыОбъектаДействия.Вставить("ДанныеОбъекта"				, ДанныеОбъекта);
	ПараметрыОбъектаДействия.Вставить("ДанныеДействия"				, СтрокаПланДействий);		
	ПараметрыОбъектаДействия.Вставить("ПараметрыРегистрацииТриггера", СформироватьПараметрыРегистрацииТриггерногоСобытия(ДанныеТриггера, ДанныеОбъекта, СтрокаПланДействий, СтрокаРеестра, ПараметрыОбъектаДействия));	
	
	Возврат ПараметрыОбъектаДействия;
	
КонецФункции	

// Функция - Сформировать параметры регистрации триггерного события
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  ДанныеОбъекта			 - 	 - 
//  ПараметрыОбъектаЗадача	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьПараметрыРегистрацииТриггерногоСобытия(ДанныеТриггера, ДанныеОбъекта = Неопределено, ДанныеДействия = Неопределено, СтрокаРеестра = Неопределено, ПараметрыГенерируемогоОбъекта)
	
	ПараметрыРегистрацииТриггера = Новый Структура();
	ПараметрыРегистрацииТриггера.Вставить("ОбъектГенерации"							, Неопределено);
	
	ПараметрыРегистрацииТриггера.Вставить("Период"									, ПараметрыГенерируемогоОбъекта.Период);
	ПараметрыРегистрацииТриггера.Вставить("ТриггерноеСобытие"						, ДанныеТриггера.ТриггерноеСобытие);
	ПараметрыРегистрацииТриггера.Вставить("Контрагент"								, Справочники.Контрагенты.ПустаяСсылка());
	ПараметрыРегистрацииТриггера.Вставить("ОбъектСобытия"							, Неопределено);
	ПараметрыРегистрацииТриггера.Вставить("ИсточникСобытия"							, Неопределено);			
	ПараметрыРегистрацииТриггера.Вставить("ИдентификаторДействия"					, ?(ДанныеДействия = Неопределено, Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"), ДанныеДействия.ИдентификаторДействия));
	ПараметрыРегистрацииТриггера.Вставить("РегистрацияПоПодписке"					, Ложь);	
	ПараметрыРегистрацииТриггера.Вставить("Описание"								, ?(ДанныеДействия = Неопределено, "", ДанныеДействия.Описание));
	ПараметрыРегистрацииТриггера.Вставить("Сообщение"								, ?(ДанныеДействия = Неопределено, "", ДанныеДействия.Сообщение));
	
	Если ДанныеОбъекта = Неопределено Тогда 
		ПараметрыРегистрацииТриггера.Вставить("Статус"								, Перечисления.СтатусыРегистрацииСобытий.Отклонено);
		ПараметрыРегистрацииТриггера.Вставить("РегистрацияЗапланированных"			, Ложь);				
	Иначе
		ПараметрыРегистрацииТриггера.Вставить("РегистрацияЗапланированных"			, ДанныеОбъекта.РегистрацияЗапланированных);		
		Если ДанныеОбъекта.РегистрацияЗапланированных Тогда 
			Если НЕ СтрокаРеестра = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(ПараметрыРегистрацииТриггера, СтрокаРеестра);
				ПараметрыРегистрацииТриггера.Вставить("Статус"						, Перечисления.СтатусыРегистрацииСобытий.Зарегистрировано);
			Иначе 	
				// МассивСтрокРеестра = ДанныеТриггера.РеестрЗапланированных.НайтиСтроки(Новый Структура("ТриггерноеСобытие, ОбъектСобытия, Контрагент, Подтверждено", ДанныеТриггера.ТриггерноеСобытие, ДанныеОбъекта.ОбъектСобытия, ДанныеОбъекта.Контрагент, Истина));
				// Если МассивСтрокРеестра.Количество() <> 0 Тогда
				//	ЗаполнитьЗначенияСвойств(ПараметрыРегистрацииТриггера, МассивСтрокРеестра[0]);					
				//	ПараметрыРегистрацииТриггера.Вставить("Статус"					, Перечисления.СтатусыРегистрацииСобытий.Зарегистрировано);
				// Иначе 
					ПараметрыРегистрацииТриггера = Неопределено;
				// КонецЕсли;
			КонецЕсли;
		Иначе 	
			ПараметрыРегистрацииТриггера.Вставить("Период"							, ПараметрыГенерируемогоОбъекта.Период);
			ПараметрыРегистрацииТриггера.Вставить("ТриггерноеСобытие"				, ДанныеТриггера.ТриггерноеСобытие);
			ПараметрыРегистрацииТриггера.Вставить("Контрагент"						, ДанныеОбъекта.Контрагент);
			ПараметрыРегистрацииТриггера.Вставить("ОбъектСобытия"					, ДанныеОбъекта.ОбъектСобытия);
			Если ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияВыписаноНаправление ИЛИ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияПрофосмотр Тогда
				ПараметрыРегистрацииТриггера.Вставить("ИсточникСобытия"				, ДанныеОбъекта.ИсточникСобытия);
			КонецЕсли;				
			ПараметрыРегистрацииТриггера.Вставить("ИдентификаторДействия"			, ДанныеДействия.ИдентификаторДействия);
			ПараметрыРегистрацииТриггера.Вставить("РегистрацияПоПодписке"			, ДанныеОбъекта.РегистрацияПоПодписке);
			ПараметрыРегистрацииТриггера.Вставить("Статус"							, Перечисления.СтатусыРегистрацииСобытий.Зарегистрировано);
		КонецЕсли;
	КонецЕсли;

	Возврат ПараметрыРегистрацииТриггера;
	
КонецФункции

// Процедура - Выполнить отправку SMS
//
// Параметры:
//  ПараметрыSMSОбъекта	 - 	 - 
//
Процедура ВыполнитьОтправкуСообщений(ПараметрыSMSОбъекта)
	
	Если ПараметрыSMSОбъекта.ПараметрыРегистрацииТриггера = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ДокументРассылки 							= Документы.РассылкаСообщений.СоздатьДокумент();
	ЗаполнитьЗначенияСвойств(ДокументРассылки, ПараметрыSMSОбъекта);
	ДокументРассылки.Дата 						= ПараметрыSMSОбъекта.Период;
	
	ЭтоПуш 			= Ложь;
	ЭтоМессенджер 	= Ложь;
	Для Каждого СтрокаКонтакт Из ПараметрыSMSОбъекта.ТаблицаКонтактов Цикл
		Если ДокументРассылки.Получатели.НайтиСтроки(Новый Структура("Получатель, НомерТелефона", СтрокаКонтакт.Получатель, СтрокаКонтакт.НомерТелефона)).Количество() = 0 Тогда 
			НоваяСтрока 						= ДокументРассылки.Получатели.Добавить();
			НоваяСтрока.Получатель 				= СтрокаКонтакт.Получатель;
			НоваяСтрока.НомерТелефона 			= СтрокаКонтакт.НомерТелефона;
			Если НЕ ЗначениеЗаполнено(ПараметрыSMSОбъекта.СервисSMSРассылки) И ЗначениеЗаполнено(СтрокаКонтакт.СервисРассылки) Тогда 
				ПараметрыSMSОбъекта.СервисSMSРассылки = СтрокаКонтакт.СервисРассылки;
			КонецЕсли;	
			НоваяСтрока.СервисРассылки 			= СтрокаКонтакт.СервисРассылки; // ПараметрыSMSОбъекта.СервисSMSРассылки;
			Если ЗначениеЗаполнено(НоваяСтрока.СервисРассылки) И ТипЗнч(НоваяСтрока.СервисРассылки) = Тип("СправочникСсылка.ВнешниеСистемы") Тогда 
				ТипВнешнейСистемы 	= ОбщегоНазначения.ПолучитьЗначениеРеквизита(НоваяСтрока.СервисРассылки, "ТипВнешнейСистемы");
				Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi ИЛИ ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда 
					ЭтоМессенджер 	= Истина;
				ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet Тогда
					ЭтоПуш 			= Истина;
				КонецЕсли;	
			КонецЕсли;	
			Если ЗначениеЗаполнено(СтрокаКонтакт.КаналСистемыСообщений) Тогда 
				НоваяСтрока.ИдКанала			= СтрокаКонтакт.КаналСистемыСообщений;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	ДокументРассылки.СервисSMSРассылки 			= ПараметрыSMSОбъекта.СервисSMSРассылки;
	
	Если ЭтоПуш Тогда
		ДокументРассылки.Тип 					= Перечисления.ТипыСобытий.ПушУведомление;		
		Если ЗначениеЗаполнено(СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеPush)) Тогда
			СодержаниеСообщения 				= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеPush);
		ИначеЕсли ЗначениеЗаполнено(СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеМессенджер)) Тогда
			СодержаниеСообщения 				= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеМессенджер);// СтруктураСодержания.СодержаниеМессенджерHTML;//;
		Иначе 
			СодержаниеСообщения 				= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.Содержание);
		КонецЕсли;	
		ДокументРассылки.Содержание 			= ИнициализироватьСодержаниеСПараметрами(СодержаниеСообщения, ПараметрыSMSОбъекта.ДанныеДействия, ПараметрыSMSОбъекта.ДанныеОбъекта);
	ИначеЕсли ЭтоМессенджер Тогда
		ДокументРассылки.Тип 					= Перечисления.ТипыСобытий.Мессенджер;				
		Если ЗначениеЗаполнено(СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеМессенджер)) Тогда
			СодержаниеСообщения 				= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеМессенджер);
		ИначеЕсли ЗначениеЗаполнено(СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеPush)) Тогда
			СодержаниеСообщения 				= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.СодержаниеPush);// СтруктураСодержания.СодержаниеМессенджерHTML;//;
		Иначе 
			СодержаниеСообщения 				= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.Содержание);
		КонецЕсли;	
		ДокументРассылки.Содержание 			= ИнициализироватьСодержаниеСПараметрами(СодержаниеСообщения, ПараметрыSMSОбъекта.ДанныеДействия, ПараметрыSMSОбъекта.ДанныеОбъекта);
	Иначе 
		СодержаниеСообщения 					= СокрЛП(ПараметрыSMSОбъекта.ДанныеДействия.Содержание);
		ДокументРассылки.Содержание 			= ИнициализироватьСодержаниеСПараметрами(СодержаниеСообщения, ПараметрыSMSОбъекта.ДанныеДействия, ПараметрыSMSОбъекта.ДанныеОбъекта);		
	КонецЕсли;	
	
	ДокументРассылки.ШаблонСообщения 			= ПараметрыSMSОбъекта.ДанныеДействия.ШаблонСообщения;
	
	Если ДокументРассылки.Получатели.Количество() = 1 Тогда 
		ДокументРассылки.ВидОперации 			= Перечисления.ВидОперацииОтправкаSMS.ОтправкаSMSПолучателю;
	Иначе
		ДокументРассылки.ВидОперации 			= Перечисления.ВидОперацииОтправкаSMS.МассоваяРассылкаSMS;
	КонецЕсли;
	
	ДокументРассылки.ДополнительныеСвойства.Вставить("ПараметрыРегистрацииТриггера", ПараметрыSMSОбъекта.ПараметрыРегистрацииТриггера);
	Попытка
		ДокументРассылки.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ДокументРассылки.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;
		
КонецПроцедуры

