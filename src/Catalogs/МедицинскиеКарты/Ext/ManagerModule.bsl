// ПРОЦЕДУРЫ И ФУНКЦИИ ФОРМИРОВАНИЯ ПЕЧАТНЫХ ФОРМ

// Функция заполняет макет Медицинская карта по переданному пациенту
//
//  Параметры:
// 		Пациент			- Контрагенты, пациент, на которого сформировать мед.карту
//
Функция СформироватьПечатнуюФормуМедКарты(МассивОбъектов, ОбъектыПечати, ПараметрыПечати) Экспорт
	
	ТабличныйДокумент = Неопределено;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_А4 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
		ИначеЕсли ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_А5 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
		ИначеЕсли ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А4 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_СССР_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
		ИначеЕсли ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А5 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_СССР_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
		ИначеЕсли ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.МедицинскаяКарта_025У_04_А4 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуМедицинскаяКарта_025У_04_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
		ИначеЕсли ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.МедицинскаяКарта_025У_04_А5 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуМедицинскаяКарта_025У_04_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);			
		ИначеЕсли ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.МедицинскаяКарта_025У_14 Тогда
			ТабличныйДокументКарты = СформироватьПечатнуюФормуМедицинскаяКарта_025У_14(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
		// ИначеЕсли ТекущийОбъект.
		КонецЕсли;
		
		Если ТипЗнч(ТабличныйДокумент) = Тип("ТабличныйДокумент") Тогда
			ТабличныйДокумент.Присоединить(ТабличныйДокументКарты);
		Иначе
			ТабличныйДокумент = ТабличныйДокументКарты;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТабличныйДокумент <> Неопределено Тогда 
		ТабличныйДокумент.АвтоМасштаб = Истина;
	КонецЕсли;
	
	Возврат ТабличныйДокумент; 
	
КонецФункции 

// Функция заполняет макет вкладыш мед карты для страховой
//
Функция СформироватьПечатныеФормыВкладышейМедКартДляСтраховой(МассивОбъектов, ОбъектыПечати, ПараметрыПечати) Экспорт
	
	ТабличныйДокумент = Неопределено;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_А4
			ИЛИ ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_СССР_А4  
			ИЛИ ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.МедицинскаяКарта_025У_04_А4
			ИЛИ ТекущийОбъект.ВидМедицинскойКарты.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.МедицинскаяКарта_025У_14 Тогда 
			ФорматПечати = "A4";
		Иначе
			ФорматПечати = "A5";
		КонецЕсли;
		ТабличныйДокументКарты = СформироватьПечатнуюФормуВкладышаМедКартыДляСтраховой(МассивОбъектов, ОбъектыПечати, ПараметрыПечати, ФорматПечати);
		
		Если ТипЗнч(ТабличныйДокумент) = Тип("ТабличныйДокумент") Тогда
			ТабличныйДокумент.Присоединить(ТабличныйДокументКарты);
		Иначе
			ТабличныйДокумент = ТабличныйДокументКарты;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТабличныйДокумент <> Неопределено Тогда 
		ТабличныйДокумент.АвтоМасштаб = Истина;
	КонецЕсли;
	
	Возврат ТабличныйДокумент; 
	
КонецФункции

// Функция заполняет макет Медицинская карта по переданному пациенту
//
//  Параметры:
// 		Пациент			- Контрагенты, пациент, на которого сформировать мед.карту
//
Функция СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено) Экспорт
	
	ТабличныйДокумент                      = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АмбулаторнаяКарта_043_У_A4";
	ТабличныйДокумент.РазмерСтраницы       = "A4";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент    = Ложь;	
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДокументПрием.Дата,
		|	ДокументПрием.Ссылка,
		|	ДокументПрием.РезультатПриема,
		|	ДокументПрием.Контрагент,
		|	ДокументПрием.Сотрудник
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ВключаяНеПроведенные
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
		|		КОНЕЦ
		|	И ДокументПрием.Контрагент = &Пациент
		|	И ДокументПрием.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументПрием.Дата";
		
		ВладелецКарты = ТекущийОбъект.ВладелецКарты; 
		
		ПечатьВкладыша = Ложь;
		ПечататьМедКарту = Ложь;		
		Если ТипЗнч(ПараметрыПечати) = Тип("Структура") Тогда
			ПечатьВкладыша = ПараметрыПечати.Свойство("ПечатьВкладыша");				
			ПечатьМедКарты = ПараметрыПечати.Свойство("ПечатьМедКарты");
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ВключаяНеПроведенные", ПечатьВкладыша);
		Запрос.УстановитьПараметр("Пациент"             , ВладелецКарты);		
		
		Если ПечатьВкладыша Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив"), ПараметрыПечати.ПечатьВкладыша, Неопределено);
		ИначеЕсли ПечатьМедКарты Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьМедКарты) = Тип("Массив"), ПараметрыПечати.ПечатьМедКарты, Неопределено);
		Иначе	
			МассивПриемов = Неопределено;	
		КонецЕсли;
		МассивПриемов = ?(ЗначениеЗаполнено(МассивПриемов), МассивПриемов, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
		Макет = ПолучитьМакет("АмбулаторнаяКарта_043_У_А4");    
		
		ПечатьМедКарты = ПечатьМедКарты ИЛИ ПараметрыПечати.Свойство("ТитульныйЛист") ИЛИ НЕ ЗначениеЗаполнено(ПараметрыПечати);
		
		// Выводим данные первого приема
		Если ПечатьМедКарты Тогда	
			
			//==================================================================ПЕЧАТЬ 1-Й СТРАНИЦЫ===========================================================================
			ОбластьМакета                                 = Макет.ПолучитьОбласть("Стр1");
			Организация                                   = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
			ОрганизацияАдрес                              = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы, "Вид");
			ОрганизацияАдресПредставление                 = ?(ОрганизацияАдрес  = Неопределено, "", ОрганизацияАдрес.Представление);
			Телефон                                       = ВладелецКарты.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, "Вид");
			ТелефонПредставление                          = ?(Телефон  = Неопределено, "", Телефон.Представление);
			ЭлектроннаяПочтаКлиента                       = ВладелецКарты.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.EmailКлиента, "Вид");
			ЭлектроннаяПочтаПредставление                 = ?(ЭлектроннаяПочтаКлиента  = Неопределено, "", ЭлектроннаяПочтаКлиента.Представление);
			
			ЗаполнитьПараметрПосимвольно(ОбластьМакета,"ОГРН", Организация.ОГРН);
			ОбластьМакета.Параметры.Организация           = Организация;	
			ОбластьМакета.Параметры.ОрганизацияАдрес      = ОрганизацияАдресПредставление;		
			ОбластьМакета.Параметры.КодПоОКПО             = Организация.КодПоОКПО;
			ОбластьМакета.Параметры.НомерКарты            = ТекущийОбъект.КодБезНулей;
			ОбластьМакета.Параметры.ТекДата               = Формат(ТекущаяДата(), "ДЛФ=DD");
			ОбластьМакета.Параметры.ФИОКлиента            = ВладелецКарты.Наименование;
			ОбластьМакета.Параметры.Ж                     = ?(ВладелецКарты.ПолКлиента = Перечисления.ПолФизическогоЛица.Женский, "v", "");
			ОбластьМакета.Параметры.М                     = ?(ВладелецКарты.ПолКлиента = Перечисления.ПолФизическогоЛица.Мужской, "v", "");			
			
			Если ЗначениеЗаполнено(ВладелецКарты.ДатаРожденияКлиента) Тогда 
				ДатаРождения = ВладелецКарты.ДатаРожденияКлиента;
				ОбластьМакета.Параметры.Г 		= Формат(ДатаРождения, "ДФ=гггг") ;
				ОбластьМакета.Параметры.Месяц 	= Формат(ДатаРождения, "ДФ=ММММ");
				ОбластьМакета.Параметры.Д 		= Формат(ДатаРождения, "ДФ=д");
			КонецЕсли;
			
			ОбластьМакета.Параметры.Телефон               = ТелефонПредставление;
			ОбластьМакета.Параметры.ЭлектроннаяПочта      = ЭлектроннаяПочтаПредставление;
			
			// Адрес
			ТабЗн = ВладелецКарты.КонтактнаяИнформация.Выгрузить();
			НайденныеСтроки = ТабЗн.НайтиСтроки(Новый Структура("Тип,Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.АдресКлиента));
			Если НайденныеСтроки.Количество() > 0 Тогда
				СтруктураАдрес = НайденныеСтроки[0];
			Иначе
				НайденныеСтроки = ТабЗн.НайтиСтроки(Новый Структура("Тип,Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента));
				Если НайденныеСтроки.Количество() > 0 Тогда
					СтруктураАдрес = НайденныеСтроки[0];
				Иначе
					СтруктураАдрес = Неопределено;
				КонецЕсли;	
			КонецЕсли;
			
			Если СтруктураАдрес <> Неопределено Тогда
				ОбластьМакета.Параметры.МестоРегистрацииРегион = СтруктураАдрес.Регион;
				ОбластьМакета.Параметры.МестоРегистрацииГород  = СтруктураАдрес.Город;
				
				СтруктураПолейАдрес = РаботаСАдресами.КонтактнаяИнформацияВСтруктуруJSON(СтруктураАдрес.ЗначенияПолей, СтруктураАдрес.Тип, СтруктураАдрес.Представление);  
				
				ОбластьМакета.Параметры.МестоРегистрацииГород = ?(ЗначениеЗаполнено(СтруктураПолейАдрес.cityType), СтруктураПолейАдрес.cityType + ". ", "") + СтруктураПолейАдрес.city;
				ОбластьМакета.Параметры.МестоРегистрацииНасПункт = СтруктураПолейАдрес.locality;
				ОбластьМакета.Параметры.МестоРегистрацииУлица = СтруктураПолейАдрес.street;
				ОбластьМакета.Параметры.МестоРегистрацииДом = СтруктураПолейАдрес.houseNumber;
				
				Если СтруктураПолейАдрес.buildings.Количество() > 0 Тогда
					ОбластьМакета.Параметры.МестоРегистрацииКорпус = СтруктураПолейАдрес.buildings[0].number;
				КонецЕсли;
				
				Если СтруктураПолейАдрес.apartments.Количество() > 0 Тогда
					ОбластьМакета.Параметры.МестоРегистрацииКвартира = СтруктураПолейАдрес.apartments[0].number;
				КонецЕсли;
				
			КонецЕсли;
			
			// 6. Документ, удостоверяющий личность
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Физлицо", ВладелецКарты);
			Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ДокументыФизическихЛиц.ВидДокумента,
			|	ДокументыФизическихЛиц.Серия,
			|	ДокументыФизическихЛиц.Номер,
			|	ДокументыФизическихЛиц.ДатаВыдачи,
			|	ДокументыФизическихЛиц.КемВыдан
			|ИЗ
			|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
			|ГДЕ
			|	ДокументыФизическихЛиц.Физлицо = &Физлицо";
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				ОбластьМакета.Параметры.ДокументВид   = Выборка.ВидДокумента;
				ОбластьМакета.Параметры.ДокументСерия = Выборка.Серия;
				ОбластьМакета.Параметры.ДокументНомер = Выборка.Номер;
				ОбластьМакета.Параметры.ДатаВыдачи    = Формат(Выборка.ДатаВыдачи, "ДФ=dd.MM.yyyy");
				ОбластьМакета.Параметры.КемВыдан      = Выборка.КемВыдан;
			КонецЕсли;
			
			// 7. Страховая организация
			МассивПолисыСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ОбязательноеМедицинскоеСтрахование);			
			Если МассивПолисыСтрахования.Количество() > 0 Тогда
				ОбластьМакета.Параметры.ОМССтраховщик  = МассивПолисыСтрахования[0].СтраховаяКомпания.Наименование;
				ОбластьМакета.Параметры.ОМСНомерПолиса = МассивПолисыСтрахования[0].НомерПолиса;
				ОбластьМакета.Параметры.ОМССерияПолиса = МассивПолисыСтрахования[0].СерияПолиса;
			КонецЕсли;
			МассивПолисыСтрахованияДобровольное = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ДобровольноеМедицинскоеСтрахование);			
			Если МассивПолисыСтрахованияДобровольное.Количество() > 0 Тогда
				ОбластьМакета.Параметры.ОМСНомерПолисаДобровольное = МассивПолисыСтрахованияДобровольное[0].НомерПолиса;
				ОбластьМакета.Параметры.ОМССерияПолисаДобровольное = МассивПолисыСтрахованияДобровольное[0].СерияПолиса;
			КонецЕсли;
			
			ТаблицаОбследований = Неопределено;
			Если ЗначениеЗаполнено(МассивПриемов) Тогда
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,, МассивПриемов);	
			КонецЕсли;
			
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("Жалобы, ПеренесенныеИСопутствующиеЗаболевания, РазвитиеНастоящегоЗаболевания, Анамнез, СостояниеСлизистойОболочкиПолостиРта, ДанныеОбъективногоИсследования, ПринимаемыеЛекарственныеПрепараты, ТермометрияПоПоказаниям, ТонометрияЧСС", "92.5,100,100", "65,100,100", "72.5,100,100", "72.5,100,100", "60,100,100,100,100,100", "92.5,100,100,100,100,100", "60,100,100", "60", "60");
			Если ТаблицаОбследований <> Неопределено И ТаблицаОбследований.Количество() > 0 Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 2-Й СТРАНИЦЫ===========================================================================
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ОбластьМакета = Макет.ПолучитьОбласть("Стр2");
			Запрос        = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ЗубнаяФормулаСрезПоследних.Зуб,
			|	ВЫБОР
			|		КОГДА ЗубнаяФормулаСрезПоследних.Область = ЗНАЧЕНИЕ(Перечисление.ОбластиЗубнойФормулы.ПустаяСсылка)
			|			ТОГДА 0
			|		ИНАЧЕ 1
			|	КОНЕЦ КАК ТипСостояния,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗуба
			|ИЗ
			|	РегистрСведений.ЗубнаяФормула.СрезПоследних КАК ЗубнаяФормулаСрезПоследних
			|ГДЕ
			|	ЗубнаяФормулаСрезПоследних.Контрагент = &Контрагент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Наименование";
			Запрос.УстановитьПараметр("Контрагент", ?(МассивПриемов.Количество() > 0, ВладелецКарты, ""));
			СостояниеЗубов            = Запрос.Выполнить().Выгрузить();
			СтруктураЗначенийРесурсов = Новый Структура;
			ТипЗубнФормулы            = ?(МассивПриемов.Количество() > 0, МассивПриемов[0].Контрагент.ТипЗубнойФормулы, 2);
			Если ТипЗубнФормулы = 1 Тогда
				Начало = 33;
				КолЗубов = 52;				
			Иначе
				Начало = 1;
				КолЗубов = 32;				
			КонецЕсли;
			
			Для ЗначениеНомерЗуба = Начало По КолЗубов Цикл
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 0));
				Если СтрокаСостояниеЗубаОсн.Количество() > 0 Тогда
					Если СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Удален Тогда
						УслОбозоначениеСостояниеЗуба = "О";
					ИначеЕсли СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Абатмент Тогда
						УслОбозоначениеСостояниеЗуба = "И";
					Иначе
						Продолжить;
					КонецЕсли;
					СтруктураЗначенийРесурсов.Вставить("СостОсн_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УслОбозоначениеСостояниеЗуба);
				КонецЕсли;
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 1));
				УсловныеОбозначенияСостоянияЗуба = "";
				Для Каждого СостояниеЗуба Из СтрокаСостояниеЗубаОсн Цикл 
					Если ЗначениеЗаполнено(СтрокаСостояниеЗубаОсн[0].СостояниеЗубнойФормулы.УсловноеОбозначение) Тогда
						Если ЗначениеЗаполнено(УсловныеОбозначенияСостоянияЗуба) Тогда 
							УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + ",";
						КонецЕсли;
						УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + СостояниеЗуба.СостояниеЗубнойФормулы.УсловноеОбозначение;
					КонецЕсли;
				КонецЦикла;	
				СтруктураЗначенийРесурсов.Вставить("СостВсп_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УсловныеОбозначенияСостоянияЗуба);
			КонецЦикла;
			ОбластьМакета.Параметры.Заполнить(СтруктураЗначенийРесурсов);
			
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("Прикус, ДанныеРентгеновскихЛабораторныхИсследований, Диагноз, ПланЛечения, ИндексГигиены, ИндексКПУ, КодМКБ10, ПланОбследования, КлиническийДиагноз, ПротоколЛечения", "92.5", "60,100,100,100,100,100,100,100", "85,100", "92.5,100,100,100,100,100,100", "92.5", "92.5", "25" , "60,100,100,100,100", "92.5,100", "92.5,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЕсли;
		
		//==================================================================ПЕЧАТЬ 4-Й СТРАНИЦЫ===========================================================================
		// Вывод данных дневника обследований
		Если ПечатьВкладыша Тогда	
			 			
			НомерВыведенныхСтрок = 0;
			КрайнийНомерСтраницы = 4;
			ПоследнийНомерСтраницы = 0; 
			
			Для Каждого СтрокаПриема Из МассивПриемов Цикл
				
				НомерВыведенныхСтрокПриема = 0;		
				
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, СтрокаПриема,, Истина);				
								
				ОбластьМакета = Макет.ПолучитьОбласть("Колонтитул");
				ОбластьМакета.Параметры.НомерСтраницы = КрайнийНомерСтраницы;
				ТабличныйДокумент.Вывести(ОбластьМакета);
				
				Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
					
					// Используются только реквизиты дневника
					Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
						Продолжить;
					КонецЕсли;	
					
					ТекстДанных             = СтрокаТ.РеквизитНаименование + ": " + СтрокаТ.РеквизитЗначение;				
					МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанных, 62.5);
					
					НомерВыведенныхСтрокРеквизита = 0;
					
					// Выводим массив текста
					Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл						 						
						Если НомерВыведенныхСтрок = 0 Или ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 25) / 25) = 0 Тогда
							Если НомерВыведенныхСтрок >= 25 Тогда				
								Если ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 25) / 25 / 2) <> 0 Тогда
									ОбластьМакета = Макет.ПолучитьОбласть("ПустаяСтрокаУдвоенногоПоля");
									ТабличныйДокумент.Вывести(ОбластьМакета);
								Иначе
									ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
								КонецЕсли;
								ОбластьМакета                         = Макет.ПолучитьОбласть("Колонтитул");
								ПоследнийНомерСтраницы = (КрайнийНомерСтраницы + (НомерВыведенныхСтрок - 25) / 25 + 1);
								ОбластьМакета.Параметры.НомерСтраницы = ПоследнийНомерСтраницы;
								ТабличныйДокумент.Вывести(ОбластьМакета);								
							КонецЕсли;
							ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
						НомерВыведенныхСтрок       = НомерВыведенныхСтрок + 1;
						НомерВыведенныхСтрокПриема = НомерВыведенныхСтрокПриема + 1;
						НомерВыведенныхСтрокРеквизита = НомерВыведенныхСтрокРеквизита + 1;
						
						ОбластьМакета                 = Макет.ПолучитьОбласть("СтрокаДневника");
						Если НомерВыведенныхСтрокПриема = 1 Тогда							
							ДанныеПриема = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаПриема, "Дата, Сотрудник");							
							ОбластьМакета.Параметры.Дата = Формат(ДанныеПриема.Дата, "ДЛФ=D");
							ОбластьМакета.Параметры.ЛечащийВрач = ДанныеПриема.Сотрудник;	
						ИначеЕсли НомерВыведенныхСтрокПриема = 2 Тогда
							ОбластьМакета.Параметры.ЛечащийВрач = "_____________(подпись)";
						КонецЕсли; 
						
						Если НомерВыведенныхСтрокРеквизита = 1 Тогда
							
							ТабличныйДокумент.Вывести(ОбластьМакета);
							РеквизитПредставление = СокрЛП(СтрокаТ.РеквизитНаименование) + ": ";
							ДлинаРеквизита = СтрДлина(РеквизитПредставление);
							
							НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
							
							// Подобрана средняя величина.
							ДелительДлины = ?(ДлинаРеквизита >= 15, 3, 4);
							КоличествоКолонокДляРеквизита = Окр((ДлинаРеквизита / ДелительДлины), 0, РежимОкругления.Окр15как20) + 5;								  
							
							ОбластьРеквизит = ТабличныйДокумент.Область(НомерСтроки, 5, НомерСтроки, КоличествоКолонокДляРеквизита);	
							ОбластьРеквизит.Объединить();             
							ОбластьРеквизит.Шрифт = Новый Шрифт("Arial", 8, Истина);
							ОбластьРеквизит.Текст = РеквизитПредставление;							 
							
							ОбластьТекст = ТабличныйДокумент.Область(НомерСтроки, КоличествоКолонокДляРеквизита+1, НомерСтроки, 29);
							ОбластьТекст.Объединить();
							ОбластьТекст.Шрифт = Новый Шрифт("Arial", 8, Ложь);
							ОбластьТекст.Текст = Сред(ТекстДанныхПоСтрокам, ДлинаРеквизита+1); 
							
						Иначе
							ОбластьМакета.Параметры.Текст = ТекстДанныхПоСтрокам;
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЦикла;
				
				// Дополняем пустыми строчками до конца листа
				Пока ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 25) / 25) <> 0 Цикл
					Если НомерВыведенныхСтрок = 0 Тогда
						ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
						ТабличныйДокумент.Вывести(ОбластьМакета);
					КонецЕсли;
					ОбластьМакета = Макет.ПолучитьОбласть("СтрокаДневника");
					ТабличныйДокумент.Вывести(ОбластьМакета);
					НомерВыведенныхСтрок = НомерВыведенныхСтрок + 1;
				КонецЦикла;
								
				ПоследнийНомерСтраницы = ?(ПоследнийНомерСтраницы = 0 ИЛИ НЕ ЗначениеЗаполнено(ТаблицаОбследований), КрайнийНомерСтраницы - 1, ПоследнийНомерСтраницы); 
				ПоследнийНомерСтраницы = ПоследнийНомерСтраницы + ?(НомерВыведенныхСтрокПриема <= 25, 1, 0);	
				КрайнийНомерСтраницы = ПоследнийНомерСтраницы + 1; 
				НомерВыведенныхСтрок = 0;
				НомерВыведенныхСтрокПриема = 0;
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();

			КонецЦикла;
			
		КонецЕсли;				
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийОбъект.ВладелецКарты.Ссылка);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;	
	Возврат ТабличныйДокумент; 
	
КонецФункции

// Функция заполняет макет Медицинская карта по переданному пациенту
//
//  Параметры:
// 		Пациент			- Контрагенты, пациент, на которого сформировать мед.карту
//
Функция СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено) Экспорт
	
	ТабличныйДокумент                      = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АмбулаторнаяКарта_043_У_A5";
	ТабличныйДокумент.РазмерСтраницы       = "A5";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент    = Ложь;	
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДокументПрием.Дата,
		|	ДокументПрием.Ссылка,
		|	ДокументПрием.РезультатПриема,
		|	ДокументПрием.Контрагент,
		|	ДокументПрием.Сотрудник
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ВключаяНеПроведенные
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
		|		КОНЕЦ
		|	И ДокументПрием.Контрагент = &Пациент
		|	И ДокументПрием.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументПрием.Дата";
		
		ВладелецКарты = ТекущийОбъект.ВладелецКарты; 
		
		ПечатьВкладыша = Ложь;
		ПечататьМедКарту = Ложь;		
		Если ТипЗнч(ПараметрыПечати) = Тип("Структура") Тогда
			ПечатьВкладыша = ПараметрыПечати.Свойство("ПечатьВкладыша");				
			ПечатьМедКарты = ПараметрыПечати.Свойство("ПечатьМедКарты");
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ВключаяНеПроведенные", ПечатьВкладыша);
		Запрос.УстановитьПараметр("Пациент"             , ВладелецКарты);		
		
		Если ПечатьВкладыша Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив"), ПараметрыПечати.ПечатьВкладыша, Неопределено);
		ИначеЕсли ПечатьМедКарты Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьМедКарты) = Тип("Массив"), ПараметрыПечати.ПечатьМедКарты, Неопределено);
		Иначе	
			МассивПриемов = Неопределено;	
		КонецЕсли;
		МассивПриемов = ?(ЗначениеЗаполнено(МассивПриемов), МассивПриемов, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));

		Макет = ПолучитьМакет("АмбулаторнаяКарта_043_У_А5");
		
		ПечатьМедКарты = ПечатьМедКарты ИЛИ ПараметрыПечати.Свойство("ТитульныйЛист") ИЛИ НЕ ЗначениеЗаполнено(ПараметрыПечати);
		
		// Выводим данные первого приема
		Если ПечатьМедКарты Тогда
			
			//==================================================================ПЕЧАТЬ 1-Й СТРАНИЦЫ===========================================================================
			ОбластьМакета                                 = Макет.ПолучитьОбласть("Стр1");
			Организация                                   = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
			ОрганизацияАдрес                              = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы, "Вид");
			ОрганизацияАдресПредставление                 = ?(ОрганизацияАдрес  = Неопределено, "", ОрганизацияАдрес.Представление);
			Телефон                                       = ВладелецКарты.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, "Вид");
			ТелефонПредставление                          = ?(Телефон  = Неопределено, "", Телефон.Представление);
			ЭлектроннаяПочтаКлиента                       = ВладелецКарты.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.EmailКлиента, "Вид");
			ЭлектроннаяПочтаПредставление                 = ?(ЭлектроннаяПочтаКлиента  = Неопределено, "", ЭлектроннаяПочтаКлиента.Представление);
			
			ЗаполнитьПараметрПосимвольно(ОбластьМакета,"ОГРН", Организация.ОГРН);
			ОбластьМакета.Параметры.Организация           = Организация;	
			ОбластьМакета.Параметры.ОрганизацияАдрес      = ОрганизацияАдресПредставление;		
			ОбластьМакета.Параметры.КодПоОКПО             = Организация.КодПоОКПО;
			ОбластьМакета.Параметры.НомерКарты            = ТекущийОбъект.КодБезНулей;
			ОбластьМакета.Параметры.ТекДата               = Формат(ТекущаяДата(), "ДЛФ=DD");
			ОбластьМакета.Параметры.ФИОКлиента            = ВладелецКарты.Наименование;
			ОбластьМакета.Параметры.Ж                     = ?(ВладелецКарты.ПолКлиента = Перечисления.ПолФизическогоЛица.Женский, "v", "");
			ОбластьМакета.Параметры.М                     = ?(ВладелецКарты.ПолКлиента = Перечисления.ПолФизическогоЛица.Мужской, "v", "");			
			
			Если ЗначениеЗаполнено(ВладелецКарты.ДатаРожденияКлиента) Тогда 
				ДатаРождения = ВладелецКарты.ДатаРожденияКлиента;
				ОбластьМакета.Параметры.Г 		= Формат(ДатаРождения, "ДФ=гггг") ;
				ОбластьМакета.Параметры.Месяц 	= Формат(ДатаРождения, "ДФ=ММММ");
				ОбластьМакета.Параметры.Д 		= Формат(ДатаРождения, "ДФ=д");
			КонецЕсли;
			
			ОбластьМакета.Параметры.Телефон               = ТелефонПредставление;
			ОбластьМакета.Параметры.ЭлектроннаяПочта      = ЭлектроннаяПочтаПредставление;
			
			// Адрес
			ТабЗн = ВладелецКарты.КонтактнаяИнформация.Выгрузить();
			НайденныеСтроки = ТабЗн.НайтиСтроки(Новый Структура("Тип,Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.АдресКлиента));
			Если НайденныеСтроки.Количество() > 0 Тогда
				СтруктураАдрес = НайденныеСтроки[0];
			Иначе
				НайденныеСтроки = ТабЗн.НайтиСтроки(Новый Структура("Тип,Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента));
				Если НайденныеСтроки.Количество() > 0 Тогда
					СтруктураАдрес = НайденныеСтроки[0];
				Иначе
					СтруктураАдрес = Неопределено;
				КонецЕсли;	
			КонецЕсли;
			
			Если СтруктураАдрес <> Неопределено Тогда
				ОбластьМакета.Параметры.МестоРегистрацииРегион = СтруктураАдрес.Регион;
				ОбластьМакета.Параметры.МестоРегистрацииГород  = СтруктураАдрес.Город;
				
				СтруктураПолейАдрес = РаботаСАдресами.КонтактнаяИнформацияВСтруктуруJSON(СтруктураАдрес.ЗначенияПолей, СтруктураАдрес.Тип, СтруктураАдрес.Представление);  
				
				ОбластьМакета.Параметры.МестоРегистрацииГород = ?(ЗначениеЗаполнено(СтруктураПолейАдрес.cityType), СтруктураПолейАдрес.cityType + ". ", "") + СтруктураПолейАдрес.city;
				ОбластьМакета.Параметры.МестоРегистрацииНасПункт = СтруктураПолейАдрес.locality;
				ОбластьМакета.Параметры.МестоРегистрацииУлица = СтруктураПолейАдрес.street;
				ОбластьМакета.Параметры.МестоРегистрацииДом = СтруктураПолейАдрес.houseNumber;
				
				Если СтруктураПолейАдрес.buildings.Количество() > 0 Тогда
					ОбластьМакета.Параметры.МестоРегистрацииКорпус = СтруктураПолейАдрес.buildings[0].number;
				КонецЕсли;
				
				Если СтруктураПолейАдрес.apartments.Количество() > 0 Тогда
					ОбластьМакета.Параметры.МестоРегистрацииКвартира = СтруктураПолейАдрес.apartments[0].number;
				КонецЕсли;
				
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 2-Й СТРАНИЦЫ===========================================================================
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
			ОбластьМакета = Макет.ПолучитьОбласть("Стр2");
			// 6. Документ, удостоверяющий личность
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Физлицо", ВладелецКарты);
			Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ДокументыФизическихЛиц.ВидДокумента,
			|	ДокументыФизическихЛиц.Серия,
			|	ДокументыФизическихЛиц.Номер,
			|	ДокументыФизическихЛиц.ДатаВыдачи,
			|	ДокументыФизическихЛиц.КемВыдан
			|ИЗ
			|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
			|ГДЕ
			|	ДокументыФизическихЛиц.Физлицо = &Физлицо";
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				ОбластьМакета.Параметры.ДокументВид   = Выборка.ВидДокумента;
				ОбластьМакета.Параметры.ДокументСерия = Выборка.Серия;
				ОбластьМакета.Параметры.ДокументНомер = Выборка.Номер;
				ОбластьМакета.Параметры.ДатаВыдачи    = Формат(Выборка.ДатаВыдачи, "ДФ=dd.MM.yyyy");
				ОбластьМакета.Параметры.КемВыдан      = Выборка.КемВыдан;
			КонецЕсли;
			
			// 7. Страховая организация
			МассивПолисыСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ОбязательноеМедицинскоеСтрахование);			
			Если МассивПолисыСтрахования.Количество() > 0 Тогда
				ОбластьМакета.Параметры.ОМССтраховщик  = МассивПолисыСтрахования[0].СтраховаяКомпания.Наименование;
				ОбластьМакета.Параметры.ОМСНомерПолиса = МассивПолисыСтрахования[0].НомерПолиса;
				ОбластьМакета.Параметры.ОМССерияПолиса = МассивПолисыСтрахования[0].СерияПолиса;
			КонецЕсли;
			МассивПолисыСтрахованияДобровольное = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ДобровольноеМедицинскоеСтрахование);			
			Если МассивПолисыСтрахованияДобровольное.Количество() > 0 Тогда
				ОбластьМакета.Параметры.ОМСНомерПолисаДобровольное = МассивПолисыСтрахованияДобровольное[0].НомерПолиса;
				ОбластьМакета.Параметры.ОМССерияПолисаДобровольное = МассивПолисыСтрахованияДобровольное[0].СерияПолиса;
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 3-Й СТРАНИЦЫ===========================================================================
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ОбластьМакета = Макет.ПолучитьОбласть("Стр3");
			
			ТаблицаОбследований = Неопределено;
			Если МассивПриемов.Количество() > 0 Тогда
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, , МассивПриемов);	
			КонецЕсли;
			
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("Жалобы, ПеренесенныеИСопутствующиеЗаболевания, РазвитиеНастоящегоЗаболевания, Анамнез, ДанныеОбъективногоИсследования, ПринимаемыеЛекарственныеПрепараты, ТермометрияПоПоказаниям, ТонометрияЧСС", "92.5,100,100", "65,100,100", "72.5,100,100", "92.5,100,100", "60,100,100,100,100,100", "60,100,100", "60", "60");
			Если ТаблицаОбследований <> Неопределено И ТаблицаОбследований.Количество() > 0 Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("Стр4");
			//==================================================================ПЕЧАТЬ 4-Й СТРАНИЦЫ===========================================================================
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
			ПараметрыОбследования = Новый Структура("СостояниеСлизистойОболочкиПолостиРта, Прикус, Диагноз, ИндексГигиены, ИндексКПУ, КодМКБ10", "92.5,100,100", "92.5", "90,100", "92.5", "92.5", "20");
			Если ТаблицаОбследований <> Неопределено И ТаблицаОбследований.Количество() > 0 Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			
			Запрос       = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ЗубнаяФормулаСрезПоследних.Зуб,
			|	ВЫБОР
			|		КОГДА ЗубнаяФормулаСрезПоследних.Область = ЗНАЧЕНИЕ(Перечисление.ОбластиЗубнойФормулы.ПустаяСсылка)
			|			ТОГДА 0
			|		ИНАЧЕ 1
			|	КОНЕЦ КАК ТипСостояния,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗуба
			|ИЗ
			|	РегистрСведений.ЗубнаяФормула.СрезПоследних КАК ЗубнаяФормулаСрезПоследних
			|ГДЕ
			|	ЗубнаяФормулаСрезПоследних.Контрагент = &Контрагент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Наименование";
			Запрос.УстановитьПараметр("Контрагент", ?(МассивПриемов.Количество() > 0, ВладелецКарты, ""));
			СостояниеЗубов            = Запрос.Выполнить().Выгрузить();
			СтруктураЗначенийРесурсов = Новый Структура;
			ТипЗубнФормулы            = ?(МассивПриемов.Количество() > 0, МассивПриемов[0].Контрагент.ТипЗубнойФормулы, 2);
			Если ТипЗубнФормулы = 1 Тогда
				Начало = 33;
				КолЗубов = 52;				
			Иначе
				Начало = 1;
				КолЗубов = 32;				
			КонецЕсли;
			
			Для ЗначениеНомерЗуба = Начало По КолЗубов Цикл
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 0));
				Если СтрокаСостояниеЗубаОсн.Количество() > 0 Тогда
					Если СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Удален Тогда
						УслОбозоначениеСостояниеЗуба = "О";
					ИначеЕсли СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Абатмент Тогда
						УслОбозоначениеСостояниеЗуба = "И";
					Иначе
						Продолжить;
					КонецЕсли;
					СтруктураЗначенийРесурсов.Вставить("СостОсн_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УслОбозоначениеСостояниеЗуба);
				КонецЕсли;
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 1));
				УсловныеОбозначенияСостоянияЗуба = "";
				Для Каждого СостояниеЗуба Из СтрокаСостояниеЗубаОсн Цикл 
					Если ЗначениеЗаполнено(СтрокаСостояниеЗубаОсн[0].СостояниеЗубнойФормулы.УсловноеОбозначение) Тогда
						Если ЗначениеЗаполнено(УсловныеОбозначенияСостоянияЗуба) Тогда 
							УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + ",";
						КонецЕсли;
						УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + СостояниеЗуба.СостояниеЗубнойФормулы.УсловноеОбозначение;
					КонецЕсли;
				КонецЦикла;	
				СтруктураЗначенийРесурсов.Вставить("СостВсп_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УсловныеОбозначенияСостоянияЗуба);
			КонецЦикла;
			ОбластьМакета.Параметры.Заполнить(СтруктураЗначенийРесурсов);
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 5-Й СТРАНИЦЫ===========================================================================
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ОбластьМакета = Макет.ПолучитьОбласть("Стр5");	
			
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("ДанныеРентгеновскихЛабораторныхИсследований, ПланОбследования, КлиническийДиагноз, КодМКБ10, ПланЛечения", "60,100,100,100,100,100,100,100", "60,100,100,100,100", "92.5,100", "20", "60,100,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 6-Й СТРАНИЦЫ===========================================================================
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ОбластьМакета = Макет.ПолучитьОбласть("Стр6");
			
			ПараметрыОбследования = Новый Структура("ПротоколЛечения", "92.5,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЕсли;
		
		//==================================================================ПЕЧАТЬ 4-Й СТРАНИЦЫ===========================================================================
		// Вывод данных дневника обследований
		
		Если ПечатьВкладыша Тогда		
						
			НомерВыведенныхСтрок = 0;
			КрайнийНомерСтраницы = 4;
			ПоследнийНомерСтраницы = 0; 
			
			ОбластьМакета = Макет.ПолучитьОбласть("Колонтитул");
			ОбластьМакета.Параметры.НомерСтраницы = КрайнийНомерСтраницы;				
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Для Каждого СтрокаПриема Из МассивПриемов Цикл
								
				НомерВыведенныхСтрокПриема = 0;
				
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, СтрокаПриема,, Истина);				
				
				Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
					
					// Используются только реквизиты дневника
					Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
						Продолжить;
					КонецЕсли;	
					
					НомерВыведенныхСтрокРеквизита = 0;
					
					ТекстДанных             = СтрокаТ.РеквизитНаименование + ": " + СтрокаТ.РеквизитЗначение;					
					МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанных, 62.5);
					
					// Выводим массив текста
					Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл						
						Если НомерВыведенныхСтрок = 0 Или ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 25) / 25) = 0 Тогда
							Если НомерВыведенныхСтрок >= 25 Тогда
								// Если ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 25) / 25 / 2) <> 0 Тогда
								//    ОбластьМакета = Макет.ПолучитьОбласть("ПустаяСтрокаУдвоенногоПоля");
								//    ТабличныйДокумент.Вывести(ОбластьМакета);
								// Иначе
								//    ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц(); 
								// КонецЕсли;
								ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
								ОбластьМакета                         = Макет.ПолучитьОбласть("Колонтитул");
								ОбластьМакета.Параметры.НомерСтраницы = (КрайнийНомерСтраницы + (НомерВыведенныхСтрок - 25) / 25 + 1);
								ТабличныйДокумент.Вывести(ОбластьМакета);
								ПоследнийНомерСтраницы = ОбластьМакета.Параметры.НомерСтраницы;
							КонецЕсли;
							ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
						НомерВыведенныхСтрок       = НомерВыведенныхСтрок + 1;
						НомерВыведенныхСтрокПриема = НомерВыведенныхСтрокПриема + 1;
						НомерВыведенныхСтрокРеквизита = НомерВыведенныхСтрокРеквизита + 1;
						
						ОбластьМакета                 = Макет.ПолучитьОбласть("СтрокаДневника");
						Если НомерВыведенныхСтрокПриема = 1 Тогда
							ОбластьМакета.Параметры.Дата = СтрокаПриема.Дата;
							ОбластьМакета.Параметры.ЛечащийВрач = СтрокаПриема.Сотрудник;	
						ИначеЕсли НомерВыведенныхСтрокПриема = 2 Тогда
							ОбластьМакета.Параметры.ЛечащийВрач = "_____________(подпись)";
						КонецЕсли; 
						
						Если НомерВыведенныхСтрокРеквизита = 1 Тогда
							
							ТабличныйДокумент.Вывести(ОбластьМакета);
							РеквизитПредставление = СокрЛП(СтрокаТ.РеквизитНаименование) + ": ";
							ДлинаРеквизита = СтрДлина(РеквизитПредставление);
							
							НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
							
							// Подобрана средняя величина.
							ДелительДлины = ?(ДлинаРеквизита >= 15, 3, 4);
							КоличествоКолонокДляРеквизита = Окр((ДлинаРеквизита / ДелительДлины), 0, РежимОкругления.Окр15как20) + 5;								  
							
							ОбластьРеквизит = ТабличныйДокумент.Область(НомерСтроки, 5, НомерСтроки, КоличествоКолонокДляРеквизита);	
							ОбластьРеквизит.Объединить();             
							ОбластьРеквизит.Шрифт = Новый Шрифт("Arial", 8, Истина);
							ОбластьРеквизит.Текст = РеквизитПредставление;							 
							
							ОбластьТекст = ТабличныйДокумент.Область(НомерСтроки, КоличествоКолонокДляРеквизита+1, НомерСтроки, 29);
							ОбластьТекст.Объединить();
							ОбластьТекст.Шрифт = Новый Шрифт("Arial", 8, Ложь);
							ОбластьТекст.Текст = Сред(ТекстДанныхПоСтрокам, ДлинаРеквизита+1); 
							
						Иначе
							ОбластьМакета.Параметры.Текст = ТекстДанныхПоСтрокам;
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
					КонецЦикла;					 
				КонецЦикла;
			КонецЦикла;	
			
			// Дополняем пустыми строчками до конца листа
			Пока ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 25) / 25) <> 0 Цикл
				Если НомерВыведенныхСтрок = 0 Тогда
					ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
					ТабличныйДокумент.Вывести(ОбластьМакета);
				КонецЕсли;
				ОбластьМакета = Макет.ПолучитьОбласть("СтрокаДневника");
				ТабличныйДокумент.Вывести(ОбластьМакета);
				НомерВыведенныхСтрок = НомерВыведенныхСтрок + 1;	
			КонецЦикла;	 
			
			ПоследнийНомерСтраницы = ПоследнийНомерСтраницы + ?(НомерВыведенныхСтрокПриема <= 25, 1, 0); 	
			КрайнийНомерСтраницы = ПоследнийНомерСтраницы + 1;
			НомерВыведенныхСтрок = 0;
			НомерВыведенныхСтрокПриема = 0;
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЕсли;				
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийОбъект.ВладелецКарты.Ссылка);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб        = Истина;	
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт; 
	
	Возврат ТабличныйДокумент; 
		
КонецФункции

// Функция заполняет макет Медицинская карта по переданному пациенту образец СССР
//
// Параметры:
// 		Пациент			- Контрагенты, пациент, на которого сформировать мед.карту
//
Функция СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_СССР_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АмбулаторнаяКарта_043_У_СССР_А4";
	ТабличныйДокумент.РазмерСтраницы       = "A4";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент    = Ложь;	
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДокументПрием.Дата,
		|	ДокументПрием.Ссылка,
		|	ДокументПрием.РезультатПриема,
		|	ДокументПрием.Контрагент,
		|	ДокументПрием.Сотрудник
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ВключаяНеПроведенные
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
		|		КОНЕЦ
		|	И ДокументПрием.Контрагент = &Пациент
		|	И ДокументПрием.ПометкаУдаления = ЛОЖЬ
		|	И &УсловиеОтборИзМассива
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументПрием.Дата";
				
		ПечатьВкладыша = Ложь;
		ПечататьМедКарту = Ложь;		
		Если ТипЗнч(ПараметрыПечати) = Тип("Структура") Тогда
			ПечатьВкладыша = ПараметрыПечати.Свойство("ПечатьВкладыша");				
			ПечатьМедКарты = ПараметрыПечати.Свойство("ПечатьМедКарты");
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ВключаяНеПроведенные", ПечатьВкладыша);
		Запрос.УстановитьПараметр("Пациент"             , ТекущийОбъект.ВладелецКарты);			
			
		Если ПечатьВкладыша Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив"), ПараметрыПечати.ПечатьВкладыша, Неопределено); 			
		ИначеЕсли ПечатьМедКарты Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьМедКарты) = Тип("Массив"), ПараметрыПечати.ПечатьМедКарты, Неопределено);	
		Иначе
			МассивПриемов = Неопределено;	
		КонецЕсли;
		
		УсловиеОтборИзМассива = ?(ЗначениеЗаполнено(МассивПриемов), "ДокументПрием.Ссылка В (&МассивПриемов)", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборИзМассива", УсловиеОтборИзМассива);	
		Запрос.УстановитьПараметр("МассивПриемов", МассивПриемов);
		
		// ТаблицаПриемов = ?(ЗначениеЗаполнено(МассивПриемов), МассивПриемов, Запрос.Выполнить().Выгрузить());
		ТаблицаПриемов = Запрос.Выполнить().Выгрузить();
		
		//////////////////////////////////////////////////////////////////////////////////////
		Макет = ПолучитьМакет("АмбулаторнаяКарта_043_У_СССР_А4");
		// Выводим данные первого приема
		
		ПечатьМедКарты = ПечатьМедКарты ИЛИ ПараметрыПечати.Свойство("ТитульныйЛист") ИЛИ НЕ ЗначениеЗаполнено(ПараметрыПечати);
		ПечатьВкладыша = ПечатьВкладыша ИЛИ ПечатьМедКарты;
		
		Если ПечатьМедКарты Тогда
			
			АдресКонтрагента                              = ТекущийОбъект.ВладелецКарты.КонтактнаяИнформация.Найти(Перечисления.ТипыКонтактнойИнформации.Адрес, "Тип");
			//==================================================================ПЕЧАТЬ 1-Й СТРАНИЦЫ===========================================================================
			ОбластьМакета                                 = Макет.ПолучитьОбласть("Стр1");
			ОбластьМакета.Параметры.Организация           = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
			ОбластьМакета.Параметры.КодПоОКПО             = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.КодПоОКПО;
			ОбластьМакета.Параметры.НомерКарты            = ТекущийОбъект.КодБезНулей;
			ОбластьМакета.Параметры.ТекДата               = Формат(ТекущаяДата(), "ДЛФ=DD");
			ОбластьМакета.Параметры.ФИОКлиента            = ТекущийОбъект.ВладелецКарты.Наименование;
			ОбластьМакета.Параметры.Пол                   = ТекущийОбъект.ВладелецКарты.ПолКлиента;
			ОбластьМакета.Параметры.Возраст               = ?(ЗначениеЗаполнено(ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента), Год(Дата(01, 01, 01) + (ТекущаяДата() - ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента)) - 1, "");
			ОбластьМакета.Параметры.Адрес                 = ?(АдресКонтрагента  = Неопределено, "", АдресКонтрагента.Представление);
			ОбластьМакета.Параметры.Профессия             = ТекущийОбъект.ВладелецКарты.Профессия;
			
			ТаблицаОбследований = Неопределено;
			Если ТаблицаПриемов.Количество() > 0 Тогда
				// Выбираем первый прием, для заполнения тутульного листа
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,ТаблицаПриемов[0].Ссылка);	
			КонецЕсли;
			// Для Каждого СтрокаТ ИЗ ТаблицаПриемов Цикл
			//	ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,СтрокаТ.Ссылка);	
			//	Если ТаблицаОбследований.Количество() > 0 Тогда
			//		ТаблицаПриемов.Удалить(СтрокаТ);
			//		Прервать;
			//	КонецЕсли;	
			// КонецЦикла;
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("Диагноз, Жалобы, ПеренесенныеИСопутствующиеЗаболевания, РазвитиеНастоящегоЗаболевания", "92.5", "92.5,100,100", "65,100,100", "72.5,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено И ТаблицаОбследований.Количество() > 0 Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			
			Запрос        = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ЗубнаяФормулаСрезПоследних.Зуб,
			|	ВЫБОР
			|		КОГДА ЗубнаяФормулаСрезПоследних.Область = ЗНАЧЕНИЕ(Перечисление.ОбластиЗубнойФормулы.ПустаяСсылка)
			|			ТОГДА 0
			|		ИНАЧЕ 1
			|	КОНЕЦ КАК ТипСостояния,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗуба
			|ИЗ
			|	РегистрСведений.ЗубнаяФормула.СрезПоследних КАК ЗубнаяФормулаСрезПоследних
			|ГДЕ
			|	ЗубнаяФормулаСрезПоследних.Контрагент = &Контрагент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Наименование";
			Запрос.УстановитьПараметр("Контрагент", ?(ТаблицаПриемов.Количество() > 0, ТаблицаПриемов[0].Контрагент, ""));
			СостояниеЗубов            = Запрос.Выполнить().Выгрузить();
			СтруктураЗначенийРесурсов = Новый Структура;
			ТипЗубнФормулы            = ?(ТаблицаПриемов.Количество() > 0, ТаблицаПриемов[0].Контрагент.ТипЗубнойФормулы, 2);
			Если ТипЗубнФормулы = 1 Тогда
				Начало = 33;
				КолЗубов = 52;				
			Иначе
				Начало = 1;
				КолЗубов = 32;				
			КонецЕсли;
			
			Для ЗначениеНомерЗуба = Начало По КолЗубов Цикл
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 0));
				Если СтрокаСостояниеЗубаОсн.Количество() > 0 Тогда
					Если СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Удален Тогда
						УслОбозоначениеСостояниеЗуба = "О";
					ИначеЕсли СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Протез Тогда
						УслОбозоначениеСостояниеЗуба = "И";
					Иначе
						Продолжить;
					КонецЕсли;
					СтруктураЗначенийРесурсов.Вставить("СостОсн_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УслОбозоначениеСостояниеЗуба);
				КонецЕсли;
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 1));
				УсловныеОбозначенияСостоянияЗуба = "";
				Для Каждого СостояниеЗуба Из СтрокаСостояниеЗубаОсн Цикл 
					Если ЗначениеЗаполнено(СтрокаСостояниеЗубаОсн[0].СостояниеЗубнойФормулы.УсловноеОбозначение) Тогда
						Если ЗначениеЗаполнено(УсловныеОбозначенияСостоянияЗуба) Тогда 
							УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + ",";
						КонецЕсли;
						УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + СостояниеЗуба.СостояниеЗубнойФормулы.УсловноеОбозначение;
					КонецЕсли;
				КонецЦикла;	
				СтруктураЗначенийРесурсов.Вставить("СостВсп_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УсловныеОбозначенияСостоянияЗуба);
			КонецЦикла;
			ОбластьМакета.Параметры.Заполнить(СтруктураЗначенийРесурсов);
			
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("ДанныеОбъективногоИсследования, Прикус, СостояниеСлизистойОболочкиПолостиРта, ДанныеРентгеновскихЛабораторныхИсследований",  "60,100,100,100", "92.5",  "37.5,100,100", "60,100,100,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 2-Й СТРАНИЦЫ===========================================================================
			// Вместо 2й страницы теперь печатается дневник (вкладыш) этого приема.
			
		КонецЕсли;
		
		Если ПечатьВкладыша Тогда		
					
			НомерВыведенныхСтрок = 0;
	        НачальныйНомерСтраницы = ?(ПечатьМедКарты, 2, 4);
			ОбластьМакета = Макет.ПолучитьОбласть("Колонтитул");
			ОбластьМакета.Параметры.НомерСтраницы = НачальныйНомерСтраницы;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			Для Каждого СтрокаПриема Из ТаблицаПриемов Цикл
								
				НомерВыведенныхСтрокПриема = 0;		
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,СтрокаПриема.Ссылка);				
	
				Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
					
					// Используются только реквизиты дневника
					Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
						Продолжить;
					КонецЕсли;	
					
					НомерВыведенныхСтрокРеквизита = 0;
					
					ТекстДанных             = СтрокаТ.РеквизитНаименование + ": " +  СтрокаТ.РеквизитЗначение;				
					МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанных, 62.5);
					
					// Выводим массив текста
					Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл						
						Если НомерВыведенныхСтрок = 0 Или ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 17) / 25) = 0 Тогда
							Если НомерВыведенныхСтрок >= 17 Тогда				
								Если ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 17) / 25 / 2) <> 0 Тогда
									ОбластьМакета = Макет.ПолучитьОбласть("ПустаяСтрокаУдвоенногоПоля");
									ТабличныйДокумент.Вывести(ОбластьМакета);
								Иначе
									ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
								КонецЕсли;
								ОбластьМакета                         = Макет.ПолучитьОбласть("Колонтитул");
								ОбластьМакета.Параметры.НомерСтраницы = (НачальныйНомерСтраницы + (НомерВыведенныхСтрок - 17) / 25 + 1);
								ТабличныйДокумент.Вывести(ОбластьМакета);
							КонецЕсли;
							ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
						НомерВыведенныхСтрок       = НомерВыведенныхСтрок + 1;
						НомерВыведенныхСтрокПриема = НомерВыведенныхСтрокПриема + 1;
						НомерВыведенныхСтрокРеквизита = НомерВыведенныхСтрокРеквизита + 1;
						
						ОбластьМакета                 = Макет.ПолучитьОбласть("СтрокаДневника");
						Если НомерВыведенныхСтрокПриема = 1 Тогда
							ОбластьМакета.Параметры.Дата = СтрокаПриема.Дата;
							ОбластьМакета.Параметры.ЛечащийВрач = СтрокаПриема.Сотрудник;	
						ИначеЕсли НомерВыведенныхСтрокПриема = 2 Тогда
							ОбластьМакета.Параметры.ЛечащийВрач = "_____________(подпись)";
						КонецЕсли; 
						
						Если НомерВыведенныхСтрокРеквизита = 1 Тогда
							
							ТабличныйДокумент.Вывести(ОбластьМакета);
							РеквизитПредставление = СокрЛП(СтрокаТ.РеквизитНаименование) + ": ";
							ДлинаРеквизита = СтрДлина(РеквизитПредставление);
							
							НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
							
							// Подобрана средняя величина.
							ДелительДлины = ?(ДлинаРеквизита >= 8, 3, 4); //?(ПечатьМедКарты, 8, 15)
							КоличествоКолонокДляРеквизита = Окр((ДлинаРеквизита / ДелительДлины), 0, РежимОкругления.Окр15как20) + 5;								  
							
							ОбластьРеквизит = ТабличныйДокумент.Область(НомерСтроки, 5, НомерСтроки, КоличествоКолонокДляРеквизита);	
							ОбластьРеквизит.Объединить();             
							ОбластьРеквизит.Шрифт = Новый Шрифт("Arial", 8, Истина);
							ОбластьРеквизит.Текст = РеквизитПредставление;							 
							
							ОбластьТекст = ТабличныйДокумент.Область(НомерСтроки, КоличествоКолонокДляРеквизита+1, НомерСтроки, 29);
							ОбластьТекст.Объединить();
							ОбластьТекст.Шрифт = Новый Шрифт("Arial", 8, Ложь);
							ОбластьТекст.Текст = Сред(ТекстДанныхПоСтрокам, ДлинаРеквизита+1); 
							
						Иначе
							ОбластьМакета.Параметры.Текст = ТекстДанныхПоСтрокам;
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;	
						
					КонецЦикла;
				КонецЦикла;
				
				Если ПечатьМедКарты Тогда
					Прервать;
				КонецЕсли;				
				
			КонецЦикла;
			// Дополняем пустыми строчками до конца листа
			Пока ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 17) / 25) <> 0 Цикл
				Если НомерВыведенныхСтрок = 0 Тогда
					ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
					ТабличныйДокумент.Вывести(ОбластьМакета);
				КонецЕсли;
				ОбластьМакета = Макет.ПолучитьОбласть("СтрокаДневника");
				ТабличныйДокумент.Вывести(ОбластьМакета);
				НомерВыведенныхСтрок = НомерВыведенныхСтрок + 1;
			КонецЦикла;
		КонецЕсли;	
		
		Если ПараметрыПечати = Неопределено Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ОбластьМакета = Макет.ПолучитьОбласть("Стр5");
			ТабличныйДокумент.Вывести(ОбластьМакета);	
		КонецЕсли;
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийОбъект.ВладелецКарты.Ссылка);	
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;	
	Возврат ТабличныйДокумент; 
	
КонецФункции

// Функция заполняет макет Медицинская карта по переданному пациенту образец СССР
//
// Параметры:
// 		Пациент			- Контрагенты, пациент, на которого сформировать мед.карту
//
Функция СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_СССР_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АмбулаторнаяКарта_043_У_СССР_А5";
	ТабличныйДокумент.РазмерСтраницы       = "A5";

	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент    = Ложь;	
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДокументПрием.Дата,
		|	ДокументПрием.Ссылка,
		|	ДокументПрием.РезультатПриема,
		|	ДокументПрием.Контрагент,
		|	ДокументПрием.Сотрудник
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ВключаяНеПроведенные
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
		|		КОНЕЦ
		|	И ДокументПрием.Контрагент = &Пациент
		|	И ДокументПрием.ПометкаУдаления = ЛОЖЬ
		|	И &УсловиеОтборИзМассива
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументПрием.Дата";
			
		ПечатьВкладыша = Ложь;
		ПечататьМедКарту = Ложь;		
		Если ТипЗнч(ПараметрыПечати) = Тип("Структура") Тогда
			ПечатьВкладыша = ПараметрыПечати.Свойство("ПечатьВкладыша");				
			ПечатьМедКарты = ПараметрыПечати.Свойство("ПечатьМедКарты");
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ВключаяНеПроведенные", ПечатьВкладыша);
		Запрос.УстановитьПараметр("Пациент"             , ТекущийОбъект.ВладелецКарты);			
				
		Если ПечатьВкладыша Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив"), ПараметрыПечати.ПечатьВкладыша, Неопределено); 			
		ИначеЕсли ПечатьМедКарты Тогда
			МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьМедКарты) = Тип("Массив"), ПараметрыПечати.ПечатьМедКарты, Неопределено);	
		Иначе
			МассивПриемов = Неопределено;	
		КонецЕсли;
		
		УсловиеОтборИзМассива = ?(ЗначениеЗаполнено(МассивПриемов), "ДокументПрием.Ссылка В (&МассивПриемов)", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборИзМассива", УсловиеОтборИзМассива);	
		Запрос.УстановитьПараметр("МассивПриемов", МассивПриемов);
		
		// ТаблицаПриемов = ?(ЗначениеЗаполнено(МассивПриемов), МассивПриемов, Запрос.Выполнить().Выгрузить());
		ТаблицаПриемов = Запрос.Выполнить().Выгрузить();
		
		//////////////////////////////////////////////////////////////////////////////////////
		Макет = ПолучитьМакет("АмбулаторнаяКарта_043_У_СССР_А5");
		
		ПечатьМедКарты = ПечатьМедКарты ИЛИ ПараметрыПечати.Свойство("ТитульныйЛист") ИЛИ НЕ ЗначениеЗаполнено(ПараметрыПечати);			
				
		// Выводим данные первого приема
		Если ПечатьМедКарты Тогда
			
			АдресКонтрагента                              = ТекущийОбъект.ВладелецКарты.КонтактнаяИнформация.Найти(Перечисления.ТипыКонтактнойИнформации.Адрес, "Тип");
			//==================================================================ПЕЧАТЬ 1-Й СТРАНИЦЫ===========================================================================
			ОбластьМакета                                 = Макет.ПолучитьОбласть("Стр1");
			ОбластьМакета.Параметры.Организация           = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация;
			ОбластьМакета.Параметры.КодПоОКПО             = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.КодПоОКПО;
			ОбластьМакета.Параметры.НомерКарты            = ТекущийОбъект.КодБезНулей;
			ОбластьМакета.Параметры.ТекДата               = Формат(ТекущаяДата(), "ДЛФ=DD");
			ОбластьМакета.Параметры.ФИОКлиента            = ТекущийОбъект.ВладелецКарты.Наименование;
			ОбластьМакета.Параметры.Пол                   = ТекущийОбъект.ВладелецКарты.ПолКлиента;
			ОбластьМакета.Параметры.Возраст               = ?(ЗначениеЗаполнено(ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента), Год(Дата(01, 01, 01) + (ТекущаяДата() - ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента)) - 1, "");
			ОбластьМакета.Параметры.Адрес                 = ?(АдресКонтрагента  = Неопределено, "", АдресКонтрагента.Представление);
			ОбластьМакета.Параметры.Профессия             = ТекущийОбъект.ВладелецКарты.Профессия;
			
			ТаблицаОбследований = Неопределено;
			Если ТаблицаПриемов.Количество() > 0 Тогда
				// Выбираем первый прием, для заполнения тутульного листа
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,ТаблицаПриемов[0].Ссылка);	
			КонецЕсли;
			// Для Каждого СтрокаТ ИЗ ТаблицаПриемов Цикл
			//	ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,СтрокаТ.Ссылка);	
			//	Если ТаблицаОбследований.Количество() > 0 Тогда
			//		ТаблицаПриемов.Удалить(СтрокаТ);
			//		Прервать;
			//	КонецЕсли;	
			// КонецЦикла;
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("Диагноз, Жалобы, ПеренесенныеИСопутствующиеЗаболевания, РазвитиеНастоящегоЗаболевания", "92.5", "92.5,100,100", "65,100,100", "72.5,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено И ТаблицаОбследований.Количество() > 0 Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ПустаяСтрокаУдвоенногоПоля");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			//==================================================================ПЕЧАТЬ 2-Й СТРАНИЦЫ===========================================================================
			ОбластьМакета = Макет.ПолучитьОбласть("Стр2");
			Запрос        = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ЗубнаяФормулаСрезПоследних.Зуб,
			|	ВЫБОР
			|		КОГДА ЗубнаяФормулаСрезПоследних.Область = ЗНАЧЕНИЕ(Перечисление.ОбластиЗубнойФормулы.ПустаяСсылка)
			|			ТОГДА 0
			|		ИНАЧЕ 1
			|	КОНЕЦ КАК ТипСостояния,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы,
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗуба
			|ИЗ
			|	РегистрСведений.ЗубнаяФормула.СрезПоследних КАК ЗубнаяФормулаСрезПоследних
			|ГДЕ
			|	ЗубнаяФормулаСрезПоследних.Контрагент = &Контрагент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Наименование";
			Запрос.УстановитьПараметр("Контрагент", ?(ТаблицаПриемов.Количество() > 0, ТаблицаПриемов[0].Контрагент, ""));
			СостояниеЗубов            = Запрос.Выполнить().Выгрузить();
			СтруктураЗначенийРесурсов = Новый Структура;
			ТипЗубнФормулы            = ?(ТаблицаПриемов.Количество() > 0, ТаблицаПриемов[0].Контрагент.ТипЗубнойФормулы, 2);
			Если ТипЗубнФормулы = 1 Тогда
				Начало = 33;
				КолЗубов = 52;				
			Иначе
				Начало = 1;
				КолЗубов = 32;				
			КонецЕсли;
			
			Для ЗначениеНомерЗуба = Начало По КолЗубов Цикл
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 0));
				Если СтрокаСостояниеЗубаОсн.Количество() > 0 Тогда
					Если СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Удален Тогда
						УслОбозоначениеСостояниеЗуба = "О";
					ИначеЕсли СтрокаСостояниеЗубаОсн[0].СостояниеЗуба = Перечисления.СостояниеЗуба.Протез Тогда
						УслОбозоначениеСостояниеЗуба = "И";
					Иначе
						Продолжить;
					КонецЕсли;
					СтруктураЗначенийРесурсов.Вставить("СостОсн_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УслОбозоначениеСостояниеЗуба);
				КонецЕсли;
				СтрокаСостояниеЗубаОсн = СостояниеЗубов.НайтиСтроки(Новый Структура("Зуб, ТипСостояния", Перечисления.Зубы[ЗначениеНомерЗуба], 1));
				УсловныеОбозначенияСостоянияЗуба = "";
				Для Каждого СостояниеЗуба Из СтрокаСостояниеЗубаОсн Цикл 
					Если ЗначениеЗаполнено(СтрокаСостояниеЗубаОсн[0].СостояниеЗубнойФормулы.УсловноеОбозначение) Тогда
						Если ЗначениеЗаполнено(УсловныеОбозначенияСостоянияЗуба) Тогда 
							УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + ",";
						КонецЕсли;
						УсловныеОбозначенияСостоянияЗуба = УсловныеОбозначенияСостоянияЗуба + СостояниеЗуба.СостояниеЗубнойФормулы.УсловноеОбозначение;
					КонецЕсли;
				КонецЦикла;	
				СтруктураЗначенийРесурсов.Вставить("СостВсп_Зуб" + ОпределитьПозициюЗуба(ЗначениеНомерЗуба), УсловныеОбозначенияСостоянияЗуба);
			КонецЦикла;
			ОбластьМакета.Параметры.Заполнить(СтруктураЗначенийРесурсов);
			
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("ДанныеОбъективногоИсследования, Прикус, СостояниеСлизистойОболочкиПолостиРта, ДанныеРентгеновскихЛабораторныхИсследований",  "60,100,100,100", "92.5",  "37.5,100,100", "60,100,100,100,100,100,100,100");
			Если ТаблицаОбследований <> Неопределено Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			//==================================================================ПЕЧАТЬ 3-Й СТРАНИЦЫ===========================================================================
			
			ОбластьМакета                       = Макет.ПолучитьОбласть("Стр3");
			ОбластьМакета.Параметры.Дата        = ?(ТаблицаПриемов.Количество() > 0, ТаблицаПриемов[0].Дата, "");
			ОбластьМакета.Параметры.ЛечащийВрач = ?(ТаблицаПриемов.Количество() > 0, ТаблицаПриемов[0].Сотрудник, "");
			
			СрезПоследних                        = РегистрыСведений.ОтветственныеЛица.СрезПоследних(ТекущаяДата(), Новый Структура("Организация, ТипОтветственногоЛица", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация, Перечисления.ТипыОтветственныхЛиц.Руководитель));
			ОбластьМакета.Параметры.Руководитель = ?(СрезПоследних.Количество() < 1, Неопределено, СрезПоследних[0].Сотрудник);
			
			// Заполняем дневник последующих обследований
			НомерВыведенныхСтрок = 1;
			Если ТаблицаОбследований <> Неопределено Тогда
				Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
					
					// Используются только реквизиты дневника
					Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
						Продолжить;
					КонецЕсли;	
					
					ТекстДанных             = СтрокаТ.РеквизитНаименование + ": " + СтрокаТ.РеквизитЗначение;
					МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанных, 62.5);
					Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл
						Если НомерВыведенныхСтрок > 11 Тогда
							Прервать;
						КонецЕсли;
						ОбластьМакета.Параметры["ДневникПервогоПосещения" + "Стр" + НомерВыведенныхСтрок] = ТекстДанныхПоСтрокам;
						НомерВыведенныхСтрок = НомерВыведенныхСтрок + 1;
					КонецЦикла;
				КонецЦикла;
			КонецЕсли;
			// Заполнение параметров обследования, с разбитием на строчки
			ПараметрыОбследования = Новый Структура("Эпикриз, Наставления", "77.5,100,100,100,100", "90,100,100,100");
			Если ТаблицаОбследований <> Неопределено  Тогда
				ЗаполнитьПараметрыОбследования(ОбластьМакета, ТаблицаОбследований, ПараметрыОбследования);
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ПустаяСтрокаУдвоенногоПоля");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЕсли;
		
		//==================================================================ПЕЧАТЬ 4-Й СТРАНИЦЫ===========================================================================
		// Вывод данных дневника обследований
		Если ПечатьВкладыша Тогда		
			
			НомерВыведенныхСтрок = 0;
			КрайнийНомерСтраницы = 4;
			ПоследнийНомерСтраницы = 0; 
			
			Для Каждого СтрокаПриема Из ТаблицаПриемов Цикл
								
				НомерВыведенныхСтрокПриема = 0;		
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты,СтрокаПриема.Ссылка);				
				
				ОбластьМакета = Макет.ПолучитьОбласть("Колонтитул");
				ОбластьМакета.Параметры.НомерСтраницы = КрайнийНомерСтраницы;
				ТабличныйДокумент.Вывести(ОбластьМакета);
				// ПоследнийНомерСтраницы = ОбластьМакета.Параметры.НомерСтраницы;
				
				Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
					
					// Используются только реквизиты дневника
					Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
						Продолжить;
					КонецЕсли;	
					
					НомерВыведенныхСтрокРеквизита = 0;
					
					ТекстДанных             = СтрокаТ.РеквизитНаименование + ": " +  СтрокаТ.РеквизитЗначение;				
					МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанных, 62.5);
					
					// Выводим массив текста
					Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл						
						Если НомерВыведенныхСтрок = 0 Или ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 24) / 25) = 0 Тогда     // 17 -> 24
							Если НомерВыведенныхСтрок >= 24 Тогда				
								// Если ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 24) / 25 / 2) <> 0 Тогда
								//	ОбластьМакета = Макет.ПолучитьОбласть("ПустаяСтрокаУдвоенногоПоля");
								//	ТабличныйДокумент.Вывести(ОбластьМакета);
								// Иначе
								//	ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
								// КонецЕсли;
								ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
								ОбластьМакета                         = Макет.ПолучитьОбласть("Колонтитул");
								ПоследнийНомерСтраницы				  = (КрайнийНомерСтраницы + (НомерВыведенныхСтрок - 24) / 25 + 1);
								ОбластьМакета.Параметры.НомерСтраницы = ПоследнийНомерСтраницы;
								ТабличныйДокумент.Вывести(ОбластьМакета);	
							КонецЕсли;
							ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
						НомерВыведенныхСтрок       = НомерВыведенныхСтрок + 1;
						НомерВыведенныхСтрокПриема = НомерВыведенныхСтрокПриема + 1;
						НомерВыведенныхСтрокРеквизита = НомерВыведенныхСтрокРеквизита + 1;
						
						ОбластьМакета                 = Макет.ПолучитьОбласть("СтрокаДневника");
						Если НомерВыведенныхСтрокПриема = 1 Тогда
							ОбластьМакета.Параметры.Дата = СтрокаПриема.Дата;
							ОбластьМакета.Параметры.ЛечащийВрач = СтрокаПриема.Сотрудник;	
						ИначеЕсли НомерВыведенныхСтрокПриема = 2 Тогда
							ОбластьМакета.Параметры.ЛечащийВрач = "_____________(подпись)";
						КонецЕсли; 
						
						Если НомерВыведенныхСтрокРеквизита = 1 Тогда
							
							ТабличныйДокумент.Вывести(ОбластьМакета);
							РеквизитПредставление = СокрЛП(СтрокаТ.РеквизитНаименование) + ": ";
							ДлинаРеквизита = СтрДлина(РеквизитПредставление);
							
							НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
							
							// Подобрана средняя величина.
							ДелитьДлины = ?(ДлинаРеквизита >= 8, 3, 4); // 15
							КоличествоКолонокДляРеквизита = Окр((ДлинаРеквизита / ДелитьДлины), 0, РежимОкругления.Окр15как20) + 5;								  
							
							ОбластьРеквизит = ТабличныйДокумент.Область(НомерСтроки, 5, НомерСтроки, КоличествоКолонокДляРеквизита);	
							ОбластьРеквизит.Объединить();             
							ОбластьРеквизит.Шрифт = Новый Шрифт("Arial", 8, Истина);
							ОбластьРеквизит.Текст = РеквизитПредставление;							 
							
							ОбластьТекст = ТабличныйДокумент.Область(НомерСтроки, КоличествоКолонокДляРеквизита+1, НомерСтроки, 29);
							ОбластьТекст.Объединить();
							ОбластьТекст.Шрифт = Новый Шрифт("Arial", 8, Ложь);
							ОбластьТекст.Текст = Сред(ТекстДанныхПоСтрокам, ДлинаРеквизита+1); 
							
						Иначе
							ОбластьМакета.Параметры.Текст = ТекстДанныхПоСтрокам;
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
							
					КонецЦикла;
				КонецЦикла;
				
			// Дополняем пустыми строчками до конца листа
			Пока ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 24) / 25) <> 0 Цикл
				Если НомерВыведенныхСтрок = 0 Тогда
					ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
					ТабличныйДокумент.Вывести(ОбластьМакета);
				КонецЕсли;
				ОбластьМакета = Макет.ПолучитьОбласть("СтрокаДневника");
				ТабличныйДокумент.Вывести(ОбластьМакета);
				НомерВыведенныхСтрок = НомерВыведенныхСтрок + 1;
			КонецЦикла;
			
			ПоследнийНомерСтраницы = ?(ПоследнийНомерСтраницы = 0 ИЛИ НЕ ЗначениеЗаполнено(ТаблицаОбследований), КрайнийНомерСтраницы - 1, ПоследнийНомерСтраницы); 
			ПоследнийНомерСтраницы = ПоследнийНомерСтраницы + ?(НомерВыведенныхСтрокПриема <= 25, 1, 0);	
			КрайнийНомерСтраницы = ПоследнийНомерСтраницы + 1; 
			НомерВыведенныхСтрок = 0;
			НомерВыведенныхСтрокПриема = 0;
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЦикла;
				
		КонецЕсли;	
		
		Если ПараметрыПечати = Неопределено Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("Стр5");
			ТабличныйДокумент.Вывести(ОбластьМакета);	
		КонецЕсли;
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийОбъект.ВладелецКарты.Ссылка);	
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт; 
	Возврат ТабличныйДокумент; 
	
КонецФункции

// Функция формирует печатную форму Накладная документа.
//
Функция СформироватьПечатнуюФормуМедицинскаяКарта_025У_04_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);	
	ПервыйДокумент    = Истина;	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МедицинскаяКарта_025У_04_А4";
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;		
		Макет          = Справочники.МедицинскиеКарты.ПолучитьМакет("МедицинскаяКарта_025У_04_А4");		
		Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ТитульныйЛист") = Истина ИЛИ ПараметрыПечати.Свойство("ПечатьМедКарты") = Истина Тогда // ПараметрыПечати = Неопределено
			
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			
			// Параметры организации
			ОбластьМакета.Параметры.ПредставлениеОрганизации	= ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация, ТекущаяДата()), "ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет");
			ОбластьМакета.Параметры.АдресОрганизации			= ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, "Фактический");
			
			МассивПолисыСтрахования                          = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ТекущийОбъект.ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ОбязательноеМедицинскоеСтрахование);
			ОбластьМакета.Параметры.СтраховаяОрганизация     = ?(МассивПолисыСтрахования.Количество() > 0, МассивПолисыСтрахования[0].СтраховаяКомпания.Наименование, "");
			ЗаполнитьПараметрПосимвольно(ОбластьМакета,"НСП", ?(МассивПолисыСтрахования.Количество() > 0, МассивПолисыСтрахования[0].СерияПолиса + " " + МассивПолисыСтрахования[0].НомерПолиса, ""));
			ОбластьМакета.Параметры.НомерКарты               = ТекущийОбъект.КодБезНулей;
			ОбластьМакета.Параметры.Фамилия                  = ТекущийОбъект.ВладелецКарты.Фамилия;
			ОбластьМакета.Параметры.Имя                      = ТекущийОбъект.ВладелецКарты.Имя;
			ОбластьМакета.Параметры.Отчество                 = ТекущийОбъект.ВладелецКарты.Отчество;
			ОбластьМакета.Параметры.Пол                      = ТекущийОбъект.ВладелецКарты.ПолКлиента;
			ОбластьМакета.Параметры.ДатаРождения             = ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента;
			ОбластьМакета.Параметры.АдресФактический         = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ТекущийОбъект.ВладелецКарты, "Фактический");
			ОбластьМакета.Параметры.АдресЮридический         = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ТекущийОбъект.ВладелецКарты, "Юридический");
			ОбластьМакета.Параметры.ТелефонДомашний          = ТекущийОбъект.ВладелецКарты.Телефон;
			ОбластьМакета.Параметры.КодОГРН					 = ?(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо, "Код ОГРН", "Код ОГРНИП");
			ОбластьМакета.Параметры.ОГРН					 = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.ОГРН;
			
			// Заполнение документа удостоверения 
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Физлицо", ТекущийОбъект.ВладелецКарты);
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			               |	ДокументыФизическихЛиц.ВидДокумента КАК ВидДокумента,
			               |	ДокументыФизическихЛиц.Серия КАК Серия,
			               |	ДокументыФизическихЛиц.Номер КАК Номер,
			               |	ДокументыФизическихЛиц.ДатаВыдачи КАК ДатаВыдачи,
			               |	ДокументыФизическихЛиц.КемВыдан КАК КемВыдан
			               |ИЗ
			               |	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
			               |ГДЕ
			               |	ДокументыФизическихЛиц.Физлицо = &Физлицо";
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				ОбластьМакета.Параметры.ДокументЛьготы = "" + Выборка.ВидДокумента + 
														 ?(ПустаяСтрока(Выборка.Номер),"", ", №" + Выборка.Номер) +
														 ?(ПустаяСтрока(Выборка.Серия),"", ", " + Выборка.Серия) +
														 ", " + Строка(Формат(Выборка.ДатаВыдачи, "ДФ=dd.MM.yyyy")) + 
														 ", " + Строка(Выборка.КемВыдан);
			КонецЕсли;

			
			ТабличныйДокумент.Вывести(ОбластьМакета);			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаЛист2");
			ТабличныйДокумент.Вывести(ОбластьМакета);		
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();		
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина Тогда					
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ДокументПрием.Дата,
			|	ДокументПрием.Ссылка,
			|	ДокументПрием.РезультатПриема,
			|	ДокументПрием.Контрагент,
			|	ДокументПрием.Сотрудник
			|ИЗ
			|	Документ.Прием КАК ДокументПрием
			|ГДЕ
			|	ВЫБОР
			|			КОГДА &ВключаяНеПроведенные
			|				ТОГДА ИСТИНА
			|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
			|		КОНЕЦ
			|	И ДокументПрием.Контрагент = &Пациент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДокументПрием.Дата";
			
			Запрос.УстановитьПараметр("ВключаяНеПроведенные",?(ТипЗнч(ПараметрыПечати) = Тип("Структура"), ПараметрыПечати.Свойство("ПечатьВкладыша"), Ложь));
			Запрос.УстановитьПараметр("Пациент", ТекущийОбъект.ВладелецКарты);
			
			Если ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина Тогда
				ТаблицаПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив"), ПараметрыПечати.ПечатьВкладыша, Неопределено); 			
			Иначе	
				ТаблицаПриемов = Неопределено;	
			КонецЕсли;
			ТаблицаПриемов = ?(НЕ ТаблицаПриемов = Неопределено, ТаблицаПриемов, Запрос.Выполнить().Выгрузить());
		
			НомерСтроки = 1;
			// Пока Выборка.Следующий() Цикл
			Для Каждого СтрокаПриема Из ТаблицаПриемов Цикл
							
				Если ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина 
					И ПараметрыПечати.ПечатьВкладыша.Найти(СтрокаПриема.Ссылка) = Неопределено Тогда // Выборка.Ссылка <> ПараметрыПечати.ПечатьВкладыша
					Продолжить;
				КонецЕсли;
					
				// Получить таблицу обследований	
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, СтрокаПриема.Ссылка);				
				// Выводим диагноз
				НайденныеСтрокиДиагноз = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Диагноз"));
				
				МассивОбластейЗаписи = Новый Массив;			
				ОбластьШапка	     = Макет.ПолучитьОбласть("ШапкаУточненныеДиагнозы");
				МассивОбластейЗаписи.Добавить(ОбластьШапка);							
				
				ОбластьСтрока	                     = Макет.ПолучитьОбласть("СтрокаУточненныеДиагнозы");			
				ОбластьСтрока.Параметры.Номер        = Строка(НомерСтроки);
				ОбластьСтрока.Параметры.Дата         = Формат(СтрокаПриема.Дата, "ДФ=dd.MM.yyyy");
				ОбластьСтрока.Параметры.Диагноз      = ?(НайденныеСтрокиДиагноз.Количество() > 0, НайденныеСтрокиДиагноз[0].РеквизитЗначение,"");
				ОбластьСтрока.Параметры.ЛечащийВрач  = СтрокаПриема.Сотрудник;				
				МассивОбластейЗаписи.Добавить(ОбластьСтрока);				
				
				ОбластьПодвал                            = Макет.ПолучитьОбласть("ПодвалУточненныеДиагнозы");
				ОбластьПодвал.Параметры.ДатаПодвал       = Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy");
				ОбластьПодвал.Параметры.СпециалистПодвал = СтрокаПриема.Сотрудник;
				МассивОбластейЗаписи.Добавить(ОбластьПодвал);
				
				Если Не ТабличныйДокумент.ПроверитьВывод(МассивОбластейЗаписи) Тогда
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();			
				КонецЕсли;
				
				Для Каждого ОбластьМакета Из МассивОбластейЗаписи Цикл
					ТабличныйДокумент.Вывести(ОбластьМакета);
				КонецЦикла;
				НомерСтроки = НомерСтроки + 1;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуНакладная()

// Функция формирует печатную форму Накладная документа.
//
Функция СформироватьПечатнуюФормуМедицинскаяКарта_025У_04_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПервыйДокумент    = Истина;	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МедицинскаяКарта_025У_04_А5";	
	ТабличныйДокумент.РазмерСтраницы       = "A5";
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;	
		Макет          = Справочники.МедицинскиеКарты.ПолучитьМакет("МедицинскаяКарта_025У_04_А5");
		
		Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ТитульныйЛист") = Истина ИЛИ ПараметрыПечати.Свойство("ПечатьМедКарты") = Истина Тогда
			
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			
			// Параметры организации
			ОбластьМакета.Параметры.ПредставлениеОрганизации	= ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация, ТекущаяДата()), "ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет");
			ОбластьМакета.Параметры.АдресОрганизации			= ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, "Фактический");
			
			МассивПолисыСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ТекущийОбъект.ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ОбязательноеМедицинскоеСтрахование);
			ОбластьМакета.Параметры.СтраховаяОрганизация = ?(МассивПолисыСтрахования.Количество() > 0, МассивПолисыСтрахования[0].СтраховаяКомпания.Наименование, "");
			ЗаполнитьПараметрПосимвольно(ОбластьМакета,"НСП", ?(МассивПолисыСтрахования.Количество() > 0, МассивПолисыСтрахования[0].СерияПолиса + " " + МассивПолисыСтрахования[0].НомерПолиса, ""));
			ОбластьМакета.Параметры.НомерКарты           = ТекущийОбъект.КодБезНулей;
			ОбластьМакета.Параметры.Фамилия              = ТекущийОбъект.ВладелецКарты.Фамилия;
			ОбластьМакета.Параметры.Имя                  = ТекущийОбъект.ВладелецКарты.Имя;
			ОбластьМакета.Параметры.Отчество             = ТекущийОбъект.ВладелецКарты.Отчество;
			ОбластьМакета.Параметры.Пол                  = ТекущийОбъект.ВладелецКарты.ПолКлиента;
			ОбластьМакета.Параметры.ДатаРождения         = ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента;
			ОбластьМакета.Параметры.АдресФактический     = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ТекущийОбъект.ВладелецКарты, "Фактический");
			ОбластьМакета.Параметры.АдресЮридический     = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ТекущийОбъект.ВладелецКарты, "Юридический");
			ОбластьМакета.Параметры.ТелефонДомашний      = ТекущийОбъект.ВладелецКарты.Телефон;
			ОбластьМакета.Параметры.КодОГРН				 = ?(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо, "Код ОГРН", "Код ОГРНИП");
			ОбластьМакета.Параметры.ОГРН				 = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.ОГРН;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаЛист2");
			ТабличныйДокумент.Вывести(ОбластьМакета);		
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();		
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина Тогда // ПараметрыПечати = Неопределено
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ДокументПрием.Дата,
			|	ДокументПрием.Ссылка,
			|	ДокументПрием.РезультатПриема,
			|	ДокументПрием.Контрагент,
			|	ДокументПрием.Сотрудник
			|ИЗ
			|	Документ.Прием КАК ДокументПрием
			|ГДЕ
			|	ВЫБОР
			|			КОГДА &ВключаяНеПроведенные
			|				ТОГДА ИСТИНА
			|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
			|		КОНЕЦ
			|	И ДокументПрием.Контрагент = &Пациент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДокументПрием.Дата";
			Запрос.УстановитьПараметр("ВключаяНеПроведенные",?(ТипЗнч(ПараметрыПечати) = Тип("Структура"), ПараметрыПечати.Свойство("ПечатьВкладыша"), Ложь));
			Запрос.УстановитьПараметр("Пациент"             , ТекущийОбъект.ВладелецКарты);
			
			Если ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина Тогда
				ТаблицаПриемов = ?(ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив"), ПараметрыПечати.ПечатьВкладыша, Неопределено); 			
			Иначе	
				ТаблицаПриемов = Неопределено;	
			КонецЕсли;
			ТаблицаПриемов = ?(НЕ ТаблицаПриемов = Неопределено, ТаблицаПриемов, Запрос.Выполнить().Выгрузить());
			
			НомерВыведенныхСтрокПриема = 0;
			НомерВыведенныхСтрок = 0;
			ПервыйПрием = Истина;

			Для Каждого СтрокаПриема Из ТаблицаПриемов Цикл
                ПервыйЛист = Истина;
				Если Не ПервыйПрием Тогда
					НомерВыведенныхСтрок = 0;
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;
				ПервыйПрием = Ложь;
				Если ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина 
					И ПараметрыПечати.ПечатьВкладыша.Найти(СтрокаПриема.Ссылка) = Неопределено Тогда // СтрокаПриема.Ссылка <> ПараметрыПечати.ПечатьВкладыша
					Продолжить;
				КонецЕсли;
				
				ОбластьЗаголовок = Макет.ПолучитьОбласть("ЗаписьЗаголовок");
				ОбластьДиагноз	 = Макет.ПолучитьОбласть("ЗаписьДиагноз");
				
				МассивОбластейЗаписи = Новый Массив;
				МассивОбластейЗаписи.Добавить(ОбластьЗаголовок);
				МассивОбластейЗаписи.Добавить(ОбластьДиагноз);
				
				ОбластьЗаголовок.Параметры.Заголовок	= "Запись медицинской книжки от " + Формат(СтрокаПриема.Дата, "ДФ='dd.MM.yyyy'");
				ОбластьЗаголовок.Параметры.Специалист	= СтрокаПриема.Сотрудник;
				
				// Получить таблицу обследований	
				ТаблицаОбследований              = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, СтрокаПриема.Ссылка);				
				// Выводим диагноз
				НайденныеСтроки                  = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Диагноз"));
				ОбластьДиагноз.Параметры.Диагноз = ?(НайденныеСтроки.Количество() >0, НайденныеСтроки[0].РеквизитЗначение,"");
				
				Для Каждого ОбластьМакета Из МассивОбластейЗаписи Цикл
					ТабличныйДокумент.Вывести(ОбластьМакета);
				КонецЦикла;	
				
				Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
					
					// Используются только реквизиты дневника
					Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
						Продолжить;
					КонецЕсли;	
					
					ТекстДанных             = СтрокаТ.РеквизитНаименование + ": " + СтрокаТ.РеквизитЗначение;				
					МассивСтрокОбследования = СтроковыеФункцииКлиентСерверСтоматология.РазбитьТекстНаСтроки(ТекстДанных, 94.5);
					
					НомерВыведенныхСтрокРеквизита = 0;
					
					// Выводим массив текста
					Для Каждого ТекстДанныхПоСтрокам Из МассивСтрокОбследования Цикл						 						
						Если НомерВыведенныхСтрок = 0 
							Или (ПервыйЛист И ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 48) / 48) = 0) 
							Или ОбщегоНазначенияСтоматология.Дроб((НомерВыведенныхСтрок - 57) / 57) = 0 Тогда
							Если (ПервыйЛист И НомерВыведенныхСтрок >= 48) Или НомерВыведенныхСтрок >= 57 Тогда				
								ПервыйЛист = Ложь;
								ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();  
								НомерВыведенныхСтрок = 0;
							КонецЕсли;
							
							ОбластьМакета = Макет.ПолучитьОбласть("ЗаписьТекст");
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
						
						НомерВыведенныхСтрок       = НомерВыведенныхСтрок + 1;
						НомерВыведенныхСтрокПриема = НомерВыведенныхСтрокПриема + 1;
						НомерВыведенныхСтрокРеквизита = НомерВыведенныхСтрокРеквизита + 1;
						
						ОбластьМакета                 = Макет.ПолучитьОбласть("СтрокаДневника");
						
						Если НомерВыведенныхСтрокРеквизита = 1 Тогда
							
							ТабличныйДокумент.Вывести(ОбластьМакета);
							РеквизитПредставление = СокрЛП(СтрокаТ.РеквизитНаименование) + ": ";
							ДлинаРеквизита = СтрДлина(РеквизитПредставление);
							
							НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
							
							// Подобрана средняя величина.
							ДелительДлины = ?(ДлинаРеквизита >= 15, 3, 4);
							КоличествоКолонокДляРеквизита = Окр((ДлинаРеквизита / ДелительДлины), 0, РежимОкругления.Окр15как20) + 5;								  
							
							ОбластьРеквизит = ТабличныйДокумент.Область(НомерСтроки, 5, НомерСтроки, КоличествоКолонокДляРеквизита);	
							ОбластьРеквизит.Объединить();             
							ОбластьРеквизит.Шрифт = Новый Шрифт("Arial", 8, Истина);
							ОбластьРеквизит.Текст = РеквизитПредставление;							 
							
							ОбластьТекст = ТабличныйДокумент.Область(НомерСтроки, КоличествоКолонокДляРеквизита+1, НомерСтроки, 29);
							ОбластьТекст.Объединить();
							ОбластьТекст.Шрифт = Новый Шрифт("Arial", 8, Ложь);
							ОбластьТекст.Текст = Сред(ТекстДанныхПоСтрокам, ДлинаРеквизита+1); 
							
						Иначе
							ОбластьМакета.Параметры.Текст = ТекстДанныхПоСтрокам;
							ТабличныйДокумент.Вывести(ОбластьМакета);
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла; 
		КонецЕсли;	
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;

	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуНакладная()

// Функция формирует печатную форму Медицинская карта клиента.
//
Функция СформироватьПечатнуюФормуМедицинскаяКарта_025У_14(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);	
	ПервыйДокумент    = Истина;	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МедицинскаяКарта_025У_14";

	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		ТаблицаПоПриемам = Новый ТаблицаЗначений;
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;		
		Макет          = Справочники.МедицинскиеКарты.ПолучитьМакет("МедицинскаяКарта_025У_14");		
		Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ТитульныйЛист") = Истина ИЛИ ПараметрыПечати.Свойство("ПечатьМедКарты") = Истина Тогда
			
			////////// Стр 1
			// Параметры организации
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаОрганизация");
			ОбластьМакета.Параметры.НаименованиеПолное	= ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация, ТекущаяДата()), "ПолноеНаименование,ОГРН,Телефоны,НомерСчета,Банк,БИК,КоррСчет");
			ОбластьМакета.Параметры.ЮридическийАдрес	= ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, "Фактический");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// Номер карты
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаКарты");
			ОбластьМакета.Параметры.НомерКартыПредставление = ТекущийОбъект.КодБезНулей;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			// ОсновныеДанные
			ОбластьМакета = Макет.ПолучитьОбласть("ОсновныеДанные");
			
			ОбластьМакета.Параметры.ДатаЗаполненияЧисло = День(ТекущаяДата());
			ОбластьМакета.Параметры.ДатаЗаполненияМесяц = Месяц(ТекущаяДата());
			ОбластьМакета.Параметры.ДатаЗаполненияГод   = Год(ТекущаяДата());
			ОбластьМакета.Параметры.ПредставлениеПолное = ТекущийОбъект.ВладелецКарты.Фамилия + " " + ТекущийОбъект.ВладелецКарты.Имя + " " + ТекущийОбъект.ВладелецКарты.Отчество;
			ОбластьМакета.Параметры.ДатаРожденияЧисло	= День(ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента);
			ОбластьМакета.Параметры.ДатаРожденияМесяц   = Месяц(ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента);
			ОбластьМакета.Параметры.ДатаРожденияГод     = Год(ТекущийОбъект.ВладелецКарты.ДатаРожденияКлиента);
			
			// Адрес
			ТабЗн = ТекущийОбъект.ВладелецКарты.КонтактнаяИнформация.Выгрузить();
			НайденныеСтроки = ТабЗн.НайтиСтроки(Новый Структура("Тип,Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента));
			Если НайденныеСтроки.Количество() > 0 Тогда
				СтруктураАдрес = НайденныеСтроки[0];
			Иначе 
				ВидКИ = ?(ТекущийОбъект.ВладелецКарты.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Справочники.ВидыКонтактнойИнформации.АдресКлиента, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);  
				НайденныеСтроки = ТабЗн.НайтиСтроки(Новый Структура("Тип,Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, ВидКИ));
				Если НайденныеСтроки.Количество() > 0 Тогда
					СтруктураАдрес = НайденныеСтроки[0];
				Иначе
					СтруктураАдрес = Неопределено;
				КонецЕсли;	
			КонецЕсли;
			
			Если СтруктураАдрес <> Неопределено Тогда
				ОбластьМакета.Параметры.МестоРегистрацииРегион = СтруктураАдрес.Регион;
				ОбластьМакета.Параметры.МестоРегистрацииГород  = СтруктураАдрес.Город;
				
				СтруктураПолейАдрес = Новый СписокЗначений;
				ПоследнийЭлемент = Неопределено;
				
				Для Сч = 1 По СтрЧислоСтрок(СтруктураАдрес.ЗначенияПолей) Цикл
					Стр = СтрПолучитьСтроку(СтруктураАдрес.ЗначенияПолей, Сч);
					Если Лев(Стр, 1) = Символы.Таб Тогда
						Если ПоследнийЭлемент <> Неопределено Тогда
							ПоследнийЭлемент.Значение = ПоследнийЭлемент.Значение + Символы.ПС + Сред(Стр, 2);
						КонецЕсли;
					Иначе
						Поз = Найти(Стр, "=");
						Если Поз <> 0 Тогда
							ПоследнийЭлемент = СтруктураПолейАдрес.Добавить(Сред(Стр, Поз+1), Лев(Стр, Поз-1));
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				
				Для Каждого ЭлементАдреса Из СтруктураПолейАдрес Цикл
					Если ЭлементАдреса.Представление = "Район" Тогда
						ОбластьМакета.Параметры.МестоРегистрацииРайон = ЭлементАдреса.Значение;	
					ИначеЕсли ЭлементАдреса.Представление = "Город" Тогда
						ОбластьМакета.Параметры.МестоРегистрацииГород = ЭлементАдреса.Значение;	
					ИначеЕсли ЭлементАдреса.Представление = "НаселенныйПункт" Тогда
						ОбластьМакета.Параметры.МестоРегистрацииНасПункт = ЭлементАдреса.Значение;	
					ИначеЕсли ЭлементАдреса.Представление = "Улица" Тогда
						ОбластьМакета.Параметры.МестоРегистрацииУлица = ЭлементАдреса.Значение;	
					ИначеЕсли ЭлементАдреса.Представление = "Дом" Тогда
						ОбластьМакета.Параметры.МестоРегистрацииДом = ЭлементАдреса.Значение;	
					ИначеЕсли ЭлементАдреса.Представление = "Квартира" Тогда
						ОбластьМакета.Параметры.МестоРегистрацииКвартира = ЭлементАдреса.Значение;		
					КонецЕсли;	
				КонецЦикла;
				
			КонецЕсли;
			
			ОбластьМакета.Параметры.ДомТелефонПациента         = ТекущийОбъект.ВладелецКарты.Телефон;
			
			МассивПолисыСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ТекущийОбъект.ВладелецКарты, ТекущаяДата(), Перечисления.ТипыПолиса.ОбязательноеМедицинскоеСтрахование);
			
			Если МассивПолисыСтрахования.Количество() > 0 Тогда
				ОбластьМакета.Параметры.ОМССтраховщик  = ?(МассивПолисыСтрахования.Количество() > 0, МассивПолисыСтрахования[0].СтраховаяКомпания.Наименование, "");
				ОбластьМакета.Параметры.ОМСНомерПолиса = МассивПолисыСтрахования[0].НомерПолиса;
				ОбластьМакета.Параметры.ОМССерияПолиса = МассивПолисыСтрахования[0].СерияПолиса;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Физлицо",	ТекущийОбъект.ВладелецКарты);
			Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ДокументыФизическихЛиц.ВидДокумента,
			|	ДокументыФизическихЛиц.Серия,
			|	ДокументыФизическихЛиц.Номер
			|ИЗ
			|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
			|ГДЕ
			|	ДокументыФизическихЛиц.Физлицо = &Физлицо";
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				ОбластьМакета.Параметры.ДокументВид = Выборка.ВидДокумента;
				ОбластьМакета.Параметры.ДокументСерия = Выборка.Серия;
				ОбластьМакета.Параметры.ДокументНомер = Выборка.Номер;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);			
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаЗаболевания");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЕсли;		
		
		ТаблицаДиагнозы = Новый ТаблицаЗначений;
		ТаблицаДиагнозы.Колонки.Добавить("ДатаПостановки");
		ТаблицаДиагнозы.Колонки.Добавить("НаименованиеЗаболевания");
		ТаблицаДиагнозы.Колонки.Добавить("КодМКБ10");
		ТаблицаДиагнозы.Колонки.Добавить("Врач");
		
		//Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина Тогда					
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ДокументПрием.Дата КАК Дата,
			|	ДокументПрием.Ссылка КАК Ссылка,
			|	ДокументПрием.РезультатПриема КАК РезультатПриема,
			|	ДокументПрием.Контрагент КАК Контрагент,
			|	ДокументПрием.Сотрудник КАК Сотрудник,
			|	ДокументПрием.Контрагент.ГруппаКрови КАК ГруппаКрови,
			|	ДокументПрием.Контрагент.RhФактор КАК RhФактор,
			|	ДокументПрием.Контрагент.АллергическиеРеакции КАК АллергическиеРеакции,
			|	ДокументПрием.Контрагент.Профессия КАК Профессия,
			|	ДокументПрием.Контрагент.Организация КАК Организация,
			|	ДокументПрием.Сотрудник.Должность КАК Должность
			|ИЗ
			|	Документ.Прием КАК ДокументПрием
			|ГДЕ
			|	ВЫБОР
			|			КОГДА &ВключаяНеПроведенные
			|				ТОГДА ИСТИНА
			|			ИНАЧЕ ДокументПрием.Проведен = ИСТИНА
			|		КОНЕЦ
			|	И ДокументПрием.Контрагент = &Пациент
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДокументПрием.Дата";
			
			Запрос.УстановитьПараметр("ВключаяНеПроведенные",?(ТипЗнч(ПараметрыПечати) = Тип("Структура"), ПараметрыПечати.Свойство("ПечатьВкладыша"), Ложь));
			Запрос.УстановитьПараметр("Пациент", ТекущийОбъект.ВладелецКарты);			

			Выборка = Запрос.Выполнить().Выбрать();
			Организация = "";
			Профессия = "";
			ГруппаКрови = "";
			RhФактор = "";
			АллергическиеРеакции = "";
			ДатаОсмотра = "";
			ДатаОсмотраВсеПриемы = "";
			ВрачДолжностьВсеРазличные = "";
			Диагноз = "";
			КодМКБ10 = "";
			Жалобы = "";
			ДанныеОбъективногоИсследования = "";
			ПеренесенныеИСопутствующиеЗаболевания = "";
			Лечение = "";
			ОсновнойДиагноз = "";
			Наставления = "";
			Анамнез = "";
			
			// если нет приемов ?
			ТаблицаПоПриемам = Новый ТаблицаЗначений;
			ТаблицаПоПриемам.Колонки.Добавить("ДатаОсмотра");
			ТаблицаПоПриемам.Колонки.Добавить("ВрачДолжность");
			ТаблицаПоПриемам.Колонки.Добавить("Жалобы");
			ТаблицаПоПриемам.Колонки.Добавить("Лечение");
			ТаблицаПоПриемам.Колонки.Добавить("ОсновнойДиагноз");
			ТаблицаПоПриемам.Колонки.Добавить("КодМКБ10");
			ТаблицаПоПриемам.Колонки.Добавить("Диагноз");
			ТаблицаПоПриемам.Колонки.Добавить("ДанныеОбъективногоИсследования");
			ТаблицаПоПриемам.Колонки.Добавить("ПеренесенныеИСопутствующиеЗаболевания");
			ТаблицаПоПриемам.Колонки.Добавить("Анамнез");
			ТаблицаПоПриемам.Колонки.Добавить("Наставления");
			
			Счетчик = 0;
			
			Пока Выборка.Следующий() Цикл
				
				Если ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина 
					И ТипЗнч(ПараметрыПечати.ПечатьВкладыша) = Тип("Массив") И ПараметрыПечати.ПечатьВкладыша.Найти(Выборка.Ссылка) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
			
				Если Счетчик = 0 Тогда
					Организация = Выборка.Организация;
					Профессия = Выборка.Профессия;
					ГруппаКрови = Выборка.ГруппаКрови;
					RhФактор = Выборка.RhФактор;
					АллергическиеРеакции = Выборка.АллергическиеРеакции;
				КонецЕсли;
				
				// Получить таблицу обследований	
				ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, Выборка.Ссылка);				
				Если ТаблицаОбследований.Количество() > 0 Тогда
					
					СтрокаПриема = ТаблицаПоПриемам.Добавить();
					ДатаОсмотра = Формат(Выборка.Дата, "ДФ=dd.MM.yyyy");
					СтрокаПриема.ДатаОсмотра = ДатаОсмотра;
					СтрокаПриема.ВрачДолжность = Строка(Выборка.Сотрудник) + ?(ЗначениеЗаполнено(Выборка.Должность), " (" + Строка(Выборка.Должность) + ")", "");
					
					НайденныеСтрокиЖалобы = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Жалобы"));
					НайденныеСтрокиДанныеОбъективногоИсследования = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","ДанныеОбъективногоИсследования"));
					НайденныеСтрокиПеренесенныеИСопутствующиеЗаболевания = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","ПеренесенныеИСопутствующиеЗаболевания"));
					НайденныеСтрокиЛечение = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Лечение"));
					НайденныеСтрокиДиагноз = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Диагноз"));						
					НайденныеСтрокиНаставления = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Наставления"));
					НайденныеСтрокиАнамнез = ТаблицаОбследований.НайтиСтроки(Новый Структура("РеквизитИмя","Анамнез"));
					
					Если НайденныеСтрокиДиагноз.Количество() > 0 Тогда
						Если Не ЗначениеЗаполнено(ОсновнойДиагноз) Тогда
							СтрокаПриема.ОсновнойДиагноз = НайденныеСтрокиДиагноз[0].РеквизитЗначение;
							СтрокаПриема.КодМКБ10 = НайденныеСтрокиДиагноз[0].КодМКБ10;
						Иначе
							СтрокаПриема.Диагноз = НайденныеСтрокиДиагноз[0].РеквизитЗначение;
						КонецЕсли;
						
						// только по первому приему
						Если Счетчик = 0 Тогда
							СтрокаДиагноз = ТаблицаДиагнозы.Добавить();
							СтрокаДиагноз.ДатаПостановки = ДатаОсмотра;
							СтрокаДиагноз.НаименованиеЗаболевания = НайденныеСтрокиДиагноз[0].РеквизитЗначение;
							СтрокаДиагноз.КодМКБ10 = НайденныеСтрокиДиагноз[0].КодМКБ10;
							СтрокаДиагноз.Врач = Выборка.Сотрудник;
						КонецЕсли;
						
					КонецЕсли;
					
					Если НайденныеСтрокиЖалобы.Количество() > 0 Тогда
						СтрокаПриема.Жалобы = НайденныеСтрокиЖалобы[0].РеквизитЗначение;
					КонецЕсли;
					
					Если НайденныеСтрокиДанныеОбъективногоИсследования.Количество() > 0 Тогда
						СтрокаПриема.ДанныеОбъективногоИсследования = НайденныеСтрокиДанныеОбъективногоИсследования[0].РеквизитЗначение;
					КонецЕсли;
					
					Если НайденныеСтрокиПеренесенныеИСопутствующиеЗаболевания.Количество() > 0 Тогда
						СтрокаПриема.ПеренесенныеИСопутствующиеЗаболевания = НайденныеСтрокиПеренесенныеИСопутствующиеЗаболевания[0].РеквизитЗначение;
					КонецЕсли;
					
					Если НайденныеСтрокиЛечение.Количество() > 0 Тогда
						СтрокаПриема.Лечение = НайденныеСтрокиЛечение[0].РеквизитЗначение;
					КонецЕсли;
					
					Если НайденныеСтрокиНаставления.Количество() > 0 Тогда
						СтрокаПриема.Наставления = НайденныеСтрокиНаставления[0].РеквизитЗначение;
					КонецЕсли;
					
					Если НайденныеСтрокиАнамнез.Количество() > 0 Тогда
						СтрокаПриема.Анамнез = НайденныеСтрокиАнамнез[0].РеквизитЗначение;
					КонецЕсли;
					
					Счетчик = Счетчик + 1;
				КонецЕсли;	
				
			КонецЦикла;
		//КонецЕсли;	
		
		Если ТаблицаДиагнозы.Количество() = 0 Тогда
			Сч = 0;  
			Пока Сч < 10 Цикл
				ОбластьМакета = Макет.ПолучитьОбласть("СтрокаЗаболевания");
				ТабличныйДокумент.Вывести(ОбластьМакета);	
				Сч = Сч + 1;
			КонецЦикла;			
			
		Иначе
			Для Каждого СтрокаДиагноз Из ТаблицаДиагнозы Цикл
				ОбластьМакета = Макет.ПолучитьОбласть("СтрокаЗаболевания");
				ОбластьМакета.Параметры.ДатаПостановки = СтрокаДиагноз.ДатаПостановки;
				ОбластьМакета.Параметры.НаименованиеЗаболевания = СтрокаДиагноз.НаименованиеЗаболевания;
				ОбластьМакета.Параметры.КодМКБ10 = СтрокаДиагноз.КодМКБ10;
				ОбластьМакета.Параметры.Врач  = СтрокаДиагноз.Врач;
				
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
		КонецЕсли;
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		Если Не ЗначениеЗаполнено(ПараметрыПечати) ИЛИ ТипЗнч(ПараметрыПечати) = Тип("Структура") И ПараметрыПечати.Свойство("ПечатьВкладыша") = Истина Тогда					
			// Стр 2
			// СоциальныйСтатус			
			ОбластьМакета = Макет.ПолучитьОбласть("СоциальныйСтатус");
			ОбластьМакета.Параметры.МестоРаботы = Организация + ?(ЗначениеЗаполнено(Профессия) И ЗначениеЗаполнено(Организация), " , ", "") + Профессия;
			ТабличныйДокумент.Вывести(ОбластьМакета);	
			
			// Диагнозы
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаЗаключительныеДиагнозы");
			ТабличныйДокумент.Вывести(ОбластьМакета);	
			
			МассивОбластейЗаписи = Новый Массив;	// для проверки, вмещается ли на лист
			ОбластьШапка	     = Макет.ПолучитьОбласть("ШапкаЗаключительныеДиагнозы");
			МассивОбластейЗаписи.Добавить(ОбластьШапка);			
			Для Каждого СтрокаДиагноз Из ТаблицаДиагнозы Цикл
				ОбластьСтрока	                     = Макет.ПолучитьОбласть("СтрокаЗаключительныеДиагнозы");			
				ОбластьСтрока.Параметры.ДатаДиагноза = СтрокаДиагноз.ДатаПостановки;
				ОбластьСтрока.Параметры.ЗаключительныйДиагноз = СтрокаДиагноз.НаименованиеЗаболевания;
				ОбластьСтрока.Параметры.Врач  = СтрокаДиагноз.Врач;
				ТабличныйДокумент.Вывести(ОбластьСтрока);
				МассивОбластейЗаписи.Добавить(ОбластьСтрока);		
			КонецЦикла;	
			ОбластьМакета = Макет.ПолучитьОбласть("Страница2Часть2");
			ОбластьМакета.Параметры.ГруппаКрови = ГруппаКрови;
			ОбластьМакета.Параметры.RhФактор = RhФактор;
			ОбластьМакета.Параметры.АллергическиеРеакции = АллергическиеРеакции;
			ТабличныйДокумент.Вывести(ОбластьМакета);	
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЕсли;
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		Если ТаблицаПоПриемам.Количество() <> 0 Тогда
			ДатаОсмотра = ТаблицаПоПриемам[0].ДатаОсмотра;
			ВрачДолжность = ТаблицаПоПриемам[0].ВрачДолжность;
			Жалобы = ТаблицаПоПриемам[0].Жалобы;
			ДанныеОбъективногоИсследования = ТаблицаПоПриемам[0].ДанныеОбъективногоИсследования;
			ПеренесенныеИСопутствующиеЗаболевания = ТаблицаПоПриемам[0].ПеренесенныеИСопутствующиеЗаболевания;
			КодМКБ10 = ТаблицаПоПриемам[0].КодМКБ10;    
			Диагноз = ТаблицаПоПриемам[0].Диагноз;
			Анамнез = ТаблицаПоПриемам[0].Анамнез;
			ОсновнойДиагноз = ТаблицаПоПриемам[0].ОсновнойДиагноз;
			Лечение = ТаблицаПоПриемам[0].Лечение;
			Наставления = ТаблицаПоПриемам[0].Наставления;
		КонецЕсли;
		
		///// Стр 3
		ОбластьМакета = Макет.ПолучитьОбласть("Страница3");
		ОбластьМакета.Параметры.ДатаОсмотраСтр3 = ДатаОсмотра;
		ОбластьМакета.Параметры.ВрачСпециальностьСтр3 = ВрачДолжность;
		ОбластьМакета.Параметры.ЖалобыПациентаСтр3Часть1 = Жалобы;
		ОбластьМакета.Параметры.ОбъективныеДанныеСтр3Часть1 = ДанныеОбъективногоИсследования;
		ОбластьМакета.Параметры.СопутствующийДиагноз1Стр3 = ПеренесенныеИСопутствующиеЗаболевания;
		ОбластьМакета.Параметры.ОсновнойДиагнозСтр3 = ОсновнойДиагноз;
		ОбластьМакета.Параметры.ОсновнойДиагнозКодМКБ10Стр3Часть1 = КодМКБ10;
		ОбластьМакета.Параметры.ОсновнойДиагнозКодМКБ10Стр3Часть2 = Диагноз;     
		ОбластьМакета.Параметры.АнамнезСтр3Часть1 = Анамнез;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		///// Стр 4
		ОбластьМакета = Макет.ПолучитьОбласть("ШапкаСтраница4");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ОбластьМакета = Макет.ПолучитьОбласть("Страница4");
		// для первого приема выводить все данные
		Если ТаблицаПоПриемам.Количество() <> 0 Тогда
			ОбластьМакета.Параметры.НаблюденияДата		= ДатаОсмотра;
			ОбластьМакета.Параметры.НаблюденияЖалобы	= Жалобы;
			ОбластьМакета.Параметры.НаблюденияДанные	= Лечение;
			ОбластьМакета.Параметры.РекомендацииСтр4	= Наставления;
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ОбластьМакета = Макет.ПолучитьОбласть("Страница4");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ОбластьМакета = Макет.ПолучитьОбласть("Страница4");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ОбластьМакета = Макет.ПолучитьОбласть("Страница4");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		///// Стр 7
		
		ОбластьМакета = Макет.ПолучитьОбласть("НачалоСтраницы7");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ОбластьМакета = Макет.ПолучитьОбласть("ОбластьВставки");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ОбластьМакета = Макет.ПолучитьОбласть("КонецСтраницы7");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
