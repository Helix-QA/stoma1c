// Функция вернет идентификатор строки данных по имени элемента.
//
Функция ИндексСтрокиДанныхДерваПоИменеиЭлемента(ИмяЭлемента)
	
	НомерСимвола = Найти(ИмяЭлемента,"_");
	Если НомерСимвола > 0 Тогда
		
		стрИд = Прав(ИмяЭлемента,СтрДлина(ИмяЭлемента) - НомерСимвола); 
		
		Возврат стрИд;
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
