// Функция, возвращает массив структур, содержащий данные результата запроса.
//
Функция РезультатЗапросаВМассивСтруктур(РезультатЗапроса)
	
	Результат = Новый Массив;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИменаСвойств = Новый Массив;
	
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ИменаСвойств.Добавить(Колонка.Имя);
	КонецЦикла;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		СтрокаДанных = Новый Структура(СтрСоединить(ИменаСвойств, ","));
		ЗаполнитьЗначенияСвойств(СтрокаДанных, Выборка);
		
		Результат.Добавить(СтрокаДанных);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

