// Процедура, СоздатьУсловноеОформление.
//
Процедура СоздатьУсловноеОформление()
	
	// Дата
	ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ПустоеВремя");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Формат", "ДФ=dd.MM.yyyy");
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЗадачаНазначеннаяДата");
	ПолеОформления.Использование = Истина;
	
	// Дата работы
	ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ПустоеВремяДатаРаботы");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;
	ЭлементОтбора.Использование  = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Формат", "ДФ=dd.MM.yyyy");
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ДатаРаботы");
	ПолеОформления.Использование = Истина;
	
	// Просроченная задача.
	ЭлементУФ 						= Список.УсловноеОформление.Элементы.Добавить();
	
	ГруппаОтбора 					= ЭлементУФ.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы 			= ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
	ГруппаОтбора.Использование 		= Истина;
	
	ЭлементОтбора 					= ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  	= Новый ПолеКомпоновкиДанных("ЗадачаНазначеннаяДата");
	ЭлементОтбора.ВидСравнения   	= ВидСравненияКомпоновкиДанных.Меньше;
	ЭлементОтбора.ПравоеЗначение 	= НачалоДня(ТекущаяДатаСеанса());
	ЭлементОтбора.Использование  	= Истина;
	
	ЭлементОтбора 					= ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  	= Новый ПолеКомпоновкиДанных("Выполнена");
	ЭлементОтбора.ВидСравнения   	= ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение 	= Ложь;
	ЭлементОтбора.Использование  	= Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 0, 0)));
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра("Текст", Нстр("ru = 'Просрочена'; en = 'Expired'"));
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("Просрочена");
	ПолеОформления.Использование = Истина;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить текст запрса для подсчета количества.
// 
Функция ПолучитьТекстЗапрсаДляПодсчетаКоличества()
	 
	// Текст запроса без отборов (чистый).
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Исполнитель
	|ПОМЕСТИТЬ ТаблицаИсполнителей
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В(&МассивСотрудников)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СоставСегментов.Сегмент
	|ИЗ
	|	РегистрСведений.СоставСегментов КАК СоставСегментов
	|ГДЕ
	|	СоставСегментов.ОбъектСегмента В(&МассивСотрудников)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ТаблицаСотрудниковПоОтборуСтруктурнойЕдиницы
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
	|	И НастройкиСотрудников.Сотрудник.ЭтоГруппа = ЛОЖЬ
	|	И НастройкиСотрудников.Сотрудник.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.Ссылка КАК Ссылка,
	|	Взаимодействие.Выполнена КАК Выполнена,
	|	Взаимодействие.ЗадачаНазначеннаяДатаНачало КАК ЗадачаНазначеннаяДатаНачало
	|ПОМЕСТИТЬ ТаблицаВзаимодействий
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	(Взаимодействие.СтруктурнаяЕдиница В (&МассивСтруктурныхЕдиниц)
	|			ИЛИ ВЫРАЗИТЬ(Взаимодействие.Исполнитель КАК Справочник.Сотрудники) В
	|				(ВЫБРАТЬ
	|					ТаблицаСотрудниковПоОтборуСтруктурнойЕдиницы.Сотрудник
	|				ИЗ
	|					ТаблицаСотрудниковПоОтборуСтруктурнойЕдиницы)
	|			ИЛИ ВЫРАЗИТЬ(Взаимодействие.Исполнитель КАК Справочник.СегментыСотрудников).СтруктурнаяЕдиница В (&МассивСтруктурныхЕдиниц)
	|			ИЛИ ВЫРАЗИТЬ(Взаимодействие.Исполнитель КАК Справочник.Заявки).СтруктурнаяЕдиница В (&МассивСтруктурныхЕдиниц)
	|			ИЛИ Взаимодействие.ИсполнительФактический В
	|				(ВЫБРАТЬ
	|					ТаблицаСотрудниковПоОтборуСтруктурнойЕдиницы.Сотрудник
	|				ИЗ
	|					ТаблицаСотрудниковПоОтборуСтруктурнойЕдиницы))
	|	И Взаимодействие.Исполнитель В
	|			(ВЫБРАТЬ
	|				ТаблицаИсполнителей.Исполнитель
	|			ИЗ
	|				ТаблицаИсполнителей КАК ТаблицаИсполнителей)
	|	И &УсловиеВидВзаимодействия
	|	И &УсловиеКонтрагент
	|	И &УсловиеИсполнительФактический
	|	И &УсловиеСтатус
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТаблицаЗадач.Ссылка) КАК КоличествоЗадач
	|ИЗ
	|	(ВЫБРАТЬ
	|		Взаимодействие.Ссылка КАК Ссылка
	|	ИЗ
	|		ТаблицаВзаимодействий КАК Взаимодействие
	|	ГДЕ
	|		Взаимодействие.Выполнена = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Взаимодействие.Ссылка
	|	ИЗ
	|		ТаблицаВзаимодействий КАК Взаимодействие
	|	ГДЕ
	|		Взаимодействие.Выполнена = ЛОЖЬ
	|		И Взаимодействие.ЗадачаНазначеннаяДатаНачало = ДАТАВРЕМЯ(1, 1, 1)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Взаимодействие.Ссылка
	|	ИЗ
	|		ТаблицаВзаимодействий КАК Взаимодействие
	|	ГДЕ
	|		Взаимодействие.Выполнена = ЛОЖЬ
	|		И Взаимодействие.ЗадачаНазначеннаяДатаНачало <> ДАТАВРЕМЯ(1, 1, 1)) КАК ТаблицаЗадач";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
// Процедура - Получить первоначальное количество задач.
//
Процедура ПолучитьПервоначальноеКоличествоЗадач()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(Взаимодействие.Ссылка) КАК КоличествоЗадач
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие";

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		УстановитьЗаголовокКоличествоЗадач(Выборка.КоличествоЗадач);
	КонецЕсли;	
	
КонецПроцедуры

