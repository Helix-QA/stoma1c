#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура инициирует заполнение документа
//
Процедура Обеспечить(ВидОбеспечения)
	
	СтруктураЗаполнения = ОбеспечитьНаСервере(ВидОбеспечения);
	ГруппировкаНоменклатура = Ложь;
	
	МассивСкладов = Новый Массив;
	Если СтруктураЗаполнения.Запасы.Количество() > 0 И СтруктураЗаполнения.Запасы[0].Свойство("Склад") Тогда
		Для Каждого ЭлементМассива Из СтруктураЗаполнения.Запасы Цикл
			Если МассивСкладов.Найти(ЭлементМассива.Склад) = Неопределено И ЗначениеЗаполнено(ЭлементМассива.Склад) И (ТипЗнч(ЭлементМассива.Склад) = Тип("СправочникСсылка.Склады") ИЛИ ТипЗнч(ЭлементМассива.Склад) = Тип("СправочникСсылка.Сотрудники")) Тогда
				МассивСкладов.Добавить(ЭлементМассива.Склад);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого ЭлементМассива Из СтруктураЗаполнения.ЗапасыСгруппированы Цикл 
		Если ЭлементМассива.Свойство("Номенклатура") Тогда 
			ГруппировкаНоменклатура = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;		
	
	Если ГруппировкаНоменклатура Тогда 		
		МассивЗапасовПоСкладу = ВернутьЗапасыПоСкладу(МассивСкладов, СтруктураЗаполнения.ЗапасыСгруппированы, ВидОбеспечения);
		Если МассивСкладов.Количество() > 1 Тогда
			ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, , ВидОбеспечения);
		ИначеЕсли МассивСкладов.Количество() = 1 Тогда
			Если ТипЗнч(МассивСкладов[0]) = Тип("СправочникСсылка.Склады") Тогда 
				ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, МассивСкладов[0], ВидОбеспечения);		
			ИначеЕсли ТипЗнч(МассивСкладов[0]) = Тип("СправочникСсылка.Сотрудники") Тогда
				ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, Неопределено, ВидОбеспечения);		
			КонецЕсли;
		ИначеЕсли МассивСкладов.Количество() = 0 Тогда	
			ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, , ВидОбеспечения);
		КонецЕсли;	
	Иначе 
		ПоказатьПредупреждение(Неопределено, "Установите в настройках отчета группировку Номенклатура!");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция возвращает структуру, необходимую для заполнения документа "ЗаказПоставщику"
//
Функция ОбеспечитьНаСервере(ВидОбеспечения)
	
	ТаблицаКритическихОстатков = Новый ТаблицаЗначений;
	
	// Макет компоновки
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(РеквизитФормыВЗначение("Отчет").СхемаКомпоновкиДанных, 
	Отчет.КомпоновщикНастроек.ПолучитьНастройки(), , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	// Компоновка данных
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	// Вывод результата
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ТаблицаКритическихОстатков = ПроцессорВывода.Вывести(ПроцессорКомпоновки); 
	
	СтруктураЗаполнения = Новый Структура;
	СтруктураЗаполнения.Вставить("ВидЦен", 				Справочники.ВидыЦен.Закупочная);
	СтруктураЗаполнения.Вставить("Запасы",				ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(ТаблицаКритическихОстатков));
	СтруктураЗаполнения.Вставить("ЗапасыСгруппированы", ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(СвернутьТаблицуЗапасов(ТаблицаКритическихОстатков, ВидОбеспечения)));
	СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница", 	ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Возврат СтруктураЗаполнения;

КонецФункции

&НаСервере
// Функция группирует таблицу остатков
//
Функция СвернутьТаблицуЗапасов(ТаблицаКритическихОстатков, ВидОбеспечения)
	
	Если ТаблицаКритическихОстатков.Колонки.Найти("Номенклатура") = Неопределено Тогда
		Возврат ТаблицаКритическихОстатков;
	Иначе	
		ТаблицаОстатков = ТаблицаКритическихОстатков.Скопировать(,);		
		Если ВидОбеспечения = "ЗаказПоставщику" ИЛИ ВидОбеспечения = "ПеремещениеЗапасов" Тогда 
			ТаблицаОстатков.Свернуть("Номенклатура", "Количество,КоличествоОстаток,КоличествоУпаковокКритическихОстатков,КоличествоУпаковокОбеспечения,КоличествоУпаковокОстатков,Обеспечение");	
		Иначе			
			Если ТаблицаОстатков.Колонки.Найти("Упаковка") = Неопределено Тогда 
				ТаблицаОстатков.Свернуть("Номенклатура", "Количество,КоличествоОстаток,КоличествоУпаковокКритическихОстатков,КоличествоУпаковокОбеспечения,КоличествоУпаковокОстатков,Обеспечение");	
			Иначе 
				ТаблицаОстатков.Свернуть("Номенклатура,Упаковка", "Количество,КоличествоОстаток,КоличествоУпаковокКритическихОстатков,КоличествоУпаковокОбеспечения,КоличествоУпаковокОстатков,Обеспечение");	
			КонецЕсли;	
		КонецЕсли;
		Возврат ТаблицаОстатков;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Функция возвращает массив запасов по выбранному складу
//
Функция ВернутьЗапасыПоСкладу(МассивСкладов, МассивЗапасы, ВидОбеспечения)
	
	Возврат ДобавитьСтавкуНДС(МассивЗапасы, ВидОбеспечения);	
	
КонецФункции

&НаСервереБезКонтекста
// Функция добавляет в массив ставку НДС
//
Функция ДобавитьСтавкуНДС(МассивЗапасовПоСкладу, ВидОбеспечения)
	
	Для Каждого ЭлементМассива Из МассивЗапасовПоСкладу Цикл 
		Если ЗначениеЗаполнено(ЭлементМассива.Номенклатура) Тогда 
			ЭлементМассива.Вставить("СтавкаНДС", ЭлементМассива.Номенклатура.СтавкаНДС);
			Если ВидОбеспечения = "ЗаказПоставщику" ИЛИ ВидОбеспечения = "ПеремещениеЗапасов" Тогда
				// ничего не делаем
			Иначе 	
				ЭлементМассива.КоличествоУпаковокОбеспечения = ?(ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию.Коэффициент = 0, ЭлементМассива.Обеспечение / 1, ЭлементМассива.Обеспечение / ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию.Коэффициент);
				Если НЕ ЭлементМассива.Свойство("Упаковка") Тогда
					ЭлементМассива.Вставить("Упаковка", ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию);
				Иначе 
					ЭлементМассива.Упаковка = ЭлементМассива.Номенклатура.УпаковкаПоУмолчанию;
				КонецЕсли;				
			КонецЕсли;	
		КонецЕсли;		
	КонецЦикла;	
	
	Возврат МассивЗапасовПоСкладу;
	
КонецФункции

&НаКлиенте
// Процедура заполняет документ
//
Процедура ЗаполнитьДокумент(МассивЗапасы, ВидЦен, СтруктурнаяЕдиница, ВыбранныйСклад = Неопределено, ВидОбеспечения)
	
	Если МассивЗапасы.Количество() > 0 Тогда
		Если ВидОбеспечения = "ЗаказПоставщику" ИЛИ ВидОбеспечения = "ЗаказПоставщикуВУпакПоУмолчанию" Тогда
			// Создаем заказ поставщику
			ЗаказПокупателяФорма = ПолучитьФорму("Документ.ЗаказПоставщику.ФормаОбъекта");
			ЗаказПокупателяФорма.Объект.ВидЦен = ВидЦен;
			Если ВыбранныйСклад <> Неопределено Тогда
				ЗаказПокупателяФорма.Объект.Склад = ВыбранныйСклад;
				ЗаказПокупателяФорма.Объект.СтруктурнаяЕдиница = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВыбранныйСклад, "СтруктурнаяЕдиница");
			Иначе
				ЗаказПокупателяФорма.Объект.Склад = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка");
				ЗаказПокупателяФорма.Объект.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
			КонецЕсли;
			//----------------------------------------
			Если МассивЗапасы.Количество() > 90 Тогда
				// Подключаем статус-бар				
				Коэфициент = 100/МассивЗапасы.Количество();
				Наращивание = Коэфициент;
				Для Каждого ЭлементМассива Из МассивЗапасы Цикл
					Состояние("Заполнение списка получателей!", ?(Цел(Наращивание) < 1, 1, Цел(Наращивание)), "Получение " + Строка(ЭлементМассива.Номенклатура) + "...", БиблиотекаКартинок.Информация32);				
					Если Не ЗначениеЗаполнено(ЭлементМассива.Номенклатура) ИЛИ ЭлементМассива.Обеспечение < 1 Тогда
						Продолжить;
					КонецЕсли;
					НоваяСтрока = ЗаказПокупателяФорма.Объект.Запасы.Добавить();
					НоваяСтрока.Номенклатура = ЭлементМассива.Номенклатура;
					Если ЭлементМассива.КоличествоУпаковокОбеспечения = 0 ИЛИ НЕ ЭлементМассива.Свойство("Упаковка")Тогда				
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.Обеспечение;
					Иначе 
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.КоличествоУпаковокОбеспечения;
						НоваяСтрока.Упаковка 			= ЭлементМассива.Упаковка;
					КонецЕсли;
					НоваяСтрока.СтавкаНДС 				= ЭлементМассива.СтавкаНДС;
					Наращивание = Наращивание + Коэфициент;
				КонецЦикла;
			Иначе
				Для Каждого ЭлементМассива Из МассивЗапасы Цикл
					Если Не ЗначениеЗаполнено(ЭлементМассива.Номенклатура) ИЛИ ЭлементМассива.Обеспечение < 1 Тогда
						Продолжить;
					КонецЕсли;
					НоваяСтрока = ЗаказПокупателяФорма.Объект.Запасы.Добавить();
					НоваяСтрока.Номенклатура = ЭлементМассива.Номенклатура;
					Если ЭлементМассива.КоличествоУпаковокОбеспечения = 0 ИЛИ НЕ ЭлементМассива.Свойство("Упаковка")Тогда				
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.Обеспечение;
					Иначе 
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.КоличествоУпаковокОбеспечения;
						НоваяСтрока.Упаковка 			= ЭлементМассива.Упаковка;
					КонецЕсли;
					НоваяСтрока.СтавкаНДС 				= ЭлементМассива.СтавкаНДС;
				КонецЦикла;
				
			КонецЕсли;
			ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЗаказПокупателяФорма, "Запасы");
			ЗаказПокупателяФорма.Открыть();
		Иначе
			// Создаем перемещение запасов
			ПеремещениеЗапасовФорма = ПолучитьФорму("Документ.ПеремещениеЗапасов.ФормаОбъекта");
			Если ВыбранныйСклад <> Неопределено Тогда
				ПеремещениеЗапасовФорма.Объект.СкладПолучатель = ВыбранныйСклад;
				ПеремещениеЗапасовФорма.Объект.СтруктурнаяЕдиницаПолучатель = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВыбранныйСклад, "СтруктурнаяЕдиница");
			Иначе
				ПеремещениеЗапасовФорма.Объект.СкладПолучатель = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка");
				ПеремещениеЗапасовФорма.Объект.СтруктурнаяЕдиницаПолучатель = СтруктурнаяЕдиница;
			КонецЕсли;
			
			Если МассивЗапасы.Количество() > 90 Тогда
				// Подключаем статус-бар
				Коэфициент = 100/МассивЗапасы.Количество();
				Наращивание = Коэфициент;
				Для Каждого ЭлементМассива Из МассивЗапасы Цикл
					Состояние("Заполнение списка получателей!", ?(Цел(Наращивание) < 1, 1, Цел(Наращивание)), "Получение " + Строка(ЭлементМассива.Номенклатура) + "...", БиблиотекаКартинок.Информация32);				
					Если Не ЗначениеЗаполнено(ЭлементМассива.Номенклатура) ИЛИ ЭлементМассива.Обеспечение < 1 Тогда
						Продолжить;
					КонецЕсли;
					НоваяСтрока = ПеремещениеЗапасовФорма.Объект.Запасы.Добавить();
					НоваяСтрока.Номенклатура = ЭлементМассива.Номенклатура;
					Если ЭлементМассива.КоличествоУпаковокОбеспечения = 0 ИЛИ НЕ ЭлементМассива.Свойство("Упаковка")Тогда				
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.Обеспечение;
					Иначе 
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.КоличествоУпаковокОбеспечения;
						НоваяСтрока.Упаковка 			= ЭлементМассива.Упаковка;
					КонецЕсли;
					НоваяСтрока.СтавкаНДС 				= ЭлементМассива.СтавкаНДС;
					Наращивание = Наращивание + Коэфициент;
				КонецЦикла;
			Иначе
				Для Каждого ЭлементМассива Из МассивЗапасы Цикл
					Если Не ЗначениеЗаполнено(ЭлементМассива.Номенклатура) ИЛИ ЭлементМассива.Обеспечение < 1 Тогда
						Продолжить;
					КонецЕсли;
					НоваяСтрока = ПеремещениеЗапасовФорма.Объект.Запасы.Добавить();
					НоваяСтрока.Номенклатура = ЭлементМассива.Номенклатура;
					Если ЭлементМассива.КоличествоУпаковокОбеспечения = 0 ИЛИ НЕ ЭлементМассива.Свойство("Упаковка")Тогда				
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.Обеспечение;
					Иначе 
						НоваяСтрока.КоличествоУпаковок 	= ЭлементМассива.КоличествоУпаковокОбеспечения;
						НоваяСтрока.Упаковка 			= ЭлементМассива.Упаковка;
					КонецЕсли;
				КонецЦикла;
				
			КонецЕсли;
			ПеремещениеЗапасовФорма.Открыть();			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти



