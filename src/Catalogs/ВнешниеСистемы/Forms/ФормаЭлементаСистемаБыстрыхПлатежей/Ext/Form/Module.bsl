&НаКлиенте
// Функция, возвращает индекс элемента по его наименованию.
//
Функция ПолучитьИндексНаименования(НаименованиеЭлемента)
	
	НачалоИндекса = СтрНайти(НаименованиеЭлемента, "_", НаправлениеПоиска.СКонца);
	Возврат Сред(НаименованиеЭлемента, НачалоИндекса + 1);
	
КонецФункции

&НаСервере
// Процедура,  осуществляет проверку заполнения структурно эквайринговых соответсвий.
//
Функция СтруктурноЭквайринговыеСоответсвияЗаполненыВерно()
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.СтруктурноЭквайринговыеСоответствия) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить хотя бы одно структурно-эквайринговое соответствие");
		Возврат Ложь;
	КонецЕсли;
	
	МассивСтрок = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("ЭквайринговыйТерминал", Справочники.ЭквайринговыеТерминалы.ПустаяСсылка()));
	
	Для Каждого НайденнаяСтрока Из МассивСтрок Цикл
		ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Удалить(НайденнаяСтрока);
	КонецЦикла;
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.СтруктурноЭквайринговыеСоответствия Цикл
		
		СтруктурнаяЕдиница	  = СтрокаТЧ.СтруктурнаяЕдиница;
		ЭквайринговыйТерминал = СтрокаТЧ.ЭквайринговыйТерминал;
		
		Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			Продолжить;
			
		ИначеЕсли Не ЗначениеЗаполнено(ЭквайринговыйТерминал) Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru='Для структурной единицы: %1 не указан ни один эквайринговый терминал';en='For structural unit: %1 is not specified any one acquiring terminal'"), СокрЛП(СтруктурнаяЕдиница));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат Ложь;
		КонецЕсли;
		
		КассаОплаты = Справочники.Кассы.ПолучитьКассуОплатыИПараметрыФискализации(ЭквайринговыйТерминал);
		
		Если Не ЗначениеЗаполнено(КассаОплаты) Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru='К эквайринговому терминалу %1 не привязана касса оплаты';en='The payment cashier is not tied to the acquiring terminal %1'"), СокрЛП(ЭквайринговыйТерминал));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
