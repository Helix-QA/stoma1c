// Функция возвращает массив выбранных сотрудников и групп, выполняется на клиенте
//
// Возвращаемое значение:
//   Массив, ссылки на сотрудников и групп
//
Функция ВернутьОтборПоСотрудникам()
	
	МассивОтбораСотрудников = Новый Массив;	
	
	Если (ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач) 
		и ПЗОтборПоСотрудникамРежимФильтра = 0 и ПЗФильтраГрафикаРежим = 0 Тогда
		МассивОтбораСотрудников.Добавить(ДеревоСотрудниковРучн.ПолучитьЭлементы()[0].Сотрудник);		
		Возврат МассивОтбораСотрудников;
	КонецЕсли;
	
	Если ПЗФильтраГрафикаРежим <> 0 Тогда
		МассивОтбораСотрудников.Добавить("Все");
		Возврат МассивОтбораСотрудников;
	КонецЕсли;	
	Для Каждого ЭлементМассива Из Элементы.ДеревоСотрудников.ВыделенныеСтроки Цикл
		Если ДеревоСотрудниковРучн.НайтиПоИдентификатору(ЭлементМассива) = Неопределено Тогда
			МассивОтбораСотрудников.Добавить("Все");
		Иначе
			МассивОтбораСотрудников.Добавить(ДеревоСотрудниковРучн.НайтиПоИдентификатору(ЭлементМассива).Сотрудник);
		КонецЕсли;
	КонецЦикла;	
	Если Элементы.ДеревоСотрудников.ВыделенныеСтроки.Количество() = 0 Тогда
		МассивОтбораСотрудников.Добавить("Все");		
	КонецЕсли;
	
	Возврат МассивОтбораСотрудников;
	
КонецФункции

