// Функция, проверяет отключены ли все фильтры.
//
Функция ВсеФильтрыОтключены(Фильтры)
	
	Для Каждого Фильтр Из Фильтры Цикл
		Если Фильтр.Значение = Истина Тогда
			Возврат Ложь;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Функция - Получить представление даты
//
// Параметры:
//  Период	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеДаты(Период)
	
	Если НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(Период) Тогда
		
		Дата = "Сегодня";
		
	ИначеЕсли НачалоДня(НачалоДня(ТекущаяДатаСеанса())-1) = НачалоДня(Период) Тогда
		
		Дата = "Вчера";
		
	ИначеЕсли НачалоДня(КонецДня(ТекущаяДатаСеанса())+1) = НачалоДня(Период) Тогда
		
		Дата = "Завтра";
		
	Иначе
		
		Дата = Формат(Период, "ДЛФ=DD");
		
	КонецЕсли;
	
	Возврат Дата;

КонецФункции

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПредварительнойЗаписи(Событие, СтатусЗаписи, Запланировано = Ложь)
	
	Представление = "";
		
	Состояние = "";
	Если Событие.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)'");
	ИначеЕсли НЕ Событие.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)'");
	КонецЕсли;
	
	Статус = "Предварительная запись";
	
	ДатаДокумента = "на " + Формат(Событие.Дата, "ДФ=HH:мм") + ?(Запланировано, ", " + Формат(Событие.Дата, "ДЛФ=DD"), "") + " {Статус}";
	
	Если СтатусЗаписи = Перечисления.СтатусыСобытия.ПриемОтменен
		Или СтатусЗаписи = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда 
		ДатаДокумента = СтрЗаменить(ДатаДокумента, "{Статус}", "<span style='color: red;'>(" + СокрЛП(Строка(СтатусЗаписи)) + ")</span>");	
	Иначе
		ДатаДокумента = СтрЗаменить(ДатаДокумента, "{Статус}", "(" + СокрЛП(Строка(СтатусЗаписи)) + ")");
	КонецЕсли;
	
	СтруктураДатаНачалаИДатаОкончания = Документы.Событие.ПолучитьПродолжительностьСобытия(Событие);
	
	ВремяСобытияВМинутах = "";
	
	Если ЗначениеЗаполнено(СтруктураДатаНачалаИДатаОкончания) 
		И ЗначениеЗаполнено(СтруктураДатаНачалаИДатаОкончания.ДатаНачала) 
		И ЗначениеЗаполнено(СтруктураДатаНачалаИДатаОкончания.ДатаОкончания) Тогда
		
		ВремяСобытияВМинутах = Строка(Окр(((СтруктураДатаНачалаИДатаОкончания.ДатаОкончания - СтруктураДатаНачалаИДатаОкончания.ДатаНачала)/60), 0, РежимОкругления.Окр15как20)) + " " + "мин.";
		
	КонецЕсли;
		
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 %2 %3 %4'"),
	Статус,
	ВремяСобытияВМинутах,
	ДатаДокумента,
	Состояние);
	
	Возврат Представление;
	
КонецФункции

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПриема(Прием, СтатусВизита, Запланировано = Ложь)
	
	Представление = "";
		
	Состояние = "";
	Если Прием.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)'");
	ИначеЕсли НЕ Прием.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)'");
	КонецЕсли;
	
	ВремяПриемаВМинутах = "";

	Если ЗначениеЗаполнено(Прием.ВремяНачалаПриема) И ЗначениеЗаполнено(Прием.ВремяОкончанияПриема) Тогда 	
		ВремяПриемаВМинутах = Строка(Окр((Прием.ВремяОкончанияПриема - Прием.ВремяНачалаПриема)/60, 0, РежимОкругления.Окр15как20)) + " " + "мин.";	
	КонецЕсли;
	
	Статус = "Прием";
	ДатаДокумента = "в " + Формат(Прием.ВремяНачалаПриема, "ДФ=HH:мм") + ?(Запланировано, ", " + Формат(Прием.ВремяНачалаПриема, "ДЛФ=DD"), "");
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 %2 %3 %4'"),
	Статус,
	ВремяПриемаВМинутах,
	ДатаДокумента,
	Состояние);
	
	Возврат Представление;
	
КонецФункции 

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеНарядЗаказа(НарядЗаказ, Статус, Запланировано = Ложь)
	
	Представление = "";
		
	Состояние = "";
	Если НарядЗаказ.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)'");
	ИначеЕсли НЕ НарядЗаказ.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)'");
	КонецЕсли;
	
	ПредставлениеНарядЗаказа = "Наряд заказ";
	ДатаДокумента = Формат(НарядЗаказ.Дата, "ДФ=HH:мм") + ?(Запланировано, ", " + Формат(НарядЗаказ.Дата, "ДЛФ=DD"), "");
	
	Статус = ?(Статус = "Нет", "(Открыт) ", "(Закрыт) "); 
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 %2 %3'"),
	ПредставлениеНарядЗаказа,
	ДатаДокумента,
	Статус);
	
	Возврат Представление;
	
КонецФункции

// Функция - Представление ФИОСотрудника
//
// Параметры:
//  Сотрудник	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПредставлениеФИОСотрудника(Сотрудник) 
	
	УстановитьПривилегированныйРежим(Истина);
	Если ЗначениеЗаполнено(Сотрудник.Фамилия) ИЛИ ЗначениеЗаполнено(Сотрудник.Имя) Тогда 
		Возврат ?(ЗначениеЗаполнено(Сотрудник.Фамилия), Сотрудник.Фамилия + "","")
		+ ?(ЗначениеЗаполнено(Сотрудник.Имя)," " + Лев(СокрЛП(Сотрудник.Имя), 1) + ".","")
		+ ?(ЗначениеЗаполнено(Сотрудник.Отчество)," " + Лев(СокрЛП(Сотрудник.Отчество), 1) + ".", "");
	Иначе
		Возврат Сотрудник.Наименование;
	КонецЕсли;	
	
КонецФункции

// Функция, возвращает структуру контактной информации.
//
Функция ПолучитьКонтактнуюИнформациюКлиента(Клиент, ДобавитьКодСтраны = Ложь) Экспорт
	
	EmailСтроки = Клиент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
	Email = Неопределено;
	Если EmailСтроки.Количество() > 0 Тогда
	  Email = EmailСтроки[0].АдресЭП;
	КонецЕсли;
	
	ТелефонСтроки = Клиент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
	НомерТелефона = Неопределено;
	Если ТелефонСтроки.Количество() > 0 Тогда
		
		НомерТелефона = ТелефонСтроки[0].НомерТелефона;
		
		СписокПолей = Новый СписокЗначений;
		УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(НомерТелефона, СписокПолей); 
		НомерТелефона = ?(ДобавитьКодСтраны, СписокПолей[0].Значение, "") + СписокПолей[1].Значение + СписокПолей[2].Значение;
		
	КонецЕсли;
	
	Возврат Новый Структура("Email, Телефон", Email, НомерТелефона);
	
КонецФункции

// Представление ФИО
//
Функция ПредставлениеФИОКонтрагента(Контаргент, ДобавитьТелефон = Ложь) Экспорт
	
	Если ЗначениеЗаполнено(Контаргент.Фамилия) ИЛИ ЗначениеЗаполнено(Контаргент.Имя) Тогда 
		Возврат ?(ЗначениеЗаполнено(Контаргент.Фамилия), Контаргент.Фамилия + "","")
		+ ?(ЗначениеЗаполнено(Контаргент.Имя)," " + Лев(Контаргент.Имя, 1) + ".","")
		+ ?(ЗначениеЗаполнено(Контаргент.Отчество)," " + Лев(Контаргент.Отчество, 1) + ".", "")
		+ ?(ДобавитьТелефон и ЗначениеЗаполнено(Контаргент.Телефон),", "+Контаргент.Телефон, "");
	Иначе
		Возврат Контаргент.Наименование;
	КонецЕсли;	
	
КонецФункции

// Функция - возвращает массив сообщений для исключения основного запроса.
// 
// Возвращаемое значение:
//   Массив 
//
Функция ПолучитьМассивСообщенийИсключенияПоСделке(Контрагент, Сделка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ПОМЕСТИТЬ ВТТелефоны
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ОбъектыОтбора
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка = &Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заявки.Ссылка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ОсновнойКлиент = &Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	КонтактыМессенджеров.Идентификатор КАК Идентификатор
	|ПОМЕСТИТЬ ТаблицаИдентификаторовКонтактовМессенджеров
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|ГДЕ
	|	КонтактыМессенджеров.ОбъектИдентификации В
	|			(ВЫБРАТЬ
	|				ОбъектыОтбора.Ссылка КАК Ссылка
	|			ИЗ
	|				ОбъектыОтбора КАК ОбъектыОтбора)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Событие.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТОбъектыТриггерныхСобытийИсключения
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.ПометкаУдаления = ЛОЖЬ
	|	И Событие.Сделка <> &Сделка
	|	И Событие.Контрагент = &Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Прием.Ссылка
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.ПометкаУдаления = ЛОЖЬ
	|	И Прием.Сделка <> &Сделка
	|	И Прием.Контрагент = &Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Сделки.Ссылка
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.Ссылка <> &Сделка
	|	И Сделки.Контрагент = &Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЖурналРегистрацииТриггерныхСобытий.SMSРассылка КАК SMSРассылка,
	|	ЖурналРегистрацииТриггерныхСобытий.IDСообщения КАК IDСообщения,
	|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ ВТПредварительныеСообщения
	|ИЗ
	|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
	|ГДЕ
	|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия В
	|			(ВЫБРАТЬ
	|				ВТОбъектыТриггерныхСобытийИсключения.Ссылка КАК Ссылка
	|			ИЗ
	|				ВТОбъектыТриггерныхСобытийИсключения КАК ВТОбъектыТриггерныхСобытийИсключения)
	|	И (ЖурналРегистрацииТриггерныхСобытий.SMSРассылка <> ЗНАЧЕНИЕ(Документ.РассылкаСообщений.ПустаяСсылка)
	|			ИЛИ ЖурналРегистрацииТриггерныхСобытий.IDСообщения <> """")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатусыСообщений.IDСообщения КАК ИДСообщения
	|ПОМЕСТИТЬ ВТИдСообщенийПоСделке
	|ИЗ
	|	РегистрСведений.СтатусыСообщений КАК СтатусыСообщений
	|ГДЕ
	|	(СтатусыСообщений.РассылкаСообщений, СтатусыСообщений.Получатель) В
	|			(ВЫБРАТЬ
	|				ВТПредварительныеСообщения.SMSРассылка КАК SMSРассылка,
	|				ВТПредварительныеСообщения.Контрагент КАК Контрагент
	|			ИЗ
	|				ВТПредварительныеСообщения КАК ВТПредварительныеСообщения
	|			ГДЕ
	|				ВТПредварительныеСообщения.SMSРассылка <> ЗНАЧЕНИЕ(Документ.РассылкаСообщений.ПустаяСсылка))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЖурналСообщений.ИдСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдДиалога В
	|			(ВЫБРАТЬ
	|				ВТПредварительныеСообщения.IDСообщения КАК IDСообщения
	|			ИЗ
	|				ВТПредварительныеСообщения КАК ВТПредварительныеСообщения
	|			ГДЕ
	|				ВТПредварительныеСообщения.IDСообщения <> """")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдСообщения В
	|			(ВЫБРАТЬ
	|				ВТИдСообщенийПоСделке.ИДСообщения КАК ИДСообщения
	|			ИЗ
	|				ВТИдСообщенийПоСделке КАК ВТИдСообщенийПоСделке)
	|	И ЖурналСообщений.ИдКлиента В
	|			(ВЫБРАТЬ
	|				ТаблицаИдентификаторовКонтактовМессенджеров.Идентификатор КАК Идентификатор
	|			ИЗ
	|				ТаблицаИдентификаторовКонтактовМессенджеров КАК ТаблицаИдентификаторовКонтактовМессенджеров)
	|	И ЖурналСообщений.СлужебноеСообщение = ЛОЖЬ
	|	И ЖурналСообщений.ОжиданиеСообщения = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Контрагент"				, Контрагент);
	Запрос.УстановитьПараметр("Сделка"					, Сделка);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ИдСообщения");
	
КонецФункции

#КонецОбласти

#Область РаботаСФИО

// Функция раскладывает ФИО в структуру.
//
// Параметры:
//	 ФИО - строка - наименование.
//
// Возвращаемое значение:
//	 Структура - со свойствами: 
//     * Фамилия  - Строка
//     * Имя      - Строка
//     * Отчество - Строка
//
Функция ФамилияИмяОтчество(Знач ФИО) Экспорт
	
	СтруктураФИО = Новый Структура("Фамилия, Имя, Отчество");
	
	МассивПодстрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ФИО, " ");
	
	Если МассивПодстрок.Количество() > 0 Тогда
		СтруктураФИО.Вставить("Фамилия", МассивПодстрок[0]);
		Если МассивПодстрок.Количество() > 1 Тогда
			СтруктураФИО.Вставить("Имя", МассивПодстрок[1]);
		КонецЕсли;
		Если МассивПодстрок.Количество() > 2 Тогда
			Отчество = "";
			Для Шаг = 2 По МассивПодстрок.Количество()-1 Цикл
				Отчество = Отчество + МассивПодстрок[Шаг] + " ";
			КонецЦикла;
			СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(Отчество, 1);
			СтруктураФИО.Вставить("Отчество", Отчество);
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтруктураФИО;
	
КонецФункции

#КонецОбласти

