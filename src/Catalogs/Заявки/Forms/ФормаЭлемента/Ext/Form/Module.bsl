// Функция - Получить массив подчиненных элементов.
//
// Параметры:
//  ПодчиненныеЭлементы	 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция ПолучитьМассивПодчиненныхЭлементов(ПодчиненныеЭлементы, ИсключаемыйЭлемент = Неопределено)
	
	МассивЭлементов = Новый Массив;
	
	Если ИсключаемыйЭлемент <> Неопределено Тогда
		
		Для Каждого Элемент Из ПодчиненныеЭлементы Цикл
			
			Если Элемент <> ИсключаемыйЭлемент Тогда
				МассивЭлементов.Добавить(Элемент);
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		Для Каждого Элемент Из ПодчиненныеЭлементы Цикл
			МассивЭлементов.Добавить(Элемент);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивЭлементов;
	
КонецФункции

