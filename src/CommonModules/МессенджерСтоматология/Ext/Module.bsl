// Функция - Chat api получить данные диалога
//
// Параметры:
//  ИдКлиента				 - 	 - 
//  ПараметрыВнешнейСистемы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ChatApi_ПолучитьДанныеДиалога(ИдКлиента, ПараметрыВнешнейСистемы, ВнешняяСистема) Экспорт
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы) Тогда
		ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	КонецЕсли;
	
	РезультатОперации = Новый Структура("ВыполненоУспешно, ОписаниеОшибки, Идентификатор, НаименованиеКлиента, ФотоКлиента", Ложь);
	
	Попытка		
		
		ПараметрыЗапроса = Новый Структура();
		ПараметрыЗапроса.Вставить("token" , ПараметрыВнешнейСистемы.ApiToken);
		ПараметрыЗапроса.Вставить("chatId", ИдКлиента);		
		
		РезультатЗапроса  = ChatApi_ВыполнитьGETЗапрос("/instance" + ПараметрыВнешнейСистемы.ChannelId + "/dialog", ПараметрыЗапроса);		
		
		Если РезультатЗапроса.Свойство("id") И ЗначениеЗаполнено(РезультатЗапроса.id) Тогда
			
			РезультатОперации.ВыполненоУспешно		= Истина;
			РезультатОперации.Идентификатор			= РезультатЗапроса.id;
			РезультатОперации.НаименованиеКлиента	= РезультатЗапроса.name;
			РезультатОперации.ФотоКлиента			= РезультатЗапроса.image;
			
		Иначе
			РезультатОперации.ОписаниеОшибки	= "Нет данных по диалогу";
		КонецЕсли;
		
	Исключение
		РезультатОперации.ОписаниеОшибки	= "Возникла исключительная ошибка при получении данных диалога: " + ОписаниеОшибки();
	КонецПопытки;	
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Chat api получить данные диалога
//
// Параметры:
//  ИдКлиента				 - 	 - 
//  ПараметрыВнешнейСистемы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция GreenApi_ПолучитьДанныеДиалога(ИдКлиента, ПараметрыВнешнейСистемы, ВнешняяСистема, ЭтоГруппа = Ложь) Экспорт
	
	Если Не ЗначениеЗаполнено(ПараметрыВнешнейСистемы) Тогда
		ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	КонецЕсли;
	
	Если СтрНайти(ПараметрыВнешнейСистемы.UrlApi, "chat-api") Тогда
		Возврат ChatApi_ПолучитьДанныеДиалога(ИдКлиента, ПараметрыВнешнейСистемы, ВнешняяСистема);
	КонецЕсли;
	
	РезультатОперации = Новый Структура("ВыполненоУспешно, ОписаниеОшибки, Идентификатор, НаименованиеКлиента, ФотоКлиента", Ложь);
	РезультатОперации.Идентификатор = ИдКлиента;
	
	Попытка		
		
		Сервер	= ПараметрыВнешнейСистемы.UrlApi + "/waInstance" + ПараметрыВнешнейСистемы.ChannelId;
		Таймаут	= 5;
		
		Соединение = Новый HTTPСоединение(Сервер,,,,, Таймаут, Новый ЗащищенноеСоединениеOpenSSL);
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "application/json");
		
		ЗапросАватара = Новый HTTPЗапрос("/GetAvatar/" + ПараметрыВнешнейСистемы.ApiToken, Заголовки);
		
		ПараметрыЗапросаАватара = Новый Структура;
		ПараметрыЗапросаАватара.Вставить("chatId", ИдКлиента);		
		
		ТелоЗапросаАватара = КодироватьВJSON(ПараметрыЗапросаАватара);
		
		ЗапросАватара.УстановитьТелоИзСтроки(ТелоЗапросаАватара);
		
		ОтветАватар				 = Соединение.ОтправитьДляОбработки(ЗапросАватара);
		ТелоОтветаАватар		 = ОтветАватар.ПолучитьТелоКакСтроку();
		СтруктураОтветаАватар	 = ДекодироватьИзJSON(ТелоОтветаАватар);
		
		СтруктураОтветаАватар.Свойство("existsWhatsapp"	, РезультатОперации.ВыполненоУспешно);
		СтруктураОтветаАватар.Свойство("urlAvatar"		, РезультатОперации.ФотоКлиента);
		
		Если ЭтоГруппа Тогда
			
			ЗапросДанныхГруппы = Новый HTTPЗапрос("/GetGroupData/" + ПараметрыВнешнейСистемы.ApiToken);
			
			ПараметрыЗапросаДанныхГруппы = Новый Структура;
			ПараметрыЗапросаДанныхГруппы.Вставить("groupId", ИдКлиента);
			
			ТелоЗапросаДанныхГруппы = КодироватьВJSON(ПараметрыЗапросаДанныхГруппы);
			
			ЗапросДанныхГруппы.УстановитьТелоИзСтроки(ТелоЗапросаДанныхГруппы);
			
			ОтветДанныеГруппы			 = Соединение.ОтправитьДляОбработки(ЗапросДанныхГруппы);
			ТелоОтветаДанныеГруппы		 = ОтветДанныеГруппы.ПолучитьТелоКакСтроку();
			СтруктураОтветаДанныеГруппы	 = ДекодироватьИзJSON(ТелоОтветаДанныеГруппы);
			
			СтруктураОтветаДанныеГруппы.Свойство("subject", РезультатОперации.НаименованиеКлиента);
			
		КонецЕсли;
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		
	КонецПопытки;	
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция, отправляет сообщение Instagram.
//
Функция Instagram_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения = Неопределено) Экспорт
	
	Попытка
		
		ИдКлиента = ПараметрыКлиента.ИдКлиента;
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "application/json");
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());			
		HTTPЗапросЗахватДиалога = Новый HTTPЗапрос("/v11.0/me/take_thread_control?access_token=" + ПараметрыВнешнейСистемы.ApiToken, Заголовки);
		
		HTTPЗапросЗахватДиалога.УстановитьТелоИзСтроки("{""recipient"": {""id"": """ + ИдКлиента + """}}");
		
		ЗахватДиалогаОтвет			 = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапросЗахватДиалога);
		СтруктураОтветаЗахватДиалога = ДекодироватьИзJSON(ЗахватДиалогаОтвет.ПолучитьТелоКакСтроку());
		
		Если Не (СтруктураОтветаЗахватДиалога.Свойство("success") И СтруктураОтветаЗахватДиалога.success = Истина) Тогда
			
			РезультатОперации = Новый Структура;	
			РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
			РезультатОперации.Вставить("ОписаниеОшибки"  , "Ошибка получения контроля над диалогом. Не удалось отправить сообщение.");
			
			Возврат РезультатОперации;
			
		КонецЕсли;
		
		HTTPЗапрос = Новый HTTPЗапрос("/v11.0/me/messages?access_token=" + ПараметрыВнешнейСистемы.ApiToken, Заголовки);
		
		СтруктураЗапроса = Новый Структура;
		СтруктураЗапроса.Вставить("recipient"	, Новый Структура("id"	, ИдКлиента));
		СтруктураЗапроса.Вставить("message"		, Новый Структура("text", ТекстСообщения));
		
		HTTPЗапрос.УстановитьТелоИзСтроки(КодироватьВJSON(СтруктураЗапроса));
		
		Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		СтруктураОтвета = ДекодироватьИзJSON(Ответ.ПолучитьТелоКакСтроку());
		
		Если СтруктураОтвета.Свойство("message_id") Тогда
			
			ИдСообщения = СтруктураОтвета.message_id;
			
			РезультатОперации = Новый Структура;
			РезультатОперации.Вставить("ВыполненоУспешно", Истина);
			РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
			РезультатОперации.Вставить("ИдКанала"     	 , "");
			
		ИначеЕсли СтруктураОтвета.Свойство("error") И СтруктураОтвета.error.Свойство("code") И СтруктураОтвета.error.code = 10 Тогда
			
			РезультатОперации = Новый Структура;
			РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
			РезультатОперации.Вставить("ОписаниеОшибки"  , "Для продолжения диалога необходимо получить входящее сообщение.");
			
		Иначе
			
			РезультатОперации = Новый Структура;
			РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
			РезультатОперации.Вставить("ОписаниеОшибки"  , "Не удалось отправить сообщение.");
			
		КонецЕсли;
			
	Исключение
		РезультатОперации = Новый Структура;
		РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
		РезультатОперации.Вставить("ОписаниеОшибки"	 , "Ошибка соединения " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция, создает подписку на webhook Instagram.
//
Функция Instagram_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения)
	
	ВыполненоУспешно = Ложь;
	
