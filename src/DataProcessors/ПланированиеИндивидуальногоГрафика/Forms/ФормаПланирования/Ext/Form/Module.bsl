&НаКлиенте
// Процедура - Выбор времени из списка
// 
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ВыборВремениИзСписка(ВыбранныйЭлемент, ДополнительныеПараметры = Неопределено) Экспорт
	
	Отказ = Ложь;
	
	Если ВыбранныйЭлемент = Неопределено Тогда 
		Возврат;
	Иначе
		// Запоминаем значение
		ЗначениеДоИзменения = ДополнительныеПараметры.ДанныеЭлемента.Значение;
		// Моделируем новое значение
		Если ДополнительныеПараметры.ЭтоНачалоИнтервала Тогда 
			ЗначениеПослеИзменения = Новый Структура("НачалоРаботы, ОкончаниеРаботы", ВыбранныйЭлемент.Значение, ЗначениеДоИзменения.ОкончаниеРаботы);
		Иначе 
			ЗначениеПослеИзменения = Новый Структура("НачалоРаботы, ОкончаниеРаботы", ЗначениеДоИзменения.НачалоРаботы, ВыбранныйЭлемент.Значение);
		КонецЕсли;
		// Производим проверку
		Если НЕ ЗначениеПослеИзменения.НачалоРаботы = Неопределено И НЕ ЗначениеПослеИзменения.ОкончаниеРаботы = Неопределено Тогда
			Если ЗначениеПослеИзменения.НачалоРаботы = ЗначениеПослеИзменения.ОкончаниеРаботы Тогда
				ОбщегоНазначенияКлиент.СообщитьПользователю("Время начала работы не может быть равно времени окончания работы!");
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			Если ЗначениеПослеИзменения.НачалоРаботы > ЗначениеПослеИзменения.ОкончаниеРаботы Тогда
				ОбщегоНазначенияКлиент.СообщитьПользователю("Время начала работы не может быть больше времени окончания работы!");
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			Для Каждого ИнтервалСписка ИЗ ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы] Цикл
				ИндексИнтервала = ЭтаФорма[ДополнительныеПараметры.ИмяТаблицы].Индекс(ИнтервалСписка);
				Если ИндексИнтервала <> ДополнительныеПараметры.ИндексСтроки И 
					НЕ ИнтервалСписка.Значение.НачалоРаботы = Неопределено И НЕ ИнтервалСписка.Значение.ОкончаниеРаботы = Неопределено Тогда
					
					// Я отдал приоритет этому механизму выявления пересечения периодов
					Если Макс(ЗначениеПослеИзменения.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы) < Мин(ЗначениеПослеИзменения.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы) Тогда
						ОбщегоНазначенияКлиент.СообщитьПользователю("Обнаружено пересечение времени: с " + Формат(Макс(ЗначениеПослеИзменения.НачалоРаботы, ИнтервалСписка.Значение.НачалоРаботы), "ДФ=HH:mm") + " по " + Формат(Мин(ЗначениеПослеИзменения.ОкончаниеРаботы, ИнтервалСписка.Значение.ОкончаниеРаботы), "ДФ=HH:mm"));
						Отказ = Истина;	
						Прервать;
					КонецЕсли; 	
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;			
		Если НЕ Отказ Тогда 
			ДополнительныеПараметры.ДанныеЭлемента.Значение 		= ЗначениеПослеИзменения;
			ДополнительныеПараметры.ДанныеЭлемента.Представление 	= ОбщегоНазначенияКлиентСерверСтоматология.ПолучитьПредставлениеИнтервала(ДополнительныеПараметры.ДанныеЭлемента.Значение);
			Элементы[ДополнительныеПараметры.ИмяЭлемента].Заголовок = Формат(ВыбранныйЭлемент.Значение, "ДФ=HH:mm");
			Если ДополнительныеПараметры.ЭтоНачалоИнтервала И ДополнительныеПараметры.ДанныеЭлемента.Значение.ОкончаниеРаботы = Неопределено Тогда
				Подключаемый_ВыборОкончанияИнтервала(ЭтаФорма.Команды.Найти("Подключаемый_ВыборОкончанияИнтервала_" + ДополнительныеПараметры.ИндексСтроки));
			Иначе 
				УстановитьТекущийЭлемент();
			КонецЕсли;
			ОбновитьОбщееВремяИнтервалов();
			ОбновитьДекорациюУпраленияСохранениемШаблонов();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить меню отбора интервалов работ
// 
Процедура ОбновитьМенюОтбораИнтерваловРабот()
	
	РодительскаяГруппа = Элементы.ГруппаСписокИнтерваловРаботы;
	// Очистим группу
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из РодительскаяГруппа.ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	Если ОтборИнтервалыРаботы.Количество() = 0 Тогда 
		ДекорацияФормы_СписокИнтервалов_Пуст = Элементы.Добавить("ДекорацияФормы_СписокИнтервалов_Пуст", Тип("ДекорацияФормы"), РодительскаяГруппа);
		ДекорацияФормы_СписокИнтервалов_Пуст.Вид 									= ВидДекорацииФормы.Надпись;
		ДекорацияФормы_СписокИнтервалов_Пуст.Заголовок 								= "Список интервалов пуст";
		ДекорацияФормы_СписокИнтервалов_Пуст.АвтоМаксимальнаяШирина    				= Ложь;
		ДекорацияФормы_СписокИнтервалов_Пуст.Высота 								= 1;
		ДекорацияФормы_СписокИнтервалов_Пуст.МаксимальнаяШирина       				= 45;
		ДекорацияФормы_СписокИнтервалов_Пуст.ГоризонтальноеПоложение   				= ГоризонтальноеПоложениеЭлемента.Центр;
		ДекорацияФормы_СписокИнтервалов_Пуст.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
		ДекорацияФормы_СписокИнтервалов_Пуст.ВертикальноеПоложение 					= ВертикальноеПоложениеЭлемента.Центр;
		ДекорацияФормы_СписокИнтервалов_Пуст.ВертикальноеПоложениеВГруппе			= ВертикальноеПоложениеЭлемента.Центр;		
		ДекорацияФормы_СписокИнтервалов_Пуст.РастягиватьПоГоризонтали  				= Истина;
		ДекорацияФормы_СписокИнтервалов_Пуст.ЦветТекста								= Новый Цвет(170, 170, 170);
		ДекорацияФормы_СписокИнтервалов_Пуст.Шрифт 									= Новый Шрифт("Arial", 11);		
	Иначе 	
		Для Каждого ЭлементСписка Из ОтборИнтервалыРаботы Цикл 
			
			ИндексИнтервала = ОтборИнтервалыРаботы.Индекс(ЭлементСписка);
			
			// Создаем группу для каждого интервала
			// --------------------------------------------------------------------------------------------		
			Группа_Интервал = Элементы.Добавить("Группа_Интервал_" + ИндексИнтервала, Тип("ГруппаФормы"), РодительскаяГруппа);
			Группа_Интервал.Вид 													= ВидГруппыФормы.ОбычнаяГруппа;
			Группа_Интервал.Заголовок 												= Группа_Интервал.Имя;
			Группа_Интервал.Отображение 											= ОтображениеОбычнойГруппы.Нет;
			Группа_Интервал.Группировка 											= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			Группа_Интервал.ОтображатьЗаголовок 									= Ложь;
			// Группа_Интервал.ЦветФона 												= ЦветаСтиля.ЦветФонаЗадач;
			Группа_Интервал.ГоризонтальныйИнтервал 									= ИнтервалМеждуЭлементамиФормы.Половинный;
			Группа_Интервал.ГоризонтальноеПоложениеВГруппе   						= ГоризонтальноеПоложениеЭлемента.Центр;
			Группа_Интервал.ГоризонтальноеПоложениеПодчиненных 						= ГоризонтальноеПоложениеЭлемента.Центр;
			Группа_Интервал.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Центр;
			Группа_Интервал.ВертикальноеПоложениеПодчиненных						= ВертикальноеПоложениеЭлемента.Центр;		
								
			Если ЭтаФорма.Команды.Найти("Подключаемый_ВыборНачалаИнтервала_" + ИндексИнтервала) = Неопределено Тогда
				Команда 			= ЭтаФорма.Команды.Добавить("Подключаемый_ВыборНачалаИнтервала_" + ИндексИнтервала);
				Команда.Заголовок 	= "[...]";
				Команда.Подсказка 	= "Укажите начало интервала";
				Команда.Действие 	= "Подключаемый_ВыборНачалаИнтервала";
			КонецЕсли;
			
			КнопкаНачалаИнтервала = Элементы.Добавить("Кнопка_ВыборНачалаИнтервала_" + ИндексИнтервала, Тип("КнопкаФормы"), Группа_Интервал);
			КнопкаНачалаИнтервала.ИмяКоманды 										= "Подключаемый_ВыборНачалаИнтервала_" + ИндексИнтервала;
			КнопкаНачалаИнтервала.Заголовок 										= ?(ЭлементСписка.Значение.НачалоРаботы = Неопределено, "[...]", Формат(ЭлементСписка.Значение.НачалоРаботы, "ДФ=HH:mm"));
			КнопкаНачалаИнтервала.ОтображениеФигуры    								= ОтображениеФигурыКнопки.Нет;
			КнопкаНачалаИнтервала.Ширина 											= 10;
			КнопкаНачалаИнтервала.ЦветТекста 										= ЦветаСтиля.ТекстВторостепеннойНадписи;
			КнопкаНачалаИнтервала.Шрифт 											= Новый Шрифт("Arial", 11);
			КнопкаНачалаИнтервала.ГоризонтальноеПоложениеВГруппе 					= ГоризонтальноеПоложениеЭлемента.Центр;
			КнопкаНачалаИнтервала.ВертикальноеПоложениеВГруппе 						= ВертикальноеПоложениеЭлемента.Центр;
			КнопкаНачалаИнтервала.ЦветФона 											= Новый Цвет(240, 240, 240);
			
			// Декорация "-"				
			ДекорацияФормы_Дефис = Элементы.Добавить("ДекорацияФормы_Дефис_" + ИндексИнтервала, Тип("ДекорацияФормы"), Группа_Интервал);
			ДекорацияФормы_Дефис.Вид 												= ВидДекорацииФормы.Надпись;
			ДекорацияФормы_Дефис.Заголовок 											= "-";
			ДекорацияФормы_Дефис.Ширина 											= 2;
			ДекорацияФормы_Дефис.ЦветТекста											= ЦветаСтиля.ТекстВторостепеннойНадписи;			
			ДекорацияФормы_Дефис.ГоризонтальноеПоложение   							= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Дефис.ГоризонтальноеПоложениеВГруппе 					= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Дефис.ВертикальноеПоложение 								= ВертикальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Дефис.ВертикальноеПоложениеВГруппе						= ВертикальноеПоложениеЭлемента.Центр;		
			
			Если ЭтаФорма.Команды.Найти("Подключаемый_ВыборОкончанияИнтервала_" + ИндексИнтервала) = Неопределено Тогда
				Команда 			= ЭтаФорма.Команды.Добавить("Подключаемый_ВыборОкончанияИнтервала_" + ИндексИнтервала);
				Команда.Заголовок 	= "[...]";
				Команда.Подсказка 	= "Укажите окончание интервала";
				Команда.Действие 	= "Подключаемый_ВыборОкончанияИнтервала";
			КонецЕсли;
			
			КнопкаОкончанияИнтервала = Элементы.Добавить("Кнопка_ВыборОкончанияИнтервала_" + ИндексИнтервала, Тип("КнопкаФормы"), Группа_Интервал);
			КнопкаОкончанияИнтервала.ИмяКоманды 									= "Подключаемый_ВыборОкончанияИнтервала_" + ИндексИнтервала;
			КнопкаОкончанияИнтервала.Заголовок 										= ?(ЭлементСписка.Значение.ОкончаниеРаботы = Неопределено, "[...]", Формат(ЭлементСписка.Значение.ОкончаниеРаботы, "ДФ=HH:mm"));
			КнопкаОкончанияИнтервала.ОтображениеФигуры    							= ОтображениеФигурыКнопки.Нет;
			КнопкаОкончанияИнтервала.Ширина 										= 10;
			КнопкаОкончанияИнтервала.ЦветТекста 									= ЦветаСтиля.ТекстВторостепеннойНадписи;
			КнопкаОкончанияИнтервала.Шрифт 											= Новый Шрифт("Arial", 11);
			КнопкаОкончанияИнтервала.ГоризонтальноеПоложениеВГруппе 				= ГоризонтальноеПоложениеЭлемента.Центр;
			КнопкаОкончанияИнтервала.ВертикальноеПоложениеВГруппе 					= ВертикальноеПоложениеЭлемента.Центр;
			КнопкаОкончанияИнтервала.ЦветФона 										= Новый Цвет(240, 240, 240);
			
			// Декорация "х"				
			ДекорацияФормы_УдалениеИнтервала = Элементы.Добавить("ДекорацияФормы_УдалениеИнтервала_" + ИндексИнтервала, Тип("ДекорацияФормы"), Группа_Интервал);
			ДекорацияФормы_УдалениеИнтервала.Вид 									= ВидДекорацииФормы.Картинка;
			// ДекорацияФормы_УдалениеИнтервала.Заголовок 								= "-";
			ДекорацияФормы_УдалениеИнтервала.Ширина 								= 1;
			ДекорацияФормы_УдалениеИнтервала.Высота 								= 1;
			ДекорацияФормы_УдалениеИнтервала.ЦветТекста								= ЦветаСтиля.ТекстВторостепеннойНадписи;			
			ДекорацияФормы_УдалениеИнтервала.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_УдалениеИнтервала.ВертикальноеПоложениеВГруппе			= ВертикальноеПоложениеЭлемента.Центр;		
			ДекорацияФормы_УдалениеИнтервала.Картинка 								= БиблиотекаКартинок.УдалениеДанных16;
			ДекорацияФормы_УдалениеИнтервала.Гиперссылка 							= Истина;
			ДекорацияФормы_УдалениеИнтервала.РастягиватьПоГоризонтали	 			= Ложь;
			
			ДекорацияФормы_УдалениеИнтервала.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_УдалитьТекущийИнтервал_Нажатие");
			
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый декорация формы удалить текущий интервал нажатие
// 
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура Подключаемый_ДекорацияФормы_УдалитьТекущийИнтервал_Нажатие(Элемент)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Элемент);
	
	Если НЕ СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда
		Если ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы].Количество() = 1 Тогда 
			ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы][СтруктураДанныеЭлемента.ИндексСтроки].Значение = Новый Структура("НачалоРаботы, ОкончаниеРаботы", Неопределено, Неопределено);
			ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы][СтруктураДанныеЭлемента.ИндексСтроки].Представление = "";
		Иначе 
			ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы].Удалить(ЭтаФорма[СтруктураДанныеЭлемента.ИмяТаблицы][СтруктураДанныеЭлемента.ИндексСтроки]);
		КонецЕсли;	
		ОбновитьМенюОтбораИнтерваловРабот();
		ОбновитьОбщееВремяИнтервалов();		
		ОбновитьДекорациюУпраленияСохранениемШаблонов();
		УстановитьТекущийЭлемент();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - Отбор периода планировании при изменении
// 
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
// 
Процедура ОтборПериодаПланированииПриИзменении(Результат, ДополнительныеПараметры) Экспорт 
	
	// Делаем бэкап значения поля
	ОткатВыбранногоЗначения = Элементы.ОтборПериод.Имя;
	
	Если НЕ Результат = Неопределено Тогда
		
		ЭтоОчистка = Результат.ДатаНачала = Дата(1,1,1);
		
		Если Не ЗначениеЗаполнено(Результат.ДатаОкончания) Тогда
			Результат.ДатаОкончания = КонецМесяца(?(ЗначениеЗаполнено(Результат.ДатаНачала), Результат.ДатаНачала, ОбщегоНазначенияСтоматология.ТекущаяСервернаяДатаНаСервере()));		
		КонецЕсли;
		
		Если Год(Результат.ДатаОкончания) - Год(Результат.ДатаНачала) > 1 Тогда
			Результат.ДатаНачала = ДобавитьМесяц(Результат.ДатаОкончания, -12);	
		КонецЕсли;
		
		ОтборПериод = Результат;
		
		Если ПроверитьНеобходимостьФиксацииИзмененийВПлане() = Истина Тогда
			СтруктураПарметров = Новый Структура;
			СтруктураПарметров.Вставить("ИмяЭлемента"	, Элементы.ОтборПериод.Имя);		
			СтруктураПарметров.Вставить("КодДляОтката"	, Элементы.ОтборПериод.Имя + "= ОткатВыбранногоЗначения;");
			Оповещение   = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОФиксацииизменений", ЭтотОбъект, СтруктураПарметров);
			ПоказатьВопрос(Оповещение,"Имеются не сохраненные изменения, они будут потеряны. Продолжить ?",РежимДиалогаВопрос.ДаНет,,,"Планирование");
			Возврат;
		Иначе 
			ОбновитьОтображениеПланирования(Истина);
		КонецЕсли;
		УстановитьДоступностьОтборуИнтервалыРаботы();
		УстановитьТекущийЭлемент();
	КонецЕсли;
	
КонецПроцедуры
	
&НаКлиенте
// Процедура - После вопроса о записи изменений оповещение
// 
// Параметры:
//  Ответ		 - 	 - 
//  ДопПараметры - 	 - 
// 
Процедура ПослеВопросаОЗаписиИзмененийОповещение(Ответ, ДопПараметры) Экспорт
	
	ПроверятьНеобхЗаписи = Ложь;
	Если Ответ = КодВозвратаДиалога.Да Тогда
		КомандаСформировать(Неопределено);	
	ИначеЕсли Ответ = КодВозвратаДиалога.Отмена Тогда
		ПроверятьНеобхЗаписи = Истина;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик асинхронного вызова после диалога вопроса
// 
Процедура ПослеЗакрытияВопросаОФиксацииизменений(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Если ЭтоОчистка И Параметры.Свойство("ИмяЭлемента") И Параметры.ИмяЭлемента = "ОтборПериод" Тогда
			ЭтоОчистка = Ложь;
			БуферФормирования.Очистить();
			УстановитьДоступностьОтборуИнтервалыРаботы();
		КонецЕсли;
		ОбновитьОтображениеПланирования(Истина);
	Иначе
		// Выполнить откат парамтера отбора, если П нажал Нет
		Если Параметры.Свойство("КодДляОтката") И ЗначениеЗаполнено(Параметры.КодДляОтката) Тогда
			Выполнить(Параметры.КодДляОтката);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить результат планирования на сервере
// 
// Параметры:
//  ДатаНачалаПериода	 - 	 - 
//  ДатаКонцаПериода	 - 	 - 
//  СтруктураПоиска		 - 	 - 
// 
Процедура ЗаполнитьРезультатПланированияНаСервере(Знач ВыбраннаяДата, Знач ПериодКопирования)
	
	День = 86400;
	РезультатПланированияРазовый.Очистить();
	СтруктураПоиска = ПолучитьПараметрыПоиска();
	
	// Определим период-источник
	Если ПериодКопирования = "День" Тогда
		ДатаНачалаПериодаИсточника 	= НачалоДня(ВыбраннаяДата - День*7);
		ДатаКонцаПериодаИсточника 	= КонецДня(ДатаНачалаПериодаИсточника);
	ИначеЕсли ПериодКопирования = "Неделя" Тогда
		ДатаНачалаПериодаИсточника 	= ОбщегоНазначенияКлиентСерверСтоматология.ДатаПоНомеруНедели(НеделяГода(ВыбраннаяДата) - 1, Год(ВыбраннаяДата));
		ДатаКонцаПериодаИсточника 	= КонецНедели(ДатаНачалаПериодаИсточника); 
	ИначеЕсли ПериодКопирования = "Месяц" Тогда 
		ДатаНачалаПериодаИсточника 	= НачалоМесяца(НачалоМесяца(ВыбраннаяДата)-1);
		ДатаКонцаПериодаИсточника 	= КонецМесяца(НачалоМесяца(ВыбраннаяДата)-1); 
	КонецЕсли;
	
	// Период-источник не пересекается с буфером
	Если ДатаНачалаПериодаИсточника < ОтборПериод.ДатаНачала И ДатаКонцаПериодаИсточника < ОтборПериод.ДатаНачала Тогда 
		ТаблицаЗанятий = ПолучитьДанныеВнеБуфера(ДатаНачалаПериодаИсточника, ДатаКонцаПериодаИсточника, СтруктураПоиска);
	// Период-источник пересекается с буфером
	ИначеЕсли ДатаНачалаПериодаИсточника < ОтборПериод.ДатаНачала И	ДатаКонцаПериодаИсточника > ОтборПериод.ДатаНачала Тогда 
		ТаблицаЗанятий = БуферФормирования.Выгрузить();
		ТаблицаЗанятий = ТаблицаЗанятий.СкопироватьКолонки();
		ТаблицаЗанятийВнеБуфера = ПолучитьДанныеВнеБуфера(ДатаНачалаПериодаИсточника, КонецДня(НачалоДня(ОтборПериод.ДатаНачала)-1), СтруктураПоиска);
		Для Каждого СтрокаТЗ Из ТаблицаЗанятийВнеБуфера Цикл 
			НоваяСтрока = ТаблицаЗанятий.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЦикла;
		// Дополним таблицу из буфера
		Для Каждого СтрокаТЗ Из БуферФормирования Цикл 
			НоваяСтрока = ТаблицаЗанятий.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЦикла;	
	// Период-источник находится в буфере
	ИначеЕсли ДатаНачалаПериодаИсточника >= ОтборПериод.ДатаНачала И ДатаКонцаПериодаИсточника <= ОтборПериод.ДатаОкончания Тогда 
		ТаблицаЗанятий = БуферФормирования.Выгрузить();
	КонецЕсли;	
		
	// Заполняем результат планирования	
	Если ПериодКопирования = "День" Тогда
		
		СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаИсточника);			
		МассивСтрок = ТаблицаЗанятий.НайтиСтроки(СтруктураПоиска); 
		Для Каждого ЭлементМассива Из МассивСтрок Цикл
			// Если НЕ ТакоеЗанятиеУжеЕсть(СтруктураПоиска, ДатаНачалаПериодаИсточника + День*7, ЭлементМассива) Тогда 
				НоваяСтрока                     = РезультатПланированияРазовый.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
				НоваяСтрока.Дата 				= НачалоДня(ВыбраннаяДата);
			// КонецЕсли;			
		КонецЦикла;
		
	ИначеЕсли ПериодКопирования = "Неделя" Тогда 
		
		Пока ДатаНачалаПериодаИсточника < ДатаКонцаПериодаИсточника Цикл 
			Если НЕ (ДатаНачалаПериодаИсточника + День*7 < ОтборПериод.ДатаНачала ИЛИ ДатаНачалаПериодаИсточника + День*7 > ОтборПериод.ДатаОкончания) Тогда
				СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаИсточника);			
				МассивСтрок = ТаблицаЗанятий.НайтиСтроки(СтруктураПоиска); 
				Для Каждого ЭлементМассива Из МассивСтрок Цикл
					// Если НЕ ТакоеЗанятиеУжеЕсть(СтруктураПоиска, ДатаНачалаПериодаИсточника + День*7, ЭлементМассива) Тогда 
						НоваяСтрока                     = РезультатПланированияРазовый.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
						НоваяСтрока.Дата 				= НоваяСтрока.Дата + День*7;
					// КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			ДатаНачалаПериодаИсточника = ДатаНачалаПериодаИсточника + День;
		КонецЦикла;
		
	ИначеЕсли ПериодКопирования = "Месяц" Тогда
		
		ДатаНачалаПериодаПриемника = ДобавитьМесяц(ДатаНачалаПериодаИсточника, 1);
		ДатаКонцаПериодаИсточника = КонецДня(ДобавитьМесяц(ДобавитьМесяц(ДатаКонцаПериодаИсточника, 1), -1));
		Пока ДатаНачалаПериодаИсточника < ДатаКонцаПериодаИсточника Цикл 
			
			Если ДеньНедели(ДатаНачалаПериодаПриемника) > ДеньНедели(ДатаНачалаПериодаИсточника) Тогда 
				ДатаНачалаПериодаИсточника = ДатаНачалаПериодаИсточника + День;
			ИначеЕсли ДеньНедели(ДатаНачалаПериодаПриемника) < ДеньНедели(ДатаНачалаПериодаИсточника) Тогда	
			    ДатаНачалаПериодаПриемника = ДатаНачалаПериодаПриемника + День*(ДеньНедели(ДатаНачалаПериодаИсточника) - ДеньНедели(ДатаНачалаПериодаПриемника));
			КонецЕсли;
			
			Если ДеньНедели(ДатаНачалаПериодаПриемника) = ДеньНедели(ДатаНачалаПериодаИсточника) Тогда
				Если НЕ (ДобавитьМесяц(ДатаНачалаПериодаИсточника, 1) < ОтборПериод.ДатаНачала ИЛИ ДобавитьМесяц(ДатаНачалаПериодаИсточника, 1) > ОтборПериод.ДатаОкончания) Тогда
					СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаИсточника);			
					МассивСтрок = ТаблицаЗанятий.НайтиСтроки(СтруктураПоиска); 
					Для Каждого ЭлементМассива Из МассивСтрок Цикл
						Если НЕ ТакоеЗанятиеУжеЕсть(СтруктураПоиска, ДатаНачалаПериодаПриемника, ЭлементМассива) Тогда 
							НоваяСтрока                       = РезультатПланированияРазовый.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
							НоваяСтрока.Дата 				= ДатаНачалаПериодаПриемника;
							НоваяСтрока.ДатаВремяНачала 	= НачалоДня(ДатаНачалаПериодаПриемника) + Час(НоваяСтрока.ДатаВремяНачала)*60*60 + Минута(НоваяСтрока.ДатаВремяНачала)*60;
							НоваяСтрока.ДатаВремяОкончания 	= НачалоДня(ДатаНачалаПериодаПриемника) + Час(НоваяСтрока.ДатаВремяОкончания)*60*60 + Минута(НоваяСтрока.ДатаВремяОкончания)*60;
						КонецЕсли;						
					КонецЦикла;
				КонецЕсли;
				ДатаНачалаПериодаИсточника = ДатаНачалаПериодаИсточника + День;
			    ДатаНачалаПериодаПриемника = ДатаНачалаПериодаПриемника + День;
			КонецЕсли;
			
			Если ДатаНачалаПериодаПриемника > КонецМесяца(ДатаНачалаПериодаПриемника) Тогда 
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Функция - Получить параметры поиска
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьПараметрыПоиска()
	
	СтруктураПоиска = Новый Структура;
	
	Если ЗначениеЗаполнено(ОтборСотрудник) Тогда 
		СтруктураПоиска.Вставить("Сотрудник", ОтборСотрудник);
	КонецЕсли;
	
	Возврат СтруктураПоиска;

КонецФункции

&НаСервере
// Функция - Получить данные вне буфера
// 
// Параметры:
//  ДатаНачалаПериода	 - 	 - 
//  ДатаКонцаПериода	 - 	 - 
//  СтруктураПоиска		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьДанныеВнеБуфера(Знач ДатаНачалаПериода, Знач ДатаКонцаПериода, Знач СтруктураПоиска)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
	|	ВремяРаботыСотрудниковПлан.Сотрудник.Должность КАК Должность,
	|	ВремяРаботыСотрудниковПлан.Минуты КАК КолМинут
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|ГДЕ
	|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|					И &ГруппаСотрудников = ИСТИНА
	|				ТОГДА ВремяРаботыСотрудниковПлан.Сотрудник В ИЕРАРХИИ (&Сотрудник)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|					И &ГруппаСотрудников = ЛОЖЬ
	|				ТОГДА ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяНачала >= &НачалоПериода
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяОкончания <= &ОкончаниеПериода
	|	И ВремяРаботыСотрудниковПлан.ТипРабочегоВремени <> ЗНАЧЕНИЕ(Перечисление.ТипыРабочегоВремени.Отпуск)
	|	И ВремяРаботыСотрудниковПлан.ТипРабочегоВремени <> ЗНАЧЕНИЕ(Перечисление.ТипыРабочегоВремени.Больничный)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВремяРаботыСотрудниковПлан.МесяцОтбор,
	|	Сотрудник,
	|	Должность,
	|	ДатаВремяНачала");
	
	Запрос.УстановитьПараметр("НачалоПериода"    , НачалоДня(ДатаНачалаПериода));
	Запрос.УстановитьПараметр("ОкончаниеПериода" , КонецДня(ДатаКонцаПериода));
	Запрос.УстановитьПараметр("Помещение"        , ?(СтруктураПоиска.Свойство("Помещение") И ЗначениеЗаполнено(СтруктураПоиска.Помещение), СтруктураПоиска.Помещение, Неопределено));
	Запрос.УстановитьПараметр("ГруппаСотрудников", ?(СтруктураПоиска.Свойство("Сотрудник") И ЗначениеЗаполнено(СтруктураПоиска.Сотрудник) И СтруктураПоиска.Сотрудник.ЭтоГруппа, Истина, Ложь));
	Запрос.УстановитьПараметр("Сотрудник"        , ?(СтруктураПоиска.Свойство("Сотрудник") И ЗначениеЗаполнено(СтруктураПоиска.Сотрудник), СтруктураПоиска.Сотрудник, Неопределено));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница" , ОтборСтруктурнаяЕдиница);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТЗ_ВремяРаботыСотрудников = БуферФормирования.Выгрузить();
	ТЗ_ВремяРаботыСотрудников = ТЗ_ВремяРаботыСотрудников.СкопироватьКолонки();
	
	ТекДень            	= Неопределено;
	ПредДень           	= Неопределено;
	ТекСтрока_ТЗ    	= Неопределено;
	ПредСтрока_ТЗ   	= Неопределено;
	ПредставлениеИнтервала = "";
	
	Пока Выборка.Следующий() Цикл
		// Получаем дату тек. дня
		ТекДень = День(Выборка.ДатаВремяНачала);
		// Если тек дата не совпадает или указанные параметры
		// создаем новую строку бофуера, иначе считаем что это след. интервал в тот же день
		Если ТекДень <> ПредДень 
			ИЛИ ТекСтрока_ТЗ = Неопределено 
			ИЛИ ТекСтрока_ТЗ.Сотрудник <> Выборка.Сотрудник
			ИЛИ ТекСтрока_ТЗ.Должность <> Выборка.Должность
			ИЛИ ТекСтрока_ТЗ.Помещение <> Выборка.Помещение Тогда
			
			ТекСтрока_ТЗ = ТЗ_ВремяРаботыСотрудников.Добавить();
			ЗаполнитьЗначенияСвойств(ТекСтрока_ТЗ, Выборка);
			ТекСтрока_ТЗ.ИдентификаторОбласти  = Новый УникальныйИдентификатор;
			ТекСтрока_ТЗ.Дата                  = Выборка.ДатаВремяНачала;
			ТекСтрока_ТЗ.СуммаРабочегоВремени  = Выборка.КолМинут;
		Иначе
			ТекСтрока_ТЗ.СуммаРабочегоВремени = ТекСтрока_ТЗ.СуммаРабочегоВремени + Выборка.КолМинут;
		КонецЕсли;
		
		// Переменная оптимизации. Кеширует массив данных на время серверного вызова
		МассивНадстрочныхСимволов = Неопределено;
		ПериодРаботы              = Новый Структура("НачалоРаботы, ОкончаниеРаботы,ВсегоМинут", Выборка.ДатаВремяНачала
		, Выборка.ДатаВремяОкончания
		, Выборка.КолМинут);	  
		НачалоПредст              = Формат(ПериодРаботы.НачалоРаботы	, "ДФ=HH:mm"); 
		КонецПредст               = Формат(ПериодРаботы.ОкончаниеРаботы	, "ДФ=HH:mm"); 
		
		ВремяИнтервала 			= ?(Выборка.КолМинут > 60, Строка(ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьМинутыВЧасы(Выборка.КолМинут)), Строка(Выборка.КолМинут) + " мин.");
		
		ПредставлениеИнтервала = НачалоПредст + " - " + КонецПредст + " (" + ВремяИнтервала + ")";
		ТекСтрока_ТЗ.ИнтервалыРаботы.Добавить(ПериодРаботы, ПредставлениеИнтервала);
		ТекСтрока_ТЗ.ИнтервалыРаботыПредст = Обработки.ПланированиеИндивидуальногоГрафика.ПолучитьПредставлениеСпискаИнтервалов(ТекСтрока_ТЗ.ИнтервалыРаботы);
		
		ПредДень      = ТекДень;
		ПредСтрока_ТЗ = ТекСтрока_ТЗ;	  
	КонецЦикла;	 
	
	Возврат ТЗ_ВремяРаботыСотрудников;
	
КонецФункции

&НаСервере
// Функция - Такое занятие уже есть
// 
// Параметры:
//  СтруктураПоиска				 - 	 - 
//  ДатаНачалаПериодаПриемника	 - 	 - 
//  СтрокаИсточника				 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ТакоеЗанятиеУжеЕсть(Знач СтруктураПоиска, Знач ДатаНачалаПериодаПриемника, Знач СтрокаИсточника)
	
	Флаг = Ложь;
	ДатаНачалаПериодаИсточника = СтруктураПоиска.Дата;
	СтруктураПоиска.Вставить("Дата", ДатаНачалаПериодаПриемника);
	МассивСтрокПриемника = БуферФормирования.НайтиСтроки(СтруктураПоиска);
	Если МассивСтрокПриемника.Количество() > 0 Тогда 
		Для Каждого ЭлементМассива Из МассивСтрокПриемника Цикл 
			Если СтрокаИсточника.Сотрудник = ЭлементМассива.Сотрудник
				И Час(СтрокаИсточника.ДатаВремяНачала) = Час(ЭлементМассива.ДатаВремяНачала)
				И Минута(СтрокаИсточника.ДатаВремяНачала) = Минута(ЭлементМассива.ДатаВремяНачала)
				И Час(СтрокаИсточника.ДатаВремяОкончания) = Час(ЭлементМассива.ДатаВремяОкончания)
				И Минута(СтрокаИсточника.ДатаВремяОкончания) = Минута(ЭлементМассива.ДатаВремяОкончания) Тогда 
				
				Флаг = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Флаг;			
	
КонецФункции

#Область МетодыВизуализацииПланаИРаботаСБуферомФормирония

&НаСервере
// Сформировать план занятий на сервере
// 
Процедура ОбновитьОтображениеПланирования(ПерезаполнитьБуфер)
	
	СформироватьТекстПериода();
	
	// Вывод шапки с наименованием дней недели
	ЗаголовокТаблицы = ПолучитьШапкуHTML();
	
	Если НЕ ЗначениеЗаполнено(ОтборПериод.ДатаНачала) И НЕ ЗначениеЗаполнено(ОтборПериод.ДатаОкончания) Тогда
		HTMLПанельПланирования = ЗаголовокТаблицы + "</body></html>";
		Возврат;
	КонецЕсли;
	
	// Очищаем таблицу областей
	ПеречислениеОбластей.Очистить();
	
	// Заполняем буфер существующими занятиями
	Если ПерезаполнитьБуфер = Истина Тогда
		ЗаполнитьБуферСуществующимиДанными();
	КонецЕсли;
	
	БуферФормирования.Сортировать("Дата, Сотрудник");
	
	// Используем XML для конкатенации строк
	// Конкатенация строк является достаточно дорогой с точки зрения производительности операцией.
	// На небольших строках/циклах потери производительности незаметны, но на больших циклах (десятки тысяч) и/или
	// на больших объёмах (десятки мегабайт) это может привести к серьёзным падениям производительности.
	ТекстовыйПосторитель = Новый ЗаписьXML;
	ТекстовыйПосторитель.УстановитьСтроку();		
	
	// Выведем наименование месяца года
	ВывестиНаименованиеМесяцаПланирования(ТекстовыйПосторитель, ОтборПериод.ДатаНачала);
	ТекстовыйПосторитель.ЗаписатьБезОбработки("<div class='TABLE_PLANNING_CHART'>" + Символы.ПС);
	
	ТекДатаПозиции             = НачалоДня(ОтборПериод.ДатаНачала);
	ДеньНеделиТекСтрокиБуфера  = 0;
	ТекМесяцГода               = Месяц(ТекДатаПозиции);
	ДеньНеделиТекОбластиВывода = 1;
	ОбластьВывода              = Неопределено;
	БуферданныхНаНеделю        = Неопределено;
	ЗабитьПустымиОбластями     = Ложь;
	
	// Основной цикл последовательного заполнения месячного плана,
	// по схеме сверху вниз, слева направо. С многократным проходом
	// по недельной строке, если в один и тот же день более одного занятия
	Пока ТекДатаПозиции <= КонецДня(ОтборПериод.ДатаОкончания) Цикл
		
		// При окончании тек. месяца, добить заглушками
		// до конца недели и вывести заголовок периода отображения
		Пока ТекМесяцГода <> Месяц(ТекДатаПозиции) Цикл
			Если ДеньНеделиТекОбластиВывода = 1 Тогда
				ТекМесяцГода 			= Месяц(ТекДатаПозиции); 
				ЗабитьПустымиОбластями 	= Ложь;
				
				// Закроем таблицу предыдущего месяца
				ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + "</div>" + Символы.ПС);
				// Выведем наименование месяца года
				ВывестиНаименованиеМесяцаПланирования(ТекстовыйПосторитель, ТекДатаПозиции);
				// Открываем таблицу
				ТекстовыйПосторитель.ЗаписатьБезОбработки("<div class='TABLE_PLANNING_CHART'>" + Символы.ПС);
			Иначе
				ВывестиНевидимуюЗаглушкуДня(ТекстовыйПосторитель, Истина);
				
				ДеньНеделиТекОбластиВывода = ДеньНеделиТекОбластиВывода + 1;
				Если ДеньНеделиТекОбластиВывода > 7 Тогда
					// Закрываем строку недели
					ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + Символы.ПС + "</div>" + Символы.ПС);
					ДеньНеделиТекОбластиВывода = 1;
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		          
		// В начале каждой недели отбираем все занятия за текущую неделю
		Если ДеньНеделиТекОбластиВывода = 1 Тогда
			// Открываем строку недели
			ЗавершенВыводНедели = Ложь;
			ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + "<div class='WEEK'>");
			Если День(ТекДатаПозиции) = 1 Тогда 
			    БуферданныхНаНеделю = ЗанятияЗаНеделюИзБуфераДляОтображения(ТекДатаПозиции,КонецНедели(ТекДатаПозиции));	
			ИначеЕсли Месяц(КонецНедели(ТекДатаПозиции)) = ТекМесяцГода Тогда 
			    БуферданныхНаНеделю = ЗанятияЗаНеделюИзБуфераДляОтображения(НачалоНедели(ТекДатаПозиции),КонецНедели(ТекДатаПозиции));
			Иначе
				БуферданныхНаНеделю = ЗанятияЗаНеделюИзБуфераДляОтображения(НачалоНедели(ТекДатаПозиции),КонецМесяца(ТекДатаПозиции));
			КонецЕсли;	
		КонецЕсли;
		
		// Если в текущей неделе есть занятия выводим их в цикле
		// пока буфер на тек. неделю не иссякнет 
		Если БуферданныхНаНеделю.Количество() > 0 Тогда
			ВременноеХранениеТекПозицииДаты = ТекДатаПозиции;
			ЭтоПервыйПроход                 = Истина;
			Пока БуферданныхНаНеделю.Количество() > 0 Цикл
				
				ДеньНеделиТекСтрокиБуфера         = ДеньНедели(ТекДатаПозиции);		
				// Ищем подходящее по времени занятия для текущей позиции вывода
				СтрокаБуфераВЭтотДень = ПервоеВОчередиЗанятиеВЭтотДеньИЗБуфера(БуферданныхНаНеделю, ДеньНеделиТекОбластиВывода);
				// Если позиция текущего вывода дает возможность вывести занятие
				Если СтрокаБуфераВЭтотДень <> Неопределено Тогда
					
					РазрешитьИзменениеЦветаОбласти = Истина;
					ВнутренняяОбласть              = Неопределено;
					// В зависимости от вида операции над занятияем выбираем область макета
					Если СтрокаБуфераВЭтотДень.Операция = "" 
					  ИЛИ СтрокаБуфераВЭтотДень.Операция = "Создать" Тогда 
					  
						ВывестиРабочийДеньСотрудника(ТекстовыйПосторитель, СтрокаБуфераВЭтотДень, ТекДатаПозиции, ЭтоПервыйПроход, СтрокаБуфераВЭтотДень.ИдентификаторОбласти);
						                     
						Если ЭтоПервыйПроход = Истина Тогда
							ДобавитьВПеречислениеОбластей(ТекДатаПозиции, СтрокаБуфераВЭтотДень.ИдентификаторОбласти);
						КонецЕсли;
						
					// Удаление занятия	
					ИначеЕсли СтрокаБуфераВЭтотДень.Операция = "Удалить" Тогда
						
						ВывестиУдаленныйРабочийДеньСотрудника(ТекстовыйПосторитель, СтрокаБуфераВЭтотДень, ТекДатаПозиции, ЭтоПервыйПроход, СтрокаБуфераВЭтотДень.ИдентификаторОбласти);
						
						Если ЭтоПервыйПроход = Истина Тогда
							ДобавитьВПеречислениеОбластей(ТекДатаПозиции, СтрокаБуфераВЭтотДень.ИдентификаторОбласти);
						КонецЕсли;						
						РазрешитьИзменениеЦветаОбласти  = Ложь;
						
					КонецЕсли;
					
					// Строку данных из буфера на неделю вывели, теперь можно ее удалить
					БуферданныхНаНеделю.Удалить(БуферданныхНаНеделю.Найти(СтрокаБуфераВЭтотДень));
				// В этот день нет занятия	
				Иначе
					
					ЭтотДеньРабочий = МасивРабочихДнейНедели.Найти(ДеньНеделиТекОбластиВывода) <> Неопределено;
					// Этот день рабочий 
					Если ТекМесяцГода = Месяц(ТекДатаПозиции) И ДеньНеделиТекОбластиВывода = ДеньНеделиТекСтрокиБуфера И ЭтоПервыйПроход = Истина И ЭтотДеньРабочий = Истина Тогда
						
						// Добавить область в перечисление
						НовыйУИД = Новый УникальныйИдентификатор;
						ДобавитьВПеречислениеОбластей(ТекДатаПозиции, НовыйУИД);
						ВывестиРабочийНезанятыйДень(ТекстовыйПосторитель, ТекДатаПозиции, НовыйУИД);
						
					// Если это не рабочий день	
					ИначеЕсли ТекМесяцГода = Месяц(ТекДатаПозиции) И  ДеньНеделиТекОбластиВывода = ДеньНеделиТекСтрокиБуфера И ЭтотДеньРабочий = Ложь Тогда						
						ВывестиНеРабочийДень(ТекстовыйПосторитель, ТекДатаПозиции);						
					// Заглушка области	
					Иначе						
						ВывестиНевидимуюЗаглушкуДня(ТекстовыйПосторитель, ЭтоПервыйПроход);						
					КонецЕсли;
				КонецЕсли;	
				
				// Наращивание тек. даты на 24 часа
				Если ДеньНеделиТекОбластиВывода = ДеньНеделиТекСтрокиБуфера  Тогда
					ТекДатаПозиции = ТекДатаПозиции + (24 * 60 * 60);
				КонецЕсли;
				
				// Окончание тек. недели
				Если ДеньНеделиТекОбластиВывода = 7 Тогда
					Если НЕ ЗавершенВыводНедели Тогда 
						// Закрываем строку недели
						ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + Символы.ПС + "</div>" + Символы.ПС);
						ЗавершенВыводНедели = НЕ ЗавершенВыводНедели И НЕ БуферданныхНаНеделю.Количество() > 0;						
					КонецЕсли;	
					ДеньНеделиТекОбластиВывода    = 1;
					Если БуферданныхНаНеделю.Количество() > 0 Тогда
						ТекДатаПозиции = ВременноеХранениеТекПозицииДаты;
						ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + "<div class='WEEK'>");
					КонецЕсли;
					ЭтоПервыйПроход      = Ложь;
				Иначе
					Если НЕ ТекДатаПозиции <= КонецДня(ОтборПериод.ДатаОкончания) Тогда 
						Если НЕ ЗавершенВыводНедели И ДеньНеделиТекОбластиВывода = 7 Тогда				
							// Закрываем строку недели
							ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + Символы.ПС + "</div>" + Символы.ПС);
							ЗавершенВыводНедели = НЕ ЗавершенВыводНедели И НЕ БуферданныхНаНеделю.Количество() > 0;
						КонецЕсли;
					КонецЕсли;	
					ДеньНеделиТекОбластиВывода = ДеньНеделиТекОбластиВывода + 1;
				КонецЕсли;		 
			КонецЦикла;
			
			// Выставить данный флаг если это не первый проход
			// и оставшуюся справа область необходимо забить пустотой
			ЗабитьПустымиОбластями = ЭтоПервыйПроход = Ложь И ДеньНеделиТекОбластиВывода > 1;
			
		// Если в недельном буфере нет занятий, выводим пустые областя	
		Иначе
			                              
			ДеньНеделиТекСтрокиБуфера = ДеньНедели(ТекДатаПозиции);	
			ЭтотДеньРабочий     = МасивРабочихДнейНедели.Найти(ДеньНеделиТекОбластиВывода) <> Неопределено;
			// Этот день рабочий 
			Если ДеньНеделиТекОбластиВывода = ДеньНеделиТекСтрокиБуфера И ЗабитьПустымиОбластями = Ложь И ЭтотДеньРабочий = Истина Тогда
				// Добавить область в перечисление
				НовыйУИД = Новый УникальныйИдентификатор;
				ДобавитьВПеречислениеОбластей(ТекДатаПозиции, НовыйУИД);				
				ВывестиРабочийНезанятыйДень(ТекстовыйПосторитель, ТекДатаПозиции, НовыйУИД);				
			// Если это не рабочий день	
			ИначеЕсли ДеньНеделиТекОбластиВывода = ДеньНеделиТекСтрокиБуфера И ЭтотДеньРабочий = Ложь И ЗабитьПустымиОбластями = Ложь Тогда			
				ВывестиНеРабочийДень(ТекстовыйПосторитель, ТекДатаПозиции);			
			// Заглушка области	
			Иначе
				ВывестиНевидимуюЗаглушкуДня(ТекстовыйПосторитель, НЕ ЗабитьПустымиОбластями);			
			КонецЕсли;
			
			// Наращивание тек. даты на 24 часа
			Если ДеньНеделиТекОбластиВывода = ДеньНеделиТекСтрокиБуфера  Тогда
				ТекДатаПозиции = ТекДатаПозиции + (24 * 60 * 60);
			КонецЕсли;
			
			// Окончание тек. недели
			Если ДеньНеделиТекОбластиВывода = 7 Тогда
				Если НЕ ЗавершенВыводНедели Тогда				
					// Закрываем строку недели
					ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + Символы.ПС + "</div>" + Символы.ПС);
					ЗавершенВыводНедели = НЕ ЗавершенВыводНедели;
				КонецЕсли;
				ДеньНеделиТекОбластиВывода      = 1 ;
				ЗабитьПустымиОбластями = Ложь;
			Иначе
				ДеньНеделиТекОбластиВывода = ДеньНеделиТекОбластиВывода + 1;
				Если НЕ ТекДатаПозиции <= КонецДня(ОтборПериод.ДатаОкончания) Тогда 
					Если НЕ ЗавершенВыводНедели Тогда				
						// Закрываем строку недели
						ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + Символы.ПС + "</div>" + Символы.ПС);
						ЗавершенВыводНедели = НЕ ЗавершенВыводНедели;
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;				
		КонецЕсли;
		
	КонецЦикла;
	
	// Закроем таблицу месяца
	ТекстовыйПосторитель.ЗаписатьБезОбработки("</div>");							
	
	// Получаем готовый HTML-документ
	HTMLПанельПланирования = ЗаголовокТаблицы + ТекстовыйПосторитель.Закрыть() + Символы.ПС + "</body></html>";
	
	// Очищаем построитель
	ТекстовыйПосторитель = Неопределено;
	
КонецПроцедуры

&НаСервере
// Заполнить буфер существующими записями занятий
// 
Процедура ЗаполнитьБуферСуществующимиДанными()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ДатаВремяНачала,
	|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
	|	ВремяРаботыСотрудниковПлан.Сотрудник.Должность КАК Должность,
	|	ВремяРаботыСотрудниковПлан.Минуты КАК КолМинут,
	|	ВремяРаботыСотрудниковПлан.ТипРабочегоВремени КАК ТипРабочегоВремени
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|ГДЕ
	|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|					И &ГруппаСотрудников = ИСТИНА
	|				ТОГДА ВремяРаботыСотрудниковПлан.Сотрудник В ИЕРАРХИИ (&Сотрудник)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|					И &ГруппаСотрудников = ЛОЖЬ
	|				ТОГДА ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяНачала >= &НачалоПериода
	|	И ВремяРаботыСотрудниковПлан.ДатаВремяНачала <= &ОкончаниеПериода
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВремяРаботыСотрудниковПлан.МесяцОтбор,
	|	Сотрудник,
	|	Должность,
	|	ДатаВремяНачала"
	);
	
	Запрос.УстановитьПараметр("НачалоПериода"      , НачалоДня(ОтборПериод.ДатаНачала));
	Запрос.УстановитьПараметр("ОкончаниеПериода"   , КонецДня(ОтборПериод.ДатаОкончания));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница" , ОтборСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник"          , ?(ЗначениеЗаполнено(ОтборСотрудник),ОтборСотрудник,Неопределено));
	Запрос.УстановитьПараметр("ГруппаСотрудников"  , ЗначениеЗаполнено(ОтборСотрудник) И ОтборСотрудник.ЭтоГруппа);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	БуферФормирования.Очистить();
	ТекДень            = Неопределено;
	ПредДень           = Неопределено;
	ТекСтрокаБуфера    = Неопределено;
	ПредСтрокаБуфера   = Неопределено;
	ПредставлениеИнтервала = "";
	
	Пока Выборка.Следующий() Цикл
		// Получаем дату тек. дня
		ТекДень = День(Выборка.ДатаВремяНачала);
		// Если тек дата не совпадает или указанные параметры
		// создаем новую строку бофуера, иначе считаем что это след. интервал в тот же день
		Если ТекДень <> ПредДень 
			ИЛИ ТекСтрокаБуфера = Неопределено 
			ИЛИ ТекСтрокаБуфера.Сотрудник <> Выборка.Сотрудник
			ИЛИ ТекСтрокаБуфера.Должность <> Выборка.Должность Тогда
			
			ТекСтрокаБуфера = БуферФормирования.Добавить();
			ЗаполнитьЗначенияСвойств(ТекСтрокаБуфера, Выборка);
			ТекСтрокаБуфера.ИдентификаторОбласти  = Новый УникальныйИдентификатор;
			ТекСтрокаБуфера.Дата                  = Выборка.ДатаВремяНачала;
			ТекСтрокаБуфера.СуммаРабочегоВремени  = Выборка.КолМинут;
		Иначе
			ТекСтрокаБуфера.СуммаРабочегоВремени = ТекСтрокаБуфера.СуммаРабочегоВремени + Выборка.КолМинут;
		КонецЕсли;
		
		// Переменная оптимизации. Кеширует массив данных на время серверного вызова
		МассивНадстрочныхСимволов = Неопределено;
		ПериодРаботы              = Новый Структура("НачалоРаботы, ОкончаниеРаботы,ВсегоМинут", Выборка.ДатаВремяНачала
		, Выборка.ДатаВремяОкончания
		, Выборка.КолМинут);	  
		НачалоПредст              = Формат(ПериодРаботы.НачалоРаботы	, "ДФ=HH:mm"); // Обработки.ПланированиеГрафикРаботыСотрудников.ПредставлениеВремениСНадстрочнымиСимволами(ПериодРаботы.НачалоРаботы, МассивНадстрочныхСимволов);
		КонецПредст               = Формат(ПериодРаботы.ОкончаниеРаботы	, "ДФ=HH:mm"); // Обработки.ПланированиеГрафикРаботыСотрудников.ПредставлениеВремениСНадстрочнымиСимволами(ПериодРаботы.ОкончаниеРаботы, МассивНадстрочныхСимволов);
		
		ВремяИнтервала 			= ?(Выборка.КолМинут > 60, Строка(ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьМинутыВЧасы(Выборка.КолМинут)), Строка(Выборка.КолМинут) + " мин.");
		
		ПредставлениеИнтервала = НачалоПредст + " - " + КонецПредст + " (" + ВремяИнтервала + ")";
		ТекСтрокаБуфера.ИнтервалыРаботы.Добавить(ПериодРаботы, ПредставлениеИнтервала);
		ТекСтрокаБуфера.ИнтервалыРаботыПредст = Обработки.ПланированиеИндивидуальногоГрафика.ПолучитьПредставлениеСпискаИнтервалов(ТекСтрокаБуфера.ИнтервалыРаботы);
		
		ПредДень         = ТекДень;
		ПредСтрокаБуфера = ТекСтрокаБуфера;	  
	КонецЦикла;	 	
	
	// заполняме таблицу уволенных 
	Запрос = новый ЗАпрос;
	ЗАпрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник,
	|	Сотрудники.Должность КАК Должность,
	|	НастройкиСотрудников.ДатаПриема КАК ДатаПриема,
	|	НастройкиСотрудников.ДатаУвольнения КАК ДатаУвольнения
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО (НастройкиСотрудников.Сотрудник = Сотрудники.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
	|		ПО (Пользователи.Сотрудник = Сотрудники.Ссылка)
	|ГДЕ
	|	НЕ Сотрудники.ЭтоГруппа
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Пользователи.РольПользователя В (&СписокРолей)
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сотрудники.Наименование";  	
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	
	СписокРолей = Новый СписокЗначений;
	СписокРолей.Добавить(Перечисления.РольПользователя.АдминистраторБазыДанных);
	СписокРолей.Добавить(Перечисления.РольПользователя.ПустаяСсылка());	
	
	Запрос.УстановитьПараметр("СписокРолей"	, СписокРолей);  		
	
	ТаблицаСотрудников = Запрос.Выполнить().Выгрузить(); 
	
	// сохраняем в элементах формы для дальнейшенго контроля
	ТаблицаСотрудниковДатыПриемаУвольнения.Очистить(); 		
	
	Для Каждого СтрокаПериодРаботы Из ТаблицаСотрудников Цикл
		
		Если НЕ((ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаПриема)
			и СтрокаПериодРаботы.ДатаПриема <= ОтборПериод.ДатаОкончания или НЕ ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаПриема))
			и (ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаУвольнения) и СтрокаПериодРаботы.ДатаУвольнения >= ОтборПериод.ДатаНачала или НЕ ЗначениеЗаполнено(СтрокаПериодРаботы.ДатаУвольнения)))  Тогда 
			
			Продолжить;
			
		КонецЕсли;
		
		НоваяСтрокаТаблицыСотрудниковДатыПриемаУвольнения = ТаблицаСотрудниковДатыПриемаУвольнения.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицыСотрудниковДатыПриемаУвольнения, СтрокаПериодРаботы);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура дополнения буфера новыми данными планирования
// 
Процедура ДополнитьБуферНовымиДаннымиПланирования(ТаблицаРезПланирования, ПроверкаВизитов = Истина)
	
	// Заполняем буфер новыми данными
	НомерОперации = НомерПоследнейОперацииВОчередиБуфераНаСервере() + 1;
	Для Каждого СтрокаРЗ ИЗ ТаблицаРезПланирования Цикл
		
		ФлагПроверки	= Истина;
		ИнтервалыРаботыПредст = Обработки.ПланированиеИндивидуальногоГрафика.ПолучитьПредставлениеСпискаИнтервалов(СтрокаРЗ.ИнтервалыРаботы);
			
		// проверка на дату увольнения и дату приема
		МассивДатыПриемаУвольнения = ТаблицаСотрудниковДатыПриемаУвольнения.НайтиСтроки(Новый Структура("Сотрудник", СтрокаРЗ.Сотрудник));
		Если МассивДатыПриемаУвольнения.Количество() > 0 Тогда
			СтрокаМассиваДатыПриемаУвольнения = МассивДатыПриемаУвольнения[0];
			Если НЕ (ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема) и СтрокаМассиваДатыПриемаУвольнения.ДатаПриема <= СтрокаРЗ.Дата или НЕ ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема)) Тогда
				
				ФлагПроверки = Ложь;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка задания периодов работы: " + Строка(Формат(СтрокаРЗ.Дата,"ДЛФ=ДД.ММ.ГГ"))+" "+Строка(ОтборСтруктурнаяЕдиница)+" сотрудник " + Строка(СтрокаРЗ.Сотрудник) + " еще не принят на работу."
				+?(ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема),"Дата приема на работу "+Строка(Формат(СтрокаМассиваДатыПриемаУвольнения.ДатаПриема,"ДЛФ=ДД.ММ.ГГ")),"")
				);
				
			КонецЕсли;   			
			
			Если  НЕ (ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения) и СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения >= СтрокаРЗ.Дата  или НЕ ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения))  Тогда 
				
				ФлагПроверки = Ложь;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка задания периодов работы: " + Строка(Формат(СтрокаРЗ.Дата,"ДЛФ=ДД.ММ.ГГ"))+" "+Строка(ОтборСтруктурнаяЕдиница)+" сотрудник " + Строка(СтрокаРЗ.Сотрудник) + " уже уволен."
				+?(ЗначениеЗаполнено(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения),", дата увольнения "+Строка(Формат(СтрокаМассиваДатыПриемаУвольнения.ДатаУвольнения,"ДЛФ=ДД.ММ.ГГ")),"") );
				
			КонецЕсли;		
		КонецЕсли;       
		
		// проверка на наличие визитов
		Если ПроверкаВизитов Тогда
			ВизитыВходятВИнтервалыРабот = ПроверитьВизитыВходятВИнтервалыРабот(СтрокаРЗ.Сотрудник, СтрокаРЗ.Дата, ОтборСтруктурнаяЕдиница, СтрокаРЗ.ИнтервалыРаботы);   			
			Если Не ВизитыВходятВИнтервалыРабот Тогда 
				ФлагПроверки = Ложь;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У сотрудника " + СтрокаРЗ.Сотрудник + " " + Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ")+ " запланированы визиты, не входящие в выбранные смены.");			
			КонецЕсли;  
		КонецЕсли;
		
		Если (СтрокаРЗ.Свойство("ТипРабочегоВремени")
			И СтрокаРЗ.ТипРабочегоВремени <> Перечисления.ТипыРабочегоВремени.Больничный 
			И СтрокаРЗ.ТипРабочегоВремени <> Перечисления.ТипыРабочегоВремени.Отпуск)
			ИЛИ НЕ СтрокаРЗ.Свойство("ТипРабочегоВремени") Тогда
			
			// проверка на работу сотрудника в этот период в другом салоне
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ВремяНачала,
			|	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ВремяОкончания
			|ИЗ
			|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
			|ГДЕ
			|	ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
			|	И ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница
			|	И НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) = &Дата";
			
			Запрос.УстановитьПараметр("Дата"				, СтрокаРЗ.Дата);
			Запрос.УстановитьПараметр("Сотрудник"			, СтрокаРЗ.Сотрудник);
			Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
			
			Результат = Запрос.Выполнить().Выгрузить();
			
			Для Каждого СтрокаТЧ Из Результат Цикл
				Для Каждого СтрокаПериода из СтрокаРЗ.ИнтервалыРаботы Цикл
					СтрокаПериодаВремяНачала 	= СтрокаРЗ.Дата + (СтрокаПериода.Значение.НачалоРаботы - Дата(01, 01, 01));
					СтрокаПериодаВремяОкончания = СтрокаРЗ.Дата + (СтрокаПериода.Значение.ОкончаниеРаботы - Дата(01, 01, 01));
					Если (СтрокаПериодаВремяОкончания - СтрокаТЧ.ВремяНачала)*(СтрокаТЧ.ВремяОкончания - СтрокаПериодаВремяНачала) > 0 Тогда 
						ФлагПроверки = Ложь;
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сотрудник " + СтрокаРЗ.Сотрудник + " уже работает в этот период в другой клинике!");
						Прервать;           
					КонецЕсли;
				КонецЦикла;		
			КонецЦикла;     
			
		КонецЕсли;

		Если ФлагПроверки Тогда
			
			// Ищем существующее рабочее время на указанную дату
			НайденныеСтроки = БуферФормирования.НайтиСтроки(Новый Структура("Дата,Сотрудник",СтрокаРЗ.Дата, СтрокаРЗ.Сотрудник));
			Для Каждого СтрокаБуфера ИЗ НайденныеСтроки Цикл
				// Если найден существующий интервал, помечаем его на удаление 
				// и скрываем для отображения
				Если НЕ ЗначениеЗаполнено(СтрокаБуфера.Операция) Тогда
					СтрокаБуфера.Операция              = "Удалить";
					СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
					СтрокаБуфера.Скрыть                = Истина;
					// Если найден новый интервал, просто удаляем его, он будет заменен	
				ИначеЕсли СтрокаБуфера.Операция = "Создать" Тогда
					БуферФормирования.Удалить(СтрокаБуфера);
				КонецЕсли;
			КонецЦикла;
			
			НоваяСтрока                       = БуферФормирования.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаРЗ);
			НоваяСтрока.ИнтервалыРаботыПредст = ИнтервалыРаботыПредст;
			НоваяСтрока.Должность             = НоваяСтрока.Сотрудник.Должность; 
			НоваяСтрока.ИдентификаторОбласти  = Новый УникальныйИдентификатор;
			НоваяСтрока.Операция              = "Создать";
			НоваяСтрока.НомерОчередиОперации  = НомерОперации;
		КонецЕсли;
		
	КонецЦикла;
	
	// Обновить визуализацию плана занятий
	ОбновитьОтображениеПланирования(Ложь);

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - проверяет входят ли визиты в указанный интервал работ
// 
Функция ПроверитьВизитыВходятВИнтервалыРабот(Сотрудник, Дата, ОтборСтруктурнаяЕдиница, ИнтервалыРаботы) 
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	                      |	СобытиеУслуги.Ссылка КАК Ссылка,
	                      |	СобытиеУслуги.ДатаНачала КАК ДатаНачала,
	                      |	СобытиеУслуги.ДатаОкончания КАК ДатаОкончания
	                      |ИЗ
	                      |	Документ.Событие.Услуги КАК СобытиеУслуги
	                      |ГДЕ
	                      |	СобытиеУслуги.Ссылка.Проведен = ИСТИНА
	                      |	И СобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	                      |	И СобытиеУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                      |	И (СобытиеУслуги.Сотрудник = &Сотрудник
	                      |			ИЛИ СобытиеУслуги.Ссылка.СсылкаНаПрием.Ассистент = &Сотрудник)
	                      |	И НАЧАЛОПЕРИОДА(СобытиеУслуги.Ссылка.Дата, ДЕНЬ) = &Дата");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ОтборСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник"			, Сотрудник);
	Запрос.УстановитьПараметр("Дата"				, НачалоДня(Дата));
	
	ТаблицаПриемов = Запрос.Выполнить().Выгрузить();
	
	Флаг = Ложь; 	
	Для Каждого СтрокаТЗ Из ТаблицаПриемов Цикл
		
		Флаг = Ложь;   
		Для Каждого СтрокаПеридов Из ИнтервалыРаботы Цикл
			
			НачалоПериода	= СтрокаПеридов.Значение.НачалоРаботы;
			КонецПериода	= СтрокаПеридов.Значение.ОкончаниеРаботы;
			
			НачалоПериода	= НачалоДня(Дата) + Час(НачалоПериода)*60*60 + Минута(НачалоПериода)*60 + Секунда(НачалоПериода);
			КонецПериода	= НачалоДня(Дата) + Час(КонецПериода)*60*60	 + Минута(КонецПериода)*60  + Секунда(КонецПериода);
			
			Если СтрокаТЗ.ДатаНачала >= НачалоПериода и СтрокаТЗ.ДатаОкончания <= КонецПериода Тогда
				Флаг = Истина;			
			КонецЕсли;
			
			// уже есть период графика работ, в который входит визит.
			Если флаг Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;   
		
		Если Не Флаг Тогда
			Прервать;					
		КонецЕсли; 		
			
	КонецЦикла;
	
	Возврат	?(ТаблицаПриемов.Количество() > 0, Флаг, Истина);
	
КонецФункции


&НаКлиенте
// Вернет текстовое представление значения параметра занятия
// 
Функция ПредставлениеЗначенияПараметраЗанятия(СтрокаБуфера, ИмяПараметра)
	
