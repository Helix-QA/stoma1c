КонецФункции

 // Процедура: ПоказатьСообщение
 //   выводит сообщение пользователю на указанным языке.
 //
 // Параметры:
 //   ИмяСообщения {Строка}
 //     Имя сообщения строкой.
 //   Параметры
 //     Структура, которая хранит значения по ключам. Каждое вхождение подстроки вида
 //     #Ключ#, где Ключ - это ключ структуры, будет заменено на значение по этому ключу.
 //     Параметр не обязательный.
 //   Язык {Строка}
 //     Код языка для работы с НСтр.
 //
 ///
Процедура ПоказатьСообщение(
	Знач ИмяСообщения,
	Знач Параметры = Неопределено,
	Знач Язык = ""
) 
	Перем
		Сообщение,
		СтруктураСообщения
	;
	Сообщение = Новый СообщениеПользователю;
	ТекстСообщения = Получить(ИмяСообщения, Параметры, Истина, Язык);
	Сообщение.Текст = ТекстСообщения;
	Сообщение.Сообщить();
	
КонецПроцедуры

// Функция: РаспаковатьАрхив
//   распаковывает файлы
// 
// Параметры:
//   ПутьКФайлуАрхива  - Строка
//         путь к файлу архива
//   ПутьРаспаковки  - Строка
//         путь куда распаковать архив
//
// Возвращаемое значение:
//   ЧтениеZipФайла - Неопределено если возникли ошибки извлечения.
///
Функция РаспаковатьАрхив(ПутьКФайлуАрхива, ПутьРаспаковки) 
	
	Попытка
		Архив = Новый ЧтениеZipФайла();
		Архив.Открыть(ПутьКФайлуАрхива);
		Индекс = 2;
		ПутьРаспаковкиВрем = ПутьРаспаковки;
		Пока Истина Цикл
			Каталог = Новый Файл(ПутьРаспаковкиВрем);
			Если Каталог.Существует() Тогда
				ПутьРаспаковкиВрем = ПутьРаспаковки + "(" + Формат(Индекс, "ЧГ=") + ")";
				Индекс = Индекс + 1;
			Иначе
				Прервать;
			КонецЕсли; 
		КонецЦикла;
		ПутьРаспаковки = ПутьРаспаковкиВрем;
		СоздатьКаталог(ПутьРаспаковки);
		Архив.ИзвлечьВсе(ПутьРаспаковки);
	Исключение
		ПоказатьСообщение("ФормированиеРеестровСчетов_ПриИзвлеченииАрхиваВозниклиОшибки");
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Архив;
	
КонецФункции

// Функция ПроверитьИмяФайлаНаОтправителяИОтчетныйПериод()
//     проверяет соответствие проверяемого имени переданному
//     согласно требованиям обмена по ОМС.
//
// Параметры
//  ИмяФайлаБезРасширения  - Строка
//         имя файла без расширения.
//  Отправитель  - СправочникСсылка.Организации, СправочникСсылка.Контрагенты
//         отправитель файла.
//  Получатель  - СправочникСсылка.Контрагенты, СправочникСсылка.Организации
//         получатель файла.
//  ОтчетныйПериод  - Дата
//         дата среза
//
// Возвращаемое значение:
//   Булево   - Истина, если переданное имя соответствует шаблону.
///
Функция ПроверитьИмяФайлаНаОтправителяИОтчетныйПериод(ИмяФайлаБезРасширения, ИсточникФинансирования = Неопределено, Отправитель, Получатель, ОтчетныйПериод) 
	
	// собираем номер от символов T,S,M до их повторной встречи
	
	ПозицияРазделителя = Найти(ИмяФайлаБезРасширения, "_");
	ЛеваяЧасть = Лев(ИмяФайлаБезРасширения, ПозицияРазделителя - 1);
	ПраваяЧасть = Сред(ИмяФайлаБезРасширения, ПозицияРазделителя + 1);
	
	СтрокаОтКогоКому = Сред(ЛеваяЧасть, 3);
	ИмяФайла_ТипДанных = Сред(ИмяФайлаБезРасширения, 1, 1);
	ИмяФайла_ТипОтправителя = Сред(ИмяФайлаБезРасширения, 2, 1);
	
	Если Найти(СтрокаОтКогоКому, "M") <> 0 Тогда
		РазделительОтправительПолучатель = Найти(СтрокаОтКогоКому, "M");
	ИначеЕсли Найти(СтрокаОтКогоКому, "T") <> 0 Тогда
		РазделительОтправительПолучатель = Найти(СтрокаОтКогоКому, "T");
	ИначеЕсли Найти(СтрокаОтКогоКому, "S") <> 0 Тогда
		РазделительОтправительПолучатель = Найти(СтрокаОтКогоКому, "S");
	Иначе
		Возврат Ложь;
	КонецЕсли;
	ИмяФайла_ТипПолучателя = Сред(СтрокаОтКогоКому, РазделительОтправительПолучатель, 1);
	
	ИмяФайла_Отправитель = Лев(СтрокаОтКогоКому,РазделительОтправительПолучатель - 1);
	ИмяФайла_Получатель = Сред(СтрокаОтКогоКому,РазделительОтправительПолучатель + 1);
	
	ИмяФайла_Год = Лев(ПраваяЧасть, 2);
	ИмяФайла_Месяц = Сред(ПраваяЧасть, 3, 2);
	
	// исходные данные
	ТипОтправителя = ПолучитьПараметрТипыИсточника(Отправитель, ИсточникФинансирования);
	ТипПолучателя = ПолучитьПараметрТипыИсточника(Получатель, ИсточникФинансирования);
	
	РеестровыйНомерОтправителя = ПолучитьКод(Отправитель, ИсточникФинансирования);
	РеестровыйНомерПолучателя = ПолучитьКод(Получатель, ИсточникФинансирования);
	ОтчетныйПериод_Год = Формат(ОтчетныйПериод, "ДФ=""гг""");
	ОтчетныйПериод_Месяц = Формат(ОтчетныйПериод, "ДФ=""ММ""");
	
	Если ИмяФайла_ТипОтправителя <> ТипОтправителя ИЛИ
		 ИмяФайла_Отправитель <> РеестровыйНомерОтправителя ИЛИ
		 ИмяФайла_ТипПолучателя <> ТипПолучателя ИЛИ
		 ИмяФайла_Получатель <> РеестровыйНомерПолучателя
	Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИмяФайла_Год <> ОтчетныйПериод_Год ИЛИ
		 ИмяФайла_Месяц <> ОтчетныйПериод_Месяц
	Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
КонецФункции

// Процедура: УдалитьФайлыПоМассивуПутей
//   удаляет временные файлы.
// 
// Параметры:
//   Массив{Массив}
//     массив путей удаления
///
Процедура УдалитьФайлыПоМассивуПутей(МассивПутей)
	
	// удаление созданного распаковкой каталога
	Попытка
		Для каждого ФайлПуть Из МассивПутей Цикл
			УдалитьФайлы(ФайлПуть);
		КонецЦикла; 
	Исключение
		ПоказатьСообщение("ФормированиеРеестровСчетов_ОшибкаУдаленияПроверяемогоАрхива");
	КонецПопытки;
	
КонецПроцедуры

 // Функция: ОбходИерархии_СоздатьУзелДерева
 //   Выполняется обход иерархии с одновременным созданием дерева.
 //   Данная функция выполняет очередной шаг обхода.
 //
 // Параметры:
 //   ИерархическаяВыборка
 //     Выборка с сортировкой по иерархии, то есть сначала идет родитель,
 //     непосредственно за ним идут иерархии детей.
 //     В выборке должно быть поле Родитель, по которому строится иерархия.
 //   Дерево.
 //     Дерево, которое заполняется. Тип ДанныеФормыДерево.
 //   ИмяПоляСсылки.
 //     Имя поля дерева, по которому осуществляется связь полем Родитель выборки.
 //
 // Возврат:
 //   Созданный узел дерева.
 //
 // Пример:
 //   // В следующем примере происходит заполнение дерева иерархическим списком
 //   // элементов справочника Номенклатура.
 //   Запрос = Новый Запрос(
 //     "ВЫБРАТЬ
 //     |	Номенклатура.Ссылка,
 //     |	Номенклатура.Наименование,
 //     |	Номенклатура.Родитель
 //     |ИЗ
 //     |	Справочник.Номенклатура КАК Номенклатура
 //     |
 //     |УПОРЯДОЧИТЬ ПО
 //     |	Ссылка ИЕРАРХИЯ"
 //   );
 //   Выборка = Запрос.Выполнить().Выбрать();
 //   Дерево = ЭтотОбъект.Дерево; // Реквизит формы типа ДанныеФормыДерево, (ДеревоЗначений)
 //   Пока Выборка.Следующий() Цикл
 //   	УзелДерева = АлгоритмыДляКоллекций.ОбходИерархии_СоздатьУзелДерева(Выборка, Дерево);
 //   	УзелДерева.Наименование = Выборка.Наименование;
 //   КонецЦикла;
 ///
Функция ОбходИерархии_СоздатьУзелДерева(ИерархическаяВыборка, Дерево, ИмяПоляСсылки = "Ссылка")
	Перем УзелДерева, ЭлементыДерева, Условие;
	ЭлементыДерева = Дерево.ПолучитьЭлементы();
	Если Не ЗначениеЗаполнено(ИерархическаяВыборка.Родитель) Тогда
		Возврат ЭлементыДерева.Добавить();
	КонецЕсли;
	УзелДерева = ЭлементыДерева[ЭлементыДерева.Количество() - 1];
	Пока Не УзелДерева[ИмяПоляСсылки] = ИерархическаяВыборка.Родитель Цикл
		ЭлементыДерева = УзелДерева.ПолучитьЭлементы();
		УзелДерева = ЭлементыДерева[ЭлементыДерева.Количество() - 1];
	КонецЦикла;
	Возврат УзелДерева.ПолучитьЭлементы().Добавить();
КонецФункции

// Функция ПолучитьИмяФайлаИнформационногоОбмена()
//     формирует имя файла обмена
//
// Параметры
//  ТипФайла  - {Строка} 
//      одна из: ZL_LIST, PERS_LIST, ZIP
//  ОрганизацияИсточник - {СправочникСсылка.Организации, СправочникСсылка.Контрагенты} 
//      источник пакета.
//  ОрганизацияПолучатель - {СправочникСсылка.Организации, СправочникСсылка.Контрагенты} 
//      получатель пакета.
//  ОтчетныйПериод  - {Дата} 
//      период формирвоания пакета
//
// Возвращаемое значение:
//   Строка   - сформированное имя файла.
///
Функция ПолучитьИмяФайлаИнформационногоОбмена(ТипФайла, ИсточникФинансирования = Неопределено, ОрганизацияИсточник, ОрганизацияПолучатель, ОтчетныйПериод)
	
	НаборСимволов = Новый Массив();
	
	НаборСимволов.Вставить(0, ПолучитьИдентификаторПередаваемыхДанных(ТипФайла));// КонстантаОзначающаяПередаваемыеДанные;
	// данные источника
	НаборСимволов.Вставить(1, ПолучитьПараметрТипыИсточника(ОрганизацияИсточник, ИсточникФинансирования));
	
	РеестровыйНомерИсточник_ = ПолучитьЗначениеРеквизитаФормированияРеестра(
																				ОрганизацияИсточник,
																				ИсточникФинансирования
																			);
	НаборСимволов.Вставить(2, ФорматироватьРеестровыйНомер(РеестровыйНомерИсточник_));
	// данные получатель
	НаборСимволов.Вставить(3, ПолучитьПараметрТипыИсточника(ОрганизацияПолучатель, ИсточникФинансирования));
	
	РеестровыйНомерПолучатель_ = ПолучитьЗначениеРеквизитаФормированияРеестра(
																				ОрганизацияПолучатель,
																				ИсточникФинансирования
																			);
	НаборСимволов.Вставить(4, ФорматироватьРеестровыйНомер(РеестровыйНомерПолучатель_));
	// данные отчетного периода
	НаборСимволов.Вставить(5, "_");
	НаборСимволов.Вставить(6, Формат(ОтчетныйПериод, "ДФ=""гг"""));
	НаборСимволов.Вставить(7, Формат(ОтчетныйПериод, "ДФ=""ММ"""));
	НаборСимволов.Вставить(8, ПолучитьПорядковыйНомерПакетаОтчетногоПериода(ОтчетныйПериод, ОрганизацияИсточник, ОрганизацияПолучатель));
	
	ОбщаяСтрока = "";
	
	Для каждого Символ Из НаборСимволов Цикл
		Если ПустаяСтрока(Символ) Тогда
			Возврат "";
		КонецЕсли;
		ОбщаяСтрока = ОбщаяСтрока + Символ;
	КонецЦикла; 
	
	
	Возврат ОбщаяСтрока;
	
КонецФункции

// Функция ПолучитьПорядковыйНомерПакетаОтчетногоПериода()
//     определяет новый порядковый номер для пакета обмена в омс
//
// Параметры
//  ОтчетныйПериод  - Дата
//         дата среза
//  Источник  - {СправочникСсылка.Организации, СправочникСсылка.Контрагенты}
//         отправитель файла.
//  Получатель  - {СправочникСсылка.Контрагенты, СправочникСсылка.Организации}
//         получатель файла.
//
// Возвращаемое значение:
//   Строка   - новый порядковый номер пакета.
///
Функция ПолучитьПорядковыйНомерПакетаОтчетногоПериода(ОтчетныйПериод, Источник, Получатель)
	
	НомерПакета = РегистрыСведений.РегистрацияПакетовИнформационногоОбмена.ПолучитьСледующийНомерПакетаОтчетногоПериода(
																					ОтчетныйПериод,
																					Источник,
																					Получатель
																					);
	
	Возврат Формат(НомерПакета, "ЧГ=0");
	
КонецФункции

// Функция ФорматироватьРеестровыйНомер()
//     получает реестровый номер участника обмена
//
// Параметры
//  Ссылка  - {СправочникСсылка.Организации, СправочникСсылка.Контрагенты}
//      участник обмена.
//
// Возвращаемое значение:
//   <Строка>   - реестровый номер участника.
///
Функция ФорматироватьРеестровыйНомер(Номер)
	
	Номер = СокрЛП(Номер);
	Номер = СтрЗаменить(Номер," ","");
	
	Возврат Номер;
	
КонецФункции

// Функция ПолучитьИдентификаторПередаваемыхДанных()
//     
//
// Параметры
//  Тип  - Строка
//      тип передаваемых данных
//
// Возвращаемое значение:
//   Строка   - идентификатор типа передаваемых данных.
///
Функция ПолучитьИдентификаторПередаваемыхДанных(Тип)
	
	Если Тип = "ZL_LIST" Тогда
		Возврат "H";
	ИначеЕсли Тип = "PERS_LIST" Тогда
		Возврат "L";
	ИначеЕсли Тип = "ZIP" Тогда
		Возврат "Z";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Процедура: СоздатьОбъект_ZL_LIST
//   Создает XDTO объект ZL_LIST, для отправки ответа
//   на запрос;
// 
// Параметры:
//   Документ{ДокументСсылка.РеестрОказаннойПомощи}
//     ссылка на документ по данных которого надо формировать файл.
//
// Возвращаемое значение:
//   XDTO объект   - созданный по документу.
///
Функция СоздатьОбъект_ZL_LIST(Документ)
	
	ИстФин_ = Неопределено;
	
	ТипЗначения_ZL_LIST = ТипFFOMS("ZL_LIST");
	
	СообщениеОбъект_ = СоздатьОбъектXDTO(ТипЗначения_ZL_LIST);
	
	ДанныеЗаполнения_ = Новый Массив;
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@VERSION","1.0");
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@DATA", ФорматДаты(ТекущаяДатаСеанса()));
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@FILENAME", ПолучитьИмяФайлаИнформационногоОбмена(
	"ZL_LIST",
	Неопределено,
	Документ.СтруктурнаяЕдиница.Организация,
	Документ.Контрагент,
	Документ.НачалоПериода
	)
	);
	////////////////////////////////////////////////////////////////////
	СчетНаОплату = Документы.АктОказанияУслуг.ПолучитьСчетРеестра(Документ.Ссылка);
	
	ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@CODE",    ПолучитьКодЗаписиСчета(Документ.Номер));
	ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@CODE_MO", ПолучитьКод(Документ.СтруктурнаяЕдиница.Организация, Неопределено));
	ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@YEAR",    Год(Документ.НачалоПериода));
	ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@MONTH",   Месяц(Документ.НачалоПериода));
	Если НЕ СчетНаОплату = Неопределено Тогда
		ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@NSCHET",  СчетНаОплату.Номер);
		ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@DSCHET",  ФорматДаты(СчетНаОплату.Дата));
	КонецЕсли;
	
	КодКонтрагента_ = ПолучитьКод(Документ.Контрагент, ИстФин_);
	Если ЗначениеЗаполнено(КодКонтрагента_) Тогда
		ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@PLAT", КодКонтрагента_);
	КонецЕсли;
	ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@SUMMAV", Документ.СуммаДокумента);
	Если ЗначениеЗаполнено(Документ.Комментарий) Тогда
		ДобавитьВМассив(ДанныеЗаполнения_,"SCHET.@COMENTS", Документ.Комментарий);
	КонецЕсли; 
	////////////////////////////////////////////////////////////////////
	
	ИтераторЗаписи = 0;
	Для Каждого СтрокаТЧПрием Из Документ.ОказанныеУслуги Цикл
		
		Прием = СтрокаТЧПрием.ДокументОснования;
		ЭлементЗаписи =  "ZAP[" + Формат(ИтераторЗаписи, "ЧН=0; ЧГ=0") + "]";
		
		// ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".@N_ZAP", СтрокаТЧПрием.НомерЗаписи);
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".@N_ZAP", СтрокаТЧПрием.НомерСтроки);
		// ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".@PR_NOV", Число(СтрокаТЧПрием.ПередачаОсуществлялась)); // TODO: после передачи менять реквизит
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".@PR_NOV", 0);
		// данные пациента
		// Для каждого Пациент Из Документ.ЗаписиПациента Цикл
		// Если Пациент.ИдентификаторПациента = СтрокаТЧПрием.ИдентификаторПациента Тогда
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".PACIENT.@ID_PAC",Строка(Прием.Контрагент.УникальныйИдентификатор()));
		КодПолисВид_ = ПолучитьКод(Прием.ПолисМедСтрахования.ТипПолиса, ИстФин_);
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".PACIENT.@VPOLIS", КодПолисВид_);
		Если ЗначениеЗаполнено(Прием.ПолисМедСтрахования.СерияПолиса) Тогда
			ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".PACIENT.@SPOLIS", Прием.ПолисМедСтрахования.СерияПолиса);
		КонецЕсли;
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".PACIENT.@NPOLIS", Прием.ПолисМедСтрахования.НомерПолиса);
		
		// КодСМО_ = ПолучитьКод(Прием.СМО, ИстФин_);
