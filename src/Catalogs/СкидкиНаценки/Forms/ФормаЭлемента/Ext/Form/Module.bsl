
&НаКлиенте
Перем пТипПолучателяПредыдущий;

#Область ОбработчикиСобытийФормы

// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	ДобавитьВПараметрыКэшируемыеДанные();
	
	// Заполним ТЧ Время работы по дням, пустыми днями
	Если Объект.ВремяПоДнямНедели.Количество() = 0 Тогда
		Для а = 1 по 7 Цикл
			НоваяСтрока = Объект.ВремяПоДнямНедели.Добавить();
			НоваяСтрока.ДеньНедели = Дата("2001010"+Строка(а));			
		КонецЦикла;		
	КонецЕсли;
	
	// Если это новый объект заполнить таблицу СЕ по умолчанию
	Если Объект.Ссылка.Пустая() Тогда
		Объект.НачислениеБонусами = Справочники.СкидкиНаценки.ОпредитьТипСкидкиНаценкиЭтоБонус(Объект.Родитель);
		ЭтаФорма.АвтоЗаголовок = Ложь;
		ЭтаФорма.Заголовок = ?(Объект.НачислениеБонусами = Истина, НСтр("ru= 'Бонус: ';en ='Bonus: '"), НСтр("ru= 'Скидка: ';en ='Discount: '")) + НСтр("ru= 'создание элемента';en ='element creation'");
		МассивСЕ = Новый Массив;
		МассивСЕ.Добавить(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		ВсеСЕ = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц(МассивСЕ);
		Для Каждого СтрокаМ ИЗ ВсеСЕ Цикл
			НоваяСтрока                    = ТаблицаСтруктурныеЕдиницыСкидки.Добавить();
			НоваяСтрока.СтруктурнаяЕдиница = СтрокаМ;
			НоваяСтрока.ДатаНачала         = ТекущаяДата();
		КонецЦикла;	
	Иначе
		// Если объект не новый загружаем парамтеры
		ПарамтерыДействия = РегистрыСведений.ДействиеСкидокНаценок.ПолучитьПарамтерыДействияСкидки(Объект.Ссылка);
		Для Каждого СтрокаТ ИЗ ПарамтерыДействия Цикл
			НоваяСтрока = ТаблицаСтруктурныеЕдиницыСкидки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТ);			
		КонецЦикла;	
	КонецЕсли;
	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("ГруппаПолучатели"		  				, "ГруппаПолучатели");
	СтруктураМеню.Вставить("ГруппаСтруктурныеЕдиницы"		  		, "ГруппаСтруктурныеЕдиницы");
	СтруктураМеню.Вставить("ГруппаВремяПоДнямНедели"		  		, "ГруппаВремяПоДнямНедели");
	СтруктураМеню.Вставить("ГруппаНаборПокупкиДляПолученияПодарков"	, "ГруппаНаборПокупкиДляПолученияПодарков");
	СтруктураМеню.Вставить("ГруппаНаборПодарков"					, "ГруппаНаборПодарков");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	УправлениеВидимостью();
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
		
КонецПроцедуры

// Процедура - При записи на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
КонецПроцедуры

// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЗаголовкиТабЧастей();
	
	СформироватьОписаниеСкидкиНаценки();
	
	ОбновитьПредставлениеПериода();
	
КонецПроцедуры

&НаКлиенте
// Обработчик перед записью на клиенте
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)	
	
	// Проверка заполнения списка ограничений
	Если Объект.ТипПолучателя = ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСегментомКлиентов") И Объект.Получатели.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru='Не указано ни одного сегмента клиентов.';en='No one segment clients specified.'"));
		Отказ = Истина;
		Возврат;
    ИначеЕсли Объект.ТипПолучателя = ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоВидамиДисконтныхКарт") И Объект.Получатели.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru='Не указано ни одной дисконтной карты.';en='No one discount cards indicated.'"));
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если ТаблицаСтруктурныеЕдиницыСкидки.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru='Не указано ни одной структурной единицы, для которых доступна данная скидка/наценка.';en='Not specified one structural unit for which isavailable this discount markup.'"));
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	Для Каждого СтрокаТ Из ТаблицаСтруктурныеЕдиницыСкидки Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТ.ДатаНачала) Тогда
			ПоказатьПредупреждение(, НСтр("ru='Не указана дата начала действия скидки/наценки в структурной единице ""';en='Not indicated date beginnings actions discounts extra charges in structural unit ""'") + СтрокаТ.СтруктурнаяЕдиница + """");
			Отказ = Истина;
			Возврат;
		КонецЕсли;	
	КонецЦикла;	
	Если Объект.УсловиеПредоставленияСкидки = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидки.Сумма")
		И Объект.ОбъектСкидки = ПредопределенноеЗначение("Перечисление.ОбъектСкидок.ПоПродажам") 
		И ПустаяСтрока(Элементы.ПериодНакопленияТип.ТекстРедактирования) Тогда
		
		Элементы.ПериодНакопленияТип.ОтметкаНезаполненного = Истина;
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru= 'Поле ""Период накопления"" не заполнено';en = 'Field ""Accumulation period"" is not filled'");
		Сообщение.Поле  = "ПериодНакопленияТип";
		Сообщение.ПутьКДанным = "Объект";
		Сообщение.КлючДанных  = Объект.Ссылка;
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	Иначе
		Элементы.ПериодНакопленияТип.ОтметкаНезаполненного = Ложь;
	КонецЕсли;
	
	Если Объект.НачислениеБонусами и НЕ ЗначениеЗаполнено(Объект.ЗначениеСкидкиНаценкиОбъектом) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст			= НСтр("ru= 'Поле ""Вид бонусного счета"" не заполнено';en ='Field ""Type of bonus account"" is not filled'");
		Сообщение.Поле			= "ЗначениеСкидкиНаценкиОбъектом";
		Сообщение.ПутьКДанным	= "Объект";
		Сообщение.КлючДанных	= Объект.Ссылка;
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ (Объект.НачислениеБонусами
		И (Объект.УсловиеПредоставленияСкидки = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидки.Всегда")
		ИЛИ Объект.УсловиеПредоставленияСкидки = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидки.Количество")
		ИЛИ Объект.УсловиеПредоставленияСкидки = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидки.Сумма")
		ИЛИ Объект.УсловиеПредоставленияСкидки = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидки.ОстатокНаЛицевомСчете"))) Тогда
		
		Объект.НеНачислятьБонусПриНаличииСкидки = Ложь;
		
	КонецЕсли;       
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ДействиеСкидокНаценок", ТаблицаСтруктурныеЕдиницыСкидки);
	
КонецПроцедуры

&НаКлиенте
// Обработчик после записи
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("ЗАПИСАНА_СКИДКА");
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - При изменении элементов вдимость описание
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ПриИзмененииЭлементовВдимостьОписание(Элемент)
	
	Если Объект.СпособПредоставленияСкидки = ПредопределенноеЗначение("Перечисление.СпособПредоставленияСкидки.ВидЦен") Тогда
		Объект.ПризнакИспользованиеНаУсмотрение = Ложь;	
	КонецЕсли;	
	
	УправлениеВидимостью();
	СформироватьОписаниеСкидкиНаценки();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПериодНакопленияТипПриИзменении".
//
Процедура ПериодНакопленияТипПриИзменении(Элемент)
	
	ОбновитьПредставлениеПериода();
	
	ОбновитьЗаголовкиТабЧастей();
	
	СформироватьОписаниеСкидкиНаценки();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Тип получателя при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ТипПолучателяПриИзменении(Элемент)
	
	Если пТипПолучателяПредыдущий <> Объект.ТипПолучателя И Объект.Получатели.Количество() > 0 Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОчиститьТЧПолучателей", ЭтотОбъект), НСтр("ru='Таблица получателей будет очищена. Подтверждаете выбор?';en='Table recipients willbe cleaned. Confirm selection?'"), РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	
	Если пТипПолучателяПредыдущий <> Объект.ТипПолучателя Тогда
		
		УправлениеВидимостью(); 
		СформироватьОписаниеСкидкиНаценки();
		
		Если Элементы.СтраницыСпособПримененияСкидки.ТекущаяСтраница = Элементы.СтраницаСППодарком Тогда		
			ПроцедураОбработкиНажатияМеню(Элементы["_ГруппаПолучатели"]);
		КонецЕсли;                                                                                
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
