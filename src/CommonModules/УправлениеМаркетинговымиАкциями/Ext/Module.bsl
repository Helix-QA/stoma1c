		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Реализация") Тогда 	
		// Если ЗначениеЗаполнено(ДокументОбъект.Контрагент) Тогда 
		//	МассивПолисов = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ДокументОбъект.Контрагент);
		//	Если МассивПолисов.Количество() > 0 Тогда 
		//		РазрешитьСкидки = Ложь;
		//	КонецЕсли;	
