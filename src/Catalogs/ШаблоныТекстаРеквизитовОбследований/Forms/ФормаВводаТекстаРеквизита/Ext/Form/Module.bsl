&НаКлиенте
// Обработчик при открытии формы на клиенте
//
Процедура ПриОткрытии(Отказ)
	Если СоставнойПодборРежим Тогда
     	 ОбновитьSVGПодбор();
	КонецЕсли;
КонецПроцедуры

