	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события сделка смена этапа
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//  ОбъектСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_СделкаСменаЭтапа(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Сделка"					, ОбъектСобытия);

		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		               |	СделкиИсторияИзмененияЭтапов.НомерСтроки КАК НомерСтроки,
		               |	СделкиИсторияИзмененияЭтапов.Дата КАК Дата,
		               |	СделкиИсторияИзмененияЭтапов.ПереходСЭтапа КАК ПереходСЭтапа,
		               |	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап КАК ПереходНаЭтап
		               |ПОМЕСТИТЬ ПоследнееИзменение
		               |ИЗ
		               |	Справочник.Сделки.ИсторияИзмененияЭтапов КАК СделкиИсторияИзмененияЭтапов
		               |ГДЕ
		               |	СделкиИсторияИзмененияЭтапов.Ссылка = &Сделка
		               |	И СделкиИсторияИзмененияЭтапов.Ссылка.ПометкаУдаления = ЛОЖЬ
		               |	И СделкиИсторияИзмененияЭтапов.Ссылка.ВидСделки = &ВидСделки
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Дата УБЫВ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ИсторияИзмененияЭтапов.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
