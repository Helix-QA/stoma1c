// Функция, возвращает слово, которое конвертировано с русского на английский языки.
//  Параметры:
//   Текст - строка, содержит текст, который нужно конвертировать.
//  Возвращаемое значение:
//   Результат - строка, которая уже конвертирована.
//
Функция ТранслитерацияРусАнгл(Текст) Экспорт 

	Результат = "";
	СимволыРус = "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯ"; 
	СимволыАнгл = "A|||B|||V|||G|||D|||E|||Yo||Zh||Z|||I|||Y|||K|||L|||M|||N|||O|||P|||R|||S|||T|||U|||F|||Kh||Ts||Ch||Sh||Sch|""|||Y|||`|||E|||Yu||Ja||"; 

	Для а = 1 по СтрДлина(Текст) Цикл 

		СимволТекста = Сред(Текст, а, 1); 

		Индекс = Найти(ВРег(СимволыРус), ВРег(СимволТекста)); 

		Если Индекс = 0 тогда 
			Результат = Результат + СимволТекста; 
		Иначе 
			ТрансСимволТекста = СтрЗаменить(Сред(СимволыАнгл, (Индекс - 1) * 4 + 1, 4), "|", "");
			Если (КодСимвола(СимволТекста) >= 97 И КодСимвола(СимволТекста) <= 122) ИЛИ (КодСимвола(СимволТекста) >= 1072 И КодСимвола(СимволТекста) <= 1103) Тогда
				ТрансСимволТекста = НРег(ТрансСимволТекста);
			КонецЕсли;
			Результат = Результат + ТрансСимволТекста;
		КонецЕсли 

	КонецЦикла ; 

	Возврат Результат; 

КонецФункции

// Функция, возвращает слово, которое конвертировано с английского на русский языки.
//  Параметры:
//   Текст - строка, содержит текст, который нужно конвертировать.
//  Возвращаемое значение:
//   Результат - строка, которая уже конвертирована.
//
Функция ТранслитерацияАнглРус(Текст) Экспорт 

	СимволыАнгл = "Sch|Yo||Zh||Kh||Ts||Ch||Sh||Yu||Ja||A|||B|||V|||G|||D|||E|||Z|||I|||Y|||K|||L|||M|||N|||O|||P|||R|||S|||T|||U|||F|||""|||Y|||`|||E|||"; 
	СимволыРус = "ЩЁЖХЦЧШЮЯАБВГДЕЗИЙКЛМНОПРСТУФЪЫЬЭ"; 

	Для а = 1 по СтрДлина(СимволыАнгл) / 4 Цикл 

		СимволСловаря = СтрЗаменить(Сред(СимволыАнгл, (а - 1) * 4 + 1, 4), "|", "");

		Текст = СтрЗаменить(Текст, НРег(СимволСловаря), НРег(Сред(СимволыРус, а, 1)));
		Текст = СтрЗаменить(Текст, ВРег(СимволСловаря), Сред(СимволыРус, а, 1));
		Текст = СтрЗаменить(Текст, СимволСловаря, Сред(СимволыРус, а, 1));
		
	КонецЦикла; 

	Возврат Текст; 

КонецФункции

