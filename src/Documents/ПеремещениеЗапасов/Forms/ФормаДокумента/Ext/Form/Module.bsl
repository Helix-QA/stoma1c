&НаСервере
Процедура УстановитьДоступностьЭлементов(ТипСтр = "СправочникСсылка.", ТипСтрП = "СправочникСсылка.")
	
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.ПеремещениеМеждуСкладами Тогда
		
		ТипСтр 								= ТипСтр + "Склады";
		ТипСтрП 							= ТипСтрП  + "Склады";
		Элементы.Склад.Заголовок            = "Склад отправитель";
		Элементы.СкладПолучатель.Заголовок  = "Склад получатель";
		// установка связей параметров выбора 
		ОрганизацияПоСЕ = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация");
 		Организация 	= ?(Не ЗначениеЗаполнено(ОрганизацияПоСЕ), Справочники.Организации.ПустаяСсылка(), ОрганизацияПоСЕ);
		НоваяСвязь 		= Новый СвязьПараметраВыбора("Отбор.Организация", "Организация", РежимИзмененияСвязанногоЗначения.Очищать);
		Массив	   		= Новый Массив();
		Массив.Добавить(НоваяСвязь);
		Элементы.СтруктурнаяЕдиницаПолучатель.СвязиПараметровВыбора = Новый ФиксированныйМассив(Массив);
		
	Иначе
		
		Элементы.СтруктурнаяЕдиницаПолучатель.СвязиПараметровВыбора = Новый ФиксированныйМассив(Новый Массив()); 
		
		Если Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОтСотрудника Тогда
			
			ТипСтр 								= ТипСтр + "Сотрудники";
			ТипСтрП 							= ТипСтрП  + "Склады";			
			Элементы.Склад.Заголовок           = "Персонал отправ.";
			Элементы.СкладПолучатель.Заголовок = "Склад получатель";   
			
		ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПередачаСотруднику Тогда
			
			ТипСтр 								= ТипСтр + "Склады";
			ТипСтрП 							= ТипСтрП  + "Сотрудники";			
			Элементы.Склад.Заголовок           = "Склад отправитель";
			Элементы.СкладПолучатель.Заголовок = "Персонал получат.";   
			
		ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПеремещенияМеждуСотрудниками Тогда
			
			ТипСтр 								= ТипСтр + "Сотрудники";
			ТипСтрП 							= ТипСтрП  + "Сотрудники";			
			Элементы.Склад.Заголовок           = "Персонал отправ.";		
			Элементы.СкладПолучатель.Заголовок = "Персонал получат.";  
			
		Иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;

	Элементы.Склад.ОграничениеТипа = Новый ОписаниеТипов(ТипСтр);
	Элементы.СкладПолучатель.ОграничениеТипа = Новый ОписаниеТипов(ТипСтрП);
	Элементы.СтруктурнаяЕдиница.Доступность = Не (Новый ОписаниеТипов(ТипСтр) = Новый ОписаниеТипов("СправочникСсылка.Склады"));
	Элементы.СтруктурнаяЕдиницаПолучатель.Доступность = Не (Новый ОписаниеТипов(ТипСтрП) = Новый ОписаниеТипов("СправочникСсылка.Склады"));	
	
КонецПроцедуры

