#Область СлужебныйПрограммныйИнтерфейс

#Область ИнтеграцияССмсСервисами

// Процедура - Проверить необходимость предложения пополнения баланса смс сервиса helix
//
Процедура ПроверитьНеобходимостьПредложенияПополненияБалансаСмсСервисаHelix() Экспорт
	
	РузальтатПроверкиБаланса = SMSРассылка.ПроверитьБалансСмсСервисаИПредложитьПополнение();
	
	Если РузальтатПроверкиБаланса = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПроверитьНеобходимостьПредложенияПополненияБалансаСмсСервисаHelixОбработчикТаймер(РузальтатПроверкиБаланса);
	
КонецПроцедуры

// Процедура - Проверить необходимость предложения пополнения баланса смс сервиса helix обработчик таймер 
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ПроверитьНеобходимостьПредложенияПополненияБалансаСмсСервисаHelixОбработчикТаймер(Результат) Экспорт
	
	Если Результат.Статус = "Выполнено" Тогда
	
	    РезультатаОперции = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если ЗначениеЗаполнено(РезультатаОперции) Тогда
			
			ПараметрыФормы = Новый Структура("СуммаПредыдущегоПоплнения,ПредлагаемаяСумма,ЭлектроннаяПочта,ТекущийБаланс,МинимальныйБаланс",
			РезультатаОперции.last_payment, 
			РезультатаОперции.recommendable_payment, 
			РезультатаОперции.email,
			РезультатаОперции.ТекущийБаланс,
			РезультатаОперции.min_balance);
			
			Оповещение = Новый ОписаниеОповещения("ОткрытьФормуПополненияБалансаСмсСервиса", ЭтотОбъект, ПараметрыФормы);
			
			Сообщение = "Баланс вашего смс счета приближается к нулю и на текущий момент составляет " + РезультатаОперции.ТекущийБаланс + "  рублей.";
			
			ПоказатьОповещениеПользователя(
			"Пополнить баланс",
			Оповещение,
			Сообщение,
			БиблиотекаКартинок.SMS32);
			
			УдалитьИзВременногоХранилища(Результат.АдресРезультата);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Открыть форму поплнения баланча смс сервиса
//
// Параметры:
//  ПараметрыФормы	 - 	 - 
//
Процедура ОткрытьФормуПополненияБалансаСмсСервиса(ПараметрыФормы) Экспорт
	
	ОткрытьФорму("Справочник.СервисыРассылки.Форма.ФормаЗапросаПополненияБалансаСмсСервиса", Новый Структура("ДанныеПополнения", ПараметрыФормы),,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

#КонецОбласти
#КонецОбласти
