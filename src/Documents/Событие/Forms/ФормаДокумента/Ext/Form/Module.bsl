// Обработать запись проведенных изменений меток.
//
Процедура ЗаписатьИзмененияМеток(ТекущийОбъект)
	
	Период = ТекущаяДатаСеанса();
	
	НаборЗаписей = РегистрыСведений.МеткиКлиентов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Клиент.Установить(ТекущийОбъект.Ссылка);
	
	МеткаПервичногоДобавлена = Ложь;
	
	Для Каждого ДанныеМетки ИЗ ЭтотОбъект.ТаблицаМеток Цикл
		
		Если ДанныеМетки.Активна = Ложь Тогда
			Продолжить;
		КонецЕсли;
		
		Если ДанныеМетки.Метка = Справочники.Метки.Первичный Тогда
			МеткаПервичногоДобавлена = Истина;
		КонецЕсли;
		
		НоваяМетка			 = НаборЗаписей.Добавить();
		НоваяМетка.Период	 = Период;
		НоваяМетка.Клиент	 = ТекущийОбъект.Ссылка;
		НоваяМетка.Метка	 = ДанныеМетки.Метка;
		НоваяМетка.Автор	 = ПараметрыСеанса.ТекущийПользователь;
		НоваяМетка.Активна	 = Истина;
		
	КонецЦикла;
	
	Если МеткаПервичногоДобавлена = Ложь Тогда
		
		СтатусПациента = СтатусКонтрагента(ТекущийОбъект.Контрагент);
		
		Если СтатусПациента = Перечисления.СтатусыКонтрагентов.Потенциальный Или СтатусПациента = Неопределено Тогда
			
			НоваяМетка			 = НаборЗаписей.Добавить();
			НоваяМетка.Период	 = Период;
			НоваяМетка.Клиент	 = ТекущийОбъект.Ссылка;
			НоваяМетка.Метка	 = Справочники.Метки.Первичный;
			НоваяМетка.Автор	 = ПараметрыСеанса.ТекущийПользователь;
			НоваяМетка.Активна	 = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

