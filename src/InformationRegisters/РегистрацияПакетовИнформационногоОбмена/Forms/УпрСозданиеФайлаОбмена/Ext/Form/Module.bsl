// Функция возвращает дул контрагента .
//
Функция ВернутьДУЛКонтрагента(Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	   "ВЫБРАТЬ ПЕРВЫЕ 1
	   |	ДокументыФизическихЛиц.Физлицо,
	   |	ДокументыФизическихЛиц.ВидДокумента,
	   |	ДокументыФизическихЛиц.Серия,
	   |	ДокументыФизическихЛиц.Номер,
	   |	ДокументыФизическихЛиц.ДатаВыдачи,
	   |	ДокументыФизическихЛиц.СрокДействия,
	   |	ДокументыФизическихЛиц.КемВыдан,
	   |	ДокументыФизическихЛиц.КодПодразделения,
	   |	ДокументыФизическихЛиц.ЯвляетсяДокументомУдостоверяющимЛичность,
	   |	ДокументыФизическихЛиц.Представление
	   |ИЗ
	   |	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
	   |ГДЕ
	   |	ДокументыФизическихЛиц.Физлицо = &Физлицо";

	Запрос.УстановитьПараметр("Физлицо", Контрагент);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ?(РезультатЗапроса.Пустой(), Неопределено, РезультатЗапроса.Выгрузить()[0]);
	
КонецФункции // ПолучитьКлючЗаписи()

// Функция ПроверитьФайлИнформационногоОбмена()
//     определяет новый порядковый номер для пакета обмена в омс
//
// Параметры
//  НачалоПериода  - Дата
//         дата среза
//  ОрганизацияИсточник  - СправочникСсылка.Организации
//         отправитель файла.
//  ОрганизацияПолучатель  - СправочникСсылка.Контрагенты
//         получатель файла.
//  ИмяФайлаАрхива  - Строка
//         имя файла, для проверки, если извлекаем из хранилища.
//  ПутьКФайлуАрхива  - Строка
//         путь к файлу на локальном диске.
//  АдресВХранилище  - Строка
//         адрес файла во временном хранилище.
//
// Возвращаемое значение:
//   Булево   - Истина, если переданный файл соответствует требованиям.
///
Функция ПроверитьФайлИнформационногоОбмена(
							НачалоПериода,
							ИсточникФинансирования,
							Отправитель,
							Получатель,
							ИмяФайлаАрхива,
							ПутьКФайлуАрхива,
							АдресВХранилище = ""
							
			)
	
	МассивФайловДляУдаления = Новый Массив();
	ВременныйКаталог = КаталогВременныхФайлов();
	// проверка на существование файла /////////////////////////////////////////////
	Если ЗначениеЗаполнено(АдресВХранилище) И
		 ЗначениеЗаполнено(ИмяФайлаАрхива)
	Тогда
		ПутьКФайлуАрхива = ВременныйКаталог + ИмяФайлаАрхива;
		ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(АдресВХранилище);
		ДвоичныеДанныеФайла.Записать(ПутьКФайлуАрхива);
		МассивФайловДляУдаления.Добавить(ПутьКФайлуАрхива);
		ФайлОбмена = Новый Файл(ПутьКФайлуАрхива);
	ИначеЕсли ЗначениеЗаполнено(ПутьКФайлуАрхива) Тогда
		ФайлОбмена = Новый Файл(ПутьКФайлуАрхива);
	Иначе
		ПоказатьСообщение("ФормированиеРеестровСчетов_НеУказаноРасположениеФайла");
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ФайлОбмена.Существует() Тогда
		ПоказатьСообщение("ФормированиеРеестровСчетов_ФайлАрхиваНеСуществует");
		Возврат Ложь;
	КонецЕсли;
	///////////////////////////////////////////////////////////////////////////////
	
	ИмяФайлаБезРаширения = ФайлОбмена.ИмяБезРасширения;
	РасширениеФайла = ФайлОбмена.Расширение;
	
	Ответ = ПроверитьИмяФайлаНаОтправителяИОтчетныйПериод(ИмяФайлаБезРаширения, ИсточникФинансирования, Отправитель, Получатель, НачалоПериода);
	
	// проверка на имя архива
	Если Ответ = Ложь Тогда
		Параметры_ = Новый Структура();
		Параметры_.Вставить("ИмяФайла", ИмяФайлаБезРаширения);
		ПоказатьСообщение("ФормированиеРеестровСчетов_ИмяФайлаНеСоответствует",Параметры_);
		Возврат Ложь;
	КонецЕсли; 
	
	// проверка возможности распаковки /////////////////////////////////
	ПутьРаспаковки = ВременныйКаталог + ИмяФайлаБезРаширения;
	Архив = РаспаковатьАрхив(ПутьКФайлуАрхива, ПутьРаспаковки);
	Если Архив = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли; 
	МассивФайловДляУдаления.Добавить(ПутьРаспаковки);
	///////////////////////////////////////////////////////////////////
	
	Если Архив.Элементы.Количество() <> 2 Тогда
		ПоказатьСообщение("ФормированиеРеестровСчетов_СтандартФайловВАрхиве");
	КонецЕсли; 
	
	Для каждого ФайлАрхива Из Архив.Элементы Цикл
		ФорматXDTOКорректен = Истина;
		Если ВРег(ФайлАрхива.Расширение) <> "XML" Тогда
			ПоказатьСообщение("ФормированиеРеестровСчетов_СтандартФайловВАрхиве");
			Возврат Ложь;
		КонецЕсли; 
		ПутьКФайлуАрхива = ПутьРаспаковки +"\" + ФайлАрхива.Имя;
		ИмяБезРасширения = ФайлАрхива.ИмяБезРасширения;
		Префикс = Лев(ФайлАрхива.Имя, 1);
		// проверка на отправителя и период
		Ответ = ПроверитьИмяФайлаНаОтправителяИОтчетныйПериод(ИмяБезРасширения, ИсточникФинансирования, Отправитель, Получатель, НачалоПериода);
		Если Ответ = Ложь Тогда
			Параметры_ = Новый Структура();
			Параметры_.Вставить("ИмяФайла", ИмяФайлаБезРаширения);
			ПоказатьСообщение("ФормированиеРеестровСчетов_ИмяФайлаНеСоответствует",Параметры_);
			Возврат Ложь;
		КонецЕсли;
		
		// проверка на нахождение только допустимых файлов
		Попытка
			Если Префикс = "H" Тогда
				ФорматXDTOКорректен = ПроверитьОбъектXDTO(ПутьКФайлуАрхива, ТипFFOMS("ZL_LIST"));
			ИначеЕсли Префикс = "L" Тогда
				ФорматXDTOКорректен = ПроверитьОбъектXDTO(ПутьКФайлуАрхива, ТипFFOMS("PERS_LIST"));
			Иначе
				Параметры_ = Новый Структура();
				Параметры_.Вставить("ИмяФайла", ФайлАрхива.Имя);
				ПоказатьСообщение("ФормированиеРеестровСчетов_ФайлВАрхивеНеСоответствуетТребованиям",Параметры_);
				Возврат Ложь;
			КонецЕсли;
		Исключение
			Рез = ОбработатьИнформациюОбОшибке(ИнформацияОбОшибке());
			Сообщение_ = Новый СообщениеПользователю;
			Сообщение_.Текст = Рез;
			Сообщение_.Сообщить();
			Возврат Неопределено;
		КонецПопытки;
		Если НЕ ФорматXDTOКорректен Тогда
			Параметры_ = Новый Структура();
			Параметры_.Вставить("ИмяФайла", ФайлАрхива.Имя);
			ПоказатьСообщение("ФормированиеРеестровСчетов_НеКорректнаяСтруктураФайла",Параметры_);
			Возврат Ложь;
		КонецЕсли; 
	КонецЦикла;
	
	УдалитьФайлыПоМассивуПутей(МассивФайловДляУдаления);
	
	Возврат Истина;
	
КонецФункции

// Функция ПроверитьОбъектXDTO()
//     проверяет ОбъектXDTO на валидность
//
// Параметры
//  ПутьКФайлу  - Строка
//         путь к файлу
//  Тип  - ТипXDTO
//         типXDTO
//
// Возвращаемое значение:
//   Булево   - Истина, если проверка прошла успешно.
///
Функция ПроверитьОбъектXDTO(ПутьКФайлу, Тип)
	
	ЧтениеXML_ = Новый ЧтениеXML();
	ЧтениеXML_.ОткрытьФайл(ПутьКФайлу,,,"windows-1251");
	Попытка
		ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(
						ЧтениеXML_,
						Тип
					);
	Исключение
		Инфо = ИнформацияОбОшибке();
		Рез = ОбработатьИнформациюОбОшибке(Инфо);
		Сообщение_ = Новый СообщениеПользователю;
		Сообщение_.Текст = Рез;
		Сообщение_.Сообщить();
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция ПолучитьЗначениеРеквизитаФормированияРеестра
//
// Параметры:
//  Данные  - Произвольный - <описание параметра>
//                 <продолжение описания параметра>
//  ИсточникФинансирования  - <СправочникСсылка.ИсточникиФинансирования - источник
//                 финансирования для определения по какому реквизииту получать данные.
//
// Возвращаемое значение:
//   Строка   - имя реквизита, с которого необходимо получить данные для формирования реестра.
//
Функция ПолучитьЗначениеРеквизитаФормированияРеестра(Данные, ИсточникФинансирования = Неопределено)
		
	// ОБМЕН ПО ОМС
	СоответствиеРеквизитов = Новый Соответствие;
	СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.Организации"), "РеестровыйНомерОМС");
	// СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.СтруктураПредприятия"), "РеестровыйНомерОМС");
	СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.Контрагенты"), "РеестровыйНомерОМС");
	СоответствиеРеквизитов.Вставить(Тип("ПеречислениеСсылка.ТипыПолиса"), Перечисления.ТипыПолиса);
	// СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.ПрофилиМедицинскойПомощи"), "КодПоОМС");
	СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.Специализации"), "КодПоОМС");
	СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.Сотрудники"), "КодПоОМС");
	СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.ВидыДокументовФизическихЛиц"), "КодПоОМС");
	// СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.ИсходыЗаболеванийПоликлиника"), Справочники.ИсходыЗаболеванийПоликлиника);
	// СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.РезультатыОбращенийПоликлиника"), Справочники.РезультатыОбращенийПоликлиника);
	СоответствиеРеквизитов.Вставить(Тип("ПеречислениеСсылка.ПолФизическогоЛица"), Перечисления.ПолФизическогоЛица);
	// СоответствиеРеквизитов.Вставить(Тип("СправочникСсылка.СпособыОплатыМедицинскойПомощи"), Справочники.СпособыОплатыМедицинскойПомощи);
	
	ЗначениеСоответствия_ = СоответствиеРеквизитов.Получить(ТипЗнч(Данные));	
	
	Если ТипЗнч(ЗначениеСоответствия_) = Тип("Строка") Тогда
		Значение_ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные, ЗначениеСоответствия_);
	Иначе
		Значение_ = ЗначениеСоответствия_.КодПоОМС(Данные);
	КонецЕсли;
	
	Возврат Значение_;
	
КонецФункции // ПолучитьИмяРеквизитаФормированияРеестра()

 // Процедура: ПолучитьТипXDTO
 //   Создает объект XDTO по типу
 // 
 // Параметры:
 ///
Функция СоздатьОбъектXDTO(ТипОбъекта, Фабрика_XDTO = Неопределено)
	
	Если Фабрика_XDTO = Неопределено Тогда
		Возврат ФабрикаXDTO.Создать(ТипОбъекта);
	Иначе
		Возврат Фабрика_XDTO.Создать(ТипОбъекта);
	КонецЕсли;
	
КонецФункции

 // Процедура: ЗаполнитьОбъектXDTO
 //   Заполняет объект xdto по его описанию
 // 
 // Параметры:
 //   Объект
 //     ОбхектXDTO
 //   ДанныеЗаполнения
 //     Массив стркутур Структура("Ключ,Значение"),
 //     где ключ  - строковый путь "tag1.tag2.tag3[0].@attr1",
 //     Значение - произвольное значение.
 //   Фабрика_XDTO
 //   Разделитель
 //		Разделитель в строковом пути
 ///
Процедура ЗаполнитьОбъектXDTO(Объект, ДанныеЗаполнения, Фабрика_XDTO = Неопределено, Разделитель=".")
	
	Для Каждого КлючЗначение_ Из ДанныеЗаполнения Цикл
		Ключи_ = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КлючЗначение_.Ключ, Разделитель);
		ТекОбъект_ = Объект;
		ПредыдущийОбъект_ = Неопределено;
		Для Каждого Ключ_ Из Ключи_ Цикл
			ПредыдущийОбъект_ = ТекОбъект_;
			Если Не ЭтоАтрибут(Ключ_) Тогда
				Если ОбъектСуществует(ТекОбъект_,Ключ_) Тогда
					ТекОбъект_ = ПолучитьОбъектПоля(ТекОбъект_,Ключ_);
				Иначе
					ТекОбъект_ = СоздатьОбъектПоля(ТекОбъект_, Ключ_, Фабрика_XDTO);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если ТекОбъект_ <> Неопределено Тогда
			Если КлючЗначение_.Значение <> Неопределено И КлючЗначение_.Значение <> "" Тогда
				Если ЭтоАтрибут(Ключ_) Тогда
					ТекОбъект_[ИмяКлюча(Ключ_)] = КлючЗначение_.Значение;
				ИначеЕсли ТипЗнч(ТекОбъект_) = Тип("Строка") И ПредыдущийОбъект_ <> Неопределено Тогда
					ПредыдущийОбъект_[ИмяКлюча(Ключ_)] = КлючЗначение_.Значение;
				Иначе
					Последовательность_ = ТекОбъект_.Последовательность();
					Последовательность_.Очистить();
					Последовательность_.Добавить(КлючЗначение_.Значение, Неопределено);
				КонецЕсли;
			КонецЕсли;
		Иначе
			ПредыдущийОбъект_[ИмяКлюча(Ключ_)] = КлючЗначение_.Значение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

 // Функция ИмяКлюча
 ///
Функция ИмяКлюча(Ключ)
	Если ЭтоАтрибут(Ключ) Тогда
		Возврат ИмяКлюча(Прав(Ключ,СтрДлина(Ключ) - 1));
	ИначеЕсли ЭтоСписок(Ключ) Тогда
		Массив_ = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Ключ, "[");
		Возврат ИмяКлюча(Массив_[0]);
	ИначеЕсли КлючСодержитТип(Ключ) Тогда
		Массив_ = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Ключ, "{");
		Возврат ИмяКлюча(Массив_[0]);
	Иначе
		Возврат Ключ;
	КонецЕсли;
КонецФункции

 // Функция ЭтоСписок
 ///
Функция ЭтоСписок(Ключ)
	Если Прав(Ключ,1) = "]" Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

 // Функция КлючСодержитТип
 ///
Функция КлючСодержитТип(Ключ)
	Возврат Найти(Ключ,"{") <> 0;
КонецФункции

 // Функция СоздатьОбъектПоля
 ///
Функция СоздатьОбъектПоля(Объект, Ключ, Фабрика_XDTO = Неопределено)

	Если КлючСодержитТип(Ключ) Тогда
		ИмяТипа_ = ПолучитьИмяТипа(Ключ);
		Тип_ = ПолучитьТипXDTO(ИмяТипа_.ИмяТипа, ИмяТипа_.ПространствоИмен, Фабрика_XDTO);
		Результат_ = СоздатьОбъектXDTO(
									Тип_,
									Фабрика_XDTO
								);
	Иначе
		Результат_ = СоздатьОбъектXDTO(
									Объект.Тип().Свойства.Получить(ИмяКлюча(Ключ)).Тип,
									Фабрика_XDTO
								);
	КонецЕсли;
	
	Если Результат_ <> Неопределено Тогда
		Если ТипЗнч(Объект[ИмяКлюча(Ключ)]) = Тип("СписокXDTO") Тогда
			Объект[ИмяКлюча(Ключ)].Добавить(Результат_);
		Иначе
			Объект[ИмяКлюча(Ключ)] = Результат_;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат_;
КонецФункции

 // Функция ПолучитьИмяТипа
 ///
Функция ПолучитьИмяТипа(Ключ)
	Лев_ = Найти(Ключ,"{");
	Прав_ = Найти(Ключ,"}");
	Зпт_ = Найти(Ключ,",");
	Содержимое_ = Сред(Ключ,Лев_ + 1,Прав_ - Лев_ - 1);
	ПространствоИмен_ = ВосстановитьПространствоИмен(Лев(Содержимое_,Зпт_ - Лев_ - 1));
	Тип_ = Прав(Содержимое_,Прав_ - Зпт_ - 1);
	Возврат Новый Структура("ПространствоИмен,ИмяТипа",ПространствоИмен_,Тип_);
КонецФункции

 // Процедура: ВосстановитьПространствоИмен
 //   Восстанавливает ПИ после преобразования функцией ПреобразоватьПространствоИмен
 // 
 // Параметры:
 ///
Функция ВосстановитьПространствоИмен(ПИ) 
	Возврат СтрЗаменить(ПИ,"#<dot>#",".");
КонецФункции

 // Процедура: ПолучитьТипXDTO
 //   Получает тип XDTO по имени типа и пространству имен
 // 
 // Параметры:
 ///
Функция ПолучитьТипXDTO(ИмяТипа, ПространствоИмен, Фабрика_XDTO = Неопределено)
	
	Если Фабрика_XDTO = Неопределено Тогда
		Возврат ФабрикаXDTO.Пакеты.Получить(ПространствоИмен).Получить(ИмяТипа);
	Иначе
		Возврат Фабрика_XDTO.Пакеты.Получить(ПространствоИмен).Получить(ИмяТипа);
	КонецЕсли;
	
КонецФункции

 // Функция ПолучитьОбъектПоля
 ///
Функция ПолучитьОбъектПоля(Объект, Ключ)
	Если ТипЗнч(Объект[ИмяКлюча(Ключ)]) = Тип("СписокXDTO") Тогда
		Если ЭтоСписок(Ключ) Тогда
			Индекс_ = ПолучитьИндекс(Ключ);
			Возврат Объект[ИмяКлюча(Ключ)].Получить(Индекс_);
		Иначе
			Возврат Объект[ИмяКлюча(Ключ)].Получить(0);
		КонецЕсли;
	Иначе
		Возврат Объект[ИмяКлюча(Ключ)];
	КонецЕсли;

КонецФункции

 // Функция ПолучитьИндекс
 ///
Функция ПолучитьИндекс(Ключ)
	Массив_ = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Ключ, "[");
	Возврат Число(Лев(Массив_[1],СтрДлина(Массив_[1])-1));
КонецФункции

 // Функция ОбъектСуществует
 ///
Функция ОбъектСуществует(Объект, Ключ)
	Если ТипЗнч(Объект[ИмяКлюча(Ключ)]) = Тип("СписокXDTO") Тогда
		Список_ = Объект[ИмяКлюча(Ключ)];
		
		Если ЭтоСписок(Ключ) Тогда
			Индекс_ = ПолучитьИндекс(Ключ);
			Возврат Список_.Количество() > Индекс_;
		Иначе
			Возврат Список_.Количество() <> 0;
		КонецЕсли;
	Иначе
		Возврат Объект[ИмяКлюча(Ключ)] <> Неопределено;
	КонецЕсли;
КонецФункции

// Функция ЭтоАтрибут
 ///
Функция ЭтоАтрибут(Ключ)
	Если Лев(Ключ,1) = "@" Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

 // Функция: Получить
 //   возвращает текст и заголовок сообщения пользователю, соответствующего
 //   имени сообщения в справочнике.
 //
 // Параметры:
 //   ИмяСообщения {Строка}
 //     Имя сообщения строкой.
 //   Параметры
 //     Структура, которая хранит значения по ключам. Каждое вхождение подстроки вида
 //     #Ключ#, где Ключ - это ключ структуры, будет заменено на значение по этому ключу.
 //     Параметр не обязательный.
 //   ТолькоТекст {Булево}
 //     Определяет возвращаемое значение. Если Ложь, то вернется структура.
 //   Язык {Строка}
 //     Код языка для работы с НСтр.
 //
 // Возврат:
 //   {Строка, Структура}
 //        Текст сообщения или структура с двумя полями: Текст и Заголовок
 ///
Функция Получить(
	Знач ИмяСообщения,
	Знач Параметры = Неопределено,
	Знач ТолькоТекст = Истина,
	Знач Язык = ""
) Экспорт
	
	СообщениеСтруктура = ПолучитьПовтИсп(ИмяСообщения, Язык);
	Сообщение = Новый Структура(СообщениеСтруктура);
	
	Если ТипЗнч(Параметры) = Тип("Структура") Тогда
		Для Каждого Параметр Из Параметры Цикл
			Шаблон = "#" + Параметр.Ключ + "#";
			Замена = Параметр.Значение;
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, Шаблон, Замена);
		КонецЦикла;
	КонецЕсли;
	
	Если ТолькоТекст = Истина Тогда
		Возврат Сообщение.Текст;
	Иначе
		Возврат Сообщение;
	КонецЕсли;
	
КонецФункции

 // Функция: Получить
 //   Получает сообщение пользователю по заданному идентификатору.
 //
 // Параметры:
 //   ИмяСообщения{Строка}
 //        Имя сообщения для получения
 //   Язык{Строка}
 //        Код языка, для получения строки НСтр
 //
 // Возврат: {Строка}
 ///
Функция ПолучитьПовтИсп(Знач ИмяСообщения, Знач КодЯзыка = "") 
	
	Сообщение = Новый Структура("Текст, Заголовок, Описание");
	
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
				"ВЫБРАТЬ ПЕРВЫЕ 1
				|	СообщенияПользователю.Наименование КАК Заголовок,
				|	СообщенияПользователю.ТекстНСтр КАК Текст,
				|	СообщенияПользователю.Описание
				|ИЗ
				|	Справочник.СообщенияПользователю КАК СообщенияПользователю
				|ГДЕ
				|	СообщенияПользователю.ПометкаУдаления = ЛОЖЬ
				|	И СообщенияПользователю.ИмяСообщения = &ИмяСообщения";
		Запрос.УстановитьПараметр("ИмяСообщения", ИмяСообщения);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(Сообщение, Выборка);
			Сообщение.Текст = НСтр(Сообщение.Текст, КодЯзыка);
		Иначе
			ВызватьИсключение НСтр("ru='Неизвестное сообщение!'");
		КонецЕсли;
		
	Исключение
		
		Сообщение.Текст = НСтр("ru='Неизвестное сообщение: " + ИмяСообщения + "'");
		Сообщение.Заголовок = НСтр("ru='Неизвестное сообщение!'");
		
	КонецПопытки;
	
	Результат = Новый ФиксированнаяСтруктура(Сообщение);
	
	Возврат Результат;
	
КонецФункции

// Функция ПолучитьПараметрТипыИсточника()
//     определяет тип участника обмена данными
//
// Параметры
//  Ссылка  - {СправочникСсылка.Организации, СправочникСсылка.Контрагенты}
//      участник обмена.
//
// Возвращаемое значение:
//   <Строка>   - тип участника обмена.
///
Функция ПолучитьПараметрТипыИсточника(Ссылка, ИсточникФинансирования)
	
	Параметр_ = "";
	
	Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Организации") Тогда
		Параметр_ =  "M";
	ИначеЕсли ТипЗнч(Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
		КодКонтрагента_ = ПолучитьЗначениеРеквизитаФормированияРеестра(Ссылка, ИсточникФинансирования);
		ДлинаКода = СтрДлина(КодКонтрагента_);
		Если ДлинаКода = 2 Тогда
			Параметр_ = "T";
		ИначеЕсли ДлинаКода = 5 Тогда
			Параметр_ = "S";
		КонецЕсли;
	КонецЕсли;
	
	Возврат Параметр_;
	
КонецФункции

Функция ПолучитьКод(Ссылка, ИсточникФинансирования)
	
	Возврат ПолучитьЗначениеРеквизитаФормированияРеестра(Ссылка, ИсточникФинансирования);
	
КонецФункции

&НаКлиенте
 // Процедура: ВывестиПредупреждение
 //   выводит предупреждение.
 //
 // Параметры:
 //   ИмяСообщения - {Строка} - 
 //     Имя сообщения строкой.
 //   Параметры - {Структура} - 
 //     Структура, которая хранит значения по ключам. Каждое вхождение подстроки вида
 //     #Ключ#, где Ключ - это ключ структуры, будет заменено на значение по этому ключу.
 //     Параметр не обязательный.
 //   ИспользоватьОповещение - {Булево} - 
 //     Признак того, что оповещение необходимо
 //   Модуль {УправляемаяФорма; КомандаКомандногоИнтерфейса; ОбщийМодуль}
 //     Программный модуль, процедура которого будет вызвана.
 //   ИмяОповещенияОЗавершении - {Строка} - 
 //     Содержит описание процедуры, которая будет вызвана
 //     после закрытия окна предупреждения со следующими параметрами.
 //   ДополнительныеПараметры - {Структура} - 
 //     Дополнительные параметры, которые будут переданы с оповещением
 //   Таймаут - {Число} - 
 //     Интервал времени в секундах, в течение которого система будет ожидать ответа пользователя.
 //     По истечении интервала окно предупреждения будет закрыто.
 //     Если параметр не указан, то время ожидания не ограничено.
 //   ИспользоватьЗаголовок - {Булево} - 
 //     Признак того, что необходимо использовать заголовок при выводе
 //   ИмяСообщенияЗаголовка - {Строка} - 
 //     Имя сообщения с заголовком строкой
 //   ПараметрыСообщенияЗаголовка - {Структура} - 
 //     Структура, которая хранит значения по ключам. Каждое вхождение подстроки вида
 //     #Ключ#, где Ключ - это ключ структуры, будет заменено на значение по этому ключу.
 //     Параметр не обязательный.
 //   Язык - {Строка} - 
 //     Код языка для работы с НСтр.
 //
 ///
Процедура ВывестиПредупреждение(
		Знач ИмяСообщения,
		Знач Параметры = Неопределено,
		Знач ИспользоватьОповещение = Ложь,
		Знач Модуль = Неопределено,
		Знач ИмяОповещенияОЗавершении = Неопределено,
		Знач ДополнительныеПараметры = Неопределено,
		Знач ИспользоватьЗаголовок = Ложь,
		Знач ИмяСообщенияЗаголовок = Неопределено,
		Знач ПараметрыСообщенияЗаголовка = Неопределено,
		Знач Таймаут = 0,
		Знач Язык = ""
	)
	
	ДанныеСообщения = Получить(ИмяСообщения, Параметры, Ложь, Язык);
	
	// определяемся с заголовком
	Если ИмяСообщенияЗаголовок = Неопределено Тогда
		ЗаголовокТекст_ = ДанныеСообщения.Заголовок;
	Иначе
		ЗаголовокТекст_ = Получить(ИмяСообщенияЗаголовок, ПараметрыСообщенияЗаголовка, Истина, Язык);
	КонецЕсли;
	
	Если ИспользоватьОповещение = Истина И Модуль <> Неопределено Тогда
		// оповещаем по завершении
		
		Если ИмяОповещенияОЗавершении = Неопределено Тогда
			// некое универсальное оповещение
			ОписаниеОповещения_ = Новый ОписаниеОповещения("ПослеЗакрытияПредупреждения", Модуль, ДополнительныеПараметры);
		Иначе
			ОписаниеОповещения_ = Новый ОписаниеОповещения(ИмяОповещенияОЗавершении, Модуль, ДополнительныеПараметры);
		КонецЕсли;
		
		
		Если ИспользоватьЗаголовок = Истина Тогда
		
			ПоказатьПредупреждение(ОписаниеОповещения_, ДанныеСообщения.Текст, Таймаут, ЗаголовокТекст_);
		
		Иначе
		
			ПоказатьПредупреждение(ОписаниеОповещения_, ДанныеСообщения.Текст, Таймаут);
			
		КонецЕсли;
		
	Иначе
		// без оповещений
		
		Если ИспользоватьЗаголовок = Истина Тогда
		
			ПоказатьПредупреждение(, ДанныеСообщения.Текст, Таймаут, ЗаголовокТекст_);
		
		Иначе
		
			ПоказатьПредупреждение(, ДанныеСообщения.Текст, Таймаут);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 
