// Функция - Выполнить операцию по платежной карте
// 
// Параметры:
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВыполнитьОперациюПоПлатежнойКарте(ОписаниеОшибки = Неопределено)
	
	СтрокиОплаты  = ПолучитьСтрокиСВнесеннойОплатой(ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта"));
	ДанныеПлатежа = Неопределено;
	
	Если ЗначениеЗаполнено(СтрокиОплаты) Тогда
		
		ФрПодключен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущаяКасса, "ИспользоватьБезПодключенияОборудования") = Ложь;
		
		Если ЗначениеЗаполнено(ЭквайринговыйТерминал) 
			И ФрПодключен = Истина 
			И ЭквайринговыйТерминалПодключен(ЭквайринговыйТерминал) Тогда		
						
			СсылкаНаобрудованиеФР = ПолучитьФРКассы(ТекущаяКасса);
			Если НЕ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.Возврат") Тогда
				ДанныеПлатежа = МенеджерОборудованияКлиент.ВыполнитьПоступлениеПлатежаЭквайринг(ЭквайринговыйТерминал, СсылкаНаобрудованиеФР, ЭтаФорма.УникальныйИдентификатор, СтрокиОплаты[0].Внесено, ОписаниеОшибки); 			
			Иначе
				ДанныеПлатежа = МенеджерОборудованияКлиент.ВыполнитьВозвратПлатежаЭквайринг(ЭквайринговыйТерминал, СсылкаНаобрудованиеФР, ЭтаФорма.УникальныйИдентификатор, СтрокиОплаты[0].Внесено, ОписаниеОшибки); 
			КонецЕсли;
			
		Иначе
			Возврат Новый Структура("НомерКарты,СсылочныйНомер,НомерЧека,КодАвторизации", СтрокиОплаты[0].ЭквайрингНомерПлатежнойКарты, СтрокиОплаты[0].ЭквайрингСсылочныйНомер, СтрокиОплаты[0].НомерЧекаЭТ, СтрокиОплаты[0].ЭквайрингКодАвторизации);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеПлатежа;
	
