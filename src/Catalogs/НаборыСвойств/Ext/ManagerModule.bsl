
#Область СлужебныеПроцедурыИФункции

// Функция - Проверить на наличие предопределенного
//
Функция ПроверитьНаНаличиеПредопределенного(ИмяПредопределенного) Экспорт
	
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИмяПредопределенныхДанных", ИмяПредопределенного);
	Запрос.Текст = "ВЫБРАТЬ
	               |	НаборыСвойств.Ссылка,
				   |	НаборыСвойств.ИмяПредопределенныхДанных
	               |ИЗ
	               |	Справочник.НаборыСвойств КАК НаборыСвойств";
				   
	ВыборкаСправочника = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаСправочника.Следующий() Цикл
		Если ВыборкаСправочника.ИмяПредопределенныхДанных = ИмяПредопределенного Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат Результат;
 
КонецФункции

#КонецОбласти
