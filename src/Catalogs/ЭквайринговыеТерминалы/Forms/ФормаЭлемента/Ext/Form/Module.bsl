// Процедура, обрабатывает изменение типа фискализации.
//
Процедура ОбработатьИзменениеТипаФискализации(Форма, ЗаголовокФискализации)
	
	Элементы 		= Форма.Элементы;
	ТипФискализации = Форма.Объект.ТипФискализации;
	
	Если ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.НеФискализировать")
		ИЛИ ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВСбербанке")
		ИЛИ ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВТинькофф")
		ИЛИ ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВСДМБанке") Тогда
		
		Элементы.КассовыйСервер.Видимость = Ложь;
	ИначеЕсли ТипФискализации = ПредопределенноеЗначение("Перечисление.ТипыФискализации.КассовыйСервер") Тогда
		Элементы.ДекорацияЗаглушка.МаксимальнаяШирина = 6;
	КонецЕсли;
	
	Элементы.ОтобразитьВыборТиповФискализации.Заголовок = ЗаголовокФискализации;
	
КонецПроцедуры

