	Если ЗначениеЗаполнено(Задание) Тогда 
		ЗаданиеОбъект = Задание.ПолучитьОбъект();
		ЗаданиеОбъект.ЗапланированныйМоментЗапуска = УниверсальноеВремя(ДатаПланирования);
		ЗаданиеОбъект.ДополнительныеСвойства.Вставить("ЗапланированныйМоментЗапуска", ЗаданиеОбъект.ЗапланированныйМоментЗапуска);		
		ЗаданиеОбъект.ОбменДанными.Загрузка = Истина;
		Попытка
			ЗаданиеОбъект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Актуализировать статусы пациентов
//
Процедура АктуализироватьСтатусыПациентов() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.АктуализацияСтатусовПациентов);
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	РегистрыСведений.СтатусыКонтрагентов.АктуализироватьСтатусыВсехПациентов();
	
	// ............
	
	ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.АктуализацияСтатусовПациентов);	
	
КонецПроцедуры

// Функция - возвращает АдресаЭП контрагента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАдресаЭПКонтрагента(Контрагент) Экспорт
	
	АдресаЭПКонтрагента = Новый Массив;
	
	Если ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда		
		Отбор = Новый Структура("Вид", Справочники.ВидыКонтактнойИнформации.EmailКлиента);
	Иначе
		Отбор = Новый Структура("Вид", Справочники.ВидыКонтактнойИнформации.EmailПользователя);
	КонецЕсли;
	
	НайденныеСтроки = Контрагент.КонтактнаяИнформация.НайтиСтроки(Отбор);
	
	Для Каждого Контакт Из НайденныеСтроки Цикл
		Если ЗначениеЗаполнено(Контакт.АдресЭП) Тогда
			АдресаЭПКонтрагента.Добавить(Контакт.АдресЭП);
		КонецЕсли;
	КонецЦикла;
	
	Возврат АдресаЭПКонтрагента;
	
КонецФункции

