// Процедура - Отправить электронное письмо
//
// Параметры:
//  ПараметрыEmailОбъекта	 - 	 - 
//
Процедура ОтправитьЭлектронноеПисьмо(ПараметрыEmailОбъекта, ОписаниеОшибки)
	
	Если ПараметрыEmailОбъекта.ПараметрыРегистрацииТриггера = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ОписаниеОшибки 			= "";
	ДополнительноеСообщение = "";
	
	Если НЕ ЗначениеЗаполнено(ПараметрыEmailОбъекта.УчетнаяЗапись) Тогда 
		ОписаниеОшибки = НСтр("ru= 'Не выбрана учетная запись электронной почты';en= 'No email account selected'");
		Возврат;
	КонецЕсли;
	
	// Актуализируем флаг активности учетной записи
	УчетнаяЗаписьИспользуетсяДляОтправки = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ПараметрыEmailОбъекта.УчетнаяЗапись, "ИспользоватьДляОтправки");
	
	// Уходим, если не активна
	Если УчетнаяЗаписьИспользуетсяДляОтправки = Ложь Тогда 
		ОписаниеОшибки = НСтр("ru= 'Выбранная учетная запись электронной почты не используется для отправки электронных писем';en= 'The selected email account is not used to send emails'");
		Возврат;
	КонецЕсли;
	
	// Проверим авторизацию и актуализируем активность учетной записи
	РаботаСПочтовымиСообщениямиСлужебный.ПроверитьВозможностьОтправкиИПолученияЭлектроннойПочты(ПараметрыEmailОбъекта.УчетнаяЗапись, ОписаниеОшибки, ДополнительноеСообщение);
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		КомментарийУчетнойЗаписи = НСтр("ru= 'Учетная запись электронной почты деактивирована автоматически триггерным событием при попытке авторизации перед отправкой сообщения. Проверьте настройки учетной записи.';en= 'The email account is deactivated automatically by a trigger event when attempting to log in before sending the message. Check your account settings.'");
		Справочники.УчетныеЗаписиЭлектроннойПочты.ОбновитьАктивностьУчетнойЗаписиЭлектроннойПочты(ПараметрыEmailОбъекта.УчетнаяЗапись, Ложь, Ложь, КомментарийУчетнойЗаписи);	
		Возврат;
	КонецЕсли;
	
	ИсходящееЭлектронноеПисьмо 					= Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
	ИсходящееЭлектронноеПисьмо.Дата           	= ПараметрыEmailОбъекта.Период;
	ЗаполнитьЗначенияСвойств(ИсходящееЭлектронноеПисьмо, ПараметрыEmailОбъекта);
	
	Для Каждого СтрокаКонтакт Из ПараметрыEmailОбъекта.ТаблицаКонтактов Цикл
		СтрокаТЧ = ИсходящееЭлектронноеПисьмо.ПолучателиПисьма.Добавить();
		СтрокаТЧ.Адрес = СтрокаКонтакт.Адрес;
		ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма = ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма + "," + СтрокаКонтакт.Получатель + " <" + СтрокаКонтакт.Адрес + "> ";
	КонецЦикла;
	
	ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма = Сред(ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма, 2, СтрДлина(ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма));
	
	ИсходящееЭлектронноеПисьмо.ДополнительныеСвойства.Вставить("ПараметрыРегистрацииТриггера", ПараметрыEmailОбъекта.ПараметрыРегистрацииТриггера);
	УровеньЖурналаРегистрацииКоллизии = Неопределено;
	
	Для Каждого Элемент из ИсходящееЭлектронноеПисьмо.ТриггерноеСобытие.Действия Цикл
		Если ИсходящееЭлектронноеПисьмо.Тема = Элемент.ШаблонСообщения.Наименование Тогда
			ИсходящееЭлектронноеПисьмо.ШаблонСообщения = Элемент.ШаблонСообщения;
		КонецЕсли;
	КонецЦикла;
	
	Результат = Документы.ЭлектронноеПисьмоИсходящее.ВыполнитьОтправкуПисьма(ИсходящееЭлектронноеПисьмо, ОписаниеОшибки, , , УровеньЖурналаРегистрацииКоллизии);
	
	Если Не Результат Тогда
		Отказ = Истина;
		ЗаписьЖурналаРегистрации(ПараметрыEmailОбъекта.ПараметрЖурналаРегистрации, ?(УровеньЖурналаРегистрацииКоллизии = Неопределено, УровеньЖурналаРегистрации.Ошибка, УровеньЖурналаРегистрацииКоллизии),
		ПараметрыEmailОбъекта.ДанныеТриггера.ТриггерноеСобытие.Метаданные(), ПараметрыEmailОбъекта.ДанныеОбъекта.ОбъектСобытия, ОписаниеОшибки);
	ИначеЕсли НЕ ИсходящееЭлектронноеПисьмо.Проведен Тогда 
		Попытка
			ИсходящееЭлектронноеПисьмо.ОбменДанными.Загрузка = Истина;
			ИсходящееЭлектронноеПисьмо.Записать(РежимЗаписиДокумента.Запись);
		Исключение
		КонецПопытки;	
	КонецЕсли; 		
	
КонецПроцедуры

// Процедура - Создать задачу
//
// Параметры:
//  ПараметрыОбъектаЗадача	 - 	 - 
//
Процедура СоздатьЗадачу(ПараметрыОбъектаЗадача)
	
	Если ПараметрыОбъектаЗадача.ПараметрыРегистрацииТриггера = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Задача_Объект = Задачи.Взаимодействие.СоздатьЗадачу();
	Задача_Объект.Заполнить(ПараметрыОбъектаЗадача);
	ЗаполнитьЗначенияСвойств(Задача_Объект, ПараметрыОбъектаЗадача);
	// Заполним параметры напоминания		
	Задачи.Взаимодействие.ЗаполнитьПараметрыНапоминания(Задача_Объект, ПараметрыОбъектаЗадача);			
	Задача_Объект.ДополнительныеСвойства.Вставить("ПараметрыРегистрацииТриггера", ПараметрыОбъектаЗадача.ПараметрыРегистрацииТриггера);			
	Задача_Объект.Записать();
	
КонецПроцедуры

// Процедура - Создать сделку
//
// Параметры:
//  ПараметрыОбъектаДействия - 	 - 
//
Процедура СоздатьСделку(ПараметрыОбъектаДействия)
	
	Если ПараметрыОбъектаДействия.ПараметрыРегистрацииТриггера = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Сделка_Объект = Справочники.Сделки.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(Сделка_Объект, ПараметрыОбъектаДействия);
	Сделка_Объект.Врач = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаДействия, "Врач", Сделка_Объект.Врач);
	Сделка_Объект.ДополнительныеСвойства.Вставить("ПараметрыРегистрацииТриггера", ПараметрыОбъектаДействия.ПараметрыРегистрацииТриггера);			
	Сделка_Объект.Записать();
	
КонецПроцедуры

// Процедура - Установить этап сделке
//
// Параметры:
//  ТекущаяСделка			 - 	 - 
//  ЭтапСделки				 - 	 - 
//  ПараметрыОбъектаДействия - 	 - 
//
Процедура УстановитьЭтапСделке(ТекущаяСделка, ЭтапСделки, ПараметрыОбъектаДействия)
	
	Если ПараметрыОбъектаДействия.ПараметрыРегистрацииТриггера = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Сделка_Объект 				= ТекущаяСделка.ПолучитьОбъект();
	Сделка_Объект.ЭтапСделки 	= ЭтапСделки;
	Если ПараметрыОбъектаДействия.Свойство("РезультатСделки") Тогда
		Сделка_Объект.РезультатСделки = ПараметрыОбъектаДействия.РезультатСделки;
		Сделка_Объект.ДатаЗавершенияСделки = ПараметрыОбъектаДействия.ДатаЗавершенияСделки;
		Если ПараметрыОбъектаДействия.РезультатСделки = Перечисления.РезультатыСделок.Успех Тогда 
			Сделка_Объект.Реализация 	= ПараметрыОбъектаДействия.Реализация;
			Сделка_Объект.СуммаСделки 	= ПараметрыОбъектаДействия.СуммаДокумента;
		ИначеЕсли ПараметрыОбъектаДействия.РезультатСделки = Перечисления.РезультатыСделок.Отказ Тогда 
			// Сделка_Объект.ПричинаОтказа = ПараметрыОбъектаДействия.ПричинаОтказа;
		КонецЕсли;	
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Сделка_Объект.ПланЛечения) Тогда 
		Сделка_Объект.ПланЛечения = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаДействия, "ПланЛечения", Сделка_Объект.ПланЛечения);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Сделка_Объект.Врач) Тогда 
		Сделка_Объект.Врач = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаДействия, "ПланЛечения", Сделка_Объект.ПланЛечения);
	КонецЕсли;	
	Если ЗначениеЗаполнено(ПараметрыОбъектаДействия.Описание) Тогда 
		Сделка_Объект.Описание = Сделка_Объект.Описание + ?(ЗначениеЗаполнено(СокрЛП(Сделка_Объект.Описание)), Символы.ПС, "") + ПараметрыОбъектаДействия.Описание;
	КонецЕсли;	
	Сделка_Объект.ДополнительныеСвойства.Вставить("ПараметрыРегистрацииТриггера", ПараметрыОбъектаДействия.ПараметрыРегистрацииТриггера);			
	Сделка_Объект.Записать();
	
КонецПроцедуры

// Процедура - Установить параметры сообщений для триггерных действий
//
// Параметры:
//  Запрос	 - 	 - 
//
Процедура УстановитьПараметрыСообщенийДляТриггерныхДействий(Запрос)
	
	Запрос.УстановитьПараметр("ПользовательПометилНаУдалениеТриггер"					, НСтр("ru='Пользователь пометил на удаление триггер.';en='The user marked the trigger for deletion.'"));
	Запрос.УстановитьПараметр("ПользовательДеактивировалТриггер"						, НСтр("ru='Пользователь деактивировал триггер.';en='The user activated the trigger.'"));	
	Запрос.УстановитьПараметр("ПользовательДеактивировалДействие"						, НСтр("ru='Пользователь деактивировал действие.';en='The user deactivated the action.'"));
	Запрос.УстановитьПараметр("ПользовательНеУказалВидДействия"							, НСтр("ru='Пользователь не указал вид действия.';en='The user did not specify the type of action.'"));
	Запрос.УстановитьПараметр("ПользовательУдалилДействие"								, НСтр("ru='Пользователь удалил действие.';en='The user deleted the action.'"));
	Запрос.УстановитьПараметр("ПользовательДобавилДействиеВПланПослеМоментаПланирования", НСтр("ru='Пользователь добавил действие в план после события.';en='The user added an action to the plan after the event.'"));	
	Запрос.УстановитьПараметр("КлиентУдаленИзСоставаЗанятия"							, НСтр("ru='Клиент удален из состава занятия.';en='The client was removed from the class.'"));
	Запрос.УстановитьПараметр("ПосещениеОтменено"										, НСтр("ru='Посещение отменено.';en='Visit canceled.'"));
	Запрос.УстановитьПараметр("ЗанятиеОтменено"											, НСтр("ru='Занятие отменено.';en='Class canceled.'"));
	Запрос.УстановитьПараметр("КлиентОтменилВизит"										, НСтр("ru='Клиент отменил визит.';en='The client canceled the session.'"));
	Запрос.УстановитьПараметр("ЗанятиеВновьАктуально"									, НСтр("ru='Занятие вновь актуально.';en='The lesson is relevant again.'"));
	Запрос.УстановитьПараметр("НеАктуально"												, НСтр("ru='Не актуально.';en='No longer relevant.'"));
	
КонецПроцедуры

// Функция - Получить актуальную задачу прошлого СРМ
//
// Параметры:
//  ПараметрыОбъектаЗадача	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАктуальнуюЗадачуПрошлогоСРМ(ПараметрыОбъектаЗадача)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Взаимодействие.Ссылка КАК Ссылка
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |ГДЕ
	               |	Взаимодействие.ТриггерноеСобытие = &ТриггерноеСобытие
	               |	И Взаимодействие.Контрагент = &Контрагент
	               |	И Взаимодействие.ЗадачаПредмет = &ЗадачаПредмет
	               |	И Взаимодействие.КодСинхронизации <> &КодСинхронизации";
	
	Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ПараметрыОбъектаЗадача.ДанныеТриггера.ТриггерноеСобытие);
	Запрос.УстановитьПараметр("Контрагент"			, ПараметрыОбъектаЗадача.Контрагент);
	Запрос.УстановитьПараметр("ЗадачаПредмет"		, ПараметрыОбъектаЗадача.ЗадачаПредмет);
	Запрос.УстановитьПараметр("КодСинхронизации"	, "");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

// Функция - Инициализировать содержание с параметрами
//
// Параметры:
//  Содержание		 - 	 - 
//  ДанныеТриггера	 - 	 - 
//  ДанныеОбъекта	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСодержаниеСПараметрами(ЗНАЧ Содержание, ДанныеДействия, ДанныеОбъекта)
	
	Если ДанныеДействия.ТаблицаЗадействованныхПараметров = Неопределено ИЛИ ДанныеДействия.ТаблицаЗначенийПараметров = Неопределено Тогда 
		Возврат Содержание;
	КонецЕсли;
	
	МассивСтрокЗначений = ДанныеДействия.ТаблицаЗначенийПараметров.НайтиСтроки(Новый Структура("Контрагент, ОбъектСобытия", ДанныеОбъекта.Контрагент, ДанныеОбъекта.ОбъектСобытия));
	
	Если МассивСтрокЗначений.Количество() = 0 Тогда 
		Возврат Содержание;
	КонецЕсли;	
		         
	Для Каждого СтрокаЗадействованныйПараметр ИЗ ДанныеДействия.ТаблицаЗадействованныхПараметров Цикл
		Если СтрокаЗадействованныйПараметр.ИзОсновнойТаблицы И СтрокаЗадействованныйПараметр.ИнициализированВИсходнойТаблице = Ложь Тогда 
			ЗначениеПарметра = МассивСтрокЗначений[0][СтрСоединить(СтрРазделить(СтрокаЗадействованныйПараметр.НаименованиеПараметра, " {}")) + СтрокаЗадействованныйПараметр.ОсновнаяТаблицаОбъекта];
		ИначеЕсли ДанныеДействия.ТаблицаЗначенийПараметров.Колонки.Найти(СтрокаЗадействованныйПараметр.РеквизитПараметра) <> Неопределено Тогда 	
			ЗначениеПарметра = МассивСтрокЗначений[0][СтрокаЗадействованныйПараметр.РеквизитПараметра];
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{Email}" Тогда 
			ЗначениеПарметра = Справочники.Контрагенты.ПолучитьEmailКонтрагента(ДанныеОбъекта.Контрагент);
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{ПолныйАдресКлиники}" Тогда 
			ЗначениеПарметра = Справочники.СтруктурныеЕдиницы.ПолучитьАдресСтруктурнойЕдиницы(ДанныеОбъекта.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{КороткийАдресКлиники}" Тогда 
			ЗначениеПарметра = Справочники.СтруктурныеЕдиницы.ПолучитьАдресСтруктурнойЕдиницы(ДанныеОбъекта.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.КороткийАдресСтруктурнойЕдиницы);			
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{ЯндексКарты}" Тогда 
			ЗначениеПарметра = Справочники.СтруктурныеЕдиницы.ПолучитьЯндексКартыСтруктурнойЕдиницы(ДанныеОбъекта.СтруктурнаяЕдиница);	
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{ЯндексОтзывы}" Тогда 
			ЗначениеПарметра = Справочники.СтруктурныеЕдиницы.ПолучитьЯндексОтзывыСтруктурнойЕдиницы(ДанныеОбъекта.СтруктурнаяЕдиница);	
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{СайтКлиники}" Тогда 
			ЗначениеПарметра = Справочники.СтруктурныеЕдиницы.ПолучитьСайтСтруктурнойЕдиницы(ДанныеОбъекта.СтруктурнаяЕдиница);	
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{ОценкаПриема}" И ДанныеДействия.ТаблицаЗначенийПараметров.Колонки.Найти("Прием") <> Неопределено Тогда 
			ЗначениеПараметра = РегистрыСведений.ОценкиПриемов.ПолучитьОценкуПриема(ДанныеОбъекта.Прием);
			// Если ЗначениеЗаполнено(ЗначениеПараметра) ИЛИ ТипЗнч(ЗначениеПараметра) = Тип("Число") Тогда 
			//	ЗначениеПараметра = ПолучитьСклоненияСтрокиПоЧислу("балл", ЗначениеПараметра, , "ЧС=Количественное", "ПД=Родительный");
			// КонецЕсли;				
		Иначе 
			ЗначениеПарметра = Null;
		КонецЕсли;
		Если ЗначениеПарметра = Null Тогда 
			ЗначениеПарметра = "";
		ИначеЕсли НЕ ЗначениеЗаполнено(ЗначениеПарметра) И НЕ ТипЗнч(ЗначениеПарметра) = Тип("Число") И НЕ ТипЗнч(ЗначениеПарметра) = Тип("Дата") Тогда 
			ЗначениеПарметра = "";
		ИначеЕсли СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{ОценкаПриема}" И (ЗначениеЗаполнено(ЗначениеПараметра) ИЛИ ТипЗнч(ЗначениеПараметра) = Тип("Число")) Тогда 
			ЗначениеПараметра = ПолучитьСклоненияСтрокиПоЧислу("балл", ЗначениеПараметра, , "ЧС=Количественное", "ПД=Именительный")[0];			
		КонецЕсли;
		// Распарсим идентификатор
		Если ЗначениеЗаполнено(ЗначениеПарметра) И СтрокаЗадействованныйПараметр.НаименованиеПараметра = "{ИдентификаторКонференции}" Тогда
			ЗначениеПарметра = ПолучитьИдентификаторКонференцииПоСсылке(ЗначениеПарметра);
		КонецЕсли;	
		Содержание = СтрЗаменить(Содержание, СтрокаЗадействованныйПараметр.НаименованиеПараметра, СокрЛП(?(ЗначениеЗаполнено(СтрокаЗадействованныйПараметр.ФорматПараметра), Формат(ЗначениеПарметра, СтрокаЗадействованныйПараметр.ФорматПараметра), Строка(ЗначениеПарметра))));
	КонецЦикла;	
	
	Возврат СокрЛП(Содержание);
	
КонецФункции

// Функция - Преобразовать в структуру
