		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь И РезультатЗапроса.Свойство("errorMessage"), РезультатЗапроса.errorMessage, ТелоОтвета);
		РезультатОперации.ТелоЗапроса			= ТелоОтвета;		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

