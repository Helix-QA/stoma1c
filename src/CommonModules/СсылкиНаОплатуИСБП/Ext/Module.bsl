// Функция - Альфа банк зарегистрировать QR
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция АльфаБанк_ЗарегистрироватьQR(СтруктураПараметров)
	
	СуммаОплаты = СтруктураПараметров.СуммаОплаты;	
	ПараметрыПШ	= СтруктураПараметров.ПараметрыПШ;
	
	РезультатЗапроса = АльфаБанк_РегистрацияЗаказа(ПараметрыПШ, СуммаОплаты);
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		ИдСБП		= РезультатЗапроса.ПараметрыРезультата.orderId; 
		НомерЗаказа = РезультатЗапроса.ПараметрыРезультата.orderNumber;
	
		ПараметрыЗапроса = Новый Структура();
		ПараметрыЗапроса.Вставить("userName"	, ПараметрыПШ.ЛогинБанка);
		ПараметрыЗапроса.Вставить("password"	, КодироватьСтроку(ПараметрыПШ.ПарольБанка, СпособКодированияСтроки.КодировкаURL));
		ПараметрыЗапроса.Вставить("mdOrder"		, ИдСБП);
		
		ТекстЗапроса = "";
		РезультатЗапроса = АльфаБанк_ПолучитьQRЗапрос(ПараметрыЗапроса, ПараметрыПШ, ТекстЗапроса);
		
		Если РезультатЗапроса.ВыполненоУспешно Тогда
			
			Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл	
				
				КороткаяСсылка 	= РезультатЗапроса.ПараметрыРезультата.payload; //ОбщегоНазначения.ПолучитьКороткуюСсылку(РезультатЗапроса.ПараметрыРезультата.payload);
				
				РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
				СтрокаТ.ДокументЗадолженности,
				СтрокаТ.Задолженность,
				ИдСБП,
				КороткаяСсылка,
				Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено,
				СтруктураПараметров.ЭквайринговыйТерминал,
				НомерЗаказа,ТекстЗапроса,,
				СтруктураПараметров.Контрагент,,
				СтруктураПараметров.СтруктурнаяЕдиница,
				ТекущаяДатаСеанса(),,
				Перечисления.ТипыСсылокНаОплату.СБПАльфаБанк,
				ПараметрыСеанса.ТекущийПользователь,
				ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600,
				РезультатЗапроса.ПараметрыРезультата.qrId
				);
								
			КонецЦикла;
			
			РезультатЗапроса.Вставить("СсылкаНаОплату"		, КороткаяСсылка);
			РезультатЗапроса.Вставить("ВремяДействителенДо"	, ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600);
			РезультатЗапроса.Вставить("НомерЗаказа"			, НомерЗаказа);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - Альфа банк регистрация заказа
//
// Параметры:
//  ПараметрыПШ	 - 	 - 
//  СуммаОплаты	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция АльфаБанк_РегистрацияЗаказа(ПараметрыПШ, СуммаОплаты)
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
		
	НомерЗаказа = СформироватьНомерЗаказаСБП();
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("userName"		, ПараметрыПШ.ЛогинБанка);
	ПараметрыЗапроса.Вставить("password"		, КодироватьСтроку(ПараметрыПШ.ПарольБанка, СпособКодированияСтроки.КодировкаURL));
	ПараметрыЗапроса.Вставить("orderNumber"		, НомерЗаказа);
	ПараметрыЗапроса.Вставить("amount"			, Формат(СуммаОплаты*100, "ЧГ=100"));
	ПараметрыЗапроса.Вставить("returnUrl"		, "https://qr.nspk.ru/");
	ПараметрыЗапроса.Вставить("expirationDate"	, ЗаписатьДатуJSON(ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600, ФорматДатыJSON.ISO));

	ПараметрыЗапросаСтрокой = "";
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		ПараметрыЗапросаСтрокой = ПараметрыЗапросаСтрокой + ?(Не ЗначениеЗаполнено(ПараметрыЗапросаСтрокой), "?", "&") + ПараметрЗапроса.Ключ + "=" + ПараметрЗапроса.Значение;			
	КонецЦикла;
	
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "web.rbsuat.com/ab/rest", ?(СтрНачинаетсяС(ПараметрыПШ.ЛогинБанка, "r-"), "payment.alfabank.ru/payment/rest/", "pay.alfabank.ru/payment/rest"));
	Соединение = Новый HTTPСоединение(АдресСервера,,,,,5, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос = Новый HTTPЗапрос("/register.do" + ПараметрыЗапросаСтрокой, ЗаголовкиHTTP);					
	
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Свойство("orderId") И РезультатЗапроса.Свойство("formUrl");   
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь И РезультатЗапроса.Свойство("errorMessage"), РезультатЗапроса.errorMessage, ТелоОтвета);
		
		Если РезультатОперации.ВыполненоУспешно = Истина Тогда
			РезультатОперации.ПараметрыРезультата.Вставить("orderNumber", НомерЗаказа);	
		КонецЕсли;
		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

