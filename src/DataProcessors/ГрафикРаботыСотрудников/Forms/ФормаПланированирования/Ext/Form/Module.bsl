Функция ВернутьВремяРаботыСтруктурнойЕдиницыПоДате (Дата, СтруктурнаяЕдиница)
	
	Результат = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(Дата, СтруктурнаяЕдиница,,Истина); 
	
	Если Результат <> Неопределено Тогда
		СтруктураРезультат = Новый Структура;
		СтруктураРезультат.Вставить("НачалоРаботы"   ,Результат.НачалоРаботы);
		СтруктураРезультат.Вставить("ОкончаниеРаботы",Результат.ОкончаниеРаботы);
		//СтруктураРезультат.Вставить("РабочийДень"    , РегистрыСведений.КалендарныеГрафики.ЭтоРабочийДень(Дата));
		Возврат СтруктураРезультат; 
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
