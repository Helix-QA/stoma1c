// Функция - Уже сформирован возврат по основанию
//
// Параметры:
//  ВозвратОтПокупателя	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция УжеСформированВозвратПоОснованию(ВозвратОтПокупателя, ЭквайринговыйТерминал = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Основание = &ВозвратОтПокупателя
	|	И &УсловиеЭквайринговыйТерминал
	|	И СтатусыОплатыЗаказов.ЭтоВозврат
	|	И СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.ОжидаетВозврата)");
	
	УсловиеЭквайринговыйТерминал = ?(ЗначениеЗаполнено(ЭквайринговыйТерминал), "И СтатусыОплатыЗаказов.ЭквайринговыйТерминал = &ЭквайринговыйТерминал", ""); 
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеЭквайринговыйТерминал", УсловиеЭквайринговыйТерминал); 
	
	Запрос.УстановитьПараметр("ВозвратОтПокупателя"	 , ВозвратОтПокупателя);
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	
	Возврат Не Запрос.Выполнить().Пустой();
		
КонецФункции

