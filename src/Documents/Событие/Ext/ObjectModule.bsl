// Процедура, обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка
		ИЛИ (ЭтотОбъект.ДополнительныеСвойства.Свойство("ОбменДаннымиЗагрузка")
		И ЭтотОбъект.ДополнительныеСвойства.ОбменДаннымиЗагрузка = Истина) Тогда
		
		Возврат;
	КонецЕсли;
	
	// Устанавливаем ссылку нового.
	Если Ссылка.Пустая() И ПолучитьСсылкуНового() = Документы.Событие.ПустаяСсылка() Тогда
		СсылкаНового = Документы.Событие.ПолучитьСсылку(Новый УникальныйИдентификатор);
		УстановитьСсылкуНового(СсылкаНового);
		УИД = СсылкаНового.УникальныйИдентификатор();
	ИначеЕсли НЕ ЗначениеЗаполнено(УИД) Тогда
		УИД = Ссылка.УникальныйИдентификатор();	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ДатаСоздания) Тогда
		ЭтотОбъект.ДатаСоздания = ТекущаяДатаСеанса();		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Статус) Тогда
		Статус = Перечисления.СтатусыСобытия.Подтверждена;
	КонецЕсли;
	
	// Если Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда
	//	ТелефонныйЗвонок = Истина;
	// КонецЕсли;
		
	ИнициализироватьДополнительныеСвойстваОбъекта();
	
	СформироватьМассивСотрудниковДляФормированияИнтервалов();
	
	// Актуализировать комментарий (предназначено при программной генерации текущего объекта)
	ИнициализироватьКомментарий();
	
	// Устанавливаем ссылку новой сделки
	ПоместитьСсылкуНовойСделки();
	
	ЗаполнитьВременныеРамкиСобытия();
	
	Если НЕ Ссылка.Пустая() И ЭтотОбъект.Ссылка.Врач <> ЭтотОбъект.Врач И ЗначениеЗаполнено(Ссылка.Врач) Тогда
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ИзмененВрачПриема", Истина);
		Календарь = Справочники.КалендариСотрудников.ПолучитьКалендарьСотрудника(Ссылка.Врач);
		Если ЗначениеЗаполнено(Календарь) Тогда
			ЭтотОбъект.ДополнительныеСвойства.Вставить("ПредыдущийКалендарь", Календарь);
        КонецЕсли;
	КонецЕсли;
	
	// Установить статусы пациента. 
	Если Не ЗначениеЗаполнено(СтатусПациента) И РежимЗаписи = РежимЗаписиДокумента.Проведение  Тогда
		УстановитьПризнакСтатусаПациента();
	КонецЕсли;
	
	Если НачалоДня(ЭтотОбъект.Дата) >= НачалоДня(ТекущаяДатаСеанса()) Тогда 		
		ПодготовитьПроверитьДанныеДляОтправкиPushУведомлений();
	КонецЕсли;
	
	РегистрыСведений.ИсторияПереносовСобытий.ЗафиксироватьИзмененияСобытияВИстории(ЭтотОбъект);
	
КонецПроцедуры

// Процедура, обработчик события "ПриЗаписи".
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка
		ИЛИ (ЭтотОбъект.ДополнительныеСвойства.Свойство("ОбменДаннымиЗагрузка")
		И ЭтотОбъект.ДополнительныеСвойства.ОбменДаннымиЗагрузка = Истина) Тогда
		
		Возврат;
	КонецЕсли;
	
	Если НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "РаботаСЧатБотом", Ложь) Тогда 
		Документы.Событие.УстановитьЗаданияВыполненным(Ссылка);
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
					
	СформироватьИнтервалыПоСотрудникам();  
	
	//Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ДобавитьТелефонСуществующемуПациенту") Тогда
	//	Попытка
	//		КонтрагентОбъект = Контрагент.ПолучитьОбъект();
	//		Справочники.Контрагенты.ДобавитьНомерТелефонаВКонтактнуюИнформациюКлиента(КонтрагентОбъект, ЭтотОбъект.ДополнительныеСвойства.ДобавитьТелефонСуществующемуПациенту); 	
	//		КонтрагентОбъект.Записать();  

	//	Исключение
	//		
	//	КонецПопытки;
	//КонецЕсли;
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ПредыдущийКалендарь") Тогда 
		ИзменитьЗаписиДанныеЗаписейКалендаряGoogle(ЭтотОбъект.ДополнительныеСвойства.ПредыдущийКалендарь);	
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Врач) Тогда
		Календарь = Справочники.КалендариСотрудников.ПолучитьКалендарьСотрудника(ЭтотОбъект.Врач);
		Если ЗначениеЗаполнено(Календарь) Тогда
			ОбменСGoogle.ПриЗаписиИсточникаЗаписиКалендаря(ЭтотОбъект);
		КонецЕсли;
	КонецЕсли;
	
	АктуализироватьДанныеПланированияПриема();
	СоздатьНовуюВоронку();
	СменитьЭтапПредопределеннойВоронки();
	АктуализироватьВрачаСделки();
	РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьСведенияДляСписка(Контрагент);
	РегистрыСведений.СделкиСведенияДляСписка.АктуализироватьСведенияДляСписка(Сделка, Контрагент);	
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ТаблицаМетокДляЗаписи") 
		И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.ТаблицаМетокДляЗаписи) Тогда
		
		РегистрыСведений.МеткиКлиентов.ЗаписатьИзмененияМеток(ЭтотОбъект, ЭтотОбъект.ДополнительныеСвойства.ТаблицаМетокДляЗаписи);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) И ЗначениеЗаполнено(ЭтотОбъект.Врач) И ЗначениеЗаполнено(ЭтотОбъект.СтруктурнаяЕдиница) Тогда
		РегистрыСведений.ИнтервалыЛистаОжидания.УдалитьПациентаИзЛистаОжидания(ЭтотОбъект.СтруктурнаяЕдиница, ЭтотОбъект.Врач, ЭтотОбъект.Контрагент);	
	КонецЕсли;
	
	Если НачалоДня(ЭтотОбъект.Дата) >= НачалоДня(ТекущаяДатаСеанса()) Тогда
		ОбработатьОтправкуPushУведомлений();		
	КонецЕсли;
	
	ДобавитьСообщениеВСистемуВзаимодействия();
		
КонецПроцедуры

// Процедура - Изменить записи данные записей календаря google
//
Процедура ИзменитьЗаписиДанныеЗаписейКалендаряGoogle(ПредыдущийКалендарь)
	
	Запись = РегистрыСведений.ДанныеЗаписейКалендаряGoogle.СоздатьМенеджерЗаписи();
	Запись.Источник = ЭтотОбъект.Ссылка;
	Запись.Прочитать();
		
	Запись.ПредыдущийКалендарь = ПредыдущийКалендарь;
	Запись.Записать();                      
	
КонецПроцедуры

