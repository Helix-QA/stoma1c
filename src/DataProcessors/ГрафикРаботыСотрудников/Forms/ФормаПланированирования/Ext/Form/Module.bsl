&НаКлиенте
// Процедура - Декорация управления сохранением шаблонов нажатие
// 
// 
Процедура ДекорацияУправленияСохранениемШаблоновНажатие(Элемент)
	
	Если НЕ ФормированиеИнтерваловЗавершено() Тогда 
		Возврат;
	КонецЕсли;   
	
	Для каждого ИнтервалСписка из ОтборИнтервалыРаботы Цикл	
		СтруктураСравнения = СправочникСменСодержитИнтервал(ОтборСтруктурнаяЕдиница,ИнтервалСписка.Значение);
		
		Если СтруктураСравнения.ФлагНаличияСмены = Истина Тогда 
			ПометитьСнятьПометкуСменуСправочник (СтруктураСравнения.НайденнаяСмена);
		Иначе    			
			ДобавитьСменуВСправочник (ОтборСтруктурнаяЕдиница, ИнтервалСписка.Значение);  			
		КонецЕсли;
		
		ОбновитьДекорациюУпраленияСохранениемСмен(ОтборСтруктурнаяЕдиница, ИнтервалСписка.Значение);    		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Добавить смену в справочник смен
// 
// 
Процедура ДобавитьСменуВСправочник (СтруктурнаяЕдиница, ИнтервалСписка)
	
	ПериодРаботыНовый = Справочники.ПериодыРаботы.СоздатьЭлемент();
	
	ПериодРаботыНовый.СтруктурнаяЕдиница	= СтруктурнаяЕдиница;   
	ПериодРаботыНовый.НачалоСмены			= ИнтервалСписка.НачалоРаботы;
	ПериодРаботыНовый.ОкончаниеСмены		= ИнтервалСписка.ОкончаниеРаботы;
	ПериодРаботыНовый.Наименование			= Формат(ПериодРаботыНовый.НачалоСмены,"ДФ=ЧЧ:мм; ДП=00:00") + " - " + Формат(ПериодРаботыНовый.ОкончаниеСмены,"ДФ=ЧЧ:мм; ДП=23:59");
	
	ПериодРаботыНовый.Записать();
	
КонецПроцедуры

&НаСервере
// Процедура - Пометить/снять пометку удаления со смены
// 
// 
Процедура ПометитьСнятьПометкуСменуСправочник (ПериодРаботы)

	ПериодРаботыОбъект =  ПериодРаботы.получитьОбъект();
	ПериодРаботыОбъект.ПометкаУдаления = НЕ ПериодРаботыОбъект.ПометкаУдаления;
	ПериодРаботыОбъект.Записать();
	
Конецпроцедуры

&НаКлиенте
// Процедура - Обновить декорацию упраления сохранением смен
// 
// 
Процедура ОбновитьДекорациюУпраленияСохранениемСмен(СтруктурнаяЕдиница, ИнтервалСписка)
	
	Структура = СправочникСменСодержитИнтервал(СтруктурнаяЕдиница, ИнтервалСписка);	
	
	Если Структура.ФлагНаличияСмены и Структура.ПометкаУдаления Тогда
		Элементы.ДекорацияУправленияСохранениемШаблонов.Картинка = БиблиотекаКартинок.РейтингЗвездаЗаполненная;
		Элементы.ДекорацияУправленияСохранениемШаблонов.Подсказка = "Пометить на удаление смену в справочнике смен";
	Иначе 
		Элементы.ДекорацияУправленияСохранениемШаблонов.Картинка = БиблиотекаКартинок.РейтингЗвездаПустая;
		Элементы.ДекорацияУправленияСохранениемШаблонов.Подсказка = "Добавить смену в справочник смен";		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Список шаблонов содержит структуру интервалов
// 
// Возвращаемое значение:
//   - 
// 
Функция СправочникСменСодержитИнтервал(СтруктурнаяЕдиница, ИнтервалСписка)
	
	ФлагНаличияСмены		= Ложь;
	НайденнаяСмена			= Неопределено;
	ПометкаУдаления	        = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПериодыРаботы.Ссылка КАК ПериодРаботы,
	|	ПериодыРаботы.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	Справочник.ПериодыРаботы КАК ПериодыРаботы
	|ГДЕ
	|	ПериодыРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ПериодыРаботы.НачалоСмены = &НачалоСмены
	|	И ПериодыРаботы.ОкончаниеСмены = &ОкончаниеСмены";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("НачалоСмены"		 		, ИнтервалСписка.НачалоРаботы);
	Запрос.УстановитьПараметр("ОкончаниеСмены"			, ИнтервалСписка.ОкончаниеРаботы);
	
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда
		ФлагНаличияСмены = Истина;   				
		НайденнаяСмена	= Результат[0].ПериодРаботы;
		ПометкаУдаления = Результат[0].ПометкаУдаления;
	КонецЕсли;
	   	
	Возврат Новый Структура("ФлагНаличияСмены, НайденнаяСмена, ПометкаУдаления", ФлагНаличияСмены, НайденнаяСмена, ПометкаУдаления);
	
КонецФункции

