&НаКлиенте
// При активации ячейки таблицы
//
Процедура ХозОперацииПриАктивизацииЯчейки(Элемент)	
	Если Элементы.Операции.ТекущийЭлемент = Элементы.ДвиженияКоличество Тогда
		ТекущиеДанные                       = Элементы.Операции.ТекущиеДанные;
		ТекущиеДанные.БлокироватьКоличество = ТекущиеДанные.СчетДт <> ПредопределенноеЗначение("ПланСчетов.Управленческий.Запасы")
		                                    И ТекущиеДанные.СчетКт <> ПредопределенноеЗначение("ПланСчетов.Управленческий.Запасы");	
	КонецЕсли;	
КонецПроцедуры


&НаСервереБезКонтекста
// Получить ограничение типа для Субконто
//
Функция  ПолучитьОграничениеПоТипу(СчетДт,НомерСубконто)
	Если СчетДт = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;	
	Если СчетДт.ВидыСубконто.Количество() > НомерСубконто Тогда
		МассивТипов        = СчетДт.ВидыСубконто[НомерСубконто].ВидСубконто.ТипЗначения.Типы();
	    ОграничениеТипа    = Новый ОписаниеТипов(МассивТипов);
		Возврат ОграничениеТипа;
    КонецЕсли;	
	Возврат Неопределено;	
КонецФункции

&НаКлиенте
Процедура СкрытьПоказатьДополнительно(Команда)
	
	Элементы.ГруппаДополнительно.Видимость = НЕ Элементы.ГруппаДополнительно.Видимость;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ОперацииПриИзменении(Элемент)
	
	ОперацииПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОперацииПриИзмененииНаСервере()
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);

КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("Операции"		, "ГруппаОперации");
	СтруктураМеню.Вставить("Дополнительно"	, "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия кнопки переключателя закладок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры	

#КонецОбласти
