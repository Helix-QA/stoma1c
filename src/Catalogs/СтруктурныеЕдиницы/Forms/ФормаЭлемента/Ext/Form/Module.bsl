
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если  ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();

	Если Объект.РасписаниеРаботы.Количество() = 0 Тогда	
		Для а = 1 по 7 Цикл
			НоваяСтрока = Объект.РасписаниеРаботы.Добавить();
			НоваяСтрока.ДеньНедели = Дата("2001010"+Строка(а));			
		КонецЦикла;
	КонецЕсли;
		
	// Контактная информация
	// КонтактнаяИнформацияСервер.ПриСозданииПриЧтенииНаСервере(ЭтаФорма, Объект);
	
	УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервере(ЭтотОбъект);
	
	Если НЕ РольДоступна("АдминистраторСистемы")
		И НЕ РольДоступна("Администрирование")
		И НЕ РольДоступна("ПолныеПрава") Тогда 
		
		Элементы.ТаблицаРасписаниеКнопкаЗаполнить.Доступность = Ложь;
	КонецЕсли;
	СоздатьМенюПереключения();
	
	РедактированиеКартинок            = ПравоДоступа("Редактирование", Метаданные.Справочники.СтруктурныеЕдиницы);
	Элементы.ПолеКартинки_7.Доступность = РедактированиеКартинок;
	Элементы.ДобавитьЛого.Доступность = РедактированиеКартинок; 
	
	Если Строка(Константы.СтранаУчета.Получить()) = "РОССИЯ" Тогда
		Элементы.ИспользоватьЯндексКарты.Видимость = Истина;
	КонецЕсли;
	Если Объект.ИспользоватьЯндексКарты Тогда
		Наименование = Ложь;
		ПолучитьНастройкиЯндексКарты(Наименование);
		ЭтотОбъект.УидСессии = ЛичныйКабинет.УидТекущейСессии();
	Иначе
		Элементы.ГруппаЯндексИдентификаторРубрики.Видимость  = Ложь;
	КонецЕсли;           	
	
	ЭтоЗаписьВЦРМ = Ложь;

	ОтобразитьКартинки();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
    // Обработчик механизма "Свойства".
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Объект, "СтраницаДополнительныеРеквизиты");	

КонецПроцедуры

&НаСервере
// Процедура обработчик события "ПередЗаписьюНаСервере"
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	//// Обработчик подсистемы "Контактная информация"
	// УправлениеКонтактнойИнформацией.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект, Отказ);
	//
	
	// КонтактнаяИнформация
	// КонтактнаяИнформацияСервер.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	// Конец КонтактнаяИнформация

	УправлениеКонтактнойИнформациейСтоматология.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	
	Если (Объект.ИспользоватьЯндексКарты Или Объект.Ссылка.ИспользоватьЯндексКарты <> Объект.ИспользоватьЯндексКарты) И ЭтаФорма.Модифицированность = Истина Тогда
		
		ЯндексУникальныйНеизменныйИдентификатор 	= СтрЗаменить(Строка(ЭтотОбъект.ЯндексНаименованиеОрганизации.УникальныйИдентификатор()), "-", "");
		
		ЯндексЧасыРаботы							= Справочники.СтруктурныеЕдиницы.ПолучитьПредставленияГрафикаРаботы(объект);
		ЯндексСтруктурнаяЕдиница					= Объект.Наименование;
		ЯндексДатаАктуализации 						= Строка(Формат(ТекущаяДатаСеанса(), "ДЛФ=D"));
		
		МассивТелефонов 							= ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
		МассивЭлПочты 								= ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)); 
		МассивАдресов 								= ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Адрес));
		МассивСоциальныхСетей                       = ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.СоциальнаяСеть));
		МассивСайтов                                = ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.ВебСтраница));
	
		
		ПроверкаНаОбязательныеПоля = Ложь;
		Если Объект.ИспользоватьЯндексКарты Тогда
			Если Не ЗначениеЗаполнено(ЯндексЧасыРаботы) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("На вкладке Основное не заполнено - Время работы");
				ПроверкаНаОбязательныеПоля = Истина;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивТелефонов)
				И ЗначениеЗаполнено(МассивТелефонов[0].Значение) 
				И ЗначениеЗаполнено(МассивАдресов)
				И ЗначениеЗаполнено(МассивАдресов[0].Значение) 
				И ЗначениеЗаполнено(МассивСайтов)
				И ЗначениеЗаполнено(МассивСайтов[0].Значение) Тогда
				
				МассивАдресовФакт						= ДекодироватьИзJSON(МассивАдресов[0].Значение);
				ЯндексАдрес 							= МассивАдресовФакт.value;
				Если МассивАдресовФакт.Свойство("comment") Тогда
					ЯндексДополнительнаяИнформацияКАдресу 	= МассивАдресовФакт.comment;
				Иначе
					ЯндексДополнительнаяИнформацияКАдресу = "";
				КонецЕсли;
				Если МассивАдресовФакт.Свойство("city") Тогда
					ЯндексГород = МассивАдресовФакт.city;
				Иначе
					ЯндексГород = МассивАдресовФакт.area;	
				КонецЕсли;
				
				ЭтотОбъект.ЯндексНомерТелефона.Очистить();
				Для Каждого Элемент из МассивТелефонов Цикл
					Если ЗначениеЗаполнено(Элемент.Значение) Тогда
						МассивТелефоновЭл		= ДекодироватьИзJSON(Элемент.Значение);
						Стр = ЯндексНомерТелефона.Добавить();
						Стр.НомерТелефона 		= СтрРазделить(МассивТелефоновЭл.value, ",")[0];
						Если МассивТелефоновЭл.Свойство("comment") Тогда
							Стр.ЧейНомер		 	= МассивТелефоновЭл.comment;
						КонецЕсли;
						Если МассивТелефоновЭл.Свойство("extNumber") Тогда
							Стр.ДобавочныйНомер 	= МассивТелефоновЭл.extNumber;
						КонецЕсли;	
					КонецЕсли;
				КонецЦикла;
				ЯндексНомераТелефонов = ДанныеФормыВЗначение(ЯндексНомерТелефона, Тип("ТаблицаЗначений"));
				
				МассивСайтов 						= ДекодироватьИзJSON(МассивСайтов[0].Значение);
				ЯндексСайт 							= МассивСайтов.value;
				
				ЯндексКоординатыПоДолготе           = Объект.Долгота;
				ЯндексКоординатыПоШироте            = Объект.Широта;
				
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните обязательные поля - Телефон, фактический адрес и сайт");
				ПроверкаНаОбязательныеПоля = Истина;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивАдресов) 
				И ЗначениеЗаполнено(МассивАдресов[1].Значение) Тогда
				
				МассивКороткихАдресов			= ДекодироватьИзJSON(МассивАдресов[1].Значение);
				ЯндексКороткийАдрес 			= МассивКороткихАдресов.value;
				
			Иначе
				ЯндексКороткийАдрес = "";
			КонецЕсли;
			
			ЭтотОбъект.ЯндексЭлектроннаяПочта.Очистить();
			Если ЗначениеЗаполнено(МассивЭлПочты) Тогда
				Для Каждого Элемент из МассивЭлПочты Цикл
					Если ЗначениеЗаполнено(Элемент.Значение) Тогда 
						МассивЭлПочтыЭЛ			= ДекодироватьИзJSON(Элемент.Значение);
						ЯндексЭлектроннаяПочта.Добавить(МассивЭлПочтыЭЛ.value);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			ЭтотОбъект.ЯндексСоциальныеСети.Очистить();
			Если ЗначениеЗаполнено(МассивСоциальныхСетей) Тогда
				Для Каждого Элемент из МассивСоциальныхСетей Цикл
					Если ЗначениеЗаполнено(Элемент.Значение) Тогда
						МассивСоциальныхСетейЭЛ	 = ДекодироватьИзJSON(Элемент.Значение);
						Если Лев(МассивСоциальныхСетейЭЛ.value, 7) = "http://" Или Лев(МассивСоциальныхСетейЭЛ.value, 8) = "https://" Тогда 
							ЯндексСоциальныеСети.Добавить(МассивСоциальныхСетейЭЛ.value);
						Иначе		 
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ссылка в соц. сетях. Указывается в нижнем регистре, полностью, включая http:// или https:// ");
							ПроверкаНаОбязательныеПоля = Истина;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЯндексСайт) И Не (Лев(ЯндексСайт, 7) = "http://" Или Лев(ЯндексСайт, 8) = "https://") Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Основной сайт сети. Указывается в нижнем регистре, полностью, включая http:// или https:// ");
				ПроверкаНаОбязательныеПоля = Истина;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ЯндексКоординатыПоШироте) ИЛИ Не ЗначениеЗаполнено(ЯндексКоординатыПоДолготе) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо указать координаты");
				ПроверкаНаОбязательныеПоля = Истина;	
			КонецЕсли;

			Если Не ЗначениеЗаполнено(ЯндексИдентификаторРубрики) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо добавить от 1 до 3 рубрик");
				ПроверкаНаОбязательныеПоля = Истина;
			КонецЕсли;
		КонецЕсли;
		// Если ЗначениеЗаполнено(ЯндексКоординатыПоДолготе) 
		//	И ЗначениеЗаполнено(ЯндексКоординатыПоШироте) Тогда
		//	ПроверкаПОДолготе = ЯвляетсяЧислом(ЯндексКоординатыПоДолготе);
		//	ПроверкаПоШироте  = ЯвляетсяЧислом(ЯндексКоординатыПоШироте);
		//	Если ПроверкаПОДолготе = Истина И ПроверкаПоШироте = Истина Тогда
		//		ЧислоПоДолготе = Число(ЯндексКоординатыПоДолготе);
		//		ЧислоПоШироте  = Число(ЯндексКоординатыПоШироте);
		//		Если ЧислоПоДолготе > 180 
		//			Или ЧислоПоДолготе < -180 
		//			Или ЧислоПоШироте > 90 
		//			Или ЧислоПоШироте < -90 Тогда
		//			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Неверно заполнены координаты. Координаты по широте(значение от -90.0000000 до 90.0000000) и Координаты по долготе(значение от -180.0000000 до 180.0000000)");
		//			ПроверкаНаОбязательныеПоля = Истина;
		//		КонецЕсли;
		//	Иначе
		//		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Неверно заполнены координаты. Координаты по широте(значение от -90.0000000 до 90.0000000) и Координаты по долготе(значение от -180.0000000 до 180.0000000)");
		//		ПроверкаНаОбязательныеПоля = Истина;
		//	КонецЕсли;
		// Иначе	
		//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните обязательные поля: Координаты по широте(значение от -90.0000000 до 90.0000000) и Координаты по долготе(значение от -180.0000000 до 180.0000000)");
		//	ПроверкаНаОбязательныеПоля = Истина;
		// КонецЕсли;		
		
		Если ПроверкаНаОбязательныеПоля Тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		Настройки  = Новый Структура();
		
		Настройки .Вставить("Организация"						, Строка(ЭтотОбъект.ЯндексНаименованиеОрганизации.УникальныйИдентификатор()));
		Настройки .Вставить("УникальныйНеизменныйИдентификатор" , ЭтотОбъект.ЯндексУникальныйНеизменныйИдентификатор);
		Настройки .Вставить("Салон"								, Объект.Наименование);
		Настройки .Вставить("ОГРН"								, ЭтотОбъект.ЯндексНаименованиеОрганизации.ОГРН);
		Настройки .Вставить("ИНН"								, ЭтотОбъект.ЯндексНаименованиеОрганизации.ИНН);
		Настройки .Вставить("ЧасыРаботы"	 					, ЭтотОбъект.ЯндексЧасыРаботы);
		Настройки .Вставить("Страна"							, Строка(Константы.СтранаУчета.Получить()));
		Настройки .Вставить("ИспользоватьЯндексКарты"			, Объект.ИспользоватьЯндексКарты);
		Настройки .Вставить("Сайт"								, НРег(ЭтотОбъект.ЯндексСайт));
		Настройки .Вставить("ДополнительныйСайт"				, НРег(ЭтотОбъект.ЯндексДополнительныйСайт));
		Настройки .Вставить("КоординатыПоДолготе"				, ЭтотОбъект.ЯндексКоординатыПоДолготе);
		Настройки .Вставить("КоординатыПоШироте"				, ЭтотОбъект.ЯндексКоординатыПоШироте);
		Настройки .Вставить("ИдентификаторРубрики"	  			, ЭтотОбъект.ЯндексИдентификаторРубрики);
		Настройки .Вставить("ДатаАктуализации"	  				, ЭтотОбъект.ЯндексДатаАктуализации);
		Настройки .Вставить("Телефон"							, ЯндексНомераТелефонов);
		Настройки .Вставить("ЭлектроннаяПочта"					, ЭтотОбъект.ЯндексЭлектроннаяПочта);
		Настройки .Вставить("Адрес"								, ЭтотОбъект.ЯндексАдрес);
		Настройки .Вставить("Город"								, ЭтотОбъект.ЯндексГород);
		Настройки .Вставить("ДопАдрес"							, ЭтотОбъект.ЯндексДополнительнаяИнформацияКАдресу);
		Настройки .Вставить("КороткийАдрес"						, ЭтотОбъект.ЯндексКороткийАдрес);
		
		ЭтаФорма.ЯндексИНН 	= ЭтотОбъект.ЯндексНаименованиеОрганизации.ИНН;
		ЭтаФорма.ЯндексОГРН	= ЭтотОбъект.ЯндексНаименованиеОрганизации.ОГРН;
		
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ЯндексКарты, ЛОжь); 
		
		Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда			
			ВнешняяСистема = Справочники.ВнешниеСистемы.СоздатьВнешнююСистему(Перечисления.ТипыВнешнихСистем.ЯндексКарты,,Истина);
		КонецЕсли;	
		ЯндексКлючВнешнейСистемы = НРег(ВнешняяСистема.КлючПриложения);
		ЯндексНомерОбласти = ЛичныйКабинет.ПолучитьНомерОбласти();
		
		Индекс = 0;
		Для Каждого СтрокаТ Из ЭтотОбъект.ФайлыКартинок Цикл
			ФайлКартинки  = ЭтотОбъект.ФайлыКартинок[Индекс].Значение;				
			БазовыйURL    =  "http://app.stoma1c.ru/api/hs/api";
			АдресКартинки = БазовыйURL + "/files/" + ВнешняяСистема.КлючПриложения + "/" + Строка(ФайлКартинки.УникальныйИдентификатор()) + "." + ФайлКартинки.Расширение;
			ЭтотОбъект.ФайлыКартинок[Индекс].Представление = АдресКартинки;
			Индекс = Индекс + 1; 				
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ФайлыКартинок) Тогда
			ЯндексСсылкаНаФото = БазовыйURL + "/files/" + ВнешняяСистема.КлючПриложения + "/gallery"; 
		Иначе	
			ЯндексСсылкаНаФото = "";
		КонецЕсли;
		
		Настройки.Вставить("СсылкаНаФото", НРег(ЯндексСсылкаНаФото));			
		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("НастройкиЯндексКарты", Настройки);
		
		ЭтоЗаписьВЦРМ = Истина;
		
		РезультатЗапроса = ЛичныйКабинет.СоздатьВнешнююСистемуВ_CRM(ВнешняяСистема, ЭтотОбъект.УидСессии);
		
		Если НЕ РезультатЗапроса.ВыполненоУспешно Тогда
			ЗаписьЖурналаРегистрации("ЯндексКарты", УровеньЖурналаРегистрации.Ошибка,,,"Код ошибки: " + РезультатЗапроса.КодОшибки + " Описание ошибки: " + РезультатЗапроса.ОписаниеОшибки); 
		КонецЕсли; 		
		
	КонецЕсли;
	
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);

КонецПроцедуры

