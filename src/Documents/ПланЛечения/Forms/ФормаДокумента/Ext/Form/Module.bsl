// Процедура, заполняет настройки подбора номенклатуры.
//
Процедура ЗаполнитьНастройкиПодбораНоменклатуры()
	
	ОтображатьАртикулВрем								= ПолучитьНастройкуПользователя(ПланыВидовХарактеристик.НастройкиПользователей.ОтображатьАртикул, Объект.АвторДокумента, Объект.СтруктурнаяЕдиница);
