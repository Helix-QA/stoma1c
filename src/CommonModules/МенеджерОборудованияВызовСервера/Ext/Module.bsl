// Функция возвращает из переменной сеанса имя компьютера клиента.
//
Функция ПолучитьРабочееМестоКлиента() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если ОбщегоНазначенияПовтИсп.ЭтоСеансРегламентногоЗадания() Тогда 
		Возврат Справочники.РабочиеМеста.ПустаяСсылка();
	Иначе 	
		Возврат ПараметрыСеанса.РабочееМестоКлиента;
	КонецЕсли;	

КонецФункции

// Функция возвращает список рабочих мест, соответствующих указанному имени компьютера.
//
Функция НайтиРабочиеМестаПоИД(ИдентификаторКлиента, ИмяКомпьютера) Экспорт
	
	Если Не ОбщегоНазначения.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат Новый Массив();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Заглушка, при первом входе не успевает инициализироваться параметр сеанса Текущий пользователь
	Если ЗначениеЗаполнено(Константы.ДатаПервогоВходаВСистему.Получить()) Тогда 
		РабочееМесто = Пользователи.ПолучитьЗначениеПоУмолчаниюПользователя(Неопределено, "ОсновноеРабочееМесто");
		
		Если ЗначениеЗаполнено(РабочееМесто) Тогда
			СписокКомпьютеров = Новый Массив;
			СписокКомпьютеров.Добавить(РабочееМесто);
			Возврат СписокКомпьютеров;
		КонецЕсли;
	КонецЕсли;
	
	// Проверяем рабочие места на наличие многопользовательского места.	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИмяКомпьютера", ИмяКомпьютера);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РабочиеМеста.Ссылка
	|ИЗ
	|	Справочник.РабочиеМеста КАК РабочиеМеста
	|ГДЕ
	|	НЕ РабочиеМеста.ПометкаУдаления
	|	И РабочиеМеста.Код = &ИмяКомпьютера
	|	И РабочиеМеста.МногопользовательскийРежим";
	
	СписокКомпьютеров = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Если СписокКомпьютеров.Количество() = 0 Тогда 
		Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	РабочиеМеста.Ссылка
		|ИЗ
		|	Справочник.РабочиеМеста КАК РабочиеМеста
		|ГДЕ
		|	РабочиеМеста.Код = &Код
		|	И РабочиеМеста.ПометкаУдаления = ЛОЖЬ
		|");
		
		Запрос.УстановитьПараметр("Код", ИдентификаторКлиента);
		СписокКомпьютеров = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
	Возврат СписокКомпьютеров;
	
КонецФункции

// Функция устанавливает в переменную сеанса имя компьютера клиента.
//
Процедура УстановитьРабочееМестоКлиента(РабочееМестоКлиента) Экспорт

