// Функция - Вернуть представление количества получателей.
//
// Параметры:
//  КоличествоПолучателей	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьПредставлениеКоличестваПолучателей(КоличествоПолучателей)
		
	Если ЗначениеЗаполнено(КоличествоПолучателей) Тогда
		ПредставлениеПолучателей = "" + КоличествоПолучателей + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Получатель", КоличествоПолучателей);
	Иначе
		ПредставлениеПолучателей = НСтр("ru='нет получателей'; en='no recipients'");
	КонецЕсли;
	
	Возврат ПредставлениеПолучателей;

КонецФункции

