// Процедура, получить значения отборов динамических списков.
//
Процедура ПолучитьЗначенияОтборов()
	
	Если ЭтотОбъект.ОтборБезСделок
		ИЛИ ЭтотОбъект.ОтборБезЗадач
		ИЛИ ЭтотОбъект.ОтборПросроченныхЗадач Тогда
			
		ОтборСтатус 				= Новый Массив();
		ОтборЭтап					= Новый Массив();
		ОтборСотрудникРегистрации   = Новый Массив();
		ОтборРекламныйИсточник 		= Новый Массив();
		ОтборКаналПривлечения 		= Новый Массив();
		ОтборТеги 					= Новый Массив();
		ОтборИнтересы 				= Новый Массив();
		ОтборСделки 				= Новый Массив();
		ОтборЗадачи 				= Новый Массив();
		ОтборМенеджер = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборМенеджеры");
		ОтборМенеджер = ?(ЗначениеЗаполнено(ОтборМенеджер), ОтборМенеджер ,УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборМенеджеры", Истина));
		ОтборСтатус = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСтатус");
		ОтборСтатус = ?(ЗначениеЗаполнено(ОтборСтатус), ОтборСтатус ,УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСтатус", Истина));
		
		// ОтборМенеджер.Добавить(ЭтотОбъект.ТекущийПользователь);
		// ОтборСтатус.Добавить("Потенциальный");
		
		Если ЭтотОбъект.ОтборБезСделок Тогда
			ОтборСделки.Добавить(Нстр("ru = 'Нет сделок'; en = 'No deals'"));
		ИначеЕсли ЭтотОбъект.ОтборБезЗадач Тогда		
			ОтборЗадачи.Добавить(Нстр("ru = 'Нет задач'; en = 'No tasks'"));
		КонецЕсли;
		
	Иначе
		
		ОтборСтатус				  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСтатус");
		ОтборЭтап				  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборЭтап");
		ОтборСотрудникРегистрации = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудникРегистрации");
		ОтборМенеджер 			  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборМенеджеры");
		ОтборРекламныйИсточник 	  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборРекламныйИсточник");
		ОтборКаналПривлечения 	  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборКаналПривлечения");
		ОтборТеги			 	  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборТеги");
		ОтборИнтересы			  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборИнтересы");
		ОтборСделки				  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСделки");
		ОтборЗадачи				  = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборЗадачи");
		
	КонецЕсли;
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборСтатус"				 , ОтборСтатус);
	СтруктураОтборов.Вставить("ОтборЭтап"				 , ОтборЭтап);
	СтруктураОтборов.Вставить("ОтборСотрудникРегистрации", ОтборСотрудникРегистрации);
	СтруктураОтборов.Вставить("ОтборМенеджер"			 , ОтборМенеджер);
	СтруктураОтборов.Вставить("ОтборРекламныйИсточник"	 , ОтборРекламныйИсточник);
	СтруктураОтборов.Вставить("ОтборКаналПривлечения"	 , ОтборКаналПривлечения);
	СтруктураОтборов.Вставить("ОтборТеги"				 , ОтборТеги);
	СтруктураОтборов.Вставить("ОтборИнтересы"			 , ОтборИнтересы);
	СтруктураОтборов.Вставить("ОтборСделки"			 	 , ОтборСделки);
	СтруктураОтборов.Вставить("ОтборЗадачи"				 , ОтборЗадачи);
	
	// Основаня процедура, установки параметров.
	УстановитьТекстЗапросаСписку(СтруктураОтборов);	
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает новый запрос для списка с учетом параметров.
//
// Параметры (название, тип, дифференцированное значение)
//	СтруктураОтборов - Структура - Массивы отборов помещенные в структуру.
//
Процедура УстановитьТекстЗапросаСписку(СтруктураОтборов)
	
	ТекстЗапросаДляКоличества = ПолучитьТекстЗапрсаДляПодсчетаКоличества();
	
	// текст запроса без отборов (чистый)
	ТекстЗапроса =	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
	|ПОМЕСТИТЬ КонтрагентыНазначеннаяДатаЗадачи
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Клиент,
	|	Контрагенты.Код КАК Код,
	|	КонтрагентыСведенияДляСписка.Статус КАК Статус,
	|	КонтрагентыСведенияДляСписка.Телефон КАК Телефон,
	|	КонтрагентыСведенияДляСписка.АдресЭП КАК АдресЭП,
	|	КонтрагентыСведенияДляСписка.Интересы КАК Интересы,
	|	Контрагенты.Менеджер КАК Менеджер,
	|	Контрагенты.ИсточникИнформации КАК ИсточникИнформации,
	|	Контрагенты.ДатаРегистрации КАК ДатаРегистрации,
	|	Контрагенты.СотрудникРегистрации КАК СотрудникРегистрации,
	|	Контрагенты.КаналПривлечения КАК КаналПривлечения,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК ТекущаяСделка,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки КАК ТекущийЭтапСделки,
	|	КонтрагентыСведенияДляСписка.СуммаСделки КАК СуммаСделки,
	|	КонтрагентыСведенияДляСписка.ПоследняяЗадача КАК ПоследняяЗадача,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача,
	|	КонтрагентыСведенияДляСписка.ПоследняяЗадачаПредставление КАК ПоследняяЗадачаПредставление,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадачаПредставление КАК СледующаяЗадачаПредставление,
	|	ВЫРАЗИТЬ(КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтрагентыНазначеннаяДатаЗадачи КАК КонтрагентыНазначеннаяДатаЗадачи
	|		ПО Контрагенты.Ссылка = КонтрагентыНазначеннаяДатаЗадачи.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ЛОЖЬ
	|	И Контрагенты.ПометкаУдаления = ЛОЖЬ
	|	И Контрагенты.ОбезличенныйКлиент = ЛОЖЬ
	|	И &УсловиеСтатус
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеМенеджер
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеТеги
	|	И &УсловиеИнтересы
	|	И &УсловиеДатаРегистрации
	|	И &УсловиеДатаЗапланированнойЗадачи
	|	И &УсловиеОтборБезЗадач
	|	И &УсловиеОтборБезСделок
	|	И &УсловиеЭтап";
	
	Если СтруктураОтборов.ОтборСтатус.Количество() > 0 Тогда 
		
		УсловиеСтатус = 
		" И Контрагенты.Ссылка В
		|			(ВЫБРАТЬ
		|				СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент
		|			ИЗ
		|				РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, ) КАК СтатусыКонтрагентовСрезПоследних
		|			ГДЕ
		|				СтатусыКонтрагентовСрезПоследних.Статус = &СтатусКлиента)";
		
		
		Если СтруктураОтборов.ОтборСтатус[0] = "Потенциальный" Тогда
			УсловиеСтатус = СтрЗаменить(УсловиеСтатус, "&СтатусКлиента", "ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный)");
		ИначеЕсли СтруктураОтборов.ОтборСтатус[0] = "Отказ" Тогда
			УсловиеСтатус = СтрЗаменить(УсловиеСтатус, "&СтатусКлиента", "ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ)");
		КонецЕсли;
		
	Иначе		
		УсловиеСтатус = "";		
	КонецЕсли;
		
	ТекстЗапроса             	= СтрЗаменить(ТекстЗапроса, "И &УсловиеСтатус", УсловиеСтатус);
	ТекстЗапросаДляКоличества 	= СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеСтатус", УсловиеСтатус);
	
	УсловиеСотрудникРегистрации = ?(ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации), "И Контрагенты.СотрудникРегистрации В (&ОтборСотрудникРегистрации)", "");
	ТекстЗапроса             	= СтрЗаменить(ТекстЗапроса, "И &УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
	ТекстЗапросаДляКоличества   = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
	
	УсловиеМенеджер             = ?(ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер), "И Контрагенты.Менеджер В (&ОтборМенеджер)", "");
	ТекстЗапроса             	= СтрЗаменить(ТекстЗапроса, "И &УсловиеМенеджер", УсловиеМенеджер);
	ТекстЗапросаДляКоличества   = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеМенеджер", УсловиеМенеджер);
	
	УсловиеРекламныйИсточник    = ?(ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник), "И Контрагенты.ИсточникИнформации В (&ОтборРекламныйИсточник)", "");
	ТекстЗапроса             	= СтрЗаменить(ТекстЗапроса, "И &УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
	ТекстЗапросаДляКоличества   = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		
	УсловиеКаналПривлечения     = ?(ЗначениеЗаполнено(СтруктураОтборов.ОтборКаналПривлечения), "И Контрагенты.КаналПривлечения В (&ОтборКаналПривлечения)", "");
	ТекстЗапроса             	= СтрЗаменить(ТекстЗапроса, "И &УсловиеКаналПривлечения", УсловиеКаналПривлечения);
	ТекстЗапросаДляКоличества   = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеКаналПривлечения", УсловиеКаналПривлечения);
		
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборТеги) Тогда
		
		ИндексПустогоТега = СтруктураОтборов.ОтборТеги.Найти(Справочники.Теги.ПустаяСсылка());
		
		УсловиеТеги =  
		"И Контрагенты.Ссылка В
		|  		(ВЫБРАТЬ
		|  			СправочникКонтрагентыТеги.Ссылка
		|  		ИЗ
		|  			Справочник.Контрагенты.Теги КАК СправочникКонтрагентыТеги
		|  		ГДЕ
		|  			СправочникКонтрагентыТеги.Тег В (&ОтборТеги))";
			
	Иначе
		УсловиеТеги = "";		
	КонецЕсли;
	
	ТекстЗапроса 			  = СтрЗаменить(ТекстЗапроса, "И &УсловиеТеги", УсловиеТеги);
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеТеги", УсловиеТеги);
	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборИнтересы) Тогда
		
		//ИндексПустогоИнтереса = СтруктураОтборов.ОтборИнтересы.Найти(Справочники.Интересы.ПустаяСсылка());
		//
		//Если ИндексПустогоИнтереса <> Неопределено Тогда
		//	
		//	УсловиеИнтересы =
		//	"И Контрагенты.Ссылка В
		//	|  		(ВЫБРАТЬ
		//	|			СправочникКонтрагентыИнтересы.Ссылка КАК Контрагент
		//	|		ИЗ
		//	|			Справочник.Контрагенты.Интересы КАК СправочникКонтрагентыИнтересы
		//	|		ГДЕ
		//	|			СправочникКонтрагентыИнтересы.Интерес В (&ОтборИнтересы)
		//	|	
		//	|		ОБЪЕДИНИТЬ ВСЕ
		//	|	
		//	|		ВЫБРАТЬ
		//	|			КонтрагентыСведенияДляСписка.Контрагент
		//	|		ИЗ
		//	|			РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
		//	|		ГДЕ
		//	|			КонтрагентыСведенияДляСписка.Интересы = """")";

		//Иначе
		//	
		//	УсловиеИнтересы =
		//	"И Контрагенты.Ссылка В
		//	|  		(ВЫБРАТЬ
		//	|  			СправочникКонтрагентыИнтересы.Ссылка
		//	|  		ИЗ
		//	|  			Справочник.Контрагенты.Интересы КАК СправочникКонтрагентыИнтересы
		//	|  		ГДЕ
		//	|  			СправочникКонтрагентыИнтересы.Интерес В (&ОтборИнтересы))";
		//	
		//КонецЕсли;
		
	Иначе
		УсловиеИнтересы = "";
	КонецЕсли;
	
	ТекстЗапроса 			  = СтрЗаменить(ТекстЗапроса, "И &УсловиеИнтересы", УсловиеИнтересы);
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеИнтересы", УсловиеИнтересы);
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации) Тогда   
		
		УсловиеДатаРегистрации = "И Контрагенты.ДатаРегистрации МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
	Иначе
		УсловиеДатаРегистрации = "";
		
	КонецЕсли;
	
	ТекстЗапроса 			  = СтрЗаменить(ТекстЗапроса, "И &УсловиеДатаРегистрации", УсловиеДатаРегистрации);
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеДатаРегистрации", УсловиеДатаРегистрации);
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи) Тогда   
		УсловиеДатаЗапланированнойЗадачи = "И КонтрагентыНазначеннаяДатаЗадачи.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		// УсловиеДатаЗапланированнойЗадачи = "И КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
	Иначе                               
		УсловиеДатаЗапланированнойЗадачи = "";
		
	КонецЕсли;
	
	ТекстЗапроса 			  = СтрЗаменить(ТекстЗапроса, "И &УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадачи) 
		И СтруктураОтборов.ОтборЗадачи[0] = Нстр("ru = 'Нет задач'; en = 'No tasks'") Тогда
		
		УсловиеОтборБезЗадач = "И КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)";				
	Иначе		
		УсловиеОтборБезЗадач = "";	
	КонецЕсли;
	
	ТекстЗапроса			  = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСделки)
		И СтруктураОтборов.ОтборСделки[0] = Нстр("ru = 'Нет сделок'; en = 'No deals'") Тогда
		
		УсловиеОтборБезСделок = "И КонтрагентыСведенияДляСписка.ТекущаяСделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";					
	Иначе		
		УсловиеОтборБезСделок = "";		
	КонецЕсли;
	
	ТекстЗапроса 		  	  = СтрЗаменить(ТекстЗапроса, "И &УсловиеОтборБезСделок", УсловиеОтборБезСделок);
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеОтборБезСделок", УсловиеОтборБезСделок);
	
	УсловиеЭтап  = ?(ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап), "И КонтрагентыСведенияДляСписка.ТекущийЭтапСделки В (&ОтборЭтап)", "");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &УсловиеЭтап", УсловиеЭтап);		
	ТекстЗапросаДляКоличества = СтрЗаменить(ТекстЗапросаДляКоличества, "И &УсловиеЭтап", УсловиеЭтап);		
	
	ЭтотОбъект.Список.ТекстЗапроса = ТекстЗапроса;
	УстановитьПараметрыСписку(СтруктураОтборов, ТекстЗапросаДляКоличества);
	
КонецПроцедуры

&НаСервере
// Процедура, УстановитьПараметрыСписку.
//
Процедура УстановитьПараметрыСписку(СтруктураОтборов, ТекстЗапросаДляКоличества)
	
	перем ОтборСтатус, ОтборЭтап, ОтборСотрудникРегистрации, ОтборМенеджер, ОтборРекламныйИсточник, 
	ОтборКаналПривлечения, ОтборТеги, ОтборИнтересы, ОтборСделки, ОтборЗадачи; 
	
	СтруктураОтборов.Свойство("ОтборСтатус"				 , ОтборСтатус);
	СтруктураОтборов.Свойство("ОтборЭтап"				 , ОтборЭтап);
	СтруктураОтборов.Свойство("ОтборСотрудникРегистрации", ОтборСотрудникРегистрации);
	СтруктураОтборов.Свойство("ОтборМенеджер"			 , ОтборМенеджер);
	СтруктураОтборов.Свойство("ОтборРекламныйИсточник"	 , ОтборРекламныйИсточник);
	СтруктураОтборов.Свойство("ОтборКаналПривлечения"	 , ОтборКаналПривлечения);
	СтруктураОтборов.Свойство("ОтборТеги"				 , ОтборТеги);
	СтруктураОтборов.Свойство("ОтборИнтересы"			 , ОтборИнтересы);
	СтруктураОтборов.Свойство("ОтборСделки"			 	 , ОтборСделки);
	СтруктураОтборов.Свойство("ОтборЗадачи"				 , ОтборЗадачи);
	
	НовыйЗапросДляКоличества = Новый Запрос(ТекстЗапросаДляКоличества);
	
	ЕстьОтборы = Ложь;
	
	Если ОтборСотрудникРегистрации.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборСотрудникРегистрации", ОтборСотрудникРегистрации);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборСотрудникРегистрации", ОтборСотрудникРегистрации);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ОтборЭтап.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборЭтап", ОтборЭтап);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборЭтап", ОтборЭтап);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ОтборМенеджер.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборМенеджер", ОтборМенеджер);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборМенеджер", ОтборМенеджер);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ОтборРекламныйИсточник.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборРекламныйИсточник", ОтборРекламныйИсточник);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборРекламныйИсточник", ОтборРекламныйИсточник);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ОтборКаналПривлечения.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборКаналПривлечения", ОтборКаналПривлечения);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборКаналПривлечения", ОтборКаналПривлечения);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ОтборТеги.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборТеги", ОтборТеги);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборТеги", ОтборТеги);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ОтборИнтересы.Количество() > 0 Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОтборИнтересы", ОтборИнтересы);
		НовыйЗапросДляКоличества.УстановитьПараметр("ОтборИнтересы", ОтборИнтересы);
		ЕстьОтборы = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации) Тогда 		
		Список.Параметры.УстановитьЗначениеПараметра("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала),    ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала, Дата(01,01,0001)));	
		Список.Параметры.УстановитьЗначениеПараметра("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания), ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания, Дата(3999,12,31)));
		НовыйЗапросДляКоличества.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала),    ЭтотОбъект.ОтборДатаРегистрации.ДатаНачала, Дата(01,01,0001)));
		НовыйЗапросДляКоличества.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания), ЭтотОбъект.ОтборДатаРегистрации.ДатаОкончания, Дата(3999,12,31)));
		ЕстьОтборы = Истина;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи) Тогда 		
		Список.Параметры.УстановитьЗначениеПараметра("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаНачала),    ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаНачала, Дата(01,01,0001)));	
		Список.Параметры.УстановитьЗначениеПараметра("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаОкончания), ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаОкончания, Дата(3999,12,31)));
		НовыйЗапросДляКоличества.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаНачала),    ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаНачала, Дата(01,01,0001)));	
		НовыйЗапросДляКоличества.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаОкончания), ЭтотОбъект.ОтборДатаЗапланированнойЗадачи.ДатаОкончания, Дата(3999,12,31)));
		ЕстьОтборы = Истина;		
	КонецЕсли;
	// Если ЗначениеЗаполнено(ОтборСтатус) И ОтборСтатус.Найти("Потенциальный") <> Неопределено Тогда 
	//	Список.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	//	НовыйЗапросДляКоличества.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	// КонецЕсли;	

	ВыборкаДляКоличества = НовыйЗапросДляКоличества.Выполнить().Выбрать();
	
	Если ВыборкаДляКоличества.Следующий() Тогда
		
		КоличествоКлиентов = ВыборкаДляКоличества.КоличествоКлиентов;
		УстановитьЗаголовокКоличествоКлиентов(ЕстьОтборы, КоличествоКлиентов);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// При изменении состава отборов.
//
Процедура ПриИзмененииОтборовСервер(Знач ИмяКоманды)
	
	Если ЭтотОбъект.ОтборБезЗадач 
		ИЛИ ЭтотОбъект.ОтборБезСделок
		ИЛИ ЭтотОбъект.ОтборПросроченныхЗадач Тогда
		
		ЭтотОбъект.ОтборБезЗадач  = Ложь;
		ЭтотОбъект.ОтборБезСделок = Ложь;
		ЭтотОбъект.ОтборПросроченныхЗадач = Ложь;

	КонецЕсли;
	
	Если СтрНайти(ИмяКоманды, "КомандаОтбор") = 0 
		И СтрНайти(ИмяКоманды, "ПолеОтбор") = 0 Тогда
		
		УстановитьФокусЭлементаСервер();
		
	КонецЕсли;
		
	ЭлементФормы   = УправлениеИнтерфейсамиСервер.ЭлементФормыПоИмениЭлемента(ЭтаФорма, ИмяКоманды);
	ИмяЭлемента    = ЭлементФормы.Имя;
	ОбновитьОтборы = УправлениеИнтерфейсамиСервер.ОбработчикЭлементаДинамическогоМенюПриНажатии(ЭтаФорма, ИмяЭлемента);

	Если ОбновитьОтборы Тогда 
		ПолучитьЗначенияОтборов();
	КонецЕсли;

КонецПроцедуры

