// Функция - Добавить массив
//
// Параметры:
//  ИсходныйМассив	 - 	 - 
//  НовыеДанные		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДобавитьВМассив(ИсходныйМассив, НовыеДанные, КонтрольУникальности = Ложь) Экспорт
	
	Если ТипЗнч(НовыеДанные) = Тип("Массив") 
		ИЛИ ТипЗнч(НовыеДанные) = Тип("ФиксированныйМассив") Тогда
		
		Для Каждого ЭлементМ ИЗ НовыеДанные Цикл
			Если КонтрольУникальности = Истина Тогда
				Если ИсходныйМассив.Найти(ЭлементМ) = Неопределено Тогда
					ИсходныйМассив.Добавить(ЭлементМ);
				КонецЕсли;
			Иначе
				ИсходныйМассив.Добавить(ЭлементМ);
			КонецЕсли;
		КонецЦикла;
		
	Иначе
		Если КонтрольУникальности = Истина Тогда
			Если ИсходныйМассив.Найти(НовыеДанные) = Неопределено Тогда
				ИсходныйМассив.Добавить(НовыеДанные);
			КонецЕсли;
		Иначе
			ИсходныйМассив.Добавить(НовыеДанные);
		КонецЕсли;
	КонецЕсли;
			
	Возврат ИсходныйМассив;
	
КонецФункции  

// Функция, возвращает массив значений из таблицы значений
//  Параметры:
//    ТаблицаЗначений - Таблица значений;
Функция ПреобразоватьТЗвМассивСтруктуры(ТаблицаЗначений) Экспорт
	
	Результат = Новый Массив;
	СтрокаКолонок = "";
	Для Каждого КолонкаТЗ Из ТаблицаЗначений.Колонки Цикл
		СтрокаКолонок = СтрокаКолонок + ?(ЗначениеЗаполнено(СтрокаКолонок), ",", "") + КолонкаТЗ.Имя;
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из ТаблицаЗначений Цикл
		НоваяСтрокаСтруктурой = Новый Структура(СтрокаКолонок);
		ЗаполнитьЗначенияСвойств(НоваяСтрокаСтруктурой, СтрокаТЗ);
		Результат.Добавить(НоваяСтрокаСтруктурой);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

