// Процедура переносит значения ресурса УпаковкаУдалить в измерение Упаковка регистра сведений.
// КритическиеОстатки и очищаяет данный ресурс.
Процедура ПереносУпаковкиВРегистреКритическиеОстатки() Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	                      |	КритическиеОстатки.Номенклатура,
	                      |	КритическиеОстатки.Склад,
						  | ЕСТЬNULL(КритическиеОстатки.Склад.СтруктурнаяЕдиница, &ТекущаяСтруктурнаяЕдиница) КАК СтруктурнаяЕдиница,
	                      |	ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка) КАК УпаковкаУдалить,
	                      |	МАКСИМУМ(КритическиеОстатки.Количество) КАК Количество,
	                      |	МАКСИМУМ(КритическиеОстатки.УпаковкаУдалить) КАК Упаковка
	                      |ИЗ
	                      |	РегистрСведений.КритическиеОстатки КАК КритическиеОстатки
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	КритическиеОстатки.Номенклатура,
	                      |	КритическиеОстатки.Склад,
	                      |	ЕСТЬNULL(КритическиеОстатки.Склад.СтруктурнаяЕдиница, &ТекущаяСтруктурнаяЕдиница),
	                      |	ЕСТЬNULL(КритическиеОстатки.Склад.СтруктурнаяЕдиница, &ТекущаяСтруктурнаяЕдиница)");
						  
	Запрос.УстановитьПараметр("ТекущаяСтруктурнаяЕдиница",ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	Результат = Запрос.Выполнить().Выгрузить();
	
	ТаблицаРегистра = РегистрыСведений.КритическиеОстатки.СоздатьНаборЗаписей();
	ТаблицаРегистра.Загрузить(Результат);
	ТаблицаРегистра.Записать(Истина);
	
КонецПроцедуры

// Процедура выбирает все записи по регситру профосмотры и проставляет измерение Вид осмотра.
//
Процедура ПрописатьВидыОсмотровВРегистрПрфосомотры() Экспорт	
	Попытка 
		НаборЗаписейПерезаписи = РегистрыСведений.Профосмотры.СоздатьНаборЗаписей();
		НаборЗаписейПерезаписи.Отбор.ВидОсмотра.Значение = Перечисления.ВидыОсмотров.ПустаяСсылка();
		НаборЗаписейПерезаписи.Отбор.ВидОсмотра.Использование = Истина;
		НаборЗаписейПерезаписи.Прочитать();
		
		НаборЗаписейУдаления = РегистрыСведений.Профосмотры.СоздатьНаборЗаписей();
		НаборЗаписейУдаления.Отбор.ВидОсмотра.Значение = Перечисления.ВидыОсмотров.ПустаяСсылка();
		НаборЗаписейУдаления.Отбор.ВидОсмотра.Использование = Истина;	
		НаборЗаписейУдаления.Записать(Истина);
		
		Для Каждого ЭлементН ИЗ НаборЗаписейПерезаписи Цикл
			ЭлементН.ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр;		
		КонецЦикла;
		НаборЗаписейПерезаписи.Отбор.ВидОсмотра.Значение = Перечисления.ВидыОсмотров.Профосмотр;
		НаборЗаписейПерезаписи.Отбор.ВидОсмотра.Использование = Истина;
		НаборЗаписейПерезаписи.Записать(Истина);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось выполнить процедуру ПрописатьВидыОсмотровВРегистрПрофсомотры");
	КонецПопытки;
