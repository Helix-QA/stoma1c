&НаКлиенте
// Процедура, обработчик события "Создание".
//
Процедура КонтрагентОтборСоздание(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ГруппаКлиентов = ОбщегоНазначенияСтоматология.ВернутьГруппуКлиентов();
	Если ЗначениеЗаполнено(ГруппаКлиентов) Тогда
		Родитель = ГруппаКлиентов;
	Иначе
		Родитель = ВернутьГруппуКонтрагентов();
	КонецЕсли;
	
	ИскомыйКлиент = Элемент.ТекстРедактирования;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Родитель", Родитель);
	ПараметрыОткрытия.Вставить("ТекстЗаполнения", ИскомыйКлиент);  
	ПараметрыЗаполнения = Новый Структура("Основание", ПараметрыОткрытия);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьИВыбратьКонтрагентаЗавершение", ЭтаФорма);
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", ПараметрыЗаполнения,,,,,ОписаниеОповещения);
	
КонецПроцедуры  

&НаКлиенте
// Процедура - Добавить и выбрать контрагента завершение
// 
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
// 
Процедура ДобавитьИВыбратьКонтрагентаЗавершение(Результат, Параметры) Экспорт
	
	Если Не Результат.Пустая() Тогда
		ЭтотОбъект.КонтрагентОтбор = Результат;
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", КонтрагентОтбор, ЗначениеЗаполнено(КонтрагентОтбор));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик списка при активации строки
//
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		Если Не Элементы.Найти("СписокОплатитьДокумент") = Неопределено Тогда
			Элементы.СписокОплатитьДокумент.Доступность = ТекущиеДанные.СуммаДокумента > ТекущиеДанные.СуммаОплачено И НЕ ЗначениеЗаполнено(ТекущиеДанные.ПолисМедСтрахования) И НЕ ТекущиеДанные.ПометкаУдаления; 		
		КонецЕсли;
	КонецЕсли;  
	
КонецПроцедуры

// Процедура - Список при получении данных на сервере
//
// Параметры:
//  ИмяЭлемента	 - 	 - 
//  Настройки	 - 	 - 
//  Строки		 - 	 - 
//
&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПриемыИзСписка = Строки.ПолучитьКлючи();
	Если ПриемыИзСписка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Прием.Контрагент КАК Контрагент,
		|	Прием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	Прием.Ссылка КАК Прием
		|ПОМЕСТИТЬ ВТПриемы
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Ссылка В(&ПриемыИзСписка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
		|	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус
		|ПОМЕСТИТЬ ВТСтатусы
		|ИЗ
		|	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
		|			,
		|			Контрагент В
		|				(ВЫБРАТЬ
		|					ВТПриемы.Контрагент
		|				ИЗ
		|					ВТПриемы КАК ВТПриемы)) КАК СтатусыКонтрагентовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПриемы.Прием КАК Прием,
		|	ВТПриемы.Контрагент КАК Контрагент,
		|	ВТПриемы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ВТСтатусы.Статус КАК Статус
		|ИЗ
		|	ВТПриемы КАК ВТПриемы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусы КАК ВТСтатусы
		|		ПО ВТПриемы.Контрагент = ВТСтатусы.Контрагент";
	
	Запрос.УстановитьПараметр("ПриемыИзСписка", ПриемыИзСписка);	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		СтрокаСписка = Строки[Выборка.Прием];
		СтрокаСписка.Данные["СтатусПациента"] = Выборка.Статус;
		
	КонецЦикла;     
	
	Если ЗначениеЗаполнено(Настройки.Отбор.Элементы) Тогда	
	//	Оповестить("ИзмененОтбор");		
	КонецЕсли;
	  
КонецПроцедуры   

#КонецОбласти

#Область ОбработчикиСобытийКомандФормы

&НаКлиенте
// Обработчик кнопки проведения оплаты документа 
//
Процедура ОплатитьДокумент(Команда)	
	
	УстановитьФункциональнуюОпцию_ОбменДаннымиВключен(Истина);	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;	
	Если НЕ ТекущиеДанные = Неопределено Тогда		
		Если ТекущиеДанные.Проведен Тогда
			
			Рекламация = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущиеДанные.Ссылка,"Рекламация");
			Если Рекламация Тогда
				ПоказатьПредупреждение(, "Нельзя оплатить прием-рекламацию!");
				Возврат;
			КонецЕсли;	
			ПараметрыОплаты = Новый Структура;
			ПараметрыОплаты.Вставить("ДатаПродажи"                       , ТекущиеДанные.Дата);
			ПараметрыОплаты.Вставить("СтруктурнаяЕдиница"                , ТекущиеДанные.СтруктурнаяЕдиница);
            ПараметрыОплаты.Вставить("Касса"                             , ТекущиеДанные.Касса);			
			ПараметрыОплаты.Вставить("ВидОперации"                       , ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа"));
			ПараметрыОплаты.Вставить("Контрагент"                        , ТекущиеДанные.Контрагент);
			ПараметрыОплаты.Вставить("ДокументыПродажи"                  , ТекущиеДанные.Ссылка);
			ПараметрыОплаты.Вставить("ЗакрытьФормуАвтоматически"         , Истина);

			ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОплаты", ПараметрыОплаты,,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
			
		Иначе
			ПоказатьПредупреждение(,"Предварительно необходимо провести документ!");
		КонецЕсли;		
	КонецЕсли;
	УстановитьФункциональнуюОпцию_ОбменДаннымиВключен(Ложь);
	
КонецПроцедуры

&НаКлиенте
// Процедура печати.
//
Процедура ДокументПечать(Команда)	
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		Структура = Новый Структура;
		Структура.Вставить("ИмяДокумента", "Прием");	
		Структура.Вставить("МассивДокументов", Элементы.Список.ВыделенныеСтроки);
		Структура.Вставить("Контрагент", Элементы.Список.ТекущиеДанные.Контрагент);   
		
		СписокПечатныхФорм = ПолучитьСписокПечати();
		Оповещение = Новый ОписаниеОповещения("ОбработкаКоманды", УправлениеПечатьюКлиентСтоматология, Структура);									
		//ПоказатьВыборИзСписка(Оповещение, СписокПечатныхФорм, ТекущийЭлемент);
		ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, ТекущийЭлемент);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - Сотрудник начало выбора продолжение завершение.
//
Процедура СотрудникНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда 
		ЭтотОбъект.ОтборНаГлавнойСотрудник = Результат;
		ОтборНаГлавнойСотрудникПриИзменении(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

