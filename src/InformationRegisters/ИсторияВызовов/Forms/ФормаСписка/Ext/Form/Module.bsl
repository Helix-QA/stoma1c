// Процедура - Проверка подключенной телефонии
//
Процедура ПроверкаПодключеннойТелефонии()

	ПодключенноеОборудование = МенеджерОборудованияВызовСервера.ПолучитьСписокОборудования("IPТелефония");
	
	Если ПодключенноеОборудование.Количество() = 0 Тогда
		ОтображениеКнопкиНастройкиТелефонии = Истина;
	Иначе
		
		КоличествоИспользуемогоОборудования = 0;
		Для Каждого ТекущееОборудование Из ПодключенноеОборудование Цикл	
			КоличествоИспользуемогоОборудования = КоличествоИспользуемогоОборудования + ?(ТекущееОборудование.УстройствоИспользуется, 1, 0);
		КонецЦикла;

		ОтображениеКнопкиНастройкиТелефонии = ?(КоличествоИспользуемогоОборудования = 0, Истина, Ложь);
		
	КонецЕсли;
	
    КоличествоПодключенногоВО = ПодключенноеОборудование.Количество();
	Элементы.ГруппаНастройкаТелефонии.Видимость = ОтображениеКнопкиНастройкиТелефонии;

КонецПроцедуры

