// Функция - Контактный номер телефона у адресата отсутствует
//
// Параметры:
//  Адресат	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция КонтактныйНомерТелефонаУАдресатаОтсутствует(Адресат)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СотрудникиКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	               |ИЗ
	               |	Справочник.Сотрудники.КонтактнаяИнформация КАК СотрудникиКонтактнаяИнформация
	               |ГДЕ
	               |	СотрудникиКонтактнаяИнформация.Ссылка = &Ссылка
	               |	И СотрудникиКонтактнаяИнформация.Тип = &Тип
	               |	И СотрудникиКонтактнаяИнформация.НомерТелефона <> &НомерТелефона";
	
	Запрос.УстановитьПараметр("Ссылка"			, Адресат);
	Запрос.УстановитьПараметр("Тип"				, Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("НомерТелефона"	, "");
	
	Возврат Запрос.Выполнить().Пустой();
	
КонецФункции	

