	|                    <td class='right_col' align='right'>
	|                        <a title=''id = 'ЭтоЛицевойСчет' style = 'cursor: pointer' class='author'{Цвет}>{Остаток}</a>
	|                    </td>
	|                </tr>
	|                <tr>
	|                    <td colspan='3' style='height: 8px;'>
	|                    </td>
	|                </tr>";
	
	Если ЗначениеЗаполнено(Контрагент) И ОбщаяИнформация.Количество() > 0 Тогда		
		ВыводитьБлок = Истина; 
		ОстатокПоТаблице = ?(ЗначениеЗаполнено(ОбщаяИнформация), ОбщаяИнформация.Итог("Остаток"), 0);		
		Остаток = "" + ?(ОстатокПоТаблице <> 0, Формат(ОстатокПоТаблице,"ЧДЦ=2; ЧРД=."), "0.00") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		
		Если ЗначениеЗаполнено(ОбщаяИнформация) И ОстатокПоТаблице < 0 Тогда 
			ЛицевойСчет = СтрЗаменить(ЛицевойСчет, "{Цвет}", "style='color: red;'");			
		КонецЕсли;
		ЛицевойСчет = СтрЗаменить(ЛицевойСчет, "{Остаток}", Остаток);
	Иначе
		ЛицевойСчет = "";		
	КонецЕсли;
	
	Возврат ЛицевойСчет;
	
КонецФункции 

