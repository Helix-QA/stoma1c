// Функция, возвращает код настройки ограничения переноса сделок между этапами.
//
Функция ПолучитьТекстОграниченияПереносаСделок(ДанныеСделки)
	
	Возврат ?(
		ЭтотОбъект.ВидСделки = ЭтотОбъект.ВидСделкиПоУмолчанию,
		"dragTo: [" + ПолучитьДоступныеДляПереносаБлоки(ДанныеСделки) + "],",
		""
	);
	
