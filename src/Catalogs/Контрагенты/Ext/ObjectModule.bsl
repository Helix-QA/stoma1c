// Процедура помечает на удаление дисконтные карты клиента
//
Процедура ПометитьНаУдалениеДисконтныеКартыКонтрагента()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Карты.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Карты КАК Карты
	               |ГДЕ
	               |	НЕ Карты.ПометкаУдаления
	               |	И Карты.ВладелецКарты = &ВладелецКарты";
				   
	Запрос.УстановитьПараметр("ВладелецКарты", ЭтотОбъект.Ссылка);			   
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Карта Из Результат Цикл
		КартаОбъект = Карта.Ссылка.ПолучитьОбъект();
		КартаОбъект.ПометкаУдаления = Истина;
		Попытка
			КартаОбъект.Записать();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать объект " + "" + Строка(КартаОбъект) + "");
		КонецПопытки;		
	КонецЦикла;	
			
КонецПроцедуры	

