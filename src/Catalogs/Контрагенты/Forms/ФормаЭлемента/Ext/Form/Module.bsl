// Функция - Структура для проверки ИННи КПП
//
// Параметры:
//  Форма		 - 	 - 
//  ПроверятьИНН - 	 - 
//  ПроверятьКПП - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СтруктураДляПроверкиИННиКППиОКПО(Форма, ПроверятьИНН, ПроверятьКПП, ПроверятьОКПО)
	
	Объект = Форма.Объект;
	СтруктураДляПроверкиИННиКПП = Новый Структура();
	
	СтруктураДляПроверкиИННиКПП.Вставить("ИНН",								   Объект.ИНН);
	СтруктураДляПроверкиИННиКПП.Вставить("КПП",								   Объект.КПП);
	СтруктураДляПроверкиИННиКПП.Вставить("ОКПО",							   Объект.КодПоОКПО);
	СтруктураДляПроверкиИННиКПП.Вставить("ЭтоЮрЛицо", 						   Объект.ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ЮрЛицо"));
	СтруктураДляПроверкиИННиКПП.Вставить("ПроверитьИНН",					   ПроверятьИНН);
	СтруктураДляПроверкиИННиКПП.Вставить("ПроверитьКПП",					   ПроверятьКПП);
	СтруктураДляПроверкиИННиКПП.Вставить("ПроверитьОКПО",					   ПроверятьОКПО);

	Возврат СтруктураДляПроверкиИННиКПП;
	
КонецФункции

