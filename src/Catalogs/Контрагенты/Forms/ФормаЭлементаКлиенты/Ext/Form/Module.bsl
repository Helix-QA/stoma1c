&НаСервере
// Функция - Получить параметры свойств полей КИ
//
// Параметры:
//  ВладелецКИ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыСвойствПолейКИ(Знач ВладелецКИ)
	
	ПараметрыСвойствПолейКИ = Новый Структура("Надпись_МаксимальнаяШирина, Представление_МаксимальнаяШирина_БезКомм, Представление_МаксимальнаяШирина_СКомм, Комментарий_МаксимальнаяШирина, ТолькоПросмотр");
	
	Если ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.Контрагенты") Тогда 
		
		Если РольДоступна(Метаданные.Роли.ПолныеПрава) ИЛИ РольДоступна(Метаданные.Роли.ИзменениеКлиентов) ИЛИ НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
			КИ_ТолькоПросмотр = Ложь;
		ИначеЕсли РольДоступна(Метаданные.Роли.ИзменениеСвоихКлиентовКуратором) Тогда 
			Если ЭтотОбъект.ТекущийПользователь = Объект.Куратор Тогда 
				КИ_ТолькоПросмотр = Ложь;
			Иначе 
				КИ_ТолькоПросмотр = Истина;
			КонецЕсли;			
		ИначеЕсли РольДоступна(Метаданные.Роли.ДобавлениеКлиентов) Тогда
			КИ_ТолькоПросмотр = Истина;
		Иначе 
			КИ_ТолькоПросмотр = Ложь;
		КонецЕсли;	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 9;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 60;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 40;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 9;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= КИ_ТолькоПросмотр;
		
	ИначеЕсли ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.Сотрудники") Тогда	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 6;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 41;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 31;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 8;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= Ложь;
		
	ИначеЕсли ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.СтруктурныеЕдиницы") Тогда	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 13;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 79;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 58;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 19;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= Ложь;
		
	ИначеЕсли ТипЗнч(ВладелецКИ) = Тип("СправочникСсылка.Организации") Тогда	
		
		ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина 					= 10;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм 	= 46;
		ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм 		= 35;
		ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина 				= 9;
		ПараметрыСвойствПолейКИ.ТолькоПросмотр 								= Ложь;
		
	КонецЕсли;
	
	Возврат ПараметрыСвойствПолейКИ;
	
КонецФункции

