
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗагрузитьНастройкиФормы();
	
	// Устанавливаем текущий реквизит поиска
	Если Параметры.Свойство("РеквизитПоиска") Тогда
		НайденРеквизитПоиска= ЭтаФорма.Элементы.ПолеРеквизитПоиска.СписокВыбора.НайтиПоЗначению(Параметры.РеквизитПоиска);
		Если НайденРеквизитПоиска<>Неопределено Тогда
			 ЭтаФорма.РеквизитРеквизитПоиска=НайденРеквизитПоиска.Значение;
		Иначе
			 ЭтаФорма.РеквизитРеквизитПоиска = ЭтаФорма.Элементы.ПолеРеквизитПоиска.СписокВыбора[0].Значение;
        КонецЕсли;
    Иначе
	     ЭтаФорма.РеквизитРеквизитПоиска = ЭтаФорма.Элементы.ПолеРеквизитПоиска.СписокВыбора[0].Значение;
	КонецЕсли;

	ЭтаФорма.РеквизитПутьПоиска = ЭтаФорма.Элементы.ПолеПутьПоиска.СписокВыбора[0].Значение;
	Для Каждого Ставки Из Перечисления.СтавкиНДС Цикл
		СтавкиНДС.Добавить(Ставки);
	КонецЦикла; 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаНайти(Команда)

	ЗначенияПоиска = Новый Структура;
	ЗначенияПоиска.Вставить("СтрокаПоиска",ЭтаФорма.РеквизитСтрокаПоиска);
	ЗначенияПоиска.Вставить("ПолеПоиска",ЭтаФорма.РеквизитРеквизитПоиска);
	ЗначенияПоиска.Вставить("ПутьПоиска",ЭтаФорма.РеквизитПутьПоиска); 
	
	Если ЭтаФорма.РеквизитРеквизитПоиска <> ЭтаФорма.Элементы.ПолеРеквизитПоиска.СписокВыбора[4].Значение Тогда
		Для Каждого Значение Из ЭтаФорма.СписокЗначенийПоиска Цикл
			Если ЭтаФорма.СписокЗначенийПоиска.Количество() = 20 Тогда
	 			ЭтаФорма.СписокЗначенийПоиска.Удалить(Значение);
			КонецЕсли;
			Если ЭтаФорма.РеквизитСтрокаПоиска = Строка(Значение) Тогда
				ЭтаФорма.СписокЗначенийПоиска.Удалить(Значение);
			КонецЕсли;
		КонецЦикла;
				
		ЭтаФорма.СписокЗначенийПоиска.Добавить(ЭтаФорма.РеквизитСтрокаПоиска);
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.СписокВыбора.Очистить();
		СохранитьНастройкиФормыПоиска();
	КонецЕсли;
	ЭтаФорма.Закрыть(ЗначенияПоиска);
	
КонецПроцедуры

#КонецОбласти    

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПолеРеквизитПоискаПриИзменении(Элемент)
	
	Если ЭтаФорма.РеквизитРеквизитПоиска = ЭтаФорма.Элементы.ПолеРеквизитПоиска.СписокВыбора[4].Значение Тогда
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.КнопкаСпискаВыбора = Ложь; 	 		
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.РежимВыбораИзСписка = Истина;
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.КнопкаВыбора = Истина; 	 		
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.СписокВыбора.Очистить();
		Для Каждого Ставки Из СтавкиНДС Цикл			
			ЭтаФорма.Элементы.ПолеСтрокаПоиска.СписокВыбора.Добавить(Ставки, Ставки);
		КонецЦикла;
	Иначе
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.РежимВыбораИзСписка = Ложь;
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.КнопкаСпискаВыбора = Истина;
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.КнопкаВыбора = Ложь; 	 		
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.СписокВыбора.Очистить();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеСтрокаПоискаПриИзменении(Элемент)
	
	ЭтаФорма.РеквизитСтрокаПоиска = ЭтаФорма.Элементы.ПолеСтрокаПоиска.ТекстРедактирования;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеСтрокаПоискаНачалоВыбораИзСписка(Элемент, СтандартнаяОбработка)
	
	Если ЭтаФорма.РеквизитРеквизитПоиска <> ЭтаФорма.Элементы.ПолеРеквизитПоиска.СписокВыбора[4].Значение Тогда	
		ЭтаФорма.Элементы.ПолеСтрокаПоиска.СписокВыбора.Очистить();
		Для Каждого Значение Из ЭтаФорма.СписокЗначенийПоиска Цикл
			ЭтаФорма.Элементы.ПолеСтрокаПоиска.СписокВыбора.Добавить(Значение, Значение);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

 #Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СохранитьНастройкиФормыПоиска()
	
	СтруктураНастроекФормы = Новый Структура;
	СтруктураНастроекФормы.Вставить("СписокЗначенийПоиска", ЭтаФорма.СписокЗначенийПоиска);
	
	ХранилищеНастроекДанныхФорм.Сохранить("ОбщаяФормаПоискаПодбора", "СтруктураНастроек", СтруктураНастроекФормы);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНастройкиФормы()
	
	СтруктураНастроек = ПолучитьЗначениеНастроекФормы();
	
	Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	// Установим сохраненные значения
	Если СтруктураНастроек.Свойство("СписокЗначенийПоиска") Тогда
		ЭтаФорма.СписокЗначенийПоиска = СтруктураНастроек.СписокЗначенийПоиска;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЗначениеНастроекФормы()
	
	Результат = ХранилищеНастроекДанныхФорм.Загрузить("ОбщаяФормаПоискаПодбора", "СтруктураНастроек");
	
	Возврат Результат;
	
КонецФункции                               

 #КонецОбласти

