	ОбработатьТЧЗапасыПослеЗаполненияУчетныхДанных();

КонецПроцедуры

&НаСервере
// Процедура заполняет табличную часть "Запасы" учетными данными.
// 
Процедура ЗаполнитьТолькоУчетныеДанные(ПоУпаковкам)

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаЗатраты.Номенклатура КАК Номенклатура,
	|	ТаблицаЗатраты.Партия КАК Партия,
	|	ТаблицаЗатраты.Упаковка КАК Упаковка,
	|	ТаблицаЗатраты.Коэффициент КАК Коэффициент,
	|	ТаблицаЗатраты.Количество КАК Количество,
	|	ТаблицаЗатраты.Цена КАК Цена,                                             
	|	ТаблицаЗатраты.КоличествоУпаковок КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ИнвентаризацияЗапасов
	|ИЗ
	|	&ТаблицаЗатраты КАК ТаблицаЗатраты";
	
	
	ТЗ =  Объект.Запасы.Выгрузить();
	ТЗ.Колонки.Добавить("Коэффициент", Новый ОписаниеТипов("Число",, Новый КвалификаторыЧисла(10,3)));
	
	Для каждого СтрокаДанных из ТЗ Цикл
		СтрокаДанных.Коэффициент = СтрокаДанных.Упаковка.Коэффициент;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ТаблицаЗатраты", ТЗ);
	
	Запрос.Выполнить(); 	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ИнвентаризацияЗапасовЗапасы.Номенклатура,
	|	ИнвентаризацияЗапасовЗапасы.Партия,
	|	ИнвентаризацияЗапасовЗапасы.Упаковка,
	|	ИнвентаризацияЗапасовЗапасы.Коэффициент,
	|	ИнвентаризацияЗапасовЗапасы.Количество,
	|	ИнвентаризацияЗапасовЗапасы.Цена,
	|	ИнвентаризацияЗапасовЗапасы.КоличествоУпаковок,
	|	ВложенныйЗапрос.КоличествоПоДаннымУчета,
	|	ВЫБОР
	|		КОГДА ИнвентаризацияЗапасовЗапасы.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ВложенныйЗапрос.КоличествоПоДаннымУчета
	|		ИНАЧЕ ВложенныйЗапрос.КоличествоПоДаннымУчета / ЕСТЬNULL(ИнвентаризацияЗапасовЗапасы.Коэффициент, 1)
	|	КОНЕЦ КАК КоличествоУпаковокПоДаннымУчета,
	|	ВЫБОР
	|		КОГДА ИнвентаризацияЗапасовЗапасы.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ВложенныйЗапрос.КоличествоПоДаннымУчета
	|		ИНАЧЕ ВложенныйЗапрос.КоличествоПоДаннымУчета / ЕСТЬNULL(ИнвентаризацияЗапасовЗапасы.Коэффициент, 1)
	|	КОНЕЦ КАК КоличествоВБазовыхЕИ
	|ИЗ
	|	ИнвентаризацияЗапасов КАК ИнвентаризацияЗапасовЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапасыОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыОстатки.Партия КАК Партия,
	|			СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоПоДаннымУчета
	|		ИЗ
	|			РегистрНакопления.ЗапасыНаСкладах.Остатки(
	|					&ДатаСреза,
	|					СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						И Склад = &Склад) КАК ЗапасыОстатки
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗапасыОстатки.Партия,
	|			ЗапасыОстатки.Номенклатура) КАК ВложенныйЗапрос
	|		ПО ИнвентаризацияЗапасовЗапасы.Номенклатура = ВложенныйЗапрос.Номенклатура
	|			И ИнвентаризацияЗапасовЗапасы.Партия = ВложенныйЗапрос.Партия";
	
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	Запрос.УстановитьПараметр("Склад"    , Объект.Склад);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"    , Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза", ПолучитьДатуОстатков(ТекОбъект)); 
	
	Объект.Запасы.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Если ПоУпаковкам Тогда
		
		Для Каждого СтрокаТЧ из Объект.Запасы Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура.УпаковкаПоУмолчанию) и не ЗначениеЗаполнено(СтрокаТЧ.Упаковка) Тогда
				СтрокаТЧ.КоличествоУпаковокПоДаннымУчета = СтрокаТЧ.КоличествоУпаковокПоДаннымУчета/СтрокаТЧ.Номенклатура.УпаковкаПоУмолчанию.Коэффициент;
				СтрокаТЧ.КоличествоУпаковок = СтрокаТЧ.КоличествоУпаковок/СтрокаТЧ.Номенклатура.УпаковкаПоУмолчанию.Коэффициент;
				СтрокаТЧ.Упаковка = СтрокаТЧ.Номенклатура.УпаковкаПоУмолчанию;
			КонецЕсли;			
		КонецЦикла;
		
	КонецЕсли;

	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);

КонецПроцедуры // ЗаполнитьТолькоУчетныеДанные()

// Процедура, обработчик события "ПриИзменении" поле ввода "КоличествоУпаковок"
//
&НаКлиенте
Процедура ЗапасыКоличествоУпаковокПриИзменении(Элемент)
	
	
	СтрокаТабличнойЧасти = Элементы["Запасы"].ТекущиеДанные;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
	 	
	РассчитатьОтклонениеПоСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти);
	
	РассчитатьСуммуУчетаТабЧасти(СтрокаТабличнойЧасти);
		
КонецПроцедуры

// Процедура, рассчитывает сумму учета в табличной части "Запасы"
//  Параметры:
//   СтрокаТабличнойЧасти - текущая строка табличной части "Запасы"
//
&НаКлиенте
Процедура РассчитатьСуммуУчетаТабЧасти(СтрокаТабличнойЧасти)
		
	СтрокаТабличнойЧасти.СуммаУчет = СтрокаТабличнойЧасти.КоличествоУпаковокПоДаннымУчета * СтрокаТабличнойЧасти.Цена;
	
КонецПроцедуры

// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ОтборИнвентаризации = Новый ХранилищеЗначения(ОтборИнвентаризации.Настройки, Новый СжатиеДанных(9));
	
КонецПроцедуры

// Процедура, рассчитывает отклонение в табличной части "Запасы" при проведении инвентаризации.
//   Параметры:
//    СтрокаТабличнойЧасти - текущая строка табличной части "Запасы", для которой рассчитывается отклонение.
//
&НаКлиенте
Процедура РассчитатьОтклонениеПоСтрокеТабличнойЧасти(СтрокаТабличнойЧасти)
	
	СтрокаТабличнойЧасти.Отклонение =  СтрокаТабличнойЧасти.КоличествоУпаковок - СтрокаТабличнойЧасти.КоличествоУпаковокПоДаннымУчета;
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Цена"
//
&НаКлиенте
Процедура ЗапасыЦенаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы["Запасы"].ТекущиеДанные;
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти);
	РассчитатьСуммуУчетаТабЧасти(СтрокаТабличнойЧасти);
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Сумма"
//
&НаКлиенте
Процедура ЗапасыСуммаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы["Запасы"].ТекущиеДанные;
	ОбработкаТабличныхЧастейКлиент.ПриИзмененииСуммыВТабличнойЧасти(СтрокаТабличнойЧасти);
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Упаковка"
//
&НаКлиенте
Процедура ЗапасыУпаковкаПриИзменении(Элемент)
	
	СтруктураПараметров = Новый Структура("РасчетДопКолонки", Истина);
	
	ТекущаяСтрока = Элементы.Запасы.ТекущиеДанные;
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
	ОбработкаТабличныхЧастейКлиент.ПриИзмененииУпаковкиТабЧасти(ТекущаяСтрока, СтруктураДанные);
	Если ОбщегоНазначенияСтоматология.ВернутьКоэффициентУпаковки(ТекущаяСтрока.Упаковка) > 1 Тогда
		ТекущаяСтрока.КоличествоУпаковокПоДаннымУчета = ТекущаяСтрока.КоличествоВБазовыхЕИ;		
		ТекущаяСтрока.КоличествоУпаковокПоДаннымУчета = ТекущаяСтрока.КоличествоУпаковокПоДаннымУчета / ОбщегоНазначенияСтоматология.ВернутьКоэффициентУпаковки(ТекущаяСтрока.Упаковка);
	Иначе 
		ТекущаяСтрока.КоличествоУпаковокПоДаннымУчета = ТекущаяСтрока.КоличествоВБазовыхЕИ; 		
	КонецЕсли;	
	РассчитатьОтклонениеПоСтрокеТабличнойЧасти(ТекущаяСтрока);	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(ТекущаяСтрока);
	РассчитатьСуммуУчетаТабЧасти(ТекущаяСтрока);         
	
КонецПроцедуры

// Процедура, обработчик события "НачалоВыбора" поле ввода "Упаковка"
//
&НаКлиенте
Процедура ЗапасыУпаковкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбработкаТабличныхЧастейКлиент.ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, Элементы.Запасы.ТекущиеДанные);
	
КонецПроцедуры

// Процедура оработчик команды "Подбор"
//
&НаКлиенте
Процедура Подбор(Команда)
	
	ИмяТабличнойЧасти  = "Запасы";
	ЕстьПартии		   = Истина;
		
	ПараметрыПодбора = Новый Структура;
	
	ПараметрыПодбора.Вставить("Период",				   Объект.Дата);
	ПараметрыПодбора.Вставить("Склад",	   			   Объект.Склад);
	ПараметрыПодбора.Вставить("СтруктурнаяЕдиница",	   Объект.СтруктурнаяЕдиница);
	ПараметрыПодбора.Вставить("ВидЦен",	   			   Объект.ВидЦен);
	ПараметрыПодбора.Вставить("ИспользуетсяСодержание",Истина);

	Если Объект[ИмяТабличнойЧасти].Количество() > 0 Тогда
		АдресЗапасовВХранилище = ПоместитьЗапасыВХранилище(ИмяТабличнойЧасти, ЕстьПартии);
		ПараметрыПодбора.Вставить("АдресЗапасовДокумента", АдресЗапасовВХранилище);
	КонецЕсли; 
	
	ТипНоменклатуры = Новый СписокЗначений;
	Для каждого ЭлементМассива Из Элементы[ИмяТабличнойЧасти + "Номенклатура"].ПараметрыВыбора Цикл
		Если ЭлементМассива.Имя = "Отбор.ТипНоменклатуры" Тогда
			Если ТипЗнч(ЭлементМассива.Значение) = Тип("ФиксированныйМассив") Тогда
				Для каждого ЭлементФиксМассива Из ЭлементМассива.Значение Цикл
					ТипНоменклатуры.Добавить(ЭлементФиксМассива);
				КонецЦикла; 
			Иначе
				ТипНоменклатуры.Добавить(ЭлементМассива.Значение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ПараметрыПодбора.Вставить("ТипНоменклатуры",	   ТипНоменклатуры);
		
	СтатусПартии = Новый СписокЗначений;
	Для каждого ЭлементМассива Из Элементы[ИмяТабличнойЧасти + "Партия"].ПараметрыВыбора Цикл
		Если ЭлементМассива.Имя = "Отбор.Статус" Тогда			
			Если ТипЗнч(ЭлементМассива.Значение) = Тип("ФиксированныйМассив") Тогда
				Для каждого ЭлементФиксМассива Из ЭлементМассива.Значение Цикл
					СтатусПартии.Добавить(ЭлементФиксМассива);
				КонецЦикла; 
			Иначе
				СтатусПартии.Добавить(ЭлементМассива.Значение);
			КонецЕсли;			
		КонецЕсли;
	КонецЦикла;
	ПараметрыПодбора.Вставить("СтатусПартии",	   		СтатусПартии);

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяТабличнойЧасти", ИмяТабличнойЧасти);
	ДополнительныеПараметры.Вставить("ЕстьПартии", ЕстьПартии);

	ОткрытьФорму("ОбщаяФорма.ФормаПодбора",
	ПараметрыПодбора,,,,,
	Новый ОписаниеОповещения("ПодборЗавершение", ЭтотОбъект, ДополнительныеПараметры), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора подбора
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПодборЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
		ПолучитьЗапасыИзХранилища(РезультатВыбора, ДополнительныеПараметры.ИмяТабличнойЧасти, ДополнительныеПараметры.ЕстьПартии);
		ОбновитьЗаголовкиТабЧастейНаСервере();
	КонецЕсли; 	
	
КонецПроцедуры

&НаСервере
// Функция получает список товаров из временного хранилища
//
Процедура ПолучитьЗапасыИзХранилища(АдресЗапасовВХранилище, ИмяТабличнойЧасти, ЕстьПартии)
	
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресЗапасовВХранилище);
	
	Для каждого СтрокаЗагрузки Из ТаблицаДляЗагрузки Цикл
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура", СтрокаЗагрузки.Номенклатура);
		СтруктураОтбора.Вставить("Упаковка", СтрокаЗагрузки.Упаковка);
		Если ЕстьПартии Тогда
			СтруктураОтбора.Вставить("Партия", СтрокаЗагрузки.Партия);
		КонецЕсли;
		
		Строки = Объект[ИмяТабличнойЧасти].НайтиСтроки(СтруктураОтбора);
		Если Строки.Количество() > 0 Тогда
			
			СтрокаТабличнойЧасти = Строки[0]; 
		Иначе
			СтрокаТабличнойЧасти = Объект[ИмяТабличнойЧасти].Добавить();
		КонецЕсли;
				
	    СтрокаТабличнойЧасти.Номенклатура =  СтрокаЗагрузки.Номенклатура;
		СтрокаТабличнойЧасти.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "ИспользоватьПартии");
		СтрокаТабличнойЧасти.ЭтоСертификат = (ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"));
		СтрокаТабличнойЧасти.Партия = СтрокаЗагрузки.Партия;
		// СтрокаТабличнойЧасти.КоличествоУпаковок =  СтрокаЗагрузки.Количество;
		// СтрокаТабличнойЧасти.Количество = СтрокаЗагрузки.Количество * ?(СтрокаТабличнойЧасти.Упаковка.Пустая() = Ложь, СтрокаТабличнойЧасти.Упаковка.Коэффициент, 1);
		СтрокаТабличнойЧасти.КоличествоУпаковок =  СтрокаЗагрузки.КоличествоУпаковок;
		СтрокаТабличнойЧасти.Количество = СтрокаЗагрузки.Количество;
		СтрокаТабличнойЧасти.Цена = СтрокаЗагрузки.Цена;
		СтрокаТабличнойЧасти.Упаковка = СтрокаЗагрузки.Упаковка;		
		СтрокаТабличнойЧасти.Сумма 		= СтрокаЗагрузки.Сумма;
		СтрокаТабличнойЧасти.Отклонение =  СтрокаТабличнойЧасти.КоличествоУпаковок - СтрокаТабличнойЧасти.КоличествоУпаковокПоДаннымУчета;
		
	КонецЦикла;
	
КонецПроцедуры // ПолучитьЗапасыИзХранилища()

&НаКлиенте
// Процедура, обработчик команды "СкрытьПодбор"
// 
Процедура СкрытьПодбор(Команда)
	
	СкрытьПодборНаСервере();
	Если Элементы.ГруппаПодборНоменклатура.Видимость Тогда
		Элементы._ПодборНоменклатур.Обновить();         
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция помещает список запасов во временное хранилище и возвращает адрес 
//
Функция ПоместитьЗапасыВХранилище(ИмяТабличнойЧасти, ЕстьПартии) 
	
	СписокКолонок = "Номенклатура, Количество, КоличествоУпаковок, Цена, Сумма, Упаковка";
	Если ЕстьПартии Тогда
		СписокКолонок = СписокКолонок + ", Партия";
	КонецЕсли;
	
	Возврат ПоместитьВоВременноеХранилище(Объект[ИмяТабличнойЧасти].Выгрузить(, СписокКолонок), УникальныйИдентификатор);
	
КонецФункции // ПоместитьЗапасыВХранилище()

&НаКлиенте
// Процедура обработчик команды вызывает форму настройки и редактирования цен.
//
Процедура РедактироватьЦены(Команда)
	
	// 1. Формируем структуру параметров для заполнения формы "Цены и Валюта".
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ВидЦен", 	  			Объект.ВидЦен);
	СтруктураПараметров.Вставить("ПерезаполнитьЦены",	Ложь);
	
	// 2. Открвыаем форму "Цены и Валюта".
	ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,,Новый ОписаниеОповещения("РедактироватьЦеныЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "РедактироватьЦеныЗавершение"
//
Процедура РедактироватьЦеныЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	// 3. Перезаполняем табличную часть "Запасы" если были внесены изменения в форме "Цены и Валюта".
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.БылиВнесеныИзменения Тогда
		
		Объект.ВидЦен = Результат.ВидЦен;
		
		// Пересчитываем цены по виду цен.					
		Если Результат.ПерезаполнитьЦены Тогда
			ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы");
			
			Для Каждого СтрокаЗапасы Из Объект.Запасы Цикл
				
				РассчитатьСуммуУчетаТабЧасти(СтрокаЗапасы);	
				
			КонецЦикла;	
			
		КонецЕсли;

	КонецЕсли;
	
