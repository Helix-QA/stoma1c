
#Область ОписаниеПеременных

&НаКлиенте
Перем ВнесеноПередРедактированием;
&НаКлиенте
Перем ТекДокументСписка;    

#КонецОбласти

#Область ОБРАБОТЧИКИ_СОБЫТИЙ_ФОРМЫ

&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("МассивДокументов") Тогда
		Если Параметры.МассивДокументов.Количество() > 0 Тогда
			Если Параметры.МассивДокументов.Количество() > 1 Тогда
				Контрагент = Параметры.МассивДокументов[0].Контрагент;
				СтруктурнаяЕдиница = Параметры.МассивДокументов[0].СтруктурнаяЕдиница;
			ИначеЕсли Параметры.МассивДокументов.Количество() = 1 Тогда
				Контрагент = Параметры.МассивДокументов[0].Контрагент;
				СтруктурнаяЕдиница = Параметры.МассивДокументов[0].СтруктурнаяЕдиница;
			КонецЕсли;
			ЗаполнитьТаблицуВходящихДокументов(Параметры.МассивДокументов);
		КонецЕсли;
	КонецЕсли; 
	
	Параметры.Свойство("ПечатьСправки", ПечатьСправки);
	Элементы.ГруппаГод.Видимость = ПечатьСправки;
	
	Год = Год(ТекущаяДата());
	
	ЭтотОбъект.ОткрытДокумент = Ложь;
	ПодготовкаТаблицуЗадолженностей(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОбработкаОповещения"
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА"
		И ЭтотОбъект.ОткрытДокумент Тогда
		
		ПодготовкаТаблицуЗадолженностей(Истина);
		ЭтотОбъект.ОткрытДокумент = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовФормы
   
&НаКлиенте
// При изменении выбора контрагента
//
Процедура КонтрагентПриИзменении(Элемент)
	
	ОбновитьФормуСервер(Ложь);
	
КонецПроцедуры 

&НаКлиенте 
// Обработчик события "ГодПриИзменении".
//
Процедура ГодПриИзменении(Элемент)  
	
	ОбновитьФормуСервер(Ложь); 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыТаблицаЗадолженностей

&НаКлиенте
// При изменении выбора состояния галочки флажков
//
Процедура ТаблицаЗадолженностейУстановитьСнятьГалочки(Команда)
	
	// Изменение картинки кнопки
	Если Элементы.ТаблицаДокументовПродажиТаблицаЗадолженностейУстановитьСнятьГалочки.Картинка = БиблиотекаКартинок.МножественныйВыбор Тогда		
		ПризнакВыбора = Ложь;
		Элементы.ТаблицаДокументовПродажиТаблицаЗадолженностейУстановитьСнятьГалочки.Картинка = БиблиотекаКартинок.МножественныйВыборВыбрано;
	Иначе
		ПризнакВыбора = Истина;
		Элементы.ТаблицаДокументовПродажиТаблицаЗадолженностейУстановитьСнятьГалочки.Картинка = БиблиотекаКартинок.МножественныйВыбор;
	КонецЕсли;	
	// Установка состояния флажков
	Для Каждого СтрокаТЧ ИЗ ТаблицаЗадолженностей Цикл		
		СтрокаТЧ.ПризнакВыбора = ПризнакВыбора;
	КонецЦикла;	 
	
    Итоги = ВернутьОбщуюСуммуВыбраных();
	ТаблицаЗадолженностейСуммаОснований      = Итоги.ОбщаяСумма;  
	ТаблицаЗадолженностейСуммаЗадолженностей = Итоги.СуммаОплачено;
	
КонецПроцедуры

&НаКлиенте
// Обработчик вызова обновления таблицы задолженностей
//
Процедура ТаблицаЗадолженностейОбновить(Команда)	
	
	ОбновитьФормуСервер(Ложь);

КонецПроцедуры

&НаКлиенте
// Обработчик открытия документа задолженности из таблицы
//
Процедура ТаблицаЗадолженностейОткрытьДокумент(Команда)
	
	ТекущиеДанные = Элементы.ТаблицаДокументовПродажи.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		ЭтотОбъект.ОткрытДокумент = Истина;
		
		ТаблицаВходящихДокументов.Очистить();
		// Запомним галочки для обновления
		Для Каждого СтрокаТЗ Из ТаблицаЗадолженностей Цикл
			
			Если СтрокаТЗ.ПризнакВыбора Тогда
				НоваяСтрока 	  = ТаблицаВходящихДокументов.Добавить();
				НоваяСтрока.Прием = СтрокаТЗ.ДокументРеализации;
			КонецЕсли;
			
		КонецЦикла;
		
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ТекущиеДанные.ДокументРеализации));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик выбора значения в таблице задолженностей
//
Процедура ТаблицаДокументовПродажиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаДокументовПродажи.ТекущиеДанные;
	Если Поле = Элементы.ТаблицаДокументовПродажиДокументОснования И НЕ ТекущиеДанные = Неопределено Тогда
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ТекущиеДанные.ДокументРеализации));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик активации строки
//
Процедура ТаблицаДокументовПродажиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаДокументовПродажи.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено И НЕ ТекДокументСписка = ТекущиеДанные.ДокументРеализации  Тогда		
		ТекДокументСписка = ТекущиеДанные.ДокументРеализации;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// При изменении признака выбора оплачиваемого документа
//
Процедура ТаблицаДокументовПродажиПризнакВыбораПриИзменении(Элемент)	
	
	ТекущиеДанные = Элементы.ТаблицаДокументовПродажи.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда		
		Итоги = ВернутьОбщуюСуммуВыбраных();
		
		ТаблицаЗадолженностейСуммаОснований      = Итоги.ОбщаяСумма;  
		ТаблицаЗадолженностейСуммаЗадолженностей = Итоги.СуммаОплачено;		
	КонецЕсли;		
	
КонецПроцедуры

&НаСервере
// Процедура подготовки таблицы задолженностей
//
Процедура ПодготовкаТаблицуЗадолженностей(ПриСтарте)
	
	ТаблицаЗадолженностей.Очистить();
	ТаблицаЗадолженностейСумма = 0;
	
	// Если таблица доступна для пользователя подгружаем все документы задолженностей
	Если ТаблицаЗадолженностейВидимость Тогда
		Элементы.ТаблицаДокументовПродажиТаблицаЗадолженностейУстановитьСнятьГалочки.Картинка = БиблиотекаКартинок.СнятьФлажки;
	КонецЕсли;
	
	// Если контрагент указан - разрешено загрузить документы задолженностей
	Если ЗначениеЗаполнено(Контрагент) Тогда
		// Получаем таблицу задолженностей
		РезЗапроса = ПолучитьСписокПриемов(Контрагент, СтруктурнаяЕдиница);
		ТаблицаЗадолженностей.Очистить();
		
		Для Каждого СтрокаТ ИЗ РезЗапроса Цикл
			
			НоваяСтрока = ТаблицаЗадолженностей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТ);
			
			Если ПриСтарте Тогда
				
				Для Каждого Документ Из ТаблицаВходящихДокументов Цикл
					Если НоваяСтрока.ДокументРеализации = Документ.Прием Тогда
						НоваяСтрока.ПризнакВыбора = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Сумма по всем задолженностям   
	Итоги = ВернутьОбщуюСуммуВыбраных();
	ТаблицаЗадолженностейСуммаОснований      = Итоги.ОбщаяСумма;  
	ТаблицаЗадолженностейСуммаЗадолженностей = Итоги.СуммаОплачено;
	
	ТаблицаЗадолженностей.Сортировать("ДатаПриема");
	
КонецПроцедуры

&НаСервере
//
//
Функция ВернутьОбщуюСуммуВыбраных()
	
	ОбщаяСумма    = 0;
	СуммаОплачено = 0;
	
	Для Каждого Документ Из ТаблицаЗадолженностей Цикл 
		Если Документ.ПризнакВыбора Тогда 
			ОбщаяСумма    = ОбщаяСумма + Документ.СуммаДокумента; 
			СуммаОплачено = СуммаОплачено + Документ.Оплачено; 
		КонецЕсли;		
	КонецЦикла;	
	
	Элементы.Напечатать.Доступность = ОбщаяСумма > 0;
	
	СтруктураИтогов = Новый Структура("ОбщаяСумма, СуммаОплачено", ОбщаяСумма, СуммаОплачено); 
	Возврат СтруктураИтогов;
	
КонецФункции

&НаСервере
// Функция - Получить список приемов
//
// Параметры:
//  Контрагент			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокПриемов(Контрагент, СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Ссылка КАК ДокументРеализации,
	|	Прием.Номер КАК НомерПриема,
	|	Прием.Дата КАК ДатаПриема,
	|	Прием.ВремяНачалаПриема КАК ВремяНачала,
	|	Прием.ВремяОкончанияПриема КАК ВремяОкончания,
	|	Прием.Контрагент КАК Клиент,
	|	Прием.ПолисМедСтрахования КАК ПолисМедСтрахования,
	|	Прием.СуммаДокумента КАК СуммаДокумента,
	|	Прием.СуммаОплачено КАК Оплачено,
	|	Прием.Сотрудник КАК Врач,
	|	Прием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.НомерСтроки = ВложенныйЗапрос.КодУслугиЗаполнен
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК КодУслугиЗаполнен
	|ИЗ
	|	Документ.Прием КАК Прием
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПриемЛечение.Ссылка КАК ПриемСсылка,
	|			МАКСИМУМ(ПриемЛечение.НомерСтроки) КАК НомерСтроки,
	|			СУММА(ВЫБОР
	|					КОГДА ПриемЛечение.КодУслуги = 1
	|							ИЛИ ПриемЛечение.КодУслуги = 2
	|						ТОГДА 1
	|					ИНАЧЕ ВЫБОР
	|							КОГДА ПриемЛечение.Номенклатура.КодУслуги = 1
	|									ИЛИ ПриемЛечение.Номенклатура.КодУслуги = 2
	|								ТОГДА 1
	|							ИНАЧЕ 0
	|						КОНЕЦ
	|				КОНЕЦ) КАК КодУслугиЗаполнен
	|		ИЗ
	|			Документ.Прием.Лечение КАК ПриемЛечение
	|		ГДЕ
	|			ПриемЛечение.Ссылка.Контрагент = &Контрагент
	|			И ПриемЛечение.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			И НЕ ПриемЛечение.Ссылка.Долговой
	|			И ПриемЛечение.Ссылка.Проведен = ИСТИНА
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ПриемЛечение.Ссылка) КАК ВложенныйЗапрос
	|		ПО Прием.Ссылка = ВложенныйЗапрос.ПриемСсылка
	|ГДЕ
	|	Прием.Контрагент = &Контрагент
	|	И Прием.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НЕ Прием.Долговой
	|	И НЕ Прием.Ссылка В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					СправкаВНалоговуюПриемы.Прием
	|				ИЗ
	|					Документ.СправкаВНалоговую.Приемы КАК СправкаВНалоговуюПриемы
	|				ГДЕ
	|					СправкаВНалоговуюПриемы.Ссылка.Пациент = &Контрагент
	|					И СправкаВНалоговуюПриемы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					И НЕ СправкаВНалоговуюПриемы.Ссылка.ПометкаУдаления)
	|	И Прием.СуммаОплачено <> 0
	|	И Прием.Проведен = ИСТИНА
	|	И ВЫБОР
	|			КОГДА &ПечатьСправки
	|				ТОГДА Прием.ПолисМедСтрахования = ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И &ОтборДокументовПоГоду
	|	И НЕ Прием.Ссылка В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					ВозвратОтПокупателя.ДокументОснования КАК ДокументОснования
	|				ИЗ
	|					Документ.ВозвратОтПокупателя КАК ВозвратОтПокупателя
	|				ГДЕ
	|					НЕ ВозвратОтПокупателя.ПометкаУдаления
	|					И ВозвратОтПокупателя.Проведен
	|					И ВозвратОтПокупателя.ДокументОснования ССЫЛКА Документ.Прием
	|					И ВозвратОтПокупателя.Контрагент = &Контрагент
	|					И ВозвратОтПокупателя.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|
	|СГРУППИРОВАТЬ ПО
	|	Прием.Ссылка,
	|	Прием.Номер,
	|	Прием.Дата,
	|	Прием.ВремяНачалаПриема,
	|	Прием.ВремяОкончанияПриема,
	|	Прием.Контрагент,
	|	Прием.ПолисМедСтрахования,
	|	Прием.СуммаДокумента,
	|	Прием.СуммаОплачено,
	|	Прием.Сотрудник,
	|	Прием.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.НомерСтроки = ВложенныйЗапрос.КодУслугиЗаполнен
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(ВложенныйЗапрос.НомерСтроки) > 0");
	
	Запрос.УстановитьПараметр("Контрагент"		  , Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ПечатьСправки"     , ПечатьСправки);
	
	ТекстЗамены = "	И Прием.Ссылка В
	|			(ВЫБРАТЬ
	|				ВложенныйЗапрос.ДокументОснования КАК ДокументОснования
	|				ИЗ
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования КАК ДокументОснования
	|						ИЗ
	|							Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
	|						ГДЕ
	|							ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
	|							И ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент = &Контрагент
	|							И ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|							И ГОД(ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата) = &Год
	|
	|						ОБЪЕДИНИТЬ ВСЕ
	|
	|					ВЫБРАТЬ
	|						СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования
	|					ИЗ
	|						Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|					ГДЕ
	|						СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Проведен
	|						И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент = &Контрагент
	|						И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						И ГОД(СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата) = &Год
	|						И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
	|						И (СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)
	|							ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат))
	|
	|						ОБЪЕДИНИТЬ ВСЕ
	|
	|					ВЫБРАТЬ
	|						ПриемУчтенныеАвансы.Ссылка
	|					ИЗ
	|						Документ.Прием.УчтенныеАвансы КАК ПриемУчтенныеАвансы
	|					ГДЕ
	|						ПриемУчтенныеАвансы.Ссылка.Проведен
	|						И ПриемУчтенныеАвансы.Ссылка.Контрагент = &Контрагент
	|						И ПриемУчтенныеАвансы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						И ПриемУчтенныеАвансы.СуммаАванса <> 0
	|						И ГОД(ПриемУчтенныеАвансы.Ссылка.Дата) = &Год) КАК ВложенныйЗапрос
	|				ГДЕ
	|					ВложенныйЗапрос.ДокументОснования ССЫЛКА Документ.Прием)";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ОтборДокументовПоГоду", ?(ПечатьСправки, ТекстЗамены, "")); 
	
	Если ПечатьСправки Тогда  
		Запрос.УстановитьПараметр("Год", Год);
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаКлиенте
// Обработчик команды печати справки
//
Процедура РаспечататьСправкуВНалоговую(Команда)
	
	КодыЗаполнены = Истина;
	МассивПриемов = Новый Массив;
	ОчиститьСообщения();
	
	Для Каждого Документ Из ТаблицаЗадолженностей Цикл
		
		Если Документ.ПризнакВыбора 
			И Документ.СуммаДокумента <> 0 Тогда
			
			Если НЕ Документ.КодУслугиЗаполнен Тогда
				КодыЗаполнены = Ложь;
				// Сообщить("Не заполнен код услуги в " + Документ.ДокументРеализации);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В номенклатуре не задан код");
			КонецЕсли;
			МассивПриемов.Добавить(Документ.ДокументРеализации);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если КодыЗаполнены Тогда
		ЭтаФорма.Закрыть(МассивПриемов);
	КонецЕсли;
	
КонецПроцедуры  

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

  &НаСервере
// Реинициализация формы, сброс всех выбранных параметров
//
Процедура ЗаполнитьТаблицуВходящихДокументов(МассивДокументов)
	
	ТаблицаВходящихДокументов.Очистить();
	Для Каждого ЭлементМассива Из МассивДокументов Цикл
		НоваяСтрока = ТаблицаВходящихДокументов.Добавить();
		НоваяСтрока.Прием = ЭлементМассива;
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
// Реинициализация формы, сброс всех выбранных параметров
//
Процедура ОбновитьФормуСервер(ПриСтарте)
	
	ПодготовкаТаблицуЗадолженностей(ПриСтарте);	
	
КонецПроцедуры

