// Обработчик начала выбора номенклатуры
//
Процедура ЗапасыНоменклатураНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка   = Ложь;	
	СтруктураПараметры     = Новый Структура();	
	МассивРазрешенныхТипов = Новый Массив;
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Запас"));
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"));
	
	СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов"          , МассивРазрешенныхТипов); 
	СтруктураПараметры.Вставить("Заголовок"                            , "Выберите товар");	  
	СтруктураПараметры.Вставить("СтруктурнаяЕдиница"                   , Объект.СтруктурнаяЕдиница);   
	СтруктураПараметры.Вставить("Дата"                                 , Объект.Дата);
	СтруктураПараметры.Вставить("БуферВыбранныхЗначенийИспользовать"   , Ложь);

	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеОткрытияФормыПодбораНоменклатурыПриНачалеВыбора", ЭтотОбъект);
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры", СтруктураПараметры,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца)

КонецПроцедуры 

&НаКлиенте 
Процедура ПослеОткрытияФормыПодбораНоменклатурыПриНачалеВыбора(Результат, ДополнительныеПараметры) Экспорт

	Если ЗначениеЗаполнено(Результат) Тогда		
		Элементы.ТаблицаТовары.ТекущиеДанные.Номенклатура = Результат.Номенклатура;
		ЗапасыНоменклатураПриИзменении(Неопределено,Ложь);		
	КонецЕсли;	
	
КонецПроцедуры	
	
&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ЗапасыНоменклатураПриИзменении(Элемент, ПересчетТЧПослеизменения = Ложь)	
	
	СтрокаТабличнойЧасти = Элементы.ТаблицаТовары.ТекущиеДанные;
	
	// Проверка на статус "в продаже".
	ВПродаже = ПолучитьСтатусНоменклатуры(СтрокаТабличнойЧасти.Номенклатура, Объект.СтруктурнаяЕдиница, Объект.Дата);
	Если НЕ ВПродаже Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Номенклатура %1 снята с продаж!"), СтрокаТабличнойЧасти.Номенклатура);
		СтрокаТабличнойЧасти.Номенклатура = Неопределено;
		Возврат;
		
	КонецЕсли;	
	
	Если ПроверитьПрименениеВидовНалогов(СтрокаТабличнойЧасти.Номенклатура) Тогда
		СтрокаТабличнойЧасти.Номенклатура = Неопределено;
		Возврат;
	КонецЕсли;
	ЗапасыНоменклатураПриИзмененииСервер(СтрокаТабличнойЧасти.ПолучитьИдентификатор(), ПересчетТЧПослеизменения);

КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриИзменении"
//
Процедура ЗапасыНоменклатураПриИзмененииСервер(ИдентификаторСтрокиТЧ, ПересчетТЧПослеизменения = Ложь)
	
	СтрокаТабличнойЧасти = Объект.Запасы.НайтиПоИдентификатору(ИдентификаторСтрокиТЧ);
					
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
	СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
	СтруктураДанные.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);	
	СтруктураДанные                      = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);	
	СтрокаТабличнойЧасти.Цена            = СтруктураДанные.Цена;
	СтрокаТабличнойЧасти.ВидЦен          = Объект.ВидЦен;   
	
	СтруктураДанныеНоменклатура          = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаТабличнойЧасти.Номенклатура, "УпаковкаПоУмолчанию, СкидкиЗапрещены"); 
	СтрокаТабличнойЧасти.Упаковка        = СтруктураДанныеНоменклатура.УпаковкаПоУмолчанию;
	СтрокаТабличнойЧасти.СкидкиЗапрещены = СтруктураДанныеНоменклатура.СкидкиЗапрещены;
	// Устанвока количества
	Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.КоличествоУпаковок) Тогда
		СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
	КонецЕсли;
	// Сброс процента строки 
	Если СтрокаТабличнойЧасти.СкидкиЗапрещены Тогда
		СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
		СтрокаТабличнойЧасти.СуммаРучнойСкидки = 0;
	КонецЕсли;
    // Установка вида цены
	СтрокаТабличнойЧасти.ВидЦен = Объект.ВидЦен;
    // Установка НДС
	Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
		СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС
	КонецЕсли;	
	// Пересчет табличной части
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);		
	Если ПересчетТЧПослеизменения Тогда
		ТабличныеЧастиПересчетПослеИзменений("Запасы", ИдентификаторСтрокиТЧ);
    КонецЕсли;
		
КонецПроцедуры

