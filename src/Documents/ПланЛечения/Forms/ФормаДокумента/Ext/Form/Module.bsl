// Процедура - Сотрудник при изменении завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СотрудникПриИзмененииПродолжение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ЭтоСтоматологическиеУслугиПред = ДополнительныеПараметры.ЭтоСтоматологическиеУслугиПред;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Объект.Лечение.Очистить();
	Иначе
		// Отмена выбора сотрудника
		Объект.Сотрудник                  = СотрудникПред;
		ЭтоСтоматологическиеУслуги = ЭтоСтоматологическиеУслугиПред;
		Возврат;
	КонецЕсли; 
	
	СотрудникПриИзмененииСервер();
	СотрудникПред = Объект.Сотрудник;  
	
КонецПроцедуры

