		СтруктураЗаполнения = Новый Структура("ПроцентСкидки, МаксимальнаяРучнаяСкидка", ПроцентСкидки, ЭтотОбъект.МаксимальнаяРучнаяСкидка);  
		Описание            = Новый ОписаниеОповещения("ПослеОткрытияФормыУстановкиРучнойСкидкиТаблицыТовары", ЭтаФорма);
		ОткрытьФорму("ОбщаяФорма.ФормаУстановкиРучнойСкидки", СтруктураЗаполнения,,,,, Описание, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура ЗапасыПартияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СтрокаТабличнойЧасти = Элементы.ТаблицаТовары.ТекущиеДанные;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
		
		мПараметрыВыбора = Новый Структура;
		мПараметрыВыбора.Вставить("Владелец"          , СтрокаТабличнойЧасти.Номенклатура);
		мПараметрыВыбора.Вставить("Склад"             , Объект.Склад);
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		мПараметрыВыбора.Вставить("Дата"              , Объект.Дата);
        мПараметрыВыбора.Вставить("МножественныйВыбор", Истина);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗапасыПартияНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти)); 
		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", мПараметрыВыбора,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Запасы партия начало выбора завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЗапасыПартияНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	СтрокаТабличнойЧасти = ДополнительныеПараметры.СтрокаТабличнойЧасти;
	
	Если Результат <> Неопределено и Результат.Количество() <> 0 Тогда
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Партия", Результат[0]);
		НайденныеСтроки = Объект.Запасы.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтроки.Количество() > 0 Тогда		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Серийный номер уже был указан в документе!");		
		Иначе	
			СтрокаТабличнойЧасти.Партия = Результат[0];
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область РаботаСНаправлениямиКВрачам

&НаСервере
// Процедура обновляет список направлений созданных на основании данного приема
//
Процедура ОбновитьСписокНаправленийНаКонсультацию()     
	
    Запрос = Новый Запрос( 
    "ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |	Специализации.Ссылка КАК Ссылка,
    |	Специализации.ИмяПредопределенныхДанных КАК Имя
    |ИЗ
    |	Справочник.Специализации КАК Специализации
    |ГДЕ
    |	Специализации.Предопределенный
    |	И Специализации.ИмяПредопределенныхДанных <> ""Стоматология""
    |
    |УПОРЯДОЧИТЬ ПО
    |	Специализации.Наименование
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |	ПрофосмотрыСрезПоследних.Сотрудник КАК Сотрудник,
    |	ПрофосмотрыСрезПоследних.Период КАК Период,
    |	ПрофосмотрыСрезПоследних.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
    |	ПрофосмотрыСрезПоследних.Статус КАК Статус,
    |	ПрофосмотрыСрезПоследних.ПричинаНаправления КАК ПричинаНаправления,
    |	ПрофосмотрыСрезПоследних.ДатаЗапланированная КАК ДатаЗапланированная,
    |	ПрофосмотрыСрезПоследних.Специализация КАК Специализация,
    |	ПрофосмотрыСрезПоследних.Комментарий КАК Комментарий,
    |	ПрофосмотрыСрезПоследних.ВидОсмотра КАК ВидОсмотра,
    |	ПрофосмотрыСрезПоследних.АвторЗаписи КАК АвторЗаписи,
    |	ВЫБОР
    |		КОГДА ПрофосмотрыСрезПоследних.Сотрудник.НаименованиеСокращенное = """"
    |			ТОГДА ПрофосмотрыСрезПоследних.Сотрудник.Наименование
    |		ИНАЧЕ ПрофосмотрыСрезПоследних.Сотрудник.НаименованиеСокращенное
    |	КОНЕЦ КАК ФИОВрача,
    |	ВЫБОР
    |		КОГДА ПрофосмотрыСрезПоследних.Специализация = ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
    |			ТОГДА ЛОЖЬ
    |		ИНАЧЕ ИСТИНА
    |	КОНЕЦ КАК НаправленКСпециалисту,
    |	ПрофосмотрыСрезПоследних.ПредварительнаяЗапись.Комментарий КАК ПЗКомментарий,
    |	ПрофосмотрыСрезПоследних.ПредварительнаяЗапись.Дата КАК ПЗДатаСоздания,
    |	ПрофосмотрыСрезПоследних.Длительность КАК Длительность
    |ИЗ
    |	РегистрСведений.Профосмотры.СрезПоследних(
    |			,
    |			Прием = &Прием
    |				И (ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.ПрофОсмотр)
    |					ИЛИ ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.ПовторныйПрием))) КАК ПрофосмотрыСрезПоследних
    |
    |УПОРЯДОЧИТЬ ПО
    |	ПрофосмотрыСрезПоследних.Период
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |	Профосмотры.Период КАК Период,
    |	Профосмотры.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
    |	Профосмотры.Контрагент КАК Контрагент,
    |	Профосмотры.Сотрудник КАК Сотрудник,
    |	Профосмотры.ВидОсмотра КАК ВидОсмотра,
    |	Профосмотры.ДатаЗапланированная КАК ДатаЗапланированная,
    |	Профосмотры.Статус КАК Статус,
    |	Профосмотры.Сделка КАК Сделка,
    |	Профосмотры.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
    |	Профосмотры.НаправившийВрач КАК НаправившийВрач,
    |	Профосмотры.АвторЗаписи КАК АвторЗаписи,
    |	Профосмотры.ПричинаНаправления КАК ПричинаНаправления,
    |	Профосмотры.ПричинаПереноса КАК ПричинаПереноса,
    |	Профосмотры.Комментарий КАК Комментарий,
    |	Профосмотры.Длительность КАК Длительность,
    |	Профосмотры.Специализация КАК Специализация,
    |	ВЫБОР
    |		КОГДА Профосмотры.Специализация = ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
    |			ТОГДА ЛОЖЬ
    |		ИНАЧЕ ИСТИНА
    |	КОНЕЦ КАК НаправленКСпециалисту,
    |	Профосмотры.ПредварительнаяЗапись.Дата КАК ПЗДатаСоздания,
    |	Профосмотры.ПредварительнаяЗапись.Комментарий КАК ПЗКомментарий
    |ПОМЕСТИТЬ ВТВсеЗаписиПоПриему
    |ИЗ
    |	РегистрСведений.Профосмотры КАК Профосмотры
    |ГДЕ
    |	Профосмотры.Прием = &Прием
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |	ВТВсеЗаписиПоПриему.Период КАК Период,
    |	ВТВсеЗаписиПоПриему.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
    |	ВТВсеЗаписиПоПриему.Контрагент КАК Контрагент,
    |	ВТВсеЗаписиПоПриему.Сотрудник КАК Сотрудник,
    |	ВТВсеЗаписиПоПриему.ВидОсмотра КАК ВидОсмотра,
    |	ВТВсеЗаписиПоПриему.ДатаЗапланированная КАК ДатаЗапланированная,
    |	ВТВсеЗаписиПоПриему.Статус КАК Статус,
    |	ВТВсеЗаписиПоПриему.Сделка КАК Сделка,
    |	ВТВсеЗаписиПоПриему.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
    |	ВТВсеЗаписиПоПриему.НаправившийВрач КАК НаправившийВрач,
    |	ВТВсеЗаписиПоПриему.АвторЗаписи КАК АвторЗаписи,
    |	ВТВсеЗаписиПоПриему.ПричинаНаправления КАК ПричинаНаправления,
    |	ВТВсеЗаписиПоПриему.ПричинаПереноса КАК ПричинаПереноса,
    |	ВТВсеЗаписиПоПриему.Комментарий КАК Комментарий,
    |	ВТВсеЗаписиПоПриему.Длительность КАК Длительность,
    |	ВТВсеЗаписиПоПриему.Специализация КАК Специализация,
    |	ВТВсеЗаписиПоПриему.НаправленКСпециалисту КАК НаправленКСпециалисту,
    |	ВЫБОР
    |		КОГДА ВТВсеЗаписиПоПриему.Сотрудник.НаименованиеСокращенное = """"""""
    |			ТОГДА ВТВсеЗаписиПоПриему.Сотрудник.Наименование
    |		ИНАЧЕ ВТВсеЗаписиПоПриему.Сотрудник.НаименованиеСокращенное
    |	КОНЕЦ КАК ФИОВрача,
    |	ВТВсеЗаписиПоПриему.ПредварительнаяЗапись.Дата КАК ПЗДатаСоздания,
    |	ВТВсеЗаписиПоПриему.Комментарий КАК ПЗКомментарий
    |ИЗ
    |	ВТВсеЗаписиПоПриему КАК ВТВсеЗаписиПоПриему
    |ГДЕ
    |	ВТВсеЗаписиПоПриему.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Направление)
    |	И ВТВсеЗаписиПоПриему.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
    |
    |УПОРЯДОЧИТЬ ПО
    |	Период");
    
	Запрос.УстановитьПараметр("Прием", Объект.Ссылка); 
	РезультатЗапроса     = Запрос.ВыполнитьПакет();  
	ВыборкаСпециализации = РезультатЗапроса[0].Выгрузить();	
	Если Не Объект.Ссылка.Пустая() Тогда
		ВыборкаПрофосмотры   = РезультатЗапроса[1].Выгрузить(); 
		ВыборкаНаправления   = РезультатЗапроса[3].Выгрузить();  // записи с заполнеными специализациями врача 
	Иначе 
		ВыборкаПрофосмотры = Новый ТаблицаЗначений;
		ВыборкаНаправления = Новый ТаблицаЗначений;
	КонецЕсли;
	// Очищаем ранее созданные элементы
	Пока Элементы.ГруппаСсылкаНаНаправление.ПодчиненныеЭлементы.Количество() > 0 Цикл		
		Элементы.Удалить(Элементы.ГруппаСсылкаНаНаправление.ПодчиненныеЭлементы[0]);		
	КонецЦикла;  
	Пока Элементы.ГруппаНаправлениеНаКонсультацию.ПодчиненныеЭлементы.Количество() > 0 Цикл		
		Элементы.Удалить(Элементы.ГруппаНаправлениеНаКонсультацию.ПодчиненныеЭлементы[0]);		
	КонецЦикла; 
	
	НаправленияНаКонсультацию.Очистить();
	
	НомерСтроки = 0; 
	Для Каждого СтрокаТЧ Из ВыборкаПрофосмотры Цикл
		
		НоваяСтрока = НаправленияНаКонсультацию.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ); 
		НоваяСтрока.НаправленКСпециалисту = Истина;  
		ЗаголовокГруппы = ?(СтрокаТЧ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием, "ПовторныйПрием", "ПрофОсмотр");
		
		ГруппаПрофосмотр = Элементы.Добавить("ГруппаПрофосмотр" + НомерСтроки, Тип("ГруппаФормы"), Элементы.ГруппаСсылкаНаНаправление);
		ГруппаПрофосмотр.Вид 					     = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаПрофосмотр.Заголовок 			         = ЗаголовокГруппы;
		ГруппаПрофосмотр.Отображение 			     = ОтображениеОбычнойГруппы.Нет;
		ГруппаПрофосмотр.Группировка 			     = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаПрофосмотр.ОтображатьЗаголовок 	     = Ложь;
		ГруппаПрофосмотр.ГоризонтальныйИнтервал      = ИнтервалМеждуЭлементамиФормы.Одинарный;
		
		Если СтрокаТЧ.Статус <> Перечисления.СтатусыПрофосмотров.Согласился Тогда
			// Декорация заголовка
			НовыйДек                          = Элементы.Добавить("ДекорацияПредставления_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаПрофосмотр);
			НовыйДек.Вид                      = ВидДекорацииФормы.Надпись;
			НовыйДек.РастягиватьПоГоризонтали = Ложь; 
			НовыйДек.АвтоМаксимальнаяШирина   = Ложь;
			Если СтрокаТЧ.ВидОсмотра = Перечисления.ВидыОсмотров.ПовторныйПрием Тогда 
				ИнтервалПередПриемом = "";
				Если ЗначениеЗаполнено(Объект.ИнтервалПередПриемом) И ЗначениеЗаполнено(Объект.ПовторныйПриемИнтервал) Тогда	
					Если Объект.ИнтервалПередПриемом = 1 Тогда
						ПредставлениеИнтервала = НСтр("ru = ';%1 день;;%1 дня;%1 дней;%1 дня'");
					ИначеЕсли Объект.ИнтервалПередПриемом = 2 Тогда
						ПредставлениеИнтервала   = НСтр("ru = ';%1 неделю;;%1 недели;%1 недель;%1 недели'"); 
					ИначеЕсли Объект.ИнтервалПередПриемом = 3 Тогда
						ПредставлениеИнтервала   = НСтр("ru = ';%1 месяц;;%1 месяца;%1 месяцев;%1 месяца'"); 					
					КонецЕсли;
					ИнтервалПередПриемом = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(ПредставлениеИнтервала, Объект.ПовторныйПриемИнтервал); 
				КонецЕсли;
				НовыйДек.Заголовок              = "Повторный прием через " + ИнтервалПередПриемом  + " длительностью " + Строка(СтрокаТЧ.Длительность) +" минут.";	
				ФормаПовторныйПриемИспользовать = Истина;
			Иначе  
				ДатаЗапланированная = Формат(СтрокаТЧ.ДатаЗапланированная, "ДЛФ=DD"); 
				НовыйДек.Заголовок            = "Вызвать на профосмотр к: " + СтрокаТЧ.ФИОВрача + " " + Лев(ДатаЗапланированная, СтрДлина(ДатаЗапланированная) - 2) + ".";
				ФормаПрофосмотрИспользовать   = Истина;
			КонецЕсли;
			НовыйДек                          = Элементы.Добавить("ДекорацияНаправления_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаПрофосмотр);
			НовыйДек.Вид                      = ВидДекорацииФормы.Надпись; 
			НовыйДек.РастягиватьПоГоризонтали = Ложь;  
			НовыйДек.Заголовок                = "Записать";
			НовыйДек.Гиперссылка              = Истина;
			НовыйДек.УстановитьДействие("Нажатие", "ОбработчикНажатияЗаписиНаПрием"); 
			
		ИначеЕсли СтрокаТЧ.Статус = Перечисления.СтатусыПрофосмотров.Согласился 
			И ЗначениеЗаполнено(СтрокаТЧ.ПредварительнаяЗапись) Тогда
			ДатаСозданияОснования = Формат(СтрокаТЧ.ПЗДатаСоздания, "ДЛФ=DD"); 						
			ТекстПредварительнойЗаписи = ?(СтрокаТЧ.ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр, "Профосмотр назначен на ", "Повторный прием назначен на ") 
			+ Лев(ДатаСозданияОснования, СтрДлина(ДатаСозданияОснования) - 2) + " в " + Формат(СтрокаТЧ.ПЗДатаСоздания, "ДФ=ЧЧ:мм") 
			+ ?(ЗначениеЗаполнено(СтрокаТЧ.ФИОВрача), " к " + СтрокаТЧ.ФИОВрача, ""); 		
			
			НовыйДек                          = Элементы.Добавить("ДекорацияПредварительнойЗаписи_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаПрофосмотр);
			НовыйДек.Вид                      = ВидДекорацииФормы.Надпись; 
			НовыйДек.РастягиватьПоГоризонтали = Ложь;  
			НовыйДек.Заголовок                = ТекстПредварительнойЗаписи; 
			НовыйДек.Гиперссылка              = Истина;
			НовыйДек.УстановитьДействие("Нажатие", "ОбработчикОткрытьПредварительнуюЗапись"); 			
			ФормаРезультатПриема              = ?(СтрокаТЧ.ВидОсмотра = Перечисления.ВидыОсмотров.Профосмотр, 1, 2);
			Объект.РезультатПриема            = ФормаРезультатПриема;
			Элементы.РезультатПриема.ТолькоПросмотр = Истина;
			Элементы.ФормаКнопкаПровестиИЗакрытьРезультатПриема.Доступность = Истина;
		КонецЕсли;	
		
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла; 
	
	Если Элементы.ГруппаСсылкаНаНаправление.ПодчиненныеЭлементы.Количество() > 0 Тогда
		Элементы.ГруппаСанация.Видимость    = Ложь; 
		Элементы.ГруппаПрофосмотр.Видимость = Ложь;    
	КонецЕсли;	
	
	Для Каждого СтрокаТЧСпециализации Из ВыборкаСпециализации Цикл  
		
		Если ЗначениеЗаполнено(ВыборкаНаправления) Тогда
			НайденнаяСтрока = ВыборкаНаправления.НайтиСтроки(Новый Структура("НаправленКСпециалисту, Специализация", Истина, СтрокаТЧСпециализации.Ссылка));
		Иначе
			НайденнаяСтрока = Неопределено;
		КонецЕсли;
		
		НоваяСтрока = НаправленияНаКонсультацию.Добавить();
		НоваяСтрока.ВидОсмотра = Перечисления.ВидыОсмотров.Направление; 
		Если ЗначениеЗаполнено(НайденнаяСтрока) Тогда 
			ЗаполнитьЗначенияСвойств(НоваяСтрока, НайденнаяСтрока[0]);
		Иначе 
			НоваяСтрока.Специализация = СтрокаТЧСпециализации.Ссылка;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.НаправившийВрач) Тогда 
			НоваяСтрока.НаправившийВрач = Объект.Сотрудник;
		КонецЕсли; 
		
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.Период) Тогда 
			НоваяСтрока.Период = ТекущаяДата() + НомерСтроки;
		КонецЕсли;
		
		ИмяЭлемента = ?(СтрокаТЧСпециализации.Имя = "Гигиена", "ВрачГигиенист", ?(СтрокаТЧСпециализации.Имя = "Терапия", "ВрачТерапевт",
		?(СтрокаТЧСпециализации.Имя = "Хирургия", "ВрачХирург", ?(СтрокаТЧСпециализации.Имя = "Ортопедия", "ВрачОртопед",
		?(СтрокаТЧСпециализации.Имя = "Ортодонтия", "ВрачОртодонт", "ВрачПародонтолог")))));  
		
		ЗаголовокЭлемента   = ?(СтрокаТЧСпециализации.Имя = "Гигиена", "Гигиениста", ?(СтрокаТЧСпециализации.Имя = "Терапия", "Терапевта",
		?(СтрокаТЧСпециализации.Имя = "Хирургия", "Хирурга", ?(СтрокаТЧСпециализации.Имя = "Ортопедия", "Ортопеда",
		?(СтрокаТЧСпециализации.Имя = "Ортодонтия", "Ортодонта", "Пародонтолога")))));				
		
		ГруппаНаправления = Элементы.Добавить("ГруппаНаправления" + НомерСтроки, Тип("ГруппаФормы"), Элементы.ГруппаНаправлениеНаКонсультацию);
		ГруппаНаправления.Вид 					     = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаНаправления.Заголовок 			     = "ГруппаНаправления";
		ГруппаНаправления.Отображение 			     = ОтображениеОбычнойГруппы.Нет;
		ГруппаНаправления.Группировка 			     = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаНаправления.ОтображатьЗаголовок 	     = Ложь;
		ГруппаНаправления.ГоризонтальныйИнтервал     = ИнтервалМеждуЭлементамиФормы.Одинарный;
		
		ПолеПереключателя                            = Элементы.Добавить("ПереключательВрача_" + НомерСтроки, Тип("ПолеФормы"), ГруппаНаправления);
		ПолеПереключателя.Вид                        = ВидПоляФормы.ПолеФлажка; 
		ПолеПереключателя.ВидФлажка                  = ВидФлажка.Выключатель;
		ПолеПереключателя.ПутьКДанным                = "НаправленияНаКонсультацию["+НомерСтроки+"].НаправленКСпециалисту";
		ПолеПереключателя.ПоложениеЗаголовка         = ПоложениеЗаголовкаЭлементаФормы.Нет; 
		ПолеПереключателя.УстановитьДействие("ПриИзменении", "ПриИзмененииПереключателяНаправлениеКСпециалисту");
		
		ДекорацияВрач                                = Элементы.Добавить("ПолеВрач_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаНаправления);
		ДекорацияВрач.Вид                            = ВидДекорацииФормы.Надпись;
		ДекорацияВрач.Заголовок                      = ЗаголовокЭлемента;  
		ДекорацияВрач.РастягиватьПоГоризонтали       = Истина;
		ДекорацияВрач.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
		ДекорацияВрач.ГоризонтальноеПоложение        = ГоризонтальноеПоложениеЭлемента.Лево;
		ДекорацияВрач.АвтоМаксимальнаяШирина         = Ложь;
		ДекорацияВрач.МаксимальнаяШирина             = 9;  	
		
		Если Не ЗначениеЗаполнено(НайденнаяСтрока) Или ЗначениеЗаполнено(НайденнаяСтрока) 
			И НоваяСтрока.Статус <> Перечисления.СтатусыПрофосмотров.Согласился И НоваяСтрока.Статус <> Перечисления.СтатусыПрофосмотров.Отказался Тогда 		
			
			ПолеВрач                                 = Элементы.Добавить(ИмяЭлемента+"_"+НомерСтроки, Тип("ПолеФормы"), ГруппаНаправления);
			ПолеВрач.Вид                             = ВидПоляФормы.ПолеВвода;
			ПолеВрач.ПутьКДанным                     = "НаправленияНаКонсультацию["+НомерСтроки+"].Сотрудник";
			ПолеВрач.ПоложениеЗаголовка              = ПоложениеЗаголовкаЭлементаФормы.Нет; 
			ПолеВрач.АвтоМаксимальнаяШирина          = Ложь;
			ПолеВрач.МаксимальнаяШирина              = 25; 
			ПолеВрач.ПодсказкаВВода                  = "Врач";
			ПолеВрач.КнопкаВыпадающегоСписка         = Ложь; 
			ПолеВрач.ОтображениеКнопкиВыбора         = ОтображениеКнопкиВыбора.ОтображатьВПолеВвода; 
			ПолеВрач.КнопкаОчистки                   = Истина;
			ПолеВрач.БыстрыйВыбор                    = Ложь; 
			ПолеВрач.ИсторияВыбораПриВводе           = ИсторияВыбораПриВводе.НеИспользовать;
			ПолеВрач.УстановитьДействие("ПриИзменении", "ПолеВрачПриИзменении");
			ПолеВрач.УстановитьДействие("НачалоВыбора", "ВрачНачалоВыбора"); 		
			ПолеВрач.УстановитьДействие("АвтоПодбор"  ,	"АвтоПодборВрача");	
			
			ПолеКомментарий                          = Элементы.Добавить("ПолеКомментарий_"+НомерСтроки, Тип("ПолеФормы"), ГруппаНаправления);
			ПолеКомментарий.Вид                      = ВидПоляФормы.ПолеВвода;
			ПолеКомментарий.ПутьКДанным              = "НаправленияНаКонсультацию["+НомерСтроки+"].Комментарий";
			ПолеКомментарий.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет; 
			ПолеКомментарий.АвтоМаксимальнаяШирина   = Ложь;
			ПолеКомментарий.МаксимальнаяШирина       = 20; 
			ПолеКомментарий.РастягиватьПоГоризонтали = Истина;
			ПолеКомментарий.ПодсказкаВвода           = "Комментарий";
			ПолеКомментарий.УстановитьДействие("ПриИзменении", "ПолеКомментарийПриИзменении");
			
			НовыйДек                                 = Элементы.Добавить("ДекорацияНаправления_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаНаправления);
			НовыйДек.Вид                             = ВидДекорацииФормы.Надпись; 
			НовыйДек.РастягиватьПоГоризонтали        = Ложь;  
			НовыйДек.Заголовок                       = "Записать";
			НовыйДек.Гиперссылка                     = Истина;
			НовыйДек.УстановитьДействие("Нажатие", "ОбработчикНажатияЗаписиНаПрием");  		
			
		ИначеЕсли ЗначениеЗаполнено(НайденнаяСтрока) И ЗначениеЗаполнено(НоваяСтрока.ПредварительнаяЗапись)
			И НоваяСтрока.Статус = Перечисления.СтатусыПрофосмотров.Согласился Тогда 
			ПолеПереключателя.Доступность            = Ложь;
			ДатаСозданияОснования                    = Формат(НоваяСтрока.ПЗДатаСоздания, "ДЛФ=DD");						
			ТекстПредварительнойЗаписи               = "Прием назначен на " + Лев(ДатаСозданияОснования, СтрДлина(ДатаСозданияОснования) - 2) +
			?(ЗначениеЗаполнено(НоваяСтрока.ФИОВрача), " к " + НоваяСтрока.ФИОВрача, "") +
			" в " + Формат(НоваяСтрока.ПЗДатаСоздания, "ДФ=ЧЧ:мм");				
			НовыйДек                                 = Элементы.Добавить("ДекорацияПредварительнойЗаписи_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаНаправления);
			НовыйДек.Вид                             = ВидДекорацииФормы.Надпись; 
			НовыйДек.РастягиватьПоГоризонтали        = Ложь;  
			НовыйДек.Заголовок                       = ТекстПредварительнойЗаписи; 
			НовыйДек.Гиперссылка                     = Истина;
			НовыйДек.УстановитьДействие("Нажатие", "ОбработчикОткрытьПредварительнуюЗапись");  
			
		ИначеЕсли ЗначениеЗаполнено(НайденнаяСтрока) И НоваяСтрока.Статус = Перечисления.СтатусыПрофосмотров.Отказался Тогда 
			ПолеПереключателя.Доступность            = Ложь;
						
			НовыйДек                                 = Элементы.Добавить("ДекорацияПредварительнойЗаписи_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаНаправления);
			НовыйДек.Вид                             = ВидДекорацииФормы.Надпись; 
			НовыйДек.РастягиватьПоГоризонтали        = Ложь;  
			НовыйДек.Заголовок                       = "Отказ от консультации"; 	
			
		ИначеЕсли ЗначениеЗаполнено(НайденнаяСтрока) И НоваяСтрока.Статус = Перечисления.СтатусыПрофосмотров.Согласился Тогда
			
			НовыйДек                                 = Элементы.Добавить("ДекорацияПредварительнойЗаписи_" + НомерСтроки, Тип("ДекорацияФормы"), ГруппаНаправления);
			НовыйДек.Вид                             = ВидДекорацииФормы.Надпись; 
			НовыйДек.РастягиватьПоГоризонтали        = Ложь;  
			НовыйДек.Заголовок                       = "Направление обработано"; 
			
		КонецЕсли;
		
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла; 	
    
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСпискаНеОбработанныхПлановИНарядЗаказов

&НаКлиенте
// Процедура - обработчик события "Нажатие"
//
Процедура ДекорацияДобавитьУслугиНажатие(Элемент)	
	
	Если ЭтотОбъект.ПробитПоФР И НЕ ЭтотОбъект.ДокументРазблокированПослеОплаты = Истина Тогда 
		Возврат;
	КонецЕсли;
		
	МассивНайденныхСтрок = ТаблицаНезавершенныхПланирований.НайтиСтроки(Новый Структура("КлючЭлемента", СтрЗаменить(Элемент.Имя, "Декорация_ДобавитьУслуги_", "")));
	Если МассивНайденныхСтрок.Количество() > 0 Тогда
		Если ТипЗнч(МассивНайденныхСтрок[0].Ссылка) = Тип("ДокументСсылка.ПланЛечения") Тогда 
			Если МассивНайденныхСтрок[0].Статус <> ПредопределенноеЗначение("Перечисление.СтатусыПланЛечения.Принят") Тогда 
				ПоказатьВопрос(Новый ОписаниеОповещения("ДекорацияДобавитьУслугиНажатиеПослеВопроса", ЭтотОбъект, Новый Структура("МассивНайденныхСтрок", МассивНайденныхСтрок)), "План лечения в статусе рассмотрения. Установить статус ""Принят"" и продолжить?", РежимДиалогаВопрос.ДаНет, , , "Вопрос");
                Возврат;	
			КонецЕсли;
		КонецЕсли;
		
		ДекорацияДобавитьУслугиНажатиеЗавершение(МассивНайденныхСтрок);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Декорация добавить услуги нажатие после вопроса
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДекорацияДобавитьУслугиНажатиеПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	МассивНайденныхСтрок = ДополнительныеПараметры.МассивНайденныхСтрок;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда 
		ПринятьПланЛечения(МассивНайденныхСтрок[0].Ссылка);
		МассивНайденныхСтрок[0].Статус = ПредопределенноеЗначение("Перечисление.СтатусыПланЛечения.Принят");
		ПерерисоватьНадписиНезавершенныхПланирований();
	Иначе 
		Возврат;
	КонецЕсли;	
	
	ДекорацияДобавитьУслугиНажатиеЗавершение(МассивНайденныхСтрок);

КонецПроцедуры

&НаКлиенте
// Процедура - Декорация добавить услуги нажатие завершение
//
// Параметры:
//  МассивНайденныхСтрок - 	 - 
//
Процедура ДекорацияДобавитьУслугиНажатиеЗавершение(Знач МассивНайденныхСтрок)
		
	МассивКлючейДобавленныхСтрок = Новый Массив;
	Для Каждого СтрокаЛечение Из Объект.Лечение Цикл 
		Если МассивКлючейДобавленныхСтрок.Найти(СтрокаЛечение.КлючСтроки) = Неопределено Тогда 
			МассивКлючейДобавленныхСтрок.Добавить(СтрокаЛечение.КлючСтроки);
		КонецЕсли;			
	КонецЦикла;
	Для Каждого СтрокаЗапасы Из Объект.Запасы Цикл 
		Если МассивКлючейДобавленныхСтрок.Найти(СтрокаЗапасы.КлючСтроки) = Неопределено Тогда 
			МассивКлючейДобавленныхСтрок.Добавить(СтрокаЗапасы.КлючСтроки);
		КонецЕсли;			
	КонецЦикла;
	
	ПараметрыФормы = Новый Структура("ОтборДокумент, МассивУжеДобавленныхСтрок, ОтборСотрудник, ОтборСтруктурнаяЕдиница",
									  МассивНайденныхСтрок[0].Ссылка, МассивКлючейДобавленныхСтрок, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
									  
	ОписаниеОповещения = Новый ОписаниеОповещения("ДекорацияДобавитьУслугиНажатиеОбработкаВыбора", ЭтотОбъект, Новый Структура("МассивНайденныхСтрок", МассивНайденныхСтрок));
	ОткрытьФорму("Документ.Прием.Форма.ФормаПодбораЗапланированныхУслуг", ПараметрыФормы,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаКлиенте
// Процедура - Декорация добавить услуги нажатие обработка выбора
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДекорацияДобавитьУслугиНажатиеОбработкаВыбора(РезультатПодбора, ДополнительныеПараметры) Экспорт
	
	МассивНайденныхСтрок = ДополнительныеПараметры.МассивНайденныхСтрок;
	
	ОписаниеОшибки = "";
	Если РезультатПодбора <> Неопределено Тогда
		ЗаполнитьРезультатомПодбора(МассивНайденныхСтрок[0].Ссылка,РезультатПодбора, ОписаниеОшибки);
	КонецЕсли;
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ПоказатьПредупреждение(,ОписаниеОшибки);	
	КонецЕсли;
	ОбновитьSVGПодбор();

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Нажатие"
//
Процедура ДекорацияОткрытьНажатие(Элемент)	
	
	МассивНайденныхСтрок = ТаблицаНезавершенныхПланирований.НайтиСтроки(Новый Структура("КлючЭлемента", СтрЗаменить(Элемент.Имя, "Декорация_ОткрытьПланЛечения_", "")));
	Если МассивНайденныхСтрок.Количество() > 0 Тогда 
		Если ТипЗнч(МассивНайденныхСтрок[0].Ссылка) = Тип("ДокументСсылка.ПланЛечения") Тогда
			ОткрытьФорму("Документ.ПланЛечения.ФормаОбъекта", Новый Структура("Ключ", МассивНайденныхСтрок[0].Ссылка));
		ИначеЕсли ТипЗнч(МассивНайденныхСтрок[0].Ссылка) = Тип("ДокументСсылка.НарядЗаказ") Тогда
			ОткрытьФорму("Документ.НарядЗаказ.ФормаОбъекта", Новый Структура("Ключ", МассивНайденныхСтрок[0].Ссылка));	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура устанавливает видимость у надписи под зубами
// с гиперсылками "Открыть" и "ДобавитьУслуги"
//
Процедура УстановитьВидимостьНадписиСНезавершеннымиПланамиЛечения() 	
	
	ТаблицаНезавершенныхПланирований.Загрузить(ВернутьТаблицуНезавершенныхПланирований(Объект.Контрагент, Объект.СтруктурнаяЕдиница, Объект.Дата));
	ПерерисоватьНадписиНезавершенныхПланирований();	
	
КонецПроцедуры

&НаСервере
//
//
Процедура ПерерисоватьНадписиНезавершенныхПланирований()
	
	// Почистим группу перед добавлением в нее элементов
	Счетчик = 0;
	КоличествоЭлементов = Элементы.ГруппаНезаконченныеПланыЛечения.ПодчиненныеЭлементы.Количество();	
	Пока Счетчик < КоличествоЭлементов Цикл		
		ЭтаФорма.Элементы.Удалить(Элементы.ГруппаНезаконченныеПланыЛечения.ПодчиненныеЭлементы[0]);
		Счетчик = Счетчик + 1;
	КонецЦикла;
	
	// Элементы.ГруппаНезаконченныеПланыЛечения.Высота = ТаблицаНезавершенныхПланирований.Количество();
	Элементы.ГруппаНезаконченныеПланыЛечения.Заголовок = "Незаконченные планы лечения и наряд-заказы (" + ТаблицаНезавершенныхПланирований.Количество() + ")"; 	
	
	Для Каждого Планирование Из ТаблицаНезавершенныхПланирований Цикл
		Если ЗначениеЗаполнено(Планирование.Ссылка) И Планирование.Дата <> Дата(1,1,1) Тогда
			Если  ТипЗнч(Планирование.Ссылка) = Тип("ДокументСсылка.НарядЗаказ") И Не Константы.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Получить() И Планирование.Статус Тогда 
				Продолжить;
			КонецЕсли;
					
			Планирование.КлючЭлемента = ОбщегоНазначенияСтоматология.ТолькоЦифры(Планирование.Номер) +""+ ОбщегоНазначенияСтоматология.ТолькоЦифры(Планирование.Дата);
			
			// Добавим группу   
			ЭлементГруппа                     		= ЭтаФорма.Элементы.Добавить("ГруппаПланаЛечения_" + Планирование.КлючЭлемента, Тип("ГруппаФормы"), Элементы.ГруппаНезаконченныеПланыЛечения);
			ЭлементГруппа.Вид                 		= ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементГруппа.ОтображатьЗаголовок 		= Ложь;
			ЭлементГруппа.Отображение         		= ОтображениеОбычнойГруппы.Нет;
			ЭлементГруппа.Группировка         		= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;		   
			ЭлементГруппа.РастягиватьПоВертикали 	= Ложь;
			ЭлементГруппа.Высота 					= 1;
			
			ЭлементГруппаВыравнивания          		= ЭтаФорма.Элементы.Добавить("ГруппаПланаЛечения_Выравнивания" + Планирование.КлючЭлемента, Тип("ГруппаФормы"), ЭлементГруппа);
			ЭлементГруппаВыравнивания.Вид                 		= ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементГруппаВыравнивания.ОтображатьЗаголовок 		= Ложь;
			ЭлементГруппаВыравнивания.Отображение         		= ОтображениеОбычнойГруппы.Нет;
			ЭлементГруппаВыравнивания.Группировка         		= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;		   
			ЭлементГруппаВыравнивания.РастягиватьПоВертикали 	= Ложь;
			ЭлементГруппаВыравнивания.Высота 					= 1;
			ЭлементГруппаВыравнивания.Ширина                    = 54;

			// добавим элементы в эту группу
			ЭлементДекорация                          	= ЭтаФорма.Элементы.Добавить("Декорация_ПланЛечения_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппаВыравнивания);
			ЭлементДекорация.Вид                      	= ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Шрифт                    	= Новый Шрифт( , , Истина, );
			Если ТипЗнч(Планирование.Ссылка) = Тип("ДокументСсылка.ПланЛечения") Тогда
				Если Планирование.Статус = Перечисления.СтатусыПланЛечения.Принят Тогда 
					ЭлементДекорация.Заголовок = "У пациента есть незаконченный план лечения";
				Иначе 
					ЭлементДекорация.Заголовок = "У пациента есть непринятый план лечения";
				КонецЕсли;
			ИначеЕсли  ТипЗнч(Планирование.Ссылка) = Тип("ДокументСсылка.НарядЗаказ") Тогда
				ЭлементДекорация.Заголовок = "У пациента есть не закрытый наряд-заказ";
			КонецЕсли;
			// ------------------------------- 
			
			СотрудникПланирования                       = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Планирование.Сотрудник, "НаименованиеСокращенное"); 
			СотрудникПланирования                       = ?(ЗначениеЗаполнено(СотрудникПланирования), СотрудникПланирования, "");
			СуммаПланирования                           = Формат(Планирование.Сумма, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(); 
			Если ТипЗнч(Планирование.Статус) = Тип("Булево") Тогда 
				Статус                                  = ?(Планирование.Статус = Истина, "Закрыт", "Открыт");
			Иначе 
				Статус = Строка(Планирование.Статус);
			КонецЕсли;
			
			ЭлементДекорация                          	= ЭтаФорма.Элементы.Добавить("Декорация_ПланЛечения_Продолжение_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппаВыравнивания);
			ЭлементДекорация.Вид                      	= ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение 	= ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь; 
			ЭлементДекорация.АвтоМаксимальнаяШирина     = Ложь;  
			ЭлементДекорация.МаксимальнаяШирина         = 110;
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Шрифт                    	= Новый Шрифт( , , Истина, );
			ЭлементДекорация.Заголовок = "от " + Формат(Планирование.Дата, "ДЛФ=DD") + " " + СотрудникПланирования + " Сумма " + СуммаПланирования + " " + Статус;
			// -------------------------------
			// ЭлементДекорация                            = ЭтаФорма.Элементы.Добавить("Декорация_Заглушка_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппа);
			// ЭлементДекорация.Вид                        = ВидДекорацииФормы.Надпись;
			// ЭлементДекорация.ГоризонтальноеПоложение    = ГоризонтальноеПоложениеЭлемента.Лево;
			// ЭлементДекорация.РастягиватьПоГоризонтали 	= Истина;
			// ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;
			// ЭлементДекорация.Высота 					= 1;			
			// ЭлементДекорация.Заголовок                  = "";
			// -------------------------------
			ЭлементДекорация                            = ЭтаФорма.Элементы.Добавить("Декорация_ОткрытьПланЛечения_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппа);
			ЭлементДекорация.Вид                        = ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение    = ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Гиперссылка                = Истина;
			ЭлементДекорация.Заголовок                  = "Открыть";
			ЭлементДекорация.УстановитьДействие("Нажатие", "ДекорацияОткрытьНажатие");
			// -------------------------------
			ЭлементДекорация                            = ЭтаФорма.Элементы.Добавить("Декорация_ДобавитьУслуги_" + Планирование.КлючЭлемента, Тип("ДекорацияФормы"), ЭлементГруппа);
			ЭлементДекорация.Вид                        = ВидДекорацииФормы.Надпись;
			ЭлементДекорация.ГоризонтальноеПоложение    = ГоризонтальноеПоложениеЭлемента.Лево;
			ЭлементДекорация.РастягиватьПоВертикали 	= Ложь;			
			ЭлементДекорация.Высота 					= 1;			
			ЭлементДекорация.Гиперссылка                = Истина;
			ЭлементДекорация.Заголовок                  = "Добавить услуги";
			// Если Планирование.Статус = Перечисления.СтатусыПланЛечения.Рассматривается Тогда 
			//	ЭлементДекорация.Доступность             = Ложь;
			// КонецЕсли;
			ЭлементДекорация.УстановитьДействие("Нажатие", "ДекорацияДобавитьУслугиНажатие");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Заполнить ТЧ Лечение по сонованию документа аванса.
//
Процедура ЗаполнитьРезультатомПодбора(ДокументОснования, МассивЗаполнения, ОписаниеОшибки)
	
	ИдентификаторыНовыхСтрокЛечения = Новый Массив;
	ИдентификаторыНовыхСтрокЗапасов = Новый Массив;
	
	ИспользуетсяПолисМедСтрахования = ЗначениеЗаполнено(Объект.ПолисМедСтрахования) И ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса);   
	
	Если ИспользуетсяПолисМедСтрахования Тогда
		МассивСтруктурСКоличествомПоПолису = ПолучитьКоличествоПоПолису(Объект.ПолисМедСтрахования, Объект.Ссылка);
	КонецЕсли;
	
	// Если основанием является план лечения
	Если ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.ПланЛечения") Тогда 
		
		Для Каждого ЭлементМассива Из МассивЗаполнения Цикл 
			// Поиск существующей строки
			НайденнаяСтрока = Объект.Лечение.НайтиСтроки(Новый Структура("КлючСтроки", ЭлементМассива.КлючСтроки));	
			Если НайденнаяСтрока.Количество() = 0 Тогда
				// Получаем строку источника заполнения
				СтрокаИсточника        = ДокументОснования.Лечение.Найти(ЭлементМассива.КлючСтроки, "КлючСтроки");
				Если СтрокаИсточника <> Неопределено Тогда 
	
					Если ИспользуетсяПолисМедСтрахования Тогда 
						
						Для Сч = 0 По СтрокаИсточника.Количество - 1 Цикл						
							
							ПолисНеограничено 		= ИСТИНА;
							ПолисКоличество 		= 0;			
							КоличествоЗубов 		= 0;
							КоличествоВПриеме 		= 0;
							ПолисСогласование 		= Перечисления.ТипыСогласованийУслугСтраховойКомпании.НеТребуется;
							КоличествоПриПревышении = 0;
							
							СтрокаУслугиПоДоговору = ЭтотОбъект._ПодборДоговорПолиса.УслугиПоДоговору.Найти(СтрокаИсточника.Номенклатура, "Номенклатура");
							Если СтрокаУслугиПоДоговору <> Неопределено Тогда
								
								ПолисНеограничено 		= СтрокаУслугиПоДоговору.Количество = 0;
								ПолисКоличество 		= СтрокаУслугиПоДоговору.Количество;
								ПолисСогласование 		= СтрокаУслугиПоДоговору.Согласование;
								КоличествоПриПревышении = СтрокаУслугиПоДоговору.КоличествоПриПревышении;
								
								Если ЗначениеЗаполнено(СтрокаУслугиПоДоговору.КлючСтроки) Тогда
									
									СтрокаУслугиПоДоговоруОграничениеЗубов = ЭтотОбъект._ПодборДоговорПолиса.ОграничениеЗубов.Найти(СтрокаУслугиПоДоговору.КлючСтроки, "КлючСтроки");	
									
									Если СтрокаУслугиПоДоговоруОграничениеЗубов <> Неопределено Тогда
										
										КоличествоЗубов 	= СтрокаУслугиПоДоговоруОграничениеЗубов.КоличествоЗубов;
										КоличествоВПриеме 	= СтрокаУслугиПоДоговоруОграничениеЗубов.КоличествоВПриеме;
										
									КонецЕсли;
								КонецЕсли;						
								
							КонецЕсли;
							
							КоличествоЗубовВсего 	= 0;
							КоличествоВсего 		= 0;
							
							Для каждого СтрокаМассива Из МассивСтруктурСКоличествомПоПолису Цикл
								Если СтрокаМассива.Номенклатура = СтрокаИсточника.Номенклатура Тогда
									
									КоличествоЗубовВсего 	= СтрокаМассива.КоличествоЗубов;
									КоличествоВсего 		= СтрокаМассива.Количество;
									
								КонецЕсли;
							КонецЦикла;
							
							СтруктураПараметровПоПолису = Новый Структура();
							СтруктураПараметровПоПолису.Вставить("ЭлементМЗуб", 			СтрокаИсточника.Зуб);
							СтруктураПараметровПоПолису.Вставить("Номенклатура", 			СтрокаИсточника.Номенклатура);
							СтруктураПараметровПоПолису.Вставить("КоличествоЗубов", 		КоличествоЗубов);
							СтруктураПараметровПоПолису.Вставить("КоличествоВПриеме", 		КоличествоВПриеме);
							СтруктураПараметровПоПолису.Вставить("ПолисНеограничено", 		ПолисНеограничено);
							СтруктураПараметровПоПолису.Вставить("ПолисКоличество", 		ПолисКоличество);
							СтруктураПараметровПоПолису.Вставить("КоличествоЗубовВсего", 	КоличествоЗубовВсего);
							СтруктураПараметровПоПолису.Вставить("КоличествоВсего", 		КоличествоВсего);
							СтруктураПараметровПоПолису.Вставить("КоличествоНоменклатурыВТЧ", Сч);
							СтруктураПараметровПоПолису.Вставить("КоличествоЗубовСНомненклатуройВТЧ", 0);
							
							ПроверитьУслугуНаСогласованностьПоПолисуНаСервере(СтруктураПараметровПоПолису, ОписаниеОшибки);
							Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
								Прервать;	
							Иначе  
								
								ОжидаетСогласования = Ложь;
								Если ПолисСогласование <> ПредопределенноеЗначение("Перечисление.ТипыСогласованийУслугСтраховойКомпании.НеТребуется") 
									И Сч + КоличествоВсего >= КоличествоПриПревышении Тогда
									
									ОжидаетСогласования = Истина;
								КонецЕсли;
								
								ДобавитьНоменклатуруИзДокументаОснования(ДокументОснования, ИдентификаторыНовыхСтрокЛечения, СтрокаИсточника, ОжидаетСогласования, Истина);
								
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе						
						ДобавитьНоменклатуруИзДокументаОснования(ДокументОснования, ИдентификаторыНовыхСтрокЛечения, СтрокаИсточника);						
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;	
	// Если основанием является наряд-заказ	
	ИначеЕсли ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.НарядЗаказ") Тогда
		Для Каждого ЭлементМассива Из МассивЗаполнения Цикл 
			// Если это услуга
			Если ЭлементМассива.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
				// Поиск существующей строки
				НайденнаяСтрока = Объект.Лечение.НайтиСтроки(Новый Структура("КлючСтроки", ЭлементМассива.КлючСтроки));	
				Если НайденнаяСтрока.Количество() = 0 Тогда
					// Получаем строку источника заполнения
					СтрокаИсточникаЛечение        = ДокументОснования.Запасы.Найти(ЭлементМассива.КлючСтроки, "КлючСтроки");
					Если СтрокаИсточникаЛечение <> Неопределено Тогда 					
						НоваяСтрока                          			= Объект.Лечение.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточникаЛечение);
						НоваяСтрока.Количество                          = НоваяСтрока.КоличествоУпаковок;
						НоваяСтрока.ВидЦен                              = СтрокаИсточникаЛечение.ВидЦенПродажи;
						НоваяСтрока.Цена                                = СтрокаИсточникаЛечение.ЦенаПродажи;
						НоваяСтрока.Сумма                               = СтрокаИсточникаЛечение.СуммаПродажи;
						НоваяСтрока.Всего                               = СтрокаИсточникаЛечение.ВсегоПродажи;
						НоваяСтрока.НомерЗаказа                         = СтрокаИсточникаЛечение.НомерЗаказа;
						НоваяСтрока.ДокументАванса                      = ДокументОснования;
						НоваяСтрока.Сотрудник 				 			= Объект.Сотрудник;
						НоваяСтрока.ЗубнойТехник 						= СтрокаИсточникаЛечение.ЗубнойТехник;
						НоваяСтрока.Гарантия 							= НоваяСтрока.Номенклатура.Гарантия;
						НоваяСтрока.КодУслуги                           = НоваяСтрока.Номенклатура.КодУслуги;
						
						// Добавляем материалы услуги.
						НормыСписанияМатериалов = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(НоваяСтрока.Номенклатура, Объект.СтруктурнаяЕдиница);
								
						Для Каждого СтрокаТЧ ИЗ НормыСписанияМатериалов Цикл			
							НоваяСтрокаМатериалы                     = Объект.Материалы.Добавить();
							НоваяСтрокаМатериалы.КлючСтроки          = НоваяСтрока.КлючСтроки;
							НоваяСтрокаМатериалы.Услуга              = НоваяСтрока.Номенклатура;
							НоваяСтрокаМатериалы.Материал            = СтрокаТЧ.Материал;
							НоваяСтрокаМатериалы.КоличествоУпаковок  = ?(СтрокаТЧ.НеЗависитОтКоличестваУслуг, СтрокаТЧ.Количество, СтрокаТЧ.Количество * ?(НоваяСтрока.КоличествоУпаковок = 0, 1, НоваяСтрока.КоличествоУпаковок));
							НоваяСтрокаМатериалы.Количество          = НоваяСтрокаМатериалы.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаТЧ.Упаковка.Коэффициент), СтрокаТЧ.Упаковка.Коэффициент, 1);
							НоваяСтрокаМатериалы.Упаковка            = СтрокаТЧ.Упаковка;
							НоваяСтрокаМатериалы.Партия              = СтрокаТЧ.Партия;							
							НоваяСтрокаМатериалы.Склад               = РегистрыСведений.НормыСписанияМатериалов.ПолучитьСкладСписанияНормМатериалов(СтрокаТЧ, Объект.СтруктурнаяЕдиница, Объект.Сотрудник);
							НоваяСтрокаМатериалы.Сотрудник           = Объект.Сотрудник;
							НоваяСтрокаМатериалы.ЗубнойТехник 		 = СтрокаИсточникаЛечение.ЗубнойТехник;
						КонецЦикла;	
						// Получаем строку источника заполнения
						// СтрокиИсточникаСкидки = ДокументОснования.СкидкиНаценки.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаИсточникаЛечение.КлючСтроки));			
						//// Добавим скидки в ТЧ СкидкиНаценки
						// Для Каждого СтрокаСкидки Из СтрокиИсточникаСкидки Цикл 
						//	НоваяСтрокаСкидкиНаценки           			= Объект.СкидкиНаценки.Добавить();
						//	ЗаполнитьЗначенияСвойств(НоваяСтрокаСкидкиНаценки, СтрокаСкидки);
						//	НоваяСтрокаСкидкиНаценки.КлючСтроки         = НоваяСтрока.КлючСтроки;
						// КонецЦикла;
						ИдентификаторыНовыхСтрокЛечения.Добавить(НоваяСтрока.ПолучитьИдентификатор());
						// ТабличныеЧастиПересчетПослеИзменений("Лечение",НоваяСтрока.ПолучитьИдентификатор());
					КонецЕсли;
				КонецЕсли;
				// Если это товар
			ИначеЕсли ЭлементМассива.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас Тогда
				// Поиск существующей строки
				НайденнаяСтрока = Объект.Запасы.НайтиСтроки(Новый Структура("КлючСтроки", ЭлементМассива.КлючСтроки));	
				Если НайденнаяСтрока.Количество() = 0 Тогда
					// Получаем строку источника заполнения
					СтрокаИсточникаЛечение        = ДокументОснования.Запасы.Найти(ЭлементМассива.КлючСтроки, "КлючСтроки");	
					Если СтрокаИсточникаЛечение <> Неопределено Тогда 					
						НоваяСтрока                          			= Объект.Запасы.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаИсточникаЛечение);
						// НоваяСтрока.КлючСтроки               			= Новый УникальныйИдентификатор;	
						НоваяСтрока.Количество                          = НоваяСтрока.КоличествоУпаковок;
						НоваяСтрока.ВидЦен                              = СтрокаИсточникаЛечение.ВидЦенПродажи;
						НоваяСтрока.Цена                                = СтрокаИсточникаЛечение.ЦенаПродажи;
						НоваяСтрока.Сумма                               = СтрокаИсточникаЛечение.СуммаПродажи;
						НоваяСтрока.Всего                               = СтрокаИсточникаЛечение.ВсегоПродажи;
						НоваяСтрока.НомерЗаказа                         = СтрокаИсточникаЛечение.НомерЗаказа;
						НоваяСтрока.ДокументАванса                      = ДокументОснования;	
						НоваяСтрока.ЗубнойТехник 						= СтрокаИсточникаЛечение.ЗубнойТехник;
						//// Получаем строку источника заполнения
						// СтрокиИсточникаСкидки = ДокументОснования.СкидкиНаценки.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаИсточникаЛечение.КлючСтроки));			
						//// Добавим скидки в ТЧ СкидкиНаценки
