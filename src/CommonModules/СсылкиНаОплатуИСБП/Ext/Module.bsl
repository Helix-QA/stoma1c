// Функция возвращает хеш строки
//
Функция ПолучитьMD5(Текст)
	
	ОбъектХеш = Новый ХешированиеДанных(ХешФункция.MD5);
	ОбъектХеш.Добавить(Текст);
	ХешСумма = Строка(ОбъектХеш.ХешСумма);
	Возврат СтрЗаменить(ХешСумма, " ", "");
	
КонецФункции

#КонецОбласти

#Область BePaid

 // Функция, формирует ссылку на оплату основание и возвращает её. 
//
Функция СформироватьСсылкуОплатыBePaid(СтруктураПараметров) 

	// https://docs.bepaid.by/ru/products#get-payment-link
	
	СтруктураВозврата		= СтруктураПараметров.СтруктураВозврата; 
	ПараметрыПШ				= СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 			= СтруктураПараметров.СуммаОплаты;
	ТаблицаЗадолженностей	= СтруктураПараметров.ТаблицаЗадолженностей;

	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура")
		Или Не ЗначениеЗаполнено(ПараметрыПШ.IdМагазинаBePaid)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.СекретныйКлючBePaid) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры эквайрингового терминала.";
		Возврат СтруктураВозврата;
	КонецЕсли;	
		
	СтруктураДанных = СформироватьСтруктуруДанныхСозданиеПродуктаBePaid(ТаблицаЗадолженностей, ПараметрыПШ);

	ОписаниеОшибки = "";
	КодОтвета      = ""; 
	product_id     = ВызовМетодаСозданиеПродуктаBePaid(СтруктураДанных, ПараметрыПШ, ОписаниеОшибки, КодОтвета); 

	Если КодОтвета <> 201 Или ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке ссылки на оплату в BePaid. " + ОписаниеОшибки;;
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	
	// отправить ссылку на оплату
	КороткаяСсылкаНаОплату = "https://api.bepaid.by/products/" + product_id + "/pay";
	
	СтруктураВозврата.Вставить("СсылкаНаОплату"	 , КороткаяСсылкаНаОплату);
	СтруктураВозврата.Вставить("ВыполненоУспешно", Истина);
	
	НомерЗаказа = ПолучитьНомерЗаказа(ТаблицаЗадолженностей[0].ДокументЗадолженности);

	Для Каждого СтрокаТ Из ТаблицаЗадолженностей Цикл
		
	РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаТ.ДокументЗадолженности, 
		СтрокаТ.Задолженность, 
		product_id, 
		КороткаяСсылкаНаОплату, 
		Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
		СтруктураПараметров.ЭквайринговыйТерминал, 
		НомерЗаказа,
		,
		Не ЗначениеЗаполнено(СтрокаТ.ДокументЗадолженности),
		СтруктураПараметров.Контрагент,
		СтрокаТ.ДокументЗадолженности.ВидЦен,
		СтруктураПараметров.СтруктурнаяЕдиница,
		ТекущаяДатаСеанса(),
		"Заказ зарегистрирован, но не оплачен",
		Перечисления.ТипыСсылокНаОплату.BePaid);
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Сформировать структуру данных be paid
//
// Параметры:
//  Основание	 - 	 - 
//  Сумма		 - 	 - 
//  ПараметрыПШ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьСтруктуруДанныхСозданиеПродуктаBePaid(ТаблицаЗадолженностей, ПараметрыПШ)
			
	СтрокаТЧ = ТаблицаЗадолженностей[0].ДокументЗадолженности.Запасы[0];
	Валюта = Константы.ВалютаУчета.Получить();   
	Если Валюта.Код = "643" Тогда
		currency = "RUB";
	Иначе 
		currency = Валюта.Наименование;	
	КонецЕсли;
	СтруктураДанных = Новый Структура();
	СтруктураДанных.Вставить("name"       , Строка(СтрокаТЧ.Номенклатура));
	СтруктураДанных.Вставить("description", Строка(СтрокаТЧ.Номенклатура.НаименованиеПолное));
	СтруктураДанных.Вставить("currency"   , currency);
	СтруктураДанных.Вставить("amount"     , СтрокаТЧ.Всего * 100);	
    СтруктураДанных.Вставить("quantity"   , СтрокаТЧ.Количество);
	СтруктураДанных.Вставить("infinite"   , Ложь);
	СтруктураДанных.Вставить("test"       , ПараметрыПШ.ТестовыйРежим);
	СтруктураДанных.Вставить("immortal"   , Истина); // Устанавливается в true, если время оплаты не ограничено.
	Если ЗначениеЗаполнено(ПараметрыПШ.UrlRedirect) Тогда
		СтруктураДанных.Вставить("return_url", ПараметрыПШ.UrlRedirect);  // URL, на который будет перенаправлен клиент после завершения оплаты 
	КонецЕсли;
	СтруктураДанных.Вставить("shop_id", ПараметрыПШ.IdМагазинаBePaid);
	СтруктураДанных.Вставить("transaction_type", "payment");
	СтруктураДанных.Вставить("language", "ru");
    СтруктураДанных.Вставить("notification_url", ПараметрыПШ.URLWebhooksBePaid);
	
	product = Новый Структура(); 	
	product.Вставить("shop_id", ПараметрыПШ.IdМагазинаBePaid);
	product.Вставить("name"   , Строка(СтрокаТЧ.Номенклатура));
	product.Вставить("description", Строка(СтрокаТЧ.Номенклатура.НаименованиеПолное));
	product.Вставить("currency"   , Валюта.Код);
	product.Вставить("amount"     , СтрокаТЧ.Всего * 100); 	
	product.Вставить("quantity"   , СтрокаТЧ.Количество);
	product.Вставить("infinite"   , Ложь);
	product.Вставить("test"       , ПараметрыПШ.ТестовыйРежим);
	product.Вставить("immortal"   , Истина); // Устанавливается в true, если время оплаты не ограничено.
	Если ЗначениеЗаполнено(ПараметрыПШ.UrlRedirect) Тогда
		СтруктураДанных.Вставить("return_url", ПараметрыПШ.UrlRedirect);  // URL, на который будет перенаправлен клиент после завершения оплаты 
	КонецЕсли;
	product.Вставить("transaction_type", "payment");
	product.Вставить("language", "ru");  
	product.Вставить("notification_url", ПараметрыПШ.URLWebhooksBePaid);
    
	СтруктураДанных.Вставить("product", product);
	
	Возврат СтруктураДанных; 
	
КонецФункции

