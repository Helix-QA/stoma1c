// Функция, возвращает текстовое содержимое HTML кода.
//
Функция ПолучитьТекстИзHTMLКода(КодHTML) Экспорт
	
	ЧтениеHTML = Новый ЧтениеHTML;
	ЧтениеHTML.УстановитьСтроку(КодHTML);
	
	ПостроительDOM = Новый ПостроительDOM;
	ДокументHTML = ПостроительDOM.Прочитать(ЧтениеHTML);
	
	ЧтениеHTML.Закрыть();
	
	Если ДокументHTML.Тело = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстовыйПостроитель = Новый ЗаписьXML;
	ТекстовыйПостроитель.УстановитьСтроку();
	
	ИзвлечьТекстHTMLЭлемента(ДокументHTML.Тело, ТекстовыйПостроитель);
	
	Возврат ТекстовыйПостроитель.Закрыть();
	
КонецФункции

// Процедура, рекурсивно извлекает текст из HTML элемента.
//
Процедура ИзвлечьТекстHTMLЭлемента(Элемент, ТекстовыйПостроитель)
	
	Если Элемент.ИмяУзла = "#text" Тогда
		ТекстовыйПостроитель.ЗаписатьБезОбработки(Элемент.ЗначениеУзла);
		
	ИначеЕсли Элемент.ИмяУзла = "br" Тогда
		ТекстовыйПостроитель.ЗаписатьБезОбработки(Символы.ПС);
		
	ИначеЕсли Элемент.ИмяУзла = "img" Тогда
		ПредставлениеУзла = ПолучитьПредставлениеЭмодзи(Элемент);
		ТекстовыйПостроитель.ЗаписатьБезОбработки(ПредставлениеУзла);
		
	Иначе
		Если Элемент.ИмяУзла = "div" Тогда
			ТекстовыйПостроитель.ЗаписатьБезОбработки(Символы.ПС);
		КонецЕсли;
		
		Для Каждого ВложенныйЭлемент Из Элемент.ДочерниеУзлы Цикл
			ИзвлечьТекстHTMLЭлемента(ВложенныйЭлемент, ТекстовыйПостроитель);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Функция, возвращает представление эмодзи по элементу картинки.
//
Функция ПолучитьПредставлениеЭмодзи(ЭлементКартинки)
	
	Если Не СтрНайти(ЭлементКартинки.ИмяКласса, "emojioneemoji") Тогда
		Возврат "";
	КонецЕсли;
	
	Источник = ЭлементКартинки.Источник;
	
	НачальнаяПозиция = СтрНайти(Источник, "/", НаправлениеПоиска.СКонца) + 1;
	КонечнаяПозиция	 = СтрНайти(Источник, ".", НаправлениеПоиска.СКонца);
	
	КодыСимволов = Сред(Источник, НачальнаяПозиция, КонечнаяПозиция - НачальнаяПозиция);
	
	Возврат КодовыеТочкиUnicodeВСтроку(КодыСимволов);
	
КонецФункции

#КонецОбласти

#КонецЕсли   
