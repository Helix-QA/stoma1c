
#Область СлужебныеПроцедурыИФункции

// Получить таблицу задолженности организации перед персоналом по указанному месяцу начисления и СЕ
Функция ПолучитьТаблицуЗадолженностиПередПерсоналом(РасчетныйМесяц = Неопределено,ДокументНачисления = Неопределено,СтруктурнаяЕдиница = Неопределено,Период = Неопределено,ИсключатьРегистратор = Неопределено) Экспорт

	ЗапросВыборка = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.СтруктурнаяЕдиница,
	|	ВложенныйЗапрос.Сотрудник,
	|	ВложенныйЗапрос.Сумма,
	|	ВложенныйЗапрос.ДокументНачисления КАК ДокументОснования
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетыСПерсоналомОбороты.Сотрудник КАК Сотрудник,
	|		РасчетыСПерсоналомОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		СУММА(РасчетыСПерсоналомОбороты.СуммаОборот) КАК Сумма,
	|		РасчетыСПерсоналомОбороты.ДокументНачисления КАК ДокументНачисления
	|	ИЗ
	|		РегистрНакопления.РасчетыСПерсоналом.Обороты(
	|				,
	|				&Период,
	|				Авто,
	|				ВЫБОР
	|						КОГДА НЕ &МесяцНачисления = НЕОПРЕДЕЛЕНО
	|							ТОГДА МесяцНачисления = &МесяцНачисления
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	|					И ВЫБОР
	|						КОГДА НЕ &ДокументНачисления = НЕОПРЕДЕЛЕНО
	|							ТОГДА ДокументНачисления = &ДокументНачисления
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ
	|					И ВЫБОР
	|						КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|							ТОГДА СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						ИНАЧЕ ИСТИНА
	|					КОНЕЦ) КАК РасчетыСПерсоналомОбороты
	|	ГДЕ
	|		ВЫБОР
	|				КОГДА НЕ &ИсключатьРегистратор = НЕОПРЕДЕЛЕНО
	|					ТОГДА НЕ РасчетыСПерсоналомОбороты.Регистратор = &ИсключатьРегистратор
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|	
	|	СГРУППИРОВАТЬ ПО
	|		РасчетыСПерсоналомОбороты.Сотрудник,
	|		РасчетыСПерсоналомОбороты.СтруктурнаяЕдиница,
	|		РасчетыСПерсоналомОбороты.ДокументНачисления) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.Сумма > 0");
	
	ЗапросВыборка.УстановитьПараметр("МесяцНачисления"     ,?(ЗначениеЗаполнено(РасчетныйМесяц),НачалоМесяца(РасчетныйМесяц),Неопределено));
	ЗапросВыборка.УстановитьПараметр("ДокументНачисления"  ,ДокументНачисления);
	ЗапросВыборка.УстановитьПараметр("СтруктурнаяЕдиница"  ,СтруктурнаяЕдиница);
	ЗапросВыборка.УстановитьПараметр("Период"              ,?(Период = Неопределено,Дата(0001,01,01,0,0,0),Период));
	ЗапросВыборка.УстановитьПараметр("ИсключатьРегистратор",ИсключатьРегистратор);
	
	Возврат ЗапросВыборка.Выполнить().Выгрузить();
	
КонецФункции	

#КонецОбласти