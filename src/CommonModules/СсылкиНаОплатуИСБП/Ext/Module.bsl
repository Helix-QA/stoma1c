// Функция - Сбербанк зарегистрировать QR
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_ЗарегистрироватьQR(СтруктураПараметров)
	
	ПараметрыПШ = СтруктураПараметров.ПараметрыПШ;
	ТипБанка	= СтруктураПараметров.ТипБанка;
	
	СтруктураПараметров.Вставить("НомерЗаказа", СформироватьНомерЗаказаСБП());
	СтруктураПараметров.Вставить("id_qr"	  , ?(ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR, ПараметрыПШ.IDQR, ПараметрыПШ.IDТерминала));
	
	ТекстЗапроса = "";
	РезультатЗапроса = Сбербанк_OrderCreateQr(СтруктураПараметров, ТекстЗапроса);
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл	
			
			КороткаяСсылка 	= РезультатЗапроса.ПараметрыРезультата.order_form_url; //ОбщегоНазначения.ПолучитьКороткуюСсылку(РезультатЗапроса.ПараметрыРезультата.order_form_url);
				
				РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
				СтрокаТ.ДокументЗадолженности,
				СтрокаТ.Задолженность,
				РезультатЗапроса.ПараметрыРезультата.order_id,
				КороткаяСсылка,
				Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено,
				СтруктураПараметров.ЭквайринговыйТерминал,
				РезультатЗапроса.ПараметрыРезультата.order_number,ТекстЗапроса,,
				СтруктураПараметров.Контрагент,,
				СтруктураПараметров.СтруктурнаяЕдиница,
				ТекущаяДатаСеанса(),,
				?(ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR, Перечисления.ТипыСсылокНаОплату.СбербанкПлатиQR, Перечисления.ТипыСсылокНаОплату.СБПСбербанк),
				ПараметрыСеанса.ТекущийПользователь,
				ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600
				);
			
		КонецЦикла;
		
		РезультатЗапроса.Вставить("СсылкаНаОплату"		, КороткаяСсылка);
		РезультатЗапроса.Вставить("ВремяДействителенДо"	, ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600);
		РезультатЗапроса.Вставить("НомерЗаказа"			, РезультатЗапроса.ПараметрыРезультата.order_number);
		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - Сбербанк order create qr
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_OrderCreateQr(СтруктураПараметров, ТекстЗапроса = "") 

	RqUID			= СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");	
	ДатаСтрокой		= ЗаписатьДатуJSON(ТекущаяДатаСеанса(), ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.УниверсальнаяДата);	
			
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("rq_uid"				, RqUID);
	ПараметрыЗапроса.Вставить("rq_tm"				, ДатаСтрокой);
	ПараметрыЗапроса.Вставить("member_id"			, "00000937");
	ПараметрыЗапроса.Вставить("order_number"		, СтруктураПараметров.НомерЗаказа);
	ПараметрыЗапроса.Вставить("order_create_date"	, ДатаСтрокой);
	ПараметрыЗапроса.Вставить("order_params_type"	, Сбербанк_order_params_type(СтруктураПараметров.ТаблицаЗадолженностей));
	ПараметрыЗапроса.Вставить("id_qr"				, СтруктураПараметров.id_qr);
	ПараметрыЗапроса.Вставить("description"			, "Оплата по структурной единице: " + Строка(СтруктураПараметров.СтруктурнаяЕдиница));
	ПараметрыЗапроса.Вставить("order_sum"			, СтруктураПараметров.СуммаОплаты*100);
	ПараметрыЗапроса.Вставить("currency"			, "643");
	
	Если СтруктураПараметров.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк Тогда
		ПараметрыЗапроса.Вставить("sbp_member_id", "100000000111");                     
	КонецЕсли;
		
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса, Ложь);
	
	Соединение = Новый HTTPСоединение("cloud.1c.fitness",,,,, 5, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос = Новый HTTPЗапрос("/api/hs/api/sbp/sbp_sber_OrderCreateQr");
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
	
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.error_code = "000000";
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		
		Если КодСостояния = 200 Тогда
			
			РезультатОперации.ОписаниеОшибки = ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь И РезультатЗапроса.Свойство("error_description"), 
				РезультатЗапроса.error_description, Неопределено);	
			
		Иначе
			
			РезультатОперации.ОписаниеОшибки = ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь, 
				РезультатЗапроса.httpMessage + ?(РезультатЗапроса.Свойство("moreInformation"), " " + РезультатЗапроса.moreInformation, ""),
				СтрШаблон("Код ответа: %1. Описание ошибки: %2", КодСостояния, ТелоОтвета));
			
		КонецЕсли;
		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;	
	
КонецФункции

// Функция - Сбербанк отменить QRКод
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_ОтменитьQRКод(СтруктураПараметров)
	
	ДокументыЗадолженности = Новый Массив;
	Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл
		ДокументыЗадолженности.Добавить(СтрокаТ.ДокументЗадолженности);	
	КонецЦикла;

	РезультатОперации	= СтруктураПараметров.СтруктураВозврата;
	НомерЗаказа			= ?(СтруктураПараметров.Свойство("НомерЗаказа"), СтруктураПараметров.НомерЗаказа, Неопределено);	
	ТаблицаЗаказов		= РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьЗаказыПоДокументам(ДокументыЗадолженности, СтруктураПараметров.ЭквайринговыйТерминал, НомерЗаказа);
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		РезультатОперации.ОписаниеОшибки = "Не найдено неоплаченных заказов по данной ссылке";
		Возврат РезультатОперации;	
	КонецЕсли;
	
	ПараметрыЗапроса = Новый Структура();
	
	МассивИдСБП = Новый Массив;
	Для Каждого СтрокаЗаказа Из ТаблицаЗаказов Цикл
		
		Если МассивИдСБП.Найти(СтрокаЗаказа.ИдЗаказа) = Неопределено Тогда
			
			ПараметрыЗапроса.Вставить("order_id", СтрокаЗаказа.ИдЗаказа);
			
			РезультатОперации = Сбербанк_OrderRevokeQr(ПараметрыЗапроса);
			
			Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
				Возврат РезультатОперации;	
			КонецЕсли;
			
			МассивИдСБП.Добавить(СтрокаЗаказа.ИдЗаказа);
			
		КонецЕсли;
		
		ОписаниеСтатуса  = НСтр("ru='Платеж отменен пользователем ';en='Payment canceled by user '") + Строка(ПараметрыСеанса.ТекущийПользователь);
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаЗаказа.Основание,,,,
		Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ,,
		СтрокаЗаказа.НомерЗаказа,,,,,,,
		ОписаниеСтатуса);
		
	КонецЦикла;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Сбербанк order revoke qr
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
