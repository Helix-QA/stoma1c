
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтбиратьПоСтруктурнойЕдинице 	  = Истина;
	СтруктурнаяЕдиница                = Неопределено;
	ИспользоватьОграничениеПоРегистру = Истина;
	ОтбиратьВрачей					  = Ложь;
	Дата                              = Неопределено;  
	Сотрудник                         = Неопределено;
	Специализация                     = Неопределено; 
	ВыводитьПомеченныхНаУдаление      = Ложь;
	
	Параметры.Свойство("СтруктурнаяЕдиница"               , СтруктурнаяЕдиница);
	Параметры.Свойство("ИспользоватьОграничениеПоРегистру", ИспользоватьОграничениеПоРегистру);
	Параметры.Свойство("ОтбиратьВрачей"                   , ОтбиратьВрачей);
	Параметры.Свойство("ДатаДокумента"                    , Дата);
	Параметры.Свойство("Сотрудник"                        , Сотрудник);  
	Параметры.Свойство("Специализация"                    , Специализация);
	Параметры.Свойство("ВыводитьПомеченныхНаУдаление"     , ВыводитьПомеченныхНаУдаление);
	Параметры.Свойство("ОтбиратьПоСтруктурнойЕдинице"	  , ОтбиратьПоСтруктурнойЕдинице);
    	
	Если Параметры.Свойство("МножественныйВыбор") Тогда
		Элементы.Список.МножественныйВыбор = ?(НЕ Параметры.МножественныйВыбор = Неопределено, Параметры.МножественныйВыбор, Ложь);
	КонецЕсли;
	
	Если Параметры.Свойство("СписокВыбораСотрудников") Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список,"Ссылка",Параметры.СписокВыбораСотрудников,Истина,ВидСравненияКомпоновкиДанных.ВСписке);
	КонецЕсли;

	Если Параметры.Свойство("Сегмент") И ЗначениеЗаполнено(Параметры.Сегмент) Тогда  	
		СоставСегмента = РегистрыСведений.СотрудникиСегмента.ПолучитьСотрудниковСегмента(Параметры.Сегмент);
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Ссылка", СоставСегмента, Истина, ВидСравненияКомпоновкиДанных.ВСписке,, Ложь);  	
	КонецЕсли; 
	
	Если Параметры.Свойство("ИсключаемыеСотрудники") Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Ссылка", Параметры.ИсключаемыеСотрудники, Истина, ВидСравненияКомпоновкиДанных.НеВСписке,, Ложь);
	КонецЕсли;  
	
	Если Параметры.Свойство("Специализация") И ЗначениеЗаполнено(Параметры.Специализация) Тогда
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Ссылка", Параметры.Специализация, Истина, ВидСравненияКомпоновкиДанных.НеВСписке,, Ложь);
	КонецЕсли;
			
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Список.Параметры.УстановитьЗначениеПараметра("СтруктурнаяЕдиница"               , СтруктурнаяЕдиница);
	Список.Параметры.УстановитьЗначениеПараметра("ИспользоватьОграничениеПоРегистру", ИспользоватьОграничениеПоРегистру);
	Список.Параметры.УстановитьЗначениеПараметра("ОтбиратьВрачей"                   , ОтбиратьВрачей);
	Список.Параметры.УстановитьЗначениеПараметра("Дата"                             , ?(Дата <> Неопределено, Дата, ТекущаяДатаСеанса())); 
	Список.Параметры.УстановитьЗначениеПараметра("Сотрудник"                        , Сотрудник); 
	Список.Параметры.УстановитьЗначениеПараметра("Специализация"                    , Специализация); 
	Список.Параметры.УстановитьЗначениеПараметра("ВыводитьПомеченныхНаУдаление"     , ВыводитьПомеченныхНаУдаление);
	Список.Параметры.УстановитьЗначениеПараметра("ОтбиратьПоСтруктурнойЕдинице"		, ОтбиратьПоСтруктурнойЕдинице);
	
	Если НЕ Параметры.Свойство("БезОтбораПоРолям") Тогда
		
		Если Параметры.Свойство("ОтборБезВрачей") Тогда 
			ТекстЗамены = ?(Параметры.Свойство("ЭтоАссистент"), " И НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Ассистент)", ")");
		Иначе   			
			ТекстЗамены = "И (НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач) ИЛИ НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач)"; 
			ТекстЗамены = ТекстЗамены + ?(Параметры.Свойство("ЭтоАссистент"), " ИЛИ НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Ассистент))", ")");
		КонецЕсли;
	Иначе
		ТекстЗамены = "";
	КонецЕсли;           
	
	Если Параметры.Свойство("ПользователиМессенджера") И Параметры.ПользователиМессенджера = Истина Тогда
		
		УсловиеПользователиМессенджера =
		"И СправочникСотрудники.Ссылка В
		|	(ВЫБРАТЬ
		|		АктивныеПользователиМессенджер.Пользователь
		|	ИЗ
		|		РегистрСведений.АктивныеПользователиМессенджер КАК АктивныеПользователиМессенджер
		|	ГДЕ
		|		АктивныеПользователиМессенджер.Дата > &ДатаСреза)";
		Список.ТекстЗапроса = СтрЗаменить(Список.ТекстЗапроса, "И &УсловиеПользователиМессенджера", УсловиеПользователиМессенджера);
		Список.Параметры.УстановитьЗначениеПараметра("ДатаСреза", ТекущаяДатаСеанса() - (3600 * 24 * 31));
		
	Иначе
		Список.ТекстЗапроса = СтрЗаменить(Список.ТекстЗапроса, "И &УсловиеПользователиМессенджера", "");
		
	КонецЕсли;
	
	Список.ТекстЗапроса = СтрЗаменить(Список.ТекстЗапроса, "И &ОтборПоРолям", ТекстЗамены);
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти  
