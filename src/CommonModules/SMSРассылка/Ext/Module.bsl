// Функция - Получить предложение для пополения баланса смс сервиса
//
// Параметры:
//  СмсСервис	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредложениеДляПополенияБалансаСмсСервиса(СмсСервис) Экспорт
	
	РезультатаОперции = Неопределено;
	
	Попытка 
		
		ЗаголовкиHTTP = Новый Соответствие;	
		ЗаголовкиHTTP.Вставить("smsservicelogin", СмсСервис.Пользователь);		
		
		РезультатЗапроса  = ВыполнитьGETЗапрос("sms_service/recommendable_payment", ЗаголовкиHTTP);	
		РезультатаОперции = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса);
		
	Исключение
		
		РезультатаОперции = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке());
		
	КонецПопытки;
	
