// Создает 2 чека коррекции: сторно и корректный чек.
//
// Параметры:
//  Контекст - Структура - данные обработки Создание чеков коррекции.
// 
// Возвращаемое значение:
//   Структура - содержит свойства:
//     * ЧекКоррекцииСторно - ДокументСсылка.ЧекКоррекции - чек коррекции сторно.
//     * ЧекКоррекции - ДокументСсылка.ЧекКоррекции - чек коррекции.
//
Функция СоздатьЧекиКоррекции(Контекст) Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("ЧекКоррекцииСторно");
	Результат.Вставить("ЧекКоррекцииСторноПроведен");
	Результат.Вставить("ЧекСкорректированный");
	Результат.Вставить("ЧекСкорректированныйПроведен");
	
	Если НЕ ЗначениеЗаполнено(Контекст.ЧекСторно) Тогда
		РезультатЧекСторно = ЧекКоррекцииСторно(Контекст);
		Если РезультатЧекСторно <> Неопределено Тогда
			Результат.ЧекКоррекцииСторно 			= РезультатЧекСторно.ЧекКоррекцииСторно;
			Результат.ЧекКоррекцииСторноПроведен 	= РезультатЧекСторно.ЧекПроведен;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Контекст.ЧекСкорректированный) Тогда
		РезультатЧек = ЧекКоррекции(Контекст);
		Если РезультатЧек <> Неопределено Тогда
			Результат.ЧекСкорректированный 			= РезультатЧек.ЧекСкорректированный;
			Результат.ЧекСкорректированныйПроведен 	= РезультатЧек.ЧекПроведен;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Функция получает ставку НДС по значению ставки.
//
Функция ПолучитьСтавкуНДСПоЗначениюСтавки(ЗначениеСтавкиНДС) Экспорт
	
	Если ЗначениеСтавкиНДС = Неопределено Тогда
		Возврат Перечисления.СтавкиНДС.БезНДС;
	Иначе
		
		Попытка
			ЗначениеСтавкиНДС = Число(ЗначениеСтавкиНДС);
		Исключение
			Возврат  Перечисления.СтавкиНДС.БезНДС;			
		КонецПопытки;    		
			
		СоответствиеСтавокНДС = Новый Соответствие;
		СоответствиеСтавокНДС.Вставить(0	, Перечисления.СтавкиНДС.НДС0);
		СоответствиеСтавокНДС.Вставить(10	, Перечисления.СтавкиНДС.НДС10);
		СоответствиеСтавокНДС.Вставить(18	, Перечисления.СтавкиНДС.НДС18);
		СоответствиеСтавокНДС.Вставить(20	, Перечисления.СтавкиНДС.НДС20);
		
		Результат = СоответствиеСтавокНДС.Получить(ЗначениеСтавкиНДС);
		Если Результат = Неопределено Тогда
			Возврат Перечисления.СтавкиНДС.БезНДС;
		Иначе
			Возврат Результат;
		КонецЕсли;     		                                       
	КонецЕсли;   	
	
	Возврат Перечисления.СтавкиНДС.БезНДС;
	
КонецФункции       

&НаСервере
// Заполняет чек коррекции на основании.
//
// Параметры:
//  Основание - ДокументСсылка - документ основание для создания чека коррекции.
//  Отказ - Булево - признак отказа от выполнения операции.
//
Функция ПолучитьДанныеЧекаКоррекцииНаОсновеФискальнойОперации(Результат, Параметры) Экспорт
	
	Если ТипЗнч(Параметры) <> Тип("Структура")
		Или (ТипЗнч(Параметры) = Тип("Структура")
		И (Не Параметры.Свойство("Касса")
		Или Не Параметры.Свойство("ТипКоррекции")
		Или Не Параметры.Свойство("НомерПредписания") 
		Или Не Параметры.Свойство("ОписаниеКоррекции")
		Или Не Параметры.Свойство("Комментарий"))) Тогда
		
		Возврат Неопределено;
	КонецЕсли;
			
	ФискальнаяОперация = Результат.ДанныеФискальнойОперации;
	
	Если ФискальнаяОперация = Неопределено Тогда
		
		ТекстСообщения = НСтр("ru = 'Нет сохраненной фискальной операции для документа'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		// Отказ = Истина;
		Возврат Неопределено;
		
	ИначеЕсли ФискальнаяОперация.ЕстьКорректирующийДокумент Тогда
		
		ТекстСообщения = НСтр("ru = 'По данному документу ранее была создана корректировка документом %1. 
		|Создание повторной корректировки не возможно.'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, 
		ФискальнаяОперация.ЧекКоррекции);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		// Отказ = Истина;
		Возврат Неопределено;
		
	КонецЕсли;
	
	Объект = ПолучитьСтруктуруДанных();
	
	Основание = ФискальнаяОперация.ДокументОснование;

	ЗаполнитьЗначенияСвойств(Объект, ФискальнаяОперация);
	
	Для Каждого ЭлементМ Из ФискальнаяОперация.МассивОснований Цикл
		НоваяСтрока = ПолучитьСтруктуруТаблицаОснований();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
		Объект.ТаблицаОснований.Добавить(НоваяСтрока);
		Если ТипЗнч(НоваяСтрока.ДокументОснование) = Тип("ДокументСсылка.Реализация")
			Или ТипЗнч(НоваяСтрока.ДокументОснование) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
			
			Если ФискальнаяОперация.МассивУчтенныеАвансы.Количество() > 0 Тогда
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ФискальнаяОперация.МассивУчтенныеАвансы[0]);
				НоваяСтрока.ИдентификаторФискальнойЗаписи = ФискальнаяОперация.МассивУчтенныеАвансы[0].ИдентификаторЗаписи;  
				Для Индекс = 1 По ФискальнаяОперация.МассивУчтенныеАвансы.Количество() - 1 Цикл
					// НоваяСтрока = Объект.ТаблицаОснований.Добавить();
					НоваяСтрока = ПолучитьСтруктуруТаблицаОснований();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ФискальнаяОперация.МассивУчтенныеАвансы[Индекс]); 
					НоваяСтрока.ИдентификаторФискальнойЗаписи = ФискальнаяОперация.МассивУчтенныеАвансы[Индекс].ИдентификаторЗаписи;
					Объект.ТаблицаОснований.Добавить(НоваяСтрока);
				КонецЦикла; 				
			КонецЕсли;	
			
		КонецЕсли;		
	КонецЦикла;
		
	Объект.Дата								= ТекущаяДатаСеанса();
	Объект.АвторДокумента 					= ОбщегоНазначенияСтоматология.ТекущийПользователь();
	Объект.ДатаКоррекции 					= ФискальнаяОперация.ДатаРасчета;
	Объект.ДополнительныйРеквизит 			= ФискальнаяОперация.ФискальныйПризнак;
	Объект.ДанныеXMLКорректируемогоЧека		= ФискальнаяОперация.ДанныеXML.Получить();
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств")
		Или ТипЗнч(Основание) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда
		Объект.ВидОперации = Основание.ВидОперации;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.Реализация") Тогда
		Объект.ВидОперации = Перечисления.ВидыОпераций.Продажа;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		Объект.ВидОперации = Перечисления.ВидыОпераций.Возврат;
	КонецЕсли;
	
	ОбщиеПараметры = МенеджерОборудованияВызовСервера.ЗагрузитьДанныеФискализацииИзXML(Объект.ДанныеXMLКорректируемогоЧека);
	
	ЗаполнитьЗначенияСвойств(Объект, ОбщиеПараметры, "СистемаНалогообложения, ТипРасчета, Кассир, КассирИНН");
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЧекКоррекции") Тогда
		Объект.Контрагент		= Основание.Покупатель;
		Объект.КонтрагентИНН	= Основание.ПокупательИНН;
	Иначе
		Объект.Контрагент		= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Основание			, "Контрагент");
		Объект.КонтрагентИНН	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Контрагент	, "ИНН");
	КонецЕсли;
			
	Объект.СНОКорректируемогоДокумента = ОбщиеПараметры.СистемаНалогообложения;
	Объект.ПризнакАгента 			   = ОбщиеПараметры.ПризнакАгента;
	
	Обработки.СозданиеЧековКоррекции.ПолучитьДанныеДляПробитияЧекаККМ(ФискальнаяОперация.ДокументОснование, ОбщиеПараметры);
	ЗаполнитьПозицииЧекаПоОбщимПараметрамСНоменклатурой(Объект, ОбщиеПараметры);
	
	// Оплаты
	Для Каждого СтрокаОплаты Из ОбщиеПараметры.ТаблицаОплат Цикл
		НоваяСтрока = ПолучитьСтруктуруОплаты();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОплаты);//,, "ТипОплаты"
		Объект.Оплата.Добавить(НоваяСтрока);
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(Объект, Параметры, "Касса, ТипКоррекции, НомерПредписания, ОписаниеКоррекции, Комментарий");
	
	Возврат Объект;
	
КонецФункции

