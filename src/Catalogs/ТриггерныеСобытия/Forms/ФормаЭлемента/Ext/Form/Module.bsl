// Процедура - Сформировать описание триггерного события
//
Процедура СформироватьОписаниеТриггерногоСобытия()
	
	СписокОписаний = ОбщегоНазначенияПовтИсп.ПолучитьОписанияТриггеров();			
	
	Если НЕ ЗначениеЗаполнено(СокрЛП(Объект.Описание)) Тогда 
		ЭлементСпискаОписания = СписокОписаний.НайтиПоЗначению(Объект.УсловиеСобытия);
		Если ЭлементСпискаОписания <> Неопределено Тогда 
			Объект.Описание = ЭлементСпискаОписания.Представление; 
		КонецЕсли;
	Иначе 
		Для Каждого ЭлементСпискаОписания Из СписокОписаний Цикл 
			Если СтрЗаменить(СокрЛП(Объект.Описание), ".", "") = СтрЗаменить(ЭлементСпискаОписания.Представление, ".", "") И ЭлементСпискаОписания.Значение <> Объект.УсловиеСобытия Тогда 
				ЭлементСпискаОписания = СписокОписаний.НайтиПоЗначению(Объект.УсловиеСобытия);
				Если ЭлементСпискаОписания <> Неопределено Тогда
					Объект.Описание = ЭлементСпискаОписания.Представление;
				Иначе 
					Объект.Описание = "";
				КонецЕсли;
				Прервать;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;	
	СформироватьДекорациюОписаниеТриггерногоСобытия();
	
КонецПроцедуры

