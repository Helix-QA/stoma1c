// Работа с XML

// Процедура записывает НЕ произвольный набор (формат) ключей структуры
Процедура	ЗаписатьИзСтруктурыВXML(ПутьКФайлу,Структура)	Экспорт
	
	// НЕТ Исключения о недостаче прав к записи и прочее
	
	ЗаписьНастройкиXML = Новый ЗаписьXML;
		ЗаписьНастройкиXML.ОткрытьФайл(ПутьКФайлу);
		ЗаписьНастройкиXML.ЗаписатьОбъявлениеXML();
		ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("DatabaseBackupConfiguration");
		// Основное
			ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("Database");
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("DB_ID");
					ЗаписьНастройкиXML.ЗаписатьТекст(Структура.Строки.DatabaseBackupConfiguration.Строки.DataBase.Строки.DB_ID.Значение);
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("DBName");
					ЗаписьНастройкиXML.ЗаписатьТекст(Структура.Строки.DatabaseBackupConfiguration.Строки.DataBase.Строки.DBName.Значение);
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();				
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("DBFolder");
					ЗаписьНастройкиXML.ЗаписатьТекст(Структура.Строки.DatabaseBackupConfiguration.Строки.DataBase.Строки.DBFolder.Значение);
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();									
			ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();
			
		// Расписание
			ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("Schedule");
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("Time");
					ЗаписьНастройкиXML.ЗаписатьТекст(Структура.Строки.DatabaseBackupConfiguration.Строки.Schedule.Строки.Time.Значение);
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();			
			ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();
			
		// Расписание хранения
			ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("RetentionRule");
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("Daily");
					ЗаписьНастройкиXML.ЗаписатьТекст(СокрЛП(Структура.Строки.DatabaseBackupConfiguration.Строки.RetentionRule.Строки.Daily.Значение));
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();			
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("Weekly");
					ЗаписьНастройкиXML.ЗаписатьТекст(СокрЛП(Структура.Строки.DatabaseBackupConfiguration.Строки.RetentionRule.Строки.Weekly.Значение));
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();			
				ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("Monthly");
					ЗаписьНастройкиXML.ЗаписатьТекст(СокрЛП(Структура.Строки.DatabaseBackupConfiguration.Строки.RetentionRule.Строки.Monthly.Значение));
				ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();			
			ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();
			
			ЗаписьНастройкиXML.ЗаписатьНачалоЭлемента("UseIt");
				ЗаписьНастройкиXML.ЗаписатьТекст(Структура.Строки.DatabaseBackupConfiguration.Строки.UseIt.Значение);
			ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();			
		ЗаписьНастройкиXML.ЗаписатьКонецЭлемента();
		
		ЗаписьНастройкиXML.Закрыть();
	
КонецПроцедуры

// Функция возвращает структуру со всеми значениями XML из файла по пути "ПутьКФайлу"
Функция 	ЗаполнитьСтруктуруИзXML(ПутьКФайлу)	Экспорт
	
	// Нет исключения и обработки ошибки в случае отсутствия доступа к файлу
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ПутьКФайлу);
	
	СтруктураИзXML = Новый Структура("Элемент,Значение,Атрибуты,Строки","xml", , ,Новый Структура());
	ОбработатьВнутрилежащие(ЧтениеXML,СтруктураИзXML);
	
	ЧтениеXML.Закрыть();

	Возврат СтруктураИзXML;
	
КонецФункции

// + Процедура обрабатывает рекурсивно данные XML и добавляют в структуру "СтруктураXML" в элемент "Строки"
Процедура 	ОбработатьВнутрилежащие(ЧтениеXML,СтруктураXML)	Экспорт
 
	Пока ЧтениеXML.Прочитать() Цикл
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			пСТрока = Новый Структура("Элемент,Значение,Атрибуты,Строки",ЧтениеXML.Имя,"",,Новый Структура());
			СтруктураXML.Строки.Вставить(ЧтениеXML.Имя,пСтрока);			
			ОбработатьВнутрилежащие(ЧтениеXML,пСтрока);
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.Текст И ЧтениеXML.ИмеетЗначение Тогда
			СтруктураXML.Значение = ЧтениеXML.Значение;
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
			Возврат;
		КонецЕсли;  
	КонецЦикла;
 
КонецПроцедуры

 
