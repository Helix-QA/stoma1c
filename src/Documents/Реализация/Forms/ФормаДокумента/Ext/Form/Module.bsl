// Процедура, Подключаемый декорация формы представление нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ДекорацияФормы_Представление_Нажатие_Промокода(Элемент)	
	
	СтруктураПромокода = ПолучитьДанныеПромокода(Объект.Промокод, Объект.Контрагент);	
	
	Если СтруктураПромокода.ПромокодСуществует Тогда         
		
		КлючСтруктурой = Новый Структура;
		КлючСтруктурой.Вставить("Вид"		, СтруктураПромокода.ВидПромокода);
		КлючСтруктурой.Вставить("Владелец"	, СтруктураПромокода.Владелец);
		ПараметрыМассив = Новый Массив;
		ПараметрыМассив.Добавить(КлючСтруктурой);   				
		КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.Промокоды", ПараметрыМассив);
		ОткрытьФорму("РегистрСведений.Промокоды.Форма.ФормаЗаписи", 
					 Новый Структура("Ключ, ПросмотрЗаписи", КлючЗаписиРегистра, Истина),,,,,, 
					 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);				
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураПромокода.ТекстОшибки); 
		
	КонецЕсли;
	
КонецПроцедуры

