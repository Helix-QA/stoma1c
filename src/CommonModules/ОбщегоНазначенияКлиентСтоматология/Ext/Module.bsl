
#Область СлужебныйПрограммныйИнтерфейс

// Открывает форму редактирования произвольного многострочного текста модально
//
// Параметры:
// МногострочныйТекст      - Строка - произвольный текст, который необходимо отредактировать
// РезультатРедактирования - Строка - переменная, в которую будет помещен результат редактирования
// Модифицированность       - Строка - флаг модифицированности формы
// Заголовок               - Строка - текст, который необходимо отобразить в заголовке формы
//
Процедура ОткрытьФормуРедактированияМногострочногоТекста(Знач МногострочныйТекст, РезультатРедактирования, Модифицированность = Ложь, 
	Знач Заголовок = "") Экспорт
	
	Оповещение = Новый ОписаниеОповещения("ПослеВводаСтроки", ЭтотОбъект);	
	Если Заголовок = Неопределено Тогда
		ПоказатьВводСтроки(Оповещение, МногострочныйТекст,,, Истина);
	Иначе
		ПоказатьВводСтроки(Оповещение, МногострочныйТекст, Заголовок,, Истина);
	КонецЕсли;
	
	
КонецПроцедуры

Процедура ПослеВводаСтроки(Строка, Параметры) Экспорт
	
	Если Не Строка = Неопределено Тогда 
		РезультатРедактирования = Строка;
		// Если Не Модифицированность Тогда
		// 	Модифицированность = Истина;
		// КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Открывает форму редактирования многострочного комментария модально
//
// Параметры:
// МногострочныйТекст      - Строка - произвольный текст, который необходимо отредактировать
// РезультатРедактирования - Строка - переменная, в которую будет помещен результат редактирования
// Модифицированность       - Строка - флаг модифицированности формы
//
Процедура ОткрытьФормуРедактированияКомментария(Знач МногострочныйТекст, РезультатРедактирования,
	Модифицированность = Ложь) Экспорт
	
	ОткрытьФормуРедактированияМногострочногоТекста(МногострочныйТекст, РезультатРедактирования, Модифицированность, 
		НСтр("ru='Комментарий'"));
	
КонецПроцедуры

// Функция разворачивает все элементы дерева значений
// 
//  Параметры
//   Элемент - Элемент дерева, элементы которого необходимо развернуть
//   Дерево - ДеревоЗначений,
//
Процедура РазвернутьДерево(Элемент, Дерево,РазвернутьПодчиненные = Истина) Экспорт	
    Для Каждого СтрокаЭлемента Из Дерево.ПолучитьЭлементы() Цикл
        Элемент.Развернуть(СтрокаЭлемента.ПолучитьИдентификатор(), РазвернутьПодчиненные);
	КонецЦикла;	
КонецПроцедуры

// Функция сворачивает все элементы дерева значений
// 
//  Параметры
//   Элемент - Элемент дерева, элементы которого необходимо развернуть
//   Дерево - ДеревоЗначений,
//
Процедура СвернутьДерево(Элемент, Дерево,СвернутьПодчиненные = Истина) Экспорт	
    Для Каждого СтрокаЭлемента Из Дерево.ПолучитьЭлементы() Цикл
        Элемент.Свернуть(СтрокаЭлемента.ПолучитьИдентификатор());
		Если СвернутьПодчиненные Тогда
		     СвернутьДерево(Элемент, СтрокаЭлемента,СвернутьПодчиненные);
		КонецЕсли;
	КонецЦикла;	
КонецПроцедуры
                               
// Процедура, выполняет открытие кассвой смены для розничных продаж.
//  Параметры:
//   КассаККМ - справочникСсылка.КассыККМ, кассаККМ, для которой выполняется открытие кассовой смены.
//   УИД      - уникальный идентификатор объекта.
//
Процедура ОткрытьКассовуюСмену(Касса, УИД, ОткрытьДок = Истина) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Касса) Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Ложь;
	ОписаниеОшибки = "";
	
	ОчиститьСообщения();
	
	Результат = ОбщегоНазначенияСтоматология.ОткрытьКассовуюСменуНаСервереБезКонтекста(Касса, ОписаниеОшибки);
	
	Если Не Результат Тогда		
		ТекстСообщения = НСтр("ru = 'При открытии смены произошла ошибка.
		|Смена не открыта.
		|Дополнительное описание:
		|%ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОткрытьДок = Ложь;	
	КонецЕсли;

	Оповестить("ОткрытиеЗакрытиеКассовойСмены", Новый Структура("Касса", Касса));
		
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		
		// Подключение устройства
		ПараметрыКассы = МенеджерОборудованияВызовСервера.ПолучитьПараметрыКассы(Касса);
		ИдентификаторУстройства                = ПараметрыКассы.ИдентификаторУстройства;
		ИспользоватьБезПодключенияОборудования = ПараметрыКассы.ИспользоватьБезПодключенияОборудования;
		
		Если ИдентификаторУстройства <> Неопределено ИЛИ ИспользоватьБезПодключенияОборудования Тогда
			
			ОписаниеОшибки = "";
			
			Если Не ИспользоватьБезПодключенияОборудования Тогда
				
				Результат = МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УИД,
				ИдентификаторУстройства,
				ОписаниеОшибки);
				
			КонецЕсли;
			
			Если Результат ИЛИ ИспользоватьБезПодключенияОборудования Тогда
				
				Если Не ИспользоватьБезПодключенияОборудования Тогда
					
					ВходныеПараметры  = Новый Структура;
					ВыходныеПараметры = Неопределено;
					
					// Открыть смену на фискальном регистраторе
					Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства,
					"OpenDay",
					ВходныеПараметры,
					ВыходныеПараметры);
					
				КонецЕсли;
				
				Если Результат ИЛИ ИспользоватьБезПодключенияОборудования Тогда
					
					Результат = ОбщегоНазначенияСтоматология.ОткрытьКассовуюСменуНаСервереБезКонтекста(Касса, ОписаниеОшибки);
					
					Если Не Результат Тогда
						
						ТекстСообщения = НСтр("ru = 'При открытии смены произошла ошибка.
						|Смена не открыта.
						|Дополнительное описание:
						|%ДополнительноеОписание%'");
						ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
						// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
						ОткрытьДок = Ложь;
					КонецЕсли;
					
				Иначе
					ТекстСообщения = НСтр("ru = 'При открытии смены произошла ошибка.
					|Смена не открыта на фискальном регистраторе.
					|Дополнительное описание:
					|%ДополнительноеОписание%'");
					ТекстСообщения = СтрЗаменить(ТекстСообщения,
					"%ДополнительноеОписание%",
					ВыходныеПараметры[1]);
					// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
					ОткрытьДок = Ложь;
					
				КонецЕсли;
				
				Если Не ИспользоватьБезПодключенияОборудования Тогда
					
					МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УИД,
					ИдентификаторУстройства);
					
				КонецЕсли;
				
			Иначе
				
				ТекстСообщения = НСтр("ru = 'При подключении устройства произошла ошибка.
				|Смена не открыта на фискальном регистраторе.
				|Дополнительное описание:
				|%ДополнительноеОписание%'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
				// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				ОткрытьДок = Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ТекстСообщения = НСтр("ru = 'Предварительно необходимо выбрать рабочее место внешнего оборудования текущего сеанса.'");
		// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОткрытьДок = Ложь;
	КонецЕсли;

	
	
КонецПроцедуры

// Процедура, выполняет закрытие кассвой смены для розничных продаж.
//  Параметры:
//   КассаККМ - справочникСсылка.КассыККМ, кассаККМ, для которой выполняется закрытие кассовой смены.
//   УИД      - уникальный идентификатор объекта.
//
Процедура ЗакрытьКассовуюСмену(Касса, УИД) Экспорт
	
	ОчиститьСообщения();
	
	Если НЕ ЗначениеЗаполнено(Касса) Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Ложь;
	ОшибкаПриСнятииZОтчета = Ложь;
	
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		
		// Подключение устройства
		ПараметрыКассы = МенеджерОборудованияВызовСервера.ПолучитьПараметрыКассы(Касса);
		ИдентификаторУстройства                = ПараметрыКассы.ИдентификаторУстройства;
		ИспользоватьБезПодключенияОборудования = ПараметрыКассы.ИспользоватьБезПодключенияОборудования;
		
		Если ИдентификаторУстройства <> Неопределено ИЛИ ИспользоватьБезПодключенияОборудования Тогда
			
			ОписаниеОшибки = "";
			
			Если Не ИспользоватьБезПодключенияОборудования Тогда
				
				Результат = МенеджерОборудованияКлиент.ПодключитьОборудованиеПоИдентификатору(УИД,
				                                                                              ИдентификаторУстройства,
				                                                                              ОписаниеОшибки);
				
			КонецЕсли;
		
			Если Результат ИЛИ ИспользоватьБезПодключенияОборудования Тогда
				
				Если Не ИспользоватьБезПодключенияОборудования Тогда
					
					ВходныеПараметры  = Новый Структура;
					ВыходныеПараметры = Неопределено;
					
					Результат = МенеджерОборудованияКлиент.ВыполнитьКоманду(ИдентификаторУстройства,
					                                                        "PrintZReport",
					                                                        ВходныеПараметры,
					                                                        ВыходныеПараметры);
					
				КонецЕсли;
				
				СтруктураПараметров = Новый Структура("Результат, Касса, УИД, ИдентификаторУстройства, ИспользоватьБезПодключенияОборудования,ВыходныеПараметры,ОписаниеОшибки", 
				Результат, Касса,УИД,ИдентификаторУстройства,ИспользоватьБезПодключенияОборудования,ВыходныеПараметры,ОписаниеОшибки); 
				
				Если Не Результат И Не ИспользоватьБезПодключенияОборудования Тогда
					
					ТекстВопроса = НСтр("ru = 'При снятии отчета на фискальном регистраторе произошла ошибка.
					                    |""%ОписаниеОшибки%""
					                    |
					                    |Если смена на фискальном регистраторе закрыта, то
					                    |нажмите ""Да"" для формирования отчета о розничных продажах.
					                    |
					                    |Закрыть смену?'");
					ТекстВопроса = СтрЗаменить(ТекстВопроса, "%ОписаниеОшибки%", ВыходныеПараметры[1]);
					
					ПоказатьВопрос(Новый ОписаниеОповещения("ЗакрытьКассовуюСменуПослеВопроса", ЭтотОбъект, СтруктураПараметров),ТекстВопроса,РежимДиалогаВопрос.ДаНет,,КодВозвратаДиалога.Нет);
                    Возврат;
					
				КонецЕсли;
				
				ЗакрытьКассовуюСменуЗавершение(СтруктураПараметров);
				
			Иначе
				
				ТекстСообщения = НСтр("ru = 'При подключении устройства произошла ошибка.
				                            |Отчет не напечатан и смена не закрыта на фискальном регистраторе.
				                            |Дополнительное описание:
				                            |%ДополнительноеОписание%'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
				// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ТекстСообщения = НСтр("ru = 'Предварительно необходимо выбрать рабочее место внешнего оборудования текущего сеанса.'");
		// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	Оповестить("ОткрытиеЗакрытиеКассовойСмены", Новый Структура("Касса", Касса));
	
КонецПроцедуры

// Процедура - Закрыть кассовую смену после вопроса
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЗакрытьКассовуюСменуПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
		
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ДополнительныеПараметры.Результат = Истина;
	КонецЕсли;

	ЗакрытьКассовуюСменуЗавершение(ДополнительныеПараметры,Истина);

	Оповестить("ОткрытиеЗакрытиеКассовойСмены", Новый Структура("Касса", ДополнительныеПараметры.Касса));

КонецПроцедуры  

// Процедура - Закрыть кассовую смену завершение
//
// Параметры:
//  СтруктураПараметров		 - 	 - 
//  ОшибкаПриСнятииZОтчета	 - 	 - 
//
Процедура ЗакрытьКассовуюСменуЗавершение(СтруктураПараметров,ОшибкаПриСнятииZОтчета = Ложь) Экспорт
	
	Результат                               = СтруктураПараметров.Результат;
	Касса                                   = СтруктураПараметров.Касса;
	УИД                                     = СтруктураПараметров.УИД;
	ИдентификаторУстройства                 = СтруктураПараметров.ИдентификаторУстройства;
	ИспользоватьБезПодключенияОборудования  = СтруктураПараметров.ИспользоватьБезПодключенияОборудования;
	ВыходныеПараметры                       = СтруктураПараметров.ВыходныеПараметры;
	ОписаниеОшибки                          = СтруктураПараметров.ОписаниеОшибки;

	Если Не Результат И Не ИспользоватьБезПодключенияОборудования Тогда
		
		ТекстСообщения = НСтр("ru = 'При снятии отчета на фискальном регистраторе произошла ошибка.
		|""%ОписаниеОшибки%""
		|Отчет на фискальном регистраторе не сформирован.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ВыходныеПараметры[1]);
		// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		
		МассивДокументов = ОбщегоНазначенияСтоматология.ЗакрытьКассовуюСменуНаСервереБезКонтекста(Касса, ОшибкаПриСнятииZОтчета, ОписаниеОшибки);
		
		// Все результирующие документы выводим пользователю.
		Если МассивДокументов <> Неопределено Тогда
			
			ОписаниеОповещенияПродолжитьПоказ = Новый ОписаниеОповещения("ПродолжитьПоказРезультирующихДокументов",ЭтотОбъект,
			Новый Структура("МассивДокументов,УИД,ИдентификаторУстройства,ОписаниеОшибки,ИспользоватьБезПодключенияОборудования",
			МассивДокументов, УИД, ИдентификаторУстройства, ОписаниеОшибки, ИспользоватьБезПодключенияОборудования));
			
			ПоказатьЗначение(ОписаниеОповещенияПродолжитьПоказ,МассивДокументов[0]);
            Возврат;
			
		КонецЕсли;
		
		// Текст ошибки должен появиться в окне открытого документа.
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'Смена закрыта на фискальном регистраторе.
			|Дополнительное описание:
			|%ДополнительноеОписание%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
			// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ИспользоватьБезПодключенияОборудования Тогда
		
		МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(УИД,
		ИдентификаторУстройства);
		
	КонецЕсли;

КонецПроцедуры 

// Процедура - Продолжить показ результирующих документов
//
// Параметры:
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПродолжитьПоказРезультирующихДокументов(ДополнительныеПараметры) Экспорт
	
	МассивДокументов = ДополнительныеПараметры.МассивДокументов;
	
	Если МассивДокументов.Количество() = 0 Тогда 
		ДополнительныеПараметры.Удалить("МассивДокументов");
		ПослеВыводаРезультирующихДокументов(ДополнительныеПараметры);
		Возврат;
	Иначе
		МассивДокументов.Удалить(0);
		ДополнительныеПараметры.МассивДокументов = МассивДокументов;
	КонецЕсли;

	Если МассивДокументов.Количество() = 0 Тогда
		ДополнительныеПараметры.Удалить("МассивДокументов");
		ПослеВыводаРезультирующихДокументов(ДополнительныеПараметры)
	Иначе
		
		ОписаниеОповещенияПродолжитьПоказ = Новый ОписаниеОповещения("ПродолжитьПоказРезультирующихДокументов",ЭтотОбъект,ДополнительныеПараметры);
		Документ = МассивДокументов[0];		
		ПоказатьЗначение(ОписаниеОповещенияПродолжитьПоказ,Документ);
		
	КонецЕсли;

КонецПроцедуры   

// Процедура - После вывода результирующих документов
//
// Параметры:
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыводаРезультирующихДокументов(ДополнительныеПараметры) Экспорт
	
	// Текст ошибки должен появиться в окне открытого документа.
	Если ЗначениеЗаполнено(ДополнительныеПараметры.ОписаниеОшибки) Тогда
		ТекстСообщения = НСтр("ru = 'Смена закрыта на фискальном регистраторе.
		|Дополнительное описание:
		|%ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ДополнительныеПараметры.ОписаниеОшибки);
		// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	Если Не ДополнительныеПараметры.ИспользоватьБезПодключенияОборудования Тогда
		
		МенеджерОборудованияКлиент.ОтключитьОборудованиеПоИдентификатору(ДополнительныеПараметры.УИД,
		ДополнительныеПараметры.ИдентификаторУстройства);
		
	КонецЕсли;

КонецПроцедуры

// Процедура обновляет состояние документа.
//  Параметры:
//   Объект - документа, у которого изменяется статус;
//   СостояниеДокумента - состояние документа, строка которая содержит статус документа.
//   КартинкаСостоянияДокумента - картинка, которая отображает статус документа.
//   РазрешеноПроведение - булево, признак возможности проведения.
//
Процедура ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение) Экспорт
	
	Если Объект.Проведен Тогда
		СостояниеДокумента = "Проведен";
		КартинкаСостоянияДокумента = 1;
	ИначеЕсли РазрешеноПроведение Тогда
		СостояниеДокумента = "Не проведен";
		КартинкаСостоянияДокумента = 0;
	Иначе
		СостояниеДокумента = "Записан";
		КартинкаСостоянияДокумента = 3;
	КонецЕсли;
	
КонецПроцедуры // ОбновитьСостояниеДокумента()

// Заменяет недопустимые символы XML на другой символ
//
// Параметры:
//	Текст - Строка
//	СимволЗамены - Строка
//   
Функция ЗаменитьНедопустимыеСимволыXML(Знач Текст, СимволЗамены = " ") Экспорт
	
	#Если НЕ ВебКлиент Тогда
		
		СимволЗамены = "[cut]";
		
		Позиция = НайтиНедопустимыеСимволыXML(Текст);
		
		Пока Позиция > 0 Цикл
			Текст = СтрЗаменить(Текст, Сред(Текст, Позиция, 1), СимволЗамены);
			Позиция = НайтиНедопустимыеСимволыXML(Текст);
		КонецЦикла;
		
	#КонецЕсли
	
	Возврат Текст;
	
КонецФункции

// Получает значение реквизита формы
// Параметры:
//		Форма
//		ПутьРеквизита - строка, путь к данным, например: "Объект.МесяцНачисления"
Функция ПолучитьРеквизитФормыПоПути(Форма, ПутьРеквизита) Экспорт
	
	МассивИмен = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПутьРеквизита, ".");
	
	Объект        = Форма;
	ПоследнееПоле = МассивИмен[МассивИмен.Количество()-1];
	
	Для Сч = 0 По МассивИмен.Количество()-2 Цикл
		Объект = Объект[МассивИмен[Сч]]
	КонецЦикла;
	
	Возврат Объект[ПоследнееПоле];
	
КонецФункции

// Устанавливает значение реквизиту формы
// Параметры:
//		Форма
//		ПутьРеквизита - строка, путь к данным, например: "Объект.МесяцНачисления"
//		Значение
Процедура УстановитьРеквизитФормыПоПути(Форма, ПутьРеквизита, Значение, ТолькоЕслиНеЗаполнен = Ложь) Экспорт
	
	МассивИмен = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПутьРеквизита, ".");
	
	Объект        = Форма;
	ПоследнееПоле = МассивИмен[МассивИмен.Количество()-1];
	
	Для Сч = 0 По МассивИмен.Количество()-2 Цикл
		Объект = Объект[МассивИмен[Сч]]
	КонецЦикла;
	Если НЕ ТолькоЕслиНеЗаполнен ИЛИ НЕ ЗначениеЗаполнено(Объект[ПоследнееПоле]) Тогда
		Объект[ПоследнееПоле] = Значение;
	КонецЕсли;
	
КонецПроцедуры

