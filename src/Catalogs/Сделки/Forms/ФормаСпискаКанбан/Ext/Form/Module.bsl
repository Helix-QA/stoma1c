// Функция, возвращает блок сделки.
//
Функция ПолучитьБлокСделки(ДанныеСделки)
	
	Если ДанныеСделки = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ПредставлениеДатыСоздания				 = ПолучитьПредставлениеДаты(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеСделки, "ДатаСделки", ""));
	
	ИдентификаторСделки						 = XMLСтрока(ДанныеСделки.Сделка);
	ПредставлениеСделки						 = ДанныеСделки.ПредставлениеСделки + ПредставлениеДатыСоздания;
	ПредставлениеКлиента					 = ДанныеСделки.ПредставлениеКлиента;
	ИдентификаторКлиента					 = XMLСтрока(ДанныеСделки.Клиент);
	НомераТелефоновКлиента					 = СтрРазделить(ДанныеСделки.НомерТелефона, ",", Ложь);
	
	ИдентификаторПричиныОтказа				 = Строка(ДанныеСделки.ПричинаОтказа.УникальныйИдентификатор());
	ПредставлениеПричиныОтказа				 = ДанныеСделки.ПричинаОтказаНаименование;
	
	КлассПометкиУдаления					 = ?(ДанныеСделки.ПометкаУдаления, " deleted", "");
	
	ИдентификаторВрача						 = XMLСтрока(ДанныеСделки.Врач);
	ПредставлениеВрача						 = ДанныеСделки.ПредставлениеВрача;
	ПредставлениеСпециализации				 = ДанныеСделки.ПредставлениеСпециализации;
	Примечание								 = ДанныеСделки.Примечание;
	ИдентификаторКуратора					 = XMLСтрока(ДанныеСделки.Куратор);
	ПредставлениеКуратора					 = ДанныеСделки.ПредставлениеКуратора;
	ПредставлениеРекламногоИсточника		 = ДанныеСделки.ПредставлениеРекламногоИсточника;
	ПредставлениеЗначенияКаналаПривлечения	 = ?(ЗначениеЗаполнено(ДанныеСделки.ПредставлениеЗначенияКаналаПривлечения), " - " + ДанныеСделки.ПредставлениеЗначенияКаналаПривлечения, "");
	ПредставлениеКаналаПривлечения			 = ДанныеСделки.ПредставлениеКаналаПривлечения + ПредставлениеЗначенияКаналаПривлечения;
	Комментарий								 = ДанныеСделки.Комментарий;
	
	СтатусПациента							 = ДанныеСделки.СтатусПациента;
	ЭтоПервыйВизит							 = (ДанныеСделки.ЭтоПовторныйПрием = Ложь);
	
	КоличествоЗадач							 = ДанныеСделки.КоличествоЗадач;
	НаправившийВрач							 = ?(ЗначениеЗаполнено(ДанныеСделки.НаправившийВрач), НСтр("ru = 'По направлению от '") + ДанныеСделки.НаправившийВрач, "");
	
	БлокНомеров = "";
	Для Каждого НомерТелефона Из НомераТелефоновКлиента Цикл
		БлокНомера = "<div class='phone-number'>" + НомерТелефона + "</div>";
		БлокНомеров = БлокНомеров + БлокНомера;
	КонецЦикла;
	
	БлокСделки =
	"			<div class='item-col" + КлассПометкиУдаления + "' id='" + ИдентификаторСделки + "'>
	|				<div class='deletion-mark'>Удалена</div>
	|				<div class='head-col'>
	|					<div class='deal-row'>
	|						<div class='title-col' data-deal-id='" + ИдентификаторСделки + "' title='" + ПредставлениеСделки + "'>" + ПредставлениеСделки + "</div>
	|						<div class='container-row'>
	|							<div class='ico-chat' title='Перейти к диалогу'></div>
	|						</div>
	|					</div>
	|				</div>
	|				<div class='referred-from'>" + НаправившийВрач + "</div>
	|				<div class='visit-type" + ?(ЭтоПервыйВизит, " first", "") + "'></div>
	|				<div class='deny-reason' id='" + ИдентификаторПричиныОтказа + "' title='" + ПредставлениеПричиныОтказа + "'>" + ПредставлениеПричиныОтказа + "</div>
	|				<div class='client-status" + ?(СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный, " new", "") + "'>" + СтатусПациента + "</div>
	|				<div class='client-name' id='" + ИдентификаторКлиента + "'>" + ПредставлениеКлиента + "</div>" +
	БлокНомеров + "
	|				<div class='manager' title='" + ПредставлениеКуратора + "' id='" + ИдентификаторКуратора + "'>" + ПредставлениеКуратора + "</div>
	|				<div class='doctor' title='" + ПредставлениеВрача + "' id='" + ИдентификаторВрача + "'>" + ПредставлениеВрача + "</div>
	|				<div class='specialization'>" + ПредставлениеСпециализации + "</div>
	|				<div class='note'>" + Примечание + "</div>
	|				<div class='ad-source'>" + ПредставлениеРекламногоИсточника + "</div>
	|				<div class='channel'>" + ПредставлениеКаналаПривлечения + "</div>
	|				<div class='comment' title='" + Комментарий + "'>" + Комментарий + "</div>
	|				<div class='tasks'>
	|					<div class='current-tasks' data-task-count='" + КоличествоЗадач + "'></div>
	|					<div class='create-task'>+ Запланировать</div>
	|					<div class='menu'>
	|						<div class='menu-container'></div>
	|					</div>
	|				</div>
	|			</div>";
	
	Возврат БлокСделки;
	
КонецФункции

