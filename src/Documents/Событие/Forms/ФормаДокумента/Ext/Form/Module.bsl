				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВнутреннийНомерСотрудника) Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ВнутреннийНомерСотрудника", ВнутреннийНомерСотрудника);	
	КонецЕсли;
    Если ЗначениеЗаполнено(IDЗвонка) Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("IDЗвонка", IDЗвонка);	
