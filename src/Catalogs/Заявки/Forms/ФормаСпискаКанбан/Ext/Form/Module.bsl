	БлокЗаявки =
	"			<div class='item-col" + КлассПометкиУдаления + "' id='" + ИдентификаторЗаявки + "'>
	|				<div class='deletion-mark'>Удалено</div>
	|				<div class='head-col'>
	|					<div class='request-row'>
	|						<div class='title-col' data-request-id='" + ИдентификаторЗаявки + "'>№ " + КодЗаявкиБезНулей + ПредставлениеДатыСоздания + "</div>
	|						<div class='container-row'>
	|							<div class='ico-chat' title='Перейти к диалогу'></div>
	|						</div>
