&НаКлиенте
// Процедура, выводит следующую в очереди заявку.
//
Процедура ВывестиЗаявкуИзОчереди(ДанныеВыводимойЗаявки)
	
	Если Не ЗначениеЗаполнено(ДанныеВыводимойЗаявки) Тогда
		Возврат;
	КонецЕсли;
	
	Документ = Элементы.Канбан.Документ;
	
	КолонкаДляДобавления = Документ.querySelector(".kanban-board[data-id='" + ДанныеВыводимойЗаявки.Статус + "']");
	
	БлокВыводимойЗаявки = Документ.createElement("div");
	БлокВыводимойЗаявки.className = "kanban-item";
	БлокВыводимойЗаявки.innerHTMl = ДанныеВыводимойЗаявки.БлокЗаявки;
	
	КнопкаПереходаВСписок = КолонкаДляДобавления.querySelector(".show-all");
	КнопкаПереходаВСписок.before(БлокВыводимойЗаявки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет представление количества заявок в блоках.
//
Процедура ОбновитьКоличествоЗаявокВБлоках(ДанныеКоличества)
	
	Документ = Элементы.Канбан.Документ;
	
	КонтейнерБлоков = Документ.querySelector(".kanban-container");
	
	Для Каждого Блок Из КонтейнерБлоков.children Цикл
		
		КоличествоЗаявок = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеКоличества, Блок.dataset.id, 0);
		
		КнопкаПоказатьВсе				 = Блок.querySelector(".show-all");
		КнопкаПоказатьВсе.dataset.count	 = КоличествоЗаявок;
		
		ПредставлениеКоличестваЭлемент				 = Блок.querySelector("span.item-count");
		ПредставлениеКоличестваЭлемент.dataset.count = КоличествоЗаявок;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, устанавливает статус заявки и возвращает результат операции.
//
Функция УстановитьСтатусЗаявки(ПредставлениеСтатуса, ИдентификаторЗаявки, СтруктураОтборов, ПараметрыЗаявки = Неопределено, ПараметрыПолученияЗаявкиИзОчереди = Неопределено)
	
	РезультатОперации = Новый Структура;
	РезультатОперации.Вставить("ОписаниеОшибки"		, "");
	РезультатОперации.Вставить("ВыполненоУспешно"	, Ложь);
	РезультатОперации.Вставить("ИдентификаторЗаявки", ИдентификаторЗаявки);
	
	Заявка = ПолучитьСсылку("Справочники", "Заявки", ИдентификаторЗаявки);
	Статус = Перечисления.СтатусыЗаявок[ПредставлениеСтатуса];
	
	Попытка
		ЗаявкаОбъект		 = Заявка.ПолучитьОбъект();
		ЗаявкаОбъект.Статус	 = Статус;
		
		Если Не ЗначениеЗаполнено(ЗаявкаОбъект.ОсновнойМенеджер) Тогда
			
			ЗаявкаОбъект.ОсновнойМенеджер = ПараметрыСеанса.ТекущийСотрудник;
			
			ДанныеСотрудника = Новый Структура;
			ДанныеСотрудника.Вставить("ИдентификаторСотрудника", XMLСтрока(ЗаявкаОбъект.ОсновнойМенеджер));
			ДанныеСотрудника.Вставить("ПредставлениеСотрудника", ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЗаявкаОбъект.ОсновнойМенеджер, "Наименование"));
			
			РезультатОперации.Вставить("ДанныеСотрудника"				, ДанныеСотрудника);
			РезультатОперации.Вставить("ОбновитьПредставлениеСотрудника", Истина);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПараметрыЗаявки) Тогда
			ЗаполнитьЗначенияСвойств(ЗаявкаОбъект, ПараметрыЗаявки);
		КонецЕсли;
		
		ЗаявкаОбъект.Записать();
		
		РезультатОперации.ВыполненоУспешно = Истина;
		
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Не удалось установить статус обращения. Текст ошибки: '") + ОписаниеОшибки;
		
	КонецПопытки;
	
	Если РезультатОперации.ВыполненоУспешно Тогда
		ЗаполнитьДополнительныеПараметрыИОповеститьСеансы(ЗаявкаОбъект, РезультатОперации, СтруктураОтборов, ПараметрыПолученияЗаявкиИзОчереди);
	КонецЕсли;
	
	Возврат РезультатОперации;
	
КонецФункции

&НаСервереБезКонтекста
// Процедура, выполняет оповещение сеансов об изменении заявки и 
// Заполняет дополнительные параметры для обработки изменения заявки.
Процедура ЗаполнитьДополнительныеПараметрыИОповеститьСеансы(ЗаявкаОбъект, РезультатОперации, СтруктураОтборов, ПараметрыПолученияЗаявкиИзОчереди)
	
	РезультатОперации.Вставить("Заявка", ЗаявкаОбъект.Ссылка);
	
	// Получаем данные количества заявок.
	ДанныеКоличества = ПолучитьКоличествоЗаявокВКолонках(СтруктураОтборов);
	РезультатОперации.Вставить("ДанныеКоличества", ДанныеКоличества);
	
	// Получаем следующую в очереди заявку для отображения в блоке.
	ДанныеВыводимойЗаявки = ПолучитьДанныеВыводимойЗаявки(СтруктураОтборов, ПараметрыПолученияЗаявкиИзОчереди);
	РезультатОперации.Вставить("ДанныеВыводимойЗаявки", ДанныеВыводимойЗаявки);
	
	// Создаем оповещение других сеансов об изменении статуса заявки.
	УстановитьПривилегированныйРежим(Истина);
	
	НомерТекущегоСеанса	 = НомерСеансаИнформационнойБазы();
	ТекущиеСеансы		 = ПолучитьСеансыИнформационнойБазы();
	
	// Если активен только один сеанс (текущий) - никого не оповещаем.
	Если ТекущиеСеансы.Количество() > 1 Тогда
		
		СистемаВзаимодействияПодключена = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена() = Истина;
		
		Если Не СистемаВзаимодействияПодключена Тогда
			
			ПараметрыОповещения = Новый Массив;
			ПараметрыОповещения.Добавить(ЗаявкаОбъект.Ссылка);
			ПараметрыОповещения.Добавить(ЗаявкаОбъект.ОсновнойМенеджер);
			ПараметрыОповещения.Добавить(ЗаявкаОбъект.СтруктурнаяЕдиница);
			
		КонецЕсли;
		
		ПользователиОповещения = Новый Массив;
		
		Для Каждого Сеанс Из ТекущиеСеансы Цикл
			
			Если (Сеанс.ИмяПриложения = "1CV8C"
				Или Сеанс.ИмяПриложения = "WebClient") Тогда
				
				Если НомерТекущегоСеанса = Сеанс.НомерСеанса Тогда
					// Текущий сеанс оповещаем с клиента.
					Продолжить;
				КонецЕсли;
				
				Если СистемаВзаимодействияПодключена Тогда
					ПользователиОповещения.Добавить(Сеанс.Пользователь);
				Иначе
					РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(
					Сеанс.НомерСеанса,,
					"ОбновленСтатусЗаявки",
					ТекущаяДатаСеанса(),,,,
					ПараметрыОповещения
					);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если СистемаВзаимодействияПодключена И ЗначениеЗаполнено(ПользователиОповещения) Тогда
			
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("Ключ"					, "ОбновленСтатусЗаявки");
			ДанныеСообщения.Вставить("Заявка"				, ЗаявкаОбъект.Ссылка);
			ДанныеСообщения.Вставить("Сотрудник"			, ?(ЗаявкаОбъект.ОсновнойМенеджер.Пустая(), Неопределено, ЗаявкаОбъект.ОсновнойМенеджер));
			ДанныеСообщения.Вставить("СтруктурнаяЕдиница"	, ?(ЗаявкаОбъект.СтруктурнаяЕдиница.Пустая(), Неопределено, ЗаявкаОбъект.СтруктурнаяЕдиница));
			
			ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает данные заявки из очереди.
//
Функция ПолучитьДанныеВыводимойЗаявки(СтруктураОтбора, ПараметрыПолученияЗаявкиИзОчереди)
	
	Если Не ЗначениеЗаполнено(ПараметрыПолученияЗаявкиИзОчереди) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяСтатуса						 = ПараметрыПолученияЗаявкиИзОчереди.Статус;
	ИдентификаторыИсключаемыхЗаявок	 = ПараметрыПолученияЗаявкиИзОчереди.ИдентификаторыИсключаемыхЗаявок;
	
	ИсключаемыеЗаявки = Новый Массив;
	
	Для Каждого ИдентификаторЗаявки Из ИдентификаторыИсключаемыхЗаявок Цикл
		
		ИсключаемаяЗаявка = Справочники.Заявки.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторЗаявки));
		ИсключаемыеЗаявки.Добавить(ИсключаемаяЗаявка);
		
	КонецЦикла;
	
	СтруктураОтбора.Вставить("Статус", Перечисления.СтатусыЗаявок[ИмяСтатуса]);
	
	ДанныеЗаявки = ПолучитьДанныеЗаявки(СтруктураОтбора,, ИсключаемыеЗаявки);
	
	Если Не ЗначениеЗаполнено(ДанныеЗаявки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	БлокЗаявки = ПолучитьБлокЗаявки(ДанныеЗаявки);
	
	ДанныеВыводимойЗаявки = Новый Структура;
	ДанныеВыводимойЗаявки.Вставить("Статус"		, ИмяСтатуса);
	ДанныеВыводимойЗаявки.Вставить("БлокЗаявки"	, БлокЗаявки);
	
	Возврат ДанныеВыводимойЗаявки;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает представление блоков, доступных для переноса.
//
Функция ПолучитьДоступныеДляПереносаБлоки(СтатусЗаявки)
	
	Если СтатусЗаявки = Перечисления.СтатусыЗаявок.Отклонена
		Или СтатусЗаявки = Перечисления.СтатусыЗаявок.Принята Тогда
		
		ДоступныеБлоки = "'Принята','Отклонена'";
		
	ИначеЕсли СтатусЗаявки = Перечисления.СтатусыЗаявок.НеОбработана Тогда
		ДоступныеБлоки = "'ПропущенныйЗвонок','ОтвеченныйЗвонок','ОтвеченныйДиалог','Перезвонить','Принята','Отклонена'";
		
	Иначе
		ДоступныеБлоки = "'НеОбработана','ПропущенныйЗвонок','ОтвеченныйЗвонок','ОтвеченныйДиалог','Перезвонить','Принята','Отклонена'";
		
	КонецЕсли;
	
	Возврат ДоступныеБлоки
	
КонецФункции

