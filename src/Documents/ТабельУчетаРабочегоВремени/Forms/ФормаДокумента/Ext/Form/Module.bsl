&НаКлиенте
// Процедура - Дни работы сотрудник начало выбора
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьСотрудника(Команда)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметры = Новый Структура();	
	МассивСотрудниковСтруктурнойЕдиницы = МассивРаботниковСтруктурнойЕдиницы(Объект.СтруктурнаяЕдиница);
	
	СтруктураПараметры.Вставить("СписокВыбораСотрудников", МассивСотрудниковСтруктурнойЕдиницы); 
	СтруктураПараметры.Вставить("Заголовок" 			 , "Выберите сотрудника");	   
	СтруктураПараметры.Вставить("БезОтбораПоРолям"		 , Истина);	
	СтруктураПараметры.Вставить("ОтбиратьВрачей"         , Истина);
	
	Оповещение = Новый ОписаниеОповещения("ВыборСотрудникаЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.Сотрудники.Форма.ФормаВыбора" ,СтруктураПараметры,,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);			
	
КонецПроцедуры 

&НаКлиенте
// Процедура - Выбор сотрудника завершение.
//
Процедура ВыборСотрудникаЗавершение(ВыбранныйСотрудник, ДопПараметры) Экспорт
	
	Если ЗначениеЗаполнено(ВыбранныйСотрудник) Тогда
		
		Строки = Объект.ДниРаботы.НайтиСтроки(Новый Структура("Сотрудник",ВыбранныйСотрудник));
		
		Если Строки.Количество() > 0 Тогда
			ОбщегоНазначения.СообщитьПользователю("Данный сотрудник уже выбран.",,,,);
		Иначе
			СтрокаТЧ                 =  Объект.ДниРаботы.Добавить();   
			СтрокаТЧ.Сотрудник       = ВыбранныйСотрудник;
			СтрокаТЧ.Должность       = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВыбранныйСотрудник,"Должность");
			Модифицированность = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура - обработчик события ПриИзменении поля ДниРаботы.
//
Процедура ДниРаботыПриИзменении(Элемент)
	
	Если (Объект.ДниРаботы.Количество()>1) Тогда
		ПересчитатьИтогиСтрокиДниРаботы(Элемент.ТекущиеДанные);
	Конецесли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриАктивизацииСтроки реквизита ДеревоСотрудников.
//
Процедура ДеревоСотрудниковПриАктивизацииСтроки(Элемент)
	
	Если Элементы.ДеревоСотрудников.ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВыделенныйЭлемент = Элементы.ДеревоСотрудников.ТекущиеДанные;	
	
	Если ВыделенныйЭлемент.Свойство("Сотрудник") Тогда
		ЗначениеФильтра = ВыделенныйЭлемент.Сотрудник;
	ИначеЕсли ВыделенныйЭлемент.Свойство("Должность") Тогда	
		ЗначениеФильтра = ВыделенныйЭлемент.Должность;
	Иначе
		ЗначениеФильтра = "ВСЕ";	
	КонецЕсли;
	
