
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("РасчетЗарплаты"				, "ГруппаРасчетЗарплаты");
	СтруктураМеню.Вставить("ПрочиеНачисленияИУдержания"	, "ГруппаПрочиеНачисленияИУдержания");
	СтруктураМеню.Вставить("Затраты"					, "ГруппаЗатраты");
	СтруктураМеню.Вставить("Авансы"						, "ГруппаАвансы");
	СтруктураМеню.Вставить("Дополнительно"				, "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, выполняет обработку нажатия кнопок динамического меню.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры	

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля ввода "Комментарий"
//
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиентСтоматология.ОткрытьФормуРедактированияКомментария(Элемент.ТекстРедактирования, Объект.Комментарий, Модифицированность);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события при изменении периода
Процедура ДатаНачалаПериодаПриИзменении(Элемент)
	
	Если Объект.ДатаНачалаПериода >= Объект.ДатаОкончанияПериода Тогда 
		Объект.ДатаОкончанияПериода = КонецМесяца(Объект.ДатаОкончанияПериода);
	КонецЕсли;
			
	Для Каждого ТекСтрокаРасчетЗарплаты Из Объект.РасчетЗарплаты Цикл
		ТекСтрокаРасчетЗарплаты.ПериодС = Объект.ДатаНачалаПериода;
		ТекСтрокаРасчетЗарплаты.ПериодПо = Объект.ДатаОкончанияПериода;
	КонецЦикла;
	
	РассчетБыл = Ложь;
	Для Каждого СтрокаТч Из Объект.РасчетЗарплаты Цикл		
		Если ЗначениеЗаполнено(СтрокаТч.Размер) Тогда
			РассчетБыл = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если РассчетБыл Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		ПоказатьВопрос(Новый ОписаниеОповещения("ДатаПериодаПриИзмененииЗавершение", ЭтотОбъект), "Пересчитать данные по заработной плате?", Режим, 0);
	КонецЕсли;  

КонецПроцедуры

&НаКлиенте
// Процедура обработчик события при изменении периода
Процедура ДатаОкончанияПериодаПриИзменении(Элемент)
	
	Для Каждого ТекСтрокаРасчетЗарплаты Из Объект.РасчетЗарплаты Цикл
		ТекСтрокаРасчетЗарплаты.ПериодПо = Объект.ДатаОкончанияПериода;
	КонецЦикла;
	
	РассчетБыл = Ложь;
	Для Каждого СтрокаТч Из Объект.РасчетЗарплаты Цикл		
		Если ЗначениеЗаполнено(СтрокаТч.Размер) Тогда
			РассчетБыл = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если РассчетБыл Тогда
		
		Режим = РежимДиалогаВопрос.ДаНет;
		ПоказатьВопрос(Новый ОписаниеОповещения("ДатаПериодаПриИзмененииЗавершение", ЭтотОбъект), "Пересчитать данные по заработной плате?", Режим, 0);
		
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Дата начала периода при изменении завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ДатаПериодаПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Рассчитать(Неопределено);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РасчетЗарплатыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "РасчетЗарплатыСотрудник" Тогда
		ПоказатьЗначение(,Элемент.ТекущиеДанные.Сотрудник);
	ИначеЕсли Поле.Имя = "РасчетЗарплатыНачислениеУдержание" Тогда
		ПоказатьЗначение(,Элемент.ТекущиеДанные.НачислениеУдержание);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РасчетЗарплатыБазаПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.РасчетЗарплаты.ТекущиеДанные;
	Если Элемент <> Элементы.РасчетЗарплатыВычисляетсяВручную Тогда
		ТекущаяСтрока.ВычисляетсяВручную = Истина;
	КонецЕсли;
	
	// СтрокаТЧСтруктура = ОбщегоНазначенияКлиентСервер.КонвертироватьСтрокуТаблицыВСтруктуру(Объект.РасчетЗарплаты, ТекущаяСтрока, 
	//							"ВычисляетсяВручную,НачислениеУдержание,ПериодС,ПериодПо,ЧасовПлан,ДнейПлан,ЧасовФакт,ДнейФакт,База,Размер,Сумма");
	РассчитатьПоНачислениюНаСервере(Элементы.РасчетЗарплаты.ТекущаяСтрока);
	// ЗаполнитьЗначенияСвойств(ТекущаяСтрока, СтрокаТЧСтруктура);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста  
// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции

&НаКлиенте
Процедура ПрочиеНачисленияИУдержанияПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)	
	ПрочиеНачисленияИУдержанияПриИзмененииСервер();	
КонецПроцедуры

&НаКлиенте
Процедура ПрочиеНачисленияИУдержанияПослеУдаления(Элемент)
	ПрочиеНачисленияИУдержанияПриИзмененииСервер();
КонецПроцедуры

&НаСервере
//
//
Процедура ПрочиеНачисленияИУдержанияПриИзмененииСервер()
	
	Если Элементы.ПрочиеНачисленияИУдержания.ТекущаяСтрока <> Неопределено Тогда
		ТекущиеДанные = объект.ПрочиеНачисленияИУдержания.НайтиПоИдентификатору(Элементы.ПрочиеНачисленияИУдержания.ТекущаяСтрока);
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.СтатьяРасходов) И ЗначениеЗаполнено(ТекущиеДанные.Начисление) Тогда
			Если ТекущиеДанные.Начисление.ТипНачисленияУдержания = ПредопределенноеЗначение("Перечисление.ТипыНачисленийУдержаний.Начисление") Тогда
				ТекущиеДанные.СтатьяРасходов = ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ПрочееНачисление");
			Иначе
				ТекущиеДанные.СтатьяРасходов = ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ПрочееУдержание");
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
	Счетчик = Объект.Затраты.Количество();
	Пока Счетчик > 0 Цикл 
		Если ТипЗнч(Объект.Затраты[Счетчик - 1].ВидНачисления) = Тип("СправочникСсылка.ПрочиеНачисленияИУдержания") Тогда 
			Объект.Затраты.Удалить(Счетчик - 1);	
		КонецЕсли;
		Счетчик = Счетчик - 1;
	КонецЦикла;	
	 
	Для Каждого СтрокаТЧ Из Объект.ПрочиеНачисленияИУдержания Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Начисление) Тогда		
			НоваяСтрока = Объект.Затраты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			НоваяСтрока.ВидНачисления 	= СтрокаТЧ.Начисление;
			Если СтрокаТЧ.Начисление.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда 
				СтрокаТЧ.Сумма 		= ?(СтрокаТЧ.Сумма > 0, СтрокаТЧ.Сумма, СтрокаТЧ.Сумма*-1);
				НоваяСтрока.Размер 	= СтрокаТЧ.Сумма;
				НоваяСтрока.Сумма 	= НоваяСтрока.Размер;
			Иначе
				СтрокаТЧ.Сумма 		= ?(СтрокаТЧ.Сумма < 0, СтрокаТЧ.Сумма, СтрокаТЧ.Сумма*-1);
				НоваяСтрока.Размер 	= СтрокаТЧ.Сумма;
				НоваяСтрока.Сумма 	= НоваяСтрока.Размер;
			КонецЕсли;	
		КонецЕсли;			
	КонецЦикла;
		
	Объект.СуммаДокумента = Объект.РасчетЗарплаты.Итог("Сумма") + Объект.ПрочиеНачисленияИУдержания.Итог("Сумма");
	
КонецПроцедуры

&НаСервере
// Процедура - обработчик команды формы "ЗаполнитьНаСервере".
//
Процедура ЗаполнитьНаСервере(Добавить = Ложь, Сотрудник = Неопределено, ГруппаСотрудника = Неопределено, ДолжностьСотрудника = Неопределено)
	
	Если Не ЗначениеЗаполнено(Объект.ДатаНачалаПериода) И Не ЗначениеЗаполнено(Объект.ДатаОкончанияПериода) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен период!");
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НачисленияИУдержанияСотрудников.Владелец КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА НачисленияИУдержанияСотрудников.ЭтоГруппа
	|			ТОГДА НачисленияИУдержанияСотрудников.ВариантИспользования
	|		ИНАЧЕ НачисленияИУдержанияСотрудников.ПолноеНаименование
	|	КОНЕЦ КАК Описание,
	|	ВЫБОР
	|		КОГДА НачисленияИУдержанияСотрудников.НачалоПериода МЕЖДУ &НачалоПериода И &КонецПериода
	|			ТОГДА НачисленияИУдержанияСотрудников.НачалоПериода
	|		КОГДА НастройкиСотрудников.ДатаПриема МЕЖДУ &НачалоПериода И &КонецПериода
	|			ТОГДА НастройкиСотрудников.ДатаПриема
	|		ИНАЧЕ &НачалоПериода
	|	КОНЕЦ КАК ПериодС,
	|	ВЫБОР
	|		КОГДА НачисленияИУдержанияСотрудников.КонецПериода МЕЖДУ &НачалоПериода И &КонецПериода
	|			ТОГДА НачисленияИУдержанияСотрудников.КонецПериода
	|		КОГДА НастройкиСотрудников.ДатаУвольнения МЕЖДУ &НачалоПериода И &КонецПериода
	|			ТОГДА НастройкиСотрудников.ДатаУвольнения
	|		ИНАЧЕ &КонецПериода
	|	КОНЕЦ КАК ПериодПо,
	|	НачисленияИУдержанияСотрудников.Код КАК Код,
	|	НачисленияИУдержанияСотрудников.Ссылка КАК НачислениеУдержание
	|ИЗ
	|	Справочник.НачисленияИУдержанияСотрудников КАК НачисленияИУдержанияСотрудников
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО НачисленияИУдержанияСотрудников.Владелец = НастройкиСотрудников.Сотрудник
	|			И НачисленияИУдержанияСотрудников.СтруктурнаяЕдиница = НастройкиСотрудников.СтруктурнаяЕдиница
	|ГДЕ
	|	НачисленияИУдержанияСотрудников.ЭтоГруппа = ЛОЖЬ
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НачисленияИУдержанияСотрудников.ПометкаУдаления = ЛОЖЬ
	|	И (НачисленияИУдержанияСотрудников.КонецПериода >= &НачалоПериода
	|			ИЛИ НачисленияИУдержанияСотрудников.КонецПериода = ДАТАВРЕМЯ(1, 1, 1))
	|	И НачисленияИУдержанияСотрудников.НачалоПериода <= &КонецПериода
	|	И (НастройкиСотрудников.ДатаУвольнения >= &НачалоПериода
	|			ИЛИ НастройкиСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1))
	|	И (НастройкиСотрудников.ДатаПриема <= &КонецПериода
	|			ИЛИ НастройкиСотрудников.ДатаПриема = ДАТАВРЕМЯ(1, 1, 1))"
		+ ?(ЗначениеЗаполнено(Сотрудник)			, Символы.ПС + "	И НачисленияИУдержанияСотрудников.Владелец = &Сотрудник ", "") 
		+ ?(ЗначениеЗаполнено(ДолжностьСотрудника)	, Символы.ПС + "	И НачисленияИУдержанияСотрудников.Владелец.Должность = &Должность ", "") 
		+ ?(ЗначениеЗаполнено(ГруппаСотрудника)		, Символы.ПС + "	И НачисленияИУдержанияСотрудников.Владелец В ИЕРАРХИИ (&ГруппаСотрудника) ", "")
		+ "
	|УПОРЯДОЧИТЬ ПО
	|	НачисленияИУдержанияСотрудников.Владелец.Наименование, НачисленияИУдержанияСотрудников.Ссылка.Наименование";
				
	Запрос.УстановитьПараметр("НачалоПериода", Объект.ДатаНачалаПериода);
	Запрос.УстановитьПараметр("КонецПериода", Объект.ДатаОкончанияПериода);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Должность", ДолжностьСотрудника);
	Запрос.УстановитьПараметр("ГруппаСотрудника", ГруппаСотрудника);
	
	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
	
	Если Добавить Тогда
		ПараметрыПоиска = Новый Структура("Сотрудник, Код, НачислениеУдержание");
		Для Каждого СтрокаТЧ Из ТаблицаРезультат Цикл
			ЗаполнитьЗначенияСвойств(ПараметрыПоиска, СтрокаТЧ);
			Если Объект.РасчетЗарплаты.НайтиСтроки(ПараметрыПоиска).Количество() <= 0 Тогда
				НоваяСтрока = Объект.РасчетЗарплаты.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЕсли;
		КонецЦикла;
	Иначе
		Объект.РасчетЗарплаты.Очистить();
		Объект.РасчетЗарплаты.Загрузить(ТаблицаРезультат);
	КонецЕсли;
	
	Объект.РасчетЗарплаты.Сортировать("Сотрудник Возр");
	ДополнитьТаблицуРасчетаДаннымиНачисления();
	
	// Заполнить таблицу "Авансы"
	ЗаполнитьАвансыНаСервере();
		
КонецПроцедуры

&НаКлиенте
