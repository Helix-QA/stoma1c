// Процедура, получает сотрудников входящих в группу.
//
Функция ПолучитьСотрудниковГруппы(Родитель, ДобавитьРодителяВСписок = Ложь)
	
	Сотрудники = Новый Массив;
	
	Если Родитель.ЭтоГруппа = Истина Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Сотрудники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Родитель = &Родитель");
		Запрос.УстановитьПараметр("Родитель", Родитель);
		
		Сотрудники = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
		Если ДобавитьРодителяВСписок = Истина Тогда
			Сотрудники.Добавить(Родитель);
		КонецЕсли;
		
		Возврат Сотрудники;
		
	Иначе
		
		Сотрудники.Добавить(Родитель);
		Возврат Сотрудники;
		
	КонецЕсли;
	
КонецФункции

