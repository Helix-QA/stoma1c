// Процедура, обработчик оповещения.
//
Процедура ВыборСтруктурнойЕдиницыЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда // добавить
		
		Для Каждого СтруктурнаяЕдиница Из ДопПараметры.МассивСтруктурныхЕдиниц Цикл
			
			Если Не ЗначениеЗаполнено(ТаблицаСтруктурныеЕдиницыСкидки.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница))) Тогда
				НоваяСтрока = ТаблицаСтруктурныеЕдиницыСкидки.Добавить();
				НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
			КонецЕсли;
			
		КонецЦикла;
		
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда // заменить
		
		ТаблицаСтруктурныеЕдиницыСкидки.Очистить();
		
		Для Каждого СтруктурнаяЕдиница Из ДопПараметры.МассивСтруктурныхЕдиниц Цикл
			
			НоваяСтрока = ТаблицаСтруктурныеЕдиницыСкидки.Добавить();
			НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
			
		КонецЦикла;  
		
	КонецЕсли;
	
КонецПроцедуры

