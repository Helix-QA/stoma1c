&НаСервере
// Процедура - Сформировать элементы меню картинки взаимодействия.
//
Процедура СформироватьЭлементыМенюКартинкиВзаимодействия()
		
	Если ЗначениеЗаполнено(Объект.ИндексКартинки) Тогда
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Ширина 		= 2;
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Высота 		= 1;
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Отображение = ОтображениеКнопки.Картинка;
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Картинка    = БиблиотекаКартинок["ВидВзаимодействия_" + Объект.ИндексКартинки];
		Элементы.ГруппаКнопкиВыбораКартинки.ЦветФона 			= Новый Цвет(255, 255, 255);
	Иначе
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Ширина 		= 0;
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Высота 		= 0;		
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Отображение = ОтображениеКнопки.Текст;
		Элементы.ГруппаКнопкиВыбораКартинки.ЦветФона 			= Новый Цвет();
	КонецЕсли;
	
	Элементы.ГруппаВыборКартинкиВзаимодействия.Доступность = ДоступноРедактированиеПоПравам;		
	Элементы.ОткрытьВыборКартинкиВзаимодействия.Доступность = ДоступноРедактированиеПоПравам;
	
	ИндексГруппы = 0;
	
	Для ИндексЭлемента = 1 По 33 Цикл
		
		// Переход на новую строку, если в группе больше заданного числа элементов.
		Если Ост(ИндексЭлемента - 1, 11) = 0 Тогда
			
			// Создание подгруппы подчиненного меню.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ГруппаЭлемента"			, Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая);
			ПараметрыГруппы.Вставить("ИмяЭлемента"   			, "ВыборКартинкиВзаимодействияСтрока_" + ИндексГруппы);
			ПараметрыГруппы.Вставить("Группировка"   			, ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
			ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал"	, ИнтервалМеждуЭлементамиФормы.Половинный);
			
			ГруппаСтрокаЭлементов 	= УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
			ИндексГруппы    		= ИндексГруппы + 1;
			
		КонецЕсли;
		
		ПараметрыГруппыКартинки = Новый Структура;
		ПараметрыГруппыКартинки.Вставить("ГруппаЭлемента", ГруппаСтрокаЭлементов);
		ПараметрыГруппыКартинки.Вставить("ИмяЭлемента"   , "ГруппаКартинкиВзаимодействия_" + ИндексЭлемента);
		ПараметрыГруппыКартинки.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
		ПараметрыГруппыКартинки.Вставить("ЦветФона"      , ?(Объект.ИндексКартинки = ИндексЭлемента, Новый Цвет(213, 213, 213), Новый Цвет(255, 255, 255)));
		
		ГруппаКартинки = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппыКартинки);
		
		// Создание элемента картинки взаимодействия.
		ПараметрыЭлемента = Новый Структура;
		ПараметрыЭлемента.Вставить("ГруппаЭлемента"        , ГруппаКартинки);
		ПараметрыЭлемента.Вставить("ИмяЭлемента"           , "ВидВзаимодействия_" + ИндексЭлемента);
		ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия" , "ВыбратьКартинкуВзаимодействия_Подключаемый");
		ПараметрыЭлемента.Вставить("Картинка"              , БиблиотекаКартинок["ВидВзаимодействия_" + ИндексЭлемента]);
		ПараметрыЭлемента.Вставить("КнопкаОтображение"     , ОтображениеКнопки.Картинка);
		//ПараметрыЭлемента.Вставить("ГоризонтальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Половинный);
		
		УправлениеИнтерфейсамиСервер.СозданиеЭлементаМеню(ЭтаФорма, ПараметрыЭлемента);
		
	КонецЦикла;
	
	УправлениеИнтерфейсамиСервер.СформироватьРеквизитСтруктурыДанныхВсплывающихГрупп(ЭтаФорма, Новый Структура("ВыборКартинкиВзаимодействия", Ложь));

КонецПроцедуры

&НаКлиенте
// Процедура - Открыть выбор картинки взаимодействия.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОткрытьВыборКартинкиВзаимодействия(Команда)
	
	Если НЕ ДоступноРедактированиеПоПравам Тогда
		Возврат;
	КонецЕсли;	
	
	Если Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая.Скрыта() Тогда 
		Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая.Показать();
	КонецЕсли;	
	
	//Если ПроверитьВидимостьВсплывающихГрупп("ВыборКартинкиВзаимодействия") Тогда
	//	УстановитьВидимостьВсплывающихГрупп("ВыборКартинкиВзаимодействия");
	//КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбрать картинку взаимодействия.
//
Процедура ВыбратьКартинкуВзаимодействия_Подключаемый(Команда)
	
	ПредИндексКартинки    = Объект.ИндексКартинки;	
	Объект.ИндексКартинки = Число(СтрРазделить(Команда.Имя, "_")[1]); 
	
	Если Объект.ИндексКартинки = ПредИндексКартинки Тогда
		//Если НЕ Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая.Скрыта() Тогда 
		//	Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая.Скрыть();
		//КонецЕсли;
	ИначеЕсли Объект.ИндексКартинки <> ПредИндексКартинки Тогда
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Ширина 		= 2;
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Высота 		= 1;		
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Отображение = ОтображениеКнопки.Картинка;
		Элементы.ОткрытьВыборКартинкиВзаимодействия.Картинка    = БиблиотекаКартинок["ВидВзаимодействия_" + Объект.ИндексКартинки];	
		Элементы.ГруппаКнопкиВыбораКартинки.ЦветФона 			= Новый Цвет(255, 255, 255);
		
		Если ЗначениеЗаполнено(ПредИндексКартинки) Тогда
			Элементы["ГруппаКартинкиВзаимодействия_" + ПредИндексКартинки].ЦветФона = Новый Цвет(255, 255, 255);
		КонецЕсли;	
		Элементы["ГруппаКартинкиВзаимодействия_" + Объект.ИндексКартинки].ЦветФона = Новый Цвет(213, 213, 213);
		
		Модифицированность = Истина;
	КонецЕсли;
	
	Если НЕ Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая.Скрыта() Тогда 
		Элементы.ГруппаВыборКартинкиВзаимодействияВсплывающая.Скрыть();
	КонецЕсли;
	
	УстановитьФокусЭлемента();

	//СнятьВидимостьВсплывающихГрупп("ВыборКартинкиВзаимодействия");
	
КонецПроцедуры

&НаКлиенте
// Функция - Проверить видимость всплывающей группы.
//
// Параметры:
//  ИмяВзаимодействия	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьВидимостьВсплывающихГрупп(ИмяЭлемента)
	
	Результат = УправлениеИнтерфейсамиКлиент.ПроверитьВидимостьВсплывающихГрупп(ЭтаФорма, ИмяЭлемента);
	
	Если Результат = Ложь Тогда 
		УстановитьФокусЭлемента();
	КонецЕсли;
	
	Возврат Результат; 
	
КонецФункции

&НаКлиенте
