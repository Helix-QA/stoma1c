#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДеревоСотрудников.Параметры.УстановитьЗначениеПараметра("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	
	// Helix = ЗащитаСервер.СоздатьОбъект("Helix");
	Helix.ОбновитьПредставлениеДняВКолонках(Элементы.ДниРаботы, Новый Структура("Месяц", Объект.Период));
	
	// Контроль недавно созданных сотрудников	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(ВернутьТаблицуНовыхСотрудников(), ТаблицаНовыхСотрудников);		
	КонецЕсли;
		
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("ДниРаботы"	  , "ГруппаДниРаботы");
	СтруктураМеню.Вставить("Дополнительно", "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ПриОткрытии(Отказ)

	Если Объект.Ссылка.Пустая() ИЛИ НЕ ЗначениеЗаполнено(Объект.Период) Тогда
		
		Объект.Период = НачалоМесяца(ОбщегоНазначенияКлиент.ДатаСеанса());	
		ПериодПредставлениеПриИзменении(Неопределено);
		
	КонецЕсли;
	ПериодПредставление = Формат(Объект.Период, "ДФ='MMMM yyyy'"); 
		
	ДеревоСотрудников.Параметры.УстановитьЗначениеПараметра("Период", Объект.Период);
	

	// Контроль недавно созданных сотрудников
	Если ТаблицаНовыхСотрудников.Количество() > 0 Тогда
		 ПодключитьОбработчикОжидания("ДиалогПользователю_ДобавлениеСотрудников", 0.7, Истина);		
	КонецЕсли;	
	
	УстановитьДоступностьВидимостьЭлементов();
	
	Объект.ДниРаботы.Сортировать("Сотрудник");
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события ПослеЗаписи.
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры
	
#КонецОбласти

