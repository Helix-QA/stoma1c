// Процедура, обработчик команды "Вставить".
// 
Процедура ПравкаВставить(Команда)
		
	ДанныеБуфера = БуферОбменаЗаполненСобытием(ЭтотОбъект.БуферОбмена, Истина);	
	Если БуферОбмена.Буфер <> Неопределено И НЕ ПЗРасшифровкаТекущейОбласти = Неопределено И НЕ ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда  
		
		Если ДанныеБуфера.ПризнакВырезать = Истина Тогда 
			
			СоздатьСобытиеКопированием(БуферОбмена.Буфер, Истина);
			Оповестить("ИзмененоСобытие");	
			
		Иначе
			
			Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) Тогда 	// сотрудник может не быть если режим отображения стоит неделя. 
				СотрудникСобытия = ПЗРасшифровкаТекущейОбласти.Сотрудник;
			ИначеЕсли ЗначениеЗаполнено(БуферОбмена.Буфер.Событие) Тогда
				СотрудникСобытия = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(БуферОбмена.Буфер.Событие, "Врач");
			КонецЕсли;
			
			ИнтервалВремени 	= ОпределнениеИнтервалаВремени(ИнтервалГрафика);
			ВставкаДатаНачала 	= ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ ИнтервалВремени)) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ИнтервалВремени)) * (60/ИнтервалВремени) * ИнтервалВремени * 60;	
			
			ЗначенияЗаполнения = Новый Структура;			
			ЗначенияЗаполнения.Вставить("ДатаНачала", ВставкаДатаНачала); 
			ЗначенияЗаполнения.Вставить("Сотрудник"	, СотрудникСобытия);
			ЗначенияЗаполнения.Вставить("Помещение"	, Неопределено);
			
			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("ЗначенияЗаполнения"	, ЗначенияЗаполнения);
			ДопПараметры.Вставить("КопируемоеСобытие"	, БуферОбмена.Буфер.Событие);
			ДопПараметры.Вставить("ПризнакВырезать"		, ДанныеБуфера.ПризнакВырезать);
			
			СоздатьВизитПослеВопросаВозможностиОповещение(КодВозвратаДиалога.Да, ДопПараметры);
			
		КонецЕсли;
						
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Показать вопрос завершение.
// 
// Параметры:
//  Результат		 - 	 -
//  ПараметрыЗаписи	 - 	 -
// 
Процедура СоздатьВизитПослеВопросаВозможностиОповещение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;	
	КонецЕсли;	
	
	Если ДопПараметры.Свойство("РезервВремени") Тогда
		
		СтруктураПарметров = Новый Структура("ЗначенияЗаполнения", ДопПараметры.ЗначенияЗаполнения);
		ОткрытьФорму("Документ.Событие.Форма.ФормаРезерва", СтруктураПарметров,, Истина,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
	Иначе
		
		ДопПараметры.ЗначенияЗаполнения.Вставить("ИнтервалГрафика", ИнтервалГрафика);  // В старом журнале ИнтервалГрафика.
		
		Если ДопПараметры.Свойство("ЭтоРабочееВремя") Тогда	
			ДопПараметры.ЗначенияЗаполнения.Вставить("ЭтоРабочееВремя", ДопПараметры.ЭтоРабочееВремя);	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИсточникЗаписи) Тогда
			ДопПараметры.ЗначенияЗаполнения.Вставить("ИсточникЗаписи", ИсточникЗаписи);
		КонецЕсли;             
		
		Если ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
			ДопПараметры.ЗначенияЗаполнения.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		КонецЕсли;
			
		ДопПараметры.ЗначенияЗаполнения.Вставить("ИсточникЗаписи", ИсточникЗаписи);
		
		СозданиеИзФормыДиалога = ?(ДопПараметры.Свойство("СозданиеИзФормыДиалога"), ДопПараметры.СозданиеИзФормыДиалога, Ложь);	
			
		Если СозданиеИзФормыДиалога = Ложь И ДопПараметры.Свойство("КопируемоеСобытие") И ЗначениеЗаполнено(ДопПараметры.КопируемоеСобытие) Тогда
				
			ВставкаДатаНачала 	= ДопПараметры.ЗначенияЗаполнения.ДатаНачала;
			ВставкаСотрудник 	= ДопПараметры.ЗначенияЗаполнения.Сотрудник;
			ВставкаПомещение 	= ДопПараметры.ЗначенияЗаполнения.Помещение;
			
			ДанныеКопируемогоСобытия = ПолучитьДанныеСобытия(ДопПараметры.КопируемоеСобытие);
			
			ДлительностьСобытия = ?(ДанныеКопируемогоСобытия.Свойство("Длительность"), ДанныеКопируемогоСобытия.Длительность, 0);
			
			СтартДельта = ?(ДанныеКопируемогоСобытия.Свойство("ДатаЗапланированная"), ДанныеКопируемогоСобытия.ДатаЗапланированная, Дата(1,1,1));
			ВставкаДатаОкончания = ВставкаДатаНачала + ДлительностьСобытия * 60;	
			
			УслугиНЕДоступныДляСотрудника = ПроверитьДоступностьУслугСотрудникомПоСобытию(ВставкаСотрудник, Объект.СтруктурнаяЕдиница, ДопПараметры.КопируемоеСобытие);
			
			Если УслугиНЕДоступныДляСотрудника.Количество() = 0 Тогда
				
				ПериодЗанятСобытиями = ПроверитьНаличиеСобытийВВыбранномПериоде(
				ВставкаДатаНачала, 
				ВставкаДатаОкончания,
				Объект.СтруктурнаяЕдиница,
				ВставкаСотрудник,
				ВставкаПомещение,
				ДопПараметры.КопируемоеСобытие);
				
				ПараметрыДиалога = Новый Структура;		
				ПараметрыДиалога.Вставить("КопируемоеСобытие"	, ДопПараметры.КопируемоеСобытие);
				ПараметрыДиалога.Вставить("Перенести"			, ДопПараметры.ПризнакВырезать);	
				ПараметрыДиалога.Вставить("ДатаНачала"			, ВставкаДатаНачала); 	
				ПараметрыДиалога.Вставить("ДатаОкончания"		, ВставкаДатаОкончания);
				ПараметрыДиалога.Вставить("СтартДельта"			, СтартДельта);
				ПараметрыДиалога.Вставить("Сотрудник"			, ВставкаСотрудник);
				ПараметрыДиалога.Вставить("Помещение"			, ВставкаПомещение);
				ПараметрыДиалога.Вставить("Длительность"		, ДлительностьСобытия);
				
				Если ПериодЗанятСобытиями = Истина Тогда
					
					ПараметрыДиалога.Вставить("Событие"				, Неопределено);	
					ПараметрыДиалога.Вставить("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
					ПараметрыДиалога.Вставить("ИнтервалЗаписи"		, ИнтервалГрафика);		
					ПараметрыДиалога.Вставить("ЭтоКопирование"		, Истина);
					ПараметрыДиалога.Вставить("КонфликтВставки"		, Истина);
					
					Оповещение = Новый ОписаниеОповещения("СоздатьСобытиеКопированиемЗавершение", ЭтотОбъект, ПараметрыДиалога);
					
					ОткрытьФорму("Обработка.РабочийКалендарь.Форма.ФормаДиалогаПереносаПриемов", ПараметрыДиалога,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
					
				Иначе		
					
					ПараметрыОткрытия = Новый Структура;
					ПараметрыОткрытия.Вставить("ИнтервалГрафика", ОпределнениеИнтервалаВремени(ИнтервалГрафика));
					ПараметрыОткрытия.Вставить("ОчиститьБуферПриЗакрытии", Истина);
					
					Если ДопПараметры.Свойство("ПризнакВырезать") И ДопПараметры.ПризнакВырезать = Истина Тогда				
						ПараметрыОткрытия.Вставить("Ключ", ДопПараметры.КопируемоеСобытие);				
					Иначе				
						ПараметрыОткрытия.Вставить("ЗначениеКопирования", ДопПараметры.КопируемоеСобытие);					
					КонецЕсли;
					ПараметрыОткрытия.Вставить("ДатаНачала", ДопПараметры.ЗначенияЗаполнения.ДатаНачала);					
					Если СтрНайти(Строка(ДопПараметры.КопируемоеСобытие), "Резерв") = 0 Тогда
						
						НоваяФорма = ПолучитьФорму("Документ.Событие.ФормаОбъекта", ПараметрыОткрытия, ЭтаФорма);
						ОбъектФормы = НоваяФорма.Объект;
						ЗаполнитьНовоеСобытиеНаСервере(ОбъектФормы, ДопПараметры.ЗначенияЗаполнения);
						КопироватьДанныеФормы(ОбъектФормы, НоваяФорма.Объект);	
						
						НоваяФорма.ДатаОкончания = ДопПараметры.ЗначенияЗаполнения.ДатаНачала + (НоваяФорма.ДатаОкончания - НоваяФорма.ДатаНачала);
						НоваяФорма.ДатаНачала = ДопПараметры.ЗначенияЗаполнения.ДатаНачала;
						НоваяФорма.Открыть();                                              
						НоваяФорма.ОбновитьВиджетСделки();
						
					Иначе
						
						ПараметрыОткрытия.Вставить("ДатаОкончания", ВставкаДатаОкончания);
						
						НоваяФорма = ПолучитьФорму("Документ.Событие.Форма.ФормаРезерва", ПараметрыОткрытия, ЭтаФорма);
						ОбъектФормы = НоваяФорма.Объект;
						ЗаполнитьНовоеСобытиеНаСервере(ОбъектФормы, ДопПараметры.ЗначенияЗаполнения);
						КопироватьДанныеФормы(ОбъектФормы, НоваяФорма.Объект);	
						
						НоваяФорма.ДатаОкончания = ДопПараметры.ЗначенияЗаполнения.ДатаНачала + (НоваяФорма.ДатаОкончания - НоваяФорма.ДатаНачала);
						НоваяФорма.ДатаНачала = ДопПараметры.ЗначенияЗаполнения.ДатаНачала;
						НоваяФорма.Открыть();                                              
						
					КонецЕсли;
				КонецЕсли;
				
			Иначе    
				
				ТекстОшибки = "Врач " + ВставкаСотрудник + ?(УслугиНЕДоступныДляСотрудника.Количество() = 1, " не оказывает услугу: ", " не оказывает услуги: ") + Символы.ПС;
				Для Каждого Элемент Из УслугиНЕДоступныДляСотрудника Цикл
					ТекстОшибки = ТекстОшибки + Элемент + Символы.ПС;	
				КонецЦикла;
				ТекстОшибки = ТекстОшибки + "Перенос записи невозможен.";
				ОчиститьБуферОбмена(ЭтотОбъект.БуферОбмена);
				ПоказатьПредупреждение(, ТекстОшибки);
				
			КонецЕсли;
			
		Иначе
			
			ОткрытьФорму("Документ.Событие.ФормаОбъекта",  ДопПараметры.ЗначенияЗаполнения, ЭтаФорма);	
			
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры  

