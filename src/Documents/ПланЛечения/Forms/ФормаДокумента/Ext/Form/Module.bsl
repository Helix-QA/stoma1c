// Функция, Получить данные даты при изменении.
//
Функция ПолучитьДанныеДатаПриИзменении(ДокументСсылка, ДатаНовая, ДатаПередИзменением)
	
	РазностьДат = ДвиженияДокументовСервер.ПроверитьНомерДокумента(ДокументСсылка, ДатаНовая, ДатаПередИзменением);
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("РазностьДат", РазностьДат);
			
	Возврат СтруктураДанные;
	
КонецФункции

&НаСервере
// Процедура конфигурирования формы при запуске
//
Процедура НастройкаФормыСервер(РежимНастройки = Неопределено, ПерезаполнитьДеревьяПодбора = Ложь)
	
	// Получить дисконтную карту контрагента
	ПолучитьДисконтнуюКартуКонтрагента(РежимНастройки);
	
	Элементы.КонтрагентСтраховойПолис.Доступность = Ложь;
	Элементы.КонтрагентСтраховойПолис.СписокВыбора.Очистить();
	// Проверка существования страховых полисов и настройка элементов
	// Загрузить полисы
	МассивПолисов = ПолучитьСтраховыеПолисыКонтрагента(Объект.Контрагент, Объект.Дата);
	Если МассивПолисов.Количество() > 0 Тогда	
		Элементы.КонтрагентСтраховойПолис.Доступность = Истина;
		// Заполнение списка выбора
		Элементы.КонтрагентСтраховойПолис.СписокВыбора.ЗагрузитьЗначения(МассивПолисов);
		Если РежимНастройки = "ПРИ_ЗАПУСКЕ" И Объект.Ссылка.Пустая() = Истина И Не ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда
			Объект.ПолисМедСтрахования = МассивПолисов[0];
		ИначеЕсли НЕ РежимНастройки = "ПРИ_ЗАПУСКЕ"  Тогда			
			Объект.ПолисМедСтрахования = МассивПолисов[0];
			Объект.ВидЦен              = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
		КонецЕсли;	
		Элементы.КонтрагентСтраховойПолис.Доступность = Истина;
	Иначе
		Если НЕ РежимНастройки = "ПРИ_ЗАПУСКЕ" Тогда 
			Объект.ПолисМедСтрахования = Неопределено;
			Объект.ВидЦен              = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
		КонецЕсли;
	КонецЕсли;
	
	// Информация о взаиморасчетах контрагента
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Телефон = Объект.Контрагент.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента, "Вид");
		Долг    = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Объект.Контрагент,, Объект.СтруктурнаяЕдиница);
		ЗапланированныеОплаты	= ОбщегоНазначенияСтоматология.ВернутьЗапланированныеОплаты(Объект.Контрагент);
		
		Если РежимРаботыЕдинаяСеть Тогда
			ОстатокЛицевогоСчета = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент, ТекущаяДатаСеанса(),,,, Истина);		                		
		Иначе
			ОстатокЛицевогоСчета = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент, ТекущаяДатаСеанса(),, Объект.СтруктурнаяЕдиница,, Истина);	
		КонецЕсли;
		
		// Декорация планируемых оплат контрагента
		Элементы.ДекорацияЗапланированныеОплаты.Заголовок = "Запланированные оплаты:";
		Элементы.ДекорацияСуммаПланируемыхОплат.Заголовок = Формат(ЗапланированныеОплаты, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Если ЗапланированныеОплаты > 0 Тогда 
			Элементы.ДекорацияЗапланированныеОплаты.ЦветТекста = Новый Цвет(220,140,0); // Новый Цвет(150, 95, 9);
			Элементы.ДекорацияСуммаПланируемыхОплат.ЦветТекста = Новый Цвет(220,140,0); // Новый Цвет(150, 95, 9);
		Иначе 
			Элементы.ДекорацияЗапланированныеОплаты.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияСуммаПланируемыхОплат.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		КонецЕсли;	
		
		// Декорация задолженности контрагента
		Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		Если Долг > 0 Тогда
			Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Долг пациента:";
			Элементы.ДекорацияДолг.Заголовок                = Формат(Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = WebЦвета.Красный;
			Элементы.ДекорацияДолг.ЦветТекста               = WebЦвета.Красный;			
		ИначеЕсли Долг < 0 Тогда
			Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Наш долг перед пациентом:";
			Элементы.ДекорацияДолг.Заголовок                = Формат(-Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияДолг.ЦветТекста               = ЦветаСтиля.ПоясняющийТекст;	
		Иначе	
			Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Нет задолженности.";
			Элементы.ДекорацияДолг.Заголовок                = "";
			Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияДолг.ЦветТекста               = ЦветаСтиля.ПоясняющийТекст;	
		КонецЕсли;
		
		// Декорация остатка лицевого счета
		Элементы.ДекорацияОстаткиНаЛицевыхсчетах.Заголовок = "На лицевом счете:";
		Элементы.ДекорацияОстатокЛицевогоСчета.Заголовок   = Формат(ОстатокЛицевогоСчета, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Если ОстатокЛицевогоСчета < 0 Тогда
			Элементы.ДекорацияОстаткиНаЛицевыхсчетах.ЦветТекста = WebЦвета.Красный;
			Элементы.ДекорацияОстатокЛицевогоСчета.ЦветТекста   = WebЦвета.Красный;
		Иначе
			Элементы.ДекорацияОстаткиНаЛицевыхсчетах.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияОстатокЛицевогоСчета.ЦветТекста   = ЦветаСтиля.ПоясняющийТекст;
		КонецЕсли; 		
	КонецЕсли;
		
	SVGВыделенныйЗуб             = "var selectzub"; 
	SVGМассивВыделенныхЗубов     = "var SelectedTeeth = [];";
	SVGМассивЛечащихсяЗубов      = "var mas='';";
	НовыйТипЗубнойФормулы        = Объект.Контрагент.ТипЗубнойФормулы;
	Если ТипЗубнойФормулы <> НовыйТипЗубнойФормулы Или РежимНастройки = "ПРИ_ЗАПУСКЕ" Тогда
		 ТипЗубнойФормулы = НовыйТипЗубнойФормулы;
		 УстановитьЗубнуюФормулу(); 
		 ЗагрузитьСтатусыЗубов(?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Дата, ТекущаяДатаСеанса())); 
		 ЗубнаяФормулаSVGBody = ФормированиеSVGКлиентСервер.СформироватьЗубнуюФормулу(СтатусыЗубов, ?(ТипЗубнойФормулы = 1, Истина, Ложь)); 
		 SVGМассивСтатусовЗубов                       = "var status = '';";
		 SVGМассивОбластей                            = "var ColorStatus = ''"; 
	КонецЕсли;
	 
	 Если ТипЗубнойФормулы = 1 Тогда
		 ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовокДФ").ПолучитьТекст();
	 Иначе
		 ЗубнаяФормулаSVG = ПолучитьОбщийМакет("SVGЗаголовок").ПолучитьТекст();
	 КонецЕсли; 
	 // формирование меню областей
	СформироватьМенюОбластей(ЗубнаяФормулаSVG);
	 
	Если РежимНастройки = "ПРИ_ЗАПУСКЕ" ИЛИ РежимНастройки = "ПРИ_ИЗМЕНЕНИИ_СОТРУДНИКА" Тогда		
		// Установить состояние формы в зависимости от признака стоматологических услуг
		Если ЭтоСтоматологическиеУслуги Тогда
			Элементы.ГруппаУслугиПодборЗубов.Видимость  = Истина;
			Элементы.ТаблицаЛечениеЗуб.Видимость        = Истина;
			
		Иначе
			Элементы.ГруппаУслугиПодборЗубов.Видимость  = Ложь;
			Элементы.ТаблицаЛечениеЗуб.Видимость        = Ложь;
		КонецЕсли;
	КонецЕсли; 
	
	// Если пред. выбранный контрагент не равен текущему пересчитать ТЧ
	Если НЕ ПредВыбранныйКонтрагент = Объект.Контрагент ИЛИ НЕ ПредВыбранныйСтраховойПолис = Объект.ПолисМедСтрахования Тогда
		
		ПересчитатьАвтоматическиеСкидкиИОбновитьЗаголовкиТабЧастей();
		
		Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда 			
			СтруктураПолис = ВернутьВидЦеныИДоговорПоПолису(Объект.ПолисМедСтрахования); 	
			ЭтотОбъект._ПодборДоговорПолиса = ?(ЗначениеЗаполнено(СтруктураПолис.Договор), СтруктураПолис.Договор, Справочники.ДоговорыКонтрагентов.ПустаяСсылка());			
		Иначе
			ЭтотОбъект._ПодборДоговорПолиса = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ПредВыбранныйСтраховойПолис = Объект.ПолисМедСтрахования Тогда
			ОбновлениеНоменклатурыВТаблицахПодбора(); 
		КонецЕсли;

	КонецЕсли;

	// Доступность полей ограничивается при статусе Принят и Закрыт для неполных прав.       
	Элементы.ТаблицаЛечение.ТолькоПросмотр                            = Не РедактированиеРазрешено;
	Элементы.ГруппаКомманднаяПанельРедактирование.ТолькоПросмотр      = Не РедактированиеРазрешено;
	Элементы.ФормаКнопкаПровестиИЗакрыть.Доступность		       	  = РедактированиеРазрешено;
	Элементы.ГруппаОсновное.ТолькоПросмотр						      = Не РедактированиеРазрешено;
	Элементы.Комментарий.ТолькоПросмотр					           	  = Не РедактированиеРазрешено;
	Элементы.ГруппаЗубнаяФормула.ТолькоПросмотр		  		  	   	  = Не РедактированиеРазрешено;   
	Элементы.СписокКонтекстноеМенюГруппаСоздание.ТолькоПросмотр	   	  = Не РедактированиеРазрешено;
	Элементы.СписокКонтекстноеМенюГруппаРедактирование.ТолькоПросмотр = Не РедактированиеРазрешено;
	Элементы.СписокКонтекстноеМенюГруппаСортировка.ТолькоПросмотр	  = Не РедактированиеРазрешено; 
	Элементы.ТаблицаЛучениеПоказатьСкрытьПодбор.Доступность	       	  = РедактированиеРазрешено;
	Элементы.ФормаПровести.Доступность      					      = РедактированиеРазрешено;
	Элементы.Сотрудник.ТолькоПросмотр      						      = Не РедактированиеРазрешено;
	Элементы.Статус.ТолькоПросмотр      							  = Не РедактированиеРазрешено;
	Элементы.Удалить.Доступность      							  	  = РедактированиеРазрешено;
	Элементы.ФормаОтменитьПроведение.Доступность                   	  = РедактированиеРазрешено;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура возвращает вид цен
//
Функция  ВернутьВидЦены(ПолисМедСтрахования, Сотрудник, СтруктурнаяЕдиница)	
	ВидЦен = Неопределено;
	Если ЗначениеЗаполнено(ПолисМедСтрахования)
		И ЗначениеЗаполнено(ПолисМедСтрахования.СтраховаяКомпания.ВидЦен_Удалить) Тогда 
		ВидЦен = ПолисМедСтрахования.СтраховаяКомпания.ВидЦен_Удалить;
	ИначеЕсли ЗначениеЗаполнено(Сотрудник) Тогда				
		ВидЦен  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Сотрудник, СтруктурнаяЕдиница , "ВидЦен");		
	КонецЕсли;		
	Если НЕ ЗначениеЗаполнено(ВидЦен) 
		И ЗначениеЗаполнено(СтруктурнаяЕдиница.ВидЦенРеализации) Тогда 
		ВидЦен = СтруктурнаяЕдиница.ВидЦенРеализации;
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(ВидЦен) Тогда		
		ВидЦен = Справочники.ВидыЦен.Розничная;
	КонецЕсли;	
	Возврат ВидЦен;	
КонецФункции

&НаКлиенте
// Процедура рассчитывает сумму в строке табличной части.
//
Процедура ТабличныеЧастиРассчитатьСуммуВСтроке(СтрокаТабличнойЧасти)
	
	СтруктураПараметров = Новый Структура("ПорядокОкругления, ОкруглятьВБольшуюСторону", ПараметрыВидаЦены.ПорядокОкругления, ПараметрыВидаЦены.ОкруглятьВБольшуюСторону);	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти,СтруктураПараметров);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры 

&НаСервере
// Процедура рассчитывает сумму в строке табличной части.
//
Процедура ТабличныеЧастиРассчитатьСуммуВСтрокеСервер(СтрокаТабличнойЧасти)
	
	СтруктураПараметров = Новый Структура("ПорядокОкругления, ОкруглятьВБольшуюСторону", ПараметрыВидаЦены.ПорядокОкругления, ПараметрыВидаЦены.ОкруглятьВБольшуюСторону);	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, СтруктураПараметров);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры 

