
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.ЭтоВерсияКОРП = ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП();
	
	ТекущийПользователь = ПараметрыСеанса.ТекущийСотрудник;
	// ОбновитьДинамическиеМенюОтборов(Параметры.Отбор, Истина);
	СоздатьУсловноеОформление();
//	Элементы.Изменить.Видимость = РольДоступна(Метаданные.Роли.ПолныеПрава);
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Инициализируем настройки при первом открытии формы
	Если ХранилищеСистемныхНастроек.Загрузить("Справочник.Контрагенты.Форма.ФормаСпискаПотенциальныеКлиенты/ТекущиеДанные") = Неопределено Тогда
		Настройки = Новый Соответствие;
		ХранилищеСистемныхНастроек.Сохранить("Справочник.Контрагенты.Форма.ФормаСпискаПотенциальныеКлиенты/ТекущиеДанные", ,Настройки);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОТБОРЫ_СПИСКА_ПОТЕНЦИАЛЬНЫХ_КЛИЕНТОВ" Тогда 
		ИнициализироватьМеханизмФильтрацииДанных(Параметр.Отбор, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события при загрузке данных из настроек на сервере.
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	ИнициализироватьМеханизмФильтрацииДанных(Параметры.Отбор, Истина);
	СоздатьУсловноеОформление();
	
	УстановитьВидимостьЭлементовКОРП();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура, обработчик события "СписокВыбор".
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущаяСтрока 		 = Элементы.Список.ТекущиеДанные;
	
	Если Поле.Имя = "ПоследняяЗадачаПредставление" ИЛИ Поле.Имя = "ПоследняяЗадачаЗадачаНазначеннаяДата"
		И ЗначениеЗаполнено(ТекущаяСтрока.ПоследняяЗадача) Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.ПоследняяЗадача);
		
	ИначеЕсли Поле.Имя = "СледующаяЗадачаПредставление" ИЛИ Поле.Имя = "СледующаяЗадачаЗадачаНазначеннаяДата"
		И ЗначениеЗаполнено(ТекущаяСтрока.СледующаяЗадача)Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.СледующаяЗадача);
		
	Иначе
		
		ПоказатьЗначение(,ТекущаяСтрока.Клиент);
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы 

&НаКлиенте
