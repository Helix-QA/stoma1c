// Процедура - Инициализировать текст запроса для регистрации при подписке на занятие
//
// Параметры:
//  Запрос	 - 	 - 
//
Процедура ИнициализироватьТекстЗапросаДляРегистрацииПриПодпискеНаЗапись(Запрос)
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТриггерныеСобытия.Ссылка КАК ТриггерноеСобытие,
	|	&Контрагент КАК Контрагент,
	|	&ДатаЗаписи КАК Дата,
	|	&ДатаВремяНачала КАК ДатаВремяНачала,
	|	&ДатаВремяОкончания КАК ДатаВремяОкончания,
	|	&ДатаОтменыЗаписи КАК ДатаОтменыЗаписи,
	|	&СтатусЗаписи КАК СтатусЗаписи,
	|	ТриггерныеСобытия.ИдентификаторДействия КАК ИдентификаторДействия,
	|	ТриггерныеСобытия.Использование КАК Использование,
	|	ТриггерныеСобытия.ВидДействия КАК ВидДействия,
	|	ТриггерныеСобытия.Удалено КАК Удалено,
	|	ТриггерныеСобытия.Ссылка.Активно КАК Активно,
	|	ТриггерныеСобытия.Описание КАК Описание,
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Зарегистрировано) КАК ПланируемыйСтатус
	|ПОМЕСТИТЬ ТаблицаТриггеровИКонтрагентов
	|ИЗ
	|	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытия
	|ГДЕ
	|	ТриггерныеСобытия.Ссылка.ЭтоГруппа = ЛОЖЬ
	|	И ТриггерныеСобытия.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И ТриггерныеСобытия.Ссылка.УсловиеСобытия В(&МассивГибридныхТриггеров)
	|	И ТриггерныеСобытия.Ссылка.УсловиеСобытия <> ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема)
	|	И ТриггерныеСобытия.Ссылка.МоментСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия)
	|	И ВЫБОР
	|			КОГДА ТриггерныеСобытия.Ссылка.УсловиеСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием)
	|				ТОГДА НЕ НАЧАЛОПЕРИОДА(&ДатаЗаписи, ДЕНЬ) < НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТриггерныеСобытия.Ссылка,
	|	&Контрагент,
	|	&ДатаЗаписи,
	|	&ДатаВремяНачала,
	|	&ДатаВремяОкончания,
	|	&ДатаОтменыЗаписи,
	|	&СтатусЗаписи,
	|	ТриггерныеСобытия.ИдентификаторДействия,
	|	ТриггерныеСобытия.Использование,
	|	ТриггерныеСобытия.ВидДействия,
	|	ТриггерныеСобытия.Удалено,
	|	ТриггерныеСобытия.Ссылка.Активно,
	|	ТриггерныеСобытия.Описание,
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
	|ИЗ
	|	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытия
	|ГДЕ
	|	&Контрагент <> НЕОПРЕДЕЛЕНО
	|	И ТриггерныеСобытия.Ссылка.ЭтоГруппа = ЛОЖЬ
	|	И ТриггерныеСобытия.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И ТриггерныеСобытия.Ссылка.УсловиеСобытия В(&МассивГибридныхТриггеров)
	|	И ВЫБОР
	|			КОГДА ТриггерныеСобытия.Ссылка.УсловиеСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ТриггерныеСобытия.Ссылка.МоментСобытия В (ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия), ЗНАЧЕНИЕ(Перечисление.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия))
