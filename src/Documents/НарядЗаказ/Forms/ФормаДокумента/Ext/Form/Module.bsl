&НаКлиенте
// Процедура, пересчитывает сумму ручной скидки.
//
Процедура ПересчитатьСуммуРучнойСкидкиВСтрокеТЧ(знач ТекущаяСтрока, ИспользоватьКоличество = Ложь)

	Если ИспользоватьКоличество <> Истина Тогда
		ТекущаяСтрока.СуммаРучнойСкидки = Окр(ТекущаяСтрока.КоличествоУпаковок * ТекущаяСтрока.ЦенаПродажи * ТекущаяСтрока.ПроцентСкидкиНаценки / 100, 2);
	Иначе
		ТекущаяСтрока.СуммаРучнойСкидки = Окр(ТекущаяСтрока.Количество * ТекущаяСтрока.ЦенаПродажи * ТекущаяСтрока.ПроцентСкидкиНаценки / 100, 2);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, пересчитывает процент ручной скидки
//
Процедура ПересчитатьПроцентРучнойСкидкиВСтрокеТЧ(знач ТекущаяСтрока, ИспользоватьКоличество = Ложь)  Экспорт
	
	Если ИспользоватьКоличество <> Истина Тогда
		Если ТекущаяСтрока.КоличествоУпаковок * ТекущаяСтрока.ЦенаПродажи <> 0 Тогда
			ТекущаяСтрока.ПроцентСкидкиНаценки = Окр(100*ТекущаяСтрока.СуммаРучнойСкидки / (ТекущаяСтрока.КоличествоУпаковок *ТекущаяСтрока.ЦенаПродажи), 2);
		Иначе
			ТекущаяСтрока.ПроцентСкидкиНаценки = 0;
		КонецЕсли;	
	Иначе
		Если ТекущаяСтрока.Количество * ТекущаяСтрока.ЦенаПродажи <> 0 Тогда
			ТекущаяСтрока.ПроцентСкидкиНаценки = Окр(100*ТекущаяСтрока.СуммаРучнойСкидки / (ТекущаяСтрока.Количество *ТекущаяСтрока.ЦенаПродажи), 2);
		Иначе
			ТекущаяСтрока.ПроцентСкидкиНаценки = 0;
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры 

