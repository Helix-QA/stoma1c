// Функция возвращает ставку НДС
//
Функция ВернутьСтавкуНДС(СтруктураДанные)
	
	Если Не СтруктураДанные.Свойство("СтруктурнаяЕдиница")
		Или (СтруктураДанные.Свойство("СтруктурнаяЕдиница") И Не ЗначениеЗаполнено(СтруктураДанные.СтруктурнаяЕдиница)) Тогда
		
		СтруктураДанные.Вставить("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	КонецЕсли;
	
	Организация = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтруктураДанные.СтруктурнаяЕдиница, "Организация");
	
	ДанныеОрганизации	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация,
								"СПриоритетомНоменклатуры, СтавкаНДС, СтавкаНДСДляАвансов, СистемаНалогообложенияДляТоваров, СистемаНалогообложенияДляАвансов");
	ДанныеНоменклатуры	= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтруктураДанные.Номенклатура,
								"СтавкаНДС, ТипНоменклатуры");
	
	Если НЕ ДанныеОрганизации.СПриоритетомНоменклатуры 
		ИЛИ (ДанныеОрганизации.СПриоритетомНоменклатуры И Не ЗначениеЗаполнено(ДанныеНоменклатуры.СтавкаНДС)) Тогда
		
		Если ДанныеНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат
			И ЗначениеЗаполнено(ДанныеОрганизации.СтавкаНДСДляАвансов) Тогда
			
			СтавкаНДС = ДанныеОрганизации.СтавкаНДСДляАвансов; 
		Иначе
			СтавкаНДС = ДанныеОрганизации.СтавкаНДС;
		КонецЕсли;
		
	Иначе
		СтавкаНДС = ДанныеНоменклатуры.СтавкаНДС;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтавкаНДС) Тогда
		Если ЗначениеЗаполнено(ДанныеОрганизации.СистемаНалогообложенияДляТоваров) Тогда 
			Если ДанныеОрганизации.СистемаНалогообложенияДляТоваров = Перечисления.СистемыНалогообложения.Общая Тогда 
				Возврат Перечисления.СтавкиНДС.НДС20;
			Иначе 
				Возврат Перечисления.СтавкиНДС.БезНДС;
			КонецЕсли;
		Иначе 
			Возврат Перечисления.СтавкиНДС.БезНДС;
		КонецЕсли;
	Иначе
		Возврат СтавкаНДС;
	КонецЕсли;   	
	
	// Если ЗначениеЗаполнено(СтруктураДанные.Номенклатура.СтавкаНДС) Тогда 
	//	Возврат СтруктураДанные.Номенклатура.СтавкаНДС;
	// Иначе 
	//	Если ЗначениеЗаполнено(СтруктураДанные.СтруктурнаяЕдиница.Организация.СистемаНалогообложения) Тогда 
	//		Если СтруктураДанные.СтруктурнаяЕдиница.Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда 
	//			Возврат Перечисления.СтавкиНДС.НДС20;
	//		Иначе 
	//			Возврат Перечисления.СтавкиНДС.БезНДС;
	//		КонецЕсли;
	//	Иначе 
	//		Возврат Перечисления.СтавкиНДС.БезНДС;
	//	КонецЕсли;
	// КонецЕсли;	
	
КонецФункции

&НаСервере
// Возвращает общую сумму документа без учета скидки
//
Функция ПолучитьСуммуДокументаБезСкидки(ТабличнаяЧасть) Экспорт

	СуммаДокумента = 0;	
	Для каждого СтрокаТабличнойЧасти Из ТабличнаяЧасть Цикл
		// Если это строка таблицы значений
		Если ТипЗнч(СтрокаТабличнойЧасти) = Тип("СтрокаТаблицыЗначений") Тогда
			ТВладелец = СтрокаТабличнойЧасти.Владелец();
			Если ТВладелец.Колонки.Найти("КоличествоУпаковок") <> Неопределено Тогда
				СуммаПоСтроке = Окр(СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.КоличествоУпаковок, 2);
			Иначе
				СуммаПоСтроке = Окр(СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.Количество, 2);
			КонецЕсли;
		// Если это строка табличной части	
		Иначе	 
			СуммаПоСтроке = Окр(СтрокаТабличнойЧасти.Цена * ?(СтрокаТабличнойЧасти.Свойство("КоличествоУпаковок"),СтрокаТабличнойЧасти.КоличествоУпаковок,СтрокаТабличнойЧасти.Количество), 2);
		КонецЕсли;
		СуммаДокумента = СуммаДокумента + СуммаПоСтроке;
	КонецЦикла;

	Возврат СуммаДокумента;

КонецФункции // ПолучитьСуммуДокументаБезСкидки()

&НаСервере
// Выполняем пересчет цены табличной части документа после изменений в форме 
// "Цены и валюта".
//
Процедура ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ФормаДокумента, ИмяТабличнойЧасти, ПересчитатьСкидки = Ложь) Экспорт
	
	СтруктураДанных = Новый Структура;
	ТабличнаяЧастьДокумента = Новый Массив;

	СтруктураДанных.Вставить("Дата",				ФормаДокумента.Объект.Дата);
	СтруктураДанных.Вставить("СтруктурнаяЕдиница",	ФормаДокумента.Объект.СтруктурнаяЕдиница);
	СтруктураДанных.Вставить("ВидЦен",				ФормаДокумента.Объект.ВидЦен);
	
	// Если ПересчитатьСкидки Тогда
	//	СтруктураДанных.Вставить("ВидСкидкиНаценки", ФормаДокумента.Объект.ВидСкидкиНаценки);
	//	СтруктураДанных.Вставить("ПроцентСкидкиНаценки", 0);
	// КонецЕсли;
	
	Для каждого СтрокаТЧ Из ФормаДокумента.Объект[ИмяТабличнойЧасти] Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
			Продолжить;	
		КонецЕсли; 
		
		СтрокаТабличнойЧасти = Новый Структура();
		СтрокаТабличнойЧасти.Вставить("Номенклатура",		СтрокаТЧ.Номенклатура);
		СтрокаТабличнойЧасти.Вставить("Упаковка",			СтрокаТЧ.Упаковка);
		Если СтрокаТЧ.Свойство("СтавкаНДС") Тогда
			СтрокаТабличнойЧасти.Вставить("СтавкаНДС",			СтрокаТЧ.СтавкаНДС);
		КонецЕсли;
		СтрокаТабличнойЧасти.Вставить("Цена",				0);
		
		ТабличнаяЧастьДокумента.Добавить(СтрокаТабличнойЧасти);
		
	КонецЦикла;
		
	Ценообразование.ПолучитьЦеныТабличнойЧастиПоВидуЦен(СтруктураДанных, ТабличнаяЧастьДокумента);
		
	Для каждого СтрокаТЧ Из ТабличнаяЧастьДокумента Цикл

		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура",		СтрокаТЧ.Номенклатура);
		СтруктураПоиска.Вставить("Упаковка",			СтрокаТЧ.Упаковка);
		Если СтрокаТЧ.Свойство("СтавкаНДС") Тогда 
			СтруктураПоиска.Вставить("СтавкаНДС",			СтрокаТЧ.СтавкаНДС);
		КонецЕсли;
		
		РезультатПоиска = ФормаДокумента.Объект[ИмяТабличнойЧасти].НайтиСтроки(СтруктураПоиска);
		
		Для каждого СтрокаРезультат Из РезультатПоиска Цикл
			
			СтрокаРезультат.Цена = СтрокаТЧ.Цена;
			
			Если СтрокаРезультат.Свойство("Сумма") Тогда
				ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаРезультат);
			КонецЕсли;
			Если СтрокаРезультат.Свойство("СуммаНДС") Тогда
				ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаРезультат);
			КонецЕсли;
			Если СтрокаРезультат.Свойство("Всего") Тогда
				ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаРезультат);
			КонецЕсли;			
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Если ПересчитатьСкидки Тогда
	//	Для каждого СтрокаТабличнойЧасти Из ФормаДокумента.Объект[ИмяТабличнойЧасти] Цикл
	//		СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = СтруктураДанных.ПроцентСкидкиНаценки;
	//		РассчитатьСуммуСтрокиТабличнойЧасти(ФормаДокумента, СтрокаТабличнойЧасти);
	//	КонецЦикла;
	// КонецЕсли;
	
КонецПроцедуры // ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен()

#КонецОбласти
