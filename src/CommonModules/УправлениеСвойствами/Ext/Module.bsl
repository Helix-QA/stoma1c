				// группа для долга клиента	
				ГруппаКнопкиДолгКлиентаДинам = Элементы.Добавить("Группа_Кнопки_Долг_Клиента_Динам" + ИндексСтроки, Тип("ГруппаФормы"), ГруппаРодитель);
