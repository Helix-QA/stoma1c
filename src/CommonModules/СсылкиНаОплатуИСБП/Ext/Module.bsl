
#Область ОсновнаяТочкаВхода

// Функция - Сформировать ссылку на оплату
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьСсылкуНаОплату(СтруктураПараметров) Экспорт
	
	СтруктураВозврата	= Новый Структура("ВыполненоУспешно, ОписаниеОшибки, СсылкаНаОплату, ВремяДействителенДо, НомерЗаказа", Ложь, Неопределено, Неопределено, Неопределено, Неопределено);	
	ПараметрыПШ			= СтруктураПараметров.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
	emailCompany		= КонтактнаяИнформацияВызовСервераСтома.ПолучитьКонтактнуюИнформацию(СтруктураПараметров.СтруктурнаяЕдиница, Ложь).Email;		
		
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры платежного шлюза"; 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	ТипБанка				= СтруктураПараметров.ЭквайринговыйТерминал.ТипБанка;
	ПараметрыПШ.ВремяЖизни	= ?(ЗначениеЗаполнено(ПараметрыПШ.ВремяЖизни), ПараметрыПШ.ВремяЖизни, 72); 
	
	СтруктураПараметров.Вставить("ПараметрыПШ"		, ПараметрыПШ); 
	СтруктураПараметров.Вставить("ТипБанка"			, ТипБанка);
	СтруктураПараметров.Вставить("СтруктураВозврата", СтруктураВозврата);
	
	Если ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ И Не ЗначениеЗаполнено(emailCompany) Тогда
		СтруктураВозврата.ОписаниеОшибки = "В контактной информации структурной единицы не заполнен email"; 
		Возврат СтруктураВозврата;		
	КонецЕсли;
		
	Если ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф Тогда
		Возврат Тинькофф_ЗарегистрироватьQR(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк Тогда
		Возврат АльфаБанк_ЗарегистрироватьQR(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк ИЛИ ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR Тогда
		Возврат Сбербанк_ЗарегистрироватьQR(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк Тогда 
		Возврат РайффайзенБанк_ЗарегистрироватьQR(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.Сбербанк Тогда
		Возврат СформироватьСсылкуОплатыСбербанк(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
		Возврат СДМ_ЗарегистрироватьQR(СтруктураПараметров);
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "Платежный шлюз не поддерживается"; 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
КонецФункции

// Функция - Отменить ссылку на оплату
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОтменитьСсылкуНаОплату(СтруктураПараметров) Экспорт
	
	СтруктураВозврата	= Новый Структура("ВыполненоУспешно, ОписаниеОшибки, СсылкаНаОплату", Ложь, Неопределено, Неопределено);	
	ПараметрыПШ			= СтруктураПараметров.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
	ТипБанка			= СтруктураПараметров.ЭквайринговыйТерминал.ТипБанка;
	
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры платежного шлюза"; 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураПараметров.Вставить("ПараметрыПШ"		, ПараметрыПШ); 
	СтруктураПараметров.Вставить("ТипБанка"			, СтруктураПараметров.ЭквайринговыйТерминал.ТипБанка);
	СтруктураПараметров.Вставить("СтруктураВозврата", СтруктураВозврата);
	
	Если ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф Тогда
		Возврат Тинькофф_ОтменитьQRКод(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк Тогда
		Возврат АльфаБанк_ОтменитьQRКод(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк ИЛИ ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR Тогда
		Возврат Сбербанк_ОтменитьQRКод(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк Тогда 
		Возврат РайффайзенБанк_ОтменитьQRКод(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда 
		Возврат СДМ_ОтменитьQRКод(СтруктураПараметров);
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.Сбербанк Тогда
		Возврат Сбербанк_ОтменитьСсылку(СтруктураПараметров);
	Иначе
		Возврат ОтменитьСсылкуНаОплатуОбщая(СтруктураПараметров);
	КонецЕсли;
	
КонецФункции

// Функция - Отменить ссылку на оплату общая
// 
// Возвращаемое значение:
//   - 
//
 Функция ОтменитьСсылкуНаОплатуОбщая(СтруктураПараметров)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.Основание КАК Основание
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.СсылкаОплаты = &СсылкаНаОплату");
	
	Запрос.УстановитьПараметр("СсылкаНаОплату", СтруктураПараметров.СсылкаНаОплату);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОписаниеСтатуса  = НСтр("ru='Платеж отменен пользователем ';en='Payment canceled by user '") + Строка(ПараметрыСеанса.ТекущийПользователь);
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		Выборка.Основание,,,,
		Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ,,
		Выборка.НомерЗаказа,,,,,,,
		ОписаниеСтатуса);
		
	КонецЦикла;
	
	СтруктураПараметров.СтруктураВозврата.ВыполненоУспешно = Истина;
	
	Возврат СтруктураПараметров.СтруктураВозврата;
	
КонецФункции

// Функция - Сформировать возврат по СБП
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьВозвратПоСБП(Знач СтруктураПараметров) Экспорт
	
	СтруктураВозврата	= Новый Структура("ВыполненоУспешно, ОписаниеОшибки", Ложь, Неопределено);	
	ПараметрыПШ			= СтруктураПараметров.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();	
	ОтветJSON			= Неопределено;
	
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры платежного шлюза"; 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если РегистрыСведений.СтатусыОплатыЗаказов.УжеСформированВозвратПоОснованию(СтруктураПараметров.ВозвратОтПокупателя, СтруктураПараметров.ЭквайринговыйТерминал) Тогда
		СтруктураВозврата.ОписаниеОшибки = "Уже сформирован возврат, который в процессе подтверждения банком, необходимо дождаться завершения"; 
		Возврат СтруктураВозврата;	
	КонецЕсли;
	
	ЗадолженностьПоДокументу = СтруктураПараметров.ВозвратОтПокупателя.СуммаДокумента - СтруктураПараметров.ВозвратОтПокупателя.СуммаОплачено;
	
	Если ЗадолженностьПоДокументу = 0 Тогда
		СтруктураВозврата.ОписаниеОшибки = "Задолженность по документу равна нулю"; 
		Возврат СтруктураВозврата;	
	КонецЕсли;
	
	Если СтруктураПараметров.СуммаВозвратаВРублях > ЗадолженностьПоДокументу Тогда
		СтруктураВозврата.ОписаниеОшибки = "Сумма возврата превышает задолженность по документу"; 
		Возврат СтруктураВозврата;	
	КонецЕсли;
	
	ДанныеЗаказа = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьДанныеЗаказа(СтруктураПараметров.ВозвратОтПокупателя, СтруктураПараметров.ЭквайринговыйТерминал);
	
	Если ДанныеЗаказа = Неопределено Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не найден заказ для осуществления возврата"; 
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	Если СтруктураПараметров.СуммаВозвратаВРублях > ДанныеЗаказа.Сумма Тогда
		СтруктураВозврата.ОписаниеОшибки = "Сумма возврата превышает оплаченную сумму по заказу"; 
		Возврат СтруктураВозврата;	
	КонецЕсли;
		
	ТипБанка				= СтруктураПараметров.ЭквайринговыйТерминал.ТипБанка;
	ПараметрыПШ.ВремяЖизни	= ?(ЗначениеЗаполнено(ПараметрыПШ.ВремяЖизни), ПараметрыПШ.ВремяЖизни, 72); 
	
	СтруктураПараметров.Вставить("ПараметрыПШ"				, ПараметрыПШ); 
	СтруктураПараметров.Вставить("ТипБанка"					, ТипБанка);
	СтруктураПараметров.Вставить("УИДВозврата"				, Строка(Новый УникальныйИдентификатор()));
	СтруктураПараметров.Вставить("НомерЗаказа"				, ДанныеЗаказа.НомерЗаказа);
	СтруктураПараметров.Вставить("ИдСБП"					, ДанныеЗаказа.ИдЗаказа);
	СтруктураПараметров.Вставить("ПараметрыJSON"			, ДанныеЗаказа.ПараметрыJSON);
	СтруктураПараметров.Вставить("СтруктураВозврата"		, СтруктураВозврата);
	СтруктураПараметров.Вставить("Сотрудник"				, ПараметрыСеанса.ТекущийПользователь);
	СтруктураПараметров.Вставить("ПредставлениеСотрудника"	, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктураПараметров.Сотрудник,"Представление"));	
	
	Статус = Неопределено;
	Если ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк Тогда 
		
		ТипСсылкиНаОплату	= Перечисления.ТипыСсылокНаОплату.СБПРайффайзенБанк;
		РезультатЗапроса	= РайффайзенБанк_ВозвратЗаказа(СтруктураПараметров);
		
		Если РезультатЗапроса.ВыполненоУспешно Тогда
			ОбщегоНазначенияБТС.Пауза(3);
			РезультатЗапроса = РайффайзенБанк_ПолучитьИнформациюПоВозврату(СтруктураПараметров, ОтветJSON);
			Если РезультатЗапроса.ВыполненоУспешно Тогда
				Статус = РезультатЗапроса.ПараметрыРезультата.refundStatus;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф Тогда
		
		ТипСсылкиНаОплату	= Перечисления.ТипыСсылокНаОплату.СБПТинькофф;
		РезультатЗапроса 	= Тинькофф_ОтменитьQRКодЗапрос(ДанныеЗаказа.ИдЗаказа, ПараметрыПШ, ОтветJSON);
		
		Если РезультатЗапроса.ВыполненоУспешно Тогда
			Статус = РезультатЗапроса.ПараметрыРезультата.Status;
		КонецЕсли;
		
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
		
		ТипСсылкиНаОплату	= Перечисления.ТипыСсылокНаОплату.СБПСДМ;
		РезультатЗапроса 	= СДМ_ОтменитьQRКодЗапрос(ДанныеЗаказа.ИдЗаказа, ПараметрыПШ, ОтветJSON);
		
		Если РезультатЗапроса.ВыполненёоУспешно Тогда
			Статус = РезультатЗапроса.ПараметрыРезультата.Status;
		КонецЕсли;
		
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк Тогда
		
		ТипСсылкиНаОплату	= Перечисления.ТипыСсылокНаОплату.СБПАльфаБанк;
		РезультатЗапроса 	= АльфаБанк_ВозвратПлатежа(СтруктураПараметров, ОтветJSON);
		
		Если РезультатЗапроса.ВыполненоУспешно Тогда
			ОбщегоНазначенияБТС.Пауза(3);
			РезультатЗапроса = АльфаБанк_ПолучитьСтатусПлатежаРасширенный(СтруктураПараметров, ОтветJSON);
			Если РезультатЗапроса.ВыполненоУспешно Тогда
				Статус = РезультатЗапроса.ПараметрыРезультата.orderStatus;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк ИЛИ ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR Тогда
				
		ТипСсылкиНаОплату	= ?(ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк, Перечисления.ТипыСсылокНаОплату.СБПСбербанк, Перечисления.ТипыСсылокНаОплату.СбербанкПлатиQR);
		РезультатЗапроса 	= Сбербанк_OrderCancelQr(СтруктураПараметров, ОтветJSON);
		
		Если РезультатЗапроса.ВыполненоУспешно Тогда
			Статус = ?(РезультатЗапроса.ПараметрыРезультата.Свойство("order_status"), РезультатЗапроса.ПараметрыРезультата.order_status, "NEW");
		КонецЕсли;
		
	Иначе
		ОтменитьТранзакцию();
		СтруктураВозврата.ОписаниеОшибки = "Платежный шлюз не поддерживается"; 		
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		Возврат СформироватьДокументСписанияИПробить(СтруктураПараметров, Статус, ТипСсылкиНаОплату, ОтветJSON);
			
	Иначе
		СтруктураВозврата.ОписаниеОшибки = РезультатЗапроса.ОписаниеОшибки; 
		Возврат СтруктураВозврата; 
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ВиджетЛК

// Функция, формирует ссылку на оплату для оплаты из виджета ЛК.
//
Функция СформироватьСсылкуНаОплатуВиджетЛК(СтруктураПараметров)
	
	ТаблицаЗадолженностей 	= СтруктураПараметров.ТаблицаЗадолженностей;
	ЭквайринговыйТерминал 	= СтруктураПараметров.ЭквайринговыйТерминал;
    СтруктурнаяЕдиница 		= СтруктураПараметров.СтруктурнаяЕдиница;
	СуммаОплаты 			= СтруктураПараметров.СуммаОплаты;
	СтруктураВозврата		= СтруктураПараметров.СтруктураВозврата;
	КороткаяСсылка			= "";
	ВнешняяСистема			= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистемуВиджета(Перечисления.ТипыВнешнихСистем.ВиджетРасписания, СтруктурнаяЕдиница);

	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
		
		АдресЛичногоКабинета = Справочники.ВнешниеСистемы.ПолучитьАдресСтраницыЛичногоКабинета(ВнешняяСистема);
		
		Если ЗначениеЗаполнено(АдресЛичногоКабинета) Тогда
			
			Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл 
				
				Реализация 		= СтрокаТ.ДокументЗадолженности;
				СсылкаНаОплату 	= АдресЛичногоКабинета + "?getPayFormDebts=Y&id=" + Строка(Реализация.УникальныйИдентификатор());
				КороткаяСсылка 	= ПолучитьКороткуюСсылку(СсылкаНаОплату);
				
				РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
				СтрокаТ.ДокументЗадолженности,
				СтрокаТ.Задолженность,,
				КороткаяСсылка,
				Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено,
				ЭквайринговыйТерминал,
				РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьМассимальныйНомерЗаказа(Перечисления.ТипыСсылокНаОплату.ВиджетЛК) + 1,,,
				Реализация.Контрагент,,
				СтруктурнаяЕдиница,
				ТекущаяДатаСеанса(),,
				Перечисления.ТипыСсылокНаОплату.ВиджетЛК
				);
				
			КонецЦикла;
		
		Иначе			
			СтруктураВозврата.ОписаниеОшибки = "Не заполнен адрес личного кабинета"; 
			Возврат СтруктураВозврата;
		КонецЕсли;
		
	Иначе
		СтруктураВозврата.ОписаниеОшибки = "Не найдена внешняя система виджета ЛК"; 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураВозврата.СсылкаНаОплату	= КороткаяСсылка;
	СтруктураВозврата.ВыполненоУспешно	= Истина;
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область РайффайзенБанк

// Функция - Райффайзен банк зарегистрировать QR
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РайффайзенБанк_ЗарегистрироватьQR(СтруктураПараметров)
	
	СуммаОплаты	= СтруктураПараметров.СуммаОплаты;	
	НомерЗаказа	= СформироватьНомерЗаказаСБП();
	ЛогинБанка	= СтруктураПараметров.ПараметрыПШ.ЛогинБанка;
	ВремяЖизни	= СтруктураПараметров.ПараметрыПШ.ВремяЖизни;
	ПараметрыПШ	= СтруктураПараметров.ПараметрыПШ;
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("order"				, НомерЗаказа);
	ПараметрыЗапроса.Вставить("amount"				, СуммаОплаты);
	ПараметрыЗапроса.Вставить("qrType"				, "QRDynamic");
	ПараметрыЗапроса.Вставить("sbpMerchantId"		, ЛогинБанка);
	ПараметрыЗапроса.Вставить("qrExpirationDate"	, ТекущаяДатаСеанса() + ВремяЖизни*3600);

	ТекстЗапроса = "";
	РезультатЗапроса = РайффайзенБанк_ЗарегистрироватьQRЗапрос(ПараметрыЗапроса, ПараметрыПШ, ТекстЗапроса);
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл	
			
			КороткаяСсылка 	= РезультатЗапроса.ПараметрыРезультата.payload; //ОбщегоНазначения.ПолучитьКороткуюСсылку(РезультатЗапроса.ПараметрыРезультата.payload);
			
			РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
				СтрокаТ.ДокументЗадолженности,
				СтрокаТ.Задолженность,
				РезультатЗапроса.ПараметрыРезультата.qrId,
				КороткаяСсылка,
				Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено,
				СтруктураПараметров.ЭквайринговыйТерминал,
				НомерЗаказа,ТекстЗапроса,,
				СтруктураПараметров.Контрагент,,
				СтруктураПараметров.СтруктурнаяЕдиница,
				ТекущаяДатаСеанса(),,
				Перечисления.ТипыСсылокНаОплату.СБПРайффайзенБанк,
				ПараметрыСеанса.ТекущийПользователь,
				ТекущаяДатаСеанса() + ВремяЖизни*3600
				);
						
		КонецЦикла;
		
		РезультатЗапроса.Вставить("СсылкаНаОплату"		, КороткаяСсылка);
		РезультатЗапроса.Вставить("ВремяДействителенДо"	, ТекущаяДатаСеанса() + ВремяЖизни*3600);
		РезультатЗапроса.Вставить("НомерЗаказа"			, НомерЗаказа);
		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

// Функция - Райффайзен банк зарегистрировать QRЗапрос
//
// Параметры:
//  ПараметрыЗапроса - 	 - 
//  ПараметрыПШ		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РайффайзенБанк_ЗарегистрироватьQRЗапрос(ПараметрыЗапроса, ПараметрыПШ, ТекстЗапроса = "")
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
	ЗаголовкиHTTP.Вставить("Authorization"		, "Bearer " + ПараметрыПШ.ПарольБанка);
	
	НастройкиСериализацииJSON = Новый НастройкиСериализацииJSON;
	НастройкиСериализацииJSON.ВариантЗаписиДаты 	 = ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением;
	НастройкиСериализацииJSON.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса,, НастройкиСериализацииJSON);
	
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "test.ecom.raiffeisen.ru", "e-commerce.raiffeisen.ru"); 
	Соединение 		= Новый HTTPСоединение(АдресСервера,,,,,5, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос 		= Новый HTTPЗапрос("/api/sbp/v1/qr/register", ЗаголовкиHTTP);			
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
	
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса, КодСостояния);
		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Райффайзен банк отменить QRКод
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РайффайзенБанк_ОтменитьQRКод(СтруктураПараметров)
	
	РезультатОперации = СтруктураПараметров.СтруктураВозврата;
	
	ДокументыЗадолженности = Новый Массив;
	Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл
		ДокументыЗадолженности.Добавить(СтрокаТ.ДокументЗадолженности);	
	КонецЦикла;
	
	ПараметрыПШ = СтруктураПараметров.ПараметрыПШ;
	НомерЗаказа = ?(СтруктураПараметров.Свойство("НомерЗаказа"), СтруктураПараметров.НомерЗаказа, Неопределено);
	
	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьЗаказыПоДокументам(ДокументыЗадолженности, СтруктураПараметров.ЭквайринговыйТерминал, НомерЗаказа);
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		РезультатОперации.ОписаниеОшибки = "Не найдено неоплаченных заказов по данной ссылке";
		Возврат РезультатОперации;	
	КонецЕсли;
	
	МассивИдСБП = Новый Массив;
	Для Каждого СтрокаЗаказа Из ТаблицаЗаказов Цикл
		
		Если МассивИдСБП.Найти(СтрокаЗаказа.ИдЗаказа) = Неопределено Тогда
			
			РезультатОперации = РайффайзенБанк_ОтменитьQRКодЗапрос(СтрокаЗаказа.ИдЗаказа, ПараметрыПШ);
			
			Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
				Возврат РезультатОперации;	
			КонецЕсли;
			
			МассивИдСБП.Добавить(СтрокаЗаказа.ИдЗаказа);
			
		КонецЕсли;
		
		ОписаниеСтатуса  = НСтр("ru='Платеж отменен пользователем ';en='Payment canceled by user '") + Строка(ПараметрыСеанса.ТекущийПользователь);
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаЗаказа.Основание,,,,
		Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ,,
		СтрокаЗаказа.НомерЗаказа,,,,,,,
		ОписаниеСтатуса);
		
	КонецЦикла;
		
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Райффайзен банк отменить QRКод запрос
//
// Параметры:
//  ИдЗаказа	 - 	 - 
//  ПараметрыПШ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция РайффайзенБанк_ОтменитьQRКодЗапрос(ИдЗаказа, ПараметрыПШ)
	
	ЗаголовкиHTTP = Новый Соответствие;	
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
	ЗаголовкиHTTP.Вставить("Authorization"		, "Bearer " + ПараметрыПШ.ПарольБанка);
	
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "test.ecom.raiffeisen.ru", "e-commerce.raiffeisen.ru");
	Соединение 		= Новый HTTPСоединение(АдресСервера,,,,,10, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос 		= Новый HTTPЗапрос("/api/sbp/v2/qrs/" + ИдЗаказа, ЗаголовкиHTTP);					
	
	Попытка
		
		HTTPОтвет	 = Соединение.Удалить(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 Тогда
			РезультатЗапроса = Новый Структура("code", "SUCCESS");	
		ИначеЕсли КодСостояния = 400 Тогда	
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации = ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса, КодСостояния);
		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Райффайзен банк получить статус платежа
//
// Параметры:
//  ИдЗаказа	 - 	 - 
//  ПараметрыПШ	 - 	 - 
//  ТелоОтвета	 - 	 - 
// 
