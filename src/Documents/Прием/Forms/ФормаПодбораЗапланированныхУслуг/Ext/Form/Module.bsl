#Область ОбработчикиСобытийФормы

////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ
&НаКлиенте
Перем ВнесеноПередРедактированием;  // ВнесеноПередРедактированием
&НаКлиенте
Перем ТекДокументСписка;

&НаСервере
// Создание формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ОтборДокумент", ОтборДокумент);	
	// ПодготовкаТаблицуЗадолженностей(ПриСтарте);	
	Если ТипЗнч(ОтборДокумент) = Тип("ДокументСсылка.ПланЛечения") Тогда
		Элементы.ТаблицаДокументовПродажиПартия.Видимость           = Ложь;
		Элементы.ТаблицаДокументовПродажиНоменклатура.Заголовок     = "Услуга";
		Элементы.ТаблицаДокументовПродажиНомерЗаказа.Заголовок      = "Номер приема";
	ИначеЕсли ТипЗнч(ОтборДокумент) = Тип("ДокументСсылка.НарядЗаказ") Тогда
		Элементы.ТаблицаДокументовПродажиНомерЗаказа.Заголовок  = "Номер заказа";
	ИначеЕсли ТипЗнч(ОтборДокумент) = Тип("ДокументСсылка.Прием") Тогда
		Элементы.ТаблицаДокументовПродажиНомерЗаказа.Видимость = Ложь;
	КонецЕсли;
	
	Параметры.Свойство("ОтборСотрудник", ЭтотОбъект.ОтборСотрудник);
	Параметры.Свойство("ОтборСтруктурнаяЕдиница", ЭтотОбъект.ОтборСтруктурнаяЕдиница);
	
	ЭтотОбъект.ОтборСотрудник = ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборСотрудник), ЭтотОбъект.ОтборСотрудник, ПараметрыСеанса.ТекущийСотрудник);
	ЭтотОбъект.ОтборСтруктурнаяЕдиница = ?(ЗначениеЗаполнено(ЭтотОбъект.ОтборСтруктурнаяЕдиница)
										 , ЭтотОбъект.ОтборСтруктурнаяЕдиница
										 , ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		
	ОбновитьФормуСервер(?(Параметры.Свойство("МассивУжеДобавленныхСтрок"), Параметры.МассивУжеДобавленныхСтрок, Новый Массив));
	
КонецПроцедуры

&НаСервере
// Реинициализация формы, сброс всех выбранных параметров
//
Процедура ОбновитьФормуСервер(МассивУжеДобавленныхСтрок = Неопределено)
		
	Если ТипЗнч(ОтборДокумент) = Тип("ДокументСсылка.ПланЛечения") Тогда	
		Запрос       = Новый Запрос;
		Запрос.Текст ="ВЫБРАТЬ РАЗРЕШЕННЫЕ
		              |	ПланЛеченияОстатки.ПланЛечения,
		              |	ПланЛеченияОстатки.НомерПриема КАК НомерЗаказаПриема,
		              |	ПланЛеченияОстатки.Зуб,
		              |	ПланЛеченияОстатки.Номенклатура,
		              |	СУММА(ПланЛеченияОстатки.Количество) КАК Количество,
		              |	СУММА(ПланЛеченияОстатки.Сумма) КАК Сумма,
		              |	ПланЛеченияОстатки.КлючСтроки,
		              |	ДокументПланЛечение.Цена,
		              |	ДокументПланЛечение.ПроцентСкидкиНаценки,
		              |	ДокументПланЛечение.СуммаАвтоматическойСкидкиНаценки
		              |ИЗ
		              |	(ВЫБРАТЬ
		              |		ПланыЛечения.ПланЛечения КАК ПланЛечения,
		              |		ПланыЛечения.НомерПриема КАК НомерПриема,
		              |		ПланыЛечения.Зуб КАК Зуб,
		              |		ПланыЛечения.Номенклатура КАК Номенклатура,
		              |		СУММА(ВЫБОР
		              |				КОГДА ПланыЛечения.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		              |					ТОГДА ПланыЛечения.Количество
		              |				ИНАЧЕ -ПланыЛечения.Количество
		              |			КОНЕЦ) КАК Количество,
		              |		СУММА(ВЫБОР
		              |				КОГДА ПланыЛечения.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		              |					ТОГДА ПланыЛечения.Сумма
		              |				ИНАЧЕ -ПланыЛечения.Сумма
		              |			КОНЕЦ) КАК Сумма,
		              |		ПланыЛечения.КлючСтроки КАК КлючСтроки
		              |	ИЗ
		              |		РегистрНакопления.ПланыЛечения КАК ПланыЛечения
		              |	ГДЕ
		              |		ПланыЛечения.ПланЛечения = &ОтборДокумент
		              |	
		              |	СГРУППИРОВАТЬ ПО
		              |		ПланыЛечения.КлючСтроки,
		              |		ПланыЛечения.Номенклатура,
		              |		ПланыЛечения.ПланЛечения,
		              |		ПланыЛечения.НомерПриема,
		              |		ПланыЛечения.Зуб) КАК ПланЛеченияОстатки
		              |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		              |			ПланЛеченияЛечение.Ссылка КАК Ссылка,
		              |			ПланЛеченияЛечение.НомерПриема КАК НомерПриема,
		              |			ПланЛеченияЛечение.Зуб КАК Зуб,
		              |			ПланЛеченияЛечение.Номенклатура КАК Номенклатура,
		              |			ПланЛеченияЛечение.Цена КАК Цена,
		              |			ПланЛеченияЛечение.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
		              |			СУММА(ПланЛеченияЛечение.СуммаАвтоматическойСкидкиНаценки) КАК СуммаАвтоматическойСкидкиНаценки,
		              |			ПланЛеченияЛечение.КлючСтроки КАК КлючСтроки
		              |		ИЗ
		              |			Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
		              |		ГДЕ
		              |			ПланЛеченияЛечение.Ссылка = &ОтборДокумент
		              |		
		              |		СГРУППИРОВАТЬ ПО
		              |			ПланЛеченияЛечение.Ссылка,
		              |			ПланЛеченияЛечение.Номенклатура,
		              |			ПланЛеченияЛечение.НомерПриема,
		              |			ПланЛеченияЛечение.Зуб,
		              |			ПланЛеченияЛечение.Цена,
		              |			ПланЛеченияЛечение.ПроцентСкидкиНаценки,
		              |			ПланЛеченияЛечение.КлючСтроки) КАК ДокументПланЛечение
		              |		ПО ПланЛеченияОстатки.КлючСтроки = ДокументПланЛечение.КлючСтроки
		              |ГДЕ
		              |	ПланЛеченияОстатки.Количество > 0
		              |	И НЕ ПланЛеченияОстатки.КлючСтроки В (&МассивУжеДобавленныхСтрок)
					  |	И ПланЛеченияОстатки.Номенклатура В (&УсловиеНоменклатураСотрудника)
		              |
		              |СГРУППИРОВАТЬ ПО
		              |	ПланЛеченияОстатки.ПланЛечения,
		              |	ПланЛеченияОстатки.НомерПриема,
		              |	ПланЛеченияОстатки.Зуб,
		              |	ПланЛеченияОстатки.Номенклатура,
		              |	ПланЛеченияОстатки.КлючСтроки,
		              |	ДокументПланЛечение.Цена,
		              |	ДокументПланЛечение.ПроцентСкидкиНаценки,
		              |	ДокументПланЛечение.СуммаАвтоматическойСкидкиНаценки";
		
#Область _______________________________________________________СтарыйМеханизм_______________________________________________________________		
		
		// Запрос.Текст =		
