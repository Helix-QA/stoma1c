&НаКлиенте
// Процедура инициирует заполнение документа
// 
Процедура Обеспечить(ВидОбеспечения)
	
	СтруктураЗаполнения = ОбеспечитьНаСервере(ВидОбеспечения);
	ГруппировкаНоменклатура = Ложь;
	
	МассивСкладов		= Новый Массив;
	
	Если СтруктураЗаполнения.Запасы.Количество() > 0 
		И (СтруктураЗаполнения.Запасы[0].Свойство("Склад") или СтруктураЗаполнения.Запасы[0].Свойство("Поставщик")) Тогда
		
		Для Каждого ЭлементМассива Из СтруктураЗаполнения.Запасы Цикл
			
			Если СтруктураЗаполнения.Запасы[0].Свойство("Склад") 
				И МассивСкладов.Найти(ЭлементМассива.Склад) = Неопределено
				И ЗначениеЗаполнено(ЭлементМассива.Склад) 
				И (ТипЗнч(ЭлементМассива.Склад) = Тип("СправочникСсылка.Склады") ИЛИ ТипЗнч(ЭлементМассива.Склад) = Тип("СправочникСсылка.Сотрудники")) Тогда
				МассивСкладов.Добавить(ЭлементМассива.Склад);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого ЭлементМассива Из СтруктураЗаполнения.ЗапасыСгруппированы Цикл 
		Если ЭлементМассива.Свойство("Номенклатура") Тогда 
			ГруппировкаНоменклатура = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	
	Если ГруппировкаНоменклатура Тогда
		МассивЗапасовПоСкладу = ВернутьЗапасыПоСкладу(МассивСкладов, СтруктураЗаполнения.ЗапасыСгруппированы, ВидОбеспечения);
		ПоставщикЗаполнения = ПолучитьПоставщикаЗаполнения(МассивЗапасовПоСкладу);
		Если МассивСкладов.Количество() > 1 Тогда
			ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, , ВидОбеспечения, ПоставщикЗаполнения);
		ИначеЕсли МассивСкладов.Количество() = 1 Тогда
			Если ТипЗнч(МассивСкладов[0]) = Тип("СправочникСсылка.Склады") Тогда
				ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, МассивСкладов[0], ВидОбеспечения, ПоставщикЗаполнения);		
			ИначеЕсли ТипЗнч(МассивСкладов[0]) = Тип("СправочникСсылка.Сотрудники") Тогда
				ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, Неопределено, ВидОбеспечения, ПоставщикЗаполнения);		
			КонецЕсли;
		ИначеЕсли МассивСкладов.Количество() = 0 Тогда	
			ЗаполнитьДокумент(МассивЗапасовПоСкладу, СтруктураЗаполнения.ВидЦен, СтруктураЗаполнения.СтруктурнаяЕдиница, , ВидОбеспечения, ПоставщикЗаполнения);
		КонецЕсли;	
	Иначе 
		ПоказатьПредупреждение(Неопределено, "Установите в настройках отчета группировку Номенклатура!");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - возвращает постащвика для заполнения документа
// 
Функция ПолучитьПоставщикаЗаполнения(МассивЗапасовПоСкладу)
	
	массивПоставщиков = Новый Массив;
	Для Каждого ЭлементМ Из МассивЗапасовПоСкладу Цикл
		Если ЭлементМ.Свойство("Поставщик")
			И МассивПоставщиков.Найти(ЭлементМ.Поставщик) = Неопределено
			И ЗначениеЗаполнено(ЭлементМ.Поставщик) 
			И ТипЗнч(ЭлементМ.Поставщик) = Тип("СправочникСсылка.Контрагенты") Тогда
			МассивПоставщиков.Добавить(ЭлементМ.Поставщик);
		КонецЕсли;  
		Если МассивПоставщиков.Количество() > 1 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ?(МассивПоставщиков.Количество() = 1, МассивПоставщиков[0], Неопределено);
	
КонецФункции

&НаСервере
// Функция возвращает структуру, необходимую для заполнения документа "ЗаказПоставщику"
// 
Функция ОбеспечитьНаСервере(ВидОбеспечения)
	
	ТаблицаКритическихОстатков = Новый ТаблицаЗначений;
	
	// Макет компоновки
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(РеквизитФормыВЗначение("Отчет").СхемаКомпоновкиДанных, 
	Отчет.КомпоновщикНастроек.ПолучитьНастройки(), , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	// Компоновка данных
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	// Вывод результата
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ТаблицаКритическихОстатков = ПроцессорВывода.Вывести(ПроцессорКомпоновки); 
	
	СтруктураЗаполнения = Новый Структура;
	СтруктураЗаполнения.Вставить("ВидЦен", 				Справочники.ВидыЦен.Закупочная);
	СтруктураЗаполнения.Вставить("Запасы",				ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(ТаблицаКритическихОстатков));
	СтруктураЗаполнения.Вставить("ЗапасыСгруппированы", ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(СвернутьТаблицуЗапасов(ТаблицаКритическихОстатков, ВидОбеспечения)));
	СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница", 	ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Возврат СтруктураЗаполнения;

КонецФункции

&НаСервере
// Функция группирует таблицу остатков
// 
Функция СвернутьТаблицуЗапасов(ТаблицаКритическихОстатков, ВидОбеспечения)
	
	Если ТаблицаКритическихОстатков.Колонки.Найти("Номенклатура") = Неопределено Тогда
		Возврат ТаблицаКритическихОстатков;
	Иначе	
		ТаблицаОстатков = ТаблицаКритическихОстатков.Скопировать(,);		
		Если ВидОбеспечения = "ЗаказПоставщику" ИЛИ ВидОбеспечения = "ПеремещениеЗапасов" Тогда 
			ТаблицаОстатков.Свернуть("Номенклатура, Партия", "Количество,КоличествоОстаток,КоличествоУпаковокКритическихОстатков,КоличествоУпаковокОбеспечения,КоличествоУпаковокОстатков,Обеспечение");	
		Иначе			
			Если ТаблицаОстатков.Колонки.Найти("Упаковка") = Неопределено Тогда 
				ТаблицаОстатков.Свернуть("Номенклатура, Партия", "Количество,КоличествоОстаток,КоличествоУпаковокКритическихОстатков,КоличествоУпаковокОбеспечения,КоличествоУпаковокОстатков,Обеспечение");	
			Иначе 
				ТаблицаОстатков.Свернуть("Номенклатура, Партия, Упаковка", "Количество,КоличествоОстаток,КоличествоУпаковокКритическихОстатков,КоличествоУпаковокОбеспечения,КоличествоУпаковокОстатков,Обеспечение");	
			КонецЕсли;	
		КонецЕсли;
		Возврат ТаблицаОстатков;
	КонецЕсли;
	
КонецФункции

