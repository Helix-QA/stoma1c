// Процедура - Обновить виджет приемы.
//
// Параметры:
//  ДанныеПриемов	 - 	 - 
//
Процедура ОбновитьВиджетПриемы(ДанныеПриемов)
	
	#Область ____________ИнформацияПоПриемам____________
	
	Если ДанныеПриемов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Всего приемов.
	Выборка = ДанныеПриемов.ДанныеВсегоПриемов.Выбрать();
	КоличествоВсего = ?(Выборка.Следующий(), Выборка.Количество, 0); 
	Элементы.ДекорацияВсегоПриемовКоличество.Заголовок = КоличествоВсего;  
			
	Если ОтображатьСравненияСПредыдущимПериодом И КоличествоВсего <> 0 Тогда
		
		Выборка = ДанныеПриемов.ДанныеВсегоПриемовПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			КоличествоВсегоВчера = Выборка.Количество;
		Иначе
			КоличествоВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(КоличествоВсегоВчера = 0, 100, (КоличествоВсего - КоличествоВсегоВчера) / КоличествоВсегоВчера * 100);
		Элементы.ДанныеПриемыСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеПриемыПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеПриемыСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеПриемыПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеПриемы.Видимость = Истина;
	Иначе
		Элементы.ДанныеПриемы.Видимость = Ложь;
	КонецЕсли;
	
	// Не завершенных приемов.
	Выборка = ДанныеПриемов.ДанныеНеЗавершенныхПриемов.Выбрать();
	Элементы.ДекорацияНеЗавершенныхПриемовКоличество.Заголовок = ?(Выборка.Следующий(), Выборка.Количество, 0);  
	
	// Отмененных приемов.
	Выборка = ДанныеПриемов.ДанныеОтмененнхПриемов.Выбрать();
	КоличествоВсего = ?(Выборка.Следующий(), Выборка.Количество, 0);
	Элементы.ДекорацияОтмененныхПриемовКоличество.Заголовок = КоличествоВсего; 
	
	Если ОтображатьСравненияСПредыдущимПериодом И КоличествоВсего <> 0 Тогда
		
		Выборка = ДанныеПриемов.ДанныеОтмененнхПриемовПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			КоличествоВсегоВчера = Выборка.Количество;
		Иначе
			КоличествоВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(КоличествоВсегоВчера = 0, 100, (КоличествоВсего - КоличествоВсегоВчера) / КоличествоВсегоВчера * 100);
		Элементы.ДанныеОтмененныеПриемыСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеОтмененныеПриемыПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеОтмененныеПриемыСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеОтмененныеПриемыПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеОтмененныеПриемы.Видимость = Истина;
	Иначе
		Элементы.ДанныеОтмененныеПриемы.Видимость = Ложь;
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ____________ВиджетПримемыПоСтатусам____________
		
	// Шапка
	Выборка = ДанныеПриемов.ДанныеШапкиЗавершено.Выбрать(); 
	
	Количество 	= ?(Выборка.Следующий(), Выборка.Количество, 0);
	
	Элементы.ДекорацияЗавершенныхПриемовКоличество.Заголовок = Количество;
	
	Если ОтображатьСравненияСПредыдущимПериодом И Количество <> 0 Тогда
		
		Выборка = ДанныеПриемов.ДанныеШапкиЗавершеноПредыдущий.Выбрать();	
		Если Выборка.Следующий() Тогда
			КоличествоВсегоВчера = Выборка.Количество;
		Иначе
			КоличествоВсегоВчера = 0;
		КонецЕсли;
		
		РазницаПроцент = ?(КоличествоВсегоВчера = 0, 100, (Количество - КоличествоВсегоВчера) / КоличествоВсегоВчера * 100);
		Элементы.ДанныеЗавершенныеПриемыСтрелка.Картинка = ?(РазницаПроцент >= 0, БиблиотекаКартинок.СтрелкаРост, БиблиотекаКартинок.СтрелкаПадение);
		РазницаПроцент = ?(РазницаПроцент < 0, -1 * РазницаПроцент, РазницаПроцент);
		Элементы.ДанныеЗавершенныеПриемыПроцент.Заголовок = Формат(РазницаПроцент, "ЧДЦ=; ЧН=") + "%";
		Элементы.ДанныеЗавершенныеПриемыСтрелка.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеЗавершенныеПриемыПроцент.Подсказка = "В сравнении с прошлым периодом";
		Элементы.ДанныеЗавершенныеПриемы.Видимость = Истина;
	Иначе
		Элементы.ДанныеЗавершенныеПриемы.Видимость = Ложь;
	КонецЕсли;
	
	// Тело Диаграммы
		
	ТаблицаРезультат = ДанныеПриемов.ДиаграммаПриемовПоСтатусам.Выгрузить();
	ТаблицаРезультат.Сортировать("Количество Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаПриемовПоСтатусам.Обновление = Ложь;
	ДиаграммаПриемовПоСтатусам.Очистить();

	Если ЕстьДанныеДляОтображения Тогда 
				
		Точка = ДиаграммаПриемовПоСтатусам.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
		
			ПредставлениеСтатуса 	= ПолучитьПредсталвениеСтатуса(СтрокаТЗ.Статус);	
			
			СерияДиаграммы 			= ДиаграммаПриемовПоСтатусам.Серии.Добавить(ПредставлениеСтатуса); 
			Точка.Текст				= "Статус";
			Точка.Значение			= СтрокаТЗ.Количество;	
					
			ДиаграммаПриемовПоСтатусам.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Количество,,);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаПриемовПоСтатусам, ЕстьДанныеДляОтображения);	
	ДиаграммаПриемовПоСтатусам.Обновление = Истина;
		
	#КонецОбласти
	
	#Область ____________ВиджетСозданоПоАдминистраторам____________
			
	// Тело Диаграммы
			
	ТаблицаЗначений = ДанныеПриемов.ДанныеСозданоПоАдминистраторам.Выгрузить();
	ТаблицаЗначений.Сортировать("ОбщееКоличество Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаЗначений.Количество() > 0;
	
	Диаграмма = ДиаграммаСозданоПоАдминистраторам; 
	
	Диаграмма.Обновление = Ложь;
	Диаграмма.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
				
		Диаграмма.КоличествоСерий = ТаблицаЗначений.Колонки.Количество() - 2; // Общее количество не выводим.	
		Диаграмма.КоличествоТочек = ТаблицаЗначений.Количество();
		
		Для НомерСтроки = 0 По ТаблицаЗначений.Количество() -1 Цикл
			
			Сотрудник = ТаблицаЗначений[НомерСтроки].Сотрудник; 
			
			Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда
				ПредставлениеСотрудник 	= ?(ЗначениеЗаполнено(Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(Сотрудник), "Без автора");	
			ИначеЕсли ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Пользователи") И ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник, "Служебный") = Истина Тогда
				ПредставлениеСотрудник 	= "Онлайн-запись";
			Иначе
				ПредставлениеСотрудник 	= Строка(Сотрудник);
			КонецЕсли;
			
			Диаграмма.Точки[НомерСтроки].Текст = ПредставлениеСотрудник;
			
			Для НомерКолонки = 1 по ТаблицаЗначений.Колонки.Количество() - 1  Цикл 
				Если ТаблицаЗначений.Колонки[НомерКолонки].Имя = "ОбщееКоличество" Тогда
					Продолжить;
				КонецЕсли;
				Серия = Диаграмма.Серии[НомерКолонки - 1];
				Серия.Текст = ?(ТаблицаЗначений.Колонки[НомерКолонки].Имя = "БезСтатуса", "Без статуса", ТаблицаЗначений.Колонки[НомерКолонки].Имя);
				Точки = Диаграмма.Точки[НомерСтроки];
				Диаграмма.УстановитьЗначение(Точки, Серия, ТаблицаЗначений[НомерСтроки][НомерКолонки]);
			КонецЦикла;
			
		КонецЦикла;    
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(Диаграмма, ЕстьДанныеДляОтображения);	
	Диаграмма.Обновление = Истина;
		
	#КонецОбласти
	
	#Область ____________ВиджетДиаграммаКаналыПриемов____________
		
	// Тело Диаграммы
	  	
	ТаблицаРезультат = ДанныеПриемов.ДанныеКаналыПриемов.Выгрузить();
	ТаблицаРезультат.Сортировать("Количество Убыв");
	
	ЕстьДанныеДляОтображения = ТаблицаРезультат.Количество() > 0;
	
	ДиаграммаПриемовСостоялось.Обновление = Ложь;
	ДиаграммаПриемовСостоялось.Очистить();
	
	Если ЕстьДанныеДляОтображения Тогда 
				
		Точка = ДиаграммаПриемовСостоялось.Точки.Добавить();
		
		Для Каждого СтрокаТЗ Из ТаблицаРезультат Цикл
			
			ПредставлениеИсточника 	= СтрокаТЗ.ИсточникЗаписи;	
			
			СерияДиаграммы 			= ДиаграммаПриемовСостоялось.Серии.Добавить(ПредставлениеИсточника); 
			Точка.Текст				= "Источник записи";
			Точка.Значение			= СтрокаТЗ.Количество;	
			
			ДиаграммаПриемовСостоялось.УстановитьЗначение(Точка, СерияДиаграммы, СтрокаТЗ.Количество);
			
		КонецЦикла;	
		
	КонецЕсли;
	
	УстановитьОтображениеДиаграммы(ДиаграммаПриемовСостоялось, ЕстьДанныеДляОтображения);	
	ДиаграммаПриемовСостоялось.Обновление = Истина;
	
	#КонецОбласти
	
КонецПроцедуры

