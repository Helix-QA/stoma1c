// Процедура - Установить вид оплаты подарочным сертификатом
// 
функция УстановитьВидОплатыПодарочнымСертификатом(ДанныеСертификата)
	
	ДобавлениеСертификата = Ложь;
	
	ВерхнийУровень = НайтиВВерхнемУровнеДереваДоступныхВидовОплат(Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат);
	
	СтрокаСертификата = НайтиВДеревеДоступныхВидовОплатСервер(
	Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,
	,,
	ДанныеСертификата.Партия,,
	Истина);
	
	Если СтрокаСертификата = Неопределено Тогда
		
		СтрокаСертификата = НайтиВДеревеДоступныхВидовОплатСервер(
		Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,,,,
		ВерхнийУровень,,
		Истина);
		
		ДобавлениеСертификата = Истина;
		
	КонецЕсли;
	
	Если СтрокаСертификата = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОплачиваемыеДокументы = ПолучитьДокументыЗадолженностиСервер(Истина);
	
	ДопустимыйОстатокДляОплаты = ДанныеСертификата.ОстатокСуммы;

	СуммаИспользовано = СуммаВнесенныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,,, ДанныеСертификата.Партия);
	
	СтрокаСертификата.ТипДенежныхСредств           = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат; 
	СтрокаСертификата.Сертификат                   = ДанныеСертификата.Сертификат;
	СтрокаСертификата.СертификатПартия             = ДанныеСертификата.Партия;
	
	СтрокаСертификата.ОстатокСредств               = ДанныеСертификата.ОстатокСуммы - СуммаИспользовано;
	СтрокаСертификата.МаксСуммаСписания            = ДопустимыйОстатокДляОплаты;
	
	СтрокаСертификата.НаименованиеВидаОплаты       = ДанныеСертификата.Представление;
	СтрокаСертификата.Представление                = ДанныеСертификата.Представление + " (" + Формат(СтрокаСертификата.ОстатокСредств,"ЧДЦ=2; ЧН=0,00") + ")";					
	СтрокаСертификата.СертификатПодтвержден        = ДанныеСертификата.Подтвержден;
	
	СтрокаСертификата.Контрагент                   = ЭтотОбъект.Контрагент;
	СтрокаСертификата.КассаОплаты                  = ЭтотОбъект.ТекущаяКасса;
	
	Если ДобавлениеСертификата = Истина Тогда
		
		СуммаОжидаемогоПлатежа     = ЭтотОбъект.ОплатаСумма - ЭтотОбъект.ОплатаВнесено;			
		СтрокаСертификата.Внесено  = ?(СтрокаСертификата.МаксСуммаСписания > СуммаОжидаемогоПлатежа, СуммаОжидаемогоПлатежа, СтрокаСертификата.МаксСуммаСписания);
				
	КонецЕсли;
	
	Возврат СтрокаСертификата.ПолучитьИдентификатор();
	
КонецФункции

&НаСервере
// Процедура - Установить кнопку добавления сертифката
// 
Процедура УстановитьКнопкуДобавленияНовогоСертификата()
	
	ВерхнийУровень = НайтиВВерхнемУровнеДереваДоступныхВидовОплат(Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат);
	
	Если ВерхнийУровень = Неопределено Тогда
		
		ДеревоОплаты                     = ВидыОплат.ПолучитьЭлементы();
		ЭлементДерева                    = ДеревоОплаты.Добавить();
		ЭлементДерева.Представление      = "Подарочные сертификаты";
		ЭлементДерева.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат;
		ЭлементДерева.ВидЛицевогоСчета   = Справочники.ВидыЛицевыхСчетов.ПустаяСсылка();
		ЭлементДерева.СертификатПартия	 = Справочники.ПартииНоменклатуры.ПустаяСсылка();
		ВерхнийУровень                   = ЭлементДерева;
		
	Иначе	
		
		ВерхнийУровень                   = ВерхнийУровень;
		
	КонецЕсли;
	
	СуществВидыОплат = НайтиВДеревеДоступныхВидовОплатСервер(
	Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат,,,
	Справочники.ПартииНоменклатуры.ПустаяСсылка(),
	ВерхнийУровень);
	
	Если НЕ ЗначениеЗаполнено(СуществВидыОплат) Тогда
		ЭлементДерева = ВерхнийУровень.ПолучитьЭлементы().Добавить();
		ЭлементДерева.ВидЛицевогоСчета = Справочники.ВидыЛицевыхСчетов.ПустаяСсылка();
		ЭлементДерева.СертификатПартия = Справочники.ПартииНоменклатуры.ПустаяСсылка();
	Иначе
		ЭлементДерева = СуществВидыОплат[0];
	КонецЕсли;
	
    ЭлементДерева.Представление      = "Добавить сертификат";	
	ЭлементДерева.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат; 
	
	Если СуществВидыОплат.Количество() > 1 Тогда
		
		ВерхнийУровень.ПолучитьЭлементы().Удалить(СуществВидыОплат[1]);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработать данные штрихкода сертификата
// 
// Параметры:
//  СтруктураДанных	 - 	 - 
// 
Процедура ДобавитьВыбранныйСертификатВВидыОплат(ДанныеСертифиаката)
	
	Если ДанныеСертифиаката.Использовать = Ложь Тогда
		
		ПоказатьОповещениеПользователя("Оплата",,ДанныеСертифиаката.ОписаниеПроверки, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 
		Возврат;
		
	КонецЕсли;
	
	ИдСтроки = УстановитьВидОплатыПодарочнымСертификатом(ДанныеСертифиаката);
	
	ОплатаСуммаПриИзменении(ЭтотОбъект.ВидыОплат.НайтиПоИдентификатору(ИдСтроки));
								
КонецПроцедуры

