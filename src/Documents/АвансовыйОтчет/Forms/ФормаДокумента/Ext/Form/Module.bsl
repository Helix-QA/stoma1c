//
//
Процедура ЗаполнитьВыданныеАвансы(Команда)

	Если НЕ ЗначениеЗаполнено(Объект.Сотрудник) Тогда 
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Необходимо заполнить сотрудника!";
		Сообщение.Поле = "Объект.Сотрудник";
		Сообщение.УстановитьДанные(Объект);
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
		
	РезультатЗапроса = ВернутьВыданныеАвансы(Объект.Ссылка, Объект.Сотрудник, Объект.СтруктурнаяЕдиница, ВернутьМассивВыбранныхДокументов());
	Для Каждого СтрокаРезультат Из РезультатЗапроса Цикл
		НоваяСтрока = Объект.ВыданныеАвансы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРезультат);
	КонецЦикла;
	
КонецПроцедуры

