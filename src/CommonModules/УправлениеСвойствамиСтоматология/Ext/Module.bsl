//
Функция КопироватьКнопкуФормы(Форма, КнопкаИсточник, ПрефиксИмениНовойКнопки, Родитель,знач ОбработчикНажатия = Неопределено,знач НовыйЗаголовок = Неопределено) Экспорт
	
	ИмяИсточника     = КнопкаИсточник.Имя;  
	КомандаИсточника = Форма.Команды.Найти(КнопкаИсточник.ИмяКоманды);
	
	Если НЕ ЗначениеЗаполнено(ОбработчикНажатия) Тогда    
		ОбработчикНажатия   = КомандаИсточника.Действие  
	КонецЕсли;
	
	Если СтрНайти(ИмяИсточника, "_") > 0 Тогда    
		ИмяИсточника = Лев(ИмяИсточника, СтрНайти(ИмяИсточника, "_"));       
	КонецЕсли;
	
	ИмяНовойКнопки = ИмяИсточника + ПрефиксИмениНовойКнопки;
	
	Если Форма.Команды.Найти(ИмяНовойКнопки) = Неопределено Тогда  
		
		КомандаФормы            = Форма.Команды.Добавить(ИмяНовойКнопки);
		КомандаФормы.Действие   = ОбработчикНажатия;
		КомандаФормы.Заголовок  = КомандаИсточника.Заголовок; 
		КомандаФормы.Подсказка  = КомандаИсточника.Подсказка; 
		
	КонецЕсли;
	
	НоваяКнопка                        = Форма.Элементы.Добавить(ИмяНовойКнопки, Тип("КнопкаФормы"), Родитель);
	
	НоваяКнопка.Заголовок              = ?(ЗначениеЗаполнено(НовыйЗаголовок), НовыйЗаголовок, КнопкаИсточник.Заголовок);
	НоваяКнопка.ИмяКоманды             = ИмяНовойКнопки;
	НоваяКнопка.ОтображениеФигуры      = КнопкаИсточник.ОтображениеФигуры;
	НоваяКнопка.ОтображениеПодсказки   = КнопкаИсточник.ОтображениеПодсказки;
	НоваяКнопка.Видимость              = КнопкаИсточник.Видимость;
	НоваяКнопка.ЦветТекста             = КнопкаИсточник.ЦветТекста;  
	НоваяКнопка.Шрифт                  = КнопкаИсточник.Шрифт; 
	НоваяКнопка.Картинка               = КнопкаИсточник.Картинка;
	НоваяКнопка.АвтоМаксимальнаяШирина = КнопкаИсточник.АвтоМаксимальнаяШирина;
	НоваяКнопка.МаксимальнаяШирина     = КнопкаИсточник.МаксимальнаяШирина;
	НоваяКнопка.Ширина                 = КнопкаИсточник.Ширина;
	НоваяКнопка.РастягиватьПоГоризонтали = КнопкаИсточник.РастягиватьПоГоризонтали;
	НоваяКнопка.Отображение            = КнопкаИсточник.Отображение;
	НоваяКнопка.ПоложениеКартинки     = КнопкаИсточник.ПоложениеКартинки;
	НоваяКнопка.ГоризонтальноеПоложениеВГруппе = КнопкаИсточник.ГоризонтальноеПоложениеВГруппе;
	НоваяКнопка.Вид = КнопкаИсточник.Вид;
	
	Возврат НоваяКнопка;
	
КонецФункции

// Функция, создает копию группы формы.
//
Функция КопироватьГруппуФормы(Форма, ГруппаИсточник, ПрефиксИмениНовойГруппы, Родитель) Экспорт
	
	ИмяИсточника = ГруппаИсточник.Имя;
	
	Если СтрНайти(ИмяИсточника, "_") > 0 Тогда    
		ИмяИсточника = Лев(ИмяИсточника, СтрНайти(ИмяИсточника, "_"));       
	КонецЕсли;
	
	ИмяНовойГруппы = ИмяИсточника + Строка(ПрефиксИмениНовойГруппы);
	
	НоваяГруппа                     = Форма.Элементы.Добавить(ИмяНовойГруппы, Тип("ГруппаФормы"), Родитель);
	
	НоваяГруппа.Вид                 = ГруппаИсточник.Вид;
	НоваяГруппа.Группировка         = ГруппаИсточник.Группировка;
	НоваяГруппа.Отображение         = ГруппаИсточник.Отображение;
	НоваяГруппа.ОтображатьЗаголовок = ГруппаИсточник.ОтображатьЗаголовок;
	НоваяГруппа.Ширина              = ГруппаИсточник.Ширина;
	НоваяГруппа.Высота              = ГруппаИсточник.Высота;
	НоваяГруппа.Заголовок           = ГруппаИсточник.Заголовок;
	НоваяГруппа.ЦветФона            = ГруппаИсточник.ЦветФона;
	
	НоваяГруппа.ВертикальныйИнтервал                = ГруппаИсточник.ВертикальныйИнтервал;
	НоваяГруппа.ГоризонтальныйИнтервал         		= ГруппаИсточник.ГоризонтальныйИнтервал;
	НоваяГруппа.ГоризонтальноеПоложениеПодчиненных  = ГруппаИсточник.ГоризонтальноеПоложениеПодчиненных;
	НоваяГруппа.ВертикальноеПоложениеПодчиненных    = ГруппаИсточник.ВертикальноеПоложениеПодчиненных;
	НоваяГруппа.РастягиватьПоГоризонтали            = ГруппаИсточник.РастягиватьПоГоризонтали;
	НоваяГруппа.РастягиватьПоВертикали              = ГруппаИсточник.РастягиватьПоВертикали;
	НоваяГруппа.ГоризонтальноеПоложениеВГруппе      = ГруппаИсточник.ГоризонтальноеПоложениеВГруппе;
	НоваяГруппа.ВертикальноеПоложениеВГруппе        = ГруппаИсточник.ВертикальноеПоложениеВГруппе;
	
	Если ГруппаИсточник.Поведение = ПоведениеОбычнойГруппы.Всплывающая Тогда
		
		НоваяГруппа.Поведение           = ГруппаИсточник.Поведение;
		НоваяГруппа.Видимость           = Истина;
		НоваяГруппа.ЦветТекстаЗаголовка = ГруппаИсточник.ЦветТекстаЗаголовка;
		НоваяГруппа.ШрифтЗаголовка      = ГруппаИсточник.ШрифтЗаголовка;
		
	КонецЕсли;
	
	Возврат НоваяГруппа;
	
КонецФункции

// Функция, создает копию элемента формы.
//
Функция КопироватьЭлементФормы(Форма, ЭлементИсточник, ПрефиксИмениНовогоЭлемента, ТипЭлемента = Неопределено, Родитель, ПутьКДанным = Неопределено, ПолучитьПутьКДанным = Ложь, Видимость = Ложь) Экспорт
	
	ИмяИсточника = ЭлементИсточник.Имя;
	
	Если СтрНайти(ИмяИсточника, "_") > 0 Тогда    
		ИмяИсточника = Лев(ИмяИсточника, СтрНайти(ИмяИсточника, "_"));
	КонецЕсли;
	
	Если ТипЭлемента = Неопределено Тогда
		ТипЭлемента = ТипЗнч(ЭлементИсточник);
	КонецЕсли;
	
	НовыйЭлемент     = Форма.Элементы.Добавить(ИмяИсточника + Формат(ПрефиксИмениНовогоЭлемента, "ЧН=; ЧГ="), ТипЭлемента, Родитель);   
	НовыйЭлемент.Вид = ЭлементИсточник.Вид;
	
	Если ТипЭлемента = Тип("ПолеФормы") Тогда
		
		Если ЭлементИсточник.Вид = ВидПоляФормы.ПолеВвода Тогда
			
			НовыйЭлемент.КнопкаВыбора              = ЭлементИсточник.КнопкаВыбора;
			НовыйЭлемент.КнопкаОткрытия            = ЭлементИсточник.КнопкаОткрытия;
			НовыйЭлемент.КнопкаОчистки             = ЭлементИсточник.КнопкаОчистки;
			НовыйЭлемент.КнопкаРегулирования       = ЭлементИсточник.КнопкаРегулирования;
			НовыйЭлемент.РедактированиеТекста      = ЭлементИсточник.РедактированиеТекста;
			НовыйЭлемент.КнопкаСпискаВыбора        = ЭлементИсточник.КнопкаСпискаВыбора;
			НовыйЭлемент.ШиринаВыпадающегоСписка   = ЭлементИсточник.ШиринаВыпадающегоСписка;
			НовыйЭлемент.ПодсказкаВвода            = ЭлементИсточник.ПодсказкаВвода;
			НовыйЭлемент.ПараметрыВыбора           = ЭлементИсточник.ПараметрыВыбора;
			НовыйЭлемент.ФормаВыбора               = ЭлементИсточник.ФормаВыбора;
			НовыйЭлемент.РежимВыбораИзСписка       = ЭлементИсточник.РежимВыбораИзСписка;
			НовыйЭлемент.КнопкаВыпадающегоСписка   = ЭлементИсточник.КнопкаВыпадающегоСписка;
			НовыйЭлемент.ОтображениеКнопкиВыбора   = ЭлементИсточник.ОтображениеКнопкиВыбора;
			НовыйЭлемент.АвтоОтметкаНезаполненного = ЭлементИсточник.АвтоОтметкаНезаполненного;
			НовыйЭлемент.ИсторияВыбораПриВводе     = ЭлементИсточник.ИсторияВыбораПриВводе;
			НовыйЭлемент.ТолькоПросмотр            = ЭлементИсточник.ТолькоПросмотр;
			
			Если ЗначениеЗаполнено(ЭлементИсточник.Подсказка) Тогда 
				НовыйЭлемент.Подсказка            = ЭлементИсточник.Подсказка;
				НовыйЭлемент.ОтображениеПодсказки = ЭлементИсточник.ОтображениеПодсказки;
			КонецЕсли;
			
			Если ЭлементИсточник.СписокВыбора.Количество() > 0 Тогда 
				
				Для Каждого ЭлементС Из ЭлементИсточник.СписокВыбора Цикл
					НовыйЭлемент.СписокВыбора.Добавить(ЭлементС.Значение, ЭлементС.Представление);    
				КонецЦикла;
				
			КонецЕсли;  
			
		ИначеЕсли ЭлементИсточник.Вид = ВидПоляФормы.ПолеКартинки Тогда
			
			НовыйЭлемент.Рамка             = ЭлементИсточник.Рамка;
			НовыйЭлемент.КартинкаЗначений     = ЭлементИсточник.КартинкаЗначений;
			НовыйЭлемент.Гиперссылка          = ЭлементИсточник.Гиперссылка;
			НовыйЭлемент.РастягиватьПоВертикали = ЭлементИсточник.РастягиватьПоВертикали;
			
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Нажатие");
			
		КонецЕсли;
		
		Если ЭлементИсточник.Вид = ВидПоляФормы.ПолеВвода
			ИЛИ ЭлементИсточник.Вид = ВидПоляФормы.ПолеНадписи
			ИЛИ ЭлементИсточник.Вид = ВидПоляФормы.ПолеКартинки Тогда
			
			НовыйЭлемент.ПоложениеЗаголовка       = ЭлементИсточник.ПоложениеЗаголовка;
			НовыйЭлемент.АвтоМаксимальнаяШирина   = ЭлементИсточник.АвтоМаксимальнаяШирина;
			НовыйЭлемент.АвтоМаксимальнаяВысота   = ЭлементИсточник.АвтоМаксимальнаяВысота;
			НовыйЭлемент.МаксимальнаяШирина       = ЭлементИсточник.МаксимальнаяШирина;
			НовыйЭлемент.МаксимальнаяВысота       = ЭлементИсточник.МаксимальнаяВысота;
			НовыйЭлемент.Шрифт                    = ЭлементИсточник.Шрифт;
			НовыйЭлемент.Ширина           = ЭлементИсточник.Ширина;
			НовыйЭлемент.Высота                   = ЭлементИсточник.Высота;
			НовыйЭлемент.РастягиватьПоГоризонтали = ЭлементИсточник.РастягиватьПоГоризонтали;
			
		КонецЕсли;
		
		Если ЭлементИсточник.Вид = ВидПоляФормы.ПолеВвода
			ИЛИ ЭлементИсточник.Вид = ВидПоляФормы.ПолеНадписи
			ИЛИ ЭлементИсточник.Вид = ВидПоляФормы.ПолеФлажка Тогда
			
			НовыйЭлемент.ПоложениеЗаголовка       = ЭлементИсточник.ПоложениеЗаголовка;
			
		КонецЕсли;
		
		// Копирование обработчиков
		Если ЭлементИсточник.Вид = ВидПоляФормы.ПолеВвода
			ИЛИ ЭлементИсточник.Вид = ВидПоляФормы.ПолеФлажка Тогда
			
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ПриИзменении");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ОбработкаВыбора");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "НачалоВыбора");
			УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "АвтоПодбор");
			
			Если ЭлементИсточник.Вид = ВидПоляФормы.ПолеВвода Тогда
				УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Открытие");
				УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ОкончаниеВводаТекста");
			КонецЕсли;
			
			Попытка
				НовыйЭлемент.ФорматРедактирования = ЭлементИсточник.ФорматРедактирования;
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
		Если ЭлементИсточник.Вид = ВидПоляФормы.ПолеФлажка Тогда
			
			НовыйЭлемент.ШиринаЭлемента       = ЭлементИсточник.ШиринаЭлемента;
			НовыйЭлемент.ВидФлажка            = ЭлементИсточник.ВидФлажка;
			
		КонецЕсли;
		
	ИначеЕсли ТипЭлемента = Тип("ДекорацияФормы") Тогда
		
		НовыйЭлемент.Шрифт                    = ЭлементИсточник.Шрифт;
		НовыйЭлемент.АвтоМаксимальнаяШирина   = ЭлементИсточник.АвтоМаксимальнаяШирина;
		НовыйЭлемент.АвтоМаксимальнаяВысота   = ЭлементИсточник.АвтоМаксимальнаяВысота;
		НовыйЭлемент.Ширина                   = ЭлементИсточник.Ширина;
		НовыйЭлемент.Высота                   = ЭлементИсточник.Высота;
		НовыйЭлемент.РастягиватьПоГоризонтали = ЭлементИсточник.РастягиватьПоГоризонтали;
		НовыйЭлемент.РастягиватьПоВертикали   = ЭлементИсточник.РастягиватьПоВертикали;
		НовыйЭлемент.МаксимальнаяШирина       = ЭлементИсточник.МаксимальнаяШирина;
		НовыйЭлемент.МаксимальнаяВысота       = ЭлементИсточник.МаксимальнаяВысота;  
		НовыйЭлемент.Гиперссылка              = ЭлементИсточник.Гиперссылка;    
		НовыйЭлемент.Подсказка                = ЭлементИсточник.Подсказка;    
		НовыйЭлемент.Рамка                    = ЭлементИсточник.Рамка;
		НовыйЭлемент.ЦветРамки                 = ЭлементИсточник.ЦветРамки;
		
		Если ЭлементИсточник.Вид = ВидДекорацииФормы.Картинка Тогда
			НовыйЭлемент.Вид      = ЭлементИсточник.Вид;
			НовыйЭлемент.Картинка = ЭлементИсточник.Картинка;
			НовыйЭлемент.РазмерКартинки = ЭлементИсточник.РазмерКартинки;
		КонецЕсли;  
		
		УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "Нажатие");
		УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, "ОбработкаНавигационнойСсылки");
		
	КонецЕсли;
	
	Если ЭлементИсточник.Вид <> ВидДекорацииФормы.Картинка Тогда
		
		НовыйЭлемент.ГоризонтальноеПоложение = ЭлементИсточник.ГоризонтальноеПоложение;
		Если ЭлементИсточник.Вид <> ВидПоляФормы.ПолеКартинки Тогда
			НовыйЭлемент.ЦветФона            = ЭлементИсточник.ЦветФона;
		КонецЕсли;
		
	КонецЕсли;
	
	НовыйЭлемент.Заголовок             = ЭлементИсточник.Заголовок;
	НовыйЭлемент.ГоризонтальноеПоложениеВГруппе = ЭлементИсточник.ГоризонтальноеПоложениеВГруппе;
	НовыйЭлемент.ВертикальноеПоложениеВГруппе   = ЭлементИсточник.ВертикальноеПоложениеВГруппе;
	НовыйЭлемент.ЦветТекста                     = ЭлементИсточник.ЦветТекста;
	НовыйЭлемент.Видимость             = ?(Видимость, Истина, ЭлементИсточник.Видимость);
	
	Если ПолучитьПутьКДанным Тогда
		ПутьКДанным = ВернутьПутьКДанным(ЭлементИсточник, ПрефиксИмениНовогоЭлемента);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПутьКДанным) Тогда
		НовыйЭлемент.ПутьКДанным = СтрЗаменить(ПутьКДанным, Символы.НПП, "");
	КонецЕсли;
	
	Возврат НовыйЭлемент;
	
КонецФункции

// Процедура, устанавилвает действие для элемента формы.
//
Процедура УстановитьДействиеДляЭлемента(ЭлементИсточник, НовыйЭлемент, ИмяДействия)
	
	Действие = ЭлементИсточник.ПолучитьДействие(ИмяДействия);
	
	Если ЗначениеЗаполнено(Действие) Тогда
		НовыйЭлемент.УстановитьДействие(ИмяДействия, Действие);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Скопировать элемент формы рекурсивно
//
// Параметры:
//  Источник -    - 
//  Родитель -    - 
//  Счетчик   -    - 
//
Процедура СкопироватьЭлементФормыРекурсивно(Источник, Родитель, Счетчик, Форма)
	
	Если ТипЗнч(Источник) = Тип("ГруппаФормы") Тогда
		
		ГруппаРодитель = КопироватьГруппуФормы(Форма, Источник, Счетчик, Родитель);
		
		Для Каждого Элемент Из Источник.ПодчиненныеЭлементы Цикл
			СкопироватьЭлементФормыРекурсивно(Элемент, ГруппаРодитель, Счетчик, Форма);  
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("КнопкаФормы") Тогда     
		КопироватьКнопкуФормы(Форма, Источник, Счетчик, Родитель);    
	ИначеЕсли ТипЗнч(Источник) = Тип("ДекорацияФормы") Тогда      
		КопироватьЭлементФормы(Форма, Источник, Счетчик, Тип("ДекорацияФормы"), Родитель);        
	Иначе    
		КопироватьЭлементФормы(Форма, Источник, Счетчик, Тип("ПолеФормы"), Родитель, ВернутьПутьКДанным(Источник, Счетчик));          
	КонецЕсли;
	
КонецПроцедуры

// Функция - Вернуть путь к данным
//
// Параметры:
//  ИмяЭлемента   -    - 
//  Счетчик     -    - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьПутьКДанным(Источник, Счетчик)
	
	ИмяЭлемента = Источник.Имя;  
	Если СтрНайти(ИмяЭлемента, "Документ") > 0 Тогда   
		ПутьКДанным = Источник.ПутьКДанным;
	Иначе             
		
		Если СтрНайти(Источник.ПутьКДанным, "[") <> 0 Тогда
			
			НачИндекс = СтрНайти(Источник.ПутьКДанным, "[");
			КонИндекс = СтрНайти(Источник.ПутьКДанным, "]");
			
			ИскомыйСимвол = Сред(Источник.ПутьКДанным, НачИндекс + 1, КонИндекс - НачИндекс -1);
			
			ПутьКДанным = СтрЗаменить(Источник.ПутьКДанным, ИскомыйСимвол, Счетчик);
			
		Иначе			
			ПутьКДанным = СтрЗаменить(Источник.ПутьКДанным, "Шаблон", Счетчик); 
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ПутьКДанным;
	
КонецФункции

// Обновить отображаемые данные на форме объекта со свойствами
Процедура ОбновитьЭлементыДополнительныхРеквизитов(Форма, Объект) Экспорт
	Если НЕ Форма.__Свойства_ИспользоватьСвойства Тогда
		Возврат;
	КонецЕсли;
	НаборСвойствОбъекта = ПолучитьДоступныеНаборыСвойств(Объект);
	Форма.__Свойства_ОсновнойНабор = НаборСвойствОбъекта;
	
	// Перенесем значения доп.реквизитов из реквизитов форм в объект
	ПеренестиЗначенияСвойствИзРеквизитовФормы(Форма, Объект);
	
	// Создадим реквизиты и разместим их на форме
	ЗаполнитьДополнительныеРеквизитыНаФорме(Форма, Объект, НаборСвойствОбъекта)
	
КонецПроцедуры

// Перенести значения свойств из реквизитов формы в табличную часть объекта
Процедура ПеренестиЗначенияСвойствИзРеквизитовФормы(Форма, Объект)
	
	Объект.ДополнительныеРеквизиты.Очистить();
	
	Для Каждого Стр Из Форма.__Свойства_ОписаниеДополнительныхРеквизитов Цикл
		Значение = Форма[Стр.ИмяРеквизитаЗначение];
		Если ЗначениеЗаполнено(Значение) Тогда
			Если ТипЗнч(Значение) = Тип("Булево") И Значение = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
			новСтр = Объект.ДополнительныеРеквизиты.Добавить();
			новСтр.Свойство = Стр.Свойство;
			новСтр.Значение = Значение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Создадим реквизиты с значениями свойств и разместить их на форме
Процедура ЗаполнитьДополнительныеРеквизитыНаФорме(Форма, Объект, НаборСвойствОбъекта)
	
	Если НаборСвойствОбъекта = Неопределено Тогда
		Набор = Форма.__Свойства_ОсновнойНабор;
	Иначе
		Набор = НаборСвойствОбъекта;
	КонецЕсли;
	
	Таблица = ПолучитьТаблицуЗначенийСвойств(Объект.ДополнительныеРеквизиты.Выгрузить(), Набор, Ложь);
	Таблица.Колонки.Добавить("ИмяРеквизитаЗначение");
	Таблица.Колонки.Добавить("ИмяРеквизитаСвойство");
	Таблица.Колонки.Добавить("Булево");
	
	УдалитьСтарыеРеквизиты(Форма);
	Форма.__Свойства_ОписаниеДополнительныхРеквизитов.Очистить();
	
	// Создадим реквизиты
	Номер = 0;
	ДобавляемыеРеквизиты = Новый Массив();
	Для Каждого СтрРеквизит Из Таблица Цикл
		
		Номер = Номер + 1;
		ТипЗначенияСвойства = СтрРеквизит.ТипЗначения;
		
		СтрРеквизит.ИмяРеквизитаЗначение = "ДополнительныйРеквизитЗначение" + Формат(Номер, "ЧГ=0");
		Реквизит = Новый РеквизитФормы(СтрРеквизит.ИмяРеквизитаЗначение, ТипЗначенияСвойства, , СтрРеквизит.Наименование, Истина);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		СтрРеквизит.ИмяРеквизитаСвойство = "";
		Если ТипЗначенияСодержитЗначенияСвойств(ТипЗначенияСвойства) Тогда
			СтрРеквизит.ИмяРеквизитаСвойство = "ДополнительныйРеквизитСвойство" + Формат(Номер, "ЧГ=0");
			Реквизит = Новый РеквизитФормы(СтрРеквизит.ИмяРеквизитаСвойство, Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения"), , , Истина);
			ДобавляемыеРеквизиты.Добавить(Реквизит);
		КонецЕсли;
		
		СтрРеквизит.Булево = ОбщегоНазначения.ОписаниеТипаСостоитИзТипа(ТипЗначенияСвойства, Тип("Булево"));
		
	КонецЦикла;
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Создадим элементы формы
	Для Каждого СтрРеквизит Из Таблица Цикл
		
		новСтр = Форма.__Свойства_ОписаниеДополнительныхРеквизитов.Добавить();
		новСтр.ИмяРеквизитаЗначение = СтрРеквизит.ИмяРеквизитаЗначение;
		новСтр.ИмяРеквизитаСвойство = СтрРеквизит.ИмяРеквизитаСвойство;
		новСтр.Свойство             = СтрРеквизит.Свойство;
		
		Форма[СтрРеквизит.ИмяРеквизитаЗначение] = СтрРеквизит.Значение;
		
		ИмяЭлементаДляРазмещения = Форма.__Свойства_ИмяЭлементаДляРазмещения;
		Родитель = ?(ИмяЭлементаДляРазмещения = "", Неопределено, Форма.Элементы[ИмяЭлементаДляРазмещения]);
		Элемент = Форма.Элементы.Добавить(СтрРеквизит.ИмяРеквизитаЗначение, Тип("ПолеФормы"), Родитель);
		Элемент.Вид = ?(СтрРеквизит.Булево, ВидПоляФормы.ПолеФлажка, ВидПоляФормы.ПолеВвода);
		Элемент.ПутьКДанным = СтрРеквизит.ИмяРеквизитаЗначение;
		
		Если СтрРеквизит.Удалено Тогда
			Элемент.ЦветТекстаЗаголовка = ЦветаСтиля.УдаленныйДополнительныйРеквизитЦвет;
			Элемент.ШрифтЗаголовка = ШрифтыСтиля.УдаленныйДополнительныйРеквизитШрифт;
		КонецЕсли;
		
		Если СтрРеквизит.ИмяРеквизитаСвойство <> "" Тогда
			Связь = Новый СвязьПараметраВыбора("Отбор.Владелец", СтрРеквизит.ИмяРеквизитаСвойство);
			масСвязи = Новый Массив;
			масСвязи.Добавить(Связь);
			Элемент.СвязиПараметровВыбора = Новый ФиксированныйМассив(масСвязи);
			Форма[СтрРеквизит.ИмяРеквизитаСвойство] = СтрРеквизит.Свойство;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// По объекту или ссылке на объект получить набор или список наборов доступных ему свойств
// Параметры:
//	ВладелецСвойств - ссылка на объект или сам объект
Функция ПолучитьДоступныеНаборыСвойств(ВладелецСвойств) Экспорт
	
	Возврат ПолучитьОсновнойНаборСвойствДляОбъекта(ВладелецСвойств);
	
КонецФункции

// По объекту или по ссылке на объект и по имени реквизита, содержащего вид объекта
// получает основной набор свойств.
// Для ссылки на справочник "Сущности" функция вернет
// предопределенный элемент справочника НаборыСвойств "Справочник_Сущности".
// Если передан параметр ВидОбъектаИмяРеквизита, функция вернет ссылку на 
// набор свойств, содержащийся в Ссылка.<ВидОбъектаИмяРеквизита>
//
Функция ПолучитьОсновнойНаборСвойствДляОбъекта(ВладелецСвойств) Экспорт
	
	МетаданныеОбъекта = ВладелецСвойств.Метаданные();
	ИмяОбъекта = МетаданныеОбъекта.Имя;
	
	ПереданОбъект = Ложь;
	Если ОбщегоНазначения.ЗначениеСсылочногоТипа(ВладелецСвойств) Тогда
		Ссылка = ВладелецСвойств;
	Иначе
		ПереданОбъект = Истина;
		Ссылка = ВладелецСвойств.Ссылка;
	КонецЕсли;
	
	ВидОбъекта = ОбщегоНазначения.ВидОбъектаПоСсылке(Ссылка);
	ВидОбъектаИмяРеквизита = "";
	Если ВидОбъектаИмяРеквизита = "" Тогда
		Если ВидОбъекта = "Справочник" или ВидОбъекта = "ПланВидовХарактеристик" Тогда
			Если ОбъектЯвляетсяГруппой(ВладелецСвойств) Тогда
				Возврат Неопределено;
			КонецЕсли;
		КонецЕсли;
		ИмяЭлемента = ВидОбъекта + "_" + ИмяОбъекта;
		Возврат Справочники.НаборыСвойств[ИмяЭлемента];
		
	Иначе
		Если ПереданОбъект = Истина Тогда
			Возврат ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВладелецСвойств[ВидОбъектаИмяРеквизита], "НаборСвойств");
			
		Иначе
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ОбъектВладелецСвойств." + ВидОбъектаИмяРеквизита + ".НаборСвойств КАК Набор
			|ИЗ
			|	" + ВидОбъекта + "." + ИмяОбъекта + " КАК ОбъектВладелецСвойств
			|ГДЕ
			|	ОбъектВладелецСвойств.Ссылка = &Ссылка";
			
			Запрос.УстановитьПараметр("Ссылка", Ссылка);
			Результат = Запрос.Выполнить();
			
			Если НЕ Результат.Пустой() Тогда
				Выборка = Результат.Выбрать();
				Выборка.Следующий();
				Если ЗначениеЗаполнено(Выборка.Набор) Тогда
					Возврат Выборка.Набор;
				Иначе
					Возврат Справочники.НаборыСвойств.ПустаяСсылка();
				КонецЕсли;
			Иначе
				Возврат Справочники.НаборыСвойств.ПустаяСсылка();
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

// Получить заполненную таблицу значений свойств объекта
Функция ПолучитьТаблицуЗначенийСвойств(ДополнительныеСвойстваОбъекта, Набор, ЭтоДополнительноеСведение) Экспорт
	
	масСвойств = ДополнительныеСвойстваОбъекта.ВыгрузитьКолонку("Свойство");
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НаборыСвойствДополнительныеРеквизиты.Свойство КАК Свойство,
	|	МИНИМУМ(НаборыСвойствДополнительныеРеквизиты.НомерСтроки) КАК Порядок
	|ПОМЕСТИТЬ ВсеСвойстваНабора
	|ИЗ
	|	Справочник.НаборыСвойств.ДополнительныеРеквизиты КАК НаборыСвойствДополнительныеРеквизиты
	|ГДЕ
	|	НаборыСвойствДополнительныеРеквизиты.Ссылка В(&Набор)
	|	И (НЕ НаборыСвойствДополнительныеРеквизиты.Ссылка.ПометкаУдаления)
	|	И (НЕ НаборыСвойствДополнительныеРеквизиты.Ссылка.ЭтоГруппа)
	|	И (НЕ &ЭтоДополнительноеСведение)
	|
	|СГРУППИРОВАТЬ ПО
	|	НаборыСвойствДополнительныеРеквизиты.Свойство
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НаборыСвойствДополнительныеСведения.Свойство,
	|	МИНИМУМ(НаборыСвойствДополнительныеСведения.НомерСтроки)
	|ИЗ
	|	Справочник.НаборыСвойств.ДополнительныеСведения КАК НаборыСвойствДополнительныеСведения
	|ГДЕ
	|	НаборыСвойствДополнительныеСведения.Ссылка В(&Набор)
	|	И (НЕ НаборыСвойствДополнительныеСведения.Ссылка.ПометкаУдаления)
	|	И (НЕ НаборыСвойствДополнительныеСведения.Ссылка.ЭтоГруппа)
	|	И &ЭтоДополнительноеСведение
	|
	|СГРУППИРОВАТЬ ПО
	|	НаборыСвойствДополнительныеСведения.Свойство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДополнительныеРеквизитыИСведения.Ссылка КАК Свойство
	|ПОМЕСТИТЬ ЗаполненныеСвойства
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|ГДЕ
	|	ДополнительныеРеквизитыИСведения.Ссылка В(&масСвойств)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВсеСвойстваНабора.Свойство,
	|	ВсеСвойстваНабора.Порядок,
	|	ЛОЖЬ КАК Удалено
	|ПОМЕСТИТЬ ВсеСвойства
	|ИЗ
	|	ВсеСвойстваНабора КАК ВсеСвойстваНабора
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаполненныеСвойства.Свойство,
	|	0,
	|	ИСТИНА
	|ИЗ
	|	ЗаполненныеСвойства КАК ЗаполненныеСвойства
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВсеСвойстваНабора КАК ВсеСвойстваНабора
	|		ПО ЗаполненныеСвойства.Свойство = ВсеСвойстваНабора.Свойство
	|ГДЕ
	|	ВсеСвойстваНабора.Свойство ЕСТЬ NULL 
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	ВсеСвойства.Свойство,
	|	ДополнительныеРеквизитыИСведения.Наименование,
	|	ДополнительныеРеквизитыИСведения.ТипЗначения,
	|	ВсеСвойства.Удалено КАК Удалено
	|ИЗ
	|	ВсеСвойства КАК ВсеСвойства
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|		ПО ВсеСвойства.Свойство = ДополнительныеРеквизитыИСведения.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Удалено,
	|	ВсеСвойства.Порядок";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ЭтоДополнительноеСведение", ЭтоДополнительноеСведение);
	Запрос.УстановитьПараметр("масСвойств", масСвойств);
	Запрос.УстановитьПараметр("Набор", Набор);
	
	ТабСвойства = Запрос.Выполнить().Выгрузить();
	ТабСвойства.Индексы.Добавить("Свойство");
	ТабСвойства.Колонки.Добавить("Значение");
	
	Для Каждого Стр Из ДополнительныеСвойстваОбъекта Цикл
		СтрСвойства = ТабСвойства.Найти(Стр.Свойство, "Свойство");
		Если СтрСвойства <> Неопределено Тогда
			СтрСвойства.Значение = Стр.Значение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТабСвойства;
	
КонецФункции

// Удалить старые реквизиты и элементы формы
Процедура УдалитьСтарыеРеквизиты(Форма)
	
	// Удалим старые реквизиты и элементы
	масУдалять = Новый Массив;
	Для Каждого СтрРеквизит Из Форма.__Свойства_ОписаниеДополнительныхРеквизитов Цикл
		
		масУдалять.Добавить(СтрРеквизит.ИмяРеквизитаЗначение);
		Если Не ПустаяСтрока(СтрРеквизит.ИмяРеквизитаСвойство) Тогда
			масУдалять.Добавить(СтрРеквизит.ИмяРеквизитаСвойство);
		КонецЕсли;
		
		Форма.Элементы.Удалить(Форма.Элементы[СтрРеквизит.ИмяРеквизитаЗначение]);
		
	КонецЦикла;
	
	Если масУдалять.Количество() Тогда
		Форма.ИзменитьРеквизиты(, масУдалять);
	КонецЕсли;
	
КонецПроцедуры

// Проверить, что тип значения свойства содержит ссылку на справочник ЗначенияСвойствОбъектов
Функция ТипЗначенияСодержитЗначенияСвойств(ТипЗначения) Экспорт
	
	Возврат ТипЗначения.Типы().Найти(Тип("СправочникСсылка.ЗначенияСвойствОбъектов")) <> Неопределено;
	
КонецФункции

// Является ли объект группой
// В качестве параметра может принимать только справочник или ПВХ
Функция ОбъектЯвляетсяГруппой(Объект)
	МетаданныеОбъекта = Объект.Метаданные();
	Если НЕ (МетаданныеОбъекта.Иерархический И МетаданныеОбъекта.ВидИерархии = Метаданные.СвойстваОбъектов.ВидИерархии.ИерархияГруппИЭлементов) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЗначениеСсылочногоТипа(Объект) Тогда
		Возврат Объект.ЭтоГруппа;
	КонецЕсли;
	
	Ссылка = Объект.Ссылка;
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Ссылка, "ЭтоГруппа");
	
КонецФункции

// Функция - Получить картинку ПШ
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКартинкуПШ(ТипШлюза) Экспорт
			
	Если ТипШлюза = Перечисления.ПлатежныеШлюзы.Сбербанк 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR Тогда		
		КартинкаПлатёжногоШлюза = БиблиотекаКартинок.СсылкиНаОплату_СберБанк_16;			
	ИначеЕсли ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПСбербанк
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПТинькофф 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда		
		КартинкаПлатёжногоШлюза = БиблиотекаКартинок.СсылкиНаОплату_СБП_16;		
	Иначе
		КартинкаПлатёжногоШлюза = Новый Картинка;
	КонецЕсли;
	
	Возврат КартинкаПлатёжногоШлюза;
	
КонецФункции

#КонецОбласти
