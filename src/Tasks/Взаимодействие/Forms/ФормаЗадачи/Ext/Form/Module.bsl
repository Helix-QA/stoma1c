&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ИмяЭлемента, ИндексЭлемента = Истина)
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	КонецЕсли;
	 	
КонецФункции

&НаКлиенте
// Процедура, СменитьФокусЭлемента.
Процедура СменитьФокусЭлемента(Знач ИндексГурппы)
	
	ЭтаФорма.ТекущийЭлемент = Элементы["КнопкаТекущийЭтап_" + ИндексГурппы];

КонецПроцедуры

&НаСервереБезКонтекста
// Функция, ПолучитьПоследнююПродажуПоСделке.
//
Функция ПолучитьПоследнююПродажуПоСделке(Сделка)
	
	Если НЕ ЗначениеЗаполнено(Сделка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Реализация.Ссылка КАК Продажа
	|ИЗ
	|	Документ.Реализация КАК Реализация
	|ГДЕ
	|	Реализация.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Реализация.Дата УБЫВ";
	Запрос.УстановитьПараметр("Сделка", Сделка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ЗначениеВозврата = ?(Выборка.Следующий(), Выборка.Продажа, Неопределено);
	
	Возврат ЗначениеВозврата;
		
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура - Инициализация формы.
//
Процедура ИнициализацияФормы()
		
	Если НЕ ЗначениеЗаполнено(Объект.ЗадачаТема) Тогда 
		Объект.ЗадачаТема = НСтр("ru = 'Без темы'; en = 'No subject'");
	КонецЕсли;
	
	// Задает вид взаимодействия по умолчанию
	Если Объект.Ссылка.Пустая() Тогда 
		
		Если Не ЗначениеЗаполнено(Объект.ВидВзаимодействияСправочник) Тогда 
			Объект.ВидВзаимодействияСправочник 	= Справочники.ВидыВзаимодействий.НайтиПоРеквизиту("ВидВзаимодействия", Перечисления.ВидыВзаимодействия.ЗвонокИсходящий);	
			ВидВзаимодействия 					= Объект.ВидВзаимодействияСправочник.ВидВзаимодействия;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.ЗадачаНазначеннаяДата) Тогда
			Объект.ЗадачаНазначеннаяДата = ОбщегоНазначенияСтоматология.ВернутьКратнуюТекущуюДатуСеанса(); 	
		КонецЕсли;
		
		// Заполнение реквизитов задачи из параметров при создании нового объекта.
		Если Параметры.Свойство("ИдентификаторСделки") Тогда
			Объект.Сделка = Справочники.Сделки.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ИдентификаторСделки));
		КонецЕсли;
		
		Если Параметры.Свойство("ИдентификаторКлиента") Тогда
			Объект.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(Параметры.ИдентификаторКлиента));
		КонецЕсли;
		
	КонецЕсли;		
	
	ЗадачаНазначеннаяДатаВремя       = Объект.ЗадачаНазначеннаяДата;
	ЗадачаНазначеннаяДатаНачалоВремя = Объект.ЗадачаНазначеннаяДатаНачало;
		
	// Заполним список выбора времени
	ЗаполнитьСписокВыбораВремениЗадачи("ЗадачаНазначеннаяДата");
	ЗаполнитьСписокВыбораВремениЗадачи("ЗадачаНазначеннаяДатаНачало");
	
	// Заполним список выбора времени напоминания.
	ЗаполнитьСписокВыбораРежимаНапоминания();
	ЗаполнитьСписокВыбораВзаимодействия();
	
	Если ТипЗнч(Объект.Исполнитель) = Тип("СправочникСсылка.Сотрудники") Тогда
		Элементы.ВзаимодействиеИсполнитель.Заголовок = ПолучитьПредставлениеФИОСотрудника(Объект.Исполнитель);	
	Иначе
		Элементы.ВзаимодействиеИсполнитель.Заголовок = Строка(Объект.Исполнитель);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Элементы.ДекорацияАвтор.Видимость = Истина;
		Если ЗначениеЗаполнено(Объект.ЗадачаАвтор) Тогда 
			ЭтоСлужебный = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.ЗадачаАвтор, "Служебный");
		Иначе 
			ЭтоСлужебный = Истина;
		КонецЕсли;	
		Если (ТипЗнч(Объект.Исполнитель) = Тип("СправочникСсылка.Сотрудники") И Объект.Исполнитель = Объект.ЗадачаАвтор) ИЛИ ЭтоСлужебный = Истина Тогда 
			Элементы.ДекорацияАвтор.Заголовок = "(Создана: " + Формат(Объект.Дата, "ДФ=dd.MM.yyyy") + ")";
		Иначе 
			Элементы.ДекорацияАвтор.Заголовок = "(Создана: " + Справочники.Сотрудники.ПолучитьСокращенноеНаименованиеСотрудника(, Объект.ЗадачаАвтор) + " " + Формат(Объект.Дата, "ДФ=dd.MM.yyyy") + ")";
		КонецЕсли;
	Иначе 
		Элементы.ДекорацияАвтор.Видимость = Ложь;
	КонецЕсли;

	// Получим клиента
	Если Не ЗначениеЗаполнено(Объект.Контрагент)
		И ЗначениеЗаполнено(Объект.ЗадачаПредмет) 
		И (ТипЗнч(Объект.ЗадачаПредмет) = Тип("СправочникСсылка.Заявки")) Тогда
		ЭтотОбъект.Клиент = Объект.ЗадачаПредмет.ОсновнойКлиент;
	Иначе 
		ЭтотОбъект.Клиент = Объект.Контрагент;
	КонецЕсли;

	// Получим статус контрагента
	Если ЗначениеЗаполнено(ЭтотОбъект.Клиент) Тогда 
		ЭтотОбъект.СтатусКлиента = Справочники.Контрагенты.ПолучитьСтатус(ЭтотОбъект.Клиент);
	КонецЕсли;
		
	ЭтотОбъект.ВзаимодействиеВыполнено = Объект.Выполнена;
	
	БизнесПроцессыИЗадачиСервер.ФормаЗадачиПриСозданииНаСервереСтоматология(ЭтотОбъект, Объект, Элементы.ГруппаСостояние,, Ложь);
		
	ОбновитьВидимостьЭлементов(Истина);
	
КонецПроцедуры

&НаСервере
// Заполнить список выбора времени выполнения задачи
//
Процедура ЗаполнитьСписокВыбораВремениЗадачи(ЗадачаДата)
	
	МассивПериодов = Новый Массив;
    СтруктураВремени               = ОбщегоНазначенияСтоматология.ПолучитьВремяРаботыСтруктурнойЕдиницы(Объект[ЗадачаДата], Объект.СтруктурнаяЕдиница);
	СтруктураВремени.ДатаНачала    = ?(ЗначениеЗаполнено(СтруктураВремени.ДатаНачала), СтруктураВремени.ДатаНачала, Дата("00010101080000"));
	СтруктураВремени.ДатаОкончания = ?(ЗначениеЗаполнено(СтруктураВремени.ДатаОкончания), СтруктураВремени.ДатаОкончания, Дата("00010101220000"));
	
	МассивПериодов.Добавить(СтруктураВремени);	
	СписокВремени = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьСписокВремени(МассивПериодов, Истина, 30);	
	
	НазначеннаяДатаДень		= День(Объект[ЗадачаДата]);
	НазначеннаяДатаМесяц	= Месяц(Объект[ЗадачаДата]);
	НазначеннаяДатаГод		= Год(Объект[ЗадачаДата]);
	
	Элементы.Найти(ЗадачаДата+"Время").СписокВыбора.Очистить();
	Элементы.Найти(ЗадачаДата+"Время").СписокВыбора.Добавить(НачалоДня(Объект[ЗадачаДата]), Нстр("ru = 'Весь день'; en = 'Entire day'"));
	
	Для Каждого Элемент ИЗ СписокВремени Цикл	
	     Элементы.Найти(ЗадачаДата+"Время").СписокВыбора.Добавить(Дата(НазначеннаяДатаГод, НазначеннаяДатаМесяц, НазначеннаяДатаДень,
		 				Час(Элемент.Значение), Минута(Элемент.Значение), Секунда(Элемент.Значение)), ?(Минута(Элемент.Значение) = 0, Элемент.Представление, Новый ФорматированнаяСтрока( Элемент.Представление,,Новый Цвет(100, 100, 100))));
	КонецЦикла;
	
	ЭтаФорма[ЗадачаДата+"Время"] = Дата(НазначеннаяДатаГод, НазначеннаяДатаМесяц, НазначеннаяДатаДень,
						Час(ЭтаФорма[ЗадачаДата+"Время"]), Минута(ЭтаФорма[ЗадачаДата+"Время"]), Секунда(ЭтаФорма[ЗадачаДата+"Время"]));
						
	Если Элементы.Найти(ЗадачаДата+"Время").СписокВыбора.НайтиПоЗначению(ЭтаФорма[ЗадачаДата+"Время"]) = Неопределено Тогда
		// Если не нашли в списке нашу дату
		Если ЗадачаНазначеннаяДатаВремя < Дата(Год(Объект[ЗадачаДата]), Месяц(Объект[ЗадачаДата]), День(Объект[ЗадачаДата]), Час(СтруктураВремени.ДатаНачала), Минута(СтруктураВремени.ДатаНачала), Секунда(СтруктураВремени.ДатаНачала)) Тогда 
			// Если наша дата меньше времени начала работы СЕ - корректируем по минимуму
			ЗадачаНазначеннаяДатаВремя = Дата(Год(Объект[ЗадачаДата]), Месяц(Объект[ЗадачаДата]), День(Объект[ЗадачаДата]), Час(СтруктураВремени.ДатаНачала), Минута(СтруктураВремени.ДатаНачала), Секунда(СтруктураВремени.ДатаНачала));
		ИначеЕсли ЗадачаНазначеннаяДатаВремя > Дата(Год(Объект[ЗадачаДата]), Месяц(Макс(Объект[ЗадачаДата], СтруктураВремени.ДатаОкончания)), День(Макс(Объект[ЗадачаДата], СтруктураВремени.ДатаОкончания)), Час(СтруктураВремени.ДатаОкончания), Минута(СтруктураВремени.ДатаОкончания), Секунда(СтруктураВремени.ДатаОкончания)) Тогда 
			// Если наша дата больше времени начала работы СЕ - корректируем по максимуму			
			ЗадачаНазначеннаяДатаВремя = Дата(Год(Объект[ЗадачаДата]), Месяц(Макс(Объект[ЗадачаДата], СтруктураВремени.ДатаОкончания)), День(Макс(Объект[ЗадачаДата], СтруктураВремени.ДатаОкончания)), Час(СтруктураВремени.ДатаОкончания), Минута(СтруктураВремени.ДатаОкончания), Секунда(СтруктураВремени.ДатаОкончания));
		Иначе 
			// Добавляем в список уникальную дату
			Элементы.Найти(ЗадачаДата+"Время").СписокВыбора.Добавить(Объект[ЗадачаДата], Формат(Объект[ЗадачаДата], "ДФ=ЧЧ:мм"));
			// Сортируем
			Элементы.Найти(ЗадачаДата+"Время").СписокВыбора.СортироватьПоЗначению();
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Заполнить список выбора взаимодействия.
//
Процедура ЗаполнитьСписокВыбораВзаимодействия()
	
	ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора.Очистить();
	
	ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора = Справочники.ВидыВзаимодействий.ПолучитьСписокВзаимодействий();
	
	Если ЗначениеЗаполнено(Объект.ВидВзаимодействияСправочник) Тогда                                     
		Для Каждого Взаимодействие Из ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора Цикл
			Если Взаимодействие.Представление = Объект.ВидВзаимодействияСправочник.Наименование Тогда
				
				Элементы.ДекорацияВзаимодействиеИконка.Картинка     = Взаимодействие.Картинка;
				Элементы.ДекорацияВзаимодействиеИконка.Видимость    = ЗначениеЗаполнено(Взаимодействие.Картинка);
				Элементы.ВидВзаимодействияСправочникВыбор.Заголовок = Взаимодействие.Представление;
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Заполнить список выбора режима напоминания
//
Процедура ЗаполнитьСписокВыбораРежимаНапоминания()
	
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Очистить();
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(-1	 , Нстр("ru = 'не напоминать'; en = 'do not remind'"));
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(0     , Нстр("ru = 'в момент события'; en = 'at the time of the event'"));
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(300   , Нстр("ru = 'за 5 минут'; en = '5 minutes before'"));
    ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(600   , Нстр("ru = 'за 10 минут'; en = '10 minutes before'"));
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(900   , Нстр("ru = 'за 15 минут'; en = '15 minutes before'"));
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(1800  , Нстр("ru = 'за 30 минут'; en = '30 minutes before'"));     
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(3600  , Нстр("ru = 'за 1 час'; en = '1 hour before'"));
	ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(7200  , Нстр("ru = 'за 2 часа'; en = '2 hours before'"));
    ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(86400 , Нстр("ru = 'за 1 день'; en = '1 day before'"));
    ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(172800, Нстр("ru = 'за 2 дня'; en = '2 days before'"));
    ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.Добавить(604800, Нстр("ru = 'за 1 неделю'; en = '1 week before'"));
	
	Если Объект.НапоминаниеИспользовать = Истина Тогда 
		Если Объект.ВариантНапоминания = Перечисления.ВариантыНапоминаний.ЗаВремяОтносительноСобытия Тогда 
			ЭтотОбъект.ЗадачаРежимНапоминания = Объект.ЗадачаНазначеннаяДата - Объект.НапоминаниеДатаНачала;
		ИначеЕсли Объект.ВариантНапоминания = Перечисления.ВариантыНапоминаний.ПоПосещению Тогда
			ЭтотОбъект.ЗадачаРежимНапоминания = 1;
		Иначе 
			ЭтотОбъект.ЗадачаРежимНапоминания = -1;
		КонецЕсли;	
	Иначе 
		ЭтотОбъект.ЗадачаРежимНапоминания = -1;
	КонецЕсли;	
	
	НайденноеЗначение = ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора.НайтиПоЗначению(ЭтотОбъект.ЗадачаРежимНапоминания);
	Если НайденноеЗначение = Неопределено Тогда
		ЭтотОбъект.ЗадачаРежимНапоминания = -1;
		Элементы.ВзаимодействиеРежимНапоминания.Заголовок = Нстр("ru = 'не напоминать'; en = 'do not remind'")
	Иначе
		Элементы.ВзаимодействиеРежимНапоминания.Заголовок = НайденноеЗначение.Представление;
	КонецЕсли;	
	
КонецПроцедуры

