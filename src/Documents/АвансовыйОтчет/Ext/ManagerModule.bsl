// Вернуть документы основания выданных авансов
Функция ВернутьВыданныеАвансыПоДокументу(Ссылка)
	
	ЗапросПоАвансам = Новый Запрос;
	ЗапросПоАвансам.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	АвансовыйОтчетВыданныеАвансы.НомерСтроки,
	|	АвансовыйОтчетВыданныеАвансы.Документ,
	|	АвансовыйОтчетВыданныеАвансы.Сумма
	|ИЗ
	|	Документ.АвансовыйОтчет.ВыданныеАвансы КАК АвансовыйОтчетВыданныеАвансы
	|ГДЕ
	|	АвансовыйОтчетВыданныеАвансы.Ссылка = &Ссылка
	|	И АвансовыйОтчетВыданныеАвансы.Сумма > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	АвансовыйОтчетВыданныеАвансы.Документ.Дата";
				   
	ЗапросПоАвансам.УстановитьПараметр("Ссылка", Ссылка);
	Возврат ЗапросПоАвансам.Выполнить().Выгрузить();
	
КонецФункции

  #Область ПроцедурыПечатиДокумента

// Процедура печати документа.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АО1") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм,
			"АО1",
			"Авансовый отчет",
			СформироватьПечатнуюФормуАО1(МассивОбъектов, ОбъектыПечати)
		);
		
	КонецЕсли;
	
КонецПроцедуры // Печать()

Функция СформироватьПечатнуюФормуАО1(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_АвансовыйОтчет";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
		
		Запрос.Текст =
		"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
		|	АвансовыйОтчет.Номер,
		|	АвансовыйОтчет.Дата КАК ДатаДокумента,
		|	АвансовыйОтчет.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	АвансовыйОтчет.Сотрудник КАК Сотрудник,
		|	АвансовыйОтчет.СуммаДокумента,
		|	АвансовыйОтчет.ВыданныеАвансы КАК ВыданныеАвансы,
		|	АвансовыйОтчет.Запасы КАК Запасы,
		|	АвансовыйОтчет.Расходы КАК Расходы,
		|	АвансовыйОтчет.Оплаты КАК Оплаты
		|ИЗ
		|	Документ.АвансовыйОтчет КАК АвансовыйОтчет
		|ГДЕ
		|	АвансовыйОтчет.Ссылка = &ТекущийДокумент";
		
		Шапка = Запрос.Выполнить().Выбрать();
		Шапка.Следующий();
		
		ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АвансовыйОтчет_АвансовыйОтчет";
		
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.АвансовыйОтчет.ПФ_MXL_АО1");
		
		// ТИТУЛЬНЫЙ ЛИСТ
		МассивАвансовыхДокументов = Шапка.ВыданныеАвансы.Выгрузить().ВыгрузитьКолонку("Документ");
		
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("Сотрудник",  Шапка.Сотрудник);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Шапка.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ДатаИтогов", Шапка.ДатаДокумента);
		Запрос.УстановитьПараметр("МассивАвансовыхДокументов", МассивАвансовыхДокументов);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(ВложенныйЗапрос.СуммаОстаток) КАК СуммаОстаток
		|ИЗ
		|	(ВЫБРАТЬ
		|		РасчетыСПодотчетникамиОстатки.СуммаОстаток КАК СуммаОстаток
		|	ИЗ
		|		РегистрНакопления.РасчетыСПодотчетниками.Остатки(
		|				&ДатаИтогов,
		|				СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|					И Сотрудник = &Сотрудник) КАК РасчетыСПодотчетникамиОстатки
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ВЫБОР
		|			КОГДА РасчетыСПодотчетниками.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|				ТОГДА ЕСТЬNULL(РасчетыСПодотчетниками.Сумма, 0)
		|			ИНАЧЕ -ЕСТЬNULL(РасчетыСПодотчетниками.Сумма, 0)
		|		КОНЕЦ
		|	ИЗ
		|		РегистрНакопления.РасчетыСПодотчетниками КАК РасчетыСПодотчетниками
		|	ГДЕ
		|		РасчетыСПодотчетниками.Регистратор В(&МассивАвансовыхДокументов)
		|		И РасчетыСПодотчетниками.Период <= &ДатаИтогов) КАК ВложенныйЗапрос";
		ПредыдущийАванс = Запрос.Выполнить().Выгрузить();
		СуммаДоДокумента = Число(ПредыдущийАванс.Итог("СуммаОстаток"));
		
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("МассивАвансовыхДокументов", МассивАвансовыхДокументов);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(СписаниеДенежныхСредств.СуммаДокумента) КАК СуммаДокумента
		|ИЗ
		|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
		|ГДЕ
		|	СписаниеДенежныхСредств.Ссылка В(&МассивАвансовыхДокументов)
		|
		|СГРУППИРОВАТЬ ПО
		|	СписаниеДенежныхСредств.Ссылка";
		Таб = Запрос.Выполнить().Выгрузить();
		ПолученоИзКассы = Число(Таб.Итог("СуммаДокумента"));
		
		ОбластьМакета = Макет.ПолучитьОбласть("Титул");
		
		// Выводим титульный лист авансового отчета
		ОбластьМакета.Параметры.суммарубкоп1= "Сумма" +ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти()+","+ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыДробнойЧасти();
		ОбластьМакета.Параметры.суммарубкоп2=ОбластьМакета.Параметры.суммарубкоп1;
		ОбластьМакета.Параметры.суммарубкоп3=ОбластьМакета.Параметры.суммарубкоп1;
        ОбластьМакета.Параметры.ТекРуб1= ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		ОбластьМакета.Параметры.ТекРуб2= ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		  ОбластьМакета.Параметры.дробчасть1 = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыДробнойЧасти();
		  ОбластьМакета.Параметры.дробчасть2 = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыДробнойЧасти();
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.ПодотчетноеЛицо           = Шапка.Сотрудник;
		ОбластьМакета.Параметры.ДолжностьПодотчетногоЛица = Шапка.Сотрудник.Должность;
		ОбластьМакета.Параметры.НомерДокумента            = Шапка.Номер;
		ОбластьМакета.Параметры.ПолученоИзКассы           = ПолученоИзКассы;
		
		Если СуммаДоДокумента >= 0 тогда
			ОбластьМакета.Параметры.НачальныйОстаток    =   СуммаДоДокумента;
		Иначе
			ОбластьМакета.Параметры.НачальныйПерерасход = - СуммаДоДокумента;
		КонецЕсли;
		
		ОбластьМакета.Параметры.ИтогоПолучено = ПолученоИзКассы;
		ОбластьМакета.Параметры.Израсходовано = Шапка.СуммаДокумента;
		
		ОстатокНаКонец = СуммаДоДокумента + ПолученоИзКассы - Шапка.СуммаДокумента;
		Если ОстатокНаКонец >= 0  Тогда
			ОбластьМакета.Параметры.КонечныйОстаток    = ОстатокНаКонец;
		Иначе
			ОбластьМакета.Параметры.КонечныйПерерасход = - ОстатокНаКонец;
		КонецЕсли;
		
		Руководитель        = ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Шапка.СтруктурнаяЕдиница.Организация, Перечисления.ТипыОтветственныхЛиц.Руководитель);
		ГлавныйБухгалтер	= ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Шапка.СтруктурнаяЕдиница.Организация, Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер);
		Кассир              = ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Шапка.СтруктурнаяЕдиница.Организация, Перечисления.ТипыОтветственныхЛиц.Кассир);
		
		ИспСумма     = Окр(Шапка.СуммаДокумента, 2, 1);
		ЦелСумма     = Цел(Шапка.СуммаДокумента);
		КопСумма     = 100 * (Окр(ИспСумма - ЦелСумма, 2, 1));
		Если КопСумма = 0 Тогда
			КопСумма= "00";
		КонецЕсли;
		
		ОбластьМакета.Параметры.ИзрасходованоРуб    = ЦелСумма;
		ОбластьМакета.Параметры.ИзрасходованоКоп    = КопСумма;
		
		ОбластьМакета.Параметры.ДатаДокумента       = Шапка.ДатаДокумента;
		
		ОбластьМакета.Параметры.СуммаОтчетаПрописью = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(Шапка.СуммаДокумента);
			
		ОбластьМакета.Параметры.Организация         	= Шапка.СтруктурнаяЕдиница.Организация;
		ОбластьМакета.Параметры.Руководитель        	= ?(Руководитель.Количество() > 0, Руководитель[0].Сотрудник, "");
		ОбластьМакета.Параметры.ДолжностьРуководителя	= ?(Руководитель.Количество() > 0, Руководитель[0].Должность, "");
		ОбластьМакета.Параметры.ГлавныйБухгалтер		= ?(ГлавныйБухгалтер.Количество() > 0, ГлавныйБухгалтер[0].Сотрудник, "");
		ОбластьМакета.Параметры.Кассир              	= ?(Кассир.Количество() > 0, Кассир[0].Сотрудник, "");
			
		ТабличныйДокумент.Вывести(ОбластьМакета);
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		// ОБОРОТНАЯ СТОРОНА
		
		Запасы = Шапка.Запасы.Выбрать();
		Расходы = Шапка.Расходы.Выбрать();
		Оплаты = Шапка.Оплаты.Выбрать();
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.суммарубкоп4= "В"+ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		ОбластьМакета.Параметры.суммарубкоп5= "В"+ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		

		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		
		// Выводим табличные части
		ОбластьМакета = Макет.ПолучитьОбласть("Строка");
		НомерСтроки   = 0;
		
		ИтогоПоОтчету        = 0;
		
		
		
		

		
		
		
		Пока Запасы.Следующий() Цикл
			
			ОбластьМакета.Параметры.Заполнить(Запасы);
			НомерСтроки = НомерСтроки + 1;
			ОбластьМакета.Параметры.НомерСтроки         = НомерСтроки;
			ОбластьМакета.Параметры.НаименованиеРасхода = Запасы.Номенклатура;
			
			ОбластьМакета.Параметры.ПоОтчету = Запасы.Сумма;
			ОбластьМакета.Параметры.ПоУчету  = Запасы.Сумма;
			
			ИтогоПоОтчету = ИтогоПоОтчету + Запасы.Сумма;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЦикла;
				НомерСтроки = ?(ЗначениеЗаполнено(Запасы.НомерСтроки), Запасы.НомерСтроки, 0);
		
		Пока Расходы.Следующий() Цикл
		
			ОбластьМакета.Параметры.Заполнить(Расходы);
			НомерСтроки = НомерСтроки + 1;
			ОбластьМакета.Параметры.НомерСтроки         = НомерСтроки;
			ОбластьМакета.Параметры.НаименованиеРасхода = Расходы.Номенклатура;
				
			ОбластьМакета.Параметры.ПоОтчету = Расходы.Сумма;
			ОбластьМакета.Параметры.ПоУчету  = Расходы.Сумма;
			
			ИтогоПоОтчету = ИтогоПоОтчету + Расходы.Сумма;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЦикла;
		
		Пока Оплаты.Следующий() Цикл
		
			ОбластьМакета.Параметры.Заполнить(Оплаты);
			НомерСтроки = НомерСтроки + 1;
			ОбластьМакета.Параметры.НомерСтроки         = НомерСтроки;
			ОбластьМакета.Параметры.НаименованиеРасхода = НСтр("ru = 'Оплата контрагенту '") + Оплаты.Контрагент;
			
			ОбластьМакета.Параметры.ПоОтчету = Оплаты.Сумма;
			ОбластьМакета.Параметры.ПоУчету  = Оплаты.Сумма;
			
			ИтогоПоОтчету = ИтогоПоОтчету + Оплаты.Сумма;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЦикла;
		
		// Выводим подвал авансовго отчета
		ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.ПодотчетноеЛицо 	 = Шапка.Сотрудник;
		ОбластьМакета.Параметры.ИтогоПоОтчету        = ИтогоПоОтчету;
		ОбластьМакета.Параметры.ИтогоПоУчету         = ИтогоПоОтчету;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

