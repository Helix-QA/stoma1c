
#Область ОбработчикиСобытий

// Процедура - Обработка заполнения
//
// Параметры:
//  ДанныеЗаполнения	 - 	 - 
//  ТекстЗаполнения		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ЭтотОбъект.Используется = Истина;
	
КонецПроцедуры

// Процедура - При записи
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
		
	Если НЕ ЭтотОбъект.ПометкаУдаления Тогда 
		Если ЭтотОбъект.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi И ЭтотОбъект.Используется Тогда 
			ИнициализироватьДанныеВнешнейСистемыПередЗаписью();
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - При записи
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриЗаписи(Отказ)
	
	ИнициализацияМехнизмаРаботыСЧатБотом();
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура - Инициализировать данные внешней системы перед записью
//
Процедура ИнициализироватьДанныеВнешнейСистемыПередЗаписью()
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	СтруктураДанныхПередЗаписью = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ЭтотОбъект.Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнешниеСистемы.ПометкаУдаления КАК ПометкаУдаления,
	|	ВнешниеСистемы.ИдентификаторКлиента КАК ИдентификаторКлиента,
	|	ВнешниеСистемы.Используется КАК Используется,
	|	ВнешниеСистемы.КлючПриложения КАК КлючПриложения,
	|	ВнешниеСистемы.КлючШифрования КАК КлючШифрования,
	|	ВнешниеСистемы.КлючШифрованияОбратногоЗвонка КАК КлючШифрованияОбратногоЗвонка,
	|	ВнешниеСистемы.Параметры КАК Параметры,
	|	ВнешниеСистемы.Синхронизирована КАК Синхронизирована,
	|	ВнешниеСистемы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.ТокенДоступа КАК ТокенДоступа,
	|	ВнешниеСистемы.УправлениеВЛичномКабинете КАК УправлениеВЛичномКабинете
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Ссылка = &Ссылка";
	
	ТаблицаСвойств = Запрос.Выполнить().Выгрузить();
	Для Каждого Колонка Из ТаблицаСвойств.Колонки Цикл 
		СтруктураДанныхПередЗаписью.Вставить(Колонка.Имя, Неопределено);
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(ТаблицаСвойств) Тогда 
		ЗаполнитьЗначенияСвойств(СтруктураДанныхПередЗаписью, ТаблицаСвойств[0]);
	КонецЕсли;
	
	ЭтотОбъект.ДополнительныеСвойства.Вставить("ДанныеПередЗаписью", СтруктураДанныхПередЗаписью);
		
КонецПроцедуры

// Процедура - Инициализация мехнизма работы с чат ботом
//
Процедура ИнициализацияМехнизмаРаботыСЧатБотом()
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДанныеПередЗаписью = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ДанныеПередЗаписью", Неопределено);
	Если ЗначениеЗаполнено(ДанныеПередЗаписью) И НЕ ДанныеПередЗаписью.Параметры = Неопределено Тогда 
		ПараметрыСистемы = ДанныеПередЗаписью.Параметры.Получить();
		Если ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСистемы, "Подписка", Неопределено))
			И СценарииНеИнициализированы() Тогда
			Попытка
				ОператорСообщения = Константы.СотрудникЧатБота.Получить();
				Если НЕ ЗначениеЗаполнено(ОператорСообщения) Тогда 
					Константы.СотрудникЧатБота.СгенерироватьСотрудникаЧатБота();
				КонецЕсли;
				ТаблицаСервисовРассылки = Справочники.СтруктурныеЕдиницы.ПолучитьТаблицуСервисовРассылокДляСтруктурныхЕдиниц();
				ОбновлениеИнформационнойБазыСтоматология.ИнициализацияСтандартногоНабораТриггеров(ТаблицаСервисовРассылки);
				ОбновлениеИнформационнойБазыСтоматология.ИнициализацияПредопределенныхСценариевЧатБота(Ложь, ТаблицаСервисовРассылки);
				ОбновлениеИнформационнойБазыСтоматология.ИнициализироватьМеханизмРекомендаций(ТаблицаСервисовРассылки);
			Исключение
				ОбщегоНазначения.СообщитьПользователю("При инициализации механизма для работы с чат-ботом произошла исключительная ситуация. Смотри подробности в журнале регистрации");
				
				МетаданныеСправочника 				= Метаданные.Справочники.ВнешниеСистемы;		
				ШаблонКомментария = НСтр("ru = 'При инициализации механизма для работы с чат-ботом произошла исключительная ситуация 
				|по причине: %1'");
				
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
				, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				
				ЗаписьЖурналаРегистрации(Справочники.ВнешниеСистемы.СобытиеЖурналаРегистрации()
				, УровеньЖурналаРегистрации.Предупреждение
				, МетаданныеСправочника
				,
				, Комментарий);				
			КонецПопытки;
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Функция - Сценарии не инициализированы
// 
// Возвращаемое значение:
//   - 
//
Функция СценарииНеИнициализированы()	
		
	Если НЕ ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИмяМакетаПредопределенногоСценария", "ПодтверждениеЗаписиНаПрием");
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СценарииЧатБотов.Ссылка КАК СценарийЧатБота
	|ИЗ
	|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
	|ГДЕ
	|	СценарииЧатБотов.ПометкаУдаления = ЛОЖЬ
	|	И СценарииЧатБотов.ИмяМакетаПредопределенногоСценария = &ИмяМакетаПредопределенногоСценария";
	
    Возврат Запрос.Выполнить().Пустой();
	
КонецФункции 

