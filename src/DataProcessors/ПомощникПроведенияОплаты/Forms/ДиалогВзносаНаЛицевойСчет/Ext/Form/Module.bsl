// Функция, рекурсивного поиска в дереве доступных видов оплаты.
//
Функция ПолучитьСтрокиСВнесеннойОплатойСервер(
	ТипДенСредств					= Неопределено,
	ЛицевойСчет						= Неопределено,								 
	ЭквайрингНомерПлатежнойКарты	= Неопределено,
	СертификатПартия				= Неопределено)
	
	МассивСтрок = Новый Массив;
	
	Для Каждого ЭлементВерхУр ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл	
		
		Если ЭлементВерхУр.Внесено > 0 Тогда
			
			Если ТипДенСредств <> Неопределено И ЭлементВерхУр.ТипДенежныхСредств <> ТипДенСредств
				ИЛИ ЛицевойСчет <> Неопределено И ЭлементВерхУр.ЛицевойСчет <> ЛицевойСчет
				ИЛИ ЭквайрингНомерПлатежнойКарты <> Неопределено И ЭлементВерхУр.ЭквайрингНомерПлатежнойКарты <> ЭквайрингНомерПлатежнойКарты
				ИЛИ СертификатПартия <> Неопределено И ЭлементВерхУр.СертификатПартия <> СертификатПартия Тогда
				
				Продолжить;
			КонецЕсли;
			
			МассивСтрок.Добавить(Новый Структура("ТипДенежныхСредств, Внесено", ЭлементВерхУр.ТипДенежныхСредств, ЭлементВерхУр.Внесено));
			
		КонецЕсли;
		
		Для Каждого ЭлементНизУр ИЗ ЭлементВерхУр.ПолучитьЭлементы() Цикл	
			
			Если ЭлементНизУр.Внесено > 0 Тогда
				
				Если ТипДенСредств <> Неопределено И ЭлементНизУр.ТипДенежныхСредств <> ТипДенСредств
					ИЛИ ЛицевойСчет <> Неопределено И ЭлементНизУр.ЛицевойСчет <> ЛицевойСчет
					ИЛИ ЭквайрингНомерПлатежнойКарты <> Неопределено И ЭлементНизУр.ЭквайрингНомерПлатежнойКарты <> ЭквайрингНомерПлатежнойКарты
					ИЛИ СертификатПартия <> Неопределено И ЭлементНизУр.СертификатПартия <> СертификатПартия Тогда
					
					Продолжить;
				КонецЕсли;
				
				МассивСтрок.Добавить(Новый Структура("ТипДенежныхСредств, Внесено", ЭлементВерхУр.ТипДенежныхСредств, ЭлементВерхУр.Внесено));
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат МассивСтрок;
	
КонецФункции

