// Процедура - Подбор места работы сотрудника дата приема при изменении.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ПодборМестаРаботыСотрудникаДатаПриемаУвольненияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ПодборМестаРаботыСотрудника.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если Элементы.ПодборМестаРаботыСотрудника.ТекущийЭлемент <> Неопределено Тогда
	   ИмяТекущегоЭлемент = ?(СтрНайти(Элементы.ПодборМестаРаботыСотрудника.ТекущийЭлемент.Имя, "ДатаПриема") <> 0, "ДатаПриема", "ДатаУвольнения"); 
	КонецЕсли;
	
	Если ТекущиеДанные.ДатаУвольнения <> Дата(1,1,1) И ТекущиеДанные.ДатаПриема <> Дата(1,1,1) 
		 И ТекущиеДанные.ДатаУвольнения <> Неопределено И ТекущиеДанные.ДатаПриема <> Неопределено Тогда 
		 
		 ДатаУвольненияУказанаВерно = ПроверкаДатыУвольнения(ТекущиеДанные.ДатаУвольнения, ТекущиеДанные.ДатаПриема);
		 Если ДатаУвольненияУказанаВерно = Ложь Тогда
			 ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата увольнения " + ТекущиеДанные.ДатаУвольнения + " должна быть больше даты приема " + ТекущиеДанные.ДатаПриема);
			 
			 Если ИмяТекущегоЭлемент <> Неопределено Тогда
				 ТекущиеДанные[ИмяТекущегоЭлемент] = Дата(1,1,1); 
			 Иначе 
				 ТекущиеДанные.ДатаПриема		= Дата(1,1,1);
				 ТекущиеДанные.ДатаУвольнения 	= Дата(1,1,1); 
			 КонецЕсли; 
			 
			 Возврат;
		 КонецЕсли;
	
	 КонецЕсли;
	
	СтрокиТЗ = ДоступныеСтруктурныеЕдиницы.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ТекущиеДанные.СтруктурнаяЕдиница));
	
	Если Не ЗначениеЗаполнено(СтрокиТЗ) И (ЗначениеЗаполнено(ТекущиеДанные.ДатаПриема) Или ЗначениеЗаполнено(ТекущиеДанные.ДатаУвольнения)) Тогда
		ТекущиеДанные.ДатаПриема 		= Дата(01,01,01);	
	    ТекущиеДанные.ДатаУвольнения 	= Дата(01,01,01);
	КонецЕсли;
	
	Для Каждого Строка Из СтрокиТЗ Цикл
		Строка.ДатаПриема 		= ТекущиеДанные.ДатаПриема;
		Строка.ДатаУвольнения 	= ТекущиеДанные.ДатаУвольнения; 
		Модифицированность = Истина;
	КонецЦикла;
			
КонецПроцедуры 

