// Процедура обработчик события "ПриИзменении" формы
//
Процедура КонтрагентПриИзменении(Элемент)		
	
	// Проверка существования страховых полисов и настройка элементов
	HTMLДокументОбследованиеБлокироватьСобытиеСформирован = Ложь;
	
    НастройкаФормыСервер("ШАПКА");
	ОбновитьSVGПодбор();
	// Обновить документ
	ОбновитьДокумент();
	ФлагВыгрузиКэш = Истина;
	// Напоминание о событиях
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда 		
		ПроверитьТекущиеНапоминанияПоПосещениямСтоматология(Объект.Контрагент);	
		Результат = ПроверитьНеобходимостьИнформированияПоДнюРожденияКонтрагента(Объект.Контрагент);
		Если Результат.Информировать = Истина Тогда
			ПоказатьПредупреждение(, Результат.СообщениеИнформирования, 15, "Информирование о дне рождения клиента");
		КонецЕсли;	
		
		ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Контрагент, Объект.СтруктурнаяЕдиница);
		УстановитьВидимостьКнопокПереходаВМессенджер(ЭтотОбъект);
		
		Если ЗначениеЗаполнено(Объект.Промокод) Тогда
			
			ДанныеПромокода = ПолучитьДанныеПромокода(Объект.Промокод, Объект.Контрагент);
			Если Не ДанныеПромокода.ПромокодСуществует Тогда
				
				УдалитьПромокод();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Промокод был удален по причине: "
																  + Символы.ПС + Символы.Таб
																  + ДанныеПромокода.ТекстОшибки); 
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе                
		
		Если ЗначениеЗаполнено(Объект.Промокод) Тогда
			
			УдалитьПромокод();
			
		КонецЕсли;
		
		УстановитьВидимостьКнопокПереходаВМессенджер(ЭтотОбъект,Истина);
	КонецЕсли;	
	
КонецПроцедуры

