// Процедура - Таблица услуги номенклатура начало выбора завершение.
//
Процедура ТаблицаУслугиНоменклатураНачалоВыбораЗавершение(Значение, Параметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Значение) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		ПодборДанные = Значение;
		Значение = ПодборДанные.Номенклатура;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Возникла ошибка при подборе!");
		Возврат;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Объект.ПолисМедСтрахования) И ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса) Тогда
	
		// ПроверкаУслугНаСогласованностьПоПолису(Неопределено, ПодборДанные, Неопределено, Новый Структура("ПроцедураПерехода, ПараметрыПерехода", "ВыборЧерезФорму", Значение));
		ПроверкаНаОграничениеПоДоговору_НоменклатураНачалоВыбораЗавершение(ПодборДанные);	
		
	Иначе	
		ТаблицаУслугиНоменклатураНачалоВыбораЗавершение_ДобавлениеПослеСогласования(Значение);
	КонецЕсли;

