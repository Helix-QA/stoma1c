// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ОбновитьТаблицуСотрудников()
		
	Если (ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач)
		и ПЗОтборПоСотрудникамРежимФильтра = 0 Тогда
		ДеревоСотрудниковРучн.ПолучитьЭлементы().Очистить();
