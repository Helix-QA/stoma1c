// Процедура - обрабатывает выбор структурной единицы.
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ОбработатьВыборСтруктурнойЕдиницы(Результат) 
	
	Если Результат <> Неопределено Тогда
		
		ТекущаяСтруктурнаяЕдиница	= Результат.Значение;
		ОтборСтруктурнаяЕдиница		= Результат.Значение; 
		
		Если СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(ОтборСтруктурнаяЕдиница) = Неопределено Тогда
			МассивСтрокНормСписания = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница));
			Если МассивСтрокНормСписания.Количество() = 0 Тогда
				ДополнитьТаблицуНормСписанияМатериалов(ОтборСтруктурнаяЕдиница, ТаблицаНормыСписанияМатериалов);
			КонецЕсли; 			
		КонецЕсли;
		
		ВывестиЭлементыНормыСписанияМатериалов(ОтборСтруктурнаяЕдиница);   		   		
		УстановитьВидимость();	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет завершение выбора номенклатуры. 
//
Процедура НоменклатураНачалоВыбораЗавершение(ДанныеВыбора, Параметры) Экспорт
	
	Если ЗначениеЗаполнено(ДанныеВыбора) Тогда
		
		ТекущиеДанные  = Параметры.ТекущиеДанные;
		ЭтоГруппа      = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДанныеВыбора.Номенклатура, "ЭтоГруппа");
		
		Если ЭтоГруппа = Истина Тогда
			
			ДанныеВыбора = Неопределено;
			ТекущиеДанные.Материал = Неопределено;
			СообщениеПользователю = "Необходимо выбрать элемент, а не группу.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеПользователю, ЭтотОбъект, "ТекущиеДанные.Материал", "Объект"); 
			
			Возврат;
		КонецЕсли;
		
		ТекущиеДанные.Материал                   = ДанныеВыбора.Номенклатура;
		ТекущиеДанные.Партия                     = ПредопределенноеЗначение("Справочник.ПартииНоменклатуры.ПустаяСсылка");
		ТекущиеДанные.ХарактеристикиИспользуются = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ДанныеВыбора.Номенклатура, "ИспользоватьПартии");
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Скопировать нормы завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура СкопироватьНормыЗавершение(СтруктурнаяЕдиницаКопирования, Параметры) Экспорт
	
	Если СтруктурнаяЕдиницаКопирования <> Неопределено Тогда
		
		СтруктурнаяЕдиницаДляДобавления = Параметры.СтруктурнаяЕдиница;		
		НормыСписанияПоСтруктурнаяЕдиницаДляДобавления = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиницаКопирования));
		
		Для Каждого СтрокаТЧ Из НормыСписанияПоСтруктурнаяЕдиницаДляДобавления Цикл
			
			НоваяСтрока = ТаблицаНормыСписанияМатериалов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			НоваяСтрока.НомерСтроки		   = ТаблицаНормыСписанияМатериалов.Индекс(НоваяСтрока);
			НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиницаДляДобавления;
			
			Если НоваяСтрока.СписыватьМатериал = 1 Тогда 
				НоваяСтрока.СкладСписания = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиницаДляДобавления, "ОсновнойСклад");
			КонецЕсли;
			
		КонецЦикла;
		
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте    
// Процедура - дополняет таблицу норм списания материалов
//
Процедура ДополнитьТаблицуНормСписанияМатериалов(СтруктурнаяЕдиница, ТаблицаНормыСписанияМатериалов)
	
	МассивСтрокОбщихНормСписания = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка")));
	Для Каждого СтрокаМ Из МассивСтрокОбщихНормСписания Цикл
		НоваяСтрока = ТаблицаНормыСписанияМатериалов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаМ, , "СтруктурнаяЕдиница, СкладСписания");
		НоваяСтрока.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
		НоваяСтрока.СкладСписания      = ?(НоваяСтрока.СписыватьМатериал = 1, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктурнаяЕдиница, "ОсновнойСклад"), ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка"));
	КонецЦикла;             	
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчки комнады - "ЗадатьОбщиеНормыСписанияДляСтруктурнойЕдиницы"
//
Процедура ЗадатьОбщиеНормыСписанияДляСтруктурнойЕдиницы(Команда)
	
	Если ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка"))).Количество() = 0 Тогда
		ТекстВопроса = "Внимание! Общие нормы списания не заданы. Нормы списания " + ТекущаяСтруктурнаяЕдиница + " будут очищены. Продолжить?";
	Иначе
		ТекстВопроса = "Установить общие нормы списания для " + ТекущаяСтруктурнаяЕдиница + "?";
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ЗадатьОбщиеНормыСписанияДляСтруктурнойЕдиницыЗавершение", ЭтотОбъект, Новый Структура("СтруктурнаяЕдиница", ТекущаяСтруктурнаяЕдиница));
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
	
КонецПроцедуры

&НаКлиенте
// Процедура - "ЗадатьОбщиеНормыСписанияДляСтруктурнойЕдиницыЗавершение"
//
Процедура ЗадатьОбщиеНормыСписанияДляСтруктурнойЕдиницыЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		СтруктурнаяЕдиницаВременная = ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка");
		Параметры.Свойство("СтруктурнаяЕдиница", СтруктурнаяЕдиницаВременная);
		Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиницаВременная) Тогда
			СтруктурнаяЕдиницаВременная = ТекущаяСтруктурнаяЕдиница;
		КонецЕсли;
		
		Модифицированность = Истина;
		
		Если СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(СтруктурнаяЕдиницаВременная) <> Неопределено Тогда
			СписокСтруктурныхЕдиницБезНормСписания.Удалить(СписокСтруктурныхЕдиницБезНормСписания.НайтиПоЗначению(СтруктурнаяЕдиницаВременная));
		КонецЕсли;
		
		МассивСтрокНормСписания = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиницаВременная));
		Для Каждого ЭлементМ Из МассивСтрокНормСписания Цикл
			ТаблицаНормыСписанияМатериалов.Удалить(ЭлементМ);			
		КонецЦикла;
		
		ДополнитьТаблицуНормСписанияМатериалов(СтруктурнаяЕдиницаВременная, ТаблицаНормыСписанияМатериалов);
		
		ОбновитьБлокИндивидуальныхНормСписания(); 
		УстановитьВидимость();

	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды "выбрать структурную единицу".
//
Процедура ВыбратьСтруктурнуюЕдиницу(Команда)
	
	Если Лев(Команда.Имя, 13) = "_ВыборКлиники" Тогда
		
		Идентификатор = Число(Сред(Команда.Имя, 14, СтрДлина(Команда.Имя)));
		
		ВыбраныйЭлементСписка = СписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм.НайтиПоИдентификатору(Идентификатор);		
		Если ВыбраныйЭлементСписка <> Неопределено Тогда
			Элементы.ГруппаВсплывающаяИндивидуальныеНормыСписания.Заголовок = ВыбраныйЭлементСписка;
			ОбработатьВыборСтруктурнойЕдиницы(ВыбраныйЭлементСписка);
			
			ОбновитьБлокИндивидуальныхНормСписания();
			ЭтаФорма.ТекущийЭлемент = Элементы.Найти("ДекорацияСменаФокуса");
		КонецЕсли;
		 		
	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик команды "ОткрытьВысплывающуюГруппуИндивидуальныхНормСписания".
//
Процедура ОткрытьВысплывающуюГруппуИндивидуальныхНормСписания(Команда)
	
	СформироватьБлокИндивидуальныхНормСписания();
	Элементы.ГруппаВсплывающаяИндивидуальныеНормыСписания.Показать();
	
КонецПроцедуры

&НаКлиенте
// Процедура - устанавливает видимость элементов.
//
Процедура УстановитьВидимость()
	
	Элементы.ГруппаВсплывающаяИндивидуальныеНормыСписания.Видимость	= Не ОбщиеНормыСписания;
	
	Элементы.ЗадатьОбщиеНормыСписанияДляСтруктурнойЕдиницы.Видимость = Не ОбщиеНормыСписания 
	И ЗаданыИндивидуальныеНормыСписания(ТекущаяСтруктурнаяЕдиница, ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка"))));
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПроверкаНормСписанияПередЗаписьюНоменклатуры" Тогда
		
		РезультатПроверки = ПроверкаНормСписанияПередЗаписьюНоменклатуры();
		Если РезультатПроверки = Ложь Тогда
			
			Оповестить("ОтрицательныйРезультатПроверкиНормСписанияПередЗаписьюНоменклатуры");
		Иначе 
			
			ПередЗакрытиемНеЗадаватьВопрос = Истина;
			ВопросЗадан = Истина;
			ВыполнитьОбработкуОповещения(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект), КодВозвратаДиалога.Да);
			
		КонецЕсли;

	КонецЕсли;	
	
КонецПроцедуры    

// Функция - проверяет нормы списания материалов перед записью номенклатуры.
// 
&НаКлиенте
Функция ПроверкаНормСписанияПередЗаписьюНоменклатуры()
	
	ТаблицаНормыСписанияМатериалов.Сортировать("СтруктурнаяЕдиница");

	Для Каждого СтрокаТЧ Из ТаблицаНормыСписанияМатериалов Цикл
						
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Материал) Тогда
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
				ПоказатьПредупреждение(, "Необходимо заполнить материал по клинике " + СтрокаТЧ.СтруктурнаяЕдиница);
			Иначе
				ПоказатьПредупреждение(, "Необходимо заполнить материал общих норм списания");
			КонецЕсли;
			Возврат Ложь;
			
		ИначеЕсли СтрокаТЧ.СписыватьМатериал = 1 
			И Не ЗначениеЗаполнено(СтрокаТЧ.СкладСписания) 
			И ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
			
			ПоказатьПредупреждение(, "Необходимо заполнить склад списания по клинике " + СтрокаТЧ.СтруктурнаяЕдиница + " по материалу " + СтрокаТЧ.Материал);
			Возврат Ложь;
			
		ИначеЕсли СтрокаТЧ.Количество = 0 Тогда
			
			Если ЗначениеЗаполнено(СтрокаТЧ.СтруктурнаяЕдиница) Тогда
				ПоказатьПредупреждение(, "Количество материалов списания должно быть больше 0 по клинике " + СтрокаТЧ.СтруктурнаяЕдиница + " по материалу " + СтрокаТЧ.Материал);
			Иначе
				ПоказатьПредупреждение(, "Количество материалов списания должно быть больше 0 для общих норм списания по материалу " + СтрокаТЧ.Материал);
			КонецЕсли;
			
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик команды "СкопироватьНормыСписанияНоменклатуры".
//
Процедура СкопироватьНормыСписанияМатериалов(Команда)
	
	ПараметрыФормы 						= Новый Структура("Отбор, ВыборГруппИЭлементов, Заголовок");
	ПараметрыФормы.Отбор                = Новый Структура("ТипНоменклатуры, ПометкаУдаления, ЭтоГруппа", ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"), Ложь, Ложь);
	ПараметрыФормы.ВыборГруппИЭлементов = ИспользованиеГруппИЭлементов.Элементы;
	ПараметрыФормы.Заголовок 			= "Выберите услугу для копирования";
		
	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора", ПараметрыФормы,,,,, Новый ОписаниеОповещения("ВыборУслугиЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);			
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения.
//
Процедура ВыборУслугиЗавершение(УслугаКопирования, ДопПараметры) Экспорт
	
	ПараметрыОткрытия = Новый Структура("УслугаКопирования", УслугаКопирования);	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросОЗамещенииНормСписания", ЭтотОбъект, ПараметрыОткрытия);
	ШрифтВыделения = Новый Шрифт(,, 12);
	ТекстВопроса = Новый ФорматированнаяСтрока("Текущие нормы списания будут заменены на нормы списания услуги ",  Новый ФорматированнаяСтрока(Строка(УслугаКопирования), ШрифтВыделения));
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , , "Вопрос пользователю");	
	
КонецПроцедуры

&НаКлиенте
// Процедура Вопрос о замещении калькуляций.
//
Процедура ВопросОЗамещенииНормСписания(Ответ, Параметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
				
		УслугаКопирования = Параметры.УслугаКопирования;
		Если ЗначениеЗаполнено(УслугаКопирования) Тогда
			
			ПриСозданииПриКопированииНаСервере(УслугаКопирования);
			СохранениеМатериалов(УслугаКопирования);
			
		КонецЕсли;
		Модифицированность = Истина;        		
		УстановитьВидимость(); 
		
	КонецЕсли; 
	
КонецПроцедуры

#Область ПодборНоменклатур

&НаКлиенте
// Процедура Скрыть/Показать подбор.
//
Процедура СкрытьПодбор(Команда)
	
	СкрытьПодборНаСервере(); 
	
	Если Элементы.ГруппаВыбораНоменклатура.Видимость Тогда
		Элементы._ПодборНоменклатур.Обновить();           
	КонецЕсли;
	
	Элементы.ТаблицаНормыСписанияМатериалов.МаксимальнаяШирина = ?(Элементы.ГруппаВыбораНоменклатура.Видимость, 125, 0);
	
КонецПроцедуры

&НаСервере
// Процедура Скрыть/Показать подбор на сервере.
//
Процедура СкрытьПодборНаСервере()
	
	Элементы.ГруппаВыбораНоменклатура.Видимость = НЕ Элементы.ГруппаВыбораНоменклатура.Видимость;
	Элементы.ЗапасыСкрытьПодбор.Пометка 	    = Элементы.ГруппаВыбораНоменклатура.Видимость;
	
КонецПроцедуры

&НаСервере
// Процедура При за =грузке данных из настроек на сервере.
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	НастройкиЗагружены = Истина;
	
	// выбор номенклатуры
	Если ТаблицаВыбранныхЗначенийИспользовать = Ложь Тогда
		
		ЭтотОбъект.ОтображатьДеревом = Настройки.Получить("ОтображатьДеревом");
		Отображение                  = ?(ОтображатьДеревом, ОтображениеТаблицы.ИерархическийСписок, ОтображениеТаблицы.Список);
		ЗаголовокВидОтображения      = ?(ОтображатьДеревом, "Список", "Дерево");
		
		СоздатьДинамическийСписокПодбораНоменклатур("ГруппаВыбораНоменклатура", Отображение,, Истина, ЗаголовокВидОтображения);
		
	Иначе
		// выбор материалов или выбор состава услуг пакета
		ЭтотОбъект.ВидЦенМатериалов = ?(НЕ ЗначениеЗаполнено(ВидЦенМатериалов), Справочники.ВидыЦен.Закупочная, ВидЦенМатериалов);	
		ЗаполнитьЗначенияПриВыбореМатериалов();
	КонецЕсли;

КонецПроцедуры

// Процедура - Вид отображения
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ВидОтображения(Команда)
	
	ОтображатьДеревом = НЕ ОтображатьДеревом;
	КнопкаВидОтображения = Элементы._ПодборНоменклатур.КоманднаяПанель.ПодчиненныеЭлементы.Найти("ВидОтображения");
	Если КнопкаВидОтображения <> Неопределено Тогда
		КнопкаВидОтображения.Картинка  = ?(ОтображатьДеревом, БиблиотекаКартинок.РежимПросмотраСпискаСписок, БиблиотекаКартинок.РежимПросмотраСпискаДерево);
		КнопкаВидОтображения.Заголовок = ?(ОтображатьДеревом, "Список", "Дерево");
	КонецЕсли;
	Элементы._ПодборНоменклатур.Отображение = ?(ОтображатьДеревом, ОтображениеТаблицы.ИерархическийСписок, ОтображениеТаблицы.Список);
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик создания динамического списка подбора номенклатур.
//
Процедура СоздатьДинамическийСписокПодбораНоменклатур(ИмяЭлементаДляРазмещения, Отображение = Неопределено, ПодборМатериалов = Ложь, ЭтоФормаВыбора = Ложь, ЗаголовокВидОтображения = Неопределено)
	
	ОбработкаТабличныхЧастейКлиент.СоздатьДинамическийСписокПодбораНоменклатур
	(ЭтаФорма,
