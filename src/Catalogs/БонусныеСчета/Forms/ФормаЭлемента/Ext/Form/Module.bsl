
#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик создания формы на сервере
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если  ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;

	Если Объект.Ссылка.Пустая() Тогда 
		Элементы.ГруппаВыравнивание.ТолькоПросмотр = Ложь;
		Если НЕ ЗначениеЗаполнено(Объект.ВладелецБонусногоСчета) Тогда 
			Если Объект.Именной Тогда 
				Объект.ВладелецБонусногоСчета = Справочники.Контрагенты.ПустаяСсылка();
			Иначе 
				Объект.ВладелецБонусногоСчета = Справочники.Карты.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ДекорацияСрокДействияНеОграничен = НСтр("ru='Не ограничен';en='Not limited'");
	
	//// Создаем элемент существующих строк состава услуг
	// СоздатьЭлементыФормыСоставПакетаУслуг();
	
	ПостроитьТаблицуИсторииОбъекта2();
	
	УстановитьВидимостьЭлементов();
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость элементов формы.
//
// Параметры:
//  Нет.
//
Процедура УстановитьЗаголовокЭлементов()
	
	// Элементы.ГруппаШапка.Заголовок = Объект.Наименование;
	
	// -----------------------Настройка заголовка процента списания-----------------------
	ЗаголовокЭлемента = "";
	Если Объект.НеОграниченПроцентомСписания Тогда		
		ЗаголовокЭлемента = ЗаголовокЭлемента + НСтр("ru= 'Списание с бонусного счета не ограничено';en ='Withdrawal from a bonus account is not limited'");
	Иначе		
		ЗаголовокЭлемента = ?(Объект.ОграничениеСписанияПроцент = 0,
								ЗаголовокЭлемента + НСтр("ru= 'Списание с бонусного счета не ограничено';en ='Withdrawal from a bonus account is not limited'"),
								ЗаголовокЭлемента + НСтр("ru= 'Списание с бонусного счета ограничено ';en ='Withdrawal from a bonus account is limited '") + Строка(Объект.ОграничениеСписанияПроцент) + " %");		
	КонецЕсли;	
	Элементы.ГруппаОграничениеСписания.Заголовок = ЗаголовокЭлемента;
	
	// --------------------Настройка заголовка состава услуг вида ЛС---------------------
	ЗаголовокЭлемента = "";
	Если Объект.Предопределенный Тогда 
		ЗаголовокЭлемента = НСтр("ru= 'Не ограничен услугами';en ='Not limited to services'");
	КонецЕсли;

	// ------------------Настройка заголовка срок действия БС------------------
	
	ЗаголовокЭлемента = "";	
	Если Объект.СрокДействияНачало = Дата(1,1,1) И Объект.СрокДействияКонец = Дата(1,1,1) Тогда
		ЗаголовокЭлемента = ЗаголовокЭлемента + НСтр("ru= 'Срок действия бонусного счета не ограничен';en ='Validity of the bonus account is not limited'");
	Иначе 
		ЗаголовокЭлемента = ЗаголовокЭлемента + СтрШаблон(НСтр("ru = 'Бонусный счет действует с %1 по %2 ';en= 'Bonus account is valid from %1 to %2 '"), 
		                                                  Формат(Объект.СрокДействияНачало, СтрШаблон("ДФ=dd.MM.yyyy; ДП='%1'", НСтр("ru='(не заполнено)'; en='(not completed)'"))), 
		                                                  Формат(Объект.СрокДействияКонец, СтрШаблон("ДФ=dd.MM.yyyy; ДП='%1'", НСтр("ru='(не заполнено)'; en='(not completed)'"))));
	КонецЕсли;
													  
	Элементы.Группа_СрокДействияВидаБонусногоСчета.Заголовок = ЗаголовокЭлемента;

	ЗаголовокЭлемента = "";
	Если Объект.Закрыт Тогда 
		ЗаголовокЭлемента = ЗаголовокЭлемента + НСтр("ru= 'Срок действия бонусного счета истек. Счет деактивирован.';en ='The bonus account has expired. Account deactivated.'");
		Элементы.Группа_СрокДействияВидаБонусногоСчета.ЦветТекстаЗаголовка = Новый Цвет(255,0,0);
		Элементы.Группа_СрокДействияВидаБонусногоСчета.Заголовок = ЗаголовокЭлемента;	
	КонецЕсли;	
	
	// ------------------Настройка заголовка срок действия начислений вида БС------------------
	ЗаголовокЭлемента = "";
	Если Объект.ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный Тогда
		ЗаголовокЭлемента = ЗаголовокЭлемента + НСтр("ru= 'Срок действия начислений не ограничен';en ='The term of the accruals is unlimited'");
	ИначеЕсли Объект.ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокОграниченПериодом Тогда
		ЗаголовокЭлемента = ЗаголовокЭлемента + НСтр("ru= 'Срок действия начислений - ';en ='Duration of accruals - '") + Объект.СрокДействияНачислений + " " + ВернутьСловоСклоненноеПоЧислу(Строка(Объект.СрокДействияНачисленийТип), Объект.СрокДействияНачислений);
	КонецЕсли;
	Элементы.ГруппаСрокДействияНачислений_ВертикальнаяЧерта.Заголовок = ЗаголовокЭлемента;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость элементов формы.
//
// Параметры:
//  Нет.
//
Процедура УстановитьВидимостьЭлементов()
	
	Если Объект.ВидБонусногоСчета.Именной = Истина Тогда
		
		Элементы.ДекорацияТипВладельца.Картинка  = БиблиотекаКартинок.ПерейтиКПользователю;
		Элементы.ДекорацияТипВладельца.Подсказка = НСтр("ru= 'Именной счет';en ='Personal account'");
		
	Иначе 
		
		Элементы.ДекорацияТипВладельца.Картинка  = БиблиотекаКартинок.ПластиковаяКартаОбновление;
		Элементы.ДекорацияТипВладельца.Подсказка = НСтр("ru= 'На предъявителя';en ='Bearer'");

	КонецЕсли;
	
	Если Объект.НеОграниченПроцентомСписания Тогда		
		Элементы.ОграничениеСписанияПроцент.Видимость 	= Ложь;
		Элементы.ДекорацияПроцент.Видимость 			= Ложь;		
	Иначе		
		Элементы.ОграничениеСписанияПроцент.Видимость 	= Истина;
		Элементы.ДекорацияПроцент.Видимость 			= Истина;		
	КонецЕсли;	
	
	// Бессрочный
	Если Объект.ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.Бессрочный  Тогда 
		
		Элементы.ГруппаПараметрыСрокаДействияНачислений.Видимость = Ложь;
		
	// Срок ограничен периодом	
	ИначеЕсли Объект.ОграничениеНачисленийПоСрокуДействия = Перечисления.ТипыОграниченийСрокаДействия.СрокОграниченПериодом Тогда
		
		Элементы.ГруппаПараметрыСрокаДействияНачислений.Видимость = Истина;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.СрокДействияНачало)
		ИЛИ ЗначениеЗаполнено(Объект.СрокДействияКонец) Тогда
		
		Элементы.СрокДействияНачало.Видимость = Истина;
		Элементы.СрокДействияКонец.Видимость  = Истина;
		Элементы.ДекорацияСрокДействияНеОграничен.Видимость = Ложь;
		
	Иначе
		
		Элементы.СрокДействияНачало.Видимость = Ложь;
		Элементы.СрокДействияКонец.Видимость  = Ложь;
		Элементы.ДекорацияСрокДействияНеОграничен.Видимость = Истина;

	КонецЕсли;

	УстановитьЗаголовокЭлементов();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура УстановитьЗаголовокЭлементовПриИзменении(Элемент)
	
	Модифицированность = Истина;
	
	УстановитьЗаголовокЭлементов();	
	
КонецПроцедуры

#КонецОбласти

#Область ОБРАБОТЧИКИ_СОБЫТИЙ_ЭЛЕМЕНТОВ_ФОРМЫ

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поля "Код".
//
Процедура КодПриИзменении(Элемент)
	Объект.Наименование = СформироватьНаименование(Объект.Код, Объект.ВидБонусногоСчета, Объект.ВладелецБонусногоСчета);
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ВидБонусногоСчетаПриИзменении".
//
Процедура ВидБонусногоСчетаПриИзменении(Элемент)
	
	ЗаполнитьНастройкиБСПоВидуБС();
	ЗаполнитьСрокДействияБСНаСеревере(Объект.ВидБонусногоСчета, Объект.ДатаОткрытия, Объект.СрокДействияНачало, Объект.СрокДействияКонец);	
	
	Объект.Наименование = СформироватьНаименование(Объект.Код, Объект.ВидБонусногоСчета, Объект.ВладелецБонусногоСчета);	
	
	ПерезаполнитьТаблицуСоставУслуг();
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ДатаОткрытияПриИзменении".
//
Процедура ДатаОткрытияПриИзменении(Элемент)

	ЗаполнитьСрокДействияБСНаСеревере(Объект.ВидБонусногоСчета, Объект.ДатаОткрытия, Объект.СрокДействияНачало, Объект.СрокДействияКонец);	
	УстановитьЗаголовокЭлементовПриИзменении(Элемент);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ВладелецПриИзменении".
//
Процедура ВладелецПриИзменении(Элемент)
	
	Объект.Наименование = СформироватьНаименование(Объект.Код, Объект.ВидБонусногоСчета, Объект.ВладелецБонусногоСчета);	
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ВладелецНачалоВыбора".
//
Процедура ВладелецНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;

	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершениеВыбораВладельца", ЭтаФорма, Элемент);
	ФормаВыбора = ?(ТипЗнч(Объект.ВладелецБонусногоСчета) = Тип("СправочникСсылка.Контрагенты"), "Справочник.Контрагенты.ФормаВыбора", "Справочник.Карты.ФормаВыбора"); 
	ОткрытьФорму(ФормаВыбора, ,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ЗавершениеВыбораВладельца" подключаемый.
//
Процедура ЗавершениеВыбораВладельца(Результат, Параметры) Экспорт 
	
	Если ЗначениеЗаполнено(Результат) Тогда 
		Если НЕ Объект.ВладелецБонусногоСчета = Результат Тогда 
			Объект.ВладелецБонусногоСчета = Результат;
		КонецЕсли;
	КонецЕсли;
	
	ВладелецПриИзменении(Неопределено);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ОграничениеПоСрокуДействияПриИзменении(Элемент)
	
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура СрокДествияПриИзменении(Элемент)
	
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

#КонецОбласти

#Область ОБРАБОТЧИКИ_КОМАНД_ФОРМы

// Процедура - Скрыть показать дополнительно
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура СкрытьПоказатьДополнительно(Команда)
	Элементы.ГруппаДополнительно.Видимость =  НЕ Элементы.ГруппаДополнительно.Видимость;
КонецПроцедуры

#КонецОбласти

#Область ИсторияОбъекта

&НаСервере
// Процедура - Построить таблицу истории объекта
//
Процедура ПостроитьТаблицуИсторииОбъекта()
	
	РезультатЗапроса    = Справочники.БонусныеСчета.ИсторияБонусногоСчета(Объект.Ссылка);				
	
	РезЗапросаВерхнийУр = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ОстатокПоБс         = РегистрыНакопления.БонусныеСчета.ПолучитьОстатокНаБонусномСчетеВладельца(Объект.Ссылка);	
	
	Декорация                          = Элементы.Добавить("ДекорацияИсторияЗаголовокПериод", Тип("ДекорацияФормы"),  Элементы.ГруппаКнопки);
	Декорация.Заголовок                = НСтр("ru= 'Остаток';en ='Balance'");
	Декорация.Шрифт                    = Новый Шрифт(Декорация.Шрифт,,11);
	Декорация.ЦветТекста               = Новый Цвет(0,150,70);
	Декорация.АвтоМаксимальнаяШирина   = Ложь;
	Декорация.МаксимальнаяШирина       = 43;
	Декорация.РастягиватьПоГоризонтали = Истина;
	
	Декорация                           = Элементы.Вставить("ДекорацияИсторияЗаголовокСумма", Тип("ДекорацияФормы"),  Элементы.ГруппаСуммы);
	Декорация.Заголовок                 = Формат(ОстатокПоБс, "ЧЦ=15; ЧДЦ=2; ЧН=0,00");
	Декорация.Шрифт                     = Новый Шрифт(Декорация.Шрифт,,11);
	Декорация.ЦветТекста                = Новый Цвет(0,150,70);
	Декорация.Ширина                    = 8;
	Декорация.ГоризонтальноеПоложение   = ГоризонтальноеПоложениеЭлемента.Право;
	
	ИндексВерхУр = 0;
	Пока РезЗапросаВерхнийУр.Следующий() Цикл
			
		Декорация                          = Элементы.Вставить("ДекорацияИсторияДокНачисления_" + Формат(ИндексВерхУр, "ЧГ="), Тип("ДекорацияФормы"), Элементы.ГруппаКнопки);
		Декорация.Заголовок                = НаименованиеВерхнегоУзлаИстории(РезЗапросаВерхнийУр);
		Декорация.АвтоМаксимальнаяШирина   = Ложь;
		Декорация.МаксимальнаяШирина       = 25;
	
		Декорация                           = Элементы.Вставить("ДекорацияИсторияДокНачисленияСумма_" + Формат(ИндексВерхУр, "ЧГ="), Тип("ДекорацияФормы"), Элементы.ГруппаСуммы);
		Декорация.Заголовок                 = Формат(РезЗапросаВерхнийУр.Сумма, "ЧЦ=15; ЧДЦ=2; ЧН=0,00");
		Декорация.Ширина                    = 8;
		Декорация.ГоризонтальноеПоложение   = ГоризонтальноеПоложениеЭлемента.Право;
	
		РезЗапросаНижнийУр = РезЗапросаВерхнийУр.Выбрать();
		
		ИндексНижнУровня = 0;
		
		Пока РезЗапросаНижнийУр.Следующий() Цикл	
					
			СтрокаТ = ЭтотОбъект.ТаблицаИсторииОбъекта.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТ, РезЗапросаНижнийУр);

			ИдЭлементов = СтрЗаменить(Строка(СтрокаТ.ПолучитьИдентификатор()), Символы.НПП, "");
			
			ПодгруппаГруппаКнопки = Элементы.Добавить("ПодгруппаГруппаКнопки_" + ИдЭлементов, Тип("ГруппаФормы"),Элементы.ГруппаКнопки);
			ПодгруппаГруппаКнопки.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ПодгруппаГруппаКнопки.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ПодгруппаГруппаКнопки.ОтображатьЗаголовок = Ложь;
			
			Декорация                          = Элементы.Вставить("ДекорацияИсторияСмещение_" + ИдЭлементов, Тип("ДекорацияФормы"), ПодгруппаГруппаКнопки);
			Декорация.Заголовок                = " ";
			Декорация.Ширина                   = 2;
						
			КомандаФормы          = ЭтаФорма.Команды.Добавить("КнопкаИсторияПериод_" + ИдЭлементов);
			КомандаФормы.Действие = "ОбработчикНажатияПоОперацииИстории";
			
			Кнопка                   = Элементы.Добавить("КнопкаИсторияПериод_" + ИдЭлементов, Тип("КнопкаФормы"),ПодгруппаГруппаКнопки);	
			Кнопка.Заголовок         = НаименованиеНижнегоУзлаИстории(РезЗапросаНижнийУр);
			Кнопка.ИмяКоманды        = КомандаФормы.Имя;	
			Кнопка.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет; 
			
