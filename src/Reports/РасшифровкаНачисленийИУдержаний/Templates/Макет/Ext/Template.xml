		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НачислениеЗарплатыЗатраты.Ссылка КАК Документ,
	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	НАЧАЛОПЕРИОДА(МАКСИМУМ(НачислениеЗарплатыЗатраты.Дата), ДЕНЬ) КАК Дата,
	НачислениеЗарплатыЗатраты.ВидНачисления,
	НачислениеЗарплатыЗатраты.Сотрудник КАК Сотрудник,
	НачислениеЗарплатыЗатраты.Номенклатура,
	МАКСИМУМ(НачислениеЗарплатыЗатраты.План) КАК План,
	СУММА(НачислениеЗарплатыЗатраты.Факт) КАК Факт,
	НачислениеЗарплатыЗатраты.База,
	НачислениеЗарплатыЗатраты.Размер,
	СУММА(НачислениеЗарплатыЗатраты.Сумма) КАК Сумма,
	НачислениеЗарплатыЗатраты.Ссылка.Дата КАК ДатаДокумента,
	НачислениеЗарплатыЗатраты.Документ КАК ДокументПродажи
ИЗ
	Документ.НачислениеЗарплаты.Затраты КАК НачислениеЗарплатыЗатраты
ГДЕ
	НачислениеЗарплатыЗатраты.Ссылка.Проведен = ИСТИНА
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;ДатаНачалаПериода ЕСТЬ NULL 
					И &amp;ДатаНачалаПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА НачислениеЗарплатыЗатраты.Ссылка.ДатаНачалаПериода &gt;= &amp;ДатаНачалаПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;ДатаОкончанияПериода ЕСТЬ NULL 
					И &amp;ДатаОкончанияПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА НачислениеЗарплатыЗатраты.Ссылка.ДатаОкончанияПериода &lt;= &amp;ДатаОкончанияПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}

СГРУППИРОВАТЬ ПО
	НачислениеЗарплатыЗатраты.Ссылка,
	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница,
	НачислениеЗарплатыЗатраты.ВидНачисления,
	НачислениеЗарплатыЗатраты.Сотрудник,
	НачислениеЗарплатыЗатраты.Номенклатура,
	НачислениеЗарплатыЗатраты.База,
	НачислениеЗарплатыЗатраты.Размер,
	НачислениеЗарплатыЗатраты.Ссылка.Дата,
	НачислениеЗарплатыЗатраты.Документ

УПОРЯДОЧИТЬ ПО
	Сотрудник</query>
