	КонецЕсли;
	// Восстановление строк представления материалов
	ПроставитьПредстваленияМатериалов();	
	// Обновить значение суммы документа 
	Объект.СуммаДокумента      = Объект.Лечение.Итог("Всего") + Объект.Запасы.Итог("Всего");
	РассчитатьСуммуСкидки();
