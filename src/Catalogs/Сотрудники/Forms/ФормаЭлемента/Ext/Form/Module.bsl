// Процедура - Изменяет доступ пользователя к ИБ 
//
Процедура ИзменитьДоступПользователя()
	
	Если НЕ Объект.ЭтоПользовательИБ И Объект.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;
	
	ЭтаФорма.Прочитать(); 
	Объект.ЭтоПользовательИБ = ДоступКИБ;
	ЭтаФорма.Записать(); 

	ПользовательОбъект = ПользовательИБ.ПолучитьОбъект();
	ПользовательОбъект.ЭтоПользовательИБ = ДоступКИБ;
	ПользовательОбъект.Записать();
	
	НачатьТранзакцию();
	Попытка      
		// 289687 Пользователь с полными правами(роль Директор) не может 
		// изменить доступность пользователя. 		
		Если РольДоступна("ПолныеПрава") Тогда
			УстановитьПривилегированныйРежим(Истина);
		КонецЕсли;
		ПользовательИнформационнойБазы = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ПользовательОбъект.ИдентификаторПользователяИБ);
		Если ПользовательИнформационнойБазы <> Неопределено Тогда
			ПользовательИнформационнойБазы.АутентификацияСтандартная = ДоступКИБ;	
			ПользовательИнформационнойБазы.Записать();                              
		КонецЕсли;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
	СформироватьДинамическиеЭлементыНастроек(Ложь);

КонецПроцедуры

