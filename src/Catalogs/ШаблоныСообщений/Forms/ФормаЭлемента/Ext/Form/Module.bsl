	Если Найти(ПисьмоТекстHTML, "<body contentEditable") = 0 И Найти(ПисьмоТекстHTML, "<BODY contentEditable") = 0 Тогда
		
		Если Найти(ПисьмоТекстHTML, "<body") <> 0 Или Найти(ПисьмоТекстHTML, "<BODY") <> 0 Тогда
			ПисьмоТекстHTML = СтрЗаменить(ПисьмоТекстHTML, "<body", "<body contentEditable=true");
			ПисьмоТекстHTML = СтрЗаменить(ПисьмоТекстHTML, "<BODY", "<BODY contentEditable=true");
		Иначе	
			ПисьмоТекстHTML = СтрЗаменить(ПисьмоТекстHTML, "<html>", "<html><body contentEditable=true>");
			ПисьмоТекстHTML = СтрЗаменить(ПисьмоТекстHTML, "</html>", "</body></html>");
			
			ПисьмоТекстHTML = СтрЗаменить(ПисьмоТекстHTML, "<HTML>", "<HTML><BODY contentEditable=true>");
			ПисьмоТекстHTML = СтрЗаменить(ПисьмоТекстHTML, "</HTML>", "</BODY></HTML>");
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обновляет колличество введенных символов.
//
Процедура ОбновитьСтатусВведеныхСимволов()
	
	Текст = Объект.Содержание;
	
	// Удаляем символы переноса строки
	мТекст = Текст;
	Пока Найти(мТекст, Символы.ПС) > 0 Цикл
		мТекст = СтрЗаменить(мТекст, Символы.ПС, "");
	КонецЦикла;
	
	РазмерностьСообщения = ?(СтрДлина(мТекст) > 160, 153, 160); // 1-sms это 160 символов, если больше 160 символов, тогда 1 sms = 153
	КоличествоСМС = 0;

	РусскиеСимволы = "йцукенгшщзхъфывапролджэячсмитьбюё@_$^~`№";
	Для а = 1 По СтрДлина(РусскиеСимволы) Цикл
		Если Найти(мТекст, Сред(РусскиеСимволы, а, 1)) > 0 Тогда
			РазмерностьСообщения = ?(СтрДлина(мТекст) > 70, 67, 70); // 1-sms это 70 символов, если больше 70 символов, тогда 1 sms = 67
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	КоличествоСМС = Цел(СтрДлина(мТекст) / РазмерностьСообщения) + ?(СтрДлина(мТекст) % РазмерностьСообщения > 0, 1, 0);
	
	СтатусВведенныхСимволов =  "" + СтрШаблон(НСтр("ru = 'Введено %1 символов. От %2 sms';en = 'Entered %1 characters. From %2 sms'"), СтрДлина(мТекст), КоличествоСМС);	
	
КонецПроцедуры

