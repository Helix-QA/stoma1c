
#Область ОписаниеПеременных

&НаКлиенте
Перем ИскомыйКлиент;
&НаКлиенте
Перем ФильтрУслугИспользован;
&НаКлиенте
Перем ПерваяСсылкаВСпикеПодбораНоменклатуры;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);		
	
	// Установим реквизиты
	СкладДокумента = Объект.Склад;
	ОбщиеПараметры = Новый Структура;
	ОбщиеПараметры.Вставить("Перечисление_Зубы_ВсяПолость", ПредопределенноеЗначение("Перечисление.Зубы.ВсяПолость"));
	// Получаем вид цены	
	Если Объект.Ссылка.Пустая() Тогда
		Если Не ЗначениеЗаполнено(Объект.ВидЦен) Тогда
			Объект.ВидЦен = Справочники.ВидыЦен.Закупочная;
		КонецЕсли;	
		Если НЕ ЗначениеЗаполнено(Объект.ВидЦенПродажи) Тогда	
			Объект.ВидЦенПродажи = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
		КонецЕсли;
	КонецЕсли;

	ПредВыбранныйКонтрагент 	    = Объект.Контрагент;
	ПредВыбранныйСтраховойПолис     = Объект.ПолисМедСтрахования; 
	ЭтотОбъект._ПодборДоговорПолиса = ВернутьДоговорПоПолису(Объект.ПолисМедСтрахования); 
	
	// Открывает доступ к колонке %ручной скидки
	ИнициализацияДоступаКРучнойСкидке();
	
	РежимРаботыЕдинаяСеть                        = Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть; 	
    СотрудникПред                                = Объект.Сотрудник;
	СегментНоменклатуры                          = ВернутьСегментНоменклатуры(Объект.Договор, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
	СтруктураНадписи                             = Новый Структура("ВидЦен, ВидЦенПродажи", Объект.ВидЦен, Объект.ВидЦенПродажи);
	Элементы.ЦеныИВалютаНадпись.Заголовок        = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи);	
	ЭтоСтоматологическиеУслуги                   = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник);

	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);		
	// Установить отображение закладок скидки/наценки, подарки	
	// ОбщегоНазначенияСтоматология.УстановитьОтображениеЗакладокСкидкиНаценкиПодарки(ЭтаФорма);
	ОбновитьНадписи();

	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("ЗапасыИУслуги", "ГруппаЗапасыИУслуги");
	СтруктураМеню.Вставить("СкидкиНаценки", "ГруппаСкидкиНаценки");	
	СтруктураМеню.Вставить("Дополнительно", "ГруппаДополнительно");	
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
		
	HTML = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст();
	НастройкаФормыСервер("ПРИ_ЗАПУСКЕ");                      	
	SVGВыделенныйЗуб                             = "var selectzub"; 
	SVGМассивВыделенныхЗубов = "var SelectedTeeth = [];";
	SVGМассивЛечащихсяЗубов  = "var mas='';";	
	
	// Если документ открыт на основании документа аванса
	// сохраняем этот документ для последующего подбора услуг
	Если Параметры.Свойство("Основание") И (ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.ПланЛечения") ИЛИ ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.Прием")) Тогда
	     ОснованиеЗаполнения = Параметры.Основание;       
		 // Позиционирование страницы лечение
		 // Элементы.ГруппаЗапасыИУслуги.ТекущаяСтраница = Элементы.Группа;
	 КонецЕсли;
	 
	СистемнаяИнформация = Новый СистемнаяИнформация;
	ЭтотОбъект.ЭтоWindows = СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86 или СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86_64;
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() 
		И (Объект.Запасы.Количество() > 0) Тогда
		ПересчитатьАвтоматическиеСкидки();
	Иначе
		ПроставитьТипСкидкиНаценки();
		ЗаполнитьВирутальныеРеквизитыПодарков();
		ЗаполнитьТЧДоступныеОплатыБонусами();
		УстановитьВидимостьЭлементов();
	КонецЕсли;   
	
	ОтобразитьИнформациюПоОплате();
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
		РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);		
	КонецЕсли;

	Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Лаборатория);   
	// Настройки сортировки подбора.	
	ЗаполнитьНастройкиПодбораНоменклатуры();
	ОтборМассивРазрешенныхТипов = Новый Массив;
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Материал);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Запас);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Услуга);  
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Набор);  
	ОбработкаТабличныхЧастейКлиент.СоздатьДинамическийСписокПодбораНоменклатур(ЭтаФорма, Объект, "ГруппаПодборТовары", 
		ОтборМассивРазрешенныхТипов, ОтображатьОстаток, ОтображатьЦену, Истина, , ОтображатьАртикул, ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса));
		
	ТаблицаПодборЗапасов = Элементы.Найти("_ПодборНоменклатур");	
	Если НЕ ТаблицаПодборЗапасов = Неопределено Тогда	
		
		ТаблицаПодборЗапасов.ПоложениеСтрокиПоиска = ПоложениеСтрокиПоиска.Нет;
		Элементы.КнопкаНастройкиПодбораЗапасов.Видимость = Истина;	
		Элементы.ГруппаЗапасыНастройкиПодбора.Видимость = Истина;
		Элементы.СтрокаПоискаПодборЗапасов.Видимость = Истина;
		
	КонецЕсли;
	
	ЗаполнитьПараметрыВыбораСтруктурныхЕдиниц();
	ЗаполнитьПараметрыВыбораОрганизаций();
	
	МаксимальнаяРучнаяСкидка = РегистрыСведений.НастройкиСотрудников.ПолучитьМаксимальнуюСкидкуСотрудника(ПараметрыСеанса.АвторизованныйПользователь.Сотрудник, Объект.СтруктурнаяЕдиница);
    СсылкиНаОплатуИСБП.ОбновитьИнформациюПоИспользованиюСсылкиНаОплату(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);	
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии"
//
Процедура ПриОткрытии(Отказ)
	
	// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		ПоддерживаемыеТипыВО.Добавить("СчитывательМагнитныхКарт");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	
	// Обновить зубную формулу 
	ОбновитьДокумент();
	// Обновить подбор в зубной формуле
	ОбновитьSVGПодбор();
	// Не удалять!!!Циклы необходимы для предварительного кеширования таблиц источников данных(хз зачем)
	Для Каждого СтрокаТ ИЗ УслгуиПодборИсточникНоменклатуры Цикл КонецЦикла;
		
	// Подключить обработчик вызова фомы подбора услуг документа аванса
	Если ЗначениеЗаполнено(ОснованиеЗаполнения) Тогда
		 ПодключитьОбработчикОжидания("ОткрытьФормуПодбораУслугДокументаАванса",1,Истина);
	КонецЕсли;
	
	// Установим сортировку подборов по полю из настроек.	
	ИзменитьСортировкуПодбора(ЭтотОбъект._ПодборНоменклатур, ЭтотОбъект.ПолеСортировкиЗапасов, "Возр");
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
// Процедура открывает доступ к колонке %ручной скидки
//
Процедура ИнициализацияДоступаКРучнойСкидке()

	Для Каждого ЭлементТЧ Из Объект.Запасы Цикл 
		ЭлементТЧ.СкидкиЗапрещены = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭлементТЧ.Номенклатура, "СкидкиЗапрещены");
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере"
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ТаблицаУдаленныхСтрок", ТаблицаУдаленныхСтрок);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи"
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	Объект.СуммаДокумента = Объект.Запасы.Итог("Всего");
	Оповестить("ОбновитьЖурналРабот");
	Оповестить("ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА_АВАНСА");
	Оповестить("ПРОВЕДЕННА_ЗАПИСЬ_НАРЯД-ЗАКАЗА");
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере"
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);	
	
КонецПроцедуры

&НаКлиенте
// Обработчик вызова фомы подбора услуг документа аванса
//
Процедура ОткрытьФормуПодбораУслугДокументаАванса()
	
	ПараметрыОтбора = Новый Структура("ОтборДокумент, ОтборСотрудник, ОтборСтруктурнаяЕдиница", ОснованиеЗаполнения, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
	ОткрытьФорму("Документ.Прием.Форма.ФормаПодбораЗапланированныхУслуг", ПараметрыОтбора,,,,, Новый ОписаниеОповещения("ОткрытьФормуПодбораУслугДокументаАвансаЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте  
// Процедура - Открыть форму подбора услуг документа аванса завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОткрытьФормуПодбораУслугДокументаАвансаЗавершение(РезультатПодбора, ДополнительныеПараметры) Экспорт
	
	Если РезультатПодбора <> Неопределено Тогда
		ЗаполнитьРезультатомПодбора(ОснованиеЗаполнения, РезультатПодбора);
		ОбновитьSVGПодбор();
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Заполнить ТЧ Лечение по сонованию документа аванса
//
Процедура ЗаполнитьРезультатомПодбора(ДокументОснования, МассивЗаполнения)
	
	// Если основанием является план лечения
	Если ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.ПланЛечения") 
		ИЛИ ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.Прием") Тогда
		Для Каждого ЭлементМассива Из МассивЗаполнения Цикл 
			// Поиск существующей строки
			НайденнаяСтрока = Объект.Запасы.НайтиСтроки(Новый Структура("КлючСтроки", ЭлементМассива.КлючСтроки));	
			Если НайденнаяСтрока.Количество() = 0 Тогда
				// Получаем строку источника заполнения
				СтрокаИсточника        = ДокументОснования.Лечение.Найти(ЭлементМассива.КлючСтроки, "КлючСтроки");
				Если СтрокаИсточника <> Неопределено Тогда 
					НоваяСтрока                          			= Объект.Запасы.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
					Если ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.ПланЛечения") Тогда 
						НоваяСтрока.ПланЛечения                     = ДокументОснования;
					ИначеЕсли ТипЗнч(ДокументОснования) = Тип("ДокументСсылка.Прием") Тогда 
						НоваяСтрока.Прием                      		= ДокументОснования;
					КонецЕсли;	
					
					ЗакупочнаяЦена = РегистрыСведений.ЦеныНоменклатуры.ПолучитьЦеныНомеклатуры(НоваяСтрока.Номенклатура, Объект.СтруктурнаяЕдиница, Справочники.ВидыЦен.Закупочная);
					ЗакупочнаяЦена = ?(ЗакупочнаяЦена.Количество() > 0, ЗакупочнаяЦена[0].Цена, 0);
					
					НоваяСтрока.КоличествоУпаковок                  = НоваяСтрока.Количество;
					НоваяСтрока.ВидЦенПродажи 						= СтрокаИсточника.ВидЦен;
					НоваяСтрока.Статус 				 				= Перечисления.СтатусыНарядЗаказа.Заказано;
					НоваяСтрока.Цена 								= ЗакупочнаяЦена;
					НоваяСтрока.Сумма 								= ЗакупочнаяЦена * НоваяСтрока.Количество;
					НоваяСтрока.Всего 								= 0;					
					НоваяСтрока.ЦенаПродажи 						= СтрокаИсточника.Цена;
					НоваяСтрока.СуммаПродажи 						= СтрокаИсточника.Сумма;
					НоваяСтрока.ВсегоПродажи 						= СтрокаИсточника.Всего;					
					НоваяСтрока.ДатаЗаказа 							= ТекущаяДата();
					// Получаем строку источника заполнения
					СтруктураОтбора = Новый Структура("КлючСтроки", СтрокаИсточника.КлючСтроки);
					СтрокиИсточникаСкидки = ДокументОснования.СкидкиНаценки.НайтиСтроки(СтруктураОтбора);			
					// Добавим скидки в ТЧ СкидкиНаценки
					Для Каждого СтрокаСкидки Из СтрокиИсточникаСкидки Цикл 
						НоваяСтрокаСкидкиНаценки           			= Объект.СкидкиНаценки.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрокаСкидкиНаценки, СтрокаСкидки);
						НоваяСтрокаСкидкиНаценки.КлючСтроки         = НоваяСтрока.КлючСтроки;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	// Обновить значение суммы документа 
	// Объект.СуммаПродажи 	= Объект.Запасы.Итог("ВсегоПродажи");
	// Объект.СуммаДокумента 	= Объект.Запасы.Итог("Всего");
	// ПересчитатьАвтоматическиеСкидки();
	
КонецПроцедуры

&НаКлиенте
// Внести аванс
//
Процедура ДокументОплатить(Команда)
				
	Если ПроверитьЗаполнение() Тогда
		НеОбновлятьРабочийСтол = Истина;
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));	
		НеОбновлятьРабочийСтол = Ложь;
		ПараметрыОплаты = Новый Структура;
		ПараметрыОплаты.Вставить("СтруктурнаяЕдиница"                , Объект.СтруктурнаяЕдиница);
		ПараметрыОплаты.Вставить("ДатаПродажи"                       , Объект.Дата);
		ПараметрыОплаты.Вставить("ВидОперации"                       , ПредопределенноеЗначение("Перечисление.ВидыОпераций.Продажа"));
		ПараметрыОплаты.Вставить("Контрагент"                        , Объект.Контрагент);
		ПараметрыОплаты.Вставить("ДокументыПродажи"                  , Объект.Ссылка);
		ПараметрыОплаты.Вставить("ЗакрытьФормуАвтоматически"         , Истина);
		
		ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОплаты", ПараметрыОплаты,,,,,
			Новый ОписаниеОповещения("ДокументОплатитьЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
		
	КонецЕсли;
	
КонецПроцедуры

