&НаСервере
// Округляет число по заданному порядку.
//
// Параметры:
//  Число        - Число, которое необходимо округлить
//  ПорядокОкругления - Перечисления.ПорядкиОкругления - порядок округления
//  ОкруглятьВБольшуюСторону - Булево - округления в большую сторону.
//
// Возвращаемое значение:
//  Число        - результат округления.
//
Функция ОкруглитьЦену(Число, ПравилоОкругления, ОкруглятьВБольшуюСторону) Экспорт
	
	Перем Результат; // Возвращаемый результат.
	
	// Преобразуем порядок округления числа.
	// Если передали пустое значение порядка, то округлим до копеек. 
	Если НЕ ЗначениеЗаполнено(ПравилоОкругления) Тогда
		ПорядокОкругления = Перечисления.ПорядкиОкругления.Окр0_01; 
	Иначе
		ПорядокОкругления = ПравилоОкругления;
	КонецЕсли;
	Порядок = Число(Строка(ПорядокОкругления));
	
	// вычислим количество интервалов, входящих в число
	КоличествоИнтервал	= Число / Порядок;
	
	// вычислим целое количество интервалов.
	КоличествоЦелыхИнтервалов = Цел(КоличествоИнтервал);
	
	Если КоличествоИнтервал = КоличествоЦелыхИнтервалов Тогда
		
		// Числа поделились нацело. Округлять не нужно.
		Результат	= Число;
	Иначе
		Если ОкруглятьВБольшуюСторону Тогда
			
			// При порядке округления "0.05" 0.371 должно округлиться до 0.4
			Результат = Порядок * (КоличествоЦелыхИнтервалов + 1);
		Иначе
			
			// При порядке округления "0.05" 0.371 должно округлиться до 0.35,
			// а 0.376 до 0.4
			Результат = Порядок * Окр(КоличествоИнтервал, 0, РежимОкругления.Окр15как20);
		КонецЕсли; 
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ОкруглитьЦену()

&НаСервере
// Возвращает цену Сертификата
// Если ТипНоменклатуры Не ПодарочныйСертификат возвращает Неопределено 
Функция ПолучитьЦенуСертификата(СтруктураДанных) Экспорт
	
	Если СтруктураДанных.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат И СтруктураДанных.ВидЦен <> Справочники.ВидыЦен.Закупочная Тогда
		
		Цена = СтруктураДанных.Номенклатура.Номинал;
		Если СтруктураДанных.Номенклатура.ВестиСерийныеНомера Тогда
			СтруктураДанных.Вставить("ВестиСерийныеНомера");
		КонецЕсли;
		
		Возврат Цена;	  
		
	КонецЕсли;
	
КонецФункции

&НаСервере
// Выполняет пересчет документа после изменений в форме "Цены и валюта".
//
// Возвращаемое значение:
//  Число        - Полученная цена номенклатуры по прайсу.
//
Функция ПолучитьЦенуНоменклатуры(СтруктураДанных) Экспорт
	
	Если СтруктураДанных.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат И СтруктураДанных.ВидЦен <> Справочники.ВидыЦен.Закупочная Тогда
		
		Если СтруктураДанных.Номенклатура.ВестиСерийныеНомера Тогда
			СтруктураДанных.Вставить("ВестиСерийныеНомера");
		КонецЕсли;
			
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.Упаковка КАК Упаковка,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаОбработки,
	|			Актуальность = ИСТИНА
	|				И Номенклатура = &Номенклатура
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И ВидЦен = &ВидЦен) КАК ЦеныНоменклатурыСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент";

	
	Запрос.УстановитьПараметр("ДатаОбработки",	 	СтруктураДанных.ДатаОбработки);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктураДанных.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Номенклатура",	 	СтруктураДанных.Номенклатура);
	Запрос.УстановитьПараметр("ВидЦен",			 	СтруктураДанных.ВидЦен);
	Если СтруктураДанных.Свойство("Сотрудник") Тогда
		ЗапросСотрудникВидЦен = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		                                     |	НастройкиСотрудников.ВидЦен
		                                     |ИЗ
		                                     |	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		                                     |ГДЕ
		                                     |	НастройкиСотрудников.Сотрудник = &Сотрудник
		                                     |	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
		ЗапросСотрудникВидЦен.УстановитьПараметр("Сотрудник", СтруктураДанных.Сотрудник);
		ЗапросСотрудникВидЦен.УстановитьПараметр("СтруктурнаяЕдиница", СтруктураДанных.СтруктурнаяЕдиница);
		Выборка = ЗапросСотрудникВидЦен.Выполнить().Выбрать();
		Если Выборка.Следующий() и ЗначениеЗаполнено(Выборка.ВидЦен) Тогда
			Запрос.УстановитьПараметр("ВидЦен",	Выборка.ВидЦен);
		КонецЕсли;
		// И ЗначениеЗаполнено(СтруктураДанных.Сотрудник.ВидЦен) Тогда
		
	КонецЕсли;
	
	ТаблицаЦен = Запрос.Выполнить().Выгрузить();
	
	Цена = ВозвратитьЦенуУпаковкиИзТаблицыЦен(ТаблицаЦен, Новый Структура("Упаковка", СтруктураДанных.Упаковка));
	
	// Учитываем: сумма включает НДС.
	Если НЕ СтруктураДанных.ВидЦен.ЦенаВключаетНДС И СтруктураДанных.Свойство("СтавкаНДС") Тогда
		Цена = ПересчитатьСуммуПриИзмененииФлаговНДС(Цена, СтруктураДанных.СтавкаНДС);
	КонецЕсли;
		
	Цена = ОкруглитьЦену(Цена, СтруктураДанных.ВидЦен.ПорядокОкругления, СтруктураДанных.ВидЦен.ОкруглятьВБольшуюСторону);
	
	Возврат Цена;
	
КонецФункции // ПолучитьЦенуНоменклатуры()

&НаСервере
// Выполняет пересчет документа после изменений в форме "Цены и валюта".
//
// Возвращаемое значение:
//  Число        - Полученная цена номенклатуры по прайсу.
//
Функция ВозвратитьЦенуУпаковкиИзТаблицыЦен(ТаблицаЦен, СтруктураПараметров) Экспорт
	
    ТаблицаЦенНоменклатуры = ТаблицаЦен.Скопировать();
	
	Если СтруктураПараметров.Свойство("Номенклатура") Тогда
		ТаблицаЦенНоменклатуры.Очистить();
		Для Каждого СтрокаТаблицыЦен Из ТаблицаЦен Цикл
			Если СтрокаТаблицыЦен.Номенклатура = СтруктураПараметров.Номенклатура Тогда
				НоваяСтрока = ТаблицаЦенНоменклатуры.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицыЦен);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Цена = 0;

	// Если есть необходимая упаковка - берем ее цену, иначе - вычисляем
	Если ТаблицаЦенНоменклатуры.Найти(СтруктураПараметров.Упаковка, "Упаковка") <> Неопределено Тогда
		Цена = ТаблицаЦенНоменклатуры.Найти(СтруктураПараметров.Упаковка, "Упаковка").Цена;
	ИначеЕсли СтруктураПараметров.Упаковка.Пустая() И ТаблицаЦенНоменклатуры.Количество() > 0 Тогда
		Цена = ТаблицаЦенНоменклатуры[0].Цена / ?(ЗначениеЗаполнено(ТаблицаЦенНоменклатуры[0].Упаковка) , ТаблицаЦенНоменклатуры[0].Упаковка.Коэффициент, 1);
	ИначеЕсли Не СтруктураПараметров.Упаковка.Пустая() И ТаблицаЦенНоменклатуры.Найти(Справочники.УпаковкиНоменклатуры.ПустаяСсылка(), "Упаковка") <> Неопределено Тогда
		Цена = ТаблицаЦенНоменклатуры.Найти(Справочники.УпаковкиНоменклатуры.ПустаяСсылка(), "Упаковка").Цена * СтруктураПараметров.Упаковка.Коэффициент;
	КонецЕсли;
		
	Возврат Цена;
	
КонецФункции // ВозвратитьЦенуУпаковкиИзТаблицыЦен()

&НаСервере
// Выполняем пересчет цены табличной части документа после изменений в форме 
// "Цены и валюта".
//
// Параметры:
//  СтруктураРеквизитов - Структура реквизитов, необходимых при пересчете
//  ТабличнаяЧастьДокумента - ДанныеФормыСтруктура, содержит табличную часть
//                 документа.
//
Процедура ПолучитьЦеныТабличнойЧастиПоВидуЦен(СтруктураДанных, ТабличнаяЧастьДокумента) Экспорт
	
	// 1. Сформируем таблицу документа.
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ТаблицаНоменклатуры = Новый ТаблицаЗначений;
	
	Массив = Новый Массив;
	
	// Номенклатура.
	Массив.Добавить(Тип("СправочникСсылка.Номенклатура"));
	ОписаниеТипов = Новый ОписаниеТипов(Массив, ,);
	Массив.Очистить();
	
	ТаблицаНоменклатуры.Колонки.Добавить("Номенклатура", ОписаниеТипов);
	
	// СтавкиНДС.
	Массив.Добавить(Тип("ПеречислениеСсылка.СтавкиНДС"));
	ОписаниеТипов = Новый ОписаниеТипов(Массив, ,);
	Массив.Очистить();
	
	ТаблицаНоменклатуры.Колонки.Добавить("СтавкаНДС", ОписаниеТипов);	
	
	// ЕдиницаИзмерения.
	Массив.Добавить(Тип("СправочникСсылка.УпаковкиНоменклатуры"));
	ОписаниеТипов = Новый ОписаниеТипов(Массив, ,);
	Массив.Очистить();
	
	ТаблицаНоменклатуры.Колонки.Добавить("Упаковка", ОписаниеТипов);	
	
	Для каждого СтрокаТЧ Из ТабличнаяЧастьДокумента Цикл
		
		НоваяСтрока = ТаблицаНоменклатуры.Добавить();
		НоваяСтрока.Номенклатура	 = СтрокаТЧ.Номенклатура;
		НоваяСтрока.Упаковка = СтрокаТЧ.Упаковка;
		Если ТипЗнч(СтрокаТЧ) = Тип("Структура") И СтрокаТЧ.Свойство("СтавкаНДС") Тогда
			НоваяСтрока.СтавкаНДС		 = СтрокаТЧ.СтавкаНДС;
		КонецЕсли;	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	ТаблицаНоменклатуры.Номенклатура,
	|	ТаблицаНоменклатуры.Упаковка,
	|	ТаблицаНоменклатуры.СтавкаНДС
	|ПОМЕСТИТЬ ВременнаяТаблицаНоменклатуры
	|ИЗ
	|	&ТаблицаНоменклатуры КАК ТаблицаНоменклатуры";
	
	Запрос.УстановитьПараметр("ТаблицаНоменклатуры", ТаблицаНоменклатуры);
	Запрос.Выполнить();
	
	ВидЦенПараметр = СтруктураДанных.ВидЦен;	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Упаковка КАК Упаковка,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаОбработки,
	|			Актуальность = ИСТИНА
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И ВидЦен = &ВидЦен) КАК ЦеныНоменклатурыСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент";
	
		
	Запрос.УстановитьПараметр("ДатаОбработки",	 	СтруктураДанных.Дата);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктураДанных.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ВидЦен",			 	ВидЦенПараметр);
	
	ТаблицаЦен = Запрос.Выполнить().Выгрузить();
	
	Для каждого СтрокаТабЧасти Из ТабличнаяЧастьДокумента Цикл
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура",	 СтрокаТабЧасти.Номенклатура);
		СтруктураПоиска.Вставить("Упаковка", 		 СтрокаТабЧасти.Упаковка);
		
		Цена = ВозвратитьЦенуУпаковкиИзТаблицыЦен(ТаблицаЦен, СтруктураПоиска);
		
		Если НЕ ВидЦенПараметр.ЦенаВключаетНДС и СтрокаТабЧасти.Свойство("СтавкаНДС") Тогда
			Цена = ПересчитатьСуммуПриИзмененииФлаговНДС(Цена, СтрокаТабЧасти.СтавкаНДС);
		КонецЕсли;
			
		СтрокаТабЧасти.Цена = ОкруглитьЦену(Цена, ВидЦенПараметр.ПорядокОкругления, ВидЦенПараметр.ОкруглятьВБольшуюСторону);
			
	КонецЦикла;
	
	МенеджерВременныхТаблиц.Закрыть();
	
КонецПроцедуры // ПолучитьЦеныТабличнойЧастиПоВидуЦен()

&НаСервере
// Получает набор данных с сервера для процедуры НоменклатураПриИзменении.
//
Функция ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные) Экспорт
	
	СтруктураДанные.Вставить("СтавкаНДС", ВернутьСтавкуНДС(СтруктураДанные));
	
	Если Не СтруктураДанные.Свойство("Упаковка") Тогда
		СтруктураДанные.Вставить("Упаковка", Справочники.УпаковкиНоменклатуры.ПустаяСсылка());
	ИначеЕсли СтруктураДанные.Упаковка.Владелец <> СтруктураДанные.Номенклатура Тогда
		СтруктураДанные.Упаковка = Справочники.УпаковкиНоменклатуры.ПустаяСсылка();
	КонецЕсли;	
	
	Если СтруктураДанные.Свойство("ВидЦен")  Тогда
		Цена = ПолучитьЦенуНоменклатуры(СтруктураДанные);
		СтруктураДанные.Вставить("Цена", Цена);
	Иначе
		СтруктураДанные.Вставить("Цена", 0);
	КонецЕсли;
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеНоменклатураПриИзменении()

