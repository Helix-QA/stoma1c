// Процедура - Выбор взаимодействия завершение
//
Процедура ВыборВзаимодействиеЗадачаЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда 
		
		Если Объект.Ссылка.Пустая() Тогда
			
			Оповещение = Новый ОписаниеОповещения("ВзаимодействиеПослеВопросаОЗаписиКлиента", ЭтотОбъект, Новый Структура("ВыполнитьДействие", "ВыборВзаимодействия"));
			ПоказатьВопрос(Оповещение, НСтр("ru='Для создания взаимодействия необходимо произвести запись нового пациента. Записать?';en='For create interactions is necessary toproduce record new client. WriteDown?'"), РежимДиалогаВопрос.ДаНет);
		Иначе
			
			ЭтотОбъект.ВзаимодействиеПараметры = Новый Структура;
			ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Взаимодействие"   , Результат.Значение.Взаимодействие);
			ЭтотОбъект.ВзаимодействиеПараметры.Вставить("ВидВзаимодействия", Результат.Значение.ВидВзаимодействия);
			ЭтотОбъект.ВзаимодействиеПараметры.Вставить("ТемаПоУмолчанию"  , Результат.Значение.ТемаПоУмолчанию);
			ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Представление"    , Результат.Представление);
			ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Картинка"         , Результат.Картинка);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВзаимодействиеЗадачаЗавершение2", ЭтаФорма);
			
			Предмет = Новый Структура("Контрагент, ВидВзаимодействия", Объект.Ссылка, Результат.Значение.ВидВзаимодействия);			 	
			                           ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаЗадачиБыстрая", 
			                           Новый Структура("ЗначенияЗаполнения, ВзаимодействиеСделка, ВзаимодействиеЗадачаПараметры", 
			                           Предмет, ЭтотОбъект.ВзаимодействиеСделка, ЭтотОбъект.ВзаимодействиеПараметры),,,,,ОписаниеОповещения,
			                           РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры  

