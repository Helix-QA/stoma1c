// Процедура - Скопировать строку дерева значений
// 
Процедура СкопироватьСтрокуДереваЗначений(Дерево, КопируемаяСтрока, НовыйРодитель) Экспорт
    
	НоваяСтрока = НовыйРодитель.Строки.Добавить(); 
	ЗаполнитьЗначенияСвойств(НоваяСтрока, КопируемаяСтрока); 
	
	Для Каждого СтрокаКопируемойСтроки ИЗ КопируемаяСтрока.Строки Цикл 
		СкопироватьСтрокуДереваЗначений(Дерево, СтрокаКопируемойСтроки, НоваяСтрока); 
	КонецЦикла; 
	
КонецПроцедуры

// Процедура - Переместить строку дерева значений
// 
Процедура ПереместитьСтрокуДереваЗначений(Дерево, ПеремещаемаяСтрока, НовыйРодитель) Экспорт
    
	НоваяСтрока = НовыйРодитель.Строки.Добавить(); 
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ПеремещаемаяСтрока); 
	
	МассивПеремещаемаяСтрокаСтроки = Новый Массив;     // Механизм что б после удаление не пропускать следущие элементы-строки
	Для Каждого СтрокаПеремещаемойСтроки ИЗ ПеремещаемаяСтрока.Строки Цикл 
		МассивПеремещаемаяСтрокаСтроки.Добавить(СтрокаПеремещаемойСтроки);
	КонецЦикла;
	Для Каждого СтрокаПеремещаемойСтроки ИЗ МассивПеремещаемаяСтрокаСтроки Цикл 
		ПереместитьСтрокуДереваЗначений(Дерево, СтрокаПеремещаемойСтроки, НоваяСтрока); 
	КонецЦикла; 
	
	Дерево.Строки.Удалить(ПеремещаемаяСтрока); 
        
КонецПроцедуры

// Устанавливает значение реквизита в дереве, возможно рекурсивное заполнение внутрь дерева
// 
Функция УстановитьЗначениеДерева(Дерево, ИмяПоля, ЗначениеПоля, Рекурсивно = Ложь) Экспорт

	Дерево[ИмяПоля] = ЗначениеПоля;
	
	Для каждого СтрокаДерева Из Дерево.Строки Цикл
		Если Рекурсивно = Истина Тогда
			УстановитьЗначениеДерева(СтрокаДерева, ИмяПоля, ЗначениеПоля, Истина);
		КонецЕсли;
	КонецЦикла; 

КонецФункции
 
