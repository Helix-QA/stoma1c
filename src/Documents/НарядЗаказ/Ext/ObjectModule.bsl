//
//
Процедура ЗаполнитьРеквизитДокументАвансаВПрием(МассивПриемов, РежимЗаписиНарядЗаказа, Отказ)		
	
	ПараметрыСеанса.ОбменДаннымиВключен = Истина;
	Для Каждого Прием Из МассивПриемов Цикл 
		МассивНайденныхСтрок = Запасы.НайтиСтроки(Новый Структура("Прием", Прием));
		Если МассивНайденныхСтрок.Количество() > 0 Тогда
			ПриемОбъект = Прием.ПолучитьОбъект();
			
			Для Каждого НайденнаяСтрока Из МассивНайденныхСтрок Цикл 
				СтрокаТЧЛечение_Прием = ПриемОбъект.Лечение.Найти(НайденнаяСтрока.КлючСтроки, "КлючСтроки");
				Если СтрокаТЧЛечение_Прием <> Неопределено Тогда				
					Если РежимЗаписиНарядЗаказа = РежимЗаписиДокумента.ОтменаПроведения Тогда
						СтрокаТЧЛечение_Прием.ДокументАванса = Документы.НарядЗаказ.ПустаяСсылка();
						НайденнаяСтрока.Прием = Документы.Прием.ПустаяСсылка();
					Иначе
						Если ЗначениеЗаполнено(СтрокаТЧЛечение_Прием.ДокументАванса) И НЕ СтрокаТЧЛечение_Прием.ДокументАванса = Ссылка Тогда 
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Наряд-заказ не может быть проведен, так как данные услуги уже проведенны в " + Строка(СтрокаТЧЛечение_Прием.ДокументАванса) + " ! ");
							Отказ = Истина;
							Возврат;
						Иначе						
							// Пишем Ссылку
							СтрокаТЧЛечение_Прием.ДокументАванса = Ссылка;
						КонецЕсли;
					КонецЕсли;	
				КонецЕсли;
				СтрокаТЧЗапасы_Прием = ПриемОбъект.Запасы.Найти(НайденнаяСтрока.КлючСтроки, "КлючСтроки");
				Если СтрокаТЧЗапасы_Прием <> Неопределено Тогда				
					Если РежимЗаписиНарядЗаказа = РежимЗаписиДокумента.ОтменаПроведения Тогда
						СтрокаТЧЗапасы_Прием.ДокументАванса = Документы.НарядЗаказ.ПустаяСсылка();
					Иначе
						Если ЗначениеЗаполнено(СтрокаТЧЗапасы_Прием.ДокументАванса) И НЕ СтрокаТЧЗапасы_Прием.ДокументАванса = Ссылка Тогда 
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Наряд-заказ не может быть проведен, так как данные услуги уже проведенны в " + Строка(СтрокаТЧЗапасы_Прием.ДокументАванса) + " ! ");
							Отказ = Истина;
							Возврат;
						Иначе						
							// Пишем Ссылку
							СтрокаТЧЗапасы_Прием.ДокументАванса = Ссылка;
						КонецЕсли;
					КонецЕсли;	
				КонецЕсли;
			КонецЦикла;
			ПриемОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЦикла;
	ПараметрыСеанса.ОбменДаннымиВключен = Ложь;	
	
КонецПроцедуры


