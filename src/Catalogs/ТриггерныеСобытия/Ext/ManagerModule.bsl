			ТриггерСменаСтатусаЗаписи.МоментСобытия 			= Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия;
			ТриггерСменаСтатусаЗаписи.ПериодСобытияВид 			= Перечисления.Периодичность.День;
			ТриггерСменаСтатусаЗаписи.СтатусЗаписи 				= Перечисления.СтатусыСобытия.Подтверждена;
