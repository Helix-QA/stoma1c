&НаСервере
// Веренет таблицу сохраняемых элементов
//
Функция ЭлементыДляСохранения()
	
	СохраняемыеЭлементы = Новый Структура("ОснованиеРезерва", Объект.ОснованиеРезерва);
	
	Возврат СохранениеВводимыхЗначений.СформироватьТаблицуСохраненяемыхЭлементов(СохраняемыеЭлементы);
	
КонецФункции

&НаКлиенте
// Устанавливает списки выбора для элементов выбора времени начала и окончания услуг
// Это вынужденная мера, т.к. в платформе 8.3.4 есть косяк со списками выбора
//
Процедура ПроинициализироватьЭлементыВыбораВремени()

	МассивИнициализируемыхЭлементов = Новый Массив;
	МассивИнициализируемыхЭлементов.Добавить("УслугиДатаНачалаПолем");
	МассивИнициализируемыхЭлементов.Добавить("УслугиДатаОкончанияПолем");
	
	МассивПериодов = Новый Массив;
	МассивПериодов.Добавить(ОбщегоНазначенияСтоматология.ПолучитьВремяРаботыСтруктурнойЕдиницы(ДатаСобытия, Объект.СтруктурнаяЕдиница));
	СписокВремени = РаботаСДиалогами.ВернутьСписокВремени(МассивПериодов, Истина);
	
	Для Каждого ИмяЭлемента Из МассивИнициализируемыхЭлементов Цикл
		
		Элементы[ИмяЭлемента].СписокВыбора.Очистить();
		Для Каждого ПредставлениеВремени Из СписокВремени Цикл
			Элементы[ИмяЭлемента].СписокВыбора.Добавить(ПредставлениеВремени.Значение, ПредставлениеВремени.Представление);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры // ПроинициализироватьЭлементыВыбораВремени()

#КонецОбласти 
