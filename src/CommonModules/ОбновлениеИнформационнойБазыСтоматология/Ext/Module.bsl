// Процедура перепроводит документы в исторической последовательности.
//
Процедура ПерепровестиИсторическиДокументыРеализацииСклада() Экспорт
	
	// Пересохраняем документы
	СписокИменДокументов = Новый Структура("ИнвентаризацияЗапасов, ПоступлениеДенежныхСредств"
				+ ",ОприходованиеЗапасов, ПеремещениеЗапасов, Поступление"
				+ ",ВозвратОтПокупателя, ВозвратПоставщику"
				+ ", Реализация, СписаниеЗапасов, СписаниеМатериалов");
	ПОПЫТКА	
		// Сообщить("Пересохраняются документы", СтатусСообщения.Информация);
		Для Каждого ИмяДокумента Из СписокИменДокументов Цикл
			ВыборкаДокумента = Документы[ИмяДокумента.Ключ].Выбрать();
			Пока ВыборкаДокумента.Следующий() Цикл
				ДокументОбъект = ВыборкаДокумента.ПолучитьОбъект();
				Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Склад", ДокументОбъект.Ссылка.Метаданные()) 
					И ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("СтруктурнаяЕдиница", ДокументОбъект.Ссылка.Метаданные()) Тогда
					ДокументОбъект.СтруктурнаяЕдиница = ?(ТипЗнч(ДокументОбъект.Склад) = Тип("СправочникСсылка.Склады"), ДокументОбъект.Склад.СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
				КонецЕсли;
				Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("СкладПолучатель", ДокументОбъект.Ссылка.Метаданные()) 
					И ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("СтруктурнаяЕдиницаПолучатель", ДокументОбъект.Ссылка.Метаданные()) Тогда
					ДокументОбъект.СтруктурнаяЕдиницаПолучатель = ?(ТипЗнч(ДокументОбъект.СкладПолучатель) = Тип("СправочникСсылка.Склады"), ДокументОбъект.СкладПолучатель.СтруктурнаяЕдиница, ДокументОбъект.СтруктурнаяЕдиница);
				КонецЕсли;
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЦикла;
		КонецЦикла;
	ИСКЛЮЧЕНИЕ
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При пересохранении документов произошла ошибка.");
		Возврат;
	КОНЕЦПОПЫТКИ;		
	
	
	// Перепроводим документы прихода
	СписокИменДокументов = Новый Структура("ИнвентаризацияЗапасов, ПоступлениеДенежныхСредств"
				+ ",ОприходованиеЗапасов, ПеремещениеЗапасов, Поступление");
	ПОПЫТКА
		// Сообщить("Перепроводятся документы прихода", СтатусСообщения.Информация);
		ОбщегоНазначения.ПерепровестиИсторическиДокументы(СписокИменДокументов, Ложь);
	ИСКЛЮЧЕНИЕ
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При перепроведении документов прихода произошла ошибка. Перепроведите документы вручную!");
		Возврат;
	КОНЕЦПОПЫТКИ;
	
	// Перепроводим документы расхода
	СписокИменДокументов = Новый Структура("ВозвратОтПокупателя, ВозвратПоставщику"
				+ ", Реализация, СписаниеЗапасов, СписаниеМатериалов");
	ПОПЫТКА
		// Сообщить("Перепроводятся документы расхода", СтатусСообщения.Информация);
		ОбщегоНазначения.ПерепровестиИсторическиДокументы(СписокИменДокументов, Ложь);
	ИСКЛЮЧЕНИЕ
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При перепроведении документов расхода произошла ошибка. Перепроведите документы вручную!");		
		Возврат;
	КОНЕЦПОПЫТКИ;
		
КонецПроцедуры

