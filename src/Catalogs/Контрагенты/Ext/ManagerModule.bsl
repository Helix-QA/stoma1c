	МассивНомеровИПолучателей = Новый Массив(2);
	МассивНомеровИПолучателей[0] = МассивПолучателей;
	МассивНомеровИПолучателей[1] = МассивНомеровТелефонов;
	Возврат МассивНомеровИПолучателей;
	
КонецФункции

// Функция, выполняющая првоерку на необходимость информирования менеджера о дне рождения контрагента
//
Функция ПроверитьНеобходимостьИнформированияПоДнюРожденияКонтрагента(Контрагент, Знач ТекущаяДата = Неопределено) Экспорт
	
	Результат = Новый Структура("Информировать, СообщениеИнформирования", Ложь, "");
	
	Если ТекущаяДата = Неопределено Тогда
		ТекущаяДата = ТекущаяДата();
	КонецЕсли;
	
	Если Контрагент.ДатаРожденияКлиента = Дата(1,1,1) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Месяц(ТекущаяДата - 2*24*60*60) = Месяц(Контрагент.ДатаРожденияКлиента)
			И День(ТекущаяДата - 2*24*60*60) = День(Контрагент.ДатаРожденияКлиента) Тогда
		Результат.Информировать = Истина;
		Результат.СообщениеИнформирования = "У пациента позавчера был день рождения!";
	ИначеЕсли Месяц(ТекущаяДата - 1*24*60*60) = Месяц(Контрагент.ДатаРожденияКлиента)
			И День(ТекущаяДата - 1*24*60*60) = День(Контрагент.ДатаРожденияКлиента) Тогда
		Результат.Информировать = Истина;
		Результат.СообщениеИнформирования = "У пациента вчера был день рождения!";
	ИначеЕсли Месяц(ТекущаяДата) = Месяц(Контрагент.ДатаРожденияКлиента)
			И День(ТекущаяДата) = День(Контрагент.ДатаРожденияКлиента) Тогда
		Результат.Информировать = Истина;
		Результат.СообщениеИнформирования = "У пациента сегодня день рождения!";
	ИначеЕсли Месяц(ТекущаяДата + 1*24*60*60) = Месяц(Контрагент.ДатаРожденияКлиента)
			И День(ТекущаяДата + 1*24*60*60) = День(Контрагент.ДатаРожденияКлиента) Тогда
		Результат.Информировать = Истина;
		Результат.СообщениеИнформирования = "У пациента завтра день рождения!";
	ИначеЕсли Месяц(ТекущаяДата + 2*24*60*60) = Месяц(Контрагент.ДатаРожденияКлиента)
			И День(ТекущаяДата + 2*24*60*60) = День(Контрагент.ДатаРожденияКлиента) Тогда
		Результат.Информировать = Истина;
		Результат.СообщениеИнформирования = "У пациента послезавтра день рождения!";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Добавление телефонного номера клиенту через форму
Процедура ДобавитьНомерТелефона(ФормаКлиента,НомерТелефона)Экспорт
	
    Элемент = ФормаКлиента.Элементы["__КИ_Поле1"];
	
	Отбор = Новый Структура("ИмяРеквизита", Элемент.Имя);
    СтрДанные = ФормаКлиента.__КИ_ОписаниеДополнительныхРеквизитов.НайтиСтроки(Отбор);

	ЗначенияПолей = Новый СписокЗначений;
	ЗначенияПолей.Добавить("",     "КодСтраны");
	ЗначенияПолей.Добавить("",     "КодГорода");
	ЗначенияПолей.Добавить(НомерТелефона, "НомерТелефона");
	ЗначенияПолей.Добавить("",    "Добавочный");
	ЗначенияПолей.Добавить("",   "Комментарий");
	
	Результат = Новый Структура;
	Результат.Вставить("ЗначенияПолей", ЗначенияПолей);
	Результат.Вставить("Представление", НомерТелефона);

	ФормаКлиента[Элемент.Имя]  = Результат.Представление;
	
	Если СтрДанные.Количество() > 0 Тогда
         СтрДанные[0].ЗначенияПолей = Результат.ЗначенияПолей;
    КонецЕсли;

КонецПроцедуры

// Функция - Получить создать группу гостей
// 
Функция ПолучитьКонтрагентаПоНомеруТелефона(НомерТелефона) Экспорт
	
	Если СтрНайти(НомерТелефона, "+") = 0 Тогда
		
		Если Сред(НомерТелефона, 1, 1) = "8" Тогда
			НомерТелефона = "7" + Сред(НомерТелефона, 2); 
		КонецЕсли;
		НомерТелефона = "+" + НомерТелефона;
	Иначе
		Если Сред(НомерТелефона, 1, 2) = "+8" Тогда
			НомерТелефона = "+7" + Сред(НомерТелефона, 3); 
		КонецЕсли;
	КонецЕсли;
	
	МассивНомеровТелефонов = Новый Массив;
	МассивНомеровТелефонов.Добавить(НомерТелефона);
	МассивНомеровТелефонов.Добавить(СтрЗаменить(НомерТелефона, "+" , ""));
	МассивНомеровТелефонов.Добавить(СтрЗаменить(НомерТелефона, "+7", ""));
	МассивНомеровТелефонов.Добавить(СтрЗаменить(НомерТелефона, "+7", "8"));
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КонтрагентыКонтактнаяИнформация.Ссылка
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|	И КонтрагентыКонтактнаяИнформация.НомерТелефона В (&МассивНомеровТелефонов)");
	
	Запрос.УстановитьПараметр("МассивНомеровТелефонов", МассивНомеровТелефонов);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Возврат ?(РезультатЗапроса.Следующий(), РезультатЗапроса.Ссылка, Неопределено);
	
КонецФункции

// Функция, возвращает контрагента по email.
//
Функция ПолучитьКонтрагентаПоEmail(Email) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)
	|	И ВЫРАЗИТЬ(КонтрагентыКонтактнаяИнформация.Представление КАК СТРОКА(300)) В (&МассивEmail)";				   
	
	МассивEmail = Новый Массив;
	МассивEmail.Добавить(Email);
    МассивEmail.Добавить(НРег(Email));
    МассивEmail.Добавить(ВРег(Email));
	МассивEmail.Добавить(ТРег(Email));
	
	Запрос.УстановитьПараметр("МассивEmail", МассивEmail);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		Возврат РезультатЗапроса.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
		
КонецФункции

// Функция возвращает номер телефона и адрес электронной почты
//
Функция ПолучитьКонтактныеДанныеКонтрагента(Контрагент) Экспорт
	
	КонтактныеДанные = Новый Структура("phone, Email");
	
	Для Каждого СтрокаТЧ Из Контрагент.КонтактнаяИнформация Цикл
		
		Если НЕ ЗначениеЗаполнено(КонтактныеДанные.phone)
			И ЗначениеЗаполнено(СтрокаТЧ.НомерТелефона) Тогда
			
			КонтактныеДанные.phone = СтрокаТЧ.НомерТелефона;
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(КонтактныеДанные.Email)
			И ЗначениеЗаполнено(СтрокаТЧ.АдресЭП) Тогда
			
			КонтактныеДанные.Email = СтрокаТЧ.АдресЭП;
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КонтактныеДанные.phone)
			И ЗначениеЗаполнено(КонтактныеДанные.Email) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат КонтактныеДанные;
		
КонецФункции

// Функция возвращает видимость поля "Законный представитель" 
//
Функция ПолучитьВидимостьЗаконногоПредставителя(ДатаРожденияКлиента, НедееспособныйГражданин = Ложь) Экспорт
	
	Если НедееспособныйГражданин Тогда Возврат Истина; КонецЕсли;
	
	КоличествоЛет = 0;
	Лет = 0;
	Месяцев = 0;
	Дней = 0;
	ДатаР = ДатаРожденияКлиента;
	Високосный = 0;
	
	Если Не День(ДобавитьМесяц(ДатаР,12)) = День(ДатаР) Тогда
		Високосный = 1;
		ДатаР = ДатаР - 60*60*24;
	КонецЕсли;
	Пока ДатаР <= ТекущаяДатаСеанса() Цикл
		ДатаР = ДобавитьМесяц(ДатаР,1);
		Месяцев = Месяцев + 1;
	КонецЦикла;
	
	Месяцев = Месяцев-1;
	Лет = Цел(Месяцев/12);
	Месяцев = Месяцев-Лет*12;
	Дней = Цел((ТекущаяДатаСеанса() - ДобавитьМесяц(ДатаР,-1))/(60*60*24))-Високосный;
	КоличествоЛет = "Лет: "+Строка(Лет)+" Месяцев: "+Строка(Месяцев)+" Дней: "+Строка(Дней);
	
	Если Лет < 18 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		 
КонецФункции

