// Процедура - Проверка связи с классификатором должностей
//
Функция ПроверитьВСИЭМК() 
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(,Перечисления.ТипыВнешнихСистем.ИЭМК, Истина);
	
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
		Если ЗначениеЗаполнено(Объект.Должность) И Не ЗначениеЗаполнено(Объект.Должность.ДолжностьПоКлассификаторуИЭМК) Тогда
			Возврат "2";
		Иначе
			Если Объект.СпецилазацииСотрудника.Количество() > 0 Тогда
				Для Каждого Элемент Из Объект.СпецилазацииСотрудника Цикл
					Если Элемент.Основная И Не ЗначениеЗаполнено(Элемент.Специализация.СпециализацияПоКлассификаторуИЭМК) Тогда
						Возврат "4";
					КонецЕсли;
				КонецЦикла;
				Возврат "3";
			Иначе
				Возврат "1";
			КонецЕсли;
		КонецЕсли;
	Иначе
		Возврат "0";
	КонецЕсли;
	
КонецФункции	

