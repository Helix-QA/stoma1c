// Функция - Входщий звонок отвечен
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  НомерТелефонаFrom			 - 	 - 
//  НомерТелефонаTo				 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция СобытиеЗвонокДозвон(ПараметрыЗвонка = Неопределено, УнифицированнаяСтруктураСобытия, ОписаниеОшибки = "")
		
	// Создаем оповещение на клиент	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда
		
		Если УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсBINOTEL Тогда
			СписокНомеровТелефонов = ПолучитьСписокНомеровТелефоновBINOTEL(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom);
		Иначе
			СписокНомеровТелефонов = Неопределено;	
		КонецЕсли;
		
		Если УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS 
			ИЛИ УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM
			ИЛИ УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсCoMagic Тогда
			
			СписокАктивныхПользователей 				= ПолучитьСписокАктивныхПользователей(УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника);
			УнифицированнаяСтруктураСобытия.Контрагент 	= ПолучитьКонтрагентаСотрудникаПоНомеруТелефона(УнифицированнаяСтруктураСобытия.НомерКонтрагента, СписокНомеровТелефонов);				
			
		Иначе 
			СписокАктивныхПользователей 				= ПолучитьСписокАктивныхПользователей(УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
			УнифицированнаяСтруктураСобытия.Контрагент 	= ПолучитьКонтрагентаСотрудникаПоНомеруТелефона(УнифицированнаяСтруктураСобытия.НомерТелефонаFrom, СписокНомеровТелефонов);			
		КонецЕсли;	
		
		НомерТелефонаFromПредставление    = ВернутьПредставлениеНомераТелефона(СписокНомеровТелефонов);
		ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
		
		ОбъектыОповещения 	 = Новый Массив;
		СотрудникиОповещения = Новый Массив;
		
		Для Каждого АктивныйСеансПользователя Из СписокАктивныхПользователей Цикл
			
			СообщениеОповещенияДействие = ?(ЗначениеЗаполнено(УнифицированнаяСтруктураСобытия.Контрагент), Символы.ПС + "Открыть карточку клиента", "");										
			СообщениеОповещения = "Клиент: " + ?(ЗначениеЗаполнено(УнифицированнаяСтруктураСобытия.Контрагент), УнифицированнаяСтруктураСобытия.Контрагент, "не найден" + ", тел. " + ?(ЗначениеЗаполнено(НомерТелефонаFromПредставление), НомерТелефонаFromПредставление, УнифицированнаяСтруктураСобытия.НомерТелефонаFrom)) + СообщениеОповещенияДействие;
			
			Если ИспользоватьСистемуВзаимодействия = Истина Тогда
				
				СотрудникиОповещения.Добавить(АктивныйСеансПользователя.Пользователь);
				
			Иначе
				
				ПараметрыОповещения = Новый_Массив(УнифицированнаяСтруктураСобытия.ПОIPТелефонии,
											   	   УнифицированнаяСтруктураСобытия.IDЗвонка,
												   УнифицированнаяСтруктураСобытия.НомерТелефонаFrom,
												   УнифицированнаяСтруктураСобытия.НомерТелефонаTo,
												   УнифицированнаяСтруктураСобытия.Контрагент);
				
				// Создаем оповещение через регистр сведений.
				РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(АктивныйСеансПользователя.РабочееМесто, 
																						Неопределено, 
																						"IPТелефония_ВходящийЗвонок",
																						ТекущаяДатаСеанса(), 
																						20,
																						"Входящий звонок", 
																						СообщениеОповещения,
																						ПараметрыОповещения);
			КонецЕсли;
		КонецЦикла; 
		
		Если ИспользоватьСистемуВзаимодействия = Истина И ЗначениеЗаполнено(СотрудникиОповещения) Тогда
			
			// Создаем оповещение через систему взаимодействия.
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("Ключ"					, "IPТелефония_ВходящийЗвонок");
			ДанныеСообщения.Вставить("IPТелефония"			, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(УнифицированнаяСтруктураСобытия.ПОIPТелефонии));
			ДанныеСообщения.Вставить("IDЗвонка"	  			, УнифицированнаяСтруктураСобытия.IDЗвонка);
			ДанныеСообщения.Вставить("НомерТелефонаFrom"	, УнифицированнаяСтруктураСобытия.НомерТелефонаFrom);
			ДанныеСообщения.Вставить("НомерТелефонаTo"		, УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
			ДанныеСообщения.Вставить("Контрагент"			, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(УнифицированнаяСтруктураСобытия.Контрагент));
			ДанныеСообщения.Вставить("Заголовок"			, "Входящий звонок");
			ДанныеСообщения.Вставить("ДатаНачалаЗвонка"		, УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова);
			ДанныеСообщения.Вставить("СообщениеОповещения"	, СообщениеОповещения);
			
			ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, СотрудникиОповещения);	
			
		КонецЕсли;
		
	КонецЕсли;	
	
	Если УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсOKTELL Тогда
		Возврат Истина;
	Иначе 	
		// Записываем в историю звонков
		ДобавитьОбновитьЗвонокВИсторию(ПараметрыЗвонка, УнифицированнаяСтруктураСобытия);
	КонецЕсли;

	Возврат Истина;
	
КонецФункции

// Функция - Входщий звонок отвечен
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  НомерТелефонаFrom			 - 	 - 
//  НомерТелефонаTo				 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция СобытиеЗвонокСоединение(ПараметрыЗвонка = Неопределено, УнифицированнаяСтруктураСобытия, ОписаниеОшибки = "")	
	
	СтрокаТЗЗвонка = РегистрыСведений.ИсторияВызовов.ПолучитьПоIDЗвонка(УнифицированнаяСтруктураСобытия.IDЗвонка);
	ЭтоВходящийЗвонок = (ЗначениеЗаполнено(СтрокаТЗЗвонка) И СтрокаТЗЗвонка.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий);
	
	// При соединении завершаем оповещение пользователя
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий 
		ИЛИ ЭтоВходящийЗвонок Тогда
		Если УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS 
			ИЛИ УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM
			ИЛИ УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсCoMagic Тогда

			СписокАктивныхПользователей = ПолучитьСписокАктивныхПользователей(УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника);
		Иначе 
			СписокАктивныхПользователей = ПолучитьСписокАктивныхПользователей(УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
		КонецЕсли;
		
		ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
		
		Если ИспользоватьСистемуВзаимодействия = Истина Тогда
		
      		Сотрудники 	 = Новый Массив;
			
			Для каждого АктивныйСеансПользователя Из СписокАктивныхПользователей Цикл
				Сотрудники.Добавить(АктивныйСеансПользователя.Пользователь);
			КонецЦикла;
			
			Если Сотрудники.Количество() > 0 Тогда
				
				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("Ключ"				, "IPТелефония_ОткрытьФормуВзаимодействияСКлиентом");
				ДанныеСообщения.Вставить("IPТелефония"		, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(УнифицированнаяСтруктураСобытия.ПОIPТелефонии));
				ДанныеСообщения.Вставить("IDЗвонка"			, УнифицированнаяСтруктураСобытия.IDЗвонка);
				ДанныеСообщения.Вставить("IDПлеча"			, УнифицированнаяСтруктураСобытия.IDПлеча);
				ДанныеСообщения.Вставить("НомерТелефонаFrom", УнифицированнаяСтруктураСобытия.НомерТелефонаFrom);
				ДанныеСообщения.Вставить("НомерТелефонаTo"	, УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
				ДанныеСообщения.Вставить("ДатаНачалаЗвонка"	, УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов);
				
				ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, Сотрудники); 
				
			КонецЕсли;
		
		Иначе
			
			// Оповещение через регистр сведений.
			Для Каждого АктивныйСеансПользователя Из СписокАктивныхПользователей Цикл
				
				// Завершаем оповещение пользователя
				РегистрыСведений.ОповещениеМониторингКлиента.ЗавершитьОповещениеКлиента(АктивныйСеансПользователя.РабочееМесто, Неопределено, "IPТелефония_ВходящийЗвонок");
				
				// Создаем оповещение открытия формы взаимодействия с клиентом
				МассивПараметров = Новый_Массив(УнифицированнаяСтруктураСобытия.ПОIPТелефонии,
												УнифицированнаяСтруктураСобытия.IDЗвонка,
												УнифицированнаяСтруктураСобытия.IDПлеча,
												УнифицированнаяСтруктураСобытия.НомерТелефонаFrom,
												УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
				
				РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(АктивныйСеансПользователя.РабочееМесто,
																					   Неопределено, 
																					   "IPТелефония_ОткрытьФормуВзаимодействияСКлиентом",
																					   ТекущаяДатаСеанса(),
																					   60,,,
																					   МассивПараметров);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Если УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсOKTELL Тогда
		Возврат Истина;
	Иначе 		
		// Записываем в историю звонков
		ДобавитьОбновитьЗвонокВИсторию(ПараметрыЗвонка, УнифицированнаяСтруктураСобытия);			
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Функция - Входщий звонок завершен
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  НомерТелефонаFrom			 - 	 - 
//  НомерТелефонаTo			 - 	 - 
//  ПродолжительностьЗвонка			 - 	 - 
//  СсылкаНаЗаписьЗвонка			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция СобытиеЗвонокЗавершен(ПараметрыЗвонка = Неопределено, УнифицированнаяСтруктураСобытия, ОписаниеОшибки = "")
	
	Результат = Истина;
	
	// При завершении звонка завершаем оповещение пользователя и создаем оповещение результата разговора
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда
		Если УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS 
			ИЛИ УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM 
			ИЛИ УнифицированнаяСтруктураСобытия.ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсCoMagic Тогда

			СписокАктивныхПользователей = ПолучитьСписокАктивныхПользователей(УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника);
		Иначе 
			СписокАктивныхПользователей = ПолучитьСписокАктивныхПользователей(УнифицированнаяСтруктураСобытия.НомерТелефонаTo);
		КонецЕсли;	
		Для Каждого АктивныйСеансПользователя Из СписокАктивныхПользователей Цикл
			
			РегистрыСведений.ОповещениеМониторингКлиента.ЗавершитьОповещениеКлиента(АктивныйСеансПользователя.РабочееМесто, Неопределено, "IPТелефония_ВходящийЗвонок");
			
		КонецЦикла;
	КонецЕсли;	
	
	// Записываем в историю звонков
	ДобавитьОбновитьЗвонокВИсторию(ПараметрыЗвонка, УнифицированнаяСтруктураСобытия);
	
	Возврат Результат;
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  НомерТелефонаSIPСотрудник		 - 	 - 
//  ВнешнийНомерТелефонаКонтрагент	 - 	 - 
//  Сотрудник						 - 	 - 
//  Контрагент						 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ИсходящийЗвонокОсуществить(ПОIPТелефонии, НомерТелефонаSIPСотрудник, ВнешнийНомерТелефонаКонтрагент, Знач Сотрудник = Неопределено, Знач Контрагент = Неопределено, ОписаниеОшибки = "") Экспорт
	
	// Получение номера телефона сотрудника
	НомерТелефонаSIP = "";
	Если ТипЗнч(НомерТелефонаSIPСотрудник) = Тип("СправочникСсылка.Сотрудники") 
		ИЛИ ТипЗнч(НомерТелефонаSIPСотрудник) = Тип("СправочникСсылка.Пользователи") Тогда
		МассивТелефонныхАппаратовСотрудника = ПолучитьСтруктуруВнутреннегоНомераПоПользователю(НомерТелефонаSIPСотрудник);
		Если МассивТелефонныхАппаратовСотрудника.Количество() = 0 Тогда
			ОписаниеОшибки = "Менеджер '" + ПараметрыСеанса.ТекущийПользователь + "' не в сети или внутренний номер телефона не зарегистрирован.";
			Возврат Ложь;
		ИначеЕсли Не ЗначениеЗаполнено(МассивТелефонныхАппаратовСотрудника[0].НомерТелефона) Тогда
			ОписаниеОшибки = "Внутренний номер телефона на менеджера '" + ПараметрыСеанса.ТекущийПользователь + "' не зарегистрирован.";
			Возврат Ложь;			
		КонецЕсли;
		Сотрудник = НомерТелефонаSIPСотрудник;
		НомерТелефонаSIP = МассивТелефонныхАппаратовСотрудника[0].НомерТелефона;
	Иначе
		НомерТелефонаSIP = НомерТелефонаSIPСотрудник;
	КонецЕсли;
	
	// Получение номера телефона контрагента
	ВнешнийНомерТелефона = "";
	Если ТипЗнч(ВнешнийНомерТелефонаКонтрагент) = Тип("СправочникСсылка.Контрагенты") Тогда
		НайденнаяСтрокаНомера = Контрагент.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, "Вид");
		Если НайденнаяСтрокаНомера = Неопределено ИЛИ Не ЗначениеЗаполнено(НайденнаяСтрокаНомера.НомерТелефона) Тогда
			ОписаниеОшибки = "У контрагента не заполнен номер телефона";
			Возврат Ложь;
		КонецЕсли;
		Контрагент = ВнешнийНомерТелефонаКонтрагент;
		ВнешнийНомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НайденнаяСтрокаНомера.НомерТелефона);
	Иначе
		ВнешнийНомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(ВнешнийНомерТелефонаКонтрагент, Ложь);
	КонецЕсли;
	
	Если НомерТелефонаSIP = "" Тогда
		ОписаниеОшибки = "Пустой номер телефона сотрудника";
		Возврат Ложь;
	ИначеЕсли ВнешнийНомерТелефона = "" Тогда
		ОписаниеОшибки = "Пустой номер телефона клиента";
		Возврат Ложь;	
	КонецЕсли;
	
	// Осуществляем звонок
	Если ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсOKTELL Тогда
		// Записываем в историю звонков
		УнифицированнаяСтруктураСобытия 								= ПолучитьУнифицированнуюСтруктуруСобытия();
		УнифицированнаяСтруктураСобытия.ПОIPТелефонии 					= ПОIPТелефонии;
		УнифицированнаяСтруктураСобытия.IDЗвонка 						= Строка(Новый УникальныйИдентификатор);
		УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 			= Ложь;
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 				= НомерТелефонаSIP;
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   				= ВнешнийНомерТелефона;
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 				= Перечисления.ВариантыНаправленияВызова.Исходящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 					= Перечисления.СтатусыЗвонка.Вызов;			
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 			= ТекущаяДатаСеанса();
		
		ДобавитьОбновитьЗвонокВИсторию(, УнифицированнаяСтруктураСобытия);

		Возврат OKTELL_ИсходящийЗвонокОсуществить(ПОIPТелефонии, НомерТелефонаSIP, ВнешнийНомерТелефона, Контрагент, Сотрудник, ОписаниеОшибки);
		
	ИначеЕсли ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсMANGO Тогда
		Возврат MANGO_ИсходящийЗвонокОсуществить(ПОIPТелефонии, НомерТелефонаSIP, ВнешнийНомерТелефона, ОписаниеОшибки);
		
	ИначеЕсли ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS Тогда
		Возврат ITOOLABS_ИсходящийЗвонокОсуществить(ПОIPТелефонии, НомерТелефонаSIP, ВнешнийНомерТелефона, ОписаниеОшибки);
		
	ИначеЕсли ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсBINOTEL Тогда
		Возврат BINOTEL_ИсходящийЗвонокОсуществить(ПОIPТелефонии, НомерТелефонаSIP, ВнешнийНомерТелефона, ОписаниеОшибки);
		
	ИначеЕсли ПОIPТелефонии.ДрайверОборудования.ОбработчикДрайвера = Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM Тогда
