&НаКлиенте
// Процедура, обработчик завершения выемки из кассы.
//
Процедура ВыемкаВыручкиЗавершение(Результат, Параметры) Экспорт
	
	ТекущиеДанные = Параметры;
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("СуммаДокумента") И Результат.СуммаДокумента > 0 Тогда 				
		// 1. Формирование документов выемки из кассы.
		ОписаниеОшибки  = Неопределено;
		РезультатВыемки = РозничныеПродажи.СформироватьВыемкуИзКассы(Результат, ОписаниеОшибки);
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			
			ТекстСообщения = НСтр("ru='При выемке денег произошла ошибка.
			                      |Дополнительное описание: %ДополнительноеОписание%';
								  |en='With the notch of money happened mistake.
								  |Additional description: %ДополнительноеОписание%'");
			
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Иначе
			ДокументВыемки = РезультатВыемки.ДокВыемки;
			
			СтатусФР = РозничныеПродажи.ПроверитьИспользованиеФРвКассе(ТекущиеДанные.Касса);		
			Если СтатусФР И ЗначениеЗаполнено(ДокументВыемки) Тогда
				// 2. Выполняем команду выемки на ФР
				ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ТекущиеДанные.Касса);
				
				ПараметрыОперации = Новый Структура;
				ПараметрыОперации.Вставить("ТипИнкассации"	, 0);
				ПараметрыОперации.Вставить("Сумма"			, Результат.СуммаДокумента);
				ПараметрыОперации.Вставить("Документ"		, ДокументВыемки);
				ПараметрыОперации.Вставить("Организация"	, ТекущиеДанные.Организация);     				
				ПараметрыОперации.Вставить("Касса"			, ТекущиеДанные.Касса);
				
				ОповещениеПриЗавершении = Новый ОписаниеОповещения("ИнкассацияНаФискальномУстройствеЗавершение", ЭтотОбъект);
				МенеджерОборудованияКлиент.НачатьИнкассациюНаФискальномУстройстве(
																	ОповещениеПриЗавершении,
																	УникальныйИдентификатор,
																	ПараметрыОперации,
																	ИдентификаторУстройстваФР);			
			КонецЕсли;			
		КонецЕсли;			
	КонецЕсли;
	
	ЗаполнитьИнформациюПоКассам();
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет поступление денег в кассу завершение.
//
Процедура ПоступлениеВКассуЗавершение(Результат, Параметры) Экспорт
	
	ТекущиеДанные = Параметры;
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("СуммаДокумента") И Результат.СуммаДокумента > 0 Тогда 				
		
		ОписаниеОшибки   = Неопределено;
		ПараметрыИспользованияКассовойСмены = Новый Структура("ТекущиеДанные, СтруктураДанных", ТекущиеДанные, Результат);
		РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, ТекущиеДанные.Касса, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки);
		
	Иначе 
		ЗаполнитьИнформациюПоКассам();
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения выемки из кассы.
//
Процедура ИнкассацияНаФискальномУстройствеЗавершение(РезультатВыполнения, Параметры) Экспорт
		
	Если РезультатВыполнения.Результат Тогда		
		// Если чек пробился, то возвращаем номер чека ккм в документ (по умолчанию 88888888).
		НомерЧека = 88888888;
		РозничныеПродажи.ЗаписатьНомерЧекаВДокумент(РезультатВыполнения.Документ, НомерЧека);
		
		// Обновление отображения данных.
		ЗаполнитьТаблицыДанных();                                                                                  		
	Иначе
		ТекстСообщения = НСтр("ru='При выполнении операции произошла ошибка.
		|Чек не напечатан на фискальном устройстве.
		|Дополнительное описание: %ДополнительноеОписание%';
		|en='With performing operations happened mistake.
		|Check not printedby on fiscal device.
		|Additional description: %ДополнительноеОписание%'");
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", РезультатВыполнения.ОписаниеОшибки);		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОБРАБОТЧИКИ_ДЛЯ_РАБОТЫ_С_КАССОВОЙ_СМЕНОЙ

&НаКлиенте
// Процедура - После контроля использования кассовой смены.
//
// Параметры:
//  ИспользованиеКассовойСменыРазрешено	 - 	 - 
//  ПараметрыИспользованияКассовойСмены	 - 	 - 
//  ОписаниеОшибки						 - 	 - 
//
Процедура ПослеКонтроляИспользованияКассовойСмены(ИспользованиеКассовойСменыРазрешено, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки) Экспорт 
	
	Если ИспользованиеКассовойСменыРазрешено = Ложь Тогда
		ПоказатьПредупреждение(, ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	// 1. Формирование документов поступления денег в кассу.
	ОписаниеОшибки  = Неопределено;
	РезультатВыемки = РозничныеПродажи.СформироватьПоступлениеВОперационнуюКассуИзкассыПредприятия(ТекущаяДата(), ПараметрыИспользованияКассовойСмены.СтруктураДанных, ОписаниеОшибки);
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ТекстСообщения = НСтр("ru='При поступление денег произошла ошибка.
		                      |Дополнительное описание: %ДополнительноеОписание%';
							  |en='With receipt of money happened mistake.
		                      |Additional description: %ДополнительноеОписание%'");
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);			
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		ДокументПоступления = РезультатВыемки.ДокПоступления;
		
		СтатусФР = РозничныеПродажи.ПроверитьИспользованиеФРвКассе(ПараметрыИспользованияКассовойСмены.ТекущиеДанные.Касса);		
		Если СтатусФР И ЗначениеЗаполнено(ДокументПоступления) Тогда
			// 2. Выполняем команду поступления денег на ФР
			ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ПараметрыИспользованияКассовойСмены.ТекущиеДанные.Касса);
			
			ПараметрыОперации = Новый Структура;
			ПараметрыОперации.Вставить("ТипИнкассации"	, 1);
			ПараметрыОперации.Вставить("Сумма"			, ПараметрыИспользованияКассовойСмены.СтруктураДанных.СуммаДокумента);
			ПараметрыОперации.Вставить("Документ"		, ДокументПоступления);
			ПараметрыОперации.Вставить("Организация"	, ПараметрыИспользованияКассовойСмены.ТекущиеДанные.Организация);
			ПараметрыОперации.Вставить("Касса"	  		, ПараметрыИспользованияКассовойСмены.ТекущиеДанные.Касса);
			
			ОповещениеПриЗавершении = Новый ОписаниеОповещения("ИнкассацияНаФискальномУстройствеЗавершение", ЭтотОбъект);
			МенеджерОборудованияКлиент.НачатьИнкассациюНаФискальномУстройстве(ОповещениеПриЗавершении, УникальныйИдентификатор, ПараметрыОперации, ИдентификаторУстройстваФР);			
		КонецЕсли;			
	КонецЕсли;					
	
	ЗаполнитьИнформациюПоКассам();
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция возвращает вариант отчета
