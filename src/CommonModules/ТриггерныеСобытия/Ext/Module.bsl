КонецФункции

// Функция - Получить данные события сделка задержка на этапе
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_СделкаЗадержкаНаЭтапе(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		
#КонецОбласти
		
	Иначе
		 
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		ЗадержкаМинут = 0;
		Запрос.УстановитьПараметр("ДатаВыборки"				, ПолучитьДатуТриггера(ДанныеТриггера, ЗадержкаМинут));
		Если ЗадержкаМинут = 0 Тогда 
			Возврат Неопределено;
		КонецЕсли;	
		Запрос.УстановитьПараметр("ТриггерноеСобытие"		, ДанныеТриггера.ТриггерноеСобытие);
		Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
		Запрос.УстановитьПараметр("ВидСделки"				, ДанныеТриггера.ВидСделки);
		Запрос.УстановитьПараметр("ЗадержкаНаЭтапе"			, ДанныеТриггера.ПереходСЭтапа);
		Запрос.УстановитьПараметр("ПараметрЗадержкаМинут"	, ЗадержкаМинут);
		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ИсторияИзмененияЭтапаСделок.Ссылка КАК Сделка
		               |ПОМЕСТИТЬ АнализируемаяТаблицаСделок
		               |ИЗ
		               |	Справочник.Сделки.ИсторияИзмененияЭтапов КАК ИсторияИзмененияЭтапаСделок
		               |ГДЕ
		               |	ИсторияИзмененияЭтапаСделок.Ссылка.ПометкаУдаления = ЛОЖЬ
		               |	И ИсторияИзмененияЭтапаСделок.Ссылка.ВидСделки = &ВидСделки
		               |	И ИсторияИзмененияЭтапаСделок.Ссылка.Контрагент В(&СегментКонтрагентов)
		               |	И ИсторияИзмененияЭтапаСделок.Дата > ДОБАВИТЬКДАТЕ(&ДатаВыборки, МИНУТА, -240)
		               |	И ИсторияИзмененияЭтапаСделок.ПереходНаЭтап = &ЗадержкаНаЭтапе
		               |	И ИсторияИзмененияЭтапаСделок.Ссылка.Контрагент.ОбезличенныйКлиент = ЛОЖЬ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ИсторияИзмененияЭтапаСделок.Ссылка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	АнализируемаяТаблицаСделок.Сделка КАК Сделка
		               |ПОМЕСТИТЬ ТаблицаОтработанныхСобытий
		               |ИЗ
		               |	АнализируемаяТаблицаСделок КАК АнализируемаяТаблицаСделок
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		               |			И (АнализируемаяТаблицаСделок.Сделка = (ВЫРАЗИТЬ(ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК Справочник.Сделки)))
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СделкиИсторияИзмененияЭтапов.Ссылка КАК Ссылка,
		               |	СделкиИсторияИзмененияЭтапов.НомерСтроки КАК НомерСтроки,
		               |	СделкиИсторияИзмененияЭтапов.Дата КАК Дата,
		               |	СделкиИсторияИзмененияЭтапов.ПереходСЭтапа КАК ПереходСЭтапа,
		               |	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап КАК ПереходНаЭтап
		               |ПОМЕСТИТЬ ТаблицаИсторииИзмененияЭтапов
		               |ИЗ
		               |	Справочник.Сделки.ИсторияИзмененияЭтапов КАК СделкиИсторияИзмененияЭтапов
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АнализируемаяТаблицаСделок КАК АнализируемаяТаблицаСделок
		               |		ПО СделкиИсторияИзмененияЭтапов.Ссылка = АнализируемаяТаблицаСделок.Сделка
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхСобытий КАК ТаблицаОтработанныхСобытий
		               |		ПО СделкиИсторияИзмененияЭтапов.Ссылка = ТаблицаОтработанныхСобытий.Сделка
		               |ГДЕ
		               |	ТаблицаОтработанныхСобытий.Сделка ЕСТЬ NULL
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	СделкиИсторияИзмененияЭтапов.Ссылка,
		               |	СделкиИсторияИзмененияЭтапов.Дата,
		               |	СделкиИсторияИзмененияЭтапов.ПереходСЭтапа,
		               |	СделкиИсторияИзмененияЭтапов.ПереходНаЭтап,
		               |	СделкиИсторияИзмененияЭтапов.НомерСтроки
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаИсторииИзмененияЭтапов.Ссылка КАК Ссылка,
		               |	ТаблицаИсторииИзмененияЭтапов.НомерСтроки КАК НомерСтроки,
		               |	ТаблицаИсторииИзмененияЭтапов.Дата КАК Дата,
		               |	ТаблицаИсторииИзмененияЭтапов.ПереходСЭтапа КАК ПереходСЭтапа,
		               |	ТаблицаИсторииИзмененияЭтапов.ПереходНаЭтап КАК ПереходНаЭтап,
		               |	КОЛИЧЕСТВО(ТаблицаИсторииИзмененияЭтапов1.ПереходНаЭтап) КАК НомерПоПорядку
		               |ПОМЕСТИТЬ ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов
		               |ИЗ
		               |	ТаблицаИсторииИзмененияЭтапов КАК ТаблицаИсторииИзмененияЭтапов
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаИсторииИзмененияЭтапов КАК ТаблицаИсторииИзмененияЭтапов1
		               |		ПО ТаблицаИсторииИзмененияЭтапов.Дата >= ТаблицаИсторииИзмененияЭтапов1.Дата
		               |			И (ВЫБОР
		               |				КОГДА ТаблицаИсторииИзмененияЭтапов.Дата = ТаблицаИсторииИзмененияЭтапов1.Дата
		               |					ТОГДА ТаблицаИсторииИзмененияЭтапов.НомерСтроки >= ТаблицаИсторииИзмененияЭтапов1.НомерСтроки
		               |				ИНАЧЕ ИСТИНА
		               |			КОНЕЦ)
		               |			И ТаблицаИсторииИзмененияЭтапов.Ссылка = ТаблицаИсторииИзмененияЭтапов1.Ссылка
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ТаблицаИсторииИзмененияЭтапов.Ссылка,
		               |	ТаблицаИсторииИзмененияЭтапов.НомерСтроки,
		               |	ТаблицаИсторииИзмененияЭтапов.Дата,
		               |	ТаблицаИсторииИзмененияЭтапов.ПереходСЭтапа,
		               |	ТаблицаИсторииИзмененияЭтапов.ПереходНаЭтап
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.Ссылка КАК Сделка,
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.НомерСтроки КАК НомерСтроки,
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.Дата КАК Дата,
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.ПереходСЭтапа КАК ПереходСЭтапа,
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.ПереходНаЭтап КАК ПереходНаЭтап,
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.НомерПоПорядку КАК НомерПоПорядку,
		               |	РАЗНОСТЬДАТ(ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.Дата, ЕСТЬNULL(ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов1.Дата, &ТекущаяДата), МИНУТА) КАК ЗадержкаНаЭтапе
		               |ПОМЕСТИТЬ ИтоговаяТаблица
		               |ИЗ
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов КАК ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов КАК ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов1
		               |		ПО (ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.НомерПоПорядку = ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов1.НомерПоПорядку - 1)
		               |			И ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.ПереходНаЭтап = ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов1.ПереходСЭтапа
		               |			И ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.Дата <> ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов1.Дата
		               |			И ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.Ссылка = ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов1.Ссылка
		               |ГДЕ
		               |	ТаблицаПорядковыхНомеровИсторииИзмененияЭтапов.ПереходНаЭтап = &ЗадержкаНаЭтапе
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ИтоговаяТаблица.Сделка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ИтоговаяТаблица.Сделка КАК Сделка,
		               |	ИтоговаяТаблица.Сделка КАК ОбъектСобытия,
		               |	ИтоговаяТаблица.Сделка.Контрагент КАК Контрагент,
		               |	ИтоговаяТаблица.ПереходСЭтапа КАК ПереходСЭтапа,
		               |	ИтоговаяТаблица.ПереходНаЭтап КАК ПереходНаЭтап,
		               |	МАКСИМУМ(ИтоговаяТаблица.Дата) КАК ДатаПереходаНаЭтап,
		               |	СРЕДНЕЕ(ИтоговаяТаблица.ЗадержкаНаЭтапе) КАК ЗадержкаНаЭтапе,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ИтоговаяТаблица КАК ИтоговаяТаблица
		               |ГДЕ
		               |	ИтоговаяТаблица.ЗадержкаНаЭтапе > &ПараметрЗадержкаМинут
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ИтоговаяТаблица.Сделка.СтруктурнаяЕдиница,
		               |	ИтоговаяТаблица.Сделка,
		               |	ИтоговаяТаблица.Сделка.Контрагент,
		               |	ИтоговаяТаблица.ПереходСЭтапа,
		               |	ИтоговаяТаблица.ПереходНаЭтап,
		               |	ИтоговаяТаблица.Сделка";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияИзмененияЭтапаСделок.Ссылка.Контрагент В(&СегментКонтрагентов)",
			"ИсторияИзмененияЭтапаСделок.Ссылка.Контрагент В
			|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
			|				ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты)
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов И НЕ ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты) ЕСТЬ NULL)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияИзмененияЭтапаСделок.Ссылка.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лицевой счет взнос
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛицевойСчетВзнос(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
		
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("ПоступлениеДенежныхСредств"	, ОбъектСобытия);
		Запрос.УстановитьПараметр("ТекущаяДата"					, ТекущаяДатаСеанса());

		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоступлениеДенежныхСредств.Ссылка КАК ОбъектСобытия,
		|	ПоступлениеДенежныхСредств.ЛицевойСчетКонтрагента КАК ЛицевойСчет,
		|	ВЫБОР
		|		КОГДА ПоступлениеДенежныхСредств.Контрагент ССЫЛКА Справочник.Контрагенты
		|			ТОГДА ВЫРАЗИТЬ(ПоступлениеДенежныхСредств.Контрагент КАК Справочник.Контрагенты)
		|		КОГДА ПоступлениеДенежныхСредств.Контрагент ССЫЛКА Справочник.Сотрудники
		|			ТОГДА ВЫРАЗИТЬ(ПоступлениеДенежныхСредств.Контрагент КАК Справочник.Сотрудники).Контрагент
		|		ИНАЧЕ ВЫРАЗИТЬ(ПоступлениеДенежныхСредств.Контрагент КАК Справочник.Контрагенты)
		|	КОНЕЦ КАК Контрагент,
		|	ПоступлениеДенежныхСредств.Дата КАК ДатаПлатежа,
		|	ПоступлениеДенежныхСредств.ЛицевойСчетКонтрагента КАК ВидЛицевогоСчета,
		|	ПоступлениеДенежныхСредств.СуммаДокумента КАК СуммаВзноса
		|ПОМЕСТИТЬ ТаблицаУчтенныхАвансов
		|ИЗ
		|	Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
		|ГДЕ
		|	ПоступлениеДенежныхСредств.Ссылка = &ПоступлениеДенежныхСредств
		|	И ПоступлениеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВзносНаЛицевойСчет)
		|	И НАЧАЛОПЕРИОДА(ПоступлениеДенежныхСредств.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаУчтенныхАвансов.ОбъектСобытия.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаУчтенныхАвансов.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаУчтенныхАвансов.ЛицевойСчет КАК ЛицевойСчет,
		|	ТаблицаУчтенныхАвансов.Контрагент КАК Контрагент,
		|	ТаблицаУчтенныхАвансов.ДатаПлатежа КАК ДатаПлатежа,
		|	ТаблицаУчтенныхАвансов.СуммаВзноса КАК СуммаВзноса,
		|	ТаблицаУчтенныхАвансов.ВидЛицевогоСчета КАК ВидЛицевогоСчета
		|ПОМЕСТИТЬ ТаблицаУчтенныхАвансовСОтбором
		|ИЗ
		|	ТаблицаУчтенныхАвансов КАК ТаблицаУчтенныхАвансов
		|ГДЕ
		|	ТаблицаУчтенныхАвансов.ВидЛицевогоСчета = &ВидЛицевогоСчета
		|	И ТаблицаУчтенныхАвансов.Контрагент В(&СегментКонтрагентов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДенежныеСредстваНаЛицевыхСчетах.ВидСчета КАК ЛицевойСчет,
		|	СУММА(ДенежныеСредстваНаЛицевыхСчетах.СуммаОстаток) КАК Остаток
		|ПОМЕСТИТЬ ТаблицаОстатковПоЛицевомуСчету
		|ИЗ
		|	РегистрНакопления.ДенежныеСредстваНаЛицевыхСчетах.Остатки(
		|			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
		|			Контрагент В
		|					(ВЫБРАТЬ
		|						ТаблицаУчтенныхАвансовСОтбором.Контрагент
		|					ИЗ
		|						ТаблицаУчтенныхАвансовСОтбором)
		|				И ВидСчета В
		|					(ВЫБРАТЬ
		|						ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет
		|					ИЗ
		|						ТаблицаУчтенныхАвансовСОтбором)) КАК ДенежныеСредстваНаЛицевыхСчетах
		|
		|СГРУППИРОВАТЬ ПО
		|	ДенежныеСредстваНаЛицевыхСчетах.ВидСчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаУчтенныхАвансовСОтбором.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаУчтенныхАвансовСОтбором.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет КАК ВидЛицевогоСчета,
		|	ТаблицаУчтенныхАвансовСОтбором.Контрагент КАК Контрагент,
		|	ТаблицаУчтенныхАвансовСОтбором.ДатаПлатежа КАК ДатаПлатежа,
		|	ТаблицаУчтенныхАвансовСОтбором.СуммаВзноса КАК СуммаВзноса,
		|	ЕСТЬNULL(ТаблицаОстатковПоЛицевомуСчету.Остаток, 0) КАК Остаток,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаУчтенныхАвансовСОтбором КАК ТаблицаУчтенныхАвансовСОтбором
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатковПоЛицевомуСчету КАК ТаблицаОстатковПоЛицевомуСчету
		|		ПО ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет = ТаблицаОстатковПоЛицевомуСчету.ЛицевойСчет";
	
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.Контрагент В(&СегментКонтрагентов)",
					"ТаблицаУчтенныхАвансов.Контрагент В
	               |					(ВЫБРАТЬ
	               |						КонтрагентыСегмента.Контрагент
	               |					ИЗ
	               |						РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
	               |					ГДЕ
	               |						КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидЛицевогоСчета) Тогда
			Запрос.УстановитьПараметр("ВидЛицевогоСчета", ДанныеТриггера.ВидЛицевогоСчета);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.ВидЛицевогоСчета = &ВидЛицевогоСчета", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лицевой счет списание
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛицевойСчетСписание(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
		
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("СписаниеДенежныхСредств"		, ОбъектСобытия);
		Запрос.УстановитьПараметр("ТекущаяДата"					, ТекущаяДатаСеанса());

		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СписаниеДенежныхСредств.Ссылка КАК ОбъектСобытия,
		|	СписаниеДенежныхСредств.ЛицевойСчетКонтрагента КАК ЛицевойСчет,
		|	ВЫБОР
		|		КОГДА СписаниеДенежныхСредств.Контрагент ССЫЛКА Справочник.Контрагенты
		|			ТОГДА ВЫРАЗИТЬ(СписаниеДенежныхСредств.Контрагент КАК Справочник.Контрагенты)
		|		КОГДА СписаниеДенежныхСредств.Контрагент ССЫЛКА Справочник.Сотрудники
		|			ТОГДА ВЫРАЗИТЬ(СписаниеДенежныхСредств.Контрагент КАК Справочник.Сотрудники).Контрагент
		|		ИНАЧЕ ВЫРАЗИТЬ(СписаниеДенежныхСредств.Контрагент КАК Справочник.Контрагенты)
		|	КОНЕЦ КАК Контрагент,
		|	СписаниеДенежныхСредств.Дата КАК ДатаПлатежа,
		|	СписаниеДенежныхСредств.ЛицевойСчетКонтрагента КАК ВидЛицевогоСчета,
		|	СписаниеДенежныхСредств.СуммаДокумента КАК СуммаСписания
		|ПОМЕСТИТЬ ТаблицаУчтенныхАвансов
		|ИЗ
		|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
		|ГДЕ
		|	СписаниеДенежныхСредств.Ссылка = &СписаниеДенежныхСредств
		|	И СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)
		|	И НАЧАЛОПЕРИОДА(СписаниеДенежныхСредств.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаУчтенныхАвансов.ОбъектСобытия.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаУчтенныхАвансов.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаУчтенныхАвансов.ЛицевойСчет КАК ЛицевойСчет,
		|	ТаблицаУчтенныхАвансов.Контрагент КАК Контрагент,
		|	ТаблицаУчтенныхАвансов.ДатаПлатежа КАК ДатаПлатежа,
		|	ТаблицаУчтенныхАвансов.СуммаСписания КАК СуммаСписания
		|ПОМЕСТИТЬ ТаблицаУчтенныхАвансовСОтбором
		|ИЗ
		|	ТаблицаУчтенныхАвансов КАК ТаблицаУчтенныхАвансов
		|ГДЕ
		|	ТаблицаУчтенныхАвансов.ВидЛицевогоСчета = &ВидЛицевогоСчета
		|	И ТаблицаУчтенныхАвансов.Контрагент В(&СегментКонтрагентов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДенежныеСредстваНаЛицевыхСчетах.ВидСчета КАК ЛицевойСчет,
		|	СУММА(ДенежныеСредстваНаЛицевыхСчетах.СуммаОстаток) КАК Остаток
		|ПОМЕСТИТЬ ТаблицаОстатковПоЛицевомуСчету
		|ИЗ
		|	РегистрНакопления.ДенежныеСредстваНаЛицевыхСчетах.Остатки(
		|			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
		|			Контрагент В
		|					(ВЫБРАТЬ
		|						ТаблицаУчтенныхАвансовСОтбором.Контрагент
		|					ИЗ
		|						ТаблицаУчтенныхАвансовСОтбором)
		|				И ВидСчета В
		|					(ВЫБРАТЬ
		|						ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет
		|					ИЗ
		|						ТаблицаУчтенныхАвансовСОтбором)) КАК ДенежныеСредстваНаЛицевыхСчетах
		|
		|СГРУППИРОВАТЬ ПО
		|	ДенежныеСредстваНаЛицевыхСчетах.ВидСчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаУчтенныхАвансовСОтбором.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаУчтенныхАвансовСОтбором.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет КАК ВидЛицевогоСчета,
		|	ТаблицаУчтенныхАвансовСОтбором.Контрагент КАК Контрагент,
		|	ТаблицаУчтенныхАвансовСОтбором.ДатаПлатежа КАК ДатаПлатежа,
		|	ТаблицаУчтенныхАвансовСОтбором.СуммаСписания КАК СуммаСписания,
		|	ЕСТЬNULL(ТаблицаОстатковПоЛицевомуСчету.Остаток, 0) КАК Остаток,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаУчтенныхАвансовСОтбором КАК ТаблицаУчтенныхАвансовСОтбором
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатковПоЛицевомуСчету КАК ТаблицаОстатковПоЛицевомуСчету
		|		ПО ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет = ТаблицаОстатковПоЛицевомуСчету.ЛицевойСчет";
	
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.Контрагент В(&СегментКонтрагентов)",
					"ТаблицаУчтенныхАвансов.Контрагент В
	               |					(ВЫБРАТЬ
	               |						КонтрагентыСегмента.Контрагент
	               |					ИЗ
	               |						РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
	               |					ГДЕ
	               |						КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидЛицевогоСчета) Тогда
			Запрос.УстановитьПараметр("ВидЛицевогоСчета", ДанныеТриггера.ВидЛицевогоСчета);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.ВидЛицевогоСчета = &ВидЛицевогоСчета", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лицевой счет критический остаток средств
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛицевойСчетКритическийОстатокСредств(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
		
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("Реализация"					, ОбъектСобытия);
		Запрос.УстановитьПараметр("МинимальноеЗначениеОстатка"	, ДанныеТриггера.ПараметрСобытия);
		Запрос.УстановитьПараметр("ТекущаяДата"					, ТекущаяДатаСеанса());

		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
		               |	РеализацияУчтенныеАвансы.Ссылка КАК ОбъектСобытия,
		               |	РеализацияУчтенныеАвансы.Аванс КАК ЛицевойСчет,
		               |	ВЫБОР
		               |		КОГДА РеализацияУчтенныеАвансы.ВладелецАванса ССЫЛКА Справочник.Контрагенты
		               |			ТОГДА ВЫРАЗИТЬ(РеализацияУчтенныеАвансы.ВладелецАванса КАК Справочник.Контрагенты)
		               |		КОГДА РеализацияУчтенныеАвансы.ВладелецАванса ССЫЛКА Справочник.Сотрудники
		               |			ТОГДА ВЫРАЗИТЬ(РеализацияУчтенныеАвансы.ВладелецАванса КАК Справочник.Сотрудники).Контрагент
		               |		ИНАЧЕ ВЫРАЗИТЬ(РеализацияУчтенныеАвансы.ВладелецАванса КАК Справочник.Контрагенты)
		               |	КОНЕЦ КАК Контрагент,
		               |	РеализацияУчтенныеАвансы.ДатаПлатежа КАК ДатаПлатежа,
		               |	РеализацияУчтенныеАвансы.СуммаАванса КАК СуммаСписания,
		               |	РеализацияУчтенныеАвансы.Ссылка.Контрагент КАК КонтрагентРеализации
		               |ПОМЕСТИТЬ ТаблицаУчтенныхАвансов
		               |ИЗ
		               |	Документ.Реализация.УчтенныеАвансы КАК РеализацияУчтенныеАвансы
		               |ГДЕ
		               |	РеализацияУчтенныеАвансы.Ссылка = &Реализация
		               |	И НЕ РеализацияУчтенныеАвансы.ВладелецАванса ССЫЛКА Справочник.ПартииНоменклатуры
		               |	И НАЧАЛОПЕРИОДА(РеализацияУчтенныеАвансы.ДатаПлатежа, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
		               |	И РеализацияУчтенныеАвансы.ТипАвансовыхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаУчтенныхАвансов.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаУчтенныхАвансов.ЛицевойСчет КАК ЛицевойСчет,
		               |	ВЫБОР
		               |		КОГДА ЕСТЬNULL(ТаблицаУчтенныхАвансов.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		               |			ТОГДА ТаблицаУчтенныхАвансов.КонтрагентРеализации
		               |		ИНАЧЕ ТаблицаУчтенныхАвансов.Контрагент
		               |	КОНЕЦ КАК Контрагент,
		               |	ТаблицаУчтенныхАвансов.ДатаПлатежа КАК ДатаПлатежа,
		               |	ТаблицаУчтенныхАвансов.СуммаСписания КАК СуммаСписания
		               |ПОМЕСТИТЬ ТаблицаУчтенныхАвансовСОтбором
		               |ИЗ
		               |	ТаблицаУчтенныхАвансов КАК ТаблицаУчтенныхАвансов
		               |ГДЕ
		               |	ТаблицаУчтенныхАвансов.ЛицевойСчет.ВидЛицевогоСчета = &ВидЛицевогоСчета
		               |	И ВЫБОР
		               |			КОГДА ЕСТЬNULL(ТаблицаУчтенныхАвансов.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		               |				ТОГДА ТаблицаУчтенныхАвансов.КонтрагентРеализации В (&СегментКонтрагентов)
		               |			ИНАЧЕ ТаблицаУчтенныхАвансов.Контрагент В (&СегментКонтрагентов)
		               |		КОНЕЦ
		               |	И ВЫБОР
		               |			КОГДА ЕСТЬNULL(ТаблицаУчтенныхАвансов.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		               |				ТОГДА ТаблицаУчтенныхАвансов.КонтрагентРеализации.ОбезличенныйКлиент = ЛОЖЬ
		               |			ИНАЧЕ ТаблицаУчтенныхАвансов.Контрагент.ОбезличенныйКлиент = ЛОЖЬ
		               |		КОНЕЦ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	РасчетыСПокупателямиОстаткиИОбороты.Основание КАК ЛицевойСчет,
		               |	СУММА(РасчетыСПокупателямиОстаткиИОбороты.СуммаОборот) КАК Остаток
		               |ПОМЕСТИТЬ ТаблицаОстатковПоЛицевомуСчету
		               |ИЗ
		               |	РегистрНакопления.РасчетыСПокупателями.ОстаткиИОбороты(
		               |			,
		               |			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
		               |			Запись,
		               |			,
		               |			Контрагент В
		               |					(ВЫБРАТЬ
		               |						ТаблицаУчтенныхАвансовСОтбором.Контрагент
		               |					ИЗ
		               |						ТаблицаУчтенныхАвансовСОтбором)
		               |				И Основание В
		               |					(ВЫБРАТЬ
		               |						ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет
		               |					ИЗ
		               |						ТаблицаУчтенныхАвансовСОтбором)
		               |				И ТипРасчета = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.ЛицевойСчет)) КАК РасчетыСПокупателямиОстаткиИОбороты
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	РасчетыСПокупателямиОстаткиИОбороты.Основание
		               |
		               |ИМЕЮЩИЕ
		               |	СУММА(РасчетыСПокупателямиОстаткиИОбороты.СуммаОборот) <= &МинимальноеЗначениеОстатка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаУчтенныхАвансовСОтбором.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет КАК ЛицевойСчет,
		               |	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
		               |	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет.ДатаОткрытия КАК ДатаОткрытия,
		               |	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет.СрокДействияНачало КАК СрокДействияНачало,
		               |	ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет.СрокДействияКонец КАК СрокДействияКонец,
		               |	ТаблицаУчтенныхАвансовСОтбором.Контрагент КАК Контрагент,
		               |	ТаблицаУчтенныхАвансовСОтбором.ДатаПлатежа КАК ДатаПлатежа,
		               |	ТаблицаУчтенныхАвансовСОтбором.СуммаСписания КАК СуммаСписания,
		               |	ТаблицаОстатковПоЛицевомуСчету.Остаток КАК Остаток,
		               |	ТаблицаУчтенныхАвансовСОтбором.ОбъектСобытия.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаУчтенныхАвансовСОтбором КАК ТаблицаУчтенныхАвансовСОтбором
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаОстатковПоЛицевомуСчету КАК ТаблицаОстатковПоЛицевомуСчету
		               |		ПО ТаблицаУчтенныхАвансовСОтбором.ЛицевойСчет = ТаблицаОстатковПоЛицевомуСчету.ЛицевойСчет";
	
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБОР
	               |			КОГДА ЕСТЬNULL(ТаблицаУчтенныхАвансов.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |				ТОГДА ТаблицаУчтенныхАвансов.КонтрагентРеализации В (&СегментКонтрагентов)
	               |			ИНАЧЕ ТаблицаУчтенныхАвансов.Контрагент В (&СегментКонтрагентов)
	               |		КОНЕЦ",
					"ВЫБОР
	               |			КОГДА ЕСТЬNULL(ТаблицаУчтенныхАвансов.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |				ТОГДА ТаблицаУчтенныхАвансов.КонтрагентРеализации В
	               |						(ВЫБРАТЬ
	               |							СоставСегментов.ОбъектСегмента
	               |						ИЗ
	               |							РегистрСведений.СоставСегментов КАК СоставСегментов
	               |						ГДЕ
	               |							СоставСегментов.Сегмент = &СегментКонтрагентов)
	               |			ИНАЧЕ ТаблицаУчтенныхАвансов.Контрагент В
	               |					(ВЫБРАТЬ
	               |						СоставСегментов.ОбъектСегмента
	               |					ИЗ
	               |						РегистрСведений.СоставСегментов КАК СоставСегментов
	               |					ГДЕ
	               |						СоставСегментов.Сегмент = &СегментКонтрагентов)
	               |		КОНЕЦ");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБОР
	               |			КОГДА ЕСТЬNULL(ТаблицаУчтенныхАвансов.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |				ТОГДА ТаблицаУчтенныхАвансов.КонтрагентРеализации В (&СегментКонтрагентов)
	               |			ИНАЧЕ ТаблицаУчтенныхАвансов.Контрагент В (&СегментКонтрагентов)
	               |		КОНЕЦ", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидЛицевогоСчета) Тогда
			Запрос.УстановитьПараметр("ВидЛицевогоСчета", ДанныеТриггера.ВидЛицевогоСчета);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаУчтенныхАвансов.ЛицевойСчет.ВидЛицевогоСчета = &ВидЛицевогоСчета", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лицевой счет окончание срока действия
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛицевойСчетОкончаниеСрокаДействия(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВЫРАЗИТЬ(ЛицевыеСчета.ВладелецЛицевогоСчета КАК Справочник.Контрагенты) КАК Контрагент,
		               |	ЛицевыеСчета.Ссылка КАК ОбъектСобытия,
		               |	ЛицевыеСчета.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
		               |	ЛицевыеСчета.ДатаОткрытия КАК ДатаОткрытия,
		               |	ЛицевыеСчета.СрокДействияНачало КАК СрокДействияНачало,
		               |	ЛицевыеСчета.СрокДействияКонец КАК СрокДействияКонец,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ТаблицаКлиентовСИстекающимиЛицевымиСчетами
		               |ИЗ
		               |	Справочник.ЛицевыеСчета КАК ЛицевыеСчета
		               |ГДЕ
		               |	ЛицевыеСчета.ПометкаУдаления = ЛОЖЬ
		               |	И ЛицевыеСчета.Архивный = ЛОЖЬ
		               |	И ЛицевыеСчета.ВидЛицевогоСчета = &ВидЛицевогоСчета
		               |	И НЕ ВЫРАЗИТЬ(ЛицевыеСчета.ВладелецЛицевогоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |	И ВЫБОР
		               |			КОГДА НЕ ВЫРАЗИТЬ(ЛицевыеСчета.ВладелецЛицевогоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |				ТОГДА ВЫРАЗИТЬ(ЛицевыеСчета.ВладелецЛицевогоСчета КАК Справочник.Контрагенты).ОбезличенныйКлиент = ЛОЖЬ
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ
		               |	И ЛицевыеСчета.ВладелецЛицевогоСчета В(&СегментКонтрагентов)
		               |	И ЛицевыеСчета.Закрыт = ЛОЖЬ
		               |	И НАЧАЛОПЕРИОДА(ЛицевыеСчета.СрокДействияКонец, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК ОбъектСобытия
		               |ПОМЕСТИТЬ ТаблицаОтработанныхТриггеров
		               |ИЗ
		               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |ГДЕ
		               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент В
		               |			(ВЫБРАТЬ
		               |				ТаблицаКлиентовСИстекающимиЛицевымиСчетами.Контрагент
		               |			ИЗ
		               |				ТаблицаКлиентовСИстекающимиЛицевымиСчетами)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.Контрагент КАК Контрагент,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.ДатаОткрытия КАК ДатаОткрытия,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.СрокДействияНачало КАК СрокДействияНачало,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.СрокДействияКонец КАК СрокДействияКонец,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами.РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам
		               |ИЗ
		               |	ТаблицаКлиентовСИстекающимиЛицевымиСчетами КАК ТаблицаКлиентовСИстекающимиЛицевымиСчетами
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхТриггеров КАК ТаблицаОтработанныхТриггеров
		               |		ПО ТаблицаКлиентовСИстекающимиЛицевымиСчетами.Контрагент = ТаблицаОтработанныхТриггеров.Контрагент
		               |			И ТаблицаКлиентовСИстекающимиЛицевымиСчетами.ОбъектСобытия = ТаблицаОтработанныхТриггеров.ОбъектСобытия
		               |ГДЕ
		               |	ТаблицаОтработанныхТриггеров.Контрагент ЕСТЬ NULL
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент
		               |ПОМЕСТИТЬ ТаблицаАктуальныхКлиентов
		               |ИЗ
		               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
		               |			КОНЕЦПЕРИОДА(&ДатаТриггера, ДЕНЬ),
		               |			Контрагент В
		               |				(ВЫБРАТЬ
		               |					ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.Контрагент
		               |				ИЗ
		               |					ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам)) КАК СтатусыКонтрагентовСрезПоследних
		               |ГДЕ
		               |	СтатусыКонтрагентовСрезПоследних.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.Контрагент КАК Контрагент,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.ДатаОткрытия КАК ДатаОткрытия,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.СрокДействияНачало КАК СрокДействияНачало,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.СрокДействияКонец КАК СрокДействияКонец,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.Контрагент.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов
		               |ИЗ
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам КАК ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам
		               |ГДЕ
		               |	ТаблицаНеОтработанныхКлиентовПоЛицевымСчетам.Контрагент В
		               |			(ВЫБРАТЬ
		               |				ТаблицаАктуальныхКлиентов.Контрагент
		               |			ИЗ
		               |				ТаблицаАктуальныхКлиентов)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	РасчетыСПокупателямиОстаткиИОбороты.Основание КАК ЛицевойСчет,
		               |	СУММА(РасчетыСПокупателямиОстаткиИОбороты.СуммаОборот) КАК Остаток
		               |ПОМЕСТИТЬ ТаблицаОстатковПоЛицевомуСчету
		               |ИЗ
		               |	РегистрНакопления.РасчетыСПокупателями.ОстаткиИОбороты(
		               |			,
		               |			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
		               |			Запись,
		               |			,
		               |			Контрагент В
		               |					(ВЫБРАТЬ
		               |						ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.Контрагент
		               |					ИЗ
		               |						ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов)
		               |				И Основание В
		               |					(ВЫБРАТЬ
		               |						ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.ОбъектСобытия
		               |					ИЗ
		               |						ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов)
		               |				И ТипРасчета = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.ЛицевойСчет)) КАК РасчетыСПокупателямиОстаткиИОбороты
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	РасчетыСПокупателямиОстаткиИОбороты.Основание
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.Контрагент КАК Контрагент,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.ОбъектСобытия КАК ОбъектСобытия,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.ВидЛицевогоСчета КАК ВидЛицевогоСчета,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.ДатаОткрытия КАК ДатаОткрытия,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.СрокДействияНачало КАК СрокДействияНачало,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.СрокДействияКонец КАК СрокДействияКонец,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.РегистрацияЗапланированных КАК РегистрацияЗапланированных,
		               |	ТаблицаОстатковПоЛицевомуСчету.Остаток КАК Остаток
		               |ИЗ
		               |	ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов КАК ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатковПоЛицевомуСчету КАК ТаблицаОстатковПоЛицевомуСчету
		               |		ПО ИтоговаяТаблицаЗакрывающихсяЛицевыхСчетов.ОбъектСобытия = ТаблицаОстатковПоЛицевомуСчету.ЛицевойСчет";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЛицевыеСчета.ВладелецЛицевогоСчета В(&СегментКонтрагентов)",
			"ЛицевыеСчета.ВладелецЛицевогоСчета В
			|			(ВЫБРАТЬ
			|				СоставСегментов.ОбъектСегмента
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЛицевыеСчета.ВладелецЛицевогоСчета В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидЛицевогоСчета) Тогда
			Запрос.УстановитьПараметр("ВидЛицевогоСчета", ДанныеТриггера.ВидЛицевогоСчета);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЛицевыеСчета.ВидЛицевогоСчета = &ВидЛицевогоСчета", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события бонусный счет начисление
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_БонусныйСчетНачисление(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
		
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("ДокументНачисления"	, ОбъектСобытия);
		Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());

		Запрос.Текст = "ВЫБРАТЬ
		               |	БонусныеСчетаОбороты.Регистратор КАК ОбъектСобытия,
		               |	БонусныеСчетаОбороты.БонусныйСчет КАК БонусныйСчет,
		               |	БонусныеСчетаОбороты.Период КАК ДатаПлатежа,
		               |	ЕСТЬNULL(СУММА(БонусныеСчетаОбороты.СуммаПриход), 0) КАК СуммаНачисления
		               |ПОМЕСТИТЬ ТаблицаОперацийСБонуснымСчетом
		               |ИЗ
		               |	РегистрНакопления.БонусныеСчета.Обороты(НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ), КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ), Регистратор, ) КАК БонусныеСчетаОбороты
		               |ГДЕ
		               |	БонусныеСчетаОбороты.Регистратор = &ДокументНачисления
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	БонусныеСчетаОбороты.Регистратор,
		               |	БонусныеСчетаОбороты.БонусныйСчет,
		               |	БонусныеСчетаОбороты.Период
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаОперацийСБонуснымСчетом.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаОперацийСБонуснымСчетом.БонусныйСчет КАК БонусныйСчет,
		               |	ВЫБОР
		               |		КОГДА ТаблицаОперацийСБонуснымСчетом.БонусныйСчет.Именной
		               |			ТОГДА ВЫБОР
		               |					КОГДА НЕ ВЫРАЗИТЬ(ТаблицаОперацийСБонуснымСчетом.БонусныйСчет.ВладелецБонусногоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |						ТОГДА ВЫРАЗИТЬ(ТаблицаОперацийСБонуснымСчетом.БонусныйСчет.ВладелецБонусногоСчета КАК Справочник.Контрагенты)
		               |					КОГДА НЕ ВЫРАЗИТЬ(ТаблицаОперацийСБонуснымСчетом.БонусныйСчет.ВладелецБонусногоСчета КАК Справочник.Карты) ЕСТЬ NULL
		               |						ТОГДА ВЫБОР
