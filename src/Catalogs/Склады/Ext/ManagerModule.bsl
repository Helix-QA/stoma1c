
#Область СлужебныйПрограммныйИнтерфейс

// Функция возвращает Склад по СЕ.
// Если у СЕ несколько Складов - возвращает Неопределенно
//
Функция ВернутьСклад(СЕ) Экспорт
	
	Если ЗначениеЗаполнено(СЕ) Тогда 
		Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Склады.Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");	
		
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СЕ);
		Результат = Запрос.Выполнить().Выгрузить();
		Если Результат.Количество() = 0 Тогда 
			Возврат Неопределено;
		ИначеЕсли Результат.Количество() = 1 Тогда 
			Возврат Результат[0].Ссылка;
		Иначе 
			Возврат Неопределено;
		КонецЕсли;
	Иначе Возврат Неопределено;
	КонецЕсли;  	
	
КонецФункции

#КонецОбласти