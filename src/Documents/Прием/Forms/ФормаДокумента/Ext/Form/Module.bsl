// Добавить значение реквизита в буферную таблицу данных
//
Процедура ДобавитьЗначениеРеквизитаВБуферДанныхОбследование(ИдентификаторРеквизита, Реквизит, Значение, ПривязанЗуб, ЗначениеРеквизитаСтрокой = "")
	
	ВедущийИД       = ПолучитьВедущийИдентификторРеквизитаОбследования(ИдентификаторРеквизита);
	ВедомыйИД       = ПолучитьВедомыйИдентификторРеквизитаОбследования(ИдентификаторРеквизита);
	НайденнаяСтрока = ПолучитьЗначениеРеквизитаИзБуфераДанныхобследования(ИдентификаторРеквизита);	
	Если НайденнаяСтрока.Количество() > 0 Тогда
		НайденнаяСтрока[0].РеквизитЗначение		   = Значение;
		НайденнаяСтрока[0].РеквизитЗначениеСтрокой = ?(ЗначениеЗаполнено(ЗначениеРеквизитаСтрокой), ЗначениеРеквизитаСтрокой, Значение);
		НайденнаяСтрока[0].ЗубЗначение             = ПривязанЗуб;
	Иначе		
		НоваяСтрока                         = ДОЗначенияРеквизитовОбследования.Добавить();
		НоваяСтрока.Реквизит                = Реквизит;
		НоваяСтрока.РеквизитИдентификатор   = ВедущийИД;
		НоваяСтрока.РеквизитЗначение        = Значение;
		НоваяСтрока.РеквизитЗначениеСтрокой = ?(ЗначениеЗаполнено(ЗначениеРеквизитаСтрокой), ЗначениеРеквизитаСтрокой, Значение);
		НоваяСтрока.ЗубЗначение             = ПривязанЗуб;
		НоваяСтрока.ЗубИдентификатор        = ВедомыйИД;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаписатьДанныеДокументаОбследования();  	
	Иначе
		ДОДокументИзменен = Истина;	
	КонецЕсли;
	
КонецПроцедуры

