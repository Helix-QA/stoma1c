// Процедура, обновляет статусы сообщений из регистра.
//
Процедура ОбновитьСтатусыSMSСРегистра()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыSMSСообщений.КлючСтроки,
	|	СтатусыSMSСообщений.IDСообщения,
	|	СтатусыSMSСообщений.СтатусСообщения,
	|	СтатусыSMSСообщений.СтатусДействия
	|ИЗ
	|	РегистрСведений.СтатусыСообщений КАК СтатусыSMSСообщений
    |ГДЕ
	|	СтатусыSMSСообщений.РассылкаСообщений = &РассылкаСообщений";
	
	Запрос.УстановитьПараметр("РассылкаСообщений", Объект.Ссылка);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЧ Из Объект.Получатели Цикл
		СтрокаРегистра = Результат.Найти(СтрокаТЧ.КлючСтроки, "КлючСтроки");
		Если СтрокаРегистра <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаРегистра);
			СтатусСообщения = СтрокаРегистра.СтатусСообщения;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

