// Процедура, обработчик события команды "ИсторияНажатие"
//
Процедура ИсторияНажатие(Команда)
	
	НайденныеСтроки = История.НайтиСтроки(Новый Структура("Наименование", Команда.Имя));

	Если НайденныеСтроки.Количество() > 0 тогда
		Элементы[ТекущийЭлементИстории].Пометка = Ложь;
		Элементы[ТекущийЭлементИстории].ЦветТекста        = Новый Цвет(77, 77, 77);
		Элементы[ТекущийЭлементИстории].Родитель.ЦветФона = Новый Цвет(242, 242, 242);
		Элементы[Команда.Имя].Пометка = Истина; 
		Элементы[Команда.Имя].ЦветТекста        = Новый Цвет(255, 255, 255);
		Элементы[Команда.Имя].Родитель.ЦветФона = Новый Цвет(25, 116, 206);
		ТекущийЭлементИстории = Команда.Имя; 
		Если  Команда.Имя = "КнопкаИстория1" Тогда
			ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var ReadOnly = true;", "var ReadOnly = false;");
			ЗагрузитьВыгрузитьКэш(Истина);
			ФлагВыгрузиКэш = Истина;
		Иначе
			Если ФлагВыгрузиКэш Тогда
				ЗагрузитьВыгрузитьКэш(Ложь);
				ФлагВыгрузиКэш = Ложь;
			КонецЕсли;
			ЗубнаяФормулаSVG = СтрЗаменить(ЗубнаяФормулаSVG, "var ReadOnly = false;", "var ReadOnly = true;");			
			ЗагрузитьСтатусыЗубов(НайденныеСтроки[0].Дата);
		КонецЕсли;
		
		ОбновитьДокумент();
	КонецЕсли; 
	
КонецПроцедуры   

&НаКлиенте
// Процедура, обработчик события команды "ВыборПриемов"
//
Процедура ВыборПриемаДляОтображенияВЗубнойФормуле(Команда)
	
	ДопПараметры       = Новый Структура("ИмяКоманды", Команда.Имя);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораПриема", ЭтотОбъект, ДопПараметры);
	ПараметрыФормы     = Новый Структура("Контрагент, СтруктурнаяЕдиница, СписокПриемов", Объект.Контрагент, Объект.СтруктурнаяЕдиница, СписокИсключаемыхПриемов);
	ОткрытьФорму("Документ.Прием.Форма.ФормаВыбора", ПараметрыФормы,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры  

&НаКлиенте
// Процедура, обработчик события "ПослеВыбораПриема"
//
Процедура ПослеВыбораПриема(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВывестиИЛИОчиститьРезультатВыбранногоПриема(Результат, ДопПараметры.ИмяКоманды);
	
КонецПроцедуры	 

&НаКлиенте
// Процедура, Обработчик события "ОчиститьВыбранныйПрием".
//
Процедура ОчиститьВыбранныйПрием(Команда)
	
	НайденныйПрием = История.НайтиСтроки(Новый Структура("Наименование", "КнопкаИстория11")); 
	Если ЗначениеЗаполнено(НайденныйПрием) Тогда
		История.Удалить(НайденныйПрием[0]); 
		ВывестиИЛИОчиститьРезультатВыбранногоПриема(, Команда.Имя); 
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере
// Процедура, выполняет формирование меню истории
//
Процедура СформироватьМенюИстории()
	
	Шаг = 0;
	Пока Шаг < ЭтаФорма.Элементы.ГруппаИстория.ПодчиненныеЭлементы.Количество() Цикл
		ЭтаФорма.Элементы.Удалить(ЭтаФорма.Элементы.ГруппаИстория.ПодчиненныеЭлементы[Шаг]);		
	КонецЦикла;
	
 	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ ПЕРВЫЕ 9
	|	НАЧАЛОПЕРИОДА(Прием.Дата, ДЕНЬ) КАК Период,
	|	Прием.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Контрагент = &Контрагент
	|	И НЕ Прием.ПометкаУдаления
	|	И Прием.Ссылка <> &Ссылка
	|	И Прием.Дата < &Дата
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ";  
	
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запрос.УстановитьПараметр("Ссылка"    , Объект.Ссылка);
	Запрос.УстановитьПараметр("Дата"      , ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата()));
	Шаг = 1;
	История.Очистить();	
	Результат = Запрос.Выполнить().Выгрузить(); 
	// для того чтобы в форме выбора отсечь приемы которые уже выведены на форме
	МассивПриемов = Результат.ВыгрузитьКолонку("Ссылка"); 
	СписокИсключаемыхПриемов.ЗагрузитьЗначения(МассивПриемов);
	СписокИсключаемыхПриемов.Добавить(Объект.Ссылка);  
	
	ГруппаЭлементИсторииСтрока                      = Элементы.Добавить("ГруппаКнопкаИсторияПриемовСтрока", Тип("ГруппаФормы"), Элементы.ГруппаИстория);
	ГруппаЭлементИсторииСтрока.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаЭлементИсторииСтрока.Заголовок 			= "ГруппаКнопкаИсторияПриемовСтрока";
	ГруппаЭлементИсторииСтрока.Отображение 			= ОтображениеОбычнойГруппы.Нет;
	ГруппаЭлементИсторииСтрока.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	ГруппаЭлементИсторииСтрока.ОтображатьЗаголовок 	= Ложь;  
	
	ГруппаЭлементИстории                        = Элементы.Добавить("ГруппаКнопкаИстория" + Шаг, Тип("ГруппаФормы"), ГруппаЭлементИсторииСтрока);
	ГруппаЭлементИстории.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаЭлементИстории.Заголовок 				= "ГруппаКнопкаИстория" + Шаг;
	ГруппаЭлементИстории.Отображение 			= ОтображениеОбычнойГруппы.Нет;
	ГруппаЭлементИстории.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	ГруппаЭлементИстории.ОтображатьЗаголовок 	= Ложь;
	ГруппаЭлементИстории.ЦветФона				= Новый Цвет(25, 116, 206);
	
	Кнопка                         = ЭтаФорма.Элементы.Добавить("КнопкаИстория" + Шаг, Тип("КнопкаФормы"), ГруппаЭлементИстории);
	НоваяСтрока                    = История.Добавить(); 
	НоваяСтрока.Наименование       = "КнопкаИстория1"; 	
	Кнопка.Заголовок               = "Текущий прием"; 
	Кнопка.ЦветТекста              = Новый Цвет(255, 255, 255);
	Кнопка.ОтображениеФигуры       = ОтображениеФигурыКнопки.Нет;	
	НоваяСтрока.Дата               = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата());
	ТекущийЭлементИстории          = "КнопкаИстория1"; 
	
	Если ЭтаФорма.Команды.Найти("КнопкаИстория1") = Неопределено Тогда
		Команда          = ЭтаФорма.Команды.Добавить("КнопкаИстория1");
		Команда.Действие = "ИсторияНажатие";	
	КонецЕсли;
	Кнопка.ИмяКоманды = "КнопкаИстория1";
	Кнопка.Пометка    = Истина;        
	
	Для Каждого СтрокаТЧ из Результат Цикл
		
		Шаг = Шаг + 1;
		
		ГруппаЭлементИстории = Элементы.Добавить("ГруппаКнопкаИстория" + Шаг, Тип("ГруппаФормы"), ГруппаЭлементИсторииСтрока);
		ГруппаЭлементИстории.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаЭлементИстории.Заголовок 				= "ГруппаКнопкаИстория" + Шаг;
		ГруппаЭлементИстории.Отображение 			= ОтображениеОбычнойГруппы.Нет;
		ГруппаЭлементИстории.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаЭлементИстории.ОтображатьЗаголовок 	= Ложь;
		ГруппаЭлементИстории.ЦветФона				= Новый Цвет(242, 242, 242);
		
		Кнопка                   = ЭтаФорма.Элементы.Добавить("КнопкаИстория" + Шаг, Тип("КнопкаФормы"), ГруппаЭлементИстории);
		НоваяСтрока              = История.Добавить();
		НоваяСтрока.Наименование = "КнопкаИстория" + Шаг;
		Если ЭтаФорма.Команды.Найти("КнопкаИстория" + Шаг) = Неопределено Тогда
			Команда          = ЭтаФорма.Команды.Добавить("КнопкаИстория" + Шаг);
			Команда.Действие = "ИсторияНажатие";
		КонецЕсли;
		Кнопка.ИмяКоманды = "КнопкаИстория" + Шаг;	
		Если Шаг = 2 Тогда
			Кнопка.Заголовок = "Предыдущий прием";
			НоваяСтрока.Дата = КонецДня(СтрокаТЧ.Период);
		Иначе
			Кнопка.Заголовок = Формат(СтрокаТЧ.Период, "ДЛФ=DD");
			НоваяСтрока.Дата = КонецДня(СтрокаТЧ.Период);
		КонецЕсли;
		Кнопка.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет; 
		
		Если Шаг%10 = 0 Тогда    
			
			Шаг = Шаг + 1;
			ГруппаЭлементИстории                        = Элементы.Добавить("ГруппаКнопкаИстория" + Шаг, Тип("ГруппаФормы"), Элементы.ГруппаИстория);
			ГруппаЭлементИстории.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаЭлементИстории.Заголовок 				= "ГруппаКнопкаИстория" + Шаг;
			ГруппаЭлементИстории.Отображение 			= ОтображениеОбычнойГруппы.Нет;
			ГруппаЭлементИстории.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаЭлементИстории.ОтображатьЗаголовок 	= Ложь;
			ГруппаЭлементИстории.ЦветФона				= Новый Цвет(242, 242, 242);
			
			Кнопка = ЭтаФорма.Элементы.Добавить("КнопкаИстория" + Шаг, Тип("КнопкаФормы"), ГруппаЭлементИстории);
			Если ЭтаФорма.Команды.Найти("КнопкаИстория" + Шаг) = Неопределено Тогда
				Команда          = ЭтаФорма.Команды.Добавить("КнопкаИстория" + Шаг);
				Команда.Действие = "ВыборПриемаДляОтображенияВЗубнойФормуле";
			КонецЕсли;  
			Кнопка.ИмяКоманды        = "КнопкаИстория" + Шаг;
			Кнопка.Заголовок         = "Еще"; 
			Кнопка.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет; 			  
			
			Кнопка = ЭтаФорма.Элементы.Добавить("ОчисткаИстории", Тип("КнопкаФормы"), Элементы.ГруппаИстория);
			Если ЭтаФорма.Команды.Найти("ОчисткаИстории") = Неопределено Тогда
				Команда          = ЭтаФорма.Команды.Добавить("ОчисткаИстории");
				Команда.Действие = "ОчиститьВыбранныйПрием";
			КонецЕсли;  
			Кнопка.ИмяКоманды        = "ОчисткаИстории";
			Кнопка.Отображение       = ОтображениеКнопки.Картинка;
			Кнопка.Картинка          = БиблиотекаКартинок.ОтменаОчиститьДанныеНовая;
			Кнопка.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
			Кнопка.Видимость         = Ложь; 			
			
		КонецЕсли; 
		
	КонецЦикла;
	
	// --------------------------------------------------------------------------------------------------------
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		
		Телефон 				= Объект.Контрагент.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента, "Вид");
		Долг 					= РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Объект.Контрагент,, Объект.СтруктурнаяЕдиница);	
		ЗапланированныеОплаты	= ОбщегоНазначенияСтоматология.ВернутьЗапланированныеОплаты(Объект.Контрагент);
		ОстатокЛицевогоСчета    = 0;
		Если РежимРаботыЕдинаяСеть Тогда
			ОстатокЛицевогоСчета 	= РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент, ТекущаяДатаСеанса(),,,, Истина);
		Иначе
			ОстатокЛицевогоСчета 	= РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Объект.Контрагент, ТекущаяДатаСеанса(),, Объект.СтруктурнаяЕдиница,, Истина);
		КонецЕсли;
		
		// Декорация предварительной записи
		ОснованиеПриема = Объект.ДокументОснование;
		Если ТипЗнч(ОснованиеПриема) = Тип("ДокументСсылка.Событие") И ЗначениеЗаполнено(ОснованиеПриема) Тогда 

			АвторДокумента = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ОснованиеПриема, "АвторДокумента");
			Если ЗначениеЗаполнено(АвторДокумента) Тогда
				Если ТипЗНЧ(АвторДокумента) = Тип("СправочникСсылка.Пользователи") Тогда
					АвторДокумента = ОбщегоНазначения.ПолучитьЗначениеРеквизита(АвторДокумента, "Сотрудник"); 
				КонецЕсли;
				Если ЗначениеЗаполнено(АвторДокумента) Тогда  
					ПредставлениеАвтора = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(АвторДокумента, "НаименованиеСокращенное, Наименование"); 	
					ФИОАвтора           = ?(ЗначениеЗаполнено(ПредставлениеАвтора.НаименованиеСокращенное), ПредставлениеАвтора.НаименованиеСокращенное, ПредставлениеАвтора.Наименование); 					
				КонецЕсли;
			Иначе
				ФИОАвтора = "";
			КонеЦЕсли;			
			
			ДатаСозданияОснования = Формат(ОснованиеПриема.ДатаСоздания, "ДЛФ=DD"); 
			Комментарий           = ?(ЗначениеЗаполнено(ОснованиеПриема.Комментарий),", " + ОснованиеПриема.Комментарий, ""); 
			ПричинаЗаписи         = ?(ЗначениеЗаполнено(ОснованиеПриема.Услуги[0].ПричинаЗаписи), ". " + ОснованиеПриема.Услуги[0].ПричинаЗаписи,""); 
			
			НаправившийВрач = РегистрыСведений.Профосмотры.ПолучитьНаправившегоВрача(Объект.Контрагент
																					, ОснованиеПриема
																					, ?(ЗначениеЗаполнено(ТекущаяСделка), ТекущаяСделка, Неопределено));
			
			Если ЗначениеЗаполнено(НаправившийВрач) Тогда
				Элементы.ДекорацияКартинкаНаправления.Видимость = Истина;																						
            	ТекстПредварительнойЗаписи = СтрШаблон(НСтр("ru='По направлению от %1';en='In the direction from %1'")
													, ОбщегоНазначения.ПолучитьЗначениеРеквизита(НаправившийВрач, "НаименованиеСокращенное"))
													+  " записан " + Лев(ДатаСозданияОснования, СтрДлина(ДатаСозданияОснования) - 2)
													+ " в " + Формат(ОснованиеПриема.ДатаСоздания, "ДФ=чч:мм")
													+ ?(ЗначениеЗаполнено(ФИОАвтора), ", " + ФИОАвтора, "")
													+ Комментарий + ПричинаЗаписи;
				

			Иначе 
				ТекстПредварительнойЗаписи = "Назначен " + Лев(ДатаСозданияОснования, СтрДлина(ДатаСозданияОснования) - 2)
													+ " в " + Формат(ОснованиеПриема.ДатаСоздания, "ДФ=чч:мм")
													+ ?(ЗначениеЗаполнено(ФИОАвтора), ", " + ФИОАвтора, "")
													+ Комментарий + ПричинаЗаписи;
													
				Элементы.ДекорацияКартинкаНаправления.Видимость = Ложь;
			КонецЕсли;
			
			Если СтрДлина(ТекстПредварительнойЗаписи) > 70 Тогда
				ЗаголовокПредварЗаписи = Лев(ТекстПредварительнойЗаписи,70) + "..."
			Иначе 
				ЗаголовокПредварЗаписи = ТекстПредварительнойЗаписи;
			КонецЕсли;
			
			Элементы.ПредварительнаяЗапись.Заголовок 				= ЗаголовокПредварЗаписи;
			Этаформа.Команды.ОткрытьПредварительнуюЗапись.Подсказка = ТекстПредварительнойЗаписи;
			
			Элементы.Группа_ПредварительнойЗаписи.Видимость = Истина; 
			
		КонецЕсли;
		
		// Декорация планируемых оплат контрагента
		Элементы.ДекорацияЗапланированныеОплаты.Заголовок = "Запланированные оплаты:";
		Элементы.ДекорацияСуммаПланируемыхОплат.Заголовок = Формат(ЗапланированныеОплаты, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Если ЗапланированныеОплаты > 0 Тогда 
			Элементы.ДекорацияЗапланированныеОплаты.ЦветТекста = Новый Цвет(220,140,0); // Новый Цвет(150, 95, 9);
			Элементы.ДекорацияСуммаПланируемыхОплат.ЦветТекста = Новый Цвет(220,140,0); // Новый Цвет(150, 95, 9);
		Иначе 
			Элементы.ДекорацияЗапланированныеОплаты.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияСуммаПланируемыхОплат.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		КонецЕсли;	
		// Декорация задолженности контрагента
		Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		Если Долг > 0 Тогда
			Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Долг пациента:";
			Элементы.ДекорацияДолг.Заголовок                = Формат(Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = WebЦвета.Красный;
			Элементы.ДекорацияДолг.ЦветТекста               = WebЦвета.Красный;			
		ИначеЕсли Долг < 0 Тогда
			Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Наш долг перед пациентом:";
			Элементы.ДекорацияДолг.Заголовок                = Формат(-Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияДолг.ЦветТекста               = ЦветаСтиля.ПоясняющийТекст;	
		Иначе	
			Элементы.ДекорацияЗадолженностьСумма.Заголовок  = "Нет задолженности.";
			Элементы.ДекорацияДолг.Заголовок                = "";
			Элементы.ДекорацияЗадолженностьСумма.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияДолг.ЦветТекста               = ЦветаСтиля.ПоясняющийТекст;	
		КонецЕсли;
		// Декорация остатка лицевого счета
		Элементы.ДекорацияОстаткиНаЛицевыхсчетах.Заголовок = "На лицевом счете:";
		Элементы.ДекорацияОстатокЛицевогоСчета.Заголовок = Формат(ОстатокЛицевогоСчета, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		Если ОстатокЛицевогоСчета < 0 Тогда
			Элементы.ДекорацияОстаткиНаЛицевыхсчетах.ЦветТекста = WebЦвета.Красный;
			Элементы.ДекорацияОстатокЛицевогоСчета.ЦветТекста = WebЦвета.Красный;
		Иначе
			Элементы.ДекорацияОстаткиНаЛицевыхсчетах.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
			Элементы.ДекорацияОстатокЛицевогоСчета.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		КонецЕсли; 		
	КонецЕсли;
	
КонецПроцедуры   

