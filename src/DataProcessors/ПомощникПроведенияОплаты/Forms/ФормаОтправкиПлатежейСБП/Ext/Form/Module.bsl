// Функция, возвращает неоплаченную ссылку на оплату.
//
Процедура ПолучитьНеоплаченнуюСсылкуНаОплату()
		
	ДокументыЗадолженности = Неопределено;
	Если Не ЗначениеЗаполнено(НомерЗаказа) Тогда
		ТаблицаВыбранныхДокументов	= ТаблицаЗадолженностей.Выгрузить(, "ДокументЗадолженности");
		ДокументыЗадолженности		= ТаблицаВыбранныхДокументов.ВыгрузитьКолонку("ДокументЗадолженности");		
	КонецЕсли;
	
	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьНеОплаченныеЗаказыПоДокументу(ДокументыЗадолженности, НомерЗаказа, ЭквайринговыйТерминал);
	
	Если ТаблицаЗаказов.Количество() > 0 И ЗначениеЗаполнено(ТаблицаЗаказов[0].СсылкаОплаты) Тогда
		
		ТаблицаЗадолженностей.Очистить();
		
		Для Каждого СтрокаТ Из ТаблицаЗаказов Цикл
			НоваяСтрока = ТаблицаЗадолженностей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТ);	
		КонецЦикла;
		
		ВремяСформирован		= СтрокаТ.ДатаРегистрацииЗаказа; 
		ВремяДействителенДо 	= СтрокаТ.ДатаОкончанияДействияСсылки;
		НомерЗаказа		    	= СтрокаТ.НомерЗаказа;
		Контрагент				= СтрокаТ.Контрагент; 
		СтруктурнаяЕдиница		= СтрокаТ.СтруктурнаяЕдиница;
		ЭквайринговыйТерминал	= СтрокаТ.ЭквайринговыйТерминал;
		СуммаОплаты				= ТаблицаЗадолженностей.Итог("Задолженность");
		СсылкаНаОплату			= СтрокаТ.СсылкаОплаты;
		
	КонецЕсли;
	
КонецПроцедуры

