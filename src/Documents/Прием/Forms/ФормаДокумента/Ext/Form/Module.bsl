// Процедура - Настройка порядка сортировки подбора.
//
Процедура НастройкаПорядкаСортировкиПодбора(Команда)
	
	ЭтоСтраницаЛечение = ?(ТекущийЭлемент.Имя = "КнопкаНастройкиПорядкаСортировкиПодбора_Лечение", Истина, Ложь);
	
	ТекущаяТаблица = ЭтотОбъект["_ПодборНоменклатур" + ?(ЭтоСтраницаЛечение, "Услуги", "")];
	ТекущаяКнопкаПоле = Элементы["КнопкаНастройкаСортировки_" + ?(ЭтоСтраницаЛечение , "Лечение", "Запасы")];	
	ТекущаяКнопкаПорядок = Элементы[ТекущийЭлемент.Имя];
	
	НовыйПорядокСортировки = ПолучитьТекущийПорядокСортировкиПодбора(ТекущаяТаблица, Истина);	
	ТекущаяКнопкаПорядок.Картинка = ?(НовыйПорядокСортировки = "Возр", БиблиотекаКартинок.УпорядочитьПоВозрастанию, БиблиотекаКартинок.УпорядочитьПоУбыванию); 	
	
   	ИзменитьСортировкуПодбора(ТекущаяТаблица, ?(ТекущаяКнопкаПоле.Заголовок = "Остаток", "Количество", ТекущаяКнопкаПоле.Заголовок), НовыйПорядокСортировки);
			
КонецПроцедуры

&НаКлиенте       
// Процедура обработчик нажатия "Подключаемый_Удалить_Промокод_Нажатие".
//
Процедура Подключаемый_Удалить_Промокод_Нажатие(Элемент)
	
	ИмяКоманды 		= Элемент.Имя;                                                            
	ИндексПромокода = Сред(ИмяКоманды, СтрДлина("Подключаемый_Удалить_Промокод_") + 1);
	Попытка         
		ИндексПромокода = Число(ИндексПромокода);
	Исключение                                   
		Возврат;
	КонецПопытки;                                
	
	ЗаголовокВопроса = ?(Модифицированность, "Документ будет сохранен" + ?(Объект.Проведен, " и проведен. ", ". "), "") + "Удалить промокод?"; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросУдалитьПромокодЗавершение", ЭтотОбъект, Новый Структура("ИндексПромокода", ИндексПромокода));
	ПоказатьВопрос(ОписаниеОповещения, ЗаголовокВопроса, РежимДиалогаВопрос.ДаНетОтмена,,, "Вопрос пользователю");
	
КонецПроцедуры 

&НаКлиенте
// Процедура, Подключаемый декорация формы представление нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ДекорацияФормы_Представление_Нажатие_Промокода(Элемент)	
	
	СтруктураПромокода = ПолучитьДанныеПромокода(Объект.Промокод, Объект.Контрагент);	
	
	Если СтруктураПромокода.ПромокодСуществует Тогда         
		
		КлючСтруктурой = Новый Структура;
		КлючСтруктурой.Вставить("Вид"		, СтруктураПромокода.ВидПромокода);
		КлючСтруктурой.Вставить("Владелец"	, СтруктураПромокода.Владелец);
		ПараметрыМассив = Новый Массив;
		ПараметрыМассив.Добавить(КлючСтруктурой);   				
		КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.Промокоды", ПараметрыМассив);
		ОткрытьФорму("РегистрСведений.Промокоды.Форма.ФормаЗаписи", 
					 Новый Структура("Ключ, ПросмотрЗаписи", КлючЗаписиРегистра, Истина),,,,,, 
					 РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);				
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураПромокода.ТекстОшибки); 
		
	КонецЕсли;
	
КонецПроцедуры

