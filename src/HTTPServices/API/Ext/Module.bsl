#Область СлужебныеПроцедурыИФункции

// Функция, возвращает структуру с заголовками запроса в нижнем регистре.
//
Функция ПолучитьСоответствиеЗаголовков(Запрос)
	
	СоответствиеСЗаголовками = Новый Соответствие;
	
	Для Каждого Заголовок Из Запрос.Заголовки Цикл
		
		Если НРег(Заголовок.Ключ) = "connection" ИЛИ НРег(Заголовок.Ключ) = "host" ИЛИ НРег(Заголовок.Ключ) = "content-length" Тогда
			Продолжить;
		КонецЕсли;
		
		СоответствиеСЗаголовками.Вставить(НРег(Заголовок.Ключ), Заголовок.Значение);
		
	КонецЦикла;
	
	Возврат СоответствиеСЗаголовками;
	
КонецФункции

// Функция, возвращает ссылку по УИД.
//
Функция ПолучитьСсылкуОбъектаПоУИД(УИД, ВидОбъекта, ИмяОбъекта)
	
	Попытка
		Выполнить("ВидОбъекта = " + ВидОбъекта);
		Ссылка = ВидОбъекта[ИмяОбъекта].ПолучитьСсылку(Новый УникальныйИдентификатор(УИД));
		Если Ссылка.ПолучитьОбъект() = Неопределено Тогда
			Ссылка = Неопределено;
		КонецЕсли;
	Исключение
		Ссылка = Неопределено;
	КонецПопытки;
	
	Возврат Ссылка;
	
КонецФункции

// Функция, возвращает HTTPОтвет. 
//
Функция ПолучитьHTTPОтвет(Ответ1с, КодОтвета = Неопределено)
	
	КодОтвета = ?(КодОтвета = Неопределено, 200, КодОтвета);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, Ответ1С);
	мОтвет = ЗаписьJSON.Закрыть();
	HTTPОтвет = Новый HTTPСервисОтвет(КодОтвета);
	HTTPОтвет.УстановитьТелоИзСтроки(мОтвет);
	HTTPОтвет.Заголовки["Content-Type"] = "application/json";
	
	Возврат HTTPОтвет;
	
КонецФункции

// Функция, возвращает структуру возврата ошибки. 
//
Функция ПолучитьСтруктуруВозвратаОшибки(КодОшибки = Неопределено, ОписаниеОшибки = "", ВернутьПустуюСтруктуру = Ложь)
	
	Если ВернутьПустуюСтруктуру Тогда
		Возврат Новый Структура("code, message", 0, "");
	КонецЕсли;
	
	СтруктураОшибки = Новый Структура("code, message", КодОшибки, api_v1.ПолучитьОписаниеОшибки(КодОшибки, ОписаниеОшибки));
	Возврат Новый Структура("Parameters, Errors",, СтруктураОшибки);
	
КонецФункции

// Функция, возвращает массив service_ids из параметров запроса.
// 
Функция ПолучитьМассив_service_ids(ПараметрыЗапроса)
	
	ТекстJSON = ПараметрыЗапроса.Получить("service_ids");
	
	Если ЗначениеЗаполнено(ТекстJSON) Тогда
		
		Попытка
			
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ТекстJSON);
			ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);
			
			Возврат ПараметрыJSON.services_array;
			
		Исключение
			Возврат Неопределено;
		КонецПопытки;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции 

// Функция, проверяет переданное занятие.
//
Функция ПолучитьСсылкуПоИдентификатору(Идентификатор, СтруктураОшибки, ЭтоСправочник = Истина, ИмяОбъекта, КодОшибки, ОбязательныйПараметр = Ложь)
	
	Ссылка = Неопределено;
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		
		Ссылка = ПолучитьСсылкуОбъектаПоУИД(Идентификатор, ?(ЭтоСправочник, "Справочники", "Документы"), ИмяОбъекта);
		Если Ссылка = Неопределено Тогда
			СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(КодОшибки);
		КонецЕсли;
		
	ИначеЕсли ОбязательныйПараметр Тогда
		СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(КодОшибки);
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

// Функция, возвращает значение из структуры по ключу.
//
Функция ПолучитьЗначениеИзСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	Если ТипЗнч(Структура) = Тип("Структура") Тогда
		Возврат ?(Структура.Свойство(Ключ), Структура[Ключ], ЗначениеПоУмолчанию);
	Иначе
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
КонецФункции

// Функция, возвращает параметры JSON из тела запроса.
//
Функция ПолучитьПараметрыJSON(Запрос)
	
	ТекстJSON  = Запрос.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON);
	
КонецФункции

// Функция, возвращает двоичные данные фото.
// 
Функция ПолучитьФайлКартинки(ВерсияСсылка)
	
	Возврат РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(ВерсияСсылка).ДвоичныеДанные;
	
КонецФункции

