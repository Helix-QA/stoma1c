		               |			И (ДЕНЬНЕДЕЛИ(ТаблицаНеОтработанныхЗаявок.ДатаСоздания) = ТаблицаВремениРаботыСЕ1.ДеньНедели)
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаВремениРаботыСЕ КАК ТаблицаВремениРаботыСЕ2
		               |		ПО ТаблицаНеОтработанныхЗаявок.СтруктурнаяЕдиница = ТаблицаВремениРаботыСЕ2.СтруктурнаяЕдиница
		               |			И (ДЕНЬНЕДЕЛИ(ДОБАВИТЬКДАТЕ(ТаблицаНеОтработанныхЗаявок.ДатаСоздания, СЕКУНДА, 86400)) = ТаблицаВремениРаботыСЕ2.ДеньНедели)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.Заявка КАК Заявка,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.Заявка КАК ОбъектСобытия,
		               |	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК Контрагент,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания КАК ДатаСоздания,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.ОсновнойМенеджер КАК ОсновнойМенеджер,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.ДеньНедели КАК ДеньНедели,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботы КАК НачалоРаботы,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.ОкончаниеРаботы КАК ОкончаниеРаботы,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботыСледующегоДня КАК НачалоРаботыСледующегоДня,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.Заявка.Фамилия КАК Фамилия,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.Заявка.Имя КАК Имя,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.Заявка.Отчество КАК Отчество,
		               |	ТаблицаЗаявокИРежимовРаботыСЕ.Заявка.НомерТелефона КАК НомерТелефона,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаЗаявокИРежимовРаботыСЕ КАК ТаблицаЗаявокИРежимовРаботыСЕ
		               |ГДЕ
		               |	ВЫБОР
		               |			КОГДА ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания МЕЖДУ ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботы И ТаблицаЗаявокИРежимовРаботыСЕ.ОкончаниеРаботы
		               |				ТОГДА ВЫБОР
		               |						КОГДА ДОБАВИТЬКДАТЕ(ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания, МИНУТА, &ПараметрЗадержкаМинут) <= ТаблицаЗаявокИРежимовРаботыСЕ.ОкончаниеРаботы
		               |							ТОГДА ДОБАВИТЬКДАТЕ(ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания, МИНУТА, &ПараметрЗадержкаМинут) <= &ТекущаяДата
		               |						ИНАЧЕ ДОБАВИТЬКДАТЕ(ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботыСледующегоДня, МИНУТА, &ПараметрЗадержкаМинут) <= &ТекущаяДата
		               |					КОНЕЦ
		               |			КОГДА ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания < ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботы
		               |				ТОГДА ДОБАВИТЬКДАТЕ(ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботы, МИНУТА, &ПараметрЗадержкаМинут) <= &ТекущаяДата
		               |			КОГДА ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания > ТаблицаЗаявокИРежимовРаботыСЕ.ОкончаниеРаботы
		               |				ТОГДА ДОБАВИТЬКДАТЕ(ТаблицаЗаявокИРежимовРаботыСЕ.НачалоРаботыСледующегоДня, МИНУТА, &ПараметрЗадержкаМинут) <= &ТекущаяДата
		               |			ИНАЧЕ ДОБАВИТЬКДАТЕ(ТаблицаЗаявокИРежимовРаботыСЕ.ДатаСоздания, МИНУТА, &ПараметрЗадержкаМинут) <= &ТекущаяДата
		               |		КОНЕЦ";
		
		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
