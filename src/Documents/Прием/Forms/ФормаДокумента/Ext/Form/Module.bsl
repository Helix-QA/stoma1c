&НаСервере
// Функция, Получить услуги сотрудника
//
// Параметры:
//  Сотрудник	 - 	 - 
//  Запасы		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьУслугиСотрудника(Сотрудник, Лечение)
	
	НайденныеСтроки  = Лечение.НайтиСтроки(Новый Структура("Сотрудник", Сотрудник));
	УслугиСотрудника = "";
	Если НайденныеСтроки.Количество() <> 0 Тогда
		
		УслугиСотрудника = НайденныеСтроки[0].Номенклатура.Наименование;
		ИндексУслуги     = 1;
		
		Пока ИндексУслуги < НайденныеСтроки.Количество() Цикл 
			
			Услуга = НайденныеСтроки[ИндексУслуги].Номенклатура.Наименование;
			
			Если Не СтрНайти(УслугиСотрудника, Услуга) Тогда   
				
				УслугиСотрудника = УслугиСотрудника + ", " + Услуга;
			КонецЕсли;
			
			ИндексУслуги = ИндексУслуги + 1;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат УслугиСотрудника;
	
КонецФункции 

