&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Объект.ТипКода = Перечисления.ВидыКарт.Wallet
		И Не ЗначениеЗаполнено(Объект.ИдентификаторПроекта) Тогда
		
		Результат = Справочники.Карты.СоздатьПроектWallet(ВнешняяСистемаWallet, ТекущийОбъект.Наименование, ЭтотОбъект.Нумератор, ЭтотОбъект.Сертификат); 
		
		Если Результат.Успешно Тогда
			
			ТекущийОбъект.ИдентификаторПроекта = Результат.id;
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки,,,, Отказ);
			
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ДобавленИзмененВидКарт", Объект.ИдентификаторПроекта > 0);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ДекорацияЭлектроннаяКартаНажатие".
//
Процедура ДекорацияЭлектроннаяКартаНажатие(Элемент)
	
	Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet");	
		
	УстановитьТекущийВидКарты();
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ДекорацияМагнитнаяКартаНажатие".
//
Процедура ДекорацияМагнитнаяКартаНажатие(Элемент)
	
	Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная");
	
	УстановитьТекущийВидКарты();
	
	ЭтаФорма.Модифицированность = Истина
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ДекорацияШтриховаяКартаНажатие".
//
Процедура ДекорацияШтриховаяКартаНажатие(Элемент)
	
	Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Штриховая");
	
	УстановитьТекущийВидКарты();
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "Именная".
//
Процедура Именная(Команда)
	
	Объект.Именная = Истина;
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(Элементы.ГруппаКнопкаИменная, Элементы.ГруппаКнопкаНаПредъявителя,, ЭтаФорма, Элементы.ДекорацияШтриховаяКарта);	
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "НаПредъявителя".
//
Процедура НаПредъявителя(Команда)
	
	Объект.Именная = Ложь;
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(Элементы.ГруппаКнопкаНаПредъявителя, Элементы.ГруппаКнопкаИменная,, ЭтаФорма, Элементы.ДекорацияШтриховаяКарта);		
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область Служебные_процедуры_и_функции

&НаСервере
// Процедура, заполняет нумераторы.
//
Процедура ЗаполнитьНумераторы()
	
	Результат = Справочники.Карты.ПолучитьНумераторыЭлектронныхКарт(ЭтотОбъект.ВнешняяСистемаWallet);
	
	Если Результат.Успешно Тогда
		
		Элементы.Нумератор.СписокВыбора.Очистить();
		Для Каждого НумераторСтруктура Из Результат.data Цикл
			Элементы.Нумератор.СписокВыбора.Добавить(НумераторСтруктура.id, НумераторСтруктура.name);	
		КонецЦикла;
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, заполняет сертификаты.
//
Процедура ЗаполнитьСертификаты()
	
	Результат = Справочники.Карты.ПолучитьСертификатыЭлектронныхКарт(ЭтотОбъект.ВнешняяСистемаWallet);
	
	Если Результат.Успешно Тогда
		
		Элементы.Сертификат.СписокВыбора.Очистить();
		Для Каждого СертификатСтруктура Из Результат.data Цикл
			Элементы.Сертификат.СписокВыбора.Добавить(СертификатСтруктура.id, СертификатСтруктура.name);	
		КонецЦикла;
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик проверки заполнения.
//
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если Объект.ТипКода = Перечисления.ВидыКарт.Wallet
		И Не ЗначениеЗаполнено(Объект.ИдентификаторПроекта) Тогда
		Если Не ЗначениеЗаполнено(ЭтотОбъект.Нумератор) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен нумератор",,,, Отказ);
		ИначеЕсли Не ЗначениеЗаполнено(ЭтотОбъект.Сертификат) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен сертификат",,,, Отказ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ДобавитьНумератор".
// 
Процедура ДобавитьНумератор(Команда)
	
	ОткрытьФорму("Справочник.ВидыКарт.Форма.ФормаДобавленияНумератора", Новый Структура("ВСWallet", ЭтотОбъект.ВнешняяСистемаWallet),,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события формы "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьНумераторы"
		И Элементы.ГруппаНумератор.Видимость Тогда
		ЗаполнитьНумераторы();	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти