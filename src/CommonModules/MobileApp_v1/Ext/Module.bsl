// Функция - Auth
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  Телефон			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция PostAuth(ВнешняяСистема, Телефон, КодПодтверждения, ТипАвторизации, ЭлПочта) Экспорт
	
	// ШаблонСообщения = Справочники.ШаблоныСообщений.КодПодтверждения.Содержание;
	ШаблонСообщения = "";
	Если ШаблонСообщения = "" Тогда
		Сообщение 	= "Ваш код подтверждения: " + КодПодтверждения;
	ИначеЕсли СтрНайти(ШаблонСообщения, "{Код подтверждения}") = 0 Тогда
		Сообщение 	= ШаблонСообщения + " " + КодПодтверждения;
	ИначеЕсли СтрНайти(ШаблонСообщения, "{Код подтверждения}") <> 0 Тогда		
		Сообщение	= СтрЗаменить(ШаблонСообщения, "{Код подтверждения}", Строка(КодПодтверждения));
	КонецЕсли;
	
	Телефон = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(Телефон);
	
	РезультатОтправки = СоздатьРассылкуСообщенийИОтправитьКодПодтверждения(ТипАвторизации, Телефон, Неопределено, Сообщение, ЭлПочта);
	
	Если РезультатОтправки <> Неопределено Тогда
		Возврат РезультатОтправки;
	Иначе
		Возврат ПолучитьСтруктуруОтвета(Новый Структура("Result", Истина)); 
	КонецЕсли;
	
КонецФункции

// Функция возвращает запись из регистра по номеру телефона клиента
//
Функция ПолучитьСотрудникаПоНомеруТелефона(НомерТелефона)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КлючиВнешнихСистем.Клиент КАК Клиент
	|ИЗ
	|	РегистрСведений.КлючиВнешнихСистем КАК КлючиВнешнихСистем
	|ГДЕ
	|	КлючиВнешнихСистем.НомерТелефона ПОДОБНО &НомерТелефона
	|	И КлючиВнешнихСистем.Использовать
	|	И КлючиВнешнихСистем.ВнешняяСистема.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.МобильноеПриложениеУправляющего)");
	
	Запрос.УстановитьПараметр("НомерТелефона", НомерТелефона);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Результат.Следующий(), Результат.Клиент, Неопределено);
	
КонецФункции

// Функция - Создать рассылку сообщений и отправить код подтверждения
//
// Параметры:
//  ТипАвторизации		 - 	 - 
//  Контрагент			 - 	 - 
//  НомерТелефона		 - 	 - 
//  Фамилия				 - 	 - 
//  Имя					 - 	 - 
//  Отчество			 - 	 - 
//  email				 - 	 - 
//  ДатаРождения		 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  Сообщение			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьРассылкуСообщенийИОтправитьКодПодтверждения(ТипАвторизации, НомерТелефона, СтруктурнаяЕдиница, Сообщение, ЭлПочта)
	
	ОписаниеОшибки = "";
	Сотрудник	   = ПолучитьСотрудникаПоНомеруТелефона(?(СтрДлина(НомерТелефона) > 10, Сред(НомерТелефона, СтрДлина(НомерТелефона) - 9, 10), НомерТелефона));
	
	ТипАвторизацииМессенджер = ТипАвторизации <> Неопределено И НРег(ТипАвторизации) = "whats_app";
	ТипАвторизацииПочта      = ТипАвторизации <> Неопределено И НРег(ТипАвторизации) = "email"; 
	
	Если ТипАвторизацииМессенджер Тогда
		
		Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда
			Возврат ПолучитьСтруктуруОтвета(, 2003, ОписаниеОшибки, Ложь);
		КонецЕсли;
		
		РезультатОтправки = ОтправитьСообщениеВМессенджер(Сотрудник, НомерТелефона, Сообщение, СтруктурнаяЕдиница, ОписаниеОшибки);
		
		Если НЕ РезультатОтправки Тогда
			Возврат ПолучитьСтруктуруОтвета(, 2060, ОписаниеОшибки, Ложь);
		КонецЕсли;
		
	ИначеЕсли ТипАвторизацииПочта Тогда
		
		Если Не ЗначениеЗаполнено(ЭлПочта) Тогда // Не УправлениеЭлектроннойПочтой.ЭлектроннаяПочтаВведенаВерно(ЭлПочта)
			Возврат ПолучитьСтруктуруОтвета(, 2061, "Не передана электронная почта", Ложь);	
		КонецЕсли;
		
		УчетнаяЗаписьЭлПочты = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
		
		Если УчетнаяЗаписьЭлПочты.ИспользоватьДляОтправки = Ложь Тогда
			Возврат ПолучитьСтруктуруОтвета(, 2061, "Не заполнена учетная запись", Ложь);	
		КонецЕсли;
		
		РезультатОтправки = ОтправитьПисьмоНаПочту(Сотрудник, ЭлПочта, Сообщение, СтруктурнаяЕдиница, УчетнаяЗаписьЭлПочты, ОписаниеОшибки);
		
		Если НЕ РезультатОтправки Тогда
			Возврат ПолучитьСтруктуруОтвета(, 2061, ?(ЗначениеЗаполнено(ОписаниеОшибки), ОписаниеОшибки, ""), Ложь);
		КонецЕсли;
		
	Иначе				
		
		Если Не ЗначениеЗаполнено(Константы.СервисSMSРассылкиПоУмолчанию.Получить()) Тогда		
			Возврат ПолучитьСтруктуруОтвета(, 1043,, Ложь);		
		КонецЕсли;
		
		ОписаниеОшибки = ОтправитьSMSСообщение(НомерТелефона, Сообщение, Сотрудник);
		
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			Возврат ПолучитьСтруктуруОтвета(1042, ОписаниеОшибки);
		КонецЕсли;			
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

