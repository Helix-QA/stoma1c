
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)  Экспорт
	
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ИнвентаризацияЗапасов") И ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		Если Не ЗначениеЗаполнено(ЭтотОбъект.ДокументОснование) Тогда
			ЭтотОбъект.ДокументОснование = ДанныеЗаполнения.Ссылка;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Склад) Тогда
			Склад = ДанныеЗаполнения.Склад;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ВидОперации) Тогда
			ВидОперации = ДанныеЗаполнения.ВидОперации;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			СтруктурнаяЕдиница = ДанныеЗаполнения.СтруктурнаяЕдиница;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	МИНИМУМ(ИнвентаризацияЗапасов.НомерСтроки) КАК НомерСтроки,
		               |	ИнвентаризацияЗапасов.Номенклатура КАК Номенклатура,
		               |	ИнвентаризацияЗапасов.Партия КАК Партия,
		               |	ИнвентаризацияЗапасов.Упаковка КАК Упаковка,
		               |	СУММА(ИнвентаризацияЗапасов.КоличествоУпаковок - ИнвентаризацияЗапасов.КоличествоУпаковокПоДаннымУчета) КАК КоличествоОтклонениеИнвентаризацииУпаковок,
		               |	СУММА(ИнвентаризацияЗапасов.Количество - ИнвентаризацияЗапасов.КоличествоПоДаннымУчета) КАК КоличествоОтклонениеИнвентаризации,
		               |	СУММА(ВЫБОР
		               |			КОГДА ОприходованиеЗапасов.КоличествоУпаковок ЕСТЬ NULL 
		               |				ТОГДА 0
		               |			ИНАЧЕ ОприходованиеЗапасов.КоличествоУпаковок
		               |		КОНЕЦ) КАК КоличествоОприходованноеУпаковок,
		               |	СУММА(ВЫБОР
		               |			КОГДА ОприходованиеЗапасов.Количество ЕСТЬ NULL 
		               |				ТОГДА 0
		               |			ИНАЧЕ ОприходованиеЗапасов.Количество
		               |		КОНЕЦ) КАК КоличествоОприходованное,
		               |	ИнвентаризацияЗапасов.Цена
		               |ИЗ
		               |	Документ.ИнвентаризацияЗапасов.Запасы КАК ИнвентаризацияЗапасов
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОприходованиеЗапасов.Запасы КАК ОприходованиеЗапасов
		               |		ПО ИнвентаризацияЗапасов.Номенклатура = ОприходованиеЗапасов.Номенклатура
		               |			И ИнвентаризацияЗапасов.Партия = ОприходованиеЗапасов.Партия
		               |			И ИнвентаризацияЗапасов.Ссылка = ОприходованиеЗапасов.Ссылка.ДокументОснование
		               |			И (ОприходованиеЗапасов.Ссылка <> &ДокументСсылка)
		               |			И (ОприходованиеЗапасов.Ссылка.Проведен)
		               |ГДЕ
		               |	ИнвентаризацияЗапасов.Ссылка = &ДокументОснование
		               |	И ИнвентаризацияЗапасов.КоличествоУпаковок - ИнвентаризацияЗапасов.КоличествоУпаковокПоДаннымУчета > 0
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ИнвентаризацияЗапасов.Номенклатура,
		               |	ИнвентаризацияЗапасов.Партия,
		               |	ИнвентаризацияЗапасов.Упаковка,
		               |	ИнвентаризацияЗапасов.Цена
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	НомерСтроки";
		
		Запрос.УстановитьПараметр("ДокументОснование", ДанныеЗаполнения);
		Запрос.УстановитьПараметр("ДокументСсылка"   , Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если НЕ РезультатЗапроса.Пустой() Тогда
			
			Выборка = РезультатЗапроса.Выбрать();
			
			// Заполнение табличной части документа.	
			Запасы.Очистить();
			
			Пока Выборка.Следующий() Цикл
				
				КоличествоОприходоватьУпаковок = Выборка.КоличествоОтклонениеИнвентаризацииУпаковок - Выборка.КоличествоОприходованноеУпаковок;
				КоличествоОприходовать         = Выборка.КоличествоОтклонениеИнвентаризации         - Выборка.КоличествоОприходованное;
				Если КоличествоОприходоватьУпаковок <= 0 Тогда
					Продолжить;
				КонецЕсли;
				
				СтрокаТабличнойЧасти = Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура       = Выборка.Номенклатура;
				СтрокаТабличнойЧасти.Партия 			= Выборка.Партия;
				СтрокаТабличнойЧасти.Упаковка           = Выборка.Упаковка;
				СтрокаТабличнойЧасти.КоличествоУпаковок = КоличествоОприходоватьУпаковок;
				СтрокаТабличнойЧасти.Количество         = КоличествоОприходовать;
				СтрокаТабличнойЧасти.Цена               = Выборка.Цена;
				СтрокаТабличнойЧасти.Сумма 				= СтрокаТабличнойЧасти.КоличествоУпаковок * СтрокаТабличнойЧасти.Цена;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если Запасы.Количество() = 0 Тогда
			
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru = 'Нет данных для оформления оприходования!'");
			Сообщение.Сообщить();
			
			СтандартнаяОбработка = Ложь;
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") и ДанныеЗаполнения.Свойство("ВидОперации") Тогда
		
		ВидОперации = ДанныеЗаполнения.ВидОперации;
        Если ВидОперации = Перечисления.ВидыОпераций.ПоСкладу Тогда
			Склад        = Справочники.Склады.ПустаяСсылка();
		ИначеЕсли ВидОперации = Перечисления.ВидыОпераций.ПоСотруднику Тогда
			Склад        = Справочники.Сотрудники.ПустаяСсылка();
		КонецЕсли;
		
	ИначеЕсли ДанныеЗаполнения = Неопределено Тогда
		
		ВидОперации = Перечисления.ВидыОпераций.ПоСкладу;
		Склад = Справочники.Склады.ПустаяСсылка();		
		
	КонецЕсли;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
		
КонецПроцедуры

// Процедура - обработчик события "ПриКопировании" объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	                       
КонецПроцедуры

// Обработчик проверки заполнения объекта
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Проверка табличной части на разрешения по значениям 
	Если ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.РазрешитьНулевуюСумму, Ложь) Тогда
		УдаляемыйЭлемент = ПроверяемыеРеквизиты.Найти("Запасы.Сумма");
		Если УдаляемыйЭлемент <> Неопределено Тогда
			ПроверяемыеРеквизиты.Удалить(УдаляемыйЭлемент);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	
	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
	
	// Инициализация данных документа.
	Документы.ОприходованиеЗапасов.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);
	
	// Движения по регистрам
	ДвиженияДокументовСервер.ЗапасыНаСкладах(ДополнительныеСвойства, Движения, Отказ);   	
	ДвиженияДокументовСервер.ПартииТоваров(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.Управленческий(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.УстановкаЦен(ДополнительныеСвойства, Движения, Отказ); 

	// Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);
	
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаУдаленияПроведения объекта.
//
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	// Удаляем цены из регистра по документу
	ДвиженияДокументовСервер.УдалениеЦен(Ссылка, Движения, Отказ);
	
КонецПроцедуры


#КонецОбласти

