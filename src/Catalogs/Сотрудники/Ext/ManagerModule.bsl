
#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Функция вернет основную специализацию сотрудника.
//
Функция ПолучитьОсновнуюСпециализациюСотрудника(Сотрудник, ТолькоПредопределенные = Истина, ДобавлятьСотруднику = Истина) Экспорт	
	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда
		 Возврат Неопределено;
	КонецЕсли;	 	
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	|	СотрудникиСпецилазацииСотрудника.Специализация КАК Специализация,
	|	ВЫБОР
	|		КОГДА СотрудникиСпецилазацииСотрудника.Основная
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ПриоритетОсновной
	|ИЗ
	|	Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|ГДЕ
	|	СотрудникиСпецилазацииСотрудника.Ссылка = &Сотрудник
	|	И НЕ СотрудникиСпецилазацииСотрудника.Специализация = ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
	|	И &УсловиеПредопределенных
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриоритетОсновной";
	
	Если ТолькоПредопределенные Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПредопределенных", "СотрудникиСпецилазацииСотрудника.Специализация.Предопределенный = ИСТИНА");
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПредопределенных", "ИСТИНА");
	КонецЕсли;
	
	ВыборкаОсновнойСпециализации = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаОсновнойСпециализации.Следующий() Тогда 
		Возврат ВыборкаОсновнойСпециализации.Специализация;
	Иначе
		Должность = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник, "Должность");
		Если ЗначениеЗаполнено(Должность) Тогда
			Специализация = Справочники.Специализации.ИнициализироватьПредопределеннуюСпециализациюПоДолжности(Должность);
			Если ЗначениеЗаполнено(Сотрудник) И ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Сотрудники") И ЗначениеЗаполнено(Специализация) И ДобавлятьСотруднику Тогда 
				Сотрудник_Объект = Сотрудник.ПолучитьОбъект();
				ЗаполнитьЗначенияСвойств(Сотрудник_Объект.СпецилазацииСотрудника.Добавить(), Новый Структура("Специализация, Основная", Специализация, Сотрудник_Объект.СпецилазацииСотрудника.Количество() <= 1));  
				Попытка
					ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Сотрудник_Объект);
				Исключение
					
				КонецПопытки;	
			КонецЕсли;
			Возврат Специализация;
		Иначе 
			Возврат Справочники.Специализации.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;

КонецФункции

// Функция - Получить массив сотрудников по специализации
//
// Параметры:
//  Специализация	 - 	 - 
//  ТолькоПоОсновным - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивСотрудниковПоСпециализации(Специализация, ТолькоПоОсновным = Ложь) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(Специализация) Тогда
		 Возврат Новый Массив;
	КонецЕсли;	 	
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Специализация", Специализация);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И Сотрудники.Служебный = ЛОЖЬ
	|	И Сотрудники.СпецилазацииСотрудника.Специализация = &Специализация
	|	И &УсловиеОсновные";
	
	Если ТолькоПоОсновным Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОсновные", "Сотрудники.СпецилазацииСотрудника.Основная = &Основная");
		Запрос.УстановитьПараметр("Основная", ТолькоПоОсновным);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеОсновные", "");
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция - Проверить сотрудник является новым для структурной единицы.
//
// Параметры:
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьСотрудникЯвляетсяНовымДляСтруктурнойЕдиницы(Сотрудник, СтруктурнаяЕдиница = Неопределено) Экспорт	
	
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда			
		Возврат Ложь;			
	ИначеЕсли Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 	
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;			
	КонецЕсли;	 	
	
	ДатаПриема = РегистрыСведений.НастройкиСотрудников.ПолучитьДатуПриемаСотрудника(Сотрудник, СтруктурнаяЕдиница);
	
	Возврат ?(ЗначениеЗаполнено(ДатаПриема), ТекущаяДатаСеанса() < ДобавитьМесяц(ДатаПриема, 3), Ложь);
	
КонецФункции

// Функция - Представление ФИОСотрудника
//
// Параметры:
//  Сотрудник	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПредставлениеФИОСотрудника(Сотрудник) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда
		Возврат НСтр("ru = '<Сотрудник не найден>'; en = 'Employee not found'");
	ИначеЕсли ТипЗнч(Сотрудник) = Тип("Строка") Тогда 
		Возврат Сотрудник;
	КонецЕсли;
	
	ДанныеСотрудника = ЗначенияРеквизитов(Сотрудник, "Фамилия, Имя, Отчество, Наименование"); 
	
	Фамилия          = ДанныеСотрудника.Фамилия; 
	ФамилияЗаполнена = ЗначениеЗаполнено(Фамилия); 
	Имя              = ДанныеСотрудника.Имя;
	ИмяЗаполнено     = ЗначениеЗаполнено(Имя); 
	
	Если ФамилияЗаполнена ИЛИ ИмяЗаполнено Тогда 
		
		Отчество = ДанныеСотрудника.Отчество;
		
		Возврат ?(ФамилияЗаполнена	, "" + ВРег(Лев(СокрЛП(Фамилия), 1)) + НРег(Сред(СокрЛП(Фамилия), 2)), "") + 
		?(ИмяЗаполнено, ?(НЕ ФамилияЗаполнена, ВРег(Лев(СокрЛП(Имя), 1)) + НРег(Сред(СокрЛП(Имя), 2)), Символ(160) + ВРег(Лев(СокрЛП(Имя), 1)) + "."), "") + 
		?(ЗначениеЗаполнено(Отчество), " " + Лев(СокрЛП(Отчество), 1) + ".", "");
		
	Иначе
		Возврат ДанныеСотрудника.Наименование;
	КонецЕсли;
	
КонецФункции

// Функция - Представление ФИОСотрудника по структуре данных.
//
// Параметры:
//  СтруктураСотрудник	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПредставлениеФИОСотрудникаПоСтруктуреДанных(СтруктураСотрудник) Экспорт
		
	Фамилия          = СтруктураСотрудник.Фамилия; 
	ФамилияЗаполнена = ЗначениеЗаполнено(Фамилия); 
	Имя              = СтруктураСотрудник.Имя;
	ИмяЗаполнено     = ЗначениеЗаполнено(Имя); 
	
	Если ФамилияЗаполнена ИЛИ ИмяЗаполнено Тогда 
		
		Отчество = СтруктураСотрудник.Отчество;
		
		Возврат ?(ФамилияЗаполнена, "" + Фамилия, "")
                  + ?(ИмяЗаполнено, " " + Лев(СокрЛП(Имя), 1) + ".", "")
                  + ?(ЗначениеЗаполнено(Отчество), " " + Лев(СокрЛП(Отчество), 1) + ".", "");
	Иначе
		Возврат СтруктураСотрудник.Наименование;
	КонецЕсли;	
	
КонецФункции

// Функция - Получить сокращенное наименование сотрудника
//
// Параметры:
//  СтруктураНаименованияСотрудника	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСокращенноеНаименованиеСотрудника(СтруктураНаименованияСотрудника = Неопределено, Сотрудник = Неопределено) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если СтруктураНаименованияСотрудника = Неопределено Тогда
		Если Сотрудник = Неопределено Тогда 
			Возврат "";
		Иначе 
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	Сотрудники.Наименование КАК Наименование,
			               |	Сотрудники.Имя КАК Имя,
			               |	Сотрудники.Отчество КАК Отчество,
			               |	Сотрудники.Фамилия КАК Фамилия,
			               |	Сотрудники.НаименованиеСокращенное КАК НаименованиеСокращенное
			               |ИЗ
			               |	Справочник.Сотрудники КАК Сотрудники
			               |ГДЕ
			               |	Сотрудники.Ссылка = &Ссылка";
			
			Запрос.УстановитьПараметр("Ссылка", Сотрудник);
			ВыборкаСотрудника = Запрос.Выполнить().Выбрать();
			Если ВыборкаСотрудника.Следующий() Тогда
				Если ЗначениеЗаполнено(СокрЛП(ВыборкаСотрудника.НаименованиеСокращенное)) Тогда 
					Возврат СокрЛП(ВыборкаСотрудника.НаименованиеСокращенное);
				Иначе 	
					СтруктураНаименованияСотрудника = Новый Структура;
					СтруктураНаименованияСотрудника.Вставить("Фамилия"		, ВыборкаСотрудника.Фамилия);
					СтруктураНаименованияСотрудника.Вставить("Имя"			, ВыборкаСотрудника.Имя);
					СтруктураНаименованияСотрудника.Вставить("Отчество"		, ВыборкаСотрудника.Отчество);
					СтруктураНаименованияСотрудника.Вставить("Наименование"	, ВыборкаСотрудника.Наименование);
					
					Возврат ПолучитьСокращенноеНаименованиеСотрудника(СтруктураНаименованияСотрудника);
				КонецЕсли;
			Иначе 
				Возврат Строка(Сотрудник);
			КонецЕсли;	
		КонецЕсли;
	Иначе 	
		ФамилияЗаполнена = ЗначениеЗаполнено(СтруктураНаименованияСотрудника.Фамилия); 
		ИмяЗаполнено     = ЗначениеЗаполнено(СтруктураНаименованияСотрудника.Имя); 
		
		Если ФамилияЗаполнена ИЛИ ИмяЗаполнено Тогда 
			ОтчествоЗаполнено = ЗначениеЗаполнено(СтруктураНаименованияСотрудника.Отчество);
			
			Возврат ?(ФамилияЗаполнена	, "" + ВРег(Лев(СокрЛП(СтруктураНаименованияСотрудника.Фамилия), 1)) + НРег(Сред(СокрЛП(СтруктураНаименованияСотрудника.Фамилия), 2)), "") + 
			?(ИмяЗаполнено		, ?(НЕ ФамилияЗаполнена, ВРег(Лев(СокрЛП(СтруктураНаименованияСотрудника.Имя), 1)) + НРег(Сред(СокрЛП(СтруктураНаименованияСотрудника.Имя), 2)), Символ(160) + ВРег(Лев(СокрЛП(СтруктураНаименованияСотрудника.Имя), 1)) + "."), "") + 
			?(ОтчествоЗаполнено	, Символ(160) + ВРег(Лев(СокрЛП(СтруктураНаименованияСотрудника.Отчество), 1)) + ".", "");
		Иначе
			Возврат СтруктураНаименованияСотрудника.Наименование;
		КонецЕсли;	
	КонецЕсли;

КонецФункции

// Функция - Получить представление сотрудника по настройке отображения.
//
Функция ПолучитьПредставлениеСотрудникаПоНастройкеОтображения(Сотрудник, ОтображениеСотрудника) Экспорт
		
	Представление = "";
	
	// Фамилия Имя Отчество.
	Если ОтображениеСотрудника = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСотрудникаВариант1 Тогда
		
		Если ЗначениеЗаполнено(Сотрудник.Наименование) Тогда
		     Представление = Сотрудник.Наименование;
		Иначе
			 Представление = СокрЛП(Сотрудник.Фамилия) + ?(ЗначениеЗаполнено(Сотрудник.Имя) 
			 	И ЗначениеЗаполнено(Сотрудник.Фамилия), " " + СокрЛП(Сотрудник.Имя), СокрЛП(Сотрудник.Имя));
		 КонецЕсли;
		 
	// Фамилия Имя.
	ИначеЕсли ОтображениеСотрудника = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСотрудникаВариант2 Тогда
		
		Представление = СокрЛП(Сотрудник.Фамилия) + ?(ЗначениеЗаполнено(Сотрудник.Имя) 
			И ЗначениеЗаполнено(Сотрудник.Фамилия), " " + СокрЛП(Сотрудник.Имя), СокрЛП(Сотрудник.Имя));
		
	// Фамилия И.О.
	ИначеЕсли ОтображениеСотрудника = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСотрудникаВариант3
		И (ЗначениеЗаполнено(Сотрудник.Фамилия) ИЛИ ЗначениеЗаполнено(Сотрудник.Имя)) Тогда
		
		Представление = ?(ЗначениеЗаполнено(Сотрудник.Фамилия),
		Сотрудник.Фамилия + "","") + ?(ЗначениеЗаполнено(Сотрудник.Имя),
		" " + Лев(СокрЛП(Сотрудник.Имя), 1) + ".","") + ?(ЗначениеЗаполнено(Сотрудник.Отчество), " " 
			+ Лев(СокрЛП(Сотрудник.Отчество), 1) + ".", "");			
	// Имя.
	ИначеЕсли ОтображениеСотрудника = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСотрудникаВариант4
		И ЗначениеЗаполнено(Сотрудник.Имя) Тогда
		
		Представление = СокрЛП(Сотрудник.Имя);
		
	// Представление в онлайн-записи.
	ИначеЕсли ОтображениеСотрудника = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСотрудникаВариант5
		И ЗначениеЗаполнено(Сотрудник.ПредставлениеДляОнлайнЗаписи) Тогда
		
		Представление = СокрЛП(Сотрудник.ПредставлениеДляОнлайнЗаписи);
	Иначе
		Представление = СокрЛП(Сотрудник.Наименование);	
	КонецЕсли;
	
	Возврат Представление;

КонецФункции

// Функция - Получить места работы сотрудника
//
// Параметры:
//  Сотрудник					 - 	 - 
//  ТипВозвращаемыхДанных		 - 	 - 
//  ВыбраннаяСтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМестаРаботыСотрудника(Сотрудник
									, ТипВозвращаемыхДанных = "Список"
									, ВыбраннаяСтруктурнаяЕдиница = Неопределено
									, ДобавлятьТекущую = Ложь
									, ИспользоватьЗакешированноеЗначение = Истина) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда 
		Сотрудник = ПараметрыСеанса.ТекущийСотрудник;
	ИначеЕсли ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Пользователи") Тогда
		Сотрудник = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник,"Сотрудник");
	КонецЕсли;
	
	Если ИспользоватьЗакешированноеЗначение Тогда 
		ТаблицаКлиник = ОбщегоНазначенияПовтИспСтоматология.ПолучитьДоступныеКлиникиДляРаботыСотрудника(Сотрудник);
	Иначе 
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Сотрудник"	, Сотрудник);
		Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДатаСеанса());		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница) КАК Представление
		|ИЗ
		|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиДоступныеСтруктурныеЕдиницы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК Сотрудники
		|		ПО СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = Сотрудники.СтруктурнаяЕдиница
		|			И СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = Сотрудники.Сотрудник
		|ГДЕ
		|	СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = &Сотрудник
		|	И ВЫБОР
		|			КОГДА ЕСТЬNULL(Сотрудники.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) = ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ Сотрудники.ДатаУвольнения > &ТекущаяДата
		|		КОНЕЦ
		|	И СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
		|	И СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ЭтоГруппа = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.Наименование";
		
		
		ТаблицаКлиник = Запрос.Выполнить().Выгрузить();
	КонецЕсли;
	
	Если ДобавлятьТекущую Тогда
		ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		Если ЗначениеЗаполнено(ТекущаяСтруктурнаяЕдиница) И ТаблицаКлиник.Найти(ТекущаяСтруктурнаяЕдиница, "СтруктурнаяЕдиница") = Неопределено Тогда
			Если ТипВозвращаемыхДанных = "Список" Тогда
				ТекущаяКлиникаПредставление = Строка(ТекущаяСтруктурнаяЕдиница);			
				ЗаполнитьЗначенияСвойств(ТаблицаКлиник.Добавить(), Новый Структура("СтруктурнаяЕдиница, Представление", ТекущаяСтруктурнаяЕдиница, ТекущаяКлиникаПредставление));
			Иначе 
				ЗаполнитьЗначенияСвойств(ТаблицаКлиник.Добавить(), Новый Структура("СтруктурнаяЕдиница, Представление", ТекущаяСтруктурнаяЕдиница, ""));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если ТипВозвращаемыхДанных = "Список" Тогда  
		СписокСтруктурныхЕдиниц = Новый СписокЗначений;
		Для Каждого СтрокаТаблицы Из ТаблицаКлиник Цикл 
			СписокСтруктурныхЕдиниц.Добавить(СтрокаТаблицы.СтруктурнаяЕдиница, СокрЛП(СтрокаТаблицы.Представление), СтрокаТаблицы.СтруктурнаяЕдиница = ?(ЗначениеЗаполнено(ВыбраннаяСтруктурнаяЕдиница), ВыбраннаяСтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));			
		КонецЦикла;
		Возврат СписокСтруктурныхЕдиниц;
	Иначе 
		Возврат ТаблицаКлиник.ВыгрузитьКолонку("СтруктурнаяЕдиница");
	КонецЕсли;	

КонецФункции

// Функция - Получить служебного сотрудника
//
// Параметры:
//  Наименование - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСлужебногоСотрудника(Наименование = Неопределено) Экспорт
	
	// Служебные сотрудники:
	// <Не указан>
	// Служебный пользователь API (не удалять!)
	// Служебный Моби (не удалять!)
	// СоДоступ
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда 
		Наименование = "<Не указан>";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НаименованиеСлужебногоСотрудника", Наименование);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Служебный
	|	И Сотрудники.Наименование ПОДОБНО &НаименованиеСлужебногоСотрудника";
	
	ВыборкаСлужебного = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаСлужебного.Следующий() Тогда 
		Возврат ВыборкаСлужебного.Ссылка;
	Иначе 
		Возврат Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;	
	
КонецФункции	

// Функция, возвращает структуру контактной информации.
//
Функция ПолучитьКонтактнуюИнформацию(Сотрудник, ДобавитьКодСтраны = Ложь) Экспорт
	
	EmailСтроки = Сотрудник.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
	Email = Неопределено;
	Если EmailСтроки.Количество() > 0 Тогда
	  Email = EmailСтроки[0].АдресЭП;
	КонецЕсли;
	
	ТелефонСтроки = Сотрудник.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
	НомерТелефона = Неопределено;
	Если ТелефонСтроки.Количество() > 0 Тогда
		
		НомерТелефона = ТелефонСтроки[0].НомерТелефона;
		
		СписокПолей = Новый СписокЗначений;
		УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(НомерТелефона, СписокПолей); 
		НомерТелефона = ?(ДобавитьКодСтраны, СписокПолей[0].Значение, "") + СписокПолей[1].Значение + СписокПолей[2].Значение;
		
	КонецЕсли;
	
	Возврат Новый Структура("Email, Телефон", Email, НомерТелефона);
	
КонецФункции

// Процедура - Записать фото сотрудника
