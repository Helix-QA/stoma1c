КонецПроцедуры

// Процедура - Обновить группу значений фильтра
//
// Параметры:
//  Форма								 - 	 - 
//  СтрокаФильтр						 - 	 - 
//  ИнициализироватьВыбранноеЗначение	 - 	 - 
//  ВыбранноеЗначение					 - 	 - 
//
Процедура ОбновитьГруппуЗначенийФильтра(Форма, СтрокаФильтр, ИнициализироватьВыбранноеЗначение = Ложь, ВыбранноеЗначение = Неопределено) Экспорт
	
	Если ИнициализироватьВыбранноеЗначение И ЗначениеЗаполнено(ВыбранноеЗначение) Тогда 
		ИнициализироватьВыбранноеЗначениеВсписке(Форма, СтрокаФильтр, ВыбранноеЗначение);
	КонецЕсли;
	
	УдалитьЭлементыФильтра(Форма, СтрокаФильтр.ИмяГруппыЗначенийФильтра);
	
	Если СтрокаФильтр.РеквизитДата <> Дата(1,1,1) Тогда 
		ОбновитьЭлементыФильтрацииПериода(Форма, СтрокаФильтр);
		Возврат;
	ИначеЕсли СтрНайти(СтрокаФильтр.Наименование, "Вероятность") <> 0 И СтрокаФильтр.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда 
		ОбновитьЭлементыВыбораДиапазонаЧисловыхЗначений(Форма, СтрокаФильтр);
		Возврат;				
	ИначеЕсли НЕ СтрокаФильтр.Инициализирован И СтрокаФильтр.ТолькоПолеВыбора Тогда 
		ОбновитьЭлементыВыбораЗначения(Форма, СтрокаФильтр);
	КонецЕсли;	
	
	КоличествоЭлементовРазмещаемыхВСтроке 					= 0;
	ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке 	= ПолучитьПримерноеКоличествоЗначенийПомещаемыхВСтрокеФильтра(СтрокаФильтр.СписокЗначений);	
	
	Для Каждого ЭлементСпискаЗначенияФильтра Из СтрокаФильтр.СписокЗначений Цикл 
		
		ИдентификаторЗначения = ЭлементСпискаЗначенияФильтра.ПолучитьИдентификатор();
		
		Если Цел(КоличествоЭлементовРазмещаемыхВСтроке / ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке) = КоличествоЭлементовРазмещаемыхВСтроке / ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке Тогда 
			Группа_Строка_Значений = Форма.Элементы.Добавить("Группа_Строка_Значений" + СтрокаФильтр.Наименование + "_" + Формат(КоличествоЭлементовРазмещаемыхВСтроке, "ЧН=0"), Тип("ГруппаФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра]);
			Группа_Строка_Значений.Вид 														= ВидГруппыФормы.ОбычнаяГруппа;
			Группа_Строка_Значений.Заголовок 												= Группа_Строка_Значений.Имя;
			Группа_Строка_Значений.Отображение 												= ОтображениеОбычнойГруппы.Нет;
			Группа_Строка_Значений.Группировка 												= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
			Группа_Строка_Значений.ОтображатьЗаголовок 										= Ложь;		
			Группа_Строка_Значений.ГоризонтальныйИнтервал 									= ИнтервалМеждуЭлементамиФормы.Половинный;
			Группа_Строка_Значений.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Центр;
			Группа_Строка_Значений.ВертикальноеПоложениеПодчиненных 						= ВертикальноеПоложениеЭлемента.Центр;
		КонецЕсли;
		
		Группа_Значения = Форма.Элементы.Добавить("Группа_Значения_" + СтрокаФильтр.Наименование + "_" + Формат(ИдентификаторЗначения, "ЧН=0"), Тип("ГруппаФормы"), Группа_Строка_Значений);
		Группа_Значения.Вид 														= ВидГруппыФормы.ОбычнаяГруппа;
		Группа_Значения.Заголовок 													= Группа_Значения.Имя;
		Группа_Значения.Отображение 												= ОтображениеОбычнойГруппы.Нет;
		Группа_Значения.Группировка 												= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		Группа_Значения.ОтображатьЗаголовок 										= Ложь;		
		Группа_Значения.ГоризонтальныйИнтервал 										= ИнтервалМеждуЭлементамиФормы.Половинный;
		// Группа_Значения.ЦветФона 													= ?(ЭлементСпискаЗначенияФильтра.Значение.Выбран, Новый Цвет(243, 243, 243), Новый Цвет());
		Группа_Значения.ЦветФона 													= ?(ЭлементСпискаЗначенияФильтра.Значение.Выбран, СтрокаФильтр.ЦветВыбранногоЗначения, Новый Цвет(255, 255, 255));		
		Группа_Значения.ВертикальноеПоложениеВГруппе 								= ВертикальноеПоложениеЭлемента.Центр;
		Группа_Значения.ВертикальноеПоложениеПодчиненных 							= ВертикальноеПоложениеЭлемента.Центр;
		// Группа_Значения.Ширина 														= ПараметрыОтображенияДанных.МаксимальнаяШирина_Группы;
		// Группа_Значения.РастягиватьПоГоризонтали 									= Ложь;
		
		ЭлементСпискаЗначенияФильтра.Значение.ИмяГруппыЗначенияФильтра 				= Группа_Значения.Имя;
		
		КомандаАктивизацииЗначенияФильтра = Форма.Команды.Найти("Активировать_ЗначениеФильтра_" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторЗначения);
		Если КомандаАктивизацииЗначенияФильтра = Неопределено Тогда
