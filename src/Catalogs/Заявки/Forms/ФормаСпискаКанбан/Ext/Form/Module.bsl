&НаСервереБезКонтекста
// Функция, возвращает блок заявки.
//
Функция ПолучитьБлокЗаявки(ДанныеЗаявки)
	
	ПредставлениеДатыСоздания				 = ПолучитьПредставлениеДаты(ДанныеЗаявки.ДатаСоздания);
	ИдентификаторЗаявки						 = XMLСтрока(ДанныеЗаявки.Ссылка);
	КодЗаявкиБезНулей						 = ПолучитьНомерНаПечать(ДанныеЗаявки.Код);
	СтатусПациента							 = ДанныеЗаявки.СтатусПациента;
	ИдентификаторКлиента					 = XMLСтрока(ДанныеЗаявки.Клиент);
	ПредставлениеКлиента					 = ДанныеЗаявки.КлиентПредставление;
	НаименованиеЗаявки						 = ?(ЗначениеЗаполнено(ДанныеЗаявки.Клиент), "", ДанныеЗаявки.Наименование);
	ИдентификаторСотрудника					 = XMLСтрока(ДанныеЗаявки.ОсновнойМенеджер);
	ПредставлениеСотрудника					 = ДанныеЗаявки.ОсновнойМенеджерПредставление;
	ПредставлениеРекламногоИсточника		 = ДанныеЗаявки.РекламныйИсточникПредставление;
	ПредставлениеЗначенияКаналаПривлечения	 = ?(ЗначениеЗаполнено(ДанныеЗаявки.КаналПривлеченияЗначениеПредставление), " - " + ДанныеЗаявки.КаналПривлеченияЗначениеПредставление, "");
	ПредставлениеКаналаПривлечения			 = ДанныеЗаявки.КаналПривлеченияПредставление + ПредставлениеЗначенияКаналаПривлечения;
	ПредставлениеОценкиЗаявки				 = ?(ДанныеЗаявки.Статус = Перечисления.СтатусыЗаявок.Отклонена, ДанныеЗаявки.ОценкаЗаявкиПредставление, "");
	АдресаЭП								 = СтрЗаменить(ДанныеЗаявки.АдресЭП, ", ", Символы.ПС);
	ИдентификаторСделки						 = XMLСтрока(ДанныеЗаявки.Сделка);
	ПредставлениеСделки						 = Строка(ДанныеЗаявки.СделкаПредставление);
	ПредставлениеЭтапаСделки				 = Строка(ДанныеЗаявки.ЭтапСделкиПредставление);
	ЦветЭтапа								 = ?(ЗначениеЗаполнено(ДанныеЗаявки.ЦветЭтапа), ЗначениеИзСтрокиВнутр(ДанныеЗаявки.ЦветЭтапа), Новый Цвет(242, 242, 242));
	ЦветТекстаЭтапа							 = ОбщегоНазначенияСтоматология.ПолучитьЦветТекстаПоЦветуФона(ЦветЭтапа, Истина);
	КлассПометкиУдаления					 = ?(ДанныеЗаявки.ПометкаУдаления, " deleted", "");
	ПредставлениеВнешнейСистемы				 = ДанныеЗаявки.ВнешняяСистемаПредставление;
	Комментарий								 = ДанныеЗаявки.Комментарий;
	
	СтильЦветФонаСделки		 = "background:" + ПолучитьЦветДляHTML(ЦветЭтапа) + ";";
	СтильЦветТекстаСделки	 = "color:" + ПолучитьЦветДляHTML(ЦветТекстаЭтапа) + ";";
	СтилиСделки				 = СтильЦветФонаСделки + СтильЦветТекстаСделки;
	
	ТекстПоляСделки = СокрЛП(ПредставлениеСделки + " " + ПредставлениеЭтапаСделки);
	
	НомераТелефонов = СтрРазделить(ДанныеЗаявки.НомерТелефона, ",", Ложь);
	
	БлокНомеров = "";
	Для Каждого НомерТелефона Из НомераТелефонов Цикл
		БлокНомера = "<div class='phone-number'>" + НомерТелефона + "</div>";
		БлокНомеров = БлокНомеров + БлокНомера;
