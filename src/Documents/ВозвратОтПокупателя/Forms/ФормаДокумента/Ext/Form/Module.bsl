
#Область ОбработчикиСобытийФормы  

&НаКлиенте
Перем ИскомыйКлиент;

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Объект.СтруктурнаяЕдиница = Объект.Склад.СтруктурнаяЕдиница;		
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен, ЗначениеЗаполнено(Объект.НомерЧекаККМ));
	// Установим реквизиты
	СкладДокумента = Объект.Склад;	
	Если Не ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		Объект.ВидЦен = ?(ЗначениеЗаполнено(Объект.ДокументОснования), 
				Объект.ДокументОснования.ВидЦен, ?(Не Объект.СтруктурнаяЕдиница.ВидЦенРеализации.Пустая(), 
						Объект.СтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Розничная));
	КонецЕсли;		
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы); 	 
	// Заполнить реквзит блокировки скидок
	Для Каждого СтрокаТЧ ИЗ Объект.Лечение Цикл
		СтрокаТЧ.СкидкиЗапрещены = СтрокаТЧ.Номенклатура.СкидкиЗапрещены;
	КонецЦикла;
	// Заполнить реквзит блокировки скидок
	Для Каждого СтрокаТЧ ИЗ Объект.Запасы Цикл
		СтрокаТЧ.СкидкиЗапрещены = СтрокаТЧ.Номенклатура.СкидкиЗапрещены;
	КонецЦикла;
	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	
	ОбновитьМенюДокумента();
	УстановкаСостоянияЭлементовФормы();
	ЭтаФорма.ТолькоПросмотр = ЗначениеЗаполнено(Объект.НомерЧекаККМ);
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ПриОкрытии
//
Процедура ПриОткрытии(Отказ)
	
		// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма); 
//	ОбщегоНазначенияСтоматология.УстановитьОтображениеЗакладокСкидкиНаценкиПодарки(ЭтаФорма);
	УстановитьОтображениеЗакладокСкидкиНаценкиПодаркиАвансы();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ОбработкаОповещения
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			ПолученыШтрихкоды(Данные);
		ИначеЕсли ИмяСобытия = "DataCollectionTerminal" Тогда
			ПолученыШтрихкоды(Параметр);
		КонецЕсли;
	КонецЕсли;
	// Конец ВнешнееОборудование 
	
	Если Источник = "ВнешнееОборудование" И ИмяСобытия = "НеизвестныеШтрихкоды" 
			И УникальныйИдентификатор = Параметр.ФормаВладелецУникальныйИдентификатор Тогда
		ПолученыШтрихкоды(Параметр.ЗарегистрированныеШтрихкоды);
	КонецЕсли;	
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи"
// 
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере"
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);	
	
КонецПроцедуры


&НаСервере
// Установить состояние элементов формы 
//
Процедура УстановкаСостоянияЭлементовФормы()
	
	Элементы.ПолисМедСтрахования.Доступность     = ЗначениеЗаполнено(Объект.ПолисМедСтрахования);	
	Элементы.Подбор.Доступность                  = НЕ ЗначениеЗаполнено(Объект.ДокументОснования);
	// ОбщегоНазначенияСтоматология.УстановитьОтображениеЗакладокСкидкиНаценкиПодарки(ЭтаФорма);
	УстановитьОтображениеЗакладокСкидкиНаценкиПодаркиАвансы(); 
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен, ЗначениеЗаполнено(Объект.НомерЧекаККМ));
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиРеквизитовШапки

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поле выбора "Контрагент"
//
Процедура КонтрагентПриИзменении(Элемент)	
	Если ЗначениеЗаполнено(Объект.ДокументОснования) Тогда
		Объект.ДокументОснования = Неопределено;		
	КонецЕсли;	
	ПодборВозвратовЗавершениеСервер(Неопределено);
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура КонтрагентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	ПараметрыОткрытия = Новый Структура("ТекущаяСтрока", Объект.Контрагент);
	
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты",
	ПараметрыОткрытия,,,,,
	Новый ОписаниеОповещения("КонтрагентНачалоВыбораЗавершение", ЭтотОбъект, Элемент), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора контрагента
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура КонтрагентНачалоВыбораЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
		Объект.Контрагент = РезультатВыбора;
		КонтрагентПриИзменении(ДополнительныеПараметры);
	КонецЕсли; 	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ОкончаниеВводаТекста
//
Процедура КонтрагентОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;	
	ДанныеВыбора = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(Текст, , Истина, Истина);	

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "АвтоПодбор"
//
Процедура КонтрагентАвтоПодбор(Элемент, Текст, ДанныеВыбора, Ожидание, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	ИскомыйКлиент = Текст;	
	ДанныеВыбора = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(Текст, 10, Истина, Истина);

КонецПроцедуры

&НаСервере
// Процедура, устанавливает структурную единицу при изменении склада документа.
//  Параметры: 
//   Нет;
//
Процедура УстановитьСтруктурнуюЕдиницуПоСкладу()
	
	Объект.СтруктурнаяЕдиница = СкладДокумента.СтруктурнаяЕдиница;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Основание возврата при изменении.
//
Процедура ОснованиеВозвратаПриИзменении(Элемент)
	
	ПодборВозвратовЗавершениеСервер(Неопределено);
	
КонецПроцедуры

&НаКлиенте
// Обработчик начала выбора документа основания. 
//
Процедура ОснованиеВозвратаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)	
	
	СтандартнаяОбработка = Ложь;
		
	СтруктураОткрытия = Новый Структура;
	СтруктураОткрытия.Вставить("Дата"              , ?(ЗначениеЗаполнено(Объект.Ссылка), КонецДня(Объект.Дата), КонецДня(ТекущаяДата())));
	СтруктураОткрытия.Вставить("Клиент"            , Объект.Контрагент);
	СтруктураОткрытия.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	СтруктураОткрытия.Вставить("Документ"          , Объект.Ссылка);
	
	ОткрытьФорму("Документ.ВозвратОтПокупателя.Форма.ФормаПодбораВозврата", СтруктураОткрытия, ЭтаФорма,,,, Новый ОписаниеОповещения("ПодборВозвратовЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаКлиенте
// Процедура - Подбор возвратов завершение.
//
Процедура ПодборВозвратовЗавершение(Результат, Параметры) Экспорт
	
	Если Не Результат = Неопределено Тогда
		Результат.Свойство("ДокументОснования", Объект.ДокументОснования);
		ПодборВозвратовЗавершениеСервер(Результат);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// При изменении выбора документа основания, сервер.
//
Процедура ПодборВозвратовЗавершениеСервер(Результат)
		
	Если ЗначениеЗаполнено(Объект.ДокументОснования) Тогда
		Объект.Контрагент = Объект.ДокументОснования.Контрагент;
		Объект.Склад      = Объект.ДокументОснования.Склад;
		Объект.Сотрудник  = Объект.ДокументОснования.Сотрудник;
		Объект.ВидЦен     = Объект.ДокументОснования.ВидЦен;
		
		Если ТипЗнч(Объект.ДокументОснования) = Тип("ДокументСсылка.Прием") Тогда
			Объект.ПолисМедСтрахования	= Объект.ДокументОснования.ПолисМедСтрахования;
			Объект.Ассистент  			= Объект.ДокументОснования.Ассистент;
		Иначе
			Объект.ПолисМедСтрахования = Неопределено;
		КонецЕсли;
		
		Объект.Запасы.Очистить();
		Объект.Лечение.Очистить();
		Объект.СкидкиНаценки.Очистить();
		Объект.Подарки.Очистить();
		Объект.УчтенныеАвансы.Очистить();
		
		МассивКлючейНоменклатуры = Новый Массив;
		
		Если Результат.Свойство("МассивСтрокВыбраннойНоменклатуры") Тогда
		
			Для Каждого СтрокаПодбора Из Результат.МассивСтрокВыбраннойНоменклатуры Цикл 
				
				Если СтрокаПодбора.ТипНоменклатуры =  Перечисления.ТипыНоменклатуры.Услуга Тогда					
					НоваяСтрока = Объект.Лечение.Добавить();					
				ИначеЕсли СтрокаПодбора.ТипНоменклатуры =  Перечисления.ТипыНоменклатуры.Запас Тогда
					НоваяСтрока = Объект.Запасы.Добавить();	
				КонецЕсли;
				
				МассивКлючейНоменклатуры.Добавить(СтрокаПодбора.КлючСтроки);				
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПодбора);
				
			КонецЦикла;
		
		КонецЕсли;
		
		ЗаполнитьДопТаблицыПоДокументуОснования(МассивКлючейНоменклатуры);	
						
		Объект.СуммаДокумента = Объект.Лечение.Итог("Сумма") + Объект.Запасы.Итог("Сумма");
		ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	Иначе
		Объект.ПолисМедСтрахования = Неопределено;
		Объект.Склад               = Неопределено;
		Объект.Сотрудник           = Неопределено;	                                       			
		Объект.Запасы.Очистить();
		Объект.Лечение.Очистить();
		Объект.СкидкиНаценки.Очистить();
		Объект.Подарки.Очистить();
	КонецЕсли;  
	
	ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма); 
	
	УстановкаСостоянияЭлементовФормы();
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить доп. таблицы документа по документу основания.
//
Процедура ЗаполнитьДопТаблицыПоДокументуОснования(МассивКлючейНоменклатуры)
	
	Если НЕ ЗначениеЗаполнено(Объект.ДокументОснования) ИЛИ НЕ ЗначениеЗаполнено(МассивКлючейНоменклатуры) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемСкидкиНаценки.КлючСтроки КАК КлючСтроки,
	|	ПриемСкидкиНаценки.НоменклатураСкидки КАК НоменклатураСкидки,
	|	ПриемСкидкиНаценки.СкидкаНаценка КАК СкидкаНаценка,
	|	ПриемСкидкиНаценки.Сумма КАК Сумма,
	|	ПриемСкидкиНаценки.БонусныйСчет КАК БонусныйСчет,
	|	ПриемСкидкиНаценки.ПризнакОплатыБонусом КАК ПризнакОплатыБонусом,
	|	ПриемСкидкиНаценки.Контрагент КАК Контрагент
	|ИЗ
	|	Документ.Прием.СкидкиНаценки КАК ПриемСкидкиНаценки
	|ГДЕ
	|	ПриемСкидкиНаценки.Ссылка = &ДокументОснования
	|	И ПриемСкидкиНаценки.КлючСтроки В(&МассивКлючейНоменклатуры)
	|	И ПриемСкидкиНаценки.Использование = ИСТИНА
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияСкидкиНаценки.КлючСтроки,
	|	РеализацияСкидкиНаценки.НоменклатураСкидки,
	|	РеализацияСкидкиНаценки.СкидкаНаценка,
	|	РеализацияСкидкиНаценки.Сумма,
	|	РеализацияСкидкиНаценки.БонусныйСчет,
	|	РеализацияСкидкиНаценки.ПризнакОплатыБонусом,
	|	РеализацияСкидкиНаценки.Контрагент
	|ИЗ
	|	Документ.Реализация.СкидкиНаценки КАК РеализацияСкидкиНаценки
	|ГДЕ
	|	РеализацияСкидкиНаценки.Ссылка = &ДокументОснования
	|	И РеализацияСкидкиНаценки.КлючСтроки В(&МассивКлючейНоменклатуры)
	|	И РеализацияСкидкиНаценки.Использование = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемПодарки.КлючСтроки КАК КлючСтроки,
	|	ПриемПодарки.Количество КАК Количество,
	|	ПриемПодарки.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ПриемПодарки.Контрагент КАК Контрагент,
	|	ПриемПодарки.Номенклатура КАК Номенклатура,
	|	ПриемПодарки.Партия КАК Партия,
	|	ПриемПодарки.СкидкаНаценка КАК СкидкаНаценка,
	|	ПриемПодарки.СуммаПодарочногоСертификата КАК СуммаПодарочногоСертификата,
	|	ПриемПодарки.Упаковка КАК Упаковка
	|ИЗ
	|	Документ.Прием.Подарки КАК ПриемПодарки
	|ГДЕ
	|	ПриемПодарки.Ссылка = &ДокументОснования
	|	И ПриемПодарки.КлючСтроки В(&МассивКлючейНоменклатуры)
	|	И ПриемПодарки.Использование = ИСТИНА
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияПодарки.КлючСтроки,
	|	РеализацияПодарки.Количество,
	|	РеализацияПодарки.КоличествоУпаковок,
	|	РеализацияПодарки.Контрагент,
	|	РеализацияПодарки.Номенклатура,
	|	РеализацияПодарки.Партия,
	|	РеализацияПодарки.СкидкаНаценка,
	|	РеализацияПодарки.СуммаПодарочногоСертификата,
	|	РеализацияПодарки.Упаковка
	|ИЗ
	|	Документ.Реализация.Подарки КАК РеализацияПодарки
	|ГДЕ
	|	РеализацияПодарки.Ссылка = &ДокументОснования
	|	И РеализацияПодарки.КлючСтроки В(&МассивКлючейНоменклатуры)
	|	И РеализацияПодарки.Использование = ИСТИНА");
	
	Запрос.УстановитьПараметр("ДокументОснования", Объект.ДокументОснования);
	Запрос.УстановитьПараметр("МассивКлючейНоменклатуры", МассивКлючейНоменклатуры);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	Объект.СкидкиНаценки.Загрузить(РезультатыЗапроса[0].Выгрузить());
	Объект.Подарки.Загрузить(РезультатыЗапроса[1].Выгрузить());  
	
КонецПроцедуры

