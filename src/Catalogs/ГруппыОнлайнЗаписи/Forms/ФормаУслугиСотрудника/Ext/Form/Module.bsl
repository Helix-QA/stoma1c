
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СоздатьДеревоУслуг();
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьФильтр();
	ПослеЗаполненияСпискаподбораноменклатур();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ФильтрПриИзменении(Элемент)
	
	УстановитьФильтр();
	Если Фильтр = 1 Тогда
		ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборНоменклатур, Истина);		
		Если ИдТекЭлемент <> Неопределено Тогда
			Элементы._ПодборНоменклатур.ТекущаяСтрока = ИдТекЭлемент;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура Подключаемый_ПодборНоменклатураПриИзменении(Элемент)
	
	ТаблицаНоменклатуры.Очистить();
	
	ИмяКолонки = Элемент.Имя;
	ТекущиеДанные = Элементы._ПодборНоменклатур.ТекущиеДанные;
	ЗначениеФлага = ?(ТекущиеДанные[ИмяКолонки] = 2, 0, ТекущиеДанные[ИмяКолонки]);
	ИндексКолонки = Число(Сред(ИмяКолонки, СтрНайти(ИмяКолонки, "_") + 1));			
	УстановитьФлагиНаЭлементы(ЗначениеФлага, ТекущиеДанные, ИмяКолонки, ИндексКолонки);
	
	Для Индекс = 0 По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		УстановитьФлагиНаГруппы(ТекущиеДанные, "ГруппаОнлайнЗаписи_"+Индекс, ТекущиеДанные.ЭтоГруппа);			
	КонецЦикла;
	
	Если Фильтр = 1 Тогда
		ИдТекЭлемент = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭтаФорма._ПодборНоменклатур, Истина);		
		Если ИдТекЭлемент <> Неопределено Тогда
			Элементы._ПодборНоменклатур.ТекущаяСтрока = ИдТекЭлемент;
		КонецЕсли;
	КонецЕсли;
	
	СохранитьЗначения(ТаблицаНоменклатуры);
	
КонецПроцедуры  

&НаКлиенте
// Процедура, обработчик события "ПередНачаломДобавления".
//
Процедура Подключаемый_ПодборСотрудниковПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередУдалением".
//
Процедура Подключаемый_ПодборСотрудниковПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, выполянет создание дерева услуг.
//
Процедура СоздатьДеревоУслуг()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ГруппыОнлайнЗаписи.Ссылка КАК ГруппаОнлайнЗаписи
	|ИЗ
	|	Справочник.ГруппыОнлайнЗаписи КАК ГруппыОнлайнЗаписи
	|ГДЕ
	|	НЕ ГруппыОнлайнЗаписи.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ГруппыОнлайнЗаписи.Код";
	ТаблицаГруппОнлайнЗаписей.Загрузить(Запрос.Выполнить().Выгрузить());	
	
	ИмяЭлементаДляРазмещения = "ГруппаДеревоНоменклатуры";
	масРеквизитов = Новый Массив;		
	
	ИмяДерева = "_ПодборНоменклатур";
	
	МассивДопустимыхТипов = Новый Массив;
	МассивДопустимыхТипов.Добавить(Тип("СправочникСсылка.Номенклатура"));
	МассивДопустимыхТипов.Добавить(Тип("Строка"));
	
	масРеквизитов.Добавить(Новый РеквизитФормы(ИмяДерева		       , Новый ОписаниеТипов("ДеревоЗначений"), , "Подбор номенклатур", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Номенклатура"	       , Новый ОписаниеТипов(МассивДопустимыхТипов), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ЭтоГруппа"		       , Новый ОписаниеТипов("Булево"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ИндКартинки"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	
	Для Индекс = 0 По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		масРеквизитов.Добавить(Новый РеквизитФормы("ГруппаОнлайнЗаписи_" + Индекс,  Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(1,0)), ИмяДерева));
	КонецЦикла;
	
	масРеквизитов.Добавить(Новый РеквизитФормы("_ПодборНоменклатурИсточникГрупп", Новый ОписаниеТипов("ДеревоЗначений"), , "Услгуи подбор список", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"), "_ПодборНоменклатурИсточникГрупп"));
	
	ИмяДерева = "_ПодборНоменклатурИсточникЭлементов";
	масРеквизитов.Добавить(Новый РеквизитФормы(ИмяДерева		       , Новый ОписаниеТипов("ТаблицаЗначений"), , "Услгуи подбор список", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Номенклатура"	       , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ЭтоГруппа"		       , Новый ОписаниеТипов("Булево"), ИмяДерева));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Родитель"		       , Новый ОписаниеТипов("СправочникСсылка.Номенклатура"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ИндКартинки"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Наименование"	       , Новый ОписаниеТипов("Строка"), ИмяДерева));
	
	Для Индекс = 0 По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		масРеквизитов.Добавить(Новый РеквизитФормы("ГруппаОнлайнЗаписи_" + Индекс,  Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(1,0)), ИмяДерева));
	КонецЦикла;
	
	ИзменитьРеквизиты(масРеквизитов);	
	
	ЭлементДерево = Элементы.Добавить("_ПодборНоменклатур", Тип("ТаблицаФормы"), Элементы[ИмяЭлементаДляРазмещения]);
	ЭлементДерево.ПутьКДанным 				 = "_ПодборНоменклатур";
	ЭлементДерево.Отображение 				 = ОтображениеТаблицы.Дерево;
	ЭлементДерево.КартинкаСтрок 			 = БиблиотекаКартинок.ТерминалПодбор; //БиблиотекаКартинок.ПиктограммыЭлементов;
	ЭлементДерево.ПутьКДаннымКартинкиСтроки  = "_ПодборНоменклатур.ИндКартинки";
	ЭлементДерево.ПоложениеКоманднойПанели   = ПоложениеКоманднойПанелиЭлементаФормы.Нет;	
	ЭлементДерево.АвтоМаксимальнаяШирина 	 = Ложь;
	ЭлементДерево.МаксимальнаяШирина 	 	 = 120;
	ЭлементДерево.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВсеУровни;
	ЭлементДерево.УстановитьДействие("ПередНачаломДобавления", "Подключаемый_ПодборСотрудниковПередНачаломДобавления");
	ЭлементДерево.УстановитьДействие("ПередУдалением", "Подключаемый_ПодборСотрудниковПередУдалением");
	
	НовыйЭлемент = ЭтаФорма.Элементы.Добавить("Номенклатура", Тип("ПолеФормы"), ЭлементДерево);	
	НовыйЭлемент.Вид 		 			 	 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.АвтоМаксимальнаяШирина 	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 		 = 60;
	НовыйЭлемент.ТолькоПросмотр 		 	 = Истина;
	НовыйЭлемент.ПутьКДанным				 = "_ПодборНоменклатур.Номенклатура";
	
	Для Индекс = 0 По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		
		НовыйЭлемент = Элементы.Добавить("ГруппаОнлайнЗаписи_"+Индекс, Тип("ПолеФормы"), ЭлементДерево);
		НовыйЭлемент.Вид					 = ВидПоляФормы.ПолеФлажка;
		НовыйЭлемент.ПутьКДанным			 = "_ПодборНоменклатур.ГруппаОнлайнЗаписи_"+Индекс;
		НовыйЭлемент.Заголовок				 = ТаблицаГруппОнлайнЗаписей[Индекс].ГруппаОнлайнЗаписи.Наименование;		
		НовыйЭлемент.ТриСостояния			 = Истина;
		НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
		НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ПодборНоменклатураПриИзменении");
		
	КонецЦикла;
	
	ЗаполнитьДеревоПодбораНоменклатур();
	
	ЗаполнитьСписокПодбораРекурсивноСервер(
	ЭтаФорма._ПодборНоменклатурИсточникГрупп.ПолучитьЭлементы(), 
	ЭтаФорма._ПодборНоменклатурИсточникЭлементов, 
	ЭтаФорма._ПодборНоменклатур, ЭтаФорма);		
	
	УстановитьНачальныеФлагиНаГруппы();
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет установку условного оформления.
//
Процедура УстановитьУсловноеОформление()
	
	ЭлементУФ = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	
	ГруппаОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;	
	
	Для Индекс = 0  По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл	
		ЭлементОтбора = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("_ПодборНоменклатур.ГруппаОнлайнЗаписи_" + Индекс); // имя поля	
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; // либо задаем свой
		ЭлементОтбора.ПравоеЗначение = 0;                                              
		ЭлементОтбора.Использование = Истина;
	КонецЦикла;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Видимость"), Ложь);
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Номенклатура");
	ПолеОформления.Использование = Истина;  
	
	Для Индекс = 0  По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();	
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ГруппаОнлайнЗаписи_" + Индекс);
		ПолеОформления.Использование = Истина;		
	КонецЦикла;
	
	ЭлементУФ = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	
	ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("_ПодборНоменклатур.ЭтоГруппа"); // имя поля	
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно; // либо задаем свой
	ЭлементОтбора.ПравоеЗначение = Истина;                                              
	ЭлементОтбора.Использование = Истина;
	
	ЭлементУФ.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ЦветФона"), Новый Цвет(245,245,245));
	
	ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("_ПодборНоменклатур");
	ПолеОформления.Использование = Истина; 
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет заполнение подбора номенклатуры 
//
Процедура ЗаполнитьДеревоПодбораНоменклатур()
	
	ЗапросГрупп = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СправочникНоменклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК СправочникНоменклатура
	|ГДЕ
	|	СправочникНоменклатура.ЭтоГруппа = ИСТИНА
	|	И СправочникНоменклатура.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка ИЕРАРХИЯ
	|АВТОУПОРЯДОЧИВАНИЕ");	
	
	ВыборкаГрупп = ЗапросГрупп.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	
	ЭтаФорма._ПодборНоменклатурИсточникГрупп.ПолучитьЭлементы().Очистить();	
	
	ЗаполнитьИсточникГрупп(ВыборкаГрупп, ЭтаФорма._ПодборНоменклатурИсточникГрупп.ПолучитьЭлементы());	
	ПустаяГруппа = ЭтаФорма._ПодборНоменклатурИсточникГрупп.ПолучитьЭлементы().Добавить();
	
	ЗапросНоменклатур = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СотрудникиМестаРаботы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ ВТСалоновСотрудника
	|ИЗ
	|	Справочник.Сотрудники.МестаРаботы КАК СотрудникиМестаРаботы
	|ГДЕ
	|	НЕ СотрудникиМестаРаботы.СтруктурнаяЕдиница.ПометкаУдаления
	|	И СотрудникиМестаРаботы.Ссылка = &Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыОбъектов.Объект КАК Номенклатура,
	|	РеквизитыОбъектов.Объект.Наименование КАК Наименование,
	|	РеквизитыОбъектов.Объект.Артикул КАК Артикул,
	|	РеквизитыОбъектов.Объект.ЭтоГруппа КАК ЭтоГруппа,
	|	РеквизитыОбъектов.Объект.Родитель КАК Родитель,
	|	РеквизитыОбъектов.Объект.ГруппаОнлайнЗаписи КАК ГруппаОнлайнЗаписи,
	|	2 КАК ИндКартинки
	|ИЗ
	|	ВТСалоновСотрудника КАК ВТСалоновСотрудника
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыОбъектов КАК РеквизитыОбъектов
	|		ПО ВТСалоновСотрудника.СтруктурнаяЕдиница = РеквизитыОбъектов.СтруктурнаяЕдиница
	|ГДЕ
	|	РеквизитыОбъектов.Реквизит = ""ОнлайнЗапись""
	|	И РеквизитыОбъектов.Объект ССЫЛКА Справочник.Номенклатура
	|	И РеквизитыОбъектов.Значение = ИСТИНА
	|	И НЕ РеквизитыОбъектов.Объект.ПометкаУдаления
	|	И РеквизитыОбъектов.Объект.НормаВремени <> 0
	|	И НЕ РеквизитыОбъектов.Объект.ЭтоГруппа
	|
	|СГРУППИРОВАТЬ ПО
	|	РеквизитыОбъектов.Объект,
	|	РеквизитыОбъектов.Объект.Наименование,
	|	РеквизитыОбъектов.Объект.Артикул,
	|	РеквизитыОбъектов.Объект.ЭтоГруппа,
	|	РеквизитыОбъектов.Объект.Родитель,
	|	РеквизитыОбъектов.Объект.ГруппаОнлайнЗаписи");
	
	ЗапросНоменклатур.УстановитьПараметр("Сотрудник", ПараметрыСеанса.ТекущийПользователь);
	ВыборкаНоменклатур = ЗапросНоменклатур.Выполнить().Выбрать();
	
	ЭтаФорма._ПодборНоменклатурИсточникЭлементов.Очистить();
	
	НомераСтруктурныхЕдиниц = Новый Соответствие;
	Для Индекс = 0 По ТаблицаГруппОнлайнЗаписей.Количество()-1 Цикл
		НомераСтруктурныхЕдиниц.Вставить(ТаблицаГруппОнлайнЗаписей[Индекс].ГруппаОнлайнЗаписи, Индекс);
	КонецЦикла;
	
	Пока ВыборкаНоменклатур.Следующий() Цикл
		
		СтрокаТЧ = ЭтаФорма._ПодборНоменклатурИсточникЭлементов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ВыборкаНоменклатур);
		
		Если ЗначениеЗаполнено(ВыборкаНоменклатур.ГруппаОнлайнЗаписи) Тогда			
			СтрокаТЧ["ГруппаОнлайнЗаписи_" + НомераСтруктурныхЕдиниц[ВыборкаНоменклатур.ГруппаОнлайнЗаписи]] = Истина;		
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

