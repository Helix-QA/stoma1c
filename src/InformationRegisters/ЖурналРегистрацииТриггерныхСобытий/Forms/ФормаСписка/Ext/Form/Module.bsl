
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
		Элементы.ИдентификаторДействия.Видимость = РольДоступна("ПолныеПрава");
		Элементы.СписокКонтекстноеМенюКнопкаПоказатьИдентификаторы.Видимость = НЕ Элементы.ИдентификаторДействия.Видимость;
	Иначе
		Элементы.ИдентификаторДействия.Видимость = РольДоступна("АдминистраторСистемы")	ИЛИ РольДоступна("Администрирование");
		Элементы.СписокКонтекстноеМенюКнопкаПоказатьИдентификаторы.Видимость = НЕ Элементы.ИдентификаторДействия.Видимость;		
	КонецЕсли;
	
	Элементы.Описание.Ширина = ?(Элементы.ИдентификаторДействия.Видимость, 29, 39);
	ИспользуетсяРасширениеМессенджер = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер");
	
КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)

	Если НЕ ЗначениеЗаполнено(ОтборПериод) Тогда 
		ОтборПериод.Вариант = ВариантСтандартногоПериода.ЭтаНеделя;
	КонецЕсли;
	УстановитьПериодНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Выбрать период планирования
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВыбратьПериодПланирования(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период = ОтборПериод;
	Диалог.Показать(Новый ОписаниеОповещения("ОтборПериодаПланированииПриИзменении", ЭтаФорма)); 
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить фильтрацию по статусу запланировано
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьФильтрациюПоСтатусуЗапланировано(Команда)
	
	ОбновитьСписокНаСервере("Запланировано");
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить фильтрацию по статусу зарегистрировано
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьФильтрациюПоСтатусуЗарегистрировано(Команда)
	
	ОбновитьСписокНаСервере("Зарегистрировано");
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить фильтрацию по статусу отклонено
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьФильтрациюПоСтатусуОтклонено(Команда)
	
