							СтруктураСобытия.Вставить("СтрокаПланДействий"	, СтрокаПланДействий);
							СтруктураСобытия.Вставить("СтрокаРеестра"		, СтрокаРеестра);			
							ЗарегистрироватьОшибкиРегистрацииСобытия(ДанныеТриггера, , СтруктураСобытия, ПараметрыРегистрации.РегистрацияПоПодписке, ПараметрыРегистрации.РегистрацияЗапланированных, СообщениеОбОшибке, Перечисления.СтатусыРегистрацииСобытий.Отклонено);			
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли РассылкаЗапрещена ИЛИ РассылкаЗапрещенаДляУслуги Тогда 
				// Пишем в журнал регистрации триггерных событий
				Если РассылкаЗапрещена Тогда 
					СообщениеОбОшибке = НСтр("ru='Рассылка сообщений запрещена.';en='Sending messages is prohibited.'");			
