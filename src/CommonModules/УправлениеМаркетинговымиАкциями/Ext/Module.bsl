// Заполняет таблицу подарки по скидкам
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  ТабличнаяЧастьПодарки - табличная часть "Подарки" документа.
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//
Процедура ЗаполнитьТЧСкидокНаценок(ТаблицаСкидок, ТабличнаяЧастьСкидкиНаценки, ТаблицаПредыдщееСостояниеСкидок)

	// заполняем ТЧ скидок наценок
	Для Каждого СтрокаТЗСкидок Из ТаблицаСкидок Цикл
		
		Если СтрокаТЗСкидок.Использовать = Ложь Тогда
			Продолжить;
		КонецЕсли; 
		
		Если СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент
				ИЛИ СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма
				ИЛИ СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.СуммаНаДокумент Тогда
				
			Если СтрокаТЗСкидок.СуммаСкидки = 0 Тогда
				Продолжить;
			КонецЕсли;
				
			НоваяСтрока = ТабличнаяЧастьСкидкиНаценки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗСкидок);
			НоваяСтрока.НоменклатураСкидки	= СтрокаТЗСкидок.Номенклатура;
			НоваяСтрока.Сумма				= СтрокаТЗСкидок.СуммаСкидки;
			НоваяСтрока.Использование		= Истина;
			Если СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение = Истина Тогда // Значит могут быть выклчены или не вклчены
				Если ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0 // Эта скидка была раньше, значит берем ее состояние, если использование = ложь, пропускаем
							И ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, Использование, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, Ложь, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() > 0
						ИЛИ ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТЗСкидок.СкидкаНаценка, СтрокаТЗСкидок.Номенклатура)).Количество() = 0
							И СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеВыклПоУмолчанию = Истина Тогда // Ранее не использовалась, 
					НоваяСтрока.Использование = Ложь;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВидЦен Тогда 
			
			НоваяСтрока = ТабличнаяЧастьСкидкиНаценки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗСкидок);
			НоваяСтрока.НоменклатураСкидки = СтрокаТЗСкидок.Номенклатура;
			// НоваяСтрока.ПриминениеСкидки = 2;
			НоваяСтрока.Сумма = 0;
			НоваяСтрока.Использование = Истина;
						
		ИначеЕсли СтрокаТЗСкидок.ПризнакОплатыБонусом = Истина Тогда
			
			НоваяСтрока = ТабличнаяЧастьСкидкиНаценки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗСкидок);
			НоваяСтрока.НоменклатураСкидки	= СтрокаТЗСкидок.Номенклатура;
			НоваяСтрока.Сумма				= СтрокаТЗСкидок.СуммаСкидки;
			НоваяСтрока.Использование		= Истина;
			
		КонецЕсли; 
			
	КонецЦикла;
		
КонецПроцедуры

// Заполняет таблицу подарки по скидкам
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  ТабличнаяЧастьПодарки - табличная часть "Подарки" документа.
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//
Процедура ЗаполнитьТЧПодарков(ТаблицаСкидок, ТабличнаяЧастьПодарки, ТаблицаПредыдщееСостояниеСкидок)

	ТаблицаСкидокПодарков = ТаблицаСкидок.Скопировать();
	ТаблицаСкидокПодарков.Свернуть("КлючСтроки, СкидкаНаценка, СпособПредоставленияСкидки, Использовать, Контрагент", "ЗначениеСкидкиНаценки");
	
	// Раскрываем и заполняем ТЧ подарков
	Для Каждого СтрокаТЗСкидок Из ТаблицаСкидокПодарков Цикл
		
		Если СтрокаТЗСкидок.Использовать = Ложь Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок Тогда
			
			ТаблицаПодарков = СтрокаТЗСкидок.СкидкаНаценка.НаборПодарков.Выгрузить();
			ТаблицаПодарков.Колонки.Добавить("СкидкаНаценка");
			ТаблицаПодарков.Колонки.Добавить("КлючСтроки");
			ТаблицаПодарков.Колонки.Добавить("Использование");
			// ТаблицаПодарков.Колонки.Добавить("НоменклатураДополнительная");
			// ТаблицаПодарков.Колонки.Добавить("СертификатТип");
			ТаблицаПодарков.Колонки.Добавить("Контрагент");
			
			Для Каждого СтрокаТаблицыПодарки Из ТаблицаПодарков Цикл
				
				СтрокаТаблицыПодарки.КлючСтроки					= СтрокаТЗСкидок.КлючСтроки;
				СтрокаТаблицыПодарки.СкидкаНаценка				= СтрокаТЗСкидок.СкидкаНаценка;
				СтрокаТаблицыПодарки.КоличествоУпаковок 		= СтрокаТаблицыПодарки.КоличествоУпаковок * СтрокаТЗСкидок.ЗначениеСкидкиНаценки;
				СтрокаТаблицыПодарки.Количество					= СтрокаТаблицыПодарки.Количество * СтрокаТЗСкидок.ЗначениеСкидкиНаценки;
				СтрокаТаблицыПодарки.Использование				= Истина;
				СтрокаТаблицыПодарки.Контрагент					= СтрокаТЗСкидок.Контрагент;
				
				// СтруктураПараметровНоменклатуры = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтрокаТаблицыПодарки.Номенклатура, 
				//													"СертификатВидРеализацииПакета, СертификатТип, СертификатПакетУслуг");
				//
				// Если СтруктураПараметровНоменклатуры.СертификатТип = Перечисления.ТипыПодарочныхСертификатов.НаПакетУслуг
				//	и СтруктураПараметровНоменклатуры.СертификатВидРеализацииПакета = Перечисления.ТипыНоминаловПодарочныхСертификатов.Фиксированный Тогда  
				//	СтрокаТаблицыПодарки.НоменклатураДополнительная = СтруктураПараметровНоменклатуры.СертификатПакетУслуг;
				// Иначе
				//	СтрокаТаблицыПодарки.НоменклатураДополнительная = Неопределено;
				// КонецЕсли;
				
				Если СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеНаУсмотрение = Истина Тогда // Значит могут быть выклчены или не вклчены
					Если ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТЗСкидок.КлючСтроки, СтрокаТаблицыПодарки.СкидкаНаценка, СтрокаТаблицыПодарки.Номенклатура)).Количество() > 0 // Эта скидка была раньше, значит берем ее состояние, если использование = ложь, пропускаем
								И ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, Использование, СкидкаНаценка, Номенклатура", СтрокаТаблицыПодарки.КлючСтроки, Ложь, СтрокаТаблицыПодарки.СкидкаНаценка, СтрокаТаблицыПодарки.Номенклатура)).Количество() > 0
							ИЛИ ТаблицаПредыдщееСостояниеСкидок.НайтиСтроки(Новый Структура("КлючСтроки, СкидкаНаценка, Номенклатура", СтрокаТаблицыПодарки.КлючСтроки, СтрокаТаблицыПодарки.СкидкаНаценка, СтрокаТаблицыПодарки.Номенклатура)).Количество() = 0
								И СтрокаТЗСкидок.СкидкаНаценка.ПризнакИспользованиеВыклПоУмолчанию = Истина Тогда // Ранее не использовалась, 
						СтрокаТаблицыПодарки.Использование = Ложь;
					КонецЕсли;
				КонецЕсли;
				
			КонецЦикла;
			
			ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(ТаблицаПодарков, ТабличнаяЧастьПодарки);

		ИначеЕсли СтрокаТЗСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВыдачаКарты Тогда
			
			НоваяСтрока = ТабличнаяЧастьПодарки.Добавить();
			НоваяСтрока.СкидкаНаценка		= СтрокаТЗСкидок.СкидкаНаценка;
			НоваяСтрока.Количество			= СтрокаТЗСкидок.ЗначениеСкидкиНаценки;
			НоваяСтрока.КоличествоУпаковок	= СтрокаТЗСкидок.ЗначениеСкидкиНаценки;			
			
		КонецЕсли; 
					
	КонецЦикла;
			
КонецПроцедуры

// Рассчитывает значение сложной скидки
//
// Параметры
//  МассивСкидок  - Массив скидок, по которым выполнилось условие
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//
// Возвращаемое значение:
//  Сумма скидки
//
Процедура РасчитатьПрименитьВытеснениСложныхСкидокПоГруппам(ТаблицаСкидок, СтруктураПараметров, ТипНачисленияСкидкаБонус = "Все", МассивБонусовНеНачисляемыхПриНаличииСкидки = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаСкидок"								, ТаблицаСкидок);
	Запрос.УстановитьПараметр("ТипНачисленияСкидкаБонус"					, ТипНачисленияСкидкаБонус);
	Запрос.УстановитьПараметр("МассивБонусовНеНачисляемыхПриНаличииСкидки"	, ?(Не ЗначениеЗаполнено(МассивБонусовНеНачисляемыхПриНаличииСкидки), NULL, МассивБонусовНеНачисляемыхПриНаличииСкидки));

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаСкидок.СкидкаНаценка КАК СкидкаНаценка,
	|	ТаблицаСкидок.НачислениеБонусами КАК НачислениеБонусами,
	|	ТаблицаСкидок.ПорядокПрименения КАК ПорядокПрименения,
	|	ТаблицаСкидок.СпособПредоставленияСкидки КАК СпособПредоставленияСкидки,
	|	ТаблицаСкидок.Сумма КАК Сумма,
	|	ТаблицаСкидок.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки,
	|	ТаблицаСкидок.ЗначениеСкидкиНаценкиОбъектом КАК ЗначениеСкидкиНаценкиОбъектом,
	|	ТаблицаСкидок.Использовать КАК Использовать,
	|	ТаблицаСкидок.СуммаСкидки КАК СуммаСкидки
	|ПОМЕСТИТЬ ТаблицаСкидок
	|ИЗ
	|	&ТаблицаСкидок КАК ТаблицаСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСкидок.СкидкаНаценка КАК СкидкаНаценка,
	|	ТаблицаСкидок.НачислениеБонусами КАК НачислениеБонусами,
	|	ТаблицаСкидок.ПорядокПрименения КАК ПорядокПрименения,
	|	ТаблицаСкидок.СпособПредоставленияСкидки КАК СпособПредоставленияСкидки,
	|	ТаблицаСкидок.Сумма КАК Сумма,
	|	ВЫРАЗИТЬ(ТаблицаСкидок.ЗначениеСкидкиНаценки КАК ЧИСЛО(15, 6)) КАК ЗначениеСкидкиНаценки,
	|	ТаблицаСкидок.ЗначениеСкидкиНаценкиОбъектом КАК ЗначениеСкидкиНаценкиОбъектом,
	|	ТаблицаСкидок.Использовать КАК Использовать,
	|	ТаблицаСкидок.СуммаСкидки КАК СуммаСкидки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаСкидок.СкидкаНаценка КАК СкидкаНаценка,
	|		МИНИМУМ(ТаблицаСкидок.НачислениеБонусами) КАК НачислениеБонусами,
	|		МИНИМУМ(ВЫБОР
	|				КОГДА ТаблицаСкидок.СпособПредоставленияСкидки = ЗНАЧЕНИЕ(Перечисление.СпособПредоставленияСкидки.ВидЦен)
	|					ТОГДА -1
	|				ИНАЧЕ ТаблицаСкидок.ПорядокПрименения
	|			КОНЕЦ) КАК ПорядокПрименения,
	|		МИНИМУМ(ТаблицаСкидок.СпособПредоставленияСкидки) КАК СпособПредоставленияСкидки,
	|		СУММА(ТаблицаСкидок.Сумма) КАК Сумма,
	|		МИНИМУМ(ТаблицаСкидок.ЗначениеСкидкиНаценки) КАК ЗначениеСкидкиНаценки,
	|		МИНИМУМ(ТаблицаСкидок.ЗначениеСкидкиНаценкиОбъектом) КАК ЗначениеСкидкиНаценкиОбъектом,
	|		МИНИМУМ(ТаблицаСкидок.Использовать) КАК Использовать,
	|		СУММА(ТаблицаСкидок.СуммаСкидки) КАК СуммаСкидки
	|	ИЗ
	|		ТаблицаСкидок КАК ТаблицаСкидок
	|	ГДЕ
	|		ВЫБОР
	|				КОГДА &ТипНачисленияСкидкаБонус = ""ТолькоСкидки""
	|					ТОГДА ТаблицаСкидок.НачислениеБонусами = ЛОЖЬ
	|				КОГДА &ТипНачисленияСкидкаБонус = ""ТолькоБонусы""
	|					ТОГДА ТаблицаСкидок.НачислениеБонусами = ИСТИНА
	|							И ВЫБОР
	|								КОГДА НЕ &МассивБонусовНеНачисляемыхПриНаличииСкидки ЕСТЬ NULL
	|									ТОГДА НЕ ТаблицаСкидок.СкидкаНаценка В (&МассивБонусовНеНачисляемыхПриНаличииСкидки)
	|								ИНАЧЕ ИСТИНА
	|							КОНЕЦ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаСкидок.СкидкаНаценка) КАК ТаблицаСкидок
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТаблицаСкидок.НачислениеБонусами,
	|	ТаблицаСкидок.ПорядокПрименения
	|ИТОГИ ПО
	|	СкидкаНаценка ТОЛЬКО ИЕРАРХИЯ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Высчитываем точну скидку, применяем вытеснение
	ДеревоПримененияСкидок = РезультатЗапроса.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	// Избавляемся от первой пустой строчки иерархии с пустым родителем
	ДеревоПримененияСкидокВрем = ДеревоПримененияСкидок.Скопировать();
	ДеревоПримененияСкидок.Строки.Очистить();
	Для Каждого СтрокаТЗ Из ДеревоПримененияСкидокВрем.Строки Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.СкидкаНаценка) Тогда
			Для Каждого СтрокаТЗВторогоУровня Из СтрокаТЗ.Строки Цикл
				СкопироватьСтрокуДереваЗначений(ДеревоПримененияСкидокВрем, СтрокаТЗВторогоУровня, ДеревоПримененияСкидок);
			КонецЦикла;
		Иначе
			СкопироватьСтрокуДереваЗначений(ДеревоПримененияСкидокВрем, СтрокаТЗ, ДеревоПримененияСкидок);
		КонецЕсли; 
	КонецЦикла;
	
	РассчитатьПрименитьВытеснениеСкидокВДереве(ТаблицаСкидок, ДеревоПримененияСкидок, Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Сложение, СтруктураПараметров);
	
	// Переносим результат применения скидок и уточненну сумму в таблицу скидок
	ТаблицаПримененияСкидок = ВыгрузитьДеревоЗначенийВТаблицу(ДеревоПримененияСкидок, Ложь);
	Для Каждого СтрокаПримененияСкидки Из ТаблицаПримененияСкидок Цикл
		
		СтрокиТаблицыСкидок = ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаПримененияСкидки.СкидкаНаценка));
		Если СтрокиТаблицыСкидок.Количество() = 0
				ИЛИ СтрокаПримененияСкидки.СкидкаНаценка.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВыдачаКарты Тогда			
			Продолжить;
		КонецЕсли; 
		
		// Пропорционально разбиваем сумму
		СуммаСкидкиВТаблицеСкидок = ИтогоВМассивеСтрок(СтрокиТаблицыСкидок, "СуммаСкидки");
		Для Каждого СтрокаТаблицыСкидки Из СтрокиТаблицыСкидок Цикл
			СтрокаТаблицыСкидки.Использовать = СтрокаПримененияСкидки.Использовать;
			СтрокаТаблицыСкидки.СуммаСкидки  = СтрокаПримененияСкидки.СуммаСкидки * ((СтрокаТаблицыСкидки.СуммаСкидки * ?(СуммаСкидкиВТаблицеСкидок <> 0, 100 / СуммаСкидкиВТаблицеСкидок, 0)) / 100);
		КонецЦикла;
		
		// Раскидываем потерявшиеся копейки
		СуммаСкидкиВТаблицеСкидок = ИтогоВМассивеСтрок(СтрокиТаблицыСкидок, "СуммаСкидки");
		Если СтрокаПримененияСкидки.СуммаСкидки <> СуммаСкидкиВТаблицеСкидок Тогда
			СтрокиТаблицыСкидок[0].СуммаСкидки = СтрокиТаблицыСкидок[0].СуммаСкидки + (СтрокаПримененияСкидки.СуммаСкидки - СуммаСкидкиВТаблицеСкидок);
		КонецЕсли; 
		
	КонецЦикла;
	
	// исправить!!!
	
	// Корректируем сумму скидки если скидка больше суммы товара
	Если ТипНачисленияСкидкаБонус <> "ТолькоБонусы" Тогда
		РазличныеСтрокиНоменклатуры = ТаблицаСкидок.Скопировать();
		РазличныеСтрокиНоменклатуры.Свернуть("КлючСтроки, Номенклатура");
		Для Каждого СтрокаТЗ Из РазличныеСтрокиНоменклатуры Цикл
			
			СуммаАвтоматическойСкидки = 0;
			СтрокиТаблицыСкидок = ТаблицаСкидок.НайтиСтроки(Новый Структура("КлючСтроки, Использовать", СтрокаТЗ.КлючСтроки, Истина));
			Для каждого СтрокаПримененияСкидки Из СтрокиТаблицыСкидок Цикл
				
				// Округляем скидки
				Если СтруктураПараметров.Свойство("ВидЦен") Тогда
					СтрокаПримененияСкидки.СуммаСкидки = ОбщегоНазначенияКлиентСервер.ОкруглитьЦену(
																						СтрокаПримененияСкидки.СуммаСкидки,
																						СтруктураПараметров.ВидЦен.ПорядокОкругления,
																						СтруктураПараметров.ВидЦен.ОкруглятьВБольшуюСторону);
				КонецЕсли;			
				
				// Корректируем сумму скидки если скидка больше суммы товара			
				Если СтрокаПримененияСкидки.СпособПредоставленияСкидки <> Перечисления.СпособПредоставленияСкидки.Подарок 
					И СтрокаПримененияСкидки.СпособПредоставленияСкидки <> Перечисления.СпособПредоставленияСкидки.ВидЦен
					И СтрокаПримененияСкидки.НачислениеБонусами <> Истина Тогда
					
					Если СтрокаПримененияСкидки.ПредыдщееСостояниеИспользование = Истина Тогда
						
						Если СтрокаПримененияСкидки.Цена * СтрокаПримененияСкидки.КоличествоУпаковок < СтрокаПримененияСкидки.СуммаСкидки + СуммаАвтоматическойСкидки Тогда
							СтрокаПримененияСкидки.СуммаСкидки = (СтрокаПримененияСкидки.Цена * СтрокаПримененияСкидки.КоличествоУпаковок - СуммаАвтоматическойСкидки);
						КонецЕсли;
						СуммаАвтоматическойСкидки = СуммаАвтоматическойСкидки + СтрокаПримененияСкидки.СуммаСкидки;	
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Рекурсивно обходит дерево и рассчитывает скидки
//
// Параметры:
//  СтрокиДерева  - Массив скидок, по которым выполнилось условие
//  ВариантСовместногоПримененияСкидокНаценок - Вариант совместного применения
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//
// Возвращаемое значение:
//  Сумма скидки
//
Процедура РассчитатьПрименитьВытеснениеСкидокВДереве(
	ТаблицаСкидок, 
	СкидкиДеревомВИерархии, 
	ВариантСовместногоПримененияСкидокНаценок,
	СтруктураПараметров							= Неопределено, 
	Знач ОграничениеПоГруппе					= 0,
	ТаблицаОграниченийПоГруппам 				= Неопределено)
	
	Если СтруктураПараметров <> Неопределено И ТипЗнч(СтруктураПараметров) = Тип("Структура") И НЕ СтруктураПараметров.Свойство("ТаблицаСкидок") Тогда 
		СтруктураПараметров.Вставить("ТаблицаСкидок", ТаблицаСкидок);
	КонецЕсли;
	
	ВремСуммаДляВариантаУсноженияСкидок = 0;
	
	// Расчитываем значение скидок рекрсивно
	Для каждого СтрокаСкидкиДерева Из СкидкиДеревомВИерархии.Строки Цикл
		Если СтрокаСкидкиДерева.СкидкаНаценка.ЭтоГруппа Тогда                 // группа
			Если ТаблицаОграниченийПоГруппам = Неопределено Тогда 
				ТаблицаОграниченийПоГруппам = СоздатьТаблицуОграниченийПоГруппам();
			КонецЕсли;
			ДобавитьВТаблицуГруппуОграничений(ТаблицаОграниченийПоГруппам, СтрокаСкидкиДерева.СкидкаНаценка);
			ОграничениеПоГруппе = ?(ОграничениеПоГруппе = 0,
									СтрокаСкидкиДерева.СкидкаНаценка.ЗначениеСкидкиНаценки,
									?(СтрокаСкидкиДерева.СкидкаНаценка.ЗначениеСкидкиНаценки = 0, 
											ОграничениеПоГруппе,
											Мин(ОграничениеПоГруппе, СтрокаСкидкиДерева.СкидкаНаценка.ЗначениеСкидкиНаценки)));
											
			РассчитатьПрименитьВытеснениеСкидокВДереве(
						ТаблицаСкидок,
						СтрокаСкидкиДерева, 
						СтрокаСкидкиДерева.СкидкаНаценка.ВариантСовместногоПримененияСкидокНаценок,
						СтруктураПараметров, 
						ОграничениеПоГруппе, 
						ТаблицаОграниченийПоГруппам);
		Иначе
			Если СтрокаСкидкиДерева.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
				ПрименитьОграничениеСкидкиНаценки(СтрокаСкидкиДерева.СкидкаНаценка, ТаблицаОграниченийПоГруппам, СтрокаСкидкиДерева, СтруктураПараметров);
						СтрокаСкидкиДерева.СуммаСкидки = ?(ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Умножение,
										(СтрокаСкидкиДерева.Сумма - ВремСуммаДляВариантаУсноженияСкидок) * СтрокаСкидкиДерева.ЗначениеСкидкиНаценки / 100,
										СтрокаСкидкиДерева.Сумма * СтрокаСкидкиДерева.ЗначениеСкидкиНаценки / 100);
			Иначе // Расчет их уже был
				ПрименитьОграничениеСкидкиНаценки(СтрокаСкидкиДерева.СкидкаНаценка, ТаблицаОграниченийПоГруппам, СтрокаСкидкиДерева, СтруктураПараметров);
				СтрокаСкидкиДерева.СуммаСкидки = СтрокаСкидкиДерева.СуммаСкидки;				
			КонецЕсли;
		КонецЕсли;
		ВремСуммаДляВариантаУсноженияСкидок = ВремСуммаДляВариантаУсноженияСкидок + СтрокаСкидкиДерева.СуммаСкидки;
	КонецЦикла;
	
	Если ТипЗнч(СкидкиДеревомВИерархии) = Тип("СтрокаДереваЗначений") Тогда
		СкидкиДеревомВИерархии.СуммаСкидки = 0;
	КонецЕсли;			
	
	СуммаНачисленияГруппой = 0;
	МассивОбработанныхНоменклатур = Новый Массив;
	Для каждого СтрокаДерева Из СкидкиДеревомВИерархии.Строки Цикл
		Для каждого СтрокаТЗ Из ТаблицаСкидок.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаДерева.СкидкаНаценка)) Цикл
			Если МассивОбработанныхНоменклатур.Найти(СтрокаТЗ.КлючСтроки) = Неопределено Тогда
				МассивОбработанныхНоменклатур.Добавить(СтрокаТЗ.КлючСтроки);
				СуммаНачисленияГруппой = СуммаНачисленияГруппой + СтрокаТЗ.Сумма;
			КонецЕсли; 
		КонецЦикла;
	КонецЦикла;
	
	// Применяем совместное применение скидок - устанавливаем использование/неиспользование в звисимости от применения, устанавливаем итогову сумму скидки для группы	
	Если ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Минимум
			ИЛИ ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум Тогда
		СкидкиДеревомВИерархии.Строки.Сортировать("СуммаСкидки " + ?(ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Минимум, "Возр", "Убыв"));
		Для каждого СтрокаДерева Из СкидкиДеревомВИерархии.Строки Цикл
			Если СтрокаДерева = СкидкиДеревомВИерархии.Строки[0] Тогда
				УстановитьЗначениеДерева(СтрокаДерева, "Использовать", Истина, Ложь);
				Если ТипЗнч(СкидкиДеревомВИерархии) = Тип("СтрокаДереваЗначений") Тогда
					Если НЕ ОграничениеПоГруппе = 0 И СуммаНачисленияГруппой * ОграничениеПоГруппе / 100 < СтрокаДерева.СуммаСкидки Тогда
						СтрокаДерева.СуммаСкидки = СуммаНачисленияГруппой * ОграничениеПоГруппе / 100;						
					ИначеЕсли ЗначениеЗаполнено(СкидкиДеревомВИерархии.СкидкаНаценка) И СкидкиДеревомВИерархии.СкидкаНаценка.ЗначениеСкидкиНаценки > 0
							И СуммаНачисленияГруппой * СкидкиДеревомВИерархии.СкидкаНаценка.ЗначениеСкидкиНаценки / 100 < СтрокаДерева.СуммаСкидки Тогда
						СтрокаДерева.СуммаСкидки = СуммаНачисленияГруппой * СкидкиДеревомВИерархии.СкидкаНаценка.ЗначениеСкидкиНаценки / 100;
					КонецЕсли;
					СкидкиДеревомВИерархии.СуммаСкидки = СтрокаДерева.СуммаСкидки;
				КонецЕсли;				
			Иначе
				УстановитьЗначениеДерева(СтрокаДерева, "Использовать", Ложь, Истина);
			КонецЕсли; 
		КонецЦикла; 
	ИначеЕсли ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Сложение
				ИЛИ ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Умножение
				ИЛИ ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.ПустаяСсылка() Тогда
		Для каждого СтрокаДерева Из СкидкиДеревомВИерархии.Строки Цикл
			УстановитьЗначениеДерева(СтрокаДерева, "Использовать", Истина, Ложь);
			Если ТипЗнч(СкидкиДеревомВИерархии) = Тип("СтрокаДереваЗначений") Тогда
				
				Если НЕ ОграничениеПоГруппе = 0 И СуммаНачисленияГруппой * ОграничениеПоГруппе / 100 < (СкидкиДеревомВИерархии.СуммаСкидки + СтрокаДерева.СуммаСкидки) Тогда
					СтрокаДерева.СуммаСкидки = СуммаНачисленияГруппой * ОграничениеПоГруппе / 100 - СкидкиДеревомВИерархии.СуммаСкидки;
				ИначеЕсли ЗначениеЗаполнено(СкидкиДеревомВИерархии.СкидкаНаценка) И СкидкиДеревомВИерархии.СкидкаНаценка.ЗначениеСкидкиНаценки > 0
						И СуммаНачисленияГруппой * СкидкиДеревомВИерархии.СкидкаНаценка.ЗначениеСкидкиНаценки / 100 < (СкидкиДеревомВИерархии.СуммаСкидки + СтрокаДерева.СуммаСкидки) Тогда
					СтрокаДерева.СуммаСкидки = СуммаНачисленияГруппой * СкидкиДеревомВИерархии.СкидкаНаценка.ЗначениеСкидкиНаценки / 100 - СкидкиДеревомВИерархии.СуммаСкидки;
				КонецЕсли;
				
				СкидкиДеревомВИерархии.СуммаСкидки = СкидкиДеревомВИерархии.СуммаСкидки + СтрокаДерева.СуммаСкидки;
				
			КонецЕсли;			
		КонецЦикла; 		
	КонецЕсли;
	
КонецПроцедуры

// Функция - Создать таблицу ограничений по группам
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьТаблицуОграниченийПоГруппам()
	
	ТаблицаОграниченийПоГруппам = Новый ТаблицаЗначений;
	ТаблицаОграниченийПоГруппам.Колонки.Добавить("СкидкаНаценка"						, Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
	ТаблицаОграниченийПоГруппам.Колонки.Добавить("ВариантыСовместногоПрименения"		, Новый ОписаниеТипов("ПеречислениеСсылка.ВариантыСовместногоПримененияСкидокНаценок"));
	ТаблицаОграниченийПоГруппам.Колонки.Добавить("МаксимальноеЗначениеСкидкиНаценки"	, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 4)));
	ТаблицаОграниченийПоГруппам.Колонки.Добавить("НакапливаемоеЗначениеСкидкиНаценки"	, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 4)));
	ТаблицаОграниченийПоГруппам.Колонки.Добавить("ОптимальнаяСкидкаНаценка"				, Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
	
	Возврат ТаблицаОграниченийПоГруппам;
	
КонецФункции

// Процедура - Добавить в таблицу группу ограничений
//
// Параметры:
//  ТаблицаОграниченийПоГруппам	 - 	 - 
//  ГруппаСкидкиНаценки			 - 	 - 
//
Процедура ДобавитьВТаблицуГруппуОграничений(ТаблицаОграниченийПоГруппам, Знач ГруппаСкидкиНаценки)
	
	Если ТаблицаОграниченийПоГруппам.Найти(ГруппаСкидкиНаценки, "СкидкаНаценка") = Неопределено Тогда 
		НоваяСтрокаТаблицы 										= ТаблицаОграниченийПоГруппам.Добавить();
		НоваяСтрокаТаблицы.СкидкаНаценка 						= ГруппаСкидкиНаценки;
		НоваяСтрокаТаблицы.ВариантыСовместногоПрименения 		= ГруппаСкидкиНаценки.ВариантСовместногоПримененияСкидокНаценок;
		НоваяСтрокаТаблицы.МаксимальноеЗначениеСкидкиНаценки	= ГруппаСкидкиНаценки.ЗначениеСкидкиНаценки;
	КонецЕсли;

КонецПроцедуры

// Процедура - Применить ограничение скидки наценки
//
// Параметры:
//  СкидкаНаценка				 - 	 - 
//  ТаблицаОграниченийПоГруппам	 - 	 - 
//  СтрокаСкидкиДерева			 - 	 - 
//
Процедура ПрименитьОграничениеСкидкиНаценки(Знач СкидкаНаценка, ТаблицаОграниченийПоГруппам, СтрокаСкидкиДерева, СтруктураПараметров)
	
	СтрокаРодитель = Неопределено;
	
	Если ЗначениеЗаполнено(ТаблицаОграниченийПоГруппам) Тогда  
		СтрокаРодитель = ТаблицаОграниченийПоГруппам.Найти(СкидкаНаценка.Родитель, "СкидкаНаценка");		
	КонецЕсли;
	
	Если СтрокаРодитель = Неопределено Тогда 
		Возврат;
	Иначе
		Если СтруктураПараметров <> Неопределено И СтруктураПараметров.Свойство("МассивНеиспользуемыхСкидок") Тогда 
			МассивНеиспользуемыхСкидок = СтруктураПараметров.МассивНеиспользуемыхСкидок;
		Иначе 
			МассивНеиспользуемыхСкидок = Новый Массив;
		КонецЕсли;
		
		Если СтрокаРодитель.МаксимальноеЗначениеСкидкиНаценки = 0 
			И НЕ (СтрокаРодитель.ВариантыСовместногоПрименения = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум
			ИЛИ СтрокаРодитель.ВариантыСовместногоПрименения = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Минимум) Тогда 
			
			ПрименитьОграничениеСкидкиНаценки(СтрокаРодитель.СкидкаНаценка, ТаблицаОграниченийПоГруппам, СтрокаСкидкиДерева, СтруктураПараметров);
		Иначе
			ОбследоватьДеревоВыше = Истина;
			Если СтрокаСкидкиДерева.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда 
				ЗначениеСкидкиНаценкиПроцент = СтрокаСкидкиДерева.ЗначениеСкидкиНаценки;
			Иначе 
				ЗначениеСкидкиНаценкиПроцент = СтрокаСкидкиДерева.СуммаСкидки / (?(СтрокаСкидкиДерева.Сумма = 0, 1, СтрокаСкидкиДерева.Сумма) / 100);
				// ЗначениеСкидкиНаценкиПроцент = ?(Цел(ЗначениеСкидкиНаценкиПроцент) <> ЗначениеСкидкиНаценкиПроцент, Цел(ЗначениеСкидкиНаценкиПроцент) + 1, ЗначениеСкидкиНаценкиПроцент);
				// Разрядность = 2;
				// РежимОкругленияЧисла = РежимОкругления.Окр15как20;
				// ЗначениеСкидкиНаценкиПроцент = ?(НЕ (Окр(ЗначениеСкидкиНаценкиПроцент, Разрядность) = ЗначениеСкидкиНаценкиПроцент),?(ЗначениеСкидкиНаценкиПроцент < 0, (Окр(ЗначениеСкидкиНаценкиПроцент-(0.5/pow(10, Разрядность)) , Разрядность, РежимОкругленияЧисла)),(Окр(ЗначениеСкидкиНаценкиПроцент+(0.5/pow(10, Разрядность)), Разрядность, РежимОкругленияЧисла))), ЗначениеСкидкиНаценкиПроцент);
			КонецЕсли;
			
			// ВАРИАНТ ГРУППОВОГО ПРИМЕНЕНИЯ: МАКСИМУМ
			Если СтрокаРодитель.ВариантыСовместногоПрименения = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум Тогда 
				Если ЗначениеСкидкиНаценкиПроцент > СтрокаРодитель.МаксимальноеЗначениеСкидкиНаценки И СтрокаРодитель.МаксимальноеЗначениеСкидкиНаценки <> 0 Тогда 
					УстановитьЗначениеДерева(СтрокаСкидкиДерева, "Использовать", Ложь, Ложь);
					ОбследоватьДеревоВыше = Ложь;
				Иначе
					Если МассивНеиспользуемыхСкидок.Найти(СтрокаСкидкиДерева.СкидкаНаценка) = Неопределено Тогда
						// Определим максимальная ли это скидка в группе
						МаксимальнаяСкидка 							= СтрокаСкидкиДерева.СкидкаНаценка;
						ЗначениеМаксимальнойСкидкиНаценкиПроцент 	= ЗначениеСкидкиНаценкиПроцент;
						Для Каждого СтрокаТаблицыСкидок Из СтруктураПараметров.ТаблицаСкидок Цикл
							Если ЗначениеЗаполнено(СтрокаТаблицыСкидок.СкидкаНаценка) Тогда
								Если ТаблицаОграниченийПоГруппам.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаТаблицыСкидок.СкидкаНаценка.Родитель)).Количество() = 0 И СтрокаТаблицыСкидок.СкидкаНаценка.Родитель.ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум И СтрокаТаблицыСкидок.СкидкаНаценка.Родитель.Родитель = СтрокаРодитель.СкидкаНаценка Тогда 
									ОбследоватьДеревоВыше = Ложь;
								КонецЕсли;	
								Если СтрокаТаблицыСкидок.СкидкаНаценка = СтрокаСкидкиДерева.СкидкаНаценка ИЛИ СтрокаТаблицыСкидок.СкидкаНаценка.Родитель <> СтрокаСкидкиДерева.СкидкаНаценка.Родитель ИЛИ СтрокаТаблицыСкидок.СкидкаНаценка.ЭтоГруппа Тогда 
									Продолжить;
								Иначе
									Если СтрокаТаблицыСкидок.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда 
										ЗначениеСкидкиНаценкиПроцент2 = СтрокаТаблицыСкидок.ЗначениеСкидкиНаценки;
									Иначе 
										ЗначениеСкидкиНаценкиПроцент2 = СтрокаТаблицыСкидок.СуммаСкидки / (?(СтрокаТаблицыСкидок.Сумма = 0, 1, СтрокаТаблицыСкидок.Сумма) / 100);
									КонецЕсли;	
									Если ЗначениеСкидкиНаценкиПроцент2 > ЗначениеМаксимальнойСкидкиНаценкиПроцент Тогда 
										МаксимальнаяСкидка 							= СтрокаТаблицыСкидок.СкидкаНаценка;
										ЗначениеМаксимальнойСкидкиНаценкиПроцент 	= ЗначениеСкидкиНаценкиПроцент2;
									КонецЕсли;	
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;
