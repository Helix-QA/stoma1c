// При очистки страхового полиса
//
Функция КонтрагентСтраховойПолисОчисткаСервер(Сотрудник, СтруктурнаяЕдиница)

	ВидЦен = СтруктурнаяЕдиница.ВидЦенРеализации;
	Если ЗначениеЗаполнено(Сотрудник) Тогда		
		ПеремВидЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Сотрудник, СтруктурнаяЕдиница , "ВидЦен");
		Если ЗначениеЗаполнено(ПеремВидЦен) Тогда
			ВидЦен = ПеремВидЦен;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВидЦен) Тогда
		ВидЦен = Справочники.ВидыЦен.Розничная;	
	КонецЕсли;
	
	Возврат ВидЦен;	
	
КонецФункции

