// Функция возвращает элемент формы по имени поля настройки.
//
Функция НайтиЭлементФормыПоИмениПоляНастройки(Имя) 
	
	Элемент = Неопределено;
	
	Если ПоляНастроек = Неопределено Тогда
		Возврат Элемент;
	КонецЕсли;
	
	ЭлементыПолейНастроек = ПоляНастроек.ПолучитьЭлементы();
	Для Каждого ТекЭлемент Из ЭлементыПолейНастроек Цикл
		Если ТекЭлемент.Поле = Имя Тогда
			Для Каждого Стр Из ТекЭлемент.Реквизиты Цикл								
				Элемент = Элементы.Найти(Стр.Ключ);
			КонецЦикла;	
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Элемент;

