&НаКлиенте
// Процедура, обработчик события "ГиперСсылкаДополнитьИнформациюОКлиентеНажатие".
//
Процедура Подключаемый_ДополнитьИнформациюОКлиенте_ВыполнитьКоманду(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Команда);
	
	// Запись в журнал регистрации
	// Необходимо для выявления редкой ошибки
	ЗаписатьВЖурналВсеПараметры(?(НЕ ЗначениеЗаполнено(Объект.ЗадачаПредмет), " Пациент не указан!", ""));
		
	Если ЗначениеЗаполнено(Объект.ЗадачаПредмет) Тогда 
		Если ТипЗнч(Объект.ЗадачаПредмет) = Тип("СправочникСсылка.Контрагенты") Тогда			
			ПараметрыФормы = Новый Структура;
			Если НЕ ЗначениеЗаполнено(ЭтотОбъект.СтатусКлиента)
				ИЛИ ЭтотОбъект.СтатусКлиента = ПредопределенноеЗначение("Перечисление.СтатусыКонтрагентов.Потенциальный") Тогда 
				УстановитьСтатусКонтрагенту(Объект.ЗадачаПредмет);
				СформироватьКонтаргентаСтрокой(Элементы.КнопкаКонтрагент.Заголовок, Объект.Контрагент);
				СформироватьПредметСтрокой(Элементы.КнопкаПредмет.Заголовок, Объект.ЗадачаПредмет);				
				ПараметрыФормы.Вставить("РедактироватьФИО", Истина);
			КонецЕсли;			
		КонецЕсли;
		Если ТипЗнч(Объект.ЗадачаПредмет) = Тип("СправочникСсылка.Контрагенты") Тогда
			ПараметрыФормы.Вставить("Ключ", Объект.ЗадачаПредмет);			
			ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершениеДополнительнойИнформации", ЭтотОбъект, СтруктураДанныеЭлемента);
			ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", ПараметрыФормы, Элементы.Предмет, , , , ОписаниеОповещения, );// РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		Иначе
			ПоказатьЗначение(, Объект.ЗадачаПредмет);			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Подключаемый декорация формы удалить текущее взаимодействие нажатие
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_УдалитьТекущееВзаимодействие_ВыполнитьКоманду(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Команда);
	
	Если СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ТекущиеВзаимодействия.Удалить(СтруктураДанныеЭлемента.ДанныеЭлемента);
	АктивизироватьСледующийЭлементНаФорме(Элементы.КнопкаСледующееВзаимодействие_Изменить);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Развернуть свернуть подробную информацию по задаче
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Подключаемый_Развернуть_Свернуть_ПодробнуюИнформацию_По_Задаче(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Команда);
	
	Если СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ГруппаСКраткойИнформацией 	= Элементы.Найти("Группа_Общая_Краткая_Информация_По_Задаче_" + Строка(СтруктураДанныеЭлемента.ИндексСтроки));
	ГруппаСПодробнойИнформацией = Элементы.Найти("Группа_Общая_Подробная_Информация_По_Задаче_" + Строка(СтруктураДанныеЭлемента.ИндексСтроки));
	
	Если НЕ ГруппаСКраткойИнформацией = Неопределено И НЕ ГруппаСПодробнойИнформацией = Неопределено Тогда 
		ГруппаСКраткойИнформацией.Видимость 	= НЕ ГруппаСКраткойИнформацией.Видимость;
		ГруппаСПодробнойИнформацией.Видимость 	= НЕ ГруппаСКраткойИнформацией.Видимость;
	КонецЕсли;
	
КонецПроцедуры

