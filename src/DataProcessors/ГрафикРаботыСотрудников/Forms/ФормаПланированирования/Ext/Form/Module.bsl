// Функция - проверяет наличие Визита сотрудника
// 
// 
Функция ПроверитьНаличиеПриема(Знач Сотрудник, Знач Период, Знач СписокПериодов, Знач СтруктурнаяЕдиница = Неопределено)
	
	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДокументСобытиеУслуги.Ссылка КАК Ссылка,
	|	ДокументСобытиеУслуги.ДатаНачала КАК ДатаНачала,
	|	ДокументСобытиеУслуги.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	Документ.Событие.Услуги КАК ДокументСобытиеУслуги
	|ГДЕ
	|	ДокументСобытиеУслуги.Ссылка.Проведен
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ДокументСобытиеУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НАЧАЛОПЕРИОДА(ДокументСобытиеУслуги.ДатаНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Период, ДЕНЬ)
	|	И ДокументСобытиеУслуги.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	|	И ВЫБОР
	|			КОГДА &Сотрудник <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ДокументСобытиеУслуги.Сотрудник = &Сотрудник
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";  
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);	
	Запрос.УстановитьПараметр("Сотрудник"         , ?(ЗначениеЗаполнено(Сотрудник), Сотрудник, Неопределено));
	Запрос.УстановитьПараметр("Период"            , Период);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	СтрокаСобытияЕстьВПериоде = Ложь;
	Пока Результат.Следующий() Цикл 
		
		Для Каждого ЭлементСписка Из СписокПериодов Цикл
			
			// Если существует визит, пересекающийся с заданным периодом
			Если (Результат.ДатаНачала >= ЭлементСписка.Значение.НачалоРаботы И Результат.ДатаНачала < ЭлементСписка.Значение.ОкончаниеРаботы)
				ИЛИ (Результат.ДатаНачала <= ЭлементСписка.Значение.НачалоРаботы И Результат.ДатаОкончания > ЭлементСписка.Значение.НачалоРаботы)
				ИЛИ (Результат.ДатаНачала >= Период + (ЭлементСписка.Значение.НачалоРаботы - Дата(1,1,1)) И Результат.ДатаНачала < Период + (ЭлементСписка.Значение.ОкончаниеРаботы - Дата(1,1,1)))
				ИЛИ (Результат.ДатаНачала <= Период + (ЭлементСписка.Значение.НачалоРаботы - Дата(1,1,1)) И Результат.ДатаОкончания > Период + (ЭлементСписка.Значение.НачалоРаботы - Дата(1,1,1))) Тогда
				
				СтруктураВозврата = Новый Структура("НачалоРаботы, ОкончаниеРаботы", ЭлементСписка.Значение.НачалоРаботы, ЭлементСписка.Значение.ОкончаниеРаботы);
				Возврат СтруктураВозврата;
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

