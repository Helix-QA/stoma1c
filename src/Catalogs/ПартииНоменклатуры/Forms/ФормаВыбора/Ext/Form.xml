	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>~Список.Номенклатура</Field>
				<Field>Список.Owner</Field>
				<Field>Список.Ref</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникПартииНоменклатуры.Владелец,
	СправочникПартииНоменклатуры.Ссылка,
	СправочникПартииНоменклатуры.Код,
	СправочникПартииНоменклатуры.Наименование,
	СУММА(ЕСТЬNULL(СертификатыОстатки.СуммаОстаток, 0)) КАК ОстатокСуммаСертификат,
	СУММА(ЕСТЬNULL(ЗапасыНаСкладахОстатки.КоличествоОстаток, 0)) КАК ОстаткоКоличествоСклад,
	СправочникПартииНоменклатуры.НомерСерии,
	СправочникПартииНоменклатуры.ГоденДо,
	ВЫБОР
		КОГДА СправочникПартииНоменклатуры.ПометкаУдаления
			ТОГДА 3
		ИНАЧЕ 1
	КОНЕЦ КАК ВариантКартинки
ИЗ
	Справочник.ПартииНоменклатуры КАК СправочникПартииНоменклатуры
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Сертификаты.Остатки(
				&amp;Период,
				ВЫБОР
						КОГДА НЕ &amp;СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
								И НЕ &amp;СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
							ТОГДА СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
						ИНАЧЕ ИСТИНА
					КОНЕЦ
					И ВЫБОР
						КОГДА НЕ Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
								И НЕ &amp;КонтрагентВладелец = НЕОПРЕДЕЛЕНО
								И НЕ &amp;КонтрагентВладелец = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
							ТОГДА Контрагент = &amp;КонтрагентВладелец
						ИНАЧЕ ИСТИНА
					КОНЕЦ) КАК СертификатыОстатки
		ПО СправочникПартииНоменклатуры.Ссылка = СертификатыОстатки.СерийныйНомер
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(
				&amp;Период,
				ВЫБОР
						КОГДА НЕ &amp;СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
								И НЕ &amp;СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
							ТОГДА СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
						ИНАЧЕ ИСТИНА
					КОНЕЦ
					И ВЫБОР
						КОГДА НЕ &amp;Склад = НЕОПРЕДЕЛЕНО
								И НЕ &amp;Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
							ТОГДА Склад = &amp;Склад
						ИНАЧЕ ИСТИНА
					КОНЕЦ) КАК ЗапасыНаСкладахОстатки
		ПО СправочникПартииНоменклатуры.Владелец = ЗапасыНаСкладахОстатки.Номенклатура
			И СправочникПартииНоменклатуры.Ссылка = ЗапасыНаСкладахОстатки.Партия

СГРУППИРОВАТЬ ПО
	СправочникПартииНоменклатуры.Ссылка,
	СправочникПартииНоменклатуры.Код,
	СправочникПартииНоменклатуры.Наименование,
	СправочникПартииНоменклатуры.Владелец</QueryText>
				<MainTable>Catalog.ПартииНоменклатуры</MainTable>
