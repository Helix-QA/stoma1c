#Область ИнтеграцияССмсСервисами

// Процедура - Проверить необходимость предложения пополнения баланса смс сервиса helix
//
Процедура ПроверитьНеобходимостьПредложенияПополненияБалансаСмсСервисаHelix() Экспорт
	
	ФоноваяЗадача = ЛичныйКабинет.ПроверитьБалансаСмсСервисаИПредложитьПополнение();
	
	Если ФоноваяЗадача = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Неопределено);
	ПараметрыОжидания.ВыводитьОкноОжидания  = Ложь;
	ПараметрыОжидания.ВыводитьСообщения     = Истина;
		
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ПроверитьНеобходимостьПредложенияПополненияБалансаСмсСервисаHelixОбработчикТаймер", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ФоноваяЗадача, ОповещениеОЗавершении, ПараметрыОжидания);

КонецПроцедуры

// Процедура - Проверить необходимость предложения пополнения баланса смс сервиса helix обработчик таймер
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ПроверитьНеобходимостьПредложенияПополненияБалансаСмсСервисаHelixОбработчикТаймер(Результат, ДопПараметры) Экспорт
	
	Если Результат.Статус = "Выполнено" Тогда
	
	    РезультатаОперции = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если ЗначениеЗаполнено(РезультатаОперции) 
			И Не РезультатаОперции.Свойство("КодОшибки") Тогда
						
			ПараметрыФормы = Новый Структура("ТекущийБаланс", РезультатаОперции.ТекущийБаланс);		
			
			Если РезультатаОперции.Свойство("last_payment") Тогда 
				ПараметрыФормы.Вставить("СуммаПредыдущегоПоплнения", РезультатаОперции.last_payment); 
			КонецЕсли;	
			Если РезультатаОперции.Свойство("recommendable_payment") Тогда 
				ПараметрыФормы.Вставить("ПредлагаемаяСумма", РезультатаОперции.recommendable_payment); 
			КонецЕсли;	
			Если РезультатаОперции.Свойство("email") Тогда 
				ПараметрыФормы.Вставить("ЭлектроннаяПочта", РезультатаОперции.email); 
			КонецЕсли;	
			Если РезультатаОперции.Свойство("min_balance") Тогда 
				ПараметрыФормы.Вставить("МинимальныйБаланс", РезультатаОперции.min_balance); 
			КонецЕсли;	
			
			Оповещение = Новый ОписаниеОповещения("ОткрытьФормуПополненияБалансаСмсСервиса",ЭтотОбъект, ПараметрыФормы);
			
			Сообщение = "Баланс вашего смс счета приближается к нулю и на текущий момент составляет " 
			+ Формат(РезультатаОперции.ТекущийБаланс, "ЧДЦ=2") + "  рублей.";
			
			ПоказатьОповещениеПользователя(
			"Пополнить баланс",
			Оповещение,
			Сообщение,
			БиблиотекаКартинок.SMS32,
			СтатусОповещенияПользователя.Важное,
			Новый УникальныйИдентификатор("8596e18a-bb2e-4d18-8adf-46488e67ea85"));
			
			УдалитьИзВременногоХранилища(Результат.АдресРезультата);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Открыть форму поплнения баланча смс сервиса
//
// Параметры:
//  ПараметрыФормы	 - 	 - 
//
Процедура ОткрытьФормуПополненияБалансаСмсСервиса(ПараметрыФормы) Экспорт
	
	ОткрытьФорму("Обработка.ЛичныйКабинет.Форма.ФормаЗапросаПополненияБалансаСмсСервиса", Новый Структура("ДанныеПополнения", ПараметрыФормы),,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

