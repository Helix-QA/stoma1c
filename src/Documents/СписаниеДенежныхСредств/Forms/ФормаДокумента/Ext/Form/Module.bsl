// Процедура печати чека на фискальном регистраторе.
//
Процедура НапечататьЧек(Команда)
	
	Если ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
		ПоказатьПредупреждение(, "Документ уже пробит на фискальном регистраторе! Номер чека:" + Объект.НомерЧекаККМ);
		Возврат;
	КонецЕсли;  
	
	Если Объект.Проведен = Ложь 
		ИЛИ ЭтаФорма.Модифицированность = Истина Тогда
		
		ПоказатьПредупреждение(, НСтр("ru='Предварительно документ необходимо провести.';en='Pre document is necessary conduct.'"));
		Возврат;
	КонецЕсли;
	
	// Проверяем ставку НДС.
	СтавкаНДС = ОбщегоНазначенияСтоматология.ПолучитьСтавкуНДС(Объект.СтруктурнаяЕдиница);			
	Если Не ЗначениеЗаполнено(СтавкаНДС) Тогда
		ПоказатьПредупреждение(, "Заполните ставку НДС в организации и повторите операцию оплаты.");
		ОткрытьФорму("Справочник.Организации.Форма.ФормаЭлемента", 
					Новый Структура("Ключ", ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация")));
		Возврат;	
	КонецЕсли;  
	
	ВидНалога = Неопределено;
	
	// Проверка на применяемые налоги.	
	Если Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВзносНаЛицевойСчет") 
		И Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВозвратСЛицевогоСчета")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВозвратАвансаКлиенту")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВзносНалицевойСчет")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВзносАвансаОтКлиента") Тогда
		
		Для Каждого СтрокаТЧ из Объект.РасшифровкаПлатежа Цикл
			ЭтоСтрокаАванса = СтрокаТЧ.ЭтоАванс
			ИЛИ СтрокаТЧ.Статья = ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВозвратАвансаКлиенту")
			ИЛИ СтрокаТЧ.Статья = ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВозвратСЛицевогоСчета") 
			ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета");
			
			Если ТипЗнч(СтрокаТЧ.ДокументОснования) = Тип("ДокументСсылка.Реализация")
				ИЛИ ТипЗнч(СтрокаТЧ.ДокументОснования) = Тип("ДокументСсылка.Прием")
				ИЛИ ТипЗнч(СтрокаТЧ.ДокументОснования) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
				Если ВидНалога = Неопределено Тогда
					ВидНалога = ?(ЭтоСтрокаАванса,
									ОбщегоНазначенияСтоматология.ПолучитьВидНалогаАванс(Объект.СтруктурнаяЕдиница),
									ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.ДокументОснования, "ВидНалога"));
					
				ИначеЕсли НЕ ВидНалога = ?(ЭтоСтрокаАванса,
					ОбщегоНазначенияСтоматология.ПолучитьВидНалогаАванс(Объект.СтруктурнаяЕдиница),
					ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.ДокументОснования, "ВидНалога")) Тогда // ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаТЧ.ДокументОснования, "ВидНалога") Тогда
					ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения.";
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
					Возврат;										
				КонецЕсли;				
			КонецЕсли;		
			
			Если ЭтоСтрокаАванса Тогда
				ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьВидНалогаАванс(Объект.СтруктурнаяЕдиница);
			КонецЕсли;		
			
		КонецЦикла;		
	Иначе
		ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьВидНалогаАванс(Объект.СтруктурнаяЕдиница);
	КонецЕсли;     
	
	// Выполнить контроль кассовой смены
	ОписаниеОшибки					= Неопределено;
	ВыполнятьОперациюНаФискальнике  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Касса, "ИспользоватьБезПодключенияОборудования") = Ложь; 
	ПараметрыИспользованияКассовойСмены = Новый Структура("ВыполнятьОперациюНаФискальнике", ВыполнятьОперациюНаФискальнике);
	РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, Объект.Касса, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки);
	     
КонецПроцедуры

&НаКлиенте
// Процедура, команда добавления динамической строки расшифровки платежа.
//
Процедура ДобавитьСтрокуРасшифровки(Команда)
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПрочееСписание") Тогда
		ИмяТЧ = "Затраты";
	Иначе
		ИмяТЧ = "РасшифровкаПлатежа";
	КонецЕсли;	
	
	НоваяСтрока = Объект[ИмяТЧ].Добавить();
	// НоваяСтрока.КлючСтроки	 = Новый УникальныйИдентификатор;
	
	СоздатьСтрокуЭлементовРасшифровки(Объект[ИмяТЧ].Количество() - 1);
	
КонецПроцедуры

&НаКлиенте
// Процедура, команда удаления динамической строки расшифровки платежа.
//
Процедура УдалитьСтрокуРасшифровки(Команда)
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПрочееСписание") Тогда
		ИмяТЧ = "Затраты";
	Иначе
		ИмяТЧ = "РасшифровкаПлатежа";
	КонецЕсли;	
	
	ИндексСтроки = ПолучитьИндексСтроки(ЭтаФорма.ТекущийЭлемент.Имя);
	УдалитьЭлементыРасшифровкиПлатежа(ИндексСтроки);
	
	Если Объект[ИмяТЧ].Количество() = 0 Тогда
		ДобавитьСтрокуРасшифровки(Неопределено);
	КонецЕсли;
	
	Объект.СуммаДокумента = Объект[ИмяТЧ].Итог("Сумма");
	
КонецПроцедуры

&НаКлиенте
// Процедура печати.
//
Процедура ДокументПечать(Команда)

	МассивДокументов = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		МассивДокументов.Добавить(Объект.Ссылка);
	КонецЕсли;
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "СписаниеДенежныхСредств");	
	Структура.Вставить("МассивДокументов", МассивДокументов);
	
	СписокПечатныхФорм = ПолучитьСписокПечати();
	
	Если ЭтотОбъект.ДоступностьКнопкиПечатьРКО = Истина Тогда	
		НайденнаяСтрокаРКО = СписокПечатныхФорм.НайтиПоЗначению("РКО");
		СписокПечатныхФорм.Удалить(НайденнаяСтрокаРКО);
	КонецЕсли;
	
	Если НЕ ДоступностьКнопкиПечатьКМЗ = Истина Тогда	
		НайденнаяСтрокаКМЗ = СписокПечатныхФорм.НайтиПоЗначению("КМ3");
		СписокПечатныхФорм.Удалить(НайденнаяСтрокаКМЗ);
	КонецЕсли;	
	
	// Делаем возврат если печатные формы не доступны
	Если НЕ ЗначениеЗаполнено(СписокПечатныхФорм) Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаКоманды", УправлениеПечатьюКлиентСтоматология, Структура);
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда	
		
		СтруктураВопроса = Новый Структура;
		СтруктураВопроса.Вставить("СписокПечатныхФорм", СписокПечатныхФорм);
		СтруктураВопроса.Вставить("Оповещение", Оповещение);
		ОповещениеДляВопроса = Новый ОписаниеОповещения("ПослеВопросаЗавершение", ЭтотОбъект, СтруктураВопроса);			
		ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны. Записать?", РежимДиалогаВопрос.ДаНет);
		
	Иначе	
		
		ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, Элементы.ФормаДокументаПечать);
		
	КонецЕсли;
	
КонецПроцедуры 

