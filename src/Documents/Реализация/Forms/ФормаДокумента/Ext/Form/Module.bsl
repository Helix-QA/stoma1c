// Процедура - обработчик события "ПриИзменении" объект поле "Сотрудник"
//
Процедура СотрудникПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Сотрудник) Тогда
		
		Объект.ВидЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаПоПути(Объект.СтруктурнаяЕдиница, "ВидЦенРеализации");
		ПеремВидЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизитаСотрудника(Объект.Сотрудник, Объект.СтруктурнаяЕдиница , "ВидЦен");
		Если Не ЗначениеЗаполнено(ПеремВидЦен) Тогда
			СтрокаТчВидЦен = Объект.ВидЦен;
		Иначе
			СтрокаТчВидЦен = ПеремВидЦен;
			Объект.ВидЦен = ПеремВидЦен;
		КонецЕсли;
		
		// Выполняем заполнение поля Цена табличной части документа исходя из вида цены
		ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы");

		
		Для Каждого СтрокаТЧ Из Объект.Запасы Цикл
			
			СтрокаТч.ВидЦен = СтрокаТчВидЦен; 			
			СтруктураДанные = Новый Структура("ВидЦен, Номенклатура", СтрокаТчВидЦен, СтрокаТЧ.Номенклатура);
			ЗаполнитьЗначенияСвойств(СтруктураДанные, СтрокаТЧ); 
			СтрокаТЧЦена = Ценообразование.ПолучитьЦенуСертификата(СтруктураДанные);
			Если СтрокаТЧЦена <> Неопределено Тогда
				СтрокаТч.Цена = СтрокаТЧЦена;
			КонецЕсли;
			
		КонецЦикла;
	
			
		// Перерасчет всех сумм и автоматических скидок
		ПересчитатьАвтоматическиеСкидки();
		
	КонецЕсли;

КонецПроцедуры

