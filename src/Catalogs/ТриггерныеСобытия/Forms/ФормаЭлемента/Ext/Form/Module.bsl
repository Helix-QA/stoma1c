// Функция - Необходимо добавить элемент ввода
//
// Параметры:
//  ИндексСтроки - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НеобходимоДобавитьЭлементВвода(ИндексСтроки)
	
	Счетчик = -1;
	Для Каждого СтрокаДействие ИЗ Объект.Действия Цикл
		//Если СтрокаДействие.Удалено Тогда 
		//	Продолжить;
		//КонецЕсли;
		Счетчик = Счетчик + 1;
	КонецЦикла;
	
	Возврат ИндексСтроки = Счетчик;
	
КонецФункции	

&НаКлиенте
// Процедура - Показать всплывающую группу параметров
//
// Параметры:
//  ИдентификаторДействия	 - 	 - 
//  ВидДействия				 - 	 - 
//
Процедура ПоказатьВсплывающуюГруппуПараметров(ИдентификаторДействия, ВидДействия)
	
	Для Каждого СтрокаДействие ИЗ Объект.Действия Цикл
		Если СтрокаДействие.ИдентификаторДействия = ИдентификаторДействия Тогда 
			ГруппаФормы = Элементы.Найти("ВсплывающаяГруппаПараметровДействия_Индекс_" + Строка(Объект.Действия.Индекс(СтрокаДействие)));
			Если НЕ ГруппаФормы = Неопределено Тогда
				Если ГруппаФормы.Скрыта() И ЗначениеЗаполнено(ВидДействия) Тогда 
					ГруппаФормы.Показать();
				ИначеЕсли НЕ ГруппаФормы.Скрыта() И НЕ ЗначениеЗаполнено(ВидДействия) Тогда	
					ГруппаФормы.Скрыть();
				КонецЕсли;	
			КонецЕсли;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция - Инициализировать структуру параметров отрисовки
//
// Параметры:
//  Объект	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСтруктуруПараметровОтрисовки(ИнициализироватьМассивАккаунтовСистемыОтправки = Истина, ИндексСтроки = Неопределено) Экспорт
	
	ПараметрыОтрисовки = Новый Структура;
	
	// Формируем пустую структуру
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	Для Каждого КолонкаТаблицы Из ТаблицаВсехВариантовУсловийТриггерныхСобытий.Колонки Цикл 
		ПараметрыОтрисовки.Вставить(КолонкаТаблицы.Имя, КолонкаТаблицы.ТипЗначения.ПривестиЗначение());
	КонецЦикла;
	// Наполняем параметрами триггера
	Если ЗначениеЗаполнено(Объект.УсловиеСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Объект.УсловиеСобытия;		
	Иначе 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	КоллекцияВариантовУсловийТриггерныхСобытий 	= ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий", ВариантУсловияТриггерногоСобытия));
	Если КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0 Тогда 
		ЗаполнитьЗначенияСвойств(ПараметрыОтрисовки, КоллекцияВариантовУсловийТриггерныхСобытий[0]);
	КонецЕсли;
	
	ПараметрыОтрисовки.Вставить("ТабличнаяЧастьСодержитОднуАктуальнуюСтроку", Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь)).Количество() < 2);
	
	// Подготовка сервисов рассылки сообщений.	
	СервисыРассылки = Новый Структура;
	СервисыРассылки.Вставить("Push"     	, Неопределено);
	СервисыРассылки.Вставить("PushWallet"   , Неопределено);
	СервисыРассылки.Вставить("Messenger"	, Неопределено);
	СервисыРассылки.Вставить("SMS"      	, Неопределено);
	
	Если ИнициализироватьМассивАккаунтовСистемыОтправки Тогда
		ИнициализироватьНастройкиКаналовУведомлений();
		
#Область СТАРЫЙ_МЕХАНИЗМ_ОПРЕДЕЛНИЯ_СЕРВИСОВ_РАССЫЛКИ
		
		// Получим массив аккаунтов
		Запрос 			= Новый Запрос;
		Запрос.Текст 	= 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВнешниеСистемы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
		|ГДЕ
		|	ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
		|	И ВнешниеСистемы.Используется = ИСТИНА
		|	И ВнешниеСистемы.ТипВнешнейСистемы В (ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Chat2Desk), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СервисыРассылки.Ссылка
		|ИЗ
		|	Справочник.СервисыРассылки КАК СервисыРассылки
		|ГДЕ
		|	СервисыРассылки.ПометкаУдаления = ЛОЖЬ";
		
		ПараметрыОтрисовки.Вставить("МассивАккаунтовСистемыОтправкиСообщений", Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
		
#КонецОбласти

		ПараметрыОтрисовки.Вставить("МассивАккаунтовСистемыОтправкиСообщений", ТаблицаВнешнихСистем.Выгрузить().ВыгрузитьКолонку("Ссылка"));
	Иначе 
		ПараметрыОтрисовки.Вставить("МассивАккаунтовСистемыОтправкиСообщений", Новый Массив);
	КонецЕсли;

	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("СтруктурнаяЕдиница", ТекущаяСтруктурнаяЕдиница);
	Если НЕ ИндексСтроки = Неопределено Тогда
		СтрокаТаблицыПлана = Объект.Действия.Получить(ИндексСтроки);
		СтруктураПоиска.Вставить("ИдентификаторДействия", СтрокаТаблицыПлана.ИдентификаторДействия);
	КонецЕсли;	
	МассивСтрокНастроекКаналов = МоделируемыеНастройкиКаналовУведомлений.НайтиСтроки(СтруктураПоиска);
	Если НЕ МассивСтрокНастроекКаналов.Количество() = 0 Тогда 
		СтрокаНастроекКаналов = МассивСтрокНастроекКаналов[0];
		Если НЕ ИндексСтроки = Неопределено Тогда
			// Конвертируем элемент коллекции в структуру, так как невозможен обмен Клиент/Сервер			
			ПараметрыОтрисовки.Вставить("СтрокаНастройкиКаналовУведомлений", СтрокуТаблицыЗначенийВСтруктуру(СтрокаНастроекКаналов, ИменаКолонокМоделируемойТаблицы()));
		КонецЕсли;	
		// Сервис Push-уведомлений
		Если НЕ СтрокаНастроекКаналов.СписокАккаунтовPush.Количество() = 0 Тогда 
			СервисыРассылки.Push = СтрокаНастроекКаналов.СписокАккаунтовPush[0].Значение; 
		КонецЕсли;
		// Сервис Push Wallet
		Если НЕ СтрокаНастроекКаналов.СписокАккаунтовPushWallet.Количество() = 0 Тогда 
			СервисыРассылки.PushWallet = СтрокаНастроекКаналов.СписокАккаунтовPushWallet[0].Значение; 
		КонецЕсли;
		// Сервисы мессенджера
		СервисыMessenger = Новый Структура;
		СервисыMessenger.Вставить("GreenApi"        , Справочники.ВнешниеСистемы.ПустаяСсылка());
		СервисыMessenger.Вставить("Chat2Desk"      , Справочники.ВнешниеСистемы.ПустаяСсылка());
		
 		ПараметрыОтрисовки.Вставить("ИспользуетсяРасширениеМессенджер", ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер"));
 
		Для Каждого ЭлементСервисMessenger Из СтрокаНастроекКаналов.СписокАккаунтовMessenger Цикл
			МассивСтрокВнешнихСистем = ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("Ссылка", ЭлементСервисMessenger.Значение));
			Если НЕ МассивСтрокВнешнихСистем.Количество() = 0 Тогда 
				Если МассивСтрокВнешнихСистем[0].ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда 
					СервисыMessenger.Вставить("GreenApi"			, ЭлементСервисMessenger.Значение);
				ИначеЕсли МассивСтрокВнешнихСистем[0].ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk Тогда 
					СервисыMessenger.Вставить("Chat2Desk"		, ЭлементСервисMessenger.Значение);
				КонецЕсли;				
			КонецЕсли;
			Если ЗначениеЗаполнено(СервисыMessenger.GreenApi) И ЗначениеЗаполнено(СервисыMessenger.Chat2Desk) Тогда 
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		СервисыРассылки.Messenger 	= СервисыMessenger;
		ОтправкаMessenger 			= ПараметрыОтрисовки.ИспользуетсяРасширениеМессенджер 
									И (ЗначениеЗаполнено(СервисыРассылки.Messenger.Chat2Desk)
									ИЛИ ЗначениеЗаполнено(СервисыРассылки.Messenger.GreenApi));
		// Сервис sms-рассылки
		СервисыРассылки.SMS 		= СтрокаНастроекКаналов.АккаунтСервисаРассылкиSMS;
	Иначе 
		
#Область СТАРЫЙ_МЕХАНИЗМ_ОПРЕДЕЛНИЯ_СЕРВИСОВ_РАССЫЛКИ_2
		
		// Сервис Push-уведомлений.
		СервисыРассылки.Push = Справочники.ВнешниеСистемы.ПустаяСсылка();//Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента, Истина);
		
		// Сервис Push Wallet 	
		СервисыРассылки.PushWallet = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Wallet);
		
		// Севисы мессенджера.
		СервисыMessenger = Новый Структура;		
		СервисыMessenger.Вставить("GreenApi"        , Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.GreenApi        , Истина));
		СервисыMessenger.Вставить("Chat2Desk"      , Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.Chat2Desk      , Истина, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));
		
		СервисыРассылки.Messenger = СервисыMessenger;
		
		ОтправкаMessenger = ЗначениеЗаполнено(СервисыРассылки.Messenger.Chat2Desk)
		ИЛИ ЗначениеЗаполнено(СервисыРассылки.Messenger.GreenApi);
		
		// Сервис sms-рассылки.
		СервисыРассылки.SMS = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.СервисSMSРассылки;
		СервисыРассылки.SMS = ?(Не ЗначениеЗаполнено(СервисыРассылки.SMS), Константы.СервисSMSРассылкиПоУмолчанию.Получить(), СервисыРассылки.SMS);
		
#КонецОбласти
		
	КонецЕсли;				
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("СервисыРассылки"  	, СервисыРассылки);
	ПараметрыРассылки.Вставить("ОтправкаPush"     	, ЗначениеЗаполнено(СервисыРассылки.Push));
	ПараметрыРассылки.Вставить("ОтправкаPushWallet" , ЗначениеЗаполнено(СервисыРассылки.PushWallet));
	ПараметрыРассылки.Вставить("ОтправкаMessenger"	, ОтправкаMessenger);
	ПараметрыРассылки.Вставить("ОтправкаSMS"      	, ЗначениеЗаполнено(СервисыРассылки.SMS));
	
	ПараметрыОтрисовки.Вставить("ПараметрыРассылки"	, ПараметрыРассылки);
	
	ПараметрыОтрисовки.Вставить("МассивДоступныхСценариев", Новый Массив);
	Если ПараметрыОтрисовки.РазрешенаРаботаСЧатБотом И ПараметрыОтрисовки.ИспользуетсяРасширениеМессенджер Тогда 
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ТриггерноеСобытие", Объект.УсловиеСобытия);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СценарииЧатБотов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
		|ГДЕ
		|	СценарииЧатБотов.ПометкаУдаления = ЛОЖЬ
		|	И СценарииЧатБотов.Используется = ИСТИНА
		|	И СценарииЧатБотов.ТриггерныеСобытия.ТриггерноеСобытие = &ТриггерноеСобытие";
		
		ПараметрыОтрисовки.Вставить("МассивДоступныхСценариев", Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	КонецЕсли;	
		
	Возврат ПараметрыОтрисовки;
	
КонецФункции

&НаСервере
Процедура ИнициализироватьНастройкиКаналовУведомлений()
	
	МВТ 	= Новый МенеджерВременныхТаблиц;
	Запрос 	= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("ТаблицаЗначенийПланДействий", Объект.Действия.Выгрузить(Новый Структура("Удалено", Ложь)));
	Запрос.УстановитьПараметр("ТаблицаЗначенийНастройкиКаналовУведомлений", Объект.НастройкиКаналовУведомлений.Выгрузить());		
	Запрос.УстановитьПараметр("ТаблицаЗначенийКешированныхНастроекКаналовУведомлений", МоделируемыеНастройкиКаналовУведомлений.Выгрузить(, "ИдентификаторДействия, СтруктурнаяЕдиница, ОтправкаPush, ОтправкаPushWallet, ОтправкаMessenger, ОтправкаSMS, АккаунтВнешнейСистемы, АккаунтСервисаРассылкиSMS, КаналСистемыСообщений"));			
	Запрос.Текст = 
	"ВЫБРАТЬ ТаблицаЗначенийПланДействий.*
	|ПОМЕСТИТЬ ПланДействий
	|ИЗ &ТаблицаЗначенийПланДействий КАК ТаблицаЗначенийПланДействий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ТаблицаЗначенийНастройкиКаналовУведомлений.*
	|ПОМЕСТИТЬ НастройкиКаналовУведомлений
	|ИЗ &ТаблицаЗначенийНастройкиКаналовУведомлений КАК ТаблицаЗначенийНастройкиКаналовУведомлений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ТаблицаЗначенийКешированныхНастроекКаналовУведомлений.*
	|ПОМЕСТИТЬ КешированныеНастройкиКаналовУведомлений
	|ИЗ &ТаблицаЗначенийКешированныхНастроекКаналовУведомлений КАК ТаблицаЗначенийКешированныхНастроекКаналовУведомлений";	
	Запрос.Выполнить();
	
	Запрос 			= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	Действия.ИдентификаторДействия КАК ИдентификаторДействия,
	|	СтруктурныеЕдиницы.Ссылка КАК СтруктурнаяЕдиница,
	|	Действия.Использование КАК Использование,
	|	Действия.ОтправкаPush КАК ОтправкаPush,
	|	Действия.ОтправкаPushWallet КАК ОтправкаPushWallet,
	|	Действия.ОтправкаMessenger КАК ОтправкаMessenger,
	|	Действия.ОтправкаSMS КАК ОтправкаSMS,
	|	Действия.АккаунтВнешнейСистемы КАК АккаунтВнешнейСистемы,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Действия.АккаунтSMS, СтруктурныеЕдиницы.СервисSMSРассылки) = ЗНАЧЕНИЕ(Справочник.СервисыРассылки.ПустаяСсылка)
	|				ИЛИ ЕСТЬNULL(Действия.АккаунтSMS, СтруктурныеЕдиницы.СервисSMSРассылки) = НЕОПРЕДЕЛЕНО
	|			ТОГДА СервисSMSРассылкиПоУмолчанию.Значение
	|		ИНАЧЕ ЕСТЬNULL(Действия.АккаунтSMS, СтруктурныеЕдиницы.СервисSMSРассылки)
	|	КОНЕЦ КАК АккаунтSMS,
	|	Действия.КаналСистемыСообщений КАК КаналСистемыСообщений
	|ПОМЕСТИТЬ МоделируемыеНастройкиКаналовУведомлений
	|ИЗ
	|	ПланДействий КАК Действия
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО (ИСТИНА),
	|	Константа.СервисSMSРассылкиПоУмолчанию КАК СервисSMSРассылкиПоУмолчанию
	|ГДЕ
	|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	|	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.ИдентификаторДействия, МоделируемыеНастройкиКаналовУведомлений.ИдентификаторДействия) КАК ИдентификаторДействия,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.СтруктурнаяЕдиница, МоделируемыеНастройкиКаналовУведомлений.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиница,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.СтруктурнаяЕдиница, МоделируемыеНастройкиКаналовУведомлений.СтруктурнаяЕдиница)) КАК ПредставлениеСтруктурнойЕдиницы,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.СтруктурнаяЕдиница.Наименование, МоделируемыеНастройкиКаналовУведомлений.СтруктурнаяЕдиница.Наименование) КАК НаименованиеСтруктурнойЕдиницы,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.ОтправкаPush, МоделируемыеНастройкиКаналовУведомлений.ОтправкаPush) КАК ОтправкаPush,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.ОтправкаPushWallet, МоделируемыеНастройкиКаналовУведомлений.ОтправкаPushWallet) КАК ОтправкаPushWallet,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.ОтправкаMessenger, МоделируемыеНастройкиКаналовУведомлений.ОтправкаMessenger) КАК ОтправкаMessenger,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.ОтправкаSMS, МоделируемыеНастройкиКаналовУведомлений.ОтправкаSMS) КАК ОтправкаSMS,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.АккаунтВнешнейСистемы, МоделируемыеНастройкиКаналовУведомлений.АккаунтВнешнейСистемы) КАК АккаунтВнешнейСистемы,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.АккаунтВнешнейСистемы, МоделируемыеНастройкиКаналовУведомлений.АккаунтВнешнейСистемы)) КАК ПредставлениеАккаунтаВнешнейСистемы,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS, МоделируемыеНастройкиКаналовУведомлений.АккаунтSMS) = ЗНАЧЕНИЕ(Справочник.СервисыРассылки.ПустаяСсылка)
	|			ТОГДА МоделируемыеНастройкиКаналовУведомлений.АккаунтSMS
	|		ИНАЧЕ ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS, МоделируемыеНастройкиКаналовУведомлений.АккаунтSMS)
	|	КОНЕЦ КАК АккаунтСервисаРассылкиSMS,
	|	ЕСТЬNULL(ТекущиеНастройкиКаналовУведомлений.КаналСистемыСообщений, МоделируемыеНастройкиКаналовУведомлений.КаналСистемыСообщений) КАК КаналСистемыСообщений
	|ИЗ
	|	МоделируемыеНастройкиКаналовУведомлений КАК МоделируемыеНастройкиКаналовУведомлений
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиКаналовУведомлений КАК ТекущиеНастройкиКаналовУведомлений
	|		ПО МоделируемыеНастройкиКаналовУведомлений.ИдентификаторДействия = ТекущиеНастройкиКаналовУведомлений.ИдентификаторДействия
	|			И МоделируемыеНастройкиКаналовУведомлений.СтруктурнаяЕдиница = ТекущиеНастройкиКаналовУведомлений.СтруктурнаяЕдиница
	|		ЛЕВОЕ СОЕДИНЕНИЕ КешированныеНастройкиКаналовУведомлений КАК ТекущиеКешированныеНастройкиКаналовУведомлений
	|		ПО МоделируемыеНастройкиКаналовУведомлений.ИдентификаторДействия = ТекущиеКешированныеНастройкиКаналовУведомлений.ИдентификаторДействия
	|			И МоделируемыеНастройкиКаналовУведомлений.СтруктурнаяЕдиница = ТекущиеКешированныеНастройкиКаналовУведомлений.СтруктурнаяЕдиница
	|ГДЕ
	|	ТекущиеКешированныеНастройкиКаналовУведомлений.СтруктурнаяЕдиница ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИдентификаторДействия,
	|	НаименованиеСтруктурнойЕдиницы,
	|	СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ВнешниеСистемы.Ссылка) КАК Представление
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВнешниеСистемы.Используется = ИСТИНА
	|	И ВнешниеСистемы.ТипВнешнейСистемы В (ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Wallet), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi), ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.Chat2Desk))";		
	
	РезультатПакетаЗапросов = Запрос.ВыполнитьПакет();
	
	ТаблицаНастроекКаналовУведомлений = РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаВнешнихСистем.Загрузить(РезультатПакетаЗапросов[2].Выгрузить());
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
	//МоделируемыеНастройкиКаналовУведомлений.Очистить();
	Для Каждого СтрокаНастройкаКанала Из ТаблицаНастроекКаналовУведомлений Цикл 
		НоваяСтрока = МоделируемыеНастройкиКаналовУведомлений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаНастройкаКанала);
		Для Каждого СтрокаВнешняяСистема Из ТаблицаВнешнихСистем Цикл 
			Если СтрокаНастройкаКанала.СтруктурнаяЕдиница = СтрокаВнешняяСистема.СтруктурнаяЕдиница ИЛИ НЕ ЗначениеЗаполнено(СтрокаВнешняяСистема.СтруктурнаяЕдиница) Тогда 
				//Если СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.МобильноеПриложениеКлиента Тогда 
				//	НоваяСтрока.СписокАккаунтовPush.Добавить(СтрокаВнешняяСистема.Ссылка, СтрокаВнешняяСистема.Представление);
				Если СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet Тогда	
					НоваяСтрока.СписокАккаунтовPushWallet.Добавить(СтрокаВнешняяСистема.Ссылка, СтрокаВнешняяСистема.Представление);
				ИначеЕсли СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi ИЛИ СтрокаВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk Тогда	
					НоваяСтрока.СписокАккаунтовMessenger.Добавить(СтрокаВнешняяСистема.Ссылка, СокрЛП(СтрокаВнешняяСистема.Представление), СтрокаВнешняяСистема.Ссылка = НоваяСтрока.АккаунтВнешнейСистемы);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Если ЗначениеЗаполнено(СтрокаНастройкаКанала.АккаунтВнешнейСистемы) Тогда 
			СохраненныйАккаунтМессенджера = НоваяСтрока.СписокАккаунтовMessenger.НайтиПоЗначению(СтрокаНастройкаКанала.АккаунтВнешнейСистемы);
			Если СохраненныйАккаунтМессенджера = Неопределено Тогда 
				//НоваяСтрока.СписокАккаунтовMessenger.Добавить(СтрокаНастройкаКанала.АккаунтВнешнейСистемы, Новый ФорматированнаяСтрока(СокрЛП(СтрокаНастройкаКанала.ПредставлениеАккаунтаВнешнейСистемы) + " (не корректный аккаунт)", , Новый Цвет(255, 0, 0)));
				НоваяСтрока.ОтправкаMessenger = Ложь;
			КонецЕсли;
		ИначеЕсли НоваяСтрока.СписокАккаунтовMessenger.Количество() = 1 Тогда  
			НоваяСтрока.АккаунтВнешнейСистемы = НоваяСтрока.СписокАккаунтовMessenger[0].Значение;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаНастройкаКанала.АккаунтСервисаРассылкиSMS) Тогда 
			НоваяСтрока.СписокАккаунтовSMS.Добавить(СтрокаНастройкаКанала.АккаунтСервисаРассылкиSMS);
		КонецЕсли;	
	КонецЦикла;
	
	ТаблицаАктуальныхСЕ = ТаблицаНастроекКаналовУведомлений.Скопировать(, "СтруктурнаяЕдиница");
	ТаблицаАктуальныхСЕ.Свернуть("СтруктурнаяЕдиница");
	СписокАктуальныхСтруктурныхЕдиниц.ЗагрузитьЗначения(ТаблицаАктуальныхСЕ.ВыгрузитьКолонку("СтруктурнаяЕдиница"));
	
КонецПроцедуры

