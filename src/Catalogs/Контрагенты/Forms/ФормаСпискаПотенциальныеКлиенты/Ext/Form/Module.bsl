//
Процедура ОтборБезЗадач(Команда)

	ОбновитьОтборНаСервере(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ОтборБезСделок".
//
Процедура ОтборБезСделок(Команда)

	ОбновитьОтборНаСервере(,Истина);
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "ОтборПросроченныхЗадач".
//
Процедура ОтборПросроченныхЗадач(Команда)
	
	// ЭтаФорма.ОтборБезЗадач  = Ложь;
	// ЭтаФорма.ОтборБезСделок = Ложь;
	// ЭтаФорма.ОтборПросроченныхЗадач = Истина;
	//
	// ОбновитьОтборНаСервере();
	
	ОбновитьОтборНаСервере(,, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "КомандаСоздать".
//
Процедура КомандаСоздать(Команда)
	
	Если ЭтотОбъект.ЭтоВерсияКОРП = Истина Тогда
		
		СписокВыбора = ПолучитьСписокВидовСделок();
		СписокВыбора.Добавить("СоздатьКлиента", НСтр("ru='Потенциального'; en='Potential'"));
		
		Оповещение = Новый ОписаниеОповещения("СоздатьПотенциальногоЗавершение", ЭтотОбъект);
		ПоказатьВыборИзМеню(Оповещение, СписокВыбора, Элементы.ДобавитьНового);
		
	Иначе
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, СоздатьПотенциальногоЗавершение.
//
Процедура СоздатьПотенциальногоЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	ИначеЕсли Результат.Значение = "СоздатьКлиента" Тогда
		
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта");
		
	ИначеЕсли ТипЗнч(Результат.Значение) = Тип("СправочникСсылка.ВидыСделок")
		И ЗначениеЗаполнено(Результат.Значение) Тогда
		
		Сделка = СоздатьСделку(Результат.Значение);

		ДанныеЗаполнения = Новый Структура();
		ДанныеЗаполнения.Вставить("Сделка", Сделка);
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", ДанныеЗаполнения);
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ____________________ОБРАБОТЧИКИ_МЕХАНИЗМА_ФИЛЬТРАЦИИ_ДАННЫХ________________________

#Область __________________ИНИЦИАЛИЗАЦИЯ_МЕХАНИЗМА_ФИЛЬТРАЦИИ______________________

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ИнициализироватьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОбновитьСписок = Ложь)
	
	// Обновляем отборы согласно параметров, переданных из другой формы	и уходим	
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ОчиститьВсеОтборы") И ПараметрыОтбора.ОчиститьВсеОтборы = Истина Тогда
		ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора); // Перешли из монитора при уже открытой текущей формы
		Возврат;
	КонецЕсли;
	
	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов(ТекущийПользователь);	
	
	// Отбор этапы сделки _0.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивЭтапов");
	ОбновитьДинамическоеМенюФильтрации_Этап(РезультатПакетногоЗапроса[2].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов, Истина);
		ОбновитьСписок = Истина;		
	КонецЕсли;	
	
	// Отбор сотрудник регистрации_1.
	ОбновитьДинамическоеМенюФильтрации_СотрудникРегистрации(РезультатПакетногоЗапроса[0].Выгрузить());
	
	// Отбор признак наличия задач _ 2.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач");
	ОбновитьДинамическоеМенюФильтрации_Задача(,УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		// МассивСтатусовНаличияЗадач = Новый Массив();
		// Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияЗадач) 
		//	И ПараметрыОтбора.МассивСтатусовНаличияЗадач[0] = "Нет задач" Тогда
		//	
		//	МассивСтатусовНаличияЗадач.Добавить(Ложь);
		// Иначе
		//	МассивСтатусовНаличияЗадач.Добавить(Истина);		
		// КонецЕсли;
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", ПараметрыОтбора.МассивСтатусовНаличияЗадач, Истина);
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор признак наличия сделок _3.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок");
	ОбновитьДинамическоеМенюФильтрации_Сделка(,УстановитьОтбор);
	Если УстановитьОтбор Тогда 
		
		МассивСтатусовНаличияСделок = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияСделок) 
			И ПараметрыОтбора.МассивСтатусовНаличияСделок[0] = Нстр("ru = 'Нет сделок'; en = 'No deals'") Тогда
			
			МассивСтатусовНаличияСделок.Добавить(Ложь);
		Иначе
			МассивСтатусовНаличияСделок.Добавить(Истина);		
		КонецЕсли;
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Сделка", МассивСтатусовНаличияСделок, Истина);
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор структурная единица _4.
	ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[4].Выгрузить(), Истина);
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина);		
		ОбновитьСписок = Истина;		
	Иначе 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Истина);
		ОбновитьСписок = Истина;		
	КонецЕсли;
	
	// Отбор менеджеров _5.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивМенеджеров"); // Перешли из монитора, открывая форму
	ОбновитьДинамическоеМенюФильтрации_Менеджер(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", ПараметрыОтбора.МассивМенеджеров, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"));
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор по дате создания _6.
	ОбновитьДинамическоеМенюФильтрации_СозданПериод();
	
	// Отбор период запланированной задачи_7. 
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодПланирования");
	ОбновитьДинамическоеМенюФильтрации_ПериодЗапланированнойЗадачи(, УстановитьОтбор);
	Если УстановитьОтбор Тогда    	
		
		МассивПериодаЗапланированнойЗадачи = Новый Массив();
		МассивПериодаЗапланированнойЗадачи.Добавить(ПараметрыОтбора.ПериодПланирования);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", МассивПериодаЗапланированнойЗадачи);
		
	КонецЕсли;
	
	// Отбор статус клиента_8. 
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("КоллекцияСтатусовКлиента");	
	ОбновитьДинамическоеМенюФильтрации_Статус(, УстановитьОтбор);
	Если УстановитьОтбор Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.КоллекцияСтатусовКлиента, Истина);
	КонецЕсли;	
	
	// Отбор рекламный источник _9.
	ВыборкаКоличества = РезультатПакетногоЗапроса[5].Выбрать();
	Если ВыборкаКоличества.Следующий() Тогда 
		Если ВыборкаКоличества.Количество < 200 Тогда 
			ОбновитьДинамическоеМенюФильтрации_РекламныйИсточник(РезультатПакетногоЗапроса[1].Выгрузить());
		Иначе 
			ОбновитьДинамическоеМенюФильтрации_РекламныйИсточник();
		КонецЕсли;	
	Иначе 	
		ОбновитьДинамическоеМенюФильтрации_РекламныйИсточник(РезультатПакетногоЗапроса[1].Выгрузить());
	КонецЕсли;
	
	// Отбор по тегам _10.
	ОбновитьДинамическоеМенюФильтрации_Тег(					РезультатПакетногоЗапроса[3].Выгрузить());
	
	Если ОбновитьСписок Тогда 
		АктуализироватьДанныеСпискаСогласноОтборов();	
	КонецЕсли; 	
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр статус.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Статус(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра	
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru = 'Статус'; en = 'Status'"));	
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыКонтрагентов"));
	
	// Формируем коллекцию сами
	КоллекцияЗначений = Новый ТаблицаЗначений;
	КоллекцияЗначений.Колонки.Добавить("Ссылка"			, Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыКонтрагентов"));
	КоллекцияЗначений.Колонки.Добавить("Представление"	, Новый ОписаниеТипов("Строка"));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", Перечисления.СтатусыКонтрагентов.Потенциальный, Нстр("ru= 'Потенциальный'; en = 'Potential'")));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", Перечисления.СтатусыКонтрагентов.Отказ, Нстр("ru = 'Отказ'; en = 'Denial'")));
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений);
	
	// Обновляем элементы фильтрации для текущего фильтра	
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																														
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр этап.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Этап(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru = 'Этап'; en = 'Stage'"));
