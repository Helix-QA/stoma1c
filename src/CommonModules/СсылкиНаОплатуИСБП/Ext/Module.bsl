// Функция - Сформировать номер заказа
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьНомерЗаказаСБП()
	
	ГСЧ				= Новый ГенераторСлучайныхЧисел(ТекущаяУниверсальнаяДатаВМиллисекундах());
	СлучайнаяСтрока = "";
	
	Для Сч = 1 по 20 Цикл        
		
		Набор = ГСЧ.СлучайноеЧисло(1,3);    
		Если Набор = 1 Тогда
			СлучайныйСимвол = ГСЧ.СлучайноеЧисло(0,9);    
		ИначеЕсли Набор = 2 Тогда
			СлучайныйСимвол = Символ(ГСЧ.СлучайноеЧисло(65,90));
		ИначеЕсли Набор = 3 Тогда
			СлучайныйСимвол = Символ(ГСЧ.СлучайноеЧисло(97,122));
		КонецЕсли;
		СлучайнаяСтрока = СлучайнаяСтрока + СлучайныйСимвол;
		
	КонецЦикла;
	
	Возврат НРег(СлучайнаяСтрока);
	
КонецФункции

// Функция - Обработать стандартный результат HTTPЗапроса
//
// Параметры:
//  РезультатЗапроса - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбработатьСтандартныйРезультатHTTPЗапроса(РезультатЗапроса, КодСостояния)
	
	РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
	РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатЗапроса.Свойство("code") И НРег(РезультатЗапроса.code) = НРег("SUCCESS");
	РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
	РезультатОперации.КодОшибки       		= КодСостояния;
	РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатЗапроса.Свойство("message"), РезультатЗапроса.message, РезультатЗапроса);
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Обработать исключение при выполнении HTTPЗапроса
//
// Параметры:
//  ДанныеИсключения - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбработатьИсключениеПриВыполненииHTTPЗапроса(ДанныеИсключения, HTTPОтвет = Неопределено)
	
	РезультатОперации = СтруктураСтандартныхПараметровРезОперации();
	
	Описание = СтрШаблон(
	"Описание: %1
	|ИмяМодуля: %2
	|НомерСтроки: %3
	|ИсходнаяСтрока: %4
	|Причина: %5",
	ДанныеИсключения.Описание,
	ДанныеИсключения.ИмяМодуля,
	ДанныеИсключения.НомерСтроки,
	ДанныеИсключения.ИсходнаяСтрока,
	ДанныеИсключения.Причина);
	
	РезультатОперации.КодОшибки       = ?(HTTPОтвет <> Неопределено, HTTPОтвет.КодСостояния, Неопределено);
	РезультатОперации.ОписаниеОшибки  = ?(HTTPОтвет <> Неопределено, HTTPОтвет.ПолучитьТелоКакСтроку(), "") + Символы.ПС + Описание;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Структура стандартынх параметров рез операции
// 
// Возвращаемое значение:
//   - 
//
Функция СтруктураСтандартныхПараметровРезОперации()	
	Возврат Новый Структура("ВыполненоУспешно, ПараметрыРезультата, КодОшибки, ОписаниеОшибки, ТелоЗапроса", Ложь, Неопределено, Неопределено, Неопределено, Неопределено);	
КонецФункции

// Функция - Структура tinkoff receipt
//
// Параметры:
//  ТаблицаЧека	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СтруктураTinkoffReceipt(СтруктураПараметров, ЭтоСДМБанк = Ложь, ЭтоЧастичнаяОплата = Ложь)
	
	ТаблицаЗадолженностей				= СтруктураПараметров.ТаблицаЗадолженностей;
	Организация							= СтруктураПараметров.Организация;	
	СтруктураОрганизации				= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Организация, "СистемаНалогообложенияДляАвансов, СистемаНалогообложения");
	СистемаНалогообложенияДляАвансов	= СтруктураОрганизации.СистемаНалогообложенияДляАвансов;
	СистемаНалогообложения				= СтруктураОрганизации.СистемаНалогообложения;
	
	// Обязательно должен быть заполнен или Телефон, или ЭлектроннаяПочта.
	Если ЭтоСДМБанк Тогда
		СведенияОЧеке = Новый Структура("email, phone, emailCompany, taxation, items",,,,, Новый Массив);
	Иначе
		СведенияОЧеке = Новый Структура("Email, Phone, Taxation, Items",,,, Новый Массив);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураПараметров.АдресЭПКонтрагента) Тогда 
		СведенияОЧеке.email = СтруктураПараметров.АдресЭПКонтрагента;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураПараметров.НомерТелефона) Тогда
		СведенияОЧеке.phone = СтруктураПараметров.НомерТелефона;
	КонецЕсли;
	
	Если ЭтоСДМБанк Тогда
		emailCompany = КонтактнаяИнформацияВызовСервераСтома.ПолучитьКонтактнуюИнформацию(СтруктураПараметров.СтруктурнаяЕдиница, Ложь).Email;		
		СведенияОЧеке.emailCompany = emailCompany;
	КонецЕсли;
	
	СуммаКОплате = 0;
	ТаблицаЧека = ПолучитьТаблицуЗапасовРеализаций(СтруктураПараметров.ТаблицаЗадолженностей);			
	Для Каждого ДокументПродажи Из ТаблицаЗадолженностей Цикл
		
		ЭтоВзносНаЛс = ТипЗнч(ДокументПродажи.ДокументЗадолженности) = Тип("СправочникСсылка.ВидыЛицевыхСчетов") ИЛИ ТипЗнч(ДокументПродажи.ДокументЗадолженности) = Тип("ДокументСсылка.НарядЗаказ") ИЛИ ТипЗнч(ДокументПродажи.ДокументЗадолженности) = Тип("ДокументСсылка.ПланЛечения");		
		СуммаОплаты = ДокументПродажи.Задолженность;		
		
		Если ЭтоВзносНаЛс Тогда
			
			Если ЭтоСДМБанк Тогда
				ЭлементДанных = Новый Структура("name, price, quantity, amount, paymentMethod, paymentObject, tax");
			Иначе
				ЭлементДанных = Новый Структура("Name, Price, Quantity, Amount, PaymentMethod, PaymentObject, Tax");
			КонецЕсли;
			
			ЭлементДанных.Name			= "Взнос на лицевой счет";
			ЭлементДанных.Quantity		= 1;
			ЭлементДанных.Amount		= ?(ЭтоСДМБанк, СуммаОплаты, СуммаОплаты*100);
			ЭлементДанных.Price			= ЭлементДанных.Amount;
			ЭлементДанных.Tax			= ПолучитьСтавкуНДС(МенеджерОборудованияВызовСервера.ПолучитьНДСПриВзносеНаЛицевойСчет(Организация));
			ЭлементДанных.PaymentMethod	= "advance";
			ЭлементДанных.PaymentObject	= "payment";
			
			СведенияОЧеке.items.Добавить(ЭлементДанных);	
			
		Иначе
			
			ОплаченоРанее = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОплатыПоДокументу(ДокументПродажи.ДокументЗадолженности);		
			МассивЗапасов = Обработки.ПомощникПроведенияОплаты.ПолучитьМассивПараметровТоваровККТ(ДокументПродажи.ДокументЗадолженности, ОплаченоРанее, СуммаОплаты, СтруктураПараметров.КассаОплаты); 
			
			НовыйМассивЗапасов = ФорматоЛогическийКонтрольРаздленияСтрок(МассивЗапасов);
			
			Для Каждого СтрокаТЧ Из НовыйМассивЗапасов Цикл
				
				Если ЭтоСДМБанк Тогда
					ЭлементДанных = Новый Структура("name, price, quantity, amount, paymentMethod, paymentObject, tax");
				Иначе
					ЭлементДанных = Новый Структура("Name, Price, Quantity, Amount, PaymentMethod, PaymentObject, Tax");
				КонецЕсли;
				
				НайденнаяСтрока = ТаблицаЧека.Найти(СтрокаТЧ.Номенклатура, "Номенклатура");
				
				СтрокаТЧ.Вставить("ТипНоменклатуры", ?(НайденнаяСтрока <> Неопределено, НайденнаяСтрока.ТипНоменклатуры, Неопределено));
					
				ЭлементДанных.Name			= СтрокаТЧ.Наименование;;
				ЭлементДанных.Quantity		= СтрокаТЧ.Количество;
				ЭлементДанных.Price			= ?(ЭтоСДМБанк, СтрокаТЧ.ЦенаСоСкидками, СтрокаТЧ.ЦенаСоСкидками*100);
				ЭлементДанных.Amount		= ?(ЭтоСДМБанк, СтрокаТЧ.Сумма, СтрокаТЧ.Сумма*100);
				
				ЭлементДанных.Tax			= ПолучитьСтавкуНДС(СтрокаТЧ.СтавкаНДС, СтрокаТЧ.СуммаВключаетНДС);
				ЭлементДанных.PaymentMethod	= ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(СтрокаТЧ);
				ЭлементДанных.PaymentObject	= ПризнакПредметаРасчетаПриПродажеИлиВозврате(СтрокаТЧ);
				
				СуммаКОплате = СуммаКОплате + СтрокаТЧ.Сумма;
				
				СведенияОЧеке.Items.Добавить(ЭлементДанных);
				
			КонецЦикла;
					
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЭтоВзносНаЛс Тогда
		ВидНалога = ?(ЗначениеЗаполнено(СистемаНалогообложенияДляАвансов), СистемаНалогообложенияДляАвансов, СистемаНалогообложения);
	Иначе
		ВидНалога = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТаблицаЗадолженностей[0].ДокументЗадолженности, "ВидНалога");
	КонецЕсли;
	
	КодСистемыНалогообложения	= МенеджерОборудованияВызовСервера.КодСистемыНалогообложения(Организация, ВидНалога); 		
	СведенияОЧеке.taxation		= ПолучитьТипыСистемНалогообложенияККТ(КодСистемыНалогообложения);	
		
	Если ЭтоВзносНаЛс = Ложь Тогда
		
		Payments			= СформироватьВидыОплат(ТаблицаЗадолженностей, СуммаКОплате);		
		ЭтоЧастичнаяОплата	= Payments.Credit > 0;
		
		Если ЭтоСДМБанк = Ложь Тогда
			СведенияОЧеке.Вставить("Payments", Payments);		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СведенияОЧеке;
	
КонецФункции

// Функция - Формато логический контроль раздления строка
//
// Параметры:
//  МассивТоварныхПозиций	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ФорматоЛогическийКонтрольРаздленияСтрок(МассивТоварныхПозиций)

	НовыеПозицииЧека = Новый Массив;
	
	Для ИндексМассива = 0 По МассивТоварныхПозиций.Количество() - 1 Цикл
		
		ТекущаяПозиция = МассивТоварныхПозиций[ИндексМассива];
		ТекущаяПозиция.Вставить("ЦенаСоСкидками", Неопределено);
		ТекущаяПозиция.Вставить("СуммаСкидок", ТекущаяПозиция.СуммаСкидки);
		ТекущаяПозиция.Вставить("Сумма", ТекущаяПозиция.СтоимостьСоСкидкой);
		
		Наименование = ТекущаяПозиция.Наименование;
		Количество = ?(ТекущаяПозиция.Количество = 0, 1, ТекущаяПозиция.Количество);
		
		Если Количество = 1 Тогда
			НоваяПозиция = ФорматноЛогическийКонтрольКлиентСервер.СкопироватьСтруктуру(ТекущаяПозиция);
			НоваяПозиция.ЦенаСоСкидками = ТекущаяПозиция.СтоимостьСоСкидкой/Количество;
			НовыеПозицииЧека.Добавить(НоваяПозиция);
			Продолжить;
		КонецЕсли;
		
		ДопустимоеРасхождение = 0;
		Сумма = ТекущаяПозиция.СтоимостьСоСкидкой;
		НомерСекции = ТекущаяПозиция.НомерСекции;
		СтавкаНДС = ТекущаяПозиция.СтавкаНДС;
		РасчетнаяЦена = Окр(Сумма / Количество, 2, 1);
		НоваяСумма = Окр(Количество * РасчетнаяЦена, 2, 1);
		РазницаСумм = НоваяСумма - Сумма;
		
		Если РазницаСумм >= -ДопустимоеРасхождение И РазницаСумм <= ДопустимоеРасхождение Тогда
			НоваяПозиция = ФорматноЛогическийКонтрольКлиентСервер.СкопироватьСтруктуру(ТекущаяПозиция);
			НоваяПозиция.ЦенаСоСкидками = РасчетнаяЦена;
			НовыеПозицииЧека.Добавить(НоваяПозиция);
			Продолжить;
		Иначе
			ФорматноЛогическийКонтрольКлиентСервер.РазделитьФискальнуюСтроку(ТекущаяПозиция, НовыеПозицииЧека, РасчетнаяЦена, РазницаСумм);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат НовыеПозицииЧека;
	
КонецФункции

// Функция - Получить типы систем налогообложения ККТ
//
// Параметры:
//  КодСистемыНалогообложения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТипыСистемНалогообложенияККТ(КодСистемыНалогообложения)
	
	//osn — общая
	//usn_income — упрощенная (доходы)
	//usn_income_outcome — упрощенная (доходы минус расходы)
	//patent — патентная
	//envd — единый налог на вмененный доход
	//esn — единый сельскохозяйственный налог
	
	Если КодСистемыНалогообложения = 0 Тогда
		Возврат "osn"; // Перечисления.ТипыСистемНалогообложенияККТ.ОСН;
	ИначеЕсли КодСистемыНалогообложения = 1 Тогда
		Возврат "usn_income"; // Перечисления.ТипыСистемНалогообложенияККТ.УСНДоход;
	ИначеЕсли КодСистемыНалогообложения = 2 Тогда
		Возврат "usn_income_outcome"; // Перечисления.ТипыСистемНалогообложенияККТ.УСНДоходРасход;	
	ИначеЕсли КодСистемыНалогообложения = 3 Тогда
		Возврат "envd"; // Перечисления.ТипыСистемНалогообложенияККТ.ЕНВД;
	ИначеЕсли КодСистемыНалогообложения = 4 Тогда
		Возврат "esn"; // Перечисления.ТипыСистемНалогообложенияККТ.ЕСН;
	ИначеЕсли КодСистемыНалогообложения = 5 Тогда
		Возврат "patent"; // Перечисления.ТипыСистемНалогообложенияККТ.Патент;                           
	Иначе
		Возврат "osn"; // Перечисления.ТипыСистемНалогообложенияККТ.ОСН;
	КонецЕсли;
	
КонецФункции

// Функция - Получить таблицу запасов реализаций
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуЗапасовРеализаций(ТаблицаЗадолженностей)
	
	МассивДокументов = Новый Массив;
	
	Для Каждого СтрокаТЗ Из ТаблицаЗадолженностей Цикл
		МассивДокументов.Добавить(СтрокаТЗ.ДокументЗадолженности);	
	КонецЦикла;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияЗапасы.Номенклатура.Наименование КАК НаименованиеНоменклатуры,
	|	РеализацияЗапасы.КоличествоУпаковок КАК Количество,
	|	РеализацияЗапасы.Всего КАК Всего,
	|	РеализацияЗапасы.Ссылка КАК Ссылка,
	|	РеализацияЗапасы.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	РеализацияЗапасы.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.Реализация.Запасы КАК РеализацияЗапасы
	|ГДЕ
	|	РеализацияЗапасы.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияУслуги.Номенклатура.Наименование,
	|	РеализацияУслуги.КоличествоУпаковок,
	|	РеализацияУслуги.Всего,
	|	РеализацияУслуги.Ссылка,
	|	РеализацияУслуги.Номенклатура.ТипНоменклатуры,
	|	РеализацияУслуги.Номенклатура
	|ИЗ
	|	Документ.Реализация.Услуги КАК РеализацияУслуги
	|ГДЕ
	|	РеализацияУслуги.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЗапасы.Номенклатура.Наименование,
	|	ПриемЗапасы.КоличествоУпаковок,
	|	ПриемЗапасы.Всего,
	|	ПриемЗапасы.Ссылка,
	|	ПриемЗапасы.Номенклатура.ТипНоменклатуры,
	|	ПриемЗапасы.Номенклатура
	|ИЗ
	|	Документ.Прием.Запасы КАК ПриемЗапасы
	|ГДЕ
	|	ПриемЗапасы.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЛечение.Номенклатура.Наименование,
	|	ПриемЛечение.КоличествоУпаковок,
	|	ПриемЛечение.Всего,
	|	ПриемЛечение.Ссылка,
	|	ПриемЛечение.Номенклатура.ТипНоменклатуры,
	|	ПриемЛечение.Номенклатура
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|ГДЕ
	|	ПриемЛечение.Ссылка В(&МассивДокументов)");
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить ставку НДС
//
// Параметры:
//  СтавкаНДС		 - 	 - 
//  СуммаВключаетНДС - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтавкуНДС(СтавкаНДС, СуммаВключаетНДС = Истина)
	
	//none — без НДС
	//vat0 — 0%
	//vat10 — 10%
	//vat18 — 18%
	//vat110 — 10/110
	//vat118 — 18/118
	
	Если СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
		Возврат "none";
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
		Возврат "vat0";
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда
		Возврат "vat10";
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда
		Возврат "vat18";
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
		Возврат "vat20";
	КонецЕсли;
	
КонецФункции

// Функция - Сбербанк order params type
//
// Параметры:
//  ТаблицаЗадолженностей	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_order_params_type(ТаблицаЗадолженностей)
			
	ТаблицаЧека   = ПолучитьТаблицуЗапасовРеализаций(ТаблицаЗадолженностей);				
	МассивТоваров = Новый Массив;	
	
	Для Каждого ДокументПродажи Из ТаблицаЗадолженностей Цикл
		
		ЭтоВзносНаЛс = ТипЗнч(ДокументПродажи) = Тип("СправочникСсылка.ВидыЛицевыхСчетов") ИЛИ ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.НарядЗаказ") ИЛИ ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ПланЛечения");		
		СуммаОплаты = ДокументПродажи.Задолженность*100;
		
		Если ЭтоВзносНаЛс Тогда
			
			ЭлементДанных = Новый Структура("position_name, position_count, position_sum, position_description");			
			
			ЭлементДанных.position_name			= "Взнос на лицевой счет";
			ЭлементДанных.position_count		= 1;
			ЭлементДанных.position_sum			= СуммаОплаты;
			ЭлементДанных.position_description	= "Взнос на лицевой счет";
			
			МассивТоваров.Добавить(ЭлементДанных);	
			
		Иначе
			
			МассивНайденныхСтрок = ТаблицаЧека.НайтиСтроки(Новый Структура("Ссылка", ДокументПродажи.ДокументЗадолженности));		
			
			Для Каждого СтрокаТЧ Из МассивНайденныхСтрок Цикл
				
				ЭлементДанных						= Новый Структура("position_name, position_count, position_sum");
				ЭлементДанных.position_name			= ОбработатьНаименованиеНоменклатуры(СтрокаТЧ.НаименованиеНоменклатуры);
				ЭлементДанных.position_count		= Окр(СтрокаТЧ.Количество + 0.5, 0, 0);
				Всего								= СтрокаТЧ.Всего*100;
				ЭлементДанных.position_sum			= ?(СуммаОплаты >= Всего, Всего, СуммаОплаты);
				
				СуммаОплаты = СуммаОплаты - ЭлементДанных.position_sum;
				
				МассивТоваров.Добавить(ЭлементДанных);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивТоваров;
	
КонецФункции

// Функция - Обработать наименование номенклатуры
//
// Параметры:
//  Наименование - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбработатьНаименованиеНоменклатуры(Наименование)
	
	НовоеНаименование = "";
	ДопустимыеСимволы = "абвгдеёжзийклмнопрстуфхцчшщъыьэюяАБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯabcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
	ПервыйСимволПолучен = Ложь;
	Для НомерСимвола = 1 по СтрДлина(Наименование) Цикл
		
		Символ = Сред(Наименование, НомерСимвола, 1);
		
		Если СтрНайти(ДопустимыеСимволы, Символ) = 0 И СтрДлина(НовоеНаименование) = 0 Тогда
			Продолжить;	
		КонецЕсли;
		
		НовоеНаименование = НовоеНаименование + Символ;
				
	КонецЦикла;
	
	Возврат НовоеНаименование;
	
КонецФункции

// Функция - Признак предмета расчета при продаже или возврате
//
// Параметры:
//  Номенклатура				 - 	 - 
//  ЭтоОплатаКредита			 - 	 - 
//  АвансоваяСхемаПробитияУслуг	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПризнакПредметаРасчетаПриПродажеИлиВозврате(СтрокаТЧ) Экспорт
	
	ЭтоОплатаКредита = СтрокаТЧ.ЭтоОплатаКредита;
	ТипНоменклатуры = СтрокаТЧ.ТипНоменклатуры;
	
	Если ЭтоОплатаКредита <> Истина
		И (ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
		ИЛИ ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор) Тогда
		
		Возврат "service"; // Возврат Перечисления.ПризнакиПредметаРасчета.Услуга;
		
	ИначеЕсли ЭтоОплатаКредита <> Истина
		И (ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас
		ИЛИ ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал) Тогда
		
		Возврат "commodity"; // Возврат Перечисления.ПризнакиПредметаРасчета.Товар;

	ИначеЕсли ЭтоОплатаКредита = Истина 
		ИЛИ ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
		
	    Возврат "payment"; //Возврат Перечисления.ПризнакиПредметаРасчета.ПлатежВыплата;

	КонецЕсли;
		
	Возврат Неопределено;
	
КонецФункции

// Функция - Признак способа расчета при продаже
//
// Параметры:
//  СуммаКОплате	 - 	 - 
//  СуммаПлатежа	 - 	 - 
//  ЭтоОплатаКредита - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(СтрокаТЧ)
	
	ЭтоОплатаКредита	= СтрокаТЧ.ЭтоОплатаКредита;
	ТипНоменклатуры		= СтрокаТЧ.ТипНоменклатуры;
	СуммаКОплате		= СтрокаТЧ.СтоимостьСоСкидкой;
	СуммаПлатежа		= СтрокаТЧ.СуммаОплачено;
			
	Если ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
		
		Возврат "advance"; //Перечисления.ПризнакиСпособаРасчета.Аванс;
		
	ИначеЕсли ЭтоОплатаКредита = Истина Тогда
		
		Возврат "credit_payment"; //Перечисления.ПризнакиСпособаРасчета.ОплатаКредита;	
		
	ИначеЕсли СуммаКОплате <= СуммаПлатежа Тогда
		
		Возврат "full_payment"; //Перечисления.ПризнакиСпособаРасчета.ПередачаСПолнойОплатой;
		
	ИначеЕсли СуммаПлатежа > 0 И СуммаПлатежа < СуммаКОплате Тогда
		
		Возврат "partial_payment"; // Перечисления.ПризнакиСпособаРасчета.ПередачаСЧастичнойОплатой;
				
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;	
	
КонецФункции

// Функция - Сформировать виды оплат
//
// Параметры:
//  МассивОплат	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьВидыОплат(ТаблицаЗадолженностей, СуммаКОплате)
	
	СуммаКОплате					= СуммаКОплате*100;
	ОплачиваемаяСумма				= ТаблицаЗадолженностей.Итог("Задолженность")*100;
	ВозвращаемаяСтруктура			= Новый Структура("Cash, Electronic, AdvancePayment, Credit, Provision", 0, ОплачиваемаяСумма, 0, 0, 0);
	ВозвращаемаяСтруктура.Credit	= ?(СуммаКОплате > ОплачиваемаяСумма, СуммаКОплате - ОплачиваемаяСумма, ВозвращаемаяСтруктура.Credit);
	
	Возврат ВозвращаемаяСтруктура;
	
КонецФункции

// Функция - Создать возврат оплаты электронными средствами
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьВозвратОплатыЭлектроннымиСредствами(СтруктураПараметров) Экспорт
	
	ДокументОплаты = Документы.СписаниеДенежныхСредств.СоздатьДокумент();
	
	ДокументОплаты.Дата						= ТекущаяДатаСеанса();
	ДокументОплаты.ТипДенежныхСредств 		= Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта;
	ДокументОплаты.ВидОперации 				= Перечисления.ВидыОпераций.ВозвратОплатыКлиенту;
	ДокументОплаты.Статья					= Справочники.СтатьиДоходовИРасходов.ВозвратОплатыКлиенту;
	ДокументОплаты.Контрагент				= СтруктураПараметров.Контрагент;
	ДокументОплаты.СтруктурнаяЕдиница		= СтруктураПараметров.СтруктурнаяЕдиница;
	ДокументОплаты.Организация				= СтруктураПараметров.СтруктурнаяЕдиница.Организация;
	ДокументОплаты.Касса					= СтруктураПараметров.КассаОплаты;
	ДокументОплаты.ЭквайрингТерминал		= СтруктураПараметров.ЭквайринговыйТерминал;
	ДокументОплаты.НомерВходящегоДокумента	= СтруктураПараметров.УИДВозврата;
	
	НоваяСтрокаТЧ						= ДокументОплаты.РасшифровкаПлатежа.Добавить();	
	НоваяСтрокаТЧ.ДокументОснования		= СтруктураПараметров.ВозвратОтПокупателя;
	НоваяСтрокаТЧ.Статья				= Справочники.СтатьиДоходовИРасходов.ВозвратОплатыКлиенту;		                                                
	НоваяСтрокаТЧ.Сумма					= СтруктураПараметров.СуммаВозвратаВРублях;			
	ДокументОплаты.СуммаДокумента		= ДокументОплаты.РасшифровкаПлатежа.Итог("Сумма");	
	
	Возврат ДокументОплаты;
	
КонецФункции

// Функция - Сформировать документ возврата и пробить
//
// Параметры:
//  Статус	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьДокументСписанияИПробить(СтруктураПараметров, Статус, ТипСсылкиНаОплату = Неопределено, ОтветJSON = Неопределено) Экспорт
	
	ПроверкаПоРегламенту = ТипСсылкиНаОплату = Неопределено;
	СтруктураВозврата	 = СтруктураПараметров.СтруктураВозврата;
	
	Если НРег(Статус) = НРег("COMPLETED") ИЛИ НРег(Статус) = НРег("REFUNDED") ИЛИ НРег(Статус) = НРег("FULL_REVERSAL") ИЛИ Статус = 4 Тогда
		  
		Статус = Перечисления.СтатусыЗаказовОнлайнОплаты.Оплачено;
		
	ИначеЕсли НРег(Статус) = НРег("DECLINED") ИЛИ НРег(Статус) = НРег("REJECTED") ИЛИ НРег(Статус) = НРег("EXPIRED") 
		ИЛИ НРег(Статус) = НРег("REVOKED") ИЛИ НРег(Статус) = НРег("REVERSED") ИЛИ НРег(Статус) = НРег("DEADLINE_EXPIRED") 
		ИЛИ НРег(Статус) = НРег("CANCELED") ИЛИ Статус = 3 ИЛИ Статус = 6 Тогда
		
		Статус = Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ;
		
	Иначе
		
		Статус = Перечисления.СтатусыЗаказовОнлайнОплаты.ОжидаетВозврата;
		
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Если Статус = Перечисления.СтатусыЗаказовОнлайнОплаты.Оплачено Тогда
		
		Если ПроверитьНаДубликатСписания(СтруктураПараметров.УИДВозврата) Тогда
			ОтменитьТранзакцию();
			РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(СтруктураПараметров.ВозвратОтПокупателя,,,, Статус,, СтруктураПараметров.УИДВозврата, ОтветJSON);
			СтруктураВозврата.ВыполненоУспешно = Истина;
			Возврат СтруктураВозврата;
		КонецЕсли;
	
		ПараметрыФискализации = Неопределено;
		СтруктураПараметров.КассаОплаты = Справочники.Кассы.ПолучитьКассуОплатыИПараметрыФискализации(СтруктураПараметров.ЭквайринговыйТерминал, ПараметрыФискализации);
		СписаниеДС = СоздатьВозвратОплатыЭлектроннымиСредствами(СтруктураПараметров);
		
		Попытка
			СписаниеДС.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ОтменитьТранзакцию();
			СтруктураВозврата.ОписаниеОшибки = ОписаниеОшибки();
			Возврат СтруктураВозврата;
		КонецПопытки;
		
		ТипФискализации = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктураПараметров.ЭквайринговыйТерминал, "ТипФискализации");
		Если ТипФискализации <> Перечисления.ТипыФискализации.ВСДМБанке И ТипФискализации <> Перечисления.ТипыФискализации.ВТинькофф Тогда 
			МассивФискализации = Новый Массив;
			МассивФискализации.Добавить(СписаниеДС.Ссылка);
			ФискализироватьПлатежи(МассивФискализации, СтруктураПараметров.КассаОплаты, ПараметрыФискализации);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПроверкаПоРегламенту = Ложь Тогда
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
			СтруктураПараметров.ВозвратОтПокупателя, 
			СтруктураПараметров.СуммаВозвратаВРублях, 
			СтруктураПараметров.ИдСБП,, 
			Статус,
			СтруктураПараметров.ЭквайринговыйТерминал,
			СтруктураПараметров.УИДВозврата,
			ОтветJSON,,
			СтруктураПараметров.Контрагент,,
			СтруктураПараметров.СтруктурнаяЕдиница,
			ТекущаяДатаСеанса(),
			СтрШаблон("Сформирован возврат по заказу %1 сотрудником %2", СтруктураПараметров.НомерЗаказа, СтруктураПараметров.ПредставлениеСотрудника),
			ТипСсылкиНаОплату,
			СтруктураПараметров.Сотрудник,,,
			Истина);
		
	Иначе
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(СтруктураПараметров.ВозвратОтПокупателя,,,, Статус,, СтруктураПараметров.УИДВозврата, ОтветJSON);	
	КонецЕсли;
	
	ЗафиксироватьТранзакцию(); 
	
	Если Статус = Перечисления.СтатусыЗаказовОнлайнОплаты.Оплачено Тогда
			
		ИспользоватьСистемуВзаимодействия	= ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
		АктивныеСотрудники					= ОбсужденияСистемыВзаимодействия.ПолучитьМассивАктивныхСотрудников(,,, СтруктураПараметров.СтруктурнаяЕдиница);
		
		Если ЗначениеЗаполнено(АктивныеСотрудники) Тогда			
			
			Если ИспользоватьСистемуВзаимодействия Тогда
				
				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("Ключ"					, "СБП_ВозвратОплаты");
				ДанныеСообщения.Вставить("ОснованиеОплаты"		, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(СписаниеДС.Ссылка));
				ДанныеСообщения.Вставить("transaction_id"		, СтруктураПараметров.УИДВозврата);
				ДанныеСообщения.Вставить("СтруктурнаяЕдиница"	, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(СтруктураПараметров.СтруктурнаяЕдиница));
				ДанныеСообщения.Вставить("Контрагент"			, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(СтруктураПараметров.Контрагент));
				ДанныеСообщения.Вставить("СтрокаОснований"		, Строка(СписаниеДС.Ссылка.УникальныйИдентификатор()));
				
				ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, АктивныеСотрудники);
				
			Иначе
				
				МассивПараметров = Новый Массив;
				МассивПараметров.Добавить(СписаниеДС.Ссылка);
				МассивПараметров.Добавить(СтруктураПараметров.УИДВозврата);
				МассивПараметров.Добавить(СтруктураПараметров.СтруктурнаяЕдиница);
				МассивПараметров.Добавить(СтруктураПараметров.Контрагент);	
				МассивПараметров.Добавить(Строка(СписаниеДС.Ссылка.УникальныйИдентификатор()));
				
				Для Каждого АктивныйСотрудник Из АктивныеСотрудники Цикл					
					РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(АктивныйСотрудник, СтруктураПараметров.СтруктурнаяЕдиница, "СБП_ВозвратОплаты",,,,, МассивПараметров);								
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	
	
	СтруктураВозврата.ВыполненоУспешно = Истина;
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Проверить на дубликат списания
//
// Параметры:
//  transaction_id	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьНаДубликатСписания(transaction_id) Экспорт
	
	// Получение поступлений
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	СписаниеДенежныхСредств.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|ГДЕ
	|	НЕ СписаниеДенежныхСредств.ПометкаУдаления
	|	И СписаниеДенежныхСредств.НомерВходящегоДокумента = &transaction_id");
	
	Запрос.УстановитьПараметр("transaction_id", transaction_id);
		
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

#Область ОбработатьВебХукСБП

// Функция - Обработать веб хук СБП
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  ПараметрыJSON	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбработатьОплатуПоСсылкуИСБП(ПараметрыЗапроса, ТекстЗапроса) Экспорт
	
	ЭтоТинькофф			= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф;
	ЭтоРайффайзенБанк	= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк;
	ЭтоАльфаБанк		= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк;	
	ЭтоСБПСбербанк		= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк;
	ЭтоСбербанкПлатиQR	= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR;
	ЭтоСДМБанк			= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ;
	ЭтоСбербанк			= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.Сбербанк;
	
	ДатаПоступления		= Неопределено;
	
	Если ЭтоТинькофф ИЛИ ЭтоСДМБанк Тогда
		
		Статус			= ПараметрыЗапроса.Status; 
		ИдСБП			= Формат(ПараметрыЗапроса.PaymentId, "ЧГ=100");
		НомерЗаказа		= ПараметрыЗапроса.OrderId;
		transaction_id	= Формат(ПараметрыЗапроса.PaymentId, "ЧГ=100"); 
		СуммаКОплате	= ?(ЭтоСДМБанк, ПараметрыЗапроса.amount, ПараметрыЗапроса.amount/100);
		
	ИначеЕсли ЭтоРайффайзенБанк Тогда
		
		Статус			= ПараметрыЗапроса.paymentStatus;
		ИдСБП			= ПараметрыЗапроса.qrId;
		НомерЗаказа		= ПараметрыЗапроса.order;
		transaction_id	= Формат(ПараметрыЗапроса.transactionId, "ЧГ=100");
		ДатаПоступления = ?(ПараметрыЗапроса.Свойство("transactionDate"), ПараметрыЗапроса.transactionDate, Неопределено);
		СуммаКОплате 	= ПараметрыЗапроса.amount;
		
	ИначеЕсли ЭтоСБПСбербанк ИЛИ ЭтоСбербанкПлатиQR Тогда
		
		// Ничего не делаем:
		// CREATED(СОЗДАН)			- создан или в привязке к заказу есть неуспешные авторизации.
		// AUTHORIZED(АВТОРИЗОВАН) 	- после 1й стадии двухстадийной оплаты.
		// ON_PAYMENT(НА ОПЛАТЕ)	- для QR СБП ожидает подтверждения платежа от СБП.
		// CONFIRMED(ПОДТВЕРЖДЕН) 	- после 2й стадии двухстадийной оплаты.
		
		// Пишем статус:
		// DECLINED(ОТКЛОНЕНО)		- отклонено банком.
		// EXPIRED(ИСТЕК)			- истек срок жизни заказа.
		// REVOKED(ОТМЕНЕНО)		- отменен до проведения финансовой операции.
		
		// Возврат и оплата:
		// REVERSED(ОБРАТНЫЙ)		- это отмена, производится в день оплаты.
		// REFUNDED(ВОЗВРАТ)		- это возврат,производится в последующие дни после оплаты.
		// PAID(ОПЛАЧЕНО)			- успешная операция покупки на сумму заказа.
		
		НайденнаяСтрокаОплаты 	= ?(ПараметрыЗапроса.Свойство("order_operation_params"), ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ПараметрыЗапроса.order_operation_params, "operation_type", "PAY"), Неопределено);
		Статус					= ПараметрыЗапроса.order_state;
		ИдСБП					= ПараметрыЗапроса.order_id;
		НомерЗаказа				= ПараметрыЗапроса.НомерЗаказа;
		ДатаПоступления 		= ?(НайденнаяСтрокаОплаты <> Неопределено, ПрочитатьДатуJSON(НайденнаяСтрокаОплаты.operation_date_time, ФорматДатыJSON.ISO), Неопределено);
		СуммаКОплате 			= ?(НайденнаяСтрокаОплаты <> Неопределено, НайденнаяСтрокаОплаты.operation_sum/100, Неопределено);
		
		Если ЭтоСБПСбербанк И ПараметрыЗапроса.Свойство("sbp_operation_params") И ПараметрыЗапроса.sbp_operation_params.Свойство("sbp_operation_id") Тогда
			transaction_id = ПараметрыЗапроса.sbp_operation_params.sbp_operation_id;
		ИначеЕсли НайденнаяСтрокаОплаты <> Неопределено Тогда
			transaction_id = НайденнаяСтрокаОплаты.operation_id;
		Иначе
			transaction_id = ПараметрыЗапроса.order_id;
		КонецЕсли;
		
	ИначеЕсли ЭтоСбербанк Тогда
		
		Статус			= ПараметрыЗапроса.paymentAmountInfo.paymentState;
		ИдСБП			= ПараметрыЗапроса.mdOrder;
		НомерЗаказа 	= ПараметрыЗапроса.НомерЗаказа;
	    transaction_id	= ПараметрыЗапроса.mdOrder;
		СуммаКОплате 	= ПараметрыЗапроса.amount/100;
		
	Иначе
		
		Статус			= ПараметрыЗапроса.operation;
		ИдСБП			= ПараметрыЗапроса.mdOrder;
		НомерЗаказа 	= ПараметрыЗапроса.orderNumber;
		transaction_id	= ПараметрыЗапроса.mdOrder;
		СуммаКОплате 	= Неопределено;
		
	КонецЕсли;
	
	Если НРег(Статус) = НРег("SUCCESS") ИЛИ НРег(Статус) = НРег("CONFIRMED") ИЛИ НРег(Статус) = НРег("PAID") ИЛИ НРег(Статус) = НРег("FULL_PAID") ИЛИ НРег(Статус) = НРег("DEPOSITED") Тогда
		СтатусЗаказа = Перечисления.СтатусыЗаказовОнлайнОплаты.Оплачено;
	ИначеЕсли НРег(Статус) = НРег("DECLINED") ИЛИ НРег(Статус) = НРег("REJECTED") ИЛИ НРег(Статус) = НРег("EXPIRED") 
		ИЛИ НРег(Статус) = НРег("REVOKED") ИЛИ (Не ЭтоТинькофф И НРег(Статус) = НРег("REVERSED")) ИЛИ НРег(Статус) = НРег("REFUNDED") 
		ИЛИ НРег(Статус) = НРег("DEADLINE_EXPIRED") ИЛИ НРег(Статус) = НРег("CANCELED") Тогда   
		СтатусЗаказа = Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ;	
	Иначе 		
		СтатусЗаказа = Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено;
	КонецЕсли;
	
	Если СтатусЗаказа <> Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено Тогда // Статус заказа изменен	
		РегистрыСведений.СтатусыОплатыЗаказов.ОбновитьЗаписьПоЗаказу(НомерЗаказа, ТекстЗапроса, ?(СтатусЗаказа = Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ, СтатусЗаказа, Неопределено));  
	КонецЕсли;
	
	Если НРег(Статус) = НРег("REVERSED") ИЛИ НРег(Статус) = НРег("REFUNDED") ИЛИ НРег(Статус) = НРег("FULL_REVERSAL") ИЛИ НРег(Статус) = НРег("PARTIAL_REVERSAL") Тогда
		// Необходимо создать возврат дс.
		Возврат Новый Структура("result", Истина);
	ИначеЕсли СтатусЗаказа <> Перечисления.СтатусыЗаказовОнлайнОплаты.Оплачено Тогда
		Возврат Новый Структура("result", Истина);
	КонецЕсли;
	
	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьЗаказыПоИд(ИдСБП, НомерЗаказа);	
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		Возврат ПолучитьСтруктуруВозврата(,1129);
	КонецЕсли;
	
	МассивПоступлений		  = Новый Массив;
	ЭквайринговыйТерминал 	  = ТаблицаЗаказов[0].ЭквайринговыйТерминал;
	СтруктурнаяЕдиница		  = ТаблицаЗаказов[0].СтруктурнаяЕдиница;
	Контрагент				  = ТаблицаЗаказов[0].Контрагент;
	Сотрудник				  = ТаблицаЗаказов[0].Сотрудник;
	ПараметрыФискализации	  = Неопределено;
	КассаОплаты				  = Справочники.Кассы.ПолучитьКассуОплатыИПараметрыФискализации(ЭквайринговыйТерминал, ПараметрыФискализации);
	Организация				  = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭквайринговыйТерминал, "Организация");
	СуммаКОплате			  = ?(СуммаКОплате = Неопределено, ТаблицаЗаказов.Итог("СуммаЗаказа"), СуммаКОплате); // АльфаБанк не передает сумму оплаты, берем ее из заказа 
	
	Если (ЭтоТинькофф ИЛИ ЭтоСДМБанк) И ПараметрыЗапроса.Свойство("Token") ИЛИ ЭтоАльфаБанк И ПараметрыЗапроса.Свойство("checksum") Тогда
		
		ПодписьВерна = ПроверитьПодписьЗапроса(ПараметрыЗапроса, ЭквайринговыйТерминал);
		
		Если Не ПодписьВерна Тогда
			Возврат ПолучитьСтруктуруВозврата(,1130);		
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(transaction_id) Тогда
		Возврат ПолучитьСтруктуруВозврата(,1012);
	ИначеЕсли Не ЗначениеЗаполнено(ЭквайринговыйТерминал) Тогда
		Возврат ПолучитьСтруктуруВозврата(,1014);
	ИначеЕсли Не ЗначениеЗаполнено(КассаОплаты) Тогда
		Возврат ПолучитьСтруктуруВозврата(,1057);
	ИначеЕсли Не ЗначениеЗаполнено(Организация) Тогда
		Возврат ПолучитьСтруктуруВозврата(1120); 
	ИначеЕсли Не ЗначениеЗаполнено(ПараметрыФискализации) Тогда
		Возврат ПолучитьСтруктуруВозврата(4058);		
	КонецЕсли;
	
	НачатьТранзакцию();	
	УстановитьБлокировку("Документ.ПоступлениеДенежныхСредств", "НомерВходящегоДокумента", transaction_id);	
	
	Если ПроверитьНаДубликатПоступления(Организация, transaction_id) Тогда
		ОтменитьТранзакцию();
		Возврат Новый Структура("result", Истина);
	КонецЕсли;
	
	ДатаПоступления = ?(ЗначениеЗаполнено(ДатаПоступления), ДатаПоступления, ТекущаяДатаСеанса());
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("Организация"				, Организация);	
	СтруктураПараметров.Вставить("Контрагент"				, Контрагент);
	СтруктураПараметров.Вставить("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
	СтруктураПараметров.Вставить("Дата"						, ДатаПоступления);
	СтруктураПараметров.Вставить("ЭквайрингТерминал"		, ЭквайринговыйТерминал);
	СтруктураПараметров.Вставить("Касса"					, КассаОплаты);
	СтруктураПараметров.Вставить("НомерВходящегоДокумента"	, transaction_id);
	СтруктураПараметров.Вставить("ВидЛицевогоСчета"			, ТаблицаЗаказов[0].Основание);
	СтруктураПараметров.Вставить("СуммаДокумента"			, СуммаКОплате);	 
	СтруктураПараметров.Вставить("ОплатаПоСсылке"			, ПараметрыЗапроса.ТипБанка);
	
	Если ТипЗнч(ТаблицаЗаказов[0].Основание) = Тип("СправочникСсылка.ВидыЛицевыхСчетов") Тогда		
		ПоступлениеДС = СоздатьПоступлениеДенежныхСредствНаЛицевойСчет(СтруктураПараметров);							
	Иначе
		ПоступлениеДС = СоздатьПоступлениеДенежныхСредств(СтруктураПараметров, ТаблицаЗаказов);   	
	КонецЕсли;
	МассивПоступлений.Добавить(ПоступлениеДС);
	
	МассивФискализации = Новый Массив;
	Для Каждого ПоступлениеОбъект Из МассивПоступлений Цикл
				
		Попытка
			ПоступлениеОбъект.Записать(РежимЗаписиДокумента.Проведение);
			РегистрыСведений.СтатусыОплатыЗаказов.ОбновитьЗаписьПоЗаказу(НомерЗаказа, ТекстЗапроса, СтатусЗаказа);
			МассивФискализации.Добавить(ПоступлениеОбъект.Ссылка);
		Исключение
			ОтменитьТранзакцию();
			ТекстОшибки = ОписаниеОшибки();
			Возврат ПолучитьСтруктуруВозвратаОшибки(1000, ТекстОшибки);
		КонецПопытки;
		
	КонецЦикла;
	
	ФискализироватьПлатежи(МассивФискализации, КассаОплаты, ПараметрыФискализации);
	ЗафиксироватьТранзакцию();
	
	ИспользоватьСистемуВзаимодействия	= ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
	АктивныеСотрудники					= ОбсужденияСистемыВзаимодействия.ПолучитьМассивАктивныхСотрудников(,,, СтруктурнаяЕдиница);
		
	Если ЗначениеЗаполнено(АктивныеСотрудники) Тогда
		
		СтрокаОснований = "";
		Для Каждого Заказ Из ТаблицаЗаказов Цикл
			Если ЗначениеЗаполнено(Заказ.Основание) И ТипЗнч(Заказ.Основание) <> Тип("СправочникСсылка.ВидыЛицевыхСчетов") Тогда
				СтрокаОснований = СтрокаОснований + ?(ЗначениеЗаполнено(СтрокаОснований), ",", "") + Заказ.Основание.УникальныйИдентификатор();
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого ПоступлениеДС Из МассивФискализации Цикл					
			
			Если ИспользоватьСистемуВзаимодействия Тогда
				
				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("Ключ"					, "СБП_УспешнаяОплата");
				ДанныеСообщения.Вставить("ОснованиеОплаты"		, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(ПоступлениеДС));
				ДанныеСообщения.Вставить("transaction_id"		, transaction_id);
				ДанныеСообщения.Вставить("СтруктурнаяЕдиница"	, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(СтруктурнаяЕдиница));
				ДанныеСообщения.Вставить("Контрагент"			, ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(Контрагент));
				ДанныеСообщения.Вставить("СтрокаОснований"		, СтрокаОснований);
				
				ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, АктивныеСотрудники);
				
			Иначе
				
				МассивПараметров = Новый Массив;
				МассивПараметров.Добавить(ПоступлениеДС);
				МассивПараметров.Добавить(transaction_id);
				МассивПараметров.Добавить(СтруктурнаяЕдиница);
				МассивПараметров.Добавить(Контрагент);	
				МассивПараметров.Добавить(СтрокаОснований);
				
				Для Каждого АктивныйСотрудник Из АктивныеСотрудники Цикл					
					РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(АктивныйСотрудник, СтруктурнаяЕдиница, "СБП_УспешнаяОплата",,,,, МассивПараметров);								
				КонецЦикла;
				
			КонецЕсли;					
			
		КонецЦикла;
	КонецЕсли;
	
	Возврат Новый Структура("result", Истина);
	
КонецФункции

// Функция - Проверить подпись запроса
//
// Параметры:
//  ПараметрыЗапроса		 - 	 - 
//  ЭквайринговыйТерминал	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПроверитьПодписьЗапроса(ПараметрыЗапроса, ЭквайринговыйТерминал)
	
	ЭтоТинькофф		= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф;
	ЭтоАльфаБанк	= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк;
	ЭтоСДМБанк		= ПараметрыЗапроса.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ;
	
	ПараметрыТерминала = ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
	
	Если ЭтоТинькофф Тогда						
		
		Если ПараметрыТерминала = Неопределено 
			ИЛИ Не ПараметрыТерминала.Свойство("СекретныйКлючТинькофф") 
			ИЛИ Не ЗначениеЗаполнено(ПараметрыТерминала.СекретныйКлючТинькофф) Тогда
			
			Возврат Ложь;
			
		КонецЕсли;
		
		ПараметрыЗапроса.Вставить("Password", ПараметрыТерминала.СекретныйКлючТинькофф);
		
		Sign = ПараметрыЗапроса.Token;
		
	ИначеЕсли ЭтоСДМБанк Тогда						
		
		Если ПараметрыТерминала = Неопределено 
			ИЛИ Не ПараметрыТерминала.Свойство("ПарольКлючаМерчанта") 
			ИЛИ Не ЗначениеЗаполнено(ПараметрыТерминала.ПарольКлючаМерчанта) Тогда
			
			Возврат Ложь;
			
		КонецЕсли;
		
		ПараметрыЗапроса.Вставить("Password", ПараметрыТерминала.ПарольКлючаМерчанта);
		
		Sign = ПараметрыЗапроса.Token;
	
	Иначе
		
		Если ПараметрыТерминала = Неопределено 
			ИЛИ Не ПараметрыТерминала.Свойство("ЗакрытыйКлюч") 
			ИЛИ Не ЗначениеЗаполнено(ПараметрыТерминала.ЗакрытыйКлюч) Тогда
			
			Возврат Ложь;
			
		КонецЕсли;
		
		Sign = ПараметрыЗапроса.checksum;
		
	КонецЕсли;
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Ключ");
	ТЗ.Колонки.Добавить("Значение");
	
	Для Каждого ЭлСтруктуры Из ПараметрыЗапроса Цикл
		
		Если НРег(ЭлСтруктуры.Ключ) = НРег("Token") ИЛИ НРег(ЭлСтруктуры.Ключ) = НРег("ТипБанка") 
			ИЛИ НРег(ЭлСтруктуры.Ключ) = НРег("checksum") ИЛИ НРег(ЭлСтруктуры.Ключ) = НРег("sign_alias") ИЛИ НРег(ЭлСтруктуры.Ключ) = НРег("repeater") Тогда 
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЭлСтруктуры.Значение) = Тип("Число") Тогда
			ПараметрЗначение = Формат(ЭлСтруктуры.Значение, "ЧГ=100");
		ИначеЕсли ТипЗнч(ЭлСтруктуры.Значение) = Тип("Булево") Тогда 
			ПараметрЗначение = Формат(ЭлСтруктуры.Значение, "БЛ=false; БИ=true");
		Иначе
			ПараметрЗначение = ЭлСтруктуры.Значение
		КонецЕсли;
		
		НоваяСтрока				= ТЗ.Добавить();
		НоваяСтрока.Ключ		= ЭлСтруктуры.Ключ;
		НоваяСтрока.Значение	= ПараметрЗначение;
		
	КонецЦикла;
	
	ТЗ.Сортировать("Ключ");
	
	ПараметрыСтрокой = "";
	Для Каждого ПараметрЗапроса Из ТЗ Цикл
		Если ЭтоТинькофф ИЛИ ЭтоСДМБанк Тогда
			ПараметрыСтрокой = ПараметрыСтрокой + ПараметрЗапроса.Значение;
		Иначе
			ПараметрыСтрокой = ПараметрыСтрокой + ПараметрЗапроса.Ключ + ";" + ПараметрЗапроса.Значение + ";";
		КонецЕсли;	
	КонецЦикла;
	
	Попытка
		
		Если ЭтоТинькофф ИЛИ ЭтоСДМБанк Тогда
			ВычисленныйSign = IPТелефония.SHA256(ПараметрыСтрокой);	
		Иначе 
			КлючШифрования  = ПараметрыТерминала.ЗакрытыйКлюч;
			ВычисленныйSign = ВРег(ОбщегоНазначения.ПолучитьХешСумму(КлючШифрования, ПараметрыСтрокой, "SHA256"));
		КонецЕсли;
		
		Возврат ВРег(ВычисленныйSign) = ВРег(Sign); 		
		
	Исключение
		Возврат Ложь;		
	КонецПопытки;
	
КонецФункции

// Функция, добавления (изменения или удаления) структурной единицы
// 
Функция ПроверитьНаДубликатПоступления(Организация, IDTransaction) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоступлениеДенежныхСредств.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|ГДЕ
	|	ПоступлениеДенежныхСредств.ПометкаУдаления = ЛОЖЬ
	|	И ПоступлениеДенежныхСредств.Организация = &Организация
	|	И ПоступлениеДенежныхСредств.НомерВходящегоДокумента = &IDTransaction");
	
	Запрос.УстановитьПараметр("Организация"  , Организация);
	Запрос.УстановитьПараметр("IDTransaction", IDTransaction);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, возвращает стурктуру возврата для http методов.
//
Функция ПолучитьСтруктуруВозврата(parameters = Неопределено, КодОшибки = 0, ОписаниеОшибки = "")
	
	message = ?(КодОшибки <> 0, ПолучитьОписаниеОшибки(КодОшибки, ОписаниеОшибки), "");
	Возврат Новый Структура("parameters, errors", parameters, Новый Структура("code, message", КодОшибки, message));
	
КонецФункции

// Функция, возвращает структуру возврата ошибки. 
// 
Функция ПолучитьСтруктуруВозвратаОшибки(КодОшибки = Неопределено, ОписаниеОшибки = "", ВернутьПустуюСтруктуру = Ложь) Экспорт
	
	Если ВернутьПустуюСтруктуру Тогда
		Возврат Новый Структура("code, message", 0, "");
	КонецЕсли;
	
	СтруктураОшибки = Новый Структура("code, message", КодОшибки, ПолучитьОписаниеОшибки(КодОшибки, ОписаниеОшибки));
	Возврат Новый Структура("Parameters, Errors",, СтруктураОшибки);
	
КонецФункции

// Функция, возвращает описание ошибки по коду.
// 
Функция ПолучитьОписаниеОшибки(КодОшибки, ДополнительноеОписание = "")
	
	Если КодОшибки = 1000 Тогда
		Возврат "Ошибка работы с базой данных. " + ДополнительноеОписание;
	ИначеЕсли КодОшибки = 1001 Тогда
		Возврат "Информация о клиенте не обновлена. " + ДополнительноеОписание;
	ИначеЕсли КодОшибки = 1002 Тогда
		Возврат "Пользователь с таким номером телефона или электронной почтой не зарегистрирован в системе";
	ИначеЕсли КодОшибки = 1012 Тогда
		Возврат "Не указано id транзакции";
	ИначеЕсли КодОшибки = 1013 Тогда
		Возврат "Не указана сумма пополнения счета";
	ИначеЕсли КодОшибки = 1014 Тогда
		Возврат "Не указан эквайринговый терминал оплаты";
	ИначеЕсли КодОшибки = 1015 Тогда
		Возврат "Обнаружено дублирования id транзакции";
	ИначеЕсли КодОшибки = 1016 Тогда
		Возврат "Прерывание транзакции, при пополнении лицевого счета: " + ДополнительноеОписание;
