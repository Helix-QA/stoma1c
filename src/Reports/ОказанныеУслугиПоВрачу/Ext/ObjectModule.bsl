

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Процедура - При компоновке результата
//
// Параметры:
//  ДокументРезультат	 - 	 - 
//  ДанныеРасшифровки	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	ОтчетыСервер.ПриКомпоновкеРезультата(КомпоновщикНастроек, СхемаКомпоновкиДанных, ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка);
	Для Каждого ЭлементОтбора Из КомпоновщикНастроек.Настройки.Отбор.Элементы ЦИкл
		
		Если ЭлементОтбора.ПредставлениеПользовательскойНастройки = "Врач" Тогда
			ЭлементОтбора.ПравоеЗначение = ПараметрыСеанса.ТекущийПользователь.Сотрудник;
			ЭлементОтбора.Использование = Истина;
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// Процедура - При определении настроек отчета
//
// Параметры:
//  НастройкиОтчета		 - 	 - 
//  НастройкиВариантов	 - 	 - 
//
Процедура ПриОпределенииНастроекОтчета(НастройкиОтчета, НастройкиВариантов) Экспорт
	
	НастройкиВариантов["ОказанныеУслуги"].Рекомендуемый    = Истина;
	
	НастройкиОтчета.Вставить("УровеньГруппировкиСтрок", 3);

	ЗаполнитьПредопределенныеВариантыОформления(НастройкиВариантов);
	
КонецПроцедуры

// Процедура - Заполнить предопределенные варианты оформления
//
// Параметры:
//  НастройкиВариантов	 - 	 - 
//
Процедура ЗаполнитьПредопределенныеВариантыОформления(НастройкиВариантов)
	
	МассивПолейСумм = Новый Массив;
	
	Для Каждого ДоступноеПоле Из КомпоновщикНастроек.Настройки.ДоступныеПоляВыбора.Элементы Цикл
		
		Если Не ДоступноеПоле.Ресурс Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяПоля = Строка(ДоступноеПоле.Поле);
		МассивПолейСумм.Добавить(ИмяПоля);
		
	КонецЦикла; 
	
	Для Каждого НастройкиТекВарианта Из НастройкиВариантов Цикл
		
		ВариантыОформления = НастройкиТекВарианта.Значение.ВариантыОформления;
		ОтчетыСервер.ДобавитьВариантыОформленияСумм(ВариантыОформления, МассивПолейСумм);
			
	КонецЦикла; 
	
	ОтобратьПриемыПоТекущемуСотруднику();
	
КонецПроцедуры

// Процедура - Отобрать приему по текущему сотруднику
//
Процедура ОтобратьПриемыПоТекущемуСотруднику() 
	
	ОтборПоВрачуСделан = Ложь;
	Для Каждого ЭлементОтбора Из КомпоновщикНастроек.Настройки.Отбор.Элементы ЦИкл
		
		Если ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Врач") Тогда // ЭлементОтбора.ПредставлениеПользовательскойНастройки = "Врач"
			ЭлементОтбора.ПравоеЗначение = ПараметрыСеанса.ТекущийПользователь.Сотрудник;
			ЭлементОтбора.Использование = Истина;
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
			ОтборПоВрачуСделан = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ ОтборПоВрачуСделан Тогда
		
		ЭлементыОтбора = КомпоновщикНастроек.Настройки.Отбор.Элементы;
		
		ОтборПоВрачу = ЭлементыОтбора.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборПоВрачу.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Врач");
		ОтборПоВрачу.ПравоеЗначение = ПараметрыСеанса.ТекущийПользователь.Сотрудник;
		ОтборПоВрачу.Использование = Истина;
		ОтборПоВрачу.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ОтборПоВрачу.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
		
		КомпоновщикНастроек.ЗагрузитьНастройки(КомпоновщикНастроек.Настройки);	
		
	КонецЕсли;
	
	
КонецПроцедуры


#КонецОбласти

#КонецЕсли

	

