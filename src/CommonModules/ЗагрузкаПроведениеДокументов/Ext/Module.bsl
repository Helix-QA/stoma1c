// Процедура - Изменить исполнителей задач по клиентам в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ИзменитьИсполнителейЗадачПоКлиентамВФоне(ПараметрыЗадания, АдресРезультата) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПараметрыЗадания.НовыйИсполнитель) Тогда 
		Возврат;
	КонецЕсли;	
	НовыйИсполнитель = ПараметрыЗадания.НовыйИсполнитель;

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	ЗадачаИсполнителя.Ссылка КАК Ссылка,
	               |	ЗадачаИсполнителя.Исполнитель КАК Исполнитель
	               |ИЗ
	               |	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	               |ГДЕ
	               |	ЗадачаИсполнителя.ПометкаУдаления = ЛОЖЬ
	               |	И ЗадачаИсполнителя.Выполнена = ЛОЖЬ
	               |	И ЗадачаИсполнителя.Исполнитель В(&МассивСотрудников)
	               |	И (ВЫРАЗИТЬ(ЗадачаИсполнителя.ЗадачаПредмет КАК Документ.Реализация).Контрагент В (&МассивКлиентов)
	               |			ИЛИ ВЫРАЗИТЬ(ЗадачаИсполнителя.ЗадачаПредмет КАК Документ.ЧленствоПакетУслуг).Контрагент В (&МассивКлиентов))
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗадачаИсполнителя.Ссылка,
	               |	ЗадачаИсполнителя.Исполнитель
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЗадачаИсполнителя.Ссылка,
	               |	ЗадачаИсполнителя.Исполнитель
	               |ИЗ
	               |	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	               |ГДЕ
	               |	ЗадачаИсполнителя.ПометкаУдаления = ЛОЖЬ
	               |	И ЗадачаИсполнителя.Выполнена = ЛОЖЬ
	               |	И ЗадачаИсполнителя.Исполнитель В(&МассивСотрудников)
	               |	И ЗадачаИсполнителя.ЗадачаПредмет В(&МассивКлиентов)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗадачаИсполнителя.Ссылка,
	               |	ЗадачаИсполнителя.Исполнитель
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЗадачаИсполнителя.Ссылка,
	               |	ЗадачаИсполнителя.Исполнитель
	               |ИЗ
	               |	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	               |ГДЕ
	               |	ЗадачаИсполнителя.ПометкаУдаления = ЛОЖЬ
	               |	И ЗадачаИсполнителя.Выполнена = ЛОЖЬ
	               |	И ЗадачаИсполнителя.Исполнитель В(&МассивСотрудников)
	               |	И ЗадачаИсполнителя.БизнесПроцесс.Контрагент В(&МассивКлиентов)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗадачаИсполнителя.Ссылка,
	               |	ЗадачаИсполнителя.Исполнитель";
	
	Запрос.УстановитьПараметр("МассивКлиентов"		, ПараметрыЗадания.МассивКлиентов);	
	Запрос.УстановитьПараметр("МассивСотрудников"	, ПараметрыЗадания.МассивИзменяемыхСотрудников);	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		ЗадачаОбъект 						= Выборка.Ссылка.ПолучитьОбъект();
		ЗадачаОбъект.Исполнитель 			= НовыйИсполнитель;
		ЗадачаОбъект.ОбменДанными.Загрузка 	= Истина;
		ЗадачаОбъект.ДополнительныеСвойства.Вставить("ЭтоОбновлениеИнформационнойБазы", Истина);
		Попытка
			ЗадачаОбъект.Записать();
			Если НЕ ЗадачаОбъект.БизнесПроцесс = Неопределено Тогда 
				Если ТипЗнч(ЗадачаОбъект.БизнесПроцесс) = Тип("БизнесПроцессСсылка.КонтрольПлатежейПоРассрочкам_КОРП") ИЛИ ТипЗнч(ЗадачаОбъект.БизнесПроцесс) = Тип("БизнесПроцессСсылка.ПродажаЧленства_КОРП") Тогда 
					Если НЕ ЗадачаОбъект.БизнесПроцесс.ИсполнительМенеджерПоПродажам = НовыйИсполнитель Тогда 
						БизнесПроцесс_Объект 								= ЗадачаОбъект.БизнесПроцесс.ПолучитьОбъект();
						БизнесПроцесс_Объект.ИсполнительМенеджерПоПродажам 	= НовыйИсполнитель;
						БизнесПроцесс_Объект.ОбменДанными.Загрузка 			= Истина;
						Попытка
							БизнесПроцесс_Объект.Записать();
						Исключение
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
						КонецПопытки;	
					КонецЕсли;	
				КонецЕсли;	
			КонецЕсли;	
		Исключение
			ТекстОшибки = ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецПопытки;	
	КонецЦикла;
	
КонецПроцедуры

// Функция - Инициализировать таблицу значений запасы
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьТаблицуЗначенийЗапасы() Экспорт
	
	МассивТиповОснований = Новый Массив;
	// МассивТиповОснований.Добавить(Тип("СправочникСсылка.ЛицевыеСчета"));
	// МассивТиповОснований.Добавить(Тип("ДокументСсылка.Аренда"));
	// МассивТиповОснований.Добавить(Тип("ДокументСсылка.ОперацииСЧленствомПакетомУслуг"));
	// МассивТиповОснований.Добавить(Тип("ДокументСсылка.ИзменениеУсловийЧленстваПакетаУслуг"));
	// МассивТиповОснований.Добавить(Тип("ДокументСсылка.ЧленствоПакетУслуг"));
	// МассивТиповОснований.Добавить(Тип("ДокументСсылка.Производство"));
	
	МоделируемаяТаблицаЗапасов = Новый ТаблицаЗначений;
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("КлючСтроки"		, Новый ОписаниеТипов("УникальныйИдентификатор"));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Номенклатура"		, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Количество"		, Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 3, ДопустимыйЗнак.Любой)));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("КоличествоУпаковок", Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 3, ДопустимыйЗнак.Любой)));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("ВидЦен"			, Новый ОписаниеТипов("СправочникСсылка.ВидыЦен"));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Цена"				, Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Любой)));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Сумма"				, Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Любой)));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Всего"				, Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Любой)));
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Основание"			, Новый ОписаниеТипов(МассивТиповОснований));			
	МоделируемаяТаблицаЗапасов.Колонки.Добавить("Сотрудник"			, Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	
	Возврат МоделируемаяТаблицаЗапасов;
			
КонецФункции	

// Функция - Начать интерпретацию сообщения клиента в фоне
//
