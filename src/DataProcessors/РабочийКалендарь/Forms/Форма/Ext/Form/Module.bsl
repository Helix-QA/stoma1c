// Процедура выполняет подготовку данных
//
Процедура ПодготовитьДанныеДляВыводаИнформацииПоКлиенту(Контрагент, СтруктурнаяЕдиница, ТабличныйДокумент, ШиринаИнформацииПоКлиенту, РазрешениеЭкрана, ТекущаяОбласть = Неопределено)
	
	Если ЗначениеЗаполнено(Контрагент) Тогда	
		Отчеты.ИнформацияПоКлиенту.ВывестиИнформациюПоКонграгенту(Контрагент, СтруктурнаяЕдиница, ТабличныйДокумент);		
		ШиринаЭкрана			= Сред(РазрешениеЭкрана, 1, Найти(РазрешениеЭкрана, "*") - 1);
		ШиринаЭкрана			= ?(ЗначениеЗаполнено(ШиринаЭкрана), ШиринаЭкрана, "1024");
		ШиринаБуфернойКолонки	= Цел(ШиринаЭкрана / 7.01) - 44.75 - 48.13 - 88;
		Ширина_2_х_БуферныхКолонок = ШиринаБуфернойКолонки / 2;
		ТабличныйДокумент.Область(, 4, , 4).ШиринаКолонки = ТабличныйДокумент.Область(, 4, , 4).ШиринаКолонки + ?(Ширина_2_х_БуферныхКолонок < 0, 0, Ширина_2_х_БуферныхКолонок);// / 2);
		ТабличныйДокумент.Область(, 8, , 8).ШиринаКолонки = ТабличныйДокумент.Область(, 8, , 8).ШиринаКолонки + ?(Ширина_2_х_БуферныхКолонок < 0, 0, Ширина_2_х_БуферныхКолонок);// / 2);		
		
		ШиринаИнформацииПоКлиенту = ТабличныйДокумент.ШиринаТаблицы;
		
		// ТабличныйДокумент.ФиксацияСлева = ТабличныйДокумент.ШиринаТаблицы;
	Иначе
		ТабличныйДокумент.Очистить();
	КонецЕсли;
	
	СформироватьИсториюВзаимодействияСКлиентом(Неопределено);
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет обновление состояние кассы
//
Процедура ОбновитьСостояниеКассы()
	
	СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСменыНаСервереБезКонтекста(Касса);
	СменаОткрыта                    = ?(СтруктураСостояниеКассовойСмены <> Неопределено, СтруктураСостояниеКассовойСмены.СменаОткрыта, Ложь);
	Если СтруктураСостояниеКассовойСмены <> Неопределено
		И ЗначениеЗаполнено(СтруктураСостояниеКассовойСмены.СтатусыКассовойСмены) Тогда		
		
		ТекстСтатусСмены 	= НСтр("ru='Касса: Смена %СтатусСмены% %ВремяИзменения%'");
		ТекстСтатусСмены 	= СтрЗаменить(ТекстСтатусСмены, "%СтатусСмены%", Нрег(СтруктураСостояниеКассовойСмены.СтатусыКассовойСмены));
		ТекстСтатусСмены   = СтрЗаменить(ТекстСтатусСмены, "%ВремяИзменения%", Формат(СтруктураСостояниеКассовойСмены.ДатаИзмененияСтатуса,"ДФ='dd MMMM ""в ""ЧЧ:мм'"));	
		Элементы.ГруппаКасса.Заголовок = ТекстСтатусСмены;
		СтатусСмены = Строка(СтруктураСостояниеКассовойСмены.СтатусыКассовойСмены);
	Иначе		
		Элементы.ГруппаКасса.Заголовок = НСтр("ru='Смена не открыта'");;
		СтатусСмены = ?(СтруктураСостояниеКассовойСмены <> Неопределено, Строка(СтруктураСостояниеКассовойСмены.СтатусыКассовойСмены), "");
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, выполняет обновление состояние кассы
//
Функция ОбновитьСостояниеКассыИзменение(СтруктураПроверки)
	
	СтруктураСостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(СтруктураПроверки.Касса);
	СтатусСмены = ?(СтруктураСостояниеКассовойСмены <> Неопределено, Строка(СтруктураСостояниеКассовойСмены.СтатусыКассовойСмены), "");
	
	Если СтатусСмены <> СтруктураПроверки.СтатусСмены Тогда
		СтруктураВозврата = Новый Структура("Изменять", Истина);	
		СтруктураВозврата.Вставить("СтатусСмены"	, СтатусСмены);
		СтруктураВозврата.Вставить("ВремяИзменения"	, ?(СтруктураСостояниеКассовойСмены <> Неопределено,
														Формат(СтруктураСостояниеКассовойСмены.ДатаИзмененияСтатуса,"ДФ='dd MMMM ""в ""ЧЧ:мм'"),
														""));
	Иначе
		СтруктураВозврата = Новый Структура("Изменять", Ложь);
	КонецЕсли;	
	
	Возврат СтруктураВозврата;
	
КонецФункции

