//	               |	""Просроченные"",
//	               |	ЗадачаИсполнителя.Выполнена,
//	               |	ВЫБОР
//	               |		КОГДА ЗадачаИсполнителя.Выполнена
//	               |			ТОГДА ""БледноЗеленый""
//	               |		ИНАЧЕ ""СветлоКоралловый""
//	               |	КОНЕЦ,
//	               |	ЗадачаИсполнителя.РезультатВыполнения.Наименование,
