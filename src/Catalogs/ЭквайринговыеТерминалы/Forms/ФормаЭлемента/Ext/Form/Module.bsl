&НаСервере
// Процедура, осуществляет отправку данных о банке в CRM.
//
Процедура ОтправитьДанныеОБанкеВCRM()
	
	Попытка
		
		ПараметрыПлатежногоШлюза 		= СформироватьСтруктуруПараметровПлатежногоШлюза();
		ВнешниеСистемыВиджетаРасписания = Справочники.ВнешниеСистемы.ПолучитьВнешниеСистемы(Перечисления.ТипыВнешнихСистем.ВиджетРасписания, Истина);
		
		Для Каждого ВнешняяСистема Из ВнешниеСистемыВиджетаРасписания Цикл
			
			api_key                 = ПолучитьЗначенияРеквизитовПоСсылке(ВнешняяСистема.Ссылка, "КлючПриложения");
			ПараметрыВнешнейСистемы = ПолучитьЗначенияРеквизитовПоСсылке(ВнешняяСистема.Ссылка, "Параметры");
			ПараметрыВнешнейСистемы = ПараметрыВнешнейСистемы.Получить();
			
			МассивСЭС = ПолучитьЗначениеИзСтруктуры(ПараметрыВнешнейСистемы, "МассивСтруктурноЭквайринговыхСоответствий", Новый Массив);
			
			Для Каждого ЭлементаМ Из МассивСЭС Цикл
				
				Если ЭлементаМ.ЭквайринговыйТерминал <> Объект.Ссылка Тогда
					Продолжить;
				КонецЕсли;	
				
				СтруктураПараметров = Справочники.ЭквайринговыеТерминалы.СформироватьСтруктуруПараметровБанка(
				ПараметрыПлатежногоШлюза,
				api_key,
				ЭлементаМ.СтруктурнаяЕдиница,
				Объект.Ссылка
				);
				
				ПараметрыЗапроса = ОбщегоНазначения.СформироватьСтрокуJSON(СтруктураПараметров);
				ВыполнитьPOSTЗапрос("update_bank_reservi", ПараметрыЗапроса);
				
			КонецЦикла;	
			
		КонецЦикла;
		
	Исключение
	КонецПопытки;
	
КонецПроцедуры	

