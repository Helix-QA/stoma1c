&НаКлиенте
// Процедура - обработчик события "ПослеЗаписи"
//
Процедура ПослеЗаписи(ПараметрыЗаписи)	
	
	Если Статус <> Объект.Статус Тогда 
		Статус = Объект.Статус;
		Оповестить("ИЗМЕНЕН_СТАТУС_ПЛАНА_ЛЕЧЕНИЯ");	
	КонецЕсли;
	Оповестить("ОбновитьИсториюВзаимодействияКонтрагента");
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события ОбработкаОповещения
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование"
		И ВводДоступен() Тогда
		Если ИмяСобытия = "TracksData" Тогда
			Если Параметр[1] = Неопределено Тогда
				Если ПолученКодКарты(Параметр[0], Параметр[0]) Тогда 
					КонтрагентПриИзменении(Неопределено);
				КонецЕсли;	
			Иначе
				Если ПолученКодКарты(Параметр[0], Параметр[1][1]) Тогда 
					КонтрагентПриИзменении(Неопределено);
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Конец ВнешнееОборудование 	
	
	Если ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА" ИЛИ ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА_АВАНСА" Тогда
		ЭтаФорма.Прочитать();
	КонецЕсли;	
	
	// Обработчик механизма "Свойства".
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
		ОбновитьДополнительныеРеквизиты();
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьИнформациюОСсылкахНаОплату" И ТипЗнч(Параметр) = Тип("Массив") И Параметр.Найти(Объект.Ссылка) <> Неопределено Тогда
		
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();
		
	ИначеЕсли ИмяСобытия = "СБП_УспешнаяОплата" Тогда
		
		ОбсужденияСистемыВзаимодействияКлиент.ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметр);	
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти  

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "ПриНажатии"
//
Процедура HTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если Не ДанныеСобытия.Element.ownerSVGElement = Неопределено Тогда 
		Если Не ДанныеСобытия.Element.ownerSVGElement = null И ЗначениеЗаполнено(ДанныеСобытия.Element.ownerSVGElement.id) Тогда
			
			СтруктураОткрытия = Неопределено;
			ОбновитьSVG = Ложь;
			ОбработатьВыбор(ДанныеСобытия.Element.ownerSVGElement.id, СтруктураОткрытия, ОбновитьSVG);
			
			Если Не СтруктураОткрытия = Неопределено И ОткрыватьПодбор Тогда 
				ОписаниеОповещения = Новый ОписаниеОповещения("HTMLПриНажатииЗавершение", ЭтотОбъект, Новый Структура("СтруктураОткрытия", СтруктураОткрытия));
				ОткрытьФорму("Справочник.Номенклатура.Форма.ЗубнаяФормулаПодбор", СтруктураОткрытия,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		Если ОбновитьSVG Тогда
			ОбновитьДокумент();
		КонецЕсли;	
	КонецЕсли;				
	
КонецПроцедуры 

&НаКлиенте
// Процедура - HTMLПри нажатии завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура HTMLПриНажатииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	СтруктураОткрытия = ДополнительныеПараметры.СтруктураОткрытия;
	ИдентификаторыНовыхСтрок = Новый Массив;						
	Если Не Результат = Неопределено и Результат.Количество() > 0 Тогда
		Для Каждого СтрокаМассива из Результат Цикл
			НоваяСтрока                          = Объект.Лечение.Добавить();
			НоваяСтрока.КлючСтроки               = Новый УникальныйИдентификатор;
			НоваяСтрока.Номенклатура             = СтрокаМассива;																		
			НоваяСтрока.Зуб = СтруктураОткрытия.Зуб; 
			ИдентификаторыНовыхСтрок.Добавить(НоваяСтрока.ПолучитьИдентификатор());
			ТаблицаУслугиНоменклатураПриИзменении(,ИдентификаторыНовыхСтрок, Истина);																		                          									
		КонецЦикла;
		ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
		ОбновитьSVGПодбор();
		Модифицированность = Истина;  								
	КонецЕсли;
	
	ОбновитьSVG = Истина;
	
	Если ОбновитьSVG Тогда
		ОбновитьДокумент();
	КонецЕсли;

КонецПроцедуры

