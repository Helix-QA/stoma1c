// Процедура - Обработать выбранное значение на сервере.
//
Процедура ОбработатьВыбранноеЗначение(Знач ВыбранноеЗначение, Знач ИмяЭлемента)
	
	Если ВыбранноеЗначение <> Неопределено Тогда 
		Счетчик = 0;
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
			Для Каждого ЭлементМ ИЗ ВыбранноеЗначение Цикл
				ДобавитьИзменитьСтрокуРасшифровкуПлатежа(Счетчик, ИмяЭлемента, ЭлементМ);
			КонецЦикла;
		Иначе
			ДобавитьИзменитьСтрокуРасшифровкуПлатежа(Счетчик, ИмяЭлемента, ВыбранноеЗначение);
		КонецЕсли; 
		// Подсчет суммы документа
		Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("Сумма");
		Если Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтСтраховойКомпании") Тогда
			ОчиститьЭлементыРасшифровки();
			СоздатьЭлементыРасшифровкиПлатежа(); 
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить изменить строку расшифровку платежа.
//
Процедура ДобавитьИзменитьСтрокуРасшифровкуПлатежа(Счетчик, Знач ИмяЭлемента, Знач ЗначениеВыбора)
		
	РазрешитьДобавление = Истина;
	// Проверка существования строки с выбранными данными
	Для Каждого СтрокаТ ИЗ Объект.РасшифровкаПлатежа Цикл 
		
		Если ТипЗнч(ЗначениеВыбора) = Тип("ДокументСсылка.НачислениеЗарплаты") Тогда
			
			СтрокаТ.Сумма       = ЗначениеВыбора.СуммаДокумента; 
			РазрешитьДобавление = Ложь;
			Счетчик = Счетчик + 1;
			Прервать;
			
		КонецЕсли;
		
		Если СтрокаТ.ДокументОснования = ЗначениеВыбора.ДокументОснования 
			И СтрокаТ.ДокументАванса = ЗначениеВыбора.ДокументАванса Тогда
			
			СтрокаТ.Сумма       = ЗначениеВыбора.СуммаДокумента; 
			РазрешитьДобавление = Ложь;
			Счетчик = Счетчик + 1;
			Прервать;
			
		КонецЕсли;	
	КонецЦикла;
	// Если добавление данных в строку разрешено
	Если РазрешитьДобавление = Истина Тогда
		
		ОбрабатываемаяСтрока = Неопределено;
		
		Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтСтраховойКомпании") Тогда
			ОбрабатываемаяСтрока = Элементы.РасшифровкаПлатежа.ТекущиеДанные;
		Иначе
			ОбрабатываемаяСтрока = Объект.РасшифровкаПлатежа[ПолучитьИндексСтроки(ИмяЭлемента)];
		КонецЕсли;	
		
		Если НЕ (Счетчик = 0 ИЛИ НЕ ЗначениеЗаполнено(ОбрабатываемаяСтрока.ДокументОснования) И НЕ ОбрабатываемаяСтрока.ЭтоАванс) Тогда 
			ПустыеСтроки = Объект.РасшифровкаПлатежа.НайтиСтроки(Новый Структура("ДокументОснования,Сумма",Неопределено,0));
			Если ПустыеСтроки.Количество() <> 0 Тогда
				ОбрабатываемаяСтрока = ПустыеСтроки[0];
			Иначе
				ОбрабатываемаяСтрока = Объект.РасшифровкаПлатежа.Добавить(); 
			КонецЕсли;
     
			
		КонецЕсли;	
		
		ОбрабатываемаяСтрока.ДокументОснования = ЗначениеВыбора.ДокументОснования;
		ОбрабатываемаяСтрока.ДокументАванса    = ЗначениеВыбора.ДокументАванса;
		ОбрабатываемаяСтрока.Сумма             = ЗначениеВыбора.Задолженность;
		
		Счетчик = Счетчик + 1;
	КонецЕсли;

КонецПроцедуры

