			Если ТриггерВзносНаЛицевойСчет.ПометкаУдаления = Истина Тогда 
				ТриггерВзносНаЛицевойСчет.ПометкаУдаления = Ложь;
			КонецЕсли;
			ТриггерВзносНаЛицевойСчет.ВидЛицевогоСчета 				= Справочники.ВидыЛицевыхСчетов.ПустаяСсылка();
			
			МассивДействийОтправитьСообщение = ТриггерВзносНаЛицевойСчет.Действия.НайтиСтроки(Новый Структура("ВидДействия, ВидАдресата, Удалено", Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение, Перечисления.ВидыАдресатов.КонтрагентСобытия, Ложь));
			СтрокаДействияОтправитьСообщение = Неопределено;
			Если МассивДействийОтправитьСообщение.Количество() = 0 Тогда 
				СтрокаДействияОтправитьСообщение = Неопределено;
			Иначе
