&НаСервере
// Процедура, создает динамический список подбора номенклатур.
//
Процедура СоздатьДинамическийСписокПодбораНоменклатур(
		Форма,
		Знач Объект,
		ИмяЭлементаДляРазмещения,
		Знач МассивТипов           		= NULL,
		ОтображатьКоличество       		= Ложь,
		ОтображатьЦену             		= Истина,
		ПодборНеСкрывается         		= Ложь,
		ОтображатьСнятыеСПродажи   		= Ложь,
		ОтображатьАртикул				= Ложь,
		ПолучитьХарактеристикиПолиса	= Ложь) Экспорт  
		
		
	Если ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги" Тогда
		ИмяДинамическогоСписка = "_ПодборНоменклатурУслуги";
	Иначе
		ИмяДинамическогоСписка = "_ПодборНоменклатур";
	КонецЕсли;
	
	УстановитьПараметрыДинамическогоСписка(
		Форма, 
		Объект, 
		МассивТипов, 
		ОтображатьКоличество, 
		ОтображатьСнятыеСПродажи,
		ИмяЭлементаДляРазмещения,
		ПолучитьХарактеристикиПолиса);
			
	Если ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги" Тогда
		РеквизитФормы = Форма._ПодборНоменклатурУслуги;
	Иначе
		РеквизитФормы = Форма._ПодборНоменклатур;
	КонецЕсли;
		
	РеквизитФормы.ОсновнаяТаблица = "Справочник.Номенклатура";
	
	РеквизитФормы.УстановитьОбязательноеИспользование("Артикул"                          , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("Родитель"                         , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("ЕдиницаИзмерения"                 , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("НормаВремени"                     , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("Упаковка"                         , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("ВидЦен"                           , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("ИспользоватьПартии"               , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("ЭтоСертификат"                    , Истина);
	РеквизитФормы.УстановитьОбязательноеИспользование("ВПродаже"                         , Истина); 	
	РеквизитФормы.УстановитьОбязательноеИспользование("Бесплатно"                        , Истина);  
	РеквизитФормы.УстановитьОбязательноеИспользование("ЭтоГруппа"                        , Истина); 
	РеквизитФормы.УстановитьОбязательноеИспользование("СкидкиЗапрещены"                  , Истина);
	
	// Если ПолучитьХарактеристикиПолиса Тогда
		РеквизитФормы.УстановитьОбязательноеИспользование("ПолисСогласование"             , Истина);
		РеквизитФормы.УстановитьОбязательноеИспользование("ПолисКоличество"				  , Истина);
		РеквизитФормы.УстановитьОбязательноеИспользование("ПолисКоличествоПриПревышении"  , Истина);
		РеквизитФормы.УстановитьОбязательноеИспользование("ПолисНеограничено"  			  , Истина);
		РеквизитФормы.УстановитьОбязательноеИспользование("КоличествоЗубов"  			  , Истина);
		РеквизитФормы.УстановитьОбязательноеИспользование("КоличествоВПриеме"  			  , Истина);
		РеквизитФормы.УстановитьОбязательноеИспользование("НаименованиеОграничения" 	  , Истина);

	// КонецЕсли;

	МассивПолей = Новый Массив;
	МассивПолей.Добавить("Номенклатура");
	
	РеквизитФормы.УстановитьОграниченияИспользованияВПорядке(МассивПолей);
	РеквизитФормы.ПолучениеПредставленийДляНевидимыхПолей = Истина;	
		
	Форма.Элементы[ИмяЭлементаДляРазмещения].ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	
	Если Не ПодборНеСкрывается
		И Не Объект.Ссылка.Пустая() Тогда
		
		Форма.Элементы[ИмяЭлементаДляРазмещения].Видимость = Ложь;
		
		Если ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги" Тогда
			Если Не Форма.Элементы.Найти("УслугиСкрытьПодбор") = Неопределено Тогда				
				Форма.Элементы["УслугиСкрытьПодбор"].Пометка = Форма.Элементы[ИмяЭлементаДляРазмещения].Видимость;
			КонецЕсли;
		Иначе
			Если Не Форма.Элементы.Найти("ЗапасыСкрытьПодбор") = Неопределено Тогда				
				Форма.Элементы["ЗапасыСкрытьПодбор"].Пометка = Форма.Элементы[ИмяЭлементаДляРазмещения].Видимость;
			КонецЕсли;
		КонецЕсли;
	
	КонецЕсли;
	
	Если ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги" Тогда
		НаименованиеПодбора = "_ПодборНоменклатурУслуги";
	Иначе
		НаименованиеПодбора = "_ПодборНоменклатур";
	КонецЕсли;
	
	ДинамическийСписок = Форма.Элементы.Найти(ИмяДинамическогоСписка);
			
	Если ДинамическийСписок = Неопределено Тогда	
		ДинамическийСписок  = Форма.Элементы.Добавить(ИмяДинамическогоСписка, Тип("ТаблицаФормы"), Форма.Элементы[ИмяЭлементаДляРазмещения]);
		ДинамическийСписок.ПутьКДанным    			   = ИмяДинамическогоСписка;
	КонецЕсли;
	
	ДинамическийСписок.Видимость      			   = Истина;	
	ДинамическийСписок.ТолькоПросмотр 			   = Ложь;
	ДинамическийСписок.КартинкаСтрок  			   = БиблиотекаКартинок.ТерминалПодбор_Новый; // ТерминалПодбор
	ДинамическийСписок.ПутьКДаннымКартинкиСтроки   = НаименованиеПодбора + ".ИндКартинки";
	ДинамическийСписок.ПоложениеКоманднойПанели    = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	ДинамическийСписок.ИзменятьСоставСтрок         = Ложь;
	ДинамическийСписок.ПоложениеСтрокиПоиска       = ПоложениеСтрокиПоиска.Верх;
	ДинамическийСписок.ПоложениеСостоянияПросмотра = ПоложениеСостоянияПросмотра.Нет;
	ДинамическийСписок.ИзменятьПорядокСтрок        = Ложь;
	ДинамическийСписок.Шапка                       = Ложь;
	ДинамическийСписок.РежимВыделения              = РежимВыделенияТаблицы.Одиночный;
	ДинамическийСписок.ПоложениеУправленияПоиском  = ПоложениеУправленияПоиском.Нет;
	ДинамическийСписок.РастягиватьПоГоризонтали    = Ложь;
	ДинамическийСписок.ВертикальнаяПолосаПрокрутки = ИспользованиеПолосыПрокрутки.НеИспользовать;
	ДинамическийСписок.НачальноеОтображениеДерева  = НачальноеОтображениеДерева.РаскрыватьВерхнийУровень;
	ДинамическийСписок.УстановитьДействие("Выбор"  , ?(ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги", "Подключаемый_ПодборУслугиВыбор", "Подключаемый_ПодборТоварыВыбор"));
		
	НовыйЭлемент = Форма.Элементы.Добавить(НаименованиеПодбора + "Подбор_Номенклатура", Тип("ПолеФормы"), ДинамическийСписок);
	НовыйЭлемент.Вид                    = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.Ширина                 = 25;
	НовыйЭлемент.АвтоМаксимальнаяШирина = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 	= 30;
	НовыйЭлемент.ПутьКДанным 			= НаименованиеПодбора + ".Номенклатура";
	
	// Если ОтображатьАртикул Тогда // ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.Прием") 
		
	НовыйЭлемент = Форма.Элементы.Добавить(НаименованиеПодбора + "Артикул", Тип("ПолеФормы"), ДинамическийСписок);
	НовыйЭлемент.Вид		 			  = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 			  = НаименованиеПодбора + ".Артикул";
	НовыйЭлемент.АвтоМаксимальнаяШирина   = Ложь;
	НовыйЭлемент.Ширина 	 			  = 3;
	НовыйЭлемент.Заголовок   			  = НСтр("ru = 'Артикул'; en = 'Vendor code'");
	НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
	НовыйЭлемент.Видимость = ОтображатьАртикул;
	
	ДинамическийСписок.РастягиватьПоГоризонтали    = Истина;
	ДинамическийСписок.АвтоМаксимальнаяШирина   = Истина;
	// ДинамическийСписок.МаксимальнаяШирина = 40;  // Ширина = 40;

	// КонецЕсли;

	// Если ОтображатьЦену Тогда
	НовыйЭлемент = Форма.Элементы.Добавить(НаименованиеПодбора + "Цена", Тип("ПолеФормы"), ДинамическийСписок);
	НовыйЭлемент.Вид		 			  = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 			  = НаименованиеПодбора + ".Цена";
	НовыйЭлемент.Формат 	 			  = "ЧДЦ=2; ЧН=0,00";  
	Если Объект <> Неопределено Тогда
		Ширина = ?(ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.Прием"), ?(ОтображатьКоличество, 4, 6), 7);
	Иначе 
		Ширина = 7;
	КонецЕсли;
	НовыйЭлемент.Ширина 	 			  = Ширина;
	НовыйЭлемент.АвтоМаксимальнаяШирина   = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 	  = 12;
	НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
	НовыйЭлемент.Видимость = ОтображатьЦену;
	// КонецЕсли;
	
	// Если ОтображатьКоличество Тогда
	НовыйЭлемент = Форма.Элементы.Добавить(НаименованиеПодбора + "Количество", Тип("ПолеФормы"), ДинамическийСписок);
	НовыйЭлемент.Вид		 			  = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 			  = НаименованиеПодбора + ".Количество";
	НовыйЭлемент.АвтоМаксимальнаяШирина   = Ложь;
	НовыйЭлемент.Ширина 	 			  = 4;
	НовыйЭлемент.Заголовок   			  = НСтр("ru = 'Остаток'; en = 'Balance'");
	НовыйЭлемент.РастягиватьПоГоризонтали = Ложь; 
	НовыйЭлемент.Видимость = ОтображатьКоличество;
	// КонецЕсли;
	
		
КонецПроцедуры

&НаСервере
// Процедура, устанавливает параметры динамического списка.
//
Процедура УстановитьПараметрыДинамическогоСписка(
		Форма,
		Объект,
		МассивТипов,
		ОтображатьКоличество,
		ОтображатьСнятыеСПродажи = Истина,
		ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги",
		ПолучитьХарактеристикиПолиса = Ложь)
		
	Если Объект <> Неопределено Тогда	
		
		ВидЦен  		   = ?(Объект.Ссылка.Метаданные().Реквизиты.Найти("ВидЦен")  			= Неопределено, Справочники.ВидыЦен.Розничная, Объект.ВидЦен);	
		СтруктурнаяЕдиница = ?(Объект.Ссылка.Метаданные().Реквизиты.Найти("СтруктурнаяЕдиница") = Неопределено, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Объект.СтруктурнаяЕдиница);
		Дата               = ТекущаяДатаСеанса();
		Для Каждого СтРеквизит Из Объект.Ссылка.Метаданные().СтандартныеРеквизиты Цикл
			Если СтРеквизит.Имя = "Дата" И ЗначениеЗаполнено(Объект.Дата) И НЕ Объект.Ссылка.Пустая() Тогда
				Дата = Объект.Дата;
			КонецЕсли;
		КонецЦикла;	
		Склад              = ?(Объект.Ссылка.Метаданные().Реквизиты.Найти("Склад") = Неопределено, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.ОсновнойСклад, Объект.Склад);
		
		СегментСотрудника  = Форма._ПодборСегментНоменклатуры;
		ОтброПоСегментам   = ЗначениеЗаполнено(СегментСотрудника); 
		
		ОтборДоговорПоПолисуМассив = Новый Массив;
		ОтборДоговорПоМедПолису    = Новый Массив;
		ВывестиДанныеПоДоговоруПолиса = Ложь;
		
	Иначе 
		
		МассивРеквизитовФормы = Форма.ПолучитьРеквизиты();
		МассивРеквизитов = Новый Массив;
		Для Каждого СтрокаМ Из МассивРеквизитовФормы Цикл
			МассивРеквизитов.Добавить(СтрокаМ.Имя);
		КонецЦикла;	
		
		СтруктурнаяЕдиница = ?(МассивРеквизитов.Найти("СтруктурнаяЕдиница") = Неопределено, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Форма.СтруктурнаяЕдиница);
		ВидЦен  		   = ?(МассивРеквизитов.Найти("ВидЦен")  			= Неопределено, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница.ВидЦенРеализации), СтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Розничная),?(ЗначениеЗаполнено(Форма.ВидЦенМатериалов), Форма.ВидЦенМатериалов, Неопределено)); 
		Дата               = ?(МассивРеквизитов.Найти("Дата") 			    = Неопределено, ТекущаяДатаСеанса(), Форма.Дата);
		Склад              = ?(МассивРеквизитов.Найти("Склад") 			    = Неопределено, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница.ОсновнойСклад),СтруктурнаяЕдиница.ОсновнойСклад, Неопределено), Форма.Склад);
		
		// параметры формы выбора номенклатуры
		Сотрудник         = ?(МассивРеквизитов.Найти("Сотрудник")   = Неопределено, Неопределено, Форма.Сотрудник);
		СегментСотрудника = ?(МассивРеквизитов.Найти("ОтборСегмент")= Неопределено, Неопределено, Форма.ОтборСегмент);
		ОтброПоСегментам  = ЗначениеЗаполнено(СегментСотрудника);
		
		ОтборДоговорПоПолисуМассив    = Новый Массив;
		ОтборДоговорПоМедПолису       = Новый Массив;
		ВывестиДанныеПоДоговоруПолиса = Ложь;
		
	КонецЕсли;

	Если Форма.ИмяФормы = "Документ.Прием.Форма.ФормаДокумента" 
		ИЛИ Форма.ИмяФормы = "Документ.ПланЛечения.Форма.ФормаДокумента"
		ИЛИ Форма.ИмяФормы = "Документ.НарядЗаказ.Форма.ФормаДокумента" Тогда
		
		ДоговорПоПолису = Форма._ПодборДоговорПолиса;	
		ВывестиДанныеПоДоговоруПолиса = ЗначениеЗаполнено(ДоговорПоПолису);
		ПолисМедСтрахования = Объект.ПолисМедСтрахования;
		ВывестиДанныеПоПолису = ЗначениеЗаполнено(Объект.ПолисМедСтрахования);
		
		Если ПолучитьХарактеристикиПолиса И ВывестиДанныеПоДоговоруПолиса Тогда
			
			ОтборДоговорПоПолисуМассив.Добавить(ДоговорПоПолису);
			Если ЗначениеЗаполнено(ДоговорПоПолису.ВидЦен)
				И ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги" Тогда
				ВидЦен = ДоговорПоПолису.ВидЦен	
			КонецЕсли;
			
		Иначе
			ОтборДоговорПоПолисуМассив.Добавить("Отсутствует");	
		КонецЕсли;
		
		Если ПолучитьХарактеристикиПолиса И ВывестиДанныеПоПолису Тогда
			ОтборДоговорПоМедПолису.Добавить("Отсутствует");		
		Иначе
			ОтборДоговорПоМедПолису.Добавить(ПолисМедСтрахования);	
		КонецЕсли;		
		
	Иначе
		ОтборДоговорПоПолисуМассив.Добавить("Отсутствует");	
		ОтборДоговорПоМедПолису.Добавить("Отсутствует");
	КонецЕсли;

	ОтборМассивТипов   = ЗначениеЗаполнено(МассивТипов);
	
	Если ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги" Тогда
		РеквизитФормы = Форма._ПодборНоменклатурУслуги;
	Иначе
		РеквизитФормы = Форма._ПодборНоменклатур;  		
		СброситьТекущуюСтрокуВПодборе(МассивТипов, Форма); // Сбрасываем текущую строку для условного оформления на видимость групп.	
	КонецЕсли;
	
	ЭтоПрием = (Форма.ИмяФормы = "Документ.Прием.Форма.ФормаДокумента") И ИмяЭлементаДляРазмещения = "ГруппаПодборУслуги";
	
	Если Объект <> Неопределено Тогда
		Сотрудник = ?(Объект.Свойство("Сотрудник"), Объект.Сотрудник, Неопределено);
	КонецЕсли;
	
	РеквизитФормы.ТекстЗапроса = ПолучитьТекстЗапросаПодбора(
		ОтброПоСегментам, 
		ОтборМассивТипов,
		Сотрудник,
		?(ПолучитьХарактеристикиПолиса, ВывестиДанныеПоДоговоруПолиса, Ложь),
		ЭтоПрием);  
		
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтображатьСнятыеСПродажи", ОтображатьСнятыеСПродажи);
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтображатьКоличество"    , ОтображатьКоличество);
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтборСтруктурнаяЕдиница" , СтруктурнаяЕдиница);
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтборВидЦен"             , ВидЦен);    
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтборНаДату"             , Дата);
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтборСклад"              , Склад); 
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		РеквизитФормы.Параметры.УстановитьЗначениеПараметра("Сотрудник" , Сотрудник);
	КонецЕсли;

	Если ОтброПоСегментам Тогда
		РеквизитФормы.Параметры.УстановитьЗначениеПараметра("СегментСотрудника"   , СегментСотрудника);	
	КонецЕсли;
	
	РеквизитФормы.Параметры.УстановитьЗначениеПараметра("СсылкаДоговорПоПолису"   , ДоговорПоПолису);
	
	Если ОтборМассивТипов Тогда
		РеквизитФормы.Параметры.УстановитьЗначениеПараметра("ОтборМассивТипов"    , МассивТипов);
	КонецЕсли;
	
	СписокНеиспользуемыхГрупп = Справочники.Номенклатура.ПолучитьНеиспользуемыеГруппы(
		СтруктурнаяЕдиница,
		Дата,
		МассивТипов,
		СегментСотрудника,
		Сотрудник,
		?((ПолучитьХарактеристикиПолиса И ВывестиДанныеПоДоговоруПолиса), ДоговорПоПолису, Неопределено));
		
	УстановитьУсловноеОформлениеСписка(РеквизитФормы, СписокНеиспользуемыхГрупп, (ПолучитьХарактеристикиПолиса И ВывестиДанныеПоДоговоруПолиса));	
	
КонецПроцедуры

&НаСервере
// Процедура, сбрасывает текущую строку, на доступную группу.
// Это нужно что бы свернуть группы, перед условным оформлением на видимость, иначе пустой подбор.
//
Процедура СброситьТекущуюСтрокуВПодборе(Знач МассивТипов, Знач Форма)

	Если Форма.Элементы.Найти("_ПодборНоменклатур") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивТипов) Тогда 
		ВыбранныйТип = Перечисления.ТипыНоменклатуры.Запас;
		Для каждого ТипНоменклатуры Из МассивТипов Цикл
			
			Если ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга Тогда
				ВыбранныйТип = ТипНоменклатуры;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	Номенклатура.Ссылка КАК ГруппаНоменклатуры
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА
		|	И Номенклатура.ПометкаУдаления = ЛОЖЬ
		|	И Номенклатура.ТипНоменклатуры = &ТипНоменклатуры";
		Запрос.УстановитьПараметр("ТипНоменклатуры", ВыбранныйТип);
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаЗапроса.Следующий() Тогда
			Форма.Элементы._ПодборНоменклатур.ТекущаяСтрока =  ВыборкаЗапроса.ГруппаНоменклатуры;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Функция, получает реквизит формы. Если реквизит не существует, то будет возвращено Неопределено. Ошибки возникать не будет.
//
Функция ПолучитьРеквизитФормы(Форма, НаименованиеРеквизита)
	
	СтруктураПоиска = Новый Структура(НаименованиеРеквизита, Неопределено);
	
	ЗаполнитьЗначенияСвойств(СтруктураПоиска, Форма);
	
	Возврат СтруктураПоиска[НаименованиеРеквизита];
	
КонецФункции

&НаСервере
// Функция, возвращает текст запроса.
//
Функция ПолучитьМассивОтбираемыхНоменклатур(Клиент, ОтброПоСегментам, Дата, СтруктурнаяЕдиница, СегментОрганизации, СегментСотрудника)
	
	Если Не ОтброПоСегментам Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтатусыНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже
		|ПОМЕСТИТЬ СтатусыНоменклатуры
		|ИЗ
		|	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&Дата, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СписокНоменклатуры.Ссылка КАК Номенклатура
		|ИЗ
		|	Справочник.Номенклатура КАК СписокНоменклатуры
		|		ЛЕВОЕ СОЕДИНЕНИЕ СтатусыНоменклатуры КАК СтатусыНоменклатуры
		|		ПО СписокНоменклатуры.Ссылка = СтатусыНоменклатуры.Номенклатура
		|ГДЕ
		|	НЕ СписокНоменклатуры.ПометкаУдаления
		|	И ЕСТЬNULL(СтатусыНоменклатуры.ВПродаже, ИСТИНА)");
		
	Иначе
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтатусыНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже
		|ПОМЕСТИТЬ СтатусыНоменклатуры
		|ИЗ
		|	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&Дата, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	СегментОрганизации.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ТаблицаНоменклатуры
		|ИЗ
		|	РегистрСведений.НоменклатураСегмента КАК СегментОрганизации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК СегментСотрудника
		|		ПО СегментОрганизации.Номенклатура = СегментСотрудника.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ СтатусыНоменклатуры КАК СтатусыНоменклатуры
		|		ПО СегментОрганизации.Номенклатура = СтатусыНоменклатуры.Номенклатура
		|ГДЕ
		|	НЕ СегментОрганизации.Номенклатура.ПометкаУдаления
		|	И СегментОрганизации.Сегмент = &СегментОрганизации
		|	И СегментСотрудника.Сегмент = &СегментСотрудника
		|	И ЕСТЬNULL(СтатусыНоменклатуры.ВПродаже, ИСТИНА)");
		
		Запрос.УстановитьПараметр("СегментОрганизации", СегментОрганизации);
		Запрос.УстановитьПараметр("СегментСотрудника" , СегментСотрудника);
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Дата"              , Дата);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("КонтрагентСегмента", ?(ЗначениеЗаполнено(Клиент), Клиент, Неопределено));
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
КонецФункции

