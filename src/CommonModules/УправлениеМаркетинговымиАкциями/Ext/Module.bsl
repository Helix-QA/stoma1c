			КонецЕсли;
			
			Если ТабличнаяЧастьУслуги <> Неопределено Тогда
				НайденныеСтроки = ТабличнаяЧастьУслуги.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТЧ.КлючСтроки)); 				
				Если НайденныеСтроки.Количество() <> 0 Тогда
					НайденнаяСтрока = НайденныеСтроки[0];        
					Если СтрокаТЧ.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
						СтрокаТЧ.СуммаСкидки = (НайденнаяСтрока.Сумма - НайденнаяСтрока.СуммаРучнойСкидки - НайденнаяСтрока.СуммаАвтоматическойСкидкиНаценки) * СтрокаТЧ.ЗначениеСкидкиНаценки / 100;
						СтрокаТЧ.СуммаСкидки = ?(СтрокаТЧ.СуммаСкидки < 0, 0, СтрокаТЧ.СуммаСкидки);
					ИначеЕсли СтрокаТЧ.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма Тогда
						СтрокаТЧ.СуммаСкидки = СтрокаТЧ.ЗначениеСкидкиНаценки;					
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;   
			
		КонецЕсли;	
	
    КонецЦикла;

КонецПроцедуры

// Функция, возвращает таблицу возможных оплат бонусами.
//
Функция ЗапросПоОплатеБонусами(
	ДокументОбъект, 
	Знач ТабличнаяЧастьЗапасы,
	Знач ТабличнаяЧастьЛечение,
	Знач ТабличнаяЧастьУслуги,
	Знач ТабличнаяЧастьСкидкиНаценки, 
	СтруктураПараметров = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
		ТабличнаяЧастьЗапасы.Колонки.Добавить("КлючСтрокиСтрокой", Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
		Для Каждого СтрокаТЗ Из ТабличнаяЧастьЗапасы Цикл
			СтрокаТЗ.КлючСтрокиСтрокой = Строка(СтрокаТЗ.КлючСтроки);
		КонецЦикла;
	КонецЕсли;
	Если ТабличнаяЧастьЛечение <> Неопределено Тогда
		ТабличнаяЧастьЛечение.Колонки.Добавить("КлючСтрокиСтрокой", Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
		Для Каждого СтрокаТЗ Из ТабличнаяЧастьЛечение Цикл
			СтрокаТЗ.КлючСтрокиСтрокой = Строка(СтрокаТЗ.КлючСтроки);
		КонецЦикла;
	КонецЕсли;
	Если ТабличнаяЧастьУслуги <> Неопределено Тогда
		ТабличнаяЧастьУслуги.Колонки.Добавить("КлючСтрокиСтрокой", Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
		Для Каждого СтрокаТЗ Из ТабличнаяЧастьУслуги Цикл
			СтрокаТЗ.КлючСтрокиСтрокой = Строка(СтрокаТЗ.КлючСтроки);
		КонецЦикла;
	КонецЕсли;   
	
	Если ТабличнаяЧастьСкидкиНаценки.Колонки.Найти("КлючСтрокиСтрокой") = Неопределено Тогда
		ТабличнаяЧастьСкидкиНаценки.Колонки.Добавить("КлючСтрокиСтрокой", Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(50)));
	КонецЕсли;
	Для Каждого СтрокаТЗ Из ТабличнаяЧастьСкидкиНаценки Цикл
		СтрокаТЗ.КлючСтрокиСтрокой = Строка(СтрокаТЗ.КлючСтроки);
	КонецЦикла;
	
	Если СтруктураПараметров <> Неопределено Тогда
		Дата 		   = СтруктураПараметров.Дата;
		ДокументСсылка = СтруктураПараметров.ДокументСсылка;
	Иначе
		Дата 		   = ?(ДокументОбъект.Ссылка.Пустая() = Истина, ТекущаяДатаСеанса(), ДокументОбъект.Дата);
		ДокументСсылка = ДокументОбъект.Ссылка;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Если ТабличнаяЧастьЗапасы  <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаЗапасы"	, ТабличнаяЧастьЗапасы)  КонецЕсли;
	Если ТабличнаяЧастьЛечение <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаЛечения" , ТабличнаяЧастьЛечение) КонецЕсли;
	Если ТабличнаяЧастьУслуги  <> Неопределено Тогда Запрос.УстановитьПараметр("ТаблицаУслуг"	, ТабличнаяЧастьУслуги)  КонецЕсли;

	ЕстьКолонкаКоличествоУпаковокТЧЛечение = Ложь;
	Если ТабличнаяЧастьЛечение <> Неопределено Тогда 
		Если ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Найти("Лечение") <> Неопределено Тогда
			ЕстьКолонкаКоличествоУпаковокТЧЛечение = ДокументОбъект.Ссылка.Метаданные().ТабличныеЧасти.Лечение.Реквизиты.Найти("КоличествоУпаковок") <> Неопределено;
		КонецЕсли;
	КонецЕсли;
		
	СтрокаОбъединение = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";	
	
	СтрокаРазделение = "
	|
	|;
	|///////////////////////////////////////////
	|";   	
	
	СтрокаПоместить = "	
	|ПОМЕСТИТЬ ТаблицаТовары
	|";	 
	
	МассивТекст = Новый Массив;
	
	// добавляем во временные таблицы. 	
	Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
		Текст = 	
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЗапасы.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
		|	ТаблицаЗапасы.НомерСтроки КАК НомерСтроки,
		|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|	ТаблицаЗапасы.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ТаблицаЗапасы.Упаковка КАК Упаковка,
		|	ТаблицаЗапасы.Количество КАК Количество,
		|	ТаблицаЗапасы.ВидЦен КАК ВидЦен,
		|	ТаблицаЗапасы.Цена КАК Цена,
		|	ТаблицаЗапасы.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТаблицаЗапасы.Сумма КАК Сумма				
		|ПОМЕСТИТЬ ТаблицаЗапасы
		|ИЗ
		|	&ТаблицаЗапасы КАК ТаблицаЗапасы";	
		
		МассивТекст.Добавить(Текст);
	КонецЕсли;
	
	Если ТабличнаяЧастьЛечение <> Неопределено Тогда
		
		Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаРазделение);
		КонецЕсли;             		
		
		Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЛечения.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
		|	ТаблицаЛечения.НомерСтроки КАК НомерСтроки,
		|	ТаблицаЛечения.Номенклатура КАК Номенклатура,"
		+ ?(ЕстьКолонкаКоличествоУпаковокТЧЛечение = Истина, 
			" ТаблицаЛечения.КоличествоУпаковок КАК КоличествоУпаковок,", 
			" ТаблицаЛечения.Количество КАК КоличествоУпаковок,")	
		+ "
		|	ТаблицаЛечения.Упаковка КАК Упаковка,
		|	ТаблицаЛечения.Количество КАК Количество,
		|	ТаблицаЛечения.ВидЦен КАК ВидЦен,
		|	ТаблицаЛечения.Цена КАК Цена,
		|	ТаблицаЛечения.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТаблицаЛечения.Сумма КАК Сумма
		|ПОМЕСТИТЬ ТаблицаЛечения
		|ИЗ
		|	&ТаблицаЛечения КАК ТаблицаЛечения";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;
	
	Если ТабличнаяЧастьУслуги <> Неопределено Тогда
		
		Если ТабличнаяЧастьЗапасы <> Неопределено 
			Или ТабличнаяЧастьЛечение <> Неопределено Тогда
			
			МассивТекст.Добавить(СтрокаРазделение);
		КонецЕсли;     
		
		Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаУслуг.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
		|	ТаблицаУслуг.НомерСтроки КАК НомерСтроки,
		|	ТаблицаУслуг.Номенклатура КАК Номенклатура,
		|	ТаблицаУслуг.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ТаблицаУслуг.Упаковка КАК Упаковка,
		|	ТаблицаУслуг.Количество КАК Количество,
		|	ТаблицаУслуг.ВидЦен КАК ВидЦен,
		|	ТаблицаУслуг.Цена КАК Цена,
		|	ТаблицаУслуг.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТаблицаУслуг.Сумма КАК Сумма
		|ПОМЕСТИТЬ ТаблицаУслуг
		|ИЗ
		|	&ТаблицаУслуг КАК ТаблицаУслуг";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;   
	
	// формируем запрос "объединение".
	МассивТекст.Добавить(СтрокаРазделение);
	Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЗапасы.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
		|	ТаблицаЗапасы.НомерСтроки КАК НомерСтроки,
		|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|	ТаблицаЗапасы.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ТаблицаЗапасы.Упаковка КАК Упаковка,
		|	ТаблицаЗапасы.Количество КАК Количество,
		|	ТаблицаЗапасы.ВидЦен КАК ВидЦен,
		|	ТаблицаЗапасы.Цена КАК Цена,
		|	ТаблицаЗапасы.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТаблицаЗапасы.Сумма КАК Сумма		
		|ПОМЕСТИТЬ ТаблицаТовары
		|ИЗ
		|	ТаблицаЗапасы КАК ТаблицаЗапасы";
		
		МассивТекст.Добавить(Текст);
	КонецЕсли;
	   	
	Если ТабличнаяЧастьЛечение <> Неопределено Тогда
		
		Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаОбъединение);
		КонецЕсли;  
		
		Текст =
		"ВЫБРАТЬ " + ?(ТабличнаяЧастьЗапасы = Неопределено, "РАЗРЕШЕННЫЕ", "") + " 
		|	ТаблицаЛечения.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
		|	ТаблицаЛечения.НомерСтроки КАК НомерСтроки,
		|	ТаблицаЛечения.Номенклатура КАК Номенклатура,
		|	ТаблицаЛечения.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ТаблицаЛечения.Упаковка КАК Упаковка,
		|	ТаблицаЛечения.Количество КАК Количество,
		|	ТаблицаЛечения.ВидЦен КАК ВидЦен,
		|	ТаблицаЛечения.Цена КАК Цена,
		|	ТаблицаЛечения.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТаблицаЛечения.Сумма КАК Сумма"
		+ ?(ТабличнаяЧастьЗапасы = Неопределено, СтрокаПоместить, "")	
		+ "
		|ИЗ
		|	ТаблицаЛечения КАК ТаблицаЛечения";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;
	
	Если ТабличнаяЧастьУслуги <> Неопределено Тогда
		
		Если ТабличнаяЧастьЗапасы <> Неопределено 
			Или ТабличнаяЧастьЛечение <> Неопределено Тогда
			МассивТекст.Добавить(СтрокаОбъединение);
		КонецЕсли;  
		
		Текст =
		"ВЫБРАТЬ " + ?(ТабличнаяЧастьЗапасы = Неопределено и ТабличнаяЧастьЛечение = Неопределено, "РАЗРЕШЕННЫЕ", "") + " 
		|	ТаблицаУслуг.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
		|	ТаблицаУслуг.НомерСтроки КАК НомерСтроки,
		|	ТаблицаУслуг.Номенклатура КАК Номенклатура,
		|	ТаблицаУслуг.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ТаблицаУслуг.Упаковка КАК Упаковка,
		|	ТаблицаУслуг.Количество КАК Количество,
		|	ТаблицаУслуг.ВидЦен КАК ВидЦен,
		|	ТаблицаУслуг.Цена КАК Цена,
		|	ТаблицаУслуг.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТаблицаУслуг.Сумма КАК Сумма"   
		+ ?(ТабличнаяЧастьЗапасы = Неопределено И ТабличнаяЧастьЛечение = Неопределено, СтрокаПоместить, "")	
		+ "
		|ИЗ
		|	ТаблицаУслуг КАК ТаблицаУслуг";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;   	
	
	ТекстЗапроса = СтрСоединить(МассивТекст, Символы.ПС);	
	
	Запрос.Текст = ТекстЗапроса + СтрокаРазделение +
	// "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	//|	ТаблицаТовары.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
	//|	ТаблицаТовары.НомерСтроки КАК НомерСтроки,
	//|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	//|	ТаблицаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	//|	ТаблицаТовары.Упаковка КАК Упаковка,
	//|	ТаблицаТовары.Количество КАК Количество,
	//|	ТаблицаТовары.ВидЦен КАК ВидЦен,
	//|	ТаблицаТовары.Цена КАК Цена,
	//|	ТаблицаТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	//|	ТаблицаТовары.Сумма КАК Сумма
	//|ПОМЕСТИТЬ ТаблицаТовары
	//|ИЗ
	//|	&ТаблицаТовары КАК ТаблицаТовары
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаСкидкиНаценки.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
	|	ТаблицаСкидкиНаценки.НомерСтроки КАК НомерСтроки,
	|	ТаблицаСкидкиНаценки.СкидкаНаценка КАК СкидкаНаценка,
	|	ТаблицаСкидкиНаценки.ПризнакОплатыБонусом КАК ПризнакОплатыБонусом,
	|	ТаблицаСкидкиНаценки.Сумма КАК Сумма
	|ПОМЕСТИТЬ ТаблицаСкидкиНаценки
	|ИЗ
	|	&ТаблицаСкидкиНаценки КАК ТаблицаСкидкиНаценки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	&Получатель КАК Получатель
	|ПОМЕСТИТЬ ТаблицаВладельцевБонусногоСчета
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	&КартаКонтрагента
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	РодственныеСвязи.Родственник
	|ИЗ
	|	РегистрСведений.РодственныеСвязи КАК РодственныеСвязи
	|ГДЕ
	|	РодственныеСвязи.Контрагент = &Получатель
	|	И РодственныеСвязи.ОбщийБонусныйСчет
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Получатель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БонусныеСчетаОстатки.БонусныйСчет КАК БонусныйСчет,
	|	БонусныеСчетаОстатки.БонусныйСчет.НеОграниченПроцентомСписания КАК НеОграниченПроцентомСписания,
	|	БонусныеСчетаОстатки.БонусныйСчет.ОграничениеСписанияПроцент КАК ОграничениеСписанияПроцент,
	|	СУММА(БонусныеСчетаОстатки.СуммаОборот) КАК СуммаОстаток
	|ПОМЕСТИТЬ ТаблицаБонусныеСчетаОстатки
	|ИЗ
	|	РегистрНакопления.БонусныеСчета.ОстаткиИОбороты(
	|			,
	|			&Дата,
	|			Авто,
	|			,
	|			БонусныйСчет.ВладелецБонусногоСчета В
	|				(ВЫБРАТЬ
	|					ТаблицаВладельцевБонусногоСчета.Получатель
	|				ИЗ
	|					ТаблицаВладельцевБонусногоСчета)) КАК БонусныеСчетаОстатки
	|ГДЕ
	|	БонусныеСчетаОстатки.Регистратор <> &ДокументСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|	БонусныеСчетаОстатки.БонусныйСчет,
	|	БонусныеСчетаОстатки.БонусныйСчет.НеОграниченПроцентомСписания,
	|	БонусныеСчетаОстатки.БонусныйСчет.ОграничениеСписанияПроцент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БонусныеСчетаТоварыОстатки.НомерСтроки КАК НомерСтроки,
	|	БонусныеСчетаТоварыОстатки.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
	|	БонусныеСчетаТоварыОстатки.НоменклатураСкидки КАК НоменклатураСкидки,
	|	БонусныеСчетаТоварыОстатки.КоличествоУпаковок КАК КоличествоУпаковок,
	|	БонусныеСчетаТоварыОстатки.Упаковка КАК Упаковка,
	|	БонусныеСчетаТоварыОстатки.Количество КАК Количество,
	|	БонусныеСчетаТоварыОстатки.ВидЦен КАК ВидЦен,
	|	БонусныеСчетаТоварыОстатки.Цена КАК Цена,
	|	БонусныеСчетаТоварыОстатки.Сумма КАК Сумма,
	|	ВЫБОР
	|		КОГДА БонусныеСчетаТоварыОстатки.СуммаДляРасчетаБонусов < 0
	|			ТОГДА 0
	|		ИНАЧЕ БонусныеСчетаТоварыОстатки.СуммаДляРасчетаБонусов
	|	КОНЕЦ КАК СуммаДляРасчетаБонусов,
	|	БонусныеСчетаТоварыОстатки.БонусныйСчет КАК БонусныйСчет,
	|	БонусныеСчетаТоварыОстатки.НеОграниченПроцентомСписания КАК НеОграниченПроцентомСписания,
	|	БонусныеСчетаТоварыОстатки.ОграничениеСписанияПроцент КАК ОграничениеСписанияПроцент,
	|	БонусныеСчетаТоварыОстатки.СуммаОстаток КАК СуммаОстаток,
	|	ВЫБОР
	|		КОГДА БонусныеСчетаТоварыОстатки.СуммаОстаток <= БонусныеСчетаТоварыОстатки.МаксимальнаяСуммаОплаты
	|			ТОГДА БонусныеСчетаТоварыОстатки.СуммаОстаток
	|		ИНАЧЕ ЕСТЬNULL(БонусныеСчетаТоварыОстатки.МаксимальнаяСуммаОплаты, 0)
	|	КОНЕЦ КАК МаксимальнаяСуммаОплаты
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		ТаблицаТовары.НомерСтроки КАК НомерСтроки,
	|		ТаблицаТовары.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
	|		ТаблицаТовары.Номенклатура КАК НоменклатураСкидки,
	|		ТаблицаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|		ТаблицаТовары.Упаковка КАК Упаковка,
	|		ТаблицаТовары.Количество КАК Количество,
	|		ТаблицаТовары.ВидЦен КАК ВидЦен,
	|		ТаблицаТовары.Цена КАК Цена,
	|		ТаблицаТовары.Сумма КАК Сумма,
	|		ТаблицаТовары.КоличествоУпаковок * ТаблицаТовары.Цена - ЕСТЬNULL(ТаблицаСкидкиНаценки.СуммаСкидки, 0) - ТаблицаТовары.СуммаРучнойСкидки КАК СуммаДляРасчетаБонусов,
	|		БонусныеСчетаОстатки.БонусныйСчет КАК БонусныйСчет,
	|		БонусныеСчетаОстатки.БонусныйСчет.НеОграниченПроцентомСписания КАК НеОграниченПроцентомСписания,
	|		БонусныеСчетаОстатки.БонусныйСчет.ОграничениеСписанияПроцент КАК ОграничениеСписанияПроцент,
	|		БонусныеСчетаОстатки.СуммаОстаток КАК СуммаОстаток,
	|		ВЫБОР
	|			КОГДА ТаблицаТовары.КоличествоУпаковок * ТаблицаТовары.Цена - ЕСТЬNULL(ТаблицаСкидкиНаценки.СуммаСкидки, 0) - ЕСТЬNULL(ТаблицаТовары.СуммаРучнойСкидки, 0) < 0
	|				ТОГДА 0
	|			ИНАЧЕ ТаблицаТовары.КоличествоУпаковок * ТаблицаТовары.Цена - ЕСТЬNULL(ТаблицаСкидкиНаценки.СуммаСкидки, 0) - ЕСТЬNULL(ТаблицаТовары.СуммаРучнойСкидки, 0)
	|		КОНЕЦ * ВЫБОР
	|			КОГДА БонусныеСчетаОстатки.БонусныйСчет.ВидБонусногоСчета.НеОграниченПроцентомСписания = ИСТИНА
	|				ТОГДА 1
	|			ИНАЧЕ БонусныеСчетаОстатки.БонусныйСчет.ВидБонусногоСчета.ОграничениеСписанияПроцент / 100
	|		КОНЕЦ КАК МаксимальнаяСуммаОплаты
	|	ИЗ
	|		ТаблицаТовары КАК ТаблицаТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				ТаблицаСкидкиНаценки.КлючСтрокиСтрокой КАК КлючСтрокиСтрокой,
	|				СУММА(ТаблицаСкидкиНаценки.Сумма) КАК СуммаСкидки
	|			ИЗ
	|				ТаблицаСкидкиНаценки КАК ТаблицаСкидкиНаценки
	|			ГДЕ
	|				ТаблицаСкидкиНаценки.ПризнакОплатыБонусом = ЛОЖЬ
	|				И ВЫРАЗИТЬ(ТаблицаСкидкиНаценки.СкидкаНаценка КАК Справочник.СкидкиНаценки).СпособПредоставленияСкидки <> ЗНАЧЕНИЕ(Перечисление.СпособПредоставленияСкидки.ВидЦен)
	|				И ВЫРАЗИТЬ(ТаблицаСкидкиНаценки.СкидкаНаценка КАК Справочник.СкидкиНаценки).НачислениеБонусами = ЛОЖЬ
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ТаблицаСкидкиНаценки.КлючСтрокиСтрокой) КАК ТаблицаСкидкиНаценки
	|			ПО (ТаблицаСкидкиНаценки.КлючСтрокиСтрокой = ТаблицаТовары.КлючСтрокиСтрокой)
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаБонусныеСчетаОстатки КАК БонусныеСчетаОстатки
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыБонусныхСчетов.ПакетУслугСоставУслуг КАК ОграничениеПоУслугамСегментамБонусныеСчета
	|				ПО (ОграничениеПоУслугамСегментамБонусныеСчета.Ссылка = БонусныеСчетаОстатки.БонусныйСчет.ВидБонусногоСчета)
	|			ПО (БонусныеСчетаОстатки.СуммаОстаток >= 0)
	|				И (ВЫБОР
	|					КОГДА ТИПЗНАЧЕНИЯ(ОграничениеПоУслугамСегментамБонусныеСчета.УслугаСегмент) = ТИП(Справочник.Номенклатура)
	|						ТОГДА ТаблицаТовары.Номенклатура = ОграничениеПоУслугамСегментамБонусныеСчета.УслугаСегмент
	|					КОГДА ТИПЗНАЧЕНИЯ(ОграничениеПоУслугамСегментамБонусныеСчета.УслугаСегмент) = ТИП(Справочник.СегментыНоменклатуры)
	|						ТОГДА (ТаблицаТовары.Номенклатура, ОграничениеПоУслугамСегментамБонусныеСчета.УслугаСегмент) В
	|								(ВЫБРАТЬ
	|									СоставСегментов.Номенклатура,
	|									СоставСегментов.Сегмент
	|								ИЗ
	|									РегистрСведений.НоменклатураСегмента КАК СоставСегментов)
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ)
	|				И (ВЫБОР
	|					КОГДА ТИПЗНАЧЕНИЯ(ОграничениеПоУслугамСегментамБонусныеСчета.ВидЦены) = ТИП(Справочник.ВидыЦен)
	|							И ОграничениеПоУслугамСегментамБонусныеСчета.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|						ТОГДА ТаблицаТовары.ВидЦен = ОграничениеПоУслугамСегментамБонусныеСчета.ВидЦены
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ)) КАК БонусныеСчетаТоварыОстатки";
	
	Запрос.УстановитьПараметр("Дата"				, Дата);
	Запрос.УстановитьПараметр("ДокументСсылка"		, ДокументСсылка);
	Запрос.УстановитьПараметр("Получатель"			, ДокументОбъект.Контрагент);
	Запрос.УстановитьПараметр("КартаКонтрагента"	, ДокументОбъект.КартаКонтрагента);
	Запрос.УстановитьПараметр("ТаблицаТовары"		, ТабличнаяЧастьЗапасы);
	Запрос.УстановитьПараметр("ТаблицаСкидкиНаценки", ТабличнаяЧастьСкидкиНаценки.Скопировать(Новый Структура("Контрагент", ДокументОбъект.Контрагент)));
		
	ТаблицаОплатаБонусами = Запрос.Выполнить().Выгрузить();
	
	ТаблицаОплатаБонусами.Колонки.Добавить("КлючСтроки", Новый ОписаниеТипов("УникальныйИдентификатор"));
	Для Каждого СтрокаТЗ Из ТаблицаОплатаБонусами Цикл
		// НайденнаяСтрока = ТабличнаяЧастьЗапасы.Найти(СтрокаТЗ.НомерСтроки, "НомерСтроки"); 
		НайденнаяСтрока = Неопределено;
		Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
			НайденнаяСтрока = ТабличнаяЧастьЗапасы.Найти(СтрокаТЗ.КлючСтрокиСтрокой, "КлючСтрокиСтрокой"); 
		КонецЕсли;
		Если НайденнаяСтрока = Неопределено И ТабличнаяЧастьЛечение <> Неопределено Тогда
			НайденнаяСтрока = ТабличнаяЧастьЛечение.Найти(СтрокаТЗ.КлючСтрокиСтрокой, "КлючСтрокиСтрокой"); 	
		КонецЕсли;
		Если НайденнаяСтрока = Неопределено И ТабличнаяЧастьУслуги <> Неопределено Тогда
			НайденнаяСтрока = ТабличнаяЧастьУслуги.Найти(СтрокаТЗ.КлючСтрокиСтрокой, "КлючСтрокиСтрокой"); 	
		КонецЕсли;     

		Если НайденнаяСтрока = Неопределено Тогда
			Продолжить;
		КонецЕсли;       		
		СтрокаТЗ.КлючСтроки = Новый УникальныйИдентификатор(НайденнаяСтрока.КлючСтрокиСтрокой);
		Если ЗначениеЗаполнено(СтрокаТЗ.ВидЦен) Тогда
			ПараметрыОкругления					= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаТЗ.ВидЦен, 
														"ПорядокОкругления, ОкруглятьВБольшуюСторону");
			СтрокаТЗ.МаксимальнаяСуммаОплаты	= ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(
														СтрокаТЗ.МаксимальнаяСуммаОплаты, 
														ПараметрыОкругления.ПорядокОкругления, 
														ПараметрыОкругления.ОкруглятьВБольшуюСторону);
		КонецЕсли;
	КонецЦикла; 
	
	Возврат ТаблицаОплатаБонусами;
	
КонецФункции

// Заполняет таблицу подарки по скидкам
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  ТабличнаяЧастьПодарки - табличная часть "Подарки" документа.
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//
Процедура РасчитатьПрименитьОплатуБонусами(ТаблицаСкидок, ТаблицаВозможнаяОплатаТоваровБонусами, ТаблицаОплатыБонусами)

	Если ТаблицаСкидок.Колонки.Найти("КлючСтрокиСтрокой") = Неопределено Тогда
		ТаблицаСкидок.Колонки.Добавить("КлючСтрокиСтрокой", Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(50)));
	КонецЕсли;
		
	Для Каждого СтрокаОплатыБонусом Из ТаблицаОплатыБонусами Цикл
		
		// Надо в случае нескольких бонусных счетов, для учета оплаты другими бонусными счетами.
		ТаблицаПримененныхБонусныхСчетов = ТаблицаСкидок.Скопировать(Новый Структура("ПризнакОплатыБонусом, Использовать", Истина, Истина));
		СуммаОплаченнаяБонуснымиСчетами  = ТаблицаПримененныхБонусныхСчетов.Итог("СуммаСкидки");
		
		// в ТаблицаВозможнаяОплатаТоваровБонусами отнимаем бонусы примененные ранее.
		Если СуммаОплаченнаяБонуснымиСчетами > 0 Тогда
			Для Каждого СтрокаТЗ Из ТаблицаВозможнаяОплатаТоваровБонусами.НайтиСтроки(Новый Структура("БонусныйСчет", СтрокаОплатыБонусом.БонусныйСчет)) Цикл
				МассивСтрокПримененныхБонусныхСчетов = ТаблицаПримененныхБонусныхСчетов.НайтиСтроки(Новый Структура("КлючСтрокиСтрокой, ПризнакОплатыБонусом, Использовать", СтрокаТЗ.КлючСтрокиСтрокой, Истина, Истина));
				Для Каждого СтрокаМ Из МассивСтрокПримененныхБонусныхСчетов Цикл
					 СтрокаТЗ.СуммаДляРасчетаБонусов = СтрокаТЗ.СуммаДляРасчетаБонусов - СтрокаМ.СуммаСкидки;					
				КонецЦикла;			
			КонецЦикла;
		КонецЕсли; 
		
		ОплатаТоваровПоБонусномуСчету = ТаблицаВозможнаяОплатаТоваровБонусами.НайтиСтроки(Новый Структура("БонусныйСчет", СтрокаОплатыБонусом.БонусныйСчет));
		
		СуммаВсегоТоваровПоБонусномуСчету = 0;
		СуммаРаспределенная				  = 0;
		Для Каждого СтрокаРаспределенияБонусовПоТоварам Из ОплатаТоваровПоБонусномуСчету Цикл
			СуммаВсегоТоваровПоБонусномуСчету = СуммаВсегоТоваровПоБонусномуСчету + СтрокаРаспределенияБонусовПоТоварам.СуммаДляРасчетаБонусов;
		КонецЦикла;
		
		СуммаВсегоТоваровПоБонусномуСчету = СуммаВсегоТоваровПоБонусномуСчету;
			
		Если СуммаВсегоТоваровПоБонусномуСчету > 0 Тогда
			Для Каждого СтрокаРаспределенияБонусовПоТоварам Из ОплатаТоваровПоБонусномуСчету Цикл
				
				СуммаОплаты = СтрокаОплатыБонусом.Сумма * СтрокаРаспределенияБонусовПоТоварам.СуммаДляРасчетаБонусов / СуммаВсегоТоваровПоБонусномуСчету;				
				
				СуммаОплаты = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(СуммаОплаты, СтрокаРаспределенияБонусовПоТоварам.ВидЦен.ПорядокОкругления, СтрокаРаспределенияБонусовПоТоварам.ВидЦен.ОкруглятьВБольшуюСторону);
				    				
				// устраняем погрешности округления.
				Если СтрокаРаспределенияБонусовПоТоварам = ОплатаТоваровПоБонусномуСчету[ОплатаТоваровПоБонусномуСчету.Количество()-1] 
						И (СуммаРаспределенная + СуммаОплаты) <> СтрокаОплатыБонусом.Сумма Тогда
						
					ПогрешностьРаспределения	= СтрокаОплатыБонусом.Сумма - (СуммаРаспределенная + СуммаОплаты);
					СуммаОплаты					= СуммаОплаты + ПогрешностьРаспределения; 
				КонецЕсли;
			
				Если СуммаОплаты > 0 Тогда
					НоваяСтрока = ТаблицаСкидок.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРаспределенияБонусовПоТоварам);
					НоваяСтрока.Номенклатура			= СтрокаРаспределенияБонусовПоТоварам.НоменклатураСкидки;
					НоваяСтрока.НачислениеБонусами		= Ложь;
					НоваяСтрока.ПризнакОплатыБонусом	= Истина;
					НоваяСтрока.Использовать			= Истина;
					НоваяСтрока.СуммаСкидки				= СуммаОплаты;
				
					СуммаРаспределенная					= СуммаРаспределенная + СуммаОплаты;
					СтрокаОплатыБонусом.СуммаОстаток	= СтрокаОплатыБонусом.СуммаОстаток - СуммаОплаты;
					
					НоваяСтрока.КлючСтрокиСтрокой		= Строка(НоваяСтрока.КлючСтроки);
				КонецЕсли;
			
			КонецЦикла;
		КонецЕсли;
			
	КонецЦикла;	
	
	ТаблицаСкидок.Колонки.Удалить("КлючСтрокиСтрокой");
	
КонецПроцедуры
                
// Функция рассчиттывает значение скидки по строке
//
// Параметры:
//  СтрокаСкидки - Строка информации о скидке
//  СтрокаТоваров - Строка табличной части Товары
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//  СуммаБезСкидки - Число, сумма от которой рассчитавается скидка;
//
// Возвращаемое значение:
//  Скидка - сумма скидки
//
Функция РассчитатьЗначениеСкидки(СтрокаСкидки, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента, СуммаБезСкидки)

	Скидка = 0;
	Если СтрокаСкидки.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
		Скидка = СуммаБезСкидки * СтрокаСкидки.ЗначениеСкидкиНаценки/100;
	ИначеЕсли СтрокаСкидки.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма Тогда
		Скидка = Мин(СуммаБезСкидки,СтрокаСкидки.ЗначениеСкидкиНаценки);
	КонецЕсли;
	               
	Возврат Скидка;

КонецФункции // РассчитатьЗначениеСкидки()

// Рекурсивно обходит дерево и рассчитывает скидки
//
// Параметры:
//  СтрокиДерева  - Массив скидок, по которым выполнилось условие
//  ВариантСовместногоПримененияСкидокНаценок - Вариант совместного применения
//  Корень - Булево. Признак верхнего уровня
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//
// Возвращаемое значение:
//  Сумма скидки
//
Функция ПолучитьРассчитатьСкидкиВДереве(СтрокиДерева, ВариантСовместногоПримененияСкидокНаценок, Корень, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента)
	
	Скидка = 0;
	
	Для каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоГруппа Тогда
			СтрокаДерева.Значение = ПолучитьРассчитатьСкидкиВДереве(СтрокаДерева.Строки, СтрокаДерева.ВариантСовместногоПримененияСкидокНаценок, Ложь, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента)
		Иначе
			Если ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Умножение 
				И СтрокаДерева.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
				СтрокаДерева.Значение = 0;
			Иначе
				СтрокаДерева.Значение = РассчитатьЗначениеСкидки(СтрокаДерева, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента, 
							?(СтрокаДерева.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма, СтрокаДерева.ЗначениеСкидкиНаценки, СтрокаТоваров.СуммаБезСкидки));
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Минимум Тогда
		СтрокиДерева.Сортировать("ЗначениеСкидкиНаценкиОбщаяСумма Возр, Значение Возр");
		Скидка = СтрокиДерева[0].Значение;
		СтрокиДерева[0].Использование = Истина;
	ИначеЕсли ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум Тогда
		СтрокиДерева.Сортировать("ЗначениеСкидкиНаценкиОбщаяСумма Убыв, Значение Убыв");
		Скидка = СтрокиДерева[0].Значение;
		СтрокиДерева[0].Использование = Истина; 
	ИначеЕсли ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Сложение Тогда
		Скидка = СтрокиДерева.Итог("Значение");
		Для каждого СтрокаДерева Из СтрокиДерева Цикл
			СтрокаДерева.Использование = Истина;
		КонецЦикла;
	ИначеЕсли ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Умножение Тогда
		СтрокиДерева.Сортировать("ПорядокПрименения Возр");
		ИндексСтроки = 0;
		Для каждого СтрокаДерева Из СтрокиДерева Цикл
			Если СтрокаДерева.ЭтоГруппа Тогда
				Скидка = Скидка + СтрокаДерева.Значение;
			ИначеЕсли СтрокаДерева.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
				СтрокаДерева.Значение = РассчитатьЗначениеСкидки(СтрокаДерева, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента, СтрокаТоваров.СуммаБезСкидки-Скидка);
				Скидка = Скидка + СтрокаДерева.Значение;
			ИначеЕсли СтрокаДерева.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма Тогда
				Скидка = Скидка + СтрокаДерева.Значение;
			КонецЕсли;
			СтрокаДерева.Использование = Истина;
			ИндексСтроки = ИндексСтроки + 1;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Скидка;
	
КонецФункции // ПолучитьРассчитатьСкидкиВДереве()

// Заполняет таблицу, примененных скидок по дереву значений
//
// Параметры:
//  СтрокиДерева  - Массив скидок, по которым выполнилось условие
//  ТаблицаПримененныхСкидок - таблица, в которую помещаем примененные скидки
//
Процедура ЗаполнитьТаблицуПримененныхСкидок(СтрокиДерева, ТаблицаПримененныхСкидок, ТолькоПримененные = Истина)
	
	Для каждого СтрокаДерева Из СтрокиДерева Цикл
		Если ТолькоПримененные = Ложь ИЛИ СтрокаДерева.Использование = Истина Тогда
			Если СтрокаДерева.ЭтоГруппа Тогда
				ЗаполнитьТаблицуПримененныхСкидок(СтрокаДерева.Строки, ТаблицаПримененныхСкидок, ТолькоПримененные)
			Иначе
				СтрокаПримененнойСкидки = ТаблицаПримененныхСкидок.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаПримененнойСкидки, СтрокаДерева);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ЗаполнитьПримененныеСкидки()

// Рассчитывает значение сложной скидки
//
// Параметры
//  МассивСкидок  - Массив скидок, по которым выполнилось условие
//  СтрокаТоваров - Строка таблицы значений с данными из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором рассчитывается скидка
//  ДатаДокумента - Дата документа необходима для расчета скидки по цене
//
// Возвращаемое значение:
//  Сумма скидки
//
Функция РассчитатьЗначениеСложнойСкидки(ТаблицаСкидок, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента, ТаблицаПримененныхСкидок, ТаблицаРассчитанныхСкидок = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СкидкиНаценки.Ссылка КАК СкидкаНаценка,
	|	СкидкиНаценки.ВариантСовместногоПримененияСкидокНаценок,
	|	СкидкиНаценки.ПорядокПрименения,
	|	СкидкиНаценки.СпособПредоставленияСкидки,
	|	СкидкиНаценки.ЗначениеСкидкиНаценки,
	|	СкидкиНаценки.НачислениеНаЛицевойСчетУдалить,
	|	СкидкиНаценки.ЭтоГруппа,
	|	СкидкиНаценки.СегментНоменклатуры,
	|	0 КАК Значение,
	|	ЛОЖЬ КАК Использование,
	|	ЛОЖЬ КАК СкидкаНаЕдиныйКомплект,
	|	СкидкиНаценки.СегментБазыРасчетаСкидки,
	|	0 КАК ЗначениеСкидкиНаценкиОбщаяСумма
	|ИЗ
	|	Справочник.СкидкиНаценки КАК СкидкиНаценки
	|ГДЕ
	|	СкидкиНаценки.Ссылка В(&МассивСкидок)
	|ИТОГИ ПО
	|	СкидкаНаценка ИЕРАРХИЯ";
	
	Запрос.УстановитьПараметр("МассивСкидок", ТаблицаСкидок.ВыгрузитьКолонку("СкидкаНаценка"));
	
	Результат = Запрос.Выполнить();
	ДеревоПримененныхСкидок = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	Если Результат.Пустой() Тогда
		Значение = 0
	Иначе
		Значение = ПолучитьРассчитатьСкидкиВДереве(ДеревоПримененныхСкидок.Строки, Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Сложение, Истина, СтрокаТоваров, СтруктурнаяЕдиница, ДатаДокумента);
		Если Значение <> 0 Тогда
			ЗаполнитьТаблицуПримененныхСкидок(ДеревоПримененныхСкидок.Строки, ТаблицаПримененныхСкидок, Истина);
			Если ТаблицаРассчитанныхСкидок <> Неопределено Тогда
				ЗаполнитьТаблицуПримененныхСкидок(ДеревоПримененныхСкидок.Строки, ТаблицаРассчитанныхСкидок, Ложь);
			КонецЕсли;
			Если ТаблицаПримененныхСкидок.Количество() > 0 
				И ТаблицаПримененныхСкидок.Итог("Значение") <> Значение И ТаблицаПримененныхСкидок.Итог("Значение") <> 0 Тогда
				
				НомерМаксимальнойСтроки  = 0;
				МаксимальнаяСумма        = 0;
				
				СуммаТабличнойЧастиДоРаспределения = ТаблицаПримененныхСкидок.Итог("Значение");
				КоэффициентРаспределения = Значение / СуммаТабличнойЧастиДоРаспределения;
				
				Для каждого СтрокаТаблицыДокумента Из ТаблицаПримененныхСкидок Цикл
				
					Если МаксимальнаяСумма < СтрокаТаблицыДокумента.Сумма Тогда
						НомерМаксимальнойСтроки  = СтрокаТаблицыДокумента.НомерСтроки;
						МаксимальнаяСумма        = СтрокаТаблицыДокумента.Значение;
					КонецЕсли;
					
					СтрокаТаблицыДокумента.Значение = СтрокаТаблицыДокумента.Значение * КоэффициентРаспределения;
					
				КонецЦикла;
				
				СуммаТабличнойЧастиПослеРаспределения = ТаблицаПримененныхСкидок.Итог("Значение");
				
				ОшибкаОкругления = Значение - (СуммаТабличнойЧастиДоРаспределения - СуммаТабличнойЧастиПослеРаспределения);
				
				Если Не ОшибкаОкругления = 0 И НомерМаксимальнойСтроки >0 Тогда
					СтрокаТабличнойЧастиНоменклатуры          = ТаблицаПримененныхСкидок[НомерМаксимальнойСтроки - 1];
					СтрокаТабличнойЧастиНоменклатуры.Значение = СтрокаТабличнойЧастиНоменклатуры.Значение - ОшибкаОкругления;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции // РассчитатьЗначениеСложнойСкидки()

// Заполняет данными таблицы, табличнуб часть скидки
//
// Параметры
//  ТаблицаПримененныхСкидок - таблица, в которое находятся данные о примененных скидках
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//
Процедура ЗаполнитьТабличнуюЧастьСкидкиПоПроценту(ТаблицаПримененныхСкидок, ТабличнаяЧастьСкидки, КлючСтрокиТоваров, НоменклатураСтрокиТоваров)

	пТаблицаПримененныхСкидок = ТаблицаПримененныхСкидок.Скопировать();
	пТаблицаПримененныхСкидок.Колонки.Значение.Имя = "Сумма";
	пТаблицаПримененныхСкидок.Колонки.Добавить("КлючСтроки");
	пТаблицаПримененныхСкидок.ЗаполнитьЗначения(КлючСтрокиТоваров,"КлючСтроки");
	пТаблицаПримененныхСкидок.Колонки.Добавить("НоменклатураСкидки");
	пТаблицаПримененныхСкидок.ЗаполнитьЗначения(НоменклатураСтрокиТоваров,"НоменклатураСкидки");	
	
	ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(пТаблицаПримененныхСкидок, ТабличнаяЧастьСкидки);
	
КонецПроцедуры // ЗаполнитьТабличнуюЧастьСкидкиПоПроценту()

// Из общей таблицы возвращает таблицу подарков или скидок сумм на чек
//
// Параметры:
//  ТаблицаСкидок - таблица всех скидок
//  СкидкиПодарки - Булево, флга возврата или подарков или сумм на чек
//
// Возвращаемое значение:
//  Таблица значений
//
Функция НайтиВТаблицеПоСтруктуре(Таблица, СтруктураПоиска)

	ТаблицаРезультат	= Таблица.СкопироватьКолонки();
	
	МассивНайденныхСтрок = Таблица.НайтиСтроки(СтруктураПоиска);
	Для каждого ЭлементМассива Из МассивНайденныхСтрок Цикл
		НоваяСтрока = ТаблицаРезультат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМассива);
	КонецЦикла;
	
	Возврат ТаблицаРезультат;

КонецФункции // ОпределитьТаблицуПодарков()

// Удаляет скидку из таблицы
//
// Параметры
//  ТаблицаСкидок - таблица всех скидок
//  СкидкаНаценка - удаляемая скидка
//  Номенклатура - для скидок по строке удаляется только эта номенклатура
//
Процедура УдалитьСкидкуИзТаблицы(ТаблицаСкидок, СкидкаНаценка, Номенклатура = Неопределено)

	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("СкидкаНаценка", СкидкаНаценка);
	
	Если Не Номенклатура = Неопределено Тогда
		СтруктураПоиска.Вставить("Номенклатура", Номенклатура);
	КонецЕсли;
	
	СтрокиТаблицыСкидок = ТаблицаСкидок.НайтиСтроки(СтруктураПоиска);
	Для каждого СтрокаТаблицыСкидок Из СтрокиТаблицыСкидок Цикл
		ТаблицаСкидок.Удалить(СтрокаТаблицыСкидок);
	КонецЦикла;

КонецПроцедуры // УдалитьСкидкуИзТаблицы()

// Вытесняет строки в таблице скидок
//
// Параметры
//  ТаблицаСкидок - Таблица скидок, применяющихся скидок
//  СтрокиДерева  - Массив скидок, по которым выполнилось условие
//  ВариантСовместногоПримененияСкидокНаценок - Вариант совместного применения
//
Процедура ПрименитьВытеснениеВДереве(ТаблицаСкидок, СтрокиДерева, УдаляемВсеСтроки)
	
	ПерваяСтрока = Истина;
	
	Для каждого СтрокаДерева Из СтрокиДерева Цикл
		Если УдаляемВсеСтроки Тогда
			Если СтрокаДерева.ЭтоГруппа Тогда
				ПрименитьВытеснениеВДереве(ТаблицаСкидок, СтрокаДерева.Строки, Истина)
			ИначеЕсли СтрокаДерева.Строки[0].СкидкаНаГруппуСтрок Тогда
				УдалитьСкидкуИзТаблицы(ТаблицаСкидок, СтрокаДерева.СкидкаНаценка)
			Иначе
				// Скидка на строку
				УдалитьСкидкуИзТаблицы(ТаблицаСкидок, СтрокаДерева.СкидкаНаценка, СтрокаДерева.Строки[0].Номенклатура)
			КонецЕсли;
		Иначе
			ПерваяСтрока = Ложь;
			Если СтрокаДерева.ЭтоГруппа Тогда
				ПрименитьВытеснениеВДереве(ТаблицаСкидок, СтрокаДерева.Строки, УдаляемВсеСтроки)
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ПрименитьВытеснениеВДереве()

// Вытесняет скидки по правилам пересечения
//
// Параметры
//  ТаблицаСкидок - Таблица скидок, применяющихся скидок
//  ТаблицаНеПрименяемыхПодарков - Таблица подарков не прошедших условия.
//
Процедура ВытеснитьСкидкиНаСегментНоменклатуры(ТаблицаСкидок, ТаблицаНеПрименяемыхПодарков)

	// Удаляем не нужные скидки
	
	Для каждого СтрокаТаблицы Из ТаблицаНеПрименяемыхПодарков Цикл
		УдалитьСкидкуИзТаблицы(ТаблицаСкидок, СтрокаТаблицы.СкидкаНаценка)
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаСкидок.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(ТаблицаСкидок.СкидкаНаценка КАК Справочник.СкидкиНаценки) КАК СкидкаНаценка,
	|	ТаблицаСкидок.СкидкаСуммойНаЧек,
	|	ТаблицаСкидок.ЭтоПодарок
	|ПОМЕСТИТЬ ТаблицаСкидок
	|ИЗ
	|	&ТаблицаСкидок КАК ТаблицаСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ТаблицаСкидок.Номенклатура КАК Номенклатура
	|ИЗ
	|	ТаблицаСкидок КАК ТаблицаСкидок";
	
	Запрос.УстановитьПараметр("ТаблицаСкидок", ТаблицаСкидок);
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Результат = Запрос.Выполнить();
	ТаблицаНоменклатуры = Результат.Выгрузить();
	Для каждого СтрокаТаблицы Из ТаблицаНоменклатуры Цикл
	
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаСкидок.Номенклатура КАК Номенклатура,
		|	ТаблицаСкидок.СкидкаНаценка КАК СкидкаНаценка,
		|	ТаблицаСкидок.СкидкаНаценка.ЭтоГруппа КАК ЭтоГруппа,
		|	ВЫБОР
		|		КОГДА ТаблицаСкидок.СкидкаСуммойНаЧек
		|				ИЛИ ТаблицаСкидок.ЭтоПодарок
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК СкидкаНаГруппуСтрок,
		|	ТаблицаСкидок.СкидкаНаценка.ВариантСовместногоПримененияСкидокНаценок КАК ВариантСовместногоПримененияСкидокНаценок
		|ИЗ
		|	ТаблицаСкидок КАК ТаблицаСкидок
		|ГДЕ
		|	ТаблицаСкидок.Номенклатура = &Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТаблицаСкидок.СкидкаНаценка.ПорядокПрименения
		|ИТОГИ ПО
		|	СкидкаНаценка ИЕРАРХИЯ";
		
		Запрос.УстановитьПараметр("Номенклатура", СтрокаТаблицы.Номенклатура);
		
		Результат = Запрос.Выполнить();
		ДеревоВытеснения = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
		
		ПрименитьВытеснениеВДереве(ТаблицаСкидок, ДеревоВытеснения.Строки, Ложь)
	КонецЦикла;

КонецПроцедуры // ВытеснитьСкидкиНаСегментНоменклатуры()

// Рекурсивно обходит дерево и вытесянет скидки подарки
//
// Параметры:
//  СтрокиДерева  - Массив скидок, по которым выполнилось условие
//  ВариантСовместногоПримененияСкидокНаценок - Вариант совместного применения
//  Таблица скидок - Таблица значений скидки подарки
//
Процедура ПрименитьПравилаВытеснениеСкидокПодарковВДереве(СтрокиДерева, ВариантСовместногоПримененияСкидокНаценок, ТаблицаСкидок)

	Если ТаблицаСкидок.Количество()<= 1 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаВозможныхСкидок = Новый ТаблицаЗначений;
	ТаблицаВозможныхСкидок.Колонки.Добавить("ЭтоГруппа");
	ТаблицаВозможныхСкидок.Колонки.Добавить("СкидкаНаценка");
	ТаблицаВозможныхСкидок.Колонки.Добавить("ПорядокПрименения");
	
	Для каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоГруппа Тогда
			ПрименитьПравилаВытеснениеСкидокПодарковВДереве(СтрокаДерева.Строки, СтрокаДерева.ВариантСовместногоПримененияСкидокНаценок, ТаблицаСкидок);
		КонецЕсли;
		СтрокаТаблицыВозможныхСкидок = ТаблицаВозможныхСкидок.Добавить();
		СтрокаТаблицыВозможныхСкидок.ЭтоГруппа               = СтрокаДерева.ЭтоГруппа;
		СтрокаТаблицыВозможныхСкидок.СкидкаНаценка           = СтрокаДерева.СкидкаНаценка;
		СтрокаТаблицыВозможныхСкидок.ПорядокПрименения       = СтрокаДерева.ПорядокПрименения;
	КонецЦикла;
	
	Если ТаблицаВозможныхСкидок.Количество() > 1 Тогда
		Если ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Минимум
			ИЛИ ВариантСовместногоПримененияСкидокНаценок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум Тогда
			ТаблицаВозможныхСкидок.Сортировать("ПорядокПрименения Возр");
			
			МассивСкидок = ТаблицаВозможныхСкидок.ВыгрузитьКолонку("СкидкаНаценка");
			МассивСкидок.Удалить(0);
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ТаблицаСкидок.СкидкаНаценка,
			|	ТаблицаСкидок.УсловиеПредоставленияСкидки,
			|	ТаблицаСкидок.ЗначениеУсловия,
			|	ТаблицаСкидок.СегментНоменклатуры,
			|	ТаблицаСкидок.СкидкаНаЕдиныйКомплект,
			|	ТаблицаСкидок.ОбъектСкидки
			|ПОМЕСТИТЬ ТаблицаСкидок
			|ИЗ
			|	&ТаблицаСкидок КАК ТаблицаСкидок
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ТаблицаСкидок.СкидкаНаценка,
			|	ТаблицаСкидок.УсловиеПредоставленияСкидки,
			|	ТаблицаСкидок.ЗначениеУсловия,
			|	ТаблицаСкидок.СегментНоменклатуры,
			|	ТаблицаСкидок.СкидкаНаЕдиныйКомплект,
			|	ТаблицаСкидок.ОбъектСкидки
			|ИЗ
			|	ТаблицаСкидок КАК ТаблицаСкидок
			|ГДЕ
			|	(НЕ ТаблицаСкидок.СкидкаНаценка В ИЕРАРХИИ (&МассивСкидок))";
			
			Запрос.УстановитьПараметр("МассивСкидок" , МассивСкидок);
			Запрос.УстановитьПараметр("ТаблицаСкидок", ТаблицаСкидок);
			Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
			
			Результат = Запрос.Выполнить();
			
			ТаблицаСкидок = Результат.Выгрузить();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры // ПрименитьПравилаВытеснениеСкидокПодарковВДереве()

// Определяет по таблице скидок подарков количество подарков
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//  ТаблицаНеПрименяемыхПодарков - Таблица значений, служит для возврата не используемых подарков
//
Процедура ОпределитьКоличествоПодарков(ТаблицаСкидок, ТаблицаТоваров, СтруктурнаяЕдиница, ТаблицаНеПрименяемыхПодарков = Неопределено)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаТоваров.Номенклатура,
	|	ТаблицаТоваров.Количество,
	|	ТаблицаТоваров.Сумма,
	|	ТаблицаТоваров.НомерСтроки
	|ПОМЕСТИТЬ ТаблицаВЗапросе
	|ИЗ
	|	&ТаблицаТоваров КАК ТаблицаТоваров";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТаблицаТоваров);
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Результат = Запрос.Выполнить();
	
	ТаблицаСкидок.Колонки.Добавить("КоличествоПодарков", Новый ОписаниеТипов("Число"));
	
	ТаблицаПозиционныхСкидокПоКоличеству = ТаблицаСкидок.СкопироватьКолонки();
	Для каждого СтрокаТаблицыСкидок Из ТаблицаСкидок Цикл
		Если СтрокаТаблицыСкидок.СкидкаНаЕдиныйКомплект Тогда
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	МИНИМУМ(ВЫБОР
			|			КОГДА ЕСТЬNULL(ТаблицаВЗапросе.Количество, 0) = 0
			|					ИЛИ ТребуемыйКомплект.Количество = 0
			|				ТОГДА 0
			|			ИНАЧЕ ТаблицаВЗапросе.Количество / ТребуемыйКомплект.Количество 
			|		КОНЕЦ) КАК Количество
			|ИЗ
			|	(ВЫБРАТЬ
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Номенклатура КАК Номенклатура,
			|		СУММА(СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Количество) КАК Количество
			|	ИЗ
			|		Справочник.СкидкиНаценки.НаборПокупкиДляПолученияПодарков КАК СкидкиНаценкиНаборПокупкиДляПолученияПодарков
			|	ГДЕ
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Ссылка = &Ссылка
			|	
			|	СГРУППИРОВАТЬ ПО
			|		СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Номенклатура) КАК ТребуемыйКомплект
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаВЗапросе КАК ТаблицаВЗапросе
			|		ПО ТребуемыйКомплект.Номенклатура = ТаблицаВЗапросе.Номенклатура";
			
			Запрос.УстановитьПараметр("Ссылка" , СтрокаТаблицыСкидок.СкидкаНаценка);
			
			Результат = Запрос.Выполнить();
			Выборка = Результат.Выбрать();
			
			Если Выборка.Следующий() Тогда
				СтрокаТаблицыСкидок.КоличествоПодарков = Цел(Выборка.Количество);
			КонецЕсли;

		Иначе
			СтрокаТаблицыСкидок.КоличествоПодарков = 1;
		КонецЕсли;
	КонецЦикла;

	ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(ТаблицаПозиционныхСкидокПоКоличеству, ТаблицаСкидок);
	
	КолвоЭлементовКоллекции = ТаблицаСкидок.Количество();
	ТаблицаНеПрименяемыхПодарков = Новый ТаблицаЗначений;
	ТаблицаНеПрименяемыхПодарков.Колонки.Добавить("СкидкаНаценка");
	Для ОбратныйИндекс = 1 По КолвоЭлементовКоллекции Цикл
		ЭлементКоллекции = ТаблицаСкидок[КолвоЭлементовКоллекции - ОбратныйИндекс];
		
		Если ЭлементКоллекции.КоличествоПодарков <= 0  Тогда
			Если ТаблицаПозиционныхСкидокПоКоличеству.Найти(ЭлементКоллекции.СкидкаНаценка, "СкидкаНаценка") = Неопределено Тогда
				СтрокаТаблицы = ТаблицаНеПрименяемыхПодарков.Добавить();
				СтрокаТаблицы.СкидкаНаценка = ЭлементКоллекции.СкидкаНаценка;
			КонецЕсли; 
			ТаблицаСкидок.Удалить(ЭлементКоллекции);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ОпределитьКоличествоПодарков()

// Заполняет таблицу подарки по скидкам
//
// Параметры:
//  ТаблицаСкидок - Таблица значений скидки подарки
//  ТаблицаТоваров - Таблица значений, в которую выгружена таблица товаров из документа
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  ТабличнаяЧастьПодарки - табличная часть "Подарки" документа.
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница, в котором рассчитываем скидки
//
Процедура ЗаполнитьТаблицуПодарков(ТаблицаСкидок, ТабличнаяЧастьПодарки, СтруктурнаяЕдиница)

	Для каждого СтрокаТаблицыСкидок Из ТаблицаСкидок Цикл
		
		ТаблицаПодарков = СтрокаТаблицыСкидок.СкидкаНаценка.НаборПодарков.Выгрузить();
		ТаблицаПодарков.Колонки.Добавить("СкидкаНаценка");
		ТаблицаПодарков.ЗаполнитьЗначения(СтрокаТаблицыСкидок.СкидкаНаценка, "СкидкаНаценка");
			
		Для каждого СтрокаТаблицыПодарки Из ТаблицаПодарков Цикл
			
			СтрокаТаблицыПодарки.КоличествоУпаковок = СтрокаТаблицыПодарки.КоличествоУпаковок * СтрокаТаблицыСкидок.КоличествоПодарков;
			СтрокаТаблицыПодарки.Количество = СтрокаТаблицыПодарки.Количество * СтрокаТаблицыСкидок.КоличествоПодарков;
			
		КонецЦикла;
		
		ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(ТаблицаПодарков, ТабличнаяЧастьПодарки);
		
	КонецЦикла;

КонецПроцедуры // ЗаполнитьТаблицуПодарки()

// Функция распределяет сумму скидки по строкам товаров
//
// Параметры
//  ТабличнаяЧастьНоменклатуры - табличная часть номенклатуры документа,
//  ТабличнаяЧастьСкидки       - табличная часть скидок,
//  СтруктурнаяЕдиница - СтруктурнаяЕдиница в котором совершается продажа
//  СтрокаРаспределяемойСкидки - строка таблицы значений или выборка, с данными по скидке
//  СуммаРаспределения - Распределяемая сумма 
//
// Возвращаемое значение
//  Булево - если смогли распределить
//
Функция РаспределитьСуммуСкидкиПоСтрокамТоваров(ТабличнаяЧастьНоменклатуры, ТабличнаяЧастьСкидки, СтруктурнаяЕдиница, СтрокаРаспределяемойСкидки, СуммаРаспределения)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаТоваров.НомерСтроки,
	|	ВЫРАЗИТЬ(ТаблицаТоваров.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ТаблицаТоваров.Количество,
	|	ТаблицаТоваров.Сумма
	|ПОМЕСТИТЬ ТаблицаВЗапросе
	|ИЗ
	|	&ТаблицаТоваров КАК ТаблицаТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.Количество,
	|	ВложенныйЗапрос.Сумма,
	|	ВложенныйЗапрос.НомерСтроки КАК НомерСтроки,
	|	ВложенныйЗапрос.Цена
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаВЗапросе.Номенклатура КАК Номенклатура,
	|		ТаблицаВЗапросе.Количество КАК Количество,
	|		МАКСИМУМ(ВЫБОР
	|				КОГДА &СегментНоменклатуры = ЗНАЧЕНИЕ(Справочник.СегментыНоменклатуры.ПустаяСсылка)
	|						ИЛИ НоменклатураСегмента.Сегмент = &СегментНоменклатуры
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ) КАК УсловиеПоНоменклатуре,
	|		ТаблицаВЗапросе.Сумма КАК Сумма,
	|		ТаблицаВЗапросе.НомерСтроки КАК НомерСтроки,
	|		ВЫБОР
	|			КОГДА ТаблицаВЗапросе.Количество = 0
	|				ТОГДА 0
	|			ИНАЧЕ ТаблицаВЗапросе.Сумма / ТаблицаВЗапросе.Количество
	|		КОНЕЦ КАК Цена,
	|		ВЫБОР
	|			КОГДА (НЕ &СкидкаНаКомплект)
	|					ИЛИ (НЕ СкидкиНаКомплект.Номенклатура ЕСТЬ NULL )
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ КАК УсловиеКомплекта
	|	ИЗ
	|		ТаблицаВЗапросе КАК ТаблицаВЗапросе
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|			ПО ТаблицаВЗапросе.Номенклатура = НоменклатураСегмента.Номенклатура
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Ссылка КАК Ссылка,
	|				СкидкиНаценкиНаборПокупкиДляПолученияПодарков.НомерСтроки КАК НомерСтроки,
	|				СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Номенклатура КАК Номенклатура,
	|				СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Упаковка КАК Упаковка,
	|				СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Количество КАК Количество
	|			ИЗ
	|				Справочник.СкидкиНаценки.НаборПокупкиДляПолученияПодарков КАК СкидкиНаценкиНаборПокупкиДляПолученияПодарков
	|			ГДЕ
	|				СкидкиНаценкиНаборПокупкиДляПолученияПодарков.Ссылка = &СкидкаНаценка) КАК СкидкиНаКомплект
	|			ПО ТаблицаВЗапросе.Номенклатура = СкидкиНаКомплект.Номенклатура
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаВЗапросе.Номенклатура,
	|		ТаблицаВЗапросе.Количество,
	|		ТаблицаВЗапросе.Сумма,
	|		ТаблицаВЗапросе.НомерСтроки,
	|		ВЫБОР
	|			КОГДА (НЕ &СкидкаНаКомплект)
	|					ИЛИ (НЕ СкидкиНаКомплект.Номенклатура ЕСТЬ NULL )
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.УсловиеПоНоменклатуре
	|	И ВложенныйЗапрос.УсловиеКомплекта
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки,
	|	Номенклатура";
	
	Запрос.УстановитьПараметр("ТаблицаТоваров", ТабличнаяЧастьНоменклатуры);
	Запрос.УстановитьПараметр("СкидкаНаценка" , СтрокаРаспределяемойСкидки.СкидкаНаценка);
	Запрос.УстановитьПараметр("СегментНоменклатуры", СтрокаРаспределяемойСкидки.СегментБазыРасчетаСкидки);
	Если ЗначениеЗаполнено(СтрокаРаспределяемойСкидки.СкидкаНаценка) И СтрокаРаспределяемойСкидки.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок Тогда
		Запрос.УстановитьПараметр("СкидкаНаКомплект", СтрокаРаспределяемойСкидки.СкидкаНаЕдиныйКомплект);
	Иначе
		Запрос.УстановитьПараметр("СкидкаНаКомплект", Ложь);
	КонецЕсли;
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Результат = Запрос.Выполнить();
	
	ТаблицаСтрокДокумента = Результат.Выгрузить();
	
	Если ТаблицаСтрокДокумента.Количество()=0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СуммаСегмента = ТаблицаСтрокДокумента.Итог("Сумма");
	
	Если СуммаСегмента = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если СуммаСегмента < СуммаРаспределения Тогда
		СуммаРаспределения = СуммаСегмента;
	КонецЕсли;	
	
	КоэффициентРаспределения = (1 - СуммаРаспределения / СуммаСегмента);
	НомерМаксимальнойСтроки  = 0;
	МаксимальнаяСумма        = 0;
	
	СуммаТабличнойЧастиТоварыДоРаспределения = ТабличнаяЧастьНоменклатуры.Итог("Сумма");
	
	Для каждого СтрокаТаблицыДокумента Из ТаблицаСтрокДокумента Цикл
	
		Если МаксимальнаяСумма < СтрокаТаблицыДокумента.Сумма Тогда
			НомерМаксимальнойСтроки  = СтрокаТаблицыДокумента.НомерСтроки;
			МаксимальнаяСумма        = СтрокаТаблицыДокумента.Сумма;
		КонецЕсли;
		
		СтрокаТабличнойЧастиНоменклатуры       = ТабличнаяЧастьНоменклатуры[СтрокаТаблицыДокумента.НомерСтроки - 1];
		Скидка = Окр(СтрокаТабличнойЧастиНоменклатуры.Сумма - СтрокаТабличнойЧастиНоменклатуры.Сумма * КоэффициентРаспределения,2,1);
		Если НЕ Скидка = 0 Тогда
			СтрокаТабличнойЧастиНоменклатуры.Сумма = СтрокаТабличнойЧастиНоменклатуры.Сумма - Скидка;
			
			СтрокаТЧСкидки = ТабличнаяЧастьСкидки.Добавить();
			СтрокаТЧСкидки.КлючСтроки    	= СтрокаТабличнойЧастиНоменклатуры.КлючСтроки;
			СтрокаТЧСкидки.НоменклатураСкидки = СтрокаТабличнойЧастиНоменклатуры.Номенклатура;
			СтрокаТЧСкидки.СкидкаНаценка 	= СтрокаРаспределяемойСкидки.СкидкаНаценка;
			СтрокаТЧСкидки.Сумма         	= Скидка;
			СтрокаТЧСкидки.НачислениеНаЛицевойСчетУдалить	= СтрокаРаспределяемойСкидки.НачислениеНаЛицевойСчетУдалить;
			// СтрокаТЧСкидки.ПрименениеСкидки = ПрименениеСкидки;
		КонецЕсли;
	КонецЦикла;
	
	СуммаТабличнойЧастиТоварыПослеРаспределения = ТабличнаяЧастьНоменклатуры.Итог("Сумма");
	
	ОшибкаОкругления = СуммаРаспределения - (СуммаТабличнойЧастиТоварыДоРаспределения - СуммаТабличнойЧастиТоварыПослеРаспределения);
	
	Если Не ОшибкаОкругления = 0 И НомерМаксимальнойСтроки >0 Тогда
		СтрокаТабличнойЧастиНоменклатуры       = ТабличнаяЧастьНоменклатуры[НомерМаксимальнойСтроки - 1];
		СтрокаТабличнойЧастиНоменклатуры.Сумма = СтрокаТабличнойЧастиНоменклатуры.Сумма - ОшибкаОкругления;
		
		СтрокаТЧСкидки = ТабличнаяЧастьСкидки.Добавить();
		СтрокаТЧСкидки.КлючСтроки    = СтрокаТабличнойЧастиНоменклатуры.КлючСтроки;
		СтрокаТЧСкидки.НоменклатураСкидки = СтрокаТабличнойЧастиНоменклатуры.Номенклатура;
		СтрокаТЧСкидки.СкидкаНаценка = СтрокаРаспределяемойСкидки.СкидкаНаценка;
		СтрокаТЧСкидки.Сумма         = ОшибкаОкругления;
		СтрокаТЧСкидки.НачислениеНаЛицевойСчетУдалить	= СтрокаРаспределяемойСкидки.НачислениеНаЛицевойСчетУдалить;
		// СтрокаТЧСкидки.ПрименениеСкидки = ПрименениеСкидки;
	КонецЕсли;
	
	Возврат Истина;

КонецФункции // РаспределитьСуммуСкидкиПоСтрокамТоваров()

// Дополняет информацию в заголовке по периоду акции и отбору по акции
//
// Параметры:
//  Результат - Табличный документв котором содержиться заполненный отчет
//  КомпоновщикНастроек - компоновщик настроек отчета
//  МаркетинговаяАкция - маркетинговая акция
//
Процедура ДополнитьЗаголовокОтчета(Результат, КомпоновщикНастроек, МаркетинговаяАкция) Экспорт

	ТекстОтбора = Результат.Область("R2C1:R2C1").Текст;
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(ТекстОтбора);
	
	// Период
	ЗначениеПараметраПериод = КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Период"));
	ЗначениеПараметраНачалоПериода = КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ПериодНачалаАкции"));
	ЗначениеПараметраКонецПериода = КомпоновщикНастроек.Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ПериодОкончанияАкции"));
	ОписаниеПериода = "";
	
	Если ЗначениеПараметраНачалоПериода <> Неопределено 
	   И ЗначениеПараметраКонецПериода <> Неопределено Тогда
		НачалоПериода = ?(ТипЗнч(ЗначениеПараметраНачалоПериода.Значение) = Тип("СтандартнаяДатаНачала"), ЗначениеПараметраНачалоПериода.Значение.Дата, ЗначениеПараметраНачалоПериода.Значение);
		КонецПериода = ?(ТипЗнч(ЗначениеПараметраКонецПериода.Значение) = Тип("СтандартнаяДатаНачала"), ЗначениеПараметраКонецПериода.Значение.Дата, ЗначениеПараметраКонецПериода.Значение);
		Если НачалоПериода = '00010101' И КонецПериода = '00010101' Тогда
			ОписаниеПериода = НСтр("ru='Период не установлен'");
		ИначеЕсли НачалоПериода = '00010101' ИЛИ КонецПериода = '00010101' Тогда
			ОписаниеПериода = Формат(НачалоПериода, "ДФ = дд.ММ.гггг; ДП = ...") + " - " + Формат(КонецПериода, "ДФ = дд.ММ.гггг; ДП = ...");
		ИначеЕсли НачалоПериода <= КонецПериода Тогда
			ОписаниеПериода = ПредставлениеПериода(НачалоДня(НачалоПериода), КонецДня(КонецПериода), "ФП = Истина");
		Иначе
			ОписаниеПериода = НСтр("ru='Неправильно задан период!'");
		КонецЕсли;
	ИначеЕсли ЗначениеПараметраПериод <> Неопределено Тогда
		Период = ЗначениеПараметраПериод.Значение;
		Если Период = '00010101' Тогда
			ОписаниеПериода = НСтр("ru='на '") + Формат(ТекущаяДата(), "ДП = ...");
		Иначе
			ОписаниеПериода = НСтр("ru='на конец дня '") + Формат(Период, "ДФ = дд.ММ.гггг; ДП = ...");
		КонецЕсли;
	Иначе
		ОписаниеПериода = "";
	КонецЕсли;
	Если Не ПустаяСтрока(ОПисаниеПериода) Тогда
		ОписаниеПериода = "Период акции: " + ОписаниеПериода;
	КонецЕсли;
	
	ТекстовыйДокумент.ВставитьСтроку(2,ОписаниеПериода);
	
	Если ЗначениеЗаполнено(МаркетинговаяАкция)  Тогда
		ОписаниеАкции = "Отбор заполнен по акции: "+МаркетинговаяАкция.НаименованиеАкции + " ("+МаркетинговаяАкция+").";
		ТекстовыйДокумент.ДобавитьСтроку(ОписаниеАкции);
	КонецЕсли;
	
	Результат.Область("R2C1:R2C1").Текст = ТекстовыйДокумент.ПолучитьТекст();
	
КонецПроцедуры // ДополнитьЗаголовокОтчета()

// Функция возвращает признак доступности скидок для клиентов
//
