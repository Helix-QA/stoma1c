 
#Область ОбработчикиСобытийФормы
 
// Процедура, обработчик события "ПриСозданииНаСервере"
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	// Установим реквизиты
	СкладДокумента = Объект.Склад;
	
	Если Не ЗначениеЗаполнено(Объект.ВидЦен) И ЗначениеЗаполнено(Объект.ОснованиеВозврата) Тогда
		Объект.ВидЦен = Объект.ОснованиеВозврата.ВидЦен;
	ИначеЕсли Не ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		Объект.ВидЦен = Справочники.ВидыЦен.Закупочная;
	КонецЕсли;

	// Сформируем надпись	
	Элементы.СтруктурнаяЕдиницаНадпись.Заголовок = Объект.СтруктурнаяЕдиница;
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);
	ВидЦенНадпись = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи, Ложь);	
	
	ОбщегоНазначенияСтоматология.ЗаполнитьПризнакИспользованияХарактеристик(Объект.Запасы);
	СоздатьМенюУправленияТабличнымиЧастями();
	ОбновитьЗаголовкиТабЧастейНаСервере();
	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	
	// СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	ЗагрузкаДанныхИзВнешнегоИсточника.ПриСозданииНаСервере(Метаданные.Документы.ВозвратПоставщику.ТабличныеЧасти.Запасы, НастройкиЗагрузкиДанных, ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзВнешнегоИсточника
	
КонецПроцедуры

// Процедура, обработчик события "ПослеЗаписи"
//
&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиентСтоматология.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте 
// Процедура, Обработчки события "ВидЦенНадписьНажатие"
//
Процедура ВидЦенНадписьНажатие(Элемент, СтандартнаяОбработка)
	
	 СтандартнаяОбработка = Ложь;
	 // 1. Формируем структуру параметров для заполнения формы "Цены и Валюта".
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ВидЦен", 	  			Объект.ВидЦен);
	СтруктураПараметров.Вставить("ПерезаполнитьЦены",	Ложь);
	
	// 2. Открвыаем форму "Цены и Валюта".
	ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,,Новый ОписаниеОповещения("РедактироватьЦеныЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

// Процедура, устанавливает структурную единицу при изменении склада документа.
//  Параметры: 
//   Нет;
//
&НаСервере
Процедура УстановитьСтруктурнуюЕдиницуПоСкладу()
	
	Объект.СтруктурнаяЕдиница = СкладДокумента.СтруктурнаяЕдиница;
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Склад"
//
&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	
	// Обработка события изменения даты.
	СкладПередИзменением = СкладДокумента;
	СкладДокумента       = Объект.Склад;
	Если Объект.Склад <> СкладПередИзменением Тогда
		 УстановитьСтруктурнуюЕдиницуПоСкладу();   		 
		 Элементы.СтруктурнаяЕдиницаНадпись.Заголовок = объект.СтруктурнаяЕдиница;
	КонецЕсли;

	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Количество"
//
&НаКлиенте
Процедура ЗапасыКоличествоУпаковокПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы["Запасы"].ТекущиеДанные;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Цена"
//
&НаКлиенте
Процедура ЗапасыЦенаПриИзменении(Элемент)
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Сумма"
//
&НаКлиенте
Процедура ЗапасыСуммаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы["Запасы"].ТекущиеДанные;
	ОбработкаТабличныхЧастейКлиент.ПриИзмененииСуммыВТабличнойЧасти(СтрокаТабличнойЧасти);
	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "СтавкаНДС"
//
&НаКлиенте
Процедура ЗапасыСтавкаНДСПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);
      	
КонецПроцедуры
 
 // Процедура рассчитывает сумму в строке табличной части.
//
&НаКлиенте
Процедура РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти = Неопределено)
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	КонецЕсли;
	
	 ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти);
	 ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	 ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры // РассчитатьСуммуВСтрокеТабличнойЧасти()

// Процедура, обработчик события "ПриИзменении" поле ввода "Номенклатура"
//
&НаКлиенте
Процедура ЗапасыНоменклатураПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Упаковка) Тогда	
		СтрокаТабличнойЧасти.Упаковка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "УпаковкаПоумолчанию");
	КонецЕсли;	
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);
	СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);	
	СтруктураДанные.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);
	
	СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.Упаковка = СтруктураДанные.Упаковка;
	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.КоличествоУпаковок) Тогда
		СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
		СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ОснованиеВозврата) Тогда
		СтрокаТабличнойЧасти.ОснованиеВозврата = Объект.ОснованиеВозврата;
	КонецЕсли;
	
	ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	
	СтрокаТабличнойЧасти.ХарактеристикиИспользуются = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "ИспользоватьПартии");
	ОбновитьЗаголовкиТабЧастейНаСервере();
	
КонецПроцедуры

// Процедура, обработчик события "ПриИзменении" поле ввода "Упаковка"
//
&НаКлиенте
Процедура ЗапасыУпаковкаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
	ОбработкаТабличныхЧастейКлиент.ПриИзмененииУпаковкиТабЧасти(СтрокаТабличнойЧасти, СтруктураДанные);
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	
КонецПроцедуры

// Процедура, обработчик события "НачалоВыбора" поле ввода "Упаковка"
//
&НаКлиенте
Процедура ЗапасыУпаковкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбработкаТабличныхЧастейКлиент.ВыбратьУпаковкуНоменклатуры(ДанныеВыбора, СтандартнаяОбработка, Элементы.Запасы.ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении" поле ввода "ОснованиеВозврата"
//
Процедура ОснованиеВозвратаПриИзменении(Элемент)
	
	Режим = РежимДиалогаВопрос.ДаНет;
	Текст = "ru = ""Заполнить документ по выбранному основанию?"";";	
	ПоказатьВопрос(Новый ОписаниеОповещения("ОснованиеВозвратаПриИзмененииЗавершение", ЭтотОбъект), НСтр(Текст), Режим, 0);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОснованиеВозвратаПриИзмененииЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Объект.ОснованиеВозврата) Тогда
		Если РезультатВопроса = КодВозвратаДиалога.Да Тогда 
			ВыполнитьЗаполнениеДокумента(Истина);
			СкладПриИзменении(Неопределено);
		Иначе
			ВыполнитьЗаполнениеДокумента(Ложь);
		КонецЕсли;
	КонецЕсли;
	
	// Сформируем надпись
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);
	ВидЦенНадпись = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи, Ложь);

КонецПроцедуры

&НаСервере
// Процедура выполняет заполнение документа на основании документа основания
//
Процедура ВыполнитьЗаполнениеДокумента(Ответ)
	
	Объект.ВидЦен = Объект.ОснованиеВозврата.ВидЦен;
	Объект.Контрагент = Объект.ОснованиеВозврата.Контрагент;
	Если Ответ Тогда
		Объект.Склад = Объект.ОснованиеВозврата.Склад;
		СтруктурнаяЕдиница = Объект.ОснованиеВозврата.СтруктурнаяЕдиница;
		Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		                      |	ПоступлениеЗапасы.Номенклатура,
		                      |	ПоступлениеЗапасы.Партия,
		                      |	ПоступлениеЗапасы.Количество,
		                      |	ПоступлениеЗапасы.Цена,
		                      |	ПоступлениеЗапасы.Сумма,
		                      |	ПоступлениеЗапасы.СтавкаНДС,
		                      |	ПоступлениеЗапасы.СуммаНДС,
		                      |	ПоступлениеЗапасы.Всего,
		                      |	ПоступлениеЗапасы.Упаковка,
		                      |	ПоступлениеЗапасы.КоличествоУпаковок,
		                      |	ПоступлениеЗапасы.Ссылка КАК ОснованиеВозврата
		                      |ИЗ
		                      |	Документ.Поступление.Запасы КАК ПоступлениеЗапасы
		                      |ГДЕ
		                      |	ПоступлениеЗапасы.Ссылка = &ДокументОснование");
		Запрос.УстановитьПараметр("ДокументОснование", Объект.ОснованиеВозврата.Ссылка);		
		Объект.Запасы.Загрузить(Запрос.Выполнить().Выгрузить());
	КонецЕсли;  
	
КонецПроцедуры

// Процедура оработчик команды "Подбор"
//
&НаКлиенте
Процедура Подбор(Команда)
	ИмяТабличнойЧасти  = "Запасы";
	ЕстьПартии		   = Истина;
		
	ПараметрыПодбора = Новый Структура;
	
	ПараметрыПодбора.Вставить("Период",				   Объект.Дата);
	ПараметрыПодбора.Вставить("Склад",	   			   Объект.Склад);
	ПараметрыПодбора.Вставить("СтруктурнаяЕдиница",	   Объект.СтруктурнаяЕдиница);
	ПараметрыПодбора.Вставить("ВидЦен",	   			   Объект.ВидЦен);
	ПараметрыПодбора.Вставить("ИспользуетсяСодержание",Истина);

	Если Объект[ИмяТабличнойЧасти].Количество() > 0 Тогда
		АдресЗапасовВХранилище = ПоместитьЗапасыВХранилище(ИмяТабличнойЧасти, ЕстьПартии);
		ПараметрыПодбора.Вставить("АдресЗапасовДокумента", АдресЗапасовВХранилище);
	КонецЕсли; 
	
	ТипНоменклатуры = Новый СписокЗначений;
	Для каждого ЭлементМассива Из Элементы[ИмяТабличнойЧасти + "Номенклатура"].ПараметрыВыбора Цикл
		Если ЭлементМассива.Имя = "Отбор.ТипНоменклатуры" Тогда
			Если ТипЗнч(ЭлементМассива.Значение) = Тип("ФиксированныйМассив") Тогда
				Для каждого ЭлементФиксМассива Из ЭлементМассива.Значение Цикл
					ТипНоменклатуры.Добавить(ЭлементФиксМассива);
				КонецЦикла; 
			Иначе
				ТипНоменклатуры.Добавить(ЭлементМассива.Значение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	ПараметрыПодбора.Вставить("ТипНоменклатуры",	   ТипНоменклатуры);
		
	СтатусПартии = Новый СписокЗначений;
	Для каждого ЭлементМассива Из Элементы[ИмяТабличнойЧасти + "Партия"].ПараметрыВыбора Цикл
		Если ЭлементМассива.Имя = "Отбор.Статус" Тогда			
			Если ТипЗнч(ЭлементМассива.Значение) = Тип("ФиксированныйМассив") Тогда
				Для каждого ЭлементФиксМассива Из ЭлементМассива.Значение Цикл
					СтатусПартии.Добавить(ЭлементФиксМассива);
				КонецЦикла; 
			Иначе
				СтатусПартии.Добавить(ЭлементМассива.Значение);
			КонецЕсли;			
		КонецЕсли;
	КонецЦикла;
	ПараметрыПодбора.Вставить("СтатусПартии",	   		СтатусПартии);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяТабличнойЧасти", ИмяТабличнойЧасти);
	ДополнительныеПараметры.Вставить("ЕстьПартии", ЕстьПартии);
	
	ОткрытьФорму("ОбщаяФорма.ФормаПодбора",
	ПараметрыПодбора,,,,,
	Новый ОписаниеОповещения("ПодборЗавершение", ЭтотОбъект, ДополнительныеПараметры), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаКлиенте
// Процедура - После выбора подбора
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПодборЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
