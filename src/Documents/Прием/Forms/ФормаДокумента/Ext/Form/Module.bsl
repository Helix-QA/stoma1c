// Процедура рассчитывает сумму в строке табличной части.
//
Процедура ТабличныеЧастиРассчитатьСуммуВСтроке(СтрокаТабличнойЧасти)
		
	ВидЦен = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидЦен), СтрокаТабличнойЧасти.ВидЦен, Объект.ВидЦен);
	ПараметрыВидаЦены = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ВидЦен, "ПорядокОкругления, ОкруглятьВБольшуюСторону");
	
	СтруктураПараметров = Новый Структура("ПорядокОкругления, ОкруглятьВБольшуюСторону", ПараметрыВидаЦены.ПорядокОкругления, ПараметрыВидаЦены.ОкруглятьВБольшуюСторону);
	
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, СтруктураПараметров);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти);
	ОбработкаТабличныхЧастейКлиент.РассчитатьСуммуВКолонкеВсегоТабЧасти(СтрокаТабличнойЧасти);
	
	Если СтрокаТабличнойЧасти.Свойство("Рекламация") И ЗначениеЗаполнено(СтрокаТабличнойЧасти.Рекламация) Тогда
		СтрокаТабличнойЧасти.Всего = 0;
	КонецЕсли;	
	// Обновить значение суммы документа 
	Объект.СуммаДокумента = Объект.Лечение.Итог("Всего") + Объект.Запасы.Итог("Всего");
	РассчитатьСуммуСкидки();
	
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) 
		И ПолучитьЗначениеБесплатно(СтрокаТабличнойЧасти.Номенклатура) Тогда
		
		СтрокаТабличнойЧасти.Цена = 0;
		СтрокаТабличнойЧасти.Сумма = 0;
		СтрокаТабличнойЧасти.СуммаАвтоматическойСкидкиНаценки =0;
	КонецЕсли; 
	
