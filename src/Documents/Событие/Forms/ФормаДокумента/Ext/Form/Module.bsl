
#Область ОписаниеПеременных

&НаКлиенте
Перем ИскомыйКлиент; 
&НаКлиенте
Перем СтруктураОбязательныеПоля; // Хранит обязательные поля
&НаКлиенте
Перем ПризнакСозданияНовогоПациента; // Флаг для корректной работы создания нового пациента
&НаКлиенте
Перем ПризнакИзмененияВремениВрачей; // Флаг для корректной работы изменения времени работы врача/ей
&НаКлиенте
Перем ОтветПользователяНаВопрос; 

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтоНовыйДок = Объект.Ссылка.Пустая();

	ЭтотОбъект.ЗапускВэбКлиент = ОбщегоНазначения.ЭтоВебКлиент();
	
	ИнициализироватьСписокСтатусовПредварительнойЗаписи();	
	ИспользуетсяРасширениеМессенджер = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер");	
	ДатаДокумента = ?(НЕ ЗначениеЗаполнено(Объект.Дата), ТекущаяДатаСеанса(), Объект.Дата);	
	Если ЭтоНовыйДок Тогда
		
		ЭтаФорма.АвтоЗаголовок = Ложь;
		ЭтаФорма.Заголовок = "Назначение приема";
				
		Объект.Дата = ?(ЗначениеЗаполнено(Параметры.ДатаНачала), Параметры.ДатаНачала, ТекущаяДатаСеанса());	
		Параметры.Свойство("Резерв"			, Объект.Резерв); 	
		Параметры.Свойство("ПеренесённаяПредварительнаяЗапись", Объект.ПеренесённаяПредварительнаяЗапись);
		Если Параметры.Свойство("Сделка") И Параметры.Свойство("Сотрудник") И (Параметры.Сделка.Врач = Параметры.Сотрудник ИЛИ Параметры.Сделка.Врач = Справочники.Сотрудники.ПустаяСсылка())Тогда
			Параметры.Свойство("Сделка", Объект.Сделка); 
		КонецЕсли;
		Параметры.Свойство("Заявка"				, ТекущаяЗаявка); 
		Параметры.Свойство("ИсточникЗаписи"		, Объект.ИсточникЗаписи);
		Параметры.Свойство("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
		
		Объект.Комментарий = ?(Параметры.Свойство("ПричинаЗаписи") И ЗначениеЗаполнено(Параметры.ПричинаЗаписи), Параметры.ПричинаЗаписи, Неопределено);
		
		Если НЕ ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда 
			
			НоваяСтрокаОбъектУслуги = Объект.Услуги.Добавить();
						
			Если ЗначениеЗаполнено(Параметры.ДатаНачала) И ЗначениеЗаполнено(Параметры.ДатаОкончания)  Тогда 

				Параметры.Свойство("ВнутреннийНомерСотрудника"	, ЭтотОбъект.ВнутреннийНомерСотрудника);  
				Параметры.Свойство("IDЗвонка"					, ЭтотОбъект.IDЗвонка);
          		Параметры.Свойство("Контрагент"					, Объект.Контрагент); 
				
				// Если в форму передан контрагент для заполнения запретить возможность его изменения
				// Если ЗначениеЗаполнено(Объект.Контрагент) И НЕ ЗначениеЗаполнено(ЭтотОбъект.ВнутреннийНомерСотрудника) Тогда
				//		Элементы.Контрагент.ТолькоПросмотр = Истина;
				// КонецЕсли;	

				Если Не ЗначениеЗаполнено(Объект.Контрагент) И ЗначениеЗаполнено(ТекущаяЗаявка) И ЗначениеЗаполнено(ТекущаяЗаявка.НомерТелефона) Тогда
					Телефон_НовыйПациент = ТекущаяЗаявка.НомерТелефона;
					ДобавитьТелефонСуществующемуПациенту = Истина;
				ИначеЕсли ЗначениеЗаполнено(Объект.Контрагент) И ЗначениеЗаполнено(Объект.Контрагент.Телефон) Тогда
	                Телефон_НовыйПациент = Объект.Контрагент.Телефон;
				КонецЕсли; 
				Если Параметры.Свойство("ВходящийНомерТелефона") И ЗначениеЗаполнено(Параметры.ВходящийНомерТелефона) Тогда
					Объект.ВходящийНомерТелефона = Параметры.ВходящийНомерТелефона;	
					Телефон_НовыйПациент = Параметры.ВходящийНомерТелефона;
				КонецЕсли;
				НоваяСтрокаОбъектУслуги.ДатаНачала    = Параметры.ДатаНачала;
				НоваяСтрокаОбъектУслуги.ДатаОкончания = Параметры.ДатаОкончания;
			Иначе
				НоваяСтрокаОбъектУслуги.ДатаНачала    = ТекущаяДатаСеанса();
				НоваяСтрокаОбъектУслуги.ДатаОкончания = НоваяСтрокаОбъектУслуги.ДатаНачала + 3600;	
			КонецЕсли;
					
			НоваяСтрокаОбъектУслуги.Сотрудник     = ?(ЗначениеЗаполнено(Параметры.Сотрудник), Параметры.Сотрудник, Неопределено);
			НоваяСтрокаОбъектУслуги.Помещение     = ?(ЗначениеЗаполнено(Параметры.Помещение), Параметры.Помещение, ПолучитьПомещениеСотрудникаПоУмолчанию(Параметры.Сотрудник, Объект.СтруктурнаяЕдиница));
			НоваяСтрокаОбъектУслуги.НормаВремени  = (НоваяСтрокаОбъектУслуги.ДатаОкончания - НоваяСтрокаОбъектУслуги.ДатаНачала) / 60;			
				
			ДатаНачала 		= НоваяСтрокаОбъектУслуги.ДатаНачала;
			ДатаОкончания 	= НоваяСтрокаОбъектУслуги.ДатаОкончания;
			НормаВремени 	= НоваяСтрокаОбъектУслуги.НормаВремени; 			
			
		Иначе   // если документ копируется, то время брать от копируемого документа, а дату текущую
			
			Если ЗначениеЗаполнено(Параметры.ДатаНачала)  Тогда
				Для Каждого СтрокаТЧ Из Объект.Услуги Цикл
					СтрокаТЧ.ДатаНачала    = Параметры.ДатаНачала;
					СтрокаТЧ.ДатаОкончания = СтрокаТЧ.ДатаНачала + (СтрокаТЧ.НормаВремени * 60);
				КонецЦикла;
			Иначе
				Для Каждого СтрокаТЧ Из Объект.Услуги Цикл
					СтрокаТЧ.ДатаНачала = НачалоДня(ТекущаяДатаСеанса()) + ((Час(СтрокаТЧ.ДатаНачала) * 3600) + (Минута(СтрокаТЧ.ДатаНачала) * 60) + (Секунда(СтрокаТЧ.ДатаНачала)));
					СтрокаТЧ.ДатаОкончания = СтрокаТЧ.ДатаНачала + (СтрокаТЧ.НормаВремени * 60);
				КонецЦикла;
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли;
			
	Если Объект.Услуги.Количество() = 0 Тогда // в тч Услуги обязательно должна быть хоть одна строка
		НоваяСтрокаОбъектУслуги = Объект.Услуги.Добавить();
		НоваяСтрокаОбъектУслуги.ДатаНачала    = ТекущаяДатаСеанса();
		НоваяСтрокаОбъектУслуги.ДатаОкончания = НоваяСтрокаОбъектУслуги.ДатаНачала + 3600;
		НоваяСтрокаОбъектУслуги.НормаВремени  = (НоваяСтрокаОбъектУслуги.ДатаОкончания - НоваяСтрокаОбъектУслуги.ДатаНачала) / 60;
	КонецЕсли;
		
	Параметры.Свойство("ИнтервалГрафика", ИнтервалГрафика);
		
	УстановитьДаты();		
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);				
    ОбновитьНадписи(); 
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		// Инициализируем полисы мед. страхования пациента
		ОбновитьПолисыМедицинскогоСтрахования(Истина);
		// Обновляем виджет сделок
		УправлениеИнтерфейсамиСервер.ОбновитьВиджетСделки(ЭтаФорма, Объект.Контрагент, Объект.Сделка);
		// Заполняем комментарий при создании записи
		ИнициализироватьКомментарий();
		// Выводим наряд-заказы
		ВывестиНезавершенныеНарядЗаказы();  
		// Выводим долги пациента
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаДолгиКонтрагентаСуществующие");
		МассивРодителей.Добавить("ГруппаБудущиеСобытияКлиента");
		ОтображениеДополнительнойИнформации(МассивРодителей);
		ИнформированияПоДнюРожденияКонтрагента = ПроверитьНеобходимостьИнформированияПоДнюРожденияКонтрагента(Объект.Контрагент); 
        Если Не ЭтоНовыйДок Тогда
			ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Контрагент, Объект.СтруктурнаяЕдиница);
		КонецЕсли;	
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ВидЦен = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Услуги[0].Сотрудник, Объект.СтруктурнаяЕдиница); 
	КонецЕсли;
	
	ЗаполнитьТаблицуМеток();
	ОбновитьМетки();
		
	// Здесь также формируется список для выбора времени приема
	ПриИзменениеДатыВизитаНаСервере(ДатаНачала); 	
	// Установка цвета
	Если ЗначениеЗаполнено(Объект.ЦветФонаРезерва) Тогда
		ЦветФонаРезерваФорма = ЗначениеИзСтрокиВнутр(Объект.ЦветФонаРезерва);
		Элементы.УстановкаЦвет.ЦветФона = ЗначениеИзСтрокиВнутр(Объект.ЦветФонаРезерва);
	Иначе 
		ЦветФонаРезерваФорма = WebЦвета.Хаки;
		Объект.ЦветФонаРезерва = ЗначениеВСтрокуВнутр(ЦветФонаРезерваФорма);
		Элементы.УстановкаЦвет.ЦветФона = ЗначениеИзСтрокиВнутр(Объект.ЦветФонаРезерва);
	КонецЕсли;	
	
	УстановитьОбязательныеПоля();	
	
	// Скрываем/Показываем блок с услугами до нажатия кнопки ДобавитьУслугу	
	ПоказыватьКнопкуДобавленияУслуг = ?(Объект.Услуги.Количество() = 0, Истина, Ложь);
	Если НЕ ПоказыватьКнопкуДобавленияУслуг Тогда
		Если ЗначениеЗаполнено(Объект.Услуги[0].Номенклатура) ИЛИ Объект.Услуги.Количество() >= 2 Тогда	
			СоздатьДинамическиеЭлементыГруппыЗапись();
		Иначе
			ПоказыватьКнопкуДобавленияУслуг = Истина;	
		КонецЕсли;				
	КонецЕсли;
	Элементы.ГруппаКнопкаДобавитьУслуги.Видимость = ПоказыватьКнопкуДобавленияУслуг;
	Элементы.ГруппаУслугПолями.Видимость = НЕ ПоказыватьКнопкуДобавленияУслуг;
			
	УстановитьВидимостьЭлементов();

	// Вставим в заголовок кнопки "Прием" номер созданного приема
	Если ЗначениеЗаполнено(Объект.СсылкаНаПрием) Тогда
		НомерПриемаПолный = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СсылкаНаПрием, "Номер");
		НомерПриемаКраткий = ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(НомерПриемаПолный, Истина, Истина);
		Элементы.ФормаКнопкаВвестиПосещение.Заголовок = "Прием №"+НомерПриемаКраткий;
	КонецЕсли;
	
	// Для контроля записей родственных связей у нового пациента;
	ПациентЗаписан_НовыйПациент = Ложь;
	
	ЗаполнитьТЧ_КИ_ПриИзменении();	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
	Параметры.Свойство("ЭтоРабочееВремя", ЭтотОбъект.ЭтоРабочееВремяСотрудника);
		
	// Сформируем надпись
	Элементы.ВыбратьСтруктурнуюЕдиницу.Заголовок = Строка(Объект.СтруктурнаяЕдиница);
	
	// Заполним интервалы длительности приема.
	ЗаполнитьИнтервалиДлительностиПриема();
	ПриемОкончен = Перечисления.СтатусыСобытия.ПриемОкончен;
	
    УстановитьПараметрыВыбораСотрудникаНаСервере();
	
	// Показываем признак блокировки и показываем нужный замок 
	НомерЗамка = Число(ВернутьКонстантуНесколькоВрачейВОдномПриеме()); 
	НужныйЗамок = Элементы.Найти("УстановитьЗамок"+НомерЗамка); 
	НужныйЗамок.Картинка = ?(Объект.Услуги.Количество() > 0 И Объект.Услуги[0].ПризнакЗаблокированно = 1, БиблиотекаКартинок.ЗамокБлокировка, БиблиотекаКартинок.ЗамокОткрытый); 	 
	НенужныйЗамок = Элементы.Найти("УстановитьЗамок"+?(НомерЗамка = 1, 0, 1));
	НенужныйЗамок.Видимость = Ложь;
	
	ПериодРаботыСЕ = ОбщегоНазначенияСтоматология.ПолучитьВремяРаботыСтруктурнойЕдиницы(НачалоДня(ДатаНачала), Объект.СтруктурнаяЕдиница);
		
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриОткрытии.
// В процедуре устанавливается текущая страница в зависимости от операции.
//
Процедура ПриОткрытии(Отказ)
		
	// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		// ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		ПоддерживаемыеТипыВО.Добавить("СчитывательМагнитныхКарт");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования
		
	Если ЗначениеЗаполнено(Объект.Контрагент) И ИнформированияПоДнюРожденияКонтрагента.Информировать Тогда
		ПоказатьПредупреждение(, ИнформированияПоДнюРожденияКонтрагента.СообщениеИнформирования, 15, "Информирование о дне рождения клиента");
	КонецЕсли;	
	ПроинициализироватьЭлементыВыбораВремени();				
	// Устанавливаем флаг для корректной работы механизма создания нового пациента. Без него крашится платформа!
	ПризнакСозданияНовогоПациента = Ложь;
	
	// Флаг для корректной работы изменения времени работы врача/ей;
	ПризнакИзмененияВремениВрачей = Ложь;
		
	ИзменитьЭлементДлительностиПриема(ПосчитатьНормуВремениТЧУслуги(), Неопределено, Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗакрытием" формы.
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Ложь;
		
	Если ЭтаФорма.Модифицированность Тогда
		СтандартнаяОбработка = Ложь; 	
		 		
		Если ОтветПользователяНаВопрос = Неопределено Тогда	
			
			Оповещение = Новый ОписаниеОповещения("ПоказатьПользователюВопросЗавершение_ПередЗакрытием", ЭтотОбъект, Неопределено);
			ПоказатьВопрос(Оповещение, "Данные были изменены! Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена);	
			Отказ = Истина;
			Возврат;
		Иначе
			
			Если ОтветПользователяНаВопрос = КодВозвратаДиалога.Да Тогда			
				
				Отказ = НЕ ПроверитьЗаполнение();
				ОтветПользователяНаВопрос = Неопределено;
				Если Отказ Тогда
					Возврат;
				Иначе 	
					ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
				КонецЕсли;
	
			ИначеЕсли ОтветПользователяНаВопрос = КодВозвратаДиалога.Отмена Тогда 
				
				ОтветПользователяНаВопрос = Неопределено;
				Отказ = Истина;
				Возврат;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе

		Оповестить("ОчиститьБуферЖурналаПредварительнойЗаписи");
		
	КонецЕсли;
		
	//
	// Если ЭтаФорма.Модифицированность Тогда

	//	СтандартнаяОбработка = Ложь;
	//	Ответ = Вопрос("Данные были изменены! Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена, , , "Вопрос");
	//	Если Ответ = КодВозвратаДиалога.Да Тогда			
	//		Отказ = НЕ ПроверитьЗаполнение();
	//		Если Отказ Тогда
	//			Возврат;
	//		Иначе 	
	//			ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	//		КонецЕсли;
	//	ИначеЕсли Ответ = КодВозвратаДиалога.Отмена Тогда 
	//		Отказ = Истина;
	//		Возврат;

	//	КонецЕсли;

	// КонецЕсли; 
	
	// Если была создана родственная связь, а форму закрывают не сохраняя, удалем связь
	Если Ссылка_НовыйПациент <> Неопределено
		И ТипЗнч(Ссылка_НовыйПациент) = Тип("СправочникСсылка.Контрагенты")
		И ПациентЗаписан_НовыйПациент = Ложь Тогда
		
			УдалитьВсеРодственныеСвязиКонтрагентаНаСервере(Ссылка_НовыйПациент);
			
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		ПроверитьТекущиеНапоминанияПоПосещениямСтоматология(Объект.Контрагент);
	КонецЕсли;	
	
