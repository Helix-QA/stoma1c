// Обновление динамических парамтеров документа
//
Процедура ОбновитьДинамическиеРеквизитыОбследования() 
	
	// Подготовка массива обрабатываемых данных
	МассивОбработки = Новый Массив;
	Для Каждого СтрокаТ ИЗ ДОРеквизитыШаблонОбследования Цикл		
		Если СтрокаТ.РеквизитТип = ОбщиеПараметры.ТипыПараметровШаблоновОбследований_Динамический Тогда
			АлгВычисления = СтрокаТ.АлгоритВычисления;
			СтруктураДанных = Новый Структура("Алгорит,ИдентификаторПараметра,Результат",АлгВычисления,СтрокаТ.РеквизитИдентификатор,Неопределено);
			МассивОбработки.Добавить(СтруктураДанных);		
		КонецЕсли;		
	КонецЦикла;
	// Вычисление алгоритмов динамических реквизитов
    ВыполнитьАлгоритмыДинамическихПарамтеровСервер(МассивОбработки);	
	// Вывод результатов вычисления 
                        
	Если НЕ Элементы.HTMLПолеОбследование.Документ = Неопределено Тогда		
		Для Каждого ЭлементМ ИЗ МассивОбработки Цикл
			document = Элементы.HTMLПолеОбследование.Документ; 
			Если ЗначениеЗаполнено(ЭлементМ.Результат) Тогда
				HTMLЭлемент = document.getElementById(ЭлементМ.ИдентификаторПараметра);
				Если HTMLЭлемент = Неопределено Тогда
					HTMLЭлемент = document.getElementById(ЭлементМ.ИдентификаторПараметра+",Addition");
				КонецЕсли;  
				Если Не HTMLЭлемент = Неопределено Тогда
					HTMLЭлемент.innerHTML            = СтрЗаменить(HTMLЭлемент.innerHTML,HTMLЭлемент.innerText,Строка(ЭлементМ.Результат));	
					HTMLЭлемент.href                 = "about:" + ПреобразоватьЗначениеВСтроку(ЭлементМ.Результат);				
					HTMLЭлемент.style.textdecoration = "none";
				КонецЕсли;			
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли; 
		
КонецПроцедуры

