	                      |	ДоговорыКонтрагентов.УслугиПоСогласованию КАК УслугиПоСогласованию
	                      |ИЗ
	                      |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	                      |ГДЕ
	                      |	ДоговорыКонтрагентов.Контрагент.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.СтраховаяКомпания)
	                      |	И НЕ ДоговорыКонтрагентов.ПометкаУдаления");
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
		СоставСегментаПоСогласованию = Неопределено;	
		МассивСегменты = Новый Массив;
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.УслугиПоСогласованию) Тогда
			МассивСегменты.Добавить(ВыборкаДетальныеЗаписи.УслугиПоСогласованию);
			СоставСегментаПоСогласованию = ВыборкаДетальныеЗаписи.УслугиПоСогласованию;	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.УслугиБезСогласования) Тогда
			МассивСегменты.Добавить(ВыборкаДетальныеЗаписи.УслугиБезСогласования);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(МассивСегменты) Тогда
			
			СправочникОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			
			ЗапросСегмент = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
				|	НоменклатураСегмента.Номенклатура КАК Номенклатура,
				|	ВЫБОР
				|		КОГДА НоменклатураСегмента.Сегмент = &СоставСегментаПоСогласованию
				|			ТОГДА ИСТИНА
				|		ИНАЧЕ ЛОЖЬ
				|	КОНЕЦ КАК Согласование
				|ИЗ
				|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
				|ГДЕ
				|	НоменклатураСегмента.Сегмент В(&Сегмент)");
			
			ЗапросСегмент.УстановитьПараметр("Сегмент", МассивСегменты);
			ЗапросСегмент.УстановитьПараметр("СоставСегментаПоСогласованию", СоставСегментаПоСогласованию);
			
			РезультатЗапросаСегмент = ЗапросСегмент.Выполнить();		
			ВыборкаДетальныеЗаписиСегмент = РезультатЗапросаСегмент.Выбрать();
			
			Пока ВыборкаДетальныеЗаписиСегмент.Следующий() Цикл
				НоваяСтрока = СправочникОбъект.УслугиПоДоговору.Добавить();
				НоваяСтрока.Номенклатура = ВыборкаДетальныеЗаписиСегмент.Номенклатура;
				НоваяСтрока.Количество = 0;
				НоваяСтрока.Согласование = ?(ВыборкаДетальныеЗаписиСегмент.Согласование, Перечисления.ТипыСогласованийУслугСтраховойКомпании.Всегда,
																						 Перечисления.ТипыСогласованийУслугСтраховойКомпании.НеТребуется);
			КонецЦикла;
			
			Попытка
				СправочникОбъект.Записать();
			Исключение
				
				СписокСобытий = Новый СписокЗначений;
				СписокСобытий.Добавить(Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий, ДатаСобытия",
														"ОбновлениеИнформационнойБазыСтоматология.ЗаполнитьДоговорыСоСтраховымиКомпаниями",
														"Ошибка",
														ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()),
														ТекущаяДатаСеанса()));	
				ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(СписокСобытий);
				
			КонецПопытки;
		
	     КонецЕсли;
		
	КонецЦикла;

	
КонецПроцедуры

// Процедура - Обновить предопределенные группы маркетинговых акций
//
Процедура ОбновитьПредопределенныеГруппыМаркетинговыхАкций() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Группа_Бонусы = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.СкидкиНаценки.Бонусы");

	Если НЕ ЗначениеЗаполнено(Группа_Бонусы) Тогда 
		Возврат;
	КонецЕсли;
	
	Группа_Бонусы_Объект = Группа_Бонусы.ПолучитьОбъект();
	Группа_Бонусы_Объект.Родитель = Справочники.СкидкиНаценки.ПустаяСсылка();
	Попытка
		Группа_Бонусы_Объект.ОбменДанными.Загрузка = Истина;
		Группа_Бонусы_Объект.Записать();
	Исключение
		МетаданныеСправочника 		= Метаданные.Справочники.СкидкиНаценки;
		ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
		
		// Сформируем комментарий			
		ШаблонКомментария = НСтр("ru = 'Не удалось инициализировать группу ""Бонусы""
		|по причине: %1'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонКомментария,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		// Запишем в журнал
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Инициализация групп маркетинговых акций'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,
		МетаданныеСправочника,,
		Комментарий);
	КонецПопытки;	
	
КонецПроцедуры

