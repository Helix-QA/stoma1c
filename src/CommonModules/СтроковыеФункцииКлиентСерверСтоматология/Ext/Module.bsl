		ТаблицаШириныСимволов.Область(12, 1).Расшифровка = 40 / 71;
		ТаблицаШириныСимволов.Область(13, 1).Текст = "";
		ТаблицаШириныСимволов.Область(13, 1).Расшифровка = 40 / 95;
	КонецЕсли;

	Если ПрямоеОпределение = Истина Тогда
		НайденнаяШирина = ТаблицаШириныСимволов.НайтиТекст(Символ, , , , Ложь, , Ложь);
		ШиринаСимвола = ?(НайденнаяШирина <> Неопределено, НайденнаяШирина.Расшифровка, 0.78);
	Иначе
		ШиринаСимвола = 0.80;
	КонецЕсли;
	
	Возврат ШиринаСимвола*(40/37); // корректирующий коэффициент, т.к. в 8.3 ширина символов изменилась
	
