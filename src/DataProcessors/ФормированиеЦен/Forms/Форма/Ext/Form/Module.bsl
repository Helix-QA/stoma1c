&НаСервере
// Процедура устанавливает цены или снимает актуальность цен номенклатуры.
//
Процедура УстановитьНаСервере(СнимаемАктуальность = Ложь)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	               |	ТаблицаНоменклатуры.Упаковка КАК Упаковка,
	               |	ТаблицаНоменклатуры.Цена КАК Цена,
	               |	ТаблицаНоменклатуры.Пометка КАК Пометка
	               |ПОМЕСТИТЬ ТаблицаНоменклатуры
	               |ИЗ
	               |	&ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	               |	ТаблицаНоменклатуры.Упаковка КАК Упаковка,
	               |	ТаблицаНоменклатуры.Цена КАК Цена,
	               |	ВЫБОР
	               |		КОГДА ЦеныНоменклатуры.ВидЦен ЕСТЬ NULL 
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК Дубль
	               |ИЗ
	               |	ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	               |		ПО ТаблицаНоменклатуры.Номенклатура = ЦеныНоменклатуры.Номенклатура
				   |			И (ТаблицаНоменклатуры.Упаковка = ЦеныНоменклатуры.Упаковка)
	               |			И (ЦеныНоменклатуры.ВидЦен = &ВидЦен)
	               |			И (ЦеныНоменклатуры.Период = &НаДату)
				   |			И (ЦеныНоменклатуры.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	               |ГДЕ
	               |	ТаблицаНоменклатуры.Пометка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВложенныйЗапрос.Номенклатура,
				   |	ВложенныйЗапрос.Упаковка,
	               |	ВложенныйЗапрос.Счетчик
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
				   |		ТаблицаНоменклатуры.Упаковка КАК Упаковка,
	               |		СУММА(1) КАК Счетчик
	               |	ИЗ
	               |		ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	               |	ГДЕ
	               |		ТаблицаНоменклатуры.Пометка
	               |	
	               |	СГРУППИРОВАТЬ ПО
	               |		ТаблицаНоменклатуры.Номенклатура,
				   |		ТаблицаНоменклатуры.Упаковка) КАК ВложенныйЗапрос
	               |ГДЕ
	               |	ВложенныйЗапрос.Счетчик > 1";
		
	Запрос.УстановитьПараметр("ВидЦен", Объект.ВидЦен);
	Запрос.УстановитьПараметр("НаДату", Объект.Период);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТаблицаНоменклатуры", ПолучитьТаблицуНоменклатуры());
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	// Проверка на дубли. При наличии дублей - отказ!	
	Выборка = МассивРезультатов[2].Выбрать();
	Отказ = Ложь;
	
	Пока Выборка.Следующий() Цикл
		
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru = 'Дублируется строка: %Номенклатура% с упаковкой (%Упаковка%)!'");
		Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%Номенклатура%", Выборка.Номенклатура);
		Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%Упаковка%", Выборка.Упаковка);
		Сообщение.Сообщить();
		Отказ = Истина;
		
	КонецЦикла;
	
	Если Отказ Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru = 'Установка цен отменена!'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	// Установка цен	
	Выборка = МассивРезультатов[1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Дубль Тогда
			
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru = 'Для номенклатуры %Номенклатура% (%Упаковка%) на %НаДату% уже установлена цена! Новая цена не записана!'");
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%НаДату%", Формат(Объект.Период, "ДФ=dd.MM.yy"));
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%Номенклатура%", Выборка.Номенклатура);
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%Упаковка%", Выборка.Упаковка);
			Сообщение.Сообщить();
			
			СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("Номенклатура", Выборка.Номенклатура);
			СтруктураОтбора.Вставить("Упаковка", Выборка.Упаковка);
			СтруктураОтбора.Вставить("Пометка", Истина);
			МассивСтрок = ЦеныНоменлатуры.НайтиСтроки(СтруктураОтбора);
			
			Для каждого НайденнаяСтрока Из МассивСтрок Цикл			
				НайденнаяСтрока.Картинка = 2;	
			КонецЦикла;
		
		ИначеЕсли НЕ ЗначениеЗаполнено(Выборка.Цена) И (НЕ СнимаемАктуальность) Тогда
			
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ru = 'Для номенклатуры %Номенклатура% (%Упаковка%) не указана цена!'");
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%Номенклатура%", Выборка.Номенклатура);
			Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%Упаковка%", Выборка.Упаковка);
			Сообщение.Сообщить();
			
			СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("Номенклатура", Выборка.Номенклатура);
			СтруктураОтбора.Вставить("Упаковка", Выборка.Упаковка);
			СтруктураОтбора.Вставить("Пометка", Истина);
			МассивСтрок = ЦеныНоменлатуры.НайтиСтроки(СтруктураОтбора);
			
			Для каждого НайденнаяСтрока Из МассивСтрок Цикл			
				НайденнаяСтрока.Картинка = 2;	
			КонецЦикла;
		
		Иначе
		
			НаборЗаписей = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Период.Установить(Объект.Период);
			НаборЗаписей.Отбор.ВидЦен.Установить(Объект.ВидЦен);
			НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(Объект.СтруктурнаяЕдиница);
			НаборЗаписей.Отбор.Номенклатура.Установить(Выборка.Номенклатура);
			НаборЗаписей.Отбор.Упаковка.Установить(Выборка.Упаковка);
			
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
			НоваяЗапись.Период = Объект.Период;
			НоваяЗапись.ВидЦен = Объект.ВидЦен;
			НоваяЗапись.СтруктурнаяЕдиница = Объект.СтруктурнаяЕдиница;
			Если СнимаемАктуальность Тогда			
				НоваяЗапись.Актуальность = Ложь;
				// НоваяЗапись.Цена = 0;
			Иначе
				НоваяЗапись.Актуальность = Истина;
				// НоваяЗапись.Цена = ОкруглитьЦену(НоваяЗапись.Цена, ПорядокОкругленияУстановки, ОкруглятьВБольшуюСторонуУстановки);
			КонецЕсли; 
			НоваяЗапись.Автор = Объект.Автор;
			НаборЗаписей.Записать();	
			
			СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("Номенклатура", Выборка.Номенклатура);
			СтруктураОтбора.Вставить("Упаковка", Выборка.Упаковка);
			СтруктураОтбора.Вставить("Пометка", Истина);
			МассивСтрок = ЦеныНоменлатуры.НайтиСтроки(СтруктураОтбора);
			
			Для каждого НайденнаяСтрока Из МассивСтрок Цикл			
				НайденнаяСтрока.Картинка = 1;
				НайденнаяСтрока.Цена = НоваяЗапись.Цена;
			КонецЦикла; 
			
		КонецЕсли;		
	
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
// Процедура удаляет из регистра записи по таблице ЦеныНоменклатуры
//
Процедура УдалитьНаСервере()
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
				   |	ТаблицаНоменклатуры.Упаковка КАК Упаковка,
	               |	ТаблицаНоменклатуры.Пометка КАК Пометка
	               |ПОМЕСТИТЬ ТаблицаНоменклатуры
	               |ИЗ
	               |	&ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	               |ГДЕ
	               |	ТаблицаНоменклатуры.Пометка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	               |	ЦеныНоменклатурыСрезПоследних.Упаковка КАК Упаковка,
	               |	ЦеныНоменклатурыСрезПоследних.Период
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			&НаДату,
	               |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница И ВидЦен = &ВидЦен
				   |				И (Номенклатура, Упаковка) В
	               |					(ВЫБРАТЬ
	               |						Таблица.Номенклатура,
				   |						Таблица.Упаковка
	               |					ИЗ
	               |						ТаблицаНоменклатуры КАК Таблица)) КАК ЦеныНоменклатурыСрезПоследних";
		
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);			   
	Запрос.УстановитьПараметр("ВидЦен", Объект.ВидЦен);
	Запрос.УстановитьПараметр("НаДату", Объект.Период);
	Запрос.УстановитьПараметр("ТаблицаНоменклатуры", ПолучитьТаблицуНоменклатуры());
	
	Выборка = Запрос.Выполнить().Выбрать();
    	
	Пока Выборка.Следующий() Цикл
	
		НаборЗаписей = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(Объект.СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.ВидЦен.Установить(Объект.ВидЦен);
		НаборЗаписей.Отбор.Номенклатура.Установить(Выборка.Номенклатура);
		НаборЗаписей.Отбор.Упаковка.Установить(Выборка.Упаковка);
		
		НаборЗаписей.Записать();
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Номенклатура", Выборка.Номенклатура);
		СтруктураОтбора.Вставить("Упаковка", Выборка.Упаковка);
		СтруктураОтбора.Вставить("Пометка", Истина);
		МассивСтрок = ЦеныНоменлатуры.НайтиСтроки(СтруктураОтбора);
		
		Для каждого НайденнаяСтрока Из МассивСтрок Цикл			
			НайденнаяСтрока.Картинка = 1;
		КонецЦикла;
			
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
// Процедура Цены номенклатуры при изменении.
//
Процедура ЦеныНоменлатурыПриИзменении(Элемент)
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		Элемент.ТекущиеДанные.Цена = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(Элемент.ТекущиеДанные.Цена, КэшРеквизитов.ПорядокОкругления, КэшРеквизитов.ОкруглятьВБольшуюСторону);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура Вид цены шапка при изменении.
//
Процедура ВидЦеныШапкаПриИзменении(Элемент)
	
	РеквизитыВидаЦен = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Объект.ВидЦен, "ПорядокОкругления, ОкруглятьВБольшуюСторону");
	КэшРеквизитов.Вставить("ПорядокОкругления", РеквизитыВидаЦен.ПорядокОкругления);
	КэшРеквизитов.Вставить("ОкруглятьВБольшуюСторону", РеквизитыВидаЦен.ОкруглятьВБольшуюСторону);	
	
КонецПроцедуры

