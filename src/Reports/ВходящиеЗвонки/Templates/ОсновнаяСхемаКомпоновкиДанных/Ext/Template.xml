		<field xsi:type="DataSetFieldField">
			<dataPath>Пациент</dataPath>
			<field>Пациент</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Пациент</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ИсторияЗвонков.IDЗвонка КАК IDЗвонка,
	ИсторияЗвонков.НачалоВызова КАК Период,
	ИсторияЗвонков.НомерТелефона КАК НомерТелефона,
	ИсторияЗвонков.ПользовательSip КАК ПользовательSip,
	ВЫБОР
		КОГДА ИсторияЗвонков.Пользователь = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
			ТОГДА ИсторияЗвонков.ПользовательSip
		ИНАЧЕ ИсторияЗвонков.Пользователь
	КОНЕЦ КАК Сотрудник,
	ВЫБОР
		КОГДА ИсторияЗвонков.ИсходящийЗвонок
				ИЛИ ИсторияЗвонков.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Исходящий)
			ТОГДА "Исходящий"
		ИНАЧЕ "Входящий"
	КОНЕЦ КАК ТипЗвонка,
	ИсторияЗвонков.НачалоВызова КАК НачалоВызова,
	ИсторияЗвонков.НачалоРазговора КАК НачалоРазговора,
	ИсторияЗвонков.ОкончаниеЗвонка КАК ОкончаниеЗвонка,
	ИсторияЗвонков.URLЗаписи КАК URLЗаписи,
	ИсторияЗвонков.ФайлЗаписи КАК ФайлЗаписи,
	ИсторияЗвонков.Статус КАК Статус,
	ВЫБОР
		КОГДА ИсторияЗвонков.ФайлЗаписи = ЗНАЧЕНИЕ(Справочник.Файлы.ПустаяСсылка)
			ТОГДА ""
		ИНАЧЕ "Запись"
	КОНЕЦ КАК Запись,
	ИсторияЗвонков.Контрагент КАК Контрагент,
	ИсторияЗвонков.НеОбработан КАК НеОбработан
ПОМЕСТИТЬ ВременнаяТаблицаИсторияЗвонков
ИЗ
	РегистрСведений.ИсторияВызовов КАК ИсторияЗвонков
ГДЕ
	ИсторияЗвонков.НачалоВызова &gt;= &amp;НачалоПериода
	И ИсторияЗвонков.НачалоВызова &lt;= &amp;ОкончаниеПериод
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	КонтрагентыКонтактнаяИнформация.Ссылка КАК Пациент,
	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
ПОМЕСТИТЬ ВременнаяТаблицаКИ
ИЗ
	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
ГДЕ
	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	И КонтрагентыКонтактнаяИнформация.НомерТелефона В
			(ВЫБРАТЬ
				ВременнаяТаблицаИсторияЗвонков.НомерТелефона
			ИЗ
				ВременнаяТаблицаИсторияЗвонков)

СГРУППИРОВАТЬ ПО
	КонтрагентыКонтактнаяИнформация.Ссылка,
	КонтрагентыКонтактнаяИнформация.НомерТелефона
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВременнаяТаблицаИсторияЗвонков.НомерТелефона КАК НомерТелефона,
	ВременнаяТаблицаКИ.Пациент КАК Пациент
ПОМЕСТИТЬ ВременнаяТаблицаТелефоны
ИЗ
	ВременнаяТаблицаИсторияЗвонков КАК ВременнаяТаблицаИсторияЗвонков
		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКИ КАК ВременнаяТаблицаКИ
		ПО ВременнаяТаблицаИсторияЗвонков.НомерТелефона = ВременнаяТаблицаКИ.НомерТелефона

СГРУППИРОВАТЬ ПО
	ВременнаяТаблицаИсторияЗвонков.НомерТелефона,
	ВременнаяТаблицаКИ.Пациент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВременнаяТаблицаИсторияЗвонков.IDЗвонка КАК IDЗвонка,
	ВременнаяТаблицаИсторияЗвонков.Период КАК Период,
	ВременнаяТаблицаИсторияЗвонков.НомерТелефона КАК НомерТелефона,
	ВременнаяТаблицаИсторияЗвонков.Сотрудник КАК Сотрудник,
	ВременнаяТаблицаИсторияЗвонков.ТипЗвонка КАК ТипЗвонка,
	ВременнаяТаблицаИсторияЗвонков.НачалоВызова КАК НачалоВызова,
	ВременнаяТаблицаИсторияЗвонков.НачалоРазговора КАК НачалоРазговора,
	ВременнаяТаблицаИсторияЗвонков.ОкончаниеЗвонка КАК ОкончаниеЗвонка,
	ВременнаяТаблицаИсторияЗвонков.URLЗаписи КАК URLЗаписи,
	ВременнаяТаблицаИсторияЗвонков.ФайлЗаписи КАК ФайлЗаписи,
	ВременнаяТаблицаИсторияЗвонков.Статус КАК Статус,
	ВременнаяТаблицаИсторияЗвонков.Запись КАК Запись,
	ВременнаяТаблицаИсторияЗвонков.ПользовательSip КАК ВнутреннийНомер,
	ВременнаяТаблицаИсторияЗвонков.НеОбработан КАК НеОбработан,
	ВЫБОР
		КОГДА ВременнаяТаблицаИсторияЗвонков.Контрагент ЕСТЬ NULL
				ИЛИ ВременнаяТаблицаИсторияЗвонков.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
				ИЛИ ВременнаяТаблицаИсторияЗвонков.Контрагент = НЕОПРЕДЕЛЕНО
			ТОГДА ВременнаяТаблицаТелефоны.Пациент
		ИНАЧЕ ВременнаяТаблицаИсторияЗвонков.Контрагент
	КОНЕЦ КАК Пациент
ПОМЕСТИТЬ ВременнаяТаблицаИтог
ИЗ
	ВременнаяТаблицаИсторияЗвонков КАК ВременнаяТаблицаИсторияЗвонков
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаТелефоны КАК ВременнаяТаблицаТелефоны
		ПО ВременнаяТаблицаИсторияЗвонков.НомерТелефона = ВременнаяТаблицаТелефоны.НомерТелефона
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВременнаяТаблицаИтог.Период КАК Период,
	ВременнаяТаблицаИтог.НомерТелефона КАК НомерТелефона,
	ВременнаяТаблицаИтог.Сотрудник КАК Сотрудник,
	ВременнаяТаблицаИтог.ТипЗвонка КАК ТипЗвонка,
	ВременнаяТаблицаИтог.НачалоВызова КАК НачалоВызова,
	ВременнаяТаблицаИтог.НачалоРазговора КАК НачалоРазговора,
	ВременнаяТаблицаИтог.ОкончаниеЗвонка КАК ОкончаниеЗвонка,
	ВременнаяТаблицаИтог.URLЗаписи КАК URLЗаписи,
	ВременнаяТаблицаИтог.ФайлЗаписи КАК ФайлЗаписи,
	ВременнаяТаблицаИтог.Статус КАК Статус,
	ВременнаяТаблицаИтог.Запись КАК Запись,
	ВременнаяТаблицаИтог.ВнутреннийНомер КАК ВнутреннийНомер,
	СтатусыКонтрагентовСрезПоследних.Статус КАК СтатусКлиента,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВременнаяТаблицаИтог.IDЗвонка) КАК КоличествоЗвонков,
	ВременнаяТаблицаИтог.НеОбработан КАК НеОбработан,
	ВременнаяТаблицаИтог.Пациент КАК Пациент
ИЗ
	ВременнаяТаблицаИтог КАК ВременнаяТаблицаИтог
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
				&amp;ОкончаниеПериод,
				Контрагент В
					(ВЫБРАТЬ
						ВременнаяТаблицаИтог.Пациент
					ИЗ
						ВременнаяТаблицаИтог)) КАК СтатусыКонтрагентовСрезПоследних
		ПО ВременнаяТаблицаИтог.Пациент = СтатусыКонтрагентовСрезПоследних.Контрагент

СГРУППИРОВАТЬ ПО
	ВременнаяТаблицаИтог.Период,
	ВременнаяТаблицаИтог.НомерТелефона,
	ВременнаяТаблицаИтог.Сотрудник,
	ВременнаяТаблицаИтог.ТипЗвонка,
	ВременнаяТаблицаИтог.НачалоВызова,
	ВременнаяТаблицаИтог.НачалоРазговора,
	ВременнаяТаблицаИтог.ОкончаниеЗвонка,
	ВременнаяТаблицаИтог.URLЗаписи,
	ВременнаяТаблицаИтог.ФайлЗаписи,
	ВременнаяТаблицаИтог.Статус,
	ВременнаяТаблицаИтог.Запись,
	ВременнаяТаблицаИтог.ВнутреннийНомер,
	СтатусыКонтрагентовСрезПоследних.Статус,
	ВременнаяТаблицаИтог.НеОбработан,
	ВременнаяТаблицаИтог.Пациент</query>
	</dataSet>
	<totalField>
		<dataPath>КоличествоЗвонков</dataPath>
		<expression>Сумма(КоличествоЗвонков)</expression>
		<group>Сотрудник</group>
		<group>Сотрудник Иерархия</group>
		<group>ТипЗвонка</group>
		<group>ОбщийИтог</group>
	</totalField>
	<parameter>
