
#Область СлужебныйПрограммныйИнтерфейс

// Процедура создает значения по умолчанию справочника "КлассификаторДолжностей"
//
Процедура СоздатьЗначенияПоУмолчанию() Экспорт
	
	Макет = Справочники.КлассификаторДолжностей.ПолучитьМакет("ДолжностиВрачейПоИЭМК");
	
	Для Х=1 по Макет.ВысотаТаблицы Цикл
		
		Ячейка1 = "R" + СтрЗаменить(Строка(Х),Символы.НПП,"")+"C1";
		Ячейка2 = "R" + СтрЗаменить(Строка(Х),Символы.НПП,"")+"C2";
		
		НаименованиеДолжности	 = Макет.Область(Ячейка2).Текст;
		КодДолжности		     = Макет.Область(Ячейка1).Текст; 
		
		КодЭлемента = Формат(Число(КодДолжности), "ЧЦ=9; ЧВН=; ЧГ=0");
		
		Если НЕ ЗначениеЗаполнено(Справочники.КлассификаторДолжностей.НайтиПоКоду(КодЭлемента)) Тогда
			ЭлементСправочника              = Справочники.КлассификаторДолжностей.СоздатьЭлемент();
			ЭлементСправочника.Код          = КодЭлемента;
			ЭлементСправочника.Наименование = НаименованиеДолжности;
			ЭлементСправочника.КодОИД       = КодДолжности;
			ЭлементСправочника.Записать();
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура создает значения из справочника oid:1.2.643.5.1.13.13.11.1002 ИЭМК "КлассификаторДолжностей"
//
Процедура ЗаполнитьСправочникДолжностей(Параметры) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Для Каждого Элемент Из Параметры Цикл
		Пропустить = Ложь;
		
		Для Каждого ЭлМассива Из Элемент.contains Цикл
			Если (ЭлМассива.code = "GROUP" И ЭлМассива.display = "1") Или (ЭлМассива.code = "ACTUAL" И ЭлМассива.display = "0") Тогда
				Пропустить = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если Не Пропустить Тогда
			КодЭлемента = Формат(Число(Элемент.code), "ЧЦ=9; ЧВН=; ЧГ=0");
			Если ЗначениеЗаполнено(Справочники.КлассификаторДолжностей.НайтиПоКоду(КодЭлемента)) Тогда
				Если Элемент.display <> НРег(Справочники.КлассификаторДолжностей.НайтиПоКоду(КодЭлемента).Наименование) Тогда
					ЭлементСправочника = Справочники.КлассификаторДолжностей.НайтиПоКоду(КодЭлемента).ПолучитьОбъект();
					ЭлементСправочника.Наименование = Лев(Врег(Лев(Элемент.display,1))+ Нрег(Сред(Элемент.display,2)), 100);
					ЭлементСправочника.КодОИД = Элемент.code;
					ЭлементСправочника.Записать();
				КонецЕсли;
			Иначе
				ЭлементСправочника = Справочники.КлассификаторДолжностей.СоздатьЭлемент();
				ЭлементСправочника.Наименование = Лев(Врег(Лев(Элемент.display,1))+ Нрег(Сред(Элемент.display,2)), 100);
				ЭлементСправочника.КодОИД = Элемент.code;
				ЭлементСправочника.Код = КодЭлемента;
				ЭлементСправочника.Записать();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти
