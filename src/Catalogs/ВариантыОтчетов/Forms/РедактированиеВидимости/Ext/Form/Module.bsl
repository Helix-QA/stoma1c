&НаКлиенте
// Процедура - Доступность пользователи при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДоступностьПользователиПриИзменении(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		РедактированиеПроизводилось = Ложь;
		Для Каждого СтрокаРедактирование Из ДоступностьРедактирование Цикл 
			Если СтрокаРедактирование.ПользовательРоль = ТекущиеДанные.Пользователь Тогда
				РедактированиеПроизводилось = Истина;
				Если НЕ СтрокаРедактирование.Доступность = ТекущиеДанные.Видимость Тогда 
					ДоступностьРедактирование.Удалить(СтрокаРедактирование);
				КонецЕсли;	
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		Если НЕ РедактированиеПроизводилось И НЕ ТекущиеДанные.Видимость = КешАктивнойСтроки.Видимость Тогда 
			СтрокаРедактирования = ДоступностьРедактирование.Добавить();
			СтрокаРедактирования.ПользовательРоль 	= ТекущиеДанные.Пользователь;
			СтрокаРедактирования.Представление 		= ТекущиеДанные.Представление;
			СтрокаРедактирования.Доступность 		= ТекущиеДанные.Видимость;
		КонецЕсли;	
	КонецЕсли;
	
	ПодсчитатьИтогиПоДоступности();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Доступность роли при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДоступностьРолиПриИзменении(Элемент)
	
	РольПользователей = Неопределено;
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда
		РедактированиеПроизводилось = Ложь;
		Для Каждого СтрокаРедактирование Из ДоступностьРедактирование Цикл 
			Если СтрокаРедактирование.ПользовательРоль = ТекущиеДанные.Пользователь Тогда
				РедактированиеПроизводилось = Истина;
				Если НЕ СтрокаРедактирование.Доступность = ТекущиеДанные.Видимость Тогда 
					ДоступностьРедактирование.Удалить(СтрокаРедактирование);
					РольПользователей = ТекущиеДанные.Пользователь;												
				КонецЕсли;	
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		Если НЕ РедактированиеПроизводилось И НЕ ТекущиеДанные.Видимость = КешАктивнойСтроки.Видимость Тогда 
			СтрокаРедактирования = ДоступностьРедактирование.Добавить();
			СтрокаРедактирования.ПользовательРоль 	= ТекущиеДанные.Пользователь;
			СтрокаРедактирования.Представление 		= ТекущиеДанные.Представление;
			СтрокаРедактирования.Доступность 		= ТекущиеДанные.Видимость;
			РольПользователей 						= ТекущиеДанные.Пользователь;								
		КонецЕсли;
		Если ЗначениеЗаполнено(РольПользователей) Тогда 
			УстановитьФлагиПользователямПоРоли(РольПользователей, ТекущиеДанные.Видимость);
		КонецЕсли;	
	КонецЕсли;
	
	ПодсчитатьИтогиПоДоступности();

КонецПроцедуры

&НаКлиенте
// Процедура - Доступность пользователи при активизации ячейки
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДоступностьПользователиПриАктивизацииЯчейки(Элемент)
	
	// Кешируем последнюю активную строку
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда 
		КешАктивнойСтроки = Новый Структура("Видимость, Пользователь, Представление", ТекущиеДанные.Видимость, ТекущиеДанные.Пользователь, ТекущиеДанные.Представление);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Доступность роли при активизации ячейки
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДоступностьРолиПриАктивизацииЯчейки(Элемент)
	
	// Кешируем последнюю активную строку
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда 
		КешАктивнойСтроки = Новый Структура("Видимость, Пользователь, Представление", ТекущиеДанные.Видимость, ТекущиеДанные.Пользователь, ТекущиеДанные.Представление);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Группа пользователи роли при смене страницы
//
// Параметры:
//  Элемент			 - 	 - 
//  ТекущаяСтраница	 - 	 - 
//
Процедура ГруппаПользователиРолиПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница = Элементы.СтраницаПользователи Тогда 
		// Кешируем последнюю активную строку
		ТекущиеДанные = Элементы.ДоступностьПользователи.ТекущиеДанные;
		Если НЕ ТекущиеДанные = Неопределено Тогда 
			КешАктивнойСтроки = Новый Структура("Видимость, Пользователь, Представление", ТекущиеДанные.Видимость, ТекущиеДанные.Пользователь, ТекущиеДанные.Представление);
		КонецЕсли;
	Иначе 
		// Кешируем последнюю активную строку
		ТекущиеДанные = Элементы.ДоступностьРоли.ТекущиеДанные;
		Если НЕ ТекущиеДанные = Неопределено Тогда 
			КешАктивнойСтроки = Новый Структура("Видимость, Пользователь, Представление", ТекущиеДанные.Видимость, ТекущиеДанные.Пользователь, ТекущиеДанные.Представление);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Установить флаги пользователям по роли
//
// Параметры:
//  РольПользователей	 - 	 - 
//  Доступность			 - 	 - 
//
Процедура УстановитьФлагиПользователямПоРоли(РольПользователей, Доступность)
	
	МассивПользоватлейИсключение = Новый Массив;
	Для Каждого СтрокаРедактирования Из ДоступностьРедактирование Цикл 
		Если ЗначениеЗаполнено(СтрокаРедактирования.ПользовательРоль) И ТипЗнч(СтрокаРедактирования.ПользовательРоль) = Тип("СправочникСсылка.Сотрудники") Тогда 
			МассивПользоватлейИсключение.Добавить(СтрокаРедактирования.ПользовательРоль);
		КонецЕсли;	
	КонецЦикла;	
	ПользователиРоли = ВернутьПользователейПоРоли(РольПользователей, МассивПользоватлейИсключение, ВариантОтчета);
	Если ЗначениеЗаполнено(ПользователиРоли) Тогда 
		Для Каждого СтрокаДоступностьПользователей Из ДоступностьПользователей Цикл 
			Если НЕ ПользователиРоли.Найти(СтрокаДоступностьПользователей.Пользователь) = Неопределено Тогда 
				СтрокаДоступностьПользователей.Видимость = Доступность;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Вернуть пользователей по роли
//
// Параметры:
//  РольПользователей	 - 	 - 
//  МассивИсключений	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьПользователейПоРоли(РольПользователей, МассивИсключений, ВариантОтчета)
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Пользователь
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ИдентификаторПользователяИБ <> &Идентификатор
	|	И Сотрудники.Роль = &РольПользователей
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Ссылка В (&МассивИсключений)
	|	И НЕ Сотрудники.Ссылка В
	|				(ВЫБРАТЬ
	|					НастройкиВариантовОтчетов.Пользователь
	|				ИЗ
	|					РегистрСведений.НастройкиВариантовОтчетов КАК НастройкиВариантовОтчетов
	|				ГДЕ
	|					НастройкиВариантовОтчетов.Вариант = &Вариант
	|					И НастройкиВариантовОтчетов.Подсистема = ЗНАЧЕНИЕ(Справочник.ИдентификаторыОбъектовМетаданных.ПустаяСсылка)
	|					И НастройкиВариантовОтчетов.Пользователь ССЫЛКА Справочник.Сотрудники
	|					И НЕ НастройкиВариантовОтчетов.Пользователь = НЕОПРЕДЕЛЕНО
	|					И НЕ НастройкиВариантовОтчетов.Пользователь = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка))";
	
	Запрос.УстановитьПараметр("Идентификатор"		, Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
	Запрос.УстановитьПараметр("МассивИсключений"	, МассивИсключений);
	Запрос.УстановитьПараметр("РольПользователей"	, РольПользователей);
	Запрос.УстановитьПараметр("Вариант"				, ВариантОтчета);
		
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Пользователь");
	
КонецФункции

