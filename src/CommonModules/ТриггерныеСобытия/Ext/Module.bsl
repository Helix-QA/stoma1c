			СтрокаЗапланированныйТриггер.МассивНеобработанныхКонтрагентов 	= РеестрЗапланированных.ВыгрузитьКолонку("Контрагент");
			ПараметрыКлюча 			= Новый Структура("Период, Контрагент", СтрокаОбъектСобытия.ДатаСменыСтатуса, СтрокаОбъектСобытия.Контрагент);
			ПараметрыМассив = Новый Массив;
			ПараметрыМассив.Добавить(ПараметрыКлюча); 		
			КлючЗаписи 				= Новый("РегистрСведенийКлючЗаписи.СтатусыКонтрагентов", ПараметрыМассив);
			ЗарегистрироватьСобытие(СтрокаЗапланированныйТриггер, , Истина, КлючЗаписи, МассивИсключительноРегламентныхТриггеров);
		КонецЦикла;	
