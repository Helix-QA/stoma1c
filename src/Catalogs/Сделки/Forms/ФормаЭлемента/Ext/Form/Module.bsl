// Процедура, устанавливает видимость и оформление, кнопки и группы "результат сделки".
//
Процедура УстановитьВидимостьРезультатаСделки()
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	// Устанавливаем свойства по умолчанию
	Элементы.ОткрытьПродажу.Видимость 					= Ложь;	
	//Элементы.УстановитьОтказ.Видимость 					= Истина;
	
	Элементы.ГруппаЭтапаОтказ.ЦветФона 					= Новый Цвет(238, 241, 246); 
	Элементы.УстановитьОтказ.ЦветТекста 				= Новый Цвет(117,117,117);
	Элементы.ГруппаЭтапаУспех.ЦветФона 					= Новый Цвет(238, 241, 246); 
	Элементы.УстановитьУспех.ЦветТекста 				= Новый Цвет(117,117,117);
	
	Элементы.УстановитьУспех.Заголовок 					= НСтр("ru = 'Успех'; en = 'Success'");
	Элементы.УстановитьОтказ.Заголовок 					= ?(ВидСделкиПредопределенный И НЕ ЗначениеЗаполнено(Объект.РезультатСделки), Строка(ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался")), НСтр("ru = 'Отказ'; en = 'Refusal'"));
	
	// Устанавливаем актуальные свойства	
	ДопустимОтказ 										= ?(ВидСделкиПредопределенный, Справочники.Сделки.ДопустимОтказСогласноТекущегоЭтапа(Объект.Ссылка, ВидСделкиПредопределенный), Истина);
	
	Элементы.УстановитьУспех.Доступность 				= НЕ ВидСделкиПредопределенный ИЛИ Объект.РезультатСделки = Перечисления.РезультатыСделок.Успех;
	Элементы.УстановитьОтказ.Доступность 				= НЕ ВидСделкиПредопределенный ИЛИ (ДопустимОтказ И НЕ Объект.РезультатСделки = Перечисления.РезультатыСделок.Отказ);

	Элементы.ГруппаЭтапаУспех.Видимость 				= НЕ ВидСделкиПредопределенный ИЛИ Объект.РезультатСделки = Перечисления.РезультатыСделок.Успех;				
	Элементы.ГруппаЭтапаОтказ.Видимость 				= НЕ ВидСделкиПредопределенный ИЛИ Объект.РезультатСделки = Перечисления.РезультатыСделок.Отказ ИЛИ ДопустимОтказ;				
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ЗначениеЗаполнено(Объект.РезультатСделки) Тогда
			Если Объект.РезультатСделки = Перечисления.РезультатыСделок.Успех Тогда
				Элементы.ГруппаЭтапаОтказ.Видимость 	= НЕ ВидСделкиПредопределенный;
				СтруктураНаименований 					= Справочники.ВидыСделок.ПолучитьНаименованияЗавершающихЭтаповСделки(Объект.ВидСделки);				
				Элементы.ГруппаЭтапаУспех.ЦветФона 		= Новый Цвет(72, 193, 123); 
				Элементы.УстановитьУспех.ЦветТекста 	= Новый Цвет(255, 255, 255);
				Элементы.УстановитьУспех.Заголовок 		= СтруктураНаименований.НаименованиеЭтапаУспех;
				//Элементы.ОткрытьПродажу.Видимость 		= Истина;
				КомандаУспеха = Команды.Найти("РезультатСделкиУспешно");
				Если ЗначениеЗаполнено(Объект.Прием) Тогда 
					НомерПродажи = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(ОбщегоНазначения.ПолучитьЗначениеРеквизита(Объект.Прием, "Номер"), "");
					Элементы.УстановитьУспех.Заголовок 	= Элементы.УстановитьУспех.Заголовок + ": " + НСтр("ru = 'Прием № '; en = 'Reception №'") + НомерПродажи;
					Если НЕ КомандаУспеха = Неопределено Тогда 
						КомандаУспеха.Подсказка = НСтр("ru = 'Открыть приём'; en = 'Open appointment'");
					КонецЕсли;	
					//Элементы.ОткрытьПродажу.Заголовок 	= НСтр("ru = 'Прием № '; en = 'Reception №'") + НомерПродажи;
					//Элементы.УстановитьОтказ.Доступность = Ложь;
				Иначе
					Элементы.УстановитьУспех.Заголовок 	= Элементы.УстановитьУспех.Заголовок + ": " + НСтр("ru = '(Прием не указан)'; en = '(No Reception specified)'");
					Если НЕ КомандаУспеха = Неопределено Тогда 
						КомандаУспеха.Подсказка = НСтр("ru = 'Выбрать приём'; en = 'Choose an appointment'");
					КонецЕсли;						
					//Элементы.ОткрытьПродажу.Заголовок 	= НСтр("ru = '(Прием не указан)'; en = '(No Reception specified)'");
				КонецЕсли;
			Иначе
				Элементы.ГруппаЭтапаОтказ.ЦветФона 		= Новый Цвет(246, 110, 110); 
				Элементы.УстановитьОтказ.ЦветТекста 	= Новый Цвет(255, 255, 255);
				Элементы.УстановитьОтказ.Заголовок 		= Строка(Объект.РезультатСделки) + ?(ЗначениеЗаполнено(Объект.ПричинаОтказа), ": " + Строка(Объект.ПричинаОтказа), "");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, УстановитьВидимостьФормы.
//
Процедура УстановитьВидимостьФормыНаСервере()
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		// ЭтаФорма.АвтоЗаголовок = Истина;		
		ЭтаФорма.Заголовок = Строка(Объект.Ссылка) + " (Сделка)";
		
		// Эмуляция RLS т.к. на просмотр не действует.
		// При записи все равно RLS не позволит записать и что бы не нервировать пользователя, нужно заблокировать форму сразу.
		// Редактировать можно только свои сделки или новые сделки.
		// С дополнительными ролями, можно менять все сделки.
		Если ЗначениеЗаполнено(Объект.Менеджер) 
			И ЭтотОбъект.ТекущийПользователь.Роль = Перечисления.РольПользователя.Врач
			И Объект.Менеджер <> ЭтотОбъект.ТекущийПользователь Тогда
			
			РазрешеноИзменение = Ложь;
			
			// У сотрудника могут быть расширенные права. Подробнее см. все роли.
			Если РольДоступна("ДобавлениеИзменениеСделокВсех")
				ИЛИ РольДоступна("ПолныеПрава")
				ИЛИ РольДоступна("АдминистраторСистемы") Тогда
				
				РазрешеноИзменение = Истина;
				
			КонецЕсли;
			
			Если Не РазрешеноИзменение Тогда
				
				ЭтаФорма.ТолькоПросмотр = Истина;
				Элементы.ГруппаСтатусыШапка.Доступность = Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
	Иначе
		// ЭтаФорма.АвтоЗаголовок = Ложь;
		ЭтаФорма.Заголовок = ?(ЗначениеЗаполнено(Объект.Код), НСтр("ru = 'Новая сделка № '; en = 'New deal'") + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Объект.Код, ""), НСтр("ru = 'Новая сделка № '; en = 'New deal'")) + " (" + СокрЛП(Строка(Объект.ВидСделки)) + ")";
	КонецЕсли;
	
	ИсточникИнформацииЭтоДругойПациент = (Объект.ИсточникИнформации = Справочники.РекламныеИсточники.ДругойПациент);
	Элементы.ИсточникИнформацииЗначение.Видимость = ИсточникИнформацииЭтоДругойПациент;	
	Если ИсточникИнформацииЭтоДругойПациент Тогда
		Элементы.ИсточникИнформацииЗначение.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	КонецЕсли;
			
	Элементы.ГруппаФИОСтатус.Видимость   = ЗначениеЗаполнено(Объект.Контрагент);
	Элементы.ГруппаФИОСоздание.Видимость = НЕ ЗначениеЗаполнено(Объект.Контрагент) И Объект.ВидСделки <> ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПостоянныеПациенты");	 
	Элементы.Контрагент.Видимость        = НЕ ЗначениеЗаполнено(Объект.Контрагент) И Объект.ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПостоянныеПациенты");
		
	УстановитьВидимостьРезультатаСделки();
	
КонецПроцедуры

