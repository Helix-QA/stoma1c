// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция OKTELL_ТестированиеСервера(Сервер, Порт, Логин, Пароль, ОписаниеОшибки = "") Экспорт
	
	MSXMLЗапрос = "name=Helix_Test&async=1&timeout=0";
	
	ФлагHTTPS = СтрНайти(Сервер, "https://");
	
	СайтАдрес = СтрЗаменить(Сервер	 , "http://" , "");
	СайтАдрес = СтрЗаменить(СайтАдрес, "https://", "");
	
	Попытка
		
	   Если ФлагHTTPS > 0 Тогда
		   Соединение = Новый HTTPСоединение(СайтАдрес, Порт, Логин, Пароль,,, Новый ЗащищенноеСоединениеOpenSSL());
	   Иначе
		   Соединение = Новый HTTPСоединение(СайтАдрес, Порт, Логин, Пароль);
	   КонецЕсли;
	   
	   HTTPЗапрос = Новый HTTPЗапрос("/execsvcscriptplain", ПолучитьЗаголовкиPOSTЗапроса());
	   HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
	   
	   // Отправка POST-запроса и получение ответа
	   СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
	   
	   Если СтруктураОтвета.КодСостояния <> 200 Тогда
		   ОписаниеОшибки = "Ошибка " + СтруктураОтвета.КодСостояния;
		   Возврат Ложь;
	   КонецЕсли;
	   
   Исключение
	   
	   ИнформацияОбОшибке = ИнформацияОбОшибке();
	   ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
	   Возврат Ложь;
	   
   КонецПопытки;
   
   Возврат Истина;
   
КонецФункции

// Функция - OKTELL событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция OKTELL_СобытиеЗвонок(ПОIPТелефонии, ИмяФункции, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	Результат = Ложь;
	
	УнифицированнаяСтруктураСобытия 								= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 					= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 			= Истина;
	УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова 			= ТекущаяДатаСеанса();
	УнифицированнаяСтруктураСобытия.IDЗвонка 						= Строка(Новый УникальныйИдентификатор);		
	
	Если ИмяФункции = "IncomingCall" Тогда
		
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= ПараметрыJSON.ExternalNumber;
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ?(ПараметрыJSON.Свойство("InternalNumberGroup"), ПараметрыJSON.InternalNumberGroup, Неопределено);
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 			= Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= Перечисления.СтатусыЗвонка.Вызов;			
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 		= ТекущаяДата();
		
		Результат = СобытиеЗвонокДозвон(, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли ИмяФункции = "IncomingCallTalkStart" Тогда
		
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= ПараметрыJSON.ExternalNumber;
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ПараметрыJSON.InternalNumber;
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 			= Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= Перечисления.СтатусыЗвонка.Разговор;			
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов	 		= ТекущаяДата();
		
		Результат = СобытиеЗвонокСоединение(, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли ИмяФункции = "IncomingCallCompleted" Тогда
		
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.ExternalNumber))));
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ?(ПараметрыJSON.InternalNumber = "", Неопределено, СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.InternalNumber)))));
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 			= Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= ?(НЕ ЗначениеЗаполнено(ПараметрыJSON.Duration), Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.Завершен);			
		УнифицированнаяСтруктураСобытия.ПринятДругимАбонентомГруппы = Ложь;
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 		= УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова - ПараметрыJSON.Duration;
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 			= ?(ЗначениеЗаполнено(ПараметрыJSON.Duration), УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова - ПараметрыJSON.Duration, Дата(1,1,1));
		УнифицированнаяСтруктураСобытия.Продолжительность	 		= ПараметрыJSON.Duration;		
		УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка 		= ПараметрыJSON.URLRecord;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 		= НЕ ЗначениеЗаполнено(ПараметрыJSON.Duration);						
		
		Результат = СобытиеЗвонокЗавершен(, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
				
	ИначеЕсли ИмяФункции = "OutgoingCallCompleted" Тогда
		
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.InternalNumber))));
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.ExternalNumber))));
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 			= Перечисления.ВариантыНаправленияВызова.Исходящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= ?(НЕ ЗначениеЗаполнено(ПараметрыJSON.Duration), Перечисления.СтатусыЗвонка.НеДозвон, Перечисления.СтатусыЗвонка.Завершен);			
		УнифицированнаяСтруктураСобытия.ПринятДругимАбонентомГруппы = Ложь;
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 		= УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова - ПараметрыJSON.Duration;
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 			= ?(ЗначениеЗаполнено(ПараметрыJSON.Duration), УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова - ПараметрыJSON.Duration, Дата(1,1,1));		
		УнифицированнаяСтруктураСобытия.Продолжительность	 		= ПараметрыJSON.Duration;		
		УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка 		= ПараметрыJSON.URLRecord;
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 		= Ложь;						
							
		Результат = СобытиеЗвонокЗавершен(, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	Иначе
		ОписаниеОшибки = "Функция не распознана '" + ИмяФункции + "'";
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция OKTELL_ИсходящийЗвонокОсуществить(ПОIPТелефонии, ВнутреннийНомерТелефона, ВнешнийНомерТелефона, Знач Контрагент = Неопределено, Знач Сотрудник = Неопределено, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Порт")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Логин")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Пароль") Тогда
		
		ОписаниеОшибки = "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		Возврат Ложь;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ExternalNumber", ВнешнийНомерТелефона);
	СтруктураПараметров.Вставить("InternalNumber", ВнутреннийНомерТелефона);
	СтруктураПараметров.Вставить("ID_Klient"	 , Строка(?(ЗначениеЗаполнено(Контрагент), Контрагент.УникальныйИдентификатор(), Неопределено)));
	СтруктураПараметров.Вставить("ID_Manager"	 , Строка(?(ЗначениеЗаполнено(Сотрудник), Сотрудник.УникальныйИдентификатор(), ПараметрыСеанса.ТекущийПользователь.УникальныйИдентификатор())));
	
	MSXMLЗапрос = "name=Helix_OutgoingCall&startparam1=" + КодироватьВJSON(СтруктураПараметров, Ложь) + "&async=1&timeout=0";
	
	ФлагHTTPS = СтрНайти(IPТелефонияПараметры.Сервер, "https://");
	
	СайтАдрес = СтрЗаменить(IPТелефонияПараметры.Сервер, "http://", "");
	СайтАдрес = СтрЗаменить(СайтАдрес				   , "https://", "");
	
	Попытка
			   	   
	   Если ФлагHTTPS > 0 Тогда
		   Соединение = Новый HTTPСоединение(СайтАдрес, IPТелефонияПараметры.Порт, IPТелефонияПараметры.Логин, IPТелефонияПараметры.Пароль,,, Новый ЗащищенноеСоединениеOpenSSL());
	   Иначе
		   Соединение = Новый HTTPСоединение(СайтАдрес, IPТелефонияПараметры.Порт, IPТелефонияПараметры.Логин, IPТелефонияПараметры.Пароль);
	   КонецЕсли;
	   
	   HTTPЗапрос = Новый HTTPЗапрос("/execsvcscriptplain", ПолучитьЗаголовкиPOSTЗапроса());
	   HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
	   
	   // Отправка POST-запроса и получение ответа
	   СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
	   
	   Если СтруктураОтвета.КодСостояния <> 200 Тогда
		   ОписаниеОшибки = "Ошибка сервиса IP-телефонии: " + СтруктураОтвета.КодСостояния;
		   Возврат Ложь;
	   КонецЕсли;
	   
	   ОтветHTTP 	 = СтруктураОтвета.ПолучитьТелоКакСтроку();
	   ПараметрыJSON = ДекодироватьИзJSON(ОтветHTTP);
	   
	   Если ПараметрыJSON.Success <> Истина Тогда
		   ОписаниеОшибки = "Ошибка при выполнении операции сервиса IP-телефонии: " + ПараметрыJSON.Description;
		   Возврат Ложь;
	   КонецЕсли;
	   
   Исключение
	   
	   ИнформацияОбОшибке = ИнформацияОбОшибке();
	   ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
	   Возврат Ложь;
	   
   КонецПопытки;
   
   Возврат Истина;
   
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция OKTELL_ПереадресацияЗвонка(ПОIPТелефонии, IDЗвонка, СНомерТелефона, НаНомерТелефона, ОписаниеОшибки = "")
		
	Попытка
			   
		ВызватьИсключение "Не поддерживаемая функциональность";
		
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

