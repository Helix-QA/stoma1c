	               |			&Период,
	               |			ВидДокумента = &ВидДокумента
	               |				И Физлицо = &Физлицо) КАК ДокументыФизическихЛицСрезПоследних";
	Запрос.УстановитьПараметр("Период", ВладелецФайла.Дата);
	Запрос.УстановитьПараметр("Физлицо", ВладелецФайла.Контрагент);
	Запрос.УстановитьПараметр("ВидДокумента", Справочники.ВидыДокументовФизическихЛиц.НайтиПоНаименованию(МассивСтрок[МассивСтрок.Количество() - 1]));
	ТаблицаЗначений = Запрос.Выполнить().Выгрузить();
	Если ТаблицаЗначений.Количество() > 0 Тогда
		Результат = ТаблицаЗначений[0].Представление;
	КонецЕсли;
	
	Если Результат = Null Тогда
		ВызватьИсключение("Указанное вид удостоверения личности не обнаружен");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

//
//
Функция ПолучитьПаспортныеДанныеКлиента(ВладелецФайла, Контрагент = Неопределено)
	
	Если Контрагент <> Неопределено Тогда 
		Если Контрагент = "Контрагент" Тогда 
			Ссылка = ВладелецФайла.Контрагент;
		ИначеЕсли Контрагент = "ЗаконныйПредставитель" Тогда	
			Ссылка = ВладелецФайла.ЗаконныйПредставитель;
		КонецЕсли;
	Иначе 
		Ссылка = Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	
	Запрос = НОвый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	                      |	ДокументыФизическихЛиц.Представление
	                      |ИЗ
	                      |	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
	                      |ГДЕ
	                      |	ДокументыФизическихЛиц.Физлицо = &Физлицо");
	Запрос.УстановитьПараметр("Физлицо", Ссылка);
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда
		Возврат Результат[0].Представление;
	Иначе
		Возврат "";
	КонецЕсли; 
	
КонецФункции

#КонецОбласти
