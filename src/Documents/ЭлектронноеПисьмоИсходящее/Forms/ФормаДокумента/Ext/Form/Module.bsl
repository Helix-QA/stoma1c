////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
// Процедура, обработчки события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Обработчик подсистемы "Дополнительные отчеты и обработки"
	ДополнительныеОтчетыИОбработкиСтоматология.ПриСозданииНаСервере(ЭтаФорма);	
	
	ЭтоНовыйДокумент = Объект.Ссылка.Пустая();
	ПисьмоОтправлено = ?(ЭтоНовыйДокумент, Ложь, (Объект.СтатусПисьма = Перечисления.СтатусыИсходящегоЭлектронногоПисьма.Отправлено));
	
	Если ЭтоНовыйДокумент Тогда
		
		Если Не ЗначениеЗаполнено(Объект.Ответственный) Тогда
			
			Объект.Ответственный = ПараметрыСеанса.ТекущийПользователь;	
			
		КонецЕсли;
		
		Если Параметры.Свойство("ЗначенияЗаполнения") И Параметры.ЗначенияЗаполнения.Свойство("ШаблонПисьма") Тогда
			
			ВыбранныйШаблон = Параметры.ЗначенияЗаполнения.ШаблонПисьма;
			Объект.ТекстHTML = ВыбранныйШаблон.ТекстHTML;
			
		КонецЕсли;
		
		 // Необходимо для отправки с формы клиента
		 Если Параметры.Свойство("Получатель") И Параметры.Свойство("АдресЭП") 
		   И ЗначениеЗаполнено(Параметры.Получатель) И ЗначениеЗаполнено(Параметры.АдресЭП) Тогда
		   
		   Получатель               = Объект.ПолучателиПисьма.Добавить();
		   Получатель.Адрес         = Параметры.АдресЭП; 
		   Получатель.Контакт       = Параметры.Получатель;
		   Получатель.Представление = Параметры.Получатель.Наименование;
		   
		   СформироватьПредставленияКонтактов(); 
		   
		 КонецЕсли;
		
		ОбработатьИзменяемыеЗначения();
		
	КонецЕсли;
	
	// Формирует переключатель закладок
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("Письмо"  , "ГруппаПисьмо");
	СтруктураМеню.Вставить("Шаблоны" , "ГруппаШаблоны");
	СтруктураМеню.Вставить("Свойства", "ГруппаСвойства");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	#Область Обработка_вложений_письма
	
	Если ЭтоНовыйДокумент Тогда
		
		ПереноситьВложения = Ложь;
		Если Параметры.Свойство("ПереноситьВложения") Тогда
			ПереноситьВложения = Параметры.ПереноситьВложения;
		КонецЕсли;
		
		Если ПереноситьВложения Тогда
			ПеренестиВложенияИзДругогоПисьма(Объект.Предмет);
		ИначеЕсли Параметры.Свойство("ЗначенияЗаполнения") И Параметры.ЗначенияЗаполнения.Свойство("Вложения") Тогда
			// Заполняем переданные вложения
			ТаблицаВложений = ДанныеФормыВЗначение(Вложения, Тип("ТаблицаЗначений"));
			Для Каждого ПереданноеВложение Из Параметры.ЗначенияЗаполнения.Вложения Цикл
				СтрокаВложения 						= ТаблицаВложений.Добавить();
				СтрокаВложения.ИмяФайла 			= ПереданноеВложение.Представление;
				СтрокаВложения.ИмяФайлаНаКомпьютере = ПереданноеВложение.Значение;
				Расширение = ФайловыеФункцииКлиентСервер.ПолучитьРасширениеФайла(СтрокаВложения.ИмяФайла);
				СтрокаВложения.ИндексКартинки 		= РаботаСФайламиСлужебныйКлиентСервер.ПолучитьИндексПиктограммыФайла(Расширение);
				СтрокаВложения.Расположение 		= 4;	// из временного хранилища
			КонецЦикла;
			ЗначениеВДанныеФормы(ТаблицаВложений, Вложения);
		КонецЕсли;
		
	Иначе
		
		ПолучитьВложенияПисьма();
		
	КонецЕсли;
	
	#КонецОбласти //Область Обработка_вложений_письма
	
	
	УстановитьСписокВыбораДоступныхУчетныхЗаписей();
	// Сохранение вводимых значений
	СохранениеВводимыхЗначений.ЗаполнитьСписокВыбора(ЭтаФорма, ЭлементыДляСохранения(), ЭтаФорма.ИмяФормы);

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Документ = Элементы.ПолеHTMLДокумента.Документ;
	Объект.ТекстHTML = ?(Документ.body.innerHTML = "", "&nbsp;", Документ.body.innerHTML);
	Объект.Текст	 =   Документ.body.innerText;
	
	// Операции с вложениями
	#Если Не ВебКлиент Тогда
	Для Каждого Стр Из Вложения Цикл
		Если Стр.Расположение = 2 Тогда
			Данные = Новый ДвоичныеДанные(Стр.ИмяФайлаНаКомпьютере);
			Стр.ИмяФайлаНаКомпьютере = ПоместитьВоВременноеХранилище(Данные, "");
			Стр.Расположение = 4;
		КонецЕсли;
	КонецЦикла;
	#КонецЕсли

	Объект.ЕстьВложения = (Вложения.Количество() <> 0);
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Если письмо адресуется только одному получателю, и он в поле "Кому" - пишем его в реквизит Предмет
	КоличествоПолучателей = ТекущийОбъект.ПолучателиПисьма.Количество();
	КоличествоПолучателейКопий = ТекущийОбъект.ПолучателиКопий.Количество() + ТекущийОбъект.ПолучателиСкрытыхКопий.Количество();
		
	Если КоличествоПолучателей = 1 И КоличествоПолучателейКопий = 0 Тогда
		ТекущийОбъект.Предмет = Объект.ПолучателиПисьма[0].Контакт;
	Иначе
		ТекущийОбъект.Предмет = Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ТекстHTML) Тогда
		Объект.ТипТекста = Перечисления.ТипыТекстовЭлектронныхПисем.HTML;
	Иначе
		Объект.ТипТекста = Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ЗаписатьВложения();
	Оповестить("ИзмененоЭлектронноеПисьмо", Объект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	//Заголовок= "Введите текст!";
	Список = Элементы.КомандаformatBlock.СписокВыбора;
	Список.Добавить("<p>", "Обычный");
	Список.Добавить("<h1>", "Заголовок 1");
	Список.Добавить("<h2>", "Заголовок 2");
	Список.Добавить("<h3>", "Заголовок 3");
	Список.Добавить("<h4>", "Заголовок 4");
	Список.Добавить("<h5>", "Заголовок 5");
	Список.Добавить("<h6>", "Заголовок 6");
	Список.Добавить("<pre>", "Форматированный");
	Список.Добавить("<address>", "Адрес");
	ТекЭлемент = Список.НайтиПоИдентификатору(0);
	СтилиТекста = ТекЭлемент.Значение;

	// Заполнение списка шрифтов
	Список = Элементы.КомандаFontName.СписокВыбора;
	Список.Добавить("Arial");
	Список.Добавить("Arial Black");
	Список.Добавить("Arial Narrow");
	Список.Добавить("Comic Sans MS");
	Список.Добавить("Courier New");
	Список.Добавить("System");
	Список.Добавить("Tahoma");
	Список.Добавить("Times New Roman");
	Список.Добавить("Verdana");
	Список.Добавить("Wingdings");
	ТекЭлемент = Список.НайтиПоИдентификатору(0);
    ИмяШрифта = ТекЭлемент.Значение;
	
	// *** Установка видимости элементов
	УстановитьВидимостьЭлементов();
	
	// Заполнение списка размеров
	Список = Элементы.КомандаFontSize.СписокВыбора;
	Для Ном = 1 По 14 Цикл
		Список.Добавить(Ном);
	КонецЦикла;
	ТекЭлемент = Список.НайтиПоИдентификатору(2);
	РазмерыШрифта = ТекЭлемент.Значение;
	
	Документ = Элементы.ПолеHTMLДокумента.Документ;
	
	Если Объект.ПолучателиПисьма.Количество() > 0 Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.Тема;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

