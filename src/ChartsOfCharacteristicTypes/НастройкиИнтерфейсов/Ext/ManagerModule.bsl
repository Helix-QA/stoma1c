
#Область СлужебныйПрограммныйИнтерфейс

// Функция - Получить группу настроек пользователя
//
// Параметры:
//  ИмяГруппыНастроекПользователя	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКоллекциюНастроекПользователя(ИмяГруппыНастроекПользователя, ВидКоллекции = "") Экспорт

	ГруппаНастроек = ПланыВидовХарактеристик.НастройкиИнтерфейсов[ИмяГруппыНастроекПользователя];
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	НастройкиИнтерфейсов.Ссылка КАК Ссылка,
	               |	НастройкиИнтерфейсов.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных
	               |ИЗ
	               |	ПланВидовХарактеристик.НастройкиИнтерфейсов КАК НастройкиИнтерфейсов
	               |ГДЕ
	               |	НастройкиИнтерфейсов.ЭтоГруппа = ЛОЖЬ
	               |	И НастройкиИнтерфейсов.Родитель = &Родитель
	               |	И НастройкиИнтерфейсов.ПометкаУдаления = ЛОЖЬ
	               |	И НастройкиИнтерфейсов.Предопределенный = ИСТИНА";
	
	Запрос.УстановитьПараметр("Родитель", ГруппаНастроек);
	
	Если ВидКоллекции = "ТаблицаЗначений" Тогда 
		Возврат Запрос.Выполнить().Выгрузить();	
	ИначеЕсли ВидКоллекции = "Массив" Тогда
		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");	
	Иначе 
		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;	
	
КонецФункции

#КонецОбласти