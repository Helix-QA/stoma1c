	Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда 
		Если ПараметрыЗначенияЗаполнения.Свойство("Ассистент") Тогда
			Объект.Ассистент = ПараметрыЗначенияЗаполнения.Ассистент;					
		КонецЕсли;	
	КонецЕсли;
		
КонецПроцедуры

// Процедура, осуществляет заполнение реквизита Контрагент
//
Процедура ЗаполнитьРеквизитКонтрагент(Объект, МетаданныеДокумента, ПараметрыЗначенияЗаполнения, Контрагент)
	
	Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда 
		Если ПараметрыЗначенияЗаполнения.Свойство(Контрагент) И ПараметрыЗначенияЗаполнения[Контрагент] <> Неопределено Тогда			
			Если ЕстьРеквизитДокумента("ВидОперации", МетаданныеДокумента) Тогда
				Если ЗначениеЗаполнено(Объект.ВидОперации) Тогда  
					Если Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратПоставщику ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаПоставщику ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика Тогда 
						Если НЕ ПараметрыЗначенияЗаполнения[Контрагент].ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда 
							Объект[Контрагент] = ПараметрыЗначенияЗаполнения[Контрагент];
						КонецЕсли;	
					ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда 
						Если ПараметрыЗначенияЗаполнения[Контрагент].ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
							Объект[Контрагент] = ПараметрыЗначенияЗаполнения[Контрагент];
						КонецЕсли;
					ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзБанка ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПрочееПоступление ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОтПодотчетника
						ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.СдачаНаличныхВБанк ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПрочееСписание ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВыдачаПодотчетнику Тогда
						Объект[Контрагент] = Справочники.Контрагенты.ПустаяСсылка();										
					Иначе 
						Объект[Контрагент] = ПараметрыЗначенияЗаполнения[Контрагент];
					КонецЕсли;
				Иначе
					Объект[Контрагент] = ПараметрыЗначенияЗаполнения[Контрагент];
				КонецЕсли;	
			Иначе 
				Объект[Контрагент] = ПараметрыЗначенияЗаполнения[Контрагент];
			КонецЕсли;			
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры	

// Процедура, осуществляет заполнение реквизита склад
//
Процедура ЗаполнитьРеквизитСклад(Объект, МетаданныеДокумента, Пользователь, ПараметрыЗначенияЗаполнения)
	
	ЗначениеНастройки = ПользователиСтоматология.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь, "ОсновнойСклад", Объект.СтруктурнаяЕдиница);
	
	Если ПараметрыЗначенияЗаполнения <> Неопределено Тогда 
		Если ПараметрыЗначенияЗаполнения.Свойство("Склад") Тогда
			Если ЕстьРеквизитДокумента("ВидОперации", МетаданныеДокумента) Тогда
				Если ЗначениеЗаполнено(Объект.ВидОперации) Тогда  
					Если Объект.ВидОперации = Перечисления.ВидыОпераций.ПоСкладу ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПеремещениеМеждуСкладами ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПередачаСотруднику Тогда 
						Если ТипЗнч(ПараметрыЗначенияЗаполнения.Склад) = Тип("СправочникСсылка.Склады") Тогда 
							Объект.Склад = ПараметрыЗначенияЗаполнения.Склад;
						ИначеЕсли ЗначениеЗаполнено(ЗначениеНастройки) Тогда 
							Объект.Склад = ЗначениеНастройки;
						КонецЕсли;	
					ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоСотруднику ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОтСотрудника ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПеремещенияМеждуСотрудниками Тогда 
						Если ТипЗнч(ПараметрыЗначенияЗаполнения.Склад) = Тип("СправочникСсылка.Сотрудники") Тогда
							Объект.Склад = ПараметрыЗначенияЗаполнения.Склад;
						// ИначеЕсли ЗначениеЗаполнено(ЗначениеНастройки) Тогда 
						//	Объект.Склад = ЗначениеНастройки;
						КонецЕсли;						
					Иначе 
						Объект.Склад = ПараметрыЗначенияЗаполнения.Склад;
					КонецЕсли;
				Иначе
					Объект.Склад = ПараметрыЗначенияЗаполнения.Склад;
				КонецЕсли;	
			Иначе 
				Объект.Склад = ПараметрыЗначенияЗаполнения.Склад;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда 	
		Если ЗначениеЗаполнено(ЗначениеНастройки) Тогда
			Объект.Склад = ЗначениеНастройки;
		ИначеЕсли ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда  
			Объект.Склад = Объект.СтруктурнаяЕдиница.ОсновнойСклад;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

// Процедура, осуществляет заполнение реквизита статус
//
Процедура ЗаполнитьРеквизитСтатус(Объект)
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ПланЛечения") Тогда 
		Объект.Статус = Перечисления.СтатусыПланЛечения.Рассматривается;
	КонецЕсли;
	
