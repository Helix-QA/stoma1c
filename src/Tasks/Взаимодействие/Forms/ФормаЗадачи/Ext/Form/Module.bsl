// Процедура - Переключатель срок период.
//
Процедура ПереключательСрокПериод()
	
	Если ЭтотОбъект.РежимПериода Тогда 
		Элементы.ЗадачаНазначеннаяДатаНачало.Видимость		= Истина;
		Элементы.ЗадачаНазначеннаяДатаНачалоВремя.Видимость	= Истина;		
		Элементы.ЗадачаНазначеннаяДата.Заголовок			= Нстр("ru = 'по'; en = 'to'");
	Иначе
		Элементы.ЗадачаНазначеннаяДатаНачало.Видимость		= Ложь;
		Элементы.ЗадачаНазначеннаяДатаНачалоВремя.Видимость	= Ложь;		
		Элементы.ЗадачаНазначеннаяДата.Заголовок 			= Нстр("ru = 'Дата'; en = 'Date'");
		
		Объект.ЗадачаНазначеннаяДатаНачало					= Дата(01,01,01);	
		ЗадачаНазначеннаяДатаНачалоВремя					= Дата(01,01,01);
		
	КонецЕсли;
	
КонецПроцедуры

