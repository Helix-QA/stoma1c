
#Область СлужебныеПроцедурыИФункции

// Функция, возвращает структуру, содержащую поля диалога.
//
Функция ПолучитьСтруктуруПолейДиалога()
	
	СтруктураПолейДиалога = Новый Структура;
	СтруктураПолейДиалога.Вставить("ИдДиалога");
	СтруктураПолейДиалога.Вставить("ИдКлиента");
	СтруктураПолейДиалога.Вставить("ВнешняяСистема");
	СтруктураПолейДиалога.Вставить("Оператор");
	СтруктураПолейДиалога.Вставить("Начало");
	СтруктураПолейДиалога.Вставить("Окончание");
	СтруктураПолейДиалога.Вставить("ОтложенДо");
	СтруктураПолейДиалога.Вставить("Длительность");
	СтруктураПолейДиалога.Вставить("СообщениеОтКлиента");
	СтруктураПолейДиалога.Вставить("СценарийЧатБота");
	СтруктураПолейДиалога.Вставить("ИдентификаторЭтапа");
	СтруктураПолейДиалога.Вставить("ОписаниеЭтапа");
	СтруктураПолейДиалога.Вставить("ЗавершенРегламентом");
	
	Возврат СтруктураПолейДиалога;
	
КонецФункции

// Функция, возвращает идентификатор текущего диалога.
//
Функция ПолучитьТекущийДиалог(ИдКлиента
							, ВнешняяСистема
							, ОператорСообщения
							, ДатаСообщения
							, СообщениеОтКлиента
							, Мессенджер
							, ДополнительныеПараметры = Неопределено) Экспорт
	
	ДанныеДиалога = ПолучитьДанныеТекущегоДиалога(ИдКлиента, ВнешняяСистема, ОператорСообщения, ДополнительныеПараметры);
	
	// Если в исходящем сообщении не заполнен оператор - это рассылка.
	Если СообщениеОтКлиента = Ложь И Не ЗначениеЗаполнено(ОператорСообщения) Тогда
		Возврат ДанныеДиалога.ИдДиалога;
	КонецЕсли;
	
	Возврат ?(
		ЗначениеЗаполнено(ДанныеДиалога.ИдДиалога),
		ОтметитьДиалогАктивным(ДанныеДиалога),
		СоздатьНовыйДиалог(ИдКлиента, ВнешняяСистема, ОператорСообщения, ДатаСообщения, Мессенджер, ДополнительныеПараметры).ИдДиалога
	);
	
КонецФункции

// Функция, возвращает данные текущего диалога.
//
Функция ПолучитьДанныеТекущегоДиалога(ИдКлиента
									, ВнешняяСистема
									, ОператорСообщения = Неопределено
									, ДополнительныеПараметры = Неопределено) Экспорт
	
	ДиалогID 				= "";								
	СценарийЧатБота 		= Неопределено;
	ЭтоБот 					= ?(НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("from"), ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры.from, "is_bot", Ложь), Ложь);
	ЕстьПараметрыСценария 	= НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("СценарийЧатБота");
	ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария = НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария");
	Если ЕстьПараметрыСценария Тогда 
		СценарийЧатБота 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "СценарийЧатБота"	, Неопределено);
		ДиалогID 			= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ДиалогID"		, "");		
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.ОтложенДо КАК ОтложенДо,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК СообщениеОтКлиента
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ИдДиалога = &ДиалогID
	|	И Диалоги.ИдКлиента = &ИдКлиента
	|	И Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеОператор
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|	И Диалоги.СценарийЧатБота = &СценарийЧатБота
	|
	|УПОРЯДОЧИТЬ ПО
	|	Начало УБЫВ");
	
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	// Фильтр по ДиалогID	
	Если ЗначениеЗаполнено(ДиалогID) Тогда 
		Запрос.УстановитьПараметр("ДиалогID", ДиалогID);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Диалоги.ИдДиалога = &ДиалогID
	|	И ", "");
	КонецЕсли;
	
	// Фильтр по сценарию
	Если ЗначениеЗаполнено(СценарийЧатБота) И НЕ ЗначениеЗаполнено(ДиалогID) Тогда 
		Запрос.УстановитьПараметр("СценарийЧатБота", СценарийЧатБота);
	ИначеЕсли НЕ ЕстьПараметрыСценария И ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария Тогда 
		Запрос.УстановитьПараметр("СценарийЧатБота", Справочники.СценарииЧатБотов.ПустаяСсылка());
	ИначеЕсли ЭтоБот Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Диалоги.СценарийЧатБота = &СценарийЧатБота", "И Диалоги.СценарийЧатБота <> &СценарийЧатБота");
		Запрос.УстановитьПараметр("СценарийЧатБота", Справочники.СценарииЧатБотов.ПустаяСсылка());		
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Диалоги.СценарийЧатБота = &СценарийЧатБота", "");
	КонецЕсли;
		
	// Фильтр по оператору	
	Если ЗначениеЗаполнено(ОператорСообщения) И НЕ ЗначениеЗаполнено(ДиалогID) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОператор", "Диалоги.Оператор = &ОператорСообщения");
		Запрос.УстановитьПараметр("ОператорСообщения", ОператорСообщения);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОператор", "ИСТИНА");	
	КонецЕсли;
	
	Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
		
	Выборка 		= Запрос.Выполнить().Выбрать();
	
	ДанныеДиалога 	= ПолучитьСтруктуруПолейДиалога();
	                              
	Если Выборка.Следующий() Тогда
		// Это активация нового сценария
		Если ЕстьПараметрыСценария И НЕ ЗначениеЗаполнено(ДиалогID) Тогда
			Мессенджер = Перечисления.Мессенджеры.ВернутьТипМессенджераВнешнейСистемы(ВнешняяСистема);
			// Закрываем текущий диалог с нашим чат-ботом
			ДанныеЗакрываемогоДиалога = ЗакрытьДиалог(Выборка.ИдДиалога, Выборка.Оператор, ТекущаяДатаСеанса(), Мессенджер); 
		Иначе 	
			ЗаполнитьЗначенияСвойств(ДанныеДиалога, Выборка);
			Если ЗначениеЗаполнено(ДанныеДиалога.ОтложенДо) И ТекущаяДатаСеанса() > ДанныеДиалога.ОтложенДо Тогда
				ОтметитьДиалогАктивным(ДанныеДиалога);
				ДанныеДиалога.ОтложенДо = Неопределено;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат ДанныеДиалога;
	
КонецФункции

Функция ПолучитьДанныеПоследнегоДиалога(ИдКлиента = Неопределено
										, Контрагент = Неопределено
										, ВнешняяСистема = Неопределено
										, ПоСценариям = Ложь) Экспорт
										
	Если НЕ ЗначениеЗаполнено(ИдКлиента) И НЕ ЗначениеЗаполнено(Контрагент) Тогда 
		Возврат Неопределено;									
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ИдКлиента) Тогда
		Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда 
			Возврат Неопределено;
		КонецЕсли;	
		ПараметрыВнешнейСистемы = Неопределено;	
		Если НЕ МессенджерСтоматология.ИнициализированыПараметрыВнешнейСистемы(ВнешняяСистема, ПараметрыВнешнейСистемы) Тогда 
			Возврат Неопределено;									
		КонецЕсли;
		ПараметрыКлиента = МессенджерСтоматология.ПолучитьПараметрыОбъектаИдентификации(Контрагент, ВнешняяСистема);
		Если ПараметрыКлиента = Неопределено Тогда 
			Возврат Неопределено;
		Иначе 
			ИдКлиента = ПараметрыКлиента.ИдКлиента;	
		КонецЕсли;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК СообщениеОтКлиента,
	|	Диалоги.ИдентификаторЭтапа КАК ИдентификаторЭтапа,
	|	Диалоги.СценарийЧатБота КАК СценарийЧатБота,
	|	Диалоги.ЗавершенРегламентом КАК ЗавершенРегламентом
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ИдКлиента = &ИдКлиента
	|	И Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И Диалоги.Оператор <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	И Диалоги.СценарийЧатБота <> ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Начало УБЫВ";
	
	Запрос.УстановитьПараметр("ИдентификаторЭтапа"	, ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	Запрос.УстановитьПараметр("ИдКлиента"			, ИдКлиента);
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда 
		Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Диалоги.ВнешняяСистема = &ВнешняяСистема", "ИСТИНА");
	КонецЕсли;
	Если НЕ ПоСценариям Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Диалоги.Оператор <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Диалоги.СценарийЧатБота <> ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)", "Диалоги.СценарийЧатБота = ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)");
	КонецЕсли;	
		
	ВыборкаДанныхПоследнегоДиалога = Запрос.Выполнить().Выбрать();
	Если ВыборкаДанныхПоследнегоДиалога.Следующий() Тогда
		ДанныеДиалога = ПолучитьСтруктуруПолейДиалога();
		ЗаполнитьЗначенияСвойств(ДанныеДиалога, ВыборкаДанныхПоследнегоДиалога);
		Возврат ДанныеДиалога;		
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные диалога
//
// Параметры:
//  ИдДиалога		 - 	 - 
//  ТолькоАктуальные - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеДиалога(ИдДиалога, ТолькоАктуальные = Ложь, ПолучитьДанныеПоследнегоСообщения = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДиалогID", ИдДиалога);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ОтложенДо КАК ОтложенДо,
	|	Диалоги.Длительность КАК Длительность,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК СообщениеОтКлиента,
	|	Диалоги.СценарийЧатБота КАК СценарийЧатБота,
	|	Диалоги.ИдентификаторЭтапа КАК ИдентификаторЭтапа,
	|	Диалоги.ОписаниеЭтапа КАК ОписаниеЭтапа,
	|	Диалоги.ЗавершенРегламентом КАК ЗавершенРегламентом
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ИдДиалога = &ДиалогID
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)";
	
	Если НЕ ТолькоАктуальные Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)", "");	
	КонецЕсли;	
	
	Выборка 		= Запрос.Выполнить().Выбрать();
	
	ДанныеДиалога 	= ПолучитьСтруктуруПолейДиалога();
	                              
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеДиалога, Выборка);
		Если ПолучитьДанныеПоследнегоСообщения Тогда 
			ДанныеСообщения = РегистрыСведений.ЖурналСообщений.ПолучитьДанныеПоследнегоСообщения(ДанныеДиалога.ВнешняяСистема, ДанныеДиалога.ИдКлиента, ДанныеДиалога.ИдДиалога);
			ДанныеДиалога.Вставить("ДанныеПоследнегоСообщения", ДанныеСообщения);
		КонецЕсли;	
	КонецЕсли;
	
	Возврат ДанныеДиалога;
	
КонецФункции

// Функция - Завершить диалоги чат бота
//
// Параметры:
//  ИдКлиента	 - 	 - 
//  Мессенджер	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗавершитьДиалогиЧатБота(ИдКлиента
								, ВнешняяСистема
								, Мессенджер
								, ДатаЗаверешения = Неопределено
								, ПричинаЗавершения = "") Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК СообщениеОтКлиента,
	|	Диалоги.ИдентификаторЭтапа КАК ИдентификаторЭтапа
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ИдКлиента = &ИдКлиента
	|	И Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|	И Диалоги.СценарийЧатБота <> ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)";
	
	ВыборкаДиалогов = Запрос.Выполнить().Выбрать();
	Если НЕ ЗначениеЗаполнено(ДатаЗаверешения) Тогда 
		ДатаЗаверешения = ТекущаяДатаСеанса()- 2;
	КонецЕсли;	
	Пока ВыборкаДиалогов.Следующий() Цикл
		Попытка
			СтруктураВозврата = ЗакрытьДиалог(ВыборкаДиалогов.ИдДиалога
											, ВыборкаДиалогов.Оператор
											, ДатаЗаверешения
											, Мессенджер
											, ВыборкаДиалогов.ИдентификаторЭтапа
											, ПричинаЗавершения);
		Исключение
						
		КонецПопытки;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Функция, отмечает диалог активным и возвращает его идентификатор.
//
Функция ОтметитьДиалогАктивным(ДанныеДиалога) Экспорт
	
	Если ЗначениеЗаполнено(ДанныеДиалога.ОтложенДо) Тогда
		
		МенеджерЗаписи			 = СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ИдДиалога = ДанныеДиалога.ИдДиалога;
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			МенеджерЗаписи.ОтложенДо = Неопределено;
			МенеджерЗаписи.Записать();
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеДиалога.ИдДиалога;
	
КонецФункции

// Функция, создает новый диалог и возвращает его идентификатор.
//
Функция СоздатьНовыйДиалог(ИдКлиента
							, ВнешняяСистема
							, ОператорСообщения
							, Дата
							, Мессенджер
							, ДополнительныеПараметры = Неопределено
							, ЗначенияЗаполнения = Неопределено
							, ЭтоАвтоматическоеДействие = Ложь) Экспорт
							
	ЭтоБот 					= ?(НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("from"), ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры.from, "is_bot", Ложь), Ложь);
	ЕстьПараметрыСценария 	= НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("СценарийЧатБота");
	ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария = НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария");
							
	ИдДиалога = Строка(Новый УникальныйИдентификатор());
	НаборЗаписейДиалоги = СоздатьНаборЗаписей();
	НаборЗаписейДиалоги.Отбор.ИдДиалога.Установить(ИдДиалога);
	
	НоваяЗапись									= НаборЗаписейДиалоги.Добавить();
	НоваяЗапись.ИдДиалога						= ИдДиалога;
	НоваяЗапись.ИдКлиента						= ИдКлиента;
	НоваяЗапись.ВнешняяСистема					= ВнешняяСистема;
	НоваяЗапись.ИнициированКлиентом				= Не ЗначениеЗаполнено(ОператорСообщения);
	НоваяЗапись.Начало							= Дата;
	
	Если НЕ ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария Тогда 
		НоваяЗапись.Оператор = ?(
			ЗначениеЗаполнено(ОператорСообщения),
			ОператорСообщения,
			ОпределитьНазначаемогоОператора(ВнешняяСистема, ИдКлиента, ДополнительныеПараметры)
		);
	КонецЕсли;	

	// Актуализируем ID диалога и пробрасываем все параметры в доп. свойства набора
	Если НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") Тогда 
		НоваяЗапись.СценарийЧатБота 			= ?(ЗначениеЗаполнено(НоваяЗапись.СценарийЧатБота), НоваяЗапись.СценарийЧатБота, 
													?(ДополнительныеПараметры.Свойство("СценарийЧатБота"), ДополнительныеПараметры.СценарийЧатБота, НоваяЗапись.СценарийЧатБота));
		
		НоваяЗапись.ИдентификаторЭтапа 			= ?(ДополнительныеПараметры.Свойство("ИдентификаторТекущегоЭтапа"), ДополнительныеПараметры.ИдентификаторТекущегоЭтапа, НоваяЗапись.ИдентификаторЭтапа);													
		НоваяЗапись.ОписаниеЭтапа 				= ?(ДополнительныеПараметры.Свойство("ОписаниеЭтапа"), ДополнительныеПараметры.ОписаниеЭтапа, "");
		НоваяЗапись.Сообщение 					= ИнициализироватьСлужебноеОписаниеДиалога(НоваяЗапись.Сообщение, "Старт");
		
		Для Каждого ЭлементКоллекции Из ДополнительныеПараметры Цикл
			Если ЭлементКоллекции.Ключ = "ДиалогID" И НЕ ЗначениеЗаполнено(ЭлементКоллекции.Значение) Тогда
				ДополнительныеПараметры.Вставить(ЭлементКоллекции.Ключ, ИдДиалога);
				НаборЗаписейДиалоги.ДополнительныеСвойства.Вставить(ЭлементКоллекции.Ключ, ИдДиалога);
			Иначе
				НаборЗаписейДиалоги.ДополнительныеСвойства.Вставить(ЭлементКоллекции.Ключ, ЭлементКоллекции.Значение);			
			КонецЕсли;
		КонецЦикла;
		Если ДополнительныеПараметры.Свойство("ПараметрыРегистрацииТриггера") Тогда 
			ДополнительныеПараметры.Удалить("ПараметрыРегистрацииТриггера");
		КонецЕсли;	
	КонецЕсли;
	
	Если ТипЗнч(ЗначенияЗаполнения) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(НоваяЗапись, ЗначенияЗаполнения);
	КонецЕсли;
	
	НаборЗаписейДиалоги.ОбменДанными.Загрузка = Истина;	
	НаборЗаписейДиалоги.Записать();
	
	ДобавитьСлужебноеСообщениеСтатусаДиалога(
		ИдКлиента,
		ВнешняяСистема,
		ИдДиалога,
		ОператорСообщения,
		Дата,
		Мессенджер,
		"Открыт",,,
		ЭтоАвтоматическоеДействие
	);
	
	СтруктураВозврата = ПолучитьСтруктуруПолейДиалога();
	ЗаполнитьЗначенияСвойств(СтруктураВозврата, НоваяЗапись);
	
	ОбновитьДанныеКонтактаМессенджера(ИдКлиента, ВнешняяСистема, ИдДиалога);
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция, создает закрывает диалог возвращает его идентификатор.
//
Функция ЗакрытьДиалог(ИдДиалога
					, ОператорСообщения
					, Дата
					, Мессенджер
					, ИдентификаторЭтапа = Неопределено
					, ПричинаЗавершения = ""
					, ЗавершенРегламентом = Ложь) Экспорт
	
	МенеджерЗаписи			 = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдДиалога = ИдДиалога;
	
	МенеджерЗаписи.Прочитать();
	
	СтруктураВозврата = ПолучитьСтруктуруПолейДиалога();
	
	Если Не МенеджерЗаписи.Выбран() Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	МенеджерЗаписи.Окончание					= Дата;
	МенеджерЗаписи.Длительность					= Дата - МенеджерЗаписи.Начало;
	Если НЕ ИдентификаторЭтапа = Неопределено Тогда 
		МенеджерЗаписи.ИдентификаторЭтапа 		= ИдентификаторЭтапа;	
	КонецЕсли;
	Если ЗначениеЗаполнено(ПричинаЗавершения) Тогда 
		МенеджерЗаписи.Сообщение = ИнициализироватьСлужебноеОписаниеДиалога(МенеджерЗаписи.Сообщение, ПричинаЗавершения);
	ИначеЕсли ЗначениеЗаполнено(МенеджерЗаписи.СценарийЧатБота) И МенеджерЗаписи.ИдентификаторЭтапа = ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор() Тогда 
		МенеджерЗаписи.Сообщение = ИнициализироватьСлужебноеОписаниеДиалога(МенеджерЗаписи.Сообщение, НСтр("ru = 'Сценарий завершён успешно'; en = 'Script completed successfully'"));
	КонецЕсли;
	МенеджерЗаписи.ЗавершенРегламентом 			= ЗавершенРегламентом;
	МенеджерЗаписи.Записать();
	
	ДобавитьСлужебноеСообщениеСтатусаДиалога(МенеджерЗаписи.ИдКлиента
											, МенеджерЗаписи.ВнешняяСистема
											, ИдДиалога
											, ОператорСообщения
											, Дата
											, Мессенджер
											, "Закрыт"
											, 
											, ИдентификаторЭтапа
											, ЗавершенРегламентом);
	
	ЗаполнитьЗначенияСвойств(СтруктураВозврата, МенеджерЗаписи);
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция, создает новый диалог и возвращает его идентификатор.
//
Функция ОтложитьДиалог(ИдДиалога, ОператорСообщения, Дата, ТекущаяДата, Мессенджер) Экспорт
	
	МенеджерЗаписи			 = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдДиалога = ИдДиалога;
	
	МенеджерЗаписи.Прочитать();
	
	СтруктураВозврата = ПолучитьСтруктуруПолейДиалога();
	
	Если Не МенеджерЗаписи.Выбран() Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	МенеджерЗаписи.ОтложенДо = Дата;
	МенеджерЗаписи.Записать();
	
	ДобавитьСлужебноеСообщениеСтатусаДиалога(
		МенеджерЗаписи.ИдКлиента,
		МенеджерЗаписи.ВнешняяСистема,
		ИдДиалога,
		ОператорСообщения,
		ТекущаяДата,
		Мессенджер,
		"Отложен",
		Дата
	);
	
	ЗаполнитьЗначенияСвойств(СтруктураВозврата, МенеджерЗаписи);
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Инициализировать служебное описание диалога
//
// Параметры:
//  ТекущееСообщение - 	 - 
//  НовоеСообщение	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьСлужебноеОписаниеДиалога(ТекущееСообщение, НовоеСообщение) Экспорт
	
	СимволПереноса = ?(ЗначениеЗаполнено(ТекущееСообщение), Символы.ПС, "");
	Возврат ТекущееСообщение + СимволПереноса + Формат(ТекущаяДатаСеанса(), "ДФ='d.MM.yy - HH:mm:ss'' - '''") + НовоеСообщение;	
	
КонецФункции

// Процедура, добавляет служебное сообщение статуса диалога.
//
Процедура ДобавитьСлужебноеСообщениеСтатусаДиалога(ИдКлиента
												, ВнешняяСистема
												, ИдДиалога
												, Оператор
												, Дата
												, Мессенджер
												, Статус
												, ДатаПереноса = Неопределено
												, ИдентификаторЭтапа = Неопределено
												, ЭтоАвтоматическоеДействие = Ложь)
	
	ТекстСообщения = ПолучитьТекстСлужебногоСообщенияСтатусаДиалога(Оператор, Дата, Статус, ДатаПереноса, ЭтоАвтоматическоеДействие);
	
	Если Не ЗначениеЗаполнено(ТекстСообщения) Тогда
		Возврат;
	КонецЕсли;
	
	//Если ИдентификаторЭтапа = Неопределено Тогда
		ПоправкаВремени = ?(Статус = "Открыт", -1, ?(Статус = "Закрыт", 1, 0)) * ?(ЭтоАвтоматическоеДействие, -1, 1);
	//Иначе 
	//	ПоправкаВремени = ?(Статус = "Открыт", -1, ?(Статус = "Закрыт", 0, 0));
	//КонецЕсли;
	
	МенеджерЗаписи						 = РегистрыСведений.ЖурналСообщений.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдКлиента			 = ИдКлиента;
	МенеджерЗаписи.ВнешняяСистема		 = ВнешняяСистема;
	МенеджерЗаписи.ИдСообщения			 = Строка(Новый УникальныйИдентификатор());
	МенеджерЗаписи.ИдДиалога			 = ИдДиалога;
	МенеджерЗаписи.ОператорСообщения	 = Оператор;
	МенеджерЗаписи.Период				 = Дата + ПоправкаВремени;
	МенеджерЗаписи.ДатаСообщения		 = Дата + ПоправкаВремени;
	МенеджерЗаписи.Мессенджер			 = Мессенджер;
	МенеджерЗаписи.ТекстСообщения		 = ТекстСообщения;
	МенеджерЗаписи.СлужебноеСообщение	 = Истина;
	МенеджерЗаписи.Прочитано			 = Истина;
	
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

// Функция, возвращает текст служебного сообщения.
//
Функция ПолучитьТекстСлужебногоСообщенияСтатусаДиалога(Оператор, Дата, Статус, ДатаПереноса = Неопределено, ЭтоАвтоматическоеДействие = Ложь) Экспорт
	
	Если Статус = "Открыт" Тогда
		
		Если ЭтоАвтоматическоеДействие = Истина Тогда
			
			Возврат СтрШаблон(
				НСтр("ru = 'Диалог автоматически переведен %1 на пользователя ""%2""'"),
				Формат(Дата, СтрШаблон("ДФ='дд.ММ.гггг ""%1"" ЧЧ:мм'", НСтр("ru = 'в'; en = 'at'"))),
				ОбщегоНазначения.ПолучитьЗначениеРеквизита(Оператор, "Наименование")
			);
			
		ИначеЕсли ЗначениеЗаполнено(Оператор) Тогда
			
			Возврат СтрШаблон(
				НСтр("ru = 'Диалог открыт %1 пользователем ""%2""'; en = 'Dialog opened %1 by user ""%2""'"),
				Формат(Дата, СтрШаблон("ДФ='дд.ММ.гггг ""%1"" ЧЧ:мм'", НСтр("ru = 'в'; en = 'at'"))),
				ОбщегоНазначения.ПолучитьЗначениеРеквизита(Оператор, "Наименование")
			);
			
		Иначе
			
			Возврат СтрШаблон(
				НСтр("ru = 'Диалог открыт клиентом %1'; en = 'Dialog opened by client %1'"),
				Формат(Дата, СтрШаблон("ДФ='дд.ММ.гггг ""%1"" ЧЧ:мм'", НСтр("ru = 'в'; en = 'at'")))
			);
			
		КонецЕсли;
		
	ИначеЕсли Статус = "Закрыт" Тогда
		
		Если ЗначениеЗаполнено(Оператор) Тогда
			
			Возврат СтрШаблон(
				НСтр("ru = 'Диалог закрыт %1 пользователем ""%2""'; en = 'Dialog closed %1 by user ""%2""'"),
				Формат(Дата, СтрШаблон("ДФ='дд.ММ.гггг ""%1"" ЧЧ:мм'", НСтр("ru = 'в'; en = 'at'"))),
				ОбщегоНазначения.ПолучитьЗначениеРеквизита(Оператор, "Наименование")
			);
			
		Иначе
			
			Возврат СтрШаблон(
				НСтр("ru = 'Диалог закрыт %1 автоматически'; en = 'Dialog closed %1 automatically'"),
				Формат(Дата, СтрШаблон("ДФ='дд.ММ.гггг ""%1"" ЧЧ:мм'", НСтр("ru = 'в'; en = 'at'")))
			);
			
		КонецЕсли;
		
	ИначеЕсли Статус = "Отложен" Тогда
		
		Возврат СтрШаблон(
			НСтр("ru = 'Диалог отложен %1 пользователем ""%2"" до %3'; en = 'Dialog closed %1 by user ""%2"" until %3'"),
			Формат(Дата, СтрШаблон("ДФ='дд.ММ.гггг ""%1"" ЧЧ:мм'", НСтр("ru = 'в'; en = 'at'"))),
			ОбщегоНазначения.ПолучитьЗначениеРеквизита(Оператор, "Наименование"),
			Формат(ДатаПереноса, "ДФ='дд.ММ.гггг ЧЧ:мм'")
		);
		
	КонецЕсли;
	
КонецФункции

// Функция, возвращает оператора, которому нужно назначить диалог.
//
Функция ОпределитьНазначаемогоОператора(ВнешняяСистема, ИдКлиента, ДополнительныеПараметры = Неопределено) Экспорт
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	ПравилоНазначенияОператоров = ?(
		ПараметрыВнешнейСистемы.Свойство("ПравилоНазначенияОператоров"),
		ПараметрыВнешнейСистемы.ПравилоНазначенияОператоров,
		Неопределено
	);
	
	// Если не выбрано правило назначения операторов - используем старую логику.
	Если Не ЗначениеЗаполнено(ПравилоНазначенияОператоров) Тогда
		//Возврат ПолучитьОператораПоследнегоДиалога(ИдКлиента, ВнешняяСистема, ДополнительныеПараметры);
		Возврат Неопределено;
		
	Иначе
		
		ТолькоАвторизованные = ПараметрыВнешнейСистемы.Свойство("ПроверятьДоступностьОператора") И ПараметрыВнешнейСистемы.ПроверятьДоступностьОператора = Истина;
		
		Если ПравилоНазначенияОператоров = Перечисления.ПравилаНазначенияОператоров.ПоЗагруженности Тогда
			Возврат ПолучитьНаименееЗагруженногоОператора(ВнешняяСистема, ТолькоАвторизованные);
			
		ИначеЕсли ПравилоНазначенияОператоров = Перечисления.ПравилаНазначенияОператоров.ПоПриоритету Тогда
			Возврат ПолучитьПриоритетногоОператора(ВнешняяСистема, ТолькоАвторизованные);
			
		ИначеЕсли ПравилоНазначенияОператоров = Перечисления.ПравилаНазначенияОператоров.ПоОчереди Тогда
			Возврат ПолучитьСледующегоВОчередиОператора(ВнешняяСистема, ТолькоАвторизованные);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

// Функция, возвращает массив идентификаторов авторизованных пользователей.
//
Функция ПолучитьИдентификаторыАвторизованныхПользователей()
	
	ИдентификаторыАвторизованныхПользователей = Новый Массив;
	
	Сеансы = ПолучитьСеансыИнформационнойБазы();
	
	Для Каждого Сеанс Из Сеансы Цикл
		
		Если Сеанс.Пользователь <> Неопределено
			И (Сеанс.ИмяПриложения = "1CV8C" Или Сеанс.ИмяПриложения = "WebClient") Тогда
			
			ИдентификаторыАвторизованныхПользователей.Добавить(Сеанс.Пользователь.УникальныйИдентификатор);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ИдентификаторыАвторизованныхПользователей;
	
КонецФункции

// Функция, возвращает наименее загруженного оператора из доступных для внешней системы.
//
Функция ПолучитьНаименееЗагруженногоОператора(ВнешняяСистема, ТолькоАвторизованные = Ложь)
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриоритетНазначенияДиалогов.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ДоступныеОператоры
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеАвторизации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ДоступныеОператоры.Сотрудник КАК Оператор,
	|	КОЛИЧЕСТВО(Диалоги.ИдДиалога) КАК КоличествоДиалогов
	|ИЗ
	|	ДоступныеОператоры КАК ДоступныеОператоры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диалоги КАК Диалоги
	|		ПО ДоступныеОператоры.Сотрудник = Диалоги.Оператор
	|			И (Диалоги.ВнешняяСистема = &ВнешняяСистема)
	|			И (Диалоги.ОтложенДо < &ТекущаяДата)
	|			И (Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1))
	|
	|СГРУППИРОВАТЬ ПО
	|	ДоступныеОператоры.Сотрудник
	|
	|УПОРЯДОЧИТЬ ПО
	|	КОЛИЧЕСТВО(Диалоги.ИдДиалога)");
	
	Запрос.УстановитьПараметр("ТекущаяДата"		, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	Если ТолькоАвторизованные = Истина Тогда
		
		УсловиеАвторизации = "ПриоритетНазначенияДиалогов.Сотрудник.ИдентификаторПользователяИБ В(&ИдентификаторыАвторизованныхПользователей)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеАвторизации", УсловиеАвторизации);
		Запрос.УстановитьПараметр("ИдентификаторыАвторизованныхПользователей", ПолучитьИдентификаторыАвторизованныхПользователей());
		
	Иначе
		Запрос.УстановитьПараметр("УсловиеАвторизации", Истина);
		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Оператор;
	КонецЕсли;
	
КонецФункции

// Функция, возвращает первого по приоритету оператора.
//
Функция ПолучитьПриоритетногоОператора(ВнешняяСистема, ТолькоАвторизованные)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПриоритетНазначенияДиалогов.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеАвторизации
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер");
	
	Если ТолькоАвторизованные = Истина Тогда
		
		УсловиеАвторизации = "ПриоритетНазначенияДиалогов.Сотрудник.ИдентификаторПользователяИБ В(&ИдентификаторыАвторизованныхПользователей)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеАвторизации", УсловиеАвторизации);
		Запрос.УстановитьПараметр("ИдентификаторыАвторизованныхПользователей", ПолучитьИдентификаторыАвторизованныхПользователей());
		
	Иначе
		Запрос.УстановитьПараметр("УсловиеАвторизации", Истина);
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Сотрудник;
	КонецЕсли;
	
КонецФункции

// Функция, возвращает следующего в очереди оператора.
//
Функция ПолучитьСледующегоВОчередиОператора(ВнешняяСистема, ТолькоАвторизованные = Ложь)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер КАК ПорядковыйНомер
	|ПОМЕСТИТЬ НомерПоследнегоВОчереди
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И ПриоритетНазначенияДиалогов.ПоследнийВОчереди
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(ПриоритетНазначенияДиалогов.ПорядковыйНомер) КАК ПорядковыйНомер
	|ПОМЕСТИТЬ МаксимальныйНомер
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер КАК ПорядковыйНомер,
	|	НомерПоследнегоВОчереди.ПорядковыйНомер КАК НомерПоследнегоВОчереди,
	|	ПриоритетНазначенияДиалогов.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НомерПоследнегоВОчереди КАК НомерПоследнегоВОчереди
	|		ПО (ИСТИНА)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МаксимальныйНомер КАК МаксимальныйНомер
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеАвторизации
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА ПриоритетНазначенияДиалогов.ПорядковыйНомер > НомерПоследнегоВОчереди.ПорядковыйНомер
	|			ТОГДА ПриоритетНазначенияДиалогов.ПорядковыйНомер
	|		ИНАЧЕ ПриоритетНазначенияДиалогов.ПорядковыйНомер + МаксимальныйНомер.ПорядковыйНомер + 1
	|	КОНЕЦ");
	
	Если ТолькоАвторизованные = Истина Тогда
		
		УсловиеАвторизации = "ПриоритетНазначенияДиалогов.Сотрудник.ИдентификаторПользователяИБ В(&ИдентификаторыАвторизованныхПользователей)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеАвторизации", УсловиеАвторизации);
		Запрос.УстановитьПараметр("ИдентификаторыАвторизованныхПользователей", ПолучитьИдентификаторыАвторизованныхПользователей());
		
	Иначе
		Запрос.УстановитьПараметр("УсловиеАвторизации", Истина);
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		РегистрыСведений.ПриоритетНазначенияДиалогов.УстановитьФлагПоследнего(ВнешняяСистема, Выборка.НомерПоследнегоВОчереди, Ложь);
		РегистрыСведений.ПриоритетНазначенияДиалогов.УстановитьФлагПоследнего(ВнешняяСистема, Выборка.ПорядковыйНомер, Истина);
		
		Возврат Выборка.Сотрудник;
		
	КонецЕсли;
	
КонецФункции

// Функция, возвращает оператора последнего диалога с клиентом.
//
Функция ПолучитьОператораПоследнегоДиалога(ИдКлиента, ВнешняяСистема, ДополнительныеПараметры = Неопределено) Экспорт
	
	ЭтоБот 					= ?(НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("from"), ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры.from, "is_bot", Ложь), Ложь);
	ЕстьПараметрыСценария 	= НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("СценарийЧатБота");
	ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария = НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И ДополнительныеПараметры.Свойство("ЭтоИнициацияНовогоДиалогаСКлиентомИзСценария");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК СлужебныйСотрудник
	|ПОМЕСТИТЬ ТаблицаСлужебных
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И Сотрудники.Служебный = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Диалоги.Оператор КАК Оператор
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСлужебных КАК ТаблицаСлужебных
	|		ПО Диалоги.Оператор = ТаблицаСлужебных.СлужебныйСотрудник
	|ГДЕ
	|	Диалоги.ИдКлиента = &ИдКлиента
	|	И Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И Диалоги.СценарийЧатБота = ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)
	|	И ТаблицаСлужебных.СлужебныйСотрудник ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	Диалоги.Начало УБЫВ");
	
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Оператор, Неопределено);
	
КонецФункции

// Процедура, записывает новое значение оператора диалога.
//
Процедура ИзменитьОператораДиалога(Оператор, ИдДиалога) Экспорт
	
	МенеджерЗаписи = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдДиалога = ИдДиалога;
	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		
		МенеджерЗаписи.Оператор = Оператор;
		МенеджерЗаписи.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, устанавливает значение параметра "ПоследнееСообщениеОтКлиента".
//
Процедура ОбновитьДанныеДиалога(ДанныеСообщения) Экспорт
	
	Если ДанныеСообщения.ОжиданиеСообщения Или ДанныеСообщения.СлужебноеСообщение Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерЗаписи = СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдДиалога = ДанныеСообщения.ИдДиалога;
	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		
		ПересчитатьДанныеПолейДиалога(МенеджерЗаписи, ДанныеСообщения);
		МенеджерЗаписи.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

// Функция, возвращает структуру - количество контактов по каждому из дополнительных фильтров.
//
Функция ПолучитьКоличествоКонтактовПоФильтрам(ВнешниеСистемы, ТекущийПользователь, ЗначениеФильтра) Экспорт
	
	Если ЗначениеФильтра = "Все" Тогда
		УсловиеФильтрации = "ИСТИНА";
	ИначеЕсли ЗначениеФильтра = "Мои" Тогда
		УсловиеФильтрации = "Диалоги.Оператор = &Оператор";
	Иначе
		Возврат Неопределено
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.Начало) КАК Начало,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ДатыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ВнешняяСистема В(&ВнешняяСистема)
	|	И Диалоги.СценарийЧатБота = ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Диалоги.ИдКлиента,
	|	Диалоги.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.ИдДиалога) КАК ИдДиалога,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ИдентификаторыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихДиалогов КАК ДатыПоследнихДиалогов
	|		ПО Диалоги.ИдКлиента = ДатыПоследнихДиалогов.ИдКлиента
	|			И Диалоги.ВнешняяСистема = ДатыПоследнихДиалогов.ВнешняяСистема
	|			И Диалоги.Начало = ДатыПоследнихДиалогов.Начало
	|ГДЕ
	|	Диалоги.ВнешняяСистема В(&ВнешняяСистема)
	|
	|СГРУППИРОВАТЬ ПО
	|	Диалоги.ИдКлиента,
	|	Диалоги.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ОтложенДо КАК ОтложенДо,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК ПоследнееСообщениеОтКлиента
	|ПОМЕСТИТЬ ДанныеПоследнихДиалогов
	|ИЗ
	|	ИдентификаторыПоследнихДиалогов КАК ИдентификаторыПоследнихДиалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Диалоги КАК Диалоги
	|		ПО (Диалоги.ИдДиалога = ИдентификаторыПоследнихДиалогов.ИдДиалога)
	|ГДЕ
	|	&УсловиеФильтрации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ДанныеПоследнихДиалогов.ИдКлиента) КАК КоличествоОтложенные
	|ИЗ
	|	ДанныеПоследнихДиалогов КАК ДанныеПоследнихДиалогов
	|ГДЕ
	|	ДанныеПоследнихДиалогов.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|	И ДанныеПоследнихДиалогов.ОтложенДо > &ТекущаяДата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ДанныеПоследнихДиалогов.ИдКлиента) КАК КоличествоОткрытые
	|ИЗ
	|	ДанныеПоследнихДиалогов КАК ДанныеПоследнихДиалогов
	|ГДЕ
	|	ДанныеПоследнихДиалогов.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|	И ДанныеПоследнихДиалогов.ОтложенДо <= &ТекущаяДата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ДанныеПоследнихДиалогов.ИдКлиента) КАК КоличествоБезОтвета
	|ИЗ
	|	ДанныеПоследнихДиалогов КАК ДанныеПоследнихДиалогов
	|ГДЕ
	|	ДанныеПоследнихДиалогов.ПоследнееСообщениеОтКлиента = ИСТИНА");
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеФильтрации", УсловиеФильтрации);
	
	Запрос.УстановитьПараметр("Оператор"		, ТекущийПользователь);
	Запрос.УстановитьПараметр("ТекущаяДата"		, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешниеСистемы);
	
	Результат = Запрос.ВыполнитьПакет();
	
	ДанныеФильтрации = Новый Структура;
	ДанныеФильтрации.Вставить("КоличествоОтложенные", Результат[Результат.ВГраница() - 2].Выгрузить()[0].КоличествоОтложенные);
	ДанныеФильтрации.Вставить("КоличествоОткрытые"	, Результат[Результат.ВГраница() - 1].Выгрузить()[0].КоличествоОткрытые);
	ДанныеФильтрации.Вставить("КоличествоБезОтвета"	, Результат[Результат.ВГраница()].Выгрузить()[0].КоличествоБезОтвета);
	
	Возврат ДанныеФильтрации;
	
КонецФункции

// Функция, проверяет необходимость возобновления закрытого диалога и возвращает идентификатор возобновленного диалога.
//
Функция ПолучитьИдВозобновленногоДиалога(ИдКлиента
										, ВнешняяСистема
										, ДатаСообщения
										, Оператор
										, СообщениеОтКлиента = Ложь) Экспорт
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	ВремяВозобновленияДиалога = ?(
		ЗначениеЗаполнено(ПараметрыВнешнейСистемы) И ПараметрыВнешнейСистемы.Свойство("ВремяВозобновленияДиалога"),
		ПараметрыВнешнейСистемы.ВремяВозобновленияДиалога,
		7200
	);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ИдентификаторЭтапа КАК ИдентификаторЭтапа,
	|	Диалоги.СценарийЧатБота КАК СценарийЧатБота,
	|	Диалоги.ЗавершенРегламентом КАК ЗавершенРегламентом
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ИдКлиента = &ИдКлиента
	|	И Диалоги.ВнешняяСистема = &ВнешняяСистема
	|
	|УПОРЯДОЧИТЬ ПО
	|	Начало УБЫВ");
	
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Не Выборка.Следующий() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Диалог еще не закрыт.
	Если Не ЗначениеЗаполнено(Выборка.Окончание) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Загрузка старого сообщения.
	Если Выборка.Начало > ДатаСообщения Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Другой оператор начинает общение.
	Если ЗначениеЗаполнено(Оператор) И Выборка.Оператор <> Оператор Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Сценарий чат-бота успешно завершен.
	Если ЗначениеЗаполнено(Выборка.СценарийЧатБота)
		И Выборка.ИдентификаторЭтапа = ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Возобновление незавершенного сценария чат-бота.
	Если ЗначениеЗаполнено(Выборка.СценарийЧатБота)
		И Выборка.ИдентификаторЭтапа <> ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор()
		И (Не Выборка.ЗавершенРегламентом Или Не СообщениеОтКлиента) Тогда
		
		Возврат Неопределено;
	КонецЕсли;
	
	// Прошло время возобновления диалога.
	Если Выборка.Окончание + ВремяВозобновленияДиалога < ДатаСообщения Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ВозобновитьЗакрытыйДиалог(Выборка.ИдДиалога);
	
	Возврат Выборка.ИдДиалога;
	
КонецФункции

// Процедура, возобновляет закрытый диалог.
//
Процедура ВозобновитьЗакрытыйДиалог(ИдДиалога)
	
	МенеджерЗаписи 							= СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдДиалога 				= ИдДиалога;
	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		
		ДатаЗакрытия = МенеджерЗаписи.Окончание;
		
		МенеджерЗаписи.Окончание	 		= Неопределено;
		МенеджерЗаписи.Длительность	 		= Неопределено;
		МенеджерЗаписи.ЗавершенРегламентом 	= Ложь;
		МенеджерЗаписи.Записать();
		
		УдалитьСлужебноеСообщениеЗакрытияДиалога(
			МенеджерЗаписи.ИдДиалога,
			МенеджерЗаписи.ВнешняяСистема,
			МенеджерЗаписи.ИдКлиента,
			ДатаЗакрытия
		);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, удаляет служебное сообщение статуса диалога.
//
Процедура УдалитьСлужебноеСообщениеЗакрытияДиалога(ИдДиалога, ВнешняяСистема, ИдКлиента, ДатаУстановкиСтатуса)
	
	НачалоПериода	 = ДатаУстановкиСтатуса - 1;
	КонецПериода	 = ДатаУстановкиСтатуса + 1;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЖурналСообщений.Период КАК Период,
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ИдДиалога = &ИдДиалога
	|	И ЖурналСообщений.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЖурналСообщений.СлужебноеСообщение
	|	И ЖурналСообщений.ТекстСообщения ПОДОБНО ""Диалог закрыт%""");
	
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ИдДиалога"		, ИдДиалога);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	Запрос.УстановитьПараметр("НачалоПериода"	, НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода"	, КонецПериода);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		МенеджерЗаписи = РегистрыСведений.ЖурналСообщений.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			МенеджерЗаписи.Удалить();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, закрывает неактивные диалоги.
//
Процедура ОбработатьЗакрытиеНеактивныхДиалогов(ИдДиалога = Неопределено) Экспорт
	
	// Передаем ИдДиалога, когда нам надо проверить и закрыть конкретнтый диалог по сценарию (часть проверок осуществляем сами выше)
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	// Получаем время для закрытия неактивных диалогов из параметров внешних систем.
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Параметры КАК Параметры
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В (&ТипыВнешнихСистем)");
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистем", Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ВремяЗакрытияДиалоговВнешнихСистем = Новый ТаблицаЗначений;
	ВремяЗакрытияДиалоговВнешнихСистем.Колонки.Добавить("ВнешняяСистема"				, Новый ОписаниеТипов("СправочникСсылка.ВнешниеСистемы"));
	ВремяЗакрытияДиалоговВнешнихСистем.Колонки.Добавить("ДатаЗакрытияОткрытыхДиалогов"	, Новый ОписаниеТипов("Дата"));
	ВремяЗакрытияДиалоговВнешнихСистем.Колонки.Добавить("ДатаЗакрытияОтложенныхДиалогов", Новый ОписаниеТипов("Дата"));
	
	Пока Выборка.Следующий() Цикл
		
		ПараметрыВнешнейСистемы = Выборка.Параметры.Получить();
		
		Если ТипЗнч(ПараметрыВнешнейСистемы) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		ВремяЗакрытияОткрытогоДиалога	 = ?(ПараметрыВнешнейСистемы.Свойство("ВремяЗакрытияОткрытогоДиалога"), ПараметрыВнешнейСистемы.ВремяЗакрытияОткрытогоДиалога, 7200);
		ВремяЗакрытияОтложенногоДиалога	 = ?(ПараметрыВнешнейСистемы.Свойство("ВремяЗакрытияОтложенногоДиалога"), ПараметрыВнешнейСистемы.ВремяЗакрытияОтложенногоДиалога, 86400);
		
		Если ВремяЗакрытияОткрытогоДиалога = 0 И ВремяЗакрытияОтложенногоДиалога = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДатаЗакрытияОткрытыхДиалогов	 = ?(ВремяЗакрытияОткрытогоДиалога = 0	, ТекущаяДата - (60*60*2), ТекущаяДата - ВремяЗакрытияОткрытогоДиалога);
		ДатаЗакрытияОтложенныхДиалогов	 = ?(ВремяЗакрытияОтложенногоДиалога = 0, Дата(1, 1, 1), ТекущаяДата - ВремяЗакрытияОтложенногоДиалога);
		
		НоваяСтрока									 = ВремяЗакрытияДиалоговВнешнихСистем.Добавить();
		НоваяСтрока.ВнешняяСистема					 = Выборка.Ссылка;
		НоваяСтрока.ДатаЗакрытияОткрытыхДиалогов	 = ДатаЗакрытияОткрытыхДиалогов;
		НоваяСтрока.ДатаЗакрытияОтложенныхДиалогов	 = ДатаЗакрытияОтложенныхДиалогов;
		
	КонецЦикла;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВремяЗакрытияДиалоговВнешнихСистем.ВнешняяСистема КАК ВнешняяСистема,
	|	ВремяЗакрытияДиалоговВнешнихСистем.ДатаЗакрытияОткрытыхДиалогов КАК ДатаЗакрытияОткрытыхДиалогов,
	|	ВремяЗакрытияДиалоговВнешнихСистем.ДатаЗакрытияОтложенныхДиалогов КАК ДатаЗакрытияОтложенныхДиалогов
	|ПОМЕСТИТЬ ВремяЗакрытияДиалоговВнешнихСистем
	|ИЗ
	|	&ВремяЗакрытияДиалоговВнешнихСистем КАК ВремяЗакрытияДиалоговВнешнихСистем
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.ОтложенДо КАК ОтложенДо,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ НезакрытыеДиалоги
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|	И НЕ Диалоги.ПоследнееСообщениеОтКлиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НезакрытыеДиалоги.ИдДиалога КАК ИдДиалога,
	|	НезакрытыеДиалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	МАКСИМУМ(ВремяЗакрытияДиалоговВнешнихСистем.ДатаЗакрытияОткрытыхДиалогов) КАК ДатаЗакрытияОткрытыхДиалогов
	|ИЗ
	|	НезакрытыеДиалоги КАК НезакрытыеДиалоги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ПО НезакрытыеДиалоги.ИдДиалога = ЖурналСообщений.ИдДиалога
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВремяЗакрытияДиалоговВнешнихСистем КАК ВремяЗакрытияДиалоговВнешнихСистем
	|		ПО НезакрытыеДиалоги.ВнешняяСистема = ВремяЗакрытияДиалоговВнешнихСистем.ВнешняяСистема
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НезакрытыеДиалоги.ОтложенДо <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА НезакрытыеДиалоги.ОтложенДо < ВремяЗакрытияДиалоговВнешнихСистем.ДатаЗакрытияОтложенныхДиалогов
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ ЖурналСообщений.ОжиданиеСообщения
	|	И &УсловиеОтправкаЧеловеком
	|
	|СГРУППИРОВАТЬ ПО
	|	НезакрытыеДиалоги.ИдДиалога,
	|	НезакрытыеДиалоги.ВнешняяСистема
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(ЖурналСообщений.Период) < МАКСИМУМ(ВремяЗакрытияДиалоговВнешнихСистем.ДатаЗакрытияОткрытыхДиалогов)");
	
	Запрос.УстановитьПараметр("ВремяЗакрытияДиалоговВнешнихСистем", ВремяЗакрытияДиалоговВнешнихСистем);
	
	Если ЗначениеЗаполнено(ИдДиалога) Тогда 
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1)
		|	И НЕ Диалоги.ПоследнееСообщениеОтКлиента", "Диалоги.ИдДиалога = &ИдДиалога");
		Запрос.УстановитьПараметр("ИдДиалога", ИдДиалога);
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеОтправкаЧеловеком", "");
		
	Иначе
		
		СотрудникЧатБота = Справочники.СценарииЧатБотов.ИнициализироватьОператораСообщения();
		
		Если ЗначениеЗаполнено(СотрудникЧатБота) Тогда
			
			Запрос.Текст = СтрЗаменить(
				Запрос.Текст,
				"&УсловиеОтправкаЧеловеком",
				"ЖурналСообщений.ОператорСообщения <> &СотрудникЧатБота И НЕ ЖурналСообщений.Триггер"
			);
			Запрос.УстановитьПараметр("СотрудникЧатБота", СотрудникЧатБота);
			
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтправкаЧеловеком", "НЕ ЖурналСообщений.Триггер");
		КонецЕсли;
		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Попытка
			ЗначениеМессенджера = Перечисления.Мессенджеры.ВернутьТипМессенджераВнешнейСистемы(Выборка.ВнешняяСистема);
			ЗакрытьДиалог(Выборка.ИдДиалога
						, Неопределено
						, ТекущаяДата
						, ЗначениеМессенджера
						,
						, ?(ЗначениеЗаполнено(ИдДиалога), НСтр("ru = 'Автоматическое закрытие неактивных диалогов при старте нового сценария чат-бота.'"), НСтр("ru = 'Автоматическое закрытие неактивных диалогов.'"))
						, Истина);
			ИдДиалога = Неопределено;
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

// Процедура, обновляет идентификатор последнего диалога в контакте мессенджера.
//
Процедура ОбновитьДанныеКонтактаМессенджера(ИдКлиента, ВнешняяСистема, ИдДиалога)
	
	МенеджерЗаписи = РегистрыСведений.КонтактыМессенджеров.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Идентификатор = ИдКлиента;
	МенеджерЗаписи.ВнешняяСистема = ВнешняяСистема;
	
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() И МенеджерЗаписи.ИдПоследнегоДиалога <> ИдДиалога Тогда
		
		МенеджерЗаписи.ИдПоследнегоДиалога = ИдДиалога;
		МенеджерЗаписи.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обновляет значения изменяемых полей диалога на основании данных сообщения.
//
Процедура ПересчитатьДанныеПолейДиалога(ДанныеДиалога, ДанныеСообщения)
	
	ЭтоОтвет = ДанныеДиалога.ПоследнееСообщениеОтКлиента И Не ДанныеСообщения.СообщениеОтКлиента;
	
	Если ЭтоОтвет Тогда
		
		ВремяОтвета		 = ?(ЗначениеЗаполнено(ДанныеДиалога.ДатаНачальногоСообщенияСерии), ДанныеСообщения.Период - ДанныеДиалога.ДатаНачальногоСообщенияСерии, 1);
		ВремяОтветаДатой = Дата(1, 1, 1) + ВремяОтвета;
		
		ДанныеДиалога.ВремяДоПервогоОтвета		 = ?(ДанныеДиалога.ИнициированКлиентом И Не ЗначениеЗаполнено(ДанныеДиалога.ВремяДоПервогоОтвета), ВремяОтветаДатой, ДанныеДиалога.ВремяДоПервогоОтвета);
		ДанныеДиалога.КоличествоОтветов			 = ДанныеДиалога.КоличествоОтветов + 1;
		ДанныеДиалога.ОбщееВремяОтветов			 = ДанныеДиалога.ОбщееВремяОтветов + ВремяОтвета;
		ДанныеДиалога.МаксимальноеВремяОтвета	 = ?(ВремяОтветаДатой > ДанныеДиалога.МаксимальноеВремяОтвета, ВремяОтветаДатой, ДанныеДиалога.МаксимальноеВремяОтвета);
		
	КонецЕсли;
	
	// Дата первого из входящих сообщений, на которые не ответил оператор.
	ДанныеДиалога.ДатаНачальногоСообщенияСерии = ?(
		ДанныеСообщения.СообщениеОтКлиента,
		?(ЗначениеЗаполнено(ДанныеДиалога.ДатаНачальногоСообщенияСерии), ДанныеДиалога.ДатаНачальногоСообщенияСерии, ДанныеСообщения.Период),
		Неопределено
	);
	
	ДанныеДиалога.ПоследнееСообщениеОтКлиента	 = ДанныеСообщения.СообщениеОтКлиента;
	ДанныеДиалога.ДатаПоследнегоСообщения		 = ДанныеСообщения.Период;
	ДанныеДиалога.КоличествоСообщений			 = ДанныеДиалога.КоличествоСообщений + 1;
	
КонецПроцедуры

// Процедура, выполняет обработку переноса диалогов.
//
Процедура ОбработатьПереносНеотвеченныхДиалогов() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Параметры КАК Параметры
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистем)");
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистем", Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ИдентификаторыАвторизованныхПользователей = ПолучитьИдентификаторыАвторизованныхПользователей();
	
	Пока Выборка.Следующий() Цикл
		// Обрабатываем внешние системы по отдельности, т.к. у каждой свои настройки.
		ПеренестиНеотвеченныеДиалоги(Выборка.Ссылка, Выборка.Параметры, ИдентификаторыАвторизованныхПользователей);
	КонецЦикла;
	
КонецПроцедуры

// Процедура, переносит диалоги, на других операторов по выбранному правилу.
//
Процедура ПеренестиНеотвеченныеДиалоги(ВнешняяСистема, Параметры, ИдентификаторыПользователей)
	
	ПараметрыВнешнейСистемы = Параметры.Получить();
	
	Если ТипЗнч(ПараметрыВнешнейСистемы) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПараметрыВнешнейСистемы.Свойство("НазначатьОператоровАвтоматически")
		Или Не ПараметрыВнешнейСистемы.НазначатьОператоровАвтоматически = Истина Тогда
		
		// Автоматическое назначение операторов не используется.
		Возврат;
	КонецЕсли;
	
	ПравилоНазначенияОператоров = ?(
		ПараметрыВнешнейСистемы.Свойство("ПравилоНазначенияОператоров"),
		ПараметрыВнешнейСистемы.ПравилоНазначенияОператоров,
		Неопределено
	);
	
	Если Не ЗначениеЗаполнено(ПравилоНазначенияОператоров) Тогда
		// Правило назначения операторов не определено, ничего не нужно делать.
		Возврат;
	КонецЕсли;
	
	ВремяНаПервыйОтвет = ?(
		ПараметрыВнешнейСистемы.Свойство("ВремяНаПервыйОтвет"),
		ПараметрыВнешнейСистемы.ВремяНаПервыйОтвет,
		0
	);
	
	Если Не ЗначениеЗаполнено(ВремяНаПервыйОтвет) Тогда
		// Задано нулевое время, функция отключена.
		Возврат;
	КонецЕсли;
	
	ВремяСменыОператора	 = ТекущаяДатаСеанса() - ВремяНаПервыйОтвет;
	ТолькоАвторизованные = ПараметрыВнешнейСистемы.Свойство("ПроверятьДоступностьОператора") И ПараметрыВнешнейСистемы.ПроверятьДоступностьОператора = Истина;;
	
	Если ПравилоНазначенияОператоров = Перечисления.ПравилаНазначенияОператоров.ПоЗагруженности Тогда
		ПеренестиДиалогиПоЗагруженности(ВнешняяСистема, ВремяСменыОператора, ТолькоАвторизованные, ИдентификаторыПользователей);
		
	ИначеЕсли ПравилоНазначенияОператоров = Перечисления.ПравилаНазначенияОператоров.ПоПриоритету Тогда
		ПеренестиДиалогиПоПриоритету(ВнешняяСистема, ВремяСменыОператора, ТолькоАвторизованные, ИдентификаторыПользователей);
		
	ИначеЕсли ПравилоНазначенияОператоров = Перечисления.ПравилаНазначенияОператоров.ПоОчереди Тогда
		ПеренестиДиалогиПоОчереди(ВнешняяСистема, ВремяСменыОператора, ТолькоАвторизованные, ИдентификаторыПользователей);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, переносит диалоги по очереди.
//
Процедура ПеренестиДиалогиПоОчереди(ВнешняяСистема, ВремяСменыОператора, ТолькоАвторизованные, ИдентификаторыПользователей)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.КоличествоСообщений КАК КоличествоСообщений
	|ПОМЕСТИТЬ ДиалогиБезОтвета
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И Диалоги.ИнициированКлиентом
	|	И Диалоги.ДатаНачальногоСообщенияСерии < &ВремяСменыОператора
	|	И Диалоги.КоличествоОтветов = 0
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер КАК ПорядковыйНомер
	|ПОМЕСТИТЬ НомерПоследнегоВОчереди
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И ПриоритетНазначенияДиалогов.ПоследнийВОчереди
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(ПриоритетНазначенияДиалогов.ПорядковыйНомер) КАК ПорядковыйНомер
	|ПОМЕСТИТЬ МаксимальныйНомер
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер КАК ПорядковыйНомер,
	|	НомерПоследнегоВОчереди.ПорядковыйНомер КАК НомерПоследнегоВОчереди,
	|	ПриоритетНазначенияДиалогов.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НомерПоследнегоВОчереди КАК НомерПоследнегоВОчереди
	|		ПО (ИСТИНА)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МаксимальныйНомер КАК МаксимальныйНомер
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеАвторизации
	|	И НЕ ПриоритетНазначенияДиалогов.Сотрудник В
	|				(ВЫБРАТЬ
	|					ДиалогиБезОтвета.Оператор
	|				ИЗ
	|					ДиалогиБезОтвета КАК ДиалогиБезОтвета)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА ПриоритетНазначенияДиалогов.ПорядковыйНомер > НомерПоследнегоВОчереди.ПорядковыйНомер
	|			ТОГДА ПриоритетНазначенияДиалогов.ПорядковыйНомер
	|		ИНАЧЕ ПриоритетНазначенияДиалогов.ПорядковыйНомер + МаксимальныйНомер.ПорядковыйНомер + 1
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДиалогиБезОтвета.ИдДиалога КАК ИдДиалога,
	|	ДиалогиБезОтвета.Оператор КАК Оператор,
	|	ДиалогиБезОтвета.ИдКлиента КАК ИдКлиента,
	|	ДиалогиБезОтвета.КоличествоСообщений КАК КоличествоСообщений
	|ИЗ
	|	ДиалогиБезОтвета КАК ДиалогиБезОтвета");
	
	Если ТолькоАвторизованные = Истина Тогда
		
		УсловиеАвторизации = "ПриоритетНазначенияДиалогов.Сотрудник.ИдентификаторПользователяИБ В(&ИдентификаторыАвторизованныхПользователей)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеАвторизации", УсловиеАвторизации);
		Запрос.УстановитьПараметр("ИдентификаторыАвторизованныхПользователей", ИдентификаторыПользователей);
		
	Иначе
		Запрос.УстановитьПараметр("УсловиеАвторизации", Истина);
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВнешняяСистема"		, ВнешняяСистема);
	Запрос.УстановитьПараметр("ВремяСменыОператора"	, ВремяСменыОператора);
	
	Результат = Запрос.ВыполнитьПакет();
	
	Если Результат[3].Пустой() Или Результат[4].Пустой() Тогда
		// Нет операторов, на которых можно перевести диалоги или нет диалогов для перевода.
		Возврат;
	КонецЕсли;
	
	ОчередьОператоров	 = Результат[3].Выгрузить();
	ДиалогиБезОтвета	 = Результат[4].Выбрать();
	
	РазмерОчереди = ОчередьОператоров.Количество();
	
	ТекущаяДата				 = ТекущаяДатаСеанса();
	МессенджерВнешнейСистемы = Перечисления.Мессенджеры.ВернутьТипМессенджераВнешнейСистемы(ВнешняяСистема);
	
	Индекс = 0;
	Пока ДиалогиБезОтвета.Следующий() Цикл
		
		НомерОператора	 = Индекс % РазмерОчереди;
		НовыйОператор	 = ОчередьОператоров[НомерОператора].Сотрудник;
		
		Индекс = Индекс + 1;
		
		НачатьТранзакцию();
		Попытка
			
			// Закрываем диалог, на который оператор не успел ответить.
			ЗакрытьДиалог(
				ДиалогиБезОтвета.ИдДиалога,
				Неопределено,
				ТекущаяДата,
				МессенджерВнешнейСистемы,
				Неопределено,
				"Диалог закрыт автоматически: превышено время ожидания ответа.",
				Истина
			);
			
			ЗначенияЗаполнения = Новый Структура;
			ЗначенияЗаполнения.Вставить("КоличествоСообщений"			, ДиалогиБезОтвета.КоличествоСообщений);
			ЗначенияЗаполнения.Вставить("ИнициированКлиентом"			, Истина);
			ЗначенияЗаполнения.Вставить("ПоследнееСообщениеОтКлиента"	, Истина);
			ЗначенияЗаполнения.Вставить("ДатаПоследнегоСообщения"		, ТекущаяДата);
			ЗначенияЗаполнения.Вставить("ДатаНачальногоСообщенияСерии"	, ТекущаяДата);
			
			// Открываем диалог на выбранного сотрудника.
			СоздатьНовыйДиалог(
				ДиалогиБезОтвета.ИдКлиента,
				ВнешняяСистема,
				НовыйОператор,
				ТекущаяДата,
				МессенджерВнешнейСистемы,,
				ЗначенияЗаполнения,
				Истина
			);
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			ЗаписьЖурналаРегистрации(
				"АвтоматическийПереводДиалогов",
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.РегистрыСведений.Диалоги,,
				СтрШаблон(
					"Не удалось перевести диалог (%1) с ""%2"" на ""%3""",
					ДиалогиБезОтвета.ИдДиалога,
					ДиалогиБезОтвета.Оператор,
					НовыйОператор
				) + Символы.ПС + "Текст ошбики: " + ОписаниеОшибки()
			);
			
		КонецПопытки;
		
	КонецЦикла;
	
	НачатьТранзакцию();
	Попытка
		РегистрыСведений.ПриоритетНазначенияДиалогов.УстановитьФлагПоследнего(ВнешняяСистема, ОчередьОператоров[НомерОператора].ПорядковыйНомер, Истина);
		РегистрыСведений.ПриоритетНазначенияДиалогов.УстановитьФлагПоследнего(ВнешняяСистема, ОчередьОператоров[0].НомерПоследнегоВОчереди, Ложь);
		
		ЗафиксироватьТранзакцию();
	Исключение
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

// Процедура, переносит диалоги по приоритету.
//
Процедура ПеренестиДиалогиПоПриоритету(ВнешняяСистема, ВремяСменыОператора, ТолькоАвторизованные, ИдентификаторыПользователей)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.КоличествоСообщений КАК КоличествоСообщений
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И Диалоги.ИнициированКлиентом
	|	И Диалоги.ДатаНачальногоСообщенияСерии < &ВремяСменыОператора
	|	И Диалоги.КоличествоОтветов = 0
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Оператор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер КАК ПорядковыйНомер,
	|	ПриоритетНазначенияДиалогов.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеАвторизации
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядковыйНомер");
	
	Если ТолькоАвторизованные = Истина Тогда
		
		УсловиеАвторизации = "ПриоритетНазначенияДиалогов.Сотрудник.ИдентификаторПользователяИБ В(&ИдентификаторыАвторизованныхПользователей)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеАвторизации", УсловиеАвторизации);
		Запрос.УстановитьПараметр("ИдентификаторыАвторизованныхПользователей", ИдентификаторыПользователей);
		
	Иначе
		Запрос.УстановитьПараметр("УсловиеАвторизации", Истина);
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВнешняяСистема"		, ВнешняяСистема);
	Запрос.УстановитьПараметр("ВремяСменыОператора"	, ВремяСменыОператора);
	
	Результат = Запрос.ВыполнитьПакет();
	
	Если Результат[0].Пустой() Или Результат[1].Пустой() Тогда
		// Нет операторов, на которых можно перевести диалоги или нет диалогов для перевода.
		Возврат;
	КонецЕсли;
	
	ДиалогиБезОтвета	 = Результат[0].Выбрать();
	ПриоритетОператоров	 = Результат[1].Выгрузить();
	
	ТекущаяДата				 = ТекущаяДатаСеанса();
	МессенджерВнешнейСистемы = Перечисления.Мессенджеры.ВернутьТипМессенджераВнешнейСистемы(ВнешняяСистема);
	ЗаменяемыйОператор		 = Неопределено;
	
	Пока ДиалогиБезОтвета.Следующий() Цикл
		
		Если ЗаменяемыйОператор <> ДиалогиБезОтвета.Оператор Тогда
			
			// Сбрасываем сохраненное значение.
			НовыйОператор = Неопределено;
			
			ЗаменяемыйОператор = ДиалогиБезОтвета.Оператор;
			
			Для Индекс = 1 По ПриоритетОператоров.Количество() - 1 Цикл
				
				Если ПриоритетОператоров[Индекс - 1].Сотрудник = ЗаменяемыйОператор Тогда
					
					НовыйОператор = ПриоритетОператоров[Индекс].Сотрудник;
					Прервать;
					
				КонецЕсли;
				
			КонецЦикла;
			
			// Если не удалось определить назначаемого оператора, берем первого по приоритету.
			НовыйОператор = ?(ЗначениеЗаполнено(НовыйОператор), НовыйОператор, ПриоритетОператоров[0].Сотрудник);
			
		КонецЕсли;
		
		Если НовыйОператор = ДиалогиБезОтвета.Оператор Тогда 
			Продолжить;
		КонецЕсли;
		
		НачатьТранзакцию();
		Попытка
			
			// Закрываем диалог, на который оператор не успел ответить.
			ЗакрытьДиалог(
				ДиалогиБезОтвета.ИдДиалога,
				Неопределено,
				ТекущаяДата,
				МессенджерВнешнейСистемы,
				Неопределено,
				"Диалог закрыт автоматически: превышено время ожидания ответа.",
				Истина
			);
			
			ЗначенияЗаполнения = Новый Структура;
			ЗначенияЗаполнения.Вставить("КоличествоСообщений"			, ДиалогиБезОтвета.КоличествоСообщений);
			ЗначенияЗаполнения.Вставить("ИнициированКлиентом"			, Истина);
			ЗначенияЗаполнения.Вставить("ПоследнееСообщениеОтКлиента"	, Истина);
			ЗначенияЗаполнения.Вставить("ДатаПоследнегоСообщения"		, ТекущаяДата);
			ЗначенияЗаполнения.Вставить("ДатаНачальногоСообщенияСерии"	, ТекущаяДата);
			
			// Открываем диалог на выбранного сотрудника.
			СоздатьНовыйДиалог(
				ДиалогиБезОтвета.ИдКлиента,
				ВнешняяСистема,
				НовыйОператор,
				ТекущаяДата,
				МессенджерВнешнейСистемы,,
				ЗначенияЗаполнения,
				Истина
			);
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			ЗаписьЖурналаРегистрации(
				"АвтоматическийПереводДиалогов",
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.РегистрыСведений.Диалоги,,
				СтрШаблон(
					"Не удалось перевести диалог (%1) с ""%2"" на ""%3""",
					ДиалогиБезОтвета.ИдДиалога,
					ДиалогиБезОтвета.Оператор,
					НовыйОператор
				) + Символы.ПС + "Текст ошбики: " + ОписаниеОшибки()
			);
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, переносит диалоги по загруженности.
//
Процедура ПеренестиДиалогиПоЗагруженности(ВнешняяСистема, ВремяСменыОператора, ТолькоАвторизованные, ИдентификаторыПользователей)
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.КоличествоСообщений КАК КоличествоСообщений
	|ПОМЕСТИТЬ ДиалогиБезОтвета
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ВнешняяСистема = &ВнешняяСистема
	|	И Диалоги.ИнициированКлиентом
	|	И Диалоги.ДатаНачальногоСообщенияСерии < &ВремяСменыОператора
	|	И Диалоги.КоличествоОтветов = 0
	|	И Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриоритетНазначенияДиалогов.Сотрудник КАК Сотрудник,
	|	ПриоритетНазначенияДиалогов.ПорядковыйНомер КАК ПорядковыйНомер
	|ПОМЕСТИТЬ ДоступныеОператоры
	|ИЗ
	|	РегистрСведений.ПриоритетНазначенияДиалогов КАК ПриоритетНазначенияДиалогов
	|ГДЕ
	|	ПриоритетНазначенияДиалогов.ВнешняяСистема = &ВнешняяСистема
	|	И &УсловиеАвторизации
	|	И НЕ ПриоритетНазначенияДиалогов.Сотрудник В
	|				(ВЫБРАТЬ
	|					ДиалогиБезОтвета.Оператор
	|				ИЗ
	|					ДиалогиБезОтвета КАК ДиалогиБезОтвета)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДоступныеОператоры.Сотрудник КАК Оператор,
	|	КОЛИЧЕСТВО(Диалоги.ИдДиалога) КАК КоличествоДиалогов
	|ИЗ
	|	ДоступныеОператоры КАК ДоступныеОператоры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диалоги КАК Диалоги
	|		ПО ДоступныеОператоры.Сотрудник = Диалоги.Оператор
	|			И (Диалоги.ВнешняяСистема = &ВнешняяСистема)
	|			И (Диалоги.ОтложенДо < &ТекущаяДата)
	|			И (Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1))
	|
	|СГРУППИРОВАТЬ ПО
	|	ДоступныеОператоры.Сотрудник,
	|	ДоступныеОператоры.ПорядковыйНомер
	|
	|УПОРЯДОЧИТЬ ПО
	|	КОЛИЧЕСТВО(Диалоги.ИдДиалога),
	|	ДоступныеОператоры.ПорядковыйНомер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДиалогиБезОтвета.ИдДиалога КАК ИдДиалога,
	|	ДиалогиБезОтвета.Оператор КАК Оператор,
	|	ДиалогиБезОтвета.ИдКлиента КАК ИдКлиента,
	|	ДиалогиБезОтвета.КоличествоСообщений КАК КоличествоСообщений
	|ИЗ
	|	ДиалогиБезОтвета КАК ДиалогиБезОтвета");
	
	Если ТолькоАвторизованные = Истина Тогда
		
		УсловиеАвторизации = "ПриоритетНазначенияДиалогов.Сотрудник.ИдентификаторПользователяИБ В(&ИдентификаторыАвторизованныхПользователей)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеАвторизации", УсловиеАвторизации);
		Запрос.УстановитьПараметр("ИдентификаторыАвторизованныхПользователей", ИдентификаторыПользователей);
		
	Иначе
		Запрос.УстановитьПараметр("УсловиеАвторизации", Истина);
		
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДата);
	Запрос.УстановитьПараметр("ВнешняяСистема"		, ВнешняяСистема);
	Запрос.УстановитьПараметр("ВремяСменыОператора"	, ВремяСменыОператора);
	
	Результат = Запрос.ВыполнитьПакет();
	
	Если Результат[2].Пустой() Или Результат[3].Пустой() Тогда
		// Нет операторов, на которых можно перевести диалоги или нет диалогов для перевода.
		Возврат;
	КонецЕсли;
	
	КоличествоДиалоговОператоров = Результат[2].Выгрузить();
	ДиалогиБезОтвета			 = Результат[3].Выбрать();
	
	МессенджерВнешнейСистемы = Перечисления.Мессенджеры.ВернутьТипМессенджераВнешнейСистемы(ВнешняяСистема);
	
	Пока ДиалогиБезОтвета.Следующий() Цикл
		
		Для Индекс = 0 По КоличествоДиалоговОператоров.Количество() - 1 Цикл
			
			Если Индекс < КоличествоДиалоговОператоров.Количество() - 1 Тогда
				
				Если КоличествоДиалоговОператоров[Индекс].КоличествоДиалогов > КоличествоДиалоговОператоров[Индекс + 1].КоличествоДиалогов Тогда
					Продолжить;
					
				Иначе
					НовыйОператор											 = КоличествоДиалоговОператоров[Индекс].Оператор;
					КоличествоДиалоговОператоров[Индекс].КоличествоДиалогов	 = КоличествоДиалоговОператоров[Индекс].КоличествоДиалогов + 1;
					
				КонецЕсли;
				
			Иначе
				НовыйОператор											 = КоличествоДиалоговОператоров[Индекс].Оператор;
				КоличествоДиалоговОператоров[Индекс].КоличествоДиалогов	 = КоличествоДиалоговОператоров[Индекс].КоличествоДиалогов + 1;
				
			КонецЕсли;
			
			НачатьТранзакцию();
			Попытка
				
				// Закрываем диалог, на который оператор не успел ответить.
				ЗакрытьДиалог(
					ДиалогиБезОтвета.ИдДиалога,
					Неопределено,
					ТекущаяДата,
					МессенджерВнешнейСистемы,
					Неопределено,
					"Диалог закрыт автоматически: превышено время ожидания ответа.",
					Истина
				);
				
				ЗначенияЗаполнения = Новый Структура;
				ЗначенияЗаполнения.Вставить("КоличествоСообщений"			, ДиалогиБезОтвета.КоличествоСообщений);
				ЗначенияЗаполнения.Вставить("ИнициированКлиентом"			, Истина);
				ЗначенияЗаполнения.Вставить("ПоследнееСообщениеОтКлиента"	, Истина);
				ЗначенияЗаполнения.Вставить("ДатаПоследнегоСообщения"		, ТекущаяДата);
				ЗначенияЗаполнения.Вставить("ДатаНачальногоСообщенияСерии"	, ТекущаяДата);
				
				// Открываем диалог на выбранного по правилу сотрудника.
				СоздатьНовыйДиалог(
					ДиалогиБезОтвета.ИдКлиента,
					ВнешняяСистема,
					НовыйОператор,
					ТекущаяДата,
					МессенджерВнешнейСистемы,,
					ЗначенияЗаполнения,
					Истина
				);
				
				ЗафиксироватьТранзакцию();
				Прервать;
				
			Исключение
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				ЗаписьЖурналаРегистрации(
					"АвтоматическийПереводДиалогов",
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.РегистрыСведений.Диалоги,,
					СтрШаблон(
						"Не удалось перевести диалог (%1) с ""%2"" на ""%3""",
						ДиалогиБезОтвета.ИдДиалога,
						ДиалогиБезОтвета.Оператор,
						НовыйОператор
					) + Символы.ПС + "Текст ошбики: " + ОписаниеОшибки()
				);
				
			КонецПопытки;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция - Диалог необходимо перевести на оператора
//
// Параметры:
//  ВнешняяСистема			 - 	 - 
//  ИдКлиента				 - 	 - 
//  ИдДиалога				 - 	 - 
//  СообщениеПользователя	 - 	 - 
//  СообщениеБота			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДиалогНеобходимоПеревестиНаОператора(ВнешняяСистема
											, ИдКлиента
											, ИдДиалога
											, СообщениеПользователя = ""
											, СообщениеБота = "") Экспорт
																					
	Если ЗначениеЗаполнено(СообщениеПользователя) И СтрНайти(СообщениеПользователя, "оператор") <> 0 Тогда 
		Возврат Истина;										
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ИдДиалога"		, ИдДиалога);
	Запрос.УстановитьПараметр("ТекстСообщения"	, СообщениеБота);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЖурналСообщений.ИдСообщения) КАК ИдСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ИдДиалога = &ИдДиалога
	|	И ЖурналСообщений.ТекстСообщения ПОДОБНО &ТекстСообщения";
	
	ВыборкаКоличестваСообщений = Запрос.Выполнить().Выбрать();
	Если ВыборкаКоличестваСообщений.Следующий() Тогда 
		Возврат ВыборкаКоличестваСообщений.ИдСообщения > 0; // Это 2 неправильный ответ	
	Иначе 
		Возврат Ложь;
	КонецЕсли;	
	
КонецФункции

#КонецОбласти
