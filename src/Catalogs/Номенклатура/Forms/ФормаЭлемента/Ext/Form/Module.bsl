// Процедура, добавляет элементы формы, для новой строки НС.
// 
Процедура ДобавитьЭлементыФормыСоставНабора(ИДСтрокиДанных = Неопределено)
	
	// Если это добавление элементов формы для новой строки данных
	СтрокаДанных = Неопределено;
	Если ИДСтрокиДанных <> Неопределено Тогда		
		СтрокаДанных  	= Объект.СоставНабора.НайтиПоИдентификатору(ИДСтрокиДанных);
	Иначе
		СтрокаДанных    = Объект.СоставНабора.Добавить();
		СтрокаДанных.СНКоличество = 1;		
		ИДСтрокиДанных  = СтрокаДанных.ПолучитьИдентификатор();
	КонецЕсли;
	
	ПерваяСтрока = ИДСтрокиДанных = 0;	
	
	ГруппаНовыхЭл = Неопределено;
	Если Элементы.Найти("ГруппаСтрокаСН_" + ИДСтрокиДанных) <> Неопределено Тогда		
		ГруппаНовыхЭл = Элементы.Найти("ГруппаСтрокаСН_" + ИДСтрокиДанных);
	Иначе
		ГруппаНовыхЭл                                   = Элементы.Вставить("ГруппаСтрокаСН_" + ИДСтрокиДанных, Тип("ГруппаФормы"), Элементы.ГруппаСоставНабора);// , Элементы.ГруппаДобавитьСтрокуНабора);
		ГруппаНовыхЭл.Вид                               = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаНовыхЭл.Группировка                       = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаНовыхЭл.Отображение                       = ОтображениеОбычнойГруппы.Нет;
		ГруппаНовыхЭл.ОтображатьЗаголовок               = Ложь;
	КонецЕсли;
	
	// Добавляем поле номенклатура
	ПолеНовогоЭлемента                      = Элементы.Добавить("НоменклатураСН_" + ИДСтрокиДанных, Тип("ПолеФормы"), ГруппаНовыхЭл);
	ПолеНовогоЭлемента.Заголовок            = "Услуга";
	ПолеНовогоЭлемента.Вид                  = ВидПоляФормы.ПолеВвода;
	ПолеНовогоЭлемента.ПутьКДанным          = "Объект.СоставНабора[" + (СтрокаДанных.НомерСтроки-1) +"].СННоменклатура";
	ПолеНовогоЭлемента.ПоложениеЗаголовка   = ?(ПерваяСтрока, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
	ПолеНовогоЭлемента.КнопкаВыпадающегосписка = Ложь;
	ПолеНовогоЭлемента.КнопкаВыбора			= Истина;
	ПолеНовогоЭлемента.ОтображениеКнопкиВыбора = ОтображениеКнопкиВыбора.ОтображатьВПолеВвода;
	ПолеНовогоЭлемента.ВыбиратьТип        	= Ложь;
	ПолеНовогоЭлемента.РастягиватьПоГоризонтали = Истина;
	ПолеНовогоЭлемента.АвтоОтметкаНезаполненного = Истина;
	ПолеНовогоЭлемента.ШрифтЗаголовка = Новый Шрифт("Arial",10,,Истина);
	ПолеНовогоЭлемента.АвтоМаксимальнаяШирина = Ложь;
	ПолеНовогоЭлемента.МаксимальнаяШирина 	= 36;	
	ПолеНовогоЭлемента.УстановитьДействие("НачалоВыбора", "СННоменклатураНачалоВыбора_Подключаемый");		
	
	// Добавляем поле количество
	ПолеНовогоЭлемента                      = Элементы.Добавить("КоличествоСН_" + ИДСтрокиДанных, Тип("ПолеФормы"), ГруппаНовыхЭл);
	ПолеНовогоЭлемента.Вид                  = ВидПоляФормы.ПолеВвода;
	ПолеНовогоЭлемента.ПутьКДанным          = "Объект.СоставНабора[" + (СтрокаДанных.НомерСтроки-1) +"].СНКоличество";
	ПолеНовогоЭлемента.ПоложениеЗаголовка   = ?(ПерваяСтрока, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
	ПолеНовогоЭлемента.КнопкаВыпадающегосписка = Ложь;
	ПолеНовогоЭлемента.Заголовок               = "Кол-во";
	ПолеНовогоЭлемента.КнопкаВыбора			   = Ложь;
	ПолеНовогоЭлемента.ОтображениеКнопкиВыбора = ОтображениеКнопкиВыбора.Авто;
	ПолеНовогоЭлемента.ВыбиратьТип        	= Ложь;
	ПолеНовогоЭлемента.РастягиватьПоГоризонтали = Ложь;
	ПолеНовогоЭлемента.Ширина = 6;
	ПолеНовогоЭлемента.АвтоОтметкаНезаполненного = Истина;	
	ПолеНовогоЭлемента.ШрифтЗаголовка = Новый Шрифт("Arial",10,,Истина);
	ПолеНовогоЭлемента.Формат = "ЧДЦ=0";
	ПолеНовогоЭлемента.ФорматРедактирования = "ЧДЦ=0";
	
	ГруппаКомандыУдалить = Неопределено;
	Если Элементы.Найти("ГруппаКомандаУдалитьСН_" + ИДСтрокиДанных) <> Неопределено Тогда		
		ГруппаКомандыУдалить = Элементы.Найти("ГруппаКомандаУдалитьСН_" + ИДСтрокиДанных);
	Иначе
		ГруппаКомандыУдалить                                   = Элементы.Вставить("ГруппаКомандаУдалитьСН_" + ИДСтрокиДанных, Тип("ГруппаФормы"), ГруппаНовыхЭл);
		ГруппаКомандыУдалить.Вид                               = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаКомандыУдалить.Группировка                       = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаКомандыУдалить.Отображение                       = ОтображениеОбычнойГруппы.Нет;
		ГруппаКомандыУдалить.ОтображатьЗаголовок               = Ложь;
	КонецЕсли;
	
	Если ПерваяСтрока Тогда
		ПолеНовогоЭлемента = Элементы.Добавить("ЗаглушкаУдалитьСН", Тип("ДекорацияФормы"), ГруппаКомандыУдалить);
	КонецЕсли;
	
	// Кнопка удаления строки занятия	
	КнопкаУдаленияВремениПроведения                 = Элементы.Добавить("УдалитьСН_" + ИДСтрокиДанных, Тип("КнопкаФормы"), ГруппаКомандыУдалить);
	КнопкаУдаленияВремениПроведения.Отображение     = ОтображениеКнопки.Картинка;
	КнопкаУдаленияВремениПроведения.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
	КнопкаУдаленияВремениПроведения.ИмяКоманды      = "УдалитьСтрокуНабора";	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора".
// 
Процедура СННоменклатураНачалоВыбора_Подключаемый(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметры     = Новый Структура();	
	МассивРазрешенныхТипов = Новый Массив;
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
	
	ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИмениЭлемента(Элемент.Имя);	
	ТекущиеДанные = Объект.СоставНабора.НайтиПоИдентификатору(ИДСтрокиДанных);
	
	СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов", МассивРазрешенныхТипов); 
	СтруктураПараметры.Вставить("Заголовок"                  , "Выберите услугу");	   
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НоменклатураНачалоВыбораЗавершение", ЭтаФорма, Элемент);
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры", СтруктураПараметры,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры
