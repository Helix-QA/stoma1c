// Функция - Получить дату и результат выполнения задачи
//
// Параметры:
//  БизнесПроцесс	 - 	 - 
//  ТочкаМаршрута	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДатуИРезультатВыполненияЗадачи(БизнесПроцесс, ТочкаМаршрута) Экспорт
	
	ЗапросВыборка = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗадачаИсполнителя.ДатаИсполнения,
	|	ЗадачаИсполнителя.РезультатВыполнения,
	|	ЗадачаИсполнителя.РезультатВыполненияПодробно
	|ИЗ
	|	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	|ГДЕ
	|	ЗадачаИсполнителя.Выполнена = ИСТИНА
	|	И ЗадачаИсполнителя.ПометкаУдаления = ЛОЖЬ
	|	И ЗадачаИсполнителя.БизнесПроцесс = &БизнесПроцесс
	|	И ЗадачаИсполнителя.ТочкаМаршрута = &ТочкаМаршрута");
	
	
	ЗапросВыборка.УстановитьПараметр("БизнесПроцесс",БизнесПроцесс);
	ЗапросВыборка.УстановитьПараметр("ТочкаМаршрута",ТочкаМаршрута);
	
	РезультатЗапроса = ЗапросВыборка.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		
		Возврат Новый Структура("ДатаИсполнения,РезультатВыполнения,РезультатВыполненияПодробно",РезультатЗапроса.ДатаИсполнения,РезультатЗапроса.РезультатВыполнения,РезультатЗапроса.РезультатВыполненияПодробно);
		
	Иначе
		
		Возврат Неопределено;
		
	КонецЕсли;
	
КОнецФункции

// Получить задачи для пользователя по клиенту
//
Функция ПолучитьЗадачиВТочкеМаршрута(БизнесПроцесс,ТочкаМаршрута) Экспорт
	
	ЗапросВыборка = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗадачаИсполнителя.Ссылка
	|ИЗ
	|	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	|ГДЕ
	|	ЗадачаИсполнителя.Выполнена = ЛОЖЬ
	|	И ЗадачаИсполнителя.ПометкаУдаления = ЛОЖЬ
	|	И ЗадачаИсполнителя.БизнесПроцесс = &БизнесПроцесс
	|	И ЗадачаИсполнителя.ТочкаМаршрута = &ТочкаМаршрута");
	
	
	ЗапросВыборка.УстановитьПараметр("БизнесПроцесс",БизнесПроцесс);
	ЗапросВыборка.УстановитьПараметр("ТочкаМаршрута",ТочкаМаршрута);
	Задача = ЗапросВыборка.Выполнить().Выгрузить();
	
	Возврат Задача.ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция - Задачи за указанный период
//
// Параметры:
//  НачалоПериода	 - 	 - 
//  КонецПериода	 - 	 - 
//  Сотрудник		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗадачиЗаУказанныйПериод(Знач НачалоПериода,
	Знач КонецПериода, 
	Знач Сотрудник = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Сотрудник"        , Сотрудник);
	Запрос.УстановитьПараметр("ДатаНачала"       , НачалоПериода);
	Запрос.УстановитьПараметр("ДатаОкончания"    , КонецПериода);
	Запрос.УстановитьПараметр("ТекущаяДата"      , НачалоДня(ТекущаяДата()));
	
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗадачаИсполнителя.Ссылка КАК Значение,
	|	ЗадачаИсполнителя.ЗадачаНазначеннаяДата КАК ВремяНачала,
	|	ЗадачаИсполнителя.ЗадачаНазначеннаяДата КАК ВремяОкончания,
	|	ЗадачаИсполнителя.Наименование КАК Текст,
	|	""Сегодня"" КАК Статус,
	|	ЗадачаИсполнителя.Выполнена,
	|	ВЫБОР
	|		КОГДА ЗадачаИсполнителя.Выполнена
	|			ТОГДА ""БледноЗеленый""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НАЧАЛОПЕРИОДА(ЗадачаИсполнителя.ЗадачаНазначеннаяДата, ДЕНЬ) < &ТекущаяДата
	|					ТОГДА ""СветлоКоралловый""
	|			КОНЕЦ
	|	КОНЕЦ КАК Цвет,
	|	ЗадачаИсполнителя.РезультатВыполнения.Наименование КАК РезультатВыполнения,
	|	ВЫБОР
	|		КОГДА ЗадачаИсполнителя.ВидВзаимодействия = ЗНАЧЕНИЕ(Перечисление.ВидыВзаимодействия.Встреча)
	|			ТОГДА ""Встреча""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ЗадачаИсполнителя.ВидВзаимодействия = ЗНАЧЕНИЕ(Перечисление.ВидыВзаимодействия.ЗвонокВходящий)
	|					ТОГДА ""ТелефонныйЗвонокВходящий""
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ЗадачаИсполнителя.ВидВзаимодействия = ЗНАЧЕНИЕ(Перечисление.ВидыВзаимодействия.ЗвонокИсходящий)
	|							ТОГДА ""ТелефонныйЗвонокИсходящий""
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК Картинка,
	|	ЗадачаИсполнителя.ВидВзаимодействия,
	|	ЗадачаИсполнителя.Исполнитель КАК Сотрудник
	|ИЗ
	|	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	|ГДЕ
	|	ЗадачаИсполнителя.Исполнитель В(&Сотрудник)
	|	И ЗадачаИсполнителя.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	
	Возврат Запрос.Выполнить().Выгрузить();		
	
	
	
	
КонецФункции

// Процедура - Заполнить параметры напоминания
//
// Параметры:
//  ЗадачаОбъект				 - 	 - 
//  СтруктураРеквизитовЗадачи	 - 	 - 
//
Процедура ЗаполнитьПараметрыНапоминания(ЗадачаОбъект, Знач СтруктураРеквизитовЗадачи) Экспорт
	
	Если СтруктураРеквизитовЗадачи.ЗадачаРежимНапоминания = -1 Тогда 
		ЗадачаОбъект.НапоминаниеИспользовать 		= Ложь;
		ЗадачаОбъект.НапоминаниеДатаНачала 			= Дата(1,1,1);
	ИначеЕсли СтруктураРеквизитовЗадачи.ЗадачаРежимНапоминания = 1 Тогда	
		ЗадачаОбъект.НапоминаниеИспользовать 		= Истина;
		ЗадачаОбъект.ВариантНапоминания 			= Перечисления.ВариантыНапоминаний.ПоПосещению;			
		ЗадачаОбъект.НапоминаниеДатаНачала 			= Дата(1,1,1);
	Иначе 
		ЗадачаОбъект.НапоминаниеИспользовать 		= Истина;
		ЗадачаОбъект.ВариантНапоминания 			= Перечисления.ВариантыНапоминаний.ЗаВремяОтносительноСобытия;			
		ЗадачаОбъект.НапоминаниеДатаНачала 			= ЗадачаОбъект.ЗадачаНазначеннаяДата - СтруктураРеквизитовЗадачи.ЗадачаРежимНапоминания;
	КонецЕсли;
	
КонецПроцедуры

