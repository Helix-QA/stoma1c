// Процедура - Заполнить таблицу получателей.
//
// Параметры:
//  МассивКлиентов	 - 	 - 
//
Процедура ЗаполнитьТаблицуПолучателей(МассивКлиентов = Неопределено)

	Если Не ЗначениеЗаполнено(МассивКлиентов)
		И ЗначениеЗаполнено(Объект.Получатели) Тогда
		
		МассивКлиентов = Объект.Получатели.Выгрузить().ВыгрузитьКолонку("Получатель");		
	КонецЕсли;	
	
	Объект.Получатели.Очистить();
	
	Если Объект.Тип = Перечисления.ТипыСобытий.SMS Тогда
		
		ЗаполнитьПолучателейSMSСообщения(МассивКлиентов);
		
	ИначеЕсли Объект.Тип = Перечисления.ТипыСобытий.ПушУведомление Тогда
		
		ЗаполнитьПолучателейPushУведомленияWallet(МассивКлиентов);
		
	ИначеЕсли Объект.Тип = Перечисления.ТипыСобытий.Мессенджер Тогда
		
		ЗаполнитьПолучателейСообщенияMessenger(МассивКлиентов);
		Если ЭтотОбъект.MessengerОтправитьВсем Тогда
			ЗаполнитьПолучателейСообщенияMessengerИнициироватьОтправку(МассивКлиентов);
		КонецЕсли;	
		
	КонецЕсли;
	
	Объект.Получатели.Сортировать("Получатель");
	ЗаполнитьПредставлениеКоличестваПолучателей();
	
КонецПроцедуры 

