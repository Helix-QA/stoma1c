
#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Функция, находит или создает рекламный источник по наименованию.
//
Функция ПолучитьРекламныйИсточник(Наименование, СоздатьПриОтсутствии = Ложь) Экспорт
	
	Если ТипЗнч(Наименование) <> Тип("Строка") Тогда
		Возврат Неопределено;
	КонецЕсли;

	ИсточникИнформации = ПолучитьИсточникИнформацииПоНаименованию(Наименование);		
	
	Если НЕ ЗначениеЗаполнено(ИсточникИнформации) И СоздатьПриОтсутствии = Истина Тогда
		ИсточникИнформации = СоздатьРекламныйИсточник(Наименование);
	КонецЕсли;
		
	Возврат ИсточникИнформации;

КонецФункции

// Функция - Получить источник информации по наименованию
//
Функция ПолучитьИсточникИнформацииПоНаименованию(Наименование)
	
	Если ТипЗнч(Наименование) <> Тип("Строка") Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	РекламныеИсточники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	НЕ РекламныеИсточники.ПометкаУдаления
	|	И РекламныеИсточники.Наименование ПОДОБНО ВЫРАЗИТЬ(&Наименование КАК СТРОКА(150))";
	
	Запрос.УстановитьПараметр("Наименование", "%" + Наименование + "%");
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Функция - Рекламный источник по наименованию.
//
// Параметры:
//  Наименование - 	 -
//
// Возвращаемое значение:
//   -
//
Функция РекламныйИсточникПоНаименованию(Наименование) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	РекламныеИсточники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.ПометкаУдаления = ЛОЖЬ
	|	И РекламныеИсточники.Наименование ПОДОБНО ""%"" + &Наименование + ""%""
	|	И РекламныеИсточники.Активный = ИСТИНА");
	
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Функция - Создать рекламный источник.
//
// Параметры:
//  Анкета			 - 	 -
//  КлючСистемы		 - 	 -
//  ПубликацииАдрес	 - 	 -
//  ПубликацииЛогин	 - 	 -
//  ПубликацииПароль - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьРекламныйИсточник(РекламныйИсточник) Экспорт
		
	РекламныйИсточникОбъект              = Справочники.РекламныеИсточники.СоздатьЭлемент();
	РекламныйИсточникОбъект.Наименование = РекламныйИсточник;
	РекламныйИсточникОбъект.Активный     = Истина;

	УсловияОтбора = Новый Структура();
	ДобавитьРеквизитВСтруктуру(УсловияОтбора, "source"		, "");
	ДобавитьРеквизитВСтруктуру(УсловияОтбора, "medium"		, "");
	ДобавитьРеквизитВСтруктуру(УсловияОтбора, "campaign" 	, "");
	ДобавитьРеквизитВСтруктуру(УсловияОтбора, "content" 	, "");
	ДобавитьРеквизитВСтруктуру(УсловияОтбора, "term" 		, "");
	ДобавитьРеквизитВСтруктуру(УсловияОтбора, "комментарий" , "");
		
	РекламныйИсточникОбъект.Условия = Новый ХранилищеЗначения(УсловияОтбора);

	РекламныйИсточникОбъект.ОбменДанными.Загрузка = Истина;
	Попытка
		РекламныйИсточникОбъект.Записать();
		Возврат РекламныйИсточникОбъект.Ссылка;		
	Исключение
		
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

// Процедура, добавляет реквизит в структуру.
//
Процедура ДобавитьРеквизитВСтруктуру(УсловияОтбора, НаименованиеРеквизита, ЗначениеРеквизита)
	
	Если УсловияОтбора.Свойство(НаименованиеРеквизита) Тогда
		УсловияОтбора[НаименованиеРеквизита] = ЗначениеРеквизита;
	Иначе
		УсловияОтбора.Вставить(НаименованиеРеквизита, ЗначениеРеквизита); 
	КонецЕсли;
	
КонецПроцедуры

// Функция, возвращает найденный рекламный источник.
//
// Параметры:
//  ПараметрыПоиска	- Структура - см. модуль объекта заявок 
// 
// Возвращаемое значение:
//  РекламныйИсточник - СправочникСсылка.РекламныеИсточники
//
Функция ПолучитьСоздатьРекламныйИсточникПоНаименованию(Наименование) Экспорт
	
	СуществующийРекламныйИсточник = ПолучитьРекламныйИсточник(Наименование);
	Возврат ?(СуществующийРекламныйИсточник = Неопределено, СоздатьРекламныйИсточник(Наименование), СуществующийРекламныйИсточник);
	
КонецФункции

// Процедура - Обработка получения представления.
//
// Параметры:
//  Данные				 - 	 - 
//  Представление		 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если ПользователиСлужебныйПовтИсп.ЯзыкИнтерфейсаАнглийский() Тогда
		
		Если Данные.Ссылка = Справочники.РекламныеИсточники.ДругойПациент Тогда
			Представление = "Another Patient";
		КонецЕсли;
		
	КонецЕсли;
	                    
КонецПроцедуры

// Функция, возвращает найденный рекламный источник.
//
// Параметры:
//  ПараметрыПоиска	- Структура - см. модуль объекта заявок 
// 
// Возвращаемое значение:
//  РекламныйИсточник - СправочникСсылка.РекламныеИсточники
//
Функция ПолучитьРекламныйИсточникПоПараметрамЗаявки(ПараметрыПоиска) Экспорт
	
	Если Не ЗначениеЗаполнено(ПараметрыПоиска) Тогда
		Возврат Справочники.РекламныеИсточники.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РекламныеИсточники.Ссылка КАК Ссылка,
	|	0 КАК ПорядокСоответствия
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	НЕ РекламныеИсточники.ПометкаУдаления
	|	И НЕ РекламныеИсточники.Активный";
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() > 0 Тогда
		Для Каждого СтрокаТЗ Из Результат Цикл
			МеткиUTM = СтрокаТЗ.Ссылка.Условия.Получить();
			Если ТипЗнч(МеткиUTM) = Тип("Структура") Тогда
				Для Каждого КлючИЗначение Из ПараметрыПоиска Цикл
					
					Ключ	 = КлючИЗначение.Ключ;
					Значение = КлючИЗначение.Значение;
					
					Если ВРег(Ключ) = "КОММЕНТАРИЙ" Тогда
						Продолжить;
					ИначеЕсли МеткиUTM.Свойство(Ключ) И Не ЗначениеЗаполнено(МеткиUTM[Ключ]) И ЗначениеЗаполнено(Значение) Тогда
					    СтрокаТЗ.ПорядокСоответствия = СтрокаТЗ.ПорядокСоответствия - 1;
					ИначеЕсли МеткиUTM.Свойство(Ключ) И МеткиUTM[Ключ] = Значение И ЗначениеЗаполнено(Значение) Тогда
						СтрокаТЗ.ПорядокСоответствия = СтрокаТЗ.ПорядокСоответствия + 10;
					ИначеЕсли МеткиUTM.Свойство(Ключ) И МеткиUTM[Ключ] <> Значение Тогда
						СтрокаТЗ.ПорядокСоответствия = СтрокаТЗ.ПорядокСоответствия - 100;
					КонецЕсли;
					
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		Результат.Сортировать("ПорядокСоответствия Убыв");
		ПодходящаяСтрока = Результат[0];
		Возврат ?(ПодходящаяСтрока.ПорядокСоответствия > 0, ПодходящаяСтрока.Ссылка, Неопределено);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция, возвращает рекламный источник, соответствующий типу внешней системы заявки.
//
// Параметры:
//  ПараметрыПоиска	- Структура - см. модуль объекта заявок 
// 
// Возвращаемое значение:
//  РекламныйИсточник - СправочникСсылка.РекламныеИсточники
//
Функция ПолучитьРекламныйИсточникВнешнейСистемы(ТипВнешнейСистемы, ИмяКвиз) Экспорт
	
	НаименованиеРекламногоИсточника = ПолучитьНаименованиеРекламногоИсточникаПоТипуВнешнейСистемы(ТипВнешнейСистемы, ИмяКвиз);
	Возврат ?(НаименованиеРекламногоИсточника = "", Неопределено, ПолучитьСоздатьРекламныйИсточникПоНаименованию(НаименованиеРекламногоИсточника));
	
КонецФункции

// Функция, возвращает наименование рекламного источника по типу внешней системы заявки.
//
// Параметры:
//  ПараметрыПоиска	- Структура - см. модуль объекта заявок 
// 
// Возвращаемое значение:
//  РекламныйИсточник - СправочникСсылка.РекламныеИсточники
//
Функция ПолучитьНаименованиеРекламногоИсточникаПоТипуВнешнейСистемы(ТипВнешнейСистемы, ИмяКвиз) Экспорт
	
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Tilda Тогда
		Возврат "tilda";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Vkontakte Тогда
		Возврат "vk.com";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.TapLink Тогда
		Возврат "instagram";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Marquiz Тогда
		Возврат "marquiz:" + ИмяКвиз;
	Иначе
		Возврат "";
	КонецЕсли;
		
КонецФункции

#КонецОбласти
	
#КонецЕсли
