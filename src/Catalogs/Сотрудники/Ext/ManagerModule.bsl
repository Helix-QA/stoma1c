// Функция - Найти создать должность сотрудника.
//
// Параметры:
//  Должность	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НайтиСоздатьДолжностьСотрудника(Должность);
	
	ИскДолжность = Справочники.Должности.НайтиПоНаименованию(Должность, Истина);
	Если ИскДолжность.Пустая() Тогда
		ИскДолжность = Справочники.Должности.СоздатьЭлемент();
		ИскДолжность.Наименование = Должность;
		ИскДолжность.Записать();
	КонецЕсли;
	
	Возврат ИскДолжность.Ссылка;
	
КонецФункции

// Процедура - Заполнение контактной информации.
//
// Параметры:
//  СтрокаТаблицы		 - 	 - 
//  ЭлементСправочника	 - 	 - 
//
Процедура ЗаполнениеКонтактнойИнформации(СтрокаТаблицы, ЭлементСправочника)
	
	Сотрудники_КонтактнаяИнформация = ЭлементСправочника.КонтактнаяИнформация;
	
	Если НЕ ПустаяСтрока(СтрокаТаблицы.АдресФакт) Тогда
		
		Объект_XDTO_Адрес = ПолучитьСтруктуру_XDTO(СтрокаТаблицы.АдресФакт, Перечисления.ТипыКонтактнойИнформации.Адрес);
		
		Если Объект_XDTO_Адрес <> Неопределено Тогда
			
			// Найти в КИ существующий Адрес
			Представление = Объект_XDTO_Адрес.Представление;
			
			НайденныеСтроки = Сотрудники_КонтактнаяИнформация.НайтиСтроки(Новый Структура("Представление, Тип", Представление, Перечисления.ТипыКонтактнойИнформации.Адрес));
			Если НайденныеСтроки.Количество() = 0 Тогда
				ЗаполнитьАдрес(ЭлементСправочника, Объект_XDTO_Адрес , Справочники.ВидыКонтактнойИнформации.АдресСотрудника);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(СтрокаТаблицы.Телефон) Тогда
		
		МассивТелефонов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТаблицы.Телефон, ",",Истина, Истина);
		Для Каждого Телефон Из МассивТелефонов Цикл 
			
			СписокПолей = Новый СписокЗначений;
			УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Телефон, СписокПолей);			
			
			Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(СокрЛП(Телефон), Перечисления.ТипыКонтактнойИнформации.Телефон);
			
			Если Объект_XDTO_Телефон <> Неопределено Тогда
				
				// Найти в КИ существующий телефон
				НомерТелефона = Объект_XDTO_Телефон.Состав.Номер;
				НайденныеСтроки = Сотрудники_КонтактнаяИнформация.НайтиСтроки(Новый Структура("НомерТелефона, Тип", НомерТелефона, Перечисления.ТипыКонтактнойИнформации.Телефон));
				Если НайденныеСтроки.Количество() = 0 Тогда
					ЗаполнитьТелефон(ЭлементСправочника, Объект_XDTO_Телефон, Справочники.ВидыКонтактнойИнформации.ТелефонСотрудника);
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;	
		
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(СтрокаТаблицы.АдресЭП) Тогда
		
		МассивАдресЭП = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТаблицы.АдресЭП, ",",Истина, Истина);
		Для Каждого АдресЭП Из МассивАдресЭП Цикл 
			
			Объект_XDTO_Email = ПолучитьСтруктуру_XDTO(СокрЛП(АдресЭП), Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
			
			Если Объект_XDTO_Email <> Неопределено  Тогда
				
				// Найти в КИ существующий АдресЭлектроннойПочты
				Представление = Объект_XDTO_Email.Представление;
				
				НайденныеСтроки = Сотрудники_КонтактнаяИнформация.НайтиСтроки(Новый Структура("Представление, Тип", Представление, Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
				Если НайденныеСтроки.Количество() = 0 Тогда
					ЗаполнитьEmail(ЭлементСправочника, Объект_XDTO_Email, Справочники.ВидыКонтактнойИнформации.EmailПользователя);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;	
		
	КонецЕсли;

КонецПроцедуры

// Функция - Получить структуру XDTO телефона
//
// Параметры:
//  Телефон	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуру_XDTO(Представление, ТипКИ)
	
	Если НЕ ЗначениеЗаполнено(Представление) Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	Объект_XDTO = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Представление, ТипКИ);
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
		Если НЕ ЗначениеЗаполнено(Объект_XDTO.Состав.Номер) Тогда 
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат Объект_XDTO;
	
КонецФункции

// Процедура - Заполнить телефон 
//
// Параметры:
//  НовыйЭлемент		 - 	 - 
//  Объект_XDTO_Телефон	 - 	 - 
//
Процедура ЗаполнитьТелефон(НовыйЭлемент, Знач Объект_XDTO_Телефон, Знач ВидКИ)
	
	Если Объект_XDTO_Телефон = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 						= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 					= Перечисления.ТипыКонтактнойИнформации.Телефон;
	НоваяСтрока.Вид 					= ВидКИ;
	НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(СтрЗаменить(Объект_XDTO_Телефон.Состав.Номер, "-", ""));
	НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
	
	НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияXMLПоПредставлению(Объект_XDTO_Телефон.Представление,ВидКИ);
	НоваяСтрока.Значение 				= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Объект_XDTO_Телефон.Представление, ВидКИ);

	НоваяСтрока.Представление			= Объект_XDTO_Телефон.Представление;
	//НоваяСтрока.ЗначенияПолей			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
	
КонецПроцедуры

// Процедура - Заполнить email 
//
// Параметры:
//  НовыйЭлемент		 - 	 - 
//  Объект_XDTO_Email	 - 	 - 
//
Процедура ЗаполнитьEmail(НовыйЭлемент, Знач Объект_XDTO_Email, Знач ВидКИ)
	
	Если Объект_XDTO_Email = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 				= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 			= Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	НоваяСтрока.Вид 			= ВидКИ;
	НоваяСтрока.АдресЭП 		= Объект_XDTO_Email.Представление;
	НоваяСтрока.ЗначенияПолей 	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Email);
	НоваяСтрока.Значение 		= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Объект_XDTO_Email.Представление, ВидКИ);
	НоваяСтрока.Представление 	= НоваяСтрока.АдресЭП;
	
КонецПроцедуры

// Процедура - Заполнить адрес
//
// Параметры:
//  НовыйЭлемент		 - 	 - 
//  Объект_XDTO_Адрес	 - 	 - 
//  ВидКИ				 - 	 - 
//
Процедура ЗаполнитьАдрес(НовыйЭлемент, Знач Объект_XDTO_Адрес, Знач ВидКИ)
	
	Если Объект_XDTO_Адрес = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	НоваяСтрока 				= НовыйЭлемент.КонтактнаяИнформация.Добавить();
	НоваяСтрока.Тип 			= Перечисления.ТипыКонтактнойИнформации.Адрес;
	НоваяСтрока.Вид 			= ВидКИ;
	НоваяСтрока.Страна 			= ?(Объект_XDTO_Адрес.Состав.Страна = Неопределено, "", Объект_XDTO_Адрес.Состав.Страна);
	НоваяСтрока.Регион 			= ?(Объект_XDTO_Адрес.Состав.Состав.СубъектРФ = Неопределено, "", Объект_XDTO_Адрес.Состав.Состав.СубъектРФ);
	НоваяСтрока.Город 			= ?(Объект_XDTO_Адрес.Состав.Состав.Город = Неопределено, "", Объект_XDTO_Адрес.Состав.Состав.Город);
	НоваяСтрока.ЗначенияПолей 	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Адрес);
	НоваяСтрока.Значение 		= УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Объект_XDTO_Адрес.Представление, ВидКИ);
	НоваяСтрока.Представление 	= Объект_XDTO_Адрес.Представление;
	
КонецПроцедуры

// Функция, находит или если не найдена группа, то создает ее.
//
// Параметры:
//  РодительНаименование	 - Строка 				- Наименование группы которую ищем. 
//  РодительВерхнегоУровня	 - СправочникСсылка 	- Ссылка на справочник родителя группы которую ищем.
//  ТипНоменклатуры			 - ПеречислениеСсылка 	- Перечисление типов номенклатуры. 
// 
// Возвращаемое значение:
//  Родитель - Ссылка на группу номенклатуры.
//
Функция НайтиСоздатьГруппу(РодительНаименование, РодительВерхнегоУровня = Неопределено)
	
	Родитель = Справочники.Сотрудники.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ЭтоГруппа = ИСТИНА
	|	И Сотрудники.Наименование = &Наименование
	|	И ВЫБОР
	|			КОГДА &РодительВерхнегоУровня <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Сотрудники.Родитель = &РодительВерхнегоУровня
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Наименование"          , РодительНаименование);
	Запрос.УстановитьПараметр("РодительВерхнегоУровня", РодительВерхнегоУровня);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Родитель = Выборка.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Родитель) Тогда
		
		// Создать родителя
		РодительОбъект                 = Справочники.Сотрудники.СоздатьГруппу();
		РодительОбъект.Наименование    = РодительНаименование;
		Если ЗначениеЗаполнено(РодительВерхнегоУровня) Тогда 
			РодительОбъект.Родитель = РодительВерхнегоУровня;
		КонецЕсли;
		
		РодительОбъект.Записать();
		Родитель = РодительОбъект.Ссылка;
		
	КонецЕсли;
	
	Возврат Родитель;
	
КонецФункции

// Функция - Получить массив сотрудников по специализации
//
// Параметры:
//  Специализация	 - 	 - 
//  ТолькоПоОсновным - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивСотрудниковПоРолям(МассивРолей) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивРолей", МассивРолей);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И Сотрудники.Служебный = ЛОЖЬ
	|	И Сотрудники.Роль В (&МассивРолей)";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция, возвращает массив сотрудников с отобором по ролям из сеанса ИБ.
//
Функция ПолучитьМассивСотрудниковПоРолямИзСеансаИБ(МассивРолей, ДобавитьТекущегоПользователя = Ложь) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(МассивРолей) Тогда
		Возврат Новый Массив;
	ИначеЕсли НЕ ТипЗнч(МассивРолей) = Тип("Массив") Тогда
		МассивРолей = Новый_Массив(МассивРолей);
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СоединенияИнформационнойБазы.Пользователь КАК Пользователь
	|ИЗ
	|	РегистрСведений.СоединенияИнформационнойБазы КАК СоединенияИнформационнойБазы
	|ГДЕ
	|	СоединенияИнформационнойБазы.Пользователь.ПометкаУдаления = ЛОЖЬ
	|	И СоединенияИнформационнойБазы.Пользователь.ЭтоГруппа = ЛОЖЬ
	|	И СоединенияИнформационнойБазы.Пользователь.Служебный = ЛОЖЬ
	|	И СоединенияИнформационнойБазы.Пользователь.Роль В(&МассивРолей)
	|	И &УсловиеТекущийПользователь");
	
	Запрос.УстановитьПараметр("МассивРолей", МассивРолей);
	
	УсловиеТекущийПользователь = ?(ДобавитьТекущегоПользователя = Истина, "НЕ СоединенияИнформационнойБазы.Пользователь = &УсловиеТекущийПользователь", "ИСТИНА");		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТекущийПользователь", УсловиеТекущийПользователь);
	Запрос.УстановитьПараметр("УсловиеТекущийПользователь", ПараметрыСеанса.ТекущийСотрудник);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Пользователь");
	
	Если ДобавитьТекущегоПользователя = Истина Тогда
		Результат.Добавить(ПараметрыСеанса.ТекущийСотрудник);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

 // Функция - Получить сотрудников структурной единицы.
//
// Параметры:
//  СтруктЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСотрудниковСтруктурнойЕдиницы(
	ОтборСтруктурнаяЕдиница, 
	ОтборРольПользователя = Неопределено, 
	ОтборДолжность        = Неопределено,
	ОтборНаДату           = Неопределено,
	ВернутьДетально       = Ложь) Экспорт
				
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.Сотрудник КАК Ссылка
	|ПОМЕСТИТЬ УволенныеСотрудники
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА ЕСТЬNULL(НастройкиСотрудников.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА НастройкиСотрудников.ДатаУвольнения <= &ОтборНаДату
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СотрудникиМестаРаботы.Ссылка КАК Ссылка,
	|	СотрудникиМестаРаботы.Ссылка.Наименование КАК Наименование,
	|	СотрудникиМестаРаботы.Ссылка.Должность КАК Должность
	|ИЗ
	|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиМестаРаботы
	|ГДЕ
	|	СотрудникиМестаРаботы.СтруктурнаяЕдиница = &ОтборСтруктурнаяЕдиница
	|	И НЕ СотрудникиМестаРаботы.Ссылка.ЭтоГруппа
	|	И НЕ СотрудникиМестаРаботы.Ссылка.ПометкаУдаления
	|	И НЕ СотрудникиМестаРаботы.Ссылка В
	|				(ВЫБРАТЬ
	|					УволенныеСотрудники.Ссылка
	|				ИЗ
	|					УволенныеСотрудники КАК УволенныеСотрудники)
	|	И &УсловиеРольПользователя
	|	И &УсловиеДолжность
	|
	|УПОРЯДОЧИТЬ ПО
	|	СотрудникиМестаРаботы.Ссылка.Наименование");
		
	Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);	
	Запрос.УстановитьПараметр("ОтборРольПользователя"  , ОтборРольПользователя);
    Запрос.УстановитьПараметр("ОтборДолжность"         , ОтборДолжность);
    Запрос.УстановитьПараметр("ОтборНаДату"            , ?(ЗначениеЗаполнено(ОтборНаДату), НачалоДня(ОтборНаДату), НачалоДня(ТекущаяДата())));
		
	УсловиеРольПользователя = ?(ЗначениеЗаполнено(ОтборРольПользователя), "И СотрудникиМестаРаботы.Ссылка.Роль В (&ОтборРольПользователя)", "");
	Запрос.Текст            = СтрЗаменить(Запрос.Текст, "И &УсловиеРольПользователя", УсловиеРольПользователя);

	УсловиеДолжность        = ?(ЗначениеЗаполнено(ОтборДолжность), "И СотрудникиМестаРаботы.Ссылка.Должность В (&ОтборДолжность)", "");
	Запрос.Текст            = СтрЗаменить(Запрос.Текст, "И &УсловиеДолжность", УсловиеДолжность);
		
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если ВернутьДетально Тогда 
		Возврат РезультатЗапроса;
	Иначе 
		Возврат РезультатЗапроса.ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
КонецФункции

// Функция - Получить сотрудников для журнала записи
//
// Параметры:
//  ОтборСтруктурнаяЕдиница	 - 	 - 
//  ОтборРольПользователя	 - 	 - 
//  ОтборДолжность			 - 	 - 
//  ОтборНаДату				 - 	 - 
//  ОтборСпециализации		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСотрудниковДляЖурналаЗаписи(ОтборСтруктурнаяЕдиница, Настройки, ОтборРольПользователя = Неопределено, ОтборДолжность = Неопределено, ОтборНаДату = Неопределено, ОтборСпециализации = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СправочникСотрудники.Ссылка КАК Сотрудник,
	|	СправочникСотрудники.Должность КАК Должность
	|ПОМЕСТИТЬ ТаблицаСотрудников
	|ИЗ
	|	Справочник.Сотрудники КАК СправочникСотрудники
	|ГДЕ
	|	СправочникСотрудники.ПометкаУдаления = ЛОЖЬ
	|	И СправочникСотрудники.Служебный = ЛОЖЬ
	|	И &УсловиеДолжность
	|
	|СГРУППИРОВАТЬ ПО
	|	СправочникСотрудники.Ссылка,
	|	СправочникСотрудники.Должность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СотрудникиСпецилазацииСотрудника.Ссылка КАК Сотрудник,
	|	МАКСИМУМ(СотрудникиСпецилазацииСотрудника.Специализация) КАК Специализация,
	|	МАКСИМУМ(СотрудникиСпецилазацииСотрудника.Основная) КАК Основная
	|ПОМЕСТИТЬ ТаблицаСпециализаций
	|ИЗ
	|	Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|ГДЕ
	|	СотрудникиСпецилазацииСотрудника.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСотрудников.Сотрудник КАК Сотрудник
	|			ИЗ
	|				ТаблицаСотрудников КАК ТаблицаСотрудников)
	|	И &УсловиеСпециализации1
	|	И СотрудникиСпецилазацииСотрудника.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
	|	И СотрудникиСпецилазацииСотрудника.Основная = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	СотрудникиСпецилазацииСотрудника.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СотрудникиСпецилазацииСотрудника.Ссылка,
	|	МАКСИМУМ(СотрудникиСпецилазацииСотрудника.Специализация),
	|	МАКСИМУМ(СотрудникиСпецилазацииСотрудника.Основная)
	|ИЗ
	|	Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
	|ГДЕ
	|	СотрудникиСпецилазацииСотрудника.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаСотрудников.Сотрудник КАК Сотрудник
	|			ИЗ
	|				ТаблицаСотрудников КАК ТаблицаСотрудников)
	|	И &УсловиеСпециализации1
	|	И СотрудникиСпецилазацииСотрудника.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
	|	И СотрудникиСпецилазацииСотрудника.Основная = ЛОЖЬ
	|
	|СГРУППИРОВАТЬ ПО
	|	СотрудникиСпецилазацииСотрудника.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	|	ТаблицаСотрудников.Должность КАК Должность,
	|	ЕСТЬNULL(ЕСТЬNULL(ТаблицаСпециализаций.Специализация, ТаблицаСпециализаций1.Специализация), ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)) КАК Специализация
	|ПОМЕСТИТЬ ТаблицаСотрудниковСпециализаций
	|ИЗ
	|	ТаблицаСотрудников КАК ТаблицаСотрудников
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСпециализаций КАК ТаблицаСпециализаций
	|		ПО ТаблицаСотрудников.Сотрудник = ТаблицаСпециализаций.Сотрудник
	|			И (ТаблицаСпециализаций.Основная = ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСпециализаций КАК ТаблицаСпециализаций1
	|		ПО ТаблицаСотрудников.Сотрудник = ТаблицаСпециализаций1.Сотрудник
	|			И (ТаблицаСпециализаций1.Основная = ЛОЖЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкиСотрудников.Сотрудник КАК Сотрудник,
	|	НастройкиСотрудников.ДатаУвольнения КАК ДатаУвольнения
	|ПОМЕСТИТЬ ВТСотрудникиУволенные
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.Сотрудник В
	|			(ВЫБРАТЬ
	|				ТаблицаСотрудников.Сотрудник КАК Сотрудник
	|			ИЗ
	|				ТаблицаСотрудников КАК ТаблицаСотрудников)
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сотрудники.Сотрудник КАК Сотрудник,
	|	ТаблицаСотрудниковСпециализаций.Специализация.Наименование КАК СпециализацияНаименование,
	|	ТаблицаСотрудниковСпециализаций.Должность.Наименование КАК ДолжностьНаименование,
	|	ТаблицаСотрудниковСпециализаций.Сотрудник.Наименование КАК СотрудникНаименование
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСотрудникиУволенные КАК ВТСотрудникиУволенные
	|		ПО Сотрудники.Сотрудник = ВТСотрудникиУволенные.Сотрудник
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаСотрудниковСпециализаций КАК ТаблицаСотрудниковСпециализаций
	|		ПО Сотрудники.Сотрудник = ТаблицаСотрудниковСпециализаций.Сотрудник
	|ГДЕ
	|	Сотрудники.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И &УсловиеСпециализации2
	|	И ВЫБОР
	|			КОГДА НЕ ТаблицаСотрудниковСпециализаций.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
	|				ТОГДА ТаблицаСотрудниковСпециализаций.Должность.ОтображатьВЖурналеПредварительнойЗаписи = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И (ВТСотрудникиУволенные.ДатаУвольнения > &ОтборДатаВремяНачалаРаботы
	|			ИЛИ ЕСТЬNULL(ВТСотрудникиУволенные.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) = ДАТАВРЕМЯ(1, 1, 1))
	|
	|СГРУППИРОВАТЬ ПО
	|	Сотрудники.Сотрудник,
	|	ТаблицаСотрудниковСпециализаций.Специализация.Наименование,
	|	ТаблицаСотрудниковСпециализаций.Сотрудник.Наименование,
	|	ТаблицаСотрудниковСпециализаций.Должность.Наименование");			
	
	Если Настройки.ОтображениеСортировка = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСортировкаВариант1 Тогда  
		// ФИО.
		Сортировка = "УПОРЯДОЧИТЬ ПО
	|	ТаблицаСотрудниковСпециализаций.Сотрудник.Наименование"; 
	ИначеЕсли Настройки.ОтображениеСортировка = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеСортировкаВариант2 Тогда 
		// Должность.
		Сортировка = "УПОРЯДОЧИТЬ ПО
	|	ТаблицаСотрудниковСпециализаций.Должность.Наименование,
	|	ТаблицаСотрудниковСпециализаций.Сотрудник.Наименование";
	Иначе
		// Осн. специализация.
		Сортировка = "УПОРЯДОЧИТЬ ПО
	|	ТаблицаСотрудниковСпециализаций.Специализация.Наименование,
	|	ТаблицаСотрудниковСпециализаций.Должность.Наименование,
	|	ТаблицаСотрудниковСпециализаций.Сотрудник.Наименование";		
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + Символы.ПС + Сортировка;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	 	  , ОтборСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ОтборДолжность"       	  , ОтборДолжность);
	Запрос.УстановитьПараметр("ОтборСпециализации"   	  , ОтборСпециализации);
	Запрос.УстановитьПараметр("ОтборПоСпециализации"   	  , ЗначениеЗаполнено(ОтборСпециализации));
	Запрос.УстановитьПараметр("ОтборДатаВремяНачалаРаботы", ?(ЗначениеЗаполнено(ОтборНаДату), ОтборНаДату, Дата(1,1,1)));
	
	УсловиеДолжность        = ?(ЗначениеЗаполнено(ОтборДолжность), "И СправочникСотрудники.Должность В(&ОтборДолжность)", "");
	Запрос.Текст            = СтрЗаменить(Запрос.Текст, "И &УсловиеДолжность", УсловиеДолжность);

	Если ЗначениеЗаполнено(ОтборСпециализации) Тогда 
		Запрос.Текст        = СтрЗаменить(Запрос.Текст, "И &УсловиеСпециализации1", "И СотрудникиСпецилазацииСотрудника.Специализация В(&ОтборСпециализации)");
		Запрос.Текст        = СтрЗаменить(Запрос.Текст, "И &УсловиеСпециализации2", "И ТаблицаСотрудниковСпециализаций.Специализация В(&ОтборСпециализации)");
	Иначе 
		Запрос.Текст        = СтрЗаменить(Запрос.Текст, "И &УсловиеСпециализации1", "");
		Запрос.Текст        = СтрЗаменить(Запрос.Текст, "И &УсловиеСпециализации2", "");
	КонецЕсли;	

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
КонецФункции

#КонецОбласти  

#КонецОбласти  

#КонецЕсли
