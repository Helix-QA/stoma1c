// Процедура - Заполнить данные получателя сообщения messenger.
//
// Параметры:
//  СтрокаДанных - 	 - 
//
Процедура ЗаполнитьДанныеПолучателяСообщенияMessenger(СтрокаДанных)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтактыМессенджеров.ВнешняяСистема КАК СервисРассылки
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|ГДЕ
	|	КонтактыМессенджеров.ВнешняяСистема.ТипВнешнейСистемы В(&ТипыВнешнихСистем)
	|	И НЕ КонтактыМессенджеров.ВнешняяСистема.ПометкаУдаления
	|	И КонтактыМессенджеров.ВнешняяСистема.Используется
	|	И КонтактыМессенджеров.ОбъектИдентификации = &Контрагент
	|	И НЕ КонтактыМессенджеров.НеУчаствоватьВРассылке");
	
	Запрос.УстановитьПараметр("Контрагент"			, СтрокаДанных.Получатель);
	Запрос.УстановитьПараметр("ТипыВнешнихСистем"	, Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПараметрыПоиска = Новый Структура;
		ПараметрыПоиска.Вставить("Получатель"    , СтрокаДанных.Получатель);
		ПараметрыПоиска.Вставить("СервисРассылки", Выборка.СервисРассылки);
		
		Если Объект.Получатели.НайтиСтроки(ПараметрыПоиска).Количество() = 0 Тогда
			
			СтрокаДанных.СервисРассылки = Выборка.СервисРассылки;
			СтрокаДанных.ТипОтправки    = "messenger";
			СтрокаДанных.Активность     = Истина;
			
			Если Выборка.СервисРассылки.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
				СтрокаДанных.НомерТелефона = Справочники.Контрагенты.ПолучитьНомерТелефонаДляРассылки(СтрокаДанных.Получатель, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
			КонецЕсли;
			
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
// Процедура - Заполнить данные получателя сообщения messenger инициировать отправку.
//
// Параметры:
//  СтрокаДанных - 	 - 
//
Процедура ЗаполнитьДанныеПолучателяСообщенияMessengerИнициироватьОтправку(СтрокаДанных)
	
	НомерТелефона = Справочники.Контрагенты.ПолучитьНомерТелефонаДляРассылки(СтрокаДанных.Получатель, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
	
	Если ЗначениеЗаполнено(НомерТелефона) Тогда
		
		ПараметрыПоиска = Новый Структура;
		ПараметрыПоиска.Вставить("НомерТелефона" , НомерТелефона);
		ПараметрыПоиска.Вставить("СервисРассылки", ЭтотОбъект.ДоступныеСервисыРассылки.МессенджерОтправкаПервым[0]);
		
		Если Объект.Получатели.НайтиСтроки(ПараметрыПоиска).Количество() = 0 Тогда
			
			СтрокаДанных.НомерТелефона  = НомерТелефона;
			СтрокаДанных.СервисРассылки = ЭтотОбъект.ДоступныеСервисыРассылки.МессенджерОтправкаПервым[0];
			СтрокаДанных.ТипОтправки    = "messenger";
			СтрокаДанных.Активность     = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

