&НаКлиенте
// Процедура, ОбработчикНажатиДинамическогоЭлементаВиджета.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ОбработчикНажатиДинамическогоЭлементаВиджета(Команда) Экспорт
   
	Если СтрНайти(Команда.Имя, "КомандаТекущийЭтап") > 0 Тогда
		
		ИндексГурппы = ПолучитьИндексСтроки(Команда.Имя);	
			
		Если Элементы["ГруппаПричиныОтказа_" + ИндексГурппы].Видимость
			ИЛИ Элементы["ГруппаПрием_"+ ИндексГурппы].Видимость Тогда
			
			Элементы["ГруппаЭтапы_" + ИндексГурппы].Видимость   	  = Истина;
			Элементы["ГруппаПричиныОтказа_" + ИндексГурппы].Видимость = Ложь;
			Элементы["ГруппаПрием_"+ ИндексГурппы].Видимость	  = Ложь;
			
		КонецЕсли;

		СменитьФокусЭлемента(ИндексГурппы);

		Элементы["ГруппаВсплывающая_" + ИндексГурппы].Показать(); 
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаСделка") Тогда 
		
		ИндексСтроки  = ПолучитьИндексСтроки(Команда.Имя);
		СтрокаТаблицы = ЭтаФорма.ТаблицаСделок[ИндексСтроки];
		
		ПоказатьЗначение(,СтрокаТаблицы.Сделка);
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаОткрытьПродажу") Тогда 
		
		ИндексСтроки = ПолучитьИндексСтроки(Команда.Имя);
		Реализация   = ЭтаФорма.ТаблицаСделок[ИндексСтроки].Прием;
		
		Если ЗначениеЗаполнено(Реализация) Тогда
			ПоказатьЗначение(,Реализация);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, ОбработчикНажатияИзменитьЭтап.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ОбработчикНажатияИзменитьЭтап(Команда) Экспорт
	
	ИндексВиджета = ПолучитьИндексСтроки(Команда.Имя, Ложь);
	
	Если СтрНайти(Команда.Имя, "КомандаИзменитьЭтапОтказ") > 0 Тогда
		  				
		Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость   	   = НЕ Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость;
		Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость = НЕ Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость;
		СменитьФокусЭлемента(ИндексВиджета);
		// Элементы["ГруппаВсплывающая_" + ИндексВиджета].Показать();
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаИзменитьЭтапУспех") > 0 Тогда
		  				
		Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость   	   = Ложь;
		Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость = Ложь;
		Элементы["ГруппаРеализация_" + ИндексВиджета].Видимость    = Истина;
		СменитьФокусЭлемента(ИндексВиджета);
		Элементы["ГруппаВсплывающая_" + ИндексВиджета].Показать();
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаСоздатьПродажу") > 0 Тогда
		
		Сделка = ЭтаФорма.ТаблицаСделок[ИндексВиджета].Сделка;
		
		Структура = Новый Структура();
		Структура.Вставить("Контрагент", Объект.Контрагент);
		Структура.Вставить("Сделка"	   , Сделка);
		ПараметрыФормы  = Новый Структура("ЗначенияЗаполнения", Структура);	
		НовоеОповещение = Новый ОписаниеОповещения("СоздатьРеализациюЗавершение", ЭтотОбъект, Сделка);
		СменитьФокусЭлемента(ИндексВиджета);
		ОткрытьФорму("Документ.Прием.Форма.ФормаДокумента",ПараметрыФормы,,,,,НовоеОповещение);
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаВыбратьПродажу") > 0 Тогда
		
		Сделка = ЭтаФорма.ТаблицаСделок[ИндексВиджета].Сделка;
		МассивСделок = Новый Массив();
		МассивСделок.Добавить(Сделка);

		НовоеОповещение = Новый ОписаниеОповещения("ВыбратьРеализациюЗавершение", ЭтотОбъект, Сделка);
		
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("Контрагент", 			  Объект.Контрагент);
		ПараметрыФормы.Вставить("ВключатьПакетИЧленство", Истина);
		ПараметрыФормы.Вставить("РеализацияБезСделки"	, Истина);
		ПараметрыФормы.Вставить("МассивСделок"			, МассивСделок);

		ОткрытьФорму("Документ.Реализация.ФормаВыбора",ПараметрыФормы,,,,,НовоеОповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		СменитьФокусЭлемента(ИндексВиджета);
	
	Иначе
		
		СменитьФокусЭлемента(ИндексВиджета);
		ОбновитьСделку(Команда.Имя, Объект.Контрагент);
		Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
		Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
		
	КонецЕсли;
	 
КонецПроцедуры

