	// КнопкаТипФильтраОчистить = Форма.Элементы.Добавить("КнопкаОчистить_" + СтрокаФильтр.Наименование + "_" + ИдентификаторФильтра, Тип("КнопкаФормы"), ГруппаКнопки_ТипФильтра_);
