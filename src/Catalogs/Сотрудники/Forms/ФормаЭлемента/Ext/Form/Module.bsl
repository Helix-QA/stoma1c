&НаСервере
// Процедура - Создать подбор места работы сотрудника
//
Процедура СоздатьПодборМестаРаботыСотрудника()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|			ТОГДА 1
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК ИндКартинки
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ЭтоГруппа");
	
	Запрос.УстановитьПараметр("Сотрудник", Объект.Ссылка);
	
	МассивСтруктурныхЕдиниц  	 = Новый Массив;
	СоответствиеИндексамКартинок = Новый Соответствие;

	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		МассивСтруктурныхЕдиниц.Добавить(Выборка.СтруктурнаяЕдиница);
		СоответствиеИндексамКартинок.Вставить(Выборка.СтруктурнаяЕдиница, Выборка.ИндКартинки);	
	КонецЦикла;	
	
	МассивДоступныхСтруктурныхЕдиниц = Новый Массив;
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.ДоступныеСтруктурныеЕдиницы Цикл
		МассивДоступныхСтруктурныхЕдиниц.Добавить(СтрокаТЧ.СтруктурнаяЕдиница);	
	КонецЦикла;
	
	ОбработкаТабличныхЧастейКлиент.СоздатьДеревоСтруктурныхЕдиниц(
		ЭтаФорма, "ДоступныеСтруктурныеЕдиницы", Объект.Ссылка,, МассивСтруктурныхЕдиниц, 
		МассивДоступныхСтруктурныхЕдиниц, СоответствиеИндексамКартинок);
		
	Для Каждого СтрокаТЗ Из ДоступныеСтруктурныеЕдиницы Цикл			
		ЗаполнитьДатыПриемаИУвольнения( ,СтрокаТЗ);
	КонецЦикла;
			
КонецПроцедуры  

&НаСервере
// Процедура - Заполнить даты приема и увольнения.
//
// Параметры:
//  ЭлементДерева	 - 	 - 
//  СтрокаТЗ		 - 	 - 
//
Процедура ЗаполнитьДатыПриемаИУвольнения(ЭлементДерева = Неопределено, СтрокаТЗ);
	
	Если ЭлементДерева = Неопределено Тогда
		ЭлементДерева = ПодборМестаРаботыСотрудника;		
	КонецЕсли;
	
	Для Каждого ЭлементДерева Из ЭлементДерева.ПолучитьЭлементы() Цикл
		
		Если ЭлементДерева.ЭтоГруппа = Истина Тогда
			ЭлементДерева.ДатаПриема 		= "Прием";
			ЭлементДерева.ДатаУвольнения 	= "Увольнение";	
			ЗаполнитьДатыПриемаИУвольнения(ЭлементДерева, СтрокаТЗ);
		Иначе
			
			Если ЭлементДерева.СтруктурнаяЕдиница <> СтрокаТЗ.СтруктурнаяЕдиница Тогда	
				Продолжить;
			Иначе			
				Если ЗначениеЗаполнено(СтрокаТЗ.ДатаПриема) Тогда	
					ЭлементДерева.ДатаПриема = СтрокаТЗ.ДатаПриема;
				КонецЕсли;
				
				Если ЗначениеЗаполнено(СтрокаТЗ.ДатаУвольнения) Тогда
					ЭлементДерева.ДатаУвольнения = СтрокаТЗ.ДатаУвольнения;
				КонецЕсли;		
			КонецЕсли; 
			
		КонецЕсли;	
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Процедура - Создать подбор места работы сотрудника
//
Процедура СоздатьПодборЖурналыПриемовСотрудника()
	
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	Для Каждого СтрокаТЧ Из ДоступныеСтруктурныеЕдиницы Цикл 
		МассивВыбранныхСтруктурныхЕдиниц.Добавить(СтрокаТЧ.СтруктурнаяЕдиница);
	КонецЦикла;

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|			ТОГДА 1
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК ИндКартинки
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|	И НЕ СтруктурныеЕдиницы.Ссылка В (&МассивСтруктурныхЕдиниц)");
	
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МассивВыбранныхСтруктурныхЕдиниц);
	
	МассивСтруктурныхЕдиниц  	 = Новый Массив;
	СоответствиеИндексамКартинок = Новый Соответствие;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		МассивСтруктурныхЕдиниц.Добавить(Выборка.СтруктурнаяЕдиница);
		СоответствиеИндексамКартинок.Вставить(Выборка.СтруктурнаяЕдиница, Выборка.ИндКартинки);	
	КонецЦикла;
	
	МассивДоступныхСтруктурныхЕдиниц = Новый Массив;
	
	Для Каждого СтрокаТ Из ЭтотОбъект.ДоступныеЖурналыПриемов Цикл
		
		МассивДоступныхСтруктурныхЕдиниц.Добавить(СтрокаТ.СтруктурнаяЕдиница);
		
	КонецЦикла;
	
	ОбработкаТабличныхЧастейКлиент.СоздатьДеревоСтруктурныхЕдиницЖурналаПриемов(
	ЭтаФорма, "ДоступныеЖурналыПриемов", Объект.Ссылка,, МассивСтруктурныхЕдиниц, 
	МассивДоступныхСтруктурныхЕдиниц, СоответствиеИндексамКартинок);
	
КонецПроцедуры

