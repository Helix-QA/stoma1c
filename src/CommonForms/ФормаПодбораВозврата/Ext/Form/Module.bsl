 
#Область ОбработчикиСобытийФормы
 
&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Документ") Тогда				
		СтрокаСсылка = "";
		Если ТипЗнч(Параметры.Документ) = Тип("ДокументСсылка.Реализация") Тогда
			Список.ТекстЗапроса = ПолучитьТекстЗапросаРеализации();
			СтрокаСсылка = "Ссылка.";
		КонецЕсли;		
		Список.Параметры.УстановитьЗначениеПараметра("Документ", Параметры.Документ);
		Если Параметры.Свойство("Контрагент") и ЗначениеЗаполнено(Параметры.Контрагент) Тогда 			
			Список.ТекстЗапроса = Список.ТекстЗапроса + "  И Запасы."+СтрокаСсылка+"Контрагент = &Контрагент";			
			Список.Параметры.УстановитьЗначениеПараметра("Контрагент", Параметры.Контрагент);			
		КонецЕсли;
		Если Параметры.Свойство("Склад") и ЗначениеЗаполнено(Параметры.Склад) Тогда 			
			Список.ТекстЗапроса     = Список.ТекстЗапроса + "  И Запасы."+СтрокаСсылка+"Склад = &Склад";			
			Список.Параметры.УстановитьЗначениеПараметра("Склад", Параметры.Склад);			
		КонецЕсли;
		Если Параметры.Свойство("Номенклатура") и  ЗначениеЗаполнено(Параметры.Номенклатура) Тогда
			Список.ТекстЗапроса = Список.ТекстЗапроса + "  И Запасы.Номенклатура = &Номенклатура";			
			Список.Параметры.УстановитьЗначениеПараметра("Номенклатура", Параметры.Номенклатура);
		КонецЕсли;
		Если Параметры.Свойство("Сотрудник") и  ЗначениеЗаполнено(Параметры.Сотрудник) Тогда
			Список.ТекстЗапроса     = Список.ТекстЗапроса + "  И Запасы."+СтрокаСсылка+"Сотрудник = &Сотрудник";			
			Список.Параметры.УстановитьЗначениеПараметра("Сотрудник", Параметры.Сотрудник);
		КонецЕсли;  
	Иначе
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "Выбор"
//
Процедура ТаблицаСписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОповеститьОВыборе(Элементы.ТаблицаСписок.ТекущиеДанные);	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Функция возвращает текст запроса для реализации
//
Функция ПолучитьТекстЗапросаРеализации()
	
	Текст   = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	          |	Запасы.Ссылка КАК ОснованиеВозврата,
	          |	Запасы.Номенклатура,
	          |	Запасы.Упаковка,
	          |	Запасы.Количество,
	          |	Запасы.КоличествоУпаковок,
	          |	Запасы.Цена,
	          |	Запасы.ПроцентСкидкиНаценки,
	          |	Запасы.СуммаАвтоматическойСкидкиНаценки,
	          |	Запасы.Сумма,
	          |	Запасы.СтавкаНДС,
	          |	Запасы.СуммаНДС,
	          |	Запасы.Всего,
	          |	Запасы.Партия,
	          |	Запасы.Ссылка.Сотрудник КАК Сотрудник,
	          |	Запасы.Ссылка.Контрагент КАК Контрагент,
	          |	Запасы.КлючСтроки КАК КлючСтроки,
	          |	Запасы.Ссылка.Склад КАК Склад
	          |ИЗ
	          |	Документ.Реализация.Запасы КАК Запасы
	          |ГДЕ
	          |	(Запасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	          |			ИЛИ Запасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Материал))
	          |	И Запасы.Ссылка = &Документ";
			  
	Возврат Текст;
	
КонецФункции 

#КонецОбласти