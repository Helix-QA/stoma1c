
#Область СлужебныеПроцедурыИФункции

// Процедура отправляет Информирование о изменении баланса на лицевом счете по SMS
//
Процедура ИнформироватьОИзмененииБалансаЛСПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Возврат;
	
	МассивКонтрагентов = Новый Массив;
	
	Регистратор = ?(Источник.Отбор.Найти("Регистратор") <> Неопределено, Источник.Отбор.Найти("Регистратор").Значение, Неопределено);
	ДвиженияПриЗаписи = Источник.Выгрузить();
	ДвиженияПередЗаписью = Источник.ДополнительныеСвойства.ДвиженияПередЗаписью;
	
	Для Каждого СтрокаТЗ Из ДвиженияПриЗаписи Цикл
		Если МассивКонтрагентов.Найти(СтрокаТЗ.Контрагент) = Неопределено Тогда
			МассивКонтрагентов.Добавить(СтрокаТЗ.Контрагент);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаТЗ Из ДвиженияПередЗаписью Цикл
		Если МассивКонтрагентов.Найти(СтрокаТЗ.Контрагент) = Неопределено Тогда
			МассивКонтрагентов.Добавить(СтрокаТЗ.Контрагент);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементКонтрагент Из МассивКонтрагентов Цикл
		ДвиженияПриЗаписиПоКонтрагенту = ДвиженияПриЗаписи.НайтиСтроки(Новый Структура("Контрагент", ЭлементКонтрагент));
		ДвиженияПередЗаписьюПоКонтрагенту = ДвиженияПередЗаписью.НайтиСтроки(Новый Структура("Контрагент", ЭлементКонтрагент));
		Если ЭлементКонтрагент.НеУчаствоватьВРассылкеСообщений = Ложь И ЗначениеЗаполнено(ЭлементКонтрагент.Телефон) И ТипЗнч(Регистратор) <> Тип("ДокументСсылка.ВводНачальныхОстатков") Тогда
			Если ДвиженияПриЗаписиПоКонтрагенту.Количество() > 0 И ДвиженияПередЗаписьюПоКонтрагенту.Количество() = 0 Тогда // Проведение
				ИнформироватьОИзмененииБалансаЛССоздатьДокументРассылкиSMS(ДвиженияПриЗаписиПоКонтрагенту, Регистратор, ЭлементКонтрагент, 1);
			ИначеЕсли ДвиженияПриЗаписиПоКонтрагенту.Количество() = 0 И ДвиженияПередЗаписьюПоКонтрагенту.Количество() > 0 Тогда // Отмена проведения
				ИнформироватьОИзмененииБалансаЛССоздатьДокументРассылкиSMS(ДвиженияПередЗаписьюПоКонтрагенту, Регистратор, ЭлементКонтрагент, -1);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура отправляет Информирование о изменении баланса на лицевом счете по SMS
//
Процедура ИнформироватьОИзмененииБалансаЛССоздатьДокументРассылкиSMS(НаборЗаписей, Регистратор, Контрагент, ТипПроведения)
	
	Если НаборЗаписей.Количество() > 0 Тогда
		СтруктурнаяЕдиница = НаборЗаписей[0].СтруктурнаяЕдиница;
	КонецЕсли;
	
	ПОПЫТКА	                                                                                                
		SMSОтправка = Документы.РассылкаСообщений.СоздатьДокумент();
		SMSОтправка.Дата = ТекущаяДата();
		SMSОтправка.ВидОперации = Перечисления.ВидОперацииОтправкаSMS.ОтправкаSMSПолучателю;
		SMSОтправка.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
		SMSОтправка.СервисSMSРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
		SMSОтправка.ДокументОснование = Регистратор;
		SMSОтправка.ОтправитьНемедленно = Истина;
		// SMSОтправка.ДатаОтправки = ТекущаяДата();
		SMSОтправка.Комментарий = "{Сформирован автоматически} Информирование о изменении баланса лицевого счета клиента по SMS";
		Для Каждого СтрокаТЗ Из НаборЗаписей Цикл
			SMSОтправка.Содержание = SMSОтправка.Содержание + ?(SMSОтправка.Содержание <> "", Символы.ПС, "") + Формат(СтрокаТЗ.Период, "ДФ='dd.MM HH:mm'") + " - ";
			Если ТипПроведения = -1 Тогда
				SMSОтправка.Содержание = SMSОтправка.Содержание + ?(СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Приход, "Отмена пополнения лиц. счета", "Отмена списания с лиц. счета");
			ИначеЕсли ТипПроведения = 1 Тогда
				SMSОтправка.Содержание = SMSОтправка.Содержание + ?(СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Приход, "Пополнение лиц. счета", "Списание с лиц. счета");				
			КонецЕсли;
			SMSОтправка.Содержание = SMSОтправка.Содержание + ?(ЗначениеЗаполнено(СтрокаТЗ.ВидСчета), " " + СтрокаТЗ.ВидСчета, "") 
							+ ". Сумма: " + СтрокаТЗ.Сумма + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты()
							+ ". Остаток: " + ОпределитьОстатокПоЛСВРазрезеСтрокДокумента(ТипПроведения, СтрокаТЗ.Контрагент, СтрокаТЗ.ВидСчета, НаборЗаписей, СтрокаТЗ) + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
		КонецЦикла;
		НоваяСтрока = SMSОтправка.Получатели.Добавить();
		НоваяСтрока.Получатель = Контрагент;
		НоваяСтрока.НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(Контрагент.Телефон);
		SMSОтправка.Записать(РежимЗаписиДокумента.Запись);
		SMSОтправка.Записать(РежимЗаписиДокумента.Проведение);
		ЗаписьЖурналаРегистрации("ИнформированиеОИзмененииБалансаЛицевогоСчета", УровеньЖурналаРегистрации.Информация,
			SMSОтправка.Метаданные(), SMSОтправка.Ссылка, "Информирование о изменении баланса лицевого счета клиента по SMS");
	ИСКЛЮЧЕНИЕ
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("ИнформированиеОИзмененииБалансаЛицевогоСчета", УровеньЖурналаРегистрации.Ошибка,
		SMSОтправка.Метаданные(), SMSОтправка.Ссылка, "Ошибка: " + ОписаниеОшибки);
	КОНЕЦПОПЫТКИ;
	
КонецПроцедуры

// Функция, возвращает остаток по лицевым счетам для каждой строки таблицы.
//
Функция ОпределитьОстатокПоЛСВРазрезеСтрокДокумента(ТипПроведения, Контрагент, ВидСчета, НаборЗаписей, ТекущаяСтрокаТЗ)
	
	Остаток = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(Контрагент, , , , ВидСчета, Истина);
	
	ПрошлиСтроку = Ложь;
	
	Для Каждого СтрокаТЗ Из НаборЗаписей Цикл
		Если СтрокаТЗ.ВидСчета = ВидСчета И ПрошлиСтроку = Истина Тогда
			Остаток = Остаток + ?(СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Приход И ТипПроведения = 1 ИЛИ СтрокаТЗ.ВидДвижения = ВидДвиженияНакопления.Расход И ТипПроведения = -1, -1 * СтрокаТЗ.Сумма, СтрокаТЗ.Сумма);
		КонецЕсли;
		Если СтрокаТЗ = ТекущаяСтрокаТЗ Тогда
			ПрошлиСтроку = Истина;
		КонецЕсли;		
	КонецЦикла;
	
	Возврат Остаток;
	
КонецФункции

#Область ОбработчикиРегламентныхЗаданий

// Процедура - Автоматическая генерация сделок
//
Процедура АвтоматическаяГенерацияСделок() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.АвтоматическаяГенерацияСделок);	
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ПредопределенныйВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	Если НЕ ЗначениеЗаполнено(ПредопределенныйВидСделки) Тогда 
		Возврат;
	КонецЕсли;
	
	ПервичныйЭтапСделки = Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(ПредопределенныйВидСделки, 1);
    ТекущийПользователь = ПараметрыСеанса.ТекущийСотрудник;
	МассивСтруктурныхЕдиниц = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц(, Истина);
	Если МассивСтруктурныхЕдиниц.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
		МассивСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
	КонецЕсли;		
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПериодОтбора"				, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц"		, МассивСтруктурныхЕдиниц);
	Запрос.УстановитьПараметр("ПредопределенныйВидСделки"	, ПредопределенныйВидСделки);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Профосмотры.Период КАК Период,
	|	Профосмотры.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Профосмотры.Контрагент КАК Контрагент,
	|	Профосмотры.Сотрудник КАК Сотрудник,
	|	Профосмотры.ВидОсмотра КАК ВидОсмотра,
	|	Профосмотры.ДатаЗапланированная КАК ДатаЗапланированная,
	|	Профосмотры.Статус КАК Статус,
	|	Профосмотры.Сделка КАК Сделка,
	|	Профосмотры.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
	|	Профосмотры.ПричинаОтказа КАК ПричинаОтказа,
	|	Профосмотры.Прием КАК Прием,
	|	Профосмотры.НаправившийВрач КАК НаправившийВрач,
	|	Профосмотры.АвторЗаписи КАК АвторЗаписи,
	|	Профосмотры.ПричинаНаправления КАК ПричинаНаправления,
	|	Профосмотры.ПричинаПереноса КАК ПричинаПереноса,
	|	Профосмотры.Комментарий КАК Комментарий,
	|	Профосмотры.Длительность КАК Длительность,
	|	Профосмотры.Специализация КАК Специализация
	|ПОМЕСТИТЬ ТаблицаЗапланированныхСобытий
	|ИЗ
	|	РегистрСведений.Профосмотры КАК Профосмотры
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(Профосмотры.ДатаЗапланированная, ДЕНЬ) = &ПериодОтбора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЗапланированныхСобытий.Период КАК Период,
	|	ТаблицаЗапланированныхСобытий.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаЗапланированныхСобытий.Контрагент КАК Контрагент,
	|	ТаблицаЗапланированныхСобытий.Сотрудник КАК Сотрудник,
	|	ТаблицаЗапланированныхСобытий.ВидОсмотра КАК ВидОсмотра,
	|	ТаблицаЗапланированныхСобытий.ДатаЗапланированная КАК ДатаЗапланированная,
	|	ТаблицаЗапланированныхСобытий.Статус КАК Статус,
	|	ТаблицаЗапланированныхСобытий.ПричинаОтказа КАК ПричинаОтказа,
	|	ТаблицаЗапланированныхСобытий.Прием КАК Прием,
	|	ТаблицаЗапланированныхСобытий.НаправившийВрач КАК НаправившийВрач,
	|	ТаблицаЗапланированныхСобытий.АвторЗаписи КАК АвторЗаписи,
	|	ТаблицаЗапланированныхСобытий.ПричинаНаправления КАК ПричинаНаправления,
	|	ТаблицаЗапланированныхСобытий.ПричинаПереноса КАК ПричинаПереноса,
	|	ТаблицаЗапланированныхСобытий.Комментарий КАК Комментарий,
	|	ТаблицаЗапланированныхСобытий.Длительность КАК Длительность,
	|	ТаблицаЗапланированныхСобытий.Специализация КАК Специализация
	|ПОМЕСТИТЬ ТаблицаЗапланированныхПрофосмотров
	|ИЗ
	|	ТаблицаЗапланированныхСобытий КАК ТаблицаЗапланированныхСобытий
	|ГДЕ
	|	ТаблицаЗапланированныхСобытий.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Профосмотр)
	|	И ТаблицаЗапланированныхСобытий.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован), ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.НапомнитьПозже))
	|	И ТаблицаЗапланированныхСобытий.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
	|	И ТаблицаЗапланированныхСобытий.ПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сделки.Ссылка КАК Сделка,
	|	Сделки.ПометкаУдаления КАК ПометкаУдаления,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.ДатаСделки КАК ДатаСделки,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.Врач КАК Врач,
	|	Сделки.Специализация КАК Специализация,
	|	Сделки.Прием КАК Прием,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.СуммаСделки КАК СуммаСделки,
	|	Сделки.ЭтапОтказа КАК ЭтапОтказа,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.ЭтапУспеха КАК ЭтапУспеха,
	|	Сделки.ЭтапСделки.НомерЭтапа > 2 КАК Записан
	|ПОМЕСТИТЬ ТаблицаСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
	|	И Сделки.ВидСделки = &ПредопределенныйВидСделки
	|	И Сделки.Контрагент В
	|			(ВЫБРАТЬ
	|				ТаблицаЗапланированныхПрофосмотров.Контрагент
	|			ИЗ
	|				ТаблицаЗапланированныхПрофосмотров)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сделки.Сделка КАК Сделка,
	|	Сделки.ПометкаУдаления КАК ПометкаУдаления,
	|	Сделки.ВидСделки КАК ВидСделки,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки,
	|	Сделки.ДатаСделки КАК ДатаСделки,
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.Врач КАК Врач,
	|	Сделки.Специализация КАК Специализация,
	|	Сделки.Прием КАК Прием,
	|	Сделки.РезультатСделки КАК РезультатСделки,
	|	Сделки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сделки.СуммаСделки КАК СуммаСделки,
	|	Сделки.ЭтапОтказа КАК ЭтапОтказа,
	|	Сделки.ЭтапСделки КАК ЭтапСделки,
	|	Сделки.ЭтапУспеха КАК ЭтапУспеха,
	|	Сделки.ЭтапСделки.НомерЭтапа > 2 КАК Записан,
	|	ЕСТЬNULL(ДокументЗаписи.Ссылка, ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)) КАК ПредварительнаяЗапись,
	|	ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка) КАК Взаимодействие
	|ИЗ
	|	ТаблицаСделок КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Событие КАК ДокументЗаписи
	|		ПО Сделки.Сделка = ДокументЗаписи.Сделка
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Сделки.Сделка,
	|	Сделки.ПометкаУдаления,
	|	Сделки.ВидСделки,
	|	Сделки.ДатаЗавершенияСделки,
	|	Сделки.ДатаСделки,
	|	Сделки.Контрагент,
	|	Сделки.Врач,
	|	Сделки.Специализация,
	|	Сделки.Прием,
	|	Сделки.РезультатСделки,
	|	Сделки.СтруктурнаяЕдиница,
	|	Сделки.СуммаСделки,
	|	Сделки.ЭтапОтказа,
	|	Сделки.ЭтапСделки,
	|	Сделки.ЭтапУспеха,
	|	Сделки.ЭтапСделки.НомерЭтапа > 2,
	|	ЕСТЬNULL(ДокументЗаписи.Ссылка, ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСделки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЗапланированныхПрофосмотров.Период КАК Период,
	|	ТаблицаЗапланированныхПрофосмотров.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаЗапланированныхПрофосмотров.Контрагент КАК Контрагент,
	|	ТаблицаЗапланированныхПрофосмотров.Сотрудник КАК Сотрудник,
	|	ТаблицаЗапланированныхПрофосмотров.ВидОсмотра КАК ВидОсмотра,
	|	ТаблицаЗапланированныхПрофосмотров.ДатаЗапланированная КАК ДатаЗапланированная,
	|	ТаблицаЗапланированныхПрофосмотров.Статус КАК Статус,
	|	ТаблицаЗапланированныхПрофосмотров.ПричинаОтказа КАК ПричинаОтказа,
	|	ТаблицаЗапланированныхПрофосмотров.Прием КАК Прием,
	|	ТаблицаЗапланированныхПрофосмотров.НаправившийВрач КАК НаправившийВрач,
	|	ТаблицаЗапланированныхПрофосмотров.АвторЗаписи КАК АвторЗаписи,
	|	ТаблицаЗапланированныхПрофосмотров.ПричинаНаправления КАК ПричинаНаправления,
	|	ТаблицаЗапланированныхПрофосмотров.ПричинаПереноса КАК ПричинаПереноса,
	|	ТаблицаЗапланированныхПрофосмотров.Комментарий КАК Комментарий,
	|	ТаблицаЗапланированныхПрофосмотров.Длительность КАК Длительность,
	|	ТаблицаЗапланированныхПрофосмотров.Специализация КАК Специализация,
	|	ТаблицаЗапланированныхПрофосмотров.Сотрудник.НаименованиеСокращенное КАК ВрачНаименованиеСокращенное,
	|	ТаблицаЗапланированныхПрофосмотров.Контрагент.Куратор КАК Ответственный,
	|	ТаблицаЗапланированныхПрофосмотров.Контрагент.СотрудникРегистрации КАК СотрудникРегистрацииПациента,
	|	ТаблицаЗапланированныхПрофосмотров.Контрагент.СотрудникРегистрации.Служебный КАК СотрудникРегистрацииСлужебный
	|ИЗ
	|	ТаблицаЗапланированныхПрофосмотров КАК ТаблицаЗапланированныхПрофосмотров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Прием КАК ДокументПрием
	|		ПО ТаблицаЗапланированныхПрофосмотров.Прием = ДокументПрием.Ссылка
	|ГДЕ
	|	ДокументПрием.ПрофосмотрИспользовать = ИСТИНА
	|	И ДокументПрием.РезультатПриема = 1
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период";
	
	РезультатПакетногоЗапроса 			= Запрос.ВыполнитьПакет();
	ТаблицаСделокКонтрагентов 			= РезультатПакетногоЗапроса[3].Выгрузить();
	ТаблицаЗапланированныхПрофосмотров 	= РезультатПакетногоЗапроса[4].Выгрузить();

	Для Каждого СтрокаТЗ Из ТаблицаЗапланированныхПрофосмотров Цикл
		Сделка 					= Неопределено;
		ПомеченаНаУдаление 		= Ложь;
		Записан 				= Ложь;
		ПредварительнаяЗапись 	= Неопределено;
		Взаимодействие 			= Неопределено;
		КоллекцияСделокКлиента = ТаблицаСделокКонтрагентов.НайтиСтроки(Новый Структура("Контрагент, Врач, Записан", СтрокаТЗ.Контрагент, СтрокаТЗ.Сотрудник, Ложь));
		Если КоллекцияСделокКлиента.Количество() > 0 Тогда 
			Сделка 				= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Сделка;
			ПомеченаНаУдаление 	= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].ПометкаУдаления;
			Взаимодействие 		= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Взаимодействие;
		Иначе 
			КоллекцияСделокКлиента = ТаблицаСделокКонтрагентов.НайтиСтроки(Новый Структура("Контрагент, Врач", СтрокаТЗ.Контрагент, СтрокаТЗ.Сотрудник));
			Если КоллекцияСделокКлиента.Количество() > 0 Тогда 
				Сделка 					= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Сделка;
				ПомеченаНаУдаление 		= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].ПометкаУдаления;
				Записан 				= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Записан;
				ПредварительнаяЗапись 	= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].ПредварительнаяЗапись;
				Взаимодействие 			= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Взаимодействие;				
			Иначе 
				КоллекцияСделокКлиента = ТаблицаСделокКонтрагентов.НайтиСтроки(Новый Структура("Контрагент, Врач, Специализация", СтрокаТЗ.Контрагент, Справочники.Сотрудники.ПустаяСсылка(), Справочники.Специализации.ПустаяСсылка()));
				Если КоллекцияСделокКлиента.Количество() > 0 Тогда 
					Сделка 					= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Сделка;
					ПомеченаНаУдаление 		= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].ПометкаУдаления;
					Записан 				= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Записан;
					ПредварительнаяЗапись 	= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].ПредварительнаяЗапись;
					Взаимодействие 			= КоллекцияСделокКлиента[КоллекцияСделокКлиента.Количество()-1].Взаимодействие;					
				КонецЕсли;				
			КонецЕсли;	
		КонецЕсли;	
		
		Если Сделка = Неопределено Тогда 
			// Формируем данные для генерации сделки
			ДанныеЗаполненияСделки = Новый Структура();
			ДанныеЗаполненияСделки.Вставить("ВидСделки"					, ПредопределенныйВидСделки);
			ДанныеЗаполненияСделки.Вставить("СтруктурнаяЕдиница"		, СтрокаТЗ.СтруктурнаяЕдиница);
			ДанныеЗаполненияСделки.Вставить("Контрагент"				, СтрокаТЗ.Контрагент);		
			ДанныеЗаполненияСделки.Вставить("ЭтапСделки"				, ПервичныйЭтапСделки);
			Если ЗначениеЗаполнено(СтрокаТЗ.Сотрудник) Тогда 
				ДанныеЗаполненияСделки.Вставить("Врач"					, СтрокаТЗ.Сотрудник);
			КонецЕсли;
			ДанныеЗаполненияСделки.Вставить("ВидОсмотра"				, СтрокаТЗ.ВидОсмотра);
			ДанныеЗаполненияСделки.Вставить("ПредыдущийПрием"			, СтрокаТЗ.Прием);			
			ДанныеЗаполненияСделки.Вставить("Описание"					, НСтр("ru='Автоматическая генерация для вызова на профосмотр';en='Automatic generation for a call for a professional examination'"));			
			ДанныеЗаполненияСделки.Вставить("ИнтерактивнаяЗапись"		, Истина);
			ДанныеЗаполненияСделки.Вставить("СформироватьНаименование"	, Истина);
		КонецЕсли;
		
		НоваяЗадача = Неопределено;
		Если НЕ ЗначениеЗаполнено(Взаимодействие) Тогда 		
			// Формируем данные для генерации задачи		
			ДанныеЗаполненияЗадачи = Новый Структура;
			ДанныеЗаполненияЗадачи.Вставить("Контрагент"                 	, СтрокаТЗ.Контрагент);
			ДанныеЗаполненияЗадачи.Вставить("ВидВзаимодействия"          	, Перечисления.ВидыВзаимодействия.ЗвонокИсходящий);
			ДанныеЗаполненияЗадачи.Вставить("Исполнитель"                	, ?(ЗначениеЗаполнено(СтрокаТЗ.Ответственный), СтрокаТЗ.Ответственный, ?(ЗначениеЗаполнено(СтрокаТЗ.СотрудникРегистрацииПациента) И НЕ СтрокаТЗ.СотрудникРегистрацииСлужебный, СтрокаТЗ.СотрудникРегистрацииПациента, ТекущийПользователь)));
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаНазначеннаяДата"      	, НачалоДня(ТекущаяДатаСеанса()) + (60*60*24));
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаТема"                 	, НСтр("ru='Записать пациента на профосмотр';en='Book a patient for a checkup'"));
			ДанныеЗаполненияЗадачи.Вставить("ЗадачаОписание"				, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Записать пациента на профосмотр к врачу %1';en='Register a patient for a medical examination %1'"), ?(ЗначениеЗаполнено(СокрЛП(СтрокаТЗ.ВрачНаименованиеСокращенное)), СокрЛП(СтрокаТЗ.ВрачНаименованиеСокращенное), Строка(СтрокаТЗ.Сотрудник))));     
			ДанныеЗаполненияЗадачи.Вставить("Сделка"						, ?(ЗначениеЗаполнено(Сделка), Сделка, Неопределено));
			ДанныеЗаполненияЗадачи.Вставить("Выполнена"                  	, Ложь);
			
			НоваяЗадача = Задачи.Взаимодействие.ИнициализироватьЗадачуСделки(ДанныеЗаполненияСделки, СтрокаТЗ.ВидОсмотра, ДанныеЗаполненияЗадачи, Истина, Истина);
		КонецЕсли;
	
		// Формируем данные для актуализации записи планирования в регистре		
		НаборЗаписей = РегистрыСведений.Профосмотры.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(СтрокаТЗ.Период);
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтрокаТЗ.СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.Контрагент.Установить(СтрокаТЗ.Контрагент);
		НаборЗаписей.Отбор.Сотрудник.Установить(СтрокаТЗ.Сотрудник);
		НаборЗаписей.Отбор.ВидОсмотра.Установить(СтрокаТЗ.ВидОсмотра);
		ЗаписьПланирования 							= НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(ЗаписьПланирования, СтрокаТЗ);
		ЗаписьПланирования.Сделка 					= ?(ЗначениеЗаполнено(Сделка), Сделка, Неопределено);	
		ЗаписьПланирования.Статус 					= ?(Записан И ЗначениеЗаполнено(ПредварительнаяЗапись), Перечисления.СтатусыПрофосмотров.Согласился, Перечисления.СтатусыПрофосмотров.Запланирован);
		ЗаписьПланирования.ПредварительнаяЗапись 	= ?(Записан И ЗначениеЗаполнено(ПредварительнаяЗапись), ПредварительнаяЗапись, Документы.Событие.ПустаяСсылка());
		НаборЗаписей.ОбменДанными.Загрузка 			= Истина;		
		
		НачатьТранзакцию();
		Попытка
			Если Сделка = Неопределено Тогда
				НоваяСделкаОбъект					= Справочники.Сделки.СоздатьНовуюСделку(ДанныеЗаполненияСделки, Истина, Истина);
				Если НЕ НоваяЗадача = Неопределено Тогда 
					НоваяЗадача.Сделка 				= НоваяСделкаОбъект.Ссылка;
				КонецЕсли;	
				ЗаписьПланирования.Сделка 			= НоваяСделкаОбъект.Ссылка;				
				// Актуализируем таблицу сделок
				НоваяСтрокаТаблицыСделок 			= ТаблицаСделокКонтрагентов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицыСделок, НоваяСделкаОбъект);
				НоваяСтрокаТаблицыСделок.Сделка 	= НоваяСделкаОбъект.Ссылка;
				НоваяСтрокаТаблицыСделок.Записан 	= Ложь;
				Если НЕ НоваяЗадача = Неопределено Тогда 
					НоваяЗадача.Записать();
					НоваяСтрокаТаблицыСделок.Взаимодействие = НоваяЗадача.Ссылка;
				КонецЕсли;					
			ИначеЕсли ПомеченаНаУдаление Тогда 
				Сделка_Объект 						= Сделка.ПолучитьОбъект();
				Сделка_Объект.ПометкаУдаления 		= Ложь;
				Сделка_Объект.ОбменДанными.Загрузка = Истина;			
				Сделка_Объект.Записать();
				Если НЕ НоваяЗадача = Неопределено Тогда 
					НоваяЗадача.Записать();
					СтрокаТаблицы = ТаблицаСделокКонтрагентов.Найти(Сделка, "Сделка");
					Если НЕ СтрокаТаблицы = Неопределено Тогда 
						СтрокаТаблицы.Взаимодействие = НоваяЗадача.Ссылка;
					КонецЕсли;	
				КонецЕсли;					
			КонецЕсли;	
			
			НаборЗаписей.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
		КонецПопытки;	
	КонецЦикла;
	
	ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.АвтоматическаяГенерацияСделок);			
	
КонецПроцедуры

// Процедура, выполняет формирование периодических сегментов по стеку изменений.
//
Процедура ФормированиеСегментовПоСтекуИзменений() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено() И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	НаборДляОбработки = РегистрыСведений.ФормированиеСегментовПоСтекуИзменений.ПолучитьПорциюОднотипныхОбъектовДляОбработки();
	
	Если НЕ ЗначениеЗаполнено(НаборДляОбработки) Тогда
		Возврат;
	КонецЕсли;
	
	Сегменты.ВыполнитьПериодическоеФормирование(,НаборДляОбработки);
	
	НачатьТранзакцию();
	
	// Очищаем очередь от этого набора объектов
	МенеджерЗаписи = РегистрыСведений.ФормированиеСегментовПоСтекуИзменений.СоздатьМенеджерЗаписи();	
	Для Каждого ОбъектСтека Из НаборДляОбработки Цикл
		МенеджерЗаписи.Объект = ОбъектСтека;
		МенеджерЗаписи.Удалить();
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

// Процедура, очищает неактуальные записи в регистре СвободныеИнтервалыСотрудников.
// 
Процедура ОчиститьНеактуальныеСвободныеИнтервалыСотрудников() Экспорт
	
	МассивСтруктуррныхЕдиниц = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц();
	
	Для Каждого СтруктурнаяЕдиница Из МассивСтруктуррныхЕдиниц Цикл
		
		ТаблицаИнтервалов = РегистрыСведений.СвободныеИнтервалыСотрудников.ПолучитьСвободныеИнтервалы(СтруктурнаяЕдиница,,,,, Истина);
		ДеньИнтервала 	  = Неопределено;
		
		Для Каждого СтрокаТЧ Из ТаблицаИнтервалов Цикл
			
			Если ДеньИнтервала = Неопределено ИЛИ СтрокаТЧ.ДеньИнтервала > ДеньИнтервала Тогда
				
				НаборЗаписей = РегистрыСведений.СвободныеИнтервалыСотрудников.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
				НаборЗаписей.Отбор.ДеньИнтервала.Установить(СтрокаТЧ.ДеньИнтервала);
				НаборЗаписей.Записать();
				
				ДеньИнтервала = СтрокаТЧ.ДеньИнтервала;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Обновление закрытия дней
//
Процедура ОбновлениеЗакрытияДней() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеЗакрытияДней);	
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	   	
	// Попытка	
		Документы.ЗакрытиеДня.ОбновлениеЗакрытияДней();
		
		// Если сегодня 1 число месяца, то создадим закрытие месяца за прошлый месяц
		Если НачалоДня(ТекущаяДата()) = НачалоМесяца(ТекущаяДата()) Тогда
			Документы.ЗакрытиеМесяца.ОбновлениеЗакрытияМесяца(ДобавитьМесяц(НачалоДня(ТекущаяДата()), -1));
			УправлениеИтогамиИАгрегатамиСлужебный.РассчитатьИтоги();
		КонецЕсли;	
		
		ИнтеграцияИЭМК.ОбновлениеДанныхИЭМК();
	
		ОбновлениеДанныхКонтрСтрахование();
		
		// Очистка неактуальных записей в листе ожидания.
		РегистрыСведений.ИнтервалыЛистаОжидания.ПроверитьИУдалитьНеактуальныеЗаписиЛистаОжидания();
		
		ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеЗакрытияДней);			
	// Исключение
	//	ОписаниеОшибкиВыполнения = ОписаниеОшибки();
	//	ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеЗакрытияДней, ОписаниеОшибкиВыполнения);		
	// КонецПопытки;
	
	
КонецПроцедуры

// Процедура зачисляет клиентам средства на бонусные счета в ДР.
//
Процедура ЗачислитьСредстваНаБонусныеСчетаИменинникам() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;   		
	КонецЕсли;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ЗачислениеСредствНаБонусныеСчетаИменинников);
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	// Попытка	
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	Контрагенты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ Именинники
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ЭтоГруппа = ЛОЖЬ
		|	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И Контрагенты.ДатаРожденияКлиента <> ДАТАВРЕМЯ(1, 1, 1)
		|	И МЕСЯЦ(&ТекущаяДата) = МЕСЯЦ(Контрагенты.ДатаРожденияКлиента)
		|	И ДЕНЬ(&ТекущаяДата) = ДЕНЬ(Контрагенты.ДатаРожденияКлиента)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ОперацияПоБонусномуСчету.Ссылка КАК Ссылка,
		|	ВЫРАЗИТЬ(ОперацияПоБонусномуСчету.ВладелецБонусногоСчета КАК Справочник.Контрагенты) КАК ВладелецБонусногоСчета,
		|	ОперацияПоБонусномуСчету.БонусныйСчет КАК БонусныйСчет,
		|	ОперацияПоБонусномуСчету.БонусныйСчет.ВидБонусногоСчета КАК ВидБонусногоСчета
		|ПОМЕСТИТЬ Начисления
		|ИЗ
		|	Документ.ОперацияПоБонусномуСчету КАК ОперацияПоБонусномуСчету
		|ГДЕ
		|	ОперацияПоБонусномуСчету.Проведен = ИСТИНА
		|	И ОперацияПоБонусномуСчету.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И ОперацияПоБонусномуСчету.Содержание ПОДОБНО &Содержание
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	БонусныеСчета.Ссылка КАК Ссылка,
		|	БонусныеСчета.ВладелецБонусногоСчета КАК ВладелецБонусногоСчета,
		|	БонусныеСчета.ВидБонусногоСчета КАК ВидБонусногоСчета,
		|	БонусныеСчета.СуммаНачисленияВДеньРождения КАК СуммаНачисленияВДеньРождения
		|ПОМЕСТИТЬ БонусныеСчета
		|ИЗ
		|	Справочник.БонусныеСчета КАК БонусныеСчета
		|ГДЕ
		|	ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты) В
		|			(ВЫБРАТЬ
		|				Именинники.Ссылка
		|			ИЗ
		|				Именинники)
		|	И НЕ БонусныеСчета.Закрыт
		|	И НЕ БонусныеСчета.ПометкаУдаления
		|	И НЕ ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		|	И БонусныеСчета.ВидБонусногоСчета.Именной
		|	И БонусныеСчета.ВидБонусногоСчета.СуммаНачисленияВДеньРождения > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВидыБонусныхСчетов.Ссылка КАК ВидБонусногоСчета,
		|	ВидыБонусныхСчетов.СуммаНачисленияВДеньРождения КАК СуммаНачисленияВДеньРождения
		|ПОМЕСТИТЬ ВидыБонусныхСчетов
		|ИЗ
		|	Справочник.ВидыБонусныхСчетов КАК ВидыБонусныхСчетов
		|ГДЕ
		|	ВидыБонусныхСчетов.ПометкаУдаления = ЛОЖЬ
		|	И ВидыБонусныхСчетов.Именной = ИСТИНА
		|	И ВидыБонусныхСчетов.СуммаНачисленияВДеньРождения > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	Именинники.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	БонусныеСчета.ВидБонусногоСчета КАК ВидБонусногоСчета,
		|	БонусныеСчета.ВладелецБонусногоСчета КАК ВладелецБонусногоСчета,
		|	БонусныеСчета.Ссылка КАК БонусныйСчет,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.НачислениеБонусныйСчет) КАК ВидОперации,
		|	БонусныеСчета.СуммаНачисленияВДеньРождения КАК Сумма,
		|	&ТекущаяДата КАК Дата
		|ИЗ
		|	Именинники КАК Именинники
		|		ЛЕВОЕ СОЕДИНЕНИЕ БонусныеСчета КАК БонусныеСчета
		|			ЛЕВОЕ СОЕДИНЕНИЕ Начисления КАК Начисления
		|			ПО БонусныеСчета.Ссылка = Начисления.БонусныйСчет
		|				И ((ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты)) = Начисления.ВладелецБонусногоСчета)
		|		ПО Именинники.Ссылка = БонусныеСчета.ВладелецБонусногоСчета
		|ГДЕ
		|	Начисления.Ссылка ЕСТЬ NULL
		|	И НЕ ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Именинники.СтруктурнаяЕдиница,
		|	ВидыБонусныхСчетов.ВидБонусногоСчета,
		|	Именинники.Ссылка,
		|	ЗНАЧЕНИЕ(Справочник.БонусныеСчета.ПустаяСсылка),
		|	ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.НачислениеБонусныйСчет),
		|	ВидыБонусныхСчетов.СуммаНачисленияВДеньРождения,
		|	&ТекущаяДата
		|ИЗ
		|	Именинники КАК Именинники
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВидыБонусныхСчетов КАК ВидыБонусныхСчетов
		|		ПО (ИСТИНА)
		|ГДЕ
		|	НЕ (ВидыБонусныхСчетов.ВидБонусногоСчета, Именинники.Ссылка) В
		|				(ВЫБРАТЬ
		|					Начисления.ВидБонусногоСчета,
		|					Начисления.ВладелецБонусногоСчета
		|				ИЗ
		|					Начисления
		|		
		|				ОБЪЕДИНИТЬ ВСЕ
		|		
		|				ВЫБРАТЬ
		|					БонусныеСчета.ВидБонусногоСчета,
		|					БонусныеСчета.ВладелецБонусногоСчета
		|				ИЗ
		|					БонусныеСчета)");
		
		Запрос.УстановитьПараметр("НачалоПериода"	,  НачалоГода(ТекущаяДата()));
		Запрос.УстановитьПараметр("КонецПериода"	,  КонецГода(ТекущаяДата()));		   
		Запрос.УстановитьПараметр("ТекущаяДата"		,  ТекущаяДата());
		Запрос.УстановитьПараметр("Содержание"		,  "%День рождения%");
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		Для Каждого СтрокаТЗ Из РезультатЗапроса Цикл 	
			
			БонусныйСчет = СтрокаТЗ.БонусныйСчет;
			
			Если НЕ ЗначениеЗаполнено(СтрокаТЗ.БонусныйСчет) Тогда
				Попытка 
					БонусныйСчетОбъект = Справочники.БонусныеСчета.СоздатьЭлемент();
					БонусныйСчетОбъект.Заполнить(СтрокаТЗ.ВидБонусногоСчета);
					БонусныйСчетОбъект.ВладелецБонусногоСчета = СтрокаТЗ.ВладелецБонусногоСчета;
					БонусныйСчетОбъект.Записать();
					
					БонусныйСчет = БонусныйСчетОбъект.Ссылка;
				Исключение
					ЗаписьЖурналаРегистрации("Зачисление средств на бонусные счета именинников",
					УровеньЖурналаРегистрации.Ошибка,,, 
					СтрШаблон("Не удалось записать бонусный счет %1 контрагента %2. Описание ошибки: %3", СтрокаТЗ.ВидБонусногоСчета, СтрокаТЗ.ВладелецБонусногоСчета, ОписаниеОшибки()));
				КонецПопытки;			
			КонецЕсли;	
			
			Если НЕ ЗначениеЗаполнено(БонусныйСчет) Тогда
				Продолжить;
			КонецЕсли;
			
			ДокументЗачисления = Документы.ОперацияПоБонусномуСчету.СоздатьДокумент();
			ЗаполнитьЗначенияСвойств(ДокументЗачисления, СтрокаТЗ,, "БонусныйСчет");	
			ДокументЗачисления.БонусныйСчет = БонусныйСчет;
			ДокументЗачисления.Содержание	= СтрШаблон(НСтр("ru = 'Зачисление бонусных средств клиенту в эквиваленте %1 %2 (День рождения)'; en= 'Crediting bonus funds to the client in the equivalent of %1 %2 (Birthday)'"), 
			Формат(СтрокаТЗ.Сумма, "ЧДЦ=2; ЧН=0,00"), ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты(СтрокаТЗ.СтруктурнаяЕдиница));
			Попытка
				ДокументЗачисления.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ЗаписьЖурналаРегистрации("Зачисление средств на бонусные счета именинников",
				УровеньЖурналаРегистрации.Ошибка,,, 
				СтрШаблон("Не удалось записать начисление на %1. Описание ошибки: %2", СтрокаТЗ.БонусныйСчет, ОписаниеОшибки()));
				// ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;
		КонецЦикла;	
		ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ЗачислениеСредствНаБонусныеСчетаИменинников);			
	// Исключение
	//	ОписаниеОшибкиВыполнения = ОписаниеОшибки();
	//	ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ЗачислениеСредствНаБонусныеСчетаИменинников, ОписаниеОшибкиВыполнения);		
	// КонецПопытки;
	
КонецПроцедуры

// Процедура вносит приветственные начисления на бонусный счет клиента.
// 
Процедура ПриЗаписиСправочникаБонусныеСчетаПриЗаписи(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если Источник.ДополнительныеСвойства.Свойство("ЭтоНовый") Тогда 
		Если Источник.ДополнительныеСвойства.ЭтоНовый Тогда 
			Если Источник.ВидБонусногоСчета.СуммаПриветственногоНачисления > 0 Тогда 
				ДокументНачисления = Документы.ОперацияПоБонусномуСчету.СоздатьДокумент();
				ДокументНачисления.Дата = ТекущаяДатаСеанса();
				ДокументНачисления.ВидОперации = Перечисления.ВидыОпераций.НачислениеБонусныйСчет;
				ДокументНачисления.БонусныйСчет = Источник.Ссылка;
				ДокументНачисления.ВладелецБонусногоСчета = Источник.ВладелецБонусногоСчета;
				ДокументНачисления.Содержание = "Зачисление бонусных средств " + ?(ТипЗнч(Источник.ВладелецБонусногоСчета) = Тип("СправочникСсылка.Контрагенты"), "клиенту", "на карту") + " в эквиваленте " + Формат(Источник.ВидБонусногоСчета.СуммаПриветственногоНачисления, "ЧДЦ=2; ЧН=0,00") + " руб. (Приветственное начисление)";
				ДокументНачисления.Сумма = Источник.ВидБонусногоСчета.СуммаПриветственногоНачисления;
				Если ДокументНачисления.ПроверитьЗаполнение() Тогда 
					ДокументНачисления.Записать();
				КонецЕсли;	
				Попытка
					ДокументНачисления.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обновить статус событий
//
Процедура ОбновитьСтатусыСобытийИЗавершитьСделки() Экспорт

	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеСтатусовСобытий);
	
	// Закрывем записи на которые пациент не явился
	НачалоПериодаПроверки = НачалоДня(ТекущаяДатаСеанса()) - 86400;
	ДатаВремяПроверки     = ТекущаяДатаСеанса() - 60*60*2;
	// Получаем запланированные приемы (предварительные записи)	
	ТаблицаПредварительныхЗаписей = Документы.Событие.ПолучитьЗаписиПоКоторымПриемНеСостоялся(НачалоПериодаПроверки
																							, ДатаВремяПроверки);
																							
	МетаданныеДокумента = Метаданные.Документы.Событие;																								
	Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхЗаписей Цикл 
		Запись_Объект = СтрокаТаблицы.ПредварительнаяЗапись.ПолучитьОбъект();	
	    Запись_Объект.Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся;
		
		Попытка 
			Запись_Объект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ШаблонКомментария = НСтр("ru = 'Ошибка установки статуса ""Приём не состоялся"" для предварительной записи: %1
			| по причине %2'");
		
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, Строка(СтрокаТаблицы.ПредварительнаяЗапись)
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
			ЗаписьЖурналаРегистрации("ОбновлениеСтатусовСобытий"
									, УровеньЖурналаРегистрации.Предупреждение
									, МетаданныеДокумента
									,
									, Комментарий);
		КонецПопытки;
	КонецЦикла;
	
	// Закрываем сделки при ручной установке статуса записи - "Прием окончен", "Прием отменен"
	ТаблицаСделок = Справочники.Сделки.ПолучитьНеЗавершенныеСделкиПоЗаписямБезПриемов(ДобавитьМесяц(НачалоПериодаПроверки, -12)
																					, ДатаВремяПроверки);
	
																					
	ПричинаОтказа 			= Неопределено;
	ДатаЗавершенияСделки 	= ТекущаяДатаСеанса();
	МетаданныеСправочника 	= Метаданные.Справочники.Сделки;																									
	Для Каждого СтрокаТаблицы Из ТаблицаСделок Цикл
		Объект_Сделка = Неопределено;
		Если СтрокаТаблицы.Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда 
			Объект_Сделка 					= СтрокаТаблицы.Сделка.ПолучитьОбъект();
			Объект_Сделка.РезультатСделки 	= Перечисления.РезультатыСделок.Успех;
			Объект_Сделка.ЭтапУспеха 		= Объект_Сделка.ЭтапСделки;
			Объект_Сделка.ЭтапСделки 		= Справочники.ЭтапыСделок.Успех;
		ИначеЕсли СтрокаТаблицы.Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда 
			Объект_Сделка 					= СтрокаТаблицы.Сделка.ПолучитьОбъект();
			Объект_Сделка.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;
			Объект_Сделка.ЭтапОтказа 		= Объект_Сделка.ЭтапСделки;
			Объект_Сделка.ЭтапСделки 		= Справочники.ЭтапыСделок.Отказ;
			Если НЕ ЗначениеЗаполнено(ПричинаОтказа) Тогда 
				ПричинаОтказа = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался");
			КонецЕсли;	
			Объект_Сделка.ПричинаОтказа 	= ПричинаОтказа;
		КонецЕсли;
		Если НЕ Объект_Сделка = Неопределено Тогда 
			Объект_Сделка.ДатаЗавершенияСделки = ДатаЗавершенияСделки;
			Объект_Сделка.ДополнительныеСвойства.Вставить("ИнтерактивнаяЗапись"	, Истина);
			Объект_Сделка.ДополнительныеСвойства.Вставить("РегламентнаяЗапись"	, Истина);			
			Попытка
				Объект_Сделка.Записать();
			Исключение
				ШаблонКомментария = НСтр("ru = 'Ошибка автоматического закрытия сделки: %1
				| по причине %2'");
		
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, Объект_Сделка.ПолноеНаименование()
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
				ЗаписьЖурналаРегистрации("АвтоматическоеЗакрытиеСделок"
										, УровеньЖурналаРегистрации.Предупреждение
										, МетаданныеСправочника
										,
										, Комментарий);
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеСтатусовСобытий);

КонецПроцедуры

// Процедура - Обработать не оплаченные заказы СБП
//
Процедура ПроверкаСтатусовЗаказов(НомерЗаказа = Неопределено, РезультатЗапроса = Неопределено) Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ПроверкаСтатусовЗаказов);	
	
	ОтказВыполнения = Ложь;	
	АктуализироватьЗаданиеОчереди(Метаданные.РегламентныеЗадания.ПроверкаСтатусовЗаказов, Истина, , ОтказВыполнения);	
	
	Если ОтказВыполнения Тогда 
		ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ПроверкаСтатусовЗаказов);			
		Возврат;
	КонецЕсли;
        
	ОбработатьНеОплаченныеЗаказыСБП();
	
	ОбщегоНазначения.ПриОкончанииВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ПроверкаСтатусовЗаказов);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиПодписокНаСобытия

// Процедура, обработчик подписки на событие.
//
Процедура ФормированиеСегментовПоСтекуИзмененийОбъектаПриЗаписи(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка = Истина Тогда		
		 Возврат;		 
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ФормированиеСегментовПоСтекуИзменений.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Объект = Источник.Ссылка;
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.Записать(Истина);
	
КонецПроцедуры

// Процедура, обработчик подписки на событие.
//
Процедура ФормированиеСегментовПоСтекуИзмененийРегистраПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Если Источник.ОбменДанными.Загрузка = Истина Тогда		
		 Возврат;		 
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("РегистрСведенийНаборЗаписей.СтатусыКонтрагентов") Тогда
		ИскомоеПоле = "Контрагент";
	Иначе
		Возврат;
	КонецЕсли;
	
	НаборЗаписейРегистра = Источник.Выгрузить();
	НаборЗаписейРегистра.Свернуть(ИскомоеПоле);
	МассивОбъектов = НаборЗаписейРегистра.ВыгрузитьКолонку(ИскомоеПоле);
	
	Если Источник.Отбор.Найти(ИскомоеПоле) <> Неопределено И МассивОбъектов.Найти(Источник.Отбор[ИскомоеПоле].Значение) = Неопределено Тогда
		МассивОбъектов.Добавить(Источник.Отбор[ИскомоеПоле].Значение);
	КонецЕсли;
	
	Для Каждого ЭлементОбъекта Из МассивОбъектов Цикл
		МенеджерЗаписи = РегистрыСведений.ФормированиеСегментовПоСтекуИзменений.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Объект = ЭлементОбъекта.Ссылка;
		МенеджерЗаписи.Период = ТекущаяДата();
		МенеджерЗаписи.Записать(Истина);
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Записать промокоды при изменении статуса клиента при записи
//
// Параметры:
//  Источник - 	 - 
//  Отказ	 - 	 - 
//
Процедура ЗаписатьПромокодыПриИзмененииСтатусаКлиентаПриЗаписи(Источник, Отказ) Экспорт

	МассивСтатусов = Новый Массив;
	МассивСтатусов.Добавить(Перечисления.СтатусыКонтрагентов.Постоянный);	
	
	Если Источник.Количество() > 0 И МассивСтатусов.Найти(Источник[0].Статус) <> Неопределено Тогда
		РегистрыСведений.Промокоды.ЗаписатьРеферальныеКоды(Источник[0].Контрагент);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

// Процедура - Актуализировать задание очереди
//
// Параметры:
//  МетаданныеРегламентногоЗадания	 - 	 - 
//
Процедура АктуализироватьЗаданиеОчереди(МетаданныеРегламентногоЗадания, Анализировать = Ложь, АктивироватьСейчас = Ложь, ОтказВыполнения = Ложь) Экспорт
	
	Если НЕ ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ПараметрыЗадания = Неопределено;
	Если Анализировать Тогда
		// Кейс инициирован из метода регламента
		ПараметрыЗадания 	= ЗаданиеОчередиВключено(МетаданныеРегламентногоЗадания.Имя, Анализировать);
		ЗаданиеИспользуется = ПараметрыЗадания.Использование;
	Иначе 
		// Кейс инициирован регистрацией данных для задания (для простых стеков)
		ЗаданиеИспользуется = ЗаданиеОчередиВключено(МетаданныеРегламентногоЗадания.Имя, Анализировать);
	КонецЕсли;
	
	Если НЕ ЗаданиеИспользуется И ПараметрыЗадания = Неопределено Тогда
		ВключитьЗадание(МетаданныеРегламентногоЗадания);
	ИначеЕсли НЕ ПараметрыЗадания = Неопределено Тогда
		ПараметрыЗадания.Вставить("МетаданныеРегламентногоЗадания", МетаданныеРегламентногоЗадания);
		Если АктивироватьСейчас Тогда 
			Если НЕ ЗаданиеИспользуется Тогда 
				ВключитьЗадание(МетаданныеРегламентногоЗадания);
			Иначе
				// Что-то попало в стек - планируем на текущий момент
				ЗапланироватьЗадание(ПараметрыЗадания.Задание, ТекущаяДатаСеанса())
			КонецЕсли;	
		Иначе
			ПроанализироватьДанныеЗадания(ПараметрыЗадания);
			ОтказВыполнения = Истина;
			Если ПараметрыЗадания.НеобходимоОбработать Тогда
				ОтказВыполнения = Ложь;				
				Если НЕ ЗаданиеИспользуется Тогда 
					ВключитьЗадание(МетаданныеРегламентногоЗадания);
				КонецЕсли;	
				// РегистрСведений.ЖурналВыполненияЗаданийОчереди.ЗарегистрироватьАктивностьЗадания(ПараметрыЗадания.Задание);
			ИначеЕсли ПараметрыЗадания.НеобходимоЗапланировать Тогда
				ЗапланироватьЗадание(ПараметрыЗадания.Задание, ПараметрыЗадания.ЗапланированныйМоментЗапуска);				
				Если НЕ ЗаданиеИспользуется Тогда 
					ВключитьЗадание(МетаданныеРегламентногоЗадания);
				КонецЕсли;					
			ИначеЕсли ЗначениеЗаполнено(ПараметрыЗадания.Задание) И НЕ ЗаданиеОчередиАктуально(ПараметрыЗадания) Тогда  
				ВыключитьЗадание(МетаданныеРегламентногоЗадания);
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Функция - Задание очереди включено
//
// Параметры:
//  ИмяРегламентногоЗадания	 - 	 - 
//  ПолучитьЗадание			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗаданиеОчередиВключено(ИмяРегламентногоЗадания, ПолучитьЗадание = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИмяРегламентногоЗадания", ИмяРегламентногоЗадания);	
	Если ПолучитьЗадание Тогда
		ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("Задание"							, Неопределено);
		ПараметрыЗадания.Вставить("Использование"					, Ложь);
		ПараметрыЗадания.Вставить("ЗапланированныйМоментЗапускаUTC"	, Неопределено);
		ПараметрыЗадания.Вставить("ЗапланированныйМоментЗапуска"	, Неопределено);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОчередьЗаданийОбластейДанных.Ссылка КАК Задание,
		|	ОчередьЗаданийОбластейДанных.Использование КАК Использование,
		|	ОчередьЗаданийОбластейДанных.ЗапланированныйМоментЗапуска КАК ЗапланированныйМоментЗапускаUTC
		|ИЗ
		|	Справочник.ОчередьЗаданийОбластейДанных КАК ОчередьЗаданийОбластейДанных
		|ГДЕ
		|	ОчередьЗаданийОбластейДанных.Шаблон.Имя = &ИмяРегламентногоЗадания";
		
		ВыборкаЗадания = Запрос.Выполнить().Выбрать();
		Если ВыборкаЗадания.Следующий() Тогда 
			ЗаполнитьЗначенияСвойств(ПараметрыЗадания, ВыборкаЗадания);
			ПараметрыЗадания.ЗапланированныйМоментЗапуска = МестноеВремя(ПараметрыЗадания.ЗапланированныйМоментЗапускаUTC);
		КонецЕсли;
		
		Возврат ПараметрыЗадания;		
	Иначе 	
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОчередьЗаданийОбластейДанных.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ОчередьЗаданийОбластейДанных КАК ОчередьЗаданийОбластейДанных
		|ГДЕ
		|	ОчередьЗаданийОбластейДанных.Использование = ЛОЖЬ
		|	И ОчередьЗаданийОбластейДанных.Шаблон.Имя = &ИмяРегламентногоЗадания";
		
		Возврат Запрос.Выполнить().Пустой();
	КонецЕсли;
	
КонецФункции

