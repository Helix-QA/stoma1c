&НаКлиенте
// Процедура, обработчик события команды "ДобавитьНовыйЭтап".
//
Процедура ДобавитьНовыйЭтап(Элемент)
	
	Индекс = ПолучитьИндексСтроки(ЭтаФорма.ТекущийЭлемент.Имя);
	ЭтоПоследняяСтрока = ?((ЭтотОбъект.ЭтапыСделок.Количество() - 1) = Индекс, Истина, Ложь);
	
	Если ЭтоПоследняяСтрока Тогда
		ДобавитьНовыйЭтапНаСервере();	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить выбор новой причны
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ДобавитьВыборНовойПричны(Элемент)
	
	Индекс = ПолучитьИндексСтроки(ЭтаФорма.ТекущийЭлемент.Имя);
	ЭтоПоследняяСтрока = ?((Объект.ПричиныОтказов.Количество() - 1) = Индекс, Истина, Ложь);
	
	ГруппаРазмещенияПричинОтказа = Элементы.Найти("ГруппаЭтапаИПричинОтказов");
	Если НЕ ГруппаРазмещенияПричинОтказа = Неопределено Тогда 
		Если ЭтоПоследняяСтрока Тогда
			ИндексСтроки = ДобавитьНовуюПричинуОтказа();	
		КонецЕсли;
		
        ОтобразитьДопустимыеПричиныОтказа();
		Если ЭтоПоследняяСтрока Тогда
			ЭтаФорма.ТекущийЭлемент = Элементы["ПричинаОтказа_" + Формат(ИндексСтроки, "ЧДЦ=0; ЧН=0; ЧГ=0")];
		КонецЕсли;	
    КонецЕсли;
		
КонецПроцедуры

