// Процедура - обработчик выбора пользователя при отмене события
//
Процедура ПоказатьПользователюВопросЗавершение_ЗапасыНоменклатураПриИзменении(Результат, ПараметрыВопроса) Экспорт
	
	Если Результат <> Неопределено Тогда
		ОтветПользователяНаВопрос = Результат;
		
		Если ПараметрыВопроса.Свойство("ПроцедураВозврата") Тогда
			
			Если ПараметрыВопроса.ПроцедураВозврата	= "ЗапасыНоменклатураПриИзменении" Тогда
				
				ЗапасыНоменклатураПриИзменении(ПараметрыВопроса.Элемент, ПараметрыВопроса.СтрокаТЧ, ПараметрыВопроса.ПересчитатьКоличествоУпаковок);
				
			ИначеЕсли ПараметрыВопроса.ПроцедураВозврата = "ЗапасыНоменклатураНачалоВыбораЗавершение" Тогда
				
				ЗапасыНоменклатураНачалоВыбораЗавершение(Новый Структура("Номенклатура", ПараметрыВопроса.РезультатФорма), ПараметрыВопроса.ПараметрыФорма);
				
			ИначеЕсли ПараметрыВопроса.ПроцедураВозврата = "УслугиНоменклатураПриИзменении" Тогда
				
				УслугиНоменклатураПриИзменении(ПараметрыВопроса.Элемент);
				
			КонецЕсли;
			
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Инициализировать список статусов предварительной записи.
//
Процедура ИнициализироватьСписокСтатусовПредварительнойЗаписи()
	
	Элементы.Статус.СписокВыбора.Очистить();
	
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыСобытия.НеПодтверждена
										, Новый ФорматированнаяСтрока(Строка(Перечисления.СтатусыСобытия.НеПодтверждена), , ЦветаСтиля.ГруппаВариантовОтчетовЦвет82)
										, Объект.Статус = Перечисления.СтатусыСобытия.НеПодтверждена);
	
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыСобытия.Подтверждена
										, Новый ФорматированнаяСтрока(Строка(Перечисления.СтатусыСобытия.Подтверждена), , ЦветаСтиля.ЦветВажного)
										, Объект.Статус = Перечисления.СтатусыСобытия.Подтверждена);
											
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыСобытия.ПриемНачат
										, Новый ФорматированнаяСтрока(Строка(Перечисления.СтатусыСобытия.ПриемНачат), , ЦветаСтиля.РезультатУспехЦвет)
										, Объект.Статус = Перечисления.СтатусыСобытия.ПриемНачат);
											
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыСобытия.ПриемОкончен
										, Новый ФорматированнаяСтрока(Строка(Перечисления.СтатусыСобытия.ПриемОкончен), , ЦветаСтиля.ЗаголовокГруппыФормы)
										, Объект.Статус = Перечисления.СтатусыСобытия.ПриемОкончен);
											
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыСобытия.ПриемОтменен
										, Новый ФорматированнаяСтрока(Строка(Перечисления.СтатусыСобытия.ПриемОтменен), , ЦветаСтиля.ДосьеПлохаяОценкаЦвет)
										, Объект.Статус = Перечисления.СтатусыСобытия.ПриемОтменен);
											
	Если ЗначениеЗаполнено(Объект.Статус) Тогда 
		Если Элементы.Статус.СписокВыбора.НайтиПоЗначению(Объект.Статус) = Неопределено Тогда 
			Элементы.Статус.СписокВыбора.Добавить(Объект.Статус
										, Новый ФорматированнаяСтрока(Строка(Объект.Статус) + " (не используется)", , ЦветаСтиля.ФайлЗанятыйДругимПользователем)
										, Истина);
		КонецЕсли;
	КонецЕсли;									
	
	
	
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция, определяет интервал времени в зависимости от выбранного интервала графика.
//
Функция ОпределнениеИнтервалаВремени(ИнтервалГрафика)
	
	ИнтервалВремени = 15;
	Если ИнтервалГрафика = 0 Тогда
		ИнтервалВремени = 15;
	ИначеЕсли ИнтервалГрафика = 1 Тогда
		ИнтервалВремени = 10; 
	ИначеЕсли ИнтервалГрафика = 2 Тогда
		ИнтервалВремени = 5;
	ИначеЕсли ИнтервалГрафика = 3 Тогда
		ИнтервалВремени = 30;	
	КонецЕсли;
	
	Возврат ИнтервалВремени;
	
КонецФункции

