// Вернет признак фискальности указанного вида оплаты для данной кассы.
//
Функция ПолучитьПризнакФискальностиВидаОплатыПоКассе(Касса, ВидОплаты) Экспорт
	
	СтрокиТБ = Касса.ВидыОплат.НайтиСтроки(Новый Структура("ВидОплаты",ВидОплаты));
	Если СтрокиТБ.Количество() = 0 Тогда
		Возврат Истина;
	 Иначе
		Возврат НЕ СтрокиТБ[0].ПробиватьНефискальныйЧек;
	КонецЕсли;
	
КонецФункции

