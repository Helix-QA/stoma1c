						ИдентификаторыНовыхСтрокЗапасов.Добавить(НоваяСтрока.ПолучитьИдентификатор());
						// ТабличныеЧастиПересчетПослеИзменений("Запасы",НоваяСтрока.ПолучитьИдентификатор());
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;	
		
	КонецЕсли;
	Если ИдентификаторыНовыхСтрокЗапасов.Количество() > 0 Тогда 	
		ТабличныеЧастиПересчетПослеИзменений("Запасы", ИдентификаторыНовыхСтрокЗапасов);
	КонецЕсли;
	Если ИдентификаторыНовыхСтрокЛечения.Количество() > 0 Тогда 	
