// Процедура, обрабтчик команды "ОтобразитьВыборТиповФискализации".
//
Процедура ОтобразитьВыборТиповФискализации(Команда)
	
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить(ПредопределенноеЗначение("Перечисление.ТипыФискализации.КассовыйСервер")   , "Кассовый сервер");
	СписокЗначений.Добавить(ПредопределенноеЗначение("Перечисление.ТипыФискализации.НеФискализировать"), "Не фискализировать");
	
	Если Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.Сбербанк") Тогда 
		СписокЗначений.Добавить(ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВСбербанке"), "В Сбербанке");
	КонецЕсли;
	
	Если Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПТинькофф") Тогда 
		СписокЗначений.Добавить(ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВТинькофф"), "В Тинькофф");
	КонецЕсли;
	
	Если Объект.ТипБанка = ПредопределенноеЗначение("Перечисление.ПлатежныеШлюзы.СБПСДМ") Тогда 
		СписокЗначений.Добавить(ПредопределенноеЗначение("Перечисление.ТипыФискализации.ВСДМБанке"), "В СДМ банке");
	КонецЕсли;
	
	ПоказатьВыборИзМеню(Новый ОписаниеОповещения("ВыборКассовогоСервераИлиОнлайнКассы", ЭтотОбъект), СписокЗначений, Элементы.ОтобразитьВыборТиповФискализации);
	
КонецПроцедуры

