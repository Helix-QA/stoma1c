Процедура ПредставлениеКИПриИзменении(Форма, Элемент, Знач ПроверкаДублирования = Ложь) Экспорт
	
	ИндексКИ = Число(Сред(Элемент.Имя, СтрДлина("ПредставлениеКИ_")+1));
	ДанныеКИ = Форма.КонтактнаяИнформация[ИндексКИ];
	
	Если ПустаяСтрока(ДанныеКИ.Представление) Тогда
		ДанныеКИ.ЗначенияПолей = "";
	Иначе
		ДанныеКИ.ЗначенияПолей = КонтактнаяИнформацияВызовСервера.КонтактнаяИнформацияXMLПоПредставлению(ДанныеКИ.Представление, ДанныеКИ.Вид);
	КонецЕсли;
	
	Если ДанныеКИ.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес") Тогда
		КонтактнаяИнформацияКлиентСервер.ЗаполнитьСписокВыбораАдресов(Форма);
	КонецЕсли;
	
	Если ПроверкаДублирования Тогда 
		Форма.ПроверкаДублированияКлиентаКонтактнаяИнформация(ДанныеКИ, ДанныеКИ.Представление);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПредставлениеКИНачалоВыбора(Форма, Элемент, ДанныеВыбора, СтандартнаяОбработка, ОповещениеОЗакрытииДиалога = Неопределено, Знач ПроверкаДублирования = Ложь) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	ИндексКИ = Число(Сред(Элемент.Имя, СтрДлина("ПредставлениеКИ_")+1));
	ДанныеКИ = Форма.КонтактнаяИнформация[ИндексКИ];
	
	// Если представление было изменено в поле и не соответствует реквизиту, то приводим в соответствие.
	Если ДанныеКИ.Представление <> Элемент.ТекстРедактирования Тогда
		ДанныеКИ.Представление = Элемент.ТекстРедактирования;
		ПредставлениеКИПриИзменении(Форма, Элемент);
		Модифицированность = Истина;
	КонецЕсли;
	
	ПараметрыФормы = УправлениеКонтактнойИнформациейКлиент.ПараметрыФормыКонтактнойИнформации(
						ДанныеКИ.Вид,
						ДанныеКИ.ЗначенияПолей,
						ДанныеКИ.Представление,
						ДанныеКИ.Комментарий);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИндексКИ", ИндексКИ);
	ДополнительныеПараметры.Вставить("Форма", Форма);
	ДополнительныеПараметры.Вставить("ПроверкаДублирования", ПроверкаДублирования);
	
	Если ОповещениеОЗакрытииДиалога <> Неопределено Тогда
		ДополнительныеПараметры.Вставить("ОповещениеОЗакрытииДиалога", ОповещениеОЗакрытииДиалога);
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗначениеКИРедактированиеВДиалогеЗавершено", ЭтотОбъект, ДополнительныеПараметры);
	
	УправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыФормы, ЭтотОбъект, ОписаниеОповещения);
	
КонецПроцедуры

Процедура ПредставлениеКИОчистка(Форма, Элемент, СтандартнаяОбработка) Экспорт
	
	ИндексКИ = Число(Сред(Элемент.Имя, СтрДлина("ПредставлениеКИ_")+1));
	ДанныеКИ = Форма.КонтактнаяИнформация[ИндексКИ];
	ДанныеКИ.ЗначенияПолей = "";
	
	Если ДанныеКИ.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес") Тогда
		КонтактнаяИнформацияКлиентСервер.ЗаполнитьСписокВыбораАдресов(Форма);
	КонецЕсли;
	
КонецПроцедуры

Процедура КомментарийКИПриИзменении(Форма, Элемент) Экспорт
	
	ИндексКИ = Число(Сред(Элемент.Имя, СтрДлина("КомментарийКИ_")+1));
	ДанныеКИ = Форма.КонтактнаяИнформация[ИндексКИ];
	
	ОжидаемыйВид = ?(ПустаяСтрока(ДанныеКИ.ЗначенияПолей), ДанныеКИ.Вид, Неопределено);
	КонтактнаяИнформацияВызовСервера.УстановитьКомментарийКонтактнойИнформации(ДанныеКИ.ЗначенияПолей, ДанныеКИ.Комментарий, ОжидаемыйВид);
	
КонецПроцедуры

Процедура ДобавитьКонтактнуюИнформациюНажатие(Форма, Элемент, МножественнаяФормаВладельца = "объектов") Экспорт
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", Форма);
	ДополнительныеПараметры.Вставить("МножественнаяФормаВладельца", МножественнаяФормаВладельца);
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьКонтактнуюИнформациюВидВыбран", ЭтотОбъект, ДополнительныеПараметры);
	
	СписокДоступныхВидов = КонтактнаяИнформацияКлиентСервер.СписокВидовДляДобавленияКонтактнойИнформации(Форма.СвойстваВидовКонтактнойИнформации, Форма.КонтактнаяИнформация);
	
	Форма.ПоказатьВыборИзСписка(ОписаниеОповещения, СписокДоступныхВидов, Элемент);
	
КонецПроцедуры

Процедура ВыполнитьКоманду(Форма, Команда, ИмяТабличнойЧасти = Неопределено) Экспорт
	
	ИмяТабличнойЧасти = ?(ИмяТабличнойЧасти = Неопределено, "КонтактнаяИнформация", ИмяТабличнойЧасти);
	            
	Если СтрНачинаетсяС(Команда.Имя, "КонтекстноеМенюКартаЯндекс_") Тогда
		
		ИндексКИ = Число(Сред(Команда.Имя, СтрДлина("КонтекстноеМенюКартаЯндекс_")+1));
		ДанныеКИ = Форма[ИмяТабличнойЧасти][ИндексКИ];
		УправлениеКонтактнойИнформациейКлиент.ПоказатьАдресНаКарте(ДанныеКИ.Представление, "Яндекс.Карты");
		
	ИначеЕсли СтрНачинаетсяС(Команда.Имя, "КонтекстноеМенюКартаGoogle_") Тогда
		
		ИндексКИ = Число(Сред(Команда.Имя, СтрДлина("КонтекстноеМенюКартаGoogle_")+1));
		ДанныеКИ = Форма[ИмяТабличнойЧасти][ИндексКИ];
		УправлениеКонтактнойИнформациейКлиент.ПоказатьАдресНаКарте(ДанныеКИ.Представление, "GoogleMaps");
		
	ИначеЕсли СтрНачинаетсяС(Команда.Имя, "ПозвонитьПоIPТелефонии_") Тогда
		
		ИндексКИ = Число(Сред(Команда.Имя, СтрДлина("ПозвонитьПоIPТелефонии_")+1));
		ДанныеКИ = Форма[ИмяТабличнойЧасти][ИндексКИ];
		
		IPТелефонияКлиент.ИсходящийЗвонокОсуществитьПоКонтрагенту(Форма.Объект.Ссылка, ДанныеКИ.Представление);
		
	ИначеЕсли СтрНачинаетсяС(Команда.Имя, "SkypeПозвонить_") Тогда
		
		ИндексКИ = Число(Сред(Команда.Имя, СтрДлина("SkypeПозвонить_")+1));
		ДанныеКИ = Форма[ИмяТабличнойЧасти][ИндексКИ];
		ДополнительныеПараметры = Новый Структура("ЛогинSkype");
		ДополнительныеПараметры.ЛогинSkype = ДанныеКИ.Представление;
		Список = Новый СписокЗначений;
		Список.Добавить("Позвонить", НСтр("ru='Позвонить';en='Call'"));	
		УправлениеКонтактнойИнформациейКлиент.ПослеВыбораИзМенюSkype(Список[0], ДополнительныеПараметры);
		
	ИначеЕсли СтрНачинаетсяС(Команда.Имя, "SkypeНачатьЧат_") Тогда
		
		ИндексКИ = Число(Сред(Команда.Имя, СтрДлина("SkypeНачатьЧат_")+1));
		ДанныеКИ = Форма[ИмяТабличнойЧасти][ИндексКИ];
		ДополнительныеПараметры = Новый Структура("ЛогинSkype");
		ДополнительныеПараметры.ЛогинSkype = ДанныеКИ.Представление;
		Список = Новый СписокЗначений;
		Список.Добавить("Начать чат", НСтр("ru='Начать чат';en='ToBegin chat'"));	
		УправлениеКонтактнойИнформациейКлиент.ПослеВыбораИзМенюSkype(Список[0], ДополнительныеПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

