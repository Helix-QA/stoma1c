// Процедура, выполянет копирование настроек сотрудника.
//
Процедура СкопироватьНастройкиСотрудника(Источник)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МестаРаботы.Выгрузить(,"СтруктурнаяЕдиница"));
	Запрос.УстановитьПараметр("Источник" , Источник);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|ГДЕ
	|	УслугиСотрудника.Сотрудник = &Источник
	|	И УслугиСотрудника.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)";
	
	Результат = Запрос.Выполнить().Выгрузить();
	НаборЗаписей = РегистрыСведений.УслугиСотрудника.СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(Результат);
	НаборЗаписей.Отбор.Сотрудник.Использование = Истина;
	НаборЗаписей.Отбор.Сотрудник.Значение = Сотрудник;
	НаборЗаписей.Записать(Истина);
	
	ЭтаФорма._ПодборНоменклатур.ПолучитьЭлементы().Очистить();
	
	ЗаполнитьДеревоПодбораНоменклатур();
	
	ЗаполнитьСписокПодбораРекурсивноСервер(
	ЭтаФорма._ПодборНоменклатурИсточникГрупп.ПолучитьЭлементы(), 
	ЭтаФорма._ПодборНоменклатурИсточникЭлементов, 
	ЭтаФорма._ПодборНоменклатур, ЭтаФорма);	
	
	УстановитьНачальныеФлагиНаГруппы(Сотрудник);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает таблицу номенклатуры для определенного сотрудника.
//
Функция ПолучитьТаблицуНоменклатурыСотрудника(ТаблицаНоменклатуры, Сотрудник)
	
	// Создаем ТаблицуЗначений.
	НоменклатураСотрудника = Новый ТаблицаЗначений;
	НоменклатураСотрудника.Колонки.Добавить("Номенклатура");
	НоменклатураСотрудника.Колонки.Добавить("НормаВремени");
	НоменклатураСотрудника.Колонки.Добавить("СтруктурнаяЕдиница");
	НоменклатураСотрудника.Колонки.Добавить("Сотрудник");
	
	// Перебираем таблицу и фильтруем по сотруднику.
	Для каждого Строка из ТаблицаНоменклатуры Цикл
		Если Строка.Сотрудник = Сотрудник Тогда
			СтрокаТЗ = НоменклатураСотрудника.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТЗ, Строка);
		КонецЕсли;
	КонецЦикла;
	
	Возврат НоменклатураСотрудника;
	
КонецФункции

#КонецОбласти