
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Клиент")
		И ЗначениеЗаполнено(Параметры.Клиент) Тогда
		
		СформироватьБлокИсторияЗвонков(Параметры.Клиент);
		ЭтаФорма.Заголовок = НСтр("ru = 'История звонков '; en = 'Call history '") + Строка(Параметры.Клиент);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик нажатия динамической кнопки.
//
Процедура ПроцедураОбработкиНажатияДинамическойКнопки(Элемент)
	
	ТипЭлемента   = ЧастьИмениЭлемента(Элемент.Имя,,0);
	Идентификатор = Число(ЧастьИмениЭлемента(Элемент.Имя,,1));	
	
	Если ТипЭлемента <> -1 Тогда
		СтрокаТаблицаЗвонков = ТаблицаЗвонков.НайтиПоИдентификатору(Идентификатор);
		Если СтрокаТаблицаЗвонков <> Неопределено Тогда
			Значение = СтрокаТаблицаЗвонков[ТипЭлемента];
			Если ЗначениеЗаполнено(Значение) Тогда
				Если ТипЭлемента = "URLЗаписи" Тогда
					АктуальныйURLЗаписи = IPТелефонияКлиент.ПолучитьАктуальныйURLЗаписиROSTELECOMКлиент(Значение, СтрокаТаблицаЗвонков.IDЗвонка, СтрокаТаблицаЗвонков.ОборудованиеТелефонии);
					НачатьЗапускПриложения(Новый ОписаниеОповещения , АктуальныйURLЗаписи); 
				Иначе
					ПоказатьЗначение(, Значение);
				КонецЕсли;
			КонецЕсли; 	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЧастьИмениЭлемента(Имя,Разделитель = "_", Индекс = 0)
	
	мИндекс = СтрРазделить(Имя,Разделитель);
		
	Возврат ?(мИндекс.Количество() > Индекс И мИндекс[Индекс] <> "", мИндекс[Индекс], -1);	
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, сформировать блок история звонков.
//
Процедура СформироватьБлокИсторияЗвонков(Клиент)
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// 1. Получить данные истории звонков контрагента
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ПОМЕСТИТЬ ВременнаяТаблицаНомераКонтрагента
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Клиент
	|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
	|	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ИсторияВызовов.НомерТелефона КАК НомерТелефона,
	|	ИсторияВызовов.Пользователь КАК Пользователь,
	|	ВЫБОР
	|		КОГДА ИсторияВызовов.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Исходящий)
	|			ТОГДА ""Исх.""
	|		КОГДА ИсторияВызовов.НаправлениеВызова = ЗНАЧЕНИЕ(Перечисление.ВариантыНаправленияВызова.Входящий)
	|			ТОГДА ""Вх.""
	|		ИНАЧЕ ""Внутр.""
	|	КОНЕЦ КАК Направление,
	|	ВЫБОР
	|		КОГДА ИсторияВызовов.НачалоРазговора <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				И ИсторияВызовов.ОкончаниеЗвонка <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|			ТОГДА ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0), СЕКУНДА, РАЗНОСТЬДАТ(ИсторияВызовов.НачалоРазговора, ИсторияВызовов.ОкончаниеЗвонка, СЕКУНДА))
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|	КОНЕЦ КАК Длительность,
	|	ИсторияВызовов.URLЗаписи КАК URLЗаписи,
	|	ИсторияВызовов.ФайлЗаписи КАК ФайлЗаписи,
	|	ИсторияВызовов.Статус КАК Статус,
	|	ВЫБОР
	|		КОГДА ИсторияВызовов.НачалоВызова <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ИсторияВызовов.НачалоВызова
	|		ИНАЧЕ ИсторияВызовов.НачалоРазговора
	|	КОНЕЦ КАК ПериодЗвонка,
	|	ИсторияВызовов.НачалоВызова КАК НачалоВызова,
	|	ИсторияВызовов.НачалоРазговора КАК НачалоРазговора,
	|	ИсторияВызовов.IDЗвонка КАК IDЗвонка,
	|	ИсторияВызовов.ОборудованиеТелефонии КАК ОборудованиеТелефонии,
	|	ИсторияВызовов.Заметка КАК Заметка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	(ИсторияВызовов.Контрагент = &Клиент
	|			ИЛИ ИсторияВызовов.НомерТелефона В
	|				(ВЫБРАТЬ
	|					ВременнаяТаблицаНомераКонтрагента.НомерТелефона
	|				ИЗ
	|					ВременнаяТаблицаНомераКонтрагента))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодЗвонка УБЫВ");
	
	Запрос.УстановитьПараметр("Клиент", Клиент);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Элементы.ГруппаШапка.Видимость = Ложь;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////
	// 2. Вывести данные	
	Пока Выборка.Следующий() Цикл
		
		СтрокаТаблицаЗвонков = ТаблицаЗвонков.Добавить(); 
		ЗаполнитьЗначенияСвойств(СтрокаТаблицаЗвонков, Выборка);
        ИдСтроки = СтрокаТаблицаЗвонков.ПолучитьИдентификатор();
		
		УправлениеИнтерфейсамиСервер.КопироватьЭлементФормыРекурсивно(ЭтаФорма,Элементы.ГруппаДанныеГоризонтальная_,Элементы.ГруппаИсторияЗвонков,ИдСтроки);
		
		// Добавить элементы
		Период 				 = Выборка.ПериодЗвонка;
		ПредставлениеПериода = Формат(Период, "ДФ=ЧЧ:мм") + " | " + Формат(Период, "ДЛФ=ДД");
		
		Минут	= Минута(Выборка.Длительность);
		Секунд	= Секунда(Выборка.Длительность);
		ПредставлениеДлительности = ?(Минут > 0, "" + Минут + " мин. ", "") + ?(Секунд > 0, "" + Секунд + " сек.", "");
		
		ИзменитьЭлементФормы("НачалоВызова_"  + ИдСтроки, ПредставлениеПериода);
		ИзменитьЭлементФормы("Длительность_"  + ИдСтроки, ПредставлениеДлительности);
		ИзменитьЭлементФормы("Направление_"   + ИдСтроки, Строка(Выборка.Направление));
		ИзменитьЭлементФормы("Статус_" 	      + ИдСтроки, Строка(Выборка.Статус));
		ИзменитьЭлементФормы("НомерТелефона_" + ИдСтроки, Строка(Выборка.НомерТелефона));
		ИзменитьЭлементФормы("Заметка_"       + ИдСтроки, Строка(Выборка.Заметка));
		
		Если ЗначениеЗаполнено(Выборка.Пользователь) Тогда 
			ИзменитьЭлементФормы("Пользователь_" + ИдСтроки, Строка(Выборка.Пользователь), Истина);
			ИзменитьЭлементФормы("ПустойПользователь_" + ИдСтроки,, Ложь);
		Иначе
			ИзменитьЭлементФормы("ПустойПользователь_" + ИдСтроки,, Истина);
			ИзменитьЭлементФормы("Пользователь_" + ИдСтроки,, Ложь);
		КонецЕсли;	
		
		ШиринаДекорацииЗаглушки = 0;
		
		Если НЕ ЗначениеЗаполнено(Выборка.URLЗаписи) Тогда
			ИзменитьЭлементФормы("URLЗаписи_" + ИдСтроки,, Ложь);
			ШиринаДекорацииЗаглушки = 2;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Выборка.ФайлЗаписи) Тогда
		   ИзменитьЭлементФормы("ФайлЗаписи_" + ИдСтроки,, Ложь);
		   ШиринаДекорацииЗаглушки = ШиринаДекорацииЗаглушки + 2;
		КонецЕсли;
		
		Если ШиринаДекорацииЗаглушки > 0 Тогда
		    ИзменитьЭлементФормы("ДекорацияЗаглушки_" + ИдСтроки,, Истина, ШиринаДекорацииЗаглушки);
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
// Процедура, выполняет добавление элемента формы.
//
Процедура ИзменитьЭлементФормы(ИмяЭлемента, Заголовок = "", Видимость = Истина, Ширина = 0)
	
	Элемент = Элементы.Найти(ИмяЭлемента);	
	Если Элемент <> Неопределено Тогда
		Элемент.Заголовок = Заголовок;	
		Элемент.Видимость = Видимость;
		Элемент.Ширина    = ?(Ширина = 0, Элемент.Ширина, Ширина); 
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
 
