

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Предмет") Тогда
		Объект.Контрагент = Параметры.Предмет;
	КонецЕсли;
	// Инициализация реквизитов при открытии.
	ИнициализацияФормы();
	СоздатьВиджетСделки(); 
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ" Тогда	
		СоздатьВиджетСделки();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	ЗадачаИзменена = ЭтотОбъект.Модифицированность;
	Объект.Выполнена = ЭтотОбъект.ВзаимодействиеВыполнено;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Заполним параметры напоминания		
	Задачи.Взаимодействие.ЗаполнитьПараметрыНапоминания(ТекущийОбъект, Новый Структура("ЗадачаРежимНапоминания", ЭтотОбъект.ЗадачаРежимНапоминания));	
	
	Если Не ЗначениеЗаполнено(ТекущийОбъект.Ссылка) Тогда
		ПараметрыЗаписи.Вставить("ЭтоНовый", Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ЗадачаИзменена Или ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗаписи, "ЭтоНовый", Ложь) Тогда
		Оповестить("ОбновитьСписокЗадачМенеджера", Объект.Ссылка);	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Сделка) Тогда
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Задача"			, Объект.Ссылка);
		ПараметрыОповещения.Вставить("Сделка"			, Объект.Сделка);
		ПараметрыОповещения.Вставить("УдалениеЗадачи"	, (Объект.Выполнена Или Объект.ПометкаУдаления));
		
		Оповестить("ОбновитьЗадачуКанбан", ПараметрыОповещения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события формы "ОбработкаПроверкиЗаполненияНаСервере".
//
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// Если задача не выполнена - проверяем заполнение
	Если Не Объект.Выполнена Тогда 
		
		Если Не ЗначениеЗаполнено(Объект.ВидВзаимодействияСправочник) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Укажите вид взаимодействия.';en='Specify view interactions.'"), Объект.Ссылка, "Объект.ВидВзаимодействияСправочник");
			Отказ = Истина;
		КонецЕсли;	
		
		// Если Не ЗначениеЗаполнено(Объект.ЗадачаПредмет) Тогда 
		//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите предмет задачи.", ЭтотОбъект, "Объект.ЗадачаПредмет");
		//	Отказ = Истина;
		// КонецЕсли;	
		
		Отказ = Не ПроверитьПравильностьПериода();	
		
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

