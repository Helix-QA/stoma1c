&НаКлиенте
// Процедура - команда создания нового события
//
Процедура СоздатьСобытие(Команда)	
	
	Область = Элементы.ТабличныйДокумент.ТекущаяОбласть;	
	Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти) И НЕ ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда		
		
		ЗаполняемыйКонтрагент = Неопределено;
		Если ЗначениеЗаполнено(ЭтотОбъект.ОтборКонтрагент) Тогда
			ЗаполняемыйКонтрагент = ЭтотОбъект.ОтборКонтрагент;
			
		ИначеЕсли ТипЗнч(Команда) = Тип("Структура") И Команда.Свойство("КлиентДляОткрытия")
					И ТипЗнч(Команда.КлиентДляОткрытия) = Тип("СправочникСсылка.Контрагенты") Тогда
					
			ЗаполняемыйКонтрагент = Команда.КлиентДляОткрытия;			
		КонецЕсли;
		
		ЗаполняемыйСотрудник = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник), ПЗРасшифровкаТекущейОбласти.Сотрудник, ОтборСотрудник);
		Если ЗначениеЗаполнено(ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента)
			И ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента <> ЗаполняемыйСотрудник Тогда
			
			ЗаполняемыйКонтрагент = Неопределено;
		КонецЕсли;
		
		Старт = ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / 4) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / 4) * 4 * 15 * 60;
		Финиш = Старт + (Область.Низ - Область.Верх + 1) / 4 * 60 * 60;		
		ЗначениеЗаполнения = Новый Структура();
		ЗначениеЗаполнения.Вставить("ДатаНачала"                       , Старт);
		ЗначениеЗаполнения.Вставить("ДатаОкончания"                    , Финиш);
		ЗначениеЗаполнения.Вставить("Сотрудник"                        , ЗаполняемыйСотрудник);
		ЗначениеЗаполнения.Вставить("Контрагент"                       , ЗаполняемыйКонтрагент);  
		ЗначениеЗаполнения.Вставить("ПеренесённаяПредварительнаяЗапись", ПеренесённаяПредварительнаяЗапись); 
		ЗначениеЗаполнения.Вставить("СтруктурнаяЕдиница"			   , Объект.СтруктурнаяЕдиница);
		// ЗначениеЗаполнения.Вставить("КонтактнаяИнформация", Строка(ОтборКонтрагент) + ", тел. " + ОтборКонтрагент.Телефон);
		ОткрытьФорму("Документ.Событие.ФормаОбъекта", ЗначениеЗаполнения, ЭтаФорма);	
	КонецЕсли;
	
КонецПроцедуры

