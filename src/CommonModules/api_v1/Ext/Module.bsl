// Функция - Получить и проверить дату
//
// Параметры:
//  datetime			 - 	 - 
//  СтруктураОшибки		 - 	 - 
//  ОбязательныйПараметр - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьИПроверитьДату(datetime, СтруктураОшибки, ОбязательныйПараметр = Ложь)
	
	Дата = Неопределено;
	
	Если ЗначениеЗаполнено(datetime) Тогда
		Если ТипЗнч(datetime) = Тип("Строка") Тогда 
			Дата = ПолучитьДату(datetime);
		ИначеЕсли ТипЗнч(datetime) = Тип("Дата") Тогда 
			Дата = datetime;
		Иначе 
			Дата = Неопределено;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Дата) Тогда
			СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(1054);
		КонецЕсли;
		
	ИначеЕсли ОбязательныйПараметр Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1061);
	КонецЕсли;
	
	Возврат Дата;
	
КонецФункции

// Функция, проверяет переданное занятие.
//
Функция ПолучитьСсылкуПоИдентификатору(Идентификатор, СтруктураОшибки, ЭтоСправочник = Истина, ИмяОбъекта, КодОшибки, ОбязательныйПараметр = Ложь)
	
	Ссылка = Неопределено;
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		
		Ссылка = ПолучитьСсылкуОбъектаПоУИД(Идентификатор, ?(ЭтоСправочник, "Справочники", "Документы"), ИмяОбъекта);
		Если Ссылка = Неопределено Тогда
			СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(КодОшибки);
		КонецЕсли;
		
	ИначеЕсли ОбязательныйПараметр Тогда
		СтруктураОшибки = ПолучитьСтруктуруВозвратаОшибки(КодОшибки);
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

// Функция, возвращает минимальную и максимальную цены номенклатуры.
// 
Функция ПолучитьЦеныНоменклатуры(Номенклатура, ТаблицаВидовЦен)
	
	МассивСтрок = ТаблицаВидовЦен.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
	
	Если МассивСтрок.Количество() = 0 Тогда
		МассивСтрок = ТаблицаВидовЦен.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
	КонецЕсли;
	
	МинимальнаяЦена  = ?(МассивСтрок.Количество() > 0, МассивСтрок[0].Цена, 0);
	МаксимальнаяЦена = ?(МассивСтрок.Количество() > 0, МассивСтрок[0].Цена, 0);
	
	Для Каждого СтрокаТЧ Из МассивСтрок Цикл
		МинимальнаяЦена  = ?(СтрокаТЧ.Цена < МинимальнаяЦена, СтрокаТЧ.Цена, МинимальнаяЦена);
		МаксимальнаяЦена = ?(СтрокаТЧ.Цена > МаксимальнаяЦена, СтрокаТЧ.Цена, МаксимальнаяЦена);
	КонецЦикла;
	
	Возврат Новый Структура("МинимальнаяЦена, МаксимальнаяЦена", МинимальнаяЦена, МаксимальнаяЦена);
	
КонецФункции

// Функция - Получить дату среза
//
// Параметры:
//  ДатаСреза			 - 	 - 
//  ДатаСрезаЗаполнена	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
функция ПолучитьДатуСреза(ДатаСреза, ДатаСрезаЗаполнена = Ложь, СтруктурнаяЕдиница = Неопределено)
	
	ПараметрыВремениРаботыСЕ = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(ДатаСреза
																			, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница)
																			,
																			, Ложь); 
																			
	Если ЗначениеЗаполнено(ПараметрыВремениРаботыСЕ) Тогда 
		Если ДатаСрезаЗаполнена Тогда
			Если ДатаСреза < ПараметрыВремениРаботыСЕ.НачалоРаботы Тогда 
				ДатаСреза = ПараметрыВремениРаботыСЕ.НачалоРаботы;
			ИначеЕсли ДатаСреза > ПараметрыВремениРаботыСЕ.ОкончаниеРаботы Тогда 
				ДатаСреза = НачалоДня(ДатаСреза) + 24*60*60;
				ПолучитьДатуСреза(ДатаСреза, ДатаСрезаЗаполнена, СтруктурнаяЕдиница);
				Возврат ДатаСреза;
			КонецЕсли;	
		Иначе 	
			Если ТекущаяДатаСеанса() < ПараметрыВремениРаботыСЕ.НачалоРаботы Тогда 
				ДатаСреза = ПараметрыВремениРаботыСЕ.НачалоРаботы;
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
	ВремяОграниченияНачалаОнлайнЗаписи = Константы.ВремяОграниченияНачалаОнлайнЗаписи.Получить();
	ВремяОграниченияНачалаОнлайнЗаписи = ВремяОграниченияНачалаОнлайнЗаписи * 60;
	ОнлайнЗаписьВозможнаНа       	   = ТекущаяДатаСеанса() + ВремяОграниченияНачалаОнлайнЗаписи;
	
	Если ДатаСрезаЗаполнена Тогда  			
		ДатаСреза = ?(ДатаСреза < ОнлайнЗаписьВозможнаНа, ОнлайнЗаписьВозможнаНа, ДатаСреза);  
	Иначе     		
		ДатаСреза = ОнлайнЗаписьВозможнаНа;
	КонецЕсли;
	
	Возврат ДатаСреза;
	
КонецФункции

// Функция - Получить структуру id title
//
// Параметры:
//  Ссылка									 - 	 - 
//  Наименование							 - 	 - 
//  ВернутьНеопределеноПриОтсутствииСсылки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуру_id_title(Ссылка, Наименование, ВернутьНеопределеноПриОтсутствииСсылки = Ложь)
	
	Если ВернутьНеопределеноПриОтсутствииСсылки И Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Неопределено;
	Иначе
		
		СтруктураIdTitle = Новый Структура;
		СтруктураIdTitle.Вставить("id"   , ?(ЗначениеЗаполнено(Ссылка)      , Строка(Ссылка.УникальныйИдентификатор()), Неопределено));
		СтруктураIdTitle.Вставить("title", ?(ЗначениеЗаполнено(Наименование), Наименование                      	  , Неопределено));
		
		Возврат СтруктураIdTitle;
		
	КонецЕсли;
	
КонецФункции

