// Процедура устанавливает печатную форму предопределенному виду медицинской карты "ОсновнойВидМедицинскойКарты".
//
Процедура УстановитьПредопределеннымВидамМедКартПечатнуюФорму() Экспорт
	
	ПредопределенныйВидМедКарты = Справочники.ВидыМедицинскихКарт.НайтиПоКоду("000000001");
	Если ПредопределенныйВидМедКарты <> Неопределено Тогда 
		Если ПредопределенныйВидМедКарты <> Справочники.ВидыМедицинскихКарт.ПустаяСсылка() Тогда
			ВидМедКартыОбъект = ПредопределенныйВидМедКарты.ПолучитьОбъект();
			ВидМедКартыОбъект.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_А4;
			ВидМедКартыОбъект.Записать();
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

// Процедура устанавливает медкартам пациентов код без лидирующих нулей.
//
Процедура УстановитьМедКартамКодБезЛидирующихНулей() Экспорт
	
	ВыборкаМедКарт = Справочники.МедицинскиеКарты.Выбрать();
	Пока ВыборкаМедКарт.Следующий() Цикл 
		МедКартаОбъект = ВыборкаМедКарт.Ссылка.ПолучитьОбъект();
		МедКартаОбъект.КодБезНулей = ФормированиеПечатныхФорм.УдалитьЛидирующиеНулиИзНомераОбъекта(МедКартаОбъект.Код);
		Попытка		
        	МедКартаОбъект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;	
	
