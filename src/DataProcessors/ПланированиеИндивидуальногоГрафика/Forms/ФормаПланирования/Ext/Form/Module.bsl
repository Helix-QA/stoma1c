&НаКлиенте
// Процедура - Декорация управления сохранением шаблонов нажатие
// 
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура ДекорацияУправленияСохранениемШаблоновНажатие(Элемент)

	СтруктураСравнения = СписокШаблоновСодержитСтруктуруИнтервалов();
	Если СтруктураСравнения.Успех Тогда 
		// Нажатие означает что необходимо удалить шаблон из списка
		СписокШаблонов.Удалить(СписокШаблонов[СтруктураСравнения.ИндексШаблона]);
		ОбновитьДекорациюУпраленияСохранениемШаблонов();
		СохранитьШаблоныВКеш(СписокШаблонов);		
	ИначеЕсли ЗначениеЗаполнено(СтруктураСравнения.Информация) Тогда
		// Попробывали сохранить - интервалы не заполнены
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураСравнения.Информация, ЭтотОбъект);
		Возврат;
	Иначе 
		// Сохраняем
		СписокШаблонов.Добавить(ОтборИнтервалыРаботы, , , БиблиотекаКартинок.РейтингЗвездаЗаполненная);
		ОбновитьДекорациюУпраленияСохранениемШаблонов();
		СохранитьШаблоныВКеш(СписокШаблонов);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Сохранить шаблоны в кеш
// 
// Параметры:
//  СписокШаблонов	 - 	 - 
// 
Процедура СохранитьШаблоныВКеш(СписокШаблонов)
	
