#КонецОбласти
		
	КонецЕсли;

	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события посещение клиники
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//  ОбъектСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПосещениеКлиники(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);	
	Запрос.УстановитьПараметр("ПараметрНомерПосещения"		, ДанныеТриггера.ПараметрСобытия);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ЗАПЛАНИРОВАННЫХ_ИЛИ_ПО_ПОДПИСКЕ

		Запрос.Текст = 
		"ВЫБРАТЬ
			               |	Посещение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	Посещение.ДатаПрихода КАК ДатаПосещения,
			               |	Посещение.Ссылка КАК Посещение,
			               |	ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) КАК Клиент,
			               |	Посещение.Основание КАК Основание
			               |ПОМЕСТИТЬ ТаблицаПосещенийПоКлиентам
			               |ИЗ
			               |	Документ.Посещение КАК Посещение
			               |ГДЕ
			               |	Посещение.Проведен = ИСТИНА
			               |	И Посещение.ПризнакОтменен = ЛОЖЬ
			               |	И Посещение.Контрагент = &Контрагент
			               |	И Посещение.Контрагент В(&СегментКонтрагентов)
			               |	И ВЫБОР
			               |			КОГДА НЕ ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) ЕСТЬ NULL
			               |				ТОГДА ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты).ОбезличенныйКлиент = ЛОЖЬ
			               |			ИНАЧЕ ИСТИНА
			               |		КОНЕЦ
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ТаблицаПосещенийПоКлиентам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	ТаблицаПосещенийПоКлиентам.ДатаПосещения КАК ДатаПосещения,
			               |	ТаблицаПосещенийПоКлиентам.Посещение КАК Посещение,
			               |	ТаблицаПосещенийПоКлиентам.Клиент КАК Клиент,
			               |	ТаблицаПосещенийПоКлиентам.Основание КАК Основание,
			               |	КОЛИЧЕСТВО(ТаблицаПосещений_1.Посещение) КАК Номер
			               |ПОМЕСТИТЬ ИтоговаяТаблицаПосещений
			               |ИЗ
			               |	ТаблицаПосещенийПоКлиентам КАК ТаблицаПосещенийПоКлиентам
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПосещенийПоКлиентам КАК ТаблицаПосещений_1
			               |		ПО ТаблицаПосещенийПоКлиентам.ДатаПосещения >= ТаблицаПосещений_1.ДатаПосещения
			               |			И ТаблицаПосещенийПоКлиентам.Клиент = ТаблицаПосещений_1.Клиент
			               |
			               |СГРУППИРОВАТЬ ПО
			               |	ТаблицаПосещенийПоКлиентам.СтруктурнаяЕдиница,
			               |	ТаблицаПосещенийПоКлиентам.ДатаПосещения,
			               |	ТаблицаПосещенийПоКлиентам.Посещение,
			               |	ТаблицаПосещенийПоКлиентам.Клиент,
			               |	ТаблицаПосещенийПоКлиентам.Основание
			               |
			               |ИМЕЮЩИЕ
			               |	КОЛИЧЕСТВО(ТаблицаПосещений_1.Посещение) = &ПараметрНомерПосещения И
			               |	ТаблицаПосещенийПоКлиентам.Посещение = &Посещение
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ИтоговаяТаблицаПосещений.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	ИтоговаяТаблицаПосещений.ДатаПосещения КАК ДатаПосещения,
			               |	ИтоговаяТаблицаПосещений.Посещение КАК Посещение,
			               |	ИтоговаяТаблицаПосещений.Клиент КАК Контрагент,
			               |	ИтоговаяТаблицаПосещений.Посещение КАК ОбъектСобытия,
			               |	ИтоговаяТаблицаПосещений.Основание КАК Основание,
			               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
			               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
			               |ИЗ
			               |	ИтоговаяТаблицаПосещений КАК ИтоговаяТаблицаПосещений";
					
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент В(&СегментКонтрагентов)",
			"Посещение.Контрагент В
			|			(ВЫБРАТЬ
			|				СоставСегментов.ОбъектСегмента
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	

		Если РегистрацияПоПодписке Тогда 
			Запрос.УстановитьПараметр("Контрагент"			, ОбъектСобытия.Контрагент);
			Запрос.УстановитьПараметр("Посещение"			, ОбъектСобытия);
		ИначеЕсли РегистрацияЗапланированных Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент = &Контрагент", "Посещение.Контрагент В(&МассивКонтрагентов)");
			Запрос.УстановитьПараметр("МассивКонтрагентов"	, ДанныеТриггера.МассивНеобработанныхКонтрагентов);
			Запрос.УстановитьПараметр("Посещение"			, ОбъектСобытия);
		КонецЕсли;	
		
#КонецОбласти

	Иначе

#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.Текст = 
		"ВЫБРАТЬ
			               |	Посещение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	Посещение.ДатаПрихода КАК ДатаПрихода,
			               |	Посещение.Ссылка КАК Посещение,
			               |	ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) КАК Клиент,
			               |	Посещение.Основание КАК Основание
			               |ПОМЕСТИТЬ ТаблицаПосещенийПоДате
			               |ИЗ
			               |	Документ.Посещение КАК Посещение
			               |ГДЕ
			               |	Посещение.Проведен = ИСТИНА
			               |	И Посещение.ПризнакОтменен = ЛОЖЬ
			               |	И Посещение.Контрагент В(&СегментКонтрагентов)
			               |	И НАЧАЛОПЕРИОДА(Посещение.ДатаПрихода, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
			               |	И НЕ ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) ЕСТЬ NULL
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	Посещение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	Посещение.ДатаПрихода КАК ДатаПосещения,
			               |	Посещение.Ссылка КАК Посещение,
			               |	Посещение.Контрагент КАК Клиент,
			               |	Посещение.Основание КАК Основание
			               |ПОМЕСТИТЬ ТаблицаПосещенийПоКлиентам
			               |ИЗ
			               |	Документ.Посещение КАК Посещение
			               |ГДЕ
			               |	Посещение.Проведен = ИСТИНА
			               |	И Посещение.ПризнакОтменен = ЛОЖЬ
			               |	И Посещение.Контрагент В
			               |			(ВЫБРАТЬ
			               |				ТаблицаПосещенийПоДате.Клиент
			               |			ИЗ
			               |				ТаблицаПосещенийПоДате)
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ТаблицаПосещенийПоКлиентам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	ТаблицаПосещенийПоКлиентам.ДатаПосещения КАК ДатаПосещения,
			               |	ТаблицаПосещенийПоКлиентам.Посещение КАК Посещение,
			               |	ТаблицаПосещенийПоКлиентам.Клиент КАК Клиент,
			               |	ТаблицаПосещенийПоКлиентам.Основание КАК Основание,
			               |	КОЛИЧЕСТВО(ТаблицаПосещений_1.Посещение) КАК Номер
			               |ПОМЕСТИТЬ ИтоговаяТаблицаПосещений
			               |ИЗ
			               |	ТаблицаПосещенийПоКлиентам КАК ТаблицаПосещенийПоКлиентам
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПосещенийПоКлиентам КАК ТаблицаПосещений_1
			               |		ПО ТаблицаПосещенийПоКлиентам.ДатаПосещения >= ТаблицаПосещений_1.ДатаПосещения
			               |			И ТаблицаПосещенийПоКлиентам.Клиент = ТаблицаПосещений_1.Клиент
			               |
			               |СГРУППИРОВАТЬ ПО
			               |	ТаблицаПосещенийПоКлиентам.СтруктурнаяЕдиница,
			               |	ТаблицаПосещенийПоКлиентам.ДатаПосещения,
			               |	ТаблицаПосещенийПоКлиентам.Посещение,
			               |	ТаблицаПосещенийПоКлиентам.Клиент,
			               |	ТаблицаПосещенийПоКлиентам.Основание
			               |
			               |ИМЕЮЩИЕ
			               |	КОЛИЧЕСТВО(ТаблицаПосещений_1.Посещение) = &ПараметрНомерПосещения И
			               |	НАЧАЛОПЕРИОДА(ТаблицаПосещенийПоКлиентам.ДатаПосещения, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	ИтоговаяТаблицаПосещений.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	ИтоговаяТаблицаПосещений.ДатаПосещения КАК ДатаПосещения,
			               |	ИтоговаяТаблицаПосещений.Посещение КАК Посещение,
			               |	ИтоговаяТаблицаПосещений.Клиент КАК Контрагент,
			               |	ИтоговаяТаблицаПосещений.Посещение КАК ОбъектСобытия,
			               |	ИтоговаяТаблицаПосещений.Основание КАК Основание,
			               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
			               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
			               |ИЗ
			               |	ИтоговаяТаблицаПосещений КАК ИтоговаяТаблицаПосещений";
			
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент В(&СегментКонтрагентов)",
			"Посещение.Контрагент В
			|			(ВЫБРАТЬ
			|				СоставСегментов.ОбъектСегмента
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
#КонецОбласти
		
	КонецЕсли;

	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события непосещение клиники
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//  ОбъектСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_НепосещениеКлиники(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
//	1. Не отправляются потому что триггер не нашел необходимые данные для регистрации на текущий период.
//	2. Логика поиска триггером данных:
//	2.1 посещения проведены, не отменены
//	2.2 триггер ищет день в день (отчет показывает равно или более)
//	2.3 триггер анализирует посещения по ЧПУ и по Реализациям (посещения с пустым основанием отсеиваются)
//	2.4 триггер анализирует посещения в разрезе ЧПУ/Посещения по нему (с 31.08.2020 исключен данный пункт из логики!!!)
//	2.5 все ЧПУ попавшие в выборку после проверки пункта 2.4 должны иметь статус "Активен" на текущий момент (иначе отсеиваются) 
//
//	Повторюсь: Анализируем "не посещение" по каждому ЧПУ (в разрезе) а не общее. (с 31.08.2020 исключен данный пункт из логики!!!)
//				Если ЧПУ закрыто на момент отработки триггера - не имеет смысл информировать клиента о его "Не хождении".

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		
#КонецОбласти
		 
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТекущаяДата"			, НачалоДня(ТекущаяДатаСеанса()));
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	Посещение.ДатаПрихода КАК ДатаПрихода,
		               |	Посещение.Ссылка КАК Посещение,
		               |	ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) КАК Контрагент,
		               |	ВЫРАЗИТЬ(Посещение.Основание КАК Документ.ЧленствоПакетУслуг) КАК Основание,
		               |	Посещение.Основание.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		               |ПОМЕСТИТЬ ТаблицаПредположительныхПосещенийПоЧленствам
		               |ИЗ
		               |	Документ.Посещение КАК Посещение
		               |ГДЕ
		               |	Посещение.Проведен = ИСТИНА
		               |	И Посещение.ПризнакОтменен = ЛОЖЬ
		               |	И Посещение.Контрагент В(&СегментКонтрагентов)
		               |	И НЕ ВЫРАЗИТЬ(Посещение.Основание КАК Документ.ЧленствоПакетУслуг) ЕСТЬ NULL
		               |	И НАЧАЛОПЕРИОДА(Посещение.ДатаПрихода, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |	И ВЫБОР
		               |			КОГДА НЕ ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |				ТОГДА ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты).ОбезличенныйКлиент = ЛОЖЬ
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ
		               |	И Посещение.Контрагент.ПометкаУдаления = ЛОЖЬ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЧленстваПакетыУслугИтоги.ДатаАктивации КАК ДатаАктивации,
		               |	ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг,
		               |	ВЫРАЗИТЬ(ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг.Контрагент КАК Справочник.Контрагенты) КАК Контрагент
		               |ПОМЕСТИТЬ ТаблицаАктивныхЧленствПакетовУслуг
		               |ИЗ
		               |	РегистрСведений.ЧленстваПакетыУслугИтоги КАК ЧленстваПакетыУслугИтоги
		               |ГДЕ
		               |	ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг В
		               |			(ВЫБРАТЬ
		               |				ТаблицаПредположительныхПосещенийПоЧленствам.Основание
		               |			ИЗ
		               |				ТаблицаПредположительныхПосещенийПоЧленствам)
		               |	И ЧленстваПакетыУслугИтоги.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧленствПакетовУслуг.Активен)
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ
		               |	ЧленстваПакетыУслугИтоги.ДатаАктивации,
		               |	ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг,
		               |	ВЫРАЗИТЬ(ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг.Контрагент КАК Справочник.Контрагенты)
		               |ИЗ
		               |	РегистрСведений.ЧленстваПакетыУслугИтоги КАК ЧленстваПакетыУслугИтоги
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПредположительныхПосещенийПоЧленствам КАК ТаблицаПредположительныхПосещенийПоЧленствам
		               |		ПО ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг = ТаблицаПредположительныхПосещенийПоЧленствам.Основание
		               |ГДЕ
		               |	НАЧАЛОПЕРИОДА(ЧленстваПакетыУслугИтоги.ДатаАктивации, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |	И ЧленстваПакетыУслугИтоги.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧленствПакетовУслуг.Активен)
		               |	И ТаблицаПредположительныхПосещенийПоЧленствам.Основание ЕСТЬ NULL
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ЧленстваПакетыУслугИтоги.ДатаАктивации,
		               |	ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг,
		               |	ВЫРАЗИТЬ(ЧленстваПакетыУслугИтоги.ЧленствоПакетУслуг.Контрагент КАК Справочник.Контрагенты)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаПредположительныхПосещенийПоЧленствам.ДатаПрихода КАК ДатаПрихода,
		               |	ТаблицаПредположительныхПосещенийПоЧленствам.Посещение КАК Посещение,
		               |	ТаблицаПредположительныхПосещенийПоЧленствам.Контрагент КАК Контрагент,
		               |	ВЫРАЗИТЬ(ТаблицаПредположительныхПосещенийПоЧленствам.Основание КАК Документ.ЧленствоПакетУслуг) КАК Основание,
		               |	ТаблицаПредположительныхПосещенийПоЧленствам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		               |ПОМЕСТИТЬ ТаблицаПредположительноАктуальныхПосещенийПоЧленствам
		               |ИЗ
		               |	ТаблицаПредположительныхПосещенийПоЧленствам КАК ТаблицаПредположительныхПосещенийПоЧленствам
		               |ГДЕ
		               |	ТаблицаПредположительныхПосещенийПоЧленствам.Основание В
		               |			(ВЫБРАТЬ
		               |				ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг
		               |			ИЗ
		               |				ТаблицаАктивныхЧленствПакетовУслуг)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.ДатаПрихода КАК ДатаПрихода,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.Посещение КАК Посещение,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.Контрагент КАК Контрагент,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.Основание КАК Основание,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		               |ПОМЕСТИТЬ ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента
		               |ИЗ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам КАК ТаблицаПредположительноАктуальныхПосещенийПоЧленствам
		               |ГДЕ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.Контрагент = ТаблицаПредположительноАктуальныхПосещенийПоЧленствам.Основание.Контрагент
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	Посещение.ДатаПрихода КАК ДатаПрихода,
		               |	Посещение.Ссылка КАК Посещение,
		               |	ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) КАК Контрагент,
		               |	ВЫРАЗИТЬ(Посещение.Основание КАК Документ.Реализация) КАК Основание,
		               |	Посещение.Основание.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		               |ПОМЕСТИТЬ ТаблицаПредположительноАктуальныхПосещенийПоРеализациям
		               |ИЗ
		               |	Документ.Посещение КАК Посещение
		               |ГДЕ
		               |	Посещение.Проведен = ИСТИНА
		               |	И Посещение.ПризнакОтменен = ЛОЖЬ
		               |	И Посещение.Контрагент В(&СегментКонтрагентов)
		               |	И Посещение.Основание ССЫЛКА Документ.Реализация
		               |	И НАЧАЛОПЕРИОДА(Посещение.ДатаПрихода, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |	И ВЫБОР
		               |			КОГДА НЕ ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |				ТОГДА ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты).ОбезличенныйКлиент = ЛОЖЬ
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента.ДатаПрихода КАК ДатаПрихода,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента.Посещение КАК Посещение,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента.Контрагент КАК Контрагент,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента.Основание КАК Основание,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		               |ПОМЕСТИТЬ ТаблицаАктуальныхПосещений
		               |ИЗ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента КАК ТаблицаПредположительноАктуальныхПосещенийПоЧленствамКонтрагента
		               |
		               |ОБЪЕДИНИТЬ ВСЕ
		               |
		               |ВЫБРАТЬ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоРеализациям.ДатаПрихода,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоРеализациям.Посещение,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоРеализациям.Контрагент,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоРеализациям.Основание,
		               |	ТаблицаПредположительноАктуальныхПосещенийПоРеализациям.СтруктурнаяЕдиница
		               |ИЗ
		               |	ТаблицаПредположительноАктуальныхПосещенийПоРеализациям КАК ТаблицаПредположительноАктуальныхПосещенийПоРеализациям
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	МАКСИМУМ(Посещение.ДатаПрихода) КАК ДатаПрихода,
		               |	ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты) КАК Контрагент
		               |ПОМЕСТИТЬ ТаблицаПоследнихПосещений
		               |ИЗ
		               |	Документ.Посещение КАК Посещение
		               |ГДЕ
		               |	Посещение.Проведен = ИСТИНА
		               |	И Посещение.ПризнакОтменен = ЛОЖЬ
		               |	И Посещение.Контрагент В
		               |			(ВЫБРАТЬ
		               |				ТаблицаАктуальныхПосещений.Контрагент
		               |			ИЗ
		               |				ТаблицаАктуальныхПосещений
		               |		
		               |			ОБЪЕДИНИТЬ
		               |		
		               |			ВЫБРАТЬ
		               |				ТаблицаАктивныхЧленствПакетовУслуг.Контрагент
		               |			ИЗ
		               |				ТаблицаАктивныхЧленствПакетовУслуг)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВЫРАЗИТЬ(Посещение.Контрагент КАК Справочник.Контрагенты)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаАктуальныхПосещений.ДатаПрихода КАК ДатаПрихода,
		               |	ТаблицаАктуальныхПосещений.Посещение КАК Посещение,
		               |	ТаблицаАктуальныхПосещений.Контрагент КАК Контрагент,
		               |	ТаблицаАктуальныхПосещений.Основание КАК ОбъектСобытия,
		               |	ТаблицаАктуальныхПосещений.Основание КАК Основание,
		               |	ТаблицаАктуальныхПосещений.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаАктуальныхПосещений КАК ТаблицаАктуальныхПосещений
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПоследнихПосещений КАК ТаблицаПоследнихПосещений
		               |		ПО ТаблицаАктуальныхПосещений.Контрагент = ТаблицаПоследнихПосещений.Контрагент
		               |			И ТаблицаАктуальныхПосещений.ДатаПрихода = ТаблицаПоследнихПосещений.ДатаПрихода
		               |
		               |ОБЪЕДИНИТЬ
		               |
		               |ВЫБРАТЬ
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ДатаАктивации,
		               |	ЗНАЧЕНИЕ(Документ.Посещение.ПустаяСсылка),
		               |	ТаблицаАктивныхЧленствПакетовУслуг.Контрагент,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг.СтруктурнаяЕдиница,
		               |	&РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаАктивныхЧленствПакетовУслуг КАК ТаблицаАктивныхЧленствПакетовУслуг
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Посещение КАК Посещение
		               |		ПО ТаблицаАктивныхЧленствПакетовУслуг.Контрагент = Посещение.Контрагент
		               |			И ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг = Посещение.Основание
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПоследнихПосещений КАК ТаблицаПоследнихПосещений
		               |		ПО ТаблицаАктивныхЧленствПакетовУслуг.Контрагент = ТаблицаПоследнихПосещений.Контрагент
		               |			И ТаблицаАктивныхЧленствПакетовУслуг.ДатаАктивации <= ТаблицаПоследнихПосещений.ДатаПрихода
		               |ГДЕ
		               |	Посещение.Ссылка ЕСТЬ NULL
		               |	И ТаблицаПоследнихПосещений.Контрагент ЕСТЬ NULL
		               |	И НАЧАЛОПЕРИОДА(ТаблицаАктивныхЧленствПакетовУслуг.ДатаАктивации, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ДатаАктивации,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.Контрагент,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг.СтруктурнаяЕдиница,
		               |	ТаблицаАктивныхЧленствПакетовУслуг.ЧленствоПакетУслуг";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент В(&СегментКонтрагентов)",
			"Посещение.Контрагент В
			|			(ВЫБРАТЬ
			|				СоставСегментов.ОбъектСегмента
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Посещение.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
				
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события потенциальный не стал клиентом
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//  ОбъектСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПотенциальныйНеСталНовым(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		
#КонецОбласти
		 
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ТриггерноеСобытие"		, ДанныеТриггера.ТриггерноеСобытие);
		Запрос.УстановитьПараметр("ДатаТриггера"			, ПолучитьДатуТриггера(ДанныеТриггера));
		// Запрос.УстановитьПараметр("ТекущаяДата"				, НачалоДня(ТекущаяДатаСеанса()));
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда
			Запрос.УстановитьПараметр("СегментКонтрагентов"	, ДанныеТриггера.СегментКонтрагентов);			
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
			               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент
			               |ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
			               |ИЗ
			               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
			               |ГДЕ
			               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
			               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
			               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК ОбъектСобытия,
			               |	СтатусыКонтрагентовСрезПоследних.Контрагент.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
			               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
			               |ИЗ
			               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
			               |			,
			               |			Контрагент.ПометкаУдаления = ЛОЖЬ
			               |				И Контрагент.ОбезличенныйКлиент = ЛОЖЬ
			               |				И НЕ Контрагент В
			               |						(ВЫБРАТЬ
			               |							ТаблицаОтработанныхКонтрагентов.Контрагент
			               |						ИЗ
			               |							ТаблицаОтработанныхКонтрагентов)
			               |				И Контрагент В
			               |					(ВЫБРАТЬ
			               |						ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты)
			               |					ИЗ
			               |						РегистрСведений.СоставСегментов КАК СоставСегментов
			               |					ГДЕ
			               |						СоставСегментов.Сегмент = &СегментКонтрагентов
			               |						И НЕ ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты) ЕСТЬ NULL)) КАК СтатусыКонтрагентовСрезПоследних
			               |ГДЕ
			               |	НАЧАЛОПЕРИОДА(СтатусыКонтрагентовСрезПоследних.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
			               |	И СтатусыКонтрагентовСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный)";
			
		Иначе 
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
			               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент
			               |ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
			               |ИЗ
			               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
			               |ГДЕ
			               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
			               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ
			               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
			               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК ОбъектСобытия,
			               |	СтатусыКонтрагентовСрезПоследних.Контрагент.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
			               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
			               |ИЗ
			               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
			               |			,
			               |			Контрагент.ПометкаУдаления = ЛОЖЬ
			               |				И Контрагент.ОбезличенныйКлиент = ЛОЖЬ
			               |				И НЕ Контрагент В
			               |						(ВЫБРАТЬ
			               |							ТаблицаОтработанныхКонтрагентов.Контрагент
			               |						ИЗ
			               |							ТаблицаОтработанныхКонтрагентов)) КАК СтатусыКонтрагентовСрезПоследних
			               |ГДЕ
			               |	НАЧАЛОПЕРИОДА(СтатусыКонтрагентовСрезПоследних.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
			               |	И СтатусыКонтрагентовСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный)";
		КонецЕсли;	
		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события пациент окончание срока действия страхового полиса
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПациентОкончаниеСрокаДействияСтраховогоПолиса(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПолисыМедицинскогоСтрахования.Ссылка КАК ОбъектСобытия,
		|	ПолисыМедицинскогоСтрахования.Контрагент КАК Контрагент,
		|	ПолисыМедицинскогоСтрахования.ТипПолиса КАК ТипПолиса,
		|	ПолисыМедицинскогоСтрахования.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ПолисыМедицинскогоСтрахования.СерияПолиса КАК СерияПолиса,
		|	ПолисыМедицинскогоСтрахования.НомерПолиса КАК НомерПолиса,
		|	ПолисыМедицинскогоСтрахования.ЛимитПолиса КАК ЛимитПолиса,
		|	ПолисыМедицинскогоСтрахования.ДанаНачала КАК ДатаВыдачи,
		|	ПолисыМедицинскогоСтрахования.ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ТаблицаПациентовСИстекающимиПолисами
		|ИЗ
		|	Справочник.ПолисыМедицинскогоСтрахования КАК ПолисыМедицинскогоСтрахования
		|ГДЕ
		|	НАЧАЛОПЕРИОДА(ПолисыМедицинскогоСтрахования.ДатаОкончания, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПациентовСИстекающимиПолисами.Контрагент КАК Контрагент,
		|	ТаблицаПациентовСИстекающимиПолисами.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаПациентовСИстекающимиПолисами.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ТаблицаПациентовСИстекающимиПолисами.СерияПолиса КАК СерияПолиса,
		|	ТаблицаПациентовСИстекающимиПолисами.НомерПолиса КАК НомерПолиса,
		|	ТаблицаПациентовСИстекающимиПолисами.ЛимитПолиса КАК ЛимитПолиса,
		|	ТаблицаПациентовСИстекающимиПолисами.ДатаВыдачи КАК ДатаВыдачи,
		|	ТаблицаПациентовСИстекающимиПолисами.ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ТаблицаПациентовСИстекающимиПолисамиФильтрация
		|ИЗ
		|	ТаблицаПациентовСИстекающимиПолисами КАК ТаблицаПациентовСИстекающимиПолисами
		|ГДЕ
		|	ТаблицаПациентовСИстекающимиПолисами.Контрагент В(&СегментКонтрагентов)
		|	И ТаблицаПациентовСИстекающимиПолисами.ТипПолиса = &ТипПолиса
		|	И ТаблицаПациентовСИстекающимиПолисами.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
		|	И ТаблицаПациентовСИстекающимиПолисами.Контрагент.ПометкаУдаления = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.Контрагент КАК Контрагент,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.СерияПолиса КАК СерияПолиса,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.НомерПолиса КАК НомерПолиса,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.ЛимитПолиса КАК ЛимитПолиса,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.ДатаВыдачи КАК ДатаВыдачи,
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация.ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ТаблицаНеОтработнныхИстекающихПолисов
		|ИЗ
		|	ТаблицаПациентовСИстекающимиПолисамиФильтрация КАК ТаблицаПациентовСИстекающимиПолисамиФильтрация
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ТаблицаПациентовСИстекающимиПолисамиФильтрация.Контрагент = ЖурналРегистрацииТриггерныхСобытий.Контрагент
		|			И ТаблицаПациентовСИстекающимиПолисамиФильтрация.ОбъектСобытия = ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		|ГДЕ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНеОтработнныхИстекающихПолисов.Контрагент КАК Контрагент,
		|	ТаблицаНеОтработнныхИстекающихПолисов.ОбъектСобытия КАК ОбъектСобытия,
		|	ТаблицаНеОтработнныхИстекающихПолисов.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ТаблицаНеОтработнныхИстекающихПолисов.СерияПолиса КАК СерияПолиса,
		|	ТаблицаНеОтработнныхИстекающихПолисов.НомерПолиса КАК НомерПолиса,
		|	ТаблицаНеОтработнныхИстекающихПолисов.ЛимитПолиса КАК ЛимитПолиса,
		|	ТаблицаНеОтработнныхИстекающихПолисов.ДатаВыдачи КАК ДатаВыдачи,
		|	ТаблицаНеОтработнныхИстекающихПолисов.ДатаОкончания КАК ДатаОкончания,
		|	ТаблицаНеОтработнныхИстекающихПолисов.Контрагент.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаНеОтработнныхИстекающихПолисов КАК ТаблицаНеОтработнныхИстекающихПолисов";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаПациентовСИстекающимиПолисами.Контрагент В(&СегментКонтрагентов)",
		"ТаблицаПациентовСИстекающимиПолисами.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаПациентовСИстекающимиПолисами.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ТипПолиса) Тогда
			Запрос.УстановитьПараметр("ТипПолиса", ДанныеТриггера.ТипПолиса);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаПациентовСИстекающимиПолисами.ТипПолиса = &ТипПолиса", "ИСТИНА");
		КонецЕсли;
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
		
#КонецОбласти
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события установка карты wallet новому клиенту
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_УстановкаКартыWalletНовомуКлиенту(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
		
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		Запрос.УстановитьПараметр("ТриггерноеСобытие"		, ДанныеТриггера.ТриггерноеСобытие);		
		Запрос.УстановитьПараметр("Карта"					, ОбъектСобытия);
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	Карты.ВладелецКарты КАК Контрагент,
		               |	Карты.Ссылка КАК ОбъектСобытия,
		               |	Карты.ВладелецКарты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ТаблицаКонтрагентов
		               |ИЗ
		               |	Справочник.Карты КАК Карты
		               |ГДЕ
		               |	Карты.Ссылка = &Карта
		               |	И Карты.ВладелецКарты В(&СегментКонтрагентов)
		               |	И Карты.ПометкаУдаления = ЛОЖЬ
		               |	И Карты.Заблокирована = ЛОЖЬ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Карты.Ссылка,
		               |	Карты.ВладелецКарты,
		               |	Карты.ВладелецКарты.СтруктурнаяЕдиница
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент
		               |ПОМЕСТИТЬ РеестрОтработанных
		               |ИЗ
		               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |ГДЕ
		               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент В
		               |			(ВЫБРАТЬ
		               |				ТаблицаКонтрагентов.Контрагент
		               |			ИЗ
		               |				ТаблицаКонтрагентов)
		               |	И ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия = &Карта
		               |	И ЖурналРегистрацииТриггерныхСобытий.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаКонтрагентов.Контрагент КАК Контрагент,
		               |	ТаблицаКонтрагентов.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаКонтрагентов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ТаблицаКонтрагентов.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ТаблицаКонтрагентов.РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаКонтрагентов КАК ТаблицаКонтрагентов
		               |ГДЕ
		               |	НЕ ТаблицаКонтрагентов.Контрагент В
		               |				(ВЫБРАТЬ
		               |					РеестрОтработанных.Контрагент
		               |				ИЗ
		               |					РеестрОтработанных)";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Карты.ВладелецКарты В(&СегментКонтрагентов)",
			"Карты.ВладелецКарты В
			|			(ВЫБРАТЬ
			|				СоставСегментов.ОбъектСегмента
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Карты.ВладелецКарты В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
				
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		
