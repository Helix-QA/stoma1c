&НаКлиенте
Процедура ОткрытьФормуВыбораРеквизита(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	// СтандартнаяОбработка = Ложь;
	
	Элемент = Элементы.КомпоновщикНастроекНастройкиОтбор;
	
	ТекСтрока = Элемент.ТекущиеДанные;
	ТекПоле = Элемент.ТекущийЭлемент;
	ВыбПоле = ТекСтрока.ЛевоеЗначение;
	
	Если ТекПоле.Имя = "КомпоновщикНастроекНастройкиОтборПравоеЗначение" И Лев(Строка(ВыбПоле), 12) = "ДопРеквизиты" Тогда
		СтандартнаяОбработка = Ложь;
		ИскПоле = КомпоновщикНастроек.Настройки.ДоступныеПоляОтбора.НайтиПоле(ВыбПоле);
		Если ИскПоле <> Неопределено И Строка(ИскПоле.ТипЗначения) = "Значения свойств объектов" Тогда
			ПараметрРевизит = КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти("Свойство" + Сред(ВыбПоле, 14));
			ПараметрРевизит = ?(ПараметрРевизит <> Неопределено, ПараметрРевизит.Значение, Неопределено);
			Параметр = Новый Структура("Владелец", ПараметрРевизит);
			ПараметрОтбор = Новый Структура("Отбор", Параметр);
		   	ВыбЗначение = Неопределено;
			ОткрытьФорму("Справочник.ЗначенияСвойствОбъектов.Форма.ФормаВыбора" , ПараметрОтбор,,,,, Новый ОписаниеОповещения("ОткрытьФормуВыбораРеквизитаЗавершение", ЭтотОбъект, Новый Структура("ВыбПоле", ВыбПоле)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
			
		КонецЕсли;
	КонецЕсли;		
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораРеквизитаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ВыбПоле = ДополнительныеПараметры.ВыбПоле;
	
	
	ВыбЗначение = Результат;
	
	Для Каждого ЭлементОтбора Из КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		
		Если ЭлементОтбора.ЛевоеЗначение = ВыбПоле И ВыбЗначение <> Неопределено Тогда						
			ЭлементОтбора.ПравоеЗначение = ВыбЗначение;
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры 

#КонецОбласти