// Процедура - устанавливает доступность кнопки "НапечататьЧек".
//
Процедура УстановитьДоступностьПечатиЧека()
	
	Разрешено = Ложь;
	
	Если НЕ ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда		
		Если Объект.ВидОперации  = Перечисления.ВидыОпераций.ОплатаОтКлиента 
			ИЛИ Объект.ВидОперации  = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета
			ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту
			ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия Тогда
			Разрешено = Истина;
		ИначеЕсли Объект.ВидОперации  = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту
			ИЛИ (Объект.ВидОперации    = Перечисления.ВидыОпераций.ВозвратОплатыСтраховойКомпании
			  И Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные) Тогда
			
			Разрешено = Ложь;
			Для Каждого СтрокаТЧ ИЗ Объект.РасшифровкаПлатежа Цикл			
				Если ЗначениеЗаполнено(СтрокаТЧ.ДокументОснования) И НЕ НачалоДня(СтрокаТЧ.ДокументОснования.Дата) = НачалоДня(Объект.Дата) Тогда
					Разрешено = Ложь;
					Прервать;
				Иначе
					Разрешено = Истина;
				КонецЕсли;	
			КонецЦикла;
		Иначе
			Разрешено = Ложь;
		КонецЕсли;     
	КонецЕсли;
	Элементы.НапечататьЧек.Доступность = (Разрешено И Не Объект.Касса.ИспользоватьБезПодключенияОборудования);
		
КонецПроцедуры 

