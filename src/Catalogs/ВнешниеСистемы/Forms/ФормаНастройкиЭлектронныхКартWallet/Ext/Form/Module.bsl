// Процедура, заполняет виды карт.
//
Процедура ЗаполнитьВидыКарт(ВидыКартWallet)
	
	ВидыКарт.Очистить();
	
	Для Каждого ВидКарты Из ВидыКартWallet Цикл
		ВидыКарт.Добавить(ВидКарты.id, ВидКарты.name);  
	КонецЦикла;
	
КонецПроцедуры

// Функция, выполняет синхронизацию видов карт.
//
Функция ПроверитьПодключениеИПолучитьВидыКартWallet()
	
	СтруктураВозврата = ПолучитьСтруктуруВозврата();
	
	Попытка
		
		Соединение = Новый HTTPСоединение(ЭтотОбъект.АдресAPI,,,,,,Новый ЗащищенноеСоединениеOpenSSL()); 
		Заголовки  = Новый Соответствие;    
		Заголовки.Вставить("X-Client-Id"    , Объект.ТокенДоступа);
		Заголовки.Вставить("X-Client-Secret", Объект.КлючШифрования);
		ЗапросНаПолучениеСпискаКарт = Новый HTTPЗапрос("/v1/projects", Заголовки); 
		Результат = Соединение.Получить(ЗапросНаПолучениеСпискаКарт);          
		
	Исключение
		
		СтруктураВозврата.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат СтруктураВозврата;  
		
	КонецПопытки;
	
	ПараметрыJson = РазобратьJson(Результат);
	
	Если Результат.КодСостояния = 200 Тогда  
		
		СтруктураВозврата.Успешно  = Истина;
		СтруктураВозврата.ВидыКарт = ПараметрыJson.data;
		
		Возврат СтруктураВозврата;  
		
	Иначе
		
		СтруктураВозврата.ОписаниеОшибки = "Ошибка подключения: " + ПараметрыJson.error.message;
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;  
	
КонецФункции

// Функция, возвращает структуру возврата.
//
Функция ПолучитьСтруктуруВозврата()
	
	Возврат Новый Структура("Успешно, ВидыКарт, ОписаниеОшибки", Ложь);
	
КонецФункции

// Функция - Разобрать json
//
// Параметры:
//  РезультатЗапроса -    - 
// 
// Возвращаемое значение:
//   - 
//
Функция РазобратьJson(РезультатЗапроса)
	
	ТекстJSON  = РезультатЗапроса.ПолучитьТелоКакСтроку();  
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);
	
	Возврат ПараметрыJSON;
	
КонецФункции

&НаСервере
// Процедура, создает динамические элементы видов карт.
//
Процедура ВывестиВидыКартWallet(ВидыКарт)
	
	УправлениеИнтерфейсамиСервер.УдалитьПодчиненныеЭлементыГруппы(ЭтаФорма, Элементы.ГруппаВидыКартОбщая, Элементы.ГруппаВидыКартСтрока_Шаблон); 
	
	Родитель = Неопределено;
	
	ВидыКарт.Добавить("КнопкаДобавить", "Добавить вид карты");
	
	Для Индекс = 0 По ВидыКарт.Количество() - 1 Цикл
		
		ОстатокОтДеления = Индекс % 7; // по 7 элементов в строке
		
		Если ОстатокОтДеления = 0 Или Родитель = Неопределено Тогда
			Родитель = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(ЭтаФорма, Элементы.ГруппаВидыКартСтрока_Шаблон, Индекс, Элементы.ГруппаВидыКартОбщая);
		КонецЕсли;
		
		ИдПроекта = ВидыКарт[Индекс].Значение;
		
		КоличествоКарт = ?(ИдПроекта = "КнопкаДобавить", Неопределено, КоличествоКартПроекта(ИдПроекта));
		
		Если Не ЗначениеЗаполнено(КоличествоКарт) Тогда
			ЗаголовокКнопки = ВидыКарт[Индекс].Представление;
		Иначе
			ЗаголовокКнопки = ВидыКарт[Индекс].Представление + СтрШаблон(" (%1)", ПолучитьСклоненияСтрокиПоЧислу("карта", КоличествоКарт, "", "ЧС=Количественное", "ПД=Именительный")[0]);
		КонецЕсли;
		
		НоваяГруппа = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(ЭтаФорма, Элементы.ГруппаВидКарты_Шаблон, ИдПроекта, Родитель);
		НоваяКнопка = УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(ЭтаФорма, Элементы.РедактироватьВидКарты_Шаблон, ИдПроекта, НоваяГруппа,, ЗаголовокКнопки, Ложь);   
		
		Если ИдПроекта = "КнопкаДобавить" Тогда
			
			НоваяКнопка.Отображение = ОтображениеКнопки.КартинкаИТекст;
			НоваяКнопка.Картинка    = БиблиотекаКартинок.СоздатьЭлементСписка; 
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция, возвращает количество карт в разрезе проекта.
//
Функция КоличествоКартПроекта(ИдПроекта)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|  КОЛИЧЕСТВО(Карты.Ссылка) КАК Количество
	|ИЗ
	|  Справочник.Карты КАК Карты
	|ГДЕ
	|  НЕ Карты.ПометкаУдаления
	|  И НЕ Карты.Заблокирована
	|  И Карты.ВидКарты.ИдентификаторПроекта = &ИдентификаторПроекта");
	
	Запрос.УстановитьПараметр("ИдентификаторПроекта", ИдПроекта); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Количество, 0);
	
КонецФункции

