		ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
		ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
		ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
		ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаКнопкиВидаСделки);		
		
		КнопкаВидвСделки = УправлениеИнтерфейсамиСервер.СоздатьЭлементКнопка(ЭтаФорма, ПараметрыКнопки);
		КнопкаВидвСделки.РастягиватьПоГоризонтали 	= Истина;	 
		//КнопкаЭтапа.АвтоМаксимальнаяШирина 		= Ложь;	 
		//КнопкаЭтапа.МаксимальнаяШирина 			= 24;	 
		
		Если СтрокаТЗ.ТаблицаЭтапов.Количество() > 0 Тогда 
			ЦветЭтапа = СтрокаТЗ.ТаблицаЭтапов[0].ЦветЭтапа;
		Иначе 
			ЦветЭтапа = Новый Цвет(0,112,210);
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ЦветЭтапа)
			ИЛИ ЗначениеИзСтрокиВнутр(ЦветЭтапа) = Новый Цвет()
			ИЛИ НЕ СтрокаТЗ.Выбран Тогда
			
			Цвет = Новый Цвет(243, 243, 243);
		Иначе		
			Цвет = ЗначениеИзСтрокиВнутр(ЦветЭтапа);
