// Процедура возвращает сумму запланированных оплат пациента
//
Функция ВернутьЗапланированныеОплаты(Контрагент = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланыЛечения.Период КАК Период,
	|	ПланыЛечения.Регистратор КАК Документ,
	|	ПланыЛечения.Регистратор.Сотрудник КАК Сотрудник,
	|	ПланыЛечения.Контрагент КАК Контрагент,
	|	ПланыЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СУММА(ПланыЛечения.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ТаблицаПланируемыеОплаты
	|ИЗ
	|	РегистрНакопления.ПланыЛечения КАК ПланыЛечения
	|ГДЕ
	|	ПланыЛечения.Контрагент = &Контрагент
	|	И ПланыЛечения.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И ВЫБОР
	|			КОГДА ПланыЛечения.Регистратор ССЫЛКА Документ.ПланЛечения
	|				ТОГДА ПланыЛечения.Регистратор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Принят)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланыЛечения.Регистратор,
	|	ПланыЛечения.Контрагент,
	|	ПланыЛечения.Период,
	|	ПланыЛечения.СтруктурнаяЕдиница,
	|	ПланыЛечения.Регистратор.Сотрудник
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НарядЗаказЗапасы.Ссылка.Дата,
	|	НарядЗаказЗапасы.Ссылка,
	|	НарядЗаказЗапасы.Ссылка.Сотрудник,
	|	НарядЗаказЗапасы.Ссылка.Контрагент,
	|	НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница,
	|	СУММА(НарядЗаказЗапасы.СуммаПродажи)
	|ИЗ
	|	Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
	|ГДЕ
	|	НарядЗаказЗапасы.Ссылка.Контрагент = &Контрагент
	|	И НарядЗаказЗапасы.Ссылка.Проведен
	|	И НЕ НарядЗаказЗапасы.Ссылка.ПометкаУдаления
	|	И НарядЗаказЗапасы.ПланЛечения = ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	НарядЗаказЗапасы.Ссылка,
	|	НарядЗаказЗапасы.Ссылка.Контрагент,
	|	НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница,
	|	НарядЗаказЗапасы.Ссылка.Дата,
	|	НарядЗаказЗапасы.Ссылка.Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВзаиморасчетыСКонтрагентами.Контрагент КАК Контрагент,
	|	ВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВзаиморасчетыСКонтрагентами.ДокументАванса.Сотрудник КАК Сотрудник,
	|	ВзаиморасчетыСКонтрагентами.ДокументАванса КАК ДокументАванса,
	|	СУММА(ВзаиморасчетыСКонтрагентами.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ТаблицаФактическиеОплаты
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами КАК ВзаиморасчетыСКонтрагентами
	|ГДЕ
	|	ВзаиморасчетыСКонтрагентами.Контрагент = &Контрагент
	|	И ВзаиморасчетыСКонтрагентами.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И НЕ ВзаиморасчетыСКонтрагентами.ДокументАванса = ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка)
	|	И НЕ ВзаиморасчетыСКонтрагентами.ДокументАванса = ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка)
	|	И НЕ ВзаиморасчетыСКонтрагентами.ДокументАванса = НЕОПРЕДЕЛЕНО
	|	И ВЫБОР
	|			КОГДА ВзаиморасчетыСКонтрагентами.ДокументАванса ССЫЛКА Документ.ПланЛечения
	|				ТОГДА ВзаиморасчетыСКонтрагентами.ДокументАванса.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Принят)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентами.Контрагент,
	|	ВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница,
	|	ВзаиморасчетыСКонтрагентами.ДокументАванса,
	|	ВзаиморасчетыСКонтрагентами.ДокументАванса.Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ТаблицаПланируемыеОплаты.Период, ГОД) КАК Год,
	|	НАЧАЛОПЕРИОДА(ТаблицаПланируемыеОплаты.Период, МЕСЯЦ) КАК Месяц,
	|	НАЧАЛОПЕРИОДА(ТаблицаПланируемыеОплаты.Период, НЕДЕЛЯ) КАК Неделя,
	|	НАЧАЛОПЕРИОДА(ТаблицаПланируемыеОплаты.Период, ДЕНЬ) КАК День,
	|	НАЧАЛОПЕРИОДА(ТаблицаПланируемыеОплаты.Период, КВАРТАЛ) КАК Квартал,
	|	ТаблицаПланируемыеОплаты.Период КАК Период,
	|	ТаблицаПланируемыеОплаты.Документ КАК Документ,
	|	ТаблицаПланируемыеОплаты.Сотрудник КАК Сотрудник,
	|	ТаблицаПланируемыеОплаты.Контрагент КАК Контрагент,
	|	ТаблицаПланируемыеОплаты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СУММА(ТаблицаПланируемыеОплаты.Сумма) КАК СуммаПланируемойОплаты,
	|	СУММА(ЕСТЬNULL(ТаблицаФактическиеОплаты.Сумма, 0)) КАК СуммаФактическойОплаты,
	|	СУММА(ТаблицаПланируемыеОплаты.Сумма - ЕСТЬNULL(ТаблицаФактическиеОплаты.Сумма, 0)) КАК ПланируемыйОстаток
	|ИЗ
	|	ТаблицаПланируемыеОплаты КАК ТаблицаПланируемыеОплаты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаФактическиеОплаты КАК ТаблицаФактическиеОплаты
	|		ПО ТаблицаПланируемыеОплаты.Документ = ТаблицаФактическиеОплаты.ДокументАванса
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаПланируемыеОплаты.Сотрудник,
	|	ТаблицаПланируемыеОплаты.Период,
	|	ТаблицаПланируемыеОплаты.Документ,
	|	ТаблицаПланируемыеОплаты.Контрагент,
	|	ТаблицаПланируемыеОплаты.СтруктурнаяЕдиница";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);  
		
	Таблица = Запрос.Выполнить().Выгрузить();	 
	
	Если Таблица.Количество() > 0 Тогда 
		Возврат Таблица.Итог("ПланируемыйОстаток");
	Иначе 
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Функция возвращает строку только с цифрами
//
Функция ТолькоЦифры(Строка) Экспорт
	
  СтрокаЧисел = "";

   Для Индекс = 1 По СтрДлина(Строка) Цикл
   
      Символ = Сред(Строка, Индекс, 1); // Перебираем все сиволы из нашей строки

      Если КодСимвола(Символ) >= 48 И КодСимвола(Символ) <= 57 Тогда // Код нуля - 48, код 9-ки - 57
         СтрокаЧисел = СтрокаЧисел + Символ;
      КонецЕсли;
   
   КонецЦикла;

   Возврат СтрокаЧисел;	
	
КонецФункции

// Функция  складывает дату и время
//
Функция СложитьДатуИВремя(Дата,Время)Экспорт
	
	Возврат  Дата(Год(Дата),Месяц(Дата),День(Дата)) + ПолучитьВремяВСекундах(Время);	
		
КонецФункции	

// Функция вернет представление времени в секундах
//
Функция ПолучитьВремяВСекундах(Время)Экспорт

     Возврат (ДеньГода(Время)-1)*24*60*60+((Час(Время)*60)*60)+(Минута(Время)*60);
	
 КонецФункции

// Функция ПолучитьЗначениеРеквизита возвращает значение
// реквизита, прочитанного из информационной базы по ссылке на объект.
// 
//  Если доступа к реквизиту нет, возникнет исключение прав доступа.
//  Если необходимо зачитать реквизит независимо от прав текущего пользователя,
//  то следует использовать предварительный переход в привилегированный режим.
// 
// Параметры:
//  Ссылка       - ссылка на объект, - элемент справочника, документ, ...
//  ИмяРеквизита - Строка, например, "Код".
// 
// Возвращаемое значение:
//  Произвольный    - зависит от типа значения прочитанного реквизита.
// 
Функция ПолучитьЗначениеРеквизитаПоПути(Ссылка, ПутьКРеквизиту) Экспорт
	
	Результат = Неопределено;
	Выполнить("Результат = Ссылка." + ПутьКРеквизиту);
	
	Возврат Результат;
	
КонецФункции

