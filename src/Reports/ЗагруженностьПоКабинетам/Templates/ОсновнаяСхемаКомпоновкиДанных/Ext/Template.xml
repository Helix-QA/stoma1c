		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДЕНЬНЕДЕЛИ(ВложенныйЗапрос.Период) КАК ПериодДеньНедели,
	ЧАС(ВложенныйЗапрос.Период) КАК ПериодЧас,
	МЕСЯЦ(ВложенныйЗапрос.Период) КАК ПериодМесяц,
	ВложенныйЗапрос.Клиент КАК Клиент,
	ВложенныйЗапрос.Регистратор,
	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ВложенныйЗапрос.Сотрудник,
	ВложенныйЗапрос.Количество,
	ВложенныйЗапрос.Помещение
ИЗ
	(ВЫБРАТЬ
		ВложенныйЗапрос.Период КАК Период,
		ВложенныйЗапрос.Помещение КАК Помещение,
		ВложенныйЗапрос.Клиент КАК Клиент,
		ВложенныйЗапрос.Регистратор КАК Регистратор,
		ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		ВложенныйЗапрос.Сотрудник КАК Сотрудник,
		1 КАК Количество
	ИЗ
		(ВЫБРАТЬ
			СобытиеУслуги.Ссылка КАК Регистратор,
			ВЫБОР
				КОГДА СобытиеУслуги.Помещение &lt;&gt; ЗНАЧЕНИЕ(Справочник.Помещения.ПустаяСсылка)
					ТОГДА СобытиеУслуги.Помещение
				ИНАЧЕ " Не указано"
			КОНЕЦ КАК Помещение,
			СобытиеУслуги.Сотрудник КАК Сотрудник,
			СобытиеУслуги.Ссылка.Дата КАК Период,
			СобытиеУслуги.Ссылка.Контрагент КАК Клиент,
			СобытиеУслуги.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		ИЗ
			Документ.Событие.Услуги КАК СобытиеУслуги
		
		СГРУППИРОВАТЬ ПО
			СобытиеУслуги.Ссылка,
			СобытиеУслуги.Сотрудник,
			СобытиеУслуги.Ссылка.Дата,
			СобытиеУслуги.Ссылка.Контрагент,
			СобытиеУслуги.Помещение,
			СобытиеУслуги.Ссылка.СтруктурнаяЕдиница) КАК ВложенныйЗапрос) КАК ВложенныйЗапрос
{ГДЕ
	(ВложенныйЗапрос.Период &gt;= &amp;НачалоПериода),
	(ВложенныйЗапрос.Период &lt;= &amp;КонецПериода)}</query>
