// Процедура, выполняет отправку смс сообщения на сайт smsmm.ru.
//  Параметры:
//   ДокументСсылка: ссылка на докумет, который выполняет отправку смс.
//   
Функция ОбработкаСервисаSMSРассылки(СервисSMSРассылкиСсылка, ПоказыватьСообщения = Истина) Экспорт

	// Если Не ЗначениеЗаполнено(СервисSMSРассылкиСсылка) Тогда 
	//	СервисSMSРассылкиСсылка = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	// КонецЕсли;
	
	Если СервисSMSРассылкиСсылка.Пустая() Тогда
		Если ПоказыватьСообщения = Истина Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет доступных обработок сервисов SMS-рассылки");
		КонецЕсли;
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяВнешнейОбработкиСервиса = СервисSMSРассылкиСсылка.ИмяОбработки;
	
	НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(СервисSMSРассылкиСсылка, "ХранилищеОбработки");
	ИмяВнешнейОбработкиСервиса = ВнешниеОбработки.Подключить(НавигационнаяСсылка, , Ложь);
	ОбработкаСервиса = ВнешниеОбработки.Создать(ИмяВнешнейОбработкиСервиса);
	
	ОбработкаСервиса.Пользователь = СервисSMSРассылкиСсылка.Пользователь;
	ОбработкаСервиса.Пароль = СервисSMSРассылкиСсылка.Пароль;
	ОбработкаСервиса.Подпись = СервисSMSРассылкиСсылка.Подпись;	
		                         
	Возврат ОбработкаСервиса;
	
