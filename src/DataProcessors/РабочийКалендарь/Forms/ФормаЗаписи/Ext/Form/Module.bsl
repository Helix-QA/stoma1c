// Процедура - Обработчик диалога выбора действия.
//
// Параметры:
//  Ответ		 - 	 -
//  ДоПараметры	 - 	 -
//
Процедура ОбработчикДиалогаВыбораДействия(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено ИЛИ (ТипЗнч(Результат) = Тип("Строка") И Результат = "Контрагент") Тогда
		Возврат;	
	ИначеЕсли ТипЗнч(Результат) = Тип("Строка") Тогда
		
		#Если ВебКлиент Тогда
			
			Если Результат = "КомандаЗапланироватьВизит" Тогда
				КомандаЗапланироватьВизит(Неопределено);		
			ИначеЕсли Результат = "КомандаУстановитьНеРабочимВременем" Тогда
				КомандаУстановитьНеРабочимВременем(Неопределено);		
			ИначеЕсли Результат = "КомандаУстановитьРабочимВременем" Тогда
				КомандаУстановитьРабочимВременем(Неопределено);		
			ИначеЕсли Результат = "КомандаЗарезервироватьВремя" Тогда
				КомандаЗарезервироватьВремя(Неопределено);		  
			ИначеЕсли Результат = "КомандаЗаписатьИзОчереди" Тогда
				КомандаЗаписатьИзОчереди(Неопределено); 									
			КонецЕсли;
			
		#Иначе
			Выполнить(Результат + "(Ложь)");
		#КонецЕсли
	КонецЕсли;
	
