		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	СправочникНоменклатура.Ссылка КАК Номенклатура,
	ЗапасыОстатки.Партия,
	СправочникНоменклатура.ИспользоватьПартии КАК ХарактеристикиИспользуются,
	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоУпаковокПоДаннымУчета,
	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоПоДаннымУчета
ИЗ
	Справочник.Номенклатура КАК СправочникНоменклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(
				,
				СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиница
					И Склад = &amp;Склад) КАК ЗапасыОстатки
		ПО СправочникНоменклатура.Ссылка = ЗапасыОстатки.Номенклатура
ГДЕ
	СправочникНоменклатура.ЭтоГруппа = ЛОЖЬ
	И СправочникНоменклатура.ТипНоменклатуры &lt;&gt; ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)

СГРУППИРОВАТЬ ПО
	СправочникНоменклатура.Ссылка,
	ЗапасыОстатки.Партия,
	СправочникНоменклатура.ИспользоватьПартии

УПОРЯДОЧИТЬ ПО
	СправочникНоменклатура.Наименование</query>
