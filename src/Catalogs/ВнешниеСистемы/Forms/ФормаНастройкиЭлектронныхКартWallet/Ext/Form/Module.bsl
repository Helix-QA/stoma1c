&НаКлиенте
// Процедура, обновляет настройки wallet.
//
Процедура ОбновитьНастройкиWallet(ПодключениеВнешнейСистемы = Ложь)
	
	ОчиститьСообщения();
	
	ПодключениеУстановлено = Ложь;
	
	АктивныйЭлемент   = Неопределено;
	НеАктивныйЭлемент = Неопределено;
	
	Результат = ОбновитьНастройкиWalletНаСервере(ПодключениеВнешнейСистемы);
	
	Если Результат.Успешно Тогда
		
		Если ЗначениеЗаполнено(Результат.ИдПроекта) 
			Или (ЗначениеЗаполнено(ИдПроектаДляРедактирования) И ВидыКарт.НайтиПоЗначению(ИдПроектаДляРедактирования) <> Неопределено) Тогда
			РедактироватьВидКартыОбработка(, ?(ЗначениеЗаполнено(ИдПроектаДляРедактирования), ИдПроектаДляРедактирования, Результат.ИдПроекта));
		КонецЕсли;
		
	Иначе
		
		Если ЗначениеЗаполнено(Результат.ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);  
		КонецЕсли;
		
	КонецЕсли;
	
	ИдПроекта = ?(Результат.Свойство("ИдПроекта"), Результат.ИдПроекта, Неопределено); 
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.ВидКартыПоУмолчанию) Тогда
		
		ЭтотОбъект.ВидКартыПоУмолчанию = ПолучитьВидКатыПоУмолчанию();				
		ВидКартыПоУмолчаниюПриИзмененииНаСервере(ЭтотОбъект.ВидКартыПоУмолчанию);
		
	КонецЕсли;
	
	Результат.Успешно = Результат.Успешно И ЗначениеЗаполнено(ИдПроекта);
	
	Элементы.ГруппаWalletНастройки.Видимость		 = Не Результат.Успешно;
	Элементы.ГруппаДополнительныеНастройки.Видимость = Результат.Успешно;
	Элементы.РедакторКарты.Видимость				 = Результат.Успешно;
	Элементы.ГруппаДополнительно.Видимость			 = Ложь;
	
	Элементы.ВидКартыПоУмолчанию.СписокВыбора.Очистить();
	Элементы.ВидКартыПоУмолчанию.СписокВыбора.ЗагрузитьЗначения(ПолучитьДоступныеВидыЭлектронныхКарт());

КонецПроцедуры

&НаСервере
// Функция, обновляет настройки wallet на сервере.
//
Функция ОбновитьНастройкиWalletНаСервере(ПодключениеВнешнейСистемы = Ложь)
	
	Если ПустаяСтрока(Объект.ТокенДоступа) Или ПустаяСтрока(Объект.КлючШифрования) Тогда
		Возврат ПолучитьСтруктуруВозврата();  
	КонецЕсли;
	
	Результат = ПроверитьПодключениеИПолучитьВидыКартWallet();
	
	Если Не Результат.Успешно Тогда
		
		УправлениеИнтерфейсамиСервер.УдалитьПодчиненныеЭлементыГруппы(ЭтаФорма, Элементы.ГруппаВидыКартОбщая, Элементы.ГруппаВидыКартСтрока_Шаблон);         
		
	Иначе
		
		ПодключениеУстановлено = Истина;
		
		Если ПодключениеВнешнейСистемы = Истина Тогда
			Константы.ИспользоватьWallet.Установить(Истина);
		КонецЕсли;
		
		ЗаполнитьВидыКарт(Результат.ВидыКарт);
		СинхронизироватьВидыКарт(ВидыКарт);
		ВывестиВидыКартWallet(ВидыКарт);
		
		Результат.Вставить("ИдПроекта", ?(ЗначениеЗаполнено(ВидыКарт) И ВидыКарт[0].Значение <> "КнопкаДобавить", ВидыКарт[0].Значение, Неопределено));
		
		Если Объект.Ссылка.Пустая() Тогда
			Записать();
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
// Процедура, выполняет синхронизацию карт.
//
