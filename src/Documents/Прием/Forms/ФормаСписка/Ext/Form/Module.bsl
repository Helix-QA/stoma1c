// Процедура - Отбор на главной ассистент начало выбора.
//
Процедура ОтборНаГлавнойАссистентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	мПараметрыВыбора = Новый Структура;
	мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", ЭтотОбъект.ОтборНаГлавнойСтрЕдиница);
	мПараметрыВыбора.Вставить("ТекущаяСтрока"     , ЭтотОбъект.ОтборНаГлавнойАссистент);
	мПараметрыВыбора.Вставить("ОтбиратьВрачей"    , Истина); 
	мПараметрыВыбора.Вставить("Сотрудник"		  , ЭтотОбъект.ОтборНаГлавнойСотрудник);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("АссистентНачалоВыбораЗавершение", ЭтаФорма);	
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", мПараметрыВыбора,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

