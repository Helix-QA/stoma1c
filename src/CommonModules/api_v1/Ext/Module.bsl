// Функция проводит аутентификацию приложения
// 
Функция ПроверитьКлючПриложения(ApiKey, ВнешняяСистема = Неопределено, ТипВнешнейСистемы = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(ApiKey) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1062);
	КонецЕсли;
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(ApiKey, ТипВнешнейСистемы);
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1063);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция проводит аутентификацию клиента
// 
Функция ПроверитьКлючКлиента(UserToken, Клиент, НомерТелефона = Неопределено, Пароль = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(UserToken) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1066);
	КонецЕсли;
	
	СтруктураДанных = РегистрыСведений.КлючиВнешнихСистем.ПолучитьДанныеКлючаВнешнейСистемы(UserToken);
	
	Если СтруктураДанных = Неопределено Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1067);
	Иначе		
		Клиент 			= СтруктураДанных.Клиент;
		НомерТелефона	= СтруктураДанных.НомерТелефона;
		Пароль			= СтруктураДанных.Пароль;		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Функция проверяет введенную дату записи
//
Функция ПроверитьДатуЗаписи(ДатаЗаписи)
	
	Если НЕ ЗначениеЗаполнено(ДатаЗаписи) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1061);
	КонецЕсли;
	
	Дата = ПолучитьДату(ДатаЗаписи);
	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Возврат ПолучитьСтруктуруВозвратаОшибки(1054);
	КонецЕсли;
	
	Возврат Новый Структура("ДатаЗаписи", Дата);
	
КонецФункции

// Функция проверяет введенный ИДУслуги
//
Функция ПроверитьИДУслуги(ИДУслуги)
	
