	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ТаблицаНовыхПациентов.Контрагент КАК Контрагент,
	        |	ТаблицаНовыхПациентов.ДатаПриема КАК Дата
	        |ПОМЕСТИТЬ СтатусыКромеПотенциальныхИОтказ
	        |ИЗ
	        |	ТаблицаНовыхПациентов КАК ТаблицаНовыхПациентов
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	ТаблицаПостоянныхПациентов.Контрагент,
	        |	ТаблицаПостоянныхПациентов.ДатаПриема
	        |ИЗ
	        |	ТаблицаПостоянныхПациентов КАК ТаблицаПостоянныхПациентов
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	ТаблицаНеВернувшихсяПациентов.Контрагент,
	        |	ТаблицаНеВернувшихсяПациентов.Дата
	        |ИЗ
	        |	ТаблицаНеВернувшихсяПациентов КАК ТаблицаНеВернувшихсяПациентов
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	СтатусыКромеПотенциальныхИОтказ.Контрагент КАК Контрагент,
	        |	МАКСИМУМ(СтатусыКромеПотенциальныхИОтказ.Дата) КАК Дата
	        |ПОМЕСТИТЬ АктуальныеДатыСтатусовКонтрагентов
	        |ИЗ
	        |	СтатусыКромеПотенциальныхИОтказ КАК СтатусыКромеПотенциальныхИОтказ
	        |
	        |СГРУППИРОВАТЬ ПО
	        |	СтатусыКромеПотенциальныхИОтказ.Контрагент
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	Контрагенты.Ссылка КАК Контрагент,
	        |	Контрагенты.ДатаРегистрации КАК ДатаРегистрации
	        |ПОМЕСТИТЬ ПотенциальныеИОтказ
	        |ИЗ
	        |	Справочник.Контрагенты КАК Контрагенты
	        |ГДЕ
	        |	НЕ Контрагенты.Ссылка В
	        |				(ВЫБРАТЬ
	        |					СтатусыКромеПотенциальныхИОтказ.Контрагент КАК Контрагент
	        |				ИЗ
	        |					СтатусыКромеПотенциальныхИОтказ КАК СтатусыКромеПотенциальныхИОтказ)
	        |	И Контрагенты.ЭтоГруппа = ЛОЖЬ
	        |	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	        |	И Контрагенты.Ссылка = &Контрагент
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ПотенциальныеИОтказ.ДатаРегистрации КАК ДатаРегистрации,
	        |	ПотенциальныеИОтказ.Контрагент КАК Контрагент,
	        |	ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный) КАК Статус
	        |ПОМЕСТИТЬ Потенциальные
	        |ИЗ
	        |	ПотенциальныеИОтказ КАК ПотенциальныеИОтказ
	        |ГДЕ
	        |	НЕ ПотенциальныеИОтказ.Контрагент В
	        |				(ВЫБРАТЬ
	        |					ПоследниеСделкиПациентовСОтказом.Контрагент КАК Контрагент
	        |				ИЗ
	        |					ПоследниеСделкиПациентовСОтказом КАК ПоследниеСделкиПациентовСОтказом)
	        |;
	        |
	        |////////////////////////////////////////////////////////////////////////////////
	        |ВЫБРАТЬ
	        |	ПоследниеСделкиПациентовСОтказом.Контрагент КАК Контрагент,
	        |	ПоследниеСделкиПациентовСОтказом.ДатаПоследнейСделкиНовыйПациент КАК Период,
	        |	ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ) КАК Статус
	        |ИЗ
	        |	ПотенциальныеИОтказ КАК ПотенциальныеИОтказ
	        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоследниеСделкиПациентовСОтказом КАК ПоследниеСделкиПациентовСОтказом
	        |		ПО ПотенциальныеИОтказ.Контрагент = ПоследниеСделкиПациентовСОтказом.Контрагент
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	Потенциальные.Контрагент,
	        |	Потенциальные.ДатаРегистрации,
	        |	Потенциальные.Статус
	        |ИЗ
	        |	Потенциальные КАК Потенциальные
	        |
	        |ОБЪЕДИНИТЬ ВСЕ
	        |
	        |ВЫБРАТЬ
	        |	АктуальныеДатыСтатусовКонтрагентов.Контрагент,
	        |	АктуальныеДатыСтатусовКонтрагентов.Дата,
	        |	ВЫБОР
	        |		КОГДА НЕ ТаблицаНеВернувшихсяПациентов.Статус ЕСТЬ NULL
	        |			ТОГДА ТаблицаНеВернувшихсяПациентов.Статус
	        |		КОГДА НЕ ТаблицаНовыхПациентов.Статус ЕСТЬ NULL
	        |			ТОГДА ТаблицаНовыхПациентов.Статус
	        |		КОГДА НЕ ТаблицаПостоянныхПациентов.Статус ЕСТЬ NULL
	        |			ТОГДА ТаблицаПостоянныхПациентов.Статус
	        |	КОНЕЦ
	        |ИЗ
	        |	АктуальныеДатыСтатусовКонтрагентов КАК АктуальныеДатыСтатусовКонтрагентов
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаНовыхПациентов КАК ТаблицаНовыхПациентов
	        |		ПО АктуальныеДатыСтатусовКонтрагентов.Контрагент = ТаблицаНовыхПациентов.Контрагент
	        |			И АктуальныеДатыСтатусовКонтрагентов.Дата = ТаблицаНовыхПациентов.ДатаПриема
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаПостоянныхПациентов КАК ТаблицаПостоянныхПациентов
	        |		ПО АктуальныеДатыСтатусовКонтрагентов.Контрагент = ТаблицаПостоянныхПациентов.Контрагент
	        |			И АктуальныеДатыСтатусовКонтрагентов.Дата = ТаблицаПостоянныхПациентов.ДатаПриема
	        |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаНеВернувшихсяПациентов КАК ТаблицаНеВернувшихсяПациентов
	        |		ПО АктуальныеДатыСтатусовКонтрагентов.Контрагент = ТаблицаНеВернувшихсяПациентов.Контрагент
	        |			И АктуальныеДатыСтатусовКонтрагентов.Дата = ТаблицаНеВернувшихсяПациентов.Дата";

#КонецОбласти

КонецФункции

// Функция - Получить текст запроса текущих статусов
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТекстЗапросаТекущихСтатусов(ИспользоватьМВТ = Ложь) Экспорт

	Если ИспользоватьМВТ Тогда 
		Возврат "ВЫБРАТЬ
		        |	СтатусыКонтрагентов.Период КАК Период,
		        |	СтатусыКонтрагентов.Контрагент КАК Контрагент,
		        |	СтатусыКонтрагентов.Статус КАК Статус
		        |ИЗ
		        |	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
		        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаКонтрагентов КАК ТаблицаКонтрагентов
		        |		ПО СтатусыКонтрагентов.Контрагент = ТаблицаКонтрагентов.Контрагент
		        |
		        |УПОРЯДОЧИТЬ ПО
		        |	Контрагент,
		        |	Период";
	Иначе 	
		Возврат "ВЫБРАТЬ
		        |	СтатусыКонтрагентов.Период КАК Период,
		        |	СтатусыКонтрагентов.Контрагент КАК Контрагент,
		        |	СтатусыКонтрагентов.Статус КАК Статус
		        |ИЗ
		        |	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
		        |ГДЕ
		        |	СтатусыКонтрагентов.Контрагент = &Контрагент
		        |
		        |УПОРЯДОЧИТЬ ПО
		        |	Контрагент,
		        |	Период";
	КонецЕсли;
	
КонецФункции

// Процедура - Удалить статус клиента
//
// Параметры:
//  СтруктураЗаписи	 - 	 - 
//
Процедура УдалитьСтатусКлиента(СтруктураЗаписи, ИспользоватьБизнесЛогику = Ложь, ИспользоватьБлокировкуЗаписи = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СтруктураЗаписи.Период) ИЛИ НЕ ЗначениеЗаполнено(СтруктураЗаписи.Контрагент) Тогда 
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Период.Установить(СтруктураЗаписи.Период);
	НаборЗаписей.Отбор.Контрагент.Установить(СтруктураЗаписи.Контрагент);	
	
	Если НЕ ИспользоватьБизнесЛогику Тогда 
		НаборЗаписей.ОбменДанными.Загрузка = Истина;	
	КонецЕсли;
	
	Попытка
		НаборЗаписей.Записать();
	Исключение 
		Возврат;
	КонецПопытки;	
	
КонецПроцедуры

// Процедура - Записать актуальный статус клиента
//
// Параметры:
//  СтруктураЗаписи	 - 	 - 
//
Процедура ЗаписатьАктуальныйСтатусКлиента(СтруктураЗаписи, ИспользоватьБизнесЛогику = Ложь, ИспользоватьБлокировкуЗаписи = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СтруктураЗаписи.Период) ИЛИ НЕ ЗначениеЗаполнено(СтруктураЗаписи.Контрагент) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ИспользоватьБлокировкуЗаписи Тогда 	
		
		НачатьТранзакцию();
		
		Попытка
			
			НаборЗаписей = СоздатьНаборЗаписей(); 
			
			НаборЗаписей.Отбор.Период.Установить(СтруктураЗаписи.Период);
			НаборЗаписей.Отбор.Контрагент.Установить(СтруктураЗаписи.Контрагент);
			
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.СтатусыКонтрагентов");
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			ЭлементБлокировки.УстановитьЗначение("Контрагент"			, СтруктураЗаписи.Контрагент);			
			БлокировкаДанных.Заблокировать();
			
			Если НЕ ИспользоватьБизнесЛогику Тогда 
				НаборЗаписей.ОбменДанными.Загрузка = Истина;	
			КонецЕсли;
			
			НаборЗаписей.Записать();
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			ОтменитьТранзакцию();
		КонецПопытки;
		
	Иначе 
		
		НаборЗаписей = СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(СтруктураЗаписи.Период);
		НаборЗаписей.Отбор.Контрагент.Установить(СтруктураЗаписи.Контрагент);
		
		ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), СтруктураЗаписи);
		
		Если НЕ ИспользоватьБизнесЛогику Тогда 
			НаборЗаписей.ОбменДанными.Загрузка = Истина;	
		КонецЕсли;
		
		Попытка
			НаборЗаписей.Записать();
		Исключение 
			
		КонецПопытки;
		
	КонецЕсли;
	
	// Актуализация статуса в регистре "КонтрагентыСведенияДляСписка".
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтруктураЗаписи, "Статус") И ЗначениеЗаполнено(СтруктураЗаписи.Статус) Тогда
		ОбновляемыеДанные = Новый Структура("Статус", СтруктураЗаписи.Статус);
		РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьНеобходимыеДанныеВСведенияхДляСписка(СтруктураЗаписи.Контрагент, ОбновляемыеДанные);		
	КонецЕсли;

КонецПроцедуры	

// Функция - Получить статус клиента
//
// Параметры:
//  Контрагент	 - 	 - 
//  Период		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтатусКлиента(Контрагент
							, Период = Неопределено
							, АктуализироватьДляСписка = Ложь
							, СтатусПоУмолчанию = Неопределено) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Контрагент"			, Контрагент);
	Запрос.УстановитьПараметр("Период"				, Период);						  
	
	Если АктуализироватьДляСписка Тогда 
		Запрос.Текст = "ВЫБРАТЬ
		               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
		               |	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус,
		               |	СтатусыКонтрагентовСрезПоследних.Период КАК Период
		               |ИЗ
		               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(&Период, Контрагент = &Контрагент) КАК СтатусыКонтрагентовСрезПоследних
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
		               |		ПО СтатусыКонтрагентовСрезПоследних.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
		               |ГДЕ
		               |	СтатусыКонтрагентовСрезПоследних.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		               |	И ЕСТЬNULL(КонтрагентыСведенияДляСписка.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)) <> СтатусыКонтрагентовСрезПоследних.Статус";
	Иначе 	
		Запрос.Текст = "ВЫБРАТЬ
		               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент,
		               |	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус,
		               |	СтатусыКонтрагентовСрезПоследних.Период КАК Период
		               |ИЗ
		               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(&Период, Контрагент = &Контрагент) КАК СтатусыКонтрагентовСрезПоследних
		               |ГДЕ
		               |	СтатусыКонтрагентовСрезПоследних.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)";
		
	КонецЕсли;

	РезультатВыборка = Запрос.Выполнить().Выбрать();
	Если РезультатВыборка.Следующий() Тогда
		Возврат РезультатВыборка.Статус;
	Иначе
		АктуализироватьДляСписка = Ложь;
		Если ЗначениеЗаполнено(СтатусПоУмолчанию) Тогда 
			Возврат СтатусПоУмолчанию;
		Иначе 	
			Возврат Перечисления.СтатусыКонтрагентов.ПустаяСсылка();
		КонецЕсли;	
	КонецЕсли; 
	
КонецФункции

// Функция - Определить статус контрагента
//
// Параметры:
//  мПараметры	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОпределитьСтатусКонтрагента(мПараметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Продажи.ДокументПродажи КАК ДокументПродажи
	|ИЗ
	|	РегистрНакопления.Продажи КАК Продажи
	|ГДЕ
	|	Продажи.Контрагент = &Контрагент
	|	И Продажи.Период < &Дата
	|	И Продажи.Регистратор ССЫЛКА Документ.Прием";
						  
	Запрос.УстановитьПараметр("Контрагент", мПараметры.Контрагент);
	Запрос.УстановитьПараметр("Дата", мПараметры.Дата);

	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		ПланируемыйСтатус = Перечисления.СтатусыКонтрагентов.Постоянный;
	Иначе
		ПланируемыйСтатус = Перечисления.СтатусыКонтрагентов.Первичный;
	КонецЕсли;
			
	Возврат ПланируемыйСтатус;

КонецФункции

// Удаляет движения регистра сведения СтатусыКонтрагентов.
//  Параметры:
//   ДокументДвижения - Документ, который производил движение по регистру;
//
Процедура УдалениеСтатусаПациента(СтруктураЗаписи) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СтруктураЗаписи.Период) ИЛИ НЕ ЗначениеЗаполнено(СтруктураЗаписи.Контрагент) Тогда 
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СтатусыКонтрагентов.Период КАК Период,
	               |	СтатусыКонтрагентов.Контрагент КАК Контрагент,
	               |	СтатусыКонтрагентов.Статус КАК Статус
	               |ИЗ
	               |	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
	               |ГДЕ
	               |	СтатусыКонтрагентов.Период = &Период
	               |	И СтатусыКонтрагентов.Контрагент = &Контрагент";

	Запрос.УстановитьПараметр("Период"		, СтруктураЗаписи.Период);
	Запрос.УстановитьПараметр("Контрагент"	, СтруктураЗаписи.Контрагент); 
	
	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			
			НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Период.Установить(Выборка.Период);
			НаборЗаписей.Отбор.Контрагент.Установить(Выборка.Контрагент);
			НаборЗаписей.Записать();
			
		КонецЦикла;
		
	КонецЕсли;

