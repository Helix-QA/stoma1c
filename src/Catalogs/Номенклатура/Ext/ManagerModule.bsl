// Процедура Сопоставить загружаемые данные из внешнего источника.
//
Процедура СопоставитьЗагружаемыеДанныеИзВнешнегоИсточника(ПараметрыСопоставления, АдресРезультата) Экспорт
	
	ТаблицаСопоставленияДанных	= ПараметрыСопоставления.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	НастройкиЗагрузкиДанных		= ПараметрыСопоставления.НастройкиЗагрузкиДанных;
	ОбновлятьДанные				= НастройкиЗагрузкиДанных.ОбновлятьСуществующие;
	ФиксированныйШаблон			= НастройкиЗагрузкиДанных.ФиксированныйШаблон;
	ПоискПоПолю                 = НастройкиЗагрузкиДанных.ПоискПоПолю;
	
	// ТаблицаСопоставленияДанных - Тип ДанныеФормыКоллекция
	Для каждого СтрокаТаблицыФормы Из ТаблицаСопоставленияДанных Цикл
		
		// Номенклатура по ШтрихКоду, Артикулу, Наименованию, НаименованиеПолное, Код, КодУслугиМЗ
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьНоменклатуру(СтрокаТаблицыФормы.Номенклатура, 
			СтрокаТаблицыФормы.Штрихкод, 
			СтрокаТаблицыФормы.Артикул, 
			СтрокаТаблицыФормы.НоменклатураНаименование, 
			СтрокаТаблицыФормы.НоменклатураНаименованиеПолное, 
			СтрокаТаблицыФормы.Код,
			СтрокаТаблицыФормы.КодСинхронизации,
			СтрокаТаблицыФормы.КодНоменклатурыМедицинскиУслуг,
			ПоискПоПолю);

		ЭтаСтрокаСопоставлена = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура);
		
		// Родитель по наименованию
		ЗначениеПоУмолчанию = Справочники.Номенклатура.ПустаяСсылка();
		ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Номенклатура, "Родитель", СтрокаТаблицыФормы.Родитель_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьРодителя("Номенклатура", СтрокаТаблицыФормы.Родитель, СтрокаТаблицыФормы.Родитель_ВходящиеДанные, ЗначениеПоУмолчанию);
					
		// Тип номенклатуры (реквизиты, закрытые для редактирования не правим)
		Если ЭтаСтрокаСопоставлена Тогда
			ЗначениеПоУмолчанию = СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры;
		Иначе
			ЗначениеПоУмолчанию = ?(ЗначениеЗаполнено(СтрокаТаблицыФормы.Родитель), СтрокаТаблицыФормы.Родитель.ТипНоменклатуры, Перечисления.ТипыНоменклатуры.Услуга);
		КонецЕсли;
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьТипНоменклатуры(СтрокаТаблицыФормы.ТипНоменклатуры, СтрокаТаблицыФормы.ТипНоменклатуры_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		// ЕдиницыИзмерения по Наименованию 
		ЗначениеПоУмолчанию = Справочники.КлассификаторЕдиницИзмерения.шт;
		ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Номенклатура, "ЕдиницаИзмерения", СтрокаТаблицыФормы.ЕдиницаИзмерения_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьЕдиницыИзмерения(СтрокаТаблицыФормы.Номенклатура, СтрокаТаблицыФормы.ЕдиницаИзмерения, СтрокаТаблицыФормы.ЕдиницаИзмерения_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		// СтавкаНДС по наименованию
		ЗначениеПоУмолчанию = ?(СтрокаТаблицыФормы.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"),
		Перечисления.СтавкиНДС.БезНДС, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.СтавкаНДС);
		
		Если Не ЭтаСтрокаСопоставлена Или СтрокаТаблицыФормы.СтавкаНДС_ВходящиеДанные <> "" Тогда
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьСтавкуНДС(СтрокаТаблицыФормы.СтавкаНДС, СтрокаТаблицыФормы.СтавкаНДС_ВходящиеДанные, ЗначениеПоУмолчанию);
		КонецЕсли;
		
		//// ЦеноваяГруппа по наименованию
		// ЗначениеПоУмолчанию = Справочники.ЦеновыеГруппы.ПустаяСсылка();
		// ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Номенклатура, "ЦеноваяГруппа", СтрокаТаблицыФормы.ЦеноваяГруппа_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		// ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьЦеновуюГруппу(СтрокаТаблицыФормы.ЦеноваяГруппа, СтрокаТаблицыФормы.ЦеноваяГруппа_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		// Комментарий как строка
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СкопироватьСтрокуВЗначениеСтроковогоТипа(СтрокаТаблицыФормы.Комментарий, СтрокаТаблицыФормы.Комментарий_ВходящиеДанные);
		
		// НормаВремени
		ЗначениеПоУмолчанию = 0;
		ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Номенклатура, "НормаВремени", СтрокаТаблицыФормы.НормаВремени_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.НормаВремени, СтрокаТаблицыФормы.НормаВремени_ВходящиеДанные, ЗначениеПоУмолчанию);
				
		//// СтранаПроисхождения по коду
		// ЗначениеПоУмолчанию = Справочники.СтраныМира.ПустаяСсылка();
		// ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Номенклатура, "СтранаПроисхождения", СтрокаТаблицыФормы.СтранаПроисхождения_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		// ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьСтрануПроисхождения(СтрокаТаблицыФормы.СтранаПроисхождения, СтрокаТаблицыФормы.СтранаПроисхождения_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		// Цена
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Цена, СтрокаТаблицыФормы.Цена_ВходящиеДанные);
		
		// УпаковкиНоменклатуры
		ЗначениеПоУмолчанию = Справочники.УпаковкиНоменклатуры.ПустаяСсылка();
		// ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Упаковка, "Упаковка", СтрокаТаблицыФормы.Упаковка_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьУпаковку(СтрокаТаблицыФормы.УпаковкаПоУмолчанию, СтрокаТаблицыФормы.УпаковкаПоУмолчанию_ВходящиеДанные, СтрокаТаблицыФормы.Номенклатура, ЗначениеПоУмолчанию);
		
		// Коэффициент
		ЗначениеПоУмолчанию = 1;
		// ПриОпределенииЗначенияПоУмолчанию(СтрокаТаблицыФормы.Коэффициент, "Коэффициент", СтрокаТаблицыФормы.Коэффициент_ВходящиеДанные, ЭтаСтрокаСопоставлена, ОбновлятьДанные, ЗначениеПоУмолчанию);
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Коэффициент, СтрокаТаблицыФормы.Коэффициент_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		//// Характеристика
		// ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьХарактеристику(СтрокаТаблицыФормы.Характеристика, СтрокаТаблицыФормы.Номенклатура,,СтрокаТаблицыФормы.Характеристика_ВходящиеДанные); 
		
		ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы);
		
		ЗагрузкаДанныхИзВнешнегоИсточника.ПрогрессСопоставленияДанных(ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицыФормы), РазмерТаблицыДанных);
		
	КонецЦикла;   
	
	Если НастройкиЗагрузкиДанных.ПоискПоПолю = 0 Тогда // Сопоставляли по наименованию
		ТаблицаСопоставленияДанных.Сортировать("НоменклатураНаименование"); 
	ИначеЕсли НастройкиЗагрузкиДанных.ПоискПоПолю = 1 Тогда  // Сопостовляли по артикулу
		 ТаблицаСопоставленияДанных.Сортировать("Артикул");
	ИначеЕсли НастройкиЗагрузкиДанных.ПоискПоПолю = 2 Тогда
		ТаблицаСопоставленияДанных.Сортировать("КодСинхронизации"); // Сопоставляли по кодусинхронизации
	ИначеЕсли НастройкиЗагрузкиДанных.ПоискПоПолю = 3 Тогда                                             
		ТаблицаСопоставленияДанных.Сортировать("КодНоменклатурыМедицинскиУслуг"); // Сопоставляли по кодууслуги		
	КонецЕсли;	
	
	ПоместитьВоВременноеХранилище(ТаблицаСопоставленияДанных, АдресРезультата);
	
КонецПроцедуры

// Процедура проверить корректность данных в свтроке таблицы.
//
Процедура ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения = "") Экспорт
	
	СтрокаТаблицыФормы._СтрокаСопоставлена = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура);
	
	ИмяСлужебногоПоля = ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна();
	
	СтрокаТаблицыФормы[ИмяСлужебногоПоля] = СтрокаТаблицыФормы._СтрокаСопоставлена
											ИЛИ (НЕ СтрокаТаблицыФормы._СтрокаСопоставлена И НЕ ПустаяСтрока(СтрокаТаблицыФормы.НоменклатураНаименование));
	
КонецПроцедуры

// Процедура Обработать подготовленные данные.
//
Процедура ОбработатьПодготовленныеДанные(СтруктураДанных, ФоновоеЗаданиеАдресХранилища = "") Экспорт
	
	НастройкиОбновленияСвойств		= СтруктураДанных.НастройкиЗагрузкиДанных.НастройкиОбновленияСвойств;
	ОбновлятьСуществующие			= СтруктураДанных.НастройкиЗагрузкиДанных.ОбновлятьСуществующие;
	СоздаватьЕслиНеСопоставлено		= СтруктураДанных.НастройкиЗагрузкиДанных.СоздаватьЕслиНеСопоставлено; 
	ПоискПоПолю 				    = СтруктураДанных.НастройкиЗагрузкиДанных.ПоискПоПолю;
	ФиксированныйШаблон				= СтруктураДанных.НастройкиЗагрузкиДанных.ФиксированныйШаблон; 	
	ТаблицаСопоставленияДанных		= СтруктураДанных.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных				= ТаблицаСопоставленияДанных.Количество();
	КоличествоЗаписейТранзакции		= 0;
	ТранзакцияОткрыта				= Ложь;	
	
	ВидЦен 			   = СтруктураДанных.НастройкиЗагрузкиДанных.ВидЦен;
	СкладОстатков 	   = СтруктураДанных.НастройкиЗагрузкиДанных.СкладОстатков;
	СтруктурнаяЕдиница = СтруктураДанных.НастройкиЗагрузкиДанных.СтруктурнаяЕдиница;
		
	Попытка
		
		Для Каждого СтрокаТаблицы Из ТаблицаСопоставленияДанных Цикл
			
			Если НЕ ТранзакцияОткрыта 
				И КоличествоЗаписейТранзакции = 0 Тогда
				
				НачатьТранзакцию();
				ТранзакцияОткрыта = Истина;
				
			КонецЕсли;
			
			ЗагрузкаВПриложениеВозможна = СтрокаТаблицы[ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна()];
			
			СогласованноеСостояниеСтроки = (СтрокаТаблицы._СтрокаСопоставлена И ОбновлятьСуществующие) 
				ИЛИ (НЕ СтрокаТаблицы._СтрокаСопоставлена И СоздаватьЕслиНеСопоставлено)
				ИЛИ ФиксированныйШаблон;
				
			Если ЗагрузкаВПриложениеВозможна И СогласованноеСостояниеСтроки Тогда
				
				КоличествоЗаписейТранзакции = КоличествоЗаписейТранзакции + 1;
				
				Если СтрокаТаблицы._СтрокаСопоставлена Тогда
					
					ЭлементСправочника = СтрокаТаблицы.Номенклатура.ПолучитьОбъект();
					Если СтрНайти(НастройкиОбновленияСвойств.ИменаПолейОбновляемые,"СтавкаНДС") Тогда
						НастройкиОбновленияСвойств.ИменаПолейОбновляемые = СтрЗаменить(НастройкиОбновленияСвойств.ИменаПолейОбновляемые, "СтавкаНДС,","");
						НастройкиОбновленияСвойств.ИменаПолейОбновляемые = СтрЗаменить(НастройкиОбновленияСвойств.ИменаПолейОбновляемые, ",СтавкаНДС","");
						НастройкиОбновленияСвойств.ИменаПолейОбновляемые = СтрЗаменить(НастройкиОбновленияСвойств.ИменаПолейОбновляемые, "СтавкаНДС","");
					КонецЕсли;
					
					Если СтрНайти(НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению,"СтавкаНДС") Тогда
						НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению = СтрЗаменить(НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению, "СтавкаНДС,","");
						НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению = СтрЗаменить(НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению, ",СтавкаНДС","");
						НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению = СтрЗаменить(НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению, "СтавкаНДС","");
					КонецЕсли;
					
					ЗаполнитьЗначенияСвойств(ЭлементСправочника, СтрокаТаблицы, НастройкиОбновленияСвойств.ИменаПолейОбновляемые, НастройкиОбновленияСвойств.ИменаПолейНеподлежащихОбновлению);
					
				Иначе
					
					НоменклатураВЭтойТранзакции = Неопределено;
					// Номенклатура по ШтрихКоду, Артикулу, Наименованию, НаименованиеПолное, Код, КодСинхронизации
					ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьНоменклатуру(НоменклатураВЭтойТранзакции, 
					СтрокаТаблицы.Штрихкод, 
					СтрокаТаблицы.Артикул, 
					СтрокаТаблицы.НоменклатураНаименование, 
					СтрокаТаблицы.НоменклатураНаименованиеПолное, 
					СтрокаТаблицы.Код,
					СтрокаТаблицы.КодСинхронизации,
					СтрокаТаблицы.КодНоменклатурыМедицинскиУслуг,
					ПоискПоПолю);
					
					Если ЗначениеЗаполнено(НоменклатураВЭтойТранзакции) Тогда
						ЭлементСправочника = НоменклатураВЭтойТранзакции.ПолучитьОбъект();
					Иначе
						
						ЭлементСправочника = Справочники.Номенклатура.СоздатьЭлемент();	
						
						ЗаполнитьЗначенияСвойств(ЭлементСправочника, СтрокаТаблицы, , ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СтандартныеИменаПолейНеподлежащихОбновлению(СтруктураДанных.НастройкиЗагрузкиДанных));
						ЭлементСправочника.Записать();					
						
					КонецЕсли;
					
				КонецЕсли;
				
				ЭлементСправочника.Наименование       = СтрокаТаблицы.НоменклатураНаименование;
				ЭлементСправочника.НаименованиеПолное = ?(ПустаяСтрока(СтрокаТаблицы.НоменклатураНаименованиеПолное), СтрокаТаблицы.НоменклатураНаименование, СтрокаТаблицы.НоменклатураНаименованиеПолное);
				ЭлементСправочника.ЭтоУслуга          = ?(ЭлементСправочника.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга, Истина, Ложь);
				ЭлементСправочника.Родитель           = СтрокаТаблицы.Родитель;
				
				Если НЕ ПустаяСтрока(СтрокаТаблицы.КодНоменклатурыМедицинскиУслуг) Тогда
					 ЭлементСправочника.НоменклатураМедицинскихУслуг = Справочники.КлассификаторНоменклатурыМедицинскихУслуг.НайтиПоКоду(СтрокаТаблицы.КодНоменклатурыМедицинскиУслуг);
				КонецЕсли;	 
				
				Если НЕ ЗначениеЗаполнено(ЭлементСправочника.Родитель)
					И ЗначениеЗаполнено(СтрокаТаблицы.Родитель_ВходящиеДанные) Тогда  
					
					// Разбить строку на подстроки
					Группа = Неопределено;
					
					МассивСлов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(СтрокаТаблицы.Родитель_ВходящиеДанные, "|");
					РодительВерхнегоУровня = Неопределено;
					Для Каждого РодительНаименование Из МассивСлов Цикл
						
						Если ЗначениеЗаполнено(РодительНаименование) Тогда
							
							Группа = НайтиСоздатьГруппу(РодительНаименование, РодительВерхнегоУровня, ЭлементСправочника.ТипНоменклатуры);
							РодительВерхнегоУровня = Группа;
							
						КонецЕсли;
						
					КонецЦикла;
					
					ЭлементСправочника.Родитель = Группа;
					
				КонецЕсли;


				Если Не ЗначениеЗаполнено(СтрокаТаблицы.УпаковкаПоУмолчанию)
					И ЗначениеЗаполнено(СтрокаТаблицы.УпаковкаПоУмолчанию_ВходящиеДанные) Тогда
										
					// Создать упаковку
					НоваяУпаковка = Справочники.УпаковкиНоменклатуры.СоздатьЭлемент();
					НоваяУпаковка.Владелец     = ЭлементСправочника.Ссылка;//?(ЭлементСправочника.Ссылка.Пустая(), ЭлементСправочникаНоваяСсылка, ЭлементСправочника.Ссылка);
					НоваяУпаковка.Наименование = СтрокаТаблицы.УпаковкаПоУмолчанию_ВходящиеДанные;
					НоваяУпаковка.Коэффициент  = СтрокаТаблицы.Коэффициент;
					НоваяУпаковка.Записать();
					
					ЭлементСправочника.УпаковкаПоУмолчанию = НоваяУпаковка.Ссылка;

				КонецЕсли;
								
				// Если Не ЗначениеЗаполнено(СтрокаТаблицы.Характеристика)
				//	И ЗначениеЗаполнено(СтрокаТаблицы.Характеристика_ВходящиеДанные) Тогда
				//	
				//	НовыйЭлементСправочникаСсылка = ЭлементСправочника.Ссылка;//?(ЭлементСправочника.Ссылка.Пустая(), ЭлементСправочникаНоваяСсылка, ЭлементСправочника.Ссылка);
				//	ЭлементСправочника.ИспользоватьПартии = Истина;
				//	
				//	НоваяХарактеристика = Справочники.ПартииНоменклатуры.Выбрать(, НовыйЭлементСправочникаСсылка, Новый Структура("Наименование", СтрокаТаблицы.Характеристика_ВходящиеДанные));
				//	Если Не НоваяХарактеристика.Следующий() Тогда
				//		НоваяХарактеристика = Справочники.ПартииНоменклатуры.СоздатьЭлемент();
				//		НоваяХарактеристика.Владелец = НовыйЭлементСправочникаСсылка;
				//		НоваяХарактеристика.Наименование = СтрокаТаблицы.Характеристика_ВходящиеДанные;
				//		НоваяХарактеристика.Записать();
				//	КонецЕсли;
				//	
				// КонецЕсли;
		
				ЭлементСправочника.Записать();
								
				Если НЕ ПустаяСтрока(СтрокаТаблицы.ШтрихКод) Тогда
					
					ШК = РегистрыСведений.Штрихкоды.СоздатьМенеджерЗаписи();
					ШК.Период   = ТекущаяДата();
					ШК.Штрихкод = СокрЛП(СтрокаТаблицы.ШтрихКод);
					ШК.Объект   = ЭлементСправочника.Ссылка;
										
					ШК.Записать(Истина);
					
				КонецЕсли;
				
				Если ЗначениеЗаполнено(СтрокаТаблицы.Цена) Тогда
					
					УстановитьЦенуНоменклатуры(ЭлементСправочника.Ссылка, ВидЦен, ЭлементСправочника.УпаковкаПоУмолчанию, СтруктурнаяЕдиница, СтрокаТаблицы.Цена); 
					
				КонецЕсли;
					
			КонецЕсли;
			
			ИндексТекущейстроки	= ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицы);
			ТекстПрогресса		= СтрШаблон(НСтр("ru ='Обработано %1 из %2 строк...'"), ИндексТекущейстроки, РазмерТаблицыДанных);
			
			#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
				ДлительныеОперации.СообщитьПрогресс(Цел(ИндексТекущейстроки * 100 / РазмерТаблицыДанных), ТекстПрогресса);
			#КонецЕсли
			
			Если ТранзакцияОткрыта
				И КоличествоЗаписейТранзакции > ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.МаксимумЗаписейВОднойТранзакции() Тогда
				
				ЗафиксироватьТранзакцию();
				ТранзакцияОткрыта = Ложь;
				КоличествоЗаписейТранзакции = 0;
				
			КонецЕсли;
			
		КонецЦикла;
			
		Если ТранзакцияОткрыта 
			И КоличествоЗаписейТранзакции > 0 Тогда
			
			ЗафиксироватьТранзакцию();
			ТранзакцияОткрыта = Ложь;
			
		КонецЕсли;
		
	Исключение
		
		ЗаписьЖурналаРегистрации(Нстр("ru='Загрузка данных'", "ru"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.Номенклатура, , ОписаниеОшибки());
		ОтменитьТранзакцию();
		
	КонецПопытки;
	
КонецПроцедуры

// Функция, находит или если не найдена группа, то создает ее.
//
// Параметры:
//  РодительНаименование	 - Строка 				- Наименование группы которую ищем. 
//  РодительВерхнегоУровня	 - СправочникСсылка 	- Ссылка на справочник родителя группы которую ищем.
//  ТипНоменклатуры			 - ПеречислениеСсылка 	- Перечисление типов номенклатуры. 
// 
// Возвращаемое значение:
//  Родитель - Ссылка на группу номенклатуры.
//
Функция НайтиСоздатьГруппу(РодительНаименование, РодительВерхнегоУровня = Неопределено, ТипНоменклатуры = Неопределено)
	
	Родитель = Справочники.Номенклатура.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа = ИСТИНА
	|	И Номенклатура.Наименование = &Наименование
	|	И ВЫБОР
	|			КОГДА &РодительВерхнегоУровня <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Номенклатура.Родитель = &РодительВерхнегоУровня
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ТипНоменклатуры <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Наименование"          , РодительНаименование);
	Запрос.УстановитьПараметр("РодительВерхнегоУровня", РодительВерхнегоУровня);
	Запрос.УстановитьПараметр("ТипНоменклатуры"       , ТипНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Родитель = Выборка.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Родитель) Тогда
		
		// Создать родителя
		РодительОбъект                 = Справочники.Номенклатура.СоздатьГруппу();
		РодительОбъект.Наименование    = РодительНаименование;
		РодительОбъект.ТипНоменклатуры = ТипНоменклатуры;
		Если ЗначениеЗаполнено(РодительВерхнегоУровня) Тогда 
			РодительОбъект.Родитель = РодительВерхнегоУровня;
		КонецЕсли;
		
		РодительОбъект.Записать();
		Родитель = РодительОбъект.Ссылка;
		
	КонецЕсли;
	
	Возврат Родитель;
	
КонецФункции

#КонецОбласти

// Функция, определяет, доступна ли номенклатура для онлайн записи.
// 
Функция НоменклатураДоступнаДляОнлайнЗаписи(ПодборСтруктурныеЕдиницы) Экспорт
	
	Для Каждого СтрокаДерева Из ПодборСтруктурныеЕдиницы.ПолучитьЭлементы() Цикл
		Если СтрокаДерева.Выгружать <> 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

#Область ОбработчикиНастроекОнлайнЗаписиИПродажи

// Функция Получить таблицу номенклатур онлайн-записи.
//
Функция ПолучитьТаблицуНоменклатурОнлайнЗаписи(Объект, ДеревоНоменклатур)
	
	ЗапросУслуг = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыОбъектов.Объект КАК Услуга,
	|	ВЫБОР
	|		КОГДА РеквизитыОбъектов.Объект.ГруппаОнлайнЗаписи.Ссылка ЕСТЬ NULL
	|				ИЛИ РеквизитыОбъектов.Объект.ГруппаОнлайнЗаписи.ПометкаУдаления
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ РеквизитыОбъектов.Объект.ГруппаОнлайнЗаписи.Ссылка
	|	КОНЕЦ КАК Родитель,
	|	РеквизитыОбъектов.Объект.ИндексСортировки КАК ИндексСортировки,
	|	2 КАК ИндексКартинки,
	|	ИСТИНА КАК ОтображатьКнопкиПеремещения
	|ИЗ
	|	РегистрСведений.РеквизитыОбъектов КАК РеквизитыОбъектов
	|ГДЕ
	|	РеквизитыОбъектов.Объект ССЫЛКА Справочник.Номенклатура
	|	И НЕ РеквизитыОбъектов.Объект.ПометкаУдаления
	|	И НЕ РеквизитыОбъектов.Объект.ЭтоГруппа
	|	И РеквизитыОбъектов.Объект.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И РеквизитыОбъектов.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыОбъектов.Значение = ИСТИНА
	|	И РеквизитыОбъектов.Реквизит = ""ОнлайнЗапись""
	|	И &УсловиеНормаВремени
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА РеквизитыОбъектов.Объект.ИндексСортировки = 0
	|			ТОГДА 999999
	|		ИНАЧЕ РеквизитыОбъектов.Объект.ИндексСортировки
	|	КОНЕЦ,
	|	РеквизитыОбъектов.Объект.Наименование");
	
	ЗапросУслуг.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	УсловиеНормаВремени = ?(Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга, "И РеквизитыОбъектов.Объект.НормаВремени <> 0", "");
	ЗапросУслуг.Текст	= СтрЗаменить(ЗапросУслуг.Текст, "И &УсловиеНормаВремени", УсловиеНормаВремени);
	
	Возврат ЗапросУслуг.Выполнить().Выгрузить();
	
КонецФункции

// Функция Получить таблицу номенклатур онлайн-продажи.
//
Функция ПолучитьТаблицуНоменклатурОнлайнПродажи(Объект, ДеревоНоменклатур)
	
	ЗапросУслуг = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыОбъектов.Объект КАК Услуга,
	|	ВЫБОР
	|		КОГДА РеквизитыОбъектов.Объект.ГруппаОнлайнПродажи.Ссылка ЕСТЬ NULL
	|				ИЛИ РеквизитыОбъектов.Объект.ГруппаОнлайнПродажи.ПометкаУдаления
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ РеквизитыОбъектов.Объект.ГруппаОнлайнПродажи.Ссылка
	|	КОНЕЦ КАК Родитель,
	|	РеквизитыОбъектов.Объект.ИндексСортировки КАК ИндексСортировки,
	|	2 КАК ИндексКартинки,
	|	ИСТИНА КАК ОтображатьКнопкиПеремещения
	|ИЗ
	|	РегистрСведений.РеквизитыОбъектов КАК РеквизитыОбъектов
	|ГДЕ
	|	РеквизитыОбъектов.Объект ССЫЛКА Справочник.Номенклатура
	|	И НЕ РеквизитыОбъектов.Объект.ПометкаУдаления
	|	И НЕ РеквизитыОбъектов.Объект.ЭтоГруппа
	|	И РеквизитыОбъектов.Объект.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементПакетУслуг), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат))
	|	И РеквизитыОбъектов.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыОбъектов.Значение = ИСТИНА
	|	И РеквизитыОбъектов.Реквизит = ""ОнлайнЗапись""
	|	И &УсловиеНормаВремени
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВЫБОР
	|		КОГДА РеквизитыОбъектов.Объект.ИндексСортировки = 0
	|			ТОГДА 999999
	|		ИНАЧЕ РеквизитыОбъектов.Объект.ИндексСортировки
	|	КОНЕЦ,
	|	РеквизитыОбъектов.Объект.Наименование");
	
	ЗапросУслуг.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	УсловиеНормаВремени = ?(Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга, "И РеквизитыОбъектов.Объект.НормаВремени <> 0", "");
	ЗапросУслуг.Текст	= СтрЗаменить(ЗапросУслуг.Текст, "И &УсловиеНормаВремени", УсловиеНормаВремени);
	
	Возврат ЗапросУслуг.Выполнить().Выгрузить();
	
КонецФункции

// Процедура, заполняет дерево услуг.
// 
Процедура ЗаполнитьДеревоНоменклатур(Объект, ДеревоНоменклатур) Экспорт
	
	ДеревоНоменклатур.ПолучитьЭлементы().Очистить();
	
	ЭтоУслуга = Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
	
	Если ЭтоУслуга Тогда
		ТаблицаГрупп 	   = ПолучитьТаблицуГруппОнлайнЗаписи();
		ТаблицаНоменклатур = ПолучитьТаблицуНоменклатурОнлайнЗаписи(Объект, ДеревоНоменклатур);
	Иначе
		ТаблицаГрупп 	   = ПолучитьТаблицуГруппОнлайнПродажи();
		ТаблицаНоменклатур = ПолучитьТаблицуНоменклатурОнлайнПродажи(Объект, ДеревоНоменклатур);
	КонецЕсли;
	
	МассивСтрок = ТаблицаНоменклатур.НайтиСтроки(Новый Структура("Услуга", Объект.Ссылка));
	
	Если МассивСтрок.Количество() > 0 Тогда
		
		ТекущаяГруппа 	 = ?(ЭтоУслуга, Объект.ГруппаОнлайнЗаписи, Объект.ГруппаОнлайнПродажи);
		ПредыдущаяГруппа = ?(ЭтоУслуга, Объект.Ссылка.ГруппаОнлайнЗаписи, Объект.Ссылка.ГруппаОнлайнПродажи);
		ГруппаИзменена   = ТекущаяГруппа <> ПредыдущаяГруппа;
		
		СтрокаТЗ 		 		  = МассивСтрок[0];
		СтрокаТЗ.Родитель 		  = ?(ЗначениеЗаполнено(ТекущаяГруппа) И Не ТекущаяГруппа.ПометкаУдаления, ТекущаяГруппа, Неопределено);
		СтрокаТЗ.ИндексСортировки = ?(ГруппаИзменена, Объект.ИндексСортировки, Объект.Ссылка.ИндексСортировки);
		
	КонецЕсли;
	
	Если ЭтоУслуга Тогда
		
		Для Каждого СтрокаТЧ Из ТаблицаГрупп Цикл
			
			МассивДочернихСтрок = ТаблицаНоменклатур.НайтиСтроки(Новый Структура("Родитель", СтрокаТЧ.Услуга));
			
			Если МассивДочернихСтрок.Количество() > 0 Тогда			
				СтрокаРодитель = ДеревоНоменклатур.ПолучитьЭлементы().Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаРодитель, СтрокаТЧ);
				
				Для Каждого СтрокаУслуги Из МассивДочернихСтрок Цикл					
					СтрокаУслуга = СтрокаРодитель.ПолучитьЭлементы().Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаУслуга, СтрокаУслуги);					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;		
	
	Иначе	
		ЗаполнитьДеревоНоменклатурРекурсивно(ТаблицаГрупп, ТаблицаНоменклатур, ДеревоНоменклатур);
	КонецЕсли;

	Для Каждого СтрокаТЧ Из ТаблицаНоменклатур.НайтиСтроки(Новый Структура("Родитель", Неопределено)) Цикл
		СтрокаУслуга = ДеревоНоменклатур.ПолучитьЭлементы().Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаУслуга, СтрокаТЧ);
	КонецЦикла;
		
КонецПроцедуры

// Функция, возвращает структуру ресурсов.
//
Процедура ЗаполнитьДеревоНоменклатурРекурсивно(ТаблицаГруппСИерархией, ТаблицаНоменклатур, ДеревоНоменклатур)
	
	Для Каждого СтрокаТЧ ИЗ ТаблицаГруппСИерархией.Строки Цикл
		
		СтрокаРодитель = ДеревоНоменклатур.ПолучитьЭлементы().Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРодитель, СтрокаТЧ);
		
		Если СтрокаТЧ.Строки.Количество() > 0 Тогда
			ЗаполнитьДеревоНоменклатурРекурсивно(СтрокаТЧ, ТаблицаНоменклатур, СтрокаРодитель);
		КонецЕсли;
		
		МассивДочернихСтрок = ТаблицаНоменклатур.НайтиСтроки(Новый Структура("Родитель", СтрокаТЧ.Услуга));
			
		Если МассивДочернихСтрок.Количество() > 0 Тогда
			
			Для Каждого СтрокаУслуги Из МассивДочернихСтрок Цикл
				
				СтрокаУслуга = СтрокаРодитель.ПолучитьЭлементы().Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаУслуга, СтрокаУслуги);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

