// Процедура, выполняет нажатие на виджет сделки после вопроса о записи.
//  
//  Описание:
//  
//  
//  Параметры (название, тип, дифференцированное значение)
//
// Параметры:
//  Результат	 - КодВозвратаДиалога	 -  да/нет.
//  ДопПараметры - Структура			 -  содержит доп. параметры.
//
Процедура ОбработчикНажатияДинамическогоЭлементаВиджетаЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да
		И ТипЗнч(ДопПараметры) = Тип("Структура")
		И ДопПараметры.Свойство("ИмяКоманды") Тогда
		
		ЭтаФорма.Записать();
		ВыполнитьНажатиеНаВиджетСделки(ДопПараметры.ИмяКоманды);

	КонецЕсли;	

КонецПроцедуры

