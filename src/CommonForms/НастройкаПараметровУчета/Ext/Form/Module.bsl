// Процедура, "При записи на сервере".
//
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Модифицированность = Истина Тогда 
		
		Если ЗначениеЗаполнено(ЗапретОнлайнЗаписиС) И Не ЗначениеЗаполнено(ЗапретОнлайнЗаписиПо)
			ИЛИ ЗначениеЗаполнено(ЗапретОнлайнЗаписиПо) И Не ЗначениеЗаполнено(ЗапретОнлайнЗаписиС) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для ограничения онлайн записи за период необходимо заполнить дату начала и дату окончания запрета!");
			Отказ = Истина;
			Возврат;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ВиджетОнлайнЗаписи) Тогда
			ЗаписатьПараметрыВнешнейСистемыСервер();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

