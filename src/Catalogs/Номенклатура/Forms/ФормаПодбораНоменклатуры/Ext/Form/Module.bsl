// Обработчик перед началом выбора упаковки номенклатуры
//
Процедура ТаблицаВыбранныхЗначенийУпаковкаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные        = Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено И ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Справочник.УпаковкиНоменклатуры.ПустаяСсылка"), "<без упаковки>");
		Если Не ОбщегоНазначенияСтоматология.ПроверитьИспользованиеУпаковокИПолучитьСписокДляВыбора(ТекущиеДанные.Номенклатура, ДанныеВыбора) Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Для данной номенклатуры нет упаковок.'"));
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора"
//
Процедура ТаблицаВыбранныхЗначенийПартияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СтрокаТабличнойЧасти = Элементы.ТаблицаВыбранныхЗначений.ТекущиеДанные;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
		
		мПараметрыВыбора = Новый Структура;
		мПараметрыВыбора.Вставить("Владелец"                       , СтрокаТабличнойЧасти.Номенклатура);
		Если Не СкладПоУмолчанию = Неопределено Тогда
			мПараметрыВыбора.Вставить("Склад"                          , СтрокаТабличнойЧасти.Склад);
		КонецЕсли;
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница"             , ОтборСтруктурнаяЕдиница);
		мПараметрыВыбора.Вставить("Дата"                           , ОтборДата);
        мПараметрыВыбора.Вставить("МножественныйВыбор"             , Истина);

		ОписаниеОповещения = Новый ОписаниеОповещения("ТаблицаВыбранныхЗначенийПартияНачалоВыбораЗавершение", ЭтотОбъект, СтрокаТабличнойЧасти);
		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", мПараметрыВыбора,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);		

	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура - Таблица выбранных значений партия начало выбора завершение.
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ТаблицаВыбранныхЗначенийПартияНачалоВыбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено И ТипЗнч(Результат) = Тип("Массив") И Результат.Количество() <> 0 Тогда
		Параметры.Партия = Результат[0];
		// пересчет остатка
		Параметры.Остаток = ПолучитьОстаток(Параметры.Номенклатура, Параметры.Склад, Параметры.Упаковка, Параметры.Партия);
	КонецЕсли;	
	
КонецПроцедуры

