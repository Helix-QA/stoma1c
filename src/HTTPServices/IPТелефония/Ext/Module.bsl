#Область СлужебныеПроцедурыИФункции
   
// Функция - проверяет на дубль звонок
//
Функция ПроверкаITOOLABS(ПОIPТелефонии, IDЗвонка) Экспорт
	
	НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Значение 		= ПОIPТелефонии;
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Использование 	= Истина;
	НаборЗаписей.Отбор.IDЗвонка.Значение 					= IDЗвонка;
	НаборЗаписей.Отбор.IDЗвонка.Использование 				= Истина;
	
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда 
		Запись = НаборЗаписей[0];
		Если Запись.Статус = Перечисления.СтатусыЗвонка.Разговор Тогда
			Возврат Истина;			
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Процедура - Распарсить строку
//
Процедура РаспарситьСтроку(ПараметрыТела, Ключ, Значение) 	
		
	Если СтрНайти(Ключ, "[") <> 0 Тогда
		
		Ключ = СтрРазделить(Ключ, "[");
		Если Прав(Ключ[1], 1) = "]" Тогда
			Ключ[1] = Лев(Ключ[1], СтрДлина(Ключ[1]) - 1);
		КонецЕсли;
		
		Попытка
			Ключ[0] = Число(Ключ[0]);
		Исключение
		КонецПопытки;  		
		
		Если ТипЗнч(Ключ[0]) <> Тип("Число") 
			И Не ПараметрыТела.Свойство(Ключ[0]) Тогда 
			
			Попытка
				
				Если Ключ.Количество() > 1 Тогда 
					
					Индекс = Число(Лев(Ключ[1], 1));					
					ПараметрыТела.Вставить(Ключ[0], Новый Массив());
					
				КонецЕсли;
				
			Исключение
				ПараметрыТела.Вставить(Ключ[0], Новый Структура());				
			КонецПопытки;
			
		КонецЕсли;
		
		Если Ключ.Количество() > 2 Тогда
			
			Пока Ключ.Количество() > 1 Цикл
				
				времКлюч = "" + времКлюч + Ключ[1] + ?(Ключ.Количество()>2, "[", "");
				
				Ключ.Удалить(1);
				
			КонецЦикла;
			
			РаспарситьСтроку(ПараметрыТела[Ключ[0]], времКлюч, Значение);
		Иначе
			
			Если ТипЗнч(Ключ[0]) = Тип("Число") 
				И ТипЗнч(ПараметрыТела) = Тип("Массив") 
				И ПараметрыТела.Количество() = Ключ[0] Тогда 
				ПараметрыТела.Добавить(Новый Структура());				
			КонецЕсли;
			РаспарситьСтроку(ПараметрыТела[Ключ[0]], Ключ[1], Значение);
			
		КонецЕсли;	
		
	Иначе 
		RawDataВСтруктуру(ПараметрыТела, Ключ, Значение);			
	КонецЕсли;
	
КонецПроцедуры   

// Процедура - Raw data в структуру
//
Процедура RawDataВСтруктуру(ПараметрыТела, Ключ, Значение)
		
	Если Лев(Ключ, 1) = "[" Тогда
		Ключ = Прав(Ключ, СтрДлина(Ключ) - 1);
	КонецЕсли; 	
		
	ПараметрыТела.Вставить(Ключ, Значение);			
	
КонецПроцедуры

// Функция - Получить параметры из строки
//
Функция ПолучитьПараметрыИзСтроки(Знач СтрокаПараметров, Знач Разделитель = ";") Экспорт
	
	Результат = Новый Структура;
	
	ОписаниеПараметра = "";
	НайденоНачалоСтроки = Ложь;
	НомерПоследнегоСимвола = СтрДлина(СтрокаПараметров);
	Для НомерСимвола = 1 По НомерПоследнегоСимвола Цикл
		Символ =Сред(СтрокаПараметров, НомерСимвола, 1);
		Если Символ = """" Тогда
			НайденоНачалоСтроки = Не НайденоНачалоСтроки;
		КонецЕсли;
		Если Символ <> Разделитель Или НайденоНачалоСтроки Тогда
			ОписаниеПараметра = ОписаниеПараметра + Символ;
		КонецЕсли;
		Если Символ = Разделитель И Не НайденоНачалоСтроки Или НомерСимвола = НомерПоследнегоСимвола Тогда
			Позиция = СтрНайти(ОписаниеПараметра, "=");
			Если Позиция > 0 Тогда
				ИмяПараметра = СокрЛП(Лев(ОписаниеПараметра, Позиция - 1));
				ЗначениеПараметра = СокрЛП(Сред(ОписаниеПараметра, Позиция + 1));
				ЗначениеПараметра = СтроковыеФункцииКлиентСервер.СократитьДвойныеКавычки(ЗначениеПараметра);
				Попытка
					Результат.Вставить(ИмяПараметра, ЗначениеПараметра);
				Исключение
				КонецПопытки;
			КонецЕсли;
			ОписаниеПараметра = "";
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Функция - MANGOПроверить аутоидентификацию
//
// Параметры:
//  IPТелефонияПодключаемоеОборудование	 - 	 - 
//  JSONСообщение						 - 	 - 
//  Sign								 - 	 - 
//  ОтносительныйURL					 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция MANGOПроверитьАутоидентификацию(IPТелефонияПодключаемоеОборудование, JSONСообщение, Sign, ОтносительныйURL = "")
	
	Попытка
		
		IPТелефонияПараметры = IPТелефонияПодключаемоеОборудование.Параметры.Получить();

		// Проверка
		ВычисленныйSign = IPТелефония.SHA256(IPТелефонияПараметры.КодПродукта + JSONСообщение + IPТелефонияПараметры.Ключ);
		Если ВычисленныйSign <> Sign Тогда 
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция, возвращает параметры запроса.
//
Функция ПолучитьПараметрыЗапроса(ТекстJSON)
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Возврат ПрочитатьJSON(ЧтениеJSON);
	Исключение
		Возврат Неопределено;
	КонецПопытки;   
	
КонецФункции

// Функция, возвращает HTTPОтвет.
//
// Параметры:
//  КодОтвета	 - 	 - 
//  Описание	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьHTTPОтветAPI(КодОтвета, Ответ1С, КодироватьВJSON = Ложь, ЗаголовокUrlencoded = Ложь)
		 		
	HTTPОтвет = Новый HTTPСервисОтвет(КодОтвета);
	
	Если КодироватьВJSON Тогда
		HTTPОтвет.УстановитьТелоИзСтроки(КодироватьВJSON(Ответ1С, Ложь));
	Иначе
		HTTPОтвет.УстановитьТелоИзСтроки(Ответ1С);
	КонецЕсли;
	
	Если ЗаголовокUrlencoded Тогда
		HTTPОтвет.Заголовки["Content-Type"] = "application/x-www-form-urlencoded";
	Иначе
		HTTPОтвет.Заголовки["Content-Type"] = "application/json";	
	КонецЕсли;
	
	Возврат HTTPОтвет; 
	
КонецФункции

// Функция возвращает структуру с заголовками запроса в нижнем регистре.
// 
// Параметры:
//  Запрос	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПривестиЗаголовкиВНижнийРегистр(Запрос)
	
	СоответствиеСЗаголовками = Новый Соответствие;
	
	Для Каждого Заголовок Из Запрос.Заголовки Цикл
		СоответствиеСЗаголовками.Вставить(НРег(Заголовок.Ключ), Заголовок.Значение);
	КонецЦикла;
	
	Возврат СоответствиеСЗаголовками;
	
КонецФункции

Функция CallTouchEventsPOST(Запрос)

   	УстановитьПривилегированныйРежим(Истина);
	
	ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.CallTouchEvents", УровеньЖурналаРегистрации.Информация, , , 
	"Вызов функции. Переданные параметры: " + Символы.ПС + РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL));
	
	// Логирование
	ЛогироватьСобытие = Ложь; //Константы.ЛогироватьHTTP.Получить();	
	
	Если ЛогироватьСобытие > 0 Тогда
		ВремяНачалаОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
		UIDЗапроса     = Новый УникальныйИдентификатор();
		HTTPЗапросЛога = Запрос;
		ДатаЛога       = ТекущаяДатаСеанса();
		ТипЗапроса     = Перечисления.HTTPСервисы.IPТелефония;
		HTTPШаблон     = "CallTouchEvents";
		
	КонецЕсли;
	//\\

	ТелоЗапроса   = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);	
	ПараметрыТела = Новый Структура();
	
	Для Каждого СтрокаМ Из СтрРазделить(ТелоЗапроса, "&") Цикл 
		
		Массив = СтрРазделить(СтрокаМ, "=");
		Если Массив.Количество() > 1 Тогда 
			РаспарситьСтроку(ПараметрыТела, Массив[0], Массив[1]); 
		КонецЕсли;
	КонецЦикла; 	
	
	Ответ1С = Новый Структура("Success, Description", Истина, "");
	Ответ = Неопределено;
	
	Попытка
		
		// Проверка Аутоидентификации
		ПОIPТелефонии = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсCallTouch);
		//IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
		
		Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда
			Ответ1С.Success = Ложь;
			Ответ1С.Description = "Аутентификация не пройдена (Сервис IP-телефонии не настроен)";
		//ИначеЕсли Не ПараметрыТела.crm_token = IPТелефонияПараметры.Ключ Тогда
		//	Ответ1С.Success = Ложь;        
		//	Ответ1С.Description = "Аутентификация не пройдена";
		КонецЕсли;
				
		ОбязательныйПараметр = "id";		
		
		Если Ответ1С.Success = Истина Тогда  			
			
			Если Не ПараметрыТела.Свойство(ОбязательныйПараметр) Тогда
				Ответ1С.Success = Ложь;					
				Ответ1С.Description = СтрШаблон(НСтр("ru='Отсутствует обязательный параметр %1.';en='Missing required parameter %1.'"), ОбязательныйПараметр);
			КонецЕсли;      			
			
			Если Ответ1С.Success Тогда
				Ответ1С.Success = IPТелефония.CallTouch_СобытиеЗвонок(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);
				Если Ответ1С.Success Тогда 
					
					//РегистрыСведений.СквознаяАналитика.Добавить(ПараметрыТела);
					Если ПараметрыТела.callphase = "calldisconnected" Тогда
						Ответ1С.Success = IPТелефония.CallTouch_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);					
					КонецЕсли;
					
				КонецЕсли;				
			КонецЕсли;			
		КонецЕсли;
		
		Если Ответ1С.Success = Ложь Тогда
			ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.CallTouchEvents", УровеньЖурналаРегистрации.Предупреждение, , , 
			"" + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		КонецЕсли;		
		
	Исключение
		
		Ответ1С.Success = Ложь;
		Ответ1С.Description = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		
		ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.CallTouchEvents", УровеньЖурналаРегистрации.Ошибка, , , 
		"" + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		
	КонецПопытки;
	
	Ответ = Новый HTTPСервисОтвет(200);	
	
	// Логирование
	Если ЛогироватьСобытие > 0 Тогда
		
		ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
		мОтвет                 = Ответ.ПолучитьТелоКакСтроку();
		мОтвет                 = ?(Ответ1С.Success = Ложь, Ответ1С.Description, мОтвет);
		КодОтвета              = ?(Ответ1С.Success = Ложь, 400, 200);
		Статус                 = ?(Ответ1С.Success = Ложь, Перечисления.СтатусыЗапросов.ЗавершенСОшибками, Перечисления.СтатусыЗапросов.Выполнен);
		
		Если ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЛогироватьСобытие, Статус, ВремяВыполнения) Тогда
			
			РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
				HTTPЗапросЛога, 
				ДатаЛога, 
				UIDЗапроса, 
				ТипЗапроса, 
				HTTPШаблон, 
				Статус, 
				ВремяВыполнения, 
				, 
				, 
				мОтвет, 
				, 
				,
				КодОтвета); 								
			
		КонецЕсли;
	КонецЕсли;

	Возврат Ответ;
	
КонецФункции

