		КонецЦикла;
	КонецЕсли;
	// Установка фильтров отбора шаблонов
	СписокШаблонов.Параметры.УстановитьЗначениеПараметра("ПодчиненРеквизиту",ПодчиненРеквизиту);
	СписокШаблонов.Параметры.УстановитьЗначениеПараметра("Диагноз"          ,ЗначениеЗаполнено(МассивДиагнозов));  
