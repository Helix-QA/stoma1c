// Функция - Получить представление товарных позиций
//
// Параметры:
//  ПараметрыДанных	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеТоварныхПозиций(ПараметрыДанных)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СтатусыОплатыЗаказов.Основание КАК Основание
	|ПОМЕСТИТЬ ВтОснований
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.НомерЗаказа = &НомерЗаказа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияЗапасы.Номенклатура.Наименование КАК Номенклатура,
	|	РеализацияЗапасы.КоличествоУпаковок КАК Количество,
	|	РеализацияЗапасы.Цена КАК Цена,
	|	РеализацияЗапасы.СуммаАвтоматическойСкидкиНаценки + РеализацияЗапасы.СуммаРучнойСкидки КАК Скидка,
	|	РеализацияЗапасы.Сумма КАК Сумма
	|ИЗ
	|	Документ.Реализация.Запасы КАК РеализацияЗапасы
	|ГДЕ
	|	РеализацияЗапасы.Ссылка В
	|			(ВЫБРАТЬ
	|				ВтОснований.Основание
	|			ИЗ
	|				ВтОснований)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияУслуги.Номенклатура.Наименование,
	|	РеализацияУслуги.КоличествоУпаковок,
	|	РеализацияУслуги.Цена,
	|	РеализацияУслуги.СуммаАвтоматическойСкидкиНаценки + РеализацияУслуги.СуммаРучнойСкидки,
	|	РеализацияУслуги.Сумма
	|ИЗ
	|	Документ.Реализация.Услуги КАК РеализацияУслуги
	|ГДЕ
	|	РеализацияУслуги.Ссылка В
	|			(ВЫБРАТЬ
	|				ВтОснований.Основание
	|			ИЗ
	|				ВтОснований)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЗапасы.Номенклатура.Наименование,
	|	ПриемЗапасы.КоличествоУпаковок,
	|	ПриемЗапасы.Цена,
	|	ПриемЗапасы.СуммаАвтоматическойСкидкиНаценки + ПриемЗапасы.СуммаРучнойСкидки,
	|	ПриемЗапасы.Сумма
	|ИЗ
	|	Документ.Прием.Запасы КАК ПриемЗапасы
	|ГДЕ
	|	ПриемЗапасы.Ссылка В
	|			(ВЫБРАТЬ
	|				ВтОснований.Основание
	|			ИЗ
	|				ВтОснований)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЛечение.Номенклатура.Наименование,
	|	ПриемЛечение.КоличествоУпаковок,
	|	ПриемЛечение.Цена,
	|	ПриемЛечение.СуммаАвтоматическойСкидкиНаценки + ПриемЛечение.СуммаРучнойСкидки,
	|	ПриемЛечение.Сумма
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|ГДЕ
	|	ПриемЛечение.Ссылка В
	|			(ВЫБРАТЬ
	|				ВтОснований.Основание
	|			ИЗ
	|				ВтОснований)");
	
	Запрос.УстановитьПараметр("НомерЗаказа", ПараметрыДанных.НомерЗаказа);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли;
	
	Запасы = РезультатЗапроса.Выгрузить();
	
	ПредставлениеТаблицы = "<tr><th style=""font-weight:bold;"">Наименование</th><th style=""font-weight:bold;"">Кол.</th><th style=""font-weight:bold;"">Цена</th><th style=""font-weight:bold;"">Скидка</th><th style=""font-weight:bold;"">Сумма</th></tr>";
	
	Для Каждого СтрокаТЗ Из Запасы Цикл
		ПредставлениеТаблицы = ПредставлениеТаблицы + "<tr><th>"+СтрокаТЗ.Номенклатура+"</th>"+"<th>"+СтрокаТЗ.Количество+"</th>"+"<th>"+СтрокаТЗ.Цена+"</th>"+"<th>"+СтрокаТЗ.Скидка+"</th>"+"<th>"+СтрокаТЗ.Сумма+"</th></tr>";	
	КонецЦикла;
	
	Возврат "<table style=""width: 100%;"">" + ПредставлениеТаблицы + "</table>"; 
	
КонецФункции

