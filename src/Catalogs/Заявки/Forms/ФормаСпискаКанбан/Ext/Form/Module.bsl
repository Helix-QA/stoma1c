		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовПациента_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовПациента_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтатусПациента", ПараметрыОтбора.МассивСтатусовПациента, Истина,,, ВариантОтбора);				
	КонецЕсли;
	
	СформироватьКанбан();
	
КонецПроцедуры

