// Процедура, СброситьОтборы.
//
Процедура СброситьОтборы()
	
	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборСтатус"				 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборЭтап"				 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборСотрудникРегистрации", Новый Массив());
	СтруктураОтборов.Вставить("ОтборМенеджер"			 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборРекламныйИсточник"	 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборКаналПривлечения"	 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборТеги"				 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборИнтересы"			 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборСделки"			 	 , Новый Массив());
	СтруктураОтборов.Вставить("ОтборЗадачи"				 , Новый Массив());

	// Основаня процедура, установки параметров.
	УстановитьТекстЗапросаСписку(СтруктураОтборов);		
	УправлениеИнтерфейсамиСервер.СнятьВыборВДинамическомМенюФормы(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить все отборы формы
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//
Процедура ОбновитьВсеОтборыФормы(ПараметрыОтбора)
	
	МассивИменМеню = Новый Массив();
	МассивИменМеню.Добавить("МенюОтборСтатус");
	МассивИменМеню.Добавить("МенюОтборЭтап");
	МассивИменМеню.Добавить("МенюОтборМенеджеры");
	МассивИменМеню.Добавить("МенюОтборСотрудникРегистрации");
	МассивИменМеню.Добавить("МенюОтборРекламныйИсточник");
	МассивИменМеню.Добавить("МенюОтборКаналПривлечения");
	МассивИменМеню.Добавить("МенюОтборТеги");
	МассивИменМеню.Добавить("МенюОтборИнтересы");
	МассивИменМеню.Добавить("МенюОтборСделки"); ОтборБезСделок 	= Ложь;
	МассивИменМеню.Добавить("МенюОтборЗадачи"); ОтборБезЗадач 	= Ложь;
	      
	УправлениеИнтерфейсамиСервер.СнятьВыборВДинамическомМенюФормы(ЭтаФорма, МассивИменМеню);
	УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборСтатус", "Потенциальный", Истина);
	Если ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборМенеджеры", ПараметрыОтбора.МассивМенеджеров, Истина);
	КонецЕсли;	
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборСделки", ПараметрыОтбора.МассивСтатусовНаличияСделок, Истина);
	КонецЕсли;		
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборЗадачи", ПараметрыОтбора.МассивСтатусовНаличияЗадач, Истина);
	КонецЕсли;		
	Если ПараметрыОтбора.Свойство("ПериодПланирования") Тогда 
		ОтборДатаЗапланированнойЗадачи = ПараметрыОтбора.ПериодПланирования;
		Элементы.ОтборЗапланированнаяЗадача.Заголовок = РаботаСОтборами.ОбновитьПредставлениеПериода(ОтборДатаЗапланированнойЗадачи, Нстр("ru = 'Запланированная задача: '; en = 'Scheduled task: '"));		
		ОбновитьСписок = Истина;
	Иначе 
		ОтборДатаЗапланированнойЗадачи = Неопределено;
		Элементы.ОтборЗапланированнаяЗадача.Заголовок = НСтр("ru='Запланированная задача';en='Scheduled task'");
		ОбновитьСписок = Истина;		
	КонецЕсли;
	
	ПолучитьЗначенияОтборов();
	
КонецПроцедуры

&НаСервере
// Функция, ЗаполнитьМассивДанных.
//
Функция ЗаполнитьМассивДанных(МассивОтборов, ЗаголовокОтбора, ИмяОтбора)
	
	ПодробныйМассив  = Новый Массив;
		
	Для Каждого ЭлементМассива Из МассивОтборов Цикл 
		
		Структура = Новый Структура();
		Структура.Вставить("Значение"	  , ЭлементМассива); 
		Структура.Вставить("Представление", ?(ЗначениеЗаполнено(ЭлементМассива),СокрЛП(Строка(ЭлементМассива)), НСтр("ru = 'Пустое'; en = 'Empty'")));
		Структура.Вставить("Выбор"		  , Ложь); 
		Структура.Вставить("Код"		  , XMLСтрока(ЭлементМассива));
		
		ПодробныйМассив.Добавить(Структура);
		
	КонецЦикла;
		
	МассивДанных = Новый Массив;	
	Структура 	 = Новый Структура();
	
	Структура.Вставить("Значение"			, ЗаголовокОтбора);
	Структура.Вставить("Представление"		, "Переключатель" + ИмяОтбора);
	Структура.Вставить("ИмяПодчиненногоМеню", "ПодчиненноеМенюОтбор" + ИмяОтбора);
	Структура.Вставить("МассивЗначений"		, ПодробныйМассив);
	
	МассивДанных.Добавить(Структура);	
	
	Возврат МассивДанных;
	
КонецФункции

#КонецОбласти

