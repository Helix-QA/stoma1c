#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область СлужебныйПрограммныйИнтерфейс	
	
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СписаниеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	|	СписаниеЗапасовЗапасы.Ссылка КАК Документ,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовЗапасы.Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовЗапасы.Ссылка.Склад
	|		ИНАЧЕ СписаниеЗапасовЗапасы.Склад
	|	КОНЕЦ КАК Склад,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	СписаниеЗапасовЗапасы.Ссылка.Дата КАК Период,
	|	СписаниеЗапасовЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеЗапасовЗапасы.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ИспользоватьПартии
	|			ТОГДА СписаниеЗапасовЗапасы.Партия
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|	КОНЕЦ КАК Партия,
	|	СписаниеЗапасовЗапасы.Количество КАК Количество
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасы
	|ИЗ
	|	Документ.СписаниеЗапасов.Запасы КАК СписаниеЗапасовЗапасы
	|ГДЕ
	|	СписаниеЗапасовЗапасы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(СписаниеЗапасовПоСкладу.НомерСтроки) КАК НомерСтроки,
	|	СписаниеЗапасовПоСкладу.Ссылка.Дата КАК Период,
	|	СписаниеЗапасовПоСкладу.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыПрочие) КАК СчетДт,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы) КАК СчетКт,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовПоСкладу.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовПоСкладу.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.НедостачиЗапасов)
	|	КОНЕЦ КАК СубконтоДт1,
	|	СписаниеЗапасовПоСкладу.Специализация КАК СубконтоДт2,
	|	NULL КАК СубконтоДт3,
	|	NULL КАК СубконтоДт4,
	|	СписаниеЗапасовПоСкладу.Номенклатура КАК СубконтоКт1,
	|	СписаниеЗапасовПоСкладу.Склад КАК СубконтоКт2,
	|	0 КАК Сумма,
	|	СУММА(СписаниеЗапасовПоСкладу.Количество) КАК Количество,
	|	""Списание запасов"" КАК Содержание
	|ПОМЕСТИТЬ ВременнаяТаблицаУправленческий
	|ИЗ
	|	Документ.СписаниеЗапасов.Запасы КАК СписаниеЗапасовПоСкладу
	|ГДЕ
	|	СписаниеЗапасовПоСкладу.Ссылка = &Ссылка
	|	И СписаниеЗапасовПоСкладу.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоСкладу)
	|	И СписаниеЗапасовПоСкладу.СотрудникРасхода = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	СписаниеЗапасовПоСкладу.Ссылка.Дата,
	|	СписаниеЗапасовПоСкладу.Ссылка.СтруктурнаяЕдиница,
	|	СписаниеЗапасовПоСкладу.Номенклатура,
	|	СписаниеЗапасовПоСкладу.Склад,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовПоСкладу.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовПоСкладу.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.НедостачиЗапасов)
	|	КОНЕЦ,
	|	СписаниеЗапасовПоСкладу.Специализация
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СУММА(СписаниеЗапасовПоПерсоананалу.НомерСтроки),
	|	СписаниеЗапасовПоПерсоананалу.Ссылка.Дата,
	|	СписаниеЗапасовПоПерсоананалу.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.РасходыСебестоимость),
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.Запасы),
	|	СписаниеЗапасовПоПерсоананалу.Специализация,
	|	NULL,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовПоПерсоананалу.СотрудникРасхода <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовПоПерсоананалу.СотрудникРасхода
	|		ИНАЧЕ СписаниеЗапасовПоПерсоананалу.Склад
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовПоПерсоананалу.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовПоПерсоананалу.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.НедостачиЗапасов)
	|	КОНЕЦ,
	|	СписаниеЗапасовПоПерсоананалу.Номенклатура,
	|	СписаниеЗапасовПоПерсоананалу.Склад,
	|	0,
	|	СУММА(СписаниеЗапасовПоПерсоананалу.Количество),
	|	""Списание запасов""
	|ИЗ
	|	Документ.СписаниеЗапасов.Запасы КАК СписаниеЗапасовПоПерсоананалу
	|ГДЕ
	|	СписаниеЗапасовПоПерсоананалу.Ссылка = &Ссылка
	|	И (СписаниеЗапасовПоПерсоананалу.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоСотруднику)
	|			ИЛИ СписаниеЗапасовПоПерсоананалу.СотрудникРасхода <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка))
	|
	|СГРУППИРОВАТЬ ПО
	|	СписаниеЗапасовПоПерсоананалу.Ссылка.Дата,
	|	СписаниеЗапасовПоПерсоананалу.Ссылка.СтруктурнаяЕдиница,
	|	СписаниеЗапасовПоПерсоананалу.Номенклатура,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовПоПерсоананалу.СтатьяРасходов <> ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовПоПерсоананалу.СтатьяРасходов
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.НедостачиЗапасов)
	|	КОНЕЦ,
	|	СписаниеЗапасовПоПерсоананалу.Специализация,
	|	ВЫБОР
	|		КОГДА СписаниеЗапасовПоПерсоананалу.СотрудникРасхода <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|			ТОГДА СписаниеЗапасовПоПерсоананалу.СотрудникРасхода
	|		ИНАЧЕ СписаниеЗапасовПоПерсоананалу.Склад
	|	КОНЕЦ,
	|	СписаниеЗапасовПоПерсоананалу.Склад";
	
	
	Запрос.УстановитьПараметр("Ссылка"            , ДокументСсылка);
	Запрос.УстановитьПараметр("ИспользоватьПартии", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьПартии);
	
	Запрос.ВыполнитьПакет();
	СформироватьТаблицаЗапасыНаСкладах(ДокументСсылка, СтруктураДополнительныеСвойства);
	СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗапасыНаСкладах(ДокументСсылка, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МИНИМУМ(ТаблицаЗапасыНаСкладах.НомерСтроки) КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаЗапасыНаСкладах.Период КАК Период,
	|	ТаблицаЗапасыНаСкладах.Склад КАК Склад,
	|	ТаблицаЗапасыНаСкладах.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаЗапасыНаСкладах.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасыНаСкладах.Партия КАК Партия,
	|	СУММА(ТаблицаЗапасыНаСкладах.Количество) КАК Количество
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаЗапасыНаСкладах
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаЗапасыНаСкладах.Период,
	|	ТаблицаЗапасыНаСкладах.Склад,
	|	ТаблицаЗапасыНаСкладах.СтруктурнаяЕдиница,
	|	ТаблицаЗапасыНаСкладах.Номенклатура,
	|	ТаблицаЗапасыНаСкладах.Партия";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасыНаСкладах", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаЗапасыНаСкладах()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаУправленческий(СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВременнаяТаблицаУправленческий.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаУправленческий.Период,
	|	ВременнаяТаблицаУправленческий.СтруктурнаяЕдиница,
	|	ВременнаяТаблицаУправленческий.СчетДт,
	|	ВременнаяТаблицаУправленческий.СчетКт,
	|	ВременнаяТаблицаУправленческий.СубконтоДт1,
	|	ВременнаяТаблицаУправленческий.СубконтоДт2,
	|	ВременнаяТаблицаУправленческий.СубконтоДт3,
	|	ВременнаяТаблицаУправленческий.СубконтоДт4,
	|	ВременнаяТаблицаУправленческий.СубконтоКт1,
	|	ВременнаяТаблицаУправленческий.СубконтоКт2,
	|	ВременнаяТаблицаУправленческий.Сумма КАК Сумма,
	|	ВременнаяТаблицаУправленческий.Количество КАК Количество,
	|	ВременнаяТаблицаУправленческий.Содержание
	|ИЗ
	|	ВременнаяТаблицаУправленческий КАК ВременнаяТаблицаУправленческий
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаУправленческий", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// Процедуры печати документа.

//
//
Функция ПечатьАктаСписанияТоваров(МассивОбъектов, ОбъектыПечати)
	
	ЗапросПоДокументам = Новый Запрос;
	ЗапросПоДокументам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоДокументам.Текст =   "ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	СписаниеЗапасов.Ссылка,
	|	СписаниеЗапасов.Номер,
	|	СписаниеЗапасов.Дата,
	|	СписаниеЗапасов.Склад,
	|	СписаниеЗапасов.СтруктурнаяЕдиница.Организация КАК Организация,
	|	СписаниеЗапасов.СтруктурнаяЕдиница.Организация.Наименование КАК ОрганизацияПредставление,
	|	СписаниеЗапасов.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
	|	ПРЕДСТАВЛЕНИЕ(СписаниеЗапасов.Склад) КАК СкладПредставление,
	|	СписаниеЗапасов.ДокументОснование КАК ДокументОснование,
	|	ПРЕДСТАВЛЕНИЕ(СписаниеЗапасов.ДокументОснование) КАК ОснованиеПредставление
	|ИЗ
	|	Документ.СписаниеЗапасов КАК СписаниеЗапасов
	|ГДЕ
	|	СписаниеЗапасов.Ссылка В(&МассивОбъектов)";
	
	ЗапросПоТоварам = Новый Запрос;
	ЗапросПоТоварам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоТоварам.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СписаниеЗапасов.Ссылка,
	|	СписаниеЗапасовЗапасы.Номенклатура,
	|	СписаниеЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	|	СписаниеЗапасовЗапасы.КоличествоУпаковок КАК Количество,
	|	СписаниеЗапасовЗапасы.Номенклатура.НаименованиеПолное КАК НоменклатураПредставление,
	|	ПРЕДСТАВЛЕНИЕ(СписаниеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения) КАК ЕдиницаИзмеренияПредставление,
	|	СписаниеЗапасовЗапасы.Упаковка,
	|	СписаниеЗапасовЗапасы.Партия
	|ИЗ
	|	Документ.СписаниеЗапасов.Запасы КАК СписаниеЗапасовЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеЗапасов КАК СписаниеЗапасов
	|		ПО СписаниеЗапасовЗапасы.Ссылка = СписаниеЗапасов.Ссылка
	|ГДЕ
	|	СписаниеЗапасов.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РеквизитыДокумента = Новый Структура("Номер, Дата, Префикс");
	СинонимДокумента = НСтр("ru='Акт о списании товаров'");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_СписаниеТоваров_АктОСписанииТоваров";
	
	Макет 				= УправлениеПечатью.МакетПечатнойФормы("Документ.СписаниеЗапасов.ПФ_MXL_АктОСписанииТоваров");
	// ОбластьЗаголовок 	= Макет.ПолучитьОбласть("Заголовок");
	
	ОбластьНомераЗаголовок			= Макет.ПолучитьОбласть("Заголовок|НомерСтроки");
	ОбластьКолонкаКодовЗаголовок	= Макет.ПолучитьОбласть("Заголовок|КолонкаКодов");
	ОбластьТоварЗаголовок			= Макет.ПолучитьОбласть("Заголовок|Товар");
	ОбластьДанныеЗаголовок			= Макет.ПолучитьОбласть("Заголовок|Данные");
	
	ОбластьОрганизацияСклад 		= Макет.ПолучитьОбласть("ОрганизацияСклад");
	
	ОбластьОснование  				= Макет.ПолучитьОбласть("Основание");
	
	ОбластьНомераШапка				= Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
	ОбластьКолонкаКодовШапка		= Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
	ОбластьТоварШапка				= Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
	ОбластьДанныеШапка				= Макет.ПолучитьОбласть("ШапкаТаблицы|Данные");
	
	ОбластьНомераСтрока 			= Макет.ПолучитьОбласть("Строка1|НомерСтроки");
	ОбластьКолонкаКодовСтрока  		= Макет.ПолучитьОбласть("Строка1|КолонкаКодов");
	ОбластьТоварСтрока  			= Макет.ПолучитьОбласть("Строка1|Товар");
	ОбластьДанныхСтрока 			= Макет.ПолучитьОбласть("Строка1|Данные");
	
	ОбластьНомераПодвалТаблицы 		= Макет.ПолучитьОбласть("ПодвалТаблицы|НомерСтроки");
	ОбластьКолонкаКодовПодвал  		= Макет.ПолучитьОбласть("ПодвалТаблицы|КолонкаКодов");
	ОбластьТоварПодвалТаблицы  		= Макет.ПолучитьОбласть("ПодвалТаблицы|Товар");
	ОбластьДанныхПодвалТаблицы 		= Макет.ПолучитьОбласть("ПодвалТаблицы|Данные");
	
	ОбластьНомераПодписиЛиния 		= Макет.ПолучитьОбласть("ПодписиЛиния|НомерСтроки");
	ОбластьКолонкаКодовПодписиЛиния	= Макет.ПолучитьОбласть("ПодписиЛиния|КолонкаКодов");
	ОбластьТоварПодвалПодписиЛиния 	= Макет.ПолучитьОбласть("ПодписиЛиния|Товар");
	ОбластьДанныхПодписиЛиния 		= Макет.ПолучитьОбласть("ПодписиЛиния|Данные");
	
	ОбластьПодписи       = Макет.ПолучитьОбласть("Подписи");
	ОбластьСуммаПрописью = Макет.ПолучитьОбласть("СуммаПрописью");
	
	ВыборкаДокументы = ЗапросПоДокументам.Выполнить().Выбрать();
	ПервыйДокумент = Истина;
	
	ДопКолонка = ЗначениеНастроекПовтИсп.ПолучитьЗначениеКонстанты("ДополнительнаяКолонкаПечатныхФормДокументов");
	Если ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Артикул Тогда
		ВыводитьКоды = Истина;
		Колонка = "Артикул";
	ИначеЕсли ДопКолонка = Перечисления.ДополнительнаяКолонкаПечатныхФормДокументов.Код Тогда
		ВыводитьКоды = Истина;
		Колонка = "Код";
	Иначе
		ВыводитьКоды = Ложь;
	КонецЕсли;
	
	Пока ВыборкаДокументы.Следующий() Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		
		// Выводим шапку накладной.
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента, ВыборкаДокументы);
		
		ОбластьНомераЗаголовок.Параметры.ТекстЗаголовка = ФормированиеПечатныхФорм.СформироватьЗаголовокДокумента(РеквизитыДокумента, СинонимДокумента);
		ТабДокумент.Вывести(ОбластьНомераЗаголовок);
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКолонкаКодовЗаголовок);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьТоварЗаголовок);
		ТабДокумент.Присоединить(ОбластьДанныеЗаголовок);
		
		ОбластьОрганизацияСклад.Параметры.Заполнить(ВыборкаДокументы);
		ТабДокумент.Вывести(ОбластьОрганизацияСклад);
		
		Если ЗначениеЗаполнено(ВыборкаДокументы.ДокументОснование) Тогда
			ОбластьОснование.Параметры.ОснованиеПредставление = ВыборкаДокументы.ОснованиеПредставление;
			ТабДокумент.Вывести(ОбластьОснование);
		КонецЕсли;
		
		// Вывод шапки.
		ТабДокумент.Вывести(ОбластьНомераШапка);
		
		Если ВыводитьКоды Тогда
			ОбластьКолонкаКодовШапка.Параметры.ДопКолонка = Колонка;
			ТабДокумент.Присоединить(ОбластьКолонкаКодовШапка);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьТоварШапка);
		
		ТабДокумент.Присоединить(ОбластьДанныеШапка);
		
		ВсегоНаименований = 0;
		
		// Вывод строк.
		
		РезультатыПоТоварам = ЗапросПоТоварам.ВыполнитьПакет();
		
		ВыборкаПоСтрокам = РезультатыПоТоварам[0].Выбрать();
		
		Пока ВыборкаПоСтрокам.Следующий() Цикл
			
			ОбластьНомераСтрока.Параметры.Заполнить(ВыборкаПоСтрокам);
			ТабДокумент.Вывести(ОбластьНомераСтрока);
			
			Если ВыводитьКоды Тогда
				Если Колонка = "Артикул" Тогда
					ОбластьКолонкаКодовСтрока.Параметры.ДопКолонка = ВыборкаПоСтрокам.Номенклатура.Артикул;
				Иначе
					ОбластьКолонкаКодовСтрока.Параметры.ДопКолонка = ВыборкаПоСтрокам.Номенклатура.Код;
				КонецЕсли;
				ТабДокумент.Присоединить(ОбластьКолонкаКодовСтрока);
			КонецЕсли;
			
			// Номенклатура.
		    ОбластьТоварСтрока.Параметры.Заполнить(ВыборкаПоСтрокам);
			ОбластьТоварСтрока.Параметры.НоменклатураПредставление = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(
			ВыборкаПоСтрокам.НоменклатураПредставление,
			Неопределено);
			
			ТабДокумент.Присоединить(ОбластьТоварСтрока);
			
			ОбластьДанныхСтрока.Параметры.Заполнить(ВыборкаПоСтрокам);
			
			Если НЕ ВыборкаПоСтрокам.Упаковка = Справочники.УпаковкиНоменклатуры.ПустаяСсылка() Тогда
				ОбластьДанныхСтрока.Параметры.ЕдиницаИзмеренияПредставление = ВыборкаПоСтрокам.Упаковка.Наименование + " (" + ВыборкаПоСтрокам.Упаковка.Коэффициент + ")";
			КонецЕсли;
			
			ТабДокумент.Присоединить(ОбластьДанныхСтрока);
			
			ВсегоНаименований = ВсегоНаименований + 1;
			
		КонецЦикла;
		
		// Вывод итогов.
		ТабДокумент.Вывести(ОбластьНомераПодвалТаблицы);
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКолонкаКодовПодвал);
		КонецЕсли;
		ТабДокумент.Присоединить(ОбластьТоварПодвалТаблицы);
		ТабДокумент.Присоединить(ОбластьДанныхПодвалТаблицы);
		
		// Вывод подписей.
		Кладовщик = ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(ВыборкаДокументы.Организация,Перечисления.ТипыОтветственныхЛиц.Кладовщик,ВыборкаДокументы.Дата);
		Если Кладовщик.Количество() > 0 Тогда
			ОбластьПодписи.Параметры.Кладовщик = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(Кладовщик[0].Сотрудник));
		КонецЕсли;	 
		ТабДокумент.Вывести(ОбластьПодписи);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаДокументы.Ссылка);
		
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабДокумент;
	
КонецФункции  

// Функция, "ПечатьТребованиеНакладная"
//
Функция ПечатьТребованиеНакладная(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_СписаниеТоваров_ТребованиеНакладная"; 
	ТабличныйДокумент.РазмерСтраницы      = "A4"; 
	ПервыйДокумент                        = Истина;
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент    = Ложь;
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СписаниеЗапасов.Ссылка КАК Ссылка,
		|	СписаниеЗапасов.Номер КАК Номер,
		|	СписаниеЗапасов.Дата КАК Дата,
		|	ПРЕДСТАВЛЕНИЕ(СписаниеЗапасов.СтруктурнаяЕдиница) КАК СЕОтправитель,
		|	ПРЕДСТАВЛЕНИЕ(СписаниеЗапасов.СтруктурнаяЕдиница.Организация) КАК Организация,
		|	СписаниеЗапасов.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
		|	СписаниеЗапасов.СтруктурнаяЕдиница.Организация.КодПоОКПО КАК КодПоОКПО
		|ИЗ
		|	Документ.СписаниеЗапасов КАК СписаниеЗапасов
		|ГДЕ
		|	СписаниеЗапасов.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СписаниеЗапасов.Ссылка КАК Ссылка,
		|	СписаниеЗапасовЗапасы.Номенклатура.НаименованиеПолное КАК НоменклатураНаименованиеПолное,
		|	СписаниеЗапасовЗапасы.Номенклатура.Наименование КАК НоменклатураНаименование,
		|	СписаниеЗапасовЗапасы.Номенклатура.Артикул КАК НомерНом,
		|	КлассификаторЕдиницИзмерения.Наименование КАК НаимЕд,
		|	КлассификаторЕдиницИзмерения.Код КАК КодЕд,
		|	СписаниеЗапасовЗапасы.КоличествоУпаковок КАК КолВоОтпущ
		|ИЗ
		|	Документ.СписаниеЗапасов.Запасы КАК СписаниеЗапасовЗапасы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеЗапасов КАК СписаниеЗапасов
		|		ПО СписаниеЗапасовЗапасы.Ссылка = СписаниеЗапасов.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
		|		ПО СписаниеЗапасовЗапасы.Номенклатура.ЕдиницаИзмерения = КлассификаторЕдиницИзмерения.Ссылка
		|ГДЕ
		|	СписаниеЗапасов.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	СписаниеЗапасовЗапасы.НомерСтроки"); 
		Запрос.УстановитьПараметр("Ссылка", ТекущийДокумент);
		РезультатЗапроса = Запрос.ВыполнитьПакет(); 
		ВыборкаДокументы = РезультатЗапроса[0].Выбрать();
		ТаблицаЗапасов   = РезультатЗапроса[1].Выгрузить(); 
		
		Макет 			 = УправлениеПечатью.МакетПечатнойФормы("Документ.СписаниеЗапасов.ПФ_MXL_ТребованиеНакладная_М27");
		СинонимДокумента = "ТРЕБОВАНИЕ-НАКЛАДНАЯ № ";
		
		Пока ВыборкаДокументы.Следующий() Цикл
			
			ОбластьШапка 	                       = Макет.ПолучитьОбласть("Шапка"); 
			ОбластьШапка.Параметры.Заполнить(ВыборкаДокументы); 
			ОбластьШапка.Параметры.ТекстЗаголовка  = СинонимДокумента + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(ВыборкаДокументы.Номер, ВыборкаДокументы.Префикс);     
			ОбластьШапка.Параметры.ДатаДок         = Формат(ВыборкаДокументы.Дата, "ДФ=dd.MM.yyyy"); 
			ОбластьШапка.Параметры.ДатаДокПрописью = " от " + Формат(ВыборкаДокументы.Дата, "ДФ='дд ММММ гггг'") + " г.";
			ТабличныйДокумент.Вывести(ОбластьШапка); 		 
			
			Если ЗначениеЗаполнено(ТаблицаЗапасов) Тогда
				ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
				ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);
				ОбластьСтрока = Макет.ПолучитьОбласть("Строка"); 
			КонецЕсли;	 
			Для Каждого Строка Из ТаблицаЗапасов Цикл
				ОбластьСтрока.Параметры.Заполнить(Строка);
				ОбластьСтрока.Параметры.НоменклатураПредставление = ?(ЗначениеЗаполнено(Строка.НоменклатураНаименованиеПолное), Строка.НоменклатураНаименованиеПолное,
				Строка.Номенклатура);
				ТабличныйДокумент.Вывести(ОбластьСтрока);
			КонецЦикла; 
			Если ЗначениеЗаполнено(ТаблицаЗапасов) Тогда
				ОбластьИтог = Макет.ПолучитьОбласть("Итог");
				ТабличныйДокумент.Вывести(ОбластьИтог);  
			КонецЕсли;
			ОбластьПодвал = Макет.ПолучитьОбласть("Подвал"); 			
			ТабличныйДокумент.Вывести(ОбластьПодвал); 	
			
			//УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаДокументы.Ссылка);
		КонецЦикла;
	КонецЦикла;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

//
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктСписанияТоваров") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АктСписанияТоваров",
		"Акт о списании товаров",
		ПечатьАктаСписанияТоваров(МассивОбъектов, ОбъектыПечати));
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТребованиеНакладная(М27)") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТребованиеНакладная(М27)",
		"Требование накладная (М27)",
		ПечатьТребованиеНакладная(МассивОбъектов, ОбъектыПечати));
		
	КонецЕсли;
	
КонецПроцедуры

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("АктСписанияТоваров", "Акт о списании запасов", , БиблиотекаКартинок.Документ);
	Список.Добавить("ТребованиеНакладная(М27)", "Требование - накладная (М27)", ,  БиблиотекаКартинок.Документ); 	
	Возврат Список;
	
КонецФункции


#Область ЗагрузкаДанныхИзВнешнегоИсточника

Процедура ПоляЗагрузкиДанныхИзВнешнегоИсточника(ТаблицаПолейЗагрузки, НастройкиЗагрузкиДанных) Экспорт
	
	//
	// Для группы полей действует правило: хотя бы одно поле в группе должно быть выбрано в колонках
	//
	
	ПолноеИмяОбъектаЗаполнения = НастройкиЗагрузкиДанных.ПолноеИмяОбъектаЗаполнения;
	
	ОписаниеТиповСтрока25 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(25));
	ОписаниеТиповСтрока30 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(30));
	ОписаниеТиповСтрока50 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(50));
	ОписаниеТиповСтрока100 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	ОписаниеТиповСтрока150 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(150));
	ОписаниеТиповСтрока200 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(200));
	ОписаниеТиповСтрока1000 = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(1000));
	ОписаниеТиповЧисло15_2 = Новый ОписаниеТипов("Число", , , , Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Неотрицательный));
	ОписаниеТиповЧисло15_3 = Новый ОписаниеТипов("Число", , , , Новый КвалификаторыЧисла(15, 3, ДопустимыйЗнак.Неотрицательный));
	
	ЭтоЗапасы = (ПолноеИмяОбъектаЗаполнения = "Документ.СписаниеЗапасов.ТабличнаяЧасть.Запасы");
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Родитель", "Группа", ОписаниеТиповСтрока100, ОписаниеТиповКолонка, , , , );
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Код", "Код", ОписаниеТиповСтрока25, ОписаниеТиповКолонка, "Номенклатура", 1, , Истина);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Штрихкод", "Штрихкод", ОписаниеТиповСтрока200, ОписаниеТиповКолонка, "Номенклатура", 2, , Истина);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Артикул", "Артикул", ОписаниеТиповСтрока25, ОписаниеТиповКолонка, "Номенклатура", 3, , Истина);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НоменклатураНаименование","Номенклатура (наименование)", ОписаниеТиповСтрока100, ОписаниеТиповКолонка, "Номенклатура", 4, , Истина);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "НоменклатураНаименованиеПолное","Номенклатура (полное наименование)", ОписаниеТиповСтрока1000, ОписаниеТиповКолонка, "Номенклатура", 5, , Истина);
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "КодСинхронизации", "Код синхронизации", ОписаниеТиповСтрока25, ОписаниеТиповКолонка, "Номенклатура", 6,,Истина);
	
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Партия", "Партия (наименование)", ОписаниеТиповСтрока150, ОписаниеТиповКолонка);	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Количество", "Количество", ОписаниеТиповСтрока25, ОписаниеТиповЧисло15_3, , , Истина);	
	//ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Цена", "Цена", ОписаниеТиповСтрока25, ОписаниеТиповЧисло15_2, , ,);	
		
	ОписаниеТиповКолонка = Новый ОписаниеТипов("СправочникСсылка.УпаковкиНоменклатуры");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "УпаковкаПоУмолчанию", "Упаковка поступления", ОписаниеТиповСтрока25, ОписаниеТиповКолонка);
	//ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "УпаковкаПродажи", "Упаковка продажи", ОписаниеТиповСтрока25, ОписаниеТиповКолонка);
	
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Коэффициент", "Коэффициент упаковки", ОписаниеТиповСтрока25, ОписаниеТиповЧисло15_2);

КонецПроцедуры

Процедура ПриОпределенииОбразцовЗагрузкиДанных(НастройкиЗагрузкиДанных, УникальныйИдентификатор) Экспорт
	
	Образец_xlsx = ПолучитьМакет("ОбразецЗагрузкиДанных_xlsx");
	ОбразецЗагрузкиДанных_xlsx = ПоместитьВоВременноеХранилище(Образец_xlsx, УникальныйИдентификатор);
	НастройкиЗагрузкиДанных.Вставить("ОбразецЗагрузкиДанных_xlsx", ОбразецЗагрузкиДанных_xlsx);
	
КонецПроцедуры

Процедура СопоставитьЗагружаемыеДанныеИзВнешнегоИсточника(ПараметрыСопоставления, АдресРезультата) Экспорт
	
	НастройкиОбновленияСвойств  = ПараметрыСопоставления.НастройкиЗагрузкиДанных.НастройкиОбновленияСвойств;
	ТаблицаСопоставленияДанных	= ПараметрыСопоставления.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	НастройкиЗагрузкиДанных		= ПараметрыСопоставления.НастройкиЗагрузкиДанных;
	ПолноеИмяОбъектаЗаполнения 	= НастройкиЗагрузкиДанных.ПолноеИмяОбъектаЗаполнения;

	// ТаблицаСопоставленияДанных - Тип ДанныеФормыКоллекция
	Для каждого СтрокаТаблицыФормы Из ТаблицаСопоставленияДанных Цикл
		
		// Номенклатура по ШтрихКоду, Артикулу, Наименованию, НаименованиеПолное, Код, КодСинхронизации
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьНоменклатуру(СтрокаТаблицыФормы.Номенклатура, 
			СтрокаТаблицыФормы.Штрихкод, 
			СтрокаТаблицыФормы.Артикул, 
			СтрокаТаблицыФормы.НоменклатураНаименование, 
			СтрокаТаблицыФормы.НоменклатураНаименованиеПолное, 
			СтрокаТаблицыФормы.Код,
			СтрокаТаблицыФормы.КодСинхронизации);
		ЭтаСтрокаСопоставлена = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура);
		
		// Родитель по наименованию
		ЗначениеПоУмолчанию = Справочники.Номенклатура.ПустаяСсылка();
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьРодителя("Номенклатура", СтрокаТаблицыФормы.Родитель, СтрокаТаблицыФормы.Родитель_ВходящиеДанные, ЗначениеПоУмолчанию);
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицыФормы.Родитель)
			И ЗначениеЗаполнено(СтрокаТаблицыФормы.Родитель_ВходящиеДанные) Тогда
			
			ГруппаНоменклатуры = Справочники.Номенклатура.СоздатьГруппу();
			ГруппаНоменклатуры.Наименование = СтрокаТаблицыФормы.Родитель_ВходящиеДанные;
			ГруппаНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас;
			ГруппаНоменклатуры.Записать();
			СтрокаТаблицыФормы.Родитель = ГруппаНоменклатуры.Ссылка;
			
		КонецЕсли;
		
		// Упаковк по умолчанию
		ЗначениеПоУмолчанию = Справочники.УпаковкиНоменклатуры.ПустаяСсылка();
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьУпаковку(СтрокаТаблицыФормы.УпаковкаПоУмолчанию, СтрокаТаблицыФормы.УпаковкаПоУмолчанию_ВходящиеДанные, СтрокаТаблицыФормы.Номенклатура, ЗначениеПоУмолчанию);
		
		// Коэффициент
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Коэффициент, СтрокаТаблицыФормы.Коэффициент_ВходящиеДанные, 1);
		
		Если НЕ ЭтаСтрокаСопоставлена
			И ЗначениеЗаполнено(СтрокаТаблицыФормы.НоменклатураНаименование) Тогда
						
			ЭлементСправочника = Справочники.Номенклатура.СоздатьЭлемент();	
			ЭлементСправочника.Заполнить(Новый Структура("Родитель", СтрокаТаблицыФормы.Родитель));
			ЗаполнитьЗначенияСвойств(ЭлементСправочника, СтрокаТаблицыФормы, , ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СтандартныеИменаПолейНеподлежащихОбновлению(ПараметрыСопоставления.НастройкиЗагрузкиДанных));
			ЭлементСправочника.Записать();
			СтрокаТаблицыФормы.Номенклатура = ЭлементСправочника.Ссылка;
			
			ЭлементСправочника.Наименование = СтрокаТаблицыФормы.НоменклатураНаименование;
			ЭлементСправочника.НаименованиеПолное = ?(ПустаяСтрока(СтрокаТаблицыФормы.НоменклатураНаименованиеПолное), СтрокаТаблицыФормы.НоменклатураНаименование, СтрокаТаблицыФормы.НоменклатураНаименованиеПолное);
			ЭлементСправочника.ЭтоУслуга = ?(ЭлементСправочника.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга, Истина, Ложь);
			ЭлементСправочника.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
						
			Если Не ЗначениеЗаполнено(СтрокаТаблицыФормы.УпаковкаПоУмолчанию)
				И ЗначениеЗаполнено(СтрокаТаблицыФормы.УпаковкаПоУмолчанию_ВходящиеДанные) Тогда
				
				// Создать упаковку по умолчанию
				НоваяУпаковка = Справочники.УпаковкиНоменклатуры.СоздатьЭлемент();
				НоваяУпаковка.Владелец     = ЭлементСправочника.Ссылка;
				НоваяУпаковка.Наименование = СтрокаТаблицыФормы.УпаковкаПоУмолчанию_ВходящиеДанные;
				НоваяУпаковка.Коэффициент  = СтрокаТаблицыФормы.Коэффициент;
				НоваяУпаковка.Записать();
			 
				ЭлементСправочника.УпаковкаПоУмолчанию = НоваяУпаковка.Ссылка;
				СтрокаТаблицыФормы.УпаковкаПоУмолчанию = НоваяУпаковка.Ссылка;
								
			КонецЕсли;
			
			ЭлементСправочника.Записать();

		КонецЕсли;
				
		// Если ПолноеИмяОбъектаЗаполнения = "Документ.ВозвратПоставщику.ТабличнаяЧасть.Запасы" Тогда
		//	
		Если СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Запас Тогда			
			СтрокаТаблицыФормы.Номенклатура = Неопределено;			
		КонецЕсли;
			
			//// Партия по Владельцу и Наименованию
			// ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьПартию(СтрокаТаблицыФормы.Партия, СтрокаТаблицыФормы.Номенклатура, СтрокаТаблицыФормы.Штрихкод, СтрокаТаблицыФормы.Партия_ВходящиеДанные);
						
			// ХарактеристикаСсылка = Справочники.ПартииНоменклатуры.ПустаяСсылка();
			Если ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура) Тогда
				
				СсылкаНомеклатуры = СтрокаТаблицыФормы.Номенклатура.Ссылка;
				Если ЗначениеЗаполнено(СтрокаТаблицыФормы.Партия_ВходящиеДанные) Тогда
					
					НомеклатураОбъект = СсылкаНомеклатуры.ПолучитьОбъект();
					Если НомеклатураОбъект.ИспользоватьПартии = Ложь Тогда
						НомеклатураОбъект.ИспользоватьПартии = Истина;
						НомеклатураОбъект.Записать();
					КонецЕсли;
					
					НоваяХарактеристика = Справочники.ПартииНоменклатуры.Выбрать(, СсылкаНомеклатуры, Новый Структура("Наименование", СтрокаТаблицыФормы.Партия_ВходящиеДанные));
					Если НоваяХарактеристика.Следующий() Тогда
						СтрокаТаблицыФормы.Партия = НоваяХарактеристика.Ссылка;
					Иначе
						НоваяХарактеристика              = Справочники.ПартииНоменклатуры.СоздатьЭлемент();
						НоваяХарактеристика.Владелец     = СсылкаНомеклатуры;
						НоваяХарактеристика.Наименование = СтрокаТаблицыФормы.Партия_ВходящиеДанные;
						НоваяХарактеристика.Записать();
						СтрокаТаблицыФормы.Партия = НоваяХарактеристика.Ссылка;
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
	
		// КонецЕсли;
								
		// Количество
		ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Количество, СтрокаТаблицыФормы.Количество_ВходящиеДанные, 1);
		
		//// Цена
		// ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Цена, СтрокаТаблицыФормы.Цена_ВходящиеДанные, 0);
		
		ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения);
		
		ЗагрузкаДанныхИзВнешнегоИсточника.ПрогрессСопоставленияДанных(ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицыФормы), РазмерТаблицыДанных);
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ТаблицаСопоставленияДанных, АдресРезультата);
	
КонецПроцедуры

Процедура ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения = "") Экспорт
	
	ИмяСлужебногоПоля = ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна();
	
	Если ПолноеИмяОбъектаЗаполнения = "Документ.СписаниеЗапасов.ТабличнаяЧасть.Запасы" Тогда
		
		СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура)
			И СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас
			И СтрокаТаблицыФормы.Количество <> 0;
				
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти

#КонецЕсли