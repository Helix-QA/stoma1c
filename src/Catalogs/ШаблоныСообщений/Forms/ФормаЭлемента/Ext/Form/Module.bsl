&НаКлиенте
Перем Документ;

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СформироватьПолеВвода();
	
	ОтображниеКода = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Если ОтображниеКода Тогда
		Элементы.Код.Видимость = Истина;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	Иначе 
		Элементы.Код.Видимость = Ложь;
		Элементы.Код.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	Дерево = РеквизитФормыВЗначение("ОбъектДеревоРеквизитов");
	
	ТаблицаПараметров = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуПараметровВсехПодставляемыхРеквизитов();
	ТаблицаРодителейПараметров = ТаблицаПараметров.Скопировать(, "ПредставлениеОсновнойТаблицаОбъекта");
	ТаблицаРодителейПараметров.Свернуть("ПредставлениеОсновнойТаблицаОбъекта");
	
	Для Каждого СтрокаРодитель Из ТаблицаРодителейПараметров Цикл 
		РодительСтрок = ДобавитьСтрокуВДеревоЗначений(Дерево, СтрокаРодитель.ПредставлениеОсновнойТаблицаОбъекта, СтрокаРодитель.ПредставлениеОсновнойТаблицаОбъекта, Ложь, , БиблиотекаКартинок.ИконкаПапкиДляСписка);
		МассивПараметров = ТаблицаПараметров.НайтиСтроки(Новый Структура("ПредставлениеОсновнойТаблицаОбъекта", СтрокаРодитель.ПредставлениеОсновнойТаблицаОбъекта));
		Для Каждого ЭлементМассива Из МассивПараметров Цикл 
			ДобавитьСтрокуВДеревоЗначений(РодительСтрок, ЭлементМассива.НаименованиеПараметра, ЭлементМассива.ПредставлениеПараметра, , , БиблиотекаКартинок.ИконкаЭлементДляСписка);
		КонецЦикла;	
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(Дерево, "ОбъектДеревоРеквизитов");	
	ЭтотОбъект.СодержаниеФД.Добавить(Объект.Содержание);
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаСервере
// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)	
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	УстановитьТекстШаблона(ТекущийОбъект);

КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
	
	СформироватьПолеВвода();	
	Элементы.СодержаниеМессенджерHTML.Документ.defaultView.templateValue = Объект.СодержаниеМессенджерHTML;
	
	КоллекцияЭлементовДерева = ОбъектДеревоРеквизитов.ПолучитьЭлементы();	
	Для Каждого Строка Из КоллекцияЭлементовДерева Цикл
		Если Строка.НаименованиеПараметра = АктуальныйРаздел Тогда 
			ИдентификаторСтроки = Строка.ПолучитьИдентификатор();
			Элементы.ДеревоРеквизитов.Развернуть(ИдентификаторСтроки);
		КонецЕсли;	
	КонецЦикла;
	АктуальныйРаздел = "";
	
	ПроцедураОбработкиНажатияМеню("ШаблонМессенджера", Истина);
	ЗадачаПериодВыполненияПриИзменении(ЭтаФорма.Элементы.Найти("ЗадачаПериодВыполнения"));	
	// АктивацияПунктаМеню ();
	
	// Заголовок= "Введите текст!";
	Список = Элементы.КомандаformatBlock.СписокВыбора;
	Список.Добавить("<p>", "Обычный");
	Список.Добавить("<h1>", "Заголовок 1");
	Список.Добавить("<h2>", "Заголовок 2");
	Список.Добавить("<h3>", "Заголовок 3");
	Список.Добавить("<h4>", "Заголовок 4");
	Список.Добавить("<h5>", "Заголовок 5");
	Список.Добавить("<h6>", "Заголовок 6");
	Список.Добавить("<pre>", "Форматированный");
	Список.Добавить("<address>", "Адрес");
	ТекЭлемент = Список.НайтиПоИдентификатору(0);
	СтилиТекста = ТекЭлемент.Значение;

	// Заполнение списка шрифтов
	Список = Элементы.КомандаFontName.СписокВыбора;
	Список.Добавить("Arial");
	Список.Добавить("Arial Black");
	Список.Добавить("Arial Narrow");
	Список.Добавить("Comic Sans MS");
	Список.Добавить("Courier New");
	Список.Добавить("System");
	Список.Добавить("Tahoma");
	Список.Добавить("Times New Roman");
	Список.Добавить("Verdana");
	Список.Добавить("Wingdings");
	ТекЭлемент = Список.НайтиПоИдентификатору(0);
    ИмяШрифта = ТекЭлемент.Значение;
	
	// Заполнение списка размеров
	Список = Элементы.КомандаFontSize.СписокВыбора;
	Для Ном = 1 По 14 Цикл
		Список.Добавить(Ном);
	КонецЦикла;
	ТекЭлемент = Список.НайтиПоИдентификатору(2);
	РазмерыШрифта = ТекЭлемент.Значение;	
	
	ОбновитьСтатусВведеныхСимволов();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Перед записью
//
// Параметры:
//  Отказ			 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если НЕ Элементы.СодержаниеМессенджерHTML.Документ = Неопределено Тогда 
		Объект.СодержаниеМессенджер = СохранитьСодержаниеМессенджер();
	КонецЕсли;	
	
	ПисьмоТекстHTML.ПолучитьHTML(Объект.ТекстHTML, Новый Структура);
	
КонецПроцедуры

&НаСервере
// Процедура - Перед записью на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТаблицаСоответствийИменВложенийИдентификаторам = Новый СписокЗначений;
	СтруктураВложений = Новый Структура;
	ПисьмоТекстHTML.ПолучитьHTML(ТекущийОбъект.ТекстHTML, СтруктураВложений);
	Для каждого Вложение Из СтруктураВложений Цикл
		ТаблицаСоответствийИменВложенийИдентификаторам.Добавить(Вложение.Ключ, Новый УникальныйИдентификатор,, Вложение.Значение);
	КонецЦикла;
	
	ПараметрыЗаписи.Вставить("ВложенияHTML", ТаблицаСоответствийИменВложенийИдентификаторам);
	
	Если ТаблицаСоответствийИменВложенийИдентификаторам.Количество() > 0 Тогда
			
		ДокументHTML = Гипертекст.ПолучитьОбъектДокументHTMLИзТекстаHTML(ТекущийОбъект.ТекстHTML);
		ЗаменитьИменаКартинокНаИдентификаторыПочтовыхВложенийВHTML( ДокументHTML, ТаблицаСоответствийИменВложенийИдентификаторам);
		ТекущийОбъект.ТекстHTML = Гипертекст.ПолучитьТекстHTMLИзОбъектаДокументHTML(ДокументHTML);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - При записи на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.РаботаСФайлами") Тогда
		МодульРаботаСФайлами = ОбщегоНазначения.ОбщийМодуль("РаботаСФайлами");
		СписокФайлов = Новый Массив;
		МодульРаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(ТекущийОбъект.Ссылка, СписокФайлов);
		Для каждого Вложение Из СписокФайлов Цикл
			Если ЗначениеЗаполнено(Вложение.Наименование) Тогда
				УдалитьПрисоединенныйФайл(Вложение.Ссылка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	СохранитьКартинкиФорматированногоДокументаКакПрисоединенныеФайлы(ТекущийОбъект.Ссылка, 
		 ПараметрыЗаписи.ВложенияHTML, УникальныйИдентификатор);

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПослеЗаписи".
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(Объект.СодержаниеМессенджерHTML) Тогда
		Оповестить("ЗаписанШаблонСообщенияМессенджера", Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПереключательОтображенияПоляHTMLПриИзменении(Элемент)
	
	Если ЭтотОбъект.ПереключательОтображенияПоляHTML = 0 Тогда
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ТекстHTMLКод) Тогда 
			
			ЭтотОбъект.ПисьмоТекстHTML = ЭтотОбъект.ТекстHTMLКод;
			ВключитьРежимРедактированияHTMLКлиент();
		КонецЕсли;
		
		ЭтаФорма.Элементы.ГруппаПросмотр.Видимость = Истина;	
		ЭтаФорма.Элементы.ГруппаКод.Видимость         = Ложь;	
		
	Иначе
		
		Если ЗначениеЗаполнено(ЭтотОбъект.ПисьмоТекстHTML) Тогда  
			ЭтотОбъект.ТекстHTMLКод = ЭтотОбъект.ПисьмоТекстHTML;
		КонецЕсли;
		
		ЭтаФорма.Элементы.ГруппаПросмотр.Видимость = Ложь;	
		ЭтаФорма.Элементы.ГруппаКод.Видимость         = Истина;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Задача период выполнения при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ЗадачаПериодВыполненияПриИзменении(Элемент)
	
	Элементы.ДекорацияДень.Заголовок = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("День", Объект.ЗадачаПериодВыполнения);	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура СодержаниеPushФДПриИзменении(Элемент)
	
	Объект.СодержаниеPush = ЭтотОбъект.СодержаниеPushФД.ПолучитьТекст();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "При изменении".
//
Процедура СодержаниеФДПриИзменении(Элемент)
	
	Объект.Содержание = ЭтотОбъект.СодержаниеФД.ПолучитьТекст();
	ПодключитьОбработчикОжидания("ОбновитьСтатусВведеныхСимволов", 0.2, Истина);
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Содержание окончание ввода текста.
//
// Параметры:
//  Элемент					 - 	 - 
//  Текст					 - 	 - 
//  ДанныеВыбора			 - 	 - 
//  ПараметрыПолученияДанных - 	 - 
//  СтандартнаяОбработка	 - 	 - 
//
Процедура СодержаниеОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ПодключитьОбработчикОжидания("ОбновитьСтатусВведеныхСимволов", 0.2, Истина);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Выполнить команду
//
// Параметры:
//  Кнопка	 - 	 - 
//
Процедура ВыполнитьКоманду(Кнопка)
	
	Команда = Сред(Кнопка.Имя, 8);
	Если Документ.queryCommandSupported(Команда) Тогда
		Документ.execCommand(Команда, Ложь);
		ПоказатьРежимыКнопок();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выполнить команду списка
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ВыполнитьКомандуСписка(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Команда = Сред(Элемент.Имя, 8);
	Если Документ.queryCommandSupported(Команда) Тогда
		Список = Элемент.СписокВыбора;
		Документ.execCommand(Команда, Истина, ВыбранноеЗначение);
		ПоказатьРежимыКнопок();
	КонецЕсли;
	ЭтаФорма.ТекущийЭлемент = Элементы.ПолеHTMLДокумента;
	
КонецПроцедуры

&НаКлиенте  
// Процедура выбора цвета.
//
Процедура ВыборЦвета(Команда)
	
	ОткрытьФорму("Обработка.ВыборWebЦвета.Форма",,,,,,
	Новый ОписаниеОповещения("ВыборЦветаЗавершение", ЭтотОбъект, Команда), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора Цвета
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборЦветаЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если РезультатВыбора <> Неопределено Тогда
		Кнопка = Сред(ДополнительныеПараметры.Имя, 8);
		Если Документ.queryCommandSupported(Кнопка) Тогда
			Документ.execCommand(Кнопка, Ложь, "" + ПеревестиИз10(РезультатВыбора.Красный) + ПеревестиИз10(РезультатВыбора.Зеленый) + ПеревестиИз10(РезультатВыбора.Синий));
		КонецЕсли;
		Модифицированность = Истина;
	КонецЕсли; 	

	ПоказатьРежимыКнопок();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Добавить(Команда)
	
	ТекущиеДанные = Элементы.ДеревоРеквизитов.ТекущиеДанные;
    Если ТекущиеДанные = Неопределено ИЛИ ТекущиеДанные.РазрешитьВыбор = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементРодитель = ТекущиеДанные.ПолучитьРодителя();
	Если ЭлементРодитель <>Неопределено Тогда 
		АктуальныйРаздел = ЭлементРодитель.НаименованиеПараметра
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ФорматСтроки) Тогда 
    	Представление = ТекущиеДанные.ФорматСтроки; 
    Иначе	
	    Представление = ТекущиеДанные.НаименованиеПараметра;
    КонецЕсли;
	
	ДобавитьЗавершение(Представление);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ДобавитьЗавершение(Результат, Параметры = Неопределено)
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Результат = "{" + Результат + "}";
	Результат = СтрЗаменить(Результат, "{{", "{");
	Результат = СтрЗаменить(Результат, "}}", "}");
	
	Если Элементы.ГруппаМессенджер.Видимость = Истина Тогда
		Документ = Элементы.СодержаниеМессенджерHTML.Документ;
		
		ТекстовыйБлок = Документ.getElementsByClassName("emojionearea-editor");
		
		Если НЕ ТекстовыйБлок = Неопределено ИЛИ ТекстовыйБлок.length > 0 Тогда
			
			ПолеВвода			 = ТекстовыйБлок[0];
			ПолеВвода.innerHTML	 = ПолеВвода.innerHTML + Результат;
			
			ПолеВвода.focus();
			ПолеВвода.scroll(0, ПолеВвода.scrollHeight);
			
		КонецЕсли;
		
	ИначеЕсли Элементы.ГруппаPush.Видимость = Истина Тогда
		ВставитьПараметр(Результат, ЭтотОбъект.СодержаниеPushФД, Элементы.СодержаниеPushФД);
		Объект.СодержаниеPush = ЭтотОбъект.СодержаниеPushФД.ПолучитьТекст();
		
	ИначеЕсли Элементы.ГруппаSMS.Видимость = Истина Тогда
		ВставитьПараметр(Результат, ЭтотОбъект.СодержаниеФД, Элементы.СодержаниеФД);
		Объект.Содержание = ЭтотОбъект.СодержаниеФД.ПолучитьТекст();
		
		ОбновитьСтатусВведеныхСимволов();
    ИначеЕсли Элементы.ГруппаПисьмо.Видимость = Истина Тогда
		ВставитьПараметр(Результат, ЭтотОбъект.ПисьмоТекстHTML, Элементы.ПолеHTMLДокумента, Истина);
	Иначе
