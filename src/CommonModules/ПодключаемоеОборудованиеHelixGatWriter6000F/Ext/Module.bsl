// Функция возвращает версию установленного драйвера
//
Функция ПолучитьВерсиюДрайвера(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры)

	Результат = Истина;

	ВыходныеПараметры.Добавить(НСтр("ru='Установлен';en='Installed'"));
	ВыходныеПараметры.Добавить(НСтр("ru='Не определена';en='Not is determined'"));

	Попытка
		ВыходныеПараметры[1] = "1.0";
	Исключение
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Функция, конвертирует в шестнадцатеричную систему счисления.
//
Функция Конвертировать_10_В_16_СС(Знач Значение)
		
	Если Значение <= 0 Тогда
		Результат = "0";
	Иначе
		Значение = Цел(Значение);
		Результат = "";
		Пока Значение > 0 Цикл			
			Результат = Сред("0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ", Значение%16 + 1, 1) + Результат;			
			Значение = Цел(Значение/16);                                                             			
		КонецЦикла;                                                                                  		
	КонецЕсли;	
	
	Если СтрДлина(Результат) < 2 Тогда
		Результат = "0" + Результат;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

