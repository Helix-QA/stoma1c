
#Область СлужебныеПроцедурыИФункции

//  Вызывается из обработчика ПриСозданииНаСервере формы объекта со свойствами
// 
Процедура ПриСозданииНаСервере(Форма, Знач Объект, ИмяЭлементаДляРазмещения) Экспорт	
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		НаборСвойствОбъекта = ПолучитьДоступныеНаборыСвойств(Объект.Ссылка);
	Иначе
		ИмяТипа = ОбщегоНазначения.ВидОбъектаПоСсылке(Объект.Ссылка) + "Объект." + Объект.Ссылка.Метаданные().Имя;
		НаборСвойствОбъекта = ПолучитьДоступныеНаборыСвойств(ДанныеФормыВЗначение(Объект, Тип(ИмяТипа)));
	КонецЕсли;
	
	//  Создадим основные объекты на форме
	СоздатьОсновныеОбъектыФормы(Форма, ИмяЭлементаДляРазмещения, НаборСвойствОбъекта);
	
	//  Если функциональной опцией использование доп.реквизитов отключено, то больше ничего не делаем
	Если Не Форма.__Свойства_ИспользоватьСвойства Тогда
		Возврат;
	КонецЕсли;
	
	//  Получим набор свойств объекта
	Если НаборСвойствОбъекта = НеОпределено Тогда
		НаборСвойствОбъекта = ПолучитьОсновнойНаборСвойствДляОбъекта(Объект.Ссылка);
	КонецЕсли;
	Форма.__Свойства_ОсновнойНабор = НаборСвойствОбъекта;
	
	//  Создадим остальные реквизиты и разместим их на форме
	ЗаполнитьДополнительныеРеквизитыНаФорме(Форма, Объект, НаборСвойствОбъекта);
	
КонецПроцедуры

//  Вызывается из обработчика ПередЗаписьюНаСервере формы объекта со свойствами
// 
Процедура ПередЗаписьюНаСервере(Форма, ТекущийОбъект) Экспорт
	
	Если Форма.__Свойства_ИспользоватьСвойства Тогда
		//  Перенесем значения доп.реквизитов из реквизитов форм в объект
		ПеренестиЗначенияСвойствИзРеквизитовФормы(Форма, ТекущийОбъект);
	КонецЕсли;
	
КонецПроцедуры

//  Обновить отображаемые данные на форме объекта со свойствами
// 
Процедура ОбновитьЭлементыДополнительныхРеквизитов(Форма, Объект) Экспорт
	Если НЕ Форма.__Свойства_ИспользоватьСвойства Тогда
		Возврат;
	КонецЕсли;
	НаборСвойствОбъекта = ПолучитьДоступныеНаборыСвойств(Объект);
	Форма.__Свойства_ОсновнойНабор = НаборСвойствОбъекта;
	
	//  Перенесем значения доп.реквизитов из реквизитов форм в объект
	ПеренестиЗначенияСвойствИзРеквизитовФормы(Форма, Объект);
	
	//  Создадим реквизиты и разместим их на форме
	ЗаполнитьДополнительныеРеквизитыНаФорме(Форма, Объект, НаборСвойствОбъекта)
	
КонецПроцедуры

//  Получить заполненную таблицу значений свойств объекта
// 
Функция ПолучитьТаблицуЗначенийСвойств(ДополнительныеСвойстваОбъекта, Набор, ЭтоДополнительноеСведение, ИмяФормы = "") Экспорт
	
	масСвойств = ДополнительныеСвойстваОбъекта.ВыгрузитьКолонку("Свойство");
	
	ТекстЗапроса =
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	НаборыСвойствДополнительныеРеквизиты.Свойство КАК Свойство,
	|	МИНИМУМ(НаборыСвойствДополнительныеРеквизиты.НомерСтроки) КАК Порядок
	|ПОМЕСТИТЬ ВсеСвойстваНабора
	|ИЗ
	|	Справочник.НаборыСвойств.ДополнительныеРеквизиты КАК НаборыСвойствДополнительныеРеквизиты
	|ГДЕ
	|	НаборыСвойствДополнительныеРеквизиты.Ссылка В(&Набор)
	|	И (НЕ НаборыСвойствДополнительныеРеквизиты.Ссылка.ПометкаУдаления)
	|	И (НЕ НаборыСвойствДополнительныеРеквизиты.Ссылка.ЭтоГруппа)
	|	И (НЕ &ЭтоДополнительноеСведение)
	|	<ДопУсловие>
	|
	|СГРУППИРОВАТЬ ПО
	|	НаборыСвойствДополнительныеРеквизиты.Свойство
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НаборыСвойствДополнительныеСведения.Свойство,
	|	МИНИМУМ(НаборыСвойствДополнительныеСведения.НомерСтроки)
	|ИЗ
	|	Справочник.НаборыСвойств.ДополнительныеСведения КАК НаборыСвойствДополнительныеСведения
	|ГДЕ
	|	НаборыСвойствДополнительныеСведения.Ссылка В(&Набор)
	|	И (НЕ НаборыСвойствДополнительныеСведения.Ссылка.ПометкаУдаления)
	|	И (НЕ НаборыСвойствДополнительныеСведения.Ссылка.ЭтоГруппа)
	|	И &ЭтоДополнительноеСведение
	|
	|СГРУППИРОВАТЬ ПО
	|	НаборыСвойствДополнительныеСведения.Свойство
	|;
	|
	|/////////////////////////////////////////////////////////////////////////////// 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ  РАЗРЕШЕННЫЕ
	|	ДополнительныеРеквизитыИСведения.Ссылка КАК Свойство
	|ПОМЕСТИТЬ ЗаполненныеСвойства
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|ГДЕ
	|	ДополнительныеРеквизитыИСведения.Ссылка В(&масСвойств)
	|;
	|
	|/////////////////////////////////////////////////////////////////////////////// 
	|ВЫБРАТЬ   РАЗРЕШЕННЫЕ
	|	ВсеСвойстваНабора.Свойство,
	|	ВсеСвойстваНабора.Порядок,
	|	ЛОЖЬ КАК Удалено
	|ПОМЕСТИТЬ ВсеСвойства
	|ИЗ
	|	ВсеСвойстваНабора КАК ВсеСвойстваНабора
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаполненныеСвойства.Свойство,
	|	0,
	|	ИСТИНА
	|ИЗ
	|	ЗаполненныеСвойства КАК ЗаполненныеСвойства
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВсеСвойстваНабора КАК ВсеСвойстваНабора
	|		ПО ЗаполненныеСвойства.Свойство = ВсеСвойстваНабора.Свойство
	|ГДЕ
	|	ВсеСвойстваНабора.Свойство ЕСТЬ NULL 
	|;
	|
	|/////////////////////////////////////////////////////////////////////////////// 
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВсеСвойства.Свойство,
	|	ДополнительныеРеквизитыИСведения.Наименование,
	|	ДополнительныеРеквизитыИСведения.ТипЗначения,
	|	ВсеСвойства.Удалено КАК Удалено,
	|	ДополнительныеРеквизитыИСведения.МножественныйВыбор КАК МножественныйВыбор
	|ИЗ
	|	ВсеСвойства КАК ВсеСвойства
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|		ПО ВсеСвойства.Свойство = ДополнительныеРеквизитыИСведения.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Удалено,
	|	ВсеСвойства.Порядок";
	
	Если ИмяФормы = "Контрагент" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗАпроса,"<ДопУсловие>","И НаборыСвойствДополнительныеРеквизиты.Свойство.ОтображатьКонтрагент");
	ИначеЕсли ИмяФормы = "Клиент" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗАпроса,"<ДопУсловие>","И НаборыСвойствДополнительныеРеквизиты.Свойство.ОтображатьКлиент");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗАпроса,"<ДопУсловие>","");
	КонецЕсли;	
		
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ЭтоДополнительноеСведение", ЭтоДополнительноеСведение);
	Запрос.УстановитьПараметр("масСвойств", масСвойств);
	Запрос.УстановитьПараметр("Набор", Набор);
	
	ТабСвойства = Запрос.Выполнить().Выгрузить();
	ТабСвойства.Индексы.Добавить("Свойство");
	ТабСвойства.Колонки.Добавить("Значение");
	
	Для Каждого Стр Из ДополнительныеСвойстваОбъекта Цикл
		СтрСвойства = ТабСвойства.Найти(Стр.Свойство, "Свойство");
		Если СтрСвойства <> Неопределено Тогда
			СтрСвойства.Значение = Стр.Значение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТабСвойства;
	
КонецФункции

//  Получить заполненную таблицу значений свойств объекта
// 
Функция ПолучитьЗначениеДопРеквизитаСвойства(Объект, ДопРеквизитСвойство) Экспорт
	
	Результат = Неопределено;
	
	Если ДопРеквизитСвойство.ЭтоДополнительноеСведение Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ДопСвойство", ДопРеквизитСвойство);
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	ДополнительныеСведения.Объект КАК Объект,
		               |	ДополнительныеСведения.Свойство КАК Свойство,
		               |	ДополнительныеСведения.Значение КАК Значение
		               |ИЗ
		               |	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		               |ГДЕ
		               |	ДополнительныеСведения.Свойство = &ДопСвойство";
		РезультатВыборка = Запрос.Выполнить().Выбрать();
		Если РезультатВыборка.Следующий() Тогда
			Результат = РезультатВыборка.Значение;
		КонецЕсли;
		
	Иначе
		РезультатВыборка = Объект.ДополнительныеРеквизиты.Найти(ДопРеквизитСвойство, "Свойство");
		Если РезультатВыборка <> Неопределено Тогда
			Результат = РезультатВыборка.Значение;
		КонецЕсли; 
		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

//  По объекту или ссылке на объект получить набор или список наборов доступных ему свойств
//  Параметры:
// 	ВладелецСвойств - ссылка на объект или сам объект
Функция ПолучитьДоступныеНаборыСвойств(ВладелецСвойств) Экспорт
	
	ДоступныеНаборы = УправлениеСвойствамиПереопределяемый.ПолучитьДоступныеНаборыСвойствПоОбъекту(ВладелецСвойств);
	
	Если ДоступныеНаборы = Неопределено Тогда
		Возврат ПолучитьОсновнойНаборСвойствДляОбъекта(ВладелецСвойств);
	Иначе
		Возврат ДоступныеНаборы;
	КонецЕсли;
	
КонецФункции

//  Используется при записи элементов справочников, которые являются видами объектов со свойствами
//  Если есть справочник Сущности к которому применяется подсистема Свойства, для него создан 
//  справочник ВидыСущностей, то при записи элемента ВидыСущностей необходимо вызывать эту процедуру
// 
//  Параметры:
// 	ВидОбъекта - объект, запись которого выполняется
// 	ИмяОбъектаСоСвойствами - имя объекта со свойствами вид которого записывается
Процедура ПередЗаписьюВидаОбъекта(ВидОбъекта, ИмяОбъектаСоСвойствами) Экспорт
	Если Не ЗначениеЗаполнено(ВидОбъекта.НаборСвойств) Тогда
		ОбъектНабора = Справочники.НаборыСвойств.СоздатьЭлемент();
	Иначе
		Если Не НаборСвойствНужноИзменить(ВидОбъекта) Тогда
			Возврат;
		КонецЕсли;
		
		ОбъектНабора = ВидОбъекта.НаборСвойств.ПолучитьОбъект();
		ЗаблокироватьДанныеДляРедактирования(ОбъектНабора.Ссылка);
	КонецЕсли;
	
	ОбъектНабора.Наименование    = ВидОбъекта.Наименование;
	ОбъектНабора.Родитель        = Справочники.НаборыСвойств[ИмяОбъектаСоСвойствами];
	ОбъектНабора.ПометкаУдаления = ВидОбъекта.ПометкаУдаления;
	ОбъектНабора.Записать();
	ВидОбъекта.НаборСвойств = ОбъектНабора.Ссылка;
	
КонецПроцедуры

//  По объекту или по ссылке на объект и по имени реквизита, содержащего вид объекта
//  получает основной набор свойств.
//  Для ссылки на справочник "Сущности" функция вернет
//  предопределенный элемент справочника НаборыСвойств "Справочник_Сущности".
//  Если передан параметр ВидОбъектаИмяРеквизита, функция вернет ссылку на 
//  набор свойств, содержащийся в Ссылка.<ВидОбъектаИмяРеквизита>
// 
Функция ПолучитьОсновнойНаборСвойствДляОбъекта(ВладелецСвойств) Экспорт
	
	МетаданныеОбъекта = ВладелецСвойств.Метаданные();
	ИмяОбъекта = МетаданныеОбъекта.Имя;
		
	Если ТипЗнч(ВладелецСвойств.Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
		ИмяОбъекта = ?(ВладелецСвойств.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, "Клиенты", "Контрагенты");
	КонецЕсли;
		
	ПереданОбъект = Ложь;
	Если ОбщегоНазначения.ЗначениеСсылочногоТипа(ВладелецСвойств) Тогда
		Ссылка = ВладелецСвойств;
	Иначе
		ПереданОбъект = Истина;
		Ссылка = ВладелецСвойств.Ссылка;
	КонецЕсли;
	
	ВидОбъекта = ОбщегоНазначения.ВидОбъектаПоСсылке(Ссылка);
	ВидОбъектаИмяРеквизита = УправлениеСвойствамиПереопределяемый.ПолучитьИмяРеквизитаВидаОбъекта(Ссылка);
	Если ВидОбъектаИмяРеквизита = "" Тогда
		ИмяЭлемента = ВидОбъекта + "_" + ИмяОбъекта;
		Если ВидОбъекта = "Справочник" или ВидОбъекта = "ПланВидовХарактеристик" Тогда
			Если ОбъектЯвляетсяГруппой(ВладелецСвойств) Тогда
				Возврат Неопределено;
			КонецЕсли;
		ИначеЕсли Справочники.НаборыСвойств.ПроверитьНаНаличиеПредопределенного(ИмяЭлемента) = Ложь Тогда 
			Возврат Неопределено;
		КонецЕсли;
		
		Возврат Справочники.НаборыСвойств[ИмяЭлемента];
		
	Иначе
		Если ПереданОбъект = Истина Тогда
			Возврат ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВладелецСвойств[ВидОбъектаИмяРеквизита], "НаборСвойств");
			
		Иначе
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ОбъектВладелецСвойств." + ВидОбъектаИмяРеквизита + ".НаборСвойств КАК Набор
			|ИЗ
			|	" + ВидОбъекта + "." + ИмяОбъекта + " КАК ОбъектВладелецСвойств
			|ГДЕ
			|	ОбъектВладелецСвойств.Ссылка = &Ссылка";
			
			Запрос.УстановитьПараметр("Ссылка", Ссылка);
			Результат = Запрос.Выполнить();
			
			Если НЕ Результат.Пустой() Тогда
				Выборка = Результат.Выбрать();
				Выборка.Следующий();
				Если ЗначениеЗаполнено(Выборка.Набор) Тогда
					Возврат Выборка.Набор;
				Иначе
					Возврат Справочники.НаборыСвойств.ПустаяСсылка();
				КонецЕсли;
			Иначе
				Возврат Справочники.НаборыСвойств.ПустаяСсылка();
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

// -----------------------Процедуры и функции для нестандартной обработки дополнительных свойств.------------------------

//  Возвращает свойства владельца.
// 
//  Параметры:
//   ВладелецСвойств      - Ссылка на владелеца свойств.
//   ПолучатьДопРеквизиты - Булево - в результат включать дополнительные реквизиты.
//   ПолучатьДопСведения  - Булево - в результат включать дополнительные сведения.
// 
//  Возвращаемое значение:
//   Массив значений типа ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения.
// 
Функция ПолучитьСписокСвойств(ВладелецСвойств, ПолучатьДопРеквизиты = Истина, ПолучатьДопСведения = Истина) Экспорт
	
	Если НЕ (ПолучатьДопРеквизиты ИЛИ ПолучатьДопСведения) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	НаборыСвойствОбъекта = ПолучитьНаборыСвойствОбъекта(ВладелецСвойств);
	
	МассивНаборовСвойствОбъекта = НаборыСвойствОбъекта.ВыгрузитьКолонку("Набор");
	
	ТекстЗапросаДопРеквизиты = 
	"ВЫБРАТЬ
	|	ТаблицаСвойств.Свойство КАК Свойство
	|ИЗ
	|	Справочник.НаборыСвойств.ДополнительныеРеквизиты КАК ТаблицаСвойств
	|ГДЕ
	|	ТаблицаСвойств.Ссылка В(&МассивНаборовСвойствОбъекта)";
	
	ТекстЗапросаДопСведения = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаСвойств.Свойство КАК Свойство
	|ИЗ
	|	Справочник.НаборыСвойств.ДополнительныеСведения КАК ТаблицаСвойств
	|ГДЕ
	|	ТаблицаСвойств.Ссылка В(&МассивНаборовСвойствОбъекта)";
	
	Запрос = Новый Запрос;
	
	Если ПолучатьДопРеквизиты И ПолучатьДопСведения Тогда
		Запрос.Текст = ТекстЗапросаДопСведения +
		"
		| ОБЪЕДИНИТЬ ВСЕ
		|" + ТекстЗапросаДопРеквизиты;
		
	ИначеЕсли ПолучатьДопРеквизиты Тогда
		Запрос.Текст = ТекстЗапросаДопРеквизиты;
		
	ИначеЕсли ПолучатьДопСведения Тогда
		Запрос.Текст = ТекстЗапросаДопСведения;
	КонецЕсли;
	
	Запрос.Параметры.Вставить("МассивНаборовСвойствОбъекта", МассивНаборовСвойствОбъекта);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Свойство");
	
	Возврат Результат;
	
КонецФункции

//  Возвращает таблицу наборов доступных свойств владельца.
// 
//  Параметры:
//   ВладелецСвойств - Ссылка на владельца свойств.
//                     Объект владельца свойств.
//                     ДанныеФормыСтруктура (по типу объекта владельца свойств).
// 
Функция ПолучитьНаборыСвойствОбъекта(ВладелецСвойств) Экспорт
	
	Если ТипЗнч(ВладелецСвойств) = Тип("ДанныеФормыСтруктура") Тогда
		ТипСсылки = ТипЗнч(ВладелецСвойств.Ссылка)
		
	ИначеЕсли ОбщегоНазначения.ЭтоСсылка(ТипЗнч(ВладелецСвойств)) Тогда
		ТипСсылки = ТипЗнч(ВладелецСвойств);
	Иначе
		ТипСсылки = ТипЗнч(ВладелецСвойств.Ссылка)
	КонецЕсли;
	
	ПолучатьОсновнойНабор = Истина;
	
	НаборыСвойств = Новый ТаблицаЗначений;
	НаборыСвойств.Колонки.Добавить("Набор");
	НаборыСвойств.Колонки.Добавить("Высота");
	НаборыСвойств.Колонки.Добавить("Заголовок");
	НаборыСвойств.Колонки.Добавить("Подсказка");
	НаборыСвойств.Колонки.Добавить("РастягиватьПоВертикали");
	НаборыСвойств.Колонки.Добавить("РастягиватьПоГоризонтали");
	НаборыСвойств.Колонки.Добавить("ТолькоПросмотр");
	НаборыСвойств.Колонки.Добавить("ЦветТекстаЗаголовка");
	НаборыСвойств.Колонки.Добавить("Ширина");
	НаборыСвойств.Колонки.Добавить("ШрифтЗаголовка");
	НаборыСвойств.Колонки.Добавить("Группировка");
	НаборыСвойств.Колонки.Добавить("Отображение");
	НаборыСвойств.Колонки.Добавить("ШиринаПодчиненныхЭлементов");
	НаборыСвойств.Колонки.Добавить("Картинка");
	НаборыСвойств.Колонки.Добавить("ОтображатьЗаголовок");
	
	// УправлениеСвойствамиПереопределяемый.ЗаполнитьНаборыСвойствОбъекта(ВладелецСвойств, ТипСсылки, НаборыСвойств, ПолучатьОсновнойНабор);
	
	Если НаборыСвойств.Количество() = 0
		И ПолучатьОсновнойНабор = Истина Тогда
		
		ОсновнойНабор = ПолучитьОсновнойНаборСвойствДляОбъекта(ВладелецСвойств);
		
		Если ЗначениеЗаполнено(ОсновнойНабор) Тогда
			НаборыСвойств.Добавить().Набор = ОсновнойНабор;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НаборыСвойств;
	
КонецФункции

//  Проверяет, используется ли дополнительные реквизиты с объектом.
// 
//  Возвращаемое значение:
//   Булево.
// 
Функция ИспользоватьДопРеквизиты(ВладелецСвойств) Экспорт
	
	Возврат ВладелецСвойств.Метаданные().ТабличныеЧасти.Найти("ДополнительныеРеквизиты") <> Неопределено;
	
КонецФункции

//  Проверяет, используется ли дополнительные сведения объектом.
// 
//  Возвращаемое значение:
//   Булево.
// 
Функция ИспользоватьДопСведения(ВладелецСвойств) Экспорт
	
	Возврат Метаданные.НайтиПоПолномуИмени("ОбщаяКоманда.ДополнительныеСведенияКоманднаяПанель") <> Неопределено
	// И Метаданные.ОбщиеКоманды.ДополнительныеСведенияКоманднаяПанель.ТипПараметраКоманды.Типы().Найти(ТипЗнч(ВладелецСвойств)) <> Неопределено
	ИЛИ Метаданные.НайтиПоПолномуИмени("ОбщаяКоманда.ДополнительныеСведенияПанельНавигации") <> Неопределено
	// И Метаданные.ОбщиеКоманды.ДополнительныеСведенияПанельНавигации.ТипПараметраКоманды.Типы().Найти(ТипЗнч(ВладелецСвойств)) <> Неопределено;
	
КонецФункции

/////////////////////////////////////////////////////////////////////////////// 
//  ОБРАБОТЧИКИ ОБНОВЛЕНИЯ ИНФОРМАЦИОННОЙ БАЗЫ

//  Процедура, обновляет список дополнительных свойств.
//   Параметры:
//    Нет;
// 
Процедура ОбновитьСписокДополнительныхСвойств() Экспорт
	
	НаборыСвойств = Справочники.НаборыСвойств.Выбрать();
	
	Пока НаборыСвойств.Следующий() Цикл
		
		ДопСведения = Новый Массив;
		
		НаборСвойствОбъект = НаборыСвойств.Ссылка.ПолучитьОбъект();
		
		Для Каждого Запись Из НаборСвойствОбъект.ДополнительныеРеквизиты Цикл
			Если Запись.Свойство.ЭтоДополнительноеСведение Тогда
				ДопСведения.Добавить(Запись);
			КонецЕсли;
		КонецЦикла;
		
		Если ДопСведения.Количество() > 0 Тогда
			
			Для Каждого ДопСведение Из ДопСведения Цикл
				НоваяСтрока = НаборСвойствОбъект.ДополнительныеСведения.Добавить();
				НоваяСтрока.Свойство = ДопСведение.Свойство;
				НаборСвойствОбъект.ДополнительныеРеквизиты.Удалить(
				НаборСвойствОбъект.ДополнительныеРеквизиты.Индекс(ДопСведение));
				
			КонецЦикла;
			НаборСвойствОбъект.Записать();
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#Область ОТОБРАЖЕНИЕ_ДОПОЛНИТЕЛЬНОЙ_ИНФОРМАЦИИ


//  Процедура - При создании при чтении на сервере
// 
//  Параметры:
//   Форма			 - УправляемаяФорма	 - 
//   ВладелецКИ		 - ЛюбаяСсылка	 - владелец контактной информации
//   ШиринаПоляВида	 - число	 - 
// 
Процедура ОтображениеДополнительнойИнформации(Форма, Знач ВладелецСсылка = Неопределено, Знач МассивРодителей = Неопределено) Экспорт
	
	Если МассивРодителей = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ВладелецСсылка = Неопределено Тогда
		ВладелецСсылка = Форма.Объект.Ссылка;
		// ВладелецОбъект = Форма.Объект;
	ИначеЕсли НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда  
		Возврат;
	КонецЕсли;
	
	ЕстьРеквизитОплаченоПоРегистру = Ложь;
	
	//  Создание таблиц-реквизитов формы, если отсутствуют
	ДобавитьРеквизитыФормыДополнительнойИнформации(Форма, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру);
	
	//  Чтение имеющейся информации объекта в созданную таблицу для отображения
	ЗаполнитьТаблицыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей);
	
	//  Пересоздание элементов формы по информации из таблицы для отображения
	ОбновитьЭлементыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру);
	
КонецПроцедуры

//  Процедура - Добавить реквизиты формы дополнительной информации
// 
//  Параметры:
//   Форма	 - 	 - 
// 
Процедура ДобавитьРеквизитыФормыДополнительнойИнформации(Форма, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру)
	
	//  Вычисляем существующие реквизиты
	СписокРеквизитовФормы = Форма.ПолучитьРеквизиты();
	
	СоздатьТаблицуУдостоверенияЛичностиСуществующие = Истина;
	СоздатьТаблицуКартыСуществующие 				= Истина;
	СоздатьТаблицуРодственникиСуществующие 			= Истина;
	СоздатьТаблицуЛицевыхСчетов 			        = Истина; 
	СоздатьТаблицуБонусныхСчетов                    = Истина;
	СоздатьТаблицуИнформацияПоОплате 				= Истина;
	СоздатьТаблицуЗаписи                            = Истина;
	СоздатьТаблицуСкидки                            = Истина;   
	СоздатьТаблицуПромокоды							= Истина;
	
	Для Каждого Реквизит Из СписокРеквизитовФормы Цикл
		Если Реквизит.Имя 		= "СуммаОплаченоПоРегистру" 	Тогда 			
			ЕстьРеквизитОплаченоПоРегистру 					= Истина;
		КонецЕсли;		
		Если Реквизит.Имя 		= "УдостоверенияЛичностиСуществующие" 	Тогда
			СоздатьТаблицуУдостоверенияЛичностиСуществующие = Ложь;
		ИначеЕсли Реквизит.Имя 	= "КартыСуществующие" 					Тогда
			СоздатьТаблицуКартыСуществующие 				= Ложь;
		ИначеЕсли Реквизит.Имя 	= "РодственникиСуществующие" 			Тогда	
			СоздатьТаблицуРодственникиСуществующие 			= Ложь;
		ИначеЕсли Реквизит.Имя 	= "ТаблицаЛицевыхСчетов"		        Тогда
			СоздатьТаблицуЛицевыхСчетов         			= Ложь; 
		ИначеЕсли Реквизит.Имя 	= "ТаблицаБонусныхСчетов"		        Тогда 	
			СоздатьТаблицуБонусныхСчетов                    = Ложь;	
		ИначеЕсли Реквизит.Имя 	= "Информация_По_Оплате"				Тогда
			СоздатьТаблицуИнформацияПоОплате 				= Ложь;	
		ИначеЕсли Реквизит.Имя 	= "ТаблицаВизитов"		        		Тогда
			СоздатьТаблицуЗаписи 		            		= Ложь;	
		ИначеЕсли Реквизит.Имя 	= "СкидкиСуществующие"		            Тогда
			СоздатьТаблицуСкидки 		            		= Ложь;	
		ИначеЕсли Реквизит.Имя  = "ПромокодыСуществующие" 				Тогда
			СоздатьТаблицуПромокоды							= Ложь;
		КонецЕсли;
	КонецЦикла;
	
	//  Создаем реквизиты формы
	МассивДобавляемыхРеквизитов = Новый Массив;
	ОписаниеСтрока 				= Новый ОписаниеТипов("Строка");
	ОписаниеБулево 				= Новый ОписаниеТипов("Булево");
	
	Для Каждого ЭлементРодитель Из МассивРодителей Цикл 
		
		Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" И СоздатьТаблицуУдостоверенияЛичностиСуществующие Тогда 
			
			ИмяТаблицы = "УдостоверенияЛичностиСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы		, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Период"		, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВидДокумента"	, Новый ОписаниеТипов("СправочникСсылка.ВидыДокументовФизическихЛиц"), ИмяТаблицы));
			СписокТипов = Новый Массив;
			СписокТипов.Добавить("СправочникСсылка.Сотрудники");
			СписокТипов.Добавить("СправочникСсылка.Контрагенты");
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Физлицо"		, ОписаниеСоставногоТипа, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Серия"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(Метаданные.РегистрыСведений.ДокументыФизическихЛиц.Ресурсы.Серия.Тип.КвалификаторыСтроки.Длина)), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Номер"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(Метаданные.РегистрыСведений.ДокументыФизическихЛиц.Ресурсы.Номер.Тип.КвалификаторыСтроки.Длина)), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаВыдачи"	, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КемВыдан"		, Новый ОписаниеТипов("Строка"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаОкончания", Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаКартыСуществующие" И СоздатьТаблицуКартыСуществующие Тогда	
			
			ИмяТаблицы = "КартыСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы				, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КартаСсылка"			, Новый ОписаниеТипов("СправочникСсылка.Карты"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипКода"				, Новый ОписаниеТипов("ПеречислениеСсылка.ВидыКарт"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВидКарты"				, Новый ОписаниеТипов("СправочникСсылка.ВидыКарт"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КодКарты"				, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(200)), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВнутреннийКодКарты"	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаРодственникиСуществующие" И СоздатьТаблицуРодственникиСуществующие Тогда	
			
			ИмяТаблицы = "РодственникиСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Контрагент"				, Новый ОписаниеТипов("СправочникСсылка.Контрагенты"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Родственник"				, Новый ОписаниеТипов("СправочникСсылка.Контрагенты"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СтепеньРодства"			, Новый ОписаниеТипов("СправочникСсылка.СтепениРодства"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОбщийЛицевойСчет"			, ОписаниеБулево, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОбщийНакопительныйСчет"	, ОписаниеБулево, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЗаконныйПредставитель"	, ОписаниеБулево, ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаЛицевыеСчетаСуществующие" И СоздатьТаблицуЛицевыхСчетов Тогда
			
			ИмяТаблицы = "ТаблицаЛицевыхСчетов";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			СписокТипов = Новый Массив;
			СписокТипов.Добавить("СправочникСсылка.ЛицевыеСчета");
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЛицевойСчет"		        , ОписаниеСоставногоТипа, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СуммаОстаток"				, Новый ОписаниеТипов("Число"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СтепеньРодства"			, Новый ОписаниеТипов("СправочникСсылка.СтепениРодства"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаБонусныеСчетаСуществующие" И СоздатьТаблицуБонусныхСчетов Тогда
			
			ИмяТаблицы = "ТаблицаБонусныхСчетов";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			СписокТипов = Новый Массив;
			СписокТипов.Добавить("СправочникСсылка.БонусныеСчета");
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("БонусныйСчет"		        , ОписаниеСоставногоТипа, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СуммаОстаток"				, Новый ОписаниеТипов("Число"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СтепеньРодства"			, Новый ОписаниеТипов("СправочникСсылка.СтепениРодства"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробно" И СоздатьТаблицуИнформацияПоОплате Тогда
			
			ИмяТаблицы = "Информация_По_Оплате";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаПлатежа"				, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			СписокТипов = Новый Массив;
			СписокТипов.Добавить("СправочникСсылка.ЛицевыеСчета");
			СписокТипов.Добавить("СправочникСсылка.Номенклатура");
			СписокТипов.Добавить("ДокументСсылка.ПоступлениеДенежныхСредств");
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);		
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДокументОплаты"			, ОписаниеСоставногоТипа, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипДенежныхСредств"		, Новый ОписаниеТипов("ПеречислениеСсылка.ТипыДенежныхСредств"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВладелецАванса"			, Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СуммаОплачено"			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КлючСвязиСтрок"			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ПолеСортировки"			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ИдентификаторФискальнойЗаписи", Новый ОписаниеТипов("Строка"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("НомерСтроки"				, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОплатаПоСсылке"			, Новый ОписаниеТипов("ПеречислениеСсылка.ПлатежныеШлюзы"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаЗаписиСуществующие" И СоздатьТаблицуЗаписи Тогда
			
			ИмяТаблицы = "ТаблицаВизитов";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Визит"		            , Новый ОписаниеТипов("ДокументСсылка.Визит"), ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаСкидкиСуществующие" И СоздатьТаблицуСкидки Тогда	
			
			ИмяТаблицы = "СкидкиСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы				    , Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Скидка"		    	    , Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЗначениеСкидкиНаценки"	, Новый ОписаниеТипов("Число"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СпособПредоставления"	    , Новый ОписаниеТипов("ПеречислениеСсылка.СпособПредоставленияСкидки"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипСкидки"    			, ОписаниеСтрока, ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" И СоздатьТаблицуПромокоды Тогда	
			
			ИмяТаблицы = "ПромокодыСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ПромокодСсылка"			, Новый ОписаниеТипов("СправочникСсылка.Промокоды"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Промокод"					, ОписаниеСтрока, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Активен"					, ОписаниеБулево, ИмяТаблицы));
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивДобавляемыхРеквизитов.Количество() > 0 Тогда
		Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

//  Процедура - Заполнить таблицы дополнительной информации
// 
//  Параметры:
//   Форма			 - 	 - 
//   ВладелецСсылка	 - 	 - 
//   МассивРодителей	 - 	 - 
// 
Процедура ЗаполнитьТаблицыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей)
	
	Для Каждого ЭлементРодитель Из МассивРодителей Цикл		
		
		Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_УДОСТОВЕРЕНИЯМИ_ЛИЧНОСТИ
			
			Форма.УдостоверенияЛичностиСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ДокументыФизическихЛиц.Период КАК Период,
			|	ДокументыФизическихЛиц.ВидДокумента КАК ВидДокумента,
			|	ДокументыФизическихЛиц.Физлицо КАК Физлицо,
			|	ДокументыФизическихЛиц.Серия КАК Серия,
			|	ДокументыФизическихЛиц.Номер КАК Номер,
			|	ДокументыФизическихЛиц.ДатаВыдачи КАК ДатаВыдачи,
			|	ДокументыФизическихЛиц.КемВыдан КАК КемВыдан,
			|	ДокументыФизическихЛиц.ДатаОкончания КАК ДатаОкончания
			|ИЗ
			|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
			|ГДЕ
			|	ДокументыФизическихЛиц.Физлицо = &Контрагент";
			
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.УдостоверенияЛичностиСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаКартыСуществующие" Тогда	
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_КАРТАМИ
			
			Форма.КартыСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Карты.Ссылка КАК КартаСсылка,
			|	Карты.ТипКода КАК ТипКода,
			|	Карты.ВидКарты КАК ВидКарты,
			|	Карты.КодКарты КАК КодКарты,
			|	Карты.ВнутреннийКодКарты КАК ВнутреннийКодКарты
			|ИЗ
			|	Справочник.Карты КАК Карты
			|ГДЕ
			|	Карты.ВладелецКарты = &ВладелецКарты
			|	И НЕ Карты.ПометкаУдаления";
			
			Запрос.УстановитьПараметр("ВладелецКарты",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.КартыСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаРодственникиСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_РОДСТВЕННИКАМИ
			
			Форма.РодственникиСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	РодственныеСвязи.Контрагент КАК Контрагент,
			|	РодственныеСвязи.Родственник КАК Родственник,
			|	РодственныеСвязи.СтепеньРодства КАК СтепеньРодства,
			|	РодственныеСвязи.ОбщийЛицевойСчет КАК ОбщийЛицевойСчет,
			|	РодственныеСвязи.ОбщийНакопительныйСчет КАК ОбщийНакопительныйСчет,
			|	РодственныеСвязи.ЗаконныйПредставитель КАК ЗаконныйПредставитель
			|ИЗ
			|	РегистрСведений.РодственныеСвязи КАК РодственныеСвязи
			|ГДЕ
			|	РодственныеСвязи.Контрагент = &Контрагент";
			
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.РодственникиСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаЛицевыеСчетаСуществующие" Тогда
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ЛИЦЕВЫМИ_СЧЕТАМИ_И_АВАНСАМИ
			
			УстановитьПривилегированныйРежим(Истина);
			
			Форма.ТаблицаЛицевыхСчетов.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			ТаблицаРодственников = РегистрыСведений.РодственныеСвязи.РодственникиКлиента(ВладелецСсылка);
			МассивКонтрагентовЛС = Новый Массив;
			
			Для Каждого СтрокаТЗ Из ТаблицаРодственников Цикл
				
				Если СтрокаТЗ.ОбщийЛицевойСчет Тогда
					МассивКонтрагентовЛС.Добавить(СтрокаТЗ.Родственник);
				КонецЕсли;
				
			КонецЦикла;
			
			МассивКонтрагентовЛС.Добавить(ВладелецСсылка);
			
			ПериодОтбора = ТекущаяДатаСеанса() + 10;
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ВложенныйЗапрос.ЛицевойСчет КАК ЛицевойСчет,
			|	ВложенныйЗапрос.ВидСчета КАК ВидСчета,
			|	СУММА(ВложенныйЗапрос.СуммаОстаток) КАК СуммаОстаток,
			|	СУММА(ВложенныйЗапрос.СуммаРасход) КАК СуммаРасход,
			|	ВложенныйЗапрос.Контрагент КАК Контрагент
			|ИЗ
			|	(ВЫБРАТЬ
			|		РасчетыСПокупателямиОбороты.Основание КАК ЛицевойСчет,
			|		ЕСТЬNULL(РасчетыСПокупателямиОбороты.СуммаОборот, 0) КАК СуммаОстаток,
			|		ЕСТЬNULL(РасчетыСПокупателямиОбороты.СуммаРасход, 0) КАК СуммаРасход,
			|		ВЫРАЗИТЬ(РасчетыСПокупателямиОбороты.Основание КАК Справочник.ЛицевыеСчета).ВидЛицевогоСчета КАК ВидСчета,
			|		РасчетыСПокупателямиОбороты.Контрагент КАК Контрагент
			|	ИЗ
			|		РегистрНакопления.РасчетыСПокупателями.Обороты(
			|				,
			|				&Период,
			|				,
			|				ТипРасчета = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.ЛицевойСчет)
			|					И Контрагент В (&МассивКонтрагентовЛС)
			|					И ВЫРАЗИТЬ(Основание КАК Справочник.ЛицевыеСчета).ПометкаУдаления = ЛОЖЬ
			|					И ВЫРАЗИТЬ(Основание КАК Справочник.ЛицевыеСчета).Закрыт = ЛОЖЬ
			|					И ВЫРАЗИТЬ(Основание КАК Справочник.ЛицевыеСчета).Внешний = ЛОЖЬ) КАК РасчетыСПокупателямиОбороты
			|	
			|	ОБЪЕДИНИТЬ
			|	
			|	ВЫБРАТЬ
			|		ЛицевыеСчета.Ссылка,
			|		0,
			|		0,
			|		ЛицевыеСчета.ВидЛицевогоСчета,
			|		ЛицевыеСчета.ВладелецЛицевогоСчета
			|	ИЗ
			|		Справочник.ЛицевыеСчета КАК ЛицевыеСчета
			|	ГДЕ
			|		ЛицевыеСчета.ВладелецЛицевогоСчета В(&МассивКонтрагентовЛС)
			|		И ЛицевыеСчета.ПометкаУдаления = ЛОЖЬ
			|		И ЛицевыеСчета.Закрыт = ЛОЖЬ
			|		И ЛицевыеСчета.Внешний = ЛОЖЬ) КАК ВложенныйЗапрос
			|
			|СГРУППИРОВАТЬ ПО
			|	ВложенныйЗапрос.ЛицевойСчет,
			|	ВложенныйЗапрос.ВидСчета,
			|	ВложенныйЗапрос.Контрагент
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	РасчетыСПокупателямиОбороты.СуммаОборот КАК СуммаОстаток,
			|	РасчетыСПокупателямиОбороты.СуммаРасход КАК СуммаРасход
			|ИЗ
			|	РегистрНакопления.РасчетыСПокупателями.Обороты(
			|			,
			|			&Период,
			|			,
			|			ТипРасчета = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)
			|				И (ВЫРАЗИТЬ(Контрагент КАК Справочник.Контрагенты)) = &Контрагент
			|				И НЕ ВЫРАЗИТЬ(Контрагент КАК Справочник.Контрагенты) ЕСТЬ NULL) КАК РасчетыСПокупателямиОбороты"); 
			
			Запрос.УстановитьПараметр("Период"              , ПериодОтбора);
			Запрос.УстановитьПараметр("Контрагент"          , ВладелецСсылка);
			Запрос.УстановитьПараметр("МассивКонтрагентовЛС", МассивКонтрагентовЛС);
			
			ОбщийРезультатВыполненияПакета = Запрос.ВыполнитьПакет();
			
			СимвольныйКод = ОбщегоНазначения.ПолучитьСимвольноеПредставлениеВалюты();
			
			//  Лицевые счета
			ТаблицаЛицевыеСчета	  = ОбщийРезультатВыполненияПакета[0].Выгрузить();
			ЛицевыеСчетаВладельца = ТаблицаЛицевыеСчета.НайтиСтроки(Новый Структура("Контрагент", ВладелецСсылка));
			
			Для Каждого СтрокаТЗ Из ЛицевыеСчетаВладельца Цикл
				
				НоваяСтрока 					= Форма.ТаблицаЛицевыхСчетов.Добавить();
				НоваяСтрока.ЛицевойСчет         = СтрокаТЗ.ЛицевойСчет;
				НоваяСтрока.Представление 		= Справочники.ЛицевыеСчета.ПолучитьПредставлениеЛицевогоСчета(СтрокаТЗ.ЛицевойСчет) + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));
				НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;
				
			КонецЦикла;
			
			//  Авансы
			ТаблицаАвансы = ОбщийРезультатВыполненияПакета[1].Выгрузить();
			
			Для Каждого СтрокаТЗ Из ТаблицаАвансы Цикл
				Если СтрокаТЗ.СуммаОстаток > 0 Тогда				
					НоваяСтрока 					= Форма.ТаблицаЛицевыхСчетов.Добавить();
					НоваяСтрока.Представление 		= СтрШаблон("Аванс (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));
					НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;				
				КонецЕсли;				
			КонецЦикла;
			
			// Лицевые счета родственников
			Для Каждого СтрокаТЗ Из ТаблицаЛицевыеСчета Цикл
				
				Если ЛицевыеСчетаВладельца.Найти(СтрокаТЗ) <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				НоваяСтрока 					= Форма.ТаблицаЛицевыхСчетов.Добавить();
				НоваяСтрока.ЛицевойСчет         = СтрокаТЗ.ЛицевойСчет;
				НоваяСтрока.Представление 		= Справочники.ЛицевыеСчета.ПолучитьПредставлениеЛицевогоСчета(СтрокаТЗ.ЛицевойСчет) + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));												
				НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;
				
				МассивСтрокРодственников = ТаблицаРодственников.НайтиСтроки(Новый Структура("Родственник", СтрокаТЗ.Контрагент));
				
				Если МассивСтрокРодственников.Количество() > 0 Тогда
					НоваяСтрока.СтепеньРодства  = МассивСтрокРодственников[0].СтепеньРодства;
				КонецЕсли;
				
			КонецЦикла;
			
			УстановитьПривилегированныйРежим(Ложь);

			#КонецОбласти  
			
			ИначеЕсли ЭлементРодитель = "ГруппаБонусныеСчетаСуществующие" Тогда
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_БОНУСНЫМИ_СЧЕТАМИ  
			
			УстановитьПривилегированныйРежим(Истина);
			
			Форма.ТаблицаБонусныхСчетов.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			ТаблицаРодственников = РегистрыСведений.РодственныеСвязи.РодственникиКлиента(ВладелецСсылка,,, Истина);  		
			МассивКонтрагентовБС = Новый Массив;
			
			Для Каждого СтрокаТЗ Из ТаблицаРодственников Цикл
				
				Если СтрокаТЗ.ОбщийБонусныйСчет Тогда
					МассивКонтрагентовБС.Добавить(СтрокаТЗ.Родственник);
				КОнецЕсли;
				
			КонецЦикла;			
			
			МассивКонтрагентовБС.Добавить(ВладелецСсылка);
			
			ПериодОтбора = ТекущаяДатаСеанса() + 10;
			
			Запрос = Новый Запрос(			
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ВложенныйЗапрос.БонусныйСчет КАК БонусныйСчет,
			|	СУММА(ВложенныйЗапрос.СуммаОстаток) КАК СуммаОстаток,
			|	СУММА(ВложенныйЗапрос.СуммаРасход) КАК СуммаРасход,
			|	ВложенныйЗапрос.Контрагент КАК Контрагент
			|ИЗ
			|	(ВЫБРАТЬ
			|		БонусныеСчетаОбороты.БонусныйСчет КАК БонусныйСчет,
			|		БонусныеСчетаОбороты.СуммаОборот КАК СуммаОстаток,
			|		БонусныеСчетаОбороты.СуммаРасход КАК СуммаРасход,
			|		БонусныеСчетаОбороты.БонусныйСчет.ВладелецБонусногоСчета КАК Контрагент
			|	ИЗ
			|		РегистрНакопления.БонусныеСчета.Обороты(
			|				,
			|				&Период,
			|				,
			|				БонусныйСчет.ВладелецБонусногоСчета В (&МассивКонтрагентовБС)
			|					И ВЫБОР
			|						КОГДА БонусныйСчет.СрокДействияНачало <> ДАТАВРЕМЯ(1, 1, 1)
			|								И БонусныйСчет.СрокДействияКонец <> ДАТАВРЕМЯ(1, 1, 1)
			|							ТОГДА БонусныйСчет.СрокДействияНачало <= &Период
			|									И БонусныйСчет.СрокДействияКонец >= &Период
			|						ИНАЧЕ ИСТИНА
			|					КОНЕЦ
			|					И НЕ БонусныйСчет.ПометкаУдаления) КАК БонусныеСчетаОбороты
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		БонусныеСчета.Ссылка,
			|		0,
			|		0,
			|		БонусныеСчета.ВладелецБонусногоСчета
			|	ИЗ
			|		Справочник.БонусныеСчета КАК БонусныеСчета
			|	ГДЕ
			|		БонусныеСчета.ВладелецБонусногоСчета В(&МассивКонтрагентовБС)
			|		И ВЫБОР
			|				КОГДА БонусныеСчета.СрокДействияНачало <> ДАТАВРЕМЯ(1, 1, 1)
			|						И БонусныеСчета.СрокДействияКонец <> ДАТАВРЕМЯ(1, 1, 1)
			|					ТОГДА БонусныеСчета.СрокДействияНачало <= &Период
			|							И БонусныеСчета.СрокДействияКонец >= &Период
			|				ИНАЧЕ ИСТИНА
			|			КОНЕЦ
			|		И НЕ БонусныеСчета.ПометкаУдаления) КАК ВложенныйЗапрос
			|
			|СГРУППИРОВАТЬ ПО
			|	ВложенныйЗапрос.БонусныйСчет,
			|	ВложенныйЗапрос.Контрагент");
			
			Запрос.УстановитьПараметр("Период"              , ПериодОтбора);
			Запрос.УстановитьПараметр("Контрагент"          , ВладелецСсылка);
			Запрос.УстановитьПараметр("МассивКонтрагентовБС", МассивКонтрагентовБС);
			
			ОбщийРезультатВыполненияПакета = Запрос.ВыполнитьПакет();
			
			СимвольныйКод = ОбщегоНазначения.ПолучитьСимвольноеПредставлениеВалюты();
			
			//  Бонусные счета
			ТаблицаБонусныеСчета   = ОбщийРезультатВыполненияПакета[0].Выгрузить();
			БонусныеСчетаВладельца = ТаблицаБонусныеСчета.НайтиСтроки(Новый Структура("Контрагент", ВладелецСсылка));
			
			Для Каждого СтрокаТЗ Из БонусныеСчетаВладельца Цикл
				Если СтрокаТЗ.СуммаОстаток > 0 Тогда								
					НоваяСтрока 					= Форма.ТаблицаБонусныхСчетов.Добавить();
					НоваяСтрока.БонусныйСчет        = СтрокаТЗ.БонусныйСчет;
					НоваяСтрока.Представление 		= Справочники.БонусныеСчета.ПолучитьПредставлениеБонусногоСчета(СтрокаТЗ.БонусныйСчет) + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));
					НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;				
				КонецЕсли;								
			КонецЦикла; 		
			
			// Бонусные счета родственников
			Для Каждого СтрокаТЗ Из ТаблицаБонусныеСчета Цикл
				
				Если СтрокаТЗ.СуммаОстаток > 0 Тогда
					
					Если БонусныеСчетаВладельца.Найти(СтрокаТЗ) <> Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					НоваяСтрока 					= Форма.ТаблицаБонусныхСчетов.Добавить();
					НоваяСтрока.БонусныйСчет        = СтрокаТЗ.БонусныйСчет;
					НоваяСтрока.Представление 		= Справочники.БонусныеСчета.ПолучитьПредставлениеБонусногоСчета(СтрокаТЗ.БонусныйСчет) + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));
					НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;
					
					МассивСтрокРодственников = ТаблицаРодственников.НайтиСтроки(Новый Структура("Родственник", СтрокаТЗ.Контрагент));
					
					Если МассивСтрокРодственников.Количество() > 0 Тогда
						НоваяСтрока.СтепеньРодства  = МассивСтрокРодственников[0].СтепеньРодства;
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
			УстановитьПривилегированныйРежим(Ложь);

			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробно" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ИНФОРМАЦИИ_ПО_ОПЛАТЕ
			
			Форма.Информация_По_Оплате.Очистить();
			
			Если ЗначениеЗаполнено(Форма.ДокументЗаказПокупателя) Тогда
				
				ДокументСсылка        = Форма.ДокументЗаказПокупателя;
				СуммаВнесенногоАванса = РегистрыНакопления.РасчетыСПокупателями.ПолучитьСуммуВнесенногоАвансаПоДокументу(ДокументСсылка);
				СуммаОплаты           = РегистрыНакопления.Оплаты.ПолучитьСуммуОплатыПоДокументу(ВладелецСсылка);
				
				Если СуммаВнесенногоАванса > 0 И СуммаОплаты = 0 Тогда	
					НоваяСтрока = Форма.Информация_По_Оплате.Добавить();
					НоваяСтрока.ПолеСортировки 	   = 4;
					НоваяСтрока.ДокументОплаты 	   = ДокументСсылка;
					НоваяСтрока.СуммаОплачено  	   = СуммаВнесенногоАванса;
					НоваяСтрока.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс;
					НоваяСтрока.НомерСтроки		   = 1;
					НоваяСтрока.ВладелецАванса     = ДокументСсылка.Контрагент;
				КонецЕсли;
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			СхемаОплат = РегистрыНакопления.Оплаты.ВернутьСтруктуруОплатыПоДокументу(ВладелецСсылка, Истина);
			
			Для Каждого СтрокаОплаты Из СхемаОплат Цикл 
				НоваяСтрока = Форма.Информация_По_Оплате.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОплаты);
				Если СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда 
					НоваяСтрока.ПолеСортировки = 1;
				ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда 
					НоваяСтрока.ПолеСортировки = 2;
				ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда 
					НоваяСтрока.ПолеСортировки = 3;
				ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс Тогда 
					НоваяСтрока.ПолеСортировки = 4;
				ИначеЕсли СтрокаОплаты.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда 
					НоваяСтрока.ПолеСортировки = 5;
				Иначе 
					НоваяСтрока.ПолеСортировки = 6;
				КонецЕсли;	
			КонецЦикла;
			Форма.Информация_По_Оплате.Сортировать("ПолеСортировки");
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаЗаписиСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ВИЗИТЫ
			
			Форма.ТаблицаВизитов.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Визит.Ссылка КАК Ссылка,
			|	Визит.ВремяНачалаВизита КАК ВремяНачалаВизита,
			|	Визит.Представление КАК Представление
			|ИЗ
			|	Документ.Визит КАК Визит
			|ГДЕ
			|	Визит.Контрагент = &Контрагент
			|	И Визит.Проведен
			|	И Визит.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВизитов.КлиентОжидается)
			|
			|УПОРЯДОЧИТЬ ПО
			|	ВремяНачалаВизита";
			
			
			Запрос.УстановитьПараметр("Контрагент", ВладелецСсылка);
			Результат = Запрос.Выполнить().Выгрузить();
			
			Для Каждого СтрокаТЗ Из Результат Цикл
				НоваяСтрока               = Форма.ТаблицаВизитов.Добавить();
				НоваяСтрока.Визит         = СтрокаТЗ.Ссылка;
				НоваяСтрока.Представление = СтрокаТЗ.Представление;
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаСкидкиСуществующие" Тогда	
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_СКИДКАМИ
			
			Форма.СкидкиСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			ТаблицаСкидкиДоступныеДляКлиента = Справочники.СкидкиНаценки.ПолучитьСкидкиДоступныеДляКлиента(ВладелецСсылка);
			
			Для Каждого СтрокаТЧ Из ТаблицаСкидкиДоступныеДляКлиента Цикл
				НоваяСтрока = Форма.СкидкиСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;
			
			#КонецОбласти 
		ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ПРОМОКОДОМ             
			
			Форма.ПромокодыСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Промокоды.Промокод КАК Промокод,
			|	Промокоды.Вид.Ссылка КАК ПромокодСсылка,
			|	Промокоды.Активен КАК Активен
			|ИЗ
			|	РегистрСведений.Промокоды КАК Промокоды
			|ГДЕ
			|	Промокоды.Владелец = &Владелец";
			
			Запрос.УстановитьПараметр("Владелец", ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.ПромокодыСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти 
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

//  Процедура - Обновить элементы дополнительной информации
// 
//  Параметры:
//   Форма			 - 	 - 
//   МассивРодителей	 - 	 - 
// 
Процедура ОбновитьЭлементыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру) Экспорт
	
	Элементы = Форма.Элементы;
	ЭтоФормаСотрудника = Форма.ИмяФормы = "Справочник.Сотрудники.Форма.ФормаЭлемента";
	
	ОтступОтЛевогоКрая = 1;
	ШиринаПредставления = ?(Не ЭтоФормаСотрудника, 29, 46);
	
	ЭтоМобильныйКлиент = ОбщегоНазначенияКлиентСервер.ЭтоМобильныйКлиент();
		
	Для Каждого ЭлементРодитель Из МассивРодителей Цикл
		
		ГруппаРодитель = Элементы.Найти(ЭлементРодитель);
		Если ГруппаРодитель = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ОчиститьГруппуОтСозданныхЭлементов(Элементы, ГруппаРодитель);
		
		
		Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" Тогда 
			
			#Область СОЗДАНИЕ_ЭЛЕМЕНТОВ_УДОСТОВЕРЕНИЯ_ЛИЧНОСТИ
			
