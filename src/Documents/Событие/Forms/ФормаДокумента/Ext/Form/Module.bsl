// Процедура, Подключаемый удалить строку табличной части.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_УдалитьСтрокуТабличнойЧастиОжидание(Элемент) Экспорт
	
	// Получим всю информацию по удаляемой строке
	СтруктураДанныхЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Элемент);
	
	Если СтруктураДанныхЭлемента.ДанныеЭлемента = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ИндексСтроки = СтруктураДанныхЭлемента.ИндексСтроки;
	СтрокаТЧ = Объект.Услуги[ИндексСтроки];
	
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПредыдущаяСтрока = Объект.Услуги[ИндексСтроки - 1];
	Если ПредыдущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаТЧ.ДатаНачала = ПредыдущаяСтрока.ДатаОкончания;
	СоздатьДинамическиеЭлементыГруппыЗапись();

	
