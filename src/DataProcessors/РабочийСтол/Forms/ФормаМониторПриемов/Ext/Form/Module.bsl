// Процедура - Отобразить все виды сделок
//
// Параметры:
//  НаполнитьДанными - 	 - 
//
Процедура ОтобразитьВсеВидыСделок(НаполнитьДанными = Истина)
	
	ЗаполнитьТаблицуВидовСделок();
	
	// Определяем родительские группы
	ГруппаСделки 								= Элементы.Найти("ГруппаСделки");
	ГруппаСделки_Шаблон_ 						= Элементы.Найти("ГруппаСделки_Шаблон_");
	
	// Обновим текущие взаимодействия
	Если ГруппаСделки = Неопределено Тогда
		Возврат;
	КонецЕсли;	
		
	// Очищаем родительские группы					
	УдалитьЭлементыГруппы(ГруппаСделки);
	// Создаем элементы
	ОбновитьЭлементыНаФормеСогласноШаблона(ГруппаСделки, ГруппаСделки_Шаблон_);
	ГруппаСделки_Шаблон_.Видимость 				= Ложь;
	
	Если НаполнитьДанными Тогда 
		ОбновитьСведенияПоСделкам();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить таблицу видов сделок
//
Процедура ЗаполнитьТаблицуВидовСделок()
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, ОтборСтруктурнаяЕдиница);
	Иначе
		МассивСтруктурныхЕдиниц 	= Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ТекущийПользователь, "Массив");		
		МассивДоступныхВидовСделок 	= Справочники.ВидыСделок.ПолучитьМассивВсехВидовСделок(Перечисления.ТипыСделок.Продажа, МассивСтруктурныхЕдиниц);
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивДоступныхВидовСделок", МассивДоступныхВидовСделок);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ТаблицаВидовСделок
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Ссылка В(&МассивДоступныхВидовСделок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЭтапыСделок.ВидСделки КАК ВидСделки,
	|	ЭтапыСделок.Ссылка КАК ЭтапСделки,
	|	ЭтапыСделок.ВидСделки.Наименование КАК ВидСделкиНаименование,
	|	ЭтапыСделок.Наименование КАК ЭтапСделкиНаименование,
	|	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа,
	|	ЭтапыСделок.ЦветЭтапа КАК ЦветЭтапа,
	|	ВЫБОР
	|		КОГДА ЭтапыСделок.ВидСделки.Предопределенный
	|			ТОГДА ВЫБОР
	|					КОГДА ЭтапыСделок.ВидСделки.ИмяПредопределенныхДанных = ""НовыеПациенты""
	|						ТОГДА 1
	|					КОГДА ЭтапыСделок.ВидСделки.ИмяПредопределенныхДанных = ""ПостоянныеПациенты""
	|						ТОГДА 2
	|					ИНАЧЕ 99
	|				КОНЕЦ
	|		ИНАЧЕ 99
	|	КОНЕЦ КАК Порядок
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.Предопределенный = ЛОЖЬ
	|	И ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	|	И ЭтапыСделок.ВидСделки В
	|			(ВЫБРАТЬ
	|				ТаблицаВидовСделок.Ссылка
	|			ИЗ
	|				ТаблицаВидовСделок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВидыСделок.Ссылка,
	|	ЭтапыСделок.Ссылка,
	|	ВидыСделок.Наименование,
	|	ВЫБОР
	|		КОГДА ЭтапыСделок.Ссылка = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех)
	|			ТОГДА ВидыСделок.НаименованиеЭтапаУспех
	|		ИНАЧЕ ВидыСделок.НаименованиеЭтапаОтказ
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЭтапыСделок.Ссылка = ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех)
	|			ТОГДА 100
	|		ИНАЧЕ 101
	|	КОНЕЦ,
	|	ЭтапыСделок.ЦветЭтапа,
	|	ВЫБОР
	|		КОГДА ВидыСделок.Предопределенный
	|			ТОГДА ВЫБОР
	|					КОГДА ВидыСделок.ИмяПредопределенныхДанных = ""НовыеПациенты""
	|						ТОГДА 1
	|					КОГДА ВидыСделок.ИмяПредопределенныхДанных = ""ПостоянныеПациенты""
	|						ТОГДА 2
	|					ИНАЧЕ 99
	|				КОНЕЦ
	|		ИНАЧЕ 99
	|	КОНЕЦ
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЭтапыСделок КАК ЭтапыСделок
	|		ПО ВидыСделок.Ссылка <> ЭтапыСделок.ВидСделки
	|ГДЕ
	|	ЭтапыСделок.Предопределенный = ИСТИНА
	|	И ВидыСделок.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаВидовСделок.Ссылка
	|			ИЗ
	|				ТаблицаВидовСделок)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок,
	|	ВидСделкиНаименование,
	|	ВидСделки,
	|	НомерЭтапа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыСделокПричиныОтказов.Ссылка КАК ВидСделки,
	|	ВидыСделокПричиныОтказов.ПричинаОтказа КАК ПричинаОтказа,
	|	ВидыСделокПричиныОтказов.ПричинаОтказа.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыСделок.ПричиныОтказов КАК ВидыСделокПричиныОтказов
	|ГДЕ
	|	ВидыСделокПричиныОтказов.Ссылка В
	|			(ВЫБРАТЬ
	|				ТаблицаВидовСделок.Ссылка
	|			ИЗ
	|				ТаблицаВидовСделок)";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
	
	РезультатПакетногоЗапроса = Запрос.ВыполнитьПакет();
	ТаблицаПричинОтказов = РезультатПакетногоЗапроса[2].Выгрузить();
	ТаблицаВидовСделок.Загрузить(РезультатПакетногоЗапроса[1].Выгрузить());
	Для Каждого СтрокаЭтап Из ТаблицаВидовСделок Цикл 
		Если СтрокаЭтап.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
			ТаблицаПричинОтказовДляВида = ТаблицаПричинОтказов.Скопировать(Новый Структура("ВидСделки", СтрокаЭтап.ВидСделки));
			Для Каждого СтрокаТаблицы Из ТаблицаПричинОтказовДляВида Цикл 
				ЗаполнитьЗначенияСвойств(СтрокаЭтап.ТаблицаПричинОтказов.Добавить(), СтрокаТаблицы);
			КонецЦикла;	
	    КонецЕсли;
	КонецЦикла;
	
	// ТаблицаВидовСделок.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить элементы группы
//
// Параметры:
//  Форма				 - 	 - 
//  РодительскаяГруппа	 - 	 - 
//
Процедура УдалитьЭлементыГруппы(РодительскаяГруппа)
	
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из Элементы[РодительскаяГруппа.Имя].ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Если СтрНайти(УдаляемыйЭлемент.Имя, "ЗаголовокВсплывающейГруппыГистограмм") <> 0 Тогда 
			Продолжить;
		Иначе 
			Элементы.Удалить(УдаляемыйЭлемент);
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить элементы на форме согласно шаблона
//
// Параметры:
//  Форма				 - 	 - 
//  ГруппаДляРазмещения	 - 	 - 
//  ГруппаШаблон		 - 	 - 
//  БизнесПроцессСсылка	 - 	 - 
//  ИндексСтроки		 - 	 - 
//  СтрокаТаблицы		 - 	 - 
//
Процедура ОбновитьЭлементыНаФормеСогласноШаблона(ГруппаДляРазмещения, ГруппаШаблон)
	
	ТаблицаВидовСделок_Группировка 	= ТаблицаВидовСделок.Выгрузить(, "ВидСделки, ВидСделкиНаименование");
	ТаблицаВидовСделок_Группировка.Свернуть("ВидСделки, ВидСделкиНаименование");
	
	Для Каждого СтрокаВидСделки Из ТаблицаВидовСделок_Группировка Цикл 
		ИндексСтроки = ТаблицаВидовСделок_Группировка.Индекс(СтрокаВидСделки);
		СрисоватьСШаблона(ГруппаДляРазмещения, ГруппаШаблон, ИндексСтроки, СтрокаВидСделки);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Срисовать с шаблона
//
// Параметры:
//  Форма				 - 	 - 
//  ГруппаДляРазмещения	 - 	 - 
//  ГруппаШаблон		 - 	 - 
//  БизнесПроцессСсылка	 - 	 - 
//  ИндексСтроки		 - 	 - 
//  СтрокаТаблицы		 - 	 - 
//
Процедура СрисоватьСШаблона(Знач ГруппаДляРазмещения
							, Знач ГруппаШаблон
							, Знач ИндексСтроки = Неопределено
							, Знач СтрокаТаблицыВидовСделок = Неопределено
							, Знач ИндексСтрокиПричины = Неопределено)
	
	Для Каждого ЭлементФормы Из ГруппаШаблон.ПодчиненныеЭлементы Цикл
		ИндексСтрокой = ?(ИндексСтроки = Неопределено, "", "_Индекс_" + Строка(ИндексСтроки));
		Если НЕ ИндексСтрокиПричины = Неопределено Тогда 
			ИндексСтрокой = ИндексСтрокой + "_ОтказПричина_" + Строка(ИндексСтрокиПричины);
		КонецЕсли;	
		Если ТипЗнч(ЭлементФормы) = Тип("ГруппаФормы") Тогда
			НовыйЭлемент = Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ГруппаФормы"), ГруппаДляРазмещения);
			НовыйЭлемент.Вид = ЭлементФормы.Вид;
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы, , ПолучитьСписокИсключенныхСвойств(ЭлементФормы.Вид));
			МодифицироватьЭлементДляЧастногоСлучая(НовыйЭлемент, , ИндексСтроки, СтрокаТаблицыВидовСделок, ИндексСтрокиПричины);
			// Отображаем этапы для вида сделки
			Если ЭлементФормы.Имя = "ГруппаЭтапыСделки_Шаблон_" Тогда 
				МассивСтрокЭтапов = ТаблицаВидовСделок.НайтиСтроки(Новый Структура("ВидСделки", СтрокаТаблицыВидовСделок.ВидСделки));
				Для Каждого СтрокаТаблицыЭтапов Из МассивСтрокЭтапов Цикл
					ИндексСтроки = ТаблицаВидовСделок.Индекс(СтрокаТаблицыЭтапов);
					Если СтрокаТаблицыЭтапов.ЭтапСделки = Справочники.ЭтапыСделок.Отказ И ЗначениеЗаполнено(СтрокаТаблицыЭтапов.ТаблицаПричинОтказов) Тогда 
						Для Каждого СтрокаПричинаОтказа Из СтрокаТаблицыЭтапов.ТаблицаПричинОтказов Цикл
							ИндексСтрокиПричины = СтрокаТаблицыЭтапов.ТаблицаПричинОтказов.Индекс(СтрокаПричинаОтказа);							
							СрисоватьСШаблона(НовыйЭлемент, ЭлементФормы, ИндексСтроки, СтрокаТаблицыЭтапов, ИндексСтрокиПричины);					
						КонецЦикла;	
					Иначе 	
						СрисоватьСШаблона(НовыйЭлемент, ЭлементФормы, ИндексСтроки, СтрокаТаблицыЭтапов);					
					КонецЕсли;	
				КонецЦикла;
			Иначе 
				СрисоватьСШаблона(НовыйЭлемент, ЭлементФормы, ИндексСтроки, СтрокаТаблицыВидовСделок, ИндексСтрокиПричины);					
			КонецЕсли;	
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ДекорацияФормы") Тогда 
			НовыйЭлемент = Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ДекорацияФормы"), ГруппаДляРазмещения);
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы);
            МодифицироватьЭлементДляЧастногоСлучая(НовыйЭлемент, , ИндексСтроки, СтрокаТаблицыВидовСделок, ИндексСтрокиПричины);
			УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ДекорацияФормы"));
			Если ЭлементФормы.Имя = "ДекорацияСуммаСделокНаЭтапе_Шаблон_" Тогда
				Если СтрокаТаблицыВидовСделок.ЭтапСделки = Справочники.ЭтапыСделок.Отказ И НЕ ИндексСтрокиПричины = Неопределено Тогда
					СтрокаТаблицыВидовСделок.ТаблицаПричинОтказов[ИндексСтрокиПричины].ЭлементСуммаСделок = НовыйЭлемент.Имя;
				Иначе 					
					СтрокаТаблицыВидовСделок.ЭлементСуммаСделок = НовыйЭлемент.Имя;
				КонецЕсли; 	
			КонецЕсли;	
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ПолеФормы") Тогда  
			НовыйЭлемент = Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("ПолеФормы"), ГруппаДляРазмещения);
			НовыйЭлемент.Вид = ЭлементФормы.Вид;
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы, , ПолучитьСписокИсключенныхСвойств(ЭлементФормы.Вид));
			МодифицироватьЭлементДляЧастногоСлучая(НовыйЭлемент, , ИндексСтроки, СтрокаТаблицыВидовСделок, ИндексСтрокиПричины);
			УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, Тип("ПолеФормы"));			
		ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Тогда  
			НовыйЭлемент = Элементы.Добавить(СтрЗаменить(ЭлементФормы.Имя, "_Шаблон_", "") + ИндексСтрокой, Тип("КнопкаФормы"), ГруппаДляРазмещения);
			ЗаполнитьЗначенияСвойств(НовыйЭлемент, ЭлементФормы);				
			НоваяКоманда = Команды.Найти(СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + ?(ЗначениеЗаполнено(ИндексСтрокой), ИндексСтрокой, ""));
			ШаблонКоманда = Команды.Найти(НовыйЭлемент.ИмяКоманды);
			Если НоваяКоманда = Неопределено Тогда 
				НоваяКоманда = Команды.Добавить(СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + ИндексСтрокой);
				ЗаполнитьЗначенияСвойств(НоваяКоманда, ШаблонКоманда);
				НоваяКоманда.Действие = "Подключаемый_" + СтрЗаменить(НовыйЭлемент.ИмяКоманды, "_Шаблон_", "") + "_ВыполнитьКоманду";				
				МодифицироватьЭлементДляЧастногоСлучая(НовыйЭлемент, НоваяКоманда, ИндексСтроки, СтрокаТаблицыВидовСделок, ИндексСтрокиПричины);				
			КонецЕсли;
			НовыйЭлемент.ИмяКоманды = НоваяКоманда.Имя;
			МодифицироватьЭлементДляЧастногоСлучая(НовыйЭлемент, НоваяКоманда, ИндексСтроки, СтрокаТаблицыВидовСделок, ИндексСтрокиПричины);
			// Запоминаем имена кнопок для обновления данных 
			Если ЭлементФормы.Имя = "ПерейтиСделкиЭтапКоличество_Шаблон_" Тогда
				Если СтрокаТаблицыВидовСделок.ЭтапСделки = Справочники.ЭтапыСделок.Отказ И НЕ ИндексСтрокиПричины = Неопределено Тогда
					СтрокаТаблицыВидовСделок.ТаблицаПричинОтказов[ИндексСтрокиПричины].ЭлементКоличествоСделок = НовыйЭлемент.Имя;
				Иначе 	
					СтрокаТаблицыВидовСделок.ЭлементКоличествоСделок = НовыйЭлемент.Имя;
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Функция - Получить список исключенных свойств
//
// Параметры:
//  ВидЭлемента	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокИсключенныхСвойств(ВидЭлемента)
	
	СписокСвойств = "";
	
	Если ВидЭлемента = ВидПоляФормы.ПолеФлажка Тогда 
		СписокСвойств = "ПутьКДанным";
	ИначеЕсли ВидЭлемента = ВидПоляФормы.ПолеВвода Тогда 
		СписокСвойств = "ВыделенныйТекст, ПутьКДанным";
	ИначеЕсли ВидЭлемента = ВидГруппыФормы.ОбычнаяГруппа Тогда	
		СписокСвойств = "ПутьКДаннымЗаголовка";
	КонецЕсли;
	
	Возврат СписокСвойств;
	
КонецФункции

&НаСервере
// Процедура - Модифицировать элемент для частного случая
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура МодифицироватьЭлементДляЧастногоСлучая(Элемент
												, Команда = Неопределено
												, ИндексСтроки
												, СтрокаТаблицы
												, ИндексСтрокиПричины = Неопределено)
	
	ПроверяемыйЭлемент = ?(Команда = Неопределено, Элемент, Команда);	
	Если НЕ ЗначениеЗаполнено(ПроверяемыйЭлемент.Подсказка) ИЛИ СтрНайти(ПроверяемыйЭлемент.Подсказка, "Процедура_") = 0 Тогда 
      	Возврат;
	КонецЕсли;
	
	ИмяОбработчика = СокрЛП(ПроверяемыйЭлемент.Подсказка);
	
	Если ИмяОбработчика = "Процедура_ОбработкаДекорации_ЗаголовокВидаСделки" Тогда 
		Процедура_ОбработкаДекорации_ЗаголовокВидаСделки(Элемент, Команда, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины);
	ИначеЕсли ИмяОбработчика = "Процедура_ОбработкаПодсказкиКоманды_КоличествоСделок" Тогда 
		Процедура_ОбработкаПодсказкиКоманды_КоличествоСделок(Элемент, Команда, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины);
	ИначеЕсли ИмяОбработчика = "Процедура_ОбработкаДекорацииШтрих_ЗаголовокЭтапа" Тогда 
		Процедура_ОбработкаДекорацииШтрих_ЗаголовокЭтапа(Элемент, Команда, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины);		
	ИначеЕсли ИмяОбработчика = "Процедура_ОбработкаГруппы_ЗаголовокЭтапа" Тогда 
		Процедура_ОбработкаГруппы_ЗаголовокЭтапа(Элемент, Команда, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины);				
	ИначеЕсли ИмяОбработчика = "Процедура_ОбработкаКоманды_Перейти_Сделки_Этап" Тогда 
		Процедура_ОбработкаКоманды_Перейти_Сделки_Этап(Элемент, Команда, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины);
	ИначеЕсли ИмяОбработчика = "Процедура_ОбработкаДекорации_ЗаголовокЭтапа" Тогда 
		Процедура_ОбработкаДекорации_ЗаголовокЭтапа(Элемент, Команда, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины);		
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
// Процедура - Процедура обработка декорации заголовок вида сделки
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура Процедура_ОбработкаДекорации_ЗаголовокВидаСделки(Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины = Неопределено)
	
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		Элемент.Подсказка 	= "";		
		Элемент.Заголовок 	= СокрЛП(СтрокаТаблицы.ВидСделкиНаименование);
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Процедура обработка подсказки команды количество сделок
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура Процедура_ОбработкаПодсказкиКоманды_КоличествоСделок(Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины = Неопределено)
	
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		Если СтрокаТаблицы.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда 
			Команда.Подсказка = Нстр("ru = 'Перейти к успешным сделкам'; en = 'Go to succesful deals'");
		ИначеЕсли СтрокаТаблицы.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
			Команда.Подсказка = Нстр("ru = 'Перейти к проигранным сделкам'; en = 'Go to lost deals'");
		Иначе 	
			Команда.Подсказка = Нстр("ru = 'Перейти к сделкам на этапе ""'; en = 'Go to deals on stage ""'") + СтрокаТаблицы.ЭтапСделкиНаименование + """";
		КонецЕсли;
	Иначе 
		Команда.Подсказка = "";
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Процедура обработка группы заголовок этапа
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура Процедура_ОбработкаДекорацииШтрих_ЗаголовокЭтапа(Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины = Неопределено)
	
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		Элемент.Подсказка 		= "";
		Если ЗначениеЗаполнено(СтрокаТаблицы.ЦветЭтапа) Тогда 
			Элемент.ЦветФона 	= ЗначениеИзСтрокиВнутр(СтрокаТаблицы.ЦветЭтапа);
		ИначеЕсли СтрокаТаблицы.ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда 
			Элемент.ЦветФона 	= Новый Цвет(83, 177, 83);
		ИначеЕсли СтрокаТаблицы.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда
			Элемент.ЦветФона 	= Новый Цвет(255, 83, 83);
		Иначе 
			Элемент.ЦветФона 	= Новый Цвет(232, 232, 232);
		КонецЕсли;
		Если Элемент.ЦветФона = Новый Цвет() Тогда 
			Элемент.ЦветФона 	= Новый Цвет(232, 232, 232);
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

&НаСервере
