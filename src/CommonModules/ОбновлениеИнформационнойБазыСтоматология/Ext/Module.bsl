				|Сотрудник: """ + ВыборкаСотрудник.СотрудникНаименование + """",
				УровеньЖурналаРегистрации.Ошибка,Метаданные.Справочники.Сотрудники,, ОписаниеОшибки());	
			КонецПопытки;
			
