&НаКлиенте
// Обработчик кнопки удаления времени занятия
// 
Процедура КомандаУдалитьВремяЗаполнения(Команда)
		
	ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИменеиЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);	
	// Проверка возможности операции	
	Если ВремяПланирования.Количество() = 1 Тогда
		ПоказатьПредупреждение(,"Необходимо оставить хотя бы одно значение периода заполнения!");
		Возврат;
	КонецЕсли;
	Если РежимПланированияРабочихДней = 1 И ИДСтрокиДанных = ВремяПланирования[0].ПолучитьИдентификатор() Тогда
		ПоказатьПредупреждение(,"В режиме циклического заполнения периодов, нельзя удалять первую строку начала периода!");
		Возврат;		
	КонецЕсли;
	
	УдалитьДинамическиеЭлементыПериодовЗаполнения(ИДСтрокиДанных);
	
	// Если исп. циклический режим заполнения(смены)
	// При удаленой одной из строк периода, необходимо перезаполнить оставшиеся строки
	Если РежимПланированияРабочихДней = 1 Тогда
		Для А = 1 По ВремяПланирования.Количество() -1 Цикл
			ВремяПланирования[А].Дата       = ВремяПланирования[А - 1].Дата + 86400;
			ВремяПланирования[А].ДатаПредст = Формат(ВремяПланирования[А].Дата,"ДФ='dd MMMM, dddd'");
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

&НаКлиенте
// Выбрать период из спсика
// 
Процедура ВыбратьПериодИзВыпадающегоСписка(Элемент, ВидПериода, НачалоПериода, Вариант, ИндексНачальногоЗначения, ОповещениеВладельца)
	
	Если Вариант = Неопределено Или Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда
		СписокПериодов = ФункцииОтчетовКлиентСервер.СписокФиксированныхПериодов(НачалоПериода, ВидПериода);
		СписокПериодов.Добавить("ВыборАвтоматическиВычисляемогоПериода", НСтр("ru = 'Относительный...'"));
		Если ИндексНачальногоЗначения = Неопределено Тогда
			ИндексНачальногоЗначения = СписокПериодов.НайтиПоЗначению(НачалоПериода);
		КонецЕсли;
	Иначе
		СписокПериодов = ФункцииОтчетовКлиентСервер.СписокВычисляемыхПериодов(ВидПериода);
		СписокПериодов.Добавить("ВыборФиксированногоПериода", НСтр("ru = 'Фиксированный...'"));
		Если ИндексНачальногоЗначения = Неопределено Тогда
			ИндексНачальногоЗначения = СписокПериодов.НайтиПоЗначению(Вариант);
		КонецЕсли;
	КонецЕсли;
	Если ИндексНачальногоЗначения = Неопределено Тогда
		ИндексНачальногоЗначения = СписокПериодов.Количество() - 1;
	КонецЕсли;
	
	ДопПараметры =  Новый Структура("ОповещениеВладельца,ВидПериода,НачалоПериода,Элемент,СписокПериодов,Вариант", ОповещениеВладельца, ВидПериода, НачалоПериода, Элемент, СписокПериодов,Вариант);
	Оповещение   = Новый ОписаниеОповещения("ПослеВыбораИзСпискапериодаОповещение", ЭтаФорма, ДопПараметры);
	ПоказатьВыборИзСписка(Оповещение, СписокПериодов, Элемент, ИндексНачальногоЗначения);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора из спискапериода оповещение
// 
// Параметры:
//  РезультатВыбора	 - 	 - 
//  ДопПараметры	 - 	 - 
// 
Процедура ПослеВыбораИзСпискапериодаОповещение(РезультатВыбора, ДопПараметры) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		ВыполнитьОбработкуОповещения(ДопПараметры.ОповещениеВладельца, Неопределено);
		Возврат;		
	ИначеЕсли ТипЗнч(РезультатВыбора.Значение) = Тип("ВариантСтандартногоПериода") Тогда
		ВыполнитьОбработкуОповещения(ДопПараметры.ОповещениеВладельца, РезультатВыбора);
		Возврат;	
	ИначеЕсли РезультатВыбора.Значение = "ВыборАвтоматическиВычисляемогоПериода" Тогда
		ВариантКопия = ВариантСтандартногоПериодаПоВиду(ДопПараметры.ВидПериода);
		ВыбратьПериодИзВыпадающегоСписка(ДопПараметры.Элемент, ДопПараметры.ВидПериода, ДопПараметры.НачалоПериода, ВариантКопия, Неопределено,ДопПараметры.ОповещениеВладельца);
		Возврат;		
	ИначеЕсли РезультатВыбора.Значение = "ВыборФиксированногоПериода" Тогда
		ВыбратьПериодИзВыпадающегоСписка(ДопПараметры.Элемент, ДопПараметры.ВидПериода, ДопПараметры.НачалоПериода, Неопределено, Неопределено,ДопПараметры.ОповещениеВладельца);
		Возврат;
	КонецЕсли;
	
	Индекс = ДопПараметры.СписокПериодов.Индекс(РезультатВыбора);
	Если Индекс = 0 Или Индекс = ДопПараметры.СписокПериодов.Количество() - 2 Тогда
		ВыбратьПериодИзВыпадающегоСписка(ДопПараметры.Элемент, ДопПараметры.ВидПериода, РезультатВыбора.Значение, ДопПараметры.Вариант, Индекс, ДопПараметры.ОповещениеВладельца);
		Возврат;	
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ДопПараметры.ОповещениеВладельца, РезультатВыбора);
КонецПроцедуры

