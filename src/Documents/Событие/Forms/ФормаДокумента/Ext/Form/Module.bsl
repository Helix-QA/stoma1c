// Функция, обработчик команды "ПоискРодственныхСвязейПоНовомуПациенту" 
//
Функция ПоискРодственныхСвязейПоНовомуПациенту(СсылкаНаНовогоПациента)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РодственныеСвязи.Контрагент КАК Контрагент
		|ИЗ
		|	РегистрСведений.РодственныеСвязи КАК РодственныеСвязи
		|ГДЕ
		|	РодственныеСвязи.Контрагент = &СсылкаНаНовогоПациента";
	
	Запрос.УстановитьПараметр("СсылкаНаНовогоПациента", СсылкаНаНовогоПациента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	НайденныеРодственныеСвязи = Новый Массив();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НайденныеРодственныеСвязи.Добавить(ВыборкаДетальныеЗаписи.Контрагент);	
	КонецЦикла;
	
	Возврат (НайденныеРодственныеСвязи);

	
КонецФункции

&НаСервереБезКонтекста
// Функция, обработчик команды "ОпределениеГруппыЗаписиНовогоПациента"
// 
Функция ПолучитьГруппуНовогоПациента()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ИСТИНА
	|	И Контрагенты.ПометкаУдаления = ЛОЖЬ
	|	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)");
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Возврат Результат;
	
КонецФункции

