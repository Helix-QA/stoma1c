Процедура ЗаполнитьРеквизитПриемВПланеЛечения____И____ПроставитьСоответствующиеСтатусы(МассивПлановЛечения, ТаблицаУдаляемыхСтрок, РежимЗаписиНарядЗаказа)		
	               
	Для Каждого ПланЛечения Из МассивПлановЛечения Цикл 
		МассивНайденныхСтрок = Запасы.НайтиСтроки(Новый Структура("ПланЛечения", ПланЛечения));
		МассивУдаляемыхСтрок = ?(ТаблицаУдаляемыхСтрок = Неопределено, Новый Массив, ТаблицаУдаляемыхСтрок.НайтиСтроки(Новый Структура("ДокументАванса", ПланЛечения)));		
		Если МассивНайденныхСтрок.Количество() > 0 ИЛИ МассивУдаляемыхСтрок.Количество() > 0 Тогда
			Выполнен = Истина;
			ПланЛеченияОбъект = ПланЛечения.ПолучитьОбъект();
			
			Для Каждого УдаляемаяСтрока Из МассивУдаляемыхСтрок Цикл 
				СтрокаТЧЛечение_План = ПланЛеченияОбъект.Лечение.Найти(УдаляемаяСтрока.КлючСтроки, "КлючСтроки");
				Если СтрокаТЧЛечение_План <> Неопределено Тогда				
					СтрокаТЧЛечение_План.Прием = Документы.НарядЗаказ.ПустаяСсылка();		
				КонецЕсли;
				Выполнен = Ложь;
			КонецЦикла;
			
			Для Каждого НайденнаяСтрока Из МассивНайденныхСтрок Цикл 
				СтрокаТЧЛечение_План = ПланЛеченияОбъект.Лечение.Найти(НайденнаяСтрока.КлючСтроки, "КлючСтроки");
				Если СтрокаТЧЛечение_План <> Неопределено Тогда				
					Если РежимЗаписиНарядЗаказа = РежимЗаписиДокумента.ОтменаПроведения Тогда
						СтрокаТЧЛечение_План.Прием = Документы.НарядЗаказ.ПустаяСсылка();
					Иначе
						// Пишем Ссылку
						СтрокаТЧЛечение_План.Прием = Ссылка;
					КонецЕсли;	
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(НайденнаяСтрока.Прием) Тогда 
					Выполнен = Ложь;						
				КонецЕсли;				
			КонецЦикла;
			
			// Дополнительная проверка ПланаЛечения
			Если Выполнен Тогда 
				Для Каждого СтрокаТч Из ПланЛечения.Лечение Цикл 
					Если ЗначениеЗаполнено(СтрокаТЧ.Прием) Тогда 
						Если ТипЗнч(СтрокаТЧ.Прием) = Тип("ДокументСсылка.НарядЗаказ") Тогда 
							Если СтрокаТЧ.Прием <> Ссылка Тогда 
								МассивНайденныхСтрокВ_НЗ = СтрокаТЧ.Прием.Запасы.НайтиСтроки(Новый Структура("ПланЛечения", ПланЛечения));
								Для Каждого НайденнаяСтрокаВ_НЗ Из МассивНайденныхСтрокВ_НЗ Цикл 
									Если НЕ ЗначениеЗаполнено(НайденнаяСтрокаВ_НЗ.Прием) Тогда 
										Выполнен = Ложь;
										Прервать;
									КонецЕсли;	
								КонецЦикла;							
							КонецЕсли;	
						КонецЕсли;		
					Иначе 
						Выполнен = Ложь;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Если Выполнен Тогда 
				Если ПланЛечения.Статус <> Перечисления.СтатусыПланЛечения.Закрыт Тогда 
					ПланЛеченияОбъект.Статус = Перечисления.СтатусыПланЛечения.Закрыт;
				КонецЕсли;
			Иначе 	
				Если ПланЛечения.Статус = Перечисления.СтатусыПланЛечения.Закрыт Тогда 
					ПланЛеченияОбъект.Статус = Перечисления.СтатусыПланЛечения.Принят;
				КонецЕсли;	
			КонецЕсли;
			ПланЛеченияОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;
	КонецЦикла;
	
	#Область __________________________________________________СтарыйМеханизм____________________________________________________________

	
	
		// Для Каждого СтрокаЛ Из Запасы Цикл
		//	Если ЗначениеЗаполнено(СтрокаЛ.ПланЛечения) И ТипЗнч(СтрокаЛ.ПланЛечения) = Тип("ДокументСсылка.ПланЛечения") Тогда 
