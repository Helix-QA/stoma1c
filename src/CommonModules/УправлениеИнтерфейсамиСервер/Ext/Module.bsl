// Процедура - Инициализировать реквизиты виджета сделки
//
// Параметры:
//  Форма	 - 	 - 
//
Процедура ИнициализироватьРеквизитыВиджетаСделки(Форма)
	
	МассивРеквизитов = Новый Массив;
	
	ПараметрыТаблицы  = Новый Структура();
	ПараметрыТаблицы.Вставить("ИмяТаблицы", "ПричиныОтказов");
	ПараметрыТаблицы.Вставить("ИмяКолонки", "Ссылка");
	ПараметрыТаблицы.Вставить("ТипКолонки", "СправочникСсылка.ПричиныОтказов");
	
	// Реквизит данных состояния отборов.
	РеквизитДанныхПричиныОтказов = ПараметрыТаблицы.ИмяТаблицы;
	
	Если НЕ ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, РеквизитДанныхПричиныОтказов) Тогда
		МассивРеквизитов.Добавить(Новый РеквизитФормы(РеквизитДанныхПричиныОтказов, Новый ОписаниеТипов("ТаблицаЗначений")));
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ПараметрыТаблицы.ИмяКолонки, Новый ОписаниеТипов(ПараметрыТаблицы.ТипКолонки), РеквизитДанныхПричиныОтказов));
	Иначе
		Форма[РеквизитДанныхПричиныОтказов].Очистить();
	КонецЕсли;
	
	ИмяТаблицы = "ТаблицаСделок";
	
	Если НЕ ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, ИмяТаблицы) Тогда
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы	, Новый ОписаниеТипов("ТаблицаЗначений")));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Сделка"	  	, Новый ОписаниеТипов("СправочникСсылка.Сделки")  , ИмяТаблицы));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("СуммаСделки"	, Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10)), ИмяТаблицы));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Прием"		, Новый ОписаниеТипов("ДокументСсылка.Прием"), ИмяТаблицы));
	Иначе
		Форма[ИмяТаблицы].Очистить();
	КонецЕсли;
	
	ИмяСписка = "СписокВидовСделок";
	
	Если НЕ ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, ИмяСписка) Тогда
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяСписка, Новый ОписаниеТипов("СписокЗначений")));
	Иначе
		Форма[ИмяСписка].Очистить();
	КонецЕсли;
	
	Если МассивРеквизитов.Количество() <> 0 Тогда 
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

// Процедура, ОбновитьЭтапыСделки.
//
Процедура ОбновитьЭтапыСделки(Форма, Знач Сделка, Знач ИндексВиджета, Знач ИндексКонтейнера, СделкаПомещенаВАрхив = Ложь) 
	
	Элементы = Форма.Элементы;
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.ВидыСделок") Тогда 
		ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(Сделка);
	Иначе 	
		ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(Сделка.ВидСделки);
	КонецЕсли;
	
	НомерТекущегоЭтапа = 0;// Сделка.ЭтапСделки.НомерЭтапа;
	Индекс = 0;
	
	СоздатьВиджет(форма, Сделка, ИндексВиджета, ИндексКонтейнера, СделкаПомещенаВАрхив);
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаЭтапы_" + ИндексВиджета);
	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.ВидыСделок") Тогда
		ГруппаРодитель = Элементы["ГруппаВсплывающаяСделка_" + ИндексВиджета];
	Иначе
		ГруппаРодитель = Элементы["ГруппаВсплывающая_" + ИндексВиджета];		
	КонецЕсли;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРодитель);	
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная); 
	ПараметрыГруппы.Вставить("ГоризонтальноеПоложениеПодчиненных", ГоризонтальноеПоложениеЭлемента.Центр);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеПодчиненных", ВертикальноеПоложениеЭлемента.Центр);
	
	ГруппаЭтапы = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);

	Если ТипЗнч(Сделка) = Тип("СправочникСсылка.ВидыСделок") ИЛИ НЕ ЗначениеЗаполнено(Сделка.РезультатСделки)
		ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ЗадачаСсылка.Взаимодействие") // ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ЧленствоПакетУслуг")
		ИЛИ Сделка.ДатаЗавершенияСделки > ТекущаяДатаСеанса()-60*5 Тогда // Показываем сделку в течении 5 минут.
		
		Для Каждого СтрокаТЗ Из ТаблицаЭтапов Цикл
			
			ЭтапСделки = СтрокаТЗ.ЭтапСделки;
			
			// Создание группы этапа.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Этап_" + Индекс + "_" + ИндексВиджета);
			ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаЭтапы);
			ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
			ПараметрыГруппы.Вставить("РастягиватьПоГоризонтали", Ложь); 
			ПараметрыГруппы.Вставить("ГоризонтальноеПоложениеВГруппе", ГоризонтальноеПоложениеЭлемента.Центр);
			ПараметрыГруппы.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Центр);
			ГруппаЭтапа = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
			ГруппаЭтапа.Ширина = 15;
			
			// Создаем команду кнопки.
			ПараметрыКоманды = Новый Структура;
			ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
			ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "Этап_" + Индекс + "_" + ИндексВиджета);
			КомандаКнопки =  СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
			
			// Создаем кнопку.
			ПараметрыКнопки = Новый Структура;
			ПараметрыКнопки.Вставить("Заголовок"   	 	 , ЭтапСделки);
			ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "Этап_" + Индекс + "_" + ИндексВиджета);
			ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
			ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
			ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
			ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаЭтапа);		
			
			КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
			КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;	 
			
			Если НЕ ЗначениеЗаполнено(ЭтапСделки.ЦветЭтапа)
				ИЛИ ЗначениеИзСтрокиВнутр(ЭтапСделки.ЦветЭтапа) = Новый Цвет() Тогда
				
				Цвет = Новый Цвет(0,112,210);
			Иначе		
				Цвет = ЗначениеИзСтрокиВнутр(ЭтапСделки.ЦветЭтапа);
			КонецЕсли;
			
			ГруппаЭтапа.ЦветФона   = Цвет;
			КнопкаЭтапа.ЦветТекста = ПолучитьЦветТекстаПоФону(ГруппаЭтапа.ЦветФона);
			
			Индекс = Индекс + 1;
			
		КонецЦикла;

		СтруктураНаименований = Справочники.ВидыСделок.ПолучитьНаименованияЗавершающихЭтаповСделки(Сделка);
		
		СоздатьКнопкуРезультатаСделки(Форма, СтруктураНаименований.НаименованиеЭтапаУспех, ГруппаЭтапы, Новый Цвет(72, 193, 123), Новый Цвет(255, 255, 255));
		СоздатьГруппуПрием(Форма, ИндексВиджета, ГруппаРодитель);
		СоздатьКнопкуРезультатаСделки(Форма, СтруктураНаименований.НаименованиеЭтапаОтказ, ГруппаЭтапы, Новый Цвет(246, 110, 110), Новый Цвет(255, 255, 255));
		СоздатьГруппуПричинОтказа(Форма, ГруппаРодитель, ИндексВиджета);	
		
	КонецЕсли;
			
КонецПроцедуры

// Процедура, СоздатьГруппуПрием.
//
Процедура СоздатьГруппуПрием(Форма, ИндексВиджета, ГруппаРодитель) Экспорт
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   	   , "ГруппаПрием_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("ГруппаЭлемента"	   , ГруппаРодитель);
	ПараметрыГруппы.Вставить("Группировка"   	   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("ВертикальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Половинный);
	ПараметрыГруппы.Вставить("Видимость"		   , Ложь);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеВГруппе"   	 , ВертикальноеПоложениеЭлемента.Центр);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеПодчиненных"	 , ВертикальноеПоложениеЭлемента.Центр);
	
	ГруппаПрием = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаСоздатьРеализацию_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаПрием);
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("ЦветФона"		 , Новый Цвет(72, 193, 123));
	ПараметрыГруппы.Вставить("ШиринаГруппы"	 , 30);
	ГруппаСоздатьРеализацию = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	// Создаем команду кнопки.
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
	ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "СоздатьПродажу_" + ИндексВиджета);
	КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	// Создаем кнопку.
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("Заголовок"   	 	 , НСтр("ru = 'Создать продажу'; en = 'Create a sale'"));
	ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "КнопкаСоздатьПродажу_" + ИндексВиджета);
	ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
	ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
	ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаСоздатьРеализацию);		
	
	КнопкаСоздатьПродажу = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	КнопкаСоздатьПродажу.ЦветТекста = Новый Цвет(255,255,255);
	КнопкаСоздатьПродажу.РастягиватьПоГоризонтали = Истина;
		
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаВыбратьРеализацию_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаПрием);
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("ЦветФона"		 , Новый Цвет(72, 193, 123));
	ПараметрыГруппы.Вставить("ШиринаГруппы"	 , 30);
	ГруппаВыбратьРеализацию = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	// Создаем команду кнопки.
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
	ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "ВыбратьПродажу_" + ИндексВиджета);
	КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	// Создаем кнопку.
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("Заголовок"   	 	 , НСтр("ru = 'Выбрать продажу'; en = 'Choose a sale'"));
	ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "КнопкаВыбратьПродажу_" + ИндексВиджета);
	ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
	ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
	ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаВыбратьРеализацию);		
	
	КнопкаВыбратьПродажу = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	КнопкаВыбратьПродажу.ЦветТекста = Новый Цвет(255,255,255);
	КнопкаВыбратьПродажу.РастягиватьПоГоризонтали = Истина;
	
КонецПроцедуры

// Процедура, СоздатьКнопкиРезультатаСделки.
//
Процедура СоздатьКнопкуРезультатаСделки(Форма
										, Заголовок
										, ГруппаРодитель
										, ЦветФона = Неопределено
										, ЦветТекста = Неопределено
										, ЭтапРезультата = Неопределено
										, РезультатСделки = Неопределено
										, ИндексЭтапа = Неопределено
										, ДоступностьЗавершающихЭтапов = Истина
										, ПричинаОтказа = Неопределено) Экспорт
	
	ИндексВиджета 		= ПолучитьИндексСтроки(ГруппаРодитель.Имя); //?(ЗначениеЗаполнено(ЭтапРезультата), Строка(ЭтапРезультата), "") + ПолучитьИндексСтроки(ГруппаРодитель.Имя);
	ИндексЭтапаСтрокой	= ?(ИндексЭтапа = Неопределено, "", "_ИндексПричины_" + Формат(ИндексЭтапа, "ЧН=0; ЧГ=0"));
	ЗаголовокЭлемента 	= СтрЗаменить(ТРег(Заголовок), " ", "");
	Если ЭтапРезультата = Перечисления.РезультатыСделок.Успех Тогда
		ИмяГруппы 		= ?(ЗначениеЗаполнено(ЭтапРезультата), Строка(ЭтапРезультата) + "_", "");
		ИмяКоманды  	= "ИзменитьЭтапУспех_" + ИндексВиджета;
		ЦветФона 		= ?(ДоступностьЗавершающихЭтапов ИЛИ РезультатСделки = ЭтапРезультата, Новый Цвет(72, 193, 123), Новый Цвет(206, 230, 215)); 
		ЦветТекста 		= ?(ДоступностьЗавершающихЭтапов ИЛИ РезультатСделки = ЭтапРезультата, Новый Цвет(255, 255, 255), Новый Цвет(79, 79, 79));
	ИначеЕсли ЭтапРезультата = Перечисления.РезультатыСделок.Отказ Тогда
		ИмяКоманды  	= "ИзменитьЭтапОтказ_" + ИндексВиджета + ИндексЭтапаСтрокой;
		ЦветФона 		= ?(ДоступностьЗавершающихЭтапов ИЛИ (РезультатСделки = ЭтапРезультата И ПричинаОтказа = Форма.ПричинаОтказа), Новый Цвет(246, 110, 110), Новый Цвет(246, 188, 188));
		ЦветТекста 		= ?(ДоступностьЗавершающихЭтапов ИЛИ (РезультатСделки = ЭтапРезультата И ПричинаОтказа = Форма.ПричинаОтказа), Новый Цвет(255, 255, 255), Новый Цвет(79, 79, 79));		
	Иначе 	
		ИмяКоманды  	= ?(ЗаголовокЭлемента = НСтр("ru = 'Санирован'; en = 'Sanitized'"), "ИзменитьЭтапУспех_" + ИндексВиджета, "ИзменитьЭтапОтказ_" + ИндексВиджета);
		Если ЦветФона = Неопределено Тогда 
			ЦветФона 	= Новый Цвет(245, 245, 245);
		КонецЕсли;
		Если ЦветТекста = Неопределено Тогда 
			ЦветТекста 		= Новый Цвет();		
		КонецЕсли;
	КонецЕсли;
	
	// Создание группы завершающих этапов.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаЗавершающегоЭтапа_" + ИмяГруппы + ИндексВиджета + ИндексЭтапаСтрокой);
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРодитель);
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
	ГруппаЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	ГруппаЭтапа.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Полуторный;
	ГруппаЭтапа.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
	// ГруппаЭтапа.Ширина = 15;
	// ГруппаЭтапа.РастягиватьПоГоризонтали = Ложь;
	
	// Создаем картинку
	ПараметрыДекорации = Новый Структура;
	ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЗавершающийЭтапСделки_" + ИмяГруппы + ИндексВиджета + ИндексЭтапаСтрокой);
	ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
	ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.Пустая);
	ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
	КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
	КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
	КартинкаВида.Ширина					 				= 2;
	КартинкаВида.Высота					 				= 1;
	КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   		, "РезультатЭтапа_" + ИмяКоманды + ИндексЭтапаСтрокой);
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		, ГруппаЭтапа);
	ПараметрыГруппы.Вставить("Группировка"   		, ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
	ГруппаКнопкиЭтапа = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	ГруппаКнопкиЭтапа.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
	ГруппаКнопкиЭтапа.Ширина = 30;
	ГруппаКнопкиЭтапа.РастягиватьПоГоризонтали = Ложь;
	ГруппаКнопкиЭтапа.ЦветФона = ЦветФона;  
	
	// Создаем команду кнопки.
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
	ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , ИмяКоманды);
	КомандаКнопки = СоздатьКомандуЭлемента(Форма, ПараметрыКоманды);
	
	// Создаем кнопку.
	ПараметрыКнопки = Новый Структура;
	ПараметрыКнопки.Вставить("Заголовок"   	 	 	, Заголовок);
	ПараметрыКнопки.Вставить("ИмяЭлемента"   	 	, "РезультатЭтапа_" + ИмяКоманды + ИндексЭтапаСтрокой);
	ПараметрыКнопки.Вставить("КнопкаОтображение" 	, ОтображениеКнопки.Текст);
	ПараметрыКнопки.Вставить("КомандаКнопки" 	 	, КомандаКнопки);
	ПараметрыКнопки.Вставить("РазмерШрифта"  	 	, 10);
	ПараметрыКнопки.Вставить("ГруппаЭлемента"	 	, ГруппаКнопкиЭтапа);
	ПараметрыКнопки.Вставить("Доступность"			, ДоступностьЗавершающихЭтапов);
	
	КнопкаЭтапа = СоздатьЭлементКнопка(Форма, ПараметрыКнопки);
	КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;
	КнопкаЭтапа.ЦветТекста 				 = ЦветТекста;
	
	// Создаем картинку
	ПараметрыДекорации = Новый Структура;
	ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЗавершающийЭтапСделки_Пустая" + ИмяГруппы + ИндексВиджета + ИндексЭтапаСтрокой);
	ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
	ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.Пустая);
	ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
	КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
	КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
	КартинкаВида.Ширина					 				= 2;
	КартинкаВида.Высота					 				= 1;
	КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
	
КонецПроцедуры

// Процедура, СоздатьГруппуПричинОтказа.
//
Процедура СоздатьГруппуПричинОтказа(Форма, ГруппаРодитель, ИндексВиджета) Экспорт
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаПричиныОтказа_" + ИндексВиджета);
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРодитель);
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("Видимость"   	 , Ложь);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеВГруппе"   	 , ВертикальноеПоложениеЭлемента.Центр);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеПодчиненных"	 , ВертикальноеПоложениеЭлемента.Центр);
	
	ГруппаПричинОтказа = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	ГруппаПричинОтказа.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	ГруппаПричинОтказа.ВертикальныйИнтервал	  = ИнтервалМеждуЭлементамиФормы.Половинный;
	
	ОбновитьПричиныОтказа(Форма, ГруппаПричинОтказа, ИндексВиджета);

КонецПроцедуры

// Процедура, СоздатьКнопкиПричиныОтказов.
//
Процедура ОбновитьПричиныОтказа(Форма, ГруппаРодитель, ИндексВиджета)
	 
	 Если Форма.ПричиныОтказов.Количество() = 0 Тогда	 
		 Возврат;
	 КонецЕсли;
	 	 
	 ТаблицаОтказов = Форма.Элементы.Добавить("ТаблицаПричинОтказов_" + ИндексВиджета, Тип("ТаблицаФормы"), ГруппаРодитель);
	 ТаблицаОтказов.ПутьКДанным = "ПричиныОтказов";
	 ТаблицаОтказов.УстановитьДействие("Выбор","ОбработчикТаблицаОтказовВыбор");
	 ТаблицаОтказов.Ширина 							= 29;
	 ТаблицаОтказов.Шапка 							= Ложь;
	 ТаблицаОтказов.ЦветРамки 				 	  	= Новый Цвет(255,255,255);
