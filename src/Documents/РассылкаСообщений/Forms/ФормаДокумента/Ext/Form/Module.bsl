Процедура РекомендацииСкрыть(Команда)
	
	Элементы.ГруппаРекомендацияВсплывающая.Скрыть();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "НачалоВыбора" табличная часть "Получатели", поле ввода "Получатель".
//
Процедура ПолучателиПолучательНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПолучателиПолучательНачалоВыбораЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты",,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Получатели Получатель начало выбора завершение.
// Завершение немодального открытия формы - Справочник Контрагенты ФормаВыбораКлиенты
// Параметры:
//  Результат				 - 	 Результат Оповещения 
//  ДополнительныеПараметры	 - 	 Параметры Оповещения
//
Процедура ПолучателиПолучательНачалоВыбораЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Элементы.Получатели.ТекущиеДанные.Получатель = Результат;
		ПолучателиПолучательПриИзменении(Неопределено);
		
	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
// Процедура - Получатели сообщений сервис рассылки при изменении.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ПолучателиСообщенийСервисРассылкиПриИзменении(Элемент)
	
	ПолучателиСообщенийСервисРассылкиПриИзмененииСервер(Элементы.Получатели.ТекущиеДанные.КлючСтроки);
	
КонецПроцедуры

&НаСервере
// Процедура - Получатели сообщений сервис рассылки при изменении сервер.
//
// Параметры:
//  КлючСтроки	 - 	 - 
//
Процедура ПолучателиСообщенийСервисРассылкиПриИзмененииСервер(КлючСтроки)
	
	СтрокаДанных = Объект.Получатели.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки))[0];
		
	СтрокаДанных.НомерТелефона = Неопределено;
	СтрокаДанных.ТипОтправки   = Неопределено;
	СтрокаДанных.Активность    = Истина;
	
	Если ЗначениеЗаполнено(СтрокаДанных.СервисРассылки) Тогда
		
		Если ТипЗнч(СтрокаДанных.СервисРассылки) = Тип("СправочникСсылка.ВнешниеСистемы")
			И СтрокаДанных.СервисРассылки.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet Тогда
			
			ЗаполнитьДанныеПолучателяPushУведомленияWallet(СтрокаДанных);
			
			СтрокаДанных.ТипОтправки = "pushWallet";
			СтрокаДанных.Активность  = ЭтотОбъект.ОтправкаPush;
			
		ИначеЕсли ТипЗнч(СтрокаДанных.СервисРассылки) = Тип("СправочникСсылка.ВнешниеСистемы") Тогда
			
			СтрокаДанных.ТипОтправки = "messenger";
			СтрокаДанных.Активность  = ЭтотОбъект.ОтправкаМессенджер;
			
			Если СтрокаДанных.СервисРассылки.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
				СтрокаДанных.НомерТелефона = Справочники.Контрагенты.ПолучитьНомерТелефонаДляРассылки(СтрокаДанных.Получатель, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(СтрокаДанных.СервисРассылки) = Тип("СправочникСсылка.СервисыРассылки") Тогда
			
			ЗаполнитьДанныеПолучателяSMSСообщения(СтрокаДанных);
			
			СтрокаДанных.ТипОтправки = "sms";
			СтрокаДанных.Активность  = ЭтотОбъект.ОтправкаSMS;
			
		КонецЕсли;	
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить данные получателя push уведомления.
//
// Параметры:
//  СтрокаДанных - 	 - 
//
Процедура ЗаполнитьДанныеПолучателяPushУведомленияWallet(СтрокаДанных)
	
	Если Справочники.Карты.ЕстьКартыWallet(СтрокаДанных.Получатель) Тогда
		
		СервисРассылки = ?(ЗначениеЗаполнено(СтрокаДанных.СервисРассылки), СтрокаДанных.СервисРассылки, ЭтотОбъект.ДоступныеСервисыРассылки.Push[0]);
		
		ПараметрыПоиска = Новый Структура;
		ПараметрыПоиска.Вставить("Получатель"    , СтрокаДанных.Получатель);
		ПараметрыПоиска.Вставить("СервисРассылки", СервисРассылки);
		
		Если Объект.Получатели.НайтиСтроки(ПараметрыПоиска).Количество() = 0 Тогда
			
			СтрокаДанных.СервисРассылки = СервисРассылки;
			СтрокаДанных.ТипОтправки    = "pushWallet";
			СтрокаДанных.Активность     = ЭтотОбъект.ОтправкаPush;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
