			ВыбПериод =  Неопределено;
		КонецЕсли;
		
		ВыбПериод = НачалоДня(ОтборПериод.ДатаНачала) + (НомерКолонки-5)*24*60*60;
		
		Если ВыбПериод > отборПериод.ДатаОкончания Тогда
			ВыбПериод =  Неопределено;
		КонецЕсли;       		
	Исключение
		ВыбПериод =  Неопределено;
	КонецПопытки;
		
	// Сотрудник.
	НомерСтроки		= Сред(ИмяОбласти, 2, позиция - 2 );
	ИД_Сотрудника	= ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтроки,Символы.НПП,"")+"C2").Текст;
	
	Сотрудник		= ?(ЭтоУникальныйИдентификатор(ИД_Сотрудника), НайтиСотрудникаПоИД(ИД_Сотрудника), ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка")); 
	
	// Содержимое ячейки.
	Содержимое = ГрафикПериодовРаботыТабДок.Область(ИмяОбласти).Текст;

