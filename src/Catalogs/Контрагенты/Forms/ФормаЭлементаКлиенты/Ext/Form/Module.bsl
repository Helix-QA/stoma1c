// Процедура, обновляет данные изменяемых телефонов.
//
Процедура ОбновитьДанныеИзменяемыхТелефонов()
	
	Для Каждого СтрокаКИ Из ЭтотОбъект.КонтактнаяИнформация Цикл
		
		Если СтрокаКИ.Тип <> ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон") Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавлятьНомер = Истина;
		ИдентификаторСтроки = СтрокаКИ.ПолучитьИдентификатор();
		
		Для Каждого ЭлементСписка Из ЭтотОбъект.ИзменяемыеТелефоныМессенджера Цикл
			
			ДанныеНомера = ЭлементСписка.Значение;
			
			Если ДанныеНомера.Идентификатор = ИдентификаторСтроки Тогда
				ДобавлятьНомер = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ДобавлятьНомер = Истина Тогда
			
			ДанныеНомера = Новый Структура;
			ДанныеНомера.Вставить("Идентификатор"	, ИдентификаторСтроки);
			ДанныеНомера.Вставить("НомерТелефона"	, "");
			ДанныеНомера.Вставить("ИзмененныйНомер"	, "");
			
			ЭтотОбъект.ИзменяемыеТелефоныМессенджера.Добавить(ДанныеНомера);
			
		КонецЕсли;
		
	КонецЦикла;
	
