// Функция - Get list reasons of canceling
// 
// Возвращаемое значение:
//   - 
//
Функция list_reasons_canceling() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПричиныОтменыЗаписи.Ссылка КАК Ссылка,
	|	ПричиныОтменыЗаписи.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ПричиныОтменыЗаписи КАК ПричиныОтменыЗаписи
	|ГДЕ
	|	НЕ ПричиныОтменыЗаписи.ПометкаУдаления");
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	МассивПричинОтменыВизита = Новый Массив;
	Для Каждого ПричинаОтмены Из РезультатЗапроса Цикл
		
		СтруктураПричинаОтмены = Новый Структура;
		СтруктураПричинаОтмены.Вставить("УИД"		  , УникальныйИдентификатор(ПричинаОтмены.Ссылка));
		СтруктураПричинаОтмены.Вставить("Наименование", ПричинаОтмены.Наименование);
		МассивПричинОтменыВизита.Добавить(СтруктураПричинаОтмены);
		
	КонецЦикла;
	
	Возврат ПолучитьСтруктуруОтвета(МассивПричинОтменыВизита);
	
КонецФункции

#КонецОбласти

#Область list_appointment

// Функция - List appointment
//
// Параметры:
//  ОтборКлиент			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  Сотрудник			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция list_appointment(ОтборКлиент, СтруктурнаяЕдиница, Сотрудник) Экспорт
	
	РольСотрудника		= ПолучитьРольСотрудника(Сотрудник);
	ЭтоВрач				= РольСотрудника = Перечисления.РольПользователя.Врач ИЛИ РольСотрудника = Перечисления.РольПользователя.ГлавныйВрач;
	ПараметрыНастроек	= Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();
	
	Если ЭтоВрач И ПараметрыНастроек <> Неопределено И ПараметрыНастроек.Свойство("НеВыводитьИсториюПриемовПоКлиенту") И ПараметрыНастроек.НеВыводитьИсториюПриемовПоКлиенту = Истина Тогда
		Возврат ПолучитьСтруктуруОтвета(,,,Ложь);	
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Ссылка КАК Ссылка,
	|	Прием.Номер КАК Номер,
	|	Прием.КурсЛечения КАК КурсЛечения,
	|	Прием.Дата КАК Дата,
	|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
	|	Прием.РезультатПриема КАК РезультатПриема,
	|	Прием.ЛечениеВрача.Сотрудник КАК ЛечениеВрачаСотрудник,
	|	Прием.ЛечениеВрача.ДатаНачала КАК ЛечениеДатаНачала,
	|	Прием.ЛечениеВрача.ДатаОкончания КАК ЛечениеДатаОкончания,
	|	Прием.ЛечениеВрача.Сотрудник.НаименованиеСокращенное КАК НаименованиеСокращенное,
	|	Прием.ЛечениеВрача.Сотрудник.Наименование КАК Наименование,
	|	Прием.ПолисМедСтрахования.Наименование КАК ПолисМедСтрахования
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	НЕ Прием.ПометкаУдаления
	|	И Прием.Контрагент = &Контрагент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|ИТОГИ ПО
	|	КурсЛечения,
	|	Прием.ЛечениеВрача
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КонтрагентыСведенияДляСписка.ДатаПервогоПриема КАК ДатаПервогоПриема,
	|	КонтрагентыСведенияДляСписка.ДатаПоследнегоПриема КАК ДатаПоследнегоПриема,
	|	КонтрагентыСведенияДляСписка.КоличествоПриемов КАК КоличествоПриемов,
	|	КонтрагентыСведенияДляСписка.Контрагент.Комментарий КАК КонтрагентКомментарий,
	|	КонтрагентыСведенияДляСписка.Контрагент.ДатаРегистрации КАК КонтрагентДатаРегистрации
	|ИЗ
	|	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|ГДЕ
	|	КонтрагентыСведенияДляСписка.Контрагент = &Контрагент");
	
	Запрос.УстановитьПараметр("Контрагент"        , ОтборКлиент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	МассивРезультатов		= Запрос.ВыполнитьПакет();
	ВыборкаКурсовЛечения	= МассивРезультатов[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	МассивПриемовПациента	= Новый Массив;	
	
	Пока ВыборкаКурсовЛечения.Следующий() Цикл 			
		
		Если ЗначениеЗаполнено(ВыборкаКурсовЛечения.КурсЛечения) Тогда		
			
			ВыборкаЛечения = ВыборкаКурсовЛечения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаЛечения.Следующий() Цикл 				
				
				Если ЗначениеЗаполнено(ВыборкаЛечения.ЛечениеВрачаСотрудник) Тогда
					ПредставлениеСотрудника = ?(ЗначениеЗаполнено(ВыборкаЛечения.НаименованиеСокращенное), ВыборкаЛечения.НаименованиеСокращенное, ВыборкаЛечения.Наименование); 
				Иначе
					ПредставлениеСотрудника = "";
				КонецЕсли;
				
				ПредставлениеЛечения = "Лечение" + ?(ЗначениеЗаполнено(ПредставлениеСотрудника), " у " + ПредставлениеСотрудника, "");
				ПериодЛечения = ?(ЗначениеЗаполнено(ВыборкаЛечения.ЛечениеДатаНачала), "с " + Формат(ВыборкаЛечения.ЛечениеДатаНачала, "ДФ=dd.MM.yyyy"), "") 
				+ ?(ЗначениеЗаполнено(ВыборкаЛечения.ЛечениеДатаОкончания), " по " + Формат(ВыборкаЛечения.ЛечениеДатаОкончания, "ДФ=dd.MM.yyyy"), "");			
				
				ДетальныеЗаписи = ВыборкаЛечения.Выбрать();
				
				МассивДетальныхЗаписей = Новый Массив;
				Пока ДетальныеЗаписи.Следующий() Цикл 
					
					ПредставлениеПриема = Формат(ДетальныеЗаписи.Дата, "ДФ='dd MMMM yyyy'") 
					+ Формат(ДетальныеЗаписи.ВремяНачалаПриема, "ДФ=''' в'' ЧЧ:мм'") 
					+ ?(ДетальныеЗаписи.РезультатПриема <> 0, ", Прием окончен", ", Прием начат");
					
					СтруктураПриема = Новый Структура;
					СтруктураПриема.Вставить("УИДПриема"			, УникальныйИдентификатор(ДетальныеЗаписи.Ссылка));
					СтруктураПриема.Вставить("ПредставлениеВерхнее"	, ПредставлениеПриема);	
					СтруктураПриема.Вставить("ПредставлениеНижнее"	, ДетальныеЗаписи.ПолисМедСтрахования);
					МассивДетальныхЗаписей.Добавить(СтруктураПриема);
					
				КонецЦикла;
				
				ЛечениеПациента = Новый Структура;
				ЛечениеПациента.Вставить("ПредставлениеВерхнее"		, ПредставлениеЛечения);
				ЛечениеПациента.Вставить("МассивДетальныхЗаписей"	, МассивДетальныхЗаписей);				
				ЛечениеПациента.Вставить("ПредставлениеНижнее"		, ПериодЛечения);
				МассивПриемовПациента.Добавить(ЛечениеПациента);
				
			КонецЦикла;
			
		Иначе 
			
			ВыборкаЛечения = ВыборкаКурсовЛечения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
			
			Пока ВыборкаЛечения.Следующий() Цикл
				
				ДетальныеЗаписи = ВыборкаЛечения.Выбрать();
				
				МассивДетальныхЗаписей = Новый Массив;
				Пока ДетальныеЗаписи.Следующий() Цикл
					
					ПредставлениеПриема = Формат(ДетальныеЗаписи.Дата, "ДФ='dd MMMM yyyy'") 
					+ Формат(ДетальныеЗаписи.ВремяНачалаПриема, "ДФ=''' в'' ЧЧ:мм'") 
					+ ?(ДетальныеЗаписи.РезультатПриема <> 0, ", Прием окончен", ", Прием начат");
					
					СтруктураПриема = Новый Структура;
					СтруктураПриема.Вставить("УИДПриема"			, УникальныйИдентификатор(ДетальныеЗаписи.Ссылка));
					СтруктураПриема.Вставить("ПредставлениеВерхнее"	, ПредставлениеПриема);
					СтруктураПриема.Вставить("ПредставлениеНижнее"	, ДетальныеЗаписи.ПолисМедСтрахования);
					МассивДетальныхЗаписей.Добавить(СтруктураПриема);
					
				КонецЦикла;
				
				ЛечениеПациента = Новый Структура;
				ЛечениеПациента.Вставить("ПредставлениеВерхнее"		, Неопределено);
				ЛечениеПациента.Вставить("МассивДетальныхЗаписей"	, МассивДетальныхЗаписей);
				ЛечениеПациента.Вставить("ПредставлениеНижнее"		, Неопределено);
				МассивПриемовПациента.Добавить(ЛечениеПациента);
				
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("МассивВизитовКлиента", МассивПриемовПациента);
	
	Выборка = МассивРезультатов[1].Выбрать();
	Если Выборка.Следующий() Тогда
		СтруктураВозврата.Вставить("ДатаПервогоВизита"			, Выборка.ДатаПервогоПриема);
		СтруктураВозврата.Вставить("ДатаПоследнегоВизита"		, Выборка.ДатаПоследнегоПриема);
		СтруктураВозврата.Вставить("КоличествоВизитов"			, Выборка.КоличествоПриемов);
		СтруктураВозврата.Вставить("Комментарий"				, Выборка.КонтрагентКомментарий);
		СтруктураВозврата.Вставить("КонтрагентДатаРегистрации"	, Выборка.КонтрагентДатаРегистрации);
	КонецЕсли;
	
	Возврат ПолучитьСтруктуруОтвета(ВалидацияJSON(СтруктураВозврата));
	
КонецФункции

#КонецОбласти

#Область employee_working_days

// Функция - Get employee working days
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Сотрудник			 - 	 - 
//  ДатаНачала			 - 	 - 
//  ДатаОкончания		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция employee_working_days(СтруктурнаяЕдиница, Сотрудник, ДатаНачала, ДатаОкончания) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	НАЧАЛОПЕРИОДА(Событие.Дата, ДЕНЬ) КАК ДеньИнтервала
	|ПОМЕСТИТЬ ТаблицаЗанятыхДней
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.Врач = &Сотрудник
	|	И Событие.Проведен
	|	И Событие.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Событие.ДатаСоздания МЕЖДУ &ДатаНачала И &ДатаОкончания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СвободныеИнтервалыСотрудников.ДеньИнтервала КАК ДеньИнтервала,
	|	""РабочийДень"" КАК ТипДня
	|ИЗ
	|	РегистрСведений.СвободныеИнтервалыСотрудников КАК СвободныеИнтервалыСотрудников
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаЗанятыхДней КАК ТаблицаЗанятыхДней
	|		ПО СвободныеИнтервалыСотрудников.ДеньИнтервала = ТаблицаЗанятыхДней.ДеньИнтервала
	|ГДЕ
	|	СвободныеИнтервалыСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И СвободныеИнтервалыСотрудников.Сотрудник = &Сотрудник
	|	И СвободныеИнтервалыСотрудников.ДеньИнтервала МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ТаблицаЗанятыхДней.ДеньИнтервала ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ТаблицаЗанятыхДней.ДеньИнтервала,
	|	""РабочийЗанятыйДень""
	|ИЗ
	|	ТаблицаЗанятыхДней КАК ТаблицаЗанятыхДней");
	
	Запрос.УстановитьПараметр("Сотрудник"			, Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаНачала"			, ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания"		, ДатаОкончания);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	МассивВозврата = Новый Массив;
	
	Для Каждого СтрокаТЗ Из РезультатЗапроса Цикл
		МассивВозврата.Добавить(Новый Структура("ДеньИнтервала, ТипДня", СтрокаТЗ.ДеньИнтервала, СтрокаТЗ.ТипДня));	
	КонецЦикла;
	
	Возврат ПолучитьСтруктуруОтвета(МассивВозврата);	
	
КонецФункции

#КонецОбласти

