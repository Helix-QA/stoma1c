// Процедура - Настройка полей сортировки подбора
//
Процедура НастройкаСортировкиПодбораЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоУслуги = Параметры.ТекущаяСтраница = "Лечение";	
	ТекущаяТаблица = ЭтотОбъект["_ПодборНоменклатур" + ?(ЭтоУслуги, "Услуги", "")];	
	Элементы["КнопкаНастройкаСортировки_" + Параметры.ТекущаяСтраница].Заголовок = Результат.Представление;
	ТекущийПорядокСортировки = ПолучитьТекущийПорядокСортировкиПодбора(ТекущаяТаблица);
	ИзменитьСортировкуПодбора(ТекущаяТаблица, Результат.Значение, ТекущийПорядокСортировки);
	
	Если ЭтоУслуги Тогда
		ЭтотОбъект.ПолеСортировкиУслуг = Результат.Значение;	
	Иначе	
		ЭтотОбъект.ПолеСортировкиЗапасов = Результат.Значение;	
	КонецЕсли; 
	
КонецПроцедуры


