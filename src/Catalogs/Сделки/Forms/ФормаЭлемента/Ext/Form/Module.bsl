// Процедура проверяет дублирование клиента по телефони и E-mail.
//
Процедура ПроверкаДублированияКлиентаКонтактнаяИнформация(ДанныеКИ, ТекстРедактирования) Экспорт
	
	Если (ПредупреждениеДублирование <> Неопределено И ПредупреждениеДублирование = Истина) Тогда
		Возврат;	
	КонецЕсли;
	
	ТипКИ = ДанныеКИ.Тип;
	
	МассивКлиентов = ПроверитьНаДублированиеКлиентаКИ(Объект.Контрагент, ТипКИ, ТекстРедактирования);
	
	Если МассивКлиентов <> Неопределено И МассивКлиентов.Количество() > 0 Тогда		
		Если МассивКлиентов.Количество() = 1 Тогда 
			Текст = НСтр("ru = 'Клиент с такими данными уже существуют. Прикрепить клиента к сделке?'; en = 'A client with this data already exists. Attach a client to a transaction?'");		
			ПоказатьВопрос(Новый ОписаниеОповещения("ПроверкаДублированияКлиентаКонтактнаяИнформацияОтвет", ЭтотОбъект, МассивКлиентов), Текст, РежимДиалогаВопрос.ДаНет);
		Иначе 	
			Текст = НСтр("ru = 'Клиенты с такими данными уже существуют, открыть список клиентов?'; en = 'Clients with such data already exist, open a list of clients?'");		
			ПоказатьВопрос(Новый ОписаниеОповещения("ПроверкаДублированияКлиентаКонтактнаяИнформацияОтвет", ЭтотОбъект, МассивКлиентов), Текст, РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли; 
	
