// Процедура, выполняет заполнения признака.
// 
Процедура ЗаполнитьПризнакИспользованияХарактеристик(МассивЗапасов)
	
	Для Каждого ЭлементМассива из МассивЗапасов Цикл
		Если ЗначениеЗаполнено(ЭлементМассива.Номенклатура) Тогда
			ЭлементМассива.Вставить("ХарактеристикиИспользуются", ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭлементМассива.Номенклатура, "ИспользоватьПартии"));
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

