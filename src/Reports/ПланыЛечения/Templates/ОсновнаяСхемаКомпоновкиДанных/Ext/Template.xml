		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПланЛечения.Ссылка КАК ПланЛечения,
	ПланЛечения.СуммаДокумента КАК СуммаДокумента,
	ПланЛечения.СуммаОплачено КАК СуммаАванса,
	ПланЛечения.Контрагент КАК Контрагент,
	ПланЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
ИЗ
	Документ.ПланЛечения КАК ПланЛечения
ГДЕ
	ПланЛечения.Проведен
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
					ИЛИ &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ПланЛечения.Дата &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
					ИЛИ &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ПланЛечения.Дата &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}</query>
	</dataSet>
