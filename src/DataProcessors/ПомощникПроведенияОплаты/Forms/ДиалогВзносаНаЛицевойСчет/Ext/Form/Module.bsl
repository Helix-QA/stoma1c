&НаСервере
// Процедура - Построить строку динаимческой таблицы задолженностей.
//
Процедура СоздатьСтрокуДинаимческойТаблицыДоступныхВидовОплат(ОсновнаяГруппа, ИдСтрокиДанных, НомерСтрокиДанВерхУр, НомерСтрокиДанНижУр, Заголовок, ЗаголовокГруппы, Картинка = Неопределено)
	
	НомерСтрокиДан = "" + НомерСтрокиДанВерхУр + ?(НомерСтрокиДанНижУр > -1, "x" + НомерСтрокиДанНижУр, "");
	
	ПодгуппаСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатСтрока_0,
	НомерСтрокиДан,
	ОсновнаяГруппа);
	
	УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатаНаименованиеСтрока_0, 
	НомерСтрокиДан,
	ПодгуппаСтроки,
	"ОбработчикНажатияВидыОплатВыбор",
	Заголовок,,,
	Картинка);
	
	ПодгуппаРедактирванияСуммы = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаВидыОплатСуммаСтрока_0,
	НомерСтрокиДан,
	ПодгуппаСтроки);
	
	// Сумма оплаты
	СоздатьГруппуСуммыВнесеннойОплаты(ПодгуппаРедактирванияСуммы, ИдСтрокиДанных, НомерСтрокиДанВерхУр, НомерСтрокиДанНижУр);
	
КонецПроцедуры

&НаСервере
// Процедура - Построить группу суммы внесенной оплаты.
//
Процедура СоздатьГруппуСуммыВнесеннойОплаты(РодительскаяГруппа, ИдСтрокиДанных, НомерСтрокиДанВерхУр, НомерСтрокиДанНижУр)
	
	НомерСтрокиДан = "" + НомерСтрокиДанВерхУр + ?(НомерСтрокиДанНижУр > -1, "x" + НомерСтрокиДанНижУр, "");
	СтрокаДанных   = ЭтотОбъект.ВидыОплат.НайтиПоИдентификатору(ИдСтрокиДанных);
	
	Если СтрокаДанных.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные ИЛИ СтрокаДанных.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта  Тогда
				
		ПолеВводаСерииСертификатаИлиВидаЛС = УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
		ЭтаФорма,
		Элементы.ПолеВыбораВидаЛицевогоСчета_0, 
		НомерСтрокиДан,
		Тип("ПолеФормы"), 
		РодительскаяГруппа,
		"ВидыОплат[" + НомерСтрокиДанВерхУр +"]" + ?(НомерСтрокиДанНижУр > -1, "[" + НомерСтрокиДанНижУр + "]", "") + ".ВыборВидаЛицевогоСчета");
		
		ПолеВводаСерииСертификатаИлиВидаЛС.Видимость = Истина;
		
	КонецЕсли;
	
	Если ПолеВводаСерииСертификатаИлиВидаЛС <> Неопределено Тогда 
		ПолеВводаСерииСертификатаИлиВидаЛС.Видимость = Ложь;         
	КонецЕсли;
	
	ПолеВводаОплаты = УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ПолеВидыОплатВводСуммыСтрока_0, 
	НомерСтрокиДан,
	Тип("ПолеФормы"), 
	РодительскаяГруппа,
	"ВидыОплат[" + НомерСтрокиДанВерхУр +"]" + ?(НомерСтрокиДанНижУр > -1, "[" + НомерСтрокиДанНижУр + "]", "") + ".Внесено");
	
	ПолеВводаОплаты.Видимость = Ложь;
	
	КнопкаПредставления =  УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатПредставлениеСуммыСтрока_0, 
	НомерСтрокиДан,
	РодительскаяГруппа);
	
	КнопкаПрименить =  УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатПрименитьеСуммуСтрока_0, 
	НомерСтрокиДан,
	РодительскаяГруппа);
	
	КнопкаУдалить =  УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КнопкаВидыОплатУдалитьСуммуСтрока_0, 
	НомерСтрокиДан,
	РодительскаяГруппа);
	
	СтрокаДанны = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы()[Число(НомерСтрокиДанВерхУр)];
	Если Число(НомерСтрокиДанНижУр) > -1 Тогда
		СтрокаДанны = СтрокаДанны.ПолучитьЭлементы()[Число(НомерСтрокиДанНижУр)];
	КонецЕсли;
	
	Если СтрокаДанны.Внесено > 0 Тогда
		
		КнопкаПредставления.Заголовок = Формат(СтрокаДанны.Внесено,"ЧДЦ=2");
		КнопкаПредставления.Видимость = Истина;
		КнопкаПрименить.Видимость     = Ложь;
		КнопкаУдалить.Видимость       = Истина;
		
	Иначе
		
		КнопкаПредставления.Заголовок =  "0,00";
		КнопкаПредставления.Видимость = Ложь;
		КнопкаПрименить.Видимость     = Ложь;
		КнопкаУдалить.Видимость       = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - При изменении выбора кассы оплаты
//
// Параметры:
//  Команда	 - 	 - 
