// Процедура - Признак отзвона клиенту
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПризнакОтзвонаКлиенту(Команда)

	Если Объект.ТелефонныйЗвонок = Ложь Тогда
		Объект.ТелефонныйЗвонок = Истина;
		// Меняем также и статус события
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.Подтверждена");
		УстановитьСвойстваЭлементамПодтвержденияЗаписи();		
	Иначе 
		
		Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.Подтверждена") И ЗначениеЗаполнено(Объект.ИдентификаторДиалога) Тогда  
			
			ОписаниеОповещенияСменыСтатуса = Новый ОписаниеОповещения("ПриОтменеПодтвержденияЗаписи", ЭтотОбъект);
			СписокКнопок = Новый СписокЗначений;
			СписокКнопок.Добавить(КодВозвратаДиалога.Да	, НСтр("ru = 'Да'; en = 'Yes'"));
			СписокКнопок.Добавить(КодВозвратаДиалога.Нет, НСтр("ru = 'Нет'; en = 'Not'"));
			Если ИспользуетсяРасширениеМессенджер Тогда 
				СписокКнопок.Добавить("ПоказатьДиалог"	, НСтр("ru = 'Открыть диалог с чат-ботом'; en = 'Open a chatbot dialog'"));
			КонецЕсли;	
			ПоказатьВопрос(ОписаниеОповещенияСменыСтатуса
						, НСтр("ru = 'Прием подтвержден пациентом посредством чат-бота. Отменить подтверждение приема?'; en = 'The appointment is confirmed by the patient via a chatbot. Cancel confirmation of receipt?'")
						, СписокКнопок
						,
						, КодВозвратаДиалога.Нет
						, НСтр("ru = 'Вопрос пользователю'; en = 'Question to the user'"));
						
			Возврат;
		КонецЕсли;
		Объект.ТелефонныйЗвонок = Ложь;
		// Меняем также и статус события
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыСобытия.НеПодтверждена");
		УстановитьСвойстваЭлементамПодтвержденияЗаписи();
	КонецЕсли;	

КонецПроцедуры

