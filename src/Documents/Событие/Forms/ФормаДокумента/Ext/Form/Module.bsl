// Функция, обработчик события "ПолучитьСписокСотрудниковОрганизации".
//
Функция ПолучитьСписокСотрудниковОрганизации(СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкиСотрудников.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НЕ НастройкиСотрудников.Сотрудник.ЭтоГруппа
	|	И (НастройкиСотрудников.Сотрудник В
	|				(ВЫБРАТЬ
	|					СвязкаПомещениеСотрудник.Сотрудник
	|				ИЗ
	|					РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник
	|				ГДЕ
	|					СвязкаПомещениеСотрудник.Помещение.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|			ИЛИ НЕ НастройкиСотрудников.Сотрудник В
	|					(ВЫБРАТЬ
	|						СвязкаПомещениеСотрудник.Сотрудник
	|					ИЗ
	|						РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник))
	|	И &СтруктурнаяЕдиница В (НастройкиСотрудников.СтруктурнаяЕдиница)
	|	И НастройкиСотрудников.Сотрудник.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НастройкиСотрудников.Сотрудник.Представление");
	
	Запрос.Параметры.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
КонецФункции

