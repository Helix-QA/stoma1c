		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Организация КАК Организация,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Контрагент КАК Контрагент,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса КАК ДокументАванса,
	СУММА(ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СуммаПриход) КАК СуммаПриход,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Период КАК Период
ПОМЕСТИТЬ ВТ_РегистрВзаиморасчеты
ИЗ
	РегистрНакопления.ВзаиморасчетыСКонтрагентами.ОстаткиИОбороты(
			,
			,
			Регистратор,
			,
			НЕ ДокументАванса В (НЕОПРЕДЕЛЕНО, ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка), ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка))
				И ВЫБОР
					КОГДА НЕ &amp;Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
							ИЛИ НЕ &amp;Контрагент = NULL
						ТОГДА Контрагент = &amp;Контрагент
					ИНАЧЕ ИСТИНА
				КОНЕЦ) КАК ВзаиморасчетыСКонтрагентамиОстаткиИОбороты

СГРУППИРОВАТЬ ПО
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.СтруктурнаяЕдиница,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Организация,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Контрагент,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.ДокументАванса,
	ВзаиморасчетыСКонтрагентамиОстаткиИОбороты.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НАЧАЛОПЕРИОДА(ВложенныйЗапрос.Период, ГОД) КАК Год,
	НАЧАЛОПЕРИОДА(ВложенныйЗапрос.Период, МЕСЯЦ) КАК Месяц,
	НАЧАЛОПЕРИОДА(ВложенныйЗапрос.Период, НЕДЕЛЯ) КАК Неделя,
	НАЧАЛОПЕРИОДА(ВложенныйЗапрос.Период, ДЕНЬ) КАК День,
	НАЧАЛОПЕРИОДА(ВложенныйЗапрос.Период, КВАРТАЛ) КАК Квартал,
	ВложенныйЗапрос.Период КАК Период,
	ВложенныйЗапрос.Документ КАК Документ,
	ВложенныйЗапрос.Сотрудник КАК Сотрудник,
	ВложенныйЗапрос.Контрагент КАК Контрагент,
	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	СУММА(ЕСТЬNULL(ВТ_РегистрВзаиморасчеты.СуммаПриход, 0)) КАК СуммаФактическойОплаты,
	СУММА(ЕСТЬNULL(ВложенныйЗапрос.СуммаПланируемойОплаты, 0)) КАК СуммаПланируемойОплаты,
	СУММА(ЕСТЬNULL(ВложенныйЗапрос.СуммаПланируемойОплаты, 0) - ЕСТЬNULL(ВТ_РегистрВзаиморасчеты.СуммаПриход, 0)) КАК ПланируемыйОстаток
ИЗ
	(ВЫБРАТЬ
		ПланыЛеченияОбороты.Период КАК Период,
		ПланыЛеченияОбороты.Регистратор КАК Документ,
		ПланыЛеченияОбороты.Регистратор.Сотрудник КАК Сотрудник,
		ПланыЛеченияОбороты.Контрагент КАК Контрагент,
		ПланыЛеченияОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		ПланыЛеченияОбороты.СуммаПриход КАК СуммаПланируемойОплаты
	ИЗ
		РегистрНакопления.ПланыЛечения.Обороты(
				,
				,
				Регистратор,
				ВЫБОР
					КОГДА НЕ &amp;Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
							ИЛИ НЕ &amp;Контрагент = NULL
						ТОГДА ПланЛечения.Контрагент = &amp;Контрагент
					ИНАЧЕ ИСТИНА
				КОНЕЦ) КАК ПланыЛеченияОбороты
	ГДЕ
		ПланыЛеченияОбороты.Регистратор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Принят)
	
	СГРУППИРОВАТЬ ПО
		ПланыЛеченияОбороты.Контрагент,
		ПланыЛеченияОбороты.СтруктурнаяЕдиница,
		ПланыЛеченияОбороты.Период,
		ПланыЛеченияОбороты.Регистратор,
		ПланыЛеченияОбороты.Регистратор.Сотрудник,
		ПланыЛеченияОбороты.СуммаПриход
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		НарядЗаказЗапасы.Ссылка.Дата,
		НарядЗаказЗапасы.Ссылка,
		НарядЗаказЗапасы.Ссылка.Сотрудник,
		НарядЗаказЗапасы.Ссылка.Контрагент,
		НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница,
		СУММА(НарядЗаказЗапасы.СуммаПродажи)
	ИЗ
		Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
	ГДЕ
		НарядЗаказЗапасы.Ссылка.Проведен
		И НарядЗаказЗапасы.ПланЛечения В (НЕОПРЕДЕЛЕНО, ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка), ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка))
		И ВЫБОР
				КОГДА НЕ &amp;Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
						ИЛИ НЕ &amp;Контрагент = NULL
					ТОГДА НарядЗаказЗапасы.Ссылка.Контрагент = &amp;Контрагент
				ИНАЧЕ ИСТИНА
			КОНЕЦ
	
	СГРУППИРОВАТЬ ПО
		НарядЗаказЗапасы.Ссылка,
		НарядЗаказЗапасы.Ссылка.Контрагент,
		НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница,
		НарядЗаказЗапасы.Ссылка.Дата,
		НарядЗаказЗапасы.Ссылка.Сотрудник) КАК ВложенныйЗапрос
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РегистрВзаиморасчеты КАК ВТ_РегистрВзаиморасчеты
		ПО ВложенныйЗапрос.Документ = ВТ_РегистрВзаиморасчеты.ДокументАванса

СГРУППИРОВАТЬ ПО
	ВложенныйЗапрос.Период,
	ВложенныйЗапрос.Документ,
	ВложенныйЗапрос.Сотрудник,
	ВложенныйЗапрос.Контрагент,
	ВложенныйЗапрос.СтруктурнаяЕдиница</query>
	</dataSet>
