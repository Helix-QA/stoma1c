#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик нажатия переключателя закладок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
	Если ВРег(Элемент.Имя) = ВРег("_ГруппаПодписи") Тогда		
		ГруппаПриветствияПодписиПриСменеСтраницы(Элементы.Подпись, "Подпись"); 
	ИначеЕсли ВРег(Элемент.Имя) = ВРег("_ГруппаПриветствия") Тогда        
		ГруппаПриветствияПодписиПриСменеСтраницы(Элементы.Приветствие, "Приветствие"); 		
	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
// Процедура Документ сформирован.
//
Процедура ТекстHTMLДокументСформирован(Элемент)
	
	Если Объект.Свойство(Элемент.Имя) Тогда	
		Если Элемент.Имя = "Приветствие" Тогда
			// Элемент.Документ.Body.innerHTML = "<html><body>" + Объект[Элемент.Имя] + "</body></html>";
			ПриветствиеHTML = "<html><body>" + Объект[Элемент.Имя] + "</body></html>";
		ИначеЕсли Элемент.Имя = "Подпись" Тогда
			ПодписьHTML = "<html><body>" + Объект[Элемент.Имя] + "</body></html>";
		КонецЕсли;
	КонецЕсли; 	                           
	
	Элемент.Документ.Body.scroll = "auto";
	Элемент.Документ.Body.contentEditable = "true";
	
КонецПроцедуры

&НаКлиенте   
// Процедура При нажатии на текст html.
//
Процедура ТекстHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Документ = Элемент.Документ;
	ПоказатьРежимыКнопок();
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте 
// Процедура при смене страницы.
//
Процедура ГруппаПриветствияПодписиПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	// Сохраняем текст HTML той страницы, с которой переключились
	ИмяАктивногоЭлемента = ТекущаяСтраница;
	Если ИмяАктивногоЭлемента = "Подпись" Тогда
		Объект.Приветствие = Элементы.Приветствие.Документ.Body.innerHTML;
	ИначеЕсли ИмяАктивногоЭлемента = "Приветствие" Тогда
		Объект.Подпись = Элементы.Подпись.Документ.Body.innerHTML;
	КонецЕсли;
	
	УстановитьАктивныйЭлементHTML();
	
	ТекстHTMLДокументСформирован(Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте  
// Процедура выполнения команды.
//
Процедура ВыполнитьКоманду(Кнопка)
	
	Команда = Сред(Кнопка.Имя, 8);
	Если Документ.queryCommandSupported(Команда) Тогда
		Документ.execCommand(Команда, Ложь);
		ПоказатьРежимыКнопок();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте 
// Процедура Показать режимы кнопок.
//
Процедура ПоказатьРежимыКнопок()
	
	Для каждого Группа Из Элементы.КоманднаяПанельКнопок.ПодчиненныеЭлементы Цикл 
		Если ТипЗнч(Группа) = Тип("ГруппаФормы") Тогда
			Для каждого Кнопка Из Группа.ПодчиненныеЭлементы Цикл
				Если ТипЗнч(Кнопка) = тип("КнопкаФормы") Тогда
					Команда = Сред(Кнопка.Имя, 8);
					Если Документ.queryCommandSupported(Команда) Тогда
						Попытка
							Кнопка.Пометка = Документ.queryCommandState(Команда);
						Исключение
						КонецПопытки;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла; 
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте   
// Процедура выполнения команды списк.
//
Процедура ВыполнитьКомандуСписка(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Команда = Сред(Элемент.Имя, 8);
	Если Документ.queryCommandSupported(Команда) Тогда
		Список = Элемент.СписокВыбора;
		Документ.execCommand(Команда, Истина, ВыбранноеЗначение);
		ПоказатьРежимыКнопок();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте    
// Процедура Вставить гиперссылку.
//
Процедура ВставитьГиперссылку(Команда)
	
	ОткрытьФорму("ОбщаяФорма.ВыборГиперссылки",,,,,,
	Новый ОписаниеОповещения("ВставитьГиперссылкуЗавершение", ЭтотОбъект), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора гиперссылки
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВставитьГиперссылкуЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если РезультатВыбора <> Неопределено Тогда
		Документ.execCommand("CreateLink", Ложь, РезультатВыбора);
		Модифицированность = Истина;
	КонецЕсли; 	

	ПоказатьРежимыКнопок();
	
КонецПроцедуры

&НаКлиенте  
// Процедура выбора цвета.
//
Процедура ВыборЦвета(Команда)
	
	ОткрытьФорму("Обработка.ВыборWebЦвета.Форма",,,,,,
	Новый ОписаниеОповещения("ВыборЦветаЗавершение", ЭтотОбъект, Команда), 
	РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора Цвета
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборЦветаЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если РезультатВыбора <> Неопределено Тогда
		Кнопка = Сред(ДополнительныеПараметры.Имя, 8);
		Если Документ.queryCommandSupported(Кнопка) Тогда
			Документ.execCommand(Кнопка, Ложь, "" + ПеревестиИз10(РезультатВыбора.Красный) + ПеревестиИз10(РезультатВыбора.Зеленый) + ПеревестиИз10(РезультатВыбора.Синий));
		КонецЕсли;
		Модифицированность = Истина;
	КонецЕсли; 	

	ПоказатьРежимыКнопок();
	
КонецПроцедуры

&НаКлиенте 
// Процедура приведения.
//
Функция ПеревестиИз10(Знач Значение = 0)
	
	Значение = Число(Значение);
	Если Значение <= 0 Тогда
		Возврат "00";
	КонецЕсли;
	
	Значение = Цел(Значение);
	Результат = "";
	
	Пока Значение > 0 Цикл
		Результат = Сред("0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ",Значение%16+1,1) + Результат;
		Значение = Цел(Значение/16);
	КонецЦикла;
	
	Если СтрДлина(Результат) = 1 Тогда
		Результат = "0" + Результат;
	КонецЕсли; 
  
	Возврат Результат;
	
КонецФункции

&НаКлиенте   
// Процедура добавления адресата.
