// Функция - Пустое содержание шаблона
//
// Параметры:
//  ШаблонСообщения	 - 	 - 
//  ИмяРеквизита	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПустоеСодержаниеШаблона(ШаблонСообщения, ИмяРеквизита = "", ВидДействия = Неопределено, Сообщение = "")
	
	ИмяРеквизитаПроверки2 = "";
	Если НЕ ЗначениеЗаполнено(ВидДействия) Тогда 
		ИмяРеквизитаПроверки = ИмяРеквизита;
	Иначе 
		Если ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру Тогда 
			ИмяРеквизитаПроверки = "ЗадачаОписание";
			Сообщение = НСтр("ru='Необходимо заполнить содержание в шаблоне для описания задачи!';en='You must fill in the content in the template for the task description!'")
		ИначеЕсли ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда	
			ИмяРеквизитаПроверки = "ТекстHTML";
			Сообщение = НСтр("ru='Необходимо заполнить содержание в шаблоне для электронного письма!';en='You must fill in the content in the email template!'")			
		ИначеЕсли ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки Тогда
			ИмяРеквизитаПроверки = "";
		Иначе 
			ИмяРеквизитаПроверки = "Содержание";
			ИмяРеквизитаПроверки2 = "СодержаниеМессенджер";			
			Сообщение = НСтр("ru='Необходимо заполнить содержание в шаблоне для генерируемых сообщений!';en='You must fill in the content in the template for generated messages!'")
		КонецЕсли;	
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ИмяРеквизитаПроверки) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ПустоеСодержание = Ложь;
	Попытка
		Если ИмяРеквизитаПроверки = "ТекстHTML" Тогда 
			ПарсерHTML 						= Новый ЧтениеHTML;
			ПарсерHTML.УстановитьСтроку(ШаблонСообщения[ИмяРеквизитаПроверки]);
			ПостроительDOM 					= Новый ПостроительDOM;
			ДокументHTML 					= ПостроительDOM.Прочитать(ПарсерHTML);
			ПустоеСодержание = ДокументHTML.Тело = Неопределено;
			Если ДокументHTML.Тело = Неопределено Тогда 
				Возврат Истина;
			Иначе 	
				Возврат ПустаяСтрока(СокрЛП(ДокументHTML.Тело.ТекстовоеСодержимое));
			КонецЕсли;	
		Иначе 	
			ПустоеСодержание = НЕ ЗначениеЗаполнено(СокрЛП(ШаблонСообщения[ИмяРеквизитаПроверки])) И НЕ ЗначениеЗаполнено(СокрЛП(ШаблонСообщения[ИмяРеквизитаПроверки2]));
		КонецЕсли;	
	Исключение
		
	КонецПопытки;
	
	Возврат ПустоеСодержание;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Действие зарегистрировано
//
// Параметры:
//  ИдентификаторДействия	 - 	 - 
//  СтандартнаяОбработка	 - 	 - 
//  СсылкаНаОбъектПустая	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДействиеЗарегистрировано(ИдентификаторДействия, ВидДействия, СтандартнаяОбработка = Истина, СсылкаНаОбъект = Неопределено)
	
	ФлагРегистрацииДействия = Ложь;
	ВидДействияИзЖурналаРегистрации = ВидДействия;
	Если ЗначениеЗаполнено(СсылкаНаОбъект) Тогда 
		ФлагРегистрацииДействия = РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.ДействиеЗарегистрировано(ИдентификаторДействия, ВидДействияИзЖурналаРегистрации); 
		СтандартнаяОбработка 	= НЕ ФлагРегистрацииДействия;
	КонецЕсли;	
	
	Если ФлагРегистрацииДействия Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ТриггерныеСобытияДействия.ВидДействия КАК ВидДействия
		               |ИЗ
		               |	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытияДействия
		               |ГДЕ
		               |	ТриггерныеСобытияДействия.Ссылка = &Ссылка
		               |	И ТриггерныеСобытияДействия.ИдентификаторДействия = &ИдентификаторДействия";
		
		Запрос.УстановитьПараметр("Ссылка"					, СсылкаНаОбъект);
		Запрос.УстановитьПараметр("ИдентификаторДействия"	, ИдентификаторДействия);
		
		ВыборкаДействия = Запрос.Выполнить().Выбрать();
		Если ВыборкаДействия.Следующий() Тогда 
			ВидДействия = ?(ЗначениеЗаполнено(ВидДействия), ВидДействия, ?(ЗначениеЗаполнено(ВыборкаДействия.ВидДействия), ВыборкаДействия.ВидДействия, ВидДействияИзЖурналаРегистрации));
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат ФлагРегистрацииДействия;
	
КонецФункции

