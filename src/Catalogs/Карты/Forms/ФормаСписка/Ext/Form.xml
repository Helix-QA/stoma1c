	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Заблокирована</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникКарты.Ссылка,
	СправочникКарты.ПометкаУдаления,
	СправочникКарты.Предопределенный,
	СправочникКарты.Код,
	СправочникКарты.Наименование,
	СправочникКарты.ВладелецКарты,
	СправочникКарты.Заблокирована,
	СправочникКарты.ДатаОткрытия,
	СправочникКарты.ТипКода,
	ВЫБОР
		КОГДА СправочникКарты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Магнитная)
			ТОГДА СправочникКарты.КодКарты
		ИНАЧЕ Штрихкоды.Штрихкод
	КОНЕЦ КАК КодКарты,
	ВЫБОР
		КОГДА СправочникКарты.Заблокирована
			ТОГДА "ЗАБЛОКИРОВАНА"
