#КонецОбласти

#Область Обработчики_Событий_формы
// Обработчики событий формы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	#Если ВебКлиент Тогда
		Возврат;      	
	#КонецЕсли
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	ВерсияСервераСЛК = ОпределитьВерсиюСервераСЛК();
	
	ЗаписьЖурналаРегистрации("Обновление СЛК", УровеньЖурналаРегистрации.Информация,,,НСтр("ru = 'Открытие помощника обновления СЛК...'"));
	// Пользователи.ПрерватьВыполнениеЕслиАвторизованВнешнийПользователь();
	
	ОписаниеОбновления = ПроверитьНаличиеТребуемойВерсииСЛК();
	
	Страницы = Элементы.Страницы.ПодчиненныеЭлементы;
	ИмяСтраницы = Страницы.СтраницаЗагрузкиОбновления.Имя;
	
	Если ОписаниеОбновления.КодСостояния = 501 Тогда // Обновление найдено
		Элементы.НадписьДоступноеОбновление.Заголовок = НСтр("ru = 'Версия'") + " " + ОписаниеОбновления.ВерсияСЛК;
		Элементы.НадписьРазмерОбновления.Заголовок = Строка(ОписаниеОбновления.РазмерФайла / (1024*1024)) + " Мбайт"; // Строка(РаботаСФайламиКлиентСервер.РазмерФайлаВКилоМегаГигаБайтах(ОписаниеОбновления.РазмерФайла, 2)) + " Мбайт";
	Иначе
		ИмяСтраницы = Страницы.СтраницаСообщенияОбОшибке.Имя;
		ПредставлениеОшибки = "Не удалось получить сведения о доступных обновлениях на сервере.";
		ТекстОшибки = ДополнитьОписаниеОшибки(ОписаниеОбновления.ОписаниеСостояния);
	КонецЕсли;
	
	// ++ Привелигированный режим
	УстановитьПривилегированныйРежим(Истина);
	
	ЗначениеХранилища = Константы.СтатусОбновленияКонфигурации.Получить();
	ОбновлениеВыполнено = Ложь;
	Если ЗначениеХранилища <> Неопределено Тогда
		СтатусОбновления = ЗначениеХранилища.Получить();
		ОбновлениеВыполнено = ?(СтатусОбновления = Неопределено, Ложь, СтатусОбновления.ОбновлениеВыполнено);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	// -- Привелигированный режим
	
	Элементы.Страницы.ТекущаяСтраница = Страницы[ИмяСтраницы];
	ПриИзмененииСтраницы();
	
	ОбновлениеУспешноПолучено = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЗаголовокФормы();
	
КонецПроцедуры

&НаСервере
////////////////////////////////////////////////////////////////////////////////
//
// Процедура ПриИзмененииСтраницы
//
// Описание: Производит необходимые действия при изменении страницы
//
Процедура ПриИзмененииСтраницы()
	
	Страницы = Элементы.Страницы;
	
	Если Страницы.ТекущаяСтраница = Страницы.ПодчиненныеЭлементы.ОбновлениеУспешноЗагружено Тогда
		
		МожноУстанавливать = СерверСЛКНаходитсяНаЭтомКомпьютере();
		
		Элементы.УстановитьОбновление.Видимость 			  = МожноУстанавливать;
		Элементы.НадписьПояснение.Видимость 				  = Не МожноУстанавливать;
		Элементы.НадписьПояснениеМожноУстанавливать.Видимость = МожноУстанавливать;
		
	КонецЕсли;
	
	ОбновитьЗаголовокФормы();
	
КонецПроцедуры // ПриИзмененииСтраницы

