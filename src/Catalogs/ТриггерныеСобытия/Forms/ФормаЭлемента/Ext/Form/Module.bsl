// Процедура - Результат настройки каналов уведомлений
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура РезультатНастройкиКаналовУведомлений(Результат, ДополнительныеПараметры = Неопределено)  Экспорт
	
	СтруктураНастроекКаналовУведомлений = Результат;
	Если СтруктураНастроекКаналовУведомлений = Неопределено тогда
		Возврат;
	КонецЕсли;
	
	ЕстьИзменения = Ложь;
	ОбновитьНастройкиКаналовУведомлений(СтруктураНастроекКаналовУведомлений, ЕстьИзменения);
	Если ЕстьИзменения Тогда 
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;	

КонецПроцедуры

&НаСервере
// Процедура - Обновить настройки каналов уведомлений
//
// Параметры:
//  СтруктураНастроекКаналовУведомлений	 - 	 - 
//  ЕстьИзменения						 - 	 - 
//
Процедура ОбновитьНастройкиКаналовУведомлений(СтруктураНастроекКаналовУведомлений, ЕстьИзменения)

	ОбновленнаяТаблицаНастроекКаналов = ПреобразоватьМассивСтруктурВТаблицуЗначений(СтруктураНастроекКаналовУведомлений.МоделируемыеНастройкиКаналовУведомлений);
	
	МВТ 	= Новый МенеджерВременныхТаблиц;
	Запрос 	= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("ОбновленнаяТаблицаНастроекКаналов"						, ОбновленнаяТаблицаНастроекКаналов.Скопировать(, "ИдентификаторДействия, СтруктурнаяЕдиница, ОтправкаPush, ОтправкаPushWallet, ОтправкаMessenger, ОтправкаSMS, АккаунтВнешнейСистемы, АккаунтСервисаРассылкиSMS, КаналСистемыСообщений"));
	Запрос.УстановитьПараметр("ТаблицаЗначенийКешированныхНастроекКаналовУведомлений"	, МоделируемыеНастройкиКаналовУведомлений.Выгрузить(, "ИдентификаторДействия, СтруктурнаяЕдиница, ОтправкаPush, ОтправкаPushWallet, ОтправкаMessenger, ОтправкаSMS, АккаунтВнешнейСистемы, АккаунтСервисаРассылкиSMS, КаналСистемыСообщений"));			
	Запрос.Текст = 
	"ВЫБРАТЬ ОбновленнаяТаблицаНастроекКаналов.*
	|ПОМЕСТИТЬ НовыеНастройкиКаналовУведомлений
	|ИЗ &ОбновленнаяТаблицаНастроекКаналов КАК ОбновленнаяТаблицаНастроекКаналов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ТаблицаЗначенийКешированныхНастроекКаналовУведомлений.*
	|ПОМЕСТИТЬ КешированныеНастройкиКаналовУведомлений
	|ИЗ &ТаблицаЗначенийКешированныхНастроекКаналовУведомлений КАК ТаблицаЗначенийКешированныхНастроекКаналовУведомлений";	
	Запрос.Выполнить();
	
	Запрос 			= Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст 	= 
	"ВЫБРАТЬ
	|	ТекущиеКешированныеНастройкиКаналовУведомлений.ИдентификаторДействия КАК ИдентификаторДействия
	|ИЗ
	|	НовыеНастройкиКаналовУведомлений КАК НовыеНастройкиКаналовУведомлений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КешированныеНастройкиКаналовУведомлений КАК ТекущиеКешированныеНастройкиКаналовУведомлений
	|		ПО НовыеНастройкиКаналовУведомлений.ИдентификаторДействия = ТекущиеКешированныеНастройкиКаналовУведомлений.ИдентификаторДействия
	|			И НовыеНастройкиКаналовУведомлений.СтруктурнаяЕдиница = ТекущиеКешированныеНастройкиКаналовУведомлений.СтруктурнаяЕдиница
	|			И (НовыеНастройкиКаналовУведомлений.ОтправкаPush <> ТекущиеКешированныеНастройкиКаналовУведомлений.ОтправкаPush
	|				ИЛИ НовыеНастройкиКаналовУведомлений.ОтправкаPushWallet <> ТекущиеКешированныеНастройкиКаналовУведомлений.ОтправкаPushWallet
	|				ИЛИ НовыеНастройкиКаналовУведомлений.ОтправкаMessenger <> ТекущиеКешированныеНастройкиКаналовУведомлений.ОтправкаMessenger
	|				ИЛИ НовыеНастройкиКаналовУведомлений.ОтправкаSMS <> ТекущиеКешированныеНастройкиКаналовУведомлений.ОтправкаSMS
	|				ИЛИ НовыеНастройкиКаналовУведомлений.АккаунтВнешнейСистемы <> ТекущиеКешированныеНастройкиКаналовУведомлений.АккаунтВнешнейСистемы
	|				ИЛИ НовыеНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS <> ТекущиеКешированныеНастройкиКаналовУведомлений.АккаунтСервисаРассылкиSMS
	|				ИЛИ (ВЫРАЗИТЬ(НовыеНастройкиКаналовУведомлений.КаналСистемыСообщений КАК СТРОКА(32))) <> (ВЫРАЗИТЬ(ТекущиеКешированныеНастройкиКаналовУведомлений.КаналСистемыСообщений КАК СТРОКА(32))))";		
	
	ЕстьИзменения = НЕ Запрос.Выполнить().Пустой();
	
	Запрос.МенеджерВременныхТаблиц.Закрыть();
	
	МоделируемыеНастройкиКаналовУведомлений.Загрузить(ОбновленнаяТаблицаНастроекКаналов);
	
	Если ЕстьИзменения Тогда 
		МассивСтрок = Объект.Действия.НайтиСтроки(Новый Структура("ИдентификаторДействия", СтруктураНастроекКаналовУведомлений.ИдентификаторДействия));
		Если НЕ МассивСтрок.Количество() = 0 Тогда 
			УстановитьСвойстваЭлементамАккаунтаСообщения(, Объект.Действия.Индекс(МассивСтрок[0]));
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

