
#Область СлужебныеПроцедурыИФункции

// Получить текущие напоминания текущего пользователя.Если передать ссылку на клиента
// будет произведено получение задач и по посещениям
Процедура ПроверитьАктивныеОповещенияКлиента() Экспорт
	
	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		Возврат;
	КонецЕсли;
	
	// Получить задачи по времени выполнения.
	ОповещенияКлиента = ПользователиСтоматология.ПолучитьАктивныеОповещенияКлиента();
	
	Для Каждого СтрокаТЗ Из ОповещенияКлиента Цикл
		
		ЗавершитьОповещение = Истина;
		
		Если СтрокаТЗ.Ключ = "ПоказатьОповещениеПользователяСчетНеОплачен" Тогда
			
			// добавить оповещение счет не оплачен
			ПредставлениеСчетНаОплату = СтрокаТЗ.Параметр_1;
			ПоказатьОповещениеПользователя(
			"Неоплаченный счет",,
			ПредставлениеСчетНаОплату,
			БиблиотекаКартинок.Информация32,
			СтатусОповещенияПользователя.Важное,
			ПредставлениеСчетНаОплату);
			
		ИначеЕсли СтрокаТЗ.Ключ = "НовоеСообщениеМессенджер" Тогда 
			
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ИдСообщения"	, СтрокаТЗ.Параметр_1);
			СтруктураПараметров.Вставить("ИдКлиента"	, СтрокаТЗ.Параметр_4);
			Оповестить(СтрокаТЗ.Ключ, СтруктураПараметров);
			
			ПользователиСтоматология.ЗавершитьОповещениеКлиента(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
			
		ИначеЕсли СтрокаТЗ.Ключ = "НовыйКонтактМессенджер" Тогда 
			
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ИдСообщения"	, СтрокаТЗ.Параметр_1);
			СтруктураПараметров.Вставить("ИдКлиента"	, СтрокаТЗ.Параметр_4);
			Оповестить(СтрокаТЗ.Ключ, СтруктураПараметров);
			
			ПользователиСтоматология.ЗавершитьОповещениеКлиента(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ОбновлениеПараметровФильтрацииМессенджер" Тогда
			
			ПараметрыОповещения = Новый Структура;
			ПараметрыОповещения.Вставить("ИдКонтакта"			, СтрокаТЗ.Параметр_1);
			ПараметрыОповещения.Вставить("Оператор"				, СтрокаТЗ.Параметр_2);
			ПараметрыОповещения.Вставить("ОтложенДо"			, СтрокаТЗ.Параметр_3);
			ПараметрыОповещения.Вставить("Окончание"			, СтрокаТЗ.Параметр_4);
			ПараметрыОповещения.Вставить("СообщениеОтКлиента"	, СтрокаТЗ.Параметр_5);
			
			Оповестить(СтрокаТЗ.Ключ, ПараметрыОповещения);
			
			ПользователиСтоматология.ЗавершитьОповещениеКлиента(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ДобавленаОнлайнЗапись" Тогда
			
			// добавить оповещение добавлена онлайн запись
			Событие = СтрокаТЗ.Параметр_1;	
			ПараметрыОповещения = Новый Структура("Событие, ОбъектОповещения, СтруктурнаяЕдиница, Ключ", Событие, СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
			ОписаниеОповещения = Новый ОписаниеОповещения("ДобавленаОнлайнЗаписьЗавершение", ОбщегоНазначенияКлиент, ПараметрыОповещения);
			ПоказатьОповещениеПользователя(
			"Добавлена онлайн-запись",
			ОписаниеОповещения,
			Строка(Событие),
			БиблиотекаКартинок.Информация32,
			СтатусОповещенияПользователя.Важное,
			Строка(Событие));       
			
		ИначеЕсли СтрокаТЗ.Ключ = "IPТелефония_ВходящийЗвонок" Тогда // И СтрокаТЗ.ОповещатьДо >= ТекущаяДатаСервера() Тогда
			
			ЗавершитьОповещение 		= Ложь;
			ПараметрыПереадресации 		= Новый Структура("IPТелефонияПодключаемоеОборудование, IDЗвонка, СНомерТелефона, НаНомерТелефона, КонтрагентНаНомере", 
			СтрокаТЗ.Параметр_1, СтрокаТЗ.Параметр_2, СтрокаТЗ.Параметр_3, СтрокаТЗ.Параметр_4, СтрокаТЗ.Параметр_5);
			КлючУникальностиОповещения = "IPТелефония_Звонок_" + СтрокаТЗ.Параметр_3;
			
			Если СтрНайти(СтрокаТЗ.Сообщение, "Нажмите для переадресации") > 0 Тогда
				ПараметрыПереадресации 		= Новый Структура("IPТелефонияПодключаемоеОборудование, IDЗвонка, IDПлеча, СНомерТелефона, НаНомерТелефона, ПереадресацияЗвонка", 
				СтрокаТЗ.Параметр_1, СтрокаТЗ.Параметр_2, СтрокаТЗ.Параметр_3, СтрокаТЗ.Параметр_4, СтрокаТЗ.Параметр_5, Истина);
				КлючУникальностиОповещения 	= "IPТелефония_Звонок_" + СтрокаТЗ.Параметр_4;
				
				ОписаниеОповещения = Новый ОписаниеОповещения("ПереадресацияЗвонкаОбработкаОповещения", IPТелефонияКлиент, ПараметрыПереадресации);
			ИначеЕсли СтрНайти(СтрокаТЗ.Сообщение, "Открыть карточку клиента") > 0 Тогда
				СтрокаТЗ.Сообщение = СтрЗаменить(СтрокаТЗ.Сообщение, "Открыть карточку клиента", ""); 
				ОписаниеОповещения = ПолучитьНавигационнуюСсылку(СтрокаТЗ.Параметр_5);
			ИначеЕсли СтрНайти(СтрокаТЗ.Сообщение, "Открыть заявку клиента") > 0 Тогда
				ОписаниеОповещения = ПолучитьНавигационнуюСсылку(СтрокаТЗ.Параметр_5);				
			ИначеЕсли СтрНайти(СтрокаТЗ.Сообщение, "Создать нового клиента") > 0 Тогда
				ПараметрыОповещения = Новый Структура("НомерТелефона", СтрокаТЗ.Параметр_3);
				ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьНовогоКлиентаОповещение", IPТелефонияКлиент, ПараметрыОповещения);
			ИначеЕсли СтрНайти(СтрокаТЗ.Сообщение, "Создать потенциального клиента") > 0 Тогда
				ПараметрыОповещения = Новый Структура("НомерТелефона", СтрокаТЗ.Параметр_3);
				ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьПотенциальногоКлиентаОповещение", IPТелефонияКлиент, ПараметрыОповещения);
			ИначеЕсли СтрНайти(СтрокаТЗ.Сообщение, "Открыть форму звонка") > 0 Тогда
				
				Если ЗначениеЗаполнено(СтрокаТЗ.Параметр_1) И ЗначениеЗаполнено(СтрокаТЗ.Параметр_2) Тогда
					ПараметрыОповещения = Новый Структура("ПОIPТелефонии, IDЗвонка, IDПлеча, СНомерТелефона, НаНомерТелефона", СтрокаТЗ.Параметр_1, СтрокаТЗ.Параметр_2, СтрокаТЗ.Параметр_3, СтрокаТЗ.Параметр_4, СтрокаТЗ.Параметр_5);
					ОписаниеОповещения  = Новый ОписаниеОповещения("ОткрытьФормуЗвонкаОповещение", IPТелефонияКлиент, ПараметрыОповещения);
				КонецЕсли;
				
			Иначе	  
				ОписаниеОповещения = Неопределено; 
			КонецЕсли;
			
			ПоказатьОповещениеПользователя(СтрокаТЗ.ЗаголовокОкна, ОписаниеОповещения, СтрокаТЗ.Сообщение, БиблиотекаКартинок.Телефон32, , КлючУникальностиОповещения);
			ПользователиСтоматология.ПеревестиОповещениеКлиентаНа10Сек(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
			
		ИначеЕсли СтрокаТЗ.Ключ = "IPТелефония_ОткрытьФормуВзаимодействияСКлиентом" Тогда
			
			Если ЗначениеЗаполнено(СтрокаТЗ.Параметр_1) И ЗначениеЗаполнено(СтрокаТЗ.Параметр_2) Тогда // И ЗначениеЗаполнено(СтрокаТЗ.Параметр_3) Тогда
				ОткрытьФорму("РегистрСведений.ИсторияВызовов.Форма.ФормаЗвонокКлиента", Новый Структура("ПОIPТелефонии, IDЗвонка, IDПлеча, СНомерТелефона, НаНомерТелефона", СтрокаТЗ.Параметр_1, СтрокаТЗ.Параметр_2, СтрокаТЗ.Параметр_3, СтрокаТЗ.Параметр_4, СтрокаТЗ.Параметр_5), , СтрокаТЗ.Параметр_2);
			КонецЕсли;	
			
		ИначеЕсли СтрокаТЗ.Ключ = "IPТелефония_ПокзатьУведомлениеОПропущенном_" + СтрокаТЗ.Параметр_4 Тогда
			
			ЗавершитьОповещение = Ложь;
			
			ПараметрыСпискаНеОбработанных 	= Новый Структура("ТелефонныйАппарат, ВнутреннийНомер, ВнутреннийНомерРодителя, КлючОповещения", СтрокаТЗ.Параметр_1, СтрокаТЗ.Параметр_2, СтрокаТЗ.Параметр_3, СтрокаТЗ.Параметр_5);			
			ОписаниеОповещения 				= Новый ОписаниеОповещения("ОткрытьСписокПропущенныхЗвонков", IPТелефонияКлиент, ПараметрыСпискаНеОбработанных);
			ПоказатьОповещениеПользователя(СтрокаТЗ.ЗаголовокОкна, ОписаниеОповещения, СтрокаТЗ.Сообщение, БиблиотекаКартинок.ТелефонныйЗвонокПропущенныйБольшой, СтатусОповещенияПользователя.Важное, СтрокаТЗ.Параметр_5);
			Оповестить("ОБНОВИТЬ_КОЛИЧЕСТВО_НЕ_ОБРАБОТАННЫХ", СтрокаТЗ.Параметр_5);
			
			// Завершаем оповещение
			ПользователиСтоматология.ЗавершитьОповещениеКлиента(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, "IPТелефония_ПокзатьУведомлениеОПропущенном_" + СтрокаТЗ.Параметр_4);
			
		ИначеЕсли СтрокаТЗ.Ключ = "IPТелефония_ОткрытьКарточкуКлиента" Тогда
			ПоказатьЗначение( ,СтрокаТЗ.Параметр_1);
		ИначеЕсли СтрокаТЗ.Ключ = "IPТелефония_СоздатьПотенциальногоКлиента" Тогда
			Представление_Телефон = СтрокаТЗ.Параметр_1;
			XML_Телефон			= УправлениеКонтактнойИнформациейСлужебныйВызовСервераСтоматология.КонтактнаяИнформацияПоПредставлению(Представление_Телефон, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента"));
			СтруктураЗаполнения = Новый Структура();
			СтруктураЗаполнения.Вставить("ТелефонКлиента"			, Представление_Телефон); 
			Если СтрокаТЗ.Параметр_2 <> Неопределено Тогда
				СтруктураЗаполнения.Вставить("ИсточникИнформации"	, СтрокаТЗ.Параметр_2);
			КонецЕсли;
			
			ФормаЭлементаКонтакт = ПолучитьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты", , , "IPТелефония_СоздатьПотенциальногоКлиента_" + СтрокаТЗ.Параметр_1);
			МассивСтрокТелефона = ФормаЭлементаКонтакт.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон")));
			НоваяСтрока		= ?(МассивСтрокТелефона.Количество() > 0, МассивСтрокТелефона[0], ФормаЭлементаКонтакт.КонтактнаяИнформация.Добавить());
			НоваяСтрока.Тип	= ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон");
			НоваяСтрока.Вид = ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента");
			НоваяСтрока.Представление = СтрокаТЗ.Параметр_1;
			НоваяСтрока.ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебныйВызовСервера.КонтактнаяИнформацияПоПредставлению(СтрокаТЗ.Параметр_1, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонКлиента"));
			ФормаЭлементаКонтакт.Модифицированность = Истина;
			
			Если СтрокаТЗ.Параметр_2 <> Неопределено Тогда
				ФормаЭлементаКонтакт.Объект.ИсточникИнформации = СтрокаТЗ.Параметр_2;
			КонецЕсли;
			
			ФормаЭлементаКонтакт.Открыть();
			
		// Иначе
		//	
		//	Оповестить(СтрокаТЗ.Ключ);
		//	ПользователиСтоматология.ЗавершитьОповещениеКлиента(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
		
		ИначеЕсли СтрокаТЗ.Ключ = "ПоказатьОповещениеУслугиНаСогласование" Тогда
			
			ПоказатьОповещениеПользователя(
			"Новая услуга на согласование",,,
			БиблиотекаКартинок.Информация32,
			СтатусОповещенияПользователя.Важное,
			Строка(СтрокаТЗ.Ключ)); 
			
			Оповестить("ПоказатьОповещениеУслугиНаСогласование");
			
		ИначеЕсли СтрНачинаетсяС(СтрокаТЗ.Ключ, "ОбновитьСогласованияСтраховыхУслуг") Тогда
					
			УИДСтрокиУслуги = ?(ЗначениеЗаполнено(СтрокаТЗ.Параметр_1), Новый УникальныйИдентификатор(СтрокаТЗ.Параметр_1), Неопределено);
			СтруктураПараметров = Новый Структура();
			СтруктураПараметров.Вставить("ИдентификаторСтроки", УИДСтрокиУслуги);
			СтруктураПараметров.Вставить("ИзмененныйПрием", СтрокаТЗ.Параметр_2);			
			
			Оповестить("ОбновитьСогласованияСтраховыхУслуг", СтруктураПараметров);
		
		ИначеЕсли СтрокаТЗ.Ключ = "ОбновлениеРабочегоСтола" Тогда
			
			Оповестить(СтрокаТЗ.Ключ);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ОбновленСтатусЗаявки" Тогда
			
			ПараметрыОповещения = Новый Структура;
			ПараметрыОповещения.Вставить("Заявка"				, СтрокаТЗ.Параметр_1);
			ПараметрыОповещения.Вставить("Сотрудник"			, СтрокаТЗ.Параметр_2);
			ПараметрыОповещения.Вставить("СтруктурнаяЕдиница"	, СтрокаТЗ.Параметр_3);
			
			Оповестить(СтрокаТЗ.Ключ, ПараметрыОповещения);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ОповещениеОНовыхЗаявках" Тогда
			
			ПараметрыОповещения = Новый Структура;
			ПараметрыОповещения.Вставить("Заявка"				, СтрокаТЗ.Параметр_1);
			ПараметрыОповещения.Вставить("Сотрудник"			, СтрокаТЗ.Параметр_2);
			ПараметрыОповещения.Вставить("СтруктурнаяЕдиница"	, СтрокаТЗ.Параметр_3);
			
			Оповестить(СтрокаТЗ.Ключ, ПараметрыОповещения);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ИзмененЭтапСделки" Или СтрокаТЗ.Ключ = "ДобавленаСделка" Тогда
			
			ПараметрыОповещения = Новый Структура;
			ПараметрыОповещения.Вставить("Сделка"	, СтрокаТЗ.Параметр_1);
			ПараметрыОповещения.Вставить("ВидСделки", СтрокаТЗ.Параметр_2);
			
			Оповестить(СтрокаТЗ.Ключ, ПараметрыОповещения);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ЗакрытьФормуЗвонкаПациенту" Тогда
			
			ПараметрыОповещения = Новый Структура;
			ПараметрыОповещения.Вставить("IDЗвонка"				, СтрокаТЗ.Параметр_1);
			ПараметрыОповещения.Вставить("Телефон"				, СтрокаТЗ.Параметр_2);
			
			Оповестить(СтрокаТЗ.Ключ, ПараметрыОповещения);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ОбновитьЗадачуКанбан" Тогда
			
			ПараметрыОповещения = Новый Структура;
			ПараметрыОповещения.Вставить("Задача"			, СтрокаТЗ.Параметр_1);
			ПараметрыОповещения.Вставить("Сделка"			, СтрокаТЗ.Параметр_2);
			ПараметрыОповещения.Вставить("ВидСделки"		, СтрокаТЗ.Параметр_3);
			ПараметрыОповещения.Вставить("УдалениеЗадачи"	, СтрокаТЗ.Параметр_4);
			
			Оповестить(СтрокаТЗ.Ключ, ПараметрыОповещения);
			
		ИначеЕсли СтрокаТЗ.Ключ = "НовоеСообщениеКонтурСтрохование" Тогда
			
			ПараметрыОповещения = Новый Структура("НомерСписка, ОбъектОповещения, СтруктурнаяЕдиница, Ключ, mediId, eventId, eventPointer, eventDateTime", 
												СтрокаТЗ.Параметр_1, 
												СтрокаТЗ.ОбъектОповещения, 
												СтрокаТЗ.СтруктурнаяЕдиница, 
												СтрокаТЗ.Ключ, 
												СтрокаТЗ.Параметр_2, 
												СтрокаТЗ.Параметр_3, 
												СтрокаТЗ.Параметр_4, 
												СтрокаТЗ.Параметр_5);
	
			ОписаниеОповещения = Новый ОписаниеОповещения("НовоеСообщениеКонтурСтрохование", ОбщегоНазначенияКлиент, ПараметрыОповещения);
			Если СтрокаТЗ.Параметр_6 = 1 Тогда
				ЗаголовокОповещения = "Поступил новый список прикрепления.";
			ИначеЕсли СтрокаТЗ.Параметр_6 = 2 Тогда
				ЗаголовокОповещения = "Поступил новый список открепления.";
			ИначеЕсли СтрокаТЗ.Параметр_6 = 3 Тогда
				ЗаголовокОповещения = "Поступил новый список изменения персональных данных.";
			КонецЕсли;
			
			ПоказатьОповещениеПользователя(ЗаголовокОповещения, 	
			ОписаниеОповещения, 
			СтрокаТЗ.Параметр_1,  
			БиблиотекаКартинок.Информация32,
			СтатусОповещенияПользователя.Важное);
			
		ИначеЕсли СтрокаТЗ.Ключ = "ПредварительнаяЗаписьОтменена" Тогда
			
			ПараметрыОповещения = Новый Структура("Ключ, СтруктурнаяЕдиница, ОбъектОповещения, Сотрудник, ДатаСобытия",
												СтрокаТЗ.Ключ,
												СтрокаТЗ.СтруктурнаяЕдиница,
												СтрокаТЗ.ОбъектОповещения,
												СтрокаТЗ.Параметр_1,
												СтрокаТЗ.Параметр_2);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ПредварительнаяЗаписьОтмененаЗавершение", ОбщегоНазначенияКлиент, ПараметрыОповещения);
			
			ПоказатьОповещениеПользователя(СтрокаТЗ.ЗаголовокОкна, 	
			ОписаниеОповещения, 
			СтрокаТЗ.Сообщение,  
			БиблиотекаКартинок.Информация32,
			СтатусОповещенияПользователя.Важное);
			
		Иначе
			ЗавершитьОповещение = Ложь;			
		КонецЕсли; 
		
		Если ЗавершитьОповещение Тогда
			ПользователиСтоматология.ЗавершитьОповещениеКлиента(СтрокаТЗ.ОбъектОповещения, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.Ключ);
		КонецЕсли;
	
	КонецЦикла; 

	// ПользователиСтоматология.ОчиститьУстаревшиеОповещенияКлиента();
	
КонецПроцедуры

