&НаКлиенте
// Функция, возвращает форму, если она открыта.
//
// Параметры:
//  ИмяФормы - Строка - Имя формы, которую нужно получить - совпадает со 
//  Значение реквизита формы "ИмяФормы". Возвращается первая найденная форма.
// 
// Возвращаемое значение:
//  ФормаКлиентскогоПриложения, Неопределено - Объект найденной открытой 
//  Формы или значение "Неопределено", если форма не найдена.
//
Функция ПолучитьОткрытуюФорму(ИмяФормы) Экспорт
	
	ОкнаКлиентскогоПриложения = ПолучитьОкна();
	
	Для Каждого ОкноКлиентскогоПриложения Из ОкнаКлиентскогоПриложения Цикл
		Для Каждого Форма Из ОкноКлиентскогоПриложения.Содержимое Цикл
			Если Форма.ИмяФормы = ИмяФормы Тогда
				Возврат Форма;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Не удалось найти открытую форму.
	Возврат Неопределено;
	
КонецФункции

// Функция, возвращает строку без недопустимых символов справа.
//
Функция УдалитьНедопустимыеСимволыСправа(Знач Строка) Экспорт
	
	Если Не ЗначениеЗаполнено(Строка) Или ТипЗнч(Строка) = Тип("Строка") Тогда
		Возврат Строка;
	КонецЕсли;
	
	Пока Истина Цикл
		
		Если Не ЗначениеЗаполнено(Строка) Тогда
			Возврат НСтр("ru = '(недопустимые символы)'; en = '(forbidden symbols)'");
		КонецЕсли;
		
		ДлинаСтроки = СтрДлина(Строка);
		
		КодСимвола = КодСимвола(Строка, ДлинаСтроки);
		
		Если Не (КодСимвола = 0 Или КодСимвола = 9 Или КодСимвола = 10 Или КодСимвола = 13
			Или (КодСимвола >= 32 И КодСимвола <= 55295)
			Или (КодСимвола >= 57344 И КодСимвола <= 65533)) Тогда
			
			Строка = Лев(Строка, ДлинаСтроки - 1);
		Иначе
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Строка;
	
КонецФункции

// Функция, преобразует кодовые точки Unicode в строку.
//
// Параметры:
//	КодыСимволовUnicode - Строка - Один или несколько шестнадцатеричных кодов символов Unicode (без "U+"), соединенных символом "-".
// Разбивает исходную строку на подстроки. Разделителем является символ "-".
// В итоговой строке разделители преобразуется в объединитель нулевой ширины (ZWJ - 8205).
//
Функция КодовыеТочкиUnicodeВСтроку(КодыСимволовUnicode) Экспорт
	
	ФрагментыСтроки			 = Новый Массив;
	НомераСимволовUnicode	 = СтрРазделить(КодыСимволовUnicode, "-", Ложь);
	
	Для Каждого НомерСимволаUnicode Из НомераСимволовUnicode Цикл
		
		КодСимвола = КонвертироватьHexВDec(НомерСимволаUnicode);
		ФрагментыСтроки.Добавить(?(
			КодСимвола > 65535,
			Символ(ПобитовыйСдвигВправо(КодСимвола, 10) + 55232) + Символ(ПобитовоеИ(КодСимвола, 1023) + 56320),
			Символ(КодСимвола)
		));
		
	КонецЦикла;
	
	Возврат СтрСоединить(ФрагментыСтроки, Символ(8205));
	
КонецФункции

