&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура СписокДокументовФлагПриИзменении(Элемент)
	
	СтрокаТЧ = Элементы.СписокДокументов.ТекущиеДанные;
	Если СтрокаТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	НайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("Флаг", Истина));
	Если НайденныеСтроки.Количество() > 0 Тогда
		мНайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("Флаг, Статус", Истина, ?(СтрокаТЧ.Флаг, СтрокаТЧ.Статус, НайденныеСтроки[0].Статус)));
	КонецЕсли;
	
	Если Не Элементы.СписокДокументовЗаказано.Доступность Тогда
		Элементы.СписокДокументовЗаказано.Доступность = Истина;
	КонецЕсли;
	Если Не Элементы.СписокДокументовВРаботе.Доступность Тогда
		Элементы.СписокДокументовВРаботе.Доступность = Истина;
	КонецЕсли;
	Если Не Элементы.СписокДокументовВыполнено.Доступность Тогда
		Элементы.СписокДокументовВыполнено.Доступность = Истина;
	КонецЕсли; 
	
	Если  НайденныеСтроки.Количество() > 0 и мНайденныеСтроки.Количество() = НайденныеСтроки.Количество() Тогда
		Элементы["СписокДокументов"+СтрЗаменить(?(СтрокаТЧ.Флаг, СтрокаТЧ.Статус, НайденныеСтроки[0].Статус), " ","")].Доступность = Ложь;
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды
//
Процедура УстановкаПериода(Команда)
		
	Диалог = Новый ДиалогРедактированияСтандартногоПериода(); 
	Диалог.Период = Период; 
	Диалог.Показать(Новый ОписаниеОповещения("УстановкаПериодаЗавершение", ЭтотОбъект, Новый Структура("Диалог", Диалог)));
	
КонецПроцедуры

&НаКлиенте
// Процедура - Установка периода завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура УстановкаПериодаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда 
		Период = Результат; 
		ЗаполнитьСписокДокументов();
	КонецЕсли;

КонецПроцедуры

