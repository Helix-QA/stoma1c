

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Контрагент"						, Контрагент);
	Параметры.Свойство("Сделка"							, Сделка);
	Параметры.Свойство("Врач"							, Врач);
	Параметры.Свойство("ВыбратьВидГенерируемойСделки"	, ВыбратьВидГенерируемойСделки);
	Параметры.Свойство("ВыбратьЭтапГенерируемойСделки"	, ВыбратьЭтапГенерируемойСделки);	
	Параметры.Свойство("ВыбранныйВидСделки"				, ВыбранныйВидСделки);
	Параметры.Свойство("ВыбранныйЭтап"					, ВыбранныйЭтап);
	
	ВыбратьЭтап = Ложь;
	Параметры.Свойство("ВыбратьЭтап", ВыбратьЭтап);
	ВыбратьЭтап = ?(ВыбратьЭтап = Неопределено, Ложь, ВыбратьЭтап);
	
	ИзменитьЭтапОтказ = Ложь;
	Параметры.Свойство("ИзменитьЭтапОтказ", ИзменитьЭтапОтказ);
	ИзменитьЭтапОтказ = ?(ИзменитьЭтапОтказ = Неопределено, Ложь, ИзменитьЭтапОтказ);
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Сделка) Тогда 
		ЭтотОбъект.СуммаСделки = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭтотОбъект.Сделка, "СуммаСделки");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбранныйВидСделки) Тогда 
		ЭтоПервичныйПовторныйПациент = ВыбранныйВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");	
	Иначе 
		ЭтоПервичныйПовторныйПациент = Ложь;	
	КонецЕсли;
	
	Если ВыбратьВидГенерируемойСделки ИЛИ ВыбратьЭтапГенерируемойСделки Тогда 
		ИнициализироватьТаблицуДоступныхВидовСделок();
		ОбновитьЭлементыВыбораГенерируемойСделки();
	Иначе
		Если ЗначениеЗаполнено(ЭтотОбъект.Сделка) Тогда 
			СтруктураОсновыныхРеквизитов = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Сделка, "ВидСделки, ЭтапСделки, РезультатСделки, ПричинаОтказа");
			ВидСделки 		= СтруктураОсновыныхРеквизитов.ВидСделки;
			РезультатСделки = СтруктураОсновыныхРеквизитов.РезультатСделки;
			ЭтапСделки 		= СтруктураОсновыныхРеквизитов.ЭтапСделки;
			ПричинаОтказа 	= СтруктураОсновыныхРеквизитов.ПричинаОтказа;
		КонецЕсли;
		ЭтоПервичныйПовторныйПациент = ВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");	
		УправлениеИнтерфейсамиСервер.ЗаполнитьТаблицуПричинОтказов(ЭтаФорма, ВидСделки, ПричиныПредопределены);
		ОбновитьЭтапыСделки();
	КонецЕсли;	
	
	ЭтаФорма.Заголовок = Сделка.Наименование;
	
	УстановитьВидимостьЭлементов(ВыбратьЭтап, ИзменитьЭтапОтказ)
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура, обработчик события "Выбор".
//
Процедура СписокВидовСделокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекстОшибки = "";
	ЭлементСписка = СписокВидовСделок.Получить(ВыбраннаяСтрока);
	Если ЗначениеЗаполнено(ЭлементСписка.Значение) Тогда 
		УправлениеИнтерфейсамиСервер.ИзменитьВидСделки(ЭтотОбъект.Сделка, ЭлементСписка.Значение, ТекстОшибки);
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	Иначе
		Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
		Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
		Если ЭтаФорма.Открыта() Тогда
			ЭтаФорма.Закрыть();
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура СуммаСделкиПриИзменении(Элемент)
	
	УправлениеИнтерфейсамиСервер.ИзменитьСуммуСделки(ЭтотОбъект.Сделка, ЭтотОбъект.СуммаСделки);
	Если ЭтаФорма.Открыта() Тогда
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, ОбработчикТаблицаОтказовВыбор.
//
Процедура ОбработчикТаблицаОтказовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка) Экспорт
	
	ПричинаОтказа = Элемент.ТекущиеДанные.Ссылка;
	ИмяЭлемента   = Элемент.Имя;
	
	ОбновитьПричинуОтказаВыборНаСервере(ПричинаОтказа, ИмяЭлемента);	
	Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
	Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
	Если ЭтаФорма.Открыта() Тогда
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Открыть сделку.
//
Процедура ОткрытьСделку(Команда)
	
	ПоказатьЗначение(,ЭтотОбъект.Сделка);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Сменить сделку.
//
Процедура СменитьСделку(Команда)
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Сделка) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭтотОбъект.Сделка, "ВидСделки"), "Предопределенный") Тогда 
		Возврат;
	КонецЕсли;
	
	СменитьСделкуНаСервере();
	
КонецПроцедуры

&НаКлиенте
// Процедура, ОбработчикНажатияИзменитьЭтап.
//
Процедура ОбработчикНажатияИзменитьЭтап(Команда) Экспорт
	
	ИндексВиджета = 0;
	
	Если СтрНайти(Команда.Имя, "Этап_Генерируемый_") <> 0 Тогда 
		Если СтрНачинаетсяС(Команда.Имя, "Этап_Генерируемый_") Тогда  
			ИндексСтроки			= Число(Сред(Команда.Имя, СтрДлина("Этап_Генерируемый_") + 1));
		ИначеЕсли СтрНачинаетсяС(Команда.Имя, "КомандаЭтап_Генерируемый_") Тогда  
			ИндексСтроки			= Число(Сред(Команда.Имя, СтрДлина("КомандаЭтап_Генерируемый_") + 1));
		Иначе 
			Возврат;
		КонецЕсли;	
		Для Каждого СтрокаВидСделки Из ТаблицаДоступныхВидовСделок Цикл 
			Если СтрокаВидСделки.ВидСделки = ВыбранныйВидСделки Тогда
				Для Каждого СтрокаЭтап Из СтрокаВидСделки.ТаблицаЭтапов Цикл 
					СтрокаЭтап.Выбран = СтрокаВидСделки.ТаблицаЭтапов.Индекс(СтрокаЭтап) = ИндексСтроки;
					Если СтрокаЭтап.Выбран Тогда 
						ВыбранныйЭтап = СтрокаЭтап.Этап;
					КонецЕсли;	
				КонецЦикла;	
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ЭтаФорма.Открыта() Тогда
			ЭтаФорма.Закрыть(ВыбранныйЭтап);
		КонецЕсли;		
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаИзменитьЭтапОтказ") > 0 Тогда
		Если ПричиныПредопределены Тогда 			
			ПричинаОтказа = ПолучитьВыбраннуюПричинуОтказа(Команда.Имя);
			ОбновитьПричинуОтказаВыборНаСервере(ПричинаОтказа, Команда.Имя);	
			Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
			Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
			Если ЭтаФорма.Открыта() Тогда
				ЭтаФорма.Закрыть();
			КонецЕсли;
		Иначе 	
			Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость   	   	= Ложь;
			Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость 	= Истина;
			Элементы["ГруппаПрием_" + ИндексВиджета].Видимость    		= Ложь;
			
			Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Видимость = Ложь;
			
		КонецЕсли;
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаИзменитьЭтапУспех") > 0 Тогда
		
		Элементы["ГруппаЭтапы_" + ИндексВиджета].Видимость   	   		= Ложь;
		Элементы["ГруппаПричиныОтказа_" + ИндексВиджета].Видимость 		= Ложь;
		Элементы["ГруппаПрием_" + ИндексВиджета].Видимость    			= Истина;
		
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Видимость = Ложь;
			
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаСоздатьПродажу") > 0 Тогда
		
		ОткрытьФормуПродажи(ИндексВиджета);
		
	ИначеЕсли СтрНайти(Команда.Имя, "КомандаВыбратьПродажу") > 0 Тогда
		
		МассивСделок = Новый Массив();
		МассивСделок.Добавить(ЭтотОбъект.Сделка);
		
		НовоеОповещение = Новый ОписаниеОповещения("ВыбратьРеализациюЗавершение", ЭтотОбъект, ЭтотОбъект.Сделка);
		
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("Контрагент"			, ЭтотОбъект.Контрагент);
		ПараметрыФормы.Вставить("ВключатьПакетИЧленство", Истина);
		ПараметрыФормы.Вставить("РеализацияБезСделки"	, Истина);
		ПараметрыФормы.Вставить("МассивСделок"			, МассивСделок);
		
		ОткрытьФорму("Документ.Прием.ФормаВыбора",ПараметрыФормы,,,,,НовоеОповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		ОбновитьСделку(Команда.Имя);
		Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
		Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
		Если ЭтаФорма.Открыта() Тогда
			ЭтаФорма.Закрыть();
		КонецЕсли;
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, ОбработчикНажатияИзменитьЭтап.
//
Процедура ОбработчикНажатияИзменитьВидСделки(Команда) Экспорт
	
	ИндексВиджета = 0;
	
	Если СтрНачинаетсяС(Команда.Имя, "КомандаВидСделки_") Тогда  
		ИндексСтроки			= Число(Сред(Команда.Имя, СтрДлина("КомандаВидСделки_") + 1));
		Если НЕ ТаблицаДоступныхВидовСделок[ИндексСтроки].ВидСделки = ВыбранныйВидСделки Тогда 
			Для Каждого СтрокаВидСделки Из ТаблицаДоступныхВидовСделок Цикл
				Если СтрокаВидСделки.Выбран Тогда 
					Для Каждого СтрокаЭтап Из СтрокаВидСделки.ТаблицаЭтапов Цикл 
						СтрокаЭтап.Выбран = Ложь;
					КонецЦикла;	
				КонецЕсли;	
				СтрокаВидСделки.Выбран 	= ТаблицаДоступныхВидовСделок.Индекс(СтрокаВидСделки) = ИндексСтроки;
				Если СтрокаВидСделки.Выбран Тогда 
					ВыбранныйВидСделки = СтрокаВидСделки.ВидСделки;					
					СтрокаВидСделки.ТаблицаЭтапов[0].Выбран = Истина;
				КонецЕсли;	
			КонецЦикла; 
			Если ЗначениеЗаполнено(ВыбранныйВидСделки) Тогда 
				ЭтоПервичныйПовторныйПациент = ВыбранныйВидСделки = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");	
			Иначе 
				ЭтоПервичныйПовторныйПациент = Ложь;	
			КонецЕсли;			
		КонецЕсли;
		Если ЭтаФорма.Открыта() Тогда
			ЭтаФорма.Закрыть(ВыбранныйВидСделки);
		КонецЕсли;		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура - Инициализировать таблицу доступных видов сделок
//
Процедура ИнициализироватьТаблицуДоступныхВидовСделок()
	
	ТаблицаДоступныхВидовСделокДляГенерации = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(, Контрагент, , Врач, Истина);
	ТаблицаДоступныхВидовСделок.Очистить();
	Для Каждого СтрокаДоступныеВидыСделок Из ТаблицаДоступныхВидовСделокДляГенерации Цикл
		НоваяСтрока = ТаблицаДоступныхВидовСделок.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДоступныеВидыСделок, , "ТаблицаЭтапов, ТаблицаПричинОтказов");
		НоваяСтрока.Выбран = НоваяСтрока.ВидСделки = ВыбранныйВидСделки;
		НоваяСтрока.ТаблицаЭтапов.Загрузить(СтрокаДоступныеВидыСделок.ТаблицаЭтапов);
		НоваяСтрока.ТаблицаПричинОтказов.Загрузить(СтрокаДоступныеВидыСделок.ТаблицаПричинОтказов);
		Если НоваяСтрока.Выбран Тогда 
			Если ЗначениеЗаполнено(ВыбранныйЭтап) Тогда 
				МассивСтрок = НоваяСтрока.ТаблицаЭтапов.НайтиСтроки(Новый Структура("Этап", ВыбранныйЭтап));
				Если МассивСтрок.Количество() > 0 Тогда 
					МассивСтрок[0].Выбран = Истина;
				КонецЕсли;
			Иначе 
				
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить элементы выбора вида генерируемой сделки
//
Процедура ОбновитьЭлементыВыбораГенерируемойСделки()
	
	ОбновитьЭлементыВыбораВидаГенерируемойСделки();
	ОбновитьЭлементыВыбораЭтапаГенерируемойСделки();
	ОбновитьЭлементыВыбораЗавершающихЭтаповГенерируемойСделки();
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить элементы выбора вида генерируемой сделки
//
Процедура ОбновитьЭлементыВыбораВидаГенерируемойСделки();
	
	ГруппаРодитель 		= Элементы.ГруппаВидовСделок;
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   		, "ГруппаВидыСделок_Общая");
	ПараметрыГруппы.Вставить("ГруппаЭлемента"		, ГруппаРодитель);	
	ПараметрыГруппы.Вставить("Группировка"   		, ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ГруппаВидыСделок = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
	ГруппаВидыСделок.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Одинарный;
	
	Для Каждого СтрокаТЗ Из ТаблицаДоступныхВидовСделок Цикл
		
		Индекс = ТаблицаДоступныхВидовСделок.Индекс(СтрокаТЗ);
		
		// Создание группы Вида.
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаВидСделки_" + Индекс);
		ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаВидыСделок);
		ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
		ГруппаВидСделки = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
		ГруппаВидСделки.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Полуторный;
		ГруппаВидСделки.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
		ГруппаВидСделки.Ширина = 30;
		ГруппаВидСделки.РастягиватьПоГоризонтали = Ложь;
				
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ВидСделки" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаВидСделки);
		ПараметрыДекорации.Вставить("Картинка"					, ?(СтрокаТЗ.Выбран, БиблиотекаКартинок.ЧекБоксПолный, БиблиотекаКартинок.Пустая));
		//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
