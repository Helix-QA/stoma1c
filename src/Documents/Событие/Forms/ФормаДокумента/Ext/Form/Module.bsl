// Процедура - Инициализировать комментарий
//
Процедура ИнициализироватьКомментарий()
	
	Если ЗначениеЗаполнено(Объект.Контрагент) И (ЗначениеЗаполнено(Объект.Ссылка) ИЛИ ЗначениеЗаполнено(ТекущаяСделка)) Тогда 
		НаправившийВрач = РегистрыСведений.Профосмотры.ПолучитьНаправившегоВрача(Объект.Контрагент
																				, ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Ссылка, Неопределено)
																				, ?(ЗначениеЗаполнено(ТекущаяСделка), ТекущаяСделка, Неопределено));
		
		Элементы.ДекорацияАвторДатаВремяСоздания.Видимость = ЗначениеЗаполнено(НаправившийВрач) ИЛИ Элементы.ДекорацияАвторДатаВремяСоздания.Видимость;
		Если ЗначениеЗаполнено(НаправившийВрач) Тогда
			Элементы.ДекорацияКартинкаНаправления.Видимость = Истина;
