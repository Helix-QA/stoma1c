&НаКлиенте
// Процедура - команда Некачественная заявка
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура НекачественнаяЗаявка(Команда)
	
	ВызвытьОповещение = Истина;	
	Если ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Заявки") Тогда
		ОткрытьФорму("Справочник.ОценкиКачестваЗаявок.ФормаВыбора",,,,,, Новый ОписаниеОповещения("ОценкаЗаявкиВыборЗавершение", ЭтотОбъект));
	ИначеЕсли ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Сделки") Тогда
		ОтменитьСделку(); 
		ЗаполнитьРезультатЗвонка(ПредопределенноеЗначение("Перечисление.РезультатыОбработкиЗвонка.ЗаписатьНеУдалось"));
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Оценка заявки завершение
//
Процедура ОценкаЗаявкиВыборЗавершение(Результат, ДопПараметры) Экспорт

	Если Результат <> Неопределено Тогда
		
		ЗаполнитьРезультатЗаявки(Результат);
		// Для закрытия окна звонка
		ОткрытаИзСписка = Истина; 
		ЗаполнитьРезультатЗвонка(ПредопределенноеЗначение("Перечисление.РезультатыОбработкиЗвонка.ЗаписатьНеУдалось"));
		ЭтаФорма.Закрыть();
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРезультатЗаявки(Оценка)
	
	ЗаявкаОснование = Справочники.Заявки.ПолучитьЗаявкуПоНомеруТелефона(НомерТелефонаКлиента);
	
	ЗаявкаОбъект = ЗаявкаОснование.ПолучитьОбъект();
	ЗаявкаОбъект.ОценкаЗаявки = Оценка;
	ЗаявкаОбъект.Статус = Перечисления.СтатусыЗаявок.Отклонена;
	ЗаявкаОбъект.Записать(); 
	
КонецПроцедуры

&НаКлиенте
// Процедура - Создать пациента и записать на прием
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СоздатьИЗаписатьПациента(Команда)
	
	Если ЗначениеЗаполнено(Фамилия) Или ЗначениеЗаполнено(Имя) Тогда
		ОбновитьЗаявкуИСделку(Ложь);                                    
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	Если ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) Тогда
		ПараметрыОткрытия.Вставить("Контрагент"              	, СтруктураКлиента.СписокКонтрагентов[0].Значение.КонтрагентСсылка);
	Иначе
		ПараметрыОткрытия.Вставить("ЗаявкаОснование"            , ЗаявкаОснование);
	КонецЕсли;
	ПараметрыОткрытия.Вставить("ЗакрытьПриСозданииЗаписи"	, Истина);    
	ПараметрыОткрытия.Вставить("ИсточникЗаписи"			, "Телефон");
	
	Если Не ОткрытаИзСписка И ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 0 Тогда	
		ПараметрыОткрытия.Вставить("ВнутреннийНомерСотрудника"			, ПараметрыТелефонногоЗвонка.ВнутреннийНомерСотрудника);	
	КонецЕсли;
	ПараметрыОткрытия.Вставить("IDЗвонка"			, IDЗвонка);
	
	ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыОткрытия, "ФормаЗаписи");
		
	Форма = ПолучитьФорму(ИмяФормыПланировщика, ПараметрыОткрытия,, "ФормаПланировщикКлючУникальности");
	Форма.Открыть();                            
	Оповестить("СозданиеСобытияСКонтрагентом", ПараметрыОткрытия);
	
	ВызвытьОповещение = Истина;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Создает пациента и сделку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СоздатьПациентаИСделку(Команда)
	
	Если ЗначениеЗаполнено(ЗаявкаОснование) И ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Заявки") Тогда
		ОбновитьЗаявкуИСделку(Истина);                                                   
	КонецЕсли;
	
	ВзаимодействиеЗадачаПараметры = Новый Структура;
	ВзаимодействиеЗадачаПараметры.Вставить("Взаимодействие"   , ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыВзаимодействий.ЗвонокИсходящий"));
	ВзаимодействиеЗадачаПараметры.Вставить("ВидВзаимодействия", ПредопределенноеЗначение("Перечисление.ВидыВзаимодействия.ЗвонокИсходящий"));
	ВзаимодействиеЗадачаПараметры.Вставить("ТемаПоУмолчанию"  , "Звонок исходящий");
	ВзаимодействиеЗадачаПараметры.Вставить("Представление"    , "Звонок исходящий");
	ВзаимодействиеЗадачаПараметры.Вставить("Картинка"         , БиблиотекаКартинок.ЗвонокИсходящий);
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Контрагент"	, СтруктураКлиента.СписокКонтрагентов[0].Значение.КонтрагентСсылка); 
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЗначенияЗаполнения"		, ЗначенияЗаполнения);
	ПараметрыОткрытия.Вставить("ВзаимодействиеСделка"	, ЗаявкаОснование);
	ПараметрыОткрытия.Вставить("ВзаимодействиеЗадачаПараметры"	, ВзаимодействиеЗадачаПараметры);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПослеУстановкиЗадачи", ЭтотОбъект);
	
	ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаЗадачиБыстрая", ПараметрыОткрытия,,,,, ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура - после установки  задачи
//
Процедура ПослеУстановкиЗадачи(Результат, ДопПараметры) Экспорт

	Если Результат <> Неопределено Тогда
		
		ЗаполнитьРезультатЗвонка(ПредопределенноеЗначение("Перечисление.РезультатыОбработкиЗвонка.ЗаписьНаПриемОтложена"));
		
	КонецЕсли;
		
КонецПроцедуры


&НаСервере
// Процедура - Обновляет заявку и сделку
//
Процедура ОбновитьЗаявкуИСделку(СоздаватьСделку) 
	
	ПреобразованныйНомер = СтрЗаменить(СтрСоединить(СтрРазделить(НомерТелефонаКлиента, "+&<>`“‘|%/\@() "), ""), Символы.НПП, "");
	
	Пациент = Справочники.Контрагенты.ПолучитьКонтрагентаПоНомеруТелефона(ПреобразованныйНомер);  
	Если ЗначениеЗаполнено(Пациент) Тогда
		СделкаПоЗаявке = Справочники.Сделки.ПолучитьАктуальнуюСделкуКлиента(Пациент, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница); 
	КонецЕсли;
	Если ЗначениеЗаполнено(СделкаПоЗаявке) Тогда
		ЗаявкаОснование = СделкаПоЗаявке; 
	Иначе
		Если Не ЗначениеЗаполнено(Пациент) Тогда
			Пациент = Справочники.Контрагенты.СоздатьКлиента(Фамилия,Имя,Отчество,НомерТелефонаКлиента,,ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница,"");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты")) И СоздаватьСделку Тогда
			
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("ВидСделки"         , ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"));
			ДанныеЗаполнения.Вставить("Контрагент"        , Пациент);
			ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
			ДанныеЗаполнения.Вставить("ЭтапСделки"        , Справочники.ЭтапыСделок.ПолучитьЭтапПоНомеру(Справочники.ВидыСделок.НовыеПациенты, 1));
			ДанныеЗаполнения.Вставить("Заявка"            , ЗаявкаОснование);
			СделкаПоЗаявке = Справочники.Сделки.СоздатьНовуюСделку(ДанныеЗаполнения, Истина);
			
			ЗаявкаОснование = СделкаПоЗаявке;
			
		КонецЕсли;
	КонецЕсли;         
	СохранитьКонтрАгента(ПОIPТелефонии, IDЗвонка, Пациент, ЗаявкаОснование);
	
	СформироватьПредставлениеИСписокВариантовНомера(НомерТелефонаКлиента, ПреобразованныйНомерТелефона, СписокВариантовНомераТелефона);
	СтруктураКлиента = ПолучитьСтруктуруКлиентаПоНомеруТелефона(СписокВариантовНомераТелефона);
	
	УстановитьВидимостьЭлементовФормы();	
	
КонецПроцедуры

&НаСервере
// Процедура - Сохраняет пациента
//
Процедура СохранитьКонтрАгента(ПОIPТелефонии, IDЗвонка, Контрагент = Неопределено, ЗаявкаОснование)
	
	НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Значение 		= ПОIPТелефонии;
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Использование 	= Истина;
	НаборЗаписей.Отбор.IDЗвонка.Значение 					= IDЗвонка;
	НаборЗаписей.Отбор.IDЗвонка.Использование 				= Истина;
	
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда 
		Запись 			= НаборЗаписей[0];
		Если Контрагент <> Неопределено Тогда
			Запись.Контрагент 	= Контрагент;    
		КонецЕсли;
		Запись.Заявка    = ЗаявкаОснование;
		НачатьТранзакцию();
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.Записать(Истина);
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, возвращает цвет текста от передаваемого цвета фона.
//
Функция ПолучитьЦветТекстаПоФону(ЦветФона)
	
	Если (ЦветФона.Зеленый + ЦветФона.Красный + ЦветФона.Синий) > 383 Тогда
		Возврат Новый Цвет(60,60,60);		
	Иначе
		Возврат Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Оповестить("ОбновитьСписокИсторииЗвонков");
	
	Если НЕ ОткрытаИзСписка И ВызвытьОповещение Тогда
		ОповеститьПоНомеруТелефона();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФамилияИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Текст) Тогда
		
		ОбновитьДанныеПоСозданиюПациента(Элемент.Имя, Текст);                          
		Если Элемент.Имя = "Фамилия" Тогда
			Фамилия = "";
		Иначе
			Имя = "";
		КонецЕсли;

	КонецЕсли;
    
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеПоСозданиюПациента(ИмяФамилия = Неопределено, ТекстЗаполнения = Неопределено)

	ПолеФ = ?(ИмяФамилия = Неопределено Или ИмяФамилия = "Имя", Фамилия, ТекстЗаполнения);
	ПолеИ = ?(ИмяФамилия = Неопределено Или ИмяФамилия = "Фамилия", Имя, ТекстЗаполнения);	
		
	Если ЗначениеЗаполнено(ПолеФ) Или ЗначениеЗаполнено(ПолеИ) Тогда
		//Элементы.ГруппаСоздатьПациентаИЗаписать.Доступность = Истина;  
		Элементы.ГруппаСоздатьПациентаИСделку.Доступность 	= Истина;
		//Элементы.СоздатьИЗаписатьПациента.Доступность 		= Истина;
		Элементы.СоздатьПациентаИСделку.Доступность 		= Истина;
	Иначе    
		//Элементы.ГруппаСоздатьПациентаИЗаписать.Доступность = Ложь;  
		Элементы.ГруппаСоздатьПациентаИСделку.Доступность 	= Ложь;
		//Элементы.СоздатьИЗаписатьПациента.Доступность 		= Ложь;
		Элементы.СоздатьПациентаИСделку.Доступность 		= Ложь;
	КонецЕсли;
	
	//Элементы.ГруппаСоздатьПациентаИЗаписать.ЦветФона 				= ?(Элементы.ГруппаСоздатьПациентаИЗаписать.Доступность, Новый Цвет(25, 116, 206), Новый Цвет(242, 242, 242));
	//Элементы.СоздатьИЗаписатьПациента.ЦветТекста 					= ?(Элементы.ГруппаСоздатьПациентаИЗаписать.Доступность, Новый Цвет(255, 255, 255), Новый Цвет(49, 49, 49));	
	Элементы.СоздатьПациентаИСделку.ЦветТекста 						= ?(Элементы.ГруппаСоздатьПациентаИСделку.Доступность, Новый Цвет(255, 255, 255), Новый Цвет(49, 49, 49));	
	Элементы.ГруппаСоздатьПациентаИСделку.ЦветФона 					= ?(Элементы.ГруппаСоздатьПациентаИСделку.Доступность, Новый Цвет(25, 116, 206), Новый Цвет(242, 242, 242));
	
КонецПроцедуры

