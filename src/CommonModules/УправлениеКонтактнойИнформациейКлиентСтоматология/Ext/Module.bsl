// Функция - Привести номер телефона к читаемому виду
//
// Параметры:
//  НомерТелефона	 - 	 - 
//  ФорматТелНомера	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПривестиНомерТелефонаКЧитаемомуВиду(НомерТелефона, ФорматТелНомера)
	
	НомерТелефона = СокрЛП(НомерТелефона);
	Если ФорматТелНомера = 1 ИЛИ ФорматТелНомера = 3 Тогда 
		ПерваяЧастьНомера = Лев(НомерТелефона, ?(СтрДлина(НомерТелефона) = 7, 3, 2));
		ВтораяЧастьНомера = Сред(НомерТелефона, ?(СтрДлина(НомерТелефона) = 7, 4, 3), 2);	
		ТретьяЧастьНомера = Прав(НомерТелефона, 2);
		
		Возврат ПерваяЧастьНомера + "-" + ВтораяЧастьНомера + "-" + ТретьяЧастьНомера; 
	Иначе 
		Возврат НомерТелефона;		
	КонецЕсли;

КонецФункции

