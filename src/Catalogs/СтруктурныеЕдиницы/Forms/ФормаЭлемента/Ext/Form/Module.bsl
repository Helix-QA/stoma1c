&НаСервере
// Процедура - удаляет рубрику и перестраивает динамические элементы.
//
Процедура УдалитьЭлементыНаСервере(ИмяКоманды)
	
	ИндексСтроки = СтрРазделить(ИмяКоманды,"_")[1];
	ЯндексИдентификаторРубрики.Удалить(ИндексСтроки);
	УдалитьДинамическиеЭлементы(Элементы.ГруппаРубрики, Элементы.ГруппаРубрика_Шаблон);
	ПостроитьДинамическиеЭлементы();
	ЭтаФорма.Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
// Процедура - включает и отключает использавание Яндекс карт.
//
Процедура ИспользоватьЯндексКартыПриИзменении(Элемент)
	
	Элементы.ГруппаЯндексИдентификаторРубрики.Видимость		= Объект.ИспользоватьЯндексКарты;
	Если Объект.ИспользоватьЯндексКарты Тогда
		Наименование = Истина;
		ЭтотОбъект.УидСессии = ЛичныйКабинет.УидТекущейСессии();
		ПолучитьНастройкиЯндексКарты(Наименование);
	КонецЕсли
	
КонецПроцедуры

&НаСервере
// Процедура - получает данные по Яндекс картам.
//
Процедура ПолучитьНастройкиЯндексКарты(Наименование)
	
	НастройкиЯндексКарты 							= Объект.Ссылка.НастройкиЯндексКарты.Получить();
	
	Если НастройкиЯндексКарты <> Неопределено Тогда
		
		УИДОрганизации = Новый УникальныйИдентификатор(?(ЗначениеЗаполнено(НастройкиЯндексКарты.Организация), НастройкиЯндексКарты.Организация, "00000000-0000-0000-0000-000000000000"));
		Организация = Справочники.Организации.ПолучитьСсылку(УИДОрганизации);
		ЭтотОбъект.ЯндексНаименованиеОрганизации = Организация;
		НастройкиЯндексКарты.Свойство("УникальныйНеизменныйИдентификатор"	, ЯндексУникальныйНеизменныйИдентификатор);
		НастройкиЯндексКарты.Свойство("Салон"								, ЯндексНаименованиеСалона);
		НастройкиЯндексКарты.Свойство("Страна"								, ЯндексСтрана);
		НастройкиЯндексКарты.Свойство("ОГРН"								, ЯндексОГРН);
		НастройкиЯндексКарты.Свойство("ИНН"									, ЯндексИНН);
		НастройкиЯндексКарты.Свойство("ДопАдрес"	   						, ЯндексДополнительнаяИнформацияКАдресу);
		НастройкиЯндексКарты.Свойство("Адрес"								, ЯндексАдрес);
		НастройкиЯндексКарты.Свойство("Сайт"								, ЯндексСайт);
		НастройкиЯндексКарты.Свойство("ДополнительныйСайт"					, ЯндексДополнительныйСайт);
		НастройкиЯндексКарты.Свойство("КоординатыПоДолготе"					, ЯндексКоординатыПоДолготе);
		НастройкиЯндексКарты.Свойство("КоординатыПоШироте"					, ЯндексКоординатыПоШироте);
		НастройкиЯндексКарты.Свойство("СсылкаНаФото"						, ЯндексСсылкаНаФото);
		НастройкиЯндексКарты.Свойство("ИдентификаторРубрики"				, ЯндексИдентификаторРубрики);
		НастройкиЯндексКарты.Свойство("ЧасыРаботы"							, ЯндексЧасыРаботы);
		НастройкиЯндексКарты.Свойство("ДатаАктуализации"					, ЯндексДатаАктуализации);
		НастройкиЯндексКарты.Свойство("КороткийАдрес"						, ЯндексКороткийАдрес);
		
		УдалитьДинамическиеЭлементы(Элементы.ГруппаРубрики, Элементы.ГруппаРубрика_Шаблон);
		ПостроитьДинамическиеЭлементы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - удаляет динамические элементы.
//
Процедура УдалитьДинамическиеЭлементы(ГруппаДляУдаления, ШаблонГруппы)
	
	МассивУдаляемых = Новый Массив;
	
	Для Каждого ЭлементГруппы Из ГруппаДляУдаления.ПодчиненныеЭлементы Цикл
		Если ЭлементГруппы <> ШаблонГруппы Тогда
			МассивУдаляемых.Добавить(ЭлементГруппы);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементФормы Из МассивУдаляемых Цикл
		Элементы.Удалить(ЭлементФормы);  
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура - создает динамические элементы.
//
Процедура ПостроитьДинамическиеЭлементы()
	
	Счетчик = 0;
	Для Каждого СтрокаТ Из ЯндексИдентификаторРубрики Цикл
		
		ГруппаФормы				 			= УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(ЭтаФорма, Элементы.ГруппаРубрика_Шаблон, Счетчик, Элементы.ГруппаРубрики);
		ДекорацияФормы			 			= УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(ЭтаФорма, Элементы.ДекорацияРубрика_Шаблон, Счетчик,, ГруппаФормы); 
		КнопкаФормы				 			= УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(ЭтаФорма, Элементы.УдалитьРубрику_Шаблон, Счетчик, ГруппаФормы); 
		Если СтрДлина(СтрокаТ.Представление) > 31 Тогда
			ДекорацияФормы.Ширина			= 17;
			// ДекорацияФормы.Высота			= 1;
		КонецЕсли;
		ДекорацияФормы.Заголовок 			= СтрокаТ.Представление;
		КнопкаФормы.Доступность				= ПравоДоступа("Редактирование", Метаданные.Справочники.СтруктурныеЕдиницы);

		Счетчик 							= Счетчик + 1;
		
	КонецЦикла;
	Элементы.КомандаПодобратьИдентификаторРубрики.Доступность = ПравоДоступа("Редактирование", Метаданные.Справочники.СтруктурныеЕдиницы);
	Если ЯндексИдентификаторРубрики.Количество() = 3 Тогда
		Элементы.КомандаПодобратьИдентификаторРубрики.Видимость = Ложь;
	Иначе
		Элементы.КомандаПодобратьИдентификаторРубрики.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - подбирает идентификаторы рубрик.
//
Процедура КомандаПодобратьИдентификаторРубрики(Команда)
	
	Если ЯндексИдентификаторРубрики.Количество() = 3 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя выбирать больше трех рубрик!");
	Иначе
		ОткрытьФорму("Справочник.СтруктурныеЕдиницы.Форма.ФормаВыбораИдентификатораРубрики");
	КонецЕсли;
	 
КонецПроцедуры

&НаСервере 
// Процедура - получает идентификатор рубрики из временного хранилища.
//
Процедура ПолучитьИдентификаторИзХранилища(АдресВХранилище)
	
	НастройкиЯндексКарты = Объект.Ссылка.НастройкиЯндексКарты.Получить();
	ЭтаФорма.Модифицированность = Истина;

	Для Счетчик = ЯндексИдентификаторРубрики.Количество() по 2 Цикл
		
		Если ЯндексИдентификаторРубрики.Количество() = Счетчик Тогда
			Стр 						= ЯндексИдентификаторРубрики.Добавить();
			Стр.Значение 				= АдресВХранилище;
			Стр.Представление           = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(АдресВХранилище, "_")[1];
			ИД 							= Стр.ПолучитьИдентификатор(); 
			УдалитьДинамическиеЭлементы(Элементы.ГруппаРубрики, Элементы.ГруппаРубрика_Шаблон);
			ПостроитьДинамическиеЭлементы();
			Возврат
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если ЭтоЗаписьВЦРМ Тогда
		ОтправитьВЦРМ();
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура, - отправляет данные в CRM.
//
Процедура ОтправитьВЦРМ()
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("session"				, ЛичныйКабинет.УидТекущейСессии());
	ПараметрыЗапроса.Вставить("structuralunit"		, СтрЗаменить(Строка(Объект.Ссылка.УникальныйИдентификатор()), "-", ""));
	ПараметрыЗапроса.Вставить("name"				, Строка(Объект.Организация));
	ПараметрыЗапроса.Вставить("yandexadress"		, ЭтаФорма.ЯндексАдрес);
	ПараметрыЗапроса.Вставить("yandexaddadress"		, ЭтаФорма.ЯндексДополнительнаяИнформацияКАдресу);
	ПараметрыЗапроса.Вставить("yandexaddsite"		, НРег(ЭтаФорма.ЯндексДополнительныйСайт));
	ПараметрыЗапроса.Вставить("yandexinn"			, Объект.Организация.ИНН);
	ПараметрыЗапроса.Вставить("yandexdolgota"		, ЭтаФорма.ЯндексКоординатыПоДолготе);
	ПараметрыЗапроса.Вставить("yandexshirota"		, ЭтаФорма.ЯндексКоординатыПоШироте);
	ПараметрыЗапроса.Вставить("yandexsalon"			, ЭтаФорма.ЯндексСтруктурнаяЕдиница);
	ПараметрыЗапроса.Вставить("yandexogrn"			, Объект.Организация.ОГРН);
	ПараметрыЗапроса.Вставить("yandexsite"			, НРег(ЭтаФорма.ЯндексСайт));
	ПараметрыЗапроса.Вставить("yandexfoto"			, НРег(ЭтаФорма.ЯндексСсылкаНаФото));
	ПараметрыЗапроса.Вставить("yandexstrana"		, Строка(Константы.СтранаУчета.Получить()));
	ПараметрыЗапроса.Вставить("yandextime"			, ЭтаФорма.ЯндексЧасыРаботы);
	ПараметрыЗапроса.Вставить("yandexdata"			, ЭтаФорма.ЯндексДатаАктуализации);
	ПараметрыЗапроса.Вставить("yandexgorod"			, ЭтаФорма.ЯндексГород);
	ПараметрыЗапроса.Вставить("yandexstatus"		, Объект.ИспользоватьЯндексКарты);
	ПараметрыЗапроса.Вставить("yandexkey"			, ЭтаФорма.ЯндексКлючВнешнейСистемы);
	ПараметрыЗапроса.Вставить("yandexobl"			, ЭтаФорма.ЯндексНомерОбласти);
	ПараметрыЗапроса.Вставить("yandexstructura"		, ЭтаФорма.ЯндексСтруктурнаяЕдиница);
	ПараметрыЗапроса.Вставить("yandexshortadres"	, ЭтаФорма.ЯндексКороткийАдрес);
	ПараметрыЗапроса.Вставить("yandextip"			, "2");   // 0 - Салон красоты, 1 - Фитнес, 2 - Стоматология

	 
	МассивЯндексРубрик = Новый Массив;
	Для Каждого СтрокаТ Из ЯндексИдентификаторРубрики Цикл
		МассивЯндексРубрик.Добавить(СтрокаТ.Значение);	
	КонецЦикла;
	ПараметрыЗапроса.Вставить("yandexrubrika" , МассивЯндексРубрик);
	
	МассивКартинок = Новый Массив;
	Для Каждого СтрокаТ Из ЭтаФорма.ФайлыКартинок Цикл
		МассивКартинок.Добавить(СтрокаТ.Представление);	
	КонецЦикла;
	ПараметрыЗапроса.Вставить("yandexkartinki" , МассивКартинок);
	
	МассивТелефонов = Новый Массив;
	Для Каждого СтрокаТ Из ЯндексНомерТелефона Цикл
		
		СтруктураСтроки = Новый Структура("НомерТелефона, ДобавочныйНомер, ЧейНомер");
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, СтрокаТ);
		МассивТелефонов.Добавить(СтруктураСтроки);
		
	КонецЦикла;
		
	ПараметрыЗапроса.Вставить("yandextelsp"		, МассивТелефонов);
	
	МассивЯндексЭлПочты = Новый Массив;
	Для Каждого СтрокаТ Из ЯндексЭлектроннаяПочта Цикл
		МассивЯндексЭлПочты.Добавить(СтрокаТ.Значение);	
	КонецЦикла;
	ПараметрыЗапроса.Вставить("yandexmailsp" , МассивЯндексЭлПочты);
	
	МассивЯндексСоциальныеСети = Новый Массив;
	Для Каждого СтрокаТ Из ЯндексСоциальныеСети Цикл
		МассивЯндексСоциальныеСети.Добавить(СтрокаТ.Значение);	
	КонецЦикла;
	ПараметрыЗапроса.Вставить("yandexsitesp" , МассивЯндексСоциальныеСети);
	
	РезультатЗапроса = ЛичныйКабинет.ОтправитьДанныеЯндексКартыВCRM(ПараметрыЗапроса);
	
КонецПроцедуры	

