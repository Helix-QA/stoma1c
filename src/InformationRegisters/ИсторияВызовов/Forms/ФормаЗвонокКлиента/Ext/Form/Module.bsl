&НаСервере
// Процедура - Отображает сделки и заявки пациента
//
Процедура ОтобразитьСделкиИЗаписи()
	
	ТаблицаСделок.Очистить();
	ТаблицаЗаписей.Очистить();
	ТаблицаПолисов.Очистить();
	УдалитьДинамическиеЭлементы(Элементы.ГруппаПациенты);
	
	СтруктураКлиента = ПолучитьСтруктуруКлиентаПоНомеруТелефона(СписокВариантовНомераТелефона);
	
	Если ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) Тогда
		
		ИндексПациента = 0;
		
		Для Каждого Пациент Из СтруктураКлиента.СписокКонтрагентов Цикл
			
			ЭлементГруппаПациент                     	= ЭтаФорма.Элементы.Добавить("ГруппаПациент_" + ИндексПациента, Тип("ГруппаФормы"), Элементы.ГруппаПациенты);
			ЭлементГруппаПациент.Вид                 	= ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементГруппаПациент.Заголовок 				= ?(СтруктураКлиента.СписокКонтрагентов.Количество() = 1, "", Пациент.Значение.Наименование);
			ЭлементГруппаПациент.Отображение         	= ОтображениеОбычнойГруппы.Нет;
			ЭлементГруппаПациент.ЦветТекстаЗаголовка	= WebЦвета.Черный;
			ЭлементГруппаПациент.ШрифтЗаголовка			= Новый Шрифт("Arial", 12);
			ЭлементГруппаПациент.Группировка         	= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
			
			ДоступныеСЕ = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник);
			ЗначТекСЕ = ДоступныеСЕ.НайтиПоЗначению(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
			НомерСтроки = ДоступныеСЕ.Индекс(ЗначТекСЕ) * (-1);
			ДоступныеСЕ.Сдвинуть(ЗначТекСЕ, НомерСтроки); 
			
			ИндексСЕ = 0;
			Для Каждого СтрЕдиница Из ДоступныеСЕ Цикл
				
				ОткрытыеСделкиПациента = Справочники.Сделки.ПолучитьСделкиПоКлиенту(Пациент.Значение.КонтрагентСсылка, СтрЕдиница.Значение, Ложь,,,,Истина,Истина,,Истина);
				ОткрытыеЗаписиПациента = Документы.Событие.СобытияЗаУказанныйПериод( НачалоДня(ТекущаяДатаСеанса()), Дата(3000,1,1),,СтрЕдиница.Значение, Пациент.Значение.КонтрагентСсылка);
				Если ЗначениеЗаполнено(ОткрытыеЗаписиПациента) Тогда
					ОткрытыеЗаписиПациента.Свернуть("Событие, ДатаНачала, Статус, ПолисМедСтрахования, Сотрудник");
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ОткрытыеСделкиПациента) Или ЗначениеЗаполнено(ОткрытыеЗаписиПациента) Тогда

					Если ИндексСЕ = 1 Тогда 
						
						ДекорацияФормы_Метка = Элементы.Добавить("ДекорацияСЕЗаголовок" + ИндексСЕ + "_" + ИндексПациента, Тип("ДекорацияФормы"), ЭлементГруппаПациент);
