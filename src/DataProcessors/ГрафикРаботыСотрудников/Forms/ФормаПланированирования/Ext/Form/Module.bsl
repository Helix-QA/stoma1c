// Обновить массив рабочих дней в неделе для текущей СЕ
// 
Процедура ОбновитьМассивРабочихДнейВНеделе()
	
	// Получаем массив номеров рабочих дней недели для СЕ	
	ВременныйМассив = Новый Массив;
	ПериодыРаботыСтруктурнойЕдиницы = ОбщегоНазначенияСтоматология.ВернутьПериодыРаботы(
															?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), ОтборСтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница),
															ОтборПериод.ДатаНачала,
															Новый Структура("КолДней" , 7));	
							
	Если ПериодыРаботыСтруктурнойЕдиницы <> Неопределено Тогда
		ПериодыРаботыСтруктурнойЕдиницы.Сортировать("ДеньНедели");		
		Для Каждого СтрокаТ ИЗ ПериодыРаботыСтруктурнойЕдиницы Цикл
			ВременныйМассив.Добавить(ДеньНедели(СтрокаТ.ДеньНедели));
		КонецЦикла;
	КонецЕсли;		
	МасивРабочихДнейНедели = Новый ФиксированныйМассив(ВременныйМассив);
	
