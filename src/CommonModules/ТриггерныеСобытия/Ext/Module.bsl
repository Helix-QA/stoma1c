#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура - Зарегистрировать событие
//
// Параметры:
//  ДанныеТриггера			 - 	 - 
//  РегистрацияПоПодписке	 - 	 - 
//
Процедура ЗарегистрироватьСобытие(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено, МассивИсключительноРегламентныхТриггеров = Неопределено, РегистрацияВФоне = Ложь) Экспорт
	
	// 1. Инициализируем актуальный план действий триггерного события
	// 2. Регистрируем некондиционные действия триггерного события
	ДанныеТриггера.ПланДействийТриггерногоСобытия = ПолучитьТаблицуПланаДействийТриггерногоСобытия(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
	
	// Если план действий пустой (не актуальный) - уходим
	Если ДанныеТриггера.ПланДействийТриггерногоСобытия.Количество() = 0 Тогда
		// Отклоняем некондиционные действия
		ЗарегистрироватьПланируемыеСобытия(ДанныеТриггера.ТаблицаНекондиционныхДействий, Истина);
		Возврат;
	КонецЕсли;
	
	// Получаем данные для регистрации события, фильтруем согласно отборов, установленных в триггерном событии
	ТаблицаДанныхОбъекта = ПолучитьДанныеДляРегистрацииСобытия(ДанныеТриггера, РегистрацияПоПодписке, РегистрацияЗапланированных, ОбъектСобытия);
	
	// Отклоняем некондиционные действия
	ЗарегистрироватьПланируемыеСобытия(ДанныеТриггера.ТаблицаНекондиционныхДействий, Истина);
	
	Если РегистрацияЗапланированных Тогда
		// Проверяем прошли ли запланированные строчки через систему фильтрации		
		АктуализироватьЗапланированныеСобытияПослеФильтрации(ДанныеТриггера, ОбъектСобытия, ТаблицаДанныхОбъекта);
		// Уходим, если по итогу событий для регистрации триггера не оказалось
		Если ТаблицаДанныхОбъекта = Неопределено ИЛИ ТаблицаДанныхОбъекта.Количество() = 0 Тогда 
			Возврат;
		КонецЕсли;	
	ИначеЕсли РегистрацияПоПодписке Тогда 
		
	Иначе
		Если НЕ ТаблицаДанныхОбъекта = Неопределено И НЕ ТаблицаДанныхОбъекта.Количество() = 0 Тогда 
			// Если это активация и события получили по регламенту как не запланированные, хотя они должны по условиям триггера планироваться в момент активации в пределах дня активции, тогда активация была будующей датой и она сейчас настала.
			// Необходимо запланировать с учетом смещения часов или минут и уйти. Регламент другим пакетом подхватит этот план в нужное время и зарегистрирует.
		Иначе
			// Если актуальные события не наступили - уходим, регистрируя пустую строчку с целью оптимизации общего механизма			
			Если НЕ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе И НЕ ДанныеТриггера.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана Тогда 
				Если НЕ МассивИсключительноРегламентныхТриггеров = Неопределено И ТипЗнч(МассивИсключительноРегламентныхТриггеров) = Тип("Массив") Тогда 
					Если НЕ МассивИсключительноРегламентныхТриггеров.Найти(ДанныеТриггера.УсловиеСобытия) = Неопределено Тогда 
						ЗарегистрироватьПланируемыеСобытия(Неопределено, , ДанныеТриггера.ПланДействийТриггерногоСобытия);
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			Возврат;
		КонецЕсли;
	КонецЕсли;

	Если ТаблицаДанныхОбъекта = Неопределено ИЛИ ТаблицаДанныхОбъекта.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
		
	// Инициализируем параметры шаблона
	ПараметрыРегистрации = Новый Структура();
	ПараметрыРегистрации.Вставить("ДанныеТриггера"							, ПреобразоватьВСтруктуру(ДанныеТриггера));
	ПараметрыРегистрации.Вставить("РегистрацияПоПодписке"					, РегистрацияПоПодписке);
	ПараметрыРегистрации.Вставить("РегистрацияЗапланированных"				, РегистрацияЗапланированных);
	ПараметрыРегистрации.Вставить("ОбъектСобытия"							, ОбъектСобытия);
	ПараметрыРегистрации.Вставить("МассивИсключительноРегламентныхТриггеров", МассивИсключительноРегламентныхТриггеров);
	ПараметрыРегистрации.Вставить("РегистрацияВФоне"						, РегистрацияВФоне);
		
	ИнициализироватьПараметрыШаблона(ДанныеТриггера, ПараметрыРегистрации, ТаблицаДанныхОбъекта, РегистрацияВФоне);
	
	Если РегистрацияВФоне = Истина ИЛИ ДанныеТриггера.ПланДействийТриггерногоСобытия.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;	
		
	// Подготовим структуру контактных данных
	СтруктураКонтактнойИнформации = Новый Структура;
	// Структура может содержать следующие таблицы:
	// - ТаблицаКлиентовСНомерамиТелефонов
	// - ТаблицаКлиентовСУказаннымиEmail
	// - ТаблицаОсновныхМенеджеров
	// - ТаблицаСотрудниковСНомерамиТелефонов
	// - ТаблицаСотрудниковСУказаннымиEmail
	ИнициализироватьСтруктуруКонтактнойИнформации(ДанныеТриггера, ТаблицаДанныхОбъекта, СтруктураКонтактнойИнформации);
	
	// Подготовим таблицу с расписанием работы СЕ
	ТаблицаВремениРаботыСтруктурнойЕдиницы = ИнициализироватьТаблицуВремениРаботыСтруктурнойЕдиницы(ТаблицаДанныхОбъекта, ДанныеТриггера);
	
	// Генерируем действия, указанные в триггере
	НачатьГенерациюОбъектовИнформирования(ДанныеТриггера,
											ТаблицаДанныхОбъекта,
											СтруктураКонтактнойИнформации,
											ТаблицаВремениРаботыСтруктурнойЕдиницы,
											ПараметрыРегистрации);
	
КонецПроцедуры

// Функция - Получить таблицу плана действий триггерного события
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуПланаДействийТриггерногоСобытия(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия)
	
	Если НЕ ДанныеТриггера.ПланДействийТриггерногоСобытия = Неопределено Тогда
		Возврат ДанныеТриггера.ПланДействийТриггерногоСобытия;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТриггерноеСобытие"										, ДанныеТриггера.ТриггерноеСобытие);
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"									, РегистрацияПоПодписке);
	УстановитьПараметрыСообщенийДляТриггерныхДействий(Запрос);
	
	Если РегистрацияЗапланированных Тогда                  
		
#Область _____________АКТУАЛИЗАЦИЯ_ПЛАНА_ДЕЙСТВИЯ_ДЛЯ_ЗАПЛАНИРОВАННЫХ_______________
		
		Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ДанныеТриггера.РеестрЗапланированных, "РеестрЗапланированных");
		Запрос.Текст = "ВЫБРАТЬ
		               |	РеестрЗапланированных.Период КАК Период,
		               |	РеестрЗапланированных.ТриггерноеСобытие КАК ТриггерноеСобытие,
		               |	РеестрЗапланированных.ДатаСменыСтатуса КАК ДатаСменыСтатуса,
		               |	РеестрЗапланированных.Контрагент КАК Контрагент,
		               |	РеестрЗапланированных.ОбъектСобытия КАК ОбъектСобытия,
		               |	РеестрЗапланированных.ИсточникСобытия КАК ИсточникСобытия,
		               |	РеестрЗапланированных.ИдентификаторДействия КАК ИдентификаторДействия,
		               |	РеестрЗапланированных.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	РеестрЗапланированных.Подтверждено КАК Подтверждено
		               |ПОМЕСТИТЬ ТаблицаРеестрЗапланированных
		               |ИЗ
		               |	РеестрЗапланированных КАК РеестрЗапланированных
		               |
		               |ОБЪЕДИНИТЬ
		               |
		               |ВЫБРАТЬ
		               |	ЖурналРегистрацииТриггерныхСобытий.Период,
		               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие,
		               |	РеестрЗапланированных.ДатаСменыСтатуса,
		               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент,
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия,
		               |	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия,
		               |	ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия,
		               |	ЖурналРегистрацииТриггерныхСобытий.РегистрацияПоПодписке,
		               |	ИСТИНА
		               |ИЗ
		               |	РеестрЗапланированных КАК РеестрЗапланированных
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |		ПО РеестрЗапланированных.ТриггерноеСобытие = ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие
		               |			И РеестрЗапланированных.Контрагент = ЖурналРегистрацииТриггерныхСобытий.Контрагент
		               |			И РеестрЗапланированных.ОбъектСобытия = ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		               |			И РеестрЗапланированных.ИсточникСобытия = ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия
		               |			И РеестрЗапланированных.ИдентификаторДействия <> ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия
		               |			И РеестрЗапланированных.РегистрацияПоПодписке = ЖурналРегистрацииТриггерныхСобытий.РегистрацияПоПодписке
		               |ГДЕ
		               |	ЖурналРегистрацииТриггерныхСобытий.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТриггерныеСобытияДействия.Ссылка КАК ТриггерноеСобытие,
		               |	ЕСТЬNULL(ТаблицаРеестрЗапланированных.ДатаСменыСтатуса, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаСменыСтатуса,
		               |	ЕСТЬNULL(ТаблицаРеестрЗапланированных.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент,
		               |	ЕСТЬNULL(ТаблицаРеестрЗапланированных.ОбъектСобытия, НЕОПРЕДЕЛЕНО) КАК ОбъектСобытия,
		               |	ЕСТЬNULL(ТаблицаРеестрЗапланированных.ИсточникСобытия, НЕОПРЕДЕЛЕНО) КАК ИсточникСобытия,
		               |	ЕСТЬNULL(ТаблицаРеестрЗапланированных.РегистрацияПоПодписке, ЛОЖЬ) КАК РегистрацияПоПодписке,
		               |	ЕСТЬNULL(ТаблицаРеестрЗапланированных.Подтверждено, ЛОЖЬ) КАК Подтверждено,
		               |	ТриггерныеСобытияДействия.Ссылка.ПометкаУдаления КАК ПометкаУдаления,
		               |	ВЫБОР
		               |		КОГДА ТриггерныеСобытияДействия.Ссылка.ПометкаУдаления = ЛОЖЬ
		               |				И ТриггерныеСобытияДействия.Ссылка.Активно = ИСТИНА
		               |				И ТриггерныеСобытияДействия.Использование = ИСТИНА
		               |				И ТриггерныеСобытияДействия.ВидДействия <> ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.ПустаяСсылка)
		               |				И ТриггерныеСобытияДействия.Удалено = ЛОЖЬ
		               |			ТОГДА ИСТИНА
		               |		ИНАЧЕ ЛОЖЬ
		               |	КОНЕЦ КАК ДействиеАктуально,
		               |	ВЫБОР
		               |		КОГДА ТаблицаРеестрЗапланированных.ТриггерноеСобытие ЕСТЬ NULL
		               |			ТОГДА ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Отклонено)
		               |		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)
		               |	КОНЕЦ КАК СтатусРегистрации,
		               |	ТриггерныеСобытияДействия.Ссылка.Активно КАК Активно,
		               |	ВЫБОР
		               |		КОГДА ТаблицаРеестрЗапланированных.ТриггерноеСобытие ЕСТЬ NULL
		               |			ТОГДА ТриггерныеСобытияДействия.ИдентификаторДействия
		               |		ИНАЧЕ ТаблицаРеестрЗапланированных.ИдентификаторДействия
		               |	КОНЕЦ КАК ИдентификаторДействия,
		               |	ВЫБОР
		               |		КОГДА ТаблицаРеестрЗапланированных.ТриггерноеСобытие ЕСТЬ NULL
		               |			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		               |		ИНАЧЕ ТаблицаРеестрЗапланированных.Период
		               |	КОНЕЦ КАК ПериодОтбора,
		               |	ТриггерныеСобытияДействия.Использование КАК Использование,
		               |	ТриггерныеСобытияДействия.ВидДействия КАК ВидДействия,
		               |	ТриггерныеСобытияДействия.ВидАдресата КАК ВидАдресата,
		               |	ТриггерныеСобытияДействия.ВидАдресатаРезервный КАК ВидАдресатаРезервный,
		               |	ТриггерныеСобытияДействия.Адресат КАК Адресат,
		               |	ТриггерныеСобытияДействия.ОтправкаPush КАК ОтправкаPush,
		               |	ТриггерныеСобытияДействия.ОтправкаPushWallet КАК ОтправкаPushWallet,
		               |	ТриггерныеСобытияДействия.ОтправкаMessenger КАК ОтправкаMessenger,
		               |	ТриггерныеСобытияДействия.ОтправкаSMS КАК ОтправкаSMS,
		               |	ТриггерныеСобытияДействия.КаналСистемыСообщений КАК КаналСистемыСообщений,
		               |	ТриггерныеСобытияДействия.АккаунтВнешнейСистемы КАК АккаунтВнешнейСистемы,
		               |	ТриггерныеСобытияДействия.АккаунтSMS КАК АккаунтSMS,
		               |	ТриггерныеСобытияДействия.АккаунтEmail КАК АккаунтEmail,
		               |	ТриггерныеСобытияДействия.ЗадачаРежимНапоминания КАК ЗадачаРежимНапоминания,
		               |	ТриггерныеСобытияДействия.ВидСделки КАК ВидСделки,
		               |	ТриггерныеСобытияДействия.ЭтапСделки КАК ЭтапСделки,
		               |	ТриггерныеСобытияДействия.СоздаватьСделку КАК СоздаватьСделку,
		               |	ТриггерныеСобытияДействия.КоличествоГенерацийСделок КАК КоличествоГенерацийСделок,
		               |	ТриггерныеСобытияДействия.СценарийЧатБота КАК СценарийЧатБота,
		               |	ТриггерныеСобытияДействия.ШаблонСообщения КАК ШаблонСообщения,
		               |	ТриггерныеСобытияДействия.Описание КАК Описание,
		               |	ВЫБОР
		               |		КОГДА ТриггерныеСобытияДействия.Ссылка.ПометкаУдаления = ИСТИНА
		               |			ТОГДА &ПользовательПометилНаУдалениеТриггер
		               |		КОГДА ТриггерныеСобытияДействия.Ссылка.Активно = ЛОЖЬ
		               |			ТОГДА &ПользовательДеактивировалТриггер
		               |		КОГДА ТриггерныеСобытияДействия.Использование = ЛОЖЬ
		               |			ТОГДА &ПользовательДеактивировалДействие
		               |		КОГДА ТриггерныеСобытияДействия.ВидДействия = ЗНАЧЕНИЕ(Перечисление.ВариантыДействийТриггерныхСобытий.ПустаяСсылка)
		               |			ТОГДА &ПользовательНеУказалВидДействия
		               |		КОГДА ТриггерныеСобытияДействия.Удалено = ИСТИНА
		               |			ТОГДА &ПользовательУдалилДействие
		               |		ИНАЧЕ """"
		               |	КОНЕЦ КАК Сообщение,
		               |	ТриггерныеСобытияДействия.Удалено КАК Удалено
		               |ПОМЕСТИТЬ ТаблицаРеестрАктуализацииЗапланированных
		               |ИЗ
		               |	Справочник.ТриггерныеСобытия.Действия КАК ТриггерныеСобытияДействия
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаРеестрЗапланированных КАК ТаблицаРеестрЗапланированных
		               |		ПО ТриггерныеСобытияДействия.Ссылка = ТаблицаРеестрЗапланированных.ТриггерноеСобытие
		               |			И ТриггерныеСобытияДействия.ИдентификаторДействия = ТаблицаРеестрЗапланированных.ИдентификаторДействия
		               |ГДЕ
		               |	ТриггерныеСобытияДействия.Ссылка = &ТриггерноеСобытие
		               |	И ЕСТЬNULL(ТаблицаРеестрЗапланированных.Подтверждено, ЛОЖЬ) = ЛОЖЬ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаРеестрАктуализацииЗапланированных.ПериодОтбора КАК ПериодОтбора,
		               |	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаЗапланированная,
		               |	ТаблицаРеестрАктуализацииЗапланированных.ТриггерноеСобытие КАК ТриггерноеСобытие,
		               |	ВЫБОР
		               |		КОГДА ТаблицаРеестрАктуализацииЗапланированных.СтатусРегистрации = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Отклонено)
		               |				И ТаблицаРеестрАктуализацииЗапланированных.ДействиеАктуально
		               |			ТОГДА ЕСТЬNULL(ТаблицаРеестрЗапланированных.Контрагент, ТаблицаРеестрАктуализацииЗапланированных.Контрагент)
		               |		ИНАЧЕ ТаблицаРеестрАктуализацииЗапланированных.Контрагент
