&НаСервере
// Процедура, формирует список обслуживаемых клиентов в Стоматология.
//
Процедура СформироватьСписокОбслуживаемыеКлиентыСервер()
	
	ДинамическийСписокЧекиККМСуммаДолговКлиентов = 0; 	
	ПараметрГруппировки = ИмяГруппировки;
	
	УсловиеГруппировки = " УПОРЯДОЧИТЬ ПО ";
	
	Если Не ЗначениеЗаполнено(ПараметрГруппировки) Тогда
		УсловиеГруппировки = УсловиеГруппировки + " ДокСсылка";
	ИначеЕсли ПараметрГруппировки = "СгруппироватьВремя" Тогда  		
		УсловиеГруппировки = УсловиеГруппировки +  " ВремяНачала,ДокСсылка ИТОГИ ПО ЧасГруппировки";
	ИначеЕсли  ПараметрГруппировки = "СгруппироватьКлиент" Тогда	
		УсловиеГруппировки = УсловиеГруппировки +  " Клиент,ДокСсылка ИТОГИ ПО Клиент";
	ИначеЕсли  ПараметрГруппировки = "СгруппироватьСотрудник" Тогда	
		УсловиеГруппировки = УсловиеГруппировки +  " Сотрудник,ДокСсылка ИТОГИ ПО Сотрудник";
	КонецЕсли;  
	
	УсловиеГруппировки = УсловиеГруппировки + " АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НАЧАЛОПЕРИОДА(Прием.Дата, ЧАС) КАК ЧасГруппировки,
	|	Прием.Дата КАК ВремяНачала,
	|	Прием.Контрагент КАК Клиент,
	|	Прием.Сотрудник КАК Сотрудник,
	|	Прием.КартаКонтрагента КАК НомерКарты,
	|	Прием.Ссылка КАК ДокСсылка,
	|	Прием.Проведен
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	(НЕ Прием.Проведен
	|				И НЕ Прием.Долговой
	|				И НЕ Прием.ПометкаУдаления
	|				И Прием.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И (Прием.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ))
	|			ИЛИ Прием.Проведен
	|				И НЕ Прием.Долговой
	|				И Прием.СуммаОплачено <> Прием.СуммаДокумента
	|				И Прием.СуммаДокумента <> 0
	|				И Прием.ПолисМедСтрахования = ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяСсылка)
	|				И НЕ Прием.ПометкаУдаления
	|				И Прием.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И (Прием.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ)))
	|
	|СГРУППИРОВАТЬ ПО
	|	Прием.Ссылка,
	|	Прием.Контрагент,
	|	Прием.КартаКонтрагента,
	|	Прием.Сотрудник,
	|	Прием.Проведен,
	|	НАЧАЛОПЕРИОДА(Прием.Дата, ЧАС),
	|	Прием.Дата"+УсловиеГруппировки;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата()); 	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТаблицаПоиска    = РезультатЗапроса.Выгрузить(); // нужна для посчета количества клиентов по группировке.  	
	ВыборкаПриемов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);   
	
	ДеревоТекущихКлиентов.ПолучитьЭлементы().Очистить();   	
	ТекущееКоличествоКлиентов = 0;
	
	Пока ВыборкаПриемов.Следующий() Цикл 							
		ДеревоСтрокаРодитель                         = ДеревоТекущихКлиентов.ПолучитьЭлементы().Добавить();
		Если  ВыборкаПриемов.ЧасГруппировки <> Null Тогда
			ВремяПосещения = Формат(ВыборкаПриемов.ЧасГруппировки, "ДФ=HH:mm") + " - " + Формат(ВыборкаПриемов.ЧасГруппировки+1*60*60, "ДФ=HH:mm");
		КонецЕсли;	
		Если НЕ ЗначениеЗаполнено(ПараметрГруппировки) Тогда  // если без группировки, тогда отображаем общим списком
			ДеревоСтрокаРодитель.ВремяЗаписи 			= ВыборкаПриемов.ВремяНачала;
			ДеревоСтрокаРодитель.КартинкаВремяЗаписи 	= БиблиотекаКартинок.ЧасыВремяПять;
			ДеревоСтрокаРодитель.Клиент 				= ВыборкаПриемов.Клиент;
			ДеревоСтрокаРодитель.КартинкаКлиент 		= БиблиотекаКартинок.ПользовательНовая;
			ДеревоСтрокаРодитель.Сотрудник 				= ВыборкаПриемов.Сотрудник;
			ДеревоСтрокаРодитель.КартинкаВрач 			= БиблиотекаКартинок.ПосещениеВрачаСтетоскоп;
			ДеревоСтрокаРодитель.Ссылка 				= ВыборкаПриемов.ДокСсылка;
			ДеревоСтрокаРодитель.Проведен               = ВыборкаПриемов.Проведен;
		Иначе			
			КолСтрок = 0; 			
			
			Если ПараметрГруппировки = "СгруппироватьВремя" Тогда // если сгруппировать по времени
				ДеревоСтрокаРодитель.ПолеПредставления = ВремяПосещения; 
				ДеревоСтрокаРодитель.ВремяЗаписи       = ВремяПосещения; 
				СтруктураПоиска                        = Новый Структура("ЧасГруппировки", ВыборкаПриемов.ЧасГруппировки);
				ДеревоСтрокаРодитель.КартинкаГруппировка = БиблиотекаКартинок.ЧасыВремяПять;
			ИначеЕсли ПараметрГруппировки = "СгруппироватьКлиент" Тогда // если сгруппировать по клиенту
				ДеревоСтрокаРодитель.ПолеПредставления   = ВыборкаПриемов.Клиент;    				
				ДеревоСтрокаРодитель.Клиент              = ВыборкаПриемов.Клиент;    				
				СтруктураПоиска                          = Новый Структура("Клиент", ВыборкаПриемов.Клиент);
				ДеревоСтрокаРодитель.КартинкаГруппировка = БиблиотекаКартинок.ПользовательНовая;
			ИначеЕсли ПараметрГруппировки              = "СгруппироватьСотрудник" Тогда // если сгруппировать по врачу
				ДеревоСтрокаРодитель.ПолеПредставления = ВыборкаПриемов.Сотрудник;    				
				ДеревоСтрокаРодитель.Сотрудник         = ВыборкаПриемов.Сотрудник;    				
				СтруктураПоиска = Новый Структура("Сотрудник", ВыборкаПриемов.Сотрудник);
				ДеревоСтрокаРодитель.КартинкаГруппировка = БиблиотекаКартинок.ПосещениеВрачаСтетоскоп;
			КонецЕсли;
			
			Если СтруктураПоиска <> Неопределено Тогда // подсчитаем количество элементов по группировке
				МС       = ТаблицаПоиска.НайтиСтроки(СтруктураПоиска); 				
				КолСтрок = ?(МС.Количество() > 1, МС.Количество() - 1, 0);
			КонецЕсли;
			
			ДеревоСтрокаРодитель.ПолеПредставления = "" + ДеревоСтрокаРодитель.ПолеПредставления + " (" + КолСтрок + ")";    			
			
			ВыборкаГруппировка = ВыборкаПриемов.Выбрать();
			Пока ВыборкаГруппировка.Следующий() Цикл  
				ДеревоПодчиненнаяСтрока             		= ДеревоСтрокаРодитель.ПолучитьЭлементы().Добавить();
				ДеревоПодчиненнаяСтрока.Ссылка 				= ВыборкаГруппировка.ДокСсылка;
				ДеревоПодчиненнаяСтрока.Проведен 		    = ВыборкаГруппировка.Проведен;
				ДеревоПодчиненнаяСтрока.ВремяЗаписи 		= ВыборкаГруппировка.ВремяНачала;
				ДеревоПодчиненнаяСтрока.КартинкаВремяЗаписи = БиблиотекаКартинок.ЧасыВремяПять;
				ДеревоПодчиненнаяСтрока.Клиент 				= ВыборкаГруппировка.Клиент;
				ДеревоПодчиненнаяСтрока.КартинкаКлиент 		= БиблиотекаКартинок.ПользовательНовая;
				ДеревоПодчиненнаяСтрока.Сотрудник 			= ВыборкаГруппировка.Сотрудник;
				ДеревоПодчиненнаяСтрока.КартинкаВрач 		= БиблиотекаКартинок.ПосещениеВрачаСтетоскоп;
			КонецЦикла; 
		КонецЕсли;
	КонецЦикла;     	
	
КонецПроцедуры

&НаСервере
