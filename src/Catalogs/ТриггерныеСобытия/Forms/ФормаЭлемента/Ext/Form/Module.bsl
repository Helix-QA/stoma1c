&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтоВерсияКОРП 								= Истина; //ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП();
	Элементы.ГруппаИнформацияДляПРОФ.Видимость 	= НЕ ЭтоВерсияКОРП;
	ЗадаватьВопросПередУдалениемДействий		= РегистрыСведений.НастройкиИнтерфейсов.ПолучитьЗначениеНастройкиПользователя("Триггеры_ЗадаватьВопросПриУдаленииДействий", Истина);
	ТекущаяСтруктурнаяЕдиница 					= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Если НЕ Элементы.ГруппаИнформацияДляПРОФ.Видимость Тогда
		ЗагрузитьТаблицуАктуализацииТриггеров();
		ЗагрузитьСписокВнешнихСистем();
	КонецЕсли;

	ИнициироватьРазделСобытия();
	ЗаполнитьСписокТриггеров(, Истина);
	ЗаполнитьСписокМоментовАктивации();
	ЗаполнитьСписокВыбораВремени();
	ЗаполнитьСписокСтруктурныхЕдиниц();
	ЗаполнитьСписокВидовПериодаСобытий();	
	ЗаполнитьСписокВидовСделок();
	ЗаполнитьСписокВидовЛицевыхСчетов();
	ЗаполнитьСписокВидовБонусныхСчетов();
	ЗаполнитьСписокСтатусовПредварительнойЗаписи();
	ЗаполнитьСписокТиповСтраховыхПолисов();
	ЗаполнитьСписокВыбораРежимаНапоминания();
	
	// Динамическое формирование табличной части
	СформироватьТаблицуДействий(, Истина);
	
	УстановитьСвойстваЭлементамФормы(Истина);
	УстановитьДоступностьЭлементамФормы();
		
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ВИДЫ_И_ЭТАПЫ_СДЕЛОК" Тогда
		// Кешируем текущие значения объекта
		СтруктураЗначенийОбъекта = ЗакешироватьТекущиеЗначенияОбъекта();
		// Читаем актуальную версию объекта
		ЭтаФорма.Прочитать();
		// Восстанавливаем значения
		ЗаполнитьЗначенияСвойств(Объект, СтруктураЗначенийОбъекта);
		ЭтаФорма.Модифицированность = НЕ Объект.Ссылка.Пустая();
		УстановитьСвойстваЭлементамДействий();
	КонецЕсли;	
	
	Если ИмяСобытия = "СОХРАНЕНИЕ_ВНЕШНЕЙ_СИСТЕМЫ" Тогда 
		УстановитьСвойстваЭлементамДействий();
	КонецЕсли;
	
	Если ИмяСобытия = "СОХРАНЕНИЕ_СЦЕНАРИЯ" Тогда 
		УстановитьСвойстваЭлементамДействий();
	КонецЕсли;
	
	Если ИмяСобытия = "ОТКЛЮЧЕН_ВОПРОС_ПОЛЬЗОВАТЕЛЮ_ОБ_УДАЛЕНИИ_ДЕЙСТВИЯ" Тогда
		Если ЗадаватьВопросПередУдалениемДействий = Истина Тогда 
			ЗадаватьВопросПередУдалениемДействий = Ложь;
		КонецЕсли;			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Перед записью
//
// Параметры:
//  Отказ			 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Активно И Объект.ЭтоГруппа = Ложь Тогда
		// Проверка на заполненость реквизитов объекта, которые скрыты в всплывающих группах
		// (Прекрасно понимаю, что данная проверка должна производится в модуле объекта.
		// Но для большей информативности пользователей было принято решение продублировать в модуле формы)
		
		СтруктураСообщения = Новый Структура;
		СтруктураСообщения.Вставить("СообщитьПользователю"			, Ложь);		
		СтруктураСообщения.Вставить("ТекстСообщения"				, "");
		СтруктураСообщения.Вставить("ПолеИнформирования"			, "");
		СтруктураСообщения.Вставить("ИндексСтроки"					, 0);
		СтруктураСообщения.Вставить("ПоказатьПараметры"				, Ложь);		
		СтруктураСообщения.Вставить("ПоказатьФормуНастройкиКаналов"	, Ложь);
		
		Для Каждого СтрокаДействия Из Объект.Действия Цикл
			Если НЕ СтрокаДействия.Использование ИЛИ НЕ ЗначениеЗаполнено(СтрокаДействия.ВидДействия) ИЛИ СтрокаДействия.Удалено Тогда 
				Продолжить;
			КонецЕсли;
			
			// Проверка для действия "Поставить задачу"
			Если СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру") Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидАдресата) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан вид исполнителя!';en='The type of performer is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "ВидАдресата");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли СтрокаДействия.ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.Сотрудник") И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан исполнитель!';en='The performer is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "Адресат");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли СтрокаДействия.ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.СегментСотрудников") И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.СегментыСотрудников")) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан сегмент исполнителей!';en='Do not specify the segment of performers!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "Адресат");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли СтрокаДействия.ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.Куратор") Тогда 
					Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидАдресатаРезервный) Тогда
						СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
						СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан резервный вид исполнителя!';en='The backup type of performer is not specified!'"));
						СтруктураСообщения.Вставить("ПолеИнформирования"	, "ВидАдресатаРезервный");
						СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
						СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
						Прервать;
					ИначеЕсли СтрокаДействия.ВидАдресатаРезервный = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.Сотрудник") И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
						СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
						СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан резервный исполнитель!';en='A backup performer was not specified!'"));
						СтруктураСообщения.Вставить("ПолеИнформирования"	, "Адресат");
						СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
						СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
						Прервать;
					ИначеЕсли СтрокаДействия.ВидАдресатаРезервный = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.СегментСотрудников") И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.СегментыСотрудников")) Тогда
						СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
						СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан резервный сегмент исполнителей!';en='Do not specify a reserve segment performers!'"));
						СтруктураСообщения.Вставить("ПолеИнформирования"	, "Адресат");
						СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
						СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
						Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			// Проверка для действия "Отправить сообщение"
			Если СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение") Тогда
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидАдресата) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан вид адресата!';en='The type of recipient is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "ВидАдресата");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли СтрокаДействия.ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.Сотрудник") И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан адресат!';en='The recipient is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "Адресат");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
					//ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаДействия.АккаунтSMS) И СтрокаДействия.ОтправкаSMS Тогда
					//	СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					//	СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан аккаунт SMS-рассылки!';en='The SMS mailing account is not specified!'"));												
					//	СтруктураСообщения.Вставить("ПолеИнформирования"	, "АккаунтSMS");
					//	СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					//	СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					//	Прервать;
					//ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаДействия.АккаунтВнешнейСистемы) И СтрокаДействия.ОтправкаMessenger Тогда
					//	СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);					
					//	СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан аккаунт системы сообщений!';en='Message system account not specified!'"));						
					//	СтруктураСообщения.Вставить("ПолеИнформирования"	, "АккаунтВнешнейСистемы");
					//	СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					//	СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					//	Прервать;					
					//ИначеЕсли СтрокаДействия.ОтправкаMessenger Тогда 
					//	ТипВнешнейСистемы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаДействия.АккаунтВнешнейСистемы, "ТипВнешнейСистемы");
					//	Если ТипВнешнейСистемы = ПредопределенноеЗначение("Перечисление.ТипыВнешнихСистем.Chat2Desk") И НЕ ЗначениеЗаполнено(СтрокаДействия.КаналСистемыСообщений) Тогда 
					//		СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					//		СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан канал системы сообщений!';en='The message system channel is not specified!'"));
					//		СтруктураСообщения.Вставить("ПолеИнформирования"	, "КаналСистемыСообщений");
					//		СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					//		СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					//		Прервать;						
					//	КонецЕсли;
				Иначе
					Уведомить = Ложь;				
					Для Каждого СтрокаНастройкаКаналов Из МоделируемыеНастройкиКаналовУведомлений Цикл 
						Если НЕ СтрокаДействия.ИдентификаторДействия = СтрокаНастройкаКаналов.ИдентификаторДействия Тогда 
							Продолжить;
						КонецЕсли;
						
						Если НЕ ЗначениеЗаполнено(СтрокаНастройкаКаналов.АккаунтВнешнейСистемы) И СтрокаНастройкаКаналов.ОтправкаMessenger Тогда
							СтруктураСообщения.Вставить("СообщитьПользователю"			, Истина);					
							СтруктураСообщения.Вставить("ТекстСообщения"				, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для структурной единицы ""%1"" не указан аккаунт системы сообщений!';en='Message system account not specified!'"), СтрокаНастройкаКаналов.СтруктурнаяЕдиница));						
							СтруктураСообщения.Вставить("ПолеИнформирования"			, "АккаунтВнешнейСистемы");
							СтруктураСообщения.Вставить("ИндексСтроки"					, Объект.Действия.Индекс(СтрокаДействия));
							СтруктураСообщения.Вставить("ПоказатьПараметры"				, Истина);
							СтруктураСообщения.Вставить("ПоказатьФормуНастройкиКаналов"	, Истина);
							Уведомить = Истина;						
							Прервать;					
						ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаНастройкаКаналов.АккаунтСервисаРассылкиSMS) И СтрокаНастройкаКаналов.ОтправкаSMS Тогда
							СтруктураСообщения.Вставить("СообщитьПользователю"			, Истина);
							СтруктураСообщения.Вставить("ТекстСообщения"				, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Для структурной единицы ""%1"" не указан аккаунт SMS-рассылки!';en='The SMS mailing account is not specified!'"), СтрокаНастройкаКаналов.СтруктурнаяЕдиница));												
							СтруктураСообщения.Вставить("ПолеИнформирования"			, "АккаунтSMS");
							СтруктураСообщения.Вставить("ИндексСтроки"					, Объект.Действия.Индекс(СтрокаДействия));
							СтруктураСообщения.Вставить("ПоказатьПараметры"				, Истина);
							СтруктураСообщения.Вставить("ПоказатьФормуНастройкиКаналов"	, Истина);							
							Уведомить = Истина;												
							Прервать; 
						КонецЕсли;
					КонецЦикла;
					Если Уведомить Тогда 
						Прервать;
					КонецЕсли;				
				КонецЕсли;	
				Если ЗначениеЗаполнено(СтрокаДействия.ШаблонСообщения) Тогда 
					Если ПустоеСодержаниеШаблона(СтрокаДействия.ШаблонСообщения, "СодержаниеМессенджер") И ПустоеСодержаниеШаблона(СтрокаДействия.ШаблонСообщения, "Содержание") Тогда 
						СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
						СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Необходимо заполнить содержание в шаблоне SMS-рассылки!';en='You must fill in the content in the SMS mailing template!'"));
						СтруктураСообщения.Вставить("ПолеИнформирования"	, "ШаблонСообщения");
						СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
						СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
						Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			// Проверка для действия "Отправить Email"			
			Если СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо") Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидАдресата) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан вид адресата!';en='The type of recipient is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "ВидАдресата");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли СтрокаДействия.ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.Сотрудник") И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан адресат!';en='The recipient is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "Адресат");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаДействия.АккаунтEmail) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан аккаунт Email-рассылки!';en='The Email mailing account is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "АккаунтEmail");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			// Проверка для действия "Повысить этап сделки"						
			Если СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки") ИЛИ СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки") Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидСделки) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан вид сделки!';en='The type of transaction is not specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "ВидСделки");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				ИначеЕсли ЗначениеЗаполнено(СтрокаДействия.ВидСделки) И НЕ ЗначениеЗаполнено(СтрокаДействия.ЭтапСделки) Тогда 
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан этап сделки!';en='The transaction stage was omitted!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "ЭтапСделки");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			// Проверка для действия "Активировать чат-бота"						
			Если СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота") Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.СценарийЧатБота) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан сценарий чат-бота!';en='No chatbot script specified!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "СценарийЧатБота");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			// Проверка заполненности шаблона
			Если ЗначениеЗаполнено(СтрокаДействия.ВидДействия) И НЕ (СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки") ИЛИ СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.СменитьЭтапСделки") ИЛИ СтрокаДействия.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота")) Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.ШаблонСообщения) Тогда
					СтруктураСообщения.Вставить("СообщитьПользователю"	, Истина);
					СтруктураСообщения.Вставить("ТекстСообщения"		, НСтр("ru='Не указан шаблон!';en='Do not specify a template!'"));
					СтруктураСообщения.Вставить("ПолеИнформирования"	, "ШаблонСообщения");
					СтруктураСообщения.Вставить("ИндексСтроки"			, Объект.Действия.Индекс(СтрокаДействия));
					СтруктураСообщения.Вставить("ПоказатьПараметры"		, Истина);
					Прервать;
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;
		
		// Информируем пользователя
		Если СтруктураСообщения.СообщитьПользователю Тогда
			// Показываем всплывающую группу
			Если СтруктураСообщения.ПоказатьПараметры Тогда 
				ЭлементФормы = Элементы.Найти("ВсплывающаяГруппаПараметровДействия_Индекс_" + Строка(СтруктураСообщения.ИндексСтроки));
				Если НЕ ЭлементФормы = Неопределено Тогда
					Если ЭлементФормы.Скрыта() Тогда 
						ЭлементФормы.Показать();
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			// Сообщаем
			ОбщегоНазначенияКлиент.СообщитьПользователю(СтруктураСообщения.ТекстСообщения,
			, "Объект.Действия[" + Формат(СтруктураСообщения.ИндексСтроки, "ЧГ=0") + "]." + СтруктураСообщения.ПолеИнформирования);
			// Прерываем запись
			Отказ = Истина;
		КонецЕсли;	
				
	КонецЕсли;

	ИнициироватьАктуализациюЗапланированных(Отказ);		
	
КонецПроцедуры

&НаКлиенте
// Процедура - Инициировать актуализацию запланированных
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ИнициироватьАктуализациюЗапланированных(Отказ)
	
	Если Отказ = Истина Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ПараметрыАктуализации) = Тип("Структура") И ПараметрыАктуализации.Свойство("ПроверкаИнициирована") Тогда 
		Возврат;
	КонецЕсли;
	
	ИнициироватьАктуализациюЗапланированныхНаСервере(); 
	Если ПараметрыАктуализации.Свойство("АктуализироватьПериодЗапланированныхСобытий") Тогда
		ОписаниеОповещенияВопроса = Новый ОписаниеОповещения("ПослеОтветаНаВопросОбАктуализациипериодаЗапланированных", ЭтотОбъект);
		СписокКнопокДиалога = Новый СписокЗначений;
		СписокКнопокДиалога.Добавить(КодВозвратаДиалога.ОК		, "Продолжить");
		СписокКнопокДиалога.Добавить(КодВозвратаДиалога.Отмена	, "Отмена");
		ПоказатьВопрос(ОписаниеОповещенияВопроса, "Вами были изменены параметры инициации триггерного события в разделе ""Старт"". Необходима актуализация времени срабатывания триггерного события для запланированных клиентов.", СписокКнопокДиалога, , , "Вопрос пользователю");
		Отказ = Истина;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - После ответа на вопрос об актуализациипериода запланированных
//
// Параметры:
//  РезультатОтвета			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеОтветаНаВопросОбАктуализациипериодаЗапланированных(РезультатОтвета, ДополнительныеПараметры = Неопределено) Экспорт 
	
	Если ЗначениеЗаполнено(РезультатОтвета) Тогда
		Если РезультатОтвета = КодВозвратаДиалога.ОК Тогда 
			ПараметрыАктуализации.Вставить("ПроверкаИнициирована", Истина);
			ЭтаФорма.Записать();
			ЭтаФорма.Закрыть();
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура - Инициировать актуализацию запланированных на сервере
//
Процедура ИнициироватьАктуализациюЗапланированныхНаСервере()
	
	ПараметрыАктуализации = Новый Структура;
	
	Если Объект.Ссылка.Пустая() Тогда 
		Возврат;
	КонецЕсли;
	
	Если Объект.Активно И Объект.ЭтоГруппа = Ложь Тогда
		Если Объект.УсловиеСобытия = Объект.Ссылка.УсловиеСобытия И Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентСменаСтатуса Тогда 
			Если Объект.Ссылка.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия И (Объект.Ссылка.ПериодСобытияВид = Перечисления.Периодичность.Час ИЛИ Объект.Ссылка.ПериодСобытияВид = Перечисления.Периодичность.Минута) 
				И Объект.МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия И (Объект.ПериодСобытияВид = Перечисления.Периодичность.Час ИЛИ Объект.ПериодСобытияВид = Перечисления.Периодичность.Минута) 
				И (Объект.Ссылка.ПериодСобытияВид <> Объект.ПериодСобытияВид ИЛИ Объект.Ссылка.ПериодСобытия <> Объект.ПериодСобытия) Тогда 
				
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ
				               |	ЖурналРегистрацииТриггерныхСобытий.Период КАК Период,
				               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие КАК ТриггерноеСобытие,
				               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
				               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК ОбъектСобытия,
				               |	ЖурналРегистрацииТриггерныхСобытий.ИдентификаторДействия КАК ИдентификаторДействия,
				               |	ЖурналРегистрацииТриггерныхСобытий.РегистрацияПоПодписке КАК РегистрацияПоПодписке
				               |ИЗ
				               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
				               |ГДЕ
				               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
				               |	И ЖурналРегистрацииТриггерныхСобытий.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРегистрацииСобытий.Запланировано)";
				
				Запрос.УстановитьПараметр("ТриггерноеСобытие", Объект.Ссылка);
				ТаблицаЗапланированных = Запрос.Выполнить().Выгрузить();
				ПараметрыАктуализации.Вставить("КоличествоЗапланированных", ТаблицаЗапланированных.Количество());
				//Если ПараметрыАктуализации.КоличествоЗапланированных > 0 Тогда 
					ПараметрыАктуализации.Вставить("АктуализироватьПериодЗапланированныхСобытий", Истина);
					ПараметрыАктуализации.Вставить("ПериодСобытияВидПрошлый", Объект.Ссылка.ПериодСобытияВид);
					ПараметрыАктуализации.Вставить("ПериодСобытияПрошлый"	, Объект.Ссылка.ПериодСобытия);
				//КонецЕсли;	
				
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Перед записью на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.НастройкиКаналовУведомлений.Очистить();
	
	Для Каждого СтрокаДействия Из ТекущийОбъект.Действия Цикл 
		Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидДействия) ИЛИ СтрокаДействия.Удалено ИЛИ НЕ СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение Тогда 
			Продолжить;
		КонецЕсли;
		
		МассивСтрокНастроекПоСтруктурнымЕдиницам = МоделируемыеНастройкиКаналовУведомлений.НайтиСтроки(Новый Структура("ИдентификаторДействия", СтрокаДействия.ИдентификаторДействия));
		Для Каждого ЭлементМассиваСтрок Из МассивСтрокНастроекПоСтруктурнымЕдиницам Цикл 
			ЗаполнитьЗначенияСвойств(ТекущийОбъект.НастройкиКаналовУведомлений.Добавить(), ЭлементМассиваСтрок);
		КонецЦикла;
	КонецЦикла;	
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ПараметрыАктуализации", ПараметрыАктуализации);
	      
КонецПроцедуры

&НаСервере
// Процедура - После записи на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)

	// Динамическое формирование табличной части
	СформироватьТаблицуДействий(, Истина);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Перед закрытием
//
// Параметры:
//  Отказ				 - 	 - 
//  ЗавершениеРаботы	 - 	 - 
//  ТекстПредупреждения	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	Если ЗавершениеРаботы ИЛИ НЕ ЭтоВерсияКОРП Тогда 
		Возврат;
	КонецЕсли;
	
	СохранитьТаблицуАктуализацииТриггеров(ТаблицаАктуализацииТриггеров); 
	
КонецПроцедуры

#КонецОбласти

#Область ________________________________ОБРАБОТЧИКИ_КОМАНД_ФОРМЫ____________________________________

&НаКлиенте
// Процедура - Активировать событие
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура АктивироватьСобытие(Команда)
	
	Объект.Активно = НЕ Объект.Активно;
	ЭтаФорма.Модифицированность = Истина;
	УстановитьСвойстваЭлементамФормы(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор времени старта
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВыборВремениСтарта(Команда)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ДатаВремя"			, НачалоДня(ТекущаяДата()) + (Час(Объект.ВремяСобытия)*60*60) + (Минута(Объект.ВремяСобытия)*60));
	ПараметрыФормы.Вставить("ШагМинут"			, 10);	

