	КонецЕсли;	
	Объект.ЭтапСделки = ЭтотОбъект.ЭтапыСделок[Индекс].Ссылка;
	
	Если ЗначениеЗаполнено(Объект.РезультатСделки) Тогда
		Объект.РезультатСделки = Неопределено;
		Объект.ПричинаОтказа   = Неопределено;
		УстановитьВидимостьРезультатаСделки();
	КонецЕсли;
	
	ОбновитьЭтапыСделки();
	
КонецПроцедуры

