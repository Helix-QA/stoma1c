// Процедура - Выбор этапа генерируемой сделки
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборЭтапаГенерируемойСделки(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда 
		Если РезультатВыбора = ДополнительныеПараметры.ВыбранныйЭтап Тогда 
			Возврат;
		КонецЕсли;
		ОбновитьВиджетСделкиНаФорме = Ложь;
		Для Каждого СтрокаВидСделки Из ТаблицаДоступныхВидовСделок Цикл 
			Если СтрокаВидСделки.ВидСделки = ДополнительныеПараметры.ВыбранныйВидСделки Тогда
				Для Каждого СтрокаЭтап Из СтрокаВидСделки.ТаблицаЭтапов Цикл 
					СтрокаЭтап.Выбран = СтрокаЭтап.Этап = РезультатВыбора;
					Если СтрокаЭтап.Выбран Тогда 
						ОбновитьВиджетСделкиНаФорме = Истина;
					КонецЕсли;	
				КонецЦикла;	
		        Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ОбновитьВиджетСделкиНаФорме Тогда 
			ОбновитьВиджетСделки(Истина, Ложь); 
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор вида генерируемой сделки
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборВидаГенерируемойСделки(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда 
		Если РезультатВыбора = ДополнительныеПараметры.ВыбранныйВидСделки Тогда 
			Возврат;
		КонецЕсли;
		ОбновитьВиджетСделкиНаФорме = Ложь;
		Для Каждого СтрокаВидСделки Из ТаблицаДоступныхВидовСделок Цикл
			Если СтрокаВидСделки.Выбран Тогда 
				Для Каждого СтрокаЭтап Из СтрокаВидСделки.ТаблицаЭтапов Цикл 
					СтрокаЭтап.Выбран = Ложь;
				КонецЦикла;	
			КонецЕсли;	
			СтрокаВидСделки.Выбран 	= СтрокаВидСделки.ВидСделки = РезультатВыбора;			
			Если СтрокаВидСделки.Выбран Тогда 
				ОбновитьВиджетСделкиНаФорме = Истина;
				СтрокаВидСделки.ТаблицаЭтапов[0].Выбран = Истина;
			КонецЕсли;	
		КонецЦикла;
		Если ОбновитьВиджетСделкиНаФорме Тогда 
			ОбновитьВиджетСделки(Истина, Ложь); 
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

