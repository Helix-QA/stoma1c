// Процедура, ОбновитьПричинуОтказаВыборНаСервере.
//
Процедура ОбновитьПричинуОтказаВыборНаСервере(ПричинаОтказа, ИмяЭлемента)	
	
	УправлениеИнтерфейсамиСервер.ОбновитьПричинуОтказа(ЭтаФорма, ПричинаОтказа, ИмяЭлемента);
	
	Если Объект.Ссылка.Пустая() Тогда
		
		ЭтотОбъект.Статус = Перечисления.СтатусыКонтрагентов.Отказ;
		ОбновитьОформлениеКнопкиСтатусаКлиента();
		
	Иначе 
		
		ЭтотОбъект.Статус = Справочники.Контрагенты.ПолучитьСтатус(Объект.Ссылка);
		ОбновитьОформлениеКнопкиСтатусаКлиента();
			
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, ОбновитьСделку.
//
Процедура ОбновитьСделку(ИмяКоманды, Контрагент)
	
	Если СтрНайти(ИмяКоманды, "КомандаЭтап") > 0 Тогда		
		
		ИндексВиджета 	= ПолучитьИндексСтроки(ИмяКоманды, Ложь);
		ИндексЭтапа     = ПолучитьИндексСтроки(ИмяКоманды);
		НайденнаяСделка = ЭтотОбъект.ТаблицаСделок[ИндексВиджета].Сделка;

		УправлениеИнтерфейсамиСервер.ОбновитьЭтапСделки(НайденнаяСделка, ИндексЭтапа);
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() 
		И ЭтотОбъект.Статус <> Перечисления.СтатусыКонтрагентов.Потенциальный Тогда
		
		ЭтотОбъект.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный;
		ОбновитьОформлениеКнопкиСтатусаКлиента();
		
	Иначе 
		
		ЭтотОбъект.Статус = Справочники.Контрагенты.ПолучитьСтатус(Объект.Ссылка);
		ОбновитьОформлениеКнопкиСтатусаКлиента();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ИмяЭлемента, ИндексЭлемента = Истина)
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		
		Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Сред(ИмяЭлемента, НомерСимвола + 1, 2)) Тогда
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 2));
		Иначе		
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));	
		КонецЕсли;		
		
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1));
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура, СменитьФокусЭлемента.
Процедура СменитьФокусЭлемента(Знач ИндексГурппы)
	
	ЭтаФорма.ТекущийЭлемент = Элементы["КнопкаТекущийЭтап_" + ИндексГурппы];
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, ПолучитьВидыСделок.
//
Функция ПолучитьВидыСделок(Пациент, Статус, ЛичныйВрач = Неопределено)
	
	Если Статус = Перечисления.СтатусыКонтрагентов.Потенциальный Тогда
		Возврат Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(, Пациент, Статус, ЛичныйВрач);
	Иначе
		Возврат Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(, Пациент, Статус, ЛичныйВрач);		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура, создает новую сделку клиенту.
//
Процедура СоздатьСделку(Клиент, ВидСделки, ЧленствоПакетУслуг = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(Клиент)
		И НЕ ЗначениеЗаполнено(ВидСделки) Тогда
		Возврат;
	КонецЕсли;
	
	Если ВидСделкиПродление(ВидСделки)
		И Не ЗначениеЗаполнено(ЧленствоПакетУслуг) Тогда
		
		ВыбратьЧленствоПакетУслугИзСписка(ВидСделки);
	Иначе		
		НоваяСделка = СоздатьСделкуНаСервере(ВидСделки, Клиент, ЧленствоПакетУслуг);
		Если ЗначениеЗаполнено(НоваяСделка) Тогда 
			Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
			Оповестить("ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ", НоваяСделка);
		КонецЕсли;	
	КонецЕсли;
		
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, определяет является ли переданный вид сделки продлением.
//
// Параметры:
//  ВидСделки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВидСделкиПродление(ВидСделки)
   Возврат ВидСделки.ТипСделки = Перечисления.ТипыСделок.Продление;
КонецФункции

&НаСервере
// Функция - Создать сделку на сервере
//
// Параметры:
//  ВидСделки			 - 	 - 
//  Клиент				 - 	 - 
//  ЧленствоПакетУслуг	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьСделкуНаСервере(Знач ВидСделки, Знач Клиент, Знач ЧленствоПакетУслуг)
	
	НоваяСделка = Неопределено;
	
	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("Контрагент"					, Клиент);
	ДанныеЗаполнения.Вставить("ВидСделки"					, ВидСделки);
	ДанныеЗаполнения.Вставить("ЭтапСделки"					, Справочники.ВидыСделок.ПолучитьСтартовыйЭтапВидаСделки(ВидСделки));
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.ЭтапСделки) Тогда
		ПричинаНеУказаныЭтапы = НСтр("ru='Для данного вида сделки не указаны этапы.';en='No stages are specified for this type of transaction'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось создать сделку по причине: ';en='Failed to create deal for the reason:'") + Символы.ПС + ПричинаНеУказаныЭтапы);
		Возврат НоваяСделка;
	КонецЕсли;		
	ДанныеЗаполнения.Вставить("ДатаСделки"					, ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("ЧленствоПакетУслуг"			, ЧленствоПакетУслуг);
	ДанныеЗаполнения.Вставить("ИсточникИнформации"			, Объект.ИсточникИнформации);
	ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"			, ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
	ДанныеЗаполнения.Вставить("ИсточникИнформацииЗначение"	, ?(ЗначениеЗаполнено(Объект.КлиентИсточникИнформации), Объект.КлиентИсточникИнформации, Неопределено));
	ДанныеЗаполнения.Вставить("Менеджер"					, Объект.Куратор);
 	ДанныеЗаполнения.Вставить("СформироватьНаименование"	, Истина);		

	Попытка
		НоваяСделка = Справочники.Сделки.СоздатьНовуюСделку(ДанныеЗаполнения, Истина);
		ОбновитьВиджетИСтатусКонтрагента();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось создать сделку по причине: ';en='Failed to create deal for the reason:'") + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат НоваяСделка;
	
КонецФункции

&НаКлиенте
// Процедура - Выбрать членство пакет услуг из списка.
//
Процедура ВыбратьЧленствоПакетУслугИзСписка(знач ВидСделки)
	
	ЧПУ = ПолучитьЧПУКлиента(Объект.Ссылка);
	
	Если ЧПУ.Количество() > 0 Тогда
		
		СписокВыбора = Новый СписокЗначений();		
		СписокВыбора.ЗагрузитьЗначения(ЧПУ);
		
		Для Каждого ЭлементСписка Из СписокВыбора Цикл		
			ЭлементСписка.Представление = ЭлементСписка.Значение; 			
		КонецЦикла;
		
		Оповещение = Новый ОписаниеОповещения("ОбработкаВыборкаЧленстваПакетаУслугЗавершение", ЭтотОбъект, ВидСделки);		
		ПоказатьВыборИзМеню(Оповещение, СписокВыбора, Элементы.КнопкаСоздатьСделку);
		
	Иначе
		ПоказатьПредупреждение(,НСтр("ru='У клиента нет членств и пакетов для продления';en='Client not memberships and packages for extension'"));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Обработка выборка членства пакета услуг завершение.
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ОбработкаВыборкаЧленстваПакетаУслугЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
