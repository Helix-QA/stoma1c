// Функция, возвращает количество задач по сделке.
//
Функция ПолучитьКоличествоЗадач(Сделка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(Взаимодействие.Ссылка) КАК КоличествоЗадач
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Сделка = &Сделка
	|	И НЕ Взаимодействие.ПометкаУдаления
	|	И НЕ Взаимодействие.Выполнена");
	
	Запрос.УстановитьПараметр("Сделка", Сделка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.КоличествоЗадач, 0);
	
