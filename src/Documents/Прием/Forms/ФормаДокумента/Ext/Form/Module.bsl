// Функция вернет значение реквизита по указанному ИД
//
Функция ПолучитьЗначениеРеквизитаИзБуфераДанныхобследования(ИдентификаторРеквизита)
	
	ВедущийИД       = ПолучитьВедущийИдентификторРеквизитаОбследования(ИдентификаторРеквизита);
	ВедомыйИД       = ПолучитьВедомыйИдентификторРеквизитаОбследования(ИдентификаторРеквизита);
	НайденныеСтроки = Неопределено;
	Если НЕ ЗначениеЗаполнено(ВедомыйИД) Тогда
		НайденныеСтроки = ДОЗначенияРеквизитовОбследования.НайтиСтроки(Новый Структура("РеквизитИдентификатор", ВедущийИД));
	Иначе
		НайденныеСтроки = ДОЗначенияРеквизитовОбследования.НайтиСтроки(Новый Структура("РеквизитИдентификатор,ЗубИдентификатор", ВедущийИД,ВедомыйИД));
	КонецЕсли;
	
	Возврат НайденныеСтроки; 
	
КонецФункции

