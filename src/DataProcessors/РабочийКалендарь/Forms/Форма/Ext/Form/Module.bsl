//
Функция СформироватьБлокДолг(ВыводитьБлок = Ложь, ОбщаяИнформация)
	
	Долг =
	"<tr valign='middle'>
	|                    <td class='left_col' td align='right'>
	|                    </td>
	|                    <td class='center_col' style='vertical-align: middle;'>
