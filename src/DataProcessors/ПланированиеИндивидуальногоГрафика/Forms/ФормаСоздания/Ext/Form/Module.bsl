
&НаКлиенте
Перем РежимПланированияРабочихДнейПред; // Хранит пред. выбранный режим планирования работы.

#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик при создании формы на сервере
// 
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Сотрудник"          , Сотрудник);
	Параметры.Свойство("СтартоваяДата"      , СтартоваяДата);
	Параметры.Свойство("ПериодЗаполнения"   , ПериодЗаполнения);
	Параметры.Свойство("ИнтервалыРаботы"	, ИнтервалыРаботыОтбор);
	
	ПараметрыСозданияЭлементовФормы = Новый Структура;
	ПараметрыСозданияЭлементовФормы.Вставить("ГруппаЭлементов"           ,"ГруппаДеньВремя_");
	ПараметрыСозданияЭлементовФормы.Вставить("ПолеДня"                   ,"День_");
    ПараметрыСозданияЭлементовФормы.Вставить("ПолеВремени"               ,"Время_");
    ПараметрыСозданияЭлементовФормы.Вставить("КнопкаУдаленияЭлементов"   ,"УдалитьВремяЗаполнения_");
	
	СтруктурнаяЕдиница            	= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ВремяРаботыСтруктурнойЕдиницы 	= Новый ФиксированныйМассив(Справочники.СтруктурныеЕдиницы.РабочиеДниСтруктурнойЕдиницы(СтруктурнаяЕдиница,, Истина));
	РежимПланированияРабочихДней 	= 2;
	
	// Создаем элемент предопределенных периодов
	Если ЗначениеЗаполнено(СтартоваяДата) Тогда
		СоздатьДинамическиеЭлементыПериодовЗаполнения(,,СтартоваяДата, ИнтервалыРаботыОтбор);
	Иначе
		СоздатьДинамическиеЭлементыПериодовЗаполнения();
	КонецЕсли;
	
	// Формируем заголовко окна
	ЭтаФорма.Заголовок = "Планирование работы с " + Формат(ПериодЗаполнения.ДатаНачала, "ДФ='dd MMMM yyyy'") + " до " + Формат(ПериодЗаполнения.ДатаОкончания, "ДФ='dd MMMM yyyy'");
	// В зависимости от предопределенных данных управляем состояние элементов формы
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		Если Сотрудник.ЭтоГруппа = Ложь Тогда
			Элементы.Сотрудник.Видимость = Ложь;
		Иначе
			НовыйПараметр = Новый ПараметрВыбора("Отбор.Родитель", Сотрудник);
			НовыйМассив   = Новый Массив();
			НовыйМассив.Добавить(НовыйПараметр);
			НовыеПараметры                     = Новый ФиксированныйМассив(НовыйМассив);
			Элементы.Сотрудник.ПараметрыВыбора = НовыеПараметры;			
			Сотрудник                          = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.КомандаЕще.Доступность = НЕ РежимПланированияРабочихДней = 2;
	
КонецПроцедуры

&НаКлиенте
// Обработчик при открытии формы на клиенте
// 
Процедура ПриОткрытии(Отказ)
	
	РежимПланированияРабочихДнейПред = РежимПланированияРабочихДней;
	
КонецПроцедуры

&НаКлиенте
// Обработчик оповещения
// 
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ПриИзмененииШаблоновИнтерваловВремени" Тогда
		ОбновитьСпискиБыстрогоВыбораПолейВременныхИнтервалов();		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// При изменении режим планирования работы
// 
Процедура РежимПланированияРабочихДнейПриИзменении(Элемент)
	
	// Если таблица планирования времени была заполнена
	// необходимо ее очистить. Задаем вопрос.
	Если РежимПланированияРабочихДнейПред <> РежимПланированияРабочихДней
		И ВремяПланирования.Количество() > 1 Тогда
		
		ОписаниеО = Новый ОписаниеОповещения("РежимПланированияРабочихДнейПриИзмененииПослеОтвета",ЭтотОбъект);
		ПоказатьВопрос(ОписаниеО,"Периода планирования будут удалены. Продолжить?",РежимДиалогаВопрос.ДаНет);
	Иначе
		РежимПланированияРабочихДнейПриИзмененииПослеОтвета(КодВозвратаДиалога.Да, Неопределено);
	КонецЕсли;	
	
	ЭтаФорма.Ширина = 58;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Обработчик кнопки формирования таблицы результирующих данных и закрытия формы
// 
Процедура СоздатьЗанятия(Команда)
	
	// Проверка верности ввода данных	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда
		ПоказатьПредупреждение(,"Укажите сотрудника, для которого производится планирование!");
		Возврат;
	КонецЕсли;	
	
	Если ВремяПланирования.Количество() = 0 Тогда
		ПоказатьПредупреждение(,"Укажите временные периоды планирования рабочего времени!");
		Возврат;
	КонецЕсли;	

	ЕстьРабочееВремя = Ложь;
	Для Каждого СтрокаВП ИЗ ВремяПланирования Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаВП.Дата) Тогда
			ПоказатьПредупреждение(,"В одном из периодов не указан день планирования!");
			Возврат;	
		КонецЕсли;
		
		Если РежимПланированияРабочихДней = 0 И СтрокаВП.ИнтервалыРаботы.Количество() = 0 Тогда
			ПоказатьПредупреждение(,"В одном из периодов не указан интервал рабочего времи!");
			Возврат;	
		Иначе
			ЕстьРабочееВремя = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьРабочееВремя = Ложь Тогда
		ПоказатьПредупреждение(,"Ни в одном из периодов не указан интервал рабочего времени!");
		Возврат;	
	КонецЕсли;
	
	Если НЕ ИнтервалыАктуальныДляГрафикаРаботыСЕ() Тогда 
		Возврат;
	КонецЕсли;	

	// Режим планирования по дням недели 
	Если РежимПланированияРабочихДней = 0 Тогда	
		// Подготовить результат планирования
		ТекущийДень = ПериодЗаполнения.ДатаНачала;
		// Проход по всему периоду заполнения
		Пока ТекущийДень <= ПериодЗаполнения.ДатаОкончания Цикл
			// Выбираем только текущий по верхнему циклу день недели
			Для Каждого СтрокаВП ИЗ ВремяПланирования Цикл				
				Если ДеньНедели(СтрокаВП.Дата) = ДеньНедели(ТекущийДень) Тогда
					НоваяСтрока                       = РезультатПланирования.Добавить();
					НоваяСтрока.Дата                  = ТекущийДень; 
					НоваяСтрока.ИнтервалыРаботы       = СтрокаВП.ИнтервалыРаботы;
					НоваяСтрока.ИнтервалыРаботыПредст = СтрокаВП.ИнтервалыРаботыПредст;
					НоваяСтрока.СуммаРабочегоВремени  = СуммаИнтерваловВМинутах(СтрокаВП.ИнтервалыРаботы);
					НоваяСтрока.Сотрудник             = Сотрудник;
					Прервать;
				КонецЕсли;	
			КонецЦикла;	
			ТекущийДень = ТекущийДень + 86400;
		КонецЦикла;		
		
		// Режим циклического планирования(смены)	
	ИначеЕсли РежимПланированияРабочихДней = 1 ИЛИ РежимПланированияРабочихДней = 2 Тогда
		
		// Подготовить результат планирования
		ТекущийДень      = ВремяПланирования[0].Дата;
		ТекНомерСтрокиВП = 0;
		// Проход по планируемому периоду
		Пока ТекущийДень <= ?(РежимПланированияРабочихДней = 2, ВремяПланирования[0].Дата, ПериодЗаполнения.ДатаОкончания) Цикл
			
			// Если это рабочий день в цикле
			СтрокаВП = ВремяПланирования[ТекНомерСтрокиВП];
			Если СтрокаВП.ИнтервалыРаботы.Количество() > 0 Тогда				
				НоваяСтрока                       = РезультатПланирования.Добавить();
				НоваяСтрока.Дата                  = ТекущийДень; 
				НоваяСтрока.ИнтервалыРаботы       = СтрокаВП.ИнтервалыРаботы;
				НоваяСтрока.ИнтервалыРаботыПредст = СтрокаВП.ИнтервалыРаботыПредст;
				НоваяСтрока.СуммаРабочегоВремени  = СуммаИнтерваловВМинутах(СтрокаВП.ИнтервалыРаботы);
				НоваяСтрока.Сотрудник             = Сотрудник;
			КонецЕсли;	
			
			ТекНомерСтрокиВП = ТекНомерСтрокиВП + 1;
			// Если дошли до конечной итерации цикла
			Если ТекНомерСтрокиВП >= ВремяПланирования.Количество() Тогда
				ТекНомерСтрокиВП = 0;
			КонецЕсли;
			
			ТекущийДень = ТекущийДень + 86400;
		КонецЦикла;
		
	КонецЕсли;
		
	ЭтаФорма.Закрыть(РезультатПланирования);
	
КонецПроцедуры

&НаКлиенте
//  Добавить время нового визита
// 
Процедура КомандаЕще(Команда)	
	
	СоздатьДинамическиеЭлементыПериодовЗаполнения(,,СледующийРабочийДень(), ПоследниеВыбранныеИнтервалыВремени());	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Обработчик события, после ответа на вопрос при изменении выбора режима периода 
// 
Процедура РежимПланированияРабочихДнейПриИзмененииПослеОтвета(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ИнтервалыРаботыЗп = Неопределено;
		Если ВремяПланирования.Количество() > 0 Тогда
			ИнтервалыРаботыЗп  = ВремяПланирования[0].ИнтервалыРаботы;
			Если ИнтервалыРаботыЗп.Количество() = 0 И НЕ ИнтервалыРаботыОтбор.Количество() = 0 Тогда 
				ИнтервалыРаботыЗп = ИнтервалыРаботыОтбор;
			КонецЕсли;	
		КонецЕсли;
		// Формируем массив ИД данных для удаления
		МассивИД = Новый Массив;
		Для А = 0 По ВремяПланирования.Количество() -1 Цикл
			МассивИД.Добавить(ВремяПланирования[А].ПолучитьИдентификатор());
		КонецЦикла;	
		// Удаляем данные и дин. элементы
		УдалитьДинамическиеЭлементыПериодовЗаполнения(МассивИД);
		
		// Добавляем первую строку
		СоздатьДинамическиеЭлементыПериодовЗаполнения(,,СтартоваяДата,ИнтервалыРаботыЗп);
		
		Элементы.КомандаЕще.Доступность = НЕ РежимПланированияРабочихДней = 2;
		
		РежимПланированияРабочихДнейПред = РежимПланированияРабочихДней;
	Иначе
		РежимПланированияРабочихДней = РежимПланированияРабочихДнейПред;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - Интервалы актуальны для графика работы СЕ
// 
// Возвращаемое значение:
//   - 
// 
Функция  ИнтервалыАктуальныДляГрафикаРаботыСЕ()
	
	Флаг = Истина;
	
	Для Каждого СтрокаВП ИЗ ВремяПланирования Цикл
		Для Каждого СтрокаРабДеньСЕ Из ВремяРаботыСтруктурнойЕдиницы Цикл
			Если РежимПланированияРабочихДней = 0 Тогда 
				ДатаСравнения = СтрокаВП.Дата;
			Иначе 
				ДатаСравнения = Дата(2001, 01, ДеньНедели(СтрокаВП.Дата));
			КонецЕсли;	
			Если ДатаСравнения = СтрокаРабДеньСЕ.ДеньНедели Тогда 
				Для Каждого ЭлементИнтервал Из СтрокаВП.ИнтервалыРаботы Цикл 
					Если ЭлементИнтервал.Значение.НачалоРаботы < СтрокаРабДеньСЕ.ДатаНачала ИЛИ ЭлементИнтервал.Значение.ОкончаниеРаботы > СтрокаРабДеньСЕ.ДатаОкончания Тогда 
						Флаг = Ложь;
						ТекстСообщения = "Выбраные интервал(ы) работы не входит(ят) в интервал работы клиники организации в указаный день.";
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "ВремяПланирования[" + Строка(ВремяПланирования.Индекс(СтрокаВП)) + "].ИнтервалыРаботыПредст", "Объект");
						Возврат Флаг;
					КонецЕсли;	
				КонецЦикла;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Флаг;
	
КонецФункции

#Область МетодыРаботыСДинамическиСоздаваемымиЭлементамиФормы

&НаСервере
// Добавить элементы формы, для нового времени визита
// 
Процедура СоздатьДинамическиеЭлементыПериодовЗаполнения(ИДНовыхЭлементов = Неопределено
	                                                  , НомерСтрокиДанных = Неопределено
													  , Дата = Неопределено
													  , ИнтервалыРаботы = Неопределено)
	
	// Если это добавление элементов формы для новой строки данных
	СтрокаДанных = Неопределено;
	Если ИДНовыхЭлементов = Неопределено Тогда		
		СтрокаДанных                                    = ВремяПланирования.Добавить();
		Если ЗначениеЗаполнено(Дата) Тогда
			Если РежимПланированияРабочихДней = 0 Тогда
				СтрокаДанных.Дата                               = Дата(2001,01,ДеньНедели(Дата));
			Иначе
				СтрокаДанных.Дата                               = Дата;
			КонецЕсли;
		КонецЕсли;
		
		ИДНовыхЭлементов                                = СтрокаДанных.ПолучитьИдентификатор();
		НомерСтрокиДанных                               = ВремяПланирования.Количество() - 1;
		
		ГруппаНовыхЭл                                   = Элементы.Вставить(ПараметрыСозданияЭлементовФормы.ГруппаЭлементов + ИДНовыхЭлементов
		, Тип("ГруппаФормы")
		, Элементы.ГруппаДниЗаполнения
		, Элементы.ГруппаДниЗаполненияЕще);
		
		ГруппаНовыхЭл.Вид                               = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаНовыхЭл.Группировка                       = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаНовыхЭл.Отображение                       = ОтображениеОбычнойГруппы.Нет;
		ГруппаНовыхЭл.ОтображатьЗаголовок               = Ложь;
	Иначе
		ГруппаНовыхЭл = Элементы.Найти(ПараметрыСозданияЭлементовФормы.ГруппаЭлементов + ИДНовыхЭлементов);
	    СтрокаДанных  = ВремяПланирования.НайтиПоИдентификатору(ИДНовыхЭлементов);	
	КонецЕсли;
	
	// Режим заполнения по конкретным дням
	Если РежимПланированияРабочихДней = 1 ИЛИ РежимПланированияРабочихДней = 2 Тогда
		
		ПолеДень                           	= Элементы.Добавить(ПараметрыСозданияЭлементовФормы.ПолеДня  + ИДНовыхЭлементов, Тип("ПолеФормы"), ГруппаНовыхЭл);
		ПолеДень.Вид                       	= ВидПоляФормы.ПолеВвода;
		ПолеДень.ПоложениеЗаголовка        	= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеДень.КнопкаВыбора              	= Истина;
		ПолеДень.КнопкаОткрытия            	= Ложь;
		ПолеДень.КнопкаОчистки             	= Ложь;
		ПолеДень.КнопкаРегулирования       	= Ложь;
		ПолеДень.РедактированиеТекста      	= Ложь;		
		ПолеДень.КнопкаСпискаВыбора        	= Ложь;
		ПолеДень.АвтоОтметкаНезаполненного 	= Истина;
		ПолеДень.АвтоМаксимальнаяШирина 	= Ложь;
		ПолеДень.МаксимальнаяШирина        	= 15;
		ПолеДень.Шрифт                     	= Новый Шрифт("Arial",11);
		ПолеДень.ТолькоПросмотр            	= РежимПланированияРабочихДней = 1 И ВремяПланирования.Количество() > 1;
		ПолеДень.ПутьКДанным               	= "ВремяПланирования[" + НомерСтрокиДанных +"].ДатаПредст";
		Если РежимПланированияРабочихДней = 2 Тогда 
			ПолеДень.ТолькоПросмотр 		= Истина;
		Иначе 
			ПолеДень.ТолькоПросмотр 		= Ложь;
		КонецЕсли;	
		ПолеДень.УстановитьДействие("НачалоВыбора", "ПолеДень_НачалоВыбора");	
		
		// Заполняем представления поля периода
		Если ЗначениеЗаполнено(СтрокаДанных.Дата) Тогда
			Если ВремяПланирования.Количество() = 1 Тогда			
				СтрокаДанных.ДатаПредст = 
				ФункцииОтчетовКлиентСервер.ПредставлениеСтандартногоПериода(Новый СтандартныйПериод(СтрокаДанных.Дата,СтрокаДанных.Дата), Перечисления.ДоступныеПериодыОтчета.День);																															   	
			Иначе
				СтрокаДанных.ДатаПредст = Формат(СтрокаДанных.Дата,"ДФ='dd MMMM, dddd'"); 
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли РежимПланированияРабочихДней = 0 Тогда
		
		// Режим заполнения за период
		ПолеДень                           	= Элементы.Добавить(ПараметрыСозданияЭлементовФормы.ПолеДня  + ИДНовыхЭлементов, Тип("ПолеФормы"), ГруппаНовыхЭл);		
		ПолеДень.Вид                       	= ВидПоляФормы.ПолеВвода;
		ПолеДень.ПоложениеЗаголовка        	= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеДень.ПутьКДанным               	= "ВремяПланирования[" + НомерСтрокиДанных +"].Дата";
		ПолеДень.РежимВыбораИзСписка       	= Истина;
		ПолеДень.КнопкаВыбора              	= Ложь;
		ПолеДень.АвтоОтметкаНезаполненного 	= Истина;
		ПолеДень.АвтоМаксимальнаяШирина 	= Ложь;
		ПолеДень.МаксимальнаяШирина        	= 18;
		ПолеДень.Шрифт                     	= Новый Шрифт("Arial",11);
		ПолеДень.ТолькоПросмотр            	= РежимПланированияРабочихДней = 1 И ВремяПланирования.Количество() > 1;
		ПолеДень.СписокВыбора.Очистить();
			
		ПолеДень.УстановитьДействие("ПриИзменении","ПолеДень_ПриИзменении");
		
		Для Каждого ЭлементМ ИЗ ВремяРаботыСтруктурнойЕдиницы Цикл
			ПолеДень.СписокВыбора.Добавить(ЭлементМ.ДеньНедели, Обработки.ПланированиеИндивидуальногоГрафика.ДеньНеделиПрописью(ДеньНедели(ЭлементМ.ДеньНедели)));
		КонецЦикла;

	КонецЕсли;
	
	// Поле выбора времени
	ПолеВремя                          	= Элементы.Добавить(ПараметрыСозданияЭлементовФормы.ПолеВремени  + ИДНовыхЭлементов, Тип("ПолеФормы"), ГруппаНовыхЭл);													 
	ПолеВремя.Вид                       = ВидПоляФормы.ПолеВвода;
	ПолеВремя.ПоложениеЗаголовка        = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ПолеВремя.ПутьКДанным               = "ВремяПланирования[" + НомерСтрокиДанных +"].ИнтервалыРаботыПредст";
	ПолеВремя.ФорматРедактирования      = "ДФ=HH:mm";
	ПолеВремя.АвтоМаксимальнаяШирина 	= Ложь;
	ПолеВремя.МаксимальнаяШирина        = 37;
	ПолеВремя.КнопкаВыбора              = Истина;
	ПолеВремя.АвтоОтметкаНезаполненного = Истина;
    ПолеВремя.РедактированиеТекста      = Ложь;	
	ПолеВремя.ПодсказкаВвода            = "Интервалы рабочего времени";
	ПолеВремя.КнопкаВыпадающегоСписка   = Истина;
	ПолеВремя.Шрифт                     = Новый Шрифт("Arial",10);
	// Заполнение списка быстрого выбора закешированными данными	
	ЗакешированныеЗначения = ХранилищеСистемныхНастроек.Загрузить("КешированиеВводимыхЗначений", "ИнтервалыВремени");
	Если ЗакешированныеЗначения <> Неопределено Тогда
		Для Каждого ЭлементМ ИЗ ЗакешированныеЗначения Цикл
			Если Не ЗначениеЗаполнено(ЭлементМ) Тогда
				Продолжить;
			КОнецЕсли;
			
			ПолеВремя.СписокВыбора.Добавить(ЭлементМ, Новый ФорматированнаяСтрока(Обработки.ПланированиеИндивидуальногоГрафика.ПредставлениеИнтервалавремени(ЭлементМ), Новый Шрифт("Arial",10)));
			Если ПолеВремя.СписокВыбора.Количество() = 10 Тогда
				Прервать;
			КонецЕсли;	
			
		КонецЦикла;
	КонецЕсли;
	// Если это режим заполнения по дням недели
	Если РежимПланированияРабочихДней = 1 И ВремяПланирования.Количество() > 0 Тогда
		ВремяПланирования[НомерСтрокиДанных].ИнтервалыРаботыПредст = "Не рабочий день";
		ПолеВремя.АвтоОтметкаНезаполненного = Ложь;
	Иначе
		// Если это режим циклического заполнения
		Если ИнтервалыРаботы <> Неопределено Тогда
			СтрокаДанных.ИнтервалыРаботы                    = ИнтервалыРаботы;
			СтрокаДанных.ИнтервалыРаботыПредст              = ПредставлениеИнтервалавремени(ИнтервалыРаботы);
		КонецЕсли;
	КонецЕсли;
	
	ПолеВремя.УстановитьДействие("НачалоВыбора","ПолеВремя_НачалоВыбора");
	ПолеВремя.УстановитьДействие("ОбработкаВыбора","ПолеВремя_ОбработкаВыбора");

		
	// Кнопка удаления строки занятия	
	КнопкаУдаленияВремени                 = Элементы.Добавить(ПараметрыСозданияЭлементовФормы.КнопкаУдаленияЭлементов + ИДНовыхЭлементов
	                                                , Тип("КнопкаФормы")
													, ГруппаНовыхЭл);
	КнопкаУдаленияВремени.ИмяКоманды      = "КомандаУдалитьПериод";
	Если РежимПланированияРабочихДней = 2 Тогда 
		КнопкаУдаленияВремени.Доступность = Ложь;
	КонецЕсли;	
	КнопкаУдаленияВремени.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
    КнопкаУдаленияВремени.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;	
	
КонецПроцедуры

&НаСервере
// Удалить элементы формы связанные с удаляемым временем визита
// 
Процедура УдалитьДинамическиеЭлементыПериодовЗаполнения(ИДСтрокиУдаления)
	
	// При удалении выбранного времени проводим удаление элементов
	// формы и строки в таблице данных т.к. индексы в таблице данных
	// смещаются, необходимо переопределить путь к данным для элементов
	// следующих после удаленных. Сделать это невозможно, поэтому мы вынуждены 
	// создать их заново
	
	МассивИД = Неопределено;
	Если ТипЗнч(ИДСтрокиУдаления) = Тип("Массив") Тогда
		МассивИД = ИДСтрокиУдаления;
	Иначе
		МассивИД = Новый Массив;
		МассивИД.Добавить(ИДСтрокиУдаления);	
	КонецЕсли;	
	
	ИндексСтроки = -1;
	// Удаляем элементы и данные
	Для Каждого ИДДанных ИЗ МассивИД Цикл
		
		ГруппаЭлементов = Элементы.Найти(ПараметрыСозданияЭлементовФормы.ГруппаЭлементов + ИДДанных);
		Элементы.Удалить(ГруппаЭлементов);	
		
		// Ищем строку в данных по ИД
		СтрокаДанных = ВремяПланирования.НайтиПоИдентификатору(ИДДанных);	
		Если СтрокаДанных <> Неопределено Тогда		
			ИндексСтроки = ВремяПланирования.Индекс(СтрокаДанных);
			ВремяПланирования.Удалить(СтрокаДанных);			
		КонецЕсли;
	КонецЦикла;
	
	// Если удаленные данные находилист не вконце таблица
	// необходимо сместить все динамические элементы вверх
	Если ИндексСтроки < ВремяПланирования.Количество() Тогда
		
		// Удаляем нижележащие элементы
		Для А = ИндексСтроки По ВремяПланирования.Количество() - 1 Цикл
			
			ИДЭлементов  = ВремяПланирования[А].ПолучитьИдентификатор();
			
			ПолеФормы = Элементы.Найти(ПараметрыСозданияЭлементовФормы.ПолеДня  + ИДЭлементов);			  
			Элементы.Удалить(ПолеФормы);
			
			ПолеФормы = Элементы.Найти(ПараметрыСозданияЭлементовФормы.ПолеВремени + ИДЭлементов);			  
			Элементы.Удалить(ПолеФормы);
			
			КнопкаФормы = Элементы.Найти(ПараметрыСозданияЭлементовФормы.КнопкаУдаленияЭлементов  + ИДЭлементов);			  
			Элементы.Удалить(КнопкаФормы);		   
		КонецЦикла;
		
		// Создаем элементы взамен удаленных на пред. этапе	  
		Для А = ИндексСтроки По ВремяПланирования.Количество() - 1 Цикл				
			
			ИДЭлементов = ВремяПланирования[А].ПолучитьИдентификатор();								
			СоздатьДинамическиеЭлементыПериодовЗаполнения(ИДЭлементов, А);				
		КонецЦикла;	   
	КонецЕсли;	   
	
КонецПроцедуры

&НаСервере
// Перезагрузить кешь шаблонов интервалов времени
// 
Процедура ОбновитьСпискиБыстрогоВыбораПолейВременныхИнтервалов()
	
	// Заполнение списка быстрого выбора закешированными данными
	ЗакешированныеЗначения = ХранилищеСистемныхНастроек.Загрузить("КешированиеВводимыхЗначений", "ИнтервалыВремени");
	Если ЗакешированныеЗначения <> Неопределено Тогда
		Для Каждого СтрокаТ ИЗ ВремяПланирования Цикл
			ПолеВвода = Элементы.Найти(ПараметрыСозданияЭлементовФормы.ПолеВремени  + СтрокаТ.ПолучитьИдентификатор());
			Если ПолеВвода <> Неопределено Тогда
				ПолеВвода.СписокВыбора.Очистить();
				Для Каждого ЭлементМ ИЗ ЗакешированныеЗначения Цикл
					Если ЭлементМ = неопределено Тогда
						Продолжить;
					КонецЕсли;
					ПолеВвода.СписокВыбора.Добавить(ЭлементМ, Обработки.ПланированиеИндивидуальногоГрафика.ПредставлениеИнтервалавремени(ЭлементМ));
					Если ПолеВвода.СписокВыбора.Количество() = 10 Тогда
						Прервать;
					КонецЕсли;	
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
КонецПроцедуры

