#Область СлужебныйПрограммныйИнтерфейс	
	
// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаТаблицаРабочееВремяСотрудников(Документ, СтруктураДополнительныеСвойства)
	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаРабочееВремяСотрудников.СтруктурнаяЕдиница,
	|	ТаблицаРабочееВремяСотрудников.Сотрудник,
	|	ТаблицаРабочееВремяСотрудников.Врач,
	|	ТаблицаРабочееВремяСотрудников.Период,
	|	ТаблицаРабочееВремяСотрудников.Дней,
	|	ТаблицаРабочееВремяСотрудников.Часов
	|ИЗ
	|	ВременнаяТаблицаРабочееВремяСотрудников КАК ТаблицаРабочееВремяСотрудников";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРабочееВремяСотрудников", РезультатЗапроса.Выгрузить());	
	
КонецПроцедуры

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(Документ, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ТабельУчетаРабочегоВремени.Ссылка.СтруктурнаяЕдиница,
				   |	ТабельУчетаРабочегоВремени.Ссылка.ВидОперации КАК ВидОперации,
	               |	ТабельУчетаРабочегоВремени.Сотрудник,
	               |	ТабельУчетаРабочегоВремени.Ссылка.Ассистент КАК Ассистент,
	               |	ТабельУчетаРабочегоВремени.Ссылка.Период КАК Период,
	               |	ТабельУчетаРабочегоВремени.День1,
	               |	ТабельУчетаРабочегоВремени.День2,
	               |	ТабельУчетаРабочегоВремени.День3,
	               |	ТабельУчетаРабочегоВремени.День4,
	               |	ТабельУчетаРабочегоВремени.День5,
	               |	ТабельУчетаРабочегоВремени.День6,
	               |	ТабельУчетаРабочегоВремени.День7,
	               |	ТабельУчетаРабочегоВремени.День8,
	               |	ТабельУчетаРабочегоВремени.День9,
	               |	ТабельУчетаРабочегоВремени.День10,
	               |	ТабельУчетаРабочегоВремени.День11,
	               |	ТабельУчетаРабочегоВремени.День12,
	               |	ТабельУчетаРабочегоВремени.День13,
	               |	ТабельУчетаРабочегоВремени.День14,
	               |	ТабельУчетаРабочегоВремени.День15,
	               |	ТабельУчетаРабочегоВремени.День16,
	               |	ТабельУчетаРабочегоВремени.День17,
	               |	ТабельУчетаРабочегоВремени.День18,
	               |	ТабельУчетаРабочегоВремени.День19,
	               |	ТабельУчетаРабочегоВремени.День20,
	               |	ТабельУчетаРабочегоВремени.День21,
	               |	ТабельУчетаРабочегоВремени.День22,
	               |	ТабельУчетаРабочегоВремени.День23,
	               |	ТабельУчетаРабочегоВремени.День24,
	               |	ТабельУчетаРабочегоВремени.День25,
	               |	ТабельУчетаРабочегоВремени.День26,
	               |	ТабельУчетаРабочегоВремени.День27,
	               |	ТабельУчетаРабочегоВремени.День28,
	               |	ТабельУчетаРабочегоВремени.День29,
	               |	ТабельУчетаРабочегоВремени.День30,
	               |	ТабельУчетаРабочегоВремени.День31
	               |ИЗ
	               |	Документ.ТабельУчетаРабочегоВремени.ДниРаботы КАК ТабельУчетаРабочегоВремени
	               |ГДЕ
	               |	ТабельУчетаРабочегоВремени.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Документ.Ссылка);
	ТаблицаДокументаТабеля = Запрос.Выполнить().Выгрузить();
	
	ТаблицаТабеля = РегистрыНакопления.РабочееВремяСотрудников.СоздатьНаборЗаписей().ВыгрузитьКолонки();
	Для Каждого СтрокаТЧ Из ТаблицаДокументаТабеля Цикл
		Для а = 1 По 31 Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ["День" + а]) Тогда
				НоваяСтрока = ТаблицаТабеля.Добавить();
				НоваяСтрока.СтруктурнаяЕдиница = СтрокаТЧ.СтруктурнаяЕдиница;		
				Если СтрокаТЧ.ВидОперации = 0 Тогда
					НоваяСтрока.Сотрудник = СтрокаТЧ.Сотрудник;
				Иначе
					НоваяСтрока.Сотрудник = СтрокаТЧ.Ассистент;
					НоваяСтрока.Врач 	  = СтрокаТЧ.Сотрудник;					
				КонецЕсли;
				НоваяСтрока.Период 	  = НачалоМесяца(СтрокаТЧ.Период) + (а - 1) * 24 * 60 * 60;
				НоваяСтрока.Дней 	  = 1;
				НоваяСтрока.Часов     = СтрокаТЧ["День" + а];
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Запрос.Текст = "ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	               |	ТабельУчетаРабочегоВремени.СтруктурнаяЕдиница,
	               |	ТабельУчетаРабочегоВремени.Сотрудник,
				   |	ТабельУчетаРабочегоВремени.Врач,
	               |	ТабельУчетаРабочегоВремени.Период,
	               |	ТабельУчетаРабочегоВремени.Дней,
	               |	ТабельУчетаРабочегоВремени.Часов
	               |ПОМЕСТИТЬ ВременнаяТаблицаРабочееВремяСотрудников
	               |ИЗ
	               |	&ТаблицаТабеля КАК ТабельУчетаРабочегоВремени";
	Запрос.УстановитьПараметр("ТаблицаТабеля", ТаблицаТабеля);
	Запрос.ВыполнитьПакет();
	
	СформироватьТаблицаТаблицаРабочееВремяСотрудников(Документ, СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Функция получает проведенный документ Табеля, по ключевым параметрам:
//
// Параметры:
// 		Параметры        - Структура параметров, СтруктурнаяЕдиница, Период
// 		Ссылка           - ДокументСсылка, ссылка на существующий документ
// 
// Возвращаемое значение:
// 		Ссылка на найденный документ
//
Функция ВозвратитьДокументПоРеквизитам(Параметры, Ссылка) Экспорт
	       
	// Проверяем есть ли документ с таким месяцем
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТабельУчетаРабочегоВремени.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ТабельУчетаРабочегоВремени КАК ТабельУчетаРабочегоВремени
		|ГДЕ
		|	ТабельУчетаРабочегоВремени.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ТабельУчетаРабочегоВремени.Период = &Период
		|	И ТабельУчетаРабочегоВремени.Проведен = ИСТИНА
		|	И ТабельУчетаРабочегоВремени.Ссылка <> &Ссылка";
		
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Параметры.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Период", Параметры.Период);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	РезультатТаблица = Запрос.Выполнить().Выгрузить();
								
	Если РезультатТаблица.Количество() > 0 Тогда
		Возврат РезультатТаблица[0].Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

