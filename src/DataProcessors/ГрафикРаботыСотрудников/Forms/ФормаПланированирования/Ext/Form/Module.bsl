	КонецЕсли;     	
	
	Сотрудник = СтруктураДанныхОбласти.Сотрудник;
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда
		Возврат;
	КонецЕсли;  
	
	МассивИзмененныхДней = Новый Массив;
	
	НомерДняНеделиДляУдаления = ДеньНедели(СтартоваяДата);
	НомерОперации             = НомерПоследнейОперацииВОчередиБуфера() + 1;
	Индекс                    = 0;
	
	БуферФормированияСотрудника = БуферФормирования.НайтиСтроки(Новый Структура("Сотрудник", Сотрудник));
	
	Пока Индекс < БуферФормированияСотрудника.Количество() Цикл
		СтрокаБуфера = БуферФормированияСотрудника[Индекс]; 
		
		Если ДеньНедели(СтрокаБуфера.Дата) = НомерДняНеделиДляУдаления Тогда 
			
			Если СтрокаБуфера.Операция = "Создать" Тогда
				МассивИзмененныхДней.Добавить(СтрокаБуфера.Дата);
				БуферФормирования.Удалить(СтрокаБуфера);
				Индекс = Индекс + 1;
				Продолжить;
			Иначе
				Данные = ПроверитьНаличиеПриема(СтрокаБуфера.Сотрудник, СтрокаБуфера.Дата, СтрокаБуфера.ИнтервалыРаботы, ОтборСтруктурнаяЕдиница);
				Если НЕ ЗначениеЗаполнено(Данные) Тогда
					МассивИзмененныхДней.Добавить(СтрокаБуфера.Дата);
					СтрокаБуфера.Операция              = "Удалить";
					СтрокаБуфера.НомерОчередиОперации  = НомерОперации;    						
				Иначе
					Интервал = Формат(СтрокаБуфера.Дата, "ДЛФ=DD") + " с " + Формат(Данные.НачалоРаботы, "ДФ=HH:мм") + " по " + Формат(Данные.ОкончаниеРаботы, "ДФ=HH:мм");
					Текст = "В интервале " + Интервал + " созданы приемы. Удаление интервала невозможно.";
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
				КонецЕсли;
			КонецЕсли;		
		КонецЕсли;
		Индекс = Индекс + 1;
	КонецЦикла;
	
	ОбновитьОтображениеПланирования(Ложь, Сотрудник, МассивИзмененныхДней);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка команды "Удалить все" табличного документа
//  удалаяет все расписание по сотруднику
//      
Процедура КомандаГрафикПериодовРаботыТабДокУдалитьВсе(Команда)
		
	ИмяОбласти = Элементы.ГрафикПериодовРаботыТабДок.ТекущаяОбласть.Имя; 
	СтруктураДанныхОбласти = ПолучитьДанныеВыделеннойОбластиГрафикПериодовРаботыТабДок (ИмяОбласти);
	
	СтартоваяДата = СтруктураДанныхОбласти.ВыбПериод;
	Если Не ЗначениеЗаполнено(СтартоваяДата) Тогда
		Возврат;
	КонецЕсли;     	
	
	Сотрудник = СтруктураДанныхОбласти.Сотрудник;
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда
		Возврат;
	КонецЕсли;  
	
	СтрокаБуфераОбразец = СтрокаБуфераФомированияПоСотрудникуДате(Сотрудник, СтартоваяДата);
	
	НомерОперации             = НомерПоследнейОперацииВОчередиБуфера() + 1;
	Индекс                    = 0;
	Пока Индекс < БуферФормирования.Количество() Цикл
		СтрокаБуфера = БуферФормирования[Индекс]; 
		// очищаем расписание по выбранному сотруднику
		Если СтрокаБуфера.Сотрудник = Сотрудник Тогда
			Если СтрокаБуфера.Операция = "Создать" Тогда
				БуферФормирования.Удалить(СтрокаБуфера);
				Продолжить;
			Иначе
				Данные = ПроверитьНаличиеПриема(СтрокаБуфера.Сотрудник, СтрокаБуфера.Дата, СтрокаБуфера.ИнтервалыРаботы, ОтборСтруктурнаяЕдиница);
				Если НЕ ЗначениеЗаполнено(Данные) Тогда
					СтрокаБуфера.Операция              = "Удалить";
					СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
				Иначе
					Интервал = Формат(СтрокаБуфера.Дата, "ДЛФ=DD") + " с " + Формат(Данные.НачалоРаботы, "ДФ=HH:мм") + " по " + Формат(Данные.ОкончаниеРаботы, "ДФ=HH:мм");
					Текст = "В интервале " + Интервал + " созданы приемы. Удаление интервала невозможно.";
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
				КонецЕсли;
			КонецЕсли;		
		КонецЕсли;
		Индекс = Индекс + 1;
	КонецЦикла; 
	
	ОбновитьОтображениеПланирования(Ложь, Сотрудник);
	
КонецПроцедуры  

#КонецОбласти

#КонецОбласти

