// Процедура, заполняет даты начала и окончания события.
//
Процедура ЗаполнитьВременныеРамкиСобытия()
	
	Если ЭтотОбъект.Услуги.Количество() Тогда
		
		Начало		 = ЭтотОбъект.Услуги[0].ДатаНачала;
		Окончание	 = ЭтотОбъект.Услуги[0].ДатаОкончания;
		
		Для Каждого Услуга Из ЭтотОбъект.Услуги Цикл
			Начало		 = ?(Начало > Услуга.ДатаНачала, Услуга.ДатаНачала, Начало);
			Окончание	 = ?(Окончание < Услуга.ДатаОкончания, Услуга.ДатаОкончания, Окончание);
		КонецЦикла;
		
		ЭтотОбъект.Дата			 = Начало;
		ЭтотОбъект.ДатаОкончания = Окончание;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Сформировать массив сотрудников для формирования интервалов
//
Процедура СформироватьМассивСотрудниковДляФормированияИнтервалов()
	
	МассивСотрудников = Новый Массив;
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.Услуги Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник)
			И МассивСотрудников.Найти(СтрокаТЧ.Сотрудник) = Неопределено Тогда
			МассивСотрудников.Добавить(СтрокаТЧ.Сотрудник);
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник) И (НЕ ЗначениеЗаполнено(ЭтотОбъект.Врач) ИЛИ ЭтотОбъект.Врач <> СтрокаТЧ.Сотрудник) Тогда
			Врач = СтрокаТЧ.Сотрудник;
		КонецЕсли;	
	КонецЦикла;
	
	Для Каждого СтрокаТЧ Из ЭтотОбъект.Ссылка.Услуги Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Сотрудник)
			И МассивСотрудников.Найти(СтрокаТЧ.Сотрудник) = Неопределено Тогда
			МассивСотрудников.Добавить(СтрокаТЧ.Сотрудник);
		КонецЕсли;
	КонецЦикла;
	
	ЭтотОбъект.ДополнительныеСвойства.Вставить("СотрудникиДляФормированияИнтервалов", МассивСотрудников);
	
КонецПроцедуры	

// Процедура - Сформировать интервалы по сотрудникам
//
Процедура СформироватьИнтервалыПоСотрудникам()
	
	Если НачалоДня(ЭтотОбъект.Дата) >= НачалоДня(ТекущаяДатаСеанса())
		И ЭтотОбъект.ДополнительныеСвойства.Свойство("СотрудникиДляФормированияИнтервалов")
		И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.СотрудникиДляФормированияИнтервалов) Тогда
		
		МассивСотрудников = ЭтотОбъект.ДополнительныеСвойства.СотрудникиДляФормированияИнтервалов;
		РегистрыСведений.СвободныеИнтервалыСотрудников.СформироватьИнтервалыПоСотрудникам(
			СтруктурнаяЕдиница, МассивСотрудников, НачалоДня(ЭтотОбъект.Дата), КонецДня(ЭтотОбъект.Дата));
			
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Инициализировать комментарий
//
Процедура ИнициализироватьКомментарий()

	Если НЕ ЭтотОбъект.Ссылка.Пустая() ИЛИ НЕ ЗначениеЗаполнено(ЭтотОбъект.Сделка) ИЛИ ЗначениеЗаполнено(СокрЛП(ЭтотОбъект.Комментарий)) Тогда
		Возврат;
	КонецЕсли;
	
	//ЭтотОбъект.Комментарий = СокрЛП(ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭтотОбъект.Сделка, "Описание"));	
	
КонецПроцедуры

// Процедура - Поместить ссылку новой сделки
//
Процедура ПоместитьСсылкуНовойСделки()
	
	Если НЕ ЭтотОбъект.Ссылка.Пустая() ИЛИ ЗначениеЗаполнено(Сделка) Тогда
		Возврат;
	КонецЕсли;	
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ВидСделкиГенерации") И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.ВидСделкиГенерации) Тогда
		Если НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("СсылкаНовойСделки") Тогда
			СсылкаНовойСделки = Справочники.Сделки.ПолучитьСсылку(Новый УникальныйИдентификатор);
			ЭтотОбъект.ДополнительныеСвойства.Вставить("СсылкаНовойСделки", СсылкаНовойСделки);
			ЭтотОбъект.Сделка = СсылкаНовойСделки;				
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

// Процедура - Актуализировать данные планирования приема
//
Процедура АктуализироватьДанныеПланированияПриема()

	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Сделка) ИЛИ НЕ ОбщегоНазначения.СсылкаСуществует(ЭтотОбъект.Сделка) Тогда 
		Возврат;
	КонецЕсли;
	
	ДанныеПередЗаписью = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ДанныеПередЗаписью", Неопределено);
	Если ЗначениеЗаполнено(ДанныеПередЗаписью) И ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеПередЗаписью, "ЭтоНовый") Тогда 
		РегистрыСведений.Профосмотры.АктуализироватьСтатусПланированияПриема(ЭтотОбъект.СтруктурнаяЕдиница
																			, ЭтотОбъект.Контрагент
																			, ЭтотОбъект.Сделка
																			, ЭтотОбъект.Ссылка
																			, Перечисления.СтатусыПрофосмотров.Согласился);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Создать новую сделку
//
Процедура СоздатьНовуюВоронку()
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ВидСделкиГенерации") И ЗначениеЗаполнено(ЭтотОбъект.ДополнительныеСвойства.ВидСделкиГенерации) И ЭтотОбъект.ДополнительныеСвойства.Свойство("СсылкаНовойСделки") Тогда
		ДанныеЗаполнения = ЗначениеИзСтрокиВнутр(ЗначениеВСтрокуВнутр(ЭтотОбъект.ДополнительныеСвойства));
		ДанныеЗаполнения.Вставить("ВидСделки"				, ДанныеЗаполнения.ВидСделкиГенерации);
		// ДанныеЗаполнения.Вставить("ДатаСделки"			, ЭтотОбъект.Дата);
		ДанныеЗаполнения.Вставить("Контрагент"				, ЭтотОбъект.Контрагент);
		ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"		, ЭтотОбъект.СтруктурнаяЕдиница);
		ДанныеЗаполнения.Вставить("ЭтапСделки"				, ДанныеЗаполнения.ЭтапСделкиГенерации);
		Если НЕ ЭтотОбъект.Услуги.Количество() = 0 Тогда 
			ДанныеЗаполнения.Вставить("Врач"				, ЭтотОбъект.Услуги[0].Сотрудник);
		КонецЕсли;
		ДанныеЗаполнения.Вставить("ИнтерактивнаяЗапись"		, Истина);
		ДанныеЗаполнения.Вставить("СформироватьНаименование", Истина);		
		Если ЗначениеЗаполнено(ВходящийНомерТелефона) Тогда
			ДанныеЗаполнения.Вставить("ВходящийНомерТелефона", ЭтотОбъект.ВходящийНомерТелефона)	
		КонецЕсли;
		НоваяСделка = Справочники.Сделки.СоздатьНовуюСделку(ДанныеЗаполнения, Истина);
	КонецЕсли;

КонецПроцедуры

// Процедура - Сменить этап предопределенной сделки
//
Процедура СменитьЭтапПредопределеннойВоронки()
	
	Если (ЭтотОбъект.Проведен ИЛИ УстановкаПометкиУдаленияЗаписи()) И ЗначениеЗаполнено(ЭтотОбъект.Сделка) Тогда 
		ДанныеСделки = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(ЭтотОбъект.Сделка, "СтруктурнаяЕдиница, ВидСделки, ЭтапСделки, РезультатСделки");
		Если НЕ ЗначениеЗаполнено(ДанныеСделки.РезультатСделки) И ЗначениеЗаполнено(ДанныеСделки.ВидСделки) И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДанныеСделки.ВидСделки, "Предопределенный") = Истина Тогда 
			СтатусПЗ = Неопределено;
			АктуальныйЭтап = Справочники.Сделки.ПолучитьАктуальныйЭтапВоронки(ЭтотОбъект.Сделка, ДанныеСделки.ВидСделки, ЭтотОбъект.Контрагент, СтатусПЗ);
			Если ЗначениеЗаполнено(АктуальныйЭтап) И НЕ ДанныеСделки.ЭтапСделки = АктуальныйЭтап Тогда 
				Справочники.Сделки.УстановитьЭтапСделке(ЭтотОбъект.Сделка
														, АктуальныйЭтап
														, Истина
														, ?(ЗначениеЗаполнено(ЭтотОбъект.Врач), ЭтотОбъект.Врач, ?(ЭтотОбъект.Услуги.Количество() = 0, ЭтотОбъект.Врач, ЭтотОбъект.Услуги[0].Сотрудник))
														, СтатусПЗ
														, ?(ЭтотОбъект.ПометкаУдаления ИЛИ НЕ ЭтотОбъект.Проведен, НСтр("ru= 'Ошибка';en= 'Mistake'"), Неопределено)
														,
														, ?(ЭтотОбъект.СтруктурнаяЕдиница <> ДанныеСделки.СтруктурнаяЕдиница, ЭтотОбъект.СтруктурнаяЕдиница, Неопределено));
				// Строчка выше - актуализация этапа - всегда актуализирует и врача в сделке
				// Потому ниже это делать уже не надо - флаг удаляем
				Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ИзмененВрачПриема") Тогда 
					ЭтотОбъект.ДополнительныеСвойства.Удалить("ИзмененВрачПриема");
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Установка пометки удаления записи
// 
// Возвращаемое значение:
//   - 
//
Функция УстановкаПометкиУдаленияЗаписи()

	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ДанныеПередЗаписью") Тогда 
		Если НЕ ЭтотОбъект.ПометкаУдаления = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства.ДанныеПередЗаписью, "ПометкаУдаления", Ложь) Тогда 
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Процедура - Актуализировать врача сделки
//
Процедура АктуализироватьВрачаСделки()

	Если ЗначениеЗаполнено(ЭтотОбъект.Сделка) И ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ЭтотОбъект.ДополнительныеСвойства, "ИзмененВрачПриема", Ложь) Тогда 
		Справочники.Сделки.СменитьВрачаВСделке(ЭтотОбъект.Сделка, ?(ЗначениеЗаполнено(ЭтотОбъект.Врач), ЭтотОбъект.Врач, ?(ЭтотОбъект.Услуги.Количество() = 0, ЭтотОбъект.Врач, ЭтотОбъект.Услуги[0].Сотрудник)), Истина);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Добавить сообщение в систему взаимодействия
//
Процедура ДобавитьСообщениеВСистемуВзаимодействия()
		
	Параметры = Новый Структура();
	Параметры.Вставить("Событие"				, ЭтотОбъект.Ссылка);
	Параметры.Вставить("ДополнительныеСвойства"	, Общегоназначения.СкопироватьРекурсивно(ЭтотОбъект.ДополнительныеСвойства));
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ЭтоНовый") 
		И ЭтотОбъект.ДополнительныеСвойства.ЭтоНовый = Истина Тогда
	 	
		Результат = ДлительныеОперации.ЗапуститьВыполнениеВФоне(, "Документы.Событие.ДобавитьСообщениеВСистемуВзаимодействия", Параметры);
	Иначе
		Документы.Событие.ДобавитьСообщениеВСистемуВзаимодействия(Параметры);
	КонецЕсли;	
	
КонецПроцедуры 

// Процедура - Инициализировать дополнительные свойства объекта
//
Процедура ИнициализироватьДополнительныеСвойстваОбъекта()
	
	Если НЕ ЭтотОбъект.Ссылка.Пустая() Тогда
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ИзмененСтатусЗаписи", ЭтотОбъект.Статус <> ЭтотОбъект.Ссылка.Статус И ЗначениеЗаполнено(ЭтотОбъект.Статус));
		Если ЭтотОбъект.Ссылка.Статус = Перечисления.СтатусыСобытия.НеПодтверждена
			И ЭтотОбъект.Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда
			ЭтотОбъект.ДополнительныеСвойства.Вставить("ПроизвестиИнформированиеКлиентаПодтверждениеОнЛайнЗаписи", Истина);
		КонецЕсли; 
		
		Если ЭтотОбъект.ДополнительныеСвойства.ИзмененСтатусЗаписи Тогда 
			
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Устанвоить статусы пациента в документе
Процедура УстановитьПризнакСтатусаПациента()
		
	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Пациент КАК Пациент,
	|	СУММА(ЕСТЬNULL(ВложенныйЗапрос.РанееБылиПриемы, 0)) КАК РанееБылиПриемы
	|ИЗ
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|		Продажи.Контрагент КАК Пациент,
	|		1 КАК РанееБылиПриемы
	|	ИЗ
	|		РегистрНакопления.Продажи КАК Продажи
	|	ГДЕ
	|		Продажи.Контрагент = &Контрагент
	|		И Продажи.Период < &Дата
	|		И Продажи.Регистратор ССЫЛКА Документ.Прием) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Пациент";
	
	Запрос.УстановитьПараметр("Контрагент"        , ЭтотОбъект.Контрагент);
	Запрос.УстановитьПараметр("Дата"              , ?(НЕ ЗначениеЗаполнено(ЭтотОбъект.Дата) Или НачалоДня(ЭтотОбъект.Дата) = НачалоДня(ТекущаяДата()), ТекущаяДата(), ЭтотОбъект.Дата)); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Если Выборка.РанееБылиПриемы = 1 Тогда
			ЭтотОбъект.СтатусПациента = Перечисления.СтатусыКонтрагентов.Постоянный;
		Иначе
			ЭтотОбъект.СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный;
		КонецЕсли;
						
	Иначе
		ЭтотОбъект.СтатусПациента = Перечисления.СтатусыКонтрагентов.Первичный;		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Подготовить проверить данные для отправки push уведомлений
//
Процедура ПодготовитьПроверитьДанныеДляОтправкиPushУведомлений()
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("НеОтправлятьПушУведомление") Тогда
		Возврат;
	КонецЕсли;
	
	НастройкиМобильногоПриложенияСтоматологии = Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();
	
	Если НастройкиМобильногоПриложенияСтоматологии = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УведомлятьВрачаОбИзмененииПриемов = НастройкиМобильногоПриложенияСтоматологии.Свойство("УведомлятьВрачаОбИзмененииПриемов") И НастройкиМобильногоПриложенияСтоматологии.УведомлятьВрачаОбИзмененииПриемов;
	
	Если НЕ УведомлятьВрачаОбИзмененииПриемов Тогда
		Возврат;
	КонецЕсли;
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.МобильноеПриложениеУправляющего, Истина);
	
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
		Возврат;
	КонецЕсли;
		
	МассивСотрудников = Новый Массив;
	МассивКлючейСотрудников = Новый Массив;
	МассивВыгруженныхСотрудников = ЭтотОбъект.Услуги.ВыгрузитьКолонку("Сотрудник");		
	МассивВыгруженныхСотрудниковДоИзменения = Ссылка.Услуги.ВыгрузитьКолонку("Сотрудник");	
	
	Для Каждого СтрокаМ Из МассивВыгруженныхСотрудников Цикл
		
		Если ЗначениеЗаполнено(СтрокаМ) И МассивСотрудников.Найти(СтрокаМ) = Неопределено И РегистрыСведений.КлючиВнешнихСистем.СотрудникЗарегистрированДляВнешнейСистемы(СтрокаМ, Истина, ВнешняяСистема) Тогда
			МассивСотрудников.Добавить(СтрокаМ);
			МассивКлючейСотрудников.Добавить(РегистрыСведений.КлючиВнешнихСистем.ПолучитьПараметрыСотрудника(ВнешняяСистема, СтрокаМ).КлючКлиента);
		КонецЕсли;
		
	КонецЦикла;
	
	СтатусИзменился			 = ЭтотОбъект.Статус <> Ссылка.Статус;
	СтатусИзменилсяНаОтменен = СтатусИзменился И ЭтотОбъект.Статус = Перечисления.СтатусыСобытия.ПриемОтменен; 
	СтатусИзменилсяНаПришел  = СтатусИзменился И ЭтотОбъект.Статус = Перечисления.СтатусыСобытия.ПриемНачат;
	
	Если СтатусИзменилсяНаОтменен Тогда
		ЭтотОбъект.ДополнительныеСвойства.Вставить("ЭтоОтмененный", Истина);
	ИначеЕсли СтатусИзменилсяНаПришел Тогда
		ЭтотОбъект.ДополнительныеСвойства.Вставить("СтатусКлиентПришел", Истина);
	Иначе
		
		Если Дата <> Дата(1,1,1) И Ссылка.Дата <> Дата Тогда
			ДополнительныеСвойства.Вставить("ЗаписьПеренесенаС" , Ссылка.Дата);
			ДополнительныеСвойства.Вставить("ЗаписьПеренесенаНа", Дата);
		КонецЕсли;
		
		ЗаписьПеренесенаССотрудников  = Новый Массив;
		ЗаписьПеренесенаНаСотрудников = Новый Массив;
		
		Для Каждого СтрокаМ Из МассивВыгруженныхСотрудниковДоИзменения Цикл
			
			Если МассивВыгруженныхСотрудников.Найти(СтрокаМ) = Неопределено И РегистрыСведений.КлючиВнешнихСистем.СотрудникЗарегистрированДляВнешнейСистемы(СтрокаМ, Истина, ВнешняяСистема) Тогда
				
				КлючСотрудника = РегистрыСведений.КлючиВнешнихСистем.ПолучитьПараметрыСотрудника(ВнешняяСистема, СтрокаМ).КлючКлиента;  
				Если МассивКлючейСотрудников.Найти(КлючСотрудника) = Неопределено Тогда 
					МассивКлючейСотрудников.Добавить(КлючСотрудника);
				КонецЕсли;
				Если ЗаписьПеренесенаССотрудников.Найти(КлючСотрудника) = Неопределено Тогда
					ЗаписьПеренесенаССотрудников.Добавить(КлючСотрудника);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаМ Из МассивВыгруженныхСотрудников Цикл
			
			Если МассивВыгруженныхСотрудниковДоИзменения.Найти(СтрокаМ) = Неопределено И РегистрыСведений.КлючиВнешнихСистем.СотрудникЗарегистрированДляВнешнейСистемы(СтрокаМ, Истина, ВнешняяСистема) Тогда
				
				КлючСотрудника = РегистрыСведений.КлючиВнешнихСистем.ПолучитьПараметрыСотрудника(ВнешняяСистема, СтрокаМ).КлючКлиента;  
				Если МассивКлючейСотрудников.Найти(КлючСотрудника) = Неопределено Тогда 
					МассивКлючейСотрудников.Добавить(КлючСотрудника);
				КонецЕсли;
				Если ЗаписьПеренесенаНаСотрудников.Найти(КлючСотрудника) = Неопределено Тогда
					ЗаписьПеренесенаНаСотрудников.Добавить(КлючСотрудника);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЗаписьПеренесенаССотрудников) ИЛИ ЗначениеЗаполнено(ЗаписьПеренесенаНаСотрудников) Тогда
			ДополнительныеСвойства.Вставить("ЗаписьПеренесенаССотрудников" , ЗаписьПеренесенаССотрудников);		
			ДополнительныеСвойства.Вставить("ЗаписьПеренесенаНаСотрудников", ЗаписьПеренесенаНаСотрудников);
			ДополнительныеСвойства.Вставить("ЭтоИзменениеСотрудников"	   , Истина);
		КонецЕсли;
		
	КонецЕсли;
	
	Если МассивКлючейСотрудников.Количество() > 0 Тогда 
		ЭтотОбъект.ДополнительныеСвойства.Вставить("МассивКлючейСотрудников", МассивКлючейСотрудников);
		ЭтотОбъект.ДополнительныеСвойства.Вставить("КлючПриложения"	        , ВнешняяСистема.КлючПриложения);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обработать отправку push уведомлений
//
Процедура ОбработатьОтправкуPushУведомлений()
	
	УстановитьПривилегированныйРежим(Истина);	
	ДанныеАнкеты = ЛичныйКабинет.ПолучитьДанныеРегистрационнойАнкеты();	
	УстановитьПривилегированныйРежим(Ложь);
		
	Если НЕ ЗначениеЗаполнено(ДанныеАнкеты) 
		ИЛИ НЕ ДанныеАнкеты.Свойство("ПродуктРегистрационныйНомер") 
		ИЛИ НЕ ЗначениеЗаполнено(ДанныеАнкеты.ПродуктРегистрационныйНомер) 
		ИЛИ НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("МассивКлючейСотрудников") 
		ИЛИ НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ЭтоОтмененный") 
		И НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ЗаписьПеренесенаС")
		И НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ЭтоИзменениеСотрудников") 
		И НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("СтатусКлиентПришел") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	СтруктураPushУведомления = Новый Структура();
	
	СтруктураPushУведомления.Вставить("УидВизита"              		 , Строка(ЭтотОбъект.Ссылка.УникальныйИдентификатор()));
	СтруктураPushУведомления.Вставить("УидСалона"              		 , Строка(ЭтотОбъект.СтруктурнаяЕдиница.УникальныйИдентификатор()));
	СтруктураPushУведомления.Вставить("НачалоВизита"           		 , ЭтотОбъект.Дата);
