// При изменении контрагента, сервер
//
Процедура КонтрагентПриИзмененииСервер()
	
	Если ТекущийКонтрагент <> Объект.Контрагент Тогда
		Объект.БанковскийСчетКонтрагента    = Неопределено;
		// Объект.ЛицевойСчетКонтрагента       = Неопределено;
		Объект.ЭквайрингВидПлатежнойКарты   = Неопределено;
		Объект.ЭквайрингНомерПлатежнойКарты = Неопределено;
		Объект.Сертификат                   = Неопределено;
		Объект.СертификатСерийныйНомер      = Неопределено;
		// Объект.СуммаДокумента               = 0;
		// Объект.РасшифровкаПлатежа.Очистить();
		// Установка банковского счета контрагента по умолчанию(при указанных условиях)
		Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		   И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета
		   И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты 
		   И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВыдачаПодотчетнику
		   И ЗначениеЗаполнено(Объект.Контрагент) Тогда	
			Объект.БанковскийСчетКонтрагента = Объект.Контрагент.БанковскийСчетПоУмолчанию;
		КонецЕсли;  
		ОбновитьИнформациюПоОстаткамЛСиЗадолженностям();
		Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Контрагент) 
			И ?(ТипЗнч(Объект.Контрагент) = Тип("СправочникСсылка.Контрагенты") 
			И Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Ложь, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

