// Функция - Создать документ исходящее письмо отправить письмо на сервере.
//
// Параметры:
//  МассивСтруктурПолучателей	 - 	 -
//  Содержание					 - 	 -
//  Тема						 - 	 -
//  ОписаниеОшибки				 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьДокументИсходящееПисьмоОтправитьПисьмоНаСервере(Контакт, Адрес, Тема, Содержание, Сделка, ОписаниеОшибки)
	
	МассивСтруктурПолучателей = Новый Массив;
	МассивСтруктурПолучателей.Добавить(Новый Структура("Контакт, Адрес", Контакт, Адрес));
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("Дата"             , ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("Тема"             , Тема);
	ДанныеЗаполнения.Вставить("Тело"             , Содержание);
	ДанныеЗаполнения.Вставить("МассивПолучателей", МассивСтруктурПолучателей);
	ДанныеЗаполнения.Вставить("Сделка"           , Сделка);
	
	УстановитьПривилегированныйРежим(Истина);
	
	ИсходящееЭлектронноеПисьмо = Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
	ИсходящееЭлектронноеПисьмо.Заполнить(ДанныеЗаполнения);
	
	Возврат Документы.ЭлектронноеПисьмоИсходящее.ВыполнитьОтправкуПисьма(ИсходящееЭлектронноеПисьмо, ОписаниеОшибки);
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Создать документ РассылкаСообщений и отправить сообщение в мессенджер.
//
// Параметры:
//  МассивСтруктурПолучателей	 - 	 -
//  Содержание					 - 	 -
//  ОписаниеОшибки				 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьДокументРассылкаСообщенийИОтправитьСообщениеМессенджерНаСервере(Получатель, ДанныеКанала, Содержание, СтруктурнаяЕдиница, ШаблонСообщения, ДокументОснование, ОписаниеОшибки)
	
	МассивСтруктурПолучателей = Новый Массив;
	
	СтруктураПолучателя = Новый Структура;
	СтруктураПолучателя.Вставить("Получатель", Получатель);
	
	Если Не ЗначениеЗаполнено(ДанныеКанала.ИдКлиента) Тогда
		СтруктураПолучателя.Вставить("НомерТелефона", ДанныеКанала.НомерМессенджера);
	КонецЕсли;
	
	МассивСтруктурПолучателей.Добавить(СтруктураПолучателя);
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("Получатели"				, МассивСтруктурПолучателей);
	ПараметрыРассылки.Вставить("Содержание"				, Содержание);
	ПараметрыРассылки.Вставить("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
	ПараметрыРассылки.Вставить("ОтправкаMessenger"		, Истина);
	ПараметрыРассылки.Вставить("ВнешняяСистема"			, ДанныеКанала.ВнешняяСистема);
	ПараметрыРассылки.Вставить("ИнициироватьОтправку"	, Истина);
	ПараметрыРассылки.Вставить("ОтправитьНемедленно"	, Истина);    
	ПараметрыРассылки.Вставить("ШаблонСообщения"		, ШаблонСообщения);
	ПараметрыРассылки.Вставить("ДокументОснование"		, ДокументОснование);
	
	Если ДанныеКанала.ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		
		ПараметрыОтправки = Новый Структура("НомерТелефона", ДанныеКанала.НомерМессенджера);
		ПараметрыРассылки.Вставить("ПараметрыОтправки", ПараметрыОтправки);
		
	КонецЕсли;
	
	Если РольДоступна("ИспользованиеМессенджера") Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Возврат Документы.РассылкаСообщений.СоздатьДокументРассылкаСообщений(ПараметрыРассылки, ОписаниеОшибки);
	
КонецФункции

&НаСервере
// Процедура, заполняет список телефонов, которые связаны с  контактами мессенджерамов.
//
Процедура ЗаполнитьСписокТелефоновДляWhatsApp()
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
		|		ПО КонтрагентыКонтактнаяИнформация.Ссылка = КонтактыМессенджеров.ОбъектИдентификации
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
		|	И КонтрагентыКонтактнаяИнформация.НомерТелефона <> """"
		|	И КонтрагентыКонтактнаяИнформация.НомерТелефона = КонтактыМессенджеров.НомерМессенджера");
		
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		
		Результат = Запрос.Выполнить().Выгрузить();
		
		ЭтотОбъект.СписокТелефоновДляWhatsApp.ЗагрузитьЗначения(Результат.ВыгрузитьКолонку("НомерТелефона"));
	Иначе 
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗаявкиКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
		|ИЗ
		|	Справочник.Заявки.КонтактнаяИнформация КАК ЗаявкиКонтактнаяИнформация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
		|		ПО ЗаявкиКонтактнаяИнформация.Ссылка = КонтактыМессенджеров.ОбъектИдентификации
		|ГДЕ
		|	ЗаявкиКонтактнаяИнформация.Ссылка = &Заявка
		|	И ЗаявкиКонтактнаяИнформация.НомерТелефона <> """"
		|	И ЗаявкиКонтактнаяИнформация.НомерТелефона = КонтактыМессенджеров.НомерМессенджера");
		
		Запрос.УстановитьПараметр("Заявка", Заявка);
		
		Результат = Запрос.Выполнить().Выгрузить();
		
		ЭтотОбъект.СписокТелефоновДляWhatsApp.ЗагрузитьЗначения(Результат.ВыгрузитьКолонку("НомерТелефона"));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
