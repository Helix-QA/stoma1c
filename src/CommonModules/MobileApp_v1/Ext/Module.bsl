КонецФункции

#Область get_doctors

// Функция возвращает данные мастера Клиники.
// 
Функция get_doctors(Сотрудник, СтруктурнаяЕдиница, ДатаНачала, ДатаОкончания) Экспорт
	
	МассивСотрудников = Новый Массив;	
	МассивСсылокСотрудников = Новый Массив;
	Настройки = Новый Структура();
	ЗагрузитьНастройкиОтображениеСотрудников(СтруктурнаяЕдиница, Настройки);
	
	Если Сотрудник.Роль = Перечисления.РольПользователя.Регистратура ИЛИ Сотрудник.Роль =  Перечисления.РольПользователя.Руководитель Тогда
		ТаблицаСотрудников = ПолучитьПодчиненныхСотрудников(Сотрудник, СтруктурнаяЕдиница);
		МассивСсылокСотрудников = ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник");
	ИначеЕсли Сотрудник.Роль = Перечисления.РольПользователя.Врач ИЛИ Сотрудник.Роль = Перечисления.РольПользователя.ГлавныйВрач Тогда
		МассивСсылокСотрудников.Добавить(Сотрудник);
	КонецЕсли;
	
	ТаблицаСотрудниковПредставление = ПолучитьРасширенноеПредставлениеСотрудников(МассивСсылокСотрудников, Настройки);
	ГрафикРаботыСотрудников		    = РегистрыСведений.ВремяРаботыСотрудниковПлан.ПолучитьПлановоеВремяРаботыСотрудника(ДатаНачала, ДатаОкончания, МассивСсылокСотрудников, СтруктурнаяЕдиница);
	
	Для Каждого СтрокаТЧ из ТаблицаСотрудниковПредставление Цикл
		
		Представление = Справочники.Сотрудники.ПолучитьПредставлениеСотрудникаПоНастройкеОтображения(СтрокаТЧ, Настройки.ОтображениеСотрудника);
		
		МассивСтрок = Новый Массив;
		МассивСтрок.Добавить(Представление);
		Если Настройки.ОтображениеДолжности = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеВариантОтображать И ЗначениеЗаполнено(СтрокаТЧ.Должность) Тогда
			МассивСтрок.Добавить(СтрокаТЧ.Должность);
		КонецЕсли;
		
		СтруктураДобавления = Новый Структура;
		СтруктураДобавления.Вставить("УИД"			   , УникальныйИдентификатор(СтрокаТЧ.Сотрудник));
		СтруктураДобавления.Вставить("Значение"		   , СокрЛП(Строка(СтрокаТЧ.Сотрудник)));
		СтруктураДобавления.Вставить("Представление"   , МассивСтрок);
		СтруктураДобавления.Вставить("РольПользователя", Строка(СтрокаТЧ.Роль));
		СтруктураДобавления.Вставить("Должность"	   , ?(ЗначениеЗаполнено(СтрокаТЧ.Должность), СокрЛП(СтрокаТЧ.Должность), "Без должности"));
		
		НайденныеСтроки = ГрафикРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
		
		Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
			ГрафикРаботыСотрудника = Новый Массив;
			Для Каждого СтрокаТЗ Из НайденныеСтроки Цикл		
				ГрафикРаботыСотрудника.Добавить(Новый Структура("ДатаНачала, ДатаОкончания", СтрокаТЗ.ДатаВремяНачала, СтрокаТЗ.ДатаВремяОкончания));
			КонецЦикла;
			СтруктураДобавления.Вставить("ГрафикРаботыСотрудника", ГрафикРаботыСотрудника);	
		Иначе
			СтруктураДобавления.Вставить("ГрафикРаботыСотрудника", Неопределено);
		КонецЕсли;
		
		МассивСотрудников.Добавить(СтруктураДобавления);
		
	КонецЦикла;
	
	Возврат ПолучитьСтруктуруОтвета(Новый Структура("МассивСотрудников", МассивСотрудников));
	
КонецФункции

// Процедура, загрузить настройки интерфейса рецепции.
// 
Процедура ЗагрузитьНастройкиОтображениеСотрудников(СтруктурнаяЕдиница, Настройки, ПолучитьВсеНастройки = Ложь)
	
	Настройки       = Новый Структура();
	ТаблицаНастроек = РегистрыСведений.НастройкиИнтерфейсов.ПолучитьНастройкиИнтерфейсаЖурналаЗаписи(СтруктурнаяЕдиница);
	
	Для Каждого СтрокаТЧ Из ТаблицаНастроек Цикл
		
		Если СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеСотрудника Тогда
			Настройки.Вставить("ОтображениеСотрудника", СтрокаТЧ.Значение);
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ОтображениеДолжности Тогда
			Настройки.Вставить("ОтображениеДолжности", СтрокаТЧ.Значение);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция, возвращает таблицу подчиненых сотрудников.
// 
Функция ПолучитьПодчиненныхСотрудников(Сотрудник, СтруктурнаяЕдиница)
	
	// Получаем из регистра НастройкиПользователей дату увольнения (если указан пользователь, то берем его сотрудника)
	// Сотрудников берем из регистра НастройкиСотрудников, т.к. там всегда есть записи по сотруднику
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НастройкиСотрудников.Сотрудник КАК Сотрудник,
	|	НастройкиСотрудников.ДатаУвольнения КАК Значение
	|ПОМЕСТИТЬ втЗначениеДатыУвольнения
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сотрудники.Сотрудник КАК Сотрудник
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ втЗначениеДатыУвольнения КАК втЗначениеДатыУвольнения
	|		ПО Сотрудники.Сотрудник = втЗначениеДатыУвольнения.Сотрудник
	|ГДЕ
	|	Сотрудники.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Сотрудники.Сотрудник.Роль <> ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель)
	|	И НЕ Сотрудники.Сотрудник.ПометкаУдаления
	|	И (втЗначениеДатыУвольнения.Значение ЕСТЬ NULL
	|			ИЛИ втЗначениеДатыУвольнения.Значение = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ втЗначениеДатыУвольнения.Значение > &ТекущаяДата)
	|	И Сотрудники.Сотрудник <> &Сотрудник");
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
КонецФункции

// Функция - Сортировать элементы справочника.
// 
// Параметры:
//  МассивСотрудников	 - 	 -
// 
// Возвращаемое значение:
//   -
// 
Функция ПолучитьРасширенноеПредставлениеСотрудников(МассивСотрудников, Настройки)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник,
	|	Сотрудники.Должность.Наименование КАК Должность,
	|	Сотрудники.Наименование КАК Наименование,
	|	Сотрудники.Фамилия КАК Фамилия,
	|	Сотрудники.Имя КАК Имя,
	|	Сотрудники.Отчество КАК Отчество,
	|	Сотрудники.ПредставлениеДляОнлайнЗаписи КАК ПредставлениеДляОнлайнЗаписи,
	|	&ПриОтображенииДолжностейПоля
	|   Сотрудники.Роль КАК Роль 
	|   
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В(&МассивСотрудников)
	|
	|УПОРЯДОЧИТЬ ПО
	|   &ПриОтображенииДолжностейУпорядочивание
	|	Сотрудники.Ссылка.Наименование");
	
	ОтображатьДолжности = Настройки.Свойство("ОтображениеДолжности") И Настройки.ОтображениеДолжности = Перечисления.ОтображенияЭлементовВЖурналеЗаписи.ОтображениеВариантОтображать; 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"&ПриОтображенииДолжностейПоля",           ?(ОтображатьДолжности,"ВЫБОР
	|		КОГДА Сотрудники.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|КОНЕЦ КАК ИндексСортировки,",""));	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"&ПриОтображенииДолжностейУпорядочивание", ?(ОтображатьДолжности,"ИндексСортировки УБЫВ,
	|Должность,",""));	
	Запрос.УстановитьПараметр("МассивСотрудников",МассивСотрудников);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	// Наличие пустого сотрудника.
	Если МассивСотрудников.Найти(Справочники.Сотрудники.ПустаяСсылка()) <> Неопределено Тогда
		
		НоваяСтрока = РезультатЗапроса.Добавить();
		НоваяСтрока.Ссылка = Справочники.Сотрудники.ПустаяСсылка();
		
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции

#КонецОбласти

// Функция - Получить данные помещений
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  ДатаНачала			 - 	 - 
//  ДатаОкончания		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция get_rooms(СтруктурнаяЕдиница, ДатаНачала, ДатаОкончания) Экспорт
	
	МассивПомещений = Справочники.Помещения.ОтборПомещений(СтруктурнаяЕдиница);
	
	РезультирующийМассив = Новый Массив;
	Для Каждого ЭлементМ ИЗ МассивПомещений Цикл
		Если ЗначениеЗаполнено(ЭлементМ) Тогда 
			РезультирующийМассив.Добавить(Новый Структура("Значение, УИД", СокрЛП(Строка(ЭлементМ)), УникальныйИдентификатор(ЭлементМ)));
		КонецЕсли;	
	КонецЦикла;
	
	РезультирующийМассив.Добавить(Новый Структура("Значение, УИД", "Без помещения", "00000000-0000-0000-0000-000000000000"));	
	Возврат ПолучитьСтруктуруОтвета(Новый Структура("МассивПомещений", РезультирующийМассив));
	
КонецФункции

// Функция - Получить настройки визитов
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция get_settings_visit(СтруктурнаяЕдиница, Сотрудник) Экспорт
	
	ТаблицаНастроек = РегистрыСведений.НастройкиИнтерфейсов.ПолучитьНастройкиИнтерфейсаЖурналаЗаписи(СтруктурнаяЕдиница, Сотрудник);
	
	ИнтервалЗаписи = 0;
	НастройкиЦветов = Новый Структура;	
	Для Каждого СтрокаТЧ Из ТаблицаНастроек Цикл		
		Если СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемНеСостоялся Тогда
			НастройкиЦветов.Вставить("ПриемНеСостоялся", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));			
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПациентОжидает Тогда
			НастройкиЦветов.Вставить("ПациентОжидает", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));			
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемНачат Тогда
			НастройкиЦветов.Вставить("ПриемНачат", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));			
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемОкончен Тогда
			НастройкиЦветов.Вставить("ПриемОкончен", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));			
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПодтверждена Тогда
			НастройкиЦветов.Вставить("Подтверждена", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));			
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветНеПодтверждена Тогда
			НастройкиЦветов.Вставить("НеПодтверждена", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));			
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемОтменен Тогда
			НастройкиЦветов.Вставить("ПриемОтменен", ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(СтрокаТЧ.Значение)));
		ИначеЕсли СтрокаТЧ.Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ИнтервалЗаписи Тогда
			ИнтервалЗаписи = СтрокаТЧ.Значение;
		КонецЕсли;			
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Склады.Наименование КАК Наименование,
	|	Склады.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	Склады.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НЕ Склады.ПометкаУдаления
	|	И НЕ Склады.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Результат = Запрос.Выполнить().Выгрузить();
	
	МассивСкладов = Новый Массив;
	Для Каждого СтрокаТ Из Результат Цикл
		СтруктураСклада = Новый Структура;
		СтруктураСклада.Вставить("НаименованиеСклада", СтрокаТ.Наименование);
		СтруктураСклада.Вставить("УИДСклада"         , УникальныйИдентификатор(СтрокаТ.Ссылка)); 
		СтруктураСклада.Вставить("Основной"          , ?(СтруктурнаяЕдиница.ОсновнойСклад = СтрокаТ.Ссылка, Истина, Ложь));
		МассивСкладов.Добавить(СтруктураСклада);
	КонецЦикла;
	
	НастройкиМобильногоПриложенияСтоматологии = Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();
	Если НастройкиМобильногоПриложенияСтоматологии = Неопределено Тогда
		ОбновитьКонстантуНастройкиМобильногоПриложенияСтоматологии();
		НастройкиМобильногоПриложенияСтоматологии = Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();
	КонецЕсли;
	
	СтруктураНастроек = Новый Структура;
	Для Каждого НастройкаМП Из НастройкиМобильногоПриложенияСтоматологии Цикл
		СтруктураНастроек.Вставить(НастройкаМП.Ключ, НастройкаМП.Значение);	
	КонецЦикла;	
		
	Настройки = Новый Структура;
	Настройки.Вставить("НастройкиЦветов"							, НастройкиЦветов);
	Настройки.Вставить("МассивСкладов"								, МассивСкладов);	
	Настройки.Вставить("НеКонтролироватьОстатки"					, Константы.НеКонтроллироватьОстатки.Получить());	
	Настройки.Вставить("РольПользователя"							, ПолучитьРольПользователя(ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сотрудник,"Роль")));
	Настройки.Вставить("ВалютаУчета"								, СокрЛП(ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты()));		
	Настройки.Вставить("НастройкиМобильногоПриложенияСтоматологии"	, СтруктураНастроек);	
	Настройки.Вставить("ИнтервалЗаписи"								, ОпределениеИнтервалаВремени(ИнтервалЗаписи));
	Настройки.Вставить("ВерсияКонфигурации"							, Метаданные.Версия + "00");
	Настройки.Вставить("ТекущаяДатаСеанса"							, ТекущаяДатаСеанса());
	Настройки.Вставить("УИДСотрудника"								, Строка(Сотрудник.УникальныйИдентификатор()));
	Настройки.Вставить("РазрешитьЗаписьКДругомуВрачу"				, Пользователи.ПолучитьЗначениеПраваПользователя("РазрешитьЗаписьКДругомуВрачу", Справочники.Пользователи.ПолучитьПользователя(Сотрудник)));
		
	Возврат ПолучитьСтруктуруОтвета(Настройки);
	
КонецФункции

#Область find_client_by_line

// Функция - Найти клиентов по номеру телефона
//
// Параметры:
//  Телефон	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция find_client_by_line(СтрокаПоиска, Сотрудник) Экспорт 
	
	РазмерПорции = 20;
	ВыборкаКлиентов = ОбщегоНазначенияСтоматология.НайтиКонтрагентовПоСтроке(СтрокаПоиска, РазмерПорции, Истина, Истина,,,,,, Истина);	
	ПараметрыНастроек = Константы.НастройкиМобильногоПриложенияСтоматологии.Получить().Получить();
	ВыводитьТелефонКлиентаВрачу = ПараметрыНастроек <> Неопределено И ПараметрыНастроек.Свойство("ВыводитьТелефонКлиентаВрачу") И ПараметрыНастроек.ВыводитьТелефонКлиентаВрачу;
	
	МассивКлиентов = Новый Массив;	
	Если ВыборкаКлиентов.Количество() > РазмерПорции Тогда
		ИнфоКлиента = Новый Структура();
		ИнфоКлиента.Вставить("УИД"			, Неопределено);
		ИнфоКлиента.Вставить("ФИО"			, "НайденоБольше20");
		ИнфоКлиента.Вставить("Представление", "Найдено более " + РазмерПорции + " пациентов, уточните поиск.");
		ИнфоКлиента.Вставить("Телефон"		, СтрокаПоиска);
		МассивКлиентов.Добавить(ИнфоКлиента);		
	ИначеЕсли ВыборкаКлиентов.Количество() = 0 Тогда
		ИнфоКлиента = Новый Структура();
		ИнфоКлиента.Вставить("УИД"			, Неопределено);
		ИнфоКлиента.Вставить("ФИО"			, "КлиентНеНайден");
		ИнфоКлиента.Вставить("Представление", "Пациент не найден. Создать нового клиента.");
		ИнфоКлиента.Вставить("Телефон"		, СтрокаПоиска);
		МассивКлиентов.Добавить(ИнфоКлиента);		
	Иначе
		
		Пока ВыборкаКлиентов.Следующий() Цикл
			
			ТелефонКлиента = ?(ЗначениеЗаполнено(ВыборкаКлиентов.Телефон) И ВыводитьТелефонКлиентаВрачу = Ложь И РольПользователяУрезана(Сотрудник), ЗаменитьНомерТелефонаДляВрача(ВыборкаКлиентов.Телефон), ВыборкаКлиентов.Телефон); 
			
			Представление = "" + ВыборкаКлиентов.Ссылка + 
			?(ЗначениеЗаполнено(ВыборкаКлиентов.ДатаРождения), ", " + Формат(ВыборкаКлиентов.ДатаРождения, "ДФ=dd.MM.yyyy"), "") + 
			?(ЗначениеЗаполнено(ТелефонКлиента), ", " + ТелефонКлиента, "") +
			?(ЗначениеЗаполнено(ВыборкаКлиентов.ТекущаяМедицинскаяКартаКод), ", № " + ВыборкаКлиентов.ТекущаяМедицинскаяКартаКод, "");
			
			ИнфоКлиента = Новый Структура;
			ИнфоКлиента.Вставить("УИД"			, УникальныйИдентификатор(ВыборкаКлиентов.Ссылка));
			ИнфоКлиента.Вставить("ФИО"			, Строка(ВыборкаКлиентов.Ссылка));	
			ИнфоКлиента.Вставить("Представление", Представление);
			ИнфоКлиента.Вставить("Телефон"		, ТелефонКлиента);      
			МассивКлиентов.Добавить(ИнфоКлиента);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ПолучитьСтруктуруОтвета(МассивКлиентов);
	
КонецФункции
	
#КонецОбласти

#Область get_appointment_data

// Функция - Получить данные визита
//
// Параметры:
//  Сотрудник	 - 	 - 
//  Визит		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция get_appointment_data(Событие, Сотрудник) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Событие.Дата КАК Дата,
	|	Событие.ДатаОкончания КАК ДатаОкончания,
	|	Событие.Комментарий КАК Комментарий,
	|	Событие.Контрагент КАК Контрагент,
	|	Событие.ПолисМедСтрахования КАК ПолисМедСтрахования,
	|	Событие.ПричинаОтмены КАК ПричинаОтмены,
	|	Событие.Статус КАК Статус,
	|	Событие.Контрагент.Представление КАК КонтрагентПредставление,
	|	Событие.ПричинаОтмены.Представление КАК ПричинаОтменыПредставление,
	|	Событие.ПолисМедСтрахования.Представление КАК ПолисМедСтрахованияПредставление,
	|	Событие.Услуги.(
	|		ПричинаЗаписи КАК ПричинаЗаписи,
	|		ПричинаЗаписи.Представление КАК ПричинаЗаписиПредставление
	|	) КАК Услуги,
	|	Событие.Представление КАК Представление,
	|	Событие.Контрагент.Телефон КАК КонтрагентТелефон,
	|	Событие.ОснованиеРезерва КАК ОснованиеРезерва,
	|	Событие.Врач КАК Врач,
	|	Событие.Врач.Наименование КАК ВрачНаименование
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.Ссылка = &Ссылка");
		
	Запрос.УстановитьПараметр("Ссылка"		, Событие);
	Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДатаСеанса());
	
	ВыборкаСобытия = Запрос.Выполнить().Выбрать();
	
	СтруктураВозврата = Новый Структура;
	Если ВыборкаСобытия.Следующий() Тогда
		СтруктураВозврата.Вставить("Дата", ВыборкаСобытия.Дата);
		СтруктураВозврата.Вставить("ДатаОкончания", ВыборкаСобытия.ДатаОкончания);
		СтруктураВозврата.Вставить("Комментарий", ВыборкаСобытия.Комментарий);
		СтруктураВозврата.Вставить("Контрагент", УникальныйИдентификатор(ВыборкаСобытия.Контрагент));
		СтруктураВозврата.Вставить("КонтрагентПредставление", ВыборкаСобытия.КонтрагентПредставление);
		СтруктураВозврата.Вставить("ПричинаОтмены", УникальныйИдентификатор(ВыборкаСобытия.ПричинаОтмены));
		СтруктураВозврата.Вставить("ПричинаОтменыПредставление", ВыборкаСобытия.ПричинаОтменыПредставление);
		СтруктураВозврата.Вставить("Статус", ПолучитьСтатусСобытия(ВыборкаСобытия.Статус));
		СтруктураВозврата.Вставить("ПолисМедСтрахования", УникальныйИдентификатор(ВыборкаСобытия.ПолисМедСтрахования));
		СтруктураВозврата.Вставить("ПолисМедСтрахованияПредставление", ВыборкаСобытия.ПолисМедСтрахованияПредставление); 
		СтруктураВозврата.Вставить("Представление", ВыборкаСобытия.Представление);
		СтруктураВозврата.Вставить("КонтрагентТелефон", ВыборкаСобытия.КонтрагентТелефон);
		СтруктураВозврата.Вставить("ОснованиеРезерва", ВыборкаСобытия.ОснованиеРезерва);
		СтруктураВозврата.Вставить("ВрачПредставление", ВыборкаСобытия.ВрачНаименование);
		СтруктураВозврата.Вставить("Врач", УникальныйИдентификатор(ВыборкаСобытия.Врач));
		
		ТаблицаУслуг = ВыборкаСобытия.Услуги.Выгрузить();
		СтрокаУслуги = ?(ТаблицаУслуг.Количество() > 0, ТаблицаУслуг[0], Неопределено); 
		
		Если СтрокаУслуги <> Неопределено Тогда
			СтруктураВозврата.Вставить("ПричинаЗаписи", УникальныйИдентификатор(СтрокаУслуги.ПричинаЗаписи));
			СтруктураВозврата.Вставить("ПричинаЗаписиПредставление", СтрокаУслуги.ПричинаЗаписиПредставление);			
		КонецЕсли;		
	КонецЕсли;
	
	СтруктураВозврата.Вставить("МассивМеток", ПолучитьМассивМеток(Событие));
		
	Возврат ПолучитьСтруктуруОтвета(ВалидацияJSON(СтруктураВозврата));
	
КонецФункции

