// Процедура, обработчик события "ПриИзменении." 
//
Процедура УслугиНоменклатураПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Услуги.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);
	СтруктураДанные.Вставить("Сотрудник", 			СтрокаТабличнойЧасти.Сотрудник);
	СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
	
	СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	
	НормаВремениНоменклатры = ВернутьНормыВремениУслуги(СтрокаТабличнойЧасти.Номенклатура);
	Если (ЗначениеЗаполнено(НормаВремениНоменклатры) ИЛИ НормаВремениНоменклатры = 0) И НормаВремениНоменклатры <> СтрокаТабличнойЧасти.НормаВремени Тогда 
		
		Если ОтветПользователяНаВопрос = Неопределено Тогда
			
			ПараметрыОповещения = Новый Структура("Элемент, ПроцедураВозврата", Элемент, "УслугиНоменклатураПриИзменении");
			Оповещение = Новый ОписаниеОповещения("ПоказатьПользователюВопросЗавершение_ЗапасыНоменклатураПриИзменении", ЭтотОбъект, ПараметрыОповещения);
			ПоказатьВопрос(Оповещение, "Норма времени по услуге не соответствует выбранному значению. Изменить?", РежимДиалогаВопрос.ДаНет);
			Возврат;
			
		ИначеЕсли ОтветПользователяНаВопрос = КодВозвратаДиалога.Да Тогда
			
			СтрокаТабличнойЧасти.ДатаОкончания = СтрокаТабличнойЧасти.ДатаНачала + НормаВремениНоменклатры * 60;
			ДатаОкончания = СтрокаТабличнойЧасти.ДатаНачала + НормаВремениНоменклатры * 60;
			СтрокаТабличнойЧасти.НормаВремени = НормаВремениНоменклатры;
			НормаВремени = НормаВремениНоменклатры;

		КонецЕсли;
		ОтветПользователяНаВопрос = Неопределено;
			
	КонецЕсли;
	
КонецПроцедуры

