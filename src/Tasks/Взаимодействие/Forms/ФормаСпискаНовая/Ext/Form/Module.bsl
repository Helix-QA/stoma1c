&НаКлиенте
// Процедура - План перед созданием
//
// Параметры:
//  Элемент				 - 	 - 
//  Начало				 - 	 - 
//  Конец				 - 	 - 
//  Значения			 - 	 - 
//  Текст				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПланПередСозданием(Элемент, Начало, Конец, Значения, Текст, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(Элемент) <> Тип("ПолеФормы") Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ЗначенияЗаполнения", Новый Структура("ЗадачаНазначеннаяДата", Начало));
	
	ОткрытьФорму("Задача.Взаимодействие.ФормаОбъекта", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);			
	
КонецПроцедуры

