// Процедура удаляет бонусы, не начисляемые при наличии скидок.
//
Функция ПолучитьМассивБонусовНеНачисляемыхПриНаличииСкидки(ТаблицаСкидок, ТабличнаяЧастьНоменклатурыЗапасы, ТабличнаяЧастьНоменклатурыЛечение)
	
	МассивУдаляемыхСтрок = Новый Массив;
	
	Если ЗначениеЗаполнено(ТабличнаяЧастьНоменклатурыЗапасы) Тогда	
		ТабличнаяЧастьНоменклатура = ТабличнаяЧастьНоменклатурыЗапасы;
	ИначеЕсли  ЗначениеЗаполнено(ТабличнаяЧастьНоменклатурыЛечение) Тогда
		ТабличнаяЧастьНоменклатура = ТабличнаяЧастьНоменклатурыЛечение;
	Иначе
		Возврат МассивУдаляемыхСтрок;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ Из ТаблицаСкидок Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЧ.СкидкаНаценка) 
			И НЕ СтрокаТЧ.СкидкаНаценка.ЭтоГруппа
			И СтрокаТЧ.СкидкаНаценка.НачислениеБонусами  
			И СтрокаТЧ.СкидкаНаценка.НеНачислятьБонусПриНаличииСкидки Тогда
			
			НайденныеСтроки = ТабличнаяЧастьНоменклатура.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТЧ.КлючСтроки));
			
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				
				СуммаОплатыБонусами = 0;
				МассивСтрокОплатыБонусами = ТаблицаСкидок.НайтиСтроки(Новый Структура("ПризнакОплатыБонусом, КлючСтроки", Истина, СтрокаТЧ.КлючСтроки));
				Для Каждого ЭлементМ Из МассивСтрокОплатыБонусами Цикл
					СуммаОплатыБонусами = СуммаОплатыБонусами + ЭлементМ.Сумма; 
				КонецЦикла;
				
				// Разделяем оплату бонусами и ручную скидку.
				Если НайденнаяСтрока.СуммаРучнойСкидки > 0 ИЛИ НайденнаяСтрока.СуммаАвтоматическойСкидкиНаценки > СуммаОплатыБонусами Тогда
					МассивУдаляемыхСтрок.Добавить(СтрокаТЧ.СкидкаНаценка);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли; 
		
	КонецЦикла;
	
	Возврат МассивУдаляемыхСтрок;
	
КонецФункции     

// Процедура - Пересчитать сумму начисление бонусами
//
// Параметры:
//  ТаблицаСкидок		 - 	 - 
//  ТабличнаяЧастьТовары - 	 - 
//
Процедура ПересчитатьСуммуНачислениеБонусами(
	ТаблицаСкидок, 
	ТабличнаяЧастьЗапасы,
	ТабличнаяЧастьЛечение,
	ТабличнаяЧастьУслуги,
	ДокументОбъект)
	
	Для Каждого СтрокаТЧ Из ТаблицаСкидок Цикл
		
		Если СтрокаТЧ.НачислениеБонусами = Истина Тогда    			
			
			Если ТабличнаяЧастьЗапасы <> Неопределено Тогда
				ЭтоНарядЗаказ = ТипЗнч(ДокументОбъект.Ссылка) = Тип("ДокументСсылка.НарядЗаказ");
				НайденныеСтроки = ТабличнаяЧастьЗапасы.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТЧ.КлючСтроки)); 				
				Если НайденныеСтроки.Количество() <> 0 Тогда
					НайденнаяСтрока = НайденныеСтроки[0];        
					Если СтрокаТЧ.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
						СтрокаТЧ.СуммаСкидки = (?(ЭтоНарядЗаказ, НайденнаяСтрока.СуммаПродажи, НайденнаяСтрока.Сумма)
												- НайденнаяСтрока.СуммаРучнойСкидки
												- НайденнаяСтрока.СуммаАвтоматическойСкидкиНаценки) * СтрокаТЧ.ЗначениеСкидкиНаценки / 100;
												
						СтрокаТЧ.СуммаСкидки = ?(СтрокаТЧ.СуммаСкидки < 0, 0, СтрокаТЧ.СуммаСкидки);
					ИначеЕсли СтрокаТЧ.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Сумма Тогда
						СтрокаТЧ.СуммаСкидки = СтрокаТЧ.ЗначениеСкидкиНаценки;					
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если ТабличнаяЧастьЛечение <> Неопределено Тогда
				НайденныеСтроки = ТабличнаяЧастьЛечение.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаТЧ.КлючСтроки)); 				
				Если НайденныеСтроки.Количество() <> 0 Тогда
					НайденнаяСтрока = НайденныеСтроки[0];        
