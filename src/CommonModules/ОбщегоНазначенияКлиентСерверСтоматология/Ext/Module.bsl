// Функция - Выгрузить колнку таб части в массив
//
// Параметры:
//  ТабЧасть	 - 	 - 
//  ИмяКолонки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВыгрузитьКолнкуТабЧастиВМассив(ТабЧасть, ИмяКолонки, ИсклЗначение = Null) Экспорт
	
	МассивИсключений = Неопределено;
	Если ИсклЗначение <> Null Тогда
		Если ТипЗнч(ИсклЗначение) = Тип("Массив") Тогда
			МассивИсключений = ИсклЗначение;
		Иначе
			МассивИсключений = Новый Массив;
			МассивИсключений.Добавить(ИсклЗначение);
		КонецЕсли;
	КонецЕсли;
		
	МассивДанных = Новый Массив;
	Для Каждого СтрокаТ ИЗ ТабЧасть Цикл
		Если МассивИсключений <> Неопределено Тогда
			Если МассивИсключений.Найти(СтрокаТ[ИмяКолонки]) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		МассивДанных.Добавить(СтрокаТ[ИмяКолонки]);
	КонецЦикла;
	
	Возврат МассивДанных;
КонецФункции

