// Процедура - Заполнить список каналов системы сообщения
//
Процедура ЗаполнитьСписокКаналовСистемыСообщения(ЭлементФормы, ИндексСтроки, СтрокаНастройкиКаналовУведомлений)
	
	Если НЕ ЭлементФормы = Неопределено Тогда 
		ЭлементФормы.Видимость = Ложь;		
		ЭлементФормы.СписокВыбора.Очистить();
		Если ЗначениеЗаполнено(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы) И ТипЗнч(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы) = Тип("СправочникСсылка.ВнешниеСистемы") Тогда 
			МассивСтрокВнешниСистем = ТаблицаВнешнихСистем.НайтиСтроки(Новый Структура("Ссылка", СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы));
			Если НЕ МассивСтрокВнешниСистем.Количество() = 0 Тогда 
				ТипВнешнейСистемы = МассивСтрокВнешниСистем[0].ТипВнешнейСистемы;
			Иначе 
				ТипВнешнейСистемы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы, "ТипВнешнейСистемы");
			КонецЕсли;
			
			Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk Тогда 
				ЭлементФормы.Видимость = Истина;			
				МассивКаналов = Новый Массив;//МессенджерСтоматология.ПолучитьКаналыChat2Desk(СтрокаНастройкиКаналовУведомлений.АккаунтВнешнейСистемы);
				Для Каждого ЭлементКанал Из МассивКаналов Цикл 
					ЭлементФормы.СписокВыбора.Добавить(ЭлементКанал.Значение, ЭлементКанал.Имя + " (" + Строка(ЭлементКанал.Значение) + ")", СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений = ЭлементКанал.Значение);
				КонецЦикла;
				Если ЗначениеЗаполнено(СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений) Тогда 
					ЭлементСпискаКанал = ЭлементФормы.СписокВыбора.НайтиПоЗначению(СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений);
					Если ЭлементСпискаКанал = Неопределено Тогда 
						ЭлементФормы.СписокВыбора.Добавить(СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений, Новый ФорматированнаяСтрока("Канал деактивирован (" + СтрокаНастройкиКаналовУведомлений.КаналСистемыСообщений + ")", , Новый Цвет(255, 0, 0)), Истина);
					КонецЕсли;
				КонецЕсли;
				Если ЭлементФормы.СписокВыбора.Количество() = 0 Тогда 
					ЭлементФормы.ПодсказкаВвода = НСтр("ru = 'Каналы сообщений не найдены'; en = 'Message channels are not found'");
				Иначе 
					ЭлементФормы.ПодсказкаВвода = НСтр("ru = 'Выберите канал сообщений'; en = 'Select a message channel'");
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

