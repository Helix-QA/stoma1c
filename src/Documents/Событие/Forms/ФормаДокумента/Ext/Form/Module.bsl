// Процедура проверяет дублирование нового пациента по телефону.
//
Процедура ПроверкаДублированияКлиентаКонтактнаяИнформация(ТекстРедактирования) Экспорт
	
	ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон");
	
	МассивКлиентов = ПроверитьНаДублированиеКлиентаКИ(Объект.Ссылка, ТипКИ, ТекстРедактирования);
	
	Если ЗначениеЗаполнено(МассивКлиентов) Тогда
		
		СписокКнопок = Новый СписокЗначений;
		СписокКнопок.Добавить(КодВозвратаДиалога.Да		, НСтр("ru='Создать родственную связь';en='Yes'"));
		СписокКнопок.Добавить(КодВозвратаДиалога.Отмена	, НСтр("ru='Нет';en='Not'"));
		СписокКнопок.Добавить(КодВозвратаДиалога.Нет	, НСтр("ru='Использовать существующего';en='Open existing'"));
		
		ДанныеКИ = Неопределено;
		
		Оповещение = Новый ОписаниеОповещения("ПроверкаДублированияКлиентаКонтактнаяИнформацияОтвет", ЭтотОбъект, Новый Структура("МассивКлиентов, ДанныеКИ", МассивКлиентов, ДанныеКИ));
		ПоказатьВопрос(Оповещение, НСтр("ru='Пациент с такими данными уже существует. Продолжить?';en='Client with such data already exists. Continue?'"), СписокКнопок,);
			
	КонецЕсли;
	
