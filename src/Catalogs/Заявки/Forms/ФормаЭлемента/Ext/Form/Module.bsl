// Процедура - Оценка заявки выбор завершение.
//
// Параметры:
//  Результат	 - 	 -
//  ДопПараметры - 	 -
//
Процедура ОценкаЗаявкиВыборЗавершение(Результат, ДопПараметры) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отклонена");
	Объект.ОценкаЗаявки  	= Результат;
	Объект.ОсновнойМенеджер = ?(Объект.ОсновнойМенеджер <> ЭтотОбъект.ТекущийПользователь, ЭтотОбъект.ТекущийПользователь, Объект.ОсновнойМенеджер);
	
	РезультатОперации = УстановитьСтатусИЗаписатьФорму();
	
	Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОперации.ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("Заявка"				, Объект.Ссылка);
	ПараметрыОповещения.Вставить("ОсновнойМенеджер"		, Объект.ОсновнойМенеджер);
	ПараметрыОповещения.Вставить("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
	
	Оповестить("ОбновленСтатусЗаявки", ПараметрыОповещения);
	
	УстановитьСостояниеЭлементовФормыСтатусыЗаявки();
	УстановитьСостояниеЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" полей "Фамилия", "Имя", "Отчество".
//
Процедура ФИОПриИзменении(Элемент = Неопределено)
		
	// Фамилия.
	Объект.Фамилия = СокрЛП(Объект.Фамилия);
	Объект.Фамилия = ВРег(Сред(Объект.Фамилия, 1, 1)) + НРег(Сред(Объект.Фамилия, 2));
	// Имя.
	Объект.Имя = СокрЛП(Объект.Имя);
	Объект.Имя = ВРег(Сред(Объект.Имя, 1, 1)) + НРег(Сред(Объект.Имя, 2));
	// Отчество.
	Объект.Отчество = СокрЛП(Объект.Отчество);
	Объект.Отчество = ВРег(Сред(Объект.Отчество, 1, 1)) + НРег(Сред(Объект.Отчество, 2));
	
	Объект.Наименование = СокрЛП(Объект.Фамилия + ?(ЗначениеЗаполнено(Объект.Фамилия), " ", "") + Объект.Имя + ?(ЗначениеЗаполнено(Объект.Имя), " ", "") + Объект.Отчество);
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

