// Функция обрабатывает код карты, полученный от внешнего оборудования
//
Функция ПолученКодКарты(КодКарты, ДанныеДорожек)

	Если ТипЗнч(ДанныеДорожек) = Тип("Массив")
	   И ДанныеДорожек.Количество() > 1
	   И ДанныеДорожек[1] <> Неопределено
	   И Не ПустаяСтрока(ДанныеДорожек[1]) Тогда
		ДанныеКарты = ДанныеДорожек[1];

		ДанныеПоКарте = Справочники.Карты.ПолучитьДанныеМагнитнойКарты(ДанныеКарты);
		Если ДанныеПоКарте <> Неопределено Тогда
			Объект.Контрагент       = ДанныеПоКарте.ВладелецКарты;
			Объект.КартаКонтрагента = ДанныеПоКарте;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Карта клиента со штриховым кодом "+ДанныеКарты+" не найдена");
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Указана неверная карта или произошла ошибка при считывании карты.
		|Повторите считывание или считайте другую карту'"));
	КонецЕсли;
    	
	Возврат Истина;

КонецФункции

