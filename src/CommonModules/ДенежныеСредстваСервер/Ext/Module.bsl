// Процедура заполняет массив непроверяемых реквизитов значениями,
// не используемыми при выбранной хозяйственной операции документа.
//
// Параметры:
// МассивВсехРеквизитов - Массив - Массив всех реквизитов документа
// МассивРеквизитовОперации - Массив - Массив реквизитов документа, которые относятся к хозяйственной операции документа
// МассивНепроверяемыхРеквизитов - Массив реквизитов объекта, не требующих проверки
//
Процедура ЗаполнитьМассивНепроверяемыхРеквизитов(МассивВсехРеквизитов, МассивРеквизитовОперации, МассивНепроверяемыхРеквизитов) Экспорт
	
	Для Каждого ЭлементМассива Из МассивВсехРеквизитов Цикл
		
		// Если реквизит не используется для хозяйственной операции, исключаем данный реквизит из проверки.
		Если МассивРеквизитовОперации.Найти(ЭлементМассива) = Неопределено Тогда
			МассивНепроверяемыхРеквизитов.Добавить(ЭлементМассива);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // ЗаполнитьМассивНепроверяемыхРеквизитов()    

// Процедура заполняет массив непроверяемых реквизитов значениями,
// не используемыми при выбранной хозяйственной операции документа.
//
// Параметры:
// МассивВсехРеквизитов - Массив - Массив всех реквизитов документа
// МассивРеквизитовОперации - Массив - Массив реквизитов документа, которые относятся к хозяйственной операции документа
// МассивНепроверяемыхРеквизитов - Массив реквизитов объекта, не требующих проверки
//
Процедура ЗаполнитьМассивНепроверяемыхРеквизитовПоОбъекту(ПроверяемыйОбъект, МассивОбязательныхРеквизитов, МассивНепроверяемыхРеквизитов) Экспорт
	
	// ПроверяемыйОбъект.Метаданные().ТабличныеЧасти.РасшифровкаПлатежа.Реквизиты
	МетаданныеОбъекта = ПроверяемыйОбъект.Метаданные();
	
	Для Каждого РеквизитМ Из МетаданныеОбъекта.Реквизиты Цикл
		
		// Если реквизит не используется для хозяйственной операции, исключаем данный реквизит из проверки.
		Если МассивОбязательныхРеквизитов.Найти(РеквизитМ.Имя) = Неопределено Тогда
			МассивНепроверяемыхРеквизитов.Добавить(РеквизитМ.Имя);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ТабличнаяЧастьМ Из МетаданныеОбъекта.ТабличныеЧасти Цикл
		
		// Если реквизит не используется для хозяйственной операции, исключаем данный реквизит из проверки.
		Если МассивОбязательныхРеквизитов.Найти(ТабличнаяЧастьМ.Имя) = Неопределено Тогда
			МассивНепроверяемыхРеквизитов.Добавить(ТабличнаяЧастьМ.Имя);
		КонецЕсли;
		
		Для Каждого РеквизитТЧ ИЗ ТабличнаяЧастьМ.Реквизиты Цикл
			// Если реквизит не используется для хозяйственной операции, исключаем данный реквизит из проверки.
			Если МассивОбязательныхРеквизитов.Найти(ТабличнаяЧастьМ.Имя +"."+ РеквизитТЧ.Имя) = Неопределено Тогда
				МассивНепроверяемыхРеквизитов.Добавить(ТабличнаяЧастьМ.Имя +"."+ РеквизитТЧ.Имя);
			КонецЕсли;
			
		КонецЦикла;	
			
	КонецЦикла;
	
КонецПроцедуры

// Процедура удаляет из массива элементы, соответствующие именам не проверяемых реквизитов объекта.
//
// Параметры:
//	МассивРеквизитов - Массив - Массив реквизитов объекта
//	МассивНепроверяемыхРеквизитов - Массив реквизитов объекта, не требующих проверки
//
Процедура УдалитьНепроверяемыеРеквизитыИзМассива(МассивРеквизитов, МассивНепроверяемыхРеквизитов) Экспорт
	
	Для Каждого ЭлементМассива Из МассивНепроверяемыхРеквизитов Цикл
		
		ПорядковыйНомер = МассивРеквизитов.Найти(ЭлементМассива);
		Если ПорядковыйНомер <> Неопределено Тогда
			МассивРеквизитов.Удалить(ПорядковыйНомер);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // УдалитьНепроверяемыеРеквизитыИзМассива()

// Процедура пересчитывает сумму в строке табличной части "Расшифровка платежа" при изменении суммы в шапке документа.
//
// Параметры:
//	Объект - ДанныеФормыСтруктура - Текущий документ
//	СуммаДокумента - Число - Сумма документа
//
Процедура ПересчетСуммыВСтрокеРасшифровкиПлатежа(Объект, СуммаДокумента) Экспорт
	
	Если Объект.РасшифровкаПлатежа.Количество() = 1 Тогда
		
		СтрокаТаблицы = Объект.РасшифровкаПлатежа[0];
		СтрокаТаблицы.Сумма = СуммаДокумента;
		
	КонецЕсли;
	
КонецПроцедуры // ПересчетСуммыВСтрокеРасшифровкиПлатежа()

// Процедура заполняет реквизит ОплаченоФакт документа продажи, по данным документа оплаты
Процедура ЗаполнитьРеквизитыОплатыДокументаОснования(ДокументОплаты, УдалениеПроведения = Ложь) Экспорт
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументОбъект.Прием") Тогда
				
		Если НЕ УдалениеПроведения Тогда
			ДокументОбъект               = ДокументОплаты;						
			
			// Перезаполняем реквизиты
			ДокументОбъект.СуммаОплачено = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОплатыПоДокументу(ДокументОплаты.Ссылка);
			// Порою возникает проблема при уст. этого реквизита....
			// ДокументОбъект.Долговой      = ДокументОбъект.СуммаОплачено < ДокументОбъект.СуммаДокумента;
			Если ДокументОплаты.Ссылка.СуммаОплачено <> ДокументОбъект.СуммаОплачено 
				ИЛИ (ДокументОплаты.Ссылка.Долговой <> ДокументОбъект.Долговой) Тогда
				ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;	
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокументОплаты) <> Тип("ДокументОбъект.ВозвратОтПокупателя") Тогда		
		// Прекратить операцию если выставлен флаг блокировки обработки
		Если (ТипЗнч(ДокументОплаты) = ТИп("ДокументОбъект.СписаниеДенежныхСредств") ИЛИ 
			ТипЗнч(ДокументОплаты) = ТИп("ДокументОбъект.ПоступлениеДенежныхСредств")) И
			ДокументОплаты.БлокировкаОбработчикаКорректировкиДокументовОснования = Истина Тогда
			Возврат;
		КонецЕсли;	
	
		РасшифровкаПлатежа = ДокументОплаты.РасшифровкаПлатежа;	
		Для А = 0 По РасшифровкаПлатежа.Количество()-1 Цикл		
			Если ЗначениеЗаполнено(РасшифровкаПлатежа[А].ДокументОснования)  Тогда		
				Если ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.Прием")
					ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.Реализация")	
					ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.ВозвратОтПокупателя") 
					ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.ПланЛечения") 
					ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.Поступление")
					ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.ЗаказПоставщику")
					ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.ВозвратПоставщику") Тогда
					ДокументОбъект               = РасшифровкаПлатежа[А].ДокументОснования.ПолучитьОбъект();
					// Получаем ост. задолженности по взаиморасчетам
					
					Если ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.ВозвратОтПокупателя") 
						И ЗначениеЗаполнено(РасшифровкаПлатежа[А].ДокументОснования.ДокументОснования) Тогда
						ДокументОснования = РасшифровкаПлатежа[А].ДокументОснования.ДокументОснования;
					Иначе
						ДокументОснования = РасшифровкаПлатежа[А].ДокументОснования;
					КонецЕсли;
						
					// Обновляем значение реквизита сумма оплачено
					Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("СуммаОплачено", ДокументОбъект.Метаданные()) Тогда
						
						Если ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.Прием")
							ИЛИ ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.Реализация") Тогда
							
							СуммаОплаченоПоДокументу = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуОплатыПоДокументу(ДокументОснования);
						Иначе
							
							НеУчитыватьДвижения = ?(УдалениеПроведения, ДокументОплаты.Ссылка, Неопределено);
							ОстатокЗадолженности = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьЗадолженностьПоДокументу(ДокументОснования, Неопределено, НеУчитыватьДвижения, Истина);							
							
							Если НЕ РасшифровкаПлатежа[А].ДокументОснования.Проведен Тогда
								ОстатокЗадолженности = ДокументОбъект.СуммаДокумента - ОстатокЗадолженности * -1;
							КонецЕсли;	
							Если ТипЗнч(РасшифровкаПлатежа[А].ДокументОснования) = Тип("ДокументСсылка.ВозвратОтПокупателя") 
								И ЗначениеЗаполнено(РасшифровкаПлатежа[А].ДокументОснования.ДокументОснования) Тогда	
								ОстатокЗадолженности = ОстатокЗадолженности * -1;		
							КонецЕсли;
							
							СуммаОплаченоПоДокументу = ДокументОбъект.СуммаДокумента - ОстатокЗадолженности;
							
						КонецЕсли;
						
						Если ДокументОбъект.СуммаОплачено = СуммаОплаченоПоДокументу Тогда
							Продолжить;
						КонецЕсли;	
						ДокументОбъект.СуммаОплачено = СуммаОплаченоПоДокументу; 	
						Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("Долговой", ДокументОбъект.Метаданные()) Тогда
							ДокументОбъект.Долговой  = ДокументОбъект.СуммаОплачено < ДокументОбъект.СуммаДокумента;
						КонецЕсли;
					КонецЕсли;
					// Установки строку видов оплаты документа
					МассивДокументов             = ПолучитьДокументыОплатыПоДокументуРеализации(РасшифровкаПлатежа[А].ДокументОснования,,ДокументОплаты.ВидОперации);
					МассивВидов                  = Новый Массив;
					ВидыОплатыСтрокой            = "";
					// Подготовка массива видов оплат из документов оплат
					Для Каждого ДокументСсылка ИЗ МассивДокументов Цикл
						Если СтрЧислоВхождений(ВидыОплатыСтрокой,ДокументСсылка.ТипДенежныхСредств)>0 ИЛИ УдалениеПроведения И ДокументСсылка = ДокументОплаты.Ссылка Тогда
							Продолжить;
						КонецЕсли;
						ТипДенежныхСредствСтрокой = Строка(ДокументСсылка.ТипДенежныхСредств);
						ТипДенежныхСредствСтрокой = ТипДенежныхСредствСтрокой + ?(ДокументСсылка.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании,": Страховая компания {"+ДокументСсылка.Контрагент+"}","");
						ВидыОплатыСтрокой         = ВидыОплатыСтрокой + ТипДенежныхСредствСтрокой+",";
						МассивВидов.Добавить(ТипДенежныхСредствСтрокой);
					КонецЦикла;
					Если ОбщегоНазначенияСтоматология.ЕстьРеквизитДокумента("ВидыОплат",ДокументОбъект.Метаданные()) Тогда
						// Сортируем массив видов оплат
						МассивВидов              = СтроковыеФункцииКлиентСерверСтоматология.СортироватьМассивСтрок(МассивВидов);
						// Конкантенация строк массива
						ДокументОбъект.ВидыОплат = СтроковыеФункцииКлиентСерверСтоматология.ПолучитьСтрокуИзМассиваПодстрок(МассивВидов,",");
					КонецЕсли;
					// Устанавливаем флаг блокировки перезаполнения(переменная)
					Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.Прием") Тогда
					     ДокументОбъект.БлокироватьВызовПерезаполненияСуммыОплачено = Истина;   
						 
						 Если ТипЗнч(ДокументОплаты) = Тип("ДокументОбъект.ПоступлениеДенежныхСредств") 
							 ИЛИ ТипЗнч(ДокументОплаты) = Тип("ДокументОбъект.СписаниеДенежныхСредств") Тогда 
							 ДокументОбъект.Касса = ДокументОплаты.Касса;
						 КонецЕсли;
						 
					КонецЕсли;
					Если ПерепровестиДокумент(ДокументОбъект) Тогда
						ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
						ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);	
					Иначе
						ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
						ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
					КонецЕсли;
				КонецЕсли;		
			КонецЕсли;		
			Если ЗначениеЗаполнено(РасшифровкаПлатежа[А].ДокументАванса) Тогда	
				Если ТипЗнч(РасшифровкаПлатежа[А].ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда
					ДокументОбъект               = РасшифровкаПлатежа[А].ДокументАванса.ПолучитьОбъект();
					ОстатокЗадолженности         = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьЗадолженностьПоДокументу(РасшифровкаПлатежа[А].ДокументАванса,Неопределено,?(УдалениеПроведения,ДокументОплаты.Ссылка,Неопределено),Истина);
					// Обновляем значение реквизита сумма оплачено
					ДокументОбъект.СуммаОплачено = ДокументОбъект.СуммаДокумента - ОстатокЗадолженности;
					Если ДокументОбъект.СуммаОплачено > 0 Тогда 
						ДокументОбъект.Статус = Перечисления.СтатусыПланЛечения.Принят;
					КонецЕсли;	
					ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
					ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
				ИначеЕсли ТипЗнч(РасшифровкаПлатежа[А].ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда
					ДокументОбъект                        = РасшифровкаПлатежа[А].ДокументАванса.ПолучитьОбъект();
					ОстатокЗадолженностиПередКлиентом     = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьЗадолженностьПоДокументу(РасшифровкаПлатежа[А].ДокументАванса,РасшифровкаПлатежа[А].ДокументАванса.Контрагент,?(УдалениеПроведения,ДокументОплаты.Ссылка,Неопределено),Истина);
					// Обновляем значение реквизита сумма оплачено 
					ДокументОбъект.СуммаОплаченоПродажи   = ДокументОбъект.СуммаПродажи - ОстатокЗадолженностиПередКлиентом; 
					Если ПерепровестиДокумент(ДокументОбъект) Тогда
						ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
						ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);	
					Иначе
						ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
						ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;		
	КонецЕсли;
КонецПроцедуры

