		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	0 КАК ИндексНабора,
	ВЫБОР
		КОГДА ДенежныеСредстваОстаткиИОбороты.Регистратор = НЕОПРЕДЕЛЕНО
			ТОГДА NULL
		ИНАЧЕ ДенежныеСредстваОстаткиИОбороты.Регистратор
	КОНЕЦ КАК Регистратор,
	NULL КАК Статья,
	ДенежныеСредстваОстаткиИОбороты.СуммаНачальныйОстаток,
	ДенежныеСредстваОстаткиИОбороты.СуммаКонечныйОстаток,
	0 КАК СуммаПриход,
	NULL КАК ДоходРасход,
	0 КАК СуммаРасход,
	ДенежныеСредстваОстаткиИОбороты.ПериодДень,
	ДенежныеСредстваОстаткиИОбороты.ПериодНеделя,
	ДенежныеСредстваОстаткиИОбороты.ПериодДекада,
	ДенежныеСредстваОстаткиИОбороты.ПериодМесяц,
	ДенежныеСредстваОстаткиИОбороты.ПериодКвартал,
	ДенежныеСредстваОстаткиИОбороты.ПериодГод,
	ДенежныеСредстваОстаткиИОбороты.ПериодСекунда,
	ДенежныеСредстваОстаткиИОбороты.ПериодМинута,
	ДенежныеСредстваОстаткиИОбороты.ПериодЧас,
	ДенежныеСредстваОстаткиИОбороты.СтруктурнаяЕдиница
ИЗ
	РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты(, , Авто, , ) КАК ДенежныеСредстваОстаткиИОбороты

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	1,
	ВЫБОР
		КОГДА ДенежныеСредства.Регистратор = НЕОПРЕДЕЛЕНО
			ТОГДА NULL
		ИНАЧЕ ДенежныеСредства.Регистратор
	КОНЕЦ,
	ДенежныеСредства.Статья,
	0,
	0,
	ВЫБОР
		КОГДА ДенежныеСредства.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
			ТОГДА ДенежныеСредства.Сумма
		ИНАЧЕ 0
	КОНЕЦ,
	ВЫБОР
		КОГДА ДенежныеСредства.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
			ТОГДА "Доход"
		ИНАЧЕ ВЫБОР
				КОГДА ДенежныеСредства.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
					ТОГДА "Расход"
			КОНЕЦ
	КОНЕЦ,
	ВЫБОР
		КОГДА ДенежныеСредства.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
			ТОГДА ДенежныеСредства.Сумма
		ИНАЧЕ 0
	КОНЕЦ,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ДЕНЬ),
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, НЕДЕЛЯ),
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ДЕКАДА),
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, МЕСЯЦ),
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, КВАРТАЛ),
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ГОД),
	ДенежныеСредства.Период,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ЧАС),
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, МИНУТА),
	ДенежныеСредства.СтруктурнаяЕдиница
ИЗ
	РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
ГДЕ
	ДенежныеСредства.Регистратор.ВидОперации &lt;&gt; ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.СдачаНаличныхВБанк)
	И ДенежныеСредства.Регистратор.ВидОперации &lt;&gt; ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзБанка)
	И ДенежныеСредства.Регистратор.ВидОперации &lt;&gt; ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеОтЭквайера)
	И НЕ ДенежныеСредства.Регистратор ССЫЛКА Документ.ПеремещениеДенежныхСредств
{ГДЕ
	(ДенежныеСредства.Период &gt;= &amp;НачалоПериода),
	(ДенежныеСредства.Период &lt;= &amp;КонецПериода)}</query>
	</dataSet>
