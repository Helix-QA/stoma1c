&НаСервереБезКонтекста
// Функция, возвращает запрос с установленными параметрами, для списка формы.
//
Функция ЗапросПолученияДанных(СтруктураОтборов, Заявка = Неопределено, ИсключаемыеЗаявки = Неопределено)
	
	// Текст запроса без отборов (чистый).
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Заявки.Ссылка КАК Ссылка,
	|	Заявки.Статус КАК Статус,
	|	Заявки.СтатусПациента КАК СтатусПациента,
	|	Заявки.Код КАК Код,
	|	Заявки.Наименование КАК Наименование,
	|	Заявки.ДатаСоздания КАК ДатаСоздания,
	|	Заявки.ДатаОбработки КАК ДатаОбработки,
	|	Заявки.ОсновнойМенеджер.Наименование КАК ОсновнойМенеджерПредставление,
	|	Заявки.ОсновнойМенеджер КАК ОсновнойМенеджер,
	|	ПРЕДСТАВЛЕНИЕ(Заявки.РекламныйИсточник) КАК РекламныйИсточникПредставление,
	|	Заявки.ОсновнойКлиент КАК Клиент,
	|	ПРЕДСТАВЛЕНИЕ(Заявки.ОсновнойКлиент) КАК КлиентПредставление,
	|	ПРЕДСТАВЛЕНИЕ(Заявки.КаналПривлечения) КАК КаналПривлеченияПредставление,
	|	ПРЕДСТАВЛЕНИЕ(Заявки.КаналПривлеченияЗначение) КАК КаналПривлеченияЗначениеПредставление,
	|	ПРЕДСТАВЛЕНИЕ(Заявки.ОценкаЗаявки) КАК ОценкаЗаявкиПредставление,
	|	Заявки.НомерТелефона КАК НомерТелефона,
	|	Заявки.АдресЭП КАК АдресЭП,
	|	Заявки.ПометкаУдаления КАК ПометкаУдаления,
	|	ПРЕДСТАВЛЕНИЕ(Заявки.ВнешняяСистема) КАК ВнешняяСистемаПредставление,
	|	Заявки.Комментарий КАК Комментарий
	|ПОМЕСТИТЬ ДанныеЗаявок
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	&УсловиеПометкаУдаления
	|	И &УсловиеСтатус
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеМенеджер
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеКаналПривлечения
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаОбработки
	|	И &УсловиеСтатусПациента
	|	И &ОтборПоСсылке
	|	И &УсловиеИсключаемыеЗаявки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеЗаявок.Ссылка КАК Ссылка,
	|	СтатусыЗаявок.Ссылка КАК Статус,
	|	ДанныеЗаявок.СтатусПациента КАК СтатусПациента,
	|	ДанныеЗаявок.Код КАК Код,
	|	ДанныеЗаявок.Наименование КАК Наименование,
	|	ДанныеЗаявок.ДатаСоздания КАК ДатаСоздания,
	|	ДанныеЗаявок.ДатаОбработки КАК ДатаОбработки,
	|	ДанныеЗаявок.ОсновнойМенеджерПредставление КАК ОсновнойМенеджерПредставление,
	|	ДанныеЗаявок.ОсновнойМенеджер КАК ОсновнойМенеджер,
	|	ДанныеЗаявок.РекламныйИсточникПредставление КАК РекламныйИсточникПредставление,
	|	ДанныеЗаявок.Клиент КАК Клиент,
	|	ДанныеЗаявок.КлиентПредставление КАК КлиентПредставление,
	|	ДанныеЗаявок.КаналПривлеченияПредставление КАК КаналПривлеченияПредставление,
	|	ДанныеЗаявок.КаналПривлеченияЗначениеПредставление КАК КаналПривлеченияЗначениеПредставление,
	|	ДанныеЗаявок.ОценкаЗаявкиПредставление КАК ОценкаЗаявкиПредставление,
	|	ДанныеЗаявок.НомерТелефона КАК НомерТелефона,
	|	ДанныеЗаявок.АдресЭП КАК АдресЭП,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК Сделка,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка.НаименованиеСокращенное КАК СделкаПредставление,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки КАК ЭтапСделки,
	|	ПРЕДСТАВЛЕНИЕ(КонтрагентыСведенияДляСписка.ТекущийЭтапСделки) КАК ЭтапСделкиПредставление,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ЦветЭтапа КАК ЦветЭтапа,
	|	ДанныеЗаявок.ПометкаУдаления КАК ПометкаУдаления,
	|	ДанныеЗаявок.ВнешняяСистемаПредставление КАК ВнешняяСистемаПредставление,
	|	ДанныеЗаявок.Комментарий КАК Комментарий
	|ИЗ
	|	Перечисление.СтатусыЗаявок КАК СтатусыЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеЗаявок КАК ДанныеЗаявок
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|			ПО ДанныеЗаявок.Клиент = КонтрагентыСведенияДляСписка.Контрагент
	|		ПО СтатусыЗаявок.Ссылка = ДанныеЗаявок.Статус
	|
	|УПОРЯДОЧИТЬ ПО
	|	СтатусыЗаявок.Порядок,
	|	ДатаСоздания УБЫВ
	|ИТОГИ ПО
	|	Статус");
	
	ПрименитьУсловияФильтрации(Запрос, СтруктураОтборов, Заявка, ИсключаемыеЗаявки);
	
	Возврат Запрос;
	
КонецФункции	

&НаСервереБезКонтекста
// Процедура, применяет условия фильтрации к запросу получения данных.
//
Процедура ПрименитьУсловияФильтрации(Запрос, СтруктураОтборов, Заявка = Неопределено, ИсключаемыеЗаявки = Неопределено)
	
	// Устанавливаем отбор по ссылке для получения данных конкретной заявки.
	Если ЗначениеЗаполнено(Заявка) Тогда
		УсловиеСсылка	 = "Заявки.Ссылка = &Ссылка";
		Запрос.Текст	 = СтрЗаменить(Запрос.Текст, "&ОтборПоСсылке", УсловиеСсылка);
		Запрос.Текст	 = СтрЗаменить(Запрос.Текст, "ЛЕВОЕ СОЕДИНЕНИЕ ДанныеЗаявок", "ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеЗаявок");
		Запрос.УстановитьПараметр("Ссылка", Заявка);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоСсылке", "ИСТИНА");
	КонецЕсли;
	
	// Получение первой в очереди на вывод заявки (связано с ограничением - вывод первых 15 заявок в колонку).
	Если ЗначениеЗаполнено(ИсключаемыеЗаявки) Тогда
		
		УсловиеИсключаемыеЗаявки = "НЕ Заявки.Ссылка В(&ИсключаемыеЗаявки)";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеИсключаемыеЗаявки", УсловиеИсключаемыеЗаявки);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБРАТЬ РАЗРЕШЕННЫЕ", "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЛЕВОЕ СОЕДИНЕНИЕ ДанныеЗаявок", "ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеЗаявок");
		
		Запрос.УстановитьПараметр("ИсключаемыеЗаявки", ИсключаемыеЗаявки);
		
		УсловиеСтатус	 = "Заявки.Статус = &Статус";
		Запрос.Текст	 = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус" + Символы.ПС, УсловиеСтатус + Символы.ПС);
		Запрос.УстановитьПараметр("Статус", СтруктураОтборов.Статус);
		
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеИсключаемыеЗаявки", "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус" + Символы.ПС, "ИСТИНА" + Символы.ПС);
		
	КонецЕсли;
	
	// Отбор пометка удаления.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборПометкаУдаления)
		И СтруктураОтборов.ОтборПометкаУдаления[0].Значение = Истина Тогда
		
		УсловиеПометкаУдаления = СтруктураОтборов.ОтборПометкаУдаления.ДоступныеЗначения[0].Представление + "Заявки.ПометкаУдаления = ИСТИНА";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", УсловиеПометкаУдаления);
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПометкаУдаления", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор структурная единица.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Заявки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Если СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.Количество() <> 0 Тогда 
			ВариантОтбора = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление;
		Иначе 
			ВариантОтбора = "";
		КонецЕсли;			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", ВариантОтбора + "Заявки.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)");			
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения());				
		// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;
	
	// Отбор менеджер.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер) Тогда
		УсловиеМенеджер = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения[0].Представление + "Заявки.ОсновнойМенеджер В (&ОтборМенеджер)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", УсловиеМенеджер);
		Запрос.УстановитьПараметр("ОтборМенеджер", СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор рекламный источник.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник) Тогда
		УсловиеРекламныйИсточник = СтруктураОтборов.ОтборРекламныйИсточник.ДоступныеЗначения[0].Представление + "Заявки.РекламныйИсточник В (&ОтборРекламныйИсточник)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		Запрос.УстановитьПараметр("ОтборРекламныйИсточник", СтруктураОтборов.ОтборРекламныйИсточник.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", "ИСТИНА");
	КонецЕсли;
	
	// Отбор канал привлечения.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборКаналПривлечения) Тогда
		УсловиеКаналПривлечения = СтруктураОтборов.ОтборКаналПривлечения.ДоступныеЗначения[0].Представление + "Заявки.КаналПривлечения В (&ОтборКаналПривлечения)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", УсловиеКаналПривлечения);
		Запрос.УстановитьПараметр("ОтборКаналПривлечения", СтруктураОтборов.ОтборКаналПривлечения.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеКаналПривлечения", "ИСТИНА");
	КонецЕсли;
	
	// Отбор сотрудник регистрации.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации) Тогда
		УсловиеСотрудникРегистрации = СтруктураОтборов.ОтборСотрудникРегистрации.ДоступныеЗначения[0].Представление + "Заявки.Автор В (&ОтборСотрудникРегистрации)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
		Запрос.УстановитьПараметр("ОтборСотрудникРегистрации", СтруктураОтборов.ОтборСотрудникРегистрации.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор дата создания.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаСоздания) Тогда   
		УсловиеДатаСоздания = "Заявки.ДатаСоздания МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", УсловиеДатаСоздания);
		ДатаНачала = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", "ИСТИНА")
	КонецЕсли;
	
	// Отбор дата обработки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаОбработки) Тогда   
		УсловиеДатаОбработки = "Заявки.ДатаОбработки МЕЖДУ &ДатаОбработкиДатаНачала И &ДатаОбработкиДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаОбработки", УсловиеДатаОбработки);
		ДатаНачала = СтруктураОтборов.ОтборДатаОбработки[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаОбработки[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаОбработкиДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаОбработкиДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаОбработки", "ИСТИНА")
	КонецЕсли;
	
	// Отбор статус пациента.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтатусПациента) Тогда
		УсловиеСтатусПациента = СтруктураОтборов.ОтборСтатусПациента.ДоступныеЗначения[0].Представление + "Заявки.СтатусПациента В (&ОтборСтатусПациента)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатусПациента", УсловиеСтатусПациента);
		Запрос.УстановитьПараметр("ОтборСтатусПациента", СтруктураОтборов.ОтборСтатусПациента.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатусПациента", "ИСТИНА")
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает пакет запроса с элементами для создания отборов.
//
Функция ПолучитьПакетЗапросаЗначенийДляОтборов()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыЗаявок.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СтатусыЗаявок.Ссылка) КАК Представление
	|ИЗ
	|	Перечисление.СтатусыЗаявок КАК СтатусыЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СотрудникиМестаРаботы.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СотрудникиМестаРаботы.Ссылка) КАК Представление
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СотрудникиМестаРаботы
	|ГДЕ
	|	СотрудникиМестаРаботы.ПометкаУдаления = ЛОЖЬ
	|	И СотрудникиМестаРаботы.ЭтоГруппа = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Заявки.ОсновнойМенеджер КАК Ссылка,
	|	Заявки.ОсновнойМенеджер.Представление КАК Представление
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	НЕ Заявки.ОсновнойМенеджер.ПометкаУдаления
	|	И Заявки.ОсновнойМенеджер <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РекламныеИсточники.Ссылка КАК Ссылка,
	|	РекламныеИсточники.Представление КАК Представление
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Заявки.Автор КАК Ссылка,
	|	Заявки.Автор.Представление КАК Представление
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	НЕ Заявки.Автор.ПометкаУдаления
	|	И Заявки.Автор <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РекламныеИсточники.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.РекламныеИсточники КАК РекламныеИсточники
	|ГДЕ
	|	РекламныеИсточники.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КаналыПривлечения.Ссылка КАК Ссылка,
	|	КаналыПривлечения.Представление КАК Представление
	|ИЗ
	|	Справочник.КаналыПривлечения КАК КаналыПривлечения
	|ГДЕ
	|	НЕ КаналыПривлечения.ПометкаУдаления");
	
	Возврат Запрос.ВыполнитьПакет();
		
КонецФункции

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ОбновитьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОчиститьФильтры = Ложь)
	
	Для каждого Строка из ТаблицаФильтров Цикл
		Строка.Инициализирован = Ложь;
	КонецЦикла;
	
	МассивИменОчищаемыхФильтров = Новый Массив();
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СотрудникРегистрации");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_РекламныйИсточник");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_КаналПривлечения");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СозданаПериод");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ДатаОбработки");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПометкаУдаленияЗаявки");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_Менеджер");
	МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтатусПациента");
	
	УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	
	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов();	
	
	// Отбор статус.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусов");	
	ОбновитьДинамическоеМенюФильтрации_Статус(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусов_ВариантОтбора"), ПараметрыОтбора.МассивСтатусов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусов, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор структурная единица.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц");	
	ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц_ВариантОтбора"), ПараметрыОтбора.МассивСтруктурныхЕдиниц_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина,,, ВариантОтбора);		
	КонецЕсли;
	
	// Отбор сотрудника регистрации.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСотрудниковРегистрации");
	ОбновитьДинамическоеМенюФильтрации_СотрудникРегистрации(РезультатПакетногоЗапроса[4].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСотрудниковРегистрации_ВариантОтбора"), ПараметрыОтбора.МассивСотрудниковРегистрации_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СотрудникРегистрации", ПараметрыОтбора.МассивСотрудниковРегистрации, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор рекламного источника.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивРекламныхИсточников");
	ОбновитьДинамическоеМенюФильтрации_РекламныйИсточник(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивРекламныхИсточников_ВариантОтбора"), ПараметрыОтбора.МассивРекламныхИсточников_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_РекламныйИсточник", ПараметрыОтбора.МассивРекламныхИсточников, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор канал привлечения.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКаналовПривлечения");
	ОбновитьДинамическоеМенюФильтрации_КаналПривлечения(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКаналовПривлечения_ВариантОтбора"), ПараметрыОтбора.МассивКаналовПривлечения_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КаналПривлечения", ПараметрыОтбора.МассивКаналовПривлечения, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор пометка удаления сделки.         
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления"); 
	ОбновитьДинамическоеМенюФильтрации_ПометкаУдаленияЗаявки(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления_ВариантОтбора"), ПараметрыОтбора.СписокСтатусовПометокУдаления_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияЗаявки", ПараметрыОтбора.СписокСтатусовПометокУдаления, Истина,,, ВариантОтбора);				
	КонецЕсли;
	
	// Отбор менеджеров.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивМенеджеров"); 
	ОбновитьДинамическоеМенюФильтрации_Менеджер(РезультатПакетногоЗапроса[2].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивМенеджеров_ВариантОтбора"), ПараметрыОтбора.МассивМенеджеров_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", ПараметрыОтбора.МассивМенеджеров, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;
	
	// Отбор дата создания.	
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодСозданияСделки");
	ОбновитьДинамическоеМенюФильтрации_СозданаПериод(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СозданаПериод", ПараметрыОтбора.ПериодСозданияСделки);	
	КонецЕсли;
	
	// Отбор дата обработки.	
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодОбработки");
	ОбновитьДинамическоеМенюФильтрации_ДатаОбработки(, УстановитьОтбор);
