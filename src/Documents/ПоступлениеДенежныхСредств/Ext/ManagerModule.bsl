// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ

// Процедура печати документа.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "КО1") Тогда		
			
			УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм,
			"КО1",
			"Поступление денежных средств",
			СформироватьПечатнуюФормуКО1(МассивОбъектов, ОбъектыПечати)
			);
			
	КонецЕсли;
	
КонецПроцедуры // Печать()
 
// Функция формирует табличный документ с печатной формой приходного кассового ордера.
//
// Возвращаемое значение:
//  Табличный документ - печатная форма приходного кассового ордера
//
Функция СформироватьПечатнуюФормуКО1(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПоступлениеДенежныхСредств.ПФ_MXL_КО1");
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	ДанныеДокумента.Ссылка КАК Ссылка,
	                      |	ДанныеДокумента.Дата КАК ДатаДокумента,
	                      |	ДанныеДокумента.Номер КАК Номер,
	                      |	ДанныеДокумента.Контрагент КАК Контрагент,
	                      |	ДанныеДокумента.Контрагент.Представление КАК КонтрагентПредставление,
	                      |	ДанныеДокумента.Контрагент КАК ПринятоОт,						  
	                      |	ДанныеДокумента.СтруктурнаяЕдиница.Организация КАК Организация,
	                      |	ДанныеДокумента.СтруктурнаяЕдиница.Организация КАК НименованиеОрганизации,
	                      |	ДанныеДокумента.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
	                      |	ДанныеДокумента.СтруктурнаяЕдиница.Организация.КодПоОКПО КАК ОрганизацияПоОКПО,
	                      |	ДанныеДокумента.СуммаДокумента КАК Сумма,
	                      |	ДанныеДокумента.АвторДокумента.Наименование КАК ФИОКассира,
	                      |	ДанныеДокумента.АвторДокумента.Ссылка КАК АвторДокументаСсылка,						  
	                      |	ДанныеДокумента.ТипДенежныхСредств КАК ТипДенежныхСредств
	                      |ИЗ
	                      |	Документ.ПоступлениеДенежныхСредств КАК ДанныеДокумента
	                      |ГДЕ
	                      |	ДанныеДокумента.Ссылка В(&МассивДокументов)
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	ДанныеДокумента.Номер");
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Выборка);
		
		ОбластьМакета.Параметры.СуммаТекВал = "Сумма" + Символы.ПС + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты() + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодДробнойчастВалюты();
		ОбластьМакета.Параметры.СчетДебет="50.01";
		Если Выборка.Ссылка.ВидОперации =Перечисления.ВидыОпераций.ВзносНаЛицевойСчет Тогда
			
			ОбластьМакета.Параметры.СубСчет="60.01,60.02";
		ИначеЕсли Выборка.Ссылка.ВидОперации =Перечисления.ВидыОпераций.ВозвратПоставщику 
			ИЛИ Выборка.Ссылка.ВидОперации =Перечисления.ВидыОпераций.ОплатаОтКлиента Тогда
			
			ОбластьМакета.Параметры.СубСчет="62.01,62.02";
		ИначеЕсли Выборка.Ссылка.ВидОперации =Перечисления.ВидыОпераций.ПоступлениеИзБанка Тогда
			
		//	ОбластьМакета.Параметры.СубСчет="51";
		// ИначеЕсли Выборка.Ссылка.ВидОперации =Перечисления.ВидыОпераций.ПоступлениеИзКассыККМ Тогда
			
			ОбластьМакета.Параметры.СубСчет="50.2";
		ИначеЕсли Выборка.Ссылка.ВидОперации =Перечисления.ВидыОпераций.ВозвратОтПодотчетника Тогда
			
			ОбластьМакета.Параметры.СубСчет="71.01";
		Иначе
			
			ОбластьМакета.Параметры.СубСчет="91.01";
		КонецЕсли;	  
		
		// Если Не ПустаяСтрока(Выборка.НаименованиеОрганизацииСокращенное) Тогда
		//	ОбластьМакета.Параметры.ПредставлениеОрганизации = Выборка.НаименованиеОрганизацииСокращенное;
		// Иначе
		СведенияОбОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Организация, Выборка.ДатаДокумента), "ОфициальноеНаименование");
		ОбластьМакета.Параметры.ПредставлениеОрганизации = СведенияОбОрганизации; 
		// ОбластьМакета.Параметры.ПредставлениеПодразделения=Выборка.Ссылка.СтруктурнаяЕдиница;
		
		// КонецЕсли;
		
		Сумма = Формат(Выборка.Сумма, "ЧЦ=15; ЧДЦ=2");
		// ВалютаРегламентированногоУчета = ЗначениеНастроекПовтИсп.ПолучитьЗначениеКонстанты("ВалютаРегламентированногоУчета");
		// Если ВалютаРегламентированногоУчета <> Выборка.Валюта Тогда
		//	Сумма = Сумма + " " + СокрЛП(Выборка.ВалютаПредставление);
		// КонецЕсли;
		ОбластьМакета.Параметры.Сумма = Сумма;
		ОбластьМакета.Параметры.СуммаРубКоп = ФормированиеПечатныхФорм.СуммаРубКоп(
			Выборка.Сумма, 
			// Выборка.Валюта,	
			,// ВалютаРегламентированногоУчета
		);
		ОбластьМакета.Параметры.СуммаПрописью  
		= ФормированиеПечатныхФорм.СформироватьСуммуПрописью(
			Выборка.Сумма, 
			// Выборка.Валюта, 
			,Ложь // ВыводитьСуммуБезКопеек
		);
		ОбластьМакета.Параметры.НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(
		Выборка.Номер, 
		Выборка.Префикс
		);
		
		ЗапросОснование = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		                               |	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования КАК ДокументОснования,
		                               |	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументАванса КАК ДокументАванса,
		                               |	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс КАК ЭтоАванс
		                               |ИЗ
		                               |	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
		                               |ГДЕ
		                               |	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка = &Ссылка");
		
		ЗапросОснование.УстановитьПараметр("Ссылка", Выборка.Ссылка);
		МассивДокументовОснования = ЗапросОснование.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументОснования");
		Основание = ЗапросОснование.Выполнить().Выбрать();							  
		
		Если Основание.Следующий() Тогда 
			Если Основание.ДокументОснования <> Неопределено Тогда
				ОбластьМакета.Параметры.Основание = Строка(ТипЗнч(Основание.ДокументОснования)) + " №" + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Основание.ДокументОснования.Номер, Истина, Истина) + " от " + Формат(Основание.ДокументОснования.Дата, "ДФ=dd.MM.yyyy");
			ИначеЕсли Основание.ЭтоАванс И ЗначениеЗаполнено(Основание.ДокументАванса) Тогда 
				ОбластьМакета.Параметры.Основание = Строка(ТипЗнч(Основание.ДокументАванса)) + " №" + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Основание.ДокументАванса.Номер, Истина, Истина) + " от " + Формат(Основание.ДокументАванса.Дата, "ДФ=dd.MM.yyyy");
			КонецЕсли;	
		КонецЕсли;
		
		ВТомЧислеНДС = ДенежныеСредстваСервер.ТекстСуммаНДСПлатежа(Выборка.Сумма, , МассивДокументовОснования, Ложь);		
		Если ПустаяСтрока(ВТомЧислеНДС) Тогда
			ОбластьМакета.Параметры.ВТомЧисле = "без налога (НДС)";
		Иначе 
			ОбластьМакета.Параметры.ВТомЧисле = ВТомЧислеНДС;
		КонецЕсли;
		
		ГлавБух = ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Выборка.Организация, Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер, Выборка.ДатаДокумента);
		Если ГлавБух.Количество() > 0 Тогда 
			ОбластьМакета.Параметры.ФИОГлавногоБухгалтера = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(ГлавБух[0].Сотрудник));
		КонецЕсли;	
		
		Кассир = ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Выборка.Организация, Перечисления.ТипыОтветственныхЛиц.Кассир, Выборка.ДатаДокумента);
		Если Кассир.Количество() > 0 Тогда 
			ОбластьМакета.Параметры.ФИОКассира = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(Кассир[0].Сотрудник));
		ИначеЕсли Выборка.АвторДокументаСсылка <> Справочники.Сотрудники.ПустаяСсылка() Тогда
			ОбластьМакета.Параметры.ФИОКассира = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(Выборка.АвторДокументаСсылка)); 
		КонецЕсли;	
		
		// ОбластьМакета.Параметры.ФИОГлавногоБухгалтера = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Выборка.ГлавныйБухгалтер);
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
		ТабличныйДокумент,
		НомерСтрокиНачало,
		ОбъектыПечати,
		Выборка.Ссылка
		);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуКО1()

#КонецОбласти

#КонецЕсли
