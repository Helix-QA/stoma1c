// Функция, ПолучитьВидыСделок.
//
Функция ПолучитьВидыСделок(Клиент = Неопределено, СтруктурнаяЕдиница = Неопределено)
	
	Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Клиент) Тогда
		ДоступныеВидыСделок = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(СтруктурнаяЕдиница, Клиент,,,,, Истина);
	Иначе
		ДоступныеВидыСделок = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(СтруктурнаяЕдиница, Неопределено,,,, Истина, Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыСделок.Ссылка КАК Ссылка,
	|	ВидыСделок.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Ссылка В (&ДоступныеВидыСделок)");
	
	Запрос.УстановитьПараметр("ДоступныеВидыСделок", ДоступныеВидыСделок);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Новый СписокЗначений;
	
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка, Выборка.Наименование);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
// Функция, создает новую сделку клиенту.
//
Функция СоздатьСделку(Клиент, ВидСделки)
		
	Если НЕ ЗначениеЗаполнено(Клиент)
		И НЕ ЗначениеЗаполнено(ВидСделки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НоваяСделка   = Справочники.Сделки.СоздатьЭлемент();		
	ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(ВидСделки);
	
	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("Контрагент"					, Клиент);
	ДанныеЗаполнения.Вставить("ВидСделки"					, ВидСделки);
	ДанныеЗаполнения.Вставить("Заявка"						, Объект.Ссылка);
	ДанныеЗаполнения.Вставить("ЭтапСделки"					, ?(ТаблицаЭтапов.Количество()> 0, ТаблицаЭтапов[0].ЭтапСделки, Неопределено));
	ДанныеЗаполнения.Вставить("ДатаСделки"					, ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("СтруктурнаяЕдиница"			, ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
	ДанныеЗаполнения.Вставить("ИсточникИнформации"			, Объект.РекламныйИсточник);
	ДанныеЗаполнения.Вставить("ИсточникИнформацииЗначение"	, Объект.ИсточникИнформацииЗначение);
	ДанныеЗаполнения.Вставить("КаналПривлечения"			, Объект.КаналПривлечения);
	ДанныеЗаполнения.Вставить("КаналПривлеченияЗначение"	, Объект.КаналПривлеченияЗначение);
	
	НоваяСделка.Заполнить(ДанныеЗаполнения);
	
	Попытка
		
		НоваяСделка.Записать();
		СоздатьВиджетСделки();
		Возврат НоваяСделка.Ссылка;
		
	Исключение
		
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось создать сделку'; en = 'Failed to create a deal.'"));
		
	КонецПопытки;
		
КонецФункции

