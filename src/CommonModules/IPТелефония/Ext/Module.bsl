// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция CoMagic_ТестированиеСервера(Сервер, Порт, Логин, КлючПродукта, ОписаниеОшибки = "") Экспорт

	СтруктураПараметров = Новый Структура("id, method, jsonrpc, params", "null", "list.calls", "2.0", Новый Структура());
	СтруктураПараметров.params.Вставить("access_token", КлючПродукта);
		
	JSONЗапрос = КодироватьВJSON(СтруктураПараметров, Ложь); 
	
	ПОПЫТКА
		
		СерверАдрес = ПреобразоватьАдресСервера(Сервер);
	
		// Создаем прокси для обращения к внешнему веб-сервису, передаем в функцию URI пространства имен, имя сервиса и порта.
		// SSL = Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаWindows(), Новый СертификатыУдостоверяющихЦентровWindows());
		SSL = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);
		HTTPСоединение = Новый HTTPСоединение(СерверАдрес, , , , , , SSL);
		
		// Создаем и устанавливаем данные в HTTP запрос
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json; charset=UTF-8");
		ЗаголовкиHTTP.Вставить("Content-Charset", "utf-8");
		
		// Формируем HTTP запрос
		HTTPЗапрос = Новый HTTPЗапрос("/v4.0", ЗаголовкиHTTP);	
		HTTPЗапрос.УстановитьТелоИзСтроки(JSONЗапрос);
		
		// Ответ от сервера получим в возвращаемом значении типа HTTPОтвет
		HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			ОписаниеОшибки = НСтр("ru= 'Ошибка ';en= 'Error '") + HTTPОтвет.КодСостояния;
			Возврат Ложь;
		КонецЕсли;
				
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
		
	Возврат Истина;
	
КонецФункции

// Функция - CoMagic событие звонок
// 
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция CoMagic_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
	
	УнифицированнаяСтруктураСобытия.НаправлениеВызова 			= ?(ПараметрыJSON.Свойство("direction") И ПараметрыJSON.direction = "out"
									ИЛИ (ПараметрыJSON.Свойство("call_info") И ПараметрыJSON.call_info.Свойство("direction") И ПараметрыJSON.call_info.direction = "out")
							ИЛИ ПараметрыJSON.Method = "AppearedOut", Перечисления.ВариантыНаправленияВызова.Исходящий, Перечисления.ВариантыНаправленияВызова.Входящий);
							
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий Тогда 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= ПараметрыJSON.Свойство("call_info") И ПараметрыJSON.call_info.Свойство("talk_time_duration") И ПараметрыJSON.call_info.talk_time_duration = 0;
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;						
	КонецЕсли;
		
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Исходящий Тогда 
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= ?(ПараметрыJSON.employee_info.Свойство("employee_phone_number"), СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.employee_info.employee_phone_number)))), Неопределено);
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.contact_info.contact_phone_number))));
		УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника 	= УнифицированнаяСтруктураСобытия.НомерТелефонаFrom;
		УнифицированнаяСтруктураСобытия.НомерКонтрагента 			= УнифицированнаяСтруктураСобытия.НомерТелефонаTo;		
	Иначе 
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.contact_info.contact_phone_number))));
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ?(ПараметрыJSON.employee_info.Свойство("employee_phone_number"), СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(СокрЛП(Строка(ПараметрыJSON.employee_info.employee_phone_number)))), Неопределено);
		УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника 	= УнифицированнаяСтруктураСобытия.НомерТелефонаTo;		
		УнифицированнаяСтруктураСобытия.НомерКонтрагента 			= УнифицированнаяСтруктураСобытия.НомерТелефонаFrom;		
	КонецЕсли;	
	
	Если ПараметрыJSON.Method = "Appeared" Тогда
		УнифицированнаяСтруктураСобытия.IDЗвонка 				= Формат(ПараметрыJSON.call_session_id, "ЧРД=; ЧРГ=; ЧН=0; ЧГ=");		
		// УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Входящий;
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 			= Перечисления.СтатусыЗвонка.Вызов;		
		ВремяПоступленияВызова                                  = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.notification_time);
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 	= ?(ЗначениеЗаполнено(ВремяПоступленияВызова), ВремяПоступленияВызова, ТекущаяДатаСеанса());
		
		Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли ПараметрыJSON.Method = "AppearedOut" Тогда
		УнифицированнаяСтруктураСобытия.IDЗвонка 				= Формат(ПараметрыJSON.call_session_id, "ЧРД=; ЧРГ=; ЧН=0; ЧГ=");		
		// УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Исходящий;						
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 			= Перечисления.СтатусыЗвонка.Вызов;
		ВремяПоступленияВызова                                  = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.notification_time);
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова 	= ?(ЗначениеЗаполнено(ВремяПоступленияВызова), ВремяПоступленияВызова, ТекущаяДатаСеанса());
		
		Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли ПараметрыJSON.Method = "Connected" Тогда
		УнифицированнаяСтруктураСобытия.IDЗвонка 				= Формат(ПараметрыJSON.call_session_id, "ЧРД=; ЧРГ=; ЧН=0; ЧГ=");				
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 			= Перечисления.СтатусыЗвонка.Разговор; 		
		ВремяОтветаНаВызов                                      = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.notification_time);
		УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 	    = ?(ЗначениеЗаполнено(ВремяОтветаНаВызов), ВремяОтветаНаВызов, ТекущаяДатаСеанса());  		
		УнифицированнаяСтруктураСобытия.РекламныйИсточник 		= ?(ПараметрыJSON.Свойство("campaign_name") И ЗначениеЗаполнено(ПараметрыJSON.campaign_name), ПолучитьСоздатьРекламныйИсточник(ПараметрыJSON.campaign_name), Неопределено);
		
		Возврат СобытиеЗвонокСоединение(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли ПараметрыJSON.Method = "Disconnected" Тогда
		УнифицированнаяСтруктураСобытия.IDЗвонка 					= Формат(ПараметрыJSON.call_info.call_session_id, "ЧРД=; ЧРГ=; ЧН=0; ЧГ=");				
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 				= ?(УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий И УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен, Перечисления.СтатусыЗвонка.Пропущен, Перечисления.СтатусыЗвонка.Завершен);
		ВремяЗавершенияВызова                                       = ПривестиСтрокуВДатаCoMagic(ПараметрыJSON.notification_time);
		УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова 	    = ?(ЗначениеЗаполнено(ВремяЗавершенияВызова), ВремяЗавершенияВызова, ТекущаяДатаСеанса());  		
		УнифицированнаяСтруктураСобытия.ПринятДругимАбонентомГруппы = Ложь;
		
		Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);		
		
	ИначеЕсли ПараметрыJSON.Method = "RecordingFanal" Тогда
		УнифицированнаяСтруктураСобытия.IDЗвонка 				= Формат(ПараметрыJSON.call_session_id, "ЧРД=; ЧРГ=; ЧН=0; ЧГ=");				
		УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 		= Неопределено;
		УнифицированнаяСтруктураСобытия.НомерТелефонаTo   		= Неопределено;
		УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Неопределено;
		УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка 	= ?(ТипЗнч(ПараметрыJSON.call_record_file_info.file_link) = Тип("Массив") И ПараметрыJSON.call_record_file_info.file_link.Количество() > 0, ПараметрыJSON.call_record_file_info.file_link[0], ПараметрыJSON.call_record_file_info.file_link);
		
		Возврат ДобавитьОбновитьЗвонокВИсторию(ПараметрыJSON, УнифицированнаяСтруктураСобытия);
						
	Иначе
		ОписаниеОшибки = НСтр("ru= 'Функция не существует или не распознана.';en= 'The function does not exist or is not recognized.'");
		Возврат Ложь;
	
	КонецЕсли; 
	
КонецФункции

// Функция - Исходящий звонок осуществить
// 
// Параметры:
//  ПОIPТелефонии	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  Контрагент				 - 	 - 
//  Сотрудник				 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция CoMagic_ИсходящийЗвонокОсуществить(ПОIPТелефонии, ВнутреннийНомерТелефона, ВнешнийНомерТелефона, ОписаниеОшибки = "")
		
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	Если IPТелефонияПараметры = Неопределено ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
			ИЛИ IPТелефонияПараметры.Свойство("Сервер") = Ложь ИЛИ IPТелефонияПараметры.Свойство("Логин") = Ложь ИЛИ IPТелефонияПараметры.Свойство("Ключ") = Ложь Тогда
		ОписаниеОшибки = НСтр("ru= 'Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.';en= 'Error! It is necessary to configure the IP-telephony server in the connected equipment.'");
		Возврат Ложь;
	КонецЕсли;
	
	ВнутреннийНомерТелефонаСсылка = Справочники.ТелефонныеАппараты.НайтиПоРеквизиту("ВнутреннийНомер", ВнутреннийНомерТелефона);
	Если НЕ (ЗначениеЗаполнено(ВнутреннийНомерТелефонаСсылка.Родитель) И ЗначениеЗаполнено(ВнутреннийНомерТелефонаСсылка.Родитель.ВнутреннийНомер)) Тогда
		ОписаниеОшибки = НСтр("ru= 'Ошибка! телефонный номер обязательно должен быть в группе с указанным номером (Виртуальный номер, арендуемый клиентом).';en= 'Error! the phone number must be in the group with the specified number (Virtual number rented by the client).'");
		Возврат Ложь;		
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура("id, method, jsonrpc, params", "null", "start.simple_call", "2.0", Новый Структура());
	СтруктураПараметров.params.Вставить("access_token", 		IPТелефонияПараметры.Ключ);
	СтруктураПараметров.params.Вставить("direction", 			"out");
	СтруктураПараметров.params.Вставить("first_call", 			"operator");
	СтруктураПараметров.params.Вставить("switch_at_once", 		Истина);
	СтруктураПараметров.params.Вставить("early_switching", 		Истина);
	СтруктураПараметров.params.Вставить("virtual_phone_number", ВнутреннийНомерТелефонаСсылка.Родитель.ВнутреннийНомер);
	СтруктураПараметров.params.Вставить("contact", 				ВнешнийНомерТелефона);
	СтруктураПараметров.params.Вставить("operator",				ВнутреннийНомерТелефона);
	
	JSONЗапрос = КодироватьВJSON(СтруктураПараметров, Ложь);
	
	Попытка
		
		СерверАдрес = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
		
		// Создаем прокси для обращения к внешнему веб-сервису, передаем в функцию URI пространства имен, имя сервиса и порта.
		// SSL = Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаWindows(), Новый СертификатыУдостоверяющихЦентровWindows());
		SSL = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);
		HTTPСоединение = Новый HTTPСоединение(СерверАдрес,,,,, 120, SSL);
		
		// Создаем и устанавливаем данные в HTTP запрос
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json; charset=UTF-8");
		ЗаголовкиHTTP.Вставить("Content-Charset", "utf-8");
		
		// Формируем HTTP запрос
		HTTPЗапрос = Новый HTTPЗапрос("/v4.0", ЗаголовкиHTTP);	
		HTTPЗапрос.УстановитьТелоИзСтроки(JSONЗапрос);
		
		// Ответ от сервера получим в возвращаемом значении типа HTTPОтвет
		HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			ОписаниеОшибки = НСтр("ru= 'Ошибка сервиса IP-телефонии ';en= 'IP-telephony service error: '") + HTTPОтвет.КодСостояния;
			Возврат Ложь;
		КонецЕсли;
		
		// Разбор ответа
		JSONОтвет = ДекодироватьИзJSON(HTTPОтвет.ПолучитьТелоКакСтроку());
		Если JSONОтвет.Свойство("error") И ТипЗнч(JSONОтвет.error) = Тип("Структура") Тогда
			ОписаниеОшибки = НСтр("ru= 'Ошибка при выполнении операции сервиса IP-телефонии: ';en= 'Error performing IP-telephony service operation: '") + JSONОтвет.error.code + ", " + JSONОтвет.error.message;
			Возврат Ложь;
		КонецЕсли; 		
		
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
		
	Возврат Истина;

КонецФункции

// Функция - Co magic перевод текущего звонка
// 
// Параметры:
//  ПОIPТелефонии			 - 	 - 
//  ВнутреннийНомерТелефона	 - 	 - 
//  ВнешнийНомерТелефона	 - 	 - 
//  ОписаниеОшибки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция CoMagic_ПереводТекущегоЗвонка(ПОIPТелефонии, call_session_id, НаНомерТелефона, ОписаниеОшибки = "")
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	Если IPТелефонияПараметры = Неопределено ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ IPТелефонияПараметры.Свойство("Сервер") = Ложь ИЛИ IPТелефонияПараметры.Свойство("Логин") = Ложь ИЛИ IPТелефонияПараметры.Свойство("Ключ") = Ложь Тогда
		ОписаниеОшибки = НСтр("ru= 'Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.';en= 'Error! It is necessary to configure the IP-telephony server in the connected equipment.'");
		Возврат Ложь;
	КонецЕсли;
	
	// hold.call
	СтруктураПараметров = Новый Структура("id, method, jsonrpc, params", "null", "hold.call", "2.0", Новый Структура());
	СтруктураПараметров.params.Вставить("access_token",      	 IPТелефонияПараметры.Ключ);
	СтруктураПараметров.params.Вставить("call_session_id", 		 call_session_id); 
	СтруктураПараметров.params.Вставить("contact_message", 		 Новый Структура());
	СтруктураПараметров.params.contact_message.Вставить("type",  "media");
	СтруктураПараметров.params.contact_message.Вставить("value", "2034");
	
	Если CoMagic_СформироватьИОтправитьЗапрос(IPТелефонияПараметры, СтруктураПараметров, ОписаниеОшибки) Тогда
		
		// make.call
		СтруктураПараметров = Новый Структура("id, method, jsonrpc, params", "null", "make.call", "2.0", Новый Структура());
		СтруктураПараметров.params.Вставить("access_token",    IPТелефонияПараметры.Ключ);
		СтруктураПараметров.params.Вставить("call_session_id", call_session_id); 
		СтруктураПараметров.params.Вставить("to", 		 	   НаНомерТелефона);
		Если CoMagic_СформироватьИОтправитьЗапрос(IPТелефонияПараметры, СтруктураПараметров, ОписаниеОшибки) Тогда    			
			
			// transfer.talk
			СтруктураПараметров = Новый Структура("id, method, jsonrpc, params", "null", "transfer.talk", "2.0", Новый Структура());
			СтруктураПараметров.params.Вставить("access_token",    IPТелефонияПараметры.Ключ);
			СтруктураПараметров.params.Вставить("call_session_id", call_session_id);	
			
			Если CoMagic_СформироватьИОтправитьЗапрос(IPТелефонияПараметры, СтруктураПараметров, ОписаниеОшибки) Тогда
				Возврат Истина;		
			КонецЕсли;
			
		КонецЕсли; 
		
	КонецЕсли; 	
	
	Возврат Ложь;
	
КонецФункции

// Функция - Co magic сформировать и отправить запрос
// 
// Параметры:
//  IPТелефонияПараметры - 	 - 
//  СтруктураПараметров	 - 	 - 
//  ОписаниеОшибки		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция CoMagic_СформироватьИОтправитьЗапрос(IPТелефонияПараметры, СтруктураПараметров, ОписаниеОшибки = "")
	
	JSONЗапрос = КодироватьВJSON(СтруктураПараметров, Ложь);
	
	Попытка
		
		СерверАдрес = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
		
		// Создаем прокси для обращения к внешнему веб-сервису, передаем в функцию URI пространства имен, имя сервиса и порта.
		// SSL = Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаWindows(), Новый СертификатыУдостоверяющихЦентровWindows());
		SSL = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);
		HTTPСоединение = Новый HTTPСоединение(СерверАдрес,,,,, 120, SSL);
		
		// Создаем и устанавливаем данные в HTTP запрос
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json; charset=UTF-8");
		ЗаголовкиHTTP.Вставить("Content-Charset", "utf-8");
		
		// Формируем HTTP запрос
		HTTPЗапрос = Новый HTTPЗапрос("/v4.0", ЗаголовкиHTTP);	
		HTTPЗапрос.УстановитьТелоИзСтроки(JSONЗапрос);
		
		// Ответ от сервера получим в возвращаемом значении типа HTTPОтвет
		HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			ОписаниеОшибки = НСтр("ru= 'Ошибка сервиса IP-телефонии ';en= 'IP-telephony service error: '") + HTTPОтвет.КодСостояния;
			Возврат Ложь;
		КонецЕсли;
		
		// Разбор ответа
		JSONОтвет = ДекодироватьИзJSON(HTTPОтвет.ПолучитьТелоКакСтроку());
		Если JSONОтвет.Свойство("result") И ТипЗнч(JSONОтвет.result) = Тип("Структура") 
			И JSONОтвет.result.Свойство("data") И ТипЗнч(JSONОтвет.result.data) = Тип("Структура") 
			И JSONОтвет.result.data.Свойство("success") И JSONОтвет.result.data.success = "false" Тогда
			ОписаниеОшибки = НСтр("ru= 'Ошибка при выполнении операции сервиса IP-телефонии';en= 'Error performing IP-telephony service operation'");
			Возврат Ложь;
		КонецЕсли; 		
		
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

