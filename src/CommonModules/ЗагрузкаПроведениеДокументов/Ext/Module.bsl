	               |	Таблица_Контракты.НомерКонтракта КАК НомерКонтракта,
	               |	Таблица_Контракты.КартаКлиента КАК КартаКлиента,
	               |	Таблица_Контракты.КартаНомер КАК КартаНомер,
	               |	Таблица_Контракты.ИДНоменклатурыЧленства КАК ИДНоменклатурыЧленства,
	               |	Таблица_Контракты.НачалоКонтракта КАК НачалоКонтракта,
	               |	ВЫБОР
	               |		КОГДА Таблица_Контракты.НачалоКонтракта = Таблица_Контракты.ОкончаниеКонтракта
	               |			ТОГДА ДОБАВИТЬКДАТЕ(Таблица_Контракты.ОкончаниеКонтракта, ДЕНЬ, 1)
	               |		ИНАЧЕ Таблица_Контракты.ОкончаниеКонтракта
	               |	КОНЕЦ КАК ОкончаниеКонтракта,
	               |	Таблица_Контракты.ДатаПродажи КАК ДатаПродажи,
	               |	Таблица_Контракты.СуммаКонтракта КАК СуммаКонтракта,
	               |	Таблица_Контракты.СуммаОплачено КАК СуммаОплачено,
	               |	Таблица_Контракты.ИДОплаты КАК ИДОплаты,
	               |	Таблица_Контракты.ТипОплаты КАК ТипОплаты,
	               |	Таблица_Контракты.ВидОперации КАК ВидОперации,
	               |	Таблица_Контракты.ДатаОплаты КАК ДатаОплаты,
	               |	Таблица_Контракты.ДатаРассрочки КАК ДатаРассрочки,
	               |	Таблица_Контракты.Аннулирован КАК Аннулирован,
	               |	Таблица_Контракты.СуммаОплаты КАК СуммаОплаты,
	               |	Таблица_Контракты.ОператорОплаты КАК ОператорОплаты,
	               |	Таблица_Контракты.Комментарий КАК Комментарий,
	               |	Таблица_Контракты.Организация КАК Организация,
	               |	Таблица_Контракты.ОрганизацияКонтракта КАК ОрганизацияКонтракта,
	               |	Таблица_Контракты.ПериодКонтракта КАК ПериодКонтракта,
	               |	ВЫБОР
	               |		КОГДА Таблица_Контракты.ДлинаПериода = 0
	               |			ТОГДА 1
	               |		ИНАЧЕ Таблица_Контракты.ДлинаПериода
	               |	КОНЕЦ КАК ДлинаПериода,
	               |	Таблица_Контракты.Заморозок КАК Заморозок,
	               |	Таблица_Контракты.КоличествоДнейЗаморозки КАК КоличествоДнейЗаморозки,
	               |	Таблица_Контракты.БонусныхДней КАК БонусныхДней,
	               |	Таблица_Контракты.КоличествоУслуг КАК КоличествоУслуг,
	               |	Таблица_Контракты.ИДНоменклатуры КАК ИДНоменклатуры,
	               |	Таблица_Контракты.КоличествоПосещений КАК КоличествоПосещений,
	               |	Таблица_Контракты.ПотраченоПосещений КАК ПотраченоПосещений,
	               |	Контрагенты.Ссылка КАК Клиент,
	               |	НоменклатураЧ.Ссылка КАК НоменклатураЧленства,
	               |	ЧленствоПакетУслугДокумент.Ссылка КАК Членство,
	               |	ЧленствоПакетУслугПред.Ссылка КАК ЧленствоПред,
	               |	ЧленствоРеализация.Ссылка КАК ЧленствоРеализация,
	               |	ВозвратОтПокупателяПоРеализациям.Ссылка КАК ВозвратОтПокупателяПоРеализации,
	               |	НоменклатураУ.Ссылка КАК НоменклатураУслуги,
	               |	ПоступлениеДенежныхСредств.Ссылка КАК ПкоСсылка,
	               |	СписаниеДенежныхСредств.Ссылка КАК РкоСсылка,
	               |	ИзменениеУсловийЧленстваПакетаУслуг.Ссылка КАК ОперацияБонусныеДни,
	               |	ЕСТЬNULL(ИзменениеУсловийЧленстваПакетаУслуг.Количество, 0) КАК БонусныеДниРанееЗагруженные
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Контракты.ИДКлиента = Контрагенты.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКлиента > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураЧ
	               |		ПО Таблица_Контракты.ИДНоменклатурыЧленства = НоменклатураЧ.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = НоменклатураЧ.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДНоменклатурыЧленства > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслугДокумент
	               |		ПО Таблица_Контракты.ИДКонтракта = ЧленствоПакетУслугДокумент.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ЧленствоПакетУслугДокумент.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслугПред
	               |		ПО Таблица_Контракты.ИДПредКонтракта = ЧленствоПакетУслугПред.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ЧленствоПакетУслугПред.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДПредКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Реализация КАК ЧленствоРеализация
	               |		ПО Таблица_Контракты.ИДКонтракта = ЧленствоРеализация.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ЧленствоРеализация.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВозвратОтПокупателя КАК ВозвратОтПокупателяПоРеализациям
	               |		ПО (ЧленствоРеализация.Ссылка = ВозвратОтПокупателяПоРеализациям.ОснованиеВозврата)
	               |			И (Таблица_Контракты.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураУ
	               |		ПО Таблица_Контракты.ИДНоменклатуры = НоменклатураУ.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = НоменклатураУ.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДНоменклатуры > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	               |		ПО Таблица_Контракты.ИДОплаты = ПоступлениеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ПоступлениеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДОплаты > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	               |		ПО Таблица_Контракты.ИДОплаты = СписаниеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = СписаниеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДОплаты > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийЧленстваПакетаУслуг КАК ИзменениеУсловийЧленстваПакетаУслуг
	               |		ПО Таблица_Контракты.ИДКонтракта = ИзменениеУсловийЧленстваПакетаУслуг.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ИзменениеУсловийЧленстваПакетаУслуг.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКонтракта > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДКлиента,
	               |	ИДКонтракта,
	               |	Таблица_Контракты.ИДОплаты
	               |ИТОГИ
	               |	МАКСИМУМ(Клиент)
	               |ПО
	               |	ИДКлиента,
	               |	ИДКонтракта,
	               |	ИДОплаты";
	
	#КонецОбласти
	                                        
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ВыборкаОрганизации			 				= РезультатПакетаЗапросов[0].Выбрать();
	ТаблицаКарт		 							= РезультатПакетаЗапросов[1].Выгрузить();	
	ТаблицаКартВБазе 							= РезультатПакетаЗапросов[2].Выгрузить();
	ТаблицаСотрудников		 					= РезультатПакетаЗапросов[3].Выгрузить();	
	ТаблицаСотрудниковВБазе 					= РезультатПакетаЗапросов[4].Выгрузить();
	ТаблицаВидовЛицевыхСчетовВБазе				= РезультатПакетаЗапросов[5].Выгрузить();
	ТаблицаЛицевыхСчетов 						= РезультатПакетаЗапросов[6].Выгрузить();
	ТаблицаЛицевыхСчетовВБазе					= РезультатПакетаЗапросов[7].Выгрузить();
	ВыборкаПоКлиентам							= РезультатПакетаЗапросов[8].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем необходимые виды ЛС на текущем этапе
	АктуализироватьТаблицуВидовЛицевыхСчетов(ТаблицаВидовЛицевыхСчетовВБазе);
	
	// Создадим и заполним таблицу соответствия организаций и касс	
	ТаблицаОрганизации = Новый ТаблицаЗначений;
	ТаблицаОрганизации.Колонки.Добавить("Организация"				,Новый ОписаниеТипов("Строка" ,, Новый КвалификаторыСтроки(90)));
	ТаблицаОрганизации.Колонки.Добавить("ОрганизацияСсылка"			,Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТаблицаОрганизации.Колонки.Добавить("КассаСсылка"				,Новый ОписаниеТипов("СправочникСсылка.Кассы"));
	ТаблицаОрганизации.Колонки.Добавить("БанковскийСчетПоУмолчанию"	,Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));
	ТаблицаОрганизации.Колонки.Добавить("ЭквайринговыйТерминал"		,Новый ОписаниеТипов("СправочникСсылка.ЭквайринговыеТерминалы"));
	
	// Создаем организации и соответствия организаций и касс
	Пока ВыборкаОрганизации.Следующий() Цикл
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые организации, кассы и т.д....", 0, ""));	
		ОрганизацияНаименование 					= СтрЗаменить(ВыборкаОрганизации.Организация, """""", """");
		СтрокаОрганизация = ТаблицаОрганизации.Найти(ОрганизацияНаименование, "Организация");
		Если СтрокаОрганизация = Неопределено Тогда 
			СтруктураОрганизация 						= СоздатьОрганизацию(ОрганизацияНаименование, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТаблицаВидовЛицевыхСчетовВБазе);
			СтрокаТаблицыОиК 							= ТаблицаОрганизации.Добавить();
			СтрокаТаблицыОиК.Организация 				= ВыборкаОрганизации.Организация;
			СтрокаТаблицыОиК.ОрганизацияСсылка 			= СтруктураОрганизация.ОрганизацияСсылка;
			СтрокаТаблицыОиК.КассаСсылка 				= СтруктураОрганизация.КассаСсылка;
			СтрокаТаблицыОиК.БанковскийСчетПоУмолчанию 	= СтруктураОрганизация.БанковскийСчетПоУмолчанию;
			СтрокаТаблицыОиК.ЭквайринговыйТерминал 		= СтруктураОрганизация.ЭквайринговыйТерминал;
		КонецЕсли;
	КонецЦикла;	
	
	// Создаем карты клиентов
	Для Каждого СтрокаКартаКлиента Из ТаблицаКарт Цикл
		КартаКлиента = СокрЛП(СтрокаКартаКлиента.КартаКлиента);
		Если КартаКлиента <> "" И ЗначениеЗаполнено(СтрокаКартаКлиента.Клиент) Тогда
			КартаКлиентаВБазе = ТаблицаКартВБазе.Найти(КартаКлиента, "ВнутреннийКодКарты");
			Если КартаКлиентаВБазе = Неопределено Тогда
				КартаКлиентаОбъект                  = Справочники.Карты.СоздатьЭлемент();
				КартаКлиентаОбъект.ВладелецКарты    = СтрокаКартаКлиента.Клиент;
				// КартаКлиентаОбъект.ТипКода          = ВидКартыШтриховая;
				КартаКлиентаОбъект.ТипКода          = ВидКарты_Магнитная;						
				КартаКлиентаОбъект.ДатаОткрытия     = СтрокаКартаКлиента.НачалоКонтракта;
				КартаКлиентаОбъект.КодКарты         = ?(СокрЛП(СтрокаКартаКлиента.КартаНомер) <> "", СокрЛП(СтрокаКартаКлиента.КартаНомер), СтрокаКартаКлиента.КартаКлиента);
				КартаКлиентаОбъект.ВнутреннийКодКарты = СокрЛП(СтрокаКартаКлиента.КартаКлиента);
				КартаКлиентаОбъект.Наименование     = "" + КартаКлиентаОбъект.ВнутреннийКодКарты + ", " + КартаКлиентаОбъект.ВладелецКарты + " (" + КартаКлиентаОбъект.ТипКода + ")";
				Попытка
					КартаКлиентаОбъект.УстановитьНовыйКод();																			
					КартаКлиентаОбъект.ОбменДанными.Загрузка = Истина;
					КартаКлиентаОбъект.Записать();
					ЗаполнитьЗначенияСвойств(ТаблицаКартВБазе.Добавить(), КартаКлиентаОбъект);
				Исключение
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка создания карты клиента ""%2"" Код карты: %3 Внутренний код карты: %4 %1 %5';en='%1 Error create cards client ""%2"" Code cards: %3 Interior code cards: %4 %1 %5'"),  Символы.ПС, Строка(СтрокаКартаКлиента.Клиент), СокрЛП(СтрокаКартаКлиента.КартаНомер), СокрЛП(СтрокаКартаКлиента.КартаКлиента), ОписаниеОшибки()));						
				КонецПопытки;	
				// СозданоКартКлиентов = СозданоКартКлиентов + 1;
				ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (карты клиентов)...';en='Preservation of preliminary data clients cards)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", КартаКлиентаОбъект.Наименование, 0, ""));					
			ИначеЕсли НЕ СтрокаКартаКлиента.Клиент = КартаКлиентаВБазе.ВладелецКарты Тогда 
				КартаКлиентаОбъект                  = КартаКлиентаВБазе.Ссылка.ПолучитьОбъект();
				КартаКлиентаОбъект.ВладелецКарты    = СтрокаКартаКлиента.Клиент;
				КартаКлиентаОбъект.ДатаОткрытия     = СтрокаКартаКлиента.НачалоКонтракта;
				КартаКлиентаОбъект.Наименование     = "" + КартаКлиентаОбъект.ВнутреннийКодКарты + ", " + КартаКлиентаОбъект.ВладелецКарты + " (" + КартаКлиентаОбъект.ТипКода + ")";
				Попытка
					КартаКлиентаОбъект.ОбменДанными.Загрузка = Истина;
					КартаКлиентаОбъект.Записать();
					ЗаполнитьЗначенияСвойств(КартаКлиентаВБазе, КартаКлиентаОбъект);
				Исключение
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка создания карты клиента ""%2"" Код карты: %3 Внутренний код карты: %4 %1 %5';en='%1 Error create cards client ""%2"" Code cards: %3 Interior code cards: %4 %1 %5'"),  Символы.ПС, Строка(СтрокаКартаКлиента.Клиент), СокрЛП(СтрокаКартаКлиента.КартаНомер), СокрЛП(СтрокаКартаКлиента.КартаКлиента), ОписаниеОшибки()));						
				КонецПопытки;	
				ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (карты клиентов)...';en='Preservation of preliminary data clients cards)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", КартаКлиентаОбъект.Наименование, 0, ""));									
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	
	// Получим должность для менеджеров	
	ДолжностьМенеджер = ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	
	// Создаем необходимых сотрудников на текущем этапе
	Для Каждого СтрокаМенеджер Из ТаблицаСотрудников Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.Менеджер) = "" Тогда 
			СтрокаСотрудник = ТаблицаСотрудниковВБазе.Найти(СокрЛП(СтрокаМенеджер.Менеджер), "Наименование");
			Если СтрокаСотрудник = Неопределено Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.Менеджер, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(СтрокаСотрудник.Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);
			КонецЕсли;				
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (сотрудники)...';en='Preservation of preliminary data staff)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", СтрокаМенеджер.Менеджер, 0, ""));		
	КонецЦикла;
		
	// Создаем необходимые ЛС на текущем этапе
	АктуализироватьТаблицуЛицевыхСчетовНаЭтапеКонтракты(ТаблицаЛицевыхСчетовВБазе, ТаблицаЛицевыхСчетов, ТаблицаВидовЛицевыхСчетовВБазе, ТекстовыйНакопитель);
	
	#КонецОбласти
	
	Если ВыборкаПоКлиентам.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по контрактам...';en='Saving data on contracts...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоКонтрактов 	= ВыборкаПоКлиентам.Количество();
	ОбщееКоличествоКонтрактов	= ?(ОбщееКоличествоКонтрактов < 1, 1, ОбщееКоличествоКонтрактов);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоКонтрактов 			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеКонтракта		= "";
	
	ТаблицаРассрочка = Новый ТаблицаЗначений;
	ТаблицаРассрочка.Колонки.Добавить("ДатаПлатежаПлан", Новый ОписаниеТипов("Дата")); 
	ТаблицаРассрочка.Колонки.Добавить("СуммаПлатежаПлан", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10,2)));
	
	МассивБессрочныхЧПУ = ПолучитьМассивБессрочныхЧПУ(ПараметрыЗадания.ПараметрыЗагрузки.СегментБессрочныхЧПУ);
	ПараметрыЗадания.ПараметрыЗагрузки.Вставить("МассивБессрочных", МассивБессрочныхЧПУ);
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоКлиентам.Следующий() Цикл
		СообщилиПрогресс = Ложь;
		СозданоКонтрактов = СозданоКонтрактов + 1;
		Если ЗначениеЗаполнено(ВыборкаПоКлиентам.Клиент) Тогда
			ВыборкаПоКонтрактам = ВыборкаПоКлиентам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоКонтрактам.Следующий() Цикл
				ЭтоОбновлениеЧленства = Ложь;
				// Выберем строку нижнего уровня с необходимыми реквизитами
				ВыборкаПоОплатам = ВыборкаПоКонтрактам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ВыборкаПоОплатам.Следующий();				
				СтрокаВыборкаПоКонтрактам = ВыборкаПоОплатам.Выбрать();
				СтрокаВыборкаПоКонтрактам.Следующий();
				// Выберем организацию тек.строки
				СтрокаОрганизация 			= ТаблицаОрганизации.Найти(СокрЛП(СтрокаВыборкаПоКонтрактам.ОрганизацияКонтракта), "Организация");
				ТекОрганизация 				= СтрокаОрганизация.ОрганизацияСсылка;
				ТекКасса 					= СтрокаОрганизация.КассаСсылка;  
				БанковскийСчетРеализации 	= СтрокаОрганизация.БанковскийСчетПоУмолчанию;
				
	#Область Создание_членства
				
				НоменклатураЧленства = СтрокаВыборкаПоКонтрактам.НоменклатураЧленства;
				Если ЗначениеЗаполнено(СтрокаВыборкаПоКонтрактам.Членство) Тогда
					Если ПараметрыЗадания.ПараметрыЗагрузки.ТолькоНовые Тогда
						Продолжить;
					Иначе	
						ЧленствоОбъект = ОбновитьЧленство(СтрокаВыборкаПоКонтрактам, НоменклатураЧленства, ПараметрыЗадания.ПараметрыЗагрузки, ТекстовыйНакопитель);
						ЭтоОбновлениеЧленства = Истина;
					КонецЕсли;	
				Иначе
					Если ЗначениеЗаполнено(НоменклатураЧленства) Тогда
						ЧленствоОбъект = СоздатьЧленство(СтрокаВыборкаПоКонтрактам, НоменклатураЧленства, ПараметрыЗадания.ПараметрыЗагрузки, ТекстовыйНакопитель);
					Иначе
						Продолжить;
					КонецЕсли;	
				КонецЕсли;
				// Если ЭтоОбновлениеЧленства Тогда 
				//	Продолжить;
				// КонецЕсли;
				
	#КонецОбласти
				
				// Менеджер контракта
				МенеджерСтрокой = СокрЛП(СтрокаВыборкаПоКонтрактам.Менеджер);
				Менеджер = Справочники.Сотрудники.ПустаяСсылка();
				Если МенеджерСтрокой <> "" Тогда
					СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.Найти(МенеджерСтрокой, "Наименование");
					Если НЕ СтрокаМенеджерСотрудник = Неопределено Тогда
						Менеджер = СтрокаМенеджерСотрудник.Ссылка;
					КонецЕсли;
				КонецЕсли;	
				
	#Область Создание_реализации
				
				// Найдем или создадим реализацию и свяжем с членством	
				Если ЗначениеЗаполнено(СтрокаВыборкаПоКонтрактам.ЧленствоРеализация) Тогда
					ДокументРеализация 						= СтрокаВыборкаПоКонтрактам.ЧленствоРеализация.ПолучитьОбъект();
					ДокументРеализация.Запасы.Очистить();
				Иначе
					ДокументРеализация 						= Документы.Реализация.СоздатьДокумент();
					ДокументРеализация.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
					ДокументРеализация.Организация 			= ТекОрганизация;
					ДокументРеализация.Склад 				= ПараметрыЗадания.ПараметрыЗагрузки.ОсновнойСкладСтруктурнойЕдиницы;
					ДокументРеализация.Дата 				= СтрокаВыборкаПоКонтрактам.ДатаПродажи;
					ДокументРеализация.КодСинхронизации 	= СтрокаВыборкаПоКонтрактам.ИДКонтракта;
					ДокументРеализация.ПрефиксСинхронизации	= СтрокаВыборкаПоКонтрактам.ПрефиксСинхронизации;
					ДокументРеализация.Комментарий 			= СтрокаВыборкаПоКонтрактам.ПрефиксСинхронизации + " - " + Формат(СтрокаВыборкаПоКонтрактам.ИДКонтракта, "ЧГ=0");
					ДокументРеализация.Контрагент 			= ВыборкаПоКлиентам.Клиент;
					ДокументРеализация.АвторДокумента 		= ?(ЗначениеЗаполнено(Менеджер), Менеджер, ТекущийПользовательСеанса);
					ДокументРеализация.ВидЦен 				= ВидЦен_Розничная;
					
					// Найдем ранее созданную карту клиента и подставим в реализацию
					Если СокрЛП(СтрокаВыборкаПоКонтрактам.КартаКлиента) <> "" Тогда
						КартаКлиента = ТаблицаКартВБазе.Найти(СокрЛП(СтрокаВыборкаПоКонтрактам.КартаКлиента), "ВнутреннийКодКарты");
						Если НЕ КартаКлиента = Неопределено Тогда
							ДокументРеализация.КартаКонтрагента = КартаКлиента.Ссылка;
						КонецЕсли;	
					КонецЕсли;
				КонецЕсли;
				СуммаРеализации 							= СтрокаВыборкаПоКонтрактам.СуммаКонтракта;
				Комент 										= "";
				НеобходиомПерепроведение 					= ДокументРеализация.Проведен И ДокументРеализация.СуммаДокумента <> СуммаРеализации;				
				ДокументРеализация.СуммаДокумента 			= СуммаРеализации;
				ДокументРеализация.Комментарий 				= ДокументРеализация.Комментарий + Комент;
				// Заполняем табличную часть "Запасы"
				ТЧ_Запасы									= ДокументРеализация.Запасы.Добавить();
				ТЧ_Запасы.КлючСтроки 						= Новый УникальныйИдентификатор;				
				ТЧ_Запасы.Номенклатура 						= НоменклатураЧленства.Ссылка;
				ТЧ_Запасы.Основание 						= ЧленствоОбъект.Ссылка;
				ТЧ_Запасы.Количество 						= 1;
				ТЧ_Запасы.КоличествоУпаковок 				= 1;
				ТЧ_Запасы.ВидЦен 							= ВидЦен_Розничная;
				ТЧ_Запасы.Цена 								= СуммаРеализации;
				ТЧ_Запасы.Сумма 							= СуммаРеализации;
				ТЧ_Запасы.Всего 							= СуммаРеализации;
				
	#КонецОбласти
	
				Попытка
					// Сохраняем документ
					ЗаписатьДокумент(ДокументРеализация, , , НеобходиомПерепроведение);
				Исключение
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + СтрШаблон(НСтр("ru = 'Ошибка сохранения док-та Реализация ""%1"" Код синхронизации: %2';en= 'Error saving document implementation ""%1"" Sync code: %2'"), Строка(ВыборкаПоКлиентам.Клиент), СокрЛП(СтрокаВыборкаПоКонтрактам.ИДКонтракта) + Символы.ПС + ОписаниеОшибки()));						
				КонецПопытки;	
				
	#Область Дополнение_членства
				
				// Дополним членство услугами
				ВыборкаПоУслугам = ВыборкаПоОплатам.Выбрать();
				ЧленствоОбъект.СоставУслуг.Очистить();
				Если СтрокаВыборкаПоКонтрактам.Статус = 2 Тогда
					// ЧленствоОбъект.Свёрнут = Истина;	 // Все ЧПУ грузим с флагом ЛОЖЬ, для того чтобы были подхвачены закрытием дня (свернем движения по месячно в момент проведения)
				КонецЕсли;	
				Пока ВыборкаПоУслугам.Следующий() Цикл
					Если НЕ ЗначениеЗаполнено(ВыборкаПоУслугам.ИДНоменклатуры) Тогда
						Продолжить;
					КонецЕсли;
					НоменклатураУслуги = ВыборкаПоУслугам.НоменклатураУслуги;	
					// Найти или добавить услугу в членство
					СтрокаУслуга = ЧленствоОбъект.СоставУслуг.Найти(НоменклатураУслуги, "УслугаСегмент");
					Если СтрокаУслуга = Неопределено Тогда
						СтрокаУслуга = ЧленствоОбъект.СоставУслуг.Добавить();
						СтрокаУслуга.УслугаСегмент = НоменклатураУслуги;
					КонецЕсли;
					СтрокаУслуга.Количество = ВыборкаПоУслугам.КоличествоУслуг;
				КонецЦикла;
				ЧленствоОбъект.ДокументПродажи = ДокументРеализация.Ссылка;
				
				// Продление членства
				Если ЗначениеЗаполнено(СтрокаВыборкаПоКонтрактам.ЧленствоПред) Тогда
					ЧленствоОбъект.ПродлеваемоеЧленствоПакетУслуг = СтрокаВыборкаПоКонтрактам.ЧленствоПред;
					ЧленствоОбъект.ТипПродления = ТипПродленияЧленстваПакетаУслуг_Продление;
				ИначеЕсли ЗначениеЗаполнено(СтрокаВыборкаПоКонтрактам.ИДПредКонтракта) Тогда
					ЧленствоПред = Документы.ЧленствоПакетУслуг.НайтиПоРеквизиту("КодСинхронизации", СтрокаВыборкаПоКонтрактам.ИДПредКонтракта);
					Если НЕ ЧленствоПред.Пустая() Тогда
						ЧленствоОбъект.ПродлеваемоеЧленствоПакетУслуг = ЧленствоПред;
						ЧленствоОбъект.ТипПродления = ТипПродленияЧленстваПакетаУслуг_Продление;
					КонецЕсли;
				ИначеЕсли НЕ ЗначениеЗаполнено(ЧленствоОбъект.ТипПродления) Тогда 
					ЧленствоОбъект.ТипПродления = ТипПродленияЧленстваПакетаУслуг_Новое;
				КонецЕсли;
				
	#КонецОбласти
	
				Попытка
					// Сохраняем документ				
					ЗаписатьДокумент(ЧленствоОбъект);
