// Получить занятия из буфера на неделю
// 
Функция ЗанятияЗаНеделюИзБуфераДляОтображения(НачалоНедели, ОкончаниеНедели)
	
	ОтборЗанятий = Новый Массив;
	Индекс = ?(СтартовыйИндексЦиклаПодбораНедельногоБуфера <> Неопределено, СтартовыйИндексЦиклаПодбораНедельногоБуфера, 0);
	Пока Индекс < БуферФормирования.Количество() Цикл
		
		СтрокаТ = БуферФормирования[Индекс];
		// Т.к. занятия в буфере отсортированы по дате начала
		// имеем возможность прервать цикл
		Если  СтрокаТ.Дата > ОкончаниеНедели Тогда
			Прервать;
		КонецЕсли;	 
				
		Если СтрокаТ.Скрыть = Ложь И СтрокаТ.Дата >= НачалоНедели И СтрокаТ.Дата <= ОкончаниеНедели Тогда
			ОтборЗанятий.Добавить(СтрокаТ); 
		КонецЕсли;
			
		Индекс = Индекс + 1;
	КонецЦикла;
	
	СтартовыйИндексЦиклаПодбораНедельногоБуфера = Индекс;
	
	Возврат ОтборЗанятий;
КонецФункции

