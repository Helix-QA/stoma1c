&НаКлиенте
// Процедура, выполянет завершение редактирования клиента.
//
Процедура ЗавершениеДополнительнойИнформации(Результат, ДополнительныеПараметры) Экспорт
	
	СформироватьКонтаргентаСтрокой(Элементы.КнопкаКонтрагент.Заголовок, Объект.Контрагент);
	СформироватьПредметСтрокой(Элементы.КнопкаПредмет.Заголовок, Объект.ЗадачаПредмет);
	
	Если ДополнительныеПараметры.ДанныеЭлемента = Неопределено Тогда 
		ОбновитьВидимостьЭлементов();
	Иначе 
		ОбновитьЭлементы_CRM(, , Истина);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Команда взаимодействие исполнитель
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВзаимодействиеИсполнитель(Команда)
	
	Оповещение     = Новый ОписаниеОповещения("ОбработчикВыбораИсполнителя", ЭтотОбъект);
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ключ"							, Объект.Исполнитель);
	ПараметрыФормы.Вставить("ВыборТолькоЭлементов"			, Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе"			, Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриЗакрытииВладельца"	, Истина);
	
	ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаВыбораИсполнителя", ПараметрыФормы, ЭтотОбъект,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик выбора исполнителя взаимодействия
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ОбработчикВыбораИсполнителя(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Объект.Исполнитель = Результат;
		Если ТипЗнч(Результат) = Тип("СправочникСсылка.Сотрудники") Тогда
			Элементы.ВзаимодействиеИсполнитель.Заголовок = ПолучитьПредставлениеФИОСотрудника(Объект.Исполнитель);
		Иначе
			 Элементы.ВзаимодействиеИсполнитель.Заголовок = Строка(Результат);
		КонецЕсли;
			
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Команда взаимодействие выбрать.
//
Процедура ВидВзаимодействияСправочникВыбор(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ВыборВидаВзаимодействияСправочникЗавершение", ЭтотОбъект);
	
	ПоказатьВыборИзМеню(Оповещение, ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора, Элементы.ВидВзаимодействияСправочникВыбор);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор взаимодействия завершение.
//
Процедура ВыборВидаВзаимодействияСправочникЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Элементы.ДекорацияВзаимодействиеИконка.Картинка     = Результат.Картинка;
		Элементы.ДекорацияВзаимодействиеИконка.Видимость    = ЗначениеЗаполнено(Результат.Картинка);
		Элементы.ВидВзаимодействияСправочникВыбор.Заголовок = Результат.Представление;
		
		Объект.ВидВзаимодействияСправочник = Результат.Значение.Взаимодействие;
		Объект.ВидВзаимодействия           = Результат.Значение.ВидВзаимодействия;
		
		Модифицированность = Истина;
		
		УстановитьЗаголовокФормы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Команда взаимодействие режим напоминания.
//
Процедура ВзаимодействиеРежимНапоминания(Команда)

	Оповещение = Новый ОписаниеОповещения("ВыборРежимаНапоминанияЗавершение", ЭтотОбъект);
	ПоказатьВыборИзМеню(Оповещение, ЭтотОбъект.ВзаимодействиеРежимНапоминанияСписокВыбора, Элементы.ВзаимодействиеРежимНапоминания);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор взаимодействия завершение
//
Процедура ВыборРежимаНапоминанияЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ЭтотОбъект.ЗадачаРежимНапоминания = Результат.Значение;
		Элементы.ВзаимодействиеРежимНапоминания.Заголовок = Результат.Представление; 

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

