#Область ОбработатьНеОплаченныеЗаказыСБП_и_СсылокНаОплату 

// Процедура - Обработать не оплаченные заказы СБП
//
Процедура ОбработатьНеОплаченныеЗаказыСБП(НомерЗаказа = Неопределено, РезультатЗапроса = Неопределено) Экспорт
	
	РезультатЗапроса		= Новый Структура("ВыполненоУспешно, ПараметрыРезультата, КодОшибки, ОписаниеОшибки, ТелоЗапроса", Ложь, Неопределено, Неопределено, Неопределено, Неопределено);	
	СообщитьПользователю	= ЗначениеЗаполнено(НомерЗаказа);
	ТаблицаЗаказов			= РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьНеОплаченныеЗаказыСБП(НомерЗаказа);	
	
	Для Каждого Заказ Из ТаблицаЗаказов Цикл
		
		ТекстОтвета	= "";
		ПараметрыПШ	= Заказ.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
		
		Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Заказ.ЭтоВозврат Тогда
			
			Заказ.ПараметрыПШ	= ПараметрыПШ;
			Статус				= Неопределено;
			Заказ.СтруктураВозврата = Новый Структура("ВыполненоУспешно, ОписаниеОшибки", Ложь, Неопределено);
			
			Если Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.РайффайзенБанк_ПолучитьИнформациюПоВозврату(Заказ, ТекстОтвета);
				
				Если РезультатЗапроса.ВыполненоУспешно Тогда
					Статус = РезультатЗапроса.ПараметрыРезультата.refundStatus;
				КонецЕсли;
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.Тинькофф_ПолучитьСтатусПлатежа(Заказ.ИдСБП, ПараметрыПШ, ТекстОтвета);
				
				Если РезультатЗапроса.ВыполненоУспешно Тогда
					Статус = РезультатЗапроса.ПараметрыРезультата.Status;
				КонецЕсли;
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.СДМ_ПолучитьСтатусПлатежа(Заказ.ИдСБП, ПараметрыПШ, ТекстОтвета);
				
				Если РезультатЗапроса.ВыполненоУспешно Тогда
					Статус = РезультатЗапроса.ПараметрыРезультата.Status;
				КонецЕсли;
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.АльфаБанк_ПолучитьСтатусПлатежаРасширенный(Заказ, ТекстОтвета);
				
				Если РезультатЗапроса.ВыполненоУспешно Тогда
					Статус = РезультатЗапроса.ПараметрыРезультата.orderStatus;
				КонецЕсли;
				
	        Иначе
								
				СтруктураПараметров = Новый Структура("order_id, tid, partner_order_number", Заказ.ИдСБП, ПараметрыПШ.IDТерминала, Заказ.НомерЗаказа);
				
				ОбщегоНазначенияБТС.Пауза(1);
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.Сбербанк_ПолучитьСтатусПлатежа(СтруктураПараметров, ТекстОтвета, ЗначениеЗаполнено(НомерЗаказа), Истина);
				
				Если РезультатЗапроса.ВыполненоУспешно Тогда
					Статус = РезультатЗапроса.ПараметрыРезультата.order_state;
				КонецЕсли;
				
			КонецЕсли;
			
			Если РезультатЗапроса.ВыполненоУспешно Тогда
				РезультатОперации = СсылкиНаОплатуИСБП.СформироватьДокументСписанияИПробить(Заказ, Статус,, ТекстОтвета);		
			КонецЕсли;
			
			РегистрыСведений.СтатусыОплатыЗаказов.ОбновитьЗаписьПоЗаказу(Заказ.УИДВозврата, ТекстОтвета,, Истина, Истина); // Добавим попытку обработки
			
		Иначе
			
			Если Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк Тогда
				
				Если Не ЗначениеЗаполнено(Заказ.ИдентификаторQRКода) Тогда
					Продолжить;
				КонецЕсли;
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.АльфаБанк_ПолучитьСтатусПлатежа(Заказ.ИдСБП, ПараметрыПШ, Заказ.ИдентификаторQRКода, ТекстОтвета);
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПТинькофф Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.Тинькофф_ПолучитьСтатусПлатежа(Заказ.ИдСБП, ПараметрыПШ, ТекстОтвета);	
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.СДМ_ПолучитьСтатусПлатежа(Заказ.ИдСБП, ПараметрыПШ, ТекстОтвета);			
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.РайффайзенБанк_ПолучитьСтатусПлатежа(Заказ.ИдСБП, ПараметрыПШ, ТекстОтвета);
				
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.Сбербанк Тогда
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.Сбербанк_ПолучитьСтатусПлатежаРасширенный(Заказ, ПараметрыПШ, ТекстОтвета);
					
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСбербанк Тогда
				
				tid = ?(ПараметрыПШ.Свойство("IDТерминала"), ПараметрыПШ.IDТерминала, Неопределено);
				
				Если Не ЗначениеЗаполнено(tid) Тогда
					Продолжить;
				КонецЕсли;
				
				СтруктураПараметров = Новый Структура("order_id, tid, partner_order_number", Заказ.ИдСБП, tid, Заказ.НомерЗаказа);
				
				ОбщегоНазначенияБТС.Пауза(1);
				
				РезультатЗапроса = СсылкиНаОплатуИСБП.Сбербанк_ПолучитьСтатусПлатежа(СтруктураПараметров, ТекстОтвета, ЗначениеЗаполнено(НомерЗаказа));
				
			Иначе
				
				РезультатЗапроса.ВыполненоУспешно = Ложь;
				РезультатЗапроса.ОписаниеОшибки   = "Не удалось распознать тип платёжного шлюза.";	
				
			КонецЕсли;
			
			РегистрыСведений.СтатусыОплатыЗаказов.ОбновитьЗаписьПоЗаказу(Заказ.НомерЗаказа, ТекстОтвета,, Не ЗначениеЗаполнено(НомерЗаказа), Не ЗначениеЗаполнено(НомерЗаказа));  			
			
			Если РезультатЗапроса.ВыполненоУспешно = Ложь Тогда 
				Продолжить;
			КонецЕсли;
			
			СтрПараметров = РезультатЗапроса.ПараметрыРезультата;
			
			Если Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк Тогда
				СтрПараметров.Вставить("operation"	, СтрПараметров.transactionState);
				СтрПараметров.Вставить("orderNumber", Заказ.НомерЗаказа);
				СтрПараметров.Вставить("mdOrder"	, Заказ.ИдСБП);
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
				СтрПараметров.Вставить("OrderId", Заказ.НомерЗаказа);
			ИначеЕсли Заказ.ТипБанка = Перечисления.ПлатежныеШлюзы.Сбербанк Тогда
				СтрПараметров.Вставить("mdOrder"	, Заказ.ИдСБП);
			Иначе
				СтрПараметров.Вставить("НомерЗаказа", Заказ.НомерЗаказа);
			КонецЕсли;		
			
			СтрПараметров.Вставить("ТипБанка", Заказ.ТипБанка);
			
			РезультатОбработки = СсылкиНаОплатуИСБП.ОбработатьОплатуПоСсылкуИСБП(СтрПараметров, ТекстОтвета);
			
		КонецЕсли;
		
		Если Заказ.Истекший = Истина И РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьСтатусЗаказа(Заказ.НомерЗаказа) =  Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено Тогда
			
			РегистрыСведений.СтатусыОплатыЗаказов.ОбновитьЗаписьПоЗаказу(Заказ.НомерЗаказа,, Перечисления.СтатусыЗаказовОнлайнОплаты.Истекший);  			
			
			Если СообщитьПользователю Тогда
				РезультатЗапроса.ОписаниеОшибки = "Время действия ссылки истекло";	
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

