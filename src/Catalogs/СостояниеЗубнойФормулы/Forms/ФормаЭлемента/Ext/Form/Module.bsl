&НаКлиенте
// Процедура, обработчик события "ПриНажатии"
//
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ДанныеСобытия.Element.id) Тогда
		ВыбЦвет = Сред(ДанныеСобытия.Element.id, 2, 100);	
		Элементы.КнопкаЦвет.ЦветФона = ОбщегоназначенияКлиентСерверСтоматология.ПолучитьЦветRGB(ВыбЦвет);         
		Объект.Цвет = ВыбЦвет;
	КонецЕсли;
	
КонецПроцедуры

