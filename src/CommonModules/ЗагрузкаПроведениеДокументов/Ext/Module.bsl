
#Область СлужебныйПрограммныйИнтерфейс

#Область ОсновныеПроцедурыИФункцииЗагрузки

#Область ACCESS

// Функция - Начать импорт данных
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьИмпортДанныхAccess(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Если ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Клиенты" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьКлиентовВФонеAccess";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьКлиентовВФонеAccess";
		КонецЕсли;	
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Клиенты""';en='Loading data. Stage ""Clients""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Номенклатура" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьНоменклатуруВФонеAccess";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьНоменклатуруВФонеAccess";
		КонецЕсли;			
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Номенклатура""';en='Loading data. Stage ""Nomenclature""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Контракты" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьКонтрактыВФонеAccessМногопоточно";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьКонтрактыВФонеAccess";
		КонецЕсли;					
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Контракты""';en='Loading data. Stage ""Contracts""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Реализации" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьРеализацииВФонеAccessМногопоточно";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьРеализацииВФонеAccess";
		КонецЕсли;							
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Реализации""';en='Loading data. Stage ""Realizations""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Занятия" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьЗанятияВФонеAccessМногопоточно";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьЗанятияВФонеAccess";
		КонецЕсли;							
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Занятия""';en='Loading data. Stage ""Classes""'");
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Посещения" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьПосещенияВФонеAccessМногопоточно";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьПосещенияВФонеAccess";
		КонецЕсли;							
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Посещения""';en='Loading data. Stage ""Visits""'");		
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "Заморозки" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьЗаморозкиВФонеAccess";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьЗаморозкиВФонеAccess";
		КонецЕсли;									
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Заморозки""';en='Loading data. Stage ""Frost""'");			
	ИначеЕсли ПараметрыПроцедуры.ПараметрыЗагрузки.ЗагружаемыйСправочник = "РеализацииДолг" Тогда
		Если ПараметрыПроцедуры.ПараметрыЗагрузки.МногопоточнаяЗагрузка Тогда 
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьДолговыеРеализацииВФонеAccess";
		Иначе 	
			ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ЗагрузитьДолговыеРеализацииВФонеAccess";
		КонецЕсли;											
		ОписаниеПроцедуры 	= НСтр("ru='Загрузка данных. Этап ""Реализации (долговые)""';en='Loading data. Stage ""Realizations debt)""'");					
	КонецЕсли;
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	ИмяПроцедуры,
	ПараметрыПроцедуры,
	ОписаниеПроцедуры);
	Возврат Результат;
	
КонецФункции
 
// Процедура - Загрузить клиентов в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьКлиентовВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	СозданоКлиентов 						= 0;
	СозданоАвто 							= 0;
	СозданоКлючей 							= 0;
	ФотоВПапке 								= Истина; // НЕ ПараметрыЗадания.ПараметрыЗагрузки.ФотоВ_ИБ;
	ГрузимФото 								= ?(ФотоВПапке, ЗначениеЗаполнено(ПараметрыЗадания.ПараметрыЗагрузки.ПапкаФотографии), Истина);
	
	МужскойПол 								= Перечисления.ПолФизическогоЛица.Мужской;
	ЖенскийПол 								= Перечисления.ПолФизическогоЛица.Женский;	
	ФизЛицо 								= Перечисления.ЮрФизЛицо.ФизЛицо;
	ТипКонтрагента_Клиенты 					= Перечисления.ТипыКонтрагентов.Клиенты;	
	ТипыКИ_АдресЭлектроннойПочты 			= Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	ТипыКИ_Адрес 							= Перечисления.ТипыКонтактнойИнформации.Адрес;
	ТипыКИ_Телефон 							= Перечисления.ТипыКонтактнойИнформации.Телефон;
	ВидКИ_ТелефонКлиента					= Справочники.ВидыКонтактнойИнформации.ТелефонКлиента;
	ВидКИ_ТелефонКлиентаДополнительный		= Справочники.ВидыКонтактнойИнформации.ТелефонКлиентаДополнительный;
	ВидКИ_АдресКлиента 						= Справочники.ВидыКонтактнойИнформации.АдресКлиента;
	ВидКИ_EmailКлиента 						= Справочники.ВидыКонтактнойИнформации.EmailКлиента;
	ВидДФЛ_ПаспортРФ 						= Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ.Ссылка;
	ТекущийПользовательСеанса 				= ПараметрыСеанса.ТекущийПользователь;	
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Если ПараметрыЗадания.ПараметрыЗагрузки.ТолькоФото И ГрузимФото Тогда 
		
	#Область Сохраняем_только_фото
		
		Таблица_ФотоКлиентов				= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_ФотоКлиентов;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_ФотоКлиентов, "Таблица_ФотоКлиентов");
		Запрос.Текст = "ВЫБРАТЬ
		               |	Таблица_ФотоКлиентов.КодСинхронизации КАК КодСинхронизации,
		               |	Таблица_ФотоКлиентов.Фото КАК Фото,
		               |	Контрагенты.Ссылка КАК Клиент
		               |ИЗ
		               |	Таблица_ФотоКлиентов КАК Таблица_ФотоКлиентов
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		               |		ПО Таблица_ФотоКлиентов.КодСинхронизации = Контрагенты.КодСинхронизации
		               |			И Таблица_ФотоКлиентов.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
		               |			И (Таблица_ФотоКлиентов.КодСинхронизации > 0)
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	КодСинхронизации";
		
		ТаблицаДанныхФотоКлиентов = Запрос.Выполнить().Выгрузить();
		// Уничтожаем временную Таблицу
		Запрос.МенеджерВременныхТаблиц.Закрыть();
		
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение фото клиентов...';en='Preservation aphoto clients...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимых сотрудников на текущем этапе...", 0, ""));
		
		ОбщееКоличествоКлиентов = ТаблицаДанныхФотоКлиентов.Количество();
		ОбщееКоличествоКлиентов = ?(ОбщееКоличествоКлиентов < 1, 1, ОбщееКоличествоКлиентов);
		ДатаНачалаПроцесса 		= ТекущаяДатаСеанса();
		ЗаписаноКлиентов 		= 0;
		ОсталосьВремени 		= Неопределено;
		ПредставлениеКлиента	= "";
				
		Для Каждого СтрокаТаблицыФото Из ТаблицаДанныхФотоКлиентов Цикл
			СообщилиПрогресс = Ложь;
			ЗаписаноКлиентов = ЗаписаноКлиентов + 1;			
			Если ЗначениеЗаполнено(СтрокаТаблицыФото.Клиент) Тогда 
				// Запишем фото клиента
				АдресФото = СтрокаТаблицыФото.Фото;
				АдресФото = СокрЛП(Формат(Число(АдресФото),"ЧГ=0"));
				Если СокрЛП(АдресФото) = "" Тогда
					// Запись в лог
					ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + "Для клиента """ + Строка(СтрокаТаблицыФото.Клиент) + """ наименование файла с фото не указано в базе данных (исходной таблице)");	
				Иначе 
					АдресФото = СокрЛП(ПараметрыЗадания.ПараметрыЗагрузки.ПапкаФотографии) + "\" + АдресФото + ".jpg";
					Файл = Новый Файл(АдресФото);
					Если Файл.Существует() Тогда 
						ДвоичныеДанные = Новый ДвоичныеДанные(АдресФото);				
						ОбменДаннымиСерверСтоматология.ЗаписатьФотоКлиентаВСправочник(ДвоичныеДанные, СтрокаТаблицыФото.Клиент, Истина);
						
						// Накапливаем статисические данные и оповещаем клиент
						ПредставлениеКлиента			= Строка(СтрокаТаблицыФото.Клиент);
						Прогресс 						= Цел(100 * ЗаписаноКлиентов / ОбщееКоличествоКлиентов);
						ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
						ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
						ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение фото клиентов...';en='Preservation aphoto clients...'") + Символы.Таб + " Осталось: " + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКлиента, ОсталосьВремени, ПредставлениеОставшегосяВремени));
						СообщилиПрогресс = Истина;
					Иначе
						// Запись в лог						
						ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Для клиента ""%2"" файл в папке с фото не найден!';en='%1 For client ""%2""; file in folder with aphoto not found!'"), Символы.ПС, Строка(СтрокаТаблицыФото.Клиент)));						
					КонецЕсли;	
				КонецЕсли;	
			КонецЕсли;
			Если СообщилиПрогресс = Ложь Тогда 
				// Накапливаем статисические данные и оповещаем клиент
				ПредставлениеКлиента			= "";
				Прогресс 						= Цел(100 * ЗаписаноКлиентов / ОбщееКоличествоКлиентов);
				ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
				ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
				ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение фото клиентов...';en='Preservation aphoto clients...'") + Символы.Таб + " Осталось: " + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКлиента, ОсталосьВремени, ПредставлениеОставшегосяВремени));
				СообщилиПрогресс = Истина;
		    КонецЕсли;
		КонецЦикла;
		
	#КонецОбласти
	
	КонецЕсли;

	Если (ПараметрыЗадания.ПараметрыЗагрузки.ТолькоФото И ГрузимФото) ИЛИ ПараметрыЗадания.ПараметрыЗагрузки.ТолькоАвтомобили Тогда
		ЛогГенерации = ТекстовыйНакопитель.Закрыть();
		Для К = 0 По 1999 Цикл
			Если К/100 = Цел(К/100) Тогда			
				ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
			КонецЕсли;	
		КонецЦикла;	
		Возврат;
	КонецЕсли;
	
	Таблица_Клиентов 						= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Клиентов;
	Таблица_КИ_Клиентов 					= ПараметрыЗадания.СписокТаблиц[1].Значение.Таблица_КИ_Клиентов;
	Таблица_Замечаний_Клиентов 				= ПараметрыЗадания.СписокТаблиц[2].Значение.Таблица_Замечаний_Клиентов;
	Таблица_Автомобилей_Клиентов 			= ПараметрыЗадания.СписокТаблиц[3].Значение.Таблица_Автомобилей_Клиентов;
	Таблица_Ключей 							= ПараметрыЗадания.СписокТаблиц[4].Значение.Таблица_Ключей;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Клиентов, "Таблица_Клиентов");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Автомобили.Ссылка КАК Ссылка,
	               |	Автомобили.Владелец КАК Владелец,
	               |	Автомобили.Код КАК Код
	               |ИЗ
	               |	Справочник.Автомобили КАК Автомобили
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	КонтрагентыЗаметки.Ссылка КАК Ссылка,
	               |	КонтрагентыЗаметки.Заметка КАК Заметка
	               |ИЗ
	               |	Справочник.Контрагенты.Заметки КАК КонтрагентыЗаметки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.ЭтоГруппа = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	РекламныеИсточники.Ссылка КАК Ссылка,
	               |	РекламныеИсточники.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.РекламныеИсточники КАК РекламныеИсточники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Клиентов.КодСинхронизации КАК КодСинхронизации,
	               |	Таблица_Клиентов.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Клиентов.Фото КАК Фото,
	               |	Контрагенты.Ссылка КАК КлиентСсылка
	               |ИЗ
	               |	Таблица_Клиентов КАК Таблица_Клиентов
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Клиентов.КодСинхронизации = Контрагенты.КодСинхронизации
	               |			И Таблица_Клиентов.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Клиентов.КодСинхронизации > 0)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Клиентов.КодСинхронизации КАК КодСинхронизации,
	               |	Таблица_Клиентов.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	МАКСИМУМ(Таблица_Клиентов.НомерАнкеты) КАК НомерАнкеты,
	               |	МАКСИМУМ(Таблица_Клиентов.Наименование) КАК Наименование,
	               |	МАКСИМУМ(Таблица_Клиентов.ДатаРождения) КАК ДатаРождения,
	               |	МАКСИМУМ(Таблица_Клиентов.Пол) КАК Пол,
	               |	МАКСИМУМ(Таблица_Клиентов.Менеджер) КАК Менеджер,
	               |	МАКСИМУМ(Таблица_Клиентов.ТелефонТип) КАК ТелефонТип,
	               |	МАКСИМУМ(Таблица_Клиентов.ТелефонКод) КАК ТелефонКод,
	               |	МАКСИМУМ(Таблица_Клиентов.ТелефонНомер) КАК ТелефонНомер,
	               |	МАКСИМУМ(Таблица_Клиентов.Дети) КАК Дети,
	               |	МАКСИМУМ(Таблица_Клиентов.Паспорт) КАК Паспорт,
	               |	МАКСИМУМ(Таблица_Клиентов.ПаспортВыдан) КАК ПаспортВыдан,
	               |	МАКСИМУМ(Таблица_Клиентов.ПаспортДата) КАК ПаспортДата,
	               |	МАКСИМУМ(Таблица_Клиентов.Адрес) КАК Адрес,
	               |	МАКСИМУМ(Таблица_Клиентов.Email) КАК Email,
	               |	МАКСИМУМ(Таблица_Клиентов.РеклИсточник) КАК РеклИсточник,
	               |	МАКСИМУМ(Таблица_Клиентов.ДатаРегистрации) КАК ДатаРегистрации,
	               |	МАКСИМУМ(Таблица_Клиентов.Фамилия) КАК Фамилия,
	               |	МАКСИМУМ(Таблица_Клиентов.Имя) КАК Имя,
	               |	МАКСИМУМ(Таблица_Клиентов.Отчество) КАК Отчество,
	               |	МАКСИМУМ(Контрагенты.Ссылка) КАК КлиентСсылка
	               |ИЗ
	               |	Таблица_Клиентов КАК Таблица_Клиентов
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Клиентов.КодСинхронизации = Контрагенты.КодСинхронизации
	               |			И Таблица_Клиентов.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Клиентов.КодСинхронизации > 0)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Клиентов.КодСинхронизации,
	               |	Таблица_Клиентов.ПрефиксСинхронизации
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КодСинхронизации";
	
	#КонецОбласти
	
	РезультатПакетаЗапросов 		= Запрос.ВыполнитьПакет();
	ТаблицаАвтомомбилейВБазе 		= РезультатПакетаЗапросов[0].Выгрузить();
	ТаблицаЗаметокКлиентов 			= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСотрудниковВБазе 		= РезультатПакетаЗапросов[2].Выгрузить();
	ТаблицаРекламныхИсточниковВБазе = РезультатПакетаЗапросов[3].Выгрузить();
	ТаблицаФото 					= РезультатПакетаЗапросов[4].Выгрузить();
	Основная_Таблица_Клиентов 		= РезультатПакетаЗапросов[5].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимых сотрудников на текущем этапе...", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Получим должность для менеджеров	
	ДолжностьМенеджер = ПолучитьДолжностьПоНаименованию("Менеджер по продажам");
	
	// Создаем необходимых сотрудников на текущем этапе
	ТаблицаМенеджеров = Основная_Таблица_Клиентов.Скопировать( , "Менеджер");
	ТаблицаМенеджеров.Свернуть("Менеджер");
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеров Цикл
		Если НЕ СокрЛП(СтрокаМенеджер.Менеджер) = "" Тогда 
			СтрокаСотрудник = ТаблицаСотрудниковВБазе.Найти(СокрЛП(СтрокаМенеджер.Менеджер), "Наименование");
			Если СтрокаСотрудник = Неопределено Тогда
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.Менеджер, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(СтрокаСотрудник.Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);
			КонецЕсли;
		КонецЕсли;      
	КонецЦикла;
	ТаблицаМенеджеровЗамечаний = Таблица_Замечаний_Клиентов.Скопировать( , "Менеджер");
	ТаблицаМенеджеровЗамечаний.Свернуть("Менеджер");
	Для Каждого СтрокаМенеджер Из ТаблицаМенеджеровЗамечаний Цикл 
		Если НЕ СокрЛП(СтрокаМенеджер.Менеджер) = "" Тогда 		
			СтрокаСотрудник = ТаблицаСотрудниковВБазе.Найти(СокрЛП(СтрокаМенеджер.Менеджер), "Наименование");
			Если СтрокаСотрудник = Неопределено Тогда 
				МенеджерСотрудник = СоздатьСотрудникаПоНаименованию(СтрокаМенеджер.Менеджер, ДолжностьМенеджер, , ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, ТекстовыйНакопитель);
				ЗаполнитьЗначенияСвойств(ТаблицаСотрудниковВБазе.Добавить(), МенеджерСотрудник);
			Иначе 
				ОбновитьМестаРаботыСотрудника(СтрокаСотрудник.Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);
			КонецЕсли;				
		КонецЕсли;
	КонецЦикла;
	
	// Активируем вид КИ: доп. телефоны 
	Если Справочники.ВидыКонтактнойИнформации.ТелефонКлиентаДополнительный.Используется = Ложь Тогда 
		ТелефонКлиентаДополнительный_Объект = Справочники.ВидыКонтактнойИнформации.ТелефонКлиентаДополнительный.ПолучитьОбъект();
		ТелефонКлиентаДополнительный_Объект.Используется = Истина;
		Если НЕ ЗначениеЗаполнено(ТелефонКлиентаДополнительный_Объект.Тип) Тогда 
			ТелефонКлиентаДополнительный_Объект.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
		КонецЕсли;	
		ТелефонКлиентаДополнительный_Объект.Записать();
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые рекламные источник в базе...", 0, ""));
	
	// Создаем необходимые рекламные источник в базе
	ТаблицаРекламныхИсточников = Основная_Таблица_Клиентов.Скопировать( , "РеклИсточник");
	ТаблицаРекламныхИсточников.Свернуть("РеклИсточник");
	Для Каждого СтрокаРекламныйИсточник Из ТаблицаРекламныхИсточников Цикл 
		Если НЕ СокрЛП(СтрокаРекламныйИсточник.РеклИсточник) = "" Тогда 		
			СтрокаРекламныйИсточникВБазе = ТаблицаРекламныхИсточниковВБазе.Найти(СокрЛП(СтрокаРекламныйИсточник.РеклИсточник), "Наименование");
			Если СтрокаРекламныйИсточникВБазе = Неопределено Тогда 
				РекламныйИсточник = Справочники.РекламныеИсточники.СоздатьЭлемент();
				РекламныйИсточник.Наименование = СокрЛП(СтрокаРекламныйИсточник.РеклИсточник);
				РекламныйИсточник.УстановитьНовыйКод();			
				РекламныйИсточник.ОбменДанными.Загрузка = Истина;
				РекламныйИсточник.Записать();
				ЗаполнитьЗначенияСвойств(ТаблицаРекламныхИсточниковВБазе.Добавить(), РекламныйИсточник);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по клиентам...';en='Saving data by to clients...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоКлиентов = Основная_Таблица_Клиентов.Количество();
	ОбщееКоличествоКлиентов = ?(ОбщееКоличествоКлиентов < 1, 1, ОбщееКоличествоКлиентов);
	ДатаНачалаПроцесса 		= ТекущаяДатаСеанса();
	ЗаписаноКлиентов 		= 0;
	ОсталосьВремени 		= Неопределено;
	ПредставлениеКлиента	= "";
	
	// Создаем клиентов
	Для Каждого СтрокаТаблицыКлиенты Из Основная_Таблица_Клиентов Цикл 
		
		НаименованиеСтрока 	= СтрокаТаблицыКлиенты.Наименование;
		ДатаРождения 	   	= СтрокаТаблицыКлиенты.ДатаРождения;
		ПолКлиента	 	   	= СтрокаТаблицыКлиенты.Пол;
		РеклИсточник 	   	= СокрЛП(СтрокаТаблицыКлиенты.РеклИсточник);
		ДатаРегистрации    	= СтрокаТаблицыКлиенты.ДатаРегистрации;
		КодСинхронизации   	= СтрокаТаблицыКлиенты.КодСинхронизации;
		ПрефиксСинхронизации= СтрокаТаблицыКлиенты.ПрефиксСинхронизации;
		НомерАнкеты		   	= СтрокаТаблицыКлиенты.НомерАнкеты;
		НомерАнкеты		   	= Формат(НомерАнкеты,"ЧГ=0");
		Дети		   	   	= СокрЛП(СтрокаТаблицыКлиенты.Дети);
		
		Если НЕ ЗначениеЗаполнено(ДатаРождения) ИЛИ ДатаРождения > ТекущаяДата() Тогда
			ДатаРождения = Дата(1,1,1);
		КонецЕсли;	
		
		Если НЕ ЗначениеЗаполнено(ДатаРегистрации) ИЛИ ДатаРегистрации > ТекущаяДата() Тогда
			ДатаРегистрации = Дата(1,1,1);
		КонецЕсли;	
		
		Если ПараметрыЗадания.ПараметрыЗагрузки.КлиентыНезашифрованы Тогда
			Фамилия 	= СокрЛП(СтрокаТаблицыКлиенты.Фамилия);
			Имя 		= СокрЛП(СтрокаТаблицыКлиенты.Имя);
			Отчество 	= СокрЛП(СтрокаТаблицыКлиенты.Отчество);
		КонецЕсли;
		
		ЭлементСоздан = Ложь;	
		// Клиент = Справочники.Контрагенты.НайтиПоРеквизиту("КодСинхронизации", КодСинхронизации);
		// Если Клиент.Пустая() Тогда
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицыКлиенты.КлиентСсылка) Тогда 	
			
			Если ПараметрыЗадания.ПараметрыЗагрузки.КлиентыНезашифрованы Тогда
				// Наименование = Фамилия+" "+Имя+" "+Отчество;
				Если ПараметрыЗадания.ПараметрыЗагрузки.ВыборПапкиСправочника.Автокоррекция = 2 Тогда
					Фамилия 		   	= ВРег(СокрЛП(Фамилия));
					Имя  			   	= ВРег(СокрЛП(Имя));
					Отчество 		   	= ВРег(СокрЛП(Отчество));
					Наименование 		= Фамилия + " " + Имя + " " + Отчество;
					Наименование       	= ВРег(СокрЛП(Наименование));
					НаименованиеПолное 	= ВРег(СокрЛП(Наименование));
				ИначеЕсли ПараметрыЗадания.ПараметрыЗагрузки.ВыборПапкиСправочника.Автокоррекция = 1 Тогда			
					Фамилия 		   	= СокрЛП(Фамилия);
					Имя 			   	= СокрЛП(Имя);
					Отчество 		   	= СокрЛП(Отчество);
					Фамилия 		  	= ВРег(Сред(Фамилия, 1, 1)) + НРег(Сред(Фамилия, 2));
					Имя 			   	= ВРег(Сред(Имя, 1, 1)) + НРег(Сред(Имя, 2));
					Отчество 		   	= ВРег(Сред(Отчество, 1, 1)) + НРег(Сред(Отчество, 2));		
					Наименование 		= Фамилия + " " + Имя + " " + Отчество;
					Наименование 	   	= СокрЛП(Наименование);
					НаименованиеПолное 	= СокрЛП(Наименование);			
				Иначе
					Фамилия 		   	= СокрЛП(Фамилия);
					Имя  			   	= СокрЛП(Имя);
					Отчество 		   	= СокрЛП(Отчество);
					Наименование 		= Фамилия + " " + Имя + " " + Отчество;
					Наименование      	= СокрЛП(Наименование);
					НаименованиеПолное 	= СокрЛП(Наименование);
				КонецЕсли;
				 
			Иначе
				Если СокрЛП(НаименованиеСтрока) = "" Тогда
					Наименование = Строка(НомерАнкеты);
					Фамилия = Строка(НомерАнкеты);
					Имя = "";
					Отчество = "";
				Иначе	
					// Сначала отделим от наименование цифровой код
					Индекс_1 = Найти(НаименованиеСтрока,"(");
					Индекс_2 = Найти(НаименованиеСтрока,")");
					Если Индекс_1 <> 0 И Индекс_2 <> 0 И Индекс_2 > Индекс_1 Тогда
						Наименование = СокрЛП(Лев(НаименованиеСтрока, Индекс_1 - 1));
					Иначе 
						Наименование = СокрЛП(НаименованиеСтрока);
					КонецЕсли;	
					
					// попытаемся разобрать наименование на Ф.И.О.
					ЧислоПробелов = СтрЧислоВхождений(Наименование, " ");
					Фамилия = "";
					Имя = "";
					Отчество = "";
					
					Если ЧислоПробелов <=2 И ЧислоПробелов > 0 Тогда // не более 3 слов в наименовании
						ВрСтр = Наименование;
						Пробел =  Найти(ВрСтр," ");
						Фамилия = Лев(ВрСтр,Пробел-1);
						ВрСтр = Прав(ВрСтр,СтрДлина(ВрСтр)-Пробел);
						
						Если СтрДлина(ВрСтр) > 0 Тогда
							Пробел =  Найти(ВрСтр," ");
							Если Пробел > 0 Тогда
								Имя = Лев(ВрСтр,Пробел-1);
								ВрСтр = Прав(ВрСтр,СтрДлина(ВрСтр)-Пробел);
							Иначе	
								Имя = СокрЛП(ВрСтр);
								ВрСтр = "";
							КонецЕсли;
						КонецЕсли;
						
						Если СтрДлина(ВрСтр) > 0 Тогда
							Отчество = СокрЛП(ВрСтр);
						КонецЕсли;		
					КонецЕсли;
					ЧислоПробелов = 0;	
				КонецЕсли;
			КонецЕсли;
			
			// Определим пол клиента
			Если СокрЛП(ПолКлиента) = "1" Тогда
				Пол = МужскойПол;
			Иначе
				Пол = ЖенскийПол;
			КонецЕсли;
						
			КлиентНайден = Ложь;
			// Если нужна синхронизация, тогда ищем клиента
			Если ПараметрыЗадания.ПараметрыЗагрузки.СинхронизироватьКлиентов Тогда
				
				ТелефонКод 		= СокрЛП(СтрокаТаблицыКлиенты.ТелефонКод);
				ТелефонНомер 	= СокрЛП(СтрокаТаблицыКлиенты.ТелефонНомер);
				
				ЗапросКлиент = Новый Запрос("ВЫБРАТЬ
				|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Клиент,
				|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
				|ИЗ
				|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
				|ГДЕ
				|	КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &НомерТелефона
				|	И КонтрагентыКонтактнаяИнформация.Тип = &Тип");
				
				ЗапросКлиент.УстановитьПараметр("НомерТелефона", "%"+ТелефонКод+ТелефонНомер);
				ЗапросКлиент.УстановитьПараметр("Тип", ТипыКИ_Телефон);
				
				РезультатКлиент = ЗапросКлиент.Выполнить().Выбрать();
				Пока РезультатКлиент.Следующий() Цикл
					
					Если ВРЕГ(РезультатКлиент.Клиент.Наименование) = ВРЕГ(Наименование) Тогда
						Если РезультатКлиент.Клиент.КодСинхронизации = 0 Тогда
							Клиент 						= РезультатКлиент.Клиент.ПолучитьОбъект();
							Клиент.Комментарий 			= ПрефиксСинхронизации + " - " + НомерАнкеты;
							Клиент.КодСинхронизации 	= КодСинхронизации;
							Клиент.ПрефиксСинхронизации = ПрефиксСинхронизации;
							КлиентНайден = Истина; 
							Прервать;
						КонецЕсли;	
					КонецЕсли;	
					
				КонецЦикла;	
				
			КонецЕсли;	
			
			Если НЕ КлиентНайден Тогда
				// Создадим нового клиента
				Клиент 						= Справочники.Контрагенты.СоздатьЭлемент();
				Клиент.Родитель 			= ПараметрыЗадания.ПараметрыЗагрузки.ВыборПапкиСправочника; 
				Клиент.Наименование 		= Наименование;
				Клиент.НаименованиеПолное 	= Наименование;
				Клиент.Комментарий 			= ПрефиксСинхронизации + " - " + НомерАнкеты;
				// Клиент.КодКлиента = НомерАнкеты;
				Клиент.КодСинхронизации 	= КодСинхронизации;
				Клиент.ПрефиксСинхронизации = ПрефиксСинхронизации;
				Клиент.Фамилия 				= Фамилия;
				Клиент.Имя 					= Имя;
				Клиент.Отчество 			= Отчество;
				Клиент.ПолКлиента 			= Пол;
				Клиент.ЮрФизЛицо 			= ФизЛицо;
				Клиент.ТипКонтрагента 		= ТипКонтрагента_Клиенты;
				Клиент.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
				Клиент.УстановитьНовыйКод();
				ЭлементСоздан 				= Истина;
			КонецЕсли;
			
		ИначеЕсли НЕ ПараметрыЗадания.ПараметрыЗагрузки.ТолькоНовые Тогда
			// Клиент = Клиент.ПолучитьОбъект();
			Клиент = СтрокаТаблицыКлиенты.КлиентСсылка.ПолучитьОбъект();
		Иначе
			Продолжить;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Клиент есть в базе ';en='Client there is at base'") + Строка(КодСинхронизации)+ "/"+ НаименованиеСтрока);
			// Возврат 0;
		КонецЕсли;
		
		Клиент.ДатаРожденияКлиента 	= ?(ЗначениеЗаполнено(Клиент.ДатаРожденияКлиента), Клиент.ДатаРожденияКлиента, ДатаРождения);
		Клиент.ДатаРегистрации 		= ?(ЗначениеЗаполнено(Клиент.ДатаРегистрации), Клиент.ДатаРегистрации, ДатаРегистрации);
		Если РеклИсточник <> "" Тогда
			СтрокаРекламныйИсточникВБазе = ТаблицаРекламныхИсточниковВБазе.Найти(РеклИсточник, "Наименование");
			Клиент.ИсточникИнформации = ?(ЗначениеЗаполнено(Клиент.ИсточникИнформации), Клиент.ИсточникИнформации, ?(СтрокаРекламныйИсточникВБазе = Неопределено, Клиент.ИсточникИнформации, СтрокаРекламныйИсточникВБазе.Ссылка));
		КонецЕсли;
		
		// МЕНЕДЖЕР КЛИЕНТА
		МенеджерСтрокой = СокрЛП(СтрокаТаблицыКлиенты.Менеджер);
		МенеджерСсылка = ТекущийПользовательСеанса;
		Если МенеджерСтрокой <> "" Тогда
			СтрокаМенеджерСотрудник = ТаблицаСотрудниковВБазе.Найти(МенеджерСтрокой, "Наименование");
			Если НЕ СтрокаМенеджерСотрудник = Неопределено Тогда
				МенеджерСсылка = СтрокаМенеджерСотрудник.Ссылка;
			КонецЕсли;
			Клиент.СотрудникРегистрации = ?(ЗначениеЗаполнено(Клиент.СотрудникРегистрации), Клиент.СотрудникРегистрации, МенеджерСсылка);			
		КонецЕсли;	
		
		// ЗАМЕТКИ (ДЕТИ, ЗАМЕЧАНИЯ)
		Если Дети <> "" Тогда
			СформированнаяЗаметкаДети = "ДЕТИ:" + Символы.ПС + Символы.Таб + Дети;
			ЗаметкаКлиента = ТаблицаЗаметокКлиентов.Найти(СформированнаяЗаметкаДети, "Заметка");
			Если ЗаметкаКлиента = Неопределено Тогда 
				Заметка 			= Клиент.Заметки.Добавить();
				Заметка.Автор 		= МенеджерСсылка;
				Заметка.Активность 	= Истина;
				Заметка.Дата 		= ?(ДатаРегистрации = Дата(1,1,1), ТекущаяДата(), ДатаРегистрации);
				Заметка.Заметка 	= СформированнаяЗаметкаДети;
			КонецЕсли;
		КонецЕсли;
		// Замечания
		МассивЗамечаний = Таблица_Замечаний_Клиентов.НайтиСтроки(Новый Структура("КодСинхронизацииКлиента, ПрефиксСинхронизации", КодСинхронизации, ПрефиксСинхронизации));
		Для Каждого ЭлементМассива Из МассивЗамечаний Цикл
			Замечание = СокрЛП(ЭлементМассива.ТекстЗамечания);
			Если Замечание <> "" Тогда
				ЗаметкаКлиента = ТаблицаЗаметокКлиентов.Найти(Замечание, "Заметка");
				Если ЗаметкаКлиента = Неопределено Тогда
					СтрокаМенеджерСделавшийЗамечание = ТаблицаСотрудниковВБазе.Найти(СокрЛП(ЭлементМассива.Менеджер), "Наименование");
					Заметка 			= Клиент.Заметки.Добавить();
					Заметка.Автор 		= ?(СтрокаМенеджерСделавшийЗамечание = Неопределено, МенеджерСсылка, СтрокаМенеджерСделавшийЗамечание.Ссылка);
					Заметка.Активность 	= Истина;
					Заметка.Дата 		= ЭлементМассива.ДатаСоздания;
					Заметка.Заметка 	= Замечание;
				КонецЕсли;
			КонецЕсли;			
		КонецЦикла;
		
		// ТЕЛЕФОН КЛИЕНТА
		МассивНомеров = Таблица_КИ_Клиентов.НайтиСтроки(Новый Структура("КодСинхронизацииКлиента, ПрефиксСинхронизации", КодСинхронизации, ПрефиксСинхронизации));
		Для Каждого ЭлементМассива Из МассивНомеров Цикл 
			ТелефонКод 		= ЭлементМассива.ТелефонКод;
			ТелефонНомер 	= ЭлементМассива.ТелефонНомер;
			ТелефонТип 		= ЭлементМассива.ТелефонТип;
			Если СокрЛП(ТелефонНомер) <> "" Тогда
				Представление	= "("+Строка(ТелефонКод)+") "+Строка(ТелефонНомер)+", "+Строка(ТелефонТип);
				// Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Представление, ТипыКИ_Телефон);
				ЗначенияПолей = Новый СписокЗначений;
				УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Представление, ЗначенияПолей, , , Ложь);
				ПолеПредставления = "";
				СтруктураКИ = Новый Структура("КодСтраны, КодГорода, НомерТелефона, Добавочный, Комментарий, Представление", "", "", "", "", "", "");
				Если ЗначенияПолей <> Неопределено Тогда
					Для Каждого ЗначениеПоля Из ЗначенияПолей Цикл
						Поле = ?(ТипЗнч(ЗначенияПолей) = Тип("Структура"), ВРег(ЗначениеПоля.Ключ), ВРег(ЗначениеПоля.Представление));
						Если Поле = "КОДСТРАНЫ" Тогда
							СтруктураКИ.КодСтраны = ЗначениеПоля.Значение;
						ИначеЕсли Поле = "КОДГОРОДА" Тогда
							СтруктураКИ.КодГорода = ЗначениеПоля.Значение;
						ИначеЕсли Поле = "НОМЕРТЕЛЕФОНА" Тогда
							СтруктураКИ.НомерТелефона = ЗначениеПоля.Значение;
						ИначеЕсли Поле = "ДОБАВОЧНЫЙ" Тогда
							СтруктураКИ.Добавочный = ЗначениеПоля.Значение;
						ИначеЕсли Поле = "КОММЕНТАРИЙ" Тогда
							СтруктураКИ.Комментарий = ЗначениеПоля.Значение;
						ИначеЕсли Поле = "ПРЕДСТАВЛЕНИЕ" Тогда
							ПолеПредставления = СокрЛП(ЗначениеПоля.Значение);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				СтруктураКИ.Представление = ?(ЗначениеЗаполнено(ПолеПредставления), ПолеПредставления, Представление);
								
				Если ЗначениеЗаполнено(СокрЛП(СтруктураКИ.НомерТелефона)) Тогда 
					СтрокаТелефон = Клиент.КонтактнаяИнформация.Найти(СтруктураКИ.НомерТелефона, "НомерТелефонаБезКодов");
					ЕстьТелефон = Клиент.КонтактнаяИнформация.Найти(ВидКИ_ТелефонКлиента, "Вид");
					Если СтрокаТелефон = Неопределено Тогда			
						НоваяСтрока = Клиент.КонтактнаяИнформация.Добавить();
						НоваяСтрока.Тип 							= ТипыКИ_Телефон;
						НоваяСтрока.НомерТелефона 					= СокрЛП(СтруктураКИ.КодСтраны) + СокрЛП(СтруктураКИ.КодГорода) + СокрЛП(СтруктураКИ.НомерТелефона);
						НоваяСтрока.НомерТелефонаБезКодов 			= СокрЛП(СтруктураКИ.НомерТелефона);
						НоваяСтрока.НомерТелефонаБезКодаСтраны 		= СокрЛП(СтруктураКИ.КодГорода) + СокрЛП(СтруктураКИ.НомерТелефона);		
						НоваяСтрока.НомерТелефонаПоследниеЦифры		= Прав(СокрЛП(СтруктураКИ.НомерТелефона), 4);									
						НоваяСтрока.Представление 					= СтруктураКИ.Представление;
						// НоваяСтрока.ЗначенияПолей 				= УправлениеКонтактнойИнформациейСлужебныйВызовСервераСтоматология.КонтактнаяИнформацияXMLПоПредставлению(Представление, ТипыКИ_Телефон);						
						НоваяСтрока.Значение 						= УправлениеКонтактнойИнформациейСлужебныйВызовСервераСтоматология.КонтактнаяИнформацияВJSON(СтруктураКИ, ТипыКИ_Телефон);
						Если ЕстьТелефон = Неопределено Тогда
							НоваяСтрока.Вид 						= ВидКИ_ТелефонКлиента;
							Клиент.Телефон 							= НоваяСтрока.Представление;
						Иначе
							НоваяСтрока.Вид 						= ВидКИ_ТелефонКлиентаДополнительный;
						КонецЕсли;
					Иначе
						СтрокаТелефон.Тип 							= ТипыКИ_Телефон;
						СтрокаТелефон.НомерТелефона 				= СокрЛП(СтруктураКИ.КодСтраны) + СокрЛП(СтруктураКИ.КодГорода) + СокрЛП(СтруктураКИ.НомерТелефона);
						СтрокаТелефон.НомерТелефонаБезКодов 		= СокрЛП(СтруктураКИ.НомерТелефона);
						СтрокаТелефон.НомерТелефонаБезКодаСтраны 	= СокрЛП(СтруктураКИ.КодГорода) + СокрЛП(СтруктураКИ.НомерТелефона);		
						СтрокаТелефон.НомерТелефонаПоследниеЦифры	= Прав(СокрЛП(СтруктураКИ.НомерТелефона), 4);									
						СтрокаТелефон.Представление 				= СтруктураКИ.Представление;						
						СтрокаТелефон.Значение 						= УправлениеКонтактнойИнформациейСлужебныйВызовСервераСтоматология.КонтактнаяИнформацияВJSON(СтруктураКИ, ТипыКИ_Телефон);
						Если ЕстьТелефон = Неопределено Тогда
							СтрокаТелефон.Вид 						= ВидКИ_ТелефонКлиента;
							Клиент.Телефон 							= СтрокаТелефон.Представление;
						Иначе
							СтрокаТелефон.Вид 						= ВидКИ_ТелефонКлиентаДополнительный;
						КонецЕсли;						
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// АДРЕС КЛИЕНТА
		Адрес = СтрокаТаблицыКлиенты.Адрес;
		Адрес = СтрЗаменить(Адрес, Символы.ПС, "");
		Адрес = СтрЗаменить(Адрес, Символы.ВК, "");
		
		Если СокрЛП(Адрес) <> "" Тогда
			
			Объект_XDTO_Адрес = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Адрес, ТипыКИ_Адрес);
			СтрокаАдрес = Клиент.КонтактнаяИнформация.Найти(СокрЛП(Адрес), "Представление");
			
			Если СтрокаАдрес = Неопределено Тогда		
				
				НоваяСтрока = Клиент.КонтактнаяИнформация.Добавить();
				НоваяСтрока.Тип 			= ТипыКИ_Адрес;
				НоваяСтрока.Вид 			= ВидКИ_АдресКлиента;
				НоваяСтрока.Страна 			= ?(Объект_XDTO_Адрес.Состав.Страна = Неопределено, "", Объект_XDTO_Адрес.Состав.Страна);
				НоваяСтрока.Город 			= ?(ТипЗнч(Объект_XDTO_Адрес.Состав.Состав) = Тип("Строка") ИЛИ Объект_XDTO_Адрес.Состав.Состав = Неопределено,"",?(Объект_XDTO_Адрес.Состав.Состав.Город = Неопределено, "", Объект_XDTO_Адрес.Состав.Состав.Город));
				НоваяСтрока.Представление 	= Объект_XDTO_Адрес.Представление;
				НоваяСтрока.ЗначенияПолей	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Адрес);
				
			КонецЕсли;
			
		КонецЕсли;
		
		// EMAIL КЛИЕНТА
		Email = СтрокаТаблицыКлиенты.Email;
		
		Если СокрЛП(Email) <> "" Тогда
			
			Объект_XDTO_Email = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Email, ТипыКИ_АдресЭлектроннойПочты);
			СтрокаEmail = Клиент.КонтактнаяИнформация.Найти(СокрЛП(Email), "Представление");
			
			Если СтрокаEmail = Неопределено Тогда		
				
				НоваяСтрока = Клиент.КонтактнаяИнформация.Добавить();
				НоваяСтрока.Тип 			= ТипыКИ_АдресЭлектроннойПочты;
				НоваяСтрока.Вид 			= ВидКИ_EmailКлиента;
				НоваяСтрока.АдресЭП 		= Объект_XDTO_Email.Представление;
				НоваяСтрока.Представление 	= НоваяСтрока.АдресЭП;
				НоваяСтрока.ЗначенияПолей	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Email);
				
			КонецЕсли;
			
		КонецЕсли;
		
		// ПАСПОРТ КЛИЕНТА
		Паспорт 	 = СтрокаТаблицыКлиенты.Паспорт;
		ПаспортВыдан = СтрокаТаблицыКлиенты.ПаспортВыдан;
		ПаспортДата	 = СтрокаТаблицыКлиенты.ПаспортДата;
		
		ПаспортВыдан = СтрЗаменить(ПаспортВыдан, Символы.ПС, "");
		ПаспортВыдан = СтрЗаменить(ПаспортВыдан, Символы.ВК, "");
		
		Если СокрЛП(Паспорт) <> "" Тогда
			
			Если Клиент.ЭтоНовый() Тогда
				Клиент.ДополнительныеСвойства.Вставить("ЗаписатьКонтрагентаБезЗапускаБП", Истина);				
				Клиент.ОбменДанными.Загрузка = Истина;
				Попытка
					Клиент.Записать();
				Исключение
					// Запись в лог						
					ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка при записи клиента! Код синхронизации: ';en= 'Error writing client! Sync code: '") + Строка(КодСинхронизации) + Символы.ПС + ОписаниеОшибки());						
				КонецПопытки;	
			КонецЕсли;
			
			ПаспортЗапись = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
			// ПаспортЗапись.Отбор.Период.Значение = ТекущаяДата();
			// ПаспортЗапись.Отбор.Период.Использование = Истина;
			ПаспортЗапись.Отбор.ВидДокумента.Значение = ВидДФЛ_ПаспортРФ;
			ПаспортЗапись.Отбор.ВидДокумента.Использование = Истина;
			ПаспортЗапись.Отбор.Физлицо.Значение = Клиент.Ссылка;
			ПаспортЗапись.Отбор.Физлицо.Использование = Истина;
			
			НоваяСтрока = ПаспортЗапись.Добавить();
			НоваяСтрока.Период		 = ТекущаяДата();
			НоваяСтрока.Физлицо      = Клиент.Ссылка;
			НоваяСтрока.ВидДокумента = ВидДФЛ_ПаспортРФ; 
			НоваяСтрока.КемВыдан	 = ПаспортВыдан;
			НоваяСтрока.Номер        = Паспорт;					
			НоваяСтрока.ДатаВыдачи = ПаспортДата;					         
			НоваяСтрока.ЯвляетсяДокументомУдостоверяющимЛичность = Истина;
			НоваяСтрока.Основной = Истина;
			
			Попытка
				ПаспортЗапись.ОбменДанными.Загрузка = Истина;
				ПаспортЗапись.Записать();
			Исключение
				
			КонецПопытки;	
			
		КонецЕсли;
		
		Клиент.ДополнительныеСвойства.Вставить("ЗаписатьКонтрагентаБезЗапускаБП", Истина);
		Клиент.ОбменДанными.Загрузка = Истина;	
		Попытка
			Клиент.Записать();
		Исключение
			// Запись в лог						
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Ошибка при записи клиента! Код синхронизации:';en='Mistake at records client! Code sync: '" + Строка(КодСинхронизации) + Символы.ПС + ОписаниеОшибки()));						
		КонецПопытки;	
		// Накапливаем статисические данные и оповещаем клиент
		ЗаписаноКлиентов 				= ЗаписаноКлиентов + 1;
		ПредставлениеКлиента			= Строка(Клиент.Ссылка);
		Прогресс 						= Цел(100 * ЗаписаноКлиентов / ОбщееКоличествоКлиентов);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по клиентам...';en='Saving data by to clients...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКлиента, ОсталосьВремени, ПредставлениеОставшегосяВремени));
					
		// Запишем фото клиента
		Если ГрузимФото Тогда
			МассивСтрокФото = ТаблицаФото.НайтиСтроки(Новый Структура("КодСинхронизации, ПрефиксСинхронизации", СтрокаТаблицыКлиенты.КодСинхронизации, СтрокаТаблицыКлиенты.ПрефиксСинхронизации));
			Если МассивСтрокФото.Количество() > 0 Тогда 
				Для Каждого ЭлементМассиваФото Из МассивСтрокФото Цикл  
					Если ЗначениеЗаполнено(ЭлементМассиваФото.Фото) Тогда 
						Если ФотоВПапке Тогда 
							АдресФото = ЭлементМассиваФото.Фото;
							АдресФото = СокрЛП(Формат(Число(АдресФото),"ЧГ=0"));
							Если СокрЛП(АдресФото) = "" Тогда
								// Запись в лог
								ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Для клиента ""%2"" наименование файла с фото не указано в базе данных (исходной таблице)';en='%1 For client ""%2"" name file with aphoto not specified in the base data original the table)'"), Символы.ПС, Строка(Клиент.Ссылка)));	
							Иначе 
								АдресФото = СокрЛП(ПараметрыЗадания.ПараметрыЗагрузки.ПапкаФотографии) + "\" + АдресФото + ".jpg";
								Файл = Новый Файл(АдресФото);
								Если Файл.Существует() Тогда 
									ДвоичныеДанные = Новый ДвоичныеДанные(АдресФото);				
									ОбменДаннымиСерверСтоматология.ЗаписатьФотоКлиентаВСправочник(ДвоичныеДанные, Клиент.Ссылка, Истина);
								Иначе 
									// Запись в лог						
									ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Для клиента %2 файл в папке с фото не найден!';en='%1 For client %2 file in folder with aphoto not found!'"), Символы.ПС, Строка(Клиент.Ссылка)));						
								КонецЕсли;	
							КонецЕсли;
						Иначе 
							ФотоСтрокаBase64 = ЭлементМассиваФото.Фото;
							ДвоичныеДанныеФото = Base64Значение(ФотоСтрокаBase64);
							Попытка
								ОбменДаннымиСерверСтоматология.ЗаписатьФотоКлиентаВСправочник(ДвоичныеДанныеФото, Клиент.Ссылка, Истина);
							Исключение
								
							КонецПопытки;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение ключей...';en='Preservation keys...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Создаем ключи
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Ключи.Ссылка КАК Ссылка,
	               |	Ключи.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	Ключи.КодКлюча КАК КодКлюча
	               |ИЗ
	               |	Справочник.Ключи КАК Ключи";
	
	ТаблицаКлючейВБазе = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаКлюч ИЗ Таблица_Ключей Цикл 
		Ключ 		= СокрЛП(СтрокаКлюч.Ключ);
		КодКлюча 	= СокрЛП(СтрокаКлюч.КодКлюча);
		КодКлюча 	= Прав(КодКлюча, 8) + Лев(КодКлюча, 6);
		Если КодКлюча <> "" И Ключ <> "" Тогда
			МассивКлючейВБазе = ТаблицаКлючейВБазе.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница, КодКлюча", ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, КодКлюча));
			Если МассивКлючейВБазе.Количество() = 0 Тогда 
				ОбъектКлюч = Справочники.Ключи.СоздатьЭлемент();
				ОбъектКлюч.СтруктурнаяЕдиница 	= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
				ОбъектКлюч.Наименование 		= ПараметрыЗадания.ПараметрыЗагрузки.ПрефиксКлючей + Ключ;
				ОбъектКлюч.КодКлюча 			= КодКлюча;
				Попытка
					ОбъектКлюч.УстановитьНовыйКод();													
					ОбъектКлюч.ОбменДанными.Загрузка = Истина;
					ОбъектКлюч.Записать();
				Исключение
					ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка при генерации ключа! Ключ: %2 Код ключа: %3 %1 %4';en='%1 Mistake at generation key! Key: %2 Code key: %3 %1 %4'"), Символы.ПС, Ключ, КодКлюча, ОписаниеОшибки()));						
				КонецПопытки;	
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;	

	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаАвтомомбилейВБазе.Очистить(); 		ТаблицаАвтомомбилейВБазе 		= Неопределено;
	ТаблицаЗаметокКлиентов.Очистить(); 			ТаблицаЗаметокКлиентов 			= Неопределено;
	ТаблицаСотрудниковВБазе.Очистить(); 		ТаблицаСотрудниковВБазе 		= Неопределено;
	ТаблицаРекламныхИсточниковВБазе.Очистить(); ТаблицаРекламныхИсточниковВБазе = Неопределено;
	Основная_Таблица_Клиентов.Очистить(); 		Основная_Таблица_Клиентов 		= Неопределено;
	
КонецПроцедуры

// Процедура - Загрузить номенклатуру в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьНоменклатуруВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Кешируем данные
	ТипНоменклатуры_Услуга 						= Перечисления.ТипыНоменклатуры.Услуга;
	ТипНоменклатуры_МодификаторЧленствПакетов	= Перечисления.ТипыНоменклатуры.МодификаторЧленствПакетов;
	ВидыУслуг_ПрочиеУслуги 						= Неопределено;
	ВидЧленствПакетовУслуг_ОграниченПосещениями = Неопределено;
	ВидЧленствПакетовУслуг_ОграниченКоличеством = Неопределено;		
	Периодичность_День 							= Перечисления.Периодичность.День;
	Периодичность_Месяц							= Перечисления.Периодичность.Месяц;
	ТипыОграничений_ОграниченПериодом 			= Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокОграниченПериодом;
	ТипыОграничений_АктивироватьПриПосещении	= Перечисления.ТипыОграниченийЧленствПакетовУслуг.АктивироватьПриПосещении;	
	ДатаУстановкиЦены 							= Дата('20010101000000');
	ВидЦены_Розничная 							= Справочники.ВидыЦен.Розничная;
	ПустаяУпаковкаНоменклатуры 					= Справочники.УпаковкиНоменклатуры.ПустаяСсылка();
	ЕдиницИзмерения_шт 							= Справочники.КлассификаторЕдиницИзмерения.шт;	
	ТекущийПользовательСеанса 					= ПараметрыСеанса.ТекущийПользователь;		
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Номенклатуры 						= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Номенклатуры;
	Таблица_Номенклатуры_Контракты 				= ПараметрыЗадания.СписокТаблиц[1].Значение.Таблица_Номенклатуры_Контракты;
	
	// 1. Номенклатура (кроме членств)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Номенклатуры			, "Таблица_Номенклатуры");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Номенклатура.Ссылка КАК Ссылка,
	               |	Номенклатура.Родитель КАК Родитель,
	               |	Номенклатура.Наименование КАК Наименование,
	               |	Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	Номенклатура.ЭтоГруппа = ИСТИНА
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СтатусыНоменклатурыСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	СтатусыНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	               |	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже,
	               |	СтатусыНоменклатурыСрезПоследних.Период КАК Период
	               |ИЗ
	               |	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&ДатаСреза, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СтатусыНоменклатурыСрезПоследних.Период,
	               |	СтатусыНоменклатурыСрезПоследних.ВПродаже,
	               |	СтатусыНоменклатурыСрезПоследних.Номенклатура,
	               |	СтатусыНоменклатурыСрезПоследних.СтруктурнаяЕдиница
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	КлассификаторЕдиницИзмерения.Ссылка КАК Ссылка,
	               |	КлассификаторЕдиницИзмерения.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Номенклатуры.КодСинхронизации КАК КодСинхронизации,
	               |	Таблица_Номенклатуры.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Номенклатуры.КодУслугиБлока КАК КодУслугиБлока,
	               |	Таблица_Номенклатуры.ИДНоменклатуры КАК ИДНоменклатуры,
	               |	Таблица_Номенклатуры.ТипНоменклатуры КАК ТипНоменклатуры,
	               |	Таблица_Номенклатуры.ВидНоменклатуры КАК ВидНоменклатуры,
	               |	Таблица_Номенклатуры.ВСоставе КАК ВСоставе,
	               |	Таблица_Номенклатуры.Активно КАК Активно,
	               |	ВЫБОР
	               |		КОГДА Таблица_Номенклатуры.ТипНоменклатуры = 3
	               |			ТОГДА ВЫБОР
	               |					КОГДА Таблица_Номенклатуры.ВСоставе = ИСТИНА
	               |						ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	               |					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	               |				КОНЕЦ
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА Таблица_Номенклатуры.ВидНоменклатуры = 0
	               |						ИЛИ Таблица_Номенклатуры.ВидНоменклатуры > 4
	               |					ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	               |				ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	               |			КОНЕЦ
	               |	КОНЕЦ КАК ТипНоменклатурыПеречисление,
	               |	Таблица_Номенклатуры.Артикул КАК Артикул,
	               |	Таблица_Номенклатуры.Штрихкод КАК Штрихкод,
	               |	Таблица_Номенклатуры.НаименованиеУслуги КАК НаименованиеУслуги,
	               |	Таблица_Номенклатуры.СокрНаименованиеУслуги КАК СокрНаименованиеУслуги,
	               |	Таблица_Номенклатуры.ПродолжительностьУслуги КАК ПродолжительностьУслуги,
	               |	Таблица_Номенклатуры.ЕдИзм КАК ЕдИзм,
	               |	Таблица_Номенклатуры.СрокДействия КАК СрокДействия,
	               |	Таблица_Номенклатуры.Количество КАК Количество,
	               |	Таблица_Номенклатуры.Цена КАК Цена,
	               |	Таблица_Номенклатуры.ПервичнаяГруппа КАК ПервичнаяГруппа,
	               |	Таблица_Номенклатуры.ВторичнаяГруппа КАК ВторичнаяГруппа,
	               |	ЕСТЬNULL(СправочникНоменклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураСсылка,
	               |	ЕСТЬNULL(СправочникНоменклатураУслугиБлоков.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураСсылкаУслугиБлока
	               |ИЗ
	               |	Таблица_Номенклатуры КАК Таблица_Номенклатуры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	               |		ПО Таблица_Номенклатуры.КодСинхронизации = СправочникНоменклатура.КодСинхронизации
	               |			И Таблица_Номенклатуры.ПрефиксСинхронизации = СправочникНоменклатура.ПрефиксСинхронизации
	               |			И (Таблица_Номенклатуры.КодСинхронизации > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатураУслугиБлоков
	               |		ПО (Таблица_Номенклатуры.КодУслугиБлока = СправочникНоменклатура.КодСинхронизации)
	               |			И (Таблица_Номенклатуры.ПрефиксСинхронизации = СправочникНоменклатура.ПрефиксСинхронизации)
	               |			И (Таблица_Номенклатуры.КодУслугиБлока > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КодСинхронизации";
	
	Запрос.УстановитьПараметр("ДатаСреза"			, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);
	
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаГруппНоменклатурыВБазе 				= РезультатПакетаЗапросов[0].Выгрузить();
	ТаблицаСтатусовНоменклатуры					= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаКлассификаторовЕдиницИзмеренияВБазе 	= РезультатПакетаЗапросов[2].Выгрузить();
	Основная_Таблица_Номенклатуры				= РезультатПакетаЗапросов[3].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые группы и ед. измерения...", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем необходимые группы
	ТаблицаГрупп = Основная_Таблица_Номенклатуры.Скопировать( , "ПервичнаяГруппа, ВторичнаяГруппа, ТипНоменклатурыПеречисление");
	ТаблицаГрупп.Свернуть("ПервичнаяГруппа, ВторичнаяГруппа, ТипНоменклатурыПеречисление");
	Для Каждого СтрокаГруппы Из ТаблицаГрупп Цикл 
		МассивГруппПервогоУровня = ТаблицаГруппНоменклатурыВБазе.НайтиСтроки(Новый Структура("Наименование, Родитель", СокрЛП(СтрокаГруппы.ПервичнаяГруппа), ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры));
		Если МассивГруппПервогоУровня.Количество() = 0 Тогда 
			ПапкаПервогоУровня 							= Справочники.Номенклатура.СоздатьГруппу();
			ПапкаПервогоУровня.Родитель 				= ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры;
			ПапкаПервогоУровня.Наименование 			= СокрЛП(СтрокаГруппы.ПервичнаяГруппа);
			ПапкаПервогоУровня.ТипНоменклатуры 			= СтрокаГруппы.ТипНоменклатурыПеречисление;
			ПапкаПервогоУровня.УстановитьНовыйКод();									
			ПапкаПервогоУровня.ОбменДанными.Загрузка 	= Истина;
			ПапкаПервогоУровня.Записать();
			ПапкаПервогоУровня 							= ПапкаПервогоУровня.Ссылка;
			ЗаполнитьЗначенияСвойств(ТаблицаГруппНоменклатурыВБазе.Добавить(), ПапкаПервогоУровня);			
		Иначе 
			ПапкаПервогоУровня 							= МассивГруппПервогоУровня[0].Ссылка;
		КонецЕсли;
		МассивГруппВторогоУровня = ТаблицаГруппНоменклатурыВБазе.НайтиСтроки(Новый Структура("Наименование, Родитель", СокрЛП(СтрокаГруппы.ВторичнаяГруппа), ПапкаПервогоУровня));
		Если МассивГруппВторогоУровня.Количество() = 0 Тогда 
			ПапкаВторогоУровня 							= Справочники.Номенклатура.СоздатьГруппу();
			ПапкаВторогоУровня.Родитель 				= ПапкаПервогоУровня;
			ПапкаВторогоУровня.Наименование 			= СокрЛП(СтрокаГруппы.ВторичнаяГруппа);
			ПапкаВторогоУровня.ТипНоменклатуры 			= СтрокаГруппы.ТипНоменклатурыПеречисление;
			ПапкаВторогоУровня.УстановитьНовыйКод();						
			ПапкаВторогоУровня.ОбменДанными.Загрузка 	= Истина;
			ПапкаВторогоУровня.Записать();
			ПапкаВторогоУровня 							= ПапкаВторогоУровня.Ссылка;
			ЗаполнитьЗначенияСвойств(ТаблицаГруппНоменклатурыВБазе.Добавить(), ПапкаВторогоУровня);
		КонецЕсли;
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые группы и ед. измерения...", 0, ""));		
	КонецЦикла;
	
	// Создаем необходимые единицы измерения
	ТаблицаЕдИзм = Основная_Таблица_Номенклатуры.Скопировать( , "ЕдИзм");
	ТаблицаЕдИзм.Свернуть("ЕдИзм");
	Для Каждого СтрокаЕдИзм Из ТаблицаЕдИзм Цикл
		Если ЗначениеЗаполнено(СокрЛП(СтрокаЕдИзм.ЕдИзм)) Тогда 
			СтрокаТЗ_ЕдИзм = ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Найти(СокрЛП(СтрокаЕдИзм.ЕдИзм), "Наименование");
			Если СтрокаТЗ_ЕдИзм = Неопределено Тогда 
				ЕдИзм 						= Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
				ЕдИзм.Наименование 			= СокрЛП(СтрокаЕдИзм.ЕдИзм);
				ЕдИзм.НаименованиеПолное 	= СокрЛП(СтрокаЕдИзм.ЕдИзм);
				ЕдИзм.УстановитьНовыйКод();			
				ЕдИзм.ОбменДанными.Загрузка = Истина;
				ЕдИзм.Записать();
				ЗаполнитьЗначенияСвойств(ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Добавить(), ЕдИзм);			
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по номенклатуре...';en='Saving data by nomenclature...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоНоменклатуры = Основная_Таблица_Номенклатуры.Количество();
	ОбщееКоличествоНоменклатуры	= ?(ОбщееКоличествоНоменклатуры < 1, 1, ОбщееКоличествоНоменклатуры);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоНоменклатур 			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеНоменклатуры	= "";
	
	// Проходим основную таблицу
	Для Каждого СтрокаТаблицыНоменклатуры Из Основная_Таблица_Номенклатуры Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.НоменклатураСсылка) Тогда 
			Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.Штрихкод) Тогда		
				НаборЗаписей = РегистрыСведений.Штрихкоды.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Объект.Установить(СтрокаТаблицыНоменклатуры.НоменклатураСсылка);
				НаборЗаписей.Отбор.Штрихкод.Установить(СтрокаТаблицыНоменклатуры.Штрихкод);
				НоваяСтрока = НаборЗаписей.Добавить();
				НоваяСтрока.Объект 			   = СтрокаТаблицыНоменклатуры.НоменклатураСсылка;		
				НоваяСтрока.Штрихкод 		   = СтрокаТаблицыНоменклатуры.Штрихкод;
				НаборЗаписей.Записать();          				
			КонецЕсли;			
			// Если ПараметрыЗадания.ПараметрыЗагрузки.ТолькоНовые Тогда 
				Продолжить;
			// Иначе 
			//	НоменклатураУслуги 				= СтрокаТаблицыНоменклатуры.НоменклатураСсылка.ПолучитьОбъект();
			// КонецЕсли;
		Иначе 
			НоменклатураУслуги 					= Справочники.Номенклатура.СоздатьЭлемент();
		КонецЕсли;	
		КодУслуги 			= СтрокаТаблицыНоменклатуры.ИДНоменклатуры;
		НаименованиеУслуги 	= СтрокаТаблицыНоменклатуры.НаименованиеУслуги;
		Если КодУслуги = 0 ИЛИ СокрЛП(НаименованиеУслуги) = "" Тогда
			Продолжить;
		КонецЕсли;
		
		// Определяем родителя
		МассивГруппПервогоУровня = ТаблицаГруппНоменклатурыВБазе.НайтиСтроки(Новый Структура("Наименование, Родитель", СокрЛП(СтрокаТаблицыНоменклатуры.ПервичнаяГруппа), ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры));
		Если МассивГруппПервогоУровня.Количество() = 0 Тогда
			ГруппаВторогоУровня = ТаблицаГруппНоменклатурыВБазе.Найти(СокрЛП(СтрокаТаблицыНоменклатуры.ВторичнаяГруппа), "Наименование");
			РодительУслуги = ?(ГруппаВторогоУровня = Неопределено, ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры, ГруппаВторогоУровня.Ссылка);
		Иначе 
			МассивГруппВторогоУровня = ТаблицаГруппНоменклатурыВБазе.НайтиСтроки(Новый Структура("Наименование, Родитель", СокрЛП(СтрокаТаблицыНоменклатуры.ВторичнаяГруппа), МассивГруппПервогоУровня[0].Ссылка));
			Если МассивГруппВторогоУровня.Количество() = 0 Тогда 
				РодительУслуги =  МассивГруппПервогоУровня[0].Ссылка;
			Иначе 
				РодительУслуги = МассивГруппВторогоУровня[0].Ссылка;
			КонецЕсли;	
		КонецЕсли;	
		
		// Заполняем по родителю
		СтруктураЗаполнения 						= Новый Структура("Родитель", РодительУслуги);
		// НоменклатураУслуги 							= Справочники.Номенклатура.СоздатьЭлемент();
		НоменклатураУслуги.Заполнить(СтруктураЗаполнения);
		// Общие реквизиты
		НоменклатураУслуги.ТипНоменклатуры 			= СтрокаТаблицыНоменклатуры.ТипНоменклатурыПеречисление;
		НоменклатураУслуги.КодСинхронизации 		= СтрокаТаблицыНоменклатуры.КодСинхронизации;
		НоменклатураУслуги.ПрефиксСинхронизации 	= СтрокаТаблицыНоменклатуры.ПрефиксСинхронизации;
		НоменклатураУслуги.Комментарий 				= СтрокаТаблицыНоменклатуры.ПрефиксСинхронизации + " - " + Формат(СтрокаТаблицыНоменклатуры.КодСинхронизации, "ЧГ=0"); 
		НоменклатураУслуги.Наименование 			= СокрЛП(НаименованиеУслуги);
		НоменклатураУслуги.НаименованиеПолное 		= СокрЛП(НаименованиеУслуги);
		НоменклатураУслуги.Артикул 					= СтрокаТаблицыНоменклатуры.Артикул;	
		
		// Реквизиты по типам
		Если СтрокаТаблицыНоменклатуры.ТипНоменклатурыПеречисление = ТипНоменклатуры_Услуга Тогда
			НоменклатураУслуги.НормаВремени 		= СтрокаТаблицыНоменклатуры.ПродолжительностьУслуги;
			НоменклатураУслуги.СписыватьПриПродаже 	= Истина;
		Иначе // Запас
			СтрокаЕдИзм = СокрЛП(СтрокаТаблицыНоменклатуры.ЕдИзм);
			Если СтрокаЕдИзм = "" Тогда
				НоменклатураУслуги.ЕдиницаИзмерения = ЕдиницИзмерения_шт;	
			ИначеЕсли СтрНайти(СтрокаЕдИзм, "шт") = 0 Тогда
				СтрокаТЗ_КЕИ = ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Найти(СтрокаЕдИзм, "Наименование");
				Если СтрокаТЗ_КЕИ = Неопределено Тогда 
					ЕдИзм = Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
					ЕдИзм.Наименование 			= СтрокаЕдИзм;
					ЕдИзм.НаименованиеПолное 	= СтрокаЕдИзм;
					ЕдИзм.УстановитьНовыйКод();			
					ЕдИзм.ОбменДанными.Загрузка = Истина;
					ЕдИзм.Записать();
				КонецЕсли;
				НоменклатураУслуги.ЕдиницаИзмерения = СтрокаТЗ_КЕИ.Ссылка;
			Иначе
				НоменклатураУслуги.ЕдиницаИзмерения = ЕдиницИзмерения_шт;
			КонецЕсли;
		КонецЕсли;
		
		Цена = СтрокаТаблицыНоменклатуры.Цена;
		Если Цена <= 0 Тогда
			НоменклатураУслуги.Бесплатно = Истина;	
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(НоменклатураУслуги.Код) Тогда 
			НоменклатураУслуги.УстановитьНовыйКод();
		КонецЕсли;	
		НоменклатураУслуги.ОбменДанными.Загрузка = Истина;
		Попытка
			НоменклатураУслуги.Записать();
		Исключение
			// Запись в лог						
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка при записи номенклатуры! Код синхронизации: ';en= 'Error writing item! Sync code: '") + Строка(СтрокаТаблицыНоменклатуры.КодСинхронизации) + Символы.ПС + ОписаниеОшибки());						
		КонецПопытки;
		
		// Накапливаем статисические данные и оповещаем клиент
		СозданоНоменклатур 				= СозданоНоменклатур + 1;
		ПредставлениеНоменклатуры		= Строка(НоменклатураУслуги.Ссылка);
		Прогресс 						= Цел(100 * СозданоНоменклатур / ОбщееКоличествоНоменклатуры);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по номенклатуре...';en='Saving data by nomenclature...'") + Символы.Таб + НСтр("ru= ' Осталось: ';en= ' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеНоменклатуры, ОсталосьВремени, ПредставлениеОставшегосяВремени));
		
		Если СтрокаТаблицыНоменклатуры.Активно = 0 Тогда
			// Установим статус номенклатуре
			МассивСтрокСтатусовНоменклатуры = ТаблицаСтатусовНоменклатуры.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница, Номенклатура", ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, НоменклатураУслуги.Ссылка));
			Если НЕ МассивСтрокСтатусовНоменклатуры.Количество() = 0 Тогда
				ВПродаже 	= МассивСтрокСтатусовНоменклатуры[0].ВПродаже;
				ДатаСтатуса = МассивСтрокСтатусовНоменклатуры[0].Период;
				ЕстьСтатус 	= Истина;
			Иначе
				ВПродаже 	= Истина;
				ДатаСтатуса = Дата(1,1,1);
				ЕстьСтатус 	= Ложь;
			КонецЕсли;	
			СтруктураСтатус = Новый Структура("ВПродаже, ДатаСтатуса, ЕстьСтатус", ВПродаже, ДатаСтатуса, ЕстьСтатус);			
			РегистрыСведений.СтатусыНоменклатуры.УстановитьСтатусПродажиНоменклатуры(ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, НоменклатураУслуги.Ссылка, НачалоДня(ТекущаяДатаСеанса()), Ложь, СтруктураСтатус);	
		КонецЕсли;
		
		Если Цена > 0 Тогда
			// Справочники.Номенклатура.УстановитьЦенуНоменклатуры(НоменклатураУслуги.Ссылка, Справочники.ВидыЦен.Розничная, Справочники.УпаковкиНоменклатуры.ПустаяСсылка(), СтруктурнаяЕдиница, Цена);
			НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			НоваяЦена.Номенклатура       = НоменклатураУслуги.Ссылка;
			НоваяЦена.ВидЦен             = ВидЦены_Розничная;
			НоваяЦена.Цена               = Цена;
			НоваяЦена.Упаковка           = ПустаяУпаковкаНоменклатуры;
			НоваяЦена.Период             = ДатаУстановкиЦены;
			НоваяЦена.Автор              = ТекущийПользовательСеанса;
			НоваяЦена.Записать();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.Штрихкод) Тогда		
			НаборЗаписей = РегистрыСведений.Штрихкоды.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Объект.Установить(НоменклатураУслуги.Ссылка);
			НаборЗаписей.Отбор.Штрихкод.Установить(СтрокаТаблицыНоменклатуры.Штрихкод);
			НоваяСтрока = НаборЗаписей.Добавить();
			НоваяСтрока.Объект 			   = НоменклатураУслуги.Ссылка;		
			НоваяСтрока.Штрихкод 		   = СтрокаТаблицыНоменклатуры.Штрихкод;
			НаборЗаписей.Записать();          				
		КонецЕсли;
		
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаГруппНоменклатурыВБазе.Очистить(); 				ТаблицаГруппНоменклатурыВБазе 				= Неопределено;
	ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Очистить(); 	ТаблицаКлассификаторовЕдиницИзмеренияВБазе 	= Неопределено;
	Основная_Таблица_Номенклатуры.Очистить();				Основная_Таблица_Номенклатуры 				= Неопределено;
	
	// ==============================================================================================================================

	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных (членства)...';en='Start process save data memberships)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Создадим группу членства	
	ГруппаЧленств = Справочники.Номенклатура.НайтиПоНаименованию("Членства", Истина, ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры);
	Если ГруппаЧленств.Пустая() ИЛИ НЕ ГруппаЧленств.ЭтоГруппа Тогда
		ГруппаЧленств 						= Справочники.Номенклатура.СоздатьГруппу();
		ГруппаЧленств.Наименование 			= "Членства";
		ГруппаЧленств.Родитель 				= ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры;
		ГруппаЧленств.ТипНоменклатуры 		= Неопределено;
		ГруппаЧленств.ОбменДанными.Загрузка = Истина;							
		ГруппаЧленств.Записать();
		ГруппаЧленств 						= ГруппаЧленств.Ссылка;
	КонецЕсли;
		
	// 2. Номенклатура (членства)		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Номенклатуры_Контракты	, "Таблица_Номенклатуры_Контракты");	
	Запрос.Текст = "ВЫБРАТЬ
	               |	Таблица_Номенклатуры_Контракты.ИмяКатегории КАК ИмяКатегории
	               |ИЗ
	               |	Таблица_Номенклатуры_Контракты КАК Таблица_Номенклатуры_Контракты
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Номенклатуры_Контракты.ИмяКатегории
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Номенклатура.Ссылка КАК Ссылка,
	               |	Номенклатура.Родитель КАК Родитель,
	               |	Номенклатура.Наименование КАК Наименование,
	               |	Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	Номенклатура.ЭтоГруппа = ИСТИНА
	               |	И Номенклатура.Родитель = &Родитель
	               |	И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементЧленство)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Номенклатуры_Контракты.КодСинхронизации КАК КодСинхронизации,
	               |	Таблица_Номенклатуры_Контракты.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Номенклатуры_Контракты.ИДКатегории КАК ИДКатегории,
	               |	Таблица_Номенклатуры_Контракты.ИДИнтервала КАК ИДИнтервала,
	               |	Таблица_Номенклатуры_Контракты.ИмяКатегории КАК ИмяКатегории,
	               |	Таблица_Номенклатуры_Контракты.ИмяИнтервала КАК ИмяИнтервала,
	               |	Таблица_Номенклатуры_Контракты.НаименованиеЧленства КАК НаименованиеЧленства,
	               |	Таблица_Номенклатуры_Контракты.ПериодКонтракта КАК ПериодКонтракта,
	               |	Таблица_Номенклатуры_Контракты.ДлинаПериода КАК ДлинаПериода,
	               |	Таблица_Номенклатуры_Контракты.Заморозок КАК Заморозок,
	               |	Таблица_Номенклатуры_Контракты.КоличествоПосещений КАК КоличествоПосещений,
	               |	Таблица_Номенклатуры_Контракты.Цена КАК Цена,
	               |	Таблица_Номенклатуры_Контракты.ИДуслуги КАК ИДуслуги,
	               |	Таблица_Номенклатуры_Контракты.Количество КАК Количество,
	               |	Таблица_Номенклатуры_Контракты.Ограничена КАК Ограничена,
	               |	Таблица_Номенклатуры_Контракты.Активна КАК Активна,
	               |	ЕСТЬNULL(НоменклатураУ.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураУслуги,
	               |	ЕСТЬNULL(НоменклатураЧ.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураЧленства
	               |ИЗ
	               |	Таблица_Номенклатуры_Контракты КАК Таблица_Номенклатуры_Контракты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураУ
	               |		ПО Таблица_Номенклатуры_Контракты.ИДуслуги = НоменклатураУ.КодСинхронизации
	               |			И Таблица_Номенклатуры_Контракты.ПрефиксСинхронизации = НоменклатураУ.ПрефиксСинхронизации
	               |			И (Таблица_Номенклатуры_Контракты.ИДуслуги > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураЧ
	               |		ПО Таблица_Номенклатуры_Контракты.КодСинхронизации = НоменклатураЧ.КодСинхронизации
	               |			И Таблица_Номенклатуры_Контракты.ПрефиксСинхронизации = НоменклатураЧ.ПрефиксСинхронизации
	               |			И (Таблица_Номенклатуры_Контракты.КодСинхронизации > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Таблица_Номенклатуры_Контракты.ИДКатегории,
	               |	Таблица_Номенклатуры_Контракты.ИДИнтервала
	               |ИТОГИ
	               |	МАКСИМУМ(ИмяКатегории)
	               |ПО
	               |	ИДКатегории,
	               |	ИДИнтервала";
		
	Запрос.УстановитьПараметр("Родитель", ГруппаЧленств);
	
	РезультатПакетаЗапросов		= Запрос.ВыполнитьПакет();
	
	МассивГруппШаблонов 		= РезультатПакетаЗапросов[0].Выгрузить().ВыгрузитьКолонку("ИмяКатегории");
	ТаблицаГруппШаблоновВБазе 	= РезультатПакетаЗапросов[1].Выгрузить();
	ВыборкаПоКатегориям 		= РезультатПакетаЗапросов[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые группы шаблонов...", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем группы шаблонов членств
	Для Каждого ГруппаШаблона Из МассивГруппШаблонов Цикл 
		СтрокаТаблицыГруппШаблоновВБазе = ТаблицаГруппШаблоновВБазе.Найти(СокрЛП(ГруппаШаблона), "Наименование");
		Если СтрокаТаблицыГруппШаблоновВБазе = Неопределено Тогда 
			ГруппШаблоновВБазе 							= Справочники.Номенклатура.СоздатьГруппу();
			ГруппШаблоновВБазе.Родитель 				= ГруппаЧленств;
			ГруппШаблоновВБазе.Наименование 			= СокрЛП(ГруппаШаблона);
			ГруппШаблоновВБазе.ТипНоменклатуры 			= Неопределено;
			ГруппШаблоновВБазе.УстановитьНовыйКод();
			ГруппШаблоновВБазе.ОбменДанными.Загрузка 	= Истина;
			ГруппШаблоновВБазе.Записать();
			ЗаполнитьЗначенияСвойств(ТаблицаГруппШаблоновВБазе.Добавить(), ГруппШаблоновВБазе);
		КонецЕсли;	
	КонецЦикла;
	
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по номенклатуре (членства)...';en='Saving data by nomenclature membership)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоНоменклатуры = ВыборкаПоКатегориям.Количество();
	ОбщееКоличествоНоменклатуры	= ?(ОбщееКоличествоНоменклатуры < 1, 1, ОбщееКоличествоНоменклатуры);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоНоменклатур 			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеНоменклатуры	= "";
	
	// Начинаем обход с категорий (шаблонов)
	Пока ВыборкаПоКатегориям.Следующий() Цикл
		
		ВыборкаПоИнтервалам = ВыборкаПоКатегориям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПоИнтервалам.Следующий() Цикл
			
			СтрокаИнтервал = ВыборкаПоИнтервалам.Выбрать();
			СтрокаИнтервал.Следующий();
			
			КодЧленства = Строка(СтрокаИнтервал.ИДКатегории) + Строка(СтрокаИнтервал.ИДИнтервала);
			// НаименованиеЧленства = СтрокаИнтервал.ИмяКатегории + " " + СтрокаИнтервал.ИмяИнтервала;
			НаименованиеЧленства = СтрокаИнтервал.НаименованиеЧленства;
			
			Если КодЧленства = "" ИЛИ СокрЛП(НаименованиеЧленства) = "" Тогда
				Продолжить;
			КонецЕсли;	
			
			// КодЧленства = "100000" + КодЧленства;
			// КодЧленства = Число(КодЧленства);
			КодЧленства 			= СтрокаИнтервал.КодСинхронизации;
			ПрефиксСинхронизации 	= СтрокаИнтервал.ПрефиксСинхронизации;
			
			Если ЗначениеЗаполнено(СтрокаИнтервал.НоменклатураЧленства) Тогда 
				Если ПараметрыЗадания.ПараметрыЗагрузки.ТолькоНовые Тогда 
					Продолжить;
				Иначе 
					НоменклатураЧленства 				= СтрокаИнтервал.НоменклатураЧленства.ПолучитьОбъект();
				КонецЕсли;
			Иначе 
				НоменклатураЧленства 					= Справочники.Номенклатура.СоздатьЭлемент();
			КонецЕсли;	
			
			СтрокаТаблицыГруппШаблоновВБазе = ТаблицаГруппШаблоновВБазе.Найти(СокрЛП(ВыборкаПоКатегориям.ИмяКатегории), "Наименование");
			Если СтрокаТаблицыГруппШаблоновВБазе = Неопределено Тогда 
				СтруктураЗаполнения = Новый Структура("Родитель", ГруппаЧленств);
			Иначе 
				СтруктураЗаполнения = Новый Структура("Родитель", СтрокаТаблицыГруппШаблоновВБазе.Ссылка);
			КонецЕсли;
			
			// НоменклатураЧленства 						= Справочники.Номенклатура.СоздатьЭлемент();
			НоменклатураЧленства.Заполнить(СтруктураЗаполнения);
			НоменклатураЧленства.КодСинхронизации 		= КодЧленства;
			НоменклатураЧленства.ПрефиксСинхронизации 	= ПрефиксСинхронизации;
			НоменклатураЧленства.Комментарий 			= ПрефиксСинхронизации + " - " + Формат(КодЧленства, "ЧГ=0");
			НоменклатураЧленства.Наименование 			= СокрЛП(НаименованиеЧленства);
			
			// Период
			НоменклатураЧленства.ЧленствоПакетУслугОграничениеПоСрокуДействия = ТипыОграничений_ОграниченПериодом;
			Если СтрокаИнтервал.ПериодКонтракта = "Y" ИЛИ СтрокаИнтервал.ПериодКонтракта = "M" Тогда
				НоменклатураЧленства.ЧленствоПакетУслугСрокДействияТип = Периодичность_Месяц;	
			Иначе	
				НоменклатураЧленства.ЧленствоПакетУслугСрокДействияТип = Периодичность_День;	
			КонецЕсли;
			
			Если СтрокаИнтервал.ПериодКонтракта = "Y" Тогда
				Коэф = 12;
			ИначеЕсли СтрокаИнтервал.ПериодКонтракта = "W" Тогда
				Коэф = 7;	
			Иначе	
				Коэф = 1;
			КонецЕсли;	
			
			НоменклатураЧленства.ЧленствоПакетУслугСрокДействия 							= СтрокаИнтервал.ДлинаПериода * Коэф;				
			НоменклатураЧленства.ЧленстваПакетаУслугАвтоматическиАктивироватьТип 			= ТипыОграничений_АктивироватьПриПосещении;
			НоменклатураЧленства.ЧленстваПакетаУслугАвтоматическиАктивироватьЧерез 			= 30;
			НоменклатураЧленства.ЧленствоПакетУслугКоличествоДнейЗаморозок 					= СтрокаИнтервал.Заморозок;
			НоменклатураЧленства.ЧленстваПакетаУслугАвтоматическиАктивироватьПриПродлении 	= Истина;
			
			Если СтрокаИнтервал.КоличествоПосещений > 0 Тогда
				НоменклатураЧленства.ЧленствоПакетУслугВидЧленстваПакетаУслуг 				= ВидЧленствПакетовУслуг_ОграниченПосещениями;
				НоменклатураЧленства.ЧленствоПакетУслугКоличествоПосещений 					= СтрокаИнтервал.КоличествоПосещений;
			КонецЕсли;	
			
			// Состав услуг
			ЕстьСтрокаУслуг = Ложь;
			ЕстьКоличество = Ложь;
			ЕстьНеограниченно = Ложь;
			ВыборкаПоСоставу = ВыборкаПоИнтервалам.Выбрать();
			Пока ВыборкаПоСоставу.Следующий() Цикл
				Если ЗначениеЗаполнено(ВыборкаПоСоставу.НоменклатураУслуги) Тогда
					СтрокаСостава 				= НоменклатураЧленства.ЧленствоПакетУслугСоставУслуг.Найти(ВыборкаПоСоставу.НоменклатураУслуги, "УслугаСегмент");
					Если СтрокаСостава = Неопределено Тогда 
						НС 						= НоменклатураЧленства.ЧленствоПакетУслугСоставУслуг.Добавить();
					Иначе 
						НС 						= СтрокаСостава;
					КонецЕсли;	
					НС.УслугаСегмент 			= ВыборкаПоСоставу.НоменклатураУслуги;
					Если ВыборкаПоСоставу.Ограничена = 0 Тогда
						НС.Количество 			= ВыборкаПоСоставу.Количество;	
					Иначе
						НС.ПосещенийНеЧаще 		= ВыборкаПоСоставу.Количество;
						НС.ПосещенийНеЧащеТип 	= Перечисления.Периодичность.День 
					КонецЕсли;
					ЕстьСтрокаУслуг = Истина;
					Если НС.Количество > 0 Тогда 
						ЕстьКоличество = Истина;
					Иначе 
						ЕстьНеограниченно = Истина;
					КонецЕсли;						
				ИначеЕсли ВыборкаПоСоставу.ИДуслуги <> 0 Тогда
					// Запись в лог
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не найдена услуга с кодом ';en='Not found service with code '") + Строка(ВыборкаПоСоставу.ИДуслуги));
					ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Не найдена услуга с кодом ';en='Not found service with code '") + Строка(ВыборкаПоСоставу.ИДуслуги) + Символы.ПС + ОписаниеОшибки());						
				КонецЕсли;
			КонецЦикла;
			НоменклатураЧленства.ЧленствоПакетУслугСоставУслуг.Свернуть("УслугаСегмент, Количество, ПосещенийНеЧаще, ПосещенийНеЧащеТип");
						
			Если НЕ ЗначениеЗаполнено(НоменклатураЧленства.Код) Тогда 
				НоменклатураЧленства.УстановитьНовыйКод();
			КонецЕсли;	
			НоменклатураЧленства.ОбменДанными.Загрузка = Истина;				
			НоменклатураЧленства.Записать();
			Попытка
				НоменклатураЧленства.Записать();
			Исключение
				// Запись в лог						
				ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Ошибка при записи номенклатуры! Код синхронизации: ';en='Mistake at records nomenclature! Code sync: '") + Строка(КодЧленства) + Символы.ПС + ОписаниеОшибки());						
			КонецПопытки;
			
			// Накапливаем статисические данные и оповещаем клиент
			СозданоНоменклатур 				= СозданоНоменклатур + 1;
			ПредставлениеНоменклатуры		= Строка(НоменклатураЧленства.Ссылка);
			Прогресс 						= Цел(100 * СозданоНоменклатур / ОбщееКоличествоНоменклатуры);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по номенклатуре (членства)...';en='Saving data by nomenclature membership)...'") + Символы.Таб + НСтр("ru= ' Осталось: ';en= ' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеНоменклатуры, ОсталосьВремени, ПредставлениеОставшегосяВремени));
			
			Если НЕ СтрокаИнтервал.Активна Тогда
				// Установим статус номенклатуре
				МассивСтрокСтатусовНоменклатуры = ТаблицаСтатусовНоменклатуры.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница, Номенклатура", ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, НоменклатураЧленства.Ссылка));
				Если НЕ МассивСтрокСтатусовНоменклатуры.Количество() = 0 Тогда
					ВПродаже 	= МассивСтрокСтатусовНоменклатуры[0].ВПродаже;
					ДатаСтатуса = МассивСтрокСтатусовНоменклатуры[0].Период;
					ЕстьСтатус 	= Истина;
				Иначе
					ВПродаже 	= Истина;
					ДатаСтатуса = Дата(1,1,1);
					ЕстьСтатус 	= Ложь;
				КонецЕсли;	
				СтруктураСтатус = Новый Структура("ВПродаже, ДатаСтатуса, ЕстьСтатус", ВПродаже, ДатаСтатуса, ЕстьСтатус);
				РегистрыСведений.СтатусыНоменклатуры.УстановитьСтатусПродажиНоменклатуры(ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, НоменклатураЧленства.Ссылка, НачалоДня(ТекущаяДатаСеанса()), Ложь, СтруктураСтатус);			
			КонецЕсли;	
			// Цена				
			// Справочники.Номенклатура.УстановитьЦенуНоменклатуры(НоменклатураЧленства.Ссылка, Справочники.ВидыЦен.Розничная, Справочники.УпаковкиНоменклатуры.ПустаяСсылка(), СтруктурнаяЕдиница, СтрокаИнтервал.Цена);
			НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			НоваяЦена.Номенклатура       = НоменклатураЧленства.Ссылка;
			НоваяЦена.ВидЦен             = ВидЦены_Розничная;
			НоваяЦена.Цена               = СтрокаИнтервал.Цена;
			НоваяЦена.Упаковка           = ПустаяУпаковкаНоменклатуры;
			НоваяЦена.Период             = ДатаУстановкиЦены;
			НоваяЦена.Автор              = ТекущийПользовательСеанса;
			НоваяЦена.Записать();
		КонецЦикла;
	КонецЦикла;

	// Найдем или создадим номенклатуру модификатора членства
	Модификатор = Справочники.Номенклатура.НайтиПоНаименованию("Бонусные дни", Истина);
	Если Модификатор.Пустая() Тогда
		Модификатор 										= Справочники.Номенклатура.СоздатьЭлемент();
		Модификатор.Наименование 							= "Бонусные дни";
		Модификатор.НаименованиеПолное 						= "Бонусные дни";
		Модификатор.ЕдиницаИзмерения 						= ЕдиницИзмерения_шт;
		Модификатор.Бесплатно 								= Истина;
		Модификатор.ТипНоменклатуры 						= ТипНоменклатуры_МодификаторЧленствПакетов;
		Модификатор.МодификаторПризнакКоличествоУказывается = Истина;
		Модификатор.МодификаторТипСрокаДействия 			= Периодичность_День;
		Модификатор.Записать();
	КонецЕсли;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаСтатусовНоменклатуры.Очистить();					ТаблицаСтатусовНоменклатуры 				= Неопределено;
	МассивГруппШаблонов.Очистить(); 						МассивГруппШаблонов 						= Неопределено;
	ТаблицаГруппШаблоновВБазе.Очистить(); 					ТаблицаГруппШаблоновВБазе 					= Неопределено;
									 						ВыборкаПоКатегориям 						= Неопределено;
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;	
		      
КонецПроцедуры

// Процедура - Загрузить контракты в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьКонтрактыВФонеAccess(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Кешируем данные
	Менеджер 											= Справочники.Сотрудники.ПустаяСсылка();
	ТекущийПользовательСеанса 							= ПараметрыСеанса.ТекущийПользователь;
	ВидКартыШтриховая 									= Перечисления.ВидыКарт.Штриховая;	
	ВидКарты_Магнитная 									= Перечисления.ВидыКарт.Магнитная;		
	ВидЦен_Розничная 									= Справочники.ВидыЦен.Розничная;
	ТипПродленияЧленстваПакетаУслуг_Продление 			= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Продление;
	ТипПродленияЧленстваПакетаУслуг_Новое				= Перечисления.ТипыПродленияЧленстваПакетаУслуг.Новое;
	ТипСрокаДействия_День 								= Перечисления.Периодичность.День;
	ТипДенежныхСредств_Наличные 						= Перечисления.ТипыДенежныхСредств.Наличные;
	СтруктураВидовДДС 									= Новый Структура;
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ОплатаОтКлиенат"		, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ОплатаОтКлиента));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ВзносНаЛицевойСчет"	, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВзносНаЛицевойСчет));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ПрочееСписание"		, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ПрочееСписание));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ВозвратОплатыКлиенту"	, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту));
	СтруктураВидовДДС.Вставить("СтатьяДвиженияДенежныхСредств_ПрочееПоступление"	, Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСтатьюПоУмолчаниюДляОперации(Перечисления.ВидыОпераций.ПрочееПоступление));
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Контракты 									= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Контракты;
	
	#Область Пакетный_Запрос
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Контракты, "Таблица_Контракты");
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Таблица_Контракты.Организация КАК Организация
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Контракты.Организация
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Таблица_Контракты.ОрганизацияКонтракта
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Контракты.ОрганизацияКонтракта
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Контракты.КартаКлиента КАК КартаКлиента,
	               |	Таблица_Контракты.КартаНомер КАК КартаНомер,
	               |	Таблица_Контракты.НачалоКонтракта КАК НачалоКонтракта,
	               |	Контрагенты.Ссылка КАК Клиент
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Контракты.ИДКлиента = Контрагенты.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКлиента > 0)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Контракты.НачалоКонтракта,
	               |	Таблица_Контракты.КартаНомер,
	               |	Контрагенты.Ссылка,
	               |	Таблица_Контракты.КартаКлиента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Карты.Ссылка КАК Ссылка,
	               |	Карты.ВнутреннийКодКарты КАК ВнутреннийКодКарты,
	               |	Карты.ВладелецКарты КАК ВладелецКарты
	               |ИЗ
	               |	Справочник.Карты КАК Карты
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Контракты.Менеджер КАК Менеджер
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Контракты.Менеджер
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Таблица_Контракты.ОператорОплаты
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Таблица_Контракты.ОператорОплаты
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Ссылка,
	               |	Сотрудники.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.ЭтоГруппа = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВидыЛицевыхСчетов.Ссылка КАК Ссылка,
	               |	ВидыЛицевыхСчетов.Наименование КАК Наименование,
	               |	ВидыЛицевыхСчетов.Предопределенный КАК Предопределенный,
	               |	ВидыЛицевыхСчетов.ОграничиватьСуммуСписанияСоСчета КАК ОграничиватьСуммуСписанияСоСчета,
	               |	ВидыЛицевыхСчетов.ПроцентОграниченияСуммыСписанияСоСчета КАК ПроцентОграниченияСуммыСписанияСоСчета,
	               |	ВидыЛицевыхСчетов.ОграничениеПоСрокуДействия КАК ОграничениеПоСрокуДействия,
	               |	ВидыЛицевыхСчетов.Внешний КАК Внешний,
	               |	ВидыЛицевыхСчетов.Организация КАК Организация,
	               |	ВидыЛицевыхСчетов.НеВестиУчетВРазрезеОрганизаций КАК НеВестиУчетВРазрезеОрганизаций,
	               |	ВидыЛицевыхСчетов.СрокДействияДатойС КАК СрокДействияДатойС,
	               |	ВидыЛицевыхСчетов.СрокДействияДатойПо КАК СрокДействияДатойПо,
	               |	ВидыЛицевыхСчетов.СрокДействияТип КАК СрокДействияТип,
	               |	ВидыЛицевыхСчетов.СрокДействия КАК СрокДействия
	               |ИЗ
	               |	Справочник.ВидыЛицевыхСчетов КАК ВидыЛицевыхСчетов
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Контракты.ПрефиксСинхронизации КАК ПрефиксСинхронизации,
	               |	Таблица_Контракты.ИДКонтракта КАК ИДКонтракта,
	               |	Таблица_Контракты.ИДКлиента КАК ИДКлиента,
	               |	Таблица_Контракты.НомерЛС КАК НомерЛС,
	               |	Таблица_Контракты.ТипОплаты КАК ТипОплаты,
	               |	Таблица_Контракты.ВидОперации КАК ВидОперации,
	               |	Таблица_Контракты.ИДОплаты КАК ИДОплаты,
	               |	Таблица_Контракты.Аннулирован КАК Аннулирован,
	               |	Таблица_Контракты.СуммаОплаты КАК СуммаОплаты,
	               |	Таблица_Контракты.ДатаПродажи КАК ДатаПродажи,
	               |	Таблица_Контракты.ДатаОплаты КАК ДатаОплаты,
	               |	Контрагенты.Ссылка КАК Клиент,
	               |	НоменклатураЧ.Ссылка КАК НоменклатураЧленства,
	               |	ЧленствоПакетУслугДокумент.Ссылка КАК Членство,
	               |	ПоступлениеДенежныхСредств.Ссылка КАК ПкоСсылка,
	               |	СписаниеДенежныхСредств.Ссылка КАК РкоСсылка
	               |ИЗ
	               |	Таблица_Контракты КАК Таблица_Контракты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Таблица_Контракты.ИДКлиента = Контрагенты.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = Контрагенты.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКлиента > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураЧ
	               |		ПО Таблица_Контракты.ИДНоменклатурыЧленства = НоменклатураЧ.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = НоменклатураЧ.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДНоменклатурыЧленства > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧленствоПакетУслуг КАК ЧленствоПакетУслугДокумент
	               |		ПО Таблица_Контракты.ИДКонтракта = ЧленствоПакетУслугДокумент.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ЧленствоПакетУслугДокумент.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДКонтракта > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	               |		ПО Таблица_Контракты.ИДОплаты = ПоступлениеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = ПоступлениеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДОплаты > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	               |		ПО Таблица_Контракты.ИДОплаты = СписаниеДенежныхСредств.КодСинхронизации
	               |			И Таблица_Контракты.ПрефиксСинхронизации = СписаниеДенежныхСредств.ПрефиксСинхронизации
	               |			И (Таблица_Контракты.ИДОплаты > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Таблица_Контракты.ИДКлиента,
	               |	Таблица_Контракты.ИДКонтракта,
	               |	Таблица_Контракты.ИДОплаты
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
