
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ИдентификаторЗаявки") Тогда
		ИдентификаторЗаявки				 = Параметры.ИдентификаторЗаявки;
		ЭтотОбъект.ОбъектИдентификации	 = ПолучитьСсылкуОбъектаПоUID("Справочники", "Заявки", ИдентификаторЗаявки);
	КонецЕсли;
	
	Если Параметры.Свойство("ИдентификаторКлиента") Тогда
		ИдентификаторКлиента			 = Параметры.ИдентификаторКлиента;
		ЭтотОбъект.ОбъектИдентификации	 = ПолучитьСсылкуОбъектаПоUID("Справочники", "Контрагенты", ИдентификаторКлиента);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.ОбъектИдентификации) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ДоступныеКаналыОтправки = Документы.РассылкаСообщений.ПолучитьДоступныеДляОтправкиВнешниеСистемыМессенджера(
		ЭтотОбъект.ОбъектИдентификации,
		ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница
	);
	КоличествоДоступныхКаналов = ДоступныеКаналыОтправки.Количество();
	
	Если КоличествоДоступныхКаналов = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Не найдены доступные каналы отправки.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		Возврат;
	КонецЕсли;
	
	Для Каждого КаналОтправки Из ДоступныеКаналыОтправки Цикл
		
		ДанныеКанала = Новый Структура;
		ДанныеКанала.Вставить("ИдКлиента"		, КаналОтправки.ИдКлиента);
		ДанныеКанала.Вставить("ВнешняяСистема"	, КаналОтправки.ВнешняяСистема);
		ДанныеКанала.Вставить("НомерМессенджера", КаналОтправки.НомерМессенджера);
		
		ЭтотОбъект.СписокКонтактов.Добавить(
			ДанныеКанала,
			СформироватьПредставлениеКаналаОтправки(КаналОтправки),,
			ПолучитьКартинкуМессенджера(КаналОтправки.ТипВнешнейСистемы)
		);
		
	КонецЦикла;
	
	Элементы.СписокКонтактов.ВысотаВСтрокахТаблицы = КоличествоДоступныхКаналов;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ВыбратьКанал(Команда)
	
	ТекущиеДанные = Элементы.СписокКонтактов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ТекстСообщения = НСтр("ru = 'Выберите канал отправки'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПерейтиВЧат(Элементы.СписокКонтактов.ТекущиеДанные.Значение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
// Функция, возвращает картинку типа внешней системы.
//
Функция ПолучитьКартинкуМессенджера(ТипВнешнейСистемы)
	
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		Возврат БиблиотекаКартинок.Whatsapp16;
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда
		Возврат БиблиотекаКартинок.Telegram16;
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Viber Тогда
		Возврат БиблиотекаКартинок.Viber16;
		
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.VkontakteApi Тогда
		Возврат БиблиотекаКартинок.Vk16;
		
	КонецЕсли;
	
	Возврат БиблиотекаКартинок.Пустая;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает представление канала отправки.
//
Функция СформироватьПредставлениеКаналаОтправки(КаналОтправки)
	
	Если КаналОтправки.ИдКлиента = "" Тогда
		Представление = КаналОтправки.НаименованиеВнешнейСистемы + " - " + НСтр("ru = 'создать контакт'") + " (" + КаналОтправки.НомерМессенджера + ")";
	Иначе
		Представление = КаналОтправки.НаименованиеВнешнейСистемы + ?(ЗначениеЗаполнено(КаналОтправки.НомерМессенджера), " (" + КаналОтправки.НомерМессенджера + ")", "");
	КонецЕсли;
	
	Возврат Представление;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик события "Выбор".
//
Процедура СписокКонтактовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ПерейтиВЧат(Элемент.ТекущиеДанные.Значение);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения перехода в чат мессенджера.
//
Процедура ПерейтиВЧат(ДанныеКанала)
	
	ОписаниеОшибки = "";
	ИдСообщения = УстановитьОжиданиеСообщения(ДанныеКанала.ИдКлиента, ДанныеКанала.ВнешняяСистема, ОписаниеОшибки, ЭтотОбъект.ОбъектИдентификации, ДанныеКанала.НомерМессенджера);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ДанныеКаналаСтруктура = Новый Структура;
	ДанныеКаналаСтруктура.Вставить("ИдКлиента"		, ДанныеКанала.ИдКлиента);
	ДанныеКаналаСтруктура.Вставить("ВнешняяСистема"	, ДанныеКанала.ВнешняяСистема);
	ДанныеКаналаСтруктура.Вставить("ИдСообщения"	, ИдСообщения);
	
	ПараметрыОткрытия = Новый Структура("ДанныеКанала", ДанныеКаналаСтруктура);
	
	Оповестить("ОткрытьДиалог", ПараметрыОткрытия);
	ОткрытьФорму("Обработка.Мессенджер_Стоматология.Форма", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.Независимый);
	
	Закрыть();
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, создает сообщение с признаком ожидания сообщения.
//
Функция УстановитьОжиданиеСообщения(ИдКлиента, ВнешняяСистема, ОписаниеОшибки, Объект = Неопределено, НомерТелефона = "")
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		
		ДанныеКонтакта	 = СоздатьКонтактМессенджера(ВнешняяСистема, Объект, НомерТелефона);
		ИдКлиента		 = ДанныеКонтакта.ИдКлиента;
		ИдСообщения		 = ДанныеКонтакта.ИдСообщения;
		
	Иначе
		ИдСообщения = МессенджерСтоматология.ПолучитьИдОжидающегоСообщенияВМесенджер(ИдКлиента, ВнешняяСистема);
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдКлиента) Тогда
		ОписаниеОшибки = НСтр("ru = 'Не удалось создать клиента в мессенджере.'; en = 'Failed to create messenger client.'");
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ИдСообщения;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, создает канал мессенджера.
//
Функция СоздатьКонтактМессенджера(ВнешняяСистема, Контрагент, Знач НомерТелефона)
	
	Если ВнешняяСистема.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		
		НомерТелефона = ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь);
		НомерТелефона = ?(СтрДлина(НомерТелефона) > 10 И Лев(НомерТелефона, 1) = "8", "7" + Сред(НомерТелефона, 2), НомерТелефона);
		
		ИдКлиента = НомерТелефона + "@c.us";
		
	КонецЕсли;
	
	ИдКлиента	 = ИдКлиента;
	ИдСообщения	 = Строка(Новый УникальныйИдентификатор);
	
	Если ЗначениеЗаполнено(ИдКлиента) Тогда
		
		НовыйДиалог					 = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
		НовыйДиалог.ИдДиалога		 = Строка(Новый УникальныйИдентификатор);
		НовыйДиалог.ВнешняяСистема	 = ВнешняяСистема;
		НовыйДиалог.ИдКлиента		 = ИдКлиента;
		НовыйДиалог.Начало			 = Дата(2022, 1, 1);
		НовыйДиалог.Окончание		 = Дата(2022, 1, 1);
		
		НовыйДиалог.Записать();
		
		РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(
			ИдКлиента,
			Контрагент,
			НомерТелефона,,
			ВнешняяСистема,
			ОбщегоНазначения.ПолучитьЗначениеРеквизита(Контрагент, "Наименование"),,,,
			НовыйДиалог.ИдДиалога
		);
		
		РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
			ИдКлиента,
			ИдСообщения,,,
			НСтр("ru = 'Создан контакт'"),
			Истина,
			Перечисления.Мессенджеры.whatsapp,
			Ложь,
			ТекущаяДатаСеанса(),
			ВнешняяСистема,,,,,,,,,
			НовыйДиалог.ИдДиалога,
			Истина
		);
		
	КонецЕсли;
	
	ДанныеКонтакта = Новый Структура;
	ДанныеКонтакта.Вставить("ИдКлиента"		, ИдКлиента);
	ДанныеКонтакта.Вставить("ИдСообщения"	, ИдСообщения);
	
	Возврат ДанныеКонтакта;
	
КонецФункции

#КонецОбласти
