// Получает реквизит данных файла
//  Параметры:Файл - ссылка на объект файл
//			НазваниеПоля - наименование реквизита, которое необходимо получить
//			ВладелецФайла - ссылка на владельца файла, на основании которого следует производить подстановку данных
//  Возвращает:значение поля, если оно существует
Функция ПолучитьЗначениеРеквизитаДляАвтозаполнения(Файл, Знач НазваниеПоля, ВладелецФайла)
	
	Результат = "";
	
	МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(НазваниеПоля, ".");
	
	Если МассивСтрок.Количество() > 1 И МассивСтрок[0] = "Договоры" Тогда
		ВыражениеРеквизита = "ВладелецФайла" + "." + Сред(НазваниеПоля, СтрДлина(МассивСтрок[0]) + 2);
		Выражение = "Результат = " + ВыражениеРеквизита;
	ИначеЕсли МассивСтрок.Количество() > 1 И МассивСтрок[0] = "Ответственные лица" Тогда
		Выражение = "
			|Запрос = Новый Запрос;
			|Запрос.Текст = ""ВЫБРАТЬ РАЗРЕШЕННЫЕ
		    |          |	ОтветственныеЛицаСрезПоследних.Сотрудник
		    |          |ИЗ
		    |          |	РегистрСведений.ОтветственныеЛица.СрезПоследних КАК ОтветственныеЛицаСрезПоследних
		    |          |ГДЕ
		    |          |	ОтветственныеЛицаСрезПоследних.Организация = &Организация
		    |          |	И ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица = &ТипОтветственногоЛица"";
			|Запрос.УстановитьПараметр(""ТипОтветственногоЛица"", Перечисления.ТипыОтветственныхЛиц[МассивСтрок[1]]);
			|Запрос.УстановитьПараметр(""Организация"", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация);
			|ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
			|Если ВыборкаЗапроса.Следующий() Тогда
			|	Результат = ВыборкаЗапроса.Сотрудник;
			|Иначе
			|	Результат = Справочники.Сотрудники.ПустаяСсылка();
			|КонецЕсли;" 
			
	ИначеЕсли ЗначениеЗаполнено(НазваниеПоля) Тогда
		Выражение = "Результат = " + НазваниеПоля;
	КонецЕсли;
	
	Выполнить(Выражение);
	
	Возврат Результат;
	
КонецФункции  

// Функция, получить значения реквиитов организации.
//
Функция ПолучитьЗначениеРеквизитаДляАвтозаполненияОрганизации(НазваниеПоля, ВладелецФайла)
	
	МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(НазваниеПоля, "."); 
	Организация = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВладелецФайла.СтруктурнаяЕдиница, "Организация");
	Результат = "";
	ВидКИ = "";
	
	Если МассивСтрок.Количество() > 1 И МассивСтрок[1] = "Телефон" Тогда
		ВидКИ = "ТелефонОрганизации";
	ИначеЕсли МассивСтрок.Количество() > 1 И МассивСтрок[1] = "Емайл" Тогда
		ВидКИ = "EmailОрганизации";
	ИначеЕсли МассивСтрок.Количество() > 1 И МассивСтрок[1] = "Фактический адрес" Тогда
		ВидКИ = "ФактАдресОрганизации";
	ИначеЕсли МассивСтрок.Количество() > 1 И МассивСтрок[1] = "Юридический адрес" Тогда
		ВидКИ = "ЮрАдресОрганизации";
	ИначеЕсли МассивСтрок.Количество() > 1 И МассивСтрок[1] = "Почтовый адрес" Тогда
		ВидКи = "ПочтовыйАдресОрганизации";
	ИначеЕсли МассивСтрок.Количество() > 1 И МассивСтрок[1] = "Факс" Тогда
		ВидКИ = "ФаксОрганизации";
	КонецЕсли;	
	
	Если ВидКИ <> "" Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ОрганизацииКонтактнаяИнформация.Представление КАК Представление
		|ИЗ
		|	Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|ГДЕ
		|	ОрганизацииКонтактнаяИнформация.Ссылка = &Организация
		|	И ОрганизацииКонтактнаяИнформация.Вид = &Вид");
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации[ВидКИ]);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Результат = ?(Выборка.Следующий(), Выборка.Представление, "");  
		
	КонецЕсли;  
	
	Возврат Результат; 		
	
КонецФункции	

