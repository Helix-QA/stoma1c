// Процедура - Сменить публикацию
//
Функция ПолучитьАдресПубликацииСБП(ИспользоватьТранслятор = Истина)
	
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.СистемаБыстрыхПлатежей, Истина); 
	
	Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда			
		ВнешняяСистема = Справочники.ВнешниеСистемы.СоздатьВнешнююСистему(Перечисления.ТипыВнешнихСистем.СистемаБыстрыхПлатежей,, Истина);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
		
		АдресРетранслятора	= "https://cloud.stoma1c.ru/api";
		HTTPСервис			= "/hs/api/sbp/{apikey}";
		HTTPСервис			= СтрЗаменить(HTTPСервис, "{apikey}", ВнешняяСистема.КлючПриложения);	
		
		Если ИспользоватьТранслятор Тогда
			Возврат "" + АдресРетранслятора + HTTPСервис;
		Иначе 
			АдресПубликации = Константы.ВнешняяПубликацияАдрес.Получить();		
			АдресПубликации = СокрЛП(АдресПубликации);
			АдресПубликации = ?(СтрЗаканчиваетсяНа(АдресПубликации, "/"),  Лев(АдресПубликации, СтрДлина(АдресПубликации)-1), АдресПубликации);
			Возврат "" + АдресПубликации + HTTPСервис;
		КонецЕсли;
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

