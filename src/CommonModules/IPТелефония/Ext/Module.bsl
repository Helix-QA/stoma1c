// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьПараметрыОборудования(Оборудование) Экспорт 
	
	ПараметрыОборудования = Новый Структура("Сервер, Пароль");
	Если ТипЗнч(Оборудование) = Тип("СправочникСсылка.ПодключаемоеОборудование") Тогда 
		ПараметрыОборудования =Оборудование.Параметры.Получить(); 
	КонецЕсли;
	
	Возврат ПараметрыОборудования; 
	
	
КонецФункции

