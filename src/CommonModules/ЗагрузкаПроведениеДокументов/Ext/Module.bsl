// Процедура - Создать и провести документы закрытия дня
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура СоздатьИПровестиДокументыЗакрытияДня(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;	
	
	НачДата 				= ПараметрыЗадания.ПериодОбработки.ДатаНачала;
	КонДата 				= ПараметрыЗадания.ПериодОбработки.ДатаОкончания;
	СозданоДокументов 		= 0;
	ПредставлениеДок 		= "";
	ОсталосьВремени 		= Неопределено;
	
	ОбщееКоличествоДокументов = Окр(Окр((КонДата - НачДата) / 86400) / 7);
	ОбщееКоличествоДокументов = ?(ОбщееКоличествоДокументов < 1, 1, ОбщееКоличествоДокументов);
	
	ДатаНачалаПроцесса = ТекущаяДатаСеанса();
	
	Пока НачДата <= КонДата Цикл
		
		ЗакрытиеДняОбъект                    			= Документы.ЗакрытиеДня.СоздатьДокумент();	
		ЗакрытиеДняОбъект.СтруктурнаяЕдиница 			= ПараметрыЗадания.СтруктурнаяЕдиница;
		ЗакрытиеДняОбъект.Дата               			= КонецДня(НачДата);
		ЗакрытиеДняОбъект.Статус             			= Перечисления.СтатусыРабочегоДня.Закрыт;
		ЗакрытиеДняОбъект.АвторДокумента 				= ПараметрыЗадания.ТекущийПользователь;
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЭтоПроведениеЗагруженныхДанных"				, Истина);		
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеАктуализироватьСтатус"						, Истина);
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПроведениеДокументовВФоне"	, Истина);
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПересчетаИтогов"				, Истина);		
		Попытка
			ЗакрытиеДняОбъект.Записать(РежимЗаписиДокумента.Проведение);
			СозданоДокументов 	= СозданоДокументов + 1;
			ПредставлениеДок	= Строка(ЗакрытиеДняОбъект.Ссылка);
		Исключение
			ПредставлениеДок	= НСтр("ru='Ошибка создания: ';en='Mistake create: '") + ОписаниеОшибки();
		КонецПопытки;

		Прогресс 						= Цел(100 * СозданоДокументов / ОбщееКоличествоДокументов);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Генерация документов ""Закрытие дня""... ';en='Generation of documents ""Closing of the day""...'") + НСтр("ru= '   Осталось: ';en= '   Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, СозданоОбъектов", ПредставлениеДок, ОсталосьВремени, ПредставлениеОставшегосяВремени, СозданоДокументов));
		
		НачДата = НачДата + 7*86400;
		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Создать и провести документы закрытия месяца
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура СоздатьИПровестиДокументыЗакрытияМесяца(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;	
	
	НачДата 				= ПараметрыЗадания.ПериодОбработки.ДатаНачала;
	КонДата 				= ПараметрыЗадания.ПериодОбработки.ДатаОкончания;
	СозданоДокументов 		= 0;
	ПредставлениеДок 		= "";
	ОсталосьВремени 		= Неопределено;
	
	ОбщееКоличествоДокументов = Окр(Окр((КонДата - НачДата) / 86400) / 30);
	ОбщееКоличествоДокументов = ?(ОбщееКоличествоДокументов < 1, 1, ОбщееКоличествоДокументов);
	
	тзИнтервалов = ПолучитьТаблицуДатЗаПериод(НачДата, КонДата, "МЕСЯЦ");
	
	ДатаНачалаПроцесса = ТекущаяДатаСеанса();
	
	Для Каждого СтрокаИнтервал Из тзИнтервалов Цикл
		
		ЗакрытиеМесяцаОбъект                    			= Документы.ЗакрытиеМесяца.СоздатьДокумент();	
		ЗакрытиеМесяцаОбъект.СтруктурнаяЕдиница 			= ПараметрыЗадания.СтруктурнаяЕдиница;
		ЗакрытиеМесяцаОбъект.Дата               			= НачалоМесяца(СтрокаИнтервал.НачИнтервала);
		ЗакрытиеМесяцаОбъект.МесяцРаспределения 			= НачалоМесяца(СтрокаИнтервал.НачИнтервала);
		ЗакрытиеМесяцаОбъект.АвторДокумента 				= ПараметрыЗадания.ТекущийПользователь;
		ЗакрытиеМесяцаОбъект.ДополнительныеСвойства.Вставить("ЭтоПроведениеЗагруженныхДанных"				, Истина);		
		ЗакрытиеМесяцаОбъект.ДополнительныеСвойства.Вставить("НеАктуализироватьСтатус"						, Истина);
		ЗакрытиеМесяцаОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПроведениеДокументовВФоне"	, Истина);
		ЗакрытиеМесяцаОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПересчетаИтогов"				, Истина);		
		Попытка
			ЗакрытиеМесяцаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			СозданоДокументов 	= СозданоДокументов + 1;
			ПредставлениеДок	= Строка(ЗакрытиеМесяцаОбъект.Ссылка);
		Исключение
			ПредставлениеДок	= НСтр("ru='Ошибка создания: ';en='Mistake create:'") + ОписаниеОшибки();
		КонецПопытки;

		Прогресс 						= Цел(100 * СозданоДокументов / ОбщееКоличествоДокументов);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Генерация документов ""Закрытие месяца""... ';en='Generation of documents ""Closing of the month""...'") + НСтр("ru= '   Осталось: ';en= '   Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, СозданоОбъектов", ПредставлениеДок, ОсталосьВремени, ПредставлениеОставшегосяВремени, СозданоДокументов));
		
		// НачДата = НачДата + 31*86400;
		
	КонецЦикла;	
	
КонецПроцедуры

// Возвращает таблицу значений с датами за период
//
// Параметры:
//  НачДата  - Дата - Начало периода
//  КонДата  - Дата - Конец периода
//  Интервал - Строка - одно из следующих значений:
//             (Секунда, Минута, Час, День, Неделя, Месяц, Квартал, Полугодие, Год)
//
// Возвращаемое значение:
//   Таблица значений с датами за период. Содержит одну колонку "НачИнтервала"
//
Функция ПолучитьТаблицуДатЗаПериод(НачДата, КонДата, Интервал) Экспорт

    тзИнтервалов = Новый ТаблицаЗначений;
    тзИнтервалов.Колонки.Добавить("НачИнтервала", Новый ОписаниеТипов("Дата"));

    Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ
    |   НАЧАЛОПЕРИОДА(&НачДата, "+Интервал+") КАК НачИнтервала
    |УПОРЯДОЧИТЬ ПО
    |   НачИнтервала
    |ИТОГИ ПО
    |   НачИнтервала ПЕРИОДАМИ("+Интервал+", &НачДата, &КонДата)";
    // Параметры запроса
    Запрос.УстановитьПараметр("НачДата", НачДата);
    Запрос.УстановитьПараметр("КонДата", КонДата);

    Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "НачИнтервала", "ВСЕ");
    Пока Выборка.Следующий() Цикл
        НоваяСтрока = тзИнтервалов.Добавить();
        НоваяСтрока.НачИнтервала = Выборка.НачИнтервала;
    КонецЦикла;

    Возврат  тзИнтервалов;

КонецФункции

// Функция - Начать операцию актуализации статусов пациентов
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьОперациюАктуализацииСтатусовПациентов(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;	
		АктуализироватьСтатусыПациентов(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	Иначе
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания"	, Истина);				
	КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.АктуализироватьСтатусыПациентов",
	ПараметрыПроцедуры,
	НСтр("ru='Актуализация статусов пациентов';en='Updating client statuses'"));
	Возврат Результат;
	
КонецФункции

