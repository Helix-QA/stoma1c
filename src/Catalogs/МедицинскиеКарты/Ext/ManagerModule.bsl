// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Ложь;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьМедКарты") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПечатьМедКарты", "Печать мед. карты", СформироватьПечатнуюФормуМедКарты(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ВкладышМедКартыДляСтраховой") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ВкладышМедКартыДляСтраховой", "Вкладыш мед. карты для страховой", СформироватьПечатныеФормыВкладышейМедКартДляСтраховой(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_А4") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_А4", "Амбулаторная карта (форма 043У)", СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_А5") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_А5", "Амбулаторная карта (форма 043У)", СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
	
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_СССР_А4") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_СССР_А4", "Амбулаторная карта (форма 043У)", СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_СССР_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
	
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_СССР_А5") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "АмбулаторнаяКарта_043_У_СССР_А5", "Амбулаторная карта (форма 043У)", СформироватьПечатнуюФормуАмбулаторнаяКарта_043_У_СССР_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "МедицинскаяКарта_025У_04_А4") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "МедицинскаяКарта_025У_04", "Медицинская карта (форма 025У/04)", СформироватьПечатнуюФормуМедицинскаяКарта_025У_04_А4(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "МедицинскаяКарта_025У_04_А5") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "МедицинскаяКарта_025У_05", "Медицинская карта (форма 025У/04)", СформироватьПечатнуюФормуМедицинскаяКарта_025У_04_А5(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));		
		
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "МедицинскаяКарта_025У_14") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "МедицинскаяКарта_025У_14", "Медицинская карта (форма 025У/14)", СформироватьПечатнуюФормуМедицинскаяКарта_025У_14(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));					
	
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ЛистУчетаДозовыхНагрузок") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ЛистУчетаДозовыхНагрузок", "Лист учета дозовых нагрузок пациента при рентгенологических исследованиях", СформироватьЛистУчетаДозовыхНагрузокПациента(МассивОбъектов, ОбъектыПечати, ПараметрыПечати));					
	КонецЕсли;  
	
КонецПроцедуры // Печать()

