
#Область СлужебныеПроцедурыИФункции

// Процедура, добавляет запись в регистр сведений;
//
Процедура ДобавитьЗапись(Объект, КодОтвета, ОтветИЭМК, УидВИЭМК, УИД, КоличествоПопыток, ДатаОтправки = Неопределено) Экспорт 
	
	МенеджерЗаписи = РегистрыСведений.ЖурналОбменаИЭМК.СоздатьМенеджерЗаписи();
	
	МенеджерЗаписи.Объект       		= Объект;
	МенеджерЗаписи.КодОтвета 			= КодОтвета;
	МенеджерЗаписи.ОтветИЭМК    		= ОтветИЭМК;
	МенеджерЗаписи.УидВИЭМК     		= УидВИЭМК;
	МенеджерЗаписи.УИД     				= УИД;
	МенеджерЗаписи.КоличествоПопыток    = КоличествоПопыток;
	МенеджерЗаписи.ДатаОтправки     	= ДатаОтправки;

	
	МенеджерЗаписи.Записать(Истина);
	
КонецПроцедуры

#КонецОбласти