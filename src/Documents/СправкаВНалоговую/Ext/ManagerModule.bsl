Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("ПФ_MXL_Справка", "Справка в налоговую", , БиблиотекаКартинок.Документ);
	
	Возврат Список;
	
КонецФункции

