
#Область СлужебныйПрограммныйИнтерфейс

// Функция - Проверить возможность звонка на данном ПК.
// 
Функция ПроверитьВозможностьЗвонкаНаДанномПК(ПоРабочемуМесту = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РабочееМесто", ПараметрыСеанса.РабочееМестоКлиента);	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТелефонныеАппараты.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	               |ГДЕ
	               |	ТелефонныеАппараты.ПометкаУдаления = ЛОЖЬ
	               |	И (ТелефонныеАппараты.ОбъектыПривязки.Объект = &РабочееМесто
	               |			&УсловиеПоРабочемуМесту)";
	
	Если ПоРабочемуМесту Тогда 		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоРабочемуМесту", "");
	Иначе		
		УсловиеПоРабочемуМесту = "ИЛИ ТелефонныеАппараты.ОбъектыПривязки.Объект = &Сотрудник";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоРабочемуМесту", УсловиеПоРабочемуМесту);
		Запрос.УстановитьПараметр("Сотрудник"   , ПараметрыСеанса.ТекущийСотрудник);
	КонецЕсли;
	
	ТелефонныйАппаратНаРабочемМесте = Запрос.Выполнить().Выгрузить();
	
	Возврат (Справочники.ПодключаемоеОборудование.ПолучитьСписокОборудования("IPТелефония").Количество() > 0
			И ТелефонныйАппаратНаРабочемМесте.Количество() > 0);
	
КонецФункции

// Функция - Запись разговора доступна.
// 
Функция ЗаписьРазговораДоступна(Сотрудник, Номер) Экспорт 
	
	ЗаписьРазговораДоступна = Ложь; 
	
	ТелефонныйАппарат = ПолучитьТелефонныйАппаратПоНомеру(Номер);
	
	Если ТелефонныйАппарат <> Неопределено Тогда 
		
		ПрослушатьЗаписьРазговоров = ТелефонныйАппарат.ПрослушатьЗаписьРазговоров;
		
		Если ПрослушатьЗаписьРазговоров Тогда 
			
			СегментСотрудников = ТелефонныйАппарат.СегментСотрудников; 			
			МассивСегментов    = РегистрыСведений.СоставСегментов.СегментыСодержащиеоОбъект(Сотрудник);				
			
			Для Каждого Сегмент Из МассивСегментов Цикл 
				
				Если Сегмент = СегментСотрудников Тогда 
					Возврат Истина;   						
				КонецЕсли;  					
				
			КонецЦикла;  			
			
		Иначе 			
			ЗаписьРазговораДоступна = Истина;				
		КонецЕсли;
		
	Иначе		
		ЗаписьРазговораДоступна = Истина; 		
	КонецЕсли;
	
	Возврат ЗаписьРазговораДоступна;
	
КонецФункции

// Функция - Получить телефонный аппарат по номеру.
//
Функция ПолучитьТелефонныйАппаратПоНомеру(Номер) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТелефонныеАппараты.Ссылка КАК Ссылка,
	|	ТелефонныеАппараты.Наименование КАК Наименование,
	|	ТелефонныеАппараты.СегментСотрудников КАК СегментСотрудников,
	|	ТелефонныеАппараты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЕСТЬNULL(ТелефонныеАппараты.ПрослушатьЗаписьРазговоров, ЛОЖЬ) КАК ПрослушатьЗаписьРазговоров
	|ИЗ
	|	Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|ГДЕ
	|	ТелефонныеАппараты.ВнутреннийНомер = &ВнутреннийНомер");
	
	Запрос.УстановитьПараметр("ВнутреннийНомер", Номер);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка, Неопределено);
	
КонецФункции

#КонецОбласти
