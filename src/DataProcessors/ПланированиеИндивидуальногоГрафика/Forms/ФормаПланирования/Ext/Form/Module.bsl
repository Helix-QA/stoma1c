// Процедура - Подключаемый выбор начала интервала
// 
// Параметры:
//  Команда	 - 	 - 
// 
Процедура Подключаемый_ВыборНачалаИнтервала(Команда)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлемента(ЭтаФорма, Команда);
	
	Если НЕ СтруктураДанныеЭлемента.ДанныеЭлемента = Неопределено Тогда 
		
		Шаг = 30; // в минутах		
		ИмяЭлемента = "Кнопка_ВыборНачалаИнтервала_" + СтруктураДанныеЭлемента.ИндексСтроки;
		СтруктураДанныеЭлемента.Вставить("ИмяЭлемента"			, ИмяЭлемента);			
		СтруктураДанныеЭлемента.Вставить("ЭтоНачалоИнтервала"	, Истина);
		
		ЭлементМассиваДней = Неопределено;
		Для Каждого ЭлементМ ИЗ ВремяРаботыСтруктурнойЕдиницы Цикл
			
			Если ЭлементМассиваДней = Неопределено Тогда 
				ЭлементМассиваДней = ЭлементМ;
			ИначеЕсли ЭлементМассиваДней.ДатаНачала > ЭлементМ.ДатаНачала Тогда // находим минимум
				ЭлементМассиваДней = ЭлементМ;
			КонецЕсли;
			
		КонецЦикла;			
		Если ЭлементМассиваДней <> Неопределено Тогда
			// Заполнить список интервалов времени
			МассивПериодов = Новый Массив;
			МассивПериодов.Добавить(ЭлементМассиваДней);
			НачинаяСВремени 		= ВернутьПоследнееУказанноеВремя(СтруктураДанныеЭлемента, Шаг);			
			СписокВермениРаботы  	= ОбщегоНазначенияКлиентСерверСтоматология.ВернутьСписокВремени(МассивПериодов, Истина, Шаг);	
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборВремениИзСписка", ЭтотОбъект, СтруктураДанныеЭлемента);
			ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокВермениРаботы, Элементы[ИмяЭлемента]);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
