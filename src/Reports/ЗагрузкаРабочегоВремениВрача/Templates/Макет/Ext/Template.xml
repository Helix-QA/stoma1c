		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) КАК ПериодДень,
	НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, НЕДЕЛЯ) КАК ПериодНеделя,
	НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ГОД) КАК ПериодГод,
	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ВремяРаботыСотрудниковПлан.Сотрудник КАК Врач,
	ВремяРаботыСотрудниковПлан.Минуты / 60 КАК ПоПлану,
	0 КАК ПоФакту
ИЗ
	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
{ГДЕ
	(ВремяРаботыСотрудниковПлан.ДатаВремяНачала МЕЖДУ &amp;НачПериода И &amp;КонПериода)}

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	НАЧАЛОПЕРИОДА(СобытиеУслуги.ДатаНачала, ДЕНЬ),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.ДатаНачала, НЕДЕЛЯ),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.ДатаНачала, МЕСЯЦ),
	НАЧАЛОПЕРИОДА(СобытиеУслуги.ДатаНачала, ГОД),
	СобытиеУслуги.Ссылка.СтруктурнаяЕдиница,
	СобытиеУслуги.Сотрудник,
	0,
	РАЗНОСТЬДАТ(СобытиеУслуги.ДатаНачала, СобытиеУслуги.ДатаОкончания, МИНУТА) / 60
ИЗ
	Документ.Событие.Услуги КАК СобытиеУслуги
ГДЕ
	СобытиеУслуги.Ссылка.Проведен
	И НЕ СобытиеУслуги.Ссылка.ПометкаУдаления
	И НЕ СобытиеУслуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	И НЕ СобытиеУслуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемНеСостоялся)
	И ВЫБОР
			КОГДА &amp;СписокМеток = ЗНАЧЕНИЕ(Справочник.Метки.ПустаяСсылка)
					ИЛИ &amp;СписокМеток = НЕОПРЕДЕЛЕНО
				ТОГДА ИСТИНА
			ИНАЧЕ СобытиеУслуги.Ссылка В
					(ВЫБРАТЬ
						МеткиКлиентов.Клиент.Ссылка КАК КлиентСсылка
					ИЗ
						РегистрСведений.МеткиКлиентов КАК МеткиКлиентов
					ГДЕ
						МеткиКлиентов.Метка = &amp;СписокМеток)
		КОНЕЦ
	И СобытиеУслуги.Ссылка.Резерв = ЛОЖЬ
{ГДЕ
	(СобытиеУслуги.ДатаНачала МЕЖДУ &amp;НачПериода И &amp;КонПериода)}</query>
