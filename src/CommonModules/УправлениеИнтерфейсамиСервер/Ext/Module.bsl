#КонецОбласти

#Область СозданиеЭлементовДинамическогоМенюВсплывающихГрупп

// Функция - Создать динамическое меню формы Расписания занятий.
//
// Параметры:
//  ИмяМеню					 - имя меню.
//  Форма					 - 	 -
//  ГруппаРодитель			 - 	 -
//  МассивПривязанныхДанных	 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  ПараметрыОформления		 - 	 -
//  ВыборПоУмолчанию		 - 	 -
//  ТипДанныхПоУмолчанию	 - 	 -
//  ОгрКолЭлементов			 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьДинамическоеМенюВсплывающихГрупп(
	ИмяМеню,
	Форма,
	ПривязанныеДанные,
	ГруппаРодитель,
	ИмяОбработчикаНажатия,
	ТипДанныхПоУмолчанию = Неопределено,
	ТипМеню              = Неопределено,
	ОгрКолЭлементов      = Неопределено,
	ПараметрыОформления  = Неопределено,
	ПересоздатьЭлемМеню  = Ложь,
	РеквизитОбновления   = Неопределено,
	ЗаголовкиМеню        = Неопределено) Экспорт
			
	РазмерШрифта         = Неопределено;
	ШиринаЭлемента       = Неопределено;
	ШиринаГруппыЭлемента = Неопределено;
	ЦветТекста           = Неопределено;
	
	МаксимальнаяШиринаПредпоказ = Неопределено;
	
	Если ЗначениеЗаполнено(ПараметрыОформления) Тогда
		
		ПараметрыОформления.Свойство("РазмерШрифта"        , РазмерШрифта);
		ПараметрыОформления.Свойство("ШиринаЭлемента"      , ШиринаЭлемента);
		ПараметрыОформления.Свойство("ШиринаГруппыЭлемента", ШиринаГруппыЭлемента);
		ПараметрыОформления.Свойство("ЦветТекста"          , ЦветТекста);
		
		ПараметрыОформления.Свойство("МаксимальнаяШиринаПредпоказ", МаксимальнаяШиринаПредпоказ);
		
	КонецЕсли;
			
	ПарметрыМеню = Новый Структура;
	ПарметрыМеню.Вставить("ИмяМеню"              , ИмяМеню);
	ПарметрыМеню.Вставить("ИмяГруппы"            , ГруппаРодитель.Имя);
	ПарметрыМеню.Вставить("РазмерШрифта"         , ?(ЗначениеЗаполнено(РазмерШрифта), РазмерШрифта, 10));
	ПарметрыМеню.Вставить("ШиринаЭлемента"       , ШиринаЭлемента);
	ПарметрыМеню.Вставить("ШиринаГруппыЭлемента" , ШиринаГруппыЭлемента);
	ПарметрыМеню.Вставить("ЦветТекста"           , ?(ЦветТекста <> Неопределено, ЦветТекста, Новый Цвет(51, 102, 187)));
	ПарметрыМеню.Вставить("ЦветТекстаВыбранного" , Новый Цвет(77 , 77 , 77));
	ПарметрыМеню.Вставить("ЦветФона"             , Новый Цвет(255, 255, 255));
	ПарметрыМеню.Вставить("ЦветФонаВыбранного"   , Новый Цвет(242, 242, 242));
	ПарметрыМеню.Вставить("ПривязанныеДанные"    , ПривязанныеДанные);
	ПарметрыМеню.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПарметрыМеню.Вставить("ТипДанныхПоУмолчанию" , ТипДанныхПоУмолчанию);
	ПарметрыМеню.Вставить("ОгрКолЭлементов"      , ?(ЗначениеЗаполнено(ОгрКолЭлементов), ОгрКолЭлементов, 5));
	ПарметрыМеню.Вставить("ПересоздатьЭлемМеню"  , ПересоздатьЭлемМеню);
	ПарметрыМеню.Вставить("ТипМеню"              , ТипМеню);
	ПарметрыМеню.Вставить("РеквизитОбновления"   , РеквизитОбновления);
	ПарметрыМеню.Вставить("ЗаголовкиМеню"        , ЗаголовкиМеню);
	
	ПарметрыМеню.Вставить("МаксимальнаяШиринаПредпоказ", МаксимальнаяШиринаПредпоказ);
	
	// Создаем динамические элементы.
	СоздатьЭлементыВДинамическомМенюВсплывающихГрупп(Форма, ПарметрыМеню);
		
	// Помещаем настройки текущего меню во временное хранилищи и получаем его адрес.
	АдресХраненияНастроекМеню = ПоместитьВоВременноеХранилище(ПарметрыМеню, Форма.УникальныйИдентификатор);
	
	НовыйАдресСтруктурыАдресов  = Ложь;
	СтруктураАдресов            = Неопределено;
	
	// Получаем адрес хранения структуры адресов настроек меню.
	// По этому адресу извлекаем структуру содержащую адреса настроек каждой менюшки.
	АдресСтруктуррыАдресов = ХранилищеСистемныхНастроек.Загрузить("ПодсистемаДинамическогоМеню", "СтруктураХраненияАдресов" + Форма.УникальныйИдентификатор);
	Если АдресСтруктуррыАдресов <> Неопределено И ЭтоАдресВременногоХранилища(АдресСтруктуррыАдресов) = Истина Тогда
		СтруктураАдресов = ПолучитьИзВременногоХранилища(АдресСтруктуррыАдресов);
	КонецЕсли;
	
	// Если структура не обнаружено, значит это новое открытие формы.
	Если СтруктураАдресов = Неопределено Тогда
		СтруктураАдресов           = Новый Структура;
		НовыйАдресСтруктурыАдресов = Истина;
	КонецЕсли;
	
    // Добавляем адрес настроек текущего меню в структуру.
	Если СтруктураАдресов.Свойство(ИмяМеню) = Ложь Тогда
		СтруктураАдресов.Вставить(ИмяМеню,АдресХраненияНастроекМеню);
	Иначе
		СтруктураАдресов[ИмяМеню] = АдресХраненияНастроекМеню;
	КонецЕсли;
	
	// Сохраняем структуру адресов.
	Если НовыйАдресСтруктурыАдресов = Истина Тогда
		АдресСтруктуррыАдресов = ПоместитьВоВременноеХранилище(СтруктураАдресов, Форма.УникальныйИдентификатор);
		ХранилищеСистемныхНастроек.Сохранить("ПодсистемаДинамическогоМеню", "СтруктураХраненияАдресов" + Форма.УникальныйИдентификатор,АдресСтруктуррыАдресов);
	Иначе
		ПоместитьВоВременноеХранилище(СтруктураАдресов, АдресСтруктуррыАдресов);
	КонецЕсли;
	
	Возврат АдресХраненияНастроекМеню;
	
КонецФункции

// Процедура - Формирование меню отбора создание элементов отбора.
//
// Параметры:
//  Форма					 - 	 -
//  ОписаниеЭлементаМеню	 - 	 -
//  ИмяМеню					 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  ОсновнаяГруппаПодчМеню	 - 	 -
//  КнопкаЗначение			 - 	 -
//  ОгрКолЭлементов			 - 	 -
//  ПредМассивЗначений		 - 	 -
//  РазмерШрифта			 - 	 -
//  ЦветФона				 - 	 -
//
Процедура СоздатьЭлементыВДинамическомМенюВсплывающихГрупп(Форма, ПараметрыМеню)
		
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ПривязанныеДанные     = ПараметрыМеню.ПривязанныеДанные;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	ТипДанныхПоУмолчанию  = ПараметрыМеню.ТипДанныхПоУмолчанию;
	ОгрКолЭлементов       = ПараметрыМеню.ОгрКолЭлементов;
	ЦветФона              = ПараметрыМеню.ЦветФона;
	ЦветФонаВыбранного    = ПараметрыМеню.ЦветФонаВыбранного;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	ЗаголовкиМеню         = ПараметрыМеню.ЗаголовкиМеню;
		
	ПредПараметрыМеню     = ПараметрыДинамическогоМенюФормы(Форма, ИмяМеню);
	ПредПривязанныеДанные = ?(ПредПараметрыМеню <> Неопределено, ПредПараметрыМеню.ПривязанныеДанные, Неопределено);
	
	// Добавление параметра видимости отборов.
	ПараметрыМеню.Вставить("Открыт"     , ?(ПредПараметрыМеню <> Неопределено И ПредПараметрыМеню.Свойство("ОткрытьМеню"), ПредПараметрыМеню.ОткрытьМеню, Ложь));
	ПараметрыМеню.Вставить("ОткрытьМеню", Ложь);
	
	// Добавление параметра видимости отборов/реквизита данных/реквизита данных состояния отборов.
	ФормированиеВсплывающегоДинамическогоМенюДобавлениеРеквизитовДанных(Форма, ИмяМеню);

	ГруппаВсплывающая = Неопределено;
	ГруппаПредпоказ   = Неопределено;

	// Создание основного меню.
    ФормированиеВсплывающегоДинамическогоМенюДобавлениеОсновногоМеню(Форма, ПараметрыМеню, ГруппаВсплывающая, ГруппаПредпоказ);
		
	МаксимальнаяШиринаПредпоказ = ПараметрыМеню.МаксимальнаяШиринаПредпоказ;
	ИндексГруппыПредпоказ       = 0;
	ШиринаГруппыПредпоказ       = 0;
	КоличествоВыбранных         = 0;
	
	ИндексГруппы   = 0;
	ИндексЭлемента = 0;
	
	// Добавление элементов редактирования меню всплывающей группы.
	ФормированиеВсплывающегоДинамическогоМенюДобавлениеЭлементовРедактирования(Форма, ПараметрыМеню, ГруппаВсплывающая, ГруппаПредпоказ);
	
	Для Каждого ЭлементМ Из ПривязанныеДанные Цикл
		
		ПредставлениеЭлемента = НормализоватьСтрокуПредставления(Строка(?(ЭлементМ.Свойство("Код"), ЭлементМ.Код, ЭлементМ.Значение)));

		// Если элемент входит в предпоказ.
		Если ЭлементМ.Предпоказ Тогда
			
			ДлинаЭлементаПредпоказ = ЭлементМ.ДлинаЭлемента;
			ШиринаГруппыПредпоказ  = ШиринаГруппыПредпоказ + ДлинаЭлементаПредпоказ;
			
			// Добавим новую группу.
			Если ШиринаГруппыПредпоказ > МаксимальнаяШиринаПредпоказ
				ИЛИ ИндексГруппыПредпоказ = 0 Тогда
				
				// Создание подгруппы подчиненного меню.
				ПараметрыГруппы = Новый Структура;
				ПараметрыГруппы.Вставить("ГруппаЭлемента"        , ГруппаПредпоказ);
				ПараметрыГруппы.Вставить("ИмяЭлемента"           , "Группа_ME_" + ИмяМеню + "_Предпоказ" + "_ID_" + ИндексГруппыПредпоказ);
				ПараметрыГруппы.Вставить("Группировка"           , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
				ПараметрыГруппы.Вставить("ШиринаГруппы"          , МаксимальнаяШиринаПредпоказ);
				ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Половинный);
				
				ГруппаПодчПредпоказ = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
				
				ШиринаГруппыПредпоказ = ДлинаЭлементаПредпоказ;
				ИндексГруппыПредпоказ = ИндексГруппыПредпоказ + 1;
				
			КонецЕсли;
			
			ИмяЭлементаПредпоказ = "Предпоказ_ME_" + ИмяМеню + "_Тип_" + ПредставлениеЭлемента;
			
			// Создание элемента предпоказа.
			ПараметрыЭлемента = Новый Структура;
			ПараметрыЭлемента.Вставить("ГруппаЭлемента"       , ГруппаПодчПредпоказ);
			ПараметрыЭлемента.Вставить("ИмяЭлемента"          , ИмяЭлементаПредпоказ);
			ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
			ПараметрыЭлемента.Вставить("Заголовок"            , ЭлементМ.Представление);
			ПараметрыЭлемента.Вставить("ЦветФона"             , ЦветФонаВыбранного);
			ПараметрыЭлемента.Вставить("РазмерШрифта"         , РазмерШрифта);
			ПараметрыЭлемента.Вставить("Группировка"          , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
			ПараметрыЭлемента.Вставить("Подсказка"            , "#" + ЭлементМ.Значение.Наименование);// ЗаголовкиМеню.ВсплывающееМеню);
			
			КомандаПредпоказ = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
			
		КонецЕсли;
		
		// Переход на новую строку, если в группе больше заданного числа элементов.
		Если Ост(ИндексЭлемента, ОгрКолЭлементов) = 0 Тогда
			
			// Создание подгруппы подчиненного меню.
			ПараметрыГруппы = Новый Структура;
			ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаВсплывающая);
			ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Группа_ME_" + ИмяМеню + "_ID_" + ИндексГруппы);
			ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
			
			ГруппаПодчМеню = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
			ИндексГруппы   = ИндексГруппы + 1;
			
		КонецЕсли;
		
		ИндексЭлемента = ИндексЭлемента + 1;
		ИмяЭлемента    = "Отбор_ME_" + ИмяМеню + "_Тип_" + ПредставлениеЭлемента;
		
		// Создание элемента отбора.
		ПараметрыЭлемента = Новый Структура;
		ПараметрыЭлемента.Вставить("ГруппаЭлемента"        , ГруппаПодчМеню);
		ПараметрыЭлемента.Вставить("ИмяЭлемента"           , ИмяЭлемента);
		ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия" , ИмяОбработчикаНажатия);
		ПараметрыЭлемента.Вставить("Заголовок"             , ЭлементМ.Представление);
		ПараметрыЭлемента.Вставить("Видимость"             , ?(ЭлементМ.Свойство("Видимость"), ЭлементМ.Видимость, Истина));
		ПараметрыЭлемента.Вставить("ЦветФона"              , ЦветФона);
		ПараметрыЭлемента.Вставить("РазмерШрифта"          , РазмерШрифта);
		ПараметрыЭлемента.Вставить("КнопкаОтображение"     , ОтображениеКнопки.Текст);
		ПараметрыЭлемента.Вставить("Группировка"           , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
		ПараметрыЭлемента.Вставить("ГоризонтальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Половинный);
				
		КомандаОтбор = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
		
		// Привязка элемента к привязанным данным параметров меню.
		ЭлементМ.Вставить("ПривязанноеЗначение", КомандаОтбор.Имя);
				
		// Отображение значения выбора в меню отбора.
		Если ЗначениеЗаполнено(ПредПривязанныеДанные)
			И ЭлементМ.Выбор = Ложь Тогда
			
			НайденноеЗначение = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(ПредПривязанныеДанные, "Значение", ЭлементМ.Значение);
			Если НайденноеЗначение <> Неопределено Тогда
				ЭлементМ.Выбор = НайденноеЗначение.Выбор;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЭлементМ.Выбор = Истина Тогда
			КоличествоВыбранных = КоличествоВыбранных + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Форма.Элементы["ГруппаПредпоказДобавить_ME_" + ИмяМеню].Видимость = Не ЗначениеЗаполнено(КоличествоВыбранных);
	
	Если ПараметрыМеню.Открыт Тогда
		
		Для Каждого ЭлементМ Из ПривязанныеДанные Цикл
			
			ЭлементОтбор = Форма.Элементы[СтрЗаменить(ЭлементМ.ПривязанноеЗначение,"Команда","Кнопка")];
			ЭлементОтбор.Родитель.ЦветФона = ?(ЭлементМ.Выбор, ЦветФонаВыбранного, ЦветФона);
			
		КонецЦикла;
		
		// Отображение меню.
		ГруппаВсплывающая.Показать();
		
	КонецЕсли;
		
	// Создание кнопки Применить.
	ПараметрыЭлемента = Новый Структура;
	
	ПараметрыЭлемента.Вставить("ГруппаЭлемента"       , ГруппаПодчМеню);
	ПараметрыЭлемента.Вставить("ИмяЭлемента"          , "Применить_ME_" + ИмяМеню);
	ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПараметрыЭлемента.Вставить("Заголовок"            , НСтр("ru = 'Применить'; en = 'Apply'"));
	ПараметрыЭлемента.Вставить("Видимость"            , Ложь);
	ПараметрыЭлемента.Вставить("ЦветФона"             , Новый Цвет(166, 202, 240));
	ПараметрыЭлемента.Вставить("РазмерШрифта"         , РазмерШрифта);
	ПараметрыЭлемента.Вставить("ШиринаЭлемента"       , 9);
	ПараметрыЭлемента.Вставить("ПереместитьВКонец"    , Истина);
	
	КомандаПрименить = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
	
КонецПроцедуры

// Процедура - Формирование меню отбора добавление реквизитов данных.
//
// Параметры:
//  Форма				 - 	 -
//  ОписаниеЭлементаМеню - 	 -
//  ПараметрыМеню		 - 	 -
//  ИндексДанных		 - 	 -
//
Процедура ФормированиеВсплывающегоДинамическогоМенюДобавлениеРеквизитовДанных(Форма, ИмяМеню)
		
	// Реквизит данных.
	ИмяРеквизитаДанных = "ME_" + ИмяМеню;
	
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, ИмяРеквизитаДанных) Тогда
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяРеквизитаДанных, Новый ОписаниеТипов("СписокЗначений")));
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
		
	КонецЕсли;
	
	// Реквизит данных состояния отборов.
	РеквизитДанныхСостоянияОтборов = "СостояниеОтборов";
		
	Если Не ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(Форма, РеквизитДанныхСостоянияОтборов) Тогда
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить(Новый РеквизитФормы(РеквизитДанныхСостоянияОтборов, Новый ОписаниеТипов("ТаблицаЗначений")));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("ИмяМеню", Новый ОписаниеТипов("Строка"), РеквизитДанныхСостоянияОтборов));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Элемент", Новый ОписаниеТипов("Строка"), РеквизитДанныхСостоянияОтборов));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Выбор"  , Новый ОписаниеТипов("Булево"), РеквизитДанныхСостоянияОтборов));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("Открыт" , Новый ОписаниеТипов("Булево"), РеквизитДанныхСостоянияОтборов));
		
		// Добавляем реквизит.
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
	Иначе
		Форма[РеквизитДанныхСостоянияОтборов].Очистить();
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Формирование всплывающего динамического меню добавление основного меню.
//
// Параметры:
//  Форма					 - 	 -
//  ИмяМеню					 - 	 -
//  ГруппаМеню				 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  ПересоздатьЭлемМеню		 - 	 -
//  ЦветФона				 - 	 -
//  ЦветФонаВыбранного		 - 	 -
//  РазмерШрифта			 - 	 -
//  ГруппаВсплывающая		 - 	 -
//  ГруппаПредпоказ			 - 	 -
//
Процедура ФормированиеВсплывающегоДинамическогоМенюДобавлениеОсновногоМеню(Форма, ПараметрыМеню, ГруппаВсплывающая, ГруппаПредпоказ)
	
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ГруппаМеню            = Форма.Элементы[ПараметрыМеню.ИмяГруппы];
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	ПересоздатьЭлемМеню   =	ПараметрыМеню.ПересоздатьЭлемМеню;
	ЦветФона              = ПараметрыМеню.ЦветФона;
	ЦветФонаВыбранного    = ПараметрыМеню.ЦветФонаВыбранного;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	ЗаголовкиМеню         = ПараметрыМеню.ЗаголовкиМеню;

	// Если необходимо пересоздать меню - то удаляем все старые элементы.
	Если ПересоздатьЭлемМеню = Истина Тогда
		
		МассивУдаляемыхЭлементов = Новый Массив;
		
		Для Каждого ЭлементМеню Из ГруппаМеню.ПодчиненныеЭлементы Цикл
			МассивУдаляемыхЭлементов.Добавить(ЭлементМеню);
		КонецЦикла;
		
		Для Каждого ЭлементМеню Из МассивУдаляемыхЭлементов Цикл
			Форма.Элементы.Удалить(ЭлементМеню);
		КонецЦикла;
		
	КонецЕсли;
	
	// Создание всплывающей группы основного меню.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента"              , ГруппаМеню);
	ПараметрыГруппы.Вставить("ИмяЭлемента"                 , "Группа_ME_" + ИмяМеню + "Всплывающая");
	ПараметрыГруппы.Вставить("Группировка"                 , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал"      , ИнтервалМеждуЭлементамиФормы.Половинный);
	ПараметрыГруппы.Вставить("ВертикальныйИнтервал"        , ИнтервалМеждуЭлементамиФормы.Половинный);
	ПараметрыГруппы.Вставить("Заголовок"                   , " ");
	ПараметрыГруппы.Вставить("ОтображатьЗаголовок"         , Истина);
	ПараметрыГруппы.Вставить("РазмерШрифтаЗаголовка"       , 1);
	ПараметрыГруппы.Вставить("ЦветТекстаЗаголовка"         , ЦветФона);
	ПараметрыГруппы.Вставить("Поведение"                   , ПоведениеОбычнойГруппы.Всплывающая);
	ПараметрыГруппы.Вставить("ВертикальноеПоложениеВГруппе", ВертикальноеПоложениеЭлемента.Низ);
	
	ГруппаВсплывающая = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
		
	// Создание группы предпоказ основного меню.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаМеню);
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Группа_ME_" + ИмяМеню + "Предпоказ");
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	
	ГруппаПредпоказ = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
		
КонецПроцедуры

// Процедура - Формирование элементов в динамическом меню всплывающих групп добавление элементов редактирования.
//
// Параметры:
//  Форма					 - 	 -
//  ИмяМеню					 - 	 -
//  ГруппаМеню				 - 	 -
//  ИмяОбработчикаНажатия	 - 	 -
//  РазмерШрифта			 - 	 -
//  ЦветФона				 - 	 -
//
Процедура ФормированиеВсплывающегоДинамическогоМенюДобавлениеЭлементовРедактирования(Форма, ПараметрыМеню, ГруппаВсплывающая, ГруппаПредпоказ)
	
	ИмяМеню               = ПараметрыМеню.ИмяМеню;
	ИмяОбработчикаНажатия = ПараметрыМеню.ИмяОбработчикаНажатия;
	ЦветФона              = ПараметрыМеню.ЦветФона;
	ЦветФонаВыбранного    = ПараметрыМеню.ЦветФонаВыбранного;
	РазмерШрифта          = ПараметрыМеню.РазмерШрифта;
	ЗаголовкиМеню         = ПараметрыМеню.ЗаголовкиМеню;
	
	// Создание элемента добавления предпоказ.
	ПараметрыЭлемента = Новый Структура;
	ПараметрыЭлемента.Вставить("ГруппаЭлемента"       , ГруппаПредпоказ);
	ПараметрыЭлемента.Вставить("ИмяЭлемента"          , "ПредпоказДобавить_ME_" + ИмяМеню);
	ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПараметрыЭлемента.Вставить("Заголовок"            , ЗаголовкиМеню.ПустоеМеню);
	ПараметрыЭлемента.Вставить("Видимость"            , Ложь);
	ПараметрыЭлемента.Вставить("РазмерШрифта"         , РазмерШрифта);
	ПараметрыЭлемента.Вставить("ЦветФона"             , ЦветФона);
	
	ПараметрыЭлемента.Вставить("ГоризонтальноеПоложениеВГруппе", ГоризонтальноеПоложениеЭлемента.Лево);
	
	КомандаПредпоказДобавить = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
	
	// Создание заголовка меню.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента"        , ГруппаВсплывающая);
	ПараметрыГруппы.Вставить("ИмяЭлемента"           , "ГруппаЗаголовок_ME_" + ИмяМеню);
	ПараметрыГруппы.Вставить("ГоризонтальныйИнтервал", ИнтервалМеждуЭлементамиФормы.Одинарный);
	
	ГруппаЗаголовокМеню = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	// Создание декорации заголовка меню.
	ПараметрыДекорации = Новый Структура;
	ПараметрыДекорации.Вставить("ГруппаЭлемента", ГруппаЗаголовокМеню);
	ПараметрыДекорации.Вставить("ИмяЭлемента"   , "ДекорацияЗаглушка_ME_" + ИмяМеню + "_Тип_Редактирование");
	ПараметрыДекорации.Вставить("Заголовок"     , " " + ЗаголовкиМеню.ВсплывающееМеню);
	ПараметрыДекорации.Вставить("ЦветТекста"    , ЦветаСтиля.МоиВариантыОтчетовЦвет);
	ПараметрыДекорации.Вставить("РазмерШрифта"  , РазмерШрифта + 1);
	
	ДекорацияЗаглушка = СоздатьЭлементДекорация(Форма, ПараметрыДекорации);
	
	// Создание кнопки Редактировать.
	ПараметрыЭлемента = Новый Структура;
	ПараметрыЭлемента.Вставить("ГруппаЭлемента"       , ГруппаЗаголовокМеню);
	ПараметрыЭлемента.Вставить("ИмяЭлемента"          , "Редактировать_ME_" + ИмяМеню);
	ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПараметрыЭлемента.Вставить("Подсказка"            , НСтр("ru = 'Редактировать '; en = 'Edit '") + ЗаголовкиМеню.ВсплывающееМеню);
	ПараметрыЭлемента.Вставить("Видимость"            , Истина);
	ПараметрыЭлемента.Вставить("РазмерШрифта"         , РазмерШрифта);
	ПараметрыЭлемента.Вставить("Картинка"             , БиблиотекаКартинок.Редактировать_16х16);
	ПараметрыЭлемента.Вставить("КнопкаОтображение"    , ОтображениеКнопки.Картинка);
	
	КомандаРедактировать = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);

	// Создание подгруппы редактирования подчиненного меню.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаВсплывающая);
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Группа_ME_" + ИмяМеню + "_Тип_Редактирование");
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная);
	
	ГруппаРедактированияМеню = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	ИмяЭлемента = "ПолеДобавить_ME_" + ИмяМеню + "_Тип_ПолеВвода";
	
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРедактированияМеню);
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , ИмяЭлемента);
	ПараметрыГруппы.Вставить("ЦветФона"      , ЦветФона);
	
	ГруппаПолеВвода = СоздатьЭлементГруппа(Форма, ПараметрыГруппы);
	
	ПараметрыПоля = Новый Структура;
	ПараметрыПоля.Вставить("ГруппаЭлемента"      , ГруппаПолеВвода);
	ПараметрыПоля.Вставить("ИмяЭлемента"         , ИмяЭлемента);
	ПараметрыПоля.Вставить("ИмяРеквизитаДанных"  , "ME_" + ИмяМеню + "_Тип_ПолеВвода");
	ПараметрыПоля.Вставить("ТипДанныхПоУмолчанию", Тип("Строка"));
	ПараметрыПоля.Вставить("ПодсказкаВвода"      , НСтр("ru = '+ Добавить'; en = '+ Add'"));
	ПараметрыПоля.Вставить("РазмерШрифта"        , 9);
	ПараметрыПоля.Вставить("ШиринаЭлемента"      , 10);
	
	ПараметрыПоля.Вставить("ОбработчикОкончаниеВводаТекста"         , ИмяОбработчикаНажатия);
	ПараметрыПоля.Вставить("ОбработчикИзменениеТекстаРедактирования", ИмяОбработчикаНажатия);
	
	ПолеВвода = СоздатьЭлементПоле(Форма, ПараметрыПоля);
	
	// Создание кнопки Добавить.
	ПараметрыЭлемента = Новый Структура;
	ПараметрыЭлемента.Вставить("ГруппаЭлемента"       , ГруппаРедактированияМеню);
	ПараметрыЭлемента.Вставить("ИмяЭлемента"          , "Добавить_ME_" + ИмяМеню);
	ПараметрыЭлемента.Вставить("ИмяОбработчикаНажатия", ИмяОбработчикаНажатия);
	ПараметрыЭлемента.Вставить("Заголовок"            , НСтр("ru = 'Добавить'; en = 'Add'"));
	ПараметрыЭлемента.Вставить("Видимость"            , Ложь);
	ПараметрыЭлемента.Вставить("ЦветФона"             , Новый Цвет(255, 215, 40));
	ПараметрыЭлемента.Вставить("РазмерШрифта"         , РазмерШрифта);
	ПараметрыЭлемента.Вставить("ШиринаЭлемента"       , 9);
		
	КомандаДобавить = СозданиеЭлементаМеню(Форма, ПараметрыЭлемента);
			
КонецПроцедуры

#КонецОбласти

#Область СозданиеЭлементовДинамическогоВиджетаСделки 

// Процедура, "ОбновитьВиджетСделки".
//
Процедура ОбновитьВиджетСделки(Форма, Знач Контрагент = Неопределено, Знач Сделка = Неопределено, АктуализироватьДанные = Истина) Экспорт
		
	ИнициализироватьРеквизитыВиджетаСделки(Форма);
	
	ЗаполнитьТаблицуПричинОтказов(Форма);	

	ОчиститьГруппуВиджетСделки(Форма);
	
	Если АктуализироватьДанные Тогда 
		Форма.ТаблицаДоступныхВидовСделок.Очистить();
		ОчиститьГруппуВиджетВыбораВидаГенерируемойСделки(Форма);		
	КонецЕсли;	

	ДоступноСозданиеСделок = ПравоДоступа("Добавление", Метаданные.Справочники.Сделки) И НЕ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Событие") И НЕ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием");
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Форма.ТекущаяСделка 				= Справочники.Сделки.ПустаяСсылка();
	ВидСделки 							= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	МассивВидовСделокПродления 			= Новый Массив;
	Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ЗадачаСсылка.Взаимодействие") Тогда
		КоллекцияСделок 				= Новый Массив();
		КоллекцияСделок.Добавить(Форма.Объект.Сделка);
		ДоступноСозданиеСделок 		= Ложь;
	ИначеЕсли ЗначениеЗаполнено(Сделка) Тогда
		Форма.ТекущаяСделка 			= Сделка;
		КоллекцияСделок 				= Новый Массив();
		КоллекцияСделок.Добавить(Сделка);
	Иначе
		Врач = Неопределено;
		Прием = Неопределено;
		Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Событие") Тогда
			Если ЗначениеЗаполнено(Форма.Объект.СсылкаНаПрием) Тогда 
				Сделка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Форма.Объект.СсылкаНаПрием, "Сделка");
			КонецЕсли;
	    	Если НЕ Форма.Объект.Услуги.Количество() = 0 Тогда 
				Врач = Форма.Объект.Услуги[0].Сотрудник;
			КонецЕсли;
		ИначеЕсли ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием") Тогда
			Если ЗначениеЗаполнено(Форма.Объект.ДокументОснование) И ТипЗнч(Форма.Объект.ДокументОснование) = Тип("ДокументСсылка.Событие") Тогда 
				Сделка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Форма.Объект.ДокументОснование, "Сделка");
			ИначеЕсли Форма.Объект.Ссылка.Пустая() И (НЕ ЗначениеЗаполнено(Форма.Объект.ДокументОснование) ИЛИ НЕ ТипЗнч(Форма.Объект.ДокументОснование) = Тип("ДокументСсылка.Событие")) Тогда 
				// При создании Приёма, если основание пустое (нет записи) - ищем ПЗ на сегодня по врачу (в рамках дня)
				ДанныеЗаписи = Документы.Событие.ПолучитьБлижайшуюЗаписьНаСегодня(Форма.Объект.ВремяНачалаПриема, , Контрагент, Форма.Объект.Сотрудник);
				Если ЗначениеЗаполнено(ДанныеЗаписи) Тогда 
					Форма.Объект.ДокументОснование = ?(ЗначениеЗаполнено(Форма.Объект.ДокументОснование), Форма.Объект.ДокументОснование, ДанныеЗаписи.ЗаписьНаПрием);
					Сделка = ДанныеЗаписи.Сделка;
					//Форма.Объект.Сделка = 
				КонецЕсли;	
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(Сделка) И НЕ Форма.Объект.Ссылка.Пустая() Тогда 
				Сделка = Справочники.Сделки.ПолучитьСделкуПоЗаписиНаПрием( , Форма.Объект.Ссылка);
			КонецЕсли;
	    	Если ЗначениеЗаполнено(Форма.Объект.Сотрудник) Тогда 
				Врач = Форма.Объект.Сотрудник;
			КонецЕсли;			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Сделка) Тогда
			Если НЕ ЗначениеЗаполнено(Форма.Объект.Сделка) Тогда 
				Форма.ТекущаяСделка = Сделка;
			КонецЕсли;	
			КоллекцияСделок = Новый Массив();
			КоллекцияСделок.Добавить(Сделка);
			ДоступноСозданиеСделок = Ложь;
		Иначе
			ДоступноСозданиеСделок = НЕ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Событие") И НЕ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием");
			ПоискДляПриемаБезЗаписи = ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием") И Форма.Объект.Ссылка.Пустая() И (НЕ ЗначениеЗаполнено(Форма.Объект.ДокументОснование) ИЛИ НЕ ТипЗнч(Форма.Объект.ДокументОснование) = Тип("ДокументСсылка.Событие"));
			Если ЗначениеЗаполнено(Форма.Объект.СтруктурнаяЕдиница) И НЕ ТипЗнч(Форма.Объект.Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда 
				СтруктурнаяЕдиница = Форма.Объект.СтруктурнаяЕдиница;
			Иначе 	
				СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
			КонецЕсли;	                           
			КоллекцияСделок = Справочники.Сделки.ПолучитьСделкиПоКлиенту(Контрагент
																	, СтруктурнаяЕдиница
																	, Истина
																	, Врач
																	, ?(ПоискДляПриемаБезЗаписи, Справочники.Сотрудники.ПолучитьОсновнуюСпециализациюСотрудника(Форма.Объект.Сотрудник), Неопределено)
																	, 
																	, Истина
																	, ТипЗнч(Форма.Объект.Ссылка) = Тип("СправочникСсылка.Контрагенты") ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("СправочникСсылка.Заявки")
																	, ?(ЗначениеЗаполнено(Форма.Объект.Ссылка), Неопределено, Перечисления.РезультатыСделок.ПустаяСсылка())
																	, 
																	, 
																	, НЕ ПоискДляПриемаБезЗаписи);
																	
			Если ПоискДляПриемаБезЗаписи Тогда
				// Если ПЗ нет на сегодня по врачу - тогда мы берем открытую, не привязанную к записи сделку, не находящуюся в регистре проф. осмотров с периодом на сегодня,
				// с таким же врачем или с пустым врачем и специализацией или пустым врачем и специализацией, подходящей для врача создаваемого приема.														
				Если КоллекцияСделок.Количество() > 0 Тогда 			
					КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(Новый Структура("ВидСделки, СтруктурнаяЕдиница, Записан", ВидСделки, СтруктурнаяЕдиница, Ложь));
					Если КоллекцияСтрок.Количество() > 0 Тогда
						Форма.ТекущаяСделка = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), КоллекцияСделок[0], КоллекцияСтрок[0].Сделка);
					КонецЕсли;
				КонецЕсли; 
				Если НЕ ЗначениеЗаполнено(Форма.ТекущаяСделка) Тогда 
					// В случае наличия предыдущего приема, который тоже без записи был создан
					Форма.ТекущаяСделка = Справочники.Сделки.ПолучитьЗавершенныеСделки(ТекущаяДатаСеанса(), СтруктурнаяЕдиница, Контрагент, Врач, ВидСделки, Перечисления.РезультатыСделок.Успех, Истина);												
				КонецЕсли;
			ИначеЕсли КоллекцияСделок.Количество() > 0 И (ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Событие") ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием")) Тогда 
				// Завершаем поиском по доступным СЕ
				КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(Новый Структура("ВидСделки, СтруктурнаяЕдиница, Записан", ВидСделки, СтруктурнаяЕдиница, НЕ Форма.Объект.Ссылка.Пустая()));
				Если КоллекцияСтрок.Количество() > 0 Тогда 
					Форма.ТекущаяСделка = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), КоллекцияСделок[0], КоллекцияСтрок[0].Сделка);
				ИначеЕсли Форма.Объект.Ссылка.Пустая() И ЗначениеЗаполнено(Врач) Тогда
					// Иначе завершаем поиском сделок по всем СЕ без врача
					КоллекцияСтрок = КоллекцияСделок.НайтиСтроки(Новый Структура("ВидСделки, Врач, Записан", ВидСделки, Справочники.Сотрудники.ПустаяСсылка(), Ложь));
					Если КоллекцияСтрок.Количество() > 0 Тогда 
						Форма.ТекущаяСделка = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), КоллекцияСделок[0], КоллекцияСтрок[0].Сделка);
						// Фильтруем коллекцию сделок для вывод в виджет только по доступным СЕ
						МассивСтруктурныхЕдиницДоступныхПользователю = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник, "Массив");
						Если ЗначениеЗаполнено(СтруктурнаяЕдиница) И МассивСтруктурныхЕдиницДоступныхПользователю.Найти(СтруктурнаяЕдиница) = Неопределено Тогда 
							МассивСтруктурныхЕдиницДоступныхПользователю.Добавить(СтруктурнаяЕдиница);
						КонецЕсли;
                        КоллекцияСделокПоДоступнымСЕ = КоллекцияСделок.СкопироватьКолонки();
						Для Каждого СтрокаТаблицы Из КоллекцияСделок Цикл 
							Если МассивСтруктурныхЕдиницДоступныхПользователю.Найти(СтрокаТаблицы.СтруктурнаяЕдиница) = Неопределено Тогда 
								Продолжить;
							КонецЕсли;
							ЗаполнитьЗначенияСвойств(КоллекцияСделокПоДоступнымСЕ.Добавить(), СтрокаТаблицы);
						КонецЦикла;
						Если КоллекцияСделокПоДоступнымСЕ.Найти(Форма.ТекущаяСделка, "Сделка") = Неопределено Тогда 
							ЗаполнитьЗначенияСвойств(КоллекцияСделокПоДоступнымСЕ.Добавить(), КоллекцияСтрок[0]);
						КонецЕсли;
						КоллекцияСделок = КоллекцияСделокПоДоступнымСЕ;
						КоллекцияСделокПоДоступнымСЕ = Неопределено;
					КонецЕсли;	
				КонецЕсли;	
			КонецЕсли; 
		КонецЕсли;
	КонецЕсли;	
	
	Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием") Тогда
		Если ЗначениеЗаполнено(Форма.Объект.ДокументОснование) Тогда 
			Форма.Элементы.Контрагент.ТолькоПросмотр 	= Истина;
			Форма.Элементы.Сотрудник.ТолькоПросмотр 	= Истина;
		Иначе 
			Форма.Элементы.Контрагент.ТолькоПросмотр 	= Ложь;
			Форма.Элементы.Сотрудник.ТолькоПросмотр 	= Ложь;
		КонецЕсли;
	КонецЕсли;
	
	ИндексВиджета 						= 0;
	КоличествоСделокВАрхиве 			= 0;
	ЕстьНеЗавершенные 					= Ложь;
	ЕстьНеЗавершенныеПредопределенные 	= Ложь;
	
	Если КоллекцияСделок.Количество() = 0 И МассивВидовСделокПродления.Количество() <> 0 Тогда 
		Для Каждого ЭлементМассива Из МассивВидовСделокПродления Цикл
			Форма.СписокВидовСделок.Добавить(ЭлементМассива);
			ИдентификаторЭлемента = Форма.СписокВидовСделок.НайтиПоЗначению(ЭлементМассива).ПолучитьИдентификатор();
			ОбновитьЭтапыСделки(Форма, ЭлементМассива, ИдентификаторЭлемента,0);
		КонецЦикла;
	Иначе 	
		Для Каждого СтрокаМассива Из КоллекцияСделок Цикл 
			         
			СделкаПомещенаВАрхив = Ложь;
			Если ЗначениеЗаполнено(СтрокаМассива.РезультатСделки) Тогда 
				Если НЕ ТипЗнч(Форма.Объект.Ссылка) = Тип("ЗадачаСсылка.Взаимодействие")
					И СтрокаМассива.ДатаЗавершенияСделки <= ТекущаяДатаСеанса()-60*5 Тогда // Показываем сделку в течении 5 минут.
				
					СоздатьГруппуАрхивСделок(Форма);
					СделкаПомещенаВАрхив = Истина;
				КонецЕсли;
			Иначе 
				ЕстьНеЗавершенные = Истина;
				Если СтрокаМассива.ВидСделки = ВидСделки Тогда 
					ЕстьНеЗавершенныеПредопределенные = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), Истина, СтрокаМассива.Записан = (НЕ Форма.Объект.Ссылка.Пустая()));
				КонецЕсли;	                    
			КонецЕсли;
			
			НоваяСтрока = Форма.ТаблицаСделок.Добавить();
			НоваяСтрока.Сделка 	    = ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), СтрокаМассива, СтрокаМассива.Сделка);
			НоваяСтрока.Прием  		= СтрокаМассива.Прием;
			НоваяСтрока.СуммаСделки = СтрокаМассива.СуммаСделки;
			
			ИндексКонтейнера = Цел(?(СделкаПомещенаВАрхив, КоличествоСделокВАрхиве, (ИндексВиджета-КоличествоСделокВАрхиве)) / 3);
			
			ОбновитьЭтапыСделки(Форма, ?(ТипЗнч(КоллекцияСделок) = Тип("Массив"), СтрокаМассива, СтрокаМассива.Сделка), ИндексВиджета,ИндексКонтейнера,СделкаПомещенаВАрхив);
			
			КоличествоСделокВАрхиве = КоличествоСделокВАрхиве + ?(СделкаПомещенаВАрхив, 1, 0);			
			ИндексВиджета = ИндексВиджета + 1;    
			
		КонецЦикла; 
		
	КонецЕсли;
	
	ПоследнийКонтейнерСделок = Форма.Элементы.Найти("ГруппаВиджетСделкиКонтейнер_"+ИндексКонтейнера);
	Если НЕ ПоследнийКонтейнерСделок = Неопределено Тогда
		
		Если ПоследнийКонтейнерСделок.ПодчиненныеЭлементы.Количество() >= 3 И КоличествоСделокВАрхиве = 0 Тогда		
			СжатьШиринуКнопокСделок(Форма, ПоследнийКонтейнерСделок, Истина); 				
		ИначеЕсли ПоследнийКонтейнерСделок.ПодчиненныеЭлементы.Количество() >= 3 И КоличествоСделокВАрхиве > 0 Тогда 			
			ПоследнийКонтейнерСделок = СоздатьГруппуКонтейнерСделок(Форма, ИндексКонтейнера + 1, Ложь);				
		КонецЕсли;	
		
	ИначеЕсли ПоследнийКонтейнерСделок = Неопределено И (ИндексВиджета - КоличествоСделокВАрхиве) = 0 Тогда			 
		ПоследнийКонтейнерСделок = СоздатьГруппуКонтейнерСделок(Форма, 0, Ложь);
		
	ИначеЕсли ПоследнийКонтейнерСделок = Неопределено Тогда
		ПоследнийКонтейнерСделок = Форма.Элементы.ВиджетСделки;	
	КонецЕсли;
	
	Если (ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Событие") ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Прием"))
		И НЕ ЗначениеЗаполнено(Сделка) И НЕ ЗначениеЗаполнено(Форма.ТекущаяСделка) И НЕ ЗначениеЗаполнено(Форма.Объект.Ссылка) Тогда
		Если ЗначениеЗаполнено(Контрагент) И ЕстьНеЗавершенныеПредопределенные = Ложь Тогда
			ОбновитьВиджетВыбораВидаГенерируемойСделки(Форма, Контрагент, Врач);
		КонецЕсли;	
	ИначеЕсли ДоступноСозданиеСделок Тогда		
		ИспользоватьЗаголовок = ?(КоллекцияСделок.Количество() > 0, Истина, Ложь);
		СоздатьКнопкуДобавитьСделку(Форма, ИспользоватьЗаголовок, ПоследнийКонтейнерСделок);	
	КонецЕсли;
	
	Если КоличествоСделокВАрхиве > 0 Тогда
		СоздатьКнопкуПросмотраАрхиваСделок(Форма, СтрШаблон(НСтр("ru = 'Архив (%1)'; en = 'Archive (%1)'"), КоличествоСделокВАрхиве), ПоследнийКонтейнерСделок);
		
	КонецЕсли; 
	//// Перемещаем группу архив сделок, в конец коллекции.
	ГруппаАрхивСделок = Форма.Элементы.Найти("ГруппаСвертываемаяАрхивСделок");
	Если ГруппаАрхивСделок <> Неопределено Тогда
		Форма.Элементы.Переместить(ГруппаАрхивСделок, Форма.Элементы.ВиджетСделки);
	КонецЕсли;

КонецПроцедуры

// Процедура - Обновить виджет выбора вида генерируемой сделки
//
// Параметры:
//  Форма					 - 	 - 
//  Пациент					 - 	 - 
//  Врач					 - 	 - 
//  АктуализироватьДанные	 - 	 - 
//
Процедура ОбновитьВиджетВыбораВидаГенерируемойСделки(Форма, Знач Пациент, Знач Врач, АктуализироватьДанные = Истина) Экспорт
	
	Если АктуализироватьДанные Тогда
		ТаблицаДоступныхВидовСделок = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(, Пациент, , Врач, Истина);
		Форма.ТаблицаДоступныхВидовСделок.Очистить();
		Для Каждого СтрокаДоступныеВидыСделок Из ТаблицаДоступныхВидовСделок Цикл
			НоваяСтрока = Форма.ТаблицаДоступныхВидовСделок.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДоступныеВидыСделок, , "ТаблицаЭтапов, ТаблицаПричинОтказов");
