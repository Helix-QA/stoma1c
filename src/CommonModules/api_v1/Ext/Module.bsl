// Функция - Получить минимальную норму времени услуг
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМинимальнуюНормуВремениУслуг()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	МИНИМУМ(ВЫБОР
	|			КОГДА Номенклатура.НормаВремени > 0
	|				ТОГДА Номенклатура.НормаВремени
	|			ИНАЧЕ 30
	|		КОНЕЦ) КАК НормаВремени
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.НормаВремени, 30);
	
КонецФункции

// Функция, проверяет входит ли прием в смену.
//
Функция ПриемВходитВСмену(Прием, Смена)
	
	Если (Прием.ДатаНачала >= Смена.ДатаВремяНачала
		И Прием.ДатаНачала < Смена.ДатаВремяОкончания)
		ИЛИ (Прием.ДатаОкончания > Смена.ДатаВремяНачала
		И Прием.ДатаОкончания <= Смена.ДатаВремяОкончания) Тогда
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Функция, проверяет, накладывается ли время одной услуги в записи на другую
//
Функция ВремяУслугСовпадает(СтрокаУслуга1, СтрокаУслуга2)
	
	РазницаМеждуНачаломУслуги1ИУслуги2 = НачалоМинуты(СтрокаУслуга1.ДатаЗаписи) - НачалоМинуты(СтрокаУслуга2.ДатаЗаписи);
	
	Если (РазницаМеждуНачаломУслуги1ИУслуги2 > 0 И НачалоМинуты(СтрокаУслуга1.ДатаЗаписи) < НачалоМинуты(СтрокаУслуга2.ДатаЗаписи + СтрокаУслуга2.НормаВремени))
		ИЛИ (РазницаМеждуНачаломУслуги1ИУслуги2 < 0 И НачалоМинуты(СтрокаУслуга2.ДатаЗаписи) < НачалоМинуты(СтрокаУслуга1.ДатаЗаписи + СтрокаУслуга1.НормаВремени)) 
		ИЛИ (РазницаМеждуНачаломУслуги1ИУслуги2 = 0) Тогда
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

