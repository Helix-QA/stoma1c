// Процедура - обработчик события "ПриНачалеРедактирования"
//
Процедура ЗатратыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда		
		Если ЗначениеЗаполнено(Объект.Статья) Тогда
			Элемент.ТекущиеДанные.СтатьяЗатрат = Объект.Статья;
		КонецЕсли;
		
		Если Элемент.ТекущиеДанные.НомерСтроки = 1 Тогда	
			Элемент.ТекущиеДанные.Сумма = Объект.СуммаДокумента;
		КонецЕсли;
		
		Если Копирование Тогда 
			Элемент.ТекущиеДанные.Сумма = 0;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

