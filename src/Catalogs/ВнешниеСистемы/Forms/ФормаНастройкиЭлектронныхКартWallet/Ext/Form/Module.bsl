&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ИдПроекта", ИдПроектаДляРедактирования);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПараметрыВнешнейСистемы = Объект.Ссылка.Параметры.Получить();
	КонецЕсли;
	
	Если ПараметрыВнешнейСистемы <> Неопределено Тогда
			
		ПараметрыВнешнейСистемы.Свойство("ИдВебХука", ЭтотОбъект.ИдВебХука);
		ПараметрыВнешнейСистемы.Свойство("АдресAPI", ЭтотОбъект.АдресAPI);
				
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		
		Объект.Используется		 = Истина;
		Объект.КлючПриложения	 = Новый УникальныйИдентификатор();
		Объект.ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet;
		СформироватьНаименование();
		
		Элементы.ГруппаWalletДополнительно.Группировка  = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		Элементы.ВидКартыПоУмолчанию.МаксимальнаяШирина = 40;
		Элементы.КлючПриложенияДополнительно.МаксимальнаяШирина = 36;
		Элементы.НаименованиеДополнительно.МаксимальнаяШирина   = 40;
		
	КонецЕсли;
	
	ЭтотОбъект.ВидКартыПоУмолчанию = Константы.ВидКартыWalletПоУмолчанию.Получить();
	
	УидСессии = ЛичныйКабинет.УидТекущейСессии();
	ЭтоОблако = ПараметрыСеанса.ОбластьДанныхИспользование;
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.АдресAPI) Тогда
		ЭтотОбъект.АдресAPI = "api.webcitrus.app";
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

