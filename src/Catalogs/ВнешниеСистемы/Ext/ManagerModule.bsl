// Функция, возвращает имя раздела внешней системы.
//
Функция ПолучитьРазделВнешнейСистемы(ТипВнешнейСистемы) Экспорт
	
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Calltouch Тогда
		Возврат "СквознаяАналитика";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		Возврат "Мессенджеры";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk Тогда
		Возврат "Мессенджеры";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.CoMagic Тогда
		Возврат "СквознаяАналитика";
	// ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Instagram Тогда
	//	Возврат "Мессенджеры";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.IPТелефония Тогда
		Возврат "Телефония";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.JivoSite Тогда
		Возврат "ИсточникиЛидов";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Marquiz Тогда
		Возврат "ИсточникиЛидов";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Roistat Тогда
		Возврат "СквознаяАналитика";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ЯндексМетрика Тогда
		Возврат "СквознаяАналитика";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.TapLink Тогда
		Возврат "ИсточникиЛидов";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда
		Возврат "Мессенджеры";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Tilda Тогда
		Возврат "ИсточникиЛидов";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Vkontakte Тогда
		Возврат "ИсточникиЛидов";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.VkontakteApi Тогда
		Возврат "Мессенджеры";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Viber Тогда
		Возврат "Мессенджеры";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet Тогда
		Возврат "ЭлектронныеКарты";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Webhook Тогда
		Возврат "ИсточникиЛидов";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи Тогда
		Возврат "ОнлайнЗапись";
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ПроДокторов Тогда
		Возврат "ОнлайнЗапись";
	Иначе
		Возврат "Прочее";
	КонецЕсли;
	
КонецФункции

// Функция, возвращает список данных внешних систем мессенджера.
//
Функция ПолучитьДоступныеВнешниеСистемыМессенджера(Получатель, СтруктурнаяЕдиница,ДляОтправкиПервым = Ложь, МассивТребуемыхТелефонов = Неопределено)	Экспорт	
	
	Если МассивТребуемыхТелефонов <> Неопределено И ТипЗнч(МассивТребуемыхТелефонов) = Тип("Строка") Тогда
		МассивНомеров = Новый Массив;
		МассивНомеров.Добавить(МассивТребуемыхТелефонов);
	Иначе
		МассивНомеров = МассивТребуемыхТелефонов;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВнешниеСистемыВсе
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистемВсе)
	|	И ВнешниеСистемы.СтруктурнаяЕдиница В (ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка), &СтруктурнаяЕдиница)
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.Используется
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВнешниеСистемыОтправитьПервым
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистемОтправитьПервым)
	|	И ВнешниеСистемы.СтруктурнаяЕдиница В (ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка), &СтруктурнаяЕдиница)
	|	И ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтактыМессенджеров.Идентификатор КАК Идентификатор,
	|	КонтактыМессенджеров.ВнешняяСистема КАК ВнешняяСистема,
	|	КонтактыМессенджеров.НомерМессенджера КАК НомерМессенджера,
	|	КонтактыМессенджеров.НеУчаствоватьВРассылке КАК НеУчаствоватьВРассылке,
	|	0 КАК ПорядокСортировки
	|ПОМЕСТИТЬ СуществующиеКонтакты
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВнешниеСистемыВсе КАК ВнешниеСистемыВсе
	|		ПО КонтактыМессенджеров.ВнешняяСистема = ВнешниеСистемыВсе.Ссылка
	|ГДЕ
	|	КонтактыМессенджеров.ОбъектИдентификации = &Получатель
	|	И НЕ КонтактыМессенджеров.ОбъектИдентификации В (НЕОПРЕДЕЛЕНО, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка), ЗНАЧЕНИЕ(Справочник.Заявки.ПустаяСсылка))
	|   И &УсловиеОтбораПоНомерамСуществующие
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемыОтправитьПервым.Ссылка КАК ВнешняяСистема,
	|	КонтактнаяИнформация.НомерТелефона КАК НомерМессенджера,
	|	ЗНАЧЕНИЕ(Перечисление.Мессенджеры.whatsapp) КАК Мессенджер,
	|	1 КАК ПорядокСортировки
	|ПОМЕСТИТЬ ДоступныеКонтакты
	|ИЗ
	|	ВнешниеСистемыОтправитьПервым КАК ВнешниеСистемыОтправитьПервым,
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Ссылка = &Получатель
	|	И КонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|	И НЕ КонтактнаяИнформация.НеУчаствоватьВРассылке
	|	И НЕ (ВнешниеСистемыОтправитьПервым.Ссылка, КонтактнаяИнформация.НомерТелефона) В
	|				(ВЫБРАТЬ
	|					СуществующиеКонтакты.ВнешняяСистема,
	|					СуществующиеКонтакты.НомерМессенджера
	|				ИЗ
	|					СуществующиеКонтакты КАК СуществующиеКонтакты)
	|  И &УсловиеОтбораПоНомерамДоступные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СуществующиеКонтакты.Идентификатор КАК Идентификатор,
	|	СуществующиеКонтакты.ВнешняяСистема КАК ВнешняяСистема,
	|	СуществующиеКонтакты.НомерМессенджера КАК НомерМессенджера,
	|	СуществующиеКонтакты.ПорядокСортировки КАК ПорядокСортировки
	|ИЗ
	|	СуществующиеКонтакты КАК СуществующиеКонтакты
	|ГДЕ
	|	СуществующиеКонтакты.НеУчаствоватьВРассылке = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	"""",
	|	ДоступныеКонтакты.ВнешняяСистема,
	|	ДоступныеКонтакты.НомерМессенджера,
	|	ДоступныеКонтакты.ПорядокСортировки
	|ИЗ
	|	ДоступныеКонтакты КАК ДоступныеКонтакты
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокСортировки");
	
	Если ДляОтправкиПервым Тогда
		ТипыВнешнихСистемВсе			 = Справочники.ВнешниеСистемы.ПолучитьТипыВнешнихСистемМессенджераОтправитьПервым();
	Иначе
		ТипыВнешнихСистемВсе			 = Справочники.ВнешниеСистемы.ПолучитьМассивТиповВнешнихСистемМессенджера();	
	КонецЕсли;
	ТипыВнешнихСистемОтправитьПервым = Справочники.ВнешниеСистемы.ПолучитьТипыВнешнихСистемМессенджераОтправитьПервым();

	Запрос.УстановитьПараметр("Получатель"						, Получатель);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"				, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТипыВнешнихСистемВсе"			, ТипыВнешнихСистемВсе);
	Запрос.УстановитьПараметр("ТипыВнешнихСистемОтправитьПервым", ТипыВнешнихСистемОтправитьПервым);
	
	Если МассивНомеров <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&УсловиеОтбораПоНомерамДоступные", "КонтактнаяИнформация.НомерТелефона В (&МассивТребуемыхНомеров)"); 
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"&УсловиеОтбораПоНомерамСуществующие", "КонтактыМессенджеров.НомерМессенджера В (&МассивТребуемыхНомеров)");
		Запрос.УстановитьПараметр("МассивТребуемыхНомеров",МассивНомеров);
	Иначе
		Запрос.УстановитьПараметр("УсловиеОтбораПоНомерамДоступные", Истина); 
		Запрос.УстановитьПараметр("УсловиеОтбораПоНомерамСуществующие", Истина);
	КонецЕсли;
	
	Если ТипЗнч(Получатель) = Тип("СправочникСсылка.Заявки") Тогда
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст,
			"Справочник.Контрагенты.КонтактнаяИнформация КАК КонтактнаяИнформация",
			"Справочник.Заявки.КонтактнаяИнформация КАК КонтактнаяИнформация"
		);
	КонецЕсли;

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	СписокЗначений = Новый СписокЗначений;
	
	Для Каждого ДанныеКонтакта Из РезультатЗапроса Цикл
		
		Значение		 = СтрокуТаблицыЗначенийВСтруктуру(ДанныеКонтакта, РезультатЗапроса);
		Представление	 = СформироватьПредставлениеКонтактаМессенджера(ДанныеКонтакта);
		Картинка		 = КартинкаТипаВнешнейСистемы(ДанныеКонтакта.ВнешняяСистема.ТипВнешнейСистемы);
		
		СписокЗначений.Добавить(Значение, Представление,, Картинка);
		
	КонецЦикла;
	
	Возврат СписокЗначений;
	
КонецФункции

// Функция, возвращает представление контакта мессенджера.
//
Функция СформироватьПредставлениеКонтактаМессенджера(ДанныеКонтакта)
	
	Представление = ДанныеКонтакта.ВнешняяСистема.Наименование;
		
	Представление = ?(
		ДанныеКонтакта.ПорядокСортировки = 1,
		"Создать контакт (+" + ДанныеКонтакта.НомерМессенджера + ") - " + Представление,
		Представление + ?(ЗначениеЗаполнено(ДанныеКонтакта.НомерМессенджера), " (" + ДанныеКонтакта.НомерМессенджера + ")", "")
	);
	
	Возврат Представление;
	
КонецФункции

// Функция - Проверить существование доступных внешних систем для отправки первым
// 
// Возвращаемое значение:
//   - 
//
Функция СуществуютДоступныеВнешниеСистемыМессенджераДляОтправкиПервым(СтруктурнаяЕдиница) Экспорт
	
	 Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется = ИСТИНА
	|	И ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВнешниеСистемы.СтруктурнаяЕдиница В (ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка), &СтруктурнаяЕдиница)
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнейСистемы)");	
	
    Запрос.УстановитьПараметр("ТипыВнешнейСистемы", ПолучитьТипыВнешнихСистемМессенджераОтправитьПервым());
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);

	Возврат НЕ Запрос.Выполнить().Пустой();

	
КонецФункции

#КонецОбласти
