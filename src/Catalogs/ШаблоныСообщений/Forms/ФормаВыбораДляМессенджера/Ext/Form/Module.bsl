
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СформироватьПолеВвода();
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаписанШаблонСообщенияМессенджера" Тогда
		
		Элементы.Список.Обновить();
		
		Если Элементы.Список.ТекущиеДанные <> Неопределено И Элементы.Список.ТекущиеДанные.Ссылка = Параметр Тогда
			ОбновитьПолеПредпросмотра(Элементы.Список);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ДокументСформирован".
//
Процедура ПолеПредпросмотраДокументСформирован(Элемент)
	
	Если Элементы.Список.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ПолеПредпросмотра.Документ.getElementById("field").contentEditable = Ложь;
	Элементы.ПолеПредпросмотра.Документ.getElementById("field").innerHtml = Элементы.Список.ТекущиеДанные.СодержаниеМессенджерHTML;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриАктивизацииСтроки".
//
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	ОбновитьПолеПредпросмотра(Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
