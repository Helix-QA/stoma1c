&НаКлиенте
// Добавить рекламацмю 
//
Процедура ДобавитьРекламацию(Команда)
		
	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда 
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Необходимо выбрать пациента!";
		Сообщение.Поле = "Объект.Контрагент";
		Сообщение.УстановитьДанные(Объект);
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ПараметрыОткрытия.Вставить("Контрагент", Объект.Контрагент);
	КонецЕсли;	
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		ПараметрыОткрытия.Вставить("ПриемИсключение", Объект.Ссылка); // Прием, который не должен отображаться в форме выбора, т.к. из этого приема, делается рекламация.
	КонецЕсли;
	
	// Открывает доступ к приемам для рекламаторов
	ИнициализацияДоступаРекламаторам("Открыть", Истина,,ПолучитьМассивРекламаций(),Объект.Контрагент,Объект.АвторДокумента,Объект.СтруктурнаяЕдиница,УникальныйИдентификаторДоступа);
	
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьРекламациюПослеВыбораПриема", ЭтотОбъект);
	ОткрытьФорму("Документ.Прием.ФормаВыбора", ПараметрыОткрытия,,,,,ОписаниеОповещения , РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

