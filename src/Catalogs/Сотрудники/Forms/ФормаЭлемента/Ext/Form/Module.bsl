// Процедура - Подключаемый декорация формы удаление нажатие
// 
Процедура Подключаемый_ДекорацияФормы_Удаление_Нажатие(Элемент)
	
	МассивПодстрок	= СтрРазделить(Элемент.Имя, "_", Ложь);
	УИДСтроки		= ?(МассивПодстрок.Количество() > 1, МассивПодстрок[1], Неопределено); 
	
	Если УИДСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьЭементСтрокиКабинет(УИДСтроки);
		
	УдаляемаяСтрока = ЭтотОбъект.КабинетыСуществующие.НайтиПоИдентификатору(Число(УИДСтроки));
	
	Если УдаляемаяСтрока <> Неопределено Тогда
		ЭтотОбъект.КабинетыСуществующие.Удалить(УдаляемаяСтрока);	
	КонецЕсли;                                                   	
		
КонецПроцедуры  

