&НаКлиенте
// Процедура обрабатывает событие начала выбора из списка в поле периода регистрации
// Процедура исполняется только на клиенте
//
Процедура ВыбратьПериодИзСпискаПредставлений(ЭтаФорма, Элемент, Период, ПериодПредставление, НачальноеЗначение = Неопределено) Экспорт

	СтандартнаяОбработка = Ложь;
	
	Если НачальноеЗначение = Неопределено Тогда
		НачальноеЗначение = Период;
	КонецЕсли;
	
	СписокВыбора = Новый СписокЗначений;
	
	ДатаВыборкаМесяца = ?(Год(НачальноеЗначение) <> 1, Дата(Год(НачальноеЗначение) - 1, 12, 01), Дата(01, 01, 02));
	
	Для а = 1 по 13 + ?(Год(НачальноеЗначение) <> 1, 1, 0) Цикл
		Если Год(ДатаВыборкаМесяца) <> Год(НачальноеЗначение) Тогда
			СписокВыбора.Добавить(ДатаВыборкаМесяца, Формат(ДатаВыборкаМесяца, "ДФ='yyyy'") + " г. ...");
		Иначе 
			СписокВыбора.Добавить(ДатаВыборкаМесяца, Формат(ДатаВыборкаМесяца, "ДФ='MMMM yyyy'") + " г.");
		КонецЕсли;
		
		ДатаВыборкаМесяца = ДобавитьМесяц(ДатаВыборкаМесяца, 1);
	КонецЦикла;
	
	ВыбранныйЭлемент = ЭтаФорма.ВыбратьИзСписка(СписокВыбора, Элемент, СписокВыбора.НайтиПоЗначению(Период));
	
	Если ВыбранныйЭлемент = Неопределено Тогда
	ИначеЕсли Год(ВыбранныйЭлемент.Значение) = Год(НачальноеЗначение) Тогда
		Период = ВыбранныйЭлемент.Значение;
		ПериодПредставление  = ВыбранныйЭлемент.Представление;
	ИначеЕсли Год(ВыбранныйЭлемент.Значение) <> Год(НачальноеЗначение) Тогда
		ВыбратьПериодИзСпискаПредставлений(ЭтаФорма, Элемент, Период, ПериодПредставление, ВыбранныйЭлемент.Значение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция возвращает интервалы времени
// 
//  Параметры
//   МассивПериодов - структура, периоды, между которыми необходимо возвратить интервалы
//   Интервал - число, интервал в минутах
//   Формат - строка, представление интервала
//
// Возвращаемое значение:
//   СписокЗначений, список времени с интервалом.
//
Функция ВернутьСписокВремени(МассивПериодов, ДатаНачала, Интервал = 15, Формат = "ДФ=ЧЧ:мм") Экспорт

	СписокВремени = Новый СписокЗначений;
	
	Для Каждого Период Из МассивПериодов Цикл
		Если ДатаНачала Тогда
			Счетчик = 0;
		Иначе
			Счетчик = 1;
		КонецЕсли;
		Период.ДатаНачала = НачалоЧаса(Период.ДатаНачала) + Цел (Минута(Период.ДатаНачала) / 15) * 15 * 60;
		Пока Период.ДатаНачала + Интервал * 60 * Счетчик <= Период.ДатаОкончания Цикл
			Время = Период.ДатаНачала + Интервал * 60 * Счетчик;
			Если СписокВремени.НайтиПоЗначению(Время) = Неопределено Тогда
				Если не ЗначениеЗаполнено(Время) Тогда
					СписокВремени.Добавить(Время, "00:00");
				Иначе
					СписокВремени.Добавить(Время, Формат(Время, Формат));
				КонецЕсли;
			КонецЕсли;			
			Счетчик = Счетчик + 1;
		КонецЦикла;
		Если Период.ДатаОкончания = Дата(01,01,01,23,59,59) и не ДатаНачала Тогда
			СписокВремени.Добавить(Период.ДатаНачала + Интервал * 60 * Счетчик, "24:00");
		КонецЕсли;
	КонецЦикла;

	Возврат СписокВремени; 
	
КонецФункции

