// Функция - проверяет на основе регистра сведений "Фискальные операции (документы)" производится ли первая оплата.
//
Функция КоличествоЗаписейВРегистре(ДокументОснование) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 2
	|	ФискальныеОперацииДокументы.ИдентификаторЗаписи КАК ИдентификаторЗаписи
	|ИЗ
	|	РегистрСведений.ФискальныеОперацииДокументы КАК ФискальныеОперацииДокументы
	|ГДЕ
	|	ФискальныеОперацииДокументы.ДокументОснование = &ДокументОснование
	|	И ФискальныеОперацииДокументы.ДокументОснование ССЫЛКА Документ.Реализация");
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	Возврат Запрос.Выполнить().Выгрузить().Количество();	
	
КонецФункции     

// Функция - проверяет на основе регистра сведений "Фискальные операции (документы)" производится ли первая оплата.
//
Функция КоличествоЗаписейВозвратОтПокупателяВРегистре(ДокументОснование) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 2
	|	ФискальныеОперацииДокументы.ИдентификаторЗаписи КАК ИдентификаторЗаписи
	|ИЗ
	|	РегистрСведений.ФискальныеОперацииДокументы КАК ФискальныеОперацииДокументы
	|ГДЕ
	|	ФискальныеОперацииДокументы.ДокументОснование = &ДокументОснование
	|	И ФискальныеОперацииДокументы.ДокументОснование ССЫЛКА Документ.ВозвратОтПокупателя");
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	Возврат Запрос.Выполнить().Выгрузить().Количество();	
	
КонецФункции       

// Функция проверяет была ли полная постоплата.
//
Функция ЕстьПолнаяПостоплата(ДокументРеализации) Экспорт
	                           	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ФискальныеОперацииДокументы.ИдентификаторЗаписи КАК ИдентификаторЗаписи
	|ПОМЕСТИТЬ ВременнаяТаблицаФискальныеОперацииДокументы
	|ИЗ
	|	РегистрСведений.ФискальныеОперацииДокументы КАК ФискальныеОперацииДокументы
	|ГДЕ
	|	ФискальныеОперацииДокументы.ДокументОснование = &ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ФискальныеОперации.ИдентификаторЗаписи КАК ИдентификаторЗаписи,
	|	СУММА(ВЫБОР
	|			КОГДА ФискальныеОперацииДокументы.ДокументОснование ССЫЛКА Документ.Реализация
	|					И ФискальныеОперации.ОплатаНаличные = 0
	|					И ФискальныеОперации.ОплатаЭлектронно = 0
	|					И ФискальныеОперации.ОплатаПредоплата = 0
	|					И ФискальныеОперации.ОплатаВстречноеПредоставление = 0
	|					И ФискальныеОперации.ОплатаПостоплата > 0
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КолРеализаций,
	|	СУММА(ВЫБОР
	|			КОГДА ФискальныеОперацииДокументы.ДокументОснование ССЫЛКА Документ.ПоступлениеДенежныхСредств
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КолОплат,
	|	ФискальныеОперации.ОплатаНаличные КАК ОплатаНаличные,
	|	ФискальныеОперации.ОплатаЭлектронно КАК ОплатаЭлектронно,
	|	ФискальныеОперации.ОплатаПостоплата КАК ОплатаПостоплата,
	|	ФискальныеОперации.ОплатаПредоплата КАК ОплатаПредоплата,
	|	ФискальныеОперации.ОплатаВстречноеПредоставление КАК ОплатаВстречноеПредоставление
	|ИЗ
	|	РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперацииДокументы КАК ФискальныеОперацииДокументы
	|		ПО ФискальныеОперации.ИдентификаторЗаписи = ФискальныеОперацииДокументы.ИдентификаторЗаписи
	|ГДЕ
	|	ФискальныеОперации.ИдентификаторЗаписи В
	|			(ВЫБРАТЬ
	|				ВременнаяТаблицаФискальныеОперацииДокументы.ИдентификаторЗаписи
	|			ИЗ
	|				ВременнаяТаблицаФискальныеОперацииДокументы)
	|
	|СГРУППИРОВАТЬ ПО
	|	ФискальныеОперации.ИдентификаторЗаписи,
	|	ФискальныеОперации.ОплатаНаличные,
	|	ФискальныеОперации.ОплатаЭлектронно,
	|	ФискальныеОперации.ОплатаПостоплата,
	|	ФискальныеОперации.ОплатаПредоплата,
	|	ФискальныеОперации.ОплатаВстречноеПредоставление
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВЫБОР
	|			КОГДА ФискальныеОперацииДокументы.ДокументОснование ССЫЛКА Документ.Реализация
	|					И ФискальныеОперации.ОплатаНаличные = 0
	|					И ФискальныеОперации.ОплатаЭлектронно = 0
	|					И ФискальныеОперации.ОплатаПредоплата = 0
	|					И ФискальныеОперации.ОплатаВстречноеПредоставление = 0
	|					И ФискальныеОперации.ОплатаПостоплата > 0
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) > 0 И
	|	СУММА(ВЫБОР
	|			КОГДА ФискальныеОперацииДокументы.ДокументОснование ССЫЛКА Документ.ПоступлениеДенежныхСредств
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) = 0");
	
	 Запрос.УстановитьПараметр("ДокументОснование", ДокументРеализации);
	 
	 Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции  

