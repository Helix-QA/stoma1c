// Функция - Получить данные истории вызова
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеИсторииВызова(IDЗвонка, Сообщение = "")
	
	СтруктураВызова = РегистрыСведений.ИсторияВызовов.ПолучитьПоIDЗвонка(IDЗвонка);
	Если ЗначениеЗаполнено(СтруктураВызова) Тогда  
		
		Если Справочники.ТелефонныеАппараты.ЗаписьРазговораДоступна(ПараметрыСеанса.ТекущийСотрудник, СтруктураВызова.ПользовательSip) Тогда
			
			Возврат СтруктураВызова; 
		Иначе
			Сообщение = НСтр("ru = 'Нет прав на прослушивание текущей записи'; en = 'No rights to listen to the current recording'");
		КонецЕсли;	
		
	КонецЕсли;
	
	Возврат Неопределено;	
	
КонецФункции

