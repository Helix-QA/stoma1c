		ТаблицаДоступныхВидовСделокПоСЕ = Запрос.Выполнить().Выгрузить();
		//РезультатПакетногоЗапроса 				= Запрос.ВыполнитьПакет();
		//ТаблицаДоступныхВидовСделокПоСЕ 		= РезультатПакетногоЗапроса[0].Выгрузить();
