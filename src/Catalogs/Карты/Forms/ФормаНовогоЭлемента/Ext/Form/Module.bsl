КонецПроцедуры	

&НаСервере
// Процедура, заполняет сервисы рассылки.
//
Процедура ЗаполнитьСервисыРассылки()
	
	Если ЗначениеЗаполнено(Объект.ВладелецКарты)
		И Объект.ТипКода = Перечисления.ВидыКарт.Wallet Тогда
		
		СервисРассылкиВыбран = Ложь;
		
		НомерТелефона 						 = ПолучитьКонтактныеДанныеКонтрагента("Телефон");
		РасширениеМессенджераПодключено		 = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер") = Истина;
		ДоступныеВнешниеСистемыМессенджера	 = Документы.РассылкаСообщений.ПолучитьДоступныеДляОтправкиВнешниеСистемыМессенджера(Объект.ВладелецКарты, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		
		РассылкаВМессенджерРазрешена = ЗначениеЗаполнено(ДоступныеВнешниеСистемыМессенджера) И РасширениеМессенджераПодключено = Истина;
		
		Если РассылкаВМессенджерРазрешена Тогда
			
			ЭтотОбъект.ОтправитьВМессенджер = Истина;
			СервисРассылкиВыбран 		    = Истина;	
			
		Иначе
			
			ЭтотОбъект.ОтправитьВМессенджер = Ложь;
						
		КонецЕсли;
		
		Элементы.ГруппаМессенджер.Видимость = РассылкаВМессенджерРазрешена;
		
		АдресЭП = ПолучитьКонтактныеДанныеКонтрагента("АдресЭлектроннойПочты");
		
		РассылкаНаПочтуРазрешена = ПроверитьВозможностьИспользованияEmailРассылки() И ЗначениеЗаполнено(АдресЭП);
		
		Если РассылкаНаПочтуРазрешена
			И Не СервисРассылкиВыбран Тогда	
			
			ЭтотОбъект.ОтправитьПоEmail = Истина;
			СервисРассылкиВыбран 	    = Истина;
			
		Иначе	
			
			ЭтотОбъект.ОтправитьПоEmail = Ложь;
			
		КонецЕсли;
		
		Элементы.ГруппаEmail.Видимость = РассылкаНаПочтуРазрешена;
				
		РассылкаНаТелефонРазрешена = ЗначениеЗаполнено(НомерТелефона); //И ПроверитьВозможностьИспользованияSMSРассылки();
		
		Если РассылкаНаТелефонРазрешена 
			И Не СервисРассылкиВыбран Тогда	
			
			ЭтотОбъект.ОтправитьПоSMS = Истина;
			СервисРассылкиВыбран 	  = Истина
			
		Иначе	
			
			ЭтотОбъект.ОтправитьПоSMS = Ложь;	
			
		КонецЕсли;
		
		Элементы.ГруппаSMS.Видимость = РассылкаНаТелефонРазрешена;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, возвращает номера телефонов контрагентов.
//
Функция ПолучитьКонтактныеДанныеКонтрагента(ТипКонтактнойИнформации)
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	&ВыбираемоеПоле КАК Контакт
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтактнаяИнформация.Тип = &ТипКонтактнойИнформации
	|	И НЕ КонтактнаяИнформация.НеУчаствоватьВРассылке");
	
	Запрос.УстановитьПараметр("Контрагент"				, Объект.ВладелецКарты);
	Запрос.УстановитьПараметр("ТипКонтактнойИнформации" , Перечисления.ТипыКонтактнойИнформации[ТипКонтактнойИнформации]);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ВыбираемоеПоле", ?(ТипКонтактнойИнформации = "Телефон", "КонтактнаяИнформация.НомерТелефона", "КонтактнаяИнформация.Представление"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Контакт, Неопределено);
	
КонецФункции

// Функция, проверяет возможность использования eamil рассылки.
//
Функция ПроверитьВозможностьИспользованияEmailРассылки()
		
	УчетныеЗаписиСуществуют = Справочники.УчетныеЗаписиЭлектроннойПочты.СуществуютУчетныеЗаписиЭлектроннойПочтыОбщиеИЛичные(ПараметрыСеанса.ТекущийПользователь, Ложь, Истина, Истина);
	
	Возврат УчетныеЗаписиСуществуют;
	
КонецФункции

&НаКлиенте
// Процедура, заополняет сервисы рассылки.
//
Процедура ВладелецКартыПриИзменении(Элемент)
	
	ЗаполнитьСервисыРассылки();
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере".
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если Объект.ТипКода = Перечисления.ВидыКарт.Wallet Тогда
			
		Если ЭтотОбъект.ОтправитьВМессенджер Тогда 
			ОтправитьСсылкуНаУстановкуКартыНаСервере(Объект.ВладелецКарты, 	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница, Объект.Ссылка, "Мессенджер");	
		КонецЕсли;
		
		Если ЭтотОбъект.ОтправитьПоSMS Тогда
			ОтправитьСсылкуНаУстановкуКартыНаСервере(Объект.ВладелецКарты, 	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница, Объект.Ссылка, "SMS");
		КонецЕсли;
		
		Если ЭтотОбъект.ОтправитьПоEmail Тогда
			
			ШаблонСообщения	 = ?(ЗначениеЗаполнено(Объект.Ссылка.ВидКарты.ШаблонСообщения), Объект.Ссылка.ВидКарты.ШаблонСообщения, Справочники.ШаблоныСообщений.СозданиеКарты);
			Содержание = ПреобразоватьСодержаниеСПараметрамиВТекст(ШаблонСообщения, Объект.Ссылка, "Email");
			СоздатьДокументИсходящееПисьмоОтправитьПисьмоНаСервере(Объект.ВладелецКарты, АдресЭП, "Создание карты", Содержание, ШаблонСообщения);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, отправляет ссылку на установку карты.
//
Процедура ОтправитьСсылкуНаУстановкуКартыНаСервере(Получатель, ТекущаяСтруктурнаяЕдиница, Карта, СервисРассылки)
	
	ОписаниеОшибки	 = "";	
	ШаблонСообщения	 = ?(ЗначениеЗаполнено(Карта.ВидКарты.ШаблонСообщения), Карта.ВидКарты.ШаблонСообщения, Справочники.ШаблоныСообщений.СозданиеКарты);
	Содержание		 = ПреобразоватьСодержаниеСПараметрамиВТекст(ШаблонСообщения, Карта, СервисРассылки);
	
	ПолучателиСообщения = Новый Массив();
	ПолучателиСообщения.Добавить(Новый Структура("Получатель", Получатель));
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("Получатели"			, ПолучателиСообщения);
	ПараметрыРассылки.Вставить("Содержание"			, Содержание);
	ПараметрыРассылки.Вставить("ШаблонСообщения"	, ШаблонСообщения);
	ПараметрыРассылки.Вставить("СтруктурнаяЕдиница"	, ТекущаяСтруктурнаяЕдиница);
	
	Если СервисРассылки = "SMS" Тогда
		ПараметрыРассылки.Вставить("ОтправкаSMS", Истина);
	КонецЕсли;
	
	Если СервисРассылки = "Мессенджер" Тогда
		ПараметрыРассылки.Вставить("ОтправкаMessenger"	 , Истина);
		ПараметрыРассылки.Вставить("ИнициироватьОтправку", Истина);
	КонецЕсли;
		
	ПараметрыРассылки.Вставить("ОтправитьНемедленно", Истина);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Документы.РассылкаСообщений.СоздатьДокументРассылкаСообщений(ПараметрыРассылки, ОписаниеОшибки);
	
КонецПроцедуры
 
&НаСервереБезКонтекста
// Функция - Преобразовать содержание с параметрами в текст
// 
Функция ПреобразоватьСодержаниеСПараметрамиВТекст(ШаблонСообщения, Карта, СервисРассылки)
	
	Если СервисРассылки = "SMS" Тогда
		Содержание = ШаблонСообщения.Содержание;
		
	ИначеЕсли СервисРассылки = "Email" Тогда
		Содержание = ШаблонСообщения.ТекстHTML;
		
	ИначеЕсли СервисРассылки = "Мессенджер" Тогда
		Содержание = ШаблонСообщения.СодержаниеМессенджер;
		
	КонецЕсли;

	Возврат Справочники.ШаблоныСообщений.ПреобразоватьСодержаниеСПараметрамиВТекст(Содержание,,,,, Карта); 
	
КонецФункции

// Процедура, создает и отправляет сообщения.
//
Процедура СоздатьДокументSMSPushРассылкаИОтправить(ТипСобытия, Содержание, ВнешняяСистемаМессенджера = Неопределено)
	
	СтруктураПолучателя = Новый Структура("Получатель, НомерТелефона, Карта", Объект.ВладелецКарты);
	СтруктураПолучателя.НомерТелефона = НомерТелефона;	
	
	МассивСтруктурПолучателей = Новый_Массив(СтруктураПолучателя);
	Документы.РассылкаСообщений.СоздатьДокументSMSPushРассылкаИОтправить(МассивСтруктурПолучателей, Содержание,, ТипСобытия, ВнешняяСистемаМессенджера);	
	
КонецПроцедуры

// Функция - Создать документ исходящее письмо отправить письмо на сервере.
//
// Параметры:
//  МассивСтруктурПолучателей	 - 	 -
//  Содержание					 - 	 -
//  Тема						 - 	 -
//  ОписаниеОшибки				 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьДокументИсходящееПисьмоОтправитьПисьмоНаСервере(Контакт, Адрес, Тема, Содержание, ШаблонСообщения)
	
	//МассивСтруктурПолучателей = Новый Массив;
	//МассивСтруктурПолучателей.Добавить(Новый Структура("Контакт, Адрес", Контакт, Адрес));
	
	МассивПолучателей = Новый массив;
	МассивПолучателей.Добавить(Контакт);
	
	МассивEmail = Новый Массив;
	МассивEmail.Добавить(Адрес);
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("Дата"				, ТекущаяДатаСеанса());
	ДанныеЗаполнения.Вставить("Тема"				, Тема);
	ДанныеЗаполнения.Вставить("Тело"				, Содержание);
	ДанныеЗаполнения.Вставить("ТекстHTML"			, Содержание);
	ДанныеЗаполнения.Вставить("МассивПолучателей"	, МассивПолучателей);
	ДанныеЗаполнения.Вставить("МассивEmail"			, МассивEmail);
	ДанныеЗаполнения.Вставить("Тип"					, Перечисления.ТипыСобытий.ВходящееПисьмо); 
	ДанныеЗаполнения.Вставить("АвторДокумента"		, ПараметрыСеанса.ТекущийПользователь);
	ДанныеЗаполнения.Вставить("Ответственный"		, ПараметрыСеанса.ТекущийПользователь);
	ДанныеЗаполнения.Вставить("ТипТекста"			, Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст);
	ДанныеЗаполнения.Вставить("ШаблонСообщения"		, ШаблонСообщения);
	
	УстановитьПривилегированныйРежим(Истина);
	
	ИсходящееЭлектронноеПисьмо = Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
	ИсходящееЭлектронноеПисьмо.Заполнить(ДанныеЗаполнения);
	
	ОписаниеОшибки = "";
	Документы.ЭлектронноеПисьмоИсходящее.ВыполнитьОтправкуПисьма(ИсходящееЭлектронноеПисьмо, ОписаниеОшибки);
	
КонецФункции

