Процедура НастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не Результат = Неопределено Тогда 		
		Объект.ATAMode 			  	= Результат.Объект.ATAMode;	
		Объект.cobMicrophoneDevice	= Результат.Объект.cobMicrophoneDevice;
		Объект.cobSpeakerDevice		= Результат.Объект.cobSpeakerDevice;
		Объект.DisplayName 			= Результат.Объект.DisplayName;
		Объект.DomainServer			= Результат.Объект.DomainServer;
		Объект.MicrophoneMute 		= Результат.Объект.MicrophoneMute;
		Объект.MicrophoneVolume		= Результат.Объект.MicrophoneVolume;
		Объект.OutboundProxy 		= Результат.Объект.OutboundProxy; 
		Объект.RegisterName 		= Результат.Объект.RegisterName;
		Объект.RegisterPassword 	= Результат.Объект.RegisterPassword; 
		Объект.RegistrationRequired = Результат.Объект.RegistrationRequired; 
		Объект.SpeakerMute 			= Результат.Объект.SpeakerMute;
		Объект.SpeakerVolume		= Результат.Объект.SpeakerVolume;
		Объект.STUNserver 			= Результат.Объект.STUNserver;
		Объект.tbRingtoneName 		= Результат.Объект.tbRingtoneName;
		Объект.UserID 				= Результат.Объект.UserID; 
		СоздаватьДокументВзаимодействие = СоздаватьВзаимодействие();
		
		Счетчик = 0;
		Индекс = -1;
		СписокКодеков.Очистить();
		Для Каждого СтрокаТЧ из СофтФон.Codecs Цикл
			Если Счетчик = 0 Тогда                   						
				Индекс = Индекс + 1;
			Иначе
				Если НЕ ?(СтрокаТЧ = "True", Истина, Ложь) Тогда
					СписокКодеков.Добавить(Индекс);
				КонецЕсли;
				Счетчик =  - 1;
			КонецЕсли;
			Счетчик = Счетчик + 1;
		КонецЦикла;
		хИсторияЗвонков.Параметры.УстановитьЗначениеПараметра("ПользовательSip", Объект.RegisterName);
		Элементы.хИсторияЗвонков.Обновить();
		
	Иначе
		Возврат;
	КонецЕсли;
	
	Если  Не СофтФон = Неопределено и СофтФон.LineRegister() Тогда		
		СофтФон.UnregisterLine();
		Счетчик = 0;
		Пока Не СофтФон.LineUnRegister() Цикл
			Счетчик = Счетчик + 1;
		КонецЦикла;			
	КонецЕсли;
	
	Если  Не СофтФон = Неопределено и Не СофтФон.LineRegister() Тогда
		СофтФон.ATAMode				 = Объект.ATAMode;
		СофтФон.UserID				 = Объект.UserID;
		СофтФон.DisplayName 		 = Объект.DisplayName;
		СофтФон.RegisterName		 = Объект.RegisterName;
		СофтФон.DomainServer 		 = Объект.DomainServer;
		СофтФон.RegisterPassword     = Объект.RegisterPassword;
		СофтФон.RegistrationRequired = Объект.RegistrationRequired;
		СофтФон.Start();	
	КонецЕсли;

КонецПроцедуры

