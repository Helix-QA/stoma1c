
#Область СлужебныйПрограммныйИнтерфейс

// Процедура - Перед записью
//
// Параметры:
//  Отказ		 - 	 - 
//  Замещение	 - 	 - 
//
Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ЭтотОбъект.ОбменДанными.Загрузка = Истина Тогда 
		Возврат;
	КонецЕсли;	
	
	Если ЭтотОбъект.Количество() = 0 Тогда
		Возврат;		
	КонецЕсли;
	
	ЭтоСценарийЧатБота = ЭтотОбъект.ДополнительныеСвойства.Свойство("СценарийЧатБота");
	
	Для Каждого Запись Из ЭтотОбъект Цикл
		
		Если ЗначениеЗаполнено(Запись.Окончание) Тогда
			Запись.ОтложенДо					 = Неопределено;
			Запись.ПоследнееСообщениеОтКлиента	 = Ложь;
		КонецЕсли;
		
		Если ЭтоСценарийЧатБота Тогда
			
			// Перехватываем и актуализируем в регистре.
	    	Запись.СценарийЧатБота 		= ?(ЗначениеЗаполнено(Запись.СценарийЧатБота), Запись.СценарийЧатБота, 
											?(ЭтотОбъект.ДополнительныеСвойства.Свойство("СценарийЧатБота"), ЭтотОбъект.ДополнительныеСвойства.СценарийЧатБота, Запись.СценарийЧатБота));
										
			Запись.ИдентификаторЭтапа 	= ?(ЭтотОбъект.ДополнительныеСвойства.Свойство("ИдентификаторТекущегоЭтапа"), ЭтотОбъект.ДополнительныеСвойства.ИдентификаторТекущегоЭтапа, Запись.ИдентификаторЭтапа);
			Запись.ОписаниеЭтапа 		= ?(ЭтотОбъект.ДополнительныеСвойства.Свойство("ОписаниеЭтапа"), ЭтотОбъект.ДополнительныеСвойства.ОписаниеЭтапа, "");
			
		КонецЕсли;
		
	КонецЦикла;	

КонецПроцедуры

// Процедура - При записи
//
// Параметры:
//  Отказ		 - 	 - 
//  Замещение	 - 	 - 
//
Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ЭтотОбъект.ОбменДанными.Загрузка = Истина
		И НЕ ЭтотОбъект.ДополнительныеСвойства.Свойство("ПараметрыРегистрацииТриггера") Тогда 		
		Возврат;
	КонецЕсли;	
	
	Если ЭтотОбъект.Количество() = 0 Тогда
		Возврат;		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект[0].Окончание) Тогда
		РегламентныеЗаданияСерверСтоматология.АктуализироватьЗаданиеОчереди(Метаданные.РегламентныеЗадания.ЗакрытиеНеактивныхДиалогов);
	КонецЕсли;
	
	Если ЭтотОбъект.ДополнительныеСвойства.Свойство("ПараметрыРегистрацииТриггера") Тогда	
		Для Каждого Запись Из ЭтотОбъект Цикл	
			ЭтотОбъект.ДополнительныеСвойства.ПараметрыРегистрацииТриггера.Вставить("ОбъектГенерации", Запись.ИдДиалога);
			РегистрыСведений.ЖурналРегистрацииТриггерныхСобытий.ЗарегистрироватьСобытиеТриггера(ЭтотОбъект.ДополнительныеСвойства.ПараметрыРегистрацииТриггера);
			Прервать;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти