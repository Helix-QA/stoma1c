// Функция -  Получить структурные единицы по кассе
Функция ПолучитьСтруктурныеЕдиницыПоКассе(Касса) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СтруктурныеЕдиницыДоступныеКассы.Ссылка КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА СтруктурныеЕдиницыДоступныеКассы.Ссылка = &ТекущаяСтруктурнаяЕдиница
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Приоритет
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы.ДоступныеКассы КАК СтруктурныеЕдиницыДоступныеКассы
	|ГДЕ
	|	СтруктурныеЕдиницыДоступныеКассы.Касса = &Касса
	|	И СтруктурныеЕдиницыДоступныеКассы.Ссылка.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет УБЫВ");
	
	Запрос.УстановитьПараметр("Касса", Касса);
	Запрос.УстановитьПараметр("ТекущаяСтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");
	
КонецФункции

// Функция - Вструктурной единице выполняются предпродажи на дату
//
// Параметры:
//  СтруктЕдиница	 - 	 - 
//  Дата			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВСтруктурнойЕдиницеВыполняютсяПредпродажиНаДату(СтруктЕдиница, Дата) Экспорт
	
	Возврат СтруктЕдиница.ПредпродажаДоОткрытияКлиники = Истина
	И СтруктЕдиница.ЗапланированнаяДатаОткрытияКлиники > НачалоДня(Дата);
	
КонецФункции

// Функция - Получить интервалы работы структурной единицы.
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьИнтервалыРаботыСтруктурнойЕдиницы(СтруктурнаяЕдиница) Экспорт
	
	МассивИнтерваловРаботы = Новый Массив;
	
	Для Каждого СтрокаТ Из СтруктурнаяЕдиница.РасписаниеРаботы Цикл
		
		// Пропускаем неактивные и праздничные дни.
		Если Не ЗначениеЗаполнено(СтрокаТ.ДеньНедели) Тогда
			Продолжить;
		КонецЕсли;
		
		ИнтервалыРаботы = Новый Массив;
		
		// Если структурная единица работает в этот день.
		Если СтрокаТ.Активность Тогда
			
			ВремяНачала = СтрокаТ.НачалоРаботы; 
			
			Если ВремяНачала > Дата(0001,01,01,00,00,00) Тогда 
				
				ПараметрыПоиска = Новый Структура("ДеньНедели", Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели - 86400)));
				ПредДеньНедели  = СтруктурнаяЕдиница.РасписаниеРаботы.НайтиСтроки(ПараметрыПоиска)[0]; 
				
				Если ПредДеньНедели.Активность И ПредДеньНедели.ОкончаниеРаботы > Дата(0001,01,02,00,00,00) Тогда
					
					// Если интервал пересекается с предыдущим днем.
					Если ВремяНачала = ПредДеньНедели.ОкончаниеРаботы - 86400 Тогда 
						ВремяНачала = Дата(0001,01,01,00,00,00);	
					Иначе
						Интервал = Новый Структура;
						Интервал.Вставить("ВремяНачала"   , Дата(0001,01,01,00,00,00));
						Интервал.Вставить("ВремяОкончания", ПредДеньНедели.ОкончаниеРаботы - 86400);
						
						ИнтервалыРаботы.Добавить(Интервал);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
			Интервал = Новый Структура;
			Интервал.Вставить("ВремяНачала"   , ВремяНачала);
			Интервал.Вставить("ВремяОкончания", ?(СтрокаТ.ОкончаниеРаботы >= Дата(0001,01,02,00,00,00), Дата(0001,01,01,23,59,00), СтрокаТ.ОкончаниеРаботы));
			
			ИнтервалыРаботы.Добавить(Интервал);
			
		// Если не работает - проверяем работу предыдущего дня после 00:00 (полуночи).	
		Иначе
			
			ПараметрыПоиска = Новый Структура("ДеньНедели", Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели - 86400)));
			ПредДеньНедели  = СтруктурнаяЕдиница.РасписаниеРаботы.НайтиСтроки(ПараметрыПоиска)[0]; 
			
			Если ПредДеньНедели.Активность И ПредДеньНедели.ОкончаниеРаботы > Дата(0001,01,02,00,00,00) Тогда
				
				Интервал = Новый Структура;
				Интервал.Вставить("ВремяНачала"   , Дата(0001,01,01,00,00,00));
				Интервал.Вставить("ВремяОкончания", ПредДеньНедели.ОкончаниеРаботы - 86400);
				
				ИнтервалыРаботы.Добавить(Интервал);
			Иначе
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;

		МассивИнтерваловРаботы.Добавить(Новый Структура("ДеньНедели, ИнтервалыРаботы", ДеньНедели(СтрокаТ.ДеньНедели), ИнтервалыРаботы));
		
	КонецЦикла;
	
	Возврат МассивИнтерваловРаботы;
	
КонецФункции	

// Функция - Получить интервалы работы структурной единицы на дату.
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  ДатаВремя			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьИнтервалыРаботыСтруктурнойЕдиницыНаДату(СтруктурнаяЕдиница, ДатаВремя) Экспорт
	
	СтрокиРасписанияРаботы = СтруктурнаяЕдиница.РасписаниеРаботы.НайтиСтроки(Новый Структура("ДеньНедели", Дата(2001, 01, ДеньНедели(ДатаВремя))));
	СтрокаРасписанияРаботы = ?(ЗначениеЗаполнено(СтрокиРасписанияРаботы), СтрокиРасписанияРаботы[0], Неопределено);
	
	Если Не ЗначениеЗаполнено(СтрокаРасписанияРаботы) Тогда
		Возврат Неопределено;	
	КонецЕсли;
	
	ИнтервалыРаботы = Новый Массив;
	
	// Если структурная единица работает в этот день.
	Если СтрокаРасписанияРаботы.Активность Тогда
		
		ВремяНачала = СтрокаРасписанияРаботы.НачалоРаботы;
		
		Если ВремяНачала > Дата(0001,01,01,00,00,00) Тогда 
			
			ПараметрыПоиска = Новый Структура("ДеньНедели", Дата(2001, 01, ДеньНедели(ДатаВремя - 86400)));
			ПредДеньНедели  = СтруктурнаяЕдиница.РасписаниеРаботы.НайтиСтроки(ПараметрыПоиска)[0]; 
			
			Если ПредДеньНедели.Активность И ПредДеньНедели.ОкончаниеРаботы > Дата(0001,01,02,00,00,00) Тогда
				
				// Если интервал пересекается с предыдущим днем.
				Если ВремяНачала = ПредДеньНедели.ОкончаниеРаботы - 86400 Тогда 
					ВремяНачала = Дата(0001,01,01,00,00,00);
				Иначе
					Интервал = Новый Структура;
					Интервал.Вставить("ВремяНачала"   , Дата(0001,01,01,00,00,00));
					Интервал.Вставить("ВремяОкончания", ПредДеньНедели.ОкончаниеРаботы - 86400);
					
					ИнтервалыРаботы.Добавить(Интервал);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Интервал = Новый Структура;
		Интервал.Вставить("ВремяНачала"   , ВремяНачала);
		Интервал.Вставить("ВремяОкончания", ?(СтрокаРасписанияРаботы.ОкончаниеРаботы >= Дата(0001,01,02,00,00,00), Дата(0001,01,01,23,59,00), СтрокаРасписанияРаботы.ОкончаниеРаботы));
		
		ИнтервалыРаботы.Добавить(Интервал);
		
	// Если не работает - проверяем работу предыдущего дня после 00:00 (полуночи).	
	Иначе
		ПараметрыПоиска = Новый Структура("ДеньНедели", Дата(2001, 01, ДеньНедели(ДатаВремя - 86400)));
		ПредДеньНедели  = СтруктурнаяЕдиница.РасписаниеРаботы.НайтиСтроки(ПараметрыПоиска)[0]; 
		
		Если Не (ПредДеньНедели.Активность И ПредДеньНедели.ОкончаниеРаботы > Дата(0001,01,02,00,00,00)) Тогда
			Возврат Неопределено;	
		КонецЕсли;	
		
		Интервал = Новый Структура;
		Интервал.Вставить("ВремяНачала"   , Дата(0001,01,01,00,00,00));
		Интервал.Вставить("ВремяОкончания", ПредДеньНедели.ОкончаниеРаботы - 86400);
		
		ИнтервалыРаботы.Добавить(Интервал);
		
	КонецЕсли;
	
	Возврат ИнтервалыРаботы;
	
КонецФункции	

// Функция - Получить макс интервалы работы структурной единицы.
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМаксИнтервалыРаботыСтруктурнойЕдиницы(СтруктурнаяЕдиница) Экспорт
	
	ИнтервалыРаботы = Новый Массив;
	
	МинВремяНачала     = Неопределено;
	МаксВремяОкончания = Неопределено;
	
	Для Каждого СтрокаТ Из СтруктурнаяЕдиница.РасписаниеРаботы Цикл
		
		// Пропускаем неактивные и праздничные дни.
		Если Не (СтрокаТ.Активность И ЗначениеЗаполнено(СтрокаТ.ДеньНедели)) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(МинВремяНачала) Тогда
			МинВремяНачала = ?(СтрокаТ.НачалоРаботы < МинВремяНачала, СтрокаТ.НачалоРаботы, МинВремяНачала);
		Иначе
			МинВремяНачала = СтрокаТ.НачалоРаботы;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(МаксВремяОкончания) Тогда
			МаксВремяОкончания = ?(СтрокаТ.ОкончаниеРаботы > МаксВремяОкончания, СтрокаТ.ОкончаниеРаботы, МаксВремяОкончания);
		Иначе
			МаксВремяОкончания = СтрокаТ.ОкончаниеРаботы;
		КонецЕсли;
		
	КонецЦикла;
	
	МинВремяНачала     = ?(ЗначениеЗаполнено(МинВремяНачала), МинВремяНачала, Дата(0001,01,01,00,00,00));
	МаксВремяОкончания = ?(ЗначениеЗаполнено(МаксВремяОкончания), МаксВремяОкончания, Дата(0001,01,01,23,59,00));
	
	// Если структурная единица работает после 00:00 (полуночи).
	Если МаксВремяОкончания > Дата(0001,01,02,00,00,00) 
		И МинВремяНачала > Дата(0001,01,01,00,00,00) Тогда
		
		Если МинВремяНачала <= МаксВремяОкончания - 86400 Тогда
			МинВремяНачала = Дата(0001,01,01,00,00,00);
		Иначе
			Интервал = Новый Структура;
			Интервал.Вставить("ВремяНачала"   , Дата(0001,01,01,00,00,00));
			Интервал.Вставить("ВремяОкончания", МаксВремяОкончания - 86400);
			
			ИнтервалыРаботы.Добавить(Интервал);
		КонецЕсли;
		
		МаксВремяОкончания = Дата(0001,01,01,23,59,00);
		
	КонецЕсли;
	
	Интервал = Новый Структура;
	Интервал.Вставить("ВремяНачала"   , МинВремяНачала);
	Интервал.Вставить("ВремяОкончания", ?(МаксВремяОкончания >= Дата(0001,01,02,00,00,00), Дата(0001,01,01,23,59,00), МаксВремяОкончания));
	
	ИнтервалыРаботы.Добавить(Интервал);
	
	Возврат ИнтервалыРаботы;
	
КонецФункции

// Функция вернет массив рабочих дней недели СЕ, если выставлен флаг ДобавитьВремяРаботы
// будет возвращен массив структур с рабочим временем
Функция РабочиеДниСтруктурнойЕдиницы(СтруктурнаяЕдиница, ДобавитьВремяРаботы = Истина, ОбработатьДатуОкончания = Ложь) Экспорт
	
	РасписаниеРаботы = ПолучитьРасписаниеРаботы(СтруктурнаяЕдиница);
	
	РабочиеДни = Новый Массив;
	Индекс = 0;
	Для Каждого СтрокаТ ИЗ РасписаниеРаботы Цикл
		
		Если СтрокаТ.Активность = Истина Тогда
			
			Если ДобавитьВремяРаботы = Истина Тогда
				
				ДатаОкончанияРаботы = СтрокаТ.ОкончаниеРаботы;
				Если ОбработатьДатуОкончания = Истина И НЕ ЗначениеЗаполнено(ДатаОкончанияРаботы) Тогда
					ДатаОкончанияРаботы = Дата('0001010123:59:59')
				КонецЕсли;
				
				РабочиеДни.Добавить(Новый Структура("ДеньНедели,ДатаНачала,ДатаОкончания", Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели)), СтрокаТ.НачалоРаботы, ДатаОкончанияРаботы));
			Иначе
				РабочиеДни.Добавить(Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели)));
			КонецЕсли;
			
		КонецЕсли;
		
		Индекс = Индекс + 1;
				
	КонецЦикла;	  
	
	Возврат РабочиеДни;
	
КонецФункции

// Функция - Получить адрес структурной единицы
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  ВидАдреса			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАдресСтруктурнойЕдиницы(СтруктурнаяЕдиница, ВидАдреса = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидАдреса) Тогда 
		ВидАдреса = Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СтруктурныеЕдиницыКонтактнаяИнформация.Представление КАК Адрес
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы.КонтактнаяИнформация КАК СтруктурныеЕдиницыКонтактнаяИнформация
	|ГДЕ
	|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка = &СтруктурнаяЕдиница
	|	И СтруктурныеЕдиницыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	|	И СтруктурныеЕдиницыКонтактнаяИнформация.Вид = &ВидыКонтактнойИнформации
	|	И (ВЫРАЗИТЬ(СтруктурныеЕдиницыКонтактнаяИнформация.Представление КАК СТРОКА(1024))) <> """"";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);    
	Запрос.УстановитьПараметр("ВидыКонтактнойИнформации", ВидАдреса);    
	
	ВыборкаАдреса = Запрос.Выполнить().Выбрать();
	Если ВыборкаАдреса.Следующий() Тогда 
		Возврат СокрЛП(ВыборкаАдреса.Адрес);
	Иначе 
	   	Возврат Null;
	КонецЕсли;
	
КонецФункции

