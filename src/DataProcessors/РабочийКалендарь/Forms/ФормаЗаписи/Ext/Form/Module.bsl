// Процедура - Легенда цвета нажатие завершение
//
// Параметры:
//  Цвет					 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЛегендаЦветаНажатиеЗавершение(Цвет, ДополнительныеПараметры) Экспорт
	
	ЛегендаЭлемент = ДополнительныеПараметры.ЛегендаЭлемент;

	Если (Цвет <> Неопределено) = Истина Тогда
		ЛегендаЭлемент.ЦветФона = Цвет;
		НаименованиеСтатуса     = Элементы.Найти(ЛегендаЭлемент.Заголовок).Заголовок;
		ОбщегоНазначенияСтоматология.УстановитьЦветФонаСобытия(ПолучитьСтатусСобытияПоНаименованию(НаименованиеСтатуса), , Цвет);
		ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция формирует и возвращает ФИО врача
//
Функция ВернутьФИОВрача(ВрачСсылка)
	
	ФИОВрача = "";
	Если ТипЗнч(ВрачСсылка) = Тип("СправочникСсылка.Сотрудники")
		и ВрачСсылка.ЭтоГруппа = Ложь 
		и ЗначениеЗаполнено(ВрачСсылка.Фамилия) Тогда 
		ФИОВрача = СокрЛП(ВрачСсылка.Фамилия);
		Если ЗначениеЗаполнено(ВрачСсылка.Имя) Тогда 
			ФИОВрача = ФИОВрача + Символы.НПП + ВРег(Лев(ВрачСсылка.Имя, 1)) + ".";
			Если ЗначениеЗаполнено(ВрачСсылка.Отчество) Тогда
				ФИОВрача = ФИОВрача + Символы.НПП + ВРег(Лев(ВрачСсылка.Отчество, 1)) + ".";
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат ФИОВрача;
	
КонецФункции

&НаКлиенте
// Процедура - Используется для выполнения обработчика снятия пометки выделения занятия.
//
Процедура Подключаемый_СнятьУстановитьПометкуВыделенияСотрудника()
	
	ОбластиСотрудников = ЭтотОбъект.ТабличныйДокументОбластиСотрудников; 
	
	Если Не ЗначениеЗаполнено(ОбластиСотрудников) Тогда 
		Возврат;	
	КонецЕсли;	
	
	Для Каждого ЭлементМ Из ОбластиСотрудников Цикл
		
		// Получаем область сотрудника.
		Попытка
			
			ОбластьСотрудника = ТабличныйДокумент.Область(ЭлементМ.Область);	
			ЭлементМ.Пометка  = Не ЭлементМ.Пометка;
			
			ЛинияГраницы = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, ?(ЭлементМ.Пометка, 2, 1));
			
			ОбластьСотрудника.ГраницаСверху = ЛинияГраницы;
			ОбластьСотрудника.ГраницаСнизу  = ЛинияГраницы;
			ОбластьСотрудника.ГраницаСлева  = ЛинияГраницы;
			ОбластьСотрудника.ГраницаСправа = ЛинияГраницы;	
			ОбластьСотрудника.ЦветРамки     = ?(ЭлементМ.Пометка, WebЦвета.Красный, Новый Цвет());			
			
		Исключение
		КонецПопытки; 
		
	КонецЦикла;
		
КонецПроцедуры

