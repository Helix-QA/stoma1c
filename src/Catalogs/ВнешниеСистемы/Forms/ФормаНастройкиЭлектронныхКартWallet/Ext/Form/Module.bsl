// Процедура, открывает редактор карт.
//
Процедура РедактироватьВидКартыОбработка(ИмяЭлемента, ИдПроекта = Неопределено)
	
	Если ИдПроекта = Неопределено И Не СтрНайти(ИмяЭлемента, "РедактироватьВидКарты_") Тогда
		Возврат;  
	КонецЕсли;
	
	ИдПроекта       = ?(ЗначениеЗаполнено(ИдПроекта), ИдПроекта, СтрЗаменить(ТекущийЭлемент.Имя, "РедактироватьВидКарты_", ""));
	АктивныйЭлемент = Элементы["ГруппаВидКарты_" + ИдПроекта];
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент, ?(АктивныйЭлемент = НеАктивныйЭлемент, Неопределено, НеАктивныйЭлемент),, ЭтаФорма, Элементы.РедакторКарты);  
	
	НеАктивныйЭлемент = АктивныйЭлемент;
	
	РедакторКарты = СтрШаблон("https://webcitrus.app/tools/%1/pass-designer/%2?client_secret=%3&1c", Объект.ТокенДоступа, ИдПроекта, Объект.КлючШифрования);
	
КонецПроцедуры

