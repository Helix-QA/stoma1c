			Элементы._ГруппаНаборПокупкиДляПолученияПодарков.Видимость = Истина;
			// ПроцедураОбработкиНажатияМенюНаСервере(Элементы["_ГруппаНаборПокупкиДляПолученияПодарков"]);		
