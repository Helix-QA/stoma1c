
#Область ________________________________ОБРАБОТЧИКИ_СОБЫТИЙ_ФОРМЫ___________________________________

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ТипКанала"					, ТипКанала);		
	Параметры.Свойство("ИдентификаторДействия"		, ИдентификаторДействия);	
	Параметры.Свойство("ТекущаяСтруктурнаяЕдиница"	, ТекущаяСтруктурнаяЕдиница);
	Параметры.Свойство("ПараметрыДействия"			, ПараметрыДействия);
	Если Параметры.Свойство("МоделируемыеНастройкиКаналовУведомлений") Тогда 
		МоделируемыеНастройкиКаналовУведомлений.Загрузить(ПреобразоватьМассивСтруктурВТаблицуЗначений(Параметры.МоделируемыеНастройкиКаналовУведомлений));
	КонецЕсли;	
	Если Параметры.Свойство("ТаблицаВнешнихСистем") Тогда 
		ТаблицаВнешнихСистем.Загрузить(ПреобразоватьМассивСтруктурВТаблицуЗначений(Параметры.ТаблицаВнешнихСистем));
	КонецЕсли;	
	
	Элементы.ГруппаДляПолученияИнтервала_Шаблон_.ВертикальныйИнтервал = ?(МоделируемыеНастройкиКаналовУведомлений.НайтиСтроки(Новый Структура("ИдентификаторДействия", ИдентификаторДействия)).Количество() > 9, ИнтервалМеждуЭлементамиФормы.Половинный, ИнтервалМеждуЭлементамиФормы.Одинарный);
	
	// Определяем родительские группы
	ГруппаРазмещенияНастроек		= Элементы.Найти("ГруппаНастройкиКаналовУведомлений");
	ГруппаРазмещенияНастроекШаблон 	= Элементы.Найти("ГруппаНастройкиКаналовУведомлений_Шаблон_");
	
	// Обновим текущие настройки
	Если НЕ ГруппаРазмещенияНастроек = Неопределено Тогда 
		// Очищаем родительские группы					
		ТриггерныеСобытия.УдалитьЭлементыГруппы(ЭтотОбъект, ГруппаРазмещенияНастроек);
		// Создаем элементы
		ТриггерныеСобытия.ОбновитьЭлементыНастроекКаналовУведомленийНаФормеСогласноШаблона(ЭтотОбъект, ГруппаРазмещенияНастроек, ГруппаРазмещенияНастроекШаблон);
		// Отключаем видимость у шаблона
		ГруппаРазмещенияНастроекШаблон.Видимость = Ложь;
		//Форма.УстановитьСвойстваЭлементамДействий();
	КонецЕсли;
	
	Если ТипКанала = "Push" Тогда 
		ЭтаФорма.Заголовок = Нстр("ru = 'Настройки Push уведомлений'; en = 'Push Notification Settings'");
	ИначеЕсли ТипКанала = "PushWallet" Тогда 
		ЭтаФорма.Заголовок = Нстр("ru = 'Настройки Push (Wallet) уведомлений'; en = 'Push (Wallet) Notification Settings'");	
	ИначеЕсли ТипКанала = "Messenger" Тогда 
		ЭтаФорма.Заголовок = Нстр("ru = 'Настройки уведомлений в мессенджер'; en = 'Notification settings in Messenger'");	
	ИначеЕсли ТипКанала = "SMS" Тогда 
		ЭтаФорма.Заголовок = Нстр("ru = 'Настройки уведомлений по SMS'; en = 'SMS Notification Settings'");			
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти

#Область ________________________________ОБРАБОТЧИКИ_КОМАНД_ФОРМЫ____________________________________

&НаКлиенте
// Процедура - Применить настройки каналов уведомлений
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПрименитьНастройкиКаналовУведомлений(Команда)
	
	СтруктураНастроек = Новый Структура();
	СтруктураНастроек.Вставить("ТипКанала"									, ТипКанала);
	СтруктураНастроек.Вставить("ИдентификаторДействия"						, ИдентификаторДействия);
	СтруктураНастроек.Вставить("МоделируемыеНастройкиКаналовУведомлений"	, ТаблицуЗначенийВМассивСтруктур(МоделируемыеНастройкиКаналовУведомлений, ИменаКолонокМоделируемойТаблицы()));
	
	Закрыть(СтруктураНастроек);
	
КонецПроцедуры

#КонецОбласти

#Область ____________________________ОБРАБОТКА_СОБЫТИЙ_ЭЛЕМЕНТОВ_ФОРМЫ_______________________________

&НаКлиенте
// Процедура - Подключаемый отправка push поле при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ОтправкаPush_Поле_ПриИзменении(Элемент)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Элемент, , "МоделируемыеНастройкиКаналовУведомлений");
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		УстановитьСвойстваЭлементамАккаунтаСообщения(, СтруктураДанныеЭлемента.ИндексСтроки);
		ЭлементФормы = Элементы.Найти("ОтправкаPush_Индекс_" + Строка(СтруктураДанныеЭлемента.ИндексСтроки + 1));
		Если НЕ ЭлементФормы = Неопределено Тогда 			
			ЭтаФорма.ТекущийЭлемент = ЭлементФормы;		
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

