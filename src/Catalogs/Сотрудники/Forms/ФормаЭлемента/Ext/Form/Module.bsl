// Процедура - Заполнить журналы приемов сотрудника.
//
Процедура ЗаполнитьДоступныеКассыСотрудника(ПриЗапуске = Истина)
				
	МассивВыбранныхСтруктурныхЕдиниц = Новый Массив;
	Для Каждого СтрокаТЧ Из ДоступныеСтруктурныеЕдиницы Цикл 
		МассивВыбранныхСтруктурныхЕдиниц.Добавить(СтрокаТЧ.СтруктурнаяЕдиница);
	КонецЦикла;
	
	Если ПриЗапуске = Истина Тогда 
		
		ДоступныеКассы.Очистить();
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СотрудникиДоступныеКассы.Касса КАК Касса,
		|	СотрудникиДоступныеКассы.Основная КАК Основная,
		|	Кассы.ПометкаУдаления КАК ПометкаУдаления
		|ИЗ
		|	Справочник.Сотрудники.ДоступныеКассы КАК СотрудникиДоступныеКассы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Кассы КАК Кассы
		|		ПО СотрудникиДоступныеКассы.Касса = Кассы.Ссылка
		|ГДЕ
		|	СотрудникиДоступныеКассы.Ссылка = &ТекущийСотрудник
		|	И СотрудникиДоступныеКассы.Касса.СтруктурнаяЕдиница В(&СтруктурныеЕдиницы)
		|	И Кассы.ТипКассы = ЗНАЧЕНИЕ(Перечисление.ТипыКасс.ОперационнаяКасса)";
		
		Запрос.УстановитьПараметр("ТекущийСотрудник"  , Объект.Ссылка);
		Запрос.УстановитьПараметр("СтруктурныеЕдиницы", МассивВыбранныхСтруктурныхЕдиниц);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = ДоступныеКассы.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка); 
		КонецЦикла;
		
	Иначе		
		
		МассивВыбранныхКасс = Новый Массив;
		Для Каждого СтрокаТЧ Из ДоступныеКассы Цикл 
			МассивВыбранныхКасс.Добавить(СтрокаТЧ.Касса);
		КонецЦикла;
		
		Для Каждого СтрокаМ Из МассивВыбранныхКасс Цикл 
			СтруктуркаКассы = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаМ, "СтруктурнаяЕдиница");
			
			Если МассивВыбранныхСтруктурныхЕдиниц.Найти(СтруктуркаКассы) = Неопределено Тогда
				МассивНайтденыхСтрок = ДоступныеКассы.НайтиСтроки(Новый Структура("Касса", СтрокаМ));
				
				Если МассивНайтденыхСтрок.Количество() > 0 Тогда
					ДоступныеКассы.Удалить(ДоступныеКассы.Индекс(МассивНайтденыхСтрок[0]));
				КонецЕсли;
			
			КонецЕсли;
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура -  обновляет подбор доступных журналов приемов сотрудника.
//
Процедура ОбновитьДоступныеКассыСотрудника()
	
	ОбработкаТабличныхЧастейКлиент.УстановитьФлагиНаСтруктурныеЕдиницы(ЭтаФорма, "ПодборДоступныеКассы");
	
	ТекущиеДанные = Элементы.ПодборДоступныеКассы.ТекущиеДанные;
	
	Если ТекущиеДанные.Выгружать = 1 И ДоступныеКассы.НайтиСтроки(
		Новый Структура("Касса", ТекущиеДанные.Касса)).Количество() = 0 Тогда
		
		СтрокаТЧ 	   = ДоступныеКассы.Вставить(0);
		СтрокаТЧ.Касса = ТекущиеДанные.Касса;
		
		Если ТекущиеДанные.ИндКартинки = 3 Тогда
			СтрокаТЧ.ПометкаУдаления = Истина;
		КонецЕсли;
		
	ИначеЕсли ТекущиеДанные.Выгружать = 0 Тогда
		
		КассыНаУдаление = ДоступныеКассы.НайтиСтроки(Новый Структура("Касса", ТекущиеДанные.Касса));
		
		Для каждого Касса из КассыНаУдаление Цикл 
			ДоступныеКассы.Удалить(Касса);
		КонецЦикла;
		
	КонецЕсли;
	
	ЗаполнитьОсновнуюКассу();
	
	ОбновитьЭлементыГруппы("ГруппаДоступныеКассыВыбранные");
		
КонецПроцедуры

&НаСервере
// Процедура, обновляет динамические элементы группы.
// 
Процедура ОбновитьЭлементыГруппы(ИмяРодительскойГруппы)
	
	ОчиститьГруппуОтСозданныхЭлементов(ИмяРодительскойГруппы);
	
	ГруппаРодитель = Элементы.Найти(ИмяРодительскойГруппы);
	Если ГруппаРодитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Устанавливает режим для отображения стр. единиц, которые не доступны пользователю.
  	УстановитьПривилегированныйРежим(Истина);
	
	Если ИмяРодительскойГруппы = "ГруппаМестаРаботыВыбранные" Тогда 		
		
		ИндексТекущейКлиники = Неопределено;
		
		Для Каждого СтрокаТЧ Из ЭтотОбъект.ДоступныеСтруктурныеЕдиницы Цикл								
			
			ИндексСтроки = ЭтотОбъект.ДоступныеСтруктурныеЕдиницы.Индекс(СтрокаТЧ);
			
			ГруппаМестоРаботы = СоздатьГруппу("ГруппаМестоРаботыВыбранные_" + ИндексСтроки, ГруппаРодитель);
			
			СоздатьДекорациюЗаглушку("МестоРаботыЗаглушка_" + ИндексСтроки, ГруппаМестоРаботы);
			СоздатьДекорациюПредставление("МестоРаботыВыбранные_" + ИндексСтроки, ГруппаМестоРаботы, 
			Строка(СтрокаТЧ.СтруктурнаяЕдиница), СтрокаТЧ.ПометкаУдаления);
			
			ИндексТекущейКлиники = ?(ЭтотОбъект.ТекущаяСтруктурнаяЕдиница = СтрокаТЧ.СтруктурнаяЕдиница, ИндексСтроки, ИндексТекущейКлиники);

		КонецЦикла;
		
		Если НЕ ИндексТекущейКлиники = Неопределено Тогда 
			ЭлементЗаглушка = Элементы.Найти("МестоРаботыЗаглушка_" + ИндексТекущейКлиники);
			Если НЕ ЭлементЗаглушка = Неопределено Тогда
				ЭлементЗаглушка.Вид = ВидДекорацииФормы.Картинка;
				ЭлементЗаглушка.Картинка = БиблиотекаКартинок.СменаКлиникиСписок;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ИмяРодительскойГруппы = "ГруппаЖурналыПриемовВыбранные" Тогда 		
		
		Для Каждого СтрокаТЧ Из ЭтотОбъект.ДоступныеЖурналыПриемов Цикл								
			
			ИндексСтроки = ЭтотОбъект.ДоступныеЖурналыПриемов.Индекс(СтрокаТЧ);
			
			ГруппаДоступныйЖурналПриемов = СоздатьГруппу("ГруппаДоступныйЖурналПриемов_" + ИндексСтроки, ГруппаРодитель);
			
			СоздатьДекорациюЗаглушку("ЖурналПриемовЗаглушка_" + ИндексСтроки, ГруппаДоступныйЖурналПриемов);
			СоздатьДекорациюПредставление("ЖурналыПриемовВыбранные_" + ИндексСтроки, ГруппаДоступныйЖурналПриемов, 
			Строка(СтрокаТЧ.СтруктурнаяЕдиница), СтрокаТЧ.ПометкаУдаления);
			
		КонецЦикла;
		
	ИначеЕсли ИмяРодительскойГруппы = "ГруппаДоступныеКассыВыбранные" Тогда 		
		
		Для Каждого СтрокаТЧ Из ЭтотОбъект.ДоступныеКассы Цикл								
			
			ИндексСтроки = ЭтотОбъект.ДоступныеКассы.Индекс(СтрокаТЧ);
			
			СоздатьГруппаДоступныеКассы = СоздатьГруппу("ГруппаДостпнаяКасса_" + ИндексСтроки, ГруппаРодитель);
			
			СоздатьДекорациюЗаглушку("ДоступнаяКасса_" + ИндексСтроки, СоздатьГруппаДоступныеКассы); 
			
			ПредставлениеКассы = ?(СтрокаТЧ.Основная, Строка(СтрокаТЧ.Касса) + " (Основная)", Строка(СтрокаТЧ.Касса));  
			СоздатьДекорациюПредставление("ДоступнаяКассаВыбранные_" + ИндексСтроки, 
			СоздатьГруппаДоступныеКассы, ПредставлениеКассы, СтрокаТЧ.ПометкаУдаления);
			
		КонецЦикла;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&НаСервере
// Процедура, очищает группу от динамических элементов.
// 
Процедура ОчиститьГруппуОтСозданныхЭлементов(Знач ЭлементРодитель)
	
	УдаляемыеЭлементы = Новый Массив;		
	Для Каждого ГруппаЭлементов Из Элементы[ЭлементРодитель].ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Если УдаляемыйЭлемент.Имя <> "ГруппаНастройка_Шаблон" Тогда 
			Элементы.Удалить(УдаляемыйЭлемент);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
// Процедура, создаёт группу.
// 
Функция СоздатьГруппу(Наименование, ГруппаРодитель)
	
	ГруппаДоступнойКассы = Элементы.Добавить(Наименование, Тип("ГруппаФормы"), ГруппаРодитель);
	ГруппаДоступнойКассы.Вид 					  = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаДоступнойКассы.Заголовок 				  = ГруппаДоступнойКассы.Имя;
	ГруппаДоступнойКассы.Отображение 			  = ОтображениеОбычнойГруппы.Нет;
	ГруппаДоступнойКассы.Группировка 			  = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	ГруппаДоступнойКассы.ОтображатьЗаголовок 	  = Ложь;	
	ГруппаДоступнойКассы.Ширина 				  = 45;
	ГруппаДоступнойКассы.РастягиватьПоГоризонтали = Ложь;
	
	Возврат ГруппаДоступнойКассы;
	
КонецФункции

&НаСервере
// Процедура, создаёт декорацию заглушку.
// 
Процедура СоздатьДекорациюЗаглушку(Наименование, ГруппаРодитель)
	
	ДекорацияФормы_Заглушка = Элементы.Добавить(Наименование, Тип("ДекорацияФормы"), ГруппаРодитель);
	ДекорацияФормы_Заглушка.Вид 						= ВидДекорацииФормы.Надпись;
	ДекорацияФормы_Заглушка.Заголовок 					= "";
	ДекорацияФормы_Заглушка.Гиперссылка 				= Истина;
	ДекорацияФормы_Заглушка.ЦветТекста 					= Новый Цвет(51, 51, 51);
	ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина    	= Ложь;
	ДекорацияФормы_Заглушка.Ширина 						= 5;
	ДекорацияФормы_Заглушка.МаксимальнаяШирина       	= 5;
	ДекорацияФормы_Заглушка.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
	ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали  	= Истина;
	ДекорацияФормы_Заглушка.Гиперссылка				  	= Ложь;
	
КонецПроцедуры

&НаСервере
// Процедура, создаёт декорацию представление.
// 
Процедура СоздатьДекорациюПредставление(Наименование, ГруппаРодитель, Заголовок, ПометкаУдаления = Ложь, ОсновнаяКасса = Ложь)
	
	ДекорацияФормы_Представление = Элементы.Добавить(Наименование, Тип("ДекорацияФормы"), ГруппаРодитель);
	ДекорацияФормы_Представление.Вид 						= ВидДекорацииФормы.Надпись;
	ДекорацияФормы_Представление.Заголовок                  = ?(ПометкаУдаления,
																Заголовок + " (удалена)",
																Заголовок);
	ДекорацияФормы_Представление.Гиперссылка 				= Истина;
	ДекорацияФормы_Представление.ЦветТекста 				= ?(ПометкаУдаления, 
																ЦветаСтиля.ЦветТекстаТребуетВниманияМДЛП, 
																Новый Цвет(51, 51, 51));
	ДекорацияФормы_Представление.АвтоМаксимальнаяШирина    	= Ложь;
	ДекорацияФормы_Представление.Ширина 					= 40;
	ДекорацияФормы_Представление.МаксимальнаяШирина        	= 40;
	ДекорацияФормы_Представление.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
	ДекорацияФормы_Представление.РастягиватьПоГоризонтали  	= Истина;
	
	ДекорацияФормы_Представление.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_Представление_Нажатие");
	                                                               
КонецПроцедуры

