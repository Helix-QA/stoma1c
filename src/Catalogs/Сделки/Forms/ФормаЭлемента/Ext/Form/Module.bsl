// Процедура, обновляет текущего клиента или создает нового.
//
Процедура ОбновитьДанныеКлиента(ТекущийОбъект)
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Контрагент) Тогда
		ОбъектКонтрагент = ТекущийОбъект.Контрагент.ПолучитьОбъект();
	Иначе
		
		// Создаем нового клиента
		ОбъектКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
		
		ДанныеЗаполнения = Новый Структура();
		ДанныеЗаполнения.Вставить("СтруктураФИО", Справочники.Контрагенты.ФамилияИмяОтчество(ПолучитьПолноеФИООбъекта(ЭтотОбъект)));
		
		ОбъектКонтрагент.Заполнить(ДанныеЗаполнения);
		
	КонецЕсли;
	
	Для Каждого СтрокаТЗ Из ЭтотОбъект.ОбновляемыеДанные Цикл
		
		Если СтрокаТЗ.ОбъектОбновления = "ФИО" Тогда
			
			ОбъектКонтрагент.ДополнительныеСвойства.Вставить("МодифицироватьНаименованиеКонтрагента");
			
			ОбъектКонтрагент.Фамилия  = ЭтотОбъект.Фамилия;
			ОбъектКонтрагент.Имя 	  = ЭтотОбъект.Имя;
			ОбъектКонтрагент.Отчество = ЭтотОбъект.Отчество;	
			
		КонецЕсли;
		
		Если СтрокаТЗ.ОбъектОбновления = "КонтактнаяИнформация" Тогда
			
			// КонтактнаяИнформация
			УправлениеКонтактнойИнформациейСтоматология.ПередЗаписьюНаСервере(ЭтотОбъект, ОбъектКонтрагент);
			// Конец КонтактнаяИнформация
	
			ОбъектКонтрагент.ДополнительныеСвойства.Вставить("КонтактнаяИнформацияПоменялась", Истина);
			// ОбъектКонтрагент.КонтактнаяИнформация.Очистить();
			// ОбъектКонтрагент.КонтактнаяИнформация.Загрузить(ЭтотОбъект.КонтактнаяИнформация.Выгрузить());
			
		КонецЕсли;
		
	КонецЦикла;
	
	Попытка
		ОбъектКонтрагент.Записать();	
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось записать клиента'; en = 'Failed to record client'") + ОписаниеОшибки());		
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ТекущийОбъект.Контрагент) Тогда
		
		ТекущийОбъект.Контрагент = ОбъектКонтрагент.Ссылка;	
		
		СтатусыКонтрагентовМенеджерЗаписи            			= РегистрыСведений.СтатусыКонтрагентов.СоздатьМенеджерЗаписи();
		СтатусыКонтрагентовМенеджерЗаписи.Период     			= ТекущаяДатаСеанса();	
		СтатусыКонтрагентовМенеджерЗаписи.Контрагент 			= ТекущийОбъект.Контрагент;
		СтатусыКонтрагентовМенеджерЗаписи.Статус     			= Перечисления.СтатусыКонтрагентов.Потенциальный;
		СтатусыКонтрагентовМенеджерЗаписи.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

