		<field xsi:type="DataSetFieldField">
			<dataPath>Минуты</dataPath>
			<field>Минуты</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.СтруктурнаяЕдиница, РабочееВремяСотрудников_ФАКТ.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиница,
	ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.Сотрудник, РабочееВремяСотрудников_ФАКТ.Сотрудник) КАК Сотрудник,
	ЕСТЬNULL(НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН, ГОД), НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ, ГОД)) КАК Год,
	ЕСТЬNULL(НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН, МЕСЯЦ), НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ, МЕСЯЦ)) КАК Месяц,
	ЕСТЬNULL(НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН, ДЕНЬ), НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ, ДЕНЬ)) КАК День,
	СУММА(ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.Минуты, 0) / 60) КАК ПЛАН_КоличествоЧасов,
	СУММА(ЕСТЬNULL(РабочееВремяСотрудников_ФАКТ.Часов, 0)) КАК ФАКТ_КоличествоЧасов,
	СУММА(ЕСТЬNULL(РабочееВремяСотрудников_ФАКТ.Дней, 0)) КАК ФАТК_КоличествоДней,
	СУММА(ЕСТЬNULL(ВЫРАЗИТЬ(РабочееВремяСотрудников_ПЛАН.Минуты / 60 / 24 + 0.5 КАК ЧИСЛО(15, 0)), 0)) КАК ПЛАН_КоличествоДней,
	ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.План, "План") КАК План,
	ЕСТЬNULL(РабочееВремяСотрудников_ФАКТ.Факт, "Факт") КАК Факт
ИЗ
	(ВЫБРАТЬ
		НАЧАЛОПЕРИОДА(РабочееВремяСотрудников.Период, ДЕНЬ) КАК ДатаВремяНачала_ФАКТ,
		РабочееВремяСотрудников.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		РабочееВремяСотрудников.Сотрудник КАК Сотрудник,
		РабочееВремяСотрудников.Дней КАК Дней,
		СУММА(РабочееВремяСотрудников.Часов) КАК Часов,
		ВЫРАЗИТЬ(&amp;ВидФакт КАК СТРОКА(1000)) КАК Факт
	ИЗ
		РегистрНакопления.РабочееВремяСотрудников КАК РабочееВремяСотрудников
	ГДЕ
		ВЫБОР
				КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
						ИЛИ &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА НАЧАЛОПЕРИОДА(РабочееВремяСотрудников.Период, ДЕНЬ) &gt;= &amp;НачалоПериода
				ИНАЧЕ ИСТИНА
			КОНЕЦ
		И ВЫБОР
				КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
						ИЛИ &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА НАЧАЛОПЕРИОДА(РабочееВремяСотрудников.Период, ДЕНЬ) &lt;= &amp;КонецПериода
				ИНАЧЕ ИСТИНА
			КОНЕЦ
		И РабочееВремяСотрудников.Врач = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	
	СГРУППИРОВАТЬ ПО
		РабочееВремяСотрудников.СтруктурнаяЕдиница,
		РабочееВремяСотрудников.Сотрудник,
		НАЧАЛОПЕРИОДА(РабочееВремяСотрудников.Период, ДЕНЬ),
		РабочееВремяСотрудников.Дней) КАК РабочееВремяСотрудников_ФАКТ
		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ВремяРаботыСотрудниковПлан.Сотрудник КАК Сотрудник,
			НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) КАК ДатаВремяНачала_ПЛАН,
			ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			СУММА(ВремяРаботыСотрудниковПлан.Минуты) КАК Минуты,
			ВЫРАЗИТЬ(&amp;ВидПлан КАК СТРОКА(1000)) КАК План
		ИЗ
			РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
		ГДЕ
			ВЫБОР
					КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
							ИЛИ &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
						ТОГДА НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) &gt;= &amp;НачалоПериода
					ИНАЧЕ ИСТИНА
				КОНЕЦ
			И ВЫБОР
					КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
							ИЛИ &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
						ТОГДА НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) &lt;= &amp;КонецПериода
					ИНАЧЕ ИСТИНА
				КОНЕЦ
		
		СГРУППИРОВАТЬ ПО
			ВремяРаботыСотрудниковПлан.Сотрудник,
			ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница,
			НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ)) КАК РабочееВремяСотрудников_ПЛАН
		ПО РабочееВремяСотрудников_ФАКТ.СтруктурнаяЕдиница = РабочееВремяСотрудников_ПЛАН.СтруктурнаяЕдиница
			И РабочееВремяСотрудников_ФАКТ.Сотрудник = РабочееВремяСотрудников_ПЛАН.Сотрудник
			И РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ = РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН

СГРУППИРОВАТЬ ПО
	ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.Сотрудник, РабочееВремяСотрудников_ФАКТ.Сотрудник),
	ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.СтруктурнаяЕдиница, РабочееВремяСотрудников_ФАКТ.СтруктурнаяЕдиница),
	ЕСТЬNULL(НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН, ГОД), НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ, ГОД)),
	ЕСТЬNULL(НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН, ДЕНЬ), НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ, ДЕНЬ)),
	ЕСТЬNULL(НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ПЛАН.ДатаВремяНачала_ПЛАН, МЕСЯЦ), НАЧАЛОПЕРИОДА(РабочееВремяСотрудников_ФАКТ.ДатаВремяНачала_ФАКТ, МЕСЯЦ)),
	ЕСТЬNULL(РабочееВремяСотрудников_ПЛАН.План, "План"),
	ЕСТЬNULL(РабочееВремяСотрудников_ФАКТ.Факт, "Факт")

УПОРЯДОЧИТЬ ПО
	День,
	Сотрудник</query>
	</dataSet>
	<calculatedField>
		<dataPath>ПроцентВыполненияПлана</dataPath>
		<expression>КоличествоЧасовФакт /КоличествоЧасовПлан * 100</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>% выполнения плана</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Шрифт</dcscor:parameter>
				<dcscor:value xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xsi:type="v8ui:Font" ref="sys:DefaultGUIFont" height="9" bold="true" italic="false" underline="false" strikeout="false" kind="WindowsFont"/>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="xs:string">ЧДЦ=2</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<totalField>
		<dataPath>ПроцентВыполненияПлана</dataPath>
		<expression>Сумма(КоличествоЧасовФакт) / Сумма(КоличествоЧасовПлан) *100</expression>
	</totalField>
