	               |								И ТелефонныеАппараты.ЭтоГруппа)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВложенныйЗапрос.ТелефонныйАппарат КАК ТелефонныйАппарат,
	               |	ВложенныйЗапрос.ВнутреннийНомер КАК ВнутреннийНомер,
	               |	ВложенныйЗапрос.ВнутреннийНомерРодителя КАК ВнутреннийНомерРодителя,
	               |	ВложенныйЗапрос.Пользователь КАК Пользователь,
	               |	ВложенныйЗапрос.РабочееМесто КАК РабочееМесто
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ТелефоныПоСотрудникам.ТелефонныйАппарат КАК ТелефонныйАппарат,
	               |		ТелефоныПоСотрудникам.ВнутреннийНомер КАК ВнутреннийНомер,
	               |		ТелефоныПоСотрудникам.ТелефонныйАппарат.Родитель.ВнутреннийНомер КАК ВнутреннийНомерРодителя,
	               |		ТелефоныПоСотрудникам.Пользователь КАК Пользователь,
	               |		ТелефоныПоСотрудникам.РабочееМесто КАК РабочееМесто
	               |	ИЗ
	               |		ТелефоныПоСотрудникам КАК ТелефоныПоСотрудникам
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ТелефоныПоРабочимМестам.ТелефонныйАппарат,
	               |		ТелефоныПоРабочимМестам.ВнутреннийНомер,
	               |		ТелефоныПоРабочимМестам.ТелефонныйАппарат.Родитель.ВнутреннийНомер,
	               |		ТелефоныПоРабочимМестам.Пользователь,
	               |		ТелефоныПоРабочимМестам.РабочееМесто
	               |	ИЗ
	               |		ТелефоныПоРабочимМестам КАК ТелефоныПоРабочимМестам
	               |			ЛЕВОЕ СОЕДИНЕНИЕ ТелефоныПоСотрудникам КАК ТелефоныПоСотрудникам
	               |			ПО ТелефоныПоРабочимМестам.РабочееМесто = ТелефоныПоСотрудникам.РабочееМесто
	               |	ГДЕ
	               |		ТелефоныПоСотрудникам.ТелефонныйАппарат ЕСТЬ NULL) КАК ВложенныйЗапрос
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВложенныйЗапрос.ВнутреннийНомерРодителя,
	               |	ВложенныйЗапрос.Пользователь,
	               |	ВложенныйЗапрос.ТелефонныйАппарат,
	               |	ВложенныйЗапрос.ВнутреннийНомер,
	               |	ВложенныйЗапрос.РабочееМесто";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция - Получить активные СИБСТелефонным аппаратом
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСтруктуруВнутреннегоНомераПоПользователю(Пользователь, ОбработчикДрайвера = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РабочееМестоКлиента = ПараметрыСеанса.РабочееМестоКлиента;
	
	Если Не ЗначениеЗаполнено(РабочееМестоКлиента) Тогда
		РабочееМестоКлиента = РегистрыСведений.РабочиеМестаАктивныхПользователей.ПолучитьРабочееМесто(Пользователь);		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь"       , Пользователь);
	Запрос.УстановитьПараметр("РабочееМестоКлиента", РабочееМестоКлиента);
	Запрос.УстановитьПараметр("ОбработчикДрайвера" , ОбработчикДрайвера);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ТелефонныеАппаратыОбъектыПривязки.Ссылка КАК ТелефонныйАппарат,
	               |	ТелефонныеАппаратыОбъектыПривязки.Ссылка.ВнутреннийНомер КАК НомерТелефона,
	               |	ТелефонныеАппаратыОбъектыПривязки.Ссылка.Оборудование КАК Оборудование
	               |ИЗ
	               |	Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыОбъектыПривязки
	               |ГДЕ
	               |	((ВЫРАЗИТЬ(ТелефонныеАппаратыОбъектыПривязки.Объект КАК Справочник.Сотрудники)) = &Пользователь
	               |			ИЛИ (ВЫРАЗИТЬ(ТелефонныеАппаратыОбъектыПривязки.Объект КАК Справочник.РабочиеМеста)) = &РабочееМестоКлиента)
	               |	И ВЫБОР
	               |			КОГДА &ОбработчикДрайвера <> НЕОПРЕДЕЛЕНО
	               |				ТОГДА ТелефонныеАппаратыОбъектыПривязки.Ссылка.Оборудование.ДрайверОборудования.ОбработчикДрайвера = &ОбработчикДрайвера
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
		
	Результат = Запрос.Выполнить().Выгрузить();
	
	МассивТелефонныхАппаратовСотрудника = Новый Массив();
	
	Если Результат.Количество() > 0 Тогда
		Для Каждого СтрокаТЧ Из Результат Цикл
			СтруктураОтвета = СтрокуТаблицыЗначенийВСтруктуру(СтрокаТЧ, "ТелефонныйАппарат, НомерТелефона, Оборудование");
			СтруктураОтвета.Вставить("РабочееМесто", РабочееМестоКлиента);
			МассивТелефонныхАппаратовСотрудника.Добавить(СтруктураОтвета);
		КонецЦикла; 	
	КонецЕсли;
	
	Возврат МассивТелефонныхАппаратовСотрудника;
	
КонецФункции

// Функция - SHA256
// 
// Параметры:
//  СтрокаВычисленияКэша - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция SHA256(СтрокаВычисленияКэша, Алгоритм = "SHA_low_case") Экспорт

	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	Хеширование.Добавить(СтрокаВычисленияКэша);
	
	Результат = "";
	Если Алгоритм = "Base64" Тогда
		Результат = Base64Строка(Хеширование.ХешСумма);
	ИначеЕсли Алгоритм = "SHA_low_case" Тогда
		Результат = Строка(Хеширование.ХешСумма);
		Результат = СтрЗаменить(Результат, " ", "");
		Результат = НРег(Результат);
	Иначе
		Результат = Строка(Хеширование.ХешСумма);
		Результат = СтрЗаменить(Результат, " ", "");
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

