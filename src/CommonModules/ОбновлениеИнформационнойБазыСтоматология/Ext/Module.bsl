			ЗаписьЖурналаРегистрации("ЗаполнениеШалонаДляОтправкиКартWallet", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());	
		КонецПопытки; 
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Заменить использование констант триггером.
//
Процедура ЗаменитьИспользованиеКонстантПоздравленияСДРПациентовТриггером() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		
		ПоздравлятьПациентаПоСМС 	= Ложь;
		ПоздравлятьПациентаПоEmail 	= Ложь;
		ВремяОтправки				= Дата(1,1,1) + 60*60*10; 
		ШаблонСообщения				= Неопределено;
		
		РегламентноеЗадание = РегламентныеЗадания.НайтиПредопределенное(Метаданные.РегламентныеЗадания.ПоздравлятьКлиента);
		РегламентноеЗадание.Использование = Ложь;
		РегламентноеЗадание.Записать();
				
		Если (ПоздравлятьПациентаПоСМС = Ложь И ПоздравлятьПациентаПоEmail = Ложь) Или Не ЗначениеЗаполнено(ШаблонСообщения)Тогда	
			Возврат;		
		КонецЕсли;
		
		// Проверяем есть ли уже триггер с поздравлениями пациентов.
		Запрос = Новый Запрос( 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТриггерныеСобытия.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
		|ГДЕ
		|	ТриггерныеСобытия.УсловиеСобытия = ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПациентДеньРождения)
		|	И ТриггерныеСобытия.ПометкаУдаления = ЛОЖЬ
		|	И ТриггерныеСобытия.Активно = ИСТИНА");
		
		Результат = Запрос.Выполнить();
		
		Если Не Результат.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
		// Создаем триггер.
		СправочникТриггерноеСобытиеОбъект = Справочники.ТриггерныеСобытия.СоздатьЭлемент();
		
		СправочникТриггерноеСобытиеОбъект.Наименование      = "День рождения пациента.";
		СправочникТриггерноеСобытиеОбъект.Активно 			= Истина;
		СправочникТриггерноеСобытиеОбъект.ВремяСобытия 		= ВремяОтправки;
		СправочникТриггерноеСобытиеОбъект.УсловиеСобытия 	= Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентДеньРождения;
		СправочникТриггерноеСобытиеОбъект.ПараметрСобытия 	= 0;
		СправочникТриггерноеСобытиеОбъект.ПериодСобытия 	= 0;
		СправочникТриггерноеСобытиеОбъект.ПериодСобытияВид	= Перечисления.Периодичность.День; 
		СправочникТриггерноеСобытиеОбъект.Описание			= "Создано автоматически при обновлении конфигурации на версию 2.1.1.32";
		СправочникТриггерноеСобытиеОбъект.МоментСобытия		= Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия;	
		
		Если ПоздравлятьПациентаПоСМС = Истина Тогда 
			
			СервисСМСРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
			
			Если ЗначениеЗаполнено(СервисСМСРассылки) = Ложь Тогда	
				СервисыСМСРассылки = Справочники.СервисыРассылки.ПолучитьСервисыSMSрассылки();
				СервисСМСРассылки = ?(СервисыСМСРассылки.Количество() <> 0, СервисыСМСРассылки[0].Ссылка, СервисСМСРассылки);
			КонецЕсли; 
			
			НоваяСтрокаДействие = СправочникТриггерноеСобытиеОбъект.Действия.Добавить();
			НоваяСтрокаДействие.ИдентификаторДействия 	= Новый УникальныйИдентификатор;
			НоваяСтрокаДействие.ВидДействия 			= Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение;
			НоваяСтрокаДействие.ВидАдресата 			= Перечисления.ВидыАдресатов.КонтрагентСобытия; 
			НоваяСтрокаДействие.ШаблонСообщения			= ШаблонСообщения;
			НоваяСтрокаДействие.Описание				= "Отправить пациенту сообщение";
			НоваяСтрокаДействие.Использование			= Истина;
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
			|ГДЕ
			|	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
			|	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ");	
			
			СтруктурныеЕдиницы = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");;
			
			Для Каждого СтруктурнаяЕдиница Из СтруктурныеЕдиницы Цикл
				
				НоваяСтрокаНастройкиКаналов = СправочникТриггерноеСобытиеОбъект.НастройкиКаналовУведомлений.Добавить(); 
				
				НоваяСтрокаНастройкиКаналов.ИдентификаторДействия 		= НоваяСтрокаДействие.ИдентификаторДействия;
				НоваяСтрокаНастройкиКаналов.СтруктурнаяЕдиница			= СтруктурнаяЕдиница;
				НоваяСтрокаНастройкиКаналов.ОтправкаSMS					= Истина;
				НоваяСтрокаНастройкиКаналов.АккаунтСервисаРассылкиSMS	= СервисСМСРассылки;	
			КонецЦикла;
			
		КонецЕсли;
		
		Если ПоздравлятьПациентаПоEmail = Истина Тогда 
			
			СервисEmailРассылки = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты; 
			
			НоваяСтрокаДействие = СправочникТриггерноеСобытиеОбъект.Действия.Добавить();
			НоваяСтрокаДействие.ИдентификаторДействия 	= Новый УникальныйИдентификатор;
			НоваяСтрокаДействие.ВидДействия 			= Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо;
			НоваяСтрокаДействие.ВидАдресата 			= Перечисления.ВидыАдресатов.КонтрагентСобытия;
			НоваяСтрокаДействие.АккаунтEmail 			= СервисEmailРассылки; 
			НоваяСтрокаДействие.ШаблонСообщения			= ШаблонСообщения;
			НоваяСтрокаДействие.Описание				= "Отправить пациенту электронное письмо";
			НоваяСтрокаДействие.Использование			= Истина;
		КонецЕсли;
		
		СправочникТриггерноеСобытиеОбъект.Записать();
		
	Исключение 
		ЗаписьЖурналаРегистрации("ТриггерныеСобытияОбновлениеИнформационнойБазыСтоматология", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());	
	КонецПопытки;
	
КонецПроцедуры

// Процедура - Заменить диагнозы на новый справочник
//
Процедура ЗаменитьДиагнозыНаНовыйСправочник() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);  
	
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗначенияПараметровОбследований.Документ КАК Документ,
		|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
		|	ЗначенияПараметровОбследований.Параметр КАК Параметр,
		|	ЗначенияПараметровОбследований.Зуб КАК Зуб,
		|	ЗначенияПараметровОбследований.ЗначениеСтрокой КАК ЗначениеСтрокой
		|ИЗ
		|	РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований
		|ГДЕ
		|	ЗначенияПараметровОбследований.Параметр = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ПараметрыОбследований.Диагноз)
		|	И (ЗначенияПараметровОбследований.Значение = ЗНАЧЕНИЕ(Справочник.Диагнозы.ПустаяСсылка)
		|			ИЛИ ЗначенияПараметровОбследований.Значение = ЗНАЧЕНИЕ(Справочник.ДиагнозыУдалить.ПустаяСсылка))
		|	И (ВЫРАЗИТЬ(ЗначенияПараметровОбследований.ЗначениеСтрокой КАК СТРОКА(300))) <> """"";	
		Выборка = Запрос.Выполнить().Выбрать();	
		Пока Выборка.Следующий() Цикл
			
			НаборЗаписей = РегистрыСведений.ЗначенияПараметровОбследований.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Документ.Установить(Выборка.Документ);	
			НаборЗаписей.Отбор.ШаблонОбследования.Установить(Выборка.ШаблонОбследования);  
			НаборЗаписей.Отбор.Параметр.Установить(Выборка.Параметр);
			НаборЗаписей.Отбор.Зуб.Установить(Выборка.Зуб);
			
			НаборЗаписей.Прочитать();	
			
			Для Каждого Запись Из НаборЗаписей Цикл
				
				ДиагнозНовыйСправочник = Справочники.Диагнозы.НайтиПоНаименованию(Выборка.ЗначениеСтрокой);
				Если ЗначениеЗаполнено(ДиагнозНовыйСправочник) Тогда
					Запись.Значение = ДиагнозНовыйСправочник;
				КонецЕсли;
				
			КонецЦикла;
			
			НаборЗаписей.Записать();
		КонецЦикла;
		
	Исключение 
		ЗаписьЖурналаРегистрации("ЗаменитьДиагнозыНаНовыйСправочникОбновлениеИнформационнойБазыСтоматология", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());	
	КонецПопытки;
	
КонецПроцедуры

// Процедура, обновляет параметры внешних систем WhatsApp.
//
Процедура ОбновлениеПараметровВнешнихСистемWhatsApp(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ОбщегоНазначения.РазделениеВключено() = Ложь Тогда
		
		Расширения = РасширенияКонфигурации.Получить();
		
		Для Каждого Расширение Из Расширения Цикл
			
			Если Расширение.Имя = "WhatsApp_GA" Тогда
				
				Попытка
					Расширение.Удалить();
					
				Исключение
					ЗаписьЖурналаРегистрации(
						"ОбновлениеПараметровВнешнихСистемWhatsApp",
						УровеньЖурналаРегистрации.Ошибка,,,
						НСтр("ru = 'Не удалось удалить неактуальное расширение ""WhatsApp_GA"", необходимо удалить расширение вручную'")
					);
					
				КонецПопытки;
				
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.КлючПриложения КАК КлючПриложения,
	|	ВнешниеСистемы.Параметры КАК Параметры
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.GreenApi)
	|	И ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления");
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		
		Если Параметры <> Неопределено Тогда
			Параметры.ОбработкаЗавершена = Истина;
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	ПараметрыAPIЦрм = ЛичныйКабинет.ПараметрыПодклчюенияК_API_CRM();
	Метод = "/update_whatsapp_instance";
	
	Попытка
		HTTPСоединение = Новый HTTPСоединение(ПараметрыAPIЦрм.АдресСервера,, ПараметрыAPIЦрм.Пользователь, ПараметрыAPIЦрм.Пароль,, 10); 	
		
	Исключение
		
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(
			"ОбновлениеПараметровВнешнихСистемWhatsApp",
			УровеньЖурналаРегистрации.Ошибка,,,
			НСтр("ru = 'Не удалось установить соединение с CRM'") + ОписаниеОшибки
		);
		
		Если Параметры <> Неопределено Тогда
			Параметры.ОбработкаЗавершена = Истина;
		КонецЕсли;
		
		Возврат;
		
	КонецПопытки;
		
	НомерОбласти 		= ЛичныйКабинет.ПолучитьНомерОбласти();
	РегНомерПродукта 	= ЛичныйКабинет.ПолучитьРегистрационныйНомерПродукта(); 
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПараметрыВнешнейСистемы = Выборка.Параметры.Получить();
		
		Если ТипЗнч(ПараметрыВнешнейСистемы) = Тип("Структура")
			И ПараметрыВнешнейСистемы.Свойство("UrlApi")
			И СтрНайти(ПараметрыВнешнейСистемы.UrlApi, "chat-api")
			И ПараметрыВнешнейСистемы.Свойство("Подписка")
			И ТипЗнч(ПараметрыВнешнейСистемы.Подписка) = Тип("Структура")
			И ПараметрыВнешнейСистемы.Подписка.Свойство("ПодпискаУИД")
			И ЗначениеЗаполнено(ПараметрыВнешнейСистемы.Подписка.ПодпискаУИД)
			И ПараметрыВнешнейСистемы.Подписка.Свойство("ДатаДо")
			И ?(ТипЗнч(ПараметрыВнешнейСистемы.Подписка.ДатаДо) = Тип("Дата"), ПараметрыВнешнейСистемы.Подписка.ДатаДо > ТекущаяДата, Истина) Тогда
			
			ЗаголовкиHTTP  = Новый Соответствие; 
			ЗаголовкиHTTP.Вставить("Content-Type", "application/json");
			
			Если НомерОбласти <> 0 Тогда
				ЗаголовкиHTTP.Вставить("areanumber" , НомерОбласти);
			КонецЕсли; 
			
			ЗаголовкиHTTP.Вставить("registrationnumber"	, РегНомерПродукта); 
			ЗаголовкиHTTP.Вставить("subscription-uid"	, ПараметрыВнешнейСистемы.Подписка.ПодпискаУИД);
			ЗаголовкиHTTP.Вставить("application-key"	, Выборка.КлючПриложения);
			ЗаголовкиHTTP.Вставить("integrationtype"	, "GeneralGreenApiAccount");
	
			HTTPЗапрос = Новый HTTPЗапрос(ПараметрыAPIЦрм.АдресПубликации + Метод, ЗаголовкиHTTP);				
			
			Попытка
				Запрос = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
				
				ТекстJSON  = Запрос.ПолучитьТелоКакСтроку(); 
				ЧтениеJSON = Новый ЧтениеJSON;
				ЧтениеJSON.УстановитьСтроку(ТекстJSON);
				ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);	
				
				Если ПараметрыJSON.Свойство("result") И ПараметрыJSON.result = Истина
					И ПараметрыJSON.Свойство("settings") И ЗначениеЗаполнено(ПараметрыJSON.settings) Тогда
					
					ПараметрыВнешнейСистемы.Вставить("ApiToken"	, ПараметрыJSON.settings.ApiToken);
					ПараметрыВнешнейСистемы.Вставить("ChannelId", ПараметрыJSON.settings.ChannelId);
					ПараметрыВнешнейСистемы.Вставить("UrlApi"	, ПараметрыJSON.settings.UrlApi);
					
					ВнешняяСистемаОбъект = Выборка.Ссылка.ПолучитьОбъект();
					ВнешняяСистемаОбъект.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы);
					
					ВнешняяСистемаОбъект.Записать();
					
				Иначе
					ЗаписьЖурналаРегистрации(
						"ОбновлениеПараметровВнешнихСистемWhatsApp",
						УровеньЖурналаРегистрации.Ошибка,
						Метаданные.Справочники.ВнешниеСистемы,
						Выборка.Ссылка,
						НСтр("ru = 'Не удалось получить данные для обновления внешней системы WhatsApp.'")
					);
				КонецЕсли;
				
			Исключение
				ОписаниеОшибки = ОписаниеОшибки();
				ЗаписьЖурналаРегистрации(
					"ОбновлениеПараметровВнешнихСистемWhatsApp",
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.Справочники.ВнешниеСистемы,
					Выборка.Ссылка,
					НСтр("ru = 'Не удалось обновить параметры внешней системы WhatsApp. Текст ошибки: '") + ОписаниеОшибки
				);
				
			КонецПопытки;
				
		КонецЕсли;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

