// Функция - Получить сотрудников с нормой времени для перезаписи
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Сотрудник			 - 	 - 
//  МассивУслуг			 - 	 - 
//  ДатаСреза			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСотрудниковСНормойВремениДляПерезаписи(СтруктурнаяЕдиница, Сотрудник, МассивУслуг, ДатаСреза = Неопределено)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ПОМЕСТИТЬ ТаблицаУслугСотрудника
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|ГДЕ
	|	&УсловиеСотрудник
	|	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И &УсловиеМассивУслуг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаУслугСотрудника.Сотрудник КАК Сотрудник,
	|	ТаблицаУслугСотрудника.Номенклатура КАК Номенклатура,
	|	ТаблицаУслугСотрудника.НормаВремени КАК НормаВремениПоСотруднику
	|ИЗ
	|	ТаблицаУслугСотрудника КАК ТаблицаУслугСотрудника
	|ГДЕ
	|	ТаблицаУслугСотрудника.Номенклатура.НормаВремени > 0
	|	И ТаблицаУслугСотрудника.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НормаВремениПоСотруднику");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	//Запрос.УстановитьПараметр("ДатаСреза"         	, ДатаСреза);
	Запрос.УстановитьПараметр("МассивУслуг" 	  	, МассивУслуг);
	Запрос.УстановитьПараметр("Сотрудник" 			, Сотрудник);
	
	УсловиеСотрудник   = ?(ЗначениеЗаполнено(Сотрудник), "УслугиСотрудника.Сотрудник = &Сотрудник", "ИСТИНА");
	Запрос.Текст       = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудник", УсловиеСотрудник);
	
	УсловиеМассивУслуг = ?(ЗначениеЗаполнено(МассивУслуг), "И УслугиСотрудника.Номенклатура В(&МассивУслуг)", "");
	Запрос.Текст  	   = СтрЗаменить(Запрос.Текст, "И &УсловиеМассивУслуг", УсловиеМассивУслуг);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
