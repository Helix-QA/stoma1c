// Процедура - Обработать подготовленные данные сертификаты.
//
Процедура ОбработатьПодготовленныеДанныеСертификаты(РезультатЗагрузки)
	
	Попытка
		
		НачатьТранзакцию();
		
		ТаблицаСопоставленияДанных = РезультатЗагрузки.ТаблицаСопоставленияДанных;
		Для каждого СтрокаТаблицы Из ТаблицаСопоставленияДанных Цикл
			
			ЗагрузкаВПриложениеВозможна = СтрокаТаблицы[ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна()];
			Если ЗагрузкаВПриложениеВозможна Тогда
				
				СтрСертификаты = Объект.СерийныеНомераСертификатов.Добавить();
				ЗаполнитьЗначенияСвойств(СтрСертификаты, СтрокаТаблицы);
				Номенклатура = СтрСертификаты.Номенклатура;
				// СтрСертификаты.КлючСтроки = Новый УникальныйИдентификатор;
				
				// СтрСертификаты.ТипСертификата = Номенклатура.СертификатТип;
				// СтрСертификаты.Номенклатура = Номенклатура.СертификатПакетУслуг;
				СтрСертификаты.Партия				= СтрокаТаблицы.Характеристика;
				
				Если ЗначениеЗаполнено(Номенклатура) Тогда
					СтрСертификаты.ИспользоватьПартии	= Номенклатура.ИспользоватьПартии; 
					СтрСертификаты.ЭтоИменнойСертификат = Номенклатура.ЭтоИменнойСертификат;
					СтрСертификаты.ВидНоминала			= Номенклатура.ВидНоминала;
					СтрСертификаты.СертификатМногоразовоеИспользование = Номенклатура.СертификатМногоразовоеИспользование;

				КонецЕсли;
							
				ТекстОшибки = "";
				// Если НЕ ЗначениеЗаполнено(СтрСертификаты.Дата)Тогда
				//	ТекстОшибки = "Не заполнена дата";
				// Иначе
				Если НЕ ЗначениеЗаполнено(СтрСертификаты.Номенклатура)Тогда
					ТекстОшибки = "Не заполнена номенклатура";
				ИначеЕсли НЕ ЗначениеЗаполнено(СтрСертификаты.Сумма) Тогда
					ТекстОшибки = "Не заполнена сумма";
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = '"+ТекстОшибки+"! Для сертификата: "+Номенклатура+", загрузка будет пропущена'"));
					Объект.СерийныеНомераСертификатов.Удалить(СтрСертификаты);
					
				// Иначе
				//	ДобавитьСоставУслугСертифкатаНапакет(Номенклатура.СертификатПакетУслуг, СтрСертификаты.КлючСтроки);
				КонецЕсли;

			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ЗаписьЖурналаРегистрации(Нстр("ru='Загрузка данных'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Документы.ВводНачальныхОстатков, , Нстр("ru ='Запасы: '") + ОписаниеОшибки());
		ОтменитьТранзакцию();
		
	КонецПопытки;
	
КонецПроцедуры 

