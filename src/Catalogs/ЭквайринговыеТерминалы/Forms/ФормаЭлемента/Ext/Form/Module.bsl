// Процедура - Скопировать строку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СкопироватьСтроку(Команда)
	
	ИмяЭлемента   = СтрРазделить(ЭтаФорма.ТекущийЭлемент.Имя, "_");
	ВыбранноеПоле = ?(ИмяЭлемента.Количество() > 1, ИмяЭлемента[1], Неопределено);
	Если ЗначениеЗаполнено(ВыбранноеПоле) Тогда
		
		Если ВыбранноеПоле = "Tinkoff" Тогда
			АдресРесурса = ЭтотОбъект.СсылкаНаОплатуТинькофф;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(АдресРесурса) Тогда
			ОбъектHtml = Новый COMОбъект("htmlfile");
			ОбъектHtml.ParentWindow.ClipboardData.Setdata("Text", АдресРесурса); 
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

