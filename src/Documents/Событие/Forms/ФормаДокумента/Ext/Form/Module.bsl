// Процедура - обработчик команды ВвестиПосещение.
//
Процедура ВвестиПосещение(Команда)
	
	Если Объект.Ссылка.Пустая() Тогда
		НеОбновлятьРабочийСтол = Истина;
		
		Попытка
			Записать(Новый Структура("РежимЗаписи, ФормированиеПриема, НеобходимаГенерацияЗаявки", РежимЗаписиДокумента.Проведение, Истина, ЗначениеЗаполнено(ЭтотОбъект.КаналПривлечения)));
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());	
		КонецПопытки;
		
		НеОбновлятьРабочийСтол = Ложь;
	КонецЕсли;
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		
		СтруктураПараметры = Новый Структура("Основание", Объект.Ссылка);	
		ОписаниеОповещения = Новый ОписаниеОповещения("ВвестиПосещениеЗавершение", ЭтаФорма);
		Если ЗначениеЗаполнено(Объект.СсылкаНаПрием) Тогда
			СтруктураПараметры.вставить("Ключ",Объект.СсылкаНаПрием);
			ОткрытьФорму("Документ.Прием.ФормаОбъекта", СтруктураПараметры,, Объект.Ссылка,,, 
				ОписаниеОповещения, РежимОткрытияОкнаФормы.Независимый);
