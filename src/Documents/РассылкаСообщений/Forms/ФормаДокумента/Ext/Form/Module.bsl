// Процедура - Рекомендации отобразить.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура РекомендацииОтобразить(Команда)
	
	Элементы.ГруппаРекомендацияВсплывающая.Показать();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Рекомендации скрыть.
//
// Параметры:
//  Команда	 - 	 - 
