// Процедура, обработчик события "ПриИзменении" поле ввода "Упаковка"
//
Процедура ЗапасыУпаковкаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);	
	ОбработкаТабличныхЧастейКлиент.ПриИзмененииУпаковкиТабЧасти(СтрокаТабличнойЧасти, СтруктураДанные);
	
	СтруктрураПараметров = Новый Структура();
	СтруктрураПараметров.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктрураПараметров.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктрураПараметров.Вставить("ВидЦен", 			Объект.ВидЦенПродажи);	
	СтруктрураПараметров.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
	СтруктрураПараметров.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);			
	СтруктураДанные = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктрураПараметров);
	
	СтрокаТабличнойЧасти.ЦенаПродажи = СтруктураДанные.Цена;    
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	РассчитатьСуммуПродажиВСтрокеТабличнойЧасти();
	
КонецПроцедуры

