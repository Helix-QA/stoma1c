				Продолжить;
			ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан исполнитель!';en='The performer is not specified!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);				
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.СегментСотрудников И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.СегментыСотрудников")) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан сегмент исполнителей!';en='Do not specify the segment of performers!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);				
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидАдресатаРезервный) Тогда
					СтрокаДействия.Сообщение = НСтр("ru='Не указан резервный вид исполнителя!';en='The backup type of performer is not specified!'");
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				ИначеЕсли СтрокаДействия.ВидАдресатаРезервный = Перечисления.ВидыАдресатов.Сотрудник И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
					СтрокаДействия.Сообщение = НСтр("ru='Не указан резервный исполнитель!';en='A backup performer was not specified!'");
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				ИначеЕсли СтрокаДействия.ВидАдресатаРезервный = Перечисления.ВидыАдресатов.СегментСотрудников И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.СегментыСотрудников")) Тогда
					СтрокаДействия.Сообщение = НСтр("ru='Не указан резервный сегмент исполнителей!';en='Do not specify a reserve segment performers!'");
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Проверка для действия "Отправить сообщение"
		Если СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение ИЛИ СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
			Если НЕ ЗначениеЗаполнено(СтрокаДействия.ВидАдресата) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан вид адресата!';en='The type of recipient is not specified!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);									
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник И (НЕ ЗначениеЗаполнено(СтрокаДействия.Адресат) ИЛИ ТипЗнч(СтрокаДействия.Адресат) <> Тип("СправочникСсылка.Сотрудники")) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан адресат!';en='The recipient is not specified!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
				Если НЕ ЗначениеЗаполнено(СтрокаДействия.АккаунтEmail) Тогда
					СтрокаДействия.Сообщение = НСтр("ru='Не указан аккаунт Email-рассылки!';en='The Email mailing account is not specified!'");												
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				КонецЕсли;
				Если ЗначениеЗаполнено(СтрокаДействия.АккаунтEmail) И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаДействия.АккаунтEmail, "ИспользоватьДляОтправки") = Ложь Тогда 
					СтрокаДействия.Сообщение = НСтр("ru= 'Выбранная учетная запись электронной почты не активна';en= 'The selected email account is not active'");												
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				КонецЕсли;
			ИначеЕсли СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение Тогда 
				Если СтрокаДействия.ОтправкаSMS И НЕ ЗначениеЗаполнено(СтрокаДействия.АккаунтSMS) Тогда
					СтрокаДействия.Сообщение = НСтр("ru='Не указан аккаунт SMS-рассылки!';en='The SMS mailing account is not specified!'");												
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				КонецЕсли;	
				Если СтрокаДействия.ОтправкаMessenger И НЕ ЗначениеЗаполнено(СтрокаДействия.АккаунтВнешнейСистемы) Тогда
					СтрокаДействия.Сообщение = НСтр("ru='Не указан аккаунт системы сообщений!';en='Message system account not specified!'");						
					ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					Продолжить;
				КонецЕсли;	
				Если СтрокаДействия.ОтправкаMessenger Тогда
					// ТипВнешнейСистемы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаДействия.АккаунтВнешнейСистемы, "ТипВнешнейСистемы");
					// Если (ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk И НЕ ЗначениеЗаполнено(СтрокаДействия.КаналСистемыСообщений) Тогда 
					//	СтрокаДействия.Сообщение = НСтр("ru='Не указан канал системы сообщений!';en='The message system channel is not specified!'");
					//	ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					//	МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					//	Продолжить;
					// ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Chat2Desk Тогда 
					//	МассивКаналов = Мессенджер_КОРП.ПолучитьКаналыChat2Desk(СтрокаДействия.АккаунтВнешнейСистемы);
					//	СписокКаналов = Новый СписокЗначений;
					//	Для Каждого ЭлементКанал Из МассивКаналов Цикл 
					//		СписокКаналов.Добавить(ЭлементКанал.Значение, ЭлементКанал.Имя + " (" + Строка(ЭлементКанал.Значение) + ")");
					//	КонецЦикла;
					//	ЭлементСпискаКанал = СписокКаналов.НайтиПоЗначению(СтрокаДействия.КаналСистемыСообщений);
					//	Если ЭлементСпискаКанал = Неопределено И (СтрокаДействия.ОтправкаPush = Ложь И СтрокаДействия.ОтправкаPushWallet = Ложь И СтрокаДействия.ОтправкаSMS = Ложь) Тогда
					//		СтрокаДействия.Сообщение = НСтр("ru='Канал системы сообщений деактивирован!';en='The message system channel is deactivated!'");
					//		ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);					
					//		МассивНекондиционныхДействий.Добавить(СтрокаДействия);
					//		Продолжить;
					//	КонецЕсли;
					// КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаДействия.ШаблонСообщения) Тогда
				Если СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда 
					Если НЕ ЗначениеЗаполнено(СокрЛП(СтрокаДействия.ШаблонСообщенияТекстHTML)) Тогда 
						СтрокаДействия.Сообщение = НСтр("ru='Необходимо заполнить содержание в шаблоне Email-рассылки!';en='You must fill in the content in the Email mailing template!'");
						ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);						
						МассивНекондиционныхДействий.Добавить(СтрокаДействия);
						Продолжить;
					КонецЕсли;
				Иначе 
					Если НЕ ЗначениеЗаполнено(СокрЛП(СтрокаДействия.ШаблонСообщенияСодержаниеPush)) И НЕ ЗначениеЗаполнено(СокрЛП(СтрокаДействия.ШаблонСообщенияСодержание)) И НЕ ЗначениеЗаполнено(СокрЛП(СтрокаДействия.ШаблонСообщенияСодержаниеМессенджер)) Тогда 
						СтрокаДействия.Сообщение = НСтр("ru='Необходимо заполнить содержание в шаблоне SMS-рассылки!';en='You must fill in the content in the SMS mailing template!'");
						ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);						
						МассивНекондиционныхДействий.Добавить(СтрокаДействия);
						Продолжить;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Проверка для действия "Активировать чат-бота"
		Если СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота Тогда
			Если НЕ ПараметрыЧатБота.РазрешенаРаботаСЧатБотом Тогда 
				СтрокаДействия.Сообщение = НСтр("ru='Для триггерного события запрещена работа с чат-ботом!';en='For a trigger event, work with a chatbot is prohibited!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли НЕ ПараметрыЧатБота.ИспользуетсяРасширениеМессенджер Тогда 
				СтрокаДействия.Сообщение = НСтр("ru='Расширение для работы с чат-ботом не активно!';en='The extension for working with the chatbot is not active!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;	
			ИначеЕсли НЕ ПараметрыЧатБота.ИспользуетсяРасширениеМессенджер Тогда 
				СтрокаДействия.Сообщение = НСтр("ru='Расширение для работы с мессенджером не активно!';en='The extension for working with the messenger is not active!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;	
			ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаДействия.СценарийЧатБота) Тогда
				СтрокаДействия.Сообщение = НСтр("ru='Не указан сценарий чат-бота!';en='No chatbot script specified!'");
				ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
				МассивНекондиционныхДействий.Добавить(СтрокаДействия);
				Продолжить;
			ИначеЕсли НЕ ПараметрыЧатБота.ТаблицаСценариев = Неопределено Тогда 
				СтрокаСценарий = ПараметрыЧатБота.ТаблицаСценариев.Найти(СтрокаДействия.СценарийЧатБота, "СценарииЧатБота");
				Если НЕ СтрокаСценарий = Неопределено Тогда 
					Если СтрокаСценарий.ПометкаУдаления Тогда 
						СтрокаДействия.Сообщение = НСтр("ru='Сценарий помечен на удаление!';en='The script is marked for deletion!'");
						ЗаполнитьЗначенияСвойств(ТаблицаНекондиционныхДействий.Добавить(), СтрокаДействия);
						МассивНекондиционныхДействий.Добавить(СтрокаДействия);
