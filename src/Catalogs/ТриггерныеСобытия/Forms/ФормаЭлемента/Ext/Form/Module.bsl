&НаСервере
// Процедура - Установить свойства элементам исполнителей
//
Процедура УстановитьСвойстваЭлементамИсполнителей(Знач ЭлементФормы = Неопределено, ИндексСтроки, ПараметрыОтображенияЭлементов = Неопределено) Экспорт
	
	// Актуализируем параметры отрисовки
	Если ПараметрыОтображенияЭлементов = Неопределено Тогда 
		ПараметрыОтображенияЭлементов 	= ИнициализироватьСтруктуруПараметровОтрисовки(Ложь);
		МассивАктуальныхСтрок 			= Объект.Действия.НайтиСтроки(Новый Структура("Удалено", Ложь));		
		ПараметрыОтображенияЭлементов.Вставить("ЭтоПерваяАктуальнаяСтрока", ?(МассивАктуальныхСтрок.Количество() = 0, Истина, ИндексСтроки = Объект.Действия.Индекс(МассивАктуальныхСтрок[0])));
	КонецЕсли;
	
	ПоискЭлемента = ?(ЭлементФормы = Неопределено, Истина, Ложь);
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ГруппаВыбораИсполнителяЗадачи_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;	
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ГруппаВыбораИсполнителяЗадачи_Индекс_" + Строка(ИндексСтроки) Тогда 		
			ЭлементФормы.Видимость = ЗначениеЗаполнено(Объект.Действия[ИндексСтроки].ВидДействия) И Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру;
			Если НЕ ПоискЭлемента ИЛИ НЕ ЭлементФормы.Видимость Тогда 
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ПоискЭлемента Тогда 
		ЭлементФормы = Элементы.Найти("ВидИсполнителя_Индекс_" + Строка(ИндексСтроки));
	КонецЕсли;		
	Если НЕ ЭлементФормы = Неопределено Тогда
		Если ЭлементФормы.Имя = "ВидИсполнителя_Индекс_" + Строка(ИндексСтроки) Тогда 		
			ЭлементФормы.СписокВыбора.Очистить();
			
			//// Добавим в качестве адресата тренера занятия	
			//Если ПараметрыОтображенияЭлементов.ВиртуальнаяГруппаСобытий = "СобытияПоЗаписям" И ПараметрыОтображенияЭлементов.РазрешенаРаботаСоСделками = Ложь Тогда
			//	ЭлементФормы.СписокВыбора.Добавить(Перечисления.ВидыАдресатов.ВрачПриема					, , Объект.Действия[ИндексСтроки].ВидАдресата = Перечисления.ВидыАдресатов.ВрачПриема);
			//КонецЕсли;
			
			// Добавим основных адресатов
			Если Объект.Действия[ИндексСтроки].ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру Тогда
				Если НЕ ПараметрыОтображенияЭлементов.ВариантыУсловийТриггерныхСобытий = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана Тогда
					// Врачам задачи не ставим	
