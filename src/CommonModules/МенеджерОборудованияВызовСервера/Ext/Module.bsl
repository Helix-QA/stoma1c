// Процедура, выводит область итога.
//
Процедура ВывестиИтог(ТабДок, Макет, ШиринаПречека, Итог, ОблРазделение)
	
	ОблИтого = Макет.ПолучитьОбласть("ИнформацияИтого" + ШиринаПречека);
	ОблИтого.Параметры.Всего = Формат(Итог, "ЧЦ=15; ЧДЦ=2; ЧН=0,00; ЧГ=0");
