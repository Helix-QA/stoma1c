// Процедура - Подключаемый перейти к диалогу
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ПерейтиКДиалогу(Элемент)	
	
	Если Объект.Ссылка.Пустая() Тогда
		Оповещение = Новый ОписаниеОповещения("ВзаимодействиеПослеВопросаОЗаписиЗаявки", ЭтотОбъект, Новый Структура("ВыполнитьДействие, Элемент", "ПерейтиКДиалогу", Элемент));
		ПоказатьВопрос(Оповещение, "Для перехода в мессенджер необходимо произвести запись новой заявки. Записать?", РежимДиалогаВопрос.ДаНет);
	Иначе
		
		Если Модифицированность И Не ЭтаФорма.Записать() Тогда
			Возврат;
		КонецЕсли;
		
		ИндексСтроки = Число(Сред(Элемент.Имя, СтрДлина("ПерейтиКДиалогу_")+1));
		ДанныеКИ     = ЭтотОбъект.КонтактнаяИнформация[ИндексСтроки];
		
		ПредставлениеНомераТелефона = ДанныеКИ.Представление;
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, " ", "");
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, "(", "");
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, ")", "");
		ПредставлениеНомераТелефона = СтрЗаменить(ПредставлениеНомераТелефона, "+", "");
		
		Если НЕ ЗначениеЗаполнено(ПредставлениеНомераТелефона) Тогда
			ОбщегоНазначения.СообщитьПользователю("Пустой номер телефона клиента");
			Возврат;
		КонецЕсли;

		ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Ссылка, ТекущаяСтруктурнаяЕдиница, Истина, ПредставлениеНомераТелефона);
					
		Если ДанныеВнешнихСистемМессенджера.Количество() = 0 Тогда
			Возврат;
		ИначеЕсли ДанныеВнешнихСистемМессенджера.Количество() = 1 Тогда
			Подключаемый_ПерейтиКДиалогуЗавершение(ДанныеВнешнихСистемМессенджера[0],Неопределено);
			Возврат;
		КонецЕсли;
		
		ОписаниеОповещения = Новый ОписаниеОповещения("Подключаемый_ПерейтиКДиалогуЗавершение", ЭтотОбъект);
		
		ПоказатьВыборИзМеню(ОписаниеОповещения, ДанныеВнешнихСистемМессенджера, Элемент);
	КонецЕсли;
	
КонецПроцедуры

