// Получить реквизит шаблона
//
Функция ПолучитьПараметрыРеквизитаШаблонаОбследования(Знач РеквизитИД) 
	
    // Получить основной идетификтор реквизита
	ИДОсновной      = ПолучитьВедущийИдентификторРеквизитаОбследования(РеквизитИД);
	НайденныеСтроки = ДОРеквизитыШаблонОбследования.НайтиСтроки(Новый Структура("РеквизитИдентификатор", ИДОсновной));
	Если НайденныеСтроки.Количество() > 0 Тогда
		// Получаем параметры реквизита
		Динамический            = НайденныеСтроки[0].РеквизитТип = ОбщиеПараметры.ТипыПараметровШаблоновОбследований_Динамический;
		СтрокаБуфераДанных      = ПолучитьЗначениеРеквизитаИзБуфераДанныхобследования(РеквизитИД);
		РеквизитЗначение        = ?(СтрокаБуфераДанных.Количество() > 0,СтрокаБуфераДанных[0].РеквизитЗначение, Неопределено);
		РеквизитЗначениеСтрокой = ?(СтрокаБуфераДанных.Количество() > 0,СтрокаБуфераДанных[0].РеквизитЗначениеСтрокой, Неопределено);
		ЗубЗначение             = ?(СтрокаБуфераДанных.Количество() > 0,СтрокаБуфераДанных[0].ЗубЗначение, Неопределено);
	
		ПараметрыРеквизита  = 
		Новый Структура("РеквизитИдентификатор,Реквизит,Динамический,ЗначениеТип,ПривязкаКЗубам,РеквизитЗначение,РеквизитЗначениеСтрокой,ЗубЗначение,ПорядковыйНомер"
		,РеквизитИД
		,НайденныеСтроки[0].Реквизит
		,Динамический
		,НайденныеСтроки[0].ТипЗначенияСтрокой
		,НайденныеСтроки[0].ПривязкаКЗубам
		,РеквизитЗначение
		,РеквизитЗначениеСтрокой
		,ЗубЗначение
		,НайденныеСтроки[0].ПорядковыйНомер);	
		
		Возврат ПараметрыРеквизита; 
	КонецЕсли;
	Возврат Неопределено; 
	
КонецФункции

