&НаСервере
// Процедура - Обновить значения фильтрации данных.
//
// Параметры:
//  ПараметрыОтбора				 - 	 - 
//  ОчиститьВсеФильтры			 - 	 - 
//  МассивИменОчищаемыхФильтров	 - 	 - 
//
Процедура ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора, ОчиститьВсеФильтры = Истина, МассивИменОчищаемыхФильтров = Неопределено)
	
	Если ОчиститьВсеФильтры Тогда 
		МассивИменОчищаемыхФильтров = Новый Массив();
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");		
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Статус");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Этап");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Менеджер");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СотрудникРегистрации");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_РекламныйИсточник");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Тег");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Задача"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_Сделка"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СозданПериод");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПериодЗапланированнойЗадачи");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивИменОчищаемыхФильтров) Тогда 
		УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	КонецЕсли;
	
	// Отбор статус клиента 
	Если ПараметрыОтбора.Свойство("КоллекцияСтатусовКлиента") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.КоллекцияСтатусовКлиента, Истина);
	КонецЕсли;
	
	// Отбор структурная единица.
	Если ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц);		
	Иначе 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	КонецЕсли;
	
	// Отбор вид сделки.
	Если ПараметрыОтбора.Свойство("МассивВидовСделок") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок);		
	КонецЕсли;

	// Отбор этапы сделки.
	Если ПараметрыОтбора.Свойство("МассивЭтапов") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов);		
	КонецЕсли;	
	
	// Отбор признак наличия задач.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач") Тогда 
		// МассивСтатусовНаличияЗадач = Новый Массив();
		// Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияЗадач) 
		//	И ПараметрыОтбора.МассивСтатусовНаличияЗадач[0] = "Нет задач" Тогда
		//	
		//	МассивСтатусовНаличияЗадач.Добавить(Ложь);
		// Иначе
		//	МассивСтатусовНаличияЗадач.Добавить(Истина);		
		// КонецЕсли;
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", ПараметрыОтбора.МассивСтатусовНаличияЗадач);
	КонецЕсли;
	
	// Отбор статусов сделки.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок") Тогда
		МассивСтатусовНаличияСделок = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияСделок) 
			И ПараметрыОтбора.МассивСтатусовНаличияСделок[0] = Нстр("ru = 'Нет сделок'; en = 'No deals'") Тогда
			
			МассивСтатусовНаличияСделок.Добавить(Ложь);
		Иначе
			МассивСтатусовНаличияСделок.Добавить(Истина);		
		КонецЕсли;
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Сделка", МассивСтатусовНаличияСделок);
	КонецЕсли;

	// Отбор менеджеров.
	Если ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Менеджер", ПараметрыОтбора.МассивМенеджеров);
	КонецЕсли;	
	
	// Отбор период запланированной задачи
	Если ПараметрыОтбора.Свойство("ПериодПланирования") Тогда    	
		МассивПериодаЗапланированнойЗадачи = Новый Массив();
		МассивПериодаЗапланированнойЗадачи.Добавить(ПараметрыОтбора.ПериодПланирования);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПериодЗапланированнойЗадачи", МассивПериодаЗапланированнойЗадачи);
	КонецЕсли;	
	
	// Отбор периода завершения сделки.
	Если ПараметрыОтбора.Свойство("ПериодСделки") Тогда    
		МассивПериодаЗавершенияСделки = Новый Массив();
		МассивПериодаЗавершенияСделки.Добавить(ПараметрыОтбора.ПериодСделки);
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ЗавершенаПериод", МассивПериодаЗавершенияСделки);
	КонецЕсли;
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

&НаСервере
// Процедура, актуализировать данные списка согласно отборов.
//
Процедура АктуализироватьДанныеСпискаСогласноОтборов()
	
	СтруктураОтборов 					= ПолучитьСтруктуруЗначенийОтбора();
	
	ЗапросДляКоличества 				= ПолучитьЗапросДляПодсчетаКоличества(СтруктураОтборов);
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда 
		ЗапросДляДинамическогоСписка 	= ПолучитьЗапросДляДинамическогоСпискаФайловыйВариант(СтруктураОтборов);
	Иначе 	
		ЗапросДляДинамическогоСписка 	= ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов);
	КонецЕсли;	
	
	// Цепляем наш запрос динамическому списку
	Список.ТекстЗапроса = ЗапросДляДинамическогоСписка.Текст;
	
	// Устанавливаем параметры динамическому списку
	Для Каждого ПараметрЗапроса Из ЗапросДляДинамическогоСписка.Параметры Цикл 
		Список.Параметры.УстановитьЗначениеПараметра(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);		
	КонецЦикла;
	
	ВыборкаДляКоличества = ЗапросДляКоличества.Выполнить().Выбрать();
	Если ВыборкаДляКоличества.Следующий() Тогда
		КоличествоКлиентов = ВыборкаДляКоличества.КоличествоКлиентов;
		УстановитьЗаголовокКоличествоЭлементовВСписке(КоличествоКлиентов);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция, возвращает структуру отборов формы.
//
Функция ПолучитьСтруктуруЗначенийОтбора()
	
	// Метод "ПолучитьЗначенияФильтра" возвращает список активированных значений фильтра.
	// У полученного списка значений есть свойство "ДоступныеЗначения", в котором хранится список всех значений.
	// Таким образом мы одним методом за одну итерацию получаем 2 списка значений(с активированными значениями и всеми значениями).
	// Вариант отбора передается в свойстве "ДоступныеЗначения" в представлении у любого элемента списка.
	
 	СтруктураОтборов = Новый Структура();
	СтруктураОтборов.Вставить("ОтборСтатус"					  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус"));
	СтруктураОтборов.Вставить("ОтборСтруктурнаяЕдиница"		  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СтруктурнаяЕдиница"));	
	СтруктураОтборов.Вставить("ОтборМенеджер"				  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Менеджер"));		
	СтруктураОтборов.Вставить("ОтборЭтап"					  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Этап"));
	СтруктураОтборов.Вставить("ОтборСотрудникРегистрации"	  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СотрудникРегистрации"));
	СтруктураОтборов.Вставить("ОтборРекламныйИсточник"		  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_РекламныйИсточник"));
	СтруктураОтборов.Вставить("ОтборТег"					  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Тег"));
	СтруктураОтборов.Вставить("ОтборЗадача"	 				  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Задача"));
	СтруктураОтборов.Вставить("ОтборСделка"	 				  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Сделка"));
	СтруктураОтборов.Вставить("ОтборДатаСоздания"			  , УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СозданПериод"));
	СтруктураОтборов.Вставить("ОтборДатаЗапланированнойЗадачи", УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_ПериодЗапланированнойЗадачи"));
		
	Возврат СтруктураОтборов;
	
КонецФункции	

&НаСервере
// Функция, возвращает запрос с установленными параметрами, для подсчета количества.
//
Функция ПолучитьЗапросДляПодсчетаКоличества(СтруктураОтборов)
	    
	// Запрос оптимизирован под файловый вариант
	Запрос = Новый Запрос;	
	// Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача) И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь И НЕ СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление = "НЕ " Тогда
	//	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	//	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Контрагенты.Ссылка) КАК КоличествоКлиентов
	//	               |ИЗ
	//	               |	Справочник.Контрагенты КАК Контрагенты
	//	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	//	               |		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
	//	               |ГДЕ
	//	               |	Контрагенты.ПометкаУдаления = ЛОЖЬ
	//	               |	И Контрагенты.ЭтоГруппа = ЛОЖЬ
	//				   |	И Контрагенты.ОбезличенныйКлиент = ЛОЖЬ
	//	               |	И &УсловиеСтруктурнаяЕдиница					   
	//	               |	И &УсловиеМенеджер
	//	               |	И &УсловиеСотрудникРегистрации
	//	               |	И &УсловиеРекламныйИсточник
	//	               |	И &УсловиеКаналПривлечения
	//	               |	И &УсловиеТеги
	//	               |	И &УсловиеИнтересы
	//	               |	И &УсловиеДатаСоздания
	//	               |	И &УсловиеСтатус
	//	               |	И &УсловиеОтборБезЗадачФильтрПоРегистру
	//	               |	И &УсловиеОтборБезСделок
	//	               |	И &УсловиеЭтап";
	// Иначе
		
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗапланированнойЗадачи)	ИЛИ (ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача) И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь И СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление = "НЕ ") Тогда 
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	Контрагенты.Ссылка КАК Контрагент,
		               |	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача
		               |ПОМЕСТИТЬ ТаблицаКонтрагентов
		               |ИЗ
		               |	Справочник.Контрагенты КАК Контрагенты
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
		               |		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
		               |ГДЕ
		               |	Контрагенты.ПометкаУдаления = ЛОЖЬ
		               |	И Контрагенты.ЭтоГруппа = ЛОЖЬ
		               |	И &УсловиеСтруктурнаяЕдиница
		               |	И &УсловиеМенеджер
		               |	И &УсловиеСотрудникРегистрации
		               |	И &УсловиеРекламныйИсточник
		               |	И &УсловиеТеги
		               |	И &УсловиеДатаСоздания
		               |	И &УсловиеСтатус
		               |	И &УсловиеОтборБезЗадачФильтрПоРегистру
		               |	И &УсловиеОтборБезСделок
		               |	И &УсловиеЭтап
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Контрагенты.Ссылка,
		               |	КонтрагентыСведенияДляСписка.СледующаяЗадача
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	Взаимодействие.Ссылка КАК СледующаяЗадача
		               |ПОМЕСТИТЬ ТаблицаЗадач
		               |ИЗ
		               |	Задача.Взаимодействие КАК Взаимодействие
		               |ГДЕ
		               |	Взаимодействие.Ссылка В
		               |			(ВЫБРАТЬ
		               |				ТаблицаКонтрагентов.СледующаяЗадача
		               |			ИЗ
		               |				ТаблицаКонтрагентов)
		               |	И Взаимодействие.ПометкаУдаления = ЛОЖЬ
		               |	И &УсловиеОтборБезЗадачФильтрПоВзаимодействиям
		               |	И &УсловиеДатаЗапланированнойЗадачи
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Взаимодействие.Ссылка
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	КОЛИЧЕСТВО(ТаблицаКонтрагентов.Контрагент) КАК КоличествоКлиентов
		               |ИЗ
		               |	ТаблицаКонтрагентов КАК ТаблицаКонтрагентов
		               |ГДЕ
		               |	ТаблицаКонтрагентов.СледующаяЗадача В
		               |			(ВЫБРАТЬ
		               |				ТаблицаЗадач.СледующаяЗадача
		               |			ИЗ
		               |				ТаблицаЗадач)";
		
	Иначе 
		
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Контрагенты.Ссылка) КАК КоличествоКлиентов
		               |ИЗ
		               |	Справочник.Контрагенты КАК Контрагенты
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
		               |		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
		               |ГДЕ
		               |	Контрагенты.ПометкаУдаления = ЛОЖЬ
		               |	И Контрагенты.ЭтоГруппа = ЛОЖЬ
		               |	И &УсловиеСтруктурнаяЕдиница
		               |	И &УсловиеМенеджер
		               |	И &УсловиеСотрудникРегистрации
		               |	И &УсловиеРекламныйИсточник
		               |	И &УсловиеТеги
		               |	И &УсловиеДатаСоздания
		               |	И &УсловиеСтатус
		               |	И &УсловиеОтборБезЗадачФильтрПоРегистру
		               |	И &УсловиеОтборБезСделок
		               |	И &УсловиеЭтап";
		
	КонецЕсли;	
	
	// Отбор структурная единица.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Контрагенты.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор статус клиента.
	Если СтруктураОтборов.ОтборСтатус.Количество() > 0  Тогда		
		УсловиеСтатус =СтруктураОтборов.ОтборСтатус.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.Статус В(&ОтборСтатус)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", УсловиеСтатус);
		Запрос.УстановитьПараметр("ОтборСтатус", СтруктураОтборов.ОтборСтатус.ВыгрузитьЗначения());
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", "ИСТИНА");
	КонецЕсли; 	
	
	// Отбор сотрудник регистрации.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации) Тогда
		УсловиеСотрудникРегистрации = СтруктураОтборов.ОтборСотрудникРегистрации.ДоступныеЗначения[0].Представление + "Контрагенты.СотрудникРегистрации В (&ОтборСотрудникРегистрации)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
		Запрос.УстановитьПараметр("ОтборСотрудникРегистрации", СтруктураОтборов.ОтборСотрудникРегистрации.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор менеджер.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер) Тогда
		УсловиеМенеджер = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения[0].Представление + "Контрагенты.Куратор В(&ОтборМенеджер)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", УсловиеМенеджер);
		Запрос.УстановитьПараметр("ОтборМенеджер", СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор рекламный источник.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник) Тогда
		УсловиеРекламныйИсточник = СтруктураОтборов.ОтборРекламныйИсточник.ДоступныеЗначения[0].Представление + "Контрагенты.ИсточникИнформации В (&ОтборРекламныйИсточник)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		Запрос.УстановитьПараметр("ОтборРекламныйИсточник", СтруктураОтборов.ОтборРекламныйИсточник.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", "ИСТИНА");
	КонецЕсли;
	
	// Отбор тег.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборТег) Тогда
		
		УсловиеТеги =  
		"Контрагенты.Ссылка В
		|  		(ВЫБРАТЬ
		|  			СправочникКонтрагентыТеги.Ссылка
		|  		ИЗ
		|  			Справочник.Контрагенты.Теги КАК СправочникКонтрагентыТеги
		|  		ГДЕ
		|  			" + СтруктураОтборов.ОтборТег.ДоступныеЗначения[0].Представление + "СправочникКонтрагентыТеги.Тег В (&ОтборТеги))";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", УсловиеТеги);
		Запрос.УстановитьПараметр("ОтборТеги", СтруктураОтборов.ОтборТег.ВыгрузитьЗначения());
		
	Иначе	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", "ИСТИНА");
	КонецЕсли;
	
	// Отбор дата создания.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаСоздания) Тогда   
		
		УсловиеДатаСоздания = "Контрагенты.ДатаРегистрации МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", УсловиеДатаСоздания);
		ДатаНачала = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
		
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", "ИСТИНА")		
	КонецЕсли;	
		
	// Отбор дата запланированной задачи.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗапланированнойЗадачи) Тогда
		Если (ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача) 
			И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь 
			И НЕ СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление = "НЕ ") Тогда
			
			// параметры не устанавливаем
			
			Если СтруктураОтборов.ОтборЗадача[0].Представление = "Нет задач" Тогда		
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", "ИСТИНА");
			КонецЕсли;
			
		Иначе
			Если СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала = Дата(1, 1, 1) И СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания = НачалоДня(ТекущаяДатаСеанса()) - 1  Тогда 
				УсловиеДатаЗапланированнойЗадачи = "Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
				УсловиеОтборБезЗадачФильтрПоВзаимодействиям = "Взаимодействие.Выполнена = ЛОЖЬ";
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадачФильтрПоВзаимодействиям", УсловиеОтборБезЗадачФильтрПоВзаимодействиям);				
			Иначе 	
				УсловиеДатаЗапланированнойЗадачи = "(Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи
			|			ИЛИ Взаимодействие.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи
			|			ИЛИ &ДатаНачалаЗапланированнойЗадачи <= Взаимодействие.ЗадачаНазначеннаяДатаНачало
			|				И &ДатаОкончанияЗапланированнойЗадачи <= Взаимодействие.ЗадачаНазначеннаяДата)";
			КонецЕсли;
			Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
			ДатаНачала 		= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала;
			ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания;
			
			Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));	
			Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
		КонецЕсли;
	Иначе                               
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", "ИСТИНА");
	КонецЕсли;
	
	// Отбор без задач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача)
		И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь Тогда
		
		УсловиеОтборБезЗадач = СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадачФильтрПоРегистру", УсловиеОтборБезЗадач);
		Если СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление = "НЕ " Тогда 
			УсловиеОтборБезЗадачФильтрПоВзаимодействиям = "Взаимодействие.Выполнена = ЛОЖЬ";
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадачФильтрПоВзаимодействиям", УсловиеОтборБезЗадачФильтрПоВзаимодействиям);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадачФильтрПоВзаимодействиям", "ИСТИНА");
		КонецЕсли;			
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадачФильтрПоРегистру"		, "ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадачФильтрПоВзаимодействиям"	, "ИСТИНА");
	КонецЕсли;  	
	
	// Отбор без сделок.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСделка)
		И СтруктураОтборов.ОтборСделка[0].Значение = Ложь Тогда
		
		УсловиеОтборБезСделок = СтруктураОтборов.ОтборСделка.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.ТекущаяСделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезСделок", УсловиеОтборБезСделок);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезСделок", "ИСТИНА");
	КонецЕсли;
	
	// Отбор этап сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.ТекущийЭтапСделки В (&ОтборЭтап)");		
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");		
	КонецЕсли;
		
	Возврат Запрос;
	
КонецФункции

&НаСервере
// Функция, возвращает запрос с установленными параметрами, для списка формы.
//
Функция ПолучитьЗапросДляДинамическогоСписка(СтруктураОтборов)
	
	// текст запроса без отборов (чистый)
	Запрос = Новый Запрос( 	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Контрагенты.Ссылка КАК Клиент,
	|	КонтрагентыСведенияДляСписка.Статус КАК Статус,
	|	КонтрагентыСведенияДляСписка.Телефон КАК Телефон,
	|	КонтрагентыСведенияДляСписка.АдресЭП КАК АдресЭП,
	|	Контрагенты.Куратор КАК Менеджер,
	|	Контрагенты.ИсточникИнформации КАК ИсточникИнформации,
	|	Контрагенты.ДатаРегистрации КАК ДатаРегистрации,
	|	Контрагенты.СотрудникРегистрации КАК СотрудникРегистрации,
	|	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК ТекущаяСделка,
	|	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки КАК ТекущийЭтапСделки,
	|	КонтрагентыСведенияДляСписка.СуммаСделки КАК СуммаСделки,
	|	КонтрагентыСведенияДляСписка.ПоследняяЗадача КАК ПоследняяЗадача,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача,
	|	КонтрагентыСведенияДляСписка.ПоследняяЗадачаПредставление КАК ПоследняяЗадачаПредставление,
	|	КонтрагентыСведенияДляСписка.СледующаяЗадачаПредставление КАК СледующаяЗадачаПредставление,
	|	ВЫРАЗИТЬ(КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Контрагенты.Ссылка = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	НЕ Контрагенты.ЭтоГруппа
	|	И НЕ Контрагенты.ПометкаУдаления
	|	И &УсловиеСтруктурнаяЕдиница
	|	И &УсловиеСтатус
	|	И &УсловиеСотрудникРегистрации
	|	И &УсловиеМенеджер
	|	И &УсловиеРекламныйИсточник
	|	И &УсловиеТеги
	|	И &УсловиеДатаСоздания
	|	И &УсловиеДатаЗапланированнойЗадачи
	|	И &УсловиеОтборБезЗадач
	|	И &УсловиеОтборБезСделок
	|	И &УсловиеЭтап");				  
	
	// Отбор структурная единица.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСтруктурнаяЕдиница) Тогда
		УсловиеСтруктурнаяЕдиница = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения[0].Представление + "Контрагенты.СтруктурнаяЕдиница В (&ОтборСтруктурнаяЕдиница)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", УсловиеСтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ОтборСтруктурнаяЕдиница", СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	// Отбор статус клиента.
	Если СтруктураОтборов.ОтборСтатус.Количество() > 0  Тогда		
		УсловиеСтатус = СтруктураОтборов.ОтборСтатус.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.Статус В (&ОтборСтатус)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", УсловиеСтатус);
		Запрос.УстановитьПараметр("ОтборСтатус", СтруктураОтборов.ОтборСтатус.ВыгрузитьЗначения());
	Иначе		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатус", "ИСТИНА");
	КонецЕсли; 	
	
	// Отбор сотрудник регистрации.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСотрудникРегистрации) Тогда
		УсловиеСотрудникРегистрации = СтруктураОтборов.ОтборСотрудникРегистрации.ДоступныеЗначения[0].Представление + "Контрагенты.СотрудникРегистрации В (&ОтборСотрудникРегистрации)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", УсловиеСотрудникРегистрации);
		Запрос.УстановитьПараметр("ОтборСотрудникРегистрации", СтруктураОтборов.ОтборСотрудникРегистрации.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСотрудникРегистрации", "ИСТИНА");	
	КонецЕсли;
	
	// Отбор менеджер.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборМенеджер) Тогда
		УсловиеМенеджер = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения[0].Представление + "Контрагенты.Куратор В (&ОтборМенеджер)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", УсловиеМенеджер);
		Запрос.УстановитьПараметр("ОтборМенеджер", СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеМенеджер", "ИСТИНА");	
	КонецЕсли;
		
	// Отбор рекламный источник.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборРекламныйИсточник) Тогда
		УсловиеРекламныйИсточник = СтруктураОтборов.ОтборРекламныйИсточник.ДоступныеЗначения[0].Представление + "Контрагенты.ИсточникИнформации В (&ОтборРекламныйИсточник)";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", УсловиеРекламныйИсточник);
		Запрос.УстановитьПараметр("ОтборРекламныйИсточник", СтруктураОтборов.ОтборРекламныйИсточник.ВыгрузитьЗначения());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеРекламныйИсточник", "ИСТИНА");
	КонецЕсли;
	
	// Отбор тег.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборТег) Тогда
		
		УсловиеТеги =  
		"Контрагенты.Ссылка В
		|  		(ВЫБРАТЬ
		|  			СправочникКонтрагентыТеги.Ссылка
		|  		ИЗ
		|  			Справочник.Контрагенты.Теги КАК СправочникКонтрагентыТеги
		|  		ГДЕ
		|  			"+СтруктураОтборов.ОтборТег.ДоступныеЗначения[0].Представление+"СправочникКонтрагентыТеги.Тег В (&ОтборТеги))";
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", УсловиеТеги);
		Запрос.УстановитьПараметр("ОтборТеги", СтруктураОтборов.ОтборТег.ВыгрузитьЗначения());

	Иначе	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТеги", "ИСТИНА");
	КонецЕсли;
		
	// Отбор дата создания.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаСоздания) Тогда   
		
		УсловиеДатаСоздания = "Контрагенты.ДатаРегистрации МЕЖДУ &ДатаРегистрацииДатаНачала И &ДатаРегистрацииДатаОкончания"; 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", УсловиеДатаСоздания);
		ДатаНачала = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаНачала;
		ДатаОкончания = СтруктураОтборов.ОтборДатаСоздания[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаНачала"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));
		Запрос.УстановитьПараметр("ДатаРегистрацииДатаОкончания", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));

	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаСоздания", "ИСТИНА")		
	КонецЕсли;	
		
	// Отбор дата запланированной задачи.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборДатаЗапланированнойЗадачи) Тогда
		Если СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала = Дата(1, 1, 1) И СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания = НачалоДня(ТекущаяДатаСеанса()) - 1  Тогда
			УсловиеДатаЗапланированнойЗадачи = "КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи";
		Иначе 	
			УсловиеДатаЗапланированнойЗадачи = "(КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи ИЛИ КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи ИЛИ &ДатаНачалаЗапланированнойЗадачи <= КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДатаНачало И &ДатаОкончанияЗапланированнойЗадачи <= КонтрагентыСведенияДляСписка.СледующаяЗадача.ЗадачаНазначеннаяДата)";
		КонецЕсли;
		Запрос.Текст 	= СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", УсловиеДатаЗапланированнойЗадачи);
		ДатаНачала 		= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаНачала;
		ДатаОкончания 	= СтруктураОтборов.ОтборДатаЗапланированнойЗадачи[0].Значение.ДатаОкончания;
		Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"   , ?(ЗначениеЗаполнено(ДатаНачала),     ДатаНачала, Дата(01,01,0001)));	
		Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи", ?(ЗначениеЗаполнено(ДатаОкончания),  ДатаОкончания, Дата(3999,12,31)));
	Иначе                               
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатаЗапланированнойЗадачи", "ИСТИНА");
	КонецЕсли;
	
	// Отбор без задач.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЗадача)
		И СтруктураОтборов.ОтборЗадача[0].Значение = Ложь Тогда
		
		УсловиеОтборБезЗадач = СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.СледующаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)";	
		Если СтруктураОтборов.ОтборЗадача.ДоступныеЗначения[0].Представление = "НЕ " Тогда 
			УсловиеОтборБезЗадач = УсловиеОтборБезЗадач + " И КонтрагентыСведенияДляСписка.СледующаяЗадача.ПометкаУдаления = ЛОЖЬ И КонтрагентыСведенияДляСписка.СледующаяЗадача.Выполнена = ЛОЖЬ";
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", УсловиеОтборБезЗадач);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезЗадач", "ИСТИНА");
	КонецЕсли;
		
	// Отбор без сделок.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборСделка)
		И СтруктураОтборов.ОтборСделка[0].Значение = Ложь Тогда
		
		УсловиеОтборБезСделок = СтруктураОтборов.ОтборСделка.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.ТекущаяСделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезСделок", УсловиеОтборБезСделок);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОтборБезСделок", "ИСТИНА");
	КонецЕсли;
		
	// Отбор этап сделки.
	Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление + "КонтрагентыСведенияДляСписка.ТекущийЭтапСделки В (&ОтборЭтап)");		
		Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");		
	КонецЕсли;
			
	Возврат Запрос;
	
КонецФункции	

&НаСервере
// Функция - Получить запрос для динамического списка файловый вариант
//
// Параметры:
//  СтруктураОтборов - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗапросДляДинамическогоСпискаФайловыйВариант(СтруктураОтборов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Взаимодействие.Ссылка КАК Взаимодействие,
	               |	Взаимодействие.Выполнена КАК Выполнена
	               |ПОМЕСТИТЬ ВременнаяТаблицаВзаимодействий
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Выполнена
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Выполнена
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.ЗадачаНазначеннаяДатаНачало МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Выполнена
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Выполнена
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.ЗадачаНазначеннаяДатаНачало >= &ДатаНачалаЗапланированнойЗадачи
	               |	И Взаимодействие.ЗадачаНазначеннаяДата >= &ДатаОкончанияЗапланированнойЗадачи
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Взаимодействие.Ссылка,
	               |	Взаимодействие.Выполнена
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Контрагенты.Ссылка КАК Клиент,
	               |	Контрагенты.Код КАК Код,
	               |	КонтрагентыСведенияДляСписка.Статус КАК Статус,
	               |	КонтрагентыСведенияДляСписка.Телефон КАК Телефон,
	               |	КонтрагентыСведенияДляСписка.АдресЭП КАК АдресЭП,
	               |	Контрагенты.Куратор КАК Менеджер,
	               |	Контрагенты.ИсточникИнформации КАК ИсточникИнформации,
	               |	Контрагенты.ДатаРегистрации КАК ДатаРегистрации,
	               |	Контрагенты.СотрудникРегистрации КАК СотрудникРегистрации,
	               |	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК ТекущаяСделка,
	               |	КонтрагентыСведенияДляСписка.ТекущийЭтапСделки КАК ТекущийЭтапСделки,
	               |	КонтрагентыСведенияДляСписка.СуммаСделки КАК СуммаСделки,
	               |	КонтрагентыСведенияДляСписка.ПоследняяЗадача КАК ПоследняяЗадача,
	               |	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача,
	               |	КонтрагентыСведенияДляСписка.ПоследняяЗадачаПредставление КАК ПоследняяЗадачаПредставление,
	               |	КонтрагентыСведенияДляСписка.СледующаяЗадачаПредставление КАК СледующаяЗадачаПредставление,
	               |	ВЫРАЗИТЬ(КонтрагентыСведенияДляСписка.ТекущийЭтапСделки.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
