			ИначеЕсли ПараметрЗадача = "СайтСтруктурнойЕдиницы" Тогда
				РезультатЗадача = "{СайтКлиники}";  
			ИначеЕсли ПараметрЗадача = "ФамилияКонтрагента" Тогда
				РезультатЗадача = "{ФамилияПациента}";                             
			ИначеЕсли ПараметрЗадача = "ИмяКонтрагента" Тогда
				РезультатЗадача = "{ИмяПациента}";                               
			ИначеЕсли ПараметрЗадача = "ОтчествоКонтрагента" Тогда
