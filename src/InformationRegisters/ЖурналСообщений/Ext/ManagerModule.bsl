
#Область СлужебныеПроцедурыИФункции

// Функция - Получить структуру полей сообщения
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктуруПолейСообщения()
	
	СтруктураПолейСообщения = Новый Структура;
	СтруктураПолейСообщения.Вставить("ТекстСообщения");
	СтруктураПолейСообщения.Вставить("ТекстСообщенияUTF8");	
	СтруктураПолейСообщения.Вставить("ДатаСообщения");
	СтруктураПолейСообщения.Вставить("Мессенджер");
	СтруктураПолейСообщения.Вставить("Прочитано");
	СтруктураПолейСообщения.Вставить("СлужебноеСообщение");
	СтруктураПолейСообщения.Вставить("СообщениеОтКлиента");
	СтруктураПолейСообщения.Вставить("ИдКанала");
	СтруктураПолейСообщения.Вставить("ИдСообщения");
	СтруктураПолейСообщения.Вставить("ОператорСообщения");
	СтруктураПолейСообщения.Вставить("ОбъектИдентификации");
	СтруктураПолейСообщения.Вставить("НаименованиеКлиента");
	СтруктураПолейСообщения.Вставить("ОжиданиеСообщения");
	СтруктураПолейСообщения.Вставить("ЭтоПересланноеСообщение");
	
	Возврат СтруктураПолейСообщения;
	
КонецФункции

// Процедура, добавляет запись в регистр сведений.
//
Процедура ДобавитьЗапистьЖурналСообщений(
	ИдКлиента,	
	ИдСообщения, 
	ИдОператора          	= Неопределено, 
	ИдКанала, 
	ТекстСообщения, 
	Прочитано, 
	Мессенджер, 
	СообщениеОтКлиента, 
	ДатаСообщения, 
	ВнешняяСистема, 
	ОператорСообщения    	= Неопределено,
	Аудиозапись          	= Неопределено,
	Изображение          	= Неопределено,
	PDF                  	= Неопределено,
	Триггер              	= Ложь,
	ИдНаписавшегоВГруппу 	= "",
	ОжиданиеСообщения    	= Ложь,
	СтруктураСообщения	 	= Неопределено,
	ИдДиалога			 	= Неопределено,
	СлужебноеСообщение	 	= Ложь,
	ДополнительныеПараметры = Неопределено,
	ЭтоПересланноеСообщение	= Ложь) Экспорт
	
	СообщениеЗакодировано 			= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "СообщениеЗакодировано", Ложь);
	
	Если СтрДлина(ТекстСообщения) > 0 И НЕ СообщениеЗакодировано Тогда
		ТекстСообщения 				= ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(ТекстСообщения, "(смайл)");
	КонецЕсли;
	
	ОператорСообщения 	= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ОператорСообщения", ОператорСообщения);
	Триггер 			= ?(ТипЗнч(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ПараметрыРегистрацииТриггера", Триггер)) = Тип("Структура"), Истина, Триггер);
	СтартСценария 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "СтартСценария", Ложь);
	
	Если НЕ СтартСценария И НЕ ЗначениеЗаполнено(ИдДиалога) И (СообщениеОтКлиента ИЛИ ЗначениеЗаполнено(ОператорСообщения)) Тогда
		ИдДиалога 					= РегистрыСведений.Диалоги.ПолучитьИдВозобновленногоДиалога(ИдКлиента, ВнешняяСистема, ДатаСообщения, ОператорСообщения);
	КонецЕсли;
	
	ПериодЗаписи = ?(ЗначениеЗаполнено(ДатаСообщения), ДатаСообщения, ТекущаяДатаСеанса());
		
	ЗавершитьДиалогиЧатБота 		= Ложь;
	ПричинаЗавершения 				= "";
	Если СтартСценария Тогда 
		ЗавершитьДиалогиЧатБота 	= Истина;
		ПричинаЗавершения 			= "Завершен по причине старта следующего сценария!";
	ИначеЕсли НЕ СлужебноеСообщение И НЕ СообщениеОтКлиента Тогда 
		ЧатБот = Константы.СотрудникЧатБота.Получить();	
		Если ЗначениеЗаполнено(ЧатБот) И НЕ ОператорСообщения = ЧатБот Тогда
			ЗавершитьДиалогиЧатБота = Истина;
			ПричинаЗавершения 		= "Завершен по причине начала активности менеджера!";			
		КонецЕсли;	
	КонецЕсли;
	
	Если ЗавершитьДиалогиЧатБота Тогда 
		// Это пишет менеджер - закрываем все диалоги по сценариям чат-бота
		РегистрыСведений.Диалоги.ЗавершитьДиалогиЧатБота(ИдКлиента
														, ВнешняяСистема
														, Мессенджер
														, ПериодЗаписи - 2
														, ПричинаЗавершения);
		Если СтартСценария Тогда 												
			ДополнительныеПараметры.СтартСценария = Ложь;
		КонецЕсли;	
	КонецЕсли;
	
	НаборЗаписейСообщения = СоздатьНаборЗаписей();
	НаборЗаписейСообщения.Отбор.Период.Установить(ПериодЗаписи);
	НаборЗаписейСообщения.Отбор.ВнешняяСистема.Установить(ВнешняяСистема);
	НаборЗаписейСообщения.Отбор.ИдКлиента.Установить(ИдКлиента);
	НаборЗаписейСообщения.Отбор.ИдСообщения.Установить(ИдСообщения);
	
	НоваяЗапись							= НаборЗаписейСообщения.Добавить();
	НоваяЗапись.Период					= ПериодЗаписи;
	НоваяЗапись.ВнешняяСистема			= ВнешняяСистема;	
	НоваяЗапись.ИдКлиента				= ИдКлиента;
	НоваяЗапись.ИдСообщения				= ИдСообщения;
	НоваяЗапись.ИдОператора				= ИдОператора;
	НоваяЗапись.ИдКанала				= ИдКанала;
	Если СообщениеЗакодировано Тогда 
		НоваяЗапись.ТекстСообщения		= РаскодироватьСтроку(ТекстСообщения, СпособКодированияСтроки.URLВКодировкеURL);
		НоваяЗапись.ТекстСообщенияUTF8	= ТекстСообщения;
	Иначе 
		НоваяЗапись.ТекстСообщения		= ТекстСообщения;
		НоваяЗапись.ТекстСообщенияUTF8	= КодироватьСтроку(ТекстСообщения, СпособКодированияСтроки.URLВКодировкеURL);
	КонецЕсли;	
	НоваяЗапись.Прочитано				= Прочитано;
	НоваяЗапись.Мессенджер				= Мессенджер;
	НоваяЗапись.СообщениеОтКлиента		= СообщениеОтКлиента;
	НоваяЗапись.ДатаСообщения			= ДатаСообщения;
	НоваяЗапись.ОператорСообщения		= ОператорСообщения;
	НоваяЗапись.Аудио					= Аудиозапись;
	НоваяЗапись.Изображение				= Изображение;
	НоваяЗапись.PDF						= PDF;
	НоваяЗапись.Триггер					= Триггер;
	НоваяЗапись.ИдНаписавшегоВГруппу	= ИдНаписавшегоВГруппу;
	НоваяЗапись.ОжиданиеСообщения		= ОжиданиеСообщения;
	НоваяЗапись.СлужебноеСообщение		= СлужебноеСообщение;
	НоваяЗапись.ЭтоПересланноеСообщение	= ЭтоПересланноеСообщение;
	НоваяЗапись.ИдДиалога				= ?(
		ЗначениеЗаполнено(ИдДиалога),
		ИдДиалога,
		РегистрыСведений.Диалоги.ПолучитьТекущийДиалог(
			ИдКлиента,
			ВнешняяСистема,
			ОператорСообщения,
			ДатаСообщения,
			СообщениеОтКлиента,
			Мессенджер,
			ДополнительныеПараметры
		)
	);	
	
	Если СтруктураСообщения <> Неопределено Тогда
		СтруктураСообщения = Новый Структура(
		"ИдКлиента, ИдСообщения, ИдКанала, ТекстСообщения, Прочитано,
		|Мессенджер, СообщениеОтКлиента, ДатаСообщения, ВнешняяСистема,
		|ОператорСообщения, Аудио, Изображение, PDF, ОжиданиеСообщения,
		|ИдДиалога, СлужебноеСообщение, ЭтоПересланноеСообщение");
		ЗаполнитьЗначенияСвойств(СтруктураСообщения, НоваяЗапись);		
	КонецЕсли;
	
	// Пробрасываем все параметры в доп. свойства набора
	Если НЕ ДополнительныеПараметры = Неопределено И ТипЗнч(ДополнительныеПараметры) = Тип("Структура") Тогда 
		Для Каждого ЭлементКоллекции Из ДополнительныеПараметры Цикл 
			НаборЗаписейСообщения.ДополнительныеСвойства.Вставить(ЭлементКоллекции.Ключ, ЭлементКоллекции.Значение);
		КонецЦикла;
	КонецЕсли;
	НаборЗаписейСообщения.ОбменДанными.Загрузка = Истина;		
	НаборЗаписейСообщения.Записать();
	
	РегистрыСведений.ЖурналНепрочитанныхСообщений.ДобавитьЗаписиПоНовомуСообщению(ВнешняяСистема, ИдКлиента);
	РегистрыСведений.Диалоги.ОбновитьДанныеДиалога(НоваяЗапись);	
	
КонецПроцедуры

// Процедура, возвращает ссылку на изображение по ид сообщения.
//
Функция ПолучитьСсылкуНаИзображение(ИдСообщения, ВнешняяСистема) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЖурналСообщений.Изображение КАК Изображение
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдСообщения = &ИдСообщения
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема");
	
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	Запрос.УстановитьПараметр("ИдСообщения"   , ИдСообщения);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Изображение, Неопределено);
		
КонецФункции

// Функция, возвращает данные сообщения по идентификатору.
//
Функция ПолучитьДанныеСообщенияПоИд(ИдСообщения, ВнешняяСистема, ВозвращатьСтруктуру = Ложь, ИдКлиента = "") Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЖурналСообщений.ТекстСообщения КАК ТекстСообщения,
	|	ЖурналСообщений.ДатаСообщения КАК ДатаСообщения,
	|	ЖурналСообщений.Мессенджер КАК Мессенджер,
	|	ЖурналСообщений.Прочитано КАК Прочитано,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	ЖурналСообщений.ИдНаписавшегоВГруппу КАК ИдентификаторОтправителя,
	|	ЖурналСообщений.ИдДиалога КАК ИдДиалога,
	|	ЖурналСообщений.СлужебноеСообщение КАК СлужебноеСообщение,
	|	ЖурналСообщений.СообщениеОтКлиента КАК СообщениеОтКлиента,
	|	ЖурналСообщений.ИдКанала КАК ИдКанала,
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения,
	|	ЖурналСообщений.ОператорСообщения КАК ОператорСообщения,
	|	ЖурналСообщений.Изображение КАК Изображение,
	|	ЖурналСообщений.Аудио КАК Аудио,
	|	ЖурналСообщений.PDF КАК PDF,
	|	ЖурналСообщений.ОжиданиеСообщения КАК ОжиданиеСообщения,
	|	ЖурналСообщений.ЭтоПересланноеСообщение КАК ЭтоПересланноеСообщение,
	|	КонтактыМессенджеров.ФотоКлиента КАК ФотоКлиента,
	|	КонтактыМессенджеров.НаименованиеКлиента КАК НаименованиеКлиента,
	|	КонтактыМессенджеров.ОбъектИдентификации КАК ОбъектИдентификации,
	|	КонтактыМессенджеров.ОбъектИдентификации.Наименование КАК ОбъектИдентификацииНаименование,
	|	ЕСТЬNULL(Диалоги.Оператор, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК Оператор,
	|	ЕСТЬNULL(Диалоги.Окончание, ДАТАВРЕМЯ(1, 1, 1)) КАК ДиалогОкончание,
	|	ЕСТЬNULL(Диалоги.ОтложенДо, ДАТАВРЕМЯ(1, 1, 1)) КАК ДиалогОтложенДо
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|		ПО ЖурналСообщений.ИдКлиента = КонтактыМессенджеров.Идентификатор
	|			И ЖурналСообщений.ВнешняяСистема = КонтактыМессенджеров.ВнешняяСистема
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Диалоги КАК Диалоги
	|		ПО ЖурналСообщений.ИдДиалога = Диалоги.ИдДиалога
	|ГДЕ
	|	ЖурналСообщений.ИдСообщения = &ИдСообщения
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема");
	
	Если СтрЧислоВхождений(ИдСообщения, Строка(ВнешняяСистема.УникальныйИдентификатор())) > 0 Тогда
		ПодстрокаПоиска = "_" + Строка(ВнешняяСистема.УникальныйИдентификатор());
		ИдСообщения = СтрЗаменить(ИдСообщения, ПодстрокаПоиска, "");
	КонецЕсли;

	Запрос.УстановитьПараметр("ИдСообщения"   , ИдСообщения);
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	// Если это группа.
	Если ЗначениеЗаполнено(ИдКлиента) И СтрНайти(ИдКлиента, "@g.us") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПО ЖурналСообщений.ИдКлиента", "ПО ЖурналСообщений.ИдНаписавшегоВГруппу");	
	КонецЕсли;
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ВозвращатьСтруктуру = Истина Тогда
		Возврат ТаблицуЗначенийВМассивСтруктур(Результат.Выгрузить())[0];
	Иначе
		Выборка = Запрос.Выполнить().Выбрать();
		Возврат ?(Выборка.Следующий(), Выборка, Неопределено);
	КонецЕсли;
	
КонецФункции	

// Функция - Получить данные последнего сообщения
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  ИдКлиента		 - 	 - 
//  ИдДиалога		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеПоследнегоСообщения(ВнешняяСистема, ИдКлиента, ИдДиалога = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЖурналСообщений.ТекстСообщения КАК ТекстСообщения,
	|	ЖурналСообщений.ДатаСообщения КАК ДатаСообщения,
	|	ЖурналСообщений.Мессенджер КАК Мессенджер,
	|	ЖурналСообщений.Прочитано КАК Прочитано,
	|	ЖурналСообщений.СлужебноеСообщение КАК СлужебноеСообщение,
	|	ЖурналСообщений.СообщениеОтКлиента КАК СообщениеОтКлиента,
	|	ЖурналСообщений.ИдКанала КАК ИдКанала,
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения,
	|	ЖурналСообщений.ОператорСообщения КАК ОператорСообщения,
	|	КонтактыМессенджеров.ОбъектИдентификации КАК ОбъектИдентификации,
	|	КонтактыМессенджеров.НаименованиеКлиента КАК НаименованиеКлиента,
	|	ЖурналСообщений.ОжиданиеСообщения КАК ОжиданиеСообщения,
	|	ЖурналСообщений.ЭтоПересланноеСообщение КАК ЭтоПересланноеСообщение
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|		ПО ЖурналСообщений.ИдКлиента = КонтактыМессенджеров.Идентификатор
	|			И ЖурналСообщений.ВнешняяСистема = КонтактыМессенджеров.ВнешняяСистема
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ИдДиалога = &ИдДиалога
	|	И ЖурналСообщений.СлужебноеСообщение = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСообщения УБЫВ";
	
	Если ЗначениеЗаполнено(ИдДиалога) Тогда 
		Запрос.УстановитьПараметр("ИдДиалога"	, ИдДиалога);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЖурналСообщений.ИдДиалога = &ИдДиалога", "ИСТИНА");
	КонецЕсли;	
	
	ДанныеСообщения 	= ПолучитьСтруктуруПолейСообщения();
	
	ВыборкаДанныхСообщения = Запрос.Выполнить().Выбрать();
	Если ВыборкаДанныхСообщения.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(ДанныеСообщения, ВыборкаДанныхСообщения);
	КонецЕсли;

	Возврат ДанныеСообщения;
	
КонецФункции

// Функция, возвращает наличие сообщения по идентификатору.
//
Функция НаличиеСообщенияПоИд(ИдСообщения, ВнешняяСистема) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|		ПО ЖурналСообщений.ИдКлиента = КонтактыМессенджеров.Идентификатор
	|			И ЖурналСообщений.ВнешняяСистема = КонтактыМессенджеров.ВнешняяСистема
	|ГДЕ
	|	ЖурналСообщений.ИдСообщения = &ИдСообщения
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема");
	
	Запрос.УстановитьПараметр("ИдСообщения"   , ИдСообщения);
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	// Если это группа и сообщение от клиента.
	Если СтрНайти(ИдСообщения, "@g.us") И СтрНайти(ИдСообщения, "false") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПО ЖурналСообщений.ИдКлиента", "ПО ЖурналСообщений.ИдНаписавшегоВГруппу");	
	КонецЕсли;
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, возвращает последнее сообщение по идентификатору.
//
Функция ПолучитьИдОператора(ИдКлиента, ВнешняяСистема) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЖурналСообщений.ИдОператора КАК ИдОператора
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И НЕ ЖурналСообщений.СообщениеОтКлиента
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЖурналСообщений.Период УБЫВ");
	
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	Запрос.УстановитьПараметр("ИдКлиента"     , ИдКлиента);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.ИдОператора, Неопределено);
	
КонецФункции

// Функция, возвращает диалоги мессенджера.
//
Функция ПолучитьСписокДиалогов(ПараметрыМессенджера) Экспорт 
		
	ОсновнойФильтр			 = ПараметрыМессенджера.ОсновнойФильтр;
	ДополнительныйФильтр	 = ПараметрыМессенджера.ДополнительныйФильтр;
	
	Оператор				 = ПараметрыМессенджера.Оператор;
	ДатаПоследнегоСообщения	 = ПараметрыМессенджера.ДатаПоследнегоСообщения;
	Количество				 = ПараметрыМессенджера.Количество;
	Поиск					 = ПараметрыМессенджера.Поиск;
	ТекстПоиска				 = ПараметрыМессенджера.ТекстПоиска;
	ВнешняяСистема			 = ПараметрыМессенджера.ВнешниеСистемы;
	
	Если ТипЗнч(ВнешняяСистема) = Тип("Строка") Тогда
		
		МассивВС = Новый Массив;
		МассивИдентификаторов = СтрРазделить(ВнешняяСистема, ",", Ложь);
		
		#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
			
			Для Каждого ИдентификаторВнешнейСистемы Из МассивИдентификаторов Цикл
				
				ВнешняяСистемаСсылка = ПолучитьСсылкуОбъектаПоUID("Справочники", "ВнешниеСистемы", ИдентификаторВнешнейСистемы);
				
				Если ЗначениеЗаполнено(ВнешняяСистемаСсылка) Тогда
					МассивВС.Добавить(ВнешняяСистемаСсылка);
				КонецЕсли; 
				
			КонецЦикла;
			
		#КонецЕсли
			
	ИначеЕсли ТипЗнч(ВнешняяСистема) <> Тип("Массив") Тогда 
		МассивВС = Новый Массив;
		МассивВС.Добавить(ВнешняяСистема);
		
	Иначе
		МассивВС = ВнешняяСистема;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаПоследнегоСообщения) И ТипЗнч(ДатаПоследнегоСообщения) = Тип("Строка") Тогда
		ДатаПоследнегоСообщения = Дата(ДатаПоследнегоСообщения);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ЗаполнитьТекстЗапросаПолученияСпискаДиалогов(Запрос);
	
	УсловиеКоличества	 = "";
	УсловиеДатыСреза	 = "ИСТИНА";
	УсловиеПоиска		 = "ИСТИНА";
	ПоискСоединение		 = "";
	
	Если Не Поиск И Количество = 0 Тогда
		ЗнакДатыСреза = ">=";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекущаяДата", "");
	Иначе
		УсловиеКоличества = "ПЕРВЫЕ " + Количество;
		ЗнакДатыСреза = "<";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаПоследнегоСообщения) И Не Поиск Тогда
		УсловиеДатыСреза = "ЖурналСообщений.Период " + ЗнакДатыСреза + " &ДатаСообщения";
	КонецЕсли;
	
	УсловиеОсновнойФильтр		 = "ИСТИНА";
	УсловиеДополнительныйФильтр	 = "ИСТИНА";
	
	Если ОсновнойФильтр = "Не назначены" Тогда
		
		УсловиеОсновнойФильтр		 = "Диалоги.Оператор = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)";
		УсловиеДополнительныйФильтр	 = "Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1) И Диалоги.ОтложенДо < &ТекущаяДата";
		
	Иначе
		
		Если ДополнительныйФильтр = "Без ответа" Тогда
			
			УсловиеДополнительныйФильтр = "Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1) И Диалоги.ПоследнееСообщениеОтКлиента";
			
		ИначеЕсли ДополнительныйФильтр = "Открытые" Тогда
			
			УсловиеДополнительныйФильтр = "Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1) И Диалоги.ОтложенДо < &ТекущаяДата";
			
		ИначеЕсли ДополнительныйФильтр = "Отложенные" Тогда
			
			УсловиеДополнительныйФильтр = "Диалоги.Окончание = ДАТАВРЕМЯ(1, 1, 1) И Диалоги.ОтложенДо > &ТекущаяДата";
			
		ИначеЕсли ДополнительныйФильтр = "Закрытые" Тогда
			
			УсловиеДополнительныйФильтр = "Диалоги.Окончание <> ДАТАВРЕМЯ(1, 1, 1)";
			
		КонецЕсли;
		
		Если ОсновнойФильтр = "Мои" Тогда
			
			УсловиеОсновнойФильтр = "Диалоги.Оператор = &Оператор";
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Поиск Тогда
		УсловиеПоиска =
		"(КонтактыМессенджеров.НаименованиеКлиента ПОДОБНО &ТекстПоиска
		|	ИЛИ КонтактыМессенджеров.НомерМессенджера ПОДОБНО &ТекстПоиска
		| 	ИЛИ ЕСТЬNULL(КонтактыМессенджеров.ОбъектИдентификации.Наименование, """") ПОДОБНО &ТекстПоиска
		|	ИЛИ ВЫБОР КОГДА КонтактыМессенджеров.ОбъектИдентификации ССЫЛКА Справочник.Контрагенты ТОГДА (Неопределено В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				Неопределено
		|			ИЗ
		|				Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|			ГДЕ
		|				КонтрагентыКонтактнаяИнформация.Ссылка = КонтактыМессенджеров.ОбъектИдентификации
		|				И КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &ТекстПоиска))
		|		КОГДА КонтактыМессенджеров.ОбъектИдентификации ССЫЛКА Справочник.Заявки ТОГДА (Неопределено В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				Неопределено
		|			ИЗ
		|				Справочник.Заявки.КонтактнаяИнформация КАК ЗаявкиКонтактнаяИнформация
		|			ГДЕ
		|				ЗаявкиКонтактнаяИнформация.Ссылка = КонтактыМессенджеров.ОбъектИдентификации
		|				И ЗаявкиКонтактнаяИнформация.НомерТелефона ПОДОБНО &ТекстПоиска))
		|			ИНАЧЕ ЛОЖЬ КОНЕЦ)";
		УсловиеКоличества = "ПЕРВЫЕ 50";
		ПоискСоединение =
		"ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
		|		ПО (ПоследниеСообщения.ИдКлиента = КонтактыМессенджеров.Идентификатор
		|			И ПоследниеСообщения.ВнешняяСистема = КонтактыМессенджеров.ВнешняяСистема)";
		
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст,
			"И Диалоги.СценарийЧатБота = ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)",
			""
		);
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 2"				, УсловиеКоличества);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПоискСоединение"		, ПоискСоединение);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоиска"		, УсловиеПоиска);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОсновнойФильтр"		, УсловиеОсновнойФильтр);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ДополнительныйФильтр", УсловиеДополнительныйФильтр);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеДатыСреза"	, УсловиеДатыСреза);
	
	Запрос.УстановитьПараметр("ВнешняяСистема", МассивВС);
	Запрос.УстановитьПараметр("ДатаСообщения" , ДатаПоследнегоСообщения);
	Запрос.УстановитьПараметр("ТекущаяДата"   , ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ТекстПоиска"   , "%"+ТекстПоиска+"%");
	Запрос.УстановитьПараметр("Оператор"	  , Оператор);
	
	Результат = Запрос.ВыполнитьПакет();
	
	// Последние 3 запроса в пакете - запросы количества контактов в фильтрах.
	КоличествоОтложенные = Результат[Результат.ВГраница() - 2].Выгрузить()[0].КоличествоОтложенные;
	КоличествоОткрытые	 = Результат[Результат.ВГраница() - 1].Выгрузить()[0].КоличествоОткрытые;
	КоличествоБезОтвета	 = Результат[Результат.ВГраница()].Выгрузить()[0].КоличествоБезОтвета;
	
	ТаблицаКонтактов = Результат[Результат.ВГраница() - 3].Выгрузить();
	
	ДанныеКонтактов = Новый Структура;
	ДанныеКонтактов.Вставить("ТаблицаКонтактов"		, ТаблицаКонтактов);
	ДанныеКонтактов.Вставить("КоличествоОтложенные"	, КоличествоОтложенные);
	ДанныеКонтактов.Вставить("КоличествоОткрытые"	, КоличествоОткрытые);
	ДанныеКонтактов.Вставить("КоличествоБезОтвета"	, КоличествоБезОтвета);
	
	Возврат ДанныеКонтактов;
	
КонецФункции

// Функция, возвращает список сообщений клиента.
//
Функция ПолучитьСписокСообщений(ИдКлиента, ДанныеПоследнегоСообщения, ВнешняяСистема) Экспорт
	
	ЭтоГруппа = РегистрыСведений.КонтактыМессенджеров.ЭтоГруппа(ИдКлиента, ВнешняяСистема);
	
	Если ЭтоГруппа = Истина Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 200
		|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
		|	ЖурналСообщений.ИдСообщения КАК ИдСообщения,
		|	ЖурналСообщений.ТекстСообщения КАК ТекстСообщения,
		|	ЖурналСообщений.СлужебноеСообщение КАК СлужебноеСообщение,
		|	ЖурналСообщений.ИдДиалога КАК ИдДиалога,
		|	ЖурналСообщений.СообщениеОтКлиента КАК СообщениеОтКлиента,
		|	ЖурналСообщений.ДатаСообщения КАК ДатаСообщения,
		|	ЖурналСообщений.Прочитано КАК Прочитано,
		|	ЖурналСообщений.Мессенджер КАК Мессенджер,
		|	ЖурналСообщений.ОператорСообщения КАК ОператорСообщения,
		|	ЖурналСообщений.ОператорСообщения.Наименование КАК НаименованиеОператораСообщения,
		|	ЖурналСообщений.PDF КАК PDF,
		|	ЖурналСообщений.Аудио КАК Аудио,
		|	ЖурналСообщений.Изображение КАК Изображение,
		|	ЖурналСообщений.ЭтоПересланноеСообщение КАК ЭтоПересланноеСообщение,
		|	ЖурналСообщений.ИдНаписавшегоВГруппу КАК ИдентификаторОтправителя,
		|	КонтактыМессенджеров.ОбъектИдентификации КАК ОбъектИдентификации,
		|	КонтактыМессенджеров.ОбъектИдентификации.Наименование КАК ОбъектИдентификацииНаименование,
		|	КонтактыМессенджеров.ФотоКлиента КАК ФотоКлиента,
		|	КонтактыМессенджеров.НаименованиеКлиента КАК НаименованиеКлиента
		|ИЗ
		|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
		|		ПО ЖурналСообщений.ВнешняяСистема = КонтактыМессенджеров.ВнешняяСистема
		|			И ЖурналСообщений.ИдНаписавшегоВГруппу = КонтактыМессенджеров.Идентификатор
		|ГДЕ
		|	ЖурналСообщений.ИдКлиента = &ИдКлиента
		|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
		|	И НЕ ЖурналСообщений.ОжиданиеСообщения
		|	И &УсловиеДата
		|	И &УсловиеИд
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСообщения УБЫВ,
		|	ИдСообщения УБЫВ");
		
	Иначе
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 200
		|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
		|	ЖурналСообщений.ИдСообщения КАК ИдСообщения,
		|	ЖурналСообщений.ТекстСообщения КАК ТекстСообщения,
		|	ЖурналСообщений.СлужебноеСообщение КАК СлужебноеСообщение,
		|	ЖурналСообщений.ИдДиалога КАК ИдДиалога,
		|	ЖурналСообщений.СообщениеОтКлиента КАК СообщениеОтКлиента,
		|	ЖурналСообщений.ДатаСообщения КАК ДатаСообщения,
		|	ЖурналСообщений.Прочитано КАК Прочитано,
		|	ЖурналСообщений.Мессенджер КАК Мессенджер,
		|	ЖурналСообщений.ОператорСообщения КАК ОператорСообщения,
		|	ЖурналСообщений.ОператорСообщения.Наименование КАК НаименованиеОператораСообщения,
		|	ЖурналСообщений.PDF КАК PDF,
		|	ЖурналСообщений.Аудио КАК Аудио,
		|	ЖурналСообщений.Изображение КАК Изображение,
		|	ЖурналСообщений.ЭтоПересланноеСообщение КАК ЭтоПересланноеСообщение,
		|	NULL КАК ИдентификаторОтправителя,
		|	NULL КАК ОбъектИдентификации,
		|	NULL КАК ОбъектИдентификацииНаименование,
		|	NULL КАК ФотоКлиента,
		|	NULL КАК НаименованиеКлиента
		|ИЗ
		|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
		|ГДЕ
		|	ЖурналСообщений.ИдКлиента = &ИдКлиента
		|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
		|	И НЕ ЖурналСообщений.ОжиданиеСообщения
		|	И &УсловиеДата
		|	И &УсловиеИд
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСообщения УБЫВ,
		|	ИдСообщения УБЫВ");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеПоследнегоСообщения) Тогда
		
		УсловиеДата	 = ?(ЗначениеЗаполнено(ДанныеПоследнегоСообщения.ДатаСообщения), "И ЖурналСообщений.Период <= &ДатаПоследнегоСообщения", "");
		УсловиеИд	 = ?(ЗначениеЗаполнено(ДанныеПоследнегоСообщения.ИдСообщения), "И ЖурналСообщений.ИдСообщения <> &ИдПоследнегоСообщения", "");
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеДата"	, УсловиеДата);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеИд"		, УсловиеИд);
		
		Запрос.УстановитьПараметр("ДатаПоследнегоСообщения" , Дата(ДанныеПоследнегоСообщения.ДатаСообщения));
		Запрос.УстановитьПараметр("ИдПоследнегоСообщения"	, ДанныеПоследнегоСообщения.ИдСообщения);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеДата"	, "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеИд"		, "");
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ИдКлиента"     	, ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Новый Структура("Диалог", Результат);
	
КонецФункции

