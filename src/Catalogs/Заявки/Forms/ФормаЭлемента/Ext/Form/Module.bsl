	//КонецЕсли;
	
	ЭтаФорма.Записать();
	Элементы.ПоказатьНаличиеДублейКлиентов.Видимость = Ложь; 
	Элементы.ОткрытьКонтрагента.Заголовок = Объект.Наименование;
