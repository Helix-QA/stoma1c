// Процедура - Добавить массив документов оплаты в очередь
//
// Параметры:
//  МассивДокументовОплаты	 - 	 - 
//
Процедура ДобавитьМассивДокументовОплатыВОчередь(МассивДокументовОплаты, НеВыполнятьПроверки = Ложь) Экспорт
	
	Для Каждого ДокументОплаты Из МассивДокументовОплаты Цикл
		
		Если НЕ ЗначениеЗаполнено(ДокументОплаты.НомерЧекаККМ)
			И ДокументОплаты.Проведен Тогда
			
			ДобавитьДокументОплатыВОчередь(ДокументОплаты, НеВыполнятьПроверки);
			
		КонецЕсли;
		
	КонецЦикла;
			
КонецПроцедуры

// Процедура - Записать признак начала пробития чека
//
// Параметры:
//  ДокументОплаты	 - 	 - 
//
Процедура ЗаписатьПризнакНачалаПробитияЧека(ДокументОплаты) Экспорт
	
	НомерТекущегоСеанса = НомерСеансаИнформационнойБазы();
	
	СчетчикПопыток = 0;
	
	Пока СчетчикПопыток < 5 Цикл
		
		НачатьТранзакцию();
		
		Попытка 
			
			МенеджерЗаписи                    = РегистрыСведений.ОчередьКассовогоСервера.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.ДокументОплаты     = ДокументОплаты;
			МенеджерЗаписи.Прочитать();
			
			МенеджерЗаписи.НомерСеансаИБ        = НомерТекущегоСеанса;
            МенеджерЗаписи.Статус               = Перечисления.СтатусыПробитияЧекаКассовымСервером.Пробивается;

			МенеджерЗаписи.Записать();
			
			ЗафиксироватьТранзакцию();
			
			Прервать;
			
		Исключение	
			
			ОтменитьТранзакцию();
			
			ОписаниеОшибки = ОписаниеОшибки();
			
			СчетчикПопыток = СчетчикПопыток + 1;
			
			Если СчетчикПопыток = 5 Тогда
				ВызватьИсключение ОписаниеОшибки;
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;

	
КонецПроцедуры

// Процедура - Записать признак начала пробития чека для массива документов
//
// Параметры:
//  МассивДокументовОплаты	 - 	 - 
//
Процедура ЗаписатьПризнакНачалаПробитияЧекаДляМассиваДокументов(МассивДокументовОплаты) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого ДокументОплаты Из МассивДокументовОплаты Цикл
		
		Если НЕ ЗначениеЗаполнено(ДокументОплаты.НомерЧекаККМ)
			И ДокументОплаты.Проведен Тогда
			
			ЗаписатьПризнакНачалаПробитияЧека(ДокументОплаты);
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

// Процедура - Записать признак успешного пробития чека
