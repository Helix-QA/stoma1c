// Функция - Получить таблицу париодов.
//
// Параметры:
//  Начало	 - 	 - 
//  Конец	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуПериодов(ДатаНачало, ДатаКонец, ПериодичностьПроверяемая)
	
	КоличествоДнейОтображаемых = (ДатаКонец + 1 - ДатаНачало)/(24*60*60);
	
	Если КоличествоДнейОтображаемых > 0 И КоличествоДнейОтображаемых <= 1 Тогда     // Отображение по часам.
		ПериодичностьПроверяемая = Перечисления.Периодичность.Час;
	ИначеЕсли  КоличествоДнейОтображаемых > 1 И КоличествоДнейОтображаемых <= 61 Тогда  // Отображение по дням. 
		ПериодичностьПроверяемая = Перечисления.Периодичность.День;
	// ИначеЕсли  КоличествоДнейОтображаемых > 31 И КоличествоДнейОтображаемых <= 61 Тогда
	//	ПериодичностьПроверяемая = Перечисления.Периодичность.Неделя;
	ИначеЕсли КоличествоДнейОтображаемых > 61 И КоличествоДнейОтображаемых <= 730 Тогда
		ПериодичностьПроверяемая = Перечисления.Периодичность.Месяц;     
	ИначеЕсли КоличествоДнейОтображаемых > 730 Тогда
		ПериодичностьПроверяемая = Перечисления.Периодичность.Год; 
	Иначе
		ПериодичностьПроверяемая = Неопределено;
	КонецЕсли;                                    
	
	ТаблицаВозврат = Новый ТаблицаЗначений;
	ТаблицаВозврат.Колонки.Добавить("ПериодНачало"		, Новый ОписаниеТипов("Дата"));
	ТаблицаВозврат.Колонки.Добавить("ПериодОкончание"	, Новый ОписаниеТипов("Дата"));
	
	ДобавляемаяДата = ДатаНачало;
	
	Пока ДобавляемаяДата < КонецДня(ДатаКонец) + 1 И ЗначениеЗаполнено(ПериодичностьПроверяемая) Цикл	
		
		СтрокаТ 				= ТаблицаВозврат.Добавить(); 
		СтрокаТ.ПериодНачало 	= ДобавляемаяДата;
	
		Если ПериодичностьПроверяемая = Перечисления.Периодичность.Час Тогда
			ДобавляемаяДата = ДобавляемаяДата + 60*60;
		ИначеЕсли ПериодичностьПроверяемая = Перечисления.Периодичность.День Тогда 	
			ДобавляемаяДата = КонецДня(ДобавляемаяДата);
		ИначеЕсли ПериодичностьПроверяемая = Перечисления.Периодичность.Неделя Тогда 	
			ДобавляемаяДата = КонецНедели(ДобавляемаяДата);
		ИначеЕсли ПериодичностьПроверяемая = Перечисления.Периодичность.Месяц Тогда 	
			ДобавляемаяДата = КонецМесяца(ДобавляемаяДата);	
		ИначеЕсли ПериодичностьПроверяемая = Перечисления.Периодичность.Год Тогда 	
			ДобавляемаяДата = КонецГода(ДобавляемаяДата);
		КонецЕсли;
		
		ДобавляемаяДата = ?(ДобавляемаяДата > ДатаКонец, ДатаКонец, ДобавляемаяДата); 
		
		СтрокаТ.ПериодОкончание = ДобавляемаяДата;
		
		ДобавляемаяДата = ДобавляемаяДата + 1;
		
	КонецЦикла;
	
	Возврат ТаблицаВозврат;
	
КонецФункции

// Функция - Получить таблицу периодов для активности.
//
// Параметры:
//  ПериодНачало	 - 	 - 
//  ПериодоКончания	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуПериодовДляАктивности(Знач ПериодНачало, Знач ПериодоКончания)
	
    ТаблицаРезультат = Новый ТаблицаЗначений;
	ТаблицаРезультат.Колонки.Добавить("ПериодЧас", Новый ОписаниеТипов("Дата"));	
	
	ДобавляемаяДата = ПериодНачало;
	
	Пока ДобавляемаяДата < ПериодоКончания Цикл
		
		СтрокаТ = ТаблицаРезультат.Добавить();
		СтрокаТ.ПериодЧас = НачалоЧаса(ДобавляемаяДата);
		
		ДобавляемаяДата = ДобавляемаяДата + 60*60;
		
		ДобавляемаяДата = ?(ДобавляемаяДата > ПериодоКончания, ПериодоКончания, ДобавляемаяДата); 
	
	КонецЦикла;
	
	Возврат ТаблицаРезультат;
	
КонецФункции 

