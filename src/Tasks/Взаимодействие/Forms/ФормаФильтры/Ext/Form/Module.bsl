
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Отбор 			  = ПолучитьИзВременногоХранилища(Параметры.Отбор);
	ИмяКоманды 		  = Параметры.ИмяКоманды;
	ВыбранноеЗначение = Параметры.ВыбранноеЗначение;
	
	Если Параметры.Свойство("ФормаСпискаПерейти") Тогда
		Элементы.АктивированныеЗначения_Фильтр_Контрагент.Видимость    = Ложь;
		Элементы.АктивированныеЗначения_Фильтр_СтатусКлиента.Видимость = Ложь;  
		Элементы.Фильтр_Контрагент.Видимость                           = Ложь;
		Элементы.Фильтр_СтатусКлиента.Видимость                        = Ложь;
		Элементы.Страница_Значения_Фильтр_Контрагент.Видимость         = Ложь;
		Элементы.Страница_Значения_Фильтр_СтатусКлиента.Видимость      = Ложь; 
	КонецЕсли;	
	
	// Создание динамических элементов с параметрами отбора.
	ИнициализироватьМеханизмФильтрацииДанных(Отбор);
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	РезультатОбновления = УправлениеИнтерфейсамиКлиент.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, ИмяКоманды, , Неопределено);
	Если РезультатОбновления.Свойство("ДействиеЭлемента") И РезультатОбновления.ДействиеЭлемента = "ОбработкаВыбора" Тогда 
		Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда 
			СтандартнаяОбработка = Ложь;
			//ВыбранноеЗначение = Неопределено;
			//ЭлементФормы.ОбновитьТекстРедактирования(); 			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ____________________ОБРАБОТЧИКИ_МЕХАНИЗМА_ФИЛЬТРАЦИИ_ДАННЫХ________________________

#Область __________________ИНИЦИАЛИЗАЦИЯ_МЕХАНИЗМА_ФИЛЬТРАЦИИ______________________

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ИнициализироватьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено)
	
	ЭтоКорп			  		  = ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП();	
	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов();	
	
	// Отбор статус.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовЗадач");	
	ОбновитьДинамическоеМенюФильтрации_Статус(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовЗадач_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовЗадач_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусовЗадач, Истина,,,ВариантОтбора);		
	КонецЕсли;
	
	// Отбор видов взаимодействия.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовВзаимодействия");	
	ОбновитьДинамическоеМенюФильтрации_ВидВзаимодействия(РезультатПакетногоЗапроса[2].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВидовВзаимодействия_ВариантОтбора"), ПараметрыОтбора.МассивВидовВзаимодействия_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидВзаимодействия", ПараметрыОтбора.МассивВидовВзаимодействия, Истина,,, ВариантОтбора);		
	КонецЕсли;
	
	Если ЭтоКорп Тогда
		// Отбор вид сделки.
		УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовСделок");
		ОбновитьДинамическоеМенюФильтрации_ВидСделки(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
		Если УстановитьОтбор Тогда 
			ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивВидовСделок_ВариантОтбора"), ПараметрыОтбора.МассивВидовСделок_ВариантОтбора, Истина);
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок, Истина,,, ВариантОтбора);		
		КонецЕсли;
		
		// Отбор этап.
		УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивЭтапов");
		ОбновитьДинамическоеМенюФильтрации_Этап(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
		Если УстановитьОтбор Тогда 
			ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивЭтапов_ВариантОтбора"), ПараметрыОтбора.МассивЭтапов_ВариантОтбора, Истина);
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов, Истина,,, ВариантОтбора);	
		КонецЕсли;	
	КонецЕсли;
	
	// Отбор по контрагентам.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКонтрагентов");
	ОбновитьДинамическоеМенюФильтрации_Контрагент(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКонтрагентов_ВариантОтбора"), ПараметрыОтбора.МассивКонтрагентов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Контрагент", ПараметрыОтбора.МассивКонтрагентов, Истина,,, ВариантОтбора);	
	КонецЕсли;
	
	// Отбор рекламного источника.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовКлиентов");
	ОбновитьДинамическоеМенюФильтрации_СтатусКлиента(РезультатПакетногоЗапроса[4].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовКлиентов_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовКлиентов_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтатусКлиента", ПараметрыОтбора.МассивСтатусовКлиентов, Истина,,, ВариантОтбора);	
	КонецЕсли;
		
	// Отбор тегов.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц");
	Если УстановитьОтбор И НЕ ЗначениеЗаполнено(ПараметрыОтбора.МассивСтруктурныхЕдиниц) Тогда	
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[6].Выгрузить(), УстановитьОтбор);
	Иначе 
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[5].Выгрузить(), УстановитьОтбор);
	КонецЕсли;
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц_ВариантОтбора"), ПараметрыОтбора.МассивСтруктурныхЕдиниц_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина,,, ВариантОтбора);	
	КонецЕсли;

	Если ЭтоКорп Тогда
		// Отбор итересов.
		УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок");
		ОбновитьДинамическоеМенюФильтрации_Сделка(,УстановитьОтбор);
		Если УстановитьОтбор Тогда
			ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок_ВариантОтбора"), ПараметрыОтбора.МассивСтатусовНаличияСделок_ВариантОтбора, Истина);
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Сделка", ПараметрыОтбора.МассивСтатусовНаличияСделок, Истина,,, ВариантОтбора);	
		КонецЕсли;
	КонецЕсли;
	
	// Отбор пометка удаления задачи.         
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления"); 
	ОбновитьДинамическоеМенюФильтрации_ПометкаУдаленияЗадачи(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("СписокСтатусовПометокУдаления_ВариантОтбора"), ПараметрыОтбора.СписокСтатусовПометокУдаления_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияЗадачи", ПараметрыОтбора.СписокСтатусовПометокУдаления, Истина,,, ВариантОтбора);				
	КонецЕсли;
	
	// Отбор исполнителей.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивИсполнителей"); 
	ОбновитьДинамическоеМенюФильтрации_Исполнитель(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивИсполнителей_ВариантОтбора"), ПараметрыОтбора.МассивИсполнителей_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Исполнитель", ПараметрыОтбора.МассивИсполнителей, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;	
	
	// Отбор исполнителей.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКтоВыполнил"); 
	ОбновитьДинамическоеМенюФильтрации_КтоВыполнил(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда
		ВариантОтбора = ?(ПараметрыОтбора.Свойство("МассивКтоВыполнил_ВариантОтбора"), ПараметрыОтбора.МассивКтоВыполнил_ВариантОтбора, Истина);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КтоВыполнил", ПараметрыОтбора.МассивКтоВыполнил, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"),, ВариантОтбора);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр статус.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Статус(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра	
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru= 'Статус'; en='Status'"));	
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_Статус");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_Статус");	
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("Строка"));
	
	
	// Формируем коллекцию сами
	КоллекцияЗначений = Новый ТаблицаЗначений;
	КоллекцияЗначений.Колонки.Добавить("Ссылка"			, Новый ОписаниеТипов("Строка"));
	КоллекцияЗначений.Колонки.Добавить("Представление"	, Новый ОписаниеТипов("Строка"));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", "Выполнена"		, Нстр("ru = 'Выполнена'; en = 'Completed'")));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", "Не выполнена"	, Нстр("ru = 'Не выполнена'; en = 'Not completed'")));
	ЗаполнитьЗначенияСвойств(КоллекцияЗначений.Добавить(), Новый Структура("Ссылка, Представление", "Просрочена"	, Нстр("ru = 'Просрочена'; en = 'Expired'")));
	
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений);
	
	// Обновляем элементы фильтрации для текущего фильтра	
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																														
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить динамическое меню фильтрации вид сделки
//
// Параметры:
//  КоллекцияЗначений		 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_ВидСделки(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	
	// Инициализируем параметры текущего фильтра
	СтруктураФильтра.Вставить("Представление"							, Нстр("ru = 'Вид сделки'; en = 'Deal type'"));
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_ВидСделки");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_ВидСделки");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_ВидСделки");
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_ВидСделки");
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_ВидСделки");
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("СправочникСсылка.ВидыСделок"));	
	
	// Инициализируем список значений для фильтрации (если не передаем коллекцию значений или передаем большую - будет автоматически установлен флаг "ТолькоПолеВыбора" в истину)
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, КоллекцияЗначений, Справочники.ВидыСделок.ПустаяСсылка(), НСтр("ru= '<не указан>'; en='<not specified>'"));
	
	// Обновляем элементы фильтрации для текущего фильтра
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																													
	
КонецПроцедуры

&НаСервере
// Процедура, инициализировать фильтр этап.
//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_Этап(КоллекцияЗначений = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	// Инициализируем структуру параметров фильтра по умолчанию
