#Область ЗачислениеСдачиНаЛицевойСчет

&НаКлиенте
// Процедура - обработчик оповещения "ПослеВопросаОЗачисленииСдачиНаЛицСчет".
//
Процедура ПослеВопросаОЗачисленииСдачиНаЛицСчет(Результат, ДопПараметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОперацияЗачисленияСдачиНаЛицевойСчет(Контрагент, ОплатаСдача, ДопПараметры.РежимЗачисленияСдачи);		
	КонецЕсли;
	
	ЗавершающийЭтапОперацииОплаты(
		ДопПараметры.ОперацияОплатыПроведеноУспешно, 
		ДопПараметры.ДанныефискальныхЧеков, 
		ДопПараметры.ДанныеПлатежаПоКарте,
		ДопПараметры.МассивДокОплаты);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Зачисление сдачи на лицевой счет
//
// Параметры:
//  Контрагент		 - 	 - 
//  СуммаЗачисления	 - 	 - 
//
Процедура ОперацияЗачисленияСдачиНаЛицевойСчет(Контрагент, СуммаЗачисления, РежимЗачисленияСдачи)
	
	Если РежимЗачисленияСдачи = 0 Тогда
		ДокСсылка = ЗачислениеСдачиНаЛицевойСчет(ID_Транзакции, Контрагент, ОплатаСдача, ЭтотОбъект.ТекущаяКасса);
	Иначе
		ДокСсылка = ЗачислениеСдачиАвансовымПлатежом(ID_Транзакции, Контрагент, ОплатаСдача, ЭтотОбъект.ТекущаяКасса);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокСсылка) Тогда
		ПоказатьПредупреждение(, "Не удалось зачислить сдачу!"); 
		Возврат;
	КонецЕсли;
			
	Если ЗначениеЗаполнено(ДокСсылка) 
		И НЕ ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ТекущаяКасса, "ИспользоватьБезПодключенияОборудования") Тогда
		
		Если ИспользоватьСтаруюСистемуФормированияДляФРдляККТ(ЭтотОбъект.ТекущаяКасса) = Ложь Тогда
			ПараметрыЧека = ПодготовитьПараметрыФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаЗачисления, ДокСсылка);  		
		Иначе
			ПараметрыЧека = ПодготовитьПараметрыФискальногоЧекаВзносаСдачиНаЛицСчетДляФР(СуммаЗачисления, ДокСсылка); 
		КонецЕсли;
		
		Если ПараметрыЧека.Результат Тогда
			
			ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ТекущаяКасса);
					
			Если ПараметрыЧека.Свойство("ФискальныйЧек") Тогда		
				
				Контекст = Новый Структура();
				Контекст.Вставить("ТипЧека", Истина);			
				Оповещение            = Новый ОписаниеОповещения("ПробитьЧекЗавершение"            , ЭтотОбъект, Контекст);
				ПослеОткрытияЧека     = Новый ОписаниеОповещения("ПечатьЧека_ПослеОткрытияЧека"    , ЭтотОбъект, Контекст);
				ПослеОшибкиПечатиЧека = Новый ОписаниеОповещения("ПечатьЧека_ПослеОшибкиПечатиЧека", ЭтотОбъект, Контекст);
				
				ОбщиеПараметры = ПараметрыЧека.ФискальныйЧек;
				МенеджерОборудованияКлиент.НачатьФискализациюЧекаНаФискальномУстройстве(Оповещение, 
																					УникальныйИдентификатор,
																					ОбщиеПараметры,
																					ИдентификаторУстройстваФР, , 
																					ПослеОткрытияЧека,
																					ПослеОшибкиПечатиЧека);		
				
			КонецЕсли;
			
			// Если был фискальный чек, то нефискальный чек напечатается после завершения фискального.
			Если ПараметрыЧека.Свойство("НефискальныйЧек") Тогда
				
				ТекстЧека  = ПараметрыЧека.НефискальныйЧек;
				Контекст   = Новый Структура();
				Контекст.Вставить("ТипЧека", Ложь);
				Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект, Контекст);
				МенеджерОборудованияКлиент.НачатьПечатьТекста(Оповещение, УникальныйИдентификатор, ТекстЧека, ИдентификаторУстройстваФР);
				
			КонецЕсли;				
			
		Иначе
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Фискализация взноса на ЛС. ';en='Fiscalization contribution on drugs.'") + ПараметрыЧека.ОписаниеОшибки);
		
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(НомерФискальногоЧека) 
			ИЛИ ЗначениеЗаполнено(НомерНефискальногоЧека) Тогда 					
			
			ЗаписатьВДокументНомерЧекаФР(ДокСсылка, ?(ЗначениеЗаполнено(НомерФискальногоЧека), НомерФискальногоЧека, НомерНефискальногоЧека));		 
			НомерФискальногоЧека   = 0;
			НомерНефискальногоЧека = 0;			
			
		КонецЕсли;
		
	КонецЕсли; 
	 
КонецПроцедуры

// Функция - Подготовить параметры чека на печать
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПодготовитьПараметрыФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса, ДокументСсылка)
	
	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	ВидНалога 	  = ?(ЗначениеЗаполнено(ЭтотОбъект.Организация.СистемаНалогообложенияДляАвансов), ЭтотОбъект.Организация.СистемаНалогообложенияДляАвансов, ЭтотОбъект.Организация.СистемаНалогообложения);
	
	ПараметрыЧека.ВидОперации             = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет;
	ПараметрыЧека.СтруктурнаяЕдиница      = ЭтотОбъект.СтруктурнаяЕдиница;
	ПараметрыЧека.Организация             = ЭтотОбъект.Организация;
	ПараметрыЧека.Сотрудник               = ЭтотОбъект.Сотрудник;
	ПараметрыЧека.Клиент                  = ЭтотОбъект.Контрагент;
	ПараметрыЧека.Дата                    = ЭтотОбъект.ДатаПродажи;
	ПараметрыЧека.Касса                   = ЭтотОбъект.ТекущаяКасса;	
	ПараметрыЧека.Количество              = 1;	
	ПараметрыЧека.СуммаКОплате            = СуммаВзноса;
	ПараметрыЧека.СуммаОплачено           = СуммаВзноса;
	
	ПараметрыЧека.МассивПараметровОплаты  = ПолучитьМассивОплатФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса);	
	ПараметрыЧека.МассивПараметровТовары  = ПолучитьМассивТоваровФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса, ДокументСсылка); 
	
	ПараметрыЧека.ТипЧека                 = 0;
	ПараметрыЧека.ВидНалога               = ВидНалога;	
	ПараметрыЧека.ВыводитьЧекНаБумагу     = ЭтотОбъект.ЧекПечатать;
    ПараметрыЧека.ЭлектроннаяПочтаКлиента = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту, ЭтотОбъект.ЧекККТКонтактыКлиентаПочта, Неопределено);
	ПараметрыЧека.НомерТелефонаКлиента    = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон, ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон, Неопределено);
	
	МассивДокументовОплаты = Новый Массив;
	МассивДокументовОплаты.Добавить(ДокументСсылка);
	
	ПараметрыЧека.МассивДокументовОснований = МассивДокументовОплаты;
	
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека);	

	Возврат ФормированиеЧека;
	
КонецФункции

&НаСервере
// Функция, возвращает массив товаров на печать
//
Функция ПолучитьМассивТоваровФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса, ДокументСсылка)
	
	МассивТоваров = Новый Массив;
	
	СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
	
	Наименование = ?(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументСсылка, "ВидОперации") = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет,
					НСтр("ru = 'Взнос на лицевой счет от:'"), НСтр("ru = 'Аванс от:'"));
								
	СтрокаТовара.Наименование           = МенеджерОборудованияВызовСервера.ПолучитьСловоСУчетомЯзыка(Наименование) + " " + Контрагент;
	СтрокаТовара.СтоимостьБезСкидки     = СуммаВзноса;
	СтрокаТовара.СтавкаНДС              = МенеджерОборудованияВызовСервера.ПолучитьНДСПриВзносеНаЛицевойСчет(ЭтотОбъект.Организация);	
	СтрокаТовара.СуммаНДС               = Ценообразование.РассчитатьСуммуНДС(СуммаВзноса, СтрокаТовара.СтавкаНДС);

	МассивТоваров.Добавить(СтрокаТовара);
	
	Возврат МассивТоваров;
	
КонецФункции

// Функция - Получить массив оплат на печать
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПолучитьМассивОплатФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса)
	
	МассивОплат = Новый Массив;		
	
	ПараметрыТипаОплаты = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиПлатежаЧека();
	
	ПараметрыТипаОплаты.ТипОплаты = Перечисления.ТипыДенежныхСредств.Наличные;
	ПараметрыТипаОплаты.Сумма     = СуммаВзноса;
	
	МассивОплат.Добавить(ПараметрыТипаОплаты);	
	
	Возврат МассивОплат;
	
КонецФункции

// Функция - Подготовить параметры чека на печать
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПодготовитьПараметрыФискальногоЧекаВзносаСдачиНаЛицСчетДляФР(СуммаВзноса, ДокументСсылка)
	
	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	ВидНалога 	  = ?(ЗначениеЗаполнено(Организация.СистемаНалогообложенияДляАвансов), ЭтотОбъект.Организация.СистемаНалогообложенияДляАвансов, ЭтотОбъект.Организация.СистемаНалогообложения);
	
	ПараметрыЧека.ВидОперации            = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет;
	ПараметрыЧека.СтруктурнаяЕдиница     = ЭтотОбъект.СтруктурнаяЕдиница;
	ПараметрыЧека.Организация            = ЭтотОбъект.Организация;
	ПараметрыЧека.Сотрудник              = ЭтотОбъект.Сотрудник;
	ПараметрыЧека.Клиент                 = ЭтотОбъект.Контрагент;
	ПараметрыЧека.Дата                   = ЭтотОбъект.ДатаПродажи;
	ПараметрыЧека.Касса                  = ЭтотОбъект.ТекущаяКасса;	
	ПараметрыЧека.Наименование           = НСтр("ru='Оплата от:';en='Payment from:'") + " " + Контрагент;
    ПараметрыЧека.СтоимостьБезСкидки     = СуммаВзноса;
    ПараметрыЧека.Количество             = 1;
	ПараметрыЧека.ТипОплаты              = Перечисления.ТипыДенежныхСредств.Наличные;		
	ПараметрыЧека.ВидНалога              = ВидНалога;		
	ПараметрыЧека.СуммаКОплате           = СуммаВзноса;
	ПараметрыЧека.СуммаОплачено          = СуммаВзноса;

	// ККТ микс
	ПараметрыЧека.МассивПараметровОплаты  = ПолучитьМассивОплатФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса);	
	ПараметрыЧека.МассивПараметровТовары  = ПолучитьМассивТоваровФискальногоЧекаВзносаСдачиНаЛицСчетДляККТ(СуммаВзноса, ДокументСсылка); 
	
	ПараметрыЧека.ТипЧека                 = 0;
	ПараметрыЧека.ВыводитьЧекНаБумагу     = Этотобъект.ЧекПечатать;
    ПараметрыЧека.ЭлектроннаяПочтаКлиента = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту, ЭтотОбъект.ЧекККТКонтактыКлиентаПочта, Неопределено);
	ПараметрыЧека.НомерТелефонаКлиента    = ?(ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон, ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон, Неопределено);
	
	МассивДокументовОплаты = Новый Массив;
	МассивДокументовОплаты.Добавить(ДокументСсылка);
	
	ПараметрыЧека.МассивДокументовОснований = МассивДокументовОплаты;
	
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоИНеФискальногоЧекаФР(ПараметрыЧека);	

	Возврат ФормированиеЧека;
	
КонецФункции

&НаСервереБезКонтекста
// Функция зачисления сдачи на лицевой счет контрагента.
//
Функция ЗачислениеСдачиНаЛицевойСчет(ID_Транзакции, Контрагент, СуммаЗачисления, Касса)
	
	ПараметрыЗаполнения = Новый Структура;
	
	ПараметрыЗаполнения.Вставить("ID_Транзакции"         , ID_Транзакции);	
	ПараметрыЗаполнения.Вставить("Контрагент"            , Контрагент);
	ПараметрыЗаполнения.Вставить("ТипДенежныхСредств"    , Перечисления.ТипыДенежныхСредств.Наличные);
	ПараметрыЗаполнения.Вставить("ВидОперации"           , Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
	ПараметрыЗаполнения.Вставить("ЛицевойСчетКонтрагента", Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет);
	ПараметрыЗаполнения.Вставить("СуммаДокумента"        , СуммаЗачисления);
	ПараметрыЗаполнения.Вставить("Касса"       		     , Касса);
	ПараметрыЗаполнения.Вставить("Комментарий"			 , НСтр("ru = 'Зачисление сдачи'; en = 'Crediting change'"));
	
	ДокОбъект = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
	ДокОбъект.Заполнить(ПараметрыЗаполнения);
	ДокОбъект.ID_Транзакции = ID_Транзакции;
	
	Если ДокОбъект.ПроверитьЗаполнение() Тогда
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Возврат Неопределено;
		КонецПопытки;		
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
	Возврат ДокОбъект.Ссылка;
	
КонецФункции

&НаСервереБезКонтекста
// Функция зачисления сдачи на лицевой счет контрагента.
//
Функция ЗачислениеСдачиАвансовымПлатежом(ID_Транзакции, Контрагент, СуммаЗачисления, Касса)
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ID_Транзакции"         , ID_Транзакции);	
	ПараметрыЗаполнения.Вставить("Контрагент"            , Контрагент);
	ПараметрыЗаполнения.Вставить("ТипДенежныхСредств"    , Перечисления.ТипыДенежныхСредств.Наличные);
	ПараметрыЗаполнения.Вставить("ВидОперации"           , Перечисления.ВидыОпераций.ОплатаОтКлиента);
	ПараметрыЗаполнения.Вставить("СуммаДокумента"        , СуммаЗачисления);  
	ПараметрыЗаполнения.Вставить("Касса"       		     , Касса);
	ПараметрыЗаполнения.Вставить("Комментарий"			 , НСтр("ru = 'Зачисление сдачи'; en = 'Crediting change'"));
	
	ДокОбъект = Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
	ДокОбъект.Заполнить(ПараметрыЗаполнения);
	Если ДокОбъект.РасшифровкаПлатежа.Количество() = 0 Тогда
		НоваяСтрока          = ДокОбъект.РасшифровкаПлатежа.Добавить();
		НоваяСтрока.ЭтоАванс = Истина;
		НоваяСтрока.Сумма    = СуммаЗачисления; 	
	КонецЕсли;
	ДокОбъект.ID_Транзакции = ID_Транзакции;
	Если ДокОбъект.ПроверитьЗаполнение() Тогда
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
	Возврат ДокОбъект.Ссылка;
	
КонецФункции

&НаСервере
// Процедура - Расставить приоритет печати чека
//
Процедура РасставитьПриоритетПечатиЧека()

	Если ЭтотОбъект.ЧекПечатать = Истина Тогда
		Элементы.ГруппаКонтактыКлиентаТелефон.Видимость			= Ложь;
		Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость 	= Истина;
		ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон 				= Ложь;
		
		Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Ложь;
		Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Истина;
		ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту 				= Ложь;
	Иначе
		Если ЗначениеЗаполнено (ЭтотОбъект.ЧекККТКонтактыКлиентаПочта) Тогда
			
			Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Истина;
			Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту 				= Истина;
			
		ИначеЕсли ЗначениеЗаполнено (ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон) Тогда
			
			Элементы.ГруппаКонтактыКлиентаТелефон.Видимость			= Истина;
			Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон 				= Истина;
		Иначе 
			ЭтотОбъект.ЧекПечатать = Истина; 
			
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Нужно указать почту или телефон пациента для отправки электронного чека.';
															|en='You must specify the patient''s mail or phone number to send an electronic receipt.'"));  
		КонецЕсли;                                            
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
// Процедура - Обновить доступные кассы
//
// Параметры:
//  врДоступныеКассы - 	 - 
//
Процедура ОбновитьДоступныеКассыДляСсылокИСбп(врДоступныеКассы)
	
	ТаблицаКасс = Справочники.Кассы.ПолучитьКассыСсылокНаОплатуИСбп(СтруктурнаяЕдиница);
	
	Для Каждого СтрокаТЗ Из ТаблицаКасс Цикл
		
		НайденнаяСтрока = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(врДоступныеКассы, "Касса", СтрокаТЗ.Касса);
		
		Если НайденнаяСтрока = Неопределено Тогда
			СтруктураДанных = Новый Структура("ИспользуетсяОнлайн,Касса,КассаДоступна,ФРИспользуется");
			ЗаполнитьЗначенияСвойств(СтруктураДанных, СтрокаТЗ); 
			врДоступныеКассы.Добавить(СтруктураДанных);
		Иначе
			НайденнаяСтрока.ИспользуетсяОнлайн = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	врДоступныеКассы = ОтсортироватьМассивСтруктур(врДоступныеКассы);
	
КонецПроцедуры

&НаСервере
// Функция - Отсортировать массив структур
//
// Параметры:
//  МассивСтруктур	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОтсортироватьМассивСтруктур(МассивСтруктур)
	
	ТаблицаКасс = Новый ТаблицаЗначений;
	ТаблицаКасс.Колонки.Добавить("ИспользуетсяОнлайн");
	ТаблицаКасс.Колонки.Добавить("Касса");
	ТаблицаКасс.Колонки.Добавить("КассаДоступна");
	ТаблицаКасс.Колонки.Добавить("ФРИспользуется");
		
	Для Каждого Строка Из МассивСтруктур Цикл
		НоваяСтрока = ТаблицаКасс.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
	КонецЦикла;
	
	ТаблицаКасс.Сортировать("ФРИспользуется Убыв, КассаДоступна Убыв");  
	
	МассивСтруктурВозврат = Новый Массив;
	
	Для Каждого Строка Из ТаблицаКасс Цикл
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("ИспользуетсяОнлайн"	, Строка.ИспользуетсяОнлайн);
		СтруктураСтроки.Вставить("Касса"				, Строка.Касса);
		СтруктураСтроки.Вставить("КассаДоступна"		, Строка.КассаДоступна);
		СтруктураСтроки.Вставить("ФРИспользуется"		, Строка.ФРИспользуется);
		МассивСтруктурВозврат.Добавить(СтруктураСтроки);
	КонецЦикла;
	
	Возврат МассивСтруктурВозврат;
	
КонецФункции

&НаСервере
// Функция - Получить картинку соответствия типу шлюза
//
// Параметры:
//  ЭквайринговыйТерминал	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКартинкуСоответствияТипуШлюза(ЭквайринговыйТерминал)
	
	ТипШлюза = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭквайринговыйТерминал, "ТипБанка"); 
	
	Если ТипШлюза = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПТинькофф ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПСбербанк 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
		Возврат БиблиотекаКартинок.СсылкиНаОплату_СБП_32;
	ИначеЕсли ТипШлюза = Перечисления.ПлатежныеШлюзы.Сбербанк ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR Тогда
		Возврат БиблиотекаКартинок.СсылкиНаОплату_СберБанк_32;
	Иначе
		Возврат Неопределено
	КонецЕсли;
	
КонецФункции

&НаСервере
// Функция, проверяет принадлежность номенклатуры к секцииям кассы ККМ.
// 
Функция ПринадлежностьКСекциям(СообщениеПользователю)
	
	Если Не ТекущаяКасса.БлокироватьПечатьЧека 
		Или (ТекущаяКасса.БлокироватьПечатьЧека И ТекущаяКасса.Секции.Количество() = 0) Тогда
		
		Возврат Истина;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеализацияЗапасы.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ТаблицаНоменклатур
	|ИЗ
	|	Документ.Реализация.Запасы КАК РеализацияЗапасы
	|ГДЕ
	|	РеализацияЗапасы.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЗапасы.Номенклатура
	|ИЗ
	|	Документ.Прием.Запасы КАК ПриемЗапасы
	|ГДЕ
	|	ПриемЗапасы.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриемЛечение.Номенклатура
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|ГДЕ
	|	ПриемЛечение.Ссылка В(&МассивДокументов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НоменклатураСегмента.Сегмент КАК Сегмент,
	|	НоменклатураСегмента.Номенклатура КАК ОбъектСегмента
	|ПОМЕСТИТЬ ТаблицаСегментов
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|ГДЕ
	|	НоменклатураСегмента.Номенклатура В
	|			(ВЫБРАТЬ
	|				ТаблицаНоменклатур.Номенклатура
	|			ИЗ
	|				ТаблицаНоменклатур)
	|	И НоменклатураСегмента.Сегмент В(&СекцииКассы)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаНоменклатур.Номенклатура КАК Номенклатура
	|ИЗ
	|	ТаблицаНоменклатур КАК ТаблицаНоменклатур
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСегментов КАК ТаблицаСегментов
	|		ПО ТаблицаНоменклатур.Номенклатура = ТаблицаСегментов.ОбъектСегмента
	|ГДЕ
	|	ТаблицаСегментов.Сегмент ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаНоменклатур.Номенклатура";   
	
	Запрос.УстановитьПараметр("МассивДокументов", ПолучитьДокументыЗадолженностиСервер(Истина));
	Запрос.УстановитьПараметр("СекцииКассы"		, ТекущаяКасса.Секции.ВыгрузитьКолонку("СегментНоменклатуры"));
	
	Результат = Запрос.Выполнить().Выгрузить();
	СтрокаСписокНоменклатур = "";
	Для Каждого СтрокаТЗ Из Результат Цикл
		СтрокаСписокНоменклатур  = СтрокаСписокНоменклатур + ?(ПустаяСтрока(СтрокаСписокНоменклатур), "", ", ") + СокрЛП(СтрокаТЗ.Номенклатура);		
	КонецЦикла;
	
	Если Результат.Количество() > 0 Тогда
		СообщениеПользователю = СтрШаблон(Нстр("ru='Проведение и оплата чека невозможна, поскольку в чеке имеется номенклатура [%1]"
", не входящая ни в одну из секций текущей кассы ККМ.';en='Holding and payment check not is possible because the"
"check contains nomenclature [%1] which is not included in any of the sections of the current ticketoffice KKM.'"), СтрокаСписокНоменклатур);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеПользователю);
		
		Возврат Ложь;     		
	КонецЕсли;
	
	Возврат Результат.Количество() = 0;
	
КонецФункции

#КонецОбласти

#КонецОбласти

