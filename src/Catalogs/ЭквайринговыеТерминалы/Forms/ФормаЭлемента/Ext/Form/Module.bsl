&НаСервере
Функция СформироватьСтруктуруПараметровПлатежногоШлюза()
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("UrlRedirect"  	  		 	, ЭтотОбъект.UrlRedirect);
	СтруктураПараметров.Вставить("URLБанка"     	  	 	 	, ЭтотОбъект.URLБанка);
	СтруктураПараметров.Вставить("ЛогинБанка"   	  		 	, ЭтотОбъект.ЛогинБанка);
	СтруктураПараметров.Вставить("ПарольБанка"  	  		 	, ЭтотОбъект.ПарольБанка);
	СтруктураПараметров.Вставить("ТестовыйРежим"	  		 	, ЭтотОбъект.ТестовыйРежим);
	СтруктураПараметров.Вставить("ВремяЖизни"   	  		 	, ЭтотОбъект.ВремяЖизниСсылкиНаОплату);
	СтруктураПараметров.Вставить("КлючТерминалаТинькофф"	 	, ЭтотОбъект.КлючТерминалаТинькофф);
	СтруктураПараметров.Вставить("СекретныйКлючТинькофф"	 	, ЭтотОбъект.СекретныйКлючТинькофф);
	СтруктураПараметров.Вставить("ЗакрытыйКлюч"				 	, ЭтотОбъект.ЗакрытыйКлюч);
	СтруктураПараметров.Вставить("IDТерминала"				 	, ЭтотОбъект.IDТерминала);
	СтруктураПараметров.Вставить("IDQR"				 			, ЭтотОбъект.IDQR);
	СтруктураПараметров.Вставить("КлючМерчанта"				 	, ЭтотОбъект.КлючТерминалаТинькофф);
	СтруктураПараметров.Вставить("ПарольКлючаМерчанта"			, ЭтотОбъект.СекретныйКлючТинькофф);
	
	Возврат СтруктураПараметров;
	
КонецФункции

