&НаСервере 
// Процедура - Заполнить по приемам на сервере
//
Процедура ЗаполнитьПоПриемамНаСервере()
	
	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковПлан.Сотрудник КАК Ассистент,
	|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
	|	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема,
	|	РАЗНОСТЬДАТ(Прием.ВремяНачалаПриема, Прием.ВремяОкончанияПриема, МИНУТА) КАК Минут,
	|	Прием.Сотрудник КАК Врач
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Прием КАК Прием
	|		ПО (ВремяРаботыСотрудниковПлан.Сотрудник = Прием.Ассистент
	|				И Прием.Проведен = ИСТИНА)
	|ГДЕ
	|	Прием.ВремяНачалаПриема МЕЖДУ &ПериодС И &ПериодПо
	|	И ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВремяРаботыСотрудниковПлан.Сотрудник = &Ассистент
	|
	|СГРУППИРОВАТЬ ПО
	|	ВремяРаботыСотрудниковПлан.Сотрудник,
	|	Прием.ВремяНачалаПриема,
	|	Прием.ВремяОкончанияПриема,
	|	Прием.Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Ссылка КАК Ссылка,
	|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
	|	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема,
	|	Прием.Ассистент КАК Сотрудник
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Проведен = ИСТИНА
	|	И Прием.ВремяНачалаПриема МЕЖДУ &ПериодС И &ПериодПо
	|	И Прием.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Прием.Ассистент = &Ассистент";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Ассистент", Объект.Ассистент);
	Запрос.УстановитьПараметр("ПериодС", НачалоМесяца(Объект.Период));
	Запрос.УстановитьПараметр("ПериодПо", КонецМесяца(Объект.Период));
	
	Результат = Запрос.ВыполнитьПакет();
	
	ТаблицаАссистирования = Результат[0].Выгрузить();
	ТаблицаАссистирования.Колонки.Добавить("ЧислоПриемовЗаСмену", Новый ОписаниеТипов("Число"));
	ТаблицаАссистирования.Колонки.Добавить("ПризнакОсновной", Новый ОписаниеТипов("Булево"));
	
	ТаблицаПриемов = Результат[1].Выгрузить();
	
	// Высчитываем количество приемов за это время
	Для Каждого СтрокаТЗ Из ТаблицаАссистирования Цикл
		Для Каждого СтрокаТЗПриема Из ТаблицаПриемов Цикл
			Если СтрокаТЗПриема.Сотрудник = СтрокаТЗ.Ассистент И СтрокаТЗПриема.ВремяНачалаПриема >= СтрокаТЗ.ВремяНачалаПриема
					И СтрокаТЗПриема.ВремяНачалаПриема <= СтрокаТЗ.ВремяОкончанияПриема Тогда
				СтрокаТЗ.ЧислоПриемовЗаСмену = СтрокаТЗ.ЧислоПриемовЗаСмену + 1;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Удаляем периоды работы, в которые не было приемов, т.е. сотрудник никому не ассистировал
	МассивУдаляемыхСтрок = Новый Массив;
	Для Каждого СтрокаТЗ Из ТаблицаАссистирования Цикл
		Если СтрокаТЗ.ЧислоПриемовЗаСмену = 0 Тогда
			МассивУдаляемыхСтрок.Добавить(СтрокаТЗ);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаТЗ Из МассивУдаляемыхСтрок Цикл
		ТаблицаАссистирования.Удалить(СтрокаТЗ);
	КонецЦикла;	
	
	// Вычисляем ассистирование по совместительству
	ТаблицаАссистирования.Сортировать("ВремяНачалаПриема, ВремяОкончанияПриема, ЧислоПриемовЗаСмену Убыв");
	Для а = 0 По ТаблицаАссистирования.Количество()-1 Цикл
		СтрокаТЗ = ТаблицаАссистирования[а];
		СтрокаТЗ.ПризнакОсновной = Истина;
		Если а > 0 И (СтрокаТЗ.ВремяНачалаПриема >= ТаблицаАссистирования[а-1].ВремяНачалаПриема И СтрокаТЗ.ВремяНачалаПриема <= ТаблицаАссистирования[а-1].ВремяОкончанияПриема
			ИЛИ СтрокаТЗ.ВремяОкончанияПриема >= ТаблицаАссистирования[а-1].ВремяНачалаПриема И СтрокаТЗ.ВремяНачалаПриема <= ТаблицаАссистирования[а-1].ВремяОкончанияПриема
			ИЛИ СтрокаТЗ.ВремяОкончанияПриема < ТаблицаАссистирования[а-1].ВремяНачалаПриема И СтрокаТЗ.ВремяОкончанияПриема > ТаблицаАссистирования[а-1].ВремяОкончанияПриема) Тогда
			СтрокаТЗ.ПризнакОсновной = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	// Переносим в таблицу дней работы
	// Очищаем значение колонок дней
	Для Каждого СтрокаТЗ Из Объект.ДниРаботы Цикл
		Для а = 1 По 31 Цикл
			СтрокаТЗ["День" + а] = Неопределено;
		КонецЦикла;
		СтрокаТЗ.ВсегоЧасов = Неопределено;
		СтрокаТЗ.ВсегоДней = Неопределено;
	КонецЦикла;
	
	// Заполняем табель работы по времени работы сотрудников
	Для Каждого СтрокаРезультат Из ТаблицаАссистирования Цикл
		// МассивСтрокТЗ = Объект.ДниРаботы.НайтиСтроки(Новый Структура("Сотрудник", СтрокаРезультат.Врач));
		МассивСтрокТЗ = Объект.ДниРаботы.НайтиСтроки(Новый Структура("Сотрудник", СтрокаРезультат.Врач));
		Если МассивСтрокТЗ.Количество() > 0 Тогда
			КоличествоМинут = Цел(СтрокаРезультат.Минут / 60) + (СтрокаРезультат.Минут - Цел(СтрокаРезультат.Минут / 60) * 60) / 60;
			МассивСтрокТЗ[0]["День" + День(СтрокаРезультат.ВремяНачалаПриема)] = МассивСтрокТЗ[0]["День" + День(СтрокаРезультат.ВремяНачалаПриема)] + ?(СтрокаРезультат.ПризнакОсновной = Истина, КоличествоМинут, КоличествоМинут / 2);
		КонецЕсли;
	КонецЦикла;
	
	// Пересчитаем итоги в табеле по сотрудникам
	Для Каждого СтрокаТЗ Из Объект.ДниРаботы Цикл
		ПересчитатьИтогиСтрокиДниРаботы(СтрокаТЗ);
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
// Процедура печати документов.
//
Процедура ДокументПечать(Команда)
	
	МассивДокументов = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		МассивДокументов.Добавить(Объект.Ссылка);
	КонецЕсли;
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "ТабельУчетаРабочегоВремени");
	Структура.Вставить("МассивДокументов", МассивДокументов);
	
	СписокПечатныхФорм = ПолучитьСписокПечати();
	Оповещение = Новый ОписаниеОповещения("ОбработкаКоманды", УправлениеПечатьюКлиентСтоматология, Структура);	
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда	
		
		СтруктураВопроса = Новый Структура;
		СтруктураВопроса.Вставить("СписокПечатныхФорм", СписокПечатныхФорм);
		СтруктураВопроса.Вставить("Оповещение", Оповещение);
		ОповещениеДляВопроса = Новый ОписаниеОповещения("ПослеВопросаЗавершение", ЭтотОбъект, СтруктураВопроса);			
		ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны. Записать?", РежимДиалогаВопрос.ДаНет);
		
	Иначе	
		
		ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, Элементы.ФормаДокументаПечать);
		
	КонецЕсли;   				
	
КонецПроцедуры

