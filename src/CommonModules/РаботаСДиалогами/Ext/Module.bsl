// Процедура устанавливает доступность элементов форм документа,
// в зависимости от настроек прав пользователя
Процедура УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ДокументФорма, ДокументОбъект, ТабличныеПоля = Неопределено) Экспорт
	
	// Если ОбщегоНазначения.УстановитьДоступностьФормыПоПравуПользователя(ЭтаФорма, ЭтотОбъект) Тогда
	//	ДокументФорма.УстановитьДоступностьЭлементовФормДокумента();
	// КонецЕсли;
	
	Если ТабличныеПоля = Неопределено Тогда
		ТабличныеПоля = Новый Структура("Запасы,ВозвращенныеЗапасы,Услуги,Расходы,ТаблицаЛечение,ТаблицаТовары");
	КонецЕсли;
	
	// Проверим перебором табличные поля формы документа
	Для Каждого ТекущееТабличноеПоле Из ТабличныеПоля Цикл
		
		ТабличноеПоле = ДокументФорма.Элементы.Найти(ТекущееТабличноеПоле.Ключ);
		Если ТабличноеПоле = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Колонка = ДокументФорма.Элементы.Найти("" + ТекущееТабличноеПоле.Ключ + "Цена");
		Если Колонка <> Неопределено Тогда
			Значение = НЕ Колонка.Доступность ИЛИ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ИзменятьЦены, Ложь);
			Колонка.ТолькоПросмотр =  Значение;
		КонецЕсли;
		
		Колонка =ДокументФорма.Элементы.Найти("" + ТекущееТабличноеПоле.Ключ + "Сумма");
		Если Колонка <> Неопределено Тогда
			Значение = НЕ Колонка.Доступность ИЛИ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ИзменятьЦены, Ложь);
			Колонка.ТолькоПросмотр =  Значение;
		КонецЕсли;
		
		Колонка = ДокументФорма.Элементы.Найти("" + ТекущееТабличноеПоле.Ключ + "ПроцентСкидкиНаценки");
		Если Колонка <> Неопределено Тогда
   			Значение = НЕ Колонка.Доступность ИЛИ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ИзменятьРучнуюСкидку, Ложь);
			Колонка.ТолькоПросмотр = Значение;
		КонецЕсли;
		
		Колонка = ДокументФорма.Элементы.Найти("" + ТекущееТабличноеПоле.Ключ + "СуммаРучнойСкидки");
		Если Колонка <> Неопределено Тогда
   			Значение = НЕ Колонка.Доступность ИЛИ ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ИзменятьРучнуюСкидку, Ложь);
			Колонка.ТолькоПросмотр = Значение;
		КонецЕсли;
		
		Колонка = ДокументФорма.Элементы.Найти("" + ТекущееТабличноеПоле.Ключ + "СтатьяРасходов");
		Если Колонка <> Неопределено Тогда
   			Значение = ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.ОбязательноеЗаполнениеСтатьиЗатратВПоступленииЗапасов, Ложь);
			Колонка.АвтоОтметкаНезаполненного = Значение;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // УстановитьДоступностьЭлементовФормДокумента()

&НаСервере
// Процедура - Установить состояние объекта.
//
// Параметры:
//  ФормаОбъекта - 	 - 
//  Удален		 - 	 - 
//  Проведен	 - 	 - 
//  ПробитНаФР	 - 	 - 
//
Процедура УстановитьСостояниеОбъекта(
	  ФормаОбъекта
	, Удален
	, Проведен = Неопределено
	, ПробитНаФР = Неопределено
	, ИзмененияПослеОплаты = Неопределено) Экспорт
		
	Если Удален = Истина Тогда
		
		ФормаОбъекта.Элементы.СостояниеОбъекта.Видимость = Истина;
		Если ФормаОбъекта.ИмяФормы = "Справочник.ВариантыОтчетов.Форма.ФормаЭлемента" Тогда
			ФормаОбъекта.Элементы.СостояниеОбъекта.Заголовок = НСтр("ru= 'Вариант отчета удален';en= 'Deleted'");
		Иначе 	
			ФормаОбъекта.Элементы.СостояниеОбъекта.Заголовок = НСтр("ru= 'Удален';en= 'Deleted'");
		КонецЕсли;	
		ФормаОбъекта.Элементы.СостояниеОбъекта.ЦветФона = Новый Цвет(255,182,193);
		
	ИначеЕсли ПробитНаФР = Истина Тогда
		
		ФормаОбъекта.Элементы.СостояниеОбъекта.Видимость = Истина;	

		Если ИзмененияПослеОплаты = Истина Тогда
			Заголовок = НСтр("ru= 'Пробит на ФР, редактирование документа заблокировано. Изменения после пробития на ФР.';
			| en= 'Stamped ticket on FR, document editing is blocked. Changes after breaking through to FR'");
			ФормаОбъекта.Элементы.СостояниеОбъекта.ЦветТекста = Цветастиля.ПоясняющийОшибкуТекст; 				
		Иначе 
			Заголовок = НСтр("ru= 'Пробит на ФР, редактирование документа заблокировано.';en= 'Stamped ticket on FR, document editing is blocked.'");				
		КонецЕсли;
		
		ФормаОбъекта.Элементы.СостояниеОбъекта.Заголовок = Заголовок;
		ФормаОбъекта.Элементы.СостояниеОбъекта.ЦветФона = Новый Цвет(255,250,205);
		
	ИначеЕсли Проведен <> Неопределено И Проведен = Ложь Тогда
		
		ФормаОбъекта.Элементы.СостояниеОбъекта.Видимость = Истина;
		ФормаОбъекта.Элементы.СостояниеОбъекта.Заголовок = НСтр("ru= 'Черновик'; en = 'Draft'");
		ФормаОбъекта.Элементы.СостояниеОбъекта.ЦветФона = Новый Цвет(235,235,235);	
		
	Иначе 
		Если ФормаОбъекта.ИмяФормы = "Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента" Тогда 
			ФормаОбъекта.Элементы.СостояниеОбъекта.Видимость = Истина;
			ФормаОбъекта.Элементы.СостояниеОбъекта.Заголовок = НСтр("ru= 'Отправлено'; en = 'Sent'");
			ФормаОбъекта.Элементы.СостояниеОбъекта.ЦветФона = Новый Цвет(228, 241, 215);
		Иначе 	
			ФормаОбъекта.Элементы.СостояниеОбъекта.Видимость = Ложь;		
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	 


