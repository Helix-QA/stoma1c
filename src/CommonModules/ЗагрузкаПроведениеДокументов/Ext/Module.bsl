#Область ВСПОМАГАТЕЛЬНЫЕ_ПРОЦЕДУРЫ_И_ФУНКЦИИ_ЗАГРУЗКИ
// Функция - Получить должность по наименованию
//
// Параметры:
//  НаименованиеДолжности	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДолжностьПоНаименованию(НаименованиеДолжности)
	
	ДолжностьМенеджер = Справочники.Должности.НайтиПоНаименованию(НаименованиеДолжности, Истина);
	Если ЗначениеЗаполнено(ДолжностьМенеджер) Тогда 
		Возврат ДолжностьМенеджер;
	Иначе 	
		// Создадим должность для менеджеров	
		ДолжностьМенеджер = Справочники.Должности.СоздатьЭлемент();
		ДолжностьМенеджер.Наименование = НаименованиеДолжности;
		ДолжностьМенеджер.УстановитьНовыйКод();					
		ДолжностьМенеджер.ОбменДанными.Загрузка = Истина;
		ДолжностьМенеджер.Записать();
		Возврат ДолжностьМенеджер.Ссылка;
	КонецЕсли;
	
КонецФункции

// Функция - Создать группу сотрудника по наименованию
//
// Параметры:
//  НаименованиеГруппы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьГруппуСотрудникаПоНаименованию(НаименованиеГруппы, ТекстовыйНакопитель)
	
	Если СокрЛП(НаименованиеГруппы) = "" Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	ГруппаСотрудника 						= Справочники.Сотрудники.СоздатьГруппу();
	ГруппаСотрудника.Наименование 			= НаименованиеГруппы;
	ГруппаСотрудника.УстановитьНовыйКод();							
	ГруппаСотрудника.ОбменДанными.Загрузка 	= Истина;
	Попытка
		ГруппаСотрудника.Записать();
	Исключение
		// Запись в лог						
		ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка создания группы сотрудника! Наименование: ';en= 'Error creating employee group! Name: '") + СокрЛП(НаименованиеГруппы) + Символы.ПС + ОписаниеОшибки());						
	КонецПопытки;	
	
	Возврат ГруппаСотрудника;	
	
КонецФункции

// Функция - Создать сотрудника по наименованию
//
// Параметры:
//  НаименованиеМенеджера	 - 	 - 
//  ДолжностьМенеджера		 - 	 - 
//  СтруктурнаяЕдиница		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьСотрудникаПоНаименованию(НаименованиеСотрудника, ДолжностьСотрудника, ГруппаСотрудника = Неопределено, СтруктурнаяЕдиница, ТекстовыйНакопитель)
	
	Если СокрЛП(НаименованиеСотрудника) = "" Тогда
		Возврат Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;	
	
	СтруктураФИО 								= ВернутьСтруктуруФИО(СокрЛП(НаименованиеСотрудника));

	МенеджерСотрудник 							= Справочники.Сотрудники.СоздатьЭлемент();
	МенеджерСотрудник.Наименование 				= СокрЛП(НаименованиеСотрудника);
	МенеджерСотрудник.Фамилия 					= СтруктураФИО.Фамилия;
	МенеджерСотрудник.Имя 						= СтруктураФИО.Имя;
	МенеджерСотрудник.Отчество 					= СтруктураФИО.Отчество;
	МенеджерСотрудник.НаименованиеСокращенное 	= Справочники.Сотрудники.ПолучитьСокращенноеНаименованиеСотрудника(СтруктураФИО); 	
	МенеджерСотрудник.Должность 				= ДолжностьСотрудника;
	МенеджерСотрудник.РольПользователя 			= Перечисления.РольПользователя.МенеджерОтделаПродаж;
	Если НЕ ГруппаСотрудника = Неопределено Тогда
		МенеджерСотрудник.Родитель 				= ГруппаСотрудника.Ссылка;
	КонецЕсли;	
	СтрМестоРаботы 								= МенеджерСотрудник.МестаРаботы.Добавить();
	СтрМестоРаботы.СтруктурнаяЕдиница 			= СтруктурнаяЕдиница;
	МенеджерСотрудник.УстановитьНовыйКод();								
	МенеджерСотрудник.ОбменДанными.Загрузка 	= Истина;
	Попытка
		МенеджерСотрудник.Записать();
	Исключение
		// Запись в лог						
		ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru= 'Ошибка при записи сотрудника! Наименование: ';en= 'Error writing employee! Name: '") + СокрЛП(НаименованиеСотрудника) + Символы.ПС + ОписаниеОшибки());						
	КонецПопытки;	
	
	Возврат МенеджерСотрудник;	
	
КонецФункции

// Процедура - Обновить места работы сотрудника
//
// Параметры:
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//
Процедура ОбновитьМестаРаботыСотрудника(Сотрудник, СтруктурнаяЕдиница)
	
	Если ЗначениеЗаполнено(Сотрудник) И ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		Попытка
			Сотрудник_Объект = Сотрудник.ПолучитьОбъект();
			Если Сотрудник_Объект.МестаРаботы.Найти(СтруктурнаяЕдиница, "СтруктурнаяЕдиница") = Неопределено Тогда 
				НовоеМестоРаботы = Сотрудник_Объект.МестаРаботы.Добавить();
				НовоеМестоРаботы.СтруктурнаяЕдиница = СтруктурнаяЕдиница;
				Сотрудник_Объект.ОбменДанными.Загрузка = Истина;
				Сотрудник_Объект.Записать();
			Иначе 
				Сотрудник_Объект = Неопределено;
			КонецЕсли;	
		Исключение
			
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

// Функция - Вернуть структуру ФИО
//
// Параметры:
//  Наименование - 	 - 
//  СтруктураФИО - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьСтруктуруФИО(Наименование, СтруктураФИО = Неопределено)
	
	Если СтруктураФИО = Неопределено Тогда 
		СтруктураФИО = Новый Структура("Фамилия, Имя, Отчество", "", "", "");
	КонецЕсли;	
	
	МассивСтрок = СтрРазделить(Наименование, " ", Ложь);	
		
	КоличествоСтрок = МассивСтрок.Количество();
	Если КоличествоСтрок = 2 Тогда 
		СтруктураФИО.Фамилия = СокрЛП(СтрСоединить(СтрРазделить(СокрЛП(МассивСтрок[0]), ".,;:""")));
		МассивСтрокРазделенныхТочкой = СтрРазделить(СокрЛП(МассивСтрок[1]), ".", Ложь);	
		Если МассивСтрокРазделенныхТочкой.Количество() > 1 Тогда 
			СтруктураФИО = ВернутьСтруктуруФИО(СтруктураФИО.Фамилия + " " + МассивСтрокРазделенныхТочкой[0] + " " + МассивСтрокРазделенныхТочкой[1], СтруктураФИО);
		Иначе 
			СтруктураФИО.Имя = СокрЛП(СтрСоединить(СтрРазделить(СокрЛП(МассивСтрок[1]), ".,;:""()")));
			Если ЗначениеЗаполнено(СтруктураФИО.Имя) Тогда 
				СтруктураФИО.Имя = ТРег(СтруктураФИО.Имя) + ?(СтрДлина(СтруктураФИО.Имя) > 1, "", ".");
			КонецЕсли;
		КонецЕсли;	
	Иначе 	
		Если КоличествоСтрок > 0 Тогда 
			СтруктураФИО.Фамилия = СокрЛП(СтрСоединить(СтрРазделить(СокрЛП(МассивСтрок[0]), ".,;:""")));
		КонецЕсли;
		Если КоличествоСтрок > 1 Тогда 
			СтруктураФИО.Имя = СокрЛП(СтрСоединить(СтрРазделить(СокрЛП(МассивСтрок[1]), ".,;:""()")));
			Если ЗначениеЗаполнено(СтруктураФИО.Имя) Тогда 
				СтруктураФИО.Имя = ТРег(СтруктураФИО.Имя) + ?(СтрДлина(СтруктураФИО.Имя) > 1, "", ".");
			КонецЕсли;
		КонецЕсли;
		Если КоличествоСтрок > 2 Тогда 
			СтруктураФИО.Отчество = СокрЛП(СтрСоединить(СтрРазделить(СокрЛП(МассивСтрок[2]), ".,;:""()")));
			Если ЗначениеЗаполнено(СтруктураФИО.Отчество) Тогда 
				СтруктураФИО.Отчество = ТРег(СтруктураФИО.Отчество) + ?(СтрДлина(СтруктураФИО.Отчество) > 1, "", ".");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если НЕ СтруктураФИО.Свойство("Наименование") Тогда 
		СтруктураФИО.Вставить("Наименование", СокрЛП(Наименование));
	КонецЕсли;
	
	Возврат СтруктураФИО;
	
КонецФункции

// Функция - Создать организацию
//
// Параметры:
//  Организация	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьОрганизацию(Организация, СтруктурнаяЕдиница, ТаблицаВидовЛицевыхСчетовВБазе)
	
	НоваяКасса = Ложь;
	Если СокрЛП(Организация) = "" Тогда
		ОрганизацияСсылка = СтруктурнаяЕдиница.Организация;	
	Иначе
		ОрганизацияСсылка = Справочники.Организации.НайтиПоНаименованию(СокрЛП(Организация), Истина);
		
		Если ОрганизацияСсылка.Пустая() Тогда	
			ОрганизацияСсылка 								= Справочники.Организации.СоздатьЭлемент();
			ОрганизацияСсылка.Наименование 					= СокрЛП(Организация);
			ОрганизацияСсылка.ПолноеНаименование 			= СокрЛП(Организация);
			ОрганизацияСсылка.СтавкаНДС 					= Перечисления.СтавкиНДС.БезНДС;
			ОрганизацияСсылка.ЮрФизЛицо 					= Перечисления.ЮрФизЛицо.ЮрЛицо;
			ОрганизацияСсылка.Страна 						= Справочники.СтраныМира.Россия;
			ОрганизацияСсылка.Записать();
			
			Касса = Справочники.Кассы.СоздатьЭлемент();
			СтрЗап = Новый Структура("Организация",ОрганизацияСсылка.Ссылка);
			Касса.Заполнить(СтрЗап);
			Касса.Наименование 								= "Касса " + СокрЛП(Организация);
			Касса.ИспользоватьБезПодключенияОборудования 	= Истина;
			Касса.Записать();
			НоваяКасса = Истина;
			
			ТекСтрЕд 										= СтруктурнаяЕдиница.ПолучитьОбъект();
			НС 												= ТекСтрЕд.ДоступныеКассы.Добавить();
			НС.Касса 										= Касса.Ссылка;
			ТекСтрЕд.Записать();			
		КонецЕсли;
		      
	КонецЕсли;
	
	// Касса
	Если НЕ НоваяКасса Тогда
		ЗапросКассы = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	СтруктурныеЕдиницыДоступныеКассы.Касса КАК Касса
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.ДоступныеКассы КАК СтруктурныеЕдиницыДоступныеКассы
		|ГДЕ
		|	СтруктурныеЕдиницыДоступныеКассы.Ссылка = &СтруктурнаяЕдиница
		|	И СтруктурныеЕдиницыДоступныеКассы.Касса.Организация = &Организация");
		
		ЗапросКассы.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		ЗапросКассы.УстановитьПараметр("Организация", ОрганизацияСсылка.Ссылка);
		
		РезультатКассы = ЗапросКассы.Выполнить().Выбрать();
		Если РезультатКассы.Следующий() Тогда
			Касса 											= РезультатКассы.Касса;	
		Иначе
			Касса 											= Справочники.Кассы.СоздатьЭлемент();
			СтрЗап 											= Новый Структура("Организация",ОрганизацияСсылка.Ссылка);
			Касса.Заполнить(СтрЗап);
			Касса.Наименование 								= "Касса " + СокрЛП(Организация);
			Касса.ИспользоватьБезПодключенияОборудования 	= Истина;
			Касса.Записать();
			
			ТекСтрЕд 										= СтруктурнаяЕдиница.ПолучитьОбъект();
			НС 												= ТекСтрЕд.ДоступныеКассы.Добавить();
			НС.Касса 										= Касса.Ссылка;
			ТекСтрЕд.Записать();
		КонецЕсли;		
	КонецЕсли;
	
	// Банковский счет
	Если НЕ ЗначениеЗаполнено(ОрганизацияСсылка.БанковскийСчетПоУмолчанию) Тогда
		БанковскийСчет 										= Справочники.БанковскиеСчета.СоздатьЭлемент();
		БанковскийСчет.Заполнить(Новый Структура("Владелец", ОрганизацияСсылка.Ссылка));
		БанковскийСчет.НомерСчета 							= "Условный счет";
		БанковскийСчет.ВалютаДенежныхСредств 				= Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки(СтруктурнаяЕдиница).ВалютаУчета;
		
		Банки 												= Справочники.Банки.Выбрать();
		Если Банки.Следующий() Тогда
			Банк 											= Банки.Ссылка;
		Иначе
			Банк 											= Справочники.Банки.СоздатьЭлемент();
			Банк.Код 										= "111111111";
			Банк.Наименование 								= "Условный банк";
			Банк.Записать();
		КонецЕсли;	
		     
		БанковскийСчет.Банк 								= Банк.Ссылка;
		БанковскийСчет.Наименование 						= СокрЛп(БанковскийСчет.НомерСчета) + ", в " + Строка(Банк);
		Попытка
			БанковскийСчет.Записать();
		Исключение
			БанковскийСчет = Справочники.БанковскиеСчета.ПустаяСсылка();
		КонецПопытки;	
		
		ОрганизацияОбъект 									= ОрганизацияСсылка.Ссылка.ПолучитьОбъект();
		ОрганизацияОбъект.БанковскийСчетПоУмолчанию 		= ?(ЗначениеЗаполнено(БанковскийСчет.Ссылка), БанковскийСчет.Ссылка, БанковскийСчет);
		ОрганизацияОбъект.Записать();
		ОрганизацияСсылка 									= ОрганизацияОбъект.Ссылка;
	КонецЕсли;	
	
	// Эквайринговый терминал
	Если НЕ ЗначениеЗаполнено(Касса.ЭквайринговыйТерминал) Тогда
		
		ЗапросЭквТерминал = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ЭквайринговыеТерминалы.Ссылка КАК ЭквТерминал
		|ИЗ
		|	Справочник.ЭквайринговыеТерминалы КАК ЭквайринговыеТерминалы
		|ГДЕ
		|	ЭквайринговыеТерминалы.Организация = &Организация
		|	И НЕ ЭквайринговыеТерминалы.Ссылка В
		|				(ВЫБРАТЬ
		|					Кассы.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал
		|				ИЗ
		|					Справочник.Кассы КАК Кассы)");
		
		ЗапросЭквТерминал.УстановитьПараметр("Организация", ОрганизацияСсылка.Ссылка);
		РезультатЭквТерминал 								= ЗапросЭквТерминал.Выполнить().Выбрать();
		Если РезультатЭквТерминал.Следующий() Тогда
			ЭквайрингТерминал 								= РезультатЭквТерминал.ЭквТерминал;	
		Иначе
			
			ЭквайрингТерминал 								= Справочники.ЭквайринговыеТерминалы.СоздатьЭлемент();
			ЭквайрингТерминал.Организация 					= ОрганизацияСсылка.Ссылка;
			ЭквайрингТерминал.БанковскийСчет 				= ОрганизацияСсылка.БанковскийСчетПоУмолчанию;
			ЭквайрингТерминал.ИспользоватьБезПодключенияОборудования = Истина;
			
			Эквайер 										= Справочники.Контрагенты.НайтиПоНаименованию("Эквайринг");
			Если Эквайер.Пустая() Тогда
				
				ГруппаПоставщики 							= Справочники.Контрагенты.НайтиПоНаименованию("Поставщики");
				Если ГруппаПоставщики.Пустая() ИЛИ НЕ ГруппаПоставщики.ЭтоГруппа Тогда
					ГруппаПоставщики 						= Справочники.Контрагенты.СоздатьГруппу();
					ГруппаПоставщики.Наименование 			= "Поставщики";
					ГруппаПоставщики.ТипКонтрагента 		= Перечисления.ТипыКонтрагентов.Поставщики;
					ГруппаПоставщики.Записать();
				КонецЕсли;	
				Эквайер 									= Справочники.Контрагенты.СоздатьЭлемент();
				Эквайер.Наименование 						= "Эквайринг";
				Эквайер.ТипКонтрагента 						= Перечисления.ТипыКонтрагентов.Поставщики;
				Эквайер.ЮрФизЛицо 							= Перечисления.ЮрФизЛицо.ЮрЛицо;
				Эквайер.Родитель 							= ГруппаПоставщики.Ссылка;
				Эквайер.Записать();
				
			КонецЕсли;	
			
			ЭквайрингТерминал.Эквайер 						= Эквайер.Ссылка;
			ЭквайрингТерминал.Наименование 					= "Эквайринг, "+ ОрганизацияСсылка.Наименование;
			СтруктураВидаЛицевогоСчета 						= ПолучитьВидЛицевогоСчета(7, ТаблицаВидовЛицевыхСчетовВБазе);
			Если НЕ СтруктураВидаЛицевогоСчета = Неопределено Тогда 
				ЭквайрингТерминал.ВидЛицевогоСчета 			= СтруктураВидаЛицевогоСчета.Ссылка;// Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет;
			КонецЕсли;	
			ЭквайрингТерминал.БанковскийСчет 				= ОрганизацияСсылка.БанковскийСчетПоУмолчанию;
			ЭквайрингТерминал.Записать();
			
		КонецЕсли;
		
		КассаОбъект 										= Касса.Ссылка.ПолучитьОбъект();
		КассаОбъект.ЭквайринговыйТерминал 					= ЭквайрингТерминал.Ссылка;
		КассаОбъект.Записать();
		
	КонецЕсли;
	
	Возврат Новый Структура("ОрганизацияСсылка, КассаСсылка, БанковскийСчетПоУмолчанию, ЭквайринговыйТерминал", ОрганизацияСсылка.Ссылка, Касса.Ссылка, ОрганизацияСсылка.БанковскийСчетПоУмолчанию, Касса.Ссылка.ЭквайринговыйТерминал);
	
КонецФункции

// Функция - Получить массив бессрочных ЧПУ
//
// Параметры:
//  СегментБессрочныхЧПУ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивБессрочныхЧПУ(СегментБессрочныхЧПУ)
	
	Если НЕ ЗначениеЗаполнено(СегментБессрочныхЧПУ) Тогда 
		Возврат Новый Массив;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Номенклатура) КАК НоменклатураЧленства
	|ИЗ
	|	РегистрСведений.СоставСегментов КАК СоставСегментов
	|ГДЕ
	|	(ВЫРАЗИТЬ(СоставСегментов.Сегмент КАК Справочник.СегментыНоменклатуры)) = &СегментНоменклатуры
	|	И НЕ ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Номенклатура) ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("СегментНоменклатуры", СегментБессрочныхЧПУ);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("НоменклатураЧленства");
	
КонецФункции

// Функция - Создать членство
//
// Параметры:
//  СтруктураРеквизитов	 - 	 - 
//  НоменклатураЧленства - 	 - 
//  СозданоЧленств		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьЧленство(СтруктураРеквизитов, НоменклатураЧленства, ПараметрыЗагрузки, ТекстовыйНакопитель)
	
	ЧленствоОбъект 									= Документы.ЧленствоПакетУслуг.СоздатьДокумент();
	ЧленствоОбъект.ЗаполнитьЧленствоПакетУслугПоНоменклатуре(НоменклатураЧленства);
	ЧленствоОбъект.Контрагент 						= СтруктураРеквизитов.Клиент;
	ЧленствоОбъект.КодСинхронизации 				= СтруктураРеквизитов.ИДКонтракта;
	ЧленствоОбъект.ПрефиксСинхронизации 			= СтруктураРеквизитов.ПрефиксСинхронизации;
	ЧленствоОбъект.Комментарий 						= СтруктураРеквизитов.ПрефиксСинхронизации + " - " + СокрЛП(СтруктураРеквизитов.НомерКонтракта) + " " + СтруктураРеквизитов.Комментарий;
	ЧленствоОбъект.Дата 							= ?(ЗначениеЗаполнено(СтруктураРеквизитов.ДатаПродажи), СтруктураРеквизитов.ДатаПродажи, СтруктураРеквизитов.НачалоКонтракта);
	ЧленствоОбъект.ДатаРучнойАктивации 				= СтруктураРеквизитов.НачалоКонтракта;
	Если ПараметрыЗагрузки.Свойство("МассивБессрочных") И ЗначениеЗаполнено(ПараметрыЗагрузки.МассивБессрочных) И НЕ ПараметрыЗагрузки.МассивБессрочных.Найти(НоменклатураЧленства) = Неопределено Тогда 
		ЧленствоОбъект.ОграничениеПоСрокуДействия 	= Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокНеОграничен;	
	Иначе 	
		ЧленствоОбъект.ОграничениеПоСрокуДействия 	= Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокОграниченПериодом;
		
		Если СтруктураРеквизитов.ПериодКонтракта = "Y" Тогда
			Коэф = 12;
		ИначеЕсли СтруктураРеквизитов.ПериодКонтракта = "W" Тогда
			Коэф = 7;	
		Иначе	
			Коэф = 1;
		КонецЕсли;	
		
		ЧленствоОбъект.СрокДействия = СтруктураРеквизитов.ДлинаПериода * Коэф;
		
		Если СтруктураРеквизитов.ПериодКонтракта = "Y" ИЛИ СтруктураРеквизитов.ПериодКонтракта = "M" Тогда
			ЧленствоОбъект.СрокДействияТип = Перечисления.Периодичность.Месяц;
			ЧистыйСрокДействия = (НачалоДня(ДобавитьМесяц(НачалоДня(СтруктураРеквизитов.НачалоКонтракта), ЧленствоОбъект.СрокДействия))) - 86400;
		Иначе	
			ЧленствоОбъект.СрокДействияТип = Перечисления.Периодичность.День;
			ЧистыйСрокДействия = (НачалоДня(СтруктураРеквизитов.НачалоКонтракта) + ЧленствоОбъект.СрокДействия * 86400) - 86400;		
		КонецЕсли;
		ЧленствоОбъект.СрокДействияДатой 		= ЧистыйСрокДействия;
		
		СрокДействияИтоговыйСуммовой			= ЧистыйСрокДействия + (СтруктураРеквизитов.БонусныхДней + СтруктураРеквизитов.КоличествоДнейЗаморозки) * 86400;
		СрокДействияСУчетомЗаморозки 			= НачалоДня(СтруктураРеквизитов.ОкончаниеКонтракта) + СтруктураРеквизитов.КоличествоДнейЗаморозки * 86400;
		
		// Если грузим все заморозки и бонусные дни
		Если ЧистыйСрокДействия <> (СрокДействияСУчетомЗаморозки - (СтруктураРеквизитов.БонусныхДней + СтруктураРеквизитов.КоличествоДнейЗаморозки) * 86400) Тогда 
			ЧленствоОбъект.СрокДействияТип 		= Перечисления.Периодичность.День;
			ЧленствоОбъект.СрокДействия 		= Цел(((СрокДействияСУчетомЗаморозки - (СтруктураРеквизитов.БонусныхДней + СтруктураРеквизитов.КоличествоДнейЗаморозки) * 86400) - СтруктураРеквизитов.НачалоКонтракта) / 86400);						
			ЧленствоОбъект.СрокДействияДатой 	= (НачалоДня(СтруктураРеквизитов.НачалоКонтракта) + ЧленствоОбъект.СрокДействия * 86400) - 86400;		
		КонецЕсли;
		
		//// Если грузим заморозки и бонусные дни только для открытых	
		// Если СтруктураРеквизитов.Статус = 2 Тогда 
		//	Если СрокДействияСУчетомЗаморозки <> ЧистыйСрокДействия Тогда 
		//		ЧленствоОбъект.СрокДействияТип 	= Перечисления.Периодичность.День;
		//		// ЧленствоОбъект.СрокДействия 	= Цел((Макс(СрокДействияСУчетомЗаморозки, ЧистыйСрокДействия) - СтруктураРеквизитов.НачалоКонтракта) / 86400);
		//		ЧленствоОбъект.СрокДействия 	= Цел((СрокДействияСУчетомЗаморозки - СтруктураРеквизитов.НачалоКонтракта) / 86400);			
		//	КонецЕсли;	
		// Иначе
		//	Если СрокДействияИтоговыйСуммовой <> СрокДействияСУчетомЗаморозки Тогда 
		//		ЧленствоОбъект.СрокДействияТип 	= Перечисления.Периодичность.День;			
		//		ЧистыйСрокДействия 				= Макс(СрокДействияСУчетомЗаморозки, СрокДействияИтоговыйСуммовой) - (СтруктураРеквизитов.БонусныхДней + СтруктураРеквизитов.КоличествоДнейЗаморозки) * 86400;
		//		ЧленствоОбъект.СрокДействия 	= Цел((ЧистыйСрокДействия - СтруктураРеквизитов.НачалоКонтракта) / 86400);
		//	КонецЕсли;	
		// КонецЕсли;
	КонецЕсли;
	
	ЧленствоОбъект.КоличествоДнейЗаморозок 	= СтруктураРеквизитов.Заморозок;
	ЧленствоОбъект.КоличествоПосещений 		= СтруктураРеквизитов.КоличествоПосещений; // СтруктураРеквизитов.КоличествоПосещений - СтруктураРеквизитов.ПотраченоПосещений;
	ЧленствоОбъект.СтруктурнаяЕдиница 		= ПараметрыЗагрузки.СтруктурнаяЕдиница;
	
	// ЧленствоОбъект.УстановитьНовыйНомер();	
	// ЧленствоОбъект.ОбменДанными.Загрузка = Истина;		
	// ЧленствоОбъект.Записать(РежимЗаписиДокумента.Запись);
	Попытка
		ЗаписатьДокумент(ЧленствоОбъект);												
	Исключение
		// Запись в лог
		ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + СтрШаблон(НСтр("ru = 'Ошибка создания док-та Членство/Пакет услуг клиента ""%1"" Номер контракта: %2';en= 'Error creating document Membership/Client service package ""%1"" Contract number: %2'"), Строка(СтруктураРеквизитов.Клиент), СокрЛП(СтруктураРеквизитов.НомерКонтракта) + Символы.ПС + ОписаниеОшибки()));						
	КонецПопытки;	
	
	// Доступные структурные единицы
	НаборЗаписей 							= РегистрыСведений.СтруктурныеЕдиницыОбъектов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Значение      = ЧленствоОбъект.Ссылка;
	НаборЗаписей.Отбор.Объект.Использование = Истина;	
	НоваяЗапись                    			= НаборЗаписей.Добавить();
	НоваяЗапись.СтруктурнаяЕдиница 			= ПараметрыЗагрузки.СтруктурнаяЕдиница;
