// Функция проверяет на дубликат контрагента.
//
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты - Ссылка на контрагента
//
// Возвращаемое значение:
//	Структура - реквизиты выбранного контрагента
//
Функция ПроверитьНаДублированиеКлиентаПоля(Контрагент, Поля) Экспорт
		
	МассивПолейДляПроверки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Поля, ";");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Ссылка <> &КонтрагентИсключение";
	Запрос.УстановитьПараметр("КонтрагентИсключение", Контрагент.Ссылка);
	Для Каждого ЭлементМассива Из МассивПолейДляПроверки Цикл
		Запрос.Текст = Запрос.Текст + "
			|	И Контрагенты." + ЭлементМассива + " = &" + ЭлементМассива;
		Запрос.УстановитьПараметр(ЭлементМассива, Контрагент[ЭлементМассива]);
	КонецЦикла;
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции // ПроверитьНаДублированиеКлиента()

// Функция проверяет на дубликат контрагента по контактной информации.
//
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты - Ссылка на контрагента
//
// Возвращаемое значение:
//	Структура - реквизиты выбранного контрагента
//
Функция ПроверитьНаДублированиеКлиентаКИ(Контрагент, ТипКИ, ЗначениеЭлемента) Экспорт
		
	Если НЕ ЗначениеЗаполнено(ЗначениеЭлемента) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
		// Уберём лишние символы из номера
		СтроковоеЗначение = УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(ЗначениеЭлемента);
		Если НЕ ЗначениеЗаполнено(СтроковоеЗначение) Тогда 
			Возврат Неопределено;
		КонецЕсли;
		Если СтрДлина(СтроковоеЗначение) = 11 Тогда
			РегиональныеНастройкиСЕ = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки();
			СтраныУчета = РегиональныеНастройкиСЕ.СтранаУчета;
			Если ЗначениеЗаполнено(СтраныУчета) Тогда 
				КодСтраныУчета = СтраныУчета.Код;
				Если ЗначениеЗаполнено(КодСтраныУчета) Тогда 
					Если КодСтраныУчета = "643" Тогда 
						Формат1 = "7" + Прав(СтроковоеЗначение, 10);
						Формат2 = "8" + Прав(СтроковоеЗначение, 10);
						Запрос.Текст = "ВЫБРАТЬ
						               |	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
						               |ИЗ
						               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
						               |ГДЕ
						               |	КонтрагентыКонтактнаяИнформация.Тип = &ТипЭлемента
						               |	И (КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &ЗначениеЭлементаФормат1
						               |			ИЛИ КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &ЗначениеЭлементаФормат2)
						               |	И КонтрагентыКонтактнаяИнформация.Ссылка <> &КонтрагентИсключение";
						
						Запрос.УстановитьПараметр("КонтрагентИсключение"	, Контрагент);
						Запрос.УстановитьПараметр("ТипЭлемента"				, ТипКИ);
						Запрос.УстановитьПараметр("ЗначениеЭлементаФормат1"	, Формат1);
						Запрос.УстановитьПараметр("ЗначениеЭлементаФормат2"	, Формат2);
						
						Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
						
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;	
		Запрос.Текст = "ВЫБРАТЬ
		               |	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
		               |ИЗ
		               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		               |ГДЕ
		               |	КонтрагентыКонтактнаяИнформация.Тип = &ТипЭлемента
		               |	И КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &ЗначениеЭлемента
		               |	И КонтрагентыКонтактнаяИнформация.Ссылка <> &КонтрагентИсключение";
		
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда 
		СтроковоеЗначение = ЗначениеЭлемента;
		Запрос.Текст = "ВЫБРАТЬ
		               |	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
		               |ИЗ
		               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		               |ГДЕ
		               |	КонтрагентыКонтактнаяИнформация.Тип = &ТипЭлемента
		               |	И КонтрагентыКонтактнаяИнформация.Представление ПОДОБНО &ЗначениеЭлемента
		               |	И КонтрагентыКонтактнаяИнформация.Ссылка <> &КонтрагентИсключение";
		
	Иначе
		Возврат Неопределено;	
	КонецЕсли;	
	
	Запрос.УстановитьПараметр("КонтрагентИсключение"	, Контрагент);
	Запрос.УстановитьПараметр("ТипЭлемента"				, ТипКИ);
	Запрос.УстановитьПараметр("ЗначениеЭлемента"		, СтроковоеЗначение);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции // ПроверитьНаДублированиеКлиентаКИ()

// Функция, выполняющая отбор клиентов по заданным условиям
//
Функция ВернутьВсехКлиентовУчавствующихВРассылке() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Получатель,
		|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
		|	И КонтрагентыКонтактнаяИнформация.НомерТелефона <> """"
		|	И КонтрагентыКонтактнаяИнформация.Ссылка.ЭтоГруппа = ЛОЖЬ
		|	И КонтрагентыКонтактнаяИнформация.Ссылка.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И КонтрагентыКонтактнаяИнформация.Ссылка.НеУчаствоватьВРассылкеСообщений = ЛОЖЬ
		|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления";
		
	Таблица = Запрос.Выполнить().Выгрузить();
	МассивПолучателей 		= Таблица.ВыгрузитьКолонку("Получатель");
