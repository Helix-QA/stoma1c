// Процедура - Изменить интерфейс формы для создания пациента
//
Процедура ИзменитьИнтерфейсФормыДляСозданияПациента() 

	ИскомыйКлиентКеш = ИскомыйКлиент; 
	ФИО = ОбщегоНазначенияКлиентСтоматология.ВернутьФИОКлиента(ИскомыйКлиент);			
	
	ИскомыйКлиент = ИскомыйКлиентКеш;
	
	ЭтаФорма.Фамилия_НовыйПациент = ?(ЗначениеЗаполнено(ФИО.Фамилия), ФИО.Фамилия, "");
	ЭтаФорма.Имя_НовыйПациент = ?(ЗначениеЗаполнено(ФИО.Имя), ФИО.Имя, "");
	ЭтаФорма.Отчество_НовыйПациент = ?(ЗначениеЗаполнено(ФИО.Отчество), ФИО.Отчество, "");
	
	Элементы.Группировка2НовыйПациент.Видимость = Истина;
	Если НЕ ЗначениеЗаполнено(Телефон_НовыйПациент) Тогда 
		Телефон_НовыйПациент = "";                           
	КонецЕсли;
	
	// Скрываем долги
	Элементы.ГруппаДолгиКонтрагента.Видимость = Ложь;
	
	// Очищаем сделки
	// УправлениеИнтерфейсамиСервер.ОчиститьГруппуВиджетСделки(ЭтаФорма);
	
	Если НЕ ПризнакСозданияНовогоПациента Тогда
		ПризнакСозданияНовогоПациента = Истина;
		Элементы.ГруппаКонтрагента.Видимость = Ложь;
	КонецЕсли;
	
