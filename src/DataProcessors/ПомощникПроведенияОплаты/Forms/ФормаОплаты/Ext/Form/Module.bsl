// Функция, устанавливает вид оплаты бонусным счетом.
//
Процедура УстановитьВидОплатыБонуснымСчетом()
	
	МассивДокументов = ПолучитьДокументыЗадолженностиСервер(Истина);
	
	ОстаткиБонусныхСчетов = РегистрыНакопления.БонусныеСчета.ПолучитьОстаткиНаБонусныхСчетахКонтрагента(
								ЭтотОбъект.Контрагент, 
								ПолучитьМассивНачисленныхБонусныхСчетов(МассивДокументов));
	
	Если ОстаткиБонусныхСчетов.Количество() > 0
		И ОстаткиБонусныхСчетов.Итог("Сумма") > 0 Тогда
		
		СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.БонусныйСчет,,,,,,,, "Бонусные счета");		
    	
    	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
    		
    		ЭлементДереваЛС                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
    		ЭлементДереваЛС.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.БонусныйСчет; 
    		ЭлементДереваЛС.Представление      = "Бонусные счета";
    		    		
    	Иначе
    		ЭлементДереваЛС = СущВидыОплатВерхУр[0];
    	КонецЕсли;
		
		Для Каждого СтрокаТЧ Из ОстаткиБонусныхСчетов Цикл
			
			БонусныйСчет 			   = СтрокаТЧ.БонусныйСчет;
			ДопустимыйОстатокДляОплаты = УправлениеМаркетинговымиАкциями.ПолучитьСуммуДоступнуюДляОплатыБонуснымСчетомВМассивеРеализацийПриемов(
												МассивДокументов,
												БонусныйСчет);
			 
			Если ДопустимыйОстатокДляОплаты > 0 Тогда
				
				Наименование 			 = Справочники.БонусныеСчета.ПолучитьПредставлениеБонусногоСчета(БонусныйСчет);
				ПредставлениеКонтрагента = ?(Контрагент <> СтрокаТЧ.Контрагент, 
												" [" 
												+ СтрокаТЧ.Контрагент 
												+ ", " 
												+ РегистрыСведений.РодственныеСвязи.ОпределитьРодство(СтрокаТЧ.Контрагент, Контрагент) + "]"
												, "");
				
				// Получаем уже выбранную сумма по данному виду счета
				СуммаИспользовано  = СуммаВнесенныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.БонусныйСчет,,,, СтрокаТЧ.БонусныйСчет);			
    			СущВидыОплатНижнУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.БонусныйСчет,,,,,,,,, СтрокаТЧ.БонусныйСчет);
				
    			Если НЕ ЗначениеЗаполнено(СущВидыОплатНижнУр) Тогда
    				НоваяСтрока = ЭлементДереваЛС.ПолучитьЭлементы().Добавить();
    				НоваяСтрока.СертификатПартия   = Справочники.ПартииНоменклатуры.ПустаяСсылка();

    			Иначе
    				НоваяСтрока = СущВидыОплатНижнУр[0];
    			КонецЕсли;
			
				НоваяСтрока.БонусныйСчет	             = СтрокаТЧ.БонусныйСчет;
				НоваяСтрока.МаксСуммаСписания     		 = ДопустимыйОстатокДляОплаты;
				НоваяСтрока.Контрагент	        	     = СтрокаТЧ.Контрагент;
				НоваяСтрока.ТипДенежныхСредств           = Перечисления.ТипыДенежныхСредств.БонусныйСчет; 
				НоваяСтрока.ОстатокСредств               = СтрокаТЧ.Сумма - СуммаИспользовано;	
				НоваяСтрока.Представление                = Наименование 
															+ ПредставлениеКонтрагента
															+ " (" 
															+ Формат(НоваяСтрока.ОстатокСредств, "ЧДЦ=2; ЧН=0,00") + ")";				
				НоваяСтрока.КассаОплаты                  = ЭтотОбъект.ТекущаяКасса;

			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;		
		
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - возвращает таблицу начисленных бонусных счетов по маркетинговой акции.
//
Функция ПолучитьМассивНачисленныхБонусныхСчетов(МассивДокументов)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	БонусныеСчетаОбороты.БонусныйСчет КАК БонусныйСчет,
	|	ЕСТЬNULL(СУММА(БонусныеСчетаОбороты.СуммаПриход), 0) КАК Сумма,
	|	БонусныеСчетаОбороты.БонусныйСчет.ВладелецБонусногоСчета КАК ВладелецБонусногоСчета,
	|	БонусныеСчетаОбороты.БонусныйСчет.ВидБонусногоСчета КАК ВидБонусногоСчета,
	|	БонусныеСчетаОбороты.БонусныйСчет.ВидБонусногоСчета.Наименование КАК Наименование
	|ИЗ
	|	РегистрНакопления.БонусныеСчета.Обороты(, , Регистратор, ) КАК БонусныеСчетаОбороты
	|ГДЕ
	|	БонусныеСчетаОбороты.Регистратор В(&МассивДокументов)
	|
	|СГРУППИРОВАТЬ ПО
	|	БонусныеСчетаОбороты.БонусныйСчет,
	|	БонусныеСчетаОбороты.БонусныйСчет.ВладелецБонусногоСчета,
	|	БонусныеСчетаОбороты.БонусныйСчет.ВидБонусногоСчета,
	|	БонусныеСчетаОбороты.БонусныйСчет.ВидБонусногоСчета.Наименование");
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции 

&НаСервере
// Процедура - Установить вид оплаты аванс
// 
Процедура УстановитьВидОплатыАвансомПоДокументу(НайденныеСтроки, ТипАванса)
	
	ЭтоАвансПоПлануЛечения 	  = (ТипАванса = 1);
	ЭтоАвансПоНарядЗаказу 	  = (ТипАванса = 2);
		
	Если ЭтоАвансПоПлануЛечения Тогда
		
		ДокументАванса				 = НайденныеСтроки[0].ПланЛечения;
		ПредставлениеДокументаАванса = ФормированиеПечатныхФорм.СформироватьПредставлениеДокумента(ДокументАванса);
		
	ИначеЕсли ЭтоАвансПоНарядЗаказу Тогда
		
		ДокументАванса				 = НайденныеСтроки[0].НарядЗаказ;
		ПредставлениеДокументаАванса = ФормированиеПечатныхФорм.СформироватьПредставлениеДокумента(ДокументАванса);

	КонецЕсли;
	
	СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.Аванс,,,,,,,, "Авансы");		
	
	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
		
		ЭлементДереваЛС                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
		ЭлементДереваЛС.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс; 
		ЭлементДереваЛС.Представление      = "Авансы";
		
	Иначе
		ЭлементДереваЛС = СущВидыОплатВерхУр[0];
	КонецЕсли;

	СуществВидыОплат = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.Аванс,,,,,,, ДокументАванса);
	
	Если НЕ ЗначениеЗаполнено(СуществВидыОплат) Тогда
		ЭлементДерева = ЭлементДереваЛС.ПолучитьЭлементы().Добавить();
	Иначе
		ЭлементДерева = СуществВидыОплат[0];
	КонецЕсли;
	
	ОстатокАванса = НайденныеСтроки[0].СуммаАванса; 
	
	// найти сумму возможной оплаты по приему
	Прием = НайденныеСтроки[0].Прием;
	
	Для Каждого СтрокаТЧ Из Прием.Лечение Цикл
		
		Если ЗначениеЗаполнено(СтрокаТЧ.ДокументАванса) И СтрокаТЧ.ДокументАванса = ДокументАванса Тогда			
			ОстатокАванса = ОстатокАванса + СтрокаТЧ.Всего;		
		КонецЕсли;
		
	КонецЦикла;
	
	ЭлементДерева.ТипДенежныхСредств      = Перечисления.ТипыДенежныхСредств.Аванс;	
	ЭлементДерева.ОстатокСредств          = НайденныеСтроки[0].СуммаДоступнаяДляОплатыАвансом;
	ЭлементДерева.МаксСуммаСписания       = ЭлементДерева.ОстатокСредств;
	ЭлементДерева.Контрагент	          = Контрагент;
	ЭлементДерева.Представление           = ПредставлениеДокументаАванса + " (" + Формат(НайденныеСтроки[0].СуммаДоступнаяДляОплатыАвансом, "ЧДЦ=2; ЧН=0,00") + ")" ;	
	ЭлементДерева.ДокументАванса          = ДокументАванса; 
	ЭлементДерева.КассаОплаты             = ЭтотОбъект.ТекущаяКасса;		
	ИндексСтрокиВидОплатыАвансу           = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Индекс(ЭлементДерева);
	
	СписокИндексовСтрок.Добавить(ИндексСтрокиВидОплатыАвансу);

КонецПроцедуры

