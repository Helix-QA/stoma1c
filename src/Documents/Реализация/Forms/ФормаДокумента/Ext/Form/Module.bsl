		мПараметрыВыбора.Вставить("Склад"             , Объект.Склад);
		мПараметрыВыбора.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
		мПараметрыВыбора.Вставить("Дата"              , Объект.Дата);
        мПараметрыВыбора.Вставить("МножественныйВыбор", Ложь);

		ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", мПараметрыВыбора,,,,, Новый ОписаниеОповещения("ПодаркиПартияНачалоВыбораЗавершение", ЭтотОбъект, Новый Структура("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
		
	КонецЕсли;

