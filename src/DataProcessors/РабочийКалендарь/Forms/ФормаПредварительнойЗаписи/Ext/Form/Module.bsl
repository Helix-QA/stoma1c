&НаКлиенте
// Обработчик активации строки табличного документа
//
Процедура ТабличныйДокументПриАктивизацииОбласти(Элемент)	
	
	Расшифровка                 = Элементы.ТабличныйДокумент.ТекущаяОбласть.Расшифровка;
	ПЗРасшифровкаТекущейОбласти = Неопределено;
	Если Не Расшифровка = Неопределено И ТипЗнч(Расшифровка) = Тип("Строка") Тогда				
    	ПЗРасшифровкаТекущейОбласти = КонвертироватьРасшифровкуТабличногоДокумента(Расшифровка,ПолучитьСтраницуМенеджера());					
	КонецЕсли;	  
	
КонецПроцедуры

&НаКлиенте
// Функция конвертирования строки расшифровки графика ПЗ в структуру данных
Функция КонвертироватьРасшифровкуТабличногоДокумента(Расшифровка,СтраницаМенеджера)  
	
	ШаблонТипов = Новый Структура;
	ШаблонТипов.Вставить("Дата"        ,Тип("Дата"));
	ШаблонТипов.Вставить("Интервал"    ,Тип("Число"));
	Если СтраницаМенеджера = "Сотрудники" Тогда
		ШаблонТипов.Вставить("Сотрудник"   ,Тип("СправочникСсылка.Сотрудники"));
	ИначеЕсли СтраницаМенеджера = "Помещения" Тогда
		ШаблонТипов.Вставить("Сотрудник"   ,Тип("СправочникСсылка.Помещения"));
	Иначе
		ШаблонТипов.Вставить("Сотрудник"   ,Тип("Строка"));
	КонецЕсли;
	ШаблонТипов.Вставить("РабочееВремя",Тип("Булево"));
	ШаблонТипов.Вставить("Событие"     ,Тип("ДокументСсылка.Событие"));
	ШаблонТипов.Вставить("ИндексВТЧ"   ,Тип("Массив"));
	
	ШаблонТипов.Вставить("Заглушка1"   ,Неопределено);
	ШаблонТипов.Вставить("Заглушка2"   ,Неопределено);
	ШаблонТипов.Вставить("КоличествоВЛистеОжидания" ,Тип("Число"));
	Возврат ОбщегоНазначенияСтоматология.ПривестиСтрокуВНаборДанных(Расшифровка,ШаблонТипов);
	
КонецФункции

&НаКлиенте
// Обработчик события ОбработкаРасшифровки элемента ТабличныйДокумент.
//
Процедура ТабличныйДокументОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)	
	
	СтандартнаяОбработка = Ложь;
	СтруктураДанных      = ПЗРасшифровкаТекущейОбласти;
	Если ТипЗнч(Расшифровка) = Тип("Строка") Тогда		
		// СтруктураДанных = КонвертироватьРасшифровкуТабличногоДокумента(Расшифровка,ПолучитьСтраницуМенеджера());
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("Дата") Тогда			
		Объект.Дата               = Расшифровка;		
		ОбновитьГрафик(,Истина);			
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("СправочникСсылка.Сотрудники") Тогда 		
		ОткрытьФорму("Справочник.Должности.ФормаОбъекта", Новый Структура("Ключ",ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Расшифровка, "Должность")));	
	ИначеЕсли ТипЗнч(Расшифровка) = Тип("СправочникСсылка.Помещения") Тогда 		
		ОткрытьФорму("Справочник.Помещения.ФормаОбъекта", Новый Структура("Ключ",Расшифровка));		
	КонецЕсли;	
	// Если удалось успешно конвертировать строку данных
	Если НЕ СтруктураДанных = Неопределено Тогда
		
		Если СтруктураДанных.Свойство("КоличествоВЛистеОжидания") И НЕ СтруктураДанных.КоличествоВЛистеОжидания = Неопределено
			И ЗначениеЗаполнено(СтруктураДанных.Сотрудник) Тогда
			
			Если ЗначениеЗаполнено(СтруктураДанных.КоличествоВЛистеОжидания) Тогда
				ОткрытьЛистОжиданияПациентов(СтруктураДанных.Сотрудник, СтруктураДанных.Дата);
			КонецЕсли;
			
			Возврат;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтруктураДанных.Событие) Тогда		
			СтандартнаяОбработка = Ложь;
			ОткрытьФорму("Документ.Событие.ФормаОбъекта", Новый Структура("Ключ", СтруктураДанных.Событие));		
		ИначеЕсли НЕ ЗначениеЗаполнено(СтруктураДанных.Событие)Тогда		
			СтандартнаяОбработка = Ложь;
			СоздатьСобытие(Неопределено);				
	    КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Обработчик дополнительной расшифровки табличного документа 
//
Процедура ТабличныйДокументОбработкаДополнительнойРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка)
	
	// Установка состояний кнопкам контекстного меню
	Если Не ПЗРасшифровкаТекущейОбласти = Неопределено Тогда
		// Устанавливаем доступность всем в Ложь
		СтруктураСостояния = Новый Структура;
		СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюСоздатьСобытие"			,Ложь);
		СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюОтменитьСобытие"			,Ложь);
		СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаВырезать"			,Ложь);
		СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаКопировать"			,Ложь);
		СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюПравкаВставить"			,Ложь);
		СтруктураСостояния.Вставить("ТабличныйДокументКонтекстноеМенюЗаписатьИзЛистаОжидания"	,Ложь);
		// В зависимости от рассшифровки, устанавливаем видимость в Истинну для определенных элементов меню
		// Для области занятой существующим ПЗ
		Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда	
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюОтменитьСобытие  	= Истина;			
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПравкаКопировать 	= Истина;	
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПравкаВырезать   	= Истина;				
		// Для свободной области	
		Иначе	
			Если ЗначениеЗаполнено(ОтборСотрудник) Тогда				
				Если БуферОбмена.Буфер <> Неопределено Тогда
					СтруктураСостояния.ТабличныйДокументКонтекстноеМенюПравкаВставить = Истина;
				КонецЕсли;
			КонецЕсли;
			
			Сотрудник = ?(ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник) И ТипЗнч(ПЗРасшифровкаТекущейОбласти.Сотрудник) = Тип("СправочникСсылка.Сотрудники")
						, ПЗРасшифровкаТекущейОбласти.Сотрудник
						, ОтборСотрудник);
						
			ВЛистеОжиданияЕстьПациенты = Ложь;
			Если ЗначениеЗаполнено(Сотрудник) Тогда
				ВЛистеОжиданияЕстьПациенты = НЕ ЭтотОбъект.СписокСотрудниковВЛистеОжидания.НайтиПоЗначению(Сотрудник) = Неопределено;
			КонецЕсли;
			
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюЗаписатьИзЛистаОжидания = ВЛистеОжиданияЕстьПациенты;
			
			СтруктураСостояния.ТабличныйДокументКонтекстноеМенюСоздатьСобытие = Истина;
		КонецЕсли;		
		// Установить доступность элементам	
		Для Каждого ЭлементС ИЗ СтруктураСостояния Цикл		
			Если НЕ Элементы[ЭлементС.Ключ].Доступность = ЭлементС.Значение Тогда
				Элементы[ЭлементС.Ключ].Доступность = ЭлементС.Значение;
			КонецЕсли;		
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЛегендаЦветаНажатие(Команда)
	
	ЛегендаЭлемент = ТекущийЭлемент;
	Если Найти(ЛегендаЭлемент.Имя, "КнопкаСтатус_") = Неопределено ИЛИ Найти(ЛегендаЭлемент.Имя, "КнопкаСтатус_") = 0 Тогда
		Возврат;
	КонецЕсли;

	ДиалогЦвета = Новый ДиалогВыбораЦвета();
	#Если Не ВебКлиент Тогда
		ДиалогЦвета.Цвет = ЛегендаЭлемент .ЦветФона;
	#КонецЕсли
	
	ДиалогЦвета.Показать(Новый ОписаниеОповещения("ЛегендаЦветаНажатиеЗавершение", ЭтотОбъект, Новый Структура("ДиалогЦвета, ЛегендаЭлемент", ДиалогЦвета, ЛегендаЭлемент)));

	
КонецПроцедуры

&НаКлиенте
Процедура ЛегендаЦветаНажатиеЗавершение(Цвет, ДополнительныеПараметры) Экспорт
	
	ДиалогЦвета = ДополнительныеПараметры.ДиалогЦвета;
	ЛегендаЭлемент = ДополнительныеПараметры.ЛегендаЭлемент;
	
	Если (Цвет <> Неопределено) = Истина Тогда
		ЛегендаЭлемент.ЦветФона = Цвет;
		НаименованиеСтатуса = Элементы.Найти("НадписьСтатус_"+Сред(ЛегендаЭлемент.Имя, СтрДлина("КнопкаСтатус_")+1)).Заголовок;
		ОбщегоНазначенияСтоматология.УстановитьЦветФонаСобытия(ПолучитьСтатусСобытияПоНаименованию(НаименованиеСтатуса), ,Цвет);
		ОбновитьГрафик();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьСтатусСобытияПоНаименованию(НаименованиеСтатуса)
	
	Для Каждого Статус Из Перечисления.СтатусыСобытия Цикл
		Если Строка(Статус) = НаименованиеСтатуса Тогда
			Возврат Статус;
		КонецЕсли;
	КонецЦикла;
	
КонецФункции

&НаКлиенте
// Процедура - обработчик команды открытия формы планирования
//
Процедура ДобавитьВЛистОжидания(Команда)
	
	// Открыть форму создания направления
	ПараметрыФормы = Новый Структура;
	Если ПЗРасшифровкаТекущейОбласти <> Неопределено Тогда
		
		ПараметрыФормы.Вставить("ДатаНачалаПериода", ПЗРасшифровкаТекущейОбласти.Дата);
		ПараметрыФормы.Вставить("ДатаОкончанияПериода", ПЗРасшифровкаТекущейОбласти.Дата);
		
		Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Сотрудник)
			И ТипЗнч(ПЗРасшифровкаТекущейОбласти.Сотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда 
			
			ПараметрыФормы.Вставить("Сотрудник", ПЗРасшифровкаТекущейОбласти.Сотрудник);
		ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект.ОтборСотрудник) Тогда
			ПараметрыФормы.Вставить("Сотрудник", ЭтотОбъект.ОтборСотрудник);
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПараметрыФормы.ДатаНачалаПериода) Тогда
		ПараметрыФормы.ДатаНачалаПериода = Объект.Дата;		
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(ПараметрыФормы.ДатаОкончанияПериода) Тогда
		ПараметрыФормы.ДатаНачалаПериода = Объект.Дата;		
	КонецЕсли;
	
	ПараметрыФормы.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	
