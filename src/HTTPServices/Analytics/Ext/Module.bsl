
#Область СлужебныеПроцедурыИФункции

// Функция, получает вебхуки с сервиса Сalltouch.
//
Функция CalltouchPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		api_key = Сред(Запрос.ОтносительныйURL, 12, СтрДлина(Запрос.ОтносительныйURL));
		
		// Логирование
		ЛогироватьСобытие = Ложь; // Константы.ЛогироватьHTTP.Получить();	
		
		Если ЛогироватьСобытие > 0 Тогда
			ВремяНачалаОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
			UIDЗапроса     = Новый УникальныйИдентификатор();
			HTTPЗапросЛога = Запрос;
			ДатаЛога       = ТекущаяДатаСеанса();
			ТипЗапроса     = Перечисления.HTTPСервисы.Analytics;
			HTTPШаблон     = "Calltouch";
		КонецЕсли;
		//\\
		
		ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(api_key, Перечисления.ТипыВнешнихСистем.Calltouch);
		Если НЕ ЗначениеЗаполнено(ВнешняяСистема) Тогда
			
			Ответ = Новый HTTPСервисОтвет(400, "Не найдена внешняя система");
			
			// Логирование
			Если ЛогироватьСобытие > 0 Тогда
				
				ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
				ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
				СтатусСобытия          = Перечисления.СтатусыЗапросов.ЗавершенСОшибками;
				мОтвет                 = Ответ.ПолучитьТелоКакСтроку();				
				РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
				HTTPЗапросЛога, 
				ДатаЛога, 
				UIDЗапроса, 
				ТипЗапроса, 
				HTTPШаблон, 
				СтатусСобытия, 
				ВремяВыполнения, 
				, 
				, 
				мОтвет, 
				, 
				,
				400); 								
				
			КонецЕсли;
			
			Возврат Ответ;
			
		КонецЕсли;
		
		ТелоЗапроса   = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);	
		ПараметрыТела = Новый Структура();
		
		Для Каждого ЭлементМассива Из СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ТелоЗапроса, "&") Цикл	
			Массив = СтрРазделить(ЭлементМассива, "=");
			РаспарситьСтроку(ПараметрыТела, Массив[0], Массив[1]); 				
		КонецЦикла;
		
		// Если тестовый запрос.
		Если ПараметрыТела.Свойство("requestId") И ПараметрыТела.requestId = "{requestId}" Тогда
			
			Ответ = Новый HTTPСервисОтвет(200, "Тестовый запрос");
			
			// Логирование
			Если ЛогироватьСобытие > 0 Тогда
				
				ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
				ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
				СтатусСобытия          = Перечисления.СтатусыЗапросов.Выполнен;
				мОтвет                 = Ответ.ПолучитьТелоКакСтроку();				
				
				Если ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЛогироватьСобытие, СтатусСобытия, ВремяВыполнения)Тогда
					
					РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
					HTTPЗапросЛога, 
					ДатаЛога, 
					UIDЗапроса, 
					ТипЗапроса, 
					HTTPШаблон, 
					СтатусСобытия, 
					ВремяВыполнения, 
					ВнешняяСистема, 
					api_key, 
					мОтвет, 
					, 
					,
					200); 								
				КонецЕсли;
			КонецЕсли;
			
			Возврат Ответ;
			
		КонецЕсли;
		
		// Если Звонок, то будем обогощать звонки информаций от коллтрекинга.
		Если ПараметрыТела.Свойство("leadtype") И ПараметрыТела.leadtype = "call" Тогда
			
			// Если в Calltouch фиксируется начало и окончание звонка, то не создаем заявку дважды.
			Если ПараметрыТела.Свойство("callphase") И ПараметрыТела.callphase = "calldisconnected" Тогда
				
				Ответ = Новый HTTPСервисОтвет(200, "Окончание звонка");
				
				// Логирование
				Если ЛогироватьСобытие > 0 Тогда
					
					ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
					ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
					СтатусСобытия          = Перечисления.СтатусыЗапросов.Выполнен;
					мОтвет                 = Ответ.ПолучитьТелоКакСтроку();	
					Если ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЛогироватьСобытие, СтатусСобытия, ВремяВыполнения) Тогда
						
						РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
						HTTPЗапросЛога, 
						ДатаЛога, 
						UIDЗапроса, 
						ТипЗапроса, 
						HTTPШаблон, 
						СтатусСобытия, 
						ВремяВыполнения, 
						ВнешняяСистема, 
						api_key, 
						мОтвет, 
						, 
						,
						200); 								
					КонецЕсли;
					
				КонецЕсли;
				
				Возврат Ответ;
				
			КонецЕсли;

		КонецЕсли;	
			
		Если ПараметрыТела.Свойство("leadtype") И (ПараметрыТела.leadtype = "request" Или ПараметрыТела.leadtype = "call") Тогда
			
					
			leadtype 			 = ?(ПараметрыТела.Свойство("leadtype")		, ПараметрыТела.leadtype	, Неопределено);
			subject 			 = ?(ПараметрыТела.Свойство("subject")		, ПараметрыТела.subject		, Неопределено);
			ИдентификаторЗаявки  = ?(ПараметрыТела.Свойство("requestId") 	, ПараметрыТела.requestId  	, Неопределено);
			ВремяСозданияЗаявки	 = ?(ПараметрыТела.Свойство("requestDate")	, ПараметрыТела.requestDate	, Неопределено);
			ФИО                  = ?(ПараметрыТела.Свойство("fio")        	, ПараметрыТела.fio        	, Неопределено);
			НомерТелефона        = ?(ПараметрыТела.Свойство("callerphone")	, ПараметрыТела.callerphone	, Неопределено);
			АдресЭП              = ?(ПараметрыТела.Свойство("email")      	, ПараметрыТела.email      	, Неопределено);
			utm_campaign		 = ?(ПараметрыТела.Свойство("utm_campaign")	, ПараметрыТела.utm_campaign, Неопределено);
			utm_content	    	 = ?(ПараметрыТела.Свойство("utm_content") 	, ПараметрыТела.utm_content , Неопределено);
			// utm_medium	    	 = ?(ПараметрыТела.Свойство("utm_medium")  	, ПараметрыТела.utm_medium  , Неопределено);
			// utm_source	    	 = ?(ПараметрыТела.Свойство("utm_source")  	, ПараметрыТела.utm_source  , Неопределено);
			utm_term	    	 = ?(ПараметрыТела.Свойство("utm_term")    	, ПараметрыТела.utm_term    , Неопределено);
			ct_cid		    	 = ?(ПараметрыТела.Свойство("sessionId")    , ПараметрыТела.sessionId   , Неопределено);
			ga_cid		    	 = ?(ПараметрыТела.Свойство("gcid")    		, ПараметрыТела.gcid   		, Неопределено);
			ym_cid		    	 = ?(ПараметрыТела.Свойство("yaClientId")   , ПараметрыТела.yaClientId  , Неопределено);
			Источник	    	 = ?(ПараметрыТела.Свойство("source")   	, ПараметрыТела.source   	, Неопределено);
			Канал		    	 = ?(ПараметрыТела.Свойство("medium")   	, ПараметрыТела.medium   	, Неопределено);
			РекламнаяСсылка    	 = ?(ПараметрыТела.Свойство("url")   		, ПараметрыТела.url   		, Неопределено);
			
			Если ПараметрыТела.Свойство("utm_source") Тогда
				utm_source = ?(ПараметрыТела.utm_source = "<не+указано>", Источник, ПараметрыТела.utm_source);
			Иначе
				utm_source = Неопределено;
			КонецЕсли;
			
			Если ПараметрыТела.Свойство("utm_medium") Тогда
				utm_medium = ?(ПараметрыТела.utm_medium = "<не+указано>", Канал, ПараметрыТела.utm_medium);
			Иначе
				utm_medium = Неопределено;
			КонецЕсли;
			
			МассивКомментариев   = ?(ПараметрыТела.Свойство("comment")    	, ПараметрыТела.comment    	, Неопределено);
			ВремяСоздания		 = ПолучитьДатуИзСтрокиCoMagic(ВремяСозданияЗаявки);
			
			Комментарий          = "Заявка создана сервисом Calltouch " + ВремяСоздания + "." + Символы.ПС;
			
			Если ЗначениеЗаполнено(subject) Тогда
				Комментарий = Комментарий + "Форма заявки: """ + СтрЗаменить(subject, "+", " ") + """." + Символы.ПС;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(МассивКомментариев) И ТипЗнч(МассивКомментариев) = Тип("Массив") И МассивКомментариев.Количество() > 0 Тогда
				Для Каждого СтрокаМ Из МассивКомментариев Цикл
					Комментарий = Комментарий + СтрокаМ.comment + Символы.ПС;
				КонецЦикла;
			КонецЕсли;
			
			Клиент = Неопределено;
			Если ЗначениеЗаполнено(НомерТелефона) Тогда
				Клиент = Справочники.Контрагенты.ПолучитьКонтрагентаПоНомеруТелефона(НомерТелефона);
			КонецЕсли;
			
			Фамилия  = Неопределено;
			Имя      = Неопределено;
			Отчество = Неопределено;
			
			МассивФИО = СтрРазделить(ФИО, "+"); 
			
			Если МассивФИО.Количество() > 0 Тогда
				Фамилия = СокрЛП(МассивФИО[0]);		
			КонецЕсли;
			
			Если МассивФИО.Количество() > 1 Тогда
				Имя = СокрЛП(МассивФИО[1]);	
			КонецЕсли;
			
			Если МассивФИО.Количество() > 2 Тогда
				Отчество = СокрЛП(МассивФИО[2]);	
			КонецЕсли;
					
			Заявка	= ПолучитьЗаявкуКлиентаCalltouch(ct_cid, ИдентификаторЗаявки);
			
			Если Не ЗначениеЗаполнено(Заявка) Тогда
				
				СтруктураПараметров = Новый Структура;
				СтруктураПараметров.Вставить("ДатаСоздания"      			, ?(ЗначениеЗаполнено(ВремяСоздания), ВремяСоздания, ТекущаяДатаСеанса()));	
				СтруктураПараметров.Вставить("Фамилия"           			, Фамилия);	
				СтруктураПараметров.Вставить("Имя"               			, Имя);	
				СтруктураПараметров.Вставить("Отчество"          			, Отчество);	
				СтруктураПараметров.Вставить("НомерТелефона"    			, НомерТелефона);
				СтруктураПараметров.Вставить("АдресЭП"           			, АдресЭП);	
				
				ПараметрыПоиска = Новый Структура();
				ПараметрыПоиска.Вставить("source"		, utm_source);
				ПараметрыПоиска.Вставить("medium"		, utm_medium);
				ПараметрыПоиска.Вставить("campaign"		, utm_campaign);
				ПараметрыПоиска.Вставить("content"		, utm_content);
				ПараметрыПоиска.Вставить("term"			, utm_term);
				ПараметрыПоиска.Вставить("комментарий"	, Комментарий);
				РекламныйИсточникПоМеткамUTM = Справочники.РекламныеИсточники.ПолучитьРекламныйИсточникПоПараметрамЗаявки(ПараметрыПоиска);
				СтруктураПараметров.Вставить("РекламныйИсточник" 			, ?(РекламныйИсточникПоМеткамUTM = Неопределено, Справочники.РекламныеИсточники.ПолучитьРекламныйИсточник(Источник), РекламныйИсточникПоМеткамUTM));
				
				СтруктураПараметров.Вставить("РекламнаяПлощадка" 			, Справочники.КаналыПривлечения.ПолучитьКаналПривлечения(Канал));
				СтруктураПараметров.Вставить("РекламнаяСсылка"   			, РекламнаяСсылка);	
				СтруктураПараметров.Вставить("Комментарий"       			, Комментарий);	
				СтруктураПараметров.Вставить("communication_id"  			, ИдентификаторЗаявки);	
				СтруктураПараметров.Вставить("communication_type"			, leadtype);	
				СтруктураПараметров.Вставить("ВнешняяСистема"    			, ВнешняяСистема);	
				СтруктураПараметров.Вставить("СтруктурнаяЕдиница"			, ВнешняяСистема.СтруктурнаяЕдиница);	
				СтруктураПараметров.Вставить("source"  						, utm_source  );
				СтруктураПараметров.Вставить("medium"  						, utm_medium  );
				СтруктураПараметров.Вставить("campaign"						, utm_campaign);
				СтруктураПараметров.Вставить("content" 						, utm_content );
				СтруктураПараметров.Вставить("term"    						, utm_term    );
				СтруктураПараметров.Вставить("ga_cid"  						, ga_cid      );
				СтруктураПараметров.Вставить("ym_cid"  						, ym_cid      );
				СтруктураПараметров.Вставить("ct_cid"  						, ct_cid	  );
			
				// Создаем заявку.
				Заявка = Справочники.Заявки.СоздатьЗаявку(СтруктураПараметров);
				
			КонецЕсли;
		КонецЕсли 
		
	Исключение
		// Логирование
		Если ЛогироватьСобытие > 0 Тогда
			
			ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
			ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
			ИнформацияОбОшибке     = ИнформацияОбОшибке();
			ОписаниеОшибки         = ИнформацияОбОшибке.Причина.Описание;
			Если СтрНайти(ИнформацияОбОшибке.Причина.Описание, "Превышено время ожидания") > 0 Тогда						
				СтатусСобытия = Перечисления.СтатусыЗапросов.TimedOut;
			Иначе
				СтатусСобытия = Перечисления.СтатусыЗапросов.ОшибкаСоединения;
			КонецЕсли;
			
			РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
			HTTPЗапросЛога, 
			ДатаЛога, 
			UIDЗапроса, 
			ТипЗапроса, 
			HTTPШаблон, 
			СтатусСобытия, 
			ВремяВыполнения, 
			ВнешняяСистема, 
			api_key,  
			ОписаниеОшибки, 
			, 
			,
			400); 								
			
		КонецЕсли;
		
		Возврат Новый HTTPСервисОтвет(400);
		
	КонецПопытки;
	
	Ответ = Новый HTTPСервисОтвет(200, "Заявка успешно создана");
	
	// Логирование
	Если ЛогироватьСобытие > 0 Тогда
		
		ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
		СтатусСобытия          = Перечисления.СтатусыЗапросов.Выполнен;
		мОтвет                 = Ответ.ПолучитьТелоКакСтроку();				
		
		Если ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЛогироватьСобытие, СтатусСобытия, ВремяВыполнения) Тогда
			
			РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
			HTTPЗапросЛога, 
			ДатаЛога, 
			UIDЗапроса, 
			ТипЗапроса, 
			HTTPШаблон, 
			СтатусСобытия, 
			ВремяВыполнения, 
			ВнешняяСистема, 
			api_key, 
			мОтвет, 
			, 
			,
			200); 								
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

// Функция, возвращает заявку клиента из формы оплаты.
//
Функция ПолучитьЗаявкуКлиентаCalltouch(ct_cid, communication_id)
	
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Заявки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	НЕ Заявки.ПометкаУдаления
	|	И Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.НеОбработана)
	|	И (Заявки.ct_cid = &ct_cid
	|			ИЛИ Заявки.communication_id = &communication_id)");
	
	Запрос.УстановитьПараметр("ct_cid"	 , ct_cid);
	Запрос.УстановитьПараметр("communication_id" , communication_id);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Процедура - Распарсить строку
//
Процедура РаспарситьСтроку(ПараметрыТела, Ключ, Значение) 	
	
	Если СтрНайти(Ключ, "[") <> 0 Тогда
		
		Ключ = СтрРазделить(Ключ, "[");
		Если Прав(Ключ[1], 1) = "]" Тогда
			Ключ[1] = Лев(Ключ[1], СтрДлина(Ключ[1]) - 1);
		КонецЕсли;
		
		Попытка
			Ключ[0] = Число(Ключ[0]);
		Исключение
		КонецПопытки;  		
		
		Если ТипЗнч(Ключ[0]) <> Тип("Число") 
			И Не ПараметрыТела.Свойство(Ключ[0]) Тогда 
			
			Попытка
				
				Если Ключ.Количество() > 1 Тогда 
					
					Индекс = Число(Лев(Ключ[1], 1));					
					ПараметрыТела.Вставить(Ключ[0], Новый Массив());
					
				КонецЕсли;
				
			Исключение
				ПараметрыТела.Вставить(Ключ[0], Новый Структура());				
			КонецПопытки;
			
		КонецЕсли;
		
		Если Ключ.Количество() > 2 Тогда
			
			Пока Ключ.Количество() > 1 Цикл
				
				времКлюч = "" + времКлюч + Ключ[1] + ?(Ключ.Количество()>2, "[", "");
				
				Ключ.Удалить(1);
				
			КонецЦикла;
			
			РаспарситьСтроку(ПараметрыТела[Ключ[0]], времКлюч, Значение);
		Иначе
			
			Если ТипЗнч(Ключ[0]) = Тип("Число") 
				И ТипЗнч(ПараметрыТела) = Тип("Массив") 
				И ПараметрыТела.Количество() = Ключ[0] Тогда 
				ПараметрыТела.Добавить(Новый Структура());				
			КонецЕсли;
			РаспарситьСтроку(ПараметрыТела[Ключ[0]], Ключ[1], Значение);
			
		КонецЕсли;	
		
	Иначе 
		RawDataВСтруктуру(ПараметрыТела, Ключ, Значение);			
	КонецЕсли;
	
КонецПроцедуры   

// Процедура - Raw data в структуру
//
Процедура RawDataВСтруктуру(ПараметрыТела, Ключ, Значение)
	
	Если Лев(Ключ, 1) = "[" Тогда
		Ключ = Прав(Ключ, СтрДлина(Ключ) - 1);
	КонецЕсли; 	
	Если СтрНайти(Ключ, "-") <> 0 Тогда
		Ключ = СтрЗаменить(Ключ, "-", "_");
	КонецЕсли;
	ПараметрыТела.Вставить(Ключ, Значение);			
	
КонецПроцедуры

// Функция, преобразует строку в дату.
//
Функция ПолучитьДатуИзСтрокиCoMagic(СтроковаяДата) 
	
	Попытка
		
		СтроковаяДата = СтрЗаменить(СтроковаяДата, "-","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата, ":","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата, "T","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата, " ","");
		СтроковаяДата = СтрЗаменить(СтроковаяДата, "+","");
		
		Если СтрДлина(СтроковаяДата) < 12 Тогда 
			Возврат Неопределено;
		КонецЕсли;	
		
		СтроковаяДата = ?(СтрДлина(СтроковаяДата) = 12, СтроковаяДата + "00", СтроковаяДата);
		СтроковаяДата = ?(СтрДлина(СтроковаяДата) > 14, Лев(СтроковаяДата, 14), СтроковаяДата);
		
		Возврат Дата(СтроковаяДата);
		
	Исключение
		Возврат Неопределено;		
	КонецПопытки;
	
КонецФункции

