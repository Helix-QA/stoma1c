// Процедура - Взаимодействие SMS Отправить сервер.
//
Процедура ВзаимодействиеSMSОтправитьСервер()
		
	ОписаниеОшибки = "";
	
	МассивСтруктурПолучателей = Новый Массив;
	МассивСтруктурПолучателей.Добавить(Новый Структура("Получатель, НомерТелефона", Объект.Контрагент, ЭтотОбъект.ВзаимодействиеSMSНомерТелефона));
	
	ДокументSMSРассылкаСоздан = СоздатьДокументSMSРассылкаИОтправитьSMSНаСервере(
		МассивСтруктурПолучателей,
		ЭтотОбъект.ВзаимодействиеSMSТекст,
		Объект.Ссылка,
		ЭтотОбъект.ТекущаяСтруктурнаяЕдиница,
		ОписаниеОшибки
	);
	
	Если ДокументSMSРассылкаСоздан = Ложь Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	КонецЕсли;	
	
	ОбновитьИсториюВзаимодействияСКлиентом(Элементы.КнопкаПодробно.Пометка);
	
	ЭтотОбъект.ВзаимодействиеSMSТекст         = "";
	ЭтотОбъект.ВзаимодействиеSMSНомерТелефона = "";
	
	СнятьВидимостьВсплывающихГруппСервер("SMS");

КонецПроцедуры

