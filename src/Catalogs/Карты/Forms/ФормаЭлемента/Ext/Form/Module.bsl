// Процедура, выполняет отправку ссылки на установку карты.
//
Процедура ОтправитьСсылкуНаУстановкуКартыНаСервере(Получатель, Карта, СервисРассылки, ОписаниеОшибки)
			
	Если Не ПустаяСтрока(ОписаниеОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	Содержание = ПреобразоватьСодержаниеСПараметрамиВТекст(Карта, Ложь);
	
	ПараметрыРассылки = Новый Структура;

	ПараметрыРассылки.Вставить("Получатели", Новый_Массив(Новый Структура("Получатель, Карта", Получатель, Карта)));
	
	Если СервисРассылки = "SMS" Тогда
		ПараметрыРассылки.Вставить("ОтправкаSMS", Истина);
		
	ИначеЕсли СервисРассылки = "Мессенджер" Тогда
		ПараметрыРассылки.Вставить("ОтправкаMessenger"	 , Истина);
		ПараметрыРассылки.Вставить("ИнициироватьОтправку", Истина);
		
	КонецЕсли;
	
	ПараметрыРассылки.Вставить("ОтправитьНемедленно", Истина);
	ПараметрыРассылки.Вставить("Содержание"         , Содержание);
	ПараметрыРассылки.Вставить("СтруктурнаяЕдиница" , ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Документы.РассылкаСообщений.СоздатьДокументРассылкаСообщений(ПараметрыРассылки, ОписаниеОшибки);
	
КонецПроцедуры

