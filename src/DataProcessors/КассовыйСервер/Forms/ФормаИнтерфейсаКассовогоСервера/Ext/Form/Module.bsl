
#Область ОбработчикиСобытийФормы

// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПараметыКассовогоСервера = ПодключаемоеОборудованиеКассовыйСервер.ПараметрыКассовогоСервера();
	Если ПараметыКассовогоСервера = Неопределено
		ИЛИ НЕ ПараметыКассовогоСервера.Свойство("КассаОплаты")
		ИЛИ НЕ ЗначениеЗаполнено(ПараметыКассовогоСервера.КассаОплаты) Тогда
		
		ЭтотОбъект.РаботаРазрешена = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаЗапрещена;
		Элементы.ДекорацияСообщение.Заголовок   = НСтр("ru = 'Кассовый сервер не настроен!'; en = 'The cash server is not configured!'");
		ЭтотОбъект.СписокОплаты.Параметры.УстановитьЗначениеПараметра("ОрганизацияОтбор", Неопределено);		
		Возврат;		
	КонецЕсли;
		       
	Если ПроверитьСсылкаБитая(ПараметыКассовогоСервера.КассаОплаты) = Истина Тогда
		ЭтотОбъект.РаботаРазрешена = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаЗапрещена;
		Элементы.ДекорацияСообщение.Заголовок   = НСтр("ru = 'Касса кассового сервера не добавлена в доступные кассы сотрудника!';
													   |en = 'The cash register of the cash server is not added to the available cash registers of the employee!'");
		ЭтотОбъект.СписокОплаты.Параметры.УстановитьЗначениеПараметра("ОрганизацияОтбор", Неопределено);		
		Возврат;
	КонецЕсли;
			
	ЭтотОбъект.КассаФискализации                   = ПараметыКассовогоСервера.КассаОплаты;
	// Доработка Юля
	ЭтотОбъект.ОрганизацияПоКассе                  = ЭтотОбъект.КассаФискализации.СтруктурнаяЕдиница.Организация;
	// Конец
	ЭтотОбъект.ИнтервалыОпросаОчереди              = ПараметыКассовогоСервера.ИнтервалВремениПроверкиОчереди;
	ЭтотОбъект.ИнтервалПробитияЧеков               = ПараметыКассовогоСервера.ИнтервалПробитияЧеков;
	ЭтотОбъект.ПередаватьСмсКлиента                = ПараметыКассовогоСервера.ОтправлятьЧекПоСмс;
    ЭтотОбъект.ПередаватьПочтуКлиента              = ПараметыКассовогоСервера.ОтправлятьЧекПоЭлектроннойПочте;
	ЭтотОбъект.ПечатьНаБумаге 					   = ?(ПараметыКассовогоСервера.Свойство("ПечатьНаБумаге"), ПараметыКассовогоСервера.ПечатьНаБумаге, Ложь);

	ЭтотОбъект.КассаИспользуетсяККТ                = КассаИспользуетсяККТ(ЭтотОбъект.КассаФискализации);
	ЭтотОбъект.ИспользоватьСтарыйРежимФискализации = ИспользоватьСтаруюСистемуФормированияДляФРдляККТ(ЭтотОбъект.КассаФискализации); 
	
	ЭтотОбъект.РежимРаботыВОтдельномСеансе         = ПараметыКассовогоСервера.РежимРаботыСеанса = 1;
	
	СостояниеКассовойСмены      = ПолучитьСостояниеКассовойСмены(ЭтотОбъект.КассаФискализации);	
	// Доработка Юля
	// Если нет ни одной кассовой смены.
	ОписаниеЗапрета = "";
	Если СостояниеКассовойСмены = Неопределено Тогда
		ОписаниеЗапрета = СтрШаблон(НСтр("ru = 'По кассе ""%1"", кассовая смена не открыта.'; en = 'At the cash register ""%1"", cash register shift is not open.'"), ЭтотОбъект.КассаФискализации);
	ИначеЕсли НЕ ЭтотОбъект.ПередаватьПочтуКлиента И НЕ ЭтотОбъект.ПередаватьСмсКлиента Тогда
		ОписаниеЗапрета = НСтр("ru = 'Не заданы параметры отправки чека по СМС или Email в настройках кассового сервера'; en = 'No settings for sending a check by SMS or Email in the settings of the cash server'");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеЗапрета) Тогда
		ЭтотОбъект.РаботаРазрешена = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаЗапрещена;
		Элементы.ДекорацияСообщение.Заголовок   = ОписаниеЗапрета;
		ЭтотОбъект.СписокОплаты.Параметры.УстановитьЗначениеПараметра("ОрганизацияОтбор", ?(ЗначениеЗаполнено(ЭтотОбъект.ОрганизацияПоКассе), ЭтотОбъект.ОрганизацияПоКассе, Неопределено));
		Возврат;  		
	КонецЕсли;  	
		
	ЭтотОбъект.ДатаНачалаОтбора = СостояниеКассовойСмены.НачалоКассовойСмены;		
	ЭтотОбъект.КассоваяСмена    = СостояниеКассовойСмены.КассоваяСмена;
	ОтобразитьСостояниеКассовойСменыСервер(СостояниеКассовойСмены);  	
	Элементы.ОткрытьКассовуюСмену.Заголовок = Строка(ЭтотОбъект.КассаФискализации);	
	
	// Доработка Юля
	ЭтотОбъект.СписокОплаты.Параметры.УстановитьЗначениеПараметра("ОрганизацияОтбор", ?(ЗначениеЗаполнено(ЭтотОбъект.ОрганизацияПоКассе), ЭтотОбъект.ОрганизацияПоКассе, Неопределено)); 	
	УстановитьРазрешениеРаботы();
	
КонецПроцедуры

// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЭтотОбъект.РаботаРазрешена = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	СтартФискализациии(Неопределено);
	
КонецПроцедуры

// Процедура - Перед закрытием
//
// Параметры:
//  Отказ				 - 	 - 
//  ЗавершениеРаботы	 - 	 - 
//  ТекстПредупреждения	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	//Если ЭтотОбъект.РежимРаботыВОтдельномСеансе = Истина Тогда
	//	Отказ = Истина;
	//	Возврат;
	//КонецЕсли;
	
	Если ЭтотОбъект.КассовыйСерверЗапущен = Истина Тогда
		
		ЭтотОбъект.КассовыйСерверЗапущен = Ложь;
		ЭтотОбъект.ИдетПечатьЧека        = Ложь;
		
		ОтключитьОбработчикОжидания("ОбработчикТаймераПоступленияДокументовНаФискализацию");
		ОтключитьОбработчикОжидания("ПробитьЧекОбработчикТаймера");
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Установить разрешение работы
//
&НаСервере
Процедура УстановитьРазрешениеРаботы()
	
	ЭтотОбъект.РаботаРазрешена = Истина;
    Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаРазрешена;

	УстановитьПривилегированныйРежим(Истина);
	
	Если КассовыйСервер.ВТекущемСеансеРазрешенЗапускКассовогоСервера() = Ложь Тогда
		
		ЭтотОбъект.РаботаРазрешена = Ложь;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаЗапрещена;
		Элементы.ДекорацияСообщение.Заголовок   = НСтр("ru = 'На текущем рабочем месте запрещен запуск кассового сервера!'; en = 'Starting the cash server is prohibited at the current workplace!'");
		
		УстановитьПривилегированныйРежим(Ложь);
		Возврат;
		
	КонецЕсли;
	
	Если ЭтотОбъект.РежимРаботыВОтдельномСеансе = Истина Тогда
		
		ПараметыКассовогоСервера = ПодключаемоеОборудованиеКассовыйСервер.ПараметрыКассовогоСервера();
	
		Если ПараметыКассовогоСервера.Пользователь = ПараметрыСеанса.ТекущийПользователь Тогда
			
			ЭтотОбъект.РаботаРазрешена = Истина;
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаРазрешена;
			
		Иначе
			
			ЭтотОбъект.РаботаРазрешена = Ложь;
			Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаРаботаЗапрещена;
			Элементы.ДекорацияСообщение.Заголовок   = НСтр("ru = 'Пользователь текущего сеанса не явялется пользователем кассового сервера!'; en = 'The user of the current session is not a cash server user!'");
			
			УстановитьПривилегированныйРежим(Ложь);

			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
			
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

// Процедура - Проверить кассовую смену
//
&НаКлиенте
Процедура ПроверитьКассовуюСмену()
	
	УстановитьКартинкуСтатуса(3, Истина);
	РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, ЭтотОбъект.КассаФискализации, Неопределено, Неопределено, Ложь);
		
КонецПроцедуры

&НаКлиенте
// Процедура - После контроля использования кассовой смены
//
// Параметры:
//  ИспользованиеКассовойСменыРазрешено	 - 	 - 
//  ПараметрыИспользованияКассовойСмены	 - 	 - 
//  ОписаниеОшибки						 - 	 - 
//
Процедура ПослеКонтроляИспользованияКассовойСмены(ИспользованиеКассовойСменыРазрешено, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки) Экспорт 
	
	Если ИспользованиеКассовойСменыРазрешено = Ложь Тогда
		
		Элементы.СтартФискализациии.Доступность = Истина;
		Элементы.СтопФискализации.Доступность   = Ложь;
		Элементы.ОткрытьКассовуюСмену.Доступность = Истина;
		
		ЭтотОбъект.КассовыйСерверЗапущен = Ложь;
		
		УстановитьКартинкуСтатуса(4, Истина);

		СостояниеКассовойСмены      = ПолучитьСостояниеКассовойСмены(ЭтотОбъект.КассаФискализации);		
	    ЭтотОбъект.КассоваяСмена    = СостояниеКассовойСмены.КассоваяСмена;

	    ОтобразитьСостояниеКассовойСмены(СостояниеКассовойСмены);
		
		ПоказатьПредупреждение(, ОписаниеОшибки);
		Возврат;
		
	Иначе 
		
		Если ЭтотОбъект.КассовыйСерверЗапущен = Истина Тогда
			СтартФискализациииЗавершение();
		КонецЕсли;
		
	КонецЕсли;
	  
	СостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(ЭтотОбъект.КассаФискализации);	
	Если СостояниеКассовойСмены = Неопределено Тогда
		ОписаниеЗапрета = СтрШаблон(НСтр("ru = 'По кассе ""%1"", кассовая смена не открыта.'; en = 'At the cash register ""%1"", cash register shift is not open.'"),
							ЭтотОбъект.КассаФискализации);
		
		Элементы.СтартФискализациии.Доступность		= Истина;
		Элементы.СтопФискализации.Доступность		= Ложь;
		Элементы.ОткрытьКассовуюСмену.Доступность	= Истина;
		
		ЭтотОбъект.КассовыйСерверЗапущен			= Ложь;
		
		УстановитьКартинкуСтатуса(4, Истина);

	    ОтобразитьСостояниеКассовойСмены(Неопределено);
		
		ПоказатьПредупреждение(, ОписаниеОшибки);
		Возврат;
	КонецЕсли;	
	
	ЭтотОбъект.ДатаНачалаОтбора = СостояниеКассовойСмены.НачалоКассовойСмены;
	ЭтотОбъект.ДатаКассовйСмены = СостояниеКассовойСмены.НачалоКассовойСмены;
	ЭтотОбъект.КассоваяСмена    = СостояниеКассовойСмены.КассоваяСмена;
	
	// Доработка Юля
	ЭтотОбъект.СписокОплаты.Параметры.УстановитьЗначениеПараметра("ОрганизацияОтбор", ?(ЗначениеЗаполнено(ЭтотОбъект.ОрганизацияПоКассе), ЭтотОбъект.ОрганизацияПоКассе, Неопределено)); 

КонецПроцедуры

#КонецОбласти

#Область УправлениеКассовымСервером

// Процедура - Открыть кассовую смену
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ОткрытьКассовуюСмену(Команда)
	
	ОткрытьФорму("Документ.КассоваяСмена.Форма.ФормаУправленияКассовойСменой");	
	
КонецПроцедуры

// Процедура - Старт фискализациии
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура СтартФискализациии(Команда)
	
	ЗаписатьВЖурналРегистрацииСообщение(НСтр("ru = 'Запускается.'; en = 'Starting.'"));
	
	ЭтаФорма.Заголовок = НСтр("ru = 'Кассовый сервер - запускается'; en = 'Cash server - starting'");
	
	ЭтотОбъект.КассовыйСерверЗапущен = Истина;
	ПодключитьОбработчикОжидания("ПроверитьКассовуюСмену", 1, Истина);
	
	Элементы.СтартФискализациии.Доступность   = Ложь;
	Элементы.СтопФискализации.Доступность     = Истина;
	Элементы.КассаФискализации.Доступность    = Ложь;
	Элементы.ОткрытьКассовуюСмену.Доступность = Ложь;

КонецПроцедуры

// Процедура - Старт фискализациии завершение
//
&НаКлиенте
Процедура СтартФискализациииЗавершение()
	
	ЭтотОбъект.КассовыйСерверЗапущен = Истина;
	ПодключитьОбработчикОжидания("ОбработчикТаймераПоступленияДокументовНаФискализацию", 1, Истина);

	ЗаписатьВЖурналРегистрацииСообщение(НСтр("ru = 'Запущен.'; en = 'Running.'"));
    ЭтаФорма.Заголовок = НСтр("ru = 'Кассовый сервер - запущен'; en = 'Cash server - running'");
	
	УстановитьКартинкуСтатуса(0, Истина);

	Элементы.СтартФискализациии.Доступность  = Ложь;
	Элементы.СтопФискализации.Доступность    = Истина;
	Элементы.КассаФискализации.Доступность   = Ложь;
    Элементы.ОткрытьКассовуюСмену.Доступность = Ложь;

КонецПроцедуры

// Процедура - Стоп фискализации
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура СтопФискализации(Команда)
	
	ЭтотОбъект.КассовыйСерверЗапущен = Ложь;
	ЭтотОбъект.ИдетПечатьЧека        = Ложь;
	
	ОтключитьОбработчикОжидания("ОбработчикТаймераПоступленияДокументовНаФискализацию");
	ОтключитьОбработчикОжидания("ПробитьЧекОбработчикТаймера");

	ЭтаФорма.Заголовок = НСтр("ru = 'Кассовый сервер - остановлен'; en = 'Cash server - stopped'");
	ЗаписатьВЖурналРегистрацииСообщение(НСтр("ru = 'Остановлен.'; en = 'Stopped.'"));
	
	УстановитьКартинкуСтатуса(0, Ложь);

	Элементы.СтартФискализациии.Доступность   = Истина;
	Элементы.СтопФискализации.Доступность     = Ложь;
	Элементы.КассаФискализации.Доступность    = Истина;
    Элементы.ОткрытьКассовуюСмену.Доступность = Истина;

КонецПроцедуры

#Область ОчередьДокументов

// Процедура - Обработчик таймера поступления документов на фискализацию
//
&НаКлиенте
Процедура ОбработчикТаймераПоступленияДокументовНаФискализацию()
	
	Если ЭтотОбъект.КассовыйСерверЗапущен = Ложь Тогда
		Возврат
	КонецЕсли;
	
	ЭтотОбъект.ВремяНачалаОбработкиОчереди = ТекущаяДата();
	
	// Доработка Юля (параметр Организация)
	ДокументыНафискализацию = КассовыйСервер.ПолучитьВсеНеОплаченныеДокументИзОчередиДляТекущегоСеанса(, ОрганизацияПоКассе, КассаФискализации);
	// Конец
	ЭтотОбъект.ОчередьФискализации.ЗагрузитьЗначения(ДокументыНафискализацию);
			
	Если ЭтотОбъект.ОчередьФискализации.Количество() > 0 Тогда		
		
		КассовыйСервер.ЗаписатьПризнакНачалаПробитияЧекаДляМассиваДокументов(ДокументыНафискализацию);
		
		ЗаписатьВЖурналРегистрацииСообщение(НСтр("ru = 'Поступило на фискализацию: '; en = 'Received by fiscalization: '") + ЭтотОбъект.ОчередьФискализации.Количество());
		
		WSHShell = Новый COMОбъект("WScript.Shell");
		WSHShell.SendKeys("{End}"); 
		
		ПодключитьОбработчикОжидания("ПробитьЧекОбработчикТаймера", 0.3, Истина);
		
	Иначе
		
		ПодключитьОбработчикОжидания("ОбработчикТаймераПоступленияДокументовНаФискализацию", ЭтотОбъект.ИнтервалыОпросаОчереди, Истина);
		
	КонецЕсли;
	
	Элементы.СписокОплаты.Обновить();
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
// Процедура, обработчик события "Выбор".
//
Процедура СписокОплатыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.СписокОплаты.ТекущиеДанные;
	
	Если Не ТекущиеДанные = Неопределено И ЗначениеЗаполнено(ТекущиеДанные.ДокументОплаты) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ПараметрыОткрытия = Новый Структура; 
		ПараметрыОткрытия.Вставить("Документ", ТекущиеДанные.ДокументОплаты);		
		ПараметрыОткрытия.Вставить("Статус"  , ТекущиеДанные.Статус);
		ОписаниеОповещения = Новый ОписаниеОповещения("СписокОплатыВыборЗавершение", ЭтотОбъект);
		ОткрытьФорму("Обработка.КассовыйСервер.Форма.ФормаДиалога", ПараметрыОткрытия,,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обработчик завершения выбора.
//
Процедура СписокОплатыВыборЗавершение(Результат, Параметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.ОбновитьСписок Тогда
		
		Элементы.СписокОплаты.Обновить();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВыполнениеФискализации

// Процедура - Пробить чек обработчик таймера
//
&НаКлиенте
Процедура ПробитьЧекОбработчикТаймера()
	
	Если ЭтотОбъект.ОчередьФискализации.Количество() = 0 
		ИЛИ ЭтотОбъект.ИдетПечатьЧека = Истина
		ИЛИ ЭтотОбъект.КассовыйСерверЗапущен = Ложь Тогда
		
		Возврат;
	КонецЕсли;
	
	//Если форма не в фокусе ввода, то ожидаем возврат на форму 
	//Если ЭтотОбъект.РежимРаботыВОтдельномСеансе = Ложь
	//	И ВводДоступен() = Ложь  Тогда
	//	
	//	ПодключитьОбработчикОжидания("ПробитьЧекОбработчикТаймера", 3, Истина);
	//	Возврат;
	//	
	//КонецЕсли;
	
	//Проверять статус кассовой смены каждые 180 сек
	//если смена закрыта, то ожидать открытия нвоой смены 
	Если (ТекущаяДата() - ЭтотОбъект.ПоследняяДатаУспешнойПроверкиКассовойСмены) >= 180 Тогда
		
		СостояниеКассовойСмены   = ПолучитьСостояниеКассовойСмены(ЭтотОбъект.КассаФискализации);	
		ЭтотОбъект.КассоваяСмена = СостояниеКассовойСмены.КассоваяСмена;

		ОтобразитьСостояниеКассовойСмены(СостояниеКассовойСмены);
		
		Если НЕ СостояниеКассовойСмены.СтатусыКассовойСмены = ПредопределенноеЗначение("Перечисление.СтатусыКассовойСмены.Открыта") Тогда
			
			ПодключитьОбработчикОжидания("ПробитьЧекОбработчикТаймера", 60, Истина);
			Возврат;
			
		КонецЕсли;	
					
		ЭтотОбъект.ПоследняяДатаУспешнойПроверкиКассовойСмены = ТекущаяДата();
	КонецЕсли;
	
	ЭтотОбъект.ИдетПечатьЧека = Истина;
	
    УстановитьКартинкуСтатуса(1, Истина);
	
	ДокументОплаты = ЭтотОбъект.ОчередьФискализации[0].Значение;
		
	ОписаниеЗапрета = Неопределено;
	
	Если ФискализацияДокументаРазрешена(ДокументОплаты, ОписаниеЗапрета) = Ложь Тогда		
		ЗавершитьПробитиеЧека(ДокументОплаты, ОписаниеЗапрета);		
		Возврат;
	КонецЕсли;
	
	// Доработка Юля
	// Бесплатную реалзиацию пробивать не нужно по ФР
	Если ДокументРеализацияБесплатно(ДокументОплаты) = Истина Тогда
		ЗаписатьПризнакПробитияЧекаРеализацияБесплатно(ДокументОплаты);
		// Удалим из очереди бесплатный документ
		ЗавершитьПробитиеЧека(ДокументОплаты, ОписаниеЗапрета);
		Возврат;
	КонецЕсли;          	
	
	Если ЭтотОбъект.ИспользоватьСтарыйРежимФискализации = Ложь Тогда
		ФормированиеЧека = ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляККТ(ДокументОплаты);
	Иначе
		ФормированиеЧека = ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляФР(ДокументОплаты);
	КонецЕсли;
		
	Если ФормированиеЧека.Результат Тогда
		
		ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ЭтотОбъект.КассаФискализации);
		
		Если ФормированиеЧека.Свойство("ФискальныйЧек") Тогда
			
			ПробитиеРазрешено = Ложь;			
			
			Если ЭтотОбъект.ПередаватьСмсКлиента И ЗначениеЗаполнено(ФормированиеЧека.ФискальныйЧек.ПокупательНомер) Тогда
				ПробитиеРазрешено = Истина;
			ИначеЕсли  ЭтотОбъект.ПередаватьПочтуКлиента И ЗначениеЗаполнено(ФормированиеЧека.ФискальныйЧек.ПокупательEmail) Тогда
				ПробитиеРазрешено = Истина;
			КонецЕсли;
			
			Если Не ПробитиеРазрешено Тогда
				ОписаниеЗапрета = "У клиента не заполнена контактная информация";
				ЗавершитьПробитиеЧека(ДокументОплаты, ОписаниеЗапрета);
				Элементы.СписокОплаты.Обновить();
				Возврат;				
			КонецЕсли; 			
			
			Контекст = Новый Структура();
			Контекст.Вставить("ТипЧека"       , Истина);
			Контекст.Вставить("ДокументОплаты", ДокументОплаты);

			Оповещение            = Новый ОписаниеОповещения("ПробитьЧекЗавершение"            , ЭтотОбъект, Контекст);
			ПослеОткрытияЧека     = Новый ОписаниеОповещения("ПечатьЧека_ПослеОткрытияЧека"    , ЭтотОбъект, Контекст);
			ПослеОшибкиПечатиЧека = Новый ОписаниеОповещения("ПечатьЧека_ПослеОшибкиПечатиЧека", ЭтотОбъект, Контекст);
			
			ОбщиеПараметры = ФормированиеЧека.ФискальныйЧек;
			МенеджерОборудованияКлиент.НачатьФискализациюЧекаНаФискальномУстройстве(Оповещение, УникальныйИдентификатор, ОбщиеПараметры, ИдентификаторУстройстваФР, , ПослеОткрытияЧека, ПослеОшибкиПечатиЧека);		
			
		КонецЕсли;			
		
		Если ФормированиеЧека.Свойство("НефискальныйЧек") Тогда
			
			ТекстЧека  = ФормированиеЧека.НефискальныйЧек;
			Контекст   = Новый Структура();
			Контекст.Вставить("ТипЧека"       , Ложь);
			Контекст.Вставить("ДокументОплаты", ДокументОплаты);
			
			Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект, Контекст);
			МенеджерОборудованияКлиент.НачатьПечатьТекста(Оповещение, УникальныйИдентификатор, ТекстЧека, ИдентификаторУстройстваФР);
			
		КонецЕсли;		
		
	Иначе
		
		ОписаниеОшибки = ФормированиеЧека.ОписаниеОшибки;
		ТекстСообщения = НСтр("ru='При проведение оплаты произошла ошибка.										"
"Дополнительное описание: %ДополнительноеОписание%';en='With holding payment happened mistake. Additional description: %ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);					
		
		ЗавершитьПробитиеЧека(ДокументОплаты, ТекстСообщения);

	КонецЕсли;

КонецПроцедуры

#Область ОбработчикиСобытийФискальника

&НаКлиенте
// Процедура, обработчик описания оповещения.
//
Процедура ПечатьЧека_ПослеОткрытияЧека(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
	
	ШапкаЧека = ПараметрыВыполнения.ВходныеПараметры;
	
	Если ПараметрыВыполнения.НомерСмены <> 0 Тогда
		ШапкаЧека.НомерСмены = ПараметрыВыполнения.НомерСмены;
	КонецЕсли;
	
	Если ПараметрыВыполнения.НомерЧека <> 0 Тогда
		ШапкаЧека.НомерЧека = ПараметрыВыполнения.НомерЧека;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ПараметрыВыполнения.ОповещениеПродолжения, ПараметрыВыполнения);
		
КонецПроцедуры

&НаКлиенте
// Процедура, завершение пробития чека на ФР.
//
Процедура ПробитьЧекЗавершение(РезультатВыполнения, ДополнительныеПараметры) Экспорт
	
	ОписаниеОшибки = Неопределено;
	
	Если РезультатВыполнения.Результат Тогда		
	
		Если РезультатВыполнения.ВыходныеПараметры <> Неопределено Тогда
			
			НомерЧекаККМ = 0;
			Если ДополнительныеПараметры.ТипЧека Тогда
				НомерЧекаККМ = РезультатВыполнения.ВыходныеПараметры[1];
			Иначе
				НомерЧекаККМ = РезультатВыполнения.ВыходныеПараметры[1];
			КонецЕсли;	
			
			Попытка 
				ИдентификаторФискальнойЗаписи = "";
				Если РезультатВыполнения.ВыходныеПараметры.Количество() > 8 Тогда
					ПараметрыФискализации = РезультатВыполнения.ВыходныеПараметры[8];
					ИдентификаторФискальнойЗаписи = ПараметрыФискализации.ИдентификаторФискальнойЗаписи;
				КонецЕсли;
				ЗаписатьРезультатПробитияЧека(ДополнительныеПараметры.ДокументОплаты, НомерЧекаККМ, ЭтотОбъект.КассоваяСмена, ИдентификаторФискальнойЗаписи);
				
			Исключение
				
				СтопФискализации(Неопределено);
				ПоказатьПредупреждение(,НСтр("ru='Кассовый сервер остановлен по причине невозможности записать результат пробития чека. Описание: ';en='Cash server stopped due to impossibility writedown result penetration check. Description:'") + ОписаниеОшибки());
				
			КонецПопытки;
			
		КонецЕсли;
		
	Иначе 		
		
		ТекстСообщения = НСтр("ru='При печати чека произошла ошибка."
"Чек не напечатан на фискальном регистраторе."
"Дополнительное описание:"
"%ДополнительноеОписание%';en='With print check happened mistake."
"Check not printedby on fiscal registrar."
"Additional description:"
"AdditionalDescription'");
		ОписаниеОшибки = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", РезультатВыполнения.ОписаниеОшибки);
		                         				
	КонецЕсли;
	
	ЗавершитьПробитиеЧека(ДополнительныеПараметры.ДокументОплаты, ОписаниеОшибки);

	Элементы.СписокОплаты.Обновить();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик оповещения.
//
Процедура ПечатьЧека_ПослеОшибкиПечатиЧека(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт

	ШапкаЧека = ПараметрыВыполнения.ВходныеПараметры;
	ШапкаЧека.НомерЧека = ШапкаЧека.НомерЧека + 1000000;

КонецПроцедуры

#КонецОбласти

// Процедура - Завершить пробитие чека
//
// Параметры:
//  ДокументОплаты	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
//
&НаКлиенте
Процедура ЗавершитьПробитиеЧека(ДокументОплаты, ОписаниеОшибки)
	
	ЗавершенСОшибкой = ЗначениеЗаполнено(ОписаниеОшибки); 
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ЗаписатьОшибкуПечатиЧека(ДокументОплаты, ОписаниеОшибки);			
		ЗаписатьВЖурналРегистрацииОшибку(ОписаниеОшибки);	
		
		УстановитьКартинкуСтатуса(2, Истина);

	КонецЕсли;
	
	УдалитьДокументИзОчередиПечати(ДокументОплаты);
	
	ИдетПечатьЧека = Ложь;
		
	Если ЭтотОбъект.КассовыйСерверЗапущен = Истина Тогда
		
		Если ЭтотОбъект.ОчередьФискализации.Количество() > 0 Тогда
			
			Тайминг = ?(ЭтотОбъект.РежимРаботыВОтдельномСеансе, ЭтотОбъект.ИнтервалПробитияЧеков, 0.3);
			
			Если ЗавершенСОшибкой = Истина Тогда
				Тайминг = 7;
			КонецЕсли;	
					
			ПодключитьОбработчикОжидания("ПробитьЧекОбработчикТаймера", Тайминг, Истина);
			
		Иначе
			
			ЭтотОбъект.ВремяКонцаОбработкиОчереди = ТекущаяДата();
			ЗатраченоВремени                      = ЭтотОбъект.ВремяКонцаОбработкиОчереди - ЭтотОбъект.ВремяНачалаОбработкиОчереди;
			РасчетныйИнтервалЗадержки             = ЭтотОбъект.ИнтервалыОпросаОчереди - ЗатраченоВремени;
			РасчетныйИнтервалЗадержки             = ?(РасчетныйИнтервалЗадержки <= 0, 0.3, РасчетныйИнтервалЗадержки);
			
			УстановитьКартинкуСтатуса(0, Истина);

			ПодключитьОбработчикОжидания("ОбработчикТаймераПоступленияДокументовНаФискализацию", РасчетныйИнтервалЗадержки, Истина);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Удалить документ из очереди печати
//
// Параметры:
//  ДокументСсылка	 - 	 - 
//
&НаКлиенте
Процедура УдалитьДокументИзОчередиПечати(ДокументОплаты)
	
	ЭлементСписка = ОчередьФискализации.НайтиПоЗначению(ДокументОплаты);
	Если ЭлементСписка<> Неопределено Тогда
		ОчередьФискализации.Удалить(ЭлементСписка);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Записать результат пробития чека
//
// Параметры:
//  ДокументОплаты	 - 	 - 
//  НомерЧекаККМ	 - 	 - 
//
&НаСервереБезКонтекста
Процедура ЗаписатьРезультатПробитияЧека(ДокументОплаты, НомерЧекаККМ, ТекущаяКассоваяСмена, ИдентификаторФискальнойЗаписи)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СчетчикПопыток = 0;
	
	Пока СчетчикПопыток < 5 Цикл
		
		НачатьТранзакцию();
		
		Попытка 
						
			ДокументОбъект              = ДокументОплаты.ПолучитьОбъект();
			ДокументОбъект.НомерЧекаККМ = НомерЧекаККМ;
			
			//На случай если док. был создан в прошлой кассовой смене и она уже закрылась
			//подменяем его на ту смену в которой он был пробит
			Если ДокументОбъект.КассоваяСмена <> ТекущаяКассоваяСмена Тогда
				ДокументОбъект.КассоваяСмена = ТекущаяКассоваяСмена;
			КонецЕсли;
			
			Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Реализация") Тогда      				
				МассивНеоплаченныхСтрок = ДокументОбъект.УчтенныеАвансы.НайтиСтроки(Новый Структура("НомерЧекаККМ, ТипАвансовыхСредств", 0, Перечисления.ТипыДенежныхСредств.ЛицевойСчет));
				Для Каждого ЭлементМ Из МассивНеоплаченныхСтрок Цикл
					ЭлементМ.ИдентификаторФискальнойЗаписи	= ИдентификаторФискальнойЗаписи; 
					ЭлементМ.НомерЧекаККМ					= НомерЧекаККМ;  				 
				КонецЦикла;				
			КонецЕсли;
						
			ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);			
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);			
			
			ЗафиксироватьТранзакцию();
			
			Прервать;
			
		Исключение	
			
			ОтменитьТранзакцию();
			
			ОписаниеОшибки = ОписаниеОшибки();
			
			СчетчикПопыток = СчетчикПопыток + 1;
			
			Если СчетчикПопыток = 5 Тогда
				ВызватьИсключение ОписаниеОшибки;
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;

	РегистрыСведений.ОчередьКассовогоСервера.ЗаписатьПризнакУспешногоПробитияЧека(ДокументОплаты, НомерЧекаККМ);
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

// Процедура, записывает бесплатную реализацию как "Пробито" в регистр сведений "ОчередьКассовогоСервера" 
// 
&НаСервереБезКонтекста
Процедура ЗаписатьПризнакПробитияЧекаРеализацияБесплатно(ДокументОплаты)
	
	УстановитьПривилегированныйРежим(Истина);
	РегистрыСведений.ОчередьКассовогоСервера.ЗаписатьПризнакУспешногоПробитияЧека(ДокументОплаты, 1);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Функция - Фискализация документа разрешена
//
// Параметры:
//  Документ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
&НаСервереБезКонтекста
Функция ФискализацияДокументаРазрешена(Документ, ОписаниеЗапрета = Неопределено)
	
	Если Документ.Проведен = Ложь ИЛИ Документ.ПометкаУдаления Тогда  		
		ОписаниеЗапрета = "Документ не проведен";
		Возврат Ложь; 		
	КонецЕсли;
	
	Если (ТипЗнч(Документ) <> Тип("ДокументСсылка.Реализация")
		И ЗначениеЗаполнено(Документ.НомерЧекаККМ))
		ИЛИ (ТипЗнч(Документ) = Тип("ДокументСсылка.Реализация")
		И Документ.УчтенныеАвансы.НайтиСтроки(Новый Структура("НомерЧекаККМ, ТипАвансовыхСредств", 0, Перечисления.ТипыДенежныхСредств.ЛицевойСчет)).Количество() = 0) Тогда  
		
		ОписаниеЗапрета = "Документ уже пробит на ФР.";
		Возврат Ложь; 
	КонецЕсли; 
		
	Возврат Истина;
	
КонецФункции

// Функция, возвращает признак того, что вся реализация
// сделана как "Бесплатно"
//
&НаСервереБезКонтекста
Функция ДокументРеализацияБесплатно(Документ)
	
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.Реализация") 
		и Документ.Запасы.Итог("Сумма") = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;	
	
КонецФункции

