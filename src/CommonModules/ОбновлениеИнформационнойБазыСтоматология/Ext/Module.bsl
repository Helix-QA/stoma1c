	, "Рекомендация после имплантации"	
	, "Рекомендация после имплантации"
	, Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия
	, "Услуги имплантации (A16.07.054)"));
	
	МассивРекомендаций.Добавить(Новый Структура("НаименованиеТриггера, ЗаголовокРекомендации, УсловиеСобытия, МоментСобытия, НаименованиеСегмента"
	, "Рекомендации по уходу за брекет системой"	
	, "Рекомендации по уходу за брекет системой"
	, Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия
	, "Услуги установки брекет системы (А16.07.048)"));

	МассивРекомендаций.Добавить(Новый Структура("НаименованиеТриггера, ЗаголовокРекомендации, УсловиеСобытия, МоментСобытия, НаименованиеСегмента"
	, "Рекомендации по уходу за элайнерами"	
	, "Рекомендации по уходу за элайнерами"
	, Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия
	, "Услуги установки элайнеров (А16.07.028, А16.07.048)"));	
	
	// Инициализируем таблицу внешних систем
	Если НЕ ЗначениеЗаполнено(ТаблицаСервисовSMS) Тогда 
		ТаблицаСервисовSMS = Справочники.СтруктурныеЕдиницы.ПолучитьТаблицуСервисовРассылокДляСтруктурныхЕдиниц();	
	КонецЕсли;	
	АктивностьТриггера = ЗначениеЗаполнено(ТаблицаСервисовSMS);

	Для Каждого ЭлементКоллекции Из МассивРекомендаций Цикл 
		
		// Инициализируем сегмент услуг
		СегментУслуг 	= Справочники.СегментыНоменклатуры.ИнициализироватьСегментНоменклатуры(ЭлементКоллекции.НаименованиеСегмента, "Сегменты медицинских услуг (Рекомендации)");
		// Инициализируем шаблон рекомендаций
		ШаблонСообщения = Справочники.ШаблоныСообщений.ИнициализироватьШаблонСообщения(ЭлементКоллекции.ЗаголовокРекомендации, "Рекомендации");
		
		Если НЕ ЗначениеЗаполнено(СегментУслуг) ИЛИ НЕ ЗначениеЗаполнено(ШаблонСообщения) Тогда 
			Продолжить;
		КонецЕсли;
		
		ПараметрыТриггерногоСобытия = Новый Структура;
		ПараметрыТриггерногоСобытия.Вставить("Наименование" 	, ЭлементКоллекции.НаименованиеТриггера);
		ПараметрыТриггерногоСобытия.Вставить("Активно"			, АктивностьТриггера);
		ПараметрыТриггерногоСобытия.Вставить("УсловиеСобытия"	, ЭлементКоллекции.УсловиеСобытия);
		ПараметрыТриггерногоСобытия.Вставить("МоментСобытия"	, ЭлементКоллекции.МоментСобытия);
		ПараметрыТриггерногоСобытия.Вставить("ПериодСобытия"	, 1);
		ПараметрыТриггерногоСобытия.Вставить("ПериодСобытияВид"	, Перечисления.Периодичность.День);
		ПараметрыТриггерногоСобытия.Вставить("ВремяСобытия"		, Дата('0001.01.01 10:00:00'));
		ПараметрыТриггерногоСобытия.Вставить("СегментУслуг"		, СегментУслуг);
		ПараметрыТриггерногоСобытия.Вставить("ПараметрыДействия"
		, Новый Структура("Использование, ВидДействия, ВидАдресата, ШаблонСообщения, Описание"
		, Истина, Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение, Перечисления.ВидыАдресатов.КонтрагентСобытия, ШаблонСообщения, НСтр("ru = 'Отправить пациенту сообщение';en= 'Send a message to the patient'")));
		
		ТриггерноеСобытие = Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие(ПараметрыТриггерногоСобытия, Истина, ТаблицаСервисовSMS, Истина);
		
	КонецЦикла;
	
	
КонецПроцедуры

// Процедура - Заполнить курсы лечения в приемах
//
Процедура ЗаполнитьКурсыЛеченияВПриемах(Параметры = Неопределено) Экспорт

	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидСделкиНовыйПациент"		, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты"));
	Запрос.УстановитьПараметр("ВидСделкиПостоянныйПациент"	, ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПостоянныеПациенты"));	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Прием.Ссылка КАК Ссылка,
		|	Прием.Дата КАК Дата,
		|	Прием.Сотрудник КАК Сотрудник,
		|	Прием.Контрагент КАК Контрагент,
		|	Прием.РезультатПриема КАК РезультатПриема,
		|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
		|	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема,
		|	Прием.СтатусПациента КАК СтатусПациента,
		|	Прием.СуммаДокумента КАК СуммаДокумента,
		|	Прием.Представление КАК Представление
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Сделка <> ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
		|	И (Прием.Сделка.ВидСделки = &ВидСделкиНовыйПациент
		|			ИЛИ Прием.Сделка.ВидСделки = &ВидСделкиПостоянныйПациент)
		|	И Прием.Проведен
		|	И Прием.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата,
		|	ВремяНачалаПриема,
		|	Сотрудник";

	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Колонки.Добавить("ЗакрытьКурс", Новый ОписаниеТипов("Булево"));  
		
	Копия = Новый ТаблицаЗначений;
	Копия = Таблица.Скопировать();
	Копия.Свернуть("Контрагент");
	Для Каждого СтрокаТЧ Из Копия Цикл
			
		СоздатьНовыйКурсИЗакрытьПредыдущий = Истина;
		Контрагент = СтрокаТЧ.Контрагент;
		НайденныеСтроки = Таблица.НайтиСтроки(Новый Структура("Контрагент", Контрагент));
		НомерСтроки = 1;
		Для Каждого Строка Из НайденныеСтроки Цикл
				
			Если Строка.РезультатПриема = 1 Тогда 
				Если НайденныеСтроки.Количество() = 1 Или НомерСтроки = НайденныеСтроки.Количество() Тогда 
					Строка.ЗакрытьКурс = Истина;  
				ИначеЕсли НомерСтроки < НайденныеСтроки.Количество() 
					И ДобавитьМесяц(Строка.Дата, 1) <= НайденныеСтроки[НомерСтроки].Дата Тогда
					Строка.ЗакрытьКурс = Истина; 
				КонецЕсли;
			КонецЕсли;
			
			НомерСтроки = НомерСтроки + 1;
			
		КонецЦикла;
		
		НомерСтроки = 1;
		Для Каждого Строка Из НайденныеСтроки Цикл
			
			Попытка
				
				// 1. Создание курса лечения
				Если СоздатьНовыйКурсИЗакрытьПредыдущий = Истина Тогда
					КурсЛеченияОбъект                = Справочники.КурсыЛечения.СоздатьЭлемент();
					КурсЛеченияОбъект.Контрагент     = Контрагент; 
					КурсЛеченияОбъект.ДатаНачала     = Строка.ВремяНачалаПриема;
					КурсЛеченияОбъект.СтатусПациента = Строка.СтатусПациента; 
					СуммаКурса                       = 0;
					Попытка
						КурсЛеченияОбъект.Записать(); 
					Исключение  
						ОписаниеОшибки = "Ошибка при записи курса лечения по приему " + Строка.Представление + " " + ОписаниеОшибки();
						ЗаписьЖурналаРегистрации("ЗаполнитьКурсыЛеченияВПриемах", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
					КонецПопытки;
					
					ТаблицаЛечений = Новый ТаблицаЗначений;
					ТаблицаЛечений.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
					ТаблицаЛечений.Колонки.Добавить("Лечение"  , Новый ОписаниеТипов("СправочникСсылка.Лечения"));
					ТаблицаЛечений.Колонки.Добавить("Закрыт"   , Новый ОписаниеТипов("Булево"));  
					
				КонецЕсли; 
				
				// 2. Создать лечение по врачу
				Если ЗначениеЗаполнено(Строка.Сотрудник) Тогда 
					НайденныеСтрокиСотрудник = ТаблицаЛечений.НайтиСтроки(Новый Структура("Сотрудник", Строка.Сотрудник)); 
					Если НайденныеСтрокиСотрудник.Количество() = 0 Тогда
						
						ЛечениеВрачаОбъект               = Справочники.Лечения.СоздатьЭлемент();
						ЛечениеВрачаОбъект.ДатаНачала    = Строка.ВремяНачалаПриема; 
						ЛечениеВрачаОбъект.Контрагент    = Контрагент;
						ЛечениеВрачаОбъект.Сотрудник     = Строка.Сотрудник;
						ЛечениеВрачаОбъект.СуммаЛечения  = Строка.СуммаДокумента;     
						ЛечениеВрачаОбъект.КурсЛечения   = КурсЛеченияОбъект.Ссылка; 
						
						// Лечение закрывать, когда следующий прием больше 30 дней или следующий рием по этому сотруднику больше 30 дней?
						// Пока сделать  когда следующий прием больше 30 дней
						Если Строка.РезультатПриема = 1 Тогда 
							Если НайденныеСтроки.Количество() = 1 Или НомерСтроки = НайденныеСтроки.Количество() Тогда 
								ЛечениеВрачаОбъект.ДатаОкончания = Строка.Дата;  
							ИначеЕсли НомерСтроки < НайденныеСтроки.Количество() 
								И ДобавитьМесяц(Строка.Дата, 1) <= НайденныеСтроки[НомерСтроки].Дата Тогда
								ЛечениеВрачаОбъект.ДатаОкончания = Строка.Дата;
							КонецЕсли;
						КонецЕсли;
							
						Попытка
							ЛечениеВрачаОбъект.Записать(); 	
							ЛечениеВрача = ЛечениеВрачаОбъект.Ссылка;
							НоваяСтрока           = ТаблицаЛечений.Добавить();						
							НоваяСтрока.Сотрудник = Строка.Сотрудник;
							НоваяСтрока.Лечение   = ЛечениеВрачаОбъект.Ссылка;
							НоваяСтрока.Закрыт    = ЗначениеЗаполнено(ЛечениеВрачаОбъект.ДатаОкончания);
							
						Исключение
							ОписаниеОшибки = "Ошибка при записи лечения по приему " + Строка.Представление + " " + ОписаниеОшибки();
							ЗаписьЖурналаРегистрации("ЗаполнитьКурсыЛеченияВПриемах", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
						КонецПопытки;
						
					Иначе
						ЛечениеВрача = НайденныеСтрокиСотрудник[0].Лечение;
					КонецЕсли;
				КонецЕсли; 				
				
				// 3. Добавление курса и лечения в прием
				ПриемОбъект              = Строка.Ссылка.ПолучитьОбъект();
				ПриемОбъект.КурсЛечения  = КурсЛеченияОбъект.Ссылка;
				ПриемОбъект.ЛечениеВрача = ЛечениеВрача; 
				ПриемОбъект.ОбменДанными.Загрузка = Истина;
				Попытка
					ПриемОбъект.Записать();
				Исключение  
					ОписаниеОшибки = "Ошибка при записи приема " + Строка.Представление + " " + ОписаниеОшибки();
					ЗаписьЖурналаРегистрации("ЗаполнитьКурсыЛеченияВПриемах", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
				КонецПопытки;
				
                // 4. Закрыть курс
				Если Строка.ЗакрытьКурс = Истина Тогда
					
					Если ТаблицаЛечений.Количество() = 0 Тогда
						СоздатьНовыйКурсИЗакрытьПредыдущий = Истина; 
					Иначе
						
						НайденныеСтрокиПоСотруднику = ТаблицаЛечений.НайтиСтроки(Новый Структура("Сотрудник, Закрыт", Строка.Сотрудник, Ложь));  
						Для Каждого НайденнаяСтрока Из НайденныеСтрокиПоСотруднику Цикл
							ЛечениеОбъект = НайденнаяСтрока.Лечение.ПолучитьОбъект(); 
						    ЛечениеОбъект.ДатаОкончания = Строка.Дата;
							ЛечениеОбъект.Записать(); 
							НайденнаяСтрока.Закрыт = Истина;
						КонецЦикла;
						НайденныеСтроки = ТаблицаЛечений.НайтиСтроки(Новый Структура("Закрыт", Ложь)); 					
						СоздатьНовыйКурсИЗакрытьПредыдущий = (НайденныеСтроки.Количество() = 0);
							
					КонецЕсли;		
				Иначе
					СоздатьНовыйКурсИЗакрытьПредыдущий = Ложь;
				КонецЕсли;
				СуммаКурса = СуммаКурса + Строка.СуммаДокумента;
					
				Если СоздатьНовыйКурсИЗакрытьПредыдущий = Истина Тогда
					Попытка 
						КурсЛеченияОбъект.СуммаКурса    = СуммаКурса;
						КурсЛеченияОбъект.ДатаОкончания = Строка.Дата; 
						КурсЛеченияОбъект.Записать();
					Исключение  
						ОписаниеОшибки = "Ошибка при записи курса лечения по приему " + Строка.Представление + " " + ОписаниеОшибки();
						ЗаписьЖурналаРегистрации("ЗаполнитьКурсыЛеченияВПриемах", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
					КонецПопытки;
				КонецЕсли; 

			Исключение  
				ОписаниеОшибки = "Ошибка при записи курса лечения по приему " + Строка.Представление + " " + ОписаниеОшибки();
				ЗаписьЖурналаРегистрации("ЗаполнитьКурсыЛеченияВПриемах", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
			КонецПопытки;
			
			НомерСтроки = НомерСтроки + 1;

		КонецЦикла;
		
		Если СуммаКурса <> 0 И КурсЛеченияОбъект.СуммаКурса = 0 Тогда
			Попытка 
				КурсЛеченияОбъект.СуммаКурса = СуммаКурса;
				КурсЛеченияОбъект.Записать();
			Исключение  
				ОписаниеОшибки = "Ошибка при записи курса лечения по контрагенту " + Контрагент + " " + ОписаниеОшибки();
				ЗаписьЖурналаРегистрации("ЗаполнитьКурсыЛеченияВПриемах", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
			КонецПопытки;	
		КонецЕсли;

	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - установка видимости смены СЕ.
//
Процедура УстановкаВидимостиСменыКлиники() Экспорт
	
	ОбщегоНазначения.ЭтоСеть();
	
КонецПроцедуры

// Процедура - Заполнить справочник Классификатор должностей на сервере
//
Процедура ЗаполнитьСправочникСпециализации() Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Справочники.Специализации.СоздатьЗначенияПоУмолчанию();

КонецПроцедуры 

// Процедура - Присвоить специализации врачам
//
Процедура ПрисвоитьСпециализацииВрачам() Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник,
	|	ВложенныйЗапрос.Наименование КАК ДолжностьНаименование
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Должности.Наименование КАК Наименование,
	|			Должности.Ссылка КАК Ссылка
	|		ИЗ
	|			Справочник.Должности КАК Должности
	|		ГДЕ
	|			НЕ Должности.ПометкаУдаления) КАК ВложенныйЗапрос
	|		ПО Сотрудники.Должность = ВложенныйЗапрос.Ссылка
	|ГДЕ
	|	НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.ЭтоГруппа
	|	И Сотрудники.Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|	И (ВложенныйЗапрос.Наименование ПОДОБНО ""%ортодонт%""
	|			ИЛИ ВложенныйЗапрос.Наименование ПОДОБНО ""%гигиен%""
	|			ИЛИ ВложенныйЗапрос.Наименование ПОДОБНО ""%хирург%""
	|			ИЛИ ВложенныйЗапрос.Наименование ПОДОБНО ""%ортопед%""
	|			ИЛИ ВложенныйЗапрос.Наименование ПОДОБНО ""%терапев%""
	|			ИЛИ ВложенныйЗапрос.Наименование ПОДОБНО ""%парадонт%"")");
	
	Выборка = Запрос.Выполнить().Выбрать();                                       
	Пока Выборка.Следующий() Цикл
		Если Найти(НРег(Выборка.ДолжностьНаименование), "ортодонт") > 0 Тогда 
			Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Ортодонтия");
		ИначеЕсли Найти(НРег(Выборка.ДолжностьНаименование), "гигиен") > 0 Тогда 
			Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Гигиена");
		ИначеЕсли Найти(НРег(Выборка.ДолжностьНаименование), "хирург") > 0 Тогда  
			Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Хирургия");  
		ИначеЕсли Найти(НРег(Выборка.ДолжностьНаименование), "ортопед") > 0 Тогда  
			Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Ортопедия"); 
		ИначеЕсли Найти(НРег(Выборка.ДолжностьНаименование), "терапев") > 0 Тогда	 
			Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Терапия"); 
		ИначеЕсли Найти(НРег(Выборка.ДолжностьНаименование), "парадонт") > 0 Тогда 
			Специализация = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.Специализации.Парадонтология"); 			
		КонецЕсли; 
		
		Если Не ЗначениеЗаполнено(Выборка.Сотрудник.СпецилазацииСотрудника) 
			ИЛИ Не ЗначениеЗаполнено(Выборка.Сотрудник.СпецилазацииСотрудника.НайтиСтроки(Новый Структура("Специализация", Специализация))) Тогда 
			Сотрудник              = Выборка.Сотрудник.ПолучитьОбъект();
			СтрокаТЧ               = Сотрудник.СпецилазацииСотрудника.Добавить();
			СтрокаТЧ.Специализация = Специализация;
			СтрокаТЧ.Основная      = Выборка.Сотрудник.СпецилазацииСотрудника.Количество() = 0;  
			Попытка
				Сотрудник.Записать(); 
			Исключение  
				ЗаписьЖурналаРегистрации("Добавление специализации сотруднику (" + Строка(Сотрудник) + ")", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
            КонецПопытки;
		КонецЕсли;	
	КонецЦикла;	

КонецПроцедуры

// Процедура - Сконвертировать предопределенные сделки
//
Процедура СконвертироватьПредопределенныеСделки() Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ВидСделки 	= Неопределено;
	Отказ 		= Ложь;

	Справочники.ВидыСделок.ИнициализироватьПредопределенныйВид_ПервичныйПовторныйПациент(ВидСделки, Отказ);
	
	Справочники.Сделки.КонвертацияСделокНовыйПациент(Отказ);
	Справочники.Сделки.КонвертацияСделокПостоянныйПациент(Отказ);	
	
КонецПроцедуры

// Процедура, Перезаписать значение регистра сведений "ЗначенияПараметровОбследований".
//
Процедура ПерезаписатьЗначениеЗначенияПараметровОбследований() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗначенияПараметровОбследований.Документ КАК Документ,
	|	ЗначенияПараметровОбследований.ШаблонОбследования КАК ШаблонОбследования,
	|	ЗначенияПараметровОбследований.Параметр КАК Параметр,
	|	ЗначенияПараметровОбследований.Зуб КАК Зуб,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ЗначенияПараметровОбследований.ЗначениеУдалить) = ТИП(СТРОКА)
	|			ТОГДА ВЫРАЗИТЬ(ЗначенияПараметровОбследований.ЗначениеУдалить КАК СТРОКА(400))
	|		ИНАЧЕ ЗначенияПараметровОбследований.ЗначениеУдалить
	|	КОНЕЦ КАК Значение,
	|	ЗначенияПараметровОбследований.ЗначениеУдалить КАК ЗначениеУдалить,
	|	ЗначенияПараметровОбследований.ПорядковыйНомер КАК ПорядковыйНомер,
	|	ЗначенияПараметровОбследований.ЗначениеСтрокой КАК ЗначениеСтрокой
	|ИЗ
	|	РегистрСведений.ЗначенияПараметровОбследований КАК ЗначенияПараметровОбследований"); 
	ТаблицаЗаписейРегистра = Запрос.Выполнить().Выгрузить();
	Попытка 		
		НаборЗаписей = РегистрыСведений.ЗначенияПараметровОбследований.СоздатьНаборЗаписей();
		НаборЗаписей.Загрузить(ТаблицаЗаписейРегистра);
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
	Исключение
		ЗаписьЖурналаРегистрации("Перезаписать регистр сведений значения параметров обследований" , УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
	КонецПопытки; 
	
КонецПроцедуры	

// Процедура - Заполнить статусы пациентов в событии.
//
Процедура ЗаполнитьСтатусыПациентовВСобытии(Параметры = Неопределено) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Событие.Ссылка КАК Ссылка,
	|	Событие.СсылкаНаПрием.СтатусПациента КАК СтатусПациента,
	|	Событие.СсылкаНаПрием КАК СсылкаНаПрием
	|ПОМЕСТИТЬ ВтСобытияСПриемами
	|ИЗ
	|	Документ.Событие КАК Событие
	|ГДЕ
	|	Событие.СсылкаНаПрием <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	|	И Событие.СсылкаНаПрием.СтатусПациента <> ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|	И Событие.СтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|	И Событие.Проведен = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Событие.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.Контрагент ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Постоянный)
	|	КОНЕЦ КАК СтатусПациента
	|ИЗ
	|	Документ.Событие КАК Событие
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПродажиОбороты.Контрагент КАК Контрагент,
	|			ПродажиОбороты.Период КАК Период
	|		ИЗ
	|			РегистрНакопления.Продажи.Обороты(
	|					,
	|					,
	|					Регистратор,
	|					НЕ ДокументПродажи В
	|							(ВЫБРАТЬ
	|								Т.СсылкаНаПрием
	|							ИЗ
	|								ВтСобытияСПриемами КАК Т)) КАК ПродажиОбороты
	|		ГДЕ
	|			ПродажиОбороты.Регистратор ССЫЛКА Документ.Прием) КАК ВложенныйЗапрос
	|		ПО (Событие.Дата > ВложенныйЗапрос.Период
	|				И Событие.Контрагент = ВложенныйЗапрос.Контрагент)
	|ГДЕ
	|	НЕ Событие.Ссылка В
	|				(ВЫБРАТЬ
	|					ВтСобытияСПриемами.Ссылка
	|				ИЗ
	|					ВтСобытияСПриемами КАК ВтСобытияСПриемами)
	|	И Событие.Проведен = ИСТИНА
	|	И Событие.СтатусПациента <> ВЫБОР
	|			КОГДА ВложенныйЗапрос.Контрагент ЕСТЬ NULL
	|				ТОГДА ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный)
	|			ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Постоянный)
	|		КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВтСобытияСПриемами.Ссылка,
	|	ВтСобытияСПриемами.СтатусПациента
	|ИЗ
	|	ВтСобытияСПриемами КАК ВтСобытияСПриемами";
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Пока Выборка.Следующий() Цикл
		
		СобытиеОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		Если СобытиеОбъект <> Неопределено Тогда		
			
			СобытиеОбъект.СтатусПациента = Выборка.СтатусПациента;	
			
			Попытка
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СобытиеОбъект);
			Исключение	
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
Конецпроцедуры

// Процедура - Заполнить уникальный идентификатор структурной единицы
//
Процедура ЗаполнитьУникальныйИдентификаторСтруктурнойЕдиницы() Экспорт
	
	// Заполнить реквизит УникальныйИдентификаторСтруктурнойЕдиницы 
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|	И СтруктурныеЕдиницы.УникальныйИдентификаторСтруктурнойЕдиницы = """"";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		СтруктурнаяЕдиницаОбъект = Выборка.Ссылка.ПолучитьОбъект();
		СтруктурнаяЕдиницаОбъект.УникальныйИдентификаторСтруктурнойЕдиницы = Строка(Новый УникальныйИдентификатор());
		Попытка
			СтруктурнаяЕдиницаОбъект.Записать(); 
		Исключение
			ЗаписьЖурналаРегистрации("Заполнить уникальный идентификатор структурной единицы", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	
	// Выгрузить в личный кабинет
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Параметры КАК Параметры,
	|	ВнешниеСистемы.КлючПриложения КАК КлючПриложения
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.УправлениеВЛичномКабинете
	|	И ВнешниеСистемы.ТипВнешнейСистемы = ЗНАЧЕНИЕ(Перечисление.ТипыВнешнихСистем.ВиджетОнлайнЗаписи)
	|	И ВнешниеСистемы.Используется = ИСТИНА");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ПараметрыВнешнейСистемы = Выборка.Параметры.Получить();
		ИспользуемыеСтруктурныеЕдиницы = Новый Массив;
		Если ПараметрыВнешнейСистемы <> Неопределено И ПараметрыВнешнейСистемы.Свойство("ИспользуемыеСтруктурныеЕдиницы") 
			И ПараметрыВнешнейСистемы.ИспользуемыеСтруктурныеЕдиницы.Количество() > 0 Тогда
			ИспользуемыеСтруктурныеЕдиницы = ПараметрыВнешнейСистемы.ИспользуемыеСтруктурныеЕдиницы;  
			Попытка 
				Организация = ПолучитьОрганизацию();  
				Если Не ЗначениеЗаполнено(Организация) Тогда
					Продолжить;
				КонецЕсли;
				Результат = ЛичныйКабинет.УдалитьРегистрациюВиджета(Организация, ИспользуемыеСтруктурныеЕдиницы, Истина);
				Если Результат.ВыполненоУспешно Тогда
					Результат = ЛичныйКабинет.ЗарегистироватьВиджет(Организация, Выборка.КлючПриложения, ИспользуемыеСтруктурныеЕдиницы);
				КонецЕсли;
				
				Результат = ЛичныйКабинет.РегистрацияОрганизацииВиджета(Организация, Выборка.КлючПриложения);	
				Если Результат.ВыполненоУспешно Тогда
					ЛичныйКабинет.РегистрацияСтруктурныхЕдиницВиджета(ИспользуемыеСтруктурныеЕдиницы); 
				КонецЕсли;
			Исключение  
				ОписаниеОшибки = "Ошибка при регистрации виджета, для обновления id структурной единицы в reservi" + Символы.ПС + ОписаниеОшибки(); 
				ЗаписьЖурналаРегистрации("Заполнить уникальный идентификатор структурной единицы", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция - Получить организацию
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОрганизацию()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Организации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	НЕ Организации.ПометкаУдаления
	|	И НЕ Организации.ЭтоГруппа");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

// Процедура - Добавить роль использование монитора руководителя.
//
// Параметры:
//  Параметры	 - 	 - 
//
Процедура ДобавитьРольИспользованиеМонитораРуководителя(Параметры = Неопределено) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.ПометкаУдаления = ЛОЖЬ
	|	И (Пользователи.РольПользователя = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Управляющий)
	|			ИЛИ Пользователи.РольПользователя = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Руководитель))";
		
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Пока Выборка.Следующий() Цикл
		
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ);		
		
		Если ПользовательИБ <> Неопределено 		
			И ПользовательИБ.Роли.Содержит(Метаданные.Роли.ИспользоватьРабочийСтолМониторРуководителя) = Ложь Тогда
			
			ПользовательИБ.Роли.Добавить(Метаданные.Роли.ИспользоватьРабочийСтолМониторРуководителя);
			
			Попытка 
				ПользовательИБ.Записать();
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
Конецпроцедуры

// Процедура, обновляет пользовательские настройки списка клиентов после ухода от реквизита "Клиенты".
//
Процедура ОбновитьПользовательскиеНастройкиСпискаКлиентов() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Отбор = Новый Структура("КлючОбъекта", "Справочник.Контрагенты.Форма.ФормаСпискаКлиенты.Список/ТекущиеПользовательскиеНастройки");
	НастройкиВыборка = ХранилищеСистемныхНастроек.Выбрать(Отбор);
	
	Пока НастройкиВыборка.Следующий() Цикл
		
		НастройкаИзменена = Ложь;
		Для Каждого ЭлементНастройки Из НастройкиВыборка.Настройки.Элементы Цикл
			
			Если ТипЗнч(ЭлементНастройки) <> Тип("УсловноеОформлениеКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ЭлементУсловногоОформления Из ЭлементНастройки.Элементы Цикл
				
				Если ЭлементУсловногоОформления.Представление = "ФильтрСкрытияНеподходящихГрупп" Тогда
					
					// Возможна ситуация, когда недействительное поле компоновки удаляется платформой.
					Если ЭлементУсловногоОформления.Отбор.Элементы.Количество() = 1
						И ЭлементУсловногоОформления.Отбор.Элементы[0].ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ЭтоГруппа") Тогда
						
						НовыйЭлементОтбора					 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
						НовыйЭлементОтбора.ЛевоеЗначение	 = Новый ПолеКомпоновкиДанных("ТипКонтрагента");
						НовыйЭлементОтбора.ПравоеЗначение	 = Перечисления.ТипыКонтрагентов.Клиенты;
						НовыйЭлементОтбора.ВидСравнения		 = ВидСравненияКомпоновкиДанных.НеРавно;
						НовыйЭлементОтбора.Использование	 = ЭлементУсловногоОформления.Отбор.Элементы[0].Использование;
						
						НастройкаИзменена = Истина;
						
					Иначе
						// Заменяем отбор по полю "Клиенты" на отбор по типу контрагента.
						Для Каждого ЭлементОтбораУсловногоОформления Из ЭлементУсловногоОформления.Отбор.Элементы Цикл
							
							Если ЭлементОтбораУсловногоОформления.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Клиенты") Тогда
								
								НовыйЭлементОтбора					 = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
								НовыйЭлементОтбора.ЛевоеЗначение	 = Новый ПолеКомпоновкиДанных("ТипКонтрагента");
								НовыйЭлементОтбора.ПравоеЗначение	 = Перечисления.ТипыКонтрагентов.Клиенты;
								НовыйЭлементОтбора.ВидСравнения		 = ВидСравненияКомпоновкиДанных.НеРавно;
								НовыйЭлементОтбора.Использование	 = ЭлементОтбораУсловногоОформления.Использование;
								
								ЭлементУсловногоОформления.Отбор.Элементы.Удалить(ЭлементОтбораУсловногоОформления);
								
								НастройкаИзменена = Истина;
								Прервать;
								
							КонецЕсли;
							
						КонецЦикла;
						
					КонецЕсли;
					
					
				КонецЕсли;
				
				Если НастройкаИзменена Тогда
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			Если НастройкаИзменена Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НастройкаИзменена Тогда
			ХранилищеСистемныхНастроек.Сохранить(
				НастройкиВыборка.КлючОбъекта,
				НастройкиВыборка.КлючНастроек,
				НастройкиВыборка.Настройки,,
				НастройкиВыборка.Пользователь
			); 
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, обновляет статусы пациентов в регистре КонтрагентыСведенияДляСписка.
//
Процедура ОбновитьСтатусыПациентовВРегистреКонтрагентыСведенияДляСписка(Параметры = Неопределено) Экспорт

	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ЭтоГруппа
	|	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			
			ПоследняяЗадача = Неопределено;
			ПоследняяЗадачаПредставление = Неопределено;
			СледующаяЗадача = Неопределено;
			СледующаяЗадачаПредставление = Неопределено;
			ТекущаяСделка 		= Неопределено;
			ТекущийЭтапСделки   = Неопределено;
			СуммаСделки         = Неопределено;
			ЗапланированнаяПредварительнаяЗапись = Неопределено;
			ДатаСледующегоПриема = Дата(1,1,1);
			
			Запрос = Новый Запрос(			
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Событие.Ссылка КАК Ссылка,
			|	Событие.Дата КАК ДатаСледующегоПриема
			|ИЗ
			|	Документ.Событие КАК Событие
			|ГДЕ
			|	Событие.Проведен
			|	И Событие.Контрагент = &Контрагент
			|	И Событие.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.НеПодтверждена), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.Подтверждена), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПациентОжидает))
			|	И Событие.ТипСобытия = ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ПредварительнаяЗапись)
			|
			|УПОРЯДОЧИТЬ ПО
			|	Событие.Дата УБЫВ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Прием.ВремяНачалаПриема КАК ДатаПервогоПриема
			|ИЗ
			|	Документ.Прием КАК Прием
			|ГДЕ
			|	Прием.Контрагент = &Контрагент
			|	И Прием.Проведен
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаПервогоПриема
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Прием.ВремяНачалаПриема КАК ДатаПоследнегоПриема
			|ИЗ
			|	Документ.Прием КАК Прием
			|ГДЕ
			|	Прием.Контрагент = &Контрагент
			|	И Прием.Проведен
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаПоследнегоПриема УБЫВ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	КОЛИЧЕСТВО(Прием.Ссылка) КАК Количество
			|ИЗ
			|	Документ.Прием КАК Прием
			|ГДЕ
			|	Прием.Контрагент = &Контрагент
			|	И Прием.Проведен
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Сделки.Ссылка КАК ТекущаяСделка,
			|	Сделки.ЭтапСделки КАК ЭтапСделки,
			|	Сделки.СуммаСделки КАК СуммаСделки
			|ИЗ
			|	Справочник.Сделки КАК Сделки
			|ГДЕ
			|	Сделки.Контрагент = &Контрагент
			|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
			|	И НЕ Сделки.ПометкаУдаления
			|
			|УПОРЯДОЧИТЬ ПО
			|	Сделки.ДатаСделки УБЫВ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус
			|ИЗ
			|	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, Контрагент = &Контрагент) КАК СтатусыКонтрагентовСрезПоследних
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
			|ИЗ
			|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
			|ГДЕ
			|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
			|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
			|	И КонтрагентыКонтактнаяИнформация.НомерТелефона <> """"
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	КонтрагентыКонтактнаяИнформация.АдресЭП КАК АдресЭП
			|ИЗ
			|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
			|ГДЕ
			|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
			|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКлиента)
			|	И КонтрагентыКонтактнаяИнформация.АдресЭП <> """"
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Взаимодействие.Ссылка КАК ПоследняяЗадача,
			|	Взаимодействие.ЗадачаТема КАК ЗадачаТема,
			|	Взаимодействие.ЗадачаОписание КАК ЗадачаОписание,
			|	Взаимодействие.ДатаИсполнения КАК ДатаИсполнения
			|ИЗ
			|	Задача.Взаимодействие КАК Взаимодействие
			|ГДЕ
			|	Взаимодействие.Выполнена
			|	И Взаимодействие.Контрагент = &Контрагент
			|	И НЕ Взаимодействие.ПометкаУдаления
			|
			|УПОРЯДОЧИТЬ ПО
			|	Взаимодействие.ЗадачаНазначеннаяДата УБЫВ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Взаимодействие.Ссылка КАК СледующаяЗадача,
			|	Взаимодействие.ЗадачаТема КАК ЗадачаТема,
			|	Взаимодействие.ЗадачаОписание КАК ЗадачаОписание,
			|	Взаимодействие.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
			|ИЗ
			|	Задача.Взаимодействие КАК Взаимодействие
			|ГДЕ
			|	НЕ Взаимодействие.Выполнена
			|	И Взаимодействие.Контрагент = &Контрагент
			|	И НЕ Взаимодействие.ПометкаУдаления
			|
			|УПОРЯДОЧИТЬ ПО
			|	Взаимодействие.ЗадачаНазначеннаяДата УБЫВ");
			
			Запрос.УстановитьПараметр("Контрагент", Выборка.Контрагент);
			
			Результат								= Запрос.ВыполнитьПакет();
			
			ТаблицаЗапланированнаяПЗ				= Результат[0].Выгрузить();	
			ТаблицаПервыйПрием						= Результат[1].Выгрузить();
			ТаблицаПоследнийПрием					= Результат[2].Выгрузить();
			ТаблицаКоличествоПриемов				= Результат[3].Выгрузить(); 	
			ТаблицаТекущаяСделка					= Результат[4].Выгрузить();
			ТаблицаТекущийСтатус					= Результат[5].Выгрузить();
			
			ДатаПоследнегоПриема = ?(ТаблицаПоследнийПрием.Количество() > 0, ТаблицаПоследнийПрием[0].ДатаПоследнегоПриема, Дата(1,1,1));
			
			Если ТаблицаЗапланированнаяПЗ.Количество() > 0 Тогда
				ЗапланированнаяПредварительнаяЗапись = ТаблицаЗапланированнаяПЗ[0].Ссылка;
				ДатаСледующегоПриема = ?(ДатаПоследнегоПриема <= ТаблицаЗапланированнаяПЗ[0].ДатаСледующегоПриема, ТаблицаЗапланированнаяПЗ[0].ДатаСледующегоПриема, Дата(1,1,1));	
			КонецЕсли;
			
			Если ТаблицаТекущаяСделка.Количество() > 0 Тогда
				ТекущаяСделка 		= ТаблицаТекущаяСделка[0].ТекущаяСделка;
				ТекущийЭтапСделки   = ТаблицаТекущаяСделка[0].ЭтапСделки;
				СуммаСделки         = ТаблицаТекущаяСделка[0].СуммаСделки;
			КонецЕсли;
			
			МассивТелефоны 			= Результат[6].Выгрузить().ВыгрузитьКолонку("НомерТелефона");
			ТелефоныСтрокой			= СтроковыеФункцииКлиентСерверСтоматология.ПолучитьСтрокуИзМассиваПодстрок(МассивТелефоны, ", ");
			
			МассивEmail 			= Результат[7].Выгрузить().ВыгрузитьКолонку("АдресЭП");
			АдресаЭПСтрокой			= СтроковыеФункцииКлиентСерверСтоматология.ПолучитьСтрокуИзМассиваПодстрок(МассивEmail, ", ");
			
			ТаблицаПоследняяЗадача	= Результат[8].Выгрузить();
			ТаблицаСледующаяЗадача	= Результат[9].Выгрузить();
			
			Если ТаблицаПоследняяЗадача.Количество() > 0 Тогда
				
				ПоследняяЗадача = ТаблицаПоследняяЗадача[0].ПоследняяЗадача;
				
				ПоследняяЗадачаТема = СокрЛП(ТаблицаПоследняяЗадача[0].ЗадачаТема);
				ПоследняяЗадачаОписание = СокрЛП(ТаблицаПоследняяЗадача[0].ЗадачаОписание);
				
				ПоследняяЗадачаПредставление = "" + ТаблицаПоследняяЗадача[0].ДатаИсполнения
												+ ?(ЗначениеЗаполнено(ПоследняяЗадачаТема), " " + ПоследняяЗадачаТема, "") 
												+ ?(ЗначениеЗаполнено(ПоследняяЗадачаОписание), " " + ПоследняяЗадачаОписание, "");
				
			КонецЕсли;
			
			Если ТаблицаСледующаяЗадача.Количество() > 0 Тогда
				
				СледующаяЗадача = ТаблицаСледующаяЗадача[0].СледующаяЗадача;
				
				СледующаяЗадачаТема = СокрЛП(ТаблицаСледующаяЗадача[0].ЗадачаТема);
				СледующаяЗадачаОписание = СокрЛП(ТаблицаСледующаяЗадача[0].ЗадачаОписание);
				
				СледующаяЗадачаПредставление = "" + ТаблицаСледующаяЗадача[0].ЗадачаНазначеннаяДата 
												+ ?(ЗначениеЗаполнено(СледующаяЗадачаТема), " " + СледующаяЗадачаТема, "") 
												+ ?(ЗначениеЗаполнено(СледующаяЗадачаОписание), " " + СледующаяЗадачаОписание, "");
				
			КонецЕсли;			
			
			ОбновляемыеДанные = Новый Структура;
			ОбновляемыеДанные.Вставить("Контрагент"		, Выборка.Контрагент);
			
			ОбновляемыеДанные.Вставить("Статус", ?(ТаблицаТекущийСтатус.Количество() > 0, ТаблицаТекущийСтатус[0].Статус, Неопределено));	
			ОбновляемыеДанные.Вставить("ДатаПервогоПриема", ?(ТаблицаПервыйПрием.Количество() > 0, ТаблицаПервыйПрием[0].ДатаПервогоПриема, Дата(1,1,1))); 
			ОбновляемыеДанные.Вставить("ДатаПоследнегоПриема", ДатаПоследнегоПриема);	
			ОбновляемыеДанные.Вставить("КоличествоПриемов", ?(ТаблицаКоличествоПриемов.Количество() > 0, ТаблицаКоличествоПриемов[0].Количество, 0));
			
			ОбновляемыеДанные.Вставить("ЗапланированнаяПредварительнаяЗапись", ЗапланированнаяПредварительнаяЗапись);
			ОбновляемыеДанные.Вставить("ДатаСледующегоПриема", ДатаСледующегоПриема);
			ОбновляемыеДанные.Вставить("ТекущаяСделка", ТекущаяСделка);
			ОбновляемыеДанные.Вставить("ТекущийЭтапСделки", ТекущийЭтапСделки);
			ОбновляемыеДанные.Вставить("СуммаСделки", СуммаСделки);
			
			ОбновляемыеДанные.Вставить("Телефон", ТелефоныСтрокой);
			ОбновляемыеДанные.Вставить("АдресЭП", АдресаЭПСтрокой);
			
			ОбновляемыеДанные.Вставить("ПоследняяЗадача", ПоследняяЗадача);
			ОбновляемыеДанные.Вставить("ПоследняяЗадачаПредставление", ПоследняяЗадачаПредставление);
			ОбновляемыеДанные.Вставить("СледующаяЗадача", СледующаяЗадача);
			ОбновляемыеДанные.Вставить("СледующаяЗадачаПредставление", СледующаяЗадачаПредставление);
		
			РегистрыСведений.КонтрагентыСведенияДляСписка.АктуализироватьНеобходимыеДанныеВСведенияхДляСписка(Выборка.Контрагент, ОбновляемыеДанные);
				
		Исключение
			ЗаписьЖурналаРегистрации("Актуализация данных в регистре сведений КонтрагентыСведенияДляСписка"
									, УровеньЖурналаРегистрации.Ошибка,,
									, ПодробноеПредставлениеОшибки(ОписаниеОшибки()));
		КонецПопытки;
		
	КонецЦикла;
	
	Если НЕ Параметры = Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура, обновляет предопределенные элементы видов сделок и причин отказа.
//
Процедура ОбновитьПредопределенныеВидСделкиИПричиныОтказов() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;  
	
	КлиентНеПришел  = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентНеПришел"); 
	КлиентОтказался = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался"); 
	Если КлиентНеПришел <> Неопределено Тогда
		ТекЭлемент = КлиентНеПришел.ПолучитьОбъект();
		ТекЭлемент.Наименование = "Пациент не пришел"; 
		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ТекЭлемент);
		Исключение 
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
				                         , УровеньЖурналаРегистрации.Ошибка
				                         ,				                         ,
				                         , "Не удалось записать предопределенный элемент ""КлиентНеПришел"" справочника Причины отказов");
		КонецПопытки; 	
	КонецЕсли; 
	
	Если КлиентОтказался <> Неопределено Тогда
		ТекЭлемент = КлиентОтказался.ПолучитьОбъект();
		ТекЭлемент.Наименование = "Пациент отказался";
		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ТекЭлемент); 
		Исключение  
			 	ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
				                         , УровеньЖурналаРегистрации.Ошибка
				                         ,				                         ,
				                         , "Не удалось записать предопределенный элемент ""КлиентОтказался"" справочника Причины отказов");
		КонецПопытки;
	КонецЕсли;
	
	ВидСделкиНовыеПациенты = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");   
	Если Не ЗначениеЗаполнено(ВидСделкиНовыеПациенты) Тогда 
		Возврат;
	КонецЕсли;			
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ВидСделки = &ВидСделки
	|	И НЕ ЭтапыСделок.ПометкаУдаления"); 
	Запрос.УстановитьПараметр("ВидСделки", ВидСделкиНовыеПациенты); 
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если СтрНайти(Выборка.Наименование, "Клиент") > 0 Или СтрНайти(Выборка.Наименование, "прием") > 0 Тогда
			ЭтапСделкиОбъект = Выборка.Ссылка.ПолучитьОбъект(); 
			Если СтрНайти(Выборка.Наименование, "Клиент") Тогда
				ЭтапСделкиОбъект.Наименование = СтрЗаменить(ЭтапСделкиОбъект.Наименование, "Клиент", "Пациент");  
			Иначе
				ЭтапСделкиОбъект.Наименование = СтрЗаменить(ЭтапСделкиОбъект.Наименование, "прием", "приём");
			КонецЕсли;
			Попытка
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ЭтапСделкиОбъект);   
			Исключение 
				ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
				                         , УровеньЖурналаРегистрации.Ошибка
				                         ,				                         ,
				                         , "Не удалось записать этап сделки" + Выборка.Наименование + " справочника этапы сделок");
			КонецПопытки; 
		КонецЕсли;						 
	КонецЦикла;		
	
	ВидСделкиОбъект = ВидСделкиНовыеПациенты.ПолучитьОбъект();
	ВидСделкиОбъект.НаименованиеЭтапаУспех = СтрЗаменить(ВидСделкиОбъект.НаименованиеЭтапаУспех, "Клиент", "Пациент");
	ВидСделкиОбъект.НаименованиеЭтапаОтказ = СтрЗаменить(ВидСделкиОбъект.НаименованиеЭтапаОтказ, "Клиент", "Пациент"); 
	Попытка 
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ВидСделкиОбъект);	 
	Исключение 
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
		                         , УровеньЖурналаРегистрации.Ошибка
		                         ,				                         ,
		                         , "Не удалось записать вид сделки" + ВидСделкиОбъект.Наименование + " справочника виды сделок");
		
	КонецПопытки;
	
КонецПроцедуры  

// Процедура, перезаписывает код номенклатуры медицинских услуг если он начинался с кириллицы. 
//
Процедура ПерезаписатьКодНоменклатурыМедицинскихУслуг() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли; 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КлассификаторНоменклатурыМедицинскихУслуг.Ссылка КАК Ссылка,
	|	КлассификаторНоменклатурыМедицинскихУслуг.Код КАК Код,
	|	КлассификаторНоменклатурыМедицинскихУслуг.Представление КАК Представление
	|ИЗ
	|	Справочник.КлассификаторНоменклатурыМедицинскихУслуг КАК КлассификаторНоменклатурыМедицинскихУслуг
	|ГДЕ
	|	НЕ КлассификаторНоменклатурыМедицинскихУслуг.ЭтоГруппа"); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	МетаданныеСправочника = Метаданные.Справочники.КлассификаторНоменклатурыМедицинскихУслуг;		
	Пока Выборка.Следующий() Цикл  	
		КодНМУ = Выборка.Код;
		Справочники.КлассификаторНоменклатурыМедицинскихУслуг.ПривестиКодКЛатинскомуВарианту(КодНМУ);
		Если СокрЛП(КодНМУ) <> СокрЛП(Выборка.Код) Тогда
			ОбъектНМУ     = Выборка.Ссылка.ПолучитьОбъект();	
			ОбъектНМУ.Код = КодНМУ;
			Попытка
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ОбъектНМУ);
			Исключение
				ШаблонКомментария = НСтр("ru = 'Не удалось записать %1 по причине: %2'");		
				Комментарий       = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
				                                                                            , Выборка.Представление
				                                                                            , ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 	
				ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
				                         , УровеньЖурналаРегистрации.Ошибка
				                         , МетаданныеСправочника
				                         ,
				                         , Комментарий);				
			КонецПопытки; 
		КонецЕсли;
	КонецЦикла;	
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.НоменклатураМедицинскихУслуг.Код КАК КодКлассификатора,
	|	Номенклатура.КодНоменклатурыМедицинскиУслуг КАК КодНМУ,
	|	Номенклатура.НоменклатураМедицинскихУслуг КАК НоменклатураМУ,
	|	Номенклатура.Представление КАК Представление
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ЭтоГруппа
	|	И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)");
	
	Выборка = Запрос.Выполнить().Выбрать();
	МетаданныеСправочника = Метаданные.Справочники.Номенклатура;	
	Пока Выборка.Следующий() Цикл 
		
		Если Не ЗначениеЗаполнено(Выборка.НоменклатураМУ) Тогда
			КодКлассификатора = "";
		Иначе
			КодКлассификатора = Выборка.КодКлассификатора; 
		КонецЕсли;  
			
		Если СокрЛП(Выборка.КодНМУ) <> СокрЛП(КодКлассификатора) Тогда			
			ОбъектНоменклатура = Выборка.Ссылка.ПолучитьОбъект();
			ОбъектНоменклатура.КодНоменклатурыМедицинскиУслуг = КодКлассификатора;
			Попытка
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ОбъектНоменклатура);
			Исключение  
				
				ШаблонКомментария = НСтр("ru = 'Не удалось записать %1 по причине: %2'");		
				Комментарий       = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
				                                                                            , Выборка.Представление
				                                                                            , ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
				
				ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
				                         , УровеньЖурналаРегистрации.Ошибка
				                         , МетаданныеСправочника
				                         ,
				                         , Комментарий);	
			КонецПопытки; 
		КонецЕсли; 
		
	КонецЦикла;	
	
КонецПроцедуры	

// Процедура - Актуализировать расписание обновления статусов событий
//
Процедура АктуализироватьРасписаниеОбновленияСтатусовСобытий() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;  

	Если ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
		Возврат;
	КонецЕсли;

	ЗаданиеНашли = Истина;	
	// Ищем задание по наименованию.
	Отбор = Новый Структура();
	Отбор.Вставить("Метаданные", "ОбновлениеСтатусовСобытий");
	Задания = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);
	
	// Проверяем, что задание найдено.
	Если Задания.Количество() <> 1 Тогда
		// Запись в журнал ошибки опущена.
		ЗаданиеНашли = Ложь;
	КонецЕсли;
	
	Если ЗаданиеНашли = Истина Тогда 	
		// Актуализируем задание.
		НашеЗадание 					= Задания[0];
		ПараметрыЗадания 				= Новый Структура();
		
		Расписание 						= Новый РасписаниеРегламентногоЗадания;
		Расписание.ПериодПовтораДней 	= 1;
		Расписание.ПериодНедель		 	= 1;
		МассивДней 						= Новый Массив; Для К = 1 По 7 Цикл МассивДней.Добавить(К); КонецЦикла; 
		МассивМесяцев 					= Новый Массив; Для К = 1 По 12 Цикл МассивМесяцев.Добавить(К); КонецЦикла;  
		
		Расписание.ДниНедели 			= МассивДней;
		Расписание.Месяцы				= МассивМесяцев;
		
		Расписание.ВремяНачала 			= Дата(1,1,1) + 60*60*3;
		
		ПараметрыЗадания.Вставить("Использование"	, Истина); 
		ПараметрыЗадания.Вставить("Расписание"		, Расписание);
		Попытка
			РегламентныеЗаданияСервер.ИзменитьЗадание(НашеЗадание.УникальныйИдентификатор, ПараметрыЗадания);
		Исключение
			
			МетаданныеЗадания 			= Метаданные.РегламентныеЗадания.ОбновлениеСтатусовСобытий;		
			ШаблонКомментария 			= НСтр("ru = 'Ошибка изменения расписания регламентного задания ""Обновление статусов событий""! 
			|по причине: %1'");
		
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																				, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
									, УровеньЖурналаРегистрации.Ошибка
									, МетаданныеЗадания
									,
									, Комментарий);
		КонецПопытки;	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Добавляет роль пользователям ИБ "ВыводНаПринтерФайлБуферОбмена"
//
Процедура ДобавитьРольВыводНаПринтерФайлБуферОбмена() Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	НЕ Сотрудники.ЭтоГруппа
	|	И НЕ Сотрудники.Служебный";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если НЕ Выборка.ИдентификаторПользователяИБ = ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор() Тогда
			
			НайденныйПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ); 
			
			Если НайденныйПользовательИБ <> Неопределено И НЕ НайденныйПользовательИБ.Роли.Содержит(Метаданные.Роли.ВыводНаПринтерФайлБуферОбмена) Тогда
				
				НайденныйПользовательИБ.Роли.Добавить(Метаданные.Роли.ВыводНаПринтерФайлБуферОбмена);
				
				Попытка
					
					НайденныйПользовательИБ.Записать();
					
				Исключение 
					
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

// Процедура - Заполнить доступные кассы пользователям.
//
Процедура ЗаполнитьДоступныеКассыПользователей(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПользователиДоступныеСтруктурныеЕдиницы.Ссылка КАК Пользователь,
	|	ПользователиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ МестаРаботыПользователей
	|ИЗ
	|	Справочник.Пользователи.ДоступныеСтруктурныеЕдиницы_Удалить КАК ПользователиДоступныеСтруктурныеЕдиницы
	|ГДЕ
	|	ПользователиДоступныеСтруктурныеЕдиницы.Ссылка.ИдентификаторПользователяИБ <> &ПустойИдентификатор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкиПользователей.Пользователь КАК Пользователь,
	|	НастройкиПользователей.Значение КАК Касса
	|ИЗ
	|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МестаРаботыПользователей КАК МестаРаботыПользователей
	|		ПО НастройкиПользователей.Пользователь = МестаРаботыПользователей.Пользователь
	|			И НастройкиПользователей.СтруктурнаяЕдиница = МестаРаботыПользователей.СтруктурнаяЕдиница
	|ГДЕ
	|	НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ОсновнаяКасса)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПользователиДоступныеСтруктурныеЕдиницы.Ссылка КАК Пользователь,
	|	Кассы.Ссылка КАК Касса,
	|	ПользователиДоступныеСтруктурныеЕдиницы.Ссылка.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
	|ИЗ
	|	Справочник.Пользователи.ДоступныеСтруктурныеЕдиницы_Удалить КАК ПользователиДоступныеСтруктурныеЕдиницы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Кассы КАК Кассы
	|		ПО ПользователиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = Кассы.СтруктурнаяЕдиница
	|ГДЕ
	|	НЕ Кассы.Ссылка ЕСТЬ NULL
	|	И ПользователиДоступныеСтруктурныеЕдиницы.Ссылка.ИдентификаторПользователяИБ <> &ПустойИдентификатор
	|ИТОГИ ПО
	|	Пользователь";             
	
	Запрос.УстановитьПараметр("ПустойИдентификатор", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
		
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	ТаблицаОсновныеКассыПользователей = МассивРезультатов[1].Выгрузить(); 
	
	Выборка = МассивРезультатов[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	
	Пока Выборка.Следующий() Цикл
		ОсновнаяКассаДобавлена 		= Ложь;
		
		СтрокаТаблицы = ТаблицаОсновныеКассыПользователей.Найти(Выборка.Пользователь, "Пользователь");
		ОсновнаяКассаПользователя 	= ?(СтрокаТаблицы <> Неопределено, СтрокаТаблицы.Касса, СтрокаТаблицы); 
		
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ);
				
		Если ПользовательИБ <> Неопределено 		
			И НЕ (ПользовательИБ.Роли.Содержит(Метаданные.Роли.ДобавлениеИзменениеДокументовПоОплате) = Истина 
			Или ПользовательИБ.Роли.Содержит(Метаданные.Роли.ДобавлениеИзменениеДокументовПоФинансам) = Истина
			Или ПользовательИБ.Роли.Содержит(Метаданные.Роли.ПолныеПрава) = Истина) Тогда
			
			Продолжить;
		КонецЕсли;;
		
		ПользовательОбъект = Выборка.Пользователь.ПолучитьОбъект();
		
		Если ПользовательОбъект = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПользовательОбъект.ДоступныеКассы_Удалить.Очистить();
		
		ВыборкаДетальныеЗаписи = Выборка.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			НоваяСтрока = ПользовательОбъект.ДоступныеКассы_Удалить.Добавить();
			НоваяСтрока.Касса = ВыборкаДетальныеЗаписи.Касса;
			
			Если ОсновнаяКассаПользователя = ВыборкаДетальныеЗаписи.Касса И ОсновнаяКассаДобавлена = Ложь Тогда
				НоваяСтрока.Основная = Истина;
				ОсновнаяКассаДобавлена = Истина;
			КонецЕсли;
			
		КонецЦикла; 
		
		Если ОсновнаяКассаДобавлена = Ложь И ПользовательОбъект.ДоступныеКассы_Удалить.Количество() > 0 Тогда
			ПользовательОбъект.ДоступныеКассы_Удалить[0].Основная = Истина;
		КонецЕсли;
		
		Попытка	
			ПользовательОбъект.Записать();
		Исключение 
		КонецПопытки;
				
	КонецЦикла;
	
КонецПроцедуры   

// Процедура - Заполнить статьи доходов документа поступление денежных средств
//
Процедура ЗаполнитьСтатьиДвиженияДокументаПоступлениеДенежныхСредств(Параметры = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Справочники.СтатьиДоходовИРасходов.ОплатаОтКлиента.ПоУмолчаниюДляОперации.Пустая() Тогда
		
		СправочникОбъект 						= Справочники.СтатьиДоходовИРасходов.ОплатаОтКлиента.ПолучитьОбъект();
		СправочникОбъект.ПоУмолчаниюДляОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента;
		
		Попытка	
			СправочникОбъект.Записать();
		Исключение
		КонецПопытки;
		
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПоступлениеДенежныхСредств.Ссылка КАК Ссылка,
	|	ПоступлениеДенежныхСредств.Проведен КАК Проведен
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|ГДЕ
	|	ПоступлениеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
	|	И ПоступлениеДенежныхСредств.Статья = ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРАсходов.ПустаяСсылка)
	|	И НЕ ПоступлениеДенежныхСредств.ПометкаУдаления");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Статья = Справочники.СтатьиДоходовИРасходов.ОплатаОтКлиента;
	
	Пока Выборка.Следующий() Цикл 
		
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		Если ДокументОбъект = Неопределено Тогда 	
			Продолжить;	
		КонецЕсли;
		
		ДокументОбъект.Статья = Статья;
		
		Попытка       
			
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			
			Если Выборка.Проведен Тогда
				
				НаборЗаписей = РегистрыНакопления.ДенежныеСредства.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Значение = Выборка.Ссылка;
				
				НаборЗаписей.Прочитать();
				
				Если НаборЗаписей.Выбран() Тогда
					
					Для Каждого Запись Из НаборЗаписей Цикл
						Если Не ЗначениеЗаполнено(Запись.Статья) И Запись.ВидДвижения = ВидДвиженияНакопления.Приход Тогда
							Запись.Статья = Статья;	
						КонецЕсли;
					КонецЦикла;
					
					НаборЗаписей.Записать();
					
				КонецЕсли;			
				
			КонецЕсли;
			
		Исключение 			
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());						
		КонецПопытки;
		
	КонецЦикла;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

