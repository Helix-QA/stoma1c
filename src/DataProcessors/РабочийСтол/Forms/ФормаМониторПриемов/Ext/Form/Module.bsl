// Процедура - Инициализировать настройки монитора
//
Процедура ИнициализироватьНастройкиМонитора()
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТаблицаНастроек = РегистрыСведений.НастройкиИнтерфейсов.ПолучитьНастройкиМонитораПродаж();	
	Для Каждого СтрокаТаблицыНастроек Из ТаблицаНастроек Цикл
		ИмяРеквизитаФормы = СтрЗаменить(СтрокаТаблицыНастроек.ИмяПредопределенныхДанных, "МониторПродаж_", "");
		Если ИмяРеквизитаФормы = "ПериодАвтообновления" Тогда 
			ЭтотОбъект[ИмяРеквизитаФормы] = ?(СтрокаТаблицыНастроек.Значение < 10, 10, СтрокаТаблицыНастроек.Значение); 
		ИначеЕсли ИмяРеквизитаФормы = "ДатаПросмотраИсторииСобытий" Тогда
			ЭтотОбъект[ИмяРеквизитаФормы] = ?(СтрокаТаблицыНастроек.Значение < ТекущаяДатаСеанса() - 86400*3, ТекущаяДатаСеанса() - 86400*3, СтрокаТаблицыНастроек.Значение); 
		ИначеЕсли ИмяРеквизитаФормы = "КоличествоКолонокДляВыводимыхВиджетов" Тогда
			ЭтотОбъект[ИмяРеквизитаФормы] = ?(СтрокаТаблицыНастроек.Значение = 0, 3, СтрокаТаблицыНастроек.Значение); 
		ИначеЕсли ИмяРеквизитаФормы = "КоличествоКолонокДляВыводимыхВиджетовKPI" Тогда
			ЭтотОбъект[ИмяРеквизитаФормы] = ?(СтрокаТаблицыНастроек.Значение = 0, 3, СтрокаТаблицыНастроек.Значение); 
		ИначеЕсли ИмяРеквизитаФормы = "ОтборПериодТип" Тогда
			ЭтотОбъект[ИмяРеквизитаФормы] = ?(СтрокаТаблицыНастроек.Значение = Перечисления.Периодичность.Час, Перечисления.Периодичность.День, СтрокаТаблицыНастроек.Значение); 
		ИначеЕсли ИмяРеквизитаФормы = "ОтборАдресатСведенийТип" Тогда
			ЭтотОбъект[ИмяРеквизитаФормы] = ?(ЗначениеЗаполнено(СтрокаТаблицыНастроек.Значение), ?(СтрокаТаблицыНастроек.Значение = "ИзСписка", "Все", СтрокаТаблицыНастроек.Значение), "Все"); 
		Иначе 
			ЭтотОбъект[ИмяРеквизитаФормы] = СтрокаТаблицыНастроек.Значение;
		КонецЕсли;
	КонецЦикла;	
	
	УстановитьОтборПоСтруктурнойЕдинице();
	ОбновитьТумблерАвтообновленияМонитораПродаж();
	УстановитьСвойстваЭлементамПомощи();
	
	// ОбсужденияВызовСервера.ОбсужденияПоОбъектамМенеджера(ИсторияСобытий, ТекущийПользователь, ДатаПросмотраИсторииСобытий, КоличествоСобытий);
	//// ОбсужденияВызовСервера.ОбсужденияПоОбъектамМенеджера(ИсторияСобытий, Справочники.Сотрудники.НайтиПоКоду("000000009"), Дата('2019.09.23 10:45:25'), КоличествоСобытий);
	
	// Элементы.КнопкаПокаВасНеБыло.Заголовок = Нстр("ru='Пока Вас не было (';en='While you were gone ('") + Формат(КоличествоСобытий, "ЧН=0") + ")"; 
	Элементы.КнопкаПокаВасНеБыло.Видимость = Ложь;
	
	УстановитьСвойстваКнопкамТаблицыСортировкиKPI("ТаблицаСортировкиПоказателейВиджетовГруппаКнопок");	
	УстановитьСвойстваКнопкамТаблицыСортировкиKPI("ТаблицаСортировкиПоказателейKPIГруппаКнопок");
	
	УстановитьПериодАгрегированияИнформацииНаСервере();
	
	Элементы.ДекорацияСекунды.Заголовок = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Секунд", ПериодАвтообновления); // подготовить к переводу	
	
	УстановитьПривилегированныйРежим(Ложь);
		
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить места работы сотрудника
//
// Параметры:
//  Сотрудник				 - 	 - 
//  ТипВозвращаемыхДанных	 - 	 - 
//  СтруктурнаяЕдиница		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМестаРаботыСотрудника(Сотрудник, ТипВозвращаемыхДанных = "Список", СтруктурнаяЕдиница = Неопределено)
	
	СписокСтруктурныхЕдиниц = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(Сотрудник, ТипВозвращаемыхДанных, СтруктурнаяЕдиница);
	РольТекущегоПользователя = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Сотрудник, "Роль");
	Если РольТекущегоПользователя = Перечисления.РольПользователя.Врач
		ИЛИ РольТекущегоПользователя = Перечисления.РольПользователя.Руководитель
		ИЛИ РольТекущегоПользователя = Перечисления.РольПользователя.АдминистраторБазыДанных
		ИЛИ РольТекущегоПользователя = Перечисления.РольПользователя.Регистратура
		ИЛИ РольТекущегоПользователя = Перечисления.РольПользователя.ГлавныйВрач
		ИЛИ РольТекущегоПользователя = Перечисления.РольПользователя.Управляющий ИЛИ РольДоступна("ПолныеПрава") Тогда 
		
		СписокСтруктурныхЕдиниц.Вставить(0, Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), "Все клиники", СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), ?(СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), БиблиотекаКартинок.ЧекБоксПолный, БиблиотекаКартинок.Пустая));
		
	КонецЕсли;
	
	Возврат СписокСтруктурныхЕдиниц;
	
КонецФункции

&НаСервере
// Процедура - Установить отбор по структурной единице
//
// Параметры:
//  ОбновитьСвойстваКнопки	 - 	 - 
//  ОбновитьДанные			 - 	 - 
//
Процедура УстановитьОтборПоСтруктурнойЕдинице(ОбновитьСвойстваКнопки = Истина, ОбновитьДанные = Ложь)
	
	Если НЕ ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) И НЕ ОтборСтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка() Тогда 
		ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	УстановитьСвойстваОтображенияЭлементовСтруктутрнойЕдиницы();

	ОбновитьДинамическоеМенюОтборСотрудники();
	Если ОтборАдресатСведенийТип = "ИзСписка" Тогда
		ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
		ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, Неопределено); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
	ИначеЕсли ОтборАдресатСведенийТип = "Мои" Тогда 
		ОтборСотрудники = Новый Массив();
		ОтборСотрудники.Добавить(ТекущийПользователь);
	Иначе 
		ОтборСотрудники = Неопределено; // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина);
	КонецЕсли;
	
	// АктуализироватьТаблицуСортировкиПоказателейKPI(, , ОтборСотрудники);
	
	Если ОбновитьДанные Тогда 
		ОбновитьОбщиеСведения();
		ОбновитьСведенияПоСделкам();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить свойства отображения элементов структутрной единицы
//
Процедура УстановитьСвойстваОтображенияЭлементовСтруктутрнойЕдиницы()
	
	Если ПолучитьМестаРаботыСотрудника(ТекущийПользователь, , ОтборСтруктурнаяЕдиница).Количество() < 2 Тогда 
		Элементы.ГруппаКнопкиВыбораСтруктурнойЕдиницы.Видимость = Ложь;
	Иначе 
		Элементы.ГруппаКнопкиВыбораСтруктурнойЕдиницы.Видимость = Истина;
		Элементы.ВыбратьСтруктурнуюЕдиницу.Заголовок = ?(ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница), СокрЛП(Строка(ОтборСтруктурнаяЕдиница)), "Все клиники");
		КоличествоСимволов = СтрДлина(Элементы.ВыбратьСтруктурнуюЕдиницу.Заголовок);
		Если КоличествоСимволов <= 15 Тогда 
			Элементы.ВыбратьСтруктурнуюЕдиницу.МаксимальнаяШирина = Цел(КоличествоСимволов*1.15);
		ИначеЕсли КоличествоСимволов > 15 И КоличествоСимволов <= 20 Тогда
			Элементы.ВыбратьСтруктурнуюЕдиницу.МаксимальнаяШирина = Цел(КоличествоСимволов*1.1);
		ИначеЕсли КоличествоСимволов > 20 И КоличествоСимволов <= 30 Тогда 
			Элементы.ВыбратьСтруктурнуюЕдиницу.МаксимальнаяШирина = Цел(КоличествоСимволов*0.95);
		ИначеЕсли КоличествоСимволов > 30 И КоличествоСимволов <= 40 Тогда 
			Элементы.ВыбратьСтруктурнуюЕдиницу.МаксимальнаяШирина = Цел(КоличествоСимволов*0.75);
		Иначе 
			Элементы.ВыбратьСтруктурнуюЕдиницу.МаксимальнаяШирина = 35;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

