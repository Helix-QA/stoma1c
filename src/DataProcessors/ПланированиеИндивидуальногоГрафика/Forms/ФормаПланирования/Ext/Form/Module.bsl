// Получить представление интервалов времени
//
Функция ПолучитьПредставлениеСпискаИнтервалов(СписокИнтервала)
	
	ПредставлениеСпискаИнтервалов = "";
	КоличествоИнтервалов = СписокИнтервала.Количество();
	Для Каждого ЭлементС ИЗ СписокИнтервала Цикл
		ТегПереносаСтроки 		= ?(СписокИнтервала.Индекс(ЭлементС) + 1 = КоличествоИнтервалов, "", "<br>");
		ПредставлениеСпискаИнтервалов = ПредставлениеСпискаИнтервалов + ЭлементС.Представление + ТегПереносаСтроки;                         
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ПредставлениеСпискаИнтервалов) Тогда
	    Возврат ПредставлениеСпискаИнтервалов;
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
