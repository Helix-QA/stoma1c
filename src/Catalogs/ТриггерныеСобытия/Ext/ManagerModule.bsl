// Функция - Сформировать представление виртуальной группы
//
// Параметры:
//  ВиртуальнаяГруппаСобытий - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьПредставлениеВиртуальнойГруппы(ВиртуальнаяГруппаСобытий = "")
	
	ПредставлениеВиртуальнойГруппы = "";
	
	Если НЕ ЗначениеЗаполнено(СокрЛП(ВиртуальнаяГруппаСобытий)) Тогда 
		Возврат ПредставлениеВиртуальнойГруппы;
	КонецЕсли;
	
	Если СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПациентам" Тогда 
		ПредставлениеВиртуальнойГруппы = "Пациенты";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоКартам" Тогда
		ПредставлениеВиртуальнойГруппы = "Карты";
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЗаявкам" Тогда
		ПредставлениеВиртуальнойГруппы = "Заявки";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоВоронкам" Тогда
		ПредставлениеВиртуальнойГруппы = "Сделки";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЛистуОжидания" Тогда
		ПредставлениеВиртуальнойГруппы = "Планирование приёмов (лист ожидания)";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЗаписям" Тогда
		ПредставлениеВиртуальнойГруппы = "Записи на приём";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПриемам" Тогда
		ПредставлениеВиртуальнойГруппы = "Приёмы";
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПланамЛечения" Тогда
		ПредставлениеВиртуальнойГруппы = "Планы лечения";		
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПродажам" Тогда
		ПредставлениеВиртуальнойГруппы = "Продажи";
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЗадолженностям" Тогда
		ПредставлениеВиртуальнойГруппы = "Задолженности";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЛицевымСчетам" Тогда
		ПредставлениеВиртуальнойГруппы = "Лицевые счета";	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоБонуснымСчетам" Тогда
		ПредставлениеВиртуальнойГруппы = "Бонусные счета";	
	Иначе 
		ПредставлениеВиртуальнойГруппы = "Другое";	
	КонецЕсли;
	
	Возврат ПредставлениеВиртуальнойГруппы;
	
КонецФункции

// Функция - Определить порядковый номер виртуальной группы
//
// Параметры:
//  ВиртуальнаяГруппаСобытий - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОпределитьПорядковыйНомерВиртуальнойГруппы(ВиртуальнаяГруппаСобытий = "")
	
	ПорядковыйНомерВиртуальнойГруппы = 0;
	
	Если НЕ ЗначениеЗаполнено(СокрЛП(ВиртуальнаяГруппаСобытий)) Тогда 
		Возврат ПорядковыйНомерВиртуальнойГруппы;
	КонецЕсли;
	
	Если СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПациентам" Тогда 
		ПорядковыйНомерВиртуальнойГруппы = 1;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоКартам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 2;
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЗаявкам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 3;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоВоронкам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 4;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЛистуОжидания" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 5;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЗаписям" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 6;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПриемам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 7;
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПланамЛечения" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 8;			
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоПродажам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 9;
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЗадолженностям" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 10;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоЛицевымСчетам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 11;	
	ИначеЕсли СокрЛП(ВиртуальнаяГруппаСобытий) = "СобытияПоБонуснымСчетам" Тогда
		ПорядковыйНомерВиртуальнойГруппы = 12;	
	Иначе 
		ПорядковыйНомерВиртуальнойГруппы = 99;	
	КонецЕсли;
	
	Возврат ПорядковыйНомерВиртуальнойГруппы;
	
КонецФункции

// Функция - Получить массив триггеров
//
// Параметры:
//  ВиртуальнаяГруппаСобытий			 - 	 - 
//  ГибридныйВариантИнициацииТриггера	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивТриггеров(ВиртуальнаяГруппаСобытий = "", ГибридныйВариантИнициацииТриггера = Неопределено) Экспорт 
	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если ЗначениеЗаполнено(ВиртуальнаяГруппаСобытий) Тогда
		Если ГибридныйВариантИнициацииТриггера <> Неопределено Тогда 
			Возврат ТаблицуВсехВариантовУсловийТриггерныхСобытий.Скопировать(Новый Структура("ВиртуальнаяГруппаСобытий, ГибридныйВариантИнициацииТриггера", ВиртуальнаяГруппаСобытий, ГибридныйВариантИнициацииТриггера), "ВариантыУсловийТриггерныхСобытий").ВыгрузитьКолонку("ВариантыУсловийТриггерныхСобытий");
		Иначе 
			Возврат ТаблицуВсехВариантовУсловийТриггерныхСобытий.Скопировать(Новый Структура("ВиртуальнаяГруппаСобытий", ВиртуальнаяГруппаСобытий), "ВариантыУсловийТриггерныхСобытий").ВыгрузитьКолонку("ВариантыУсловийТриггерныхСобытий");
		КонецЕсли;	
	Иначе
		Если ГибридныйВариантИнициацииТриггера <> Неопределено Тогда 
			Возврат ТаблицуВсехВариантовУсловийТриггерныхСобытий.Скопировать(Новый Структура("ГибридныйВариантИнициацииТриггера", ГибридныйВариантИнициацииТриггера), "ВариантыУсловийТриггерныхСобытий").ВыгрузитьКолонку("ВариантыУсловийТриггерныхСобытий");
		Иначе 
			Возврат ТаблицуВсехВариантовУсловийТриггерныхСобытий.ВыгрузитьКолонку("ВариантыУсловийТриггерныхСобытий");
		КонецЕсли;	
	КонецЕсли;
	
КонецФункции

