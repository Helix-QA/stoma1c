// Функция вернет идентификатор строки элемента или группы
//
Функция ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ТаблицаПодбора, ВернутьГруппу = Ложь)
	
	ВерхнийУровень = ТаблицаПодбора.ПолучитьЭлементы();
	
	Для Каждого ЭлементУровня ИЗ ВерхнийУровень Цикл 
		
		Для НомерСЕ = 1 по МестаРаботы.Количество() Цикл 
			
			Если ЭлементУровня.ЭтоГруппа и ЭлементУровня["СтруктурнаяЕдиница"+НомерСЕ] Тогда
				
				Если ВернутьГруппу Тогда
					Возврат ЭлементУровня.ПолучитьИдентификатор();
				Иначе
					Рез = ПолучитьИдентификаторПервойНоменклатурыВспискеПодбора(ЭлементУровня); 
					Если Рез <> Неопределено Тогда
						Возврат Рез;
					КонецЕсли;				
				КонецЕсли;
				
			ИначеЕсли ЭлементУровня["СтруктурнаяЕдиница"+НомерСЕ] Тогда
				
				Возврат ЭлементУровня.ПолучитьИдентификатор();
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Неопределено; 
	
КонецФункции

&НаКлиенте
// Процедура, выполняет установку флагов на элменеты.
//
Процедура УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки)
	
	Флаг 		 = ТекущиеДанные[ИмяКолонки];
	ДанныеДерева = ТекущиеДанные.ПолучитьЭлементы();
	
	Для Каждого СтрокаДерева из ДанныеДерева Цикл
		
		Если Фильтр = 1 Тогда
			
			Видимость = Ложь;
			
			Для НомерСЕ = 1 по МестаРаботы.Количество() Цикл
				Если СтрокаДерева["СтруктурнаяЕдиница"+НомерСЕ] Тогда
					Видимость = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
		Иначе
			Видимость = Истина;
		КонецЕсли;
		
		Если Видимость Тогда
			СтрокаДерева[ИмяКолонки] = Флаг;
		КонецЕсли;
		
		Если СтрокаДерева.ЭтоГруппа Тогда
			УстановитьФлагиНаЭлементы(СтрокаДерева, ИмяКолонки);
		КонецЕсли;
		
	КонецЦикла;		
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает флаги на группы.
//
Процедура УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, ЭтоРодитель = Ложь)
	
	Если ЭтоРодитель Тогда
		Родитель = ТекущиеДанные;
	Иначе
		Родитель = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	
	Если Родитель = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДерева = Родитель.ПолучитьЭлементы();
	
	КоличествоВыбранных = 0;
	Для Каждого СтрокаДерева из ДанныеДерева Цикл
		
		Если СтрокаДерева[ИмяКолонки] = 1 Тогда
			КоличествоВыбранных = КоличествоВыбранных + 1;
		ИначеЕсли СтрокаДерева[ИмяКолонки] = 2 Тогда
			КоличествоВыбранных = -1;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если КоличествоВыбранных = ДанныеДерева.Количество() Тогда
		Родитель[ИмяКолонки] = 1;
	ИначеЕсли КоличествоВыбранных = 0 Тогда
		Родитель[ИмяКолонки] = 0;
	Иначе
		Родитель[ИмяКолонки] = 2;
	КонецЕсли;		
	
	УстановитьФлагиНаГруппы(Родитель, ИмяКолонки);
	
КонецПроцедуры

&НаСервере
// Процедура, выполянет сохранение значений в регистр сведений.
//
Процедура СохранитьЗначения(Знач ТаблицаНоменклатуры, Сотрудник)
	
	Таблица = ДанныеФормыВЗначение(ТаблицаНоменклатуры, Тип("ТаблицаЗначений"));
	
	Если Сотрудник.ЭтоГруппа = Истина Тогда
		
		Сотрудники = ПолучитьСотрудниковГруппы(Сотрудник, Истина);
		Для Каждого Работник из Сотрудники Цикл
			
			// Отбираем номенклатуру относящуюся к определенному сотруднику.
			НоменклатураСотрудника = ПолучитьТаблицуНоменклатурыСотрудника(Таблица, Работник);
			
			НаборЗаписей = РегистрыСведений.УслугиСотрудника.СоздатьНаборЗаписей();
			НаборЗаписей.Загрузить(НоменклатураСотрудника);
			НаборЗаписей.Отбор.Сотрудник.Использование = Истина;
			НаборЗаписей.Отбор.Сотрудник.Значение = Работник;
			НаборЗаписей.Записать(Истина);
			
		КонецЦикла;
		
	Иначе
		
		НаборЗаписей = РегистрыСведений.УслугиСотрудника.СоздатьНаборЗаписей();			
		НаборЗаписей.Загрузить(Таблица);
		НаборЗаписей.Отбор.Сотрудник.Использование = Истина;
		НаборЗаписей.Отбор.Сотрудник.Значение = Сотрудник;
		НаборЗаписей.Записать(Истина);
		
	КонецЕсли;
	
КонецПроцедуры

