&НаСервере
// Процедура - обработчик события ПриСозданииНаСервере формы.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	БуферОбмена             = Новый Структура("Буфер, ПризнакВырезать");
	ПЗФильтрГрафикаОбновить = Истина;
	Объект.Дата = ТекущаяДата();
	Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ТекущийПользователь = ПараметрыСеанса.ТекущийПользователь;
	ТекущийСотрудник 	= ПараметрыСеанса.ТекущийСотрудник;
	УстановитьПривилегированныйРежим(Истина);
	ГруппаКонтрагентов = Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);
	УстановитьПривилегированныйРежим(Ложь);
	ЕстьПравоРедактированияГрафикаРаботСотрудника = РольДоступна("ПолныеПрава") ИЛИ (РольДоступна("ДобавлениеИзменениеГрафикаРаботыСотрудников") И НЕ ЭтоЖурналЗаписиПоРасширеннымНастройкам);
	// Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.СестраХозяйка Тогда
	//	Элементы.ГруппаЛеваяКолонка.Видимость = Ложь;
	//	Элементы.ГруппаКлиент.Видимость = Ложь;
	//	Элементы.ИнформацияКлиента.Видимость = Ложь;
	//	Элементы.ГруппаОтчетыЗапасы.Видимость = Истина;
	//	Элементы.ГруппаДействия.Видимость = Ложь;
	//	Элементы.ГруппаОтчеты.Видимость = Ложь;
	//	Элементы.ГруппаКасса.Видимость = Ложь;
	// ИначеЕсли ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Бухгалтер Тогда
	//	Элементы.ГруппаЛеваяКолонка.Видимость = Ложь;
	//	Элементы.ГруппаКлиент.Видимость = Ложь;
	//	Элементы.ИнформацияКлиента.Видимость = Ложь;
	//	Элементы.ГруппаОтчетыБухгалтера.Видимость = Истина;	
	//	Элементы.ГруппаДействия.Видимость = Ложь;
	//	Элементы.ГруппаОтчеты.Видимость = Ложь;
	//	Элементы.ГруппаКасса.Видимость = Ложь;
	// ИначеЕсли ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач  или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач Тогда
	//	Элементы.ГруппаОтчетыВрача.Видимость = Истина;
	// КонецЕсли; 
	
	ЭтаФорма.Заголовок = "Журнал записи";// ПараметрыСеанса.ТекущийПользователь.РольПользователя;
	
	Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач или ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач Тогда		
		Элементы.ЖурналПЗОтборПоСотрудникамРежимФильтра.СписокВыбора.Очистить();
		Элементы.ЖурналПЗОтборПоСотрудникамРежимФильтра.СписокВыбора.Добавить(0, "Моя запись");
		
		НеОтображатьОбщееРасписание = Пользователи.ПолучитьЗначениеПраваПользователя("НеОтображатьОбщееРасписание");
		Если НеОтображатьОбщееРасписание = Ложь Тогда			
			Элементы.ЖурналПЗОтборПоСотрудникамРежимФильтра.СписокВыбора.Добавить(1, "Общая запись");
		КонецЕсли;	
		ЭтоВрач = Истина;
		Врач = ПараметрыСеанса.ТекущийПользователь.Сотрудник;			
		ЭтоГлавВрач = (ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.ГлавныйВрач);
	КонецЕсли;
	
	// --------------------------------------------------------------
	ВернутьДоступныеДляПользователяСЕ();
	
	Параметры.Свойство("Контрагент"					, ЭтотОбъект.КлиентДляОткрытия);
	Параметры.Свойство("ЗаписьИзДругойФормы"		, ЭтотОбъект.ЗаписьИзКарточкиКлиента);
	Параметры.Свойство("ЗакрытьПриСозданииЗаписи"	, ЭтотОбъект.ЗаписьИзКарточкиКлиента); 
	
	Параметры.Свойство("ИсточникЗаписи"		, ЭтотОбъект.ИсточникЗаписи);
	
	Параметры.Свойство("Сделка"                           , ЭтотОбъект.Сделка);
	Параметры.Свойство("Заявка"                           , ЭтотОбъект.Заявка);
	Параметры.Свойство("ВнутреннийНомерСотрудника"	      , ЭтотОбъект.ВнутреннийНомерСотрудника);
	Параметры.Свойство("IDЗвонка"						  , ЭтотОбъект.IDЗвонка);

	Если ЗначениеЗаполнено(ЭтотОбъект.ИсточникЗаписи) И ТипЗнч(ЭтотОбъект.ИсточникЗаписи) = Тип("Строка") Тогда
		ЭтотОбъект.ИсточникЗаписи = ПолучитьИсточникЗаписиПоИмени(ЭтотОбъект.ИсточникЗаписи); 
	КонецЕсли;
	
	// Получение разрешение монитора клиента.
	ПолучитьРазрешениеМонитораКлиента();

	ЭтотОбъект.ЦветаЭлементов = Новый Структура;
	
	ЦветаЭлементов.Вставить("ЦветФона"                   , Новый Цвет(255, 255, 255));
	ЦветаЭлементов.Вставить("ЦветФонаВыбранного"         , Новый Цвет(218, 230, 244));
	ЦветаЭлементов.Вставить("ЦветТекста"                 , Новый Цвет(51,  102, 187));
	ЦветаЭлементов.Вставить("ЦветТекстаВыбранного"       , Новый Цвет(64,  64,  64));
	ЦветаЭлементов.Вставить("ЦветТекстаНеактивногоВизита", Новый Цвет(128, 128, 128));
	ЦветаЭлементов.Вставить("ЦветРамкиАктивногоВизита"   , WebЦвета.Красный);
	
	Если ПроверитьНаличиеСотрудниковПоГрафику() Тогда	
		ЭтотОбъект.ПЗОтборПоСотрудникамРежимФильтра = 1;
	Иначе
		ЭтотОбъект.ПЗОтборПоСотрудникамРежимФильтра = 0;
	КонецЕсли;
	
	ИдентификацияПриложенияGoogle = Константы.ИдентификацияПриложенияGoogle.Получить();
	Если ЗначениеЗаполнено(ИдентификацияПриложенияGoogle) Тогда
		СинхронизацияКалендаряGoogle = РегистрыСведений.СеансовыеДанныеGoogle.ОбластьДоступаGoogleКалендарьВключена();
	Иначе
		СинхронизацияКалендаряGoogle = Ложь;
	КонецЕсли; 
	Элементы.СинхронизироватьCGoogle.Видимость = СинхронизацияКалендаряGoogle;
	
	УстановитьВидимостьЭлементовНаСогласованиеСтраховой(); 
	ПроверкаПодключеннойТелефонии();
	ДоступностьСменыСЕ();

	ЭтотОбъект.ЗакрыватьПриИзмененииСобытия = ?(Параметры.Свойство("ЗакрыватьПриИзмененииСобытия"), Параметры.ЗакрыватьПриИзмененииСобытия, Истина);
	
	ДобавитьЗаписьОбОткрытииЗакрытииФормы(ТекущийСотрудник, ТекущаяДатаСеанса(), Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ПриОткрытии(Отказ)
	
	ВыполнятьАктивизациюСтрокиТекущихКлиентов     = Истина;
	ВводПриемаЧерезКонтекстноеМеню                = Ложь;
	СтраницаРаботаСКлиентомОбновлена              = Ложь;
	СтраницаЖурналПредварительнойЗаписиОбновлена  = Ложь;
	ТаблицаОбслуживаниеКлиентовПерваяАктивация    = Ложь;
	ТаблицаНЕ_ОбслуживаниеКлиентовПерваяАктивация = Ложь;
	ПЗРасшифровкаСтатусовОбновить                 = Истина;
	РазрешениеЭкрана                              = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьТекущееРазрешениеЭкрана();
	
	ОбновлениеСтраницыЖурналПредварительнойЗаписи(,Истина);
	
	// МеханизмВнешнегоОборудования
	МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиентаБезМодальногоВызова(Новый ОписаниеОповещения("ОбновитьРабочееМестоКлиентаЗавершение", ЭтотОбъект));
	// Конец МеханизмВнешнегоОборудования 
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик оповещения формы.
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзмененоСобытие" Тогда
		Если ЭтотОбъект.ЗаписьИзКарточкиКлиента И ЭтотОбъект.ЗакрыватьПриИзмененииСобытия = Истина Тогда
			ЭтаФорма.Закрыть();
		КонецЕсли;  
		
		ПериодЗанятСобытиями = Ложь;
		Если ТипЗнч(Параметр) = Тип("ДокументСсылка.Событие") Тогда
			ДопПараметры = ПолучитьДанныеСобытияПоВремени(Параметр);
			ДатаНачала		= ?(ДопПараметры.Свойство("ДатаНачала"), ДопПараметры.ДатаНачала, Дата(1,1,1)); 	
			ДатаОкончания	= ?(ДопПараметры.Свойство("ДатаОкончания"), ДопПараметры.ДатаОкончания, Дата(1,1,1));
			Сотрудник		= ?(ДопПараметры.Свойство("Сотрудник"), ДопПараметры.Сотрудник, Неопределено);
			Помещение		= ?(ДопПараметры.Свойство("Помещение"), ДопПараметры.Помещение, Неопределено);
			Событие			= ?(ДопПараметры.Свойство("Событие"), Параметр, Неопределено);	
			ПериодЗанятСобытиями = ПроверитьНаличиеСобытийВВыбранномПериоде(ДатаНачала, ДатаОкончания, Объект.СтруктурнаяЕдиница, Сотрудник, Помещение, Событие);
		КонецЕсли;  
		
		Если ПериодЗанятСобытиями = Истина Тогда		
			ОповещениеНовое = Новый ОписаниеОповещения("ОбработчикДиалогаВыбораДействия", ЭтотОбъект);				
			ДопПараметры.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
			ДопПараметры.Вставить("ИнтервалЗаписи", ИнтервалГрафика);
			
			ОткрытьФорму("Обработка.РабочийКалендарь.Форма.ФормаДиалогаПереносаПриемов", ДопПараметры, ЭтотОбъект,,,, ОповещениеНовое, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
			
		Иначе
						
			Если БуферОбменаЗаполненСобытием(ЭтотОбъект.БуферОбмена, Ложь).Результат Тогда
				БуферОбмена.ПризнакВырезать 			= Ложь;
				БуферОбмена.Буфер           			= Неопределено;		
			КонецЕсли;
			ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента = Неопределено;
			
			Оповестить("ОбновитьРабочийСтол"); 
			
			ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);		
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ИзмененаДолжность" ИЛИ ИмяСобытия = "ИзмененоПомещение" ИЛИ ИмяСобытия = "ОБНОВИТЬ_ГРАФИК_ПЗ"  Тогда
		ПЗФильтрГрафикаОбновить = Истина;
		ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);				
	ИначеЕсли ИмяСобытия = "ИзмененаСтруктурнаяЕдиница" Тогда
		Объект.СтруктурнаяЕдиница = Параметр.ТекущаяСтруктурнаяЕдиница;
		// Если Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаРабочийСтол Тогда
		//	ОбновлениеСтраницыРаботаСклиентом();
		// ИначеЕсли Элементы.ГлобальнаяГруппа.ТекущаяСтраница = Элементы.ГруппаПредварительнаяЗапись Тогда
			ПЗФильтрГрафикаОбновить = Истина;
			ОбновлениеСтраницыЖурналПредварительнойЗаписи();
		// КонецЕсли;		
	ИначеЕсли ИмяСобытия = "ИзмененаСтруктурнаяЕдиницаВЗакладках" Тогда
		СтраницаРаботаСКлиентомОбновлена = Ложь;
		СтраницаЖурналПредварительнойЗаписиОбновлена = Ложь;
		ПриСозданииНаСервере(Ложь, Истина);
		ПриОткрытии(Ложь);
		
	ИначеЕсли ИмяСобытия = "ОбновлениеРабочегоСтола" Тогда
		
		ТаблицаОбслуживаниеКлиентовПерваяАктивация = Ложь;
		ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);
		
	ИначеЕсли ИмяСобытия = "СозданиеСобытияСКонтрагентом" Тогда
		
		Если Параметр.Свойство("Контрагент") Тогда
			ЭтотОбъект.КлиентДляОткрытия = Параметр.Контрагент;
		ИначеЕсли Параметр.Свойство("ЗаявкаОснование") тогда
			ЭтотОбъект.Заявка = Параметр.ЗаявкаОснование;
		КонецЕсли;
		
		Если Параметр.Свойство("КонтролироватьЗаписьПациентаПоСотруднику")
			И Параметр.КонтролироватьЗаписьПациентаПоСотруднику = Истина Тогда
			
			Параметр.Свойство("СотрудникПриКонтролеЗаписиПациента", ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента);
		Иначе
			ЭтотОбъект.СотрудникПриКонтролеЗаписиПациента = Неопределено;		
		КонецЕсли;
		
		Если Параметр.Свойство("ВнутреннийНомерСотрудника") Тогда
			ЭтотОбъект.ВнутреннийНомерСотрудника = Параметр.ВнутреннийНомерСотрудника;
		КонецЕсли;
		
		Если Параметр.Свойство("IDЗвонка") Тогда
			ЭтотОбъект.IDЗвонка = Параметр.IDЗвонка;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьСогласованияСтраховыхУслуг"
		ИЛИ ИмяСобытия = "ПоказатьОповещениеУслугиНаСогласование" Тогда 
		
		УстановитьВидимостьЭлементовНаСогласованиеСтраховой();
	КонецЕсли;
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование"
		И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			// Преобразуем предварительно к ожидаемому формату
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			
			ПолученыШтрихкоды(Данные);
		КонецЕсли;
	КонецЕсли;
	
	Если Источник = "ВнешнееОборудование"
		И ВводДоступен() Тогда
		Если ИмяСобытия = "TracksData" Тогда
			Если Параметр[1] = Неопределено Тогда
				ПолученКодКарты(Параметр[0], Параметр[0]);
			Иначе
				ПолученКодКарты(Параметр[0], Параметр[1][1]);
			КонецЕсли;   			
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновлениеСтраницыЖурналПредварительнойЗаписи" Тогда
		
		Если ЗначениеЗаполнено(Параметр) 
			И ТипЗнч(Параметр) = Тип("Структура") 
			И Параметр.Свойство("ИнтервалГрафика", ИнтервалГрафика) Тогда 
			
			ОбновлениеСтраницыЖурналПредварительнойЗаписи(, Истина);
		Иначе 
			ОбновлениеСтраницыЖурналПредварительнойЗаписи();
		КонецЕсли;
		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере  
// Процедура, обработчик события "ПередЗагрузкойДанныхИзНастроекНаСервере"
//
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	Если ЭтотОбъект.ПЗОтборПоСотрудникамРежимФильтра = 1 Тогда
		Настройки.Вставить("ПЗОтборПоСотрудникамРежимФильтра", 1);
		Настройки.Вставить("ПЗФильтраГрафикаРежим", 0);
	Иначе
		Настройки.Вставить("ПЗОтборПоСотрудникамРежимФильтра", 0);
		Настройки.Вставить("ПЗФильтраГрафикаРежим", 0);
	КонецЕсли;

	Если ЭтоВрач Тогда
		Настройки.Удалить("ПЗОтборПоСотрудникамРежимФильтра");
	КонецЕсли;
	
КонецПроцедуры

