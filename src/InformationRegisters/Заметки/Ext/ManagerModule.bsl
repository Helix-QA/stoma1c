
#Область СлужебныеПроцедурыИФункции

// Процедура - Закрепить открепить заметку.
//
// Параметры:
//  ИдЗаметки	 - 	 - 
//  Закреплена	 - 	 - 
//
Процедура ЗакрепитьОткрепитьЗаметку(ИдЗаметки, Закреплена) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Заметки.Объект КАК Объект,
	|	Заметки.АктивностьЗаметки КАК АктивностьЗаметки,
	|	Заметки.Автор КАК Автор,
	|	Заметки.Период КАК Период,
	|	Заметки.Заметка КАК Заметка,
	|	Заметки.Сделка КАК Сделка,
	|	&Закреплена КАК Закреплена,
	|	Заметки.ИД КАК ИД
	|ИЗ
	|	РегистрСведений.Заметки КАК Заметки
	|ГДЕ
	|	Заметки.ИД = &ИДЗаметки";
	
	Запрос.УстановитьПараметр("ИДЗаметки"	, ИдЗаметки);
	Запрос.УстановитьПараметр("Закреплена"	, Закреплена);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		МенеджерЗаписи = РегистрыСведений.Заметки.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		МенеджерЗаписи.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти