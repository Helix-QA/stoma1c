// Процедура, удаляет элементы формы связанные с нормами списания.
// 
Процедура УдалитьЭлементыФормыСоставНабора(ИДСтрокиДанных)
	
	// Ищем строку в данных по ИД
	СтрокаДанных = Объект.СоставНабора.НайтиПоИдентификатору(ИДСтрокиДанных);	
	Если СтрокаДанных <> Неопределено Тогда
		
		// Удаляем элементы
		Для Каждого СтрокаТЗ Из Объект.СоставНабора Цикл
			Элементы.Удалить(Элементы["НоменклатураСН_" + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы["КоличествоСН_" + СтрокаТЗ.ПолучитьИдентификатор()]);			
			Элементы.Удалить(Элементы["УдалитьСН_" + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы["ГруппаКомандаУдалитьСН_" + СтрокаТЗ.ПолучитьИдентификатор()]);
			Элементы.Удалить(Элементы["ГруппаСтрокаСН_" + СтрокаТЗ.ПолучитьИдентификатор()]);
		КонецЦикла;
		
		// Удалить строку из данных
		Объект.СоставНабора.Удалить(СтрокаДанных);
		
		// Создаем элементы взамен удаленных на пред. этапе	  
		Для Каждого СтрокаТЗ Из Объект.СоставНабора Цикл
			ДобавитьЭлементыФормыСоставНабора(СтрокаТЗ.ПолучитьИдентификатор());				
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

