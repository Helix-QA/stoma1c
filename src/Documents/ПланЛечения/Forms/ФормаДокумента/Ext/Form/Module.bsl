		Если Поле.Имя = "ТаблицаЛечениеНоменклатура" и ЗначениеЗаполнено(ТекущийЭлемент.ТекущиеДанные.Номенклатура) Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,ТекущийЭлемент.ТекущиеДанные.Номенклатура);
		ИначеЕсли Поле.Имя = "ТаблицаЛечениеПрием" и ЗначениеЗаполнено(ТекущийЭлемент.ТекущиеДанные.Прием) Тогда
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,ТекущийЭлемент.ТекущиеДанные.Прием);
		КонецЕсли;
	КонецЕсли;
	
