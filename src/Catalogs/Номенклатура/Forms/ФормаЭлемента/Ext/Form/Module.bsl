Процедура ЗаполнитьСписокВыбораВидаНоминалаСертификата()
	
	Элементы.ВидНоминала.СписокВыбора.Очистить();
	Элементы.ВидНоминала.СписокВыбора.Добавить(Ложь, "Фиксированный");
	Если Элементы.ВестиСерийныеНомера.Видимость И Объект.ИспользоватьПартии Тогда
		Элементы.ВидНоминала.СписокВыбора.Добавить(Истина, "Определяется при продаже");
	Иначе
		Объект.ВидНоминала = Ложь;
	КонецЕсли;
	Элементы.ВидНоминала.ОбновитьТекстРедактирования();
	Элементы.Номинал.Доступность = НЕ Объект.ВидНоминала;
	
