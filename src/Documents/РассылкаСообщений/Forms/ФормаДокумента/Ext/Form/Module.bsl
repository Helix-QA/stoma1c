// Процедура - Заполнить получателей push уведомления.
//
// Параметры:
//  МассивКлиентов	 - 	 - 
//
Процедура ЗаполнитьПолучателейPushУведомленияWallet(МассивКлиентов = Неопределено)
	
	Запрос = Новый Запрос(    
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Карты.ВладелецКарты КАК Получатель
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	НЕ Карты.ПометкаУдаления
	|	И НЕ Карты.Заблокирована
	|	И Карты.ТипКода = ЗНАЧЕНИЕ(Перечисление.ВидыКарт.Wallet)
	|	И Карты.ВнутреннийКодКарты <> """"
	|	И Карты.КоличествоУстановок <> 0
