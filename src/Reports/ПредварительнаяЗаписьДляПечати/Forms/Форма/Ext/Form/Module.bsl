// Функия возвращает список документов на предварительную запись
//
Функция ВыбратьДокументы(ДатаНачала, ДатаОкончания = Неопределено, Режим)
	
	// Получим предварительные записи
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СобытиеУслуги.Ссылка,
	               |	СобытиеУслуги.ДатаНачала,
	               |	СобытиеУслуги.ДатаОкончания,
	               |	СобытиеУслуги.Сотрудник,
	               |	СобытиеУслуги.Номенклатура,
	               |	СобытиеУслуги.Ссылка.Контрагент КАК Контрагент,
	               |	СобытиеУслуги.Ссылка.Контрагент.Телефон КАК Телефон,
	               |	СобытиеУслуги.Ссылка.Комментарий КАК Комментарий,
	               |	РАЗНОСТЬДАТ(СобытиеУслуги.ДатаНачала, СобытиеУслуги.ДатаОкончания, МИНУТА) КАК Длительность
	               |ИЗ
	               |	Документ.Событие.Услуги КАК СобытиеУслуги
	               |ГДЕ
	               |	СобытиеУслуги.ДатаНачала >= &ДатаНачала
	               |	И СобытиеУслуги.ДатаНачала <= &ДатаОкончания
	               |	И СобытиеУслуги.Ссылка.Проведен = ИСТИНА
	               |	И СобытиеУслуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И ВЫБОР
	               |			КОГДА &Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	               |				ТОГДА СобытиеУслуги.Сотрудник = &Сотрудник
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И СобытиеУслуги.Ссылка.ПричинаОтмены = ЗНАЧЕНИЕ(Справочник.ПричиныОтменыЗаписи.ПустаяСсылка)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СобытиеУслуги.ДатаОкончания,
	               |	СобытиеУслуги.Ссылка,
	               |	СобытиеУслуги.Номенклатура,
	               |	СобытиеУслуги.Сотрудник,
	               |	СобытиеУслуги.ДатаНачала,
	               |	СобытиеУслуги.Ссылка.Контрагент,
	               |	СобытиеУслуги.Ссылка.Контрагент.Телефон,
	               |	СобытиеУслуги.Ссылка.Комментарий";
	
	Если ДатаОкончания = Неопределено Тогда 				   
		ДатаОкончания = КонецДня(ДатаНачала);
	КонецЕсли;
	
	Запрос.Параметры.Вставить("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	Запрос.Параметры.Вставить("Сотрудник"			, Сотрудник);
	Запрос.Параметры.Вставить("ДатаНачала"			, ДатаНачала);
	Запрос.Параметры.Вставить("ДатаОкончания"		, КонецДня(ДатаОкончания)); 
	
	ТаблицаПредварительныхЗаписей = Запрос.Выполнить().Выгрузить();	
	
	// Для режима "День" дополним таблицу некоторыми параметрами
	Если ТаблицаПредварительныхЗаписей.Количество() > 0 Тогда 
		Если Режим = "День" Тогда			
			// Подготовим параметры
			МассивКонтрагентов 		= Новый Массив;
			МассивСтруктурныхЕдиниц = Новый Массив;
			МассивСтруктурныхЕдиниц.Добавить(СтруктурнаяЕдиница);
			МассивКонтрагентов = ТаблицаПредварительныхЗаписей.Скопировать();
			МассивКонтрагентов.Свернуть("Контрагент");
			МассивКонтрагентов = МассивКонтрагентов.ВыгрузитьКолонку("Контрагент"); 
			
			// Получим статусы контрагентов
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	Статусы.Контрагент КАК Контрагент,
			               |	Статусы.Статус КАК Статус
			               |ИЗ
			               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, Контрагент В (&МассивКонтрагентов)) КАК Статусы";
			
			Запрос.УстановитьПараметр("МассивКонтрагентов"		, МассивКонтрагентов);
			
			ТаблицаСтатусов = Запрос.Выполнить().Выгрузить();
			
			// Получим незавершшенные наряд-заказы контрагентов			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	ВложенныйЗапрос.Ссылка КАК НарядЗаказ,
			               |	ВложенныйЗапрос.Ссылка.Контрагент КАК Контрагент,
			               |	ВложенныйЗапрос.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
			               |	ВложенныйЗапрос.Ссылка.Дата КАК Дата,
			               |	"""" КАК СтрокаКлюч
			               |ИЗ
			               |	(ВЫБРАТЬ
			               |		НарядЗаказЗапасы.Ссылка КАК Ссылка
			               |	ИЗ
			               |		Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
			               |	ГДЕ
			               |		НарядЗаказЗапасы.Ссылка.Проведен
			               |		И НЕ НарядЗаказЗапасы.Ссылка.ПометкаУдаления
			               |		И (НарядЗаказЗапасы.Прием = ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
			               |				ИЛИ НарядЗаказЗапасы.Прием = НЕОПРЕДЕЛЕНО
			               |				ИЛИ НарядЗаказЗапасы.Прием = NULL)
			               |		И НарядЗаказЗапасы.Ссылка.Контрагент В(&МассивКонтрагентов)
			               |		И НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
			               |	
			               |	СГРУППИРОВАТЬ ПО
			               |		НарядЗаказЗапасы.Ссылка) КАК ВложенныйЗапрос
			               |
			               |УПОРЯДОЧИТЬ ПО
			               |	Дата";
			
			Запрос.УстановитьПараметр("МассивКонтрагентов"		, МассивКонтрагентов);
			Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц"	, МассивСтруктурныхЕдиниц);		
			
			ТаблицаНезавершенныхНарядЗаказов = Запрос.Выполнить().Выгрузить();
			// Дополним таблицу полученными данными
			ТаблицаПредварительныхЗаписей.Колонки.Добавить("СтатусКонтрагента");
			ТаблицаПредварительныхЗаписей.Колонки.Добавить("МассивНезавершенныхНарядЗаказов");
			Для Каждого Событие Из ТаблицаПредварительныхЗаписей Цикл 
				СтрокаТаблицыСтатусов = ТаблицаСтатусов.Найти(Событие.Контрагент, "Контрагент");
				Событие.СтатусКонтрагента 				= ?(СтрокаТаблицыСтатусов <> Неопределено, СтрокаТаблицыСтатусов.Статус, "");
				Событие.МассивНезавершенныхНарядЗаказов = ТаблицаНезавершенныхНарядЗаказов.НайтиСтроки(Новый Структура("Контрагент", Событие.Контрагент)) 
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТаблицаПредварительныхЗаписей;
	
КонецФункции

