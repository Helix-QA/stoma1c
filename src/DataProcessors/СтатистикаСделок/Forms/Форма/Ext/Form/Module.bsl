// Процедура - Установить форматы временных элементов формы.
//
Функция ПолучитьВремяВФорматеПродолжительности(КоличествоМинут)
	
		
	Если КоличествоМинут = Неопределено Или КоличествоМинут = 0 Тогда
		Возврат "0 минут";
	КонецЕсли;
	
	Если КоличествоМинут >= 1440 Тогда // - дней - часов
		КоличествоДней = Цел(КоличествоМинут / 1440);
		КоличествоЧасов = Цел(Окр(((КоличествоМинут - (КоличествоДней * 1440))/60), 0)); 
		
		Если КоличествоДней > 0 Тогда		
			ДниСтрокой = СтрокаСЧислом(";%1 день;;%1 дня;%1 дней;%1 дня", КоличествоДней, ВидЧисловогоЗначения.Количественное, "L=ru");
		Иначе
			ДниСтрокой = "";
		КонецЕсли;
		
		Если КоличествоЧасов > 0 Тогда
			ЧасыСтрокой = СтрокаСЧислом(";%1 час;%1 часов;%1 часа;%1 часов;%1 часа", КоличествоЧасов, ВидЧисловогоЗначения.Количественное, "L=ru");
		Иначе
			ЧасыСтрокой = "";
		КонецЕсли;
	
		Возврат СтрШаблон("%1 %2", ДниСтрокой, ЧасыСтрокой); 
		
	ИначеЕсли КоличествоМинут >= 60 Тогда 
		
		КоличествоЧасов = Цел(КоличествоМинут / 60); 
		КоличествоМинут = Цел((КоличествоМинут - (КоличествоЧасов * 60)));
		
		Если КоличествоЧасов > 0 Тогда
			ЧасыСтрокой = СтрокаСЧислом(";%1 час;%1 часов;%1 часа;%1 часов;%1 часа", КоличествоЧасов, ВидЧисловогоЗначения.Количественное, "L=ru");
		Иначе
			ЧасыСтрокой = "";
		КонецЕсли;
		
		Если КоличествоМинут > 0 Тогда
			МинутыСтрокой = СтрокаСЧислом(";%1 минута;%1 минут;%1 минуты;%1 минут;%1 минуты", КоличествоМинут, ВидЧисловогоЗначения.Количественное, "L=ru");
		Иначе
			МинутыСтрокой = "";
		КонецЕсли;
	
		Возврат СтрШаблон("%1 %2", ЧасыСтрокой, МинутыСтрокой);
		
	КонецЕсли;
	
	Если КоличествоМинут > 0 Тогда
		МинутыСтрокой = СтрокаСЧислом(";%1 минута;%1 минут;%1 минуты;%1 минут;%1 минуты", КоличествоМинут, ВидЧисловогоЗначения.Количественное, "L=ru");
	Иначе
		МинутыСтрокой = "";
	КонецЕсли;
	
	Возврат МинутыСтрокой; 

		
КонецФункции

&НаСервере
// Процедура - Задать пропорциональные величины элементов.
//
Процедура ЗадатьПропорциональныеВеличиныЭлементов()
	
	СтруктураПараметров = Новый Структура();   
	СтруктураПараметров.Вставить("МаксимальныйПоказательКоличество"	, Число(Элементы.ДекорацияНовыйОбращенияКоличество.Заголовок));
	СтруктураПараметров.Вставить("МаксимальныйПоказательШирины"		, Элементы.ГруппаНовыеОбращенияИнформация.Ширина);
	СтруктураПараметров.Вставить("МинимальныйПоказательШирины"		, 24);
	
	// Для начала все группы с одинаковым максимумом.
	ЗадатьШиринуГруппы(Элементы.ГруппаКачественныеОбращенияИнф	, Число(Элементы.ДекорацияНадписьКоличествоКачественныхОбращений.Заголовок)	, СтруктураПараметров);	
	
	СтруктураПараметров.Вставить("МинимальныйПоказательШирины"		, 18);

  	ЗадатьШиринуГруппы(Элементы.ГруппаКлиентЗаписан				, Число(Элементы.ДекорацияКлиентЗаписанКоличество.Заголовок)				, СтруктураПараметров);
	ЗадатьШиринуГруппы(Элементы.ГруппаКлиентПодтвердил			, Число(Элементы.ДекорацияКлиентПодтвердилКоличество.Заголовок)				, СтруктураПараметров); 
	
	//СтруктураПараметров.Вставить("МаксимальныйПоказательКоличество"	, Число(Элементы.ДекорацияПотенциальнаяЗаписьКоличество.Заголовок));
	
	ЗадатьШиринуГруппы(Элементы.ГруппаПредложениеОзвучено		, Число(Элементы.ДекорацияПредложениеОзвученоКоличество.Заголовок)			, СтруктураПараметров); 		
	ЗадатьШиринуГруппы(Элементы.ГруппаКлиентЗаписанПовторные	, Число(Элементы.ДекорацияКлиентЗаписанПовторныеКоличество.Заголовок)		, СтруктураПараметров); 
	ЗадатьШиринуГруппы(Элементы.ГруппаКлиентПодтвердилПовторные	, Число(Элементы.ДекорацияКлиентПодтвердилПовторныеКоличество.Заголовок)	, СтруктураПараметров); 
	
	СтруктураПараметров.Вставить("МаксимальныйПоказательШирины"		, Элементы.ГруппаНовыеОбращенияИнформация.Ширина - 18); 	
	
	Если Число(Элементы.ДекорацияКлиентПришелКоличество.Заголовок) < Число(Элементы.ДекорацияКлиентПодтвердилКоличество.Заголовок) Тогда 
		СтруктураПараметров.Вставить("МинимальныйПоказательШирины"		, 14);                                                                   
	КонецЕсли;
	
	СтруктураПараметров.Вставить("МаксимальныйПоказательКоличество"	, Число(Элементы.ДекорацияКлиентПришелКоличество.Заголовок) + Число(Элементы.ДекорацияКлиентОтменилКоличество.Заголовок));
	
    ЗадатьШиринуГруппы(Элементы.ГруппаКлиентПришел	, Число(Элементы.ДекорацияКлиентПришелКоличество.Заголовок)	, СтруктураПараметров);
	
	СтруктураПараметров.Вставить("МаксимальныйПоказательШирины"		, 50 - Элементы.ГруппаКлиентПришел.Ширина);
	ЗадатьШиринуГруппы(Элементы.ГруппаПотери		, Число(Элементы.ДекорацияКлиентОтменилКоличество.Заголовок), СтруктураПараметров);
	
	СтруктураПараметров.Вставить("МаксимальныйПоказательШирины"		, Элементы.ГруппаНовыеОбращенияИнформация.Ширина - 18); 
	
	Если Число(Элементы.ДекорацияКлиентПришелПовторныеКоличество.Заголовок) >= Число(Элементы.ДекорацияКлиентПодтвердилПовторныеКоличество.Заголовок) Тогда 
		СтруктураПараметров.Вставить("МинимальныйПоказательШирины"		, 18);                                                                   
	КонецЕсли;
	СтруктураПараметров.Вставить("МаксимальныйПоказательКоличество"	, Число(Элементы.ДекорацияКлиентПришелПовторныеКоличество.Заголовок) + Число(Элементы.ДекорацияКлиентОтмененоПовторныеКоличество.Заголовок));
	
	ЗадатьШиринуГруппы(Элементы.ГруппаКлиентПришелПостоянные, Число(Элементы.ДекорацияКлиентПришелПовторныеКоличество.Заголовок)	, СтруктураПараметров);	

	СтруктураПараметров.Вставить("МаксимальныйПоказательШирины"		, 50 - Элементы.ГруппаКлиентПришелПостоянные.Ширина);
	ЗадатьШиринуГруппы(Элементы.ГруппаПотериПовторные		, Число(Элементы.ДекорацияКлиентОтмененоПовторныеКоличество.Заголовок)	, СтруктураПараметров);	

КонецПроцедуры  

&НаСервере
// Процедура - Зада ширин группы.
//
// Параметры:
//  Группа							 - 	 - 
//  МаксимальноеЗначениеШирина		 - 	 - 
//  МаксимальноеЗначениеКоличество	 - 	 - 
//  КоличественныйПоказатель		 - 	 - 
//
Процедура ЗадатьШиринуГруппы(Группа, КоличественныйПоказатель, СтруктураПараметров)
		
	МаксимальныйПоказательКоличество 	= 0;
	МаксимальныйПоказательШирины		= 0;	
	МинимальныйПоказательШирины			= 0;
	ЗначениеПромежуточное   			= 0;
	
	СтруктураПараметров.Свойство("МаксимальныйПоказательКоличество"	, МаксимальныйПоказательКоличество);
	СтруктураПараметров.Свойство("МаксимальныйПоказательШирины"		, МаксимальныйПоказательШирины);
	СтруктураПараметров.Свойство("МинимальныйПоказательШирины"		, МинимальныйПоказательШирины);	
	
	Если МаксимальныйПоказательКоличество <> 0 Тогда 	
		ЗначениеПромежуточное = Окр((КоличественныйПоказатель / МаксимальныйПоказательКоличество) * МаксимальныйПоказательШирины, 0);	
	КонецЕсли; 
	
	ШиринаПромежуточный = Макс(ЗначениеПромежуточное, МинимальныйПоказательШирины); 	
	Группа.Ширина = Мин(ШиринаПромежуточный, МаксимальныйПоказательШирины);     

КонецПроцедуры  

