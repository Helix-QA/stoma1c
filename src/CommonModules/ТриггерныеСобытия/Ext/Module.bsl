			Иначе 
				// Пишем в журнал регистрации триггерных событий
				СообщениеОбОшибке = НСтр("ru='Не обнаружены соответствующие контактные данные получателя для рассылки сообщений, либо не корректно указан аккаунт уведомлений для структурной единицы регистрации данного события.';en='The corresponding contact details of the recipient for sending messages were not found, or the notification account for the structural unit for registering this event was not correctly specified.'");			
				СтруктураСобытия = Новый Структура;
