// Процедура, обработчик события "ПриНачалеРедактирования" таблицы "РасшифровкаПлатежа".
//
Процедура РасшифровкаПлатежаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)	
	Если НоваяСтрока = Истина Тогда
		Если Объект.СтатьяВТаблице = Ложь Тогда
			Элемент.ТекущиеДанные.Статья = Объект.Статья;
		Иначе
			Элемент.ТекущиеДанные.Статья = ПолучитьПредопределеннуюСтатьюДляОперации(Объект.ВидОперации,Ложь);
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратЗаработнойПлаты")
	   И НоваяСтрока = Истина Тогда
		Элемент.ТекущиеДанные.ДокументОснования = Объект.ВозвратВыплатыЗПДокументОснования;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик при окончании редактирования ТЧ 
Процедура РасшифровкаПлатежаПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если Элемент.ТекущийЭлемент = Элементы.РасшифровкаПлатежаСумма Тогда
		Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("Сумма");
	КонецЕсли;                                                           
	// Проверка соответсвия статьи расходов
	ТекущиеДанные         = Элементы.РасшифровкаПлатежа.ТекущиеДанные;
	Если ТекущиеДанные <> НЕопределено Тогда
		СтатьяРасходов = ПолучитьПредопределеннуюСтатьюДляОперации(Объект.ВидОперации,НЕ ЗначениеЗаполнено(ТекущиеДанные.ДокументОснования));
		МестоХраненияСтатьи = ?(НЕ Объект.СтатьяВТаблице, Объект, ТекущиеДанные); 
		Если ЗначениеЗаполнено(СтатьяРасходов) И (НЕ ЗначениеЗаполнено(МестоХраненияСтатьи.Статья) ИЛИ СтатьяРасходов <> МестоХраненияСтатьи.Статья) Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("РасшифровкаПлатежаПриОкончанииРедактированияЗавершение", ЭтотОбъект, Новый Структура("МестоХраненияСтатьи, СтатьяРасходов", МестоХраненияСтатьи, СтатьяРасходов));
			ПоказатьВопрос(ОписаниеОповещения, "Статья расходов не соответсвует виду операции, сменить статью?",РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

