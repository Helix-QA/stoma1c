		|ПОМЕСТИТЬ ТаблицаУслуг
		|ИЗ
		|	&ТаблицаУслуг КАК ТаблицаУслуг";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;   
	
	// формируем запрос "объединение".
	МассивТекст.Добавить(СтрокаРазделение);
	Если ТаблицаЗапасов <> Неопределено Тогда
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаЗапасы.НомерСтроки,
		|	ТаблицаЗапасы.Номенклатура,
