// Параметры:
//  Элемент	 - 	 - 
//
Процедура Подключаемый_ВидДействия_Поле_ПриИзменении(Элемент)
	
	СтруктураДанныеЭлемента = УправлениеСвойствамиКлиентСтоматология.ПолучитьДанныеЭлементаНастройкиДействийТриггерногоСобытия(ЭтотОбъект, Элемент, ТекущаяСтруктурнаяЕдиница);
	Если НЕ СтруктураДанныеЭлемента = Неопределено Тогда
		Если ДействиеЗарегистрировано(СтруктураДанныеЭлемента.ДанныеЭлемента.ИдентификаторДействия, СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия, , Объект.Ссылка) Тогда
			СообщитьОНедопустимостиСменыДействия(СтруктураДанныеЭлемента.ИндексСтроки);
			Возврат;
		КонецЕсли;		
		СтруктураДанныеЭлемента.ДанныеЭлемента.Использование = ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия);
		Если ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия) И НеобходимоДобавитьЭлементВвода(СтруктураДанныеЭлемента.ИндексСтроки) Тогда 
			СформироватьТаблицуДействий(СтруктураДанныеЭлемента.ИндексСтроки, , Истина);
		Иначе 	
			УстановитьСвойстваЭлементамДействий(, СтруктураДанныеЭлемента.ИндексСтроки);
		КонецЕсли;
		Если СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия = ПредопределенноеЗначение("Перечисление.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота") Тогда 
			СтруктураДанныеЭлемента.ДанныеЭлемента.ВидАдресата = ПредопределенноеЗначение("Перечисление.ВидыАдресатов.КонтрагентСобытия");	
		КонецЕсли;	
		ПоказатьВсплывающуюГруппуПараметров(СтруктураДанныеЭлемента.ДанныеЭлемента.ИдентификаторДействия, СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия);
		Если ЗначениеЗаполнено(СтруктураДанныеЭлемента.ДанныеЭлемента.ШаблонСообщения) Тогда
			ИнформирующееСообщение = "";
			Если ПустоеСодержаниеШаблона(СтруктураДанныеЭлемента.ДанныеЭлемента.ШаблонСообщения, , СтруктураДанныеЭлемента.ДанныеЭлемента.ВидДействия, ИнформирующееСообщение) Тогда 
				// Сообщаем
				Если ЗначениеЗаполнено(ИнформирующееСообщение) Тогда 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ИнформирующееСообщение,
					, "Объект.Действия[" + Формат(СтруктураДанныеЭлемента.ИндексСтроки, "ЧГ=0") + "]." + "ШаблонСообщения");
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;
	
