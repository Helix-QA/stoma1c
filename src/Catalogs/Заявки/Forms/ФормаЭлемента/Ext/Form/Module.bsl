		ИначеЕсли Действие = "СоздатьSMS" Тогда
			СоздатьSMSРассылкуНаКлиенте();
		ИначеЕсли Действие = "ВыборВзаимодействия" Тогда
			ВыборВзаимодействиеЗадачаНаСервере();
		ИначеЕсли Действие = "ПерейтиКДиалогу" Тогда
			Подключаемый_ПерейтиКДиалогу(Параметры.Элемент);
		КонецЕсли;
		
