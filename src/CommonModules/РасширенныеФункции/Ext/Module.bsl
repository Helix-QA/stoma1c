// Функция - Получить структурную единицу
// 
// Параметры:
//  IDUnit	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСсылкуОбъектаПоUID(ВидОбъекта, ИмяОбъекта, ID, ВызыватьИсключение = Ложь, Отказ = Ложь) Экспорт
	
	Результат = Неопределено;
	
	ПОПЫТКА
		
		IDСсылка = Новый УникальныйИдентификатор(ID);
		
		Если ВидОбъекта = "Справочники" Тогда
			Результат = Справочники[ИмяОбъекта].ПолучитьСсылку(IDСсылка);
		ИначеЕсли ВидОбъекта = "Документы" Тогда
			Результат = Документы[ИмяОбъекта].ПолучитьСсылку(IDСсылка);
		ИначеЕсли ВидОбъекта = "Задачи" Тогда
			Результат = Задачи[ИмяОбъекта].ПолучитьСсылку(IDСсылка);
		Иначе
			Отказ = Истина;
		КонецЕсли;
		
		Если Результат <> Неопределено И Результат.ПолучитьОбъект() = Неопределено Тогда
			Отказ = Истина;
		КонецЕсли;
		
	ИСКЛЮЧЕНИЕ
		Отказ = Истина;
		
	КОНЕЦПОПЫТКИ;
		
	Если Отказ = Истина И ВызыватьИсключение = Истина Тогда
		ВызватьИсключение "Ссылка на объект '" + ИмяОбъекта + "' по uID='" + ID + "' не найдена!"
	КонецЕсли;
	
	// Если Результат = Неопределено Тогда
	// 	Результат = Справочники[ИмяОбъекта].ПустаяСсылка();
	// КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции

