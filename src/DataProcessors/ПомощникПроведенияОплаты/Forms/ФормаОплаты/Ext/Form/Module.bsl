// Процедура - Завершающий этап операции оплаты
//
Процедура ЗавершающийЭтапОперацииОплаты(
	ОплатаЗавершенаУспешно, 
	ДанныеФискальныхЧеков,
	ДанныеПлатежаПоКарте,
	МассивДокОплаты)
		
	Если ОплатаЗавершенаУспешно = Истина Тогда
		
		МассивОплат = Новый Массив;
		Для Каждого СтрокаТ ИЗ ЭтотОбъект.ВидыОплат.ПолучитьЭлементы() Цикл
			Если СтрокаТ.Внесено > 0 Тогда
				МассивОплат.Добавить(Новый Структура("ТипДенежныхСредств, ДокументАванса, ЛицевойСчет, БонусныйСчет, Внесено",
								СтрокаТ.ТипДенежныхСредств, СтрокаТ.ДокументАванса, СтрокаТ.ВидЛицевогоСчета,  СтрокаТ.БонусныйСчет, СтрокаТ.Внесено));
			КонецЕсли;
			Для Каждого СтрокаТ ИЗ СтрокаТ.ПолучитьЭлементы() Цикл
				Если СтрокаТ.Внесено > 0 Тогда
					МассивОплат.Добавить(Новый Структура("ТипДенежныхСредств, ДокументАванса, ЛицевойСчет, БонусныйСчет, Внесено", 
								СтрокаТ.ТипДенежныхСредств, СтрокаТ.ДокументАванса, СтрокаТ.ВидЛицевогоСчета, СтрокаТ.БонусныйСчет, СтрокаТ.Внесено));
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
			
		ДанныеПоКартеУжеЗаписаны = Ложь;
		Если ЗначениеЗаполнено(ДанныеФискальныхЧеков)
			И (ЗначениеЗаполнено(ДанныеФискальныхЧеков.НомерФискальногоЧека) 
			ИЛИ ЗначениеЗаполнено(ДанныеФискальныхЧеков.НомерНеФискальногоЧека)) Тогда
				
			РежимЗаписи_ = РежимЗаписиДокумента.Запись;	
			
			// Номер чека получен успешно, дописать его в документы оплаты
			ЗаписатьДокументы(
				ТекущаяКассаИспользуетсяККТ,
				МассивДокОплаты,
				РежимЗаписи_,
				ТекущаяКасса,
				ДанныеФискальныхЧеков, 
				ДанныеПлатежаПоКарте,
				МассивОплат);
			
			ДанныеПоКартеУжеЗаписаны = Истина;
						
		КонецЕсли;
		
		Если ДанныеПоКартеУжеЗаписаны = Ложь
			И ЗначениеЗаполнено(ДанныеПлатежаПоКарте) Тогда
			
			ЗаписатьДокументы(
				ТекущаяКассаИспользуетсяККТ,
				МассивДокОплаты, 
				РежимЗаписиДокумента.Запись,
				ТекущаяКасса, 
				ДанныеФискальныхЧеков,
				ДанныеПлатежаПоКарте,
				МассивОплат);
		КонецЕсли;
		
		// Завершение операции оповещение д. списоков, закрытие/обновление формы
		ОповеститьОбИзменении(ПредопределенноеЗначение("Документ.Прием.ПустаяСсылка"));
		ОповеститьОбИзменении(ПредопределенноеЗначение("Документ.Реализация.ПустаяСсылка"));
		ОповеститьОбИзменении(ПредопределенноеЗначение("Документ.ПланЛечения.ПустаяСсылка"));
		Оповестить("ПРОВЕДЕНА_ОПЛАТА_ДОКУМЕНТА");
		Если ЭтоВзносАванса Тогда
			Оповестить("ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА_АВАНСА");
		КонецЕсли;	
		Если ПараметрФормыЗакрыватьФормуПослеОплаты Тогда
			Закрыть(Новый Структура("ОперацияВыполнена",Истина));
		Иначе			
			
			ДокументыЗадолженности.Очистить();
			ОбновитьФорму("ОБНОВИТЬ_ТАБЛИЦУ_ЗАДОЛЖЕННОСТЕЙ",Истина);

		КонецЕсли;   
		
	Иначе
				
		// При печати чека произошла ошибка, отменить проведение документов оплаты
		Если ЗначениеЗаполнено(МассивДокОплаты) Тогда
			
			МассивОплат = Новый Массив;
						
			ЗаписатьДокументы(
				ТекущаяКассаИспользуетсяККТ, 
				МассивДокОплаты, 
				РежимЗаписиДокумента.ОтменаПроведения);	
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

