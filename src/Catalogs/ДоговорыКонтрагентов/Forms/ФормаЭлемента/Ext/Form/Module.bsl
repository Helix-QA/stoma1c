// Процедура, обработчик события "ПриИзменении"
//
Процедура ФильтрПриИзменении(Элемент)
	
	УстановитьФильтр();
	Если Фильтр = 1 Тогда
		ДанныеДерева = ЭтаФорма.ДеревоНоменклатур.ПолучитьЭлементы(); 
		Если ДанныеДерева.Количество() > 0 Тогда
			Элементы.ДеревоНоменклатур.ТекущаяСтрока = 0; 
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Дерево номенклатур выбран при изменении.
//
Процедура ДеревоНоменклатурВыбранПриИзменении(Элемент)
	
	ИмяКолонки 	  = Элемент.Имя;
	ТекущиеДанные = Элементы.ДеревоНоменклатур.ТекущиеДанные;
	МассивНоменклатурИсключений = ПолучитьСписокНоменклатурыОрганичений();
	
	Если ТекущиеДанные.ЭтоГруппа Тогда  
		
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли;
		
		УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки, МассивНоменклатурИсключений);
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, Истина);
		
	Иначе
		
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			
			НайденнаяНоменклатура = МассивНоменклатурИсключений.Найти(ТекущиеДанные.Номенклатура);
			Если НайденнаяНоменклатура = Неопределено Тогда
				ТекущиеДанные[ИмяКолонки] = 0;
				УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки);
			Иначе 
				ТекущиеДанные[ИмяКолонки] = 1; // требуется, т.к. автоматически меняется на 1.
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Удалите услугу: %1 из дерева ограничений", ТекущиеДанные.Номенклатура));
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

