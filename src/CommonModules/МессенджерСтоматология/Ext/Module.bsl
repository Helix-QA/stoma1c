	КонецПопытки;
	
	Возврат ВыполненоУспешно;
	
КонецФункции

// Функция, создает подписку на webhook Telegram.
//
Функция Telegram_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения)
	
	ВыполненоУспешно = Ложь;
		
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());			
		HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/getWebhookInfo");
		
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		Если РезультатЗапроса.Свойство("result") И РезультатЗапроса.result.Свойство("url") И РезультатЗапроса.result.url = АдресПодключения Тогда
			ВыполненоУспешно = Истина;
		Иначе	
			HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
			HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/setWebhook?url=" + АдресПодключения + "&allowed_updates=[""message"", ""edited_message"", ""callback_query""]");
			
			РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
			
			ВыполненоУспешно = РезультатЗапроса.result = 1;
		КонецЕсли;
		
	Исключение
	КонецПопытки;
	
	Возврат ВыполненоУспешно;
	
КонецФункции

// Функция, отправляет сообщение Telegram.
//
Функция Telegram_ОтправитьСообщение(ТекстСообщения
									, ПараметрыКлиента
									, ПараметрыВнешнейСистемы
									, Вложения = Неопределено
									, ДополнительныеПараметры = Неопределено) Экспорт
	
	Попытка
		
		Если ТипЗнч(Вложения) = Тип("Массив") И Вложения.Количество() > 0 Тогда
			
			ИдКлиента = ПараметрыКлиента.ИдКлиента;
			Разделитель = СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
			
			Заголовки = Новый Соответствие;
			Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Разделитель);
			
			HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());			
			HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/sendDocument", Заголовки);
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("chat_id", ИдКлиента);
			ПараметрыЗапроса.Вставить("caption", ТекстСообщения);
			
			HTTPЗапрос.УстановитьТелоИзДвоичныхДанных(СформироватьMultipartFormData(Разделитель, Вложения[0], "document", ПараметрыЗапроса));
			
			РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос).ПолучитьТелоКакСтроку());
			
			Если РезультатЗапроса.Свойство("result") Тогда
				
				ИдСообщения = РезультатЗапроса.result.message_id;
				ИдСообщения = ?(ТипЗнч(ИдСообщения) = Тип("Число"), Формат(ИдСообщения, "ЧГ="), ИдСообщения);
				ИдСообщения = СокрЛП(ИдСообщения);
				
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно", Истина);
				РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
				РезультатОперации.Вставить("ИдКанала"        , "");
				РезультатОперации.Вставить("Вложения"		 , ПолучитьСсылкуНаФайл_Telegram(РезультатЗапроса.result.document, ПараметрыВнешнейСистемы));
				
			Иначе
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки"  , ?(РезультатЗапроса.Свойство("description"), "Ошибка отправки. " + РезультатЗапроса.description, "Неизвестная ошибка отправки."));
			КонецЕсли;
			
		Иначе
			
			ИдКлиента = ПараметрыКлиента.ИдКлиента;
			
			// Кодируем сообщение чат-бота
			//ЗакодироватьСообщениеЧатБота(ТекстСообщения, ДополнительныеПараметры);
			
			HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("chat_id"	, ИдКлиента);
			ПараметрыЗапроса.Вставить("text"	, ТекстСообщения);
			
			Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "JSONСтруктураКнопок") <> Неопределено Тогда 
				ПараметрыЗапроса.Вставить("reply_markup", ДополнительныеПараметры.JSONСтруктураКнопок);
			КонецЕсли;
			
			ТелоЗапроса = КодироватьВJSON(ПараметрыЗапроса);
			
			Заголовки = Новый Соответствие;
			Заголовки.Вставить("Content-Type", "application/json");
			
			HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/sendMessage", Заголовки);
			HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
			
			Ответ			 = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
			ТелоОтвета		 = Ответ.ПолучитьТелоКакСтроку();
			ПараметрыОтвета	 = ДекодироватьИзJSON(ТелоОтвета);
			
			Если ПараметрыОтвета.Свойство("result") Тогда
				
				ИдСообщения = ПараметрыОтвета.result.message_id;
				ИдСообщения = ?(ТипЗнч(ИдСообщения) = Тип("Число"), Формат(ИдСообщения, "ЧГ="), ИдСообщения);
				ИдСообщения = СокрЛП(ИдСообщения);
				
				РезультатОперации = Новый Структура();
				РезультатОперации.Вставить("ВыполненоУспешно", Истина);
				РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
				РезультатОперации.Вставить("ИдКанала"     	 , "");
				
			Иначе
				РезультатОперации = Новый Структура;	
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки"  , ?(ПараметрыОтвета.Свойство("description"), "Ошибка отправки. " + ПараметрыОтвета.description, "Неизвестная ошибка отправки."));
			КонецЕсли;
			
		КонецЕсли;	
		
	Исключение
		РезультатОперации = Новый Структура;
		РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
		РезультатОперации.Вставить("ОписаниеОшибки"	 , "Ошибка соединения " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Telegram редактировать сообщение
//
// Параметры:
//  СтрокаЗамены		 - 	 - 
//  ПараметрыСсобщения	 - 	 - 
//  ВнешняяСистема		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Telegram_РедактироватьСообщение(Знач СтрокаЗамены, ПараметрыСобщения, Знач ДанныеСообщения, ЭтоОтветКлиента = Ложь) Экспорт

	СтрокаЗамены = СокрЛП(СтрокаЗамены);
	
	message_id = Формат(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСобщения, "message_id", ""), "ЧГ=0");
	
	РезультатОперации = Новый Структура;
	РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
	РезультатОперации.Вставить("ОписаниеОшибки"  , "");
	РезультатОперации.Вставить("ИдСообщения"     , message_id);
	
	Если НЕ ЗначениеЗаполнено(СтрокаЗамены) Тогда 
		РезультатОперации.ОписаниеОшибки = "Не удалось отредактировать сообщение. Не заполнены строка, на которую будет заменено сообщение."; 	
		Возврат РезультатОперации;
	КонецЕсли;
	
	ПараметрыВнешнейСистемы = Неопределено;
	ВнешняяСистема 				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеСообщения, "ВнешняяСистема", Неопределено);
	Если ВнешняяСистема = Неопределено Тогда
		СтрокаЗаменыДляЖурнала 	= ДанныеСообщения.ДополнительныеПараметры.text;
		ДанныеСообщения 		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеСообщения, "ДанныеСообщения", Неопределено);
		ВнешняяСистема 			= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеСообщения, "ВнешняяСистема", Неопределено);
	Иначе 
		СтрокаЗаменыДляЖурнала 	= СтрокаЗамены;
	КонецЕсли;	
	Если НЕ ИнициализированыПараметрыВнешнейСистемы(ВнешняяСистема, ПараметрыВнешнейСистемы) Тогда 
		РезультатОперации.ОписаниеОшибки = "Не удалось отредактировать сообщение. Не заполнены параметры внешней системы."; 	
		Возврат РезультатОперации;
	КонецЕсли;
	
	ИдКлиента = Формат(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСобщения, "chat_id", ""), "ЧГ=0");
	Если НЕ ЗначениеЗаполнено(ИдКлиента) Тогда 
		РезультатОперации.ОписаниеОшибки = "Не удалось отредактировать сообщение. Не указан идентификатор чата."; 	
		Возврат РезультатОперации;
	КонецЕсли;
	
	is_bot 				= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСобщения, "is_bot"				, Ложь);	
	JSONСтруктураКнопок = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСобщения, "JSONСтруктураКнопок"	, Неопределено);

	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Если JSONСтруктураКнопок = Неопределено Тогда 
			HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/editMessageText?chat_id=" + ИдКлиента + "&message_id=" + message_id + "&text=" + СтрокаЗамены);
		Иначе 
			HTTPЗапрос = Новый HTTPЗапрос("/bot" + ПараметрыВнешнейСистемы.ApiToken + "/editMessageText?chat_id=" + ИдКлиента + "&message_id=" + message_id + "&text=" + СтрокаЗамены + "&reply_markup=" + JSONСтруктураКнопок);
		КонецЕсли;	
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		Если РезультатЗапроса.Свойство("result") Тогда
			
			ИдСообщения = РезультатЗапроса.result.message_id;
			ИдСообщения = ?(ТипЗнч(ИдСообщения) = Тип("Число"), Формат(ИдСообщения, "ЧГ="), ИдСообщения);
			ИдСообщения = СокрЛП(ИдСообщения);
			
			Если is_bot Тогда 
				СтрокаЗаменыДляЖурнала = СокрЛП(СтрЗаменить(СтрокаЗаменыДляЖурнала, "Ваш выбор:", "")); 
			КонецЕсли;	
			РегистрыСведений.ЖурналСообщений.РедактироватьСообщение(ДанныеСообщения, СтрокаЗаменыДляЖурнала, ЭтоОтветКлиента);
			
			РезультатОперации = Новый Структура();
			РезультатОперации.Вставить("ВыполненоУспешно", Истина);
			РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
			РезультатОперации.Вставить("ИдКанала"     	 , "");
			
		Иначе
			РезультатОперации = Новый Структура;	
			РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
			РезультатОперации.Вставить("ОписаниеОшибки"  , ?(РезультатЗапроса.Свойство("description"), "Ошибка отправки. " + РезультатЗапроса.description, "Неизвестная ошибка отправки."));
		КонецЕсли;
		
	Исключение
		РезультатОперации = Новый Структура;
		РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
		РезультатОперации.Вставить("ОписаниеОшибки"	 , "Ошибка соединения " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция, создает подписку на webhook Viber.
//
Функция Viber_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения)
	
	ВыполненоУспешно = Ложь;
		
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("url"			, АдресПодключения);
		ПараметрыЗапроса.Вставить("send_name"	, Истина);
		ПараметрыЗапроса.Вставить("send_photo"	, Истина);
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type"		, "application/json");
		Заголовки.Вставить("X-Viber-Auth-Token"	, ПараметрыВнешнейСистемы.ApiToken);
		
		HTTPЗапрос = Новый HTTPЗапрос("set_webhook", Заголовки);
		
		ТелоЗапроса = КодироватьВJSON(ПараметрыЗапроса);
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();
		ПараметрыОтвета = ДекодироватьИзJSON(ТелоОтвета);
		
		ВыполненоУспешно = (ПараметрыОтвета.status = 0);
		
	Исключение
	КонецПопытки;
	
	Возврат ВыполненоУспешно;
	
КонецФункции

// Функция, отправляет сообщение Viber.
//
Функция Viber_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения = Неопределено, Оператор = Неопределено) Экспорт
	
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type"		, "application/json");
		Заголовки.Вставить("X-Viber-Auth-Token"	, ПараметрыВнешнейСистемы.ApiToken);
		
		HTTPЗапрос = Новый HTTPЗапрос("send_message", Заголовки);
		
		Если ЗначениеЗаполнено(Оператор) И ПараметрыВнешнейСистемы.Свойство("ИспользоватьИменаСотрудников")
			И ПараметрыВнешнейСистемы.ИспользоватьИменаСотрудников = Истина Тогда
			
			ДанныеОтправителя = Новый Структура;
			ДанныеОтправителя.Вставить("name", Лев(ОбщегоНазначения.ПолучитьЗначениеРеквизита(Оператор, "НаименованиеСокращенное"), 28));
			
		Иначе
			
			ДанныеОтправителя = Новый Структура;
			ДанныеОтправителя.Вставить("name", ПараметрыВнешнейСистемы.ИмяОтправителя);
			
		КонецЕсли;
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("type"	, "text");
		ПараметрыЗапроса.Вставить("sender"	, ДанныеОтправителя);
		ПараметрыЗапроса.Вставить("receiver", ПараметрыКлиента.ИдКлиента);
		
		Если ЗначениеЗаполнено(Вложения) Тогда
			
			ОшибкаЗагрузкиФайла = "";
			СсылкаНаФайл = ЗагрузитьФайлВХранилищеИПолучитьСсылку(Вложения[0], ОшибкаЗагрузкиФайла);
			
			Если Не ЗначениеЗаполнено(СсылкаНаФайл) Тогда
				
				ОписаниеОшибки = "При отправке файла произошла ошибка." + Символы.ПС + ОшибкаЗагрузкиФайла;
				
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
				
				Возврат РезультатОперации;
				
			КонецЕсли;
			
			ПараметрыЗапроса.Вставить("text", ?(ЗначениеЗаполнено(ТекстСообщения), ТекстСообщения + Символы.ПС + СсылкаНаФайл, СсылкаНаФайл));
			
		Иначе
			ПараметрыЗапроса.Вставить("text", ТекстСообщения);
			
		КонецЕсли;
		
		ТелоЗапроса = КодироватьВJSON(ПараметрыЗапроса);
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		РезультатЗапроса = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ТелоРезультата = РезультатЗапроса.ПолучитьТелоКакСтроку();
		ПараметрыРезультата = ДекодироватьИзJSON(ТелоРезультата);
		
		Если ПараметрыРезультата.Свойство("status_message") И НРег(ПараметрыРезультата.status_message) = "ok" Тогда
			
			ИдСообщения = ПараметрыРезультата.message_token;
			
			РезультатОперации = Новый Структура;
			РезультатОперации.Вставить("ВыполненоУспешно", Истина);
			РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
			РезультатОперации.Вставить("ИдКанала"	     , Неопределено);
			
			Если ЗначениеЗаполнено(СсылкаНаФайл) Тогда
				РезультатОперации.Вставить("Вложения", СсылкаНаФайл);
			КонецЕсли;
			
		Иначе
			
			ОписаниеОшибки = "Ошибка отправки.";
			
			Если ПараметрыРезультата.Свойство("status") Тогда
				ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Код ошибки: " + ПараметрыРезультата.status;
			КонецЕсли;
			
			Если ПараметрыРезультата.Свойство("status_message") Тогда
				ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Текст ошибки: " + ПараметрыРезультата.status_message;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТелоРезультата) Тогда
				ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + "Ответ сервера: " + ТелоРезультата;
			КонецЕсли;
			
			РезультатОперации = Новый Структура;	
			РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
			РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
			
		КонецЕсли;
		
	Исключение
		
		ОписаниеОшибки = "Ошибка отправки. Текст ошибки: " + ОписаниеОшибки();
		
		РезультатОперации = Новый Структура;
		РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
		РезультатОперации.Вставить("ОписаниеОшибки", ОписаниеОшибки);
		
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция, получить список диалогов VkApi.
//
Функция VkApi_ПолучитьСписокДиалогов(UrlApi, ApiToken, ChannelId) Экспорт
	
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 	
		
		КодДляИсполнения = 
		"var request_conv_count = 200;
		|var c = API.messages.getConversations({""count"":request_conv_count});
		|var conversations = c.items;
		|var conversations_count = c.count;
		|var user_ids = conversations@.conversation@.peer@.id;
		|var chat_count = 0;
		|var result = [];
		|var users = API.users.get({""user_ids"":user_ids,""fields"":""photo_200""});
		|var i = 0;
		|var user_data = [];
		|while (i < users.length) {
		|  user_data.push({""id"":""""+users[i].id,""name"":users[i].first_name+"" ""+users[i].last_name,""image"":users[i].photo_200});
		|  i = i + 1;
		|}
		|return user_data;";
		
		КодДляИсполнения = КодироватьСтроку(КодДляИсполнения,СпособКодированияСтроки.КодировкаURL);
		
		HTTPЗапрос = Новый HTTPЗапрос("/method/execute?code=" + КодДляИсполнения + "&access_token=" + ApiToken + "&v=5.124");
		
		РезультатЗапроса = HTTPСоединение.Получить(HTTPЗапрос);
		СтруктураОтвета	 = РазобратьJson(РезультатЗапроса);
		
		Если СтруктураОтвета.Свойство("response") Тогда
			Возврат СтруктураОтвета.response;
		Иначе
			Возврат Неопределено;
		КонецЕсли;
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// Функция, получить список диалогов VkApi.
//
Функция VkApi_ПолучитьДанныеДиалога(ДиалогID, ВнешняяСистема) Экспорт
	
	ПараметрыВнешнейСистемы = ВнешняяСистема.Параметры.Получить();
	
	РезультатОперации = Новый Структура("ВыполненоУспешно, ОписаниеОшибки, Идентификатор, НаименованиеКлиента, ФотоКлиента", Ложь);
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 	
		
		КодДляИсполнения = 
		"var c = API.messages.getConversationsById({""peer_ids"":""" + ДиалогID + """});
		|var conversations = c.items;
		|var conversations_count = c.count;
		|var user_ids = conversations@.peer@.id;
		|var chat_count = 0;
		|var result = [];
		|var users = API.users.get({""user_ids"":user_ids,""fields"":""photo_200""});
		|var i = 0;
		|var user_data = [];
		|while (i < users.length) {
		|  user_data.push({""id"":""""+users[i].id,""name"":users[i].first_name+"" ""+users[i].last_name,""image"":users[i].photo_200});
		|  i = i + 1;
		|}
		|return user_data;";
		
		КодДляИсполнения = КодироватьСтроку(КодДляИсполнения,СпособКодированияСтроки.КодировкаURL);
		
		HTTPЗапрос = Новый HTTPЗапрос("/method/execute?code=" + КодДляИсполнения + "&access_token=" + ПараметрыВнешнейСистемы.ApiToken + "&v=5.124");
		
		РезультатЗапроса = HTTPСоединение.Получить(HTTPЗапрос);
		СтруктураОтвета	 = РазобратьJson(РезультатЗапроса);
						
		Если СтруктураОтвета.Свойство("response") И СтруктураОтвета.response.Количество() > 0 Тогда
			
			РезультатОперации.ВыполненоУспешно		= Истина;
			РезультатОперации.Идентификатор			= СтруктураОтвета.response[0].id;
			РезультатОперации.НаименованиеКлиента	= СтруктураОтвета.response[0].name;
			РезультатОперации.ФотоКлиента			= СтруктураОтвета.response[0].image;
			
		Иначе
			РезультатОперации.ОписаниеОшибки	= "Нет данных по диалогу";
		КонецЕсли;
				
	Исключение
		РезультатОперации.ОписаниеОшибки	= "Возникла исключительная ошибка при получении данных диалога: " + ОписаниеОшибки();
	КонецПопытки;
	
	Возврат РезультатОперации; 
	
КонецФункции

// Функция, создает подписку на webhook VkApi.
//
Функция VkApi_СоздатьПодпискуНаWebhook(ПараметрыВнешнейСистемы, АдресПодключения)
	
	ВыполненоУспешно = Ложь;
		
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	
		КодДляИсполнения = 
		"var servers = API.groups.getCallbackServers({""group_id"":"+ПараметрыВнешнейСистемы.ChannelId+"}).items;
		|var i = 0;
		|while (i < servers.length) {
		|	if (servers[i].url == """+АдресПодключения+""") {
		|		API.groups.deleteCallbackServer({""group_id"":"+ПараметрыВнешнейСистемы.ChannelId+",""server_id"":servers[i].id});
		|	}
		|	i = i + 1;
		|}
		|var new_server_id = API.groups.addCallbackServer({""group_id"":"+ПараметрыВнешнейСистемы.ChannelId+",""url"":"""+АдресПодключения+""",""title"":""1С-Вебхуки""});
		|return API.groups.setCallbackSettings({""group_id"":"+ПараметрыВнешнейСистемы.ChannelId+",""server_id"":new_server_id,""api_version"":5.124,""message_new"":1,""message_reply"":1,""message_allow"":1,""message_edit"":1,""message_deny"":1});";

		HTTPЗапрос = Новый HTTPЗапрос("method/execute?code="+КодироватьСтроку(КодДляИсполнения, СпособКодированияСтроки.КодировкаURL)+"&access_token="+ПараметрыВнешнейСистемы.ApiToken+"&v=5.124");
		
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		ВыполненоУспешно = РезультатЗапроса.response = 1;
		
	Исключение
	КонецПопытки;
	
	Возврат ВыполненоУспешно;
	
КонецФункции

// Функция, отправляет сообщение VkApi.
//
Функция VkApi_ОтправитьСообщение(ТекстСообщения, ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения = Неопределено) Экспорт
	
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		ГСЧ = Новый ГенераторСлучайныхЧисел;
		random_id = ФорматироватьИдентификатор(ГСЧ.СлучайноеЧисло());
		ИдКлиента = ПараметрыКлиента.ИдКлиента;
		
		АдресаЗагруженныхВложений = Новый Массив;
		Если ЗначениеЗаполнено(Вложения) Тогда
			ВложенияДляОтправки = ПреобразоватьВложенияVkApi(ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения, АдресаЗагруженныхВложений);
		Иначе
			ВложенияДляОтправки = "";
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(Вложения) И ВложенияДляОтправки = "" Тогда
			Возврат Новый Структура("ВыполненоУспешно, ОписаниеОшибки", Ложь, "Не удалось загрузить файл, сообщение не отправлено.");
		КонецЕсли;	
		
		HTTPЗапрос = Новый HTTPЗапрос("/method/messages.send?peer_id="+ИдКлиента+"&random_id="+random_id+"&message="+ТекстСообщения+"&attachment="+ВложенияДляОтправки+"&access_token="+ПараметрыВнешнейСистемы.ApiToken+"&v=5.124");
		
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		Если РезультатЗапроса.Свойство("response") Тогда
			
			ИдСообщения = РезультатЗапроса.response;
			ИдСообщения = ?(ТипЗнч(ИдСообщения) = Тип("Число"), Формат(ИдСообщения, "ЧГ="), ИдСообщения);
			ИдСообщения = СокрЛП(ИдСообщения);
			
			РезультатОперации = Новый Структура();
			РезультатОперации.Вставить("ВыполненоУспешно", Истина);
			РезультатОперации.Вставить("ИдСообщения"     , ИдСообщения);
			РезультатОперации.Вставить("ИдКанала"     	 , "");
			
			Если АдресаЗагруженныхВложений.Количество() > 0 Тогда
				РезультатОперации.Вставить("Вложения", СтрСоединить(АдресаЗагруженныхВложений, "|"));
			КонецЕсли;
			
		Иначе
			РезультатОперации = Новый Структура;	
			РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
			Если РезультатЗапроса.Свойство("error") Тогда
				Если РезультатЗапроса.error.Свойство("error_msg") Тогда
					РезультатОперации.Вставить("ОписаниеОшибки", РезультатЗапроса.error.error_msg);
				ИначеЕсли РезультатЗапроса.error.Свойство("error_code")	Тогда
					РезультатОперации.Вставить("ОписаниеОшибки", "Ошибка отправки. Код ошибки " + РезультатЗапроса.error.error_code);
				КонецЕсли;
			Иначе
				РезультатОперации.Вставить("ОписаниеОшибки", "Неизвестная ошибка отправки.");
			КонецЕсли;
		КонецЕсли;
		
	Исключение
		РезультатОперации = Новый Структура;
		РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
		РезультатОперации.Вставить("ОписаниеОшибки"	 , "Ошибка соединения " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция, преобразовывает файлы для отправки во вложения ВК.
//
Функция ПреобразоватьВложенияVkApi(ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложения, АдресаЗагруженныхВложений)
	
	Если Не ЗначениеЗаполнено(Вложения) Тогда
		Возврат "";
	КонецЕсли;
	
	ВложенияСтрокой = "";
		
	Для Каждого Вложение Из Вложения Цикл
		ВложенияСтрокой = ВложенияСтрокой + ПолучитьВложениеVkApi(ПараметрыКлиента, ПараметрыВнешнейСистемы, Вложение, АдресаЗагруженныхВложений) + ",";
	КонецЦикла;
	
	Возврат ?(СокрЛП(ВложенияСтрокой) = ",", "", ВложенияСтрокой);
	
КонецФункции

// Функция, загружает файл в ВК и возвращает вложение ВК строкой для последующей отправки.
//
Функция ПолучитьВложениеVkApi(ПараметрыКлиента, ПараметрыВнешнейСистемы, Файл, АдресаЗагруженныхВложений)
	
	Попытка
		
		HTTPСоединение = Новый HTTPСоединение(ПараметрыВнешнейСистемы.UrlApi,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		
		HTTPЗапрос = Новый HTTPЗапрос("/method/docs.getMessagesUploadServer?peer_id="+ПараметрыКлиента.ИдКлиента+"&access_token="+ПараметрыВнешнейСистемы.ApiToken+"&v=5.124");
		
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		Если РезультатЗапроса.Свойство("error") Тогда
			Возврат "";
		КонецЕсли;	
		
		АдресРесурса = Сред(РезультатЗапроса.response.upload_url, СтрНайти(РезультатЗапроса.response.upload_url, "/",,, 3));
		АдресСервера = Сред(СтрЗаменить(РезультатЗапроса.response.upload_url, АдресРесурса, ""), СтрНайти(РезультатЗапроса.response.upload_url, "/",,, 2) + 1);
		
		HTTPСоединениеСерверЗагрузки = Новый HTTPСоединение(АдресСервера,,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Разделитель = СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Разделитель);
		
		HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
		HTTPЗапрос.УстановитьТелоИзДвоичныхДанных(СформироватьMultipartFormData(Разделитель, Файл, "file"));
		
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединениеСерверЗагрузки.ОтправитьДляОбработки(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		Если РезультатЗапроса.Свойство("error") Тогда
			Возврат "";
		КонецЕсли;	
		
		HTTPЗапрос = Новый HTTPЗапрос("/method/docs.save?file="+РезультатЗапроса.file+"&title="+Файл.ИмяФайла+"&access_token="+ПараметрыВнешнейСистемы.ApiToken+"&v=5.124");
		
		РезультатЗапроса = ДекодироватьИзJSON(HTTPСоединение.Получить(HTTPЗапрос).ПолучитьТелоКакСтроку());
		
		Если РезультатЗапроса.Свойство("error") Тогда
			Возврат "";
		КонецЕсли;
		
		АдресаЗагруженныхВложений.Добавить(РезультатЗапроса.response.doc.url);
		Возврат "doc" + Формат(РезультатЗапроса.response.doc.owner_id, "ЧГ=") + "_" + Формат(РезультатЗапроса.response.doc.id, "ЧГ=");
		
	Исключение
		Возврат "";
	КонецПопытки;	
	
КонецФункции

// Функция, формирует тело HTTP-запроса и возвращает его как двоичные данные.
//
Функция СформироватьMultipartFormData(Разделитель, Файл, ИмяПараметраФайла = "file", ПараметрыЗапроса = Неопределено)
	
	ДвоичныеДанныеФайла = Base64Значение(Сред(Файл.ДанныеФайла, СтрНайти(Файл.ДанныеФайла, ",") + 1));
	
	НачальнаяПозиция = СтрНайти(Файл.ДанныеФайла, ":") + 1;
	КонечнаяПозиция = СтрНайти(Файл.ДанныеФайла, ";");
	
	ТипMIME = Сред(Файл.ДанныеФайла, НачальнаяПозиция, КонечнаяПозиция - НачальнаяПозиция);
	
	Поток = Новый ПотокВПамяти;
	ЗаписьДанных = Новый ЗаписьДанных(Поток, "UTF-8",, Символы.ПС);
	Если ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
		Для Каждого КлючИЗначение Из ПараметрыЗапроса Цикл
			
			ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
			ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=""" + КлючИЗначение.Ключ + """");
			ЗаписьДанных.ЗаписатьСтроку("");
			ЗаписьДанных.ЗаписатьСтроку(КлючИЗначение.Значение);
			
		КонецЦикла;
	КонецЕсли;	
	ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
	ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=""" + ИмяПараметраФайла + """; filename=""" + Файл.ИмяФайла + """");
	ЗаписьДанных.ЗаписатьСтроку("Content-Type:" + ТипMIME);
	ЗаписьДанных.ЗаписатьСтроку("");
	ЗаписьДанных.Записать(ДвоичныеДанныеФайла);
	ЗаписьДанных.ЗаписатьСтроку("");
	ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель + "--");
	ЗаписьДанных.Закрыть();
	
	Возврат Поток.ЗакрытьИПолучитьДвоичныеДанные();
	
КонецФункции

// Функция - Собрать параметры JSON.
//
Функция СобратьJson(СтруктураДанных) Экспорт
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, СтруктураДанных);
	
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

// Функция - Разобрать параметры JSON.
//
Функция РазобратьJson(Запрос) Экспорт
	
	Попытка
		
		ТекстJSON  = Запрос.ПолучитьТелоКакСтроку();
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		
		Возврат ПрочитатьJSON(ЧтениеJSON);
		
	Исключение
		
		ВызватьИсключение СтрШаблон(НСтр("ru = 'Ошибка: %1. Код состояния: %2. Исходный текст JSON: %3';en= 'Error: %1. Code response: %2. Source text JSON: %3'"), ОписаниеОшибки(), Запрос.КодСостояния, ТекстJSON);
		
	КонецПопытки;

КонецФункции

// Функция - Получить внешний IP-Адрес.
// 
Функция ПолучитьВнешнийIPАдрес() Экспорт
	
	IPАдрес = "";
	
	Попытка
		
		// http:// ip-api.com/json/
		Соединение = Новый HTTPСоединение("ip-api.com");
		HTTPЗапрос = Новый HTTPЗапрос("json");				
		
		РезультатЗапроса = Соединение.Получить(HTTPЗапрос);
		РезультатЗапроса = РазобратьJson(РезультатЗапроса);
		
		Если РезультатЗапроса.Свойство("status") И РезультатЗапроса.status = "success"
			И РезультатЗапроса.Свойство("query") И ЗначениеЗаполнено(РезультатЗапроса.query) Тогда
			
			IPАдрес = РезультатЗапроса.query
		КонецЕсли;
		
	Исключение
	КонецПопытки;
	
	Возврат IPАдрес;
	
КонецФункции

