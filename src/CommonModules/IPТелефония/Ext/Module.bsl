// 
Функция ВернутьПредставлениеНомераТелефона(Знач СписокНомеровТелефонов)
	
	ПредставлениеНомера = "";
	
	Для Каждого ЭлементСписка Из СписокНомеровТелефонов	Цикл 
		Если ЭлементСписка.Пометка = Истина Тогда 
