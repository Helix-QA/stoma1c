
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере" формы.
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтборСтрЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтрЕдиница, ЗначениеЗаполнено(ОтборСтрЕдиница));	
	Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	Элементы.КассаОтбор.ОграничениеТипа      = Новый ОписаниеТипов("СправочникСсылка.Кассы");

КонецПроцедуры // ПриСозданииНаСервере()

&НаСервере
// Обработчик после загрузки настроек формы на сервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если ОтборВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОтПодотчетника") Тогда
	     Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
		 Элементы.КонтрагентОтбор.Заголовок       = "Сотрудник";
    Иначе
	 	 Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
		 Элементы.КонтрагентОтбор.Заголовок       = "Контрагент";
	КонецЕсли;	
	
	Если ОтборТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные") Тогда
	     Элементы.КассаОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		 Элементы.КассаОтбор.Заголовок       = "Банковский счет";
    Иначе
	 	 Элементы.КассаОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Кассы");
		 Элементы.КассаОтбор.Заголовок       = "Касса";
	КонецЕсли;	
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтрЕдиница, ЗначениеЗаполнено(ОтборСтрЕдиница));
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ТипДенежныхСредств", ОтборТипДенСредств, ЗначениеЗаполнено(ОтборТипДенСредств));
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ВидОперации", ОтборВидОперации, ЗначениеЗаполнено(ОтборВидОперации));
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", ОтборКонтрагентСотрудник, ЗначениеЗаполнено(ОтборКонтрагентСотрудник));
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Касса", ОтборКассаБанковскийСчет, ЗначениеЗаполнено(ОтборКассаБанковскийСчет));
		 
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

////////////////////// ОБРАБОТЧИКИ ЭЛЕМЕНТОВ ОТБОРА /////////////////////////

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля СтрЕдиницаОтбор
//
Процедура СтрЕдиницаОтборПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтрЕдиница, ЗначениеЗаполнено(ОтборСтрЕдиница));
КонецПроцедуры

&НаКлиенте
// При изменениие типа ден. средств
Процедура ОтборТипДенСредствПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ТипДенежныхСредств", ОтборТипДенСредств, ЗначениеЗаполнено(ОтборТипДенСредств));
	
	Если ОтборТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные") Тогда
	     Элементы.КассаОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		 Элементы.КассаОтбор.Заголовок       = "Банковский счет";
    Иначе
	 	 Элементы.КассаОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Кассы");
		 Элементы.КассаОтбор.Заголовок       = "Касса";
	КонецЕсли;	
	 
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Касса", ОтборКассаБанковскийСчет, ЗначениеЗаполнено(ОтборКассаБанковскийСчет));
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля ВидОперацииОтбор
//
Процедура ВидОперацииОтборПриИзменении(Элемент)
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ВидОперации", ОтборВидОперации, ЗначениеЗаполнено(ОтборВидОперации));
	
	Если ОтборВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОтПодотчетника") Тогда
	    Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
		Элементы.КонтрагентОтбор.Заголовок       = "Сотрудник";
    Иначе
		Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
		Элементы.КонтрагентОтбор.Заголовок       = "Контрагент";
	КонецЕсли;	
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", ОтборКонтрагентСотрудник, ЗначениеЗаполнено(ОтборКонтрагентСотрудник));
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля КонтрагентОтбор
//
Процедура КонтрагентОтборПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", ОтборКонтрагентСотрудник, ЗначениеЗаполнено(ОтборКонтрагентСотрудник));
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля КассаОтбор
//
Процедура КассаОтборПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Касса", ОтборКассаБанковскийСчет, ЗначениеЗаполнено(ОтборКассаБанковскийСчет));
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

////////////////////// ОБРАБОТЧИК КНОПОК СОЗДАНИЯ ДОКУМЕНТОВ ///////////////////

 &НаКлиенте
// Процедура вызывается обработчиком любой кнопки создания документа 
Процедура ОбщийОбработчикСозданияДокументов(Команда)
	
	ПараметрТипДенСредств = Неопределено;
	ПараметрВидОперации   = Неопределено;
	ПараметрТипДенСредств = ?(СтрЧислоВхождений(Команда.Имя,"ЛицевойСчет")                 >0 ,ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ЛицевойСчет"),ПараметрТипДенСредств);
	ПараметрТипДенСредств = ?(СтрЧислоВхождений(Команда.Имя,"Безналичные")                 >0 ,ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные"),ПараметрТипДенСредств);
    ПараметрТипДенСредств = ?(СтрЧислоВхождений(Команда.Имя,"ПлатежнаяКарта")              >0 ,ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта"),ПараметрТипДенСредств);
    ПараметрТипДенСредств = ?(СтрЧислоВхождений(Команда.Имя,"Наличные")                    >0 ,ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Наличные"),ПараметрТипДенСредств);
		
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ОплатаОтКлиента")             >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтКлиента"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ОплатаОтСтраховойКомпании")   >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ОплатаОтСтраховойКомпании"),ПараметрВидОперации);
    ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВзносНаЛицевойСчет")          >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВзносНаЛицевойСчет"),ПараметрВидОперации);
    ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВозвратОплатыОтПоставщика")   >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика"),ПараметрВидОперации);
    ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ПоступлениеИзБанка")          >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеИзБанка"),ПараметрВидОперации);
    ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВозвратОтПодотчетника")       >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОтПодотчетника"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВозвратОплатыКлиенту")        >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОплатыКлиенту"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВозвратНалога")               >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратНалога"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ПоступлениеОтЭквайера")       >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеОтЭквайера"),ПараметрВидОперации);
    ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВозвратЗайма")                >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратЗайма"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВводОстатков")                >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВводОстатков"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВзносУчредителя")             >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВзносУчредителя"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ПрочееПоступление")           >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПрочееПоступление"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ПоступлениеИзКассы")          >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеИзКассы"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя,"ВозвратЗаработнойПлаты")      >0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратЗаработнойПлаты"),ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя, "ПоступлениеРозничнойВыручки")>0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы"), ПараметрВидОперации);
	ПараметрВидОперации   = ?(СтрЧислоВхождений(Команда.Имя, "ПоступлениеИзКассыПредприятия")>0 ,ПредопределенноеЗначение("Перечисление.ВидыОпераций.ПоступлениеИзКассыПредприятия"), ПараметрВидОперации);
	

	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("Основание", Новый Структура("ВидОперации, ТипДенежныхСредств, Отбор", ПараметрВидОперации, ПараметрТипДенСредств, Новый Структура("Контрагент, СтруктурнаяЕдиница, Касса", ОтборКонтрагентСотрудник, ОтборСтрЕдиница, ОтборКассаБанковскийСчет)));
	// СтруктураПараметры.Вставить("Отбор", Новый Структура("Контрагент, СтруктурнаяЕдиница, Касса", ОтборКонтрагентСотрудник, ОтборСтрЕдиница, ОтборКассаБанковскийСчет));
	ОткрытьФорму("Документ.ПоступлениеДенежныхСредств.ФормаОбъекта", СтруктураПараметры);

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора"
//
Процедура КассаОтборНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ОтборСтрЕдиница) Тогда 
		СтандартнаяОбработка = Ложь;
		ОткрытьФорму("Справочник.Кассы.ФормаВыбора", Новый Структура("Отбор", Новый Структура("СтруктурнаяЕдиница", ОтборСтрЕдиница)),,,,, Новый ОписаниеОповещения("КассаОтборНачалоВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	Иначе 
		СтандартнаяОбработка = Истина;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Касса отбор начало выбора завершение
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура КассаОтборНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда 
		ОтборКассаБанковскийСчет = Результат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОбработкаВыбора"
//
Процедура СтрЕдиницаОтборОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ВыбранноеЗначение <> ОтборСтрЕдиница Тогда
		ОтборКассаБанковскийСчет = ПредопределенноеЗначение("Справочник.Кассы.ПустаяСсылка");
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Касса", ОтборКассаБанковскийСчет, ЗначениеЗаполнено(ОтборКассаБанковскийСчет));
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "Очистка"
//
Процедура СтрЕдиницаОтборОчистка(Элемент, СтандартнаяОбработка)
	
	ОтборКассаБанковскийСчет = ПредопределенноеЗначение("Справочник.Кассы.ПустаяСсылка");
	
КонецПроцедуры

&НаКлиенте
// Загрузить выписки из банка(механизм клиент банка)
Процедура ЗагрузитьВыписку(Команда)
	ОбщегоНазначенияКлиентСтоматология.ЗагрузитьДанныеИзФайлаВыписки(УникальныйИдентификатор, "kl_to_1c.txt");
КонецПроцедуры


#КонецОбласти