	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Событие КАК Событие
	|		ПО ТаблицаСделокПациента.Сделка = Событие.Сделка
	|ГДЕ
	|	Событие.Ссылка ЕСТЬ NULL";	
	
	ВыборкаАналогичнойСделки = Запрос.Выполнить().Выбрать();
	Если ВыборкаАналогичнойСделки.Следующий() Тогда
		ПредварительнаяЗапись = Документы.Событие.ПолучитьПредварительнуюЗаписьПоСделке(ГенерируемаяСделка.Ссылка);
		Если ЗначениеЗаполнено(ПредварительнаяЗапись) Тогда
			ДанныеЗаписи 		= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПредварительнаяЗапись, "Номер, Дата");
			ПричинаОтказа 		= НСтр("ru = 'Перезапись к другому врачу';en = 'Transferring to another doctor'");       
