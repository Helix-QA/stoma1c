// Функция - Создать документ РассылкаСообщений и отправить SMS.
//
// Параметры:
//  МассивСтруктурПолучателей	 - 	 -
//  Содержание					 - 	 -
//  ОписаниеОшибки				 - 	 -
//
// Возвращаемое значение:
//   -
//
Функция СоздатьДокументSMSРассылкаИОтправитьSMSНаСервере(Заявка, НомерТелефона, Содержание, Сделка, СтруктурнаяЕдиница, ОписаниеОшибки)
	
	МассивСтруктурПолучателей = Новый Массив;
	МассивСтруктурПолучателей.Добавить(Новый Структура("Получатель, НомерТелефона", Заявка, НомерТелефона));
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("Получатели"        , МассивСтруктурПолучателей);
	ПараметрыРассылки.Вставить("Содержание"        , Содержание);
	ПараметрыРассылки.Вставить("Сделка"            , Сделка);
	ПараметрыРассылки.Вставить("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	ПараметрыРассылки.Вставить("ОтправкаSMS"       , Истина);
	
	Возврат Документы.РассылкаСообщений.СоздатьДокументРассылкаСообщений(ПараметрыРассылки, ОписаниеОшибки);
	
