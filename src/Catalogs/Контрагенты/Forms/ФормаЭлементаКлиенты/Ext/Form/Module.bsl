// Процедура, производит автокоррекцию ФИО.
//
Процедура ПроизвестиАвтокоррекциюФИО()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Автокоррекция = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Родитель, "Автокоррекция");	
	Если Автокоррекция = 2 Тогда
		Объект.Фамилия	= ВРег(СокрЛП(Объект.Фамилия));
		Объект.Имя		= ВРег(СокрЛП(Объект.Имя));
		Объект.Отчество = ВРег(СокрЛП(Объект.Отчество));
	ИначеЕсли Автокоррекция = 1 Тогда
		Объект.Фамилия	= ТРег(СокрЛП(Объект.Фамилия));// ВРег(Сред(Объект.Фамилия, 1, 1)) + НРег(Сред(Объект.Фамилия, 2));
		Объект.Имя		= ТРег(СокрЛП(Объект.Имя));// ВРег(Сред(Объект.Имя, 1, 1)) + НРег(Сред(Объект.Имя, 2));
		Объект.Отчество = ТРег(СокрЛП(Объект.Отчество));// ВРег(Сред(Объект.Отчество, 1, 1)) + НРег(Сред(Объект.Отчество, 2));
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
// Процедура, проверяет обязательные поля для заполнения из установленных настроек.
//
Процедура УстановитьОбязательныеПоля() 
	
	ХранилищеСтруктураОбязательныеПоля = Константы.ОбязательныеПоляКлиенты.Получить();
	СтруктураОбязательныеПоля = ХранилищеСтруктураОбязательныеПоля.Получить();	
	
	Если СтруктураОбязательныеПоля = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	Для Каждого ОбязательноеПоле Из СтруктураОбязательныеПоля Цикл
		
		Если Лев(ОбязательноеПоле.Ключ, 6) <> "КЛИЕНТ" Тогда 
			Продолжить;	
		КонецЕсли;	
		
		ИзмененноеОбязательноеПоле = СтрЗаменить(ОбязательноеПоле.Ключ, "КЛИЕНТ_", "");
		
		Если СтрЗаменить(ИзмененноеОбязательноеПоле, Прав(ИзмененноеОбязательноеПоле, 1), "") = "ПредставлениеКИ_" И ОбязательноеПоле.Значение = Истина Тогда 
			
			КоличествоЭлементовКИ = Элементы.КонтактнаяИнформация.ПодчиненныеЭлементы.Количество();
			ИндексЭлементаКИ = 0;
			
			Пока КоличествоЭлементовКИ <> 0 Цикл
				
				ТекЭлемент = Элементы.Найти(СтрЗаменить(ИзмененноеОбязательноеПоле, Прав(ИзмененноеОбязательноеПоле, 1), "") + ИндексЭлементаКИ);
				Если ТекЭлемент <> Неопределено Тогда 
					
					Если ОбязательноеПоле.Ключ = "КЛИЕНТ_ПредставлениеКИ_0" 
						ИЛИ ОбязательноеПоле.Ключ = "КЛИЕНТ_ПредставлениеКИ_1"
						ИЛИ ОбязательноеПоле.Ключ = "КЛИЕНТ_ПредставлениеКИ_2" Тогда
						
						ТекЭлемент.АвтоОтметкаНезаполненного = ОбязательноеПоле.Значение;
					КонецЕсли;
					
					КоличествоЭлементовКИ = КоличествоЭлементовКИ - 1;
					
				КонецЕсли;
				
				ИндексЭлементаКИ = ИндексЭлементаКИ + 1;
				
			КонецЦикла;
			
		Иначе
			
			ТекЭлемент = Элементы.Найти(ИзмененноеОбязательноеПоле);
			Если ТекЭлемент <> Неопределено И Не ТекЭлемент = Элементы.Пол Тогда 
				ТекЭлемент.АвтоОтметкаНезаполненного = ОбязательноеПоле.Значение;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

