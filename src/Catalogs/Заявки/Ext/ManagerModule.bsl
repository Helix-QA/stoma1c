
#Если Сервер Или ВнешнееСоединение Или ТолстыйКлиентОбычноеПриложение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Функция - Создать входящую заявку.
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьВходящуюЗаявку(
	communication_id  		 	= Неопределено,
	communication_type		 	= Неопределено,
	ДатаЗаявки        		 	= Неопределено, 
	Фамилия           		 	= Неопределено,
	Имя               		 	= Неопределено, 
	Отчество          		 	= Неопределено, 
	НомерТелефона     		 	= Неопределено, 
	АдресЭП           		 	= Неопределено, 
	РекламныйИсточник 		 	= Неопределено,
	РекламнаяПлощадка 		 	= Неопределено, 
	РекламнаяСсылка   		 	= Неопределено, 
	Комментарий       		 	= Неопределено, 
	ПараметрыUTM      		 	= Неопределено,
	ВнешняяСистема    			= Неопределено,
	ОписаниеОшибки    			= "",
	ОсновнойКлиент    			= Неопределено,
	СтруктурнаяЕдиница			= Неопределено,
	КлиентИзВиджетаЛК 			= Неопределено,
	ДополнительныеПараметры		= Неопределено,
	КонтактнаяИнформацияСоцСеть = Неопределено,
	НаименованиеЗаявки          = Неопределено,
	КаналПривлеченияЗначение	= Неопределено,
	Статус						= Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	СтруктурЗаполнения = Новый Структура;
	СтруктурЗаполнения.Вставить("ДатаСоздания"      			, ?(ЗначениеЗаполнено(ДатаЗаявки), ДатаЗаявки, ТекущаяДатаСеанса()));	
	СтруктурЗаполнения.Вставить("Фамилия"           			, Фамилия);	
	СтруктурЗаполнения.Вставить("Имя"               			, Имя);	
	СтруктурЗаполнения.Вставить("Отчество"          			, Отчество);	
	СтруктурЗаполнения.Вставить("НомерТелефона"    				, НомерТелефона);
	СтруктурЗаполнения.Вставить("АдресЭП"           			, АдресЭП);	
	СтруктурЗаполнения.Вставить("РекламныйИсточник" 			, РекламныйИсточник);
	СтруктурЗаполнения.Вставить("РекламнаяПлощадка"	 			, РекламнаяПлощадка);// КаналПривлечения
	СтруктурЗаполнения.Вставить("РекламнаяСсылка"   			, РекламнаяСсылка);	
	СтруктурЗаполнения.Вставить("Комментарий"       			, Комментарий);	
	СтруктурЗаполнения.Вставить("ПараметрыUTM"      			, ПараметрыUTM);
	СтруктурЗаполнения.Вставить("communication_id"  			, communication_id);	
	СтруктурЗаполнения.Вставить("communication_type"			, communication_type);	
	СтруктурЗаполнения.Вставить("ВнешняяСистема"    			, ВнешняяСистема);	
	СтруктурЗаполнения.Вставить("СтруктурнаяЕдиница"			, СтруктурнаяЕдиница);	
	СтруктурЗаполнения.Вставить("ОсновнойКлиент"				, ОсновнойКлиент);
	СтруктурЗаполнения.Вставить("КонтактнаяИнформацияСоцСеть"	, КонтактнаяИнформацияСоцСеть);
	СтруктурЗаполнения.Вставить("КаналПривлеченияЗначение"		, КаналПривлеченияЗначение);
	СтруктурЗаполнения.Вставить("Статус"						, Статус);

	// Создание новой заявки.
	НоваяЗаявка = Справочники.Заявки.СоздатьЭлемент();
	
	НоваяЗаявка.Заполнить(СтруктурЗаполнения);
	НоваяЗаявка.Наименование = НаименованиеЗаявки;	
	НоваяЗаявка.КлиентИзВиджетаЛК = КлиентИзВиджетаЛК;
	НоваяЗаявка.ДополнительныеСвойства.Вставить("ЭтоНовый", Истина);
	
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") Тогда
		Для Каждого КлючИЗначение Из ДополнительныеПараметры Цикл
			Если ТипЗнч(КлючИЗначение) = Тип("КлючИЗначение") Тогда
				НоваяЗаявка.ДополнительныеСвойства.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
			Иначе
				НоваяЗаявка.ДополнительныеСвойства.Вставить(КлючИЗначение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(КлиентИзВиджетаЛК) Тогда
		НоваяЗаявка.КонтактнаяИнформация.Загрузить(КлиентИзВиджетаЛК.КонтактнаяИнформация.Выгрузить());
		НоваяЗаявка.НомерТелефона = КлиентИзВиджетаЛК.Телефон;
	КонецЕсли;
	
	Попытка
		НоваяЗаявка.Записать();
	Исключение
		ОписаниеОшибки = НСтр("ru= 'Не удалось создать заявку! ';en= 'Failed to create a request! '") + ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
		
	Если НоваяЗаявка.ДополнительныеСвойства.Свойство("ЭтоНовый") И НоваяЗаявка.Статус = Перечисления.СтатусыЗаявок.Принята Тогда
		Сообщение = "Статус: Новое обращение -> " + Строка(НоваяЗаявка.Статус);
		Если ЗначениеЗаполнено(ПараметрыСеанса.ТекущийСотрудник) Тогда
			Сообщение = Сообщение + Символы.ПС + "Сотрудник: " + Строка(ПараметрыСеанса.ТекущийСотрудник);
		КонецЕсли;
		ОбсужденияСервер.ДобавитьСообщение(Сообщение, НоваяЗаявка.Ссылка,, Истина);
	КонецЕсли;
	
	Возврат НоваяЗаявка.Ссылка;
	
КонецФункции	

// Функция - Создатьзаявку.
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьЗаявку(СтруктураПараметров) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	

	// Создание новой заявки.
	НоваяЗаявка = Справочники.Заявки.СоздатьЭлемент();
	НоваяЗаявка.Заполнить(СтруктураПараметров);
	НоваяЗаявка.ДополнительныеСвойства.Вставить("ЭтоНовый"	  , Истина);
	НоваяЗаявка.ДополнительныеСвойства.Вставить("ОнлайнЗаявка", Истина);  
	
	Попытка
		НоваяЗаявка.Записать();
	Исключение
		ОписаниеОшибки = НСтр("ru= 'Не удалось создать заявку! ';en= 'Failed to create a request! '") + ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
		
	Возврат НоваяЗаявка.Ссылка;
	
КонецФункции	

Функция СоздатьНовуюЗаявку(ДанныеГенерации, ВключитьБизнесЛогику = Ложь, ВернутьОбъект = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если ТипЗнч(ДанныеГенерации) = Тип("Структура") Тогда 
		
		Если ДанныеГенерации.Свойство("СсылкаНовойЗаявки") И ОбщегоНазначения.СсылкаСуществует(ДанныеГенерации.СсылкаНовойЗаявки) Тогда
			Возврат ДанныеГенерации.СсылкаНовойЗаявки;
		КонецЕсли;
		
		НоваяЗаявка = СоздатьЭлемент();
		НоваяЗаявка.Заполнить(ДанныеГенерации);    //НоваяЗаявка.КаналПривлечения  ДанныеГенерации.КаналПривлечения
		Если ДанныеГенерации.Свойство("СформироватьНаименование") Тогда 
			НоваяЗаявка.АктуализироватьНаименованиеОбращения(Истина);
		КонецЕсли;
		Если ЗначениеЗаполнено(НоваяЗаявка.ОсновнойКлиент) И НЕ ЗначениеЗаполнено(НоваяЗаявка.КонтактнаяИнформация) Тогда 
			НоваяЗаявка.КонтактнаяИнформация.Загрузить(НоваяЗаявка.ОсновнойКлиент.КонтактнаяИнформация.Выгрузить());
		КонецЕсли;	
		Если ДанныеГенерации.Свойство("СсылкаНовойЗаявки") Тогда 
			НоваяЗаявка.УстановитьСсылкуНового(ДанныеГенерации.СсылкаНовойЗаявки);
		КонецЕсли;
		Если ДанныеГенерации.Свойство("ИнтерактивнаяЗапись") Тогда 
			НоваяЗаявка.ДополнительныеСвойства.Вставить("ИнтерактивнаяЗапись", Истина);
		КонецЕсли;
		НоваяЗаявка.ДополнительныеСвойства.Вставить("ЭтоНовый", Истина);
		
		Попытка
			НоваяЗаявка.ОбменДанными.Загрузка = НЕ ВключитьБизнесЛогику;			
			НоваяЗаявка.Записать();
			Если ВернутьОбъект Тогда 
				Возврат НоваяЗаявка;
			Иначе 	
				Возврат НоваяЗаявка.Ссылка;
			КонецЕсли;	
		Исключение
			МетаданныеСправочника 		= Метаданные.Справочники.Заявки;
			ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
			
			ОбъектИнициации = Неопределено;
			ДанныеГенерации.Свойство("ОбъектИнициации", ОбъектИнициации);
			// Сформируем комментарий
			Если ОбъектИнициации = Неопределено Тогда 
				ШаблонКомментария = НСтр("ru = 'Не удалось создать новое обращение
				|по причине: %1'");
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонКомментария,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));				
			Иначе
				ПредставлениеОбъекта = СокрЛП(Строка(ОбъектИнициации));
				Если ТипЗнч(ОбъектИнициации) = Тип("ДокументСсылка.Прием") Тогда 
					ШаблонКомментария = НСтр("ru = 'При записи приема: %1, не удалось создать новое обращение
					|по причине: %2'");
				Иначе 
					ШаблонКомментария = НСтр("ru = 'При записи объекта: %1, не удалось создать новое обращение
					|по причине: %2'");
				КонецЕсли;	
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				ШаблонКомментария,
				ПредставлениеОбъекта,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));				
			КонецЕсли;	
			
			// Запишем в журнал
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Создание заявки'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			МетаданныеСправочника,,
			Комментарий);
			
			ВызватьИсключение Комментарий;
		КонецПопытки;	
	КонецЕсли;	
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Создать заявку по входу гостевого клиента
//
// Параметры:
//  Гость				 - 	 - 
//  ДатаПрохода			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  РекламныйИсточник	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьЗаявкуПоВходуГостевогоКлиента(Гость, ДатаПрохода, СтруктурнаяЕдиница = Неопределено, РекламныйИсточник, ОсновнойМенеджер = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если СуществуюЗаявкиПоКлиенту(Гость, СтруктурнаяЕдиница, Истина) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураЗаполнения = Новый Структура();
	СтруктураЗаполнения.Вставить("ДатаСоздания"					, ДатаПрохода);
	СтруктураЗаполнения.Вставить("Фамилия"						, Гость.Фамилия);
	СтруктураЗаполнения.Вставить("Имя"							, Гость.Имя);
	СтруктураЗаполнения.Вставить("Отчество"						, Гость.Отчество);
	//СтруктураЗаполнения.Вставить("РекламнаяПлощадка"			, Справочники.КаналыПривлечения.ГостевойВизит);
	СтруктураЗаполнения.Вставить("РекламныйИсточник"			, Справочники.РекламныеИсточники.ДругойПациент);
	СтруктураЗаполнения.Вставить("ИсточникИнформацииЗначение"	, РекламныйИсточник);
	СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница"			, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));
	СтруктураЗаполнения.Вставить("ОсновнойКлиент"				, Гость);
	СтруктураЗаполнения.Вставить("ОсновнойМенеджер"				, ?(ЗначениеЗаполнено(ОсновнойМенеджер), ОсновнойМенеджер, ПараметрыСеанса.ТекущийСотрудник));
	СтруктураЗаполнения.Вставить("Статус"						, Перечисления.СтатусыЗаявок.НеОбработана);
	СтруктураЗаполнения.Вставить("Комментарий"					, НСтр("ru = 'Создана автоматически при посещения клиники в качестве гостя.'; en = 'Created automatically when visiting the clinic as a guest.'"));
	
	// Создание новой заявки.
	НоваяЗаявка = Справочники.Заявки.СоздатьЭлемент();
	НоваяЗаявка.Заполнить(СтруктураЗаполнения);	
	
	НоваяЗаявка.КонтактнаяИнформация.Загрузить(Гость.КонтактнаяИнформация.Выгрузить());
	
	НоваяЗаявка.ДополнительныеСвойства.Вставить("ЭтоНовый", Истина);	
	
	Попытка
		НоваяЗаявка.Записать();
	Исключение
		ОписаниеОшибки = НСтр("ru= 'Не удалось создать заявку! ';en= 'Failed to create a request! '") + ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
		
	Возврат НоваяЗаявка.Ссылка;
	
КонецФункции

// Функция - Существую заявки по клиенту
//
// Параметры:
//  Контрагент				 - 	 - 
//  СтруктурнаяЕдиница		 - 	 - 
//  АнализироватьОтклоненные - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СуществуюЗаявкиПоКлиенту(Контрагент, СтруктурнаяЕдиница = Неопределено, АнализироватьОтклоненные = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Заявки.Ссылка КАК Заявка,
	               |	Заявки.ДатаСоздания КАК ДатаСоздания,
	               |	Заявки.Статус КАК Статус
	               |ПОМЕСТИТЬ ТаблицаЗаявокКлиента
	               |ИЗ
	               |	Справочник.Заявки КАК Заявки
	               |ГДЕ
	               |	Заявки.ОсновнойКлиент = &ОсновнойКлиент
	               |	И Заявки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаЗаявокКлиента.Заявка КАК Заявка
	               |ИЗ
	               |	ТаблицаЗаявокКлиента КАК ТаблицаЗаявокКлиента
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА &АнализироватьОтклоненные
	               |				ТОГДА ВЫБОР
	               |						КОГДА ТаблицаЗаявокКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена)
	               |							ТОГДА ТаблицаЗаявокКлиента.ДатаСоздания < ДОБАВИТЬКДАТЕ(&ТекущаяДата, ГОД, -1)
	               |						ИНАЧЕ ИСТИНА
	               |					КОНЕЦ
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ОсновнойКлиент"			, Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница));
	Запрос.УстановитьПараметр("ТекущаяДата"				, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("АнализироватьОтклоненные", АнализироватьОтклоненные);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, создает потенциального клиента по заявке.
//
Функция СоздатьПотенциальногоКлиентаПоВходящейЗаявке(Заявка, ОписаниеОшибки) Экспорт
		
	НовыйКлиент = Справочники.Контрагенты.СоздатьЭлемент();	
	
	НовыйКлиент.Фамилия             		= Заявка.Фамилия;
	НовыйКлиент.Имя                 		= Заявка.Имя;
	НовыйКлиент.Отчество            		= Заявка.Отчество;
	НовыйКлиент.ТипКонтрагента      		= Перечисления.ТипыКонтрагентов.Клиенты;
	НовыйКлиент.ЮрФизЛицо           		= Перечисления.ЮрФизЛицо.ФизЛицо;
	НовыйКлиент.ДатаРегистрации     		= ТекущаяДатаСеанса();
	
	ПолСтрокой = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьПолКлиента(НовыйКлиент.Фамилия, НовыйКлиент.Имя, НовыйКлиент.Отчество);
	Если ПолСтрокой = "Мужской" Тогда
		НовыйКлиент.ПолКлиента = Перечисления.ПолФизическогоЛица.Мужской;
	ИначеЕсли ПолСтрокой = "Женский" Тогда
		НовыйКлиент.ПолКлиента = Перечисления.ПолФизическогоЛица.Женский;
	КонецЕсли;
	
	ИскомыйЭлемент = Справочники.Контрагенты.НайтиПоНаименованию("Пациенты", Истина);
	Если ИскомыйЭлемент.Пустая() Тогда
		Клиенты = Справочники.Контрагенты.СоздатьГруппу();
		Клиенты.Наименование = "Пациенты";
		Клиенты.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты;
		Клиенты.Автокоррекция = 1;
		Клиенты.Записать();
	КонецЕсли;
	
	НовыйКлиент.Родитель            		= Справочники.Контрагенты.НайтиПоНаименованию("Пациенты", Истина);
	НовыйКлиент.КаналПривлечения 			= Заявка.КаналПривлечения;
	НовыйКлиент.КаналПривлеченияЗначение	= Заявка.КаналПривлеченияЗначение;
	НовыйКлиент.ИсточникИнформации 			= Заявка.РекламныйИсточник;
	НовыйКлиент.КлиентИсточникИнформации 	= Заявка.ИсточникИнформацииЗначение;
	НовыйКлиент.СотрудникРегистрации	 	= ПараметрыСеанса.ТекущийСотрудник;
	НовыйКлиент.СтруктурнаяЕдиница			= ?(ЗначениеЗаполнено(Заявка.СтруктурнаяЕдиница), Заявка.СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	НовыйКлиент.Куратор 					= ?(ТипЗнч(Заявка.ОсновнойМенеджер) = Тип("СправочникСсылка.Сотрудники"), ?(ЗначениеЗаполнено(Заявка.ОсновнойМенеджер), Заявка.ОсновнойМенеджер, ПараметрыСеанса.ТекущийСотрудник), ПараметрыСеанса.ТекущийПользователь);
	
	// Заполним КИ клиента.
	НовыйКлиент.КонтактнаяИнформация.Загрузить(Заявка.КонтактнаяИнформация.Выгрузить());
	
	Если ТипЗнч(Заявка) = Тип("СправочникОбъект.Заявки") Тогда 
		НовыйКлиент.ДополнительныеСвойства.Вставить("Заявка", Заявка.Ссылка);
	ИначеЕсли ТипЗнч(Заявка) = Тип("СправочникСсылка.Заявки") Тогда 
		НовыйКлиент.ДополнительныеСвойства.Вставить("Заявка", Заявка);
	КонецЕсли;
	
	Попытка
		НовыйКлиент.Записать();
	Исключение
		ОписаниеОшибки = НСтр("ru= 'Не удалось создать клиента! ';en= 'Failed to create client! '") + ОписаниеОшибки();
		Возврат Неопределено;
	КонецПопытки;
	
	РегистрыСведений.СтатусыКонтрагентов.УстановитьСтатусПациенту(НовыйКлиент.Ссылка, Перечисления.СтатусыКонтрагентов.Потенциальный);
		
	//РегистрыСведений.КонтактыМессенджеров.СменитьОбъектИдентификацииПриСозданииКлиента(?(ТипЗнч(Заявка) = Тип("СправочникОбъект.Заявки"), Заявка.Ссылка, Заявка), НовыйКлиент.Ссылка);
	
	Возврат НовыйКлиент.Ссылка;
	
КонецФункции

// Функция - Получить необработанные заявки.
//
// Возвращаемое значение:
//   -
//
Функция ПолучитьНеОбработанныеЗаявки(Пользователь = Неопределено, Сообщение = "") Экспорт
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Заявки.Ссылка КАК Ссылка,
	|	Заявки.ИмяКлиента КАК ИмяКлиента,
	|	Заявки.РекламныйИсточник КАК РекламныйИсточник
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ПометкаУдаления = ЛОЖЬ
	|	И НЕ Заявки.Статус В(ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Принята), ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена))
	|	И ВЫБОР
	|			КОГДА &ТекущийПользователь <> НЕОПРЕДЕЛЕНО
	|				ТОГДА Заявки.ОсновнойМенеджер = &ТекущийПользователь
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ");
	
	Запрос.УстановитьПараметр("ТекущийПользователь", ?(ЗначениеЗаполнено(Пользователь), Пользователь, Неопределено));
	
	МассивНеобработанныхзаявок     = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	КоличествоНеобработанныхЗаявок = МассивНеобработанныхЗаявок.Количество();
	
	Если КоличествоНеобработанныхЗаявок > 0 Тогда
		
		ПредставлениеЗаявок = СтрокаСЧислом(НСтр("ru = '; необработанная заявка; ; необработанных заявки; необработанных заявок; необработанных заявки'; en = '; untreated request;;;; untreated requests'"),
									КоличествоНеобработанныхЗаявок,
									ВидЧисловогоЗначения.Количественное,
									НСтр("ru='L=ru'; en='L=en'"));
		Сообщение           = Нстр("ru = 'У вас '; en = 'You have '") + КоличествоНеобработанныхЗаявок + " " + ПредставлениеЗаявок;
		
	КонецЕсли;
	
	Возврат МассивНеобработанныхЗаявок;
	
КонецФункции

// Функция - Получить заявку по номеру телефона.
//
// Параметры:
//  НомерТелефона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗаявкуПоНомеруТелефона(Знач НомерТелефона, МассивСтатусов = Неопределено, СтруктурнаяЕдиница = Неопределено, ИскатьПоВсемКлиникам = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если ТипЗнч(НомерТелефона) = Тип("Массив") Тогда 
		МассивНомеровТелефонов = НомерТелефона;
	Иначе 	
		МассивНомеровТелефонов = Новый Массив;
		Если ТипЗнч(НомерТелефона) = Тип("Строка") Тогда 
			МассивНомеровТелефонов.Добавить(НомерТелефона);
			МассивНомеровТелефонов.Добавить(ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Ложь));
			МассивНомеровТелефонов.Добавить(ОбщегоНазначенияКлиентСерверСтоматология.ВернутьПриведенныйНомер(НомерТелефона, Истина));
			
			ОбъектXDTOИнформации = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(НомерТелефона, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента);
			
			НомерТелефона = "+7" + ОбъектXDTOИнформации.Состав.КодГорода + ОбъектXDTOИнформации.Состав.Номер;
			МассивНомеровТелефонов.Добавить(НомерТелефона);
			НомерТелефона = "+8" + ОбъектXDTOИнформации.Состав.КодГорода + ОбъектXDTOИнформации.Состав.Номер;
			МассивНомеровТелефонов.Добавить(НомерТелефона);	
		ИначеЕсли ТипЗнч(НомерТелефона) = Тип("Массив") Тогда
			Для Каждого НомерТелефонаЭлемент Из НомерТелефона Цикл 
				МассивНомеровТелефонов.Добавить(НомерТелефонаЭлемент);
				ЗначенияПолей = Новый СписокЗначений;
				УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(НомерТелефонаЭлемент, ЗначенияПолей);
				Если МассивНомеровТелефонов.Найти(НомерТелефонаЭлемент) = Неопределено Тогда 
					МассивНомеровТелефонов.Добавить(НомерТелефонаЭлемент);
				КонецЕсли;	
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Заявки.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена)
	|			ТОГДА 2
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК СортировкаПоСтатусу,
	|	ВЫБОР
	|		КОГДА Заявки.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ТОГДА 2
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК СортировкаПоСтруктурнойЕдинице
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	(Заявки.КонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|				И Заявки.КонтактнаяИнформация.НомерТелефона В (&МассивНомеровТелефонов)
	|			ИЛИ ВЫРАЗИТЬ(Заявки.КонтактнаяИнформация.Представление КАК СТРОКА(200)) В (&МассивНомеровТелефонов))
	|	И &УсловиеСтатусы
	|	И &УсловиеСтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	СортировкаПоСтруктурнойЕдинице,
	|	СортировкаПоСтатусу,
	|	Заявки.ДатаСоздания УБЫВ");
	
	Запрос.УстановитьПараметр("МассивНомеровТелефонов", МассивНомеровТелефонов);
	Если ЗначениеЗаполнено(МассивСтатусов) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатусы", "Заявки.Статус В(&МассивСтатусов)");
		Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатусы", "ИСТИНА");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) ИЛИ СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка() Тогда
		МассивСтруктурныхЕдиниц = Новый Массив;
		МассивСтруктурныхЕдиниц.Добавить(СтруктурнаяЕдиница);
		Если МассивСтруктурныхЕдиниц.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
			МассивСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "Заявки.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)");
		Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Если РезультатЗапроса.Следующий() Тогда
		Возврат РезультатЗапроса.Ссылка;
	ИначеЕсли ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) И ИскатьПоВсемКлиникам Тогда
		МассивСтатусов = Новый Массив;
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.НеОбработана);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ОтвеченныйДиалог);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ОтвеченныйЗвонок);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.Перезвонить);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ПропущенныйЗвонок);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.Отклонена);
		
		Возврат ПолучитьЗаявкуПоНомеруТелефона(МассивНомеровТелефонов, МассивСтатусов); 
	КонецЕсли;
	
	Возврат Справочники.Заявки.ПустаяСсылка();

КонецФункции

// Функция - Получить массив сотрудников для оповещения о новых заявках.
//
// Возвращаемое значение:
//   -
//
Функция ПолучитьСотрудниковДляОповещенияОНовыхЗаявках() Экспорт
	
	МассивРолей = Новый Массив;
	МассивРолей.Добавить(Перечисления.РольПользователя.АдминистраторБазыДанных);
	МассивРолей.Добавить(Перечисления.РольПользователя.Директор);
	МассивРолей.Добавить(Перечисления.РольПользователя.МенеджерОтделаПродаж);
	МассивРолей.Добавить(Перечисления.РольПользователя.РуководительОтделаПродаж);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.РольПользователя КАК РольПользователя
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.РольПользователя В(&МассивРолей)");
	
	Запрос.УстановитьПараметр("МассивРолей", МассивРолей);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Процедура - Актуализировать основного клиента заявки.
//
// Параметры:
//  Заявка			 - 	 - 
//  Контрагент	 - 	 - 
//
Процедура АктуализироватьОсновногоКлиентаЗаявки(Заявка, Контрагент) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Заявка.ОсновнойКлиент <> Контрагент Тогда 
		
		ЗаявкаОбъект 				= Заявка.ПолучитьОбъект();
		ЗаявкаОбъект.ОсновнойКлиент = Контрагент;
		ЗаявкаОбъект.Статус         = Перечисления.СтатусыЗаявок.Принята;
		
		Попытка
			ЗаявкаОбъект.Записать();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не удалось актуализировать заявку!'; en = 'Failed to update the application!'") + Символы.ПС + ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Функция - Получить заявку контрагента
//
// Параметры:
//  Контрагент	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗаявкуКонтрагента(Контрагент, МассивСтатусов = Неопределено, СтруктурнаяЕдиница = Неопределено, ИскатьПоВсемКлиникам = Ложь) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Заявки.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена)
	|			ТОГДА 2
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК СортировкаПоСтатусу,
	|	ВЫБОР
	|		КОГДА Заявки.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ТОГДА 2
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК СортировкаПоСтруктурнойЕдинице
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	НЕ Заявки.ПометкаУдаления
	|	И Заявки.ОсновнойКлиент = &Контрагент
	|	И &УсловиеСтатусы
	|	И &УсловиеСтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	СортировкаПоСтруктурнойЕдинице,
	|	СортировкаПоСтатусу,
	|	Заявки.ДатаСоздания УБЫВ");
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Если ЗначениеЗаполнено(МассивСтатусов) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатусы", "Заявки.Статус В(&МассивСтатусов)");
		Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтатусы", "ИСТИНА");
	КонецЕсли;
	
	МассивСтруктурныхЕдиниц = Неопределено;
	Если ЗначениеЗаполнено(СтруктурнаяЕдиница) ИЛИ СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка() Тогда
		МассивСтруктурныхЕдиниц = Новый Массив;
		МассивСтруктурныхЕдиниц.Добавить(СтруктурнаяЕдиница);
		Если МассивСтруктурныхЕдиниц.Найти(Справочники.СтруктурныеЕдиницы.ПустаяСсылка()) = Неопределено Тогда 
			МассивСтруктурныхЕдиниц.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
		КонецЕсли;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "Заявки.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)");
		Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;	
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	ИначеЕсли ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) И ИскатьПоВсемКлиникам Тогда
		МассивСтатусов = Новый Массив;
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.НеОбработана);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ОтвеченныйДиалог);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ОтвеченныйЗвонок);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.Перезвонить);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.ПропущенныйЗвонок);
		МассивСтатусов.Добавить(Перечисления.СтатусыЗаявок.Отклонена);
		
		Возврат ПолучитьЗаявкуКонтрагента(Контрагент, МассивСтатусов); 
	КонецЕсли;	
	
	Возврат Неопределено;
	
КонецФункции

// Функция, возвращает заявку по номеру JivoSite
//
Функция ПолучитьЗаявкуПоНомеруJivoSite(НомерДживоСайта) Экспорт 

	Если НЕ ЗначениеЗаполнено(НомерДживоСайта) Тогда
		Возврат Неопределено;
	КонецЕсли;
		
	ВнешняяСистема = Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.JivoSite);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтактыМессенджеров.ОбъектИдентификации КАК ОбъектИдентификации
	|ИЗ
	|	РегистрСведений.КонтактыМессенджеров КАК КонтактыМессенджеров
	|ГДЕ
	|	КонтактыМессенджеров.Идентификатор = &Идентификатор
	|	И КонтактыМессенджеров.ВнешняяСистема = &ВнешняяСистема");
	Запрос.УстановитьПараметр("Идентификатор", НомерДживоСайта);
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка[0], Неопределено);	

КонецФункции

// Функция, возвращает актульные заявки контрагента.
//
Функция ПолучитьМассивАктуальныхЗаявокКонтрагента(ТекстПоиска = "", Контрагент = Неопределено) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Заявки.Ссылка КАК Заявка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Сделки.Ссылка КАК Ссылка
	|		ИЗ
	|			Справочник.Сделки КАК Сделки
	|		ГДЕ
	|			НЕ Сделки.ПометкаУдаления
	|			И Сделки.Контрагент = &ОсновнойКлиент) КАК ВложенныйЗапрос
	|		ПО Заявки.Ссылка = ВложенныйЗапрос.Ссылка.Заявка
	|ГДЕ
	|	Заявки.ОсновнойКлиент = &ОсновнойКлиент
	|	И Заявки.ОсновнойКлиент.Наименование ПОДОБНО &Текст
	|	И НЕ Заявки.ПометкаУдаления
	|	И НЕ Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена)
	|	И ВложенныйЗапрос.Ссылка.Заявка ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	Заявки.ДатаСоздания УБЫВ");
	
	Запрос.УстановитьПараметр("ОсновнойКлиент", Контрагент);
	Запрос.УстановитьПараметр("Текст"         , "%" + ТекстПоиска + "%");
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Заявка");	
	
КонецФункции	

// Функция, возвращает заявки контрагента.
//
Функция ПолучитьМассивЗаявокКонтрагента(Контрагент = Неопределено) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Заявки.Ссылка КАК Заявка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ОсновнойКлиент = &ОсновнойКлиент
	|	И НЕ Заявки.ПометкаУдаления
	|	И НЕ Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отклонена)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Заявки.ДатаСоздания УБЫВ");
	
	Запрос.УстановитьПараметр("ОсновнойКлиент", Контрагент);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Заявка");	
	
