	КонецЕсли;    
	
	СписокАдресовЭП = Новый Массив;
	СписокАдресовЭП.Добавить(ДанныеКИ.Представление);
	
	ПараметрыПисьма = Новый Структура("Получатель,АдресЭП", Объект.Контрагент, ДанныеКИ.Представление);
	
