#Область ОбработчикиСобытийФормы  
  
&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Автооткрытие",Автооткрытие);
	
	Если Автооткрытие Тогда
		Открывать = ХранилищеСистемныхНастроек.Загрузить("СофтФон", "ОткрыватьСофтФон");		
		Если Открывать = Неопределено или (Не Открывать = Неопределено и Не Открывать) Тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;	
	КонецЕсли;	
	
	
	СоздаватьДокументВзаимодействие = ?(ХранилищеСистемныхНастроек.Загрузить("СофтФон", "СоздаватьДокументВзаимодействие") = Неопределено, Ложь, 
	ХранилищеСистемныхНастроек.Загрузить("СофтФон", "СоздаватьДокументВзаимодействие"));

КонецПроцедуры 

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии"
//
Процедура ПриОткрытии(Отказ)
	
	хИсторияЗвонков.Параметры.УстановитьЗначениеПараметра("ПользовательSip", Объект.RegisterName);
	
	Если ЭтаФорма.Окно = Неопределено Тогда
		Отказ = Истина;
		ОткрытьФорму("Обработка.СофтФон.Форма.Форма", , , , ВариантОткрытияОкна.ОтдельноеОкно);		
		Возврат;
	КонецЕсли;
	
	Если СофтФон = Неопределено Тогда
		Попытка
			СофтФон = Новый COMОбъект("HelixSoftPhone");
			СофтФон = Неопределено;
		Исключение
			Отказ = Истина;
			НастройкиФормы = Новый Структура("Объект", Объект);
			ОткрытьФорму("Обработка.СофтФон.Форма.ФормаНастройки",НастройкиФормы,,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
			Возврат;
		КонецПопытки;
	КонецЕсли;	
	
	Каталог = КаталогВременныхФайлов();	
	ФайлВходящийЗвонок = Новый Файл(Каталог+"basic_ring.wav");
	ФайлИсходящийЗвонок = Новый Файл(Каталог+"ringback.wav");
	ФайлВходящийЗвонок.НачатьПроверкуСуществования(Новый ОписаниеОповещения("ПриОткрытииПослеПроверкиВходящегоЗвонка", ЭтотОбъект, 
	Новый Структура("Каталог, ФайлИсходящийЗвонок", Каталог, ФайлИсходящийЗвонок)));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииПослеПроверкиВходящегоЗвонка(Существует, ДополнительныеПараметры) Экспорт
	
	Каталог = ДополнительныеПараметры.Каталог;
	ФайлИсходящийЗвонок = ДополнительныеПараметры.ФайлИсходящийЗвонок;
	
	Если Не Существует Тогда
		ВернутьМакет(Истина).Записать(Каталог+"basic_ring.wav");
	КонецЕсли;
	
	ФайлИсходящийЗвонок.НачатьПроверкуСуществования(Новый ОписаниеОповещения("ПриОткрытииПослеПроверкиИсходящегоЗвонка", ЭтотОбъект, 
	Новый Структура("Каталог", Каталог)));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииПослеПроверкиИсходящегоЗвонка(Существует, ДополнительныеПараметры) Экспорт
	
	Каталог = ДополнительныеПараметры.Каталог;

	Если Не Существует Тогда
		ВернутьМакет(Ложь).Записать(Каталог+"ringback.wav");
	КонецЕсли;	
	
	Попытка
		
		Если СофтФон = Неопределено Тогда
			
			СофтФон = Новый COMОбъект("HelixSoftPhone");
			
		КонецЕсли;
		
		Если Не СофтФон.GetActiveSoftPhone() И Автооткрытие Тогда
			Отказ = Истина;
			Возврат;
		КонецЕсли;
		
		Если Не СофтФон.GetActiveSoftPhone() Тогда
			ОткрытьФорму("Обработка.СофтФон.Форма.ФормаАктивации",,,,,, Новый ОписаниеОповещения("ПриОткрытииПродолжение", ЭтотОбъект,Новый Структура("Каталог",Каталог)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			Возврат;
		КонецЕсли;
		
		ПриОткрытииЗавершение(СофтФон,Каталог);
		
	Исключение			
		
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено или Результат = Ложь Тогда
		ЗакрытьСофтФон = Истина;
		Закрыть();
		Возврат;
	КонецЕсли;
	
	ПриОткрытииЗавершение(ДополнительныеПараметры.СофтФон,ДополнительныеПараметры.Каталог);

КонецПроцедуры            

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии"
//
// Параметры:
//  СофтФон	 - 	 - 
//
Процедура ПриОткрытииЗавершение(СофтФон,Каталог)

	Попытка
		
		СофтФон.preStart();
		СофтФон.SetRingtone(Каталог+"basic_ring.wav");
		СофтФон.SetRingBack(Каталог+"ringback.wav"); 
		УстановитьНастройки();						
		СофтФон.SetNoResize(365, 650);
		
	Исключение
		
	КонецПопытки;
	
	УстановитьВидимостьМикрофона();
	
	Объект.RegName = "";
	Объект.RegStatus = "Отключен";
	Элементы.ГруппаКлавиатура.Видимость = ложь;		
	// Элементы.хИсторияЗвонковВсеЗвонки.Пометка = Истина;
	Элементы.хИсторияЗвонковВсеЗвонки.КнопкаПоУмолчанию = Истина;
	
	Если не СофтФон = Неопределено Тогда
		ПодключитьОбработчикОжидания("ВыполнитьРегистрацию", 1, Истина);
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ОбработкаАктивизацииОкна", 1);
	ПодключитьОбработчикОжидания("ПроверитьПодключение", 30);
	
КонецПроцедуры   

&НаКлиенте
// Процедура, обработчик события "ПередЗакрытием"
//
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы ИЛИ ЗакрытьСофтФон Тогда
		ЗакрытьСофтФон = Ложь;
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;
	ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект), "Закрыть Софтфон?", РежимДиалогаВопрос .ДаНет); 
		
КонецПроцедуры

&НаКлиенте
// Процедура - Перед закрытием завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПередЗакрытиемЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ЗакрытьСофтФон = Истина;
		Закрыть();
		Возврат;
	КонецЕсли;
	
	Если Не СофтФон = Неопределено и СофтФон.LineRegister() Тогда	
		СофтФон.UnregisterLine();
		Счетчик = 0;
		Пока Не СофтФон.LineUnRegister() Цикл
			Счетчик = Счетчик + 1;
		КонецЦикла;			
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьСписки" Тогда
		Элементы.хИсторияЗвонков.Обновить();
		Элементы.ТелефонныйСправочник.Обновить();
	ИначеЕсли ИмяСобытия = "ОбновитьМикрофон" Тогда
		УстановитьВидимостьМикрофона();
	КонецЕсли;     	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ВнешнееСобытие"
//
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	
	Если Событие = "ChangedPhoneLineInformation" Тогда
		ЭтаФорма.Заголовок  = СофтФон.RegName;
		Объект.RegStatus = СофтФон.LineRegState;
	ИначеЕсли Событие = "ChangedCallState" Тогда		
		ДанныеЗвонка = ПолучитьИнформациюЗвонка(Данные);
		Если Не ДанныеЗвонка.Входящий Тогда
			ИдИсходящегоЗвонка = Данные;
			Элементы.ДекорацияСостояниеИсходящегоЗвонка.Заголовок = ДанныеЗвонка.Состояние;
			Если ДанныеЗвонка.Состояние = "Разговор" Тогда
				ДатаИсходящегоЗвонка = ВернутьСерверноеВремя();
			КонецЕсли;			
			Если ДанныеЗвонка.Завершен Тогда
				ИдИсходящегоЗвонка = "";
				СтатусИсходящегоЗвонка = ДанныеЗвонка.Состояние;
				ПодключитьОбработчикОжидания("УбратьВидимостьИсходящегоЗвонка", 2, Истина);
				Если СоздаватьДокументВзаимодействие Тогда // Взаимодействие
					ДокСобытие = СоздатьДокументВзаимодействие(Новый Структура("НовыйДокумент, Клиент, Телефон, ДатаНачалаРазговора, Входящий", 
					Истина, ДанныеЗвонка.ИнфоКлиента.Анкета, ДанныеЗвонка.НомерТелефона, ТекущаяДата(), Ложь));
					// СтрокаТЧ.Событие = ДокСобытие;     
					ОткрытьФорму("Документ.Взаимодействие.Форма.ФормаДокумента", Новый Структура("Ключ", ДокСобытие));
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если ДанныеЗвонка.Завершен Тогда
				НайденныеСтроки = АктивныеВходящиеЗвонки.НайтиСтроки(Новый Структура("Ид", Данные));
				Если НайденныеСтроки.Количество() > 0 тогда
					Для Каждого СтрокаТЧ из НайденныеСтроки Цикл
						СтрокаТЧ.Состояние = ДанныеЗвонка.Состояние;
						СтрокаТЧ.Завершен = ДанныеЗвонка.Завершен;
						СтрокаТЧ.ДатаОкончанияРазговора = ВернутьСерверноеВремя();
						Если ВводДоступен() Тогда
							Если ЗначениеЗаполнено(СтрокаТЧ.ИдОтображаемогоЭлемента) Тогда
								Элементы["ДекорацияВхСостояние"+СтрокаТЧ.ИдОтображаемогоЭлемента].Заголовок = ДанныеЗвонка.Состояние;
							КонецЕсли;
						КонецЕсли;						
						УбратьВидимостьВходящегоЗвонка();
						
					КонецЦикла;
				КонецЕсли;
			Иначе
				НайденныеСтроки = АктивныеВходящиеЗвонки.НайтиСтроки(Новый Структура("Ид", Данные));
				Если НайденныеСтроки.Количество() > 0 тогда
					Для Каждого СтрокаТЧ из НайденныеСтроки Цикл
						СтрокаТЧ.Состояние = ДанныеЗвонка.Состояние;
						Если ДанныеЗвонка.Состояние = "Разговор" Тогда
							СтрокаТЧ.ДатаНачалаРазговора = ВернутьСерверноеВремя();		
							Если СоздаватьДокументВзаимодействие Тогда // Взаимодействие
								ДокСобытие = СоздатьДокументВзаимодействие(Новый Структура("НовыйДокумент, Клиент, Телефон, ДатаНачалаРазговора, Входящий", 
								Истина, СтрокаТЧ.Анкета, СтрокаТЧ.НомерТелефона, СтрокаТЧ.ДатаНачалаРазговора, Истина));
								СтрокаТЧ.Событие = ДокСобытие;     
								ОткрытьФорму("Документ.Взаимодействие.Форма.ФормаДокумента", Новый Структура("Ключ", ДокСобытие));
							КонецЕсли;							
						КонецЕсли;
						Если ЗначениеЗаполнено(СтрокаТЧ.ИдОтображаемогоЭлемента) Тогда
							Элементы["ДекорацияВхСостояние"+СтрокаТЧ.ИдОтображаемогоЭлемента].Заголовок = ДанныеЗвонка.Состояние;
						КонецЕсли;						
					КонецЦикла;
				КонецЕсли; 				
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли Событие = "IncomingCall" Тогда		
		ДанныеЗвонка = ПолучитьИнформациюЗвонка(Данные);		
		СоздатьВходящийЗвонок(Данные, ДанныеЗвонка);
		ОбновитьАктивныеЗвонки();
		УстановитьТекущийЭлемент();		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗагрузкойДанныхИзНастроекНаСервере"
//
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	УстановитьКодекиПоУмолчанию = Истина;
	
	Для Каждого СтрокаНастроек из Настройки Цикл
		Если СтрокаНастроек.Ключ = "СписокКодеков" Тогда
			УстановитьКодекиПоУмолчанию = Ложь;
        КонецЕсли;
	КонецЦикла;
	
	Если УстановитьКодекиПоУмолчанию Тогда
		Список = Новый СписокЗначений;
		Список.Добавить("6");
		Список.Добавить("7");
		Список.Добавить("10");
		Список.Добавить("11");
		Список.Добавить("13");
		Список.Добавить("14");
		Список.Добавить("15");
		Список.Добавить("16");
		Список.Добавить("18");
		Настройки.Вставить("СписокКодеков", Список);
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

 #Область СлужебныеПроцедурыИФункции
 
&НаКлиенте
// Процедура, выполняет обновление картинки микрофона
//
Процедура УстановитьВидимостьМикрофона()
	
	Если Не СофтФон = Неопределено Тогда
		Объект.MicrophoneMute = СофтФон.MicrophoneMute;	
		Если Объект.MicrophoneMute Тогда
			Элементы.Микрофон.Картинка = Элементы.КартинкаМикрофонВыключить.Картинка;
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, мониторит событие активизации окна
//
Процедура ОбработкаАктивизацииОкна()
	
	Если ВводДоступен() Тогда
		УстановкаВидимостиЗвонков();
	КонецЕсли;
	
	СоздатьОповещение(); 
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет проверку линии
//
Процедура ПроверитьПодключение()
	
	Если Объект.RegStatus = "Регистрация тайм-аут" Тогда		
		Если  Не СофтФон = Неопределено и Не СофтФон.LineRegister() Тогда
			СофтФон.ATAMode				 = Объект.ATAMode;
			СофтФон.UserID				 = Объект.UserID;
			СофтФон.DisplayName 		 = Объект.DisplayName;
			СофтФон.RegisterName		 = Объект.RegisterName;
			СофтФон.DomainServer 		 = Объект.DomainServer;
			СофтФон.RegisterPassword     = Объект.RegisterPassword;
			СофтФон.RegistrationRequired = Объект.RegistrationRequired;
			СофтФон.Start();	
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет создание оповещения 
//
Процедура СоздатьОповещение()
	
	НайденныеСтроки = АктивныеВходящиеЗвонки.НайтиСтроки(Новый Структура("Состояние", "Вызов"));	
	
	ТекстСообщения = "";	
	
	Если НайденныеСтроки.Количество() > 0 Тогда		
		Количество = НайденныеСтроки.Количество();
		Если Количество > 1 Тогда
			ТекстШапки = "Входящие звоноки ("+Количество+")";
		Иначе
			ТекстШапки = "Входящий звонок";
		КонецЕсли;	
		
		ТекСтрока = 1;
		Для Каждого ДанныеЗвонка из НайденныеСтроки Цикл
			ТекстСообщения = ТекстСообщения + ДанныеЗвонка.НомерТелефона + Символы.ПС;		
			Если ЗначениеЗаполнено(ДанныеЗвонка.Анкета) Тогда                                       		
				ТекстСообщения = ТекстСообщения + ДанныеЗвонка.Анкета + Символы.ПС;		
			КонецЕсли;
			ТекстСообщения = ТекстСообщения + ДанныеЗвонка.ФИО+ Символы.ПС;		      		
			Если Не Количество = ТекСтрока Тогда
				 ТекстСообщения = ТекстСообщения + "----------------" + Символы.ПС;
			КонецЕсли;
			ТекСтрока = ТекСтрока + 1;
		КонецЦикла;
	ПоказатьОповещениеПользователя(ТекстШапки, "e1cib/app/Обработка.СофтФон", ТекстСообщения, Элементы.КартинкаЗвонок.Картинка);
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
// Процедура, устанавливает видимость звонков
//
Процедура УстановкаВидимостиЗвонков()
	
	Массив = Новый Массив;
	Массив.Добавить(1);
	Массив.Добавить(2);
	Массив.Добавить(3);
	Массив.Добавить(4);
	Массив.Добавить(5);

	Для Каждого СтрокаТЧ из Массив Цикл
		Если Элементы["ГруппаВхЗвонок"+СтрокаТЧ].Видимость Тогда
			 НайденныеСтроки = АктивныеВходящиеЗвонки.НайтиСтроки(Новый Структура("ИдОтображаемогоЭлемента", Строка(СтрокаТЧ)));
			 Если НайденныеСтроки.Количество() = 0 Тогда
				  Элементы["ГруппаВхЗвонок"+СтрокаТЧ].Видимость = Ложь;
			 КонецЕсли;
		КонецЕсли;
	КонецЦикла;		
		
	НайденныеСтроки = АктивныеВходящиеЗвонки.НайтиСтроки(Новый Структура("Завершен", Ложь));
	
	Для Каждого СтрокаМассива из НайденныеСтроки Цикл
		Если ЗначениеЗаполнено(СтрокаМассива.ИдОтображаемогоЭлемента) Тогда
			Продолжить;
		КонецЕсли;
		НомерГруппы = 0;
		Для Каждого СтрокаТЧ из Массив Цикл
			Если Не Элементы["ГруппаВхЗвонок"+СтрокаТЧ].Видимость Тогда
				НомерГруппы = СтрокаТЧ;
			КонецЕсли;
		КонецЦикла;	                                         
			
		Если ЗначениеЗаполнено(НомерГруппы) Тогда
			СтрокаМассива.ИдОтображаемогоЭлемента = НомерГруппы;
			Элементы["ГруппаВхЗвонок"+НомерГруппы].Видимость = Истина;
			Элементы["ДекорацияВхНомер"+НомерГруппы].Заголовок = СтрокаМассива.НомерТелефона;
			ЭтаФорма["ДекорацияВхИмяАбонента"+НомерГруппы] = СтрокаМассива.ФИО;
			Элементы["ДекорацияВхСостояние"+НомерГруппы].Заголовок = СтрокаМассива.Состояние;
			Элементы["Ответить" + НомерГруппы].Картинка = Элементы.КартинкаЗвонок.Картинка;
			Элементы["Ответить" + НомерГруппы].Заголовок = "Ответить";
		КонецЕсли;  			
	КонецЦикла;  	
	
КонецПроцедуры

