// Функция получает таблицу значений из динамического списка.
//
Функция ПолучитьТаблицуЗначенийДинамическогоСписка()
	
	// Получаем схему компановки данных (здесь хранится текст запроса)
	Схема 	  = Элементы.Список.ПолучитьИсполняемуюСхемуКомпоновкиДанных();	
	Настройки = Элементы.Список.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();

	// Выводим динамический список в таблицу значений
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(Схема, Настройки,,, Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	Возврат ПроцессорВывода.Вывести(ПроцессорКомпоновки);
		
КонецФункции

&НаСервере
// Процедура, СоздатьУсловноеОформление.
//
Процедура СоздатьУсловноеОформление()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(ЭтапыСделок.ЦветЭтапа КАК СТРОКА(100)) КАК ЦветЭтапа
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	НЕ (ВЫРАЗИТЬ(ЭтапыСделок.ЦветЭтапа КАК СТРОКА(100))) = """"";
	
	ТаблицаЦветов = Запрос.Выполнить().Выгрузить();
		
	Для Каждого СтрокаТЧ Из ТаблицаЦветов Цикл
		
		ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЦветЭтапа");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = СтрокаТЧ.ЦветЭтапа;
		ЭлементОтбора.Использование  = Истина;
		
		ЦветЭтапа = ЗначениеИзСтрокиВнутр(СтрокаТЧ.ЦветЭтапа);
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветЭтапа);
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ПолучитьЦветТекстаПоФону(ЦветЭтапа));
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЭтапСделки");
		ПолеОформления.Использование = Истина;
		
		// Условное оформление для успеха.
		ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЭтапСделки");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно; 
		ЭлементОтбора.ПравоеЗначение = Справочники.ЭтапыСделок.Успех;
		ЭлементОтбора.Использование  = Истина;
		
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона"  , Новый Цвет(72, 193, 123));
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(255, 255, 255));
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЭтапСделки");
		ПолеОформления.Использование = Истина;
		
		// Условное оформление для отказа.
		ЭлементУФ = Список.УсловноеОформление.Элементы.Добавить();
		ЭлементОтбора = ЭлементУФ.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЭтапСделки");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Справочники.ЭтапыСделок.Отказ;
		ЭлементОтбора.Использование  = Истина;
		
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветФона"  , Новый Цвет(246, 110, 110));
		ЭлементУФ.Оформление.УстановитьЗначениеПараметра("ЦветТекста",(Новый Цвет(255, 255, 255)));
		
		ПолеОформления = ЭлементУФ.Поля.Элементы.Добавить();
		ПолеОформления.Поле 		 = Новый ПолеКомпоновкиДанных("ЭтапСделки");
		ПолеОформления.Использование = Истина;
		
	КонецЦикла;
				
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает цвет текста от передаваемого цвета фона.
//
Функция ПолучитьЦветТекстаПоФону(ЦветФона)
	
	Если (ЦветФона.Зеленый + ЦветФона.Красный + ЦветФона.Синий) > 383 Тогда
		Возврат Новый Цвет(60,60,60);		
	Иначе
		Возврат Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецФункции

&НаСервере
// Процедура, устанавливает заголовки дополнительных отборов "кол-во без сделок" и "кол-во с просроченными задачами".
//
Процедура УстановитьЗаголовкиДополнительныхОтборов()
	
	СтруктураОтборов = Новый Структура;
	СтруктураОтборов.Вставить("ОтборМенеджер"				, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Менеджер"));
	СтруктураОтборов.Вставить("ОтборСтруктурнаяЕдиница"		, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_СтруктурнаяЕдиница"));
	//СтруктураОтборов.Вставить("ОтборЭтап"					, УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Этап"));

	СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ВыгрузитьЗначения();
	Если НЕ ЗначениеЗаполнено(СписокМенеджеров) Тогда
		 СписокМенеджеров = СтруктураОтборов.ОтборМенеджер.ДоступныеЗначения.ВыгрузитьЗначения();
	КонецЕсли;
	
	СписокКлиник = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ВыгрузитьЗначения();
	Если НЕ ЗначениеЗаполнено(СписокКлиник) Тогда
		СписокКлиник = СтруктураОтборов.ОтборСтруктурнаяЕдиница.ДоступныеЗначения.ВыгрузитьЗначения();
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Ссылка КАК Сделка
	|ПОМЕСТИТЬ ТаблицаСделок
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	|		ПО Сделки.Контрагент = КонтрагентыСведенияДляСписка.Контрагент
	|ГДЕ
	|	Сделки.ВидСделки = &ВидСделки
	|	И ВЫБОР
	|			КОГДА &ОтборСтатусПациента = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ КонтрагентыСведенияДляСписка.Статус = &ОтборСтатусПациента
	|		КОНЕЦ
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.ПустаяСсылка)
	|	И Сделки.СтруктурнаяЕдиница В(&СписокКлиник)
	|	И Сделки.Менеджер В(&СписокМенеджеров)
	|	И Сделки.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СделкиСведенияДляСписка.Сделка) КАК КоличествоБезАктивности
	|ИЗ
	|	РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|ГДЕ
	|	СделкиСведенияДляСписка.Сделка В
	|			(ВЫБРАТЬ
	|				ТаблицаСделок.Сделка
	|			ИЗ
	|				ТаблицаСделок)
	|	И СделкиСведенияДляСписка.ЗапланированнаяЗадача = ЗНАЧЕНИЕ(Задача.Взаимодействие.ПустаяСсылка)
	|	И СделкиСведенияДляСписка.ЗапланированнаяПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сделки.Сделка КАК Сделка,
	|	СделкиСведенияДляСписка.ЗапланированнаяЗадача КАК ЗапланированнаяЗадача
	|ПОМЕСТИТЬ СделкиЗапланированнаяЗадача
	|ИЗ
	|	ТаблицаСделок КАК Сделки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СделкиСведенияДляСписка КАК СделкиСведенияДляСписка
	|		ПО Сделки.Сделка = СделкиСведенияДляСписка.Сделка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СделкиЗапланированнаяЗадача.Сделка КАК Ссылка,
	|	СделкиЗапланированнаяЗадача.ЗапланированнаяЗадача.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата
	|ПОМЕСТИТЬ СделкиЗадачаНазначеннаяДата
	|ИЗ
	|	СделкиЗапланированнаяЗадача КАК СделкиЗапланированнаяЗадача
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СделкиЗадачаНазначеннаяДата.Ссылка) КАК КоличествоПросроченныхЗадач
	|ИЗ
	|	СделкиЗадачаНазначеннаяДата КАК СделкиЗадачаНазначеннаяДата
	|ГДЕ
	|	СделкиЗадачаНазначеннаяДата.ЗадачаНазначеннаяДата МЕЖДУ &ДатаНачалаЗапланированнойЗадачи И &ДатаОкончанияЗапланированнойЗадачи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СделкиЗадачаНазначеннаяДата.Ссылка) КАК КоличествоЗадач
	|ИЗ
	|	СделкиЗадачаНазначеннаяДата КАК СделкиЗадачаНазначеннаяДата
	|ГДЕ
	|	СделкиЗадачаНазначеннаяДата.ЗадачаНазначеннаяДата МЕЖДУ &НачалоДня И &КонецДня";
	
	Запрос.УстановитьПараметр("СписокМенеджеров"					, СписокМенеджеров);
	Запрос.УстановитьПараметр("ДатаНачалаЗапланированнойЗадачи"     , Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаОкончанияЗапланированнойЗадачи"  , КонецДня(ТекущаяДатаСеанса() - 86400));
	Запрос.УстановитьПараметр("НачалоДня"							, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("КонецДня"							, КонецДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("СписокКлиник"						, СписокКлиник);
	Запрос.УстановитьПараметр("ВидСделки"							, ЭтотОбъект.ОтборВидСделки);
	Запрос.УстановитьПараметр("ОтборСтатусПациента"					, ЭтотОбъект.ОтборСтатусПациента);
	
	// Для единообразия списка и канбана подсчет ведется без разреза по этапу.
	//
	//// Отбор этап сделки.
	//Если ЗначениеЗаполнено(СтруктураОтборов.ОтборЭтап) Тогда	
	//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление + "Сделки.ЭтапСделки В (&ОтборЭтап)");		
	//	Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ВыгрузитьЗначения());
	//Иначе
	//	Если СтруктураОтборов.ОтборЭтап.ДоступныеЗначения.Количество() <> 0 Тогда 
	//		ВариантОтбора = СтруктураОтборов.ОтборЭтап.ДоступныеЗначения[0].Представление;
	//	Иначе 
	//		ВариантОтбора = "";
	//	КонецЕсли;	
	//	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", ВариантОтбора + "Сделки.ЭтапСделки В (&ОтборЭтап)");			
	//	Запрос.УстановитьПараметр("ОтборЭтап", СтруктураОтборов.ОтборЭтап.ДоступныеЗначения.ВыгрузитьЗначения());		
	//	// Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеЭтап", "ИСТИНА");		
	//КонецЕсли;
	
	РезультатЗапроса 				   	= Запрос.ВыполнитьПакет();
	ВыборкаКоличестваБезАктивности 		= РезультатЗапроса[1].Выбрать();	
	ВыборкаКоличествоПросроченныхЗадач 	= РезультатЗапроса[4].Выбрать();
	ВыборкаКоличествоЗадачиНаСегодня 	= РезультатЗапроса[5].Выбрать();
	
	ЦветРамкиНаличиеЗадач	 = Новый Цвет(208, 53, 86);
	ЦветРамкиОтсутствиеЗадач = Новый Цвет(160, 160, 160);
	
	ЦветТекстаНаличиеЗадач		 = Новый Цвет(208, 53, 86);
	ЦветТекстаОтсутствиеЗадач	 = Новый Цвет(77, 77, 77);
	
	КоличествоБезАктивности = ?(ВыборкаКоличестваБезАктивности.Следующий(), ВыборкаКоличестваБезАктивности.КоличествоБезАктивности, 0);
	
	ЭтотОбъект.БезЗадачКоличество	 		 = КоличествоБезАктивности;
	Элементы.БезЗадачКоличество.Ширина	 	 = СтрДлина(КоличествоБезАктивности) / 2 + 1;
	Элементы.БезЗадачКоличество.ЦветРамки	 = ?(КоличествоБезАктивности = 0, ЦветРамкиОтсутствиеЗадач, ЦветРамкиНаличиеЗадач);
	Элементы.БезЗадачКоличество.ЦветТекста	 = ?(КоличествоБезАктивности = 0, ЦветТекстаОтсутствиеЗадач, ЦветТекстаНаличиеЗадач);
	
	КоличествоПросроченныхЗадач = ?(ВыборкаКоличествоПросроченныхЗадач.Следующий(), ВыборкаКоличествоПросроченныхЗадач.КоличествоПросроченныхЗадач, 0);
	
	ЭтотОбъект.ПросроченныеЗадачиКоличество			 = КоличествоПросроченныхЗадач;
	Элементы.ПросроченныеЗадачиКоличество.Ширина	 = СтрДлина(КоличествоПросроченныхЗадач) / 2 + 1;
	Элементы.ПросроченныеЗадачиКоличество.ЦветРамки	 = ?(КоличествоПросроченныхЗадач = 0, ЦветРамкиОтсутствиеЗадач, ЦветРамкиНаличиеЗадач);
	Элементы.ПросроченныеЗадачиКоличество.ЦветТекста = ?(КоличествоПросроченныхЗадач = 0, ЦветТекстаОтсутствиеЗадач, ЦветТекстаНаличиеЗадач);
	
	КоличествоСЗадачамиНаСегодня = ?(ВыборкаКоличествоЗадачиНаСегодня.Следующий(), ВыборкаКоличествоЗадачиНаСегодня.КоличествоЗадач, 0);
	
	ЭтотОбъект.ЗадачиНаСегодняКоличество			 = КоличествоСЗадачамиНаСегодня;
	Элементы.ЗадачиНаСегодняКоличество.Ширина		 = СтрДлина(КоличествоСЗадачамиНаСегодня) / 2 + 1;
	Элементы.ЗадачиНаСегодняКоличество.ЦветРамки	 = ?(КоличествоСЗадачамиНаСегодня = 0, ЦветРамкиОтсутствиеЗадач, ЦветРамкиНаличиеЗадач);
	Элементы.ЗадачиНаСегодняКоличество.ЦветТекста	 = ?(КоличествоСЗадачамиНаСегодня = 0, ЦветТекстаОтсутствиеЗадач, ЦветТекстаНаличиеЗадач);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СоздатьСделку".
//
Процедура СоздатьСделку(Команда)
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ОтборВидСделки) Тогда
		СоздатьСделкуИзСпискаЗавершение(Новый Структура("Значение", ЭтотОбъект.ОтборВидСделки));
		Возврат;
	КонецЕсли;
	
	МассивВидовСделок = ПолучитьВидыСделок();
	
	Если МассивВидовСделок.Количество() > 1 Тогда 
		СписокВыбора = Новый СписокЗначений();
		СписокВыбора.ЗагрузитьЗначения(МассивВидовСделок);
		
		Оповещение = Новый ОписаниеОповещения("СоздатьСделкуИзСпискаЗавершение", ЭтотОбъект);
		ПоказатьВыборИзМеню(Оповещение, СписокВыбора, Элементы.СоздатьСделку);
	ИначеЕсли МассивВидовСделок.Количество() <> 0 Тогда 
		СоздатьСделкуИзСпискаЗавершение(Новый Структура("Значение", МассивВидовСделок[0]));
	КонецЕсли;

КонецПроцедуры

