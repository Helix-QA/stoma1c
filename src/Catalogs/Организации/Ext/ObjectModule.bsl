
#Область ОбработчикиСобытий

// Процедура, обработчик события "ПередЗаписью".
//
&НаСервере
Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	

	Если ЗначениеЗаполнено(ИНН) Тогда
		// Если ЮрФизЛицо = ФизЛицо, то ИНН должен быть равен 12 цифрам, ОГРНИП - 15 цифрам.
		Если ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
			Если СтрДлина(СокрЛП(ИНН)) <> 12 Тогда
				ТекстСообщения = НСтр("ru = 'ИНН указан неверно! ИНН должен состоять из 12 цифр!'");
				ОбменДаннымиСервер.СообщитьОбОшибке(ТекстСообщения, Отказ);     				
			КонецЕсли;
			Если СтрДлина(СокрЛП(ОГРН)) <> 15 Тогда
				ТекстСообщения = НСтр("ru = 'ОГРНИП указан неверно! ОГРНИП должен состоять из 15 цифр!'");
				ОбменДаннымиСервер.СообщитьОбОшибке(ТекстСообщения, Отказ);     				
			КонецЕсли;
		// Если ЮрФизЛицо = ЮрЛицо, то ИНН должен быть равен 10 цифрам, ОГРН - 13 цифрам.
		ИначеЕсли  ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо  И Константы.СтранаУчета.Получить().Код <> "417" Тогда
			
			Если СтрДлина(СокрЛП(ИНН)) <> 10 Тогда    			
				ТекстСообщения = НСтр("ru = 'ИНН указан неверно! ИНН должен состоять из 10 цифр!'");
				ОбменДаннымиСервер.СообщитьОбОшибке(ТекстСообщения, Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не Отказ Тогда
			// Если длина ИНН соответствует требованиям, тогда проверяем строку на наличие букв.
			Если ЕстьБуквыВСтрокеИНН() Тогда
				ТекстСообщения = НСтр("ru = 'ИНН указан неверно! ИНН должен состоять только цифр!'");
				ОбменДаннымиСервер.СообщитьОбОшибке(ТекстСообщения, Отказ); 
			КонецЕсли;  
		КонецЕсли; 		
	КонецЕсли;
	
	// Проверим длину реквизита КПП
	Если  ЗначениеЗаполнено(КПП) и (ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо) Тогда
		Если СтрДлина(СокрЛП(КПП)) <> 9 Тогда    			
			ТекстСообщения = НСтр("ru = 'КПП указан неверно! КПП должен состоять из 9 цифр!'");
			ОбменДаннымиСервер.СообщитьОбОшибке(ТекстСообщения, Отказ);
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ГоловнаяОрганизация)
		И ЭтоГоловнаяОрганизация = Истина Тогда
		ЭтоГоловнаяОрганизация = Ложь;
	КонецЕсли;
		
КонецПроцедуры

// Процедура, обработчик события "ПриЗаписи"
//
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ГоловнаяОрганизация)
		И ГоловнаяОрганизация.ЭтоГоловнаяОрганизация = Ложь Тогда
		
		ОрганизацияОбъект = ГоловнаяОрганизация.ПолучитьОбъект();
		ОрганизацияОбъект.ЭтоГоловнаяОрганизация = Истина;
		Попытка
			ОрганизацияОбъект.Записать();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
			Отказ = Истина;
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

// Процедура, обработчик события "ПриКопировании"
//
Процедура ПриКопировании(ОбъектКопирования)
	
	Наименование     = "";
	КодСинхронизации = "";
	Если Не ЭтоГруппа Тогда
		ИНН = "";
		КПП = "";
		Префикс = "";
		КодПоОКПО = "";	
		ПолноеНаименование = "";
		БанковскийСчетПоУмолчанию = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Функция, проверяет наличие букв в строке ИНН.
//  Параметры:
//    Нет;
//  Возвращаемое значение:
//   ЕстьБуквы - Булево - если есть буквы в ИНН, тогда нужно выдавать ошибку.
//
Функция ЕстьБуквыВСтрокеИНН() Экспорт
	
	ЕстьБуквы      = Ложь;  	
	ИННБезПробелов = СокрЛП(ИНН);
	ДлинаСтрокиИНН = СтрДлина(ИННБезПробелов);
	
	Для Н = 1 По ДлинаСтрокиИНН Цикл
		КодСимволаВСтроке = КодСимвола(ИННБезПробелов, Н);
		Если (КодСимволаВСтроке > 47) и (КодСимволаВСтроке < 58) Тогда
            Продолжить;
		Иначе
			ЕстьБуквы = Истина;
			Прервать;
		КонецЕсли;		
	КонецЦикла;
	
	Возврат ЕстьБуквы;   
	
КонецФункции

#КонецОбласти