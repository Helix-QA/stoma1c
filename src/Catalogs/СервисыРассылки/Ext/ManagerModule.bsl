// Функция - SMSC KZ сведения о сервисе SMS
// 
// Возвращаемое значение:
//   - 
//
Функция SMSC_KZ_СведенияОСервисеSMS()

	РезультатСтруктура = Новый Структура("Наименование, Версия, Информация, ПоддержкаМножественнойОтправки, СсылкаНаСайт, СсылкаНаСайтПредставление");
	
	РезультатСтруктура.Наименование = "SMSC_KZ";
	РезультатСтруктура.Версия       = 1;
	РезультатСтруктура.Информация   = НСтр("ru = 'SMSC_KZ — сервис рассылок смс-сообщений.'; en = 'SMSC_KZ - SMS messaging service.'");
	РезультатСтруктура.ПоддержкаМножественнойОтправки = Истина;
	РезультатСтруктура.СсылкаНаСайт = "https://smsc.kz/";
	РезультатСтруктура.СсылкаНаСайтПредставление = "smsc.kz";
	
	Возврат РезультатСтруктура;

КонецФункции

// Функция, выполняет отправку смс сообщения
//  Параметры:
//   ТекстSMS: Текст, текст отправляемого сообщения.
//   МассивНомеров: Массив, Массив номеров телефонов для отправки сообщения.
//  
Функция SMSC_KZ_ОтправитьSMS(СервисSMSРассылки, ТекстSMS, Получатели)
	
	Результат = СоздатьТаблицуРезульта(Получатели, Истина);
	
	Для Каждого ПолучательSMS Из Результат Цикл
		
		ПОПЫТКА
			
			ОписаниеОшибки = "";
			
			Аргументы = "&phones=" + URLEncode(ПолучательSMS.НомерТелефона) +
			            "&mes=" + URLEncode(ТекстSMS) +
			            ?(Не ПустаяСтрока(СервисSMSРассылки.Подпись), "&sender=" + URLEncode(СервисSMSРассылки.Подпись), "") +
						"&fmt=3&charset=utf-8";
			Ответ = SMSC_KZ_ПослатьКоманду("/sys/send.php", Аргументы, СервисSMSРассылки, ОписаниеОшибки);
			
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				
				Результат.ЗаполнитьЗначения(ОписаниеОшибки, "СтатусСообщения");
				Результат.ЗаполнитьЗначения(Перечисления.СтадииДоставкиSMSСообщений.ПустаяСсылка(), "СтадияДоставки");
				Возврат Результат;
				
			КонецЕсли;	
			
			СтруктураОтвета = ДекодироватьИзJSON(Ответ);
				
			Если СтруктураОтвета.Свойство("error") Тогда
				
				ПолучательSMS.СтатусСообщения = "Ошибка отправки SMS (" + СтруктураОтвета.error + ")";
				ПолучательSMS.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ОшибкаДоставки;
				Возврат Результат;

			КонецЕсли;	
			
			Если СтруктураОтвета.Свойство("id") Тогда
				
				Если ТипЗнч(СтруктураОтвета.id) = Тип("Число") Тогда
					ПолучательSMS.IDСообщения = Формат(СтруктураОтвета.id, "ЧГ=0");
				Иначе
					ПолучательSMS.IDСообщения = Строка(СтруктураОтвета.id);
				КонецЕсли;
				
			КонецЕсли;
		
		ИСКЛЮЧЕНИЕ
			
			ПолучательSMS.СтатусСообщения = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ПолучательSMS.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ПустаяСсылка();
			
		КОНЕЦПОПЫТКИ
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции // ОтправитьSMS()

// Функция, получает статус отправленного сообщения по его ID
//  Параметры:
//   МассивIDSMS: Массив, Массив ID сообщений.
//   
Функция SMSC_KZ_ПолучитьСтатусSMS(СервисSMSРассылки, IDСообщений)
	
	Результат = СоздатьТаблицуРезульта(IDСообщений, Ложь);
		
	Для Каждого СтрокаIDСообщения Из Результат Цикл
		
		ПОПЫТКА
			
			ОписаниеОшибки = "";
			Если ПустаяСтрока(СтрокаIDСообщения.IDСообщения) Тогда
				Продолжить;
			КонецЕсли;
			
			Аргументы = "&phone=" + URLEncode(СтрокаIDСообщения.НомерТелефона) +
			            "&id=" + URLEncode(СтрокаIDСообщения.IDСообщения) +
						"&fmt=3";
			
			Ответ = SMSC_KZ_ПослатьКоманду("/sys/status.php", Аргументы, СервисSMSРассылки, ОписаниеОшибки);
			
			Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				
				СтрокаIDСообщения.СтатусСообщения = ОписаниеОшибки;
				СтрокаIDСообщения.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
				
				Возврат Результат;
				
			КонецЕсли;
			
			СтруктураОтвета = ДекодироватьИзJSON(Ответ);
			
			
			Если СтруктураОтвета.Свойство("status") Тогда
				status = СтруктураОтвета.status;
				Если status = -1 Или status = 0 Тогда  // ожидает отправки или передано оператору
					СтатусСообщенияСтрока = НСтр("ru = 'В режиме доставки'; en = 'In delivery mode'");
					СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
				ИначеЕсли status = 1  Тогда // доставлено
					СтадияДоставки = Перечисления.СтадииДоставкиSMSСообщений.СообщениеДоставлено;
					СтатусСообщенияСтрока = НСтр("ru = 'Сообщение доставлено'; en = 'Message delivered'");
				Иначе
					СтадияДоставки = Перечисления.СтадииДоставкиSMSСообщений.ОшибкаДоставки;
					СтатусСообщенияСтрока = НСтр("ru = 'Ошибка доставки'; en = 'Delivery error'");
				КонецЕсли;
				СтрокаIDСообщения.СтадияДоставки  = СтадияДоставки;
				СтрокаIDСообщения.СтатусСообщения = СтатусСообщенияСтрока;
			Иначе
				СтрокаIDСообщения.СтатусСообщения = НСтр("ru = 'Ошибка доставки'; en = 'Delivery error'");
			    СтрокаIDСообщения.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
			КонецЕсли;
			
		ИСКЛЮЧЕНИЕ
			
			СтрокаIDСообщения.СтатусСообщения = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			СтрокаIDСообщения.СтадияДоставки  = Перечисления.СтадииДоставкиSMSСообщений.ВРежимеДоставки;
			
		КОНЕЦПОПЫТКИ
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции // ПолучитьСтатусSMS()

// Функция, выполняет получение баланса
//  Параметры:
//
Функция SMSC_KZ_ПолучитьБаланс(СервисSMSРассылки)
		
	ОписаниеОшибки 	= "";
	Аргументы = "&cur=1&fmt=3";
				
	Ответ			= SMSC_KZ_ПослатьКоманду("/sys/balance.php", Аргументы, СервисSMSРассылки, ОписаниеОшибки);
	
	Результат = Новый Структура("Баланс, Валюта, Ошибка, ОписаниеОшибки", 0, "Руб.", Ложь, "");
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		Результат.Ошибка         = Истина;
	    Результат.ОписаниеОшибки = ОписаниеОшибки;
		Возврат Результат;

	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ответ) Тогда
	    СтруктураОтвета = ДекодироватьИзJSON(Ответ);
		Результат.Ошибка = Ложь;
		Результат.Валюта = ?(СтруктураОтвета.Свойство("currency"), СтруктураОтвета.currency, "");
		Результат.Баланс = ?(СтруктураОтвета.Свойство("balance"), СтруктураОтвета.balance, "");
	Иначе
	    Результат.Ошибка         = Истина;
	    Результат.ОписаниеОшибки = НСтр("ru= 'Неверный формат ответа';en= 'Invalid response format'");
	КонецЕсли;
		
    Возврат Результат;
	
КонецФункции

// Функция - SMSC KZ послать команду
//
// Параметры:
//  Команда				 - 	 - 
//  Аргументы			 - 	 - 
//  СервисSMSРассылки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция SMSC_KZ_ПослатьКоманду(Команда, Аргументы = "", СервисSMSРассылки, ОписаниеОшибки) Экспорт

	Сервер = "smsc.kz";
	
	Ресурс = Команда;                         
    Параметры = "login=" + КодироватьСтроку(СокрЛП(СервисSMSРассылки.Пользователь), СпособКодированияСтроки.КодировкаURL) 
		+ "&psw=" + КодироватьСтроку(СокрЛП(СервисSMSРассылки.Пароль), СпособКодированияСтроки.КодировкаURL) + Аргументы;	
	Результат = ПрочитатьАдрес(Сервер, Ресурс, Параметры, ОписаниеОшибки);                       
	
	Возврат Результат;	
	
КонецФункции 

