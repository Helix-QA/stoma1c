&НаКлиенте
Процедура ПерейтиНеделяПредыдущая(Команда)	
	Объект.Дата = Объект.Дата - 7 * 24 * 60 * 60;
	ОбновитьГрафик(,Истина);	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиНеделяСледующая(Команда)	
	Объект.Дата = Объект.Дата + 7 * 24 * 60 * 60;
	ОбновитьГрафик(,Истина);	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиПредыдущийМесяц(Команда)	
	Объект.Дата = ДобавитьМесяц(Объект.Дата, -1);
	ОбновитьГрафик(,Истина);	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиСледующийМесяц(Команда)
	Объект.Дата = ДобавитьМесяц(Объект.Дата, 1);
	ОбновитьГрафик(,Истина);	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиДеньНедели(Команда)
	Объект.Дата = НачалоНедели(Объект.Дата) + Число(Сред(Команда.Имя, СтрДлина(Команда.Имя), 1) - 1) * 24 * 60 * 60;
    ОбновитьГрафик(,Истина);
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиНеделяМесяца(Команда)
	НеобходимаяДата = НачалоМесяца(Объект.Дата) + Число(Сред(Команда.Имя, СтрДлина(Команда.Имя), 1) - 1) * 7 * 24 * 60 * 60;
	Если Месяц(Объект.Дата) = Месяц(НеобходимаяДата) Тогда
		Объект.Дата = НачалоМесяца(Объект.Дата) + Число(Сред(Команда.Имя, СтрДлина(Команда.Имя), 1) - 1) * 7 * 24 * 60 * 60;
	Иначе
		Объект.Дата = КонецМесяца(Объект.Дата);
	КонецЕсли;
	ОбновитьГрафик(,Истина);
КонецПроцедуры

&НаКлиенте
Процедура ДиалогКалендаря(Команда)

	ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", Новый Структура("Дата", Объект.Дата),,,,, Новый ОписаниеОповещения("ДиалогКалендаряВыбораЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		
	
КонецПроцедуры

#КонецОбласти



&НаКлиенте                 
Процедура ДиалогКалендаряВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Объект.Дата = Результат;
		ОбновитьГрафик(,Истина);
	КонецЕсли;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Функция ВернутьЗаголовокДняНедели(Знач Дата, НомерДня)	
       	СтруктураСокрашенияМесяца = Новый Структура("М1, М2, М3, М4, М5, М6, М7, М8, М9, М10, М11, М12", "Янв.", "Фев.", "Март", "Апр.", "Май", "Июнь", "Июль", "Авг.", "Сен.", "Окт.", "Нояб.", "Дек.");
	Дата                      = НачалоНедели(Дата) + (НомерДня - 1) * 24 * 60 * 60;	
	Возврат " " + Формат(Дата, "ДФ=dd") + " " + СтруктураСокрашенияМесяца["М" + Месяц(Дата)];	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Функция ВернутьЗаголовокНеделиМесяца(Знач Дата, НомерНедели)	
	Дата                 = НачалоМесяца(Дата);
	НачалоНеделиПоНомеру = НачалоНедели(Дата + (НомерНедели - 1) * 7 * 24 * 60 * 60);
	КонецНеделиПоНомеру  = КонецНедели(Дата + (НомерНедели - 1) * 7 * 24 * 60 * 60);	
	Возврат " " + Формат(НачалоНеделиПоНомеру, "ДФ=dd") + " - " + Формат(КонецНеделиПоНомеру, "ДФ=dd")+" " +Формат(КонецНеделиПоНомеру, "ДФ=MMM");	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Функция ВернутьНомерНеделиМесяца(Знач Дата)	
	НомерНедели = Цел((День(Дата) + ДеньНедели(НачалоМесяца(Дата) ) - 2 ) / 7) + 1;	
	Возврат НомерНедели;	
КонецФункции

&НаКлиенте
Процедура ОтборПриИзменении(Элемент)	
	ОбновитьГрафик();	
КонецПроцедуры

