&НаСервере
// Процедура, создает строку элементов расшифровки платежа.
//
Процедура СоздатьСтрокуЭлементовРасшифровки(Индекс)
	
	ИспользоватьАвансы = Константы.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Получить() И Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента;
	
	ГруппаНовыхЭл                         = Элементы.Добавить("СтрокаРасшифровки_" + Индекс, Тип("ГруппаФормы"), Элементы.ГруппаСтрокиРасшифровки);
	ГруппаНовыхЭл.Вид                     = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНовыхЭл.Группировка             = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
	ГруппаНовыхЭл.Отображение             = ОтображениеОбычнойГруппы.Нет;
	ГруппаНовыхЭл.Ширина				  = 114; //?(Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта, 134, 140);
	ГруппаНовыхЭл.ОтображатьЗаголовок     = Ложь;
	ГруппаНовыхЭл.РастягиватьПоГоризонтали = Неопределено;
	
	ДекорацияНомерСтроки				  = Элементы.Добавить("ДекорацияНомер_" + Индекс, Тип("ДекорацияФормы"), ГруппаНовыхЭл);
	ДекорацияНомерСтроки.Заголовок        = Индекс + 1;
	ДекорацияНомерСтроки.Ширина			  = 2;
	
	ШиринаДопПолей = 0;
	
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗаработнойПлаты Тогда
		
		ПолеСотрудник					  		= Элементы.Добавить("Сотрудник_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
		ПолеСотрудник.Вид				 		= ВидПоляФормы.ПолеВвода;
		ПолеСотрудник.РастягиватьПоГоризонтали	= Неопределено;
		ПолеСотрудник.АвтоМаксимальнаяШирина   	= Ложь;
		ПолеСотрудник.Ширина  					= 0;
		ПолеСотрудник.МаксимальнаяШирина  		= 25;
		ПолеСотрудник.ПутьКДанным		  		= "Объект.РасшифровкаПлатежа[" + Индекс +"].Сотрудник";
		ПолеСотрудник.ПоложениеЗаголовка  		= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеСотрудник.ПодсказкаВвода	  		= "Сотрудник";
		ШиринаДопПолей							= ШиринаДопПолей + ПолеСотрудник.МаксимальнаяШирина; 
		
		Объект.РасшифровкаПлатежа[Индекс].ДокументОснования = Объект.ВозвратВыплатыЗПДокументОснования;
		
	КонецЕсли;	
	
	ПолеДокумент                          = Элементы.Добавить("Основание_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
	ПолеДокумент.Вид                      = ВидПоляФормы.ПолеВвода;
	ПолеДокумент.ПоложениеЗаголовка       = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ПолеДокумент.АвтоМаксимальнаяШирина   = Ложь;
	ПолеДокумент.РастягиватьПоГоризонтали = Неопределено;
	ПолеДокумент.ПодсказкаВвода			  = "Основание";
	ПолеДокумент.КнопкаВыпадающегоСписка  = Ложь; 
	ПолеДокумент.КнопкаОткрытия			  = Истина;
	ПолеДокумент.КнопкаВыбора			  = Истина;	
	ПолеДокумент.ИсторияВыбораПриВводе    = ИсторияВыбораПриВводе.НеИспользовать;
	ПолеДокумент.РежимВыбораИзСписка 	  = Ложь;
	ПолеДокумент.ПутьКДанным              = "Объект.РасшифровкаПлатежа[" + Индекс +"].ДокументОснования";
	ПолеДокумент.УстановитьДействие("НачалоВыбора"	 , "РасшифровкаПлатежаЗаказРеализацияНачалоВыбора");
	ПолеДокумент.УстановитьДействие("ОбработкаВыбора", "РасшифровкаПлатежаЗаказРеализацияОбработкаВыбора");
	
	МаксимальнаяШиринаПолеДокумента = ?(Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеОтЭквайера, 97, 90);	
	ПолеДокумент.МаксимальнаяШирина = МаксимальнаяШиринаПолеДокумента;  // МаксимальнаяШирина корректируется ниже!	

		
	Если ИспользоватьАвансы Тогда
		
		ПолеАванс						  		= Элементы.Добавить("ДокументАванса_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
		ПолеАванс.Вид					  		= ВидПоляФормы.ПолеВвода;
		ПолеАванс.ПоложениеЗаголовка	  		= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеАванс.РастягиватьПоГоризонтали		= Неопределено;
		ПолеАванс.Ширина  						= 0;
		ПолеАванс.АвтоМаксимальнаяШирина   		= Ложь;
		ПолеАванс.МаксимальнаяШирина	  		= 25;
		ПолеАванс.ПутьКДанным			  		= "Объект.РасшифровкаПлатежа[" + Индекс +"].ДокументАванса";
		ПолеАванс.ПодсказкаВвода		  		= "Документ аванса";
		// ПолеАванс.УстановитьДействие("ОкончаниеВводаТекста", "РасшифровкаПлатежаДинамическиеОкончаниеВводаТекста");
		ШиринаДопПолей							= ШиринаДопПолей + ПолеАванс.МаксимальнаяШирина;
		
	КонецЕсли;	
	
	Если Объект.СтатьяВТаблице Тогда
		
		ПолеСтатья						  		= Элементы.Добавить("Статья_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
		ПолеСтатья.Вид					  		= ВидПоляФормы.ПолеВвода;
		ПолеСтатья.ПутьКДанным			  		= "Объект.РасшифровкаПлатежа[" + Индекс + "].Статья";
		ПолеСтатья.РастягиватьПоГоризонтали		= Неопределено;
		ПолеСтатья.Ширина  						= 0;
		ПолеСтатья.АвтоМаксимальнаяШирина   	= Ложь;
		ПолеСтатья.МаксимальнаяШирина			= 25;
		ПолеСтатья.ПодсказкаВвода		  		= "Статья дохода";
		ПолеСтатья.ПоложениеЗаголовка	  		= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ШиринаДопПолей							= ШиринаДопПолей + ПолеСтатья.МаксимальнаяШирина;
		
		Объект.РасшифровкаПлатежа[Индекс].Статья = Объект.Статья;
		
	Иначе
		
		Объект.РасшифровкаПлатежа[Индекс].Статья = ПолучитьПредопределеннуюСтатьюДляОперации(Объект.ВидОперации, Ложь);
		
	КонецЕсли;
		
	КоррекцияШирины = ШиринаДопПолей / 25;
	ПолеДокумент.МаксимальнаяШирина = ПолеДокумент.МаксимальнаяШирина - ШиринаДопПолей - ?(КоррекцияШирины >= 1, (КоррекцияШирины * 2), 1);
		
	ПолеСумма                      		  = Элементы.Добавить("Сумма_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
	ПолеСумма.Вид                  		  = ВидПоляФормы.ПолеВвода;
	ПолеСумма.Ширина					  = 13;
	ПолеСумма.ПоложениеЗаголовка   		  = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ПолеСумма.ПутьКДанным          		  = "Объект.РасшифровкаПлатежа[" + Индекс +"].Сумма";
	ПолеСумма.ПодсказкаВвода			  = "Сумма";
	ПолеСумма.УстановитьДействие("ПриИзменении", "РасшифровкаПлатежаСуммаПриИзменении");
	
	Если ИспользоватьАвансы Тогда
		ПолеСумма.УстановитьДействие("ОкончаниеВводаТекста"		, "РасшифровкаПлатежаДинамическиеОкончаниеВводаТекста");
		// ПолеДокумент.УстановитьДействие("ОкончаниеВводаТекста"	, "РасшифровкаПлатежаДинамическиеОкончаниеВводаТекста");	
	КонецЕсли;
	
	КнопкаУдаления                  	  = Элементы.Добавить("УдалитьСтроку_" + Индекс, Тип("КнопкаФормы"), ГруппаНовыхЭл);
	КнопкаУдаления.Отображение     	      = ОтображениеКнопки.Картинка;
	КнопкаУдаления.Картинка				  = БиблиотекаКартинок.ОчиститьДанные;
	КнопкаУдаления.ОтображениеФигуры 	  = ОтображениеФигурыКнопки.Нет;
	КнопкаУдаления.ИмяКоманды      	      = "УдалитьСтрокуРасшифровки";
	
КонецПроцедуры

&НаСервере
// Процедура, создает динамические элементы расшифровки платежа.
//
Процедура СоздатьЭлементыРасшифровкиПлатежа()
	
	ОчиститьЭлементыРасшифровки();
	Индекс = 0;
	Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл
		
		СоздатьСтрокуЭлементовРасшифровки(Индекс);
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Если Объект.РасшифровкаПлатежа.Количество() = 0 Тогда
		НоваяСтрока = Объект.РасшифровкаПлатежа.Добавить();	
		СоздатьСтрокуЭлементовРасшифровки(0);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, удаляет динамическую строку расшифровки платежа.
//
Процедура УдалитьЭлементыРасшифровкиПлатежа(ИндексСтроки)
	
	СтрокаДанных = Объект.РасшифровкаПлатежа[ИндексСтроки];	
	
	Если СтрокаДанных <> Неопределено Тогда 		
		
		Индекс = 0;
		Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл
			Если Элементы.Найти("СтрокаРасшифровки_" + Индекс) <> Неопределено Тогда
				Элементы.Удалить(Элементы["СтрокаРасшифровки_" + Индекс]);	
			КонецЕсли;
			Индекс = Индекс + 1;              
		КонецЦикла;				
		Объект.РасшифровкаПлатежа.Удалить(СтрокаДанных);		
		СоздатьЭлементыРасшифровкиПлатежа();
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура, удаляет динамически созданные элементы расшифровки платежа.
//
Процедура ОчиститьЭлементыРасшифровки()
	
	Количество = Элементы.ГруппаСтрокиРасшифровки.ПодчиненныеЭлементы.Количество();
	Если Количество = 0 Тогда Возврат;
	КонецЕсли;
	
	Для Индекс = 0 По Количество - 1 Цикл
		Элементы.Удалить(Элементы.Найти("СтрокаРасшифровки_" + Индекс));
	КонецЦикла;	
		
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость элементов в зависимости от вида операции.
//
Процедура ОбновитьОтображениеРасшифровки()
	
	ВидыОпераций = Перечисления.ВидыОпераций;
	
	Если Объект.ВидОперации = ВидыОпераций.ВзносНаЛицевойСчет Или Объект.ВидОперации = ВидыОпераций.ПоступлениеИзБанка
		Или Объект.ВидОперации = ВидыОпераций.ВозвратЗайма Или Объект.ВидОперации = ВидыОпераций.ВводОстатков
		Или Объект.ВидОперации = ВидыОпераций.ВзносУчредителя Или Объект.ВидОперации = ВидыОпераций.ПрочееПоступление Тогда
		
		Элементы.ГруппаРасшифровкаПлатежа.Видимость			 = Ложь;
		Элементы.ГруппаРасшифровкаДинамические.Видимость = Ложь;
		
		Элементы.ГруппаРасшифровка.Видимость   = Ложь;
		Элементы.ГруппаДополнительно.Видимость = Истина;
		Элементы._Расшифровка.Видимость  = Ложь;
		Элементы.Дек_Расшифровка.Видимость = Ложь;
		Элементы._Дополнительно.Видимость = Ложь;
		Элементы.Дек_Дополнительно.Видимость = Истина;
		Возврат;
		
	КонецЕсли;	

	Элементы.ГруппаРасшифровка.Видимость   = Истина;
	Элементы.ГруппаДополнительно.Видимость = Ложь;
	Элементы._Расшифровка.Видимость  = Ложь;
	Элементы.Дек_Расшифровка.Видимость = Истина;
	Элементы._Дополнительно.Видимость = Истина;
	Элементы.Дек_Дополнительно.Видимость = Ложь;
		
	Если Объект.ВидОперации = ВидыОпераций.ОплатаОтСтраховойКомпании Тогда
		Элементы.ГруппаРасшифровкаПлатежа.Видимость			 = Истина;
		Элементы.КоманднаяПанельЗаглушкаВыравнивание.МаксимальнаяШирина = 0;
		Элементы.ГруппаРасшифровкаДинамические.Видимость = Ложь;
	Иначе
		Элементы.ГруппаРасшифровкаПлатежа.Видимость			 = Ложь;
		Элементы.ГруппаРасшифровкаДинамические.Видимость = Истина;
	КонецЕсли;

КонецПроцедуры	

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
Функция ПолучитьИндексСтроки(ИмяЭлемента)
	
	НомерСимвола = Найти(ИмяЭлемента,"_");
	Возврат Число(Прав(ИмяЭлемента,СтрДлина(ИмяЭлемента) - НомерСимвола)); 
	
КонецФункции

&НаСервере
// Функция возвращает ссылку на отчет
