#Область Ссылки_и_СБП

&НаСервере
// Процедура - Установить вид оплаты СБП
//
Процедура УстановитьВидОплатыСБП_И_СсылокНаОплату()
	
	ТаблицаЭТ = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыеТерминалыСБП_И_СсылокНаОплату(ЭтотОбъект.Касса, ЭтотОбъект.СтруктурнаяЕдиница, Истина);	
	
	Если ТаблицаЭТ.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	СущВидыОплатВерхУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей,,,,,, Справочники.ЭквайринговыеТерминалы.ПустаяСсылка());
	
	Если НЕ ЗначениеЗаполнено(СущВидыОплатВерхУр) Тогда
		
		ЭлементДереваЭТ                    = ЭтотОбъект.ВидыОплат.ПолучитьЭлементы().Добавить();
		ЭлементДереваЭТ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей; 
		ЭлементДереваЭТ.Представление      = НСтр("ru = 'Система быстрых платежей и ссылки на оплату'; en = 'Fast payment system and payment links'");  
		
	Иначе
		ЭлементДереваЭТ = СущВидыОплатВерхУр[0];
	КонецЕсли;
		
	Для Каждого СтрокаТ ИЗ ТаблицаЭТ Цикл
				
		СущВидыОплатНижнУр = НайтиВДеревеДоступныхВидовОплатСервер(Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей,,,,,, СтрокаТ.ЭквайринговыйТерминал);
		
		НоваяСтрока = ?(ЗначениеЗаполнено(СущВидыОплатНижнУр), СущВидыОплатНижнУр[0], ЭлементДереваЭТ.ПолучитьЭлементы().Добавить());
		
		НоваяСтрока.ЭквайринговыйТерминал  = СтрокаТ.ЭквайринговыйТерминал;
		НоваяСтрока.Контрагент	           = ЭтотОбъект.Контрагент;
		НоваяСтрока.КассаОплаты            = ЭтотОбъект.Касса;
		НоваяСтрока.ТипДенежныхСредств     = Перечисления.ТипыДенежныхСредств.СистемаБыстрыхПлатежей;
		НоваяСтрока.МаксСуммаСписания      = -1;
		НоваяСтрока.НаименованиеВидаОплаты = СтрокаТ.Наименование;
		НоваяСтрока.Представление		   = СтрокаТ.Наименование;
				
	КонецЦикла;
			
КонецПроцедуры

&НаСервере
// Функция - Получить картинку соответствия типу шлюза
//
// Параметры:
//  ЭквайринговыйТерминал	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКартинкуСоответствияТипуШлюза(ЭквайринговыйТерминал)
	
	ТипШлюза = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭквайринговыйТерминал, "ТипБанка"); 
	
	Если ТипШлюза = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПАльфаБанк ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПТинькофф ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПСбербанк 
		ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СБПСДМ Тогда
		Возврат БиблиотекаКартинок.СсылкиНаОплату_СБП_32;
	ИначеЕсли ТипШлюза = Перечисления.ПлатежныеШлюзы.Сбербанк ИЛИ ТипШлюза = Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR Тогда
		Возврат БиблиотекаКартинок.СсылкиНаОплату_СберБанк_32;
	Иначе
		Возврат Неопределено
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура - Проверить возможность оплаты СБП
//
Процедура ПроверитьВозможностьОплатыСБП(СтрокаВыбраннойОплаты, Элемент)
	
	Если Не ЗначениеЗаполнено(СтрокаВыбраннойОплаты.Контрагент) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Клиент не заполнен");
		Возврат;
	КонецЕсли;
	
	Если СуммаВнесенныхВидовОплатСервер() <> 0 Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Смешанный тип оплаты недоступен для оплаты через систему быстрых платежей или ссылок на оплату");
		Возврат;		
		
	ИначеЕсли НЕ ЗначениеЗаполнено(ЭтотОбъект.Касса) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Не указана касса, оплата невозможна!';en='Not indicated cashbox payment impossible!'"));  
		Возврат;
		
	ИначеЕсли НЕ ЗначениеЗаполнено(ЭтотОбъект.ВидЛицевогоСчета) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru='Не указан вид лицевой счета который будет создан!';en='Not specified view facial accounts which willbe created by!'"));
		Возврат;
				
	КонецЕсли;
	
	СтруктураПараметров = ПолучитьПараметрыДляПроверки(СтрокаВыбраннойОплаты.ЭквайринговыйТерминал);
		
	Если СтруктураПараметров.СсылкаСформированаПоДругомуШлюзу Тогда 		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураПараметров.ОписаниеОшибки);
		Возврат;				
	КонецЕсли;
	
	Если СтруктураПараметров.СсылкаПолучена Тогда	
		ОткрытьФормуСБП(СтруктураПараметров);		
	Иначе		
		ВводСуммыОплаты(Элемент);		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Получить параметры для проверки
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрыДляПроверки(СбпЭквайринговыйТерминал)
	
	ДокументыЗадолженности = Новый Массив;
	ДокументыЗадолженности.Добавить(ВидЛицевогоСчета);
	
	Выборка			= РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьСсылкуНаОплату(ДокументыЗадолженности, СбпЭквайринговыйТерминал);
	СсылкаПолучена	= Выборка <> Неопределено;			
	СсылкаСформированаПоДругомуШлюзу = СсылкаПолучена И Выборка.СсылкаЭТ <> СбпЭквайринговыйТерминал;
	
	ОписаниеОшибки	= "";
	Если СсылкаСформированаПоДругомуШлюзу Тогда
		ОписаниеОшибки = СтрШаблон("Ссылка уже сформирована по эквайринговому терминалу: %1. Необходимо отменить существующую ссылку", Выборка.ЭквайринговыйТерминал);
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("ТипБанка"							, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СбпЭквайринговыйТерминал, "ТипБанка"));	
	СтруктураПараметров.Вставить("СсылкаСформированаПоДругомуШлюзу"	, СсылкаСформированаПоДругомуШлюзу);
	СтруктураПараметров.Вставить("ОписаниеОшибки"                   , ОписаниеОшибки);
	СтруктураПараметров.Вставить("СсылкаПолучена"                   , СсылкаПолучена);
	СтруктураПараметров.Вставить("НомерЗаказа"                   	, ?(СсылкаПолучена, Выборка.НомерЗаказа, Неопределено));
	  
	Возврат СтруктураПараметров;
	
КонецФункции

&НаКлиенте
// Процедура - Открыть форму СБП
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
//
Процедура ОткрытьФормуСБП(СтруктураПараметров)
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораСБП", ЭтотОбъект, СтруктураПараметров);
	ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаОтправкиПлатежейСБП", СтруктураПараметров,,,,, ОписаниеОповещения);	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора СБП
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыбораСБП(Результат, ДополнительныеПараметры) Экспорт	
	
	Если Результат <> Неопределено И Результат.ОбновитьИнформациюОСсылкахНаОплату И Не Результат.ОтменаСсылки И ЭтаФорма.Открыта() Тогда
		
		ЭтаФорма.Закрыть();	
		
	ИначеЕсли ТекущееПолеВводаСБП <> Неопределено Тогда
		
		ТекущееПолеВводаСуммыОплаты = Неопределено;
		ОбработчикНажатияКнопкаУдалитьСумму(ТекущееПолеВводаСБП);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - Завершить ввод суммы оплаты СБП
//
// Параметры:
//  СтрокаДанных - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Процедура ЗавершитьВводСуммыОплатыСБП(СтрокаВыбраннойОплаты)
	
	Если СтрокаВыбраннойОплаты.Внесено = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Внесенная сумма должна быть больше нуля");
		Возврат;
	КонецЕсли;
		
	СтруктураПараметров = ПолучитьПараметрыДляПроверки(СтрокаВыбраннойОплаты.ЭквайринговыйТерминал);
	
	МассивЗадолженностей = Новый Массив;
	МассивЗадолженностей.Добавить(Новый Структура("ДокументЗадолженности, Задолженность", ВидЛицевогоСчета, СтрокаВыбраннойОплаты.Внесено));
	
	СтруктураПараметров.Вставить("МассивЗадолженностей"		, МассивЗадолженностей);
	СтруктураПараметров.Вставить("КассаОплаты"				, СтрокаВыбраннойОплаты.КассаОплаты);
	СтруктураПараметров.Вставить("Контрагент"				, СтрокаВыбраннойОплаты.Контрагент);
	СтруктураПараметров.Вставить("СтруктурнаяЕдиница"		, ЭтотОбъект.СтруктурнаяЕдиница);
	СтруктураПараметров.Вставить("Организация"				, ЭтотОбъект.Организация);
	СтруктураПараметров.Вставить("ЭквайринговыйТерминал"	, СтрокаВыбраннойОплаты.ЭквайринговыйТерминал);
	СтруктураПараметров.Вставить("СуммаОплаты"				, СтрокаВыбраннойОплаты.Внесено);	
	
	ОткрытьФормуСБП(СтруктураПараметров);
	
КонецПроцедуры

&НаСервере
// Функция рекурсивного поиска в дереве доступных видов оплаты.
// 
Функция СуммаВнесенныхВидовОплатСервер(
	ТипДенСредств = Неопределено,
	ЛицевойСчет = Неопределено,
	ЭквайрингНомерПлатежнойКарты = Неопределено,
	СертификатПартия = Неопределено)
	
	МассивСтрок =  ПолучитьСтрокиСВнесеннойОплатойСервер(ТипДенСредств, ЛицевойСчет, ЭквайрингНомерПлатежнойКарты, СертификатПартия);
	
	ВремСумма = 0;
	Для Каждого СтрокаОплаты ИЗ МассивСтрок Цикл		
		ВремСумма = ВремСумма + СтрокаОплаты.Внесено;	
	КонецЦикла;
	
	Возврат ВремСумма;
	
КонецФункции

&НаСервере
// Процедура - Обновить доступные кассы
//
// Параметры:
//  врДоступныеКассы - 	 - 
//
Процедура ОбновитьДоступныеКассыДляСсылокИСбп(врДоступныеКассы)
	
	ТаблицаКасс = Справочники.Кассы.ПолучитьКассыСсылокНаОплатуИСбп(СтруктурнаяЕдиница);
	
	Для Каждого СтрокаТЗ Из ТаблицаКасс Цикл
		
		НайденнаяСтрока = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(врДоступныеКассы, "Касса", СтрокаТЗ.Касса);
		
		Если НайденнаяСтрока = Неопределено Тогда
			СтруктураДанных = Новый Структура("ИспользуетсяОнлайн,Касса,КассаДоступна,ФРИспользуется");
			ЗаполнитьЗначенияСвойств(СтруктураДанных, СтрокаТЗ); 
			врДоступныеКассы.Добавить(СтруктураДанных);
		Иначе
			НайденнаяСтрока.ИспользуетсяОнлайн = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	врДоступныеКассы = ОтсортироватьМассивСтруктур(врДоступныеКассы);
	
КонецПроцедуры

&НаСервере
// Функция - Отсортировать массив структур
//
// Параметры:
//  МассивСтруктур	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОтсортироватьМассивСтруктур(МассивСтруктур)
	
	ТаблицаКасс = Новый ТаблицаЗначений;
	ТаблицаКасс.Колонки.Добавить("ИспользуетсяОнлайн");
	ТаблицаКасс.Колонки.Добавить("Касса");
	ТаблицаКасс.Колонки.Добавить("КассаДоступна");
	ТаблицаКасс.Колонки.Добавить("ФРИспользуется");
		
	Для Каждого Строка Из МассивСтруктур Цикл
		НоваяСтрока = ТаблицаКасс.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
	КонецЦикла;
	
	ТаблицаКасс.Сортировать("ФРИспользуется Убыв, КассаДоступна Убыв");  
	
	МассивСтруктурВозврат = Новый Массив;
	
	Для Каждого Строка Из ТаблицаКасс Цикл
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("ИспользуетсяОнлайн"	, Строка.ИспользуетсяОнлайн);
		СтруктураСтроки.Вставить("Касса"				, Строка.Касса);
		СтруктураСтроки.Вставить("КассаДоступна"		, Строка.КассаДоступна);
		СтруктураСтроки.Вставить("ФРИспользуется"		, Строка.ФРИспользуется);
		МассивСтруктурВозврат.Добавить(СтруктураСтроки);
	КонецЦикла;
	
	Возврат МассивСтруктурВозврат;
	
КонецФункции

