	|				КОНЕЦ
	|		КОНЕЦ) КАК ПроцентСкидки,
	|	СУММА(ВозвратОтПокупателяЗапасы.Сумма) КАК СуммаСоСкидкой,
	|	ВозвратОтПокупателяЗапасы.Номенклатура.Артикул
	|ИЗ
	|	Документ.ВозвратОтПокупателя.Запасы КАК ВозвратОтПокупателяЗапасы
	|ГДЕ
	|	ВозвратОтПокупателяЗапасы.Ссылка.ДокументОснования = &Ссылка
	|	И ВозвратОтПокупателяЗапасы.Ссылка.Проведен = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	ВозвратОтПокупателяЗапасы.Номенклатура,
	|	ВозвратОтПокупателяЗапасы.Номенклатура.Артикул");
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();    	
	
	// Лечение
	ТаблицаВозращенныхУслуг = ПакетЗапросов[0].Выгрузить();
	
	Для Каждого СтрокаТЗ Из ТаблицаВозращенныхУслуг Цикл   		
		МассивНайденныхСтрок = Объект.Лечение.НайтиСтроки(Новый Структура("Номенклатура" ,  СтрокаТЗ.Номенклатура));
		Если МассивНайденныхСтрок.Количество() > 0 Тогда
			МассивНайденныхСтрок[0].Возвращено = СтрокаТЗ.Количество;
		КонецЕсли;                                     	
	КонецЦикла;
	
	// Запасы
	ТаблицаВозращенныхЗапасов = ПакетЗапросов[1].Выгрузить();
	
	Для Каждого СтрокаТЗ Из ТаблицаВозращенныхЗапасов Цикл   		
		МассивНайденныхСтрок = Объект.Запасы.НайтиСтроки(Новый Структура("Номенклатура" ,  СтрокаТЗ.Номенклатура));
		Если МассивНайденныхСтрок.Количество() > 0 Тогда
			МассивНайденныхСтрок[0].Возвращено = СтрокаТЗ.Количество;
		КонецЕсли;                                     	
	КонецЦикла;           	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия на переключатель закладок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	УстановитьОтображениеЭлементовПереключателя(Элемент.Имя);
	
	Если Элемент.Имя = "_ГруппаЗапасы" 
		Или Элемент.Имя = "_ГруппаЛечение" Тогда  	
		ОбновитьПоборНаСервере(Элемент.Имя); 	
	ИначеЕсли Элемент.Имя = "_ЗубнаяФормула" Тогда	
		ОбновитьДокумент(); 	
	КонецЕсли;
	
	Элементы.ГруппаПодвал.Видимость = (Элемент.Имя = "_ГруппаЛечение" ИЛИ Элемент.Имя = "_ГруппаЗапасы"); 
	
	ВидимостьСтрокиСостоянияОбъекта =  НЕ ((Элемент.Имя = "_ЗубнаяФормула" ИЛИ Элемент.Имя = "_ГруппаОбследование")
										  И СтрЧислоВхождений(Элементы.СостояниеОбъекта.Заголовок, "Пробит на ФР") > 0);
										  
	Элементы.ГруппаСостояниеОбъекта.Видимость = ВидимостьСтрокиСостоянияОбъекта;
		
	Если ЗначениеЗаполнено(ПринудительноеОбновлениеТаблицыПодбора) Тогда	
		
		ИзменитьСортировкуПодбора(ЭтотОбъект[ПринудительноеОбновлениеТаблицыПодбора], "Наименование", ПолучитьТекущийПорядокСортировкиПодбора(ЭтотОбъект[ПринудительноеОбновлениеТаблицыПодбора]));							
		// Элементы[ПринудительноеОбновлениеТаблицыПодбора].Обновить();
		ПринудительноеОбновлениеТаблицыПодбора = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить подбор на сервере.
//
Процедура ОбновитьПоборНаСервере(Имя)

	Если Имя = "_ГруппаЗапасы" Тогда
		Элементы._ПодборНоменклатур.Обновить();
	Иначе
		Элементы._ПодборНоменклатурУслуги.Обновить();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
