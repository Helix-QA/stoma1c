// Функция - Тестирование сервера
//
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция CallTouch_ТестированиеСервера(Сервер, Порт, Ключ, ОписаниеОшибки = "") Экспорт	
	 		
	MSXMLЗапрос = "cmd=accounts"
	+ "&token=" + Ключ;
	
	Попытка
		
		СайтАдрес = ПреобразоватьАдресСервера(Сервер);
		
		Если СтрНайти(Сервер, "https://") = 1 Тогда  
			Соединение = Новый HTTPСоединение(СайтАдрес, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		Иначе 
			Соединение = Новый HTTPСоединение(СайтАдрес, 80);
		КонецЕсли;		
		HTTPЗапрос = Новый HTTPЗапрос("/sys/crm_api.wcgp", ПолучитьЗаголовкиPOSTЗапроса());
		HTTPЗапрос.УстановитьТелоИзСтроки(MSXMLЗапрос);
		
		// Отправка POST-запроса и получение ответа
		СтруктураОтвета = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если СтруктураОтвета.КодСостояния <> 200 Тогда
			
			ОписаниеОшибки = НСтр("ru= 'Ошибка сервиса IP-телефонии: ';en= 'IP-telephony service error: '") + СтруктураОтвета.КодСостояния;
			ОтветHTTP = СтруктураОтвета.ПолучитьТелоКакСтроку();
			
			Если ОтветHTTP <> "" Тогда
				ПараметрыJSON  = ДекодироватьИзJSON(ОтветHTTP);
				ОписаниеОшибки = ОписаниеОшибки + " (" + ПараметрыJSON.error + ")";
			КонецЕсли;
			
			Возврат Ложь;
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Функция - событие звонок
//
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция CallTouch_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	УнифицированнаяСтруктураСобытия 							= ПолучитьУнифицированнуюСтруктуруСобытия();
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 				= ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 					= ПараметрыJSON.id;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие 		= Ложь;
	
	УнифицированнаяСтруктураСобытия.НомерТелефонаFrom 			= ПараметрыJSON.callerphone; 
	УнифицированнаяСтруктураСобытия.НомерТелефонаTo   			= ПараметрыJSON.phonenumber;
	УнифицированнаяСтруктураСобытия.ВнутреннийНомерСотрудника   = ?(ПараметрыJSON.Свойство("redirectNumber"), ПараметрыJSON.redirectNumber, "");
	УнифицированнаяСтруктураСобытия.НомерКонтрагента 		    = ПараметрыJSON.redirectNumber;
	
	
	// Если ПараметрыJSON.callphase = "INCOMING" Тогда 
	УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Входящий;
	// ИначеЕсли ПараметрыJSON.callphase = "OUTGOING" Тогда 
	//	УнифицированнаяСтруктураСобытия.НаправлениеВызова 		= Перечисления.ВариантыНаправленияВызова.Исходящий;
	// КонецЕсли;
	
	Если УнифицированнаяСтруктураСобытия.НаправлениеВызова = Перечисления.ВариантыНаправленияВызова.Входящий 
		И ПараметрыJSON.callphase = "calldisconnected" Тогда 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= ПараметрыJSON.status = "unsuccessful";
	Иначе 
		УнифицированнаяСтруктураСобытия.ПризнакЗвонокПропущен 	= Ложь;						
	КонецЕсли; 
	
	timestamp    = ?(ПараметрыJSON.Свойство("timestamp"), ПараметрыJSON.timestamp, 0);
	waiting_time = ?(ПараметрыJSON.Свойство("waiting_time"), ПараметрыJSON.waiting_time, 0);
	duration     = ?(ПараметрыJSON.Свойство("duration"), ПараметрыJSON.duration, 0);
	
	Если ПараметрыJSON.callphase = "callconnected" Тогда
		УнифицированнаяСтруктураСобытия.СтатусЗвонка 		   = Перечисления.СтатусыЗвонка.Вызов;							
		УнифицированнаяСтруктураСобытия.ВремяПоступленияВызова = МестноеВремя(Дата(1970, 01, 01) + timestamp, ПолучитьЧасовойПоясИнформационнойБазы());
		Возврат СобытиеЗвонокДозвон(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
		
	ИначеЕсли ПараметрыJSON.callphase = "calldisconnected" Тогда
		Если ПараметрыJSON.status = "successful" Тогда
			
			УнифицированнаяСтруктураСобытия.СтатусЗвонка 		  = Перечисления.СтатусыЗвонка.Разговор;	
			УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 	  = МестноеВремя(Дата(1970, 01, 01) + timestamp + waiting_time, ПолучитьЧасовойПоясИнформационнойБазы());
			
			СобытиеЗвонокСоединение(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			
			УнифицированнаяСтруктураСобытия.СтатусЗвонка 		  = Перечисления.СтатусыЗвонка.Завершен;
			// УнифицированнаяСтруктураСобытия.ВремяОтветаНаВызов 	  = МестноеВремя(Дата(1970, 01, 01) + timestamp + waiting_time, ПолучитьЧасовойПоясИнформационнойБазы());
			УнифицированнаяСтруктураСобытия.ВремяЗавершенияВызова = МестноеВремя(Дата(1970, 01, 01) + timestamp + waiting_time + duration, ПолучитьЧасовойПоясИнформационнойБазы());
			Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			
		ИначеЕсли ПараметрыJSON.status = "unsuccessful" Тогда		
			
			УнифицированнаяСтруктураСобытия.СтатусЗвонка  = Перечисления.СтатусыЗвонка.Пропущен;
			Возврат СобытиеЗвонокЗавершен(ПараметрыJSON, УнифицированнаяСтруктураСобытия, ОписаниеОшибки);
			
		КонецЕсли;
		
	Иначе
		
		ОписаниеОшибки = НСтр("ru= 'Функция не существует или не распознана.';en= 'The function does not exist or is not recognized.'");
		Возврат Ложь;	
		
	КонецЕсли;
	
КонецФункции

// Функция - событие запись разговора
//
// Параметры:
//  ИмяФункции		 - 	 - 
//  ПараметрыJSON	 - 	 - 
//  ОписаниеОшибки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция CallTouch_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыJSON, ОписаниеОшибки = "") Экспорт
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Токен")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("ИД") Тогда
		
		ОписаниеОшибки = НСтр("ru= 'Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.';en= 'Error! It is necessary to configure the IP-telephony server in the connected equipment.'");
		Возврат Ложь;
	КонецЕсли;
	
	// Https://api.calltouch.ru/calls-service/RestAPI/{ID сайта}/getnodeid/
	// Https://api-nodeX.calltouch.ru/
	// Https://api-node{номер сервера Calltouch}.calltouch.ru/calls-service/RestAPI/{идентификатор сайта}/calls-diary/calls/{callId}/download?clientApiId={токен}
	
	
	СсылкаНаЗаписьЗвонка = "http://api.calltouch.ru/calls-service/RestAPI/" + IPТелефонияПараметры.ИД + "/calls-diary/calls/" + ПараметрыJSON.id + "/download?clientApiId=" + IPТелефонияПараметры.Токен;	
	
	УнифицированнаяСтруктураСобытия 					  = ПолучитьУнифицированнуюСтруктуруСобытия();	
	УнифицированнаяСтруктураСобытия.ПОIPТелефонии 		  = ПОIPТелефонии;
	УнифицированнаяСтруктураСобытия.IDЗвонка 			  = ПараметрыJSON.id;
	УнифицированнаяСтруктураСобытия.СсылкаНаЗаписьЗвонка  = СсылкаНаЗаписьЗвонка;
	УнифицированнаяСтруктураСобытия.ФинализирующееСобытие = Ложь;
	
	ДобавитьОбновитьЗвонокВИсторию(ПараметрыJSON, УнифицированнаяСтруктураСобытия);
	
	//==========
	АдресСервера 			  = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
	
	Попытка
		
		Соединение   		  = Новый HTTPСоединение(АдресСервера, 80); 
		HTTPЗапрос   		  = Новый HTTPЗапрос("/stat/getrecordedfile/?IDConnection=" );
		HTTPОтвет     		  = Соединение.Получить(HTTPЗапрос);
		ДвоичныеДанныеФайла   = HTTPОтвет.ПолучитьТелоКакДвоичныеДанные();
		
	Исключение
		
		ИнформацияОбОшибке 	  = ИнформацияОбОшибке();
		ОписаниеОшибки 		  = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Неопределено;
		
	КонецПопытки;
	
	АдресВоВременномХранилище =?(ЗначениеЗаполнено(ДвоичныеДанныеФайла), ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла), "");
	//==========
	
	Возврат Истина;
	
КонецФункции

// Функция, тестирование сервера.
//
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция CallTouch_ПолучениеФайлаЗаписиРазговора(ПОIPТелефонии, IDЗаписи, ОписаниеОшибки = "", СтруктураПереадресации = Неопределено) Экспорт
	
	АдресВоВременномХранилище = "";
	IPТелефонияПараметры 	  = ПОIPТелефонии.Параметры.Получить();
	
	АдресСервера 			  = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
	
	Попытка
		
		Соединение   		  = Новый HTTPСоединение(АдресСервера, 80); 
		HTTPЗапрос   		  = Новый HTTPЗапрос("/stat/getrecordedfile/?IDConnection=" + IDЗаписи);
		HTTPОтвет     		  = Соединение.Получить(HTTPЗапрос);
		ДвоичныеДанныеФайла   = HTTPОтвет.ПолучитьТелоКакДвоичныеДанные();
		
	Исключение
		
		ИнформацияОбОшибке 	  = ИнформацияОбОшибке();
		ОписаниеОшибки 		  = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Неопределено;
		
	КонецПопытки;
	
	АдресВоВременномХранилище =?(ЗначениеЗаполнено(ДвоичныеДанныеФайла), ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла), "");
	
	Возврат АдресВоВременномХранилище; 
		
КонецФункции

// Функция - Call touch получить информацию о посетителе сайта
//
// Параметры:
//  ПОIPТелефонии		 - 	 - 
//  НомерТелефонаКлиента - 	 - 
//  ОписаниеОшибки		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция CallTouch_ПолучитьИнформациюОПосетителеСайта(ПОIPТелефонии, НомерТелефона, ОписаниеОшибки = "") Экспорт
	
	IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
	
	Если IPТелефонияПараметры = Неопределено
		ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Сервер")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("Токен")
		ИЛИ НЕ IPТелефонияПараметры.Свойство("ИД") Тогда
		
		ОписаниеОшибки = НСтр("ru= 'Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.';en= 'Error! It is necessary to configure the IP-telephony server in the connected equipment.'");
		Возврат Ложь;
	КонецЕсли;
	
	АдресСервера = ПреобразоватьАдресСервера(IPТелефонияПараметры.Сервер);
	
	Попытка
		
		ТекущаяДата = ТекущаяДатаСеанса();
	    ТекущаяДата = "" + День(ТекущаяДата) + "/" + Месяц(ТекущаяДата) + "/" + Год(ТекущаяДата);
		ТекущаяДата = СтрЗаменить(ТекущаяДата, Символы.НПП, "");
		ТекущаяДата = СтрЗаменить(ТекущаяДата, " ", "");
		
		Параметры = 
		"?clientApiId=" + IPТелефонияПараметры.Токен +
		"&dateFrom="    + ТекущаяДата +
		"&dateTo="      + ТекущаяДата +
		"&page="        + 1 +
		"&limit="       + 500 +
		"&attribution=" + 0 +
		"&ani.value="   + НомерТелефона;		
		
		Соединение    = Новый HTTPСоединение(АдресСервера, ,,,,, Новый ЗащищенноеСоединениеOpenSSL()); 
		HTTPЗапрос    = Новый HTTPЗапрос("/calls-service/RestAPI/" + IPТелефонияПараметры.ИД + "/calls-diary/calls" + Параметры);
		HTTPОтвет     = Соединение.ВызватьHTTPМетод("GET", HTTPЗапрос);
		
		ПараметрыJSON = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		ПараметрыJSON = ДекодироватьИзJSON(ПараметрыJSON);
		
		Если ПараметрыJSON.Свойство("records") Тогда 
			
		 	Индекс = ПараметрыJSON.records.Количество() - 1;
			ПоследнийЗвонок = ПараметрыJSON.records[Индекс];
			
		КонецЕсли;
				
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки 	   = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		Возврат Неопределено;
		
	КонецПопытки;
		
	Возврат ПоследнийЗвонок;
	
КонецФункции

#КонецОбласти

#КонецОбласти

