// Процедура - При создании при чтении на сервере
//
// Параметры:
//  Форма			 - УправляемаяФорма	 - 
//  ВладелецКИ		 - ЛюбаяСсылка	 - владелец контактной информации
//  ШиринаПоляВида	 - число	 - 
//
Процедура КонтактнаяИнформацияПриСозданииПриЧтенииНаСервере(СтруктураНовогоТелефонногоНомера = Неопределено) 
	
	ВладелецКИСсылка = Объект.Ссылка;
	ВладелецКИОбъект = Объект;		
	
	// Определение вспомогательной информации
	Если ТипЗнч(ВладелецКИСсылка) = Тип("СправочникСсылка.Сотрудники") Тогда
		// И ((ЗначениеЗаполнено(ВладелецКИСсылка) И ВладелецКИСсылка.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты) ИЛИ (НЕ ЗначениеЗаполнено(ВладелецКИСсылка) И ВладелецКИОбъект.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты)) Тогда 
		ГруппаВидовКИ = Справочники.ВидыКонтактнойИнформации.СправочникСотрудники;
	Иначе 	
		ПолноеИмяОбъектаМетаданных = ВладелецКИСсылка.Метаданные().ПолноеИмя();
		ГруппаВидовКИ = Справочники.ВидыКонтактнойИнформации[СтрЗаменить(ПолноеИмяОбъектаМетаданных, ".", "")];
	КонецЕсли;
	
	// Создание таблиц-реквизитов формы, если отсутствуют
	ДобавитьРеквизитыФормыКонтактнойИнформации();
	
	// Кэширование информации о доступных видах контактной информации в созданной таблице
	ПрочитатьСвойстваВидовКонтактнойИнформации(ГруппаВидовКИ);
	
	// Чтение имеющейся контактной информации объекта в созданную таблицу для отображения
	ЗаполнитьТаблицуКонтактнойИнформации(СтруктураНовогоТелефонногоНомера);
	
	// Пересоздание элементов формы по информации из таблицы для отображения
	ОбновитьЭлементыКонтактнойИнформации();
	
КонецПроцедуры

&НаСервере
// Процедура - Перед записью на сервере
//
// Параметры:
//  Форма			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//
Процедура КонтактнаяИнформацияПередЗаписьюНаСервере(ТекущийОбъект)
	
	// КонтактнаяИнформацияКопия = ТекущийОбъект.КонтактнаяИнформация.Выгрузить();
	ТекущийОбъект.КонтактнаяИнформация.Очистить();
	
	Для Каждого ДанныеКИ Из ЭтаФорма.КонтактнаяИнформация Цикл
		УправлениеКонтактнойИнформациейСтоматология.ЗаписатьКонтактнуюИнформацию(ТекущийОбъект, ДанныеКИ.ЗначенияПолей, ДанныеКИ.Вид, ДанныеКИ.Тип);
	КонецЦикла;
	
	// Для ИндексСтроки = 0 По ТекущийОбъект.КонтактнаяИнформация.Количество() - 1 Цикл
	//	ТекущийОбъект.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке = КонтактнаяИнформацияКопия[ИндексСтроки].НеУчаствоватьВРассылке;
	// КонецЦикла;	
	
КонецПроцедуры

&НаСервере
// Процедура - Добавить реквизиты формы контактной информации
//
// Параметры:
//  Форма	 - 	 - 
//
Процедура ДобавитьРеквизитыФормыКонтактнойИнформации()
	
	МассивДобавляемыхРеквизитов = Новый Массив;
	СписокРеквизитовФормы = ЭтаФорма.ПолучитьРеквизиты();
	
	СоздатьТаблицуКонтактнаяИнформация = Истина;
	СоздатьТаблицуСвойстваВидовКонтактнойИнформации = Истина;
	
	Для Каждого Реквизит Из СписокРеквизитовФормы Цикл
		Если Реквизит.Имя = "КонтактнаяИнформация" Тогда
			СоздатьТаблицуКонтактнаяИнформация = Ложь;
		ИначеЕсли Реквизит.Имя = "СвойстваВидовКонтактнойИнформации" Тогда
			СоздатьТаблицуСвойстваВидовКонтактнойИнформации = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	ОписаниеСтрока = Новый ОписаниеТипов("Строка");
	ОписаниеБулево = Новый ОписаниеТипов("Булево");
	
	Если СоздатьТаблицуКонтактнаяИнформация Тогда
		
		ИмяТаблицы = "КонтактнаяИнформация";
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы, Новый ОписаниеТипов("ТаблицаЗначений"),,, Истина));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Вид", Новый ОписаниеТипов("СправочникСсылка.ВидыКонтактнойИнформации"), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Тип", Новый ОписаниеТипов("ПеречислениеСсылка.ТипыКонтактнойИнформации"), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(500)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Комментарий", ОписаниеСтрока, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЗначенияПолей", ОписаниеСтрока, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Значение", ОписаниеСтрока, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("НеУчаствоватьВРассылке", ОписаниеБулево, ИмяТаблицы));		
		
	КонецЕсли;
	
	Если СоздатьТаблицуСвойстваВидовКонтактнойИнформации Тогда
		
		ИмяТаблицы = "СвойстваВидовКонтактнойИнформации";
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы, Новый ОписаниеТипов("ТаблицаЗначений"),,, Истина));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Вид", Новый ОписаниеТипов("СправочникСсылка.ВидыКонтактнойИнформации"), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ПредставлениеВида", ОписаниеСтрока, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Тип", Новый ОписаниеТипов("ПеречислениеСсылка.ТипыКонтактнойИнформации"), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВыводитьВФормеВсегда", ОписаниеБулево, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("РазрешитьВводНесколькихЗначений", ОписаниеБулево, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОбязательноеЗаполнение", ОписаниеБулево, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Подсказка", ОписаниеСтрока, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ПроверятьКорректность", ОписаниеБулево, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВидРедактирования", ОписаниеСтрока, ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("МногострочноеПоле", ОписаниеБулево, ИмяТаблицы));
		
	КонецЕсли;
	
	Если МассивДобавляемыхРеквизитов.Количество() > 0 Тогда
		ЭтаФорма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Прочитать свойства видов контактной информации
//
// Параметры:
//  Форма			 - 	 - 
//  ГруппаВидовКИ	 - 	 - 
//
Процедура ПрочитатьСвойстваВидовКонтактнойИнформации(ГруппаВидовКИ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПорядокТиповКИ.Тип КАК Тип,
	|	ПорядокТиповКИ.Порядок КАК Порядок
	|ПОМЕСТИТЬ втПорядокТипов
	|ИЗ
	|	&ПорядокТиповКИ КАК ПорядокТиповКИ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыКонтактнойИнформации.Ссылка КАК Вид,
	|	ПРЕДСТАВЛЕНИЕ(ВидыКонтактнойИнформации.Ссылка) КАК ПредставлениеВида,
	|	ВидыКонтактнойИнформации.Тип КАК Тип,
	|	ЕСТЬNULL(НастройкиВидовКонтактнойИнформации.ВыводитьВФормеВсегда, ЛОЖЬ) КАК ВыводитьВФормеВсегда,
	|	ВидыКонтактнойИнформации.РазрешитьВводНесколькихЗначений КАК РазрешитьВводНесколькихЗначений,
	|	ВидыКонтактнойИнформации.ОбязательноеЗаполнение КАК ОбязательноеЗаполнение,
	|	"""" КАК Подсказка,
	|	ВидыКонтактнойИнформации.ПроверятьКорректность КАК ПроверятьКорректность,
	|	ВидыКонтактнойИнформации.ВидРедактирования = ""Диалог"" КАК РедактированиеТолькоВДиалоге,
	|	ВидыКонтактнойИнформации.ВидРедактирования КАК ВидРедактирования,
	|	ВидыКонтактнойИнформации.ВидПоляДругое КАК ВидПоляДругое,
	|	ЛОЖЬ КАК МногострочноеПоле
	|ИЗ
	|	Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядокТипов КАК втПорядокТипов
	|		ПО ВидыКонтактнойИнформации.Тип = втПорядокТипов.Тип
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиВидовКонтактнойИнформации КАК НастройкиВидовКонтактнойИнформации
	|		ПО ВидыКонтактнойИнформации.Ссылка = НастройкиВидовКонтактнойИнформации.Вид
	|ГДЕ
	|	ВидыКонтактнойИнформации.ПометкаУдаления = ЛОЖЬ
	|	И (ВидыКонтактнойИнформации.Родитель = &ГруппаВидовКИ
	|			ИЛИ ВидыКонтактнойИнформации.Родитель.Родитель = &ГруппаВидовКИ)
	|	И НЕ ВидыКонтактнойИнформации.ЭтоГруппа
	|	И ВидыКонтактнойИнформации.Используется = ИСТИНА
	|
	|УПОРЯДОЧИТЬ ПО
	|	втПорядокТипов.Порядок,
	|	ВидыКонтактнойИнформации.РеквизитДопУпорядочивания";

	// Запрос = Новый Запрос;
	// Запрос.Текст = 
	// "ВЫБРАТЬ
	//|	ПорядокТиповКИ.Тип КАК Тип,
	//|	ПорядокТиповКИ.Порядок КАК Порядок
	//|ПОМЕСТИТЬ втПорядокТипов
	//|ИЗ
	//|	&ПорядокТиповКИ КАК ПорядокТиповКИ
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	ВидыКонтактнойИнформации.Ссылка КАК Вид,
	//|	ПРЕДСТАВЛЕНИЕ(ВидыКонтактнойИнформации.Ссылка) КАК ПредставлениеВида,
	//|	ВидыКонтактнойИнформации.Тип КАК Тип,
	//|	ВидыКонтактнойИнформации.ВыводитьПоУмолчанию КАК ВыводитьВФормеВсегда,
	//|	ВидыКонтактнойИнформации.РазрешитьВводНесколькихЗначений КАК РазрешитьВводНесколькихЗначений,
	//|	ВидыКонтактнойИнформации.ОбязательноеЗаполнение,
	//|	ВидыКонтактнойИнформации.Подсказка,
	//|	ВидыКонтактнойИнформации.ПроверятьКорректность,
	//|	ВидыКонтактнойИнформации.ВидРедактирования,
	//|	ВидыКонтактнойИнформации.МногострочноеПоле
	//|ИЗ
	//|	Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
	//|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядокТипов КАК втПорядокТипов
	//|		ПО ВидыКонтактнойИнформации.Тип = втПорядокТипов.Тип
	//|ГДЕ
	//|	ВидыКонтактнойИнформации.ПометкаУдаления = ЛОЖЬ
	//|	И ВидыКонтактнойИнформации.Родитель = &ГруппаВидовКИ
	//|	И ВидыКонтактнойИнформации.Используется
	//|
	//|УПОРЯДОЧИТЬ ПО
	//|	втПорядокТипов.Порядок,
	//|	ВидыКонтактнойИнформации.РеквизитДопУпорядочивания";
	
	Запрос.УстановитьПараметр("ПорядокТиповКИ", ПорядокТиповКИ());
	Запрос.УстановитьПараметр("ГруппаВидовКИ", ГруппаВидовКИ);
	
	ТаблицаСвойств = Запрос.Выполнить().Выгрузить();
	ЭтаФорма.СвойстваВидовКонтактнойИнформации.Загрузить(ТаблицаСвойств);
	
КонецПроцедуры

&НаСервере
// Процедура - Заполнить таблицу контактной информации
//
// Параметры:
//  Форма		 - 	 - 
//  ВладелецКИ	 - 	 - 
//
Процедура ЗаполнитьТаблицуКонтактнойИнформации(СтруктураНовогоТелефонногоНомера = Неопределено)
	
	ЭтаФорма.КонтактнаяИнформация.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПорядокТипов.Тип КАК Тип,
	|	ПорядокТипов.Порядок КАК Порядок
	|ПОМЕСТИТЬ втПорядокТипов
	|ИЗ
	|	&ПорядокТипов КАК ПорядокТипов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыКонтактнойИнформации.Ссылка КАК Вид,
	|	ВидыКонтактнойИнформации.Тип КАК Тип,
	|	ВидыКонтактнойИнформации.РеквизитДопУпорядочивания КАК ПорядокВидов,
	|	втПорядокТипов.Порядок КАК ПорядокТипов
	|ПОМЕСТИТЬ втВсегдаВыводимыеВиды
	|ИЗ
	|	Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядокТипов КАК втПорядокТипов
	|		ПО ВидыКонтактнойИнформации.Тип = втПорядокТипов.Тип
	|ГДЕ
	|	ВидыКонтактнойИнформации.Ссылка В(&ВсегдаВыводимыеВиды)
	|	И ВидыКонтактнойИнформации.Используется
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Вид
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВладелецКонтактнаяИнформация.Вид КАК Вид,
	|	ВладелецКонтактнаяИнформация.Тип КАК Тип,
	|	ВладелецКонтактнаяИнформация.Представление КАК Представление,
	|	ВладелецКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
	|	ВладелецКонтактнаяИнформация.Вид.РеквизитДопУпорядочивания КАК ПорядокВидов,
	|	втПорядокТипов.Порядок КАК ПорядокТипов
	|ПОМЕСТИТЬ втДанныеКИ
	|ИЗ
	|	Справочник.Сотрудники.КонтактнаяИнформация КАК ВладелецКонтактнаяИнформация
	|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядокТипов КАК втПорядокТипов
	|		ПО ВладелецКонтактнаяИнформация.Тип = втПорядокТипов.Тип
	|ГДЕ
	|	ВладелецКонтактнаяИнформация.Ссылка = &ВладелецКИ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Вид
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(втДанныеКИ.Вид, втВсегдаВыводимыеВиды.Вид) КАК Вид,
	|	ЕСТЬNULL(втДанныеКИ.Тип, втВсегдаВыводимыеВиды.Тип) КАК Тип,
	|	ЕСТЬNULL(втДанныеКИ.Представление, """") КАК Представление,
	|	ЕСТЬNULL(втДанныеКИ.ЗначенияПолей, """") КАК ЗначенияПолей,
	|	ЕСТЬNULL(втДанныеКИ.ПорядокТипов, втВсегдаВыводимыеВиды.ПорядокТипов) КАК ПорядокТипов,
	|	ЕСТЬNULL(втДанныеКИ.ПорядокВидов, втВсегдаВыводимыеВиды.ПорядокВидов) КАК ПорядокВидов
	|ИЗ
	|	втВсегдаВыводимыеВиды КАК втВсегдаВыводимыеВиды
	|		ПОЛНОЕ СОЕДИНЕНИЕ втДанныеКИ КАК втДанныеКИ
	|		ПО втВсегдаВыводимыеВиды.Вид = втДанныеКИ.Вид
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокТипов,
	|	ПорядокВидов";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Справочник.Сотрудники", Объект.Ссылка.Метаданные().ПолноеИмя());
	Запрос.УстановитьПараметр("ВладелецКИ",		Объект.Ссылка);
	Запрос.УстановитьПараметр("ПорядокТипов",	ПорядокТиповКИ());
	Запрос.УстановитьПараметр("ВсегдаВыводимыеВиды", 
	ЭтаФорма.СвойстваВидовКонтактнойИнформации.Выгрузить(Новый Структура("ВыводитьВФормеВсегда", Истина), "Вид"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если (ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Выборка.ЗначенияПолей)) 
			ИЛИ Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
			
			НоваяСтрока = ЭтаФорма.КонтактнаяИнформация.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.Комментарий = УправлениеКонтактнойИнформациейСтоматология.КомментарийКонтактнойИнформации(Выборка.ЗначенияПолей);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ СтруктураНовогоТелефонногоНомера = Неопределено Тогда 
		Если СтруктураНовогоТелефонногоНомера.Свойство("ДобавитьНомерТелефона") И СтруктураНовогоТелефонногоНомера.Свойство("НомерТелефона") Тогда
			НоваяСтрока = Неопределено;
			МассивСтрокИмеющейсяКИ 		= ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
			Если НЕ МассивСтрокИмеющейсяКИ.Количество() = 0 Тогда 
				Для Каждого СтрокаМассива Из МассивСтрокИмеющейсяКИ Цикл 
					Если НЕ ЗначениеЗаполнено(СтрокаМассива.ЗначенияПолей) И НЕ ЗначениеЗаполнено(СтрокаМассива.Представление) Тогда
						НоваяСтрока 	= СтрокаМассива;
						Прервать;
					КонецЕсли;
				КонецЦикла;	
			КонецЕсли;
			Если НоваяСтрока = Неопределено Тогда 
				НоваяСтрока 			= ЭтаФорма.КонтактнаяИнформация.Добавить();
				НоваяСтрока.Вид 		= ?(Объект.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента);				
			КонецЕсли;
			НоваяСтрока.Тип 			= Перечисления.ТипыКонтактнойИнформации.Телефон;
			Если НЕ ЗначениеЗаполнено(НоваяСтрока.Вид) Тогда 
				НоваяСтрока.Вид 		= ?(Объект.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Справочники.ВидыКонтактнойИнформации.ТелефонКлиента, Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента);				
			КонецЕсли;	
			НоваяСтрока.Представление 	= СтруктураНовогоТелефонногоНомера.НомерТелефона;
			НоваяСтрока.ЗначенияПолей 	= КонтактнаяИнформацияВызовСервераСтома.КонтактнаяИнформацияXMLПоПредставлению(НоваяСтрока.Представление, НоваяСтрока.Вид);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Есть другие заполненные строки вида КИ
//
// Параметры:
//  Форма					 - 	 - 
//  ПроверяемаяСтрока		 - 	 - 
//  ВидКонтактнойИнформации	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЕстьДругиеЗаполненныеСтрокиВидаКИ(Знач ПроверяемаяСтрока, Знач ВидКонтактнойИнформации)
	
	ВсеСтрокиЭтогоВида = ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(
	Новый Структура("Вид", ВидКонтактнойИнформации));
	
	Для Каждого СтрокаВида Из ВсеСтрокиЭтогоВида Цикл
		
		Если СтрокаВида <> ПроверяемаяСтрока И Не ПустаяСтрока(СтрокаВида.Представление) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
// Процедура - Добавить команду контекстного меню
//
// Параметры:
//  Форма		 - 	 - 
//  ИмяКоманды	 - 	 - 
//  Картинка	 - 	 - 
//  Заголовок	 - 	 - 
//  Подсказка	 - 	 - 
//  ПолеВладелец - 	 - 
//
Процедура ДобавитьКомандуКонтекстногоМеню(ИмяКоманды, Картинка, Заголовок, Подсказка, ПолеВладелец)
	
	Если ЭтаФорма.Команды.Найти(ИмяКоманды) = Неопределено Тогда
		Команда = ЭтаФорма.Команды.Добавить(ИмяКоманды);
		Команда.Картинка = Картинка;
		Команда.Заголовок = Заголовок;
		Команда.Подсказка = Подсказка;
		Команда.Действие = "Подключаемый_КонтактнаяИнформация_ВыполнитьКоманду";
	КонецЕсли;
	
	Кнопка = ЭтаФорма.Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), ПолеВладелец.КонтекстноеМеню);
	Кнопка.ИмяКоманды = ИмяКоманды;
	
КонецПроцедуры

&НаСервере
// Процедура - Добавить команду контекстного меню
//
// Параметры:
//  Форма		 - 	 - 
//  ИмяКоманды	 - 	 - 
//  Картинка	 - 	 - 
//  Заголовок	 - 	 - 
//  Подсказка	 - 	 - 
//  ПолеВладелец - 	 - 
//
Процедура ДобавитьКомандуКнопкой(ИмяКоманды, Картинка, Заголовок, Подсказка, ГруппаДействий)
	
	Если ЭтаФорма.Команды.Найти(ИмяКоманды) = Неопределено Тогда
		Команда = ЭтаФорма.Команды.Добавить(ИмяКоманды);
		Команда.Отображение = ОтображениеКнопки.Картинка;
		Команда.Картинка = Картинка;
		Команда.Заголовок = Заголовок;
		Команда.Подсказка = Подсказка;
		Команда.Действие = "Подключаемый_КонтактнаяИнформация_ВыполнитьКоманду";
	КонецЕсли;
	
	Кнопка = ЭтаФорма.Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), ГруппаДействий);
	Кнопка.ИмяКоманды = ИмяКоманды;
	
КонецПроцедуры

&НаСервере
// Процедура обновляет элементы формы в соответствии с данными в реквизите-таблице
//
// Параметры:
//  Форма	 - УправляемаяФорма	 - форма-владелец контактной информации
//
Процедура ОбновитьЭлементыКонтактнойИнформации()
	
	ПараметрыСвойствПолейКИ = ПолучитьПараметрыСвойствПолейКИ(Объект.Ссылка);
	
	
	КомандыДобавления = ЭтаФорма.Элементы.Найти("КнопкаДобавитьКонтактнуюИнформацию");
	Если КомандыДобавления <> Неопределено Тогда
		КомандыДобавления.Видимость = КонтактнаяИнформацияКлиентСервер.СписокВидовДляДобавленияКонтактнойИнформации(ЭтаФорма.СвойстваВидовКонтактнойИнформации, ЭтаФорма.КонтактнаяИнформация).Количество() > 0; // И НЕ ПараметрыСвойствПолейКИ.ТолькоПросмотр;
	КонецЕсли;
	
	// Элементы = ЭтаФорма.Элементы;
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из Элементы.КонтактнаяИнформация.ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	ШиринаПоляКомментария = 9;
	Если УдаляемыеЭлементы.Количество() > 0 Тогда
		ШиринаПоляВида = Элементы["ВидКИ_0"].Ширина;
	КонецЕсли;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	Отбор = Новый Структура("Вид");
	
	Для Каждого ДанныеКИ Из ЭтаФорма.КонтактнаяИнформация Цикл
		
		ИндексКИ = ЭтаФорма.КонтактнаяИнформация.Индекс(ДанныеКИ);
		Отбор.Вид = ДанныеКИ.Вид;
		НайденныеСтроки = ЭтаФорма.СвойстваВидовКонтактнойИнформации.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		СвойстваВида 			= НайденныеСтроки[0];
		ДоступенВводКомментария = ДляТипаКонтактнойИнформацииДоступенВводКомментария(ДанныеКИ.Тип);
		ДоступенЗвонок          = ДанныеКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон И Справочники.ТелефонныеАппараты.ПроверитьВозможностьЗвонкаНаДанномПК();
		
		// Создаем группу
		// --------------------------------------------------------------------------------------------		
		ГруппаЗначениеКИ = Элементы.Добавить("КИ_" + ИндексКИ, Тип("ГруппаФормы"), Элементы.КонтактнаяИнформация);
		ГруппаЗначениеКИ.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаЗначениеКИ.Заголовок = ДанныеКИ.Вид;
		ГруппаЗначениеКИ.Отображение = ОтображениеОбычнойГруппы.Нет;
		ГруппаЗначениеКИ.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		ГруппаЗначениеКИ.ОтображатьЗаголовок = Ложь;		
		ГруппаЗначениеКИ.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
		
		// Создаем картинку
		// --------------------------------------------------------------------------------------------		
		ДекорацияДействие = Элементы.Добавить("ДействиеКИ_" + ИндексКИ, Тип("ДекорацияФормы"), ГруппаЗначениеКИ);
		ДекорацияДействие.Вид						 = ВидДекорацииФормы.Картинка;
		ДекорацияДействие.Картинка					 = КартинкаДействияПоТипуКонтактнойИнформации(ДанныеКИ.Тип);
		// ДекорацияДействие.Гиперссылка = Истина;
		ДекорацияДействие.АвтоМаксимальнаяШирина	 = Ложь;
		ДекорацияДействие.РастягиватьПоГоризонтали	 = Ложь;
		ДекорацияДействие.Ширина					 = 2;
		ДекорацияДействие.Высота					 = 1;		
		
		Если ДанныеКИ.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон") 
			Или ДанныеКИ.Тип = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты") Тогда  			
			ЭлементФормы 			 = Элементы.Добавить("РазрешитьЗапретитьРассылку_" + ИндексКИ, Тип("ДекорацияФормы"), ГруппаЗначениеКИ);	
			ЭлементФормы.Вид		 = ВидДекорацииФормы.Картинка;
			ЭлементФормы.Картинка    = ПолучитьКартинку(ЭтаФорма.КонтактнаяИнформация[ИндексКИ].НеУчаствоватьВРассылке);
			ЭлементФормы.Гиперссылка = Истина;
			ЭлементФормы.УстановитьДействие("Нажатие", "ПроцедураОбработкиНажатияДинамическойКнопки");
			ЭлементФормы.АвтоМаксимальнаяШирина	    = Ложь;
			ЭлементФормы.РастягиватьПоГоризонтали	= Ложь;
			ЭлементФормы.Ширина	     = 1;
			ЭлементФормы.Высота		 = 1;
			ЭлементФормы.Подсказка   = ПолучитьПодсказку(ЭтаФорма.КонтактнаяИнформация[ИндексКИ].НеУчаствоватьВРассылке) ;
			ЭлементФормы.ОтображениеПодсказки = ОтображениеПодсказки.Всплывающая;
		Иначе
			ЭлементФормы 			 = Элементы.Добавить("РазрешитьЗапретитьРассылкуПустая_" + ИндексКИ, Тип("ДекорацияФормы"), ГруппаЗначениеКИ);	
			ЭлементФормы.Вид		 = ВидДекорацииФормы.Картинка;
			ЭлементФормы.Ширина      = 1;
			ЭлементФормы.Высота					  = 1;
			ЭлементФормы.АвтоМаксимальнаяШирина	  = Ложь;
			ЭлементФормы.РастягиватьПоГоризонтали = Ложь;
		КонецЕсли;		
		
		// Создаем надпись
		// --------------------------------------------------------------------------------------------		
		ПолеВид = Элементы.Добавить("ВидКИ_" + ИндексКИ, Тип("ПолеФормы"), ГруппаЗначениеКИ);
		ПолеВид.Вид 								= ВидПоляФормы.ПолеНадписи;
		ПолеВид.ПутьКДанным 						= "КонтактнаяИнформация[" + ИндексКИ + "].Вид";
		ПолеВид.ПоложениеЗаголовка 					= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеВид.АвтоМаксимальнаяШирина 				= Ложь;
		ПолеВид.РастягиватьПоГоризонтали 			= Ложь;
		ПолеВид.МаксимальнаяШирина 					= ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина;
		
		ПолеВид.Ширина   = ПараметрыСвойствПолейКИ.Надпись_МаксимальнаяШирина - 4;	
		
		ДоступноРедактированиеВДиалоге = ДляТипаКонтактнойИнформацииДоступноРедактированиеВДиалоге(ДанныеКИ.Тип);
		
		
		// Создаем представление
		// --------------------------------------------------------------------------------------------		
		ПолеПредставление = Элементы.Добавить("ПредставлениеКИ_" + ИндексКИ, Тип("ПолеФормы"), ГруппаЗначениеКИ);
		ПолеПредставление.Вид 						= ВидПоляФормы.ПолеВвода;
		ПолеПредставление.ПутьКДанным 				= "КонтактнаяИнформация[" + ИндексКИ + "].Представление";
		ПолеПредставление.ТолькоПросмотр 			= ПараметрыСвойствПолейКИ.ТолькоПросмотр И ЗначениеЗаполнено(ДанныеКИ.ЗначенияПолей);
		ПолеПредставление.ПоложениеЗаголовка 		= ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеПредставление.КнопкаВыбора 				= ДоступноРедактированиеВДиалоге;
		ПолеПредставление.Подсказка 				= СвойстваВида.Подсказка;
		ПолеПредставление.АвтоОтметкаНезаполненного = СвойстваВида.ОбязательноеЗаполнение;
		ПолеПредставление.АвтоМаксимальнаяШирина 	= Ложь;
		// ПолеПредставление.РастягиватьПоГоризонтали 	= Ложь;
		ПолеПредставление.МаксимальнаяШирина 		= ?(ДоступенВводКомментария, ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_СКомм, ПараметрыСвойствПолейКИ.Представление_МаксимальнаяШирина_БезКомм) - 1;
		ПолеПредставление.ШиринаВыпадающегоСписка 	= 40;
		ПолеПредставление.УстановитьДействие("ПриИзменении", "Подключаемый_ПредставлениеКИПриИзменении");
		ПолеПредставление.УстановитьДействие("Очистка", "Подключаемый_ПредставлениеКИОчистка");
		Если СвойстваВида.ВидРедактирования = "Диалог" Тогда
			ПолеПредставление.РедактированиеТекста 	= Ложь;
			ПолеПредставление.ЦветФона 				= ЦветаСтиля.КонтактнаяИнформацияСРедактированиемВДиалогеЦвет;
		КонецЕсли;
		Если ДоступноРедактированиеВДиалоге Тогда
			ПолеПредставление.УстановитьДействие("НачалоВыбора", "Подключаемый_ПредставлениеКИНачалоВыбора");
		КонецЕсли;
		Если СвойстваВида.МногострочноеПоле Тогда
			ПолеПредставление.МногострочныйРежим 	= Истина;
			ПолеПредставление.Высота 				= 2;
			ПолеПредставление.РастягиватьПоВертикали = Ложь;
		КонецЕсли;
		
		// Создаем поле для комментария
		// --------------------------------------------------------------------------------------------
		Если ДоступенВводКомментария Тогда
			
			ПолеКомментарий = Элементы.Добавить("КомментарийКИ_" + ИндексКИ, Тип("ПолеФормы"), ГруппаЗначениеКИ);
			ПолеКомментарий.Вид 						= ВидПоляФормы.ПолеВвода;
			ПолеКомментарий.ПутьКДанным 				= "КонтактнаяИнформация[" + ИндексКИ + "].Комментарий";
			ПолеКомментарий.ТолькоПросмотр 				= ПараметрыСвойствПолейКИ.ТолькоПросмотр И ЗначениеЗаполнено(ДанныеКИ.ЗначенияПолей);			
			ПолеКомментарий.ПоложениеЗаголовка 			= ПоложениеЗаголовкаЭлементаФормы.Нет;
			ПолеКомментарий.ПропускатьПриВводе 			= Истина;
			ПолеКомментарий.ПодсказкаВвода 				= НСтр("ru='Прим.';en='Note'");
			// ПолеКомментарий.Ширина 						= 8;
			ПолеКомментарий.АвтоМаксимальнаяШирина 		= Ложь;
			// ПолеКомментарий.РастягиватьПоГоризонтали 	= Ложь;
			ПолеКомментарий.МаксимальнаяШирина 			= ?(ДоступенЗвонок, 5, ПараметрыСвойствПолейКИ.Комментарий_МаксимальнаяШирина);
			ПолеКомментарий.УстановитьДействие("ПриИзменении", "Подключаемый_КомментарийКИПриИзменении");
			
		КонецЕсли;
		
		// Команды контекстного меню: показать адрес в Яндекс.Карты или GoogleMaps
		Если ДанныеКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
			
			ДобавитьКомандуКонтекстногоМеню(
			"КонтекстноеМенюКартаЯндекс_" + ИндексКИ,
			БиблиотекаКартинок.ЯндексКарты,
			НСтр("ru='Адрес на Яндекс.Картах';en='Address on Yandex.Maps'"),
			НСтр("ru='Показывает адрес на картах Яндекс.Карты';en='Shows address on YandexMaps Maps'"),
			ПолеПредставление
			);
			ДобавитьКомандуКонтекстногоМеню(
			"КонтекстноеМенюКартаGoogle_" + ИндексКИ,
			БиблиотекаКартинок.GoogleMaps,
			НСтр("ru='Адрес на Google Maps';en='Address on Google Maps'"),
			НСтр("ru='Показывает адрес на карте Google Maps';en='Shows the address on the map Google Maps'"),
			ПолеПредставление
			);
			
		ИначеЕсли ДоступенЗвонок Тогда
			
			ДобавитьКомандуКнопкой(
			"ПозвонитьПоIPТелефонии_" + ИндексКИ,
			БиблиотекаКартинок.ТелефонныйЗвонокИсходящий,
			НСтр("ru='Позвонить';en='Call'"),
			НСтр("ru='Позвонить клиенту по IP-телефонии';en='Call to the client by IP telephony'"),
			ГруппаЗначениеКИ
			);					
			
		ИначеЕсли ДанныеКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
			
			СервисSMSРассылки = Константы.СервисSMSРассылкиПоУмолчанию.Получить();
			Если ЗначениеЗаполнено(СервисSMSРассылки) Тогда
				ДобавитьКомандуКонтекстногоМеню(
				"ОтправитьSMS_" + ИндексКИ,
				БиблиотекаКартинок.ОтправитьSMS,
				НСтр("ru = 'Отправить SMS'"),
				НСтр("ru = 'Отправить SMS'"),
				ПолеПредставление
				);	
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;
	
	КонтактнаяИнформацияКлиентСервер.ЗаполнитьСписокВыбораАдресов(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Процедура обработки нажатия динамической кнопки.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ПроцедураОбработкиНажатияДинамическойКнопки(Элемент)	
	
	ИндексСтроки      = Число(Сред(Элемент.Имя, СтрДлина("РазрешитьЗапретитьРассылку_")+1));// Цел(Прав(Элемент.имя, 1));
	ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке = Не ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке;
	Элемент.Картинка  = ПолучитьКартинку(ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке);
	Элемент.Подсказка = ПолучитьПодсказку(ЭтаФорма.КонтактнаяИнформация[ИндексСтроки].НеУчаствоватьВРассылке);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьКартинку(Флаг)
	
	Возврат ?(Флаг, БиблиотекаКартинок.РассылкаЗапрещена, БиблиотекаКартинок.РассылкаРазрешена);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьПодсказку(Флаг)
	
	Возврат ?(Флаг, НСтр("ru='Рассылка запрещена';en='Newsletter is prohibited'"), НСтр("ru='Рассылка разрешена';en='Newsletter is allowed'"));
	
КонецФункции

&НаСервере
// Функция - Для типа контактной информации доступно редактирование в диалоге
//
// Параметры:
//  ТипКИ	 - ПеречислениеСсылка.ТипыКонтактнойИнформации	 - тип для которого проверяется доступность редактирования в диалоге
// 
// Возвращаемое значение:
//  Булево - признак возможности редактирования в диалоге
//
Функция ДляТипаКонтактнойИнформацииДоступноРедактированиеВДиалоге(ТипКИ)
	
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
		Возврат Истина;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
		Возврат Истина;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.Факс Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаСервере
// Функция - Для типа контактной информации доступен ввод комментария
//
// Параметры:
//  ТипКИ	 - ПеречислениеСсылка.ТипыКонтактнойИнформации	 - тип для которого проверяется доступность ввода комментария
// 
// Возвращаемое значение:
//  Булево - признак наличия поля комментария на форме
//
Функция ДляТипаКонтактнойИнформацииДоступенВводКомментария(ТипКИ)
	
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Адрес Или ТипКИ = Перечисления.ТипыКонтактнойИнформации.Другое Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

&НаСервере
// Функция - Картинка действия по типу контактной информации
//
// Параметры:
//  ТипКИ	 - ПеречислениеСсылка.ТипыКонтактнойИнформации	 - тип для которого получается картинка
// 
// Возвращаемое значение:
//  Картинка - пиктограмма для отображения
//
Функция КартинкаДействияПоТипуКонтактнойИнформации(ТипКИ)
	
	Если ТипКИ = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
		КартинкаДействия = БиблиотекаКартинок.КонтактнаяИнформацияТелефон;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
		КартинкаДействия = БиблиотекаКартинок.КонтактнаяИнформацияЕмэйл;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
		КартинкаДействия = БиблиотекаКартинок.КонтактнаяИнформацияАдрес;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.Факс Тогда
		КартинкаДействия = БиблиотекаКартинок.КонтактнаяИнформацияФакс;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.Skype Тогда
		КартинкаДействия = БиблиотекаКартинок.КонтактнаяИнформацияСкайп;
	ИначеЕсли ТипКИ = Перечисления.ТипыКонтактнойИнформации.СоциальнаяСеть Тогда
		КартинкаДействия = БиблиотекаКартинок.КонтактнаяИнформацияСоциальнаяСеть;
	Иначе
		КартинкаДействия = БиблиотекаКартинок.Пустая;
	КонецЕсли;
	
	Возврат КартинкаДействия;
	
КонецФункции

&НаСервере
// Функция проверяет корректность адреса электронной почты
//
// Параметры:
//  ОбъектКИ	 - ОбъектXDTO	 - объект XDTO контактной информации
//  ИмяРеквизита - строка	 - имя реквизита формы, с которым будет связано сообщение об ошибке
// 
// Возвращаемое значение:
//  Булево - признак корректности
//
Функция ЭлектроннаяПочтаКорректна(ОбъектКИ, Знач ИмяРеквизита = "")
	
	СтрокаОшибки = "";
	
	АдресЭП = ОбъектКИ.Состав;
	ПространствоИмен = УправлениеКонтактнойИнформациейКлиентСерверСтоматология.ПространствоИмен();
	Если АдресЭП <> Неопределено И АдресЭП.Тип() = ФабрикаXDTO.Тип(ПространствоИмен, "ЭлектроннаяПочта") Тогда
		Попытка
			Результат = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(АдресЭП.Значение);
			Если Результат.Количество() > 1 Тогда
				
				СтрокаОшибки = Нстр("ru='Допускается ввод только одного адреса электронной почты';en='Allowed input only one email addresses'");
				
			КонецЕсли;
		Исключение
			СтрокаОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЕсли;
	
	Если Не ПустаяСтрока(СтрокаОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаОшибки,,ИмяРеквизита);
	КонецЕсли;
	
	Возврат ПустаяСтрока(СтрокаОшибки);
	
КонецФункции

&НаСервере
// Функция возвращает таблицу типов контактной информации в порядке по умолчанию
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Стандартный порядок типов контактной информации для отображения в интерфейсе
//
Функция ПорядокТиповКИ()
	
	ПорядокТиповКИ = Новый ТаблицаЗначений;
	ПорядокТиповКИ.Колонки.Добавить("Тип"	 , Новый ОписаниеТипов("ПеречислениеСсылка.ТипыКонтактнойИнформации"));
	ПорядокТиповКИ.Колонки.Добавить("Порядок", Новый ОписаниеТипов("Число"));
	
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Телефон			   , 1);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, 2);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Адрес				   , 3);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Факс				   , 4);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.Skype				   , 5);
	ДобавитьТипКонтактнойИнформации(ПорядокТиповКИ, Перечисления.ТипыКонтактнойИнформации.СоциальнаяСеть	   , 6);
	
	Возврат ПорядокТиповКИ;
	
