
#Область СлужебныеПроцедурыИФункции

// Функция вернет отработанное вермя сотрудников за указанный период
Функция ПолучитьОтработанноеВремяСотрудников(СтруктурнаяЕдиница, НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВремяРаботыСотрудниковФакт.Сотрудник КАК Сотрудник,
	|	СУММА(ВремяРаботыСотрудниковФакт.Минуты) КАК Время
	|ИЗ
	|	РегистрСведений.ВремяРаботыСотрудниковФакт КАК ВремяРаботыСотрудниковФакт
	|ГДЕ
	|	ВремяРаботыСотрудниковФакт.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВремяРаботыСотрудниковФакт.ДатаВремяНачала >= &НачалоПериода
	|	И ВремяРаботыСотрудниковФакт.ДатаВремяНачала <= &КонецПериода
	|
	|СГРУППИРОВАТЬ ПО
	|	ВремяРаботыСотрудниковФакт.Сотрудник");
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("НачалоПериода",НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",КонецПериода);

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

#КонецОбласти