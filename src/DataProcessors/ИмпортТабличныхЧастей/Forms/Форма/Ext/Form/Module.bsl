&НаКлиенте
// Получить наименования реквизитов.
//
Функция ПолучитьСтрокуНаимеванийРеквизитов()
	
	ТекстСостояния = "Производится анализ выбранного файла";
	ТекстПояснения = "Это может занять некоторое время. Пожалуйста, подождите...";
	Картинка	   = БиблиотекаКартинок.ДлительнаяОперация48;
	
	Состояние(ТекстСостояния, , ТекстПояснения, Картинка);
	
	СписокКолонокФайла.Очистить();
	Если ТипФайлаИмпорта = "EXCEL" Тогда
		
		Рез = ПолучитьПоляИзExcel();
		Если НЕ Рез = "" Тогда
			ПоказатьПредупреждение(,Рез);
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если СписокКолонокФайла.Количество() = 0 Тогда 		 
		ПоказатьПредупреждение(,"Не удалось получить строку наименований реквизитов. Убедитесь, что данная строка расположена в файле первой по счету!");
		Возврат Ложь;
	Иначе		   
		Возврат Истина;	   
	КонецЕсли; 		  
КонецФункции

&НаКлиенте
// Получаем наименования полей из первой строки.
//
Функция ПолучитьПоляИзExcel()
	
	СписокКолонокФайла.Очистить();
	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.WorkBooks.Open(ФайлИмпорта);
		ExcelЛист = Excel.Sheets(1);
	Исключение
		ТекстИсключение = ОписаниеОшибки();
		Возврат "Невозможно подключиться к файлу! " + ТекстИсключение;	 
	КонецПопытки;
	
	ColumnsCount = Excel.Cells.CurrentRegion.Columns.Count;		
	ДанныеСтроки = ИзСтрокиExcel(ExcelЛист, 1, ColumnsCount);
	Если ДанныеСтроки <> Неопределено Тогда
		СписокКолонокФайла = ДанныеСтроки;
	КонецЕсли;
	
	Excel.WorkBooks.Close();
	Excel = 0;
	Возврат "";
	
КонецФункции

&НаКлиенте
// Получить список данных из строки Excel.
//
Функция ИзСтрокиExcel(ExcelЛист, НомерСтроки, КолСтолбцов)
	
	СписокПолей = Новый СписокЗначений;	
	ПустаяСтрока = Истина;
	
	Для Столбец = 1 По КолСтолбцов Цикл
		
		СписокПолей.Добавить(ExcelЛист.Cells(НомерСтроки, Столбец).Text, ExcelЛист.Cells(НомерСтроки, Столбец).Text);
		Если ExcelЛист.Cells(НомерСтроки, Столбец).Text <> "" Тогда
			ПустаяСтрока = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПустаяСтрока Тогда
		Возврат Неопределено;
	Иначе
		Возврат СписокПолей;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Загрузка реквизитов справочника из таблицы Excel.
//
Процедура ЗагрузитьИзExcel()
	
	ТекстСостояния = "Выполнение импорта данных";
	Прогресс	   = 0;
	ТекстПояснения = "Это может занять продолжительное время...";
	Картинка 	   = БиблиотекаКартинок.ДлительнаяОперация48;
	Состояние(ТекстСостояния, Прогресс, ТекстПояснения, Картинка);
	
	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.WorkBooks.Open(ФайлИмпорта);
		
		ExcelЛист = Excel.Sheets(1);
	Исключение
		ТекстПредупреждения = "Невозможно открыть файл Microsoft Excel. Причина: " + ОписаниеОшибки();
		ПоказатьПредупреждение(,ТекстПредупреждения, , "Импорт номенклатуры");		 
	КонецПопытки;
	
	ОбщееКолСтрок = Excel.Cells.CurrentRegion.Rows.Count;
	КолСтолбцов   = Excel.Cells.CurrentRegion.Columns.Count;
	
	// Количество строк файла, которые будут обработаны на сервере, после чего управление
	// вернется на клиент для отображения текущего прогресса.
	РазмерПорции = 50;
	
	ИндексТекущейСтроки 		= 2;
	СозданоЭлементовСправочника = 0;
	ДобавленоЭлементовВТЧ 		= 0;
	
	Пока ИндексТекущейСтроки <= ОбщееКолСтрок Цикл
		
		// Получаем очередную порцию данных.
		КолСтрокВПорции = ИндексТекущейСтроки + РазмерПорции;
		ПорцияДанных = Новый Массив;
		
		Пока ИндексТекущейСтроки <= Мин(ОбщееКолСтрок, КолСтрокВПорции) Цикл
			
			ДанныеСтрокиExcel = ИзСтрокиExcel(ExcelЛист, ИндексТекущейСтроки, КолСтолбцов);
			
			Если ДанныеСтрокиExcel <> Неопределено Тогда // Строка не пуста.
				ПорцияДанных.Добавить(ДанныеСтрокиExcel);
			КонецЕсли;
			
			ИндексТекущейСтроки = ИндексТекущейСтроки + 1;
			
		КонецЦикла;
		// Конец получения порции данных.
		
		Если ПорцияДанных.Количество() > 0 Тогда
			РезультатОбработки 			= ОбработатьПорциюНаСервере(ПорцияДанных); 
			СозданоЭлементовСправочника = РезультатОбработки.СозданоЭлементовСправочника + СозданоЭлементовСправочника;
			ДобавленоЭлементовВТЧ 		= РезультатОбработки.ДобавленоЭлементовВТЧ + ДобавленоЭлементовВТЧ;
		КонецЕсли;
		
		Прогресс = Цел(100 * ИндексТекущейСтроки / ОбщееКолСтрок);
		Состояние(ТекстСостояния, Прогресс, ТекстПояснения, Картинка);
		
	КонецЦикла;
	
	Excel.WorkBooks.Close();
	Excel = 0;
	
	ТекстПредупреждения = "Операция импортирования завершена успешно." + Символы.ПС
						+ "Обработано строк в файле: " + Формат(ИндексТекущейСтроки - 2, "ЧН=0") + Символы.ПС
						+ "Добавленно элементов в табличную часть: " + Формат(ДобавленоЭлементовВТЧ, "ЧН=0") + Символы.ПС
						+ "Создано элементов справочника Номенклатура: " + Формат(СозданоЭлементовСправочника, "ЧН=0");
						
	ПоказатьПредупреждение(,ТекстПредупреждения, , "Импорт номенклатуры");
	
	ЭтаФорма.Закрыть(ДанныеВТабличнуюЧасть);
	                                                                                 
КонецПроцедуры

&НаСервере
// Функция проводит обработку полученной порции из файла и возвращает количество загруженных элементов.
//
Функция ОбработатьПорциюНаСервере(ПорцияДанных)
	
	СозданоЭлементовСправочника = 0;
	ДобавленоЭлементовВТЧ		= 0;
	
	Для Каждого СписокЗначений Из ПорцияДанных Цикл
		
		СтруктураРеквизитов = Новый Структура();
		
		// Подстановка реквизитов в соответствии с колонками
		Для А = 0 По Объект.ТаблицаСоответсвийПолей.Количество() - 1 Цикл
			
			Строка = Объект.ТаблицаСоответсвийПолей[А];
			Если Строка.КолонкаФайла <> "" Тогда
				Идентификатор = СписокКолонокФайла.НайтиПоЗначению(Строка.КолонкаФайла).ПолучитьИдентификатор();
				СтруктураРеквизитов.Вставить(СтрЗаменить(Строка.РеквизитСправочника, " ", ""), СписокЗначений[Идентификатор].Значение);
			Иначе   
				СтруктураРеквизитов.Вставить(СтрЗаменить(Строка.РеквизитСправочника, " ", ""), "");
			КонецЕсли;
			
		КонецЦикла;			
		
		Результат = ЗаполнитьРеквизитыТабличнойЧасти(СтруктураРеквизитов);
		
		Если ТипЗнч(Результат.ЗначенияСтрокиТЧ) = Тип("Структура") Тогда
			ДанныеВТабличнуюЧасть.Добавить(Результат.ЗначенияСтрокиТЧ);
			ДобавленоЭлементовВТЧ = ДобавленоЭлементовВТЧ + 1;
		КонецЕсли;
		
		Если Результат.ОписаниеОшибки = Неопределено Тогда
			СозданоЭлементовСправочника = СозданоЭлементовСправочника + Результат.РезультатЗаписиЭлемента;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат);
		КонецЕсли;
		
	КонецЦикла;

	Возврат Новый Структура("СозданоЭлементовСправочника, ДобавленоЭлементовВТЧ", СозданоЭлементовСправочника, ДобавленоЭлементовВТЧ);
	
КонецФункции

&НаСервере
// Функция создает полученную из файла номенклатуру, если она отсутсвует в базе, а также создает и заполняет новый
// элемент табличной части документа.
//
Функция ЗаполнитьРеквизитыТабличнойЧасти(СтруктураРеквизитов)
	
	Если СтруктураРеквизитов.Количество() = 0 Тогда
		Возврат "Не найдено соответствий между наименованиями реквизитов и полями табличной части!";
	КонецЕсли;
	
	ЭлементСоздан = Истина;
	
	Попытка
		// Получаем значения реквизитов.
		Наименование 	 				= ВернутьЗначениеРевизита("Наименование"											, СтруктураРеквизитов);
		Штрихкод 		 				= ВернутьЗначениеРевизита("Штрихкод"												, СтруктураРеквизитов);
		Артикул			 				= ВернутьЗначениеРевизита("Артикул"													, СтруктураРеквизитов);
		Количество						= ВернутьЗначениеРевизита("Количество"												, СтруктураРеквизитов);   
		Упаковка		 				= ВернутьЗначениеРевизита("Упаковка"												, СтруктураРеквизитов);     
		Цена 			 				= ВернутьЗначениеРевизита("Цена"													, СтруктураРеквизитов);         
		НормаВремени 	 				= ВернутьЗначениеРевизита(СтрЗаменить("Норма времени", " ", "")						, СтруктураРеквизитов);   
		УпаковкаПоУмолчанию 			= ВернутьЗначениеРевизита(СтрЗаменить("Упаковка по умолчанию", " ", "")				, СтруктураРеквизитов);     
		КоэффициентУпаковкиПоУмолчанию 	= ВернутьЗначениеРевизита(СтрЗаменить("Коэффициент упаковки по умолчанию", " ", "")	, СтруктураРеквизитов);
		
		// Определяем существование номеклатуры.
		Если ПоискПоТипу = 1 Тогда
			СсылкаНомеклатуры = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
		ИначеЕсли ПоискПоТипу = 2 Тогда
			ЗаписьШтрихкода = РегистрыСведений.Штрихкоды.ПолучитьДанныеПоШтрихкодам(Штрихкод);
			Если ЗаписьШтрихкода.Свойство("Объект") Тогда
				СсылкаНомеклатуры = ЗаписьШтрихкода.Объект;
			Иначе
				СсылкаНомеклатуры = Справочники.Номенклатура.ПустаяСсылка();
			КонецЕсли;
		ИначеЕсли ПоискПоТипу = 3 Тогда
			Если НЕ ПустаяСтрока(Артикул) Тогда
				СсылкаНомеклатуры = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", Артикул);
			Иначе
				СсылкаНомеклатуры = Справочники.Номенклатура.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
		
		
		Если СсылкаНомеклатуры.Пустая() И СоздаватьНенайденнуюНоменклатуру И
			((КлючеваяСтрокаТЧ = "Наименование" И НЕ(ПустаяСтрока(Наименование))) ИЛИ (КлючеваяСтрокаТЧ = "Артикул" И НЕ(ПустаяСтрока(Артикул)))) Тогда
			НовыйЭлемент = Справочники.Номенклатура.СоздатьЭлемент();
			НовыйЭлемент.Родитель 			= ПапкаДляНовыйНоменклатуры;  
			НовыйЭлемент.Наименование 		= Наименование;
			НовыйЭлемент.НаименованиеПолное = Наименование;
			НовыйЭлемент.ТипНоменклатуры 	= ПапкаДляНовыйНоменклатуры.ТипНоменклатуры;
			НовыйЭлемент.Артикул 			= Артикул;
			
			// По умолчанию единицы измерения ставим "шт".
			НовыйЭлемент.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
			
			// В зависимости от того, какая система налогообложения установленна в текущей структурной единице, устанавливаем ставку НДС.
			Если ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница.Организация.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда					
				НовыйЭлемент.СтавкаНДС = Перечисления.СтавкиНДС.НДС20;					
			Иначе					
				НовыйЭлемент.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;			
			КонецЕсли;
			
			НовыйЭлемент.Записать();
			
			СсылкаНомеклатуры = НовыйЭлемент.Ссылка;
					
			// Запись упаковки номеклатуры.
			Если Упаковка <> "" Тогда
				НоваяУпаковка = Справочники.УпаковкиНоменклатуры.СоздатьЭлемент();
				НоваяУпаковка.Наименование = Упаковка;
				НоваяУпаковка.Владелец = НовыйЭлемент.Ссылка;
				НоваяУпаковка.Коэффициент = 1; 
				НоваяУпаковка.Записать();
			КонецЕсли;
           	Если КоэффициентУпаковкиПоУмолчанию <> "0" и  УпаковкаПоУмолчанию <> "" Тогда
            			НоваяУпаковкаПоУмолчанию = Справочники.УпаковкиНоменклатуры.СоздатьЭлемент();
						НоваяУпаковкаПоУмолчанию.Наименование = УпаковкаПоУмолчанию;
						НоваяУпаковкаПоУмолчанию.Владелец = НовыйЭлемент.Ссылка;
						НоваяУпаковкаПоУмолчанию.Коэффициент = КоэффициентУпаковкиПоУмолчанию; 
						НоваяУпаковкаПоУмолчанию.Записать();
						НовыйЭлемент.УпаковкаПоУмолчанию = НоваяУпаковкаПоУмолчанию.Ссылка;
				КонецЕсли;
			НовыйЭлемент.НормаВремени =  НормаВремени;
			НовыйЭлемент.Записать();

		Иначе
			ЭлементСоздан = Ложь;
		КонецЕсли;
		
		// Запись цены номеклатуры.	
		Если Цена <> "" И РегистрироватьЦены И ЗначениеЗаполнено(ВидЦенРегистрации) И НЕ СсылкаНомеклатуры.Пустая() Тогда
			НоваяЦена = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.Автор = ПараметрыСеанса.ТекущийПользователь;	
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
			НоваяЦена.ВидЦен = ВидЦенРегистрации;
			НоваяЦена.Номенклатура = СсылкаНомеклатуры;
			НоваяЦена.Цена = Цена;
			НоваяЦена.Период = ТекущаяДата();
			НоваяЦена.Записать();
		КонецЕсли;

		// Запись штрихкода
		Если Штрихкод <> "" И НЕ СсылкаНомеклатуры.Пустая() Тогда
			НовыйШтрихКод = РегистрыСведений.Штрихкоды.СоздатьМенеджерЗаписи();
			НовыйШтрихКод.Объект = СсылкаНомеклатуры;
			НовыйШтрихКод.Период = ТекущаяДата();
			НовыйШтрихКод.Штрихкод = Штрихкод;
			НовыйШтрихКод.Записать();
		КонецЕсли;	

		// Заполнение строк табличной части.
		//ОбъектНоменклатуры = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
		
		
		Если НЕ СсылкаНомеклатуры.Пустая() Тогда
			ЗначенияСтрокиТЧ = Новый Структура("Номенклатура, Количество, Упаковка, Цена");
			ЗначенияСтрокиТЧ.Номенклатура	 	= СсылкаНомеклатуры;
			ЗначенияСтрокиТЧ.Количество	  		= Число(?(ПустаяСтрока(Количество), 0, СтрЗаменить(Количество, " ", "")));
			ЗначенияСтрокиТЧ.Упаковка	  		= Справочники.УпаковкиНоменклатуры.НайтиПоНаименованию(Упаковка, Истина, , СсылкаНомеклатуры);
			ЗначенияСтрокиТЧ.Цена		  		= Число(?(ПустаяСтрока(Цена), 0, СтрЗаменить(Цена, " ", "")));
		КонецЕсли;                                
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Новый Структура("РезультатЗаписиЭлемента, ЗначенияСтрокиТЧ, ОписаниеОшибки", ?(ЭлементСоздан, 1, 0), ЗначенияСтрокиТЧ, ОписаниеОшибки);
	
КонецФункции

&НаСервере
// Функция возвращает значение реквизита справочника из переданной структуры реквизитов.
//
Функция ВернутьЗначениеРевизита(НаименованиеРеквизита, СтруктураРеквизитов)
	
	Возврат ?(СтруктураРеквизитов.Свойство(НаименованиеРеквизита), СтруктураРеквизитов[СтрЗаменить(НаименованиеРеквизита, " ", "")], "");
	
КонецФункции  

&НаКлиенте
Процедура РегистрироватьЦеныПриИзменении(Элемент)
	
	Элементы.ВидЦенРегистрации.Доступность = РегистрироватьЦены;
	
КонецПроцедуры

#КонецОбласти