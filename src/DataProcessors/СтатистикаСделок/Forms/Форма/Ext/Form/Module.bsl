// Функция - Получить значение из соответствия.
//
// Параметры:
//  Соответствие		 - 	 - 
//  Ключ				 - 	 - 
//  ЗначениеПоУмолчанию	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗначениеИзСоответствия(Соответствие, Ключ, ЗначениеПоУмолчанию)

	ЗначениеСоответствия = Соответствие.Получить(Ключ);
	Возврат ?(ЗначениеСоответствия = Неопределено, ЗначениеПоУмолчанию, ЗначениеСоответствия); 
		
КонецФункции

