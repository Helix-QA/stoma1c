// Функция - Получить таблицу сотрудников.
// 
// Параметры:
//  ДатаВремяНачала						 - 	 -
//  ДатаВремяОкончания					 - 	 -
// 
// Возвращаемое значение:
//   -
// 
Функция ПолучитьТаблицуДолжностей(ВременныйСписокСотрудников = Неопределено)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сотрудники.Ссылка) КАК КоличествоСотрудников,
	|	Сотрудники.Должность КАК Должность
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В (&СписокСотрудников)
	|
	|СГРУППИРОВАТЬ ПО
	|	Сотрудники.Должность";
	
	Если Не ЗначениеЗаполнено(ВременныйСписокСотрудников) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сотрудники.Ссылка В (&СписокСотрудников)", "Истина");	
	Иначе
		Запрос.УстановитьПараметр("СписокСотрудников", ВременныйСписокСотрудников);
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции 

