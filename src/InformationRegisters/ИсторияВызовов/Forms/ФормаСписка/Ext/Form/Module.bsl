// Процедура - Отбор пользователь sip
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОтборПользовательSip(Команда)
	
	СписокТелефонныхАппаратов 	= ВернутьСписокТелефонныхАппаратов(ОтборПользовательSIP);	
	ОписаниеОповещения 			= Новый ОписаниеОповещения("ВыборПользователяSip", ЭтотОбъект, СписокТелефонныхАппаратов);
	ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокТелефонныхАппаратов, Элементы.ОтборПользовательSip);
	
КонецПроцедуры     

&НаКлиенте
// Процедура - Выбор пользователя sip
//
// Параметры:
//  ВыбранноеЗначение		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ВыборПользователяSip(ВыбранноеЗначение, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НЕ ВыбранноеЗначение = Неопределено Тогда 
		ОтборПользовательSIP = ВыбранноеЗначение.Значение.ТелефонныйАппарат;
		
		// Удалим старые значения номеров пользователей SIP
		СтрокаСписка = СписокНомеров.Количество() - 1; 
		Пока СтрокаСписка >= 0 Цикл 
			Если СписокНомеров[СтрокаСписка].Пометка = Ложь Тогда 
				СписокНомеров.Удалить(СтрокаСписка); 
			КонецЕсли; 
			СтрокаСписка = СтрокаСписка - 1; 
		КонецЦикла;			
		
		Если ЗначениеЗаполнено(ОтборПользовательSIP) Тогда 
			// Добавим в список выбранный номер пользователя SIP или группы
			СписокНомеров.Добавить(ВыбранноеЗначение.Значение.ВнутреннийНомер, , Ложь);
			// Если выбрали группу добавим все номера входящие в эту группу
			Если ВыбранноеЗначение.Значение.ЭтоГруппа = Истина Тогда
				// Если выбрали группу - добавим все номера входящие в эту группу			
				Для Каждого ЭлементСпискаТелефонныйАппарат Из ДополнительныеПараметры Цикл 
					Если ЭлементСпискаТелефонныйАппарат.Значение.ЭтоГруппа = Ложь И ЭлементСпискаТелефонныйАппарат.Значение.Родитель = ВыбранноеЗначение.Значение.ТелефонныйАппарат Тогда 
						СписокНомеров.Добавить(ЭлементСпискаТелефонныйАппарат.Значение.ВнутреннийНомер, , Ложь);
					КонецЕсли;
				КонецЦикла;
			Иначе
				Если ЗначениеЗаполнено(ВыбранноеЗначение.Значение.ВнутреннийНомерРодителя) Тогда 
					// Если выбрали конкртеного пользователя SIP - добавим также номер его группы 
					СписокНомеров.Добавить(ВыбранноеЗначение.Значение.ВнутреннийНомерРодителя, , Ложь);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьОтборПоПользователюSip();
	УстановитьКоличествоЗвонков();

КонецПроцедуры

&НаКлиенте
// Процедура - Открыть форму записи
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОткрытьФормуЗаписи(Команда)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если НЕ ТекущиеДанные = Неопределено Тогда 
		ПередаваемыеПараметры = Новый Структура; 	
		ПередаваемыеПараметры.Вставить("ОборудованиеТелефонии"	, ТекущиеДанные.ОборудованиеТелефонии);
		ПередаваемыеПараметры.Вставить("IDЗвонка"				, ТекущиеДанные.IDЗвонка);
		
		ПараметрыМассив = Новый Массив;
		ПараметрыМассив.Добавить(ПередаваемыеПараметры); 		
		КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.ИсторияВызовов", ПараметрыМассив); 
		
		ОткрытьФорму("РегистрСведений.ИсторияВызовов.ФормаЗаписи", Новый Структура("Ключ, Владелец, ОткрытьФормуЗаписи", КлючЗаписиРегистра, "ФормаСписка", Истина), ЭтаФорма);
	КонецЕсли;

КонецПроцедуры

#Область ОБРАБОТЧИКИ_СОБЫТИЙ_ЭЛЕМЕНТОВ_ШАПКИ_ФОРМЫ

&НаКлиенте
// Процедура - Список выбор
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбраннаяСтрока		 - 	 - 
//  Поле				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ВнутреннийНомерСотрудника) Тогда
		ПользовательSip = ТекущиеДанные.ВнутреннийНомерСотрудника;
	ИначеЕсли ТекущиеДанные.НаправлениеВызова = ПредопределенноеЗначение("Перечисление.ВариантыНаправленияВызова.Исходящий") Тогда
		ПользовательSip = ТекущиеДанные.НомерТелефона;
	Иначе
		ПользовательSip = ТекущиеДанные.ПользовательSip;
	КонецЕсли; 

	ЗаписьРазговораДоступна = ЗаписьРазговораДоступнаНаСервере(ПользовательSip) И ЗаписьРазговораДоступнаПоРолям(ТекущиеДанные.Пользователь, ТекущиеДанные.Контрагент);
	Сообщение               = НСтр("ru='Нет прав на прослушивание текущей записи';en='Not is right to listen to current records'");

	Если НЕ ТекущиеДанные = Неопределено Тогда 
		Если Поле.Имя = "URLЗаписи" Тогда 
			СтандартнаяОбработка = Ложь;
			Если ЗначениеЗаполнено(ТекущиеДанные.ФайлЗаписи) Тогда 
				ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(ТекущиеДанные.ФайлЗаписи); // ПолучитьРабочийКаталог()
				РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
			ИначеЕсли ЗначениеЗаполнено(ТекущиеДанные.URLЗаписи) Тогда 
				АктуальныйURLЗаписи = IPТелефонияКлиент.ПолучитьАктуальныйURLЗаписиROSTELECOMКлиент(ТекущиеДанные.URLЗаписи, ТекущиеДанные.IDЗвонка, ТекущиеДанные.ОборудованиеТелефонии);
				Оповещение = Новый ОписаниеОповещения(,,, "ОтобразитьОшибку", ЭтотОбъект);
				НачатьЗапускПриложения(Оповещение, АктуальныйURLЗаписи);
			КонецЕсли;	
			//ИначеЕсли Поле.Имя = "Визит" И ЗначениеЗаполнено(ТекущиеДанные.Визит) Тогда	
			//	СтандартнаяОбработка = Ложь;
			//	ПоказатьЗначение( , ТекущиеДанные.Визит);
		ИначеЕсли Поле.Имя = "CRM" И ЗначениеЗаполнено(ТекущиеДанные.CRM) Тогда 
			СтандартнаяОбработка = Ложь;
			Если СтрНайти(ТекущиеДанные.CRM, "Обращение") = 0 Тогда
				ФормаСделки = ПолучитьСделку(ТекущиеДанные.CRM);
				ПоказатьЗначение(,ФормаСделки);                                
			Иначе
				ФормаЗаявки = ПолучитьЗаявку(НайтиЧислаВСтроке(ТекущиеДанные.CRM));
				ПоказатьЗначение(,ФормаЗаявки);
			КонецЕсли;
		ИначеЕсли Поле.Имя = "Контрагент" И ЗначениеЗаполнено(ТекущиеДанные.Контрагент) Тогда 
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,ТекущиеДанные.Контрагент); 
		ИначеЕсли Поле.Имя = "Пользователь" И ЗначениеЗаполнено(ТекущиеДанные.Пользователь) Тогда 
			СтандартнаяОбработка = Ложь;
			ПоказатьЗначение(,ТекущиеДанные.Пользователь);	
		Иначе
			СтандартнаяОбработка = Ложь;
			ПередаваемыеПараметры = Новый Структура; 	
			ПередаваемыеПараметры.Вставить("ОборудованиеТелефонии"	, ТекущиеДанные.ОборудованиеТелефонии);
			ПередаваемыеПараметры.Вставить("IDЗвонка"				, ТекущиеДанные.IDЗвонка);
			
			ПараметрыМассив = Новый Массив;
			ПараметрыМассив.Добавить(ПередаваемыеПараметры); 		
			КлючЗаписиРегистра = Новый("РегистрСведенийКлючЗаписи.ИсторияВызовов", ПараметрыМассив); 
			
			ОткрытьФорму("РегистрСведений.ИсторияВызовов.Форма.ФормаЗвонокКлиента", Новый Структура("ПОIPТелефонии, IDЗвонка, ОткрытаИзСписка, ЗаписьРазговораДоступна, Заявка", ТекущиеДанные.ОборудованиеТелефонии, ТекущиеДанные.IDЗвонка, Истина, ЗаписьРазговораДоступна, ТекущиеДанные.Заявка), ЭтаФорма, КлючЗаписиРегистра);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

