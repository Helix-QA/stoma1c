	КонецЕсли;
	
	Возврат РазрешитьСкидки;
	
	КонецФункции
	
// Функция получает Контрагента и его родственников
Функция КонтрагентИРодственники(Получатель)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РодственныеСвязи.Родственник КАК Родственник
	|ИЗ
	|	РегистрСведений.РодственныеСвязи КАК РодственныеСвязи
	|ГДЕ
	|	РодственныеСвязи.Контрагент = &Получатель
	|	И РодственныеСвязи.ОбщийНакопительныйСчет";

	Запрос.УстановитьПараметр("Получатель", Получатель);
	МассивКонтрагентов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Родственник");
	МассивКонтрагентов.Добавить(Получатель);
	Возврат МассивКонтрагентов;
	
КонецФункции

// Функция получает карту по контрагенту.
//
Функция ПолучитьКарту(Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Карты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Карты КАК Карты
	|ГДЕ
	|	Карты.ВладелецКарты = &ВладелецКарты
	|	И Карты.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("ВладелецКарты", Контрагент);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	Если Результат.Количество() <> 0 Тогда
		Возврат Результат[0];
	Иначе
		Возврат Справочники.Карты.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

#КонецОбласти
