// Функция, сериализует json в массив.
// 
Функция ПолучитьМассивИзJson(МассивJson, ИмяПараметра)
	
	Если ЗначениеЗаполнено(МассивJson) Тогда
		
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(МассивJson);
