		Попытка
			ВидСделки_Объект.ОбменДанными.Загрузка = Истина;
			ВидСделки_Объект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;	

КонецПроцедуры

// Процедура - Инициализировать предопределенный вид первичный повторный пациент
//
Процедура ИнициализироватьПредопределенныйВид_ПервичныйПовторныйПациент(ВидСделки = Неопределено, Отказ = Ложь) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	ВидСделок__НовыеПациенты = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	
	Запрос 		= Новый Запрос;
	Запрос.УстановитьПараметр("ПредопределенныйЭлемент_НовыеПациенты", ВидСделок__НовыеПациенты);	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыСделок.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВидСделкиНовыеПациенты
	|ИЗ
	|	Справочник.ВидыСделок КАК ВидыСделок
	|ГДЕ
	|	ВидыСделок.Предопределенный = ИСТИНА
	|	И ВидыСделок.Ссылка = &ПредопределенныйЭлемент_НовыеПациенты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭтапыСделок.Ссылка КАК Ссылка,
	|	ЭтапыСделок.Наименование КАК Наименование,
	|	ЭтапыСделок.ВидСделки КАК ВидСделки,
	|	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа,
	|	ИСТИНА КАК Удалить
	|ИЗ
	|	Справочник.ЭтапыСделок КАК ЭтапыСделок
	|ГДЕ
	|	ЭтапыСделок.ВидСделки В
	|			(ВЫБРАТЬ
	|				ВидСделкиНовыеПациенты.Ссылка
	|			ИЗ
	|				ВидСделкиНовыеПациенты)
	|	И ЭтапыСделок.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерЭтапа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидСделкиНовыеПациенты.Ссылка КАК Ссылка
	|ИЗ
	|	ВидСделкиНовыеПациенты КАК ВидСделкиНовыеПациенты";
	
	
	РезультатПакетаЗапросов = Запрос.ВыполнитьПакет();
	
#Область ОБЛАСТЬ_ИНИЦИАЛИЗИРОВАНИЯ_ПРЕДОПРЕДЕЛЕННОГО_ВИДА_СДЕЛКИ_НовыеПациенты
	
	ВыборкаНовыеПациенты = РезультатПакетаЗапросов[2].Выбрать();
	Если ВыборкаНовыеПациенты.Следующий() Тогда 
		ВидСделки_Объект = ВыборкаНовыеПациенты.Ссылка.ПолучитьОбъект();
	Иначе 
		ВидСделки_Объект = Справочники.ВидыСделок.СоздатьЭлемент();
		ВидСделки_Объект.УстановитьНовыйКод();
	КонецЕсли;		
	Если ВидСделки_Объект <> Неопределено Тогда 
		ВидСделки_Объект.ИмяПредопределенныхДанных 	= "НовыеПациенты";
		ВидСделки_Объект.Наименование 				= НСтр("ru = 'Первичный, повторный пациент'; en = 'Primary, repeat patient'");
		ВидСделки_Объект.Префикс 					= ПолучитьПрефиксВоронкиПоНаименованию(ВидСделки_Объект.Наименование);
		ВидСделки_Объект.ТипСделки 					= Перечисления.ТипыСделок.Продажа;
		ВидСделки_Объект.НаименованиеЭтапаУспех 	= НСтр("ru = 'Пациент пришел'; en = 'The patient came'");
		ВидСделки_Объект.НаименованиеЭтапаОтказ		= НСтр("ru = 'Пациент не пришел'; en = 'Patient didn''t come'");
		
		Если НЕ ЗначениеЗаполнено(ВидСделки_Объект.СтруктурныеЕдиницыПрименения) Тогда 
			СтрокаТЧ = ВидСделки_Объект.СтруктурныеЕдиницыПрименения.Добавить();
			СтрокаТЧ.СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
		КонецЕсли;	
		
		ВидСделки_Объект.СтатусыПациентовПрименения.Очистить();
		ЗаполнитьЗначенияСвойств(ВидСделки_Объект.СтатусыПациентовПрименения.Добавить(), Новый Структура("СтатусПациента", Перечисления.СтатусыКонтрагентов.Потенциальный));
		ЗаполнитьЗначенияСвойств(ВидСделки_Объект.СтатусыПациентовПрименения.Добавить(), Новый Структура("СтатусПациента", Перечисления.СтатусыКонтрагентов.Первичный));
		ЗаполнитьЗначенияСвойств(ВидСделки_Объект.СтатусыПациентовПрименения.Добавить(), Новый Структура("СтатусПациента", Перечисления.СтатусыКонтрагентов.Постоянный));		
		ЗаполнитьЗначенияСвойств(ВидСделки_Объект.СтатусыПациентовПрименения.Добавить(), Новый Структура("СтатусПациента", Перечисления.СтатусыКонтрагентов.Отказ));
		
		ВидСделки_Объект.ОбменДанными.Загрузка 		= Истина;
		НачатьТранзакцию();
		Попытка
			НеобходимоОбновитьПовторноИспользуемыеЗначения = Ложь;			
			КлиентНеПришел 	= Справочники.ПричиныОтказов.ИнициализироватьПредопределеннуюПричинуОтказа("КлиентНеПришел"	, "Пациент не пришел", НеобходимоОбновитьПовторноИспользуемыеЗначения);
			КлиентОтказался = Справочники.ПричиныОтказов.ИнициализироватьПредопределеннуюПричинуОтказа("КлиентОтказался", "Пациент отказался", НеобходимоОбновитьПовторноИспользуемыеЗначения);
			ЛюбаяПричина 	= Справочники.ПричиныОтказов.ИнициализироватьПредопределеннуюПричинуОтказа("ЛюбаяПричина"	, "Любая причина", НеобходимоОбновитьПовторноИспользуемыеЗначения);
			
			Если ЗначениеЗаполнено(КлиентНеПришел) Тогда
				Если ВидСделки_Объект.ПричиныОтказов.Найти(КлиентНеПришел, "ПричинаОтказа") = Неопределено Тогда 
					ЗаполнитьЗначенияСвойств(ВидСделки_Объект.ПричиныОтказов.Добавить(), Новый Структура("ПричинаОтказа", КлиентНеПришел));	
				КонецЕсли;	
			КонецЕсли;
			Если ЗначениеЗаполнено(КлиентОтказался) Тогда
				Если ВидСделки_Объект.ПричиныОтказов.Найти(КлиентОтказался, "ПричинаОтказа") = Неопределено Тогда 				
					ЗаполнитьЗначенияСвойств(ВидСделки_Объект.ПричиныОтказов.Добавить(), Новый Структура("ПричинаОтказа", КлиентОтказался));	
				КонецЕсли;	
			КонецЕсли;
			
			ВидСделки_Объект.Записать();
			ВидСделки = ВидСделки_Объект.Ссылка;
			ЗафиксироватьТранзакцию();
			Если НеобходимоОбновитьПовторноИспользуемыеЗначения Тогда 
				ОбновитьПовторноИспользуемыеЗначения();
			КонецЕсли;				
		Исключение
			ОтменитьТранзакцию();
			Отказ = Истина;
			ЗаписьЖурналаРегистрации(НСтр("ru='Ошибка создания вида сделки!';en='Mistake create kind of deals!'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ВидыСделок, , ОписаниеОшибки());			
		КонецПопытки;	
	КонецЕсли;
	
	Если НЕ Отказ Тогда 
		ТаблицаЭтапов = РезультатПакетаЗапросов[1].Выгрузить();
		СтруктураЭтаповМассивом = Справочники.ЭтапыСделок.ПолучитьПервоначальнуюСтруктуруЭтаповВидаСделки(ВидСделки);
		Для Каждого СтруктураЭтапа Из СтруктураЭтаповМассивом Цикл
			МассивСтрокРанееСозданныхЭтапов = ТаблицаЭтапов.НайтиСтроки(Новый Структура("НомерЭтапа, Наименование", СтруктураЭтапа.НомерЭтапа, СтруктураЭтапа.Наименование));
			Если МассивСтрокРанееСозданныхЭтапов.Количество() = 0 Тогда
				ЭтапСделки_Объект = Справочники.ЭтапыСделок.СоздатьЭлемент();
				ЭтапСделки_Объект.УстановитьНовыйКод();
			Иначе 	
				ЭтапСделки_Объект = МассивСтрокРанееСозданныхЭтапов[0].Ссылка.ПолучитьОбъект();
				МассивСтрокРанееСозданныхЭтапов[0].Удалить = Ложь;
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(ЭтапСделки_Объект, СтруктураЭтапа);
			ЭтапСделки_Объект.ВидСделки 			= ВидСделки;
			Попытка
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ЭтапСделки_Объект);
			Исключение
				Отказ = Истина;
				ЗаписьЖурналаРегистрации(НСтр("ru='Ошибка создания вида сделки!';en='Mistake create kind of deals!'"), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ЭтапыСделок, , ОписаниеОшибки());			
			КонецПопытки;
		КонецЦикла;
		Для Каждого РанееСозданныйЭтап Из ТаблицаЭтапов Цикл 
			Если РанееСозданныйЭтап.Удалить Тогда 
				ЭтапСделки_Объект = РанееСозданныйЭтап.Ссылка.ПолучитьОбъект();
				ЭтапСделки_Объект.ПометкаУдаления = Истина;	
				Попытка
					ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ЭтапСделки_Объект);
				Исключение
					
				КонецПопытки;	
			КонецЕсли;	
		КонецЦикла;		
	КонецЕсли; 
	
#КонецОбласти

КонецПроцедуры

// Функция - Получить префикс сделки по наименованию
//
// Параметры:
//  Наименование - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПрефиксВоронкиПоНаименованию(Наименование) Экспорт 
	
	Префикс = "";
	МассивСлов = СтрРазделить(СокрЛП(Наименование), " ");
	Для Каждого Слово Из МассивСлов Цикл 
		Если СтрДлина(СокрЛП(Слово)) < 3 Тогда 
			Продолжить;
		КонецЕсли;
		Префикс = Префикс + ВРег(Лев(Слово, 1));
	КонецЦикла;
	
	Возврат Префикс;
	
КонецФункции

// Процедура - Обработка получения данных выбора
//
// Параметры:
//  ДанныеВыбора		 - 	 - 
//  Параметры			 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
 	СтандартнаяОбработка = Ложь;
	МассивТиповСделок = Новый Массив;
	Если Параметры.Отбор.Свойство("ТипСделки") Тогда
		Если ТипЗнч(Параметры.Отбор.ТипСделки) = Тип("ФиксированныйМассив") Тогда
			МассивТиповСделок = Параметры.Отбор.ТипСделки;
		Иначе
			МассивТиповСделок.Добавить(Параметры.Отбор.ТипСделки);
		КонецЕсли;		
	КонецЕсли;
	
	ДанныеВыбора = НайтиВидыСделокПоСтроке(Параметры.СтрокаПоиска, 12, МассивТиповСделок);	
	
КонецПроцедуры

// Функция - Найти виды сделок по строке
//
// Параметры:
//  СтрокаПоиска		 - 	 - 
//  РазмерПорции		 - 	 - 
//  МассивТиповСделок	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НайтиВидыСделокПоСтроке(СтрокаПоиска, РазмерПорции = 12, МассивТиповСделок = Неопределено) Экспорт
	
	СтрокаПоиска = СокрЛ(СтрокаПоиска);
	Если СокрЛ(СтрокаПоиска) = "" ИЛИ СтрДлина(СтрокаПоиска) < 3 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	//=======================АНАЛИЗ ВВЕДЕННЫХ СИМВОЛОВ=======================
	Если СтрДлина(СокрЛ(СтрокаПоиска)) <> 0 Тогда 
		//К = 1;
		ЕстьЦифры = Ложь;
		ЕстьБуквы = Ложь;
		СтрокаПоиска_М = СтрСоединить(СтрРазделить(СтрокаПоиска, " ()-+"));
		СтрокаПоиска_Ц = СтрСоединить(СтрРазделить(СтрокаПоиска, СтрСоединить(СтрРазделить(СтрокаПоиска, "0123456789"))));
		Если СтрокаПоиска_М = СтрокаПоиска_Ц Тогда 
			СтрокаПоиска = СтрокаПоиска_Ц;
			ЕстьЦифры = Истина;
		Иначе 
			КоличествоЦифр = 0;
			КоличествоБукв = 0;
			Для К = 1 По СтрДлина(СокрЛ(СтрокаПоиска)) Цикл 
				Если Найти("0123456789", Сред(СтрокаПоиска, К, 1)) <> 0 Тогда 
					ЕстьЦифры = Истина;
					КоличествоЦифр = КоличествоЦифр + 1;
				Иначе 
					ЕстьБуквы = Истина;
					КоличествоБукв = КоличествоБукв + 1;
				КонецЕсли;
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;		
	
	Запрос = Новый Запрос;
	Если ЕстьБуквы И НЕ ЕстьЦифры Тогда
		
		Запрос.УстановитьПараметр("СтрокаПоиска", СокрЛ(СтрокаПоиска) + "%");
		
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 20
		               |	ВложенныйЗапрос.Ссылка КАК Ссылка,
		               |	МИНИМУМ(ВложенныйЗапрос.Индекс) КАК Индекс,
		               |	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ВложенныйЗапрос.ТипСделки КАК ТипСделки,
		               |	ВложенныйЗапрос.Код КАК Код,
		               |	ВложенныйЗапрос.Наименование КАК Наименование
		               |ИЗ
		               |	(ВЫБРАТЬ ПЕРВЫЕ 20
		               |		ВидыСделок.Ссылка КАК Ссылка,
		               |		1 КАК Индекс,
		               |		ВидыСделок.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |		ВидыСделок.ТипСделки КАК ТипСделки,
		               |		ВидыСделок.Код КАК Код,
		               |		ВидыСделок.Наименование КАК Наименование
		               |	ИЗ
		               |		Справочник.ВидыСделок КАК ВидыСделок
		               |	ГДЕ
		               |		ВидыСделок.Наименование ПОДОБНО &СтрокаПоиска
		               |		И ВидыСделок.ПометкаУдаления = ЛОЖЬ
		               |		И (ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
		               |				ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		               |		И ВидыСделок.ТипСделки В(&МассивТиповСделок)) КАК ВложенныйЗапрос
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВложенныйЗапрос.Ссылка,
		               |	ВложенныйЗапрос.СтруктурнаяЕдиница,
		               |	ВложенныйЗапрос.ТипСделки,
		               |	ВложенныйЗапрос.Код,
		               |	ВложенныйЗапрос.Наименование
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Индекс,
		               |	ВложенныйЗапрос.Наименование,
		               |	ВложенныйЗапрос.Код";
		
	Иначе
		
		Запрос.УстановитьПараметр("СтрокаПоиска", СокрЛ(СтрокаПоиска) + "%");
		
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 20
		               |	ВложенныйЗапрос.Ссылка КАК Ссылка,
		               |	МИНИМУМ(ВложенныйЗапрос.Индекс) КАК Индекс,
		               |	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ВложенныйЗапрос.ТипСделки КАК ТипСделки,
		               |	ВложенныйЗапрос.Код КАК Код,
		               |	ВложенныйЗапрос.Наименование КАК Наименование
		               |ИЗ
		               |	(ВЫБРАТЬ ПЕРВЫЕ 20
		               |		ВидыСделок.Ссылка КАК Ссылка,
		               |		1 КАК Индекс,
		               |		ВидыСделок.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |		ВидыСделок.ТипСделки КАК ТипСделки,
		               |		ВидыСделок.Код КАК Код,
		               |		ВидыСделок.Наименование КАК Наименование
		               |	ИЗ
		               |		Справочник.ВидыСделок КАК ВидыСделок
		               |	ГДЕ
		               |		ВидыСделок.Наименование ПОДОБНО &СтрокаПоиска
		               |		И ВидыСделок.ПометкаУдаления = ЛОЖЬ
		               |		И (ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
		               |				ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		               |		И ВидыСделок.ТипСделки В(&МассивТиповСделок)
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		ВидыСделок.Ссылка,
		               |		2,
		               |		ВидыСделок.СтруктурнаяЕдиница,
		               |		ВидыСделок.ТипСделки,
		               |		ВидыСделок.Код,
		               |		ВидыСделок.Наименование
		               |	ИЗ
		               |		Справочник.ВидыСделок КАК ВидыСделок
		               |	ГДЕ
		               |		ВидыСделок.Код ПОДОБНО &СтрокаПоиска
		               |		И ВидыСделок.ПометкаУдаления = ЛОЖЬ
		               |		И (ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
		               |				ИЛИ ВидыСделок.СтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		               |		И ВидыСделок.ТипСделки В(&МассивТиповСделок)) КАК ВложенныйЗапрос
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ВложенныйЗапрос.Ссылка,
		               |	ВложенныйЗапрос.СтруктурнаяЕдиница,
		               |	ВложенныйЗапрос.ТипСделки,
		               |	ВложенныйЗапрос.Код,
		               |	ВложенныйЗапрос.Наименование
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Индекс,
		               |	ВложенныйЗапрос.Наименование,
		               |	ВложенныйЗапрос.Код";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Если МассивТиповСделок.Количество() > 0 Тогда 
		Запрос.УстановитьПараметр("МассивТиповСделок", МассивТиповСделок);
	Иначе                                                 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВидыСделок.ТипСделки В(&МассивТиповСделок)", "ИСТИНА");
	КонецЕсли;	
	
	Результат = Запрос.Выполнить().Выбрать();			
	
	СписокКонтрагентов = Новый СписокЗначений;
	
	Счетчик = 1;
	Пока ?(РазмерПорции = 0, Результат.Следующий(), Результат.Следующий() И Счетчик <= РазмерПорции) Цикл
		Представление = "" + СокрЛП(Результат.Наименование);
		СписокКонтрагентов.Добавить(Результат.Ссылка, Представление);			
		Счетчик = Счетчик + 1;                                       		
	КонецЦикла;                            	 			
	
	Возврат СписокКонтрагентов;
	
КонецФункции

// Функция - Получить структурную единицу применения вида сделки
//
// Параметры:
//  ВидСделки	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСтруктурнуюЕдиницуПримененияВидаСделки(ВидСделки) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидСделки", ВидСделки);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫБОР
	|		КОГДА ВидыСделокСтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ТОГДА ВидыСделокСтруктурныеЕдиницыПрименения.НомерСтроки + 99
	|		КОГДА ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка.СтруктурнаяЕдиница = ВидыСделокСтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница
	|			ТОГДА 0
	|		ИНАЧЕ ВидыСделокСтруктурныеЕдиницыПрименения.НомерСтроки
	|	КОНЕЦ КАК Приоритет,
	|	ВЫБОР
	|		КОГДА ВидыСделокСтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ТОГДА ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка.СтруктурнаяЕдиница
	|		ИНАЧЕ ВидыСделокСтруктурныеЕдиницыПрименения.СтруктурнаяЕдиница
	|	КОНЕЦ КАК СтруктурнаяЕдиница
	|ИЗ
	|	Справочник.ВидыСделок.СтруктурныеЕдиницыПрименения КАК ВидыСделокСтруктурныеЕдиницыПрименения
	|ГДЕ
	|	ВидыСделокСтруктурныеЕдиницыПрименения.Ссылка = &ВидСделки
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет";
	
	ВыборкаСЕ = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаСЕ.Следующий() Тогда 
		Если ЗначениеЗаполнено(ВыборкаСЕ.СтруктурнаяЕдиница) Тогда 
			Возврат ВыборкаСЕ.СтруктурнаяЕдиница;
		Иначе 
			Возврат ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; // в любой клинике
	    КонецЕсли;
	Иначе 
		Возврат ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; // в любой клинике
	КонецЕсли;	
	
КонецФункции

// Функция - Получить наименования завершающих этапов сделки
//
// Параметры:
//  СделкаИлиВид - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьНаименованияЗавершающихЭтаповСделки(СделкаИлиВид) Экспорт
	
	СтруктураНаименований = Новый Структура;
	СтруктураНаименований.Вставить("НаименованиеЭтапаУспех", "Успех");
	СтруктураНаименований.Вставить("НаименованиеЭтапаОтказ", "Отказ");
	
	Если НЕ ЗначениеЗаполнено(СделкаИлиВид) Тогда 
		Возврат СтруктураНаименований;
	КонецЕсли;
	
	Если ТипЗнч(СделкаИлиВид) = Тип("СправочникСсылка.ВидыСделок") Тогда 
		ВидСделки = СделкаИлиВид;
	ИначеЕсли ТипЗнч(СделкаИлиВид) = Тип("СправочникСсылка.Сделки") Тогда 
		ВидСделки = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СделкаИлиВид, "ВидСделки");
	Иначе 
		Возврат СтруктураНаименований;
	КонецЕсли; 	
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидСделки", ВидСделки);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВидыСделок.НаименованиеЭтапаУспех КАК НаименованиеЭтапаУспех,
	               |	ВидыСделок.НаименованиеЭтапаОтказ КАК НаименованиеЭтапаОтказ
	               |ИЗ
	               |	Справочник.ВидыСделок КАК ВидыСделок
	               |ГДЕ
	               |	ВидыСделок.Ссылка = &ВидСделки";
	
	ВыборкаНаименований = Запрос.Выполнить().Выбрать();
	Если ВыборкаНаименований.Следующий() Тогда
		Если ЗначениеЗаполнено(СокрЛП(ВыборкаНаименований.НаименованиеЭтапаУспех)) Тогда 
			СтруктураНаименований.НаименованиеЭтапаУспех = СокрЛП(ВыборкаНаименований.НаименованиеЭтапаУспех);
		КонецЕсли;
		Если ЗначениеЗаполнено(СокрЛП(ВыборкаНаименований.НаименованиеЭтапаОтказ)) Тогда 
			СтруктураНаименований.НаименованиеЭтапаОтказ = СокрЛП(ВыборкаНаименований.НаименованиеЭтапаОтказ);
		КонецЕсли;
		Возврат СтруктураНаименований;
	Иначе 
		Возврат СтруктураНаименований;
	КонецЕсли;	
		
КонецФункции

#КонецОбласти
	
#КонецЕсли