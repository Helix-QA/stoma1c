&НаКлиенте
// Процедура - обработчик команды "ПоказатьСтраницуРедактированияЦен".
//
Процедура ПоказатьСтраницуРедактированияЦен(Команда)
	
	Если Команда.Имя = "ПоказатьСтраницуЗаполнитьПоЦенам" Тогда		
		Элементы.ГруппаИзмененияЦен.Заголовок="Заполнение цен по клинике и виду цен" ;
		Элементы.ПараметрыСтраницы.ТекущаяСтраница = Элементы.СтраницаЗаполнитьПоЦенам;
		ВидЦен = Объект.ВидЦен;
		Период = ТекущаяДата();
	ИначеЕсли Команда.Имя = "ПоказатьСтраницуЗаполнитьПоДокументу" Тогда	
		Элементы.ГруппаИзмененияЦен.Заголовок="Заполнение цен по документу поступления запасов" ;
		Элементы.ПараметрыСтраницы.ТекущаяСтраница = Элементы.СтраницаЗаполнитьПоДокументу;
	ИначеЕсли Команда.Имя = "ПоказатьСтраницуИзменитьНаПроцент" Тогда		
		Элементы.ГруппаИзмененияЦен.Заголовок="Изменение текущих цен на процент" ;
		Элементы.ПараметрыСтраницы.ТекущаяСтраница = Элементы.СтраницаИзменитьНаПроцент;
		ПлюсМинус = "+";
	ИначеЕсли Команда.Имя = "ПоказатьСтраницуИзменитьНаСумму" Тогда		
		Элементы.ГруппаИзмененияЦен.Заголовок="Изменение текущих цен на сумму" ;
		Элементы.ПараметрыСтраницы.ТекущаяСтраница = Элементы.СтраницаИзменитьНаСумму;
		ПлюсМинус = "+";
	ИначеЕсли Команда.Имя = "ПоказатьСтраницуОкруглить" Тогда		
		Элементы.ГруппаИзмененияЦен.Заголовок="Округление текущих цен" ;
		Элементы.ПараметрыСтраницы.ТекущаяСтраница = Элементы.СтраницаОкруглить;
	КонецЕсли;
	
	Элементы.ГруппаИзмененияЦен.Видимость = Истина;
	
КонецПроцедуры


&НаКлиенте
// Процедура - обработчик команды "ЗаполнитьНоменклатуруПоГруппамНоменклатуры".
