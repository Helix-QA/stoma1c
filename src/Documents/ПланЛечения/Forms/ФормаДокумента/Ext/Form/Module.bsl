&НаКлиенте
// Процедура, обработчик события "ПриНажатии"
//
Процедура УслугиПодборЗубовПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ДанныеЭлемента = ДанныеСобытия.Element.parentNode.id;
	
	Если ДанныеЭлемента = "Switch" тогда
		МассивВыделенныхЗубов.Очистить();
		ТипЗубнойФормулы = ?(ТипЗубнойФормулы = 1, 0, 1);
		SVGВыделенныйЗуб = "var selectzub"; 
		SVGМассивВыделенныхЗубов = "var SelectedTeeth = [];";
		SVGМассивЛечащихсяЗубов  =  "var mas='';";		
		УстановитьЗубнуюФормулу();
		ОбновитьSVGПодбор();  
		ВидЗубнойФормулыПриИзменении();
	КонецЕсли;
	
	Если ДанныеЭлемента = "Del" Тогда
		МассивВыделенныхЗубов.Очистить();
		Возврат;
	КонецЕсли;
	Если ДанныеЭлемента = "ОдиночныйРежимВыделения" Тогда
		МассивВыделенныхЗубов.Очистить();
		МножественныйРежимВыделения = Ложь;
	ИначеЕсли ДанныеЭлемента = "МножественныйРежимВыделения" Тогда
		МножественныйРежимВыделения = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(ДанныеЭлемента) и Найти(ДанныеЭлемента, "Зуб") > 0  Тогда
		Зуб = ДанныеЭлемента;
		Если Найти(Зуб, "Зуб") > 0 Тогда
			Зуб = ПредопределенноеЗначение("Перечисление.Зубы."+Зуб);
		Иначе
			Возврат;
		КонецЕсли;
		Если МножественныйРежимВыделения Тогда
			Если МассивВыделенныхЗубов.НайтиПоЗначению(Зуб) = Неопределено Тогда
				МассивВыделенныхЗубов.Добавить(Зуб);
			Иначе
				МассивВыделенныхЗубов.Удалить(МассивВыделенныхЗубов.НайтиПоЗначению(Зуб));
			КонецЕсли;
		Иначе
			Если МассивВыделенныхЗубов.Количество() > 0 и Зуб = МассивВыделенныхЗубов[0].Значение Тогда
				МассивВыделенныхЗубов.Очистить();
			Иначе
				МассивВыделенныхЗубов.Очистить();
				МассивВыделенныхЗубов.Добавить(Зуб);
				НайденныеСтроки = Объект.Лечение.НайтиСтроки(Новый Структура("Зуб", Зуб));
				Если НайденныеСтроки.Количество() > 0 Тогда
					Элементы.ТаблицаЛечение.ТекущаяСтрока = НайденныеСтроки[0].ПолучитьИдентификатор();
				КонецЕсли; 				
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Обработчик начала выбора значений
//
Процедура ТаблицаУслугиНоменклатураНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	СтруктураПараметры     = Новый Структура();	
	МассивРазрешенныхТипов = Новый Массив;
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
	МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор"));
	
	СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов"          	, МассивРазрешенныхТипов); 
	СтруктураПараметры.Вставить("Заголовок"                            	, "Выберите услугу");	  
	СтруктураПараметры.Вставить("СтруктурнаяЕдиница"                   	, Объект.СтруктурнаяЕдиница);   
	СтруктураПараметры.Вставить("Дата"                                 	, Объект.Дата);
	СтруктураПараметры.Вставить("БуферВыбранныхЗначенийИспользовать"   	, Ложь);
	СтруктураПараметры.Вставить("Сегмент"								, _ПодборСегментНоменклатуры);
	СтруктураПараметры.Вставить("СегментУслугПоСогласованию"			, ОтборСегментУслугПоСогласованию);
	СтруктураПараметры.Вставить("ДоговорПолисаМедСтрахования"		    , ЭтотОбъект._ПодборДоговорПолиса);
	СтруктураПараметры.Вставить("ПолисМедСтрахования"		    		, Объект.ПолисМедСтрахования);
	СтруктураПараметры.Вставить("ВозвращатьДанныеПоДоговоруПолиса"		, Истина); 
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ТаблицаУслугиНоменклатураНачалоВыбораЗавершение", ЭтаФорма); 	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры", СтруктураПараметры, ЭтаФорма,,,, 
		ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После выбора номенклатуры
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ТаблицаУслугиНоменклатураНачалоВыбораЗавершение(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
		
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
		
		ПодборДанные = РезультатВыбора;
		РезультатВыбора = ПодборДанные.Номенклатура;
			
		Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(РезультатВыбора, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор") Тогда
			СоставНабора = ОбщегоНазначенияСтоматология.ПолучитьСоставНабора(РезультатВыбора);
			ПерваяСтока = Истина;
			Для Каждого СтрокаТЧ из СоставНабора Цикл
				Если Не ПерваяСтока Тогда
					Элементы.ТаблицаЛечение.ДобавитьСтроку();
				КонецЕсли;
				Элементы.ТаблицаЛечение.ТекущиеДанные.Номенклатура = СтрокаТЧ.Номенклатура;
				Элементы.ТаблицаЛечение.ТекущиеДанные.Количество   = СтрокаТЧ.Количество;
				ТаблицаУслугиНоменклатураПриИзменении();
				ПерваяСтока = Ложь;
			КонецЦикла;
		Иначе		
			Элементы.ТаблицаЛечение.ТекущиеДанные.Номенклатура = РезультатВыбора;
			ТаблицаУслугиНоменклатураПриИзменении();		
		КонецЕсли;
		
	КонецЕсли; 	
		
КонецПроцедуры

&НаКлиенте
// При изменении выбора номенклатуры
//
Процедура ТаблицаУслугиНоменклатураПриИзменении(
	Элемент = Неопределено,
	ИдентификаторыНовыхСтрок = Неопределено,
	ПересчетТЧПослеизменения = Ложь)	
	
	Если ИдентификаторыНовыхСтрок = Неопределено
		И Элементы.ТаблицаЛечение.ТекущиеДанные <> Неопределено Тогда
		
		ИдентификаторыНовыхСтрок = Элементы.ТаблицаЛечение.ТекущиеДанные.ПолучитьИдентификатор();
	КонецЕсли; 
	
	ИдентификаторыНовыхСтрокМассив = Новый Массив;	
	Если ТипЗнч(ИдентификаторыНовыхСтрок) <> Тип("Массив") Тогда
		ИдентификаторыНовыхСтрокМассив.Добавить(ИдентификаторыНовыхСтрок);
	Иначе
		ИдентификаторыНовыхСтрокМассив = ИдентификаторыНовыхСтрок; 
	КонецЕсли; 
	
	ТаблицаУслугиНоменклатураПриИзмененииСервер(ИдентификаторыНовыхСтрокМассив, ПересчетТЧПослеизменения);
	
КонецПроцедуры

&НаСервере
// Процедура - Таблица услуги номенклатура при изменении сервер.
//
Процедура ТаблицаУслугиНоменклатураПриИзмененииСервер(ИдентификаторыНовыхСтрокМассив, ПересчетТЧПослеизменения)

	Для Каждого ИдентификаторНовыхСтрок Из ИдентификаторыНовыхСтрокМассив Цикл
		
		Если ИдентификаторНовыхСтрок <> Неопределено Тогда
			
			СтрокаТабличнойЧасти = Объект.Лечение.НайтиПоИдентификатору(ИдентификаторНовыхСтрок);  
			
			СтруктураДанные = ПолучитьДанныеЦенообразованияНоменклатуры(СтрокаТабличнойЧасти.Номенклатура);

			СтрокаТабличнойЧасти.Цена   = СтруктураДанные.Цена;
			Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.Количество) Тогда
				СтрокаТабличнойЧасти.Количество = 1;
			КонецЕсли;
			СтрокаТабличнойЧасти.ВидЦен = СтруктураДанные.ВидЦен;	
			Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
				СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС
			КонецЕсли;
			
			РеквизитыНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СтрокаТабличнойЧасти.Номенклатура, "СкидкиЗапрещены, Бесплатно");	
			СтрокаТабличнойЧасти.СкидкиЗапрещены = РеквизитыНоменклатуры.СкидкиЗапрещены;
			Если СтрокаТабличнойЧасти.СкидкиЗапрещены Тогда
				СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
				СтрокаТабличнойЧасти.СуммаРучнойСкидки = 0;
			КонецЕсли;	
			СтрокаТабличнойЧасти.Бесплатно = РеквизитыНоменклатуры.Бесплатно; 
			ТабличныеЧастиРассчитатьСуммуВСтрокеСервер(СтрокаТабличнойЧасти); 
			
		КонецЕсли;
		
	КонецЦикла;
	
	Объект.СуммаДокумента = Объект.Лечение.Итог("Всего");
	
	Если ПересчетТЧПослеизменения Тогда
		ТабличныеЧастиПересчетПослеИзменений("Лечение");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Функция - Получить данные ценообразования номенклатуры.
//
Функция ПолучитьДанныеЦенообразованияНоменклатуры(Знач Номенклатура)
	
	ВидЦенСтруктура = ?(ЗначениеЗаполнено(_ПодборДоговорПолиса) И ЗначениеЗаполнено(_ПодборДоговорПолиса.ВидЦен), _ПодборДоговорПолиса.ВидЦен, Объект.ВидЦен);
	// Получение данных ценообразования
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
	СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
	СтруктураДанные.Вставить("ВидЦен", 				ВидЦенСтруктура);	
	СтруктураДанные.Вставить("Номенклатура", 		Номенклатура);
	СтруктураДанныеНоменклатура = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	Возврат СтруктураДанныеНоменклатура;

КонецФункции

