
#Область ОбработчикиСобытийФормы

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Обработчик подсистемы "Дополнительные отчеты и обработки"
	ДополнительныеОтчетыИОбработкиСтоматология.ПриСозданииНаСервере(ЭтаФорма);
	
	СформироватьОписаниеПисьма();
	
	ЗадатьВидимостьЭлементов();
	
	ОпределитьОтправителяПисьма(); 
	
	СтруктураМеню = Новый Структура;
	СтруктураМеню.Вставить("Письмо"  , "ГруппаОсновные");
	СтруктураМеню.Вставить("Свойства", "ГруппаСвойства");	
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события формы "ПослеЗаписи"
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ИзмененоЭлектронноеПисьмо", Объект.Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ОткрытьВложениеВыполнить()
	
	УправлениеЭлектроннойПочтойКлиент.ОткрытьВложение(Элементы.Вложения.ТекущиеДанные.Ссылка);

КонецПроцедуры

&НаКлиенте
Процедура СохранитьВложениеВыполнить()
	
	УправлениеЭлектроннойПочтойКлиент.СохранитьВложение(Элементы.Вложения.ТекущиеДанные.Ссылка);

КонецПроцедуры

&НаКлиенте
Процедура ДополнительноВыполнить()
	
	Текст = Новый ТекстовыйДокумент;
	Текст.ДобавитьСтроку(ДополнительнаяИнформацияОПисьме);
	Текст.ДобавитьСтроку("");
	Текст.ДобавитьСтроку("");
	Текст.ДобавитьСтроку("-------------------------------------------------");
	Текст.ДобавитьСтроку(Объект.ВнутреннийЗаголовок);
	Текст.Показать();

КонецПроцедуры

&НаКлиенте
Процедура Ответить(Команда)
	
	Если НЕ ПроверитьНаВозможностьОтпавкиПисьма(Объект.УчетнаяЗапись) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Учетная запись не предназначена для отправки писем");
		Возврат;
	КонецЕсли;
	
	Основание = Новый Структура("Предмет, Команда", Объект.Ссылка, "Ответить");
	ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", Основание);
	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтветитьВсем(Команда)
	
	Если НЕ ПроверитьНаВозможностьОтпавкиПисьма(Объект.УчетнаяЗапись) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Учетная запись не предназначена для отправки писем");
		Возврат;
	КонецЕсли;
	
	Основание = Новый Структура("Предмет, Команда", Объект.Ссылка, "ОтветитьВсем");
	ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", Основание);
	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура Переслать(Команда)
	
	Если НЕ ПроверитьНаВозможностьОтпавкиПисьма(Объект.УчетнаяЗапись) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Учетная запись не предназначена для отправки писем");
		Возврат;
	КонецЕсли;
	
	Основание = Новый Структура("Предмет, Команда", Объект.Ссылка, "Переслать");
	ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения, ПереноситьВложения", Основание, Истина);
	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаДокумента", ПараметрыОткрытия);
	
КонецПроцедуры

 #КонецОбласти
 
#Область ОбработчикиСобытийЭлементовШапкиФормы 

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);	
		
КонецПроцедуры

&НаКлиенте
Процедура ВложенияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	УправлениеЭлектроннойПочтойКлиент.ОткрытьВложение(Элементы.Вложения.ТекущиеДанные.Ссылка);

КонецПроцедуры

&НаКлиенте
Процедура НадписьКонтактаНажатие(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ОтправительКонтакт)
		 И ТипЗнч(Объект.ОтправительКонтакт) = Тип("СправочникСсылка.Контрагенты") Тогда
		 
		ОткрытьФормуКонтрагента(Объект.ОтправительКонтакт);
		
	Иначе
		
		УточнитьКонтакт();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВложенияПриАктивизацииСтроки(Элемент)
	
	текДанные = Элементы.Вложения.ТекущиеДанные;
	Элементы.ОткрытьВложение.Доступность	= НЕ текДанные = Неопределено;
	Элементы.СохранитьВложение.Доступность	= НЕ текДанные = Неопределено;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработаноПриИзменении(Элемент)
	
	Если Объект.Обработано Тогда
		
		ТекПользователь = ОбщегоНазначенияСтоматология.ТекущийПользователь();
		
		Если Объект.Ответственный <> ТекПользователь Тогда
			
			Объект.Ответственный = ТекПользователь;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УточнитьКонтакт()
	
	ЗаголовокФормы = "Соответствие адресу <" + Объект.ОтправительАдрес + ">";
	ПараметрыФормы = Новый Структура("Заголовок", ЗаголовокФормы);
	
	Оповещение = Новый ОписаниеОповещения("ПослеВыбораКонтрагента", ЭтаФорма);
	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбора",,,,,,Оповещение);  
	
КонецПроцедуры  

&НаКлиенте
Процедура ПослеВыбораКонтрагента(Результат, Параметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("СправочникСсылка.Контрагенты") Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ОтправительКонтакт = Результат;
	Объект.Предмет			  = Результат;
	
	ЭтаФорма.Записать();
	
	EmailПрисвоен = УправлениеКонтактнойИнформациейСлужебныйВызовСервераСтоматология.ПрисвоитьEmailКонтрагенту(Результат, Объект.ОтправительАдрес);
	
	Если EmailПрисвоен Тогда
		
		ТекстОповещения = "Контактная информация обновлена.";
		НавСсылка = ПолучитьНавигационнуюСсылку(Результат);
		КартинкаОповещения = БиблиотекаКартинок.Информация32;
		ПоказатьОповещениеПользователя(ТекстОповещения, НавСсылка, Результат, КартинкаОповещения);
		
		Элементы.НадписьКонтакта.Заголовок = Строка(Объект.ОтправительКонтакт);
		
	КонецЕсли;
	
КонецПроцедуры	
	
&НаСервере
Процедура ОпределитьОтправителяПисьма()
	
	Если (НЕ ЗначениеЗаполнено(Объект.ОтправительКонтакт)
		ИЛИ ТипЗнч(Объект.ОтправительКонтакт) <> Тип("СправочникСсылка.Контрагенты")) И  ЗначениеЗаполнено(Объект.ОтправительАдрес) Тогда
		
		// Если при создании вх. почты контакт еще не был уточнен,
		// осуществляем поиск контрагента по E-mail.
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.АдресЭП = &Email
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка УБЫВ";
		
		Запрос.УстановитьПараметр("Email", Объект.ОтправительАдрес);
		
		УстановитьПривилегированныйРежим(Истина);  	// ******
		Выборка = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);		// ******
		
		Если Выборка.Следующий() Тогда
			Объект.ОтправительКонтакт = Выборка.Ссылка;
			Объект.Предмет			  = Выборка.Ссылка;
			Записать(Новый Структура());
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипЗнч(Объект.ОтправительКонтакт) = Тип("СправочникСсылка.Контрагенты") Тогда
		Элементы.НадписьКонтакта.Заголовок = Строка(Объект.ОтправительКонтакт);
	Иначе
		Элементы.НадписьКонтакта.Заголовок = "Уточнить контакт";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуКонтрагента(Контрагент)
	
	ИмяОткрываемойФормы = ?(КотрагентЯвляетсяКлиентом(Контрагент), "ФормаЭлементаКлиенты", "ФормаЭлемента");
	
	ПараметрыФормы = Новый Структура("Ключ", Контрагент);
	ОткрытьФорму("Справочник.Контрагенты.Форма." + ИмяОткрываемойФормы, ПараметрыФормы);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КотрагентЯвляетсяКлиентом(Контрагент)
	
	Возврат Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты;
	
КонецФункции

&НаСервере
Функция ПроверитьНаВозможностьОтпавкиПисьма(УчетнаяЗаписьСсылка) 
	
	Если НЕ УчетнаяЗаписьСсылка.ИспользоватьДляОтправки Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура СформироватьОписаниеПисьма()
	
	Начало = "
	|<html>
	|<head>  
	|<META http-equiv=Content-Type content=""text/html; charset=" + СокрЛП(Объект.Кодировка) + """>
	|<META content=""MSHTML 6.00.2800.1400"" name=GENERATOR>
	|<body scroll=""auto"">";
	
	Если ЗначениеЗаполнено(Объект.ТекстHTML) Тогда
		
		Описание = Объект.ТекстHTML;
		
	Иначе
		
		Описание = Объект.Текст;
		
		Если Найти(Описание, Символы.ПС) > 0 Тогда
			Описание = СтрЗаменить(Описание, Символы.ПС, "<br>");
		КонецЕсли;
		
	КонецЕсли;
	
	Конец = "
	|</body>
	|</html>";
	
	Описание = Начало + Описание + Конец;
	
	ТекстПисьма = Описание;
	
	ОтправительПредставление = Объект.ОтправительПредставление;
	Элементы.ОтправительПредставление.Подсказка = Объект.ОтправительАдрес;
	
	ПолучателиКопийПредставление = Объект.СписокПолучателейКопий;
	ПолучателиПредставление = Объект.СписокПолучателейПисьма;
	
	табВложения = УправлениеЭлектроннойПочтой.ПолучитьВложенияЭлектронногоПисьма(Объект.Ссылка);
	
	Вложения.Очистить();
	Для Каждого Стр Из табВложения Цикл
		новСтр = Вложения.Добавить();
		новСтр.Ссылка         = Стр.Ссылка;
		новСтр.ИмяФайла       = Стр.ИмяФайла;
		новСтр.ИндексКартинки = Стр.ИндексКартинки;
		новСтр.Размер         = Стр.Размер;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗадатьВидимостьЭлементов()
	
	// Видимость группы вложений письма
	Если Вложения.Количество() = 0 Тогда
		Элементы.ГруппаВложения.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик создания нового взаимодействия "Встреча"
Процедура ЗапланироватьВстречу(Команда)
	
	СоздатьНовоеВзаимодействие(ПредопределенноеЗначение("Справочник.ВидыВзаимодействий.Встреча"));
		
КонецПроцедуры

&НаКлиенте
// Обработчик создания нового взаимодействия "Телефонный звонок исходящий"
Процедура ЗапланироватьТелефонныйЗвонок(Команда)

   СоздатьНовоеВзаимодействие(ПредопределенноеЗначение("Справочник.ВидыВзаимодействий.ЗвонокИсходящий"));
		
КонецПроцедуры

&НаКлиенте
// Создать новое взаимодействие на основании данного существующего
Процедура СоздатьНовоеВзаимодействие(ВидВзаимодействия)
	
	// Если документ модифицирован необходимо его предварительно записать
	Если Объект.Ссылка.Пустая() ИЛИ Модифицированность Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьНовоеВзаимодействиеЗавершение", ЭтотОбъект, Новый Структура("ВидВзаимодействия", ВидВзаимодействия));
		ПоказатьВопрос(ОписаниеОповещения, "Документ должен быть записан! Записать?", РежимДиалогаВопрос.ДаНет);
        Возврат;
		
	КонецЕсли;
	
	// Открываем форму нового взаимодействия
	СоздатьНовоеВзаимодействиеФрагмент(ВидВзаимодействия);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Создать новое взаимодействие завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура СоздатьНовоеВзаимодействиеЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ВидВзаимодействия = ДополнительныеПараметры.ВидВзаимодействия;
	
	Если КодВозвратаДиалога.Да = РезультатВопроса Тогда
		Если НЕ Записать() Тогда
			Возврат;
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
	
	СоздатьНовоеВзаимодействиеФрагмент(ВидВзаимодействия);

КонецПроцедуры

&НаКлиенте
// Процедура - Создать новое взаимодействие фрагмент
//
// Параметры:
//  ВидОперацииВзаимодействия	 - 	 - 
//
Процедура СоздатьНовоеВзаимодействиеФрагмент(Знач ВидВзаимодействия)
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ВидВзаимодействияСправочник", ВидВзаимодействия);
	ДанныеЗаполнения.Вставить("ЗадачаТема",              Объект.Тема);
	Если ТипЗнч(Объект.ОтправительКонтакт) = Тип("СправочникСсылка.Контрагенты") И ЗначениеЗаполнено(Объект.ОтправительКонтакт) Тогда
		ДанныеЗаполнения.Вставить("Контрагент", Объект.ОтправительКонтакт);
		ДанныеЗаполнения.Вставить("ЗадачаПредмет", Объект.ОтправительКонтакт);
	КонецЕсли;
	
	ОткрытьФорму("Задача.Взаимодействие.ФормаОбъекта",Новый Структура("Основание", ДанныеЗаполнения));

КонецПроцедуры

&НаКлиенте
// Процедура - Удалить письмо
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура УдалитьПисьмо(Команда)
	
	ТекстВопроса = ?(Объект.ПометкаУдаления,
					"Вы действительно хотите снять пометку удаления у письма?",
					"Вы действительно хотите пометить письмо на удаление?");
	
	ПоказатьВопрос(Новый ОписаниеОповещения("УдалитьПисьмоЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Удалить письмо завершение
//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура УдалитьПисьмоЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		
		Если НЕ Объект.Ссылка.Пустая() Тогда
			УстановитьПометкуУдаления(Объект.Ссылка);
		КонецЕсли;
		
		Оповестить("ИзмененоЭлектронноеПисьмо");
		
		Прочитать(); // Обновляем данные на форме
		
		// Если письмо было удалено - закрываем форму
		Если Объект.ПометкаУдаления Тогда
			Модифицированность = Ложь;
			Закрыть();
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьПометкуУдаления(ПисьмоСсылка)
	
	ПисьмоОбъект = ПисьмоСсылка.ПолучитьОбъект();
