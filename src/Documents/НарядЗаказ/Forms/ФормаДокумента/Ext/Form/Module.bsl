// Процедура, обработчик события ОбработкаОповещения
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ВнешнееОборудование
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Данные = Новый Массив();
			Если Параметр[1] = Неопределено Тогда
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[0], 1)); // Достаем штрихкод из основных данных
			Иначе
				Данные.Добавить(Новый Структура("Штрихкод, Количество", Параметр[1][1], 1)); // Достаем штрихкод из дополнительных данных
			КонецЕсли;
			ПолученыШтрихкоды(Данные);
		ИначеЕсли ИмяСобытия = "TracksData" Тогда
			Если Параметр[1] = Неопределено Тогда
				ПолученКодКарты(Параметр[0], Параметр[0]);
			Иначе
				ПолученКодКарты(Параметр[0], Параметр[1][1]);
			КонецЕсли;
		ИначеЕсли ИмяСобытия = "DataCollectionTerminal" Тогда
			ПолученыШтрихкоды(Параметр);
		КонецЕсли;
	КонецЕсли;
	// Конец ВнешнееОборудование 	
	
	Если Источник = "ВнешнееОборудование" И ИмяСобытия = "НеизвестныеШтрихкоды" 
		И УникальныйИдентификатор = Параметр.ФормаВладелецУникальныйИдентификатор Тогда
		ПолученыШтрихкоды(Параметр.ЗарегистрированныеШтрихкоды);
	КонецЕсли;	
	
	Если ИмяСобытия = "ИЗМЕНЕН_СТАТУС_ПЛАНА_ЛЕЧЕНИЯ" Тогда
		УстановитьВидимостьНадписиСНезавершеннымиПланамиЛечения();
	КонецЕсли;	
	
	Если ИмяСобытия = "ПРОВЕДЕННО_ИЗМЕНЕНИЕ_ДОКУМЕНТА" Тогда
		ЭтаФорма.Прочитать();
	КонецЕсли;		
	
	Если ИмяСобытия = "ОбновитьИнформациюОСсылкахНаОплату" И ТипЗнч(Параметр) = Тип("Массив") И Параметр.Найти(Объект.Ссылка) <> Неопределено Тогда
		
		ОбновитьИнформациюПоИспользованиюСсылкиНаОплатуСервер();
		
	ИначеЕсли ИмяСобытия = "СБП_УспешнаяОплата" Тогда
		
		ОбсужденияСистемыВзаимодействияКлиент.ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметр);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция обрабатывает код карты, полученный от внешнего оборудования
//
Функция ПолученКодКарты(КодКарты, ДанныеДорожек)
	
	Если ТипЗнч(ДанныеДорожек) = Тип("Массив")
		И ДанныеДорожек.Количество() > 1
		И ДанныеДорожек[1] <> Неопределено
		И Не ПустаяСтрока(ДанныеДорожек[1]) Тогда
		ДанныеКарты = ДанныеДорожек[1];
		
		ДанныеПоКарте = Справочники.Карты.ПолучитьДанныеМагнитнойКарты(ДанныеКарты);
		Если ДанныеПоКарте <> Неопределено Тогда
			Объект.Контрагент       = ДанныеПоКарте.ВладелецКарты;
			Объект.КартаКонтрагента = ДанныеПоКарте;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Карта клиента со штриховым кодом "+ДанныеКарты+" не найдена");
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Указана неверная карта или произошла ошибка при считывании карты.
		|Повторите считывание или считайте другую карту'"));
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

