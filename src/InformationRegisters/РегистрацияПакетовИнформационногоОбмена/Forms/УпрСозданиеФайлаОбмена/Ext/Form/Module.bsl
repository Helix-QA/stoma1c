////
// Процедура: СоздатьОбъект_PERS_LIST
//   Создает XDTO объект PERS_LIST, для отправки ответа
//   на запрос;
// 
// Параметры:
//   Документ{ДокументСсылка.РеестрОказаннойПомощи}
//     ссылка на документ по данных которого надо формировать файл.
//
// Возвращаемое значение:
//   XDTO объект   - созданный по документу.
///
Функция СоздатьОбъект_PERS_LIST(Документ)
	
	ТипЗначения_PERS_LIST = ТипFFOMS("PERS_LIST");
	
	СообщениеОбъект_ = СоздатьОбъектXDTO(ТипЗначения_PERS_LIST);
	
	ДанныеЗаполнения_ = Новый Массив;
	// ЗАГОЛОВОК
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@VERSION","1.0");
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@DATA",ФорматДаты(ТекущаяДатаСеанса()));
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@FILENAME",ПолучитьИмяФайлаИнформационногоОбмена(
	"PERS_LIST",
	Неопределено,
	Документ.СтруктурнаяЕдиница.Организация,
	Документ.Контрагент,
	Документ.НачалоПериода
	)
	);
	ДобавитьВМассив(ДанныеЗаполнения_,"ZGLV.@FILENAME1",ПолучитьИмяФайлаИнформационногоОбмена(
	"ZL_LIST",
	Неопределено,
	Документ.СтруктурнаяЕдиница.Организация,
	Документ.Контрагент,
	Документ.НачалоПериода
	)
	);
	////////////////////////////////////////////////////////////////////
	
	// данные пациента
	ИтераторПациентов = 0;
	Для Каждого СтрокаУслуга Из Документ.ОказанныеУслуги Цикл
		
		Пациент = СтрокаУслуга.ДокументОснования.Контрагент;	
		
		ЭлементПациент = "PERS[" + Формат(ИтераторПациентов, "ЧН=0; ЧГ=0") + "]";		
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@ID_PAC", Строка(Пациент.УникальныйИдентификатор()));
		
		// перс данные
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@FAM", ФорматПустойСтрокиНЕТ(Пациент.Фамилия));
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@IM", ФорматПустойСтрокиНЕТ(Пациент.Имя));
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@OT", ФорматПустойСтрокиНЕТ(Пациент.Отчество));
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@W", ПолучитьКод(Пациент.ПолКлиента, Неопределено));
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@DR", ФорматДаты(Пациент.ДатаРожденияКлиента));
		
		// представитель
		Если ЗначениеЗаполнено(Пациент.ЗаконныйПредставитель.Фамилия) Тогда
			ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@FAM_P", Пациент.ЗаконныйПредставитель.Фамилия);
		КонецЕсли; 
		Если ЗначениеЗаполнено(Пациент.ЗаконныйПредставитель.Имя) Тогда
			ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@IM_P", Пациент.ЗаконныйПредставитель.Имя);
		КонецЕсли; 
		Если ЗначениеЗаполнено(Пациент.ЗаконныйПредставитель.Отчество) Тогда
			ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@OT_P", ФорматПустойСтрокиНЕТ(Пациент.ЗаконныйПредставитель.Отчество));
		КонецЕсли; 
		Если ЗначениеЗаполнено(Пациент.ЗаконныйПредставитель.ПолКлиента) Тогда
			ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@W_P", ПолучитьКод(Пациент.ЗаконныйПредставитель.ПолКлиента, Неопределено));
		КонецЕсли; 
		Если ЗначениеЗаполнено(Пациент.ЗаконныйПредставитель.ДатаРожденияКлиента) Тогда
			ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@DR_P", ФорматДаты(Пациент.ЗаконныйПредставитель.ДатаРожденияКлиента));
		КонецЕсли; 
		// Если ЗначениеЗаполнено(Пациент.МестоРожденияПредставление) Тогда
		//	ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@MR", Пациент.МестоРожденияПредставление);
		// КонецЕсли; 
		
		// ДУЛ
		ДУЛ = ВернутьДУЛКонтрагента(Пациент);
		Если ЗначениеЗаполнено(ДУЛ) Тогда
			КодДокументВид_ = ПолучитьКод(ДУЛ.ВидДокумента, Неопределено);
			Если ЗначениеЗаполнено(КодДокументВид_) Тогда
				ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@DOCTYPE", КодДокументВид_);
				Если ЗначениеЗаполнено(ДУЛ.Серия) Тогда
					ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@DOCSER", ДУЛ.Серия);
				КонецЕсли;
				Если ЗначениеЗаполнено(ДУЛ.Номер) Тогда
					ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@DOCNUM", ДУЛ.Номер);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// Если ЗначениеЗаполнено(Пациент.СтраховойНомерПФР) Тогда
		//	ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@SNILS", Пациент.СтраховойНомерПФР);
		// КонецЕсли;
		// Если ЗначениеЗаполнено(Пациент.МестоЖительстваОКАТО) Тогда
		//	ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@OKATOG", Пациент.МестоЖительстваОКАТО);
		// КонецЕсли;
		// Если ЗначениеЗаполнено(Пациент.МестоПребыванияОКАТО) Тогда
		//	ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@OKATOP", Пациент.МестоПребыванияОКАТО);
		// КонецЕсли;
		// Если ЗначениеЗаполнено(Пациент.КомментарийКПациенту) Тогда
		//	ДобавитьВМассив(ДанныеЗаполнения_, ЭлементПациент +".@COMENTP", Пациент.КомментарийКПациенту);
		// КонецЕсли;
		
		ИтераторПациентов = ИтераторПациентов + 1;
	КонецЦикла;
	
	Попытка
		ЗаполнитьОбъектXDTO(СообщениеОбъект_, ДанныеЗаполнения_);
		СообщениеОбъект_.Проверить();
	Исключение
		Рез = ОбработатьИнформациюОбОшибке(ИнформацияОбОшибке());
		Сообщение_ = Новый СообщениеПользователю;
		Сообщение_.Текст = Рез;
		Сообщение_.Сообщить();
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат СообщениеОбъект_;
	
КонецФункции

// Функция ФорматПустойСтрокиНЕТ()
//     форматирует пустую строку
//
// Параметры
//  Строка  - {Строка}
//      строка для форматирования
//
// Возвращаемое значение:
//   Строка   - если параметр пустая строка, то "НЕТ"
///
Функция ФорматПустойСтрокиНЕТ(Строка)
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат "НЕТ";
	Иначе
		Возврат Строка;
	КонецЕсли; 
	
КонецФункции

