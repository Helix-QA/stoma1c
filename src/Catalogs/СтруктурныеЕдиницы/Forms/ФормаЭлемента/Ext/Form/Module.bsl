//
&НаКлиенте
Процедура ВремяОкончанияРаботыНачалоВыбораИзСписка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	МассивПериодов = Новый Массив;
	
	ПериодРаботы = Новый Структура("ДатаНачала, ДатаОкончания");
	Если ЗначениеЗаполнено(Объект.ВремяНачалаРаботы) тогда
		ПериодРаботы.ДатаНачала = Объект.ВремяНачалаРаботы;
	Иначе
		ПериодРаботы.ДатаНачала = Дата("00010101000000");
	КонецЕсли;
	ПериодРаботы.ДатаОкончания = Дата("00010101235959");
	МассивПериодов.Добавить(ПериодРаботы);
	
	СписокВремени = РаботаСДиалогами.ВернутьСписокВремениДляОкончанияРаботы(МассивПериодов,Ложь,30);
	
	НачальноеЗначение = СписокВремени.НайтиПоЗначению(Объект.ВремяНачалаРаботы);
	
	ПоказатьВыборИзСписка(Новый ОписаниеОповещения("ВремяОкончанияРаботыПослеВыбораИзСписка", ЭтотОбъект, Новый Структура("Элемент", Элемент)), СписокВремени, Элемент, НачальноеЗначение); 	

