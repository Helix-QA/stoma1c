// Процедура, отмечает услуги сотрудников.
//
Процедура ОтметитьУслугиСотрудника(Установить, СтруктурнаяЕдиница)
	
	ТаблицаМестаРаботы = ?(Сотрудник <> Неопределено, МестаРаботы, ЭтотОбъект.МестаРаботы);
	Для Каждого МестоРаботы Из ТаблицаМестаРаботы Цикл
		МестоРаботыСотрудника = "СтруктурнаяЕдиница" + МестоРаботы.НомерСтроки;		
	
		ДанныеДерева = ЭтаФорма._ПодборНоменклатур.ПолучитьЭлементы();
		Для Каждого СтрокаТЧ Из ДанныеДерева Цикл
			ТекущиеДанные = СтрокаТЧ;
			ИмяКолонки 	  = МестоРаботыСотрудника;
			ТекущиеДанные[СтруктурнаяЕдиница] = Установить;
			УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки);
			УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, Истина);
		КонецЦикла;
		
		ТаблицаНоменклатуры.Очистить();
		ДанныеДерева = ЭтаФорма._ПодборНоменклатур.ПолучитьЭлементы();
		Для Каждого СтрокаТЧ из ДанныеДерева Цикл
			
			Если СтрокаТЧ.ЭтоГруппа Тогда
				ЗаполнитьТаблицуНоменклатуры(СтрокаТЧ);
			Иначе
				ЗаполнитьСтрокуТаблицыНоменклатуры(СтрокаТЧ);
			КонецЕсли;
			
		КонецЦикла;
		
		СохранитьЗначения(ТаблицаНоменклатуры, Сотрудник);
	
	КонецЦикла;

КонецПроцедуры

