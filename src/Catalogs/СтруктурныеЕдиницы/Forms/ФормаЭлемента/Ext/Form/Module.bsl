//
// Параметры:
//  РезультатВопроса		 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ЗаполнитьПоУмолчаниюЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт

	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Для Каждого СтрокаРасписание из Объект.РасписаниеРаботы Цикл
			СтрокаРасписание.НачалоРаботы    = Объект.ВремяНачалаРаботы;
			СтрокаРасписание.ОкончаниеРаботы = Объект.ВремяОкончанияРаботы;
			СтрокаРасписание.Активность = Истина;
		КонецЦикла;
		Модифицированность = Истина;
	КонецЕсли;

