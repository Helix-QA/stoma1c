#Область ПодготовкаДанныхЧекаОплатыПродажи

// Функция - Подготовить параметры чека на печать
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляККТ(ДокументОплаты)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВидНалога      = Неопределено;
	Касса          = Неопределено;
	СуммаДокумента = 0;
	ВидОперации    = Перечисления.ВидыОпераций.Продажа;
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
		
		ВидОперации = ДокументОплаты.ВидОперации;		
		
		Если ДокументОплаты.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет Тогда
			ВидНалога = ?(ЗначениеЗаполнено(ДокументОплаты.Организация.СистемаНалогообложенияДляАвансов), 
				ДокументОплаты.Организация.СистемаНалогообложенияДляАвансов, ВидНалога);			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования) 
			И (ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования) = Тип("ДокументСсылка.Реализация")
			ИЛИ ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования) = Тип("ДокументСсылка.Прием")) Тогда
			
			ВидНалога   = ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования.ВидНалога;			
			ВидОперации = Перечисления.ВидыОпераций.Продажа;
			
		ИначеЕсли ЗначениеЗаполнено(ДокументОплаты.РасшифровкаПлатежа[0].ДокументАванса) 
			И (ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].ДокументАванса) = Тип("ДокументСсылка.ПланЛечения")
			ИЛИ ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ")) Тогда
			
			ВидНалога   = ДокументОплаты.РасшифровкаПлатежа[0].ДокументАванса.ВидНалога;			
			ВидОперации = Перечисления.ВидыОпераций.Продажа;
			
		КонецЕсли;
		
		Касса          = ДокументОплаты.Касса;
		СуммаДокумента = ДокументОплаты.СуммаДокумента;
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда	
		
		ВидОперации	   = Перечисления.ВидыОпераций.Возврат;
		Касса          = ДокументОплаты.Касса;
		СуммаДокумента = ДокументОплаты.СуммаДокумента;
		Если ЗначениеЗаполнено(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования)
			И ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
			ВидНалога = ДокументОплаты.РасшифровкаПлатежа[0].ДокументОснования.ВидНалога;
		КонецЕсли;
		
	КонецЕсли;     	
	
	Организация    = ДокументОплаты.Организация;
    ПочтаКлиента   = Неопределено;
	ТелефонКлиента = Неопределено;    	
	
	ЗаполнитьКонтактнуюИнформацию(ДокументОплаты, ПочтаКлиента, ТелефонКлиента, Касса);  	

	Если (ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОплаты, "ВнешняяСистема") И Не ЗначениеЗаполнено(ДокументОплаты.ВнешняяСистема) 
		И ЗначениеЗаполнено(ДокументОплаты.АвторДокумента)
		И (ДокументОплаты.АвторДокумента.Наименование <> "<Не указан>" 
		И ДокументОплаты.АвторДокумента.Наименование <> "Служебный пользователь API (не удалять!)")) Тогда
		
		СотрудникДляЧека = ДокументОплаты.АвторДокумента;
	Иначе
		СотрудникДляЧека = ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущийПользователь");
	КонецЕсли;
			
	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	
	ПараметрыЧека.ВидОперации             = ВидОперации;
	ПараметрыЧека.СтруктурнаяЕдиница      = ДокументОплаты.СтруктурнаяЕдиница;
	ПараметрыЧека.Организация             = ДокументОплаты.Организация;
	ПараметрыЧека.Сотрудник               = СотрудникДляЧека;
	ПараметрыЧека.Клиент                  = ДокументОплаты.Контрагент;
	ПараметрыЧека.Дата                    = ТекущаяДата();
	ПараметрыЧека.Касса                   = Касса;
	ПараметрыЧека.Количество              = 1;		
	ПараметрыЧека.СуммаОплачено           = СуммаДокумента;
	ПараметрыЧека.ВидНалога               = ВидНалога; 
	ПараметрыЧека.ТипЧека                 = ?(ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.СписаниеДенежныхСредств"), 1, 0);
    ПараметрыЧека.ВыводитьЧекНаБумагу     = ЭтотОбъект.ПечатьНаБумаге;
	
	Если НЕ ЗначениеЗаполнено(ПочтаКлиента) И НЕ ЗначениеЗаполнено(ТелефонКлиента) Тогда
		ПараметрыЧека.НомерТелефонаКлиента    = Неопределено;
		ПараметрыЧека.ЭлектроннаяПочтаКлиента = Неопределено;                           
	ИначеЕсли ЗначениеЗаполнено(ПочтаКлиента) Тогда		
		ПараметрыЧека.ЭлектроннаяПочтаКлиента = ПочтаКлиента;  
		ПараметрыЧека.НомерТелефонаКлиента    = Неопределено;
	Иначе		
		ПараметрыЧека.НомерТелефонаКлиента    = ТелефонКлиента;
		ПараметрыЧека.ЭлектроннаяПочтаКлиента = Неопределено;
	КонецЕсли;

	ПараметрыЧека.МассивПараметровТовары = Обработки.КассовыйСервер.ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ(ДокументОплаты, Касса); 		
	ПараметрыЧека.МассивПараметровОплаты = ПолучитьМассивОплатФискальногоЧекаОплатыПродажи(ДокументОплаты);	
	
	ПараметрыЧека.СуммаКОплате = ПолучитьСуммуКОплатеПоТабТоваров(ПараметрыЧека.МассивПараметровТовары);

	МассивДокументовОплаты = Новый Массив;
	МассивДокументовОплаты.Добавить(ДокументОплаты);
	
	ПараметрыЧека.МассивДокументовОснований = МассивДокументовОплаты;
	
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека);	

	Возврат ФормированиеЧека;
	
КонецФункции

// Функция - Получить сумму оплаты по документу задолженности
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПолучитьСуммуКОплатеПоТабТоваров(МассивПараметровТовары)
	
	СуммаКОплате = 0;
	Для Каждого СтрокаТ ИЗ МассивПараметровТовары Цикл		
		СуммаКОплате = СуммаКОплате + СтрокаТ.СтоимостьСоСкидкой;		
	КонецЦикла;

	Возврат СуммаКОплате;
КонецФункции

// Функция - Получить массив оплат на печать
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПолучитьМассивОплатФискальногоЧекаОплатыПродажи(ДокументОплаты)
	
	МассивОплат = Новый Массив;		
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") ИЛИ ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.СписаниеДенежныхСредств") Тогда
		
		ПараметрыТипаОплаты = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиПлатежаЧека();
		ПараметрыТипаОплаты.ТипОплаты = ДокументОплаты.ТипДенежныхСредств;
		ПараметрыТипаОплаты.Сумма     = ДокументОплаты.СуммаДокумента;
		
		МассивОплат.Добавить(ПараметрыТипаОплаты);	
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Реализация") Тогда
		
		Для Каждого СтрокаТ ИЗ ДокументОплаты.УчтенныеАвансы Цикл
			
			Если СтрокаТ.НомерЧекаККМ <> 0 Или СтрокаТ.ТипАвансовыхСредств <> Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
				Продолжить;
			КонецЕсли;
						
			ПараметрыТипаОплаты = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиПлатежаЧека();
			ПараметрыТипаОплаты.ТипОплаты = СтрокаТ.ТипАвансовыхСредств;
			ПараметрыТипаОплаты.Сумма     = СтрокаТ.СуммаАванса;
			
			МассивОплат.Добавить(ПараметрыТипаОплаты);	
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивОплат;	
	
КонецФункции

// Функция - Подготовить параметры чека на печать
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ПодготовитьПараметрыФискальногоЧекаОплатыПродажиДляФР(ДокументОплаты)
	
	ВидНалога      = Неопределено;
	Касса          = Неопределено;
	СуммаДокумента = 0;
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
		
		Если ДокументОплаты.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет Тогда
			ВидНалога = ?(ЗначениеЗаполнено(ДокументОплаты.Организация.СистемаНалогообложенияДляАвансов), ДокументОплаты.Организация.СистемаНалогообложенияДляАвансов, ВидНалога);			
		КонецЕсли;   
		
		Если ЗначениеЗаполнено(ДокументОплаты.РасшифровкаПлатежа[0].Основание)
			И ТипЗнч(ДокументОплаты.РасшифровкаПлатежа[0].Основание) = Тип("ДокументСсылка.Реализация") Тогда
			
			ВидНалога = ДокументОплаты.РасшифровкаПлатежа[0].Основание.ВидНалога;
			
		КонецЕсли;
		
		Касса          = ДокументОплаты.Касса;
		СуммаДокумента = ДокументОплаты.СуммаДокумента;
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Реализация") Тогда
		
		ВидНалога      = ДокументОплаты.ВидНалога;
		Касса          = ДокументОплаты.УчтенныеАвансы[0].КассаОплаты;
		СуммаДокумента = Документы.Реализация.ПолучитьСуммуНеФискализированныхУчтенныхАвансов(ДокументОплаты);//ДокументОплаты.УчтенныеАвансы.Итог("СуммаАванса");
		
	КонецЕсли;

	Организация		= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ДокументОплаты, "Организация");
	ПочтаКлиента   	= Неопределено;
	ТелефонКлиента 	= Неопределено;
	
	ЗаполнитьКонтактнуюИнформацию(ДокументОплаты, ПочтаКлиента, ТелефонКлиента, Касса);
	
	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	
	ПараметрыЧека.ВидОперации            = Перечисления.ВидыОпераций.Продажа;
	ПараметрыЧека.СтруктурнаяЕдиница     = ДокументОплаты.СтруктурнаяЕдиница;
	ПараметрыЧека.Организация            = ДокументОплаты.Организация;
	ПараметрыЧека.Сотрудник              = ?(ЗначениеЗаполнено(ДокументОплаты.АвторДокумента), 
												ДокументОплаты.АвторДокумента, 
												ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущийПользователь"));
	ПараметрыЧека.Клиент                 = ДокументОплаты.Контрагент;
	ПараметрыЧека.Дата                   = ТекущаяДата();
	ПараметрыЧека.Касса                  = Касса;
	ПараметрыЧека.Количество             = 1;
	ПараметрыЧека.СуммаОплачено          = СуммаДокумента;
	ПараметрыЧека.СтоимостьБезСкидки     = СуммаДокумента;		
	ПараметрыЧека.Наименование           = НСтр("ru='Оплата от:';en='Payment from:'") + " " + ДокументОплаты.Контрагент;;
	ПараметрыЧека.ТипЧека                = 0;
	
	//ККТ-ые пар-ы
	ПараметрыЧека.ВидНалога               = ВидНалога; 	
	ПараметрыЧека.ВыводитьЧекНаБумагу     = Ложь;
	ПараметрыЧека.ЭлектроннаяПочтаКлиента = ПочтаКлиента;
	ПараметрыЧека.НомерТелефонаКлиента    = ТелефонКлиента;

	ПараметрыЧека.МассивПараметровТовары = ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляФР(ДокументОплаты);		
	ПараметрыЧека.МассивПараметровОплаты = ПолучитьМассивОплатФискальногоЧекаОплатыПродажи(ДокументОплаты);	
	
	ПараметрыЧека.СуммаКОплате           = ПолучитьСуммуКОплатеПоТабТоваров(ПараметрыЧека.МассивПараметровТовары);
	
	МассивДокументовОплаты = Новый Массив;
	МассивДокументовОплаты.Добавить(ДокументОплаты);
	
	ПараметрыЧека.МассивДокументовОснований = МассивДокументовОплаты;
	
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоИНеФискальногоЧекаФР(ПараметрыЧека);	

	Возврат ФормированиеЧека;
	
КонецФункции

&НаСервере
//Функция, возвращает массив товаров на печать
//
Функция ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляФР(ДокументОплаты)
	
	МассивДокументовРеализации = Новый Массив;
		
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ПоступлениеДенежныхСредств") Тогда
		
		Для Каждого СтрокаТЧ ИЗ ДокументОплаты.РасшифровкаПлатежа Цикл
			МассивДокументовРеализации.Добавить(СтрокаТЧ.Основание);
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.Реализация") Тогда
		
		МассивДокументовРеализации.Добавить(ДокументОплаты);
		
	КонецЕсли;

	МассивТоваров = Новый Массив;
    Для Каждого Основание ИЗ МассивДокументовРеализации Цикл
		
		Организация        = Основание.Организация;		
		ОплатаПоРеализации = 0;
		СуммаДокумента     = 0;
		
		ОплатаПоРеализации = СуммаОплатыРеализацииДоТекущегоДокумента(Основание, ДокументОплаты.Дата);	
		СуммаДокумента     = Основание.СуммаДокумента;
		
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.Реализация") Тогда
			
			Если ОплатаПоРеализации = 0  Тогда
				
				Для Каждого СтрокаЗапаса ИЗ Основание.Запасы Цикл
					
					Если СтрокаЗапаса.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.МодификаторЧленствПакетов 
						И СтрокаЗапаса.КоличествоУпаковок * СтрокаЗапаса.Цена = 0 Тогда				
						Продолжить;
					КонецЕсли;
					
					СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
					
					СтрокаТовара.Номенклатура           = СтрокаЗапаса.Номенклатура;
					СтрокаТовара.Наименование           = СтрокаЗапаса.Номенклатура.Наименование;
					СтрокаТовара.СтоимостьБезСкидки     = СтрокаЗапаса.КоличествоУпаковок * СтрокаЗапаса.Цена;
					СтрокаТовара.СуммаСкидки            = (СтрокаЗапаса.КоличествоУпаковок * СтрокаЗапаса.Цена) - СтрокаЗапаса.Всего;
					СтрокаТовара.СтоимостьСоСкидкой     = СтрокаТовара.СтоимостьБезСкидки - СтрокаТовара.СуммаСкидки;
					СтрокаТовара.Количество             = СтрокаЗапаса.КоличествоУпаковок;
					СтрокаТовара.СтавкаНДС              = СтрокаЗапаса.СтавкаНДС;
					СтрокаТовара.СуммаНДС               = СтрокаЗапаса.СуммаНДС;
					СтрокаТовара.НомерСекции            = Справочники.Кассы.ВернутьСекциюПоНоменклатуре(СтрокаЗапаса.Номенклатура, ЭтотОбъект.КассаФискализации);
					СтрокаТовара.Штрихкод               = РегистрыСведений.Штрихкоды.ПоулчитьШтрихкодПоОбъекту(СтрокаЗапаса.Номенклатура, СтрокаЗапаса.Партия);
					СтрокаТовара.ЭтоОплатаКредита       = Ложь;
					
					МассивТоваров.Добавить(СтрокаТовара);
					
				КонецЦикла; 
				
			Иначе
				
				СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
				
				СтрокаТовара.Номенклатура           = Справочники.Номенклатура.ПустаяСсылка();
				СтрокаТовара.Наименование           = "Продажа №" + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Основание.Номер, Организация.Префикс) + " - Частичная оплата";
				СтрокаТовара.СтоимостьБезСкидки     = СтрокаТЧ.Сумма;
				СтрокаТовара.СтоимостьСоСкидкой     = СтрокаТЧ.Сумма;
				СтрокаТовара.СуммаСкидки            = 0;
				СтрокаТовара.Количество             = 1;
				СтрокаТовара.ЭтоОплатаКредита       = ВыполняетсяПостоплатаРеализации(Основание, Истина);
				
				Если ЗначениеЗаполнено(Организация) Тогда
					
					СтрокаТовара.СтавкаНДС = Ценообразование.ПолучитьСтавкуНДСНоменклатуры(Новый Структура("Организация", Организация));
					СтрокаТовара.СуммаНДС  = Цел(Ценообразование.РассчитатьСуммуНДС(СтрокаТовара.СтоимостьБезСкидки , СтрокаТовара.СтавкаНДС, Основание.СуммаВключаетНДС));
					
				КонецЕсли;
				
				МассивТоваров.Добавить(СтрокаТовара);
				
				//МассивТоваров.Добавить(Новый Структура("Наименование, СтоимостьБезСкидки, Количество", 
				//"Продажа №" + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(СтрокаТЧ.Основание.Номер, Объект.Организация.Префикс)+
				//" частичная оплата", СтрокаТЧ.Сумма , 1));			
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивТоваров;
	
КонецФункции

// Функция - Сумма оплаты реализации
//
// Параметры:
//  Реализация	 - 	 - 
