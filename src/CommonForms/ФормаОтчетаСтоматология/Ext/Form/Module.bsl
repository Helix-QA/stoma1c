// Процедура, проверяет актуальность данных отчета.
//
Процедура ПрверитьАктуальностьДанных(ВыбранныйПараметр)
	
	ОтображениеСостояния = Элементы.ОтчетТабличныйДокумент.ОтображениеСостояния;
	Если ОтображениеСостояния.Видимость = Истина
		И ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.Неактуальность Тогда
		
		ТекстВопроса = НСтр("ru='Отчет не сформирован. Сформировать?';en='Report not formed. To form'");		
		
		ДопПараметр = Новый Структура("ВыбранныйПараметр", ВыбранныйПараметр);
		Оповещение = Новый ОписаниеОповещения("ПослеПроверкиНаАктуальностьДанных", ЭтотОбъект, ДопПараметр);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Да);
		Возврат;
	КонецЕсли;
	
	ОбработкаРезультатаВыбораОперации(ВыбранныйПараметр);
	
КонецПроцедуры

&НаКлиенте
// Процедура, завершение после "ПослеПроверкиНаАктуальность".
//
Процедура ПослеПроверкиНаАктуальностьДанных(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	СформироватьНепосредственно();

	ОбработкаРезультатаВыбораОперации(ДополнительныеПараметры.ВыбранныйПараметр);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработка выбранного результата операции.
//
Процедура ОбработкаРезультатаВыбораОперации(ВыбранныйПараметр)
	
	Если ВыбранныйПараметр = "ИзменитьКлиентов" Тогда
		
		ИзменитьКлиентовИзОтчета();
		
	ИначеЕсли ВыбранныйПараметр = "СоздатьСегментКлиентов" Тогда
		
		СоздатьСегментКлиентовИзОтчета();
		
	ИначеЕсли ВыбранныйПараметр = "ОбновитьСегмент" Тогда
		
		ОбновитьСегментИзОтчета();
		
	ИначеЕсли ВыбранныйПараметр = "СоздатьЗадачиПоКлиентам" Тогда
		
		ЭтотОбъект.СоздатьЗадачу = Истина;
		ПоказатьВсплывающуюГруппу();
		
	ИначеЕсли ВыбранныйПараметр = "СоздатьСделкиПоКлиентам" Тогда
		
		ЭтотОбъект.СоздатьЗадачу = Ложь;
		ПоказатьВсплывающуюГруппу();
		
	ИначеЕсли ВыбранныйПараметр = "ОтправитьПоЭлектроннойПочтеКлиентамИзОтчета"  Тогда
		
		ПараметрыОткрытия = ОтправитьПоЭлектроннойПочтеКлиентамИзОтчетаНаСервере();
		Если ПараметрыОткрытия <> Неопределено Тогда
			ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.ФормаОбъекта", ПараметрыОткрытия);
		КонецЕсли;

	ИначеЕсли ВыбранныйПараметр = "Отправить_SMS"  Тогда
		
		МассивКлиентов  = ПолучитьМассивКонтрагентовИзРезультата();
		МассивТелефонов = Новый Массив;
		Если МассивКлиентов.Количество() > 0 Тогда
			
			МассивСтруктурПолучателей = Новый Массив;
			
			Для Каждого Клиент Из МассивКлиентов Цикл
				
				ТелефоныКлиента = ПолучитьНомераТелефоновКонтрагента(Клиент);
				Для Каждого Телефон Из ТелефоныКлиента Цикл 
					Если МассивТелефонов.Найти(Телефон) = Неопределено Тогда
						МассивСтруктурПолучателей.Добавить(Новый Структура("Получатель, НомерТелефона", Клиент, Телефон));
						МассивТелефонов.Добавить(Телефон);
					КонецЕсли;
				КонецЦикла;
				
			КонецЦикла;
			
			ПараметрыОткрытия = Новый Структура("Получатели", МассивСтруктурПолучателей);
			ОткрытьФорму("Документ.РассылкаСообщений.ФормаОбъекта", ПараметрыОткрытия);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьПоЭлектроннойПочте(Команда)
	ОтображениеСостояния = Элементы.ОтчетТабличныйДокумент.ОтображениеСостояния;
	Если ОтображениеСостояния.Видимость = Истина
		И ОтображениеСостояния.ДополнительныйРежимОтображения = ДополнительныйРежимОтображения.Неактуальность Тогда
		
		ТекстВопроса = НСтр("ru='Отчет не сформирован. Сформировать?';en='Report not formed. To form'");
		Ответ = Неопределено;

		ПоказатьВопрос(Новый ОписаниеОповещения("ОтправитьПоЭлектроннойПочтеЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Да);
        Возврат;
	КонецЕсли;
	
	ОтправитьПоЭлектроннойПочтеФрагмент();
КонецПроцедуры

