	Группа_Значения_Периода = Форма.Элементы.Добавить("Группа_Значения_Периода" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("ГруппаФормы"), Группа_ШапкаПериода);
