
#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура вызывается по кнопке "Разрешить редактирование".
//
Процедура РазрешитьРедактирование(Команда)

	Результат = Новый Массив;
	Если РазрешитьРедактированиеБанковскийСчет Тогда
		Результат.Добавить("БанковскийСчет");
	КонецЕсли;
	Если РазрешитьРедактированиеЭквайер Тогда
		Результат.Добавить("Эквайер");
	КонецЕсли;
	
	Закрыть(Результат);   

КонецПроцедуры // РазрешитьРедактирование()

#КонецОбласти
