	Сделка = ЭтаФорма.ТаблицаСделок[ИндексВиджета].Сделка;
	
	Структура = Новый Структура();
	Структура.Вставить("Контрагент"			, Объект.Ссылка);
	Структура.Вставить("Сделка"	   			, Сделка);
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеКонстанты("ИспользоватьМенеджераПрезентацииПриПродаже") = Истина Тогда 	
		МенеджерПрезентации = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Сделка, "МенеджерПрезентации");
		Структура.Вставить("МенеджерПрезентации", ?(ЗначениеЗаполнено(МенеджерПрезентации), МенеджерПрезентации, Объект.МенеджерПрезентации));
	КонецЕсли;
	ПараметрыФормы  = Новый Структура("ЗначенияЗаполнения", Структура);	
	НовоеОповещение = Новый ОписаниеОповещения("СоздатьРеализациюЗавершение", ЭтотОбъект, Сделка);
	
	СменитьФокусЭлемента(ИндексВиджета);
	ОткрытьФорму("Документ.Реализация.Форма.ФормаДокумента",ПараметрыФормы,,,,,НовоеОповещение);
	
КонецПроцедуры

