						Контрагент = Неопределено;
					КонецЕсли;	
				Исключение
					Контрагент = Неопределено;
				КонецПопытки;
			КонецЕсли;
			Если ЗначениеЗаполнено(Контрагент) Тогда
				МассивКонтрагентов.Добавить(Контрагент);
			КонецЕсли;
			Запрос.УстановитьПараметр("ОбъектСобытия"		, ОбъектСобытия);				
			Запрос.УстановитьПараметр("МассивКонтрагентов"	, МассивКонтрагентов);
			Запрос.УстановитьПараметр("ПериодОтбора"		, Дата(1, 1, 1));
		КонецЕсли;	
		
		ТаблицаПланаДействий = Запрос.Выполнить().Выгрузить();
		
