// Процедура - Построить динаимческую таблицу задолженностей
// 
&НаСервере
Процедура ПостроитьДинамическиеЭлементыВыбораКасс()
	
	УдалитьДинамическиеЭлементыВыбораКасс();
			
	Индекс = 1;
	Пока Индекс < ЭтотОбъект.ДоступныеКассы.Количество()  Цикл

		ДанныеПоКассе =  ЭтотОбъект.ДоступныеКассы[Индекс];
		ПостроитьЭлементыВыбораКассы(ДанныеПоКассе, Индекс);
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Если ЭтотОбъект.ДоступныеКассы.Количество() > 0 Тогда
		
        УстановитьСостояниеКнопкиВыбораКассы(Элементы.ГруппаКассаОплатыКнопка_0, Элементы.КассаОплаты_0);
		ЭтотОбъект.ТекущаяКассаИспользуетсяККТ = ЭтотОбъект.ТекущаяКасса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;
		
	Иначе
		
		Элементы.КассаОплаты_0.Заголовок = "Нет доступных касс у сотрудника";
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Установить состояние кнопки выбора кассы
// 
// Параметры:
//  ГруппаКнопки - 	 - 
//  КнопкаВыбора - 	 - 
// 
&НаСервере
Процедура УстановитьСостояниеКнопкиВыбораКассы(ГруппаКнопки, КнопкаВыбора)
	
	ИндексДанных = ИндексСтрокиДанныхПоИмениЭлемента(ГруппаКнопки.Имя);
	
	ДанныеКассы       = ЭтотОбъект.ДоступныеКассы[ИндексДанных];	
	ЭтоВыбраннаяКасса = ДанныеКассы.Касса = ЭтотОбъект.ТекущаяКасса;	
	
	ГруппаКнопки.ЦветФона = ?(ЭтоВыбраннаяКасса, ЦветаСтиля["ЦветАктивности"], Новый Цвет(255,255,255));
	
	КнопкаВыбора.Доступность = НЕ ЭтоВыбраннаяКасса И (ДанныеКассы.КассаДоступна ИЛИ ДанныеКассы.ИспользуетсяОнлайн);
	КнопкаВыбора.ЦветТекста  = ?(ЭтоВыбраннаяКасса, WebЦвета.Черный, Новый Цвет(51,102,187));	
	КнопкаВыбора.Заголовок   = ДанныеКассы.Касса.Наименование;
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить динаимеческие элементы состав занятия
// 
// Параметры:
//  ИндексПервогоЭлемента	 - 	 - 
// 
Процедура УдалитьДинамическиеЭлементыВыбораКасс()
	
	ОсновнаяГруппа = ВыборКассРодительскаяГруппа();
	
	// Все оставльные
	Индекс = ОсновнаяГруппа.ПодчиненныеЭлементы.Количество() - 1;
	Пока Индекс > 0  Цикл
		
		Элементы.Удалить(ОсновнаяГруппа.ПодчиненныеЭлементы[Индекс]);
		
		Индекс = Индекс - 1;
		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Построить строку динаимческой таблицы задолженностей
// 
// Параметры:
//  СтрокаТ	 - 	 - 
// 
&НаСервере
Процедура ПостроитьЭлементыВыбораКассы(ДанныеКассы, ИндексДанных)

	НомерСтрокиДан   = ИндексДанных;	
	ОсновнаяГруппа   = ВыборКассРодительскаяГруппа();
		
	ПодгруппаСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаКассаОплаты_0,
	НомерСтрокиДан,
	ОсновнаяГруппа);
	
	ПодгруппаКнопки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаКассаОплатыКнопка_0,
	НомерСтрокиДан,
	ПодгруппаСтроки);
	
	КнопкаВыбораКассы = УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.КассаОплаты_0,
	НомерСтрокиДан,
	ПодгруппаКнопки,,
	ДанныеКассы.Касса.Наименование);	
	
	УстановитьСостояниеКнопкиВыбораКассы(ПодгруппаКнопки, КнопкаВыбораКассы);
	
КонецПроцедуры

// Функция - Выбор касс родительская группа
// 
// Возвращаемое значение:
//   - 
// 
&НаСервере
Функция ВыборКассРодительскаяГруппа()
	
	Возврат Элементы.ГруппаВыборКассыДляОплаты;
	
КонецФункции

#КонецОбласти

&НаСервере
// Процедура - Обновить выбор доступных касс
// 
// Параметры:
//  ДокументДляОплаты		 - 	 - 
//  КассыДляВсехДокументов	 - 	 - 
// 
Процедура ОбновитьВыборДоступныхКасс(ДокументДляОплаты = Неопределено, КассыДляВсехДокументов = Неопределено)
	
	ЭтотОбъект.ТекущаяКасса = Неопределено;
	
	// Настройка кассы оплаты
	ВременныйМассив = РозничныеПродажи.ПолучитьКассыДоступныеДляОплаты(
		КассыДляВсехДокументов,
		ПараметрыСеанса.РабочееМестоКлиента,
		Ложь);	                                                           
	
	ЭтотОбъект.ДоступныеКассы.Очистить();
	
	врДоступныеКассы = Новый Массив;
	
	// Оставляем только те кассы, которые доступны для документов оплаты
	Если ЗначениеЗаполнено(КассыДляВсехДокументов) Тогда
		
		врДоступныеКассы = Новый Массив;
		Для Каждого ЭлементМ ИЗ ВременныйМассив Цикл
			Если НЕ КассыДляВсехДокументов.Найти(ЭлементМ.Касса) = Неопределено Тогда
				врДоступныеКассы.Добавить(ЭлементМ);
			КонецЕсли;	
		КонецЦикла;		
		
	Иначе
		
		врДоступныеКассы = ВременныйМассив;
		
	КонецЕсли;
	
	ОбновитьДоступныеКассыДляСсылокИСбп(врДоступныеКассы);
	
	// Последовательность касс уже упорядоченна по приоритету в функции: Справочники.Кассы.ПолучитьКассыДляОплаты.
	Если врДоступныеКассы.Количество() > 0 И ДокументДляОплаты <> Неопределено Тогда
						
		Для Каждого ЭлементМ ИЗ врДоступныеКассы Цикл
			
			Если ЭлементМ.КассаДоступна = Истина ИЛИ ЭлементМ.ИспользуетсяОнлайн = Истина Тогда
				
				ЭтотОбъект.ТекущаяКасса = ЭлементМ.Касса;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;					
			
	КонецЕсли;
	
	Для Каждого ЭлементМ ИЗ врДоступныеКассы Цикл 
		
		НоваяСтрока = ЭтотОбъект.ДоступныеКассы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементМ);
		
	КонецЦикла;
	
	ПостроитьДинамическиеЭлементыВыбораКасс();

КонецПроцедуры

&НаСервере
// Обновить таблицу задолженностей без перезагрузки ее элементов
Процедура ПриИзмененииВыбораКассыОплатыСервер(ЭлементИмя)
		
	Индекс = 0;
	
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ДоступныеКассы Цикл
		
		Если ЭлементИмя = "КассаОплаты_" + Индекс Тогда
			
			ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Доступность     = Ложь;
			ЭтаФорма.Элементы["КассаОплаты_" + Индекс].ЦветТекста      = WebЦвета.Черный;
			ЭтаФорма.Элементы["ГруппаКассаОплатыКнопка_" + Индекс].ЦветФона = ЦветаСтиля["ЦветАктивности"]; 
			
			ЭтотОбъект.ТекущаяКасса = СтрокаТ.Касса;
			
		Иначе	
			
			ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Доступность           = СтрокаТ.КассаДоступна ИЛИ СтрокаТ.ИспользуетсяОнлайн;
			ЭтаФорма.Элементы["КассаОплаты_" + Индекс].ЦветТекста            = Новый Цвет(51,102,187);
			ЭтаФорма.Элементы["ГруппаКассаОплатыКнопка_" + Индекс].ЦветФона  = Новый Цвет(255,255,255);
			
		КонецЕсли;
		
		Индекс = Индекс + 1;
		                 
	КонецЦикла; 
	
	ОчиститьВнесенныеВидыОплат();
	ЭтотОбъект.ОплатаВнесено   = 0;
	ЭтотОбъект.ОплатаСдача     = 0;		
	ЭтотОбъект.ОплатаСумма     = 0;
	
	ЭтотОбъект.ТекущаяКассаИспользуетсяККТ = ЭтотОбъект.ТекущаяКасса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;
	ЭтотОбъект.ПечатьКопииЧека             = ЭтотОбъект.ТекущаяКасса.ПечатьКопииЧеков;
	ЭтотОбъект.ПечатьКопииЧекаКоличество   = ЭтотОбъект.ТекущаяКасса.ПечатьКопииЧековКоличество;
	ЭтотОбъект.ЧекПечатать				   = Не ЭтотОбъект.ТекущаяКасса.ПриоритетЭлектронногоЧека;
	
	РасставитьПриоритетПечатиЧека();
	
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ТаблицаЗадолженностей Цикл
		
		ОплатаЗаблокирована          = (ЭтотОбъект.ТекущаяКасса.СтруктурнаяЕдиница <> СтрокаТ.СтруктурнаяЕдиница); 
		СтрокаТ.ОплатаЗаблокирована  = ОплатаЗаблокирована;
		
		Если ОплатаЗаблокирована = Истина Тогда
			СтрокаТ.ОписаниеБлокировки = "Не выбрана касса для оплаты!";
		Иначе
			СтрокаТ.ОписаниеБлокировки = Неопределено;
		КонецЕсли;
		
		Если ОплатаЗаблокирована Тогда
			СтрокаТ.ПризнакВыбора = Ложь;
		ИначеЕсли СтрокаТ.ПризнакВыбора Тогда		
			СтрокаТ.ПризнакВыбора = НЕ ОплатаЗаблокирована;
		КонецЕсли;
		
		Если НЕ ОплатаЗаблокирована Тогда
			
			Если СтрокаТ.ПризнакВыбора = Истина 
				И СтрокаТ.ОплатаЗаблокирована = Ложь Тогда
				
				ЭтотОбъект.ОплатаСумма = ЭтотОбъект.ОплатаСумма + СтрокаТ.Задолженность;
				
			КонецЕсли;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	УстановитьВидыОплатСервер(Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ТаблицаЗадолженностей

#Область КонструкторДинамическойТаблицыЗадолженности

// Процедура - Построить динаимческую таблицу задолженностей
// 
&НаСервере
Процедура ПостроитьДинамическуюТаблицуЗадолженностей()
	
	УдалитьДинамическиеЭлементыТаблицыЗадолженности();
			
	Индекс = 1;
	Пока Индекс < ЭтотОбъект.ТаблицаЗадолженностей.Количество()  Цикл

		СтрокаТ = ЭтотОбъект.ТаблицаЗадолженностей[Индекс];
		ПостроитьСтрокуДинамическойТаблицыЗадолженностей(СтрокаТ);
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Если ЭтотОбъект.ТаблицаЗадолженностей.Количество() > 0 Тогда
		
		Элементы.ЗадолженностьДатаСтрока_0.Заголовок = ЭтотОбъект.ТаблицаЗадолженностей[0].Группировка;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить динаимеческие элементы состав занятия
// 
// Параметры:
//  ИндексПервогоЭлемента	 - 	 - 
// 
Процедура УдалитьДинамическиеЭлементыТаблицыЗадолженности()
	
	ОсновнаяГруппа = ЗадолженностьРодительскаяГруппаФормы();
	
	// Все оставльные
	Индекс = ОсновнаяГруппа.ПодчиненныеЭлементы.Количество() - 1;
	Пока Индекс > 0  Цикл
		
		Элементы.Удалить(ОсновнаяГруппа.ПодчиненныеЭлементы[Индекс]);
		
		Индекс = Индекс - 1;
		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура - Построить строку динаимческой таблицы задолженностей
// 
// Параметры:
//  СтрокаТ	 - 	 - 
// 
&НаСервере
Процедура ПостроитьСтрокуДинамическойТаблицыЗадолженностей(СтрокаТ)

	НомерСтрокиДан   = ЭтотОбъект.ТаблицаЗадолженностей.Индекс(СтрокаТ);	
	ОсновнаяГруппа   = ЗадолженностьРодительскаяГруппаФормы();
		
	ПодгруппаСтроки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаЗадолженностьСтрока_0,
	НомерСтрокиДан,
	ОсновнаяГруппа);
	
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ДекорацияЗадолженностьСмещениеСлеваСтрока_0, 
	НомерСтрокиДан,
	Тип("ДекорацияФормы"),
	ПодгруппаСтроки);

	// Поле выбора
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ЗадолженностьВыборСтрока_0, 
	НомерСтрокиДан,
	Тип("ПолеФормы"), 
	ПодгруппаСтроки,
	"ТаблицаЗадолженностей[" + НомерСтрокиДан +"].ПризнакВыбора");
	
	// Кнопка расшифровки
	ПодгруппаКнопки = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(
	ЭтаФорма,
	Элементы.ГруппаЗадолженностьКнопкаСтрока_0,
	НомерСтрокиДан,
	ПодгруппаСтроки);
	
	УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(
	ЭтаФорма,
	Элементы.ЗадолженностьДатаСтрока_0,
	НомерСтрокиДан,
	ПодгруппаКнопки,
	"ТаблицаЗадолженностейРасшифровкаНажатие",
	СтрокаТ.Группировка);	
	
	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ЗадолженностьРасшифровкаСтрока_0, 
	НомерСтрокиДан,
	Тип("ПолеФормы"), 
	ПодгруппаСтроки,
	"ТаблицаЗадолженностей[" + НомерСтрокиДан +"].Представление");

	УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(
	ЭтаФорма,
	Элементы.ЗадолженностьЗадолженностьСтрока_0, 
	НомерСтрокиДан,
	Тип("ПолеФормы"), 
	ПодгруппаСтроки,
	"ТаблицаЗадолженностей[" + НомерСтрокиДан +"].Задолженность");
	
КонецПроцедуры

