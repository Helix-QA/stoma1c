			ПоказатьВопрос(Оповещение, НСтр("ru='Для создания сделки необходимо сохранить пердварительную запись. Записать?';en='For create deals is necessary toproduce record new client. WriteDown?'"), РежимДиалогаВопрос.ДаНет);
			
		Иначе
			СоздатьСделку(Объект.Ссылка, Результат.Значение); 			
		КонецЕсли;
				
