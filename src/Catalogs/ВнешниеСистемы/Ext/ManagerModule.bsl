
#Область СлужебныеПроцедурыИФункции

//  Имя событие для записи в журнал регистрации.
//
Функция СобытиеЖурналаРегистрации() Экспорт
	
	Возврат НСтр("ru = 'Внешняя система'", ОбщегоНазначения.КодОсновногоЯзыка());
	
КонецФункции

// Процедура, обработчик события "ОбработкаПолученияФормы".
//
Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)

	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Если Параметры.Свойство("Ключ") Тогда
			ТипВнешнейСистемы = Параметры.Ключ.ТипВнешнейСистемы;
		ИначеЕсли Параметры.Свойство("ТипВнешнейСистемы") Тогда
			ТипВнешнейСистемы = Параметры.ТипВнешнейСистемы;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТипВнешнейСистемы) Тогда
		
		Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Wallet Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаНастройкиЭлектронныхКартWallet"; 
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Calltouch Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаCalltouch";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Roistat Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаRoistat";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ЯндексМетрика Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаЯндексМетрика";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ПроДокторов Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаПроДокторов";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Webhook Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаWebhook";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ВиджетОнлайнЗаписи Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаВиджетОнлайнЗаписи";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ИЭМК Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаИЭМК";

		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.IPТелефония Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаIPТелефония";

		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.ЯндексКарты Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаЯндексКарты";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.CoMagic Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "ФормаЭлементаCoMagic";	
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.JivoSite Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма		 = "ФормаЭлементаJivoSite";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Marquiz Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаЭлементаMarquiz";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Tilda Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаЭлементаTilda";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.TapLink Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаЭлементаTapLink";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.КонтурСтрахование Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаЭлементаКонтурСтрахование";
			
		ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.СистемаБыстрыхПлатежей Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма 		 = "ФормаЭлементаСистемаБыстрыхПлатежей";
			
		КонецЕсли; 
		
	КонецЕсли;

КонецПроцедуры

// Функция - Получить внешнюю систему
//
// Параметры:
//  КлючПриложения		 - 	 - 
//  ТипыСистем			 - 	 - 
//  ТолькоИспользуемое	 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
//  ВозвращатьВсе		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВнешнююСистему(
	КлючПриложения		 = Неопределено,
	Знач ТипыСистем		 = Неопределено,
	ТолькоИспользуемое	 = Истина,
	СтруктурнаяЕдиница	 = Неопределено,
	ВозвращатьВсе		 = Ложь) Экспорт
	
	Если ТипЗнч(ТипыСистем) <> Тип("Массив") Тогда
		
		ТипыСистем = Новый_Массив(ТипыСистем);
		
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ТолькоИспользуемое = ИСТИНА
	|				ТОГДА ВнешниеСистемы.Используется = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА &Ключ <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.КлючПриложения = &Ключ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА НЕ НЕОПРЕДЕЛЕНО В (&ТипыСистем)
	|				ТОГДА ВнешниеСистемы.ТипВнешнейСистемы В (&ТипыСистем)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						ИЛИ ВнешниеСистемы.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ");
	
	Запрос.УстановитьПараметр("Ключ"              , ?(ЗначениеЗаполнено(КлючПриложения)    , КлючПриложения    , Неопределено));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, Неопределено));
	Запрос.УстановитьПараметр("ТолькоИспользуемое", ТолькоИспользуемое);
    Запрос.УстановитьПараметр("ТипыСистем"        , ТипыСистем);
	
	Если ВозвращатьВсе = Ложь Тогда
		Результат = Запрос.Выполнить().Выбрать();
		Возврат ?(Результат.Следующий(), Результат.Ссылка, Справочники.ВнешниеСистемы.ПустаяСсылка());
	Иначе
		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
КонецФункции

// Функция, возвращает флаг использования мессенджера.
//
Функция МессенджерИспользуется(СтруктурнаяЕдиница = Неопределено) Экспорт
	
	ТипыВнешнихСистем = ПолучитьМассивТиповВнешнихСистемМессенджера();
	
	Запрос = Новый Запрос( 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистем)
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.Используется
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|						ИЛИ ВнешниеСистемы.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ");
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистем", ТипыВнешнихСистем);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции

// Функция, возвращает типы внешних систем мессенджера.
//
Функция ПолучитьМассивТиповВнешнихСистемМессенджера() Экспорт
	
	ТипыВнешнихСистем = Новый Массив;
	// ТипыВнешнихСистем.Добавить(Перечисления.ТипыВнешнихСистем.Chat2Desk);
	ТипыВнешнихСистем.Добавить(Перечисления.ТипыВнешнихСистем.VkontakteApi);
	// ТипыВнешнихСистем.Добавить(Перечисления.ТипыВнешнихСистем.Instagram);
	ТипыВнешнихСистем.Добавить(Перечисления.ТипыВнешнихСистем.GreenApi);
	ТипыВнешнихСистем.Добавить(Перечисления.ТипыВнешнихСистем.Telegram);
	ТипыВнешнихСистем.Добавить(Перечисления.ТипыВнешнихСистем.Viber);
	
	Возврат ТипыВнешнихСистем;
	
КонецФункции

// Функция, возвращает типы внешних систем мессенджера, в которых можно начинать диалог первым.
//
Функция ПолучитьТипыВнешнихСистемМессенджераОтправитьПервым() Экспорт
	
