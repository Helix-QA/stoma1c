//
// Параметры:
//  ДанныеПериода			 - 	 - 
//  ОбновитьЭлементыЗначений - 	 - 
//
Процедура ОбновитьДинамическоеМенюФильтрации_СозданаПериод(ДанныеПериода = Неопределено, ОбновитьЭлементыЗначений = Ложь)
	
	СтруктураФильтра = УправлениеИнтерфейсамиСервер.ПолучитьСтруктуруФильтра();
	СтруктураФильтра.Вставить("Представление"							, НСтр("ru = 'Создана'; en = 'Created by'"));
	СтруктураФильтра.Вставить("РеквизитДата"							, НачалоДня(ТекущаяДатаСеанса()));
	СтруктураФильтра.Вставить("Наименование"							, "Фильтр_СозданаПериод");
	СтруктураФильтра.Вставить("ИмяГруппыТипФильтра"						, "Фильтр_СозданаПериод");
	СтруктураФильтра.Вставить("ИмяСтраницыЗначенийФильтра"				, "Страница_Значения_Фильтр_СозданаПериод");
	СтруктураФильтра.Вставить("ИмяГруппыЗначенийФильтра"				, "Значения_Фильтр_СозданаПериод");
	СтруктураФильтра.Вставить("ИмяГруппыАктивированныхЗначенийФильтра"	, "АктивированныеЗначения_Фильтр_СозданаПериод");
	СтруктураФильтра.Вставить("ОбновитьЭлементыЗначений"				, ОбновитьЭлементыЗначений);
	СтруктураФильтра.Вставить("ОписаниеТипаЗначения"					, Новый ОписаниеТипов("СтандартныйПериод"));
	
	УправлениеИнтерфейсамиСервер.ИнициализироватьСписокЗначений(СтруктураФильтра, , Новый СтандартныйПериод, НСтр("ru = 'За весь период'; en = 'For all period'"));
																												
	УправлениеИнтерфейсамиСервер.ОбновитьЭлементыФильтрацииДанных(ЭтаФорма, СтруктураФильтра);																												
		
КонецПроцедуры 

