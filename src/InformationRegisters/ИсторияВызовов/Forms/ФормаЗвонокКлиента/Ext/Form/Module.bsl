// Процедура - Добавить необрабатываемый номер
//
// Параметры:
//  Номер	 - 	 - 
//
Процедура УдалитьНеобрабатываемыйНомер(Знач НомерТелефона, Знач ПричинаБлокировки = "")
	
	УстановитьПривилегированныйРежим(Истина);
	
	МенеджерЗаписи = РегистрыСведений.ЗаблокированныеНомераТелефонов.СоздатьМенеджерЗаписи();
