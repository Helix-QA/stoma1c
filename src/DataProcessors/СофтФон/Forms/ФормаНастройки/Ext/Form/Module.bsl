&НаКлиенте
// Процедура, обработчик события команды
//
Процедура УстановитьПоУмолчанию(Команда)
	
	Для Каждого СтрокаТЧ из ТаблицаКодеков Цикл
		СофтФон.EnableCodec(СтрокаТЧ.Индекс, Истина);
	КонецЦикла;
	Список = Новый Массив;
	Список.Добавить("6");
	Список.Добавить("7");
	Список.Добавить("10");
	Список.Добавить("11");
	Список.Добавить("13");
	Список.Добавить("14");
	Список.Добавить("15");
