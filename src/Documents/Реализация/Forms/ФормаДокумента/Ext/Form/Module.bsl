// Процедура обработчик нажатия "Подключаемый_Удалить_Промокод_Нажатие".
//
Процедура Подключаемый_Удалить_Промокод_Нажатие(Элемент)
	
	ИмяКоманды 		= Элемент.Имя;                                                            
	ИндексПромокода = Сред(ИмяКоманды, СтрДлина("Подключаемый_Удалить_Промокод_") + 1);
	Попытка         
		ИндексПромокода = Число(ИндексПромокода);
	Исключение                                   
		Возврат;
	КонецПопытки;                                
	
	ЗаголовокВопроса = ?(Модифицированность, "Документ будет сохранен" + ?(Объект.Проведен, " и проведен. ", ". "), "") + "Удалить промокод?"; 
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросУдалитьПромокодЗавершение", ЭтотОбъект, Новый Структура("ИндексПромокода", ИндексПромокода));
	ПоказатьВопрос(ОписаниеОповещения, ЗаголовокВопроса, РежимДиалогаВопрос.ДаНетОтмена,,, "Вопрос пользователю");
	
КонецПроцедуры 

