//
Процедура ВыборВзаимодействиеЗадачаЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ЭтотОбъект.ВзаимодействиеЗадачаТема = "";
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры = Новый Структура;
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Вставить("Взаимодействие"   , Результат.Значение.Взаимодействие);
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Вставить("ВидВзаимодействия", Результат.Значение.ВидВзаимодействия);
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Вставить("ТемаПоУмолчанию"  , Результат.Значение.ТемаПоУмолчанию);
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Вставить("Представление"    , Результат.Представление);
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Вставить("Картинка"         , Результат.Картинка);
		
		Если Объект.Ссылка.Пустая() Тогда
						
			Оповещение = Новый ОписаниеОповещения("ВзаимодействиеПослеВопросаОЗаписиЗаявки", ЭтотОбъект, Новый Структура("ВыполнитьДействие", "ВыборВзаимодействия"));
			ПоказатьВопрос(Оповещение, НСтр("ru = 'Для создания взаимодействия необходимо произвести запись заявки. Записать?'; en = 'To create an interaction, you must record the application. To record?'"), РежимДиалогаВопрос.ДаНет);
		Иначе
			ВыборВзаимодействиеЗадачаНаСервере();		
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Выбор взаимодействия на клиенте
//
Процедура ВыборВзаимодействиеЗадачаНаСервере()
	
	Элементы.ДекорацияВзаимодействиеЗадачаИконка.Картинка     = ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Картинка;
	Элементы.ДекорацияВзаимодействиеЗадачаИконка.Видимость    = ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Картинка);
	Элементы.ДекорацияВзаимодействиеЗадачаЗаголовок.Заголовок = ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Представление;
	
	УстановитьВидимостьВсплывающихГруппСервер("ВзаимодействиеЗадача");
	
	ЭтотОбъект.ВзаимодействиеЗадачаТема  = ?(ЗначениеЗаполнено(ВзаимодействиеЗадачаТема) , ВзаимодействиеЗадачаТема	, ЭтотОбъект.ВзаимодействиеЗадачаПараметры.ТемаПоУмолчанию);
	ЭтотОбъект.ВзаимодействиеЗадачаТекст = ?(ЗначениеЗаполнено(ВзаимодействиеЗадачаТекст), ВзаимодействиеЗадачаТекст, "");
	
	// Установить дату взаимодействия.
	ЭтотОбъект.ВзаимодействиеЗадачаДата = ПолучитьОкругленноеВремяВзаимодействия(ЭтотОбъект.ВзаимодействиеЗадачаВыполнена);	
	ВзаимодействиеЗадачаДатаПриИзмененииНаСервере();
	
	// Обновить исполнителя взаимодействия.
	ЭтотОбъект.ВзаимодействиеЗадачаИсполнитель         = Объект.ОсновнойМенеджер;	
	Элементы.ВзаимодействиеЗадачаИсполнитель.Заголовок = ПолучитьПредставлениеФИОСотрудника(Объект.ОсновнойМенеджер);
		
	// Обновить режим напоминания взаимодействия.
	РежимНапоминанияПоУмолчанию = ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминанияСписокВыбора[0];		
	
	ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминания    = РежимНапоминанияПоУмолчанию.Значение;
	Элементы.ВзаимодействиеЗадачаНапоминание.Заголовок = РежимНапоминанияПоУмолчанию.Представление;
	
	ПереместитьЭлементСделкиВзаимодействия("ГруппаВзаимодействиеЗадачаШапка");
	
	АктивныйЭлемент   = ?(ЭтотОбъект.ВзаимодействиеЗадачаВыполнена, Элементы.ГруппаВзаимодействиеЗадачаСтатусВыполнена, Элементы.ГруппаВзаимодействиеЗадачаСтатусНеВыполнена);
	НеактивныйЭлемент = ?(Не ЭтотОбъект.ВзаимодействиеЗадачаВыполнена, Элементы.ГруппаВзаимодействиеЗадачаСтатусВыполнена, Элементы.ГруппаВзаимодействиеЗадачаСтатусНеВыполнена);
	УправлениеИнтерфейсамиСервер.ИзменитьАктивностьПереключателяФормы(АктивныйЭлемент, НеактивныйЭлемент, ЭтотОбъект.ВзаимодействиеЗадачаВыполнена);
	
КонецПроцедуры	

