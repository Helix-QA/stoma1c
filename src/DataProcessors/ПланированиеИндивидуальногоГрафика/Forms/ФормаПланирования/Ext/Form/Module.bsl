// Процедура - Открыть список заверщение Клиент.
// 
// Параметры:
//  Результат	 - 	 -
//  ДопПараметры - 	 -
// 
Процедура ОткрытьСписокСалоновЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбранноеЗначение		= Результат.Значение;
	ОтборСтруктурнаяЕдиница = ВыбранноеЗначение;
	
	Элементы.ОткрытьСписокСалоны.Заголовок = Строка(ВыбранноеЗначение);
	
 	// Получаем массив номеров рабочих дней недели для СЕ	
    ОбновитьМассивРабочихДнейВНеделе();

	ВремяРаботыСтруктурнойЕдиницы = ВернутьВремяРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница);

	ОбновитьОтображениеПланирования(Истина);	

КонецПроцедуры

&НаСервереБезКонтекста
// Функция вернет массив рабочих дней недели СЕ, если выставлен флаг ДобавитьВремяРаботы
// будет возвращен массив структур с рабочим временем
Функция РабочиеДниСтруктурнойЕдиницы(СтруктурнаяЕдиница, ДобавитьВремяРаботы = Истина) 
	
  	  РабочиеДни = Новый Массив;
	  Для Каждого СтрокаТ ИЗ СтруктурнаяЕдиница.РасписаниеРаботы Цикл
		  Если СтрокаТ.Активность = Истина Тогда
			  Если ДобавитьВремяРаботы = Истина Тогда
				  РабочиеДни.Добавить(Новый Структура("ДеньНедели,ДатаНачала,ДатаОкончания", Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели)), СтрокаТ.НачалоРаботы, СтрокаТ.ОкончаниеРаботы));
			  Иначе
				  РабочиеДни.Добавить(Дата(2001, 01, ДеньНедели(СтрокаТ.ДеньНедели)));
			  КонецЕсли;
		  КонецЕсли;
		  // Выходим по достижению 7-й строки(воскресенье, отсекая строку выходного дня)
		  Если  СтруктурнаяЕдиница.РасписаниеРаботы.Индекс(СтрокаТ) = 6 Тогда
			  Прервать;
		  КонецЕсли;	  
	  КонецЦикла;	  
	  
	  Возврат РабочиеДни;	  
  КонецФункции
  
  // Процедура, изменяет график работы сотрудников.
// 
Процедура ЗафиксироватьИзмененияВГрафикеСотрудниковВРегистре(СтруктурнаяЕдиница, БуферФормирования)
	
	БуферФормирования.Сортировать("Сотрудник, Дата, Операция Убыв");
	МассивЗаполнения  = Новый Массив;
	НСтроки 	  	  = 0;
	МассивСотрудников = Новый Массив;
	НачалоПериода 	  = НачалоДня(ТекущаяДатаСеанса());
	КонецПериода  	  = Неопределено;
	
	Пока НСтроки < БуферФормирования.Количество() Цикл
		
		// Подготовка буфера фиксации данных в пределах текущего месяца и текущего сотрудника
		СтрокаБуфера     = БуферФормирования[НСтроки];
		СтрокаБуфераСлед = Неопределено;
		Если НСтроки < БуферФормирования.Количество() - 1 Тогда
			СтрокаБуфераСлед = БуферФормирования[НСтроки + 1];
		КонецЕсли;
		МесяцОтбора  = Дата(Год(СтрокаБуфера.Дата), Месяц(СтрокаБуфера.Дата), 01);
		
		МесяцОтбораСлед = Неопределено;
		Если НСтроки < БуферФормирования.Количество() - 1 Тогда
			МесяцОтбораСлед  = Дата(Год(СтрокаБуфераСлед.Дата), Месяц(СтрокаБуфераСлед.Дата), 01);
		КонецЕсли;

		Если ЗначениеЗаполнено(СтрокаБуфера.Операция) Тогда
			
			МассивЗаполнения.Добавить(СтрокаБуфера);
			
			Если МассивСотрудников.Найти(СтрокаБуфера.Сотрудник) = Неопределено Тогда
				МассивСотрудников.Добавить(СтрокаБуфера.Сотрудник);
			КонецЕсли;
			
			НачалоПериода = ?(НачалоПериода > СтрокаБуфера.Дата, СтрокаБуфера.Дата, НачалоПериода);
			КонецПериода  = ?(Не ЗначениеЗаполнено(КонецПериода) ИЛИ КонецПериода < СтрокаБуфера.Дата, СтрокаБуфера.Дата, КонецПериода);
			
		КонецЕсли;
		
		// Как только текущий сотрудник не совпадает с предыдущим или достигнут предел буфера
		// переходим к операции фиксации набора изменений по пред. сотруднику
		Если (СтрокаБуфераСлед = Неопределено
			ИЛИ СтрокаБуфераСлед.Сотрудник <> СтрокаБуфера.Сотрудник
			ИЛИ МесяцОтбораСлед <> МесяцОтбора)
			И МассивЗаполнения.Количество() > 0 Тогда
			
			// Создаем набор записей для конкретного сотрудника + разрез доп. параметров
			НаборЗаписей = РегистрыСведений.ВремяРаботыСотрудниковПлан.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
			НаборЗаписей.Отбор.МесяцОтбор.Установить(МесяцОтбора);
			НаборЗаписей.Отбор.Сотрудник.Установить(МассивЗаполнения[0].Сотрудник);
			
			НаборЗаписей.Прочитать();
			ВременнаяТаблица = НаборЗаписей.Выгрузить();
			
			Для Каждого ЭлементМ ИЗ МассивЗаполнения Цикл
				
				// Если на строке пометка удаления 
				// находим эти данные во временной таблице и удаляем
				Если ЭлементМ.Операция = "Удалить" Тогда
					// Необходимо пройти по всем интервалам рабочего времени в этот день
					
					Если ЭлементМ.Свойство("ТипРабочегоВремени")
						И (ЭлементМ.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный 
						Или ЭлементМ.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск) Тогда
						
						НайденныеСтроки = ВременнаяТаблица.НайтиСтроки(Новый Структура("ДатаВремяНачала", ЭлементМ.Дата));
						Для Каждого СтрокаН ИЗ НайденныеСтроки Цикл
							ВременнаяТаблица.Удалить(СтрокаН);
						КонецЦикла;

					Иначе
						
						Для Каждого ИнтервалВ ИЗ ЭлементМ.ИнтервалыРаботы Цикл
							ДатаВремяНачала = ЗаменитьВремяВДате(ЭлементМ.Дата,ИнтервалВ.Значение.НачалоРаботы);
							НайденныеСтроки = ВременнаяТаблица.НайтиСтроки(Новый Структура("ДатаВремяНачала", ДатаВремяНачала));
							Для Каждого СтрокаН ИЗ НайденныеСтроки Цикл
								ВременнаяТаблица.Удалить(СтрокаН);
							КонецЦикла;
						КонецЦикла;
						
					КонецЕсли;

					// Добавляем новые записи	
				ИначеЕсли ЭлементМ.Операция = "Создать" Тогда
					
					Если ЭлементМ.Свойство("ТипРабочегоВремени") 
						И (ЭлементМ.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Больничный
						Или ЭлементМ.ТипРабочегоВремени = Перечисления.ТипыРабочегоВремени.Отпуск) Тогда
						
						НоваяСтрока                     = ВременнаяТаблица.Добавить();
						НоваяСтрока.СтруктурнаяЕдиница  = СтруктурнаяЕдиница;
						НоваяСтрока.МесяцОтбор          = МесяцОтбора;
						НоваяСтрока.Сотрудник           = ЭлементМ.Сотрудник;
						НоваяСтрока.ДатаВремяНачала     = ЭлементМ.Дата;
						НоваяСтрока.ДатаВремяОкончания  = ЭлементМ.Дата;
						НоваяСтрока.Минуты              = 0;
						НоваяСтрока.ТипРабочегоВремени  = ЭлементМ.ТипРабочегоВремени;
						
					Иначе
						
						Для Каждого ИнтервалВ ИЗ ЭлементМ.ИнтервалыРаботы Цикл
							НоваяСтрока                     = ВременнаяТаблица.Добавить();
							НоваяСтрока.СтруктурнаяЕдиница  = СтруктурнаяЕдиница;
							НоваяСтрока.МесяцОтбор          = МесяцОтбора;
							НоваяСтрока.Сотрудник           = ЭлементМ.Сотрудник;
							ИнтервалВ.Значение.НачалоРаботы 	= Дата(Год("00010101"), Месяц("00010101"), День("00010101"), Час(ИнтервалВ.Значение.НачалоРаботы), Минута(ИнтервалВ.Значение.НачалоРаботы), Секунда(ИнтервалВ.Значение.НачалоРаботы));
							ИнтервалВ.Значение.ОкончаниеРаботы  = Дата(Год("00010101"), Месяц("00010101"), День("00010101"), Час(ИнтервалВ.Значение.ОкончаниеРаботы), Минута(ИнтервалВ.Значение.ОкончаниеРаботы), Секунда(ИнтервалВ.Значение.ОкончаниеРаботы));
							НоваяСтрока.ДатаВремяНачала     = ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ЭлементМ.Дата, ИнтервалВ.Значение.НачалоРаботы); 
							НоваяСтрока.ДатаВремяОкончания  = ОбщегоНазначенияСтоматология.СложитьДатуИВремя(ЭлементМ.Дата, ИнтервалВ.Значение.ОкончаниеРаботы); 
							НоваяСтрока.Минуты              = (НоваяСтрока.ДатаВремяОкончания - НоваяСтрока.ДатаВремяНачала) / 60;
							НоваяСтрока.ТипРабочегоВремени  = Перечисления.ТипыРабочегоВремени.Рабочее;  // Перечисление есть, но в регистре ещё нет
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЦикла;
			
			НаборЗаписей.Загрузить(ВременнаяТаблица);
			НаборЗаписей.Записать(Истина);
			
			МассивЗаполнения.Очистить();
			
		КонецЕсли;
		
		НСтроки = НСтроки + 1;
	КонецЦикла;
	
	// Если операция фиксации изменений прошла успешно, то очищаем пометки операций
	НСтроки = 0;
	Пока НСтроки < БуферФормирования.Количество() Цикл
		Если БуферФормирования[НСтроки].Операция = "Удалить" Тогда
			БуферФормирования.Удалить(БуферФормирования[НСтроки]);
			Продолжить;
		КонецЕсли;
		БуферФормирования[НСтроки].Операция             = Неопределено;
		БуферФормирования[НСтроки].НомерОчередиОперации = Неопределено;
		
		НСтроки = НСтроки + 1;
	КонецЦикла;
	
	РегистрыСведений.СвободныеИнтервалыСотрудников.СформироватьИнтервалыПоСотрудникам(СтруктурнаяЕдиница, МассивСотрудников, НачалоПериода, КонецДня(КонецПериода));
	
КонецПроцедуры

// Функция, изменяет время в дате.
// 
Функция ЗаменитьВремяВДате(Дата, ВрямяНов)
	
	Возврат НачалоДня(Дата) + ?(ВрямяНов <> Дата(0001,01,02,00,00,00), ВрямяНов - НачалоДня(ВрямяНов), 86400); 	
	
КонецФункции


#КонецОбласти
