		СтрокаТЧ.ДатаВыполнения = Неопределено;
	ИначеЕсли СтрокаТЧ.Статус = ПредопределенноеЗначение("Перечисление.СтатусыНарядЗаказа.Выполнено") Тогда
		СтрокаТЧ.ДатаЗаказа = ?(ЗначениеЗаполнено(СтрокаТЧ.ДатаЗаказа),СтрокаТЧ.ДатаЗаказа, ТекущаяДата());
		СтрокаТЧ.ДатаВыполнения = ?(ЗначениеЗаполнено(СтрокаТЧ.ДатаВыполнения),СтрокаТЧ.ДатаВыполнения, ТекущаяДата());
