				ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеобходимоУдалитьЧленствоПакетУслугИзДокумента"	, Истина);			
				ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЭтоВосстановлениеПоследовательности"				, Истина);
				ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЧленствоПакетУслугПоследовательности"			, ПараметрыЗадания.ЧленствоПакетУслуг);
				ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПроведениеДокументовВФоне"		, Истина);
				ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеАктуализироватьСтатус"							, Истина);
