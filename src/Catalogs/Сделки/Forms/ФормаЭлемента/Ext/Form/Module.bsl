							ЭтаФорма, , , ,
							Новый ОписаниеОповещения("ПослеВыборкаКонтрагентаДубля", ЭтотОбъект, МассивКлиентов));
		Иначе
			// НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(МассивКлиентов[0]);
			// ПерейтиПоНавигационнойСсылке(НавигационнаяСсылка);
			ПослеВыборкаКонтрагентаДубля(МассивКлиентов[0], МассивКлиентов)
		КонецЕсли;                                            		
	Иначе
		ПредупреждениеДублирование = Истина;
	КонецЕсли; 
	
КонецПроцедуры
 
&НаКлиенте
// Процедура - После выборка контрагента дубля
//
// Параметры:
//  РезультатВыбора			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПослеВыборкаКонтрагентаДубля(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) И ЗначениеЗаполнено(ДополнительныеПараметры) И ТипЗнч(ДополнительныеПараметры) = Тип("Массив") И ДополнительныеПараметры.Найти(РезультатВыбора) <> Неопределено Тогда 
		Объект.Контрагент = РезультатВыбора;
		ОбновитьДанныеПоКлиенту();
	Иначе 
		ПредупреждениеДублирование = Ложь;
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ИсторияВзаимодействияСКлиентом

&НаСервере
// Процедура - Обновить историю взаимодействия с клиентом.
//
// Параметры:
//  РежимПодробно	 - 	 -
//  ВыводитьВсе		 - 	 -
//
Процедура ОбновитьИсториюВзаимодействияСКлиентом(Фильтры = Неопределено, РежимПодробно = Ложь, ВыводитьВсе = Ложь)
	
	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Возврат;
	КонецЕсли;	
	
	УстановитьПривилегированныйРежим(Истина);
	
	Фильтры = Новый Структура;
		 
	ОбщегоНазначенияКлиентСерверСтоматология.ЗаполнитьСтруктуруФильтрациИсторииВзаимодйствия(СписокФильтрацииИсторииВзаимодействия, Фильтры);
	
	ПараметрыДанных = Новый Структура;
	ПараметрыДанных.Вставить("Сделка"	         		, Объект.Ссылка);	
	ПараметрыДанных.Вставить("Контрагент"         		, Объект.Контрагент);
	ПараметрыДанных.Вставить("СтатусКлиента"      		, ЭтотОбъект.СтатусКонтрагента);
	СтруктураДатПациента = ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Объект.Контрагент, "ДатаРожденияКлиента, ДатаРегистрации");
	ПараметрыДанных.Вставить("ДатаРожденияКлиента"		, СтруктураДатПациента.ДатаРожденияКлиента);
	ПараметрыДанных.Вставить("ДатаРегистрацииКлиента"	, СтруктураДатПациента.ДатаРегистрации); 
	ПараметрыДанных.Вставить("СделкаДатаНачала"			, Объект.ДатаСделки);
	ПараметрыДанных.Вставить("СделкаДатаОкончания"		, ?(ЗначениеЗаполнено(Объект.ДатаЗавершенияСделки), Объект.ДатаЗавершенияСделки, ТекущаяДатаСеанса()));
    ПараметрыДанных.Вставить("ВходящийНомерТелефона"	, Объект.ВходящийНомерТелефона);  
	
	ТаблицаИсторииВзаимодействий = Справочники.Контрагенты.ПолучитьИсториюВзаимодействияКлиента(ПараметрыДанных, Истина, Фильтры);
	
	ЭтотОбъект.ИсторияВзаимодействий.Загрузить(ТаблицаИсторииВзаимодействий);
	
	ТекстHTML = УправлениеИнтерфейсамиСервер.СформироватьИсториюВзаимодействий(ЭтаФорма, ПараметрыДанных, Истина, ВыводитьВсе);
	ЭтотОбъект.ИсторияВзаимодействия = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(ТекстHTML);
	
КонецПроцедуры

#Область ОбработчикиСобытийИсторииВзаимодействия

&НаКлиенте
// Процедура, обработчик события "ПриНажатии" поля формы "ИсторияВзаимодействия".
//
Процедура ИсторияВзаимодействияПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	ЭлементHTML 		= ДанныеСобытия.Element; 
	ДанныеСсылкиHTML 	= ДанныеСобытия.Anchor;
	Документ 			= Элемент.Документ;
	
	Попытка 
		
		Если ДанныеСсылкиHTML = Неопределено Тогда 				// Нажали в пустое место.	
			Возврат;	
		ИначеЕсли ДанныеСсылкиHTML.name = "more" Тогда
			
			СтандартнаяОбработка = Ложь;						
			
			Фильтры = Новый Структура();
			Фильтры.Вставить("Прием"      , ПолучитьЗначениеФильтра("Прием")); 	
			Фильтры.Вставить("SMS"        , ПолучитьЗначениеФильтра("SMS"));
			Фильтры.Вставить("Письмо"     , ПолучитьЗначениеФильтра("Письмо"));
			Фильтры.Вставить("ПланЛечения", ПолучитьЗначениеФильтра("ПланЛечения"));
			Фильтры.Вставить("Событие"    , ПолучитьЗначениеФильтра("Событие"));	
			Фильтры.Вставить("Заметка"    , ПолучитьЗначениеФильтра("Заметка"));	
			Фильтры.Вставить("Задача"    , ПолучитьЗначениеФильтра("Задача"));	
			
			Если ВсеФильтрыОтключены(Фильтры) Тогда
				Фильтры = Новый Структура();
			КонецЕсли;
			
			ОбновитьИсториюВзаимодействияСКлиентом(Фильтры, Истина, Истина);
			
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "note") Тогда  // редактировать заметку
			
			СтандартнаяОбработка = Ложь;
			
			СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ДанныеСсылкиHTML.id);
			
			Если РольДоступнаКлиентСервер("ПолныеПрава")
				ИЛИ РольДоступнаКлиентСервер("ДобавлениеИзменениеКлиентов") Тогда
				
				МассивЭлементовHTML = ДанныеСсылкиHTML.getElementsByClassName("text-message");
				
				Если МассивЭлементовHTML.length > 0 Тогда
					РедактироватьЗаметку(МассивЭлементовHTML[0], СтрокаТЗ.Заметка, СтрокаТЗ);
				КонецЕсли;
				
			КонецЕсли; 
			
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "call_comment") Тогда // редактировать коментарий звонка
			
			СтандартнаяОбработка = Ложь;
			
			МассивЭлементовHTML = ДанныеСсылкиHTML.getElementsByClassName("text-message");
			
			Если МассивЭлементовHTML.length > 0 Тогда
				РедактироватьЗаметкуЗвонок(МассивЭлементовHTML[0],  ДанныеСсылкиHTML.id);
			КонецЕсли;
		
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "profs") Тогда  // редактировать профосмотр.		
			
			СтандартнаяОбработка = Ложь;
			
			РедактироватьПрофосмотр(ДанныеСсылкиHTML);
		ИначеЕсли СтрНайти(ЭлементHTML.className, "listen_call") Тогда // прослущать звонок
			
			СтандартнаяОбработка = Ложь;
			
			СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ЭлементHTML.id);
			Сообщение = "";
			
			ДанныеВызова = ПолучитьДанныеИсторииВызова(СтрокаТЗ.Взаимодействие, Сообщение);
			
			Если Не ЗначениеЗаполнено(ДанныеВызова) Тогда 
				Если ЗначениеЗаполнено(Сообщение) Тогда 
					ПоказатьПредупреждение(,Сообщение);
				КонецЕсли;
				Возврат;
			ИначеЕсли ЗначениеЗаполнено(ДанныеВызова.ФайлЗаписи) Тогда					
				СсылкаНаФайл = ПолучитьСсылкуПоУид(ДанныеВызова.ФайлЗаписи.УникальныйИдентификатор(), ЭлементHTML.name);
				
				ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(СсылкаНаФайл);
				
				РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
				
			ИначеЕсли ЗначениеЗаполнено(ДанныеВызова.URLЗаписи) Тогда
				АктуальныйURLЗаписи = IPТелефонияКлиент.ПолучитьАктуальныйURLЗаписиROSTELECOMКлиент(ДанныеВызова.URLЗаписи, ДанныеВызова.IDЗвонка, ДанныеВызова.ОборудованиеТелефонии);
				НачатьЗапускПриложения(Новый ОписаниеОповещения("ПослеЗапускаПриложения", ЭтотОбъект), АктуальныйURLЗаписи);
			Иначе
				Возврат;
			КонецЕсли;
			
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "open_dialog") Тогда  // Открыть диалог.
			
			СтандартнаяОбработка = Ложь;
			
			ИдКлиента 			= Лев(ДанныеСсылкиHTML.id, СтрНайти(ДанныеСсылкиHTML.id, "_") - 1);	
			UidВнешнейСистемы 	= Сред(ДанныеСсылкиHTML.id, СтрНайти(ДанныеСсылкиHTML.id, "_") + 1, СтрДлина(ДанныеСсылкиHTML.id));
			
			ПерейтиВЧат(ИдКлиента, UidВнешнейСистемы);
			
		ИначеЕсли СтрНайти(ЭлементHTML.className, "task") > 0 Тогда 
			Ссылка = ПолучитьСсылкуНаЗадачуПоУид(Новый УникальныйИдентификатор(ЭлементHTML.id));
			ОбновитьФорму = ОтметитьЗадачуКакВыполненую(Ссылка);
			Если ОбновитьФорму Тогда
				УстановитьФильтрИсторииВзаимодействияНаСервере();	
			КонецЕсли;
		ИначеЕсли СтрНайти(ДанныеСсылкиHTML.name, "clip") Тогда // закрепить/открепить
			
			СтандартнаяОбработка = Ложь;
			
			СтрокаТЗ = ЭтотОбъект.ИсторияВзаимодействий.НайтиПоИдентификатору(ДанныеСсылкиHTML.id);
			
			ЗакрепитьОткрепитьЗаметку(СтрокаТЗ.ИДЗаметки, СтрНайти(ДанныеСсылкиHTML.name, "off"));
			ОбновитьИсториюВзаимодействияСКлиентом();
	
		ИначеЕсли ЗначениеЗаполнено(ДанныеСобытия.Href) Тогда
			
			СтандартнаяОбработка = Ложь;
			ПерейтиПоНавигационнойСсылке(ДанныеСобытия.Href);
			
		Иначе
			СтандартнаяОбработка = Ложь;
		КонецЕсли;
		
		Элемент.Доступность = Истина;
		
	Исключение
		
	КонецПопытки;
	
КонецПроцедуры

