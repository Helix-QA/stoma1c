// Процедура, СоздатьСделкуИзСписка.
//
Процедура СоздатьСделкуИзСписка(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	ИначеЕсли ТипЗнч(Результат.Значение) = Тип("СправочникСсылка.ВидыСделок") Тогда
		
		Если Объект.Ссылка.Пустая() Тогда
			
			Оповещение = Новый ОписаниеОповещения("СоздатьСделкуИзСпискаПослеВопросаОЗаписиКлиента", ЭтотОбъект, Новый Структура("ВидСделки", Результат.Значение));
			ПоказатьВопрос(Оповещение, НСтр("ru='Для создания сделки необходимо произвести запись нового клиента. Записать?';en='For create deals is necessary toproduce record new client. WriteDown?'"), РежимДиалогаВопрос.ДаНет);
			
		Иначе
			СоздатьСделку(Объект.Ссылка, Результат.Значение); 			
		КонецЕсли;
				
	КонецЕсли;
	
КонецПроцедуры

