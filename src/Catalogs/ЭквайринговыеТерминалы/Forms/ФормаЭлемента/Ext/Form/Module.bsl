// Процедура - Сгенерировать ссылку
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура СгенерироватьСсылку(Команда)
	
	ПараметрыПШ = Новый Структура;
	ПараметрыПШ.Вставить("КлючТерминалаТинькофф", ЭтотОбъект.КлючТерминалаТинькофф);
	ПараметрыПШ.Вставить("СекретныйКлючТинькофф", ЭтотОбъект.СекретныйКлючТинькофф);
	ПараметрыПШ.Вставить("ВремяЖизни"			, ЭтотОбъект.ВремяЖизниСсылкиНаОплату);
	ПараметрыПШ.Вставить("ТестовыйРежим"		, Ложь);
	
	РезультатЗапроса = СсылкиНаОплатуИСБП.Тинькофф_ИнициализацияПлатежнойСессии(ПараметрыПШ, 10);
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		ЭтотОбъект.СсылкаНаОплатуТинькофф = РезультатЗапроса.ПараметрыРезультата.PaymentURL;
	Иначе
		ОписаниеОшибки = ?(ЗначениеЗаполнено(РезультатЗапроса.ОписаниеОшибки), РезультатЗапроса.ОписаниеОшибки, "Ошибка при генерации ссылки"); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
	КонецЕсли;
	
КонецПроцедуры

