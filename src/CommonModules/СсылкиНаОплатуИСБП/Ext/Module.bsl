#Область Апекс

// Функция, формирует ссылку на оплату основание и возвращает её. 
//
Функция СформироватьСсылкуОплатыАпекс(СтруктураПараметров)	
	
	// http://docs.paygateway.ru/pages/viewpage.action?pageId=21332167#id-%D0%9C%D0%95%D0%A0%D0%A7%D0%90%D0%9D%D0%A2-%D0%98%D0%9D%D0%A2%D0%95%D0%A0%D0%A4%D0%95%D0%99%D0%A1%D0%B4%D0%BB%D1%8F%D0%B2%D0%BD%D0%B5%D1%88%D0%BD%D0%B8%D1%85%D0%BC%D0%B0%D0%B3%D0%B0%D0%B7%D0%B8%D0%BD%D0%BE%D0%B2-%D0%97%D0%B0%D0%BF%D1%80%D0%BE%D1%81%D0%BD%D0%B0%D0%B2%D1%8B%D1%81%D1%82%D0%B0%D0%B2%D0%BB%D0%B5%D0%BD%D0%B8%D0%B5%D1%81%D1%87%D1%91%D1%82%D0%B0%D0%BF%D0%BB%D0%B0%D1%82%D0%B5%D0%BB%D1%8C%D1%89%D0%B8%D0%BA%D1%83%D0%BF%D0%BE%D1%8D%D0%BB%D0%B5%D0%BA%D1%82%D1%80%D0%BE%D0%BD%D0%BD%D0%BE%D0%B9%D0%BF%D0%BE%D1%87%D1%82%D0%B5/SMS	
		
	СтруктураВозврата		= СтруктураПараметров.СтруктураВозврата; 
    ПараметрыПШ				= СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 			= СтруктураПараметров.СуммаОплаты;
	ТаблицаЗадолженностей	= СтруктураПараметров.ТаблицаЗадолженностей;
	
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") Или Не ЗначениеЗаполнено(ПараметрыПШ.ЛицевойСчетАпекс)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.СекретныйКлюч1Апекс) Или Не ЗначениеЗаполнено(ПараметрыПШ.СекретныйКлюч2Апекс) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры эквайрингового терминала.";
		Возврат СтруктураВозврата;
		
	КонецЕсли;	
   
	СтруктураДанных = СформироватьСтруктуруДанных(СтруктураПараметров);

	ОписаниеОшибки = "";
	Ответ = ВызовМетода(СтруктураДанных, ПараметрыПШ, ОписаниеОшибки); 

	Если Ответ = Неопределено Или ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке ссылки на оплату в Апекс. " + ОписаниеОшибки;	
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	
	Если ТипЗнч(Ответ) <> Тип("Соответствие") Или Ответ["status"] = Неопределено Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не верный ответ.";
		Возврат СтруктураВозврата;
		
	КонецЕсли;	
		
	status = Ответ["status"];
	
	Если status = "error" Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке ссылки на оплату в Апекс. " + Ответ["errorcode"] + " " + Ответ["errortext"];
		Возврат СтруктураВозврата;

	КонецЕсли;

	КороткаяСсылкаНаОплату = Ответ["payURL"]; 
	Если Не ЗначениеЗаполнено(КороткаяСсылкаНаОплату) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не передана ссылка на оплату.";
		Возврат СтруктураВозврата;

	КонецЕсли;
	
	СтруктураВозврата.СсылкаНаОплату = КороткаяСсылкаНаОплату;
	СтруктураВозврата.ВыполненоУспешно = Истина;
	
	НомерЗаказа = Число(Ответ["transID"]);
	
	Для Каждого СтрокаТ Из ТаблицаЗадолженностей Цикл
		
	РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаТ.ДокументЗадолженности, 
		СтрокаТ.Задолженность, 
		Ответ["number"], 
		КороткаяСсылкаНаОплату, 
		Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
		СтруктураПараметров.ЭквайринговыйТерминал, 
		НомерЗаказа,
		,
		Не ЗначениеЗаполнено(СтрокаТ.ДокументЗадолженности),
		СтруктураПараметров.Контрагент,,
		СтруктураПараметров.СтруктурнаяЕдиница,
		ТекущаяДатаСеанса(),
		"Заказ зарегистрирован, но не оплачен",
		Перечисления.ТипыСсылокНаОплату.Апекс);
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Сформировать структуру данных
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
