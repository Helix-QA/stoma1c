			Имя 			   	= СокрЛП(СтрокаТаблицыКлиенты.Имя);
			Отчество 		   	= СокрЛП(СтрокаТаблицыКлиенты.Отчество);
			Фамилия 		  	= ВРег(Сред(Фамилия, 1, 1)) + НРег(Сред(Фамилия, 2));
			Имя 			   	= ВРег(Сред(Имя, 1, 1)) + НРег(Сред(Имя, 2));
			Отчество 		   	= ВРег(Сред(Отчество, 1, 1)) + НРег(Сред(Отчество, 2));		
			Наименование 		= Фамилия + " " + Имя + " " + Отчество;
			Наименование 	   	= СокрЛП(Наименование);
			НаименованиеПолное 	= СокрЛП(Наименование);			
		Иначе
			Фамилия 		   	= СокрЛП(СтрокаТаблицыКлиенты.Фамилия);
			Имя  			   	= СокрЛП(СтрокаТаблицыКлиенты.Имя);
			Отчество 		   	= СокрЛП(СтрокаТаблицыКлиенты.Отчество);
			Наименование 		= Фамилия + " " + Имя + " " + Отчество;
			Наименование      	= СокрЛП(Наименование);
			НаименованиеПолное 	= СокрЛП(Наименование);
		КонецЕсли;
		
		// Определим пол клиента
		Если СтрокаТаблицыКлиенты.ПолКлиента = 0 Тогда
			Пол = МужскойПол;
		Иначе
			Пол = ЖенскийПол;
		КонецЕсли;
		
		ЭлементСоздан = Ложь;	
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицыКлиенты.КлиентСсылка) Тогда 	
			// Создадим нового клиента
			Клиент 						= Справочники.Контрагенты.СоздатьЭлемент();
			Клиент.УстановитьНовыйКод();
			ЭлементСоздан 				= Истина;			
		Иначе 
			Клиент 						= СтрокаТаблицыКлиенты.КлиентСсылка.ПолучитьОбъект();
		КонецЕсли;	
		Клиент.Родитель 				= ?(ЗначениеЗаполнено(Клиент.Родитель), Клиент.Родитель, ПараметрыЗадания.ПараметрыЗагрузки.ВыборПапкиСправочника); 
		Клиент.Наименование 			= Наименование;
		Клиент.НаименованиеПолное 		= Наименование;
		Клиент.Комментарий 				= СтрокаТаблицыКлиенты.НомерАнкеты;
		Клиент.КодСинхронизации 		= СтрокаТаблицыКлиенты.КодСинхронизации;
		Клиент.Фамилия 					= Фамилия;
		Клиент.Имя 						= Имя;
		Клиент.Отчество 				= Отчество;
		Клиент.ПолКлиента 				= Пол;
		Клиент.ЮрФизЛицо 				= ФизЛицо;
		Клиент.ТипКонтрагента 			= ТипКонтрагента_Клиенты;
		Клиент.СтруктурнаяЕдиница 		= ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
		Клиент.ДатаРожденияКлиента 		= ?(ЗначениеЗаполнено(Клиент.ДатаРожденияКлиента), Клиент.ДатаРожденияКлиента, ДатаРождения);
		
		//// Замечания
		// Замечание = СокрЛП(СтрокаТаблицыКлиенты.Комментарий);
		// Если Замечание <> "" Тогда
		//	ЗаметкаКлиента = Клиент.Заметки.Найти(Замечание, "Заметка");
		//	Если ЗаметкаКлиента = Неопределено Тогда
		//		Заметка 			= Клиент.Заметки.Добавить();
		//		Заметка.Автор 		= ТекущийПользовательСеанса;
		//		Заметка.Активность 	= Истина;
		//		Заметка.Дата 		= ТекущаяДатаСеанса();
		//		Заметка.Заметка 	= Замечание;
		//	КонецЕсли;
		// КонецЕсли;			
		
		// Замечания
		Тег_Гость_СПА_СтрокаТЧ 			= Клиент.Теги.Найти(Тег_Гость_СПА, "Тег");
		Если Тег_Гость_СПА_СтрокаТЧ = Неопределено Тогда
			Тег_Гость_СПА_СтрокаТЧ 		= Клиент.Теги.Добавить();
			Тег_Гость_СПА_СтрокаТЧ.Тег 	= Тег_Гость_СПА;
		КонецЕсли;
		
		// ТЕЛЕФОН КЛИЕНТА моб.
		Если СокрЛП(СтрокаТаблицыКлиенты.ТелефонМобильный) <> "" Тогда
			Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(СокрЛП(СтрокаТаблицыКлиенты.ТелефонМобильный), ТипыКИ_Телефон);
			Если ЗначениеЗаполнено(Объект_XDTO_Телефон.Состав.Номер) Тогда 
				СтрокаТелефон = Клиент.КонтактнаяИнформация.Найти(Объект_XDTO_Телефон.Состав.Номер, "НомерТелефонаБезКодов");
				Если СтрокаТелефон = Неопределено Тогда			
					НоваяСтрока = Клиент.КонтактнаяИнформация.Добавить();
					НоваяСтрока.Тип 					= ТипыКИ_Телефон;
					НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
					НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
					НоваяСтрока.Представление 			= Объект_XDTO_Телефон.Представление;
					Объект_XDTO_Телефон.Комментарий 	= "мобильный";
					НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
					НоваяСтрока.Вид 					= ВидКИ_ТелефонКлиента;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
		
		// ТЕЛЕФОН КЛИЕНТА раб.
		Если СокрЛП(СтрокаТаблицыКлиенты.ТелефонРабочий) <> "" Тогда
			Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(СокрЛП(СтрокаТаблицыКлиенты.ТелефонРабочий), ТипыКИ_Телефон);
			Если ЗначениеЗаполнено(Объект_XDTO_Телефон.Состав.Номер) Тогда 
				СтрокаТелефон = Клиент.КонтактнаяИнформация.Найти(Объект_XDTO_Телефон.Состав.Номер, "НомерТелефонаБезКодов");
				Если СтрокаТелефон = Неопределено Тогда			
					НоваяСтрока = Клиент.КонтактнаяИнформация.Добавить();
					НоваяСтрока.Тип 					= ТипыКИ_Телефон;
					НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
					НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
					НоваяСтрока.Представление 			= Объект_XDTO_Телефон.Представление;
					Объект_XDTO_Телефон.Комментарий 	= "рабочий";
					НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
					НоваяСтрока.Вид 					= ВидКИ_ТелефонКлиента;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
		
		// ТЕЛЕФОН КЛИЕНТА дом.
		Если СокрЛП(СтрокаТаблицыКлиенты.ТелефонДомашний) <> "" Тогда
			Объект_XDTO_Телефон = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(СокрЛП(СтрокаТаблицыКлиенты.ТелефонДомашний), ТипыКИ_Телефон);
			Если ЗначениеЗаполнено(Объект_XDTO_Телефон.Состав.Номер) Тогда 
				СтрокаТелефон = Клиент.КонтактнаяИнформация.Найти(Объект_XDTO_Телефон.Состав.Номер, "НомерТелефонаБезКодов");
				Если СтрокаТелефон = Неопределено Тогда			
					НоваяСтрока = Клиент.КонтактнаяИнформация.Добавить();
					НоваяСтрока.Тип 					= ТипыКИ_Телефон;
					НоваяСтрока.НомерТелефона 			= СокрЛП(Объект_XDTO_Телефон.Состав.КодСтраны) + СокрЛП(Объект_XDTO_Телефон.Состав.КодГорода) + СокрЛП(Объект_XDTO_Телефон.Состав.Номер);
					НоваяСтрока.НомерТелефонаБезКодов 	= Объект_XDTO_Телефон.Состав.Номер;
					НоваяСтрока.Представление 			= Объект_XDTO_Телефон.Представление;
					Объект_XDTO_Телефон.Комментарий 	= "домашний";
					НоваяСтрока.ЗначенияПолей 			= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Телефон);
					НоваяСтрока.Вид 					= ВидКИ_ТелефонКлиента;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
				
		// EMAIL КЛИЕНТА
		Email = СтрокаТаблицыКлиенты.Email;
		Если СокрЛП(Email) <> "" Тогда
			Объект_XDTO_Email = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOПоПредставлению(Email, ТипыКИ_АдресЭлектроннойПочты);
			СтрокаEmail = Клиент.КонтактнаяИнформация.Найти(СокрЛП(Email), "Представление");
			Если СтрокаEmail = Неопределено Тогда		
				НоваяСтрока 				= Клиент.КонтактнаяИнформация.Добавить();
				НоваяСтрока.Тип 			= ТипыКИ_АдресЭлектроннойПочты;
				НоваяСтрока.Вид 			= ВидКИ_EmailКлиента;
				НоваяСтрока.АдресЭП 		= Объект_XDTO_Email.Представление;
				НоваяСтрока.Представление 	= НоваяСтрока.АдресЭП;
				НоваяСтрока.ЗначенияПолей	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияXDTOВXML(Объект_XDTO_Email);
			КонецЕсли;
		КонецЕсли;
		
		Клиент.ДополнительныеСвойства.Вставить("ЗаписатьКонтрагентаБезЗапускаБП", Истина);
		Клиент.ОбменДанными.Загрузка = Истина;	
		Попытка
			Клиент.Записать();
		Исключение
			// Запись в лог						
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Ошибка при записи клиента! Код синхронизации: ';en='Mistake at records client! Code sync: '") + Строка(СтрокаТаблицыКлиенты.КодСинхронизации) + Символы.ПС + ОписаниеОшибки());						
		КонецПопытки;	
		// Накапливаем статисические данные и оповещаем клиент
		ЗаписаноКлиентов 				= ЗаписаноКлиентов + 1;
		ПредставлениеКлиента			= Строка(Клиент.Ссылка);
		Прогресс 						= Цел(100 * ЗаписаноКлиентов / ОбщееКоличествоКлиентов);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по клиентам...';en='Saving data by to clients...'") + Символы.Таб + НСтр("ru= ' Осталось: ';en= ' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКлиента, ОсталосьВремени, ПредставлениеОставшегосяВремени));
	КонецЦикла;	
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда				
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;	

	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	Основная_Таблица_Клиентов.Очистить(); 		Основная_Таблица_Клиентов 		= Неопределено;
	
КонецПроцедуры

// Процедура - Загрузить номенклатуру в фоне
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗагрузитьНоменклатуруВФонеFirebird(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Кешируем данные
	ТипНоменклатуры_Услуга 						= Перечисления.ТипыНоменклатуры.Услуга;
	ТипНоменклатуры_Запас 						= Перечисления.ТипыНоменклатуры.Запас;
	ТипНоменклатуры_МодификаторЧленствПакетов	= Перечисления.ТипыНоменклатуры.МодификаторЧленствПакетов;
	ВидыУслуг_ПрочиеУслуги 						= Неопределено;
	ВидЧленствПакетовУслуг_ОграниченПосещениями = Неопределено;	
	Периодичность_День 							= Перечисления.Периодичность.День;
	Периодичность_Месяц							= Перечисления.Периодичность.Месяц;
	ТипыОграничений_ОграниченПериодом 			= Перечисления.ТипыОграниченийЧленствПакетовУслуг.СрокОграниченПериодом;
	ТипыОграничений_АктивироватьПриПосещении	= Перечисления.ТипыОграниченийЧленствПакетовУслуг.АктивироватьПриПосещении;	
	ДатаУстановкиЦены 							= Дата('20010101000000');
	ВидЦены_Закупочная 							= Справочники.ВидыЦен.Закупочная;	
	ВидЦены_Розничная 							= Справочники.ВидыЦен.Розничная;
	ПустаяУпаковкаНоменклатуры 					= Справочники.УпаковкиНоменклатуры.ПустаяСсылка();
	ЕдиницИзмерения_шт 							= Справочники.КлассификаторЕдиницИзмерения.шт;	
	ТекущийПользовательСеанса 					= ПараметрыСеанса.ТекущийПользователь;		
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Групп_Номенклатуры	 				= ПараметрыЗадания.СписокТаблиц[0].Значение.Таблица_Групп_Номенклатуры;	
	Таблица_Номенклатуры 						= ПараметрыЗадания.СписокТаблиц[1].Значение.Таблица_Номенклатуры;
	Таблица_Калькуляций 						= ПараметрыЗадания.СписокТаблиц[2].Значение.Таблица_Калькуляций;	
	// Таблица_Номенклатуры_Контракты 				= ПараметрыЗадания.СписокТаблиц[1].Значение.Таблица_Номенклатуры_Контракты;
	
	// 1. Номенклатура (кроме членств)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Номенклатуры			, "Таблица_Номенклатуры");
	Запрос.Текст = "ВЫБРАТЬ
	               |	УпаковкиНоменклатуры.Ссылка КАК Ссылка,
	               |	УпаковкиНоменклатуры.Владелец КАК Владелец,
	               |	УпаковкиНоменклатуры.Коэффициент КАК Коэффициент,
	               |	Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	               |ИЗ
	               |	Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	               |		ПО УпаковкиНоменклатуры.Владелец = Номенклатура.Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Номенклатура.Ссылка КАК Ссылка,
	               |	Номенклатура.Родитель КАК Родитель,
	               |	Номенклатура.Наименование КАК Наименование,
	               |	Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	Номенклатура.ЭтоГруппа = ИСТИНА
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СтатусыНоменклатурыСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	СтатусыНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	               |	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже,
	               |	СтатусыНоменклатурыСрезПоследних.Период КАК Период
	               |ИЗ
	               |	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&ДатаСреза, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СтатусыНоменклатурыСрезПоследних.Период,
	               |	СтатусыНоменклатурыСрезПоследних.ВПродаже,
	               |	СтатусыНоменклатурыСрезПоследних.Номенклатура,
	               |	СтатусыНоменклатурыСрезПоследних.СтруктурнаяЕдиница
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	КлассификаторЕдиницИзмерения.Ссылка КАК Ссылка,
	               |	КлассификаторЕдиницИзмерения.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Номенклатуры.КодСинхронизации КАК КодСинхронизации,
	               |	Таблица_Номенклатуры.ИДНоменклатуры КАК ИДНоменклатуры,
	               |	Таблица_Номенклатуры.Наименование КАК Наименование,
	               |	Таблица_Номенклатуры.Активно КАК Активно,
	               |	Таблица_Номенклатуры.ТипНоменклатуры КАК ТипНоменклатуры,
	               |	ВЫБОР
	               |		КОГДА Таблица_Номенклатуры.ТипНоменклатуры = 1
	               |			ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	               |		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	               |	КОНЕЦ КАК ТипНоменклатурыПеречисление,
	               |	Таблица_Номенклатуры.ИДГруппы КАК ИДГруппы,
	               |	Таблица_Номенклатуры.НаименованиеГруппы КАК НаименованиеГруппы,
	               |	Таблица_Номенклатуры.ТипГруппы КАК ТипГруппы,
	               |	Таблица_Номенклатуры.ИДРодительскойГруппы КАК ИДРодительскойГруппы,
	               |	Таблица_Номенклатуры.Артикул КАК Артикул,
	               |	Таблица_Номенклатуры.КритическийОстаток КАК КритическийОстаток,
	               |	Таблица_Номенклатуры.Количество КАК Количество,
	               |	Таблица_Номенклатуры.ЕдИзм КАК ЕдИзм,
	               |	Таблица_Номенклатуры.Себестоимость КАК Себестоимость,
	               |	Таблица_Номенклатуры.Цена1 КАК Цена1,
	               |	Таблица_Номенклатуры.Цена2 КАК Цена2,
	               |	Таблица_Номенклатуры.Цена3 КАК Цена3,
	               |	Таблица_Номенклатуры.ПродолжительностьУслугиМин КАК ПродолжительностьУслугиМин,
	               |	Таблица_Номенклатуры.Штрихкод КАК Штрихкод,
	               |	Таблица_Номенклатуры.Комментарий КАК Комментарий,
	               |	ЕСТЬNULL(СправочникНоменклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураСсылка
	               |ИЗ
	               |	Таблица_Номенклатуры КАК Таблица_Номенклатуры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	               |		ПО Таблица_Номенклатуры.КодСинхронизации = СправочникНоменклатура.КодСинхронизации
	               |			И (Таблица_Номенклатуры.КодСинхронизации > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	КодСинхронизации";
	
	Запрос.УстановитьПараметр("ДатаСреза"			, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница);
	
	РезультатПакетаЗапросов 					= Запрос.ВыполнитьПакет();
	ТаблицаУпаковокВБазе 						= РезультатПакетаЗапросов[0].Выгрузить();	
	ТаблицаГруппНоменклатурыВБазе 				= РезультатПакетаЗапросов[1].Выгрузить();
	ТаблицаСтатусовНоменклатуры					= РезультатПакетаЗапросов[2].Выгрузить();
	ТаблицаКлассификаторовЕдиницИзмеренияВБазе 	= РезультатПакетаЗапросов[3].Выгрузить();
	Основная_Таблица_Номенклатуры				= РезультатПакетаЗапросов[4].Выгрузить();
	      
	// Уничтожаем временную Таблицу
	Запрос.МенеджерВременныхТаблиц.Закрыть();	
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые группы и ед. измерения...", 0, ""));
	
	#Область Создание_предварительных_данных
	
	// Создаем необходимые группы
	ТаблицаГрупп = Основная_Таблица_Номенклатуры.Скопировать( , "ИДГруппы, НаименованиеГруппы, ТипГруппы, ИДРодительскойГруппы");
	ТаблицаГрупп.Свернуть("ИДГруппы, НаименованиеГруппы, ТипГруппы, ИДРодительскойГруппы");
	ТаблицаГрупп.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаИерархииГрупп = ТаблицаГрупп.СкопироватьКолонки();
	ТаблицаИерархииГрупп.Колонки.Добавить("Уровень", Новый ОписаниеТипов("Число"	, Новый КвалификаторыЧисла(3,0, ДопустимыйЗнак.Неотрицательный)));
	Для Каждого СтрокаГруппы Из ТаблицаГрупп Цикл
		ТаблицаИерархииГрупп.Очистить();
		СформироватьТаблицуИерархииГрупп(СтрокаГруппы, ТаблицаИерархииГрупп, Таблица_Групп_Номенклатуры, ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры);
		ТаблицаИерархииГрупп.Сортировать("Уровень Убыв");
		// ОбновитьВеткуИерархииГрупп(ТаблицаИерархииГрупп, ТаблицаГруппНоменклатурыВБазе);
		ПапкаВерхнегоУровня = ТаблицаИерархииГрупп[0].Ссылка; 
		Для Каждого СтрокаТаблицыИерархииГрупп Из ТаблицаИерархииГрупп Цикл 
			СтрокаТаблицыИерархииГрупп.Ссылка = ПапкаВерхнегоУровня;
			МассивГруппВерхнегоУровня = ТаблицаГруппНоменклатурыВБазе.НайтиСтроки(Новый Структура("Наименование, Родитель", СокрЛП(СтрокаТаблицыИерархииГрупп.НаименованиеГруппы), ПапкаВерхнегоУровня));
			Если МассивГруппВерхнегоУровня.Количество() = 0 Тогда 
				ГруппаНоменклатуры	 						= Справочники.Номенклатура.СоздатьГруппу();
				ГруппаНоменклатуры.Родитель 				= ПапкаВерхнегоУровня;
				ГруппаНоменклатуры.Наименование 			= СокрЛП(СтрокаТаблицыИерархииГрупп.НаименованиеГруппы);
				ГруппаНоменклатуры.ТипНоменклатуры 			= ?(СтрокаТаблицыИерархииГрупп.ТипГруппы = 1, ТипНоменклатуры_Услуга, ТипНоменклатуры_Запас);
				ГруппаНоменклатуры.УстановитьНовыйКод();									
				ГруппаНоменклатуры.ОбменДанными.Загрузка 	= Истина;
				ГруппаНоменклатуры.Записать();
				ЗаполнитьЗначенияСвойств(ТаблицаГруппНоменклатурыВБазе.Добавить(), ГруппаНоменклатуры);
				ПапкаВерхнегоУровня 						= ГруппаНоменклатуры.Ссылка;
			Иначе 
				ПапкаВерхнегоУровня 						= МассивГруппВерхнегоУровня[0].Ссылка;
			КонецЕсли;
		КонецЦикла;	
		СтрокаГруппы.Ссылка 								= ПапкаВерхнегоУровня;
		
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных...';en='Preservation of preliminary data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создаем необходимые группы и ед. измерения...", 0, ""));		
	КонецЦикла;
	
	// Создаем необходимые единицы измерения
	ТаблицаЕдИзм = Основная_Таблица_Номенклатуры.Скопировать( , "ЕдИзм");
	ТаблицаЕдИзм.Свернуть("ЕдИзм");
	Для Каждого СтрокаЕдИзм Из ТаблицаЕдИзм Цикл
		Если ЗначениеЗаполнено(СокрЛП(СтрокаЕдИзм.ЕдИзм)) Тогда 
			СтрокаТЗ_ЕдИзм = ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Найти(СокрЛП(СтрокаЕдИзм.ЕдИзм), "Наименование");
			Если СтрокаТЗ_ЕдИзм = Неопределено Тогда 
				ЕдИзм 						= Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
				ЕдИзм.Наименование 			= СокрЛП(СтрокаЕдИзм.ЕдИзм);
				ЕдИзм.НаименованиеПолное 	= СокрЛП(СтрокаЕдИзм.ЕдИзм);
				ЕдИзм.УстановитьНовыйКод();			
				ЕдИзм.ОбменДанными.Загрузка = Истина;
				ЕдИзм.Записать();
				ЗаполнитьЗначенияСвойств(ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Добавить(), ЕдИзм);			
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ВидЦены_1 = Справочники.ВидыЦен.НайтиПоНаименованию("Цена 1", Истина);
	Если НЕ ЗначениеЗаполнено(ВидЦены_1) Тогда 
		ВидЦены_1_Объект = Справочники.ВидыЦен.СоздатьЭлемент();
		ВидЦены_1_Объект.Заполнить(Неопределено);
		ВидЦены_1_Объект.Наименование 	= "Цена 1";
		ВидЦены_1_Объект.Записать();
		ВидЦены_1 						= ВидЦены_1_Объект.Ссылка;
	КонецЕсли;
	
	ВидЦены_2 = Справочники.ВидыЦен.НайтиПоНаименованию("Цена 2", Истина);
	Если НЕ ЗначениеЗаполнено(ВидЦены_2) Тогда 
		ВидЦены_2_Объект = Справочники.ВидыЦен.СоздатьЭлемент();
		ВидЦены_2_Объект.Заполнить(Неопределено);
		ВидЦены_2_Объект.Наименование 	= "Цена 1";
		ВидЦены_2_Объект.Записать();
		ВидЦены_2 						= ВидЦены_2_Объект.Ссылка;
	КонецЕсли;
	
	ВидЦены_3 = Справочники.ВидыЦен.НайтиПоНаименованию("Цена 3", Истина);
	Если НЕ ЗначениеЗаполнено(ВидЦены_3) Тогда 
		ВидЦены_3_Объект = Справочники.ВидыЦен.СоздатьЭлемент();
		ВидЦены_3_Объект.Заполнить(Неопределено);
		ВидЦены_3_Объект.Наименование 	= "Цена 1";
		ВидЦены_3_Объект.Записать();
		ВидЦены_3 						= ВидЦены_3_Объект.Ссылка;
	КонецЕсли;
	
	#КонецОбласти
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по номенклатуре...';en='Saving data by nomenclature...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоНоменклатуры = Основная_Таблица_Номенклатуры.Количество();
	ОбщееКоличествоНоменклатуры	= ?(ОбщееКоличествоНоменклатуры < 1, 1, ОбщееКоличествоНоменклатуры);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоНоменклатур 			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеНоменклатуры	= "";
	
	// Проходим основную таблицу
	Для Каждого СтрокаТаблицыНоменклатуры Из Основная_Таблица_Номенклатуры Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.НоменклатураСсылка) Тогда 
			Продолжить;
		КонецЕсли;	
		КодУслуги 			= СтрокаТаблицыНоменклатуры.ИДНоменклатуры;
		// НаименованиеУслуги 	= СтрокаТаблицыНоменклатуры.НаименованиеУслуги;
		Если КодУслуги = 0 Тогда  // ИЛИ СокрЛП(НаименованиеУслуги) = "" Тогда
			Продолжить;
		КонецЕсли;
		
		// Определяем родителя
		СтрокаРодитель = ТаблицаГрупп.Найти(СтрокаТаблицыНоменклатуры.ИДГруппы, "ИДГруппы");
		Если НЕ СтрокаРодитель = Неопределено Тогда 
			РодительУслуги = ?(ЗначениеЗаполнено(СтрокаРодитель.Ссылка), СтрокаРодитель.Ссылка, ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры);
		Иначе 
			РодительУслуги = ПараметрыЗадания.ПараметрыЗагрузки.ГруппаНоменклатуры;
		КонецЕсли;
		
		// Заполняем по родителю
		СтруктураЗаполнения 						= Новый Структура("Родитель", РодительУслуги);
		Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.НоменклатураСсылка) Тогда 
			НоменклатураУслуги 							= СтрокаТаблицыНоменклатуры.НоменклатураСсылка.ПолучитьОбъект();
		Иначе 
			НоменклатураУслуги 							= Справочники.Номенклатура.СоздатьЭлемент();
		КонецЕсли;			
		НоменклатураУслуги.Заполнить(СтруктураЗаполнения);
		// Общие реквизиты
		НоменклатураУслуги.ТипНоменклатуры 			= СтрокаТаблицыНоменклатуры.ТипНоменклатурыПеречисление;
		НоменклатураУслуги.КодСинхронизации 		= СтрокаТаблицыНоменклатуры.КодСинхронизации;
		НоменклатураУслуги.Комментарий 				= Формат(СтрокаТаблицыНоменклатуры.КодСинхронизации, "ЧГ=0"); 
		НоменклатураУслуги.Наименование 			= СокрЛП(СтрокаТаблицыНоменклатуры.Наименование);
		НоменклатураУслуги.НаименованиеПолное 		= СокрЛП(СтрокаТаблицыНоменклатуры.Наименование);
		НоменклатураУслуги.Артикул 					= СтрокаТаблицыНоменклатуры.Артикул;	
		
		// Реквизиты по типам
		Если СтрокаТаблицыНоменклатуры.ТипНоменклатурыПеречисление = ТипНоменклатуры_Услуга Тогда
			НоменклатураУслуги.НормаВремени 		= СтрокаТаблицыНоменклатуры.ПродолжительностьУслугиМин;
			НоменклатураУслуги.СписыватьПриПродаже 	= Истина;
		Иначе // Запас
			СтрокаЕдИзм = СокрЛП(СтрокаТаблицыНоменклатуры.ЕдИзм);
			Если СтрокаЕдИзм = "" Тогда
				НоменклатураУслуги.ЕдиницаИзмерения = ЕдиницИзмерения_шт;	
			ИначеЕсли СтрНайти(СтрокаЕдИзм, "шт") = 0 Тогда
				СтрокаТЗ_КЕИ = ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Найти(СтрокаЕдИзм, "Наименование");
				Если СтрокаТЗ_КЕИ = Неопределено Тогда 
					ЕдИзм = Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
					ЕдИзм.Наименование 			= СтрокаЕдИзм;
					ЕдИзм.НаименованиеПолное 	= СтрокаЕдИзм;
					ЕдИзм.УстановитьНовыйКод();			
					ЕдИзм.ОбменДанными.Загрузка = Истина;
					ЕдИзм.Записать();
				КонецЕсли;
				НоменклатураУслуги.ЕдиницаИзмерения = СтрокаТЗ_КЕИ.Ссылка;
			Иначе
				НоменклатураУслуги.ЕдиницаИзмерения = ЕдиницИзмерения_шт;
			КонецЕсли;
		КонецЕсли;
					
		Цена1 = СтрокаТаблицыНоменклатуры.Цена1;
		Цена2 = СтрокаТаблицыНоменклатуры.Цена2;
		Цена3 = СтрокаТаблицыНоменклатуры.Цена3;
		Цена = Макс(Цена1, Цена2, Цена3);
		Если Цена <= 0 Тогда
			НоменклатураУслуги.Бесплатно = Истина;	
		КонецЕсли;
		
		НоменклатураУслуги.УстановитьНовыйКод();		
		НоменклатураУслуги.ОбменДанными.Загрузка = Истина;
		Попытка
			НоменклатураУслуги.Записать();
			СтрокаТаблицыНоменклатуры.НоменклатураСсылка = НоменклатураУслуги.Ссылка;
		Исключение
			// Запись в лог						
			ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Ошибка при записи номенклатуры! Код синхронизации: ';en='Mistake at records nomenclature! Code sync: '") + Строка(СтрокаТаблицыНоменклатуры.КодСинхронизации) + Символы.ПС + ОписаниеОшибки()); 						
		КонецПопытки;
		
		// Накапливаем статисические данные и оповещаем клиент
		СозданоНоменклатур 				= СозданоНоменклатур + 1;
		ПредставлениеНоменклатуры		= Строка(НоменклатураУслуги.Ссылка);
		Прогресс 						= Цел(100 * СозданоНоменклатур / ОбщееКоличествоНоменклатуры);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по номенклатуре...';en='Saving data by nomenclature...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеНоменклатуры, ОсталосьВремени, ПредставлениеОставшегосяВремени));
		
		УпаковкаНоменклатуры = ПустаяУпаковкаНоменклатуры;
		Если СтрокаТаблицыНоменклатуры.Количество > 1 Тогда 
			МассивУпаковокНоменклатуры = ТаблицаУпаковокВБазе.НайтиСтроки(Новый Структура("Владелец, Коэффициент, ЕдиницаИзмерения", НоменклатураУслуги.Ссылка, СтрокаТаблицыНоменклатуры.Количество, НоменклатураУслуги.ЕдиницаИзмерения));	
			Если МассивУпаковокНоменклатуры.Количество() = 0 Тогда 
				УпаковкаНоменклатуры_Объект 						= Справочники.УпаковкиНоменклатуры.СоздатьЭлемент();
				УпаковкаНоменклатуры_Объект.Владелец 				= НоменклатураУслуги.Ссылка;
				УпаковкаНоменклатуры_Объект.Коэффициент 			= СтрокаТаблицыНоменклатуры.Количество;
				УпаковкаНоменклатуры_Объект.Наименование 			= Формат(СтрокаТаблицыНоменклатуры.Количество, "ЧГ=0") + " " + Строка(НоменклатураУслуги.ЕдиницаИзмерения);
				УпаковкаНоменклатуры_Объект.ОбменДанными.Загрузка	= Истина;
				УпаковкаНоменклатуры_Объект.Записать();
				УпаковкаНоменклатуры								= ТаблицаУпаковокВБазе.Добавить();
				ЗаполнитьЗначенияСвойств(УпаковкаНоменклатуры, УпаковкаНоменклатуры_Объект);
				УпаковкаНоменклатуры.ЕдиницаИзмерения 				= НоменклатураУслуги.ЕдиницаИзмерения;
				УпаковкаНоменклатуры 								= УпаковкаНоменклатуры_Объект.Ссылка;
			Иначе 
				УпаковкаНоменклатуры 								= МассивУпаковокНоменклатуры[0].Ссылка;
			КонецЕсли;
		КонецЕсли;	
		
		Если СтрокаТаблицыНоменклатуры.Активно = 0 Тогда
			// Установим статус номенклатуре
			МассивСтрокСтатусовНоменклатуры = ТаблицаСтатусовНоменклатуры.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница, Номенклатура", ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, НоменклатураУслуги.Ссылка));
			Если НЕ МассивСтрокСтатусовНоменклатуры.Количество() = 0 Тогда
				ВПродаже 	= МассивСтрокСтатусовНоменклатуры[0].ВПродаже;
				ДатаСтатуса = МассивСтрокСтатусовНоменклатуры[0].Период;
				ЕстьСтатус 	= Истина;
			Иначе
				ВПродаже 	= Истина;
				ДатаСтатуса = Дата(1,1,1);
				ЕстьСтатус 	= Ложь;
			КонецЕсли;	
			СтруктураСтатус = Новый Структура("ВПродаже, ДатаСтатуса, ЕстьСтатус", ВПродаже, ДатаСтатуса, ЕстьСтатус);			
			РегистрыСведений.СтатусыНоменклатуры.УстановитьСтатусПродажиНоменклатуры(ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница, НоменклатураУслуги.Ссылка, НачалоДня(ТекущаяДатаСеанса()), Ложь, СтруктураСтатус);	
		КонецЕсли;
		
		Если СтрокаТаблицыНоменклатуры.Себестоимость > 0 И СтрокаТаблицыНоменклатуры.ТипНоменклатурыПеречисление = ТипНоменклатуры_Запас Тогда 
			НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			НоваяЦена.Номенклатура       = НоменклатураУслуги.Ссылка;
			НоваяЦена.ВидЦен             = ВидЦены_Закупочная;
			НоваяЦена.Цена               = СтрокаТаблицыНоменклатуры.Себестоимость;
			НоваяЦена.Упаковка           = ПустаяУпаковкаНоменклатуры;
			НоваяЦена.Период             = ДатаУстановкиЦены;
			НоваяЦена.Автор              = ТекущийПользовательСеанса;
			НоваяЦена.Записать();
		КонецЕсли;
		
		Если Цена1 > 0 Тогда
			НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			НоваяЦена.Номенклатура       = НоменклатураУслуги.Ссылка;
			НоваяЦена.ВидЦен             = ВидЦены_1;
			НоваяЦена.Цена               = Цена1;
			НоваяЦена.Упаковка           = УпаковкаНоменклатуры;
			НоваяЦена.Период             = ДатаУстановкиЦены;
			НоваяЦена.Автор              = ТекущийПользовательСеанса;
			НоваяЦена.Записать();
		КонецЕсли;
		
		Если Цена2 > 0 Тогда
			НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			НоваяЦена.Номенклатура       = НоменклатураУслуги.Ссылка;
			НоваяЦена.ВидЦен             = ВидЦены_2;
			НоваяЦена.Цена               = Цена2;
			НоваяЦена.Упаковка           = УпаковкаНоменклатуры;
			НоваяЦена.Период             = ДатаУстановкиЦены;
			НоваяЦена.Автор              = ТекущийПользовательСеанса;
			НоваяЦена.Записать();
		КонецЕсли;
		
		Если Цена3 > 0 Тогда
			НоваяЦена                    = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
			НоваяЦена.СтруктурнаяЕдиница = ПараметрыЗадания.ПараметрыЗагрузки.СтруктурнаяЕдиница;
			НоваяЦена.Номенклатура       = НоменклатураУслуги.Ссылка;
			НоваяЦена.ВидЦен             = ВидЦены_3;
			НоваяЦена.Цена               = Цена3;
			НоваяЦена.Упаковка           = УпаковкаНоменклатуры;
			НоваяЦена.Период             = ДатаУстановкиЦены;
			НоваяЦена.Автор              = ТекущийПользовательСеанса;
			НоваяЦена.Записать();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.Штрихкод) Тогда		
			НаборЗаписей = РегистрыСведений.Штрихкоды.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Объект.Установить(НоменклатураУслуги.Ссылка);
			НаборЗаписей.Отбор.Штрихкод.Установить(СтрокаТаблицыНоменклатуры.Штрихкод);
			НоваяСтрока = НаборЗаписей.Добавить();
			НоваяСтрока.Объект 			   = НоменклатураУслуги.Ссылка;		
			НоваяСтрока.Штрихкод 		   = СтрокаТаблицыНоменклатуры.Штрихкод;
			НаборЗаписей.Записать();          				
		КонецЕсли;
		
	КонецЦикла;
	
	
	// -------------------------------------------------- СОЗДАНИЕ КАЛЬКУЛЯЦИЙ -------------------------------------------------------
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(Таблица_Калькуляций			, "Таблица_Калькуляций");
	Запрос.Текст = "ВЫБРАТЬ
	               |	Калькуляции.Ссылка КАК Ссылка,
	               |	Калькуляции.Владелец КАК Владелец,
	               |	Калькуляции.Дата КАК Дата
	               |ИЗ
	               |	Справочник.Калькуляции КАК Калькуляции
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица_Калькуляций.ИДУслуги КАК ИДУслуги,
	               |	Таблица_Калькуляций.ДатаСозданияКалькуляции КАК ДатаСозданияКалькуляции,
	               |	Таблица_Калькуляций.ИДМатериала КАК ИДМатериала,
	               |	Таблица_Калькуляций.КоличествоМатериала КАК КоличествоМатериала,
	               |	Таблица_Калькуляций.ИндексМатериала КАК ИндексМатериала,
	               |	ЕСТЬNULL(СправочникНоменклатураУслуги.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураУслуга,
	               |	ЕСТЬNULL(СправочникНоменклатураМатериалы.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК НоменклатураМатериал
	               |ИЗ
	               |	Таблица_Калькуляций КАК Таблица_Калькуляций
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатураУслуги
	               |		ПО Таблица_Калькуляций.ИДУслуги = СправочникНоменклатураУслуги.КодСинхронизации
	               |			И (Таблица_Калькуляций.ИДУслуги > 0)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатураМатериалы
	               |		ПО Таблица_Калькуляций.ИДМатериала = СправочникНоменклатураМатериалы.КодСинхронизации
	               |			И (Таблица_Калькуляций.ИДМатериала > 0)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ИДУслуги,
	               |	ДатаСозданияКалькуляции,
	               |	ИндексМатериала
	               |ИТОГИ ПО
	               |	НоменклатураУслуга,
	               |	ДатаСозданияКалькуляции";
	
	РезультатПакетаЗапросов = Запрос.ВыполнитьПакет();
	ТаблицаКалькуляцийВБазе = РезультатПакетаЗапросов[0].Выгрузить();
	ВыборкаПоУслугам 		= РезультатПакетаЗапросов[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение данных по калькуляциям...';en='Saving data on costing...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоУслуг	 	= ВыборкаПоУслугам.Количество();
	ОбщееКоличествоУслуг		= ?(ОбщееКоличествоУслуг < 1, 1, ОбщееКоличествоУслуг);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоКалькуляций			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеКалькуляции	= "";
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Пока ВыборкаПоУслугам.Следующий() Цикл
		СозданоКалькуляций = СозданоКалькуляций + 1;
		Если НЕ ЗначениеЗаполнено(ВыборкаПоУслугам.НоменклатураУслуга) Тогда 
			Продолжить;
		КонецЕсли;
		
		ВыборкаПоДатам = ВыборкаПоУслугам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		КалькуляцияСоздана = Ложь;
		Пока ВыборкаПоДатам.Следующий() Цикл 
			МассивКалькуляцийВбазе = ТаблицаКалькуляцийВБазе.НайтиСтроки(Новый Структура("Владелец, Дата", ВыборкаПоУслугам.НоменклатураУслуга, ВыборкаПоДатам.ДатаСозданияКалькуляции));
			Если НЕ МассивКалькуляцийВбазе.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			КалькуляцияУслуги 				= Справочники.Калькуляции.СоздатьЭлемент();
			КалькуляцияУслуги.Владелец 		= ВыборкаПоУслугам.НоменклатураУслуга;
			КалькуляцияУслуги.Дата	 		= ВыборкаПоДатам.ДатаСозданияКалькуляции;
			КалькуляцияУслуги.Наименование 	= "Калькуляция " + КалькуляцияУслуги.Владелец.Наименование + " от " + Формат(КалькуляцияУслуги.Дата, "ДЛФ=Д");

			ВыборкаПоМатериалам 		= ВыборкаПоДатам.Выбрать();
			Пока ВыборкаПоМатериалам.Следующий() Цикл
				Если НЕ ЗначениеЗаполнено(ВыборкаПоМатериалам.НоменклатураМатериал) Тогда 
					Продолжить;
				КонецЕсли;	
				НоваяСтрокаСостава 						= КалькуляцияУслуги.Состав.Добавить();
				НоваяСтрокаСостава.Номенклатура 		= ВыборкаПоМатериалам.НоменклатураМатериал;
				НоваяСтрокаСостава.Количество 			= ВыборкаПоМатериалам.КоличествоМатериала;
				НоваяСтрокаСостава.КоличествоУпаковок 	= ВыборкаПоМатериалам.КоличествоМатериала;
				НоваяСтрокаСостава.СписыватьМатериал 	= Истина;
				НоваяСтрокаСостава.СкладСписания 		= ПараметрыЗадания.ПараметрыЗагрузки.ОсновнойСкладСтруктурнойЕдиницы;
			КонецЦикла;
			Попытка
				КалькуляцияУслуги.Записать();
				КалькуляцияСоздана = Истина;
			Исключение
				// Запись в лог						
				ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка при записи калькуляции! Дата: %2 Услуга: %3 %1 %4';en='%1 Mistake at records costing! Date: %2 Service: %3 %1 %4'"), Символы.ПС, Строка(ВыборкаПоДатам.ДатаСозданияКалькуляции), Строка(ВыборкаПоУслугам.НоменклатураУслуга), ОписаниеОшибки()));						
			КонецПопытки;
			
			
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеКалькуляции		= Строка(КалькуляцияУслуги.Ссылка);
			Прогресс 						= Цел(100 * СозданоКалькуляций / ОбщееКоличествоУслуг);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Сохранение данных по калькуляциям...';en='Saving data on costing...'") + Символы.Таб + НСтр("ru= ' Осталось: ';en= ' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКалькуляции, ОсталосьВремени, ПредставлениеОставшегосяВремени));
			СообщилиПрогресс = Истина;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТаблицаГруппНоменклатурыВБазе.Очистить(); 				ТаблицаГруппНоменклатурыВБазе 				= Неопределено;
	ТаблицаКлассификаторовЕдиницИзмеренияВБазе.Очистить(); 	ТаблицаКлассификаторовЕдиницИзмеренияВБазе 	= Неопределено;
	Основная_Таблица_Номенклатуры.Очистить();				Основная_Таблица_Номенклатуры 				= Неопределено;
	ТаблицаКалькуляцийВБазе.Очистить();						ТаблицаКалькуляцийВБазе 					= Неопределено;
	
	// ==============================================================================================================================
	// Найдем или создадим номенклатуру модификатора членства
	Модификатор = Справочники.Номенклатура.НайтиПоНаименованию("Бонусные дни", Истина);
	Если Модификатор.Пустая() Тогда
		Модификатор 										= Справочники.Номенклатура.СоздатьЭлемент();
		Модификатор.Наименование 							= "Бонусные дни";
		Модификатор.НаименованиеПолное 						= "Бонусные дни";
		Модификатор.ЕдиницаИзмерения 						= ЕдиницИзмерения_шт;
		Модификатор.Бесплатно 								= Истина;
		Модификатор.ТипНоменклатуры 						= ТипНоменклатуры_МодификаторЧленствПакетов;
		Модификатор.МодификаторПризнакКоличествоУказывается = Истина;
		Модификатор.МодификаторТипСрокаДействия 			= Периодичность_День;
		Модификатор.Записать();
	КонецЕсли;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл 	
		Если К/100 = Цел(К/100) Тогда		
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Удаление временных таблиц...';en='Temporary tables deletion...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// ТаблицаСтатусовНоменклатуры.Очистить();					ТаблицаСтатусовНоменклатуры 				= Неопределено;
	// МассивГруппШаблонов.Очистить(); 						МассивГруппШаблонов 						= Неопределено;
	// ТаблицаГруппШаблоновВБазе.Очистить(); 					ТаблицаГруппШаблоновВБазе 					= Неопределено;
									 						ВыборкаПоКатегориям 						= Неопределено;
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;	
		      
КонецПроцедуры

 #КонецОбласти 

// Функция - Начать импорт данных
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьИзменениеДанныхВФоне(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	ИмяПроцедуры 		= "ЗагрузкаПроведениеДокументов.ИзменитьДанныеВФонеМногопоточно";
	ОписаниеПроцедуры 	= НСтр("ru='Изменение данных...';en='Change data...'");
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	ИмяПроцедуры,
	ПараметрыПроцедуры,
	ОписаниеПроцедуры);
	Возврат Результат;
	
КонецФункции

// Процедура - Изменить данные в фоне многопоточно
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ИзменитьДанныеВФонеМногопоточно(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса изменения данных...';en='Start process changes data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Объектов = ПараметрыЗадания.ОбрабатываемыеОбъекты;
	
	КоличествоПотоков = 8;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	МассивТаблиц 					= Новый Массив;
	РазбитьТаблицуОбъектовПоКлючевомуПолю(Таблица_Объектов, "Ссылка", КоличествоПотоков, МассивТаблиц);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Генерация фоновых заданий...';en='Generation of background works...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	// Генерируем фоновые задания
	МассивФоновыхЗаданий 				= Новый Массив;
	МассивИдентификаторовФоновыхЗаданий = Новый Массив;
	Для Каждого ТаблицаОбъектов Из МассивТаблиц Цикл 
		УникальныйИдентификаторЗадания 	= Новый УникальныйИдентификатор();
		ПараметрыПроцедуры = ПараметрыЗадания;
		ПараметрыПроцедуры.ОбрабатываемыеОбъекты = ТаблицаОбъектов;
		// ПараметрыПроцедуры.СписокТаблиц[0].Значение.Таблица_Контракты 			= ТаблицаОбъектов;
		// ПараметрыПроцедуры.СписокТаблиц[0].Значение.КоличествоПолученныхСтрок 	= ТаблицаОбъектов.Количество();
		
		Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторЗадания,
		"ЗагрузкаПроведениеДокументов.ИзменитьДанныеВПотоке",
		ПараметрыПроцедуры,
		НСтр("ru = 'Изменение данных. Поток № " + Строка(МассивТаблиц.Найти(ТаблицаОбъектов)) + "'"));
		
		Если НЕ Результат = Неопределено Тогда 
			Задание = ДлительныеОперации.НайтиЗаданиеПоИдентификатору(Результат.ИдентификаторЗадания);
			Если НЕ Задание = Неопределено Тогда 
				МассивФоновыхЗаданий.Добавить(Задание);
				МассивИдентификаторовФоновыхЗаданий.Добавить(Результат.ИдентификаторЗадания);
			КонецЕсли;
		Иначе 
			ОшибкаИнициацииФоновогоЗадания = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Передача идентификаторов фоновых заданий...';en='Broadcast background assignments ids...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, МассивИдентификаторовФоновыхЗаданий", "", 0, "", МассивИдентификаторовФоновыхЗаданий));
	
	// Ожидаем выполнения фоновых заданий 
	Если МассивФоновыхЗаданий.Количество() > 0 Тогда 
		Попытка 
			ФоновыеЗадания.ОжидатьЗавершения(МассивФоновыхЗаданий); 
		Исключение
			ОшибкаИнициацииФоновогоЗадания = Истина;			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Ошибка проведения!';en='Mistake holding!'"));
		КонецПопытки; 
	КонецЕсли;
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл 	
		Если К/100 = Цел(К/100) Тогда				
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;	
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

// Процедура - Изменить данные в потоке
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ИзменитьДанныеВПотоке(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка 	= Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Старт процесса сохранения данных...';en='Start process save data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТекстовыйНакопитель = Новый ЗаписьXML;
	ТекстовыйНакопитель.УстановитьСтроку();		
	
	Таблица_Объектов 			= ПараметрыЗадания.ОбрабатываемыеОбъекты;
	МассивИзменяемыхПараметров 	= ПараметрыЗадания.ИзменяемыеРеквизиты;
	
	Если Таблица_Объектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Изменение данных...';en='Change data...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ОбщееКоличествоКонтрактов 	= Таблица_Объектов.Количество();
	ОбщееКоличествоКонтрактов	= ?(ОбщееКоличествоКонтрактов < 1, 1, ОбщееКоличествоКонтрактов);
	ДатаНачалаПроцесса 			= ТекущаяДатаСеанса();
	СозданоКонтрактов 			= 0;
	ОсталосьВремени 			= Неопределено;
	ПредставлениеКонтракта		= "";
	
	// ОСНОВНОЙ ЦИКЛ ОБХОДА ТАБЛИЦЫ ДАННЫХ
	Для Каждого СтрокаТаблицы Из Таблица_Объектов Цикл
		СообщилиПрогресс = Ложь;
		СозданоКонтрактов = СозданоКонтрактов + 1;
		Если ЗначениеЗаполнено(СтрокаТаблицы.Ссылка) Тогда
			ЧленствоОбъект = СтрокаТаблицы.Ссылка.ПолучитьОбъект();
			
			Для Каждого СтруктураИзменяемогоПараметра Из МассивИзменяемыхПараметров Цикл 
				Если СтруктураИзменяемогоПараметра.Изменять = Истина Тогда 
			    	ЧленствоОбъект[СтруктураИзменяемогоПараметра.Имя] = СтруктураИзменяемогоПараметра.Значение;
			    КонецЕсли;
			КонецЦикла;
			
			Попытка
				// Сохраняем документ				
				ЗаписатьДокумент(ЧленствоОбъект, , , Истина);
			Исключение
				// Запись в лог
				ТекстовыйНакопитель.ЗаписатьБезОбработки(Символы.ПС + НСтр("ru='Ошибка сохранения док-та Членство/Пакет услуг клиента ';en='Mistake save doc Membership Package services client '") + Строка(СтрокаТаблицы.Ссылка) + "" + Символы.ПС + ОписаниеОшибки());						
			КонецПопытки;
			
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеКонтракта			= Строка(СтрокаТаблицы.Ссылка);
			Прогресс 						= Цел(100 * СозданоКонтрактов / ОбщееКоличествоКонтрактов);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Изменение данных...';en='Change data...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКонтракта, ОсталосьВремени, ПредставлениеОставшегосяВремени));
			СообщилиПрогресс = Истина;
			
		КонецЕсли;
		
		Если СообщилиПрогресс = Ложь Тогда 
			// Накапливаем и выводим статисические данные и оповещаем клиент
			ПредставлениеКонтракта			= "";
			Прогресс 						= Цел(100 * СозданоКонтрактов / ОбщееКоличествоКонтрактов);
			ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
			ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
			ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Изменение данных...';en='Change data...'") + Символы.Таб + НСтр("ru=' Осталось: ';en=' Left: '") + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеКонтракта, ОсталосьВремени, ПредставлениеОставшегосяВремени));		
		КонецЕсли;		
	КонецЦикла; // ВыборкаПоКлиентам
	
	ЛогГенерации = ТекстовыйНакопитель.Закрыть();
	Для К = 0 По 1999 Цикл
		Если К/100 = Цел(К/100) Тогда 
			ДлительныеОперации.СообщитьПрогресс(100, НСтр("ru='Сохранение лога...';en='Preservation broad gull...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ЛогГенерации", "", 0, "", ЛогГенерации));		
		КонецЕсли;	
	КонецЦикла;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;		
	
КонецПроцедуры

 #КонецОбласти  
 
 #КонецОбласти

