
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ЭтотОбъект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ЭтотОбъект.АвторДокумента = ПараметрыСеанса.ТекущийПользователь;

	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	
КонецПроцедуры

// Процедура - обработчик события "ПриКопировании" объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	                       
КонецПроцедуры

// Обработчик перед записью документа
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Проверка существования документа закрывающего данный месяц
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ЗакрытиеМесяца.Ссылка
		|ИЗ
		|	Документ.ЗакрытиеМесяца КАК ЗакрытиеМесяца
		|ГДЕ
		|	ГОД(ЗакрытиеМесяца.МесяцРаспределения) = ГОД(&МесяцРаспределения)
		|	И ЗакрытиеМесяца.Проведен = ИСТИНА
		|	И МЕСЯЦ(ЗакрытиеМесяца.МесяцРаспределения) = МЕСЯЦ(&МесяцРаспределения)
		|	И ЗакрытиеМесяца.Ссылка <> &ИсключитьСсылку
		|	И ЗакрытиеМесяца.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
		
		Запрос.УстановитьПараметр("МесяцРаспределения",ЭтотОбъект.МесяцРаспределения);
		Запрос.УстановитьПараметр("ИсключитьСсылку",ЭтотОбъект.Ссылка);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница",ЭтотОбъект.СтруктурнаяЕдиница);
		РезВыборки = Запрос.Выполнить().Выбрать();
		Если РезВыборки.Количество() > 0 Тогда
			РезВыборки.Следующий();
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + РезВыборки.Ссылка	+" документ закрывает указаный месяц!");	 
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

// Обработчик проведени объекта
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
		
	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);		
    // Инициализация данных документа.	
	Документы.ЗакрытиеМесяца.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);		
	// Движения по регистрам
	ДвиженияДокументовСервер.Управленческий(ДополнительныеСвойства, Движения, Отказ);	
    // Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);	

КонецПроцедуры


#КонецОбласти

