&НаСервере
// Процедура, выполняет становку статуса
//
Процедура УстановитьСтатусы(Статус, ТекущийНомерЗаказа = Неопределено)
	
	Статус = Перечисления.СтатусыНарядЗаказа[Статус];
	Массив = Новый Массив;
	Для Каждого СтрокаТЧ из СписокДокументов Цикл
		Если СтрокаТЧ.Флаг Тогда
			УстановкаСтатуса(СтрокаТЧ.Ссылка, СтрокаТЧ.НомерСтроки, Статус);	
			Массив.Добавить(СтрокаТЧ.НомерЗаказа);
		КонецЕсли;
	КонецЦикла;
	ЗаполнитьСписокДокументов(Массив, ТекущийНомерЗаказа);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, выполняет установку статуса
//
Процедура УстановкаСтатуса(Документ, НомерСтроки, Статус)
	
	ДокументОбъект = Документ.ПолучитьОбъект();
	Если Не ДокументОбъект.Запасы.Количество() < НомерСтроки Тогда
		ДокументОбъект.Запасы[НомерСтроки - 1].Статус = Статус;
		Если Статус = Перечисления.СтатусыНарядЗаказа.Заказано  Тогда
			 ДокументОбъект.Запасы[НомерСтроки - 1].ДатаЗаказа 	   = Неопределено;
			 ДокументОбъект.Запасы[НомерСтроки - 1].ДатаВыполнения = Неопределено;
		КонецЕсли;		
		Если Статус =  Перечисления.СтатусыНарядЗаказа.ВРаботе  Тогда
			Если НЕ ЗначениеЗаполнено(ДокументОбъект.Запасы[НомерСтроки - 1].ДатаЗаказа) Тогда
				ДокументОбъект.Запасы[НомерСтроки - 1].ДатаЗаказа = ТекущаяДата();
			КонецЕсли;
			ДокументОбъект.Запасы[НомерСтроки - 1].ДатаВыполнения = Неопределено;
		КонецЕсли;
		Если Статус =  Перечисления.СтатусыНарядЗаказа.Выполнено и не ЗначениеЗаполнено(ДокументОбъект.Запасы[НомерСтроки - 1].ДатаВыполнения) Тогда
			 ДокументОбъект.Запасы[НомерСтроки - 1].ДатаВыполнения = ТекущаяДата();
			 Если Не ЗначениеЗаполнено(ДокументОбъект.Запасы[НомерСтроки - 1].ДатаЗаказа) Тогда
				   ДокументОбъект.Запасы[НомерСтроки - 1].ДатаЗаказа = ТекущаяДата();
			 КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	НайденныеСтроки = ДокументОбъект.Запасы.НайтиСтроки(Новый Структура("Статус",  Перечисления.СтатусыНарядЗаказа.Выполнено));
	Если НайденныеСтроки.Количество() = ДокументОбъект.Запасы.Количество() Тогда
		ДокументОбъект.Статус = Истина;	
	Иначе
		ДокументОбъект.Статус = Ложь;
	КонецЕсли;
		
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Выбор"
//
Процедура СписокДокументовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтрокаТЧ = Элементы.СписокДокументов.ТекущиеДанные;
	Если Не СтрокаТЧ = Неопределено Тогда
		ОткрытьФорму("Документ.НарядЗаказ.Форма.ФормаДокумента", Новый Структура("Ключ", СтрокаТЧ.Ссылка));
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
