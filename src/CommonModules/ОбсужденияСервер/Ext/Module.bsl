Процедура ВключитьФОИспользоватьНапоминанияПользователяПриОбновлении(СтруктураПараметров) Экспорт
		
КонецПроцедуры

Функция ПреобразоватьНавигационныеСсылки(Комментарий)
	
	МассивСсылок = Новый Массив;
	МассивНавигационныхСсылок = Новый Массив;
	Остаток = Комментарий;
	Комментарий = "";
	Позиция = Найти(Остаток, "e1cib");
	Пока Позиция>0 Цикл
		Комментарий = Комментарий+Лев(Остаток, Позиция-1);
		Остаток = Сред(Остаток, Позиция);
		Позиция = Найти(Остаток, " ");
		СловоПосле = ?(Позиция=0, Остаток, Лев(Остаток, Позиция-1));
		Остаток = ?(Позиция=0, "", Сред(Остаток, Позиция));
		
		ТретьяТочка = Найти(СловоПосле, "'>");
		Если ТретьяТочка> 0 Тогда
			КонецНС = Прав(СловоПосле, СтрДлина(СловоПосле) - ТретьяТочка+1);
			СловоПослеДляСсылки = СтрЗаменить(СловоПосле, КонецНС, "");
			МассивНавигационныхСсылок.Добавить(СловоПослеДляСсылки);
		Иначе
			МассивНавигационныхСсылок.Добавить(СловоПосле);
		КонецЕсли;
		
		Комментарий = Комментарий+"<A HREF='"+СловоПосле+"'>%"+Формат(МассивНавигационныхСсылок.Количество(), "ЧГ=0")+"</A>";
		СсылкаНаОбъект = ПолучитьСсылкуИзНавигационной(СловоПосле);
		МассивСсылок.Добавить(СсылкаНаОбъект); 
		Позиция = Найти(Остаток, "e1cib");
	КонецЦикла;
	Комментарий = Комментарий+Остаток;  
	ПредставленияСсылок = ПолучитьПредставленияНавигационныхСсылок(МассивНавигационныхСсылок);
	Индекс = ПредставленияСсылок.Количество();
	Пока Индекс>0 Цикл
		Представление = ПредставленияСсылок[Индекс-1].Текст;
		Комментарий = СтрЗаменить(Комментарий, "%"+Формат(Индекс, "ЧГ=0"), Представление);
		Индекс = Индекс-1;
	КонецЦикла;
	
	возврат МассивСсылок;
	
КонецФункции

// Функция получает запись регистра в строковом виде
//
Функция ПолучитьЗаписьРегистраСтрокой(ЗаписьРегистра, МетаданныеРегистра)

	СтрокаЗаписи = "";
	Если МетаданныеРегистра.Ресурсы.Найти("Представление") <> Неопределено Тогда 
		Возврат ЗаписьРегистра.Представление;
	КонецЕсли;
	
	Для Каждого Измерение Из МетаданныеРегистра.Измерения Цикл 
		СтрокаЗаписи = СтрокаЗаписи + ?(ЗначениеЗаполнено(ЗаписьРегистра[Измерение.Имя]), ?(Не ПустаяСтрока(СтрокаЗаписи), ", ", "") + ЗаписьРегистра[Измерение.Имя], "");
	КонецЦикла;
	Для Каждого Ресурс Из МетаданныеРегистра.Ресурсы Цикл 
		СтрокаЗаписи = СтрокаЗаписи + ?(ЗначениеЗаполнено(ЗаписьРегистра[Ресурс.Имя]), ?(Не ПустаяСтрока(СтрокаЗаписи), ", ", "") + ЗаписьРегистра[Ресурс.Имя], "");
	КонецЦикла;
	Для Каждого Реквизит Из МетаданныеРегистра.Реквизиты Цикл 
		СтрокаЗаписи = СтрокаЗаписи + ?(ЗначениеЗаполнено(ЗаписьРегистра[Реквизит.Имя]), ?(Не ПустаяСтрока(СтрокаЗаписи), ", ", "") + ЗаписьРегистра[Реквизит.Имя], "");
	КонецЦикла;

	Возврат СтрокаЗаписи;
	
КонецФункции 

// Функция сравнивает есть ли значения полей строки в наборе записей
//
Функция ЕстьЗаписьВНабореЗаписей(Запись, НаборЗаписейРегистра, СравнениеПоИзмерениям = Истина)
	
	НаборЗаписейРегистраТЗ = ?(ТипЗнч(НаборЗаписейРегистра) = Тип("ТаблицаЗначений"), НаборЗаписейРегистра, НаборЗаписейРегистра.Выгрузить());
	
	СтруктураПоиска = Новый Структура;
	Для Каждого ЭлементКолонки Из НаборЗаписейРегистраТЗ.Колонки Цикл
		СтруктураПоиска.Вставить(ЭлементКолонки.Имя, Запись[ЭлементКолонки.Имя]);
	КонецЦикла;
	
	Возврат НаборЗаписейРегистраТЗ.НайтиСтроки(СтруктураПоиска).Количество() > 0;
	
КонецФункции

// процедура делает запись в регистр Обсуждения
//
Процедура ЗаписатьСообщениеОбсуждения(Запись, Сообщение)
	
	Если ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.ДокументыФизическихЛиц") Тогда 
		ОбъектОбсуждения = Запись.Физлицо;
	ИначеЕсли ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.СтатусыКонтрагентов") Тогда 
		ОбъектОбсуждения = Запись.Контрагент;
	ИначеЕсли ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.ЦеныНоменклатуры") ИЛИ 
		ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.СтатусыНоменклатуры") Тогда 
		ОбъектОбсуждения = Запись.Номенклатура;   
	ИначеЕсли ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.СвязкаПомещениеСотрудник") 
		ИЛИ ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.ВремяРаботыСотрудниковПлан") Тогда 
		ОбъектОбсуждения = Запись.Сотрудник;
	ИначеЕсли ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.НастройкиПользователей") Тогда 
		ОбъектОбсуждения = Запись.Пользователь;
	ИначеЕсли ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.НоменклатураСегмента") 
		Или ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.КонтрагентыСегмента") Тогда 
		ОбъектОбсуждения = Запись.Сегмент;
	ИначеЕсли ТипЗнч(Запись) = Тип("РегистрСведенийЗапись.ДействиеСкидокНаценок") Тогда 	
		ОбъектОбсуждения = Запись.СкидкаНаценка;
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(Сообщение) Тогда
		ДобавитьСообщение(
		Сообщение, 
		ОбъектОбсуждения,
		, 
		Истина);
	КонецЕсли;  
	
КонецПроцедуры

// Функция возвращает данные структуры в виде строки
//
Функция ПреобразоватьСтруктуруВСтроку(Структура, Разделитель)

	СтрокаРезультат = "";
	Для Каждого ЭлементСтруктуры Из Структура Цикл   
		СтрокаРезультат = СтрокаРезультат + ?(ЗначениеЗаполнено(ЭлементСтруктуры.Значение), ?(Не ПустаяСтрока(СтрокаРезультат), Разделитель + " ", "") + ЭлементСтруктуры.Значение, ""); 
	КонецЦикла;
	Возврат СтрокаРезультат;
	
КонецФункции 

// Функция сравнивает переданные табличные части и возвращает описание изменений строкой
//
Функция ОписаниеИзмененийТабличныхЧастей(СтарыйОбъект, НовыйОбъект)

	ОписаниеИзменений = "";
	Если ОбщегоНазначения.ЭтоДокумент(СтарыйОбъект.Метаданные()) Тогда
		МетаданныеОбъекта = Метаданные.Документы;
	ИначеЕсли ОбщегоНазначения.ЭтоСправочник(СтарыйОбъект.Метаданные()) Тогда
		МетаданныеОбъекта = Метаданные.Справочники;
	КонецЕсли; 
	
	Для Каждого ТЧ Из МетаданныеОбъекта[СтарыйОбъект.Метаданные().Имя].ТабличныеЧасти Цикл 
		СтараяТЧ = СтарыйОбъект[ТЧ.Имя];
		НоваяТЧ = НовыйОбъект[ТЧ.Имя];
		
		Если ТЧ.Имя = "КонтактнаяИнформация" Тогда 
			МассивСтарыхЗначений = СтараяТЧ.ВыгрузитьКолонку("Представление");
			МассивНовыхЗначений = НоваяТЧ.ВыгрузитьКолонку("Представление"); 
			Текст = ОписаниеСравненияМассивов(МассивСтарыхЗначений, МассивНовыхЗначений);
		Иначе 
			СписокКолонокСравнения = "";
			Для Каждого КолонкаТаблицы Из ТЧ.Реквизиты Цикл
				Если КолонкаТаблицы.Имя = "КлючСтроки" Тогда 
					Продолжить; 
				КонецЕсли;
				СписокКолонокСравнения = СписокКолонокСравнения + ?(СписокКолонокСравнения<>"", ",", "") + КолонкаТаблицы.Имя;
			КонецЦикла;				
			Текст = ОписаниеСравненияТаблиц(СтараяТЧ, НоваяТЧ, СписокКолонокСравнения);
		КонецЕсли;
	
		Если НЕ ПустаяСтрока(Текст) Тогда
			ОписаниеИзменений = ОписаниеИзменений+ ?(ПустаяСтрока(ОписаниеИзменений), "", Символы.ПС)+ ТЧ.Синоним + ": " +Текст + Символы.ПС;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОписаниеИзменений;
КонецФункции 

#КонецОбласти 
