&НаСервере
Функция ПолучитьДанныеОЗаметке(ИД)
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	Заметки.Автор КАК Автор
	               |ИЗ
	               |	РегистрСведений.Заметки КАК Заметки";
	Запрос.УстановитьПараметр("ИД", ИД);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат ?(Выборка.Следующий(), Выборка.Автор, Неопределено);
КонецФункции

