	ИначеЕсли КодОшибки = 1068 Тогда
		Возврат "Код подтверждения не действителен";
	ИначеЕсли КодОшибки = 1071 Тогда
		Возврат "Не задан массив записи";	
	ИначеЕсли КодОшибки = 1080 Тогда
		Возврат "Не найдено сотрудников, способных оказать переданный массив услуг";	
	ИначеЕсли КодОшибки = 1100 Тогда
		Возврат "Не найден сотрудник, который может оказать выбранную услугу";
	ИначеЕсли КодОшибки = 1101 Тогда
