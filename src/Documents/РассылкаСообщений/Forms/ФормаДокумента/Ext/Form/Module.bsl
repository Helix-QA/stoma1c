// Процедура - Заполнение получателей.
//
// Параметры:
//  Действие - 	 - 
//
Процедура ЗаполнениеПолучателей(Действие)
	
	Если ЗначениеЗаполнено(Объект.Получатели) Тогда
		
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаОПродолженииЗаполненияПолучателей", ЭтотОбъект, Новый Структура("Действие", Действие));
		
		ПоказатьВопрос(Оповещение, НСтр("ru='Будет очищена табличная часть, продолжить?'; en='123'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнениеПолучателейВыполнитьДействие(Действие);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - После вопроса о продолжении записи.
//
// Параметры:
//  Ответ		 - 	 -
//  ДопПараметры - 	 -
//
Процедура ПослеВопросаОПродолженииЗаполненияПолучателей(Ответ, ДопПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		Объект.Получатели.Очистить();
		ЗаполнениеПолучателейВыполнитьДействие(ДопПараметры.Действие);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Заполнение получателей выполнить действие.
//
// Параметры:
//  Действие - 	 - 
//
Процедура ЗаполнениеПолучателейВыполнитьДействие(Действие)
	
	Если Действие = "ЗаполнитьВсех" Тогда
		
		ЗаполнитьТаблицуПолучателей();
		
	ИначеЕсли Действие = "ЗаполнитьПоСегменту" Тогда
		
		Оповещение = Новый ОписаниеОповещения("ЗаполнитьПолучателейПоСегментуЗавершение", ЭтотОбъект);
		ОткрытьФорму("Справочник.СегментыКонтрагентов.Форма.ФормаВыбора",,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	ИначеЕсли Действие = "ЗаполнитьПоОтбору" Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ТаблицаПолучателей" , Объект.Получатели);
		ПараметрыФормы.Вставить("ОтправкаMessenger"  , Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер"));
		ПараметрыФормы.Вставить("ОтправкаSMS"        , Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS"));
		
		Оповещение = Новый ОписаниеОповещения("ЗаполнитьПолучателейПоОтборуЗавершение", ЭтотОбъект);
		
		ОткрытьФорму("Документ.РассылкаСообщений.Форма.ОтборПолучателей", ПараметрыФормы,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
