
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере".
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
			
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	РабочееМесто       = ПараметрыСеанса.РабочееМестоКлиента;
	
	Параметры.Свойство("КассоваяСмена", ЭтотОбъект.ОтборКассоваяСмена);
	
	ЭтотОбъект.ОтборПериод.Вариант = ВариантСтандартногоПериода.Сегодня;
	
	ЗаполнитьТаблицыДанных();
	
	Элементы.ЧекКоррекции.Видимость = РольДоступна("ПолныеПрава")
		ИЛИ РольДоступна("ДобавлениеИзменениеДокументовПоОплате")
		ИЛИ РольДоступна("ДобавлениеИзменениеДокументовПоФинансам")
		ИЛИ РольДоступна("ЧтениеДокументовПоФинансам");
		
	Элементы.ОтчетПоВыручке.Видимость = Элементы.ЧекКоррекции.Видимость ИЛИ РольДоступна("ОтчетыПоДенежнымСредствам");
	
КонецПроцедуры

&НаКлиенте
