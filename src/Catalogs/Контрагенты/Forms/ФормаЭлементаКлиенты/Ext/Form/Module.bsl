// Процедура, обработчик оповещения.
//
Процедура ЗавершитьРедактированиеЗаметкиНаСервере(ТекстЗаметки, ИдЗаметки, Сделка)
		
	Выборка = РегистрыСведений.Заметки.Выбрать(,,Новый Структура ("ИД", Новый УникальныйИдентификатор(ИдЗаметки)));	
	Пока Выборка.Следующий() Цикл
		СтруктураОтбора = Новый Структура();
		СтруктураОтбора.Вставить("Объект"			, Выборка.Объект);
		СтруктураОтбора.Вставить("АктивностьЗаметки", Выборка.АктивностьЗаметки);
		СтруктураОтбора.Вставить("Автор"			, Выборка.Автор);
		СтруктураОтбора.Вставить("Период"			, Выборка.Период);
		СтруктураОтбора.Вставить("Заметка"			, ТекстЗаметки);
		СтруктураОтбора.Вставить("Сделка"			, Сделка);
		СтруктураОтбора.Вставить("ИД"				, Выборка.ИД);
		СтруктураОтбора.Вставить("Закреплена"		, Выборка.Закреплена);
	КонецЦикла;
	
	ОбъектРегистрСведенийЗаметка = РегистрыСведений.Заметки.СоздатьНаборЗаписей();
	ОбъектРегистрСведенийЗаметка.ОбменДанными.Загрузка = Истина; 
	ОбъектРегистрСведенийЗаметка.Отбор.ИД.Установить(СтруктураОтбора.ИД);
	ЗаполнитьЗначенияСвойств(ОбъектРегистрСведенийЗаметка.Добавить(), СтруктураОтбора);
	ОбъектРегистрСведенийЗаметка.Записать(Истина);
	
КонецПроцедуры 

