
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ДанныеТелефонов") Тогда
		ДанныеТелефонов = Параметры.ДанныеТелефонов;
	КонецЕсли;
	
	// Не открываем форму если нет телефонов для выбора.
	Если Не ЗначениеЗаполнено(ДанныеТелефонов) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Для Каждого ДанныеТелефона Из ДанныеТелефонов Цикл
		СписокНомеров.Добавить(ДанныеТелефона, ДанныеТелефона.Представление,, БиблиотекаКартинок.ЗвонокИсходящийСиняя);
	КонецЦикла;
	
	Элементы.СписокНомеров.ВысотаВСтрокахТаблицы = ДанныеТелефонов.Количество();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокНомеров

&НаКлиенте
// Процедура, обработчик события "Выбор".
//
Процедура СписокНомеровВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Закрыть(Элемент.ТекущиеДанные.Значение);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура ВыбратьНомер(Команда)
	
	ТекущиеДанные = Элементы.СписокНомеров.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ТекстСообщения = НСтр("ru = 'Выберите номер телефона'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Закрыть(Элементы.СписокНомеров.ТекущиеДанные.Значение);
	
КонецПроцедуры

#КонецОбласти
