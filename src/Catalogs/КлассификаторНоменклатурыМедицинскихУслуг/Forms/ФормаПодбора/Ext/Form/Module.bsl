// Процедура, обработчик события "ПриИзменении".
//
Процедура Подключаемый_ПодборКлассификаторУслугПриИзменении(Элемент)
	
	ИмяКолонки = Элемент.Имя;
	ТекущиеДанные = Элементы._ПодборКлассификаторУслуг.ТекущиеДанные;
	Если ТекущиеДанные.ЭтоГруппа Тогда                      		
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли; 
		УстановитьФлагиНаЭлементы(ТекущиеДанные, ИмяКолонки);
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки, Истина);
	Иначе
		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли;		
		УстановитьФлагиНаГруппы(ТекущиеДанные, ИмяКолонки);			
	КонецЕсли;
	
	ТаблицаКлассификаторУслуг.Очистить();
	ДанныеДерева = ЭтаФорма._ПодборКлассификаторУслуг.ПолучитьЭлементы();
	Для Каждого СтрокаТЧ Из ДанныеДерева Цикл
		Если СтрокаТЧ.ЭтоГруппа Тогда
			ЗаполнитьТаблицуНоменклатуры(СтрокаТЧ);
		Иначе
			ЗаполнитьСтрокуТаблицыНоменклатуры(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры 

