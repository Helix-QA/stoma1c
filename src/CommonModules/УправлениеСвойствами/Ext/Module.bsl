				ДекорацияФормы_Заглушка.Заголовок 					= "";
				ДекорацияФормы_Заглушка.Гиперссылка 				= Ложь;
				ДекорацияФормы_Заглушка.ЦветТекста 					= ЦветаСтиля.ТекстВторостепеннойНадписи;
				ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Заглушка.Ширина 						= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.МаксимальнаяШирина       	= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали  	= Истина;
				
				// Создаем представление
				//--------------------------------------------------------------------------------------------		
				ДекорацияФормы_Представление = Элементы.Добавить("ПромокодыСуществующие_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаПромокодыСуществующие);
				ДекорацияФормы_Представление.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Представление.Заголовок                  = СформироватьПредставлениеЭлемента(Форма, СтрокаТЗ, ЭлементРодитель);
				ДекорацияФормы_Представление.Гиперссылка 				= Истина;
				ДекорацияФормы_Представление.ЦветТекста 				= ЦветаСтиля.ТекстВторостепеннойНадписи;
				ДекорацияФормы_Представление.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Представление.Ширина 					= 33;
				ДекорацияФормы_Представление.МаксимальнаяШирина        	= 33;
				ДекорацияФормы_Представление.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Представление.РастягиватьПоГоризонтали  	= Истина;
				
				ДекорацияФормы_Представление.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_Представление_Нажатие");								
				
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаСкидкиСуществующие" Тогда	
			
			#Область СОЗДАНИЕ_ЭЛЕМЕНТОВ_СКИДКИ
			
			СимвольноеПредставлениеВалюты = ОбщегоНазначения.ПолучитьСимвольноеПредставлениеВалюты();
			
			Для Каждого СтрокаТЗ Из Форма.СкидкиСуществующие Цикл
				
				ИндексСтроки = Форма.СкидкиСуществующие.Индекс(СтрокаТЗ);
				
				//  Создаем группу
				// --------------------------------------------------------------------------------------------		
				ГруппаСкидкиСуществующие = Элементы.Добавить("ГруппаСкидкиСуществующие_" + ИндексСтроки, Тип("ГруппаФормы"), ГруппаРодитель);
				ГруппаСкидкиСуществующие.Вид 				= ВидГруппыФормы.ОбычнаяГруппа;
				ГруппаСкидкиСуществующие.Заголовок 			= ГруппаСкидкиСуществующие.Имя;
				ГруппаСкидкиСуществующие.Отображение 		= ОтображениеОбычнойГруппы.Нет;
				ГруппаСкидкиСуществующие.Группировка 		= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				ГруппаСкидкиСуществующие.ОтображатьЗаголовок = Ложь;				
				
				ДекорацияФормы_Заглушка = Элементы.Добавить("СкидкиЗаглушка_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаСкидкиСуществующие);
				ДекорацияФормы_Заглушка.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Заглушка.Заголовок 					= "";
				ДекорацияФормы_Заглушка.Гиперссылка 				= Истина;
				ДекорацияФормы_Заглушка.ЦветТекста 					= Новый Цвет(100, 100, 100);
				ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Заглушка.Ширина 						= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.МаксимальнаяШирина       	= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали  	= Истина;
				ДекорацияФормы_Заглушка.Гиперссылка				  	= Ложь;
				
				//  Создаем тип скидки
				// --------------------------------------------------------------------------------------------		
				ДекорацияФормы_ТипСкидки = Элементы.Добавить("СкидкиТипСкидки_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаСкидкиСуществующие);
				ДекорацияФормы_ТипСкидки.Вид 						 = ВидДекорацииФормы.Надпись;
				ДекорацияФормы_ТипСкидки.Заголовок                   = СтрокаТЗ.ТипСкидки;
				ДекорацияФормы_ТипСкидки.ЦветТекста 				 = Новый Цвет(100, 100, 100);
				ДекорацияФормы_ТипСкидки.АвтоМаксимальнаяШирина      = Ложь;
				ДекорацияФормы_ТипСкидки.Ширина 					 = 9;
				ДекорацияФормы_ТипСкидки.МаксимальнаяШирина        	 = 9;
				ДекорацияФормы_ТипСкидки.ГоризонтальноеПоложение     = ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_ТипСкидки.РастягиватьПоГоризонтали    = Истина;

				//  Создаем представление
				// --------------------------------------------------------------------------------------------		
				ДекорацияФормы_Представление = Элементы.Добавить("СкидкиСуществующие_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаСкидкиСуществующие);
				ДекорацияФормы_Представление.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Представление.Заголовок                  = СтрокаТЗ.Представление;
				ДекорацияФормы_Представление.Гиперссылка 				= Истина;
				ДекорацияФормы_Представление.ЦветТекста 				= Новый Цвет(100, 100, 100);
				ДекорацияФормы_Представление.АвтоМаксимальнаяШирина    	= Ложь;
				//ДекорацияФормы_Представление.Ширина 					= 33;
				ДекорацияФормы_Представление.МаксимальнаяШирина        	= ?(СтрокаТЗ.ТипСкидки = "Персональная", 32, 33);
				ДекорацияФормы_Представление.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Представление.РастягиватьПоГоризонтали  	= Истина;
				
				ДекорацияФормы_Представление.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_Представление_Нажатие");
				
				//  Создаем представление значения
				// --------------------------------------------------------------------------------------------		
				Если СтрокаТЗ.ЗначениеСкидкиНаценки <> 0 Тогда
					
					Представление = Формат(СтрокаТЗ.ЗначениеСкидкиНаценки, "ЧЦ=15; ЧДЦ=2") + " " +
									?(СтрокаТЗ.СпособПредоставления = Перечисления.СпособПредоставленияСкидки.Сумма ИЛИ СтрокаТЗ.СпособПредоставления = Перечисления.СпособПредоставленияСкидки.СуммаНаДокумент, СимвольноеПредставлениеВалюты, "%");
					
					ДекорацияФормы_ПредставлениеОстатка = Элементы.Добавить("ДекорацияФормы_Представление_Значение_" + ИндексСтроки, Тип("ДекорацияФормы"), ГруппаСкидкиСуществующие);
					ДекорацияФормы_ПредставлениеОстатка.Вид 							= ВидДекорацииФормы.Надпись;
					ДекорацияФормы_ПредставлениеОстатка.Заголовок                  		= Представление;
					ДекорацияФормы_ПредставлениеОстатка.Ширина 							= 9;
					ДекорацияФормы_ПредставлениеОстатка.Высота 							= 1;
					ДекорацияФормы_ПредставлениеОстатка.ЦветТекста 						= ЦветаСтиля.ТекстВторостепеннойНадписи;				
					ДекорацияФормы_ПредставлениеОстатка.ГоризонтальноеПоложение			= ГоризонтальноеПоложениеЭлемента.Право;				
					ДекорацияФормы_ПредставлениеОстатка.ГоризонтальноеПоложениеВГруппе 	= ГоризонтальноеПоложениеЭлемента.Право;
					ДекорацияФормы_ПредставлениеОстатка.РастягиватьПоВертикали 			= Ложь;
					ДекорацияФормы_ПредставлениеОстатка.РастягиватьПоГоризонтали		= Ложь;
					
				КонецЕсли;
				
				Если СтрокаТЗ.ТипСкидки = "Персональная" Тогда
					
					//  добавить кнопку Удалить
					//ГруппаКомандыУдалить = Неопределено;
					//Если Элементы.Найти("ГруппаКомандаУдалить_" + ИндексСтроки) <> Неопределено Тогда		
					//	ГруппаКомандыУдалить = Элементы.Найти("ГруппаКомандаУдалить_" + ИндексСтроки);
					//Иначе		
					//	ГруппаКомандыУдалить                     = Элементы.Вставить("ГруппаКомандаУдалить_" + ИндексСтроки, Тип("ГруппаФормы"), ГруппаСкидкиСуществующие);
					//	ГруппаКомандыУдалить.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
					//	ГруппаКомандыУдалить.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
					//	ГруппаКомандыУдалить.Отображение         = ОтображениеОбычнойГруппы.Нет;
					//	ГруппаКомандыУдалить.ОтображатьЗаголовок = Ложь;	
					//КонецЕсли;
					
					КнопкаУдаленияСкидки                     = Элементы.Добавить("Удалить_" + ИндексСтроки, Тип("КнопкаФормы"), ГруппаСкидкиСуществующие);
					КнопкаУдаленияСкидки.Отображение         = ОтображениеКнопки.Картинка;
					КнопкаУдаленияСкидки.ОтображениеФигуры 	 = ОтображениеФигурыКнопки.Нет;
					КнопкаУдаленияСкидки.ИмяКоманды          = "УдалитьСтрокуСкидка";
					
				КонецЕсли;
				
			КонецЦикла;
			
			#КонецОбласти
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

//  Процедура - Очистить группу от созданных элементов
// 
//  Параметры:
//   Элементы		 - 	 - 
//   ЭлементРодитель	 - 	 - 
// 
Процедура ОчиститьГруппуОтСозданныхЭлементов(Элементы, Знач ГруппаРодитель)
	
	УдаляемыеЭлементы = Новый Массив;		
	Для Каждого ГруппаЭлементов Из ГруппаРодитель.ПодчиненныеЭлементы Цикл
		Если ГруппаЭлементов.Имя = "ГруппаСсылкаОплаты" Тогда
			Продолжить;
		КонецЕсли;
		
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

//  Процедура - Сформировать представление элемента
// 
//  Параметры:
//   СтрокаТЗ		 - 	 - 
//   ЭлементРодитель	 - 	 - 
// 
Функция СформироватьПредставлениеЭлемента(Форма, Знач СтрокаТЗ, Знач ЭлементРодитель) Экспорт
		
	Валюта = ?(ЗначениеЗаполнено(ОбщегоНазначения.ПолучитьСимвольноеПредставлениеВалюты()), ОбщегоНазначения.ПолучитьСимвольноеПредставлениеВалюты(),
																						  ОбщегоНазначения.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
	Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" Тогда
		
		Возврат СокрП(Строка(СтрокаТЗ.ВидДокумента)) + ?(ЗначениеЗаполнено(СтрокаТЗ.Серия), ", " + Строка(СтрокаТЗ.Серия), "") + " " + Строка(СтрокаТЗ.Номер) 
											  + ?(ЗначениеЗаполнено(СтрокаТЗ.ДатаВыдачи), ", выдан "+ Формат(СтрокаТЗ.ДатаВыдачи, "ДФ='dd.MM.yyyy'") + " г. ", "")	
											  + Строка(СтрокаТЗ.КемВыдан) 
											  + ?(ЗначениеЗаполнено(СтрокаТЗ.ДатаОкончания), " до " + Формат(СтрокаТЗ.ДатаОкончания, "ДФ='dd.MM.yyyy'") + " г. ", "");
		
	ИначеЕсли ЭлементРодитель = "ГруппаКартыСуществующие" Тогда	
		
		ЭтоКартаWallet = ЗначениеЗаполнено(СтрокаТЗ.ВидКарты.ИдентификаторПроекта);
		
		Возврат Строка(СтрокаТЗ.ВидКарты) + " " + ?(ЗначениеЗаполнено(СтрокаТЗ.ВнутреннийКодКарты) И Не ЭтоКартаWallet, Строка(СтрокаТЗ.ВнутреннийКодКарты), Строка(СтрокаТЗ.КодКарты));
		
	ИначеЕсли ЭлементРодитель = "ГруппаРодственникиСуществующие" Тогда 
		
		Возврат Строка(СтрокаТЗ.Родственник) + " (" + Строка(СтрокаТЗ.СтепеньРодства) + ")";
		
	ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробно" Тогда
		
		СтроковоеПредставление = "";
		Если СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда 
			СтроковоеПредставление = "Сертификат № " + Строка(СтрокаТЗ.ВладелецАванса) + " " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
			СтроковоеПредставление = "Карта " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПустаяСсылка() И ТипЗнч(СтрокаТЗ.ДокументОплаты) = Тип("ДокументСсылка.КорректировкаДолга") Тогда
			СтроковоеПредставление = "Списание " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
			СтроковоеПредставление = "Нал. " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
			СтроковоеПредставление = "Лиц. счет " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;	
		ИначеЕсли СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			СтроковоеПредставление = "Безнал. " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		Иначе
			СтроковоеПредставление = Строка(НРег(СтрокаТЗ.ТипДенежныхСредств)) + " " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтроковоеПредставление) Тогда 
			
			Если НЕ НачалоДня(Форма.Объект.Дата) = НачалоДня(СтрокаТЗ.ДатаПлатежа) Тогда 
				
				Если СтрокаТЗ.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ВСчетЗарплаты Тогда
				    СтроковоеПредставление = СтроковоеПредставление + " за " + Формат(СтрокаТЗ.ДатаПлатежа, "ДФ='MMMM yyyy'");
				Иначе
				    СтроковоеПредставление = СтроковоеПредставление + Формат(СтрокаТЗ.ДатаПлатежа, "ДФ=' (dd.MM.yyyy)'");
				КонецЕсли;
			КонецЕсли;	
			
		КонецЕсли;
		
		Возврат СтроковоеПредставление;	
		
	ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробноДоговор" Тогда
		
		СтроковоеПредставление = Формат(СтрокаТЗ.ДатаПлатежа, "ДЛФ=D") + ": " + Формат(СтрокаТЗ.СуммаОплачено, "ЧДЦ=2") + " " + Валюта;
		Возврат СтроковоеПредставление;
		
	ИначеЕсли ЭлементРодитель = "ГруппаМедСправкиСуществующие" Тогда	
		
		ДатаОкончанияМедСправки = НачалоДня(ДобавитьМесяц(СтрокаТЗ.ДатаВыдачи, СтрокаТЗ.МедСправка.СрокДействия));
		Возврат "" + СтрокаТЗ.МедСправка + ", выдана " + Формат(СтрокаТЗ.ДатаВыдачи, "ДФ='dd.MM.yyyy'") + " до " + Формат(ДатаОкончанияМедСправки, "ДФ='dd.MM.yyyy'");    
		
	ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" Тогда
		СтроковоеПредставление = СтрокаТЗ.ПромокодСсылка.Наименование + ?(СтрокаТЗ.ПромокодСсылка.ПометкаУдаления, НСтр("ru = ' (удален)'; en = ' (deleted)'"), "") + ": " + СтрокаТЗ.Промокод;
		Возврат СтроковоеПредставление;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ОТОБРАЖЕНИЕ_ТАБЛИЧНЫХ_ЧАСТЕЙ


//  Процедура - Обновить отображение табличных частей
// 
//  Параметры:
//   Форма			 - 	 - 
//   ВладелецСсылка	 - 	 - 
//   МассивПараметров - 	 - 
// 
Процедура ОбновитьОтображениеТабличныхЧастей(Форма, Знач ВладелецСсылка = Неопределено, Знач МассивТабличныхЧастей = Неопределено) Экспорт
	
	//  Выходим если параметры не переданы
	Если МассивТабличныхЧастей = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	//  Определяем владельца формы
	Если ВладелецСсылка = Неопределено Тогда
		ВладелецСсылка = Форма.Объект.Ссылка;
	ИначеЕсли НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда  
		Возврат;
	КонецЕсли;
	
	//  Создание таблиц-реквизитов формы, если отсутствуют	
	ДобавитьРеквизитыФормы(Форма);
	
	//  Пересоздание элементов формы по информации из таблицы для отображения
	ОбновитьДинамическиеЭлементыТабличныхЧастей(Форма, ВладелецСсылка, МассивТабличныхЧастей);	
	
КонецПроцедуры

//  Процедура - Добавить реквизиты формы
// 
//  Параметры:
//   Форма	 - 	 - 
// 
Процедура ДобавитьРеквизитыФормы(Форма)
	
	//  Вычисляем существующие реквизиты
	СписокРеквизитовФормы = Форма.ПолучитьРеквизиты();
	
	СоздатьТаблицуВремениОжидания = Истина;
	
	Для Каждого Реквизит Из СписокРеквизитовФормы Цикл
		Если Реквизит.Имя = "Таблица_ВремениОжидания" 	Тогда
			СоздатьТаблицуВремениОжидания = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	//  Создаем реквизиты формы
	МассивДобавляемыхРеквизитов = Новый Массив;
	
	Если СоздатьТаблицуВремениОжидания Тогда 
		
		ИмяТаблицы = "Таблица_ВремениОжидания";
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КлючСтроки"				, Новый ОписаниеТипов("УникальныйИдентификатор"), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВремяОжидания"			, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(4, 0, ДопустимыйЗнак.Неотрицательный)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Надпись"	            	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВремяОжидания_Текст"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)), ИмяТаблицы));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаНачалаОжидания"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10)), ИмяТаблицы));
	Иначе 
		Форма.Таблица_ВремениОжидания.Очистить();
	КонецЕсли;
	
	Если МассивДобавляемыхРеквизитов.Количество() > 0 Тогда
		Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

//  Процедура, перестраивает динамические элементы в визите.
// 
Процедура ОбновитьДинамическиеЭлементыТабличныхЧастей(Форма, ВладелецСсылка, МассивТабличныхЧастей)
	
	Элементы 	   					  = Форма.Элементы;
	ДокументЗакрыт 					  = Форма.ДокументЗакрыт;
	
	Для Каждого ПараметрыТабличнойЧасти Из МассивТабличныхЧастей Цикл 
		
		ГруппаРодительТабличнойЧасти = Элементы.Найти(ПараметрыТабличнойЧасти.ГруппаДляРазмещения);
		
		//  Пропускаем если нет группы для размещения или нет указанной табличной части
		Если ГруппаРодительТабличнойЧасти = Неопределено
			ИЛИ ВладелецСсылка.Метаданные().ТабличныеЧасти.Найти(ПараметрыТабличнойЧасти.ТабличнаяЧасть) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		//  Удалим элементы
		УдаляемыеЭлементы = Новый Массив;
		Для Каждого ГруппаЭлементов Из ГруппаРодительТабличнойЧасти.ПодчиненныеЭлементы Цикл
			
			Если ГруппаЭлементов.Имя <> "ГруппаОтменаВизитаПредварительнаяСтоимость" Тогда 
				УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
			КонецЕсли;	
			
		КонецЦикла;
		
		Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
			Элементы.Удалить(УдаляемыйЭлемент);
		КонецЦикла;
		
		//  Выводим элементы
		ПредыдущаяСтрока = Неопределено;
		
		Для Каждого СтрокаТЧ Из Форма.Объект[ПараметрыТабличнойЧасти.ТабличнаяЧасть] Цикл 
			
			Номенклатура = СтрокаТЧ.Номенклатура;
			Если ЗначениеЗаполнено(Номенклатура) 
				И (Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга 
				   ИЛИ Номенклатура.НормаВремени = 0) Тогда 
				   
				Продолжить;
			КонецЕсли;
			
			ПробитПоФР = ЗначениеЗаполнено(Форма.Объект.НомерЧекаККМ) Или Форма.Объект.УчтенныеАвансы.Итог("НомерЧекаККМ") > 0;
            ТолькоПросмотрПоля = ?(ПробитПоФР, Истина, ЗначениеЗаполнено(СтрокаТЧ.Курс));
		   	ИндексСтрокиТЧ        = Форма.Объект[ПараметрыТабличнойЧасти.ТабличнаяЧасть].Индекс(СтрокаТЧ);
			НоменклатураЗаполнена = ЗначениеЗаполнено(Номенклатура) ИЛИ ИндексСтрокиТЧ = 0;
			
			ВремяОжидания = 0;
			ИспользоватьФункционалSPA = ПолучитьФункциональнуюОпцию("ИспользоватьФункционалSPA");
			ИспользоватьРесурсы    	  = ПолучитьФункциональнуюОпцию("ИспользоватьРесурсы");
			
			Если ПредыдущаяСтрока <> Неопределено Тогда
				ВремяОжидания = ПолучитьВремяОжидания(СтрокаТЧ, Форма.Объект[ПараметрыТабличнойЧасти.ТабличнаяЧасть], ПредыдущаяСтрока);
			КонецЕсли;
					
			Если ВремяОжидания > 0 Тогда
				ДатаНачалаОжидания = Формат(ПредыдущаяСтрока.ДатаНачала + ПредыдущаяСтрока.НормаВремени * 60, "ДФ=HH:мм"); 
				ВывестиВремяОжидания(Форма, ГруппаРодительТабличнойЧасти, ПараметрыТабличнойЧасти, СтрокаТЧ.КлючСтроки, ВремяОжидания, ДатаНачалаОжидания, ИндексСтрокиТЧ);
			КонецЕсли;
			
			ПредставлениеТЧ = ПараметрыТабличнойЧасти.ТабличнаяЧасть + "_" + ИндексСтрокиТЧ;
			
			//  Создаем общую группу для строки ТЧ
			ГруппаСтрокиТабличнойЧасти = Элементы.Добавить("Группа_СтрокаТЧ_" + ПредставлениеТЧ, Тип("ГруппаФормы"), ГруппаРодительТабличнойЧасти);
			ГруппаСтрокиТабличнойЧасти.Вид 												= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаСтрокиТабличнойЧасти.Заголовок 										= ГруппаСтрокиТабличнойЧасти.Имя;
			ГруппаСтрокиТабличнойЧасти.Отображение 										= ОтображениеОбычнойГруппы.Нет;
			ГруппаСтрокиТабличнойЧасти.Группировка 										= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаСтрокиТабличнойЧасти.ОтображатьЗаголовок 								= Ложь;
			ГруппаСтрокиТабличнойЧасти.ГоризонтальноеПоложениеПодчиненных 				= ГоризонтальноеПоложениеЭлемента.Лево;
			ГруппаСтрокиТабличнойЧасти.ГоризонтальныйИнтервал 							= ИнтервалМеждуЭлементамиФормы.Одинарный;
			
			Если Не НоменклатураЗаполнена Тогда
				
				ДекорацияФормы_Заглушка_НоваяСтрока = Форма.Элементы.Добавить("ДекорацияФормы_Заглушка_НоваяСтрока_ТЧ_" + ПредставлениеТЧ, Тип("ДекорацияФормы"), ГруппаСтрокиТабличнойЧасти);
				ДекорацияФормы_Заглушка_НоваяСтрока.Вид 									= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Заглушка_НоваяСтрока.Заголовок 							    = "";
			    ДекорацияФормы_Заглушка_НоваяСтрока.АвтоМаксимальнаяШирина                  = Ложь;
				ДекорацияФормы_Заглушка_НоваяСтрока.МаксимальнаяШирина                      = 10;
				ДекорацияФормы_Заглушка_НоваяСтрока.Ширина                                  = 10;

			КонецЕсли;			
			
			//  Создаем поле признака блокировки строки ТЧ.
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти = Элементы.Добавить("Группа_Блокировки_СтрокаТЧ_" + ПредставлениеТЧ, Тип("ГруппаФормы"), ГруппаСтрокиТабличнойЧасти);
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.Заголовок 							= ГруппаПоляБлокировкиСтрокиТабличнойЧасти.Имя;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.Отображение 						= ОтображениеОбычнойГруппы.Нет;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.ОтображатьЗаголовок 				= Ложь;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.РастягиватьПоГоризонтали 			= Ложь;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.Ширина                             = 2;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.ВертикальныйИнтервал               = ИнтервалМеждуЭлементамиФормы.Полуторный;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.ГоризонтальноеПоложениеВГруппе     = ГоризонтальноеПоложениеЭлемента.Центр;
			ГруппаПоляБлокировкиСтрокиТабличнойЧасти.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Центр;
			
			Если ИндексСтрокиТЧ = 0 Тогда 
				ДекорацияФормы_Заглушка_БлокироватьСтроку = Форма.Элементы.Добавить("ДекорацияФормы_Заглушка_Блокировать_ТЧ_" + ПредставлениеТЧ, Тип("ДекорацияФормы"), ГруппаПоляБлокировкиСтрокиТабличнойЧасти);
				ДекорацияФормы_Заглушка_БлокироватьСтроку.Вид       = ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Заглушка_БлокироватьСтроку.Заголовок = "";
				ДекорацияФормы_Заглушка_БлокироватьСтроку.Шрифт     = Новый Шрифт("Arial", 5); 
			КонецЕсли;
			
			ПолеФормы_БлокироватьСтроку = Элементы.Добавить("ПолеФормы_БлокироватьСтроку_ТЧ_" + ПредставлениеТЧ, Тип("ПолеФормы"), ГруппаПоляБлокировкиСтрокиТабличнойЧасти);
			ПолеФормы_БлокироватьСтроку.Вид                            = ВидПоляФормы.ПолеКартинки;
			ПолеФормы_БлокироватьСтроку.ПутьКДанным                    = "Объект." + ПараметрыТабличнойЧасти.ТабличнаяЧасть + "["+ Строка(ИндексСтрокиТЧ) + "]" + ".ПризнакЗаблокировано";
			ПолеФормы_БлокироватьСтроку.ПоложениеЗаголовка             = ПоложениеЗаголовкаЭлементаФормы.Нет;
			ПолеФормы_БлокироватьСтроку.КартинкаЗначений               = БиблиотекаКартинок.КоллекцияКартинокБлокировка;
			ПолеФормы_БлокироватьСтроку.Гиперссылка                    = Истина;
			ПолеФормы_БлокироватьСтроку.Ширина                         = 2;
			ПолеФормы_БлокироватьСтроку.Рамка                          = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
			ПолеФормы_БлокироватьСтроку.РастягиватьПоГоризонтали       = Ложь;
			ПолеФормы_БлокироватьСтроку.РастягиватьПоВертикали         = Ложь;
			ПолеФормы_БлокироватьСтроку.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
			
			ПолеФормы_БлокироватьСтроку.УстановитьДействие("Нажатие", "Подключаемый_БлокироватьСтрокуТабличнойЧасти");
			
			// Создаем поле времени начала.
			ПолеФормы_ВремяНачала = Элементы.Добавить("ПолеФормы_ВремяНачала_ТЧ_" + ПредставлениеТЧ, Тип("ПолеФормы"), ГруппаСтрокиТабличнойЧасти);
			ПолеФормы_ВремяНачала.Вид 								   = ВидПоляФормы.ПолеВвода;
			ПолеФормы_ВремяНачала.ПутьКДанным 						   = "Объект." + ПараметрыТабличнойЧасти.ТабличнаяЧасть + "["+ Строка(ИндексСтрокиТЧ) + "]" + ".ДатаНачала";
			ПолеФормы_ВремяНачала.Заголовок 						   = "Время";
			ПолеФормы_ВремяНачала.Подсказка							   = "Время начала";
			ПолеФормы_ВремяНачала.ПоложениеЗаголовка 				   = ?(ИндексСтрокиТЧ = 0, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
			ПолеФормы_ВремяНачала.КнопкаОткрытия 					   = Ложь;
			ПолеФормы_ВремяНачала.КнопкаВыбора				    	   = Ложь;
			ПолеФормы_ВремяНачала.КнопкаВыпадающегоСписка 			   = Истина;
			ПолеФормы_ВремяНачала.РежимВыбораИзСписка                  = Истина;
			ПолеФормы_ВремяНачала.АвтоМаксимальнаяШирина 			   = Ложь;
			ПолеФормы_ВремяНачала.МаксимальнаяШирина 				   = 6;
			ПолеФормы_ВремяНачала.ШиринаВыпадающегоСписка 			   = 7;
			ПолеФормы_ВремяНачала.АвтоОтметкаНезаполненного 		   = Истина;
			ПолеФормы_ВремяНачала.Видимость                            = НоменклатураЗаполнена;
			
			ПолеФормы_ВремяНачала.УстановитьДействие("ПриИзменении"	  , "ЗапасыДатаНачалаПриИзменении");
			ПолеФормы_ВремяНачала.УстановитьДействие("НачалоВыбора"	  , "ЗапасыДатаНачалаНачалоВыбора");
			ПолеФормы_ВремяНачала.УстановитьДействие("ОбработкаВыбора", "ЗапасыДатаНачалаОбработкаВыбора");
			
			Форма.ЗаполнитьСписокВремениНачалаУслуг(ПолеФормы_ВремяНачала, СтрокаТЧ);
			
			ГруппаНоменклатуры =  Элементы.Добавить("Группа_Номенклатура_" + ИндексСтрокиТЧ, Тип("ГруппаФормы"), ГруппаСтрокиТабличнойЧасти);
			ГруппаНоменклатуры.Вид 												= ВидГруппыФормы.ОбычнаяГруппа;			
			ГруппаНоменклатуры.Отображение 										= ОтображениеОбычнойГруппы.Нет;
			ГруппаНоменклатуры.Группировка 										= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
			ГруппаНоменклатуры.ОтображатьЗаголовок 								= Ложь;  
			
			ПолеФормы_Номенклатура = Элементы.Добавить("ПолеФормы_Номенклатура_ТЧ_" + ПредставлениеТЧ, Тип("ПолеФормы"), ГруппаНоменклатуры);
			ПолеФормы_Номенклатура.Вид 											= ВидПоляФормы.ПолеВвода;
			ПолеФормы_Номенклатура.ПутьКДанным 									= "Объект." + ПараметрыТабличнойЧасти.ТабличнаяЧасть + "["+ Строка(ИндексСтрокиТЧ) + "]" + ".Номенклатура";
			ПолеФормы_Номенклатура.Заголовок 								    = "Услуга";			
			ПолеФормы_Номенклатура.ПоложениеЗаголовка 							= ?(ИндексСтрокиТЧ = 0, ПоложениеЗаголовкаЭлементаФормы.Верх, ПоложениеЗаголовкаЭлементаФормы.Нет);
			ПолеФормы_Номенклатура.АвтоМаксимальнаяШирина 						= Ложь;
			
			Если ИспользоватьРесурсы = Истина И ИспользоватьФункционалSPA = Истина Тогда
				МаксимальнаяШирина = 22;
			ИначеЕсли ИспользоватьФункционалSPA = Истина Тогда
				МаксимальнаяШирина = 30;
			Иначе
				МаксимальнаяШирина = 50;
			КонецЕсли;
			
			ПолеФормы_Номенклатура.МаксимальнаяШирина 							= МаксимальнаяШирина;
			ПолеФормы_Номенклатура.ПодсказкаВвода 								= "Выберите услугу";
			ПолеФормы_Номенклатура.АвтоОтметкаНезаполненного 					= Ложь;
			ПолеФормы_Номенклатура.БыстрыйВыбор                                 = Ложь;
