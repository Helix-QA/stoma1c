// Процедура - Прослушать запись
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПрослушатьЗапись(Команда)
	
	Если ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.ФайлЗаписи) Тогда
		ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(ПараметрыТелефонногоЗвонка.ФайлЗаписи); // ПолучитьРабочийКаталог()
		РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
	ИначеЕсли ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.URLЗаписи) Тогда 
		АктуальныйURLЗаписи = IPТелефонияКлиент.ПолучитьАктуальныйURLЗаписиROSTELECOMКлиент(ПараметрыТелефонногоЗвонка.URLЗаписи, IDЗвонка, ПОIPТелефонии);
		Оповещение = Новый ОписаниеОповещения(,,, "ОтобразитьОшибку", ЭтотОбъект);
		НачатьЗапускПриложения(Оповещение, АктуальныйURLЗаписи);
	КонецЕсли;	
	
КонецПроцедуры

