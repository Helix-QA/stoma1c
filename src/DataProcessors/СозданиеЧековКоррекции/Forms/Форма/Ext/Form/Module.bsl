&НаСервере
// Процедура - создает чеки на сервере.
//
Функция СоздатьЧекиСервер()
	
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат Ложь;
	Иначе
		Возврат Обработки.СозданиеЧековКоррекции.СоздатьЧекиКоррекции(Объект);
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура - выполняет пробитие чека.
//
Процедура ПробитьЧекВыполнить(ЧекКоррекции, ПробиватьСледующийЧек = Истина)
	
	ФормированиеЧека = ПодготовитьДанныеДляПробитияЧека(ЧекКоррекции);
	Если ФормированиеЧека.Результат Тогда
		ИдентификаторУстройства = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(Объект.Касса);
		Если ФормированиеЧека.Свойство("ФискальныйЧек") Тогда     			
			ОбщиеПараметры = ФормированиеЧека.ФискальныйЧек;      
			ПараметрыОповещения = Новый Структура("ПробиватьСледующийЧек"			, ПробиватьСледующийЧек);
			Оповещение = Новый ОписаниеОповещения("ПробитьЧекВыполнитьЗавершение"	, ЭтотОбъект, ПараметрыОповещения);
			МенеджерОборудованияКлиент.НачатьФискализациюЧекаНаФискальномУстройстве(Оповещение, УникальныйИдентификатор, ОбщиеПараметры, ИдентификаторУстройства);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

