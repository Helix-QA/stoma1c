// Импорт из текстового файла

// Работа с текстовым файлом
&НаКлиенте
Функция ПолучитьПоляФайла()
	
	Если ТипФайлаИмпорта="TEXT" Тогда
		
		// Читаем первую строку файла содержащую наименования колонок
		Текст = Новый ЧтениеТекста(ФайлИмпорта);
		Стр = Текст.ПрочитатьСтроку();
		Если Стр=Неопределено Тогда
			
			ПоказатьПредупреждение(,"Файл импорта пуст ! импорт не возможен !");
			Возврат Ложь;
		КонецЕсли;	 
		
		СписокКолонокФайла = СтрокаВСписок(Стр, СимволРазделитель);
	Иначе
		
		СписокКолонокФайла = ПолчитьПоляИзExcel();
	КонецЕсли;
	
	Если СписокКолонокФайла.Количество() = 0 Тогда 
		
		ПоказатьПредупреждение(,"Файл импорта пуст ! импорт не возможен !");
		Возврат Ложь;
	Иначе
		
		Возврат Истина;	   
	КонецЕсли; 
	
КонецФункции

// Получить строку реквизитов из текстового файла
&НаКлиенте
Функция ЗагрузитьИзТекста()
	
	Попытка
		
		// Выводим оповещение, т.к. показать прогресс в случае с текстовым файлом затруднительно
		ПоказатьОповещениеПользователя("Выполнение импорта данных", , "Производится загрузка данных из файла. Это может занять некоторое время.", БиблиотекаКартинок.Информация32);
		
		Текст = Новый ЧтениеТекста(ФайлИмпорта);
		Стр = Текст.ПрочитатьСтроку();
		Стр = Текст.ПрочитатьСтроку(); 
		
		СтруктураРеквизитов = Новый Структура();
		
		Пока Стр <> Неопределено Цикл
			
			СписокДанных = СтрокаВСписок(Стр, СимволРазделитель);
			Индекс = 0;
			Пока Индекс < Объект.ТаблицаСоответсвийПолей.Количество() Цикл
				
				Строка 		= Объект.ТаблицаСоответсвийПолей[Индекс];
				Реквизит 	= СтрЗаменить(Строка.РеквизитСправочника," ","");
				Реквизит 	= СтрЗаменить(Реквизит,"*","");	
				
				Если Строка.КолонкаФайла <> "" Тогда
					Идентификатор = СписокКолонокФайла.НайтиПоЗначению(Строка.КолонкаФайла).ПолучитьИдентификатор();
					СтруктураРеквизитов.Вставить(Реквизит, СписокДанных[Идентификатор].Значение);
				Иначе   
					СтруктураРеквизитов.Вставить(Реквизит, "");
				КонецЕсли;	   
				
				Индекс = Индекс + 1;
			КонецЦикла;
			
			ОбщегоНазначенияКлиентСерверСтоматология.УдалитьНедопустимыеСимволыXMLРабочая(Стр, "");
			
			ЗаполнитьРеквизитыСправочника(СтруктураРеквизитов, Стр, ВидМедицинскихКарт);
			Стр = Текст.ПрочитатьСтроку();
			
		КонецЦикла;
	Исключение 
		ТекстИсключение = ОписаниеОшибки();
		ПоказатьПредупреждение(,"Ошибка обработки файла: " + ТекстИсключение);
		Возврат неопределено;	
	КонецПопытки;	
	
	Возврат Истина;
	
КонецФункции

//////////////////////////////////////////////////////////////////////////////
// Процесс импорта

&НаКлиенте
// Процедура - Старт импорта
//
Процедура СтартИмпорта(Команда)
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ФайлИмпорта) Тогда 		
		ПоказатьПредупреждение(,"Укажите файл импорта");
		Возврат;		
	КонецЕсли;
	
	Если  ВыборПапкиСправочника.Пустая() = Истина Тогда
		ПоказатьПредупреждение(,"Укажите папку справочника");
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.СтраховаяКомпания) Тогда 		
		ПоказатьПредупреждение(,"Укажите страховую компанию");
		Возврат;		
	КонецЕсли;
	
	ПроверятьЗаполнениеФИО = Истина;
	
	ТаблицаСоответствийПолей = Объект.ТаблицаСоответсвийПолей;
	РезультатПроверки = ВернутьНезаполненныеОбязательныеПоляТаблицыСоответствий(ТаблицаСоответствийПолей, ПроверятьЗаполнениеФИО, ЭтотОбъект.ПоискПоТипу);
	
	Если ПроверятьЗаполнениеФИО И РезультатПроверки.Свойство("Стр_НезаполненныеРеквизитыФИО") И ЗначениеЗаполнено(РезультатПроверки.Стр_НезаполненныеРеквизитыФИО) Тогда
		
		ФИОЗаполнено = НЕ РезультатПроверки.Стр_НезаполненныеРеквизитыФИО.Свойство("ФИО");
		
		ПроверкаЗаполненияФИО = ?(РезультатПроверки.Стр_НезаполненныеРеквизитыФИО.Свойство("Фамилия"), 0, 1) + 
							  + ?(РезультатПроверки.Стр_НезаполненныеРеквизитыФИО.Свойство("Имя"), 0, 1) +
							  + ?(РезультатПроверки.Стр_НезаполненныеРеквизитыФИО.Свойство("Отчество"), 0, 1);
		
		Если НЕ ФИОЗаполнено И ПроверкаЗаполненияФИО = 0 Тогда
			
			ПоказатьПредупреждение(,"Заполните поля ФИО или Фамилия, Имя, Отчество");			
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если РезультатПроверки.Свойство("Строка_НезаполненныеРеквизиты") И ЗначениеЗаполнено(РезультатПроверки.Строка_НезаполненныеРеквизиты) Тогда
		
		ПоказатьПредупреждение(,"Заполните следующие реквизиты в таблице соответствий: " + РезультатПроверки.Строка_НезаполненныеРеквизиты + ".");
	    Возврат;
		
	КонецЕсли;
		
	Если ФлагРазрешенияИмпорта = Истина Тогда
		СчетчикИмпортируемыхОбъектов = 0;
		Результат = Ложь;
		
		Если ТипФайлаИмпорта = "TEXT" Тогда
			
			Результат = ЗагрузитьИзТекста();
		Иначе
			Результат = ЗагрузитьИзExcel();
		КонецЕсли;	
		
		Если Результат = Истина Тогда	
			
			ПоказатьПредупреждение(,"Операция импортирования завершена успешно. Обновлено объектов: "+Формат(СчетчикИмпортируемыхОбъектов, "ЧН=0"));
		КонецЕсли;	 
	Иначе
		
		ПоказатьПредупреждение(,"Операция не возможна в связи с неверными настройками импортирования");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Вернуть незаполненные обязательные поля таблицы соответствий
//
Функция ВернутьНезаполненныеОбязательныеПоляТаблицыСоответствий(ТаблицаСоответсвийПолей, ВключатьПроверкуФИОВРезультат = Ложь, ПоискПоТипу)
	
	ТаблицаСоответсвийПолей_ТаблицаЗначений = ТаблицаСоответсвийПолей.Выгрузить(); 	
	ОбязательныеПоля = ТаблицаСоответсвийПолей_ТаблицаЗначений.НайтиСтроки(Новый Структура("ОтметкаНезаполненного", Истина));
	
	Если НЕ ПоискПоТипу = 1 Тогда
		
		ПолеПоиска = ?(ПоискПоТипу = 2, "Дата рождения", "Телефон");
		ДопСтрока = ТаблицаСоответсвийПолей_ТаблицаЗначений.НайтиСтроки(Новый Структура("РеквизитСправочника", ПолеПоиска)); 	
		Если ЗначениеЗаполнено(ДопСтрока) Тогда		
			ОбязательныеПоля.Добавить(ДопСтрока[0]); 			
		КонецЕсли;
		
	КонецЕсли;
	// ВозвращаемыйМассивР = Новый Массив;
	ПредставлениеНезаполненных = "";
	Если ВключатьПроверкуФИОВРезультат Тогда
		ВозвращаемаяСтруктураФИО = Новый Структура;
	КонецЕсли;
	
	Для Каждого СтрокаТ Из ОбязательныеПоля Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаТ.КолонкаФайла) Тогда
			
			Если СтрокаТ.РеквизитСправочника = "ФИО" ИЛИ
				 СтрокаТ.РеквизитСправочника = "Фамилия" ИЛИ
				 СтрокаТ.РеквизитСправочника = "Имя" ИЛИ
				 СтрокаТ.РеквизитСправочника = "Отчество" Тогда
				 
				Если ВключатьПроверкуФИОВРезультат = Истина Тогда 
					// ВозвращаемыйМассивФИО.Добавить(СтрокаТ.РеквизитСправочника);
					ВозвращаемаяСтруктураФИО.Вставить(СтрокаТ.РеквизитСправочника, Ложь);
				КонецЕсли;
				
			Иначе
				ПредставлениеНезаполненных = "" + ПредставлениеНезаполненных + """" + СтрокаТ.РеквизитСправочника + """, "; 
				// ВозвращаемыйМассивР.Добавить(СтрокаТ.РеквизитСправочника);		 				 
			КонецЕсли;
			 			
		КонецЕсли;
		
	КонецЦикла;
	
	ПредставлениеНезаполненных = ?(ЗначениеЗаполнено(ПредставлениеНезаполненных), Сред(ПредставлениеНезаполненных, 1, СтрДлина(ПредставлениеНезаполненных) - 2), "");
	
	СтруктураВозврата = Новый Структура;
	// СтруктураВозврата.Вставить("Массив_НезаполненныеРеквизиты", ВозвращаемыйМассивР);
	СтруктураВозврата.Вставить("Строка_НезаполненныеРеквизиты", ПредставлениеНезаполненных);
	Если ВключатьПроверкуФИОВРезультат Тогда
		СтруктураВозврата.Вставить("Стр_НезаполненныеРеквизитыФИО", ВозвращаемаяСтруктураФИО);
	КонецЕсли;
	
	Возврат СтруктураВозврата; 
			
КонецФункции


