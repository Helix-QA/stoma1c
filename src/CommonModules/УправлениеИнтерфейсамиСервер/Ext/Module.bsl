	ПолеВыбораЗначениеФильтра.ПоложениеЗаголовка 									= ПоложениеЗаголовкаЭлементаФормы.Нет;	
	ПолеВыбораЗначениеФильтра.КнопкаВыпадающегоСписка 								= Ложь;			
	ПолеВыбораЗначениеФильтра.КнопкаВыбора 											= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаОчистки 										= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаРегулирования 									= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаОткрытия 										= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаСоздания 										= Ложь;
	ПолеВыбораЗначениеФильтра.ИсторияВыбораПриВводе 								= ИсторияВыбораПриВводе.НеИспользовать;
	// ПолеВыбораЗначениеФильтра.РастягиватьПоГоризонтали 								= Истина;
	ПолеВыбораЗначениеФильтра.ЦветФона 												= Новый Цвет(250, 250, 250);
	ПолеВыбораЗначениеФильтра.Ширина 												= 5;
	ПолеВыбораЗначениеФильтра.ГоризонтальноеПоложение 								= ГоризонтальноеПоложениеЭлемента.Центр;
	ПолеВыбораЗначениеФильтра.ГоризонтальноеПоложениеВГруппе 						= ГоризонтальноеПоложениеЭлемента.Лево;
	ПолеВыбораЗначениеФильтра.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Верх;
	ПолеВыбораЗначениеФильтра.МинимальноеЗначение 									= 0;
	
	ПолеВыбораЗначениеФильтра.ОграничениеТипа 	= СтрокаФильтр.ОписаниеТипаЗначения;

	ДекорацияРазделитель = Форма.Элементы.Добавить("ДекорацияРазделитель_ЗначениеФильтра_" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("ДекорацияФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра]);
	ДекорацияРазделитель.Вид 														= ВидДекорацииФормы.Надпись;
	ДекорацияРазделитель.Заголовок                  								= "-";
	ДекорацияРазделитель.Гиперссылка 												= Ложь;
	// ДекорацияРазделитель.ЦветТекста 												= Новый Цвет(255, 255, 255);
	ДекорацияРазделитель.Ширина 													= 3;
	// ДекорацияРазделитель.Шрифт 														= Новый Шрифт("Arial", 1);
	ДекорацияРазделитель.РастягиватьПоГоризонтали 									= Ложь;
	ДекорацияРазделитель.РастягиватьПоВертикали 									= Ложь;
	ДекорацияРазделитель.ГоризонтальноеПоложениеВГруппе 							= ГоризонтальноеПоложениеЭлемента.Лево;	
	ДекорацияРазделитель.ГоризонтальноеПоложение 									= ГоризонтальноеПоложениеЭлемента.Центр;
	ДекорацияРазделитель.ВертикальноеПоложениеВГруппе 								= ВертикальноеПоложениеЭлемента.Верх;
	ДекорацияРазделитель.ВертикальноеПоложение 										= ВертикальноеПоложениеЭлемента.Верх;
	
	ПолеВыбораЗначениеФильтра = Форма.Элементы.Добавить("Выбрать_ЗначениеФильтра_КонецДиапазона" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("ПолеФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра]);
	ПолеВыбораЗначениеФильтра.Вид 													= ВидПоляФормы.ПолеВвода;	
	ЗаполнитьЗначенияСвойств(ПолеВыбораЗначениеФильтра, СтрокаФильтр.ПараметрыПолеВыбора);	
	ПолеВыбораЗначениеФильтра.ПутьКДанным 											= "ТаблицаФильтров[" + Форма.ТаблицаФильтров.Индекс(СтрокаФильтр) + "].КонецЧисловогоДиапазона";	
	ПолеВыбораЗначениеФильтра.Заголовок 											= Нстр("ru = 'до'; en = 'to'");	
	ПолеВыбораЗначениеФильтра.ПоложениеЗаголовка 									= ПоложениеЗаголовкаЭлементаФормы.Нет;	
	ПолеВыбораЗначениеФильтра.КнопкаВыпадающегоСписка 								= Ложь;			
	ПолеВыбораЗначениеФильтра.КнопкаВыбора 											= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаОчистки 										= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаРегулирования 									= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаОткрытия 										= Ложь;
	ПолеВыбораЗначениеФильтра.КнопкаСоздания 										= Ложь;
	ПолеВыбораЗначениеФильтра.ИсторияВыбораПриВводе 								= ИсторияВыбораПриВводе.НеИспользовать;
	// ПолеВыбораЗначениеФильтра.РастягиватьПоГоризонтали 								= Истина;
	ПолеВыбораЗначениеФильтра.ЦветФона 												= Новый Цвет(250, 250, 250);
	ПолеВыбораЗначениеФильтра.Ширина 												= 5;
	ПолеВыбораЗначениеФильтра.ГоризонтальноеПоложение 								= ГоризонтальноеПоложениеЭлемента.Центр;	
	ПолеВыбораЗначениеФильтра.ГоризонтальноеПоложениеВГруппе 						= ГоризонтальноеПоложениеЭлемента.Лево;
	ПолеВыбораЗначениеФильтра.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Верх;
	ПолеВыбораЗначениеФильтра.МаксимальноеЗначение 									= 100;
	
	ПолеВыбораЗначениеФильтра.ОграничениеТипа 	= СтрокаФильтр.ОписаниеТипаЗначения;
	
	
	СтрокаФильтр.Инициализирован 	= Истина;
	СтрокаФильтр.Актуализирован 	= Истина;
	
	Форма.Элементы[СтрокаФильтр.ИмяГруппыЗначенийФильтра].Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
КонецПроцедуры

// Процедура - Деактивировать все значения фильтрации данных
//
// Параметры:
//  Форма						 - 	 - 
//  МассивИменОчищаемыхФильтров	 - 	 - 
//
Процедура ДеактивироватьВсеЗначенияФильтрацииДанных(Форма, МассивИменОчищаемыхФильтров) Экспорт

	Если ТипЗнч(МассивИменОчищаемыхФильтров) <> Тип("Массив") Тогда 
		Возврат;
	КонецЕсли;	
	
	Для Каждого НаименованиеФильтра Из МассивИменОчищаемыхФильтров Цикл 
		МассивСтрокФильтра = Форма.ТаблицаФильтров.НайтиСтроки(Новый Структура("Наименование", НаименованиеФильтра));
		Если МассивСтрокФильтра.Количество() <> 0 Тогда 
			Если МассивСтрокФильтра[0].ОписаниеТипаЗначения = Новый ОписаниеТипов("СтандартныйПериод") Тогда
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра 				= Новый СтандартныйПериод;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра 		= Новый СтандартныйПериод;
				МассивСтрокФильтра[0].РеквизитДата 												= ?(МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала = Дата(1,1,1),
																									НачалоДня(ТекущаяДата()),
																									МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала);				
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.Выбран 						= Ложь;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.Активирован 					= Ложь;
				МассивСтрокФильтра[0].КоличествоАктивированныхЗначений 							= 0;			
				Если НЕ МассивСтрокФильтра[0].Инициализирован Тогда 				
					ОбновитьГруппуЗначенийФильтра(Форма, МассивСтрокФильтра[0]);
				КонецЕсли;	
				ОбновитьСвойстваКалендаря(Форма, МассивСтрокФильтра[0], Истина);				
			Иначе 
				Для Каждого ЭлементСпискаЗначения Из МассивСтрокФильтра[0].СписокЗначений Цикл 
					ЭлементСпискаЗначения.Значение.Выбран 		= Ложь;
					ЭлементСпискаЗначения.Значение.Активирован 	= Ложь;
				КонецЦикла;
				МассивСтрокФильтра[0].КоличествоАктивированныхЗначений = 0;
			КонецЕсли;
			ОбновитьГруппуАктивированныхЗначенийФильтра(Форма, МассивСтрокФильтра[0]);				
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Установить значения фильтрации данных
//
// Параметры:
//  Форма						 - 	 - 
//  НаименованиеФильтра			 - 	 - 
//  ЗначениеВыбора				 - 	 - 
//  ДобавлятьНовыеЗначения		 - 	 - 
//  ПредставлениеПустогоЗначения - 	 - 
//
Процедура УстановитьЗначенияФильтрацииДанных(Форма, НаименованиеФильтра, ЗначениеВыбора, ДобавлятьНовыеЗначения = Ложь, ПредставлениеПустогоЗначения = Неопределено, ЗапретРедактированияФильтрации = Ложь, ВариантОтбора = Истина) Экспорт
	
	Если Не ЗначениеЗаполнено(ПредставлениеПустогоЗначения) Тогда
		ПредставлениеПустогоЗначения = Нстр("ru = '<не указано>'; en = '<not indicated>'");
	КонецЕсли;	
		
	Если ТипЗнч(ЗначениеВыбора) = Тип("СписокЗначений") Тогда
		МассивЗначений = ЗначениеВыбора.ВыгрузитьЗначения();
		Если ЗначениеВыбора.Количество() <> 0 Тогда
			ВариантОтбора = ЗначениеВыбора[0].Пометка;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ЗначениеВыбора) = Тип("Массив") Тогда
		МассивЗначений = ЗначениеВыбора;
	Иначе
		МассивЗначений = Новый Массив;
		МассивЗначений.Добавить(ЗначениеВыбора);
	КонецЕсли;	
	
	МассивСтрокФильтра = Форма.ТаблицаФильтров.НайтиСтроки(Новый Структура("Наименование", НаименованиеФильтра));
	Если МассивСтрокФильтра.Количество() <> 0 Тогда // И МассивЗначений.Количество() <> 0 Тогда
		МассивСтрокФильтра[0].Актуализирован 	= Ложь;
		МассивСтрокФильтра[0].ВариантОтбора 	= ВариантОтбора;
		Если МассивСтрокФильтра[0].СписокЗначений.Количество() = 0 Тогда 
			Если ДобавлятьНовыеЗначения ИЛИ МассивСтрокФильтра[0].ТолькоПолеВыбора Тогда
				КоллекцияЗначений = ПолучитьКоллекциюПредставленийМассиваЗначений(МассивЗначений);				
				ИнициализироватьСписокЗначений(МассивСтрокФильтра[0], КоллекцияЗначений, , , Истина, Истина);
				МассивСтрокФильтра[0].КоличествоАктивированныхЗначений = МассивСтрокФильтра[0].СписокЗначений.Количество();
				МассивСтрокФильтра[0].Инициализирован = Ложь; // так как добавили новые элементы, флаг того что все элементы прорисовались проставляем в ложь				
			КонецЕсли;	
		Иначе
			Если МассивСтрокФильтра[0].ОписаниеТипаЗначения = Новый ОписаниеТипов("СтандартныйПериод") Тогда
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала 			= МассивЗначений[0].ДатаНачала;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.ДатаОкончания 			= МассивЗначений[0].ДатаОкончания;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.Вариант	 			= МассивЗначений[0].Вариант;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра.ДатаНачала 		= МассивЗначений[0].ДатаНачала;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра.ДатаОкончания 	= МассивЗначений[0].ДатаОкончания;
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра.Вариант	 		= МассивЗначений[0].Вариант;
				МассивСтрокФильтра[0].РеквизитДата 														= ?(МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала = Дата(1,1,1),
																											НачалоДня(ТекущаяДата()),
																											МассивСтрокФильтра[0].СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала);				
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.Выбран 								= ?(МассивЗначений[0].ДатаНачала = Дата(1,1,1) И МассивЗначений[0].ДатаОкончания = Дата(1,1,1), Ложь, Истина);
				МассивСтрокФильтра[0].СписокЗначений[0].Значение.Активирован 							= ?(МассивЗначений[0].ДатаНачала = Дата(1,1,1) И МассивЗначений[0].ДатаОкончания = Дата(1,1,1), Ложь, Истина);
				МассивСтрокФильтра[0].КоличествоАктивированныхЗначений 									= ?(МассивЗначений[0].ДатаНачала = Дата(1,1,1) И МассивЗначений[0].ДатаОкончания = Дата(1,1,1), 0, 1);;			
				// СтрокаФильтра.Применен 				= Ложь;
				Если НЕ МассивСтрокФильтра[0].Инициализирован Тогда 
					ОбновитьГруппуЗначенийФильтра(Форма, МассивСтрокФильтра[0]);
				КонецЕсли;	
				ОбновитьСвойстваКалендаря(Форма, МассивСтрокФильтра[0], Истина);				
			Иначе 	
				МассивСтрокФильтра[0].КоличествоАктивированныхЗначений = 0;			
				Для Каждого ЭлементСпискаЗначения Из МассивСтрокФильтра[0].СписокЗначений Цикл 
					ИндексЭлементМассива = МассивЗначений.Найти(ЭлементСпискаЗначения.Значение.ЗначениеФильтра);
					Если ИндексЭлементМассива = Неопределено Тогда 		// отключаем выбор
						ЭлементСпискаЗначения.Значение.Выбран 		= Ложь;
						ЭлементСпискаЗначения.Значение.Активирован 	= Ложь;
					Иначе                                          		// включаем выбор
						ЭлементСпискаЗначения.Значение.Выбран 		= Истина;
						ЭлементСпискаЗначения.Значение.Активирован 	= Истина;
						МассивЗначений.Удалить(ИндексЭлементМассива);	// удалаяем из массива
						МассивСтрокФильтра[0].КоличествоАктивированныхЗначений = МассивСтрокФильтра[0].КоличествоАктивированныхЗначений + 1;								
					КонецЕсли;	
				КонецЦикла;
				Если ДобавлятьНовыеЗначения И МассивЗначений.Количество() <> 0 Тогда // если в массиве остались элементы и разрешено добавление - добавляем
					Для Каждого ЭлементМассива Из МассивЗначений Цикл 
						ЭлементСписка 		= МассивСтрокФильтра[0].СписокЗначений.Добавить();
						СтруктураЗначения 	= Новый Структура;
						СтруктураЗначения.Вставить("ЗначениеФильтра", ЭлементМассива);
						ЭлементСписка.Представление = ?(ЗначениеЗаполнено(ЭлементМассива), СокрЛП(Строка(ЭлементМассива)), ПредставлениеПустогоЗначения);
						СтруктураЗначения.Вставить("Выбран"						, ДобавлятьНовыеЗначения);
						СтруктураЗначения.Вставить("Активирован"				, ДобавлятьНовыеЗначения);
						СтруктураЗначения.Вставить("ИмяГруппыЗначенияФильтра"	, "");
						СтруктураЗначения.Вставить("ИмяКнопкиЗначенияФильтра"	, "");
						ЭлементСписка.Значение = СтруктураЗначения;
						МассивСтрокФильтра[0].КоличествоАктивированныхЗначений = МассивСтрокФильтра[0].КоличествоАктивированныхЗначений + 1;					
					КонецЦикла;
					МассивСтрокФильтра[0].Инициализирован = Ложь; // так как добавили новые элементы, флаг того что все элементы прорисовались проставляем в ложь
					МассивСтрокФильтра[0].СписокЗначений.СортироватьПоПредставлению();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Если ЗапретРедактированияФильтрации И МассивСтрокФильтра[0].Инициализирован = Ложь И НЕ МассивСтрокФильтра[0].ОписаниеТипаЗначения = Новый ОписаниеТипов("СтандартныйПериод") Тогда 
			ОбновитьГруппуЗначенийФильтра(Форма, МассивСтрокФильтра[0]);
		КонецЕсли;	
		ОбновитьГруппуАктивированныхЗначенийФильтра(Форма, МассивСтрокФильтра[0]);
	КонецЕсли;
	
	ОбновитьДоступКЭлементамФильтрации(Форма, НаименованиеФильтра, ЗапретРедактированияФильтрации);
	
КонецПроцедуры

// Функция - Получить коллекцию представлений массива значений
//
// Параметры:
//  МассивЗначений	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКоллекциюПредставленийМассиваЗначений(КоллекцияЗначений) Экспорт
	
	Если КоллекцияЗначений.Количество() < 2 Тогда 
		Возврат КоллекцияЗначений;
	КонецЕсли;
	
	Если ТипЗнч(КоллекцияЗначений) = Тип("СписокЗначений") Тогда 
		МассивЗначений = КоллекцияЗначений.ВыгрузитьЗначения();
	Иначе 
		МассивЗначений = КоллекцияЗначений;
	КонецЕсли;
	
	Если ТипЗнч(МассивЗначений[0]) = Тип("СправочникСсылка.Сотрудники") Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	Сотрудники.Ссылка КАК Ссылка,
		               |	Сотрудники.НаименованиеСокращенное КАК Представление
		               |ИЗ
		               |	Справочник.Сотрудники КАК Сотрудники
		               |ГДЕ
		               |	Сотрудники.Ссылка В(&МассивЗначений)";
		
		Запрос.УстановитьПараметр("МассивЗначений", МассивЗначений);
	    Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат КоллекцияЗначений;
	КонецЕсли;	
	
КонецФункции

// Процедура - Обновить группу активированных значений фильтра
//
// Параметры:
//  Форма							 - 	 - 
//  СтрокаФильтра					 - 	 - 
//  ОбщееКоличествоВыбранныхЗначений - 	 - 
//
Процедура ОбновитьГруппуАктивированныхЗначенийФильтра(Форма, СтрокаФильтра) Экспорт
	
	УдалитьЭлементыФильтра(Форма, СтрокаФильтра.ИмяГруппыАктивированныхЗначенийФильтра);
	УстановитьОтображениеКнопкиАктивизацииМенюФильтрации(Форма);
	
	СтрокаФильтра.Применен = Истина;
	
	Если СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда 
		Если СтрокаФильтра.НачалоЧисловогоДиапазона = 0 И СтрокаФильтра.КонецЧисловогоДиапазона = 0 Тогда 
			ОбновитьСвойстваГруппыЗначенийФильтра(Форма, СтрокаФильтра);
			Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Заголовок = ?(СтрокаФильтра.ВариантОтбора, Нстр("ru = 'Равно'; en = 'Equals'"), Нстр("ru = 'Не равно'; en = 'Not equals'"));
			АктуализироватьМасштабПанелиФильтрации(Форма);
			Возврат;
		КонецЕсли;	
	ИначеЕсли СтрокаФильтра.КоличествоАктивированныхЗначений = 0 И НЕ (СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число"))) Тогда
		ОбновитьСвойстваГруппыЗначенийФильтра(Форма, СтрокаФильтра);
		Если НЕ СтрокаФильтра.РеквизитДата = Дата(1,1,1) И СтрокаФильтра.СписокЗначений.Количество() > 0 И ТипЗнч(СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра) = Тип("СтандартныйПериод") Тогда 
			ОбновитьСвойстваЭлементаЗначения(Форма, СтрокаФильтра, СтрокаФильтра.СписокЗначений[0]);
		Иначе 
			Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Заголовок = ?(СтрокаФильтра.ВариантОтбора = Истина, Нстр("ru = 'Равно'; en = 'Equals'"), Нстр("ru = 'Не равно'; en = 'Not equals'"));
		КонецЕсли;
		АктуализироватьМасштабПанелиФильтрации(Форма);
		Возврат;
	КонецЕсли;	
	
	ИдентификаторФильтра = СтрокаФильтра.ПолучитьИдентификатор();
	
	КомандаАктивированныеЗначенияФильтра = Форма.Команды.Найти("Показать_Активированные_ЗначенияФильтра_" + СтрокаФильтра.Наименование + "_Идентификатор_" + ИдентификаторФильтра);
	Если КомандаАктивированныеЗначенияФильтра = Неопределено Тогда
		КомандаАктивированныеЗначенияФильтра 				= Форма.Команды.Добавить("Показать_Активированные_ЗначенияФильтра_" + СтрокаФильтра.Наименование + "_Идентификатор_" + ИдентификаторФильтра);
		КомандаАктивированныеЗначенияФильтра.Заголовок 		= КомандаАктивированныеЗначенияФильтра.Имя;
		КомандаАктивированныеЗначенияФильтра.Подсказка 		= "";
		КомандаАктивированныеЗначенияФильтра.Действие 		= "ОбработчикНажатияЭлементаФильтрацииДанных";
	КонецЕсли;
	
	КнопкаАктивированныеЗначениеФильтра = Форма.Элементы.Добавить("Показать_Активированные_ЗначенияФильтра_" + СтрокаФильтра.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("КнопкаФормы"), Форма.Элементы[СтрокаФильтра.ИмяГруппыАктивированныхЗначенийФильтра]);
	КнопкаАктивированныеЗначениеФильтра.ИмяКоманды 												= КомандаАктивированныеЗначенияФильтра.Имя;
	КнопкаАктивированныеЗначениеФильтра.Заголовок 												= ПолучитьЗаголовокКнопкиАктивированныхЗначений(СтрокаФильтра);
	// КнопкаАктивированныеЗначениеФильтра.Картинка 												= БиблиотекаКартинок.Крестик;		
	// КнопкаАктивированныеЗначениеФильтра.Фигура 												= ФигураКнопки.Овал;
	КнопкаАктивированныеЗначениеФильтра.ОтображениеФигуры    									= ОтображениеФигурыКнопки.Нет;
	// КнопкаАктивированныеЗначениеФильтра.ПоложениеКартинки 									= ПоложениеКартинкиКнопкиФормы.Право;
	КнопкаАктивированныеЗначениеФильтра.Отображение 											= ОтображениеКнопки.Текст;
	// КнопкаАктивированныеЗначениеФильтра.Ширина 												= ПараметрыОтображенияДанных.МаксимальнаяШирина_ВариантаВзаимодействия;
	// КнопкаАктивированныеЗначениеФильтра.РастягиватьПоГоризонтали 								= ;
	// КнопкаАктивированныеЗначениеФильтра.ЦветТекста 											= Новый Цвет(255, 255, 255); //?(ЗначениеФильтра.Пометка, Новый Цвет(), Новый Цвет(0, 112, 210));
	// КнопкаАктивированныеЗначениеФильтра.ЦветФона 												= Новый Цвет(0, 112, 210);
	КнопкаАктивированныеЗначениеФильтра.Шрифт 													= Новый Шрифт("Arial", 11);
	// КнопкаАктивированныеЗначениеФильтра.ГоризонтальноеПоложениеВГруппе 						= ГоризонтальноеПоложениеЭлемента.Лево;
	КнопкаАктивированныеЗначениеФильтра.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Центр;
	
	КомандаУдалитьАктивированныеЗначенияФильтра = Форма.Команды.Найти("Удалить_Активированные_ЗначенияФильтра_" + СтрокаФильтра.Наименование + "_Идентификатор_" + ИдентификаторФильтра);
	Если КомандаУдалитьАктивированныеЗначенияФильтра = Неопределено Тогда
		КомандаУдалитьАктивированныеЗначенияФильтра 				= Форма.Команды.Добавить("Удалить_Активированные_ЗначенияФильтра_" + СтрокаФильтра.Наименование + "_Идентификатор_" + ИдентификаторФильтра);
		КомандаУдалитьАктивированныеЗначенияФильтра.Заголовок 		= КомандаУдалитьАктивированныеЗначенияФильтра.Имя;
		КомандаУдалитьАктивированныеЗначенияФильтра.Подсказка 		= "";
		КомандаУдалитьАктивированныеЗначенияФильтра.Действие 		= "ОбработчикНажатияЭлементаФильтрацииДанных";
	КонецЕсли;
	
	КнопкаУдалитьАктивированныеЗначениеФильтра = Форма.Элементы.Добавить("Удалить_Активированные_ЗначенияФильтра_" + СтрокаФильтра.Наименование + "_Идентификатор_" + ИдентификаторФильтра, Тип("КнопкаФормы"), Форма.Элементы[СтрокаФильтра.ИмяГруппыАктивированныхЗначенийФильтра]);
	КнопкаУдалитьАктивированныеЗначениеФильтра.ИмяКоманды 										= КомандаУдалитьАктивированныеЗначенияФильтра.Имя;
	// КнопкаУдалитьАктивированныеЗначениеФильтра.Заголовок 										= ПолучитьЗаголовокКнопкиАктивированныхЗначений(СтрокаФильтра);
	КнопкаУдалитьАктивированныеЗначениеФильтра.Картинка 										= БиблиотекаКартинок.Крестик;		
	// КнопкаУдалитьАктивированныеЗначениеФильтра.Фигура 										= ФигураКнопки.Овал;
	КнопкаУдалитьАктивированныеЗначениеФильтра.ОтображениеФигуры    							= ОтображениеФигурыКнопки.Нет;
	// КнопкаУдалитьАктивированныеЗначениеФильтра.ПоложениеКартинки 								= ПоложениеКартинкиКнопкиФормы.Право;
	КнопкаУдалитьАктивированныеЗначениеФильтра.Отображение 										= ОтображениеКнопки.Картинка;
	// КнопкаУдалитьАктивированныеЗначениеФильтра.Ширина 										= ПараметрыОтображенияДанных.МаксимальнаяШирина_ВариантаВзаимодействия;
	// КнопкаУдалитьАктивированныеЗначениеФильтра.РастягиватьПоГоризонтали 						= ;
	// КнопкаУдалитьАктивированныеЗначениеФильтра.ЦветТекста 									= Новый Цвет(255, 255, 255); //?(ЗначениеФильтра.Пометка, Новый Цвет(), Новый Цвет(0, 112, 210));
	// КнопкаУдалитьАктивированныеЗначениеФильтра.ЦветФона 										= Новый Цвет(0, 112, 210);
	// КнопкаУдалитьАктивированныеЗначениеФильтра.Шрифт 											= Новый Шрифт("Arial", 11);
	// КнопкаУдалитьАктивированныеЗначениеФильтра.ГоризонтальноеПоложениеВГруппе 				= ГоризонтальноеПоложениеЭлемента.Лево;
	КнопкаУдалитьАктивированныеЗначениеФильтра.ВертикальноеПоложениеВГруппе 					= ВертикальноеПоложениеЭлемента.Центр;
	
	АктуализироватьМасштабПанелиФильтрации(Форма);
	
КонецПроцедуры

// Процедура, устанавливает отображение кнопки "Кнопка_ПоказатьМенюФильтрацииДанных".
//
Процедура УстановитьОтображениеКнопкиАктивизацииМенюФильтрации(Форма)
	
	Кнопка_ПоказатьМенюФильтрацииДанных = Форма.Элементы["Кнопка_ПоказатьМенюФильтрацииДанных"];
	
	Если СтрНайти(Форма.ИмяФормы, "ФормаФильтры") Тогда
		
		Кнопка_ПоказатьМенюФильтрацииДанных.Видимость = Ложь;
		
	Иначе
		
		КоличествоУстановленныхФильтров = 0;
		Для Каждого СтрокаТаблицы Из Форма.ТаблицаФильтров Цикл
			КоличествоУстановленныхФильтров = КоличествоУстановленныхФильтров + (СтрокаТаблицы.КоличествоАктивированныхЗначений > 0);
		КонецЦикла;
		
		Кнопка_ПоказатьМенюФильтрацииДанных.Заголовок = ?(
		КоличествоУстановленныхФильтров = 0,
		Нстр("ru='Фильтр';en='Filter'"),
		СтрШаблон(Нстр("ru = 'Фильтр (%1)'; en = 'Filter (%1)'"), КоличествоУстановленныхФильтров)
		);
		Кнопка_ПоказатьМенюФильтрацииДанных.Ширина				 = ?(КоличествоУстановленныхФильтров = 0, 9, 11);
		Кнопка_ПоказатьМенюФильтрацииДанных.МаксимальнаяШирина	 = ?(КоличествоУстановленныхФильтров = 0, 9, 11);
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Обновить доступ к элементам фильтрации
//
// Параметры:
//  Форма							 - 	 - 
//  НаименованиеФильтра				 - 	 - 
//  ЗапретРедактированияФильтрации	 - 	 - 
//
Процедура ОбновитьДоступКЭлементамФильтрации(Форма, НаименованиеФильтра, ЗапретРедактированияФильтрации)
	
	МассивСтрокФильтра = Форма.ТаблицаФильтров.НайтиСтроки(Новый Структура("Наименование", НаименованиеФильтра));
	Если МассивСтрокФильтра.Количество() <> 0 Тогда 
		Если МассивСтрокФильтра[0].РеквизитДата <> Дата(1,1,1) Тогда
			Возврат;
		КонецЕсли;
		ИдентификаторФильтра = МассивСтрокФильтра[0].ПолучитьИдентификатор();		
		КнопкаВариантОтбора = Форма.Элементы.Найти(МассивСтрокФильтра[0].ИмяКнопкиВариантОтбора);
		Если КнопкаВариантОтбора <> Неопределено Тогда 
			КнопкаВариантОтбора.Доступность = НЕ ЗапретРедактированияФильтрации;
		КонецЕсли;
		Если МассивСтрокФильтра[0].ТолькоПолеВыбора Тогда 
			ПолеВыбораЗначениеФильтра = Форма.Элементы.Найти("Выбрать_ЗначениеФильтра_" + МассивСтрокФильтра[0].Наименование + "_Идентификатор_" + ИдентификаторФильтра);
			Если ПолеВыбораЗначениеФильтра <> Неопределено Тогда 
				ПолеВыбораЗначениеФильтра.Доступность = НЕ ЗапретРедактированияФильтрации;
			КонецЕсли;
		КонецЕсли;
		КнопкаУдалитьАктивированныеЗначениеФильтра = Форма.Элементы.Найти("Удалить_Активированные_ЗначенияФильтра_" + МассивСтрокФильтра[0].Наименование + "_Идентификатор_" + ИдентификаторФильтра);
		Если КнопкаУдалитьАктивированныеЗначениеФильтра <> Неопределено Тогда 
			КнопкаУдалитьАктивированныеЗначениеФильтра.Доступность = НЕ ЗапретРедактированияФильтрации;
		КонецЕсли;
		Если МассивСтрокФильтра[0].Инициализирован = Истина Тогда 
			Для Каждого ЭлементСписка Из МассивСтрокФильтра[0].СписокЗначений Цикл 
				Форма.Элементы[ЭлементСписка.Значение.ИмяКнопкиЗначенияФильтра].Доступность = НЕ ЗапретРедактированияФильтрации;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Получить заголовок кнопки активированных значений
//
// Параметры:
//  СтрокаФильтра	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЗаголовокКнопкиАктивированныхЗначений(СтрокаФильтра)
	
	КоличествоВыбранных 			= 0;
	Если НЕ СтрокаФильтра.РеквизитДата = Дата(1,1,1) И СтрокаФильтра.СписокЗначений.Количество() > 0 И ТипЗнч(СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра) = Тип("СтандартныйПериод") Тогда 
		ЗаголовокАктивированныхЗначений = СтрокаФильтра.Представление + ": ";
	ИначеЕсли СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда 
		ЗаголовокАктивированныхЗначений = Строка(СтрокаФильтра.НачалоЧисловогоДиапазона) + " - " + Строка(СтрокаФильтра.КонецЧисловогоДиапазона);
	Иначе 	
		ЗаголовокАктивированныхЗначений = "";
	КонецЕсли;	
	Для Каждого ЭлементСпискаЗначения Из СтрокаФильтра.СписокЗначений Цикл 
		Если ЭлементСпискаЗначения.Значение.Активирован Тогда 
			КоличествоВыбранных 			= КоличествоВыбранных + 1;
			ЗаголовокАктивированныхЗначений = ?(СтрокаФильтра.ВариантОтбора, "", Нстр("ru = 'Не '; en = 'Not '"))
											+ ?(ОбщегоНазначения.ЭтоСсылка(ТипЗнч(ЭлементСпискаЗначения.Значение.ЗначениеФильтра))
													// И ТипЗнч(ЭлементСпискаЗначения.Значение.ЗначениеФильтра) <> Тип("ПеречислениеСсылка.СтатусыЧленствПакетовУслуг")
													И НЕ ЗначениеЗаполнено(ЭлементСпискаЗначения.Значение.ЗначениеФильтра),
												СтрокаФильтра.Представление + " " + СтрСоединить(СтрРазделить(ЭлементСпискаЗначения.Представление, "<>")),
												ЗаголовокАктивированныхЗначений + ЭлементСпискаЗначения.Представление);
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоВыбранных > 1 Тогда 
		ЗаголовокАктивированныхЗначений = ?(СтрокаФильтра.ВариантОтбора, "", Нстр("ru = 'Не '; en = 'Not '")) + СтрокаФильтра.Представление + Символ(160) + "(" + Строка(КоличествоВыбранных) + ")";
	ИначеЕсли СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда 
		ЗаголовокАктивированныхЗначений = ?(СтрокаФильтра.ВариантОтбора, "", Нстр("ru = 'Не '; en = 'Not '")) + СтрокаФильтра.Представление + ": " + ЗаголовокАктивированныхЗначений;		
	ИначеЕсли КоличествоВыбранных > 0 И СтрокаФильтра.ВыводитьЗаголовокРаздела Тогда 
		ЗаголовокАктивированныхЗначений = СтрокаФильтра.Представление + ": " + ЗаголовокАктивированныхЗначений;		
	КонецЕсли;	
	
	Возврат ЗаголовокАктивированныхЗначений;
	
КонецФункции

// Процедура - Обновить свойства разделов фильтра
//
// Параметры:
//  Форма				 - 	 - 
//  АктуализироватьФлаги - 	 - 
//
Процедура ОбновитьСвойстваРазделовФильтра(Форма, АктуализироватьФлаги = Ложь) Экспорт
	
	ИнициализироватьЗначенияФильтра = Ложь;
	АктуализироватьЗначенияФильтра 	= Ложь;
	ИмяТекущейСтраницы 				= Форма.Элементы.СтраницыЗначенийФильтров.ТекущаяСтраница.Имя;
	Для Каждого СтрокаФильтра Из Форма.ТаблицаФильтров Цикл
		Если АктуализироватьФлаги = Истина Тогда
			СтрокаФильтра.КоличествоАктивированныхЗначений = 0;
			Для Каждого ЭлементСпискаЗначенийФильтра Из СтрокаФильтра.СписокЗначений Цикл
				Если ЭлементСпискаЗначенийФильтра.Значение.Выбран <> ЭлементСпискаЗначенийФильтра.Значение.Активирован Тогда 
					ЭлементСпискаЗначенийФильтра.Значение.Выбран = ЭлементСпискаЗначенийФильтра.Значение.Активирован;
					СтрокаФильтра.Актуализирован = Ложь;
				КонецЕсли;
				Если ЭлементСпискаЗначенийФильтра.Значение.Выбран Тогда 
					СтрокаФильтра.КоличествоАктивированныхЗначений = СтрокаФильтра.КоличествоАктивированныхЗначений + 1;
				КонецЕсли;
				Если НЕ СтрокаФильтра.РеквизитДата = Дата(1,1,1) И ТипЗнч(СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра) = Тип("СтандартныйПериод") Тогда 
					Если НЕ СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра = СтрокаФильтра.СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра Тогда 
						СтрокаФильтра.РеквизитДата = ?(СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала = Дата(1,1,1), НачалоДня(ТекущаяДата()), СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала);
						ЗаполнитьЗначенияСвойств(СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра, СтрокаФильтра.СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра);
						СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра.Вариант = СтрокаФильтра.СписокЗначений[0].Значение.ПрошлоеЗначениеФильтра.Вариант;
 						ОбновитьСвойстваКалендаря(Форма, СтрокаФильтра);
					КонецЕсли;
				Иначе
					Если СтрокаФильтра.КоличествоАктивированныхЗначений > 0 Тогда
						СтрокаФильтра.ВариантОтбора = Истина;
						Для Каждого ЭлементАктивированный Из Форма.Элементы[СтрокаФильтра.ИмяГруппыАктивированныхЗначенийФильтра].ПодчиненныеЭлементы Цикл 
							Если СтрНайти(ЭлементАктивированный.Заголовок, "Не ") <> 0 Тогда //(СтрНайти(ЭлементАктивированный.Заголовок, "Не ") <> 0 И СтрНайти(ЭлементАктивированный.Заголовок, "Не проведено") = 0) ИЛИ СтрНайти(ЭлементАктивированный.Заголовок, "Не Не проведено") <> 0 Тогда 
								ИзменитьВариантОтбора = Истина;
								Для Каждого ЭлементСписка Из СтрокаФильтра.СписокЗначений Цикл 
									Если ЭлементСписка.Представление = ЭлементАктивированный.Заголовок Тогда
										ИзменитьВариантОтбора = Ложь;
										Прервать;
									КонецЕсли;
								КонецЦикла;	
								СтрокаФильтра.ВариантОтбора = ?(ИзменитьВариантОтбора, Ложь, СтрокаФильтра.ВариантОтбора);
								Прервать;
							КонецЕсли;
						КонецЦикла;	
					Иначе 	
						СтрокаФильтра.ВариантОтбора = Истина;
					КонецЕсли;
					Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Заголовок = ?(СтрокаФильтра.ВариантОтбора = Истина, Нстр("ru = 'Равно'; en = 'Equals'"), Нстр("ru = 'Не равно'; en = 'Not equals'"));	
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;	
		Если СтрокаФильтра.ИмяСтраницыЗначенийФильтра = ИмяТекущейСтраницы Тогда
			Если НЕ СтрокаФильтра.Инициализирован Тогда 
				ИнициализироватьЗначенияФильтра = Истина;
				ИдентификаторСтрокиФильтра 		= СтрокаФильтра.ПолучитьИдентификатор();
			ИначеЕсли НЕ СтрокаФильтра.Актуализирован Тогда 
				АктуализироватьЗначенияФильтра 	= Истина;
				ИдентификаторСтрокиФильтра 		= СтрокаФильтра.ПолучитьИдентификатор();
			КонецЕсли;	
			// Форма.Элементы[СтрокаФильтра.ИмяГруппыТипФильтра].ЦветФона 		= Новый Цвет(218, 230, 244);
			Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Родитель.ЦветФона 	= СтрокаФильтра.ЦветВыбранногоЗначения;// Новый Цвет(218, 230, 244);			
		    Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].ЦветТекста 			= Новый Цвет();
			Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Видимость	= ?(СтрокаФильтра.РеквизитДата = Дата(1,1,1), Истина, Ложь);
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].ЦветТекста = Новый Цвет();			
			// Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Заголовок 			= ?(СтрокаФильтра.КоличествоАктивированныхЗначений = 0, СтрокаФильтра.Представление, СтрокаФильтра.Представление + " (" + Строка(СтрокаФильтра.КоличествоАктивированныхЗначений) + ")");			
		Иначе 
			// Форма.Элементы[СтрокаФильтра.ИмяГруппыТипФильтра].ЦветФона 		= Новый Цвет(255, 255, 255);
			Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Родитель.ЦветФона 	= Новый Цвет(255, 255, 255);
		    Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].ЦветТекста 			= Новый Цвет(0, 112, 210);
			Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Видимость	= Ложь;			
			// Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Заголовок 			= СтрокаФильтра.Представление;
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].ЦветТекста = Новый Цвет(0, 128, 0);						
		КонецЕсли;
		Если СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].Заголовок = ?(СтрокаФильтра.НачалоЧисловогоДиапазона = 0
																																								И СтрокаФильтра.КонецЧисловогоДиапазона = 0, "", "(1)");		
		Иначе 	
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].Заголовок = ?(СтрокаФильтра.КоличествоАктивированныхЗначений = 0,
																																							"",
																																							"(" + Строка(СтрокаФильтра.КоличествоАктивированныхЗначений) + ")");		
		КонецЕсли;
		Если СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].Видимость = ?(СтрокаФильтра.НачалоЧисловогоДиапазона = 0
																																								И СтрокаФильтра.КонецЧисловогоДиапазона = 0, Ложь, Истина);
		ИначеЕсли СтрокаФильтра.КоличествоАктивированныхЗначений = 0 Тогда
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].Видимость = Ложь;
			// Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Заголовок 			= СтрокаФильтра.Представление;
		Иначе
			Форма.Элементы["ДекорацияКоличествоАктивированных_" + СтрокаФильтра.Наименование + "_Идентификатор_" + СтрокаФильтра.ПолучитьИдентификатор()].Видимость = Истина;			
			// Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Заголовок 			= СтрокаФильтра.Представление; // + " (" + Строка(СтрокаФильтра.КоличествоАктивированныхЗначений) + ")";
		КонецЕсли;
	КонецЦикла;
	
	Если ИнициализироватьЗначенияФильтра Тогда 
		Форма.ОбновитьГруппуЗначенийФильтра(ИдентификаторСтрокиФильтра);
	ИначеЕсли АктуализироватьЗначенияФильтра Тогда
		ОбновитьСвойстваГруппыЗначенийФильтра(Форма, , ИдентификаторСтрокиФильтра);
	КонецЕсли;	
	
КонецПроцедуры	

//// Процедура - Обновить свойства элемента варианта отбора
////
//// Параметры:
////  Форма			 - 	 - 
////  СтрокаФильтра	 - 	 - 
////
// Процедура ОбновитьСвойстваЭлементаВариантаОтбора(Форма, СтрокаФильтра)
//	
//	Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Заголовок = ?(СтрокаФильтра.ВариантОтбора = Истина, "Равно", "Не равно");	
//	
// КонецПроцедуры	

// Процедура - Обновить свойства календаря
//
// Параметры:
//  Форма			 - 	 - 
//  СтрокаФильтра	 - 	 - 
//  Актуализирован	 - 	 - 
//
Процедура ОбновитьСвойстваКалендаря(Форма, СтрокаФильтра, Актуализирован = Ложь)
	
	СтрокаФильтра.СписокЗначений[0].Представление 				= ПолучитьПредставлениеПериода(СтрокаФильтра.СписокЗначений[0].Значение);
	
	ЗначениеСписка = СтрокаФильтра.СписокЗначений[0].Значение;
	Если ТипЗнч(ЗначениеСписка) = Тип("Структура")
		И ЗначениеСписка.Свойство("ИмяКнопкиПериодаФильтра") Тогда
		Форма.Элементы[ЗначениеСписка.ИмяКнопкиПериодаФильтра].Заголовок = СтрокаФильтра.СписокЗначений[0].Представление;	
	КонецЕсли;
	
	МинимальнаяДата 	= СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра.ДатаНачала;
	МаксимальнаяДата 	= СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра.ДатаОкончания;
	// Обновляем видимость нужных нам месяцев в календаре путем устаовки ограничений на календарь
	Если Макс(МинимальнаяДата, НачалоМесяца(ТекущаяДата())) < Мин(НачалоДня(МаксимальнаяДата), ДобавитьМесяц(НачалоМесяца(ТекущаяДата()), 2)) Тогда
		Если МинимальнаяДата < НачалоМесяца(ТекущаяДата()) Тогда 
			Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].НачалоПериодаОтображения 	= МинимальнаяДата;
			Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].КонецПериодаОтображения 	= ДобавитьМесяц(МинимальнаяДата, 2);
		Иначе 	
			Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].НачалоПериодаОтображения 	= НачалоМесяца(ТекущаяДата());
			Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].КонецПериодаОтображения 	= ДобавитьМесяц(НачалоМесяца(ТекущаяДата()), 2);
		КонецЕсли;
	ИначеЕсли ЗначениеЗаполнено(МинимальнаяДата) И ЗначениеЗаполнено(МаксимальнаяДата) Тогда 
		Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].НачалоПериодаОтображения 	= МинимальнаяДата;
		Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].КонецПериодаОтображения 	= ДобавитьМесяц(МинимальнаяДата, 2);
	КонецЕсли;
	// После обновления - сбрасываем ограничения календаря
	Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].НачалоПериодаОтображения 	= Дата(1,1,1);
	Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].КонецПериодаОтображения 	= Дата(1,1,1);
	// Очищаем массив выделенных дат в календаре
	Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].ВыделенныеДаты.Очистить();
	// Накидываем в массив выделенных дат календаря новые даты
	Если ЗначениеЗаполнено(МинимальнаяДата) И ЗначениеЗаполнено(МаксимальнаяДата) Тогда
		Пока МинимальнаяДата <= МаксимальнаяДата Цикл 
			Форма.Элементы[СтрокаФильтра.СписокЗначений[0].Значение.ИмяПоляКалендаряФильтра].ВыделенныеДаты.Добавить(МинимальнаяДата);
			МинимальнаяДата = МинимальнаяДата + 86400;
		КонецЦикла;
	КонецЕсли;
	СтрокаФильтра.Актуализирован = Актуализирован;
	
КонецПроцедуры

// Процедура - Обновить свойства группы значений фильтра
//
// Параметры:
//  Форма						 - 	 - 
//  СтрокаФильтра				 - 	 - 
//  ИдентификаторСтрокиФильтра	 - 	 - 
//
Процедура ОбновитьСвойстваГруппыЗначенийФильтра(Форма, СтрокаФильтра = Неопределено, ИдентификаторСтрокиФильтра = Неопределено) Экспорт
	
	Если СтрокаФильтра = Неопределено Тогда
		Если ИдентификаторСтрокиФильтра = Неопределено Тогда 
			Возврат;
		КонецЕсли;			
		СтрокаФильтра = Форма.ТаблицаФильтров.НайтиПоИдентификатору(ИдентификаторСтрокиФильтра);
	КонецЕсли;
	Если СтрокаФильтра.Инициализирован = Ложь Тогда 
		Возврат;
	КонецЕсли;	
	Для Каждого ЭлементСпискаЗначенийФильтра Из СтрокаФильтра.СписокЗначений Цикл 
		Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяГруппыЗначенияФильтра].ЦветФона 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, Новый Цвет(218, 230, 244), Новый Цвет(255, 255, 255));	
		// Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяКнопкиЗначенияФильтра].Отображение 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, ОтображениеКнопки.КартинкаИТекст, ОтображениеКнопки.Текст);	
		// Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяКнопкиЗначенияФильтра].ЦветТекста 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, Новый Цвет(255, 255, 255), Новый Цвет());
	КонецЦикла;	
					
КонецПроцедуры	

// Процедура - Обновить свойства элемента значения
//
// Параметры:
//  Форма						 - 	 - 
//  СтрокаФильтра				 - 	 - 
//  ЭлементСпискаЗначенийФильтра - 	 - 
//  ДанныеЭлементаФильтрации	 - 	 - 
//
Процедура ОбновитьСвойстваЭлементаЗначения(Форма, СтрокаФильтра = Неопределено, ЭлементСпискаЗначенийФильтра = Неопределено, ДанныеЭлементаФильтрации = Неопределено) Экспорт
	
	Если СтрокаФильтра = Неопределено Тогда
		Если ДанныеЭлементаФильтрации = Неопределено ИЛИ ДанныеЭлементаФильтрации.Свойство("ИдентификаторФильтра") = Ложь Тогда 
			Возврат;
		КонецЕсли;			
		СтрокаФильтра = Форма[ДанныеЭлементаФильтрации.ИмяТаблицы].НайтиПоИдентификатору(ДанныеЭлементаФильтрации.ИдентификаторФильтра);
	КонецЕсли;	
	Если ЭлементСпискаЗначенийФильтра = Неопределено Тогда 
		Если НЕ СтрокаФильтра.РеквизитДата = Дата(1,1,1) И СтрокаФильтра.СписокЗначений.Количество() > 0 И ТипЗнч(СтрокаФильтра.СписокЗначений[0].Значение.ЗначениеФильтра) = Тип("СтандартныйПериод") Тогда
			ЭлементСпискаЗначенийФильтра = СтрокаФильтра.СписокЗначений[0];
		ИначеЕсли ДанныеЭлементаФильтрации.Свойство("ИдентификаторЗначения") Тогда  	
			ЭлементСпискаЗначенийФильтра = СтрокаФильтра.СписокЗначений.НайтиПоИдентификатору(ДанныеЭлементаФильтрации.ИдентификаторЗначения);
		Иначе 
			Возврат;
		КонецЕсли;	
	КонецЕсли;	
	
	ИмяТекущейСтраницы 												= Форма.Элементы.СтраницыЗначенийФильтров.ТекущаяСтраница.Имя;	
	
	Если СтрНайти(СтрокаФильтра.Наименование, "Вероятность") И СтрокаФильтра.ОписаниеТипаЗначения.СодержитТип(Тип("Число")) Тогда
		Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Заголовок 			= ?(СтрокаФильтра.НачалоЧисловогоДиапазона = 0 И СтрокаФильтра.КонецЧисловогоДиапазона = 0, СтрокаФильтра.Представление, СтрокаФильтра.Представление + " (1)");	
	Иначе
		Форма.Элементы[СтрокаФильтра.ИмяТипФильтра].Заголовок 			= ?(СтрокаФильтра.КоличествоАктивированныхЗначений = 0, СтрокаФильтра.Представление, СтрокаФильтра.Представление + " (" + Строка(СтрокаФильтра.КоличествоАктивированныхЗначений) + ")");	
	КонецЕсли;
	
	Если ТипЗнч(ЭлементСпискаЗначенийФильтра.Значение.ЗначениеФильтра) = Тип("СтандартныйПериод") Тогда
		Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Видимость	= Ложь;
	Иначе 	
		Форма.Элементы[СтрокаФильтра.ИмяКнопкиВариантОтбора].Видимость	= ?(СтрокаФильтра.КоличествоАктивированныхЗначений > 0 ИЛИ СтрокаФильтра.ИмяСтраницыЗначенийФильтра = ИмяТекущейСтраницы, Истина, Ложь);			
	КонецЕсли;
	
	Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяГруппыЗначенияФильтра].ЦветФона 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, Новый Цвет(218, 230, 244), Новый Цвет(255, 255, 255));	
	Если ТипЗнч(ЭлементСпискаЗначенийФильтра.Значение.ЗначениеФильтра) = Тип("СтандартныйПериод") Тогда
		Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяКнопкиПериодаФильтра].Заголовок 	= ЭлементСпискаЗначенийФильтра.Представление;			
		Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяКнопкиПериодаФильтра].ЦветТекста 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, Новый Цвет(), Новый Цвет(65, 137, 199));	
	КонецЕсли;	
	// Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяКнопкиЗначенияФильтра].Отображение 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, ОтображениеКнопки.КартинкаИТекст, ОтображениеКнопки.Текст);	
	// Форма.Элементы[ЭлементСпискаЗначенийФильтра.Значение.ИмяКнопкиЗначенияФильтра].ЦветТекста 	= ?(ЭлементСпискаЗначенийФильтра.Значение.Выбран, Новый Цвет(255, 255, 255), Новый Цвет());		
	
КонецПроцедуры

// Процедура - Актуализировать масштаб панели фильтрации
//
// Параметры:
//  Форма							 - 	 - 
//  ГруппаФильтрации				 - 	 - 
//  МассивЭлементовМасштабирования	 - 	 - 
//  КоличествоСимволов				 - 	 - 
//
Процедура АктуализироватьМасштабПанелиФильтрации(Форма, ГруппаФильтрации = Неопределено, МассивЭлементовМасштабирования = Неопределено, КоличествоСимволов = Неопределено)
	
	Если МассивЭлементовМасштабирования = Неопределено Тогда 
		ГруппаМенюФильтрацияДанных = Форма.Элементы.Найти("ФильтрацияДанных");
		
		Если ГруппаМенюФильтрацияДанных = Неопределено Тогда 
			Возврат;
		КонецЕсли;
		// РазрешениеЭкрана = ОбщегоНазначенияКлиентСервер.ОпределитьТекущееРазрешениеЭкрана();
		
		КоличествоСимволов = 0;
		МассивЭлементовМасштабирования = Новый Массив;
		Если ТипЗнч(ГруппаМенюФильтрацияДанных.Родитель) = Тип("ГруппаФормы") Тогда 
			Для Каждого ЭлементыРодителя Из ГруппаМенюФильтрацияДанных.Родитель.ПодчиненныеЭлементы Цикл 
				Если ЭлементыРодителя.Видимость = Истина И ТипЗнч(ЭлементыРодителя) = Тип("КнопкаФормы") Тогда
					КоличествоСимволов = КоличествоСимволов + СтрДлина(ЭлементыРодителя.Заголовок) + 1;
					// МассивЭлементовМасштабирования.Добавить(ЭлементыРодителя);
				ИначеЕсли ЭлементыРодителя.Видимость = Истина И ТипЗнч(ЭлементыРодителя) = Тип("ДекорацияФормы") Тогда
					КоличествоСимволов = КоличествоСимволов + СтрДлина(ЭлементыРодителя.Заголовок) + 1;
					// МассивЭлементовМасштабирования.Добавить(ЭлементыРодителя);
				ИначеЕсли ЭлементыРодителя = ГруппаМенюФильтрацияДанных Тогда
					АктуализироватьМасштабПанелиФильтрации(Форма, ЭлементыРодителя, МассивЭлементовМасштабирования, КоличествоСимволов);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// Посчитали элементы
		Для Каждого ЭлементМасштабирования Из МассивЭлементовМасштабирования Цикл 
			ЭлементМасштабирования.Шрифт = ?(КоличествоСимволов > 119, Новый Шрифт("Arial", 10), Новый Шрифт("Arial", 11));	
		КонецЦикла;	
	Иначе 
		Для Каждого ЭлементыГруппаФильтрация Из ГруппаФильтрации.ПодчиненныеЭлементы Цикл
			Если ТипЗнч(ЭлементыГруппаФильтрация) = Тип("ГруппаФормы") И ЭлементыГруппаФильтрация.Имя = "МенюФильтрацииДанных" Тогда 
			    Продолжить;
			ИначеЕсли ЭлементыГруппаФильтрация.Видимость = Истина И ТипЗнч(ЭлементыГруппаФильтрация) = Тип("КнопкаФормы") И ЭлементыГруппаФильтрация.Имя = "Кнопка_ПоказатьМенюФильтрацииДанных" Тогда	
				КоличествоСимволов = КоличествоСимволов + СтрДлина(ЭлементыГруппаФильтрация.Заголовок) + 1;
			ИначеЕсли ЭлементыГруппаФильтрация.Видимость = Истина И (ТипЗнч(ЭлементыГруппаФильтрация) = Тип("КнопкаФормы") ИЛИ ТипЗнч(ЭлементыГруппаФильтрация) = Тип("ДекорацияФормы")) Тогда	
				КоличествоСимволов = КоличествоСимволов + СтрДлина(ЭлементыГруппаФильтрация.Заголовок) + 1;
				МассивЭлементовМасштабирования.Добавить(ЭлементыГруппаФильтрация);
			ИначеЕсли ТипЗнч(ЭлементыГруппаФильтрация) = Тип("ГруппаФормы") И ЭлементыГруппаФильтрация.Имя = "АктивированныеФильтры" Тогда 
				АктуализироватьМасштабПанелиФильтрации(Форма, ЭлементыГруппаФильтрация, МассивЭлементовМасштабирования, КоличествоСимволов);
			ИначеЕсли ТипЗнч(ЭлементыГруппаФильтрация.Родитель) = Тип("ГруппаФормы") И ЭлементыГруппаФильтрация.Родитель.Имя = "АктивированныеФильтры" Тогда 
				АктуализироватьМасштабПанелиФильтрации(Форма, ЭлементыГруппаФильтрация, МассивЭлементовМасштабирования, КоличествоСимволов);
			ИначеЕсли ТипЗнч(ЭлементыГруппаФильтрация) = Тип("ГруппаФормы") Тогда 
				Для Каждого ЭлементКнопкаАктивации Из ЭлементыГруппаФильтрация.ПодчиненныеЭлементы Цикл 
					Если ЭлементКнопкаАктивации.Видимость = Истина И (ТипЗнч(ЭлементКнопкаАктивации) = Тип("КнопкаФормы") ИЛИ ТипЗнч(ЭлементКнопкаАктивации) = Тип("ДекорацияФормы")) Тогда
						КоличествоСимволов = КоличествоСимволов + СтрДлина(ЭлементКнопкаАктивации.Заголовок) + 1;
						МассивЭлементовМасштабирования.Добавить(ЭлементКнопкаАктивации);
					ИначеЕсли ТипЗнч(ЭлементКнопкаАктивации) = Тип("ГруппаФормы")	Тогда 
						АктуализироватьМасштабПанелиФильтрации(Форма, ЭлементКнопкаАктивации, МассивЭлементовМасштабирования, КоличествоСимволов);
					КонецЕсли;	
				КонецЦикла;	
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

// Функция - Получить список исключемых свойств элементв при копировании
//
// Параметры:
//  ВидЭлемента	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокИсключемыхСвойствЭлементвПриКопировании(ВидЭлемента) Экспорт
	
	СписокСвойств = "";
	
	Если ВидЭлемента = ВидПоляФормы.ПолеФлажка Тогда 
		СписокСвойств = "ПутьКДанным";
	ИначеЕсли ВидЭлемента = ВидПоляФормы.ПолеВвода Тогда
		СписокСвойств = "ПутьКДанным";
		#Если НаКлиенте Тогда
			СписокСвойств = "ВыделенныйТекст, ПутьКДанным";
		#КонецЕсли
	ИначеЕсли ВидЭлемента = ВидГруппыФормы.ОбычнаяГруппа Тогда	
		СписокСвойств = "ПутьКДаннымЗаголовка";
	КонецЕсли;
	
	Возврат СписокСвойств;
	
КонецФункции

// Функция - Получить примерное количество значений помещаемых в строке фильтра
//
// Параметры:
//  СписокЗначений	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПримерноеКоличествоЗначенийПомещаемыхВСтрокеФильтра(СписокЗначений)
	
	КоличествоСимволов 										= 0;
	ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке 	= 1;
	Для Каждого ЭлементСпискаЗначенияФильтра Из СписокЗначений Цикл 
		КоличествоСимволов = КоличествоСимволов + СтрДлина(ЭлементСпискаЗначенияФильтра.Представление) + 1;
	КонецЦикла;
	СреднееКоличествоСимволовПредставленияЗначения = Цел(КоличествоСимволов / ?(СписокЗначений.Количество() = 0, 1, СписокЗначений.Количество()));				
	Если СреднееКоличествоСимволовПредставленияЗначения < 5 Тогда
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 11;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 5 И СреднееКоличествоСимволовПредставленияЗначения < 8 Тогда
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 10;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 7 И СреднееКоличествоСимволовПредставленияЗначения < 10 Тогда 
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 9;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 9 И СреднееКоличествоСимволовПредставленияЗначения < 12 Тогда	
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 8;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 11 И СреднееКоличествоСимволовПредставленияЗначения < 14 Тогда	
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 6;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 13 И СреднееКоличествоСимволовПредставленияЗначения < 17 Тогда	
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 5;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 16 И СреднееКоличествоСимволовПредставленияЗначения < 21 Тогда	
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 4;
	ИначеЕсли СреднееКоличествоСимволовПредставленияЗначения > 20 И СреднееКоличествоСимволовПредставленияЗначения < 26 Тогда	
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 3;
	Иначе 
		ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке = 2;
	КонецЕсли;
	
	Возврат ОриентировочноеКоличествоЭлементовРазмещаемыхВСтроке;
	
КонецФункции

// Функция - Получить представление периода
//
// Параметры:
//  СтруктураЗначения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеПериода(СтруктураЗначения)
	
	ПредставлениеПериода = "";
	СтруктураЗначения.СписокСтандартныхПериодов.ЗаполнитьПометки(Ложь);
	Если СтруктураЗначения.ЗначениеФильтра.ДатаНачала = Дата(1,1,1) И СтруктураЗначения.ЗначениеФильтра.ДатаОкончания = Дата(1,1,1) Тогда 
		ПредставлениеПериода = СтруктураЗначения.ПредставлениеПустогоПериода;
	Иначе
		Если СтруктураЗначения.ЗначениеФильтра.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда 
			Если ЗначениеЗаполнено(СтруктураЗначения.ЗначениеФильтра.ДатаНачала) И ЗначениеЗаполнено(СтруктураЗначения.ЗначениеФильтра.ДатаОкончания) Тогда
				ПериодНеПроизвольный = Новый СтандартныйПериод();
				Для Каждого ВариантаП Из ВариантСтандартногоПериода Цикл
					Если ВариантаП = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда 
						Продолжить;
					КонецЕсли;	
					ПериодНеПроизвольный.Вариант = ВариантаП; 
					Если ПериодНеПроизвольный.ДатаНачала = СтруктураЗначения.ЗначениеФильтра.ДатаНачала И ПериодНеПроизвольный.ДатаОкончания = СтруктураЗначения.ЗначениеФильтра.ДатаОкончания Тогда
						СтруктураЗначения.ЗначениеФильтра.Вариант = ВариантаП;
						ПредставлениеПериода = Строка(СтруктураЗначения.ЗначениеФильтра.Вариант);
						ЭлементСтандартныйПериод = СтруктураЗначения.СписокСтандартныхПериодов.НайтиПоЗначению(СтруктураЗначения.ЗначениеФильтра.Вариант);
						Если НЕ ЭлементСтандартныйПериод = Неопределено Тогда 
							ЭлементСтандартныйПериод.Пометка = Истина;
						КонецЕсли;	
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				Если НЕ ЗначениеЗаполнено(ПредставлениеПериода) Тогда 
					Если НачалоДня(СтруктураЗначения.ЗначениеФильтра.ДатаНачала) = СтруктураЗначения.ЗначениеФильтра.ДатаНачала
																			И КонецДня(СтруктураЗначения.ЗначениеФильтра.ДатаОкончания) = СтруктураЗначения.ЗначениеФильтра.ДатаОкончания
																			И КонецДня(СтруктураЗначения.ЗначениеФильтра.ДатаНачала) = СтруктураЗначения.ЗначениеФильтра.ДатаОкончания Тогда 
						ПредставлениеПериода = Формат(СтруктураЗначения.ЗначениеФильтра.ДатаНачала, "ДФ='д ММММ гггг'");				
					ИначеЕсли НачалоМесяца(СтруктураЗначения.ЗначениеФильтра.ДатаНачала) = СтруктураЗначения.ЗначениеФильтра.ДатаНачала
																			И КонецМесяца(СтруктураЗначения.ЗначениеФильтра.ДатаОкончания) = СтруктураЗначения.ЗначениеФильтра.ДатаОкончания
																			И КонецМесяца(СтруктураЗначения.ЗначениеФильтра.ДатаНачала) = СтруктураЗначения.ЗначениеФильтра.ДатаОкончания Тогда 
						ПредставлениеПериода = Формат(СтруктураЗначения.ЗначениеФильтра.ДатаНачала, "ДФ='ММММ гггг'");
					Иначе 	
						ПредставлениеПериода = Формат(СтруктураЗначения.ЗначениеФильтра.ДатаНачала, "ДФ=d.MM.yy") + " - " + Формат(СтруктураЗначения.ЗначениеФильтра.ДатаОкончания, "ДФ=dd.MM.yy");			
					КонецЕсли;
				КонецЕсли;
			Иначе 
				Если НЕ ЗначениеЗаполнено(СтруктураЗначения.ЗначениеФильтра.ДатаНачала) Тогда 
					ПредставлениеПериода = Нстр("ru = 'по '; en = 'to '") + Формат(СтруктураЗначения.ЗначениеФильтра.ДатаОкончания, "ДФ=d.MM.yy");			
				ИначеЕсли НЕ ЗначениеЗаполнено(СтруктураЗначения.ЗначениеФильтра.ДатаОкончания) Тогда 	
					ПредставлениеПериода = Нстр("ru = 'с '; en = 'from '") + Формат(СтруктураЗначения.ЗначениеФильтра.ДатаНачала, "ДФ=d.MM.yy");			
				КонецЕсли;	
			КонецЕсли;	
		Иначе
			СтруктураЗначения.СписокСтандартныхПериодов.ЗаполнитьПометки(Ложь);				
			ЭлементСтандартныйПериод = СтруктураЗначения.СписокСтандартныхПериодов.НайтиПоЗначению(СтруктураЗначения.ЗначениеФильтра.Вариант);
			Если НЕ ЭлементСтандартныйПериод = Неопределено Тогда 
				ЭлементСтандартныйПериод.Пометка = Истина;
			КонецЕсли;	
			ПредставлениеПериода = Строка(СтруктураЗначения.ЗначениеФильтра.Вариант);
		КонецЕсли;
	КонецЕсли;	

	Возврат ПредставлениеПериода;
	
КонецФункции	

// Процедура, выводит блок дата.
//
Функция ВывестиДату(Дата, СтрокаТЗ = Неопределено)
	
	ДатаHTML = "<div class='date-chat' {СтильHtmlЛиния}><span {СтильHtmlГраницаБлока}>{Дата}</span></div>";
	
	Если (СтрокаТЗ.ТипСобытия = "ДеньРожденияКлиента" И День(СтрокаТЗ.Дата) = День(ТекущаяДатаСеанса())) Тогда 
        ПредставлениеДаты = "Сегодня";
	ИначеЕсли ТипЗнч(Дата) = Тип("Дата") Тогда			
		ПредставлениеДаты = ПолучитьПредставлениеДатыИсторииВзаимодействия(Дата);
	Иначе	
		ПредставлениеДаты = Дата;
	КонецЕсли;

	СтильHtml = "";
	
	Если ПредставлениеДаты = "Закреплено" Тогда
		
		СтильHtmlЛиния 			= "style = '--color:#3f4cff;'";
		СтильHtmlГраницаБлока 	= "style = 'border-color:#3f4cff;'";
		
	ИначеЕсли ПредставлениеДаты = "Сегодня" Тогда
		
		СтильHtmlЛиния 			= "style = '--color:#0cac09;'";
		СтильHtmlГраницаБлока 	= "style = 'border-color:#0cac09;'";
		
	ИначеЕсли ПредставлениеДаты = "Запланировано" Тогда
		
		СтильHtmlЛиния 			= "style = '--color:#ff9b00;'";
		СтильHtmlГраницаБлока 	= "style = 'border-color:#ff9b00;'";
		
	ИначеЕсли ПредставлениеДаты = "Просроченно" Тогда
		
		СтильHtmlЛиния 			= "style = '--color:#fc4242;'";
		СтильHtmlГраницаБлока 	= "style = 'border-color:#fc4242;'";
		
	КонецЕсли;
	
	ПредставлениеДатыТекст = ?(ПредставлениеДаты = "Просроченно", "Просрочено", ПредставлениеДаты);  
	
	ДатаHTML = СтрЗаменить(ДатаHTML		, "{Дата}"					, ПредставлениеДатыТекст);		
	ДатаHTML = СтрЗаменить(ДатаHTML		, "{СтильHtmlЛиния}"		, СтильHtmlЛиния);
	ДатаHTML = СтрЗаменить(ДатаHTML		, "{СтильHtmlГраницаБлока}"	, СтильHtmlГраницаБлока); 
	
	Возврат ДатаHTML;
	
КонецФункции 

// Функция, выводит блок регистрации заявки.
//
Функция СформироватьБлокРегистрацияЗаявки(Взаимодействие, СтрокаТЗ, ПараметрыДанных)
		
	Если ЗначениеЗаполнено(ПараметрыДанных) 
		И ПараметрыДанных.Свойство("Заявка")
		И Взаимодействие = ПараметрыДанных.Заявка Тогда 
		
		БлокРегистрацияЗаявки = ВывестиБлокИнформация(Нстр("ru='Заявка зарегистрирована';en='Request registered'"), СтрокаТЗ.Дата, СтрокаТЗ.Автор);
	Иначе
		РекламныйИсточник              = Взаимодействие.РекламныйИсточник;
		РекламныйИсточникПредставление = ?(ЗначениеЗаполнено(РекламныйИсточник), " - " + РекламныйИсточник, "");
			
		СсылкаЗаявки = ПолучитьНавигационнуюСсылку(Взаимодействие);
		ТекстБлока   = Нстр("ru='Зарегистрирована заявка';en='Request registered'") + РекламныйИсточникПредставление;		
		
		БлокРегистрацияЗаявки = ВывестиБлокИнформация(ТекстБлока, СтрокаТЗ.Дата, СтрокаТЗ.Автор);
	КонецЕсли;

	Возврат БлокРегистрацияЗаявки;
	
КонецФункции

// Функция, формирует блок показать еще.
//
Функция ВывестиБлокПоказатьЕще(Текст)
	
	БлокИнформация = "<div class='more'><span><a style='color:#000000' href='' name='more' title='Показать еще...'>{Текст}</a></span></div>";   

	Возврат СтрЗаменить(БлокИнформация, "{Текст}", Текст);
	
КонецФункции 

// Процедура, выводит блок наличия задач клиента.
//
Функция ВывестиБлокНаличияЗадачКлиента(Знач НаличиеЗапланированныхЗадач)
	
	ТекстHTML = "";
	Если НаличиеЗапланированныхЗадач = Ложь Тогда 
		
		ТекстHTML = "<div class='date-chat interaction'><span></span></div>";
		
	КонецЕсли;

	Возврат ТекстHTML;
	
КонецФункции

// Функция, выводит блок информации.
//
Функция ВывестиБлокИнформация(Текст, Дата = Неопределено, Автор = Неопределено, Ссылка = Неопределено)
		
	БлокИнформация = "<div class='line-info'><span>{Дата}</span> <span>{Автор}</span> <span>{ТекстИнформации}</span></div>";
		
	БлокИнформация = СтрЗаменить(БлокИнформация, "{Дата}"			, Формат(Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'; ДЛФ="));
	БлокИнформация = СтрЗаменить(БлокИнформация, "{Автор}"  		, Автор);
	БлокИнформация = СтрЗаменить(БлокИнформация, "{ТекстИнформации}", Текст);
	
	Возврат БлокИнформация;
	
КонецФункции

// Функция, выводит блок регистрации клиента.
//
Функция СформироватьБлокРегистрацияКлиента(Взаимодействие, ПараметрыДанных, СтрокаТЗ)
		
	Если ЗначениеЗаполнено(ПараметрыДанных) 
		И ПараметрыДанных.Свойство("Контрагент")
		И Взаимодействие = ПараметрыДанных.Контрагент Тогда 
		
		БлокРегистрацияКлиента = ВывестиБлокИнформация(НСтр("ru = 'Пациент зарегистрирован'; en = 'Registered client '"), Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'"), СтрокаТЗ.Автор);	
		
	Иначе	
		ПараметрыСсылки = Новый Структура;
		ПараметрыСсылки.Вставить("Значение" , ПолучитьНавигационнуюСсылку(Взаимодействие));
		ПараметрыСсылки.Вставить("Подсказка", Нстр("ru = 'Открыть клиента'; en = 'Open cleint'"));
		
		ТекстБлока = Нстр("ru='Зарегистрирован пациент - ';en='Registered client -'") + Справочники.Контрагенты.ПредставлениеФИОКонтрагента(Взаимодействие);		
		
		БлокРегистрацияКлиента = ВывестиБлокИнформация(ТекстБлока, Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'"), СтрокаТЗ.Автор);	
	КонецЕсли;                                            
	
	Возврат БлокРегистрацияКлиента;
	
КонецФункции

// Функция, выводит пустую строку.
//
Функция ДобавитьЗакрытиеДиалога(ДанныеДиалога = Неопределено)	
	
	ИдКлиента = "";
	ВнешняяСистема = ""; 
	
	Если ЗначениеЗаполнено(ДанныеДиалога) И ТипЗнч(ДанныеДиалога)= Тип("Структура") Тогда   
		ДанныеДиалога.Свойство("ИдКлиента"		, ИдКлиента);
		ДанныеДиалога.Свойство("ВнешняяСистема"	, ВнешняяСистема);
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
		UIDВнешнейСистемы = Строка(ВнешняяСистема.УникальныйИдентификатор());
	КонецЕсли;
	
	БлокКнопкаДиалог	= "";
	
	Если РольДоступна("ПолныеПрава") 
		ИЛИ РольДоступна("ИспользованиеМессенджера") 
		И (ЗначениеЗаполнено(ИдКлиента) 
		И ЗначениеЗаполнено(UIDВнешнейСистемы)) Тогда
		
		БлокКнопкаДиалог = "<div class='num-dial'><a href='#' id='{ИдКлиента}_{UIDВнешнейСистемы}' title='Перейти к диалогу' name='open_dialog' style='color: #21b528'>Диалог</a></div>";
		
		БлокКнопкаДиалог = СтрЗаменить(БлокКнопкаДиалог, "{ИдКлиента}"			, ИдКлиента);
		БлокКнопкаДиалог = СтрЗаменить(БлокКнопкаДиалог, "{UIDВнешнейСистемы}"	, UIDВнешнейСистемы);
	КонецЕсли;                                                                                                                                                  	
	
	Блок = 
	"</div>
	|{БлокКнопкаДиалог}
   	|	</div>
	|</div>";
	
	Блок = СтрЗаменить(Блок, "{БлокКнопкаДиалог}", БлокКнопкаДиалог);
	
	Возврат Блок; 
	                                                        
КонецФункции

// Функция, формирует блок звонок.
//
Функция СформироватьБлокЗвонок(СтрокаТЗ, НаправлениеВызова)
		
	Если НаправлениеВызова = "ВходящийЗвонок" Тогда  
		
		HTMLНаправлениеВызова 	= "incomingcall";
		ПредставлениеЗвонка		= "Входящий Звонок"; 
		
	ИначеЕсли НаправлениеВызова = "ИсходящийЗвонок" Тогда 
		
		HTMLНаправлениеВызова 	= "outgoingcall";
		ПредставлениеЗвонка 	= "Исходящий Звонок";  
		
	ИначеЕсли НаправлениеВызова = "ПропущенныйЗвонок" Тогда 
		
		HTMLНаправлениеВызова 	= "missedcall";
		ПредставлениеЗвонка 	= "Пропущенный Звонок";  
		                                                         
	КонецЕсли;
	
	ВерхнийОтступ			= "";
	НижнийОтступ 			= "";
	СтильHtmlГраницаБлока 	= "";

	
	ШаблонИсходящийЗвонок = 
	"<div class='wr-message'>                                               
	|    <div class='message'  style= '{НижнийОтступ} {СтильHtmlГраницаБлока}'>
	|		<div class='mainlink'>
	|			<a href='' title='{ПредставлениеЗвонка}' name='call_comment' id='{ИдЗвонка}'>
	|				<div class='inner-message {HTMLНаправлениеВызова}' style=""{ВерхнийОтступ}"">
    |          			<div class='info-message' style= 'margin: 1px 0 7px 0;'>{Заголовок}</div>
    |           		<div class='text-message' style='color: #000'>{Заметка}</div>
    |         		</div> 
	|        	</a> 
	|		</div>
	|     <div class='die-message' style='background: #f7f7f7'>{Прослушать}</div>
    |    </div>
	|</div>";
	
	Уид = СтрокаТЗ.ПолучитьИдентификатор();
	
	АвторПредставление 				= Строка(СтрокаТЗ.Автор);
	ПредставлениеДлительностиВызова = ?(СтрокаТЗ.Длительность > 0, ВывестиПродолжительностьЗвонка(СтрокаТЗ.Длительность), Нстр("ru='Менее минуты';en='Less minutes'"));             
	Заголовок 						= Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'") + " " + АвторПредставление + " (" + ПредставлениеДлительностиВызова + ")";
	
	Если Не ЗначениеЗаполнено(СтрокаТЗ.Заметка) Тогда
		ВерхнийОтступ	= "--top:-4px;";
		НижнийОтступ	= "--paddingbottom:0px;";
	КонецЕсли;
		
	Если СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "border-color:#0cac09;";		
	КонецЕсли;
	
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{HTMLНаправлениеВызова}", HTMLНаправлениеВызова);
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{Заметка}"   			, ?(ЗначениеЗаполнено(СтрокаТЗ.Заметка), СтрокаТЗ.Заметка, ""));
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{АвторДокумента}"		, АвторПредставление);
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{ИдЗвонка}"		 		, Уид); 
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{ПредставлениеЗвонка}"	, ПредставлениеЗвонка);
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{Редактировать}" 		, Нстр("ru='Редактировать заметку';en='Edit note'"));
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{Заголовок}" 			, Заголовок);
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{ВерхнийОтступ}" 		, ВерхнийОтступ);
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{НижнийОтступ}" 		, НижнийОтступ);
	ШаблонИсходящийЗвонок = СтрЗаменить(ШаблонИсходящийЗвонок, "{СтильHtmlГраницаБлока}", СтильHtmlГраницаБлока);
	
	ВывестиСсылкуПрослушать(ШаблонИсходящийЗвонок, СтрокаТЗ.URLЗаписи, СтрокаТЗ.ФайлЗаписи, Уид, СтрокаТЗ.Взаимодействие);	

	Возврат ШаблонИсходящийЗвонок;	
	
КонецФункции 

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПредварительнойЗаписи(СтрокаТЗ, СтатусЗаписи, Запланировано = Ложь, ПредставлениеШапкиБлока)
	
	Событие = СтрокаТЗ.Взаимодействие;
	
	Представление = "";
	
	ПолисМедСтрахования = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Событие, "ПолисМедСтрахования"); 
	
	ПричинаЗаписи = ?(Событие.Услуги.Количество() > 0 И ЗначениеЗаполнено(Событие.Услуги[0].ПричинаЗаписи), Строка(Событие.Услуги[0].ПричинаЗаписи), "");
	
	ПредставлениеШапкиБлока = Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'"); 		
	
	СтруктураДатаНачалаИДатаОкончания = Документы.Событие.ПолучитьПродолжительностьСобытия(Событие);
	
	// Продолжительность
	ВремяСобытияВМинутах = ?((СтруктураДатаНачалаИДатаОкончания.Свойство("Длительность") И ЗначениеЗаполнено(СтруктураДатаНачалаИДатаОкончания.Длительность)),
	Строка(СтруктураДатаНачалаИДатаОкончания.Длительность) + " " + "мин.",
	"");	
	ПредставлениеШапкиБлока = ?(ЗначениеЗаполнено(ВремяСобытияВМинутах), ПредставлениеШапкиБлока + " - " + ВремяСобытияВМинутах, ПредставлениеШапкиБлока);
	
	// Сотрудник
	ПредствлениеСотрудника 	= ?(ЗначениеЗаполнено(СтрокаТЗ.Сотрудник), Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник), "");
	ПредставлениеШапкиБлока = ?(ЗначениеЗаполнено(ПредствлениеСотрудника), ПредставлениеШапкиБлока + " " + "<b>" + ПредствлениеСотрудника + "</b>", ПредставлениеШапкиБлока);
	
	ПредставлениеШапкиБлока = "Запись на " + ПредставлениеШапкиБлока;
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда
		
		РеквизитыПолисаМедСтрахования 	= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПолисМедСтрахования, "СтраховаяКомпания, Договор");
		РеквизитыКонтрагента 			= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(РеквизитыПолисаМедСтрахования.СтраховаяКомпания, "ЦветФонаМетки, ЦветТекстаБелый, КраткоеНаименование");
		ПрограммаСтрахования 			= ОбщегоНазначения.ПолучитьЗначениеРеквизита(РеквизитыПолисаМедСтрахования.Договор, "ПрограммаСтрахования");
		
		ФонМетки 	= ?(ЗначениеЗаполнено(РеквизитыКонтрагента.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(РеквизитыКонтрагента.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
		ФонМетки 	= ПолучитьЦветHEX(ФонМетки);
		ЦветТекста  = ?(РеквизитыКонтрагента.ЦветТекстаБелый, "rgb(255,255,255)", "rgb(0,0,0)");	
		Заголовок	= РеквизитыКонтрагента.КраткоеНаименование;
		
		БордерРадиус = ?(ЗначениеЗаполнено(ПрограммаСтрахования), "border-radius: 3px 0 0 3px" , "border-radius: 3px");
		
		БлокМеткиМедСтрахования = "<span > <i style='background: {ФонМетки}; {БордерРадиус}; color:{ЦветТекста}; padding: 1px 1px 1px 7px; font-style: normal';> {Заголовок} </i></span>";
		
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{ФонМетки}"		, ФонМетки);  
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{ЦветТекста}"	, ЦветТекста);
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{Заголовок}"	, Заголовок);
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{БордерРадиус}"	, БордерРадиус);
	
		Если ЗначениеЗаполнено(ПрограммаСтрахования) Тогда                                                     
			
			ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(ПрограммаСтрахования);
	       
			БлокВидДоговора = "<span> <i style='background: {ФонПрограммыСтрахования}; border-radius: 0 3px 3px 0; color: {ЦветТекста}; padding: 1px 7px 1px 7px; font-style: normal';> {ЗаголовокПрограммыСтрахования} </i> </span>";  
			
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ФонВидДоговора}"					, ПолучитьЦветHEX(ДанныеПрограммыСтрахования.ЦветФона));
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ЗаголовокПрограммыСтрахования}" 	, ДанныеПрограммыСтрахования.Текст);
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ЦветТекста}"						, ПолучитьЦветHEX(ДанныеПрограммыСтрахования.ЦветТекста));
			
			БлокМеткиМедСтрахования = БлокМеткиМедСтрахования + Символы.ПС + БлокВидДоговора;
		КонецЕсли; 
	Иначе
		БлокМеткиМедСтрахования = "";	
	КонецЕсли;
	
	ПредставлениеШапкиБлока = ПредставлениеШапкиБлока + БлокМеткиМедСтрахования;
	
	БлокШаблон = "<i style= 'font-size: 12px; font-style: normal;'> {Текст} </i>";
			
	ПредставлениеШапкиБлока = СтрЗаменить(БлокШаблон, "{Текст}"	, ПредставлениеШапкиБлока);									
	
	ВремЗапасы = Событие.Услуги.Выгрузить().Скопировать(); 
	ВремЗапасы.Свернуть("Номенклатура");                 
	
	ПредставлениеНоменклатура 	= "";	
	МассивНоменклатур 			= ВремЗапасы.ВыгрузитьКолонку("Номенклатура"); 		
	
	Для Каждого Номенклатура Из МассивНоменклатур Цикл
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			МассивНоменклатур.Удалить(МассивНоменклатур.Найти(Номенклатура));	
		КонецЕсли;
	КонецЦикла;
	
	КоличествоСтрок   = МассивНоменклатур.Количество();
			
	Для Счетчик = 0 По КоличествоСтрок - 1 Цикл 	
		
		Если Счетчик <> КоличествоСтрок - 1 Тогда                // Это не последний элемент.
			ПредставлениеНоменклатура = ПредставлениеНоменклатура + МассивНоменклатур[Счетчик] + ", " + Символы.ПС; 
		Иначе 
			ПредставлениеНоменклатура = ПредставлениеНоменклатура + МассивНоменклатур[Счетчик]; 	 
		КонецЕсли; 
			
	КонецЦикла; 
	
	ПредставлениеНоменклатура = ?(ЗначениеЗаполнено(ПричинаЗаписи) И ЗначениеЗаполнено(ПредставлениеНоменклатура), Символы.ПС + Символы.ПС, ПредставлениеНоменклатура);	
			 	
	Комментарий = Событие.Комментарий; 
	
	Комментарий = ?(ЗначениеЗаполнено(Комментарий) И (ЗначениеЗаполнено(ПредставлениеНоменклатура) Или ЗначениеЗаполнено(ПричинаЗаписи)), Символы.ПС + Символы.ПС + Комментарий, Комментарий);
		
	Возврат ПричинаЗаписи + ПредставлениеНоменклатура + Комментарий;
	
КонецФункции

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПриема(СтрокаТЗ, СтатусПриема, Запланировано = Ложь, ПредставлениеШапкиБлока)
	
	Прием 				= СтрокаТЗ.Взаимодействие; 
	
	ПолисМедСтрахования = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Прием, "ПолисМедСтрахования"); 
	
	Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда
		
		РеквизитыПолисаМедСтрахования 	= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПолисМедСтрахования, "СтраховаяКомпания, Договор");
		РеквизитыКонтрагента 			= ОбщегоНазначения.ПолучитьЗначенияРеквизитов(РеквизитыПолисаМедСтрахования.СтраховаяКомпания, "ЦветФонаМетки, ЦветТекстаБелый, КраткоеНаименование");
		ПрограммаСтрахования 			= ОбщегоНазначения.ПолучитьЗначениеРеквизита(РеквизитыПолисаМедСтрахования.Договор, "ПрограммаСтрахования");
		
		ФонМетки 	= ?(ЗначениеЗаполнено(РеквизитыКонтрагента.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(РеквизитыКонтрагента.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
		ФонМетки 	= ПолучитьЦветHEX(ФонМетки);
		ЦветТекста  = ?(РеквизитыКонтрагента.ЦветТекстаБелый, "rgb(255,255,255)", "rgb(0,0,0)");	
		Заголовок	= РеквизитыКонтрагента.КраткоеНаименование;
		
		БордерРадиус = ?(ЗначениеЗаполнено(ПрограммаСтрахования), "border-radius: 3px 0 0 3px" , "border-radius: 3px");
		
		БлокМеткиМедСтрахования = "<span > <i style='background: {ФонМетки}; {БордерРадиус}; color:{ЦветТекста}; padding: 1px 1px 1px 7px; font-style: normal';> {Заголовок} </i></span>";
		
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{ФонМетки}"		, ФонМетки);  
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{ЦветТекста}"	, ЦветТекста);
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{Заголовок}"	, Заголовок);
		БлокМеткиМедСтрахования = СтрЗаменить(БлокМеткиМедСтрахования, "{БордерРадиус}"	, БордерРадиус);
	
		Если ЗначениеЗаполнено(ПрограммаСтрахования) Тогда
			
			ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(ПрограммаСтрахования);
	        
			ФонПрограммыСтрахования			= ПолучитьЦветHEX(ДанныеПрограммыСтрахования.ЦветФона);
			ЗаголовокПрограммыСтрахования 	= ДанныеПрограммыСтрахования.Текст;
			ЦветТекста						= ПолучитьЦветHEX(ДанныеПрограммыСтрахования.ЦветТекста);
			
			БлокВидДоговора = "<span> <i style='background: {ФонПрограммыСтрахования}; border-radius: 0 3px 3px 0; color: {ЦветТекста}; padding: 1px 7px 1px 7px; font-style: normal';> {ЗаголовокПрограммыСтрахования} </i> </span>";  
			
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ФонПрограммыСтрахования}"			, ФонПрограммыСтрахования);
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ЗаголовокПрограммыСтрахования}" 	, ЗаголовокПрограммыСтрахования);
			БлокВидДоговора = СтрЗаменить(БлокВидДоговора, "{ЦветТекста}"					 	, ЦветТекста);
	
			БлокМеткиМедСтрахования = БлокМеткиМедСтрахования + Символы.ПС + БлокВидДоговора;
		КонецЕсли; 
	Иначе
		БлокМеткиМедСтрахования = "";	
	КонецЕсли;
	
	ПредставлениеСотрудника = "";			
	ВремяПриемаВМинутах 	= "";
		
	Если СтатусПриема = Перечисления.СтатусыСобытия.ПриемОкончен Тогда 	
		Если ЗначениеЗаполнено(Прием.ВремяНачалаПриема) И ЗначениеЗаполнено(Прием.ВремяОкончанияПриема) Тогда
			ВремяПриемаВМинутах = Строка(Окр((Прием.ВремяОкончанияПриема - Прием.ВремяНачалаПриема)/60, 0, РежимОкругления.Окр15как20)) + " " + "мин.";
		ИначеЕсли ЗначениеЗаполнено(Прием.ВремяОкончанияПриема) Тогда
			ВремяПриемаВМинутах = Формат(Прием.ВремяОкончанияПриема, "ДФ='""в"" ЧЧ:мм'");
		КонецЕсли;
	ИначеЕсли СтатусПриема = Перечисления.СтатусыСобытия.ПриемНачат Тогда
		ВремяПриемаВМинутах = Формат(Прием.ВремяНачалаПриема, "ДФ='""в"" ЧЧ:мм'");	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТЗ.Сотрудник) Тогда
		ПредставлениеСотрудника = Справочники.Сотрудники.ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник);	
	КонецЕсли;
	
	// Если ЗначениеЗаполнено(СтатусПриема) Тогда		
	//	
	//	Если ТипЗнч(СтатусПриема) = Тип("ПеречислениеСсылка.СтатусыСобытия") Тогда  
	//		// Цвета статуса.
