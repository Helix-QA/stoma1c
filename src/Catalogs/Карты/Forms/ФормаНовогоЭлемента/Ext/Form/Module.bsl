КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СоздатьКарту".
//
Процедура СоздатьКарту(Команда)
	
	Если Не (Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Wallet") 
		Или ЗначениеЗаполнено(Объект.КодКарты)) Тогда
		
		ПоказатьОповещениеПользователя("Карта (создание)",, СтрШаблон("Поле ""%1"" не заполнено", ?(Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Штриховая"), "Штрихкод", "Заводской номер карты")), БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное);		
		Возврат;
		
	КонецЕсли;
	
	Если ЭтаФорма.Записать() Тогда
		
		ЭтаФорма.Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиСобытийЭлементовФормы

