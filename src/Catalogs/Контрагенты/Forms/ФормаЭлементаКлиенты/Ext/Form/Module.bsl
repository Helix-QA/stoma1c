
&НаКлиенте
перем ТекФамилия; // Хранит текущую фамилию
&НаКлиенте
перем ТекОтчество; // Хранит текущее отчество
&НаКлиенте
перем ТекИмя; // Хранит текущее имя
&НаКлиенте
перем ПредупреждениеДублирование; // Переменная для хранения данных о дублировании записи
&НаКлиенте
Перем СтруктураОбязательныеПоля; // Хранит обязательные поля
&НаКлиенте
Перем КонтактнаяИнформацияОчистить; // Хранит данные контактной информации для очистки

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ЭтаФорма.Заголовок = Строка(Объект.Ссылка) + " (Пациент)";
	
	Если (Параметры.Свойство("ТекущийРодитель")) И (НЕ ЗначениеЗаполнено(Объект.Ссылка)) Тогда // это новый, тогда заполним родителя
		Объект.Родитель = Параметры.ТекущийРодитель;
	КонецЕсли;
	
	ЭтотОбъект.ТекущийПользователь       = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ЮрФизЛицо                        = Перечисления.ЮрФизЛицо.ФизЛицо;
		Объект.ДатаРегистрации                  = ТекущаяДата();
		
		Если Параметры.Свойство("Фамилия") Тогда
			Объект.Фамилия = Параметры.Фамилия;
		КонецЕсли;
			
		Если Параметры.Свойство("Имя") Тогда
			Объект.Имя = Параметры.Имя;
		КонецЕсли;
		
		Если Параметры.Свойство("Отчество") Тогда
			Объект.Отчество = Параметры.Отчество;
		КонецЕсли;
		
		Если Параметры.Свойство("Родитель") Тогда
		     Объект.Родитель = Параметры.Родитель;
		КонецЕсли;
		 
		// Объект.Фамилия      = ?(Параметры.Свойство("Фамилия")  	   , Параметры.фамилия 		, "");
		// Объект.Имя          = ?(Параметры.Свойство("Имя")		   , Параметры.Имя     		, "");
		// Объект.Отчество     = ?(Параметры.Свойство("Отчество")	   , Параметры.Отчество		, "");
		Объект.Телефон      = ?(Параметры.Свойство("НомерТелефона"), Параметры.НомерТелефона, ""); 
		Объект.ПолКлиента   = ?(Параметры.Свойство("Пол")		   , Параметры.Пол		    , "");
		Объект.Наименование = ?(Параметры.Свойство("Наименование") , Параметры.Наименование , "");
		
		Элементы.ФормаСоздатьПрием.Доступность = Ложь;
		Элементы.ФормаСоздатьПрием.Видимость   = Ложь;
		
	КонецЕсли;
	
	//// Обработчик механизма "Контактная информация".
	// УправлениеКонтактнойИнформацией.ПриСозданииНаСервере(ЭтаФорма, Объект, "ГруппаКонтактнаяИнформацияКлиенты");
		
	// Контактная информация
	УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервере(ЭтотОбъект);
	// Конец Контактная информация.
	Автокоррекция = Объект.Родитель.Автокоррекция;

	Если Объект.Ссылка.Пустая() Тогда
		Элементы.ГруппаУдостоверенияЛичности.Видимость = Ложь;
		Элементы.ГруппаУдостоверениеЛичности.Видимость = Истина;
		Элементы.ОткрытьИсториюСтатусов.Доступность    = Ложь;
		СтатусКлиента = Перечисления.СтатусыКонтрагентов.Потенциальный;
		СформироватьСтруктуруДанныхВсплывающихГрупп();
	Иначе
		Элементы.ГруппаУдостоверенияЛичности.Видимость = Истина;
		Элементы.ГруппаУдостоверениеЛичности.Видимость = Ложь;
		СтатусКлиента = Справочники.Контрагенты.ПолучитьСтатус(Объект.Ссылка);
		Если СтатусКлиента = Перечисления.СтатусыКонтрагентов.ПустаяСсылка() Тогда
			СтатусКлиента = Перечисления.СтатусыКонтрагентов.Потенциальный;
		КонецЕсли;
		
		СформироватьСтруктуруДанныхВсплывающихГрупп();
		ВывестиИсториюСтатусовКонтрагента();
		ОтобразитьЗаявкуКонтрагента();
		
	КонецЕсли;
	
	// Добавление телефонного номера в дополнительные реквизиты
	Если Не ЗначениеЗаполнено(Объект.Ссылка) И Параметры.Свойство("НомерТелефона") Тогда
		Справочники.Контрагенты.ДобавитьНомерТелефона(ЭтаФорма, Параметры.НомерТелефона);		
	КонецЕсли;    	
	
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Объект, "ГруппаДополнительныеРеквизиты");	
		
	// -------------------------
	// УправлениеСвойствамиСтома.ПриСозданииНаСервере(ЭтаФорма, Объект, "ГруппаДополнительнаяИнформация");
	
	// Установим отбор на записи удостоверения личности контрагента и прочитаем его
	// УдостоверениеЛичностиКонтрагентаЗапись = РеквизитФормыВЗначение("УдостоверениеЛичностиКонтрагента");
	// УдостоверениеЛичностиКонтрагентаЗапись.Период = ТекущаяДата();
	// УдостоверениеЛичностиКонтрагентаЗапись.ФизЛицо = Объект.Ссылка;
	// УдостоверениеЛичностиКонтрагентаЗапись.ВидДокумента = ВернутьВидДокументаДФЛДляВывода(Объект.Ссылка);
	// Если НЕ УдостоверениеЛичностиКонтрагентаЗапись.ВидДокумента.Пустая() Тогда // Считываем значение, только если есть необходимые документы
	//	УдостоверениеЛичностиКонтрагентаЗапись.Прочитать();
	// КонецЕсли;
	// ЗначениеВРеквизитФормы(УдостоверениеЛичностиКонтрагентаЗапись, "УдостоверениеЛичностиКонтрагента");
	
	ЗаполнитьТаблицуМеток();
	ОбновитьМетки(НЕ Объект.Ссылка.Пустая());
	УправлениеЭлементамиФормы();
	
	ЗаполненПол = ?(ЗначениеЗаполнено(Объект.ПолКлиента), Истина, ЗаполненПол);
	
	Если РольДоступна("Администрирование") ИЛИ РольДоступна("ПолныеПрава") Тогда
		Элементы.ОбязательныеПоля.Видимость = Истина;
	КонецЕсли;	

	ЗаполнитьСписокВыбораРежимаНапоминания();
	ЗаполнитьСписокВыбораВзаимодействияЗадача();	
	
	УстановитьОтборВСпискеПолисов();
	УправлениеЭлементамиФормы();
	ПриСозданииПриЧтенииНаСервере();
	
	ВремСписокФильтрацииИсторииВзаимодействия = ХранилищеСистемныхНастроек.Загрузить("Справочники.Контрагенты.Форма.ФормаЭлементаКлиенты", "НастройкиФильтрации");	
	ОбщегоНазначенияКлиентСерверСтоматология.ЗаполнитьСписокФильтрацииИсторииВзаимодействияПоУмолчанию(СписокФильтрацииИсторииВзаимодействия, Неопределено, ВремСписокФильтрацииИсторииВзаимодействия, Объект.Ссылка);	
	
	ФильтрПрименен = ФильтрПрименен(СписокФильтрацииИсторииВзаимодействия);	
	Элементы.ОчиститьФильтры.Видимость	= ФильтрПрименен;
	Элементы.ПоказатьФильтры.Картинка	= ?(ФильтрПрименен, БиблиотекаКартинок.ФильтрУстановлен, БиблиотекаКартинок.ФильтрНеУстановлен); 
	
	Если НЕ Объект.Ссылка.Пустая() Тогда		
		СформироватьИсториюВзаимодействияСКлиентом();
	КонецЕсли;
	
	УстановитьОбязательныеПоля();
	ЗаполнитьСписокВыбораШаблоновSMSСообщений();
	ОбновитьОформлениеКнопкиСтатусаКлиента();
	
	Если Параметры.Свойство("Сделка") 
		И ЗначениеЗаполнено(Параметры.Сделка) Тогда
		
		ЭтотОбъект.Сделка = Параметры.Сделка;
		УправлениеИнтерфейсамиСервер.ОбновитьВиджетСделки(ЭтаФорма,, Параметры.Сделка);
		
		ЭтотОбъект.ВзаимодействиеСделка = Параметры.Сделка;
		УстановитьСостояниеЭлементовСделкиВзаимодействия(ЭтотОбъект.ВзаимодействиеСделка, ЭтотОбъект.ВзаимодействиеСделка.ЭтапСделки.ЦветЭтапа);
	Иначе 	
		ОбновитьВиджетСделки();			
	КонецЕсли;
	
	ПроизвестиАвтокоррекциюФИО();			
	
	ЗаполнитьДанныеТелефоновДоИзменения();
	
	Элементы.ДекорацияГруппаКровиСтрокой.Видимость = Ложь;
	Если НЕ ЗначениеЗаполнено(Объект.ГруппаКрови) И ЗначениеЗаполнено(Объект.ГруппаКрови_Удалить) Тогда
		Элементы.ДекорацияГруппаКровиСтрокой.Видимость = Истина;
		Элементы.ДекорацияГруппаКровиСтрокой.Заголовок = Объект.ГруппаКрови_Удалить;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриЗакрытии" формы
//
Процедура ПриЗакрытии()
	
	Оповестить("ДанныеКлиентаМодифицированы");	

	Если ЭтаФорма.ОписаниеОповещенияОЗакрытии <> Неопределено И ЭтаФорма.ОписаниеОповещенияОЗакрытии.ИмяПроцедуры = "ДобавитьИВыбратьКонтрагентаЗавершение" Тогда
		ОповеститьОВыборе(Объект.Ссылка);
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// Обработчик механизма "Свойства".
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтаФорма, ИмяСобытия, Параметр) Тогда
		ОбновитьДополнительныеРеквизиты();
	КонецЕсли;
	
	Если ИмяСобытия = "ПРОВЕДЕН_ВЗНОС_НА_ЛИЦЕВОЙ_СЧЕТ" И Источник = Объект.Ссылка Тогда 
		
		// Дополнительная информация
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаЛицевыеБонусныеСчетаСуществующие");	
		ОтображениеДополнительнойИнформации(МассивРодителей);
		ПоказатьОповещениеПользователя(,,"Зачислено на лицевой счет: " + Строка(Параметр.СуммаВзноса) + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты(), БиблиотекаКартинок.Информация32, СтатусОповещенияПользователя.Информация);
		
	КонецЕсли;
	
	Если ИмяСобытия = "ОБНОВЛЕНЫ_МЕТКИ_КЛИЕНТА" Тогда
		ОбновитьМетки();
	ИначеЕсли (ИмяСобытия = "ОБНОВЛЕНА_ТЕКУЩАЯ_МЕДИЦИНСКАЯ_КАРТА_КЛИЕНТА" ИЛИ ИмяСобытия = "ОБНОВЛЕНЫ_МЕДИЦИНСКИЕ_КАРТЫ_КЛИЕНТА")
		И Параметр = Объект.Ссылка Тогда
		
		Если ЗначениеЗаполнено(Источник) 
			И Не ЗначениеЗаполнено(Объект.ТекущаяМедицинскаяКарта) Тогда
			Объект.ТекущаяМедицинскаяКарта = Источник;
			Записать();
		КонецЕсли;
		
		Прочитать();
		УправлениеЭлементамиФормы();
		
	ИначеЕсли ИмяСобытия = "ОчиститьПолеКИ"
		И КонтактнаяИнформацияОчистить <> Неопределено Тогда
		
		Результат = ЭтаФорма.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид, Представление", КонтактнаяИнформацияОчистить.Вид, КонтактнаяИнформацияОчистить.Представление));
		
		Если Результат.Количество() > 0 Тогда 			
			ЭтаФорма.КонтактнаяИнформация.Удалить(Результат[0]);			
		КонецЕсли;
		
		КонтактнаяИнформацияОчистить = Неопределено;
		
	ИначеЕсли ИмяСобытия = "ОбновленыУдостоверения" Тогда
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаУдостоверенияЛичностиСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);  
	ИначеЕсли ИмяСобытия = "СозданаНоваяКарта" ИЛИ ИмяСобытия = "ИзмененаКарта" Тогда
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаКартыСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);	
	ИначеЕсли ИмяСобытия = "ЗаписанаСкидка" Тогда
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаСкидкиСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);
	ИначеЕсли ИмяСобытия = "ОбновленыПолисы" Тогда
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаПолисыСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);
	ИначеЕсли ИмяСобытия = "ОбновитьИсториюВзаимодействияКонтрагента" Тогда
		Если ЗначениеЗаполнено(Параметр) И ТипЗнч(Параметр) = Тип("Структура") Тогда 
			Если Параметр.Свойство("Пациент") И Параметр.Пациент = Объект.Ссылка Тогда
				// Фильтры = Новый Структура();
				СформироватьИсториюВзаимодействияСКлиентом();
				// УстановитьФильтрИсторииВзаимодействияНаСервере();
			КонецЕсли;
		КонецЕсли;	
	ИначеЕсли ИмяСобытия = "СозданаИзмененаУчетнаяЗапись" Тогда		
		ВзаимодействиеПисьмоНастроитьАккаунтЗавершение(Параметр);
	КонецЕсли; 
	
	Если ИмяСобытия = "ОбновленаРодственнаяСвязь" Тогда 
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаРодственникиСуществующие");
		ОтображениеДополнительнойИнформации(МассивРодителей);
	КонецЕсли;
	
	Если ИмяСобытия = "ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ" Тогда
		УстановитьФокусЭлемента();
		ОбновитьВиджетИСтатусКонтрагента();
		УстановитьАктуальнуюСделкуВзаимодействия();
	КонецЕсли;	
	
	Если ИмяСобытия = "ОбновленыПолисы" Тогда
		
	КонецЕсли;
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОБЯЗАТЕЛЬНЫЕ_ПОЛЯ" Тогда
		УстановитьОбязательныеПоля();
		ЭтаФорма.ОтключитьОтметкуНезаполненного();
	КонецЕсли; 
	
	Если ИмяСобытия = "ОбновленыПромокоды" Тогда	
		
		МассивРодителей = Новый Массив();
		МассивРодителей.Добавить("ГруппаПромокодыСуществующие");
		
		ОтображениеДополнительнойИнформации(МассивРодителей);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриЧтенииНаСервере".
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	
	ЗаполнитьСписокТелефоновДляWhatsApp();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПередЗаписью" формы
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	УстановитьОбязательныеПоля();
	СтруктураОбязательныхДинамПолей = ПолучитьОбязательныеДинамПоля();
	СтруктураФлаговДинамПолей       = Неопределено;
	
	Для Каждого ЭлементФормы Из Элементы Цикл
		
		Если ТипЗнч(ЭлементФормы) = Тип("ПолеФормы") И ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода  И ЭлементФормы.АвтоОтметкаНезаполненного = Истина Тогда			
			
			Если Найти(ЭлементФормы.Имя, "ДатаРождения") <> 0 И ЭлементФормы.ТекстРедактирования = "  .  .    " 
				И НЕ ЗначениеЗаполнено(Объект.ДатаРожденияКлиента) Тогда
				
				Если ЭлементФормы.Имя = "ДатаРождения" Тогда
					ИмяЭлемента = "Дата рождения";				
				КонецЕсли;
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле дата рождения пациента!");
				Отказ = Истина;
				Прервать; 
			
			КонецЕсли;
			
			Если ЭлементФормы.ТекстРедактирования = "" Тогда
				
				Если ЭлементФормы.Имя = "Наименование" Тогда
					
					Если Объект.Наименование <> "" Тогда
						Продолжить;
					КонецЕсли;
					ИмяЭлемента = "Имя";
					
				ИначеЕсли СтрНачинаетсяС(ЭлементФормы.Имя, "ПредставлениеКИ_") = Истина Тогда
					Продолжить;  
					
				ИначеЕсли ЭлементФормы.Имя = "ВидДокумента" ИЛИ ЭлементФормы.Имя = "Серия" ИЛИ ЭлементФормы.Имя = "Номер"  
					ИЛИ ЭлементФормы.Имя = "КемВыдан" ИЛИ ЭлементФормы.Имя = "КодПодразделения" ИЛИ ЭлементФормы.Имя = "ДатаВыдачи" Тогда 
					
					Если ЭлементФормы.Имя = "ВидДокумента" Тогда
						ИмяЭлемента = "вид документа"; 
					ИначеЕсли ЭлементФормы.Имя = "КодПодразделения" Тогда
						ИмяЭлемента = "код подразделения";
					ИначеЕсли ЭлементФормы.Имя = "ДатаВыдачи" Тогда
						ИмяЭлемента = "дата выдачи";
					ИначеЕсли ЭлементФормы.Имя = "КемВыдан" Тогда
						ИмяЭлемента = "кем выдан"; 
					Иначе
						ИмяЭлемента = НРег(ЭлементФормы.Имя);
					КонецЕсли; 
					ЗначениеЭлемента = ВернутьВидДокументаДФЛДляВывода(Объект.Ссылка, ЭлементФормы.Имя);
					Если ЗначениеЗаполнено(ЗначениеЭлемента) Тогда
						Продолжить;
					КонецЕсли;	
					
				ИначеЕсли ЭлементФормы.Имя = "Куратор" ИЛИ ЭлементФормы.Имя = "Родитель" ИЛИ ЭлементФормы.Имя = "МестоРождения"
					ИЛИ ЭлементФормы.Имя = "СоциальныйСтатус" Тогда 
					Если ЭлементФормы.Имя = "МестоРождения" Тогда
						ИмяЭлемента = "место рождения";
					ИначеЕсли ЭлементФормы.Имя = "Родитель" Тогда
						ИмяЭлемента = "группа пациентов"; 
					ИначеЕсли ЭлементФормы.Имя = "СоциальныйСтатус" Тогда
						ИмяЭлемента = "социальный статус";
					Иначе
						ИмяЭлемента = НРег(ЭлементФормы.Имя);
					КонецЕсли;  
					
					Если ЗначениеЗаполнено(Объект[ЭлементФормы.Имя]) Тогда
						Продолжить;
					КонецЕсли;	
					
				Иначе
					ИмяЭлемента = ЭлементФормы.Имя;	
					Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, ЭлементФормы.Имя) И ЗначениеЗаполнено(Объект[ЭлементФормы.Имя]) Тогда 					
						Продолжить;	
					КонецЕсли;
					
				КонецЕсли;
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле " + ИмяЭлемента + "!");
				Отказ = Истина;
				Прервать;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ТипЗнч(ЭлементФормы) = Тип("ПолеФормы") И ЭлементФормы.Вид = ВидПоляФормы.ПолеВвода Тогда
			Если СтрНачинаетсяС(ЭлементФормы.Имя, "ПредставлениеКИ_") = Истина Тогда
				СтруктураФлаговДинамПолей = ПроверитьОбязательныеДинамПоля(ЭлементФормы, СтруктураФлаговДинамПолей);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла; 
	
	Если СтруктураФлаговДинамПолей = Неопределено Тогда
		СтруктураФлаговДинамПолей = СоздатьОбнуленнуюСтруктуруФлаговДинамПолей();
	КонецЕсли;
	
	// Проверка динамических полей, обязательных для заполнения, на заполненность
	// Если внесено несколько полей для телефонов, необходимо, чтобы хотя бы одно из полей было заполнено. С Email то же самое
	// Проверка осуществляется выше, и выставляются Флаги. Здесь флаги просто проверяются для вывода сообщения об ошибке
	Если СтруктураОбязательныхДинамПолей.ФлагТелефон = Истина 
		И СтруктураФлаговДинамПолей.ХотяБыОдинТелефон = Ложь Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле Телефон!");
		Отказ = Истина;
		
	ИначеЕсли СтруктураОбязательныхДинамПолей.ФлагEmail = Истина 
		И СтруктураФлаговДинамПолей.ХотяБыОдинEmail = Ложь Тогда 
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле Email!");
		Отказ = Истина;
		
	ИначеЕсли СтруктураОбязательныхДинамПолей.ФлагАдрес = Истина 
		И СтруктураФлаговДинамПолей.ХотяБыОдинАдрес = Ложь Тогда 
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено поле Адрес!");
		Отказ = Истина;
		
	КонецЕсли;
	
	// Страховые метки выводятся из полиса, нет необходимость хранить их в метках клиента.
	//
	//	МеткаСтраховая = ПолучитьСсылкуМеткиПоНаименованию("Страховая");
	//	Если ЕстьДействующийПолис() И НЕ МеткаСтраховая.Пустая() Тогда
	//		МеткаДляУстановки = ТаблицаМеток.НайтиСтроки(Новый Структура("Метка", МеткаСтраховая));
	//		Для Каждого Метка Из МеткаДляУстановки Цикл
	//			Метка.Активна = Истина;
	//		КонецЦикла;
	//	КонецЕсли;
	
	Если Объект.ЮрФизЛицо.Пустая() Тогда
		Объект.ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ФизЛицо");
	КонецЕсли;
	
	Объект.Наименование = Объект.Фамилия + ?(ЗначениеЗаполнено(Объект.Фамилия), " ", "") + Объект.Имя + ?(ЗначениеЗаполнено(Объект.Имя), " ", "") + Объект.Отчество;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// Заполним служебный реквизит номера телефонов
	НомераТелефонов = Новый Массив;
	Для Каждого СтрокаКИ Из ТекущийОбъект["КонтактнаяИнформация"] Цикл
		Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон И НЕ ПустаяСтрока(СтрокаКИ.Представление) Тогда
			НомераТелефонов.Добавить(СтрокаКИ.Представление);
		КонецЕсли;
	КонецЦикла;
	
	ТекущийОбъект.Телефон = СтрСоединить(НомераТелефонов, ", ");
	
	// КонтактнаяИнформация
	УправлениеКонтактнойИнформациейСтоматология.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец КонтактнаяИнформация
	
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);
	
	// Синхронизация данных контактов мессенджеров с телефонами клиентов.
	ЗаполнитьДанныеТелефоновПередЗаписью();
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ИзмененныеТелефоны", ЭтотОбъект.ИзменяемыеТелефоныМессенджера);
	
	ТекущийСтатус = Справочники.Контрагенты.ПолучитьСтатус(Объект.Ссылка);
	Если НЕ ЗначениеЗаполнено(ТекущийСтатус) Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("Статус", СтатусКлиента);
	Иначе 
		ТекущийОбъект.ДополнительныеСвойства.Вставить("Статус", ТекущийСтатус);
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере"
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления);
	// Если контрагент был пустой, то обновляем в наборах записей на ссылку созданного контрагента
	Если УдостоверениеЛичностиКонтрагента.Физлицо <> Объект.Ссылка Тогда
		УдостоверениеЛичностиКонтрагента.Физлицо = Объект.Ссылка;
	КонецЕсли;
	
	// Запись данных Удостоверения личности
	Если Не УдостоверениеЛичностиКонтрагента.ВидДокумента.Пустая() И ЗначениеЗаполнено(УдостоверениеЛичностиКонтрагента.Физлицо) Тогда
		УдостоверениеЛичностиКонтрагентаЗапись = РеквизитФормыВЗначение("УдостоверениеЛичностиКонтрагента");
		УдостоверениеЛичностиКонтрагентаЗапись.Записать();
		ЗначениеВРеквизитФормы(УдостоверениеЛичностиКонтрагентаЗапись, "УдостоверениеЛичностиКонтрагента");
		// ИначеЕсли Не УдостоверениеЛичностиКонтрагента.ИсходныйКлючЗаписи.Пустой() И УдостоверениеЛичностиКонтрагента.ВидДокумента.Пустая() Тогда
		//	УдостоверениеЛичностиКонтрагентаЗапись = РеквизитФормыВЗначение("УдостоверениеЛичностиКонтрагента");
		//	ЗаполнитьЗначенияСвойств(УдостоверениеЛичностиКонтрагентаЗапись, УдостоверениеЛичностиКонтрагента.ИсходныйКлючЗаписи);
		//	УдостоверениеЛичностиКонтрагентаЗапись.Удалить();
		//	ЗначениеВРеквизитФормы(УдостоверениеЛичностиКонтрагентаЗапись, "УдостоверениеЛичностиКонтрагента");
	КонецЕсли;
	
	УправлениеЭлементамиФормы(); 
	
	// Обработчик механизма "Свойства".
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект);

КонецПроцедуры

