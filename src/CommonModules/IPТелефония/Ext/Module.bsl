// Функция - Звонок уже записан в базу и не требуется его перезапись
//
// Параметры:
//  IDЗвонка - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЗвонокУжеЗаписанВБазуИНеТребуетсяЕгоПерезапись(IDЗвонка)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ИсторияВызовов.IDЗвонка КАК IDЗвонка
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	|ГДЕ
	|	ИсторияВызовов.IDЗвонка = &IDЗвонка
	|	И (ИсторияВызовов.URLЗаписи <> """"
	|			ИЛИ ИсторияВызовов.НачалоВызова <= &ДатаПред
	|			ИЛИ ИсторияВызовов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Завершен)
	|			ИЛИ ИсторияВызовов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.НеДозвон)
	|			ИЛИ ИсторияВызовов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Пропущен))");
	
	Запрос.УстановитьПараметр("IDЗвонка"	, IDЗвонка);
	Запрос.УстановитьПараметр("ДатаПред"	, ТекущаяДатаСеанса() - 86400);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

