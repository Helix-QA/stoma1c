			// ГруппаПоляБлокировкиСтрокиТабличнойЧасти.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Центр;
			//
			// Если ИндексСтрокиТЧ = 0 Тогда 
			//	ДекорацияФормы_Заглушка_БлокироватьСтроку = Форма.Элементы.Добавить("ДекорацияФормы_Заглушка_Блокировать_ТЧ_" + ПредставлениеТЧ, Тип("ДекорацияФормы"), ГруппаПоляБлокировкиСтрокиТабличнойЧасти);
			//	ДекорацияФормы_Заглушка_БлокироватьСтроку.Вид       = ВидДекорацииФормы.Надпись;
			//	ДекорацияФормы_Заглушка_БлокироватьСтроку.Заголовок = "";
			//	ДекорацияФормы_Заглушка_БлокироватьСтроку.Шрифт     = Новый Шрифт("Arial", 5); 
			// КонецЕсли;
			//
			// Если НоменклатураЗаполнена Тогда
			//	
			//	ПолеФормы_БлокироватьСтроку = Элементы.Добавить("ПолеФормы_БлокироватьСтроку_ТЧ_" + ПредставлениеТЧ, Тип("ПолеФормы"), ГруппаПоляБлокировкиСтрокиТабличнойЧасти);
			//	ПолеФормы_БлокироватьСтроку.Вид                            = ВидПоляФормы.ПолеКартинки;
			//	ПолеФормы_БлокироватьСтроку.ПутьКДанным                    = "Объект." + ПараметрыТабличнойЧасти.ТабличнаяЧасть + "["+ Строка(ИндексСтрокиТЧ) + "]" + ".ПризнакЗаблокированно";
			//	ПолеФормы_БлокироватьСтроку.ПоложениеЗаголовка             = ПоложениеЗаголовкаЭлементаФормы.Нет;
			//	ПолеФормы_БлокироватьСтроку.КартинкаЗначений               = БиблиотекаКартинок.КоллекцияКартинокБлокировкаНовая;
			//	ПолеФормы_БлокироватьСтроку.Гиперссылка                    = Истина;
			//	ПолеФормы_БлокироватьСтроку.Ширина                         = 2;
			//	ПолеФормы_БлокироватьСтроку.Рамка                          = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
			//	ПолеФормы_БлокироватьСтроку.РастягиватьПоГоризонтали       = Ложь;
			//	ПолеФормы_БлокироватьСтроку.РастягиватьПоВертикали         = Ложь;
			//	ПолеФормы_БлокироватьСтроку.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
			//	
			//	ПолеФормы_БлокироватьСтроку.УстановитьДействие("Нажатие", "Подключаемый_БлокироватьСтрокуТабличнойЧасти");
			//	
			// КонецЕсли;
			
			
			ПредыдущаяСтрока = СтрокаТЧ;
			
		КонецЦикла;
		
		//  Создаем декорацию "Услуги отсутствуют"
		Если ГруппаРодительТабличнойЧасти.ПодчиненныеЭлементы.Количество() = 0 Тогда 
			
			ДекорацияФормы_Услуги_Отсутствуют = Форма.Элементы.Добавить("ДекорацияФормы_Услуги_Отсутствуют_ТЧ_" + ПараметрыТабличнойЧасти.ТабличнаяЧасть, Тип("ДекорацияФормы"), ГруппаРодительТабличнойЧасти);
			ДекорацияФормы_Услуги_Отсутствуют.Вид 									= ВидДекорацииФормы.Надпись;
			ДекорацияФормы_Услуги_Отсутствуют.Заголовок 							= "Услуги отсутствуют";
			ДекорацияФормы_Услуги_Отсутствуют.РастягиватьПоГоризонтали 				= Истина;
			ДекорацияФормы_Услуги_Отсутствуют.АвтоМаксимальнаяШирина 				= Ложь;
			ДекорацияФормы_Услуги_Отсутствуют.МаксимальнаяШирина 					= 55; // 127
			ДекорацияФормы_Услуги_Отсутствуют.ГоризонтальноеПоложение 				= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Услуги_Отсутствуют.ВертикальноеПоложение 				= ВертикальноеПоложениеЭлемента.Центр;			
			ДекорацияФормы_Услуги_Отсутствуют.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Услуги_Отсутствуют.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Услуги_Отсутствуют.Шрифт 								= Новый Шрифт("Arial", 11); 
			// ДекорацияФормы_Услуги_Отсутствуют.ЦветФона 								= ЦветаСтиля.ЦветФонаЗадач;
			
		КонецЕсли;
			
	КонецЦикла;

		
	//	Форма.ОтобразитьНовуюСтроку();
	
КонецПроцедуры

// Процедура - Заполнить шкалу длительности приема
//
// Параметры:
//  Форма				 - 	 ЭтаФорма 
//  ГруппаВыводаКнопок	 - 	 Тип строка, название группы для вывода кнопок длительности 
//  МассивДлительностей	 - 	 Длительности, которые необходимо вывести.
//							 Если Неопределено - длительности берутся из регистра длительностей.
//							 Не учитывается, если передать НовыйЭлемент!							 
//  НовыйЭлемент		 - 	 Длительность, которую необходимо добавить. Если передать этот параметр, будет  только отрисован этот элемент 
//  ВозможностьУдалять	 - 	 Истина = Выводить кнопки удаления возле каждой длительности. Истина - только для формы настроек планировщика. 
//
Процедура ЗаполнитьШкалуДлительностиПриема(Форма, ГруппаВыводаКнопок, МассивДлительностей, НовыйЭлемент, ВозможностьУдалять = Ложь, РасширениеПланировщикаАктивно = Истина) Экспорт
	
	Массив_Длительности = Новый Массив;

	Если НЕ ЗначениеЗаполнено(ГруппаВыводаКнопок) Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьКнопкиДлительности = Ложь;
	
	Если ЗначениеЗаполнено(НовыйЭлемент) ИЛИ НовыйЭлемент = 0 Тогда	
		
		// Использовалась кнопка N'
		Если НЕ ТипЗнч(НовыйЭлемент) = Тип("Массив") Тогда
			Массив_Длительности.Добавить(НовыйЭлемент);
		Иначе
			Массив_Длительности = НовыйЭлемент;
		КонецЕсли;	
		
		// КоличествоКнопокДлительности = РегистрыСведений.ДлительностиПриемов.ПолучитьКоличествоКнопокДлительности() + Массив_Длительности.Количество();
		
	Иначе
		
		Если НЕ ЗначениеЗаполнено(МассивДлительностей) Тогда
			Массив_Длительности = РегистрыСведений.ДлительностиПриемов.ВернутьДлительностиПриемов(Истина);
		КонецЕсли;
		УдалитьКнопкиДлительности = Истина;
		
		Массив_Длительности.Добавить("N");
		
		// КоличествоКнопокДлительности = Массив_Длительности.Количество();
		
	КонецЕсли;
	
	КоличествоЭлементовВГруппе = ?(ВозможностьУдалять, ?(РасширениеПланировщикаАктивно, 9, 8), 11);
	
	ГруппаДляРазмещенияДлительности = Форма.Элементы.Найти(ГруппаВыводаКнопок);	

	Если НЕ ГруппаДляРазмещенияДлительности = Неопределено Тогда
				
		// Удаляем созданные группы с длительностями
		Если УдалитьКнопкиДлительности Тогда
			
			МассивУдаляемыхГрупп = Новый Массив;		
			Для Каждого УдаляемаяОбщаяГруппа Из ГруппаДляРазмещенияДлительности.ПодчиненныеЭлементы Цикл
				МассивУдаляемыхГрупп.Добавить(УдаляемаяОбщаяГруппа);				
			КонецЦикла;		
			Для Каждого УдаляемыйЭлемент Из МассивУдаляемыхГрупп Цикл
				Форма.Элементы.Удалить(УдаляемыйЭлемент);
			КонецЦикла;
			
		КонецЕсли;
				
		Если ВозможностьУдалять Тогда
			
			Если Форма.Команды.Найти("УстановитьВремяДлительности") = Неопределено Тогда
				КомандаУстановитьВремяДлительности				= Форма.Команды.Добавить("УстановитьВремяДлительности");
				КомандаУстановитьВремяДлительности.Заголовок	= "Элемент длительности приема";
				КомандаУстановитьВремяДлительности.Действие		= "Подключаемый_УстановитьВремяДлительности";
			КонецЕсли;
			
			ЭтоВебКлиент = ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент();
			
		Иначе
			ЭтоВебКлиент = Форма.ЗапускВэбКлиент;
		КонецЕсли;
		
		КешИндексГруппы = 1;
		ГруппаДляРазмещенияДлительностиОбщая = Неопределено;
		
		Для НомерСоздаваемойКнопки = 0 По Массив_Длительности.ВГраница() Цикл	
			
			// Создание групп-контейнеров по рядам
			
			Если НовыйЭлемент = Неопределено Тогда
				
				ТекущийИндексГруппы = Цел(НомерСоздаваемойКнопки / (КоличествоЭлементовВГруппе));
				
				Если КешИндексГруппы = ТекущийИндексГруппы Тогда
					
					Если ГруппаДляРазмещенияДлительностиОбщая = Неопределено Тогда					
						ГруппаДляРазмещенияДлительностиОбщая = Форма.Элементы.Найти(ГруппаДляРазмещенияДлительности.Имя + "_Общая_"+ТекущийИндексГруппы);						
					КонецЕсли;
					
				Иначе
					
					ГруппаДляРазмещенияДлительностиОбщая = Форма.Элементы.Добавить(ГруппаДляРазмещенияДлительности.Имя + "_Общая_"+ТекущийИндексГруппы, Тип("ГруппаФормы"), ГруппаДляРазмещенияДлительности);
					ГруппаДляРазмещенияДлительностиОбщая.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
					ГруппаДляРазмещенияДлительностиОбщая.Заголовок 				= ГруппаДляРазмещенияДлительности.Имя;
					ГруппаДляРазмещенияДлительностиОбщая.Отображение 			= ОтображениеОбычнойГруппы.Нет;
					ГруппаДляРазмещенияДлительностиОбщая.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
					ГруппаДляРазмещенияДлительностиОбщая.ОтображатьЗаголовок 	= Ложь;
					ГруппаДляРазмещенияДлительностиОбщая.ГоризонтальныйИнтервал	= ИнтервалМеждуЭлементамиФормы.Одинарный;
					
					Если ВозможностьУдалять Тогда
						ГруппаДляРазмещенияДлительностиОбщая.ВертикальныйИнтервал	= ИнтервалМеждуЭлементамиФормы.Половинный;							
					КонецЕсли;
					
					КешИндексГруппы = ТекущийИндексГруппы;
					
				КонецЕсли;
			Иначе
				
				КоличествоГруппыДлительностиНаФорме = ГруппаДляРазмещенияДлительности.ПодчиненныеЭлементы.Количество();	
				
				Если ЗначениеЗаполнено(КоличествоГруппыДлительностиНаФорме) Тогда 
					ГруппаДляРазмещенияДлительностиОбщая = ГруппаДляРазмещенияДлительности.ПодчиненныеЭлементы[КоличествоГруппыДлительностиНаФорме-1];
				Иначе
					ГруппаДляРазмещенияДлительностиОбщая = ГруппаДляРазмещенияДлительности;
				КонецЕсли;
								
			КонецЕсли;
			
			// Создание кнопок длительности
			
			ЭлементДлительность = Массив_Длительности[НомерСоздаваемойКнопки];
			
			Если НЕ Форма.Элементы.Найти(ГруппаДляРазмещенияДлительности.Имя + "_" + ЭлементДлительность) = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			Если ВозможностьУдалять Тогда 	
				
				ГруппаВыравниваниеЭлементаДлительности = Форма.Элементы.Добавить("Выравнивание"+ГруппаДляРазмещенияДлительности.Имя + "_" + ЭлементДлительность, Тип("ГруппаФормы"), ГруппаДляРазмещенияДлительностиОбщая);
				ГруппаВыравниваниеЭлементаДлительности.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
				ГруппаВыравниваниеЭлементаДлительности.Заголовок 			= ГруппаВыравниваниеЭлементаДлительности.Имя;
				ГруппаВыравниваниеЭлементаДлительности.Отображение 			= ОтображениеОбычнойГруппы.Нет;
				ГруппаВыравниваниеЭлементаДлительности.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				ГруппаВыравниваниеЭлементаДлительности.ОтображатьЗаголовок 	= Ложь;
				ГруппаВыравниваниеЭлементаДлительности.ГоризонтальныйИнтервал	= ИнтервалМеждуЭлементамиФормы.Нет;	
				
			КонецЕсли;
			
			ГруппаЭлементаДлительности = Форма.Элементы.Добавить(ГруппаДляРазмещенияДлительности.Имя + "_" + ЭлементДлительность, Тип("ГруппаФормы"), ?(ВозможностьУдалять, ГруппаВыравниваниеЭлементаДлительности, ГруппаДляРазмещенияДлительностиОбщая));
			ГруппаЭлементаДлительности.Вид 					= ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаЭлементаДлительности.Заголовок 			= ?(ЭлементДлительность = "N", "", ГруппаЭлементаДлительности.Имя);
			ГруппаЭлементаДлительности.Отображение 			= ОтображениеОбычнойГруппы.Нет;
			ГруппаЭлементаДлительности.Группировка 			= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			ГруппаЭлементаДлительности.ОтображатьЗаголовок 	= Ложь;
			ГруппаЭлементаДлительности.ЦветФона				= Новый Цвет(242, 242, 242);
			
			КнопкаИмяКоманды = ?(ЭлементДлительность = "N" И ВозможностьУдалять, "ДлительностьПриемаДобавить", 
															?(НовыйЭлемент = Неопределено И НЕ ЭлементДлительность = "N", "УстановитьВремяДлительности", "ИзменитьДлительностьПриема"));
			
			КнопкаЭлементаДлительности = Форма.Элементы.Добавить("КнопкаДлительности_" + ЭлементДлительность, Тип("КнопкаФормы"), ГруппаЭлементаДлительности);
			КнопкаЭлементаДлительности.Отображение       	= ОтображениеКнопки.Текст;
			КнопкаЭлементаДлительности.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
			КнопкаЭлементаДлительности.ИмяКоманды        	= КнопкаИмяКоманды;
			
			ДлительностьКолвоСимволов = СтрДлина(Строка(ЭлементДлительность));
			Если ЭтоВебКлиент Тогда
				ШиринаКнопки = ?(ДлительностьКолвоСимволов <= 1, 2, 3);
			Иначе
				ШиринаКнопки = ?(ДлительностьКолвоСимволов <= 2, 3, 4);
			КонецЕсли;	
			
			КнопкаЭлементаДлительности.Ширина			    = ШиринаКнопки;
			КнопкаЭлементаДлительности.Заголовок		    = "" + ЭлементДлительность + "'";
			КнопкаЭлементаДлительности.ОтображениеПодсказки = ОтображениеПодсказки.Авто;		
					
			Если ВозможностьУдалять И НЕ ЭлементДлительность = "N" Тогда
				
				КнопкаУдаленияДлительности = Форма.Элементы.Добавить("КнопкаУдаленияДлительности_" + ЭлементДлительность, Тип("КнопкаФормы"), ГруппаВыравниваниеЭлементаДлительности);
				КнопкаУдаленияДлительности.Отображение       	= ОтображениеКнопки.Картинка;
				КнопкаУдаленияДлительности.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
				КнопкаУдаленияДлительности.Картинка 			= БиблиотекаКартинок.ОтменаОчиститьДанныеНовая;
				КнопкаУдаленияДлительности.ИмяКоманды        	= "ДлительностьПриемаУдалить";			
				КнопкаУдаленияДлительности.Заголовок		    = "";
				КнопкаУдаленияДлительности.ОтображениеПодсказки = ОтображениеПодсказки.Авто;
				КнопкаУдаленияДлительности.Ширина				= 2;
				КнопкаУдаленияДлительности.Высота				= 0;
				
			КонецЕсли;
			
			// Создание интерфейса добавления длительности
			
			Если ЭлементДлительность = "N" Тогда
				
				ПолеВводаДлительности 							= Форма.Элементы.Добавить("НовыйЭлементДлительностиПриема", Тип("ПолеФормы"), ГруппаЭлементаДлительности);
				ПолеВводаДлительности.Вид 						= ВидПоляФормы.ПолеВвода;
				ПолеВводаДлительности.Заголовок 				= "";
				ПолеВводаДлительности.ПоложениеЗаголовка 		= ПоложениеЗаголовкаЭлементаФормы.Нет;
				ПолеВводаДлительности.ПутьКДанным 				= "НовыйЭлементДлительностиПриема";
				ПолеВводаДлительности.Видимость 				= Ложь;
				ПолеВводаДлительности.АвтоМаксимальнаяШирина	= Ложь;
				ПолеВводаДлительности.Ширина					= 0;
				ПолеВводаДлительности.МаксимальнаяШирина		= 4;
				ПолеВводаДлительности.УстановитьДействие("ПриИзменении", "Подключаемый_НовыйЭлементДлительностиПриемаПриИзменении");
				
				КнопкаЭлементаДлительности = Форма.Элементы.Добавить("СохранитьЭлементДлительностиПриема", Тип("КнопкаФормы"), ?(ВозможностьУдалять, ГруппаВыравниваниеЭлементаДлительности, ГруппаДляРазмещенияДлительностиОбщая)); //);
				КнопкаЭлементаДлительности.Отображение       	= ОтображениеКнопки.Картинка;
				КнопкаЭлементаДлительности.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
