// Процедура, обработчик события "Выбор"
//
Процедура ТаблицаЛечениеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "ТаблицаЛечениеМатериалыПредставление" Тогда
		СтандартнаяОбработка = Ложь;	
		ТекущиеДанные          = Элементы.ТаблицаЛечение.ТекущиеДанные;
		СтруктураПараметры     = Новый Структура();	
		МассивРазрешенныхТипов = Новый Массив;
		МассивРазрешенныхТипов.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал"));
		// Подготовка массив ранее выбранных материалов
		МассивВыбранныхЗначений = Новый Массив;
		Для Каждого СтрокаТЧ ИЗ Объект.Материалы Цикл
			Если СтрокаТЧ.КлючСтроки = ТекущиеДанные.КлючСтроки Тогда
				МассивВыбранныхЗначений.Добавить(Новый Структура("Номенклатура,Количество,Упаковка,Склад, Партия, ВключатьВСтоимость, ВидЦен",СтрокаТЧ.Материал,СтрокаТЧ.КоличествоУпаковок,СтрокаТЧ.Упаковка,СтрокаТЧ.Склад, СтрокаТЧ.Партия, СтрокаТЧ.ВключатьВСтоимость, СтрокаТЧ.ВидЦен));
			КонецЕсли;		
		КонецЦикла;
		
		СтруктураПараметры.Вставить("ОтборМассивРазрешенныхТипов"          , МассивРазрешенныхТипов); 
		СтруктураПараметры.Вставить("Заголовок"                            , "Выберите материалы");	  
		СтруктураПараметры.Вставить("СтруктурнаяЕдиница"                   , Объект.СтруктурнаяЕдиница);   
		СтруктураПараметры.Вставить("Дата"                                 , Объект.Дата);
		СтруктураПараметры.Вставить("БуферВыбранныхЗначенийИспользовать"   , Истина);
		СтруктураПараметры.Вставить("ВыбранныеЗначения"                    , МассивВыбранныхЗначений);
		СтруктураПараметры.Вставить("Склад"                                , Объект.Склад);
		СтруктураПараметры.Вставить("КолонкаСкладВидимость"                , Истина);
		
		ИмяТаблицы   = Элементы.ТаблицаЛечение.Имя;
		ДопПараметры = Новый Структура("ТекущиеДанные, ИмяТаблицы", ТекущиеДанные, ИмяТаблицы);
		Оповещение   = Новый ОписаниеОповещения("ПослеОткрытияФормыПодбораНоменклатуры", ЭтотОбъект, ДопПараметры);
		// Открыть форму подбора материалов
		ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаПодбораНоменклатуры", СтруктураПараметры,,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	КонецЕсли;
	
	Если Поле.Имя = "ТаблицаЛечениеСогласование" Тогда
		// Элемент.ТекущиеДанные.ПризнакСогласования = НЕ Элемент.ТекущиеДанные.ПризнакСогласования;
		
		ТекущиеДанные = Элемент.ТекущиеДанные;

		Если ЗначениеЗаполнено(ТекущиеДанные.ТребуетсяСогласование) Тогда
			
			ПараметрыОповещения = Новый Структура(); 		
			ПараметрыОповещения.Вставить("ЛечениеТекущиеДанные", ТекущиеДанные);
			
			ПараметрыФормы = Новый Структура();
			ПараметрыФормы.Вставить("ПолисМедСтрахования"	 , Объект.ПолисМедСтрахования);	
			ПараметрыФормы.Вставить("Номенклатура"			 , ТекущиеДанные.Номенклатура);
			ПараметрыФормы.Вставить("СтатусСогласования"	 , ТекущиеДанные.СтатусСогласования); 
			ПараметрыФормы.Вставить("Зуб"					 , ТекущиеДанные.Зуб);
			ПараметрыФормы.Вставить("РежимРедактировать"	 , Истина);
			ПараметрыФормы.Вставить("Контрагент"			 , Объект.Контрагент);
			ПараметрыФормы.Вставить("Комментарий"			 , ТекущиеДанные.КомментарийСогласования);
						
			ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьСогласованиеУслуги", ЭтотОбъект, ПараметрыОповещения);
			ОткрытьФорму("РегистрСведений.СогласованияСтраховыхУслуг.Форма.ФормаСогласования", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
		
		КонецЕсли;
				
	КонецЕсли;
	
КонецПроцедуры  

