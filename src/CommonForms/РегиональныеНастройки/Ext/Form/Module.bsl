// Функция - Состояние фонового задания
// 
// Возвращаемое значение:
//   - 
//
Функция СостояниеФоновогоЗадания(ИдентификаторЗадания)
	
	Результат = Новый Структура("Прогресс, Завершено, Ошибка");
	
	Результат.Ошибка = "";
	Если ИдентификаторЗадания = Неопределено Тогда
		Результат.Завершено = Истина;
		Результат.Прогресс  = Неопределено;
		Результат.Ошибка    = НСтр("ru = 'Произошла ошибка'; en = 'An error has occurred'");
	Иначе
		Попытка
			Результат.Завершено = ДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания);
			Результат.Прогресс  = ДлительныеОперации.ПрочитатьПрогресс(ИдентификаторЗадания);
		Исключение
			Результат.Ошибка = ПодробноеПредставлениеОшибки( ИнформацияОбОшибке() );
		КонецПопытки
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
// Функция - Модифицированы региональные параметры
//
// Параметры:
//  СтруктурнаяЕдиница		 - 	 - 
//  Страна					 - 	 - 
//  ФорматТелефонныхНомеров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция МодифицированыРегиональныеПараметры(Страна, ФорматТелефонныхНомеров)
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если Страна <> Константы.СтранаУчета.Получить() ИЛИ ФорматТелефонныхНомеров <> Константы.ФорматТелефонныхНомеров.Получить() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции


#КонецОбласти 
