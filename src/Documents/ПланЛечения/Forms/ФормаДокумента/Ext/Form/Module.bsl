// Процедура, обработчик события "Выбор"
//
Процедура Подключаемый_ПодборУслугиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если РедактированиеРазрешено = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаДерева = Элементы._ПодборНоменклатурУслуги.ТекущиеДанные; 
	Если СтрокаДерева = Неопределено
		ИЛИ СтрокаДерева.ЭтоГруппа Тогда
		
		СтандартнаяОбработка = Истина;
		Возврат;
		
	КонецЕсли;
	
	Если НомерПриемаПодбор = 0 Тогда
		ВыборНомераПриемаОбщаяКоманда(ЭтаФорма.Команды.ВыборНомераПриема1);
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ОтборСегментУслугПоСогласованию) Тогда
		ЭтоНоменклатураПоСогласованию = ПроверитьВхождениеВНоменклатуруСогласования(СтрокаДерева.Номенклатура);
		// Предупредить о необходимости согласования со страховой компанией
		Если ЭтоНоменклатураПоСогласованию = Истина Тогда                              
			ПоказатьПредупреждение(,"Выбранная услуга требует согласования со страховой компанией");
		КонецЕсли;                                      
	КонецЕсли;		
	
	Количество = 1;
	МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
	Если МассивЗубов.Количество() = 0 тогда
		МассивЗубов.Добавить(ОбщиеПараметры.Перечисление_Зубы_ВсяПолость);
	КонецЕсли;     	
	
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаДерева.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор") Тогда
		МассивНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьСоставНабора(СтрокаДерева.Номенклатура);
	Иначе
		МассивНоменклатуры = Новый Массив;
		МассивНоменклатуры.Добавить(Новый Структура("Номенклатура, Количество", СтрокаДерева.Номенклатура, 1));
	КонецЕсли;
	
	ИдентификаторыНовыхСтрок = Новый Массив; 
	ИспользуетсяПолисМедСтрахования = ЗначениеЗаполнено(Объект.ПолисМедСтрахования) И ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса);
	ОписаниеОшибки = "";
	
	Для Каждого СтрокаТЧ из МассивНоменклатуры Цикл			
		Для Каждого ЭлементМЗуб ИЗ МассивЗубов Цикл
			
			СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("Номенклатура"  , СтрокаТЧ.Номенклатура);
			СтруктураОтбора.Вставить("Зуб"           , ЭлементМЗуб);
			СтруктураОтбора.Вставить("НомерПриема"   , Число(НомерПриемаПодбор));
			Строки = Объект.Лечение.НайтиСтроки(СтруктураОтбора);
			
			Если ИспользуетсяПолисМедСтрахования Тогда 
				
				СтруктураПараметровПоПолису = Новый Структура();
				СтруктураПараметровПоПолису.Вставить("ЭлементМЗуб", 		ЭлементМЗуб);
				СтруктураПараметровПоПолису.Вставить("КоличествоНоменклатурыВТЧ", ВернутьКоличествоНоменклатурыВТЧЛечение(СтрокаТЧ.Номенклатура));
				СтруктураПараметровПоПолису.Вставить("КоличествоЗубовСНомненклатуройВТЧ", ПолучитьКоличествоЗубовСНомненклатурой(СтрокаТЧ.Номенклатура));					
				СтруктураПараметровПоПолису.Вставить("КоличествоЗубов", 	СтрокаДерева.КоличествоЗубов);
				СтруктураПараметровПоПолису.Вставить("КоличествоВПриеме", 	СтрокаДерева.КоличествоВПриеме);
				СтруктураПараметровПоПолису.Вставить("Номенклатура", 		СтрокаДерева.Номенклатура);
				СтруктураПараметровПоПолису.Вставить("ПолисНеограничено", 	СтрокаДерева.ПолисНеограничено);
				СтруктураПараметровПоПолису.Вставить("ПолисКоличество", 	СтрокаДерева.ПолисКоличество);					
				СтруктураПараметровПоПолису.Вставить("КоличествоВсего", 	0);
				
				ПроверитьУслугуНаСогласованностьПоПолису(СтруктураПараметровПоПолису, ОписаниеОшибки);
				Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
					ПоказатьПредупреждение(,ОписаниеОшибки);	 
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			Если Строки.Количество() > 0 Тогда
				Строки[0].Количество = Строки[0].Количество + СтрокаТЧ.Количество;
			Иначе 
				ЛечениеТекущиеДанные = Элементы.ТаблицаЛечение.ТекущиеДанные;
				Если ЛечениеТекущиеДанные <> Неопределено И НЕ ЗначениеЗаполнено(ЛечениеТекущиеДанные.Номенклатура) Тогда							
					ЛечениеТекущиеДанные.Номенклатура = СтрокаТЧ.Номенклатура;
					ЛечениеТекущиеДанные.НомерПриема  = НомерПриемаПодбор;
					ЛечениеТекущиеДанные.КлючСтроки   = Новый УникальныйИдентификатор;	
					ИдентификаторыНовыхСтрок.Добавить(ЛечениеТекущиеДанные.ПолучитьИдентификатор());	
				Иначе 				
					НоваяСтрока                           = Объект.Лечение.Добавить();
					НоваяСтрока.КлючСтроки                = Новый УникальныйИдентификатор;
					НоваяСтрока.Номенклатура              = СтрокаТЧ.Номенклатура;
					НоваяСтрока.НомерПриема				  = НомерПриемаПодбор;
					НоваяСтрока.Количество                = СтрокаТЧ.Количество;
					НоваяСтрока.Зуб                       = ЭлементМЗуб;
					НоваяСтрока.Бесплатно = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "Бесплатно");
					Элементы.ТаблицаЛечение.ТекущаяСтрока  = НоваяСтрока.ПолучитьИдентификатор();	
					ИдентификаторыНовыхСтрок.Добавить(НоваяСтрока.ПолучитьИдентификатор());			
				КонецЕсли;
			КонецЕсли;					
		КонецЦикла;	
	КонецЦикла;
	
	ТаблицаУслугиНоменклатураПриИзменении(, ИдентификаторыНовыхСтрок, Истина);	
	ОбновитьSVGПодбор(Истина);
	Модифицированность = Истина;
	// Привести фильтр услуг в исходное состояние
	Если ФильтрУслугИспользован = Истина Тогда
		ФильтрУслуги            = "";
		ЭтаФорма.ТекущийЭлемент = Элементы.ПолеФильтрУслугиНаименование;
		
		#Если не ВебКлиент Тогда
			Системнаяинформация = Новый Системнаяинформация;
			Если Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86 Или Системнаяинформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда 
				WSHShell                = Новый COMОбъект("WScript.Shell");
				WSHShell.SendKeys("+{TAB}");
			КонецЕсли;
		#Конецесли			
		
	КонецЕсли;
	
	ОбновитьЗаголовкиТабЧастейНаСервере();		
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиТаблицыУслуги

