Процедура ОчиститьРСНастройкиСотрудниковОтДублей() 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сотрудники.Сотрудник КАК Сотрудник,
	|	Сотрудники.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Сотрудники.СегментыНоменклатуры КАК СегментыНоменклатуры,
	|	Сотрудники.ВидЦен КАК ВидЦен,
	|	Сотрудники.ДатаПриема КАК ДатаПриема,
	|	Сотрудники.ДатаУвольнения КАК ДатаУвольнения,
	|	Сотрудники.РазрешитьПриемНесколькихПациентов КАК РазрешитьПриемНесколькихПациентов,
	|	Сотрудники.ОсновнойШаблонОбследований КАК ОсновнойШаблонОбследований
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК Сотрудники");	
	
	ТаблицаНастроекСотрудника = Запрос.Выполнить().Выгрузить();
	
	НоваяТаблица = ТаблицаНастроекСотрудника.СкопироватьКолонки();
	Запомним = Неопределено;
	Проверка = Ложь;
	Для Каждого СтрокаТЗ Из ТаблицаНастроекСотрудника Цикл

		Если ЗначениеЗаполнено(СтрокаТЗ.СтруктурнаяЕдиница) Тогда
			Если Проверка Тогда
				НоваяСтрока = НоваяТаблица.Добавить();
				НоваяСтрока.Сотрудник = Запомним.Сотрудник;
				НоваяСтрока.СегментыНоменклатуры = Запомним.СегментыНоменклатуры;
				НоваяСтрока.ВидЦен = Запомним.ВидЦен;
				НоваяСтрока.ДатаПриема = Запомним.ДатаПриема;
				НоваяСтрока.ДатаУвольнения = Запомним.ДатаУвольнения;
				НоваяСтрока.РазрешитьПриемНесколькихПациентов = Запомним.РазрешитьПриемНесколькихПациентов;
				НоваяСтрока.ОсновнойШаблонОбследований = Запомним.ОсновнойШаблонОбследований;
				Проверка = Ложь;
			Иначе
				НоваяСтрока = НоваяТаблица.Добавить();
				НоваяСтрока.Сотрудник = СтрокаТЗ.Сотрудник;
				НоваяСтрока.СегментыНоменклатуры = СтрокаТЗ.СегментыНоменклатуры;
				НоваяСтрока.ВидЦен = СтрокаТЗ.ВидЦен;
				НоваяСтрока.ДатаПриема = СтрокаТЗ.ДатаПриема;
				НоваяСтрока.ДатаУвольнения = СтрокаТЗ.ДатаУвольнения;
				НоваяСтрока.РазрешитьПриемНесколькихПациентов = СтрокаТЗ.РазрешитьПриемНесколькихПациентов;
				НоваяСтрока.ОсновнойШаблонОбследований = СтрокаТЗ.ОсновнойШаблонОбследований;
			КонецЕсли;
			НоваяСтрока.СтруктурнаяЕдиница = СтрокаТЗ.СтруктурнаяЕдиница;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаТЗ.СтруктурнаяЕдиница) Тогда
			Запомним = СтрокаТЗ;
			Проверка = Истина;
		КонецЕсли;

	КонецЦикла; 
		
	Рег = РегистрыСведений.НастройкиСотрудников;
	НаборНастройкиСотрудников = Рег.СоздатьНаборЗаписей();
	НаборНастройкиСотрудников.Загрузить(НоваяТаблица);
	НаборНастройкиСотрудников.Записать();
	
КонецПроцедуры

// Процедура, заполняет сведения для списка контрагенов.
// 
Процедура ПерезаполнитьСведенияДляСпискаКонтрагентов(Параметры = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;	
	
	Попытка
		РегистрыСведений.КонтрагентыСведенияДляСписка.ОбновитьРегистрКонтрагентыСведенияДляСписка();                          	
	Исключение
		ЗаписьЖурналаРегистрации("ОбновлениеИБ", УровеньЖурналаРегистрации.Ошибка,,,"Перезаполнение списка клиентов: " + ОписаниеОшибки());
	КонецПопытки;
	
	Если Параметры <> Неопределено Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;	
	
КонецПроцедуры 

// Процедура, заполняет типы контрагенов.
// 
Процедура ЗаполнитьТипыКонтрагентов() Экспорт
	
	// При переходе на новую систему не всегда существуют папки Пациенты и Поставщики, если их нет, то создаем.
	Справочники.Контрагенты.ЗаполнитьПоУмолчанию();

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	Контрагенты.ТипКонтрагента КАК ТипКонтрагента,
	|	Контрагенты.Родитель КАК Родитель
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ЛОЖЬ
	|	И Контрагенты.ТипКонтрагента = Значение(Перечисление.ТипыКонтрагентов.ПустаяСсылка)");
	                                                                     
	Выборка = Запрос.Выполнить().Выбрать();                          
												
	Пока Выборка.Следующий() Цикл
		
		СсылкаНаЭлемент = Выборка.Ссылка.ПолучитьОбъект();
		
		Если СсылкаНаЭлемент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо
			ИЛИ (Не ЗначениеЗаполнено(СсылкаНаЭлемент.Родитель)
			И ЗначениеЗаполнено(СсылкаНаЭлемент.КлиентыУдалить)
			И Не СсылкаНаЭлемент.КлиентыУдалить) Тогда
			СсылкаНаЭлемент.Родитель = Справочники.Контрагенты.НайтиПоНаименованию("Поставщики", Истина, Справочники.Контрагенты.ПустаяСсылка());	
		Иначе
			СсылкаНаЭлемент.Родитель = Справочники.Контрагенты.НайтиПоНаименованию("Пациенты", Истина, Справочники.Контрагенты.ПустаяСсылка());
		КонецЕсли;
		
		Если Строка(СсылкаНаЭлемент.Родитель) = "Клиенты" Или Строка(СсылкаНаЭлемент.Родитель) = "Пациенты" Тогда
			СсылкаНаЭлемент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты;
		ИначеЕсли Строка(СсылкаНаЭлемент.Родитель) = "Поставщики" Тогда
			СсылкаНаЭлемент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Поставщик;
		ИначеЕсли Строка(СсылкаНаЭлемент.Родитель) = "Страховые Компании" Тогда
			СсылкаНаЭлемент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.СтраховаяКомпания;
		КонецЕсли;
		
		СсылкаНаЭлемент.Записать();
		
	КонецЦикла;
	
КонецПроцедуры 

