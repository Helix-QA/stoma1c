&НаСервере
// Процедура - Обновить динамическое меню отбор сотрудники
//
// Параметры:
//  ОтборСотрудник	 - 	 - 
//
Процедура ОбновитьДинамическоеМенюОтборСотрудники(ОтборСотрудник = Неопределено)
	
	// УстановитьПривилегированныйРежим(Истина);
	
	// Подготовка массива сотрудников                                              
	МассивСтруктурСотрудников 		= Новый Массив;
	ТаблицаСотрудниковИзСегмента 	= Неопределено;
	
	ТаблицаСотрудниковИзСегмента = ПолучитьВсехМенеджеровОтделаПродаж();
	// Если ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.РуководительОтделаПродаж Тогда 
	//	// Получаем всех менеджеров
	//	ТаблицаСотрудниковИзСегмента = ПолучитьМенеджеровОтделаПродаж();
	// Иначе 
	//	СегментСотрудников = Пользователи.ПолучитьЗначениеПоУмолчаниюПользователя(ТекущийПользователь, "ПросмотрЗадачСотрудников", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	//	Если ЗначениеЗаполнено(СегментСотрудников) Тогда
	//		ТаблицаСотрудниковИзСегмента = РегистрыСведений.СоставСегментов.ВернутьСоставСегментаСотрудниковТаблицей(СегментСотрудников);
	//	КонецЕсли;	
	// КонецЕсли;	
	
	Если ТаблицаСотрудниковИзСегмента.Количество() <> 0 Тогда
		Если ЗначениеЗаполнено(ТекущийПользователь) Тогда 
			Если ТаблицаСотрудниковИзСегмента.Найти(ТекущийПользователь, "Сотрудник") = Неопределено Тогда
				СтрокаТаблицы 				= ТаблицаСотрудниковИзСегмента.Добавить();
				СтрокаТаблицы.Сотрудник 	= ТекущийПользователь;
				СтрокаТаблицы.Представление	= ТекущийПользователь.НаименованиеСокращенное;
				// СтрокаТаблицы.Отчество 		= ТекущийПользователь.Отчество;
				// СтрокаТаблицы.Фамилия 		= ТекущийПользователь.Фамилия;
				// СтрокаТаблицы.Наименование 	= ТекущийПользователь.Наименование;
				ТаблицаСотрудниковИзСегмента.Сортировать("Представление");
			КонецЕсли;
		КонецЕсли;
		Элементы.ГруппаОтборСотрудники.Видимость = Истина;
		Для Каждого СтрокаТаблицы ИЗ ТаблицаСотрудниковИзСегмента Цикл
			МассивСтруктурСотрудников.Добавить(Новый Структура("Значение, Представление, Выбор, Код", СтрокаТаблицы.Сотрудник, ?(ЗначениеЗаполнено(СтрокаТаблицы.Сотрудник), ?(ЗначениеЗаполнено(СокрЛП(СтрокаТаблицы.Представление)), СокрЛП(СтрокаТаблицы.Представление), СокрЛП(Строка(СтрокаТаблицы.Сотрудник))), Нстр("ru = 'Без сотрудника'; en = 'No employee'")), Ложь, XMLСтрока(СтрокаТаблицы.Сотрудник)));
		КонецЦикла;
		Элементы.ГруппаКнопкиПоказатьСведенияДляВсех.Видимость = Истина;
		Элементы.ГруппаКнопкиПоказатьСведенияМои.Доступность = Истина;				
		УстановитьТипАдресатаСведенийНаСервере(ОтборАдресатСведенийТип, , Ложь);		
		МассивОтбораДляПоляДопВвода = ТаблицаСотрудниковИзСегмента.ВыгрузитьКолонку("Сотрудник");		
	ИначеЕсли ЗначениеЗаполнено(ТекущийПользователь) Тогда 
		МассивСтруктурСотрудников.Добавить(Новый Структура("Значение, Представление, Выбор, Код", ТекущийПользователь, ?(ЗначениеЗаполнено(ТекущийПользователь), ?(ЗначениеЗаполнено(СокрЛП(ТекущийПользователь.НаименованиеСокращенное)), СокрЛП(ТекущийПользователь.НаименованиеСокращенное), СокрЛП(Строка(ТекущийПользователь))), Нстр("ru = 'Без сотрудника'; en = 'No employee'")), Ложь, XMLСтрока(ТекущийПользователь)));		
		МассивОтбораДляПоляДопВвода = Новый Массив;
		МассивОтбораДляПоляДопВвода.Добавить(ТекущийПользователь);
		УстановитьТипАдресатаСведенийНаСервере("Мои", , Ложь);
		Элементы.ГруппаОтборСотрудники.Видимость = Ложь;
		Элементы.ГруппаКнопкиПоказатьСведенияДляВсех.Видимость = Ложь;
		Элементы.ПоказатьСведенияМои.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
		// Элементы.ДекорацияУказательВыбранныеМоиСведения.Видимость = Истина;
		Элементы.ГруппаКнопкиПоказатьСведенияМои.ЦветФона = Новый Цвет();
		Элементы.ГруппаКнопкиПоказатьСведенияМои.Доступность = Ложь;		
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("Значение"				, Нстр("ru = 'Сотрудник'; en = 'Employee'"));
	СтруктураОтбора.Вставить("Представление"		, "ПереключательСотрудник");
	СтруктураОтбора.Вставить("ИмяПодчиненногоМеню"	, "ПодчиненноеМенюОтборСотрудники");
	СтруктураОтбора.Вставить("МассивЗначений"		, МассивСтруктурСотрудников);
	
	Если МассивСтруктурСотрудников.Количество() > 10 Тогда
		СтруктураОтбора.Вставить("МассивЗначений"	, Новый Массив);		
		СтруктураОтбора.Вставить("ПолеДопВвода"		, Истина);
		СтруктураОтбора.Вставить("ПараметрыВыбора"	, Новый Структура("Ссылка", Новый ФиксированныйМассив(МассивОтбораДляПоляДопВвода)));
	КонецЕсли;
	
	МассивДанных = Новый Массив;
	МассивДанных.Добавить(СтруктураОтбора);
	
	УправлениеИнтерфейсамиСервер.СоздатьДинамическоеМенюФормыРасписанияЗанятий(
	"МенюОтборСотрудники", 
	ЭтаФорма, 
	Элементы.ГруппаОтборСотрудники, 
	МассивДанных,
	"ОбработчикНажатияЭлементаДинамическогоМеню",,,
	Истина,
	Тип("СправочникСсылка.Сотрудники"),,
	15,,,
	"Отбор");

КонецПроцедуры

&НаСервере
// При изменении состава отборов
//
Процедура ПриИзмененииОтборовСервер(Знач ИмяКоманды)
	
	Если СтрНайти(ИмяКоманды, "КомандаОтбор") = 0 
		И СтрНайти(ИмяКоманды, "ПолеОтбор") = 0 Тогда
		
		УстановитьФокусЭлементаСервер();
	КонецЕсли;
	
	ИмяМеню = Неопределено;
	
	ЭлементФормы        = УправлениеИнтерфейсамиСервер.ЭлементФормыПоИмениЭлемента(ЭтаФорма, ИмяКоманды);
	ИмяЭлемента         = ЭлементФормы.Имя;
	ОбновитьПланировщик = УправлениеИнтерфейсамиСервер.ОбработчикЭлементаДинамическогоМенюПриНажатии(ЭтаФорма, ИмяЭлемента);
	 
	// Селектирование страниц филтров в зависимости от переключателей
	Если УправлениеИнтерфейсамиСервер.ЭтоЭлементБыстрогоВыбора(ИмяЭлемента) Тогда
		
		ИмяМеню = УправлениеИнтерфейсамиСервер.ИмяДинамическогоМенюФормыИзЭлемента(ИмяЭлемента);
		
		// Если сменился период отображения, необходимо обновить меню отборов 
		Если СтрНайти(ИмяЭлемента,"КнопкаПрименить") > 0 
			ИЛИ СтрНайти(ИмяЭлемента,"УдалитьЗначение") > 0 Тогда
			
			Если СтрНайти(ИмяМеню, "МенюОтборСотрудники") > 0 Тогда
				
				// ОбновитьДинамическиеМенюОтборов("Отборы");
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьТипАдресатаСведенийНаСервере(ИмяКоманды);

	// Обновить планировщик
	Если ОбновитьПланировщик Тогда 
		ОбновитьОбщиеСведения();
		ОбновитьСведенияПоСделкам();		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик нажатия элемента динамического меню
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОбработчикНажатияЭлементаДинамическогоМеню(Команда) Экспорт		
			
	// Если это элнмент открытия Списка
	Если СтрНайти(Команда.Имя, "ОткрытьСписок") > 0 Тогда
		
		// Открываем список значений
		ОбработчикНажатияСпискаДинамическогоМеню(Команда.Имя);			
		Возврат;
		
	КонецЕсли;
	                             
	ПриИзмененииОтборовСервер(Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик нажатия списка динамического меню
//
// Параметры:
//  Форма					 - 	 - 
//  СписокЗначений			 - 	 - 
//  ИмяКнопкиПредставления	 - 	 - 
//
Процедура ОбработчикНажатияСпискаДинамическогоМеню(ИмяКоманды)
	
	// Получаем привязанные данные и доп значения
	СтруктураДанных = ОбработчикНажатияСпискаДинамическогоМенюСервер(ИмяКоманды);  
	
	Если СтруктураДанных = Неопределено Тогда
		ОбновитьОбщиеСведения();
		Возврат;
	КонецЕсли;	
	
	// Выбор значения из выпадающего меню
	Оповещение = Новый ОписаниеОповещения("ОбработчикОткрытияСпискаДинамическогоМенюЗавершение", ЭтотОбъект, СтруктураДанных);
	ПоказатьВыборИзМеню(Оповещение, СтруктураДанных.ПривязанныеДанные.СписокЗначений, ЭтаФорма.Элементы[СтруктураДанных.ИмяКнопкиПредставления]);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик открытия списка динамического меню завершение 
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ОбработчикОткрытияСпискаДинамическогоМенюЗавершение(Результат, ДопПараметры) Экспорт
	
 	ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.План;

	// Обрабатываем результат выбора
	Если Результат <> Неопределено  Тогда
		
		ДопПараметры.Вставить("РезультатЗначение", Результат.Значение);
		ДопПараметры.Вставить("РезультатПредставление", Результат.Представление);
		
		ОбработчикНажатияСпискаДинамическогоМенюСерверЗавершение(ДопПараметры)	 				
	КонецЕсли;	
	
КонецПроцедуры

