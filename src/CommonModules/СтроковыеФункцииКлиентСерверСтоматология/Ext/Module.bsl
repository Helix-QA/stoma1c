	//							СтруктураНадписи.ВалютаДокумента = СтруктураНадписи.ВалютаРасчетов, СокрЛП(Строка(СтруктураНадписи.Курс)),
	//							СокрЛП(Строка(СтруктураНадписи.КурсНациональнаяВалюта))));	
	//	Иначе
	//		ТекстНадписи = НСтр("ru = 'Валюта: <нет>'");
