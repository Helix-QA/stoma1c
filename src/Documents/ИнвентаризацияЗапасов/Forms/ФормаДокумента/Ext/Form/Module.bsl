	КонецЕсли; 
	
	КомандаЗаполнитьТолькоУчетныеДанныеЗавершение();

КонецПроцедуры

&НаКлиенте
// Процедура - Команда заполнить только учетные данные завершение
//
Процедура КомандаЗаполнитьТолькоУчетныеДанныеЗавершение()
	
