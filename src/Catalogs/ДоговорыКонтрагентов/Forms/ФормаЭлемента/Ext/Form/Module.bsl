&НаКлиенте
// Процедура, обработчик события дерева формы "ДеревоУслугВыбор".
//
Процедура ДеревоУслугВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		
		Если Элемент.ТекущиеДанные.Номенклатура = Неопределено
			ИЛИ ТипЗнч(Элемент.ТекущиеДанные.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда 
			
			Если Поле.Имя = "ДеревоУслугНоменклатура" Тогда
				ПоказатьЗначение(,Элемент.ТекущиеДанные.Номенклатура);
			КонецЕсли;
			СтандартнаяОбработка = Истина;
			
		Иначе
			
			ПараметрыЗубов = Новый Структура(); 
			ПараметрыЗубов.Вставить("НаименованиеОграничения", Элемент.ТекущиеДанные.НаименованиеОграничения);
			ПараметрыЗубов.Вставить("КлючСтроки", 		Элемент.ТекущиеДанные.КлючСтрокиОграничениеЗубов);
			ПараметрыЗубов.Вставить("КоличествоЗубов", 	Элемент.ТекущиеДанные.КоличествоЗубов);
			ПараметрыЗубов.Вставить("КоличествоВПриеме",Элемент.ТекущиеДанные.КоличествоВПриеме);
			ПараметрыЗубов.Вставить("Согласование",		Элемент.ТекущиеДанные.Согласование);
			
			Оповещение = Новый ОписаниеОповещения("ДобавитьОграничениеЗубовНаСервереЗавершение", ЭтотОбъект);
			ОткрытьФорму("Справочник.ДоговорыКонтрагентов.Форма.ФормаОграниченияЗубов", ПараметрыЗубов,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события дерева формы "ДеревоУслугПередНачаломДобавления".
