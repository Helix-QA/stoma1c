
#Область СлужебныеПроцедурыИФункции

//  Процедура - При создании при чтении на сервере
// 
//  Параметры:
//   Форма			 - УправляемаяФорма	 - 
//   ВладелецКИ		 - ЛюбаяСсылка	 - владелец контактной информации
//   ШиринаПоляВида	 - число	 - 
// 
Процедура ОтображениеДополнительнойИнформации(Форма, Знач ВладелецСсылка = Неопределено, Знач МассивРодителей = Неопределено) Экспорт
	
	Если МассивРодителей = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ВладелецСсылка = Неопределено Тогда
		ВладелецСсылка = Форма.Объект.Ссылка;
	ИначеЕсли ТипЗнч(ВладелецСсылка) <> Тип("ДанныеФормыСтруктура")
		И ТипЗнч(ВладелецСсылка) <> Тип("ФормаКлиентскогоПриложения")
		И Не ЗначениеЗаполнено(ВладелецСсылка) Тогда
		
		Возврат;
	КонецЕсли;
	
	ЕстьРеквизитОплаченоПоРегистру = Ложь;
	
	//  Создание таблиц-реквизитов формы, если отсутствуют
	ДобавитьРеквизитыФормыДополнительнойИнформации(Форма, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру);
	
	//  Чтение имеющейся информации объекта в созданную таблицу для отображения
	ЗаполнитьТаблицыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей);
	
	//  Пересоздание элементов формы по информации из таблицы для отображения
	ОбновитьЭлементыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру);
	
КонецПроцедуры

//  Процедура - Добавить реквизиты формы дополнительной информации
// 
//  Параметры:
//   Форма	 - 	 - 
// 
Процедура ДобавитьРеквизитыФормыДополнительнойИнформации(Форма, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру)
	
	//  Вычисляем существующие реквизиты
	СписокРеквизитовФормы = Форма.ПолучитьРеквизиты();
	
	СоздатьТаблицуУдостоверенияЛичностиСуществующие = Истина;
	СоздатьТаблицуПолисыСуществующие 				= Истина;
	СоздатьТаблицуСкидки                            = Истина;
	СоздатьТаблицуЛицевыхБонусныхСчетов             = Истина;
	СоздатьТаблицуРодственникиСуществующие 			= Истина;
	СоздатьТаблицуПользователиИБСуществующие 		= Истина;
	СоздатьТаблицуКабинетыСуществующие              = Истина;
	СоздатьТаблицуИнформацияПоОплате 				= Истина;
	СоздатьТаблицуДолгиСуществующие					= Истина;
	СоздатьТаблицуКартыСуществующие 				= Истина;
    СоздатьТаблицуБудущиеСобытия 					= Истина;
	СоздатьТаблицуПромокоды							= Истина;
	
	Для Каждого Реквизит Из СписокРеквизитовФормы Цикл
		Если Реквизит.Имя 		= "СуммаОплаченоПоРегистру" 	Тогда 			
			ЕстьРеквизитОплаченоПоРегистру 					= Истина;
		КонецЕсли;		
		Если Реквизит.Имя 		= "УдостоверенияЛичностиСуществующие"	Тогда
			СоздатьТаблицуУдостоверенияЛичностиСуществующие = Ложь;
		ИначеЕсли Реквизит.Имя 	= "ПолисыСуществующие"					Тогда
			СоздатьТаблицуПолисыСуществующие 				= Ложь;
		ИначеЕсли Реквизит.Имя 	= "СкидкиСуществующие"					Тогда
			СоздатьТаблицуСкидки 		            		= Ложь;	
		ИначеЕсли Реквизит.Имя  = "ТаблицаЛицевыхБонусныхСчетов"		Тогда
			СоздатьТаблицуЛицевыхБонусныхСчетов 			= Ложь;
		ИначеЕсли Реквизит.Имя 	= "РодственникиСуществующие"			Тогда	
			СоздатьТаблицуРодственникиСуществующие 			= Ложь;
		ИначеЕсли Реквизит.Имя 	= "ПользователиИБСуществующие"			Тогда	
			СоздатьТаблицуПользователиИБСуществующие 		= Ложь;
		ИначеЕсли Реквизит.Имя 	= "КабинетыСуществующие"				Тогда	
			СоздатьТаблицуКабинетыСуществующие 				= Ложь;
		ИначеЕсли Реквизит.Имя 	= "Информация_По_Оплате"				Тогда
			СоздатьТаблицуИнформацияПоОплате 				= Ложь;
		ИначеЕсли Реквизит.Имя 	= "ДолгиСуществующие"					Тогда
			СоздатьТаблицуДолгиСуществующие 				= Ложь;	
		ИначеЕсли Реквизит.Имя 	= "КартыСуществующие"					Тогда
			СоздатьТаблицуКартыСуществующие 				= Ложь;	
		ИначеЕсли Реквизит.Имя 	= "БудущиеСобытия"						Тогда
			СоздатьТаблицуБудущиеСобытия 					= Ложь;
		ИначеЕсли Реквизит.Имя  = "ПромокодыСуществующие" 				Тогда
			СоздатьТаблицуПромокоды							= Ложь;
		КонецЕсли;    		
		
	КонецЦикла;
	
	//  Создаем реквизиты формы
	МассивДобавляемыхРеквизитов = Новый Массив;
	ОписаниеСтрока 				= Новый ОписаниеТипов("Строка");
	ОписаниеБулево 				= Новый ОписаниеТипов("Булево");
	
	Для Каждого ЭлементРодитель Из МассивРодителей Цикл 
		
		Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" И СоздатьТаблицуУдостоверенияЛичностиСуществующие Тогда 
			
			ИмяТаблицы = "УдостоверенияЛичностиСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы		, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Период"		, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВидДокумента"	, Новый ОписаниеТипов("СправочникСсылка.ВидыДокументовФизическихЛиц"), ИмяТаблицы));
			СписокТипов = Новый Массив;
			СписокТипов.Добавить("СправочникСсылка.Сотрудники");
			СписокТипов.Добавить("СправочникСсылка.Контрагенты");
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Физлицо"		, ОписаниеСоставногоТипа, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Серия"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(Метаданные.РегистрыСведений.ДокументыФизическихЛиц.Ресурсы.Серия.Тип.КвалификаторыСтроки.Длина)), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Номер"		, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(Метаданные.РегистрыСведений.ДокументыФизическихЛиц.Ресурсы.Номер.Тип.КвалификаторыСтроки.Длина)), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаВыдачи"	, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КемВыдан"		, Новый ОписаниеТипов("Строка"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаОкончания", Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаСкидкиСуществующие" И СоздатьТаблицуСкидки Тогда	
			
			ИмяТаблицы = "СкидкиСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы				    , Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Скидка"		    	    , Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЗначениеСкидкиНаценки"	, Новый ОписаниеТипов("Число"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СпособПредоставления"	    , Новый ОписаниеТипов("ПеречислениеСсылка.СпособПредоставленияСкидки"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипСкидки"    			, ОписаниеСтрока, ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаПолисыСуществующие" И СоздатьТаблицуПолисыСуществующие Тогда	
			
			ИмяТаблицы = "ПолисыСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы				    , Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Полис"		    		, Новый ОписаниеТипов("СправочникСсылка.ПолисыМедицинскогоСтрахования"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипПолиса"		    	, Новый ОписаниеТипов("ПеречислениеСсылка.ТипыПолиса"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СтраховаяКомпания"		, Новый ОписаниеТипов("СправочникСсылка.Контрагенты"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СерияПолиса"	   			, ОписаниеСтрока, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("НомерПолиса"    			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаНачала"    			, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаОкончания"    		, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЛимитПолиса"    			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаЛицевыеБонусныеСчетаСуществующие" И СоздатьТаблицуЛицевыхБонусныхСчетов Тогда
			
			ИмяТаблицы = "ТаблицаЛицевыхБонусныхСчетов";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			СписокТипов = Новый Массив;
			СписокТипов.Добавить(Тип("СправочникСсылка.ВидыЛицевыхСчетов"));
			СписокТипов.Добавить(Тип("СправочникСсылка.БонусныеСчета"));
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЛицевойБонусныйСчет"		, ОписаниеСоставногоТипа, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Представление"			, ОписаниеСтрока, ИмяТаблицы));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СуммаОстаток"				, Новый ОписаниеТипов("Число"), ИмяТаблицы)); 
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СтепеньРодства"			, Новый ОписаниеТипов("СправочникСсылка.СтепеньРодства"), ИмяТаблицы));

		ИначеЕсли ЭлементРодитель = "ГруппаРодственникиСуществующие" И СоздатьТаблицуРодственникиСуществующие Тогда	
			
			ИмяТаблицы = "РодственникиСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Контрагент"				, Новый ОписаниеТипов("СправочникСсылка.Контрагенты"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Родственник"				, Новый ОписаниеТипов("СправочникСсылка.Контрагенты"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СтепеньРодства"			, Новый ОписаниеТипов("СправочникСсылка.СтепеньРодства"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОбщийЛицевойСчет"			, ОписаниеБулево, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОбщийНакопительныйСчет"	, ОписаниеБулево, ИмяТаблицы));
			// МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОбщийБонусныйСчет"	    , ОписаниеБулево, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЗаконныйПредставитель"	, ОписаниеБулево, ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаПользовательИБСуществующий" И СоздатьТаблицуПользователиИБСуществующие Тогда	
			
			ИмяТаблицы = "ПользователиИБСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Пользователь"				, Новый ОписаниеТипов("СправочникСсылка.Пользователи"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаКабинетыСуществующие" И СоздатьТаблицуКабинетыСуществующие Тогда 
			
			ИмяТаблицы = "КабинетыСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Помещение" , Новый ОписаниеТипов("СправочникСсылка.Помещения"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Сотрудник" , Новый ОписаниеТипов("СправочникСсылка.Сотрудники"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Основное" , ОписаниеБулево, ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробно" И СоздатьТаблицуИнформацияПоОплате Тогда
			
			ИмяТаблицы = "Информация_По_Оплате";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаПлатежа"				, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			СписокТипов = Новый Массив;
			// СписокТипов.Добавить("СправочникСсылка.ЛицевыеСчета");
			СписокТипов.Добавить("СправочникСсылка.Номенклатура");
			СписокТипов.Добавить("СправочникСсылка.БонусныеСчета");
			СписокТипов.Добавить("ДокументСсылка.ПоступлениеДенежныхСредств");
			СписокТипов.Добавить("ДокументСсылка.СписаниеДенежныхСредств");
			СписокТипов.Добавить("ДокументСсылка.ПланЛечения");
			СписокТипов.Добавить("ДокументСсылка.НарядЗаказ");
			
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);		
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДокументОплаты"			, ОписаниеСоставногоТипа, ИмяТаблицы));
			
			МассивТипов = Новый Массив;
			МассивТипов.Добавить("ПеречислениеСсылка.ТипыДенежныхСредств");
			МассивТипов.Добавить("Строка");
			ОписаниеТипа = Новый ОписаниеТипов(МассивТипов,,,, Новый КвалификаторыСтроки(30));			
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипДенежныхСредств"		, ОписаниеТипа, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВладелецАванса"			, Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("СуммаОплачено"			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ИдСтроки"					, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ПолеСортировки"			, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("БонусныйСчет"				, Новый ОписаниеТипов("СправочникСсылка.БонусныеСчета"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ОплатаПоСсылке"			, Новый ОписаниеТипов("ПеречислениеСсылка.ПлатежныеШлюзы"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаДолгиКонтрагентаСуществующие" И СоздатьТаблицуДолгиСуществующие Тогда	
			
			ИмяТаблицы = "ДолгиСуществующие";
			СписокТипов = Новый Массив;
			СписокТипов.Добавить("ДокументСсылка.Реализация");
			СписокТипов.Добавить("ДокументСсылка.ВводНачальныхОстатков");
			СписокТипов.Добавить("ДокументСсылка.Прием");
			СписокТипов.Добавить("ДокументСсылка.Поступление");
			ОписаниеСоставногоТипа = Новый ОписаниеТипов(СписокТипов);	
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Основание"	        	, ОписаниеСоставногоТипа, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Сумма"					, Новый ОписаниеТипов("Число"), ИмяТаблицы));
			// МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипРасчета"               , Новый ОписаниеТипов("ПеречислениеСсылка.ТипыРасчетов"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Дата"              		, Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Контрагент"               , Новый ОписаниеТипов("СправочникСсылка.Контрагенты"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаКартыСуществующие" И СоздатьТаблицуКартыСуществующие Тогда	
			
			ИмяТаблицы = "КартыСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы				, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КартаСсылка"			, Новый ОписаниеТипов("СправочникСсылка.Карты"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ТипКода"				, Новый ОписаниеТипов("ПеречислениеСсылка.ВидыКарт"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВидКарты"				, Новый ОписаниеТипов("СправочникСсылка.ВидыКарт"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("КодКарты"				, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(200)), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ВнутреннийКодКарты"	, Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)), ИмяТаблицы));	
			
		ИначеЕсли ЭлементРодитель = "ГруппаБудущиеСобытияКлиента" И СоздатьТаблицуБудущиеСобытия Тогда	
			
			ИмяТаблицы = "БудущиеСобытия";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Событие"	        		, Новый ОписаниеТипов("ДокументСсылка.Событие"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ДатаСобытия"              , Новый ОписаниеТипов("Дата"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Сотрудник"				, Новый ОписаниеТипов("СправочникСсылка.Сотрудники"), ИмяТаблицы));
			
		ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" И СоздатьТаблицуПромокоды Тогда	
			
			ИмяТаблицы = "ПромокодыСуществующие";
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы					, Новый ОписаниеТипов("ТаблицаЗначений"), , , Истина));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ПромокодСсылка"			, Новый ОписаниеТипов("СправочникСсылка.Промокоды"), ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Промокод"					, ОписаниеСтрока, ИмяТаблицы));
			МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Активен"					, ОписаниеБулево, ИмяТаблицы));
					
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивДобавляемыхРеквизитов.Количество() > 0 Тогда
		Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

//  Процедура - Заполнить таблицы дополнительной информации
// 
//  Параметры:
//   Форма			 - 	 - 
//   ВладелецСсылка	 - 	 - 
//   МассивРодителей	 - 	 - 
// 
Процедура ЗаполнитьТаблицыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей)
	
	Для Каждого ЭлементРодитель Из МассивРодителей Цикл		
		
		Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_УДОСТОВЕРЕНИЯМИ_ЛИЧНОСТИ
			
			Форма.УдостоверенияЛичностиСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ДокументыФизическихЛиц.ВидДокумента КАК ВидДокумента,
			|	ДокументыФизическихЛиц.Физлицо КАК Физлицо,
			|	ДокументыФизическихЛиц.Серия КАК Серия,
			|	ДокументыФизическихЛиц.Номер КАК Номер,
			|	ДокументыФизическихЛиц.ДатаВыдачи КАК ДатаВыдачи,
			|	ДокументыФизическихЛиц.КемВыдан КАК КемВыдан,
			|	ДокументыФизическихЛиц.СрокДействия КАК СрокДействия
			|ИЗ
			|	РегистрСведений.ДокументыФизическихЛиц КАК ДокументыФизическихЛиц
			|ГДЕ
			|	ДокументыФизическихЛиц.Физлицо = &Контрагент";
			
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.УдостоверенияЛичностиСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаПолисыСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ПОЛИСАМИ_МЕДИЦИНСКОГО_СТРАХОВАНИЯ
			
			Форма.ПолисыСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ПолисыМедицинскогоСтрахования.Наименование КАК Представление,
			|	ПолисыМедицинскогоСтрахования.ТипПолиса КАК ТипПолиса,
			|	ПолисыМедицинскогоСтрахования.СтраховаяКомпания КАК СтраховаяКомпания,
			|	ПолисыМедицинскогоСтрахования.СерияПолиса КАК СерияПолиса,
			|	ПолисыМедицинскогоСтрахования.НомерПолиса КАК НомерПолиса,
			|	ПолисыМедицинскогоСтрахования.ЛимитПолиса КАК ЛимитПолиса,
			|	ПолисыМедицинскогоСтрахования.ДанаНачала КАК ДатаНачала,
			|	ПолисыМедицинскогоСтрахования.ДатаОкончания КАК ДатаОкончания,
			|	ПолисыМедицинскогоСтрахования.Ссылка КАК Полис
			|ИЗ
			|	Справочник.ПолисыМедицинскогоСтрахования КАК ПолисыМедицинскогоСтрахования
			|ГДЕ
			|	ПолисыМедицинскогоСтрахования.Контрагент = &Контрагент
			|	И НЕ ПолисыМедицинскогоСтрахования.ПометкаУдаления
			|	И ПолисыМедицинскогоСтрахования.ДатаОкончания >= &Период
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаНачала");
			
			Запрос.УстановитьПараметр("Период"    , НачалоДня(ТекущаяДатаСеанса()));
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.ПолисыСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаСкидкиСуществующие" Тогда	
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_СКИДКАМИ
			
			Форма.СкидкиСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			ТаблицаСкидкиДоступныеДляКлиента = Справочники.СкидкиНаценки.ПолучитьСкидкиДоступныеДляКлиента(ВладелецСсылка);
			
			Для Каждого СтрокаТЧ Из ТаблицаСкидкиДоступныеДляКлиента Цикл
				НоваяСтрока = Форма.СкидкиСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаЛицевыеБонусныеСчетаСуществующие" Тогда
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ЛИЦЕВЫМИ_БОНУСНЫМИ_СЧЕТАМИ_И_АВАНСАМИ
			
			УстановитьПривилегированныйРежим(Истина);
			
			Форма.ТаблицаЛицевыхБонусныхСчетов.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			// Отбор родственников с общим лицевым счетом.
			ТаблицаРодственников = РегистрыСведений.РодственныеСвязи.РодственникиКлиента(ВладелецСсылка,, Истина);			
			МассивКонтрагентов = ТаблицаРодственников.ВыгрузитьКолонку("Родственник");
			МассивКонтрагентов.Добавить(ВладелецСсылка);
			
			ТаблицаРодственников = РегистрыСведений.РодственныеСвязи.РодственникиКлиента(ВладелецСсылка,,,, Истина);  		
			МассивКонтрагентовБС = Новый Массив;			
			Для Каждого СтрокаТЗ Из ТаблицаРодственников Цикл				
				МассивКонтрагентовБС.Добавить(СтрокаТЗ.Родственник);				
			КонецЦикла;			
			МассивКонтрагентовБС.Добавить(ВладелецСсылка);

			ПериодОтбора = ТекущаяДатаСеанса() + 10;
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ДенежныеСредстваНаЛицевыхСчетахОстаткиИОбороты.СуммаКонечныйОстаток КАК СуммаОстаток,
			|	ДенежныеСредстваНаЛицевыхСчетахОстаткиИОбороты.СуммаРасход КАК СуммаРасход,
			|	ДенежныеСредстваНаЛицевыхСчетахОстаткиИОбороты.ВидСчета КАК ВидСчета,
			|	ДенежныеСредстваНаЛицевыхСчетахОстаткиИОбороты.Контрагент КАК Контрагент
			|ИЗ
			|	РегистрНакопления.ДенежныеСредстваНаЛицевыхСчетах.ОстаткиИОбороты(, &Период, , , Контрагент В (&МассивКонтрагентов)) КАК ДенежныеСредстваНаЛицевыхСчетахОстаткиИОбороты
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВложенныйЗапрос.БонусныйСчет КАК БонусныйСчет,
			|	СУММА(ВложенныйЗапрос.СуммаОстаток) КАК СуммаОстаток,
			|	СУММА(ВложенныйЗапрос.СуммаРасход) КАК СуммаРасход,
			|	ВложенныйЗапрос.ВладелецБонусногоСчета КАК Контрагент
			|ИЗ
			|	(ВЫБРАТЬ
			|		БонусныеСчетаОбороты.БонусныйСчет КАК БонусныйСчет,
			|		БонусныеСчетаОбороты.СуммаОборот КАК СуммаОстаток,
			|		БонусныеСчетаОбороты.СуммаРасход КАК СуммаРасход,
			|		БонусныеСчетаОбороты.БонусныйСчет.ВладелецБонусногоСчета КАК ВладелецБонусногоСчета
			|	ИЗ
			|		РегистрНакопления.БонусныеСчета.Обороты(
			|				,
			|				&Период,
			|				,
			|				БонусныйСчет.ВладелецБонусногоСчета В (&МассивКонтрагентовБС)
			|					И ВЫБОР
			|						КОГДА БонусныйСчет.СрокДействияНачало <> ДАТАВРЕМЯ(1, 1, 1)
			|								И БонусныйСчет.СрокДействияКонец <> ДАТАВРЕМЯ(1, 1, 1)
			|							ТОГДА БонусныйСчет.СрокДействияНачало <= &Период
			|									И БонусныйСчет.СрокДействияКонец >= &Период
			|						ИНАЧЕ ИСТИНА
			|					КОНЕЦ
			|					И НЕ БонусныйСчет.ПометкаУдаления
			|					И НЕ БонусныйСчет.Закрыт) КАК БонусныеСчетаОбороты
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		БонусныеСчета.Ссылка,
			|		0,
			|		0,
			|		БонусныеСчета.ВладелецБонусногоСчета
			|	ИЗ
			|		Справочник.БонусныеСчета КАК БонусныеСчета
			|	ГДЕ
			|		БонусныеСчета.ВладелецБонусногоСчета В(&МассивКонтрагентовБС)
			|		И ВЫБОР
			|				КОГДА БонусныеСчета.СрокДействияНачало <> ДАТАВРЕМЯ(1, 1, 1)
			|						И БонусныеСчета.СрокДействияКонец <> ДАТАВРЕМЯ(1, 1, 1)
			|					ТОГДА БонусныеСчета.СрокДействияНачало <= &Период
			|							И БонусныеСчета.СрокДействияКонец >= &Период
			|				ИНАЧЕ ИСТИНА
			|			КОНЕЦ
			|		И НЕ БонусныеСчета.ПометкаУдаления
			|		И НЕ БонусныеСчета.Закрыт) КАК ВложенныйЗапрос
			|
			|СГРУППИРОВАТЬ ПО
			|	ВложенныйЗапрос.БонусныйСчет,
			|	ВложенныйЗапрос.ВладелецБонусногоСчета");
			
			Запрос.УстановитьПараметр("Период"              , ПериодОтбора);
			Запрос.УстановитьПараметр("МассивКонтрагентов"  , МассивКонтрагентов);
			Запрос.УстановитьПараметр("Контрагент"		  	, ВладелецСсылка);
            Запрос.УстановитьПараметр("МассивКонтрагентовБС", МассивКонтрагентовБС);

			ОбщийРезультатВыполненияПакета = Запрос.ВыполнитьПакет();
			
			СимвольныйКод = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
			ФормаКлиента  = Форма.ИмяФормы = "Справочник.Контрагенты.Форма.ФормаЭлементаКлиенты";

			//  Лицевые счета
			ТаблицаЛицевыеСчета	  = ОбщийРезультатВыполненияПакета[0].Выгрузить();
			ЛицевыеСчетаВладельца = ТаблицаЛицевыеСчета.НайтиСтроки(Новый Структура("Контрагент", ВладелецСсылка));
			
			Для Каждого СтрокаТЗ Из ЛицевыеСчетаВладельца Цикл
				
				НоваяСтрока 					= Форма.ТаблицаЛицевыхБонусныхСчетов.Добавить();
				НоваяСтрока.ЛицевойБонусныйСчет = СтрокаТЗ.ВидСчета;
				НоваяСтрока.Представление 		= СтрокаТЗ.ВидСчета.Наименование + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));
				НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;
				
			КонецЦикла;	
			// Лицевые счета родственников
			Для Каждого СтрокаТЗ Из ТаблицаЛицевыеСчета Цикл
				
				Если ЛицевыеСчетаВладельца.Найти(СтрокаТЗ) <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				НоваяСтрока 					= Форма.ТаблицаЛицевыхБонусныхСчетов.Добавить();
				НоваяСтрока.ЛицевойБонусныйСчет = СтрокаТЗ.ВидСчета;
				НоваяСтрока.Представление 		= ?(ФормаКлиента,
													СтрокаТЗ.ВидСчета.Наименование + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СимвольныйКод), 
													СтрокаТЗ.ВидСчета.Наименование);				
				НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;				
				МассивСтрокРодственников = ТаблицаРодственников.НайтиСтроки(Новый Структура("Родственник", СтрокаТЗ.Контрагент));				
				Если МассивСтрокРодственников.Количество() > 0 Тогда
					НоваяСтрока.СтепеньРодства  = МассивСтрокРодственников[0].СтепеньРодства;
				КонецЕсли;				
			КонецЦикла;   

			// Бонусные счета
			ТаблицаБонусныеСчета = ОбщийРезультатВыполненияПакета[1].Выгрузить();  
			БонусныеСчетаВладельца = ТаблицаБонусныеСчета.НайтиСтроки(Новый Структура("Контрагент", ВладелецСсылка));
			Для Каждого СтрокаТЗ Из БонусныеСчетаВладельца Цикл
				НоваяСтрока 					= Форма.ТаблицаЛицевыхБонусныхСчетов.Добавить();
				НоваяСтрока.ЛицевойБонусныйСчет = СтрокаТЗ.БонусныйСчет;
				НоваяСтрока.Представление 		= ?(ФормаКлиента, 
													Справочники.БонусныеСчета.ПолучитьПредставлениеБонусногоСчета(СтрокаТЗ.БонусныйСчет)
													+ СтрШаблон(Нстр("ru = ' (Общий расход: %1 %2) '; en = ' (Total expense: %1 %2) '"), Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СимвольныйКод), 
													Справочники.БонусныеСчета.ПолучитьПредставлениеБонусногоСчета(СтрокаТЗ.БонусныйСчет));
				
				НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;
			КонецЦикла;
			// Бонусные счета родственников
			Для Каждого СтрокаТЗ Из ТаблицаБонусныеСчета Цикл
				
				Если СтрокаТЗ.СуммаОстаток > 0 Тогда					
					Если БонусныеСчетаВладельца.Найти(СтрокаТЗ) <> Неопределено Тогда
						Продолжить;
					КонецЕсли;
					
					НоваяСтрока 					= Форма.ТаблицаЛицевыхБонусныхСчетов.Добавить();
					НоваяСтрока.ЛицевойБонусныйСчет = СтрокаТЗ.БонусныйСчет;
					НоваяСтрока.Представление 		= Справочники.БонусныеСчета.ПолучитьПредставлениеБонусногоСчета(СтрокаТЗ.БонусныйСчет) + СтрШаблон(" (Общий расход: %1 %2) ", Формат(СтрокаТЗ.СуммаРасход, "ЧЦ=15; ЧДЦ=2; ЧН="), СокрЛП(СимвольныйКод));
					НоваяСтрока.СуммаОстаток  		= СтрокаТЗ.СуммаОстаток;					
					МассивСтрокРодственников = ТаблицаРодственников.НайтиСтроки(Новый Структура("Родственник", СтрокаТЗ.Контрагент));					
					Если МассивСтрокРодственников.Количество() > 0 Тогда
						НоваяСтрока.СтепеньРодства  = МассивСтрокРодственников[0].СтепеньРодства;
					КонецЕсли;
					
				КонецЕсли;				
			КонецЦикла;
			
			УстановитьПривилегированныйРежим(Ложь);
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаРодственникиСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_РОДСТВЕННИКАМИ
			
			Форма.РодственникиСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	РодственныеСвязи.Контрагент КАК Контрагент,
			|	РодственныеСвязи.Родственник КАК Родственник,
			|	РодственныеСвязи.СтепеньРодства КАК СтепеньРодства,
			|	РодственныеСвязи.ОбщийЛицевойСчет КАК ОбщийЛицевойСчет,
			|	РодственныеСвязи.ОбщийНакопительныйСчет КАК ОбщийНакопительныйСчет,
			|	РодственныеСвязи.ЗаконныйПредставитель КАК ЗаконныйПредставитель
			|ИЗ
			|	РегистрСведений.РодственныеСвязи КАК РодственныеСвязи
			|ГДЕ
			|	РодственныеСвязи.Контрагент = &Контрагент";
			
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.РодственникиСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаПользовательИБСуществующий" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ПОЛЬЗОВАТЕЛЯМИИБ
			
			Форма.ПользователиИБСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Пользователи.Ссылка КАК Пользователь
			|ИЗ
			|	Справочник.Пользователи КАК Пользователи
			|ГДЕ
			|	Пользователи.Сотрудник = &Контрагент
			|	И НЕ Пользователи.ПометкаУдаления";
			
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.ПользователиИБСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаКабинетыСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_КАБИНЕТЫ_СУЩЕСТВУЮЩИЕ
			
			Форма.КабинетыСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СвязкаПомещениеСотрудник.Основное КАК Основное,
			|	СвязкаПомещениеСотрудник.Помещение КАК Помещение,
			|	СвязкаПомещениеСотрудник.Сотрудник КАК Сотрудник
			|ИЗ
			|	РегистрСведений.СвязкаПомещениеСотрудник КАК СвязкаПомещениеСотрудник
			|ГДЕ
			|	СвязкаПомещениеСотрудник.Сотрудник = &Контрагент";
			
			Запрос.УстановитьПараметр("Контрагент",	ВладелецСсылка);
			
			ТаблицаКабинетов = Запрос.Выполнить().Выгрузить();
			
			Форма.КабинетыСуществующие.Загрузить(ТаблицаКабинетов);
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаИнформацияПоОплатеПодробно" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ИНФОРМАЦИИ_ПО_ОПЛАТЕ
			
			Форма.Информация_По_Оплате.Очистить();
			
			Если ТипЗнч(ВладелецСсылка) <> Тип("ДанныеФормыСтруктура")
				И ТипЗнч(ВладелецСсылка) <> Тип("ФормаКлиентскогоПриложения")
				И Не ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			СхемаОплат = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ВернутьСтруктуруОплатыПоДокументу(ВладелецСсылка.Ссылка);
			
			Для Каждого СтрокаОплаты Из СхемаОплат Цикл 
				
				НоваяСтрока = Форма.Информация_По_Оплате.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОплаты);
				
				ТипДенежныхСредств = СтрокаОплаты.ТипДенежныхСредств;
				
				Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
					НоваяСтрока.ПолеСортировки = 1;
				ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда
					НоваяСтрока.ПолеСортировки = 2;
				ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда
					НоваяСтрока.ПолеСортировки = 3;
				ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Аванс Тогда
					НоваяСтрока.ПолеСортировки = 4;
				ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПодарочныйСертификат Тогда
					НоваяСтрока.ПолеСортировки = 5;
				Иначе
					НоваяСтрока.ПолеСортировки = 6;
				КонецЕсли;
				
			КонецЦикла;
			
			// сворачиваем по бонусному счету
			ТаблицаОплатыБонусами = ВладелецСсылка.СкидкиНаценки.Выгрузить(Новый Структура("ПризнакОплатыБонусом", Истина));
			ТаблицаОплатыБонусами.Свернуть("БонусныйСчет", "Сумма");
			
			Для Каждого СтрокаТЧ Из ТаблицаОплатыБонусами Цикл // ВладелецСсылка.СкидкиНаценки.НайтиСтроки(Новый Структура("ПризнакОплатыБонусом", Истина)) Цикл
				
				НоваяСтрока = Форма.Информация_По_Оплате.Добавить();
				НоваяСтрока.БонусныйСчет       = СтрокаТЧ.БонусныйСчет;
				НоваяСтрока.СуммаОплачено      = СтрокаТЧ.Сумма;
				НоваяСтрока.ПолеСортировки 	   = 7;
				НоваяСтрока.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.БонусныйСчет;
			КонецЦикла;
			
			Форма.Информация_По_Оплате.Сортировать("ПолеСортировки");
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаДолгиКонтрагентаСуществующие" Тогда
			
			#Область ЗАПОЛНЕНИЕ_ДОЛГОВ_КОНТРАГЕНТА
			
			МассивКлиентов = Новый Массив;
			МассивКлиентов.Добавить(ВладелецСсылка);
			
			// Родственники   = РегистрыСведений.РодственныеСвязи.РодственникиКлиента(ВладелецСсылка);
			// Если Родственники.Количество() > 0 Тогда
			//	
			//	МассивРодственников = Родственники.ВыгрузитьКолонку("Родственник");
			//	ОбщегоНазначения.ДобавитьВМассив(МассивКлиентов, МассивРодственников);
			//	
			// КонецЕсли;
			
			// ВсеОрганизации = Справочники.Сотрудники.ПолучитьВсеОрганизацииДляСотрудника(ПараметрыСеанса.ТекущийПользователь);
			
			ЗапросПоДолгам = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументРеализации КАК Основание,
			|	-ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток КАК Сумма,
			|	ВзаиморасчетыСКонтрагентамиОстатки.Контрагент КАК Контрагент
			|ПОМЕСТИТЬ ВТ_ДолгиОснование
			|ИЗ
			|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
			|			,
			|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
			|				И Контрагент = &Контрагент
			|				И ДокументРеализации <> НЕОПРЕДЕЛЕНО
			|				И ДокументРеализации <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)) КАК ВзаиморасчетыСКонтрагентамиОстатки
			|ГДЕ
			|	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток < 0
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса,
			|	-ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток,
			|	ВзаиморасчетыСКонтрагентамиОстатки.Контрагент
			|ИЗ
			|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
			|			,
			|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
			|				И Контрагент = &Контрагент
			|				И ДокументРеализации = НЕОПРЕДЕЛЕНО
			|				И ДокументАванса <> НЕОПРЕДЕЛЕНО
			|				И ДокументРеализации <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)) КАК ВзаиморасчетыСКонтрагентамиОстатки
			|ГДЕ
			|	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток < 0
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	МИНИМУМ(ВзаиморасчетыСКонтрагентами.Регистратор.Дата) КАК Дата,
			|	ВзаиморасчетыСКонтрагентами.Регистратор КАК Основание
			|ПОМЕСТИТЬ ВТ_ДолгиДата
			|ИЗ
			|	РегистрНакопления.ВзаиморасчетыСКонтрагентами КАК ВзаиморасчетыСКонтрагентами
			|ГДЕ
			|	ВзаиморасчетыСКонтрагентами.Регистратор В
			|			(ВЫБРАТЬ
			|				ВТ_ДолгиОснование.Основание
			|			ИЗ
			|				ВТ_ДолгиОснование КАК ВТ_ДолгиОснование)
			|
			|СГРУППИРОВАТЬ ПО
			|	ВзаиморасчетыСКонтрагентами.Регистратор
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_ДолгиОснование.Основание КАК Основание,
			|	ВТ_ДолгиОснование.Сумма КАК Сумма,
			|	ВТ_ДолгиОснование.Контрагент КАК Контрагент,
			|	ВТ_ДолгиДата.Дата КАК Дата
			|ИЗ
			|	ВТ_ДолгиОснование КАК ВТ_ДолгиОснование
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДолгиДата КАК ВТ_ДолгиДата
			|		ПО ВТ_ДолгиОснование.Основание = ВТ_ДолгиДата.Основание
			|
			|УПОРЯДОЧИТЬ ПО
			|	Дата");
			
			ЗапросПоДолгам.УстановитьПараметр("СтруктурнаяЕдиница", ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
			ЗапросПоДолгам.УстановитьПараметр("Контрагент"		  , ВладелецСсылка);
			// Запрос.УстановитьПараметр("Период"        , КонецДня(ТекущаяДатаСеанса()));
			// ТаблицаДолгов = ЗапросПоДолгам.Выполнить().Выгрузить();
									
			Форма.ДолгиСуществующие.Загрузить(ЗапросПоДолгам.Выполнить().Выгрузить());		
			
			#КонецОбласти 
			
		ИначеЕсли ЭлементРодитель = "ГруппаКартыСуществующие" Тогда	
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_КАРТАМИ
			
			Форма.КартыСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Карты.Ссылка КАК КартаСсылка,
			|	Карты.ТипКода КАК ТипКода,
			|	Карты.ВидКарты КАК ВидКарты,
			|	Карты.КодКарты КАК КодКарты,
			|	Карты.ВнутреннийКодКарты КАК ВнутреннийКодКарты
			|ИЗ
			|	Справочник.Карты КАК Карты
			|ГДЕ
			|	Карты.ВладелецКарты = &ВладелецКарты
			|	И НЕ Карты.ПометкаУдаления";
			
			Запрос.УстановитьПараметр("ВладелецКарты",	ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.КартыСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти    
			
		ИначеЕсли ЭлементРодитель = "ГруппаБудущиеСобытияКлиента" Тогда
			
			#Область ЗАПОЛНЕНИЕ_БУДУЩИХ_СОБЫТИЙ_КОНТРАГЕНТА
			
			// НУЖНЫ УСЛОВИЯ НА ДРУГИЕ СТАТУСЫ ????
			
			МассивКлиентов = Новый Массив;
			МассивКлиентов.Добавить(ВладелецСсылка);
						
			ЗапросПоБудущимСобытиям = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	Услуги.Ссылка КАК Событие
			|ПОМЕСТИТЬ ВТСобытий
			|ИЗ
			|	Документ.Событие.Услуги КАК Услуги
			|ГДЕ
			|	Услуги.Ссылка.Проведен
			|	И НЕ Услуги.Ссылка.ПометкаУдаления
			|	И НЕ Услуги.Ссылка.Статус.Ссылка В (ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен), ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОкончен))
			|	И Услуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
			|	И НЕ Услуги.Ссылка = &ИсключаемоеСобытие
			|	И Услуги.Ссылка.Контрагент = &Контрагент
			|	И Услуги.ДатаНачала > &ТекущаяДата
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СобытиеУслуги.Ссылка КАК Событие,
			|	МИНИМУМ(СобытиеУслуги.ДатаНачала) КАК ДатаСобытия,
			|	СобытиеУслуги.Ссылка.Врач КАК Сотрудник
			|ИЗ
			|	ВТСобытий КАК ВТСобытий
			|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Событие.Услуги КАК СобытиеУслуги
			|		ПО ВТСобытий.Событие = СобытиеУслуги.Ссылка
			|
			|СГРУППИРОВАТЬ ПО
			|	СобытиеУслуги.Ссылка,
			|	СобытиеУслуги.Ссылка.Врач
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаСобытия");
					
			ЗапросПоБудущимСобытиям.УстановитьПараметр("СтруктурнаяЕдиница"	, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
			ЗапросПоБудущимСобытиям.УстановитьПараметр("Контрагент"			, ВладелецСсылка);
			ЗапросПоБудущимСобытиям.УстановитьПараметр("ТекущаяДата"		, ТекущаяДатаСервера());
			ЗапросПоБудущимСобытиям.УстановитьПараметр("ИсключаемоеСобытие"	, Форма.Объект.Ссылка);
			
			Форма.БудущиеСобытия.Загрузить(ЗапросПоБудущимСобытиям.Выполнить().Выгрузить());		
			
			#КонецОбласти		
			
		ИначеЕсли ЭлементРодитель = "ГруппаПромокодыСуществующие" Тогда 
			
			#Область ЗАПОЛНЕНИЕ_ТАБЛИЦЫ_ПРОМОКОДОМ             
			
			Форма.ПромокодыСуществующие.Очистить();
			
			Если НЕ ЗначениеЗаполнено(ВладелецСсылка) Тогда
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Промокоды.Промокод КАК Промокод,
			|	Промокоды.Вид.Ссылка КАК ПромокодСсылка,
			|	Промокоды.Активен КАК Активен
			|ИЗ
			|	РегистрСведений.Промокоды КАК Промокоды
			|ГДЕ
			|	Промокоды.Владелец = &Владелец";
			
			Запрос.УстановитьПараметр("Владелец", ВладелецСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоваяСтрока = Форма.ПромокодыСуществующие.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			КонецЦикла;
			
			#КонецОбласти 

		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

//  Процедура - Обновить элементы дополнительной информации
// 
//  Параметры:
//   Форма			 - 	 - 
//   МассивРодителей	 - 	 - 
// 
Процедура ОбновитьЭлементыДополнительнойИнформации(Форма, ВладелецСсылка, МассивРодителей, ЕстьРеквизитОплаченоПоРегистру) Экспорт
	
	Элементы = Форма.Элементы;
	ЭтоФормаСотрудника = Форма.ИмяФормы = "Справочник.Сотрудники.Форма.ФормаЭлемента";
	
	Если ТипЗнч(ВладелецСсылка) = Тип("СправочникСсылка.Сотрудники")Тогда
		ОтступОтЛевогоКрая = 9;
	Иначе
		ОтступОтЛевогоКрая = 1;
	КонецЕсли;
	ШиринаПредставления = ?(Не ЭтоФормаСотрудника, 29, 46);
	
	//	ЭтоМобильныйКлиент = ОбщегоНазначенияКлиентСервер.ЭтоМобильныйКлиент();
	
	Для Каждого ЭлементРодитель Из МассивРодителей Цикл
		
		ГруппаРодитель = Элементы.Найти(ЭлементРодитель);
		Если ГруппаРодитель = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ОчиститьГруппуОтСозданныхЭлементов(Элементы, ГруппаРодитель);
		 		
		Если ЭлементРодитель = "ГруппаУдостоверенияЛичностиСуществующие" Тогда 
			
			#Область СОЗДАНИЕ_ЭЛЕМЕНТОВ_УДОСТОВЕРЕНИЯ_ЛИЧНОСТИ
			
			Для Каждого СтрокаТЗ Из Форма.УдостоверенияЛичностиСуществующие Цикл
				
				ИДСтроки = СтрокаТЗ.ПолучитьИдентификатор();
				
				//  Создаем группу
				// --------------------------------------------------------------------------------------------		
				ГруппаУдостоверенияЛичности = Элементы.Добавить("ГруппаУдостоверенияЛичностиСуществующие_" + ИДСтроки, Тип("ГруппаФормы"), ГруппаРодитель);
				ГруппаУдостоверенияЛичности.Вид 				= ВидГруппыФормы.ОбычнаяГруппа;
				ГруппаУдостоверенияЛичности.Заголовок 			= ГруппаУдостоверенияЛичности.Имя;
				ГруппаУдостоверенияЛичности.Отображение 		= ОтображениеОбычнойГруппы.Нет;
				ГруппаУдостоверенияЛичности.Группировка 		= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				ГруппаУдостоверенияЛичности.ОтображатьЗаголовок = Ложь;				
				// ГруппаУдостоверенияЛичности.ВертикальноеПоложениеПодчиненных 	= ВертикальноеПоложениеЭлемента.Центр;
				
				ДекорацияФормы_Заглушка = Элементы.Добавить("УдостоверенияЛичностиЗаглушка_" + ИДСтроки, Тип("ДекорацияФормы"), ГруппаУдостоверенияЛичности);
				ДекорацияФормы_Заглушка.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Заглушка.Заголовок 					= "";
				ДекорацияФормы_Заглушка.Гиперссылка 				= Истина;
				ДекорацияФормы_Заглушка.ЦветТекста 					= Новый Цвет(100, 100, 100);
				ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Заглушка.Ширина 						= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.МаксимальнаяШирина       	= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали  	= Истина;
				ДекорацияФормы_Заглушка.Гиперссылка				  	= Ложь;
				
				//  Создаем представление
				// --------------------------------------------------------------------------------------------		
				ДекорацияФормы_Представление = Элементы.Добавить("УдостоверенияЛичностиСуществующие_" + ИДСтроки, Тип("ДекорацияФормы"), ГруппаУдостоверенияЛичности);
				ДекорацияФормы_Представление.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Представление.Заголовок                  = СформироватьПредставлениеЭлемента(Форма, СтрокаТЗ, ЭлементРодитель);
				ДекорацияФормы_Представление.Гиперссылка 				= Истина;
				ДекорацияФормы_Представление.ЦветТекста 				= Новый Цвет(100, 100, 100);
				// ДекорацияФормы_Представление.Шрифт 						= Новый Шрифт("Verdana" , 8, , Истина);
				ДекорацияФормы_Представление.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Представление.МаксимальнаяШирина        	= 55;
				ДекорацияФормы_Представление.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Представление.РастягиватьПоГоризонтали  	= Истина;
				
				ДекорацияФормы_Представление.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_Представление_Нажатие");
				
			КонецЦикла;
			
			#КонецОбласти
			
		ИначеЕсли ЭлементРодитель = "ГруппаПолисыСуществующие" Тогда 
			
			#Область СОЗДАНИЕ_ЭЛЕМЕНТОВ_ПОЛИСЫ_МЕДИЦИНСКОГО_СТРАХОВАНИЯ
			
			Для Каждого СтрокаТЗ Из Форма.ПолисыСуществующие Цикл
				
				ИДСтроки = СтрокаТЗ.ПолучитьИдентификатор();
				
				//  Создаем группу
				// --------------------------------------------------------------------------------------------		
				ГруппаПолисыКонтрагента = Элементы.Добавить("ГруппаПолисКонтрагента_" + ИДСтроки, Тип("ГруппаФормы"), ГруппаРодитель);
				ГруппаПолисыКонтрагента.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
				ГруппаПолисыКонтрагента.Отображение 						= ОтображениеОбычнойГруппы.Нет;
				ГруппаПолисыКонтрагента.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				ГруппаПолисыКонтрагента.ОтображатьЗаголовок 				= Ложь;	
				
				//  Создаем заглушку
				// --------------------------------------------------------------------------------------------					
				ДекорацияФормы_Заглушка = Элементы.Добавить("ПолисКонтрагентаЗаглушка_" + ИДСтроки, Тип("ДекорацияФормы"), ГруппаПолисыКонтрагента);
				ДекорацияФормы_Заглушка.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Заглушка.Заголовок 					= "";
				ДекорацияФормы_Заглушка.ЦветТекста 					= Новый Цвет(100, 100, 100);
				ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Заглушка.МаксимальнаяШирина       	= ОтступОтЛевогоКрая;
				ДекорацияФормы_Заглушка.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
				ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали  	= Истина;
				ДекорацияФормы_Заглушка.Гиперссылка				  	= Ложь;

				//  Создаем метки при необходимости
				// --------------------------------------------------------------------------------------------		
				
				ГруппаМеткиПолисов = Элементы.Добавить("ГруппаМеткиПолисов_" + ИДСтроки, Тип("ГруппаФормы"), ГруппаПолисыКонтрагента);
				ГруппаМеткиПолисов.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
				ГруппаМеткиПолисов.Отображение 						= ОтображениеОбычнойГруппы.Нет;
				ГруппаМеткиПолисов.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				ГруппаМеткиПолисов.ОтображатьЗаголовок 				= Ложь;
				ГруппаМеткиПолисов.ГоризонтальныйИнтервал			= ИнтервалМеждуЭлементамиФормы.Нет;

				Если ЗначениеЗаполнено(СтрокаТЗ.СтраховаяКомпания) И ЗначениеЗаполнено(СтрокаТЗ.СтраховаяКомпания.КраткоеНаименование) Тогда
					
					ГруппаАльфа = Элементы.Добавить("ГруппаАльфа_" + ИДСтроки, Тип("ГруппаФормы"), ГруппаМеткиПолисов);
					ГруппаАльфа.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
					ГруппаАльфа.Отображение 						= ОтображениеОбычнойГруппы.Нет;
					ГруппаАльфа.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
					ГруппаАльфа.ОтображатьЗаголовок 				= Ложь;	

					ФонМетки = ?(ЗначениеЗаполнено(СтрокаТЗ.СтраховаяКомпания.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(СтрокаТЗ.СтраховаяКомпания.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
					ГруппаАльфа.ЦветФона  = ФонМетки; 

					ДекорацияФормы_Альфа = Элементы.Добавить("ПолисАльфа_" + ИДСтроки, Тип("ДекорацияФормы"), ГруппаАльфа);
					ДекорацияФормы_Альфа.Вид 						= ВидДекорацииФормы.Надпись;
					ДекорацияФормы_Альфа.ГоризонтальноеПоложение   	= ГоризонтальноеПоложениеЭлемента.Лево;
					ДекорацияФормы_Альфа.Гиперссылка			  	= Ложь;
 					ДекорацияФормы_Альфа.ЦветТекста  				= ?(СтрокаТЗ.СтраховаяКомпания.ЦветТекстаБелый, Новый Цвет(255,255,255), Новый Цвет(77,77,77));
					ДекорацияФормы_Альфа.Заголовок					= СтрокаТЗ.СтраховаяКомпания.КраткоеНаименование;

				КонецЕсли;
				
				Если ЗначениеЗаполнено(СтрокаТЗ.Полис.Договор.ПрограммаСтрахования) Тогда

					ПрограммаСтрахования = СтрокаТЗ.Полис.Договор.ПрограммаСтрахования;
					
					ГруппаВидДоговора = Элементы.Добавить("ГруппаВидДоговора_" + ИДСтроки, Тип("ГруппаФормы"), ГруппаМеткиПолисов);
					ГруппаВидДоговора.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
					ГруппаВидДоговора.Отображение 						= ОтображениеОбычнойГруппы.Нет;
					ГруппаВидДоговора.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
					ГруппаВидДоговора.ОтображатьЗаголовок 				= Ложь;
					
					ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(ПрограммаСтрахования); 

					ГруппаВидДоговора.ЦветФона  = ДанныеПрограммыСтрахования.ЦветФОна; 

					ДекорацияФормы_ВидДоговора = Элементы.Добавить("ВидДоговора_" + ИДСтроки, Тип("ДекорацияФормы"), ГруппаВидДоговора);
					ДекорацияФормы_ВидДоговора.Вид 						= ВидДекорацииФормы.Надпись;
					ДекорацияФормы_ВидДоговора.ГоризонтальноеПоложение  = ГоризонтальноеПоложениеЭлемента.Лево;
					ДекорацияФормы_ВидДоговора.Гиперссылка			  	= Ложь;
 					ДекорацияФормы_ВидДоговора.ЦветТекста  				= ДанныеПрограммыСтрахования.ЦветТекста;
					ДекорацияФормы_ВидДоговора.Заголовок				= ДанныеПрограммыСтрахования.Текст;

				КонецЕсли;
				//  Создаем представление
				// --------------------------------------------------------------------------------------------		
				ДекорацияФормы_Представление = Элементы.Добавить("ПолисКонтрагента_" + ИДСтроки, Тип("ДекорацияФормы"), ГруппаПолисыКонтрагента);
				ДекорацияФормы_Представление.Вид 						= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_Представление.Заголовок                  = СформироватьПредставлениеЭлемента(Форма, СтрокаТЗ, ЭлементРодитель);
				ДекорацияФормы_Представление.Гиперссылка 				= Истина;
				ДекорацияФормы_Представление.ЦветТекста 				= Новый Цвет(100, 100, 100);
				ДекорацияФормы_Представление.АвтоМаксимальнаяШирина    	= Ложь;
				ДекорацияФормы_Представление.МаксимальнаяШирина        	= 55;
