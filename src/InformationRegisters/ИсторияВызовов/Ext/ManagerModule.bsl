
#Область СлужебныеПроцедурыИФункции

// Функция - Получить по IDЗвонка
//
// Параметры:
//  IDЗвонка - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПоIDЗвонка(IDЗвонка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("IDЗвонка", IDЗвонка);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1 *
	               |ИЗ
	               |	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	               |ГДЕ
	               |	ИсторияВызовов.IDЗвонка = &IDЗвонка";
				   
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если РезультатЗапроса.Количество() > 0 Тогда
		Возврат СтрокуТаблицыЗначенийВСтруктуру(РезультатЗапроса[0], РезультатЗапроса);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить коллтрекинг номер
//
// Параметры:
//  IDЗвонка		 - 	 - 
//  ПОIPТелефонии	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКоллтрекингНомер(IDЗвонка = Неопределено, ПОIPТелефонии = Неопределено, Заявка = Неопределено) Экспорт
	
	СтруктураКоллтрекинга = Новый Структура;
	
	Если IDЗвонка = Неопределено И ПОIPТелефонии = Неопределено И Заявка = Неопределено Тогда 
		СтруктураКоллтрекинга.Вставить("ПОIPТелефонии"		, Неопределено);
		СтруктураКоллтрекинга.Вставить("IDЗвонка"			, "");
		СтруктураКоллтрекинга.Вставить("КоллтрекингНомер"	, "");
		
		Возврат СтруктураКоллтрекинга;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ИсторияВызовов.ОборудованиеТелефонии КАК ПОIPТелефонии,
	               |	ИсторияВызовов.IDЗвонка КАК IDЗвонка,
	               |	ИсторияВызовов.КоллтрекингНомер КАК КоллтрекингНомер
	               |ИЗ
	               |	РегистрСведений.ИсторияВызовов КАК ИсторияВызовов
	               |ГДЕ
	               |	ИсторияВызовов.ОборудованиеТелефонии = &ОборудованиеТелефонии
	               |	И ИсторияВызовов.IDЗвонка = &IDЗвонка
	               |	И ИсторияВызовов.Заявка = &Заявка
	               |	И ИсторияВызовов.КоллтрекингНомер <> """"";
	
	Если НЕ ЗначениеЗаполнено(IDЗвонка) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияВызовов.IDЗвонка = &IDЗвонка", "ИСТИНА");
	Иначе 
		Запрос.УстановитьПараметр("IDЗвонка", IDЗвонка);
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(ПОIPТелефонии) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияВызовов.ОборудованиеТелефонии = &ОборудованиеТелефонии", "ИСТИНА");
	Иначе 
		Запрос.УстановитьПараметр("ОборудованиеТелефонии", ПОIPТелефонии);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Заявка) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияВызовов.Заявка = &Заявка", "ИСТИНА");
	Иначе 
		Запрос.УстановитьПараметр("Заявка", Заявка);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("IDЗвонка", IDЗвонка);
	
	ВыборкаКоллтрекингНомер = Запрос.Выполнить().Выбрать();
	Если ВыборкаКоллтрекингНомер.Следующий() Тогда
		СтруктураКоллтрекинга.Вставить("ПОIPТелефонии"		, ВыборкаКоллтрекингНомер.ПОIPТелефонии);
		СтруктураКоллтрекинга.Вставить("IDЗвонка"			, ВыборкаКоллтрекингНомер.IDЗвонка);
		СтруктураКоллтрекинга.Вставить("КоллтрекингНомер"	, ВыборкаКоллтрекингНомер.КоллтрекингНомер);
		
		Возврат СтруктураКоллтрекинга;
	Иначе 
		СтруктураКоллтрекинга.Вставить("ПОIPТелефонии"		, Неопределено);
		СтруктураКоллтрекинга.Вставить("IDЗвонка"			, "");
		СтруктураКоллтрекинга.Вставить("КоллтрекингНомер"	, "");
		
		Возврат СтруктураКоллтрекинга;
	КонецЕсли;	
		
КонецФункции	


#КонецОбласти








