		<field xsi:type="DataSetFieldField">
			<dataPath>СтатусКлиента</dataPath>
			<field>СтатусКлиента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Статус клиента</v8:content>
				</v8:item>
				<v8:item>
