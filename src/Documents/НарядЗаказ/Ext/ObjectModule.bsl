//
//
Процедура ПостОбработкаДокументовАванса(РежимЗаписиНарядЗаказа = Неопределено, Отказ)	
	
	Если Проведен Тогда
		МассивПлановЛечения = Новый Массив;
		МассивПриемов = Новый Массив;
		// табличная часть Запасы
		Для Каждого СтрокаТЧ Из Запасы Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.ПланЛечения) Тогда 
				Если ТипЗнч(СтрокаТЧ.ПланЛечения) = Тип("ДокументСсылка.ПланЛечения") Тогда	
					Если МассивПлановЛечения.Найти(СтрокаТЧ.ПланЛечения) = Неопределено Тогда  
						МассивПлановЛечения.Добавить(СтрокаТЧ.ПланЛечения);
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаТЧ.Прием) Тогда
					Если МассивПриемов.Найти(СтрокаТЧ.Прием) = Неопределено Тогда  
						МассивПриемов.Добавить(СтрокаТЧ.Прием);
					КонецЕсли;
			КонецЕсли;		
		КонецЦикла;
		// Дополним массивы	документами, содержавшимися в строках, которые мы удалили	
		Если ДополнительныеСвойства.Свойство("ТаблицаУдаленныхСтрок") Тогда 
			ТаблицаУдаляемыхСтрок = ДополнительныеСвойства.ТаблицаУдаленныхСтрок.Выгрузить();
			ТаблицаУдаляемыхСтрок.Свернуть("КлючСтроки, ДокументАванса");
			Если ДополнительныеСвойства.ТаблицаУдаленныхСтрок.Количество() > 0 Тогда			
				ТаблицаДокументовАванса = ДополнительныеСвойства.ТаблицаУдаленныхСтрок.Выгрузить(, "ДокументАванса");			
				ТаблицаДокументовАванса.Свернуть("ДокументАванса");
				
				Для Каждого ДокументАванса Из ТаблицаДокументовАванса Цикл 
					Если ТипЗнч(ДокументАванса.ДокументАванса) = Тип("ДокументСсылка.ПланЛечения") Тогда	
						Если МассивПлановЛечения.Найти(ДокументАванса.ДокументАванса) = Неопределено Тогда  
							МассивПлановЛечения.Добавить(ДокументАванса.ДокументАванса);
						КонецЕсли;
					КонецЕсли;	
				КонецЦикла;
			КонецЕсли;	
		Иначе 
			ТаблицаУдаляемыхСтрок = Неопределено;
		КонецЕсли;
		
		ЗаполнитьРеквизитПриемВПланеЛечения____И____ПроставитьСоответствующиеСтатусы(МассивПлановЛечения, ТаблицаУдаляемыхСтрок, РежимЗаписиНарядЗаказа);	
		ЗаполнитьРеквизитДокументАвансаВПрием(МассивПриемов, РежимЗаписиНарядЗаказа, Отказ);
		// ЭтотОбъект.Прочитать();
	КонецЕсли;

КонецПроцедуры

//
