// Функция, возвращает список доступных полей сортировки подбора
//
// Параметры:
//  НажатаяКнопка	 - 	 НажатаяКнопка (ТекущийЭлемент) 
// 
// Возвращаемое значение:
//   СписокЗначений, состоящий из доступных полей сортировки подбора 
//
Функция ПолучитьСписокДоступныхПолейСортировкиПодбора(СтраницаЗапасы = Ложь)
	
	СписокПолейСортировки = Новый СписокЗначений;
	СписокПолейСортировки.Добавить("Наименование", "Наименование");	
	
	Если ОтображатьАртикул Тогда
		СписокПолейСортировки.Добавить("Артикул", "Артикул");	
	КонецЕсли;	
	
	Если ОтображатьЦену Тогда
		СписокПолейСортировки.Добавить("Цена", "Цена");	
	КонецЕсли;
		
	Если СтраницаЗапасы И ОтображатьОстаток Тогда
		СписокПолейСортировки.Добавить("Количество", "Остаток");	
	КонецЕсли;	
	
	Возврат(СписокПолейСортировки);
	
КонецФункции

