// Функция - получает список структурных единиц с отметкой индивидуальных норм списания
// 
Функция ПолучитьСписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм()
	
	СписокЗначений = Новый СписокЗначений;
	
	ТаблицаОбщихНормСписания = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка")));
	
	Для Каждого СтрокаТЗ Из СписокСтруктурныхЕдиниц Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.Значение) тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗаданыИндивидуальныеНормыСписания(СтрокаТЗ.Значение, ТаблицаОбщихНормСписания) Тогда
			СписокЗначений.Добавить(СтрокаТЗ.Значение,,, БиблиотекаКартинок.ПодборТоваров);
		Иначе
			СписокЗначений.Добавить(СтрокаТЗ.Значение);
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат СписокЗначений;
	
КонецФункции    
    
