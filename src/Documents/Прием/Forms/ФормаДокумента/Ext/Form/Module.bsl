// Процедура, ОбновитьСделку.
//
Процедура ОбновитьСделку(ИмяКоманды, Контрагент)
	
	Если СтрНайти(ИмяКоманды, "КомандаЭтап") > 0 Тогда		
		
		ИндексВиджета 	= ПолучитьИндексСтроки(ИмяКоманды, Ложь);
		ИндексЭтапа     = ПолучитьИндексСтроки(ИмяКоманды);
		НайденнаяСделка = ЭтотОбъект.ТаблицаСделок[ИндексВиджета].Сделка;

		УправлениеИнтерфейсамиСервер.ОбновитьЭтапСделки(НайденнаяСделка, ИндексЭтапа);
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() 
		И ЭтотОбъект.Статус <> Перечисления.СтатусыКонтрагентов.Потенциальный Тогда
		
		ЭтотОбъект.Статус = Перечисления.СтатусыКонтрагентов.Потенциальный;
		// ОбновитьОформлениеКнопкиСтатусаКлиента();
		
	Иначе 
		
		ЭтотОбъект.Статус = Справочники.Контрагенты.ПолучитьСтатус(Объект.Ссылка);
		// ОбновитьОформлениеКнопкиСтатусаКлиента();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ИмяЭлемента, ИндексЭлемента = Истина)
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		
		Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Сред(ИмяЭлемента, НомерСимвола + 1, 2)) Тогда
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 2));
		Иначе		
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));	
		КонецЕсли;		
		
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1));
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура, СменитьФокусЭлемента.
