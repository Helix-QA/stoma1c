	|<td class='center_col'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|<p class='content'><a href='{Ссылка}' class='profs' title='Открыть профосмотр' id='{ИдПрофосмотра}'> {Представление}</a> {Описание}</p>";
	
	Уид = СтрокаТЗ.ПолучитьИдентификатор();
	
	ПредставлениеДаты = ?(Запланировано,  ПолучитьПредставлениеДаты(СтрокаТЗ.Дата) + ", ", ""); 
	
	
	ТекстHTML = СтрЗаменить(ТекстHTML, "{ИдПрофосмотра}" 	, Уид);
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Представление}" 	, ПредставлениеДаты + Строка(СтрокаТЗ.ВидОсмотра) + " (" + СтрокаТЗ.Статус + "). ");
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Описание}" 		, СтрокаТЗ.ПричинаНаправления);
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Картинка}"		 	, Base64Строка(БиблиотекаКартинок.Профосмотр16х16.ПолучитьДвоичныеДанные()));
	
	ТекстHTML = ТекстHTML + 
	"</td>
	|<td class='right_col' align='right'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|";
	
	СотрудникHTML = ""; 		
	
	СотрудникHTML = "<p class='author' title='{Сотрудник}'>{Сотрудник}</p>";
	СотрудникHTML = СтрЗаменить(СотрудникHTML, "{Сотрудник}", ПредставлениеФИОСотрудника(СтрокаТЗ.Сотрудник));
	
	ТекстHTML = ТекстHTML + СотрудникHTML + Символы.ПС;
	
	Возврат ТекстHTML + "</td>" + Символы.ПС + "</tr>";
	
КонецФункции

// Функция, формирует блок визит.
//
Функция СформироватьБлокПрием(Прием, Статус, ЦветФона = "", Запланировано = Ложь)
	
	Если ЗначениеЗаполнено(Прием.ПолисМедСтрахования) Тогда	
		ЦветФона = "#c3eefa";		
	КонецЕсли;
	
	ТекстHTML = 
	"<tr>
	|<td align='right' class='left_col' style='background-color: inherit;'>
	|<img alt='Прием' src='data:image/png;base64, {Картинка}'/>
	|</td>
	|<td class='center_col'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|<p class='content'><a href='{Ссылка}' title='Открыть прием'>{Представление}</a>Сумма: {Сумма} Оплачено: {Оплачено}</p>";
	
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Ссылка}"        , ПолучитьНавигационнуюСсылку(Прием));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Представление}" , ПолучитьПредставлениеПриема(Прием, Статус, Запланировано));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Картинка}"		 , Base64Строка(БиблиотекаКартинок.PNG_СтетоскопПриемВрача_16х16.ПолучитьДвоичныеДанные()));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Оплачено}"		 , "" + Прием.СуммаОплачено + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты());
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Сумма}"		 , "" + Прием.СуммаДокумента + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты());
	
	ТаблицаЗапасов 		= Прием.Лечение.Выгрузить().Скопировать(); 
	ВремТаблицаЗапасов 	= ТаблицаЗапасов.Скопировать();
	ВремТаблицаЗапасов.Свернуть("Номенклатура");
	
	Для Каждого Номенклатура Из ВремТаблицаЗапасов.ВыгрузитьКолонку("Номенклатура") Цикл
		
		МассивСтрокТаблицы  = ТаблицаЗапасов.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура)); 
		КоличествоСтрок    	= МассивСтрокТаблицы.Количество();
		СтрокаЗубов = "Зубы: ";
		
		Для Счетчик = 0 По КоличествоСтрок - 1 Цикл 	
			
			Если Счетчик <> КоличествоСтрок - 1 Тогда                // Это не последний элемент.
				СтрокаЗубов = СтрокаЗубов + МассивСтрокТаблицы[Счетчик].Зуб + ", "; 
			Иначе 
				СтрокаЗубов = СтрокаЗубов + МассивСтрокТаблицы[Счетчик].Зуб;	 
			КонецЕсли; 
			
		КонецЦикла;
		
		ОбщаяСтрокаНоменклатуры = СтрокаЗубов + " - " + Строка(Номенклатура);
	
		Шаблон = "<p class='content' title='{Номенклатура}'>{Номенклатура}</p>";
		ТекстHTML = ТекстHTML + Символы.ПС + СтрЗаменить(Шаблон, "{Номенклатура}"	, ОбщаяСтрокаНоменклатуры);			 	
				
	КонецЦикла;
		
	ТекстHTML = ТекстHTML + 
	"</td>
	|<td class='right_col' align='right'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	
	СотрудникHTML = ""; 		
	
	СотрудникHTML = "<p class='author' title='{Сотрудник}'>{Сотрудник}</p>";
	СотрудникHTML = СтрЗаменить(СотрудникHTML, "{Сотрудник}", ПредставлениеФИОСотрудника(Прием.Сотрудник));
	Если ЗначениеЗаполнено(Прием.Ассистент) Тогда
		СотрудникHTML = СотрудникHTML + "<p class='author' title='{Ассистент}'>{Ассистент}</p>";
		СотрудникHTML = СтрЗаменить(СотрудникHTML, "{Ассистент}", ПредставлениеФИОСотрудника(Прием.Ассистент));
	КонецЕсли;			
	
	ТекстHTML = ТекстHTML + СотрудникHTML + Символы.ПС;
	
	
	ТекстHTML = ТекстHTML + "<a class='reference' style='background: {НавигационнаяСсылкаЦвет}' href='{НавигационнаяСсылка}' title='{НавигационнаяСсылкаПодсказка}'>{НавигационнаяСсылкаПредставление}</a>";
	
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ТекстHTML, Прием.Сделка, Прием);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТекстHTML + "</td>" + Символы.ПС + "</tr>";
	
КонецФункции 

// Функция, формирует блок визит.
//
Функция СформироватьБлокНарядЗаказ(НарядЗаказ, Статус, ЦветФона = "", Запланировано = Ложь)
	
	ТекстHTML = 
	"<tr>
	|<td align='right' class='left_col' style='background-color: inherit;'>
	|<img alt='Прием' src='data:image/svg+xml;base64, {Картинка}'/>      
	|</td>
	|<td class='center_col'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|<p class='content'><a href='{Ссылка}' title='Открыть наряд заказ'>{Представление}</a>Сумма: {Сумма}</p>";
	
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Ссылка}"        , ПолучитьНавигационнуюСсылку(НарядЗаказ));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Представление}" , ПолучитьПредставлениеНарядЗаказа(НарядЗаказ, Статус, Запланировано));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Картинка}"		 , Base64Строка(БиблиотекаКартинок.НарядЗаказ16х16.ПолучитьДвоичныеДанные()));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Сумма}"		 , "" + НарядЗаказ.СуммаДокумента + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты());
	
	ВремЗапасы = НарядЗаказ.Запасы.Выгрузить().Скопировать(); 
	ВремЗапасы.Свернуть("Номенклатура");                 
	
	Для Каждого Номенклатура Из ВремЗапасы.ВыгрузитьКолонку("Номенклатура") Цикл
		
		Шаблон = "<p class='content' title='{Номенклатура}'>{Номенклатура}</p>";
		ТекстHTML = ТекстHTML + Символы.ПС + СтрЗаменить(Шаблон, "{Номенклатура}", Строка(Номенклатура));			 	
		
	КонецЦикла;
	
	ТекстHTML = ТекстHTML + 
	"</td>
	|<td class='right_col' align='right'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	
	СотрудникHTML = ""; 		
	
	СотрудникHTML = "<p class='author' title='{Сотрудник}'>{Сотрудник}</p>";
	СотрудникHTML = СтрЗаменить(СотрудникHTML, "{Сотрудник}", ПредставлениеФИОСотрудника(НарядЗаказ.Сотрудник));			
	
	ТекстHTML = ТекстHTML + СотрудникHTML + Символы.ПС;
		
	ТекстHTML = ТекстHTML + "<a class='reference' style='background: {НавигационнаяСсылкаЦвет}' href='{НавигационнаяСсылка}' title='{НавигационнаяСсылкаПодсказка}'>{НавигационнаяСсылкаПредставление}</a>";
	
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ТекстHTML, ,НарядЗаказ);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТекстHTML + "</td>" + Символы.ПС + "</tr>";
	
КонецФункции

// Функция, формирует блок диалог.
//
Функция СформироватьБлокДиалог(СтрокаТЗ, ТегДиалогаОткрыт)
	
	Если СтрокаТЗ.ВзаимодействиеИд = "0" Тогда
		// Сообщение от клиента.
		ШаблонДиалог = "
		|<tr>
		|	<td colspan='2' width=585px>
		|		<div style='float: right; color:gray'>{ДатаСообщения}</div>
		|		<div class='block_right'>
		|			<div><p class='leftstr'>{ТекстСообщения}</p></div>	
		|		</div>
		|	</td>
		|</tr>";
				
	Иначе
		// Сообщение от менеджера.
		ШаблонДиалог = "
		|<tr>
		|	<td colspan='2' width=585px>
		|		<div style='float: left; color:gray'>{ДатаСообщения}</div>
		|		<div class='block_left'><p class='leftstr'>{ТекстСообщения}</p></div>
		|	</td>
		|</tr>";
		
	КонецЕсли;
	
	Если ТегДиалогаОткрыт Тогда
		ШаблонДиалог =  ШаблонДиалог + "
		|<tr>
		|<td colspan='3' style='height: 8px;'>
		|</td>	
		|</tr>";
	
	КонецЕсли;

	Уид = СтрокаТЗ.ПолучитьИдентификатор();
	
	// Посимвольно очищаем строку от недопустимых символов с конца,
	// на случай если в конец попала половина составного символа. Татарой.
	
	ТекстСодержания = ?(СтрокаТЗ.ТекстСообщения = "", СтрокаТЗ.Ссылка.Содержание, СтрокаТЗ.ТекстСообщения);  
	
	ДлинаСтрокиРезультат = СтрДлина(ТекстСодержания);
	ПоследнийСимвол = "";
	
	Пока Не ЗначениеЗаполнено(ПоследнийСимвол) Цикл
		
		Если ДлинаСтрокиРезультат = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПоследнийСимвол = ОбщегоНазначенияКлиентСерверСтоматология.УдалитьНедопустимыеСимволыXMLРабочая(Сред(ТекстСодержания, ДлинаСтрокиРезультат, 1));
		
		Если ЗначениеЗаполнено(ПоследнийСимвол) Тогда
			Прервать;
		КонецЕсли;
		
		ДлинаСтрокиРезультат = ДлинаСтрокиРезультат - 1;
		
	КонецЦикла;
	
	ТекстСообщения = Лев(ТекстСодержания, ДлинаСтрокиРезультат);
	
	Сообщение =  ?(ЗначениеЗаполнено(ТекстСообщения), ТекстСообщения, "...");
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{ТекстСообщения}"	, Сообщение);
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{ДатаСообщения}"	, Формат(СтрокаТЗ.Дата, "ДФ=HH:mm"));
	
	Возврат ШаблонДиалог;		
	
КонецФункции

// Процедура - Сформировать блок взаимодействия получить значения навигационной ссылки.
//
// Параметры:
//  Задача					 - 	 - 
//  ТипЗадачи				 - 	 - 
//  ДопДанныеПодсказка		 - 	 - 
//  ДопДанныеПредставление	 - 	 - 
//  ДопДанныеЦвет			 - 	 - 
//  НавигационнаяСсылка		 - 	 - 
//  ЦветФона				 - 	 - 
//
Процедура ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонБлока, СделкаВзаимодействия = Неопределено, ОбъектВзаимодействия = Неопределено)
	
	// Если передана сделка взаимодействия.
	Если ЗначениеЗаполнено(СделкаВзаимодействия) И ТипЗнч(СделкаВзаимодействия) = Тип("СправочникСсылка.Сделки") Тогда
		ДанныеСделки 		= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(СделкаВзаимодействия, "Наименование, Код, ВидСделки, ЭтапСделки, Врач");
		ВидСделки 			= ДанныеСделки.ВидСделки;
		Врач 				= ДанныеСделки.Врач;
		
		НаименованиеСделки 	= Справочники.Сделки.ИнициализироватьСокращенноеНаименованиеСделки(ДанныеСделки, Истина, , Истина);
		
		Если НЕ ЗначениеЗаполнено(НаименованиеСделки) Тогда 
			НаименованиеСделки = ?(ЗначениеЗаполнено(ДанныеСделки.Наименование), ДанныеСделки.Наименование, Справочники.Сделки.СоздатьНаименованиеСделки(СделкаВзаимодействия));
			НаименованиеСделки = СокрЛП(НаименованиеСделки) + " " + Справочники.Сделки.ПолучитьСокращенноеНаименованиеВрача(, ДанныеСделки.Врач); 
		КонецЕсли;	
		НавигационнаяСсылкаПредставление = НаименованиеСделки;
		НавигационнаяСсылкаПодсказка     = НавигационнаяСсылкаПредставление;
		НавигационнаяСсылкаЦвет          = ПолучитьЦветДляСделки(, ДанныеСделки.ЭтапСделки);
		НавигационнаяСсылка              = ПолучитьНавигационнуюСсылку(СделкаВзаимодействия);  
	ИначеЕсли ЗначениеЗаполнено(ОбъектВзаимодействия) Тогда 
		Если ОбщегоНазначенияСтоматология.ЕстьРеквизитОбъекта("Сделка", , ОбъектВзаимодействия) Тогда
			Сделка = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбъектВзаимодействия, "Сделка");
			Если ЗначениеЗаполнено(Сделка) Тогда 
				ДанныеСделки 		= ОбщегоНазначенияСтоматология.ПолучитьЗначенияРеквизитов(Сделка, "Наименование, Код, ВидСделки, ЭтапСделки, Врач");
				ВидСделки 			= ДанныеСделки.ВидСделки;
				Врач 				= ДанныеСделки.Врач;
				
				НаименованиеСделки 	= Справочники.Сделки.ИнициализироватьСокращенноеНаименованиеСделки(ДанныеСделки, Истина, , Истина);
				
				Если НЕ ЗначениеЗаполнено(НаименованиеСделки) Тогда 
					НаименованиеСделки = ?(ЗначениеЗаполнено(ДанныеСделки.Наименование), ДанныеСделки.Наименование, Справочники.Сделки.СоздатьНаименованиеСделки(Сделка));
					НаименованиеСделки = СокрЛП(НаименованиеСделки) + " " + Справочники.Сделки.ПолучитьСокращенноеНаименованиеВрача(, ДанныеСделки.Врач); 
				КонецЕсли;	
				НавигационнаяСсылкаПредставление = НаименованиеСделки;
				НавигационнаяСсылкаПодсказка     = НавигационнаяСсылкаПредставление;
				НавигационнаяСсылкаЦвет          = "rgb(236, 236, 159)";
				НавигационнаяСсылка              = ПолучитьНавигационнуюСсылку(Сделка);  
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылкаПредставление}", НавигационнаяСсылкаПредставление);
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылкаПодсказка}"    , НавигационнаяСсылкаПодсказка);
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылкаЦвет}"         , НавигационнаяСсылкаЦвет);
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылка}"             , НавигационнаяСсылка);	
		
КонецПроцедуры

// Функция - Получить цвет для бизнес процесса.
//
// Параметры:
//  БизнесПроцесс	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветДляСделки(Сделка = Неопределено, ЭтапСделки = Неопределено)
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Сделка) И НЕ ЗначениеЗаполнено(ЭтапСделки) Тогда
		Возврат "";
	КонецЕсли;
	
	ЦветЭтапа = "";
	Если НЕ ЗначениеЗаполнено(ЭтапСделки) Тогда 
		ЭтапСделки 	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Сделка, "ЭтапСделки");
		Если ЗначениеЗаполнено(ЭтапСделки) Тогда
			Если ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда 
				ЦветЭтапа = Новый Цвет(72, 193, 123);
			ИначеЕсли ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда 
				ЦветЭтапа = Новый Цвет(246, 110, 110);
			Иначе 	
				ЦветЭтапа 	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭтапСделки, "ЦветЭтапа");
			КонецЕсли;	
		Иначе 
			ЦветЭтапа 	= "";
		КонецЕсли;	
	Иначе 
		Если ЭтапСделки = Справочники.ЭтапыСделок.Успех Тогда 
			ЦветЭтапа = Новый Цвет(72, 193, 123);
		ИначеЕсли ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда 
			ЦветЭтапа = Новый Цвет(246, 110, 110);
		Иначе 	
			ЦветЭтапа 	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭтапСделки, "ЦветЭтапа");
		КонецЕсли;	
	КонецЕсли;	
	Цвет      		= ?(ТипЗнч(ЦветЭтапа) = Тип("Цвет"), ЦветЭтапа, ?(ТипЗнч(ЦветЭтапа) = Тип("Строка") И ЗначениеЗаполнено(ЦветЭтапа), ЗначениеИзСтрокиВнутр(ЦветЭтапа), Неопределено));	
		
	Возврат ?(Цвет <> Неопределено, СтрШаблон("rgb(%1,%2,%3)", Цвет.Красный, Цвет.Зеленый, Цвет.Синий), "");
	
КонецФункции

