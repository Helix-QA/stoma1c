
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбъектГенерацииОтсутствует = "Объект генерации отсутствует";
	
	Элементы.Взаимодействие.Видимость 				= ЗначениеЗаполнено(Запись.Взаимодействие);
	Элементы.Сделка.Видимость 						= ЗначениеЗаполнено(Запись.Сделка);
	Элементы.ГруппаГенерацияДиалога.Видимость 		= ЗначениеЗаполнено(Запись.IDСообщения);
	Элементы.SMSРассылка.Видимость 					= ЗначениеЗаполнено(Запись.SMSРассылка);
	Элементы.ЭлектронноеПисьмоИсходящее.Видимость 	= ЗначениеЗаполнено(Запись.ЭлектронноеПисьмоИсходящее);
	
	Элементы.ОбъектГенерацииОтсутствует.Видимость = НЕ Элементы.Взаимодействие.Видимость И
													НЕ Элементы.Сделка.Видимость И
													НЕ Элементы.ГруппаГенерацияДиалога.Видимость И
													НЕ Элементы.SMSРассылка.Видимость И
													НЕ Элементы.ЭлектронноеПисьмоИсходящее.Видимость;
													
	Элементы.ГруппаОбъектыГенерации.Заголовок 		= ?(Элементы.ОбъектГенерацииОтсутствует.Видимость, "Объект генерации отсутствует", "Объект генерации");
	
	ЭтаФорма.ТекущийЭлемент = Элементы.Период;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Перейти к журналу диалогов
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПерейтиКЖурналуДиалогов(Команда)

	Отбор = Новый Структура;
	Отбор.Вставить("ИдДиалога", Запись.IDСообщения);
	//ОткрытьФорму("РегистрСведений.Диалоги.ФормаСписка", Новый Структура("Отбор", Отбор), ЭтаФорма);
	ОткрытьФорму("РегистрСведений.Диалоги.ФормаСписка", Отбор, ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти