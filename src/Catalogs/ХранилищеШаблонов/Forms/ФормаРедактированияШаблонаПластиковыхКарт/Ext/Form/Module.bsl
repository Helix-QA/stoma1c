// Процедура осуществляет выбор доступного поля
//
// Параметры
//  Выбрать  - ИдентификаторКомпоновкиДанных - Идентификатор компоновки данных
//
&НаКлиенте
Процедура ВыборДоступногоПоля(ВыбраннаяСтрока)

    ПолеШаблон            = ПолеТабличногоДокумента.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Текст);       
	ПолеШаблон.Заполнение = ТипЗаполненияОбластиТабличногоДокумента.Текст;
	Индекс                = ПолеТабличногоДокумента.Рисунки.Индекс(ПолеШаблон); 	
	ИмяПоляВШаблоне       = Строка(КомпоновщикНастроек.Настройки.ДоступныеПоляПорядка.ПолучитьОбъектПоИдентификатору(ВыбраннаяСтрока).Поле);
	
	ПолеТабличногоДокумента.Рисунки[Индекс].Имя   = ИмяПоляВШаблоне;
	ПолеТабличногоДокумента.Рисунки[Индекс].Текст = ИмяПоляВШаблоне;	
	ПолеТабличногоДокумента.Рисунки[Индекс].Узор  = ТипУзораТабличногоДокумента.БезУзора;
	ПолеТабличногоДокумента.Рисунки[Индекс].Расположить(ПолеТабличногоДокумента.Область("R2C2"));
	ПолеТабличногоДокумента.Рисунки[Индекс].Высота = 10;
	ПолеТабличногоДокумента.Рисунки[Индекс].Ширина = 30;
	ПолеТабличногоДокумента.Рисунки[Индекс].Линия  = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
	
КонецПроцедуры // ВыборДоступногоПоля()

&НаСервере
Функция ДействиеОКСервер(Отказ)
	
	Если ПолеТабличногоДокумента.ОбластьПечати = Неопределено Тогда // шаблон не редактировался
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо установить область печати");
	Иначе 
		ПроверитьУмещение(Отказ);
		Возврат ПоместитьВоВременноеХранилище(ПодготовитьСтруктуруМакетаШаблона(), Новый УникальныйИдентификатор);
	КонецЕсли;
	
КонецФункции // ДействиеОКСервер()

// Процедура помещает в табличный документ шаблон по умолчанию.
//
&НаСервере
Процедура ПоместитьВТабличныйДокументШаблонПоУмолчанию(ИмяШаблона)
	
	ШаблонПоУмолчанию = Справочники.ХранилищеШаблонов.ПолучитьМакет(ИмяШаблона);
	
	ПолеТабличногоДокумента = ШаблонПоУмолчанию;
	
КонецПроцедуры // ПоместитьВТабличныйДокументШаблонПоУмолчанию()

