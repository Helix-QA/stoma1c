// Функция, выполняет отправку смс сообщения
//  Параметры:
//   ТекстSMS: Текст, текст отправляемого сообщения.
//   МассивНомеров: Массив, Массив номеров телефонов для отправки сообщения.
//  
Функция TurboSMS_ОтправитьSMS(СервисSMSРассылки, ТекстSMS, Получатели)  Экспорт
	
	Результат = СоздатьТаблицуРезульта(Получатели, Истина);
		
	IdСессии = "";
	РезультатАвторизации =  Auth(СервисSMSРассылки, IdСессии);
	
	Если РезультатАвторизации.Количество() = 0 Тогда 
		Для Каждого СтрокаРезультата из Результат Цикл
			СтрокаРезультата.СтатусСообщения = "Неизвестная ошибка";
		КонецЦикла;	
		Возврат Результат;
	КонецЕсли;	
	
	Если РезультатАвторизации[0] <> "Вы успешно авторизировались" Тогда 
		Для Каждого СтрокаРезультата из Результат Цикл
			СтрокаРезультата.СтатусСообщения = РезультатАвторизации[0];
		КонецЦикла;	
		Возврат Результат;
	КонецЕсли;       
	
	SendSMS(СервисSMSРассылки, IdСессии, ТекстSMS, Результат);
	
	Возврат Результат;
	
КонецФункции

// Функция, получает статус отправленного сообщения по его ID
//  Параметры:
//   МассивIDSMS: Массив, Массив ID сообщений.
//   
функция TurboSMS_ПолучитьСтатусSMS(СервисSMSРассылки, IDСообщений) Экспорт
	
	Результат = СоздатьТаблицуРезульта(IDСообщений, Ложь);
	
	IdСессии = "";
	РезультатАвторизации = Auth(СервисSMSРассылки, IdСессии);
	
	Если РезультатАвторизации.Количество() = 0 Тогда 
		Возврат Результат;
	КонецЕсли;	
	
	Если РезультатАвторизации[0] <> "Вы успешно авторизировались" Тогда 
		Возврат Результат;
	КонецЕсли;
	
	GetMessageStatus(IdСессии, Результат);
	
	Возврат Результат;
	
КонецФункции

// Функция, выполняет получение баланса
//  Параметры:
//
Функция TurboSMS_ПолучитьБаланс(СервисSMSРассылки)  
	
	IdСессии = "";
	РезультатАвторизации = Auth(СервисSMSРассылки, IdСессии);
	
	СтрВозврата = Новый Структура("Баланс, Валюта, Ошибка, ОписаниеОшибки", 0, "Руб.", Ложь, "");
	
	Если РезультатАвторизации.Количество() = 0 Тогда 
		СтрВозврата.Ошибка			 = Истина;
		СтрВозврата.ОписаниеОшибки	 = "Неизвестная ошибка";
		Возврат СтрВозврата;
	КонецЕсли;
	
	Если РезультатАвторизации[0] <> "Вы успешно авторизировались" Тогда 
		СтрВозврата.Ошибка			 = Истина;
		СтрВозврата.ОписаниеОшибки	 = РезультатАвторизации[0];
		Возврат СтрВозврата;
	КонецЕсли;
	
	Баланс = GetCreditBalance(IdСессии);
	
	Если Баланс.Количество() = 0 Тогда 
		СтрВозврата.Ошибка			 = Истина;
		СтрВозврата.ОписаниеОшибки	 = "Неизвестная ошибка";
		Возврат СтрВозврата;
	КонецЕсли;
	
	Результат = Баланс[0];
	
	БалансЧисло = 0; 
	Попытка
		БалансЧисло = Число(Результат);
	Исключение
		БалансЧисло = Результат;
	КонецПопытки;
	
	Если БалансЧисло = 0 Тогда 
		СтрВозврата.Баланс = БалансЧисло; 
	Иначе
		СтрВозврата.Баланс = БалансЧисло;
		СтрВозврата.Валюта = "ед.";
	КонецЕсли;
	
	Возврат СтрВозврата;
	
КонецФункции

// Функция, выполняет авторизацию перед выполнением действия в TurboSMS.
//
Функция Auth(СервисSMSРассылки, IdСессии)
	
	sXML = 
	"<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:tur=""http://turbosms.in.ua/api/Turbo"">
	|	<soapenv:Header/>
	|	<soapenv:Body>
	|  	 <tur:Auth>
	|  	    <!--Optional:-->
	|  	    <tur:login>"+СокрЛП(СервисSMSРассылки.Пользователь)+"</tur:login>
	|  	    <!--Optional:-->
	|  	    <tur:password>"+СокрЛП(СервисSMSРассылки.Пароль)+"</tur:password>
	|  	 </tur:Auth>
	|	</soapenv:Body>
	|</soapenv:Envelope>";

	HTTPСоединение = Новый HTTPСоединение("turbosms.in.ua");
	
	HTTPЗапрос = Новый HTTPЗапрос("/api/soap.html");
	HTTPЗапрос.УстановитьТелоИзСтроки(sXML);
	
	Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	IdСессии = Ответ.Заголовки.Получить("Set-Cookie");
	
	Возврат РазобратьОтвет(Ответ.ПолучитьТелоКакСтроку(), "<ns1:AuthResult>", "</ns1:AuthResult>");
	
КонецФункции

// Функция, возвращает баланс аккаунта.
//
Функция GetCreditBalance(IdСессии)
	
	sXML = 
	"<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:tur=""http://turbosms.in.ua/api/Turbo"">
	|<soapenv:Header/>
	|	<soapenv:Body>
	|		<tur:GetCreditBalance/>
	|	</soapenv:Body>
	|</soapenv:Envelope>";
	
	HTTPСоединение = Новый HTTPСоединение("turbosms.in.ua");
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("COOKIE", IdСессии);
	
	HTTPЗапрос = Новый HTTPЗапрос("/api/soap.html", Заголовки);
	HTTPЗапрос.УстановитьТелоИзСтроки(sXML);
	
	Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Возврат РазобратьОтвет(Ответ.ПолучитьТелоКакСтроку(), "<ns1:GetCreditBalanceResult>", "</ns1:GetCreditBalanceResult>");
	
КонецФункции

// Процедура, выполняет отправку сообщения.
//
Процедура SendSMS(СервисSMSРассылки, IdСессии, ТекстСМС, ТаблицаРезультата)
	
	HTTPСоединение = Новый HTTPСоединение("turbosms.in.ua");
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("COOKIE", IdСессии);
	
	HTTPЗапрос = Новый HTTPЗапрос("/api/soap.html", Заголовки);

	Для Каждого СтрокаРезультата из ТаблицаРезультата Цикл
		
		sXML = 
		"<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:tur=""http://turbosms.in.ua/api/Turbo"">
		|<soapenv:Header/>
		|	<soapenv:Body>
		|  	 <tur:SendSMS>
		|		<tur:sender>"+ СокрЛП(СервисSMSРассылки.Подпись) +"</tur:sender>
		|		<tur:destination>"+СокрЛП(СтрокаРезультата.НомерТелефона)+"</tur:destination>
		|		<tur:text>"+СокрЛП(ТекстСМС) +"</tur:text>
		|		<tur:wappush></tur:wappush>
		|  	 </tur:SendSMS>
		|	</soapenv:Body>
		|</soapenv:Envelope>";
		
		HTTPЗапрос.УстановитьТелоИзСтроки(sXML);
		Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		МассивПараметров = РазобратьОтвет(Ответ.ПолучитьТелоКакСтроку(), "<ns1:ResultArray>", "</ns1:ResultArray>");
		Если МассивПараметров.Количество() > 0 Тогда
			СтрокаРезультата.СтатусСообщения = МассивПараметров[0];
			Если МассивПараметров[0] = "Сообщение доставлено получателю"  Тогда
				СтрокаРезультата.СтатусДействия = 1;
			КонецЕсли;	
			
			Если МассивПараметров.Количество() > 1 Тогда
				СтрокаРезультата.IDСообщения =  МассивПараметров[1];
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры

// Процедура, выполняет получение статуса сообщения.
//
Процедура GetMessageStatus (IdСессии, ТаблицаРезультата)
	
	HTTPСоединение = Новый HTTPСоединение("turbosms.in.ua");
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("COOKIE", IdСессии);
	
	HTTPЗапрос = Новый HTTPЗапрос("/api/soap.html", Заголовки);
	
	Для Каждого СтрокаРезультата из ТаблицаРезультата Цикл
		Если СтрокаРезультата.СтатусДействия = 1 Тогда
			Продолжить;
		КонецЕсли;	
		
		sXML = 
		"<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:tur=""http://turbosms.in.ua/api/Turbo"">
		|<soapenv:Header/>
		|	<soapenv:Body>
		|  	 <tur:GetMessageStatus>
		|		<tur:MessageId>"+ СокрЛП(СтрокаРезультата.IDСообщения) +"</tur:MessageId>
		|  	 </tur:GetMessageStatus>
		|	</soapenv:Body>
		|</soapenv:Envelope>";
		
		HTTPЗапрос.УстановитьТелоИзСтроки(sXML);
		Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		МассивПараметров = РазобратьОтвет(Ответ.ПолучитьТелоКакСтроку(), "<ns1:GetMessageStatusResult>", "</ns1:GetMessageStatusResult>");
		Если МассивПараметров.Количество() > 0 Тогда
			СтрокаРезультата.СтатусСообщения = МассивПараметров[0];
			Если МассивПараметров[0] = "Сообщение доставлено получателю"  Тогда
				СтрокаРезультата.СтатусДействия = 1;
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры

// Функция, обрабатывает ответ.
//
Функция РазобратьОтвет(Стр, ЛеваяГраница, ПраваяГраница)
	
	МассивПараметров = новый Массив;
	
	ЕстьСтрока = Истина;
	ПозСледПоиск = 1;
	Пока ЕстьСтрока Цикл
		НачальнаяПозиция = СтрНайти(Стр, ЛеваяГраница,,ПозСледПоиск);
		ЕстьСтрока = НЕ НачальнаяПозиция = 0;
		Если ЕстьСтрока Тогда 
			НачальнаяПозиция = НачальнаяПозиция + СтрДлина(ЛеваяГраница);
			КонечнаяПозиция = СтрНайти(Стр, ПраваяГраница,, ПозСледПоиск);
			ПозСледПоиск  = КонечнаяПозиция + СтрДлина(ПраваяГраница);
			Результат = Сред(Стр, НачальнаяПозиция, КонечнаяПозиция - НачальнаяПозиция);
			МассивПараметров.Добавить(Результат);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивПараметров;
	
КонецФункции

