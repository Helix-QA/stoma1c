&НаСервере
// Процедура - управляет отображением элементов формы.
//
Процедура УстановитьВидимостьЭлементов()
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		
		ФИОКонтрагента = ПолучитьПолноеФИООбъекта(ЭтотОбъект);
		Элементы.ОткрытьКонтрагента.Заголовок = ?(ЗначениеЗаполнено(ФИОКонтрагента), ФИОКонтрагента, Объект.Контрагент.НаименованиеПолное);		
		
		СоответствиеЦветов  = ПолучитьСоответствиеЦветовИСтатусовКлиентов();
		СтатусПредставление = ?(ЭтотОбъект.СтатусКонтрагента = Перечисления.СтатусыКонтрагентов.Потенциальный, Нстр("ru = 'Потенциальный'; en = 'Potential'"), ЭтотОбъект.СтатусКонтрагента); 
		
		Элементы.ГруппаСтатус.ЦветФона            = СоответствиеЦветов.Получить(ЭтотОбъект.СтатусКонтрагента);	
		Элементы.ОткрытьИсториюСтатусов.Заголовок = СтатусПредставление; 
				
	КонецЕсли;	
	
	// Видимость элементов взаимодействий.
	Элементы.ГруппаSMS.Видимость = РазрешенаОтправкаSMSСообщений();
	
	Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость     = НЕ НаличиеСервисаSMSРассылки();
	Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость            = НЕ Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость;	
	
	Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость = НЕ НаличиеПочтовогоАккаунта();
	Элементы.ГруппаВзаимодействиеПисьмоОсновная.Видимость         = НЕ Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость;
	
	Если НЕ Объект.Ссылка.Пустая() И ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач Тогда 
		Элементы.ГруппаКонтактнаяИнформацияСправочникКлиенты.Видимость	= Ложь;			
	КонецЕсли;
	
	УстановитьФокусЭлементаСервер();
	
	Если ЗначениеЗаполнено(Объект.РезультатСделки) Тогда 
		Элементы.Врач.ТолькоПросмотр 			= Истина;
		Элементы.Специализация.ТолькоПросмотр 	= Истина;
		Элементы.Менеджер.ТолькоПросмотр 		= Истина;
	КонецЕсли;
	
КонецПроцедуры

