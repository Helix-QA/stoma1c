				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВложенныйЗапрос.СтруктурнаяЕдиница,
	ВложенныйЗапрос.АвторДокумента,
	ВложенныйЗапрос.ДатаНачала,
	ВложенныйЗапрос.Клиент КАК Клиент,
	ВложенныйЗапрос.Врач,
	СУММА(1) КАК Запись,
	СУММА(ВЫБОР
			КОГДА ВложенныйЗапрос.Прием ЕСТЬ NULL 
				ТОГДА 0
			ИНАЧЕ 1
		КОНЕЦ) КАК Явка
ИЗ
	(ВЫБРАТЬ
		СобытиеУслуги.Ссылка КАК ПредварительнаяЗапись,
		СобытиеУслуги.ДатаНачала КАК ДатаНачала,
		СобытиеУслуги.Сотрудник КАК Врач,
		СобытиеУслуги.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		СобытиеУслуги.Ссылка.Контрагент КАК Клиент,
		СобытиеУслуги.Ссылка.АвторДокумента КАК АвторДокумента,
		Прием.Ссылка КАК Прием
	ИЗ
		Документ.Событие.Услуги КАК СобытиеУслуги
			ЛЕВОЕ СОЕДИНЕНИЕ Документ.Прием КАК Прием
			ПО СобытиеУслуги.Ссылка = Прием.ДокументОснование
	ГДЕ
		НЕ СобытиеУслуги.Ссылка.ПометкаУдаления) КАК ВложенныйЗапрос
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL 
					И &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ВложенныйЗапрос.ДатаНачала &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL 
					И &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ВложенныйЗапрос.ДатаНачала &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}

СГРУППИРОВАТЬ ПО
	ВложенныйЗапрос.СтруктурнаяЕдиница,
	ВложенныйЗапрос.АвторДокумента,
	ВложенныйЗапрос.ДатаНачала,
	ВложенныйЗапрос.Клиент,
	ВложенныйЗапрос.Врач</query>
