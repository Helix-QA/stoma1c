// Функция получает начало периода относительно окончания периода.
//
// Параметры:
//  Дата		 - Дата	 - дата окончания
//  ВидПериода	 - ПеречислениеСсылка.ВидыПериодовМонитораРуководителя	 - вид периода.
// 
// Возвращаемое значение:
//  Дата - дата начала.
//
Функция ПолучитьНачалоПериода(Дата, НастройкаВиджета) Экспорт
	
	Результат = Дата;
	
	ВидПериода = НастройкаВиджета.Период; 
	Если ВидПериода = ПоследняяНеделя Тогда
		Результат = НачалоДня(Дата - (7 * 24 * 3600));
	ИначеЕсли ВидПериода = ПоследнийМесяц Тогда
		Результат = НачалоДня(ДобавитьМесяц(Дата, -1));
	ИначеЕсли ВидПериода = ПоследнийКвартал Тогда
		Результат = НачалоДня(ДобавитьМесяц(Дата, -3));
	ИначеЕсли ВидПериода = ПоследниеПолгода Тогда
		Результат = НачалоДня(ДобавитьМесяц(Дата, -6));
	ИначеЕсли ВидПериода = ПоследнийГод Тогда
		Результат = НачалоДня(ДобавитьМесяц(Дата, -12));
	ИначеЕсли ВидПериода = ПоследнийДень Тогда
		Результат = НачалоДня(Дата);
	ИначеЕсли ВидПериода = ПроизвольныйДень Тогда
		Результат = НачалоДня(Дата);
	ИначеЕсли ВидПериода = ПроизвольныйМесяц Тогда
		Результат = Началомесяца(Дата);
	ИначеЕсли ВидПериода = ПроизвольныйГод Тогда
		Результат = НачалоГода(Дата);
	ИначеЕсли ВидПериода = ТекущийМесяц Тогда
		Результат = НачалоМесяца(Дата);
	ИначеЕсли ВидПериода = ПроизвольныйПериод 
		И НастройкаВиджета.Свойство("ПроизвольныйПериод") Тогда
		Результат = НастройкаВиджета.ПроизвольныйПериод.ДатаНачала;
	Иначе 
		Результат = НачалоДня(Дата);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Функция получает конец периода относительно окончания периода.
//
// Параметры:
//  Дата		 - Дата	 - дата окончания
//  ВидПериода	 - ПеречислениеСсылка.ВидыПериодовМонитораРуководителя	 - вид периода.
// 
// Возвращаемое значение:
//  Дата - дата начала.
//
Функция ПолучитьКонецПериода(Дата, НастройкаВиджета) Экспорт
	
	Результат = Дата;
	
	ВидПериода = НастройкаВиджета.Период;
	Если ВидПериода = ПроизвольныйМесяц Тогда
		Результат = КонецМесяца(Дата); 
	ИначеЕсли ВидПериода = ПроизвольныйГод Тогда
		Результат = КонецГода(Дата);
	ИначеЕсли ВидПериода = ТекущийМесяц Тогда
		Результат = КонецМесяца(Дата);
	ИначеЕсли ВидПериода = ПроизвольныйПериод 
		И НастройкаВиджета.Свойство("ПроизвольныйПериод") Тогда
		Результат = НастройкаВиджета.ПроизвольныйПериод.ДатаОкончания;
	Иначе 
		Результат = КонецДня(Дата);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

