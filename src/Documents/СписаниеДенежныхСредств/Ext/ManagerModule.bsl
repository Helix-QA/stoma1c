КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаВзаиморасчетыСКонтрагентами(СтруктураДополнительныеСвойства,ДокументСсылка)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
	|	ТаблицаВзаиморасчетыСКонтрагентами.ВидДвижения КАК ВидДвижения,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ДокументОснования КАК ДокументРеализации,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ДокументАванса КАК ДокументАванса,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Период КАК Период,
	|	ТаблицаВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Контрагент КАК Контрагент,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Организация КАК Организация,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ЭтоАванс КАК ЭтоАванс,
	|	СУММА(ТаблицаВзаиморасчетыСКонтрагентами.Сумма) КАК Сумма,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Договор КАК Договор
	|ИЗ
	|	ВременнаяТаблицаВзаиморасчетыКонтрагентов КАК ТаблицаВзаиморасчетыСКонтрагентами
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаВзаиморасчетыСКонтрагентами.НомерСтроки,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ДокументОснования,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ДокументАванса,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Период,
	|	ТаблицаВзаиморасчетыСКонтрагентами.СтруктурнаяЕдиница,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Контрагент,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Организация,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ЭтоАванс,
	|	ТаблицаВзаиморасчетыСКонтрагентами.ВидДвижения,
	|	ТаблицаВзаиморасчетыСКонтрагентами.Договор
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТаблицаВзаиморасчетыСКонтрагентами.НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	
	
	// Пост обработка рез. запроса
	// Для сети стоматологий с типом единая сеть, при недостатке средств на ЛС по текущей
	// СЕ и при наличии средств по другой СЕ необходимо переместить средства на текущую СЕ.
	Если ДокументСсылка.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет 
		И ДокументСсылка.ВидОперации        = Перечисления.ВидыОпераций.ОплатаОтКлиента	
		И Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть Тогда
		
		// Получаем текущий остаток ЛС для данной СЕ
		ТекущийОстатокЛС = ДенежныеСредстваСервер.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(ДокументСсылка.Контрагент,ДокументСсылка.Дата,ДокументСсылка.Ссылка,ДокументСсылка.СтруктурнаяЕдиница,ДокументСсылка.ЛицевойСчетКонтрагента,Истина);
		Если ТекущийОстатокЛС < ДокументСсылка.СуммаДокумента Тогда
			// Получаем временную таблицу и зачищаем ее от строк сторнирования
			ВременнаяТ = РезультатЗапроса.Скопировать();
			РезультатЗапроса.Очистить();
			СчетчикТ   = 0;
			Пока СчетчикТ < ВременнаяТ.Количество() Цикл
				Если ВременнаяТ[СчетчикТ].Сумма < 0 Тогда
					ВременнаяТ.Удалить(СчетчикТ);
				Иначе
					СчетчикТ = СчетчикТ + 1;
				КонецЕсли;
			КонецЦикла;
			
			// Получаем таблицу остаток по все СЕ для данного счета
			ТаблицаОстатков = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевымСчетахКонтрагентаПоСЕ(ДокументСсылка.Контрагент,ДокументСсылка.Дата,ДокументСсылка.Ссылка,,ДокументСсылка.ЛицевойСчетКонтрагента);
			// Заполнение таблицы движений и перераспределения средств
			Для Каждого СтрокаТ ИЗ ВременнаяТ Цикл
				// Если баланс достаточен для оплаты позиции
				ОстатокПлатежа = СтрокаТ.Сумма;
				Если ТекущийОстатокЛС >0 Тогда
					// Строка сторнирования
					НоваяСтрока                    = РезультатЗапроса.Добавить();
					НоваяСтрока.ВидДвижения        = ВидДвиженияНакопления.Приход;
					НоваяСтрока.Период             = СтрокаТ.Период;
					НоваяСтрока.СтруктурнаяЕдиница = СтрокаТ.СтруктурнаяЕдиница;
					НоваяСтрока.Организация        = СтрокаТ.Организация;
					НоваяСтрока.Контрагент         = СтрокаТ.Контрагент;
					НоваяСтрока.Сумма              = ?(ТекущийОстатокЛС >= СтрокаТ.Сумма, -СтрокаТ.Сумма,-ТекущийОстатокЛС);
					// Строка оплаты
					НоваяСтрока                    = РезультатЗапроса.Добавить();
					НоваяСтрока.ВидДвижения        = ВидДвиженияНакопления.Приход;
					НоваяСтрока.Период             = СтрокаТ.Период;
					НоваяСтрока.СтруктурнаяЕдиница = СтрокаТ.СтруктурнаяЕдиница;
					НоваяСтрока.Организация        = СтрокаТ.Организация;
					НоваяСтрока.ДокументРеализации = СтрокаТ.ДокументРеализации;
					НоваяСтрока.ДокументАванса     = СтрокаТ.ДокументАванса;
					НоваяСтрока.Контрагент         = СтрокаТ.Контрагент;
					НоваяСтрока.Сумма              = ?(ТекущийОстатокЛС >= СтрокаТ.Сумма, СтрокаТ.Сумма,ТекущийОстатокЛС);
					
					ТекущийОстатокЛС               = ТекущийОстатокЛС - СтрокаТ.Сумма; 	
					ОстатокПлатежа                 = СтрокаТ.Сумма - НоваяСтрока.Сумма;
				КонецЕсли;	   
				// Если средств по текущей СЕ не хватила для оплаты перемещаем
				// имеющиеся средства на других СЕ
				Если ОстатокПлатежа > 0 Тогда
					Для Каждого СтрокаТ2 ИЗ ТаблицаОстатков Цикл
						Если СтрокаТ2.СуммаОстаток > 0 И СтрокаТ2.СтруктурнаяЕдиница <> СтрокаТ.СтруктурнаяЕдиница Тогда
							// Строка сторнирования
							НоваяСтрока                    = РезультатЗапроса.Добавить();
							НоваяСтрока.ВидДвижения        = ВидДвиженияНакопления.Приход;
							НоваяСтрока.Период             = СтрокаТ.Период;
							НоваяСтрока.СтруктурнаяЕдиница = СтрокаТ2.СтруктурнаяЕдиница;
							НоваяСтрока.Организация        = СтрокаТ2.СтруктурнаяЕдиница.Организация;
							НоваяСтрока.Контрагент         = ДокументСсылка.Контрагент;// СтрокаТ.Контрагент;
							НоваяСтрока.Сумма              = ?(СтрокаТ2.СуммаОстаток >= ОстатокПлатежа, -ОстатокПлатежа,-СтрокаТ2.СуммаОстаток);
							// Строка оплаты
							НоваяСтрока                    = РезультатЗапроса.Добавить();
							НоваяСтрока.ВидДвижения        = ВидДвиженияНакопления.Приход;
							НоваяСтрока.Период             = СтрокаТ.Период;
							НоваяСтрока.СтруктурнаяЕдиница = СтрокаТ.СтруктурнаяЕдиница;
							НоваяСтрока.Организация        = СтрокаТ.Организация;
							НоваяСтрока.ДокументРеализации = СтрокаТ.ДокументРеализации;
							НоваяСтрока.ДокументАванса     = СтрокаТ.ДокументАванса;
							НоваяСтрока.Контрагент         = СтрокаТ.Контрагент;
							НоваяСтрока.Сумма              = ?(СтрокаТ2.СуммаОстаток >= ОстатокПлатежа, ОстатокПлатежа,СтрокаТ2.СуммаОстаток);
							
							СтрокаТ2.СуммаОстаток          = СтрокаТ2.СуммаОстаток - ОстатокПлатежа; 	
							ОстатокПлатежа                 = ОстатокПлатежа - НоваяСтрока.Сумма;
							Если ОстатокПлатежа <= 0 Тогда
								Прервать;
							КонецЕсли;	   
						КонецЕсли;	   
					КонецЦикла;
				КонецЕсли; 
			КонецЦикла;
			
			РезультатЗапроса.Свернуть("ВидДвижения,Период,СтруктурнаяЕдиница,Организация,ДокументРеализации,ДокументАванса,Контрагент","Сумма");
