
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтруктураМеню = Новый Структура; 
	СтруктураМеню.Вставить("Содержание"   , "Основное");
 	СтруктураМеню.Вставить("Дополнительно", "ГруппаДополнительно");
	
	ОбработкаТабличныхЧастейКлиент.СоздатьМенюДокумента(ЭтаФорма, СтруктураМеню, "ГруппаПереключательЗакладок");
	
	// Обработчик подсистемы "Дополнительные отчеты и обработки"
	ДополнительныеОтчетыИОбработкиСтоматология.ПриСозданииНаСервере(ЭтаФорма);
	
	ЗаполнитьПараметрыБонусногоСчетаВладельца("СозданиеФормы");	
	
	УстановитьВидимость();
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
		РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);		
	КонецЕсли;
	
КонецПроцедуры // ПриСозданииНаСервере()

&НаСервере
// Процедура - обработчик события "ПослеЗаписиНаСервере".
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
КонецПроцедуры

&НаСервере
// Процедура - обработчик события "ПриЧтенииНаСервере".
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
	Иначе
		Элементы.ГруппаСостояниеОбъекта.Видимость = Ложь;	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте 
// Процедура - Перед записью.
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.СписаниеБонусныйСчет") И Объект.Сумма > ОстатокБонусногоСчета Тогда
		Объект.Сумма = ОстатокБонусногоСчета;		
		Отказ = Истина;		                 
		Предупреждение("Сумма списания превышает остаток бонусного счета");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ТумблерТипВладельцаПриИзменении".
//
Процедура ТумблерТипВладельцаПриИзменении(Элемент)

	ЗаполнитьПараметрыБонусногоСчетаВладельца("Переключатель");
	ОбновитьИнформациюПоОстаткамБС();
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ВладелецБонусногоСчетаПриИзменении".
//
Процедура ВладелецБонусногоСчетаПриИзменении(Элемент)

	ЗаполнитьПараметрыБонусногоСчетаВладельца("Владелец");
	ОбновитьИнформациюПоОстаткамБС();	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ВладелецБонусногоСчетаНачалоВыбора".
//
Процедура ВладелецБонусногоСчетаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если НЕ ТумблерТипВладельца Тогда 
		НовыйПараметр = Новый ПараметрВыбора("Отбор.ТипКонтрагента", ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Клиенты"));
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НовыйПараметр);
		НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		Элемент.ПараметрыВыбора = НовыеПараметры;
	Иначе 
		Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "БонусныйСчетПриИзменении".
//
Процедура БонусныйСчетПриИзменении(Элемент)

	ОбновитьИнформациюПоОстаткамБС();
	
КонецПроцедуры   

&НаКлиенте
// Процедура, выполняет обработку нажатия динамических кнопок.
//
Процедура ПроцедураОбработкиНажатияМеню(Элемент)
	
	ОбработкаТабличныхЧастейКлиент.ПроцедураОбработкиНажатияМеню(ЭтаФорма, Элемент.Имя);
	
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура заполняет бонусные счета контрагентов.
//
Процедура ЗаполнитьПараметрыБонусногоСчетаВладельца(Знач ПолеНаФорме = "")
	
	Если ПолеНаФорме = "Владелец" Тогда 
		
		БонусныеСчетаВладельца = Справочники.БонусныеСчета.ВернутьБонусныеСчетаВладельца(Объект.ВладелецБонусногоСчета, Объект.Дата);		
		Если БонусныеСчетаВладельца.Количество() = 1 Тогда 
			Объект.БонусныйСчет = БонусныеСчетаВладельца[0];
		КонецЕсли;
		
	ИначеЕсли ПолеНаФорме = "Переключатель" Тогда
		
		Если ТумблерТипВладельца Тогда 
			Объект.ВладелецБонусногоСчета = Справочники.Карты.ПустаяСсылка();
		Иначе 
			Объект.ВладелецБонусногоСчета = Справочники.Контрагенты.ПустаяСсылка();
		КонецЕсли;
		Объект.БонусныйСчет = Справочники.БонусныеСчета.ПустаяСсылка();
		
	ИначеЕсли ПолеНаФорме = "СозданиеФормы" Тогда 
		
		Если Объект.Проведен Тогда 
			ПереключитьТумблер(Объект.ВладелецБонусногоСчета, ТумблерТипВладельца);
		Иначе
			Если ЗначениеЗаполнено(Объект.ВладелецБонусногоСчета) Тогда
				ПереключитьТумблер(Объект.ВладелецБонусногоСчета, ТумблерТипВладельца);
				Если Объект.Ссылка.Пустая() Тогда
					ЗаполнитьПараметрыБонусногоСчетаВладельца("Владелец");
				Иначе 
					БонусныеСчетаВладельца = Справочники.БонусныеСчета.ВернутьБонусныеСчетаВладельца(Объект.ВладелецБонусногоСчета, Объект.Дата);
					Если ЗначениеЗаполнено(Объект.БонусныйСчет) Тогда 
						Если БонусныеСчетаВладельца.Найти(Объект.БонусныйСчет) = Неопределено Тогда
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru= 'На текущую дату документа бонусный счет клиента уже не актуален!';en ='As of the current date of the document, the client’s bonus account is no longer relevant!'"), Объект.Ссылка, "Объект.БонусныйСчет"); 
						КонецЕсли;	
					КонецЕсли;
				КонецЕсли;	
			Иначе 
				ЗаполнитьПараметрыБонусногоСчетаВладельца("Переключатель");				
			КонецЕсли;	
		КонецЕсли;
		
	КонецЕсли;		
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура осуществляет управление тумблером.
//
Процедура ПереключитьТумблер(Знач ВладелецБонусногоСчета, ТумблерТипВладельца)

	Если ТипЗнч(ВладелецБонусногоСчета) = Тип("СправочникСсылка.Контрагенты") Тогда 
		ТумблерТипВладельца = Ложь;
	ИначеЕсли ТипЗнч(ВладелецБонусногоСчета) = Тип("СправочникСсылка.Карты") Тогда 
		ТумблерТипВладельца = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура обновляет информацию по остаткам на бонусном счете клиента. 
//
Процедура ОбновитьИнформациюПоОстаткамБС()	
	
	ДатаОстатков = ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Дата, ТекущаяДатаСеанса());
	ОстатокБонусногоСчета = РегистрыНакопления.БонусныеСчета.ПолучитьОстатокНаБонусномСчетеВладельца(Объект.БонусныйСчет, ДатаОстатков);	
	// Декорация остатка бонусного счета
	Элементы.ДекорацияОстаткиНаБонусномСчете.Заголовок	= Формат(ОстатокБонусногоСчета, "ЧЦ=15; ЧДЦ=2; ЧН=")
															+ " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
	Элементы.ДекорацияОстаткиНаБонусномСчете.ЦветТекста = ?(ОстатокБонусногоСчета < 0, WebЦвета.Красный, ЦветаСтиля.ПоясняющийТекст);
	
КонецПроцедуры

&НаСервере
// Процедура - устанавливает видимость реквизитов в зависимости от вида операции.
//
Процедура УстановитьВидимость()
	
	Элементы.Шапка.ТолькоПросмотр		= Объект.Проведен; 
	Элементы.Основное.ТолькоПросмотр 	= Объект.Проведен;
	
	ЭтаФорма.Заголовок = "";
	// Установка первой части заголовка по типу операции
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.НачислениеБонусныйСчет Тогда
		ЭтаФорма.Заголовок = НСтр("ru= 'Взнос на бонусный счет';en ='Bonus account contribution'");
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.СписаниеБонусныйСчет Тогда
		ЭтаФорма.Заголовок = НСтр("ru= 'Списание с бонусного счета';en ='Withdrawal from the bonus account'");
	Иначе
		ЭтаФорма.Заголовок = НСтр("ru= 'Операция по бонусному счету';en ='Bonus account operation'");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + НСтр("ru= ' (создание)';en =' (creation)'");
	Иначе 
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " №" + Объект.Номер + НСтр("ru= ' от ';en =' from '") + Формат(Объект.Дата, "ДЛФ=DDT");
	КонецЕсли;
	
	Если ТумблерТипВладельца Тогда 
		Элементы.ВладелецБонусногоСчета.ПодсказкаВвода = НСтр("ru= 'Карта';en ='Card'");
	Иначе 
		Элементы.ВладелецБонусногоСчета.ПодсказкаВвода = НСтр("ru= 'Пациент';en ='Client'");
	КонецЕсли;	
	
	Элементы.Основание.Видимость = ЗначениеЗаполнено(Объект.Основание);
	
	ОбновитьИнформациюПоОстаткамБС();
		
КонецПроцедуры 


#КонецОбласти
