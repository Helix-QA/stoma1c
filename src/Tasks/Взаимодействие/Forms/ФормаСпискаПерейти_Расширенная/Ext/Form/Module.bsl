&НаКлиенте
// Процедура - Добавить БП
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Добавить_БП(Команда)
	
	Если ТипЗнч(ОбъектКлюч) = Тип("СправочникСсылка.Контрагенты") Тогда
		Если ЭтоВерсияКОРП Тогда 
			СписокСоздаваемыхБП = Новый СписокЗначений;
			//СписокСоздаваемыхБП.Добавить(Тип("БизнесПроцессСсылка.ПродажаЧленства_КОРП")			, Нстр("ru = 'Продажа членства, пакета услуг'; en = 'Sale of a membership, package of services'"), , БиблиотекаКартинок.БизнесПроцесс);
			// СписокСоздаваемыхБП.Добавить(Тип("БизнесПроцессСсылка.ПродажаДополнительныхУслуг_КОРП")	, "Продажа дополнительной услуги", , БиблиотекаКартинок.БизнесПроцесс);
			ОписаниеОповещения = Новый ОписаниеОповещения("ВыборБП", ЭтотОбъект);
			ЭтаФорма.ПоказатьВыборИзМеню(ОписаниеОповещения, СписокСоздаваемыхБП, Элементы.КнопкаДобавитьБП);
		Иначе	
			ПараметрПредмет = Новый Структура("ЗадачаПредмет", ОбъектКлюч);	 	 
			ОткрытьФорму("Задача.ЗадачаИсполнителя.ФормаОбъекта", Новый Структура("ЗначенияЗаполнения", ПараметрПредмет), ЭтаФорма);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
