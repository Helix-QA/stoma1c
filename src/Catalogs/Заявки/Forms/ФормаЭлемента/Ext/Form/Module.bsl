// Процедура - Установить состояние элементов формы статусы заявок.
//
Процедура УстановитьСостояниеЭлементовФормыСтатусыЗаявки()
	
	// Установить значение статуса Заявки.
	Если ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.НеОбработана") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено);
		Элементы.ГруппаСтатусНеОбработана.ЦветФона	 = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		Элементы.СтатусНеОбработана.ЦветТекста		 = Новый Цвет(255, 255, 255);
		
	ИначеЕсли ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ПропущенныйЗвонок") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено);
		Элементы.ГруппаСтатусПропущенныйЗвонок.ЦветФона = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		
	ИначеЕсли ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОтвеченныйЗвонок") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено);
		Элементы.ГруппаСтатусОтвеченныйЗвонок.ЦветФона = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		
	ИначеЕсли ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОтвеченныйДиалог") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено);
		Элементы.ГруппаСтатусОтвеченныйДиалог.ЦветФона = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		
	ИначеЕсли ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Перезвонить") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено);
		Элементы.ГруппаСтатусПерезвонить.ЦветФона = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		
	ИначеЕсли ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отклонена") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено, Истина);
		Элементы.ГруппаСтатусНекачественная.ЦветФона = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		Элементы.СтатусНекачественная.ЦветТекста	 = Новый Цвет(255, 255, 255);
		
		Элементы.СтатусНеОбработана.Доступность		 = Ложь;
		Элементы.СтатусПропущенныйЗвонок.Доступность = Ложь;
		Элементы.СтатусОтвеченныйЗвонок.Доступность	 = Ложь;
		Элементы.СтатусОтвеченныйДиалог.Доступность	 = Ложь;
		Элементы.СтатусПерезвонить.Доступность		 = Ложь;
		
	ИначеЕсли ЭтотОбъект.СтатусЗаявки = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Принята") Тогда
		
		УстановитьСостояниеЭлементаФормыСтатусЗаявки(Неопределено);
		Элементы.ГруппаСтатусОбработана.ЦветФона = ПолучитьЦветСтатусаЗаявки(ЭтотОбъект.СтатусЗаявки);
		
		Элементы.СтатусНеОбработана.Доступность		 = Ложь;
		Элементы.СтатусПропущенныйЗвонок.Доступность = Ложь;
		Элементы.СтатусОтвеченныйЗвонок.Доступность	 = Ложь;
		Элементы.СтатусОтвеченныйДиалог.Доступность	 = Ложь;
		Элементы.СтатусПерезвонить.Доступность		 = Ложь;
		
	КонецЕсли;

КонецПроцедуры

