	Если МассивПодстрок.Количество() > 1 Тогда
		ОбщегоНазначенияКлиент.УстановитьТекстВБуферОбмена(ЭтотОбъект[МассивПодстрок[1]]);
		ПоказатьОповещениеПользователя("Текст скопирован в буфер обмена.");		
	КонецЕсли;
	
