// Функция - Получить массив меток
//
// Параметры:
//  Событие	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМассивМеток(Событие)

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Метки.Ссылка КАК Метка,
	|	Метки.ЦветМетки КАК ЦветМетки,
	|	НЕ КлиентскиеМеткиСрезПоследних.Клиент ЕСТЬ NULL КАК ВыбраннаяМетка,
	|	Метки.Наименование КАК МеткаПредставление
	|ПОМЕСТИТЬ ВТМетки
	|ИЗ
	|	Справочник.Метки КАК Метки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиКлиентов.СрезПоследних(
	|				&ТекущаяДата,
	|				Клиент = &Событие
	|					И Активна = ИСТИНА) КАК КлиентскиеМеткиСрезПоследних
	|		ПО Метки.Ссылка = КлиентскиеМеткиСрезПоследних.Метка
	|ГДЕ
	|	НЕ Метки.ПометкаУдаления
	|	И Метки.ИспользоватьДляПредварительнойЗаписи
	|
	|СГРУППИРОВАТЬ ПО
	|	Метки.Ссылка,
	|	НЕ КлиентскиеМеткиСрезПоследних.Клиент ЕСТЬ NULL,
	|	Метки.ЦветМетки,
	|	Метки.Наименование
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	МеткиКлиентов.Метка.Ссылка,
	|	МеткиКлиентов.Метка.ЦветМетки,
	|	ИСТИНА,
	|	МеткиКлиентов.Метка.Наименование
	|ИЗ
	|	РегистрСведений.МеткиКлиентов.СрезПоследних(
	|			&ТекущаяДата,
	|			Клиент В
	|					(ВЫБРАТЬ
	|						Событие.Контрагент
	|					ИЗ
	|						Документ.Событие КАК Событие
	|					ГДЕ
	|						Событие.Ссылка = &Событие)
	|				И Активна = ИСТИНА) КАК МеткиКлиентов
	|ГДЕ
	|	НЕ МеткиКлиентов.Метка.ПометкаУдаления
	|	И МеткиКлиентов.Метка.ИспользоватьДляПациентов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТМетки.Метка КАК Метка,
	|	ВТМетки.ЦветМетки КАК ЦветМетки,
	|	МАКСИМУМ(ВТМетки.ВыбраннаяМетка) КАК ВыбраннаяМетка,
	|	ВТМетки.МеткаПредставление КАК МеткаПредставление
	|ИЗ
	|	ВТМетки КАК ВТМетки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТМетки.МеткаПредставление,
	|	ВТМетки.ЦветМетки,
	|	ВТМетки.Метка
	|
	|УПОРЯДОЧИТЬ ПО
	|	МеткаПредставление");
	
	Запрос.УстановитьПараметр("Событие"		, Событие);
	Запрос.УстановитьПараметр("ТекущаяДата"	, ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	МассивМеток = Новый Массив;
	Пока Выборка.Следующий() Цикл
		
		СтруктураМетки = Новый Структура();
		СтруктураМетки.Вставить("УИДМетки"			, УникальныйИдентификатор(Выборка.Метка));
		СтруктураМетки.Вставить("МеткаПредставление", Выборка.МеткаПредставление);
		СтруктураМетки.Вставить("ВыбраннаяМетка"	, Выборка.ВыбраннаяМетка);
		СтруктураМетки.Вставить("ЦветМетки"			, ПолучитьRGBЦвет(ЗначениеИзСтрокиВнутр(Выборка.ЦветМетки),,, Истина));
		
		МассивМеток.Добавить(СтруктураМетки);
		
	КонецЦикла;
	
	Возврат МассивМеток;
	
КонецФункции

