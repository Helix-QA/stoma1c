// Процедура - Статус обработана.
//
// Параметры:
//  Команда	 - 	 -
//
Процедура СтатусОбработана(Команда)
	
	УстановитьФокусЭлемента();
	
	Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Принята") Тогда
		
		ВидыСделокСписок = ПолучитьВидыСделок(, Объект.СтруктурнаяЕдиница);
		СписокВыбора 	 = Новый СписокЗначений();
		
		СписокВыбора.Добавить("НазначитьПрием", НСтр("ru = 'Записать на прием'"));
		СписокВыбора.Добавить("СоздатьКлиента", НСтр("ru = 'Записать на прием позже'"));
		
		Для каждого ЭлементСписка Из ВидыСделокСписок Цикл
			СписокВыбора.Добавить(ЭлементСписка.Значение, НСтр("ru = 'Записать на прием + '; en = 'Make an appointment + '") + ЭлементСписка.Представление); 
		КонецЦикла;
			
		СписокВыбора.Добавить("ВыбратьСуществующего", НСтр("ru = 'Существующий пациент'"));
		
		Оповещение = Новый ОписаниеОповещения("СтатусОбработанЗавершение", ЭтотОбъект);
		ПоказатьВыборИзМеню(Оповещение, СписокВыбора, Элементы.СтатусОбработана);
		
	КонецЕсли;

КонецПроцедуры

