		// КонецЕсли; 
		
		// ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".PACIENT.@NOVOR", Пациент.ПризнакНоворожденного);
		ДобавитьВМассив(ДанныеЗаполнения_, ЭлементЗаписи + ".PACIENT.@NOVOR", Ложь);
		// КонецЕсли; 
