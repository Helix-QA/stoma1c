// Функция - Вернуть последнее указанное время
// 
// Параметры:
//  ИндексСтроки - 	 - 
//  Шаг			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ВернутьПоследнееУказанноеВремя(Знач СтруктураДанныеЭлемента, Знач Шаг)
	
	Если СтруктураДанныеЭлемента.ЭтоНачалоИнтервала ИЛИ ОтборИнтервалыРаботы[СтруктураДанныеЭлемента.ИндексСтроки].Значение.НачалоРаботы = Неопределено Тогда 
		ИндексСтроки 		= СтруктураДанныеЭлемента.ИндексСтроки - 1;
	Иначе  
		ИндексСтроки 		= СтруктураДанныеЭлемента.ИндексСтроки;
	КонецЕсли;	
	ПоследнееУказанноеВремя = Неопределено;
	
	Пока ИндексСтроки >= 0 Цикл
		Если СтруктураДанныеЭлемента.ЭтоНачалоИнтервала Тогда
			Если НЕ ОтборИнтервалыРаботы[ИндексСтроки].Значение.ОкончаниеРаботы = Неопределено Тогда 
				ПоследнееУказанноеВремя = ОтборИнтервалыРаботы[ИндексСтроки].Значение.ОкончаниеРаботы;
				Прервать;
			ИначеЕсли НЕ ОтборИнтервалыРаботы[ИндексСтроки].Значение.НачалоРаботы = Неопределено Тогда	
				ПоследнееУказанноеВремя = ОтборИнтервалыРаботы[ИндексСтроки].Значение.НачалоРаботы;
				Прервать;
			КонецЕсли;
		Иначе
			Если ИндексСтроки = СтруктураДанныеЭлемента.ИндексСтроки И НЕ ОтборИнтервалыРаботы[ИндексСтроки].Значение.НачалоРаботы = Неопределено Тогда 
				ПоследнееУказанноеВремя = ОтборИнтервалыРаботы[ИндексСтроки].Значение.НачалоРаботы;
				Прервать;
			Иначе 	
				Если НЕ ОтборИнтервалыРаботы[ИндексСтроки].Значение.ОкончаниеРаботы = Неопределено Тогда	
					ПоследнееУказанноеВремя = ОтборИнтервалыРаботы[ИндексСтроки].Значение.ОкончаниеРаботы;
					Прервать;
				ИначеЕсли НЕ ОтборИнтервалыРаботы[ИндексСтроки].Значение.НачалоРаботы = Неопределено Тогда	
					ПоследнееУказанноеВремя = ОтборИнтервалыРаботы[ИндексСтроки].Значение.НачалоРаботы;
					Прервать;
				КонецЕсли;	
			КонецЕсли;	
		КонецЕсли;
		ИндексСтроки = ИндексСтроки - 1;		
	КонецЦикла;	
	
	Если НЕ ПоследнееУказанноеВремя = Неопределено Тогда 
		ПоследнееУказанноеВремя = ПоследнееУказанноеВремя + Шаг*60;
	КонецЕсли;	
		
	Возврат ПоследнееУказанноеВремя;	
	
КонецФункции

&НаКлиенте
// Процедура - Обновить общее время интервалов
// 
Процедура ОбновитьОбщееВремяИнтервалов()
	
	СуммаМинут 		= 0;
	Для Каждого Интервал Из ОтборИнтервалыРаботы Цикл 
		Если НЕ Интервал.Значение.НачалоРаботы = Неопределено И НЕ Интервал.Значение.ОкончаниеРаботы = Неопределено Тогда 
			КоличествоМинут = Цел((Интервал.Значение.ОкончаниеРаботы - Интервал.Значение.НачалоРаботы) / 60);
		Иначе 
			КоличествоМинут = 0;
		КонецЕсли;
		СуммаМинут = СуммаМинут + КоличествоМинут;	
	КонецЦикла;
	
	Если СуммаМинут = 0 Тогда 
		Элементы.ПоказатьСписокШаблонов.Заголовок = "Смены";
	Иначе 
		Часы  = Цел(СуммаМинут / 60);
		Минут = СуммаМинут - (Часы * 60);		
		Элементы.ПоказатьСписокШаблонов.Заголовок = "Смены (" +  ?(Часы > 0 ,"" + Часы + " ч.","") + ?(Минут > 0 ,"" + Минут + " м.","") + ")";
	КонецЕсли;
	
КонецПроцедуры

