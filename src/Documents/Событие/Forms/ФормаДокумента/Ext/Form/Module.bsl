// Процедура - Напомнить пациенту о будущих событиях.
//
Процедура НапомнитьПациентуОБудущихСобытиях(Команда)
	
	ПредставлениеСобытий = "";
	ЗапланированноеСобытие = Неопределено;
	Для Каждого БудущееСобытие Из ЭтаФорма.БудущиеСобытия Цикл
		ПредставлениеСобытий = ПредставлениеСобытий + Символы.ПС + Формат(БудущееСобытие.ДатаСобытия, "ДФ='дд ММММ ЧЧ:мм'") + ", врач " + БудущееСобытие.Сотрудник; 
		Если ЭтаФорма.БудущиеСобытия.Количество() = 1 Тогда
			ЗапланированноеСобытие = БудущееСобытие.Событие; 
		КонецЕсли;
	КонецЦикла;
	
	ПредставлениеКлиента = ПолучитьПредставлениеПациентаДляНапоминанияОБудущихСобытиях(Объект.Контрагент);	
	ТекстСообщения = ПредставлениеКлиента + ", ждем Вас!" + Символы.ПС + ПредставлениеСобытий;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Контрагент", Объект.Контрагент);
	ПараметрыОткрытия.Вставить("МессенджерВключен", ЭтотОбъект.ИспользуетсяРасширениеМессенджер);
	ПараметрыОткрытия.Вставить("ТекстСообщенияSms", ТекстСообщения);   
	ПараметрыОткрытия.Вставить("ДокументОснование", ЗапланированноеСобытие);
		
	ОткрытьФорму("Документ.ЭлектронноеПисьмоИсходящее.Форма.ФормаОтправкиСообщения", ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

