// Функция, проверяет отключены ли все фильтры.
//
Функция ВсеФильтрыОтключены(Фильтры)
	
	Для Каждого Фильтр Из Фильтры Цикл
		Если Фильтр.Значение = Истина Тогда
			Возврат Ложь;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Функция, возвращает цвет, соответствующий статусу заявки.
//
Функция ПолучитьЦветСтатусаЗаявки(Статус) Экспорт
	
	Если Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.НеОбработана") Тогда
		Цвет = Новый Цвет(0, 185, 97);
		
	ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ПропущенныйЗвонок") Тогда
		Цвет = Новый Цвет(253, 176, 81);
		
	ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОтвеченныйЗвонок") Тогда
		Цвет = Новый Цвет(163, 212, 155);
		
	ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОтвеченныйДиалог") Тогда
		Цвет = Новый Цвет(163, 212, 155);
		
	ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Перезвонить") Тогда
		Цвет = Новый Цвет(255, 238, 149);
		
	ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Принята") Тогда
		Цвет = Новый Цвет(47, 182, 68);
		
	ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отклонена") Тогда
		Цвет = Новый Цвет(241, 23, 22);
		
	Иначе
		Цвет = Новый Цвет(242, 242, 242);
		
	КонецЕсли;
	
	Возврат Цвет;
	
КонецФункции

