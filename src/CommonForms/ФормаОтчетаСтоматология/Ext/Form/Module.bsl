// Функция - Отправить по электронной почте клиентам из отчета на сервере
// 
// Возвращаемое значение:
//   - 
//
&НаСервере
Функция ОтправитьПоЭлектроннойПочтеКлиентамИзОтчетаНаСервере()
	
	ДоступныеУчетныеЗаписи = ПолучитьСписокДоступныхУчетныхЗаписей();
	
	Если ДоступныеУчетныеЗаписи.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Для текущего пользователя не задана учетная запись электронной почты';en='For current user not set accounting record email of mail'"));
		Отказ = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	УчетнаяЗапись = ДоступныеУчетныеЗаписи[0].Ссылка;
		
	ИсходящееЭлектронноеПисьмо                = Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
	ИсходящееЭлектронноеПисьмо.Автор 		  = ПараметрыСеанса.ТекущийПользователь;
	ИсходящееЭлектронноеПисьмо.Важность       = Перечисления.ВариантыВажностиЗадачи.Обычная;
	ИсходящееЭлектронноеПисьмо.Дата           = ТекущаяДатаСеанса();
	ИсходящееЭлектронноеПисьмо.ЕстьВложения   = Ложь;
	ИсходящееЭлектронноеПисьмо.Кодировка      = "utf-8";
	
	ИсходящееЭлектронноеПисьмо.УчетнаяЗапись = УчетнаяЗапись;
	ИсходящееЭлектронноеПисьмо.Тема          = "Рассылка";
	ИсходящееЭлектронноеПисьмо.ТипТекста     = Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст;
	ИсходящееЭлектронноеПисьмо.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ИсходящееЭлектронноеПисьмо.Ответственный = ПараметрыСеанса.ТекущийПользователь;
	ИсходящееЭлектронноеПисьмо.ОтправительПредставление = ?(ЗначениеЗаполнено(УчетнаяЗапись.ИмяПользователя), УчетнаяЗапись.ИмяПользователя + " <" + УчетнаяЗапись.АдресЭлектроннойПочты + ">", УчетнаяЗапись.АдресЭлектроннойПочты);
	
	МассивКонтрагентов = ПолучитьМассивКонтрагентовИзРезультата();
	
	Если МассивКонтрагентов.Количество() > 0 Тогда
				
		Для Каждого ЭлементМассива Из МассивКонтрагентов Цикл
			
			EmailКонтрагента = ПолучитьEmailКонтрагента(ЭлементМассива);
			Для Каждого Email Из EmailКонтрагента Цикл 
				
				НоваяСтрока = ИсходящееЭлектронноеПисьмо.ПолучателиПисьма.Добавить();

				НоваяСтрока.Контакт       = ЭлементМассива;
				НоваяСтрока.Адрес         = Email;
				НоваяСтрока.Представление = Строка(ЭлементМассива);
				ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма = ИсходящееЭлектронноеПисьмо.СписокПолучателейПисьма + "," + ЭлементМассива + " <" + Email + "> ";
	
			КонецЦикла;
			
		КонецЦикла;
		ИсходящееЭлектронноеПисьмо.Записать();
		ПараметрыОткрытия = Новый Структура("Ключ", ИсходящееЭлектронноеПисьмо.Ссылка);
		
	КонецЕсли;

	Возврат ПараметрыОткрытия;
	
КонецФункции

