#Область ФункцииИПроцедурыПодбора

&НаКлиенте
// Процедура, обработчик события "Выбор"
// 
Процедура Подключаемый_ПодборТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтрокаПодбора = Элементы._ПодборНоменклатур.ТекущиеДанные;
	Если Не СтрокаПодбора = Неопределено и Не СтрокаПодбора.ЭтоГруппа Тогда					
		
		СтандартнаяОбработка = Ложь;
		Номенклатура = СтрокаПодбора.Номенклатура; 		
		МассивПартий = Новый Массив;		
		МассивПартий.Добавить(ПредопределенноеЗначение("Справочник.ПартииНоменклатуры.ПустаяСсылка"));		
		
		Если СтрокаПодбора.ИспользоватьПартии Тогда			
			
			СтруктураВыбора = Новый Структура;		
			СтруктураВыбора.Вставить("Номенклатура"        , Номенклатура);
			СтруктураВыбора.Вставить("СтруктурнаяЕдиница"  , Объект.СтруктурнаяЕдиница);
            СтруктураВыбора.Вставить("Склад"               , Объект.Склад);
            СтруктураВыбора.Вставить("Дата"                , Объект.Дата);
			СтруктураВыбора.Вставить("МножественныйВыбор"  , Истина);
            СтруктураВыбора.Вставить("ОтборРежимОтбора"    , 0);
			
			ОткрытьФорму("Справочник.ПартииНоменклатуры.ФормаВыбора", СтруктураВыбора,,,,, Новый ОписаниеОповещения("Подключаемый_ПодборНоменклатураВыборЗавершение", ЭтотОбъект, Новый Структура("МассивПартий, Номенклатура", МассивПартий, Номенклатура)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			Возврат;	
			
		КонецЕсли;
		Подключаемый_ПодборНоменклатураВыборОбработка(МассивПартий, Номенклатура);
		
	КонецЕсли;	 
	
КонецПроцедуры 

