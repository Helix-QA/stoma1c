Функция СписокПациентов(Телефон)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 	
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Контрагент
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
		|	И КонтрагентыКонтактнаяИнформация.НомерТелефона = &Телефон
		|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления"; 
	
	Запрос.УстановитьПараметр("Телефон", Телефон);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Контрагент");

КонецФункции
		
// Функция - проверяет есть ли у пациента прием
// 
Функция ПриемСуществует(Пациент)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Прием.Ссылка КАК Ссылка,
		|	Прием.Контрагент КАК Контрагент
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Контрагент = &Контрагент";
	
	Запрос.УстановитьПараметр("Контрагент", Пациент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ?(РезультатЗапроса.Пустой(), Ложь, Истина);
	
КонецФункции

// Функция - Добавить обновить звонок в историю
// 
// Параметры:
//  НомерТелефонаИз	 - 	 - 
//  НомерТелефонаВ	 - 	 - 
//  ПризнакИсходящийЗвонок	 - 	 - 
//  Продолжительность		 - 	 - 
//  СсылкаНаЗаписьЗвонка	 - 	 - 
//  Статус					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ДобавитьПопыткуПолучениеФайла(ПОIPТелефонии, IDЗвонка)
	
	НаборЗаписей = РегистрыСведений.ИсторияВызовов.СоздатьНаборЗаписей(); 
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Значение 		= ПОIPТелефонии;
	НаборЗаписей.Отбор.ОборудованиеТелефонии.Использование 	= Истина;
	НаборЗаписей.Отбор.IDЗвонка.Значение 					= IDЗвонка;
	НаборЗаписей.Отбор.IDЗвонка.Использование 				= Истина;
	
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда
		Запись = НаборЗаписей[0];
		Запись.ПопытокПолученияФайлаЗаписи = Запись.ПопытокПолученияФайлаЗаписи + 1;
		НаборЗаписей.Записать(Истина);
	КонецЕсли;
	
КонецФункции

// Функция - Получить контрагента по номеру телефона
// 
// Параметры:
//  НомерТелефона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьКонтрагентаСотрудникаПоНомеруТелефона(НомерТелефона, СписокНомеровТелефонов = Неопределено) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(НомерТелефона) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СписокНомеровТелефонов) Тогда
		Получили_XDTO = Ложь;
		НомерТелефонаТолькоЦифры = СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(НомерТелефона));
		
		СписокНомеровТелефонов = Новый СписокЗначений;	
		СписокНомеровТелефонов.Добавить(НомерТелефона);
		СписокНомеровТелефонов.Добавить(?(Лев(НомерТелефонаТолькоЦифры, 1) = "8", "7" + Сред(НомерТелефонаТолькоЦифры, 2), НомерТелефонаТолькоЦифры));
		СписокНомеровТелефонов.Добавить(?(Лев(НомерТелефонаТолькоЦифры, 1) = "7", "8" + Сред(НомерТелефонаТолькоЦифры, 2), НомерТелефонаТолькоЦифры));
		
		Если ЗначениеЗаполнено(НомерТелефонаТолькоЦифры) И СтрДлина(СокрЛП(НомерТелефонаТолькоЦифры)) > 4 Тогда 
			СписокНомеровТелефонов.Добавить(НомерТелефонаТолькоЦифры);		
			Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(СокрЛП(НомерТелефонаТолькоЦифры), Перечисления.ТипыКонтактнойИнформации.Телефон);
			Если НЕ Объект_XDTO_Телефон = Неопределено Тогда
				Получили_XDTO = Истина;				
				СписокНомеровТелефонов.Добавить(			Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокНомеровТелефонов.Добавить("8" 	+ 	Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокНомеровТелефонов.Добавить("7" 	+ 	Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокНомеровТелефонов.Добавить("+7" 	+ 	Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
				СписокНомеровТелефонов.Добавить(			Объект_XDTO_Телефон.Представление, , Истина);
				СписокНомеровТелефонов.Добавить(Объект_XDTO_Телефон.Состав.КодСтраны + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			КонецЕсли;	
		КонецЕсли;
		Если НЕ Получили_XDTO Тогда  
			ЭлементСписка = СписокНомеровТелефонов.НайтиПоЗначению(НомерТелефона);
			Если НЕ ЭлементСписка = Неопределено Тогда 
				ЭлементСписка.Пометка = Истина;
			КонецЕсли;
		КонецЕсли;			
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивНомеровТелефонов", СписокНомеровТелефонов.ВыгрузитьЗначения());
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	               |	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	               |ГДЕ
	               |	КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
	               |	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	               |	И КонтрагентыКонтактнаяИнформация.НомерТелефона В(&МассивНомеровТелефонов)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	СотрудникиКонтактнаяИнформация.Ссылка
	               |ИЗ
	               |	Справочник.Сотрудники.КонтактнаяИнформация КАК СотрудникиКонтактнаяИнформация
	               |ГДЕ
	               |	СотрудникиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПользователя)
	               |	И СотрудникиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	               |	И СотрудникиКонтактнаяИнформация.НомерТелефона В(&МассивНомеровТелефонов)";
				   
	РезультатПоКонтрагентам = Запрос.Выполнить().Выбрать();
	
	Возврат ?(РезультатПоКонтрагентам.Следующий(), РезультатПоКонтрагентам.Ссылка, Справочники.Контрагенты.ПустаяСсылка());
	
КонецФункции

// Функция - Получить список номеров телефонов BINOTEL
// 
// Параметры:
//  НомерТелефона	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСписокНомеровТелефоновBINOTEL(НомерТелефона) Экспорт 
	
	Получили_XDTO = Ложь;				
	СписокНомеровТелефонов = Новый СписокЗначений;	
	СписокНомеровТелефонов.Добавить(НомерТелефона);
	НомерТелефонаТолькоЦифры = СокрЛП(УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(НомерТелефона));
	Если ЗначениеЗаполнено(НомерТелефонаТолькоЦифры) И СтрДлина(СокрЛП(НомерТелефонаТолькоЦифры)) > 4 Тогда 
		СписокНомеровТелефонов.Добавить(НомерТелефонаТолькоЦифры);		
		Объект_XDTO_Телефон = ПолучитьСтруктуру_XDTO(СокрЛП(НомерТелефонаТолькоЦифры), Перечисления.ТипыКонтактнойИнформации.Телефон);
		Если НЕ Объект_XDTO_Телефон = Неопределено Тогда
			Получили_XDTO = Истина;				
			СписокНомеровТелефонов.Добавить(			Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			СписокНомеровТелефонов.Добавить("38" 	+ 	Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			СписокНомеровТелефонов.Добавить("+38" 	+ 	Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
			СписокНомеровТелефонов.Добавить(			Объект_XDTO_Телефон.Представление, , Истина);
			СписокНомеровТелефонов.Добавить(Объект_XDTO_Телефон.Состав.КодСтраны + Объект_XDTO_Телефон.Состав.КодГорода + Объект_XDTO_Телефон.Состав.Номер);
		КонецЕсли;	
	КонецЕсли;
	Если НЕ Получили_XDTO Тогда  
		ЭлементСписка = СписокНомеровТелефонов.НайтиПоЗначению(НомерТелефона);
		Если НЕ ЭлементСписка = Неопределено Тогда 
			ЭлементСписка.Пометка = Истина;
		КонецЕсли;
	КонецЕсли;			
	
	Возврат СписокНомеровТелефонов;
	
КонецФункции

// Функция - Получить создать рекламный источник
//
// Параметры:
//  Наименование - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСоздатьРекламныйИсточник(Наименование)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Наименование", Наименование);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	РекламныеИсточники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.РекламныеИсточники КАК РекламныеИсточники
		|ГДЕ
		|	РекламныеИсточники.Наименование = &Наименование";
		
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() Тогда
			Возврат Результат.Ссылка;
		Иначе
			РекламныйИсточникОбъект = Справочники.РекламныеИсточники.СоздатьЭлемент();
			РекламныйИсточникОбъект.Наименование = Наименование;
			РекламныйИсточникОбъект.Записать();
			Возврат РекламныйИсточникОбъект.Ссылка;
		КонецЕсли;
		
	Исключение
		
		Возврат Неопределено;
		
	КонецПопытки;
	
КонецФункции

// Функция - Получить внутреннего менеджера
// 
// Параметры:
//  ВнешнийНомерТелефона - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьЛичногоМенеджераДляПереадресации(ВнешнийНомерТелефона, ОписаниеОшибки = "") Экспорт
		
	Контрагент = ПолучитьКонтрагентаСотрудникаПоНомеруТелефона(ВнешнийНомерТелефона);
	Если Не ЗначениеЗаполнено(Контрагент) Тогда
		ОписаниеОшибки = "Contractor is not found";
		Возврат Ложь;
	ИначеЕсли Не ЗначениеЗаполнено(Контрагент.Менеджер) Тогда
		ОписаниеОшибки = "Contractor has no responsible manager";
		Возврат Ложь;
	КонецЕсли;
	
	МассивТелефонныхАппаратовСотрудника = ПолучитьСтруктуруВнутреннегоНомераПоПользователю(Контрагент.Менеджер);
	Если МассивТелефонныхАппаратовСотрудника.Количество() = 0 Тогда
		ОписаниеОшибки = "Manager is offline";
		Возврат Ложь;
	ИначеЕсли Не ЗначениеЗаполнено(МассивТелефонныхАппаратовСотрудника[0].НомерТелефона) Тогда
		ОписаниеОшибки = "Number is not registred";
		Возврат Ложь;		
	КонецЕсли;
	
	Результат = Новый Структура("InternalNumberGroup, FIO, ID, Оборудование", "", "", "");
	Результат.InternalNumberGroup = Строка(МассивТелефонныхАппаратовСотрудника[0].НомерТелефона);
	Результат.FIO = Строка(Контрагент.Менеджер.Наименование);
	Результат.ID = Строка(Контрагент.Менеджер.УникальныйИдентификатор());
	Результат.Оборудование = МассивТелефонныхАппаратовСотрудника[0].Оборудование;
	
	Возврат Результат;
	
КонецФункции

// Функция - Получить активные СИБСТелефонным аппаратом
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьСписокАктивныхПользователей(ВнутреннийНомерТелефонаГруппы = Неопределено, ВыбратьВсехАктивныхСотрудников = Ложь) Экспорт
	
	// так же для группы, могут быть несколько пользователей 
	Если Не ЗначениеЗаполнено(ВнутреннийНомерТелефонаГруппы) И Не ВыбратьВсехАктивныхСотрудников Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ТелефонныеАппараты.Ссылка КАК ТелефонныйАппарат,
	|	ТелефонныеАппараты.ВнутреннийНомер КАК ВнутреннийНомер,
	|	СоединенияИнформационнойБазы.Пользователь КАК Пользователь,
	|	СоединенияИнформационнойБазы.РабочееМесто КАК РабочееМесто
	|ПОМЕСТИТЬ ТелефоныПоРабочимМестам
	|ИЗ
	|	Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыРабочиеМеста
	|		ПО ТелефонныеАппараты.Ссылка = ТелефонныеАппаратыРабочиеМеста.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СоединенияИнформационнойБазы КАК СоединенияИнформационнойБазы
	|		ПО (СоединенияИнформационнойБазы.РабочееМесто = (ВЫРАЗИТЬ(ТелефонныеАппаратыРабочиеМеста.Объект КАК Справочник.РабочиеМеста)))
	|ГДЕ
	|	ТелефонныеАппараты.ПометкаУдаления = ЛОЖЬ
	|	И ТелефонныеАппараты.ВнутреннийНомер <> """"
	|	И ВЫБОР
	|			КОГДА &НомерТелефона <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ТелефонныеАппараты.ВнутреннийНомер = &НомерТелефона
	|						ИЛИ ТелефонныеАппараты.Ссылка В ИЕРАРХИИ
	|							(ВЫБРАТЬ
	|								ТелефонныеАппараты.Ссылка
	|							ИЗ
	|								Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|							ГДЕ
	|								ТелефонныеАппараты.ВнутреннийНомер = &НомерТелефона
	|								И ТелефонныеАппараты.ЭтоГруппа)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ СоединенияИнформационнойБазы.Пользователь.Служебный
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ТелефонныеАппараты.Ссылка КАК ТелефонныйАппарат,
	|	ТелефонныеАппараты.ВнутреннийНомер КАК ВнутреннийНомер,
	|	СоединенияИнформационнойБазы.Пользователь КАК Пользователь,
	|	СоединенияИнформационнойБазы.РабочееМесто КАК РабочееМесто
	|ПОМЕСТИТЬ ТелефоныПоСотрудникам
	|ИЗ
	|	Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ТелефонныеАппараты.ОбъектыПривязки КАК ТелефонныеАппаратыРабочиеМеста
	|		ПО ТелефонныеАппараты.Ссылка = ТелефонныеАппаратыРабочиеМеста.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СоединенияИнформационнойБазы КАК СоединенияИнформационнойБазы
	|		ПО (СоединенияИнформационнойБазы.Пользователь = (ВЫРАЗИТЬ(ТелефонныеАппаратыРабочиеМеста.Объект КАК Справочник.Сотрудники)))
	|ГДЕ
	|	ТелефонныеАппараты.ПометкаУдаления = ЛОЖЬ
	|	И ТелефонныеАппараты.ВнутреннийНомер <> """"
	|	И ВЫБОР
	|			КОГДА &НомерТелефона <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ТелефонныеАппараты.ВнутреннийНомер = &НомерТелефона
	|						ИЛИ ТелефонныеАппараты.Ссылка В ИЕРАРХИИ
	|							(ВЫБРАТЬ
	|								ТелефонныеАппараты.Ссылка
	|							ИЗ
	|								Справочник.ТелефонныеАппараты КАК ТелефонныеАппараты
	|							ГДЕ
	|								ТелефонныеАппараты.ВнутреннийНомер = &НомерТелефона
	|								И ТелефонныеАппараты.ЭтоГруппа)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ СоединенияИнформационнойБазы.Пользователь.Служебный
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТелефоныПоСотрудникам.ТелефонныйАппарат КАК ТелефонныйАппарат,
	|	ТелефоныПоСотрудникам.ВнутреннийНомер КАК ВнутреннийНомер,
	|	ТелефоныПоСотрудникам.Пользователь КАК Пользователь,
	|	ТелефоныПоСотрудникам.РабочееМесто КАК РабочееМесто
	|ИЗ
	|	ТелефоныПоСотрудникам КАК ТелефоныПоСотрудникам
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ТелефоныПоРабочимМестам.ТелефонныйАппарат,
	|	ТелефоныПоРабочимМестам.ВнутреннийНомер,
	|	ТелефоныПоРабочимМестам.Пользователь,
	|	ТелефоныПоРабочимМестам.РабочееМесто
	|ИЗ
	|	ТелефоныПоРабочимМестам КАК ТелефоныПоРабочимМестам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТелефоныПоСотрудникам КАК ТелефоныПоСотрудникам
	|		ПО ТелефоныПоРабочимМестам.РабочееМесто = ТелефоныПоСотрудникам.РабочееМесто
	|ГДЕ
	|	ТелефоныПоСотрудникам.ТелефонныйАппарат ЕСТЬ NULL");
	
	Запрос.УстановитьПараметр("НомерТелефона", ВнутреннийНомерТелефонаГруппы);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

