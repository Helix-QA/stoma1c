// Процедура, обработчик команды "ПолучитьКодПодтвержденияУправляющего".
// 
Процедура ПолучитьКодПодтвержденияУправляющего(Команда)
	
	ПолучитьКодПодтвержденияДляАвторизации(ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего, Истина);

КонецПроцедуры

&НаСервере
// Функция, возвращает код подтверждения.
// 
Процедура ПолучитьКодПодтвержденияДляАвторизации(ВнешняяСистема, ПервичноеВключение = Ложь)
	
	НомерТелефонаТекущий = ПолучитьНомерТелефонаСотрудника(Объект.Ссылка);
	
	Если Не ЗначениеЗаполнено(НомерТелефонаТекущий) Тогда
		Возврат;	
	КонецЕсли;	
	
	Результат = ЛичныйКабинет.ПолучитьКодПодтвержденияДляАвторизации(НомерТелефонаТекущий, ВнешняяСистема);
	
	Если ВнешняяСистема.ТипВнешнейСистемы =	Перечисления.ТипыВнешнихСистем.МобильноеПриложениеУправляющего Тогда
		
		Если Результат.ВыполненоУспешно Тогда
			ЭтотОбъект.КодПодтверждения = Результат.ПараметрыРезультата.confirmation_code; 
			Элементы.КодПодтверждения.Видимость = Истина;
			Элементы.ПолучитьКодПодтвержденияУправляющего.Видимость = Ложь;
		Иначе
			
			Если ПервичноеВключение Тогда
				
				ОписаниеОшибки   = "";
				Зарегистрировать = ЛичныйКабинет.ЗарегистрироватьКлючПользователя(НомерТелефонаТекущий, ОписаниеОшибки);
				
				Если Зарегистрировать ИЛИ СтрНачинаетсяС(ОписаниеОшибки, "Ошибка отправки SMS") Тогда
					ПолучитьКодПодтвержденияДляАвторизации(ЭтотОбъект.ВнешняяСистемаМобильногоПриложенияУправляющего);
				Иначе
					Элементы.ПолучитьКодПодтвержденияУправляющего.РасширеннаяПодсказка.Заголовок = ОписаниеОшибки;
					Элементы.ПолучитьКодПодтвержденияУправляющего.Видимость = Истина;
					Элементы.КодПодтверждения.Видимость = Ложь;
				КонецЕсли;
				
			Иначе
				Элементы.ПолучитьКодПодтвержденияУправляющего.РасширеннаяПодсказка.Заголовок = Результат.ОписаниеОшибки;
				Элементы.ПолучитьКодПодтвержденияУправляющего.Видимость = Истина;
				Элементы.КодПодтверждения.Видимость = Ложь;
			КонецЕсли;	
			
		КонецЕсли;
		
		
	КонецЕсли
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ОтправитьSMS".
// 
Процедура ОтправитьSMS(Команда)
	
	Если Объект.Ссылка.Пустая() Или Модифицированность Тогда 
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаОЗаписиСотрудника", ЭтотОбъект, Новый Структура("Событие", "ОтправкаSMS"));
		Вопрос = ?(Объект.Ссылка.Пустая(), "Для отправки sms необходимо записать нового сотрудника. Записать?", "Необходимо сохранить изменения. Сохранить?");
		ПоказатьВопрос(ОписаниеОповещения, Вопрос, РежимДиалогаВопрос.ДаНет);				
		
	Иначе
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект.НомерТелефона) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить номер телефона");
			Возврат;
		КонецЕсли;
		
		ОписаниеОшибки = "";	
		Если Не ПроверитьВозможностьИспользованияSMSРассылки(ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
			Возврат;	
		КонецЕсли;
		
		Если ОтправитьSMSСообщение() Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сообщение отправлено");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

