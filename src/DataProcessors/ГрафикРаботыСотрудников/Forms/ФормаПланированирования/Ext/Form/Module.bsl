&НаСервере
// Процедура - Отбор по сотруднику.
// 
// 
Процедура ОтборГрафикПериодовРаботыПоСотруднику()
	
	ЗаполнитьСорудниковСогласноОтборов();
	
	// сначала все отобразим
	НомерСтрокиТабДок = 2;
	Пока НомерСтрокиТабДок <=  ГрафикПериодовРаботыТабДок.ВысотаТаблицы Цикл
		ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтрокиТабДок,Символы.НПП,"")).Видимость = Истина;
		НомерСтрокиТабДок = НомерСтрокиТабДок + 1;
	КонецЦикла;
		
	НомерСтрокиТабДок = 2; 
	Пока НомерСтрокиТабДок <=  ГрафикПериодовРаботыТабДок.ВысотаТаблицы Цикл
		ИД_Сотрудник = ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтрокиТабДок,Символы.НПП,"")+"C2").Текст;
		ТекСотрудник = НайтиСотрудникаПоИД(ИД_Сотрудник);
		
		Если СписокСотрудниковПоОтборам.НайтиПоЗначению(ТекСотрудник) = Неопределено Тогда
			ГрафикПериодовРаботыТабДок.Область("R"+СтрЗаменить(НомерСтрокиТабДок,Символы.НПП,"")).Видимость = Ложь;
		КонецЕсли; 
		
		НомерСтрокиТабДок = НомерСтрокиТабДок + 1;
	КонецЦикла;
	
КонецПроцедуры

