// Процедура - обработчик события "НачалоВыбора" поля "РасшифровкаПлатежаЗаказПоступление".
//
Процедура РасшифровкаПлатежаЗаказРеализацияНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ЭлементФормы = ДополнительныеПараметры.ЭлементФормы;
	
	Если ЭлементФормы <> Неопределено Тогда
		ИндексСтроки = Число(Прав(ЭлементФормы.Имя, СтрДлина(ЭлементФормы.Имя) - (СтрДлина(ЭлементФормы.Имя) -1)));
		Объект.РасшифровкаПлатежа[ИндексСтроки].ДокументОснования = Результат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОбработкаВыбора" поля "РасшифровкаПлатежаЗаказПоступление".
//
Процедура РасшифровкаПлатежаЗаказРеализацияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;	
	СуммуБратьПоКолонкеОплачено = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании");
	Если ВыбранноеЗначение <> Неопределено Тогда			
		Счетчик = 0;
		Для Каждого ЭлементМ ИЗ ВыбранноеЗначение Цикл
			
			РазрешитьДобавление = Истина;
			// Проверка существования строки с выбранными данными
			Для Каждого СтрокаТ ИЗ объект.РасшифровкаПлатежа Цикл
				Если СтрокаТ.ДокументОснования = ЭлементМ.ДокументОснования И СтрокаТ.ДокументАванса = ЭлементМ.ДокументАванса Тогда
					Если СуммуБратьПоКолонкеОплачено = Истина Тогда
						СтрокаТ.Сумма       = ЭлементМ.Оплачено;
					Иначе	
						СтрокаТ.Сумма       = ЭлементМ.Задолженность; 
					КонецЕсли;
					РазрешитьДобавление = Ложь;
					Прервать;
				КонецЕсли;	
			КонецЦикла;
			// Есди добавление данных в строку разрешено
			Если РазрешитьДобавление = Истина Тогда
				ОбрабатываемаяСтрока = Неопределено;
				
				Если Счетчик = 0 Тогда
					Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании") Тогда
						ОбрабатываемаяСтрока = Элементы.РасшифровкаПлатежа.ТекущиеДанные;
					Иначе
						ОбрабатываемаяСтрока = Объект.РасшифровкаПлатежа[ПолучитьИндексСтроки(Элемент.Имя)];
					КонецЕсли;	
				Иначе
					ОбрабатываемаяСтрока = Объект.РасшифровкаПлатежа.Добавить();
				КонецЕсли;
		
				ОбрабатываемаяСтрока.ДокументОснования = ЭлементМ.ДокументОснования;
				ОбрабатываемаяСтрока.ДокументАванса    = ЭлементМ.ДокументАванса;
				
				Если СуммуБратьПоКолонкеОплачено = Истина Тогда
					ОбрабатываемаяСтрока.Сумма = ЭлементМ.Оплачено;
				Иначе	
					ОбрабатываемаяСтрока.Сумма = ЭлементМ.Задолженность; 
				КонецЕсли;
			
				Счетчик = Счетчик + 1;
			КонецЕсли;
		КонецЦикла;
		// Подсчет суммы документа
		Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("Сумма");
		ОткорректироватьСуммуЗатрат();
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
