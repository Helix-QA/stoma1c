		               |	И ИсторияИзмененияЭтапов.ПереходНаЭтап = &ПереходНаЭтап
		               |	И ИсторияИзмененияЭтапов.Ссылка.Контрагент.ОбезличенныйКлиент = ЛОЖЬ
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ИсторияИзмененияЭтапов.Ссылка.СтруктурнаяЕдиница,
		               |	ИсторияИзмененияЭтапов.Ссылка,
		               |	ИсторияИзмененияЭтапов.Ссылка.Контрагент,
		               |	ИсторияИзмененияЭтапов.Ссылка.ВидСделки";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Сделки.Ссылка.Контрагент В(&СегментКонтрагентов)",
			"ИсторияИзмененияЭтапов.Ссылка.Контрагент В
			|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
			|				ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты)
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов И НЕ ВЫРАЗИТЬ(СоставСегментов.ОбъектСегмента КАК Справочник.Контрагенты) ЕСТЬ NULL)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияИзмененияЭтапов.Ссылка.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидСделки) Тогда
			Запрос.УстановитьПараметр("ВидСделки", ДанныеТриггера.ВидСделки);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "СделкиИсторияИзмененияЭтапов.Ссылка.ВидСделки = &ВидСделки", "ИСТИНА");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияИзмененияЭтапов.Ссылка.ВидСделки = &ВидСделки", "ИСТИНА");			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ПереходСЭтапа) Тогда 
			Запрос.УстановитьПараметр("ПереходСЭтапа", ДанныеТриггера.ПереходСЭтапа);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИсторияИзмененияЭтапов.ПереходСЭтапа = &ПереходСЭтапа", "ИСТИНА");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ПереходНаЭтап) Тогда 
