&НаКлиенте
//
//
Процедура ТаблицаВыбранныхЗначенийНоменклатураНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметры     = Новый Структура();	
