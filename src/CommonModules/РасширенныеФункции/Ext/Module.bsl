// Функция преобразует массив структур с одинаковым набором параметров в таблицу значений.
//
Функция МассивСтруктурВТаблицуЗначенийСтоматология(МассивСтруктур, МассивКолонок = Неопределено) Экспорт
		
	ТаблицаЗначений = Новый ТаблицаЗначений;
	
	Если МассивСтруктур.Количество() > 0 Тогда
					
		Для Каждого РеквизитСтруктуры Из МассивСтруктур[0] Цикл
			
			Если НЕ МассивКолонок = Неопределено И ТипЗнч(МассивКолонок) = Тип("Массив") Тогда 
				Если МассивКолонок.Найти(РеквизитСтруктуры.Ключ) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		
			МассивТипов = Новый Массив;
			МассивТипов.Добавить(ТипЗнч(РеквизитСтруктуры.Значение));
			ТаблицаЗначений.Колонки.Добавить(РеквизитСтруктуры.Ключ, Новый ОписаниеТипов(МассивТипов,,,, Новый КвалификаторыСтроки(1024)));
		КонецЦикла;
		
		Для Каждого Структура Из МассивСтруктур Цикл
			НоваяСтрока = ТаблицаЗначений.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Структура);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ТаблицаЗначений;
		
КонецФункции

