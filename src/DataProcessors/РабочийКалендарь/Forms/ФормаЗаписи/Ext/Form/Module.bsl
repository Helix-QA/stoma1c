// Функция - Проверяет есть ли сотрудники работающие по графику.
// 
Функция ПроверитьНаличиеСотрудниковПоГрафику()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НастройкаСотрудников.Сотрудник КАК Сотрудник,
	|	НастройкаСотрудников.Сотрудник.Должность КАК Должность
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкаСотрудников
	|ГДЕ
	|	НастройкаСотрудников.Сотрудник.ПометкаУдаления = ЛОЖЬ
	|	И НастройкаСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ВЫБОР
	|			КОГДА &ОтоборСотрудниковСУчетомГрафикаРаботы = ИСТИНА
	|				ТОГДА НастройкаСотрудников.Сотрудник В
	|						(ВЫБРАТЬ
	|							РабочиеДниСотрудников.Сотрудник
	|						ИЗ
	|							РегистрСведений.ВремяРаботыСотрудниковПлан КАК РабочиеДниСотрудников
	|						ГДЕ
	|							НАЧАЛОПЕРИОДА(РабочиеДниСотрудников.ДатаВремяНачала, ДЕНЬ) >= НАЧАЛОПЕРИОДА(&ДатаНачала, ДЕНЬ)
	|							И НАЧАЛОПЕРИОДА(РабочиеДниСотрудников.ДатаВремяНачала, ДЕНЬ) <= НАЧАЛОПЕРИОДА(&ДатаКонца, ДЕНЬ)
	|							И РабочиеДниСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА НЕ НастройкаСотрудников.Сотрудник.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
	|				ТОГДА НастройкаСотрудников.Сотрудник.Должность.ОтображатьВЖурналеПредварительнойЗаписи = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	НастройкаСотрудников.Сотрудник,
	|	НастройкаСотрудников.Сотрудник.Должность
	|
	|УПОРЯДОЧИТЬ ПО
	|	НастройкаСотрудников.Сотрудник.Наименование
	|ИТОГИ ПО
	|	Должность";
	
	Если ПЗГрафикаРежимотОбражения = 0 Тогда		 
		ДатаНачало = НачалоДня(Объект.Дата);
		ДатаКонец  = КонецДня(Объект.Дата);
	ИначеЕсли ПЗГрафикаРежимотОбражения = 1 Тогда
		ДатаНачало = НачалоНедели(Объект.Дата);
		ДатаКонец  = КонецНедели(Объект.Дата);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"                   , Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ОтоборСотрудниковСУчетомГрафикаРаботы", Истина);
	Запрос.УстановитьПараметр("ДатаНачала"                           , ДатаНачало);
	Запрос.УстановитьПараметр("ДатаКонца"                            , ДатаКонец);
	ТаблицаСотрудников = Запрос.Выполнить().Выгрузить();

	Если ТаблицаСотрудников.Количество() > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

