// Функция возвращает период работы структурной единицы в определенный день недели
//
// Параметры:
// ДеньНедели - Дата на которую необходимо получить период работы
// СтруктурнаяЕдиница
//
// Возвращаемое значение
//  Период работы структурной единицы
Функция ПолучитьВремяРаботыСтруктурнойЕдиницы(Дата, СтруктурнаяЕдиница) Экспорт
	
	ПериодРаботы = Новый Структура("ДатаНачала, ДатаОкончания");
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	РасписаниеРаботы.НачалоРаботы КАК НачалоРаботы,
	                      |	ВЫБОР
	                      |		КОГДА РасписаниеРаботы.ОкончаниеРаботы = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	                      |			ТОГДА КОНЕЦПЕРИОДА(ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0), ДЕНЬ)
	                      |		ИНАЧЕ РасписаниеРаботы.ОкончаниеРаботы
	                      |	КОНЕЦ КАК ОкончаниеРаботы
	                      |ИЗ
	                      |	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК РасписаниеРаботы
	                      |ГДЕ
	                      |	РасписаниеРаботы.Ссылка = &СтруктурнаяЕдиница
	                      |	И ДЕНЬНЕДЕЛИ(РасписаниеРаботы.ДеньНедели) = ДЕНЬНЕДЕЛИ(&Дата)
	                      |	И РасписаниеРаботы.Активность = ИСТИНА");
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Дата", Дата);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		ПериодРаботы.ДатаНачала 	= НачалоДня(Дата) + (Результат.НачалоРаботы - Дата(01, 01, 01));
		ПериодРаботы.ДатаОкончания 	= НачалоДня(Дата) + (Результат.ОкончаниеРаботы - Дата(01, 01, 01));
	Иначе 
		ПериодРаботы.ДатаНачала 	= НачалоДня(Дата) + (Дата(1, 1, 1, 01, 00, 00) - Дата(01, 01, 01));
		ПериодРаботы.ДатаОкончания 	= НачалоДня(Дата) + (Дата(1, 1, 1, 23, 00, 00) - Дата(01, 01, 01));
	КонецЕсли;
		
	Возврат ПериодРаботы;	
	
КонецФункции

// Функция - Вернуть кратную текущую дату сеанса
// 
// Возвращаемое значение:
//   - 
// 
Функция ВернутьКратнуюТекущуюДатуСеанса() Экспорт
	
	ТекущаяДатаКлиента 		= ТекущаяДатаСеанса();
	ВременнойРазделитель 	= НачалоЧаса(ТекущаяДатаКлиента) + 60*30;
	
	Если КонецЧаса(ТекущаяДатаКлиента) - ТекущаяДатаКлиента > ТекущаяДатаКлиента - НачалоЧаса(ТекущаяДатаКлиента) Тогда 
		Если ВременнойРазделитель - ТекущаяДатаКлиента > ТекущаяДатаКлиента - НачалоЧаса(ТекущаяДатаКлиента) Тогда 
			ТекущаяДатаКлиента = НачалоЧаса(ТекущаяДатаКлиента);
		Иначе 
			ТекущаяДатаКлиента = ВременнойРазделитель;
		КонецЕсли;
	ИначеЕсли КонецЧаса(ТекущаяДатаКлиента) - ТекущаяДатаКлиента < ТекущаяДатаКлиента - НачалоЧаса(ТекущаяДатаКлиента) Тогда 
		Если КонецЧаса(ТекущаяДатаКлиента) - ТекущаяДатаКлиента > ТекущаяДатаКлиента - ВременнойРазделитель Тогда 
			ТекущаяДатаКлиента = ВременнойРазделитель;
		Иначе 
			ТекущаяДатаКлиента = ВременнойРазделитель + 60*30;
		КонецЕсли;
	Иначе 
		ТекущаяДатаКлиента = НачалоДня(ТекущаяДатаКлиента);
	КонецЕсли;
	
	Возврат ТекущаяДатаКлиента;
	
КонецФункции

