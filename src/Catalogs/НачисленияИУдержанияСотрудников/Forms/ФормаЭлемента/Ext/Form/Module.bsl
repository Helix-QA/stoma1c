
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МассивСтруктурныхЕдиниц = ВернутьСписокСтруктурныхЕдиницСотрудника(Объект.Владелец);
	
	Если Объект.Ссылка.Пустая() Тогда
		Если МассивСтруктурныхЕдиниц.Найти(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница) <> Неопределено Тогда
			Объект.СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
		КонецЕсли;  
		Объект.УсловиеСуммаОт = 0;
		Объект.УсловиеСуммаДо = 0;
	КонецЕсли;	
	УправлениеЭлементами(Ложь);
	Элементы.ПолноеНаименование.ТолькоПросмотр = Не Объект.ВозможностьРедактировать;
	
	Если ЗначениеЗаполнено(Объект.Владелец) Тогда
		
		Массив = Новый Массив;
		Массив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивСтруктурныхЕдиниц)));
		Элементы.СтруктурнаяЕдиница.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
		
	КонецЕсли;	
		
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

&НаКлиенте                                    
// Процедура -  обработчик события формы "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)

	Если Не ЗначениеЗаполнено(Объект.ПолноеНаименование) Тогда
		СформироватьНаименование(Истина);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" различных полей формы
//
Процедура ФормированиеИнтерфейсаПриИзменении(Элемент)
	УправлениеЭлементами(Истина);
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" различных полей формы
//
Процедура ФормированиеНаименованияПриИзменении(Элемент)
	СформироватьНаименование();
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" различных поля формы "КонецПериода"
//
Процедура КонецПериодаПриИзменении(Элемент)
	Если Объект.КонецПериода <> Дата(1,1,1) 
	   И Объект.КонецПериода < Объект.НачалоПериода Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата окончания действия начисления(удержания) должна быть больше даты начала действия!");
		Объект.КонецПериода = Дата("00010101");
	КонецЕсли;
	Объект.НачалоПериода = НачалоДня(Объект.НачалоПериода);
	Объект.КонецПериода = КонецДня(Объект.КонецПериода);

КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "НачалоВыбора" поля формы "СтруктурнаяЕдиница".
//
Процедура СтруктурнаяЕдиницаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
		
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметров = Новый Структура("ТекущаяСтрока, Сотрудник", Объект.СтруктурнаяЕдиница, Объект.Владелец);		
	Оповещение = Новый ОписаниеОповещения("СтруктурнаяЕдиницаНачалоВыбораЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаВыбора", СтруктураПараметров,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура НачалоПериодаПриИзменении(Элемент)
    
	Если Объект.КонецПериода <> Дата(1,1,1) 
		И  Объект.НачалоПериода > Объект.КонецПериода Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Дата начала действия начисления(удержания) должна быть меньше даты окончания действия!");
		Объект.НачалоПериода = Дата("00010101");
	КонецЕсли;
	Объект.НачалоПериода = НачалоДня(Объект.НачалоПериода);
	Объект.КонецПериода = КонецДня(Объект.КонецПериода);	          
КонецПроцедуры

&НаКлиенте
// Процедура срабатывает при изменении поля УсловиеСумма.
//
Процедура УсловиеСуммаПриИзменении(Элемент)	
	УправлениеЭлементами(Истина);          
КонецПроцедуры

&НаКлиенте  
// Процедура срабатывает при изменении поля СравнениеУсловиеСумма.
//
Процедура СравнениеУсловиеСуммаПриИзменении(Элемент)
	УправлениеЭлементами(Истина);   
	Объект.УсловиеСуммаОт = 0;
	Объект.УсловиеСуммаДо = 0;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВозможностьРедактирования(Команда)
	
	Если Объект.ВозможностьРедактировать = Ложь  Тогда
		Объект.ВозможностьРедактировать = Истина; 		
		Элементы.ПолноеНаименование.ТолькоПросмотр = Ложь;
	Иначе
		Объект.ВозможностьРедактировать = Ложь; 
		Элементы.ПолноеНаименование.ТолькоПросмотр = Истина;
		СформироватьНаименование(Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура - изменяет свойства элементов формы в зависимости от установленных значений
//
Процедура УправлениеЭлементами(ФормироватьНаименование = Истина)
	
	Элементы.СтраницыУточненияТипаНачисления.Видимость = Ложь;
	Элементы.ГруппаУсловияНачислений.Видимость		   = Ложь;
	Элементы.ТипНачисленияУдержания.Доступность 	   = Ложь;
	Элементы.ГруппаУсловиеСуммаПроцент.Видимость	   = Ложь;
	
	Если Объект.НачислениеУдержание = Перечисления.ТипыНачисленийУдержаний.Удержание Тогда
		
		
	ИначеЕсли Объект.НачислениеУдержание = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда
		
		Если Объект.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Процент Тогда
			
			Элементы.Размер.МаксимальноеЗначение = 100;
			Объект.Размер = ?(Объект.Размер > 100, 0, Объект.Размер);
			Элементы.ПроцентВалютаЗаголовок.Заголовок = "%";
			
			Элементы.ТипНачисленияУдержания.Доступность 			 = Истина;
			Элементы.СтраницыУточненияТипаНачисления.Видимость 		 = Истина;
			Элементы.СтраницыУточненияТипаНачисления.ТекущаяСтраница = Элементы.ГруппаРазмерНачисленияПроцент;
			Элементы.ГруппаУсловияНачислений.Видимость 	   		 	 = Истина;
			Элементы.СтраницыУсловийНачислений.ТекущаяСтраница 		 = Элементы.ГруппаУсловийНачисленийПроцент;
			Элементы.ГруппаУсловиеСуммаПроцент.Видимость = Истина;
			
			Если Объект.УсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ОтВсейСуммы Тогда
				Элементы.ГруппаУсловиеОтЧастиСуммы.Видимость = Ложь;
			Иначе                                                   
				Элементы.ГруппаУсловиеОтЧастиСуммы.Видимость = Истина;				
				Если Объект.ТипСравненияУсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Между Тогда
					Элементы.УсловиеСуммаОт.Видимость = Истина;
					Элементы.УсловиеСуммаДо.Видимость = Истина; 
					Элементы.ДекорацияУсловиеСУммаИ.Видимость = Истина;    				
				ИначеЕсли Объект.ТипСравненияУсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Больше Тогда
					Элементы.УсловиеСуммаОт.Видимость = Истина;
					Элементы.УсловиеСуммаДо.Видимость = Ложь; 
					Элементы.ДекорацияУсловиеСУммаИ.Видимость = Ложь;  
				ИначеЕсли Объект.ТипСравненияУсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Меньше Тогда
					Элементы.УсловиеСуммаОт.Видимость = Ложь;
					Элементы.УсловиеСуммаДо.Видимость = Истина; 
					Элементы.ДекорацияУсловиеСУммаИ.Видимость = Ложь; 
				КонецЕсли;				
			КонецЕсли;
			
			Если Объект.УчитыватьМатериалы = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.НеУчитыватьСтоимостьМатериалов 
					ИЛИ  Объект.УчитыватьМатериалы = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.УчитыватьСебестоимостьТовара Тогда
				Элементы.ВидЦен.Видимость = Ложь;
				Элементы.ТипЦен.Видимость = Ложь;
				Элементы.ГруппаСегментПередаваемыхМатериалов.Видимость = Ложь;
			ИначеЕсли Объект.УчитыватьМатериалы = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.УчитыватьСтоимостьМатериалов Тогда
				Элементы.ТипЦен.Видимость = Истина;
				Элементы.ВидЦен.Видимость = (Объект.ТипЦен = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоВидуЦен);
				Элементы.ГруппаСегментПередаваемыхМатериалов.Видимость = Ложь;
			ИначеЕсли Объект.УчитыватьМатериалы = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ВычитатьСтоимостьПереданныхСотрудникуМатериалов Тогда
				Элементы.ТипЦен.Видимость = Истина;
				Элементы.ВидЦен.Видимость = (Объект.ТипЦен = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоВидуЦен);
				Элементы.ГруппаСегментПередаваемыхМатериалов.Видимость = Истина;				
			КонецЕсли;
			
			Если Объект.ОтСуммы = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоВидуЦен Тогда
				Элементы.ВидЦенСуммы.Видимость = Истина;
			Иначе
				Элементы.ВидЦенСуммы.Видимость = Ложь;
			КонецЕсли;
			
			Если Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.БезУсловий Тогда
				Элементы.ТипСравнения.Видимость = Ложь;
				Элементы.СуммаПродаж.Видимость = Ложь;
			Иначе
				Элементы.ТипСравнения.Видимость = Истина;
				Элементы.СуммаПродаж.Видимость = Истина;
			КонецЕсли; 			
			
		ИначеЕсли Объект.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Оклад Тогда
				
				Элементы.Размер.МаксимальноеЗначение = 1000000000;
				Элементы.ПроцентВалютаЗаголовок.Заголовок = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				
				Элементы.ТипНачисленияУдержания.Доступность 			 = Истина;
				Элементы.СтраницыУточненияТипаНачисления.Видимость 		 = Истина;
				Элементы.СтраницыУточненияТипаНачисления.ТекущаяСтраница = Элементы.ГруппаРазмерНачисленияОклад;
				
				Если Объект.ЗависимостьОтВыработки = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗависитОтВыработки	Тогда
					Элементы.ТипПериодаНачисления.Видимость = Истина;
				Иначе
					Элементы.ТипПериодаНачисления.Видимость = Ложь;
				КонецЕсли;
				Элементы.ГруппаУсловиеСуммаПроцент.Видимость = Ложь;
				
		ИначеЕсли Объект.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф Тогда
				
				Элементы.Размер.МаксимальноеЗначение = 1000000000;
				Элементы.ПроцентВалютаЗаголовок.Заголовок = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				
				Элементы.ТипТарифаВрач.Видимость						 = (Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования);
				Элементы.ТипНачисленияУдержания.Доступность 			 = Истина;
				Элементы.СтраницыУточненияТипаНачисления.Видимость 	     = Истина;				
				Элементы.СтраницыУточненияТипаНачисления.ТекущаяСтраница = Элементы.ГруппаРазмерНачисленияТариф;
				
				Элементы.ГруппаУсловияНачислений.Видимость 	   		 	 = (Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования 
				ИЛИ Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧас ИЛИ Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.АвторуЗаОплаченныйПрием);
				Элементы.СтраницыУсловийНачислений.ТекущаяСтраница 		 = Элементы.ГруппаУсловийНачисленийТариф;
				
				Элементы.ГруппаСегментНоменклатурыТариф.Видимость		 = (Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования
				Или Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.АвторуЗаОплаченныйПрием);
				Если Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.БезУсловий Тогда
					Элементы.ТипСравненияТариф.Видимость = Ложь;
					Элементы.СуммаПродажТариф.Видимость = Ложь;
					Элементы.ТарифВалютаСравнениеСуммыЗаголовок.Видимость = Ложь;
				Иначе
					Если Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЕслиСуммаПродажи Тогда
						Элементы.ТипСравненияТариф.Видимость = Истина;
						Элементы.ТарифВалютаСравнениеСуммыЗаголовок.Заголовок = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
					Иначе
						Элементы.ТипСравненияТариф.Видимость = Ложь;
						Элементы.ТарифВалютаСравнениеСуммыЗаголовок.Заголовок = "Часов";
					КонецЕсли;
					Элементы.СуммаПродажТариф.Видимость = Истина;
					Элементы.ТарифВалютаСравнениеСуммыЗаголовок.Видимость = Истина;
				КонецЕсли;
				
				Элементы.ГруппаВыработкиПоЧасам.Видимость 				  	= (Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования);
				Элементы.ТипСегментаНоменклатурыЗаголовокТариф.Заголовок  	= ?(Объект.ТипТарифа <> Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.АвторуЗаОплаченныйПрием, "по номенклатуре сегмента", "содержащий номенклатуру");
				Элементы.ГруппаСравнениеСуммаТариф.Видимость				= (Объект.ТипТарифа <> Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.АвторуЗаОплаченныйПрием);
				Элементы.ГруппаУсловиеСуммаПроцент.Видимость = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не Объект.ВозможностьРедактировать и ФормироватьНаименование = Истина Тогда
	   СформироватьНаименование();
	КонецЕсли;
   
КонецПроцедуры // УправлениеЭлементами()

&НаСервере
// Процедура - формирует наименование элемента справочника в зависимости от выбранных значений на форме.
//
Процедура СформироватьНаименование(ФормироватьПринудительно = Истина)
	
	Если Объект.ВозможностьРедактировать И ФормироватьПринудительно <> Истина Тогда
	   Возврат;
	КонецЕсли;

	ПолноеНаименование = "";
	Наименование = "";
	
	Если Объект.НачислениеУдержание = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда
		
		// Формируем наименования для вида начислений "Оклад"
		Если Объект.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Оклад Тогда
			
			ПолноеНаименование = ПолноеНаименование + Объект.ТипНачисленияУдержания + " в размере " + Объект.Размер + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти() + Объект.ЗависимостьОтВыработки;
			Наименование = Наименование + Объект.ТипНачисленияУдержания;
			Если Элементы.ТипПериодаНачисления.Видимость Тогда 
				ПолноеНаименование = ПолноеНаименование + " " + Объект.ТипПериодаНачисления;
				Наименование = Наименование + " " + Объект.ТипПериодаНачисления;
			КонецЕсли;
			
			// Формируем наименования для вида начислений "Тариф"	
		ИначеЕсли Объект.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф Тогда
			
			ПолноеНаименование = ПолноеНаименование + Объект.ТипНачисленияУдержания + " " + Объект.ТипТарифа;
			
			Если Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧасАссистирования Тогда
				ПолноеНаименование = ПолноеНаименование + ?(ЗначениеЗаполнено(Объект.Врач), " врача " + Объект.Врач,"");
				ПолноеНаименование = ПолноеНаименование + ?(ЗначениеЗаполнено(Объект.СегментНоменклатуры), ", по номенклатуре сегмента " + Объект.СегментНоменклатуры,"");
				ПолноеНаименование = ПолноеНаименование +  ?(Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЕслиСуммаПродажи, 
										", " + Объект.УсловиеПродажи + " " + Объект.ТипСравнения + " " + Объект.СуммаПродаж + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти() + ",", "");
				ПолноеНаименование = ПолноеНаименование +  ?(Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасДо ИЛИ Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасСверх,
										", " + Объект.УсловиеПродажи + " " + Объект.СуммаПродаж + " часов,", "");
				ПолноеНаименование = ПолноеНаименование +  ?(Объект.УсловиеПродажи =  Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.БезУсловий, ",", "") + " если отработано " + Объект.УсловиеВыработкиПоЧасам + " " + Объект.ТипСравненияВыработкиПоЧасам + " " + Объект.КоличествоЧасов + " ч., ";						
			ИначеЕсли Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧас Тогда
				ПолноеНаименование = ПолноеНаименование +  ?(Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасДо ИЛИ Объект.УсловиеПродажи = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаКаждыйЧасСверх,
										", " + Объект.УсловиеПродажи + " " + Объект.СуммаПродаж + " часов,", "");				
			ИначеЕсли Объект.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.АвторуЗаОплаченныйПрием Тогда 
				ПолноеНаименование = ПолноеНаименование +  ?(ЗначениеЗаполнено(Объект.СегментНоменклатуры), ", содержащий номенклатуру сегмента """ + Объект.СегментНоменклатуры + """, ", ""); 
			КонецЕсли;
			
			ПолноеНаименование = ПолноеНаименование + " в размере " + Объект.Размер + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();		
			Наименование = Наименование + Объект.ТипНачисленияУдержания + " " + Объект.ТипТарифа;
			
			// Формируем наименования для вида начислений "Процент"	
		ИначеЕсли Объект.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Процент Тогда
			
			ПолноеНаименование = ПолноеНаименование + Объект.ТипНачисленияУдержания + ?(Не Объект.УчитываяТолькоОплаченныеПродажи, " от оказанных ", " от оказанных и оплаченных ") + Объект.ОтПродаж + " в размере " + Объект.Размер + " % ";
			Если Объект.УсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ОтВсейСуммы Тогда
				ПолноеНаименование = ПолноеНаименование + Объект.УсловиеСумма;
			Иначе        
				Если Объект.ТипСравненияУсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Больше Тогда
					УсловиеСуммы = "от части суммы от " + Объект.УсловиеСуммаОт + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();  
				ИначеЕсли Объект.ТипСравненияУсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Меньше Тогда
					УсловиеСуммы = "от части суммы до " + Объект.УсловиеСуммаДо + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				ИначеЕсли Объект.ТипСравненияУсловиеСумма = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.Между Тогда
					УсловиеСуммы = "от части суммы между " + Объект.УсловиеСуммаОт + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти() + "и " + Объект.УсловиеСуммаДо + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				КонецЕсли;
				ПолноеНаименование = ПолноеНаименование + УсловиеСуммы;
			КонецЕсли;
			
			Наименование = Наименование + Объект.ТипНачисленияУдержания + ?(Не Объект.УчитываяТолькоОплаченныеПродажи, " от оказанных ", " от оказанных и оплаченных ") + Объект.ОтПродаж;
			ПолноеНаименование = ПолноеНаименование + ?(ЗначениеЗаполнено(Объект.СегментНоменклатуры), ", по номенклатуре сегмента " + Объект.СегментНоменклатуры,"");
			ПолноеНаименование = ПолноеНаименование + ?(ЗначениеЗаполнено(Объект.СегментНоменклатуры), ", клиентам сегмента " + Объект.СегментКонтрагента,"");
			ПолноеНаименование = ПолноеНаименование + ", " + Объект.УчитыватьМатериалы;
			Если Элементы.ТипЦен.Видимость Тогда
				ПолноеНаименование = ПолноеНаименование + " " + Объект.ТипЦен;
				Если Элементы.ВидЦен.Видимость Тогда 
					ПолноеНаименование = ПолноеНаименование + " " + Объект.ВидЦен;
				КонецЕсли;
			КонецЕсли;
			ПолноеНаименование = ПолноеНаименование + " от суммы " + Объект.ОтСуммы + 
					?(Объект.ОтСуммы = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоВидуЦен, " """ + Объект.ВидЦенСуммы + """", "") 
					+ ", " + Объект.УсловиеПродажи;
			Если Элементы.ТипСравнения.Видимость Тогда
				ПолноеНаименование = ПолноеНаименование + " " + Объект.ТипСравнения + " " + Объект.СуммаПродаж + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
				Наименование = Наименование + ", " + Объект.УсловиеПродажи + " " + Объект.ТипСравнения + " " + Объект.СуммаПродаж + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли Объект.НачислениеУдержание = Перечисления.ТипыНачисленийУдержаний.Удержание Тогда
		
		Наименование = "" + Объект.НачислениеУдержание + " в размере " + Объект.Размер + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		ПолноеНаименование = Наименование;
		
	КонецЕсли;
	
	Объект.Наименование = Наименование;
	Объект.ПолноеНаименование = ПолноеНаименование;
	
КонецПроцедуры // СформироватьНаименование()

