		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	СписокВыбора.Очистить();
	
	КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий", ВариантУсловияТриггерногоСобытия));
	
	Если КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0 Тогда 
		Для Каждого ЭлементКоллекции Из КоллекцияВариантовУсловийТриггерныхСобытий[0].СписокВидовПериодаАктивации Цикл
			НовыйЭлементСписка 						= СписокВыбора.Добавить();
			НовыйЭлементСписка.Значение 			= ЭлементКоллекции.Значение;
			НовыйЭлементСписка.Представление 		= СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(XMLСтрока(ЭлементКоллекции.Значение), ПериодСобытия);
			НовыйЭлементСписка.Пометка 				= ПериодСобытияВид = ЭлементКоллекции.Значение;
		КонецЦикла;	
	Иначе 
		СписокВыбора.Добавить(Перечисления.Периодичность.День, СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(XMLСтрока(Перечисления.Периодичность.День), ПериодСобытия), ПериодСобытияВид = Перечисления.Периодичность.День);
	КонецЕсли;
	
КонецПроцедуры

