// Процедура - Установить свойства элементам параметра активации
//
Процедура УстановитьСвойстваЭлементамПараметраАктивации()
	
	Элементы.ПараметрСобытияНомерПосещения.Видимость 		= Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники;
	Элементы.ГруппаПараметрПериод.Видимость 				= Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе ИЛИ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана;
	Элементы.ПериодСобытияПараметр.ПоложениеЗаголовка 		= ?(Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана, ПоложениеЗаголовкаЭлементаФормы.Нет, ПоложениеЗаголовкаЭлементаФормы.Лево);
	
	// Сбрасываем свойства
	Элементы.ПараметрСобытия.Видимость 								= Ложь;	
	Элементы.ПараметрСобытияНомерПосещения.Видимость 				= Ложь;
	Элементы.ПараметрСобытия.МинимальноеЗначение 					= 0;	
	Элементы.ПараметрСобытияНомерПосещения.МинимальноеЗначение 		= 0;
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий 	= ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	ПараметрыВариантаУсловияТриггерныхСобытий 		= ТаблицаВсехВариантовУсловийТриггерныхСобытий.Найти(Объект.УсловиеСобытия, "ВариантыУсловийТриггерныхСобытий");	
	Если ПараметрыВариантаУсловияТриггерныхСобытий <> Неопределено Тогда 
		ЭлементПараметра = Элементы.Найти(ПараметрыВариантаУсловияТриггерныхСобытий.ИмяЭлементаПараметраСобытия);
		Если ЭлементПараметра <> Неопределено Тогда 
			ЭлементПараметра.Видимость 				= ПараметрыВариантаУсловияТриггерныхСобытий.ИспользуетсяПараметрСобытия;
			ЭлементПараметра.МинимальноеЗначение 	= ПараметрыВариантаУсловияТриггерныхСобытий.МинимальноеЗначениеПараметраСобытия;
		КонецЕсли;	
	КонецЕсли;
	
	Элементы.ПараметрСобытия.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	
	Если Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники ИЛИ Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПотенциальныйНеСталНовым Тогда 
		Элементы.ПараметрСобытия.Заголовок = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("День", Объект.ПараметрСобытия, "Родительный");
	ИначеЕсли Объект.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ЛицевойСчетКритическийОстатокСредств Тогда
		Элементы.ПараметрСобытия.Заголовок = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
	КонецЕсли;
	
	Элементы.ПериодСобытияПараметр.АвтоОтметкаНезаполненного 	= Элементы.ГруппаПараметрПериод.Видимость;
	Элементы.ПериодСобытияПараметр.ОтметкаНезаполненного 		= Элементы.ГруппаПараметрПериод.Видимость;	
	Элементы.ПериодСобытияВидПараметр.АвтоОтметкаНезаполненного = Элементы.ГруппаПараметрПериод.Видимость;
	Элементы.ПериодСобытияВидПараметр.ОтметкаНезаполненного 	= Элементы.ГруппаПараметрПериод.Видимость;
	Элементы.ВидСделки.АвтоОтметкаНезаполненного 				= Элементы.ГруппаПараметрПериод.Видимость;
	Элементы.ВидСделки.ОтметкаНезаполненного 					= Элементы.ГруппаПараметрПериод.Видимость;	
	Элементы.ПереходСЭтапа.АвтоОтметкаНезаполненного 			= Элементы.ГруппаПараметрПериод.Видимость;
	Элементы.ПереходСЭтапа.ОтметкаНезаполненного 				= Элементы.ГруппаПараметрПериод.Видимость;
	
КонецПроцедуры

