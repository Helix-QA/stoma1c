// Процедура - Таблица услуги номенклатура начало выбора завершение добавление после согласования.
//
Процедура ТаблицаУслугиНоменклатураНачалоВыбораЗавершение_ДобавлениеПослеСогласования(Значение, СтруктураДанныеПолиса = Неопределено) 
	
	Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Значение, "ТипНоменклатуры") 
			= ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Набор") Тогда
		СоставНабора = ОбщегоНазначенияСтоматология.ПолучитьСоставНабора(Значение);
		ПерваяСтока = Истина;
		Для Каждого СтрокаТЧ из СоставНабора Цикл
			Если Не ПерваяСтока Тогда
				Элементы.ТаблицаЛечение.ДобавитьСтроку();
			КонецЕсли;
			Элементы.ТаблицаЛечение.ТекущиеДанные.Номенклатура = СтрокаТЧ.Номенклатура;
			Элементы.ТаблицаЛечение.ТекущиеДанные.КоличествоУпаковок   = СтрокаТЧ.Количество;
			Элементы.ТаблицаЛечение.ТекущиеДанные.Количество   = СтрокаТЧ.Количество;
			ТаблицаУслугиНоменклатураПриИзменении(Неопределено);
			ПерваяСтока = Ложь;
		КонецЦикла;
	Иначе	 
		ТекущиеДанные = Элементы.ТаблицаЛечение.ТекущиеДанные;
		ТекущиеДанные.Номенклатура 			= Значение;
		
		ТекущиеДанные.СтатусСогласования 	= Неопределено;	
		ТекущиеДанные.ТребуетсяСогласование = Неопределено;
		ТекущиеДанные.ТребуетсяСогласование = Неопределено;
		ТекущиеДанные.Согласователь 		= Неопределено;
		ТекущиеДанные.ДатаСогласования 		= Неопределено;
		ТекущиеДанные.ДатаОтправки 			= Неопределено;
		ТекущиеДанные.КомментарийСогласования = Неопределено;
				
		ТаблицаУслугиНоменклатураПриИзменении(Неопределено,, Ложь);	
	КонецЕсли;	
	
	Если НЕ СтруктураДанныеПолиса = Неопределено Тогда
		Если СтруктураДанныеПолиса.Свойство("Результат") ИЛИ
			СтруктураДанныеПолиса.Свойство("ПолисСогласование") ИЛИ
			СтруктураДанныеПолиса.Свойство("СогласованиеПриПревышении") Тогда
			
			СтрокаТабличнойЧасти = Элементы.ТаблицаЛечение.ТекущиеДанные;
			// Если СтруктураДанныеПолиса.Свойство("ПолисСогласование") Тогда	
				СтрокаТабличнойЧасти.ТребуетсяСогласование = СтруктураДанныеПолиса.ПолисСогласование;			
			// КонецЕсли;
			Если НЕ СтруктураДанныеПолиса.СогласованиеПриПревышении = Неопределено И СтруктураДанныеПолиса.СогласованиеПриПревышении = Ложь Тогда
				СтрокаТабличнойЧасти.ТребуетсяСогласование = Неопределено;			
			КонецЕсли;
			Если НЕ СтруктураДанныеПолиса.Результат = Неопределено И ЗначениеЗаполнено(СтрокаТабличнойЧасти.ТребуетсяСогласование) Тогда 
				СтрокаТабличнойЧасти.СтатусСогласования = СтруктураДанныеПолиса.Результат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// При изменении выбора номенклатуры
//
Процедура ТаблицаУслугиНоменклатураПриИзменении(
	Элемент, 
	ИдентификаторыНовыхСтрок = Неопределено, 
	ПересчетТЧПослеизменения = Ложь, 
	СтрокаТЧ				 = Неопределено, 
	СтруктураДанныеПолиса	 = Неопределено)	
	
	Если СтрокаТЧ = Неопределено
		И Элементы.ТаблицаЛечение.ТекущиеДанные <> Неопределено Тогда
		СтрокаТЧ = Элементы.ТаблицаЛечение.ТекущиеДанные;
	Иначе
		Возврат;
	КонецЕсли;
	
	// Проверка на статус "в продаже".
	ВПродаже = ПолучитьСтатусНоменклатуры(СтрокаТЧ.Номенклатура, Объект.СтруктурнаяЕдиница, Объект.Дата);
	Если НЕ ВПродаже Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Номенклатура %1 снята с продаж!"), СтрокаТЧ.Номенклатура);
		СтрокаТЧ.Номенклатура = Неопределено;
		Возврат;
		
	КонецЕсли;	
	
	Если ПроверитьПрименениеВидовНалогов(СтрокаТЧ.Номенклатура) 
		ИЛИ Не УслугаДоступнаДляСотрудника(СтрокаТЧ.Номенклатура, Объект.СтруктурнаяЕдиница, Объект.Сотрудник) Тогда
		СтрокаТЧ.Номенклатура = Неопределено;
		Возврат;
	КонецЕсли;
		
	Если ИдентификаторыНовыхСтрок = Неопределено Тогда
		ИдентификаторыНовыхСтрок = СтрокаТЧ.ПолучитьИдентификатор();
	КонецЕсли;
	
	ТаблицаУслугиНоменклатураПриИзмененииСервер(ИдентификаторыНовыхСтрок, ПересчетТЧПослеизменения, СтруктураДанныеПолиса);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Таблица лечение номенклатура обработка выбора.
//
Процедура ТаблицаЛечениеНоменклатураОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтрокаТЧ = Элементы.ТаблицаЛечение.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса) Тогда 
		
		Если СтрокаТЧ <> Неопределено Тогда
			СтрокаТЧ.Номенклатура = ВыбранноеЗначение;
		КонецЕсли;
		
		ТаблицаУслугиНоменклатураПриИзменении(Элемент);

	Иначе
		
		// Выполнить проверку по договору
		МассивНоменклатуры = Новый Массив();
		МассивНоменклатуры.Добавить(ВыбранноеЗначение); 
		
		МассивЗубов = Новый Массив();
		Если СтрокаТЧ <> Неопределено
			И ЗначениеЗаполнено(СтрокаТЧ.Зуб) Тогда
			МассивЗубов.Добавить(СтрокаТЧ.Зуб);
		Иначе
			МассивЗубов = МассивВыделенныхЗубов.ВыгрузитьЗначения();
			Если МассивЗубов.Количество() = 0 Тогда 
				МассивЗубов.Добавить(ОбщиеПараметры.Перечисление_Зубы_ВсяПолость);
			КонецЕсли;	
		КонецЕсли;
		
		МассивСтруктурСКоличествомПоПолису = ПолучитьКоличествоПоПолису(Объект.ПолисМедСтрахования, Объект.Ссылка);
		КоличествоЗубовВсего = 0;
		КоличествоВсего = 0;
		ОписаниеОшибки = "";
		
		Для Каждого СтрокаМассива Из МассивСтруктурСКоличествомПоПолису Цикл
			Если СтрокаМассива.Номенклатура = ВыбранноеЗначение Тогда
				
				КоличествоЗубовВсего = СтрокаМассива.КоличествоЗубов;
				КоличествоВсего      = СтрокаМассива.Количество;
				
			КонецЕсли;
		КонецЦикла;
		
		СтруктураПараметров				 = ПолучитьКоличествоЗубовПоДоговору(ЭтотОбъект._ПодборДоговорПолиса, ВыбранноеЗначение); 
		ИнформацияНоменклатурыПоДоговору = ПолучитьИнформациюНоменклатурыПоДоговору(ЭтотОбъект._ПодборДоговорПолиса, ВыбранноеЗначение);
		
		Если ИнформацияНоменклатурыПоДоговору <> Неопределено Тогда
			
			СтруктураПараметровПоПолису = Новый Структура();
			СтруктураПараметровПоПолису.Вставить("ПолисКоличество"				, ИнформацияНоменклатурыПоДоговору.Количество);
			СтруктураПараметровПоПолису.Вставить("ПолисНеограничено"			, ИнформацияНоменклатурыПоДоговору.Количество = 0);
			СтруктураПараметровПоПолису.Вставить("ПолисСогласование"			, ИнформацияНоменклатурыПоДоговору.Согласование);	 
			СтруктураПараметровПоПолису.Вставить("ПолисКоличествоПриПревышении"	, ИнформацияНоменклатурыПоДоговору.КоличествоПриПревышении);
			
			СтруктураПараметровПоПолису.Вставить("ЭлементМЗуб"						, МассивЗубов[0]);
			СтруктураПараметровПоПолису.Вставить("КоличествоНоменклатурыВТЧ"        , ВернутьКоличествоНоменклатурыВТЧЛечение(ВыбранноеЗначение));
			СтруктураПараметровПоПолису.Вставить("КоличествоЗубовСНомненклатуройВТЧ", ПолучитьКоличествоЗубовСНомненклатурой(ВыбранноеЗначение));	
			СтруктураПараметровПоПолису.Вставить("КоличествоЗубов"					, СтруктураПараметров.КоличествоЗубов);
			СтруктураПараметровПоПолису.Вставить("КоличествоВПриеме"				, СтруктураПараметров.КоличествоВПриеме);
			СтруктураПараметровПоПолису.Вставить("Номенклатура"						, ВыбранноеЗначение);
			СтруктураПараметровПоПолису.Вставить("КоличествоЗубовВсего"				, КоличествоЗубовВсего);
			СтруктураПараметровПоПолису.Вставить("КоличествоВсего"					, КоличествоВсего);
			
			ПроверитьУслугуНаСогласованностьПоПолису(СтруктураПараметровПоПолису, ОписаниеОшибки);
			
		Иначе
			ОписаниеОшибки = НСтр("ru = 'Выбранная номенклатура не содерждится в договоре.'");	
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
			ПоказатьПредупреждение(, ОписаниеОшибки);
			ВыбранноеЗначение     = Неопределено; 
			СтрокаТЧ.Номенклатура = Неопределено;
			Возврат;
		Иначе
			СтрокаТЧ.Номенклатура = ВыбранноеЗначение;
		КонецЕсли;
		
		СтруктураДанныеПолиса = ПолучитьСтруктуруДанныхПолиса(СтруктураПараметровПоПолису, СтруктураПараметровПоПолису);
		ТаблицаУслугиНоменклатураПриИзменении(Элемент,,,,СтруктураДанныеПолиса);
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить количество зубов по договору.
//
Функция ПолучитьКоличествоЗубовПоДоговору(Договор, ВыбранноеЗначение)
	
	КоличествоЗубов   = 0; 
	КоличествоВПриеме = 0;
	СтрокаУслугиПоДоговору = Договор.УслугиПоДоговору.Найти(ВыбранноеЗначение, "Номенклатура");
	Если СтрокаУслугиПоДоговору <> Неопределено И ЗначениеЗаполнено(СтрокаУслугиПоДоговору.КлючСтроки) Тогда									
		
		СтрокаУслугиПоДоговоруОграничениеЗубов = Договор.ОграничениеЗубов.Найти(СтрокаУслугиПоДоговору.КлючСтроки, "КлючСтроки");	
		Если СтрокаУслугиПоДоговоруОграничениеЗубов <> Неопределено Тогда
			КоличествоЗубов   = СтрокаУслугиПоДоговоруОграничениеЗубов.КоличествоЗубов;
			КоличествоВПриеме = СтрокаУслугиПоДоговоруОграничениеЗубов.КоличествоВПриеме;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Новый Структура("КоличествоЗубов, КоличествоВПриеме", КоличествоЗубов, КоличествоВПриеме);
	
КонецФункции
	
&НаСервереБезКонтекста
// Функция - Проверяет доступна услуга сотруднику или нет.
//
Функция УслугаДоступнаДляСотрудника(Услуга, СтруктурнаяЕдиница, Сотрудник)
	
     Возврат РегистрыСведений.УслугиСотрудника.УслугаДоступнаДляСотрудника(Услуга, Сотрудник, СтруктурнаяЕдиница);
	 
КонецФункции

&НаКлиенте
// Процедура - обработчик события "АвтоПодбор"
//
Процедура ТаблицаЛечениеНоменклатураАвтоПодбор(Элемент, Текст, ДанныеВыбора, Ожидание, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Не ЗначениеЗаполнено(Текст);
	
	Если СтрДлина(Текст) >= 3 Тогда
		
		СтрокаТЧ	 = Элементы.ТаблицаЛечение.ТекущиеДанные;
		ДанныеВыбора = ПолучитьСписокНоменклатурАвтоПодбора(Текст, Истина, СтрокаТЧ.Сотрудник, Объект.СтруктурнаяЕдиница,
			Объект.ВидЦен, Объект.Дата, _ПодборСегментНоменклатуры, ОтборСегментУслугПоСогласованию, ЭтотОбъект._ПодборДоговорПолиса); // ПЕРЕДАТЬ ПОЛИС!
		
	Иначе
		
		СписокНоменклатуры = Новый СписокЗначений;
		СписокНоменклатуры.Добавить(Неопределено, "Для поиска необходимо ввести 3 и более символа.");		
		ДанныеВыбора = СписокНоменклатуры;
		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает список номенклатур для автоподбора
//
Функция ПолучитьСписокНоменклатурАвтоПодбора(
		СтрокаПоиска, 
		ТолькоУслуги, 
		Сотрудник = Неопределено, 
		СтруктурнаяЕдиница, 
		ВидЦен, 
		Дата = Неопределено, 
		Сегмент = Неопределено, 
		СегментУслугПоСогласованию = Неопределено,
		ПодборДоговорПолиса = Неопределено)
	
	ВидЦенСотрудника = ?(ЗначениеЗаполнено(ВидЦен), ВидЦен, Справочники.ВидыЦен.Розничная);
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Номенклатура.Ссылка КАК Номенклатура,
	               |	0 КАК НормаВремени,
	               |	Номенклатура.Наименование КАК Наименование
	               |ПОМЕСТИТЬ ВТНоменклатура
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	&ТолькоУслуги = ЛОЖЬ
	               |	И НЕ Номенклатура.ПометкаУдаления
	               |	И НЕ Номенклатура.ЭтоГруппа
	               |	И (Номенклатура.Наименование ПОДОБНО &СтрокаПоиска
	               |			ИЛИ Номенклатура.Артикул = &СтрокаПоискаПоАртикулу)
	               |	И Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Номенклатура.Ссылка,
	               |	Номенклатура.НормаВремени,
	               |	Номенклатура.Наименование
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	&СотрудникЗаполнен = ЛОЖЬ
	               |	И НЕ Номенклатура.ПометкаУдаления
	               |	И НЕ Номенклатура.ЭтоГруппа
	               |	И Номенклатура.Наименование ПОДОБНО &СтрокаПоиска
	               |	И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	               |	И &УсловиеПоНормеВремени
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	УслугиСотрудника.Номенклатура,
	               |	УслугиСотрудника.Номенклатура.НормаВремени,
	               |	УслугиСотрудника.Номенклатура.Наименование
	               |ИЗ
	               |	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	               |ГДЕ
	               |	&СотрудникЗаполнен = ИСТИНА
	               |	И УслугиСотрудника.Сотрудник = &Сотрудник
	               |	И УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И УслугиСотрудника.Номенклатура.Наименование ПОДОБНО &СтрокаПоиска
	               |	И НЕ УслугиСотрудника.Номенклатура.ПометкаУдаления
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СтатусыНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	               |	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже
	               |ПОМЕСТИТЬ СтатусыНоменклатуры
	               |ИЗ
	               |	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(
	               |			&Дата,
	               |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |				И Номенклатура В
	               |					(ВЫБРАТЬ
	               |						ВТНоменклатура.Номенклатура
	               |					ИЗ
	               |						ВТНоменклатура)) КАК СтатусыНоменклатурыСрезПоследних
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТНоменклатура.Номенклатура КАК Номенклатура,
	               |	ВТНоменклатура.НормаВремени КАК НормаВремени,
	               |	ВТНоменклатура.Наименование КАК Наименование
	               |ПОМЕСТИТЬ ВТНоменклатураПоСегменту
	               |ИЗ
	               |	ВТНоменклатура КАК ВТНоменклатура
	               |ГДЕ
	               |	&УсловиеПоСегменту
	               |	И &УсловиеСегментуУслугПоСогласованию
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВТНоменклатураПоСегменту.Номенклатура КАК Номенклатура,
	               |	ВТНоменклатураПоСегменту.НормаВремени КАК НормаВремени,
	               |	ВТНоменклатураПоСегменту.Наименование КАК Наименование
	               |ПОМЕСТИТЬ ВТНоменклатураВПродаже
	               |ИЗ
	               |	ВТНоменклатураПоСегменту КАК ВТНоменклатураПоСегменту
	               |		ЛЕВОЕ СОЕДИНЕНИЕ СтатусыНоменклатуры КАК СтатусыНоменклатуры
	               |		ПО ВТНоменклатураПоСегменту.Номенклатура = СтатусыНоменклатуры.Номенклатура
	               |ГДЕ
	               |	ЕСТЬNULL(СтатусыНоменклатуры.ВПродаже, ИСТИНА)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТЦены
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			&Дата,
	               |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |				И ВидЦен = &ВидЦен
	               |				И Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	               |				И Номенклатура В
	               |					(ВЫБРАТЬ
	               |						ВТНоменклатураВПродаже.Номенклатура
	               |					ИЗ
	               |						ВТНоменклатураВПродаже)) КАК ЦеныНоменклатурыСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	               |	ЦеныНоменклатурыСрезПоследних.Цена
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТЕдиныеЦены
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			&Дата,
	               |			СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	               |				И Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	               |				И ВидЦен = &ВидЦен
	               |				И Номенклатура В
	               |					(ВЫБРАТЬ
	               |						ВТНоменклатураВПродаже.Номенклатура
	               |					ИЗ
	               |						ВТНоменклатураВПродаже)) КАК ЦеныНоменклатурыСрезПоследних
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	               |	ЦеныНоменклатурыСрезПоследних.Цена
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТНоменклатураВПродаже.Номенклатура КАК Номенклатура,
	               |	ВТНоменклатураВПродаже.НормаВремени КАК НормаВремени,
	               |	ЕСТЬNULL(ЕСТЬNULL(ВТЦены.Цена, ВТЕдиныеЦены.Цена), 0) КАК Цена,
	               |	ВТНоменклатураВПродаже.Наименование КАК Наименование
	               |ИЗ
	               |	ВТНоменклатураВПродаже КАК ВТНоменклатураВПродаже
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦены КАК ВТЦены
	               |		ПО ВТНоменклатураВПродаже.Номенклатура = ВТЦены.Номенклатура
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТЕдиныеЦены КАК ВТЕдиныеЦены
	               |		ПО ВТНоменклатураВПродаже.Номенклатура = ВТЕдиныеЦены.Номенклатура
				   |ГДЕ
				   |	&УсловиеОграничениеПодбораПоПолису";
	
	Запрос.УстановитьПараметр("ТолькоУслуги"      , ТолькоУслуги);
	Запрос.УстановитьПараметр("СотрудникЗаполнен" , ЗначениеЗаполнено(Сотрудник));
	Запрос.УстановитьПараметр("Сотрудник"         , Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("СтрокаПоискаПоАртикулу", СокрЛ(СтрокаПоиска));
	Запрос.УстановитьПараметр("СтрокаПоиска"      , СокрЛ(СтрокаПоиска) + "%");
	Запрос.УстановитьПараметр("ВидЦен"            , ВидЦенСотрудника);
	Запрос.УстановитьПараметр("Дата"              , Дата);
	
	УсловиеПоНормеВремени = ?(ТолькоУслуги, " И Номенклатура.НормаВремени > 0", "");
	Запрос.Текст 		  = СтрЗаменить(Запрос.Текст, "И &УсловиеПоНормеВремени", УсловиеПоНормеВремени);
	
	Если ТолькоУслуги И ЗначениеЗаполнено(Сегмент) Тогда
		
		УсловиеПоСегменту = " ВТНоменклатура.Номенклатура В
		|			(ВЫБРАТЬ
		|				НоменклатураСегмента.Номенклатура КАК Номенклатура
		|			ИЗ
		|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|			ГДЕ
		|				НоменклатураСегмента.Сегмент = &СегментОрганизации)";
		
		Запрос.УстановитьПараметр("Сегмент", Сегмент);
				
	Иначе	
		УсловиеПоСегменту = " Истина";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоСегменту", УсловиеПоСегменту);
	
	Если ТолькоУслуги И ЗначениеЗаполнено(СегментУслугПоСогласованию) Тогда
		УсловиеСегментуУслугПоСогласованию = " ВТНоменклатура.Номенклатура В
		|			(ВЫБРАТЬ
		|				НоменклатураСегмента.Номенклатура КАК Номенклатура
		|			ИЗ
		|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|			ГДЕ
		|				НоменклатураСегмента.Сегмент = &СегментУслугПоСогласованию)";
		
		Запрос.УстановитьПараметр("СегментУслугПоСогласованию", СегментУслугПоСогласованию);

    Иначе	
		УсловиеСегментуУслугПоСогласованию = " Истина";
	КонецЕсли;

	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСегментуУслугПоСогласованию", УсловиеСегментуУслугПоСогласованию);

	УсловиеОграничениеПодбораПоПолису = 
	"ВТНоменклатураВПродаже.Номенклатура В (ВЫБРАТЬ
	|			ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура КАК ТЧДоговорНоменклатура
	|		ИЗ
	|			Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|		ГДЕ
	|			ДоговорыКонтрагентовУслугиПоДоговору.Ссылка = &СсылкаДоговорПоПолису)";
		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОграничениеПодбораПоПолису", ?(ЗначениеЗаполнено(ПодборДоговорПолиса), УсловиеОграничениеПодбораПоПолису, "ИСТИНА"));
	
	Если ЗначениеЗаполнено(ПодборДоговорПолиса) Тогда
		Запрос.УстановитьПараметр("СсылкаДоговорПоПолису", ПодборДоговорПолиса);	
	КонецЕсли;
	
	ТаблицаНоменклатур = Запрос.Выполнить().Выгрузить();
	СписокЗначений = Новый СписокЗначений;
	
	Для Каждого СтрокаТЧ Из ТаблицаНоменклатур Цикл
		Представление = ПолучитьПредставлениеУслугиАвтоПодбора(СтрокаТЧ);
		СписокЗначений.Добавить(СтрокаТЧ.Номенклатура, Представление);
	КонецЦикла;
	
	Возврат СписокЗначений;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, получить представление строки авто подбора
//
Функция ПолучитьПредставлениеУслугиАвтоПодбора(СтруктураДанные)
	
	ПредставлениеНормыВремени = "";
	Если ЗначениеЗаполнено(СтруктураДанные.НормаВремени) Тогда
		ПредставлениеНормыВремени = Новый ФорматированнаяСтрока(",", Новый ФорматированнаяСтрока(" " + СтруктураДанные.НормаВремени + " мин",, Новый Цвет(0,112,210)));
	КонецЕсли;
	
	ПредставлениеЦены = "";
	Если ЗначениеЗаполнено(СтруктураДанные.Цена) Тогда
		
		СтранаУчета = Константы.СтранаУчета.Получить();  		
		
		ПредставлениеВалютыУчета = СтрРазделить(СтранаУчета.ВалютаУчета.ПараметрыПрописи, ",");
		
		НаименованиеВалюты = ?(ПредставлениеВалютыУчета.Количество() > 9, ПредставлениеВалютыУчета[9], "руб.");
		
		ПредставлениеЦены = Новый ФорматированнаяСтрока(",", Новый ФорматированнаяСтрока(" " + СтруктураДанные.Цена 
			+ НаименованиеВалюты,, ЦветаСтиля.ФайлЗанятыйТекущимПользователем));
		
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока((СтруктураДанные.Наименование), ПредставлениеНормыВремени, ПредставлениеЦены);
	
КонецФункции

&НаКлиенте
// Процедура - обработчик события "ОкончаниеВводаТекста"
//
Процедура ТаблицаЛечениеНоменклатураОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)

	Если ПерваяСсылкаВСпикеПодбораНоменклатуры = "ЭтоСтандартнаяОбработка" Тогда 
		
	ИначеЕсли ЗначениеЗаполнено(Объект.ПолисМедСтрахования) Тогда
		ТаблицаЛечениеНоменклатураАвтоПодбор(Элемент, Текст, ДанныеВыбора, 0.2, СтандартнаяОбработка)
		
	Иначе 	
		Если ПерваяСсылкаВСпикеПодбораНоменклатуры = Неопределено Тогда 
			Элемент.Родитель.ТекущиеДанные.Номенклатура	= ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
			
		ИначеЕсли ПерваяСсылкаВСпикеПодбораНоменклатуры <> Неопределено Тогда
			
			Элемент.Родитель.ТекущиеДанные.Номенклатура	= ПерваяСсылкаВСпикеПодбораНоменклатуры;
			ДанныеВыбора                      			= Неопределено;
			ПерваяСсылкаВСпикеПодбораНоменклатуры 		= Неопределено;
			ТаблицаУслугиНоменклатураПриИзменении(Элемент);
			
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// При изменении выбора номенклатуры
//
Процедура ТаблицаУслугиНоменклатураПриИзмененииСервер(ИдентификаторыИзмененныхСтрок,ПересчетТЧПослеизменения = Ложь, СтруктураДанныеПолиса = Неопределено)

	ИдентификаторыСтрок = Неопределено;
	
	Если ТипЗнч(ИдентификаторыИзмененныхСтрок) = Тип("Массив") Тогда
		ИдентификаторыСтрок = ИдентификаторыИзмененныхСтрок;
	Иначе
		ИдентификаторыСтрок = Новый Массив;
		ИдентификаторыСтрок.Добавить(ИдентификаторыИзмененныхСтрок);
	КонецЕсли;
	
	Для Каждого ЭлИдентификаторСтроки Из ИдентификаторыСтрок Цикл
		// Получаем строку ТЧ
		СтрокаТабличнойЧасти = Объект.Лечение.НайтиПоИдентификатору(ЭлИдентификаторСтроки);	
		// Получение данных ценообразования
		СтруктураДанные = Новый Структура();
		СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
		СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
		СтруктураДанные.Вставить("ВидЦен", 				?(ЗначениеЗаполнено(_ПодборДоговорПолиса) И ЗначениеЗаполнено(_ПодборДоговорПолиса.ВидЦен), _ПодборДоговорПолиса.ВидЦен, Объект.ВидЦен));	
		СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
		СтруктураДанные.Вставить("Упаковка", 			СтрокаТабличнойЧасти.Упаковка);
		
		СтруктураДанные               = Ценообразование.ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);	
		СтрокаТабличнойЧасти.Цена     = СтруктураДанные.Цена;
		СтрокаТабличнойЧасти.Упаковка = СтруктураДанные.Упаковка;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.Количество) Тогда
			СтрокаТабличнойЧасти.КоличествоУпаковок = 1;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.ВидЦен = Объект.ВидЦен;
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
			СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.СкидкиЗапрещены = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "СкидкиЗапрещены");
			Если СтрокаТабличнойЧасти.СкидкиЗапрещены Тогда
			СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
			СтрокаТабличнойЧасти.СуммаРучнойСкидки = 0;
			// ТекущийЭлемент.ПодчиненныеЭлементы.ТаблицаЛечениеПроцентСкидкиНаценки.ТолькоПросмотр = Истина;
		КонецЕсли;
		
		Если Константы.ИспользоватьУЕТ.Получить() = Истина Тогда
			СтрокаТабличнойЧасти.УЕТ = СтрокаТабличнойЧасти.Номенклатура.УЕТ;
		КонецЕсли;	
		
		ОбработкаТабличныхЧастейКлиент.ПересчитатьКоличествоЕдиницВСтрокеТЧКлиент(СтрокаТабличнойЧасти);
		СтрокаТабличнойЧасти.Гарантия = СтрокаТабличнойЧасти.Номенклатура.Гарантия;
		// Работа с табличной частью материалы
		// Предварительно удаляем материалы предыдущей услуги
		ТабличныеЧастиУдалитьСтрокиСервер("Материалы", СтрокаТабличнойЧасти.КлючСтроки);
		// Добавляем материалы данной услуги 
		НормыСписанияМатериалов = РегистрыСведений.НормыСписанияМатериалов.ПолучитьНормыСписанияМатериалов(СтрокаТабличнойЧасти.Номенклатура, Объект.СтруктурнаяЕдиница);
		
		Для Каждого СтрокаТЧ ИЗ НормыСписанияМатериалов Цикл
			
			НоваяСтрока                     = Объект.Материалы.Добавить();
			НоваяСтрока.КлючСтроки          = СтрокаТабличнойЧасти.КлючСтроки;
			НоваяСтрока.Услуга              = СтрокаТабличнойЧасти.Номенклатура;
			НоваяСтрока.Материал            = СтрокаТЧ.Материал;
			НоваяСтрока.КоличествоУпаковок  = ?(СтрокаТЧ.НеЗависитОтКоличестваУслуг, СтрокаТЧ.Количество, СтрокаТЧ.Количество * ?(СтрокаТабличнойЧасти.КоличествоУпаковок = 0, 1, СтрокаТабличнойЧасти.КоличествоУпаковок));
			НоваяСтрока.Количество          = НоваяСтрока.КоличествоУпаковок * ?(ЗначениеЗаполнено(СтрокаТЧ.Упаковка.Коэффициент), СтрокаТЧ.Упаковка.Коэффициент, 1);
			НоваяСтрока.Упаковка            = СтрокаТЧ.Упаковка;
			НоваяСтрока.Партия              = СтрокаТЧ.Партия;
			НоваяСтрока.Склад               = РегистрыСведений.НормыСписанияМатериалов.ПолучитьСкладСписанияНормМатериалов(СтрокаТЧ, Объект.СтруктурнаяЕдиница, Объект.Сотрудник);
			НоваяСтрока.Сотрудник           = Объект.Сотрудник;
			НоваяСтрока.ВключатьВСтоимость  = СтрокаТЧ.ВключатьВСтоимостьУслуги;
			НоваяСтрока.ВидЦен				= СтрокаТЧ.ВидЦен;
			
		КонецЦикла;
		
		СтрокаТабличнойЧасти.Цена     = РассчитатьЦенуПоМатериалам(СтрокаТабличнойЧасти.КлючСтроки);

		СтрокаТабличнойЧасти.КодУслуги = СтрокаТабличнойЧасти.Номенклатура.КодУслуги;
		                    		
		ТабличныеЧастиРассчитатьСуммуВСтрокеСервер("Лечение", ЭлИдентификаторСтроки);
	КонецЦикла;
	
	// Пересчитатть таблицу лечение
		Если ПересчетТЧПослеизменения Тогда
		ТабличныеЧастиПересчетПослеИзменений("Лечение", ИдентификаторыСтрок);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) 
		И ПолучитьЗначениеБесплатно(СтрокаТабличнойЧасти.Номенклатура) Тогда
		
		СтрокаТабличнойЧасти.Цена = 0;
		СтрокаТабличнойЧасти.Сумма = 0;
		СтрокаТабличнойЧасти.СуммаАвтоматическойСкидкиНаценки = 0;
		СтрокаТабличнойЧасти.СуммаРучнойСкидки = 0;

	КонецЕсли;    	
			
	Если НЕ СтруктураДанныеПолиса = Неопределено Тогда
		Если СтруктураДанныеПолиса.Свойство("Результат") ИЛИ
			СтруктураДанныеПолиса.Свойство("ПолисСогласование") ИЛИ
			СтруктураДанныеПолиса.Свойство("СогласованиеПриПревышении") Тогда
				
			СтрокаТабличнойЧасти.ТребуетсяСогласование = СтруктураДанныеПолиса.ПолисСогласование;			
			
			Если НЕ СтруктураДанныеПолиса.СогласованиеПриПревышении = Неопределено И СтруктураДанныеПолиса.СогласованиеПриПревышении = Ложь Тогда
				СтрокаТабличнойЧасти.ТребуетсяСогласование = Неопределено;			
			КонецЕсли; 
			
			Если НЕ СтруктураДанныеПолиса.Результат = Неопределено И ЗначениеЗаполнено(СтрокаТабличнойЧасти.ТребуетсяСогласование) Тогда 
				СтрокаТабличнойЧасти.СтатусСогласования = СтруктураДанныеПолиса.Результат;
			КонецЕсли; 
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере
// Функция, пересчитывает цену услуги в зависимости от используемых материалов.
//
Функция РассчитатьЦенуПоМатериалам(КлючСтроки)
	
	ТекущаяСтрока = Объект.Лечение.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки))[0];
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ДатаОбработки"	 , Объект.Дата);
	СтруктураДанных.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	СтруктураДанных.Вставить("Номенклатура"		 , ТекущаяСтрока.Номенклатура);
	СтруктураДанных.Вставить("ВидЦен"			 , ?(ЗначениеЗаполнено(_ПодборДоговорПолиса), _ПодборДоговорПолиса.ВидЦен, Объект.ВидЦен));
	СтруктураДанных.Вставить("Упаковка"			 , ТекущаяСтрока.Упаковка);
	СтруктураДанных.Вставить("СтавкаНДС"		 , ТекущаяСтрока.СтавкаНДС);
	
	Цена = Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураДанных);
	ЦенаМатериалы = 0;
	Для Каждого СтрокаМ Из Объект.Материалы Цикл
		Если ТекущаяСтрока.Номенклатура = СтрокаМ.Услуга И СтрокаМ.ВключатьВСтоимость И СтрокаМ.КлючСтроки = КлючСтроки Тогда
			
			СтруктураДанных = Новый Структура;
			СтруктураДанных.Вставить("ДатаОбработки"	 , Объект.Дата);
			СтруктураДанных.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
			СтруктураДанных.Вставить("Номенклатура"		 , СтрокаМ.Материал);
			СтруктураДанных.Вставить("ВидЦен"			 , СтрокаМ.ВидЦен);
			СтруктураДанных.Вставить("Упаковка"			 , СтрокаМ.Упаковка);
			СтруктураДанных.Вставить("СтавкаНДС"		 , ТекущаяСтрока.СтавкаНДС);
			
			ЦенаМатериалы = ЦенаМатериалы + Ценообразование.ПолучитьЦенуНоменклатуры(СтруктураДанных) * СтрокаМ.Количество;
			
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Цена + ЦенаМатериалы / ТекущаяСтрока.Количество;
	
КонецФункции	

