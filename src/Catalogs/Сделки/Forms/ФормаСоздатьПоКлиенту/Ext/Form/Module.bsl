&НаСервере
// Процедура, заполняет элементы формы.
Процедура ЗаполнениеЭлементовФормы()
	
	Если Параметры.Свойство("ВыбранныйПараметр") Тогда
		ЭтотОбъект.СоздатьЗадачу = (Параметры.ВыбранныйПараметр = "СоздатьЗадачиПоКлиентам");
	КонецЕсли;
	
	Если Параметры.Свойство("ВыделенныеЭлементы") Тогда
		Элементы.ВзаимодействиеПрименитьКВыделенным.Заголовок = СтрШаблон(НСтр("ru='К выбранным (%1)';en='TO selected (%1)'"), Параметры.ВыделенныеЭлементы);
	КонецЕсли;
	
	Если Параметры.Свойство("Количество") Тогда
		Элементы.ВзаимодействиеПрименитьКоВсем.Заголовок = СтрШаблон(НСтр("ru='Ко всем (%1)';en='To to all (%1)'"), Параметры.Количество);		
	КонецЕсли;
	
	ЭтотОбъект.ВзаимодействиеПараметры = Неопределено;
	
	Если ЭтотОбъект.СоздатьЗадачу Тогда
		
		// Подтягиваем первый вид задачи из списка.
		Если ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора.Количество() > 0 Тогда
			Взаимодействие = ЭтотОбъект.ВзаимодействиеЗадачаСписокВыбора[0];
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Пустая таблица видов взаимодействия';en='Empty table species interactions'"));
			Возврат;
		КонецЕсли;
		
		// Заполняем произвольный реквизит формы.
	ЭтотОбъект.ВзаимодействиеПараметры = Новый Структура;
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Взаимодействие"   , Взаимодействие.Значение.Взаимодействие);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("ВидВзаимодействия", Взаимодействие.Значение.ВидВзаимодействия);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("ТемаПоУмолчанию"  , Взаимодействие.Значение.ТемаПоУмолчанию);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Представление"    , Взаимодействие.Представление);
		ЭтотОбъект.ВзаимодействиеПараметры.Вставить("Картинка"         , Взаимодействие.Картинка);
		
		Элементы.ВыбратьВидЗадачи.Заголовок 			 = Взаимодействие.Значение.ВидВзаимодействия; 
		Элементы.ДекорацияВзаимодействиеИконка.Картинка  = Взаимодействие.Картинка; 
		Элементы.ДекорацияВзаимодействиеИконка.Видимость = Взаимодействие.Картинка.Вид <> ВидКартинки.Пустая;
		
		// Установить тему по умолчанию.
		ЭтотОбъект.ВзаимодействиеЗадачаТема  = ЭтотОбъект.ВзаимодействиеПараметры.ТемаПоУмолчанию;
		ЭтотОбъект.ВзаимодействиеОписание = "";
		
		// Установить дату взаимодействия.
		ЭтотОбъект.ВзаимодействиеЗадачаДата = ПолучитьОкругленноеВремяВзаимодействия();	
		ВзаимодействиеЗадачаДатаПриИзмененииНаСервере();
		
		// Обновить режим напоминания взаимодействия.
		РежимНапоминанияПоУмолчанию = ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминанияСписокВыбора[0];		
		
		ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминания    = РежимНапоминанияПоУмолчанию.Значение;
		Элементы.ВзаимодействиеЗадачаНапоминание.Заголовок = РежимНапоминанияПоУмолчанию.Представление;

	Иначе
					
		// Устанавливаем первый попавшийся вид сделки.
		МассивВидовСделок = ПолучитьВидыСделок();
		Если МассивВидовСделок.Количество() > 0 Тогда
			ЭтотОбъект.ВидСделки = МассивВидовСделок[0];
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, показать всплывающую группу "ГруппаВзаимодействиеЗадачаВсплывающая".
// Устанавливает видимость элементов группы, а так же показывает группу.
//
Процедура УстановитьВидимостьЭлементов()
	
	Если ЭтотОбъект.СоздатьЗадачу Тогда
		
		Элементы.ВзаимодействиеЗадачаПрочееТема.Видимость 	= Истина;
		Элементы.ВзаимодействиеЗадачаНапоминание.Видимость 	= Истина;
		Элементы.ГруппаВзаимодействиеВид.Видимость			= Истина;
		Элементы.ГруппаВзаимодействиеЗадачаДата.Видимость	= Истина;
		Элементы.ГруппаВидСделки.Видимость					= Ложь;
		
	Иначе
			
		Элементы.ВзаимодействиеЗадачаПрочееТема.Видимость 	= Ложь;
		Элементы.ВзаимодействиеЗадачаНапоминание.Видимость 	= Ложь;
		Элементы.ГруппаВзаимодействиеВид.Видимость			= Ложь;
		Элементы.ГруппаВзаимодействиеЗадачаДата.Видимость	= Ложь;	
		Элементы.ГруппаВидСделки.Видимость					= Истина;	
		
	КонецЕсли;
	
	Элементы.ГруппаВзаимодействиеПрименитьОбщая.Доступность = ЗначениеЗаполнено(ТаблицаДействия);
	
КонецПроцедуры

&НаСервере
// Процедура, ЗаполнитьПроцентомСтрокиТаблицыЗначений.
//
// Описание:
//
//
// Параметры (название, тип, дифференцированное значение)
//
Процедура ЗаполнитьПроцентомСтрокиТаблицыЗначений()
	
	КолвоЭлементов = ЭтотОбъект.ТаблицаДействия.Количество();
	ЭтотОбъект.ОстаточныйПроцентОтДеления = 0;
	
	Если КолвоЭлементов > 0 Тогда
		
		Процентов  		   = Цел(100/КолвоЭлементов);
		НедостающийПроцент = 100 - (Процентов*КолвоЭлементов);
		
		Для Каждого СтрокаТЗ Из ЭтотОбъект.ТаблицаДействия Цикл
			СтрокаТЗ.Пропорция = Процентов;
		КонецЦикла;	
		
		ЭтотОбъект.ОстаточныйПроцентОтДеления = НедостающийПроцент;
		Элементы.ГруппаВзаимодействиеПрименитьОбщая.Доступность = НедостающийПроцент = 0;
		
	Иначе
		Элементы.ГруппаВзаимодействиеПрименитьОбщая.Доступность = Ложь;	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура, УдалитьПустыеСтрокиСотрудников.
//
Процедура УдалитьПустыеСтрокиСотрудников()
	
	МассивПустыхСтрок = ЭтотОбъект.ТаблицаДействия.НайтиСтроки(Новый Структура("Сотрудник", ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка")));
	Для Каждого СтрокаМассива Из МассивПустыхСтрок Цикл		
		ЭтотОбъект.ТаблицаДействия.Удалить(ЭтотОбъект.ТаблицаДействия.Индекс(СтрокаМассива));	
	КонецЦикла;	
	
КонецПроцедуры

