// Процедура, обработчик события "ПриАктивизацииСтроки"
//
Процедура ТаблицаТекущиеКлиентыПриАктивизацииСтроки(Элемент)
	
	// При создании формы обработчик отработает автоматически
	// необходимо отменить его срабатывание
	Если НЕ ТаблицаОбслуживаниеКлиентовПерваяАктивация Тогда
		ТаблицаОбслуживаниеКлиентовПерваяАктивация   = Истина;
		Возврат;
	КонецЕсли;		
	
	ОбработатьВыборКонтрагентаВТаблицеТекущиеКлиенты(Элементы.ТаблицаТекущиеКлиенты.ТекущиеДанные);	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриАктивизацииЯчейки".
//
Процедура ТаблицаТекущиеКлиентыПриАктивизацииЯчейки(Элемент)
	
	Если ЭтаФорма.ТекущийЭлемент.Имя = "ТаблицаТекущиеКлиенты" И
		(ЭтаФорма.ТекущийЭлемент.ТекущийЭлемент.Имя = "ДеревоТекущихКлиентовКлиент"
		ИЛИ ЭтаФорма.ТекущийЭлемент.ТекущийЭлемент.Имя = "ДеревоТекущихКлиентовВремяЗаписи"
		ИЛИ ЭтаФорма.ТекущийЭлемент.ТекущийЭлемент.Имя = "ДеревоТекущихКлиентовВрач") Тогда		
			
		ОбработатьВыборКонтрагентаВТаблицеТекущиеКлиенты(Элементы.ТаблицаТекущиеКлиенты.ТекущиеДанные);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриАктивизацииСтроки"
//
Процедура ТаблицаНЕ_ТекущиеКлиентыПриАктивизацииСтроки(Элемент)
	
	// При создании формы обработчик отработает автоматически
	// необходимо отменить его срабатывание
	Если НЕ ТаблицаНЕ_ОбслуживаниеКлиентовПерваяАктивация Тогда
		ТаблицаНЕ_ОбслуживаниеКлиентовПерваяАктивация   = Истина;
		Возврат;
	КонецЕсли;		
	// Если Элементы.ТаблицаНЕ_ТекущиеКлиенты.ТекущиеДанные <> Неопределено И НЕ Элементы.ТаблицаНЕ_ТекущиеКлиенты.ТекущиеДанные.Ссылка.Пустая() Тогда
	//	УстановитьДоступностьКнопкиОплатить(Элементы.ТаблицаНЕ_ТекущиеКлиенты.ТекущиеДанные.Ссылка);
	// КонецЕсли;
	
	ТаблицаТекущиеДанные = Элементы.ТаблицаНЕ_ТекущиеКлиенты.ТекущиеДанные;
	Если Элементы.ТаблицаНЕ_ТекущиеКлиенты.Видимость = Истина 
		И ТаблицаТекущиеДанные <> Неопределено 
		И НЕ ТаблицаТекущиеДанные.Клиент.Пустая()
		И НЕ Контрагент = ТаблицаТекущиеДанные.Клиент Тогда
		
		Контрагент = ТаблицаТекущиеДанные.Клиент;
		КонтрагентПриИзменении(Неопределено);
		
