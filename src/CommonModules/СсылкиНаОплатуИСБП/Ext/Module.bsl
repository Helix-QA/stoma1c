// Функция - Сформировать массив элементов для фискализации сбербанк
//
// Параметры:
//  ТаблицаЗадолженностей	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_СформироватьМассивЭлементовДляФискализации(ТаблицаЗадолженностей, СтруктураПараметров, ЭтоЧастичнаяОплата = Ложь) Экспорт
   	
	Если ЗначениеЗаполнено(ТаблицаЗадолженностей) И ТипЗнч(ТаблицаЗадолженностей[0].ДокументЗадолженности) = Тип("ДокументСсылка.Реализация") Тогда 
		
		ТаблицаЧека 				= ПолучитьТаблицуЗапасовРеализаций(ТаблицаЗадолженностей);
		
		items 	   = Новый Массив;
		positionId = 1;   // Индекс товара к корзине
		
		СуммаПоТаблицеЗапасов = 0;
		Для Каждого ДокументПродажи Из ТаблицаЗадолженностей Цикл
			
			СуммаОплаты = ДокументПродажи.Задолженность;
			
			МассивЗапасов = Документы.Реализация.ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ(ДокументПродажи.ДокументЗадолженности, СтруктураПараметров.КассаОплаты, СуммаОплаты, ДокументПродажи.Оплачено = 0,, Истина);
			НовыйМассивЗапасов = ФорматоЛогическийКонтрольРаздленияСтрок(МассивЗапасов);
			
			Для Каждого СтрокаТЧ Из НовыйМассивЗапасов Цикл
								
				НайденнаяСтрока = ТаблицаЧека.Найти(СтрокаТЧ.Номенклатура, "Номенклатура");
				
				СтрокаТЧ.Вставить("ВидУслуги"			, ?(НайденнаяСтрока <> Неопределено, НайденнаяСтрока.ВидУслуги, Неопределено));
				СтрокаТЧ.Вставить("ТипНоменклатуры"		, ?(НайденнаяСтрока <> Неопределено, НайденнаяСтрока.ТипНоменклатуры, Неопределено));
				СтрокаТЧ.Вставить("СписыватьПриПродаже"	, ?(НайденнаяСтрока <> Неопределено, НайденнаяСтрока.СписыватьПриПродаже, Неопределено));
					
				ПризнакСпособаРасчета	= Сбербанк_ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(СтрокаТЧ);
				ПризнакПредметаРасчета	= Сбербанк_ПризнакПредметаРасчетаПриПродажеИлиВозврате(СтрокаТЧ);
				
				// Количество
				quantity = Новый Структура;
				quantity.Вставить("value"  , СтрокаТЧ.Количество);
				quantity.Вставить("measure", "шт.");
				
				// Ставка НДС
				tax = Новый Структура;
				//tax.Вставить("taxType", api_ОбщегоНазначения.ПолучитьПредставлениеСтавкиНДС_v3(СтрокаТЧ.СтавкаНДС, СтрокаТЧ.СуммаВключаетНДС));
                tax.Вставить("taxSum" , СтрокаТЧ.СуммаНДС);
				
				// Признак способа расчета 
				paymentMethod = Новый Структура;
				paymentMethod.Вставить("name", "paymentMethod");
				paymentMethod.Вставить("value", ПризнакСпособаРасчета); 
				
				// Признак предмета расчета
				paymentObject = Новый Структура;
				paymentObject.Вставить("name", "paymentObject");
				paymentObject.Вставить("value", ПризнакПредметаРасчета); 
				
				attributes = Новый Массив;
				attributes.Добавить(paymentMethod);
				attributes.Добавить(paymentObject);
				
				itemAttributes = Новый Структура;
				itemAttributes.Вставить("attributes", attributes);
				
				СтруктураТовара = Новый Структура;
				СтруктураТовара.Вставить("positionId"	 , positionId); 
				СтруктураТовара.Вставить("name"			 , СформироватьОписаниеЗаказа(СтрокаТЧ.Наименование));
				СтруктураТовара.Вставить("quantity"		 , quantity); 
				СтруктураТовара.Вставить("itemCode"		 , Строка(СтрокаТЧ.Номенклатура.УникальныйИдентификатор()));
				СтруктураТовара.Вставить("tax"			 , tax);
				СтруктураТовара.Вставить("itemPrice"	 , СтрокаТЧ.ЦенаСоСкидками*100); 
				СтруктураТовара.Вставить("itemAmount"	 , СтрокаТЧ.Сумма*100);	
				СтруктураТовара.Вставить("itemAttributes", itemAttributes); 
				
				СуммаПоТаблицеЗапасов = СуммаПоТаблицеЗапасов + СтрокаТЧ.Сумма;
				
				items.Добавить(СтруктураТовара);
				
				positionId = positionId + 1;
				
			КонецЦикла;
		КонецЦикла;
				
		cartItems = Новый Структура;
		cartItems.Вставить("items", items);
		
		orderBundle = Новый Структура;
		orderBundle.Вставить("cartItems", cartItems);
		
		Payments = СформироватьВидыОплат(ТаблицаЗадолженностей, СуммаПоТаблицеЗапасов);		
		ЭтоЧастичнаяОплата = Payments.Credit > 0;
		
		ПараметрыOrderBundle = КодироватьВJSON(orderBundle, Ложь);
		
		ПараметрыЗапроса = "&orderBundle=" + ПараметрыOrderBundle;
		
	КонецЕсли;
	
	Возврат ПараметрыЗапроса;
	
КонецФункции

// Функция - Получить признак способа расчета для Сбербанка.
//
// Параметры:
//  СтрокаТЧ					 - 	 - 
//  АвансоваяСхемаПробитияУслуг	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
// 1 - полная предварительная оплата до момента передачи предмета расчёта;
// 2 - частичная предварительная оплата до момента передачи предмета расчёта;
// 3 - аванс;
// 4 - полная оплата в момент передачи предмета расчёта;
// 5 - частичная оплата предмета расчёта в момент его передачи с последующей оплатой в кредит;
// 6 - передача предмета расчёта без его оплаты в момент его передачи с последующей оплатой в кредит;
// 7 - оплата предмета расчёта после его передачи с оплатой в кредит.
//
Функция Сбербанк_ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(СтрокаТЧ)  
	
	PaymentMethod = ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(СтрокаТЧ); 
	
	Если PaymentMethod = "advance" Тогда        	 // Аванс
		Возврат 3;
	ИначеЕсли PaymentMethod = "credit_payment" Тогда // Кредит 
		Возврат 7;
	ИначеЕсли PaymentMethod = "full_payment" Тогда   // ВыплатаПлатеж
		Возврат 4;
	ИначеЕсли PaymentMethod = "partial_payment" Тогда
		Возврат 2; 
	ИначеЕсли PaymentMethod = "full_prepayment" Тогда
		Возврат 1;
	КонецЕсли;
	
КонецФункции

// Функция - Получить признак предмета расчета для Сбербанка.
//
// Параметры:
//  СтрокаТЧ					 - 	 - 
//  АвансоваяСхемаПробитияУслуг	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
// 1 - товар;
// 2 - подакцизный товар;
// 3 - работа;
// 4 - услуга;
// 5 - ставка азартной игры;
// 6 - выигрыш азартной игры;
// 7 - лотерейный билет;
// 8 - выигрыш лотереи;
// 9 - предоставление РИД;
// 10 - платеж;
// 11 - агентское вознаграждение;
// 12 - составной предмет расчёта;
// 13 - иной предмет расчёта;
// 14 - имущественное право;
// 15 - внереализационный доход;
// 16 - страховые взносы: о суммах расходов, уменьшающих сумму налога (авансовых платежей) в соответствии с пунктом 3.1 статьи 346.21 Налогового кодекса Российской Федерации;
// 17 - торговый сбор: о суммах уплаченного торгового сбора;
// 18 - курортный сбор.
//
Функция Сбербанк_ПризнакПредметаРасчетаПриПродажеИлиВозврате(СтрокаТЧ) Экспорт 
	
	PaymentObject = ПризнакПредметаРасчетаПриПродажеИлиВозврате(СтрокаТЧ); 
	
	Если PaymentObject = "service" Тогда        // Услуга
		Возврат 4;
	ИначеЕсли PaymentObject = "commodity" Тогда // Товар 
		Возврат 1;
	ИначеЕсли PaymentObject = "payment" Тогда   // ВыплатаПлатеж
		Возврат 10;
	Иначе
		Возврат 1;								
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область СДМ

// Функция - СДМ зарегистрировать QR
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СДМ_ЗарегистрироватьQR(СтруктураПараметров)
	
	ПараметрыПШ	= СтруктураПараметров.ПараметрыПШ;
	НомерЗаказа = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьМассимальныйНомерЗаказа(Перечисления.ТипыСсылокНаОплату.СБПСДМ) + 1;
	НомерЗаказа = ?(НомерЗаказа = 1, 1000000, НомерЗаказа); // Номер заказа начинается от 7ми цифр
	
	НомерИтерации = 0;
	Пока НомерИтерации < 20 Цикл // На случай, если данный номер заказа уже создан каким-то чудом в СДМ банке.
		
		РезультатЗапроса = СДМ_СозданиеЗаказа(СтруктураПараметров, НомерЗаказа);
				
		Если РезультатЗапроса.ВыполненоУспешно = Ложь И РезультатЗапроса.ПараметрыРезультата <> Неопределено 
			И РезультатЗапроса.ПараметрыРезультата.Свойство("errorCode") И НРег(РезультатЗапроса.ПараметрыРезультата.errorCode) = НРег("P003") Тогда
			НомерЗаказа = НомерЗаказа + 1;		
		Иначе
			Прервать;	
		КонецЕсли;
		
		НомерИтерации = НомерИтерации + 1;
		
	КонецЦикла;
	
	Если РезультатЗапроса.ВыполненоУспешно Тогда
		
		Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл	
			
			КороткаяСсылка 	= РезультатЗапроса.ПараметрыРезультата.paymentUrl; //ОбщегоНазначения.ПолучитьКороткуюСсылку(РезультатЗапроса.ПараметрыРезультата.Data);
			
			РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
			СтрокаТ.ДокументЗадолженности,
			СтрокаТ.Задолженность,
			Формат(РезультатЗапроса.ПараметрыРезультата.PaymentId,"ЧГ=0"),
			КороткаяСсылка,
			Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено,
			СтруктураПараметров.ЭквайринговыйТерминал,
			НомерЗаказа,,,
			СтруктураПараметров.Контрагент,,
			СтруктураПараметров.СтруктурнаяЕдиница,
			ТекущаяДатаСеанса(),,
			Перечисления.ТипыСсылокНаОплату.СБПСДМ,
			ПараметрыСеанса.ТекущийПользователь,
			ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600
			);
			
		КонецЦикла;
		
		РезультатЗапроса.Вставить("СсылкаНаОплату"		, КороткаяСсылка);
		РезультатЗапроса.Вставить("ВремяДействителенДо"	, ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600);
		РезультатЗапроса.Вставить("НомерЗаказа"			, НомерЗаказа);
		
	КонецЕсли;
	
	Возврат РезультатЗапроса;	
	
КонецФункции

// Функция - СДМ создание заказа
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СДМ_СозданиеЗаказа(СтруктураПараметров, НомерЗаказа)
	
	ПараметрыПШ 	= СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 	= СтруктураПараметров.СуммаОплаты;
	ВнешняяСистема	= Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.СистемаБыстрыхПлатежей, Истина);
	
	ЗаголовкиHTTP = Новый Соответствие;		
	ЗаголовкиHTTP.Вставить("Accept-Language"	, "ru");	
	ЗаголовкиHTTP.Вставить("Content-Type"		, "application/json");
		
	НастройкиСериализацииJSON = Новый НастройкиСериализацииJSON;
	НастройкиСериализацииJSON.ВариантЗаписиДаты 	 = ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением;
	НастройкиСериализацииJSON.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
		
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("ecommKey"		, Число(ПараметрыПШ.КлючМерчанта));
	ПараметрыЗапроса.Вставить("amount"			, СуммаОплаты); 
	ПараметрыЗапроса.Вставить("orderId"			, НомерЗаказа);
	ПараметрыЗапроса.Вставить("description"		, "Оплата по структурной единице: " + Строка(СтруктураПараметров.СтруктурнаяЕдиница));
	ПараметрыЗапроса.Вставить("dueDate"			, ТекущаяДатаСеанса() + ПараметрыПШ.ВремяЖизни*3600); // Максимальный срок - 30 дней. Значение по умолчанию - 1 день.	
	ПараметрыЗапроса.Вставить("paymentType"		, "SBP"); 
	ПараметрыЗапроса.Вставить("notificationUrl"	, "https://cloud.stoma1c.ru/api/hs/api/sbp/" + ВнешняяСистема.КлючПриложения);
	
	Если ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтруктураПараметров.ЭквайринговыйТерминал, "ТипФискализации") = Перечисления.ТипыФискализации.ВСДМБанке Тогда
		
		ЭтоЧастичнаяОплата = Ложь;
		ПараметрыReceipt = СтруктураTinkoffReceipt(СтруктураПараметров, Истина, ЭтоЧастичнаяОплата);	
		
		Если ЭтоЧастичнаяОплата = Истина Тогда
			РезультатОперации = СтруктураСтандартныхПараметровРезОперации();
			РезультатОперации.ОписаниеОшибки = "При фискализации на стороне СДМ банка запрещены частичные оплаты.";
			Возврат РезультатОперации;			
		Иначе 
			ПараметрыЗапроса.Вставить("receipt", ПараметрыReceipt);
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыЗапроса.Вставить("token", Тинькофф_СформироватьПодписьЗапроса(ПараметрыЗапроса, ПараметрыПШ.ПарольКлючаМерчанта));
	
	ТекстЗапроса = КодироватьВJSON(ПараметрыЗапроса,, НастройкиСериализацииJSON);
		
	АдресСервера 	= ?(ПараметрыПШ.ТестовыйРежим, "payment-test.sdm.ru", "payment.sdm.ru");
	Соединение		= Новый HTTPСоединение(АдресСервера,,,,,5, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос		= Новый HTTPЗапрос("/init/", ЗаголовкиHTTP);			
	HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса);		
	
	Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Success И НРег(РезультатЗапроса.Status) = НРег("NEW");
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь, 
			РезультатЗапроса.message, ТелоОтвета);
			
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - СДМ отменить QRКод
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СДМ_ОтменитьQRКод(СтруктураПараметров)
	
	ДокументыЗадолженности = Новый Массив;
	Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл
		ДокументыЗадолженности.Добавить(СтрокаТ.ДокументЗадолженности);	
	КонецЦикла;
	
	РезультатОперации			= СтруктураПараметров.СтруктураВозврата;
	ПараметрыПШ  				= СтруктураПараметров.ПараметрыПШ;
	НомерЗаказа					= ?(СтруктураПараметров.Свойство("НомерЗаказа"), СтруктураПараметров.НомерЗаказа, Неопределено);
	
	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьЗаказыПоДокументам(ДокументыЗадолженности, СтруктураПараметров.ЭквайринговыйТерминал, НомерЗаказа);
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		РезультатОперации.ОписаниеОшибки = "Не найдено неоплаченных заказов по данной ссылке";
		Возврат РезультатОперации;	
	КонецЕсли;
	
	МассивИдСБП = Новый Массив;
	Для Каждого СтрокаЗаказа Из ТаблицаЗаказов Цикл
		
		Если МассивИдСБП.Найти(СтрокаЗаказа.ИдЗаказа) = Неопределено Тогда
									
			РезультатОперации = СДМ_ОтменитьQRКодЗапрос(СтрокаЗаказа.ИдЗаказа, ПараметрыПШ);
			
			Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
				Возврат РезультатОперации;	
			КонецЕсли;
			
			МассивИдСБП.Добавить(СтрокаЗаказа.ИдЗаказа);
			
		КонецЕсли;
		
		ОписаниеСтатуса  = НСтр("ru='Платеж отменен пользователем ';en='Payment canceled by user '") + Строка(ПараметрыСеанса.ТекущийПользователь);
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаЗаказа.Основание,,,,
		Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ,,
		СтрокаЗаказа.НомерЗаказа,,,,,,,
		ОписаниеСтатуса);
				
	КонецЦикла;
	
	Возврат РезультатОперации;
	
КонецФункции

