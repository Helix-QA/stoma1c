&НаКлиенте
// Процедура, обновляет представление периода действия скидки.
//
Процедура ОбновитьПредставлениеПериода()
	
	Элементы.ПериодНакопленияТип.СписокВыбора[0].Представление = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Месяц", Объект.ПериодНакопления);
	Элементы.ПериодНакопленияТип.СписокВыбора[1].Представление = СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("День" , Объект.ПериодНакопления);
	
КонецПроцедуры

&НаСервере
Процедура УправлениеВидимостью()
	
	Если (Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Сумма
		ИЛИ Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Количество)
		И Объект.ОбъектСкидки = Перечисления.ОбъектСкидок.ПоПродажам Тогда
		
		Элементы.ПериодНакопленияТип.Видимость = Истина;
		Объект.ПериодНакопленияТип			   = ?(НЕ ЗначениеЗаполнено(Объект.ПериодНакопленияТип), Перечисления.Периодичность.Месяц, Объект.ПериодНакопленияТип);
	ИначеЕсли Не Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.НомерПокупки Тогда 
		Элементы.ПериодНакопленияТип.Видимость = Ложь;
		Объект.ПериодНакопленияТип			   = Перечисления.Периодичность.ПустаяСсылка();
	КонецЕсли;
	
	Если Объект.ОбъектСкидки = Перечисления.ОбъектСкидок.НаДокумент Тогда
		Элементы.ВидСравненияУсловия1.Видимость 	= Истина;
		Элементы.ЗначениеУсловия1.Видимость 		= Истина;
		Элементы.ВидСравненияУсловия.Видимость 		= Ложь;
		Элементы.ЗначениеУсловия.Видимость 			= Ложь;		
		Элементы.ОбъектСкидки.МаксимальнаяШирина	= 15;	
	Иначе 
		Элементы.ВидСравненияУсловия1.Видимость 	= Ложь;
		Элементы.ЗначениеУсловия1.Видимость 		= Ложь;
		Элементы.ВидСравненияУсловия.Видимость 		= Истина;
		Элементы.ЗначениеУсловия.Видимость 			= Истина;				
		Элементы.ОбъектСкидки.МаксимальнаяШирина 	= 7; 	
	КонецЕсли;
	
	Если Объект.ПериодНакопленияТип = Перечисления.Периодичность.ПустаяСсылка() Тогда
		Элементы.ОбъектНакопленияНомерПокупки.МаксимальнаяШирина 	= 9;
		Элементы.ПериодНакопленияТипНомерПокупки.МаксимальнаяШирина = 15;
	Иначе 
		Элементы.ОбъектНакопленияНомерПокупки.МаксимальнаяШирина 	= 7;
		Элементы.ПериодНакопленияТипНомерПокупки.МаксимальнаяШирина = 6;
	КонецЕсли;	
	
	Если Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
		Элементы.ЗначениеСкидкиНаценкиВидБонусногоСчета.МаксимальнаяШирина = 26;
	Иначе 
		Элементы.ЗначениеСкидкиНаценкиВидБонусногоСчета.МаксимальнаяШирина = 25;
	КонецЕсли;	
	
	// Элементы ДняРождения
	Если Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.ДеньРождения Тогда
		
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеДеньРождения;
		Элементы.ГруппаУП2.Видимость = Ложь;
		Элементы.ГруппаУП3.Видимость = Истина;		
		Элементы.СпособПредоставленияСкидки.Ширина = 9;  
		Элементы.УсловиеПредоставленияСкидки.Ширина = 9; 
		Элементы.СегментБазыРасчетаСкидки.МаксимальнаяШирина = 44;
		
	ИначеЕсли Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.НомерПокупки Тогда
		
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеНомерПокупки;
		Элементы.ГруппаУП2.Видимость = Ложь;
		Элементы.ГруппаУП3.Видимость = Истина; 
		Элементы.СпособПредоставленияСкидки.Ширина = 9;
		Элементы.УсловиеПредоставленияСкидки.Ширина = 9;
		Элементы.СегментБазыРасчетаСкидки.МаксимальнаяШирина = 44;
		
	ИначеЕсли Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Всегда Тогда
		
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеВсегда;
		Элементы.ГруппаУП2.Видимость = Ложь;
		Элементы.ГруппаУП3.Видимость = Ложь;
		Элементы.СпособПредоставленияСкидки.Ширина = 11;
		Элементы.УсловиеПредоставленияСкидки.Ширина = 11; 
		Элементы.СегментБазыРасчетаСкидки.МаксимальнаяШирина = 41;
			
	ИначеЕсли Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.ОстатокНаЛицевомСчете Тогда
		
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловияОстатокНаЛицевомСчете;
		Элементы.ГруппаУП2.Видимость = Ложь;
		Элементы.СпособПредоставленияСкидки.Ширина = 13; 
		Элементы.УсловиеПредоставленияСкидки.Ширина = 13;
		Элементы.СегментБазыРасчетаСкидки.МаксимальнаяШирина = 44;
		
	ИначеЕсли Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.ПредыдущийПрием Тогда
		
		 Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеПредыдущийПрием;
		 Элементы.ГруппаУП2.Видимость = Ложь;
		 Элементы.ГруппаУП3.Видимость = Истина; 
		 Элементы.СпособПредоставленияСкидки.Ширина = 11; 
		 Элементы.УсловиеПредоставленияСкидки.Ширина = 11;
		 Элементы.СегментБазыРасчетаСкидки.МаксимальнаяШирина = 41;
		
	ИначеЕсли Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Промокод Тогда 		
		
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеПромокод;
		Элементы.ГруппаУП2.Видимость = Ложь;
		Элементы.ГруппаУП3.Видимость = Истина;
		
	ИначеЕсли Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.БонусРефералу Тогда		
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеПромокод;		
		Элементы.ГруппаУП2.Видимость = Ложь;
		Элементы.ГруппаУП3.Видимость = Ложь;		
		Элементы.ГруппаСП2.Видимость = Ложь;
		
	Иначе
		 
		Элементы.СтраницыУсловийПредоставленияСкидки.ТекущаяСтраница = Элементы.СтраницаУсловиеСуммаКоличество;		
		Элементы.ГруппаУП2.Видимость = Истина;
		Элементы.ГруппаУП3.Видимость = Истина;
		Элементы.СпособПредоставленияСкидки.Ширина = 9;
		Элементы.УсловиеПредоставленияСкидки.Ширина = 9; 
		Элементы.СегментБазыРасчетаСкидки.МаксимальнаяШирина = 44;
		
	КонецЕсли;
	
	// Элемент ПериодНакопления
	Если Объект.ОбъектСкидки = Перечисления.ОбъектСкидок.ПоПродажам Тогда
		Элементы.ОбъектНакопления.Видимость = Истина;
		Элементы.ПериодНакопления.Видимость = Истина;
		// Элементы.ПериодНакопленияЗаголовокПосле.Видимость = Истина;
	Иначе
		Элементы.ОбъектНакопления.Видимость = Ложь;
		Элементы.ПериодНакопления.Видимость = Ложь;
		// Элементы.ПериодНакопленияЗаголовокПосле.Видимость = Ложь;
	КонецЕсли;
		
	// Элемент ПериодНакопления
	Элементы.ПериодНакопленияНомерПокупки.Видимость = (Объект.ПериодНакопленияТип <> Перечисления.Периодичность.ПустаяСсылка());
	
	// Элемент ГруппаСП121
	Если Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок Тогда
		Элементы.СтраницыСпособПримененияСкидки.ТекущаяСтраница = Элементы.СтраницаСППодарком;
	ИначеЕсли Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВидЦен Тогда
		Элементы.СтраницыСпособПримененияСкидки.ТекущаяСтраница = Элементы.СтраницаСПВидомЦен;
	ИначеЕсли Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.ВыдачаКарты Тогда
		Элементы.СтраницыСпособПримененияСкидки.ТекущаяСтраница = Элементы.СтраницаСПВыдачейКарты;				
	Иначе
		Элементы.СтраницыСпособПримененияСкидки.ТекущаяСтраница = Элементы.СтраницаСПСуммойПроцентом;
	КонецЕсли;
	
	// Заголовок элемента ЗначениеУсловия
	Если Объект.УсловиеПредоставленияСкидки = Перечисления.УсловияПредоставленияСкидки.Сумма Тогда
		Элементы.ЗначениеУсловия.Заголовок	= ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
		Элементы.ЗначениеУсловия1.Заголовок = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();		
	Иначе
		Элементы.ЗначениеУсловия.Заголовок = НСтр("ru = '  Ед.'; en = '  Units'");
		Элементы.ЗначениеУсловия1.Заголовок = НСтр("ru = '  Ед.'; en = '  Units'");		
	КонецЕсли;	
	
	// Заголовок элемента ЗначениеСкидкиНаценки
	Если Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Процент Тогда
		Элементы.ЗначениеСкидкиНаценки.Заголовок = " %";
	Иначе
		Элементы.ЗначениеСкидкиНаценки.Заголовок = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
	КонецЕсли;		
		
	Если Не Объект.НачислениеБонусами
		и Объект.ТипПолучателя = Перечисления.ТипыПолучателейСкидкиНаценки.КлиентРекламныйИсточник Тогда
		
		Элементы.СпособПредоставленияСкидки.СписокВыбора.Очистить();
		Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.Подарок);
		Объект.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок;
		
	Иначе
		
		Элементы.СпособПредоставленияСкидки.СписокВыбора.Очистить();
		Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.Сумма);
		Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.Процент);
		Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.СуммаНаДокумент);
		Если НЕ Объект.НачислениеБонусами Тогда
			Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.Подарок);
			Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.ВидЦен);
		КонецЕсли;                                                                                                    	
		
		Элементы.СегментБазыРасчетаСкидки.Видимость = Истина;
		Элементы.ГруппаИспользование.Видимость      = Истина;
		Массив = Новый Массив;
		Элементы.ЗначениеСкидкиНаценкиВидБонусногоСчета.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
		Элементы.ЗначениеСкидкиНаценкиВидБонусногоСчета.ПодсказкаВвода = НСтр("ru= 'Вид бонусного счета';en ='Type of bonus account'");
		
	КонецЕсли;
	
	Если Объект.НачислениеБонусами = Истина Тогда
		Если Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.Подарок) <> Неопределено
			И Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.ВидЦен) <> Неопределено
			И Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.ВыдачаКарты) <> Неопределено Тогда
			Элементы.СпособПредоставленияСкидки.СписокВыбора.Удалить(Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.Подарок));
			Элементы.СпособПредоставленияСкидки.СписокВыбора.Удалить(Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.ВидЦен));
			// Элементы.СпособПредоставленияСкидки.СписокВыбора.Удалить(Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.ВыдачаКарты));
		КонецЕсли;
	Иначе
		Если Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.Подарок) = Неопределено
			И Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.ВидЦен) = Неопределено
			И Элементы.СпособПредоставленияСкидки.СписокВыбора.НайтиПоЗначению(Перечисления.СпособПредоставленияСкидки.ВыдачаКарты) = Неопределено Тогда
			Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.Подарок);
			Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.ВидЦен);
			// Элементы.СпособПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.СпособПредоставленияСкидки.ВыдачаКарты);
		КонецЕсли;
	КонецЕсли;
	//
	Элементы.УсловиеПредоставленияСкидки.СписокВыбора.Очистить();
	Элементы.УсловиеПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.УсловияПредоставленияСкидки.Всегда);
	Элементы.УсловиеПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.УсловияПредоставленияСкидки.ДеньРождения);
	Элементы.УсловиеПредоставленияСкидки.СписокВыбора.Добавить(Перечисления.УсловияПредоставленияСкидки.Количество);
