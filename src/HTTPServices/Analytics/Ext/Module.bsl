					мОтвет, 
					, 
					,
					200); 								
				КонецЕсли;
				
			КонецЕсли;
			
			Возврат Ответ;
			
			//////////// Получение информации о клиентах
		ИначеЕсли Запрос.ПараметрыЗапроса.Получить("action") = "export_clients" Тогда
			
			Ответ = Новый HTTPСервисОтвет(200);	
			Ответ.Заголовки.Вставить("Content-Type", "application/json;  charset=utf-8");
			
			ДатаСделок = Запрос.ПараметрыЗапроса.Получить("date");
			
			Ответ.УстановитьТелоИзСтроки(ПолучитьJsonСтруктуруКлиентов(ДатаСделок), КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
			
			// Логирование
			Если ЛогироватьСобытие > 0 Тогда
				
				ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
				ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
				СтатусСобытия 		   = Перечисления.СтатусыЗапросов.Выполнен;						
				мОтвет                 = Ответ.ПолучитьТелоКакСтроку();
				
				Если ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЛогироватьСобытие, СтатусСобытия, ВремяВыполнения) Тогда
					
					РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
					HTTPЗапросЛога, 
					ДатаЛога, 
					UIDЗапроса, 
					ТипЗапроса, 
					HTTPШаблон, 
					СтатусСобытия, 
					ВремяВыполнения, 
					, 
					, 
					мОтвет, 
					, 
					,
					200); 								
				КонецЕсли;
				
			КонецЕсли;
			
			Возврат Ответ;
			
		Иначе
			
			// Логирование
			Если ЛогироватьСобытие > 0 Тогда
				
				ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
				ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
				СтатусСобытия 		   = Перечисления.СтатусыЗапросов.ЗавершенСОшибками;						
				
				РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
				HTTPЗапросЛога, 
				ДатаЛога, 
				UIDЗапроса, 
				ТипЗапроса, 
				HTTPШаблон, 
				СтатусСобытия, 
				ВремяВыполнения, 
				ВнешняяСистема, 
				, 
