// Процедура, выполняет установку номера документа
//
Процедура УстановитьНомерЗаказа()
	
	Если ЗначениеЗаполнено(Объект.Номер) Тогда
		МаксИдентификаторСтроки = 0;
		Перезаписать = Ложь;
		Для Каждого СтрокаТЧ из Объект.Запасы Цикл
			Если ЗначениеЗаполнено(СтрокаТЧ.НомерЗаказа) Тогда
				Ключ = Сред(СтрокаТЧ.НомерЗаказа, Найти(СтрокаТЧ.НомерЗаказа, "-")+1);			
				Если Число(Ключ) > МаксИдентификаторСтроки Тогда
					МаксИдентификаторСтроки = Число(Ключ);
				КонецЕсли;
			КонецЕсли;		
		КонецЦикла;
		Для Каждого СтрокаТЧ из Объект.Запасы Цикл
			Если Не ЗначениеЗаполнено(СтрокаТЧ.НомерЗаказа) или Найти(СтрокаТЧ.НомерЗаказа, "-") = 1 Тогда
				МаксИдентификаторСтроки = МаксИдентификаторСтроки + 1;
				СтрокаТЧ.НомерЗаказа = СтрЗаменить(ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Объект.Номер, "", Ложь),"-","") + "-"+ МаксИдентификаторСтроки;
				Перезаписать = Истина;
			КонецЕсли;
		КонецЦикла;  
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
// Процедура, выполняет перезаполнение цен в ТЧ Запасы
//
Процедура ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ПерезаполнитьЦеныПродажи, ПерезаполнитьЦенуЗакупки)
	
	Если ПерезаполнитьЦеныПродажи Тогда 		
		СтруктураДанных = Новый Структура;
		ТабличнаяЧастьДокумента = Новый Массив;  		
		СтруктураДанных.Вставить("Дата",				Объект.Дата);
		СтруктураДанных.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
		СтруктураДанных.Вставить("ВидЦен",				Объект.ВидЦенПродажи);
		
		Для каждого СтрокаТЧ Из Объект.Запасы Цикл			
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
				Продолжить;	
			КонецЕсли;                            			
			СтрокаТабличнойЧасти = Новый Структура();
			СтрокаТабличнойЧасти.Вставить("Номенклатура",		СтрокаТЧ.Номенклатура);
			СтрокаТабличнойЧасти.Вставить("Упаковка",			СтрокаТЧ.Упаковка);
			СтрокаТабличнойЧасти.Вставить("Цена",				0);			
			ТабличнаяЧастьДокумента.Добавить(СтрокаТабличнойЧасти);			
		КонецЦикла;	
		Ценообразование.ПолучитьЦеныТабличнойЧастиПоВидуЦен(СтруктураДанных, ТабличнаяЧастьДокумента);	
		Для каждого СтрокаТЧ Из ТабличнаяЧастьДокумента Цикл			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Номенклатура",		СтрокаТЧ.Номенклатура);
			СтруктураПоиска.Вставить("Упаковка",			СтрокаТЧ.Упаковка);		
			РезультатПоиска = Объект.Запасы.НайтиСтроки(СтруктураПоиска);		
			Для каждого СтрокаРезультат Из РезультатПоиска Цикл				
				СтрокаРезультат.ЦенаПродажи = СтрокаТЧ.Цена;	
				РассчитатьСуммуПродажиВСтрокеТабличнойЧасти(СтрокаРезультат);         				
			КонецЦикла;                                     			
		КонецЦикла;			
	КонецЕсли;	
	Если ПерезаполнитьЦенуЗакупки Тогда
		ЦенообразованиеКлиент.ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(ЭтаФорма, "Запасы", , ПерезаполнитьЦенуЗакупки);
		Для Каждого СтрокаТЧ из Объект.Запасы Цикл
			СтрокаТЧ.ВидЦен = Объект.ВидЦен;
		КонецЦикла;		 
	КонецЕсли;
	
	СтруктураНадписи = Новый Структура("ВидЦен, ВидЦенПродажи", Объект.ВидЦен, Объект.ВидЦенПродажи);
	Элементы.ЦеныИВалютаНадпись.Заголовок = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи);
	
КонецПроцедуры

