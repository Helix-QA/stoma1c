// ПодключаемоеОборудование
//
//
Функция ПолученыШтрихкоды(ДанныеШтрикодов)
	
	НеизвестныеШтрихкоды = Новый Массив;
	
	Для Каждого ЭлементШтрихкода Из ДанныеШтрикодов Цикл
		ИдентификаторыНовыхСтрок = 0;
		Если ОбработкаТабличныхЧастейКлиент.СШКОбработкаТабличнойЧасти(Элементы.Запасы, ЭлементШтрихкода, Объект.Контрагент, Объект.КартаКонтрагента, , Объект.Запасы, НеизвестныеШтрихкоды, ИдентификаторыНовыхСтрок) Тогда
			// ЗапасыНоменклатураПриИзменении(Элементы.Запасы.ТекущиеДанные);
			// ИдентификаторыНовыхСтрок=Элементы.Запасы.ТекущиеДанные.ПолучитьИдентификатор();	
			ЗапасыНоменклатураПриИзменении(Неопределено,ИдентификаторыНовыхСтрок,Истина);	
			ЗапасыУпаковкаПриИзменении(Элементы.Запасы.ТекущиеДанные);
			ПересчитатьАвтоматическиеСкидкиИОбновитьЗаголовкиТабЧастей();// ПересчитатьАвтоматическиеСкидки();
		КонецЕсли;
		Если НеизвестныеШтрихкоды.Количество() > 0 Тогда 
			СтруктураПараметров = Новый Структура("НеизвестныеШтрихкоды", НеизвестныеШтрихкоды);
			ОткрытьФорму("РегистрСведений.Штрихкоды.Форма.РегистрацияШтрихкодовНоменклатуры", СтруктураПараметров, ЭтаФорма);
		КонецЕсли;
	КонецЦикла;						
	
