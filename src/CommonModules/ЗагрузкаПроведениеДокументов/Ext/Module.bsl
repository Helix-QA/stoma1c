	КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ВосстановитьПоследовательность",
	ПараметрыПроцедуры,
	НСтр("ru='Восстановление последовательности...';en='Sequence recovery...'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Восстановить последовательность
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ВосстановитьПоследовательность(ПараметрыЗадания, АдресРезультата) Экспорт 
	
	// ТаблицаВосстановленииПоследовательности = Новый ТаблицаЗначений;
	// ТаблицаВосстановленииПоследовательности.Колонки.Добавить("ЧленствоПакетУслуг", Новый ОписаниеТипов("ДокументСсылка.ЧленствоПакетУслуг"));
	//
	// НоваяСтрока = ТаблицаВосстановленииПоследовательности.Добавить();
	// НоваяСтрока.ЧленствоПакетУслуг = ПараметрыЗадания.ЧленствоПакетУслуг;
	//
	// Последовательности.ЧленстваПакетыУслуг.Восстановить(, ТаблицаВосстановленииПоследовательности);
	
    Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЧленстваПакетыУслуг.Регистратор КАК Регистратор,
	|	ЧленстваПакетыУслуг.Период КАК Период,
	|	ЧленстваПакетыУслуг.ЧленствоПакетУслуг КАК ЧленствоПакетУслуг,
	|	ЧленстваПакетыУслуг.МоментВремени КАК МоментВремени
	|ПОМЕСТИТЬ ЧленстваПакетыУслуг
	|ИЗ
	|	Последовательность.ЧленстваПакетыУслуг КАК ЧленстваПакетыУслуг
	|ГДЕ
	|	ЧленстваПакетыУслуг.ЧленствоПакетУслуг = &ЧленствоПакетУслуг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
