	Если НЕ Константы.НесколькоВрачейВОдномПриеме.Получить() Тогда 
		Возврат "Основной";
	Иначе 
		Возврат "Основной_БЕЗ_ДЕТАЛИЗАЦИИ_ПО_СОТРУДНИКАМ";
	КонецЕсли;
	
КонецФункции

