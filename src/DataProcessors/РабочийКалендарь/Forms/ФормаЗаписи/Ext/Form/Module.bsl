// Обработчик кнопки открытия списка отмененных предварительных записей
//
Процедура СтрицаПЗПоказатьОтмененныеЗаписи(Команда)	
	
	// Подготовка параметров формы
	Параметрыформы = Новый Структура;
	Если ПолучитьСтраницуМенеджера() = "Неделя" Тогда
		Параметрыформы.Вставить("ОтборПериодНачало",НачалоНедели(Объект.Дата));
		Параметрыформы.Вставить("ОтборПериодКонец" ,КонецНедели(Объект.Дата));
	Иначе
		Параметрыформы.Вставить("ОтборПериодНачало",НачалоДня(Объект.Дата));
		Параметрыформы.Вставить("ОтборПериодКонец" ,КонецДня(Объект.Дата));	
	КонецЕсли;
	Если ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники") Тогда
		Параметрыформы.Вставить("ОтборСотрудник"  ,ПЗФиьтрГрафикаТекущаяСтрока);
	КонецЕсли;
	Если ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Помещения") Тогда
		Параметрыформы.Вставить("ОтборПомещение"  ,ПЗФиьтрГрафикаТекущаяСтрока);
	КонецЕсли;
	ОткрытьФорму("Документ.Событие.Форма.ФормаСпискаОтмененныхСобытий",Параметрыформы,ЭтаФорма); 
	
КонецПроцедуры

