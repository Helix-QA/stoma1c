КонецПроцедуры

&НаСервере
// Процедура - помечает на удаление объекты связанные с обращением
//
Процедура ПометитьНаУдалениеСвязанныеОбъекты(Удалить)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЗначениеЗаполнено(ЗаявкаОснование) Тогда
		
		ЗаявкаОбъект = ЗаявкаОснование.ПолучитьОбъект();
		Если ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Заявки") Тогда
			ЗаявкаОбъект.Статус = ?(Удалить, Перечисления.СтатусыЗаявок.Отклонена, Перечисления.СтатусыЗаявок.Принята);
		КонецЕсли;
		ЗаявкаОбъект.ПометкаУдаления = Удалить;
		ЗаявкаОбъект.Записать();   
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) Тогда
		
		Для Каждого Пациент Из СтруктураКлиента.СписокКонтрагентов Цикл
			
			ОткрытыеСделкиПациента = Справочники.Сделки.ПолучитьСделкиПоКлиенту(Пациент.Значение.КонтрагентСсылка,, Ложь,,,,Истина,Истина,,Истина);
			
			Для Каждого Элемент Из ОткрытыеСделкиПациента Цикл
				
				СделкаОбъект 					= Элемент.Сделка.ПолучитьОбъект();
				СделкаОбъект.ЭтапСделки 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
				СделкаОбъект.ЭтапОтказа 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
				СделкаОбъект.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;
				СделкаОбъект.ПометкаУдаления 	= Истина;
				СделкаОбъект.Записать();	
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - менает этап сделки в отказ
//
Процедура ОтменитьСделку()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЗначениеЗаполнено(ЗаявкаОснование) Тогда
		
		СделкаОбъект 					= ЗаявкаОснование.ПолучитьОбъект();
		СделкаОбъект.ЭтапСделки 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
		СделкаОбъект.ЭтапОтказа 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
		СделкаОбъект.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;

		СделкаОбъект.Записать();   

	КонецЕсли;
    	
КонецПроцедуры

&НаСервере
// Функция - проверяет есть ли у пациента прием
// 
Функция ПриемСуществует(Пациент)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Прием.Ссылка КАК Ссылка,
		|	Прием.Контрагент КАК Контрагент
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Контрагент = &Контрагент";
	
	Запрос.УстановитьПараметр("Контрагент", Пациент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ?(РезультатЗапроса.Пустой(), Ложь, Истина);
	
КонецФункции

&НаКлиенте
// Процедура - помечает на удаление сделку
//
Процедура ЗвонокНеСвязанСПриемом(Команда)
	
	Если ЗначениеЗаполнено(ЗаявкаОснование) И ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Сделки") Тогда
		УдалитьСделку(); 
	ИначеЕсли ЗначениеЗаполнено(ЗаявкаОснование) И ТипЗнч(ЗаявкаОснование) = Тип("СправочникСсылка.Заявки") Тогда
       	ПометитьНаУдалениеСвязанныеОбъекты(Истина);
	КонецЕсли;

	ЗаполнитьРезультатЗвонка(ПредопределенноеЗначение("Перечисление.РезультатыОбработкиЗвонка.ЗвонокНеСвязанСПриемом"));
	ВызвытьОповещение = Истина;
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

&НаСервере
// Процедура - помечает на удаление сделку
//
Процедура УдалитьСделку()
	
	УстановитьПривилегированныйРежим(Истина);
	
	СделкаОбъект 					= ЗаявкаОснование.ПолучитьОбъект();
	СделкаОбъект.ЭтапСделки 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
	СделкаОбъект.ЭтапОтказа 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ЭтапыСделок.Отказ");
	СделкаОбъект.РезультатСделки 	= Перечисления.РезультатыСделок.Отказ;
	СделкаОбъект.ПометкаУдаления 	= Истина;
	СделкаОбъект.Записать();   
	
КонецПроцедуры

&НаСервере
// Процедура - оповещает о закрытии формы связи
//
Процедура ОповеститьПоНомеруТелефона()

	УстановитьПривилегированныйРежим(Истина);
	
	ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
	
	СписокАктивныхПользователей = IPТелефония.ПолучитьСписокАктивныхПользователей(ПараметрыТелефонногоЗвонка.ВнутреннийНомерСотрудника);
	
	Если ИспользоватьСистемуВзаимодействия = Истина Тогда
		
		Сотрудники 	 = Новый Массив;
		
		Для каждого АктивныйСеансПользователя Из СписокАктивныхПользователей Цикл
			Сотрудники.Добавить(АктивныйСеансПользователя.Пользователь);
		КонецЦикла;
		
		Если Сотрудники.Количество() > 0 Тогда
			
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("Ключ"				, "ЗакрытьФормуЗвонкаПациенту");
			ДанныеСообщения.Вставить("Телефон"       	, НомерТелефонаКлиента);    
			ДанныеСообщения.Вставить("IDЗвонка"       	, IDЗвонка);

			ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения, Сотрудники); 
			
		КонецЕсли;
		
	Иначе
		
		// Оповещение через регистр сведений.
		Для Каждого АктивныйСеансПользователя Из СписокАктивныхПользователей Цикл
			
			МассивПараметров = Новый Массив;
			МассивПараметров.Добавить(НомерТелефонаКлиента);
			МассивПараметров.Добавить(IDЗвонка);
			
			РегистрыСведений.ОповещениеМониторингКлиента.ДобавитьОповещениеКлиента(АктивныйСеансПользователя.РабочееМесто,
			Неопределено, 
			"ЗакрытьФормуЗвонкаПациенту",
			ТекущаяДатаСеанса(),
			60,,,
			МассивПараметров);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

