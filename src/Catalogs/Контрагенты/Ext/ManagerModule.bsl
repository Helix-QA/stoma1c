	ТекстовыйПосторитель.ЗаписатьБезОбработки(ТекстHTML);	
	
	ДатаРожденияКлиента    = ПараметрыДанных.ДатаРожденияКлиента;
	ДатаРегистрацииКлиента = ПараметрыДанных.ДатаРегистрацииКлиента;
	БлокЗапланированоВыведен = Ложь;
	ТекущаяДата = Неопределено;
	
	ТаблицаИсторииВзаимодействия = ЭтаФорма.ИсторияВзаимодействий;
	КоличествоСобытий = ТаблицаИсторииВзаимодействия.Количество();
	ИндексКонец  = ?(ВыводитьВсе ИЛИ КоличествоСобытий - 1 < 20, КоличествоСобытий - 1, 19);
	
	ТегДиалогаОткрыт = Ложь;
	КоличествоСообщенийБезРазрыва = 1;

	Для Индекс = 0 По ИндексКонец Цикл		
		СтрокаТЗ = ТаблицаИсторииВзаимодействия[Индекс];
		ДатаНачалоДня = НачалоДня(СтрокаТЗ.Дата);
		ЭтоБлокЗапланировано 	= СтрокаТЗ.ТипВзаимодействия = "Запланировано";
		ЭтоЗаметка				= СтрокаТЗ.ТипСобытия		 = "Заметка";
		ЦветФона = ?(ЭтоБлокЗапланировано, "#f5f5dc", "");
		
		Если СтрокаТЗ.ТипСобытия = "Заметка" Тогда
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокЗаметка(СтрокаТЗ));
		КонецЕсли;
		
		Если Не СтрНайти(СтрокаТЗ.ТипСобытия, "Диалог")
			И ТегДиалогаОткрыт Тогда
			
			ТегДиалогаОткрыт = Ложь;
			КоличествоСообщенийБезРазрыва = 1;
			
		КонецЕсли;
		
		Если ЭтоБлокЗапланировано И Не БлокЗапланированоВыведен  Тогда
			ВывестиБлокИнформация(ТекстовыйПосторитель, СтрокаТЗ.ТипВзаимодействия,,,,8);
			БлокЗапланированоВыведен = Истина;
		КонецЕсли;	
		
		Если НЕ ЭтоБлокЗапланировано И НЕ ЭтоЗаметка Тогда
			Если ТекущаяДата = Неопределено Или ТекущаяДата <> ДатаНачалоДня Тогда  // сменилась дата, выводим
				ВывестиДату(ТекстовыйПосторитель, ДатаНачалоДня);
				ТекущаяДата = ДатаНачалоДня;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаТЗ.ТипСобытия = "ДатаРегистрацииКлиента" Тогда
			ВывестиБлокИнформация(ТекстовыйПосторитель, "Пациент зарегистрирован", , 12, -8);
		КонецЕсли;
		
		Если СтрокаТЗ.ТипСобытия = "Событие" Тогда
			ВыводитьДату = ЭтоБлокЗапланировано И Не НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(СтрокаТЗ.Дата);
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокПредварительнаяЗапись(СтрокаТЗ.Ссылка, СтрокаТЗ.Статус, ЦветФона, ВыводитьДату));	
		ИначеЕсли СтрокаТЗ.ТипСобытия = "Профосмотр" Тогда
			ВыводитьДату = ЭтоБлокЗапланировано И Не НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(СтрокаТЗ.Дата);
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокПрофосмотр(СтрокаТЗ, СтрокаТЗ.Статус, ЦветФона, ВыводитьДату));
		ИначеЕсли СтрокаТЗ.ТипСобытия = "Прием" Тогда
			ВыводитьДату = ЭтоБлокЗапланировано И Не НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(СтрокаТЗ.Дата);
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокПрием(СтрокаТЗ.Ссылка,СтрокаТЗ.Статус, ЦветФона, ВыводитьДату));
		ИначеЕсли СтрокаТЗ.ТипСобытия = "НарядЗаказ" Тогда
			ВыводитьДату = ЭтоБлокЗапланировано И Не НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(СтрокаТЗ.Дата);
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокНарядЗаказ(СтрокаТЗ.Ссылка, СтрокаТЗ.Статус, ЦветФона, ВыводитьДату));
		ИначеЕсли СтрокаТЗ.ТипСобытия = "ПланЛечения" Тогда
			ВыводитьДату = ЭтоБлокЗапланировано И Не НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(СтрокаТЗ.Дата);
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокПланЛечения(СтрокаТЗ.Ссылка, СтрокаТЗ.Статус, ЦветФона, ВыводитьДату));										
		ИначеЕсли СтрокаТЗ.ТипСобытия = "SMS" Тогда
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокSMS(СтрокаТЗ.Ссылка, СтрокаТЗ.Автор, СтрокаТЗ.Статус));			
		ИначеЕсли СтрокаТЗ.ТипСобытия = "Письмо" Тогда
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокПисьмо(СтрокаТЗ.Ссылка, СтрокаТЗ.Автор, СтрокаТЗ.Статус));						
		ИначеЕсли СтрокаТЗ.ТипСобытия = "Задача" Тогда
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформироватьБлокЗадача(СтрокаТЗ.Ссылка));					
		ИначеЕсли СтрНачинаетсяС(СтрокаТЗ.ТипСобытия, "Диалог") Тогда
			
			КоличествоСообщенийБезРазрыва = КоличествоСообщенийБезРазрыва + 1;
			
			СформированныйБлокДиалог = СформироватьБлокДиалог(СтрокаТЗ, ?(ТегДиалогаОткрыт = Ложь, Истина, Ложь));
			
			Если ТегДиалогаОткрыт = Ложь И ЗначениеЗаполнено(СформированныйБлокДиалог) Тогда
				
				Если СтрокаТЗ.ТипСобытия = "ДиалогTelegram" Тогда
					АдресКартинки = Base64Строка(БиблиотекаКартинок.Telegram16.ПолучитьДвоичныеДанные());
				ИначеЕсли СтрокаТЗ.ТипСобытия = "ДиалогVK" Тогда
					АдресКартинки = Base64Строка(БиблиотекаКартинок.Vk16.ПолучитьДвоичныеДанные());
				ИначеЕсли СтрокаТЗ.ТипСобытия = "ДиалогViber" Тогда
					АдресКартинки = Base64Строка(БиблиотекаКартинок.Viber16.ПолучитьДвоичныеДанные());
				ИначеЕсли СтрокаТЗ.ТипСобытия = "ДиалогWhatsApp" Тогда
					АдресКартинки = Base64Строка(БиблиотекаКартинок.Whatsapp16.ПолучитьДвоичныеДанные());
				КонецЕсли;
				
 				ТегДиалогаОткрыт = Истина;
				
				БлокДиалог =
				"<tr align='left' valign='top'>
				|<td rowspan= '{КоличествоСообщенийБезРазрыва}'>
				|<img alt='{Текст}' src='data:image/png;base64, {АдресКартинки}'/>
				|</td>";
				
				БлокДиалог = СтрЗаменить(БлокДиалог, "{АдресКартинки}"					, АдресКартинки);
				БлокДиалог = СтрЗаменить(БлокДиалог, "{КоличествоСообщенийБезРазрыва}"	, КоличествоСообщенийБезРазрыва);
				БлокДиалог = СтрЗаменить(БлокДиалог, "{Текст}"							, Нстр("ru = 'Диалог'; en = 'Dialog'"));
				
				ТекстовыйПосторитель.ЗаписатьБезОбработки(БлокДиалог);
				
			КонецЕсли;
			
			ТекстовыйПосторитель.ЗаписатьБезОбработки(СформированныйБлокДиалог);
			
		КонецЕсли;
		
		ТекстовыйПосторитель.ЗаписатьБезОбработки(Символы.ПС + ДобавитьПустуюСтроку());					
		
	КонецЦикла;
	
	Если КоличествоСобытий > 20 И НЕ ВыводитьВсе Тогда
		ВывестиБлокПоказатьЕще(ТекстовыйПосторитель, "Показать еще (" + Строка(КоличествоСобытий - 20) + ")");		
	КонецЕсли;
	
	ТекстовыйПосторитель.ЗаписатьБезОбработки("</table>
	|</body>
	|</head>
	|</html>");							
	
	ИсторияВзаимодействия = ТекстовыйПосторитель.Закрыть();		
	// Очищаем построитель
	ТекстовыйПосторитель = Неопределено;
	
	Возврат ИсторияВзаимодействия;
	
КонецФункции

// Процедура, выводит блок информации.
//
Процедура ВывестиБлокИнформация(ТекстовыйПосторитель, Текст, ЦветФона = "#ffffff", РазмерШрифта = 16, ОтступСверху = 0, ОтступСнизу = 0)
	
	БлокИнформация =   
	"<tr style='background-color: {ЦветФона};'>
	|<td colspan='3'>
	|<p class='info' style='color: #1fa3ff; font: {РазмерШрифта}px arial; margin: {ОтступСверху}px 0px {ОтступСнизу}px 0px;'>{Текст}</p>
	|</td>	                               
	|</tr>";
	
	БлокИнформация = СтрЗаменить(БлокИнформация, "{ЦветФона}"    , ЦветФона);
	БлокИнформация = СтрЗаменить(БлокИнформация, "{РазмерШрифта}", РазмерШрифта);
	БлокИнформация = СтрЗаменить(БлокИнформация, "{ОтступСверху}", ОтступСверху);
	БлокИнформация = СтрЗаменить(БлокИнформация, "{ОтступСнизу}" , ОтступСнизу);
	БлокИнформация = СтрЗаменить(БлокИнформация, "{Текст}"       , Текст);
	
	ТекстовыйПосторитель.ЗаписатьБезОбработки(БлокИнформация);									
	
КонецПроцедуры

// Функция, формирует блок визит.
//
Функция СформироватьБлокПланЛечения(ПланЛечения, Статус, ЦветФона = "", Запланировано = Ложь)
	
	ТекстHTML = 
	"<tr>
	|<td align='right' class='left_col' style='background-color: inherit;'>
	|<img alt='Прием' src='data:image/png;base64, {Картинка}'/>
	|</td>
	|<td class='center_col'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|<p class='content'><a href='{Ссылка}' title='Открыть план лечения'>{Представление}</a>({Статус}) Сумма: {Сумма} Оплачено: {Оплачено}</p>";
	
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Ссылка}"        , ПолучитьНавигационнуюСсылку(ПланЛечения));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Представление}" , ПолучитьПредставлениеПланаЛечения(ПланЛечения, Статус, Запланировано));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Картинка}"		 , Base64Строка(БиблиотекаКартинок.PNG_ПланЛечения_16х16.ПолучитьДвоичныеДанные()));
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Статус}"		 , ПланЛечения.Статус);
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Оплачено}"		 , "" + ПланЛечения.СуммаОплачено + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты());
	ТекстHTML = СтрЗаменить(ТекстHTML, "{Сумма}"		 , "" + ПланЛечения.СуммаДокумента + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты());
	
	ВремЗапасы = ПланЛечения.Лечение.Выгрузить().Скопировать(); 
	ВремЗапасы.Свернуть("Номенклатура");                 
	
	Для Каждого Номенклатура Из ВремЗапасы.ВыгрузитьКолонку("Номенклатура") Цикл
		
		Шаблон = "<p class='content' title='{Номенклатура}'>{Номенклатура}</p>";
		ТекстHTML = ТекстHTML + Символы.ПС + СтрЗаменить(Шаблон, "{Номенклатура}", Строка(Номенклатура));			 	
		
	КонецЦикла;
	
	
	ТекстHTML = ТекстHTML + 
	"</td>
	|<td class='right_col' align='right'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|";
	
	УстановитьПривилегированныйРежим(Истина);
	
	СотрудникHTML = ""; 		
	
	СотрудникHTML = "<p class='author' title='{Сотрудник}'>{Сотрудник}</p>";
	СотрудникHTML = СтрЗаменить(СотрудникHTML, "{Сотрудник}", ПредставлениеФИОСотрудника(ПланЛечения.Сотрудник));			
	
	ТекстHTML = ТекстHTML + СотрудникHTML + Символы.ПС;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТекстHTML + "</td>" + Символы.ПС + "</tr>";
	
КонецФункции

// Функция, возвращает представление визита.
//
Функция ПолучитьПредставлениеПланаЛечения(ПланЛечения, СтатусВизита, Запланировано = Ложь)
	
	Представление = "";
		
	Состояние = "";
	Если ПланЛечения.ПометкаУдаления Тогда
		Состояние = НСтр("ru='(удален)'");
	ИначеЕсли НЕ ПланЛечения.Проведен Тогда
		Состояние = НСтр("ru='(не проведен)'");
	КонецЕсли;
	
	Статус = "План лечения";
	ДатаДокумента = Формат(ПланЛечения.Дата, "ДЛФ=DD") + " в " + Формат(ПланЛечения.Дата, "ДФ=HH:мм");
	
	Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
	НСтр("ru='%1 %2 %3'"),
	Статус,
	ДатаДокумента,
	Состояние);
	
	Возврат Представление;
	
КонецФункции

// Функция - Сформировать блок задача
//
// Параметры:
//  СтрокаТЗ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокЗадача(Задача)
	
	ЦветФона = "";
	ШаблонЗадача = 
	"<tr valign='middle'>
	|<td class='left_col' td align='right'>
	|<img alt='Задача' src='data:image/png;base64, {Картинка}'/>
	|</td>
	|<td class='center_col' style='vertical-align: middle;" + ?(ЗначениеЗаполнено(ЦветФона), " background-color: " + ЦветФона + ";'", "'") + ">
	|<input {Чекнут} title='{ДопОписание}' type='checkbox' class='task' id='{УИд}'/>
	|<p class='content'><a href='{Ссылка}' title='Открыть задачу'>{Дата} {Представление}{ДопИнформация}.</a> {Описание}</p>
	|</td>
	|<td class='right_col' align='right'" + ?(ЗначениеЗаполнено(ЦветФона), " style='background-color: " + ЦветФона + ";'", "") + ">
	|<p title='{Автор}' class='author'>{Автор}</p>
	|</td>
	|</tr>";
	
	УИд = Задача.УникальныйИдентификатор();
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Описание}" 	  , ?(ЗначениеЗаполнено(Задача.ЗадачаОписание), Задача.ЗадачаОписание, ""));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Тема}"     	  , Задача.ЗадачаТема);
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Дата}"     	  , ?(Задача.Выполнена, "", Формат(Задача.ЗадачаНазначеннаяДата, "ДФ='d MMMM'") + ","));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Автор}"    	  , Справочники.Сотрудники.ПредставлениеФИОСотрудника(Задача.ЗадачаАвтор));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Представление}", Строка(Задача.Ссылка));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Ссылка}"       , ПолучитьНавигационнуюСсылку(Задача));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ДопОписание}"  , ?(Задача.Выполнена, "", "Отметить как выполнено"));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Чекнут}"   	  , ?(Задача.Выполнена, "checked disabled", ""));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{УИд}"     	  , УИд);
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Картинка}"	  , Base64Строка(БиблиотекаКартинок.PNG_ЗадачаНовый_16х16.ПолучитьДвоичныеДанные()));  	
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ДопИнформация}", ?(Не Задача.Выполнена И Задача.ЗадачаНазначеннаяДата < ТекущаяДатаСеанса(), " <span style='color: red;'>(Просрочена)</span>", ""));
	
	Возврат ШаблонЗадача;	

КонецФункции

