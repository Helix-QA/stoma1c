// Процедура устанавливает видимость закладок скидки/наценки и подарки в форме документа.
//
Процедура УстановитьОтображениеЗакладокСкидкиНаценкиПодарки(Форма, ПолучатьДанныеИзФормы = Ложь) Экспорт
	
	Объект = ?(ПолучатьДанныеИзФормы, Форма, Форма.Объект);
	
	// Закладка скидки/наценки.
	Если Форма.Элементы.Найти("ГруппаСкидкиНаценки") <> Неопределено Тогда	
		
		ЭтоФормаРеализации = СтрНайти(Форма.ИмяФормы, "Реализация") > 0 Или СтрНайти(Форма.ИмяФормы, "Прием") > 0;
		КоличествоСтрокСкидкиНаценки = ?(ЭтоФормаРеализации,
										Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("ПризнакОплатыБонусом", Ложь)).Количество(), 
										Объект.СкидкиНаценки.Количество());
		
		Форма.Элементы.Группа_Кнопки_СкидкиНаценки.Видимость = КоличествоСтрокСкидкиНаценки > 0;
	КонецЕсли;
	
	// Закладки подарки.
	Если Форма.Элементы.Найти("ГруппаПодарки") <> Неопределено
		И Форма.Элементы.Найти("_Подарки") <> Неопределено Тогда
		
		Форма.Элементы.Группа_Кнопки_Подарки.Видимость = Объект.Подарки.Количество() > 0;
	КонецЕсли;
	
	// Учтенные Авансы.
	Если Форма.Элементы.Найти("ГруппаУчтенныеАвансы") <> Неопределено
		И Форма.Элементы.Найти("_УчтенныеАвансы") <> Неопределено Тогда
		
		Форма.Элементы.Группа_Кнопки_УчтенныеАвансы.Видимость = Объект.УчтенныеАвансы.Количество() > 0;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет отправку смс сообщения на сайт smsmm.ru.
//  Параметры:
//   ДокументСсылка: ссылка на докумет, который выполняет отправку смс.
//   
Процедура ОтправитьSMSПоДокументу(Документ, ПереотправитьНедоставленные = Истина, Отказ = Ложь) Экспорт
	
	// Подключаем обработку сервиса
	ОбработкаСервисSMSРассылки = ОбщегоНазначенияСтоматология.ОбработкаСервисаSMSРассылки(Документ.СервисSMSРассылки);
	Если ОбработкаСервисSMSРассылки = Неопределено Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Выгружаем номера получателей SMS
	Получатели = РегистрыСведений.СтатусыСообщений.СоздатьНаборЗаписей().ВыгрузитьКолонки();
	Получатели.Колонки.Добавить("Содержание");		
	Для Каждого Получатель Из Документ.Получатели Цикл
		НоваяСтрока = Получатели.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Получатель, "КлючСтроки, НомерТелефона");
		НоваяСтрока.Содержание = Документы.РассылкаСообщений.ПреобразоватьСодержаниеСПараметрамиВТекст(Документ.Содержание, Документ, Получатель.Получатель);				
	КонецЦикла;
	
	// Удаляем строки из ПолучателейSMS, которым SMS уже было отправленно
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтатусыSMSСообщенийСрезПоследних.КлючСтроки,
		|	СтатусыSMSСообщенийСрезПоследних.IDСообщения,
		|	СтатусыSMSСообщенийСрезПоследних.СтатусСообщения,
		|	СтатусыSMSСообщенийСрезПоследних.СтатусДействия
		|ИЗ
		|	РегистрСведений.СтатусыСообщений.СрезПоследних(, КлючСтроки В (&МассикКлючСтроки)) КАК СтатусыSMSСообщенийСрезПоследних
		|ГДЕ
		|	НЕ (СтатусыSMSСообщенийСрезПоследних.IDСообщения = """"
		|	ИЛИ (&ПереотправитьНедоставленные И СтатусыSMSСообщенийСрезПоследних.СтатусДействия = -2))";
	Запрос.УстановитьПараметр("МассикКлючСтроки", Получатели.ВыгрузитьКолонку("КлючСтроки"));
	Запрос.УстановитьПараметр("ПереотправитьНедоставленные", ПереотправитьНедоставленные);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаРезультат Из Результат Цикл
		Пока Получатели.Найти(СтрокаРезультат.КлючСтроки, "КлючСтроки") <> Неопределено Цикл
			Получатели.Удалить(Получатели.Найти(СтрокаРезультат.КлючСтроки, "КлючСтроки"));
		КонецЦикла;
	КонецЦикла;	
	
	// Отправка запроса
	ПолучателиСодержание = Получатели.Скопировать();
	ПолучателиСодержание.Свернуть("Содержание");
	ПолучателиСодержание = ПолучателиСодержание.ВыгрузитьКолонку("Содержание");
	
	Для Каждого СодержаниеЭлемент Из ПолучателиСодержание Цикл
		ВременнаяПолучатели = Получатели.Скопировать(Получатели.НайтиСтроки(Новый Структура("Содержание", СодержаниеЭлемент)));
		ВыдаватьСообщенияОбОшибке = (Найти(Документ.Комментарий, "{Сформирован автоматически}") = 0);
		Результат = ОбработкаСервисSMSРассылки.ОтправитьSMS(СодержаниеЭлемент, ВременнаяПолучатели, ВыдаватьСообщенияОбОшибке);
		Если ВыдаватьСообщенияОбОшибке И Отказ = Ложь Тогда
			Отказ = Не Результат;
		КонецЕсли;
		Для Каждого СтрокаТЗ Из ВременнаяПолучатели Цикл
			НайденнаяСтрока = Получатели.Найти(СтрокаТЗ.КлючСтроки, "КлючСтроки");
			ЗаполнитьЗначенияСвойств(НайденнаяСтрока, СтрокаТЗ);
		КонецЦикла;
	КонецЦикла;	
	Получатели.ЗаполнитьЗначения(ТекущаяДата(), "Период");
	
	// Проведение по регистру
	ТекущиеДвижениеПоРегистру = РегистрыСведений.СтатусыСообщений.СоздатьНаборЗаписей();
	ТекущиеДвижениеПоРегистру.Прочитать();
	ТекущиеДвижениеПоРегистру = ТекущиеДвижениеПоРегистру.Выгрузить();
	
	ДвижениеПоРегистру = РегистрыСведений.СтатусыСообщений.СоздатьНаборЗаписей();
	Для Каждого СтрокаТЗ Из Получатели Цикл
		СтруктураПоиска = Новый Структура("КлючСтроки, СтатусДействия, СтатусСообщения, IDСообщения, НомерТелефона", СтрокаТЗ.КлючСтроки, СтрокаТЗ.СтатусДействия, СтрокаТЗ.СтатусСообщения, СтрокаТЗ.IDСообщения, СтрокаТЗ.НомерТелефона);
		Если ТекущиеДвижениеПоРегистру.НайтиСтроки(СтруктураПоиска).Количество() = 0 Тогда
			НоваяСтрока = ДвижениеПоРегистру.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);			
		КонецЕсли;
	КонецЦикла;
	Если ДвижениеПоРегистру.Количество() > 0 Тогда
		ДвижениеПоРегистру.Записать(Ложь);
	КонецЕсли;
			
КонецПроцедуры // ОтправитьSMSПоДокументу()

