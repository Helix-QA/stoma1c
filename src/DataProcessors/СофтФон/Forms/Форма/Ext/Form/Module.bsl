// Функция, выполняет возврат ФИО 
//
Функция ВернутьАбонемента(НомерТелефона)
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	КонтрагентыКонтактнаяИнформация.Ссылка,
	                      |	КонтрагентыКонтактнаяИнформация.Ссылка.Наименование КАК Клиент,
	                      |	КонтрагентыКонтактнаяИнформация.Ссылка.НаименованиеПолное КАК ФИО,
	                      |	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК ЧистыйНомер
	                      |ИЗ
	                      |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	                      |ГДЕ
	                      |	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	                      |	И КонтрагентыКонтактнаяИнформация.НомерТелефона ПОДОБНО &Телефон");
				  
	НомерТелефона = СтрЗаменить(НомерТелефона, "+", "");
	ПерваяЦифра = Сред(НомерТелефона, 1, 1);
	Если СтрДлина(НомерТелефона) > 10 и (ПерваяЦифра = "7" или ПерваяЦифра = "8") Тогда
		мНомерТелефона = "%" + Сред(НомерТелефона, 2);
	ИначеЕсли СтрДлина(НомерТелефона) > 8 И СтрДлина(НомерТелефона) <= 10 Тогда
		мНомерТелефона = "%" + НомерТелефона;
	Иначе
		мНомерТелефона = НомерТелефона;
	КонецЕсли;	
	Запрос.УстановитьПараметр("Телефон", мНомерТелефона);
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда		
		Возврат Новый Структура("Анкета, Клиент, НомерТелефона", Результат[0].Ссылка, Результат[0].Клиент, Результат[0].ЧистыйНомер);
	Иначе
		Возврат Новый Структура("Анкета, Клиент, НомерТелефона", Неопределено, "Неопределен", НомерТелефона);
	КонецЕсли;
	
	
КонецФункции

