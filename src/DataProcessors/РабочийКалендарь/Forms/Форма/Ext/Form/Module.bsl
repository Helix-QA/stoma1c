&НаСервере
// Функция - Сформировать планы
//
// Параметры:
//  ВыводитьБлок - 	 - 
//  ПланыЛечения - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьПланы(ВыводитьБлок = Ложь, ПланыЛечения)
	
	СтрокаПлана = 
	"<tr valign='middle' style='padding: 5px;'>
	|            <td class='right_col' align='right'>
	|                <p title='' class='author'>{Дата}</p>
	|            </td>
	|            <td class='right_col' align='right'>
	|                <a title='' class='author' href='{НавигационнаяСсылка}'>{ПланЛечения}</a>
	|            </td>
	|            <td class='right_col' align='right'>
	|                <a title='' class='author' href='{НавигационнаяСсылкаСтрах}' style = 'cursor:{text}' >{СтраховаяКомпания}</a>  
	|            </td>
	|            <td class='right_col' align='right'>
	|                <p title='' class='author'>{СтатусПланаЛечения}</p>
	|            </td>
	|            <td class='right_col' align='right'>
	|                <p title='' class='author'>{СуммаДокумента}</p>
	|            </td>
	|            <td class='right_col' align='right'>
	|                <p title='' class='author'>{СуммаАванса}</p>
	|            </td>
	|            <td class='right_col' align='right'>
	|                <p title='' class='author'>{ПроцентВыполнения}</p>
	|            </td>
	|        </tr>
	|		 <tr>
	|            <td colspan='3' style='height: 8px;'></td>
	|        </tr>";
	
	СтрокаПлановЛечения = "";
	
	Если ЗначениеЗаполнено(Контрагент) И ПланыЛечения.Количество() > 0 Тогда
		СуммаИтого         = 0;
		СуммаОплаченоИтого = 0;
		СуммаСписаноИтого  = 0;
		
		Пока ПланыЛечения.Следующий() Цикл
			СуммаИтого = СуммаИтого + ПланыЛечения.СуммаИтого;		
		КонецЦикла;	
		
		ПланыЛечения.Сбросить();
		Пока ПланыЛечения.Следующий() Цикл
			
			ВыводитьБлок = Истина;
			
			ПланЛечения	= Формат(ПланыЛечения.ПланЛеченияСсылка.Дата, "ДФ=HH:mm") + ", Врач: " + Строка(ПланыЛечения.ПланЛеченияСсылка.Сотрудник);
			Если ЗначениеЗаполнено(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования) Тогда
				СтраховаяКомпания  				= Строка(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.СтраховаяКомпания) + ", полис №" + Строка(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.НомерПолиса) + "-" + Строка(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.СерияПолиса) + " до: " + Формат(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.ДатаОкончания, "ДФ='dd MMMM yyyy'");			
				РасшифровкаСтраховаяКомпания	= ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования;								
			Иначе				
				СтраховаяКомпания  				= "<Отсутствует>";
				РасшифровкаСтраховаяКомпания	= "";				
			КонецЕсли;
			СуммаДокумента 			= Формат(ПланыЛечения.СуммаИтого, "ЧДЦ=2; ЧРД=.");
			РасшифровкаПланаЛечения	= ПланыЛечения.ПланЛеченияСсылка;
			
			ВыборкаПоУслугам = ПланыЛечения.Выбрать(ОбходРезультатаЗапроса.Прямой);
			ПроцентВыполнения = Отчеты.ИнформацияПоКлиенту.ЗаполнитьПроцентВыполненияПланаЛечения(ВыборкаПоУслугам,,, Истина, Ложь);
			
			НоваяСтрокаПланаЛечения = СтрЗаменить(СтрокаПлана			 , "{Дата}"			            , Формат(ПланыЛечения.ПланЛеченияСсылка.Дата, "ДЛФ=Д"));
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{ПланЛечения}"	            , ПланЛечения);
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{НавигационнаяСсылка}"      , ПолучитьНавигационнуюСсылку(ПланыЛечения.ПланЛеченияСсылка));
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{СтраховаяКомпания}"        , СтраховаяКомпания);
			Если СтраховаяКомпания  = Строка(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.СтраховаяКомпания) + ", полис №" + Строка(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.НомерПолиса) + "-" + Строка(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.СерияПолиса) + " до: " + Формат(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования.ДатаОкончания, "ДФ='dd MMMM yyyy'") Тогда
			
				НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{НавигационнаяСсылкаСтрах}" , ПолучитьНавигационнуюСсылку(ПланыЛечения.ПланЛеченияСсылка.ПолисМедСтрахования));
				
			Иначе
				НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{text}" , "text; text-decoration:none");
			КонецЕсли; 		
				
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{СтатусПланаЛечения}"       , ПланыЛечения.ПланЛеченияСсылка.Статус);
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{СуммаДокумента}"           , СуммаДокумента);
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{СуммаАванса}"           	, РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьСуммуВнесенногоАвансПоДокументу( ПланыЛечения.ПланЛеченияСсылка));
			НоваяСтрокаПланаЛечения = СтрЗаменить(НоваяСтрокаПланаЛечения, "{ПроцентВыполнения}"        , ПроцентВыполнения);
			
			СтрокаПлановЛечения = СтрокаПлановЛечения + НоваяСтрокаПланаЛечения;
		КонецЦикла; 		
	КонецЕсли;
	
	Возврат СтрокаПлановЛечения;
	
КонецФункции

&НаСервере
