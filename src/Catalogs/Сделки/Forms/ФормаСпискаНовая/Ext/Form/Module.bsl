&НаКлиенте
// Функция - Данные выбранных фильтров.
//
Функция ПараметрыВыбранныхФильтровКлиент()
	
	ПараметрыОтбора = Новый Структура;
	
	Для Каждого Строка из ТаблицаФильтров Цикл
		Если Строка.КоличествоАктивированныхЗначений > 0 Тогда
			
			МассивДанных = ПолучениеЭлементовОтбораКлиент(Новый Массив, Строка.СписокЗначений, Строка.Наименование);
			
			Если Строка.Наименование = "Фильтр_Статус" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусов"			   				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусов_ВариантОтбора"				, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_СтруктурнаяЕдиница" Тогда
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц"					, МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтруктурныхЕдиниц_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Менеджер" Тогда
				ПараметрыОтбора.Вставить("МассивМенеджеров"				 			, МассивДанных);
				ПараметрыОтбора.Вставить("МассивМенеджеров_ВариантОтбора"			, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Врач" Тогда
				ПараметрыОтбора.Вставить("МассивВрачей"				 				, МассивДанных);
				ПараметрыОтбора.Вставить("МассивВрачей_ВариантОтбора"				, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_СотрудникРегистрации" Тогда
				ПараметрыОтбора.Вставить("МассивСотрудниковРегистрации"				 , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСотрудниковРегистрации_ВариантОтбора", Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_РекламныйИсточник" Тогда
				ПараметрыОтбора.Вставить("МассивРекламныхИсточников"			  	, МассивДанных);
				ПараметрыОтбора.Вставить("МассивРекламныхИсточников_ВариантОтбора"	, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_ПричинаОтказа" Тогда
				ПараметрыОтбора.Вставить("МассивПричинОтказов"			  			, МассивДанных);
				ПараметрыОтбора.Вставить("МассивПричинОтказов_ВариантОтбора"		, Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_Тег" Тогда
				ПараметрыОтбора.Вставить("МассивТегов"								, МассивДанных);
				ПараметрыОтбора.Вставить("МассивТегов_ВариантОтбора"				, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_Интерес" Тогда
				ПараметрыОтбора.Вставить("МассивИнтересов"							, МассивДанных);
				ПараметрыОтбора.Вставить("МассивИнтересов_ВариантОтбора"			, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_КаналПривлечения" Тогда
				ПараметрыОтбора.Вставить("МассивКаналовПривлечения"				 	, МассивДанных);
				ПараметрыОтбора.Вставить("МассивКаналовПривлечения_ВариантОтбора"	, Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПредварительнаяЗапись" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияПредварительнойЗаписи"			   , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияПредварительнойЗаписи_ВариантОтбора", Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_Задача" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияЗадач"			   , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовНаличияЗадач_ВариантОтбора", Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПризнакВыполненияСделки" Тогда
				ПараметрыОтбора.Вставить("МассивСтатусовСделок"			     , МассивДанных);
				ПараметрыОтбора.Вставить("МассивСтатусовСделок_ВариантОтбора", Строка.ВариантОтбора);

			ИначеЕсли Строка.Наименование = "Фильтр_ПометкаУдаленияСделки" Тогда
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления"			  , МассивДанных);
				ПараметрыОтбора.Вставить("СписокСтатусовПометокУдаления_ВариантОтбора", Строка.ВариантОтбора);
				
			ИначеЕсли Строка.Наименование = "Фильтр_СозданаПериод" Тогда
				ПараметрыОтбора.Вставить("ПериодСозданияСделки", МассивДанных);

			ИначеЕсли Строка.Наименование = "Фильтр_ПериодЗапланированнойЗадачи" Тогда
				ПараметрыОтбора.Вставить("ПериодПланирования", МассивДанных);

			ИначеЕсли Строка.Наименование = "Фильтр_ЗавершенаПериод" Тогда
				ПараметрыОтбора.Вставить("ПериодСделки", МассивДанных);	
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПараметрыОтбора;
	
КонецФункции

&НаКлиенте
// Функция - ПолучениеЭлементовОтбора
Функция ПолучениеЭлементовОтбораКлиент(Массив, СписокЗначений, НаименованиеФильтра)
	
	Если НаименованиеФильтра = "Фильтр_СозданаПериод" 
		Или НаименованиеФильтра = "Фильтр_ЗавершенаПериод" 
		Или НаименованиеФильтра = "Фильтр_ПериодЗапланированнойЗадачи" Тогда
		
		Если СписокЗначений.Количество() > 0 Тогда
			ЗаданноеЗначение = СписокЗначений.Получить(0).Значение; 
			Массив.Добавить(ЗаданноеЗначение.ЗначениеФильтра);
		КонецЕсли;
		
	Иначе
		
		Если СписокЗначений.Количество() > 0 Тогда
			Для каждого Значение из СписокЗначений Цикл
				Если Значение.Значение.Выбран = Истина Тогда
					Массив.Добавить(Значение.Значение.ЗначениеФильтра);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Массив;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура ПослеВыбораВидаСделки(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Или Результат.Значение = ЭтотОбъект.ОтборВидСделки Тогда
		// Ничего не изменилось - действий не требуется.
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.ОтборВидСделки			 = Результат.Значение;
	Элементы.ИзменитьВидСделки.Заголовок = Результат.Представление;
	
	АктуализироватьДанныеСпискаСогласноОтборов();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Процедура, устанавливает отображение фильтров по задачам.
//
Процедура УстановитьОтображениеФильтровПоЗадачам(Форма, ОтборБезАктивности = Ложь, ОтборПросроченныхЗадач = Ложь, ОтборЗадачНаСегодня = Ложь)
	
	ФонАктивнойГруппы	 = Новый Цвет(218, 230, 244);
	ФонНеактивнойГруппы	 = Новый Цвет(255, 255, 255);
	
	Форма.Элементы.ГруппаБезЗадач.ЦветФона			 = ФонНеактивнойГруппы;
	Форма.Элементы.ГруппаЗадачиНаСегодня.ЦветФона	 = ФонНеактивнойГруппы;
	Форма.Элементы.ГруппаПросроченныеЗадачи.ЦветФона = ФонНеактивнойГруппы;
	
	Форма.Элементы.СброситьОтборБезЗадач.Видимость			 = Ложь;
	Форма.Элементы.СброситьОтборЗадачиНаСегодня.Видимость	 = Ложь;
	Форма.Элементы.СброситьОтборПросроченныеЗадачи.Видимость = Ложь;
	
	Если ОтборБезАктивности = Истина Тогда
		
		Форма.Элементы.ГруппаБезЗадач.ЦветФона			 = ФонАктивнойГруппы;
		Форма.Элементы.СброситьОтборБезЗадач.Видимость	 = Истина;
		
		Форма.ОтборПоЗадачам = 3;
		
	ИначеЕсли ОтборЗадачНаСегодня = Истина Тогда
		
		Форма.Элементы.ГруппаЗадачиНаСегодня.ЦветФона			 = ФонАктивнойГруппы;
		Форма.Элементы.СброситьОтборЗадачиНаСегодня.Видимость	 = Истина;
		
		Форма.ОтборПоЗадачам = 1;
		
	ИначеЕсли ОтборПросроченныхЗадач = Истина Тогда
		
		Форма.Элементы.ГруппаПросроченныеЗадачи.ЦветФона			 = ФонАктивнойГруппы;
		Форма.Элементы.СброситьОтборПросроченныеЗадачи.Видимость	 = Истина;
		
		Форма.ОтборПоЗадачам = 2;
		
	Иначе
		Форма.ОтборПоЗадачам = 0;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Возвращает значение свойства структуры.
//
// Параметры:
//   Структура - Структура
//             - ФиксированнаяСтруктура - объект, из которого необходимо прочитать значение ключа.
//   Ключ - Строка - имя свойства структуры, для которого необходимо прочитать значение.
//   ЗначениеПоУмолчанию - Произвольный - необязательный. Возвращается когда в структуре нет значения по указанному
//                                        ключу.
//       Для скорости рекомендуется передавать только быстро вычисляемые значения (например примитивные типы),
//       а инициализацию более тяжелых значений выполнять после проверки полученного значения (только если это
//       требуется).
//
// Возвращаемое значение:
//   Произвольный - значение свойства структуры. ЗначениеПоУмолчанию если в структуре нет указанного свойства.
//
Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	Возврат ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию);
	
КонецФункции

