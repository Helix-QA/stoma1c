// Процедура, распределяет сделки и задачи в пропорции.
//
Процедура РаспределитьВПропорции(Знач ТаблицаЗначенийКлиентов)
	
	КоличествоСотрудников = ЭтотОбъект.ТаблицаДействия.Количество();
	
	Если КоличествоСотрудников <= 0 Тогда		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не выбраны исполнители!';en='Not selected performers!'"));
		Возврат;	
	КонецЕсли;
	
	ТипЧисло = Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(3));
	
	ТЗСотрудников = ЭтотОбъект.ТаблицаДействия.Выгрузить();
	ТЗСотрудников.Колонки.Добавить("КоличествоКлиентов"	, ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("ПроцентТекущий"		, ТипЧисло);
	ТЗСотрудников.Колонки.Добавить("Дельта"				, ТипЧисло);
	
	ТЗКлиентовСотрудников = ТаблицаЗначенийКлиентов.Скопировать(,"Контрагент");
	ТЗКлиентовСотрудников.Колонки.Добавить("Сотрудник");
	
	НачатьТранзакцию();
	
	Для Каждого СтрокаТЗ Из ТЗКлиентовСотрудников Цикл
		
		ПриоритетныйСотрудник = Неопределено;
		ПриоритетныйПроцент   = 0;
		
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			Если СтрокаСотрудников.Дельта >= ПриоритетныйПроцент Тогда
				
				ПриоритетныйСотрудник = СтрокаСотрудников.Сотрудник;
				ПриоритетныйПроцент   = СтрокаСотрудников.Дельта;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЭтотОбъект.СоздатьЗадачу Тогда
			
			ОбъектЗадача = Задачи.Взаимодействие.СоздатьЗадачу();
			ДанныеЗаполнения = Новый Структура;
			ДанныеЗаполнения.Вставить("Контрагент"                 , СтрокаТЗ.Контрагент);
			ДанныеЗаполнения.Вставить("ВидВзаимодействия"          , ЭтотОбъект.ВзаимодействиеПараметры.ВидВзаимодействия);
			ДанныеЗаполнения.Вставить("ВидВзаимодействияСправочник", ЭтотОбъект.ВзаимодействиеПараметры.Взаимодействие);
			ДанныеЗаполнения.Вставить("Исполнитель"                , ПриоритетныйСотрудник);
			ДанныеЗаполнения.Вставить("ЗадачаНазначеннаяДата"      , ЭтотОбъект.ВзаимодействиеЗадачаДата);
			ДанныеЗаполнения.Вставить("ЗадачаТема"                 , ЭтотОбъект.ВзаимодействиеЗадачаТема);
			ДанныеЗаполнения.Вставить("ЗадачаОписание"             , ЭтотОбъект.ВзаимодействиеОписание);
			ДанныеЗаполнения.Вставить("Сделка"                     , Справочники.Сделки.ПолучитьАктуальнуюСделкуКлиента(СтрокаТЗ.Контрагент));
			
			НоваяЗадача = Задачи.Взаимодействие.СоздатьЗадачу();
			НоваяЗадача.Заполнить(ДанныеЗаполнения);	
			
			Задачи.Взаимодействие.ЗаполнитьПараметрыНапоминания(НоваяЗадача, Новый Структура("ЗадачаРежимНапоминания", ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминания));	
			
			НоваяЗадача.Записать();
		
		Иначе
			
			НоваяСделка   = Справочники.Сделки.СоздатьЭлемент();		
			ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(ЭтотОбъект.ВидСделки);
			
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("Контрагент"	,СтрокаТЗ.Контрагент);
			ДанныеЗаполнения.Вставить("ВидСделки"	,ЭтотОбъект.ВидСделки);
			ДанныеЗаполнения.Вставить("ЭтапСделки"	,?(ТаблицаЭтапов.Количество()> 0, ТаблицаЭтапов[0].ЭтапСделки, Неопределено));
			ДанныеЗаполнения.Вставить("КаналПривлечения"  ,СтрокаТЗ.Контрагент.КаналПривлечения); 
			ДанныеЗаполнения.Вставить("ИсточникИнформации",СтрокаТЗ.Контрагент.ИсточникИнформации);
			ДанныеЗаполнения.Вставить("ИсточникИнформацииЗначение",СтрокаТЗ.Контрагент.ИсточникИнформацииЗначение);
			ДанныеЗаполнения.Вставить("Описание"    , ЭтотОбъект.ВзаимодействиеОписание); 
			ДанныеЗаполнения.Вставить("Менеджер"    , ПриоритетныйСотрудник);
			
			НоваяСделка.Заполнить(ДанныеЗаполнения);
			НоваяСделка.Записать();

		КонецЕсли;
		
		СтрокаТЗСотрудников = ТЗСотрудников.Найти(ПриоритетныйСотрудник);
		
		// Обновляем данные в таблице сотрудников.
		Если СтрокаТЗСотрудников <> Неопределено Тогда
			
			СтрокаТЗСотрудников.КоличествоКлиентов = СтрокаТЗСотрудников.КоличествоКлиентов + 1;
			СтрокаТЗСотрудников.ПроцентТекущий 	   = СтрокаТЗСотрудников.КоличествоКлиентов/ТЗСотрудников.Итог("КоличествоКлиентов")*100; 
			СтрокаТЗСотрудников.Дельта 		       = СтрокаТЗСотрудников.Пропорция - СтрокаТЗСотрудников.ПроцентТекущий;
			
		КонецЕсли;
		
		// Обновляем данные в таблице значений.
		Для Каждого СтрокаСотрудников Из ТЗСотрудников Цикл
			
			СтрокаСотрудников.ПроцентТекущий 	   = СтрокаСотрудников.КоличествоКлиентов/ТЗСотрудников.Итог("КоличествоКлиентов")*100; 
			СтрокаСотрудников.Дельта 		       = СтрокаСотрудников.Пропорция - СтрокаСотрудников.ПроцентТекущий;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();

КонецПроцедуры

