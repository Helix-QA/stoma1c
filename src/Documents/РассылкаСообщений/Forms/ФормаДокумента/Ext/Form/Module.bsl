КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ПодборПоШаблону"
//
Процедура ПодборПоШаблону(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодборПоШаблонуЗавершение", ЭтотОбъект);
	
	Если Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
		ОткрытьФорму("Справочник.ШаблоныСообщений.Форма.ФормаВыбораДляМессенджера",,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		ПараметрыВыбораШаблона = Новый Структура;
		ПараметрыВыбораШаблона.Вставить("ТипШаблона", Объект.Тип);
		
		ОткрытьФорму("Справочник.ШаблоныСообщений.ФормаВыбора", ПараметрыВыбораШаблона,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПодборПоШаблонуЗавершение"
//
Процедура ПодборПоШаблонуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
		ИмяРеквизитаСодержание = "Содержание";
		
	ИначеЕсли Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда
		ИмяРеквизитаСодержание = "СодержаниеМессенджер";
		
	ИначеЕсли Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда
		ИмяРеквизитаСодержание = "СодержаниеPush";
		
	КонецЕсли;
	
	Объект.Содержание = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Результат, ИмяРеквизитаСодержание);
	ПреобразоватьСодержаниеСПараметрамиВТекст(Объект.Содержание, Объект);
	
	Если Объект.Тип = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
		ОбновитьСтатусВведеныхСимволов(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура, обработчик команды "ПодборПоШаблону"
//
Процедура ПреобразоватьСодержаниеСПараметрамиВТекст(Содержание, Знач Документ)
	
	Если Документ.ВидОперации = Перечисления.ВидОперацииОтправкаSMS.ОтправкаSMSПолучателю Тогда
		Содержание = Документы.РассылкаСообщений.ПреобразоватьСодержаниеСПараметрамиВТекст(Содержание, Документ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "Транслитерация"
//
Процедура Транслитерация(Команда)
	
	Если (КодСимвола(Объект.Содержание) >= 65 И КодСимвола(Объект.Содержание) <= 90) ИЛИ (КодСимвола(Объект.Содержание) >= 97 И КодСимвола(Объект.Содержание) <= 122) Тогда
		Объект.Содержание = СтроковыеФункцииКлиентСерверСтоматология.ТранслитерацияАнглРус(Объект.Содержание);
	ИначеЕсли КодСимвола(Объект.Содержание) >= 1040 И КодСимвола(Объект.Содержание) <= 1103 Тогда
		Объект.Содержание = СтроковыеФункцииКлиентСерверСтоматология.ТранслитерацияРусАнгл(Объект.Содержание);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "КомандаОбновитьСтатусыSMS"
//
Процедура КомандаОбновитьСтатусыSMS(Команда)
	
	ВыполнитьПроверкуСтатусовSMS();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ОбновитьБаланс"
//
Процедура ОбновитьБаланс(Команда)
	
	ОбновитьБалансАккаунтаSMS();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Пополнить баланс
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПополнитьБаланс(Команда)
	
	ОткрытьФорму("Справочник.СервисыРассылки.Форма.ФормаЗапросаПополненияБалансаСмсСервиса",,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура MessengerОтправитьВсемПриИзменении(Элемент)
	
	Элементы.ГруппаИнициироватьОтправкуСообщений.Видимость = ЭтотОбъект.MessengerОтправитьВсем;
	
	Если ЭтотОбъект.MessengerОтправитьВсем Тогда
		ЭтотОбъект.ТекущийЭлемент = Элементы.ГруппаРекомендацияВсплывающая;
		Элементы.ГруппаРекомендацияВсплывающая.Показать();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Получатели) Тогда
		ЗаполнитьТаблицуПолучателей();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля "Дата".
//
Процедура ДатаПриИзменении(Элемент)

	ДатаПередИзменением = ДатаДокумента;
	ДатаДокумента = Объект.Дата;
	Если Объект.Дата <> ДатаПередИзменением Тогда
		СтруктураДанные = ПолучитьДанныеДатаПриИзменении(Объект.Ссылка, Объект.Дата, ДатаПередИзменением);
		Если СтруктураДанные.РазностьДат <> 0 Тогда
			Объект.Номер = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОкончаниеВводаТекста" поле ввода "Содержание"
//
Процедура СодержаниеОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ЭтотОбъект.ОтправкаSMS Тогда
		ПодключитьОбработчикОжидания("ЗапуститьОбновлениеСтатусаВведенныхСимволов", 0.2, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ПолучателиПолучательПриИзменении(Элемент)
	
	СтрокаДанных = Элементы.Получатели.ТекущиеДанные;
	
	СтрокаДанных.НомерТелефона  = Неопределено;
	СтрокаДанных.СервисРассылки = Неопределено;
	СтрокаДанных.ТипОтправки    = Неопределено;
	СтрокаДанных.Активность     = Истина;
	
	Если ЗначениеЗаполнено(СтрокаДанных.Получатель) Тогда
		
		ЗаполнитьДанныеПолучателяСообщения(СтрокаДанных.КлючСтроки);
		
		Если Не ЗначениеЗаполнено(СтрокаДанных.СервисРассылки) Тогда
			СтрокаДанных.Получатель = Неопределено;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ru = 'Для выбранного клиента нет доступных сервисов рассылки!'; en = 'There are no message services available for the selected client!'"));
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПриИзменении".
//
Процедура ЗаполнитьДанныеПолучателяСообщения(КлючСтроки)
	
	СтрокаДанных = Объект.Получатели.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки))[0];
	
	Если Не ЗначениеЗаполнено(СтрокаДанных.СервисРассылки) Тогда
		
		Если Объект.Тип = Перечисления.ТипыСобытий.SMS Тогда
			
			ЗаполнитьДанныеПолучателяSMSСообщения(СтрокаДанных);
			
		ИначеЕсли Объект.Тип = Перечисления.ТипыСобытий.Мессенджер Тогда
			
			ЗаполнитьДанныеПолучателяСообщенияMessenger(СтрокаДанных);
			
			Если Не ЗначениеЗаполнено(СтрокаДанных.СервисРассылки)
				И ЭтотОбъект.MessengerОтправитьВсем Тогда
				
				ЗаполнитьДанныеПолучателяСообщенияMessengerИнициироватьОтправку(СтрокаДанных);
			КонецЕсли;	
			
		ИначеЕсли Объект.Тип = Перечисления.ТипыСобытий.ПушУведомление Тогда
			
			ЗаполнитьДанныеПолучателяPushУведомленияWallet(СтрокаДанных);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаполнитьПредставлениеКоличестваПолучателей();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ПолучателиТелефонПриИзменении(Элемент)
	
	ТекущиеДанные    = Элементы.Получатели.ТекущиеДанные;
	ПриведенныйНомер = ВернутьПриведенныйНомер(ТекущиеДанные.НомерТелефона); 
	
	Если Объект.Получатели.НайтиСтроки(Новый Структура("НомерТелефона", ПриведенныйНомер)).Количество() > 1 Тогда 
		ТекущиеДанные.НомерТелефона = "";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Данный номер телефона уже имеется в списке получателей."); 		
	Иначе
		ТекущиеДанные.НомерТелефона = ПриведенныйНомер;
	КонецЕсли; 
	
	ТекущиеДанные.IdСообщения     = Неопределено;
	ТекущиеДанные.СтатусСообщения = Неопределено;
	ТекущиеДанные.СтатусДействия  = Неопределено; 
	СтатусСообщения               = Неопределено;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ОтправитьНемедленноПриИзменении(Элемент)
	
	Если Объект.ОтправитьНемедленно = Ложь Тогда
		Элементы.ГруппаДатыРассылки.Видимость = Истина;
		Если Не ЗначениеЗаполнено(Объект.ДатаОтправки) Тогда
			Объект.ДатаОтправки = ТекущаяДата();
		КонецЕсли;
	ИначеЕсли Объект.ОтправитьНемедленно = Истина Тогда
		Элементы.ГруппаДатыРассылки.Видимость = Ложь;
		Если ЗначениеЗаполнено(Объект.ДатаОтправки) Тогда
			Объект.ДатаОтправки = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

