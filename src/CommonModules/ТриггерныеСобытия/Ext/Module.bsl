// Процедура - Подписка регистрация триггерных событий КОРП обработка проведения
//
// Параметры:
//  Источник		 - 	 - 
//  Отказ			 - 	 - 
//  РежимПроведения	 - 	 - 
//
Процедура Подписка_РегистрацияТриггерныхСобытий_ОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	// Возврат;
	
	Если Отказ ИЛИ Источник.ОбменДанными.Загрузка ИЛИ НЕ ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП() Тогда 
		Возврат;
	КонецЕсли;
	
	ОбъектСобытия 		= Источник;	
	ТаблицаТриггеров 	= ПолучитьАктуальныеТриггеры(ОбъектСобытия);
	Если ТаблицаТриггеров = Неопределено ИЛИ ТаблицаТриггеров.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;	
	
	Для Каждого СтрокаТриггер Из ТаблицаТриггеров Цикл
		ЗарегистрироватьСобытие(СтрокаТриггер, Истина, , ОбъектСобытия);
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Регистрация триггерных событий КОРП при записи при записи
//
// Параметры:
//  Источник - 	 - 
//  Отказ	 - 	 - 
//
Процедура Подписка_РегистрацияТриггерныхСобытий_ПриЗаписи(Источник, Отказ) Экспорт
	
	// Возврат;
	
	Если Отказ ИЛИ НЕ ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП() Тогда 
		Возврат;
	ИначеЕсли Источник.ОбменДанными.Загрузка
			И НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Источник.ДополнительныеСвойства, "НеобходимоИнициироватьВыполнениеТриггерногоСобытия", Ложь) Тогда 
		Возврат;	
	КонецЕсли;
	
	ОбъектСобытия 			= Источник;
	ТаблицаДанныхТриггеров 	= ПолучитьАктуальныеТриггеры(ОбъектСобытия);
	
	Если ТаблицаДанныхТриггеров = Неопределено ИЛИ ТаблицаДанныхТриггеров.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;	
	
	Для Каждого СтрокаТриггер Из ТаблицаДанныхТриггеров Цикл
		ЗарегистрироватьСобытие(СтрокаТриггер, Истина, , ОбъектСобытия);
	КонецЦикла;	
	
КонецПроцедуры
	
// Процедура - Подписка регистрация триггерных событий КОРП при записи набора записей
//
// Параметры:
//  Источник	 - 	 - 
//  Отказ		 - 	 - 
//  Замещение	 - 	 - 
//
Процедура Подписка_РегистрацияТриггерныхСобытий_ПриЗаписиНабораЗаписей(Источник, Отказ, Замещение) Экспорт
	
	// Возврат;
	
	Если Отказ ИЛИ Источник.ОбменДанными.Загрузка ИЛИ Источник.ДополнительныеСвойства.Свойство("ЭтоПроведениеЗагруженныхДанных") ИЛИ НЕ ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП() Тогда 
		Возврат;
	КонецЕсли;
	
	ОбъектСобытия 			= Источник;
	ТаблицаДанныхТриггеров 	= ПолучитьАктуальныеТриггеры(ОбъектСобытия);
	
	Если ТаблицаДанныхТриггеров = Неопределено ИЛИ ТаблицаДанныхТриггеров.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;	
	
	Для Каждого СтрокаТриггер Из ТаблицаДанныхТриггеров Цикл
		ЗарегистрироватьСобытие(СтрокаТриггер, Истина, , ОбъектСобытия);
	КонецЦикла;

КонецПроцедуры

// Процедура - Выполнить регистрацию триггерных событий
//
Процедура Регламент_ВыполнитьРегистрациюТриггерныхСобытий(МассивСтруктурныхЕдиниц = Неопределено) Экспорт
	
	// Возврат;
	
	Если МассивСтруктурныхЕдиниц = Неопределено Тогда 	
		Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
			И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
			Возврат;
		КонецЕсли;
		
		ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.РегистрацияТриггерныхСобытий);
		
