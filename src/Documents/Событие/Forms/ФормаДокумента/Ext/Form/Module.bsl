// Процедура, обработчик команды ОтменитьСобытие.
//
Процедура КомандаОтменитьСобытие(Команда)
	
	Если Модифицированность = Истина Тогда
	// Если Вопрос("Событие было модифицировано, перед отменой события все изменения сохраняться.", РежимДиалогаВопрос.ОКОтмена) = КодВозвратаДиалога.ОК Тогда
		Если ОтветПользователяНаВопрос = Неопределено Тогда				
		
			Оповещение = Новый ОписаниеОповещения("ПоказатьПользователюВопросЗавершение_КомандаОтменитьСобытие", ЭтотОбъект, Неопределено);
			ПоказатьВопрос(Оповещение, "Событие было модифицировано, перед отменой события все изменения сохраняться.", РежимДиалогаВопрос.ОКОтмена);
			Возврат;
			
		ИначеЕсли ОтветПользователяНаВопрос = КодВозвратаДиалога.ОК Тогда	
			ОтветПользователяНаВопрос = Неопределено;
			Записать();
		Иначе
			ОтветПользователяНаВопрос = Неопределено;
			Возврат;			
		КонецЕсли;
	
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСтоматология.ОтменитьСобытие(Объект.Ссылка,, Новый ОписаниеОповещения("КомандаОтменитьСобытиеЗавершение", ЭтотОбъект));
			
