&НаСервере
// Процедура - Заполнить значения структуры данных всплывающих групп.
//
Процедура СформироватьСтруктуруДанныхВсплывающихГрупп()
	
	ПараметрыВидимости = Новый Структура;		
	ПараметрыВидимости.Вставить("ИсторияСтатусов"     , Ложь);
	ПараметрыВидимости.Вставить("ВзаимодействиеЗадача", Ложь);
	ПараметрыВидимости.Вставить("SMS"                 , Ложь);
	ПараметрыВидимости.Вставить("Письмо"              , Ложь);
		
	УправлениеИнтерфейсамиСервер.СформироватьРеквизитСтруктурыДанныхВсплывающихГрупп(ЭтаФорма, ПараметрыВидимости);
	
КонецПроцедуры

#Область Статусы

&НаСервере
// Процедура, добавляет на форму статусы контрагента.
//
Процедура ВывестиИсториюСтатусовКонтрагента()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыКонтрагентов.Период КАК Период,
	|	СтатусыКонтрагентов.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
	|ГДЕ
	|	СтатусыКонтрагентов.Контрагент = &Контрагент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ");
	
	Запрос.УстановитьПараметр("Контрагент",	Объект.Ссылка);
	
	ТаблицаСтатусов = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТ Из ТаблицаСтатусов Цикл
		
		НоваяСтрока = ЭтотОбъект.СтатусыКлиента.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТ);
		
		ИндексЭлементов = НоваяСтрока.ПолучитьИдентификатор(); 
		
		СкопироватьЭлементФормыРекурсивно(Элементы.ГруппаСтатус_Шаблон, Элементы.ГруппаИсторияСтатусов, ИндексЭлементов);						
		
		Элементы["ДекорацияПериод_" + ИндексЭлементов].Заголовок = Формат(СтрокаТ.Период, "ДФ='д МММ гггг'"); 
		
		УправлениеИнтерфейсамиСервер.ДобавитьЗначениеВРеквизитСтруктурыДанныхВсплывающихГрупп(ЭтаФорма, "Статус_" + ИндексЭлементов);	
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
// Процедура, копирует элементы формы.
//
Процедура СкопироватьЭлементФормыРекурсивно(Источник, Родитель, Индекс)
	
	Если ТипЗнч(Источник) = Тип("ГруппаФормы") Тогда
		
		ГруппаРодитель = УправлениеИнтерфейсамиСервер.КопироватьГруппуФормы(ЭтаФорма, Источник, Индекс, Родитель);
		
		Для Каждого Элемент Из Источник.ПодчиненныеЭлементы Цикл
			СкопироватьЭлементФормыРекурсивно(Элемент, ГруппаРодитель, Индекс);	
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("КнопкаФормы") Тогда 
		
		УправлениеИнтерфейсамиСервер.КопироватьКнопкуФормы(ЭтаФорма, Источник, Индекс, Родитель);
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДекорацияФормы") Тогда	
		
		УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(ЭтаФорма, Источник, Индекс, Тип("ДекорацияФормы"), Родитель);				
	Иначе		
		УправлениеИнтерфейсамиСервер.КопироватьЭлементФормы(ЭтаФорма, Источник, Индекс, Тип("ПолеФормы"), Родитель, ВернутьПутьКДанным(Источник, Индекс));				
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Вернуть путь к данным
//
// Параметры:
//  ИмяЭлемента	 - 	 - 
//  Индекс		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьПутьКДанным(Источник, Индекс)
	
	ИмяЭлемента = Источник.Имя;
	
	Если СтрНайти(ИмяЭлемента, "Документ") > 0 Тогда 
		
		ПутьКДанным = Источник.ПутьКДанным;
	Иначе
		ПутьКДанным = СтрЗаменить(Источник.ПутьКДанным, "[0]", "[" + Индекс + "]");
	КонецЕсли;
	
	Возврат ПутьКДанным;
	
КонецФункции

