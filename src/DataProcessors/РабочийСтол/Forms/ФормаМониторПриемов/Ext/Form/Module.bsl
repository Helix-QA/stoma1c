// Процедура - Установить режим вывода KPI
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура УстановитьРежимВыводаKPI(Команда)
	
	Если СтрНайти(Команда.Имя, "KPI") = 0 Тогда 
		КоличествоКолонокДляВыводимыхВиджетов = Число(СтрСоединить(СтрРазделить(Команда.Имя, СтрСоединить(СтрРазделить(Команда.Имя, "0123456789")))));
		УстановитьСвойстваКнопкамТаблицыСортировкиKPI("ТаблицаСортировкиПоказателейВиджетовГруппаКнопок");
		ЗаписатьЗначениеНастройкиПользователяНаСервере("МониторПродаж_КоличествоКолонокДляВыводимыхВиджетов", КоличествоКолонокДляВыводимыхВиджетов);
	Иначе 	
		КоличествоКолонокДляВыводимыхВиджетовKPI = Число(СтрСоединить(СтрРазделить(Команда.Имя, СтрСоединить(СтрРазделить(Команда.Имя, "0123456789")))));
		УстановитьСвойстваКнопкамТаблицыСортировкиKPI("ТаблицаСортировкиПоказателейKPIГруппаКнопок");		
		ЗаписатьЗначениеНастройкиПользователяНаСервере("МониторПродаж_КоличествоКолонокДляВыводимыхВиджетовKPI", КоличествоКолонокДляВыводимыхВиджетовKPI);		
	КонецЕсли;
	
КонецПроцедуры

