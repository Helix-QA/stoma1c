// Процедура, обработчик оповещения.
//
Процедура ВзаимодействиеЗаметкаДобавитьСервер()
	
	ДобавитьЗаметкуЗаявкиКлиента(ЭтотОбъект.ВзаимодействиеЗаметкаТекст, Объект.Ссылка);
	
	ОбновитьИсториюВзаимодействияСКлиентом(, Элементы.КнопкаПодробно.Пометка);
		
	ЭтотОбъект.ВзаимодействиеЗаметкаТекст = "";
	
	СнятьВидимостьВсплывающихГруппСервер("Заметка");
	
