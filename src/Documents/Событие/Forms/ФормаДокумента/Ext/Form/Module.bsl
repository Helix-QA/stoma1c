// Процедура, обработчик события "ПриИзменении" поля "Контрагент" на сервере.
//
Процедура КонтрагентПриИзмененииСервер()
	
	ОбновитьНадписи();
	Объект.ПолисМедСтрахования = Справочники.ПолисыМедицинскогоСтрахования.ПустаяСсылка();
	ОбновитьПолисыМедицинскогоСтрахования();
	ВывестиНезавершенныеНарядЗаказы();
	УправлениеИнтерфейсамиСервер.ОбновитьВиджетСделки(ЭтаФорма, Объект.Контрагент, Объект.Сделка);
	ИнициализироватьКомментарий();
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Контрагент, Объект.СтруктурнаяЕдиница);
		УстановитьВидимостьКнопокПереходаВМессенджер(ЭтотОбъект);
		Элементы.ДобавитьИВыбратьКонтрагента.Видимость = Ложь;
	Иначе
		Элементы.ДобавитьИВыбратьКонтрагента.Видимость = Истина;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьТаблицуМеток();
	КонецЕсли;
	ОбновитьМетки();
	
	УстановитьВидимостьЭлементов();
	
	// Выводим комментарий из карточки клиента в подсказку
	КомментарийКонтрагента = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Контрагент, "Комментарий");
	Если ЗначениеЗаполнено(Объект.Контрагент) И ЗначениеЗаполнено(КомментарийКонтрагента) Тогда 
		Элементы.КонтрагентРасширеннаяПодсказка.Заголовок = КомментарийКонтрагента;	
		Элементы.Контрагент.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
	Иначе 
		Элементы.Контрагент.ОтображениеПодсказки = ОтображениеПодсказки.Авто;
	КонецЕсли;
	
	МассивРодителей = Новый Массив();
	МассивРодителей.Добавить("ГруппаДолгиКонтрагентаСуществующие");
	МассивРодителей.Добавить("ГруппаБудущиеСобытияКлиента");
	ОтображениеДополнительнойИнформации(МассивРодителей);
	
КонецПроцедуры

