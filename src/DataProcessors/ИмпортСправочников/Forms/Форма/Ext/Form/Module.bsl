// Импорт из текстового файла

// Работа с текстовым файлом
&НаКлиенте
Функция ПолучитьПоляФайла()
	
	Если ТипФайлаИмпорта="TEXT" Тогда
		
		// Читаем первую строку файла содержащую наименования колонок
		Текст = Новый ЧтениеТекста(ФайлИмпорта);
		Стр = Текст.ПрочитатьСтроку();
		Если Стр=Неопределено Тогда
			
			ПоказатьПредупреждение(,"Файл импорта пуст ! импорт не возможен !");
			Возврат Ложь;
		КонецЕсли;	 
		
		СписокКолонокФайла = СтрокаВСписок(Стр, СимволРазделитель);
	Иначе
		
		СписокКолонокФайла = ПолчитьПоляИзExcel();
	КонецЕсли;
	
	Если СписокКолонокФайла.Количество() = 0 Тогда 
		
		ПоказатьПредупреждение(,"Файл импорта пуст ! импорт не возможен !");
		Возврат Ложь;
	Иначе
		
		Возврат Истина;	   
	КонецЕсли; 
	
КонецФункции

// Получить строку реквизитов из текстового файла
&НаКлиенте
Функция ЗагрузитьИзТекста()
	
	Попытка
		
		// Выводим оповещение, т.к. показать прогресс в случае с текстовым файлом затруднительно
		ПоказатьОповещениеПользователя("Выполнение импорта данных", , "Производится загрузка данных из файла. Это может занять некоторое время.", БиблиотекаКартинок.Информация32);
		
		Текст = Новый ЧтениеТекста(ФайлИмпорта);
		Стр = Текст.ПрочитатьСтроку();
		Стр = Текст.ПрочитатьСтроку();
		СтруктураРеквизитов=Новый Структура();
		
		Пока Стр <> Неопределено Цикл
			
			СписокДанных = СтрокаВСписок(Стр, СимволРазделитель);
			Индекс = 0;
			Пока Индекс< Объект.ТаблицаСоответсвийПолей.Количество() Цикл
				
				Строка=Объект.ТаблицаСоответсвийПолей[Индекс];
				Реквизит = СтрЗаменить(Строка.РеквизитСправочника," ","");
				Реквизит = СтрЗаменить(Реквизит,"*","");	
				
				Если Строка.КолонкаФайла <> "" Тогда
					Идентификатор = СписокКолонокФайла.НайтиПоЗначению(Строка.КолонкаФайла).ПолучитьИдентификатор();
					СтруктураРеквизитов.Вставить(Реквизит, СписокДанных[Идентификатор].Значение);
				Иначе   
					СтруктураРеквизитов.Вставить(Реквизит, "");
				КонецЕсли;	   
				
				Индекс = Индекс + 1;
			КонецЦикла;		
			
			ЗаполнитьРеквизитыСправочника(СтруктураРеквизитов, Стр, ВидМедицинскихКарт);
			Стр = Текст.ПрочитатьСтроку();
			
		КонецЦикла;
	Исключение 
		ТекстИсключение=ОписаниеОшибки();
		ПоказатьПредупреждение(,"Ошибка обработки файла: "+ТекстИсключение);
		Возврат неопределено;	
	КонецПопытки;	
	
	Возврат Истина;
	
КонецФункции

//////////////////////////////////////////////////////////////////////////////
// Процесс импорта

&НаКлиенте
//
//
Процедура СтартИмпорта(Команда)
	
	Если ЗагружаемыйСправочник = "" Тогда
		ПоказатьПредупреждение(,"Укажите заполняемый справочник");
		Возврат;
	КонецЕсли;
	
	Если  ВыборПапкиСправочника.Пустая() = Истина Тогда
		ПоказатьПредупреждение(,"Укажите папку справочника");
		Возврат;
	КонецЕсли;	  
	
	Если ЗагружаемыйСправочник = "Номенклатура" И НомеклатураТипЦен.Пустая() = Истина Тогда
		ПоказатьПредупреждение(,"Укажите тип цен");
		Возврат;
	КонецЕсли;	
	
	Если ЗагружаемыйСправочник = "Номенклатура" Тогда
		Если НЕ ЗначениеЗаполнено(ПоискПоТипу) Тогда 
			ПоказатьПредупреждение(,"Не указан тип поиска номенклатуры!");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗагружаемыйСправочник = "Номенклатура" Тогда
		Если ПоискПоТипу = 1 Тогда
			Если НЕ ЗаполненыРеквизитыДляНоменклатуры("Наименование") Тогда 
				ПоказатьПредупреждение(,"Не указано наименование!");
				Возврат;
			КонецЕсли;	
		ИначеЕсли ПоискПоТипу = 3 Тогда
			Если НЕ ЗаполненыРеквизитыДляНоменклатуры("Артикул") Тогда 			
				ПоказатьПредупреждение(,"Не указан артикул!");
				Возврат;
			КонецЕсли;				
		КонецЕсли;	
	КонецЕсли;
	
	Если ЗагружаемыйСправочник = "Пациенты" Тогда
		Если НЕ ЗначениеЗаполнено(СтраховаяКомпания) Тогда 
			Если ЗаполненыРеквизитыДляПолиса() Тогда 
				ПоказатьПредупреждение(,"Укажите страховую компанию");
				Возврат;
			КонецЕсли;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ТипПолиса) Тогда 
			Если ЗаполненыРеквизитыДляПолиса() Тогда 
				ПоказатьПредупреждение(,"Укажите тип полиса");
				Возврат;
			КонецЕсли;
		КонецЕсли;
		// Если НЕ ЗначениеЗаполнено(ДоговорСтраховойКомпании) Тогда 
		//	Если ЗаполненыРеквизитыДляПолиса() Тогда 
		//		Предупреждение("Укажите договор страхования");
		//		Возврат;
		//	КонецЕсли;
		// КонецЕсли;
	КонецЕсли;
	
	Если ФлагРазрешенияИмпорта=Истина Тогда
		СчетчикИмпортируемыхОбъектов=0;
		результат = Ложь;
		Если ТипФайлаИмпорта = "TEXT" Тогда
			
			результат = ЗагрузитьИзТекста();
		Иначе
			результат = ЗагрузитьИзExcel();
		КонецЕсли;	
		
		Если результат=Истина Тогда	
			
			ПоказатьПредупреждение(,"Операция импортирования завершена успешно. Загружено объектов: "+Формат(СчетчикИмпортируемыхОбъектов, "ЧН=0"));
		КонецЕсли;	 
	Иначе
		
		ПоказатьПредупреждение(,"Операция не возможна в связи с неверными настройками импортирования");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
//
//
Функция ЗаполненыРеквизитыДляНоменклатуры(ПроверяемыйРеквизит)
	
	РеквизитДляНоменклатурыЗаполнен = Ложь;	
	
	ТаблицаСоответсвийПолей_ТаблицаЗначений = Объект.ТаблицаСоответсвийПолей.Выгрузить();
	СтрокаТЧ = ТаблицаСоответсвийПолей_ТаблицаЗначений.Найти(ПроверяемыйРеквизит, "РеквизитСправочника");
	Если СтрокаТЧ <> Неопределено Тогда 
		Если ЗначениеЗаполнено(СтрокаТЧ.КолонкаФайла) Тогда 
			РеквизитДляНоменклатурыЗаполнен = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РеквизитДляНоменклатурыЗаполнен;
	
КонецФункции

