// Функция - Вернуть сегмент номенклатуры по сотруднику
//
// Параметры:
//  Сотрудник			 - 	 - 
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьСегментНоменклатурыПоСотруднику(Сотрудник, СтруктурнаяЕдиница) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	НастройкиСотрудников.СегментыНоменклатуры КАК СегментНоменклатуры
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.Сотрудник = &Сотрудник
	|	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница");
	
	Запрос.УстановитьПараметр("Сотрудник"		  , Сотрудник);	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.СегментНоменклатуры, Справочники.СегментыНоменклатуры.ПустаяСсылка());
	
КонецФункции

