Процедура ОткрытьФормуВыбораЦвета(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Кнопка = Сред(Параметры.Команда.Имя, 8);
		Если Документ.queryCommandSupported(Кнопка) Тогда
			Документ.execCommand(Кнопка, Ложь, "" + ПеревестиИз10(Результат.Красный) + ПеревестиИз10(Результат.Зеленый) + ПеревестиИз10(Результат.Синий));
		КонецЕсли;
	КонецЕсли;
	ПоказатьРежимыКнопок();

КонецПроцедуры	
	
&НаКлиенте
Функция ПеревестиИз10(Знач Значение = 0)
	
	Значение = Число(Значение);
	Если Значение <= 0 Тогда
		Возврат "00";
	КонецЕсли;
	
	Значение = Цел(Значение);
	Результат = "";
	
	Пока Значение > 0 Цикл
		Результат = Сред("0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ",Значение%16+1,1) + Результат;
		Значение = Цел(Значение/16);
	КонецЦикла;
	
	Если СтрДлина(Результат) = 1 Тогда
		Результат = "0" + Результат;
	КонецЕсли; 
  
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбработатьИзменяемыеЗначения()
	
	Получатель = Справочники.Контрагенты.ПустаяСсылка();
	
	Если Объект.ПолучателиПисьма.Количество() > 0 Тогда
		
		Если ТипЗнч(Объект.ПолучателиПисьма[0].Контакт) = Тип("СправочникСсылка.Контрагенты") Тогда
			Получатель = Объект.ПолучателиПисьма[0].Контакт;
		КонецЕсли;
		
	КонецЕсли;
	
	МенеджерПочтыСервер.ОбработатьИзменяемыеЗначенияВПисьме(Объект.ТекстHTML, Получатель);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСписокВыбораДоступныхУчетныхЗаписей()
	
	ТЗУчетныеЗаписи = Справочники.УчетныеЗаписиЭлектроннойПочты.ВернутьУчетныеЗаписиЭлектроннойПочтыОбщиеИЛичные(ПараметрыСеанса.ТекущийПользователь, Ложь, Истина, Ложь, Ложь);	
	
	Для Каждого СтрокаТЗ Из ТЗУчетныеЗаписи Цикл
		
		УчетнаяЗапись = СтрокаТЗ.Ссылка;
		ПредставлениеУчетнойЗаписи = ?(ЗначениеЗаполнено(СтрокаТЗ.ИмяПользователя),
									   СтрокаТЗ.ИмяПользователя + " <" + СтрокаТЗ.АдресЭлектроннойПочты + ">",
									   СтрокаТЗ.АдресЭлектроннойПочты);
		
		Элементы.ОтправительПредставление.СписокВыбора.Добавить(УчетнаяЗапись, ПредставлениеУчетнойЗаписи);
		
	КонецЦикла;
	
КонецПроцедуры

