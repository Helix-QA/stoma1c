&НаСервере
// Процедура, устанавливает видимость элементов формы.
//
Процедура УстановитьВидимостьЭлементов(ВыбратьЭтап = Ложь, ИзменитьЭтапОтказ = Ложь)
	
	Элементы.ГруппаШапкаВидовСделок.Видимость 					= Ложь;
	Элементы.ГруппаШапкаЭтаповСделок.Видимость 					= Ложь;
	Элементы.ГруппаСписокВидовСделок.Видимость 					= Ложь;
	Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Видимость 		= Ложь;
	Элементы.СделкиДействие.Видимость 							= Ложь;
	
	Если ВыбратьВидГенерируемойСделки Тогда 
		Элементы.ГруппаШапкаВидовСделок.Видимость 				= Истина;
		Элементы.ГруппаШапкаЭтаповСделок.Видимость 				= Истина;
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Видимость 	= Истина;		
		Элементы.ГруппаЭтапы.Доступность						= Ложь;
		Элементы.ГруппаШапкаЭтаповСделок.Заголовок 				= "Этапы сделки: " + СокрЛП(Строка(ВыбранныйВидСделки));
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Заголовок	= "Завершающие этапы сделки";//"Завершающие этапы сделки: " + СокрЛП(Строка(ВыбранныйВидСделки));				
		ЭтаФорма.Заголовок 										= "Выберите вид сделки";
		ЭтаФорма.Ширина 										= 30;
		ЭтаФорма.Высота 										= 33;		
	ИначеЕсли ВыбратьЭтапГенерируемойСделки Тогда 
		Элементы.ГруппаШапкаЭтаповСделок.Видимость 				= Истина;
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Видимость 	= Истина;
		Элементы.ГруппаЗавершающиеЭтапы.Доступность				= Ложь;		
		Элементы.ГруппаШапкаЭтаповСделок.Заголовок 				= "Этапы сделки: " + СокрЛП(Строка(ВыбранныйВидСделки));
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Заголовок	= "Завершающие этапы сделки";//"Завершающие этапы сделки: " + СокрЛП(Строка(ВыбранныйВидСделки));						
		ЭтаФорма.Заголовок 										= "Выберите этап сделки";		
		ЭтаФорма.Ширина 										= 30;
		ЭтаФорма.Высота 										= 22;				
	Иначе 	
		ЗаполненыВидыСделок = ЭтотОбъект.СписокВидовСделок.Количество() > 0;
		Если ЗаполненыВидыСделок Тогда
			Элементы.СделкиДействие.Видимость = Ложь;
			Элементы.ГруппаСписокВидовСделок.Видимость = Истина;
		Иначе 
			Элементы.СменитьСделку.Видимость = НЕ ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЭтотОбъект.Сделка, "ВидСделки"), "Предопределенный");
		КонецЕсли;
		
		Элементы.ГруппаЭтапы.Видимость 							= ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		Элементы.ГруппаШапкаЭтаповСделок.Видимость 				= ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		Элементы.ГруппаЭтапы.Доступность 						= ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		Элементы.ГруппаШапкаЭтаповСделок.Доступность			= ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Видимость 	= ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		Элементы.ГруппаШапкаЗавершающихЭтаповСделок.Доступность = ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		Элементы.ГруппаЗавершающиеЭтапы.Доступность 			= ВыбратьЭтап ИЛИ ИзменитьЭтапОтказ;
		
		Элементы.СделкиДействие.Видимость = НЕ ВыбратьЭтап И НЕ ЗаполненыВидыСделок И НЕ ИзменитьЭтапОтказ;
		
		Если ИзменитьЭтапОтказ Тогда
			Элементы.ГруппаЭтапы_0.Видимость   	     = Ложь;
			Элементы.ГруппаПричиныОтказа_0.Видимость = Истина;	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Сменить сделку на сервере.
//
Процедура СменитьСделкуНаСервере()
	
	МассивВидов = Справочники.ВидыСделок.ПолучитьДоступныеДляГенерацииВидыСделок(, ?(ЗначениеЗаполнено(Контрагент), Контрагент, ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Сделка, "Контрагент")), , Врач);
	ЭтотОбъект.СписокВидовСделок.ЗагрузитьЗначения(МассивВидов);
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

&НаСервере
// Процедура, ОбновитьЭтапыСделки.
//
Процедура ОбновитьЭтапыСделки() 
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Сделка) Тогда 
		Возврат;
	КонецЕсли;
	
	НомерЭтапа 			= ЭтапСделки.НомерЭтапа;
	ТаблицаЭтапов 		= Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(ВидСделки);
	НомерТекущегоЭтапа 	= ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭтапСделки, "НомерЭтапа");
	Индекс = 0;
	ДопустимОтказ 		= ?(ЭтоПервичныйПовторныйПациент, Справочники.Сделки.ДопустимОтказСогласноТекущегоЭтапа(ЭтотОбъект.Сделка, ЭтоПервичныйПовторныйПациент), Истина);
	
	ИндексВиджета = 0;
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаЭтапы_" + ИндексВиджета);
	ГруппаРодитель = Элементы.ГруппаЭтапы;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРодитель);	
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ГруппаЭтапы = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
	ГруппаЭтапы.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	
	Для Каждого СтрокаТЗ Из ТаблицаЭтапов Цикл
		
		ЭтапСделки = СтрокаТЗ.ЭтапСделки;
		
		Если НЕ Индекс = 0 Тогда 
			// Создаем картинку
			ПараметрыДекорации = Новый Структура;
			ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_СтрелкаВниз_" + Индекс);
			ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапы);
			ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.СтрелкаВниз);
			//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
			ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
			КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
			КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
			КартинкаВида.Ширина					 				= 2;
			КартинкаВида.Высота					 				= 1;
			КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
			КартинкаВида.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
		КонецЕсли;
		
		// Создание группы этапа.
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Этап_" + Индекс + "_" + ИндексВиджета);
		ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаЭтапы);
		ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
		ГруппаЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
		ГруппаЭтапа.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Полуторный;
		ГруппаЭтапа.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
		ГруппаЭтапа.Ширина = 30;
		ГруппаЭтапа.РастягиватьПоГоризонтали = Ложь;
		
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЭтапСделки" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
		ПараметрыДекорации.Вставить("Картинка"					, ?(СтрокаТЗ.НомерЭтапа = НомерЭтапа, БиблиотекаКартинок.ЧекБоксПолный, БиблиотекаКартинок.Пустая));
		//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 1;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
		// Создание группы кнопки этапа.
		ПараметрыГруппы = Новый Структура;
		ПараметрыГруппы.Вставить("ИмяЭлемента"   , "Этап_ГруппаКнопки" + Индекс);
		ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаЭтапа);
		ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);
		ГруппаКнопкиЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
		ГруппаКнопкиЭтапа.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
		ГруппаКнопкиЭтапа.Ширина = 30;
		ГруппаКнопкиЭтапа.РастягиватьПоГоризонтали = Ложь;
		
		// Создаем команду кнопки.
		ПараметрыКоманды = Новый Структура;
		ПараметрыКоманды.Вставить("ИмяОбработчикаНажатия", "ОбработчикНажатияИзменитьЭтап");
		ПараметрыКоманды.Вставить("ИмяЭлемента"   	 	 , "Этап_" + Индекс + "_" + ИндексВиджета);
		КомандаКнопки =  УправлениеИнтерфейсамиСервер.СоздатьКомандуЭлемента(ЭтаФорма, ПараметрыКоманды);
		
		// Создаем кнопку.
		ПараметрыКнопки = Новый Структура;
		ПараметрыКнопки.Вставить("Заголовок"   	 	 , ЭтапСделки);
		ПараметрыКнопки.Вставить("ИмяЭлемента"   	 , "Этап_" + Индекс + "_" + ИндексВиджета);
		ПараметрыКнопки.Вставить("КнопкаОтображение" , ОтображениеКнопки.Текст);
		ПараметрыКнопки.Вставить("КомандаКнопки" 	 , КомандаКнопки);
		ПараметрыКнопки.Вставить("РазмерШрифта"  	 , 10);
		ПараметрыКнопки.Вставить("ГруппаЭлемента"	 , ГруппаКнопкиЭтапа);		
		
		КнопкаЭтапа = УправлениеИнтерфейсамиСервер.СоздатьЭлементКнопка(ЭтаФорма, ПараметрыКнопки);
		КнопкаЭтапа.РастягиватьПоГоризонтали = Истина;	 
		
		Если ЭтоПервичныйПовторныйПациент Тогда
			Если ЗначениеЗаполнено(РезультатСделки) Тогда
				Если РезультатСделки = Перечисления.РезультатыСделок.Успех Тогда 
					КнопкаЭтапа.Доступность 	= Ложь;
				Иначе 
					КнопкаЭтапа.Доступность 	= ДопустимОтказ И (СтрокаТЗ.НомерЭтапа = 1 ИЛИ СтрокаТЗ.НомерЭтапа = 2);
				КонецЕсли;	
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 1 ИЛИ СтрокаТЗ.НомерЭтапа = 2 Тогда
				КнопкаЭтапа.Доступность 		= НомерТекущегоЭтапа < 3;
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 3 Тогда 
				КнопкаЭтапа.Доступность 		= Ложь;
			ИначеЕсли СтрокаТЗ.НомерЭтапа = 4 Тогда 	
				КнопкаЭтапа.Доступность 		= Ложь;//НомерТекущегоЭтапа > 2;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЗ.ЦветЭтапа)
			ИЛИ ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа) = Новый Цвет()
			ИЛИ СтрокаТЗ.НомерЭтапа > НомерЭтапа Тогда 
			Если СтрокаТЗ.НомерЭтапа = НомерЭтапа Тогда
				Цвет = Новый Цвет(229, 229, 229);
			Иначе 	
				Цвет = Новый Цвет(243, 243, 243);
			КонецЕсли;
		ИначеЕсли СтрокаТЗ.НомерЭтапа = НомерЭтапа Тогда
			Цвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа);
		Иначе		
			Цвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа);
		КонецЕсли;
		
		//Если НЕ ЗначениеЗаполнено(СтрокаТЗ.ЦветЭтапа)
		//	ИЛИ ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа) = Новый Цвет() Тогда
		//	
		//	Цвет = Новый Цвет(0,112,210);
		//Иначе		
		//	Цвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ЦветЭтапа);
		//КонецЕсли;
		
		ГруппаКнопкиЭтапа.ЦветФона   	= Цвет;
		КнопкаЭтапа.ЦветТекста 			= УправлениеИнтерфейсамиСервер.ПолучитьЦветТекстаПоФону(ГруппаКнопкиЭтапа.ЦветФона);
		
		// Создаем картинку
		ПараметрыДекорации = Новый Структура;
		ПараметрыДекорации.Вставить("ИмяЭлемента"				, "Картинка_Выбран_ЭтапСделки_пустая" + Индекс);
		ПараметрыДекорации.Вставить("ГруппаЭлемента"			, ГруппаЭтапа);
		ПараметрыДекорации.Вставить("Картинка"					, БиблиотекаКартинок.Пустая);
		//ПараметрыДекорации.Вставить("ИмяОбработчикаНажатия"		, "ОбработчикНажатияИзменитьЭтап");
		ПараметрыДекорации.Вставить("РастягиватьПоГоризонтали"	, Ложь);
		КартинкаВида = УправлениеИнтерфейсамиСервер.СоздатьЭлементДекорация(ЭтаФорма, ПараметрыДекорации);
		КартинкаВида.АвтоМаксимальнаяШирина	 				= Ложь;		
		КартинкаВида.Ширина					 				= 2;
		КартинкаВида.Высота					 				= 1;
		КартинкаВида.ВертикальноеПоложениеВГруппе 			= ВертикальноеПоложениеЭлемента.Центр;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	//Если НЕ ЭтоПервичныйПовторныйПациент ИЛИ (ЭтоПервичныйПовторныйПациент И РезультатСделки = Перечисления.РезультатыСделок.ПустаяСсылка()) Тогда 
	//	Возврат;
	//КонецЕсли;
	
	// Создание группы.
	ПараметрыГруппы = Новый Структура;
	ПараметрыГруппы.Вставить("ИмяЭлемента"   , "ГруппаЗавершающиеЭтапы_" + 0);
	ГруппаРодитель = Элементы.ГруппаЗавершающиеЭтапы;
	ПараметрыГруппы.Вставить("ГруппаЭлемента", ГруппаРодитель);	
	ПараметрыГруппы.Вставить("Группировка"   , ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	ГруппаЗавершающиеЭтапы = УправлениеИнтерфейсамиСервер.СоздатьЭлементГруппа(ЭтаФорма, ПараметрыГруппы);
	ГруппаЗавершающиеЭтапы.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Одинарный;
	
	НаименованиеЭтапаУспех = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВидСделки, "НаименованиеЭтапаУспех");
	НаименованиеЭтапаУспех = ?(ЗначениеЗаполнено(СокрЛП(НаименованиеЭтапаУспех)), СокрЛП(НаименованиеЭтапаУспех), НСтр("ru = 'Успех'; en = 'Success'"));
	НаименованиеЭтапаОтказ = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВидСделки, "НаименованиеЭтапаОтказ");
	НаименованиеЭтапаОтказ = ?(ЗначениеЗаполнено(СокрЛП(НаименованиеЭтапаОтказ)), СокрЛП(НаименованиеЭтапаОтказ), НСтр("ru = 'Отказ'; en = 'Denial'"));
	
	ДоступностьЗавершающихЭтапов = НЕ ЭтоПервичныйПовторныйПациент;
	
	УправлениеИнтерфейсамиСервер.СоздатьКнопкуРезультатаСделки(ЭтаФорма, НаименованиеЭтапаУспех, ГруппаЗавершающиеЭтапы, , , Перечисления.РезультатыСделок.Успех, РезультатСделки, , ДоступностьЗавершающихЭтапов);
	УправлениеИнтерфейсамиСервер.СоздатьГруппуПрием(ЭтаФорма, ИндексВиджета, Элементы.Выравнивание);
	Если ПричиныПредопределены Тогда 
		Для Каждого СтрокаПричина Из ПричиныОтказов Цикл
			ДоступностьЗавершающихЭтапов = НЕ ЭтоПервичныйПовторныйПациент;			
			Если ЭтоПервичныйПовторныйПациент И СтрокаПричина.Ссылка = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПричиныОтказов.КлиентОтказался") Тогда 
				Если НЕ ЗначениеЗаполнено(ЭтотОбъект.РезультатСделки) И Справочники.Сделки.ДопустимОтказСогласноТекущегоЭтапа(ЭтотОбъект.Сделка, ЭтоПервичныйПовторныйПациент) Тогда 
					ДоступностьЗавершающихЭтапов = Истина;
				КонецЕсли; 
			КонецЕсли;	
			УправлениеИнтерфейсамиСервер.СоздатьКнопкуРезультатаСделки(ЭтаФорма, СокрЛП(СтрокаПричина.Наименование), ГруппаЗавершающиеЭтапы, , , Перечисления.РезультатыСделок.Отказ, РезультатСделки, ПричиныОтказов.Индекс(СтрокаПричина), ДоступностьЗавершающихЭтапов, СтрокаПричина.Ссылка);
		КонецЦикла;	
	Иначе 	
		УправлениеИнтерфейсамиСервер.СоздатьКнопкуРезультатаСделки(ЭтаФорма, НаименованиеЭтапаОтказ, ГруппаЗавершающиеЭтапы, , , Перечисления.РезультатыСделок.Отказ, РезультатСделки, , ДоступностьЗавершающихЭтапов);
		УправлениеИнтерфейсамиСервер.СоздатьГруппуПричинОтказа(ЭтаФорма, Элементы.Выравнивание, ИндексВиджета);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, ОбновитьСделку.
//
Процедура ОбновитьСделку(ИмяКоманды)
	
	Если СтрНайти(ИмяКоманды, "КомандаЭтап") > 0 Тогда		
		
		ИндексВиджета 	= ПолучитьИндексСтроки(ИмяКоманды, Ложь);
		ИндексЭтапа     = ПолучитьИндексСтроки(ИмяКоманды);
		УправлениеИнтерфейсамиСервер.ОбновитьЭтапСделки(ЭтотОбъект.Сделка, ИндексЭтапа);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ЗНАЧ ИмяЭлемента, ИндексЭлемента = Истина)

	НомерСимвола = СтрНайти(ИмяЭлемента, "_ИндексПричины_");
	Если ЗначениеЗаполнено(НомерСимвола) Тогда 
		ИмяЭлемента = Лев(ИмяЭлемента, НомерСимвола-1);
	КонецЕсли;
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		
		Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Сред(ИмяЭлемента, НомерСимвола + 1, 2)) Тогда
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 2));
		Иначе		
			Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));	
		КонецЕсли;		
		
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1));
	КонецЕсли;
	
КонецФункции

&НаКлиенте
// Процедура, ВыбратьРеализациюЗавершение.
//
Процедура ВыбратьРеализациюЗавершение(Результат, ДопПараметры) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Возврат;		
	КонецЕсли;
	
	ВыбратьРеализациюЗавершениеНаСервере(Результат, ДопПараметры);
	Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
	Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
	Если ЭтаФорма.Открыта() Тогда
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, ВыбратьРеализациюЗавершениеНаСервере.
//
Процедура ВыбратьРеализациюЗавершениеНаСервере(Продажа, Сделка)
	
	УправлениеИнтерфейсамиСервер.ОбновитьЭтапУспех(Сделка, Продажа);
	
КонецПроцедуры

&НаКлиенте
// Процедура, открывает форму продажи.
//
Процедура ОткрытьФормуПродажи(ИндексВиджета)
	
	Сделка = ЭтотОбъект.Сделка;
	
	Структура = Новый Структура();
	Структура.Вставить("Контрагент"			, ЭтотОбъект.Контрагент);
	Структура.Вставить("Сделка"	   			, Сделка);
	ПараметрыФормы  = Новый Структура("ЗначенияЗаполнения", Структура);	
	НовоеОповещение = Новый ОписаниеОповещения("СоздатьРеализациюЗавершение", ЭтотОбъект, Сделка);
	
	ОткрытьФорму("Документ.Прием.Форма.ФормаДокумента",ПараметрыФормы,,,,,НовоеОповещение);
	
КонецПроцедуры

&НаКлиенте
// Процедура, СоздатьРеализациюЗавершение.
//
Процедура СоздатьРеализациюЗавершение(Результат, ДопПараметры) Экспорт
	
	СоздатьРеализациюЗавершениеНаСервере(ДопПараметры);
	Оповестить("ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ");
	Оповестить("ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ");
	Если ЭтаФорма.Открыта() Тогда
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, СоздатьРеализациюЗавершениеНаСервере.
//
Процедура СоздатьРеализациюЗавершениеНаСервере(Сделка)
	
	Прием = ПолучитьПоследнююПродажуПоСделке(Сделка);
	Если ЗначениеЗаполнено(Прием) Тогда
		УправлениеИнтерфейсамиСервер.ОбновитьЭтапУспех(Сделка, Прием);		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, ПолучитьПоследнююПродажуПоСделке.
//
Функция ПолучитьПоследнююПродажуПоСделке(Сделка)
	
	Если НЕ ЗначениеЗаполнено(Сделка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Прием.Ссылка КАК Продажа
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Сделка = &Сделка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Прием.Дата УБЫВ";
	Запрос.УстановитьПараметр("Сделка", Сделка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ЗначениеВозврата = ?( Выборка.Следующий(), Выборка.Продажа, Неопределено);
	
	Возврат ЗначениеВозврата;
	
КонецФункции

&НаКлиенте
// Функция - Получить выбранную причину отказа
//
// Параметры:
//  ИмяКоманда	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВыбраннуюПричинуОтказа(ЗНАЧ ИмяКоманда)
	
	Попытка	
		НомерСимвола = СтрНайти(ИмяКоманда,"_ИндексПричины_");
		Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Сред(ИмяКоманда, НомерСимвола + СтрДлина("_ИндексПричины_"), 2)) Тогда
			ИндексПричины = Число(Сред(ИмяКоманда, НомерСимвола + СтрДлина("_ИндексПричины_"), 2));
		Иначе
			ИндексПричины = Число(Сред(ИмяКоманда, НомерСимвола + СтрДлина("_ИндексПричины_"), 1));
		КонецЕсли;
		Возврат ПричиныОтказов.Получить(ИндексПричины).Ссылка;		
	Исключение 
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не заполнены входящие данные'; en = 'Incoming data is not filled'"));
		Возврат Неопределено;
	КонецПопытки;	
	
КонецФункции

&НаСервере
// Процедура, ОбновитьПричинуОтказаВыборНаСервере.
//
Процедура ОбновитьПричинуОтказаВыборНаСервере(ПричинаОтказа, ИмяЭлемента)	
	
	ОбновитьПричинуОтказа(ПричинаОтказа, ИмяЭлемента);
	
КонецПроцедуры

&НаСервере
// Процедура, обновляет причину отказа в сделке.
//
// Параметры:
// 	Форма 			- управляемая форма - форма объекта.
//	ПричинаОтказа 	- Ссылка  			- элемент справочника, причины отказов.
//	ИмяЭлемента 	- Строка 			- имя нажатого элемента виджета(имя нажатой таблицы отказов).
// 
Процедура ОбновитьПричинуОтказа(знач ПричинаОтказа, знач ИмяЭлемента)
	
	Если НЕ ЗначениеЗаполнено(ПричинаОтказа) ИЛИ НЕ ЗначениеЗаполнено(ИмяЭлемента) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не заполнены входящие данные'; en = 'Incoming data is not filled'"));
		Возврат;
	КонецЕсли;
	
	ИндексВиджета 	= ПолучитьИндексСтроки(ИмяЭлемента, Ложь);
	
	Сделка 		= ЭтотОбъект.Сделка;
	
	ОбъектСделка  	= Сделка.ПолучитьОбъект(); 
	Прием	 		= ОбъектСделка.Прием;
	ОбъектСделка.РезультатСделки 		= Перечисления.РезультатыСделок.Отказ;
	Если ЗначениеЗаполнено(ОбъектСделка.ЭтапСделки) И НЕ ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ОбъектСделка.ЭтапСделки, "Предопределенный") Тогда 
		ОбъектСделка.ЭтапОтказа 		= ОбъектСделка.ЭтапСделки;
	ИначеЕсли НЕ ЗначениеЗаполнено(ОбъектСделка.ЭтапОтказа) Тогда 
		ОбъектСделка.ЭтапОтказа 		= Справочники.ВидыСделок.ПолучитьСтартовыйЭтапВидаСделки(ОбъектСделка.ВидСделки);
	КонецЕсли;	
	ОбъектСделка.ЭтапСделки		 		= Справочники.ЭтапыСделок.Отказ;
	ОбъектСделка.ПричинаОтказа	 	  	= ПричинаОтказа;
	ОбъектСделка.ДатаЗавершенияСделки 	= Неопределено;
	ОбъектСделка.Прием					= Неопределено;
	
	Если ЗначениеЗаполнено(Прием) Тогда
		ДокументРеализация = Прием.ПолучитьОбъект();
		ДокументРеализация.Сделка = Неопределено;
	КонецЕсли;
	
	НачатьТранзакцию();	
	Попытка
		ОбъектСделка.Записать();
		Если ЗначениеЗаполнено(Прием) Тогда
			ДокументРеализация.Записать(?(ДокументРеализация.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись));
		КонецЕсли;
		ЗафиксироватьТранзакцию();			
	Исключение
		ОтменитьТранзакцию();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти