&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменениеЗадачи" Тогда 
		ОбновитьДанныеДляОтображения();
	ИначеЕсли ИмяСобытия = "ОбновитьСписокЗадачМенеджера" Тогда 
		Элементы.СписокЗадач.Обновить();		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

