		КонтаргентСтрокой = Нстр("ru = 'Контрагент не указан.'; en = 'Counterparty not selected.'");
	Иначе
		КонтаргентСтрокой = Строка(Контрагент)
							+ ?(ЗначениеЗаполнено(Контрагент.Телефон), Нстр("ru = ', тел. '; en = ', tel. '") + Контрагент.Телефон, "") 
							+ ?(ЗначениеЗаполнено(СтатусКлиента), " (" + Строка(СтатусКлиента) + ")", "");
