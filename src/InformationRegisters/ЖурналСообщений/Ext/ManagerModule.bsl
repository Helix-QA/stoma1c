КонецПроцедуры	

// Функция, возвращает мессенджер клиента по идентификатору.
//
Функция ПолучитьМессенджерыПоИдКлиента(МассивИдентификаторов, ВнешняяСистема)Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЖурналСообщений.Мессенджер КАК Мессенджер,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдКлиента В(&МассивИдентификаторов)
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема");
	
	Запрос.УстановитьПараметр("ВнешняяСистема"       , ВнешняяСистема);
	Запрос.УстановитьПараметр("МассивИдентификаторов", МассивИдентификаторов);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

// Функция - Получить количество отправленных сообщений.
//
// Параметры:
//  ВнешняяСистема	 - 	 - 
//  НачалоОтбора	 - 	 - 
//  КонецОтбора		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКоличествоОтправленныхСообщений(ВнешняяСистема, НачалоОтбора, КонецОтбора) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(*) КАК Количество
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ДатаСообщения МЕЖДУ &НачалоОтбора И &КонецОтбора");
	
	Запрос.УстановитьПараметр("ВнешняяСистема", ВнешняяСистема);
	Запрос.УстановитьПараметр("НачалоОтбора"  , НачалоОтбора);
	Запрос.УстановитьПараметр("КонецОтбора"   , КонецОтбора);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.Количество, 0);
	
КонецФункции

// Процедура, удаляет сообщение из регистра.
//
Процедура УдалитьСообщение(ИдСообщения, ИдКлиента, ВнешняяСистема) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ЖурналСообщений.Период КАК Период
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ИдСообщения = &ИдСообщения
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема");
	
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ИдСообщения"		, ИдСообщения);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		
		МенеджерЗаписи = РегистрыСведений.ЖурналСообщений.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Период			 = Результат.Период;
		МенеджерЗаписи.ИдКлиента		 = ИдКлиента;
		МенеджерЗаписи.ИдСообщения		 = ИдСообщения;
		МенеджерЗаписи.ВнешняяСистема	 = ВнешняяСистема;
		
		МенеджерЗаписи.Удалить();
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура, отмечает прочитанными сообщения, отправленные до указанной даты.
//
Процедура ПрочитатьСообщенияПоДате(ИдКлиента, ВнешняяСистема, ДатаСообщения) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЖурналСообщений.Период КАК Период,
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	ЖурналСообщений.ИдСообщения КАК ИдСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ДатаСообщения <= &ДатаСообщения
	|	И НЕ ЖурналСообщений.Прочитано
	|	И НЕ ЖурналСообщений.СообщениеОтКлиента");
	
	Запрос.УстановитьПараметр("ИдКлиента"		, ИдКлиента);
	Запрос.УстановитьПараметр("ДатаСообщения"	, ДатаСообщения);
	Запрос.УстановитьПараметр("ВнешняяСистема"	, ВнешняяСистема);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.ЖурналСообщений.СоздатьМенеджерЗаписи();
		
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			
			МенеджерЗаписи.Прочитано = Истина;
			МенеджерЗаписи.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция, возвращает данные сообщений.
//
Функция ПолучитьДанныеСообщений(ИдКлиента, ВнешняяСистема, ИдентификаторыСообщений) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЖурналСообщений.ТекстСообщения КАК ТекстСообщения,
	|	ЖурналСообщений.Изображение КАК Изображение,
	|	ЖурналСообщений.Аудио КАК Аудио,
	|	ЖурналСообщений.PDF КАК PDF
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема = &ВнешняяСистема
	|	И ЖурналСообщений.ИдКлиента = &ИдКлиента
	|	И ЖурналСообщений.ИдСообщения В(&ИдентификаторыСообщений)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЖурналСообщений.Период,
	|	ЖурналСообщений.ИдСообщения");
	
	Запрос.УстановитьПараметр("ИдКлиента"				, ИдКлиента);
	Запрос.УстановитьПараметр("ВнешняяСистема"			, ВнешняяСистема);
	Запрос.УстановитьПараметр("ИдентификаторыСообщений"	, ИдентификаторыСообщений);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

// Процедура, заполняет текст запроса.
//
Процедура ЗаполнитьТекстЗапросаПолученияСпискаДиалогов(Запрос)
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.Начало) КАК Начало,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ДатыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.ВнешняяСистема В(&ВнешняяСистема)
	|	И Диалоги.СценарийЧатБота = ЗНАЧЕНИЕ(Справочник.СценарииЧатБотов.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Диалоги.ИдКлиента,
	|	Диалоги.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.ИдДиалога) КАК ИдДиалога,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ИдентификаторыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихДиалогов КАК ДатыПоследнихДиалогов
	|		ПО Диалоги.ИдКлиента = ДатыПоследнихДиалогов.ИдКлиента
	|			И Диалоги.ВнешняяСистема = ДатыПоследнихДиалогов.ВнешняяСистема
	|			И Диалоги.Начало = ДатыПоследнихДиалогов.Начало
	|ГДЕ
	|	Диалоги.ВнешняяСистема В(&ВнешняяСистема)
	|
	|СГРУППИРОВАТЬ ПО
	|	Диалоги.ИдКлиента,
	|	Диалоги.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ОтложенДо КАК ОтложенДо,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК ПоследнееСообщениеОтКлиента
	|ПОМЕСТИТЬ ДанныеПоследнихДиалогов
	|ИЗ
	|	ИдентификаторыПоследнихДиалогов КАК ИдентификаторыПоследнихДиалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Диалоги КАК Диалоги
	|		ПО (Диалоги.ИдДиалога = ИдентификаторыПоследнихДиалогов.ИдДиалога)
	|ГДЕ
	|	&ОсновнойФильтр
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Диалоги.ИдДиалога КАК ИдДиалога,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема,
	|	Диалоги.Оператор КАК Оператор,
	|	Диалоги.Начало КАК Начало,
	|	Диалоги.Окончание КАК Окончание,
	|	Диалоги.ОтложенДо КАК ОтложенДо,
	|	Диалоги.ПоследнееСообщениеОтКлиента КАК ПоследнееСообщениеОтКлиента
	|ПОМЕСТИТЬ ПоследниеДиалоги
	|ИЗ
	|	ДанныеПоследнихДиалогов КАК ДанныеПоследнихДиалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Диалоги КАК Диалоги
	|		ПО (Диалоги.ИдДиалога = ДанныеПоследнихДиалогов.ИдДиалога)
	|ГДЕ
	|	&ДополнительныйФильтр
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЖурналСообщений.ИдКлиента КАК ИдКлиента,
	|	ЖурналСообщений.ВнешняяСистема КАК ВнешняяСистема,
	|	МАКСИМУМ(ЖурналСообщений.Период) КАК Период
	|ПОМЕСТИТЬ ПоследниеСообщения
	|ИЗ
	|	РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоследниеДиалоги КАК ПоследниеДиалоги
	|		ПО (ПоследниеДиалоги.ИдДиалога = ЖурналСообщений.ИдДиалога)
	|ГДЕ
	|	ЖурналСообщений.ВнешняяСистема В(&ВнешняяСистема)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЖурналСообщений.ИдКлиента,
	|	ЖурналСообщений.ВнешняяСистема
	|;
	|
