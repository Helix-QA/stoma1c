// Функция - Буфер обмена заполнен событием.
// 
Функция БуферОбменаЗаполненСобытием(БуферОбмена, ПолучитьПризнакВырезать = Ложь)
	
	СобытиеВБуфереОбмена = (ЗначениеЗаполнено(БуферОбмена)
								И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(БуферОбмена, "Буфер")
								И ЗначениеЗаполнено(БуферОбмена.Буфер)
								И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(БуферОбмена.Буфер, "Событие")
								И ЗначениеЗаполнено(БуферОбмена.Буфер.Событие));
		
	СтруктураВозврата = Новый Структура("Результат, ПризнакВырезать", СобытиеВБуфереОбмена, Ложь);
	
	Если ПолучитьПризнакВырезать = Истина Тогда
		
		Если СобытиеВБуфереОбмена Тогда
			СтруктураВозврата.ПризнакВырезать = ?(ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(БуферОбмена, "ПризнакВырезать"), БуферОбмена.ПризнакВырезать, Ложь);				
		Иначе
			СтруктураВозврата.ПризнакВырезать = Ложь;	
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции   

