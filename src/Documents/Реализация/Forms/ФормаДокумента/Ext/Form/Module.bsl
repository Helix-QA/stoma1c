// Функция, проверяет приминение налогов.
//
Функция ПроверитьПрименениеВидовНалов(Номенклатура)
	
	Отказ = Ложь;	
	
	МассивНоменклатуры = Новый Массив;
	Для Каждого СтрокаТЧ из Объект.Запасы Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) и НЕ СтрокаТЧ.Номенклатура = Номенклатура Тогда
			МассивНоменклатуры.Добавить(СтрокаТЧ.Номенклатура);
		КонецЕсли;
	КонецЦикла;		
	Для Каждого СтрокаТЧ из Объект.Услуги Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) и НЕ СтрокаТЧ.Номенклатура = Номенклатура Тогда
			МассивНоменклатуры.Добавить(СтрокаТЧ.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивНоменклатуры.Количество() > 0 Тогда
		
		ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(МассивНоменклатуры[0], "ВидНалога");
		Если НЕ ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Номенклатура, "ВидНалога") Тогда
			Отказ = Истина;
			ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения (ЕНВД, УСХН, ПСН). Номенклатура '%1' и '%2' используют разные режимы налогообложения";
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, МассивНоменклатуры[0], Номенклатура);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);				
		КонецЕсли;
		
	КонецЕсли;		
	
	Возврат Отказ;
	
КонецФункции

