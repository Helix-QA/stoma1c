// Функция возвращает закрытие дня.
//
Функция ПолучитьЗакрытияДня(ЧленствоПакетУслуг)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументЗакрытиеДня.Ссылка КАК ЗакрытиеДня
	|ИЗ
	|	Документ.ЗакрытиеДня КАК ДокументЗакрытиеДня
	|ГДЕ
	|	ДокументЗакрытиеДня.ЗакрытиеЧленствПакетовУслуг.ЧленствоПакетУслуг = &ЧленствоПакетУслуг
	|	И ДокументЗакрытиеДня.Проведен = ИСТИНА");
	
	Запрос.УстановитьПараметр("ЧленствоПакетУслуг", ЧленствоПакетУслуг);
	
	МассивЗакрытияДня = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ЗакрытиеДня");
	
	Возврат МассивЗакрытияДня;
	
КонецФункции

// Функция проверяет не корректное закрытие дня.
//
Функция НеКорректноеЗакрытиеДня(ЧленствоПакетУслуг, СрокДействияЧПУ, СтруктурнаяЕдиница = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		СтруктурнаяЕдиница = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЧленствоПакетУслуг, "СтруктурнаяЕдиница");
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДокументЗакрытиеДня.Ссылка КАК ЗакрытиеДня
	|ИЗ
	|	Документ.ЗакрытиеДня КАК ДокументЗакрытиеДня
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ДокументЗакрытиеДня.Дата, ДЕНЬ) <> НАЧАЛОПЕРИОДА(&ДатаОкончанияДействия, ДЕНЬ)
	|	И ДокументЗакрытиеДня.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ДокументЗакрытиеДня.ЗакрытиеЧленствПакетовУслуг.ЧленствоПакетУслуг = &ЧленствоПакетУслуг");
	
	Запрос.УстановитьПараметр("ДатаОкончанияДействия"	, СрокДействияЧПУ);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ЧленствоПакетУслуг"		, ЧленствоПакетУслуг);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

// Процедура добавляет членство, пакет усулг в подходящее закрытие дня.
//
Процедура ДобавитьВПодходящееЗакрытиеДня(ЧленствоПакетУслуг, СрокДействияЧПУ, СтруктурнаяЕдиница = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда 
		СтруктурнаяЕдиница = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ЧленствоПакетУслуг, "СтруктурнаяЕдиница");
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДокументЗакрытиеДня.Ссылка КАК ЗакрытиеДня
	|ИЗ
	|	Документ.ЗакрытиеДня КАК ДокументЗакрытиеДня
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ДокументЗакрытиеДня.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаОкончанияДействия, ДЕНЬ)
	|	И ДокументЗакрытиеДня.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И ДокументЗакрытиеДня.Проведен = ИСТИНА");
	
	Запрос.УстановитьПараметр("ДатаОкончанияДействия"	, СрокДействияЧПУ);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"		, СтруктурнаяЕдиница);
		
	ВыборкаЗакрытиеДня = Запрос.Выполнить().Выбрать();
	Если ВыборкаЗакрытиеДня.Следующий() Тогда 
		Если ЗначениеЗаполнено(ВыборкаЗакрытиеДня.ЗакрытиеДня) Тогда 
			ЗакрытиеДняОбъект = ВыборкаЗакрытиеДня.ЗакрытиеДня.ПолучитьОбъект();
		Иначе
			ЗакрытиеДняОбъект = Неопределено;
		КонецЕсли;
	Иначе
		ЗакрытиеДняОбъект = Документы.ЗакрытиеДня.СоздатьДокумент();
		ЗакрытиеДняОбъект.Дата				 = КонецДня(СрокДействияЧПУ);
		ЗакрытиеДняОбъект.Статус			 = Перечисления.СтатусыРабочегоДня.Закрыт;
		ЗакрытиеДняОбъект.СтруктурнаяЕдиница = СтруктурнаяЕдиница;	
	КонецЕсли;	
	
	Если ЗакрытиеДняОбъект <> Неопределено Тогда
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеобходимоДобавитьЧленствоПакетУслугВДокумент", Истина);
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЭтоВосстановлениеПоследовательности"			, Истина);
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЧленствоПакетУслугПоследовательности"		, ЧленствоПакетУслуг);
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПроведениеДокументовВФоне"	, Истина);
		ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеАктуализироватьСтатус"						, Истина);
		Попытка				
			ЗакрытиеДняОбъект.Записать(?(ЗначениеЗаполнено(ЗакрытиеДняОбъект.Ссылка), РежимЗаписиДокумента.Запись, РежимЗаписиДокумента.Проведение));
		Исключение
			
		КонецПопытки;  
	КонецЕсли;
	
КонецПроцедуры

// Функция возвращает срок действия членства, пакет услуг.
//
Функция ПолучитьСрокДействияЧленстваПакетаУслуг(ЧленствоПакетУслуг)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(ЧленстваПакетыУслугОбороты.Период) КАК ДатаПоследнегоСписания,
	|	ЧленстваПакетыУслугОбороты.Основание КАК Основание
	|ПОМЕСТИТЬ ПоследнийДокумент
	|ИЗ
	|	РегистрНакопления.ЧленстваПакетыУслуг.Обороты(
	|			,
	|			,
	|			Регистратор,
	|			Основание = &ЧленствоПакетУслуг
	|				И Основание ССЫЛКА Документ.ЧленствоПакетУслуг
	|				И (ВЫРАЗИТЬ(Основание КАК Документ.ЧленствоПакетУслуг).ТипЧленстваПакетаУслуг В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементПакетУслуг))
	|					ИЛИ ВЫРАЗИТЬ(Основание КАК Документ.ЧленствоПакетУслуг).ТипЧленстваПакетаУслуг В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементЧленство))
	|						И ВЫРАЗИТЬ(Основание КАК Документ.ЧленствоПакетУслуг).ВидЧленстваПакетаУслуг = ЗНАЧЕНИЕ(Перечисление.ВидыЧленствПакетовУслуг.ОграниченПосещениями))) КАК ЧленстваПакетыУслугОбороты
	|ГДЕ
	|	(ЧленстваПакетыУслугОбороты.Регистратор ССЫЛКА Документ.Занятие
	|			ИЛИ ЧленстваПакетыУслугОбороты.Регистратор ССЫЛКА Документ.Аренда
	|			ИЛИ ЧленстваПакетыУслугОбороты.Регистратор ССЫЛКА Документ.Посещение)
	|	И ЧленстваПакетыУслугОбороты.КоличествоРасход > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧленстваПакетыУслугОбороты.Основание
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВложенныйЗапрос.КоличествоПриход) КАК КоличествоПриход,
	|	СУММА(ВложенныйЗапрос.КоличествоРасход) КАК КоличествоРасход,
	|	СУММА(ВложенныйЗапрос.ДнейПриход) КАК ДнейПриход,
	|	СУММА(ВложенныйЗапрос.ДнейДополнительноПриход) КАК ДнейДополнительноПриход,
	|	СУММА(ВложенныйЗапрос.КоличествоПриход - ВложенныйЗапрос.КоличествоРасход) КАК КоличествоКонечныйОстаток,
	|	ВложенныйЗапрос.Основание КАК Основание
	|ПОМЕСТИТЬ ЧленстваПакетыУслугОстаткиИОбороты
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЧленстваПакетыУслугОбороты.КоличествоПриход КАК КоличествоПриход,
	|		ЧленстваПакетыУслугОбороты.КоличествоРасход КАК КоличествоРасход,
	|		ЧленстваПакетыУслугОбороты.ДнейПриход КАК ДнейПриход,
	|		ЧленстваПакетыУслугОбороты.ДнейДополнительноПриход КАК ДнейДополнительноПриход,
	|		ЧленстваПакетыУслугОбороты.Основание КАК Основание
	|	ИЗ
	|		РегистрНакопления.ЧленстваПакетыУслуг.Обороты(, &ТекущаяДата, , Основание = &ЧленствоПакетУслуг) КАК ЧленстваПакетыУслугОбороты
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		-1 * ЧленстваПакетыУслугОбороты.КоличествоПриход,
	|		-1 * ЧленстваПакетыУслугОбороты.КоличествоРасход,
	|		-1 * ЧленстваПакетыУслугОбороты.ДнейПриход,
	|		-1 * ЧленстваПакетыУслугОбороты.ДнейДополнительноПриход,
	|		ЧленстваПакетыУслугОбороты.Основание
	|	ИЗ
	|		РегистрНакопления.ЧленстваПакетыУслуг.Обороты(, &ТекущаяДата, Регистратор, Основание = &ЧленствоПакетУслуг) КАК ЧленстваПакетыУслугОбороты
	|	ГДЕ
	|		ЧленстваПакетыУслугОбороты.Регистратор ССЫЛКА Документ.ЗакрытиеДня) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Основание
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫБОР
	|		КОГДА ДокументЧленствоПакетУслуг.ТипЧленстваПакетаУслуг В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементПакетУслуг))
	|				И ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.КоличествоПриход, 0) > 0
	|				И ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.КоличествоКонечныйОстаток, 0) <= 0
	|			ТОГДА ЕСТЬNULL(ПоследнийДокумент.ДатаПоследнегоСписания, ДАТАВРЕМЯ(1, 1, 1))
	|		КОГДА ДокументЧленствоПакетУслуг.ТипЧленстваПакетаУслуг В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементЧленство))
	|				И ДокументЧленствоПакетУслуг.ВидЧленстваПакетаУслуг = ЗНАЧЕНИЕ(Перечисление.ВидыЧленствПакетовУслуг.ОграниченПосещениями)
	|				И ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.КоличествоПриход, 0) > 0
	|				И ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.КоличествоКонечныйОстаток, 0) <= 0
	|			ТОГДА ЕСТЬNULL(ПоследнийДокумент.ДатаПоследнегоСписания, ДАТАВРЕМЯ(1, 1, 1))
	|		КОГДА ДокументЧленствоПакетУслуг.ТипЧленстваПакетаУслуг В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементЧленство), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.АбонементПакетУслуг))
	|			ТОГДА ВЫБОР
	|					КОГДА ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.ДнейПриход, 0) + ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.ДнейДополнительноПриход, 0) > 0
	|							И ЕСТЬNULL(СтатусыЧленствПакетовУслугСрезПервойАктивации.Период, ДАТАВРЕМЯ(1, 1, 1)) <> ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(СтатусыЧленствПакетовУслугСрезПервойАктивации.Период, ДЕНЬ, ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.ДнейПриход, 0) + ЕСТЬNULL(ЧленстваПакетыУслугОстаткиИОбороты.ДнейДополнительноПриход, 0) - 1), ДЕНЬ)
	|					ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|				КОНЕЦ
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК СрокДействия
	|ИЗ
	|	Документ.ЧленствоПакетУслуг КАК ДокументЧленствоПакетУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыЧленствПакетовУслуг.СрезПервых(
	|				,
	|				ЧленствоПакетУслуг = &ЧленствоПакетУслуг
	|					И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧленствПакетовУслуг.Активен)) КАК СтатусыЧленствПакетовУслугСрезПервойАктивации
	|		ПО ДокументЧленствоПакетУслуг.Ссылка = СтатусыЧленствПакетовУслугСрезПервойАктивации.ЧленствоПакетУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыЧленствПакетовУслуг.СрезПоследних(ДОБАВИТЬКДАТЕ(&ТекущаяДата, СЕКУНДА, 300), ЧленствоПакетУслуг = &ЧленствоПакетУслуг) КАК СтатусыЧленствПакетовУслугСрезПоследних
	|		ПО ДокументЧленствоПакетУслуг.Ссылка = СтатусыЧленствПакетовУслугСрезПоследних.ЧленствоПакетУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПоследнийДокумент КАК ПоследнийДокумент
	|		ПО ДокументЧленствоПакетУслуг.Ссылка = ПоследнийДокумент.Основание
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЧленстваПакетыУслугОстаткиИОбороты КАК ЧленстваПакетыУслугОстаткиИОбороты
	|		ПО ДокументЧленствоПакетУслуг.Ссылка = ЧленстваПакетыУслугОстаткиИОбороты.Основание
	|ГДЕ
	|	ДокументЧленствоПакетУслуг.Ссылка = &ЧленствоПакетУслуг");
	
	Запрос.УстановитьПараметр("ЧленствоПакетУслуг"	, ЧленствоПакетУслуг);
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.СрокДействия; 
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Начать сохранение настроек пользователя
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьСохранениеНастроекПользователя(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)	
	// Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;		
		ЗаписатьНастройкиПользователя(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	// Иначе 
	//	СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания", Истина);		
	// КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийСотрудник);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ЗаписатьНастройкиПользователя",
	ПараметрыПроцедуры,
	НСтр("ru='Сохранение настроек пользователя...';en='Saving user settings...'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Записать настройки пользователя
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗаписатьНастройкиПользователя(ПараметрыЗадания, АдресРезультата) Экспорт
	
	Если НЕ ПараметрыЗадания.Свойство("ТекущийПользователь") Тогда 
		ПараметрыЗадания.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийСотрудник);	
	КонецЕсли;
	
	КоллекцияНастроекПВХ 				= ПланыВидовХарактеристик.НастройкиИнтерфейсов.ПолучитьКоллекциюНастроекПользователя(ПараметрыЗадания.ИмяГруппыНастроекПользователя, "ТаблицаЗначений");
	
	Для Каждого НастройкаПВХ Из КоллекцияНастроекПВХ Цикл 
		Для Каждого РеквизитФормы Из ПараметрыЗадания.СтруктураРеквизитовФормы Цикл
			Если РеквизитФормы.Ключ = СтрЗаменить(НастройкаПВХ.ИмяПредопределенныхДанных, ПараметрыЗадания.ПрефиксНастроекПользователя, "") Тогда 
				РегистрыСведений.НастройкиИнтерфейсов.ЗаписатьЗначениеНастройкиПользователя(НастройкаПВХ.ИмяПредопределенныхДанных, РеквизитФормы.Значение, ПараметрыЗадания.ТекущийПользователь);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Функция - Начать установку статуса прибытия клиента
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьУстановкуСтатусаПрибытияКлиента(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)	
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;			
		УстановитьСтатусыПрибытияКлиента(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	Иначе 
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания", Истина);		
	КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.УстановитьСтатусыПрибытияКлиента",
	ПараметрыПроцедуры,
	НСтр("ru='Установка статуса прибытия клиента';en='Installation status arrival client'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Установить статусы прибытия клиента
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура УстановитьСтатусыПрибытияКлиента(ПараметрыЗадания, АдресРезультата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ЗанятиеСоставЗанятия.Ссылка КАК Занятие
	               |ПОМЕСТИТЬ ТаблицаСоставЗанятия
	               |ИЗ
	               |	Документ.Занятие.СоставЗанятия КАК ЗанятиеСоставЗанятия
	               |ГДЕ
	               |	ЗанятиеСоставЗанятия.Ссылка.Проведен
	               |	И ЗанятиеСоставЗанятия.Контрагент = &Контрагент
	               |	И ЗанятиеСоставЗанятия.СтатусПрибытия = 0
	               |	И ЗанятиеСоставЗанятия.ДатаБронирования = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ 
	               |	Занятие.Ссылка КАК Занятие
	               |ИЗ
	               |	Документ.Занятие КАК Занятие
	               |ГДЕ
	               |	Занятие.Ссылка В
	               |			(ВЫБРАТЬ
	               |				ТаблицаСоставЗанятия.Занятие
	               |			ИЗ
	               |				ТаблицаСоставЗанятия КАК ТаблицаСоставЗанятия)
	               |	И НАЧАЛОПЕРИОДА(Занятие.ДатаВремяНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаПрихода, ДЕНЬ)
	               |	И Занятие.СтатусЗанятия <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗанятия.Отменено)
	               |	И Занятие.ТипЗанятия В (ЗНАЧЕНИЕ(Перечисление.ТипыЗанятий.ГрупповоеЗанятие), ЗНАЧЕНИЕ(Перечисление.ТипыЗанятий.ПерсональноеЗанятие), ЗНАЧЕНИЕ(Перечисление.ТипыЗанятий.АрендаЗала))
	               |	И (&ДатаПрихода МЕЖДУ ДОБАВИТЬКДАТЕ(Занятие.ДатаВремяНачала, МИНУТА, -1 * &ВремяПереодеванияДоЗанятия) И ДОБАВИТЬКДАТЕ(Занятие.ДатаВремяОкончания, СЕКУНДА, -1)
	               |			ИЛИ &ДатаПрихода <> ДАТАВРЕМЯ(1, 1, 1)
	               |				И &ДатаУхода <> ДАТАВРЕМЯ(1, 1, 1)
	               |				И (Занятие.ДатаВремяНачала МЕЖДУ &ДатаПрихода И &ДатаУхода))
	               |	И Занятие.Номенклатура.УслугаТипОтметкиПрибытияНаЗанятие <> ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаПрибытияКлиентаНаЗанятие.ОтмечаетТренер)
	               |	И Занятие.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
	
	Запрос.УстановитьПараметр("Контрагент" 					 , ПараметрыЗадания.Контрагент);
	Запрос.УстановитьПараметр("ДатаПрихода"					 , ПараметрыЗадания.ДатаПрихода);
	Запрос.УстановитьПараметр("ДатаУхода"  					 , ПараметрыЗадания.ДатаУхода);
	Запрос.УстановитьПараметр("ВремяПереодеванияДоЗанятия"   , 0);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"           , ПараметрыЗадания.СтруктурнаяЕдиница);
	// Запрос.УстановитьПараметр("ВремяПереодеванияПослеЗанятия", Константы.ВремяПереодеванияПослеЗанятия.Получить());
	
	ТаблицаЗанятий = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЧ Из ТаблицаЗанятий Цикл
		НачатьТранзакцию();
		Попытка
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("Документ.Занятие");
			ЭлементБлокировки.УстановитьЗначение("Ссылка", СтрокаТЧ.Занятие);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
			ОбъектЗанятие = СтрокаТЧ.Занятие.ПолучитьОбъект();
			НайденныеСтроки = ОбъектЗанятие.СоставЗанятия.НайтиСтроки(Новый Структура("Контрагент", ПараметрыЗадания.Контрагент));
			Для Каждого СтрокаСоставаЗанятия Из НайденныеСтроки Цикл
				СтрокаСоставаЗанятия.СтатусПрибытия = 1;
			КонецЦикла;
			ОбъектЗанятие.ДополнительныеСвойства.Вставить("РасчетКонтрагента"	, ПараметрыЗадания.Контрагент);
			ОбъектЗанятие.ДополнительныеСвойства.Вставить("НеСоздаватьПосещение", Истина);
			ОбъектЗанятие.Записать(РежимЗаписиДокумента.Проведение);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации("Ошибка установки статуса клиента", УровеньЖурналаРегистрации.Ошибка, 
			?(ЗначениеЗаполнено(СтрокаТЧ.Занятие), СтрокаТЧ.Занятие.Метаданные(), Неопределено), ОбъектЗанятие.Ссылка, ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

// Функция - Начать завершение связанных задач
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьЗавершениеСвязанныхЗадач(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)	
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;			
		ЗавершитьСвязанныеЗадачи(СтруктураПараметров, Неопределено);
		Возврат Неопределено;
	Иначе 
		СтруктураПараметров.Вставить("НеОжидатьЗавершенияФоновогоЗадания", Истина);		
	КонецЕсли;	
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.ЗавершитьСвязанныеЗадачи",
	ПараметрыПроцедуры,
	НСтр("ru='Завершение связанных задач';en='Completing related tasks'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Завершить связанные задачи
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ЗавершитьСвязанныеЗадачи(ПараметрыЗадания, АдресРезультата) Экспорт
	
	//Если ПараметрыЗадания.ДополнительныеСвойства.Свойство("ЭтоНовый") И ПараметрыЗадания.ДополнительныеСвойства.ЭтоНовый = Истина Тогда 
	//	ИнициализироватьЗадачиСогласноПредмета = Истина;
	//Иначе 
		ИнициализироватьЗадачиСогласноПредмета = Ложь;
	//КонецЕсли;	
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Взаимодействие.Ссылка КАК ВзаимодействиеСсылка,
	               |	ИСТИНА КАК Инициализирована
	               |ИЗ
	               |	Задача.Взаимодействие КАК Взаимодействие
	               |ГДЕ
	               |	Взаимодействие.ПометкаУдаления = ЛОЖЬ
	               |	И Взаимодействие.Выполнена = ЛОЖЬ
	               |	И Взаимодействие.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И Взаимодействие.Сделка = &Сделка";
				   //|
				   //|ОБЪЕДИНИТЬ ВСЕ
				   //|
				   //|ВЫБРАТЬ
				   //|	Взаимодействие.Ссылка,
				   //|	ЛОЖЬ
				   //|ИЗ
				   //|	Задача.Взаимодействие КАК Взаимодействие
				   //|ГДЕ
				   //|	&ИнициализироватьЗадачиСогласноПредмета
				   //|	И Взаимодействие.ПометкаУдаления = ЛОЖЬ
				   //|	И Взаимодействие.Выполнена = ЛОЖЬ
				   //|	И Взаимодействие.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
				   //|	И Взаимодействие.ЗадачаПредмет = &ЗадачаПредмет
				   //|	И Взаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ИнициализироватьЗадачиСогласноПредмета"	, ИнициализироватьЗадачиСогласноПредмета);	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"						, ПараметрыЗадания.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сделка"									, ПараметрыЗадания.Сделка);
	//Запрос.УстановитьПараметр("ЗадачаПредмет"							, ПараметрыЗадания.ЧленствоПакетУслуг);
	
	ВыборкаЗадач = Запрос.Выполнить().Выбрать();
	ДатаЗаверешенияЗадач = ТекущаяДатаСеанса();
	Пока ВыборкаЗадач.Следующий() Цикл 
		Задача_Объект 							= ВыборкаЗадач.ВзаимодействиеСсылка.ПолучитьОбъект();
		Задача_Объект.ВзаимодействиеСостоялось 	= Ложь;
		Задача_Объект.Выполнена 				= Истина;
		Задача_Объект.ДатаИсполнения 			= ДатаЗаверешенияЗадач;
		Задача_Объект.ИсполнительФактический 	= ПараметрыСеанса.ТекущийСотрудник;//Справочники.Сотрудники.ПустаяСсылка();
		Если ВыборкаЗадач.Инициализирована = Ложь Тогда 
			Задача_Объект.Сделка 				= ПараметрыЗадания.Сделка;
		КонецЕсли;
		ЗадачаОписание = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗадания.ДополнительныеСвойства, "ЗадачаОписание", "");
		Если ЗначениеЗаполнено(ЗадачаОписание) Тогда 
			Задача_Объект.ЗадачаОписание 		= СокрЛП(СокрЛП(Задача_Объект.ЗадачаОписание) + Символы.ПС + Символы.ПС + ЗадачаОписание);
		Иначе 	
			Задача_Объект.ЗадачаОписание 		= СокрЛП(Задача_Объект.ЗадачаОписание) + Символы.ПС + Символы.ПС + "Завершена автоматически, в связи с закрытием сделки.";
		КонецЕсли;	
		Задача_Объект.ДополнительныеСвойства.Вставить("НеИнициализироватьСделку", Истина);
		Попытка
			Задача_Объект.Записать();
		Исключение
			
		КонецПопытки;	
	КонецЦикла;	
	
КонецПроцедуры

// Функция - Начать запись регистра в фоне
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  СтруктураПараметров		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьПомещениеЧленствПакетовУслугВСтек(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	// Для файловых баз не запускаем фоновое выполнение, дабы свести к минимуму вероятность возникновения конфликта блокировок. (таблицы на файловом варианте при записи блокируются полностью)	
	Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
		// Удалим параметр
		Если СтруктураПараметров.Свойство("Пауза") Тогда 
			СтруктураПараметров.Удалить("Пауза");
		КонецЕсли;			
		ПолучитьИПоместитьДокументыВСтек(СтруктураПараметров, Неопределено);
