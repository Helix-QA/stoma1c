// Процедура, обновляет котекстное меню списка сделок.
//
Процедура ОбновитьКонтекстноеМенюСделок(Сделка)
	
	ТекущийЭлементФормы = ЭтаФорма.ТекущийЭлемент;
	Если ТипЗнч(ТекущийЭлементФормы) <> Тип("ТаблицаФормы") Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрокаСписка = ТекущийЭлементФормы.ТекущиеДанные;
	Если ТекущаяСтрокаСписка <> Неопределено И ТекущаяСтрокаСписка.Свойство("ВидСделки") Тогда
		ВидТекущейСделки = ТекущаяСтрокаСписка.ВидСделки;
	Иначе
		Возврат;
	КонецЕсли;
	
	ПодчиненныеЭелеменыКонтекстногоМеню = Элементы.СписокСменитьСделку.ПодчиненныеЭлементы;
	
	Для Каждого ПодчиненныйЭлемент Из ПодчиненныеЭелеменыКонтекстногоМеню Цикл
		
		ИндексТЗ      = ПолучитьИндексСтроки(ПодчиненныйЭлемент.Имя);
		ВидСделки     = ЭтотОбъект.ТаблицаВидовСделок[ИндексТЗ].ВидСделки;
		
		ПодчиненныйЭлемент.Видимость = Не (ВидТекущейСделки = ВидСделки);
		
	КонецЦикла;
	
КонецПроцедуры

