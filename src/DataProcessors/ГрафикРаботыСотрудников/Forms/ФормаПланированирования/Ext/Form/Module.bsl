			КнопкаОкончанияИнтервала.ИмяКоманды 									= "Подключаемый_ВыборОкончанияИнтервала_" + ИндексИнтервала;
			КнопкаОкончанияИнтервала.Заголовок 										= ?(ЭлементСписка.Значение.ОкончаниеРаботы = Неопределено, "[...]", Формат(ЭлементСписка.Значение.ОкончаниеРаботы, "ДФ=HH:mm"));
			КнопкаОкончанияИнтервала.ОтображениеФигуры    							= ОтображениеФигурыКнопки.Нет;
			КнопкаОкончанияИнтервала.Ширина 										= 4;
			КнопкаОкончанияИнтервала.ЦветТекста 									= ЦветаСтиля.ТекстВторостепеннойНадписи;
			КнопкаОкончанияИнтервала.Шрифт 											= Новый Шрифт("Arial", 11);
			КнопкаОкончанияИнтервала.ГоризонтальноеПоложениеВГруппе 				= ГоризонтальноеПоложениеЭлемента.Центр;
			КнопкаОкончанияИнтервала.ВертикальноеПоложениеВГруппе 					= ВертикальноеПоложениеЭлемента.Центр;
			КнопкаОкончанияИнтервала.ЦветФона 										= Новый Цвет(240, 240, 240);
			
			// Декорация "х"				
			ДекорацияФормы_УдалениеИнтервала = Элементы.Добавить("ДекорацияФормы_УдалениеИнтервала_" + ИндексИнтервала, Тип("ДекорацияФормы"), Группа_Интервал);
			ДекорацияФормы_УдалениеИнтервала.Вид 									= ВидДекорацииФормы.Картинка;
			// ДекорацияФормы_УдалениеИнтервала.Заголовок 								= "-";
			ДекорацияФормы_УдалениеИнтервала.Ширина 								= 1;
			ДекорацияФормы_УдалениеИнтервала.Высота 								= 1;
			ДекорацияФормы_УдалениеИнтервала.ЦветТекста								= ЦветаСтиля.ТекстВторостепеннойНадписи;			
			ДекорацияФормы_УдалениеИнтервала.ГоризонтальноеПоложениеВГруппе 		= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_УдалениеИнтервала.ВертикальноеПоложениеВГруппе			= ВертикальноеПоложениеЭлемента.Центр;		
			ДекорацияФормы_УдалениеИнтервала.Картинка 								= БиблиотекаКартинок.УдалениеДанных16;
			ДекорацияФормы_УдалениеИнтервала.Гиперссылка 							= Истина;
			ДекорацияФормы_УдалениеИнтервала.РастягиватьПоГоризонтали	 			= Ложь;
			
			ДекорацияФормы_УдалениеИнтервала.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_УдалитьТекущийИнтервал_Нажатие");
			
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

