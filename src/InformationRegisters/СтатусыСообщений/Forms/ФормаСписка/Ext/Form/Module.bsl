&НаКлиенте
Процедура ОчиститьРегистр(Команда)
	ОчиститьРегистрНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОчиститьРегистрНаСервере()
	
	НаборЗап = РегистрыСведений.СтатусыСообщений.СоздатьНаборЗаписей();
	НаборЗап.Прочитать();
	НаборЗап.Очистить();
	НаборЗап.Записать();
	
КонецПроцедуры

