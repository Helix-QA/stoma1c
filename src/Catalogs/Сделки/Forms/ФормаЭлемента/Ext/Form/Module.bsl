КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СоздатьПрием".
//
Процедура СоздатьПрием(Команда)
	
	Если Объект.Врач.Пустая() Тогда	
		ПоказатьПредупреждение(, НСтр("ru = 'Для назначения приема требуется выбрать врача.'; en = 'To make an appointment, you need to choose a doctor.'"));		
	Иначе		
		
		ПараметрыОткрытия = Новый Структура();
		ПараметрыОткрытия.Вставить("ОтборПоСотрудникИлиДолжности"	, Объект.Врач);
		ПараметрыОткрытия.Вставить("ПереключательПериода"			, ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Неделя")); 
		ПараметрыОткрытия.Вставить("Контрагент"						, Объект.Контрагент);
		ПараметрыОткрытия.Вставить("ЗаписьИзДругойФормы"			, Истина);
		
		ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыОткрытия, "ФормаЗаписи");
		ОткрытьФорму(ИмяФормыПланировщика, ПараметрыОткрытия,, Новый УникальныйИдентификатор,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
		// ОткрытьФорму("Обработка.ЖурналЗаписи.Форма.Форма", ПараметрыОткрытия,, Новый УникальныйИдентификатор,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;

КонецПроцедуры

