&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура ПослеВыбораДействия(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		// Отменен выбор оценки заявки, возвращаем заявку на место.
		ОтменитьПеретаскиваниеЗаявки();
		Возврат;
	КонецЕсли;
	
	Если Результат = "ЗаписатьНаПрием" Тогда
		СоздатьКлиента(ДополнительныеПараметры.ИдентификаторЗаявки, ДополнительныеПараметры.ПараметрыПолученияЗаявкиИзОчереди, Истина);
		
	ИначеЕсли Результат = "СоздатьКлиента" Тогда
		СоздатьКлиента(ДополнительныеПараметры.ИдентификаторЗаявки, ДополнительныеПараметры.ПараметрыПолученияЗаявкиИзОчереди);
		
	ИначеЕсли Результат = "ВыбратьКлиента" Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораКлиента", ЭтотОбъект, ДополнительныеПараметры);
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаВыбораКлиенты",,,,,, ОписаниеОповещения);
		
	ИначеЕсли ТипЗнч(Результат) = Тип("УникальныйИдентификатор") Тогда
		СоздатьКлиента(ДополнительныеПараметры.ИдентификаторЗаявки, ДополнительныеПараметры.ПараметрыПолученияЗаявкиИзОчереди, Истина, Результат);
  		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения асинхронного события.
//
Процедура ПослеВыбораКлиента(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		// Отменен выбор клиента, возвращаем заявку на место.
		ОтменитьПеретаскиваниеЗаявки();
		Возврат;
	КонецЕсли;
	
	ПараметрыЗаявки = Новый Структура;
	ПараметрыЗаявки.Вставить("ОсновнойКлиент", Результат);
	
	РезультатОперации = УстановитьСтатусЗаявки(
		"Принята",
		ДополнительныеПараметры.ИдентификаторЗаявки,
		ПолучитьСтруктуруЗначенийОтбораКлиент(),
		ПараметрыЗаявки,
		ДополнительныеПараметры.ПараметрыПолученияЗаявкиИзОчереди
	);
	ОбработатьРезультатПереносаЗаявки(РезультатОперации);
	
КонецПроцедуры

&НаКлиенте
// Процедура, создает клиента на основании заявки и записывает его на прием если нужно.
//
Процедура СоздатьКлиента(ИдентификаторЗаявки, ПараметрыПолученияЗаявкиИзОчереди, ЗаписатьНаПрием = Ложь, ИдентификаторВидаСделки = Неопределено)
	
	СтруктураОтборов = ПолучитьСтруктуруЗначенийОтбораКлиент();
	
	РезультатОперации = СоздатьКлиентаНаСервере(ИдентификаторЗаявки, СтруктураОтборов, ПараметрыПолученияЗаявкиИзОчереди, ИдентификаторВидаСделки);
	ОбработатьРезультатПереносаЗаявки(РезультатОперации, Истина);
	
	Если РезультатОперации.ВыполненоУспешно = Истина И ЗаписатьНаПрием = Истина Тогда
		ОткрытьЖурналЗаписи(РезультатОперации.ПараметрыОткрытияЖурнала);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, создает клиента и возвращает результат операции.
//
Функция СоздатьКлиентаНаСервере(ИдентификаторЗаявки, СтруктураОтборов, ПараметрыПолученияЗаявкиИзОчереди, ИдентификаторВидаСделки)
	
	РезультатОперации = Новый Структура;
	РезультатОперации.Вставить("ОписаниеОшибки"				, "");
	РезультатОперации.Вставить("ВыполненоУспешно"			, Ложь);
	РезультатОперации.Вставить("ИдентификаторЗаявки"		, ИдентификаторЗаявки);
	РезультатОперации.Вставить("ПараметрыОткрытияЖурнала"	, Новый Структура);
	
	Заявка = ПолучитьСсылку("Справочники", "Заявки", ИдентификаторЗаявки);
	
	НачатьТранзакцию();
	Попытка
		СсылкаНовогоКлиента = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор);
		
		ЗаявкаОбъект				 = Заявка.ПолучитьОбъект();
		ЗаявкаОбъект.Статус			 = Перечисления.СтатусыЗаявок.Принята;
		ЗаявкаОбъект.ОсновнойКлиент	 = СсылкаНовогоКлиента;
		
		Если Не ЗначениеЗаполнено(ЗаявкаОбъект.ОсновнойМенеджер) Тогда
			
			ЗаявкаОбъект.ОсновнойМенеджер = ПараметрыСеанса.ТекущийСотрудник;
			
			ДанныеСотрудника = Новый Структура;
			ДанныеСотрудника.Вставить("ИдентификаторСотрудника", XMLСтрока(ЗаявкаОбъект.ОсновнойМенеджер));
			ДанныеСотрудника.Вставить("ПредставлениеСотрудника", ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЗаявкаОбъект.ОсновнойМенеджер, "Наименование"));
			
			РезультатОперации.Вставить("ДанныеСотрудника"				, ДанныеСотрудника);
			РезультатОперации.Вставить("ОбновитьПредставлениеСотрудника", Истина);
			
		КонецЕсли;
		
		НовыйКлиент = Справочники.Контрагенты.СоздатьЭлемент();
		НовыйКлиент.УстановитьСсылкуНового(СсылкаНовогоКлиента);
		
		СтруктураФИО = Новый Структура;
		СтруктураФИО.Вставить("Имя"		, ЗаявкаОбъект.Имя);
		СтруктураФИО.Вставить("Фамилия"	, ЗаявкаОбъект.Фамилия);
		СтруктураФИО.Вставить("Отчество", ЗаявкаОбъект.Отчество);
		
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("СтруктураФИО", СтруктураФИО);
		ДанныеЗаполнения.Вставить("Родитель"	, Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты));
		
		НовыйКлиент.Заполнить(ДанныеЗаполнения);
		
		// Переносим контактную информацию из заявки.
		Для Каждого СтрокаКИ Из ЗаявкаОбъект.КонтактнаяИнформация Цикл
			НоваяСтрокаКИ = НовыйКлиент.КонтактнаяИнформация.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаКИ, СтрокаКИ);
		КонецЦикла;
		
		НовыйКлиент.ДополнительныеСвойства.Вставить("Заявка", Заявка);
		
		НовыйКлиент.Записать();
		ЗаявкаОбъект.Записать();
		
		// Запись на прием с выбранным видом сделки.
		Если ЗначениеЗаполнено(ИдентификаторВидаСделки) Тогда
			
			ВидСделки = Справочники.ВидыСделок.ПолучитьСсылку(ИдентификаторВидаСделки);
			
			СделкаОбъект = Справочники.Сделки.СоздатьЭлемент();
			ТаблицаЭтапов = Справочники.ВидыСделок.ПолучитьЭтапыПоВидуСделки(ВидСделки);
			
			ДанныеЗаполненияСделки = Новый Структура;
			ДанныеЗаполненияСделки.Вставить("Контрагент"					, СсылкаНовогоКлиента);
			ДанныеЗаполненияСделки.Вставить("ВидСделки"						, ВидСделки);
			ДанныеЗаполненияСделки.Вставить("Заявка"						, ЗаявкаОбъект.Ссылка);
			ДанныеЗаполненияСделки.Вставить("ЭтапСделки"					, ?(ТаблицаЭтапов.Количество() > 0, ТаблицаЭтапов[0].ЭтапСделки, Неопределено));
			ДанныеЗаполненияСделки.Вставить("ДатаСделки"					, ТекущаяДатаСеанса());
			ДанныеЗаполненияСделки.Вставить("СтруктурнаяЕдиница"			, ЗаявкаОбъект.СтруктурнаяЕдиница);
			ДанныеЗаполненияСделки.Вставить("ИсточникИнформации"			, ЗаявкаОбъект.РекламныйИсточник);
			ДанныеЗаполненияСделки.Вставить("ИсточникИнформацииЗначение"	, ЗаявкаОбъект.ИсточникИнформацииЗначение);
			ДанныеЗаполненияСделки.Вставить("КаналПривлечения"				, ЗаявкаОбъект.КаналПривлечения);
			ДанныеЗаполненияСделки.Вставить("КаналПривлеченияЗначение"		, ЗаявкаОбъект.КаналПривлеченияЗначение);
			
			СделкаОбъект.Заполнить(ДанныеЗаполненияСделки);
			СделкаОбъект.Записать();
			
			РезультатОперации.ПараметрыОткрытияЖурнала.Вставить("Сделка", СделкаОбъект.Ссылка);
			
			РезультатОперации.Вставить("ДанныеСделки"				, ПолучитьДанныеСделкиДляОбновленияБлока(СделкаОбъект));
			РезультатОперации.Вставить("ОбновитьПредставлениеСделки", Истина);
			
		КонецЕсли;
		
		РезультатОперации.ПараметрыОткрытияЖурнала.Вставить("Контрагент", НовыйКлиент.Ссылка);
		РезультатОперации.ВыполненоУспешно	 = Истина;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();
		КонецЕсли;
		
		ОписаниеОшибки = ОписаниеОшибки();
		РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Не удалось создать пациента. Текст ошибки: '") + ОписаниеОшибки;
		
	КонецПопытки;
	
	Если РезультатОперации.ВыполненоУспешно Тогда
		ЗаполнитьДополнительныеПараметрыИОповеститьСеансы(ЗаявкаОбъект, РезультатОперации, СтруктураОтборов, ПараметрыПолученияЗаявкиИзОчереди);
	КонецЕсли;
	
	Возврат РезультатОперации;
	
КонецФункции

&НаСервереБезКонтекста
// Функция, возвращает данные для обновления блока сделки.
//  
// Параметры:
//  ДанныеСделки - СделкаОбъект или структура (Ссылка, НаименованиеСокращенное, ЭтапСделки - если не переданы данные этапа)
//  ДанныеЭтапа - Структура - Наименование, ЦветЭтапа
// 
Функция ПолучитьДанныеСделкиДляОбновленияБлока(ДанныеСделки, ДанныеЭтапа = Неопределено)
	
	Если ДанныеЭтапа = Неопределено Тогда
		ДанныеЭтапа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ДанныеСделки.ЭтапСделки, "Наименование, ЦветЭтапа");
	КонецЕсли;
	
	ЦветЭтапа		 = ?(ЗначениеЗаполнено(ДанныеЭтапа.ЦветЭтапа), ЗначениеИзСтрокиВнутр(ДанныеЭтапа.ЦветЭтапа), Новый Цвет(242, 242, 242));
	ЦветТекстаЭтапа	 = ОбщегоНазначенияСтоматология.ПолучитьЦветТекстаПоЦветуФона(ЦветЭтапа, Истина);
	
	СтильЦветФонаСделки		 = "background:" + ПолучитьЦветДляHTML(ЦветЭтапа) + ";";
	СтильЦветТекстаСделки	 = "color:" + ПолучитьЦветДляHTML(ЦветТекстаЭтапа) + ";";

	СтилиСделки			 = СтильЦветФонаСделки + СтильЦветТекстаСделки;
	ИдентификаторСделки	 = Строка(ДанныеСделки.Ссылка.УникальныйИдентификатор());
	ПредставлениеСделки	 = СокрЛП(ДанныеСделки.НаименованиеСокращенное + " " + ДанныеЭтапа.Наименование);
	
	ДанныеСделкиДляОбновленияБлока = Новый Структура;
	ДанныеСделкиДляОбновленияБлока.Вставить("СтилиСделки"			, СтилиСделки);
	ДанныеСделкиДляОбновленияБлока.Вставить("ИдентификаторСделки"	, ИдентификаторСделки);
	ДанныеСделкиДляОбновленияБлока.Вставить("ПредставлениеСделки"	, ПредставлениеСделки);
	
	Возврат ДанныеСделкиДляОбновленияБлока;
	
КонецФункции

&НаКлиенте
// Процедура, открывает журнал записи.
//
Процедура ОткрытьЖурналЗаписи(ПараметрыОткрытия)
	
	ПараметрыОткрытия.Вставить("ЗаписьИзДругойФормы"			, Истина);
	ПараметрыОткрытия.Вставить("ЗакрыватьПриИзмененииСобытия"	, Истина);
	
	ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыОткрытия);
	ОткрытьФорму(ИмяФормыПланировщика, ПараметрыОткрытия,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
