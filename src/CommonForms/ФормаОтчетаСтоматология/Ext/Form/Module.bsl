			ЗаказПокупателяФорма = ПолучитьФорму("Документ.ЗаказПоставщику.ФормаОбъекта");
			ЗаказПокупателяФорма.Объект.ВидЦен = ВидЦен;
			Если ВыбранныйСклад <> Неопределено Тогда
				ЗаказПокупателяФорма.Объект.Склад				= ВыбранныйСклад;
				ЗаказПокупателяФорма.Объект.СтруктурнаяЕдиница	= ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(ВыбранныйСклад, "СтруктурнаяЕдиница");
			Иначе
				ЗаказПокупателяФорма.Объект.Склад				= ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка");
				ЗаказПокупателяФорма.Объект.СтруктурнаяЕдиница	= СтруктурнаяЕдиница;
			КонецЕсли;
			ЗаказПокупателяФорма.Объект.Контрагент				= ?(ВыбранныйПоставщик <> Неопределено, ВыбранныйПоставщик, ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка"));
			
