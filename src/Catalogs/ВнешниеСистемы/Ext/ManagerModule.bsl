// Процедура, создает внешнюю систему в CRM и ретрансляторе.
//
Процедура ПодключитьВнешнююСистему(ВнешняяСистема, Отказ, УИДСессии = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
		
	// Если ПараметрыСеанса.ОбластьДанныхИспользование И Не ЗначениеЗаполнено(Константы.ВнешняяПубликацияАдрес.Получить()) Тогда  // адрес внешней публикации нужен для ретранслятора вне зависимости облако это или нет
	//	
	//	АдресПубликации = "https://cloud.stoma1c.ru/" + ПолучитьИмяПубликацииИнформационнойБазы() + "/" + Формат(ПараметрыСеанса.ОбластьДанныхЗначение, "ЧГ=");
	//	Константы.ВнешняяПубликацияАдрес.Установить(АдресПубликации);
	//	
	// КонецЕсли;
	
	ЭтоОблако = ПараметрыСеанса.ОбластьДанныхИспользование;
	
	Если ЭтоОблако 
		И Не ЗначениеЗаполнено(Константы.ВнешняяПубликацияАдрес.Получить()) Тогда
		
		АдресПубликации = "https://cloud.stoma1c.ru/app/" + Формат(ПараметрыСеанса.ОбластьДанныхЗначение, "ЧГ=");
		Константы.ВнешняяПубликацияАдрес.Установить(АдресПубликации);
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ОписаниеОшибки = ""; 
	// создать (обновить) внешнюю систему в crm и ретрансляторе
	УидСессии        = ?(УИДСессии = Неопределено, ЛичныйКабинет.УидТекущейСессии(), УИДСессии);
	РезультатЗапроса = ЛичныйКабинет.СоздатьВнешнююСистемуВ_CRM(ВнешняяСистема, УидСессии);
	
	Если Не РезультатЗапроса.ВыполненоУспешно Тогда
		ОписаниеОшибки = РезультатЗапроса.ОписаниеОшибки;    
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки,,,, Отказ);  
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

// Функция - Проверить существование внешней системы
// 
// Возвращаемое значение:
//   - 
//
Функция СуществуетВнешняяСистемаПоТипу(
	ТипСистемы = Неопределено, 
	ТолькоИспользуемое = Истина, 
	СтруктурнаяЕдиница = Неопределено, 
	ТекущаяВнешняяСистема = Неопределено) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Код КАК Код,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ТолькоИспользуемое = ИСТИНА
	|				ТОГДА ВнешниеСистемы.Используется = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВЫБОР
	|			КОГДА &ТипСистемы <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.ТипВнешнейСистемы = &ТипСистемы
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &СтруктурнаяЕдиница <> НЕОПРЕДЕЛЕНО
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешниеСистемы.Ссылка <> &ТекущаяВнешняяСистема");	
	
    Запрос.УстановитьПараметр("ТипСистемы"           , ?(ЗначениеЗаполнено(ТипСистемы), ТипСистемы, Неопределено));
	Запрос.УстановитьПараметр("ТолькоИспользуемое"   , ТолькоИспользуемое);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"   , СтруктурнаяЕдиница); 
	Запрос.УстановитьПараметр("ТекущаяВнешняяСистема", ТекущаяВнешняяСистема);

	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

// Функция, возвращает массив, содержащий данные внешних систем мессенджера.
//
Функция ПолучитьДанныеВнешнихСистемМессенджера(СтруктурнаяЕдиница = Неопределено) Экспорт
	
	ТекущаяСтруктурнаяЕдиница = ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВнешниеСистемы.Параметры КАК Параметры,
	|	ВнешниеСистемы.ТипВнешнейСистемы КАК ТипВнешнейСистемы,
	|	ВнешниеСистемы.КлючПриложения КАК КлючПриложения
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.Используется
	|	И НЕ ВнешниеСистемы.ПометкаУдаления
	|	И ВнешниеСистемы.ТипВнешнейСистемы В(&ТипыВнешнихСистем)
	|	И ВнешниеСистемы.СтруктурнаяЕдиница В(&СтруктурныеЕдиницы)");
	
	Запрос.УстановитьПараметр("ТипыВнешнихСистем"	, ПолучитьМассивТиповВнешнихСистемМессенджера());
	Запрос.УстановитьПараметр("СтруктурныеЕдиницы"	, Новый_Массив(ТекущаяСтруктурнаяЕдиница, Справочники.СтруктурныеЕдиницы.ПустаяСсылка()));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ДанныеВнешнихСистем = Новый Массив;
	
	СегментыСотрудника = Неопределено;
	
	Пока Выборка.Следующий() Цикл
		
		ПараметрыВС = Выборка.Параметры.Получить();
		
		Если Не ЗначениеЗаполнено(ПараметрыВС) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПараметрыВС.Свойство("СегментСотрудников") И ЗначениеЗаполнено(ПараметрыВС.СегментСотрудников) Тогда
			
			Если СегментыСотрудника = Неопределено Тогда
				СегментыСотрудника = РегистрыСведений.СотрудникиСегмента.ПолучитьСегментыСотрудника(ПараметрыСеанса.ТекущийПользователь.Сотрудник);
			КонецЕсли;
			
			Если СегментыСотрудника.Найти(ПараметрыВС.СегментСотрудников) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		ДанныеВнешнихСистем.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Выборка));
		
	КонецЦикла;

	Возврат ДанныеВнешнихСистем;
	
КонецФункции

// Функция, возвращает картинку типа внешней системы.
//
Функция КартинкаТипаВнешнейСистемы(ТипВнешнейСистемы) Экспорт
	
	Если ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.GreenApi Тогда
		Картинка = БиблиотекаКартинок.Whatsapp16;
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Telegram Тогда
		Картинка = БиблиотекаКартинок.Telegram16;
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.VkontakteApi Тогда
		Картинка = БиблиотекаКартинок.Vk16;
	ИначеЕсли ТипВнешнейСистемы = Перечисления.ТипыВнешнихСистем.Viber Тогда
		Картинка = БиблиотекаКартинок.Viber16;
	Иначе
		Картинка = БиблиотекаКартинок.Пустая;
	КонецЕсли;
	
	Возврат Картинка;
	
