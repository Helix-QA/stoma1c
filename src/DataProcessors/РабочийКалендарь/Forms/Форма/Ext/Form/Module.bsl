&НаСервере
// Функция - Сформировать блок запись
//
// Параметры:
//  ВыводитьБлок - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокЗапись(ВыводитьБлок = Ложь)
	
	СтрокиПредварительнойЗаписи = "";
	
	СтрокаПредварительнойЗаписи =
	"<tr valign='middle'>
	|            <td class='center_colnew1' style='vertical-align: middle;' width='85%'>
	|                <p class='content'><a href='{НавигационнаяСсылка}'>{Запись}</a> </p>
	|            </td>
	|			 <td class='center_colnew1' style='vertical-align: middle; {Цвет}' align='center' width='15%'>     
	|                {Статус}
	|            </td>
	|        </tr>
	|        <tr>
	|            <td colspan='3' style='height: 8px;'>
	|            </td>
	|        </tr>";
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СобытиеУслуги.Ссылка КАК Ссылка,
	|	СобытиеУслуги.Номенклатура КАК Номенклатура,
	|	СобытиеУслуги.ПричинаЗаписи КАК ПричинаЗаписи,
	|	СобытиеУслуги.Сотрудник КАК Сотрудник,
	|	СобытиеУслуги.ДатаНачала КАК ДатаНачала,
	|	СобытиеУслуги.Цена КАК Цена,
	|	СобытиеУслуги.Ссылка.Контрагент КАК Контрагент,
	|	СобытиеУслуги.Ссылка.Статус КАК Статус
	|ИЗ
	|	Документ.Событие.Услуги КАК СобытиеУслуги
	|ГДЕ
	|	СобытиеУслуги.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И СобытиеУслуги.ДатаНачала >= &ДатаНачала
	|	И СобытиеУслуги.Ссылка.Контрагент = &Клиент
	|	И СобытиеУслуги.Ссылка.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	СобытиеУслуги.Ссылка.Дата";
	
	ЗапросЗаписи = Новый Запрос(ТекстЗапроса);
	ЗапросЗаписи.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДата()));
	// ЗапросЗаписи.УстановитьПараметр("Статус", Перечисления.СтатусыСобытия.Подтверждена);
	ЗапросЗаписи.УстановитьПараметр("Клиент", Контрагент);
	
	РезультатЗаписи = ЗапросЗаписи.Выполнить().Выбрать();
	
	Если РезультатЗаписи.Количество() > 0 И ЗначениеЗаполнено(Контрагент) Тогда
		
		Пока РезультатЗаписи.Следующий() Цикл
			
			ВыводитьБлок = Истина;
			
			СтрокаЗапись = Формат(РезультатЗаписи.ДатаНачала,"ДФ='ддд дд ММММ ЧЧ:мм'") + ", " + Строка(РезультатЗаписи.Сотрудник) + ?(ЗначениеЗаполнено(РезультатЗаписи.ПричинаЗаписи), (", "+Строка(РезультатЗаписи.ПричинаЗаписи)), "") + ?(РезультатЗаписи.Цена <> 0, (", "+Строка(РезультатЗаписи.Цена)+" руб."), ""); 
			НоваяСтрокаПредварительнойЗаписи = СтрЗаменить(СтрокаПредварительнойЗаписи, "{НавигационнаяСсылка}", ПолучитьНавигационнуюСсылку(РезультатЗаписи.Ссылка));
			НоваяСтрокаПредварительнойЗаписи = СтрЗаменить(НоваяСтрокаПредварительнойЗаписи, "{Запись}", СтрокаЗапись);
			Статус = Строка(РезультатЗаписи.Статус);
			НоваяСтрокаПредварительнойЗаписи = СтрЗаменить(НоваяСтрокаПредварительнойЗаписи, "{Статус}", Статус);
			Если РезультатЗаписи.Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
				НоваяСтрокаПредварительнойЗаписи = СтрЗаменить(НоваяСтрокаПредварительнойЗаписи, "{Цвет}", "color:#FF0000;");
			Иначе
				НоваяСтрокаПредварительнойЗаписи = СтрЗаменить(НоваяСтрокаПредварительнойЗаписи, "{Цвет}", "color:#000000;");
			КонецЕсли;
			СтрокиПредварительнойЗаписи = СтрокиПредварительнойЗаписи + НоваяСтрокаПредварительнойЗаписи;		
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СтрокиПредварительнойЗаписи;
	
КонецФункции

