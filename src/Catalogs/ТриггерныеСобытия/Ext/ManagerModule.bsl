#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область СлужебныйПрограммныйИнтерфейс

// Функция - Получить описания триггеров
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОписанияТриггеров() Экспорт 
	
	СписокОписаний = Новый СписокЗначений;
	
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентРегистрация,
							Нстр("ru = 'Триггер срабатывает один раз в момент или после регистрации пациента.'; en = 'The trigger is triggered once during or after the client's registration.'"));	
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПотенциальныйНеСталНовым, 
							Нстр("ru = 'Триггер срабатывает один раз спустя заданное количество дней, если потенциальный пациент не повысил свой статус до нового или постоянного пациента клиники.'; en = 'The trigger is triggered once after the specified number of days, if the potential customer has not upgraded their status to a clinic client or clinic member.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники, 
							Нстр("ru = 'Триггер анализирует непосещение пациентов за указанные период (в днях). Регистрация события происходит по типу ""день в день"". Для анализа выбираются посещения, в основании у которых должны быть указаны, либо активные ЧПУ на текущий момент, либо реализации по клиенту.'; en = 'The trigger analyzes non-attendance of clients for the specified period (in days). The event is registered using the ""day-to-day"" type. For the analysis, we select the sessions that should be based on either the active NC at the moment, or implementations for the client.'"));	
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаявкаНеОбработана, 
							Нстр("ru = 'Триггер срабатывает один раз спустя заданное количество часов/минут, если заявка не была обработана. Заявки поступившие в нерабочее время триггер отработает на следующий день.'; en = 'The trigger is triggered once after the specified number of hours, if the request has not been processed. Applications received after business hours trigger will work the next day.'"));									
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаСменаЭтапа,
							Нстр("ru = 'Триггер срабатывает один раз в момент смены этапа или спустя заданное количество дней.'; en = 'The trigger is triggered once when the stage changes or after a specified number of days.'"));	
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе, 
							Нстр("ru = 'Триггер срабатывает один раз для каждой сделки в момент отсутствия смены этапа в течении определенного времени.'; en = 'The trigger is triggered once for each trade when there is no stage change for a certain time.'"));		
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияВыписаноНаправление, 
							Нстр("ru = 'Триггер срабатывает для всех направлений со статусом ""Запланировано"" или ""Напомнить позже"", по которым нет предварительной записи на приём. В направлении должен быть указан врач. Например: Если в условиях триггера указано ""после события через 2 дня"" - тогда триггер сработает для всех направлений к указанным врачам через 2 после выписки направления, если пациент не записался на приём.'; en = 'Trigger is triggered for all referrals with the status ""Scheduled"" for which there is no prior appointment. The referral must have a physician listed. For example: If the trigger conditions specify ""After event in 2 days"" - then the trigger will be triggered for all referrals to the specified doctors 2 days after the referral is issued, if the patient has not made an appointment.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияОчередьНаЗапись, 
							Нстр("ru = 'Триггер срабатывает для всех пациентов в очереди на запись со статусом ""Запланировано"" или ""Напомнить позже"", по которым нет предварительной записи на приём. Также должен быть указан врач. Например: Если в условиях триггера указано ""до события за 2 дня"" - тогда триггер сработает для всех пациентов в очереди за 2 дня до даты запланированной, если отсутствует запись на приём.'; en = 'The trigger is triggered for all patients in the appointment queue with the status ""Scheduled"" for which there is no appointment. The doctor must also be specified. For example: If the trigger conditions specify ""2 days before event"". - then the trigger will trigger for all patients in the queue 2 days before the scheduled date if there is no appointment.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЛистОжиданияПрофосмотр, 
							Нстр("ru = 'Триггер срабатывает для всех пациентов с запланированным профосмотром, по которым нет предварительной записи на приём. Например: Если в условиях триггера указано ""до события за 7 дней"" - тогда триггер сработает для всех пациентов, у которых запланирован профосмотр через 7 дней и отсутствует запись на приём.'; en = 'Trigger is triggered for all patients with scheduled exams that do not have an appointment. For example: If the trigger conditions are ""7 days before the event"". - then the trigger is triggered for all patients who are scheduled for an exam in 7 days and do not have an appointment.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаСотрудникомКлиники, 
							Нстр("ru = 'Триггер регистрирует событие при смене статуса сотрудником клиники в уже существующей предварительной записи. Регистрация происходит в разрезе пациента и предварительной записи. Таким образом, для пациента и его предварительной записи, триггер будет регистрировать событие только один раз. Последующие изменения статуса для предварительной записи регистрироваться триггером не будут. Для этого нужно создать другой триггер и указать ему соответствующий статус предварительной записи, для которого должна происходить регистрация события.'; en = 'Trigger registers an event when a status change occurs in an existing appointment. The event is logged in terms of the patient and the appointment. Thus, for a patient and his appointment, the trigger will log the event only once. Subsequent status changes for the preregistration will not be logged by the trigger. To do this, you must create another trigger and specify the appropriate status of the appointment for which the event is to be logged.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСменаСтатусаПациентом, 
							Нстр("ru = 'Триггер регистрирует событие при смене статуса пациентом, посредством внешних систем в уже существующей предварительной записи. Регистрация происходит в разрезе пациента и предварительной записи. Таким образом, для пациента и его предварительной записи, триггер будет регистрировать событие только один раз. Последующие изменения статуса для предварительной записи регистрироваться триггером не будут. Для этого нужно создать другой триггер и указать ему соответствующий статус предварительной записи, для которого должна происходить регистрация события.'; en = 'Trigger registers an event when a status change occurs in an existing appointment. The event is logged in terms of the patient and the appointment. Thus, for a patient and his appointment, the trigger will log the event only once. Subsequent status changes for the preregistration will not be logged by the trigger. To do this, you must create another trigger and specify the appropriate status of the appointment for which the event is to be logged.'"));							
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеПереносДатыВремени, 
							Нстр("ru = 'Триггер регистрирует событие только при первом переносе даты и времени начала в уже существующем групповом занятии. При последующих переносах даты и времени начала в групповом занятии регистрация события происходить не будет. Также групповое занятие должно быть в статусе ""Запланировано"".'; en = 'The trigger registers the event only when the start date and time are moved for the first time in an existing group activity. Subsequent postponements of the start date and time in the group session will not register the event. Also, the group lesson should have the status ""Scheduled"".'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеЗаменаИнструктора, 
							Нстр("ru = 'Триггер регистрирует событие только при первой замене инструктора в уже существующем групповом занятии. При последующих изменениях инструктора в групповом занятии регистрация события происходить не будет. Также групповое занятие должно быть в статусе ""Запланировано"".'; en = 'The trigger registers the event only when the instructor is replaced for the first time in an existing group session. Subsequent changes to the instructor in the group session will not register the event. Also, the group lesson should have the status ""Scheduled"".'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема, 
							Нстр("ru = 'Триггер срабатывает в момент начала приема.'; en = 'The trigger is triggered when the class starts.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеСписаниеУслугиКлиентПрибыл, 
							Нстр("ru = 'Триггер срабатывает в момент списания услуги, если клиент прибыл.'; en = 'The trigger is triggered when the service is debited, if the client has arrived.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеСписаниеУслугиПоНеявке, 
							Нстр("ru = 'Триггер срабатывает в момент списания услуги, если услуга списана по неявке клиента.'; en = 'The trigger is triggered when the service is debited, if the service is debited due to the client's non-appearance.'"));
	СписокОписаний.Добавить(Перечисления.ВариантыУсловийТриггерныхСобытий.ЗанятиеПроведеноКлиентПрибыл, 
							Нстр("ru = 'Триггер срабатывает после окончания занятия для каждого клиента в случае его посещения. Триггер можно использовать для отправки сообщения клиенту с просьбой оценить качество предоставленных услуг.'; en = 'The trigger is triggered after the end of the lesson for each client in case of his visit. A trigger can be used to send a message to a client asking him to rate the quality of the services provided.'"));
	
	Возврат СписокОписаний;
	
КонецФункции	

// Функция - Получить таблицу всех вариантов условий триггерных событий
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий() Экспорт
	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий = Новый ТаблицаЗначений;
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ВариантыУсловийТриггерныхСобытий"				, Новый ОписаниеТипов("ПеречислениеСсылка.ВариантыУсловийТриггерныхСобытий"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ВиртуальнаяГруппаСобытий"						, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(128)));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ПредставлениеВиртуальнойГруппыСобытий"			, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(128)));	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ПорядковыйНомерВиртуальнойГруппыСобытий" 		, Новый ОписаниеТипов("Число", Новый КвалификаторыСтроки(2)));	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("СписокМоментовАктивации"							, Новый ОписаниеТипов("СписокЗначений"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("СписокВидовПериодаАктивации"						, Новый ОписаниеТипов("СписокЗначений"));	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("БазовыйВариант"									, Новый ОписаниеТипов("Булево")); // Для добавляемых триггеров - присваивать "Ложь"
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ГибридныйВариантИнициацииТриггера" 				, Новый ОписаниеТипов("Булево")); // Истина - срабатывает и по подписке на событие, и по регламенту. Ложь - только по регламенту.
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяПараметрСобытия" 					, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ОбязательноеЗаполнениеПараметраСобытия" 			, Новый ОписаниеТипов("Булево"));	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("МинимальноеЗначениеПараметраСобытия" 			, Новый ОписаниеТипов("Число", Новый КвалификаторыСтроки(1)));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИмяЭлементаПараметраСобытия"						, Новый ОписаниеТипов("Строка")); // Смотрим на нужный элемент на форме триггера
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяТипАктивацииЧленстваПакетаУслуг"		, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяОтборПоСтруктурнойЕдинице" 			, Новый ОписаниеТипов("Булево"));		
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяОтборПоИсточникамЗаписи" 			, Новый ОписаниеТипов("Булево"));	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяОтборПоСегментуУслуг" 				, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяОтборПоВидуСделки" 					, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяОтборПоВидуЛицевогоСчета"			, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ИспользуетсяОтборПоВидуБонусногоСчета"			, Новый ОписаниеТипов("Булево"));					
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ОбязательноеЗаполнениеСегментаУслуг"				, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("РазрешенаРаботаСоСделками"						, Новый ОписаниеТипов("Булево"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("РазрешенаРаботаСЧатБотом"						, Новый ОписаниеТипов("Булево"));	
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("ДопустимыйВидСделки"								, Новый ОписаниеТипов("СправочникСсылка.ВидыСделок"));
	ТаблицуВсехВариантовУсловийТриггерныхСобытий.Колонки.Добавить("СписокДопустимыхЗавершающихЭтаповСделок"			, Новый ОписаниеТипов("СписокЗначений"));
	
	ОписаниеТипаВариантыМоментовАктивацииТриггерныхСобытий 	= Новый ОписаниеТипов("ПеречислениеСсылка.ВариантыМоментовАктивацииТриггерныхСобытий");
	ОписаниеВидаПериодаСобытия 								= Новый ОписаниеТипов("ПеречислениеСсылка.Периодичность");
	ОписаниеЗавершающихЭтаповСделок							= Новый ОписаниеТипов("СправочникСсылка.ЭтапыСделок");
	
	
#Область ___________________________СОБЫТИЯ_ПО_КЛИЕНТАМ_____________________________

	// ПациентРегистрация
	СтруктураПараметровТриггера = ИнициализироватьСтруктуруПараметровТриггера("СобытияПоПациентам");	
	СтруктураПараметровТриггера.СписокМоментовАктивации.Добавить(Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия);
	СтруктураПараметровТриггера.СписокМоментовАктивации.Добавить(Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия);
	
	СтруктураПараметровТриггера.СписокВидовПериодаАктивации.Добавить(Перечисления.Периодичность.День);
	СтруктураПараметровТриггера.СписокВидовПериодаАктивации.Добавить(Перечисления.Периодичность.Час);
	СтруктураПараметровТриггера.СписокВидовПериодаАктивации.Добавить(Перечисления.Периодичность.Минута);
	
	СтруктураПараметровТриггера.Вставить("ВариантыУсловийТриггерныхСобытий"					, Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентРегистрация);
	СтруктураПараметровТриггера.Вставить("ГибридныйВариантИнициацииТриггера"				, Истина);
	СтруктураПараметровТриггера.Вставить("РазрешенаРаботаСоСделками"						, Истина);
	СтруктураПараметровТриггера.Вставить("ДопустимыйВидСделки"								, Справочники.ВидыСделок.НовыеПациенты);
	
	ЗаполнитьЗначенияСвойств(ТаблицуВсехВариантовУсловийТриггерныхСобытий.Добавить(), СтруктураПараметровТриггера);
	
	// ПациентДеньРождения
	СтруктураПараметровТриггера = ИнициализироватьСтруктуруПараметровТриггера("СобытияПоПациентам");	
	СтруктураПараметровТриггера.СписокМоментовАктивации.Добавить(Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия);
