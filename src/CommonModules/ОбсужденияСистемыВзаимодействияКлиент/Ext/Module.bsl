// Процедура - Оповестить при возврате оплаты СБП
//
// Параметры:
//  ДанныеОповещения - 	 - 
//
Процедура ОповеститьПриВозвратеОплатыСБП(ДанныеОповещения) Экспорт 
	
	Оповестить("СБП_ВозвратОплаты", ДанныеОповещения);
	ПоказатьОповещениеПользователя("Система быстрых платежей", ПолучитьНавигационнуюСсылку(ДанныеОповещения.ОснованиеОплаты), "Возврат оплаты по СБП успешно проведен",,, "СБП_ВозвратОплаты" + ДанныеОповещения.transaction_id);	
	
