	ПараметрыСтруктура = ДополнительныеПараметры.ПараметрыСтруктура;
	КоличествоУпаковок = ?(Число = Неопределено, ДополнительныеПараметры.КоличествоУпаковок, Число);

	Если Число = Неопределено Тогда
		Возврат;	
	КонецЕсли; 
	
	ОтобранныеЗапасыПеретаскиваниеЗавершение(КоличествоУпаковок, ПараметрыСтруктура);

