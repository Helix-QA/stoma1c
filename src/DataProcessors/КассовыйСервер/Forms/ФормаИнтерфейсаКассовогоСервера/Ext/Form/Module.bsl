//Функция, возвращает массив товаров на печать
//
Функция ПолучитьМассивТоваровЧекаВзносаНаЛицСчетДляККТ(СуммаВзноса, Организация)
	
	МассивТоваров = Новый Массив;
	
	СтрокаТовара = МенеджерОборудованияВызовСервера.ПустаяСтруктураСтрокиТоваровЧека();
	
	СтрокаТовара.Наименование           = НСтр("ru='Взнос на лицевой счет';en='Contribution to personal account'");
	СтрокаТовара.СтоимостьБезСкидки     = СуммаВзноса;
	СтрокаТовара.СтавкаНДС              = МенеджерОборудованияВызовСервера.ПолучитьНДСПриВзносеНаЛицевойСчет(Организация);
	СтрокаТовара.СуммаНДС               = Ценообразование.РассчитатьСуммуНДС(СуммаВзноса, СтрокаТовара.СтавкаНДС, Справочники.ВидыЦен.Розничная.ЦенаВключаетНДС);
	СтрокаТовара.ЭтоОплатаКредита       = Ложь;
	СтрокаТовара.СуммаОплачено          = СуммаВзноса;
	
	МассивТоваров.Добавить(СтрокаТовара);
	
	Возврат МассивТоваров;
	
КонецФункции    

