// Функция - подготавливает параметры чека ККТ.
//
Функция ПодготовитьПараметрыЧекаДляККТ(ПочтаКлиента, ТелефонКлиента, ПечататьЧек)
		
	МассивДокументовОплаты = Новый Массив;
	МассивДокументовОплаты.Добавить(Объект.Ссылка);
	Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл
		Если СтрокаТЧ.Сумма <> 0 И ЗначениеЗаполнено(СтрокаТЧ.ДокументОснования) Тогда
			МассивДокументовОплаты.Добавить(СтрокаТЧ.ДокументОснования);
		КонецЕсли;
	КонецЦикла;

	ПараметрыЧека = МенеджерОборудованияВызовСервера.ПустаяСтруктураПараметровЧека();
	
	ОперацияАванса = Ложь;
	Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл
		Если СтрокаТЧ.ЭтоАванс
			Или СтрокаТЧ.Статья = Справочники.СтатьиДоходовИРасходов.ВзносАвансаОтКлиента
			Или СтрокаТЧ.Статья = Справочники.СтатьиДоходовИРасходов.ВзносНалицевойСчет Тогда
			
			ОперацияАванса = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыЧека.ВидОперации             = ?(ОперацияАванса, Перечисления.ВидыОпераций.ВзносНаЛицевойСчет, Перечисления.ВидыОпераций.Продажа);
	ПараметрыЧека.СтруктурнаяЕдиница      = Объект.СтруктурнаяЕдиница;
	ПараметрыЧека.Организация             = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация");
	ПараметрыЧека.Сотрудник               = Объект.Сотрудник;
	ПараметрыЧека.Клиент                  = Объект.Контрагент;
	ПараметрыЧека.Дата                    = ТекущаяДатаСеанса();
	ПараметрыЧека.Касса                   = Объект.Касса;
	ПараметрыЧека.Количество              = 1;		
	ПараметрыЧека.СуммаОплачено           = Объект.СуммаДокумента;
	ПараметрыЧека.ВидНалога               = ВидНалога; 
	ПараметрыЧека.ТипЧека                 = 0;
	ПараметрыЧека.ВыводитьЧекНаБумагу     = ПечататьЧек;
	ПараметрыЧека.ЭлектроннаяПочтаКлиента = ПочтаКлиента;
	ПараметрыЧека.НомерТелефонаКлиента    = ТелефонКлиента;
	
	ПараметрыЧека.МассивПараметровТовары  = ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ();	
	ПараметрыЧека.МассивПараметровОплаты  = ПолучитьМассивОплатФискальногоЧекаОплатыПродажи();	
	
	СуммаКОплатеПоТаблицеТоваров = 0;
	Для Каждого ЭлементМ Из ПараметрыЧека.МассивПараметровТовары Цикл
		СуммаКОплатеПоТаблицеТоваров = СуммаКОплатеПоТаблицеТоваров + ЭлементМ.СтоимостьСоСкидкой;
	КонецЦикла;
	
	ПараметрыЧека.СуммаКОплате = СуммаКОплатеПоТаблицеТоваров;  
	
	ПараметрыЧека.МассивДокументовОснований = МассивДокументовОплаты;
	
	ФормированиеЧека = МенеджерОборудованияВызовСервера.ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека);	

	Возврат ФормированиеЧека;

КонецФункции

