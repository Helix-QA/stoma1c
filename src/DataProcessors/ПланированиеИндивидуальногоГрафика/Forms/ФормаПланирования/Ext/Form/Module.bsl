#Область ОбработчикиСобытийФормы

&НаСервере
// Обработчик при создании формы на сервере
// 
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.ОтборСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Элементы.ОткрытьСписокСалоны.Заголовок = Строка(ОтборСтруктурнаяЕдиница);
	
	Параметры.Свойство("ОтборСотрудник"				  , ЭтотОбъект.ОтборСотрудник);
	Параметры.Свойство("ПерейтиГрафикРаботыСотрудника", ЭтотОбъект.ПерейтиГрафикРаботыСотрудника);
	
	Элементы.ОтборСотрудник.Видимость = НЕ ЗначениеЗаполнено(ЭтотОбъект.ОтборСотрудник);
	Элементы.ПраваяКолонка.Заголовок  = ?(ЭтотОбъект.ПерейтиГрафикРаботыСотрудника, "Клиника", "Сотрудник");
	
	СформироватьЗаголовокГруппыОтборовИФормы();
	
	// Получаем массив номеров рабочих дней недели для СЕ	
    ОбновитьМассивРабочихДнейВНеделе();

	// Заполнение спсика быстрого выбора закешированными данными	
	ЗакешированныеЗначения = ХранилищеСистемныхНастроек.Загрузить("КешированиеВводимыхЗначений", "ИнтервалыВремени");
	Если ЗакешированныеЗначения <> Неопределено Тогда
		
		Для Каждого ЭлементМ ИЗ ЗакешированныеЗначения Цикл
			
			Если ЗначениеЗаполнено(ЭлементМ) Тогда
				
				ПредставлениеИнтервала = ПредставлениеИнтервалаВремени(ЭлементМ);
				Если ПредставлениеИнтервала = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				СписокШаблонов.Добавить(ЭлементМ, Новый ФорматированнаяСтрока(ПредставлениеИнтервала, Новый Шрифт("Arial",10)),, БиблиотекаКартинок.РейтингЗвездаЗаполненная);
				Элементы.ИнтервалыРаботыПредст.СписокВыбора.Добавить(ЭлементМ,Новый ФорматированнаяСтрока(ПредставлениеИнтервала, Новый Шрифт("Arial",10)));
				
				Если Элементы.ИнтервалыРаботыПредст.СписокВыбора.Количество() = 10 Тогда
					Прервать;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Добавим первую пустую неудаляемую строку интервала 
	ОтборИнтервалыРаботы.Добавить(Новый Структура("НачалоРаботы, ОкончаниеРаботы", Неопределено, Неопределено));
	// Отобразим интервалы на форме
	ОбновитьМенюОтбораИнтерваловРабот();
	Элементы.КомандаСвернуть.Пометка = Истина;    
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();

КонецПроцедуры

&НаКлиенте
// Обработчик открытия формы
// 
Процедура ПриОткрытии(Отказ)
	
	ПроверятьНеобхЗаписи 	= Истина;
	ЭтоОчистка 				= Ложь;
	Если НЕ ЗначениеЗаполнено(ОтборПериод) Тогда 
		ОтборПериод.Вариант = ВариантСтандартногоПериода.ЭтотМесяц;
	КонецЕсли;
	
	ИнформацияЭкрана = ПолучитьИнформациюЭкрановКлиента();
	
	Если ИнформацияЭкрана.Количество()>0 Тогда
		Для каждого Параметр из ИнформацияЭкрана Цикл
			Строка = РазрешениеЭкрана.Добавить();
			Строка.Ширина = Параметр.Ширина;
			Строка.Высота = Параметр.Высота;
		КонецЦикла;
	КонецЕсли;
	
	ВремяРаботыСтруктурнойЕдиницы = ВернутьВремяРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница);
	
	ОбновитьОтображениеПланирования(Истина);
	
	ПодключитьОбработчикОжидания("ПроверитьАктивныеОповещенияГрафикаРаботыСотрудников", 10);
	
КонецПроцедуры

&НаКлиенте
// Обработчик оповещения формы о внешнем событии
// 
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПРИ_ЗАПИСИ_СТРУКТУРНОЙ_ЕДИНИЦЫ" Тогда
		// Получаем массив номеров рабочих дней недели для СЕ
        ОбновитьМассивРабочихДнейВНеделе();
		ОбновитьОтображениеПланирования(Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик перед закрытием формы
// 
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда 
		Возврат;
	КонецЕсли;
	
	Если ПроверятьНеобхЗаписи = Истина И ПроверитьНеобходимостьФиксацииИзмененийВПлане() = Истина Тогда	
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаОЗаписиИзмененийОповещение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение,"Имеются несохраненные изменения графика работы. Записать изменения ?", РежимДиалогаВопрос.ДаНетОтмена);
		ПроверятьНеобхЗаписи = Ложь;
		Отказ = Истина;		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Обработка выбора для полей отборов
// 
Процедура ПараметрОтбораОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	// Делаем бэкап значения поля
	ОткатВыбранногоЗначения = ЭтаФорма[Элемент.Имя];
	ЭтотОбъект.ОтборСтруктурнаяЕдиница = ВыбранноеЗначение;
	
	Если ПерейтиГрафикРаботыСотрудника = Ложь Тогда 
		
		Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ОтборСтруктурнаяЕдиница) Тогда
			ЭтотОбъект.ОтборСотрудник = Неопределено;
			ОбновитьОтображениеПланирования(Истина);
		Иначе
			ДоступныДляВыбора = ПолучитьСотрудниковСтруктурнойЕдиницы(ЭтотОбъект.ОтборСтруктурнаяЕдиница);
			Если ДоступныДляВыбора.Найти(ЭтотОбъект.ОтборСотрудник) = Неопределено Тогда
				ЭтотОбъект.ОтборСотрудник = Неопределено;
			КонецЕсли; 
			ОбновитьОтображениеПланирования(Истина);
		КонецЕсли;
		
	Иначе
		ОбновитьОтображениеПланирования(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Обработчик при изменении для всех полей отбора
// 
Процедура ПараметрОтбораПриИзменении(Элемент)
	
	ОтборСтруктурнаяЕдиница = Неопределено;
	
	Если ЭтоОчистка И Элемент.Имя = "ОтборПериод" Тогда 
		Возврат;
	КонецЕсли;
	
	Если ПроверитьНеобходимостьФиксацииИзмененийВПлане() = Истина Тогда
		// КодДляОтката = Элемент.Имя + "= ОткатВыбранногоЗначения;";
		ЭтоОчистка = Ложь;
		СтруктураПарметров = Новый Структура;
		СтруктураПарметров.Вставить("ИмяЭлемента"	, Элемент.Имя);
		СтруктураПарметров.Вставить("КодДляОтката"	, Элемент.Имя + "= ОткатВыбранногоЗначения;");
		Оповещение   = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОФиксацииизменений", ЭтотОбъект, СтруктураПарметров);
		ПоказатьВопрос(Оповещение,"Имеются не сохраненные изменения, они будут потеряны. Продолжить ?",РежимДиалогаВопрос.ДаНет,,,"Планирование");
		Возврат;
	Иначе 	
		ОбновитьОтображениеПланирования(Истина);
	КонецЕсли;
	
	УстановитьДоступностьОтборуИнтервалыРаботы();
	
КонецПроцедуры

