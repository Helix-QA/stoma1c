	|                    </td>
	|                </tr>
	|                <tr>
	|                    <td colspan='3' style='height: 8px;'>
	|                    </td>
	|                </tr>";
	
	Если ЗначениеЗаполнено(Контрагент) И ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
		СуммаЗадолженности = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Контрагент,, Объект.СтруктурнаяЕдиница);		
		Если  СуммаЗадолженности > 0 Тогда
			Долг 		= СтрЗаменить(Долг, "{Цвет}", "color: red;");
			ДолгКлиента = ""+ ?(ЗначениеЗаполнено(СуммаЗадолженности), Формат(СуммаЗадолженности,"ЧДЦ=2; ЧРД=.") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(), "0.00" + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
			НадписьДолг = "Долг пациента:";
		Иначе	
			Долг 		= СтрЗаменить(Долг, "{Цвет}", "");
			ДолгКлиента = ""+ ?(ЗначениеЗаполнено(СуммаЗадолженности), Формат(-СуммаЗадолженности,"ЧДЦ=2; ЧРД=.") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти(), "0.00" + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти());
			НадписьДолг = "Наш долг перед пациентом:";
		КонецЕсли;
		
		ВыводитьБлок 	= Истина; 	
		Долг 		 	= СтрЗаменить(Долг, "{Долг}"       , ДолгКлиента);
		Долг 			= СтрЗаменить(Долг, "{НадписьДолг}", НадписьДолг);
		
	Иначе
		Долг = "";			
	КонецЕсли;
	
	Возврат Долг;
	
