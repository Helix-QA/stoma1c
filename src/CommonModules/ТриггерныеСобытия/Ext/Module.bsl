		               |	ТаблицаОперацийСБонуснымСчетомКонтрагента.СуммаСписания КАК СуммаСписания,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагента.ВидБонусногоСчета КАК ВидБонусногоСчета
		               |ПОМЕСТИТЬ ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор
		               |ИЗ
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагента КАК ТаблицаОперацийСБонуснымСчетомКонтрагента
		               |ГДЕ
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагента.Контрагент <> НЕОПРЕДЕЛЕНО
		               |	И ТаблицаОперацийСБонуснымСчетомКонтрагента.Контрагент В(&СегментКонтрагентов)
		               |	И ТаблицаОперацийСБонуснымСчетомКонтрагента.Контрагент.ОбезличенныйКлиент = ЛОЖЬ
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	БонусныеСчетаОстатки.БонусныйСчет КАК БонусныйСчет,
		               |	ЕСТЬNULL(СУММА(БонусныеСчетаОстатки.СуммаОстаток), 0) КАК СуммаОстаток
		               |ПОМЕСТИТЬ ТаблицаОстатковПоБонусномуСчету
		               |ИЗ
		               |	РегистрНакопления.БонусныеСчета.Остатки(
		               |			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
		               |			БонусныйСчет В
		               |				(ВЫБРАТЬ
		               |					ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.БонусныйСчет
		               |				ИЗ
		               |					ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор)) КАК БонусныеСчетаОстатки
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	БонусныеСчетаОстатки.БонусныйСчет
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.БонусныйСчет КАК БонусныйСчет,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.ВидБонусногоСчета КАК ВидБонусногоСчета,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.БонусныйСчет.ДатаОткрытия КАК ДатаОткрытия,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.БонусныйСчет.СрокДействияНачало КАК СрокДействияНачало,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.БонусныйСчет.СрокДействияКонец КАК СрокДействияКонец,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.Контрагент КАК Контрагент,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.ДатаПлатежа КАК ДатаПлатежа,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.СуммаСписания КАК СуммаСписания,
		               |	ТаблицаОстатковПоБонусномуСчету.СуммаОстаток КАК Остаток,
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.ОбъектСобытия.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ИЗ
		               |	ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор КАК ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатковПоБонусномуСчету КАК ТаблицаОстатковПоБонусномуСчету
		               |		ПО ТаблицаОперацийСБонуснымСчетомКонтрагентаОтбор.БонусныйСчет = ТаблицаОстатковПоБонусномуСчету.БонусныйСчет";
	
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОперацийСБонуснымСчетомКонтрагента.Контрагент В(&СегментКонтрагентов)",
					"ТаблицаОперацийСБонуснымСчетомКонтрагента.Контрагент В
	               |					(ВЫБРАТЬ
	               |						СоставСегментов.ОбъектСегмента
	               |					ИЗ
	               |						РегистрСведений.СоставСегментов КАК СоставСегментов
	               |					ГДЕ
	               |						СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОперацийСБонуснымСчетомКонтрагента.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидБонусногоСчета) Тогда
			Запрос.УстановитьПараметр("ВидБонусногоСчета", ДанныеТриггера.ВидБонусногоСчета);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОперацийСБонуснымСчетом.БонусныйСчет.ВидБонусногоСчета = &ВидБонусногоСчета", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ

		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события бонусный счет окончание срока действия
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_БонусныйСчетОкончаниеСрокаДействия(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ
		
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |	ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты) КАК Контрагент,
		               |	БонусныеСчета.Ссылка КАК ОбъектСобытия,
		               |	БонусныеСчета.ВидБонусногоСчета КАК ВидБонусногоСчета,
		               |	БонусныеСчета.ДатаОткрытия КАК ДатаОткрытия,
		               |	БонусныеСчета.СрокДействияНачало КАК СрокДействияНачало,
		               |	БонусныеСчета.СрокДействияКонец КАК СрокДействияКонец,
		               |	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ТаблицаКлиентовСИстекающимиБонуснымиСчетами
		               |ИЗ
		               |	Справочник.БонусныеСчета КАК БонусныеСчета
		               |ГДЕ
		               |	БонусныеСчета.ПометкаУдаления = ЛОЖЬ
		               |	И БонусныеСчета.ВидБонусногоСчета = &ВидБонусногоСчета
		               |	И НЕ ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |	И ВЫБОР
		               |			КОГДА НЕ ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты) ЕСТЬ NULL
		               |				ТОГДА ВЫРАЗИТЬ(БонусныеСчета.ВладелецБонусногоСчета КАК Справочник.Контрагенты).ОбезличенныйКлиент = ЛОЖЬ
		               |			ИНАЧЕ ИСТИНА
		               |		КОНЕЦ
		               |	И БонусныеСчета.ВладелецБонусногоСчета В(&СегментКонтрагентов)
		               |	И БонусныеСчета.Закрыт = ЛОЖЬ
		               |	И НАЧАЛОПЕРИОДА(БонусныеСчета.СрокДействияКонец, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		               |	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК ОбъектСобытия
		               |ПОМЕСТИТЬ ТаблицаОтработанныхТриггеров
		               |ИЗ
		               |	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		               |ГДЕ
		               |	ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие
		               |	И ЖурналРегистрацииТриггерныхСобытий.Контрагент В
		               |			(ВЫБРАТЬ
		               |				ТаблицаКлиентовСИстекающимиБонуснымиСчетами.Контрагент
		               |			ИЗ
		               |				ТаблицаКлиентовСИстекающимиБонуснымиСчетами)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.Контрагент КАК Контрагент,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.ВидБонусногоСчета КАК ВидБонусногоСчета,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.ДатаОткрытия КАК ДатаОткрытия,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.СрокДействияНачало КАК СрокДействияНачало,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.СрокДействияКонец КАК СрокДействияКонец,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами.РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам
		               |ИЗ
		               |	ТаблицаКлиентовСИстекающимиБонуснымиСчетами КАК ТаблицаКлиентовСИстекающимиБонуснымиСчетами
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхТриггеров КАК ТаблицаОтработанныхТриггеров
		               |		ПО ТаблицаКлиентовСИстекающимиБонуснымиСчетами.Контрагент = ТаблицаОтработанныхТриггеров.Контрагент
		               |			И ТаблицаКлиентовСИстекающимиБонуснымиСчетами.ОбъектСобытия = ТаблицаОтработанныхТриггеров.ОбъектСобытия
		               |ГДЕ
		               |	ТаблицаОтработанныхТриггеров.Контрагент ЕСТЬ NULL
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	СтатусыКонтрагентовСрезПоследних.Контрагент КАК Контрагент
		               |ПОМЕСТИТЬ ТаблицаАктуальныхКлиентов
		               |ИЗ
		               |	РегистрСведений.СтатусыКонтрагентов.СрезПоследних(
		               |			КОНЕЦПЕРИОДА(&ДатаТриггера, ДЕНЬ),
		               |			Контрагент В
		               |				(ВЫБРАТЬ
		               |					ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.Контрагент
		               |				ИЗ
		               |					ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам)) КАК СтатусыКонтрагентовСрезПоследних
		               |ГДЕ
		               |	СтатусыКонтрагентовСрезПоследних.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.Контрагент КАК Контрагент,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.ОбъектСобытия КАК ОбъектСобытия,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.ВидБонусногоСчета КАК ВидБонусногоСчета,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.ДатаОткрытия КАК ДатаОткрытия,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.СрокДействияНачало КАК СрокДействияНачало,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.СрокДействияКонец КАК СрокДействияКонец,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.Контрагент.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.РегистрацияЗапланированных КАК РегистрацияЗапланированных
		               |ПОМЕСТИТЬ ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов
		               |ИЗ
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам КАК ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам
		               |ГДЕ
		               |	ТаблицаНеОтработанныхКлиентовПоБонуснымСчетам.Контрагент В
		               |			(ВЫБРАТЬ
		               |				ТаблицаАктуальныхКлиентов.Контрагент
		               |			ИЗ
		               |				ТаблицаАктуальныхКлиентов)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	БонусныеСчетаОстатки.БонусныйСчет КАК БонусныйСчет,
		               |	ЕСТЬNULL(СУММА(БонусныеСчетаОстатки.СуммаОстаток), 0) КАК СуммаОстаток
		               |ПОМЕСТИТЬ ТаблицаОстатковПоБонусномуСчету
		               |ИЗ
		               |	РегистрНакопления.БонусныеСчета.Остатки(
		               |			КОНЕЦПЕРИОДА(&ТекущаяДата, ДЕНЬ),
		               |			БонусныйСчет В
		               |				(ВЫБРАТЬ
		               |					ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.ОбъектСобытия
		               |				ИЗ
		               |					ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов)) КАК БонусныеСчетаОстатки
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	БонусныеСчетаОстатки.БонусныйСчет
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.Контрагент КАК Контрагент,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.ОбъектСобытия КАК ОбъектСобытия,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.ВидБонусногоСчета КАК ВидБонусногоСчета,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.ДатаОткрытия КАК ДатаОткрытия,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.СрокДействияНачало КАК СрокДействияНачало,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.СрокДействияКонец КАК СрокДействияКонец,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.РегистрацияЗапланированных КАК РегистрацияЗапланированных,
		               |	ТаблицаОстатковПоБонусномуСчету.СуммаОстаток КАК Остаток
		               |ИЗ
		               |	ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов КАК ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов
		               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОстатковПоБонусномуСчету КАК ТаблицаОстатковПоБонусномуСчету
		               |		ПО ИтоговаяТаблицаЗакрывающихсяБонусныхСчетов.ОбъектСобытия = ТаблицаОстатковПоБонусномуСчету.БонусныйСчет";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "БонусныеСчета.ВладелецБонусногоСчета В(&СегментКонтрагентов)",
			"БонусныеСчета.ВладелецБонусногоСчета В
			|			(ВЫБРАТЬ
			|				СоставСегментов.ОбъектСегмента
			|			ИЗ
			|				РегистрСведений.СоставСегментов КАК СоставСегментов
			|			ГДЕ
			|				СоставСегментов.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "БонусныеСчета.ВладелецБонусногоСчета В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.ВидБонусногоСчета) Тогда
			Запрос.УстановитьПараметр("ВидБонусногоСчета", ДанныеТриггера.ВидБонусногоСчета);
		Иначе 	
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "БонусныеСчета.ВидБонусногоСчета = &ВидБонусногоСчета", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лист ожидания выписано направление
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛистОжиданияВыписаноНаправление(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Направление.Период КАК Период,
		|	Направление.Контрагент КАК Контрагент,
		|	Направление.Сотрудник КАК Сотрудник,
		|	Направление.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	Направление.ВидОсмотра КАК ВидОсмотра,
		|	Направление.ДатаЗапланированная КАК ДатаЗапланированная,
		|	Направление.Статус КАК Статус,
		|	Направление.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
		|	Направление.Прием КАК Прием,
		|	Направление.ПричинаНаправления КАК ПричинаНаправления,
		|	Направление.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаНаправленийПоДате
		|ИЗ
		|	РегистрСведений.Профосмотры КАК Направление
		|ГДЕ
		|	НАЧАЛОПЕРИОДА(Направление.ДатаЗапланированная, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНаправленийПоДате.Период КАК Период,
		|	ТаблицаНаправленийПоДате.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийПоДате.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийПоДате.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаНаправленийПоДате.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаНаправленийПоДате.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаНаправленийПоДате.Статус КАК Статус,
		|	ТаблицаНаправленийПоДате.Прием КАК Прием,
		|	ТаблицаНаправленийПоДате.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаНаправленийПоДате.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаНаправленийФильтрация
		|ИЗ
		|	ТаблицаНаправленийПоДате КАК ТаблицаНаправленийПоДате
		|ГДЕ
		|	ТаблицаНаправленийПоДате.Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|	И ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)
		|	И ТаблицаНаправленийПоДате.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Направление)
		|	И ТаблицаНаправленийПоДате.ДатаЗапланированная <> ДАТАВРЕМЯ(1, 1, 1)
		|	И ТаблицаНаправленийПоДате.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован), ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.НапомнитьПозже))
		|	И ТаблицаНаправленийПоДате.ПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
		|	И ТаблицаНаправленийПоДате.Прием <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК Сотрудник,
		|	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия КАК Прием
		|ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
		|ИЗ
		|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаНаправленийФильтрация КАК ТаблицаНаправленийФильтрация
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ЖурналРегистрацииТриггерныхСобытий.Контрагент = ТаблицаНаправленийФильтрация.Контрагент
		|			И ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия = ТаблицаНаправленийФильтрация.Сотрудник
		|			И ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия = ТаблицаНаправленийФильтрация.Прием
		|
		|СГРУППИРОВАТЬ ПО
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия,
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНаправленийФильтрация.Период КАК ДатаВыпискиНаправления,
		|	ТаблицаНаправленийФильтрация.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийФильтрация.Сотрудник КАК ОбъектСобытия,
		|	ТаблицаНаправленийФильтрация.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийФильтрация.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаНаправленийФильтрация.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаНаправленийФильтрация.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаНаправленийФильтрация.Статус КАК Статус,
		|	ТаблицаНаправленийФильтрация.Прием КАК ИсточникСобытия,
		|	ТаблицаНаправленийФильтрация.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаНаправленийФильтрация.Комментарий КАК Комментарий,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаНаправленийФильтрация КАК ТаблицаНаправленийФильтрация
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхКонтрагентов КАК ТаблицаОтработанныхКонтрагентов
		|		ПО ТаблицаНаправленийФильтрация.Контрагент = ТаблицаОтработанныхКонтрагентов.Контрагент
		|			И ТаблицаНаправленийФильтрация.Сотрудник = ТаблицаОтработанныхКонтрагентов.Сотрудник
		|			И ТаблицаНаправленийФильтрация.Прием = ТаблицаОтработанныхКонтрагентов.Прием
		|ГДЕ
		|	ТаблицаОтработанныхКонтрагентов.Контрагент ЕСТЬ NULL";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)",
			"ТаблицаНаправленийПоДате.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
						
#КонецОбласти
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лист ожидания очередь на запись
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛистОжиданияОчередьНаЗапись(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДатаСеанса());
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Направление.Период КАК Период,
		|	Направление.Контрагент КАК Контрагент,
		|	Направление.Сотрудник КАК Сотрудник,
		|	Направление.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	Направление.ВидОсмотра КАК ВидОсмотра,
		|	Направление.ДатаЗапланированная КАК ДатаЗапланированная,
		|	Направление.Статус КАК Статус,
		|	Направление.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
		|	Направление.Прием КАК Прием,
		|	Направление.ПричинаНаправления КАК ПричинаНаправления,
		|	Направление.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаНаправленийПоДате
		|ИЗ
		|	РегистрСведений.Профосмотры.СрезПоследних(КОНЕЦПЕРИОДА(&ДатаТриггера, ДЕНЬ), ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.ОчередьНаЗапись)) КАК Направление
		|ГДЕ
		|	НАЧАЛОПЕРИОДА(Направление.ДатаЗапланированная, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНаправленийПоДате.Период КАК Период,
		|	ТаблицаНаправленийПоДате.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийПоДате.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийПоДате.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаНаправленийПоДате.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаНаправленийПоДате.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаНаправленийПоДате.Статус КАК Статус,
		|	ТаблицаНаправленийПоДате.Прием КАК Прием,
		|	ТаблицаНаправленийПоДате.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаНаправленийПоДате.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаНаправленийФильтрация
		|ИЗ
		|	ТаблицаНаправленийПоДате КАК ТаблицаНаправленийПоДате
		|ГДЕ
		|	ТаблицаНаправленийПоДате.Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|	И ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)
		|	И ТаблицаНаправленийПоДате.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.ОчередьНаЗапись)
		|	И ТаблицаНаправленийПоДате.ДатаЗапланированная <> ДАТАВРЕМЯ(1, 1, 1)
		|	И ТаблицаНаправленийПоДате.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован), ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.НапомнитьПозже))
		|	И ТаблицаНаправленийПоДате.ПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ТаблицаНаправленийФильтрация.Период) КАК Период,
		|	ТаблицаНаправленийФильтрация.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийФильтрация.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийФильтрация.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ ТаблицаПоследнихЗаписейВОчередь
		|ИЗ
		|	ТаблицаНаправленийФильтрация КАК ТаблицаНаправленийФильтрация
		|
		|СГРУППИРОВАТЬ ПО
		|	ТаблицаНаправленийФильтрация.Контрагент,
		|	ТаблицаНаправленийФильтрация.Сотрудник,
		|	ТаблицаНаправленийФильтрация.СтруктурнаяЕдиница
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНаправленийФильтрация.Период КАК Период,
		|	ТаблицаНаправленийФильтрация.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийФильтрация.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийФильтрация.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаНаправленийФильтрация.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаНаправленийФильтрация.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаНаправленийФильтрация.Статус КАК Статус,
		|	ТаблицаНаправленийФильтрация.Прием КАК Прием,
		|	ТаблицаНаправленийФильтрация.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаНаправленийФильтрация.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаАктуальныхЗаписейВОчередь
		|ИЗ
		|	ТаблицаПоследнихЗаписейВОчередь КАК ТаблицаПоследнихЗаписейВОчередь
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаНаправленийФильтрация КАК ТаблицаНаправленийФильтрация
		|		ПО ТаблицаПоследнихЗаписейВОчередь.Период = ТаблицаНаправленийФильтрация.Период
		|			И ТаблицаПоследнихЗаписейВОчередь.Контрагент = ТаблицаНаправленийФильтрация.Контрагент
		|			И ТаблицаПоследнихЗаписейВОчередь.Сотрудник = ТаблицаНаправленийФильтрация.Сотрудник
		|			И ТаблицаПоследнихЗаписейВОчередь.СтруктурнаяЕдиница = ТаблицаНаправленийФильтрация.СтруктурнаяЕдиница
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК Сотрудник,
		|	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия КАК Прием
		|ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
		|ИЗ
		|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаАктуальныхЗаписейВОчередь КАК ТаблицаАктуальныхЗаписейВОчередь
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И (НАЧАЛОПЕРИОДА(ЖурналРегистрацииТриггерныхСобытий.Период, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ))
		|			И ЖурналРегистрацииТриггерныхСобытий.Контрагент = ТаблицаАктуальныхЗаписейВОчередь.Контрагент
		|			И ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия = ТаблицаАктуальныхЗаписейВОчередь.Сотрудник
		|
		|СГРУППИРОВАТЬ ПО
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия,
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаАктуальныхЗаписейВОчередь.Период КАК ДатаПостановкиВОчередь,
		|	ТаблицаАктуальныхЗаписейВОчередь.Контрагент КАК Контрагент,
		|	ТаблицаАктуальныхЗаписейВОчередь.Сотрудник КАК ОбъектСобытия,
		|	ТаблицаАктуальныхЗаписейВОчередь.Сотрудник КАК Сотрудник,
		|	ТаблицаАктуальныхЗаписейВОчередь.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаАктуальныхЗаписейВОчередь.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаАктуальныхЗаписейВОчередь.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаАктуальныхЗаписейВОчередь.Статус КАК Статус,
		|	ТаблицаАктуальныхЗаписейВОчередь.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаАктуальныхЗаписейВОчередь.Комментарий КАК Комментарий,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаАктуальныхЗаписейВОчередь КАК ТаблицаАктуальныхЗаписейВОчередь
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхКонтрагентов КАК ТаблицаОтработанныхКонтрагентов
		|		ПО ТаблицаАктуальныхЗаписейВОчередь.Контрагент = ТаблицаОтработанныхКонтрагентов.Контрагент
		|			И ТаблицаАктуальныхЗаписейВОчередь.Сотрудник = ТаблицаОтработанныхКонтрагентов.Сотрудник
		|ГДЕ
		|	ТаблицаОтработанныхКонтрагентов.Контрагент ЕСТЬ NULL";		
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)",
			"ТаблицаНаправленийПоДате.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
#КонецОбласти
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события лист ожидания профосмотр
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ЛистОжиданияПрофосмотр(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		Запрос.УстановитьПараметр("ТриггерноеСобытие"	, ДанныеТриггера.ТриггерноеСобытие);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Направление.Период КАК Период,
		|	Направление.Контрагент КАК Контрагент,
		|	Направление.Сотрудник КАК Сотрудник,
		|	Направление.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	Направление.ВидОсмотра КАК ВидОсмотра,
		|	Направление.ДатаЗапланированная КАК ДатаЗапланированная,
		|	Направление.Статус КАК Статус,
		|	Направление.ПредварительнаяЗапись КАК ПредварительнаяЗапись,
		|	Направление.Прием КАК Прием,
		|	Направление.ПричинаНаправления КАК ПричинаНаправления,
		|	Направление.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаНаправленийПоДате
		|ИЗ
		|	РегистрСведений.Профосмотры.СрезПоследних(КОНЕЦПЕРИОДА(&ДатаТриггера, ДЕНЬ), ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Профосмотр)) КАК Направление
		|ГДЕ
		|	НАЧАЛОПЕРИОДА(Направление.ДатаЗапланированная, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНаправленийПоДате.Период КАК Период,
		|	ТаблицаНаправленийПоДате.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийПоДате.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийПоДате.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаНаправленийПоДате.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаНаправленийПоДате.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаНаправленийПоДате.Статус КАК Статус,
		|	ТаблицаНаправленийПоДате.Прием КАК Прием,
		|	ТаблицаНаправленийПоДате.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаНаправленийПоДате.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ТаблицаНаправленийФильтрация
		|ИЗ
		|	ТаблицаНаправленийПоДате КАК ТаблицаНаправленийПоДате
		|ГДЕ
		|	ТаблицаНаправленийПоДате.Сотрудник <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|	И ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)
		|	И ТаблицаНаправленийПоДате.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Профосмотр)
		|	И ТаблицаНаправленийПоДате.ДатаЗапланированная <> ДАТАВРЕМЯ(1, 1, 1)
		|	И ТаблицаНаправленийПоДате.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован), ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.НапомнитьПозже))
		|	И ТаблицаНаправленийПоДате.ПредварительнаяЗапись = ЗНАЧЕНИЕ(Документ.Событие.ПустаяСсылка)
		|	И ТаблицаНаправленийПоДате.Прием <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК Сотрудник,
		|	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия КАК Прием
		|ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
		|ИЗ
		|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаНаправленийФильтрация КАК ТаблицаНаправленийФильтрация
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ЖурналРегистрацииТриггерныхСобытий.Контрагент = ТаблицаНаправленийФильтрация.Контрагент
		|			И ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия = ТаблицаНаправленийФильтрация.Сотрудник
		|			И ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия = ТаблицаНаправленийФильтрация.Прием
		|
		|СГРУППИРОВАТЬ ПО
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия,
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ИсточникСобытия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаНаправленийФильтрация.Период КАК Период,
		|	ТаблицаНаправленийФильтрация.Контрагент КАК Контрагент,
		|	ТаблицаНаправленийФильтрация.Сотрудник КАК ОбъектСобытия,
		|	ТаблицаНаправленийФильтрация.Сотрудник КАК Сотрудник,
		|	ТаблицаНаправленийФильтрация.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаНаправленийФильтрация.ВидОсмотра КАК ВидОсмотра,
		|	ТаблицаНаправленийФильтрация.ДатаЗапланированная КАК ДатаЗапланированная,
		|	ТаблицаНаправленийФильтрация.Статус КАК Статус,
		|	ТаблицаНаправленийФильтрация.Прием КАК ИсточникСобытия,
		|	ТаблицаНаправленийФильтрация.ПричинаНаправления КАК ПричинаНаправления,
		|	ТаблицаНаправленийФильтрация.Комментарий КАК Комментарий,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаНаправленийФильтрация КАК ТаблицаНаправленийФильтрация
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхКонтрагентов КАК ТаблицаОтработанныхКонтрагентов
		|		ПО ТаблицаНаправленийФильтрация.Контрагент = ТаблицаОтработанныхКонтрагентов.Контрагент
		|			И ТаблицаНаправленийФильтрация.Сотрудник = ТаблицаОтработанныхКонтрагентов.Сотрудник
		|			И ТаблицаНаправленийФильтрация.Прием = ТаблицаОтработанныхКонтрагентов.Прием
		|ГДЕ
		|	ТаблицаОтработанныхКонтрагентов.Контрагент ЕСТЬ NULL";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)",
			"ТаблицаНаправленийПоДате.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаНаправленийПоДате.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
#КонецОбласти
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
