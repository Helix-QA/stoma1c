// Функция - Itoolabs event POST
//
Функция ITOOLABSEventsPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.ITOOLABSEvents", УровеньЖурналаРегистрации.Информация, , , 
	"Вызов функции. Переданные параметры: " + Символы.ПС + РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL));
	
	Ответ1С = Новый Структура("Success, Description", Истина, "");
	
	ТелоЗапроса   = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);	
	ПараметрыТела = ПолучитьПараметрыИзСтроки(ТелоЗапроса, "&");	
	
	Попытка
		
		// Проверка Аутоидентификации
		ПОIPТелефонии = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсITOOLABS);
		
		Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда	
			Ответ1С.Success 	= Ложь;
			Ответ1С.Description = "Аутентификация не пройдена (Сервис IP-телефонии не настроен)";
			Возврат ПолучитьHTTPОтветAPI(401, Ответ1С, Истина);
		КонецЕсли;
		
		IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
		
		Токен = ?(ЗначениеЗаполнено(IPТелефонияПараметры.Токен), IPТелефонияПараметры.Токен, IPТелефонияПараметры.Ключ); 
		
		Если Не ПараметрыТела.crm_token = Токен Тогда
			Ответ1С.Success 	= Ложь;
			Ответ1С.Description = "Аутентификация не пройдена";
			Возврат ПолучитьHTTPОтветAPI(401, Ответ1С, Истина);		
		КонецЕсли;
		
		ОбязательныйПараметр = "cmd";						
		Если Не ПараметрыТела.Свойство(ОбязательныйПараметр) Тогда
			
			Ответ1С.Success     = Ложь;					
			Ответ1С.Description = СтрШаблон(НСтр("ru='Отсутствует обязательный параметр %1.'"), ОбязательныйПараметр);
			Возврат ПолучитьHTTPОтветAPI(400, Ответ1С, Истина);
			
		КонецЕсли;      			
		
		Если ПараметрыТела.cmd = "event" Тогда
			// Могут прислать 2 запроса если телефоны работают в группе, второму прилетает тип - пропущенный, будем его игнорировать
			ЭтоДубльЗвонка = Ложь;
			Если ПараметрыТела.type = "CANCELLED" Тогда
				ЭтоДубльЗвонка = ПроверкаITOOLABS(ПОIPТелефонии, ПараметрыТела.callid); 
			КонецЕсли;
			Если НЕ ЭтоДубльЗвонка Тогда
				Ответ1С.Success = IPТелефония.ITOOLABS_СобытиеЗвонок(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);
			КонецЕсли;
		ИначеЕсли ПараметрыТела.cmd = "history" Тогда
			Ответ1С.Success = IPТелефония.ITOOLABS_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);
			//ИначеЕсли ПараметрыТела.cmd = "contact" Тогда
			//	Ответ = IPТелефония.ITOOLABS_ПереадресацияЗвонка(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);					
		КонецЕсли;
		
		Возврат ПолучитьHTTPОтветAPI(200, Ответ1С, Истина);
		
	Исключение
		
		Ответ1С.Success     = Ложь;
		Ответ1С.Description = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		
		ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.ITOOLABSEvents", УровеньЖурналаРегистрации.Ошибка, , , 
		"" + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		
		Возврат ПолучитьHTTPОтветAPI(500, Ответ1С, Истина);
		
	КонецПопытки;
	
КонецФункции

// Функция - Binotel events POST
//
Функция BINOTELEventsPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.BINOTELEvents", УровеньЖурналаРегистрации.Информация, , , 
	"Вызов функции. Переданные параметры: " + Символы.ПС + РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL));
	
	Ответ1С = Новый Структура("Success, Description", Истина, "");
	
	ТелоЗапроса = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);
	
	ПараметрыТела = Новый Структура();
	
	Для Каждого ЭлементМассива Из СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ТелоЗапроса, "&") Цикл
		
		Массив = СтрРазделить(ЭлементМассива, "=");
		РаспарситьСтроку(ПараметрыТела, Массив[0], Массив[1]); 			
		
	КонецЦикла;
	
	Попытка
		
		// Проверка Аутоидентификации
		ПОIPТелефонии = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсBINOTEL);
		
		Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда			
			Ответ1С.Success = Ложь;
			Ответ1С.Description = "Аутентификация не пройдена (Сервис IP-телефонии не настроен)";
			Возврат ПолучитьHTTPОтветAPI(401, Ответ1С, Истина);			
		КонецЕсли;
		
		IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
		
		ОбязательныйПараметр = "generalCallID";							
		Если Не ПараметрыТела.Свойство(ОбязательныйПараметр) И Не (ПараметрыТела.Свойство("callDetails") И ПараметрыТела.callDetails.Свойство(ОбязательныйПараметр)) Тогда
			
			Ответ1С.Success = Ложь;					
			Ответ1С.Description = СтрШаблон(НСтр("ru='Отсутствует обязательный параметр %1.'"), ОбязательныйПараметр);
			Возврат ПолучитьHTTPОтветAPI(400, Ответ1С, Истина);
			
		КонецЕсли;      			
		
		requestType = ?(ПараметрыТела.Свойство("requestType"), ПараметрыТела.requestType, Неопределено);
		Ответ1С.Success = IPТелефония.BINOTEL_СобытиеЗвонок(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);		
		
		disposition = ?(ПараметрыТела.Свойство("disposition"), ПараметрыТела.disposition, Ложь); 
		
		Если requestType = "apiCallCompleted" 
			И Не (disposition = "CONGESTION" 
			ИЛИ disposition = "CHANUNAVAIL"
			ИЛИ disposition = "BUSY"
			ИЛИ disposition = "NOANSWER"
			ИЛИ disposition = "CANCEL") Тогда 
			Ответ1С.Success = IPТелефония.BINOTEL_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыТела, Ответ1С.Description);				
		КонецЕсли;	
		
		Возврат ПолучитьHTTPОтветAPI(?(Ответ1С.Success, 200, 400), Ответ1С, Истина);	
		
	Исключение
		
		Ответ1С.Success = Ложь;
		Ответ1С.Description = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		
		ЗаписьЖурналаРегистрации("Http-сервисы.IPТелефония.BINOTELEvents", УровеньЖурналаРегистрации.Ошибка, , , 
		"" + Ответ1С.Description + Символы.ПС + Запрос.ПолучитьТелоКакСтроку());
		
		Возврат ПолучитьHTTPОтветAPI(500, Ответ1С, Истина);
		
	КонецПопытки;  
	
КонецФункции   

// Функция - ROSTELECOMEvents POST
//
// Параметры:
//  Запрос	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ROSTELECOMEventsPOST(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Ответ1С = Новый Структура("Success, Description", Истина, "");
	
	//АпиКей           = Запрос.ПараметрыURL.Получить("ApiKey");
	ЗаголовкиЗапроса = ПривестиЗаголовкиВНижнийРегистр(Запрос);
	ClientID         = ЗаголовкиЗапроса.Получить("clientid");
	
	ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
	ПараметрыJSON = ПолучитьПараметрыЗапроса(ТелоЗапроса);
	
	Если ПараметрыJSON = Неопределено Тогда
		Возврат ПолучитьHTTPОтветAPI(400, "Ошибка формата JSON: " + ТелоЗапроса);		
	КонецЕсли;
	
	ЭтоДобавлениеРК = ?(СтрНайти(Запрос.ОтносительныйURL, "get_campaign") > 0, Истина, Ложь);
	Попытка
 		
		ПОIPТелефонии = IPТелефония.ОпределитьПодключаемоеОборудование(Перечисления.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикХеликсROSTELECOM);
		
		Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда
			Возврат ПолучитьHTTPОтветAPI(401, "Аутентификация не пройдена (Сервис IP-телефонии не настроен)");
		КонецЕсли;
		                                     
		IPТелефонияПараметры = ПОIPТелефонии.Параметры.Получить();
		Токен				 = ?(ТипЗнч(IPТелефонияПараметры) = Тип("Структура") И IPТелефонияПараметры.Свойство("Код"), IPТелефонияПараметры.Код, Неопределено); 
		
		Если Не ЗначениеЗаполнено(IPТелефонияПараметры) ИЛИ ТипЗнч(IPТелефонияПараметры) <> Тип("Структура") Тогда			
			
			Возврат ПолучитьHTTPОтветAPI(400, "Аутентификация не пройдена (Параметры IP-телефонии не настроены)");			
			
		ИначеЕсли ЭтоДобавлениеРК Тогда
			
			IPТелефония.ROSTELECOM_ДополнитьЗвонокРекламнойКомпанией(ПОIPТелефонии, ПараметрыJSON);
			
			Возврат ПолучитьHTTPОтветAPI(200, "Выполнено успешно");
			
		ИначеЕсли Токен <> ClientID Тогда
			
			Возврат ПолучитьHTTPОтветAPI(401, "Аутентификация не пройдена (Передан неверный токен)");
			
		ИначеЕсли Не ПараметрыJSON.Свойство("state") Тогда
			
			Возврат ПолучитьHTTPОтветAPI(400, "Отсутствует обязательный параметр: state.");
			
		КонецЕсли;
		
 		Ответ1С.Success = IPТелефония.ROSTELECOM_СобытиеЗвонок(ПОIPТелефонии, ПараметрыJSON, IPТелефонияПараметры, Ответ1С.Description);
		
		Если НЕ Ответ1С.Success Тогда
			Возврат ПолучитьHTTPОтветAPI(400, Ответ1С.Description);
		КонецЕсли;
		
		Если НРег(ПараметрыJSON.state) = "end" И ПараметрыJSON.Свойство("is_record") И Булево(ПараметрыJSON.is_record) Тогда
			Ответ1С.Success = IPТелефония.ROSTELECOM_СобытиеЗаписьРазговора(ПОIPТелефонии, ПараметрыJSON, IPТелефонияПараметры, Ответ1С.Description); 								
		КонецЕсли;
		
		Возврат ПолучитьHTTPОтветAPI(200, "Выполнено успешно");
		
	Исключение
		
		Возврат ПолучитьHTTPОтветAPI(500, ОписаниеОшибки());

	КонецПопытки;	

КонецФункции

