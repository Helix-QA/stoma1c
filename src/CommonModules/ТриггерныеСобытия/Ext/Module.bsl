				СообщениеОбОшибке = "Ошибка при обновлении настроек каналов уведомлений триггерного события:" + Символы.ПС + Символы.ПС + ОписаниеОшибки();
				ЗаписьЖурналаРегистрации("РегистрацияТриггерныхСобытий.ОбновлениеНастройкиКаналовУведомлений", УровеньЖурналаРегистрации.Ошибка,
					Метаданные.Справочники.ТриггерныеСобытия, СтрокаТриггер.ТриггерСсылка, СообщениеОбОшибке + Символы.ПС + "Фиксация: " + Строка(ТекущаяДатаСеанса()) + Символы.ПС + "Триггерное событие: " + Строка(СтрокаТриггер.ТриггерСсылка));									
			КонецПопытки;
		КонецЕсли;	
	КонецЦикла;
	
	ЗаданиеНашли = Истина;	
	// Ищем задание по наименованию.
