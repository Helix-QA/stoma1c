		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СобытиеУслуги.Ссылка КАК ПредварительнаяЗапись,
	СобытиеУслуги.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	СобытиеУслуги.Ссылка.Контрагент КАК Контрагент,
	СобытиеУслуги.Ссылка.Статус КАК Статус,
	СобытиеУслуги.Ссылка.ПричинаОтмены КАК ПричинаОтмены,
	СобытиеУслуги.ДатаНачала КАК ВремяНачала,
	СобытиеУслуги.ДатаОкончания КАК ВремяОкончания,
	СобытиеУслуги.Номенклатура КАК Услуга,
	СобытиеУслуги.Сотрудник КАК Врач,
	СобытиеУслуги.Помещение КАК Помещение,
	ВЫБОР
		КОГДА СобытиеУслуги.НомерСтроки = 1
			ТОГДА СобытиеУслуги.НомерСтроки
	КОНЕЦ КАК Количество,
	СобытиеУслуги.Цена КАК Стоимость
ИЗ
	Документ.Событие.Услуги КАК СобытиеУслуги
ГДЕ
	НЕ СобытиеУслуги.Ссылка.ПометкаУдаления
	И СобытиеУслуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	И СобытиеУслуги.Ссылка.Контрагент.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
					И &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА СобытиеУслуги.Ссылка.Дата &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
					И &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА СобытиеУслуги.Ссылка.Дата &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}

УПОРЯДОЧИТЬ ПО
	СобытиеУслуги.ДатаНачала УБЫВ</query>
