КонецПроцедуры

&НаКлиенте
// Процедура - Перед записью
//
// Параметры:
//  Отказ			 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	// Реализация логики Андрея   // Если у карты пустой код, то проверку делать не надо Р. Журавель
	
	Если СокрЛП(Объект.КодКарты) <> "" ИЛИ СокрЛП(Объект.ВнутреннийКодКарты) <> "" Тогда
		
		СтруктураРезультата = ПроверитьНаличиеКодаВСистеме(Объект.Ссылка, Объект.ТипКода, Объект.КодКарты, Объект.ВнутреннийКодКарты);
		Если СтруктураРезультата.ЕстьКодВБазе Тогда
			Отказ = Истина;
			
			ОбъектНазначения = ?(ТипЗнч(СтруктураРезультата.Клиент) = Тип("СправочникСсылка.Контрагенты"), "клиенту", "сотруднику");
			
			Если СтруктураРезультата.Заблокирована = Истина ИЛИ СтруктураРезультата.ПометкаУдаления = Истина Тогда
				ТекстВопроса = СтрШаблон(НСтр("ru = 'Данная карта (%1) назначена другому %2 (%3)
				|Карта заблокирована.
				|Вы хотите разблокировать и назначить ее клиенту (%4)?';
				|en = 'This card (%1) is assigned to another %2 (%3)
				|The card is blocked.
				|You want to unlock and assign it to a client (%4)?'"), 
				СтруктураРезультата.КодКарты, ОбъектНазначения, СтруктураРезультата.ПредставлениеКлиента, Объект.ВладелецКарты);
				
				СтруктураРезультата.Вставить("НовыйВладелец", Объект.ВладелецКарты);
			Иначе
				ТекстВопроса = "Данная карта (" + СтруктураРезультата.КодКарты + ") назначена другому " + ОбъектНазначения + " (" + СтруктураРезультата.ПредставлениеКлиента + "). 
				|Открыть существующую карту?";
				СтруктураРезультата.Вставить("НовыйВладелец", Неопределено);
			КонецЕсли;
			
			ОписаниеОповещенияПослеВопроса = Новый ОписаниеОповещения("ОбработкаРезультатаВопросаОНаличииКартыВСистеме", ЭтаФорма, СтруктураРезультата);
			ПоказатьВопрос(ОписаниеОповещенияПослеВопроса, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , , НСтр("ru='Сообщение пользователю';en='Message to user'"));
		КонецЕсли;
		
		
		Если НЕ Объект.ПометкаУдаления И НЕ Объект.Заблокирована 
			И ТипЗнч(Объект.ВладелецКарты) = Тип("СправочникСсылка.Контрагенты") И Объект.ТипКода = ПредопределенноеЗначение("Перечисление.ВидыКарт.Магнитная") Тогда
			НезаблокированныеКарты = ПолучитьНезаблокированныеКартыКлиента(Объект.ВладелецКарты, Объект.ТипКода, Объект.Ссылка);
			Если НезаблокированныеКарты > 0 И НЕ ЗаданВопросОБлокировкеАктивныхКарт Тогда
				Отказ = Истина;
				ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗаписьюЗавершение", ЭтотОбъект), "Активные карты клиента будут заблокированы. Продолжить?",РежимДиалогаВопрос.ДаНет);	
			КонецЕсли;	
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписьюЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ЗаданВопросОБлокировкеАктивныхКарт = Истина;
		ЭтаФорма.Записать();
		ЭтаФорма.Закрыть();
	Иначе
		ЗаданВопросОБлокировкеАктивныхКарт = Ложь;
	КонецЕсли;

КонецПроцедуры

