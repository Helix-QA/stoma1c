КонецФункции // ПолучитьБлокируемыеРеквизитыОбъекта()

// Процедура - Сопоставить номенклатуру.
//
Процедура СопоставитьНоменклатуру(Номенклатура, Наименование = Неопределено, КодСинхронизации = Неопределено, ТипНоменклатуры = Неопределено)
	
	НоменклатураНайденная = Справочники.Номенклатура.ПустаяСсылка();
	Если НЕ ЗначениеЗаполнено(Наименование) И НЕ ЗначениеЗаполнено(КодСинхронизации) Тогда		
		Номенклатура = НоменклатураНайденная;
	Иначе
		
		Если ЗначениеЗаполнено(КодСинхронизации) Тогда
			
			// поиск по коду синхронизации
			Попытка
				НоменклатураНайденная = Справочники.Номенклатура.НайтиПоРеквизиту("КодСинхронизации", КодСинхронизации);				
			Исключение
				НоменклатураНайденная = Справочники.Номенклатура.ПустаяСсылка();
			КонецПопытки;
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(НоменклатураНайденная) 
			И ЗначениеЗаполнено(Наименование) Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Номенклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	НЕ Номенклатура.ПометкаУдаления
			|	И Номенклатура.Наименование ПОДОБНО &Наименование
			|	И &УсловиеТипНоменклатуры";
			Запрос.УстановитьПараметр("Наименование", Наименование + "%");
			
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеТипНоменклатуры", ?(ЗначениеЗаполнено(ТипНоменклатуры), "Номенклатура.ТипНоменклатуры = &ТипНоменклатуры", ""));
			Если ЗначениеЗаполнено(ТипНоменклатуры) Тогда
				Запрос.УстановитьПараметр("ТипНоменклатуры", ТипНоменклатуры);
			КонецЕсли;
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НоменклатураНайденная = Выборка.Ссылка;
			КонецЦикла;
			
		КонецЕсли;
		
		Номенклатура = НоменклатураНайденная;
		
	КонецЕсли;

КонецПроцедуры

// Процедура - Сопоставить склад.
//
Процедура СопоставитьСклад(СкладЗначение, СкладВходящиеДанные, СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Склады.Ссылка КАК Склад
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	НЕ Склады.ПометкаУдаления
	|	И НЕ Склады.ЭтоГруппа
	|	И Склады.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Склады.Наименование = &Наименование";
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Наименование", СкладВходящиеДанные);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СкладЗначение = Выборка.Склад;
	КонецЦикла;	
	
КонецПроцедуры

