// Функция выполняет поиск контрагентов
//
Функция НайтиКонтрагентаПоСтроке(СтрокаПоиска)
	
	Если СокрЛ(СтрокаПоиска) = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
		Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		                      |	ВложенныйЗапрос.Ссылка КАК Ссылка,
		                      |	МИНИМУМ(ВложенныйЗапрос.Индекс) КАК Индекс,
		                      |	ВложенныйЗапрос.Фамилия КАК Фамилия,
		                      |	ВложенныйЗапрос.Имя КАК Имя,
		                      |	ВложенныйЗапрос.Отчество КАК Отчество,
		                      |	ВложенныйЗапрос.Телефон КАК Телефон
		                      |ИЗ
		                      |	(ВЫБРАТЬ
		                      |		Контрагенты.Ссылка КАК Ссылка,
		                      |		1 КАК Индекс,
		                      |		Контрагенты.Фамилия КАК Фамилия,
		                      |		Контрагенты.Имя КАК Имя,
		                      |		Контрагенты.Отчество КАК Отчество,
		                      |		Контрагенты.Телефон КАК Телефон
		                      |	ИЗ
		                      |		Справочник.Контрагенты КАК Контрагенты
		                      |	ГДЕ
		                      |		Контрагенты.Фамилия ПОДОБНО &Поиск
		                      |		И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		                      |		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		                      |		И НЕ Контрагенты.ПометкаУдаления
		                      |	
		                      |	ОБЪЕДИНИТЬ ВСЕ
		                      |	
		                      |	ВЫБРАТЬ
		                      |		Контрагенты.Ссылка,
		                      |		2,
		                      |		Контрагенты.Фамилия,
		                      |		Контрагенты.Имя,
		                      |		Контрагенты.Отчество,
		                      |		Контрагенты.Телефон
		                      |	ИЗ
		                      |		Справочник.Контрагенты КАК Контрагенты
		                      |	ГДЕ
		                      |		Контрагенты.Имя ПОДОБНО &Поиск
		                      |		И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		                      |		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		                      |		И НЕ Контрагенты.ПометкаУдаления
		                      |	
		                      |	ОБЪЕДИНИТЬ ВСЕ
		                      |	
		                      |	ВЫБРАТЬ
		                      |		Контрагенты.Ссылка,
		                      |		3,
		                      |		Контрагенты.Фамилия,
		                      |		Контрагенты.Имя,
		                      |		Контрагенты.Отчество,
		                      |		Контрагенты.Телефон
		                      |	ИЗ
		                      |		Справочник.Контрагенты КАК Контрагенты
		                      |	ГДЕ
		                      |		Контрагенты.Отчество ПОДОБНО &Поиск
		                      |		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		                      |		И НЕ Контрагенты.ПометкаУдаления
		                      |	
		                      |	ОБЪЕДИНИТЬ ВСЕ
		                      |	
		                      |	ВЫБРАТЬ
		                      |		Контрагенты.Ссылка,
		                      |		4,
		                      |		Контрагенты.Фамилия,
		                      |		Контрагенты.Имя,
		                      |		Контрагенты.Отчество,
		                      |		Контрагенты.Телефон
		                      |	ИЗ
		                      |		Справочник.Контрагенты КАК Контрагенты
		                      |	ГДЕ
		                      |		Контрагенты.Наименование ПОДОБНО &Поиск
		                      |		И Контрагенты.ЭтоГруппа = ЛОЖЬ
		                      |		И НЕ Контрагенты.ПометкаУдаления
		                      |	
		                      |	ОБЪЕДИНИТЬ ВСЕ
		                      |	
		                      |	ВЫБРАТЬ
		                      |		Контрагенты.Ссылка,
		                      |		5,
		                      |		Контрагенты.Фамилия,
		                      |		Контрагенты.Имя,
		                      |		Контрагенты.Отчество,
