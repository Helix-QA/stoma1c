// Процедура - Сопоставить загружаемые данные из внешнего источника.
//
// Параметры:
//  ПараметрыСопоставления	 - 	 - 
//  АдресРезультата			 - 	 - 
//
Процедура СопоставитьЗагружаемыеДанныеИзВнешнегоИсточника(ПараметрыСопоставления, АдресРезультата) Экспорт
	
	ТаблицаСопоставленияДанных	= ПараметрыСопоставления.ТаблицаСопоставленияДанных;
	РазмерТаблицыДанных			= ТаблицаСопоставленияДанных.Количество();
	НастройкиЗагрузкиДанных		= ПараметрыСопоставления.НастройкиЗагрузкиДанных;
	
	ПолноеИмяОбъектаЗаполнения = НастройкиЗагрузкиДанных.ПолноеИмяОбъектаЗаполнения;

	Для каждого СтрокаТаблицыФормы Из ТаблицаСопоставленияДанных Цикл
		
		Если ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.Продажи" Тогда
			
			СопоставитьНоменклатуру(СтрокаТаблицыФормы.Номенклатура, СтрокаТаблицыФормы.НоменклатураНаименование);
				
			ЭтаСтрокаСопоставлена = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура);
			
			Если ЭтаСтрокаСопоставлена Тогда
				// НомерЗуба
				ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьХарактеристикуПоНаименованию(СтрокаТаблицыФормы.Партия, СтрокаТаблицыФормы.Партия_ВходящиеДанные, , СтрокаТаблицыФормы.Номенклатура);
				
			КонецЕсли;
			
			// Контрагент
			СопоставитьКонтрагента(СтрокаТаблицыФормы.Клиент, СтрокаТаблицыФормы.Контрагент, СтрокаТаблицыФормы.Телефон);
			
			// Плательщик
			СопоставитьКонтрагента(СтрокаТаблицыФормы.Плательщик, СтрокаТаблицыФормы.ПлательщикНаименование, СтрокаТаблицыФормы.ТелефонПлательщика);		

			// Сотрудник
			СопоставитьСотрудника(СтрокаТаблицыФормы.Сотрудник, СтрокаТаблицыФормы.Сотрудник_ВходящиеДанные);
			
			// Ассистент
			СопоставитьСотрудника(СтрокаТаблицыФормы.Ассистент, СтрокаТаблицыФормы.Ассистент_ВходящиеДанные);
			
			// Количество
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Количество, СтрокаТаблицыФормы.Количество_ВходящиеДанные, 1);
			
			// НомерЗуба
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьНомерЗуба(СтрокаТаблицыФормы.НомерЗуба, СтрокаТаблицыФормы.НомерЗуба_ВходящиеДанные, Неопределено);
			
			// Сумма
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Сумма, СтрокаТаблицыФормы.Сумма_ВходящиеДанные, 1);
			
			// СтоимостьБезСкидки
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.СтоимостьБезСкидки, СтрокаТаблицыФормы.СтоимостьБезСкидки_ВходящиеДанные, 1);
			
			// Дата продажи 
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.ДатаПродажи, СтрокаТаблицыФормы.ДатаПродажи_ВходящиеДанные);
			
			//// Заполнение Себестоимость 
			// СтрокаТаблицыФормы.Себестоимость = ?(СтрокаТаблицыФормы.Количество <> 0, СтрокаТаблицыФормы.Сумма / СтрокаТаблицыФормы.Количество, СтрокаТаблицыФормы.Сумма);
		
			ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения);
			
		ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.БонусныеСчета" Тогда
			
			// Контрагент
			СопоставитьКонтрагента(СтрокаТаблицыФормы.Клиент, СтрокаТаблицыФормы.Контрагент, СтрокаТаблицыФормы.Телефон, СтрокаТаблицыФормы.КонтрагентКодСинхронизации);
			// Сумма
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Сумма, СтрокаТаблицыФормы.Сумма_ВходящиеДанные, 1);
			
			// ВидБонусногоСчета 
			Если ЗначениеЗаполнено(СтрокаТаблицыФормы.ВидБонусногоСчета_ВходящиеДанные) Тогда
				
				Запрос = Новый Запрос(
				"ВЫБРАТЬ РАЗРЕШЕННЫЕ
				|	ВидыБонусныхСчетов.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник.ВидыБонусныхСчетов КАК ВидыБонусныхСчетов
				|ГДЕ
				|	НЕ ВидыБонусныхСчетов.ПометкаУдаления
				|	И ВидыБонусныхСчетов.Наименование = &Наименование");
				
				Запрос.УстановитьПараметр("Наименование", СтрокаТаблицыФормы.ВидБонусногоСчета_ВходящиеДанные);
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					СтрокаТаблицыФормы.ВидБонусногоСчета = Выборка.Ссылка;
				КонецЦикла;
				
				Если Не ЗначениеЗаполнено(СтрокаТаблицыФормы.ВидБонусногоСчета) Тогда
					
					НовыйВидБС = Справочники.ВидыБонусныхСчетов.СоздатьЭлемент();
					НовыйВидБС.Наименование = СтрокаТаблицыФормы.ВидБонусногоСчета_ВходящиеДанные;
					НовыйВидБС.Записать();
					
					СтрокаТаблицыФормы.ВидБонусногоСчета = НовыйВидБС;
					
				КонецЕсли;
			КонецЕсли;
			
			ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения);
			
		ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.ДенежныеСредстваНаЛицевыхСчетах" Тогда
			
			// Контрагент
			СопоставитьКонтрагента(СтрокаТаблицыФормы.Клиент, СтрокаТаблицыФормы.Контрагент, СтрокаТаблицыФормы.Телефон);
			
			// Сумма
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Сумма, СтрокаТаблицыФормы.Сумма_ВходящиеДанные, 1);
			
			// Основание - вид лицевого счета
			Если ЗначениеЗаполнено(СтрокаТаблицыФормы.Основание_ВходящиеДанные) Тогда
				
				Запрос = Новый Запрос(
				"ВЫБРАТЬ РАЗРЕШЕННЫЕ
				|	ВидыЛицевыхСчетов.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник.ВидыЛицевыхСчетов КАК ВидыЛицевыхСчетов
				|ГДЕ
				|	НЕ ВидыЛицевыхСчетов.ПометкаУдаления
				|	И ВидыЛицевыхСчетов.Наименование ПОДОБНО &Наименование");
				
				Запрос.УстановитьПараметр("Наименование", "%"+СтрокаТаблицыФормы.Основание_ВходящиеДанные+"%");
				Выборка = Запрос.Выполнить().Выбрать();
				
				Пока Выборка.Следующий() Цикл
					СтрокаТаблицыФормы.Основание = Выборка.Ссылка;
				КонецЦикла;
				
				Если Не ЗначениеЗаполнено(СтрокаТаблицыФормы.Основание) Тогда
					
					НовыйВидЛС = Справочники.ВидыЛицевыхСчетов.СоздатьЭлемент();
					НовыйВидЛС.Наименование = СтрокаТаблицыФормы.Основание_ВходящиеДанные;
					НовыйВидЛС.Записать();
					
					СтрокаТаблицыФормы.Основание = НовыйВидЛС.Ссылка;
					
				КонецЕсли;
			КонецЕсли;
			
			ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения);
			

		ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.СерийныеНомераСертификатов" Тогда
			
			// Номенклатура
			СопоставитьНоменклатуру(СтрокаТаблицыФормы.Номенклатура, СтрокаТаблицыФормы.НоменклатураНаименование, СтрокаТаблицыФормы.НоменклатураКодСинхронизации);
			
			Если СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
				СтрокаТаблицыФормы.Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
			КонецЕсли;
			
			// Сумма
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Сумма, СтрокаТаблицыФормы.Сумма_ВходящиеДанные, 1);
			
			//// Даты
			//ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.Дата, СтрокаТаблицыФормы.Дата_ВходящиеДанные);
			//ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.ПакетУслугДатаАктивации, СтрокаТаблицыФормы.ПакетУслугДатаАктивации_ВходящиеДанные);
			//ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВДату(СтрокаТаблицыФормы.ДатаОкончания, СтрокаТаблицыФормы.ДатаОкончания_ВходящиеДанные);
			
			// Характеристика
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.СопоставитьХарактеристику(СтрокаТаблицыФормы.Характеристика, СтрокаТаблицыФормы.Номенклатура,,СтрокаТаблицыФормы.Характеристика_ВходящиеДанные); 
			
			// Контрагент
			СопоставитьКонтрагента(СтрокаТаблицыФормы.Клиент, СтрокаТаблицыФормы.Контрагент, СтрокаТаблицыФормы.Телефон);
			
			// Количество
			ЗагрузкаДанныхИзВнешнегоИсточникаПереопределяемый.ПреобразоватьСтрокуВЧисло(СтрокаТаблицыФормы.Количество, СтрокаТаблицыФормы.Количество_ВходящиеДанные, 1);
			

			Если ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура) Тогда
				
				Если Не ЗначениеЗаполнено(СтрокаТаблицыФормы.Характеристика)
					И ЗначениеЗаполнено(СтрокаТаблицыФормы.Характеристика_ВходящиеДанные) Тогда
										
					НоваяХарактеристика = Справочники.ПартииНоменклатуры.СоздатьЭлемент();
					НоваяХарактеристика.Владелец = СтрокаТаблицыФормы.Номенклатура;
					НоваяХарактеристика.Наименование = СтрокаТаблицыФормы.Характеристика_ВходящиеДанные;
					НоваяХарактеристика.Записать();
					
				КонецЕсли;
				
			КонецЕсли;

			ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения);
			
		КонецЕсли;
		
		ЗагрузкаДанныхИзВнешнегоИсточника.ПрогрессСопоставленияДанных(ТаблицаСопоставленияДанных.Индекс(СтрокаТаблицыФормы), РазмерТаблицыДанных);
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ТаблицаСопоставленияДанных, АдресРезультата);
	
КонецПроцедуры

// Процедура - Проверить корректность данных в строке таблицы.
//
// Параметры:
//  СтрокаТаблицыФормы			 - 	 - 
//  ПолноеИмяОбъектаЗаполнения	 - 	 - 
//
Процедура ПроверитьКорректностьДанныхВСтрокеТаблицы(СтрокаТаблицыФормы, ПолноеИмяОбъектаЗаполнения = "") Экспорт
	
	ИмяСлужебногоПоля = ЗагрузкаДанныхИзВнешнегоИсточника.ИмяСлужебногоПоляЗагрузкаВПриложениеВозможна();
	Если ПустаяСтрока(ПолноеИмяОбъектаЗаполнения) 
		ИЛИ ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.Продажи" Тогда
		
		СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура)
		И (СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас
		ИЛИ СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
		ИЛИ СтрокаТаблицыФормы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат)
		И СтрокаТаблицыФормы.Количество <> 0 И СтрокаТаблицыФормы.Сумма <> 0;
		
	ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.БонусныеСчета" Тогда
		
		СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.ВидБонусногоСчета)
		И ЗначениеЗаполнено(СтрокаТаблицыФормы.Клиент)
		И СтрокаТаблицыФормы.Сумма <> 0;
		
	ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.ДенежныеСредстваНаЛицевыхСчетах" Тогда
		
		СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.Основание)
		И ЗначениеЗаполнено(СтрокаТаблицыФормы.Клиент)
		И СтрокаТаблицыФормы.Сумма <> 0;
		
	ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.ПакетыУслуг" Тогда
		
		СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура)
		И ЗначениеЗаполнено(СтрокаТаблицыФормы.Клиент)
		И ЗначениеЗаполнено(СтрокаТаблицыФормы.ДатаПриобретения);
		
	ИначеЕсли ПолноеИмяОбъектаЗаполнения = "Документ.ВводНачальныхОстатков.ТабличнаяЧасть.СерийныеНомераСертификатов" Тогда
		
		СтрокаТаблицыФормы[ИмяСлужебногоПоля] = ЗначениеЗаполнено(СтрокаТаблицыФормы.Номенклатура) И СтрокаТаблицыФормы.Сумма <> 0;

	КонецЕсли;
	
КонецПроцедуры

// Процедура - Сопоставить контрагента.
//
Процедура СопоставитьКонтрагента(Контрагент, ФИОклиента = Неопределено, Телефонклиента = Неопределено, Кодсинхронизацииклиента = Неопределено)
	
	КлиентНайденный = Справочники.Контрагенты.ПустаяСсылка();
	Если НЕ ЗначениеЗаполнено(ФИОклиента) И НЕ ЗначениеЗаполнено(Телефонклиента) И НЕ ЗначениеЗаполнено(Кодсинхронизацииклиента) Тогда	
		
		Контрагент = КлиентНайденный;
		
	Иначе
			
		Если ЗначениеЗаполнено(КодСинхронизацииКлиента) Тогда
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Контрагенты.Ссылка
			|ИЗ
			|	Справочник.Контрагенты КАК Контрагенты
			|ГДЕ
			|	НЕ Контрагенты.ПометкаУдаления
			|	И НЕ Контрагенты.ЭтоГруппа
			|	И Контрагенты.КодСинхронизации = &ЗначениеПоиска");
			
			Запрос.УстановитьПараметр("ЗначениеПоиска", КодСинхронизацииКлиента);
			Выборка = Запрос.Выполнить().Выбрать();
			
			Пока Выборка.Следующий() Цикл
				КлиентНайденный = Выборка.Ссылка;
			КонецЦикла;
			
		КонецЕсли;
		
		// Поиск по телефону
		Если Не ЗначениеЗаполнено(КлиентНайденный) И ЗначениеЗаполнено(ТелефонКлиента) Тогда 
			ТелефонКлиентаДляПоиска = СокрЛП(ТелефонКлиента);
			ТелефонКлиентаДляПоиска = ?(СтрНайти(ТелефонКлиентаДляПоиска, "+") > 0, СтрЗаменить(ТелефонКлиентаДляПоиска, "+", ""), ТелефонКлиентаДляПоиска);
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
			|ГДЕ
			|	КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
			|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
			|	И (КонтрагентыКонтактнаяИнформация.НомерТелефона = &Телефон
			|			ИЛИ (ВЫРАЗИТЬ(КонтрагентыКонтактнаяИнформация.Представление КАК СТРОКА(100))) = &Телефон
			|			ИЛИ КонтрагентыКонтактнаяИнформация.НомерТелефонаБезКодаСтраны = &Телефон)
			|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления
			|	И НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ЭтоГруппа";
			
			Запрос.УстановитьПараметр("Телефон", ТелефонКлиентаДляПоиска);
			Выборка = Запрос.Выполнить().Выбрать();
			
			Пока Выборка.Следующий() Цикл
				КлиентНайденный = Выборка.Ссылка;
			КонецЦикла;
				
		КонецЕсли;

		// Поиск по наименованию
		Если Не ЗначениеЗаполнено(КлиентНайденный) И ЗначениеЗаполнено(ФИОклиента) Тогда  
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Контрагенты.Ссылка
			|ИЗ
			|	Справочник.Контрагенты КАК Контрагенты
			|ГДЕ
			|	НЕ Контрагенты.ПометкаУдаления
			|	И НЕ Контрагенты.ЭтоГруппа
			|	И Контрагенты.Наименование = &ЗначениеПоиска");
			
			Запрос.УстановитьПараметр("ЗначениеПоиска", ФИОклиента);
			Выборка = Запрос.Выполнить().Выбрать();
			
			Пока Выборка.Следующий() Цикл
				КлиентНайденный = Выборка.Ссылка;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Контрагент = КлиентНайденный;
	
КонецПроцедуры

// Процедура - Сопоставить сотрудника.
//
Процедура СопоставитьСотрудника(Сотрудник, Наименование)
	
	СотрудникНайденный = Справочники.Сотрудники.ПустаяСсылка();
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		Сотрудник = СотрудникНайденный;
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	Сотрудники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	НЕ Сотрудники.ПометкаУдаления
		|	И Сотрудники.Наименование = &Наименование";
		Запрос.УстановитьПараметр("Наименование", Наименование);
		
		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			СотрудникНайденный = Выборка.Ссылка;
		КонецЦикла;
		
		Сотрудник = СотрудникНайденный;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Сопоставить номенклатуру.
//
Процедура СопоставитьНоменклатуру(Номенклатура, Наименование = Неопределено, КодСинхронизации = Неопределено)
	
	НоменклатураНайденная = Справочники.Номенклатура.ПустаяСсылка();
	Если НЕ ЗначениеЗаполнено(Наименование) И НЕ ЗначениеЗаполнено(КодСинхронизации) Тогда		
		Номенклатура = НоменклатураНайденная;
	Иначе
		
		Если ЗначениеЗаполнено(КодСинхронизации) Тогда
			
			// поиск по коду синхронизации
			Попытка
				НоменклатураНайденная = Справочники.Номенклатура.НайтиПоРеквизиту("КодСинхронизации", КодСинхронизации);				
			Исключение
				НоменклатураНайденная = Справочники.Номенклатура.ПустаяСсылка();
			КонецПопытки;
			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(НоменклатураНайденная) 
			И ЗначениеЗаполнено(Наименование) Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			|	Номенклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	НЕ Номенклатура.ПометкаУдаления
			|	И Номенклатура.Наименование ПОДОБНО &Наименование";
			Запрос.УстановитьПараметр("Наименование","%" + Наименование + "%");
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				НоменклатураНайденная = Выборка.Ссылка;
			КонецЕсли;
			
		КонецЕсли;
		
		Номенклатура = НоменклатураНайденная;
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли