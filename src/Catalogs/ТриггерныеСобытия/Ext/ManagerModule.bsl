	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	//Если ОбязательноеЗаполнение Тогда 
	//	КоллекцияПараметровВариантаУсловияТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий, ИспользуетсяОтборПоВидуСделки, ОбязательноеЗаполнениеСегментаУслуг", ВариантУсловияТриггерногоСобытия, Истина, ОбязательноеЗаполнение));	
	//Иначе 
		КоллекцияПараметровВариантаУсловияТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий, ИспользуетсяОтборПоВидуБонусногоСчета", ВариантУсловияТриггерногоСобытия, Истина));	
	//КонецЕсли;
	
	Возврат НЕ КоллекцияПараметровВариантаУсловияТриггерныхСобытий.Количество() = 0;
	
КонецФункции

// Процедура - Сформировать описание действия
//
// Параметры:
//  СтрокаДействия	 - 	 - 
//
Процедура СформироватьОписаниеДействия(СтрокаДействия) Экспорт 
	
	Если СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЗадачаМенеджеру Тогда 
		Если СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.ВрачПриема Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Поставить задачу врачу'; en = 'Set a task to the doctor'");
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Поставить задачу куратору пациента'; en = 'Set a task for the main sales Manager'");			
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Поставить задачу сотруднику'; en = 'Assign a task to an employee'");
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.СегментСотрудников Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Поставить задачу сегменту сотрудников'; en = 'Assign a task to a segment of employees'");;						
		Иначе 
			СтрокаДействия.Описание = Нстр("ru = 'Поставить задачу'; en = 'Set the task'");			
		КонецЕсли;
	ИначеЕсли СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение Тогда
		Если СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.КонтрагентСобытия Тогда 
			СтрокаДействия.Описание = Нстр("ru = 'Отправить пациенту сообщение'; en = 'Send a message to the client'");
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.ВрачПриема Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Отправить врачу сообщение'; en = 'Send a message to the coach'");
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Отправить куратору пациента сообщение'; en = 'Send a message to the main sales Manager'");			
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Отправить сотруднику сообщение'; en = 'Send a message to an employee'");			
		Иначе 
			СтрокаДействия.Описание = Нстр("ru = 'Отправить сообщение'; en = 'Send message'");			
		КонецЕсли;
		СпособыОтправки = Новый Массив;
		Если СтрокаДействия.ОтправкаPush Тогда 
			СпособыОтправки.Добавить("Push");
		КонецЕсли;
		Если СтрокаДействия.ОтправкаPushWallet Тогда 
			СпособыОтправки.Добавить("Push(Wallet)");
		КонецЕсли;	
		Если СтрокаДействия.ОтправкаMessenger Тогда 
			СпособыОтправки.Добавить(Нстр("ru = 'Мессенджер'; en = 'Messenger'"));
		КонецЕсли;	
		Если СтрокаДействия.ОтправкаSMS Тогда 
			СпособыОтправки.Добавить("SMS");
		КонецЕсли;	
		Если СпособыОтправки.Количество() > 0 Тогда 
			СтрокаДействия.Описание = СтрокаДействия.Описание + " (" + СтрСоединить(СпособыОтправки, ", ") + ")";
		КонецЕсли;	
	ИначеЕсли СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ЭлектронноеПисьмо Тогда
		Если СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.КонтрагентСобытия Тогда 
			СтрокаДействия.Описание = Нстр("ru = 'Отправить пациенту электронное письмо'; en = 'Send an email to the client'");
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.ВрачПриема Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Отправить врачу электронное письмо'; en = 'Send an email to the coach'");
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Отправить куратору пациента электронное письмо'; en = 'Send an email to the main sales Manager'");			
		ИначеЕсли СтрокаДействия.ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник Тогда
			СтрокаДействия.Описание = Нстр("ru = 'Отправить сотруднику электронное письмо'; en = 'Send an email to an employee'");			
		Иначе 
			СтрокаДействия.Описание = Нстр("ru = 'Отправить электронное письмо'; en = 'Send an email'");			
		КонецЕсли;
	ИначеЕсли СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ПовыситьЭтапСделки Тогда
		Если ЗначениеЗаполнено(СтрокаДействия.ЭтапСделки) Тогда 
			СтрокаДействия.Описание = СтрШаблон(Нстр("ru = 'Повысить этап сделки до: ""%1""'; en = 'Increase the transaction stage to: ""%1""'"), СокрЛП(Строка(СтрокаДействия.ЭтапСделки))); 
		Иначе 
			СтрокаДействия.Описание = Нстр("ru = 'Повысить этап сделки'; en = 'To increase the stage of the transaction'"); 
		КонецЕсли;
	ИначеЕсли СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.АктивироватьЧатБота Тогда
		Если ЗначениеЗаполнено(СтрокаДействия.СценарийЧатБота) Тогда 
			СтрокаДействия.Описание = СтрШаблон(Нстр("ru = 'Запустить сценарий: ""%1""'; en = 'Run the script: ""%1""'"), СокрЛП(Строка(СтрокаДействия.СценарийЧатБота)));
		Иначе 	
			СтрокаДействия.Описание = Нстр("ru = 'Запустить сценарий диалога чат-бота'; en = 'Run the chatbot dialog script'");
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

// Функция - Триггерное событие активно
//
// Параметры:
//  ВариантУсловияТриггерногоСобытия - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ТриггерноеСобытиеАктивно(ВариантУсловияТриггерногоСобытия) Экспорт 
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("УсловиеСобытия", ВариантУсловияТриггерногоСобытия);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТриггерныеСобытия.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
	|ГДЕ
	|	ТриггерныеСобытия.ПометкаУдаления = ЛОЖЬ
	|	И ТриггерныеСобытия.ЭтоГруппа = ЛОЖЬ
	|	И ТриггерныеСобытия.Активно = ИСТИНА
	|	И ТриггерныеСобытия.УсловиеСобытия = &УсловиеСобытия";
	
	Возврат НЕ Запрос.Выполнить().Пустой();	
	
КонецФункции

// Функция - Инициализировать триггерное событие
//
// Параметры:
//  ПараметрыТриггерногоСобытия				 - 	 - 
//  АнализироватьИмющиесяСогласноПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьТриггерноеСобытие(ПараметрыТриггерногоСобытия, АнализироватьИмющиесяСогласноПараметров = Ложь, ТаблицаСервисовSMS = Неопределено, ИскатьПоНаименованию = Ложь) Экспорт
	
	ТриггерноеСобытие = Неопределено;
	
	Если НЕ ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыТриггерногоСобытия, "УсловиеСобытия", Неопределено))
		ИЛИ НЕ ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыТриггерногоСобытия, "МоментСобытия", Неопределено))
		ИЛИ НЕ ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыТриггерногоСобытия, "ПериодСобытия", Неопределено))
		ИЛИ НЕ ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыТриггерногоСобытия, "ПериодСобытияВид", Неопределено))
		ИЛИ НЕ ЗначениеЗаполнено(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыТриггерногоСобытия, "ПараметрыДействия", Неопределено)) Тогда 
		
		Возврат ТриггерноеСобытие;
	КонецЕсли;	
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Если АнализироватьИмющиесяСогласноПараметров Тогда 
		ТриггерноеСобытие = ПолучитьТриггерноеСобытиеСогласноПараметров(ПараметрыТриггерногоСобытия, , ИскатьПоНаименованию);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТриггерноеСобытие) Тогда 
		Возврат ТриггерноеСобытие;
	КонецЕсли;
	
	Попытка
		// Генерируем триггер
		ТриггерноеСобытие_Объект			= СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(ТриггерноеСобытие_Объект, ПараметрыТриггерногоСобытия);
		ТриггерноеСобытие_Объект.Наименование = ?(ЗначениеЗаполнено(ТриггерноеСобытие_Объект.Наименование), ТриггерноеСобытие_Объект.Наименование, Строка(ПараметрыТриггерногоСобытия.УсловиеСобытия));
		СписокОписанийТриггеров 								= ПолучитьОписанияТриггеров();
		ЭлементСпискаОписаниеУсловия 							= СписокОписанийТриггеров.НайтиПоЗначению(ПараметрыТриггерногоСобытия.УсловиеСобытия);
		Если НЕ ЭлементСпискаОписаниеУсловия = Неопределено Тогда 
			ТриггерноеСобытие_Объект.Описание 					= ЭлементСпискаОписаниеУсловия.Представление;
		КонецЕсли;
		
		СтрокаДействия 											= ТриггерноеСобытие_Объект.Действия.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДействия, ПараметрыТриггерногоСобытия.ПараметрыДействия);
		СтрокаДействия.ИдентификаторДействия 					= Новый УникальныйИдентификатор();
		СтрокаДействия.Использование 							= Истина;
		
		Если СтрокаДействия.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение
			И ЗначениеЗаполнено(ТаблицаСервисовSMS) Тогда 
			// Актуализируем настройки каналов уведомлений
			Для Каждого СтрокаТаблицаСервисовSMS Из ТаблицаСервисовSMS Цикл 
				СтрокаНастройкиКаналовУведомления									= ТриггерноеСобытие_Объект.НастройкиКаналовУведомлений.Добавить();
				СтрокаНастройкиКаналовУведомления.ИдентификаторДействия 			= СтрокаДействия.ИдентификаторДействия;
				СтрокаНастройкиКаналовУведомления.СтруктурнаяЕдиница 				= СтрокаТаблицаСервисовSMS.СтруктурнаяЕдиница;
				СтрокаНастройкиКаналовУведомления.ОтправкаPushWallet 				= СтрокаТаблицаСервисовSMS.ОтправкаPushWallet;
				СтрокаНастройкиКаналовУведомления.ОтправкаMessenger 				= СтрокаТаблицаСервисовSMS.ОтправкаMessenger;
				СтрокаНастройкиКаналовУведомления.АккаунтВнешнейСистемы     		= СтрокаТаблицаСервисовSMS.АккаунтВнешнейСистемы;
				СтрокаНастройкиКаналовУведомления.ОтправкаSMS 						= ЗначениеЗаполнено(СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS);
				СтрокаНастройкиКаналовУведомления.АккаунтСервисаРассылкиSMS 		= СтрокаТаблицаСервисовSMS.АккаунтСервисаРассылкиSMS;
			КонецЦикла;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ТриггерноеСобытие_Объект.Код) Тогда 
			ТриггерноеСобытие_Объект.УстановитьНовыйКод();
		КонецЕсли;
		// Сохраняем триггер
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ТриггерноеСобытие_Объект);							
		Возврат ТриггерноеСобытие_Объект.Ссылка;
	Исключение
		МетаданныеСправочника 				= Метаданные.Справочники.ТриггерныеСобытия;		
		ШаблонКомментария = НСтр("ru = 'Не удалось инициализировать триггерное событие ""%1"" (%2) 
		|по причине: %3'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																			, ТриггерноеСобытие_Объект.Наименование
																			, Строка(ПараметрыТриггерногоСобытия.УсловиеСобытия)
																			, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации()
								, УровеньЖурналаРегистрации.Предупреждение
								, МетаданныеСправочника
								,
								, Комментарий);
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

// Функция - Получить триггерное событие согласно параметров
//
// Параметры:
//  ПараметрыТриггерногоСобытия	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТриггерноеСобытиеСогласноПараметров(ПараметрыТриггерногоСобытия, ТолькоАктивные = Ложь, ИскатьПоНаименованию = Ложь)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТриггерныеСобытия.Ссылка КАК ТриггерноеСобытие
	|ИЗ
	|	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
	|ГДЕ
	|	ТриггерныеСобытия.ПометкаУдаления = ЛОЖЬ
	|	И ТриггерныеСобытия.ЭтоГруппа = ЛОЖЬ";
	
	МетаданныеТриггерныеСобытия = Метаданные.Справочники.ТриггерныеСобытия;
	Для Каждого Параметр Из ПараметрыТриггерногоСобытия Цикл 
		Если Параметр.Ключ = "ПараметрыДействия" Тогда 
			Продолжить;
		КонецЕсли;
		Если Параметр.Ключ = "Активно" Тогда
			Если НЕ ТолькоАктивные Тогда 
				Продолжить;
			КонецЕсли;	
		КонецЕсли;
		Если Параметр.Ключ = "СегментУслуг" ИЛИ Параметр.Ключ = "ВремяСобытия" Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ МетаданныеТриггерныеСобытия.Реквизиты.Найти(Параметр.Ключ) = Неопределено Тогда 
			Запрос.Текст = Запрос.Текст + "
			|	И ТриггерныеСобытия." + Параметр.Ключ + " = &" + Параметр.Ключ;
			Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
		КонецЕсли;
		Если ИскатьПоНаименованию И Параметр.Ключ = "Наименование" Тогда 
			Запрос.Текст = Запрос.Текст + "
			|	И ТриггерныеСобытия." + Параметр.Ключ + " = &" + Параметр.Ключ;
			Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
		КонецЕсли;			
	КонецЦикла;
	
	МассивИмеющихсяТриггерныхСобытий = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ТриггерноеСобытие");
	Если НЕ ЗначениеЗаполнено(МассивИмеющихсяТриггерныхСобытий) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыДействия = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыТриггерногоСобытия, "ПараметрыДействия", Неопределено);
	Если НЕ ЗначениеЗаполнено(ПараметрыДействия) Тогда 
		Возврат МассивИмеющихсяТриггерныхСобытий[0];
	КонецЕсли;	
	
	ТриггерноеСобытие = Неопределено;
	ПараметрыПоискаДействия = Новый Структура(Новый ФиксированнаяСтруктура(ПараметрыТриггерногоСобытия.ПараметрыДействия));
	Если ПараметрыПоискаДействия.Свойство("ШаблонСообщения") Тогда 
		ПараметрыПоискаДействия.Удалить("ШаблонСообщения");
	КонецЕсли;
	Если ПараметрыПоискаДействия.Свойство("Описание") Тогда 
		ПараметрыПоискаДействия.Удалить("Описание");
	КонецЕсли;		
	Для Каждого ТриггерноеСобытиеСсылка Из МассивИмеющихсяТриггерныхСобытий Цикл 
		Если ТриггерноеСобытиеСсылка.Действия.НайтиСтроки(ПараметрыПоискаДействия).Количество() <> 0 Тогда 
			ТриггерноеСобытие = ТриггерноеСобытиеСсылка;
		    Прервать;
		КонецЕсли;		
	КонецЦикла;
	
	Возврат ТриггерноеСобытие;
	
КонецФункции

// Процедура - Инициализировать триггерное событие лицевой счет взнос
//
