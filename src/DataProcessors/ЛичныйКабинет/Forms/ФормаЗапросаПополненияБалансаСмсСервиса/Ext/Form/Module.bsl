
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("СервисSMS") Тогда
		ЭтотОбъект.СервисSMS = Параметры.СервисSMS;
	КонецЕсли;
	
	Если Параметры.Свойство("ДанныеПополнения")
		И ЗначениеЗаполнено(Параметры.ДанныеПополнения) Тогда 
		
		Параметры.ДанныеПополнения.Свойство("ПредлагаемаяСумма"        , ЭтотОбъект.ПредлагаемаяСумма);
		Параметры.ДанныеПополнения.Свойство("СуммаПредыдущегоПоплнения", ЭтотОбъект.СуммаПрошлогоПополнения);
		Параметры.ДанныеПополнения.Свойство("ЭлектроннаяПочта"         , ЭтотОбъект.АдресЭлектроннойПочты);
		Параметры.ДанныеПополнения.Свойство("ТекущийБаланс"            , ЭтотОбъект.ТекущийБаланс);
		Параметры.ДанныеПополнения.Свойство("МинимальныйБаланс"        , ЭтотОбъект.МинимальныйБаланс);
		
		Элементы.Заголовок.Заголовок = "Баланс вашего смс счета приближается к нулю и на текущий момент составляет " + ЭтотОбъект.ТекущийБаланс + " рублей.";		
				
	Иначе
		
		АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
		
		ПараметрыЗапроса = Новый Структура("НеКонтролироватьДатаПоследнегоСчета", Истина);
		ЛичныйКабинет.ПроверитьБалансаСмсСервисаДлительнаяОперация(ПараметрыЗапроса, АдресРезультата, ЭтотОбъект.СервисSMS);
		
		ПараметрыПополнения = ПолучитьИзВременногоХранилища(АдресРезультата);
		
		Если ЗначениеЗаполнено(ПараметрыПополнения) Тогда
			
			Если ПараметрыПополнения.Свойство("КодОшибки") Тогда
				
				Если ПараметрыПополнения.КодОшибки = 1091 Тогда 
					
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не существует договор на стороне сервиса Helix Sms.'"));	
				Иначе 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Не удалось обратиться к сервису Helix Sms.'"));	
				КонецЕсли;
				
				Отказ = Истина;
				
			КонецЕсли;
			
			ПараметрыПополнения.Свойство("recommendable_payment" , ЭтотОбъект.ПредлагаемаяСумма);
			ПараметрыПополнения.Свойство("last_payment"          , ЭтотОбъект.СуммаПрошлогоПополнения);
			ПараметрыПополнения.Свойство("email"                 , ЭтотОбъект.АдресЭлектроннойПочты);
			ПараметрыПополнения.Свойство("ТекущийБаланс"         , ЭтотОбъект.ТекущийБаланс);
			ПараметрыПополнения.Свойство("min_balance"           , ЭтотОбъект.МинимальныйБаланс);
			
		КонецЕсли;
		
		Элементы.Заголовок.Заголовок = "Баланс вашего смс счета составляет " + ЭтотОбъект.ТекущийБаланс + " рублей.";		
		
	КонецЕсли;
	
	Элементы.ИзменитьМинимальныйБаланс.Заголовок = Строка(ЭтотОбъект.МинимальныйБаланс) + " рублей.";
	
	ЭтотОбъект.МинимальныйБалансПред = ЭтотОбъект.МинимальныйБаланс; 
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.СуммаПрошлогоПополнения) Тогда
		
		Элементы.ГруппаСуммаПрошлогоСчета.Видимость = Ложь;
		ЭтотОбъект.СуммаПополнения                  = ЭтотОбъект.ПредлагаемаяСумма;
		
	КонецЕсли;
	
	Элементы.РекомендуемаяСумма.Заголовок  = "" + ЭтотОбъект.ПредлагаемаяСумма + " рублей."; 
	Элементы.КакВПрошлыйРаз.Заголовок      = "" + ЭтотОбъект.СуммаПрошлогоПополнения + " рублей.";	
	Элементы.ГруппаЗапросСчета.Видимость   = Истина;
	Элементы.ГруппаПодтверждения.Видимость = Ложь;	
	Элементы.ПопробоватьСнова.Видимость    = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура - Изменить минимальный баланс
//
// Параметры:
//  Элемент				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ИзменитьМинимальныйБаланс(Элемент, СтандартнаяОбработка)
	
	Элементы.МинимальныйБаланс.Видимость         = Истина;	
	Элементы.ИзменитьМинимальныйБаланс.Видимость = Ложь;
		
КонецПроцедуры

&НаКлиенте
// Процедура - Минимальный баланс при изменении
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура МинимальныйБалансПриИзменении(Элемент)
	
	Элементы.МинимальныйБаланс.Видимость         = Ложь;	
	Элементы.ИзменитьМинимальныйБаланс.Видимость = Истина;

	МинимальныйБалансПриИзмененииСервер();
		
КонецПроцедуры

&НаСервере
// Процедура - Минимальный баланс при изменении сервер
//
Процедура МинимальныйБалансПриИзмененииСервер()
		
	Результат = ЛичныйКабинет.ИзменитьЗначениеКритическогоБалансаСмсСервиса(
	?(ЗначениеЗаполнено(ЭтотОбъект.СервисSMS), ЭтотОбъект.СервисSMS, СервисSMSРассылкиПоУмолчанию()),
	ЭтотОбъект.МинимальныйБаланс);
	
	Если Результат <> Неопределено
		И Результат.ВыполненоУспешно = Истина Тогда
		
		Элементы.ИзменитьМинимальныйБаланс.ЦветТекста        = WebЦвета.ЗеленыйЛес;	
		Элементы.ИзменитьМинимальныйБаланс.Заголовок         = Строка(ЭтотОбъект.МинимальныйБаланс) + " рублей. Изменен";
		ЭтаФорма.Команды.ИзменитьМинимальныйБаланс.Подсказка = "Изменить минимальный баланс"; 
		ЭтотОбъект.МинимальныйБалансПред                     = ЭтотОбъект.МинимальныйБаланс;
		
	Иначе
		
		ЭтотОбъект.МинимальныйБаланс                         = ЭтотОбъект.МинимальныйБалансПред;
		Элементы.ИзменитьМинимальныйБаланс.ЦветТекста        = WebЦвета.Красный;	
		Элементы.ИзменитьМинимальныйБаланс.Заголовок         = Строка(ЭтотОбъект.МинимальныйБаланс) + " рублей. Ошибка изменения";
		ЭтаФорма.Команды.ИзменитьМинимальныйБаланс.Подсказка = Результат.ОписаниеОшибки;	
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Выставить счет
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВыставитьСчет(Команда)
	
	ОписаниеОшибки = Неопределено;
	Результат      = Неопределено;
		
	Результат = ЛичныйКабинет.ВыставитьСчетНаПополнениеСмсСервиса(
	?(ЗначениеЗаполнено(ЭтотОбъект.СервисSMS), ЭтотОбъект.СервисSMS, СервисSMSРассылкиПоУмолчанию()),
	ЭтотОбъект.СуммаПополнения, 
	ЭтотОбъект.АдресЭлектроннойПочты);
		
	Элементы.ГруппаЗапросСчета.Видимость   = Ложь;
	Элементы.ГруппаПодтверждения.Видимость = Истина;
	
	Если Результат <> Неопределено
		И Результат.ВыполненоУспешно = Истина Тогда
		
		ЭтотОбъект.СтатусОтправки          = "Счет отправлен";
		Элементы.СтатусОтправки.ЦветТекста = WebЦвета.ЗеленыйЛес;
        ЗаписатьДатуВыставленияСчета();
		
		Оповестить("СозданСчетНаПополнениеСмсСервиса");
		
	Иначе
		
		ЭтотОбъект.СтатусОтправки           = Результат.ОписаниеОшибки;
		Элементы.СтатусОтправки.ЦветТекста  = WebЦвета.Красный;
		Элементы.ПопробоватьСнова.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Установить рекомендуемую сумму
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура УстановитьРекомендуемуюСумму(Команда)
	
	ЭтотОбъект.СуммаПополнения = ЭтотОбъект.ПредлагаемаяСумма;
	
КонецПроцедуры

// Процедура - Установить сумма прошлого взноса
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура УстановитьСуммаПрошлогоВзноса(Команда)
	
	ЭтотОбъект.СуммаПополнения = ЭтотОбъект.СуммаПрошлогоПополнения;

КонецПроцедуры

// Процедура - Попробовать снова
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ПопробоватьСнова(Команда)
	   	
	Элементы.ГруппаЗапросСчета.Видимость  = Истина;
	Элементы.ГруппаПодтверждения.Видимость = Ложь;
	
	Элементы.ПопробоватьСнова.Видимость = Ложь;

КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Сервис SMSРассылки по умолчанию
// 
// Возвращаемое значение:
//   - 
//
Функция СервисSMSРассылкиПоУмолчанию()
	
	Возврат Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	
КонецФункции

&НаСервереБезКонтекста
// Процедура - Записать дату выставления счета
//
Процедура ЗаписатьДатуВыставленияСчета()
	
	ДанныеАнкеты = ЛичныйКабинет.ПолучитьДанныеРегистрационнойАнкеты();
	Если ДанныеАнкеты = Неопределено Тогда
		ДанныеАнкеты = ЛичныйКабинет.ПолучитьПустуюСтруктуруДанныхАнкетыДляХраненияНаКлиенте();
	КонецЕсли;
	
	Если ДанныеАнкеты.Свойство("ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса") = Ложь Тогда
		ДанныеАнкеты.Вставить("ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса", ТекущаяДатаСеанса());
	Иначе
		ДанныеАнкеты.ДатаПоследнейВыпискиСчетаПоплненияСмсБаланса = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ЛичныйКабинет.ЗаписатьДанныеРегистрационнойАнкеты(ДанныеАнкеты);
	
КонецПроцедуры

#КонецОбласти
