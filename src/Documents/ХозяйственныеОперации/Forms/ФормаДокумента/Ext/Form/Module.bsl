 
#Область ОбработчикиСобытийЭлементовШапкиФормы 
 
&НаКлиенте
// Обработчик при изменении счета Дт
//
Процедура ДвиженияСчетДтПриИзменении(Элемент)	
	
	ТекущиеДанные   = Элементы.Операции.ТекущиеДанные;
	ОграничениеТипа = ПолучитьОграничениеПоТипу(ТекущиеДанные.СчетДт,0);
	Если ОграничениеТипа = Неопределено Тогда
		ТекущиеДанные.СубконтоДт1            = Неопределено;
		ТекущиеДанные.БлокироватьСубконтоДт1 = Истина;
	Иначе
		ТекущиеДанные.БлокироватьСубконтоДт1 = Ложь;
		Если НЕ ОграничениеТипа.СодержитТип(ТипЗнч(ТекущиеДанные.СубконтоДт1)) Тогда
			ТекущиеДанные.СубконтоДт1 = Неопределено;
		КонецЕсли;
	КонецЕсли;	 		 
	
	ОграничениеТипа = ПолучитьОграничениеПоТипу(ТекущиеДанные.СчетДт,1);
	Если ОграничениеТипа = Неопределено Тогда
		ТекущиеДанные.СубконтоДт2            = Неопределено;
		ТекущиеДанные.БлокироватьСубконтоДт2 = Истина;
	Иначе
		ТекущиеДанные.БлокироватьСубконтоДт2 = Ложь;
		Если НЕ ОграничениеТипа.СодержитТип(ТипЗнч(ТекущиеДанные.СубконтоДт2)) Тогда
			ТекущиеДанные.СубконтоДт2 = Неопределено;
		КонецЕсли;
	КонецЕсли;	 
	
	Если ЗначениеЗаполнено(ТекущиеДанные.Количество) 
		И ТекущиеДанные.СчетДт <> ПредопределенноеЗначение("ПланСчетов.Управленческий.Запасы")
		И ТекущиеДанные.СчетКт <> ПредопределенноеЗначение("ПланСчетов.Управленческий.Запасы") Тогда
		ТекущиеДанные.Количество = 0;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Обработчик начала выбора значения субконто Дт1
//
Процедура ДвиженияСубконтоДт1НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекущиеДанные     = Элементы.Операции.ТекущиеДанные;
	ОграничениеТипа   = ПолучитьОграничениеПоТипу(ТекущиеДанные.СчетДт,0);
	Если ОграничениеТипа <> Неопределено Тогда
		Элемент.ОграничениеТипа = ОграничениеТипа;
	Иначе
		Элемент.ОграничениеТипа              = Новый ОписаниеТипов;
		ТекущиеДанные.БлокироватьСубконтоДт1 = Истина;
		СтандартнаяОбработка                 = Ложь;
	КонецЕсли;
КонецПроцедуры

