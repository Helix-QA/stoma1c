// Процедура - Выполнить переход на триггерную систему событий
//
Процедура ВыполнитьПереходНаТриггернуюСистемуСобытий() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Отказ 				= Ложь;
	
	// Создание сегментов для триггерных событий
	ТаблицаСегментов 	= Неопределено;
	ИнициализироватьСегментыТриггеров(ТаблицаСегментов, Отказ);
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;	
	
	ТаблицаТриггерныхСобытий = Неопределено;
	ТриггерКонтроляРассрочек = Неопределено;

	// Создание триггерных событий
	ГенерацияТриггерныхСобытий(ТаблицаСегментов, ТаблицаТриггерныхСобытий, ТриггерКонтроляРассрочек, Отказ);
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;	
	
	АктуализироватьВзаимодействияПоПродлениюЧленствПакетовУслуг(ТаблицаТриггерныхСобытий);
	
	АктуализироватьВзаимодействияПоПродажеДополнительныхУслуг(ТаблицаТриггерныхСобытий);
	
	АктуализироватьВзаимодействияПоКонтролюПлатежейПоРассрочкам(ТриггерКонтроляРассрочек);	
	
	АктуализироватьВзаимодействияПоПродажеЧленства();
	
	АктуализироватьВзаимодействияПростые();
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Процедура - Инициализировать сегменты триггеров
//
// Параметры:
//  ТаблицаСегментов - 	 - 
//  Отказ			 - 	 - 
//
Процедура ИнициализироватьСегментыТриггеров(ТаблицаСегментов, Отказ = Ложь) Экспорт 

	// Создаем таблицу сегментов, где будем аккумулировать созданные сегменты
	ТаблицаСегментов = Новый ТаблицаЗначений;
	// ТаблицаСегментов.Колонки.Добавить("СтруктурнаяЕдиница"	, Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
	ТаблицаСегментов.Колонки.Добавить("Сегмент"				, Новый ОписаниеТипов("СправочникСсылка.СегментыНоменклатуры"));
	ТаблицаСегментов.Колонки.Добавить("НастройкаБП"			, Новый ОписаниеТипов("СправочникСсылка.НастройкиБизнесПроцессов"));
	ТаблицаСегментов.Колонки.Добавить("Услуга"				, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	
	
	// Выбираем номенклатуру с активными настройками для формирования сегментов
	// + номенклатуру в текущих активных БП даже если в самой номенклатуре настройка уже не активна
	Запрос 			= Новый Запрос;
	Запрос.Текст 	= "ВЫБРАТЬ
	             	  |	ВЫРАЗИТЬ(РеквизитыНоменклатуры.Значение КАК Справочник.НастройкиБизнесПроцессов) КАК НастройкаБП,
	             	  |	РеквизитыНоменклатуры.Номенклатура КАК Номенклатура
	             	  |ПОМЕСТИТЬ ТаблицаНоменклатуры
	             	  |ИЗ
	             	  |	РегистрСведений.РеквизитыНоменклатуры КАК РеквизитыНоменклатуры
	             	  |ГДЕ
	             	  |	РеквизитыНоменклатуры.Реквизит = ""ПродлениеЧленстваНастройка""
	             	  |	И РеквизитыНоменклатуры.Номенклатура В
	             	  |			(ВЫБРАТЬ
	             	  |				РеквизитыНоменклатуры.Номенклатура КАК Номенклатура
	             	  |			ИЗ
	             	  |				РегистрСведений.РеквизитыНоменклатуры КАК РеквизитыНоменклатуры
	             	  |			ГДЕ
	             	  |				РеквизитыНоменклатуры.Реквизит = ""ЗапуститьПроцессПродленияЧленстваПоНастройке""
	             	  |				И РеквизитыНоменклатуры.Значение = ИСТИНА)
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	РеквизитыНоменклатуры.Значение,
	             	  |	РеквизитыНоменклатуры.Номенклатура
	             	  |
	             	  |ОБЪЕДИНИТЬ ВСЕ
	             	  |
	             	  |ВЫБРАТЬ
	             	  |	ВЫРАЗИТЬ(РеквизитыНоменклатуры.Значение КАК Справочник.НастройкиБизнесПроцессов),
	             	  |	РеквизитыНоменклатуры.Номенклатура
	             	  |ИЗ
	             	  |	РегистрСведений.РеквизитыНоменклатуры КАК РеквизитыНоменклатуры
	             	  |ГДЕ
	             	  |	РеквизитыНоменклатуры.Реквизит = ""ПродлениеПакетаУслугНастройка""
	             	  |	И РеквизитыНоменклатуры.Номенклатура В
	             	  |			(ВЫБРАТЬ
	             	  |				РеквизитыНоменклатуры.Номенклатура КАК Номенклатура
	             	  |			ИЗ
	             	  |				РегистрСведений.РеквизитыНоменклатуры КАК РеквизитыНоменклатуры
	             	  |			ГДЕ
	             	  |				РеквизитыНоменклатуры.Реквизит = ""ЗапуститьПроцессПродленияПакетаУслугПоНастройке""
	             	  |				И РеквизитыНоменклатуры.Значение = ИСТИНА)
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	РеквизитыНоменклатуры.Значение,
	             	  |	РеквизитыНоменклатуры.Номенклатура
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	ПродлениеЧленства_КОРП.НастройкаБизнесПроцесса КАК НастройкаБизнесПроцесса,
	             	  |	ПродлениеЧленства_КОРП.ЧленствоПакетУслуг.Номенклатура КАК ЧленствоПакетУслугНоменклатура
	             	  |ПОМЕСТИТЬ ТаблицаНастроекПоТекущимБП
	             	  |ИЗ
	             	  |	БизнесПроцесс.ПродлениеЧленства_КОРП КАК ПродлениеЧленства_КОРП
	             	  |ГДЕ
	             	  |	ПродлениеЧленства_КОРП.Стартован = ИСТИНА
	             	  |	И ПродлениеЧленства_КОРП.Завершен = ЛОЖЬ
	             	  |	И НЕ ПродлениеЧленства_КОРП.ЧленствоПакетУслуг.Номенклатура В
	             	  |				(ВЫБРАТЬ
	             	  |					ТаблицаНоменклатуры.Номенклатура
	             	  |				ИЗ
	             	  |					ТаблицаНоменклатуры)
	             	  |
	             	  |ОБЪЕДИНИТЬ ВСЕ
	             	  |
	             	  |ВЫБРАТЬ
	             	  |	ПродлениеПакетаУслуг_КОРП.НастройкаБизнесПроцесса,
	             	  |	ПродлениеПакетаУслуг_КОРП.ЧленствоПакетУслуг.Номенклатура
	             	  |ИЗ
	             	  |	БизнесПроцесс.ПродлениеПакетаУслуг_КОРП КАК ПродлениеПакетаУслуг_КОРП
	             	  |ГДЕ
	             	  |	ПродлениеПакетаУслуг_КОРП.Стартован = ИСТИНА
	             	  |	И ПродлениеПакетаУслуг_КОРП.Завершен = ЛОЖЬ
	             	  |	И НЕ ПродлениеПакетаУслуг_КОРП.ЧленствоПакетУслуг.Номенклатура В
	             	  |				(ВЫБРАТЬ
	             	  |					ТаблицаНоменклатуры.Номенклатура
	             	  |				ИЗ
	             	  |					ТаблицаНоменклатуры)
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	ВЫРАЗИТЬ(РеквизитыНоменклатуры.Значение КАК Справочник.НастройкиБизнесПроцессов) КАК НастройкаБП,
	             	  |	РеквизитыНоменклатуры.Номенклатура КАК Услуга
	             	  |ПОМЕСТИТЬ ТаблицаУслуг
	             	  |ИЗ
	             	  |	РегистрСведений.РеквизитыНоменклатуры КАК РеквизитыНоменклатуры
	             	  |ГДЕ
	             	  |	РеквизитыНоменклатуры.Реквизит = ""ЗаписьНаЗанятиеНастройка""
	             	  |	И РеквизитыНоменклатуры.Номенклатура В
	             	  |			(ВЫБРАТЬ
	             	  |				РеквизитыНоменклатуры.Номенклатура КАК Номенклатура
	             	  |			ИЗ
	             	  |				РегистрСведений.РеквизитыНоменклатуры КАК РеквизитыНоменклатуры
	             	  |			ГДЕ
	             	  |				РеквизитыНоменклатуры.Реквизит = ""ЗапуститьПроцессЗаписиНаЗанятиеПоНастройке""
	             	  |				И РеквизитыНоменклатуры.Значение = ИСТИНА)
	             	  |	И РеквизитыНоменклатуры.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	             	  |	И РеквизитыНоменклатуры.Номенклатура.ВидУслуги <> ЗНАЧЕНИЕ(Перечисление.ВидыУслугНоменклатуры.УслугиСалона)
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	РеквизитыНоменклатуры.Значение,
	             	  |	РеквизитыНоменклатуры.Номенклатура
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	ТаблицаУслуг.НастройкаБП КАК НастрокаБП,
	             	  |	ТаблицаУслуг.Услуга КАК Услуга,
	             	  |	НоменклатураЧленствоПакетУслугСоставУслуг.Ссылка КАК Членство
	             	  |ПОМЕСТИТЬ ТаблицаНоменклатурыДляДопПродаж
	             	  |ИЗ
	             	  |	ТаблицаУслуг КАК ТаблицаУслуг
	             	  |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ЧленствоПакетУслугСоставУслуг КАК НоменклатураЧленствоПакетУслугСоставУслуг
	             	  |		ПО ТаблицаУслуг.Услуга = НоменклатураЧленствоПакетУслугСоставУслуг.УслугаСегмент
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	ТаблицаНоменклатуры.НастройкаБП КАК НастройкаБП,
	             	  |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Услуга,
	             	  |	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура
	             	  |ПОМЕСТИТЬ ТаблицаНастроекБП_И_Номенклатуры
	             	  |ИЗ
	             	  |	ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	             	  |
	             	  |ОБЪЕДИНИТЬ ВСЕ
	             	  |
	             	  |ВЫБРАТЬ
	             	  |	ТаблицаНастроекПоТекущимБП.НастройкаБизнесПроцесса,
	             	  |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка),
	             	  |	ТаблицаНастроекПоТекущимБП.ЧленствоПакетУслугНоменклатура
	             	  |ИЗ
	             	  |	ТаблицаНастроекПоТекущимБП КАК ТаблицаНастроекПоТекущимБП
	             	  |
	             	  |ОБЪЕДИНИТЬ ВСЕ
	             	  |
	             	  |ВЫБРАТЬ
	             	  |	ТаблицаНоменклатурыДляДопПродаж.НастрокаБП,
	             	  |	ТаблицаНоменклатурыДляДопПродаж.Услуга,
	             	  |	ТаблицаНоменклатурыДляДопПродаж.Членство
	             	  |ИЗ
	             	  |	ТаблицаНоменклатурыДляДопПродаж КАК ТаблицаНоменклатурыДляДопПродаж
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.НастройкаБП КАК НастройкаБП,
	             	  |	ЗНАЧЕНИЕ(Справочник.СегментыНоменклатуры.ПустаяСсылка) КАК Сегмент,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.Номенклатура КАК ОбъектСегмента,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.Услуга КАК Услуга,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.НастройкаБП.ВидБизнесПроцесса КАК ВидБизнесПроцесса,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.НастройкаБП.Код КАК НастройкаБПКод
	             	  |ИЗ
	             	  |	ТаблицаНастроекБП_И_Номенклатуры КАК ТаблицаНастроекБП_И_Номенклатуры
	             	  |
	             	  |СГРУППИРОВАТЬ ПО
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.НастройкаБП,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.Номенклатура,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.Услуга,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.НастройкаБП.ВидБизнесПроцесса,
	             	  |	ТаблицаНастроекБП_И_Номенклатуры.НастройкаБП.Код
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ
	             	  |	СегментыНоменклатуры.Ссылка КАК Ссылка,
	             	  |	СегментыНоменклатуры.Наименование КАК Наименование,
	             	  |	СегментыНоменклатуры.Описание КАК Описание
	             	  |ИЗ
	             	  |	Справочник.СегментыНоменклатуры КАК СегментыНоменклатуры
	             	  |ГДЕ
	             	  |	СегментыНоменклатуры.ЭтоГруппа = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаНоменклатуры_И_НастроекБП = РезультатЗапроса[5].Выгрузить();	
	ТаблицаСегментовНоменклатуры	 = РезультатЗапроса[6].Выгрузить();	
	// МассивСтруктурныхЕдиниц			 = РезультатЗапроса[5].Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");	
	
	ГруппаРодительСегментов = ИнициализироватьГруппуСегментов();
	Если ГруппаРодительСегментов = Неопределено Тогда 
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Для Каждого ЭлементСтруктурнаяЕдиница Из МассивСтруктурныхЕдиниц Цикл
	//	ТаблицаНастроекПоСтруктурнойЕдинице = ТаблицаНоменклатуры_И_НастроекБП.Скопировать(Новый Структура("СтруктурнаяЕдиница", ЭлементСтруктурнаяЕдиница));
		ТаблицаНастроекБП = ТаблицаНоменклатуры_И_НастроекБП.Скопировать(, "НастройкаБП, Услуга, ВидБизнесПроцесса, НастройкаБПКод");
		ТаблицаНастроекБП.Свернуть("НастройкаБП, Услуга, ВидБизнесПроцесса, НастройкаБПКод");
		
		Для Каждого СтрокаТЗНастрока Из ТаблицаНастроекБП Цикл
			Если СтрокаТЗНастрока.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродажаДополнительныхУслуг_КОРП Тогда 
				ОписаниеСегмента = "Сегмент членств сформирован автоматически для триггеров системы. В данный сегмент попала номенклатура, в составе которой есть услуга """ + СокрЛП(Строка(СтрокаТЗНастрока.Услуга)) + """ с активированной настройкой бизнес-процесса """ + СокрЛП(Строка(СтрокаТЗНастрока.НастройкаБП)) + """. Номер настройки - " + СтрокаТЗНастрока.НастройкаБПКод;
			Иначе 
				ОписаниеСегмента 									= "Сегмент " + ?(СтрокаТЗНастрока.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродлениеПакетаУслуг_КОРП, "пакетов услуг", "членств") + " сформирован автоматически для триггеров системы. В данный сегмент попала номенклатура, которая учавствовала в сервисных звонках настройки бизнес-процесса """ + СокрЛП(Строка(СтрокаТЗНастрока.НастройкаБП)) + """. Номер настройки - " + СтрокаТЗНастрока.НастройкаБПКод;
			КонецЕсли;	
			МассивСегментов = ТаблицаСегментовНоменклатуры.НайтиСтроки(Новый Структура("Описание", ОписаниеСегмента));
			Если МассивСегментов.Количество() = 0 Тогда 
				СегментНоменклатуры_Объект 							= Справочники.СегментыНоменклатуры.СоздатьЭлемент();
				СегментНоменклатуры_Объект.Родитель 				= ГруппаРодительСегментов;
				// СегментНоменклатуры_Объект.СтруктурнаяЕдиница 		= ЭлементСтруктурнаяЕдиница;
				СегментНоменклатуры_Объект.Наименование 			= "Сегмент " + ?(СтрокаТЗНастрока.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродлениеПакетаУслуг_КОРП, "пакетов услуг", "членств") + " с услугой """ + СокрЛП(Строка(СтрокаТЗНастрока.Услуга)) + """ в составе для настройки - " + СокрЛП(Строка(СтрокаТЗНастрока.НастройкаБП));// + " (" + СокрЛП(Строка(ЭлементСтруктурнаяЕдиница)) + ")";
				СегментНоменклатуры_Объект.СпособФормирования 		= Перечисления.СпособыФормированияСегментов.ФормироватьВручную;
				СегментНоменклатуры_Объект.ДатаСоздания 			= НачалоДня(ТекущаяДатаСеанса());
				СегментНоменклатуры_Объект.Описание 				= ОписаниеСегмента;
				СегментНоменклатуры_Объект.Автор 					= ПараметрыСеанса.ТекущийСотрудник;
				СегментНоменклатуры_Объект.УстановитьНовыйКод();										
				СегментНоменклатуры_Объект.ОбменДанными.Загрузка 	= Истина;
				Попытка
					// Сохраняем сегмент
					СегментНоменклатуры_Объект.Записать();
					Для Каждого СтрокаТЗ ИЗ ТаблицаНоменклатуры_И_НастроекБП Цикл 
						Если СтрокаТЗ.НастройкаБП = СтрокаТЗНастрока.НастройкаБП Тогда 
							СтрокаТЗ.Сегмент = СегментНоменклатуры_Объект.Ссылка;
						КонецЕсли;
					КонецЦикла;	
					// Наполняем номенклатурой
					НаборЗаписейСоставСегментов = РегистрыСведений.СоставСегментов.СоздатьНаборЗаписей();
					НаборЗаписейСоставСегментов.Отбор.Сегмент.Установить(СегментНоменклатуры_Объект.Ссылка);
					НаборЗаписейСоставСегментов.Загрузить(ТаблицаНоменклатуры_И_НастроекБП.Скопировать(Новый Структура("НастройкаБП, Услуга, Сегмент", СтрокаТЗНастрока.НастройкаБП, СтрокаТЗНастрока.Услуга, СегментНоменклатуры_Объект.Ссылка), "Сегмент, ОбъектСегмента"));		
					НаборЗаписейСоставСегментов.Записать(Ложь);
					// Формируем результирующую таблицу
					НоваяСтрока = ТаблицаСегментов.Добавить();
					// НоваяСтрока.СтруктурнаяЕдиница 	= ЭлементСтруктурнаяЕдиница;
					НоваяСтрока.Сегмент 			= СегментНоменклатуры_Объект.Ссылка;
					НоваяСтрока.НастройкаБП 		= СтрокаТЗНастрока.НастройкаБП;
					НоваяСтрока.Услуга	 			= СтрокаТЗНастрока.Услуга;					
				Исключение
					Отказ = Истина;
					ЗаписьЖурналаРегистрации("Ошибка создания сегмента номенклатуры!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.СегментыНоменклатуры, , ОписаниеОшибки());			
					Прервать;
				КонецПопытки;
			Иначе 
				НоваяСтрока = ТаблицаСегментов.Добавить();
				// НоваяСтрока.СтруктурнаяЕдиница 	= ЭлементСтруктурнаяЕдиница;
				НоваяСтрока.Сегмент 			= МассивСегментов[0].Ссылка;
				НоваяСтрока.НастройкаБП 		= СтрокаТЗНастрока.НастройкаБП;
				НоваяСтрока.Услуга	 			= СтрокаТЗНастрока.Услуга;				
			КонецЕсли;
		КонецЦикла;
	//	Если Отказ Тогда Прервать; КонецЕсли;
	// КонецЦикла;
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Инициализировать группу сегментов
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьГруппуСегментов()
	
	ГруппаСегментов = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Наименование", "Сегменты номенклатуры для триггеров" + "%");	
	Запрос.Текст = "ВЫБРАТЬ
	               |	СегментыНоменклатуры.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.СегментыНоменклатуры КАК СегментыНоменклатуры
	               |ГДЕ
	               |	СегментыНоменклатуры.ЭтоГруппа = ИСТИНА
	               |	И СегментыНоменклатуры.Наименование ПОДОБНО &Наименование";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда 
		ГруппаСегментовНоменклатуры							= Справочники.СегментыНоменклатуры.СоздатьГруппу();
		ГруппаСегментовНоменклатуры.Наименование 			= "Сегменты номенклатуры для триггеров";
		ГруппаСегментовНоменклатуры.УстановитьНовыйКод();							
		ГруппаСегментовНоменклатуры.ОбменДанными.Загрузка 	= Истина;
		Попытка
			ГруппаСегментовНоменклатуры.Записать();
			ГруппаСегментов = ГруппаСегментовНоменклатуры.Ссылка;
		Исключение
			// Запись в лог						
			ЗаписьЖурналаРегистрации("Ошибка создания группы сегментов номенклатуры!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.СегментыНоменклатуры, , ОписаниеОшибки());			
		КонецПопытки;	
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда 
			ГруппаСегментов = Выборка.Ссылка;
		КонецЕсли;	
	КонецЕсли;

	Возврат ГруппаСегментов;
	
КонецФункции

// Функция - Инициализировать группу триггерного события
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьГруппуТриггерногоСобытия(СтрокаСервисныйЗвонок)
	
	ГруппаТриггерногоСобытия = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Наименование", СокрЛП(СтрокаСервисныйЗвонок.Наименование));	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТриггерныеСобытия.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
	               |ГДЕ
	               |	ТриггерныеСобытия.ЭтоГруппа = ИСТИНА
	               |	И ТриггерныеСобытия.Наименование ПОДОБНО &Наименование";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда 
		ГруппаТриггерногоСобытия_Объект							= Справочники.ТриггерныеСобытия.СоздатьГруппу();
		ГруппаТриггерногоСобытия_Объект.Наименование 			= СокрЛП(СтрокаСервисныйЗвонок.Наименование);
		ГруппаТриггерногоСобытия_Объект.УстановитьНовыйКод();							
		ГруппаТриггерногоСобытия_Объект.ОбменДанными.Загрузка 	= Истина;
		Попытка
			ГруппаТриггерногоСобытия_Объект.Записать();
			ГруппаТриггерногоСобытия = ГруппаТриггерногоСобытия_Объект.Ссылка;
		Исключение
			// Запись в лог						
			ЗаписьЖурналаРегистрации("Ошибка создания группы триггерного события!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ТриггерныеСобытия, , ОписаниеОшибки());			
		КонецПопытки;	
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда 
			ГруппаТриггерногоСобытия = Выборка.Ссылка;
		КонецЕсли;	
	КонецЕсли;

	Возврат ГруппаТриггерногоСобытия;
	
КонецФункции

// Процедура - Генерация триггерных событий
//
// Параметры:
//  ТаблицаСегментов		 - 	 - 
//  ТаблицаТриггерныхСобытий - 	 - 
//  ТриггерКонтроляРассрочек - 	 - 
//  Отказ					 - 	 - 
//
Процедура ГенерацияТриггерныхСобытий(ТаблицаСегментов, ТаблицаТриггерныхСобытий = Неопределено, ТриггерКонтроляРассрочек, Отказ) Экспорт
	
	МассивВидовБизнесПроцессов = Новый Массив;
	МассивВидовБизнесПроцессов.Добавить(Перечисления.ВидыБизнесПроцессов.ПродлениеЧленства_КОРП);
	МассивВидовБизнесПроцессов.Добавить(Перечисления.ВидыБизнесПроцессов.ПродлениеПакетаУслуг_КОРП);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = УправлениеЗапасамиПартионныйУчет.ВыбратьТЗВВременнуюТаблицу(ТаблицаСегментов, "ТаблицаСегментов");
	Запрос.УстановитьПараметр("МассивВидовБизнесПроцессов", МассивВидовБизнесПроцессов);
	Запрос.Текст = "ВЫБРАТЬ
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка КАК СсылкаНастройкиБП,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.Наименование КАК Наименование,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ВидБизнесПроцесса КАК ВидБизнесПроцесса,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ПометкаУдаления КАК ПометкаУдаления,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.НомерСтроки КАК НомерСтроки,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.УИД КАК УИД,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.МоментАктивации КАК МоментАктивации,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.ПериодАктивации КАК ПериодАктивации,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.ТипПериода КАК ТипПериода,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.КоличествоПовторений КАК КоличествоПовторений,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.КритическийОстаток КАК КритическийОстаток,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.СегментИсполнителей КАК СегментИсполнителей,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Тема КАК Тема,
	               |	ЛОЖЬ КАК КонтрольОстаткаПакета,
	               |	ЗНАЧЕНИЕ(Справочник.ТриггерныеСобытия.ПустаяСсылка) КАК ТриггерСсылка,
	               |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Услуга
	               |ИЗ
	               |	Справочник.НастройкиБизнесПроцессов.СервисныеЗвонки КАК НастройкиБизнесПроцессовСервисныеЗвонки
	               |ГДЕ
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ВидБизнесПроцесса В(&МассивВидовБизнесПроцессов)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.Наименование,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ВидБизнесПроцесса,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ПометкаУдаления,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.НомерСтроки,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.УИД,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.МоментАктивации,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.ПериодАктивации,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.ТипПериода,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.КоличествоПовторений,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.КритическийОстаток,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.СегментИсполнителей,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Тема,
	               |	ИСТИНА,
	               |	ЗНАЧЕНИЕ(Справочник.ТриггерныеСобытия.ПустаяСсылка),
	               |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	               |ИЗ
	               |	Справочник.НастройкиБизнесПроцессов.СервисныеЗвонки КАК НастройкиБизнесПроцессовСервисныеЗвонки
	               |ГДЕ
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ВидБизнесПроцесса = ЗНАЧЕНИЕ(Перечисление.ВидыБизнесПроцессов.ПродлениеПакетаУслуг_КОРП)
	               |	И НастройкиБизнесПроцессовСервисныеЗвонки.МоментАктивации = ЗНАЧЕНИЕ(Перечисление.ВариантыАктивацииСервисныхЗвонков_Удалить.ДоОкончанияСрокаДействияЗа)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.Наименование,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ВидБизнесПроцесса,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ПометкаУдаления,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.НомерСтроки,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.УИД,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.МоментАктивации,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.ПериодАктивации,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.ТипПериода,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.КоличествоПовторений,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.КритическийОстаток,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.СегментИсполнителей,
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Тема,
	               |	ЛОЖЬ,
	               |	ЗНАЧЕНИЕ(Справочник.ТриггерныеСобытия.ПустаяСсылка),
	               |	ТаблицаСегментов.Услуга
	               |ИЗ
	               |	Справочник.НастройкиБизнесПроцессов.СервисныеЗвонки КАК НастройкиБизнесПроцессовСервисныеЗвонки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСегментов КАК ТаблицаСегментов
	               |		ПО НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка = ТаблицаСегментов.НастройкаБП
	               |ГДЕ
	               |	НастройкиБизнесПроцессовСервисныеЗвонки.Ссылка.ВидБизнесПроцесса = ЗНАЧЕНИЕ(Перечисление.ВидыБизнесПроцессов.ПродажаДополнительныхУслуг_КОРП)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ШаблоныСообщений.Ссылка КАК Ссылка,
	               |	ШаблоныСообщений.Наименование КАК Наименование,
	               |	ШаблоныСообщений.ЗадачаОписание КАК ЗадачаОписание
	               |ИЗ
	               |	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	               |ГДЕ
	               |	ШаблоныСообщений.ЭтоГруппа = ЛОЖЬ
	               |	И ШаблоныСообщений.Предопределенный = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТриггерныеСобытия.Ссылка КАК Ссылка,
	               |	ТриггерныеСобытия.Наименование КАК Наименование,
	               |	ТриггерныеСобытия.КодСинхронизации КАК КодСинхронизации,
	               |	ТриггерныеСобытия.УсловиеСобытия КАК УсловиеСобытия
	               |ИЗ
	               |	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
	               |ГДЕ
	               |	ТриггерныеСобытия.ЭтоГруппа = ЛОЖЬ";
	
	РезультатЗапроса 		= Запрос.ВыполнитьПакет();
	ТаблицаСервисныхЗвонков = РезультатЗапроса[0].Выгрузить();
	ТаблицаШаблонов 		= РезультатЗапроса[1].Выгрузить();
	ТаблицаТриггеров 		= РезультатЗапроса[2].Выгрузить();
	
	ДоступныеУчетныеЗаписи 	= УправлениеЭлектроннойПочтой.ПолучитьДоступныеУчетныеЗаписи(Истина);
	АккаунтEmail   			= ?(ДоступныеУчетныеЗаписи.Количество() > 0, ДоступныеУчетныеЗаписи[0].Ссылка, Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты);
	АккаунтSMS 				= Константы.СервисSMSРассылкиПоУмолчанию.Получить();
	
	ГруппаШаблонов 			= ИнициализироватьГруппуШаблоновСообщений();
	Отказ 					= Ложь;
	
	// Создаем триггеры согласно настройкам продления членств/пакетов услуг	
	Для Каждого СтрокаСервисныйЗвонок Из ТаблицаСервисныхЗвонков Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаСервисныйЗвонок.МоментАктивации) Тогда 
			Продолжить;
		КонецЕсли;
		
		МассивСегментов = ТаблицаСегментов.НайтиСтроки(Новый Структура("НастройкаБП, Услуга", СтрокаСервисныйЗвонок.СсылкаНастройкиБП, СтрокаСервисныйЗвонок.Услуга));
		Если МассивСегментов.Количество() = 0 Тогда 
			СегментНоменклатуры = Неопределено;
			Услуга 				= Неопределено;
		Иначе 
			СегментНоменклатуры = МассивСегментов[0].Сегмент;
			Услуга 				= МассивСегментов[0].Услуга;				
		КонецЕсли;
		СоздатьТриггерноеСобытие(СтрокаСервисныйЗвонок, ТаблицаТриггеров, СегментНоменклатуры, Услуга, АккаунтEmail, АккаунтSMS, ТаблицаШаблонов, ГруппаШаблонов, Отказ);
		Если Отказ = Истина Тогда 
			Прервать;			
		КонецЕсли;	
	КонецЦикла;
	
	УИД_ТриггераКонтроляПлатежей 	= Новый УникальныйИдентификатор("178266c8-7767-4b92-810a-5d41d5bf7275");
	ТриггерКонтроляПлатежей 		= Справочники.ТриггерныеСобытия.НайтиПоРеквизиту("КодСинхронизации", УИД_ТриггераКонтроляПлатежей);
	
	Если НЕ ЗначениеЗаполнено(ТриггерКонтроляПлатежей) Тогда 
		// Создаем триггер для контроля платежей по рассрочкам
		Триггер_Объект 									= Справочники.ТриггерныеСобытия.СоздатьЭлемент();
		Триггер_Объект.Наименование 					= "Напоминание о просроченном платеже по рассрочке";	
		Триггер_Объект.Активно 							= Истина;
		Триггер_Объект.УсловиеСобытия 					= Перечисления.ВариантыУсловийТриггерныхСобытий.ПродажаПлатежПоРассрочке;
		Триггер_Объект.МоментСобытия 					= Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия;
		Триггер_Объект.ВремяСобытия 					= Дата(1, 1, 1, 23, 0, 0);
		// Триггер_Объект.ВидАдресата_Удалить 				= Перечисления.ВидыАдресатов.Куратор;
		// Триггер_Объект.Адресат_Удалить 					= Справочники.СегментыСотрудников.МенеджерыОтделаПродаж;
		// Триггер_Объект.АккаунтSMS_Удалить 				= АккаунтSMS;
		// Триггер_Объект.АккаунтEmail_Удалить 			= АккаунтEmail;
		// Триггер_Объект.ШаблонСообщения_Удалить 			= СгенерироватьШаблонДляТриггерногоСобытия(ТаблицаШаблонов, ГруппаШаблонов, , , Отказ);
		Триггер_Объект.КодСинхронизации 				= УИД_ТриггераКонтроляПлатежей;	
		Триггер_Объект.Описание 						= "Триггерное событие сформированно автоматически.";
		Триггер_Объект.УстановитьНовыйКод();		
		Триггер_Объект.ОбменДанными.Загрузка 			= Истина;
		Попытка
			Триггер_Объект.Записать();
			ТриггерКонтроляРассрочек = Триггер_Объект.Ссылка;
		Исключение
			Отказ = Истина;
			ЗаписьЖурналаРегистрации("Ошибка создания триггерного события! " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП) + " Код настройки: " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП.Код) + " Номер строки: " + Строка(СтрокаСервисныйЗвонок.НомерСтроки), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ТриггерныеСобытия, , ОписаниеОшибки());			
		КонецПопытки;
	Иначе 
		ТриггерКонтроляРассрочек = ТриггерКонтроляПлатежей;
	КонецЕсли;

	Если НЕ ТаблицаТриггерныхСобытий = Неопределено Тогда 
		ТаблицаТриггерныхСобытий.Загрузить(ТаблицаСервисныхЗвонков);
	Иначе 
		ТаблицаТриггерныхСобытий = ТаблицаСервисныхЗвонков;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Создать триггерное событие
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
//  ТаблицаТриггеров		 - 	 - 
//  СегментНоменклатуры		 - 	 - 
//  Услуга					 - 	 - 
//  АккаунтEmail			 - 	 - 
//  АккаунтSMS				 - 	 - 
//  ТаблицаШаблонов			 - 	 - 
//  ГруппаШаблонов			 - 	 - 
//  Отказ					 - 	 - 
//
Процедура СоздатьТриггерноеСобытие(СтрокаСервисныйЗвонок, ТаблицаТриггеров, СегментНоменклатуры, Услуга, АккаунтEmail, АккаунтSMS, ТаблицаШаблонов, ГруппаШаблонов, Отказ)
	
	// Поиск уже созданных
	МассивСтрокТриггера = ТаблицаТриггеров.НайтиСтроки(Новый Структура("КодСинхронизации", СтрокаСервисныйЗвонок.УИД));
	Если МассивСтрокТриггера.Количество() = 1 Тогда
		СтрокаСервисныйЗвонок.ТриггерСсылка 		= МассивСтрокТриггера[0].Ссылка;
		// Если НЕ ЗначениеЗаполнено(МассивСтрокТриггера[0].СегментЧленствПакетовУслуг) И ЗначениеЗаполнено(СегментНоменклатуры) Тогда 
		//	Триггер_Объект 							= МассивСтрокТриггера[0].Ссылка.ПолучитьОбъект();
		//	Триггер_Объект.СегментЧленствПакетовУслуг 		= СегментНоменклатуры;
		//	Триггер_Объект.ОбменДанными.Загрузка 	= Истина;
		//	Попытка
		//		Триггер_Объект.Записать();
		//	Исключение
		//		Отказ = Истина;
		//		ЗаписьЖурналаРегистрации("Ошибка редактирования триггерного события! " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП) + " Код настройки: " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП.Код) + " Номер строки: " + Строка(СтрокаСервисныйЗвонок.НомерСтроки), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ТриггерныеСобытия, , ОписаниеОшибки());			
		//	КонецПопытки;
		// КонецЕсли;	
		Возврат; // Продолжить;		
	ИначеЕсли МассивСтрокТриггера.Количество() > 1 Тогда
		Для Каждого СтрокаМассива Из МассивСтрокТриггера Цикл
			ТриггерНайден = Ложь;			
			Если СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродажаДополнительныхУслуг_КОРП И ЗначениеЗаполнено(Услуга) Тогда
				Если НЕ СтрНайти(СтрокаМассива.Наименование, СокрЛП(Строка(Услуга))) = 0 Тогда 
					СтрокаСервисныйЗвонок.ТриггерСсылка 	= СтрокаМассива.Ссылка;
					ТриггерНайден = Истина;
				КонецЕсли;	
			КонецЕсли;	
			// Если ТриггерНайден И НЕ ЗначениеЗаполнено(СтрокаМассива.СегментЧленствПакетовУслуг) И ЗначениеЗаполнено(СегментНоменклатуры) Тогда 
			//	Триггер_Объект 								= СтрокаМассива.Ссылка.ПолучитьОбъект();
			//	Триггер_Объект.СегментЧленствПакетовУслуг 	= СегментНоменклатуры;
			//	Триггер_Объект.ОбменДанными.Загрузка 		= Истина;
			//	Попытка
			//		Триггер_Объект.Записать();
			//	Исключение
			//		Отказ = Истина;
			//		ЗаписьЖурналаРегистрации("Ошибка редактирования триггерного события! " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП) + " Код настройки: " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП.Код) + " Номер строки: " + Строка(СтрокаСервисныйЗвонок.НомерСтроки), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ТриггерныеСобытия, , ОписаниеОшибки());			
			//	КонецПопытки;
			// КонецЕсли;
		КонецЦикла;
		Возврат; // Продолжить;
	КонецЕсли;	
	
	// Если не нашли - создаем
	Триггер_Объект 										= Справочники.ТриггерныеСобытия.СоздатьЭлемент();
	Триггер_Объект.Родитель 							= ИнициализироватьГруппуТриггерногоСобытия(СтрокаСервисныйЗвонок);
	Если СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродажаДополнительныхУслуг_КОРП Тогда
		Триггер_Объект.Наименование 					= "Звонок для записи клиента на пробное занятие """ + СокрЛП(Строка(Услуга)) + """";
	Иначе 	
		Триггер_Объект.Наименование 					= СокрЛП(СтрокаСервисныйЗвонок.Тема) + " (" + СокрЛП(Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП)) + ")";
	КонецЕсли;	
	Триггер_Объект.Активно 								= НЕ СтрокаСервисныйЗвонок.ПометкаУдаления И ЗначениеЗаполнено(СегментНоменклатуры);
	Триггер_Объект.УсловиеСобытия 						= ПолучитьУсловиеТриггерногоСобытия(СтрокаСервисныйЗвонок);
	Триггер_Объект.ПараметрСобытия 						= ПолучитьПараметрТриггерногоСобытия(СтрокаСервисныйЗвонок, Триггер_Объект.УсловиеСобытия);
	Триггер_Объект.МоментСобытия 						= ПолучитьМоментТриггерногоСобытия(СтрокаСервисныйЗвонок, Триггер_Объект.УсловиеСобытия);
	Триггер_Объект.ПериодСобытия 						= ПолучитьПериодТриггерногоСобытия(СтрокаСервисныйЗвонок, Триггер_Объект.УсловиеСобытия, Триггер_Объект.МоментСобытия);
	Триггер_Объект.ВремяСобытия 						= Дата(1, 1, 1, 1, 30, 0);
	// Триггер_Объект.ВидАдресата_Удалить 					= ПолучитьВидАдресатаДляЗадачи(СтрокаСервисныйЗвонок);
	// Триггер_Объект.Адресат_Удалить 						= ПолучитьАдресатаДляЗадачи(СтрокаСервисныйЗвонок, Триггер_Объект.ВидАдресата_Удалить);
	// Триггер_Объект.АккаунтSMS_Удалить 					= АккаунтSMS;
	// Триггер_Объект.АккаунтEmail_Удалить 				= АккаунтEmail;
	// Триггер_Объект.ШаблонСообщения_Удалить 				= СгенерироватьШаблонДляТриггерногоСобытия(ТаблицаШаблонов, ГруппаШаблонов, СтрокаСервисныйЗвонок, Услуга, Отказ);
	Триггер_Объект.КодСинхронизации 					= СтрокаСервисныйЗвонок.УИД;
	Если СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродажаДополнительныхУслуг_КОРП Тогда
		Триггер_Объект.Описание 						= "Триггерное событие сформированно автоматически на основании настроек сервисных звонков." + Символы.ПС + "Настройка: " + СокрЛП(Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП)) + " Номер строки: " + Строка(СтрокаСервисныйЗвонок.НомерСтроки) + Символы.ПС + "Услуга: " + СокрЛП(Строка(Услуга));
	Иначе 	
		Триггер_Объект.Описание 						= "Триггерное событие сформированно автоматически на основании настроек сервисных звонков." + Символы.ПС + "Настройка продления: " + СокрЛП(Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП)) + " Номер строки: " + Строка(СтрокаСервисныйЗвонок.НомерСтроки);
	КонецЕсли;
	Триггер_Объект.УстановитьНовыйКод();		
	Триггер_Объект.ОбменДанными.Загрузка 				= Истина;
	Попытка
		Триггер_Объект.Записать();
		СтрокаСервисныйЗвонок.ТриггерСсылка 			= Триггер_Объект.Ссылка;
	Исключение
		Отказ = Истина;
		ЗаписьЖурналаРегистрации("Ошибка создания триггерного события! " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП) + " Код настройки: " + Строка(СтрокаСервисныйЗвонок.СсылкаНастройкиБП.Код) + " Номер строки: " + Строка(СтрокаСервисныйЗвонок.НомерСтроки), УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ТриггерныеСобытия, , ОписаниеОшибки());			
	КонецПопытки;

КонецПроцедуры

// Функция - Получить условие триггерного события
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьУсловиеТриггерногоСобытия(СтрокаСервисныйЗвонок)
	
	УсловиеТриггерногоСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	
	Если СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеПервогоПосещенияЧерез Тогда	
		УсловиеТриггерногоСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентПосещениеКлиники;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ОтсутствиеКлиентаВКлиникеВТечении Тогда	
		УсловиеТриггерногоСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПациентНепосещениеКлиники;
	КонецЕсли;
	
	Возврат УсловиеТриггерногоСобытия;
	
КонецФункции	

// Функция - Получить параметр триггерного события
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
//  УсловиеСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПараметрТриггерногоСобытия(СтрокаСервисныйЗвонок, УсловиеСобытия)
	
	ПараметрТриггерногоСобытия 	= 0;
	ПериодАктивации 			= ?(СтрокаСервисныйЗвонок.ПериодАктивации < 1, 1, СтрокаСервисныйЗвонок.ПериодАктивации);
	Если СтрокаСервисныйЗвонок.ТипПериода = Перечисления.Периодичность.Месяц Тогда 
		ПериодАктивации = ПериодАктивации*30;
	КонецЕсли;	
	
	Если СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеПервогоПосещенияЧерез Тогда	
		ПараметрТриггерногоСобытия = 1;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ОтсутствиеКлиентаВКлиникеВТечении Тогда	
		ПараметрТриггерногоСобытия = ПериодАктивации;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ЗанимаетсяРежеЧем1РазВ Тогда	
		ПараметрТриггерногоСобытия = ПериодАктивации;
	КонецЕсли;
	
	Возврат ПараметрТриггерногоСобытия;
	
КонецФункции	

// Функция - Получить момент триггерного события
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
//  УсловиеСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьМоментТриггерногоСобытия(СтрокаСервисныйЗвонок, УсловиеСобытия)
	
	МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПустаяСсылка();
	
	Если СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеАктивацииЧерез Тогда 
		МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеПервогоПосещенияЧерез Тогда	
		МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ОтсутствиеКлиентаВКлиникеВТечении Тогда	
		МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ДоОкончанияСрокаДействияЗа И СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродлениеЧленства_КОРП Тогда
		МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ДоОкончанияСрокаДействияЗа И СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродлениеПакетаУслуг_КОРП Тогда
		МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия;
	ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ЗанимаетсяРежеЧем1РазВ Тогда	
		МоментТриггерногоСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия;
	КонецЕсли;
	
	Возврат МоментТриггерногоСобытия;
	
КонецФункции	

// Функция - Получить период триггерного события
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
//  УсловиеСобытия			 - 	 - 
//  МоментСобытия			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПериодТриггерногоСобытия(СтрокаСервисныйЗвонок, УсловиеСобытия, МоментСобытия)
	
	ПериодТриггерногоСобытия 	= 0;
	ПериодАктивации 			= ?(СтрокаСервисныйЗвонок.ПериодАктивации < 1, 1, СтрокаСервисныйЗвонок.ПериодАктивации);
	Если СтрокаСервисныйЗвонок.ТипПериода = Перечисления.Периодичность.Месяц Тогда 
		ПериодАктивации = ПериодАктивации*30;
	КонецЕсли;	
	
	Если МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия ИЛИ МоментСобытия = Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия Тогда 
		Если СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеАктивацииЧерез Тогда 
			ПериодТриггерногоСобытия = ПериодАктивации;
		ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеПервогоПосещенияЧерез Тогда	
			ПериодТриггерногоСобытия = ПериодАктивации;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПериодТриггерногоСобытия;
	
КонецФункции	

// Функция - Получить вид адресата для задачи
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВидАдресатаДляЗадачи(СтрокаСервисныйЗвонок)
	
	ВидАдресата = Перечисления.ВидыАдресатов.ПустаяСсылка();
	
	Если ЗначениеЗаполнено(СтрокаСервисныйЗвонок.СегментИсполнителей) Тогда 
		Если ТипЗнч(СтрокаСервисныйЗвонок.СегментИсполнителей) = Тип("СправочникСсылка.СегментыСотрудников") Тогда 
			ВидАдресата = Перечисления.ВидыАдресатов.СегментСотрудников;
		// ИначеЕсли СтрокаСервисныйЗвонок.СегментИсполнителей = Перечисления.РольПользователя.МенеджерОтделаПродаж Тогда
		Иначе 	
			ВидАдресата = Перечисления.ВидыАдресатов.Куратор;
		// ИначеЕсли СтрокаСервисныйЗвонок.СегментИсполнителей = Перечисления.РольПользователя.МенеджерОтделаСервиса Тогда 
		//	ВидАдресата = Перечисления.ВидыАдресатов.ОсновнойМенеджерОтделаСервиса;
		КонецЕсли;	
	Иначе 
		ВидАдресата = Перечисления.ВидыАдресатов.Куратор;
	КонецЕсли;	
	
	Возврат ВидАдресата;
	
КонецФункции	

// Функция - Получить адресата для задачи
//
// Параметры:
//  СтрокаСервисныйЗвонок	 - 	 - 
//  ВидАдресата				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАдресатаДляЗадачи(СтрокаСервисныйЗвонок, ВидАдресата)
	
	Адресат = Неопределено;
	
	Если ВидАдресата = Перечисления.ВидыАдресатов.Сотрудник ИЛИ ВидАдресата = Перечисления.ВидыАдресатов.СегментСотрудников Тогда 
		Адресат = СтрокаСервисныйЗвонок.СегментИсполнителей;
	ИначеЕсли ВидАдресата = Перечисления.ВидыАдресатов.Куратор Тогда 
		Адресат = Справочники.СегментыСотрудников.МенеджерыОтделаПродаж;
	КонецЕсли;	
	
	Возврат Адресат;
	
КонецФункции	

// Функция - Сгенерировать шаблон для триггерного события
//
// Параметры:
//  ТаблицаШаблонов			 - 	 - 
//  ГруппаШаблонов			 - 	 - 
//  СтрокаСервисныйЗвонок	 - 	 - 
//  Услуга					 - 	 - 
//  Отказ					 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СгенерироватьШаблонДляТриггерногоСобытия(ТаблицаШаблонов, ГруппаШаблонов, СтрокаСервисныйЗвонок = Неопределено, Услуга, Отказ)
	
	НаименованиеШаблона = "";
	ОписаниеЗадачи = "";
	
	Если СтрокаСервисныйЗвонок = Неопределено Тогда 
		НаименованиеШаблона = "Напоминание об платеже по рассрочке";
		ОписаниеЗадачи 		= "Необходимо проинформировать клиента о просроченном платеже по рассрочке" + "
		|Дата платежа: {ДатаПлановогоПлатежаПоРассрочке}" + "
		|Сумма платежа: {СуммаПлановогоПлатежаПоРассрочке} руб.";
	Иначе 	
		Если СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеПервогоПосещенияЧерез Тогда 
			НаименованиеШаблона = "Звонок после первого посещения через " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации);
			ОписаниеЗадачи 		= "Клиент первый раз посетил клинику {ДатаПервогоПосещенияКонтрагента}" + "
			|Поинтересуйтесь впечатлениями от первого посещения, предложите записать его на тестирование";
		ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ПослеАктивацииЧерез Тогда
			Если СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродажаДополнительныхУслуг_КОРП Тогда
				НаименованиеШаблона = "Звонок для записи клиента на пробное занятие """ + СокрЛП(Строка(Услуга)) + """";
				ОписаниеЗадачи 		= "Предложите клиенту записать его на пробное занятие """ + СокрЛП(Строка(Услуга)) + """, для последующей продажи ему дополнительных услуг.";
			Иначе 	
				НаименованиеШаблона = "Звонок после активации членства/пакета услуг через " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации);
				ОписаниеЗадачи 		= "Клиент прошел адаптационный период " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации) + "
				|Поинтересуйтесь регулярно ли он ходит, устраивает ли его качество проводимых тренировок";
			КонецЕсли;
		ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ОтсутствиеКлиентаВКлиникеВТечении Тогда 	
			НаименованиеШаблона = "Звонок в случае отсутсвия клиента в клинике в течении " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации, "Родительный");
			ОписаниеЗадачи 		= "Клиент не посещает клинику в течении " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации, "Родительный") + "
			|Необходимо поинтересоваться у клиента о причинах. Устраивает ли его качество услуг и тренировок?";
		ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ЗанимаетсяРежеЧем1РазВ Тогда 	
			НаименованиеШаблона = "Звонок при возникновении риска не использования пакета (при условии что клиент занимается 1 раз в " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации) + ")";
			ОписаниеЗадачи 		= "Срок действия пакета услуг заканчивается {ДатаОкончанияЧленства} Осталось: {КоличествоУслугВПакете}" + "
			|Существует вероятность того, что он не успеет их отходить. Постарайтесь вернуть клиента в клинику, запишите его на занятие";
		ИначеЕсли СтрокаСервисныйЗвонок.МоментАктивации = Перечисления.ВариантыАктивацииСервисныхЗвонков_Удалить.ДоОкончанияСрокаДействияЗа Тогда 	
			Если СтрокаСервисныйЗвонок.КонтрольОстаткаПакета = Ложь Тогда 
				Если СтрокаСервисныйЗвонок.ВидБизнесПроцесса = Перечисления.ВидыБизнесПроцессов.ПродлениеЧленства_КОРП Тогда 
					НаименованиеШаблона = "Звонок за " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации) + " до окончания срока действия членства";
					ОписаниеЗадачи 		= "Через " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации) + " у клиента закончится срок действия членства.
					|Постарайтесь узнать, настроен ли клиент на продление, все ли его устраивает. У вас еще есть время, что-то изменить";
				Иначе 
					НаименованиеШаблона = "Звонок за " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации) + " до окончания срока действия пакета услуг";
					ОписаниеЗадачи 		= "Срок действия пакета услуг заканчивается через " + Строка(СтрокаСервисныйЗвонок.ПериодАктивации) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(СтрокаСервисныйЗвонок.ТипПериода), СтрокаСервисныйЗвонок.ПериодАктивации) + ".
					|Предложите клиенту приобрести новый пакет";
					
				КонецЕсли;	
			Иначе 
				НаименованиеШаблона = "Информирование о малом количестве услуг в пакете (" + Строка(СтрокаСервисныйЗвонок.КритическийОстаток) + " услуг)";
				ОписаниеЗадачи 		= "Остаток услуг в пакете меньше или равен " + Строка(СтрокаСервисныйЗвонок.КритическийОстаток) + ".
				|Предложите клиенту приобрести новый пакет";
			КонецЕсли;						
		КонецЕсли;
	КонецЕсли;

	МассивШаблонов = ТаблицаШаблонов.НайтиСтроки(Новый Структура("Наименование, ЗадачаОписание", НаименованиеШаблона, ОписаниеЗадачи));
	Если МассивШаблонов.Количество() = 0 Тогда 
		ШаблонСообщения_Объект 							= Справочники.ШаблоныСообщений.СоздатьЭлемент();
		ШаблонСообщения_Объект.Заполнить(Неопределено);
		ШаблонСообщения_Объект.Родитель 				= ГруппаШаблонов; 
		ШаблонСообщения_Объект.Наименование 			= НаименованиеШаблона;
		ШаблонСообщения_Объект.ЗадачаВидВзаимодействия 	= Справочники.ВидыВзаимодействий.ЗвонокИсходящий;
		ШаблонСообщения_Объект.ЗадачаПериодВыполнения 	= 1;
		ШаблонСообщения_Объект.ЗадачаОписание 			= ОписаниеЗадачи;
		ШаблонСообщения_Объект.УстановитьНовыйКод();		
		ШаблонСообщения_Объект.ОбменДанными.Загрузка 	= Истина;
		Попытка
			ШаблонСообщения_Объект.Записать();
			НоваяСтрока 					= ТаблицаШаблонов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ШаблонСообщения_Объект);
			Возврат ШаблонСообщения_Объект.Ссылка;
		Исключение
			Отказ = Истина;
			ЗаписьЖурналаРегистрации("Ошибка создания шаблона сообщения! " + НаименованиеШаблона + Символы.ПС + ОписаниеЗадачи, УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ШаблоныСообщений, , ОписаниеОшибки());			
			Возврат Справочники.ШаблоныСообщений.ПустаяСсылка();
		КонецПопытки;
	Иначе 
		Возврат МассивШаблонов[0].Ссылка;
	КонецЕсли;
	
КонецФункции	

// Функция - Инициализировать группу шаблонов сообщений
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьГруппуШаблоновСообщений()
	
	ГруппаШаблонов = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Наименование", "Шаблоны сообщений для триггеров" + "%");	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ШаблоныСообщений.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	               |ГДЕ
	               |	ШаблоныСообщений.ЭтоГруппа = ИСТИНА
	               |	И ШаблоныСообщений.Наименование ПОДОБНО &Наименование";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда 
		ГруппаШаблонов_Объект						= Справочники.ШаблоныСообщений.СоздатьГруппу();
		ГруппаШаблонов_Объект.Наименование 			= "Шаблоны сообщений для триггеров";
		ГруппаШаблонов_Объект.УстановитьНовыйКод();							
		ГруппаШаблонов_Объект.ОбменДанными.Загрузка = Истина;
		Попытка
			ГруппаШаблонов_Объект.Записать();
			ГруппаШаблонов = ГруппаШаблонов_Объект.Ссылка;
		Исключение
			// Запись в лог						
			ЗаписьЖурналаРегистрации("Ошибка создания группы шаблонов сообщений!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ШаблоныСообщений, , ОписаниеОшибки());			
		КонецПопытки;	
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда 
			ГруппаШаблонов = Выборка.Ссылка;
		КонецЕсли;	
	КонецЕсли;

	Возврат ГруппаШаблонов;
	
КонецФункции

// Процедура - Актуализировать взаимодействия по продаже членства
//
Процедура АктуализироватьВзаимодействияПоПродажеЧленства() Экспорт
	
	// Подготавливаем данные для генерации сделок
	Отказ 		= Ложь;
	Запрос 		= Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВидыСделок.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ВидыСделок КАК ВидыСделок
	               |ГДЕ
	               |	ВидыСделок.Предопределенный = ИСТИНА
	               |	И ВидыСделок.Ссылка = &ИмяПредопределенныхДанных";
	
	ВидСделок__ПродажаЧленства = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПродажаЧленства");
	
	Запрос.УстановитьПараметр("ИмяПредопределенныхДанных", ВидСделок__ПродажаЧленства);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		ВидСделки = Выборка.Ссылка;
	Иначе 	
		ВидСделки_Объект 							= Справочники.ВидыСделок.СоздатьЭлемент();
		ВидСделки_Объект.Наименование 				= НСтр("ru = 'Новая продажа'; en = 'New sale'");
		ВидСделки_Объект.ИмяПредопределенныхДанных 	= "ПродажаЧленства";
		ВидСделки_Объект.ТипСделки 					= Перечисления.ТипыСделок.Продажа;
		ВидСделки_Объект.УстановитьНовыйКод();
		ВидСделки_Объект.ОбменДанными.Загрузка 		= Истина;
		Попытка
			ВидСделки_Объект.Записать();
			ВидСделки = ВидСделки_Объект.Ссылка;
		Исключение
			Отказ = Истина;
			ЗаписьЖурналаРегистрации("Ошибка создания вида сделки!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ВидыСделок, , ОписаниеОшибки());			
		КонецПопытки;	
	КонецЕсли;
	
	Если Отказ = Истина Тогда 
		Возврат;
	КонецЕсли;
	
	МассивТочекМаршрута = Новый Массив;
	МассивТочекМаршрута.Добавить(БизнесПроцессы.ПродажаЧленства_КОРП.ТочкиМаршрута.ДействиеПервичныйКонтакт);
	МассивТочекМаршрута.Добавить(БизнесПроцессы.ПродажаЧленства_КОРП.ТочкиМаршрута.ДействиеПрезентацияКлиники);
	МассивТочекМаршрута.Добавить(БизнесПроцессы.ПродажаЧленства_КОРП.ТочкиМаршрута.ДействиеПробноеЗанятие);
	МассивТочекМаршрута.Добавить(БизнесПроцессы.ПродажаЧленства_КОРП.ТочкиМаршрута.ДействиеОформлениеПродажи);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЭтапыСделок.Ссылка КАК Ссылка,
	               |	ЭтапыСделок.Наименование КАК Наименование,
	               |	ЭтапыСделок.ВидСделки КАК ВидСделки,
	               |	ЭтапыСделок.НомерЭтапа КАК НомерЭтапа,
	               |	ЗНАЧЕНИЕ(БизнесПроцесс.ПродажаЧленства_КОРП.ТочкаМаршрута.ПустаяСсылка) КАК ТочкаМаршрута
	               |ИЗ
	               |	Справочник.ЭтапыСделок КАК ЭтапыСделок
	               |ГДЕ
	               |	ЭтапыСделок.ВидСделки = &ВидСделки
	               |	И НЕ ЭтапыСделок.Ссылка В(ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Успех), ЗНАЧЕНИЕ(Справочник.ЭтапыСделок.Отказ))
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерЭтапа";
	
	Запрос.УстановитьПараметр("ВидСделки", ВидСделки);
	ТаблицаЭтаповСделок = Запрос.Выполнить().Выгрузить();
	НомерЭтапа = 0;
	
	Для Каждого ТочкаМаршрута Из МассивТочекМаршрута Цикл
		НомерЭтапа = НомерЭтапа + 1;
		СтрокаЭтап = ТаблицаЭтаповСделок.Найти(ТочкаМаршрута.НаименованиеЗадачи, "Наименование");
		Если НЕ ЗначениеЗаполнено(СтрокаЭтап) Тогда
			ЭтапСделки_Объект 						= Справочники.ЭтапыСделок.СоздатьЭлемент();
			ЭтапСделки_Объект.Наименование 			= ТочкаМаршрута.НаименованиеЗадачи;
			ЭтапСделки_Объект.ВидСделки 			= ВидСделки;
			ЭтапСделки_Объект.НомерЭтапа 			= НомерЭтапа;
			Если НомерЭтапа = 1 Тогда 
				ЭтапСделки_Объект.ЦветЭтапа 		= ЗначениеВСтрокуВнутр(Новый Цвет(255, 254, 178));
			ИначеЕсли НомерЭтапа = 2 Тогда 
				ЭтапСделки_Объект.ЦветЭтапа 		= ЗначениеВСтрокуВнутр(Новый Цвет(255, 200, 200));
			ИначеЕсли НомерЭтапа = 3 Тогда 
				ЭтапСделки_Объект.ЦветЭтапа 		= ЗначениеВСтрокуВнутр(Новый Цвет(152, 203, 255));
			ИначеЕсли НомерЭтапа = 4 Тогда 
				ЭтапСделки_Объект.ЦветЭтапа 		= ЗначениеВСтрокуВнутр(Новый Цвет(222, 255, 129));
			КонецЕсли;	
			ЭтапСделки_Объект.УстановитьНовыйКод();
			ЭтапСделки_Объект.ОбменДанными.Загрузка = Истина;
			Попытка
				ЭтапСделки_Объект.Записать();
				НоваяСтрокаЭтап 					= ТаблицаЭтаповСделок.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаЭтап, ЭтапСделки_Объект);
				НоваяСтрокаЭтап.ТочкаМаршрута 		= ТочкаМаршрута;
			Исключение
				Отказ = Истина;
				ЗаписьЖурналаРегистрации("Ошибка создания этапа сделки!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ЭтапыСделок, , ОписаниеОшибки());			
			КонецПопытки;
		Иначе 
			СтрокаЭтап.ТочкаМаршрута 				= ТочкаМаршрута;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ Справочники.ЭтапыСделок.Успех.ВидСделки = ВидСделки Тогда 
		Этап_Успех 							= Справочники.ЭтапыСделок.Успех.ПолучитьОбъект();
		// Этап_Успех.ВидСделки 				= ВидСделки;
		// Этап_Успех.НомерЭтапа 				= 5;
		Этап_Успех.ЦветЭтапа 				= ЗначениеВСтрокуВнутр(Новый Цвет(72, 193, 123));		
		Этап_Успех.ОбменДанными.Загрузка 	= Истина;
		Попытка
			Этап_Успех.Записать();
		Исключение
			Отказ = Истина;
			ЗаписьЖурналаРегистрации("Ошибка редактирования предопределнного этапа сделки!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ЭтапыСделок, , ОписаниеОшибки());			
		КонецПопытки;	
	КонецЕсли;
	
	Если НЕ Справочники.ЭтапыСделок.Отказ.ВидСделки = ВидСделки Тогда 
		Этап_Отказ 							= Справочники.ЭтапыСделок.Отказ.ПолучитьОбъект();
		// Этап_Отказ.ВидСделки 				= ВидСделки;
		// Этап_Отказ.НомерЭтапа 				= 6;
		Этап_Отказ.ЦветЭтапа 				= ЗначениеВСтрокуВнутр(Новый Цвет(246, 110, 110));		
		Этап_Отказ.ОбменДанными.Загрузка 	= Истина;
		Попытка
			Этап_Отказ.Записать();
		Исключение
			Отказ = Истина;
			ЗаписьЖурналаРегистрации("Ошибка редактирования предопределнного этапа сделки!", УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.ЭтапыСделок, , ОписаниеОшибки());			
		КонецПопытки;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивТочекМаршрута"	, МассивТочекМаршрута);
	Запрос.УстановитьПараметр("ТекущаяДата"			, НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("Комментарий"			, "Пометка удаления: Нет -> Да" + "%");

	Запрос.Текст = "ВЫБРАТЬ
	               |	ПричиныОтказов.Ссылка КАК Ссылка,
	               |	ПричиныОтказов.Наименование КАК Наименование
	               |ИЗ
	               |	Справочник.ПричиныОтказов КАК ПричиныОтказов
	               |;
