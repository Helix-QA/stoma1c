//  Прием	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТипЗубнойФормулы(Контрагент, Дата, Прием) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗубнаяФормулаСрезПоследних.ТипЗубнойФормулы КАК ТипЗубнойФормулы
	|ИЗ
	|	РегистрСведений.ЗубнаяФормула.СрезПоследних(
	|			&Дата,
	|			Контрагент = &Контрагент
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЗубнаяФормулаСрезПоследних";  
	Запрос.УстановитьПараметр("Контрагент"        , Контрагент); 	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ?(Прием.Пустая(), ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница, Прием.СтруктурнаяЕдиница));
	Запрос.УстановитьПараметр("Дата"              , ?(Прием.Пустая(), ТекущаяДатаСеанса(), Дата)); 
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда
		ТипЗубнойФормулы = Выборка.ТипЗубнойФормулы;  
	Иначе
		ТипЗубнойФормулы = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Контрагент, "ТипЗубнойФормулы");  
	КонецЕсли;
	Возврат ТипЗубнойФормулы;
	
КонецФункции

