#Область СлужебныеПроцедурыИФункции

&НаСервере
// Заполнить таблицу акта отобранными документами прием
Функция ЗаполнитьТаблицуОказанныеУслуги(Контрагент,ТолькоНеОплченнымиДокументами)	
	
	ВременнаяТаблица = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ДанныеПоВзаиморасчетамДляКонтрагента(
		Объект.Контрагент,
		,Объект.СтруктурнаяЕдиница,
		ТолькоНеОплченнымиДокументами,,,
		Объект.Договор,
		Объект.Организация);
	
	Объект.ОказанныеУслуги.Очистить();
	Для Каждого СтрокаТ ИЗ ВременнаяТаблица Цикл	
		
		Если СтрокаТ.ДокументРеализации = Неопределено Тогда
			Продолжить;
		КонецЕсли;   
		
		Разрешено = Истина;
		Если  ЗначениеЗаполнено(Объект.НачалоПериода) И СтрокаТ.ДокументРеализации.Дата <= Объект.НачалоПериода Тогда
			Разрешено = Ложь;			
		КонецЕсли;			
		Если ЗначениеЗаполнено(Объект.ОкончаниеПериода) И СтрокаТ.ДокументРеализации.Дата >= КонецДня(Объект.ОкончаниеПериода) Тогда
			Разрешено = Ложь;
		КонецЕсли;		
		Если Разрешено Тогда
			НоваяСтрока                   = Объект.ОказанныеУслуги.Добавить();
			НоваяСтрока.ДокументОснования = СтрокаТ.ДокументРеализации;
			Если ТолькоНеОплченнымиДокументами Тогда
				НоваяСтрока.Сумма             = СтрокаТ.Задолженность;
			Иначе
				НоваяСтрока.Сумма             = СтрокаТ.СуммаДокумента;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецФункции

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	ОписаниеУслуги();
КонецПроцедуры

&НаКлиенте
Процедура ОписаниеУслуги()
	
	Если ЗначениеЗаполнено(Объект.НачалоПериода) и  ЗначениеЗаполнено(Объект.ОкончаниеПериода) Тогда
		Период = " за период с " + Формат(Объект.НачалоПериода, "ДФ=""дд.ММ.гггг 'г.'""") + " по " + Формат(Объект.ОкончаниеПериода, "ДФ=""дд.ММ.гггг 'г.'""");	
	ИначеЕсли ЗначениеЗаполнено(Объект.НачалоПериода) и  не ЗначениеЗаполнено(Объект.ОкончаниеПериода)  Тогда
		Период = " за период с " + Формат(Объект.НачалоПериода, "ДФ=""дд.ММ.гггг 'г.'""");
	ИначеЕсли не ЗначениеЗаполнено(Объект.НачалоПериода) и  ЗначениеЗаполнено(Объект.ОкончаниеПериода)  Тогда
		Период = " за период по " + Формат(Объект.ОкончаниеПериода, "ДФ=""дд.ММ.гггг 'г.'""");	
	Иначе
		Период = "";
	КонецЕсли;
	ДоговорСтрока = "";
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		
		НомерДоговора = НомерДоговораКонтрагента(Объект.Договор);
		ДатаДоговора  = ДатаДоговораКонтрагента(Объект.Договор);
		Если ЗначениеЗаполнено(НомерДоговора) и ЗначениеЗаполнено(ДатаДоговора) Тогда
			ДоговорСтрока = " по договору №" + НомерДоговора + " от " + ДатаДоговора;
		ИначеЕсли  ЗначениеЗаполнено(НомерДоговора) и не ЗначениеЗаполнено(ДатаДоговора)  Тогда
			ДоговорСтрока = " по договору №" + НомерДоговора;
		ИначеЕсли  не ЗначениеЗаполнено(НомерДоговора) и ЗначениеЗаполнено(ДатаДоговора)  Тогда
			ДоговорСтрока = " по договору от " + ДатаДоговора;
		Иначе 
			ДоговорСтрока = "";
		КонецЕсли;
		
	КонецЕсли;
	
	Объект.ОписаниеУслуги = "Оказание медицинских услуг" + Период + ДоговорСтрока;
	
КонецПроцедуры	

