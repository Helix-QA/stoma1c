// Процедура - Преобразовать для азербайджан
//
// Параметры:
//  Представление		 - 	 - 
//  СписокПолей			 - 	 - 
//  СтруктураРезультата	 - 	 - 
//
Процедура ПреобразоватьДля_Азербайджана(Представление, СписокПолей, СтруктураРезультата)
	
	ТелефонПредставление = СокрЛП(Представление);	
	// СписокПолей = "";
	КодСтраны     = "";
	КодГорода     = "";
	НомерТелефона = "";
	Добавочный    = "";
	Комментарий   = "";
	
	// Вычислим код страны
	КодСтраны = СтруктураРезультата.ФорматТелНомера;
	Если Не ЗначениеЗаполнено(КодСтраны) Тогда
		КодСтраны = "+994";
	КонецЕсли;
	
	// ----------------------Проверим комментарий--------------------------
	Поз = Найти(ТелефонПредставление, ", ");
	Если Поз <> 0 Тогда
		// Вырежем комментарий
		Комментарий 			= СокрЛП(Сред(ТелефонПредставление, Поз + 2));
		ТелефонПредставление 	= СтрЗаменить(ТелефонПредставление, Комментарий, "");
	КонецЕсли;	
	
	// Оставим одни лишь цифры
	НомерТелефона_ТолькоЦифры = УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(ТелефонПредставление);
	// Отсекаем лидирующие нули
	НомерТелефона_ТолькоЦифры = СтрЗаменить(СокрЛ(СтрЗаменить(НомерТелефона_ТолькоЦифры, "0", " ")), " ", "0");
	
	ПравильныйНомер = Ложь;	
	// Уберем код страны, если есть для правильного анализа
	НомерТелефонаБезКодаСтраны = НомерТелефона_ТолькоЦифры;
	Если СтрДлина(НомерТелефона_ТолькоЦифры) > 8 Тогда 
		Если СтрНайти(Лев(НомерТелефона_ТолькоЦифры, 3), "994") <> 0 Тогда 
			НомерТелефонаБезКодаСтраны = Сред(НомерТелефона_ТолькоЦифры, СтрНайти(Лев(НомерТелефона_ТолькоЦифры, 3), "994") + 3, 8);
			ПравильныйНомер = Истина;			
		КонецЕсли;
	КонецЕсли;
	
	Если СтрДлина(НомерТелефонаБезКодаСтраны) = 8 Тогда
		МассивКодовОператоров = ВернутьМассивМобильныхДвухЗначныхКодовДляАзербайджана();
		Если МассивКодовОператоров.Найти(Сред(НомерТелефонаБезКодаСтраны, 1, 2)) <> Неопределено Тогда
			КодГорода 		= Сред(НомерТелефонаБезКодаСтраны, 1, 2);
			НомерТелефона 	= Сред(НомерТелефонаБезКодаСтраны, 3, 6);
		ИначеЕсли Лев(НомерТелефонаБезКодаСтраны, 4) = "1864" Тогда // Это Сумгаит! 
			КодГорода 		= Сред(НомерТелефонаБезКодаСтраны, 1, 4);
			НомерТелефона 	= Сред(НомерТелефонаБезКодаСтраны, 5, 4);
		Иначе 
			КодГорода 		= Сред(НомерТелефонаБезКодаСтраны, 1, 3);
			НомерТелефона 	= Сред(НомерТелефонаБезКодаСтраны, 4, 5);
		КонецЕсли;
		ПравильныйНомер = Истина;
	Иначе 
		ПравильныйНомер = Ложь;	
	КонецЕсли;
	
	Если ПравильныйНомер Тогда 
		// ------------------- Поправим представление ------------------------
		Представление = СокрЛП(КодСтраны);				
		Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + "(" + СокрЛП(КодГорода) + ")";				
		Если Не ПустаяСтрока(НомерТелефона) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", " ") + СокрЛП(НомерТелефона);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Добавочный) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + "доб. " + СокрЛП(Добавочный);
		КонецЕсли;				
		Если НЕ ПустаяСтрока(Комментарий) Тогда
			Представление = Представление + ?(ПустаяСтрока(Представление), "", ", ") + СокрЛП(Комментарий);
		КонецЕсли;
		// --------------------------------------------------------------------
					
		СписокПолей.Добавить(?(КодСтраны = "994", КодСтраны, УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(КодСтраны)), "КОДСТРАНЫ");
		СписокПолей.Добавить(КодГорода		, "КОДГОРОДА");
		СписокПолей.Добавить(НомерТелефона	, "НОМЕРТЕЛЕФОНА");
		СписокПолей.Добавить(Добавочный		, "ДОБАВОЧНЫЙ");
		СписокПолей.Добавить(Представление	, "ПРЕДСТАВЛЕНИЕ");		
		СписокПолей.Добавить(Комментарий	, "КОММЕНТАРИЙ");
		
	Иначе
		СтруктураРезультата.ПравильныйНомер = Ложь;		
		ЗаполнитьПоляВЗаписиПоПредставлениюТелефон(Представление, СписокПолей, СтруктураРезультата);
	КонецЕсли;		
	
КонецПроцедуры

