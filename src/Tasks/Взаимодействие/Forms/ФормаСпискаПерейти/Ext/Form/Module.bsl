
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтотОбъект.Контрагент = ?(Параметры.Отбор.Свойство("МассивКлиентов"), ?(Параметры.Отбор.МассивКлиентов.Количество() > 0, Параметры.Отбор.МассивКлиентов[0], Неопределено), Неопределено);
	
	МассивСтруктурныхЕдиниц = Справочники.Сотрудники.ПолучитьМестаРаботыСотрудника(ПараметрыСеанса.ТекущийСотрудник, "Массив");
	ДатаРегистрации = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ЭтотОбъект.Контрагент, "ДатаРегистрации");
	ДатаНачала = ?(ЗначениеЗаполнено(ЭтотОбъект.Контрагент) И ЗначениеЗаполнено(ДатаРегистрации), ДатаРегистрации, Дата(1,1,1));
	Список.Параметры.УстановитьЗначениеПараметра("ПериодОтбораДатаНачала" 	, ДатаНачала);
	Список.Параметры.УстановитьЗначениеПараметра("ПериодОтбораДатаОкончания", ТекущаяДатаСеанса());
	
	Если Не ЗначениеЗаполнено(МассивСтруктурныхЕдиниц) Тогда		
		МассивСтруктурныхЕдиниц.Добавить(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);			
	КонецЕсли;
	
	ЭтотОбъект.ОтборСтруктурныеЕдиницы = Новый ФиксированныйМассив(МассивСтруктурныхЕдиниц);	
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Инициализируем настройки при первом открытии формы
	Если ХранилищеСистемныхНастроек.Загрузить("Задача.Взаимодействие.Форма.ФормаСпискаПерейти/ТекущиеДанные") = Неопределено Тогда
		Настройки = Новый Соответствие;
		ХранилищеСистемныхНастроек.Сохранить("Задача.Взаимодействие.Форма.ФормаСпискаПерейти/ТекущиеДанные", ,Настройки);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	ЭтоКорп = ОбщегоНазначенияПовтИсп.ЭтоВерсияКОРП();
	
КонецПроцедуры

&НаСервере
// Процедура - При загрузке данных из настроек на сервере
//
// Параметры:
//  Настройки	 - 	 - 
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	ИнициализироватьМеханизмФильтрацииДанных(Параметры.Отбор, Истина);
	СоздатьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОТБОРЫ_СПИСКА_ВЗАИМОДЕЙСТВИЙ" Тогда 
	КонецЕсли;
	
	Если ИмяСобытия = "ИзменениеЗадачи" Тогда		

	ИначеЕсли ИмяСобытия = "ОбновлениеМонитораЗадач" Тогда
		ПолучитьЗначенияОтборов();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура, обработчик события "СписокВыбор".
//
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущаяСтрока 		 = Элементы.Список.ТекущиеДанные;
	
	Если Поле.Имя = "Сделка"
		И ЗначениеЗаполнено(ТекущаяСтрока.Сделка) Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.Сделка);
		
	ИначеЕсли Поле.Имя = "Контрагент" 
		И ЗначениеЗаполнено(ТекущаяСтрока.Контрагент)Тогда
		
		ПоказатьЗначение(,ТекущаяСтрока.Контрагент);
		
	Иначе
		
		ПоказатьЗначение(,ТекущаяСтрока.Ссылка);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура - Список перед началом добавления
//
Процедура СписокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда 
		
		ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаЗадачи", Новый Структура("ЗначенияЗаполнения", Новый Структура("Контрагент", ЭтотОбъект.Контрагент)), ЭтаФорма);
		Отказ = Истина;
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаВыбора".
//
Процедура ДействиеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	УстановитьВидмостьВсплывающейГруппы(ВыбранноеЗначение);

КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ТаблицаДействияПроцентПриИзменении(Элемент)
	
	СуммаПроцентов   = ЭтотОбъект.ТаблицаДействия.Итог("Пропорция");
	ОстатокПроцентов = 100 - СуммаПроцентов;
	
	Если ОстатокПроцентов = 0 Тогда
		
		Элементы.ОстаточныйПроцент.Видимость = НЕ Элементы.ОстаточныйПроцент.Видимость;
		
	Иначе
		
		ЭтотОбъект.ОстаточныйПроцентОтДеления = ОстатокПроцентов;
		Элементы.ОстаточныйПроцент.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ТаблицаДействияСотрудникПриИзменении(Элемент)
	
	ЗаполнитьПроцентомСтрокиТЗ();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Создать
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Создать(Команда)
	
	ОткрытьФорму("Задача.Взаимодействие.ФормаОбъекта", Новый Структура("ЗначенияЗаполнения", Новый Структура("Контрагент", ?(Этаформа.ВладелецФормы.Параметры.Свойство("Ключ"), Этаформа.ВладелецФормы.Параметры.Ключ, Неопределено))));	
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "Изменить".
//
Процедура Изменить(Команда)
	
	ЭтотОбъект.Действие = "Исполнитель";	
	УстановитьВидмостьВсплывающейГруппы(ЭтотОбъект.Действие);
	
	ВыделенныеЭлементы = Элементы.Список.ВыделенныеСтроки.Количество();
	Если ВыделенныеЭлементы > 1 Тогда
		Элементы.Применить.Заголовок = Нстр("ru = 'Применить к '; en = 'Apply to '") + ВыделенныеЭлементы; 
	Иначе
		Элементы.Применить.Заголовок = Нстр("ru = 'Применить к '; en = 'Apply to '") + ЭтотОбъект.КоличествоЗадач;	
	КонецЕсли;
	
	Элементы.ГруппаИзменитьВсплывающая.Показать();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ДействияДобавить".
//
Процедура ДействияДобавить(Команда)
	
	НоваяСтрока = ЭтотОбъект.ТаблицаДействия.Добавить();	
	Элементы.ТаблицаДействия.ТекущаяСтрока = ЭтотОбъект.ТаблицаДействия.Индекс(НоваяСтрока);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ДействияУдалить".
//
Процедура ДействияУдалить(Команда)
	
	ТекущиеДанные = Элементы.ТаблицаДействия.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		ЭтотОбъект.ТаблицаДействия.Удалить(ТекущиеДанные);
		ЗаполнитьПроцентомСтрокиТЗ();

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события команды "Применить".
//
Процедура Применить(Команда)
	
	ВопросОбИзменении()	
		
КонецПроцедуры

&НаКлиенте
// Процедура, ВопросОИзменении.
//
Процедура ВопросОбИзменении()
	
	ВыделенныеЭлементы = Элементы.Список.ВыделенныеСтроки.Количество();
	Если ВыделенныеЭлементы > 1 Тогда
		Вопрос = СтрШаблон(НСтр("ru='Внимание!!! Изменения будут применены ко всем %1 выделенным строкам в списке. Эти изменения необратимы. Продолжить?';en='Attention!!! Changes will be applied to to all %1 selected lines in list. These changes are irreversible. Continue?'"), ВыделенныеЭлементы);
	Иначе
		Вопрос = СтрШаблон(НСтр("ru = 'Внимание!!! Изменения будут применены ко всем %1 видимым строкам в списке (даже не выделенным). Эти изменения необратимы. Продолжить?'; en = 'text %1 text'"), ЭтотОбъект.КоличествоЗадач);
	КонецЕсли;

	
	Оповещение = Новый ОписаниеОповещения("ПослеВопросаОбИзменении", ЭтотОбъект, Новый Структура("КоличествоВыделенныхСтрок", ВыделенныеЭлементы)); 
	ПоказатьВопрос(Оповещение,
	Вопрос,
	РежимДиалогаВопрос.ДаНет,
	0, // таймаут в секундах
	КодВозвратаДиалога.Да, // (необ.) кнопка по умолчанию
	НСтр("ru = 'Вопрос пользователю'; en = 'Question to user'") // (необ.) заголовок
	); 	
	
КонецПроцедуры

&НаКлиенте
// Процедура, ПослеВопросаОбИзменении.
//
Процедура ПослеВопросаОбИзменении(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ПрименитьНаСервере(ДопПараметры);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбновитьДинамическоеМеню

&НаСервере
// Процедура - Инициализировать механизм фильтрации данных
//
// Параметры:
//  ПараметрыОтбора	 - 	 - 
//  ОбновитьСписок	 - 	 - 
//
Процедура ИнициализироватьМеханизмФильтрацииДанных(ПараметрыОтбора = Неопределено, ОбновитьСписок = Ложь)
	
	// Обновляем отборы согласно параметров, переданных из другой формы	и уходим	
 	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ОчиститьВсеОтборы") И ПараметрыОтбора.ОчиститьВсеОтборы = Истина Тогда
		ОбновитьЗначенияФильтрацииДанных(ПараметрыОтбора); // Перешли из монитора при уже открытой текущей формы
		Возврат;
	КонецЕсли; 
	
	МассивКлиентов = Новый Массив;
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКлиентов") Тогда
	   МассивКлиентов = ПараметрыОтбора.МассивКлиентов; 
	КонецЕсли;
		
	РезультатПакетногоЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов();	
	
	// Отбор статус. 
 	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовЗадач");	
	ОбновитьДинамическоеМенюФильтрации_Статус(, УстановитьОтбор);
	Если УстановитьОтбор Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусовЗадач, Истина);
	КонецЕсли;
		
	// Отбор вид взаимодействия. 
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовВзаимодействия");
	ОбновитьДинамическоеМенюФильтрации_ВидВзаимодействия(РезультатПакетногоЗапроса[2].Выгрузить(), Истина);
	Если УстановитьОтбор Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидВзаимодействия", ПараметрыОтбора.МассивВидовВзаимодействия, Истина);		
	КонецЕсли;
	
	Если ЭтоКорп Тогда
		// Отбор Вид сделки. 
		УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивВидовСделок");
		ОбновитьДинамическоеМенюФильтрации_ВидСделки(РезультатПакетногоЗапроса[3].Выгрузить(), УстановитьОтбор);
		Если УстановитьОтбор Тогда 		
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок, Истина);
			ОбновитьСписок = Истина;		
		КонецЕсли;
		
		// Отбор этап. 
		УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивЭтапов");
		ОбновитьДинамическоеМенюФильтрации_Этап(РезультатПакетногоЗапроса[0].Выгрузить(), УстановитьОтбор);
		Если УстановитьОтбор Тогда 		
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов, Истина);
			ОбновитьСписок = Истина;		
		КонецЕсли;
	КонецЕсли;
	
	// Отбор контрагент. 
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКлиентов");
	ОбновитьДинамическоеМенюФильтрации_Контрагент(, УстановитьОтбор);
	Если УстановитьОтбор Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Контрагент", ПараметрыОтбора.МассивКлиентов, Ложь);
		ОбновитьСписок = Истина;		
	КонецЕсли;
	
	// Отбор структурная единица.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц");
	Если УстановитьОтбор И НЕ ЗначениеЗаполнено(ПараметрыОтбора.МассивСтруктурныхЕдиниц) Тогда	
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[6].Выгрузить(), УстановитьОтбор);
	Иначе 
		ОбновитьДинамическоеМенюФильтрации_СтруктурнаяЕдиница(РезультатПакетногоЗапроса[5].Выгрузить(), УстановитьОтбор);
	КонецЕсли;	
	Если УстановитьОтбор Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц, Истина);
	КонецЕсли;
	
	Если ЭтоКорп Тогда
		// Отбор признак наличия сделки. 
		УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок");
		ОбновитьДинамическоеМенюФильтрации_Сделка(,УстановитьОтбор);
		Если УстановитьОтбор Тогда 
			
			МассивСтатусовНаличияСделок = Новый Массив();
			Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияСделок) 
				И ПараметрыОтбора.МассивСтатусовНаличияСделок[0] = Нстр("ru = 'Нет сделок'; en = 'No deals'") Тогда
				
				МассивСтатусовНаличияСделок.Добавить(Ложь);
			Иначе
				МассивСтатусовНаличияСделок.Добавить(Истина);		
			КонецЕсли;
			
			УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Сделка", МассивСтатусовНаличияСделок, Истина);
			ОбновитьСписок = Истина;
		КонецЕсли;
	КонецЕсли;

	// Отбор пометка удаления задачи.
	УстановитьОтбор = Ложь;// Истина; 
	ОбновитьДинамическоеМенюФильтрации_ПометкаУдаленияЗадачи(, УстановитьОтбор);
	Если УстановитьОтбор Тогда
		СписокСтатусовПометокУдаления = Новый СписокЗначений;
		СписокСтатусовПометокУдаления.Добавить(Истина, , Ложь);
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияЗадачи", СписокСтатусовПометокУдаления, Истина);		
		ОбновитьСписок = Истина;		
	КонецЕсли;
	
	// Отбор исполнитель. 
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивИсполнителей"); // Перешли из монитора, открывая форму
	ОбновитьДинамическоеМенюФильтрации_Исполнитель(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Исполнитель", ПараметрыОтбора.МассивИсполнителей, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"));
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор кто выполнил.
	УстановитьОтбор = ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивКтоВыполнил"); // Перешли из монитора, открывая форму
	ОбновитьДинамическоеМенюФильтрации_КтоВыполнил(РезультатПакетногоЗапроса[1].Выгрузить(), УстановитьОтбор);
	Если УстановитьОтбор Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_КтоВыполнил", ПараметрыОтбора.МассивКтоВыполнил, Истина, НСтр("ru = '<не указан>'; en = '<not specified>'"));
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор пеориод тип.
	Если ПараметрыОтбора <> Неопределено И ТипЗнч(ПараметрыОтбора) = Тип("Структура") И (ПараметрыОтбора.Свойство("ОтборПериодТип") И ПараметрыОтбора.Свойство("ОтборПериодЗначение") ИЛИ ПараметрыОтбора.Свойство("МассивСтатусовЗадач")) Тогда 
		Если УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус").НайтиПоЗначению("Просрочена") <> Неопределено Тогда 
			ПериодОтбора.ДатаНачала    	= Дата(01, 01, 0001);
			ПериодОтбора.ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;
			ВыбранныйПериод 			= 4;
			УстановитьСвойстваОтображенияЭлементов();
		ИначеЕсли ПараметрыОтбора.Свойство("ОтборПериодТип") И ПараметрыОтбора.Свойство("ОтборПериодЗначение") Тогда 
			Если ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.День Тогда 
				ВыбранныйПериод 		= 0;
				ПериодОтбора 			= ПараметрыОтбора.ОтборПериодЗначение;
				ПериодОтбора.Вариант 	= ПараметрыОтбора.ОтборПериодЗначение.Вариант;				
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
				ВыбранныйПериод 		= 2;
				ПериодОтбора 			= ПараметрыОтбора.ОтборПериодЗначение;				
				ПериодОтбора.Вариант 	= ПараметрыОтбора.ОтборПериодЗначение.Вариант;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда
				ВыбранныйПериод 		= 3;
				ПериодОтбора 			= ПараметрыОтбора.ОтборПериодЗначение;
				ПериодОтбора.Вариант 	= ПараметрыОтбора.ОтборПериодЗначение.Вариант;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Час Тогда
				ВыбранныйПериод 		= 4;
				ПериодОтбора 			= ПараметрыОтбора.ОтборПериодЗначение;				
			КонецЕсли;
		КонецЕсли;
		ОбновитьСписок = Истина;
		УстановитьСвойстваОтображенияЭлементов();		
	КонецЕсли;
	
	Если ОбновитьСписок Тогда 
		АктуализироватьДанныеСпискаСогласноОтборов();	
	КонецЕсли; 	
	
КонецПроцедуры   

