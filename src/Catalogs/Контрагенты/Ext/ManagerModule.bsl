КонецФункции

 // Функция, получает информацию из табличных частей справочника и формирует структуру.  
//
Функция ПолучитьМассивТелефоновИEmailКонтрагента(Контрагент) Экспорт
	
	СтруктураВозврата = Новый Структура("Телефоны, Email", Новый Массив, Новый Массив);
	
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)
	|	И КонтрагентыКонтактнаяИнформация.НомерТелефона <> """"
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыКонтактнаяИнформация.АдресЭП КАК АдресЭП
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКлиента)
	|	И КонтрагентыКонтактнаяИнформация.АдресЭП <> """"");
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	МассивТелефонов 	= ПакетЗапросов[0].Выгрузить().ВыгрузитьКолонку("НомерТелефона");	
	МассивEmail 		= ПакетЗапросов[1].Выгрузить().ВыгрузитьКолонку("АдресЭП");
	
	СтруктураВозврата.Телефоны	= МассивТелефонов;
	СтруктураВозврата.Email		= МассивEmail;
	
	Возврат СтруктураВозврата;
	
