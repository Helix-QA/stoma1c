// Функция - Вернуть имя табличной части для начисления бонусов
//
// Параметры:
//  РеализацияОбъект - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьИмяТабличнойЧастиДляНачисленияБонусов(РеализацияОбъект) 

	Если ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Запасы", РеализацияОбъект.Ссылка.Метаданные())
		И РеализацияОбъект.Запасы.Количество() > 0 Тогда
		Возврат "Запасы";
	ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Лечение", РеализацияОбъект.Ссылка.Метаданные())
		И РеализацияОбъект.Лечение.Количество() > 0 Тогда
		Возврат "Лечение";
	ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьТабличнаяЧастьДокумента("Услуги", РеализацияОбъект.Ссылка.Метаданные())
		И РеализацияОбъект.Услуги.Количество() > 0 Тогда
		Возврат "Услуги";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

