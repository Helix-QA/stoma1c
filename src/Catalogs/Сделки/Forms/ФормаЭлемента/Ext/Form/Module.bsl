	Если НЕ (ЗначениеЗаполнено(Объект.Менеджер) И ТипЗнч(Объект.Менеджер) = Тип("СправочникСсылка.Пользователи")) Тогда 
		МассивТипов = Новый Массив(); 
		МассивТипов.Добавить(Тип("СправочникСсылка.Сотрудники")); 
		НашеОписание = Новый ОписаниеТипов(МассивТипов);
		
		Элементы.Менеджер.ОграничениеТипа = НашеОписание; 
