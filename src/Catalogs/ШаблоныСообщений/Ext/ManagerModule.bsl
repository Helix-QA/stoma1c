// Функция - Преобразовать содержание с параметрами в текст.
//
Функция ПреобразоватьСодержаниеСПараметрамиВТекст(Знач Содержание, Документ, Получатель, ЭтоДокументОснование = Ложь, НеСообщатьОбОшибках = Ложь, Карта = Неопределено) Экспорт
	
	// Получаем значение параметров
	МассивПараметров = ПолучитьМассивПараметровИзШаблона(Содержание, "{}");
	Для Каждого Параметр Из МассивПараметров Цикл
		
		Результат = Неопределено;
		Попытка 
			Если Параметр = "Email" Тогда
				МассивЭлПочты = Получатель.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)); 
				Результат = ?(МассивЭлПочты.Количество() > 0, МассивЭлПочты[0].Представление, "");
			ИначеЕсли Параметр = "ДатаОкончанияМедицинскойСправки" Тогда
				МедСправкаКлиента = РегистрыСведений.МедицинскиеСправкиКлиентов.ПолучитьМедицинскуюСправкуКонтрагента(Получатель,, ТекущаяДатаСеанса());
				Результат = ?(МедСправкаКлиента <> Неопределено, Формат(МедСправкаКлиента.ДатаОкончания, "ДЛФ=ДД"), ""); 
			ИначеЕсли Параметр = "КороткийАдресКлиники" Тогда
				Адрес = Справочники.СтруктурныеЕдиницы.ПолучитьАдресСтруктурнойЕдиницы(Получатель.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.КороткийАдресСтруктурнойЕдиницы);
				Результат = ?(ЗначениеЗаполнено(Адрес), Адрес, "");
			ИначеЕсли Параметр = "ПолныйАдресКлиники" Тогда
				ПолныйАдрес = Справочники.СтруктурныеЕдиницы.ПолучитьАдресСтруктурнойЕдиницы(Получатель.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
				Результат = ?(ЗначениеЗаполнено(ПолныйАдрес), ПолныйАдрес, ""); 
			ИначеЕсли Параметр = "СайтКлиники" Тогда	
				Сайт = Справочники.СтруктурныеЕдиницы.ПолучитьСайтСтруктурнойЕдиницы(Получатель.СтруктурнаяЕдиница);
				Результат = ?(ЗначениеЗаполнено(Сайт), Сайт, ""); 
			ИначеЕсли Параметр = "ЯндексКарты" Тогда	
				Сайт = Справочники.СтруктурныеЕдиницы.ПолучитьЯндексКартыСтруктурнойЕдиницы(Получатель.СтруктурнаяЕдиница);
				Результат = ?(ЗначениеЗаполнено(Сайт), Сайт, ""); 
	        ИначеЕсли Параметр = "ЯндексОтзывы" Тогда	
				Сайт = Справочники.СтруктурныеЕдиницы.ПолучитьЯндексОтзывыСтруктурнойЕдиницы(Получатель.СтруктурнаяЕдиница);
				Результат = ?(ЗначениеЗаполнено(Сайт), Сайт, ""); 
			ИначеЕсли Параметр = "ДатаОкончанияПолиса" ИЛИ Параметр = "СерияПолиса"	ИЛИ Параметр = "НомерПолиса" ИЛИ Параметр = "ЛимитПолиса" Тогда 
				Результат = "";
				Если ЗначениеЗаполнено(Документ.ДокументОснование) И ТипЗнч(Документ.ДокументОснование) = Тип("ДокументСсылка.Событие") Тогда
					 ПолисМедСтрахования = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Документ.ДокументОснование, "ПолисМедСтрахования");
					 Если ЗначениеЗаполнено(ПолисМедСтрахования) Тогда 
						 Если Параметр = "ДатаОкончанияПолиса" Тогда
							 ДатаОкончания = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ПолисМедСтрахования, "ДатаОкончания");
							 Результат = ?(ЗначениеЗаполнено(ДатаОкончания), Формат(ДатаОкончания, "ДЛФ=DD"), "");
						ИначеЕсли Параметр = "СерияПолиса" Тогда	 
							 Результат = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ПолисМедСтрахования, "СерияПолиса"); 
						ИначеЕсли Параметр = "НомерПолиса" Тогда	 
							 Результат = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ПолисМедСтрахования, "НомерПолиса");
	                    ИначеЕсли Параметр = "ЛимитПолиса" Тогда	 
							 ЛимитПолиса = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ПолисМедСтрахования, "ЛимитПолиса"); 
							 Результат = ?(ЗначениеЗаполнено(ЛимитПолиса), Строка(ЛимитПолиса), "");
						КонецЕсли;
					 КонецЕсли;
				КонецЕсли; 			
			Иначе
				Выполнить("Результат = " + ВернутьПутьКРеквизитуПоПредставлении(Параметр));
			КонецЕсли;
		Исключение
			Ошибка = Истина;
		КонецПопытки; 		
		
		Если Карта <> Неопределено Тогда
			
			Если Найти(НРег(Параметр), "владелец") <> 0 Тогда
				
				Результат = СокрЛП(Карта.ВладелецКарты.Наименование);	
				
			ИначеЕсли Найти(НРег(Параметр), "датаоткрытия") <> 0 Тогда
				
				Результат = Формат(Карта.ДатаОткрытия, "ДФ=dd.MM.yyyy");
				
			ИначеЕсли Найти(НРег(Параметр), "номер") <> 0 Тогда
				
				Результат = СокрЛП(Карта.КодКарты); 

			ИначеЕсли Найти(НРег(Параметр), "наименование") <> 0 Тогда
				
				Результат = СокрЛП(Карта.Наименование);
				
			ИначеЕсли Новый_Массив("ссылканаустановкукарты", "ссылка").Найти(НРег(Параметр)) <> Неопределено Тогда
				
				Результат = ПолучитьСсылкуСозднанияКарты(Карта.СсылкаНаУстановкуКарты); 
				
			КонецЕсли;
		КонецЕсли;
		Если Результат <> Неопределено Тогда
			Содержание = СтрЗаменить(Содержание, "{" + Параметр + "}", Результат);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Содержание;
	
КонецФункции

// Функция, возвращает короткую ссылку на создание карты
//
Функция ПолучитьСсылкуСозднанияКарты(СсылкаНаУстановкуКарты)
	
	//link = СтрШаблон("https://webcitrus.app/getcard/%1/%2", ТокенДоступа, НомерКарты);  	
	
	ДеталиСсылки = Новый Структура;
	ДеталиСсылки.Вставить("domainUriPrefix", "https://glk.me");	
	ДеталиСсылки.Вставить("link", СсылкаНаУстановкуКарты);		
	
	ДанныеСсылки = Новый Структура("dynamicLinkInfo, suffix", ДеталиСсылки, Новый Структура("option", "SHORT"));	
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);		
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);	
	ЗаписатьJSON(ЗаписьJSON, ДанныеСсылки); 	
	ДанныеJSON = ЗаписьJSON.Закрыть();
	
	Попытка		
		HTTPСоединение = Новый HTTPСоединение("firebasedynamiclinks.googleapis.com",,,,,, Новый ЗащищенноеСоединениеOpenSSL());
		ЗаголовкиHTTP  = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json");
		
		HTTPЗапрос = Новый HTTPЗапрос("/v1/shortLinks/?key=AIzaSyAoS1PL4lwzRZWxMlPY1fGex4OC1L65jhw", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(ДанныеJSON); 		
		
		Запрос = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		ТекстJSON  = Запрос.ПолучитьТелоКакСтроку();  
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON); 
	Исключение		
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("ПолучениеКороткойСсылки", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
		Возврат Неопределено;        
	КонецПопытки;
	
	Если Запрос.КодСостояния = 200 Тогда
		Возврат ПараметрыJSON.shortLink;
	Иначе
		ОписаниеОшибки = "Код состояния: " + Запрос.КодСостояния + Символы.ПС + ТекстJSON;
		ЗаписьЖурналаРегистрации("ПолучениеКороткойСсылки", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);		
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

// Функция - Получить массив параметров из шаблона.
//
Функция ПолучитьМассивПараметровИзШаблона(ФормулаШаблона, ЗнакиВыделения = "{}")
	
	МассивПараметров = Новый Массив;
	
	НачалоПараметра = 0;
	КонецПараметра	= 0;	
	
	ЕстьStyle			= СтрНайти(ФормулаШаблона, "<style") <> 0 И СтрНайти(ФормулаШаблона, "</style>") <> 0; 
	НачальноеЗначение	= ?(ЕстьStyle, СтрНайти(ФормулаШаблона, "</style>") + СтрДлина("</style>"), 1);
		
	Для а = НачальноеЗначение По СтрДлина(ФормулаШаблона) Цикл
		Если Сред(ФормулаШаблона, а, 1) = Сред(ЗнакиВыделения, 1, 1) Тогда
			НачалоПараметра = а + 1;
		ИначеЕсли Сред(ФормулаШаблона, а, 1) = Сред(ЗнакиВыделения, 2, 1) Тогда
			КонецПараметра = а - 1;			
		КонецЕсли;
		Если НачалоПараметра <> 0 И КонецПараметра <> 0 И (КонецПараметра - НачалоПараметра + 1) > 0 Тогда
			МассивПараметров.Добавить(Сред(ФормулаШаблона, НачалоПараметра, КонецПараметра - НачалоПараметра + 1));
			НачалоПараметра = 0;
			КонецПараметра = 0;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивПараметров;
	
КонецФункции

// Функция - Вернуть путь к реквизиту по представлении.
//
Функция ВернутьПутьКРеквизитуПоПредставлении(Наименование, ЭтоДокументОснование = Ложь)
		
	СписокПараметров = Новый СписокЗначений;
	СписокПараметров.Добавить("Фамилия"                         , "Получатель.Фамилия");
	СписокПараметров.Добавить("Имя"                             , "Получатель.Имя");
	СписокПараметров.Добавить("Отчество"                        , "Получатель.Отчество");
	СписокПараметров.Добавить("ФИО"                             , "Получатель.Наименование");  
	СписокПараметров.Добавить("День"                            , "Формат(Документ.ДокументОснование.Дата, ""ДФ='dd MMMM'"")");
	СписокПараметров.Добавить("Время"                           , "Формат(Документ.ДокументОснование.Дата, ""ДФ=HH:mm"")");
	СписокПараметров.Добавить("День и время"                    , "Формат(Документ.ДокументОснование.Дата, ""ДФ='dd MMMM HH:mm'"")");
	СписокПараметров.Добавить("Сотрудник"                       , "Документ.ДокументОснование.Врач");
	СписокПараметров.Добавить("Услуга"                          , "Документ.ДокументОснование.Номенклатура");
	СписокПараметров.Добавить("Структурная единица"             , "Документ.ДокументОснование.СтруктурнаяЕдиница");
	                                                
	СписокПараметров.Добавить("ФамилияПациента"            		, "Получатель.Фамилия");
	СписокПараметров.Добавить("ИмяПациента"            			, "Получатель.Имя");
	СписокПараметров.Добавить("ОтчествоПациента"				, "Получатель.Отчество");
	СписокПараметров.Добавить("НаименованиеПациента"            , "Получатель.Наименование");
	СписокПараметров.Добавить("ФИОПациента"                     , "Получатель.НаименованиеПолное"); 
	СписокПараметров.Добавить("НаименованиеПациентаСокращенное" , "Получатель.НаименованиеСокращенное");
	СписокПараметров.Добавить("ДатаРегистрации"           		, "Формат(Получатель.ДатаРегистрации, ""ДЛФ=ДД"")");
	СписокПараметров.Добавить("Клиника"        					, "Получатель.СтруктурнаяЕдиница.Наименование");
	СписокПараметров.Добавить("ДатаРожденияПациента"           	, "Формат(Получатель.ДатаРожденияКлиента, ""ДЛФ=ДД"")");
	СписокПараметров.Добавить("КураторФИО"            		    , "Получатель.Куратор.Наименование");
	СписокПараметров.Добавить("КураторИмя"            			, "Получатель.Куратор.Имя");
	СписокПараметров.Добавить("Телефон"            				, "Получатель.Телефон");  
