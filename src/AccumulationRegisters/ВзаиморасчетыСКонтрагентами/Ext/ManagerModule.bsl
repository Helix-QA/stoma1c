// Получить аванса по документу
Функция ПолучитьСуммуВнесенногоАвансПоДокументу(ДокументАванса,ПериодОтбора = Неопределено) Экспорт
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход) КАК СуммаПриход
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|			,
	|			&ПериодОтбора,
	|			,
	|			ДокументАванса = &ДокументАванса
	|				И ДокументРеализации = НЕОПРЕДЕЛЕНО) КАК ВзаиморасчетыСКонтрагентамиОбороты";
	
    Запрос.УстановитьПараметр("ДокументАванса",ДокументАванса);	
    Запрос.УстановитьПараметр("ПериодОтбора",?(ЗначениеЗаполнено(ПериодОтбора),ПериодОтбора,ТекущаяДата()));	
	Возврат Запрос.Выполнить().Выгрузить().Итог("СуммаПриход");
КонецФункции

// Получить задолженность для документа реализации по конкретному авансовому документу
Функция ПолучитьЗадолженностьПоДокументуРеализацииНаОснованииАванса(
	ДокументРеализации,
	ДокументАванса,
	ПериодОтбора = Неопределено) Экспорт
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ЕстьNull(ВзаиморасчетыСКонтрагентамиОбороты.СуммаРасход, 0)) КАК СуммаРасход
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|			,
	|			&ПериодОтбора,
	|			,
	|			ДокументАванса = &ДокументАванса
	|				И ДокументРеализации = &ДокументРеализации) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СУММА(ЕстьNull(ВзаиморасчетыСКонтрагентамиОбороты.СуммаРасход, 0))
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|			,
	|			&ПериодОтбора,
	|			,
	|			ВЫБОР
	|					КОГДА &ДокументОснование <> НЕОПРЕДЕЛЕНО
	|						ТОГДА ДокументАванса = &ДокументОснование
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ
	|				И ДокументРеализации = &ДокументРеализации) КАК ВзаиморасчетыСКонтрагентамиОбороты";
	
    Запрос.УстановитьПараметр("ДокументАванса", ДокументАванса);
	Если ТипЗнч(ДокументАванса) = Тип("ДокументСсылка.НарядЗаказ") Тогда		
	    Запрос.УстановитьПараметр("ДокументОснование", ДокументАванса.ДокументОснование);	
	Иначе
		Запрос.УстановитьПараметр("ДокументОснование", Неопределено);	
	КонецЕсли;
	
    Запрос.УстановитьПараметр("ДокументРеализации", ДокументРеализации);	
    Запрос.УстановитьПараметр("ПериодОтбора",?(ЗначениеЗаполнено(ПериодОтбора),ПериодОтбора,ТекущаяДата()));	
	Возврат Запрос.Выполнить().Выгрузить().Итог("СуммаРасход");

КонецФункции

// Получить сумму аванса по взаиморасчетам с контрагентом
Функция ПолучитьОстатокАвансаПоКонтрагенту(
	Контрагент,
	Период				= Неопределено,
	СтруктурнаяЕдиница	= Неопределено,
	ТолькоБезДокАванса	= Ложь) Экспорт	
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
	|			&Период,
	|			Контрагент = &Контрагент
	|				И ВЫБОР
	|					КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|							И НЕ &СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|						ТОГДА СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ
	|				И ВЫБОР
	|					КОГДА &ТолькоБезДокАванса = ИСТИНА
	|						ТОГДА ДокументАванса = НЕОПРЕДЕЛЕНО
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ
	|				И ЭтоАванс = ИСТИНА) КАК ВзаиморасчетыСКонтрагентамиОстатки";
				   
	Запрос.УстановитьПараметр("Контрагент"         ,Контрагент);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница" ,СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Период"             ,Период);
	Запрос.УстановитьПараметр("ТолькоБезДокАванса" ,ТолькоБезДокАванса);

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
	     Возврат Выборка.СуммаОстаток;
	 Иначе
		 Возврат 0;
	КонецЕсли;

КонецФункции	

// Функция - Получить сумму остатка аванса по документу
//
Функция ПолучитьСуммуОстаткаАвансаПоДокументу(ДокументЗадолженности, МассивДокументовАванса) Экспорт
	
	Запрос       = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса КАК ДокументАванса,
	|	СУММА(ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток) КАК СуммаОстатокАванса
	|ПОМЕСТИТЬ ВТАвансы
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
	|			,
	|			ДокументАванса В (&МассивОснований)
	|				И ЭтоАванс = ИСТИНА) КАК ВзаиморасчетыСКонтрагентамиОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТАвансы.ДокументАванса КАК ДокументАванса,
	|	СУММА(ВТАвансы.СуммаОстатокАванса) КАК СуммаОстатокАванса,
	|	СУММА(ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход, 0)) КАК СуммаВнесенногоАванса
	|ПОМЕСТИТЬ ВТВнесенныеАвансы
	|ИЗ
	|	ВТАвансы КАК ВТАвансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|				,
	|				,
	|				Авто,
	|				ДокументАванса В (&МассивОснований)
	|					И ЭтоАванс = ИСТИНА) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|		ПО ВТАвансы.ДокументАванса = ВзаиморасчетыСКонтрагентамиОбороты.ДокументАванса
	|			И (ВзаиморасчетыСКонтрагентамиОбороты.Регистратор = &ДокументЗадолженности)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТАвансы.ДокументАванса
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВТАвансы.СуммаОстатокАванса) + СУММА(ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОбороты.СуммаПриход, 0)) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОбороты.СуммаРасход, 0)) КАК СуммаВозможнойОплаты,
	|	ВзаиморасчетыСКонтрагентамиОбороты.ДокументАванса КАК ДокументАванса
	|ПОМЕСТИТЬ ВТВозможнаяОплатаПриема
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|			,
	|			,
	|			,
	|			ДокументАванса В (&МассивОснований)
	|				И ДокументРеализации = &ДокументЗадолженности) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ВзаиморасчетыСКонтрагентамиОбороты.ДокументАванса
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОбороты.СуммаРасход, 0)) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТВнесенныеАвансы.ДокументАванса КАК ДокументАванса,
	|	ЕСТЬNULL(ВТВнесенныеАвансы.СуммаОстатокАванса, 0) КАК СуммаОстатокАванса,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТВозможнаяОплатаПриема.СуммаВозможнойОплаты, 0) + ЕСТЬNULL(ВТВнесенныеАвансы.СуммаВнесенногоАванса, 0) < ЕСТЬNULL(ВТВнесенныеАвансы.СуммаОстатокАванса, 0)
	|				И ЕСТЬNULL(ВТВозможнаяОплатаПриема.СуммаВозможнойОплаты, 0) + ЕСТЬNULL(ВТВнесенныеАвансы.СуммаВнесенногоАванса, 0) > 0
	|			ТОГДА ЕСТЬNULL(ВТВозможнаяОплатаПриема.СуммаВозможнойОплаты, 0) + ЕСТЬNULL(ВТВнесенныеАвансы.СуммаВнесенногоАванса, 0)
	|		ИНАЧЕ ЕСТЬNULL(ВТВнесенныеАвансы.СуммаОстатокАванса, 0)
	|	КОНЕЦ КАК СуммаДоступнаяДляОплатыАвансом
	|ИЗ
	|	ВТВнесенныеАвансы КАК ВТВнесенныеАвансы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТВозможнаяОплатаПриема КАК ВТВозможнаяОплатаПриема
	|		ПО ВТВнесенныеАвансы.ДокументАванса = ВТВозможнаяОплатаПриема.ДокументАванса
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЕСТЬNULL(ВТВозможнаяОплатаПриема.СуммаВозможнойОплаты, 0) + ЕСТЬNULL(ВТВнесенныеАвансы.СуммаВнесенногоАванса, 0) < ЕСТЬNULL(ВТВнесенныеАвансы.СуммаОстатокАванса, 0)
	|					И ЕСТЬNULL(ВТВозможнаяОплатаПриема.СуммаВозможнойОплаты, 0) + ЕСТЬNULL(ВТВнесенныеАвансы.СуммаВнесенногоАванса, 0) > 0
	|				ТОГДА ЕСТЬNULL(ВТВозможнаяОплатаПриема.СуммаВозможнойОплаты, 0) + ЕСТЬNULL(ВТВнесенныеАвансы.СуммаВнесенногоАванса, 0)
	|			ИНАЧЕ ЕСТЬNULL(ВТВнесенныеАвансы.СуммаОстатокАванса, 0)
	|		КОНЕЦ > 0";
	
	Запрос.УстановитьПараметр("МассивОснований"      , МассивДокументовАванса);
	Запрос.УстановитьПараметр("ДокументЗадолженности", ДокументЗадолженности);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции	

// Получить величину задолженности по документам
Функция ПолучитьЗадолженностьПоДокументам(МассивДокументов, НеУчитываетсяРегистратор = Неопределено, СтруктурнаяЕдиница) Экспорт
	
	ЗапросВыборка       = Новый Запрос; 
	Если НеУчитываетсяРегистратор = Неопределено Тогда
		ЗапросВыборка.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	-ЕСТЬNULL(СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаОборот), 0) КАК Сумма
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
		|			,
		|			,
		|			,
		|			ДокументРеализации В (&МассивДокументов)
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ВзаиморасчетыСКонтрагентамиОбороты";
	Иначе  
		ЗапросВыборка.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	-ЕСТЬNULL(СУММА(ВзаиморасчетыСКонтрагентамиОбороты.СуммаОборот), 0) КАК Сумма
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
		|			,
		|			,
		|			Авто,
		|			ДокументРеализации В (&МассивДокументов)
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ВзаиморасчетыСКонтрагентамиОбороты
		|ГДЕ
		|	ВзаиморасчетыСКонтрагентамиОбороты.Регистратор <> &НеУчитываетсяРегистратор";   
		ЗапросВыборка.УстановитьПараметр("НеУчитываетсяРегистратор", НеУчитываетсяРегистратор);
	КонецЕсли;
	ЗапросВыборка.УстановитьПараметр("МассивДокументов", МассивДокументов); 
	ЗапросВыборка.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);

	РезВыборки = ЗапросВыборка.Выполнить().Выбрать();		
	Возврат ?(РезВыборки.Следующий(), ?(РезВыборки.Сумма < 0, 0, РезВыборки.Сумма), 0);		
	
КонецФункции

#КонецОбласти 
