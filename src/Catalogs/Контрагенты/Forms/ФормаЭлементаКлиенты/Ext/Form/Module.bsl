										ИЛИ Объект.СоциальныйСтатус = Справочники.СоциальныеСтатусыКонтрагентов.Учащийся);
	Элементы.Профессия.Видимость    = (Объект.СоциальныйСтатус = Справочники.СоциальныеСтатусыКонтрагентов.Работающий);									
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		Элементы.ФормаСоздатьПрием.Доступность = Истина;
		// Элементы.ФормаСоздатьПрием.Видимость   = Истина;
		// Скроем для Врача контактную информацию
		Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач Тогда 
		//	Элементы.ДатаРождения.Видимость 						= Ложь;
			Элементы.ГруппаКонтактнаяИнформацияКлиенты.Видимость			= Ложь;
			Элементы.ГруппаКонтактнаяИнформацияСправочникКлиенты.Видимость	= Ложь;
			Элементы.КомандыДобавленияКонтактнойИнформации.Видимость		= Ложь;
			Элементы.ГруппаУдостоверениеЛичности.Видимость					= Ложь;
			Элементы.ГруппаСоциальныйСтатус.Видимость						= Ложь;
			Для Каждого ЭлементФормы Из Элементы.ГруппаОсновнаяКонтИнф.ПодчиненныеЭлементы Цикл 
				Если Найти(ЭлементФормы.Имя, "КИ_Поле") <> 0 Тогда 
					ЭлементФормы.Видимость = Ложь;
				КонецЕсли;	
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;	
	
	// Если ЗначениеЗаполнено(УдостоверениеЛичностиКонтрагента.ВидДокумента) Тогда
	//	Элементы.ВидДокумента.ТолькоПросмотр = Истина;
	// КонецЕсли;
	
	Элементы.ДобавитьМедКарту.Видимость = Объект.ТекущаяМедицинскаяКарта.Пустая();
	Элементы.ТекущаяМедицинскаяКартаКод.Видимость = Не Объект.ТекущаяМедицинскаяКарта.Пустая();
	
	// Отображение информации о дате создания документа
	
	// Элементы.ДекорацияДатаСоздания.Видимость = НЕ Объект.Ссылка.Пустая();
	// Элементы.ДекорацияДатаСоздания.Заголовок = "Создан: " + Формат(Объект.ДатаРегистрации, "ДФ='дд ММММ ""в"" ЧЧ:мм, '") + Объект.СотрудникРегистрации;	
	
	Если Объект.ДатаРожденияКлиента <> Дата(1,1,1) Тогда
		
		Элементы.ЗаконныйПредставитель.Видимость = Справочники.Контрагенты.ПолучитьВидимостьЗаконногоПредставителя(Объект.ДатаРожденияКлиента, Объект.НедееспособныйГражданин);

	Иначе
		
		Элементы.ЗаконныйПредставитель.Видимость = Ложь;
		
	КонецЕсли;	
	
	Элементы.ГруппаМеткиКлиента.Видимость = Истина;  
	
	УстановитьВидимостьЗначенияКаналаПривлечения(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьВозраст(ДатаРожденияКлиента)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РАЗНОСТЬДАТ(&ДатаРожденияКлиента, &ТекущаяДата, ГОД) КАК Возраст";
	
	Запрос.УстановитьПараметр("ДатаРожденияКлиента"	, ДатаРожденияКлиента);
	Запрос.УстановитьПараметр("ТекущаяДата"			, ТекущаяДата());
	
	Возраст = 0;
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		 Возраст = Выборка.Возраст;
	КонецЦикла;
	
	Возврат Возраст;
	
КонецФункции

