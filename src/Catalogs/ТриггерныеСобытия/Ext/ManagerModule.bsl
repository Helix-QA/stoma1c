// Процедура - Инициализировать ограничения по типу сделки
//
// Параметры:
//  ПараметрыВыбора					 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//  ВидСделки						 - 	 - 
//
Процедура ИнициализироватьОграниченияПоТипуСделки(ПараметрыВыбора, ВариантУсловияТриггерногоСобытия = Неопределено, ВидСделки, ВидСделкиФильтр = Неопределено) Экспорт
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий", ВариантУсловияТриггерногоСобытия));
	
	Если КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0 Тогда
		ДопустимыйВидСделки = КоллекцияВариантовУсловийТриггерныхСобытий[0].ДопустимыйВидСделки;
	Иначе 
		ДопустимыйВидСделки = Перечисления.ТипыСделок.ПустаяСсылка();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДопустимыйВидСделки) И ВариантУсловияТриггерногоСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.СделкаЗадержкаНаЭтапе Тогда 
		МассивПараметров 		= Новый Массив;
		МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Ссылка"			, ВидСделкиФильтр));
		МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.ПометкаУдаления"	, Ложь));
		ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
		Если ЗначениеЗаполнено(ВидСделки) И ВидСделки <> ВидСделкиФильтр Тогда 
			ВидСделки = Справочники.ВидыСделок.ПустаяСсылка();
		КонецЕсли;		
	Иначе 
		МассивПараметров 		= Новый Массив;
		Если ЗначениеЗаполнено(ДопустимыйВидСделки) Тогда 		
			МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Ссылка"		, ДопустимыйВидСделки));
		КонецЕсли;	
		МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.ПометкаУдаления"	, Ложь));
		ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
		Если ЗначениеЗаполнено(ВидСделки) И ЗначениеЗаполнено(ДопустимыйВидСделки) И ВидСделки <> ДопустимыйВидСделки Тогда 
			ВидСделки = Справочники.ВидыСделок.ПустаяСсылка();
		КонецЕсли;		
	КонецЕсли;
	
	
КонецПроцедуры

// Процедура - Инициализировать завершающие этапы сделок
//
// Параметры:
//  СписокВыбора					 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//
Процедура ИнициализироватьЗавершающиеЭтапыСделок(СписокВыбора, ВариантУсловияТриггерногоСобытия = Неопределено) Экспорт 
	
	ТаблицаВсехВариантовУсловийТриггерныхСобытий = ОбщегоНазначенияПовтИсп.ПолучитьТаблицуВсехВариантовУсловийТриггерныхСобытий();
	
	Если НЕ ЗначениеЗаполнено(ВариантУсловияТриггерногоСобытия) Тогда 
		ВариантУсловияТриггерногоСобытия 		= Перечисления.ВариантыУсловийТриггерныхСобытий.ПустаяСсылка();
	КонецЕсли;
	
	СписокВыбора.Очистить();
	
	КоллекцияВариантовУсловийТриггерныхСобытий = ТаблицаВсехВариантовУсловийТриггерныхСобытий.НайтиСтроки(Новый Структура("ВариантыУсловийТриггерныхСобытий", ВариантУсловияТриггерногоСобытия));
	
	Если КоллекцияВариантовУсловийТриггерныхСобытий.Количество() <> 0 Тогда 
		Для Каждого ЭлементКоллекции Из КоллекцияВариантовУсловийТриггерныхСобытий[0].СписокДопустимыхЗавершающихЭтаповСделок Цикл
			НовыйЭлементСписка 						= СписокВыбора.Добавить();
			НовыйЭлементСписка.Значение 			= ЭлементКоллекции.Значение;
			НовыйЭлементСписка.Представление 		= ЭлементКоллекции.Представление;
			//НовыйЭлементСписка.Пометка 				= МоментАктивации = ЭлементКоллекции.Значение;
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры	

// Процедура - Инициализировать ограничения по доступным сценариям
//
// Параметры:
//  ПараметрыВыбора					 - 	 - 
//  ВариантУсловияТриггерногоСобытия - 	 - 
//  МассивДоступныхСценариев		 - 	 - 
//
Процедура ИнициализироватьОграниченияПоДоступнымСценариям(ПараметрыВыбора, ВариантУсловияТриггерногоСобытия = Неопределено, МассивДоступныхСценариев = Неопределено) Экспорт
	
	Если МассивДоступныхСценариев = Неопределено Тогда
		МассивДоступныхСценариев = Новый Массив;
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ТриггерноеСобытие", ВариантУсловияТриггерногоСобытия);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СценарииЧатБотов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СценарииЧатБотов КАК СценарииЧатБотов
		|ГДЕ
		|	СценарииЧатБотов.ПометкаУдаления = ЛОЖЬ
		|	И СценарииЧатБотов.Используется = ИСТИНА
		|	И СценарииЧатБотов.ИмяМакетаПредопределенногоСценария <> """"
		|	И СценарииЧатБотов.ТриггерныеСобытия.ТриггерноеСобытие = &ТриггерноеСобытие";
		
		МассивДоступныхСценариев = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
	НовыеЗначения = Новый ФиксированныйМассив(МассивДоступныхСценариев);
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", НовыеЗначения));
	ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	
КонецПроцедуры

