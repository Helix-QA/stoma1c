
// Функция, возвращает неоплаченную ссылку на оплату.
//
Функция ПолучитьВыборкуНеоплаченнойСсылки(Основание, ТипСсылкиНаОплату = Неопределено, ЭквайринговыйТерминал = Неопределено, ИсключитьВиджетЛК = Ложь, НомерЗаказа = Неопределено) Экспорт
	
	Если ТипЗнч(Основание) = Тип("Массив") Тогда
		МассивОснований = Основание;
	Иначе
		МассивОснований = Новый Массив;
		МассивОснований.Добавить(Основание);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.СсылкаОплаты КАК СсылкаОплаты,
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки КАК ДатаОкончанияДействияСсылки,
	|	СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа КАК ДатаРегистрацииЗаказа,
	|	СУММА(СтатусыОплатыЗаказов.Сумма) КАК Сумма,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)
	|	И СтатусыОплатыЗаказов.Основание В(&МассивОснований)
	|	И ВЫБОР
	|			КОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки > &ТекущаяДата
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И &УсловиеТипСсылкиНаОплату
	|	И &УсловиеЭквайринговыйТерминал
	|	И &ИсключитьВиджетЛК
	|	И &УсловиеНомерЗаказа
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатусыОплатыЗаказов.СсылкаОплаты,
	|	СтатусыОплатыЗаказов.НомерЗаказа,
	|	СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки,
	|	СтатусыОплатыЗаказов.ДатаРегистрацииЗаказа,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал");
	
	Запрос.УстановитьПараметр("МассивОснований"  	 , МассивОснований);
	Запрос.УстановитьПараметр("ТипСсылкиНаОплату"	 , ТипСсылкиНаОплату);
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	Запрос.УстановитьПараметр("ТекущаяДата"			 , ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("НомерЗаказа"	 		 , НомерЗаказа);
	
	УсловиеТипСсылкиНаОплату = ?(ЗначениеЗаполнено(ТипСсылкиНаОплату), "И СтатусыОплатыЗаказов.ТипСсылкиНаОплату = &ТипСсылкиНаОплату", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеТипСсылкиНаОплату", УсловиеТипСсылкиНаОплату);
	
	ИсключитьВиджетЛК = ?(ИсключитьВиджетЛК, "И СтатусыОплатыЗаказов.ТипСсылкиНаОплату <> Значение(Перечисление.ТипыСсылокНаОплату.ВиджетЛК)", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ИсключитьВиджетЛК", ИсключитьВиджетЛК);
	
	УсловиеЭквайринговыйТерминал = ?(ЗначениеЗаполнено(ЭквайринговыйТерминал), "И СтатусыОплатыЗаказов.ЭквайринговыйТерминал = &ЭквайринговыйТерминал", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеЭквайринговыйТерминал", УсловиеЭквайринговыйТерминал);
	
	УсловиеНомерЗаказа = ?(ЗначениеЗаполнено(НомерЗаказа), "И СтатусыОплатыЗаказов.НомерЗаказа = &НомерЗаказа", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеНомерЗаказа", УсловиеНомерЗаказа);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка, Неопределено);
	
КонецФункции

// Функция, возвращает неоплаченную ссылку на оплату.
//
Функция ПолучитьТаблицуНеоплаченныхСсылок(Основание, ТипСсылкиНаОплату = Неопределено, ЭквайринговыйТерминал = Неопределено, НомерЗаказа = Неопределено) Экспорт
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОплатыЗаказов.СсылкаОплаты КАК СсылкаОплаты,
	|	СтатусыОплатыЗаказов.НомерЗаказа КАК НомерЗаказа,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.Основание КАК ДокументЗадолженности
	|ИЗ
	|	РегистрСведений.СтатусыОплатыЗаказов КАК СтатусыОплатыЗаказов
	|ГДЕ
	|	СтатусыОплатыЗаказов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовОнлайнОплаты.НеОплачено)
	|	И СтатусыОплатыЗаказов.Основание В(&МассивОснований)
	|	И ВЫБОР
	|			КОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА СтатусыОплатыЗаказов.ДатаОкончанияДействияСсылки > &ТекущаяДата
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И &УсловиеТипСсылкиНаОплату
	|	И &УсловиеЭквайринговыйТерминал
	|	И &УсловиеНомерЗаказа
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатусыОплатыЗаказов.СсылкаОплаты,
	|	СтатусыОплатыЗаказов.НомерЗаказа,
	|	СтатусыОплатыЗаказов.ЭквайринговыйТерминал,
	|	СтатусыОплатыЗаказов.Основание");
	
	Запрос.УстановитьПараметр("МассивОснований"  	 , Основание);
	Запрос.УстановитьПараметр("ТипСсылкиНаОплату"	 , ТипСсылкиНаОплату);
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	Запрос.УстановитьПараметр("ТекущаяДата"			 , ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("НомерЗаказа"	 		 , НомерЗаказа);
	
	УсловиеТипСсылкиНаОплату = ?(ЗначениеЗаполнено(ТипСсылкиНаОплату), "И СтатусыОплатыЗаказов.ТипСсылкиНаОплату = &ТипСсылкиНаОплату", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеТипСсылкиНаОплату", УсловиеТипСсылкиНаОплату);
		
	УсловиеЭквайринговыйТерминал = ?(ЗначениеЗаполнено(ЭквайринговыйТерминал), "И СтатусыОплатыЗаказов.ЭквайринговыйТерминал = &ЭквайринговыйТерминал", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеЭквайринговыйТерминал", УсловиеЭквайринговыйТерминал);
	
	УсловиеНомерЗаказа = ?(ЗначениеЗаполнено(НомерЗаказа), "И СтатусыОплатыЗаказов.НомерЗаказа = &НомерЗаказа", "");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &УсловиеНомерЗаказа", УсловиеНомерЗаказа);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Функция, формирует ссылку на оплату основание и возвращает её. 
//
Функция СформироватьСсылкуОплаты(
		Основание, 
		ЭквайринговыйТерминал, 
		СуммаЗаказаВРублях, 
		ПараметрыJSON = Неопределено, 
		Контрагент, 
		ВидЦены = Неопределено) Экспорт
	
	НомерЗаказа        = ПолучитьМассимальныйНомерЗаказа(Перечисления.ТипыСсылокНаОплату.Сбербанк) + 1;
	Сумма              = Формат(СуммаЗаказаВРублях * 100, "ЧГ="); // сумма в копейках.
	ЗапасыОснования    = Основание.Запасы;
	ДатаЗаказа         = ТекущаяДатаСеанса();
	СтруктурнаяЕдиница = Основание.СтруктурнаяЕдиница;
	ПлатежныйШлюз      = ЭквайринговыйТерминал.ТипБанка;
	СтруктураВозврата  = Новый Структура;
	
	ФискализацияВСбербанке = ЭквайринговыйТерминал.ТипФискализации = Перечисления.ТипыФискализации.ВСбербанке;

	ПараметрыПШ = ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") 
		ИЛИ Не ЗначениеЗаполнено(ПлатежныйШлюз) Тогда
		
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , "Не заполнены параметры эквайрингового терминала.");
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	URlRedirect        = ПараметрыПШ.UrlRedirect;
	Логин              = ПараметрыПШ.ЛогинБанка;
	Пароль             = ПараметрыПШ.ПарольБанка; 
	ВремяЖизниВЧасах   = ПараметрыПШ.ВремяЖизни;
	
	Описание      = "";
	ПервыйЭлемент = Истина;
	Для Каждого СтрокаТЧ Из ЗапасыОснования Цикл 
		
		Если Не ПервыйЭлемент Тогда
			Описание = Описание + ", "	
		КонецЕсли;		
		НаименованиеНоменкалтуры = ПолучитьЗначенияРеквизитовПоСсылке(СтрокаТЧ.Номенклатура, "Наименование");
		Описание = НаименованиеНоменкалтуры + " x" + СтрокаТЧ.Количество;			
		ПервыйЭлемент = Ложь;
		
	КонецЦикла;	                                                                   	
	
	Если ФискализацияВСбербанке = Истина И ТипЗнч(Основание) = Тип("ДокументСсылка.Реализация") Тогда 
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("КассаОплаты", Неопределено);
		СтруктураПараметров.Вставить("Организация", Основание.Организация);
		
		ТаблицаЗадолженностей = Новый ТаблицаЗначений;
		ТаблицаЗадолженностей.Колонки.Добавить("Задолженность");
		ТаблицаЗадолженностей.Колонки.Добавить("ДокументЗадолженности");
		ТаблицаЗадолженностей.Колонки.Добавить("Оплачено");
				
		НоваяСтрока = ТаблицаЗадолженностей.Добавить();
		НоваяСтрока.Задолженность = Основание.СуммаДокумента;
		НоваяСтрока.ДокументЗадолженности = Основание;
		НоваяСтрока.Оплачено = 0;	
		
		orderBundle = СсылкиНаОплатуИСБП.Сбербанк_СформироватьМассивЭлементовДляФискализации(ТаблицаЗадолженностей, СтруктураПараметров);
		
	КонецЕсли;
	
	Если ПлатежныйШлюз = Перечисления.ПлатежныеШлюзы.Сбербанк Тогда	
		
		НомерЗаказаВШлюзе = СофрмироватьНомерЗаказа(Основание.Номер, ДатаЗаказа);
		
		ПараметрыЗапроса = "language=ru&orderNumber={OrderNumber}&returnUrl={URL}&amount={Amount}&password={Password}&userName={Login}&pageView=DESKTOP&description={Description}&sessionTimeoutSecs={SessionTimeoutSecs}&jsonParams={jsonParams}";
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{OrderNumber}"       , НомерЗаказаВШлюзе);	
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Amount}"            , Сумма);               
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{URL}"               , URlRedirect);
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Login}"             , Логин);
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Password}"          , КодироватьСтроку(Пароль, СпособКодированияСтроки.КодировкаURL)); 
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Description}"       , СформироватьОписаниеЗаказа(Описание));
		
		Если ВремяЖизниВЧасах <> 0 Тогда
			ВремяЖизниВСекундах = Формат(ВремяЖизниВЧасах * 3600, "ЧГ=");
			ПараметрыЗапроса    = СтрЗаменить(ПараметрыЗапроса, "{SessionTimeoutSecs}", ВремяЖизниВСекундах);
		Иначе
			ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "&sessionTimeoutSecs={SessionTimeoutSecs}", "");
		КонецЕсли;
		
		Клиент 		 = Основание.Контрагент;
		EmailКлиента = ПолучитьEmailКлиента(Клиент);
		Телефон		 = УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(Клиент.Телефон);
		
		ПараметрыJson = Новый Структура("ClubID, phone, orderPhone, orderEmail, UserID, GoogleClientID, YandexClientID");
		
		ПараметрыJson.orderPhone = КодироватьСтроку(Телефон, СпособКодированияСтроки.КодировкаURL);
		ПараметрыJson.phone 	 = КодироватьСтроку(Телефон, СпособКодированияСтроки.КодировкаURL);
		ПараметрыJson.orderEmail = КодироватьСтроку(EmailКлиента  , СпособКодированияСтроки.КодировкаURL);
		ПараметрыJson.UserID     = КодироватьСтроку(Клиент.УникальныйИдентификатор(), СпособКодированияСтроки.КодировкаURL);
		ПараметрыJson.ClubID     = КодироватьСтроку(СтруктурнаяЕдиница.УникальныйИдентификатор(), СпособКодированияСтроки.КодировкаURL);
		
		Если ЗначениеЗаполнено(EmailКлиента) Тогда
			ПараметрыJson.Вставить("email", КодироватьСтроку(EmailКлиента, СпособКодированияСтроки.КодировкаURL));
		КонецЕсли;

		ПараметрыЗаявки = ПолучитьПараметрыЗаявкиДляРегистрацииЗаказа(Клиент);
		
		ПараметрыJson.GoogleClientID = КодироватьСтроку(ПараметрыЗаявки.ga_cid, СпособКодированияСтроки.КодировкаURL); 
		ПараметрыJson.YandexClientID = КодироватьСтроку(ПараметрыЗаявки.ym_cid, СпособКодированияСтроки.КодировкаURL);
		
		ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{jsonParams}", СобратьJson(ПараметрыJson, Ложь));
		
		Если ФискализацияВСбербанке = Истина И ЗначениеЗаполнено(orderBundle) Тогда
			ПараметрыЗапроса = ПараметрыЗапроса + orderBundle;	
		КонецЕсли;
		
		Попытка
			ОтветОтСервера  = ВыполнитьGETЗапроскСбербанку(ПараметрыЗапроса, ПараметрыПШ.ТестовыйРежим);
		Исключение
			ОтветОтСервера = Неопределено;
		КонецПопытки;
		
	ИначеЕсли ПлатежныйШлюз = Перечисления.ПлатежныеШлюзы.Paymo Тогда
		
		НомерЗаказаВШлюзе = СофрмироватьНомерЗаказа(Основание.Номер, ДатаЗаказа);
		
		ПараметрыЗапроса = Новый Структура();
		ПараметрыЗапроса.Вставить("api_key"       , Пароль);
		ПараметрыЗапроса.Вставить("price"         , Формат(СуммаЗаказаВРублях,"ЧГ="));
		ПараметрыЗапроса.Вставить("description"   , Описание);
		ПараметрыЗапроса.Вставить("order"         , НомерЗаказаВШлюзе);
		ПараметрыЗапроса.Вставить("departure_type", "url");
		
		ПараметрыЗапроса = ПолучитьСтрокуИзСтруктуры(ПараметрыЗапроса);
		
		Попытка
			ОтветОтСервера = ВыполнитьPostЗапросКPaymo(ПараметрыЗапроса);
		Исключение
			ОтветОтСервера = Новый Структура;	
		КонецПопытки;
		
		ОтветОтСервераВременный = Новый Структура;
		
		Если ОтветОтСервера.Свойство("result") И ОтветОтСервера.result = "success" Тогда
			ОтветОтСервераВременный.Вставить("formUrl", ОтветОтСервера.url);
			ОтветОтСервераВременный.Вставить("orderId", НомерЗаказаВШлюзе);
		Иначе
			ОтветОтСервераВременный.Вставить("errorCode"   , "");
			ОтветОтСервераВременный.Вставить("errorMessage", ?(ОтветОтСервера.Свойство("message"), ОтветОтСервера.message, "Неизвестная ошибка."));
		КонецЕсли;
		
		ОтветОтСервера = ОтветОтСервераВременный;
		
	КонецЕсли;
	
	Если ОтветОтСервера = Неопределено Тогда
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , "Ошибка при обращении к серверу");
	ИначеЕсли ОтветОтСервера.Свойство("errorCode")  Тогда
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , ОтветОтСервера.errorMessage);
	Иначе		
		
		КороткаяСсылкаНаОплату = ПолучитьКороткуюСсылку(ОтветОтСервера.formUrl);
		Если ЗначениеЗаполнено(КороткаяСсылкаНаОплату) Тогда
			СтруктураВозврата.Вставить("СсылкаСформирована", Истина);
		Иначе
			СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		КонецЕсли;
		СтруктураВозврата.Вставить("СсылкаОплаты", КороткаяСсылкаНаОплату);
		
		Если ТипЗнч(Основание) = Тип("Структура") Тогда
			Основание = Неопределено;
		КонецЕсли;
		
		СоздатьИлиОбновитьЗапись(
			Основание, 
			СуммаЗаказаВРублях, 
			ОтветОтСервера.orderId, 
			КороткаяСсылкаНаОплату, 
			Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
			ЭквайринговыйТерминал, 
			НомерЗаказа,
			ПараметрыЗапроса,
			Не ЗначениеЗаполнено(Основание),
			Контрагент,
			ВидЦены,
			СтруктурнаяЕдиница,
			ДатаЗаказа,
			"Заказ зарегистрирован, но не оплачен",
			Перечисления.ТипыСсылокНаОплату.Сбербанк
		);
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция, формирует ссылку на оплату основание и возвращает её. 
//
Функция СформироватьСсылкуОплатыАпекс(
		Основание, 
		ЭквайринговыйТерминал, 
		СуммаЗаказаВРублях) Экспорт

	// http://docs.paygateway.ru/pages/viewpage.action?pageId=21332167#id-%D0%9C%D0%95%D0%A0%D0%A7%D0%90%D0%9D%D0%A2-%D0%98%D0%9D%D0%A2%D0%95%D0%A0%D0%A4%D0%95%D0%99%D0%A1%D0%B4%D0%BB%D1%8F%D0%B2%D0%BD%D0%B5%D1%88%D0%BD%D0%B8%D1%85%D0%BC%D0%B0%D0%B3%D0%B0%D0%B7%D0%B8%D0%BD%D0%BE%D0%B2-%D0%97%D0%B0%D0%BF%D1%80%D0%BE%D1%81%D0%BD%D0%B0%D0%B2%D1%8B%D1%81%D1%82%D0%B0%D0%B2%D0%BB%D0%B5%D0%BD%D0%B8%D0%B5%D1%81%D1%87%D1%91%D1%82%D0%B0%D0%BF%D0%BB%D0%B0%D1%82%D0%B5%D0%BB%D1%8C%D1%89%D0%B8%D0%BA%D1%83%D0%BF%D0%BE%D1%8D%D0%BB%D0%B5%D0%BA%D1%82%D1%80%D0%BE%D0%BD%D0%BD%D0%BE%D0%B9%D0%BF%D0%BE%D1%87%D1%82%D0%B5/SMS	
	
	СтруктураВозврата = Новый Структура;
	ПараметрыПШ = ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") 
		Или Не ЗначениеЗаполнено(ЭквайринговыйТерминал.ТипБанка)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.ЛицевойСчетАпекс)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.СекретныйКлюч1Апекс)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.СекретныйКлюч2Апекс) Тогда
		
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , "Не заполнены параметры эквайрингового терминала.");
		Возврат СтруктураВозврата;
	КонецЕсли;	
   
	СтруктураДанных = СформироватьСтруктуруДанных(Основание, СуммаЗаказаВРублях, ПараметрыПШ);

	ОписаниеОшибки = "";
	Ответ = ВызовМетода(СтруктураДанных, ПараметрыПШ, ОписаниеОшибки, Основание); 

	Если Ответ = Неопределено Или ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		
		Сообщение = "Ошибка при отправке ссылки на оплату в Апекс. " + ОписаниеОшибки;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение);
		ЗаписьЖурналаРегистрации("Апекс", УровеньЖурналаРегистрации.Ошибка,,, Сообщение);
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , Сообщение);
		
		Возврат СтруктураВозврата;
		
	КонецЕсли;
	
	Если ТипЗнч(Ответ) <> Тип("Соответствие")
		Или Ответ["status"] = Неопределено Тогда
		
		Сообщение = "Не верный ответ.";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение);
		ЗаписьЖурналаРегистрации("Апекс", УровеньЖурналаРегистрации.Ошибка,,, Сообщение);
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , Сообщение);
		Возврат СтруктураВозврата;
		
	КонецЕсли;	
		
	status = Ответ["status"];
	
	Если status = "error" Тогда
		
		Сообщение = "Ошибка при отправке ссылки на оплату в Апекс. " + Ответ["errorcode"] + " " + Ответ["errortext"];
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение);
		ЗаписьЖурналаРегистрации("Апекс", УровеньЖурналаРегистрации.Ошибка,,, Сообщение);		
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , Сообщение);
		Возврат СтруктураВозврата;

	КонецЕсли;

	КороткаяСсылкаНаОплату = Ответ["payURL"]; 
	Если Не ЗначениеЗаполнено(КороткаяСсылкаНаОплату) Тогда
		
		СтруктураВозврата.Вставить("СсылкаСформирована", Ложь);
		СтруктураВозврата.Вставить("ОписаниеОшибки"    , "Не передана ссылка на оплату.");
		Возврат СтруктураВозврата;

	КонецЕсли;
	
	СтруктураВозврата.Вставить("СсылкаОплаты"      , КороткаяСсылкаНаОплату);
	СтруктураВозврата.Вставить("СсылкаСформирована", Истина);
	
	НомерЗаказа = Число(Ответ["transID"]);
	
	СоздатьИлиОбновитьЗапись(
		Основание, 
		СуммаЗаказаВРублях, 
		Ответ["number"], 
		КороткаяСсылкаНаОплату, 
		Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
		ЭквайринговыйТерминал, 
		НомерЗаказа,
		,
		Не ЗначениеЗаполнено(Основание),
		Основание.Контрагент,
		Основание.ВидЦен,
		Основание.СтруктурнаяЕдиница,
		ТекущаяДатаСеанса(),
		"Заказ зарегистрирован, но не оплачен",
		Перечисления.ТипыСсылокНаОплату.Апекс);

	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Вызов Метода
// 
// Возвращаемое значение:
//   - 
//
Функция ВызовМетода(СтруктураДанных, ПараметрыПШ, ОписаниеОшибки, Основание)
	
	Попытка
		
		Логин              = ПараметрыПШ.ЛогинБанка;
		Пароль             = ПараметрыПШ.ПарольБанка; 
		ТестовыйРежим      = ПараметрыПШ.ТестовыйРежим;
		АдресAPI           = ?(ПараметрыПШ.ТестовыйРежим, "https://secure.test.paygateway.ru/api/payment/invoice/", "https://secure.paygateway.ru/api/payment/invoice/");
		АдресAPI           = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресAPI);	
	    ОтветСервиса       = Неопределено;
		
		ЗаписьJSON      = Новый ЗаписьJSON;
		ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
		ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
		ЗаписатьJSON(ЗаписьJSON, СтруктураДанных);
		ТелоЗапроса = ЗаписьJSON.Закрыть();
		
		HTTPСоединение = Новый HTTPСоединение(АдресAPI.Хост,, Логин, Пароль,,20, Новый ЗащищенноеСоединениеOpenSSL());
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type",  "application/json");
		ЗаголовкиHTTP.Вставить("Accept-Charset", "utf-8");
			
		HTTPЗапрос = Новый HTTPЗапрос("/" + АдресAPI.ПутьНаСервере, ЗаголовкиHTTP);
		HTTPЗапрос.Заголовки = ЗаголовкиHTTP;
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		ОтветHTTP = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	    ОтветСервера = ОтветHTTP.ПолучитьТелоКакСтроку();		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ОтветСервера);
		ОтветСервиса = ПрочитатьJSON(ЧтениеJSON, Истина);
		КодОтвета = ОтветHTTP.КодСостояния;
		
	Исключение
		
		ОтветСервиса   = ОписаниеОшибки();
		ОписаниеОшибки = ОтветСервиса;
		КодОтвета      = 500;
		
	КонецПопытки;

	// Логирование
	ЛогироватьСобытие = Константы.ЛогироватьHTTP.Получить();	
	
	Если ЛогироватьСобытие > 0 Тогда
		
		СтруктураЛогирования   = ОбщегоНазначения.СформироватьСтруктуруЛогирования(HTTPЗапрос, , "Apex", 
			Перечисления.HTTPСервисы.Apex, Истина);
		ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ВремяВыполнения        = (ВремяОкончанияОперации - СтруктураЛогирования.ВремяНачалаОперации) / 1000;
		СтатусСобытия		   = ?(КодОтвета = 200, Перечисления.СтасусыЗапросов.Выполнен, Перечисления.СтасусыЗапросов.ЗавершенСОшибками);
		ОтветСтрока            = ОтветСервиса;
		Если ТипЗнч(ОтветСервиса) = Тип("Соответствие") Тогда
			
			ОтветСтрока = "";
			Для Каждого Элемент Из ОтветСервиса Цикл
				 ОтветСтрока = ОтветСтрока + Символы.ПС + Элемент.Ключ + ": " + Элемент.Значение; 
			КонецЦикла;
			
		КонецЕсли;

		ОбщегоНазначения.ЛогироватьЗапрос(ОтветСтрока, СтруктураЛогирования, СтатусСобытия, КодОтвета, Истина, Основание);
				
	КонецЕсли;
	
	Возврат ОтветСервиса;
	
КонецФункции

// Функция - Сформировать структуру данных
//
// Параметры:
//  Основание	 - 	 - 
//  Сумма		 - 	 - 
//  ПараметрыПШ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьСтруктуруДанных(Основание, Сумма, ПараметрыПШ)
		
	СтруктураДанных = Новый Структура();
	Сумма = Формат(Сумма, "ЧРД=.; ЧГ=");            // сумма в копейках.
	СтруктураДанных.Вставить("amount", Сумма);     // стоимость товара в валюте оплаты (amountcurr)
	СтруктураДанных.Вставить("amountcurr", "RUB"); // валюта, в которой задана стоимость товара (amount)
	СтруктураДанных.Вставить("paysys", "MBC");     // VISA/MasterCard
	ДатаЗаказа  = ТекущаяДатаСеанса();
	НомерЗаказа = СофрмироватьНомерЗаказа(Основание.Номер, ДатаЗаказа);
	НомерЗаказа = СтрЗаменить(НомерЗаказа, ":", "");
	СтруктураДанных.Вставить("number", НомерЗаказа); // уникальный внутренний номер заказа магазина
	
	Описание      = "";
	ПервыйЭлемент = Истина;
	Для Каждого СтрокаТЧ Из Основание.Запасы Цикл 
		
		Если Не ПервыйЭлемент Тогда
			Описание = Описание + ", "	
		КонецЕсли;		
		НаименованиеНоменкалтуры = ПолучитьЗначенияРеквизитовПоСсылке(СтрокаТЧ.Номенклатура, "Наименование");
		Описание = НаименованиеНоменкалтуры + " x" + СтрокаТЧ.Количество;			
		ПервыйЭлемент = Ложь;
		
	КонецЦикла;	  
	Описание = СформироватьОписаниеЗаказа(Описание);
	Описание = СтрЗаменить(Описание, ":", "");
	Описание = КодироватьСтроку(Описание, СпособКодированияСтроки.КодировкаURL);
	
	СтруктураДанных.Вставить("description", Описание); // текстовое описание заказа, представленное в виде URL-encoded строки (минимум – 6 символов) 
	СтруктураДанных.Вставить("validity", "");	
	Контрагент = Основание.Контрагент;
	first_name = ?(ЗначениеЗаполнено(Контрагент.Имя), Контрагент.Имя, Контрагент.Наименование);
	СтруктураДанных.Вставить("first_name", first_name);  // имя плательщика
	last_name = ?(ЗначениеЗаполнено(Контрагент.Имя) И ЗначениеЗаполнено(Контрагент.Фамилия), Контрагент.Фамилия, "");
	middle_name = ?(ЗначениеЗаполнено(Контрагент.Имя) И ЗначениеЗаполнено(Контрагент.Отчество), Контрагент.Отчество, "");
	СтруктураДанных.Вставить("last_name"  , last_name);    // Фамилия плательщика
	СтруктураДанных.Вставить("middle_name", middle_name);  // отчество  плательщика

	email = ПолучитьEmailКлиента(Контрагент);
	Если ЗначениеЗаполнено(email) Тогда
		СтруктураДанных.Вставить("email", email);
		СтруктураДанных.Вставить("notify_email", 0);
	КонецЕсли;
	//Телефон = ПолучитьТелефонКлиента(Контрагент);
	//Если ЗначениеЗаполнено(Телефон) Тогда
	//	СтруктураДанных.Вставить("phone", Телефон);
	//	СтруктураДанных.Вставить("notify_phone", 1);	
	//КонецЕсли;
	СтруктураДанных.Вставить("backURL", ""); //  URL возврата на сайт магазина после оплаты	
		
	СтруктураДанных.Вставить("account", ПараметрыПШ.ЛицевойСчетАпекс);  //номер счёта магазина в Системе paygateway (сообщается при регистрации и отображается в Личном кабинете владельца магазина)
			
	Для Каждого Элемент Из СтруктураДанных Цикл
		signature = ?(ЗначениеЗаполнено(signature), signature + ":" + Элемент.Значение, Элемент.Значение); 
	КонецЦикла;
	// если в лк в настройках MD5
	signature = signature + ":" +  ПараметрыПШ.СекретныйКлюч1Апекс + ":" + ПараметрыПШ.СекретныйКлюч2Апекс; 
	Если ПараметрыПШ.Свойство("HMACАпекс") И ПараметрыПШ.HMACАпекс Тогда
		signature = ОбщегоНазначения.ПолучитьХешСумму(ПараметрыПШ.СекретныйКлюч1Апекс +  ПараметрыПШ.СекретныйКлюч2Апекс, signature, "sha256");
	Иначе
		signature = ПолучитьMD5(signature);
	КонецЕсли;	
	signature = Строка(signature);
	СтруктураДанных.Вставить("signature", signature);
	
	Структураfiscal_data = Новый Структура; 
	Массивitems = Новый Массив;

	Для Каждого СтрокаТЧ Из Основание.Запасы Цикл
		
		СтруктураТовара = Новый Структура;
		СтруктураТовара.Вставить("title", Строка(СтрокаТЧ.Номенклатура)); 
		СтруктураТовара.Вставить("price", Строка(СтрокаТЧ.Цена));
		СтруктураТовара.Вставить("qty", Строка(СтрокаТЧ.Количество));
        Массивitems.Добавить(СтруктураТовара);
				
	КонецЦикла;
	
	Массивfiscal_data = Новый Массив; 
	Структураfiscal_data.Вставить("items", Массивitems);
	Массивfiscal_data.Добавить(Структураfiscal_data);
	СтруктураДанных.Вставить("fiscal_data", Массивfiscal_data);	
	
	Возврат СтруктураДанных;
	
КонецФункции

// Функция, возвращает email клиента.
//
Функция ПолучитьEmailКлиента(Клиент)
	
	EmailКлиента = Справочники.Контрагенты.ПолучитьEmailКонтрагента(Клиент); 
	Возврат ?(ЗначениеЗаполнено(EmailКлиента), EmailКлиента, "");
	
КонецФункции

// Функция возвращает хеш строки
//
Функция ПолучитьMD5(Текст)
	
	ОбъектХеш = Новый ХешированиеДанных(ХешФункция.MD5);
	ОбъектХеш.Добавить(Текст);
	ХешСумма = Строка(ОбъектХеш.ХешСумма);
	Возврат СтрЗаменить(ХешСумма, " ", "");
	
КонецФункции

// Функция, возвращает параметры заявки для регистрации заказа в разрезе контрагента.
//
Функция ПолучитьПараметрыЗаявкиДляРегистрацииЗаказа(Клиент)
	
	ПараметрыЗаявки = Новый Структура("ga_cid, ym_cid", "", "");
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Заявки.ga_cid КАК ga_cid,
	|	Заявки.ym_cid КАК ym_cid
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ga_cid <> """"
	|	И Заявки.ym_cid <> """"
	|	И Заявки.ОсновнойКлиент = &ОсновнойКлиент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Заявки.ДатаСоздания УБЫВ");
	
	Запрос.УстановитьПараметр("ОсновнойКлиент", Клиент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыЗаявки, Выборка);		
	КонецЕсли;
	
	Возврат ПараметрыЗаявки;
	
КонецФункции

// Функция, формирует описание заказа
Функция СформироватьОписаниеЗаказа(Описание)
	
	Описание = СтрЗаменить(Описание, "%", "");
	Описание = СтрЗаменить(Описание, "+", "");
	
	Возврат Лев(СокрЛП(Описание), 128); 
	
КонецФункции

// Функция,выыполняет POST запрос к сбербанку.
//
Функция ВыполнитьGETЗапроскСбербанку(Параметры = "", ТестовыйРежим = Ложь)
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();  
	
	HTTPСоединение = Новый HTTPСоединение(?(ТестовыйРежим, "3dsec.sberbank.ru", "securepayments.sberbank.ru"),,,,,, ЗащищенноеСоединение); 
	HTTPЗапрос     = Новый HTTPЗапрос("/payment/rest/register.do?" + Параметры);

	Запрос = HTTPСоединение.Получить(HTTPЗапрос);
	ТекстJSON  = Запрос.ПолучитьТелоКакСтроку(); 
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);	
	
	Возврат ПараметрыJSON;

КонецФункции

// Функция - Собрать json
//
// Параметры:
//  ТелоЗапроса	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СобратьJson(ПараметрыЗапроса, ПереносСтрок = Истина)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(?(ПереносСтрок, ПереносСтрокJSON.Авто, ПереносСтрокJSON.Нет));
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, ПараметрыЗапроса);
	
	Возврат ЗаписьJSON.Закрыть();
	
