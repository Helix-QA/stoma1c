// Процедура обновляет блок индивидуальных норм списания.
//
Процедура ОбновитьБлокИндивидуальныхНормСписания()
	
	Для Каждого ЭлементСписка Из СписокСтруктурныхЕдиницСОтметкойИндивидуальныхНорм Цикл
		
		ИДСтрокиДанных = ЭлементСписка.ПолучитьИдентификатор();
		
		ТаблицаОбщихНормСписания = ТаблицаНормыСписанияМатериалов.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ПредопределенноеЗначение("Справочник.СтруктурныеЕдиницы.ПустаяСсылка")));
		ЗаданыИндивидуальныеНормыСписания = ЗаданыИндивидуальныеНормыСписанияНаСервере(ЭлементСписка.Значение, ТаблицаОбщихНормСписания);
			
		КомандаВыборСалона	= Элементы.Найти("_ВыборКлиники" + ИДСтрокиДанных);
		Если КомандаВыборСалона <> Неопределено Тогда
			КомандаВыборСалона.ЦветТекста	= ?(ЗаданыИндивидуальныеНормыСписания, WebЦвета.Зеленый, WebЦвета.Черный);
			КомандаВыборСалона.ЦветФона		= ?(ЭлементСписка.Значение = ТекущаяСтруктурнаяЕдиница, Новый Цвет(240, 240, 240), WebЦвета.Белый);
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры   

