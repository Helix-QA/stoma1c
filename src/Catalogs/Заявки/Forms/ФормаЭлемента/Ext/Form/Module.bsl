//
Процедура ВзаимодействиеЗадачаДатаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ЭтотОбъект.ВзаимодействиеЗадачаВыполнена Тогда
		
		СтандартнаяОбработка = ВзаимодействиеЗадачаРазрешеноСозданиеНаУказаннуюДату(ВыбранноеЗначение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие задача дата окончание ввода текста.
//
// Параметры:
//  Элемент					 - 	 - 
//  Текст					 - 	 - 
//  ДанныеВыбора			 - 	 - 
//  ПараметрыПолученияДанных - 	 - 
//  СтандартнаяОбработка	 - 	 - 
//
Процедура ВзаимодействиеЗадачаДатаОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Если ЭтотОбъект.ВзаимодействиеЗадачаВыполнена Тогда
		
		Попытка
			СтандартнаяОбработка = ВзаимодействиеЗадачаРазрешеноСозданиеНаУказаннуюДату(Дата(Текст + " 00:00:00"));	
		Исключение
			СтандартнаяОбработка = Ложь;
			Возврат;
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Взаимодействие задача время обработка выбора.
//
// Параметры:
//  Элемент				 - 	 - 
//  ВыбранноеЗначение	 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ВзаимодействиеЗадачаВремяОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ЭтотОбъект.ВзаимодействиеЗадачаВыполнена Тогда
		
		СтандартнаяОбработка = ВзаимодействиеЗадачаРазрешеноСозданиеНаУказаннуюДату(ВыбранноеЗначение);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - Взаимодействие задача разрешено создание на указанную дату.
//
// Параметры:
//  ВыбраннаяДата	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВзаимодействиеЗадачаРазрешеноСозданиеНаУказаннуюДату(ВыбраннаяДата)
	
	Если ВыбраннаяДата > ТекущаяДата() Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Создание выполненных задач будущей датой запрещено!'; en = 'Creating completed tasks by a future date is prohibited!'"));
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
// Процедура - Команда взаимодействие исполнитель
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВзаимодействиеЗадачаИсполнитель(Команда)
	
	Оповещение     = Новый ОписаниеОповещения("ОбработчикВыбораИсполнителяЗадачи", ЭтотОбъект);
	ПараметрыФормы = Новый Структура("Ключ", ЭтотОбъект.ВзаимодействиеЗадачаИсполнитель);	
	
	ОткрытьФорму("Задача.Взаимодействие.Форма.ФормаВыбораИсполнителя", ПараметрыФормы, ЭтотОбъект,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик выбора исполнителя взаимодействия
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ОбработчикВыбораИсполнителяЗадачи(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Если ТипЗнч(Результат) = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка") Тогда
			Представление = ПолучитьПредставлениеФИОСотрудника(Результат);
		Иначе
			Представление = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Результат, "Наименование");		
		КонецЕсли;

		ЭтотОбъект.ВзаимодействиеЗадачаИсполнитель         = Результат;	
		Элементы.ВзаимодействиеЗадачаИсполнитель.Заголовок = Представление;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получить представление ФИОСотрудника.
//
Функция ПолучитьПредставлениеФИОСотрудника(Сотрудник)
	
	Возврат Справочники.Сотрудники.ПредставлениеФИОСотрудника(Сотрудник);		
	
КонецФункции

&НаКлиенте
Процедура ВзаимодействиеЗадачаСтатусНеВыполнена(Команда)
	
	ЭтотОбъект.ВзаимодействиеЗадачаВыполнена = Ложь;
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(
		Элементы.ГруппаВзаимодействиеЗадачаСтатусНеВыполнена,
		Элементы.ГруппаВзаимодействиеЗадачаСтатусВыполнена,
		Ложь
	);
	
КонецПроцедуры

&НаКлиенте
Процедура ВзаимодействиеЗадачаСтатусВыполнена(Команда)
	
	ЭтотОбъект.ВзаимодействиеЗадачаДата      = ПолучитьОкругленноеВремяВзаимодействия(Истина);
	ЭтотОбъект.ВзаимодействиеЗадачаВыполнена = Истина;
	
	УправлениеИнтерфейсамиКлиент.ИзменитьАктивностьПереключателяФормы(
		Элементы.ГруппаВзаимодействиеЗадачаСтатусВыполнена,
		Элементы.ГруппаВзаимодействиеЗадачаСтатусНеВыполнена,
		Истина
	);
	
	ВзаимодействиеЗадачаДатаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Команда взаимодействие задача режим напоминания.
//
Процедура ВзаимодействиеЗадачаРежимНапоминания(Команда)

	Оповещение = Новый ОписаниеОповещения("ВыборРежимаНапоминанияЗавершение", ЭтотОбъект);
	ПоказатьВыборИзМеню(Оповещение, ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминанияСписокВыбора, Элементы.ВзаимодействиеЗадачаНапоминание);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Выбор взаимодействия завершение
//
Процедура ВыборРежимаНапоминанияЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминания    = Результат.Значение;
		Элементы.ВзаимодействиеЗадачаНапоминание.Заголовок = Результат.Представление; 

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Команда взаимодействие создать.
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ВзаимодействиеЗадачаСоздать(Команда)
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеЗадачаДата) Тогда
		ВзаимодействиеЗадачаСоздатьСервер();
		ЭтотОбъект.ВзаимодействиеЗадачаПараметры = Новый Структура;		
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не заполнены данные взаимодействия!'; en = 'Interaction data is not filled!'"));
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик оповещения.
//
Процедура ВзаимодействиеЗадачаСоздатьСервер()
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ЗадачаПредмет"              , Объект.Ссылка);
	ДанныеЗаполнения.Вставить("Контрагент"                 , Объект.ОсновнойКлиент);
	ДанныеЗаполнения.Вставить("ВидВзаимодействия"          , ЭтотОбъект.ВзаимодействиеЗадачаПараметры.ВидВзаимодействия);
	ДанныеЗаполнения.Вставить("ВидВзаимодействияСправочник", ЭтотОбъект.ВзаимодействиеЗадачаПараметры.Взаимодействие);
	ДанныеЗаполнения.Вставить("Исполнитель"                , ЭтотОбъект.ВзаимодействиеЗадачаИсполнитель);
	ДанныеЗаполнения.Вставить("ЗадачаНазначеннаяДата"      , ЭтотОбъект.ВзаимодействиеЗадачаДата);
	ДанныеЗаполнения.Вставить("ЗадачаТема"                 , ?(ЗначениеЗаполнено(ЭтотОбъект.ВзаимодействиеЗадачаТема), ЭтотОбъект.ВзаимодействиеЗадачаТема, ""));
	ДанныеЗаполнения.Вставить("ЗадачаОписание"             , ЭтотОбъект.ВзаимодействиеЗадачаТекст);
	ДанныеЗаполнения.Вставить("Сделка"                     , ЭтотОбъект.ВзаимодействиеСделка);
	ДанныеЗаполнения.Вставить("Выполнена"                  , ЭтотОбъект.ВзаимодействиеЗадачаВыполнена);
	
	НоваяЗадача = Задачи.Взаимодействие.СоздатьЗадачу();
	НоваяЗадача.Заполнить(ДанныеЗаполнения);	
	
	Задачи.Взаимодействие.ЗаполнитьПараметрыНапоминания(НоваяЗадача, Новый Структура("ЗадачаРежимНапоминания", ЭтотОбъект.ВзаимодействиеЗадачаРежимНапоминания));	
	
	НоваяЗадача.Записать();
	
	ОбновитьИсториюВзаимодействияВыборочно("Задача", НоваяЗадача.Ссылка);
	ОбновитьИсториюВзаимодействияСКлиентом(, Элементы.КнопкаПодробно.Пометка);
	
	ВзаимодействиеЗадачаТема  = "";
	ВзаимодействиеЗадачаТекст = "";
	
	СнятьВидимостьВсплывающихГруппСервер("ВзаимодействиеЗадача");
	
КонецПроцедуры

// Процедура - Обновить историю взаимодействия выборочно
//
&НаСервере 
Процедура ОбновитьИсториюВзаимодействияВыборочно(ТипСобытия, Взаимодействие = "", ВзаимодействиеИд = "", Тип = "")
	
	УстановитьПривилегированныйРежим(Истина);
	
	// заметка
	Если ЗначениеЗаполнено(ВзаимодействиеИд) Тогда
		НайденныеСтроки = ИсторияВзаимодействий.НайтиСтроки(Новый Структура("ВзаимодействиеИд", ВзаимодействиеИд));
		Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
			ИсторияВзаимодействий.Удалить(СтрокаТЧ);
		КонецЦикла;
		СтрокаИстории = ИсторияВзаимодействий.Добавить();
		
	Иначе
		НайденныеСтроки = ИсторияВзаимодействий.НайтиСтроки(Новый Структура("Взаимодействие", Взаимодействие));
		Если НайденныеСтроки.Количество() = 0 Тогда
			СтрокаИстории = ИсторияВзаимодействий.Добавить();
		Иначе
			СтрокаИстории = НайденныеСтроки[0];
		КонецЕсли;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Если ТипСобытия = "Задача" Тогда 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗадачаВзаимодействие.Ссылка КАК Взаимодействие,
		|	ВЫБОР
		|		КОГДА ЗадачаВзаимодействие.Выполнена
		|			ТОГДА ЗадачаВзаимодействие.ДатаИсполнения
		|		ИНАЧЕ ЗадачаВзаимодействие.ЗадачаНазначеннаяДата
		|	КОНЕЦ КАК Дата,
		|	""Задача"" КАК ТипСобытия,
		|	ВЫБОР
		|		КОГДА ЗадачаВзаимодействие.Выполнена
		|			ТОГДА ""История""
		|		ИНАЧЕ ""Запланировано""
		|	КОНЕЦ КАК ТипВзаимодействия,
		|	ВЫБОР
		|		КОГДА ЗадачаВзаимодействие.Выполнена
		|			ТОГДА ЗадачаВзаимодействие.ИсполнительФактический
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗадачаВзаимодействие.Исполнитель ССЫЛКА Справочник.Сотрудники
		|					ТОГДА ЗадачаВзаимодействие.Исполнитель
		|				ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|			КОНЕЦ
		|	КОНЕЦ КАК Автор,
		|	ВЫБОР
		|		КОГДА ЗадачаВзаимодействие.Выполнена
		|			ТОГДА ЗадачаВзаимодействие.ИсполнительФактический.НаименованиеСокращенное
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗадачаВзаимодействие.Исполнитель ССЫЛКА Справочник.Сотрудники
		|					ТОГДА ЗадачаВзаимодействие.Исполнитель.НаименованиеСокращенное
		|				ИНАЧЕ ЗадачаВзаимодействие.Исполнитель.Наименование
		|			КОНЕЦ
		|	КОНЕЦ КАК АвторПредставление,
		|	ВЫБОР
		|		КОГДА ЗадачаВзаимодействие.Исполнитель = ЗадачаВзаимодействие.ЗадачаАвтор
		|				ИЛИ ЗадачаВзаимодействие.ЗадачаАвтор.Служебный
		|			ТОГДА NULL
		|		ИНАЧЕ ЗадачаВзаимодействие.ЗадачаАвтор.НаименованиеСокращенное
		|	КОНЕЦ КАК АвторВзаимодействияПредставление,
		|	""Взаимодействие"" КАК ТипЗадачи,
		|	ЗадачаВзаимодействие.ВидВзаимодействияСправочник.ИндексКартинки КАК ИндексКартинкиВзаимодействия,
		|	ВЫБОР
		|		КОГДА ЗадачаВзаимодействие.Сделка = ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.Сделки.ПустаяСсылка)
		|		ИНАЧЕ ЗадачаВзаимодействие.Сделка
		|	КОНЕЦ КАК Сделка
		|ИЗ
		|	Задача.Взаимодействие КАК ЗадачаВзаимодействие
		|ГДЕ
		|	ЗадачаВзаимодействие.Ссылка = &Ссылка
		|	И (ЗадачаВзаимодействие.Контрагент = &Контрагент
		|			ИЛИ ЗадачаВзаимодействие.ЗадачаПредмет = &Контрагент)";
		
		Запрос.УстановитьПараметр("Контрагент", Объект.Ссылка);

	// ИначеЕсли ТипСобытия = "Заметка" Тогда
	//	
	//	Запрос.Текст =
	//	"ВЫБРАТЬ
	//	|	ЗакрепленныеВзаимодействия.ВзаимодействиеИд КАК ВзаимодействиеИд,
	//	|	ЗакрепленныеВзаимодействия.Взаимодействие КАК Взаимодействие
	//	|ПОМЕСТИТЬ ЗакрепленныеЗаметкиДляИсключения
	//	|ИЗ
	//	|	РегистрСведений.ЗакрепленныеВзаимодействия КАК ЗакрепленныеВзаимодействия
	//	|ГДЕ
	//	|	ЗакрепленныеВзаимодействия.ВзаимодействиеИд = &ИД
	//	|	И ЗакрепленныеВзаимодействия.ТипСобытия = ""Заметка""
	//	|;
	//	|
	//	|////////////////////////////////////////////////////////////////////////////////
	//	|ВЫБРАТЬ
	//	|	NULL КАК Взаимодействие,
	//	|	Заметки.Период КАК Дата,
	//	|	""Заметка"" КАК ТипСобытия,
	//	|	""История"" КАК ТипВзаимодействия,
	//	|	Заметки.Автор КАК Автор,
	//	|	Заметки.Автор.НаименованиеСокращенное КАК АвторПредставление,
	//	|	ВЫРАЗИТЬ(Заметки.Заметка КАК СТРОКА(1000)) КАК Заметка,
	//	|	NULL КАК Длительность,
	//	|	NULL КАК Начало,
	//	|	NULL КАК Окончание,
	//	|	NULL КАК Статус,
	//	|	Заметки.ИД КАК ВзаимодействиеИд,
	//	|	NULL КАК ТипЗадачи,
	//	|	NULL КАК ИндексКартинкиВзаимодействия,
	//	|	NULL КАК URLЗаписи,
	//	|	NULL КАК ФайлЗаписи,
	//	|	Заметки.Сделка КАК Сделка
	//	|ИЗ
	//	|	РегистрСведений.Заметки КАК Заметки
	//	|ГДЕ
	//	|	Заметки.ИД = &ИД
	//	|	И Заметки.АктивностьЗаметки
	//	|	И НЕ Заметки.ИД В
	//	|				(ВЫБРАТЬ
	//	|					ЗакрепленныеЗаметкиДляИсключения.ВзаимодействиеИд
	//	|				ИЗ
	//	|					ЗакрепленныеЗаметкиДляИсключения)
	//	|	И &ВыводитьЗакрепленные = ЛОЖЬ
	//	|
	//	|ОБЪЕДИНИТЬ ВСЕ
	//	|
	//	|ВЫБРАТЬ
	//	|	ЗакрепленныеВзаимодействия.Взаимодействие,
	//	|	ЗакрепленныеВзаимодействия.Дата,
	//	|	ЗакрепленныеВзаимодействия.ТипСобытия,
	//	|	""Закреплен"",
	//	|	ВЫБОР
	//	|		КОГДА ЗакрепленныеВзаимодействия.Автор ССЫЛКА Справочник.Сотрудники
	//	|			ТОГДА ЗакрепленныеВзаимодействия.Автор
	//	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	//	|	КОНЕЦ,
	//	|	ВЫБОР
	//	|		КОГДА ЗакрепленныеВзаимодействия.Автор ССЫЛКА Справочник.Сотрудники
	//	|			ТОГДА ЗакрепленныеВзаимодействия.Автор.НаименованиеСокращенное
	//	|		ИНАЧЕ ЗакрепленныеВзаимодействия.Автор
	//	|	КОНЕЦ,
	//	|	ЗакрепленныеВзаимодействия.Заметка,
	//	|	ЗакрепленныеВзаимодействия.Длительность,
	//	|	ЗакрепленныеВзаимодействия.Начало,
	//	|	ЗакрепленныеВзаимодействия.Окончание,
	//	|	ЗакрепленныеВзаимодействия.Статус,
	//	|	ЗакрепленныеВзаимодействия.ВзаимодействиеИд,
	//	|	ЗакрепленныеВзаимодействия.ТипЗадачи,
	//	|	ВЫРАЗИТЬ(ЗакрепленныеВзаимодействия.Взаимодействие КАК Задача.Взаимодействие).ВидВзаимодействияСправочник.ИндексКартинки,
	//	|	ЗакрепленныеВзаимодействия.URLЗаписи,
	//	|	ЗакрепленныеВзаимодействия.ФайлЗаписи,
	//	|	ЗакрепленныеВзаимодействия.Сделка
	//	|ИЗ
	//	|	РегистрСведений.ЗакрепленныеВзаимодействия КАК ЗакрепленныеВзаимодействия
	//	|ГДЕ
	//	|	ЗакрепленныеВзаимодействия.ВзаимодействиеИд = &ИД
	//	|	И ЗакрепленныеВзаимодействия.ТипСобытия = ""Заметка""
	//	|	И &ВыводитьЗакрепленные = ИСТИНА"; 
	//	
	// ИначеЕсли ТипСобытия = "Занятие" Тогда
	//	
	//	Запрос.Текст =
	//	"ВЫБРАТЬ
	//	|	ЗанятиеСоставЗанятия.Ссылка КАК Взаимодействие ,
	//	|	ЗанятиеСоставЗанятия.Ссылка.Дата КАК Дата,
	//	|	""Занятие"" КАК ТипСобытия,
	//	|	""История"" КАК ТипВзаимодействия,
	//	|	ЗанятиеСоставЗанятия.Ссылка.АвторДокумента КАК Автор,
	//	|	ЗанятиеСоставЗанятия.Ссылка.АвторДокумента.НаименованиеСокращенное КАК АвторПредставление,
	//	|	ЗанятиеСоставЗанятия.Ссылка.СтатусЗанятия КАК Статус
	//	|ИЗ
	//	|	Документ.Занятие.СоставЗанятия КАК ЗанятиеСоставЗанятия
	//	|ГДЕ
	//	|	ЗанятиеСоставЗанятия.Ссылка = &Ссылка";

	КонецЕсли;	
	
	Запрос.УстановитьПараметр("Ссылка", Взаимодействие);
	Если ТипСобытия = "Заметка" И ЗначениеЗаполнено(ВзаимодействиеИд) Тогда
		Запрос.УстановитьПараметр("ИД" , Новый УникальныйИдентификатор(ВзаимодействиеИд));
		Запрос.УстановитьПараметр("ВыводитьЗакрепленные", Тип = "Закреплен");		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтрокаИстории, Выборка); 
	КонецЦикла;
	ИсторияВзаимодействий.Сортировать("ТипВзаимодействия, Дата Убыв");
	Фильтры = ПолучитьФильтры();
	
	ПараметрыПроцедуры = Новый Структура;
	ПараметрыПроцедуры.Вставить("Контрагент"              , Объект.Ссылка);
	// ПараметрыПроцедуры.Вставить("СтатусКлиента"           , Справочники.Контрагенты.ПолучитьСтатус(Объект.ОсновнойКлиент, Объект.СтруктурнаяЕдиница));
	// ПараметрыПроцедуры.Вставить("ДатаРожденияКлиента"     , Объект.ДатаРожденияКлиента);
	ПараметрыПроцедуры.Вставить("РежимПодробно"           , Элементы.КнопкаПодробно.Пометка);
	ПараметрыПроцедуры.Вставить("ВыводитьВсе"             , ВыводитьВсеВзаимодействия);
	ПараметрыПроцедуры.Вставить("Фильтры"                 , Фильтры);

	ТекстHTML = УправлениеИнтерфейсамиСервер.СформироватьИсториюВзаимодействий(ЭтаФорма, ПараметрыПроцедуры, 
		ПараметрыПроцедуры.РежимПодробно, ПараметрыПроцедуры.ВыводитьВсе); 
	ЭтотОбъект.ИсторияВзаимодействия = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(ТекстHTML);

КонецПроцедуры

&НаСервере
Функция ПолучитьФильтры()
	
	Фильтры = Новый Структура();
	Фильтры.Вставить("Взаимодействие", ПолучитьЗначениеФильтра("Взаимодействие")); 	
	Фильтры.Вставить("Заметка"       , ПолучитьЗначениеФильтра("Заметка")); 
	// Фильтры.Вставить("Сообщение"     , ПолучитьЗначениеФильтра("Сообщение"));
	// Фильтры.Вставить("SMS"	 		 , ПолучитьЗначениеФильтра("SMS"));
	// Фильтры.Вставить("Письмо"     	 , ПолучитьЗначениеФильтра("Письмо"));
	
	Если ВсеФильтрыОтключены(Фильтры) Тогда
		Фильтры = Новый Структура();
	КонецЕсли;
	
	Возврат Фильтры;
	
КонецФункции

&НаСервере
// Функция, возвращает значение фильтра.
//
Функция ПолучитьЗначениеФильтра(ИмяФильтр)
	
	Фильтр = Элементы["ДекорацияФильтр" + ИмяФильтр];
	Возврат СтрНайти(Фильтр.Подсказка, "Очистить") > 0;
	
КонецФункции

&НаСервере
// Функция, проверяет отключены ли все фильтры.
//
Функция ВсеФильтрыОтключены(Фильтры)
	
	Для Каждого Фильтр Из Фильтры Цикл
		Если Фильтр.Значение = Истина Тогда
			Возврат Ложь;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции


#КонецОбласти

&НаКлиенте
// Процедура, обработчик команды.
//
Процедура СозадтьЗаметку(Команда)
	
	Если Не ПроверитьВидимостьВсплывающихГрупп("Заметка") Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ВзаимодействиеПослеВопросаОЗаписиЗаявки", ЭтотОбъект, Новый Структура("ВыполнитьДействие", "ДобавитьЗаметку"));
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Для добавления заметки нужно произвести запись заявки. Записать?'; en = 'To add a note, you need to record the application. To record?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		Обработчик = Новый ОписаниеОповещения("ЗавершитьДобавлениеЗаметки", ЭтотОбъект);
		ОткрытьФорму("РегистрСведений.Заметки.Форма.ФормаРедактированияЗаметки", Новый Структура("Контрагент", Объект.Ссылка),ЭтаФорма,,,,Обработчик,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
	КонецЕсли;
	
КонецПроцедуры

