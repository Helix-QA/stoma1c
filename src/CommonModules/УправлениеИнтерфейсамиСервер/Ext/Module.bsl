// Функция - Получить представление даты.
//
// Параметры:
//  Период	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеДатыИсторииВзаимодействия(Период)
	
	Если НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(Период) Тогда		
		Дата = Нстр("ru='Сегодня';en='Today'");		
	ИначеЕсли НачалоДня(НачалоДня(ТекущаяДатаСеанса())-1) = НачалоДня(Период) Тогда		
		Дата = Нстр("ru='Вчера';en='Yesterday'");		
	ИначеЕсли НачалоДня(КонецДня(ТекущаяДатаСеанса())+1) = НачалоДня(Период) Тогда		
		Дата = Нстр("ru='Завтра';en='Tomorrow'");		
	Иначе		
		Дата = Формат(Период, "ДЛФ=ДД");		
	КонецЕсли;
	
	Возврат Дата;

КонецФункции

// Функция, формирует блок sms.
//
Функция СформироватьБлокSMS(СтрокаТЗ)
	
	ШаблонSMS = " 
	|<div class='wr-message'>
    |    <div class='message' style='{СтильHtmlГраницаБлока}'>
    |    	<div class='mainlink'> 
	|			<a href='{Ссылка}' title='{Заголовок}' name='SMS'>
	|				<div class='inner-message sms'>
    |           		<div class='info-message'>{Представление} ({Статус})</div>
    |             		<div class='text-message' style='color: #000'>{ТекстSMS}</div>
    |         		</div>
	|			</a>
	|		</div>
    |     </div>
    |</div>";
	
	ДокументSMSРассылки 	= СтрокаТЗ.Взаимодействие;	
	АвторПредставление 		= Строка(СтрокаТЗ.Автор);	
	СтильHtmlГраницаБлока	= "";
	
	Если СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "border-color:#0cac09;";		
	КонецЕсли;

	ШаблонSMS = СтрЗаменить(ШаблонSMS, "{Представление}" 		, ПолучитьПредставлениеИсходящегоСообщения(ДокументSMSРассылки, АвторПредставление));
	ШаблонSMS = СтрЗаменить(ШаблонSMS, "{ТекстSMS}"      		, СтрокаТЗ.ТекстСообщения);
	ШаблонSMS = СтрЗаменить(ШаблонSMS, "{Статус}"        		, СтрокаТЗ.Статус);
	ШаблонSMS = СтрЗаменить(ШаблонSMS, "{Ссылка}"        		, ПолучитьНавигационнуюСсылку(ДокументSMSРассылки));
	ШаблонSMS = СтрЗаменить(ШаблонSMS, "{Заголовок}"	 		, Нстр("ru='Открыть сообщение'; en='Open message'"));
	ШаблонSMS = СтрЗаменить(ШаблонSMS, "{СтильHtmlГраницаБлока}", СтильHtmlГраницаБлока);
	
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонSMS,, ДокументSMSРассылки);
		
	Возврат ШаблонSMS;	
	
КонецФункции

// Функция, формирует блок электронное письмо.
//
Функция СформироватьБлокЭлектронноеПисьмо(СтрокаТЗ)
	
	ШаблонПисьмо = 
	"<div class='wr-message'>
    |    <div class='message' style='{СтильHtmlГраницаБлока}'>
    |    	<div class='mainlink'> 
	|			<a href='{Ссылка}' title='{Заголовок}' name='email'>
	|				<div class='inner-message email'>
    |           		<div class='info-message'>{Представление} ({Статус})</div>
    |             		<div class='text-message' style='color: #000'>{ТемаПисьма}</div>
    |         		</div>
	|			</a>
	|		</div>
    |     </div>
    |</div>";

	ДокументЭлектронноеПисьмо 	= СтрокаТЗ.Взаимодействие;
	СтильHtmlГраницаБлока		= "";
	АвторПредставление 			= Строка(СтрокаТЗ.Автор);
	
	Если СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "border-color:#0cac09;";		
	КонецЕсли;
	
	ШаблонПисьмо = СтрЗаменить(ШаблонПисьмо, "{Представление}" 			, ПолучитьПредставлениеИсходящегоСообщения(ДокументЭлектронноеПисьмо, АвторПредставление));
	ШаблонПисьмо = СтрЗаменить(ШаблонПисьмо, "{ТемаПисьма}"    			, ДокументЭлектронноеПисьмо.Тема);
	ШаблонПисьмо = СтрЗаменить(ШаблонПисьмо, "{Статус}"        			, Строка(СтрокаТЗ.СтатусПисьма));
	ШаблонПисьмо = СтрЗаменить(ШаблонПисьмо, "{Ссылка}"        			, ПолучитьНавигационнуюСсылку(ДокументЭлектронноеПисьмо));
	ШаблонПисьмо = СтрЗаменить(ШаблонПисьмо, "{Заголовок}"     			, Нстр("ru='Открыть письмо'; en='Open letter'"));
	ШаблонПисьмо = СтрЗаменить(ШаблонПисьмо, "{СтильHtmlГраницаБлока}"  , СтильHtmlГраницаБлока);
	
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонПисьмо, СтрокаТЗ.Сделка, ДокументЭлектронноеПисьмо);
	
	Возврат ШаблонПисьмо;	
	
КонецФункции

// Функция, возвращает представление документа sms рассылки.
//
Функция ПолучитьПредставлениеИсходящегоСообщения(ИсходящееСообщение, АвторСообщения)
	
	// Время отправки.
	Представление = Формат(ИсходящееСообщение.Дата, "ДФ='dd.MM.yyyy ЧЧ:мм'") + " "+ АвторСообщения;
	
	Если ИсходящееСообщение.ПометкаУдаления Тогда
		Представление = Представление + НСтр("ru='(удален)'; en='(deleted)'");
	ИначеЕсли Не ИсходящееСообщение.Проведен Тогда
		Представление = Представление + НСтр("ru='(не проведен)'; en='(not held)'");
	КонецЕсли;
	
	Возврат СокрЛП(Представление);
	
КонецФункции

// Функция, возвращает представление документа sms рассылки.
//
Функция ПолучитьПредставлениеЗаписи(СтрокаТЗ, ТипЗаписи, ЭтоБлокЗапланировано = Ложь, ПредставлениеШапкиБлока)
	
	Если ТипЗаписи = "Событие" Тогда 
		Возврат ПолучитьПредставлениеПредварительнойЗаписи(СтрокаТЗ, СтрокаТЗ.Статус, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);
	ИначеЕсли ТипЗаписи = "Прием" Тогда 
		Возврат ПолучитьПредставлениеПриема(СтрокаТЗ, СтрокаТЗ.Статус, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);
	ИначеЕсли ТипЗаписи = "НарядЗаказ" Тогда 
		Возврат ПолучитьПредставлениеНарядЗаказа(СтрокаТЗ, СтрокаТЗ.Статус, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);
	ИначеЕсли ТипЗаписи = "ПланЛечения" Тогда 
		Возврат ПолучитьПредставлениеПланаЛечения(СтрокаТЗ, СтрокаТЗ.Статус, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);
	ИначеЕсли ТипЗаписи = "Профосмотр" Тогда 
		Возврат ПолучитьПредставлениеПрофосмотра(СтрокаТЗ, СтрокаТЗ.Статус, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);
	ИначеЕсли ТипЗаписи = "Обращение" Тогда 
		Возврат ПолучитьПредставлениеОбращения(СтрокаТЗ, СтрокаТЗ.Статус, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока); 
	КонецЕсли;	
	
КонецФункции

// Функция, формирует блок заметка.
//
Функция СформироватьБлокЗаметка(СтрокаТЗ)
	
	ШаблонЗаметка = 
	"<div class='wr-message'>	
    |	<div class='message{ЗакрепленнаяЗаметка}' style='{СтильHtmlГраницаБлока}'>    
    |   	<div class='mainlink'>
	|			<a href='' title='{Заголовок}' name='note' id='{ИдЗаметки}'>
    |        		<div class='inner-message'>
    |          			<div class='info-message'>{Представление}</div>
    |           		<div class='text-message' style='color: #000000;'>{ТекстЗаметки}</span></div>  
    |         		</div>
	|			</a>
	|    	</div> 
	| 		<div class='clip'> <a href='' title='{ПредставлениеЗакрепитьЗаметку}' name= '{Класс}' id='{ИдЗаметки}'> <span>{БлокКартинка}</span></a></div>
	|  	</div>		 	
	|</div>";
	
	Уид = СтрокаТЗ.ПолучитьИдентификатор();
	СтильHtmlГраницаБлока = "";	
	
	Если ЗначениеЗаполнено(СтрокаТЗ.Заметка) Тогда
		ТекстЗаметки = ?(СтрДлина(СтрокаТЗ.Заметка) > 200, Лев(СтрокаТЗ.Заметка, 200) + "...", СтрокаТЗ.Заметка);
	Иначе
		ТекстЗаметки = "...";
	КонецЕсли;
	
	СобытиеЗакреплено = (СтрокаТЗ.ТипВзаимодействия = "Закреплено");
	
	Если СобытиеЗакреплено Тогда
		Base64 			= СтрЗаменить(СтрЗаменить(Base64Строка(БиблиотекаКартинок.БулавкаОткрепить.ПолучитьДвоичныеДанные()),Символы.ПС, ""), Символы.ВК, "");		
		ПредставлениеЗакрепитьЗаметку = "Открепить заметку"; 
		Класс = "clip on"
	Иначе
		Base64 			= СтрЗаменить(СтрЗаменить(Base64Строка(БиблиотекаКартинок.БулавкаПрикрепить.ПолучитьДвоичныеДанные()),Символы.ПС, ""), Символы.ВК, "");
		ПредставлениеЗакрепитьЗаметку = "Закрепить заметку";
		Класс = "clip off"
	КонецЕсли;
	
	АдресКартинки 	= "data:image/png;base64," + Base64;
	БлокКартинка 	= СтрЗаменить("<img src='{АдресКартинки}' width='16' height='16'/>", "{АдресКартинки}", АдресКартинки);
	
	Если СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "border-color:#0cac09;";		
	КонецЕсли;
	
	Представление 	= Формат(СтрокаТЗ.Дата,"ДФ='dd.MM.yyyy ЧЧ:мм'" ) + " " + Строка(СтрокаТЗ.Автор);

	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{БлокКартинка}"          		, БлокКартинка);
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{ПредставлениеЗакрепитьЗаметку}", ПредставлениеЗакрепитьЗаметку);
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{Класс}"          				, Класс);
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{ЗакрепленнаяЗаметка}"			, ?(СобытиеЗакреплено, " fixed", ""));
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{ТекстЗаметки}"          		, ТекстЗаметки); 
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{Представление}"         		, Представление); 
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{ИдЗаметки}"             		, Уид);
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{Заголовок}"     		 		, Нстр("ru='Редактировать заметку';en='Edit note'"));
	ШаблонЗаметка = СтрЗаменить(ШаблонЗаметка, "{СтильHtmlГраницаБлока}"     	, СтильHtmlГраницаБлока);
	
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонЗаметка, СтрокаТЗ.Сделка);	
	
	Возврат ШаблонЗаметка;	
	
КонецФункции

// Функция, формирует блок диалог.
//
Функция СформироватьБлокДиалог(СтрокаТЗ, ТегДиалогаОткрыт, ТипСобытия)
	
	Если СтрокаТЗ.ВзаимодействиеИд = "0" Тогда
		// Сообщение от клиента.	
		ВходящееСообщение = "";
	Иначе 
		// Сообщение от менеджера
		ВходящееСообщение = "answer"; 
		АватарСотрудника = РегистрыСведений.АктивныеПользователиМессенджер.ПолучитьАватарСотрудника(СтрокаТЗ.Автор);
			
	КонецЕсли;	
	
	Если СтрокаТЗ.Статус = Истина Тогда  // Это служебное сообщение
		ШаблонДиалог = 
		" <div class='line-info'>
		|	<span> {ТекстСообщения} </span>
		|  </div>";
	Иначе	
		ШаблонДиалог = 
		"<div class='item-dialog {ВходящееСообщение}'>
		|   <div class='photo'><img src='{Фото}' onerror='userPhotoErrorHandler(this)'/></div>
		|   <div class='text-dial'>
		|   	<div class='info-message'>{Дата} {Автор}</div>
		|   	<p>{ТекстСообщения}</p>
		|   </div>
		|</div>";
	КонецЕсли;
	
	Уид 					= СтрокаТЗ.ПолучитьИдентификатор();
	СтильHtmlГраницаБлока	= "";	
	

	Сообщение = ?(ЗначениеЗаполнено(СтрокаТЗ.ТекстСообщения), СтрокаТЗ.ТекстСообщения, "..."); 
	Сообщение = СтрЗаменить(Сообщение, "<", "&lt");
	
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{Автор}"  				, Строка(СтрокаТЗ.Автор));
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{Дата}"  					, Формат(СтрокаТЗ.Дата,"ДФ='dd.MM.yyyy ЧЧ:мм'" ));
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{ВходящееСообщение}"  	, ВходящееСообщение);
    ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{ТекстСообщения}"  		, Сообщение);
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{ДатаСообщения}" 			, Формат(СтрокаТЗ.Дата, "ДФ=HH:mm"));
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{Фото}" 					, ?(ЗначениеЗаполнено(ВходящееСообщение), АватарСотрудника, СтрокаТЗ.URLЗаписи));
	ШаблонДиалог = СтрЗаменить(ШаблонДиалог, "{СтильHtmlГраницаБлока}" 	, СтильHtmlГраницаБлока);
	
	Возврат ШаблонДиалог;		
	
КонецФункции

// Функция, формирует блок задача.
//
Функция СформироватьБлокЗадача(СтрокаТЗ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Взаимодействие.ЗадачаОписание КАК СТРОКА(1024)) КАК ЗадачаОписание,
	|	Взаимодействие.Выполнена КАК Выполнена,
	|	Взаимодействие.ДатаИсполнения КАК ДатаИсполнения,
	|	Взаимодействие.ЗадачаТема КАК ЗадачаТема,
	|	Взаимодействие.ЗадачаНазначеннаяДата КАК ЗадачаНазначеннаяДата,
	|	Взаимодействие.КоличествоПереносов КАК КоличествоПереносов,
	|	Взаимодействие.ВидВзаимодействияСправочник.ИндексКартинки КАК ИндексКартинки,
	|	Взаимодействие.ВидВзаимодействияСправочник КАК ВидВзаимодействияСправочник,
	|	Взаимодействие.Дата КАК Дата,
	|	Взаимодействие.ЗадачаПредмет КАК ЗадачаПредмет,
	|	Взаимодействие.Сделка КАК Сделка
	|ИЗ
	|	Задача.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.Ссылка = &Ссылка";
	
	Задача = СтрокаТЗ.Взаимодействие;   
	Запрос.УстановитьПараметр("Ссылка", Задача);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ЗадачаОписание              = Выборка.ЗадачаОписание;
		ЗадачаВыполнена             = Выборка.Выполнена;
		ЗадачаДатаИсполнения        = Выборка.ДатаИсполнения;
		ЗадачаТема                  = Выборка.ЗадачаТема;
		ЗадачаНазначеннаяДата       = Выборка.ЗадачаНазначеннаяДата;
		ЗадачаКоличествоПереносов   = Выборка.КоличествоПереносов;
		ИндексКартинки              = Выборка.ИндексКартинки;
		ВидВзаимодействияСправочник = Выборка.ВидВзаимодействияСправочник;
		ЗадачаДата                  = Выборка.Дата;
		ЗадачаПредмет               = Выборка.ЗадачаПредмет;
		Сделка						= Выборка.Сделка;
		
	КонецЕсли;
	
	ТипЗадачи = "Взаимодействие";
		
	БлокКартинка = 	"";
	
	Если ЗначениеЗаполнено(ИндексКартинки) Тогда	
		Картинка = БиблиотекаКартинок["ВидВзаимодействия_" + ИндексКартинки];					
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Картинка) Тогда
		Base64 			= СтрЗаменить(СтрЗаменить(Base64Строка(Картинка.ПолучитьДвоичныеДанные()),Символы.ПС, ""), Символы.ВК, "");
		АдресКартинки 	= "data:image/svg+xml;base64," + Base64;
		
		БлокКартинка 	= СтрЗаменить("<img src='{АдресКартинки}' width='12' height='12'/>", "{АдресКартинки}", АдресКартинки); 
	КонецЕсли;
		
	ФлажокВыполнения = "";
	ДопИнформация    = "";
	КлассЗадачи		 = "";
	ЗадачаПросрочена = "";
	БлокСделка		 = "";
	
	Если Не ЗадачаВыполнена Тогда 
		// Задача запланирована
		КлассЗадачи = "plan";	
		
		// Поле флажка выполнения задачи.
		ФлажокВыполнения = "<input style='margin:0 2px 0 0; width:12px; height:12px;' title='{ОписаниеВыполнения}' type='checkbox' class='executetask' name='{ТипЗадачи}' id='{УидЗадача}'/>";
		
		ФлажокВыполнения = СтрЗаменить(ФлажокВыполнения, "{ОписаниеВыполнения}", Нстр("ru='Отметить как выполнено';en='Mark as done'"));
		ФлажокВыполнения = СтрЗаменить(ФлажокВыполнения, "{ТипЗадачи}"         , ТипЗадачи);
		ФлажокВыполнения = СтрЗаменить(ФлажокВыполнения, "{УидЗадача}"         , Задача.УникальныйИдентификатор());	
		
		Если ЗадачаНазначеннаяДата < ТекущаяДатаСеанса() Тогда
			ЗадачаПросрочена = "overdue";
		КонецЕсли;
		
	Иначе
		// Задача выполнена
		КлассЗадачи = "done"; 
	КонецЕсли; 
		                             	
	ШаблонЗадача = 
	"<div class='wr-message'>
	| 	<div class='message {ЗадачаПросрочена}' {СтильHtmlГраницаБлока}> 
	|       <div class='mainlink'>
	|			<a href='{Ссылка}' title='Открыть задачу' name='task'>
	|    			<div class='inner-message {КлассЗадачи}'>	
	|    	    		<div class='info-message'>{ДатаСоздания} {Автор}</div>
	|    	    		<div class='text-message'>{ФлажокВыполнения}<span class='interaction' style='color: #000'>{БлокКартинка} {ЗадачаТема} {Описание}</span></div>
	|     			</div> 
	|			</a>
	|  		</div>
	|		{БлокСделка}
	|	</div>	
	| </div>";  
		
	Если ЗначениеЗаполнено(Сделка) Тогда
		БлокСделка = "<div class='die-message' style = 'background: {НавигационнаяСсылкаЦвет}'><a style='color: #000'; href='{НавигационнаяСсылка}' title='{НавигационнаяСсылкаПодсказка}'>{НавигационнаяСсылкаПредставление}</a></div>";
	КонецЕсли;
	
	Если СтрокаТЗ.ТипВзаимодействия = "Запланировано" И Не ЗначениеЗаполнено(ЗадачаПросрочена) Тогда		
		СтильHtmlГраницаБлока 	= "style = 'border-color:#ff9b00;'";	
	ИначеЕсли СтрокаТЗ.ТипВзаимодействия = "Просроченно" Тогда
		СтильHtmlГраницаБлока 	= "style = 'border-color:#fc4242;'";	
	ИначеЕсли СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "style = 'border-color:#0cac09;'";		
	КонецЕсли;
	
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Описание}"        		, ?(ЗначениеЗаполнено(ЗадачаОписание), "- " + ЗадачаОписание, ""));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ЗадачаПросрочена}"   	, ?(ЗначениеЗаполнено(ЗадачаПросрочена), ЗадачаПросрочена, ""));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{КлассЗадачи}"     		, ?(ЗначениеЗаполнено(КлассЗадачи), КлассЗадачи, ""));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ЗадачаТема}" 			, ?(ЗначениеЗаполнено(ЗадачаТема), Строка(ЗадачаТема), ""));
   	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{БлокСделка}"        		, БлокСделка);
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ФлажокВыполнения}"   	, ФлажокВыполнения);
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Автор}"           		, Строка(СтрокаТЗ.Автор));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ДатаСоздания}"    		, ?(ЗадачаВыполнена, Формат(ЗадачаДатаИсполнения, "ДФ='dd.MM.yyyy ЧЧ:мм'"), Формат(ЗадачаНазначеннаяДата, "ДФ='dd.MM.yyyy ЧЧ:мм'")));	
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Ссылка}"          		, ПолучитьНавигационнуюСсылку(Задача));	
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ЗаголовокОткрыть}"		, Нстр("ru='Открыть задачу';en='Open task'")); 
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{БлокКартинка}"       	, БлокКартинка);
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{СтильHtmlГраницаБлока}"	, СтильHtmlГраницаБлока);
		
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонЗадача, Сделка, Задача);
		
	Возврат ШаблонЗадача;	
	
КонецФункции

// Функция, формирует блок статус сделки.
//
Функция СформироватьБлокСтатусСделки(СтрокаТЗ)
	
	Сделка = СтрокаТЗ.Взаимодействие;  
	
	Если ЗначениеЗаполнено(СтрокаТЗ.ПереходСЭтапа.ЦветЭтапа) Тогда   		
		ПереходСЭтапаЦвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ПереходСЭтапа.ЦветЭтапа);
		
		Если ПереходСЭтапаЦвет.Вид = ВидЦвета.Абсолютный Тогда
			ПереходСЭтапаЦвет = "rgb("+ПереходСЭтапаЦвет.Красный+","+ПереходСЭтапаЦвет.Зеленый+","+ПереходСЭтапаЦвет.Синий+")";	
		Иначе
			ПереходСЭтапаЦвет = "rgb(248, 247, 247)";
		КонецЕсли;	
	Иначе 
		ПереходСЭтапаЦвет = "rgb(248, 247, 247)";	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТЗ.ПереходНаЭтап.ЦветЭтапа) Тогда 
		ПереходНаЭтапЦвет = ЗначениеИзСтрокиВнутр(СтрокаТЗ.ПереходНаЭтап.ЦветЭтапа);
		Если ПереходНаЭтапЦвет.Вид = ВидЦвета.Абсолютный Тогда 
			ПереходНаЭтапЦвет = "rgb("+ПереходНаЭтапЦвет.Красный+","+ПереходНаЭтапЦвет.Зеленый+","+ПереходНаЭтапЦвет.Синий+")";
		Иначе
			ПереходНаЭтапЦвет = "rgb(248, 247, 247)";
		КонецЕсли;
	Иначе
		ПереходНаЭтапЦвет = "rgb(248, 247, 247)";
	КонецЕсли;

	ШаблонЗадача =
	" <div class='line-info'>
    |     	<a href='{Ссылка}'>{Дата} {Представление} </a>
    |     	<span>
    |         	<i style='background: {ПереходСЭтапаЦвет}';>{ПереходСЭтапа}</i>
    |     	</span>
	|		<span> → </span>
   	|		<span>
    |        	<i style='background: {ПереходНаЭтапЦвет}';>{ПереходНаЭтап}</i>
    |     	</span>
    |  </div>";
			
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Представление}"    	, Справочники.Сделки.ИнициализироватьСокращенноеНаименованиеСделки(Сделка, Истина, Истина));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Дата}"    			, Строка(Формат(СтрокаТЗ.Дата,"ДФ='dd.MM.yyyy ЧЧ:мм'" )));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{Ссылка}"           	, ПолучитьНавигационнуюСсылку(Сделка));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ПереходСЭтапа}"    	, Строка(СтрокаТЗ.ПереходСЭтапа));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ПереходСЭтапаЦвет}"	, ПереходСЭтапаЦвет);
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ПереходНаЭтап}"    	, Строка(СтрокаТЗ.ПереходНаЭтап));
	ШаблонЗадача = СтрЗаменить(ШаблонЗадача, "{ПереходНаЭтапЦвет}"	, ПереходНаЭтапЦвет);
		
	Возврат ШаблонЗадача;	
	
КонецФункции

// Функция - Сформировать блок предварительная запись.
//
// Параметры:
//  СтрокаТЗ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокЗапись(СтрокаТЗ, ЭтоБлокЗапланировано = Ложь)

	Статус 					= СтрокаТЗ.Статус;
	Стиль 					= "";
	СтильТекста 			= "";
	Картинка				= "";
	ПредставлениеШапкиБлока = ""; 
	СтильHtmlГраницаБлока	= "";
	ВерхнийОтступ			= "";
	НижнийОтступ			= "";
	
	Если СтрокаТЗ.ТипСобытия = "Событие" Тогда	
		ТипСобытия = "pre-entry";
		Заголовок 	= "Открыть предварительную запись.";
		Стиль	  	= "margin: 1px 0 7px 0;";
		СтильТекста = "color: #000;";
	ИначеЕсли СтрокаТЗ.ТипСобытия = "Прием" Тогда 
		ТипСобытия 	= "reception";
		Заголовок 	= "Открыть прием.";
		Стиль	  	= "margin: 1px 0 15px 0;";
		СтильТекста = "color: #000;";
	ИначеЕсли СтрокаТЗ.ТипСобытия = "НарядЗаказ" Тогда 
		ТипСобытия = "outfitorder"; 
		Заголовок = "Открыть наряд заказ.";
	ИначеЕсли СтрокаТЗ.ТипСобытия = "ПланЛечения" Тогда 
		ТипСобытия = "treatmentplan";
		Заголовок = "Открыть план лечения.";
	ИначеЕсли СтрокаТЗ.ТипСобытия = "Обращение" Тогда
		ТипСобытия = "appeal";
		Заголовок = "Открыть обращение.";
		Стиль	  	= "margin: 1px 0 7px 0;";
		СтильТекста = "color: #000;";
	КонецЕсли;                                           
	
	ШаблонЗапись = " 
	|<div class='wr-message'>
	|    <div class='message' style='{СтильHtmlГраницаБлока} {НижнийОтступ}'>
	|    	<div class='mainlink'> 
	|			<a href='{Ссылка}' title='{Заголовок}' name='Запись' id>
	|				<div class='inner-message {ТипСобытия}' style=""{Картинка} {ВерхнийОтступ}"">
	|           		<div class='info-message' style='{Стиль} {СтильТекста}'>{ПредставлениеШапкиБлока}</div>
	|             		<div class='text-message' style='white-space: pre-wrap; color: #000; {СтильТекста}'>{ПредставлениеЗаписи}</div>
	|         		</div>
	|			</a>
	|		</div>
	| 		{БлокПредставлениеСтатуса}
	|     </div>
	|</div>";    
		
	Если ЗначениеЗаполнено(Статус) И Статус <> Перечисления.СтатусыСобытия.НеПодтверждена Тогда		
		
		Если ТипЗнч(Статус) = Тип("ПеречислениеСсылка.СтатусыСобытия") Тогда  
			// Цвета статуса.
			ЦветФона 	= ПолучитьЦветЗаписиПоСтатусуСобытия(Статус, СтрокаТЗ.СтруктурнаяЕдиница); 
			ЦветФона 	= ПолучитьЦветHEX(ЗначениеИзСтрокиВнутр(ЦветФона)); 
			ЦветТекста 	= "#000000";
			
			Если Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
				СтильТекста = СтильТекста + "text-decoration: line-through; color: #ff0000;"; 	
				Картинка 	= СтрШаблон("--url:%1;", ПолучитьКартинкуДляHTML("ПриемОтменен"));				
			КонецЕсли;
			
		ИначеЕсли Статус = "(Удален)" Тогда 
			ЦветФона 	= "#dd2020";  
			ЦветТекста 	= "#ffffff";
		ИначеЕсли ТипЗнч(Статус) = Тип("Булево") Тогда
			Статус = ?(Статус = Истина, "Закрыт", "Открыт");
		ИначеЕсли ТипЗнч(Статус) = Тип("ПеречислениеСсылка.СтатусыЗаявок") Тогда
			
			ЦветФона 	= Справочники.Заявки.ПолучитьЦветСтатусаЗаявки(Статус); 
			ЦветФона 	= ПолучитьЦветHEX(ЦветФона); 
			ЦветТекста 	= "#000000";	
			
		Иначе
			ЦветФона = Новый Цвет();
			ЦветТекста = "#000000";
		КонецЕсли;
		
		БлокПредставлениеСтатуса = "<div class='die-message'> <span style='padding: 5px;'> <i style='background: {ЦветФона}; border-radius : 3px; color: {ЦветТекста}; padding: 1px 7px 1px 7px; font-style: normal;';> {Статус} </i> </span></div>";
			
		БлокПредставлениеСтатуса = СтрЗаменить(БлокПредставлениеСтатуса	, "{ЦветФона}"	, ЦветФона); 
		БлокПредставлениеСтатуса = СтрЗаменить(БлокПредставлениеСтатуса	, "{ЦветТекста}", ЦветТекста);
		БлокПредставлениеСтатуса = СтрЗаменить(БлокПредставлениеСтатуса	, "{Статус}"	, Статус);	
	КонецЕсли;
		
	Если СтрокаТЗ.ТипВзаимодействия = "Запланировано" Тогда	
		СтильHtmlГраницаБлока 	= "border-color:#ff9b00;";
	ИначеЕсли СтрокаТЗ.ТипВзаимодействия = "Просроченно" Тогда
		СтильHtmlГраницаБлока 	= "style = 'border-color:#fc4242;'";
	ИначеЕсли СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "border-color:#0cac09;";		
	КонецЕсли;
	
	СсылкаЗапись 			= СтрокаТЗ.Взаимодействие;
	ПредставлениеЗаписи 	= ПолучитьПредставлениеЗаписи(СтрокаТЗ, СтрокаТЗ.ТипСобытия, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);		
	
	Если Не ЗначениеЗаполнено(ПредставлениеЗаписи) Тогда
		ВерхнийОтступ	= "--top:-4px;";
		НижнийОтступ	= "--paddingbottom:0px;";
	КонецЕсли;

	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Дата}" 						, Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:ММ'"));
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Автор}" 						, Строка(СтрокаТЗ.Автор)); 
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{ПредставлениеЗаписи}" 		, ПредставлениеЗаписи);  
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{ТипСобытия}" 				, ТипСобытия);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{ПредставлениеШапкиБлока}"	, ПредставлениеШапкиБлока); 
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{БлокПредставлениеСтатуса}" 	, ?(ЗначениеЗаполнено(БлокПредставлениеСтатуса), БлокПредставлениеСтатуса, ""));
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Ссылка}"        				, ПолучитьНавигационнуюСсылку(СсылкаЗапись));
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Заголовок}"	 				, Заголовок);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Стиль}"	 					, Стиль);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{СтильТекста}"	 			, СтильТекста);
    ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Картинка}"	 				, Картинка);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{ВерхнийОтступ}"	 			, ВерхнийОтступ);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{СтильHtmlГраницаБлока}"	 	, СтильHtmlГраницаБлока);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{НижнийОтступ}"	 			, НижнийОтступ);
	
	ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонЗапись,, СсылкаЗапись);
	
	Возврат ШаблонЗапись;
	
КонецФункции

// Функция - Сформировать блок предварительная запись.
//
// Параметры:
//  СтрокаТЗ - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокПрофосмотр(СтрокаТЗ, ЭтоБлокЗапланировано = Ложь)

	СтильHtmlГраницаБлока 	= "";
	Статус 					= СтрокаТЗ.Статус; 
		
	ШаблонЗапись = " 
	|<div class='wr-message'>
	|    <div class='message' {СтильHtmlГраницаБлока}>
	|    	<div class='mainlink'> 
	|			<a href='{Ссылка}' title='{Заголовок}' name='profs' id = '{Уид}'>
	|				<div class='inner-message medicalExamination'>
	|           		<div class='info-message'>{ПредставлениеШапкиБлока}</div>
	|             		<div class='text-message' style='color: #000; white-space: pre-wrap;'>{ПредставлениеЗаписи}</div>
	|         		</div>
	|			</a>
	|		</div>
	|     </div>
	|</div>";    
	
	Уид = СтрокаТЗ.ПолучитьИдентификатор(); 
	
	ПредставлениеШапкиБлока = ""; 
	
	ПредставлениеЗаписи = ПолучитьПредставлениеЗаписи(СтрокаТЗ, СтрокаТЗ.ТипСобытия, ЭтоБлокЗапланировано, ПредставлениеШапкиБлока);
	
	АвторПредставление = Строка(СтрокаТЗ.Автор);	
	
	Если СтрокаТЗ.ТипВзаимодействия = "Запланировано" Тогда	
		СтильHtmlГраницаБлока 	= "style = 'border-color:#ff9b00;'";	
	ИначеЕсли СтрокаТЗ.ТипВзаимодействия = "История" 
		И НачалоДня(СтрокаТЗ.Дата) = НачалоДня(ТекущаяДатаСеанса()) Тогда	
		СтильHtmlГраницаБлока 	= "style = 'border-color:#0cac09;'";		
	КонецЕсли;

	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Дата}" 						, Формат(СтрокаТЗ.Дата, "ДФ='dd.MM.yyyy ЧЧ:ММ'"));
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{ПредставлениеЗаписи}" 		, ПредставлениеЗаписи);  
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Уид}" 						, Уид);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Статус}" 					, "(" + Статус +")"); 
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{ПредставлениеШапкиБлока}"	, ПредставлениеШапкиБлока);
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{Заголовок}"	 				, "Открыть профосмотр");
	ШаблонЗапись = СтрЗаменить(ШаблонЗапись, "{СтильHtmlГраницаБлока}"	 	, СтильHtmlГраницаБлока);
	
	Возврат ШаблонЗапись;
	
КонецФункции

// Функция - Вывести продолжительность звонка.
//
Функция ВывестиПродолжительностьЗвонка(ПродолжительностьЗвонкаВСекундах)
	
	ПродолжительностьЗвонка = Дата(1,1,1) + ПродолжительностьЗвонкаВСекундах;
	
	Если ПродолжительностьЗвонка <= Дата('00010101000059') Тогда 
		Возврат Формат(ПродолжительностьЗвонка, "ДФ='с""" + Нстр("ru=' сек.';en='sec.'") + """'");
	ИначеЕсли ПродолжительностьЗвонка <= Дата('00010101005959') И ПродолжительностьЗвонка > Дата('00010101000059') Тогда
		Возврат Формат(ПродолжительностьЗвонка, "ДФ='m """+Нстр("ru='мин.';en='min.'")+""" с """+Нстр("ru='сек.';en='sec.'")+"""'");
	ИначеЕсли ПродолжительностьЗвонка <= Дата('00010101235959') И ПродолжительностьЗвонка > Дата('00010101005959') Тогда
		Возврат Формат(ПродолжительностьЗвонка, "ДФ='h """+Нстр("ru='ч.';en='h.'")+""" m """+Нстр("ru='мин.';en='min.'")+""" с """+Нстр("ru='сек.';en='sec.'")+"""'");
	Иначе 	
		Возврат Формат(ПродолжительностьЗвонка, "ДФ='d """+Нстр("ru='дней';en='days'")+""" h """+Нстр("ru='ч.';en='h.'")+""" m """+Нстр("ru='мин.';en='min.'")+""" с """+Нстр("ru='сек.';en='sec.'")+"""'");
	КонецЕсли;	
	
КонецФункции

// Процедура - Вывести ссылку прослушать.
//
// Параметры:
//  ТекстHTML	 - 	 - 
//  URLЗаписи	 - 	 - 
//  ФайлЗаписи	 - 	 - 
//  Уид			 - 	 - 
//
Процедура ВывестиСсылкуПрослушать(ТекстHTML, URLЗаписи, ФайлЗаписи, Уид, УИДЗвонка = "")
		
	Если (ЗначениеЗаполнено(URLЗаписи) ИЛИ ЗначениеЗаполнено(ФайлЗаписи)) И ЗаписьРазговораДоступнаПоРолям(УИДЗвонка) Тогда
		
		ШаблонСсылкаПрослушать = "<a href='' class='listen_call' style='Color:#37af1a' id='" + Уид + "' name='{Звонок}'>Прослушать</a>";
		
		ТекстHTML = СтрЗаменить(ТекстHTML, "{Прослушать}", ШаблонСсылкаПрослушать);
		ТекстHTML = СтрЗаменить(ТекстHTML, "{Звонок}"	 , Нстр("ru='Звонок';en='Call'"));
	Иначе
		ТекстHTML = СтрЗаменить(ТекстHTML, "{Прослушать}", "");
		ТекстHTML = СтрЗаменить(ТекстHTML, "{Звонок}"	 , "");	
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Сформировать блок взаимодействия получить значения навигационной ссылки.
//
// Параметры:
//  Задача					 - 	 - 
//  ТипЗадачи				 - 	 - 
//  ДопДанныеПодсказка		 - 	 - 
//  ДопДанныеПредставление	 - 	 - 
//  ДопДанныеЦвет			 - 	 - 
//  НавигационнаяСсылка		 - 	 - 
//  ЦветФона				 - 	 - 
//
Процедура ФормированиеБлокаВзаимодействияУстановитьЗначенияНавигационнойСсылки(ШаблонБлока, СделкаВзаимодействия = Неопределено, ОбъектВзаимодействия = Неопределено, Сотрудник = Неопределено)
	
	// Если передана сделка взаимодействия.
	Если ЗначениеЗаполнено(СделкаВзаимодействия) Тогда
		
		НавигационнаяСсылкаПредставление = Справочники.Сделки.ИнициализироватьСокращенноеНаименованиеСделки(СделкаВзаимодействия, Истина, Истина);
		НавигационнаяСсылкаПодсказка     = НавигационнаяСсылкаПредставление;
		НавигационнаяСсылкаЦвет          = ПолучитьЦветДляСделки(СделкаВзаимодействия);
		НавигационнаяСсылка              = ПолучитьНавигационнуюСсылку(СделкаВзаимодействия);  
		
	ИначеЕсли ЗначениеЗаполнено(ОбъектВзаимодействия) Тогда 
		
		Если ОбщегоНазначенияСтоматология.ЕстьРеквизитОбъекта("ЗадачаПредмет", , ОбъектВзаимодействия) Тогда
			
			ЗадачаПредмет = ОбъектВзаимодействия.ЗадачаПредмет;
			Если ЗначениеЗаполнено(ЗадачаПредмет) Тогда 
				НавигационнаяСсылкаПредставление = Строка(ЗадачаПредмет);
				НавигационнаяСсылкаПодсказка     = НавигационнаяСсылкаПредставление;
				НавигационнаяСсылкаЦвет          = "rgb(236, 236, 159)";
				НавигационнаяСсылка              = ПолучитьНавигационнуюСсылку(ЗадачаПредмет);  
			КонецЕсли;
			
		ИначеЕсли ОбщегоНазначенияСтоматология.ЕстьРеквизитОбъекта("БизнесПроцесс", , ОбъектВзаимодействия) Тогда  
			
			ЗадачаБизнесПроцесс = ОбъектВзаимодействия.БизнесПроцесс; 
			Если ЗначениеЗаполнено(ЗадачаБизнесПроцесс) Тогда 
				НавигационнаяСсылкаПредставление = ПолучитьПредставлениеБизнесПроцесса(ЗадачаБизнесПроцесс);
				НавигационнаяСсылкаПодсказка     = Строка(ЗадачаБизнесПроцесс);
				НавигационнаяСсылкаЦвет          = ПолучитьЦветДляБизнесПроцесса(ЗадачаБизнесПроцесс);
				НавигационнаяСсылка              = ПолучитьНавигационнуюСсылку(ЗадачаБизнесПроцесс);  
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(Сотрудник) Тогда 
		
		НавигационнаяСсылкаПредставление = Справочники.Сотрудники.ПредставлениеФИОСотрудника(Сотрудник);
		НавигационнаяСсылкаПодсказка     = НавигационнаяСсылкаПредставление;
		НавигационнаяСсылкаЦвет          = ПолучитьЦветДляСотрудника(Сотрудник);
		НавигационнаяСсылка              = ПолучитьНавигационнуюСсылку(Сотрудник); 
		
	КонецЕсли;
	
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылкаПредставление}", НавигационнаяСсылкаПредставление);
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылкаПодсказка}"    , НавигационнаяСсылкаПодсказка);
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылкаЦвет}"         , НавигационнаяСсылкаЦвет);
	ШаблонБлока = СтрЗаменить(ШаблонБлока, "{НавигационнаяСсылка}"             , НавигационнаяСсылка);	
		
КонецПроцедуры

// Функция - Получить цвет для бизнес процесса.
//
// Параметры:
//  БизнесПроцесс	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветДляСделки(Сделка)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЦветЭтапа = Сделка.ЭтапСделки.ЦветЭтапа;	
	Цвет      = ?(ЗначениеЗаполнено(ЦветЭтапа), ЗначениеИзСтрокиВнутр(Сделка.ЭтапСделки.ЦветЭтапа), Неопределено);	
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ?(Цвет <> Неопределено, СтрШаблон("rgb(%1,%2,%3)", Цвет.Красный, Цвет.Зеленый, Цвет.Синий), "");
	
КонецФункции 

// Функция - Получить цвет для бизнес процесса.
//
// Параметры:
//  БизнесПроцесс	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветДляСотрудника(Сотрудник)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЦветФона = СтрЗаменить(Сотрудник.Должность.ЦветФона,Символы.ПС, "");	
	Цвет      = ?(ЗначениеЗаполнено(ЦветФона), ЗначениеИзСтрокиВнутр(ЦветФона), Неопределено);	
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ?(Цвет <> Неопределено, ПолучитьЦветИзСтиляПлатформы(Цвет), "");
	
КонецФункции 

// Функция, формирует представление бизнес процесса.
//
Функция ПолучитьПредставлениеБизнесПроцесса(БизнесПроцесс)
	
	Если ТипЗнч(БизнесПроцесс) = Тип("БизнесПроцессСсылка.ПродажаЧленства_КОРП") Тогда
		Возврат Нстр("ru='Продажа членства';en='Sale memberships'");
	ИначеЕсли ТипЗнч(БизнесПроцесс) = Тип("БизнесПроцессСсылка.ПродлениеЧленства_КОРП") Тогда
		Возврат Нстр("ru='Продление членства';en='Extension memberships'");
	ИначеЕсли ТипЗнч(БизнесПроцесс) = Тип("БизнесПроцессСсылка.ПродлениеПакетаУслуг_КОРП") Тогда
		Возврат Нстр("ru='Продление пакета';en='Extension package'");
	ИначеЕсли ТипЗнч(БизнесПроцесс) = Тип("БизнесПроцессСсылка.ПродажаДополнительныхУслуг_КОРП") Тогда
		Возврат Нстр("ru='Продажа услуг';en='Sale services'");
	ИначеЕсли ТипЗнч(БизнесПроцесс) = Тип("БизнесПроцессСсылка.КонтрольПлатежейПоРассрочкам_КОРП") Тогда
		Возврат Нстр("ru='Рассрочка';en='Installment'");
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

// Функция - Получить цвет для бизнес процесса.
//
// Параметры:
//  БизнесПроцесс	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьЦветДляБизнесПроцесса(БизнесПроцесс)
			
	Цвет = "";
	ТипБизнесПроцесса = ТипЗнч(БизнесПроцесс);
	                                                          
	Если ТипБизнесПроцесса = Тип("БизнесПроцессСсылка.ПродажаЧленства_КОРП") Тогда 
		Цвет = "rgb(236, 236, 159)";
	ИначеЕсли ТипБизнесПроцесса = Тип("БизнесПроцессСсылка.ПродлениеЧленства_КОРП") Тогда 
		Цвет = "rgb(181, 209, 237)";
	ИначеЕсли ТипБизнесПроцесса = Тип("БизнесПроцессСсылка.ПродлениеПакетаУслуг_КОРП") Тогда 
		Цвет = "rgb(136, 191, 136)";
	ИначеЕсли ТипБизнесПроцесса = Тип("БизнесПроцессСсылка.КонтрольПлатежейПоРассрочкам_КОРП") Тогда 
		Цвет = "rgb(136, 156, 211)";
	ИначеЕсли ТипБизнесПроцесса = Тип("БизнесПроцессСсылка.ПродажаДополнительныхУслуг_КОРП") Тогда 
		Цвет = "rgb(217, 171, 126)";
	КонецЕсли;
	
