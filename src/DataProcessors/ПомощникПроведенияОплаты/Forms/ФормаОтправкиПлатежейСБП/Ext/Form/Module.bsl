
#Область Переменные

&НаКлиенте
Перем ИзмененТекстСообщения;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ЭквайринговыйТерминал"	, ЭтотОбъект.ЭквайринговыйТерминал);
	Параметры.Свойство("НомерЗаказа"			, ЭтотОбъект.НомерЗаказа);
	Параметры.Свойство("СуммаОплаты"			, ЭтотОбъект.СуммаОплаты);	
	Параметры.Свойство("КассаОплаты"			, ЭтотОбъект.КассаОплаты);
	Параметры.Свойство("Контрагент"    			, ЭтотОбъект.Контрагент);
	Параметры.Свойство("СтруктурнаяЕдиница"		, ЭтотОбъект.СтруктурнаяЕдиница);		
	Параметры.Свойство("Организация"			, ЭтотОбъект.Организация);
	
	ЭтотОбъект.Организация = ?(Не ЗначениеЗаполнено(ЭтотОбъект.Организация), СтруктурнаяЕдиница.Организация, ЭтотОбъект.Организация);  
	
	Если Параметры.Свойство("МассивЗадолженностей") Тогда		
		
		СуммаОплатыПередана = ЗначениеЗаполнено(ЭтотОбъект.СуммаОплаты);
		СуммаВрем			= ЭтотОбъект.СуммаОплаты;	
		
		Для Каждого СтрокаМ Из Параметры.МассивЗадолженностей Цикл
			
			Если СуммаОплатыПередана И СуммаВрем <= 0 Тогда
				Прервать;
			КонецЕсли;
			
			НоваяСтрока = ЭтотОбъект.ТаблицаЗадолженностей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаМ);
			
			Если СуммаОплатыПередана Тогда
				НоваяСтрока.Задолженность = ?(СтрокаМ.Задолженность > СуммаВрем, СуммаВрем, СтрокаМ.Задолженность);
				СуммаВрем = СуммаВрем - НоваяСтрока.Задолженность;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ПолучитьНеоплаченнуюСсылкуНаОплату();		
	ЗаполнитьСервисыРассылки();
	ЗаполнитьТребуемыеПараметрыПШ();
	ОбновитьQRКод();
	ОбновитьЭлементыФормы();
	
	МассивПО = МенеджерОборудованияВызовСервера.ОборудованиеПоПараметрам("ДисплейПокупателя");
	
	Если МассивПО.Количество() > 0 Тогда
		ЭтотОбъект.ПодключаемоеОборудование = МассивПО[0].Ссылка;	
	КонецЕсли;
	
	ЭтаФорма.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	#Если ВебКлиент Тогда
		
		Элементы.ГруппаСкопироватьВБуфер.Видимость = Ложь;
		Элементы.СкопироватьСсылкуВБуфер.Видимость = Ложь;
		
	#Иначе
		
		ЭтоWindowsКлиент = ОбщегоНазначенияКлиентСервер.ЭтоWindowsКлиент();
		
		Элементы.ГруппаСкопироватьВБуфер.Видимость = ЭтоWindowsКлиент;
		Элементы.СкопироватьСсылкуВБуфер.Видимость = ЭтоWindowsКлиент;
		
	#КонецЕсли
	
	ВывестиQrКодНаМонитор();
	
КонецПроцедуры

&НаКлиенте
// Процедура - При закрытии
//
// Параметры:
//  ЗавершениеРаботы - 	 - 
//
Процедура ПриЗакрытии(ЗавершениеРаботы)
		
	Попытка
		ОчиститьQrНаМониторе(); // чисто клиенские вызовы, но на всякий пусть будет попытка
	Исключение
	КонецПопытки;
	
	Если ЗавершениеРаботы = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ЭквайринговыйТерминал) И ИзмененТекстСообщения = Истина Тогда		
		ЗаписатьПараметрыПШ(ЭквайринговыйТерминал, ШаблонДляОтправкиСсылкиНаОплату);						
	КонецЕсли;
	
	Если ОбновитьИнформациюОСсылкахНаОплату = Истина Тогда
		МассивЗадолженностей = Новый Массив;
		Для Каждого СтрокаТ Из ЭтотОбъект.ТаблицаЗадолженностей Цикл
			МассивЗадолженностей.Добавить(СтрокаТ.ДокументЗадолженности);	
		КонецЦикла;		
		Оповестить("ОбновитьИнформациюОСсылкахНаОплату", МассивЗадолженностей);			
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаСервере
// Процедура - Обновить элементы формы
//
Процедура ОбновитьЭлементыФормы()
		
	ЭтаФорма.Заголовок				= Строка(ЭквайринговыйТерминал.ТипБанка) + ", " + ЭквайринговыйТерминал.Наименование;
	СсылкаСоздана					= ЗначениеЗаполнено(ЭтотОбъект.СсылкаНаОплату);
	Элементы.СуммаОплаты.Заголовок 	= "Сумма оплаты: " + Формат(ЭтотОбъект.СуммаОплаты, "ЧДЦ=2; ЧН=0,00") + " " + СокрЛП(ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти()); 	
	
	Элементы.ГруппаСсылкаНаОплату.Видимость							= СсылкаСоздана;
	Элементы.СформироватьСсылкуНаОплатуСВыбраннойСуммой.Заголовок 	= ?(СсылкаСоздана, "Отправить", "Сгенерировать");  
	Элементы.ГруппаВремяДействия.Видимость							= СсылкаСоздана;
	
	Элементы.ГруппаСформирован.Видимость 	= ЗначениеЗаполнено(ЭтотОбъект.ВремяСформирован);
	Элементы.СформированДата.Заголовок		= Формат(ЭтотОбъект.ВремяСформирован,"ДФ='dd.MM.yyyy ЧЧ:мм'");
	
	Элементы.ГруппаДействителенДо.Видимость	= ЗначениеЗаполнено(ЭтотОбъект.ВремяДействителенДо);
	Элементы.ДействителенДоДата.Заголовок	= Формат(ЭтотОбъект.ВремяДействителенДо,"ДФ='dd.MM.yyyy ЧЧ:мм'");
	
	МассивПлатежныхШлюзов = Новый Массив;
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПСбербанк);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СбербанкПлатиQR);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПАльфабанк);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПРайффайзенБанк);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПСДМ);
	МассивПлатежныхШлюзов.Добавить(Перечисления.ПлатежныеШлюзы.СБПТинькофф); 
	
	Элементы.ПроверитьСтатус.Видимость = СсылкаСоздана И МассивПлатежныхШлюзов.Найти(ЭквайринговыйТерминал.ТипБанка) <> Неопределено;
	
	УстановитьВидимостьЭлементовРедактированияШаблона(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СформироватьСсылкуНаОплатуСВыбраннойСуммой".
//
Процедура СформироватьСсылкуНаОплатуСВыбраннойСуммой(Команда)
	
	СсылкаУжеПолучена = ЗначениеЗаполнено(ЭтотОбъект.СсылкаНаОплату);
	
	Если Не СсылкаУжеПолучена Тогда				
		СформироватьСсылкуНаОплатуСервер();
		ВывестиQrКодНаМонитор();
	Иначе		
		РазослатьСсылку();								
	КонецЕсли;
	
	Если ЭтотОбъект.СкопироватьВБуферОбмена Тогда
		СкопироватьСсылкуОплатыВБуфер(ЭтотОбъект.СсылкаНаОплату);	
	КонецЕсли;
	
	Если СсылкаУжеПолучена Тогда
		ЗакрытьФорму();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Сформировать ссылку на оплату сервер
// 
// Возвращаемое значение:
//   - 
//
Процедура СформироватьСсылкуНаОплатуСервер()
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);
	СтруктураПараметров.Вставить("КассаОплаты"			, КассаОплаты);
	СтруктураПараметров.Вставить("Контрагент"			, Контрагент);
	СтруктураПараметров.Вставить("Организация"			, Организация);
	СтруктураПараметров.Вставить("СуммаОплаты"			, СуммаОплаты);
	СтруктураПараметров.Вставить("ТаблицаЗадолженностей", ТаблицаЗадолженностей);
	СтруктураПараметров.Вставить("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	СтруктураПараметров.Вставить("НомерТелефона"		, НомерТелефона);
	СтруктураПараметров.Вставить("АдресЭПКонтрагента"	, АдресЭП);
	
	Результат = СсылкиНаОплатуИСБП.СформироватьСсылкуНаОплату(СтруктураПараметров);
	
	Если Результат.ВыполненоУспешно Тогда
		
		ВремяСформирован 	= ТекущаяДатаСеанса();
		ВремяДействителенДо = Результат.ВремяДействителенДо;
		СсылкаНаОплату	 	= Результат.СсылкаНаОплату;
		НомерЗаказа	 		= Результат.НомерЗаказа;
		ДанныеQRКода	 	= УправлениеПечатью.ДанныеQRКода(Результат.СсылкаНаОплату, 0, 200);
		
		Если ТипЗнч(ДанныеQRКода) = Тип("ДвоичныеДанные") Тогда			
			QRКод = ПоместитьВоВременноеХранилище(ДанныеQRКода, УникальныйИдентификатор);
		КонецЕсли;
		ОбновитьЭлементыФормы();
		
		ОбновитьИнформациюОСсылкахНаОплату = Истина;
		
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "Отмена".
//
Процедура Отмена(Команда)
	
	ЗакрытьФорму(Истина);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить ссылку на оплату
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОтменитьСсылкуНаОплату(Команда)
	
	ТекстВопроса = НСтр("ru='Отмена ссылки приведет к невозможности автоматической оплаты по этой ссылке.
							|Продолжить?';
						|en='Cancellation of the link will result in the inability to automatically pay for this link.
							|Continue?'");

	ЗаголовокВопроса = НСтр("ru='Внимание!';en='Attention!'");
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьСсылкуНаОплатуЗавершение", ЭтаФорма);
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет,,, ЗаголовокВопроса);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отменить ссылку на оплату завершение
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ОтменитьСсылкуНаОплатуЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат = КодВозвратаДиалога.Да И ЗначениеЗаполнено(ЭтотОбъект.СсылкаНаОплату) Тогда
		
		Результат = ОтменитьСсылкуНаОплатуСервер();
		
		Если Результат.ВыполненоУспешно Тогда
			ОбновитьИнформациюОСсылкахНаОплату = Истина;
			ЗакрытьФорму(Истина);
		Иначе		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);
		КонецЕсли;
				
	КонецЕсли;
	
КонецПроцедуры

