// Процедура, "ФИО При изменении".
//
Процедура ФИОПриИзменении(Элемент)
	
	Если Автокоррекция = 2 Тогда
		Объект.Фамилия	= ВРег(СокрЛП(Объект.Фамилия));
		Объект.Имя		= ВРег(СокрЛП(Объект.Имя));
		Объект.Отчество = ВРег(СокрЛП(Объект.Отчество));
	ИначеЕсли Автокоррекция = 1 Тогда
		Объект.Фамилия	= ТРег(СокрЛП(Объект.Фамилия));// ВРег(Сред(Объект.Фамилия, 1, 1)) + НРег(Сред(Объект.Фамилия, 2));
		Объект.Имя		= ТРег(СокрЛП(Объект.Имя));// ВРег(Сред(Объект.Имя, 1, 1)) + НРег(Сред(Объект.Имя, 2));
		Объект.Отчество = ТРег(СокрЛП(Объект.Отчество));// ВРег(Сред(Объект.Отчество, 1, 1)) + НРег(Сред(Объект.Отчество, 2));
	КонецЕсли;
	
	// Заполняем пол клиента, если он не был заполнен ранее
	Если Объект.Ссылка.Пустая() ИЛИ (НЕ Объект.Ссылка.Пустая() И НЕ ЗаполненПол)Тогда
		ПолКлиента = ОбщегоНазначенияКлиентПовтИспСтоматология.ОпределитьПолКлиента(Объект.Фамилия, Объект.Имя, Объект.Отчество);
		Если ПолКлиента = "Мужской" Тогда
			Объект.ПолКлиента = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Мужской");
		ИначеЕсли ПолКлиента = "Женский" Тогда
			Объект.ПолКлиента = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Женский");
		КонецЕсли;
	КонецЕсли;		
	
	Объект.Наименование = Объект.Фамилия + ?(ЗначениеЗаполнено(Объект.Фамилия), " ", "") + Объект.Имя + ?(ЗначениеЗаполнено(Объект.Имя), " ", "") + Объект.Отчество;
	ПроверкаДублированияКлиента(Неопределено);
	
КонецПроцедуры

