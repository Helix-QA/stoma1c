&НаКлиенте
// Процедура - Открыть форму ввода доп информации
//
// Параметры:
//  Результат				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ОткрытьФормуВыбораКабинета(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	
	ЭтоКлиент 		= Ложь;
	ЭтоКонтрагент 	= Ложь;
		
	Если ТипЗнч(Объект.Ссылка) = Тип("СправочникСсылка.Сотрудники") Тогда
		Если ЭтаФорма.ИмяФормы = "Документ.Прием.Форма.ФормаДокумента" Тогда
			ЭтоКлиент 		= Истина;
		Иначе 
			ЭтоКонтрагент 	= Истина;
		КонецЕсли;
	КонецЕсли;	
	
	Если ТипЗнч(Результат) = Тип("КодВозвратаДиалога") И Результат = КодВозвратаДиалога.Да Тогда
		Записать = Истина;
	ИначеЕсли ТипЗнч(Результат) = Тип("КодВозвратаДиалога") И Результат = КодВозвратаДиалога.Нет Тогда
		Записать = Ложь;
	Иначе
		Записать = Неопределено;
	КонецЕсли;	
	
	Если Объект.Ссылка.Пустая() Тогда
		Если Записать = Неопределено Тогда
			Возврат;
		ИначеЕсли Записать = Истина И ЭтаФорма.ПроверитьЗаполнение() Тогда
			ФормаЗаписана = ЭтаФорма.Записать();
			Если НЕ ФормаЗаписана Тогда
				Возврат;
			КонецЕсли;
			Если ЭтоКлиент Тогда 
				ЭтаФорма.Заголовок = Строка(Объект.Ссылка) + " (Клиент)";
			КонецЕсли;	
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Свойство("ЭтоКабинет") И ДополнительныеПараметры.ЭтоКабинет Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВыборКабинетаЗавершение", ЭтотОбъект);
		
		ПараметрыОткрытия = Новый Структура("СотрудникОтбораПомещений", Объект.Ссылка);		
		ОткрытьФорму("Справочник.Помещения.ФормаВыбора", ПараметрыОткрытия,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	КонецЕсли;
		
КонецПроцедуры

