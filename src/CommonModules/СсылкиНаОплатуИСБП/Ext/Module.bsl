// Функция - Сформировать ссылку оплаты ЮКасса
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьСсылкуОплатыЮКасса(СтруктураПараметров)
	
	// Документация
	// https://yookassa.ru/developers/payment-acceptance/getting-started/quick-start#create-payment 
	
	// 1. Проверка параметров эквайринга
	ПередаваемаяСтруктура	= Новый Структура; 
	СтруктураВозврата		= СтруктураПараметров.СтруктураВозврата; 
	ПараметрыПШ				= СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 			= СтруктураПараметров.СуммаОплаты;
	ТаблицаЗадолженностей	= СтруктураПараметров.ТаблицаЗадолженностей;
    ОснованиеПлатежа		= ТаблицаЗадолженностей[0].ДокументЗадолженности;
	
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура")
		Или Не ЗначениеЗаполнено(ПараметрыПШ.ЛогинБанка)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.ПарольБанка)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.UrlRedirect) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры эквайрингового терминала.";
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	ТекстОшибки             = "";
	КороткаяСсылкаНаОплату  = "";
	УИДПлатежа              = "";
	
	Попытка
		
		// 2. Формирвоание соединения и передача заголовков	
		Соединение    = Новый HTTPСоединение("api.yookassa.ru",, ПараметрыПШ.ЛогинБанка, ПараметрыПШ.ПарольБанка,,5, Новый ЗащищенноеСоединениеOpenSSL());
		ЗаголовкиHTTP = Новый Соответствие;
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json"); 	
		УИД = Строка(ОснованиеПлатежа.УникальныйИдентификатор());
		ЗаголовкиHTTP.Вставить("Idempotence-Key", УИД);  
		
		// 3. Формирвоание структуры данных и тела запроса		
		amount = Новый Структура("value, currency", СуммаОплаты, "RUB"); 
		ПередаваемаяСтруктура.Вставить("amount", amount);
		ПередаваемаяСтруктура.Вставить("capture", Истина);
		ОснованиеПлатежаСтрокой = Строка(ОснованиеПлатежа);
		ПередаваемаяСтруктура.Вставить("description", ОснованиеПлатежаСтрокой);
		confirmation = Новый Структура("type, return_url", "redirect", ПараметрыПШ.UrlRedirect);
		ПередаваемаяСтруктура.Вставить("confirmation", confirmation);
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто);
		ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
		ЗаписатьJSON(ЗаписьJSON, ПередаваемаяСтруктура);
		ТелоЗапроса = ЗаписьJSON.Закрыть();	
			
		// 4. Отправка данных в сервис    
		HTTPЗапрос = Новый HTTPЗапрос("/v3/payments", ЗаголовкиHTTP);
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		Запрос    = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТекстJSON = Запрос.ПолучитьТелоКакСтроку();
		
		// 5. Обработка ответа
		ЧтениеJSON    = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		ПараметрыJSON = ПрочитатьJSON(ЧтениеJSON);  
		
		Если ПараметрыJSON.Свойство("type") Тогда
			Если ПараметрыJSON.type = "error" Тогда 
				Если ПараметрыJSON.Свойство("description") Тогда
					ТекстОшибки = ПараметрыJSON.description;
				Иначе
					ТекстОшибки = "Ошибка при отправке данных в сервис ЮКасса на получение ссылки на оплату по " + ОснованиеПлатежаСтрокой;
				КонецЕсли;
			КонецЕсли; 		
		Иначе
			Если ПараметрыJSON.Свойство("id") Тогда
				УИДПлатежа = ПараметрыJSON.id;			
			КонецЕсли;			
			Если ПараметрыJSON.Свойство("confirmation") Тогда
				Если ПараметрыJSON.confirmation.Свойство("confirmation_url") Тогда 
					КороткаяСсылкаНаОплату = ПараметрыJSON.confirmation.confirmation_url; 
				КонецЕсли;
			КонецЕсли;			
		КонецЕсли;		
	Исключение  		
		ТекстОшибки       = "Ошибка при отправке данных в сервис ЮКасса на получение ссылки на оплату по " 
			+ ОснованиеПлатежаСтрокой + Символы.ПС + ОписаниеОшибки();
	КонецПопытки;
	
	Если Не ЗначениеЗаполнено(КороткаяСсылкаНаОплату) Или Не ЗначениеЗаполнено(УИДПлатежа) Тогда 
		ТекстОшибки = ?(ЗначениеЗаполнено(ТекстОшибки), ТекстОшибки, "Ошибка при отправке данных в сервис ЮКасса на получение ссылки на оплату по " 
			+ ОснованиеПлатежаСтрокой + Символы.ПС);
        ТекстОшибки = ТекстОшибки + ?(Не ЗначениеЗаполнено(КороткаяСсылкаНаОплату), "Не передана ссылка на оплату.", "Не передано значение id.");
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда		
		СтруктураВозврата.ОписаниеОшибки = ТекстОшибки;
		Возврат СтруктураВозврата;		
	КонецЕсли;
	
	СтруктураВозврата.Вставить("СсылкаНаОплату"		, КороткаяСсылкаНаОплату);
	СтруктураВозврата.Вставить("ВыполненоУспешно"	, Истина);
	
	// 6. Добавление в регистр Статусы оплаты заказов новой записи со статусом Не оплачено 
	НомерЗаказа = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьМассимальныйНомерЗаказа(Перечисления.ТипыСсылокНаОплату.ЮКасса) + 1;
	
	Для Каждого СтрокаТ Из ТаблицаЗадолженностей Цикл
		
	РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаТ.ДокументЗадолженности, 
		СтрокаТ.Задолженность, 
		УИДПлатежа, 
		КороткаяСсылкаНаОплату, 
		Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
		СтруктураПараметров.ЭквайринговыйТерминал, 
		НомерЗаказа,
		ТелоЗапроса,
		Не ЗначениеЗаполнено(СтрокаТ.ДокументЗадолженности),
		СтруктураПараметров.Контрагент,,
		СтруктураПараметров.СтруктурнаяЕдиница,
		ТекущаяДатаСеанса(),
		"Заказ зарегистрирован, но не оплачен",
		Перечисления.ТипыСсылокНаОплату.ЮКасса);
		
	КонецЦикла;
		
	Возврат СтруктураВозврата;
	
КонецФункции

#КонецОбласти

#Область СбербанкИPaymo

// Функция, формирует ссылку на оплату основание и возвращает её. 
//
// В случае если параметр sessionTimeoutSecs не задан, будет использовано значение, указанное в настройках мерчанта или время по умолчанию (1200 секунд = 20 минут).
// 
// expirationDate Дата и время окончания жизни заказа. Формат: yyyy-MM-ddTHH:mm:ss.
// Если этот параметр не передаётся в запросе, то для определения времени окончания жизни заказа используется sessionTimeoutSecs.
// Если в запросе присутствует параметр expirationDate, то значение параметра sessionTimeoutSecs не учитывается.
Функция СформироватьСсылкуОплатыСбербанк(СтруктураПараметров)
			
	СтруктураВозврата		= СтруктураПараметров.СтруктураВозврата; 
	ПараметрыПШ				= СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 			= СтруктураПараметров.СуммаОплаты;
	ТаблицаЗадолженностей	= СтруктураПараметров.ТаблицаЗадолженностей;	
	НомерЗаказа 			= СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
	Сумма              		= Формат(СуммаОплаты*100, "ЧГ="); // сумма в копейках.
	ДатаЗаказа         		= ТекущаяДатаСеанса();
	СтруктурнаяЕдиница 		= СтруктураПараметров.СтруктурнаяЕдиница;
	ПлатежныйШлюз      		= СтруктураПараметров.ТипБанка;
	Клиент              	= СтруктураПараметров.Контрагент;
	EmailКлиента			= СтруктураПараметров.АдресЭПКонтрагента;
	НомерТелефона	        = СтруктураПараметров.НомерТелефона;
	ЭквайринговыйТерминал   = СтруктураПараметров.ЭквайринговыйТерминал;
	ФискализацияВСбербанке  = ЭквайринговыйТерминал.ТипФискализации = Перечисления.ТипыФискализации.ВСбербанке;
	Основание               = ТаблицаЗадолженностей[0].ДокументЗадолженности;
	
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") ИЛИ Не ЗначениеЗаполнено(ПлатежныйШлюз) Тогда
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры эквайрингового терминала.";
		Возврат СтруктураВозврата;
	КонецЕсли;	
	
	URlRedirect        = ПараметрыПШ.UrlRedirect;
	Логин              = ПараметрыПШ.ЛогинБанка;
	Пароль             = ПараметрыПШ.ПарольБанка; 
	ВремяЖизниВЧасах   = ПараметрыПШ.ВремяЖизни;
	ВремяЖизниВСекундах = ?(ЗначениеЗаполнено(ВремяЖизниВЧасах), ВремяЖизниВЧасах*3600, 72*3600); // По умолчанию, если время не заполнено - 3 дня.
	
	Описание      = "";	
	Если ТаблицаЗадолженностей.Количество() > 0 И ТипЗнч(ТаблицаЗадолженностей[0].ДокументЗадолженности) = Тип("ДокументСсылка.Реализация") Тогда 
		ПервыйЭлемент = Истина;
		Для Каждого ОснованиеД Из ТаблицаЗадолженностей Цикл 
			Для Каждого СтрокаТЧ Из ОснованиеД.ДокументЗадолженности.Запасы Цикл						
				Если Не ПервыйЭлемент Тогда
					Описание = Описание + ", "	
				КонецЕсли;		
				НаименованиеНоменкалтуры = ПолучитьЗначенияРеквизитовПоСсылке(СтрокаТЧ.Номенклатура, "Наименование");
				Описание = НаименованиеНоменкалтуры + " x" + СтрокаТЧ.Количество;			
				ПервыйЭлемент = Ложь;			
			КонецЦикла;
		КонецЦикла;
	КонецЕсли; 
	
	Если ФискализацияВСбербанке = Истина Тогда 
		
		ЭтоЧастичнаяОплата = Ложь;
		orderBundle = Сбербанк_СформироватьМассивЭлементовДляФискализации(ТаблицаЗадолженностей, СтруктураПараметров, ЭтоЧастичнаяОплата);
		
		Если ЭтоЧастичнаяОплата = Истина Тогда 
			СтруктураВозврата.ОписаниеОшибки = "При фискализации на стороне сбербанка запрещены частичные оплаты.";
			Возврат СтруктураВозврата;
		КонецЕсли;	
		
	КонецЕсли;
	
	// https://securepayments.sberbank.ru/wiki/doku.php/integration:api:rest:requests:register
	НомерЗаказаВШлюзе = СформироватьНомерЗаказаСБП();
	
	ПараметрыЗапроса = "language=ru&orderNumber={OrderNumber}&returnUrl={URL}&amount={Amount}&password={Password}&userName={Login}&pageView=DESKTOP&description={Description}&sessionTimeoutSecs={SessionTimeoutSecs}&jsonParams={jsonParams}";
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{OrderNumber}"       , НомерЗаказаВШлюзе);	
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Amount}"            , Сумма);               
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{URL}"               , URlRedirect);
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Login}"             , Логин);
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Password}"          , КодироватьСтроку(Пароль, СпособКодированияСтроки.КодировкаURL)); 
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Description}"       , СформироватьОписаниеЗаказа(Описание));
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{SessionTimeoutSecs}", Формат(ВремяЖизниВСекундах, "ЧГ="));
	
	ПараметрыJson = Новый Структура("ClubID, phone, orderPhone, orderEmail, UserID, GoogleClientID, YandexClientID, ClubName");
	ClubName = СокрЛП(СтруктурнаяЕдиница);
	ClubName = СтрЗаменить(ClubName, """", "");
	ПараметрыJson.orderPhone = КодироватьСтроку(НомерТелефона, СпособКодированияСтроки.КодировкаURL);
	ПараметрыJson.phone 	 = КодироватьСтроку(НомерТелефона, СпособКодированияСтроки.КодировкаURL);
	ПараметрыJson.orderEmail = КодироватьСтроку(EmailКлиента  , СпособКодированияСтроки.КодировкаURL);
	ПараметрыJson.UserID     = КодироватьСтроку(Клиент.УникальныйИдентификатор(), СпособКодированияСтроки.КодировкаURL);
	ПараметрыJson.ClubID     = КодироватьСтроку(СтруктурнаяЕдиница.УникальныйИдентификатор(), СпособКодированияСтроки.КодировкаURL);
	ПараметрыJson.ClubName   = КодироватьСтроку(ClubName, СпособКодированияСтроки.КодировкаURL);
	
	Если ЗначениеЗаполнено(EmailКлиента) Тогда
		ПараметрыJson.Вставить("email", КодироватьСтроку(EmailКлиента, СпособКодированияСтроки.КодировкаURL));
	КонецЕсли;
	
	ПараметрыЗаявки = ПолучитьПараметрыЗаявкиДляРегистрацииЗаказа(Клиент);
	
	ПараметрыJson.GoogleClientID = КодироватьСтроку(ПараметрыЗаявки.ga_cid, СпособКодированияСтроки.КодировкаURL); 
	ПараметрыJson.YandexClientID = КодироватьСтроку(ПараметрыЗаявки.ym_cid, СпособКодированияСтроки.КодировкаURL);
	
	ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{jsonParams}", КодироватьВJSON(ПараметрыJson, Ложь));
	
	Если ФискализацияВСбербанке = Истина И ЗначениеЗаполнено(orderBundle) Тогда
		ПараметрыЗапроса = ПараметрыЗапроса + orderBundle;	
	КонецЕсли;
	
	Попытка
		ОтветОтСервера  = ВыполнитьGETЗапроскСбербанку(ПараметрыЗапроса, ПараметрыПШ.ТестовыйРежим);
	Исключение
		ОтветОтСервера = Неопределено;
	КонецПопытки;
	
	Если ОтветОтСервера = Неопределено Тогда
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при обращении к серверу";	
	ИначеЕсли ОтветОтСервера.Свойство("errorCode")  Тогда
		СтруктураВозврата.ОписаниеОшибки = ОтветОтСервера.errorMessage;
	Иначе		
		
		КороткаяСсылкаНаОплату = ПолучитьКороткуюСсылку(ОтветОтСервера.formUrl);
		Если ЗначениеЗаполнено(КороткаяСсылкаНаОплату) Тогда
			СтруктураВозврата.ВыполненоУспешно = Истина;
		КонецЕсли;
		СтруктураВозврата.Вставить("СсылкаНаОплату", КороткаяСсылкаНаОплату);
		СтруктураВозврата.Вставить("НомерЗаказа"   , НомерЗаказа);

		Для Каждого СтрокаТ Из ТаблицаЗадолженностей Цикл
			
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
			СтрокаТ.ДокументЗадолженности, 
			СтрокаТ.Задолженность, 
			ОтветОтСервера.orderId, 
			КороткаяСсылкаНаОплату, 
			Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
			СтруктураПараметров.ЭквайринговыйТерминал, 
			НомерЗаказа,
			ПараметрыЗапроса,
			Не ЗначениеЗаполнено(СтрокаТ.ДокументЗадолженности),
			СтруктураПараметров.Контрагент,,
			СтруктураПараметров.СтруктурнаяЕдиница,
			ДатаЗаказа,
			"Заказ зарегистрирован, но не оплачен",
			Перечисления.ТипыСсылокНаОплату.Сбербанк,,
			ТекущаяДатаСеанса() + ВремяЖизниВСекундах);
			
		КонецЦикла;
			
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Сбербанк отменить ссылку на оплату
//
// Параметры:
//  СтруктураПараметров	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_ОтменитьСсылку(СтруктураПараметров) 
	
	ДокументыЗадолженности = Новый Массив;
	Если СтруктураПараметров.Свойство("ТаблицаЗадолженностей") Тогда
		Для Каждого СтрокаТ Из СтруктураПараметров.ТаблицаЗадолженностей Цикл
			ДокументыЗадолженности.Добавить(СтрокаТ.ДокументЗадолженности);	
		КонецЦикла; 
	ИначеЕсли СтруктураПараметров.Свойство("ДокументыЗадолженности") Тогда
		ДокументыЗадолженности = СтруктураПараметров.ДокументыЗадолженности 	
	КонецЕсли;
	
	РезультатОперации			= СтруктураПараметров.СтруктураВозврата;
	ПараметрыПШ  				= СтруктураПараметров.ПараметрыПШ;
	НомерЗаказа					= ?(СтруктураПараметров.Свойство("НомерЗаказа"), СтруктураПараметров.НомерЗаказа, Неопределено);

	ТаблицаЗаказов = РегистрыСведений.СтатусыОплатыЗаказов.ПолучитьЗаказыПоДокументам(ДокументыЗадолженности, СтруктураПараметров.ЭквайринговыйТерминал, НомерЗаказа);
	
	Если ТаблицаЗаказов.Количество() = 0 Тогда
		РезультатОперации.ОписаниеОшибки = "Не найдено неоплаченных заказов по данной ссылке";
		Возврат РезультатОперации;	
	КонецЕсли;
	
	МассивИдЗаказов = Новый Массив;
	Для Каждого СтрокаЗаказа Из ТаблицаЗаказов Цикл
		
		Если МассивИдЗаказов.Найти(СтрокаЗаказа.ИдЗаказа) = Неопределено Тогда
			
			ПараметрыПШ = СтруктураПараметров.ЭквайринговыйТерминал.ПараметрыПлатежногоШлюза.Получить();
			Если ТипЗнч(ПараметрыПШ) <> Тип("Структура") Тогда
				
				РезультатОперации = Новый Структура;
				РезультатОперации.Вставить("ВыполненоУспешно" , Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки" , "Не заполнены параметры эквайрингового терминала.");
				Возврат РезультатОперации;   
				
			КонецЕсли;	
			
			ПараметрыЗапроса = "userName={Login}&password={Password}&language=ru&orderNumber={OrderNumber}";
			ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{OrderNumber}"       , СтрокаЗаказа.ИдЗаказа);	
			ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Login}"             , ПараметрыПШ.ЛогинБанка);
			ПараметрыЗапроса = СтрЗаменить(ПараметрыЗапроса, "{Password}"          , КодироватьСтроку(ПараметрыПШ.ПарольБанка, СпособКодированияСтроки.КодировкаURL)); 
			
			Попытка
				ОтветОтСервера  = ВыполнитьPOSTЗапроскСбербанку(ПараметрыЗапроса, ПараметрыПШ.ТестовыйРежим, "/payment/rest/decline.do?");
			Исключение
				ОтветОтСервера = Неопределено;
			КонецПопытки;
			
			РезультатОперации = СтруктураСтандартныхПараметровРезОперации();
			Если ОтветОтСервера = Неопределено Тогда
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				РезультатОперации.Вставить("ОписаниеОшибки", "Ошибка при обращении к серверу");
			ИначеЕсли ОтветОтСервера.Свойство("errorCode")  Тогда
				
				РезультатОперации.Вставить("ВыполненоУспешно", Ложь);
				
				Если СтрНайти(ОтветОтСервера.errorMessage, "Пользователь не имеет разрешения на отклонение заказов") > 0 Тогда
					РезультатОперации.Вставить("ОписаниеОшибки", ОтветОтСервера.errorMessage + ". Пожалуйста, обратитесь в банк");	
				Иначе
					РезультатОперации.Вставить("ОписаниеОшибки", ОтветОтСервера.errorMessage);	
				КонецЕсли;
				
			Иначе		
				РезультатОперации.Вставить("ВыполненоУспешно", Истина);
			КонецЕсли;
			
			Если РезультатОперации.ВыполненоУспешно = Ложь Тогда
				Возврат РезультатОперации;	
			КонецЕсли;
			
			МассивИдЗаказов.Добавить(СтрокаЗаказа.ИдЗаказа);
			
		КонецЕсли;
		
		ОписаниеСтатуса  = НСтр("ru='Платеж отменен';en='Payment canceled'");
		
		РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
			СтрокаЗаказа.Основание,,,,
			Перечисления.СтатусыЗаказовОнлайнОплаты.Отказ,,
			СтрокаЗаказа.НомерЗаказа,,,,,,,
			ОписаниеСтатуса);
		
	КонецЦикла;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Альфа банк получить статус платежа по QR
//
// Параметры:
//  ИдСБП				 - 	 - 
//  ПараметрыПШ			 - 	 - 
//  ИдентификаторQRКода	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция Сбербанк_ПолучитьСтатусПлатежаРасширенный(СтруктураПараметров, ПараметрыПШ, ТелоОтвета = Неопределено) Экспорт 
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("orderId"	   , СтруктураПараметров.ИдСБП);
	ПараметрыЗапроса.Вставить("orderNumber", СтруктураПараметров.НомерЗаказа);	
	ПараметрыЗапроса.Вставить("userName"   , ПараметрыПШ.ЛогинБанка);
	ПараметрыЗапроса.Вставить("password"   , КодироватьСтроку(ПараметрыПШ.ПарольБанка, СпособКодированияСтроки.КодировкаURL));
	
	ПараметрыЗапросаСтрокой = "";
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		ПараметрыЗапросаСтрокой = ПараметрыЗапросаСтрокой + ?(Не ЗначениеЗаполнено(ПараметрыЗапросаСтрокой), "?", "&") + ПараметрЗапроса.Ключ + "=" + ПараметрЗапроса.Значение;			
	КонецЦикла;	
	
	АдресСервера = ?(ПараметрыПШ.ТестовыйРежим, "3dsec.sberbank.ru", "securepayments.sberbank.ru");
	Соединение = Новый HTTPСоединение(АдресСервера,,,,,3, Новый ЗащищенноеСоединениеOpenSSL());	
	HTTPЗапрос = Новый HTTPЗапрос("/payment/rest/getOrderStatusExtended.do" + ПараметрыЗапросаСтрокой);								
	
    Попытка
		
		HTTPОтвет	 = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		ТелоОтвета	 = HTTPОтвет.ПолучитьТелоКакСтроку();	
		КодСостояния = HTTPОтвет.КодСостояния;
		
		Если КодСостояния = 200 ИЛИ СтрНачинаетсяС(ТелоОтвета, "{") Тогда 
			РезультатЗапроса = ДекодироватьИзJSON(ТелоОтвета);
		Иначе
			РезультатЗапроса = ТелоОтвета;
		КонецЕсли;
		
		РезультатОперации                     	= СтруктураСтандартныхПараметровРезОперации();		
		РезультатОперации.ВыполненоУспешно		= КодСостояния = 200 И РезультатЗапроса.Свойство("orderStatus") И РезультатЗапроса.Свойство("errorCode") И РезультатЗапроса.errorCode = "0";
		РезультатОперации.ПараметрыРезультата	= РезультатЗапроса;	
		РезультатОперации.КодОшибки       		= КодСостояния;
		РезультатОперации.ОписаниеОшибки 		= ?(ТипЗнч(РезультатЗапроса) = Тип("Структура") И РезультатОперации.ВыполненоУспешно = Ложь И РезультатЗапроса.Свойство("errorMessage"), РезультатЗапроса.errorMessage, ТелоОтвета);
		РезультатОперации.ТелоЗапроса			= ТелоОтвета;		
	Исключение		
		РезультатОперации = ОбработатьИсключениеПриВыполненииHTTPЗапроса(ИнформацияОбОшибке(), HTTPОтвет);	
	КонецПопытки;
	
	Возврат РезультатОперации; 
		
КонецФункции

// Функция, возвращает параметры заявки для регистрации заказа в разрезе контрагента.
//
Функция ПолучитьПараметрыЗаявкиДляРегистрацииЗаказа(Клиент)
	
	ПараметрыЗаявки = Новый Структура("ga_cid, ym_cid", "", "");
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Заявки.ga_cid КАК ga_cid,
	|	Заявки.ym_cid КАК ym_cid
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.ga_cid <> """"
	|	И Заявки.ym_cid <> """"
	|	И Заявки.ОсновнойКлиент = &ОсновнойКлиент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Заявки.ДатаСоздания УБЫВ");
	
	Запрос.УстановитьПараметр("ОсновнойКлиент", Клиент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыЗаявки, Выборка);		
	КонецЕсли;
	
	Возврат ПараметрыЗаявки;
	
КонецФункции

