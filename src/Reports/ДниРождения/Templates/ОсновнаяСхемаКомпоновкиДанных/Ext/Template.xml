		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Контрагенты.Ссылка КАК Клиент,
	Контрагенты.ДатаРожденияКлиента КАК ДатаРожденияКлиента,
	СтатусыКонтрагентовСрезПоследних.Статус КАК Статус,
	ВложенныйЗапрос.ВозрастКлиента КАК Возраст
ИЗ
	Справочник.Контрагенты КАК Контрагенты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
			ПО Контрагенты.Ссылка = КонтрагентыСегмента.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКонтрагентов.СрезПоследних({(&amp;ТекущаяДата)}, ) КАК СтатусыКонтрагентовСрезПоследних
		ПО Контрагенты.Ссылка = СтатусыКонтрагентовСрезПоследних.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ВЫБОР
				КОГДА Контрагенты.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА ВЫБОР
							КОГДА МЕСЯЦ(&amp;ТекущаяДата) &lt; МЕСЯЦ(Контрагенты.ДатаРожденияКлиента)
								ТОГДА РАЗНОСТЬДАТ(Контрагенты.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД) - 1
							КОГДА МЕСЯЦ(&amp;ТекущаяДата) &gt; МЕСЯЦ(Контрагенты.ДатаРожденияКлиента)
								ТОГДА РАЗНОСТЬДАТ(Контрагенты.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД)
							КОГДА МЕСЯЦ(&amp;ТекущаяДата) = МЕСЯЦ(Контрагенты.ДатаРожденияКлиента)
								ТОГДА ВЫБОР
										КОГДА ДЕНЬ(&amp;ТекущаяДата) &lt; ДЕНЬ(Контрагенты.ДатаРожденияКлиента)
											ТОГДА РАЗНОСТЬДАТ(Контрагенты.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД) - 1
										КОГДА ДЕНЬ(&amp;ТекущаяДата) &gt;= ДЕНЬ(Контрагенты.ДатаРожденияКлиента)
											ТОГДА РАЗНОСТЬДАТ(Контрагенты.ДатаРожденияКлиента, &amp;ТекущаяДата, ГОД)
									КОНЕЦ
							ИНАЧЕ NULL
						КОНЕЦ
				ИНАЧЕ NULL
			КОНЕЦ КАК ВозрастКлиента,
			Контрагенты.Ссылка КАК Ссылка
		ИЗ
			Справочник.Контрагенты КАК Контрагенты) КАК ВложенныйЗапрос
		ПО Контрагенты.Ссылка = ВложенныйЗапрос.Ссылка
ГДЕ
	Контрагенты.ЭтоГруппа = ЛОЖЬ
	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	И Контрагенты.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
	И МЕСЯЦ(Контрагенты.ДатаРожденияКлиента) * 100 + ДЕНЬ(Контрагенты.ДатаРожденияКлиента) МЕЖДУ МЕСЯЦ(&amp;НачалоПериода) * 100 + ДЕНЬ(&amp;НачалоПериода) И МЕСЯЦ(&amp;КонецПериода) * 100 + ДЕНЬ(&amp;КонецПериода)</query>
	</dataSet>
