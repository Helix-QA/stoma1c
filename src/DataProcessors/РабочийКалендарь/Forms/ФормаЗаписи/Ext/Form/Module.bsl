// Обработчик журнала ПЗ, уменьшить интервала раб.времени сотрудника 
//
Процедура ГрафикПЗВремяРаботыСотрудникаУменьшить(Команда)
	
	Область = Элементы.ТабличныйДокумент.ТекущаяОбласть;	
	Если НЕ ПЗРасшифровкаТекущейОбласти = Неопределено  Тогда		
		Если ЗначениеЗаполнено(ПЗРасшифровкаТекущейОбласти.Событие) Тогда
			ПоказатьПредупреждение(,"Неудалось установить время нерабочим. Интервал занят " + ПЗРасшифровкаТекущейОбласти.Событие);
			Возврат;
		КонецЕсли;
		ИнтервалВремени = ОпределнениеИнтервалаВремени(ИнтервалГрафика);
		Старт = ПЗРасшифровкаТекущейОбласти.Дата + Цел(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ИнтервалВремени)) * 60 * 60 + ОбщегоНазначенияКлиентСерверСтоматология.Дроб(ПЗРасшифровкаТекущейОбласти.Интервал / (60/ИнтервалВремени)) * (60/ИнтервалВремени) * ИнтервалВремени * 60;
		Финиш = Старт + (Область.Низ - Область.Верх + 1) / (60/ИнтервалВремени) * 60 * 60;
		
		ПолученныйСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
		ВозвращатьСообщение = Ложь;
		
		Если ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Сотрудники") И НЕ ПЗФиьтрГрафикаТекущаяСтрока.Пустая() Тогда			
			ПолученныйСотрудник = ПЗФиьтрГрафикаТекущаяСтрока;
			ВозвращатьСообщение = Истина;
		ИначеЕсли ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("Строка") ИЛИ ТипЗнч(ПЗФиьтрГрафикаТекущаяСтрока) = Тип("СправочникСсылка.Должности") Тогда 
			ПолученныйСотрудник = ВернутьСотрудникаПоШапке(Область.Имя); 
			ВозвращатьСообщение = Истина;	
		КонецЕсли;
		
		Если ВозвращатьСообщение И ЗначениеЗаполнено(ПолученныйСотрудник) Тогда
			ВозвратСообщения = "";
			
			// Проверка возможности удаления рабочего времени
			Если НЕ ПроверитьВозможностьУдаленияРабочегоВремениСотрудника(Старт, Финиш, ПолученныйСотрудник, Объект.СтруктурнаяЕдиница, ВозвратСообщения) Тогда
				ОписаниеОповещения = Новый ОписаниеОповещения("ГрафикПЗВремяРаботыПослеВопроса", ЭтотОбъект, 
									 Новый Структура("ПолученныйСотрудник, Старт, Финиш, РасширениеИнтервала", ПолученныйСотрудник, Старт, Финиш, Ложь));
				ПоказатьВопрос(ОписаниеОповещения,ВозвратСообщения+" Продолжить?",РежимДиалогаВопрос.ДаНет);
				Возврат;			
			КонецЕсли;
			
			УстановитьРабочееВремя(Старт,Финиш,ПолученныйСотрудник,Ложь, Объект.СтруктурнаяЕдиница);
			ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);  
			
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры


