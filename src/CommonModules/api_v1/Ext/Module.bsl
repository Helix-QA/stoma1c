// Функция осуществляет создание предварительной записи
//
Функция book_record(СтруктурнаяЕдиница
					, record_array
					, Клиент
					, ФИОКлиента
					, ИсточникИнформации
					, КомментарийЗаписи
					, ВнешняяСистема
					, НомерТелефона
					, ЗаКакоеВремяНапоминатьОЗаписи
					, ДополнительныеПараметры = Неопределено
					, email = Неопределено
					, birthday = Неопределено) Экспорт
	
	СтруктураОшибки = Неопределено;
	ТаблицаЗначенийЗаписи = ПолучитьТаблицуЗаписи(record_array, СтруктураОшибки);
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;			
	КонецЕсли;
	
	СтруктураОшибки = ПроверитьТаблицуЗаписи(ТаблицаЗначенийЗаписи, СтруктурнаяЕдиница);
	
	Если СтруктураОшибки <> Неопределено Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	АвторДокумента 		= ?(ИсточникИнформации = "Чат-бот", Константы.СотрудникЧатБота.Получить(), Неопределено);
	ИсточникИнформации 	= ПолучитьРекламныйИсточник(ИсточникИнформации);
	СтруктураОшибки    	= ОбновитьИнформациюОКлиенте(Клиент, ФИОКлиента, ИсточникИнформации, email, birthday, СтруктурнаяЕдиница);
		
	Если СтруктураОшибки <> Неопределено Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	                           
	Врач      	= ?(ТаблицаЗначенийЗаписи.Количество() <> 0, ТаблицаЗначенийЗаписи[0].Сотрудник, Неопределено);
	Заявка    	= ПолучитьЗаявку(Клиент, ФИОКлиента, ИсточникИнформации, СтруктурнаяЕдиница, ВнешняяСистема, НомерТелефона);	
	Сделка 		= Справочники.Сделки.ИнициализироватьПредопределеннуюСделку(Клиент, СтруктурнаяЕдиница, Врач, , , , Истина, 3);
	
	ОбъектСобытие = СформироватьСобытие(Клиент
										, ТаблицаЗначенийЗаписи
										, СтруктурнаяЕдиница
										, ВнешняяСистема
										, ИсточникИнформации
										, КомментарийЗаписи
										, Сделка
										, ЗаКакоеВремяНапоминатьОЗаписи);
										
	Если ЗначениеЗаполнено(АвторДокумента) Тогда 
		ОбъектСобытие.АвторДокумента = АвторДокумента;
	КонецЕсли;	
	ЕстьПараметрыСценария = ЗаписатьДополнительныеПараметры(ОбъектСобытие, ДополнительныеПараметры);										
		
	Попытка
		ОбъектСобытие.ДополнительныеСвойства.Вставить("ОбновлениеРабочегоСтола", Истина);
		ОбъектСобытие.ДополнительныеСвойства.Вставить("ДобавленаОнлайнЗапись", Истина);
		
		ОбъектСобытие.Записать(РежимЗаписиДокумента.Проведение);
		Событие = ОбъектСобытие.Ссылка;
		
		Если ЗначениеЗаполнено(ОбъектСобытие.ПеренесённаяПредварительнаяЗапись) Тогда 
			РегистрыСведений.МеткиКлиентов.ПеренестиМеткиОбъекта(ОбъектСобытие.ПеренесённаяПредварительнаяЗапись, Событие);
		КонецЕсли;	
	Исключение
		Возврат ПолучитьСтруктуруВозвратаОшибки(1000, ОписаниеОшибки());
	КонецПопытки;	
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Result"	  , Истина);
	СтруктураВозврата.Вставить("record_id", Строка(Событие.УникальныйИдентификатор()));
	СтруктураВозврата.Вставить("status"   , "Reserved");
	Если ЕстьПараметрыСценария Тогда 
		СтруктураВозврата.Вставить("record", Событие);
	КонецЕсли;	

	Возврат Новый Структура("Parameters, Errors", СтруктураВозврата, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
		
КонецФункции

