// Функция возвращает символьное представление используемой валюты.
// 
Функция ПолучитьСимвольноеПредставлениеВалюты() Экспорт
	
	Валюта = Константы.ВалютаУчета.Получить();	
	Если НЕ ЗначениеЗаполнено(Валюта) ИЛИ ТипЗнч(Валюта)<>Тип("СправочникСсылка.Валюты") Тогда
		Возврат "";
	КонецЕсли; 
	
	Если Валюта.СимвольноеПредставление <> "" Тогда	
		Возврат Валюта.СимвольноеПредставление;
	Иначе
		СтрокаПараметров = СтрЗаменить(Валюта.ПараметрыПрописи, ",", Символы.ПС);
		ЦелаяЧасть       = СокрЛП(СтрПолучитьСтроку(СтрокаПараметров,10));
		Возврат ?(ЦелаяЧасть ="", " "+Строка(Валюта)+" ", " "+ЦелаяЧасть+" ");
	КонецЕсли;
	
КонецФункции 

// Модифицирована слиянием механизма БСП с неким, используемым ранее
// 
Функция ЕстьРеквизитОбъекта(ИмяРеквизита, МетаданныеОбъекта = Неопределено, Объект = Неопределено) Экспорт
	
	Если МетаданныеОбъекта = Неопределено И НЕ Объект = Неопределено Тогда 
		КлючУникальности   = Новый УникальныйИдентификатор;
		СтруктураРеквизита = Новый Структура(ИмяРеквизита, КлючУникальности);
		ЗаполнитьЗначенияСвойств(СтруктураРеквизита, Объект);
		
		Возврат СтруктураРеквизита[ИмяРеквизита] <> КлючУникальности;
		
	ИначеЕсли НЕ МетаданныеОбъекта = Неопределено Тогда
		
		Возврат НЕ (МетаданныеОбъекта.Реквизиты.Найти(ИмяРеквизита) = Неопределено);
		
	КонецЕсли;
		
	Возврат Ложь;		

КонецФункции

// Модифицирована слиянием механизма БСП с неким, используемым ранее
// 
Функция ЕстьРеквизитОбъектаМодифицирована(ИмяРеквизита, МетаданныеОбъекта = Неопределено, Объект = Неопределено) Экспорт
	
