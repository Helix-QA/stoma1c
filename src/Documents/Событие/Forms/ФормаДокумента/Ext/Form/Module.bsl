// Процедура - обработчик события ПослеЗаписи.
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если Не НеОбновлятьРабочийСтол Тогда  
		Оповестить("ИзмененоСобытие", Объект.Ссылка);
	КонецЕсли;
	
	Если ЭтоНовыйДок Тогда 
		ОповеститьОЗаписиНового(Объект.Ссылка);
		Оповестить("ОбновитьИсториюВзаимодействияКонтрагента", Новый Структура("Пациент, Сделка, ТелефонДляСоздания", Объект.Контрагент, Объект.Сделка, Телефон_НовыйПациент));
		Если ЗначениеЗаполнено(Объект.Сделка) Тогда 
			Оповестить("ОБНОВИТЬ_СВЕДЕНИЯ_ПО_СДЕЛКАМ", Объект.Сделка);
		КонецЕсли;	
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ЗаявкаОснование"            , Неопределено);
		Оповестить("СозданиеСобытияСКонтрагентом", ПараметрыОткрытия); 
		
	КонецЕсли;	 
	
КонецПроцедуры

