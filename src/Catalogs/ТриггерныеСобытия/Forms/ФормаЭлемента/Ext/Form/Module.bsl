			СписокЗначенийОтветаНаВопрос = Новый СписокЗначений;
			СписокЗначенийОтветаНаВопрос.Добавить("Удалить", "Да");
			СписокЗначенийОтветаНаВопрос.Добавить("УдалитьИОтключитьВопрос", "Да, больше не спрашивать");
			СписокЗначенийОтветаНаВопрос.Добавить("Отмена", "Отмена");			
			ПоказатьВопрос(Оповещение, ТекстВопроса, СписокЗначенийОтветаНаВопрос, , , НСтр("ru='Вопрос пользователю';en='Question to the user'"));
		Иначе 
			УдалитьДействиеТриггера(СтруктураДанныеЭлемента.ДанныеЭлемента);
		КонецЕсли;
	КонецЕсли;	
			
КонецПроцедуры

