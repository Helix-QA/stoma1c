Процедура УдалитьСтрокуРасшифровки(Команда)
	
	ИндексСтроки = ПолучитьИндексСтроки(ЭтаФорма.ТекущийЭлемент.Имя);
	УдалитьЭлементыРасшифровкиПлатежа(ИндексСтроки);
	
	Если Объект.РасшифровкаПлатежа.Количество() = 0 Тогда
		ДобавитьСтрокуРасшифровки(Неопределено);
	КонецЕсли;
	
	Объект.СуммаДокумента = Объект.РасшифровкаПлатежа.Итог("Сумма");
	
КонецПроцедуры

&НаСервере
// Получает ссылки на внешнее оборудование.
//
Функция ПолучитьСсылкиНаОборудованиеФР()
	
	Возврат ?(ЗначениеЗаполнено(Объект.Касса) И ЗначениеЗаполнено(Объект.Касса.ВнешнееОборудование),
				Объект.Касса.ВнешнееОборудование.Ссылка,
				Справочники.ПодключаемоеОборудование.ПустаяСсылка());
	
КонецФункции // ПолучитьСсылкиНаОборудование

&НаСервере
// Процедура - устанавливает видимость реквизитов в зависимости от хозяйственной операции.
//
Процедура УстановитьВидимость()
	
	// ЭтаФорма.ТолькоПросмотр = ЗначениеЗаполнено(Объект.НомерЧекаККМ); 
	// Элементы.ГруппаБлокировкаДокумента.Видимость =  ЗначениеЗаполнено(Объект.НомерЧекаККМ);
	
	// Установка первой части заголовка по типу операции
	Если Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента Тогда
		ЭтаФорма.Заголовок = "Оплата от пациента";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет Тогда
		ЭтаФорма.Заголовок = "Взнос на лицевой счет";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика Тогда
		ЭтаФорма.Заголовок = "Возврат от поставщика";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзБанка Тогда
		ЭтаФорма.Заголовок = "Поступление из банка";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзКассы Тогда
		ЭтаФорма.Заголовок = "Поступление из кассы";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОтПодотчетника Тогда
		ЭтаФорма.Заголовок = "Возврат от подотчетника";		
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда
		ЭтаФорма.Заголовок = "Возврат оплаты клиенту";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании Тогда		
		ЭтаФорма.Заголовок = "Оплата от страховой компании";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратНалога Тогда		
		ЭтаФорма.Заголовок = "Возврат налога";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеОтЭквайера Тогда
		ЭтаФорма.Заголовок = "Поступление от эквайера";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗайма Тогда
		ЭтаФорма.Заголовок = "Получение, возврат займа";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВводОстатков Тогда		
		ЭтаФорма.Заголовок = "Ввод начальных остатков";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗайма Тогда		
		ЭтаФорма.Заголовок = "Получение, возврат займа";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВзносУчредителя Тогда		
		ЭтаФорма.Заголовок = "Взнос учредителя";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ВозвратЗаработнойПлаты Тогда	
		ЭтаФорма.Заголовок = "Возврат заработной платы";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПрочееПоступление Тогда	
		ЭтаФорма.Заголовок = "Прочее поступление";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы Тогда
		ЭтаФорма.Заголовок = "Поступление розничной выручки из операционной кассы";
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзКассыПредприятия Тогда
		ЭтаФорма.Заголовок = "Поступление из кассы предприятия";
	КонецЕсли;
	
	// Изменение состава списка выбора операции и установка втрой части заголовка по виду денежных средств
	Элементы.ВидОперации.СписокВыбора.Очистить();
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтКлиента);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПоступлениеИзБанка);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОтПодотчетника);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратЗайма);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратЗаработнойПлаты);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВводОстатков);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВзносУчредителя);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПрочееПоступление);		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы);		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПоступлениеИзКассыПредприятия);		
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " наличными средствами";		
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда	
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтКлиента);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыОтПоставщика);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПоступлениеОтЭквайера);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратНалога);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратЗайма);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратЗаработнойПлаты);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВводОстатков);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВзносУчредителя);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПоступлениеИзКассы);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПрочееПоступление);
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " безналичными средствами";
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта Тогда		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ОплатаОтКлиента);
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " платежной картой";
	ИначеЕсли Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда	
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ВозвратОплатыКлиенту);
        Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОпераций.ПрочееПоступление);
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " на лицевой счет";
	КонецЕсли;	
	
	ЭтаФорма.ТолькоПросмотр                      = ЭтотОбъект.ЗаблокироватьРедактирование; 	
	Элементы.ГруппаБлокировкаДокумента.Видимость = ЭтотОбъект.ЗаблокироватьРедактирование;
	Элементы.ГруппаОтменаПробития.Видимость      = Ложь;
	Элементы.Очистить_Чек.Доступность 			 = РольДоступна("ПолныеПрава") И Объект.НомерЧекаККМ = 99999999;
	Элементы.Очистить_Чек.Видимость				 = ЭтаФорма.ТолькоПросмотр;
	Элементы.ДекорацияОповещениеБлокировки.МаксимальнаяШирина = 111;
	
	Если (Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтКлиента 
		ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании) Тогда
		
		СуществующийДокСписания = ПолучитьСсылкуДокументаСписанияПоОтменеОшибочнойОплаты(Объект.Ссылка);
		
		Если ЗначениеЗаполнено(СуществующийДокСписания) 
			ИЛИ НачалоДня(Объект.Дата) = НачалоДня(ТекущаяДата()) 
			ИЛИ НЕ ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
			
			Элементы.ГруппаОтменаПробития.Видимость = Истина;
			Элементы.ДекорацияОповещениеБлокировки.МаксимальнаяШирина = 90;
			
			Если НЕ ЗначениеЗаполнено(СуществующийДокСписания) Тогда
				Элементы.ДекорацияОтменаОплаты.Заголовок = НСтр("ru = 'Отменить'; en = 'Cancel'");
			Иначе
				Элементы.ДекорацияОтменаОплаты.Заголовок = НСтр("ru = 'Отменен: '; en = 'Canceled: '") + СуществующийДокСписания;
				Элементы.ДекорацияОповещениеБлокировки.МаксимальнаяШирина = 64;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

	Если Элементы.ВидОперации.СписокВыбора.НайтиПоЗначению(Объект.ВидОперации) = Неопределено Тогда		
		Объект.ВидОперации = Неопределено;
		ЭтаФорма.Заголовок = "Поступление денежных средств";
		
		СтрокаТаблицыРасшифровки = Элементы.Найти("Основание_0");
		Если НЕ СтрокаТаблицыРасшифровки = Неопределено И Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные Тогда
			СтрокаТаблицыРасшифровки.МаксимальнаяШирина = 90;		
		КонецЕсли;
		
	КонецЕсли;	
	Если Объект.Ссылка.Пустая() Тогда
		ЭтаФорма.Заголовок = ЭтаФорма.Заголовок + " (создание)";
	КонецЕсли;		
	Если ЗначениеЗаполнено(Объект.КассоваяСмена) Тогда
		Элементы.КассоваяСменаТекущая.Видимость = Истина;
		мНомер                           = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Объект.КассоваяСмена.Номер, "");		
		КассоваяСменаТекущая = "Кассовая смена № " + ?(Найти(мНомер, "-") > 0, мНомер, "00"+мНомер) + " от " + Формат(Объект.КассоваяСмена.Дата,"ДФ=dd.MM.yyyy");
	Иначе
		Элементы.КассоваяСменаТекущая.Видимость = Ложь;
	КонецЕсли;
	
	// Установка состояния элементов формы
	УправлениеИнтерфейсамиСервер.УстановкаСостоянийЭлементовФормы(ЭтаФорма,Объект);
	// Установка банковского счета контрагента по умолчанию(при указанных условиях)
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		И НЕ Объект.ВидОперации     = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет	
		И НЕ ЗначениеЗаполнено(Объект.БанковскийСчетКонтрагента) 
		И ЗначениеЗаполнено(Объект.Контрагент) Тогда	
		Объект.БанковскийСчетКонтрагента = Объект.Контрагент.БанковскийСчетПоУмолчанию;
	ИначеЕсли (Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзБанка ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзКассы)
		И НЕ ЗначениеЗаполнено(Объект.БанковскийСчетКонтрагента) Тогда
		Объект.БанковскийСчетКонтрагента = Объект.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию;
	КонецЕсли;    
	Если Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные
		И НЕ ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда	
		Объект.БанковскийСчет = Объект.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию;
	КонецЕсли; 	
	Элементы.РасшифровкаПлатежаСтатья.Видимость = Объект.СтатьяВТаблице;

	УстановитьДоступностьПечатиЧека();
	ОбновитьИнформациюПоОстаткамЛСиЗадолженностям();
	Если ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
		Элементы.СтруктурнаяЕдиница.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	ОбновитьОтображениеРасшифровки();
	Элементы.Договор.Видимость = ЗначениеЗаполнено(Объект.Контрагент) 
		И ?(ТипЗнч(Объект.Контрагент) = Тип("СправочникСсылка.Контрагенты") 
		И Объект.Контрагент.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты, Ложь, Истина);  
		
	Если ВыполнятьОперациюНаЭТ(Объект.ТипДенежныхСредств, Объект.ВидОперации, Объект.Касса, Объект.ЭквайрингТерминал) = Истина Тогда
		Элементы.НапечататьЧек.Заголовок = Нстр("ru = 'Пробить на ФР и ЭТ'; en = 'Punch on FR and AT'");
	Иначе
		Элементы.НапечататьЧек.Заголовок = Нстр("ru = 'Пробить на ФР'; en = 'Punch on FR'");
	КонецЕсли;
		
КонецПроцедуры 

&НаСервере
// Процедура - устанавливает доступность кнопки "НапечататьЧек".
//
Процедура УстановитьДоступностьПечатиЧека()
	
	Разрешено = Ложь;
	ТекстОшибки   = "";
	Если НЕ ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
		Если Объект.ВидОперации  = Перечисления.ВидыОпераций.ОплатаОтКлиента
		 ИЛИ Объект.ВидОперации  = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет
		 ИЛИ Объект.ВидОперации = Перечисления.ВидыОпераций.ПоступлениеИзКассыПредприятия
		 ИЛИ (Объект.ВидОперации  = Перечисления.ВидыОпераций.ОплатаОтСтраховойКомпании
		   И (Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные  
		 ИЛИ  Объект.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта)) Тогда
			Разрешено = Истина;
		ИначеЕсли Объект.ВидОперации  = Перечисления.ВидыОпераций.ВозвратОплатыКлиенту Тогда		
			Разрешено = Ложь;
			Для Каждого СтрокаТЧ ИЗ Объект.РасшифровкаПлатежа Цикл			
				Если ЗначениеЗаполнено(СтрокаТЧ.ДокументОснования) И НЕ НачалоДня(СтрокаТЧ.ДокументОснования.Дата) = НачалоДня(Объект.Дата) Тогда
					Разрешено = Ложь;
					Прервать;
				Иначе
					Разрешено = Истина;
				КонецЕсли;	
			КонецЦикла;
		Иначе
			Разрешено = Ложь;
		КонецЕсли;     
	КонецЕсли;
	
	Если Разрешено Тогда
		
		РозничныеПродажи.СменаОткрыта(Объект.КассоваяСмена, ТекущаяДата(), ТекстОшибки);

		Если ((СокрЛП(ТекстОшибки) = "Кассовая смена закрыта") ИЛИ (СокрЛП(ТекстОшибки) = "Кассовая смена не открыта")) ИЛИ (Лев(ТекстОшибки, 33) = "С момента открытия кассовой смены") Тогда
			Разрешено = Ложь;	
		КонецЕсли;	

	КонецЕсли;
	
	Элементы.НапечататьЧек.Доступность = Разрешено;

КонецПроцедуры 

