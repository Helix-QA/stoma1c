// Функция осуществляет обработку внешних событий торгового оборудования.
//
Функция ОбработатьСобытие(ОбъектДрайвера, Параметры, ПараметрыПодключения, Событие, Данные, ВыходныеПараметры) Экспорт

	Результат = Истина;
	
	Если Параметры.Свойство("КонвертироватьКодКарты") и Параметры.КонвертироватьКодКарты Тогда
		Попытка
			КодКарты = Конвертировать_10_В_16_СС(Число(Данные));
		Исключение
			КодКарты = Данные;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Ошибка конвертирования кода карты: ';en='Mistake conversion code cards:'") + Данные);
		КонецПопытки;
	Иначе	
		КодКарты = Данные;	
	КонецЕсли;
	
    ДанныеДорожек = Новый Массив;
	ДанныеДорожек.Добавить(Неопределено);
	ДанныеДорожек.Добавить(КодКарты);
	ДанныеДорожек.Добавить(Неопределено);
	
	ВыходныеПараметры.Добавить("TracksData");
	ВыходныеПараметры.Добавить(Новый Массив());
	ВыходныеПараметры[1].Добавить(КодКарты);
	ВыходныеПараметры[1].Добавить(Новый Массив);
	ВыходныеПараметры[1][1].Добавить(КодКарты);
	ВыходныеПараметры[1][1].Добавить(ДанныеДорожек);
	ВыходныеПараметры[1][1].Добавить(0);	
	Возврат Результат;

КонецФункции

