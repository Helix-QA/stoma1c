// Процедура, обнвляет записи регистра контрагенты сведения для списка.
//
Процедура ОбновитьЗаписиРегистраКонтрагентыСведенияДляСписка()

	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить();
	ЭлементБлокировки.Область = "РегистрСведений.КонтрагентыСведенияДляСписка";
	ЭлементБлокировки.УстановитьЗначение("Контрагент", Контрагент);
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	Блокировка.Заблокировать();

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Сделки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.Контрагент = &Контрагент
	|	И НЕ Сделки.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сделки.ДатаСделки УБЫВ";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Выборка = Запрос.Выполнить().Выбрать();
	
	МенеджерЗаписи = РегистрыСведений.КонтрагентыСведенияДляСписка.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Контрагент = Контрагент;
	МенеджерЗаписи.Прочитать();
	
	Если НЕ МенеджерЗаписи.Выбран() Тогда
		МенеджерЗаписи.Контрагент = Контрагент;
	КонецЕсли;
	
	Если Выборка.Следующий() Тогда
		
		ПоследняяСделка = Выборка.Ссылка;
			
		МенеджерЗаписи.ТекущаяСделка     = ПоследняяСделка;
		МенеджерЗаписи.ТекущийЭтапСделки = ПоследняяСделка.ЭтапСделки;
		
	Иначе 
		
		МенеджерЗаписи.ТекущаяСделка     = Справочники.Сделки.ПустаяСсылка();
		МенеджерЗаписи.ТекущийЭтапСделки = Справочники.ЭтапыСделок.ПустаяСсылка();
						
	КонецЕсли;
	
	МенеджерЗаписи.Записать();

КонецПроцедуры

// Процедура - Зафиксировать историю изменения этапов
//
Процедура ЗафиксироватьИсториюИзмененияЭтапов()
	
	Если ЗначениеЗаполнено(ЭтотОбъект.ЭтапСделки) Тогда
		Если ЭтотОбъект.Ссылка.Пустая() Тогда 
			ПереходСЭтапа = Справочники.ЭтапыСделок.ПустаяСсылка();
			ПереходНаЭтап = ЭтотОбъект.ЭтапСделки;
		ИначеЕсли ЭтотОбъект.ЭтапСделки <> ЭтотОбъект.Ссылка.ЭтапСделки Тогда 
			ПереходСЭтапа = ЭтотОбъект.Ссылка.ЭтапСделки;
			ПереходНаЭтап = ЭтотОбъект.ЭтапСделки;
			Если ЭтотОбъект.ЭтапСделки = Справочники.ЭтапыСделок.Отказ Тогда 
				ЭтотОбъект.ДополнительныеСвойства.Вставить("УстановленЭтапОтказ", Истина);
			КонецЕсли;	
		Иначе 
			Возврат;
		КонецЕсли;	
	Иначе 
		Возврат;
	КонецЕсли;
	
	НоваяСтрока 				= ЭтотОбъект.ИсторияИзмененияЭтапов.Добавить();
	НоваяСтрока.Дата 			= ТекущаяДатаСеанса();
	НоваяСтрока.ПереходСЭтапа 	= ПереходСЭтапа;
	НоваяСтрока.ПереходНаЭтап 	= ПереходНаЭтап;
	НоваяСтрока.Автор			= ПараметрыСеанса.ТекущийСотрудник;
	
КонецПроцедуры

