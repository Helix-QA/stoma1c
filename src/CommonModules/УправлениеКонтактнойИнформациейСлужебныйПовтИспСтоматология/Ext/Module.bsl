// Возвращает имя события для регистрации в журнале событий контактной информации
//
Функция СобытиеЖурналаРегистрации() Экспорт
	Возврат НСтр("ru='Контактная информация'");
КонецФункции

// Определяет наличие доступности подсистемы АдресныйКлассификатор и наличие записей о регионах в регистре сведений
// АдресныеОбъекты.
//
Функция АдресныйКлассификаторДоступен() Экспорт
	ЕстьКлассификатор = ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.АдресныйКлассификатор");
	Если ЕстьКлассификатор И НЕ ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
		МодульАдресныйКлассификаторСлужебный = ОбщегоНазначения.ОбщийМодуль("АдресныйКлассификаторСлужебный");
		ЕстьКлассификатор = МодульАдресныйКлассификаторСлужебный.ПроверитьНачальноеЗаполнение();
	КонецЕсли;
	
	Возврат ЕстьКлассификатор;
КонецФункции

// Функция - Начать преобразование формата телефонных номеров
//
// Параметры:
//  ПараметрыСообщения	 - 	 - 
//
Функция НачатьПреобразованиеФорматаТелефонныхНомеров(УникальныйИдентификатор, ПараметрыПреобразования = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ТипЗнч(ПараметрыПреобразования) = Тип("Структура") И ПараметрыПреобразования.Свойство("СтранаУчета") И ЗначениеЗаполнено(ПараметрыПреобразования.СтранаУчета) Тогда
		СтранаУчета = ПараметрыПреобразования.СтранаУчета;
		ПараметрыПроцедуры = ПараметрыПреобразования;		
	Иначе
		РегиональныеНастройкиСЕ = Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки();
		СтранаУчета = РегиональныеНастройкиСЕ.СтранаУчета;
		ПараметрыПроцедуры = Новый Структура;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтранаУчета) И (СтранаУчета.Код = "643" ИЛИ СтранаУчета.Код = "784") Тогда
		
		УникальныйИдентификаторФормы = Новый УникальныйИдентификатор(УникальныйИдентификатор);
		
		ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
		Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
			Возврат Неопределено;
		КонецЕсли;
		
		Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
																			"УправлениеКонтактнойИнформациейСлужебныйПовтИспСтоматология.ПреобразоватьФорматТелефонныхНомеров",
																			ПараметрыПроцедуры,
																			НСтр("ru='Преобразование формата телефонных номеров';en='Convert phone numbers'"));
		Возврат Результат;
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// В фоне отправляет электронный чек через настроенного поставщика услуги, при возникновении ошибки записываются данные ошибки.
// 
// Параметры:
//  ПараметрыСообщения - Структура.Структура. Со свойствами
//       Адресат - Строка, номер телефона или адреса электроннной почты.
//       ТипРассылки -Перечисления.ТипыРассылкиЭлектронного чека
//       ПараметрыСообщения - Структура. Структура сообщения зависит от типа рассылки
//  АдресРезультата - Хранилище сохраняющее результаты выполнения
// 
Процедура ПреобразоватьФорматТелефонныхНомеров(ПараметрыЗадания, АдресРезультата) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Индекс = 0;
	ПараметрыПреобразования = Новый Структура();
	СтруктураРезультата 	= Справочники.СтруктурныеЕдиницы.ВернутьРегиональныеНастройки();	
	Если ПараметрыЗадания.Свойство("СтруктурнаяЕдиница") Тогда 
		ПараметрыПреобразования.Вставить("СтруктурнаяЕдиница"	, ПараметрыЗадания.СтруктурнаяЕдиница);
	Иначе 
		ПараметрыПреобразования.Вставить("СтруктурнаяЕдиница"	, Справочники.СтруктурныеЕдиницы.ПустаяСсылка());
	КонецЕсли;
	Если ПараметрыЗадания.Свойство("СтранаУчета") И ЗначениеЗаполнено(ПараметрыЗадания.СтранаУчета) Тогда 
		ПараметрыПреобразования.Вставить("СтранаУчета"			, ПараметрыЗадания.СтранаУчета);
		ПараметрыПреобразования.Вставить("Код"					, ПараметрыЗадания.СтранаУчета.Код);
	Иначе 
		ПараметрыПреобразования.Вставить("СтранаУчета"			, СтруктураРезультата.СтранаУчета);
		ПараметрыПреобразования.Вставить("Код"					, СтруктураРезультата.Код);
	КонецЕсли;	
	Если ПараметрыЗадания.Свойство("ФорматТелефонныхНомеров") Тогда 
		ПараметрыПреобразования.Вставить("ФорматТелНомера"		, ПараметрыЗадания.ФорматТелефонныхНомеров);
	Иначе 
		ПараметрыПреобразования.Вставить("ФорматТелНомера"		, СтруктураРезультата.ФорматТелНомера);
	КонецЕсли;	
	
	КоличествоОбъектов = ПолучитьОбщееКоличествоОбъектов(ПараметрыПреобразования);
	
	ПреобразоватьТелефонныеНомераКонтрагентов(КоличествоОбъектов, Индекс, ПараметрыПреобразования);
	
	ПреобразоватьТелефонныеНомераСотрудников(КоличествоОбъектов, Индекс, ПараметрыПреобразования);
	
	ПреобразоватьТелефонныеНомераСтруктурныхЕдиниц(КоличествоОбъектов, Индекс, ПараметрыПреобразования);
	
	ПреобразоватьТелефонныеНомераОрганизаций(КоличествоОбъектов, Индекс, ПараметрыПреобразования);
		
КонецПроцедуры

// Функция - Получить общее количество объектов
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОбщееКоличествоОбъектов(ПараметрыПреобразования)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ  	
	|	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ТаблицаСотрудниковРаботающихВДругихСЕ
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	|ГДЕ
	|	СотрудникиМестаРаботы.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница
	|;  		
	|////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ТаблицаСотрудниковРаботающихВПереданнойСЕ
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	|ГДЕ
	|	СотрудникиМестаРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И НЕ СотрудникиМестаРаботы.Сотрудник В
	|				(ВЫБРАТЬ
	|					ТаблицаСотрудниковРаботающихВДругихСЕ.Сотрудник
	|				ИЗ
	|					ТаблицаСотрудниковРаботающихВДругихСЕ)
	|; 
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВложенныйЗапрос.КоличествоОбъектов) КАК КоличествоОбъектов
	|ИЗ
	|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ КонтрагентыКонтактнаяИнформация.Ссылка) КАК КоличествоОбъектов
	|	ИЗ
