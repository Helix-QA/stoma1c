// Функция, создает канал мессенджера.
//
Функция СоздатьКлиентаМессенджера(ВнешняяСистема, Контрагент, Знач НомерТелефона)
	
	НомерТелефона = УправлениеКонтактнойИнформацией.ВернутьТелефонТолькоЦифрами(НомерТелефона);
	ИдКлиента = НомерТелефона + "@c.us";
	
	РегистрыСведений.КонтактыМессенджеров.ЗаписатьИдентификаторМессенджера(
		ИдКлиента,
		Контрагент,
		НомерТелефона,,
		ВнешняяСистема,
		Контрагент.Наименование
	);
	
	РегистрыСведений.ЖурналСообщений.ДобавитьЗапистьЖурналСообщений(
		ИдКлиента,
		Строка(Новый УникальныйИдентификатор()),,,
		"Создан клиент",
		Истина,
		Перечисления.Мессенджеры.whatsapp,
		Ложь,
		Дата(1, 1, 1),
		ВнешняяСистема,,,,,,,,,,
		Истина
	);
	
	Возврат ИдКлиента;
	
КонецФункции

