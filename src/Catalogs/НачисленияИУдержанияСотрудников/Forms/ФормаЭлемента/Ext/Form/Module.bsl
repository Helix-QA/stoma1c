// Функция - возвращает массив структурных единиц в которых работает сотрудник
//
Функция ВернутьСписокСтруктурныхЕдиницСотрудника(Сотрудник)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	НастройкиСотрудников.СтруктурнаяЕдиница
		|ИЗ
		|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
		|ГДЕ
		|	НастройкиСотрудников.Сотрудник = &Сотрудник";

	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	МассивСтруктурныхЕдиниц = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");

	Возврат МассивСтруктурныхЕдиниц;
	
КонецФункции

