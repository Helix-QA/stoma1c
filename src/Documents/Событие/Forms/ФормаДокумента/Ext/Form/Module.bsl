&НаКлиенте
// Процедура, обработчик события "СохранитьНовуюДлительностьПриема" 
//
Процедура СохранитьНовуюДлительностьПриема(Команда) Экспорт
	
	НоваяДлительность = НовыйЭлементДлительностиПриема;
 	
	МаксимальнаяДлительностьТекПриема = ПолучитьМаксимальнуюДлительностьТекущегоПриема(Объект.Услуги[0].ДатаНачала,
																						Объект.СтруктурнаяЕдиница,
																						Объект.Услуги[0].Сотрудник,
																						ЭтотОбъект.ЭтоРабочееВремяСотрудника);
	
	Если НоваяДлительность > МаксимальнаяДлительностьТекПриема Тогда
		
		ЭтотОбъект.НовыйЭлементДлительностиПриема = МаксимальнаяДлительностьТекПриема;
		НоваяДлительность = МаксимальнаяДлительностьТекПриема;
		
	КонецЕсли;

	ДлительностьПоменялась = Истина;
	
	// Нажата раннее созданная кнопка
	Если СписокИнтерваловДлительностиПриема[0].Значение <> "N" Тогда
		
		ДлительностьНаТекущейКнопке = СписокИнтерваловДлительностиПриема[0].Значение;
		
		// Кастомная кнопка изменена пользователем
		Если ДлительностьНаТекущейКнопке <> НоваяДлительность Тогда
			
			Если Элементы.Найти("ГруппаВыводаКнопокДлительности_"+НоваяДлительность) = Неопределено Тогда // И НоваяДлительность <> 0
				// СохранитьИлиУдалитьДлительностиПриемаНаСервере(НоваяДлительность); // НовыйЭлементДлительностиПриема
				ФлагВремяНоль = Истина;
			ИначеЕсли Элементы.Найти("ГруппаВыводаКнопокДлительности_"+НоваяДлительность) <> Неопределено Тогда
				КнопкаКнопкаДлительности_N = Элементы.Найти("КнопкаДлительности_N");
				Если НЕ КнопкаКнопкаДлительности_N = Неопределено Тогда
					КнопкаКнопкаДлительности_N.Видимость = Истина;	
				КонецЕсли;
				ФлагВремяНоль = Ложь;
			КонецЕсли;
			
			ИзменитьЭлементДлительностиПриема(НоваяДлительность, Неопределено, Ложь, ДлительностьНаТекущейКнопке);
			
			КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
			Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
				КнопкаУдалитьЭлементДлительностиПриема.Видимость = ФлагВремяНоль;	
			КонецЕсли;
			ДлительностьНаТекущейКнопке = НоваяДлительность;
			
		ИначеЕсли ДлительностьНаТекущейКнопке = НоваяДлительность Тогда
			
			КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
			Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
				КнопкаУдалитьЭлементДлительностиПриема.Видимость = Истина;	
			КонецЕсли;
			ДлительностьПоменялась = Ложь;
			
		КонецЕсли;
		
		// ТекущаяНажатаяКнопка = Элементы.Найти(?(НоваяДлительность <> 0, "КнопкаДлительности_"+ДлительностьНаТекущейКнопке, "КнопкаДлительности_N"));
		ТекущаяНажатаяКнопка = Элементы.Найти("КнопкаДлительности_"+ДлительностьНаТекущейКнопке);
		Если НЕ ТекущаяНажатаяКнопка = Неопределено Тогда
			ТекущаяНажатаяКнопка.Видимость = Истина;
		КонецЕсли;
		СписокИнтерваловДлительностиПриема[0].Значение = ДлительностьНаТекущейКнопке;			
		
	Иначе
		
		// Пользователь нажал на кнопку N'
		
		ЭтоСтандартнаяКнопка = Элементы.Найти("ГруппаВыводаКнопокДлительности_"+НоваяДлительность);
		Если ЭтоСтандартнаяКнопка = Неопределено Тогда // и НоваяДлительность <> 0
			// СохранитьИлиУдалитьДлительностиПриемаНаСервере(НоваяДлительность);
			КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
			Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
				КнопкаУдалитьЭлементДлительностиПриема.Видимость = Истина;	
			КонецЕсли;
			СписокИнтерваловДлительностиПриема[0].Значение = НоваяДлительность;				
		ИначеЕсли ЭтоСтандартнаяКнопка <> Неопределено Тогда			
			
			КнопкаКнопкаДлительности_N = Элементы.Найти("КнопкаДлительности_N");
			Если НЕ КнопкаКнопкаДлительности_N = Неопределено Тогда
				КнопкаКнопкаДлительности_N.Видимость = Истина;	
			КонецЕсли;				
			СписокИнтерваловДлительностиПриема[0].Значение = "N";
			
		КонецЕсли;
		
		ИзменитьЭлементДлительностиПриема(НоваяДлительность, Неопределено);	
		
	КонецЕсли;
	
	Если ДлительностьПоменялась Тогда
		ПересчетВремениОказанияУслуг(НоваяДлительность);
	КонецЕсли;
	
	КнопкаСохранитьЭлементДлительностиПриема = Элементы.Найти("СохранитьЭлементДлительностиПриема");
	Если НЕ КнопкаСохранитьЭлементДлительностиПриема = Неопределено Тогда
		КнопкаСохранитьЭлементДлительностиПриема.Видимость = Ложь;	
	КонецЕсли;
	ПолеВводаНовыйЭлементДлительностиПриема = Элементы.Найти("НовыйЭлементДлительностиПриема");
	Если НЕ ПолеВводаНовыйЭлементДлительностиПриема = Неопределено Тогда
		ПолеВводаНовыйЭлементДлительностиПриема.Видимость = Ложь;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
// Процедура - Удалить эту длительность приема, используется для удаления самостоятельно созданного времени приема
//
Процедура УдалитьЭтуДлительностьПриема(Команда)
	
	УдаляемаяДлительность = Неопределено;
	
	Если ТипЗнч(Команда) = Тип("КомандаФормы") Тогда 
	
		Если Команда.Имя = "УстановитьВремяДлительности" Тогда
		// Нажали на кнопку, созданную динамически.
		
			ДлительностьНаНажатойКнопке = Число(СтрРазделить(ТекущийЭлемент.Имя, "_", Ложь)[1]);
			
			Если СписокИнтерваловДлительностиПриема[0].Значение <> Неопределено И СписокИнтерваловДлительностиПриема[0].Значение <> "N" Тогда
				
				УдаляемаяДлительность = СписокИнтерваловДлительностиПриема[0].Значение;
				СписокИнтерваловДлительностиПриема[0].Значение = "N";
				
			КонецЕсли;
			
			НоваяДлительность = ДлительностьНаНажатойКнопке;
			

		ИначеЕсли Команда.Имя = "ДлительностьПриемаУдалить" Тогда  // УдалитьЭтуДлительностьПриема
		// Нажали на крестик.
		
			УдаляемаяДлительность = СписокИнтерваловДлительностиПриема[0].Значение;		
		    СписокИнтерваловДлительностиПриема[0].Значение = "N";
			НоваяДлительность = 0;
			
			КнопкаКнопкаДлительности_N = Элементы.Найти("КнопкаДлительности_N");
			Если НЕ КнопкаКнопкаДлительности_N = Неопределено Тогда
				КнопкаКнопкаДлительности_N.Видимость = Ложь;	
			КонецЕсли;
			КнопкаУдалитьЭлементДлительностиПриема = Элементы.Найти("УдалитьЭлементДлительностиПриема");
			Если НЕ КнопкаУдалитьЭлементДлительностиПриема = Неопределено Тогда
				КнопкаУдалитьЭлементДлительностиПриема.Видимость = Истина;	
			КонецЕсли;
	
		КонецЕсли;
		
		ПересчетВремениОказанияУслуг(НоваяДлительность);
		
		Если НЕ (НоваяДлительность = 0 И (УдаляемаяДлительность = 0 ИЛИ УдаляемаяДлительность = "N")) Тогда
			ИзменитьЭлементДлительностиПриема(НоваяДлительность, Неопределено, Ложь, УдаляемаяДлительность);		
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Команда) = Тип("Строка") Тогда
		// Удалили строку ТЧ.
		Если Команда = "УдалитьСтрокуТЧ" Тогда
			
			УдаляемаяДлительность = Неопределено;
			Если СписокИнтерваловДлительностиПриема[0].Значение <> "N" Тогда
				УдаляемаяДлительность = СписокИнтерваловДлительностиПриема[0].Значение;
			КонецЕсли;
			
			НоваяНормаВремени = ПосчитатьНормуВремениТЧУслуги();
			ПересчетВремениОказанияУслуг(НоваяНормаВремени);
			
			ИзменитьЭлементДлительностиПриема(НоваяНормаВремени, Неопределено, Ложь, УдаляемаяДлительность);
			
		    СписокИнтерваловДлительностиПриема[0].Значение = ?(СписокИнтерваловДлительностиПриема.НайтиПоЗначению(НоваяНормаВремени) = Неопределено, НоваяНормаВремени, "N");
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция - Посчитать норму времени В ТЧ "Услуги"
// 
Функция ПосчитатьНормуВремениТЧУслуги()
	
	ТекущаяНормаВремени = 0;
	Для СтрокаУслуги = 1 по Объект.Услуги.Количество() Цикл
		ТекущаяНормаВремени = ТекущаяНормаВремени + Объект.Услуги[СтрокаУслуги-1].НормаВремени;	
	КонецЦикла;
	
	Возврат ТекущаяНормаВремени;
	
КонецФункции

&НаКлиенте
// Процедура - "ПересчетВремениОказанияУслуг", используется для пересчета времени приема в Табл. части Услуги 
//
Процедура ПересчетВремениОказанияУслуг(НоваяДлительность)
	
	Если Объект.Услуги.Количество() <= 1 Тогда
		Объект.Услуги[0].НормаВремени = НоваяДлительность;
		Объект.Услуги[0].ДатаОкончания = Объект.Услуги[0].ДатаНачала + (НоваяДлительность * 60);
			
	Иначе
		КоличествоСтрок = Объект.Услуги.Количество() - 1;
		
		СреднееВремяДлительностиОднойУслуги = Цел(НоваяДлительность / КоличествоСтрок);
		Если (НоваяДлительность % КоличествоСтрок) <> 0 Тогда
			ПоследняяДлительность = СреднееВремяДлительностиОднойУслуги + (НоваяДлительность % КоличествоСтрок);
			ЕстьОстаток = Истина;
		КонецЕсли;
		
		Для ТекущаяСтрока = 1 По Объект.Услуги.Количество() Цикл
			Если ЗначениеЗаполнено(Объект.Услуги[ТекущаяСтрока-1].Номенклатура) Тогда	
				Объект.Услуги[ТекущаяСтрока-1].НормаВремени = ?(ТекущаяСтрока = КоличествоСтрок И ЕстьОстаток = Истина, ПоследняяДлительность, СреднееВремяДлительностиОднойУслуги);
				Объект.Услуги[ТекущаяСтрока-1].ДатаНачала = ?(ТекущаяСтрока = 1, Объект.Услуги[0].ДатаНачала, Объект.Услуги[ТекущаяСтрока-2].ДатаОкончания);
				Объект.Услуги[ТекущаяСтрока-1].ДатаОкончания = ?(ТекущаяСтрока = 1, Объект.Услуги[0].ДатаНачала + (СреднееВремяДлительностиОднойУслуги * 60), Объект.Услуги[ТекущаяСтрока-1].ДатаНачала + ?(ТекущаяСтрока = КоличествоСтрок И ЕстьОстаток = Истина, (ПоследняяДлительность * 60), (СреднееВремяДлительностиОднойУслуги * 60)));
			ИначеЕсли НЕ ЗначениеЗаполнено(Объект.Услуги[ТекущаяСтрока-1].Номенклатура) Тогда
				Объект.Услуги[Объект.Услуги.Количество()-1].ДатаНачала = Объект.Услуги[Объект.Услуги.Количество()-2].ДатаОкончания;
				// Объект.Услуги[Объект.Услуги.Количество()-1].ДатаОкончания = Объект.Услуги[Объект.Услуги.Количество()-1].ДатаОкончания + (СреднееВремяДлительностиОднойУслуги * 60);
				Объект.Услуги[Объект.Услуги.Количество()-1].ДатаОкончания = Объект.Услуги[Объект.Услуги.Количество()-1].ДатаНачала;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция - Получает максимально возможную длительность для текущего приема
// 
Функция ПолучитьМаксимальнуюДлительностьТекущегоПриема(ВремяНачала, СтруктурнаяЕдиница, Сотрудник, ЭтоРабочееВремяСотрудника)

	ТЗСобытий = Документы.Событие.ФактСобытийЗаУказаныйПериод(
		ВремяНачала,
		КонецДня(ВремяНачала),
		СтруктурнаяЕдиница,
		Сотрудник);	
				
	Если ТЗСобытий.Количество() = 1 Тогда
		Возврат ( (ТЗСобытий[0].ДатаНачала - ВремяНачала) / 60 );		
	КонецЕсли;		
		
	ГрафикРаботыСотрудникаПолучен = Ложь;	
	Если ЭтоРабочееВремяСотрудника = Неопределено Тогда	
															
		ГрафикРаботыСотрудника = РегистрыСведений.ВремяРаботыСотрудниковПлан.ПроверитьРаботаетЛиСотрудникВпериодВремя(
			ВремяНачала,,,
			Сотрудник,
			СтруктурнаяЕдиница,,
			Истина);
			
		ГрафикРаботыСотрудникаПолучен = Истина;
		
		Если ГрафикРаботыСотрудника.Количество() = 1 Тогда	
			ЭтоРабочееВремяСотрудника = (ГрафикРаботыСотрудника[0].ДатаОкончания >= ВремяНачала);		
		Иначе
			ЭтоРабочееВремяСотрудника = Ложь;	
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоРабочееВремяСотрудника = Истина Тогда				
			
		Если НЕ ГрафикРаботыСотрудникаПолучен Тогда							
			ГрафикРаботыСотрудника = РегистрыСведений.ВремяРаботыСотрудниковПлан.ПроверитьРаботаетЛиСотрудникВпериодВремя(
				ВремяНачала,,,
				Сотрудник,
				СтруктурнаяЕдиница,,
				Истина); 	
		КонецЕсли;
			
		ПеременнаяКонецПериода = ГрафикРаботыСотрудника[0].ДатаОкончания;
					
	Иначе // Если сотрудник работает не по графику.
		
		ГрафикРаботыКлиники = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(ВремяНачала, СтруктурнаяЕдиница);
		ПеременнаяКонецПериода = НачалоДня(ВремяНачала) + (ГрафикРаботыКлиники.ОкончаниеРаботы - Дата(1,1,1));

	КонецЕсли;
				
	Возврат ( (ПеременнаяКонецПериода - ВремяНачала) / 60 );				
		 	
КонецФункции

#КонецОбласти

&НаКлиенте
// Процедура - "УслугиДатаНачалаПолемОбработкаВыбора", Используется для пересчета времени начала приема
//
Процедура УслугиДатаНачалаПолемОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
		
	Если Объект.Услуги.Количество() = 1 Тогда
		Объект.Услуги[0].ДатаНачала = ВыбранноеЗначение;
		Объект.Услуги[0].ДатаОкончания = Объект.Услуги[0].ДатаНачала + (Объект.Услуги[0].НормаВремени * 60);
			
	Иначе
		
		Для ТекущаяСтрока = 1 По Объект.Услуги.Количество() Цикл
			
			Если ЗначениеЗаполнено(Объект.Услуги[ТекущаяСтрока-1].Номенклатура) Тогда	
				Объект.Услуги[ТекущаяСтрока-1].ДатаНачала = ?(ТекущаяСтрока = 1, ВыбранноеЗначение, Объект.Услуги[ТекущаяСтрока-2].ДатаОкончания);
				Объект.Услуги[ТекущаяСтрока-1].ДатаОкончания = Объект.Услуги[ТекущаяСтрока-1].ДатаНачала + (Объект.Услуги[ТекущаяСтрока-1].НормаВремени * 60);
				
			ИначеЕсли НЕ ЗначениеЗаполнено(Объект.Услуги[ТекущаяСтрока-1].Номенклатура) Тогда
				Объект.Услуги[Объект.Услуги.Количество()-1].ДатаНачала = Объект.Услуги[Объект.Услуги.Количество()-2].ДатаОкончания;
				Объект.Услуги[Объект.Услуги.Количество()-1].ДатаОкончания = Объект.Услуги[Объект.Услуги.Количество()-1].ДатаНачала;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Объект.Дата = ВыбранноеЗначение;
	
	// Если поменяли время начала приема, надо изменить длительность, если есть другие записи	
	
	ТекущаяДлительностьПриема = ПосчитатьНормуВремениТЧУслуги();
	МаксимальнаяДлительностьТекПриема = ПолучитьМаксимальнуюДлительностьТекущегоПриема(ВыбранноеЗначение,
																						Объект.СтруктурнаяЕдиница,
																						Объект.Услуги[0].Сотрудник,
																						ЭтотОбъект.ЭтоРабочееВремяСотрудника);

 	Если ТекущаяДлительностьПриема > МаксимальнаяДлительностьТекПриема Тогда	
		ЭтотОбъект.НовыйЭлементДлительностиПриема = МаксимальнаяДлительностьТекПриема;	
		СохранитьНовуюДлительностьПриема(Неопределено);
	КонецЕсли;
		
КонецПроцедуры

