&НаСервере
// Процедура, добавляет заметку на сервере.
//
Процедура ДобавитьЗаметкуЗаявкиКлиента(ТекстЗаметки, ЗаявкаКлиента)
	
	СтруктураОтбора = Новый Структура();
	СтруктураОтбора.Вставить("Объект"			, ЗаявкаКлиента);
	СтруктураОтбора.Вставить("АктивностьЗаметки", Истина);
	СтруктураОтбора.Вставить("Автор"			, ЭтотОбъект.ТекущийПользователь);
	СтруктураОтбора.Вставить("Период"			, ТекущаяДатаСеанса());
	СтруктураОтбора.Вставить("Заметка"			, ТекстЗаметки);
	СтруктураОтбора.Вставить("Сделка"			, ЭтотОбъект.ВзаимодействиеСделка);
	СтруктураОтбора.Вставить("ИД"				, Новый УникальныйИдентификатор);
	
	ОбъектРегистрСведенийЗаметка = РегистрыСведений.Заметки.СоздатьНаборЗаписей();
	ОбъектРегистрСведенийЗаметка.ОбменДанными.Загрузка = Истина;
	ОбъектРегистрСведенийЗаметка.Отбор.ИД.Установить(СтруктураОтбора.ИД);
	
	ЗаполнитьЗначенияСвойств(ОбъектРегистрСведенийЗаметка.Добавить(), СтруктураОтбора);
	
	ОбъектРегистрСведенийЗаметка.Записать(Истина);
	
КонецПроцедуры

