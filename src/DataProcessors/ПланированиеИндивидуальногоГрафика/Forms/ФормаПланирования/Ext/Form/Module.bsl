// Процедура - Проверить вхождение интервалов в график работы СЕ
// 
// Параметры:
//  ВыбраннаяДата	 - 	 - 
// 
Процедура ПроверитьВхождениеИнтерваловВГрафикРаботыСЕ(Знач ВыбраннаяДата)
	
	ВремяРаботыСтруктурнойЕдиницы = ВернутьВремяРаботыСтруктурнойЕдиницы(ОтборСтруктурнаяЕдиница);
	
	Для Каждого ЭлементМ ИЗ ВремяРаботыСтруктурнойЕдиницы Цикл
		Если ДеньНедели(ЭлементМ.ДеньНедели) = ДеньНедели(ВыбраннаяДата) Тогда

			ДатаНачалаРаботыСЕ 		= ЭлементМ.ДатаНачала;
			ДатаОкончанияРаботыСЕ 	= ?(ЭлементМ.ДатаОкончания < ЭлементМ.ДатаНачала, ЭлементМ.ДатаОкончания + 86400, ЭлементМ.ДатаОкончания);
			
			Прервать;
		КонецЕсли;	
	КонецЦикла;			
	
	СписокИнтервалов = Новый СписокЗначений;
	Для Каждого ЭлементПериод Из ОтборИнтервалыРаботы Цикл 
		Если НЕ (ЭлементПериод.Значение.НачалоРаботы < ДатаНачалаРаботыСЕ ИЛИ ЭлементПериод.Значение.ОкончаниеРаботы > ДатаОкончанияРаботыСЕ) Тогда 
        	СписокИнтервалов.Добавить(ЭлементПериод.Значение, ЭлементПериод.Представление);
		КонецЕсли;	
	КонецЦикла;
	
	Если СписокИнтервалов.Количество() = ОтборИнтервалыРаботы.Количество() Тогда 
		ЗаполнитьЭлементПланирования(ВыбраннаяДата, СписокИнтервалов);
	Иначе                                                                         
		Если СписокИнтервалов.Количество() = 0 Тогда 
			СообщениеТекст = "Выбраные интервал(ы) работы не входит(ят) в интервал работы структурной организации в указаный день.";
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеТекст, ЭтаФорма.КлючУникальности, "ИнтервалыРаботыПредст");
		Иначе                                                            
			СообщениеТекст = "Часть выбранных интервалов работы, указанных в шапке, не входят в интервал работы структурной организации в указаный день.";
			СообщениеТекст = СообщениеТекст + Символы.ПС + Символы.ПС;
			СообщениеТекст = СообщениеТекст + "Добавить только подходящие интервалы работ?";
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("ВыбраннаяДата"	, ВыбраннаяДата);
			СтруктураПараметров.Вставить("СписокИнтервалов"	, СписокИнтервалов);
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтаФорма, СтруктураПараметров);
			ПоказатьВопрос(Оповещение, СообщениеТекст, РежимДиалогаВопрос.ОКОтмена);
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

