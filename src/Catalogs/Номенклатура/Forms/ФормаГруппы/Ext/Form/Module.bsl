
#Область ОбработчикиСобытийФормы

// Процедура, обработчик события "ПриСозданииНаСервере".
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если НЕ Объект.Родитель = Справочники.Номенклатура.ПустаяСсылка() И Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПустаяСсылка() Тогда
		
		Объект.ТипНоменклатуры = Объект.Родитель.ТипНоменклатуры;
		
	КонецЕсли;
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти