// Функция - Сформирвоать блок скидки
//
// Параметры:
//  ВыводитьБлок - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьБлокСкидки(ВыводитьБлок = Ложь)
	
	Скидки = "";
	СтрокаСкидки =
	"<tr>
	|	<td colspan='3' style='height: 8px;'>
	|	</td>
	|</tr>
	|<tr align='center' valign='middle'>
	|	<td class='right_col' align='center'>
	|		<p title='' class='author'>{ТипСкидки}</p>
	|	</td>
	|	<td class='right_col' align='center'>
	|		<a title='' class='author' href='{НавигационнаяСсылка}'>{Скидка}</a>
	|	</td>
	|	<td class='right_col' align='center'>
	|		<p title='' class='author'>{СуммаСкидки}</p>
	|	</td>
	|</tr>";
	
	Если ЗначениеЗаполнено(Контрагент) Тогда  
		
		ТаблицаСкидкиДоступныеДляКлиента = Справочники.СкидкиНаценки.ПолучитьСкидкиДоступныеДляКлиента(Контрагент);
		
		ВыводитьБлок = ЗначениеЗаполнено(ТаблицаСкидкиДоступныеДляКлиента);
		
		Для Каждого Скидка Из ТаблицаСкидкиДоступныеДляКлиента Цикл 
			
			СимвольныйКод = ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
			
			ТипСкидки             = Скидка.ТипСкидки;
			ПредставлениеСкидки   = Скидка.Представление;
			ЗначениеСкидкиНаценки = ?(Скидка.ЗначениеСкидкиНаценки <> 0,Формат(Скидка.ЗначениеСкидкиНаценки, "ЧЦ=15; ЧДЦ=2") + " " + ?(Скидка.СпособПредоставления = Перечисления.СпособПредоставленияСкидки.Сумма, СимвольныйКод, "%"),"");
			
			НоваяСтрокаСкидки = СтрЗаменить(СтрокаСкидки,      "{Скидка}",              ПредставлениеСкидки);
			НоваяСтрокаСкидки = СтрЗаменить(НоваяСтрокаСкидки, "{НавигационнаяСсылка}", ПолучитьНавигационнуюСсылку(Скидка.Скидка));
			НоваяСтрокаСкидки = СтрЗаменить(НоваяСтрокаСкидки, "{ТипСкидки}",           ТипСкидки);  
			НоваяСтрокаСкидки = СтрЗаменить(НоваяСтрокаСкидки, "{СуммаСкидки}",         ЗначениеСкидкиНаценки);
			
			Скидки = Скидки + НоваяСтрокаСкидки;			
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Скидки;
	
КонецФункции

