// Функция - Разрешено использование кассовой смены
//
// Параметры:
//  Касса	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДоступностьИспользованияКассовойСмены(Касса) Экспорт
	
	Возврат ЗначениеЗаполнено(Касса.ВнешнееОборудование) 
			И Касса.ИспользоватьБезПодключенияОборудования = Ложь;	
			
КонецФункции        

// Функция выполняет открытие кассовой смены.
//
Функция ОткрытьКассовуюСмену(Касса, ОписаниеОшибки = "") Экспорт
	
	Результат = Документы.КассоваяСмена.ОткрытьКассовуюСмену(Касса, ОписаниеОшибки);		
	
	Если Результат = Истина Тогда		
		ОткрытьСменыНаСовместныхКассах(Касса);
	КонецЕсли;
	
	Возврат Результат;   	
	
КонецФункции

// Процедура - Открыть смены на совместных кассах
//
// Параметры:
//  Кассса	 - 	 - 
//
Процедура ОткрытьСменыНаСовместныхКассах(Кассса)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Кассы.Ссылка КАК Касса
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.ВнешнееОборудование = &ВнешнееОборудование
	|	И Кассы.ПометкаУдаления = ЛОЖЬ
	|	И НЕ Кассы.Ссылка = &ИсключитьКассу
	|	И Кассы.ИспользоватьБезПодключенияОборудования = ЛОЖЬ");
	
	Запрос.УстановитьПараметр("ВнешнееОборудование", Кассса.ВнешнееОборудование);
	Запрос.УстановитьПараметр("ИсключитьКассу"     , Кассса);
	
	Кассы = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Касса");
	
	Для Каждого КассаС ИЗ Кассы Цикл
		
		ОписаниеОшибки = Неопределено;
		
		Результат = Документы.КассоваяСмена.ОткрытьКассовуюСмену(КассаС, ОписаниеОшибки);				
		
		Если Не Результат Тогда
			
			ТекстСообщения = СтрШаблон(НСтр("ru = 'При открытии смены на кассе %1 произошла ошибка. Смена не открыта.
                                             |Дополнительное описание: %2'; en = 'An error occurred while opening the shift at the %1 cashbox. Shift is not open.
                                             |Additional description: %2'"), КассаС, ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры
                                                
