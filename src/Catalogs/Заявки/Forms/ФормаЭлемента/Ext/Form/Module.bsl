#Область ИсторияВзаимодействия

&НаСервере
// Процедура - Обновить историю взаимодействия.
//
// Параметры:
//  РежимПодробно	 - 	 -
//  ВыводитьВсе		 - 	 -
//
Процедура ОбновитьИсториюВзаимодействияСКлиентом(Фильтры = Неопределено, РежимПодробно = Ложь, ВыводитьВсе = Ложь)
		
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Фильтры = Новый Структура();
	
	ОбщегоНазначенияКлиентСерверСтоматология.ЗаполнитьСтруктуруФильтрациИсторииВзаимодйствия(СписокФильтрацииИсторииВзаимодействия, Фильтры);
	
	ПараметрыДанных = Новый Структура;
	
	ПараметрыДанных.Вставить("Ссылка"						, Объект.Ссылка);
	ПараметрыДанных.Вставить("ОсновнойКлиент"       		, Объект.ОсновнойКлиент);
	ПараметрыДанных.Вставить("РежимПодробно"    			, Истина);
	ПараметрыДанных.Вставить("ВыводитьВсе"      			, ВыводитьВсеВзаимодействия);
	ПараметрыДанных.Вставить("Фильтры"          			, Фильтры);
	ПараметрыДанных.Вставить("ВнешняяСистема"   			, Объект.ВнешняяСистема);
	ПараметрыДанных.Вставить("ТекущаяСтруктурнаяЕдиница"	, ЭтотОбъект.ТекущаяСтруктурнаяЕдиница);
	ПараметрыДанных.Вставить("ДатаРожденияКлиента"			, Объект.ОсновнойКлиент.ДатаРожденияКлиента);
	ПараметрыДанных.Вставить("ДатаРегистрацииКлиента"		, Объект.ОсновнойКлиент.ДатаРегистрации);
	ПараметрыДанных.Вставить("ВходящийНомерТелефона"		, Объект.ВходящийНомерТелефона);

	ТаблицаИсторииВзаимодействий = Справочники.Заявки.ПолучитьИсториюВзаимодействияЗаявки(ПараметрыДанных, Истина, ПараметрыДанных.Фильтры);	
	ЭтотОбъект.ИсторияВзаимодействий.Загрузить(ТаблицаИсторииВзаимодействий);	
	ТекстHTML = УправлениеИнтерфейсамиСервер.СформироватьИсториюВзаимодействий(ЭтаФорма, ПараметрыДанных, Истина, ПараметрыДанных.ВыводитьВсе); 	
	ЭтотОбъект.ИсторияВзаимодействия = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(ТекстHTML);
	
КонецПроцедуры

&НаСервере
// Функция, формирует таблицу истории взаимодействия.
//
Функция СформироватьТаблицуИсторииВзаимодействия(РежимПодробно)
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ПОМЕСТИТЬ ВТТелефоны
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЗаявкиКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|	ИЗ
	|		Справочник.Заявки.КонтактнаяИнформация КАК ЗаявкиКонтактнаяИнформация
	|	ГДЕ
	|		ЗаявкиКонтактнаяИнформация.Ссылка = &Заявка
	|		И ЗаявкиКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КонтрагентыКонтактнаяИнформация.НомерТелефона
	|	ИЗ
	|		Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|	ГДЕ
	|		&ВыводИнформацииКлиента
	|		И КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|		И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)) КАК КонтактнаяИнформация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Заявки.Ссылка КАК Взаимодействие,
	|	Заявки.ДатаСоздания КАК Дата,
	|	""ДатаРегистрацииЗаявки"" КАК ТипСобытия,
	|	NULL КАК ТипВзаимодействия,
	|	NULL КАК Автор,
	|	NULL КАК АвторПредставление,
	|	NULL КАК Заметка,
	|	NULL КАК Длительность,
	|	NULL КАК Начало,
	|	NULL КАК Окончание,
	|	NULL КАК Статус,
	|	NULL КАК ВзаимодействиеИД,
	|	""Заметка"" КАК ТипЗадачи,
	|	NULL КАК URLЗаписи,
	|	NULL КАК ФайлЗаписи,
	|	NULL КАК ТекстСообщения,
	|	NULL КАК Сделка
	|ИЗ
	|	Справочник.Заявки КАК Заявки
	|ГДЕ
	|	Заявки.Ссылка = &Заявка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка,
	|	Контрагенты.ДатаРожденияКлиента,
	|	""ДеньРожденияКлиента"",
	|	ВЫБОР
	|		КОГДА Контрагенты.ДатаРожденияКлиента = &ТекущаяДата
	|			ТОГДА ""История""
	|		ИНАЧЕ ""Запланировано""
	|	КОНЕЦ,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	&ВыводИнформацииКлиента
	|	И Контрагенты.Ссылка = &Контрагент
	|	И &ДатаРожденияКлиента МЕЖДУ &ТекущаяДата И ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, 1)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Контрагенты.Ссылка,
	|	НАЧАЛОПЕРИОДА(Контрагенты.ДатаРегистрации, ДЕНЬ),
	|	""ДатаРегистрацииКлиента"",
	|	""История"",
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	&ВыводИнформацииКлиента
	|	И Контрагенты.Ссылка = &Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка,
	|	ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка.Дата,
	|	""Письмо"",
	|	""История"",
	|	ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка.Автор,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка.Автор),
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка.СтатусПисьма,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	Документ.ЭлектронноеПисьмоИсходящее.ПолучателиПисьма КАК ЭлектронноеПисьмоИсходящееПолучателиПисьма
	|ГДЕ
	|	НЕ ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка.ПометкаУдаления
	|	И ЭлектронноеПисьмоИсходящееПолучателиПисьма.Контакт В(&ОбъектыОтбора)
	|	И ЭлектронноеПисьмоИсходящееПолучателиПисьма.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	NULL,
	|	Заметки.Период,
	|	""Заметка"",
	|	""История"",
	|	Заметки.Автор,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Заметки.Автор),
	|	ВЫРАЗИТЬ(Заметки.Заметка КАК СТРОКА(1000)),
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	Заметки.ИД,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	РегистрСведений.Заметки КАК Заметки
	|ГДЕ
	|	Заметки.Объект В(&ОбъектыОтбора)
	|	И Заметки.АктивностьЗаметки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ИсторияЗвонков.IDЗвонка,
	|	ИсторияЗвонков.НачалоВызова,
	|	ВЫБОР
	|		КОГДА ИсторияЗвонков.ИсходящийЗвонок = ИСТИНА
	|			ТОГДА ""ИсходящийЗвонок""
	|		КОГДА ИсторияЗвонков.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗвонка.Пропущен)
	|			ТОГДА ""ПропущенныйЗвонок""
	|		ИНАЧЕ ""ВходящийЗвонок""
	|	КОНЕЦ,
	|	""История"",
	|	ИсторияЗвонков.Пользователь,
	|	ИсторияЗвонков.Пользователь.НаименованиеСокращенное,
	|	ВЫРАЗИТЬ(ИсторияЗвонков.Заметка КАК СТРОКА(200)),
	|	ВЫБОР
	|		КОГДА ИсторияЗвонков.НачалоРазговора <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ИсторияЗвонков.ОкончаниеЗвонка <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА РАЗНОСТЬДАТ(ИсторияЗвонков.НачалоРазговора, ИсторияЗвонков.ОкончаниеЗвонка, СЕКУНДА)
	|		КОГДА ИсторияЗвонков.НачалоВызова <> ДАТАВРЕМЯ(1, 1, 1)
	|				И ИсторияЗвонков.ОкончаниеЗвонка <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА РАЗНОСТЬДАТ(ИсторияЗвонков.НачалоВызова, ИсторияЗвонков.ОкончаниеЗвонка, СЕКУНДА)
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ИсторияЗвонков.НачалоРазговора <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ИсторияЗвонков.НачалоРазговора
	|		ИНАЧЕ ИсторияЗвонков.НачалоВызова
	|	КОНЕЦ,
	|	ИсторияЗвонков.ОкончаниеЗвонка,
	|	NULL,
	|	NULL,
	|	NULL,
	|	ИсторияЗвонков.URLЗаписи,
	|	ИсторияЗвонков.ФайлЗаписи,
	|	NULL,
	|	NULL
	|ИЗ
	|	РегистрСведений.ИсторияВызовов КАК ИсторияЗвонков
	|ГДЕ
	|	ИсторияЗвонков.НомерТелефона В
	|			(ВЫБРАТЬ
	|				ВТТелефоны.НомерТелефона
	|			ИЗ
	|				ВТТелефоны)
	|
