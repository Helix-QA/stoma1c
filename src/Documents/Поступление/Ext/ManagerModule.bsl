// Функция вернет документ поступления созданный на основании указанного док заказа
Функция ПолучитьДокПоступленияПоДокЗаказа(ЗаказПоставщику) Экспорт
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПоступлениеЗапасы.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Поступление.Запасы КАК ПоступлениеЗапасы
	|ГДЕ
	|	ПоступлениеЗапасы.ДокументОснования = &ДокументОснование
	|	И ПоступлениеЗапасы.Ссылка.ПометкаУдаления = ЛОЖЬ
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоступлениеЗапасы.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка УБЫВ";
	Запрос.УстановитьПараметр("ДокументОснование",ЗаказПоставщику);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат ?(Выборка.Следующий(),Выборка.Ссылка,Неопределено);
	
КонецФункции

// Заполнить объект поступления на основании заполнения
Процедура ЗаполнитьДокПоступлениеИзОснования(Докобъект, Основание) Экспорт	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Докобъект.Склад      	      = Основание.Склад;
		Докобъект.Контрагент 	      = Основание.Контрагент;
		Докобъект.СтруктурнаяЕдиница  = Основание.СтруктурнаяЕдиница;
		Докобъект.СуммаОплачено       = Основание.СуммаОплачено;
		Докобъект.ДокументОснование	  = Основание;

		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗаказПоставщику.Номенклатура,
		|	ЗаказПоставщику.Партия,
		|	ЗаказПоставщику.Количество,
		|	ЗаказПоставщику.Цена,
		|	ЗаказПоставщику.Сумма,
		|	ЗаказПоставщику.СтавкаНДС,
		|	ЗаказПоставщику.СуммаНДС,
		|	ЗаказПоставщику.Всего,
		|	ЗаказПоставщику.Упаковка,
		|	ЗаказПоставщику.КоличествоУпаковок,
		|	ЗаказПоставщику.Ссылка КАК ДокументОснования
		|ИЗ
		|	Документ.ЗаказПоставщику.Запасы КАК ЗаказПоставщику
		|ГДЕ
		|	ЗаказПоставщику.Ссылка = &ДокументОснование";
		Запрос.УстановитьПараметр("ДокументОснование", Основание);	
		Докобъект.Запасы.Загрузить(Запрос.Выполнить().Выгрузить());	
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.НарядЗаказ") Тогда				
		Докобъект.Склад      			= Основание.Склад;		
		Докобъект.СтруктурнаяЕдиница 	= Основание.СтруктурнаяЕдиница;
		Докобъект.ВидЦен       		    = Основание.ВидЦен;
		Докобъект.Контрагент   		    = Основание.Лаборатория;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	НарядЗаказЗапасы.Ссылка КАК ДокументОснования,
		|	НарядЗаказЗапасы.Количество,
		|	НарядЗаказЗапасы.КоличествоУпаковок,
		|	НарядЗаказЗапасы.Номенклатура,
		|	НарядЗаказЗапасы.Партия,
		|	НарядЗаказЗапасы.Сумма,
		|	НарядЗаказЗапасы.Упаковка,
		|	НарядЗаказЗапасы.Цена,
		|	НарядЗаказЗапасы.Всего,
		|	ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.БезНдс) КАК СтавкаНДС
		|ИЗ
		|	Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
		|ГДЕ
		|	НарядЗаказЗапасы.Ссылка = &ДокументОснование
		|	И (НарядЗаказЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
		|			ИЛИ НарядЗаказЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Материал))
		|	И НарядЗаказЗапасы.Лаборатория = &Лаборатория
		|	И ВЫБОР
		|			КОГДА &Фильтр
		|				ТОГДА НарядЗаказЗапасы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыНарядЗаказа.выполнено)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	НарядЗаказЗапасы.Ссылка КАК ДокументОснования,
		|	НарядЗаказЗапасы.Количество,
		|	НарядЗаказЗапасы.КоличествоУпаковок,
		|	НарядЗаказЗапасы.Номенклатура,
		|	НарядЗаказЗапасы.Партия,
		|	НарядЗаказЗапасы.Сумма,
		|	НарядЗаказЗапасы.Упаковка,
		|	НарядЗаказЗапасы.Цена,
		|	НарядЗаказЗапасы.Всего,
		|	ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.БезНдс) КАК СтавкаНДС,
		|	НарядЗаказЗапасы.Ссылка.Сотрудник,
		|	СотрудникиСпецилазацииСотрудника.Специализация,
		|	ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.Лаборатория) КАК СтатьяРасходов
		|ИЗ
		|	Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники.СпецилазацииСотрудника КАК СотрудникиСпецилазацииСотрудника
		|		ПО НарядЗаказЗапасы.Ссылка.Сотрудник = СотрудникиСпецилазацииСотрудника.Ссылка
		|			И (СотрудникиСпецилазацииСотрудника.Основная = ИСТИНА)
		|ГДЕ
		|	НарядЗаказЗапасы.Ссылка = &ДокументОснование
		|	И НарядЗаказЗапасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|	И НарядЗаказЗапасы.Лаборатория = &Лаборатория
		|	И ВЫБОР
		|			КОГДА &Фильтр
		|				ТОГДА НарядЗаказЗапасы.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыНарядЗаказа.выполнено)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";           
		
		Запрос.УстановитьПараметр("ДокументОснование", Основание);		
		Запрос.УстановитьПараметр("Лаборатория"      , Основание.Лаборатория);
		Запрос.УстановитьПараметр("Фильтр"           , Ложь);
		Результат = Запрос.ВыполнитьПакет();
		Докобъект.Запасы.Загрузить(Результат[0].Выгрузить());
		Докобъект.Расходы.Загрузить(Результат[1].Выгрузить());
	КонецЕсли;
КонецПроцедуры

