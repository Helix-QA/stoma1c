
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.ЗагрузитьКлассификатор.Видимость = Не ОбщегоНазначения.РазделениеВключено();
	Элементы.ЗагрузитьКлассификатор.ТолькоВоВсехДействиях = Истина;
	ПодборОтображитьДеревом                   = Истина;
	СоздатьДеревоУслуг();
	УстановитьУсловноеОформление();
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Процедура - Сохранить
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура Сохранить(Команда)
		
	Ссылки = Новый Массив;
	Для Каждого СтрокаТЧ Из ТаблицаКлассификаторУслуг Цикл
		Ссылки.Добавить(СтрокаТЧ.Услуга);		
	КонецЦикла;
	
	Если Ссылки.Количество() > 0 Тогда
		
		МассивУслуг = ОбработатьВыборНаСервере(Ссылки, Группа);
		Количество = МассивУслуг.Количество();
		Оповестить("ОбновитьПослеДобавления");
		Если Количество = 0 Тогда
			Описание = "Услуги не загружены. Необходимо выбрать загружаемые услуги.";
		Иначе
			Описание = "Загружено " + Количество + " услуг в справочник Номенклатура.";
		КонецЕсли;		
		ПоказатьОповещениеПользователя("Загрузка услуг",,Описание, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 		
	КонецЕсли;
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

// Процедура - Загрузить классификатор
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ЗагрузитьКлассификатор(Команда)
	
	РезультатЗагрузки = ДобавитьИзКлассификатораНаСервере();
	Описание = "В классификатор загружено " + РезультатЗагрузки.КолличествоЗагружено + " услуг." + 
		?(РезультатЗагрузки.КолличествоОбновлено <> 0, " Обновлено " + РезультатЗагрузки.КолличествоОбновлено + ".", "");
	
	ПоказатьОповещениеПользователя("Загрузка классификатора услуг",, Описание, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 
	ОбновитьДеревоУслуг();
	
КонецПроцедуры

// Процедура - Выбрать строки
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ВыбратьСтроки(Команда)
	
	ОтметитьУслуги(1);

КонецПроцедуры

// Процедура - Исключить строки
//
// Параметры:
//  Команда	 - 	 - 
//
&НаКлиенте
Процедура ИсключитьСтроки(Команда)
	
	 ОтметитьУслуги(0);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура, выполянет создание дерева услуг.
//
Процедура СоздатьДеревоУслуг()
	
	ИмяЭлементаДляРазмещения = "ГруппаДеревоКлассификаторУслуг";
	масРеквизитов = Новый Массив;		
	
	ИмяДерева = "_ПодборКлассификаторУслуг";
	
	МассивДопустимыхТипов = Новый Массив;
	МассивДопустимыхТипов.Добавить(Тип("СправочникСсылка.КлассификаторНоменклатурыМедицинскихУслуг"));
	МассивДопустимыхТипов.Добавить(Тип("Строка"));
	
	масРеквизитов.Добавить(Новый РеквизитФормы(ИмяДерева		       , Новый ОписаниеТипов("ДеревоЗначений"), , "Подбор номенклатур", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Услуга"	   			   , Новый ОписаниеТипов(МассивДопустимыхТипов), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ЭтоГруппа"		       , Новый ОписаниеТипов("Булево"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ИндКартинки"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("НормаВремени"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("КодУслуги"	           , Новый ОписаниеТипов("Строка"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("УЕТ"	               , Новый ОписаниеТипов("Строка"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Выбран"				   , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(1,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Наименование"	       , Новый ОписаниеТипов("Строка"), ИмяДерева));
	
	масРеквизитов.Добавить(Новый РеквизитФормы("_ПодборКлассификаторУслугИсточникГрупп", Новый ОписаниеТипов("ДеревоЗначений"), , "Услуги подбор список", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Услуга"				   , Новый ОписаниеТипов("СправочникСсылка.КлассификаторНоменклатурыМедицинскихУслуг"), "_ПодборКлассификаторУслугИсточникГрупп"));
	
	ИмяДерева = "_ПодборКлассификаторУслугИсточникЭлементов";
	масРеквизитов.Добавить(Новый РеквизитФормы(ИмяДерева		       , Новый ОписаниеТипов("ТаблицаЗначений"), , "Услуги подбор список", Ложь));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Услуга"	               , Новый ОписаниеТипов("СправочникСсылка.КлассификаторНоменклатурыМедицинскихУслуг"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ЭтоГруппа"		       , Новый ОписаниеТипов("Булево"), ИмяДерева));	
	масРеквизитов.Добавить(Новый РеквизитФормы("Родитель"		       , Новый ОписаниеТипов("СправочникСсылка.КлассификаторНоменклатурыМедицинскихУслуг"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("ИндКартинки"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Наименование"	       , Новый ОписаниеТипов("Строка"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("НормаВремени"	       , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(10,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("КодУслуги"	           , Новый ОписаниеТипов("Строка"), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("Выбран"				   , Новый ОписаниеТипов("Число",,Новый КвалификаторыЧисла(1,0)), ИмяДерева));
	масРеквизитов.Добавить(Новый РеквизитФормы("УЕТ"	               , Новый ОписаниеТипов("Строка"), ИмяДерева));
			
	ИзменитьРеквизиты(масРеквизитов);	
	
	ЭлементДерево = Элементы.Добавить("_ПодборКлассификаторУслуг", Тип("ТаблицаФормы"), Элементы[ИмяЭлементаДляРазмещения]);
	ЭлементДерево.ПутьКДанным 				 = "_ПодборКлассификаторУслуг";
	ЭлементДерево.Отображение 				 = ОтображениеТаблицы.Дерево;
	ЭлементДерево.КартинкаСтрок 			 = БиблиотекаКартинок.ТерминалПодбор; 
	ЭлементДерево.ПутьКДаннымКартинкиСтроки  = "_ПодборКлассификаторУслуг.ИндКартинки";
	ЭлементДерево.ПоложениеКоманднойПанели   = ПоложениеКоманднойПанелиЭлементаФормы.Нет;	
	ЭлементДерево.АвтоМаксимальнаяШирина 	 = Ложь;
	ЭлементДерево.РастягиватьПоГоризонтали	 = Истина;
	ЭлементДерево.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВерхнийУровень;
	ЭлементДерево.ПоложениеСтрокиПоиска      = ПоложениеСтрокиПоиска.Верх;
	ЭлементДерево.ПоложениеУправленияПоиском = ПоложениеУправленияПоиском.Нет;

	НовыйЭлемент = Элементы.Добавить("Выбран", Тип("ПолеФормы"), ЭлементДерево);
	НовыйЭлемент.Вид					 = ВидПоляФормы.ПолеФлажка;
	НовыйЭлемент.ПутьКДанным			 = "_ПодборКлассификаторУслуг.Выбран";
	НовыйЭлемент.ТриСостояния			 = Истина;
	НовыйЭлемент.ЦветФонаЗаголовка	 	 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
	НовыйЭлемент.ПоложениеЗаголовка      = ПоложениеЗаголовкаЭлементаФормы.Нет;
	НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ПодборКлассификаторУслугПриИзменении");

	НовыйЭлемент = Элементы.Добавить("КодУслуги", Тип("ПолеФормы"), ЭлементДерево);
	НовыйЭлемент.Вид		 				 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным				 = "_ПодборКлассификаторУслуг.КодУслуги";
	НовыйЭлемент.Ширина 					 = 8;
	НовыйЭлемент.АвтоМаксимальнаяШирина 	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 		 = 8;
	НовыйЭлемент.РастягиватьПоГоризонтали	 = Ложь;	
	НовыйЭлемент.Заголовок					 = "Код";
	НовыйЭлемент.ЦветФонаЗаголовка	 		 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ТолькоПросмотр              = Истина;

	НовыйЭлемент = ЭтаФорма.Элементы.Добавить("Услуга", Тип("ПолеФормы"), ЭлементДерево);	
	НовыйЭлемент.Вид 		 			 	 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.АвтоМаксимальнаяШирина 	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 		 = 60;
	НовыйЭлемент.ТолькоПросмотр 		 	 = Истина;
	НовыйЭлемент.ЦветФонаЗаголовка	 		 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ПутьКДанным				 = "_ПодборКлассификаторУслуг.Услуга";
		
	НовыйЭлемент = Элементы.Добавить("НормаВремени", Тип("ПолеФормы"), ЭлементДерево);
	НовыйЭлемент.Вид		 				 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным				 = "_ПодборКлассификаторУслуг.НормаВремени";
	НовыйЭлемент.Ширина 					 = 8;
	НовыйЭлемент.АвтоМаксимальнаяШирина 	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 		 = 8;
	НовыйЭлемент.РастягиватьПоГоризонтали	 = Ложь;	
	НовыйЭлемент.Заголовок					 = "Норма времени";
	НовыйЭлемент.ЦветФонаЗаголовка	 		 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ТолькоПросмотр              = Истина;
	
	НовыйЭлемент = Элементы.Добавить("УЕТ", Тип("ПолеФормы"), ЭлементДерево);
	НовыйЭлемент.Вид		 				 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным				 = "_ПодборКлассификаторУслуг.УЕТ";
	НовыйЭлемент.Ширина 					 = 8;
	НовыйЭлемент.АвтоМаксимальнаяШирина 	 = Ложь;
	НовыйЭлемент.МаксимальнаяШирина 		 = 8;
	НовыйЭлемент.РастягиватьПоГоризонтали	 = Ложь;	
	НовыйЭлемент.Заголовок					 = "УЕТ";
	НовыйЭлемент.ЦветФонаЗаголовка	 		 = Новый Цвет(255, 255, 255);
	НовыйЭлемент.ТолькоПросмотр              = Истина;

	ЗаполнитьДеревоПодбораКлассификатора();
	
	ЗаполнитьСписокПодбораРекурсивноСервер(
		ЭтаФорма._ПодборКлассификаторУслугИсточникГрупп.ПолучитьЭлементы(), 
		ЭтаФорма._ПодборКлассификаторУслугИсточникЭлементов, 
		ЭтаФорма._ПодборКлассификаторУслуг, ЭтаФорма);		
		
	ЗаполнитьСуществующиеУслуги();
	
КонецПроцедуры

&НаСервере
// Процедура, выполянет создание дерева услуг.
//
Процедура ОбновитьДеревоУслуг()
	
	ЗаполнитьДеревоПодбораКлассификатора();
	
	ЗаполнитьСписокПодбораРекурсивноСервер(
		ЭтаФорма._ПодборКлассификаторУслугИсточникГрупп.ПолучитьЭлементы(), 
		ЭтаФорма._ПодборКлассификаторУслугИсточникЭлементов, 
		ЭтаФорма._ПодборКлассификаторУслуг, ЭтаФорма);		
		
	ЗаполнитьСуществующиеУслуги();

КонецПроцедуры

&НаСервере
// Процедура, заполняет источник групп
//
Процедура ЗаполнитьИсточникГрупп(ВыборкаГрупп, УровеньЗаполнения)
	
	Для Каждого УровеньОбхода Из ВыборкаГрупп.Строки Цикл
		НоваяСтрока = УровеньЗаполнения.Добавить();
		ЗаполнитьИсточникГрупп(УровеньОбхода, НоваяСтрока.ПолучитьЭлементы());
		НоваяСтрока.Услуга = УровеньОбхода.Ссылка;                          
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
// Процедура, выполняет заполнение подбора классификатора 
//
Процедура ЗаполнитьДеревоПодбораКлассификатора()
	
	ЗапросГрупп = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СправочникКлассификаторУслуг.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КлассификаторНоменклатурыМедицинскихУслуг КАК СправочникКлассификаторУслуг
	|ГДЕ
	|	СправочникКлассификаторУслуг.ЭтоГруппа = ИСТИНА
	|	И СправочникКлассификаторУслуг.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка ИЕРАРХИЯ
	|АВТОУПОРЯДОЧИВАНИЕ");	
	
	ВыборкаГрупп = ЗапросГрупп.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	
	ЭтаФорма._ПодборКлассификаторУслугИсточникГрупп.ПолучитьЭлементы().Очистить();	
	
	ЗаполнитьИсточникГрупп(ВыборкаГрупп, ЭтаФорма._ПодборКлассификаторУслугИсточникГрупп.ПолучитьЭлементы());	
	ПустаяГруппа = ЭтаФорма._ПодборКлассификаторУслугИсточникГрупп.ПолучитьЭлементы().Добавить();
	
	ЗапросУслуг = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СпрКлассификаторУслуг.Ссылка КАК Услуга,
	|	СпрКлассификаторУслуг.ЭтоГруппа КАК ЭтоГруппа,
	|	ВЫБОР
	|		КОГДА СпрКлассификаторУслуг.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндКартинки,
	|	СпрКлассификаторУслуг.Родитель КАК Родитель,
	|	СпрКлассификаторУслуг.Наименование КАК Наименование,
	|	СпрКлассификаторУслуг.НормаВремени КАК НормаВремени,
	|	СпрКлассификаторУслуг.Код КАК КодУслуги,
	|	СпрКлассификаторУслуг.УЕТ КАК УЕТ
	|ИЗ
	|	Справочник.КлассификаторНоменклатурыМедицинскихУслуг КАК СпрКлассификаторУслуг
	|ГДЕ
	|	НЕ СпрКлассификаторУслуг.ПометкаУдаления
	|	И НЕ СпрКлассификаторУслуг.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	Код
	|ИТОГИ
	|	МАКСИМУМ(ЭтоГруппа),
	|	МАКСИМУМ(ИндКартинки),
	|	МАКСИМУМ(Родитель),
	|	МАКСИМУМ(Наименование)
	|ПО
	|	Услуга");
	
	ВыборкаУслуг = ЗапросУслуг.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ЭтаФорма._ПодборКлассификаторУслугИсточникЭлементов.Очистить();
	
	Пока ВыборкаУслуг.Следующий() Цикл
		
		СтрокаТЧ = ЭтаФорма._ПодборКлассификаторУслугИсточникЭлементов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, ВыборкаУслуг);
				
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура рекурсивного заолнения дерева подбора номенклатур
//
Процедура ЗаполнитьСписокПодбораРекурсивноСервер(ИсточникГрупп, ИсточникУслуг, ЭлементЗаполнения, Форма)
	
	Если ПодборОтображитьДеревом Тогда 
		
		Для Каждого УровеньЗаполнения Из ИсточникГрупп Цикл	
			
			Если ЗначениеЗаполнено(УровеньЗаполнения.Услуга) Тогда 
				НоваяСтрокаГруппы		 	= ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
				НоваяСтрокаГруппы.Услуга 	= УровеньЗаполнения.Услуга;		
				НоваяСтрокаГруппы.ЭтоГруппа = Истина;				
			Иначе 
				НоваяСтрокаГруппы = Форма._ПодборКлассификаторУслуг; 				
			КонецЕсли;
			
			ЗаполнитьСписокПодбораРекурсивноСервер(УровеньЗаполнения.ПолучитьЭлементы(), ИсточникУслуг, НоваяСтрокаГруппы, Форма);						
			УслугиПоРодителю = Форма._ПодборКлассификаторУслугИсточникЭлементов.НайтиСтроки(Новый Структура("Родитель", УровеньЗаполнения.Услуга));	
			
			// Заполняем услуги
			Для Каждого СтрокаН Из УслугиПоРодителю Цикл
					
				НоваяСтрока = НоваяСтрокаГруппы.ПолучитьЭлементы().Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаН);
				
			КонецЦикла;	
			
			// Удаляем узел группы если он не содержит элементы
			Если НоваяСтрокаГруппы.ПолучитьЭлементы().Количество() = 0 
				И Не ТипЗнч(НоваяСтрокаГруппы) = Тип("ДанныеФормыДерево") Тогда
				ЭлементЗаполнения.ПолучитьЭлементы().Удалить(НоваяСтрокаГруппы);
			КонецЕсли;	
			
		КонецЦикла;	
	Иначе
		
		ЭлементыЗаполнения = ЭлементЗаполнения.ПолучитьЭлементы();
		
		Для Каждого УровеньЗаполнения Из ИсточникУслуг Цикл
			
			НоваяСтрока = ЭлементыЗаполнения.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, УровеньЗаполнения);
			
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

