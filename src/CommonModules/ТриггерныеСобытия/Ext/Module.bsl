// Процедура - Сгруппировать данные по посещениям
//
// Параметры:
//  ТаблицаДанныхОбъекта - 	 - 
//
Процедура СгруппироватьДанныеПоПосещениям(ТаблицаДанныхОбъекта)
	
	ТаблицаГруппировки = ТаблицаДанныхОбъекта.Скопировать(, "ДатаПрихода, Контрагент, ОбъектСобытия, Основание, СтруктурнаяЕдиница, РегистрацияПоПодписке, РегистрацияЗапланированных");
	ТаблицаГруппировки.Свернуть("ДатаПрихода, Контрагент, ОбъектСобытия, Основание, СтруктурнаяЕдиница, РегистрацияПоПодписке, РегистрацияЗапланированных");
	Если ТаблицаГруппировки.Количество() <> ТаблицаДанныхОбъекта.Количество() Тогда 
		ТаблицаСгруппированныхДанных = ТаблицаДанныхОбъекта.СкопироватьКолонки();
		Для Каждого СтрокаТЗ Из ТаблицаГруппировки Цикл 
			МассивСтрок = ТаблицаДанныхОбъекта.НайтиСтроки(Новый Структура("ДатаПрихода, Контрагент, Основание, СтруктурнаяЕдиница, РегистрацияПоПодписке, РегистрацияЗапланированных", СтрокаТЗ.ДатаПрихода, СтрокаТЗ.Контрагент, СтрокаТЗ.Основание, СтрокаТЗ.СтруктурнаяЕдиница, СтрокаТЗ.РегистрацияПоПодписке, СтрокаТЗ.РегистрацияЗапланированных));
			Если МассивСтрок.Количество() <> 0 Тогда 
				ЗаполнитьЗначенияСвойств(ТаблицаСгруппированныхДанных.Добавить(), МассивСтрок[0]);
			КонецЕсли;	
		КонецЦикла;
		ТаблицаДанныхОбъекта 			= ТаблицаСгруппированныхДанных;
		ТаблицаСгруппированныхДанных 	= Неопределено;
	КонецЕсли;
	ТаблицаГруппировки 				= Неопределено;		
	
КонецПроцедуры

// Процедура - Зарегистрировать событие в журнале
//
// Параметры:
//  ДанныеТриггера							 - 	 - 
//  СтрокаТаблицыДанных						 - 	 - 
//  СтрокаПлан								 - 	 - 
//  СтрокаРеестра							 - 	 - 
//  СтруктураКонтактнойИнформации	 - 	 - 
//  ТаблицаВремениРаботыСтруктурнойЕдиницы	 - 	 - 
//
Процедура ЗарегистрироватьСобытиеВЖурнале(ДанныеТриггера,
											СтрокаТаблицыДанных,
											СтрокаПланДействий,
											СтрокаРеестра = Неопределено,
											СтруктураКонтактнойИнформации,
											ТаблицаВремениРаботыСтруктурнойЕдиницы,
											ТаблицаИнформацииПоСделкам = Неопределено,
											ПараметрыРегистрации)

	
	Период = ТекущаяДатаСеанса();
	МассивНомеров 				= Новый Массив;
	МассивEmail 				= Новый Массив;
		
	// Отправляем сообщение
	Если СтрокаПланДействий.ВидДействия = Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение Тогда
		Попытка
			РассылкаЗапрещена 			= Ложь;
			РассылкаЗапрещенаДляУслуги 	= Ложь;
			ТаблицаКонтактов = ВернутьТаблицуКонтактов(СтрокаТаблицыДанных, СтрокаПланДействий, СтруктураКонтактнойИнформации, РассылкаЗапрещена, РассылкаЗапрещенаДляУслуги);
			Если НЕ ТаблицаКонтактов.Количество() = 0 Тогда
				Если СтрокаПланДействий.ТаблицаЗначенийПараметров <> Неопределено И НЕ СтрокаПланДействий.ТаблицаЗначенийПараметров.Колонки.Найти("СсылкаНаОценкуИОтзыв") = Неопределено Тогда 
					// Это конктретный триггер "ЗанятиеПроведеноКлиентПрибыл" и в шаблоне есть параметр "СсылкаНаОценкуИОтзыв"
					// Попробуем получить ссылку
					КороткаяСсылкаНаОценкуЗанятия = Неопределено; // РегламентныеЗаданияСерверСтоматология.ПолучитьКороткуюСсылку(СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.ОбъектСобытия, СтрокаТаблицыДанных.Контрагент, "rating");
					Если НЕ ЗначениеЗаполнено(КороткаяСсылкаНаОценкуЗанятия) Тогда
						// Пишем в журнал регистрации триггерных событий
						СообщениеОбОшибке = НСтр("ru='Не удалось сгенерировать ссылку для оценки и отзыва по занятию для клиента.';en='Failed to generate lesson rating and feedback link for customer.'");			
						СтруктураСобытия = Новый Структура;
						СтруктураСобытия.Вставить("СтрокаТаблицыДанных"	, СтрокаТаблицыДанных);
						СтруктураСобытия.Вставить("СтрокаПланДействий"	, СтрокаПланДействий);
						СтруктураСобытия.Вставить("СтрокаРеестра"		, СтрокаРеестра);			
						ЗарегистрироватьОшибкиРегистрацииСобытия(ДанныеТриггера, , СтруктураСобытия, ПараметрыРегистрации.РегистрацияПоПодписке, ПараметрыРегистрации.РегистрацияЗапланированных, СообщениеОбОшибке, Перечисления.СтатусыРегистрацииСобытий.Отклонено);			
					Иначе
						Попытка
							ИнициализацияВнешнейСистемыОценокИОтзывов(Истина);
						Исключение
							ВызватьИсключение;
						КонецПопытки;
						
						МассивСтрокЗначений = СтрокаПланДействий.ТаблицаЗначенийПараметров.НайтиСтроки(Новый Структура("Контрагент, ОбъектСобытия", СтрокаТаблицыДанных.Контрагент, СтрокаТаблицыДанных.ОбъектСобытия));
						Для Каждого СтрокЗначений Из МассивСтрокЗначений Цикл 
							СтрокЗначений.СсылкаНаОценкуИОтзыв = КороткаяСсылкаНаОценкуЗанятия;
						КонецЦикла;	
						ПараметрыSMSОбъекта = ИнициализироватьПараметрыSMSОбъекта(ДанныеТриггера, СтрокаТаблицыДанных, СтрокаПланДействий, СтрокаРеестра, ТаблицаКонтактов, Период);
						ВыполнитьОтправкуСообщений(ПараметрыSMSОбъекта);
					КонецЕсли;
				ИначеЕсли СтрокаПланДействий.ТаблицаЗначенийПараметров <> Неопределено И НЕ СтрокаПланДействий.ТаблицаЗначенийПараметров.Колонки.Найти("СсылкаНаИнформациюОЗаписиНаЗанятие") = Неопределено Тогда
					КороткаяСсылкаНаИнформациюОЗаписи = Неопределено; // РегламентныеЗаданияСерверСтоматология.ПолучитьКороткуюСсылку(СтрокаТаблицыДанных.СтруктурнаяЕдиница, СтрокаТаблицыДанных.ОбъектСобытия, СтрокаТаблицыДанных.Контрагент, "record");
					Если НЕ ЗначениеЗаполнено(КороткаяСсылкаНаИнформациюОЗаписи) Тогда
						// Пишем в журнал регистрации триггерных событий
						СообщениеОбОшибке = НСтр("ru='Не удалось сгенерировать ссылку на информацию о записи на занятие.';en='Failed to generate class enrollment information link.'");			
						СтруктураСобытия = Новый Структура;
						СтруктураСобытия.Вставить("СтрокаТаблицыДанных"	, СтрокаТаблицыДанных);
						СтруктураСобытия.Вставить("СтрокаПланДействий"	, СтрокаПланДействий);
						СтруктураСобытия.Вставить("СтрокаРеестра"		, СтрокаРеестра);			
						ЗарегистрироватьОшибкиРегистрацииСобытия(ДанныеТриггера, , СтруктураСобытия, ПараметрыРегистрации.РегистрацияПоПодписке, ПараметрыРегистрации.РегистрацияЗапланированных, СообщениеОбОшибке, Перечисления.СтатусыРегистрацииСобытий.Отклонено);			
					Иначе
						Попытка
