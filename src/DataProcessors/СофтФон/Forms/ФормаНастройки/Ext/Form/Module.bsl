&НаКлиенте
// Процедура, обработчик события "ПриИзменении"
//
Процедура ТаблицаКодековФлагПриИзменении(Элемент)
	
	Если СофтФон = Неопределено Тогда
		Возврат;
	КонецЕсли;
	СтрокаТЧ = Элементы.ТаблицаКодеков.ТекущиеДанные;
	
	Если Не СтрокаТЧ = Неопределено Тогда		
		СофтФон.EnableCodec(СтрокаТЧ.Индекс, СтрокаТЧ.Флаг);
		// ЗагрузитьКодеки();               
	КонецЕсли;
	
		
КонецПроцедуры

