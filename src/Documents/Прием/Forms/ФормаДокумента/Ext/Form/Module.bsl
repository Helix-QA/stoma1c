// Процедура, обработчик команды "Подключаемый_УдалитьОплатуБонусом".
//
Процедура Подключаемый_УдалитьОплатуБонусом(Команда)
	
	Индекс		= ПолучитьИндексИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);
	СтрокаТЧ	= ЭтотОбъект.Информация_По_Оплате[Индекс];
	
	МассивУдаляемыхСтрок = Объект.СкидкиНаценки.НайтиСтроки(Новый Структура("БонусныйСчет, ПризнакОплатыБонусом", СтрокаТЧ.БонусныйСчет, Истина));
	Для Каждого ЭлементМ Из МассивУдаляемыхСтрок Цикл
		Объект.СкидкиНаценки.Удалить(ЭлементМ);
