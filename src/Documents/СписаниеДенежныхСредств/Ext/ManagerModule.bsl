// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ПараметрыВывода.ДоступнаПечатьПоКомплектно = Истина;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "РКО") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "РКО", "Расходный кассовый ордер", СформироватьПечатнуюФормуКО2(МассивОбъектов, ОбъектыПечати));
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "КМ3") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
		КоллекцияПечатныхФорм,
		"КМ3",
		"Расходный кассовый ордер",
		СформироватьПечатнуюФормуКМ3(МассивОбъектов, ОбъектыПечати)
		);
		
	КонецЕсли;
	
КонецПроцедуры // Печать()

// Функция получения списка печатных форм.
//
Функция ПолучитьСписокПечатныхФорм() Экспорт
	
	Список = Новый СписокЗначений;
	Список.Добавить("РКО", "КО-2 (Расходный кассовый ордер)", , БиблиотекаКартинок.Документ);
	Список.Добавить("КМ3", "Акт о возврате денежных сумм", , БиблиотекаКартинок.Документ);
	
	Возврат Список;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ФОРМИРОВАНИЯ ПЕЧАТНЫХ ФОРМ

// Функция формирует печатную форму КО2.
// 
Функция СформироватьПечатнуюФормуКО2(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_РасходИзКассы";
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос();
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СписаниеДенежныхСредств.Номер КАК Номер,
		|	СписаниеДенежныхСредств.Дата КАК ДатаДокумента,
		|	СписаниеДенежныхСредств.СуммаДокумента КАК СуммаДокумента,
		|	СписаниеДенежныхСредств.СтруктурнаяЕдиница.Организация КАК Организация,
		|	СписаниеДенежныхСредств.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
		|	СписаниеДенежныхСредств.СтруктурнаяЕдиница.Организация.КодПоОКПО КАК ОрганизацияПоОКПО,
		|	СписаниеДенежныхСредств.СтруктурнаяЕдиница.Организация.ПолноеНаименование КАК ПредставлениеОрганизации,
		|	ВалютаУчета.Значение КАК ВалютаДенежныхСредств,
		|	СписаниеДенежныхСредств.ВидОперации КАК Основание,
		|	ВЫБОР
		|		КОГДА СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
		|				ИЛИ СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета)
		|				ИЛИ СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту)
		|				ИЛИ СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаПоставщику)
		|				ИЛИ СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании)
		|				ИЛИ СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыдачаПодотчетнику)
		|			ТОГДА СписаниеДенежныхСредств.Контрагент
		|	КОНЕЦ КАК Выдать
		|ИЗ
		|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств,
		|	Константа.ВалютаУчета КАК ВалютаУчета
		|ГДЕ
		|	СписаниеДенежныхСредств.Ссылка = &ТекущийДокумент
		|	И СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)";
		
		Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);		
		ВыборкаДляПечати = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаДляПечати.Количество() > 0 Тогда 
			ВыборкаДляПечати.Следующий();
			
			Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.СписаниеДенежныхСредств.ПФ_MXL_РКО");
			ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_РасходИзКассы_РасходИзКассы";
			
			Если ВыборкаДляПечати.ДатаДокумента < Дата('20110101') Тогда
				НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(ВыборкаДляПечати.Номер, ВыборкаДляПечати.Префикс);
			Иначе
				НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(ВыборкаДляПечати.Номер, Истина, Истина);
			КонецЕсли;		
			
			ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
			ОбластьМакета.Параметры.Заполнить(ВыборкаДляПечати);
			ОбластьМакета.Параметры.НомерДокумента = НомерДокумента;
			Если ТекущийДокумент.ВидОперации = Перечисления.ВидыОпераций.ВыплатаЗаработнойПлаты Тогда
				ОбластьМакета.Параметры.Выдать = ТекущийДокумент.РасшифровкаПлатежа[0].Сотрудник;
			КонецЕсли;
			ОбластьМакета.Параметры.Сумма = ФормированиеПечатныхФорм.СуммаПлатежногоДокумента(
			ВыборкаДляПечати.СуммаДокумента,
			Ложь
			);
			ОбластьМакета.Параметры.СуммаПрописью = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(
			ВыборкаДляПечати.СуммаДокумента,
			ВыборкаДляПечати.ВалютаДенежныхСредств,
			Ложь
			);
			Руководители = ФормированиеПечатныхФорм.ОтветственныеЛицаОрганизационнойЕдиницы(ВыборкаДляПечати.Организация, ТекущийДокумент.Ссылка.ПолучитьОбъект().МоментВремени());
			
			ОбластьМакета.Параметры.ФИОРуководителя		  = Руководители.ФИОРуководителя;
			ОбластьМакета.Параметры.ДолжностьРуководителя = Руководители.РуководительДолжность;
			ОбластьМакета.Параметры.ФИОГлавногоБухгалтера = Руководители.ФИОГлавногоБухгалтера;
			ОбластьМакета.Параметры.ФИОКассира            = Руководители.ФИОКассира;
			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
	
КонецФункции // ПечатнаяФорма()

// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФормуКМ3(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.СписаниеДенежныхСредств.ПФ_MXL_КМ3");
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеДокумента.Ссылка КАК Ссылка,
	|	ДанныеДокумента.Дата КАК ДатаДокумента,
	|	ДанныеДокумента.Номер КАК Номер,
	|	ДанныеДокумента.СтруктурнаяЕдиница,
	|	ДанныеДокумента.СтруктурнаяЕдиница.Организация.Префикс КАК Префикс,
	|	ДанныеДокумента.СтруктурнаяЕдиница.Организация КАК Организация,
	|	ДанныеДокумента.СуммаДокумента КАК Сумма,
	|	ДанныеДокумента.СтруктурнаяЕдиница.Организация.КодПоОКПО КАК ОрганизацияПоОКПО,
	|	ДанныеДокумента.СтруктурнаяЕдиница.Организация.ИНН
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка В(&МассивДокументов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номер");
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Выборка);
		ОбластьМакета.Параметры.ПредставлениеОрганизации = Выборка.Организация;
		
		СведенияОбОрганизации=ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Организация, Выборка.ДатаДокумента), "ОфициальноеНаименование");
		ОбластьМакета.Параметры.ПредставлениеОрганизации = СведенияОбОрганизации;
		ОбластьМакета.Параметры.ПредставлениеПодразделения = Выборка.СтруктурнаяЕдиница;
		
		ОбластьМакета.Параметры.НомерДокумента = ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(
		Выборка.Номер,
		Выборка.Префикс
		);
		ОбластьМакета.Параметры.ДатаДокумента		= Формат(Выборка.ДатаДокумента, "ДФ=dd.MM.yyyy");
		Сумма = Формат(Выборка.Сумма, "ЧЦ=15; ЧДЦ=2");
		
		ОбластьМакета.Параметры.Сумма = Сумма;
		ОбластьМакета.Параметры.СуммаПрописью = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(
		Выборка.Сумма, 
		, 
		Ложь);
		
		Руководитель=ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Выборка.Организация,Перечисления.ТипыОтветственныхЛиц.Руководитель,Выборка.ДатаДокумента);
		Если Руководитель.Количество()>0 Тогда
			ФИОРуководителя = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(Руководитель[0].Сотрудник)); 
			ОбластьМакета.Параметры.ФИОРуководителя = ФИОРуководителя;
			ОбластьМакета.Параметры.ДолжностьРуководителя=Руководитель[0].Должность;
			ОбластьМакета.Параметры.ДолжностьФИОРуководителя = ТРег(Руководитель[0].Должность) + " " + ФИОРуководителя;
		КонецЕсли;	
		
		ГлавБух=ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Выборка.Организация,Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер,Выборка.ДатаДокумента);
		Если ГлавБух.Количество()>0 Тогда 
			ОбластьМакета.Параметры.ФИОГлавногоБухгалтера=ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(ГлавБух[0].Сотрудник));
		КонецЕсли;	
		
		Кассир=ОбщегоНазначенияСтоматология.ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Выборка.Организация,Перечисления.ТипыОтветственныхЛиц.Кассир,Выборка.ДатаДокумента);
		Если Кассир.Количество()>0 Тогда 
			ОбластьМакета.Параметры.ФИОКассира=ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(Кассир[0].Сотрудник));
		КонецЕсли;	
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
		ТабличныйДокумент,
		НомерСтрокиНачало,
		ОбъектыПечати,
		Выборка.Ссылка
		);
		
		Возврат ТабличныйДокумент;
		
	КонецЦикла;
	
КонецФункции

#КонецОбласти

#КонецЕсли 
