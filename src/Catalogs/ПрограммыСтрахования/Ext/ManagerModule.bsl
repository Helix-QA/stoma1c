
#Область СлужебныеПроцедурыИФункции

// Функция - Получить цвет фона и текста.
//
// Параметры:
//  ПрограммаСтрахования - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТекстЦветФонаИТекста(ПрограммаСтрахования) Экспорт
	
	СтруктураРезультат = Новый Структура();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрограммыСтрахования.ЦветФона КАК ЦветФона,
	|	ПрограммыСтрахования.ЦветТекстаБелый КАК ЦветТекстаБелый,
	|	ПрограммыСтрахования.НаименованиеКратко КАК НаименованиеКратко,
	|	ПрограммыСтрахования.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ПрограммыСтрахования КАК ПрограммыСтрахования
	|ГДЕ
	|	ПрограммыСтрахования.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ПрограммаСтрахования); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЦветФона 		= ?(ЗначениеЗаполнено(Выборка.ЦветФона), ЗначениеИзСтрокиВнутр(Выборка.ЦветФона), Новый Цвет());
		ЦветТекста 		= ?(Выборка.ЦветТекстаБелый = Истина, Новый Цвет(255,255,255), Новый Цвет(77,77,77));
		ЦветТекстаБелый = Выборка.ЦветТекстаБелый;
		ТекстКратко 	= ?(ЗначениеЗаполнено(Выборка.НаименованиеКратко), Выборка.НаименованиеКратко, Лев(Выборка.Наименование, 10));   
	Иначе
		ЦветФона 		= Новый Цвет();
		ЦветТекста 		= Новый Цвет(77,77,77);
		ЦветТекстаБелый = Ложь;
		ТекстКратко 	= "";
	КонецЕсли;
	
	СтруктураРезультат.Вставить("ЦветФона"			, ЦветФона);
	СтруктураРезультат.Вставить("ЦветТекста"		, ЦветТекста);
	СтруктураРезультат.Вставить("ЦветТекстаБелый"	, ЦветТекстаБелый);
	СтруктураРезультат.Вставить("Текст"				, ТекстКратко);

	Возврат СтруктураРезультат;
	
КонецФункции

// Функция - Получить программу страхования по владельцу.
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПрограммыСтрахованияПоВладельцу(Владелец, ВидДоговора, КоличествоПервых = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 10
	|	ПрограммыСтрахования.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПрограммыСтрахования КАК ПрограммыСтрахования
	|ГДЕ
	|	ПрограммыСтрахования.Владелец = &Владелец
	|	И ПрограммыСтрахования.ВидДоговора = &ВидДоговора
	|	И ПрограммыСтрахования.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Владелец"	, Владелец);
	Запрос.УстановитьПараметр("ВидДоговора"	, ВидДоговора);
	
	Если ЗначениеЗаполнено(КоличествоПервых) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 10", СтрШаблон("ПЕРВЫЕ %1", КоличествоПервых));  	
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 10", "")
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
			
КонецФункции

