&НаКлиенте
// Выполнить печать Х-отчета.
//
Процедура ХОтчет(Элемент)
	
	Начало      = СтрНайти(Элемент.Имя, "_");
	НомерСтроки = Сред(Элемент.Имя,Начало + 1);
	
	ТекущиеДанные = ДанныеПоКассам[Число(НомерСтроки)];	
	ОповещениеПриЗавершении   = Новый ОписаниеОповещения("ОперацияЗавершение", ЭтотОбъект);
	ИдентификаторУстройстваФР = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ТекущиеДанные.Касса);
	ПараметрыОперации         = Новый Структура("Организация", ТекущиеДанные.Организация);
	
	МенеджерОборудованияКлиент.НачатьФормированиеОтчетаБезГашения(ОповещениеПриЗавершении, УникальныйИдентификатор, ПараметрыОперации, ИдентификаторУстройстваФР);

КонецПроцедуры

&НаКлиенте
// Закрытие смены, печать Z-отчета.
//
Процедура ZОтчет(Элемент)
	
	Начало      = СтрНайти(Элемент.Имя, "_");
	НомерСтроки = Сред(Элемент.Имя,Начало + 1);
	
	// Вызываем форму закрытия касссовй смены
	ТекущиеДанные = ДанныеПоКассам[Число(НомерСтроки)];	
	Если ТекущиеДанные.Открыта Тогда
		ОткрытьФорму("Документ.КассоваяСмена.Форма.ФормаЗакрытияКассовойСмены", Новый Структура("Касса", ТекущиеДанные.Касса),,,,, Новый ОписаниеОповещения("ZОтчетЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	Иначе
		ПараметрыОперации = Новый Структура;
		ИдентификаторУстройства = МенеджерОборудованияВызовСервера.ПолучитьИдентификаторФискальногоРегистратораДляКассы(ТекущиеДанные.Касса);		
		НомерТекущейСтроки = НомерСтроки;
		Если ЗначениеЗаполнено(ИдентификаторУстройства) Тогда                             			
			ПараметрыОперации = Новый Структура("Организация, Касса", ТекущиеДанные.Организация, ТекущиеДанные.Касса);
			Оповещение = Новый ОписаниеОповещения("ОткрытиеСменыЗавершение", ЭтотОбъект);
			МенеджерОборудованияКлиент.НачатьОткрытиеСменыНаФискальномУстройстве(Оповещение, УникальныйИдентификатор, ПараметрыОперации, ИдентификаторУстройства);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, закрытие кассовой смены завршение.
//
Процедура ОткрытиеСменыЗавершение(РезультатВыполнения, Параметры) Экспорт
	
	Если РезультатВыполнения.Результат Тогда 
		
		ОписаниеОшибки = "";		
		ТекущиеДанные  = ДанныеПоКассам[Число(НомерТекущейСтроки)];
		Результат      = РозничныеПродажи.ОткрытьКассовуюСмену(ТекущиеДанные.Касса, ОписаниеОшибки);		
		
		Если Не Результат Тогда
			
			ТекстСообщения = НСтр("ru='При открытии смены произошла ошибка. Смена не открыта.
			                      |Дополнительное описание: %ДополнительноеОписание%';
								  |en='With opening shifts happened mistake. Change not isopen.
								  |Additional description: %ДополнительноеОписание%'");
			
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			
		Иначе			
			
			ЭтаФорма.Закрыть(Истина);
			
		КонецЕсли;		
		
	Иначе
		
		ТекстСообщения = НСтр("ru='При открытии смены произошла ошибка.
		                      |Смена не открыта на фискальном регистраторе.
							  |%ДополнительноеОписание%';
							  |en='With opening shifts happened mistake.
							  |Change is not isopen on fiscal registrar.
							  |%ДополнительноеОписание%'");
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", РезультатВыполнения.ОписаниеОшибки);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
// Обработчик кнопки формирования выемки выручки.
//
Процедура ВыемкаВыручки(Элемент)
	
	Начало			= СтрНайти(Элемент.Имя, "_");
	НомерСтроки		= Сред(Элемент.Имя,	Начало + 1);	
	ТекущиеДанные	= ДанныеПоКассам[Число(НомерСтроки)];  
	
	Статья = Неопределено;
	ВидОперации = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекущиеДанные.Касса, "ВыемкаИзКассы");   
	
	Если ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.СдачаНаличныхВБанк") Тогда                
		Статья = ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.СдачаНаличныхВБанк");
	ИначеЕсли ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия") Тогда                
		Статья = ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.СдачаРозничнойВыручкиВКассуПредприятия");
	КонецЕсли;	
	
	ОткрытьФорму("Документ.КассоваяСмена.Форма.ФормаЗапросаСуммыОперации",
				Новый Структура("Инкассация, Касса, Статья", Истина, ТекущиеДанные.Касса, Статья),,,,,
				Новый ОписаниеОповещения("ВыемкаВыручкиЗавершение", ЭтотОбъект, ТекущиеДанные),
				РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	 
КонецПроцедуры

