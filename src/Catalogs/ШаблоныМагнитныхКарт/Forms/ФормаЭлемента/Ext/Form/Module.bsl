//
Процедура ВзятьПоле1Завершение(Результат, Параметры) Экспорт
	
	Элементы.ПоляДорожки1.ДобавитьСтроку();
	НовоеПоле = Элементы.ПоляДорожки1.ТекущиеДанные;
	НовоеПоле.НомерБлока = Результат.НомерБлока;
