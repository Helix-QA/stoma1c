#Область CloudPayments

// Функция, формирует ссылку на оплату основание и возвращает её. 
//
Функция СформироватьСсылкуОплатыCloudPayments(СтруктураПараметров)

	//https://developers.cloudpayments.ru/#sozdanie-scheta-dlya-otpravki-po-pochte 
	
	СтруктураВозврата		= СтруктураПараметров.СтруктураВозврата; 
	ПараметрыПШ				= СтруктураПараметров.ПараметрыПШ;
	СуммаОплаты 			= СтруктураПараметров.СуммаОплаты;
	ТаблицаЗадолженностей	= СтруктураПараметров.ТаблицаЗадолженностей;
    Валюта                  = СтруктураПараметров.СтруктурнаяЕдиница.Валюта;
	
	Если ТипЗнч(ПараметрыПШ) <> Тип("Структура")
		Или Не ЗначениеЗаполнено(ПараметрыПШ.ОткрытыйКлючCloudPayments)
		Или Не ЗначениеЗаполнено(ПараметрыПШ.ПарольCloudPayments) Тогда
		
		СтруктураВозврата.ОписаниеОшибки = "Не заполнены параметры эквайрингового терминала.";
		Возврат СтруктураВозврата;
	КонецЕсли;	
   
	СтруктураДанных = СформироватьСтруктуруДанныхCloudPayments(ТаблицаЗадолженностей, СуммаОплаты, ПараметрыПШ, Валюта);

	ОписаниеОшибки = "";
	Ответ = ВызовМетодаCloudPayments(СтруктураДанных, ПараметрыПШ, ОписаниеОшибки); 

	Если Ответ = Неопределено Или ЗначениеЗаполнено(ОписаниеОшибки) Тогда		
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке ссылки на оплату в CloudPayments. " + ОписаниеОшибки;
		Возврат СтруктураВозврата;		
	КонецЕсли;
		
	Если ТипЗнч(Ответ) <> Тип("Соответствие") Или Ответ["Success"] = Неопределено Тогда		
		СтруктураВозврата.ОписаниеОшибки = "Не верный ответ.";
		Возврат СтруктураВозврата;		
	КонецЕсли;	
		
	Success = Ответ["Success"];
	
	Если Success = Ложь Тогда
		СтруктураВозврата.ОписаниеОшибки = "Ошибка при отправке ссылки на оплату в CloudPayments. " + Ответ["Message"];
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	КороткаяСсылкаНаОплату = Ответ["Model"]["Url"]; 
	
	Если Не ЗначениеЗаполнено(КороткаяСсылкаНаОплату) Тогда		
		СтруктураВозврата.ОписаниеОшибки = "Не передана ссылка на оплату.";
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтруктураВозврата.Вставить("СсылкаНаОплату"		, КороткаяСсылкаНаОплату);
	СтруктураВозврата.Вставить("ВыполненоУспешно"	, Истина);
	
	НомерЗаказа = Число(Ответ["Model"]["Number"]);
	
	Для Каждого СтрокаТ Из ТаблицаЗадолженностей Цикл
		
	РегистрыСведений.СтатусыОплатыЗаказов.СоздатьИлиОбновитьЗапись(
		СтрокаТ.ДокументЗадолженности, 
		СтрокаТ.Задолженность, 
		СтруктураДанных.InvoiceId, 
		КороткаяСсылкаНаОплату, 
		Перечисления.СтатусыЗаказовОнлайнОплаты.НеОплачено, 
		СтруктураПараметров.ЭквайринговыйТерминал, 
		НомерЗаказа,
		,
		Не ЗначениеЗаполнено(СтрокаТ.ДокументЗадолженности),
		СтруктураПараметров.Контрагент,,
		СтруктураПараметров.СтруктурнаяЕдиница,
		ТекущаяДатаСеанса(),
		"Заказ зарегистрирован, но не оплачен",
		Перечисления.ТипыСсылокНаОплату.CloudPayments);
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция - Сформировать структуру данных
//
// Параметры:
//  Основание	 - 	 - 
//  Сумма		 - 	 - 
//  ПараметрыПШ	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СформироватьСтруктуруДанныхCloudPayments(ТаблицаЗадолженностей, Сумма, ПараметрыПШ, Валюта)
		
	СтруктураДанных = Новый Структура();
	Сумма = Формат(Сумма, "ЧРД=.; ЧГ=");                  // сумма в копейках.
	СтруктураДанных.Вставить("Amount", Сумма);     // стоимость товара в валюте оплаты (amountcurr)   
	ВалютаНаименование = ?(ЗначениеЗаполнено(Валюта), Валюта.Наименование, "RUB");
	СтруктураДанных.Вставить("Currency", ВалютаНаименование);   // валюта, в которой задана стоимость товара (amount)
	ЭтоРеализация = ТипЗнч(ТаблицаЗадолженностей[0].ДокументЗадолженности) = Тип("ДокументСсылка.Реализация");
	
	Описание      = "";
	ПервыйЭлемент = Истина;
	
	Если ЭтоРеализация Тогда
		Для Каждого Основание Из ТаблицаЗадолженностей Цикл
			Для Каждого СтрокаТЧ Из Основание.ДокументЗадолженности.Запасы Цикл 
				
				Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда		
					Если Не ПервыйЭлемент Тогда
						Описание = Описание + ", "	
					КонецЕсли;		
					Описание = Описание + СтрокаТЧ.Номенклатура.Наименование;
					ПервыйЭлемент = Ложь;
				КонецЕсли;	
			КонецЦикла;	  
		КонецЦикла;
	Иначе
		Описание = "Взнос на лицевой счет";	
	КонецЕсли;
	
	СтруктураДанных.Вставить("Description", Описание); //Назначение платежа в свободной форме 
	
	ДатаЗаказа  = ТекущаяДатаСеанса();
	НомерЗаказа = СформироватьНомерЗаказаСБП();
	НомерЗаказа = СтрЗаменить(НомерЗаказа, ":", "");

	СтруктураДанных.Вставить("InvoiceId", НомерЗаказа); // Номер заказа в вашей системе
	СтруктураДанных.Вставить("SuccessRedirectUrl", ПараметрыПШ.PayУведомлениеCloudPayments);	
	
	Возврат СтруктураДанных;
	
КонецФункции

