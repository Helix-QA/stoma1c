	//|						ТОГДА НастройкиПользователей.Значение
	//|					ИНАЧЕ NULL
	//|				КОНЕЦ) КАК ДатаПриема,
	//|			МАКСИМУМ(ВЫБОР
	//|					КОГДА НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаУвольнения)
	//|						ТОГДА НастройкиПользователей.Значение
	//|					ИНАЧЕ NULL
	//|				КОНЕЦ) КАК ДатаУвольнения
	//|		ИЗ
	//|			РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	//|		ГДЕ
	//|       НастройкиПользователей.Пользователь ССЫЛКА Справочник.Сотрудники
	//|			И (НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаПриема)
	//|					ИЛИ НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.НастройкиПользователей.ДатаУвольнения))
	//|		
	//|		СГРУППИРОВАТЬ ПО
	//|			НастройкиПользователей.Пользователь) КАК ДатыПриемаНаРаботу
	//|		ПО Сотрудники.Ссылка = ДатыПриемаНаРаботу.Пользователь
	//|ГДЕ
	//|	НЕ Сотрудники.ЭтоГруппа
	//|	И НЕ Сотрудники.ПометкаУдаления
	//|	И Сотрудники.Должность = &Должность
	//|	И Сотрудники.Роль = &Роль
	//|	И Сотрудники.Ссылка В ИЕРАРХИИ (&Сотрудник)";          	
	#КонецОбласти
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.НормаВремени КАК НормаВремениСотрудника,
	|	Номенклатуры.НормаВремени КАК НормаВремени,
	|	Номенклатуры.НормаВремени КАК БазоваяНормаВремени
	|ПОМЕСТИТЬ УслугиСотрудника
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатуры
	|		ПО УслугиСотрудника.Номенклатура = Номенклатуры.Ссылка
	|ГДЕ
	|	УслугиСотрудника.Номенклатура = &Номенклатура
	|	И УслугиСотрудника.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СпрСотрудники.Ссылка КАК Сотрудник,
	|	СпрСотрудники.ЭтоГруппа КАК ЭтоГруппа,
	|	ВЫБОР
	|		КОГДА СпрСотрудники.ЭтоГруппа
	|			ТОГДА 0
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндКартинки,
	|	СпрСотрудники.Родитель КАК Родитель,
	|	СпрСотрудники.Наименование КАК Наименование,
	|	УслугиСотрудника.НормаВремениСотрудника КАК НормаВремениСотрудника,
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СпрСотрудники.Должность КАК Должность,
	|	СпрСотрудники.Роль КАК Роль
	|ИЗ
	|	Справочник.Сотрудники КАК СпрСотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ УслугиСотрудника КАК УслугиСотрудника
	|		ПО СпрСотрудники.Ссылка = УслугиСотрудника.Сотрудник
	|ГДЕ
	|	НЕ СпрСотрудники.ПометкаУдаления
	|	И НЕ СпрСотрудники.ЭтоГруппа
	|   И СпрСотрудники.Служебный = ЛОЖЬ
	|	И &ОтборПоДолжности
	|	И &ОтборПоРоли
	|   И &ОтборПоСотруднику
	|УПОРЯДОЧИТЬ ПО
	|	Должность,
	|	Наименование");
	
	Запрос.УстановитьПараметр("Номенклатура"			  , ЭтотОбъект.Номенклатура);
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МестаРаботы.Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница"));
	
	Если ЗначениеЗаполнено(ОтборСотрудник) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И &ОтборПоСотруднику","И СпрСотрудники.Ссылка = &Сотрудник"); 
		Запрос.УстановитьПараметр("Сотрудник",ОтборСотрудник);  
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И &ОтборПоСотруднику","");
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ОтборСотрудникДолжность) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И &ОтборПоДолжности","И СпрСотрудники.Должность = &Должность"); 
		Запрос.УстановитьПараметр("Должность",ОтборСотрудникДолжность); 
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И &ОтборПоДолжности","");
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ОтборСотрудникРоль) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И &ОтборПоРоли","И СпрСотрудники.Роль = &Роль"); 
		Запрос.УстановитьПараметр("Роль",ОтборСотрудникРоль);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"И &ОтборПоРоли",""); 
	КонецЕсли;
		
	
	ВременныйСписокСотрудников = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
