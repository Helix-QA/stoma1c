//
//
Функция ВернутьВыданныеАвансы(Ссылка, Сотрудник, СтруктурнаяЕдиница, МассивУжеВыбранныхАвансов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВложенныйЗапрос.Документ КАК Документ,
	               |	ВложенныйЗапрос.Сотрудник КАК Сотрудник,
	               |	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	ВложенныйЗапрос.Сумма КАК Сумма
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.ДокументОснования КАК Документ,
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.Сотрудник КАК Сотрудник,
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |		СУММА(РасчетыСПодотчетникамиОстаткиИОбороты.СуммаОборот) КАК Сумма
	               |	ИЗ
	               |		РегистрНакопления.РасчетыСПодотчетниками.ОстаткиИОбороты(
	               |				,
	               |				,
	               |				Авто,
	               |				,
	               |				Сотрудник = &Сотрудник
	               |					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |					И ДокументОснования <> ЗНАЧЕНИЕ(Документ.СписаниеДенежныхСредств.ПустаяСсылка)
	               |					И НЕ ДокументОснования В (&МассивДокументов)) КАК РасчетыСПодотчетникамиОстаткиИОбороты
	               |	ГДЕ
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.Регистратор <> &Регистратор
	               |	
	               |	СГРУППИРОВАТЬ ПО
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.ДокументОснования,
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.Сотрудник,
	               |		РасчетыСПодотчетникамиОстаткиИОбороты.СтруктурнаяЕдиница) КАК ВложенныйЗапрос
	               |ГДЕ
	               |	ВложенныйЗапрос.Сумма > 0
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВложенныйЗапрос.Документ.Дата";
				   
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("МассивДокументов", МассивУжеВыбранныхАвансов);
	Запрос.УстановитьПараметр("Регистратор", Ссылка);
	
	Возврат ОбщегоНазначенияКлиентСерверСтоматология.КонвертироватьТаблицуВМассивСтруктур(Запрос.Выполнить().Выгрузить());	
	
КонецФункции 

