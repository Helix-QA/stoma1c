
#Область ОбработчикиСобытийФормы

&НаСервере 
// Обработчик события "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПоказыватьКод          = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников"); 
	Элементы.Код.Видимость = ПоказыватьКод;	 
	Список.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	
КонецПроцедуры

#КонецОбласти