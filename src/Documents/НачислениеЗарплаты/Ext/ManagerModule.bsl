// ПРОЦЕДУРЫ И ФУНКЦИИ ПЕЧАТИ

// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФорму(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.НачислениеЗарплаты.ПФ_MXL_РасчетныйЛисток");

	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	НачислениеЗарплатыРасчетЗарплаты.Ссылка КАК Ссылка,
	                      |	НачислениеЗарплатыРасчетЗарплаты.Сотрудник КАК Сотрудник,
	                      |	НачислениеЗарплатыРасчетЗарплаты.НачислениеУдержание КАК ВидНачисления,
	                      |	ВЫБОР
	                      |		КОГДА НачислениеЗарплатыРасчетЗарплаты.Сумма > 0
	                      |			ТОГДА НачислениеЗарплатыРасчетЗарплаты.Сумма
	                      |		ИНАЧЕ 0
	                      |	КОНЕЦ КАК СуммаНачисления,
	                      |	НачислениеЗарплатыРасчетЗарплаты.База,
	                      |	НачислениеЗарплатыРасчетЗарплаты.Размер,
	                      |	НачислениеЗарплатыРасчетЗарплаты.Ссылка.СтруктурнаяЕдиница,
	                      |	НачислениеЗарплатыРасчетЗарплаты.Ссылка.Организация,
	                      |	НачислениеЗарплатыРасчетЗарплаты.ДнейФакт КАК ДнейФакт,
	                      |	НачислениеЗарплатыРасчетЗарплаты.ЧасовФакт КАК ЧасовФакт,
	                      |	НачислениеЗарплатыРасчетЗарплаты.ДнейПлан КАК ДнейПлан,
	                      |	НачислениеЗарплатыРасчетЗарплаты.ЧасовПлан КАК ЧасовПлан,
	                      |	НачислениеЗарплатыРасчетЗарплаты.Сотрудник.Должность КАК Должность,
	                      |	НачислениеЗарплатыРасчетЗарплаты.Ссылка.ДатаНачалаПериода КАК РасчетнаяДата,
	                      |	КОНЕЦПЕРИОДА(НачислениеЗарплатыРасчетЗарплаты.Ссылка.ДатаОкончанияПериода, ДЕНЬ) КАК ДатаОкончанияПериода,
	                      |	ВЫБОР
	                      |		КОГДА НачислениеЗарплатыРасчетЗарплаты.Сумма < 0
	                      |			ТОГДА НачислениеЗарплатыРасчетЗарплаты.Сумма
	                      |		ИНАЧЕ 0
	                      |	КОНЕЦ КАК СуммаУдержания
	                      |ИЗ
	                      |	Документ.НачислениеЗарплаты.РасчетЗарплаты КАК НачислениеЗарплатыРасчетЗарплаты
	                      |ГДЕ
	                      |	НачислениеЗарплатыРасчетЗарплаты.Ссылка В(&МассивОбъектов)
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Сотрудник,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Начисление,
	                      |	ВЫБОР
	                      |		КОГДА НачислениеЗарплатыПрочиеНачисленияИУдержания.Сумма > 0
	                      |			ТОГДА НачислениеЗарплатыПрочиеНачисленияИУдержания.Сумма
	                      |		ИНАЧЕ 0
	                      |	КОНЕЦ,
	                      |	0,
	                      |	0,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.СтруктурнаяЕдиница,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.Организация,
	                      |	0,
	                      |	0,
	                      |	0,
	                      |	0,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Сотрудник.Должность,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.ДатаНачалаПериода,
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка.ДатаОкончанияПериода,
	                      |	ВЫБОР
	                      |		КОГДА НачислениеЗарплатыПрочиеНачисленияИУдержания.Сумма < 0
	                      |			ТОГДА НачислениеЗарплатыПрочиеНачисленияИУдержания.Сумма
	                      |		ИНАЧЕ 0
	                      |	КОНЕЦ
	                      |ИЗ
	                      |	Документ.НачислениеЗарплаты.ПрочиеНачисленияИУдержания КАК НачислениеЗарплатыПрочиеНачисленияИУдержания
	                      |ГДЕ
	                      |	НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка В(&МассивОбъектов)
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Сотрудник");
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.СледующийПоЗначениюПоля("Сотрудник") Цикл
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("ОбластьЗаголовок");
		ОбластьШапки = Макет.ПолучитьОбласть("ОбластьШапка");
		ОбластьШапки.Параметры.Заполнить(Выборка);
		ОбластьШапки.Параметры.РасчетнаяДата = Формат(Выборка.РасчетнаяДата, "ДФ=dd.MM.yy") + " по: " + Формат(Выборка.ДатаОкончанияПериода, "ДФ=dd.MM.yy");

		ОбластьШапкиТаблицы = Макет.ПолучитьОбласть("ОбластьШапкаТаблицы");
		
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		ТабличныйДокумент.Вывести(ОбластьШапки);
		ТабличныйДокумент.Вывести(ОбластьШапкиТаблицы);
		
		ВыборкаДетально 		= Выборка;
		ОбластьСтрокаНачисление = Макет.ПолучитьОбласть("ОбластьСтрокаТаблицыНачисление");
		ОбластьСтрокаУдержание 	= Макет.ПолучитьОбласть("ОбластьСтрокаТаблицыУдержание");
		
		ТабДокументНачисленияУдержания 	= Новый ТабличныйДокумент;
		ТабДокументНачисления 			= Новый ТабличныйДокумент;
		ТабДокументУдержания 			= Новый ТабличныйДокумент;

		КолН 			= 0;  // Количество начислений
		КолУ 			= 0;  // Количество удержаний
		
		СуммаНачисления = 0;
		СуммаУдержания  = 0;
		
		Пока ВыборкаДетально.Следующий() Цикл
			ИмяРеквизита = "";
			Если ТипЗнч(ВыборкаДетально.ВидНачисления) = Тип("СправочникСсылка.НачисленияИУдержанияСотрудников") Тогда 
				ИмяРеквизита = "НачислениеУдержание";
			Иначе 
				ИмяРеквизита = "ТипНачисленияУдержания";
			КонецЕсли;
			
			Если ВыборкаДетально.ВидНачисления[ИмяРеквизита] = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда
				
				ОбластьСтрокаНачисление.Параметры.Заполнить(ВыборкаДетально);
				
				Если ИмяРеквизита = "НачислениеУдержание" Тогда 
					Если ВыборкаДетально.ВидНачисления.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Процент Тогда
						ОбластьСтрокаНачисление.Параметры.ДнейЧасов = Формат(ВыборкаДетально.Размер, "") + "%";
					ИначеЕсли ВыборкаДетально.ВидНачисления.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Оклад Тогда
						Если ВыборкаДетально.ВидНачисления.ЗависимостьОтВыработки = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗависитОтВыработки
							И ВыборкаДетально.ВидНачисления.ТипПериодаНачисления = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ПоЧасам Тогда
							ОбластьСтрокаНачисление.Параметры.ДнейЧасов = Формат(ВыборкаДетально.ЧасовПлан, "ЧДЦ=0; ЧН=") + " / " + Формат(ВыборкаДетально.ЧасовФакт, "ЧДЦ=0; ЧН=");
						Иначе
							ОбластьСтрокаНачисление.Параметры.ДнейЧасов = Формат(ВыборкаДетально.ДнейПлан, "ЧДЦ=0; ЧН=") + " / " + Формат(ВыборкаДетально.ДнейФакт, "ЧДЦ=0; ЧН=");
						КонецЕсли;
					ИначеЕсли ВыборкаДетально.ВидНачисления.ТипНачисленияУдержания = Перечисления.ТипыНачисленийУдержаний.Тариф Тогда
						Если ВыборкаДетально.ВидНачисления.ТипТарифа = Перечисления.ВариантыЗначенийПоВидамНачисленийУдержаний.ЗаЧас Тогда
							ОбластьСтрокаНачисление.Параметры.ДнейЧасов = Формат(ВыборкаДетально.ЧасовФакт, "ЧДЦ=0; ЧН=");
						Иначе
							ОбластьСтрокаНачисление.Параметры.ДнейЧасов = Формат(ВыборкаДетально.ДнейФакт, "ЧДЦ=0; ЧН=");
						КонецЕсли;					
					Иначе
						ОбластьСтрокаНачисление.Параметры.ДнейЧасов = "";
					КонецЕсли;
				Иначе 
					ОбластьСтрокаНачисление.Параметры.ДнейЧасов = "";
				КонецЕсли;
				
				ТабДокументНачисления.Вывести(ОбластьСтрокаНачисление);
				
				КолН = КолН +1;
				СуммаНачисления = СуммаНачисления + Выборка.СуммаНачисления;
				
			ИначеЕсли ВыборкаДетально.ВидНачисления[ИмяРеквизита] = Перечисления.ТипыНачисленийУдержаний.Удержание Тогда
				
				ОбластьСтрокаУдержание.Параметры.Заполнить(ВыборкаДетально);
				ОбластьСтрокаУдержание.Параметры.СуммаУдержания = Выборка.СуммаУдержания*-1;				
				ТабДокументУдержания.Вывести(ОбластьСтрокаУдержание);
				КолУ = КолУ +1;
				СуммаУдержания = СуммаУдержания + Выборка.СуммаУдержания;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Линия = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная,1);
		
		// Соединяем начисления и удержания
		ТабДокументНачисленияУдержания.Присоединить(ТабДокументНачисления);
		ТабДокументНачисленияУдержания.Присоединить(ТабДокументУдержания);
		Область = ТабДокументНачисленияУдержания.Область("R1C1:R"+Макс(КолН, КолУ)+"C7");
		Область.Обвести(Линия, Линия, Линия, Линия);
		
		// Выводим параллельные списки начислений удержаний
		ТабличныйДокумент.Вывести(ТабДокументНачисленияУдержания);
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЕСТЬNULL(СУММА(РасчетыСПерсоналомОстаткиИОбороты.СуммаНачальныйОстаток), 0) КАК ДолгНачало,
		|	ЕСТЬNULL(СУММА(РасчетыСПерсоналомОстаткиИОбороты.СуммаКонечныйОстаток), 0) КАК Долг,
		|	ЕСТЬNULL(СУММА(РасчетыСПерсоналомОстаткиИОбороты.СуммаРасход), 0) КАК Выплачено,
		|	ЕСТЬNULL(СУММА(РасчетыСПерсоналомОстаткиИОбороты.СуммаПриход), 0) КАК Начислено
		|ИЗ
		|	РегистрНакопления.РасчетыСПерсоналом.ОстаткиИОбороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			,
		|			,
		|			Сотрудник = &Сотрудник
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК РасчетыСПерсоналомОстаткиИОбороты";
		
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Выборка.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("Сотрудник", Выборка.Сотрудник);
		Запрос.УстановитьПараметр("НачалоПериода", Выборка.РасчетнаяДата);		
		Запрос.УстановитьПараметр("КонецПериода", КонецДня(Выборка.ДатаОкончанияПериода));
		
		ВыборкаИтоги = Запрос.Выполнить().Выбрать();
		ВыборкаИтоги.Следующий();
		
		ОбластьСтрокаИтог = Макет.ПолучитьОбласть("ОбластьСтрокаИтог");
		ОбластьСтрокаИтог.Параметры.СуммаУдержания  = СуммаУдержания*-1;
		ОбластьСтрокаИтог.Параметры.СуммаНачисления = СуммаНачисления;
		
		ОбластьПодвал = Макет.ПолучитьОбласть("ОбластьПодвал");
		ОбластьПодвал.Параметры.ДолгНачало 		= Формат(ВыборкаИтоги.ДолгНачало, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		ОбластьПодвал.Параметры.Выплачено 		= Формат(ВыборкаИтоги.Выплачено, "ЧЦ=15; ЧДЦ = 2; ЧН=0,00") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		ОбластьПодвал.Параметры.Долг 			= Формат(ВыборкаИтоги.Долг, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти();
		СуммаИтого 								= ВыборкаИтоги.Долг;
		ОбластьПодвал.Параметры.СуммаПрописью 	= Формат(СуммаИтого, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодИспользуемойВалютыЦелойЧасти() +"(" + ФормированиеПечатныхФорм.СформироватьСуммуПрописью(СуммаИтого) + ")";
		
		ТабличныйДокумент.Вывести(ОбластьСтрокаИтог);
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФорму()

// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФормуПлатежнаяВедомость(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.НачислениеЗарплаты.ПФ_MXL_ПлатежнаяВедомость");

	Для Каждого ДокНачисление Из МассивОбъектов Цикл
		ОбластьШапкиДокумента = Макет.ПолучитьОбласть("ШапкаДокумента");
		ОбластьШапкиДокумента.Параметры.НазваниеОрганизации = ДокНачисление.Организация;
		ОбластьШапкиДокумента.Параметры.СуммаДокПрописью = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(ДокНачисление.РасчетЗарплаты.Итог("Сумма") + ДокНачисление.ПрочиеНачисленияИУдержания.Итог("Сумма") - ДокНачисление.Авансы.Итог("Сумма"));
		ОбластьШапкиДокумента.Параметры.СуммаДок = ДокНачисление.РасчетЗарплаты.Итог("Сумма") + ДокНачисление.ПрочиеНачисленияИУдержания.Итог("Сумма") - ДокНачисление.Авансы.Итог("Сумма");
		ОбластьШапкиДокумента.Параметры.Валюта = ОбщегоНазначенияСтоматология.ПолучитьСимвольныйКодЦелойчастиВалюты();
		
		Отбор = Новый Структура("Организация, ТипОтветственногоЛица", ДокНачисление.Организация, Перечисления.ТипыОтветственныхЛиц.Руководитель);
		СрезОтветственныхЛиц = РегистрыСведений.ОтветственныеЛица.СрезПоследних(ТекущаяДата(), Отбор);
		ОбластьШапкиДокумента.Параметры.РуководительДолжность = ?(СрезОтветственныхЛиц.Количество() > 0, СрезОтветственныхЛиц[0].Должность, "");
		ОбластьШапкиДокумента.Параметры.ФИОРуководителя = ?(СрезОтветственныхЛиц.Количество() > 0, ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(СрезОтветственныхЛиц[0].Сотрудник)), "");
		Отбор = Новый Структура("Организация, ТипОтветственногоЛица", ДокНачисление.Организация, Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер);
		СрезОтветственныхЛиц = РегистрыСведений.ОтветственныеЛица.СрезПоследних(ТекущаяДата(), Отбор);
		ОбластьШапкиДокумента.Параметры.ФИОГлавногоБухгалтера = ?(СрезОтветственныхЛиц.Количество() > 0, ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Строка(СрезОтветственныхЛиц[0].Сотрудник)), "");
		ОбластьШапкиДокумента.Параметры.НомерДок = ДокНачисление.Номер;
		ОбластьШапкиДокумента.Параметры.ДатаДок = ДокНачисление.Дата;
		ОбластьШапкиДокумента.Параметры.ОтчетныйПериодС = ДокНачисление.ДатаНачалаПериода;
		ОбластьШапкиДокумента.Параметры.ОтчетныйПериодПо = ДокНачисление.ДатаОкончанияПериода;
		ТабличныйДокумент.Вывести(ОбластьШапкиДокумента);
		
		ОбластьШапки = Макет.ПолучитьОбласть("Шапка");
		ТабличныйДокумент.Вывести(ОбластьШапки);
		
		Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
		                      |	ВложенныйЗапрос.Сотрудник,
		                      |	СУММА(ВложенныйЗапрос.Сумма) КАК Сумма
		                      |ИЗ
		                      |	(ВЫБРАТЬ
		                      |		НачислениеЗарплатыРасчетЗарплаты.Сотрудник КАК Сотрудник,
		                      |		СУММА(НачислениеЗарплатыРасчетЗарплаты.Сумма) КАК Сумма
		                      |	ИЗ
		                      |		Документ.НачислениеЗарплаты.РасчетЗарплаты КАК НачислениеЗарплатыРасчетЗарплаты
		                      |	ГДЕ
		                      |		НачислениеЗарплатыРасчетЗарплаты.Ссылка = &Ссылка
		                      |	
		                      |	СГРУППИРОВАТЬ ПО
		                      |		НачислениеЗарплатыРасчетЗарплаты.Сотрудник
		                      |	
		                      |	ОБЪЕДИНИТЬ ВСЕ
		                      |	
		                      |	ВЫБРАТЬ
		                      |		НачислениеЗарплатыПрочиеНачисленияИУдержания.Сотрудник,
		                      |		СУММА(НачислениеЗарплатыПрочиеНачисленияИУдержания.Сумма)
		                      |	ИЗ
		                      |		Документ.НачислениеЗарплаты.ПрочиеНачисленияИУдержания КАК НачислениеЗарплатыПрочиеНачисленияИУдержания
		                      |	ГДЕ
		                      |		НачислениеЗарплатыПрочиеНачисленияИУдержания.Ссылка = &Ссылка
		                      |	
		                      |	СГРУППИРОВАТЬ ПО
		                      |		НачислениеЗарплатыПрочиеНачисленияИУдержания.Сотрудник
		                      |	
		                      |	ОБЪЕДИНИТЬ ВСЕ
		                      |	
		                      |	ВЫБРАТЬ
		                      |		НачислениеЗарплатыАвансы.Сотрудник,
		                      |		СУММА(-НачислениеЗарплатыАвансы.Сумма)
		                      |	ИЗ
		                      |		Документ.НачислениеЗарплаты.Авансы КАК НачислениеЗарплатыАвансы
		                      |	ГДЕ
		                      |		НачислениеЗарплатыАвансы.Ссылка = &Ссылка
		                      |	
		                      |	СГРУППИРОВАТЬ ПО
		                      |		НачислениеЗарплатыАвансы.Сотрудник) КАК ВложенныйЗапрос
		                      |ГДЕ
		                      |	ВложенныйЗапрос.Сумма <> 0
		                      |
		                      |СГРУППИРОВАТЬ ПО
		                      |	ВложенныйЗапрос.Сотрудник
		                      |
		                      |УПОРЯДОЧИТЬ ПО
		                      |	ВложенныйЗапрос.Сотрудник.Наименование");
		Запрос.УстановитьПараметр("Ссылка", ДокНачисление);
		Выборка = Запрос.Выполнить().Выбрать();
		
		ОбластьСтрокаДетали = Макет.ПолучитьОбласть("Детали");
		Индекс = 0;
		Пока Выборка.Следующий() Цикл
			Индекс = Индекс + 1;
			ОбластьСтрокаДетали.Параметры.НомерСтроки = Индекс;
			ОбластьСтрокаДетали.Параметры.ТабельныйНомер = Выборка.Сотрудник.Код;
			ОбластьСтрокаДетали.Параметры.ХарактерРаботы = "Осн.";
			ОбластьСтрокаДетали.Параметры.Физлицо = Выборка.Сотрудник;
			ОбластьСтрокаДетали.Параметры.Сумма = Выборка.Сумма;
			ТабличныйДокумент.Вывести(ОбластьСтрокаДетали);
			
		КонецЦикла;
		
		ОбластьПодвала = Макет.ПолучитьОбласть("Подвал");
		ТабличныйДокумент.Вывести(ОбластьПодвала);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуКО2()

// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФормуРасшифровкаНачисленияПодробно(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.НачислениеЗарплаты.ПФ_MXL_РасшифровкаНачисленияПодробно");
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	НачислениеЗарплатыЗатраты.Ссылка,
	                      |	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница,
	                      |	НАЧАЛОПЕРИОДА(НачислениеЗарплатыЗатраты.Дата, ДЕНЬ) КАК Дата,
	                      |	НачислениеЗарплатыЗатраты.ВидНачисления КАК ВидНачисления,
	                      |	НачислениеЗарплатыЗатраты.Контрагент,
	                      |	НачислениеЗарплатыЗатраты.Сотрудник,
	                      |	НачислениеЗарплатыЗатраты.Номенклатура,
	                      |	НачислениеЗарплатыЗатраты.План,
	                      |	НачислениеЗарплатыЗатраты.Факт,
	                      |	НачислениеЗарплатыЗатраты.База,
	                      |	НачислениеЗарплатыЗатраты.Размер,
	                      |	НачислениеЗарплатыЗатраты.Сумма
	                      |ИЗ
	                      |	Документ.НачислениеЗарплаты.Затраты КАК НачислениеЗарплатыЗатраты
	                      |ГДЕ
	                      |	НачислениеЗарплатыЗатраты.Ссылка.Проведен = ИСТИНА
	                      |	И НачислениеЗарплатыЗатраты.Ссылка В(&МассивОбъектов)
	                      |
	                      |УПОРЯДОЧИТЬ ПО
						  |	Сотрудник,
	                      |	Дата,
	                      |	ВидНачисления");
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		Область = Макет.ПолучитьОбласть("Заголовок");
		ТабличныйДокумент.Вывести(Область);
	Иначе
		
		Пока Выборка.СледующийПоЗначениюПоля("Сотрудник") Цикл
			
			Область = Макет.ПолучитьОбласть("Заголовок");
			Область.Параметры.Заполнить(Выборка);
			Область.Параметры.РасчетнаяДата = "с: " + Формат(Выборка.Ссылка.ДатаНачалаПериода, "ДФ=dd.MM.yy") + " по: " + Формат(Выборка.Ссылка.ДатаОкончанияПериода, "ДФ=dd.MM.yy");
			ТабличныйДокумент.Вывести(Область);
			
			Область = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(Область);
			
			СуммаНачисленияИтого = 0;
			СуммаУдержанияИтого = 0;
			
			ВыборкаПоДате = Выборка;
			Пока ВыборкаПоДате.СледующийПоЗначениюПоля("Дата") Цикл
				
				НомерСтрокиТаблицыС = ТабличныйДокумент.ВысотаТаблицы;
				
				ВыборкаДетально = ВыборкаПоДате;
				Пока ВыборкаДетально.Следующий() Цикл
					
					Область = Макет.ПолучитьОбласть("СтрокаЗначений");
					Область.Параметры.Заполнить(ВыборкаДетально);
					Если Область.Параметры.Сумма <> Окр(ВыборкаДетально.Сумма, 2) Тогда
						Область.Параметры.Сумма = Формат(Окр(ВыборкаДетально.Сумма, 2), "ЧЦ=15; ЧДЦ=2") + "..";
					КонецЕсли;
					
					ИмяРеквизита = "";
					Если ТипЗнч(ВыборкаДетально.ВидНачисления) = Тип("СправочникСсылка.НачисленияИУдержанияСотрудников") Тогда 
						ИмяРеквизита = "НачислениеУдержание";
					Иначе 
						ИмяРеквизита = "ТипНачисленияУдержания";
					КонецЕсли;
					
					Если ВыборкаДетально.ВидНачисления[ИмяРеквизита] = Перечисления.ТипыНачисленийУдержаний.Начисление Тогда
						СуммаНачисленияИтого = СуммаНачисленияИтого + Выборка.Сумма;
					Иначе
						СуммаУдержанияИтого = СуммаУдержанияИтого + -1 * Выборка.Сумма;
					КонецЕсли;
					
					ТабличныйДокумент.Вывести(Область);
					
				КонецЦикла;
				
				ТабличныйДокумент.Область(НомерСтрокиТаблицыС + 1, 1, ТабличныйДокумент.ВысотаТаблицы, 1).Объединить();
				
			КонецЦикла;
			
			Область = Макет.ПолучитьОбласть("Итог");
			Область.Параметры.СуммаНачисленияИтого = СуммаНачисленияИтого;
			Область.Параметры.СуммаУдержанияИтого = СуммаУдержанияИтого;
			Область.Параметры.СуммаИтого = СуммаНачисленияИтого - СуммаУдержанияИтого;
			ТабличныйДокумент.Вывести(Область);
			
		КонецЦикла;
	КонецЕсли;
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуРасшифровкаНачисления()

// Функция формирует табличный документ с печатной формой накладной,
// разработанной методистами
//
// Возвращаемое значение:
//  Табличный документ - печатная форма накладной
//
Функция СформироватьПечатнуюФормуРасшифровкаНачисления(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;

	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.НачислениеЗарплаты.ПФ_MXL_РасшифровкаНачисления");
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	НачислениеЗарплатыЗатраты.Ссылка КАК Ссылка,
	                      |	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	                      |	НАЧАЛОПЕРИОДА(НачислениеЗарплатыЗатраты.Дата, ДЕНЬ) КАК Дата,
	                      |	НачислениеЗарплатыЗатраты.ВидНачисления КАК ВидНачисления,
	                      |	НачислениеЗарплатыЗатраты.Сотрудник КАК Сотрудник,
	                      |	НачислениеЗарплатыЗатраты.Номенклатура КАК Номенклатура,
	                      |	МАКСИМУМ(НачислениеЗарплатыЗатраты.План) КАК План,
	                      |	СУММА(НачислениеЗарплатыЗатраты.Факт) КАК Факт,
	                      |	СУММА(НачислениеЗарплатыЗатраты.База) КАК База,
	                      |	НачислениеЗарплатыЗатраты.Размер КАК Размер,
	                      |	СУММА(НачислениеЗарплатыЗатраты.Сумма) КАК Сумма
	                      |ИЗ
	                      |	Документ.НачислениеЗарплаты.Затраты КАК НачислениеЗарплатыЗатраты
	                      |ГДЕ
	                      |	НачислениеЗарплатыЗатраты.Ссылка.Проведен = ИСТИНА
	                      |	И НачислениеЗарплатыЗатраты.Ссылка В(&МассивОбъектов)
	                      |	И НачислениеЗарплатыЗатраты.ВидНачисления.ТипНачисленияУдержания <> ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийУдержаний.Оклад)
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	НачислениеЗарплатыЗатраты.Ссылка,
	                      |	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница,
	                      |	НАЧАЛОПЕРИОДА(НачислениеЗарплатыЗатраты.Дата, ДЕНЬ),
	                      |	НачислениеЗарплатыЗатраты.ВидНачисления,
	                      |	НачислениеЗарплатыЗатраты.Сотрудник,
	                      |	НачислениеЗарплатыЗатраты.Номенклатура,
	                      |	НачислениеЗарплатыЗатраты.Размер
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	НачислениеЗарплатыЗатраты.Ссылка,
	                      |	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница,
	                      |	МАКСИМУМ(НАЧАЛОПЕРИОДА(НачислениеЗарплатыЗатраты.Дата, ДЕНЬ)),
	                      |	НачислениеЗарплатыЗатраты.ВидНачисления,
	                      |	НачислениеЗарплатыЗатраты.Сотрудник,
	                      |	НачислениеЗарплатыЗатраты.Номенклатура,
	                      |	НачислениеЗарплатыЗатраты.План,
	                      |	СУММА(НачислениеЗарплатыЗатраты.Факт),
	                      |	НачислениеЗарплатыЗатраты.База,
	                      |	НачислениеЗарплатыЗатраты.Размер,
	                      |	СУММА(НачислениеЗарплатыЗатраты.Сумма)
	                      |ИЗ
	                      |	Документ.НачислениеЗарплаты.Затраты КАК НачислениеЗарплатыЗатраты
	                      |ГДЕ
	                      |	НачислениеЗарплатыЗатраты.Ссылка.Проведен = ИСТИНА
	                      |	И НачислениеЗарплатыЗатраты.Ссылка В(&МассивОбъектов)
	                      |	И НачислениеЗарплатыЗатраты.ВидНачисления.ТипНачисленияУдержания = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийУдержаний.Оклад)
	                      |
	                      |СГРУППИРОВАТЬ ПО
	                      |	НачислениеЗарплатыЗатраты.Ссылка,
	                      |	НачислениеЗарплатыЗатраты.Ссылка.СтруктурнаяЕдиница,
	                      |	НачислениеЗарплатыЗатраты.ВидНачисления,
	                      |	НачислениеЗарплатыЗатраты.Сотрудник,
	                      |	НачислениеЗарплатыЗатраты.Номенклатура,
	                      |	НачислениеЗарплатыЗатраты.План,
	                      |	НачислениеЗарплатыЗатраты.База,
	                      |	НачислениеЗарплатыЗатраты.Размер
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	НачислениеЗарплатыЗатраты.Сотрудник,
	                      |	Дата,
	                      |	НачислениеЗарплатыЗатраты.ВидНачисления");
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Не Выборка.Следующий() Тогда
		Область = Макет.ПолучитьОбласть("Заголовок"); 
		ТабличныйДокумент.Вывести(Область); 
	Иначе
		Пока Выборка.СледующийПоЗначениюПоля("Сотрудник") Цикл
			
			Область = Макет.ПолучитьОбласть("Заголовок");
			Область.Параметры.Заполнить(Выборка);
			Область.Параметры.РасчетнаяДата = "с: " + Формат(Выборка.Ссылка.ДатаНачалаПериода, "ДФ=dd.MM.yy") + " по: " + Формат(Выборка.Ссылка.ДатаОкончанияПериода, "ДФ=dd.MM.yy");
			ТабличныйДокумент.Вывести(Область);
			
			Область = Макет.ПолучитьОбласть("Шапка");
			ТабличныйДокумент.Вывести(Область);
			
			СуммаНачисленияИтого = 0;
			СуммаУдержанияИтого = 0;
			ПредыдущаяДата = Дата(01, 01, 01);
			
			ВыборкаПоДате = Выборка;
			Пока ВыборкаПоДате.СледующийПоЗначениюПоля("Дата") Цикл
				
				НомерСтрокиТаблицыС = ТабличныйДокумент.ВысотаТаблицы;
				
				ВыборкаДетально = ВыборкаПоДате;
