// Процедура, обработчик события "ОбработкаЗаполнения"
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") и ДанныеЗаполнения.Свойство("СтруктурнаяЕдиница") Тогда
		СтруктурнаяЕдиница   = ДанныеЗаполнения.СтруктурнаяЕдиница;
	Иначе
		СтруктурнаяЕдиница	 = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; 		
	КонецЕсли;
	Наименование = Формат(НачалоСмены,"ДФ=ЧЧ:мм; ДП=00:00") + " - " + Формат(ОкончаниеСмены,"ДФ=ЧЧ:мм; ДП=23:59");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция проверяет наличие аналогичных периодов.
//
Функция ПроверитьНаличиеАналогичногоПериода()
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	ПериодыРаботы.Ссылка
	                      |ИЗ
	                      |	Справочник.ПериодыРаботы КАК ПериодыРаботы
	                      |ГДЕ
	                      |	ПериодыРаботы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                      |	И ПериодыРаботы.НачалоСмены = &НачалоСмены
	                      |	И ПериодыРаботы.ОкончаниеСмены = &ОкончаниеСмены
	                      |	И ПериодыРаботы.Ссылка <> &Ссылка");
						  
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("НачалоСмены", НачалоСмены);
	Запрос.УстановитьПараметр("ОкончаниеСмены", ОкончаниеСмены);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Возврат Результат.Следующий();
	
КонецФункции

#КонецОбласти