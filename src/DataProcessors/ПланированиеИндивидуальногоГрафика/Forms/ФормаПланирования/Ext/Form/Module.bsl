&НаКлиенте
// Процедура - После закрытия формы создания оповещение
// 
// Параметры:
//  РезультатПланирования	 - 	 - 
//  ДопПараметры			 - 	 - 
// 
Процедура ПослеЗакрытияФормыСозданияОповещение(Результат, ДопПараметры) Экспорт
	
	НСтроки                = 0;
	ЗадаватьВопрос         = Истина;
	РезультатВопроса       = Неопределено;
	РезультатПланирования  = Неопределено;
	Если ТипЗнч(ДопПараметры) = Тип("Структура")
		И ДопПараметры.Свойство("РезВопроса") Тогда
		
		РезультатВопроса      = Результат;
		РезультатПланирования = ДопПараметры.РезультатПланирования;
		НСтроки               = ДопПараметры.НСтроки;		
		Если ЗначениеЗаполнено(РезультатВопроса) Тогда
			ЗадаватьВопрос = НЕ РезультатВопроса.ДляВсех;
		КонецЕсли;
	Иначе
		РезультатПланирования = Результат;
	КонецЕсли;
	
	Если РезультатПланирования <> Неопределено Тогда
		  		
		// Проверка наложения новых рабочих интервалов, на существующие интервалы
		Пока НСтроки < РезультатПланирования.Количество() Цикл
			
			СтрокаРЗ = РезультатПланирования[НСтроки];
			// Ищем существующее рабочее время на указанную дату
			НайденныеСтроки = БуферФормирования.НайтиСтроки(Новый Структура("Дата, Сотрудник, Операция", СтрокаРЗ.Дата, СтрокаРЗ.Сотрудник, ""));
			Если НайденныеСтроки.Количество() > 0 Тогда
				Для Каждого СтрокаБуфера ИЗ НайденныеСтроки Цикл   					
					Если РезультатВопроса <> Неопределено Тогда
						// Ответ Нет
						Если РезультатВопроса = Неопределено ИЛИ РезультатВопроса.Ответ = КодВозвратаДиалога.Нет Тогда
							РезультатПланирования.Удалить(НСтроки);
							НСтроки = НСтроки - 1;
							
							Если ЗадаватьВопрос = Истина Тогда
								РезультатВопроса = Неопределено;
							КонецЕсли;
							
							Продолжить;
						// Да	
						ИначеЕсли РезультатВопроса.Ответ = КодВозвратаДиалога.Да Тогда
							// Да, Для всех
							Если РезультатВопроса.ДляВсех = Истина Тогда
								НСтроки = РезультатПланирования.Количество();
							КонецЕсли;
							
							Прервать;
						КонецЕсли;
						
						Если ЗадаватьВопрос = Истина Тогда
							РезультатВопроса = Неопределено;
						КонецЕсли;
					Иначе	
						Если ЗадаватьВопрос = Истина Тогда
							// Если это существующее рабочее время, задать вопро о его замене
							ТВопроса = "Для сотрудника " + ПредставлениеЗначенияПараметраЗанятия(СтрокаБуфера, "Сотрудник") 
							+ " уже существует рабочее время на " + ПредставлениеЗначенияПараметраЗанятия(СтрокаБуфера, "ДатаВремяРаботы")
							+ Символы.ПС + Символы.ПС + "Заменить его?"; 
							
							ДопПараметры = Новый Структура("РезВопроса,НСтроки,РезультатПланирования", Истина, НСтроки,РезультатПланирования);
							Оповещение   = Новый ОписаниеОповещения("ПослеЗакрытияФормыСозданияОповещение", ЭтаФорма, ДопПараметры); 
							ОткрытьФорму("Обработка.ПланированиеИндивидуальногоГрафика.Форма.ФормаДиалогаВопроса",Новый Структура("Вопрос",ТВопроса),ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
							Возврат;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;	 	 
			КонецЕсли;
			
			НСтроки = НСтроки + 1;
		КонецЦикла;
		
		ФлагПроверки = Истина;
		Для Каждого СтрокаРЗ Из РезультатПланирования Цикл
			
			ВизитыВходятВИнтервалыРабот = ПроверитьВизитыВходятВИнтервалыРабот(СтрокаРЗ.Сотрудник, СтрокаРЗ.Дата, ОтборСтруктурнаяЕдиница, СтрокаРЗ.ИнтервалыРаботы);   			
			
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("РезультатПланирования" , РезультатПланирования);
			
			Если НЕ ВизитыВходятВИнтервалыРабот Тогда
				Если ТипЗнч(СтрокаРЗ.ИнтервалыРаботы) = Тип("СписокЗначений") И СтрокаРЗ.ИнтервалыРаботы.Количество() > 0 Тогда
					ФлагПроверки = Ложь;
					Оповещение = Новый ОписаниеОповещения("ГрафикПериодовРаботыТабДокВыборПродолжить", ЭтотОбъект, СтруктураПараметров);
					ПоказатьВопрос(Оповещение, "У сотрудника " + СтрокаРЗ.Сотрудник + " " + Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ")+ " запланированы визиты, не входящие в выбранные смены. Продолжить?", РежимДиалогаВопрос.ДаНетОтмена);			
				Иначе
					ФлагПроверки = Ложь;
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У сотрудника " + СтрокаРЗ.Сотрудник + " " + Формат(СтрокаРЗ.Дата, "ДЛФ = ДДММГГ")+ " запланированы визиты. Удаление интервала невозможно.");			
				КонецЕсли;
			КонецЕсли;	

		КонецЦикла;
		
		Если ФлагПроверки Тогда
			ДополнитьБуферНовымиДаннымиПланирования(РезультатПланирования);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

