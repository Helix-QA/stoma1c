		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПриемЛечение.Ссылка КАК ДокументСРекламацией,
	ПриемЛечение.Номенклатура КАК Номенклатура,
	ПриемЛечение.Рекламация КАК ДокументОснования,
	ПриемЛечение.Ссылка.Контрагент КАК Контрагент,
	ПриемЛечение.Зуб КАК Зуб,
	ПриемЛечение.КоличествоУпаковок КАК Количество,
	ПриемЛечение.Сотрудник КАК Врач,
	ПриемЛечение.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
ИЗ
	Документ.Прием.Лечение КАК ПриемЛечение
ГДЕ
	ПриемЛечение.Рекламация &lt;&gt; ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	И ПриемЛечение.Ссылка.Проведен
{ГДЕ
	(ВЫБОР
			КОГДА НЕ &amp;НачалоПериода ЕСТЬ NULL
					ИЛИ &amp;НачалоПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ПриемЛечение.Ссылка.Дата &gt;= &amp;НачалоПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ),
	(ВЫБОР
			КОГДА НЕ &amp;КонецПериода ЕСТЬ NULL
					ИЛИ &amp;КонецПериода &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ПриемЛечение.Ссылка.Дата &lt;= &amp;КонецПериода
			ИНАЧЕ ИСТИНА
		КОНЕЦ)}</query>
	</dataSet>
