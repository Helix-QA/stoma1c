// Процедура - Установить свойства кнопкам таблицы сортировки KPI
//
Процедура УстановитьСвойстваКнопкамТаблицыСортировкиKPI(ИмяГруппаРодитель)
	
	Для Каждого ПодчиненныйЭлемент Из Элементы[ИмяГруппаРодитель].ПодчиненныеЭлементы Цикл 
		Если ТипЗнч(ПодчиненныйЭлемент) = Тип("КнопкаФормы") Тогда 
			Если СтрНайти(ПодчиненныйЭлемент.ИмяКоманды, "РежимВывода") <> 0 Тогда
				ПодчиненныйЭлемент.Пометка = СтрСоединить(СтрРазделить(ПодчиненныйЭлемент.ИмяКоманды, СтрСоединить(СтрРазделить(ПодчиненныйЭлемент.ИмяКоманды, "0123456789")))) = ?(ИмяГруппаРодитель = "ТаблицаСортировкиПоказателейВиджетовГруппаКнопок", Строка(КоличествоКолонокДляВыводимыхВиджетов), Строка(КоличествоКолонокДляВыводимыхВиджетовKPI));
				ПодчиненныйЭлемент.ЦветТекста = ?(ПодчиненныйЭлемент.Пометка, Новый Цвет(0, 150, 70), Новый Цвет(77, 77, 77));
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

