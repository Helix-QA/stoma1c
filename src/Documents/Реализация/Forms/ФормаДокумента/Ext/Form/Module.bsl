	// Закладка подарки
	Если ЭтаФорма.Элементы.Найти("Группа_Кнопки_Подарки") <> Неопределено Тогда	
	
		Если Объект.Подарки.Количество() > 0 Тогда
			ЭтаФорма.Элементы.Группа_Кнопки_Подарки.Видимость = Истина;
