&НаСервере 
// Процедура - Выбор фильтров истории взаимодействия завершение.
//
// Параметры:
//  Результат	 - 	 - 
//  Параметры	 - 	 - 
//
Процедура ВыборФильтровИсторииВзаимодействияЗавершение(Результат, Параметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	СписокФильтрацииИсторииВзаимодействия = Результат;	
	
	Если НЕ Объект.Ссылка.Пустая() Тогда		
		СформироватьИсториюВзаимодействияСКлиентом();
	КонецЕсли;
	
	ФильтрПрименен = ФильтрПрименен(СписокФильтрацииИсторииВзаимодействия);	
	Элементы.ОчиститьФильтры.Видимость	= ФильтрПрименен;
	Элементы.ПоказатьФильтры.Картинка	= ?(ФильтрПрименен, БиблиотекаКартинок.ФильтрУстановлен, БиблиотекаКартинок.ФильтрНеУстановлен);
	
	ОбщегоНазначения.ХранилищеСистемныхНастроекСохранить("Справочники.Контрагенты.Форма.ФормаЭлементаКлиенты", "НастройкиФильтрации", СписокФильтрацииИсторииВзаимодействия);
		
КонецПроцедуры

