#Область СобытияФормы

&НаСервере
// Процедура - обработчик события "ПриСозданииНаСервере"
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ТипЗаменяемойСтроки"	 		, ТипЗаменяемойСтроки);
	Параметры.Свойство("ЗаменяемоеЗначение"		 		, ЗаменяемоеЗначение);
	Параметры.Свойство("ТипЗначенияЗамены"		 		, ТипЗначенияЗамены);
	Параметры.Свойство("ЗначениеЗамены"			 		, ЗначениеЗамены);
	Параметры.Свойство("ФорматЗначенияЗамены"	 		, ФорматЗначенияЗамены);
	Параметры.Свойство("ТипРеквизитаЗамены"		 		, ТипРеквизитаЗамены);
	Параметры.Свойство("ШаблонФайла"			 		, ШаблонФайла);
	Параметры.Свойство("КэшСписокаПолей"		 		, КэшСписокаПолей);
	Параметры.Свойство("ТипЗаменыПустогоЗначения"		, ТипЗаменыПустогоЗначения);
	Параметры.Свойство("ЗначениеЗаменыНезаполненного"	, ЗначениеЗаменыНезаполненного);
	Параметры.Свойство("КоличествоСимволовПрочерков" 	, КоличествоСимволовПрочерков);
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();

КонецПроцедуры

&НаКлиенте
