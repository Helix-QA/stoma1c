	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - Сохранить скопированное или вырезанное событие
//
Процедура СохранитьСкопированноеИлиВырезанноеСобытие(КопируемоеСобытие, Перенести = Ложь, ДопПараметры)

	Документы.Событие.ВставитьСкопированнуюИлиВырезаннуюПредварительнуюЗапись(КопируемоеСобытие, Перенести, ДопПараметры);
	
КонецПроцедуры

&НаСервере
// Процедура - Получить доступных для отбора сотрудников.
// 
// Параметры:
//  КонецПериода	 - 	 -
//  НачалоПериода	 - 	 -
//  ОтборДолжности	 - 	 -
// 
Функция ПолучитьДоступныхДляОтбораСотрудников(Знач НачалоПериода, Знач КонецПериода)
	
	МассивСотрудников      = Новый Массив;
	//МассивРольПользователя = Новый Массив;
    //МассивРольПользователя.Добавить(Перечисления.РольПользователя.МастерСалонаКрасоты);
	
	Если ЭтотОбъект.ПЗОтборПоСотрудникамРежимФильтра = Истина Тогда
		
		МассивСотрудников = РегистрыСведений.ВремяРаботыСотрудниковПлан.СотрудникиРаботающиевУказанныйПериод(
			НачалоПериода,
			?(КонецПериода = КонецДня(КонецПериода), КонецПериода + 1, КонецПериода),
			Объект.СтруктурнаяЕдиница);
		
	Иначе
		
		МассивСотрудников = Справочники.Сотрудники.ПолучитьСотрудниковСтруктурнойЕдиницы(
			Объект.СтруктурнаяЕдиница,,,
			НачалоПериода,
			Ложь);
		
	КонецЕсли;
	
	// Получаем сотрудникв уже задействованных в визитах.
	СотрудникиИзСобытий = Документы.Событие.ПолучитьСотрудниковИзСобытий(
		НачалоПериода,
		КонецПериода,,
		Объект.СтруктурнаяЕдиница);
	
	Если ЗначениеЗаполнено(СотрудникиИзСобытий) Тогда
		ОбщегоНазначения.ДобавитьВМассив(МассивСотрудников, СотрудникиИзСобытий, Истина);
	КонецЕсли;

	Возврат МассивСотрудников;
	
КонецФункции

&НаКлиенте
// Функция - Изменитьрежим отображения отмененных.
//
// Параметры:
//  Применить	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИзменитьрежимОтображенияОтмененных(Применить)
	
	РежимПросмотраОтмененных 							= Применить;
	Элементы.ОчиститьФильтр_СтатусОтмененные.Видимость 	= Применить;
	
	Элементы.АктивированныеЗначения_Фильтр_СтатусОтмененные.ЦветФона = ?(РежимПросмотраОтмененных, Новый Цвет(218, 230, 244), Новый Цвет());
	
	ОбновлениеСтраницыЖурналПредварительнойЗаписи(Ложь);

КонецФункции

&НаКлиенте
// Процедура, открывает лист ожидания пациентов.
//
Процедура ОткрытьЛистОжиданияПациентов(Сотрудник, ДатаЛистаОжидания = Неопределено, ПараметрыОткрытия = Неопределено, СоздаватьПриемПриЗаписи = Ложь)
	
	Если НЕ ЗначениеЗаполнено(ПараметрыОткрытия) Тогда
		ПараметрыОткрытия = Новый Структура;
	КонецЕсли;
	
	ПараметрыОткрытия.Вставить("Сотрудник", Сотрудник);
	ПараметрыОткрытия.Вставить("Дата", ?(ЗначениеЗаполнено(ДатаЛистаОжидания), НачалоДня(ДатаЛистаОжидания), НачалоДня(Объект.Дата)));
    ПараметрыОткрытия.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);	
	ПараметрыОткрытия.Вставить("СоздаватьПриемПриЗаписи", СоздаватьПриемПриЗаписи);
	
	Оповещение = Неопределено;
	Если СоздаватьПриемПриЗаписи Тогда		
		Оповещение = Новый ОписаниеОповещения("ОткрытьЛистОжиданияПациентовЗавершение", ЭтотОбъект, ПараметрыОткрытия); 
	КонецЕсли;
	
	ОткрытьФорму("РегистрСведений.ИнтервалыЛистаОжидания.Форма.ФормаСпискаУпрощенная", ПараметрыОткрытия,,,,, Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Открыть лист ожидания пациентов завершение.
//
Процедура ОткрытьЛистОжиданияПациентовЗавершение(Результат, ДопПараметры) Экспорт

	Если Результат = Неопределено ИЛИ ДопПараметры = Неопределено Тогда
		Возврат;				
	КонецЕсли;
	
	СоздатьСобытие(Новый Структура("КлиентДляОткрытия", Результат));
	
КонецПроцедуры

