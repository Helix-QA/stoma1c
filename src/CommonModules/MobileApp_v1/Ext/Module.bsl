// Функция, возвращает список структурных единиц.
// 
// Возвращаемое значение:
//   - 
// 
Функция GetClinics(Сотрудник) Экспорт
	
	МассивСтруктурныхЕдиниц  = Новый Массив;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НастройкиСотрудников.ДатаУвольнения КАК Значение,
	|	НастройкиСотрудников.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ ТаблицаДатыУвольнения
	|ИЗ
	|	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|ГДЕ
	|	НастройкиСотрудников.Сотрудник = &Сотрудник
	|	И НастройкиСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
	|	И НастройкиСотрудников.ДатаУвольнения <= &ТекущаяДата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.Представление КАК Представление
	|ИЗ
	|	Справочник.Сотрудники.ДоступныеСтруктурныеЕдиницы КАК СотрудникиДоступныеСтруктурныеЕдиницы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаДатыУвольнения КАК ТаблицаДатыУвольнения
	|		ПО СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = ТаблицаДатыУвольнения.СтруктурнаяЕдиница
	|ГДЕ
	|	СотрудникиДоступныеСтруктурныеЕдиницы.Ссылка = &Сотрудник
	|	И СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
	|	И СотрудникиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.ЭтоГруппа = ЛОЖЬ
	|	И ТаблицаДатыУвольнения.СтруктурнаяЕдиница ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПользователиДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница.Наименование");

	
	Запрос.УстановитьПараметр("Сотрудник"  , Сотрудник);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого МестоРаботы Из Результат Цикл
		
		СтруктураОтвета = Новый Структура;
		СтруктураОтвета.Вставить("Uid" , УникальныйИдентификатор(МестоРаботы.СтруктурнаяЕдиница));
		СтруктураОтвета.Вставить("Name", МестоРаботы.Представление);
		
		МассивСтруктурныхЕдиниц.Добавить(СтруктураОтвета);
		
	КонецЦикла;
	
	Возврат ПолучитьСтруктуруОтвета(МассивСтруктурныхЕдиниц);
	
КонецФункции

