	|	И РеквизитыСотрудников.Объект ССЫЛКА Справочник.Сотрудники
	|	И (ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|			ИЛИ ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	|	ТаблицаСотрудников.ВидЦен КАК ВидЦен,
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ПОМЕСТИТЬ ТаблицаУслуг
	|ИЗ
	|	ТаблицаСотрудников КАК ТаблицаСотрудников
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыОбъектов КАК РеквизитыНоменклатуры
	|			ПО УслугиСотрудника.СтруктурнаяЕдиница = РеквизитыНоменклатуры.СтруктурнаяЕдиница
	|				И УслугиСотрудника.Номенклатура = РеквизитыНоменклатуры.Объект
	|				И (РеквизитыНоменклатуры.Реквизит = ""ОнлайнЗапись"")
	|		ПО ТаблицаСотрудников.Сотрудник = УслугиСотрудника.Сотрудник
	|ГДЕ
	|	УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И УслугиСотрудника.Номенклатура.НормаВремени > 0
	|	И УслугиСотрудника.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И РеквизитыНоменклатуры.Значение = ИСТИНА
	|	И НЕ УслугиСотрудника.Номенклатура.ПометкаУдаления
	|	И &УсловиеМассивУслуг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаУслуг.Сотрудник КАК Сотрудник,
	|	ТаблицаУслуг.ВидЦен КАК ВидЦен,
	|	ТаблицаУслуг.Номенклатура КАК Номенклатура,
	|	ТаблицаУслуг.НормаВремени КАК НормаВремени
	|ПОМЕСТИТЬ ТабицаУслугВПродаже
	|ИЗ
	|	ТаблицаУслуг КАК ТаблицаУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыНоменклатуры.СрезПоследних(&ДатаСреза, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК СтатусыНоменклатурыСрезПоследних
	|		ПО ТаблицаУслуг.Номенклатура = СтатусыНоменклатурыСрезПоследних.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(СтатусыНоменклатурыСрезПоследних.ВПродаже, ИСТИНА) = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаУслуг.Сотрудник КАК Сотрудник,
	|	ТаблицаУслуг.Сотрудник.ПредставлениеДляОнлайнЗаписи КАК Наименование,
	|	ТаблицаУслуг.Сотрудник.Должность КАК Должность,
	|	ТаблицаУслуг.Сотрудник.Должность.Наименование КАК ДолжностьНаименование,
	|	ВЫРАЗИТЬ(ТаблицаУслуг.Сотрудник.ОписаниеДляСайтаHTML КАК СТРОКА(1000)) КАК ОписаниеДляСайтаHTML,
	|	ТаблицаУслуг.Сотрудник.APIВес КАК Вес,
	|	ТаблицаУслуг.Сотрудник.ФайлКартинки.Расширение КАК РасширениеФото,
	|	ТаблицаУслуг.Сотрудник.ФайлКартинки.Размер КАК РазмерФото,
	|	МИНИМУМ(ТаблицаУслуг.НормаВремени) КАК НормаВремени
	|ИЗ
	|	ТабицаУслугВПродаже КАК ТаблицаУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаСреза, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЦеныСрезПоследних
	|		ПО ТаблицаУслуг.Номенклатура = ЦеныСрезПоследних.Номенклатура
	|			И ТаблицаУслуг.ВидЦен = ЦеныСрезПоследних.ВидЦен
	|ГДЕ
	|	(ЕСТЬNULL(ЦеныСрезПоследних.Цена, 0) <> 0
	|			ИЛИ ТаблицаУслуг.Номенклатура.Бесплатно)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаУслуг.Сотрудник,
	|	ТаблицаУслуг.Сотрудник.ПредставлениеДляОнлайнЗаписи,
	|	ТаблицаУслуг.Сотрудник.Должность,
	|	ТаблицаУслуг.Сотрудник.Должность.Наименование,
	|	ВЫРАЗИТЬ(ТаблицаУслуг.Сотрудник.ОписаниеДляСайтаHTML КАК СТРОКА(1000)),
	|	ТаблицаУслуг.Сотрудник.APIВес,
	|	ТаблицаУслуг.Сотрудник.ФайлКартинки.Расширение,
	|	ТаблицаУслуг.Сотрудник.ФайлКартинки.Размер");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза"         , ДатаСреза);
	Запрос.УстановитьПараметр("МассивУслуг" 	  , МассивУслуг);
	
	УсловиеМассивУслуг = ?(ЗначениеЗаполнено(МассивУслуг), "И УслугиСотрудника.Номенклатура В(&МассивУслуг)", "");
	Запрос.Текст  	   = СтрЗаменить(Запрос.Текст, "И &УсловиеМассивУслуг", УсловиеМассивУслуг);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции
                            
// Функция, возвращает таблицу сотрудников с минимальной нормой времени.
// 
Функция ПолучитьСотрудниковСНормойВремени2(СтруктурнаяЕдиница, Сотрудник, МассивУслуг, ДатаСреза)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РеквизитыСотрудников.Объект КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА НастройкиСотрудников.ВидЦен = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.Розничная)
	|		ИНАЧЕ НастройкиСотрудников.ВидЦен
	|	КОНЕЦ КАК ВидЦен
	|ПОМЕСТИТЬ ТаблицаСотрудников
	|ИЗ
	|	РегистрСведений.РеквизитыОбъектов КАК РеквизитыСотрудников
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	|		ПО РеквизитыСотрудников.СтруктурнаяЕдиница = НастройкиСотрудников.СтруктурнаяЕдиница
	|			И РеквизитыСотрудников.Объект = НастройкиСотрудников.Сотрудник
	|ГДЕ
	|	НЕ РеквизитыСотрудников.Объект.ЭтоГруппа
	|	И НЕ РеквизитыСотрудников.Объект.ПометкаУдаления
	|	И РеквизитыСотрудников.Значение = ИСТИНА
	|	И РеквизитыСотрудников.Реквизит = ""ОнлайнЗаписьСотрудник""
	|	И РеквизитыСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И РеквизитыСотрудников.Объект ССЫЛКА Справочник.Сотрудники
	|	И &УсловиеСотрудник
	|	И (ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.Врач)
	|			ИЛИ ВЫРАЗИТЬ(РеквизитыСотрудников.Объект КАК Справочник.Сотрудники).Роль = ЗНАЧЕНИЕ(Перечисление.РольПользователя.ГлавныйВрач))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСотрудников.Сотрудник КАК Сотрудник,
	|	ТаблицаСотрудников.ВидЦен КАК ВидЦен,
	|	УслугиСотрудника.Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ПОМЕСТИТЬ ТаблицаУслуг
	|ИЗ
	|	ТаблицаСотрудников КАК ТаблицаСотрудников
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РеквизитыОбъектов КАК РеквизитыНоменклатуры
	|			ПО УслугиСотрудника.СтруктурнаяЕдиница = РеквизитыНоменклатуры.СтруктурнаяЕдиница
	|				И УслугиСотрудника.Номенклатура = РеквизитыНоменклатуры.Объект
	|				И (РеквизитыНоменклатуры.Реквизит = ""ОнлайнЗапись"")
	|		ПО ТаблицаСотрудников.Сотрудник = УслугиСотрудника.Сотрудник
	|ГДЕ
	|	УслугиСотрудника.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И УслугиСотрудника.Номенклатура.НормаВремени > 0
	|	И УслугиСотрудника.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|	И РеквизитыНоменклатуры.Значение = ИСТИНА
	|	И &УсловиеМассивУслуг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ПОМЕСТИТЬ ТаблицаЦен
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаСреза,
	|			Номенклатура В
	|					(ВЫБРАТЬ
	|						ТаблицаУслуг.Номенклатура
	|					ИЗ
	|						ТаблицаУслуг)
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЦеныНоменклатурыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ТаблицаУслуг.Сотрудник КАК Сотрудник,
	|	ТаблицаУслуг.Номенклатура КАК Номенклатура,
	|	ТаблицаУслуг.НормаВремени КАК НормаВремениПоСотруднику
	|ИЗ
	|	ТаблицаУслуг КАК ТаблицаУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаЦен КАК ТаблицаЦен
	|		ПО ТаблицаУслуг.Номенклатура = ТаблицаЦен.Номенклатура
	|			И ТаблицаУслуг.ВидЦен = ТаблицаЦен.ВидЦен
	|ГДЕ
	|	(ЕСТЬNULL(ТаблицаЦен.Цена, 0) <> 0
	|			ИЛИ ТаблицаУслуг.Номенклатура.Бесплатно)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НормаВремениПоСотруднику");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ДатаСреза"         , ДатаСреза);
	Запрос.УстановитьПараметр("МассивУслуг" 	  , МассивУслуг);
	Запрос.УстановитьПараметр("МассивСотрудников" , Сотрудник);
	
	УсловиеСотрудник   = ?(ЗначениеЗаполнено(Сотрудник), " И РеквизитыСотрудников.Объект В (&МассивСотрудников) ", "");
	Запрос.Текст       = СтрЗаменить(Запрос.Текст, "И &УсловиеСотрудник", УсловиеСотрудник);
	
	УсловиеМассивУслуг = ?(ЗначениеЗаполнено(МассивУслуг), "И УслугиСотрудника.Номенклатура В(&МассивУслуг)", "");
	Запрос.Текст  	   = СтрЗаменить(Запрос.Текст, "И &УсловиеМассивУслуг", УсловиеМассивУслуг);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
