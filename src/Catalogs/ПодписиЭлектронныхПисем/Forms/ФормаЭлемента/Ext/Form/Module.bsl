&НаКлиенте 
// Процедура вставляет текст в поле.
//
Процедура ВставитьТекстВПолеHTML(Текст)
	
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
		
	Если ИмяАктивногоЭлемента = "Приветствие" Тогда
		HTMLДокумент = Элементы.Приветствие.Документ;
	ИначеЕсли ИмяАктивногоЭлемента = "Подпись" Тогда 
		HTMLДокумент = Элементы.Подпись.Документ;
	КонецЕсли;
	
	Попытка
		Выделение = HTMLДокумент.selection.createRange();
		Выделение.pasteHTML(Текст);
	Исключение
		Выделение = HTMLДокумент.getSelection().getRangeAt(0);
		Если Выделение <> Неопределено Тогда
			Узел = Выделение.createContextualFragment(Текст);
			Выделение.insertNode(Узел);         
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте 
// Процедура устанавливает активный элемент.
//
Процедура УстановитьАктивныйЭлементHTML()
	
	ИмяАктивногоЭлемента = ?(Элементы.ГруппаПриветствия.Видимость = Истина, Элементы.ГруппаПриветствия.Заголовок, Элементы.ГруппаПодписи.Заголовок);
	
	ЭтаФорма.ТекущийЭлемент = Элементы[ИмяАктивногоЭлемента];
	Документ = Элементы[ИмяАктивногоЭлемента].Документ;
	
КонецПроцедуры

