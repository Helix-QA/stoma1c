 
#Область ОписаниеПеременных 
 
&НаКлиенте
Перем ПерваяСсылкаВСпикеПодбораНоменклатуры;
&НаКлиенте
Перем ТаблицаЛечениеИзмененаСуммаСтроки;
&НаКлиенте
Перем ФильтрУслугИспользован;
&НаКлиенте
Перем ИскомыйКлиент;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере"
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщиеПараметры = Новый Структура;
	ОбщиеПараметры.Вставить("Перечисление_Зубы_ВсяПолость", ПредопределенноеЗначение("Перечисление.Зубы.ВсяПолость"));
	
	ИспользуетсяРасширениеМессенджер = ОбщегоНазначенияСтоматология.ИспользуетсяРасширение("Мессенджер");	
	
	РедактированиеРазрешено = (Объект.Статус <> Перечисления.СтатусыПланЛечения.Принят И Объект.Статус <> Перечисления.СтатусыПланЛечения.Закрыт)
								ИЛИ РольДоступна("ПолныеПрава") ИЛИ РольДоступна("АдминистраторСистемы");
	
	РаботаСДиалогами.УстановитьДоступностьЭлементовФормДокументаПоПравамПользователя(ЭтаФорма, Объект);
	// Получаем вид цены
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ВидЦен = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
	КонецЕсли;
	РежимРаботыЕдинаяСеть           = Константы.РежимРаботыСетиСтоматологий.Получить() = Перечисления.РежимРаботыСетиСтоматологий.ЕдинаяСеть; 	
	Статус                          = Объект.Статус;
	ЭтоСтоматологическиеУслуги      = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник);   
	УстановитьОтборСегментНоменклатуры(Объект.ПолисМедСтрахования,Объект.СтруктурнаяЕдиница,объект.Сотрудник);	
	ВидЦеныПред                     = Объект.ВидЦен;
	ТипЗубнойФормулы        	    = Объект.Контрагент.ТипЗубнойФормулы;
	ПредВыбранныйКонтрагент 	    = Объект.Контрагент;
	ПредВыбранныйСтраховойПолис     = Объект.ПолисМедСтрахования; 
	НомерПриемаПодбор               = "0";
	ЭтотОбъект._ПодборДоговорПолиса = ВернутьДоговорПоПолису(Объект.ПолисМедСтрахования);	
	ОткрыватьПодбор                 = Истина;
	// Элементы.НомерПриемаВсе.Пометка = Истина;	
	Элементы.ГруппаНомерПриема_Все.ЦветФона = Новый Цвет(25 , 116, 206);
	Элементы.ГруппаНомерПриема_Все.ПодчиненныеЭлементы[0].ЦветТекста = Новый Цвет(255 , 255, 255);
	
	Если Не ЗначениеЗаполнено(Объект.Касса) Тогда
		ЗначениеНастройки = ПользователиСтоматология.ПолучитьЗначениеПоУмолчаниюПользователя(Объект.АвторДокумента, "ОсновнаяКасса", Объект.СтруктурнаяЕдиница);	
		Объект.Касса      = ?(ЗначениеЗаполнено(ЗначениеНастройки), ЗначениеНастройки, Объект.СтруктурнаяЕдиница.ОсновнаяКасса);	
	КонецЕсли;
	ПараметрыВидаЦены = Новый Структура;
	ПараметрыВидаЦены.Вставить("ПорядокОкругления"       , Объект.ВидЦен.ПорядокОкругления);
	ПараметрыВидаЦены.Вставить("ОкруглятьВБольшуюСторону", Объект.ВидЦен.ОкруглятьВБольшуюСторону);
	
	СоздатьМенюУправленияТабличнымиЧастями();
	
	HTML = ПолучитьОбщийМакет("HTMLДокумент").ПолучитьТекст();
	НастройкаФормыСервер("ПРИ_ЗАПУСКЕ");
	СотрудникПред = Объект.Сотрудник;
	
	// Открывает доступ к колонке %ручной скидки
	ИнициализацияДоступаКРучнойСкидке();
	//
	//ДополнительныеПараметры = Новый Структура;
	//ДополнительныеПараметры.Вставить(Объект);
	//ДополнительныеПараметры.Вставить("ГруппаДополнительнаяИнформация");
	//ДополнительныеПараметры.Вставить("ИмяЭлементаКоманднойПанели", "ФормаГруппаПодменюДополнительныеРеквизиты");
	
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтаФорма, Объект, "ФормаГруппаПодменюДополнительныеРеквизиты");
	
	ОбновитьЗаголовкиТабЧастейНаСервере();
	
	// Установка реквизитов формы.
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда	
		Если Не Объект.Ссылка.Пустая() Тогда
			ЭтотОбъект.ДанныеВнешнихСистемМессенджера = ПолучитьДоступныеВнешниеСистемыМессенджера(Объект.Контрагент, Объект.СтруктурнаяЕдиница);
		КонецЕсли;	
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() 
		И Объект.Лечение.Количество() > 0 Тогда
		ПересчитатьАвтоматическиеСкидки();
	Иначе
		ПроставитьТипСкидкиНаценки();
		ЗаполнитьВирутальныеРеквизитыПодарков();
		ЗаполнитьТЧДоступныеОплатыБонусами();
		УстановитьВидимостьЭлементов();
	КонецЕсли;   
	
	ОтобразитьИнформациюПоОплате();
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
		РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);		
	КонецЕсли;  
	
	// Настройки сортировки подбора.	
	ЗаполнитьНастройкиПодбораНоменклатуры();
	
	// Подбор
	ОтборМассивРазрешенныхТипов     = Новый Массив;	
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Услуга);
	ОтборМассивРазрешенныхТипов.Добавить(Перечисления.ТипыНоменклатуры.Набор);
	ОбработкаТабличныхЧастейКлиент.СоздатьДинамическийСписокПодбораНоменклатур(ЭтаФорма, Объект, "ГруппаПодборУслуги", 
	ОтборМассивРазрешенныхТипов, Ложь,, Истина,,Истина, ЗначениеЗаполнено(ЭтотОбъект._ПодборДоговорПолиса)); 
	
	ТаблицаПодборУслуг = Элементы.Найти("_ПодборНоменклатурУслуги");	
	Если НЕ ТаблицаПодборУслуг = Неопределено Тогда	
		
		ТаблицаПодборУслуг.ПоложениеСтрокиПоиска = ПоложениеСтрокиПоиска.Нет;
		Элементы.КнопкаНастройкиПодбораУслуг.Видимость = Истина;
		Элементы.ГруппаЛечениеНастройкиПодбора.Видимость = Истина;
		Элементы.СтрокаПоискаПодборУслуг.Видимость = Истина;
		
	КонецЕсли;

	ЗаполнитьПараметрыВыбораСтруктурныхЕдиниц();
	
	МаксимальнаяРучнаяСкидка = РегистрыСведений.НастройкиСотрудников.ПолучитьМаксимальнуюСкидкуСотрудника(ПараметрыСеанса.АвторизованныйПользователь.Сотрудник, Объект.СтруктурнаяЕдиница);
	СсылкиНаОплатуИСБП.ОбновитьИнформациюПоИспользованиюСсылкиНаОплату(ЭтаФорма);
	
КонецПроцедуры

// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = Истина;	
	Иначе
		Элементы.ГруппаСостояниеОбъекта.Видимость = Ложь;	
	КонецЕсли; 
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

// Процедура - После записи на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	РаботаСДиалогами.УстановитьСостояниеОбъекта(ЭтаФорма, Объект.ПометкаУдаления, Объект.Проведен);  
	
	Если ЗначениеЗаполнено(ТекущийОбъект.Контрагент) И
		(СтатусыЗубов.Количество() > 0 ИЛИ СостоянияЗубов.Количество() > 0) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ЗубнаяФормула.Период
		|ИЗ
		|	РегистрСведений.ЗубнаяФормула КАК ЗубнаяФормула
		|ГДЕ
		|	ЗубнаяФормула.Прием = &Прием";
		Запрос.УстановитьПараметр("Прием",ТекущийОбъект.Ссылка); 
		Результат = Запрос.Выполнить().Выгрузить();
		Если Результат.Количество() > 0 Тогда
			НаборЗаписей = РегистрыСведений.ЗубнаяФормула.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Период.Установить(Результат[0].Период);
			НаборЗаписей.Отбор.Контрагент.Установить(ТекущийОбъект.Контрагент);
			НаборЗаписей.Записать();
		КонецЕсли;
		
		мЗапрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗубнаяФормулаСрезПоследних.Зуб КАК Зуб,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы КАК Состояние,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Цвет КАК Цвет,
		|	ЗубнаяФормулаСрезПоследних.Область КАК Область,
		|	ВЫБОР
		|		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		|			ТОГДА ""0""
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Удален)
		|					ТОГДА ""1""
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Штифт)
		|							ТОГДА ""2""
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Абатмент)
		|									ТОГДА ""3""
		|								ИНАЧЕ ""4""
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	КОНЕЦ КАК СтатусЗуба
		|ИЗ
		|	РегистрСведений.ЗубнаяФормула.СрезПоследних(&Дата, Контрагент = &Контрагент) КАК ЗубнаяФормулаСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗубнаяФормулаСрезПоследних.Зуб,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Цвет,
		|	ЗубнаяФормулаСрезПоследних.Область,
		|	ВЫБОР
		|		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		|			ТОГДА ""0""
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Удален)
		|					ТОГДА ""1""
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Штифт)
		|							ТОГДА ""2""
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Абатмент)
		|									ТОГДА ""3""
		|								ИНАЧЕ ""4""
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	КОНЕЦ");
		мЗапрос.УстановитьПараметр("Контрагент", ТекущийОбъект.Контрагент);					
		мЗапрос.УстановитьПараметр("Дата", ТекущийОбъект.Дата); 
		
		ТаблицаСостояний = мЗапрос.Выполнить().Выгрузить();
		
		НаборЗаписей = РегистрыСведений.ЗубнаяФормула.СоздатьНаборЗаписей();	
		// НаборЗаписей.Отбор.Прием.Установить(ТекущийОбъект.Ссылка);
		
		НаборЗаписей.Отбор.Период.Установить(ТекущийОбъект.Дата);
		НаборЗаписей.Отбор.Контрагент.Установить(ТекущийОбъект.Контрагент);
		мТаблица = Новый ТаблицаЗначений;
		мТаблица = НаборЗаписей.ВыгрузитьКолонки();
		
		Для Каждого СтрокаТЧ из СтатусыЗубов Цикл			  
			НайденныеСостояния = СостоянияЗубов.НайтиСтроки(Новый Структура("Зуб, СтатусЗуба", СтрокаТЧ.Зуб, СтрокаТЧ.СтатусЗуба));
			Если НайденныеСостояния.Количество() > 0 Тогда 				
				Для Каждого СтрокаМассива из НайденныеСостояния Цикл
					
					мНайденныеСтроки = ТаблицаСостояний.НайтиСтроки(Новый Структура("Зуб, Состояние, Область, СтатусЗуба", СтрокаТЧ.Зуб,СтрокаМассива.Состояние,СтрокаМассива.Область, СтрокаТЧ.СтатусЗуба));
					Если мНайденныеСтроки.Количество() > 0 Тогда
						Продолжить;
					КонецЕсли;     					
					
					НоваяСтрока = мТаблица.Добавить();
					НоваяСтрока.Период = ТекущийОбъект.Дата;
					НоваяСтрока.Контрагент = ТекущийОбъект.Контрагент;
					НоваяСтрока.СтруктурнаяЕдиница = ТекущийОбъект.СтруктурнаяЕдиница;
					НоваяСтрока.Зуб = СтрокаТЧ.Зуб;
					НоваяСтрока.Прием = ТекущийОбъект.Ссылка;
					НоваяСтрока.СостояниеЗуба = Перечисления.СостояниеЗуба[Число(СтрокаТЧ.СтатусЗуба)];
					НоваяСтрока.Область = СтрокаМассива.Область;
					НоваяСтрока.СостояниеЗубнойФормулы = СтрокаМассива.Состояние;
					НоваяСтрока.ТипЗубнойФормулы = ТипЗубнойФормулы;
				КонецЦикла;
			Иначе
				мНайденныеСтроки = ТаблицаСостояний.НайтиСтроки(Новый Структура("Зуб, СтатусЗуба", СтрокаТЧ.Зуб, СтрокаТЧ.СтатусЗуба));
				Если мНайденныеСтроки.Количество() > 0 Тогда
					Продолжить;
				КонецЕсли;  
				НоваяСтрока = мТаблица.Добавить();
				НоваяСтрока.Период = ТекущийОбъект.Дата;
				НоваяСтрока.Контрагент = ТекущийОбъект.Контрагент;
				НоваяСтрока.СтруктурнаяЕдиница = ТекущийОбъект.СтруктурнаяЕдиница;				  
				НоваяСтрока.Зуб = СтрокаТЧ.Зуб;				
				НоваяСтрока.Прием = ТекущийОбъект.Ссылка;
				НоваяСтрока.СостояниеЗуба = Перечисления.СостояниеЗуба[Число(СтрокаТЧ.СтатусЗуба)];	
				НоваяСтрока.ТипЗубнойФормулы = ТипЗубнойФормулы;
			КонецЕсли;		 
		КонецЦикла;
		Если мТаблица.Количество() > 0 Тогда
			НаборЗаписей.Загрузить(мТаблица);
			НаборЗаписей.Записать(Истина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура обработчик события "ПриОткрытии" формы
//
Процедура ПриОткрытии(Отказ)
	
	// МеханизмВнешнегоОборудования
	Если МенеджерОборудованияКлиент.ОбновитьРабочееМестоКлиента() Тогда
		ОписаниеОшибки = "";
		
		ПоддерживаемыеТипыВО = Новый Массив();
		ПоддерживаемыеТипыВО.Добавить("СканерШтрихкода");
		ПоддерживаемыеТипыВО.Добавить("СчитывательМагнитныхКарт");
		
		Если Не МенеджерОборудованияКлиент.ПодключитьОборудованиеПоТипу(УникальныйИдентификатор, ПоддерживаемыеТипыВО, ОписаниеОшибки) Тогда
			ТекстСообщения = НСтр("ru = 'При подключении оборудования произошла ошибка:
			|""%ОписаниеОшибки%"".'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	// Конец МеханизмВнешнегоОборудования 		
	
	ОбновитьSVGПодбор();   
	
	// Обновить зубную формулу 
	ОбновитьДокумент();
	
	Для Каждого СтрокаТЧ Из Объект.Лечение	Цикл					
		СтрокаТЧ.Бесплатно = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.Номенклатура, "Бесплатно");
	КонецЦикла;
	
	Если Объект.ПометкаУдаления = Истина Тогда
		Элементы.ГруппаСостояниеОбъекта.Видимость = истина;	
	КонецЕсли;
	
	ЦветФона   = Новый Цвет(220, 220, 220); 

	// Установим сортировку подборов по полю из настроек.	
	ИзменитьСортировкуПодбора(ЭтотОбъект._ПодборНоменклатурУслуги, ЭтотОбъект.ПолеСортировкиУслуг, "Возр");

	Элементы.ТаблицаЛечение.Ширина		= ?(Элементы._ПодборНоменклатурУслуги.Видимость, 0, 151);
	Элементы.УслугиПодборЗубов.Ширина	= ?(Элементы._ПодборНоменклатурУслуги.Видимость, 1, 150);	
	
КонецПроцедуры

