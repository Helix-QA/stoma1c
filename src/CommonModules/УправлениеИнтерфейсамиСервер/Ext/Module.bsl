	ДекорацияКоличествоАктивированных.ГоризонтальноеПоложениеВГруппе 							= ГоризонтальноеПоложениеЭлемента.Лево;	
	ДекорацияКоличествоАктивированных.ГоризонтальноеПоложение 									= ГоризонтальноеПоложениеЭлемента.Лево;
	
	ГруппаКнопки_ВариантОтбора = Форма.Элементы.Добавить("Группа_ВариантОтбора_" + СтрокаФильтр.Наименование + "_" + ИдентификаторФильтра, Тип("ГруппаФормы"), Форма.Элементы[СтрокаФильтр.ИмяГруппыТипФильтра]);
	ГруппаКнопки_ВариантОтбора.Вид 														= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКнопки_ВариантОтбора.Заголовок 												= ГруппаКнопки_ВариантОтбора.Имя;
	ГруппаКнопки_ВариантОтбора.Отображение 												= ОтображениеОбычнойГруппы.Нет;
	ГруппаКнопки_ВариантОтбора.Группировка 												= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаКнопки_ВариантОтбора.ОтображатьЗаголовок 										= Ложь;
	ГруппаКнопки_ВариантОтбора.ЦветФона 												= Новый Цвет(218, 230, 244);	
	ГруппаКнопки_ВариантОтбора.ГоризонтальныйИнтервал 									= ИнтервалМеждуЭлементамиФормы.Половинный;
	ГруппаКнопки_ВариантОтбора.ГоризонтальноеПоложениеВГруппе 							= ГоризонтальноеПоложениеЭлемента.Право;
	ГруппаКнопки_ВариантОтбора.ВертикальноеПоложениеВГруппе 							= ВертикальноеПоложениеЭлемента.Центр;
	ГруппаКнопки_ВариантОтбора.ВертикальноеПоложениеПодчиненных 						= ВертикальноеПоложениеЭлемента.Центр;
	
	// Инструменты варианта отбора всех значений опеределенного фильтра
	КомандаТипФильтраВариантОтбора = Форма.Команды.Найти("ИзменитьВариантОтбора_ТипФильтра_" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра);
	Если КомандаТипФильтраВариантОтбора = Неопределено Тогда
		КомандаТипФильтраВариантОтбора 					= Форма.Команды.Добавить("ИзменитьВариантОтбора_ТипФильтра_" + СтрокаФильтр.Наименование + "_Идентификатор_" + ИдентификаторФильтра);
		КомандаТипФильтраВариантОтбора.Заголовок 		= КомандаТипФильтраВариантОтбора.Имя;
		КомандаТипФильтраВариантОтбора.Подсказка 		= "";
		КомандаТипФильтраВариантОтбора.Действие 		= "ОбработчикНажатияЭлементаФильтрацииДанных";
	КонецЕсли;
	
	КнопкаИзменитьВариантОтбора = Форма.Элементы.Добавить("КнопкаИзменитьВариантОтбора_" + СтрокаФильтр.Наименование + "_" + ИдентификаторФильтра, Тип("КнопкаФормы"), ГруппаКнопки_ВариантОтбора);
	КнопкаИзменитьВариантОтбора.ИмяКоманды 							= КомандаТипФильтраВариантОтбора.Имя;
