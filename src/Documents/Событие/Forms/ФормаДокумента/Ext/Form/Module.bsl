// Процедура, обработка нажатия на виджет сделки.
//  
//  Описание: обрабаытвает нажатие на элемент формы, виджет сделки.
//  
//  
//  Параметры (название, тип, дифференцированное значение)
//
// Параметры:
//  ИмяКоманды	 - строка - имя выполненной команды.
//
Процедура ВыполнитьНажатиеНаВиджетСделки(ИмяКоманды)
	
	Если СтрНайти(ИмяКоманды, "КомандаОткрытьПродажу") Тогда 
		
		ИндексСтроки = ПолучитьИндексСтроки(ИмяКоманды);
		Реализация   = ЭтаФорма.ТаблицаСделок[ИндексСтроки].Прием;
		
		Если ЗначениеЗаполнено(Реализация) Тогда
			ПоказатьЗначение(,Реализация);
		КонецЕсли;
		
	Иначе
		
		Если СтрНайти(ИмяКоманды, "КомандаСделка") Тогда
			
			ИндексГурппы  = ПолучитьИндексСтроки(ИмяКоманды, Ложь);
			ИмяГруппыРодителя = Элементы["ГруппаТелоВиджета_" + ИндексГурппы].Родитель.Имя;
			СтрокаТаблицы = ЭтаФорма.ТаблицаСделок[ИндексГурппы];
			// Если НЕ ИмяГруппыРодителя = "ВиджетСделки" Тогда
				ПоказатьЗначение(,СтрокаТаблицы.Сделка);
				Возврат;
			// КонецЕсли;

		КонецЕсли;
		
		Врач = Неопределено;
		Если НЕ Объект.Услуги.Количество() = 0 Тогда 
			Врач = Объект.Услуги[0].Сотрудник;
		КонецЕсли;		
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент"	, Объект.Контрагент);
		ПараметрыФормы.Вставить("ВыбратьЭтап"	, СтрНайти(ИмяКоманды, "КомандаТекущийЭтап") > 0);
		ПараметрыФормы.Вставить("Врач"			, Врач);
		
		ИндексГурппы  = ПолучитьИндексСтроки(ИмяКоманды, Ложь);
		СтрокаТаблицы = ЭтаФорма.ТаблицаСделок[ИндексГурппы];
		ПараметрыФормы.Вставить("Сделка", СтрокаТаблицы.Сделка);
		
		ОткрытьФорму("Справочник.Сделки.Форма.ФормаВиджета", ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

