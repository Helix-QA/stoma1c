// Функция - Roistat GET.
//
Функция RoistatGET(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		    
		// Логирование
		ЛогироватьСобытие = Константы.ЛогироватьHTTP.Получить();	
		
		Если ЛогироватьСобытие > 0 Тогда
			ВремяНачалаОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
			UIDЗапроса     = Новый УникальныйИдентификатор();
			HTTPЗапросЛога = Запрос;
			ДатаЛога       = ТекущаяДатаСеанса();
			ТипЗапроса     = Перечисления.HTTPСервисы.Analytics;
			HTTPШаблон     = "Roistat";
		КонецЕсли;
		//\\
		
		// Получение информации о статусах
		Если Запрос.ПараметрыЗапроса.Получить("action")= "import_scheme" Тогда 
			
			Ответ = Новый HTTPСервисОтвет(200);	
			Ответ.Заголовки.Вставить("Content-Type", "application/json;  charset=utf-8");
			Ответ.УстановитьТелоИзСтроки(ПолучитьJsonСтруктуруСхемыИмпорта(), КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
			
			// Логирование
			Если ЛогироватьСобытие > 0 Тогда
				
				ВремяОкончанияОперации = ТекущаяУниверсальнаяДатаВМиллисекундах();
				ВремяВыполнения        = (ВремяОкончанияОперации - ВремяНачалаОперации)/1000;
				СтатусСобытия 		   = Перечисления.СтатусыЗапросов.Выполнен;						
				мОтвет                 = Ответ.ПолучитьТелоКакСтроку();
				
				Если ОбщегоНазначения.ВыполнитьЛогированиеЗапроса(ЛогироватьСобытие, СтатусСобытия, ВремяВыполнения) Тогда
					
					РегистрыСведений.ЖурналЗапросов.ЛогироватьЗапрос(
					HTTPЗапросЛога, 
					ДатаЛога, 
					UIDЗапроса, 
					ТипЗапроса, 
					HTTPШаблон, 
					СтатусСобытия, 
					ВремяВыполнения, 
					, 
					, 
					мОтвет, 
					, 
					,
					200); 								
				КонецЕсли;
				
			КонецЕсли;
			
			Возврат Ответ;
			
			// Получение информации о сделках	
		ИначеЕсли Запрос.ПараметрыЗапроса.Получить("action") = "export" Тогда 
			
			Ответ = Новый HTTPСервисОтвет(200);	
			Ответ.Заголовки.Вставить("Content-Type", "application/json;  charset=utf-8");
