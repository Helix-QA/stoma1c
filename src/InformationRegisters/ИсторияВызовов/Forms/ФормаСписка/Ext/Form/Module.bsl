// Функция - находит числа в строке
//
Функция НайтиЧислаВСтроке(КодСтрока)

   СтрокаЧисел = "";

   Для Индекс = 1 По СтрДлина(КодСтрока) Цикл
   
      Символ = Сред(КодСтрока, Индекс, 1); // Перебираем все сиволы из нашей строки

      Если КодСимвола(Символ) >= 48 И КодСимвола(Символ) <= 57 Тогда // Код нуля - 48, код 9-ки - 57
         СтрокаЧисел = СтрокаЧисел + Символ;
	  //ИначеЕсли СтрДлина(СтрокаЧисел) > 0 Тогда
	  //   МассивЧисел.Добавить(Число(СтрокаЧисел));
      КонецЕсли;
   
   КонецЦикла;

   Возврат СтрокаЧисел

КонецФункции

