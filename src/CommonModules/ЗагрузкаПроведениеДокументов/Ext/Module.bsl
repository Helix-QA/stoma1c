	НСтр("ru = 'Проведения док-ов: " + СтруктураПараметров.ПредставлениеДокумента + "'"));
	Возврат Результат;
	
КонецФункции

// Процедура - Получить и провести документы в несколько потоков
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
//
Процедура ПолучитьИПровестиДокументыВНесколькоПотоков(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Получение документов...';en='Getting of documents...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	ТекстЗапроса = "ВЫБРАТЬ 
	               |	ДокументПроведения.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.&ДОКУМЕНТ КАК ДокументПроведения
	               |ГДЕ
				   |	ДокументПроведения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница"
	               +?(ПараметрыЗадания.ПровестиПроведенные, "", " И ДокументПроведения.Проведен = ЛОЖЬ")
	               +" И ДокументПроведения.ПометкаУдаления = ЛОЖЬ"
				   +?(ЗначениеЗаполнено(ПараметрыЗадания.ПериодПроведения.ДатаНачала)," И ДокументПроведения.Дата >= &НачалоПериода" ,"")
				   +?(ЗначениеЗаполнено(ПараметрыЗадания.ПериодПроведения.ДатаОкончания)," И ДокументПроведения.Дата <= &КонецПериода" ,"")	               
	               +" УПОРЯДОЧИТЬ ПО
	               |	ДокументПроведения.Дата";
				   								   
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДОКУМЕНТ", ПараметрыЗадания.ИмяДокумента);
	
	ЗапросДокументы = Новый Запрос(ТекстЗапроса);
	ЗапросДокументы.УстановитьПараметр("СтруктурнаяЕдиница"	, ПараметрыЗадания.СтруктурнаяЕдиница);
	ЗапросДокументы.УстановитьПараметр("НачалоПериода"		, ПараметрыЗадания.ПериодПроведения.ДатаНачала);
	ЗапросДокументы.УстановитьПараметр("КонецПериода"		, ПараметрыЗадания.ПериодПроведения.ДатаОкончания);
	
	ТаблицаДокументовДляПроведения 	= ЗапросДокументы.Выполнить().Выгрузить();
	
	ОбщееКоличествоДокументов 		= ТаблицаДокументовДляПроведения.Количество();
	КоличествоПотоков 				= ОпределитьКоличествоПотоков(ОбщееКоличествоДокументов, ПараметрыЗадания);
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Разбиение на потоки...';en='Splitting on streams...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	
	МассивТаблиц 					= Новый Массив;
	РазбитьТаблицуОбъектовПоКлючевомуПолю(ТаблицаДокументовДляПроведения, "Ссылка", КоличествоПотоков, МассивТаблиц, Ложь);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ОшибкаИнициацииФоновогоЗадания = Ложь;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Генерация фоновых заданий...';en='Generation of background works...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "", 0, ""));
	           
	// Генерируем фоновые задания
	МассивФоновыхЗаданий 				= Новый Массив;
	МассивИдентификаторовФоновыхЗаданий = Новый Массив;
	Для Каждого ТаблицаОбъектов Из МассивТаблиц Цикл 
		УникальныйИдентификаторЗадания 	= Новый УникальныйИдентификатор();
		ПараметрыПроцедуры = ПараметрыЗадания;
		ПараметрыПроцедуры.Вставить("ТаблицаОбъектов", ТаблицаОбъектов);
		
		Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторЗадания,
		"ЗагрузкаПроведениеДокументов.ПровестиДокументыВПотоке",
		ПараметрыПроцедуры,
		НСтр("ru = 'Проведения док-ов: " + ПараметрыЗадания.ПредставлениеДокумента + " Поток № " + Строка(МассивТаблиц.Найти(ТаблицаОбъектов)) + "'"));
		
		Если НЕ Результат = Неопределено Тогда 
			Задание = ДлительныеОперации.НайтиЗаданиеПоИдентификатору(Результат.ИдентификаторЗадания);
			Если НЕ Задание = Неопределено Тогда 
				МассивФоновыхЗаданий.Добавить(Задание);
				МассивИдентификаторовФоновыхЗаданий.Добавить(Результат.ИдентификаторЗадания);
			КонецЕсли;
		Иначе 
			ОшибкаИнициацииФоновогоЗадания = Истина;
		КонецЕсли;
	КонецЦикла;
	
	ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Передача идентификаторов фоновых заданий...';en='Broadcast background assignments ids...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, МассивИдентификаторовФоновыхЗаданий", "", 0, "", МассивИдентификаторовФоновыхЗаданий));
	
	// Ожидаем выполнения фоновых заданий 
	Если МассивФоновыхЗаданий.Количество() > 0 Тогда 
		Попытка 
			ФоновыеЗадания.ОжидатьЗавершения(МассивФоновыхЗаданий); 
		Исключение
			ОшибкаИнициацииФоновогоЗадания = Истина;			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Ошибка проведения';en='Mistake holding'"));
		КонецПопытки; 
	КонецЕсли;
	
	Если ПараметрыЗадания.ПровестиПроведенные = Ложь Тогда 
		КоличествоНеПроведенных = ПолучитьКоличествоНеПроведенныхДокументы(ПараметрыЗадания);
	Иначе 
		КоличествоНеПроведенных = 0;
	КонецЕсли;
	
	// Контрольный проход для заблокированных
	Если НЕ ОшибкаИнициацииФоновогоЗадания И ПараметрыЗадания.ПровестиПроведенные = Ложь И НЕ КоличествоНеПроведенных = ОбщееКоличествоДокументов И ЕстьНеПроведенныеДокументы(ПараметрыЗадания) Тогда
		ПараметрыЗадания.КоличествоПотоков = "1";
		ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Проведение заблокированных...';en='Holding blocked...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени, ОчиститьТаблицуПараметровПотоков", "", 0, "", Истина));		
		ПолучитьИПровестиДокументыВНесколькоПотоков(ПараметрыЗадания, АдресРезультата);
	КонецЕсли;	
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;
	
КонецПроцедуры

// Функция - Провести документы в потоке
//
// Параметры:
//  ПараметрыЗадания - 	 - 
//  АдресРезультата	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПровестиДокументыВПотоке(ПараметрыЗадания, АдресРезультата) Экспорт
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;
	
	ЭтоЧленствоПакетУслуг 			= ?(ПараметрыЗадания.Свойство("ИмяДокумента"), ПараметрыЗадания.ИмяДокумента = "ЧленствоПакетУслуг", Ложь);	
	ТаблицаДокументовДляПроведения 	= ПараметрыЗадания.ТаблицаОбъектов;
	
	ОбщееКоличествоДокументов 		= ТаблицаДокументовДляПроведения.Количество();
	ОбщееКоличествоДокументов 		= ?(ОбщееКоличествоДокументов < 1, 1, ОбщееКоличествоДокументов);
	ДатаНачалаПроцесса 				= ТекущаяДатаСеанса();
	ПроведеноДокументов 			= 0;
	ОсталосьВремени 				= Неопределено;
	ПредставлениеДокумента			= "";
	
	Для Каждого СтрокаТаблицыДокумент Из ТаблицаДокументовДляПроведения Цикл
		ПроведеноДокументов 		= ПроведеноДокументов + 1;
		ДокументОбъект 				= СтрокаТаблицыДокумент.Ссылка.ПолучитьОбъект();
		ПредставлениеДокумента 		= Строка(СтрокаТаблицыДокумент.Ссылка);		
		Попытка
			Если ПараметрыЗадания.Свойство("ЭтоПроведениеЗагруженныхДанных") Тогда 
				ДокументОбъект.ДополнительныеСвойства.Вставить("ЭтоПроведениеЗагруженныхДанных", Истина);
				Если ЭтоЧленствоПакетУслуг Тогда
					ДокументОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПересчетаИтогов", Истина);							
					Если ЗначениеЗаполнено(ДокументОбъект.СрокДействияДатой) И ДокументОбъект.СрокДействияДатой < НачалоДня(ДатаНачалаПроцесса) Тогда 
						ДокументОбъект.ДополнительныеСвойства.Вставить("СворачиватьДвиженияПоМесячно", Истина);
					КонецЕсли;	
				КонецЕсли;	
			КонецЕсли;	
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		Исключение
			// СчОшибок = СчОшибок + 1;
		КонецПопытки;
		// Накапливаем статисические данные и оповещаем клиент
		ПредставлениеДокумента			= ПредставлениеДокумента;
		Прогресс 						= Цел(100 * ПроведеноДокументов / ОбщееКоличествоДокументов);
		ОсталосьВремени 				= ОбщегоНазначенияКлиентСервер.ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Прогресс, ДатаНачалаПроцесса, ТекущаяДатаСеанса(), ОсталосьВремени);
		ПредставлениеОставшегосяВремени = ОбщегоНазначенияКлиентСервер.ВернутьПредставлениеВремени(ОсталосьВремени);
		ДлительныеОперации.СообщитьПрогресс(Прогресс, НСтр("ru='Проведение документов...';en='Conduct of documents...'") + Символы.Таб + " Осталось: " + ПредставлениеОставшегосяВремени, Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ПредставлениеДокумента, ОсталосьВремени, ПредставлениеОставшегосяВремени));
	КонецЦикла;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;
	
КонецФункции

// Процедура - Провести документы
//
// Параметры:
//  ТаблицаДокументов	 - 	 - 
//  ИндексНачала		 - 	 - 
//  РазмерПорции		 - 	 - 
//  ВидДокумента		 - 	 - 
//  КоличествоПотоков	 - 	 - 
//
Процедура ПровестиДокументы(ТаблицаДокументов, ИндексНачала, РазмерПорции, ВидДокумента, КоличествоПотоков, ОтключитьПроверки, ПерерасчитыватьСтоимость) Экспорт 
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;
	СчОшибок = 0;
	
	Если КоличествоПотоков = 1 Тогда
		НачатьТранзакцию();
	КонецЕсли;
	
	Для Сч = 1 По РазмерПорции Цикл
		
		Индекс = ?(Сч=1, ИндексНачала, Индекс+1); 
		
		ДокументОбъект = ТаблицаДокументов[Индекс].Ссылка.ПолучитьОбъект();
		Попытка 			
			Если ОтключитьПроверки Тогда
				ДокументОбъект.ДополнительныеСвойства.Вставить("ОбменДаннымиЗагрузка", Истина);
			КонецЕсли;
			
			
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		Исключение
			Сообщение = (""+Формат(ТекущаяДата(), "ДЛФ=ДВ")+СтрШаблон(НСтр("ru = ' Документ %1 не проведен: %2';en= ' Document %1 failed: %2'"),ДокументОбъект.Ссылка, Строка(ДокументОбъект.КодСинхронизации)+Символы.ПС+ОписаниеОшибки()));
			ЗаписьЖурналаРегистрации("ПроведениеДокументов.Ошибка",
				УровеньЖурналаРегистрации.Информация,
				,
				,
				Сообщение);
			СчОшибок = СчОшибок + 1;
		КонецПопытки;
		
	КонецЦикла;
	
	Если ТранзакцияАктивна() Тогда
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
	Сообщение = (""+Формат(ТекущаяДата(), "ДЛФ=ДВ")+НСтр("ru= ' Ошибок проведения: ';en= ' Mistakes: '")+ Строка(СчОшибок));	
			ЗаписьЖурналаРегистрации("ПроведениеДокументов.Ошибка",
				УровеньЖурналаРегистрации.Информация,
				,
				,
				Сообщение);
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;
	
КонецПроцедуры  

// Процедура - Пометить на удаление объекты
//
// Параметры:
//  ТаблицаДокументов	 - 	 - 
//  ИндексНачала		 - 	 - 
//  РазмерПорции		 - 	 - 
//  КоличествоПотоков	 - 	 - 
//
Процедура ПометитьНаУдалениеОбъекты(ТаблицаДокументов, ИндексНачала, РазмерПорции, КоличествоПотоков) Экспорт 
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Истина;
	МассивЗаблокированных = Новый Массив;
	
	Если КоличествоПотоков = 1 Тогда
		НачатьТранзакцию();
	КонецЕсли;
	
	Для Сч = 1 По РазмерПорции Цикл
		Индекс = ?(Сч = 1, ИндексНачала, Индекс+1); 
		ДокументОбъект = ТаблицаДокументов[Индекс].Ссылка.ПолучитьОбъект();
		Попытка
			ДокументОбъект.УстановитьПометкуУдаления(Истина); 
		Исключение
			МассивЗаблокированных.Добавить(ДокументОбъект.Ссылка);
		КонецПопытки;
	КонецЦикла;
	Для Каждого ЭлементМассива Из МассивЗаблокированных Цикл 
		ДокументОбъект = ЭлементМассива.ПолучитьОбъект();		
		Попытка
			ДокументОбъект.УстановитьПометкуУдаления(Истина); 
		Исключение
			// МассивЗаблокированных.Добавить(ДокументОбъект.Ссылка);
		КонецПопытки;
	КонецЦикла;	
	
	Если ТранзакцияАктивна() Тогда
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
	ПараметрыСеанса.ОбменДаннымиЗагрузка = Ложь;
	
КонецПроцедуры  

// Функция - Начать генерацию документов закрытия дня
//
// Параметры:
//  УникальныйИдентификатор	 - 	 - 
//  ПериодОбработки			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция НачатьГенерациюДокументовЗакрытияДня(УникальныйИдентификатор, Знач СтруктураПараметров) Экспорт
	
	УникальныйИдентификаторФормы 	= Новый УникальныйИдентификатор(УникальныйИдентификатор);
	
	ОбщийМодульДлительныеОперации = ОбщегоНазначения.ОбщийМодуль("ДлительныеОперации");
	Если ОбщийМодульДлительныеОперации = Неопределено Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыПроцедуры = СтруктураПараметров;
	ПараметрыПроцедуры.Вставить("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Результат = ОбщийМодульДлительныеОперации.ЗапуститьВыполнениеВФоне(УникальныйИдентификаторФормы,
	"ЗагрузкаПроведениеДокументов.СоздатьИПровестиДокументыЗакрытияДня",
	ПараметрыПроцедуры,
	НСтр("ru='Генерация документов ""Закрытие дня""';en='Generation of documents ""Closing of the day""'"));
	Возврат Результат;
	
КонецФункции

