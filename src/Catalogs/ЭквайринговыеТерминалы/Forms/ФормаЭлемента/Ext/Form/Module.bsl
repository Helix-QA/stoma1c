&НаСервере
// Процедура - Добавить в кассу эквайринговый терминал
//
Процедура ДобавитьВКассуЭквайринговыйТерминал()
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Касса) И ПолучитьКассуЭквайринга(Объект.Ссылка) = Неопределено Тогда
		
		УстановитьОсновнымЭквайрингом = Не ЗначениеЗаполнено(ЭтотОбъект.Касса.ЭквайринговыйТерминал) И Объект.ТипЭквайринга = Перечисления.ТипыЭквайринговыхТерминалов.Торговый;
		
		ОбъектКасса = ЭтотОбъект.Касса.ПолучитьОбъект();
		
		Если УстановитьОсновнымЭквайрингом = Истина Тогда
			ОбъектКасса.ЭквайринговыйТерминал = Объект.Ссылка; 	
		КонецЕсли;
			
		НоваяСтрока							= ОбъектКасса.ЭквайринговыеТерминалы.Добавить();
		НоваяСтрока.ЭквайринговыйТерминал	= Объект.Ссылка;
		НоваяСтрока.Основной				= УстановитьОсновнымЭквайрингом;
		
		Попытка
			ОбъектКасса.Записать();
		Исключение
		КонецПопытки;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Процедура - Тип эквайринга при изменении
//
Процедура ТипЭквайрингаПриИзменении(Форма, ПриСоздании = Ложь)
	
	Объект		= Форма.Объект;
	Элементы	= Форма.Элементы;
	
	ЭтоОнлайн	= Объект.ТипЭквайринга = ПредопределенноеЗначение("Перечисление.ТипыЭквайринговыхТерминалов.Онлайн");
	ЭтоТорговый	= Объект.ТипЭквайринга = ПредопределенноеЗначение("Перечисление.ТипыЭквайринговыхТерминалов.Торговый"); 
	
	АктивныйФон     = Новый Цвет(25, 116, 206);
	АктивныйЦвет	= Новый Цвет(255, 255, 255);
	НеактивныйФон   = Новый Цвет(235, 235, 237);
	НеактивныйЦвет	= Новый Цвет(77, 77, 77);
	
	Элементы.ГруппаТорговыйЭквайринг.ЦветФона          	= ?(ЭтоТорговый	, АктивныйФон	, НеактивныйФон); 
	Элементы.ПереключательТорговыйЭквайринг.ЦветТекста 	= ?(ЭтоТорговый	, АктивныйЦвет	, НеактивныйЦвет);  
	Элементы.ГруппаОнлайнЭквайринг.ЦветФона           	= ?(ЭтоОнлайн	, АктивныйФон	, НеактивныйФон); 
	Элементы.ПереключательОнлайнЭквайринг.ЦветТекста	= ?(ЭтоОнлайн	, АктивныйЦвет	, НеактивныйЦвет); 
	
	Элементы.ГруппаОборудование.Видимость	= ЭтоТорговый;
	Элементы.ГруппаБанка.Видимость			= ЭтоОнлайн;
		
	Если ПриСоздании = Ложь Тогда
		
		Если ЭтоОнлайн Тогда
			
			Объект.ПодключаемоеОборудование						= Неопределено;	
			Объект.ИспользоватьБезПодключенияОборудования		= Истина;      
			
		ИначеЕсли ЭтоТорговый Тогда
			
			Объект.ТипФискализации								= ПредопределенноеЗначение("Перечисление.ТипыФискализации.НеФискализировать");
			Объект.ТипБанка										= Неопределено;
			Объект.КассовыйСервер 								= Неопределено;
			Объект.ИспользоватьОплатуПоСсылке 					= Ложь;
			Элементы.КассовыйСервер.Видимость 					= Ложь;
			Элементы.ОтобразитьВыборТиповФискализации.Заголовок = "Не фискализировать";
			
		КонецЕсли;
		
		Элементы.ВнешнееОборудование.Доступность				= Не Объект.ИспользоватьБезПодключенияОборудования;
		Форма.ТекущийЭлемент 									= Элементы.Эквайрер;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Получить драйвер кассового сервера
//
Функция ПолучитьДрайверКассовогоСервера()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ДрайверыОборудования.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ДрайверыОборудования КАК ДрайверыОборудования
	|ГДЕ
	|	ДрайверыОборудования.ИмяПредопределенныхДанных = ""ДрайверКассовогоСервера""");
	
	Выборка = Запрос.Выполнить().Выбрать();

	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
// Процедура - Заполнить список выбора кассового сервера
//
Процедура ЗаполнитьСписокВыбораКассовогоСервера(ОбъектТипФискализации, ОбъектОрганизация, ЭлементКассовыйСервер)
	
	ЭлементКассовыйСервер.СписокВыбора.Очистить();
	СписокДрайверов = ПолучитьКассовыеСервераПоДрайверуОборудования(ОбъектТипФискализации, ОбъектОрганизация);	
	
	Для Каждого СтрокаСписка Из СписокДрайверов Цикл
		ЭлементКассовыйСервер.СписокВыбора.Добавить(СтрокаСписка.Значение);		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти