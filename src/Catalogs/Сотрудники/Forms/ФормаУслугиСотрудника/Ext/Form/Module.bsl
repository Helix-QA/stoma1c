// Процедура рекурсивного заолнения дерева подбора номенклатур
//
Процедура ЗаполнитьСписокПодбораРекурсивноСервер(ИсточникГрупп,ИсточникНоменклатуры,ЭлементЗаполнения, Форма)
	
	ФильтрДанные = НРег(ПодборФильтр);	
	Если ПодборОтобразитьДеревом Тогда 
		
		Для Каждого УровеньЗаполнения ИЗ ИсточникГрупп Цикл	
			Если ЗначениеЗаполнено(УровеньЗаполнения.Номенклатура) Тогда 
				НоваяСтрокаГруппы              = ЭлементЗаполнения.ПолучитьЭлементы().Добавить();
				НоваяСтрокаГруппы.Номенклатура = УровеньЗаполнения.Номенклатура;		
				НоваяСтрокаГруппы.ЭтоГруппа    = Истина;				
			Иначе 
				НоваяСтрокаГруппы = Форма._ПодборНоменклатур; 				
			КонецЕсли;
			
			ЗаполнитьСписокПодбораРекурсивноСервер(УровеньЗаполнения.ПолучитьЭлементы(),ИсточникНоменклатуры, НоваяСтрокаГруппы, Форма);						
			НоменклатураПоРодителю = Форма._ПодборНоменклатурИсточникЭлементов.НайтиСтроки(Новый Структура("Родитель", УровеньЗаполнения.Номенклатура));	
			
			// Заполняем номенклатуры
			Для Каждого СтрокаН ИЗ НоменклатураПоРодителю Цикл
				Если ЗначениеЗаполнено(ПодборФильтр) Тогда
					Если ПодборПереключательФильтра = 0 Тогда 
						Если НЕ НРег(СтрокаН.Артикул) = ФильтрДанные И СтрЧислоВхождений(НРег(СтрокаН.Наименование),ФильтрДанные) = 0  Тогда
							Продолжить;
						КонецЕсли;
					ИначеЕсли ПодборПереключательФильтра = 1 Тогда 
						Если НЕ НРег(СтрокаН.Артикул) = ФильтрДанные Тогда
							Продолжить;
						КонецЕсли;
					Иначе 
						Если СтрЧислоВхождений(НРег(СтрокаН.Наименование),ФильтрДанные) = 0 Тогда
							Продолжить;
						КонецЕсли;
					КонецЕсли;			
				КонецЕсли;
				НоваяСтрока = НоваяСтрокаГруппы.ПолучитьЭлементы().Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаН);
			КонецЦикла;	
			
			// Удаляем узел группы если он не содержит элементы
			Если НоваяСтрокаГруппы.ПолучитьЭлементы().Количество() = 0 и Не ТипЗнч(НоваяСтрокаГруппы) = Тип("ДанныеФормыДерево") Тогда
