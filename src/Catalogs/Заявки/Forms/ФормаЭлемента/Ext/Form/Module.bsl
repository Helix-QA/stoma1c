
&НаКлиенте
Перем ПредупреждениеДублирование; // Переменная для хранения данных о дублировании записи.     

&НаКлиенте
Перем ЗаписьНаПрием;

#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура, обработчик события формы "ПриСозданииНаСервере".
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтображниеКода                               = ПолучитьФункциональнуюОпцию("ПоказыватьКодСправочников");
	Элементы.Код.Видимость                       = ОтображниеКода;
	Элементы.Дата.ГоризонтальноеПоложениеВГруппе = ?(Не ОтображниеКода, ГоризонтальноеПоложениеЭлемента.Лево, ГоризонтальноеПоложениеЭлемента.Право);
		
	Параметры.Свойство("ПОIPТелефонии"	 , ПОIPТелефонии);
	Параметры.Свойство("IDЗвонка"		 , IDЗвонка);
	Параметры.Свойство("КоллтрекингНомер", КоллтрекингНомер);
	
	ЭтотОбъект.ТекущийПользователь       = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ТекущаяСтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;

	Если Объект.Ссылка.Пустая() Тогда
		
		Если Не ЗначениеЗаполнено(Объект.Статус) Тогда
			Объект.Статус = Перечисления.СтатусыЗаявок.НеОбработана;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.ОсновнойМенеджер) Тогда
			Объект.ОсновнойМенеджер = ЭтотОбъект.ТекущийПользователь;
		КонецЕсли;
	КонецЕсли;

	// Не нужно перетирать исходные данные заявки.
	//// Синхронизация с клиентом. Заполняется реквизит справочника.
	// Если ЗначениеЗаполнено(Объект.ОсновнойКлиент) Тогда
	//	Объект.Фамилия  = Объект.ОсновнойКлиент.Фамилия;
	//	Объект.Имя      = Объект.ОсновнойКлиент.Имя;
	//	Объект.Отчество = Объект.ОсновнойКлиент.Отчество;
	//	
	//	Объект.Наименование = СокрЛП(Объект.Фамилия + ?(ЗначениеЗаполнено(Объект.Фамилия), " ", "") 
	//							+ Объект.Имя + ?(ЗначениеЗаполнено(Объект.Имя), " ", "") + Объект.Отчество);		
	// КонецЕсли;
	
	ЭтотОбъект.СтатусЗаявки = Объект.Статус;	
		
	ВремСписокФильтрацииИсторииВзаимодействия = ХранилищеСистемныхНастроек.Загрузить("Справочники.Заявки.Форма.ФормаЭлемента", "НастройкиФильтрации");	
	ОбщегоНазначенияКлиентСерверСтоматология.ЗаполнитьСписокФильтрацииИсторииВзаимодействияПоУмолчанию(СписокФильтрацииИсторииВзаимодействия, Неопределено, ВремСписокФильтрацииИсторииВзаимодействия, Объект.Ссылка);
	
	ФильтрПрименен = ФильтрПрименен(СписокФильтрацииИсторииВзаимодействия);	
	Элементы.ОчиститьФильтры.Видимость	= ФильтрПрименен;
	Элементы.ПоказатьФильтры.Картинка	= ?(ФильтрПрименен, БиблиотекаКартинок.ФильтрУстановлен, БиблиотекаКартинок.ФильтрНеУстановлен);
	
	СформироватьСтруктуруДанныхВсплывающихГрупп();	
	
	УстановитьСостояниеЭлементовФормы();
	
	// Видимость элементов UTM.
	УстановитьСостояниеЭлементовUTM();
	// Видимость элементов Client ID.
	УстановитьСостояниеЭлементовClientID();
	
	// Контактная информация.
	Если Параметры.Ключ.Пустая() Тогда
		УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервере(ЭтотОбъект);
	КонецЕсли;
	
	ПроверкаДублированияКлиентаКонтактнаяИнформацияНаСервере();
	
	ЗаполнитьСписокВыбораВзаимодействия();
	ЗаполнитьСписокВыбораРежимаНапоминания();
	ЗаполнитьСписокВыбораШаблоновSMSСообщений();
	
	// Блок истории взаимодействия.
	Если Не Объект.Ссылка.Пустая() Тогда
		
		// Заполняется реквизит формы.
		ЭтотОбъект.Фамилия  = Объект.Фамилия;
		ЭтотОбъект.Имя      = Объект.Имя;
		ЭтотОбъект.Отчество = Объект.Отчество;	

		ОбновитьИсториюВзаимодействияСКлиентом();	
		СоздатьВиджетСделки();
		УстановитьАктуальнуюСделкуВзаимодействия();

	КонецЕсли;
	
	ОбновитьЗаголовокЗаявки();
	
	Элементы.Комментарий.МаксимальнаяВысота = Мин(Макс((СтрЧислоСтрок(Объект.Комментарий) / 1.5) + 1, 3), 14);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	ЗаписьНаПрием = Ложь;
	
КонецПроцедуры                

&НаСервере
// Процедура - При чтении на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// Контактная информация
	УправлениеКонтактнойИнформациейСтоматология.ПриСозданииПриЧтенииНаСервере(ЭтотОбъект);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события формы "ПриОткрытии".
//
Процедура ПриОткрытии(Отказ)
	
	УстановитьСостояниеЭлементовФормыСтатусыЗаявки();
	КомментарийПриИзменении(Неопределено);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события формы "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Статус <> ЭтотОбъект.СтатусЗаявки Тогда
		Объект.Статус = ЭтотОбъект.СтатусЗаявки;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события формы "ПередЗаписьюНаСервере".
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.ДополнительныеСвойства.Вставить("ИнтерактивнаяЗапись", Истина);
	
	//// Заполнить контактную информацию.
	УправлениеКонтактнойИнформациейСтоматология.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец КонтактнаяИнформация
	
	Если ЭтотОбъект.ОповеститьОНовойЗаявке = Истина
		ИЛИ Объект.Ссылка.Пустая() = Истина Тогда
		
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ОповеститьОНовойЗаявке", Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - После записи на сервере
//
// Параметры:
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(ПОIPТелефонии) И ЗначениеЗаполнено(IDЗвонка) Тогда
		ЗаписатьЗаявкуВРегистрИсторияВызовов();
	КонецЕсли;
	
	ОбновитьЗаголовокЗаявки();
	
КонецПроцедуры

&НаКлиенте
// Процедура - После записи.
//
// Параметры:
//  ПараметрыЗаписи	 - 	 -
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ЗаписанаНоваяЗаявка", Объект.Ссылка, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения.
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОБНОВИТЬ_ОБЯЗАТЕЛЬНЫЕ_ПОЛЯ" Тогда
		
		УстановитьОбязательныеПоля();
		ЭтаФорма.ОтключитьОтметкуНезаполненного();

	ИначеЕсли ИмяСобытия = "ОБНОВИТЬ_ВИДЖЕТ_СДЕЛКИ" Тогда
		
		СоздатьВиджетСделки();		
		УстановитьАктуальнуюСделкуВзаимодействия();
		
	ИначеЕсли ИмяСобытия = "СозданИзмененСервисSMSРассылки" Тогда
		
		ВзаимодействиеSMSНастроитьСервисЗавершение(Параметр);
		
	ИначеЕсли ИмяСобытия = "СозданаИзмененаУчетнаяЗапись" Тогда
		
		ВзаимодействиеПисьмоНастроитьАккаунтЗавершение(Параметр);
		
	ИначеЕсли ИмяСобытия = "ЗаписанНовыйКлиент" Тогда
		
		УстановитьСостояниеЭлементовФормы();
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Процедура - Установить видимость элементов формы.
//
Процедура УстановитьСостояниеЭлементовФормы()
		
	Элементы.СтатусНекачественная.Заголовок	 = НСтр("ru = 'Некачественное'");
	Элементы.СтатусОбработана.Заголовок		 = НСтр("ru = 'Качественное'");
	Элементы.СтатусОбработана.Отображение	 = ОтображениеКнопки.КартинкаИТекст;
	
	// Если заявка обработана.
	Если Не Объект.Ссылка.Пустая() Тогда 
				
		Если ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Принята
			Или ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Отклонена Тогда
			
			Элементы.ПоказатьНаличиеДублейКлиентов.Видимость = Ложь;
			Элементы.ОткрытьКонтрагента.Видимость 			 = Ложь;
			Элементы.СтатусОбработана.Отображение            = ОтображениеКнопки.Текст;
			
			Элементы.ОткрытьКонтрагентаНеОбработана.Видимость = Ложь;
			Элементы.СтатусНеОбработана.Заголовок = НСтр("ru = 'Новое обращение'");

			Если ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Принята
				И ЗначениеЗаполнено(Объект.ОсновнойКлиент) Тогда
				
				Элементы.СтатусОбработана.Заголовок   = НСтр("ru = 'Качественное'; en = 'Received: '");
				Элементы.ОткрытьКонтрагента.Заголовок = Объект.ОсновнойКлиент.Наименование;
				Элементы.ОткрытьКонтрагента.Видимость = Истина;
								
			ИначеЕсли ЭтотОбъект.СтатусЗаявки = Перечисления.СтатусыЗаявок.Отклонена Тогда
				
				Элементы.СтатусНекачественная.Заголовок      = НСтр("ru = 'Некачественное '; en = 'Poor application '") + Объект.ОценкаЗаявки;
				Элементы.СтатусНекачественная.ЦветТекста	 = Новый Цвет(255, 255, 255);
				Элементы.ГруппаСтатусНекачественная.ЦветФона = Новый Цвет(241, 23, 22);
				
			КонецЕсли;
			
		ИначеЕсли ЗначениеЗаполнено(Объект.ОсновнойКлиент) Тогда
			
			// Элементы.ОткрытьКонтрагентаНеОбработана.Заголовок = Объект.ОсновнойКлиент.Наименование;
			// Элементы.ОткрытьКонтрагентаНеОбработана.Видимость = Истина;
			
			Элементы.СтатусНеОбработана.Заголовок = НСтр("ru = 'Новое обращение'");
			
		КонецЕсли;	
		
	Иначе	
		Элементы.РекламнаяСсылка.Видимость   = Ложь;
		Элементы.ГруппаUTM.Видимость         = Ложь;
		// Элементы.ГруппаФИО.Видимость         = Ложь;
		// Элементы.ГруппаФИО.Видимость = Истина;
		
	КонецЕсли;
	
	РекламныйИсточникДругойПациент = (Объект.РекламныйИсточник = Справочники.РекламныеИсточники.ДругойПациент);
	Элементы.ИсточникИнформацииЗначение.Видимость = РекламныйИсточникДругойПациент;	
	Если РекламныйИсточникДругойПациент Тогда
		Элементы.ИсточникИнформацииЗначение.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	КонецЕсли;
	
	
	// Если Объект.РекламнаяПлощадка = Справочники.КаналыПривлечения.ЛидФорма Тогда
	//	Элементы.КаналПривлеченияЗначение.Видимость       = Истина;
	//	Элементы.КаналПривлеченияЗначение.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.ЛидФормы");
	//	Элементы.КаналПривлеченияЗначение.Заголовок       = НСтр("ru = 'Лид форма'; en = 'Lead form'");		
	// Иначе
	//	Элементы.КаналПривлеченияЗначение.Видимость       = Ложь;
	// КонецЕсли;
	
	// Видимость элементов взаимодействий.
	Элементы.ГруппаSMS.Видимость = РазрешенаОтправкаSMSСообщений();
	
	Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость     = Не НаличиеСервисаSMSРассылки();
	Элементы.ГруппаВзаимодействиеSMSОсновная.Видимость            = Не Элементы.ГруппаВзаимодействиеSMSНастроитьСервис.Видимость;	
	
	Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость = Не НаличиеПочтовогоАккаунта();
	Элементы.ГруппаВзаимодействиеПисьмоОсновная.Видимость         = Не Элементы.ГруппаВзаимодействиеПисьмоНастроитьАккаунт.Видимость;
	
	УстановитьВидимостьЗначенияКаналаПривлечения(ЭтотОбъект);

	УстановитьФокусЭлементаСервер();
	
	Элементы.ГруппаПерсональныеДанные.Видимость = ЗначениеЗаполнено(Объект.ОсновнойКлиент);
	
	Если ЗначениеЗаполнено(Объект.ОсновнойКлиент) Тогда
		
		ЭтотОбъект.СтатусКонтрагента = Справочники.Контрагенты.ПолучитьСтатус(Объект.ОсновнойКлиент);
		Если НЕ ЗначениеЗаполнено(ЭтотОбъект.СтатусКонтрагента) Тогда
			ЭтотОбъект.СтатусКонтрагента = Перечисления.СтатусыКонтрагентов.Первичный;
		КонецЕсли;
		
		ЗаполнитьТаблицуМеток();
		ОбновитьМетки();
		
		ФИОКонтрагента = ПолучитьПолноеФИООбъекта(ЭтотОбъект);
		Элементы.ОткрытьКонтрагента.Заголовок = ?(ЗначениеЗаполнено(ФИОКонтрагента), ФИОКонтрагента, Объект.ОсновнойКлиент.Наименование);		
		
		СоответствиеЦветов  = ПолучитьСоответствиеЦветовИСтатусовКлиентов();
		СтатусПредставление = ?(ЭтотОбъект.СтатусКонтрагента = Перечисления.СтатусыКонтрагентов.Потенциальный, Нстр("ru = 'Потенциальный'; en = 'Potential'"), ЭтотОбъект.СтатусКонтрагента); 
		
		Элементы.ГруппаСтатус.ЦветФона            = СоответствиеЦветов.Получить(ЭтотОбъект.СтатусКонтрагента);	
		Элементы.ОткрытьИсториюСтатусов.Заголовок = СтатусПредставление; 
				
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить состояние элементов UTM.
//
Процедура УстановитьСостояниеЭлементовUTM()
	
	ОтображениеГруппыUTM = Ложь;
	
	Если Не Объект.Ссылка.Пустая() Тогда
		
		ОтображениеUtmSource   = ЗначениеЗаполнено(Объект.utm_source);
		ОтображениеUtmMedium   = ЗначениеЗаполнено(Объект.utm_medium);
		ОтображениеUtmCampaign = ЗначениеЗаполнено(Объект.utm_campaign);
		ОтображениеUtmTerm     = ЗначениеЗаполнено(Объект.utm_term);
		ОтображениеUtmContent  = ЗначениеЗаполнено(Объект.utm_content);
		
		Если ОтображениеUtmSource
			ИЛИ ОтображениеUtmMedium
			ИЛИ ОтображениеUtmCampaign
			ИЛИ ОтображениеUtmTerm
			ИЛИ ОтображениеUtmContent Тогда
			
			ОтображениеГруппыUTM = Истина;
			
			Элементы.utm_source.Видимость   = ОтображениеUtmSource;
			Элементы.utm_medium.Видимость   = ОтображениеUtmMedium;
			Элементы.utm_campaign.Видимость = ОтображениеUtmCampaign;
			Элементы.utm_term.Видимость     = ОтображениеUtmTerm;
			Элементы.utm_content.Видимость  = ОтображениеUtmContent;
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	Элементы.ГруппаUTM.Видимость = ОтображениеГруппыUTM;
	
	
			
						
				
	
	
КонецПроцедуры

&НаСервере
// Процедура - Установить состояние элементов UTM.
//
Процедура УстановитьСостояниеЭлементовClientID()
				
			Элементы.ym_cid.Видимость   		= ЗначениеЗаполнено(Объект.ym_cid);
			Элементы.ga_cid.Видимость   		= ЗначениеЗаполнено(Объект.ga_cid);
			Элементы.fitness1c_cid.Видимость   	= ЗначениеЗаполнено(Объект.fitness1c_cid);
			Элементы.ct_cid.Видимость     		= ЗначениеЗаполнено(Объект.ct_cid);
			Элементы.rs_cid.Видимость  			= ЗначениеЗаполнено(Объект.rs_cid);
			Элементы.rs_vid.Видимость  			= ЗначениеЗаполнено(Объект.rs_vid);
