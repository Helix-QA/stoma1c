	Запрос.УстановитьПараметр("ЧленствоПакетУслуг", ПараметрыЗадания.ЧленствоПакетУслуг);
	
	ТаблицаПоследовательностиРегистраторов = Запрос.Выполнить().Выгрузить();
	
	СрокДействияЧПУ = ПолучитьСрокДействияЧленстваПакетаУслуг(ПараметрыЗадания.ЧленствоПакетУслуг);
	Если НЕ НачалоДня(СрокДействияЧПУ) < НачалоДня(ТекущаяДатаСеанса()) Тогда // действителен
		МассивЗакрытияДня = ПолучитьЗакрытияДня(ПараметрыЗадания.ЧленствоПакетУслуг);
		Для Каждого ЗакрытиеДня Из МассивЗакрытияДня Цикл 
			ЗакрытиеДняОбъект = ЗакрытиеДня.ПолучитьОбъект();
			ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеобходимоУдалитьЧленствоПакетУслугИзДокумента"	, Истина);			
			ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЭтоВосстановлениеПоследовательности"				, Истина);
			ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("ЧленствоПакетУслугПоследовательности"			, ПараметрыЗадания.ЧленствоПакетУслуг);
			ЗакрытиеДняОбъект.ДополнительныеСвойства.Вставить("НеДобавлятьВСтекПроведениеДокументовВФоне"		, Истина);
