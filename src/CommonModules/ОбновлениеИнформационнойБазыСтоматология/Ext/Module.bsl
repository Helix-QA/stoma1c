// Процедура - Проставить символьное представление валют
//
Процедура ПроставитьСимвольноеПредставлениеВалют() Экспорт
	Попытка 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Валюты.Ссылка КАК Ссылка,
		|	Валюты.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Валюты КАК Валюты";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		
		Пока Выборка.Следующий() Цикл
			Если Найти(Выборка.Наименование, "EUR") > 0 Тогда
				ВалютаОбъект = Выборка.Ссылка.ПолучитьОбъект();
				ВалютаОбъект.СимвольноеПредставление = "€";
				ВалютаОбъект.Записать();
			КонецЕсли;
			
			Если Найти(Выборка.Наименование, "USD") > 0 Тогда
				ВалютаОбъект = Выборка.Ссылка.ПолучитьОбъект();
				ВалютаОбъект.СимвольноеПредставление = "$";
				ВалютаОбъект.Записать();
			КонецЕсли;
			
			Если Найти(Выборка.Наименование, "RUR") > 0 ИЛИ Найти(Выборка.Наименование, "руб") > 0 Тогда
				ВалютаОбъект = Выборка.Ссылка.ПолучитьОбъект();
				ВалютаОбъект.СимвольноеПредставление = "₽";
				ВалютаОбъект.Записать();
			КонецЕсли;  
			
			Если Найти(Выборка.Наименование, "UAH") > 0 Тогда
				ВалютаОбъект = Выборка.Ссылка.ПолучитьОбъект();
				ВалютаОбъект.СимвольноеПредставление = "₴";
				ВалютаОбъект.Записать();
			КонецЕсли;
			
			Если Найти(Выборка.Наименование, "BYN") > 0 Тогда
				ВалютаОбъект = Выборка.Ссылка.ПолучитьОбъект();
				ВалютаОбъект.СимвольноеПредставление = "Br";
				ВалютаОбъект.Записать();
			КонецЕсли;
			
		КонецЦикла;	
	Исключение
	КонецПопытки;
	
КонецПроцедуры

