// Процедура, выполняет переход на новую систему налогообложения.
//
Процедура ПереходНаНовуюСистемуНалогообложения() Экспорт
	
	ПривелигированныйРежимДо = ПривилегированныйРежим();
	Если Не ПривелигированныйРежимДо Тогда	
		УстановитьПривилегированныйРежим(Истина);	
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.Ссылка КАК Организация
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.СистемаНалогообложенияДляТоваров = ЗНАЧЕНИЕ(Перечисление.ТипыСистемНалогообложенияККТ.ПустаяСсылка)");	
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЗ Из Результат Цикл
		Попытка
			ОрганизацияОбъект = СтрокаТЗ.Организация.ПолучитьОбъект();		
			ОрганизацияОбъект.СистемаНалогообложенияДляТоваров	= ПолучитьСистемуНалогообложения(ОрганизацияОбъект);
			ОрганизацияОбъект.СПриоритетомНоменклатуры			= Истина;
			ОрганизацияОбъект.Записать();     			
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка установки системы налогообложения для организации %1. Описание ошибки: %2.'"), СтрокаТЗ.Организация, ОписаниеОшибки));      
		КонецПопытки;
	КонецЦикла;
	
	Если Не ПривелигированныйРежимДо Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры 

