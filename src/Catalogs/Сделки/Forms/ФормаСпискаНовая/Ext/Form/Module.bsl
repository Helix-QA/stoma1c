// Процедура, создает либо находит существующую таблицу и отчищает ее.
//
Процедура ИнициализироватьТаблицуВидовСделок()
	
	МассивРеквизитов = Новый Массив();
	ИмяТаблицы = "ТаблицаВидовСделок";
	
	Если НЕ ОбщегоНазначенияСтоматология.ЕстьРеквизитФормы(ЭтаФорма, ИмяТаблицы) Тогда
		МассивРеквизитов.Добавить(Новый РеквизитФормы(ИмяТаблицы , Новый ОписаниеТипов("ТаблицаЗначений")));
		МассивРеквизитов.Добавить(Новый РеквизитФормы("ВидСделки", Новый ОписаниеТипов("СправочникСсылка.ВидыСделок")  , ИмяТаблицы));
	Иначе
		ЭтаФорма[ИмяТаблицы].Очистить();
	КонецЕсли;
	
	Если МассивРеквизитов.Количество() <> 0 Тогда 
		// Добавляем реквизит.
		ЭтаФорма.ИзменитьРеквизиты(МассивРеквизитов);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, создает дианмические эелементы формы смены вида сделки.
//
Процедура СоздатьЭлементыСменыВидаСделки()
	
	КомандаСменыВидаСделки = ЭтаФорма.Команды.Найти("ИзменитьВидСделки");
	
	// Добавляем новые данные в таблицу значений.
	ВидыСделок = ПолучитьДанныеВидовСделок();
	Индекс = 0;
	Для Каждого ДанныеВидаСделки Из ВидыСделок Цикл
		
		// Заполнение списка выбора видов сделок.
		ЭтотОбъект.ДоступныеВидыСделок.Добавить(ДанныеВидаСделки.Ссылка, ДанныеВидаСделки.Наименование);
		
		НоваяСтрокаТЗ = ЭтотОбъект.ТаблицаВидовСделок.Добавить();
		НоваяСтрокаТЗ.ВидСделки = ДанныеВидаСделки.Ссылка;
		
		ИмяЭлемента = "ВидСделки_" + Индекс;
		
		// Создаем команду.
		КомандаКнопки = ЭтаФорма.Команды.Найти("Команда" + ИмяЭлемента);	
		Если КомандаКнопки = Неопределено Тогда
			
			КомандаКнопки = ЭтаФорма.Команды.Добавить("Команда" + ИмяЭлемента);
			КомандаКнопки.Действие  = "ИзменитьВидСделки";
			
		КонецЕсли;
		
		// Создаем кнопку.
		НайденнаяКнопка = ЭтаФорма.Элементы.Найти(ИмяЭлемента);
		Если НайденнаяКнопка = Неопределено Тогда			
			
			ЭлементКнопка = ЭтаФорма.Элементы.Вставить(ИмяЭлемента, Тип("КнопкаФормы"), Элементы.СписокСменитьСделку);
			ЭлементКнопка.ИмяКоманды = КомандаКнопки.Имя;
			ЭлементКнопка.Заголовок = ДанныеВидаСделки.Наименование;
			ЭлементКнопка.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
			
		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
КонецПроцедуры

