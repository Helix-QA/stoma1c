// Процедура - Получить разрешение монитора клиента.
// 
Процедура ПолучитьРазрешениеМонитораКлиента()
		
	ЭкраныКлиента = ПолучитьИнформациюЭкрановКлиента();
	ЭтотОбъект.ИнформацияЭкранаКлиента = ?(ЭкраныКлиента <> Неопределено, ЭкраныКлиента[0], Неопределено);
	
	Если ЭтотОбъект.ИнформацияЭкранаКлиента <> Неопределено Тогда
		
		ШиринаЭкрана = ЭтотОбъект.ИнформацияЭкранаКлиента.Ширина;
		
		Если ШиринаЭкрана < 1920 Тогда
			
			МасштабФормы = (ШиринаЭкрана / 1920) * 1.2 * 100;
			ЭтаФорма.Масштаб = ?(МасштабФормы >= 80, МасштабФормы, 80);
									
			Элементы.ДеревоСотрудников.АвтоМаксимальнаяВысота = Ложь;
			Элементы.ДеревоСотрудников.МаксимальнаяВысота     = 25;
			Элементы.ДеревоПомещений.АвтоМаксимальнаяВысота   = Ложь;
			Элементы.ДеревоПомещений.МаксимальнаяВысота       = 25;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

