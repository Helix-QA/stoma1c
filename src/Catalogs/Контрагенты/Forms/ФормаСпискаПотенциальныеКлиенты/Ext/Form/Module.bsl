&НаКлиенте
// Процедура, обработчик нажатия элемента динамического меню.
//
Процедура ОбработчикНажатияЭлементаДинамическогоМеню(Команда) Экспорт
		
	ПриИзмененииОтборовСервер(Команда.Имя);
		
КонецПроцедуры

&НаСервере
// Процедура создания динамических меню.
//
//	Описание:
// 		Очередность создания пакетов:
//		Менеджер,
//		СотрудникРегистрации,
//		ИсточникИнформации,
//		КаналПривлечения,
//		ТекущийЭтапСделки,
//		Интересы,
//		Теги.
//
Процедура ОбновитьДинамическиеМенюОтборов(ПараметрыОтбора = Неопределено, ОбновитьСписок = Ложь)
	
	// Обновляем отборы согласно параметров, переданных из другой формы	и уходим	
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ОчиститьВсеОтборы") И ПараметрыОтбора.ОчиститьВсеОтборы = Истина Тогда
		ОбновитьВсеОтборыФормы(ПараметрыОтбора); // Перешли из монитора при уже открытой текущей формы
		Возврат;
	КонецЕсли;
	
	МассивПакетовЗапроса = ПолучитьПакетЗапросаЗначенийДляОтборов(ТекущийПользователь);
	
	ОбновитьДинамическоеМенюОтборСтатус();
	
	МассивМенеджеров 			 = МассивПакетовЗапроса[0].Выгрузить().ВыгрузитьКолонку("Менеджер");
	МассивМенеджеров.Добавить(Справочники.Сотрудники.ПустаяСсылка());
	ОбновитьДинамическоеМенюОтборМенеджеры(МассивМенеджеров);
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивМенеджеров") Тогда // Перешли из монитора, открывая форму
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборМенеджеры", ПараметрыОтбора.МассивМенеджеров, Истина);
		ОбновитьСписок = Истина;
	КонецЕсли;	
	
	МассивСотрудниковРегистрации = МассивПакетовЗапроса[0].Выгрузить().ВыгрузитьКолонку("СотрудникРегистрации");
	МассивСотрудниковРегистрации.Добавить(Справочники.Сотрудники.ПустаяСсылка());
	ОбновитьДинамическоеМенюОтборСотрудникРегистрации(МассивСотрудниковРегистрации);
	
	МассивРекламныхИсточников 	 = МассивПакетовЗапроса[2].Выгрузить().ВыгрузитьКолонку("ИсточникИнформации");
	МассивРекламныхИсточников.Добавить(Справочники.РекламныеИсточники.ПустаяСсылка());
	ОбновитьДинамическоеМенюОтборРекламныйИсточник(МассивРекламныхИсточников);
	
	МассивКаналовПривлечения	 = МассивПакетовЗапроса[3].Выгрузить().ВыгрузитьКолонку("КаналПривлечения");
	МассивКаналовПривлечения.Добавить(Справочники.КаналыПривлечения.ПустаяСсылка());
	ОбновитьДинамическоеМенюОтборКаналПривлечения(МассивКаналовПривлечения);
	
	МассивЭтапов				 = МассивПакетовЗапроса[4].Выгрузить().ВыгрузитьКолонку("ТекущийЭтапСделки");
	// Нужно что-бы успех и отказ были всегда в конце.
	ИндексОтказа = МассивЭтапов.Найти(Справочники.ЭтапыСделок.Отказ);
	Если ИндексОтказа <> Неопределено Тогда
		МассивЭтапов.Удалить(ИндексОтказа); 
		МассивЭтапов.Добавить(Справочники.ЭтапыСделок.Отказ);
	КонецЕсли;
	
	ИндексУспеха = МассивЭтапов.Найти(Справочники.ЭтапыСделок.Успех);
	Если ИндексУспеха <> Неопределено Тогда
		МассивЭтапов.Удалить(ИндексУспеха); 
		МассивЭтапов.Добавить(Справочники.ЭтапыСделок.Успех);
	КонецЕсли;

	ОбновитьДинамическоеМенюОтборЭтапы(МассивЭтапов);
	
	МассивИнтересовОтбора		 = МассивПакетовЗапроса[5].Выгрузить().ВыгрузитьКолонку("Интересы");
	МассивИнтересовОтбора.Добавить(Справочники.Интересы.ПустаяСсылка());
	ОбновитьДинамическоеМенюОтборИнтересы(МассивИнтересовОтбора);
	
	МассивТеговОтбора			 = МассивПакетовЗапроса[6].Выгрузить().ВыгрузитьКолонку("Теги");
	МассивТеговОтбора.Добавить(Справочники.Теги.ПустаяСсылка());
	ОбновитьДинамическоеМенюОтборТеги(МассивТеговОтбора);
		
	ОбновитьДинамическоеМенюОтборСделки();
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияСделок") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборСделки", ПараметрыОтбора.МассивСтатусовНаличияСделок, Истина);
		ОбновитьСписок = Истина;		
	КонецЕсли;		
	ОбновитьДинамическоеМенюОтборЗадачи();
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач") Тогда 
		УправлениеИнтерфейсамиСервер.УстановитьВыборВДинамическомМенюФормы(ЭтаФорма, "МенюОтборЗадачи", ПараметрыОтбора.МассивСтатусовНаличияЗадач, Истина);
		ОбновитьСписок = Истина;		
	КонецЕсли;		
	
	Если ПараметрыОтбора <> Неопределено И ПараметрыОтбора.Свойство("ПериодПланирования") Тогда 
		ОтборДатаЗапланированнойЗадачи = ПараметрыОтбора.ПериодПланирования;
		Элементы.ОтборЗапланированнаяЗадача.Заголовок = РаботаСОтборами.ОбновитьПредставлениеПериода(ЭтотОбъект.ОтборДатаЗапланированнойЗадачи, НСтр("ru='Запланированная задача: ';en='Scheduled task:'"));		
		ОбновитьСписок = Истина;		
	КонецЕсли;
	
	Если ОбновитьСписок Тогда 
		ПолучитьЗначенияОтборов();
	КонецЕсли; 	
	
КонецПроцедуры

