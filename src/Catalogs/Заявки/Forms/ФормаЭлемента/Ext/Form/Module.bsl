// Процедура, проверяет заполнение контактной информации.
//
Процедура ПроверитьЗаполнениеКонтактнойИнформации(Отказ, ДанныеПоля)
	
	Если ДанныеПоля.Поле = "НомерТелефона" Тогда
		ТипКонтактнойИнформации = Перечисления.ТипыКонтактнойИнформации.Телефон;
		
	ИначеЕсли ДанныеПоля.Поле = "АдресЭП" Тогда
		ТипКонтактнойИнформации = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		
	КонецЕсли;
	
	КонтактнаяИнформацияЗаполнена = Ложь;
	
	Для Каждого СтрокаКИ Из ЭтотОбъект.КонтактнаяИнформация Цикл
		
		Если СтрокаКИ.Тип = ТипКонтактнойИнформации И ЗначениеЗаполнено(СтрокаКИ.Представление) Тогда
			КонтактнаяИнформацияЗаполнена = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не КонтактнаяИнформацияЗаполнена Тогда
		ТекстСообщения = ДанныеПоля.ПредставлениеПоля + НСтр("ru = ' обязателен для заполнения'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;
	
КонецПроцедуры

