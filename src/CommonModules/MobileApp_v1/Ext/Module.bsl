//
Функция ИзвлечьОписаниеОшибки(знач ТекстОшибки) 
	
	КодОшибкиИзОбъекта = Неопределено;
	
	Если СтрНайти(ТекстОшибки, "[2036]") > 0 Тогда
		
		Начало = СтрНайти(ТекстОшибки, "[2036]");
		Конец  = СтрДлина(ТекстОшибки);
		
		Если Начало > 0 И Конец > 0 Тогда				
			ТекстОшибки = Сред(ТекстОшибки, Начало + 6, Конец);				
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ТекстОшибки;
	
