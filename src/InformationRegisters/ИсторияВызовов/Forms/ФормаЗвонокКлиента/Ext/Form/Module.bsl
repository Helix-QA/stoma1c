&НаКлиенте
// Процедура - Подключаемый открыть партнера
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Подключаемый_ОткрытьКонтрагента(Команда) Экспорт

	Индекс 					= Число(СтрЗаменить(Команда.Имя, "Кнопка_ОткрытьКонтрагента_", ""));	
	КонтрагентСсылка		= СтруктураКлиента.СписокКонтрагентов[Индекс].Значение.КонтрагентСсылка;
	
	Если ТипЗнч(КонтрагентСсылка) = Тип("СправочникСсылка.Контрагенты") Тогда 
		ОткрытьФорму("Справочник.Контрагенты.ФормаОбъекта", Новый Структура("Ключ, IDЗвонка", КонтрагентСсылка, IDЗвонка));
	ИначеЕсли ТипЗнч(КонтрагентСсылка) = Тип("СправочникСсылка.Сотрудники") Тогда
		ОткрытьФорму("Справочник.Сотрудники.ФормаОбъекта", Новый Структура("Ключ, IDЗвонка", КонтрагентСсылка, IDЗвонка));
	КонецЕсли;	
	
КонецПроцедуры

