// Функция, возвращает представление блоков, доступных для переноса.
//
Функция ПолучитьДоступныеДляПереносаБлоки(ДанныеСделки)
	
	ЭтапПотенциальныйПрием 	= ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапПотенциальныйПрием");
	ЭтапПредложениеОзвучено = ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапПредложениеОзвучено");
	ЭтапОтказ 				= ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапОтказ");
	ЭтапКлиентЗаписан		= ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапКлиентЗаписан");
	ЭтапКлиентПодтвердил	= ЭтотОбъект.ДанныеПредопределенногоВидаСделки.Получить("ЭтапКлиентПодтвердил");
	
	Если (ЗначениеЗаполнено(ЭтапПотенциальныйПрием) И ДанныеСделки.ЭтапСделки = ЭтапПотенциальныйПрием)
		ИЛИ (ЗначениеЗаполнено(ЭтапПредложениеОзвучено) И ДанныеСделки.ЭтапСделки = ЭтапПредложениеОзвучено)
		ИЛИ (ЗначениеЗаполнено(ЭтапОтказ) И ДанныеСделки.ЭтапСделки = ЭтапОтказ) Тогда
		
		МассивБлоков = Новый Массив;
		
		МассивБлоков.Добавить("'" + ?(ЗначениеЗаполнено(ЭтапПотенциальныйПрием), Строка(ЭтапПотенциальныйПрием.УникальныйИдентификатор()), "") + "'");
		МассивБлоков.Добавить("'" + ?(ЗначениеЗаполнено(ЭтапПредложениеОзвучено), Строка(ЭтапПредложениеОзвучено.УникальныйИдентификатор()), "") + "'");
		МассивБлоков.Добавить("'" + ?(ЗначениеЗаполнено(ЭтапОтказ), Строка(ЭтапОтказ.УникальныйИдентификатор()), "") + "'");
		
		ДоступныеБлоки = СтрСоединить(МассивБлоков, ", ");
		
	ИначеЕсли (ЗначениеЗаполнено(ЭтапКлиентЗаписан) И ДанныеСделки.ЭтапСделки = ЭтапКлиентЗаписан)
		ИЛИ (ЗначениеЗаполнено(ЭтапКлиентПодтвердил) И ДанныеСделки.ЭтапСделки = ЭтапКлиентПодтвердил) Тогда
		
		ДоступныеБлоки = "'" + ?(ЗначениеЗаполнено(ЭтапОтказ), Строка(ЭтапОтказ.УникальныйИдентификатор()), "") + "'";
		
	Иначе
		ДоступныеБлоки = "";
		
	КонецЕсли;
		
	Возврат ДоступныеБлоки
	
КонецФункции

