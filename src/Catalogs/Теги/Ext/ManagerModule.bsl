// Функция - Получить таблицу тегов
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьТаблицуТегов() Экспорт
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Теги.Ссылка КАК Ссылка,
	|	Теги.Наименование КАК Наименование
	|ИЗ
	|	Справочник.Теги КАК Теги
	|ГДЕ
	|	НЕ Теги.ПометкаУдаления");
				
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

