КонецФункции

// Функции вовращащие соращенное наименование текущей валюты  целой и дробной части(руб. коп.)
//
Функция ПолучитьСимвольныйКодЦелойчастиВалюты(ВалютаПоУмолчанию = "Руб.", ВернутьМеждународныйСимвол = Ложь) Экспорт
	
	ТекущаяВалюта = Константы.ВалютаУчета.Получить();
	Если НЕ ЗначениеЗаполнено(ТекущаяВалюта) Тогда
		Возврат  " " + ВалютаПоУмолчанию + " ";
	КонецЕсли;
	
	ТекущаяВалютаСтруктура = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ТекущаяВалюта, "СимвольноеПредставление, ПараметрыПрописи");
	
	Если ВернутьМеждународныйСимвол Тогда 
		Если ЗначениеЗаполнено(СокрЛП(ТекущаяВалютаСтруктура.СимвольноеПредставление)) Тогда 
			Возврат " " + СокрЛП(ТекущаяВалютаСтруктура.СимвольноеПредставление) + " ";
		КонецЕсли;	
	КонецЕсли;
	
	СтрокаПараметров = СтрЗаменить(ТекущаяВалютаСтруктура.ПараметрыПрописи, ",", Символы.ПС);
	ЦелаяЧасть = СокрЛП(СтрПолучитьСтроку(СтрокаПараметров,10));
	Если ЦелаяЧасть = "" тогда
		Возврат Строка(ТекущаяВалюта);
	Иначе 
		Возврат ЦелаяЧасть;
	Конецесли;
	
КонецФункции

