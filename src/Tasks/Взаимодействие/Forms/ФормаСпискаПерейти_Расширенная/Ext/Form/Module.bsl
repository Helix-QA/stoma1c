&НаКлиенте
// Процедура - Обработчик нажатия элемента динамического меню
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОбработчикНажатияЭлементаДинамическогоМеню(Команда) Экспорт		
			
	// ЭтаФорма.ТекущийЭлемент = Элементы.План;	
	
	// Если это элнмент открытия Списка
	Если СтрНайти(Команда.Имя, "ОткрытьСписок") > 0 Тогда
		
		// Открываем список значений
		ОбработчикНажатияСпискаДинамическогоМеню(Команда.Имя);			
		Возврат;
		
	КонецЕсли;
	                             
	ПриИзмененииОтборовСервер(Команда.Имя);
	
КонецПроцедуры

#Область ________________ОБРАБОТЧИКИ_НАЖАТИЯ_СПИСКА_ДИНАМИЧЕСКОГО_МЕНЮ__________________

&НаКлиенте
// Процедура - Обработчик нажатия списка динамического меню
//
// Параметры:
//  Форма					 - 	 - 
//  СписокЗначений			 - 	 - 
//  ИмяКнопкиПредставления	 - 	 - 
//
Процедура ОбработчикНажатияСпискаДинамическогоМеню(ИмяКоманды)
	
	// Получаем привязанные данные и доп значения
	СтруктДанных = ОбработчикНажатияСпискаДинамическогоМенюСервер(ИмяКоманды);  
	
	Если СтруктДанных = Неопределено Тогда
		ОбновитьДанныеДляОтображения();
		Возврат;
	КонецЕсли;	
	
	// Выбор значения из выпадающего меню
	Оповещение = Новый ОписаниеОповещения("ОбработчикОткрытияСпискаДинамическогоМенюЗавершение", ЭтотОбъект, СтруктДанных);
	ПоказатьВыборИзМеню(Оповещение, СтруктДанных.ПривязанныеДанные.СписокЗначений, ЭтаФорма.Элементы[СтруктДанных.ИмяКнопкиПредставления]);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработчик открытия списка динамического меню завершение 
//
// Параметры:
//  Результат	 - 	 - 
//  ДопПараметры - 	 - 
//
Процедура ОбработчикОткрытияСпискаДинамическогоМенюЗавершение(Результат, ДопПараметры) Экспорт
	
 	ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.План;

	// Обрабатываем результат выбора
	Если Результат <> Неопределено  Тогда
		
		ДопПараметры.Вставить("РезультатЗначение", Результат.Значение);
		ДопПараметры.Вставить("РезультатПредставление", Результат.Представление);
		
		ОбработчикНажатияСпискаДинамическогоМенюСерверЗавершение(ДопПараметры)	 				
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Функция - Обработчик нажатия списка динамического меню сервер 
//
// Параметры:
//  КомандаИмя		 - 	 - 
//  КомандаИмяРод	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОбработчикНажатияСпискаДинамическогоМенюСервер(КомандаИмя)
	
	Возврат УправлениеИнтерфейсамиСервер.ОбработчикНажатияСпискаДинамическогоМеню(ЭтаФорма, КомандаИмя);
	
КонецФункции

&НаСервере
// Процедура - Обработчик нажатия списка динамического меню сервер завершение 
//
// Параметры:
//  СтруктДанных - 	 - 
//
Процедура ОбработчикНажатияСпискаДинамическогоМенюСерверЗавершение(СтруктДанных)
	
	// Обработка выбранного значения
	УправлениеИнтерфейсамиСервер.ОбработчикНажатияСпискаДинамическогоМенюЗавершение(ЭтаФорма, СтруктДанных);
	
	ПриИзмененииОтборовСервер(ЭтаФорма.Элементы[СтруктДанных.ИмяКнопкиПредставления].ИмяКоманды);
	
КонецПроцедуры

#КонецОбласти

#Область __________________________ОБНОВИТЬ_ДИНАМИЧЕСКИЕ_МЕНЮ___________________________

&НаСервере
// Процедура создания динамических меню отборов
Процедура ОбновитьДинамическиеМенюОтборов(ЧтоОбновить = "Все", ЗначениеПоУмолчанию = Неопределено)
	
	// Подготовка переключателя отбора статуса выполненности задачи
	Если СтрНайти(ЧтоОбновить,"Все") > 0
		ИЛИ СтрНайти(ЧтоОбновить,"Отборы") > 0 
		ИЛИ СтрНайти(ЧтоОбновить,"ОтборСтатусыВыполненности") > 0 Тогда
		
		ОбновитьДинамическоеМенюОтборСтатусыВыполненности();
		
	КонецЕсли;
	
	// Подготовка переключателя отбора видов взаимодействий задачи
	Если СтрНайти(ЧтоОбновить,"Все") > 0
		ИЛИ СтрНайти(ЧтоОбновить,"Отборы") > 0 
		ИЛИ СтрНайти(ЧтоОбновить,"ОтборВидыВзаимодействий") > 0 Тогда
		
		ОбновитьДинамическоеМенюОтборВидыВзаимодействий();
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Процедура - Обновить динамическое меню отбор статус выполненности 
//
Процедура ОбновитьДинамическоеМенюОтборСтатусыВыполненности(ОтборСтатусВыполненности = Неопределено)
	
	МассивСтатусовВыполненности = Новый  Массив;
	МассивСтатусовВыполненности.Добавить(Новый Структура("Значение, Представление, Выбор", Истина	, Нстр("ru = 'Выполнена'; en = 'Completed'")		, Ложь));
	МассивСтатусовВыполненности.Добавить(Новый Структура("Значение, Представление, Выбор", Ложь		, Нстр("ru = 'Не выполнена'; en = 'Not completed'")	, Ложь));   
	
	Если ЗначениеЗаполнено(ОтборСтатусВыполненности) Тогда 
		ЗначениеПоУмолчанию = ОтборСтатусВыполненности;		
		ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(МассивСтатусовВыполненности, "Значение", ОтборСтатусВыполненности).Выбор = Истина;
	КонецЕсли;
	
	МассивДанных = Новый Массив;		
	МассивДанных.Добавить(Новый Структура("Значение, Представление, ИмяПодчиненногоМеню, МассивЗначений", "Статус", "ПереключательСтатусыВыполненности", "ПодчиненноеМенюОтборСтатусыВыполненности", МассивСтатусовВыполненности));	
	
	УправлениеИнтерфейсамиСервер.СоздатьДинамическоеМенюФормыРасписанияЗанятий(
	"МенюОтборСтатусыВыполненности",
	ЭтаФорма, 
	Элементы.ГруппаОтборСтатусыВыполненности,
	МассивДанных, 
	"ОбработчикНажатияЭлементаДинамическогоМеню",
	ЗначениеПоУмолчанию,,
	Истина,,,,
	Новый Структура("ШиринаЭлемента", 6),,
	"Отбор");

КонецПроцедуры

&НаСервере
// Процедура - Обновить динамическое меню отбор статус выполненности 
//
Процедура ОбновитьДинамическоеМенюОтборВидыВзаимодействий(ОтборВидВзаимодействия = Неопределено)
	
	// Получим таблицу всех видов взаимодействий
	ТаблицаВидовВзаимодействий 	= Справочники.ВидыВзаимодействий.ПолучитьТаблицуВзаимодействий();
	// Подготовка массива видов взаимодействий                                              	
	МассивВидовВзаимодействий 	= Новый Массив;
	Для Каждого СтрокаТаблицы Из ТаблицаВидовВзаимодействий Цикл 
		МассивВидовВзаимодействий.Добавить(Новый Структура("Значение, Представление, Выбор, Код", СтрокаТаблицы.Ссылка, СтрокаТаблицы.Наименование, Ложь, СтрокаТаблицы.Ссылка.УникальныйИдентификатор()));
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ОтборВидВзаимодействия) Тогда 
		ЗначениеПоУмолчанию = ОтборВидВзаимодействия;
		Если ТипЗнч(ОтборВидВзаимодействия) = Тип("СправочникСсылка.ВидыВзаимодействий") Тогда 
			НайденноеЗначение   = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(МассивВидовВзаимодействий, "Значение", ОтборВидВзаимодействия);
			Если НайденноеЗначение <> Неопределено Тогда 
				НайденноеЗначение.Выбор = Истина;
			КонецЕсли;			
		ИначеЕсли ТипЗнч(ОтборВидВзаимодействия) = Тип("Массив") Тогда	
			Для Каждого ЭлементМассива Из ОтборВидВзаимодействия Цикл 
				НайденноеЗначение   = ОбщегоНазначенияКлиентСерверСтоматология.НайтиВМассивеСтруктур(МассивВидовВзаимодействий, "Значение", ЭлементМассива);
				Если НайденноеЗначение <> Неопределено Тогда 
					НайденноеЗначение.Выбор = Истина;
				КонецЕсли;			
			КонецЦикла;	
		КонецЕсли;	
	КонецЕсли;
	
	МассивДанных = Новый Массив;		
	МассивДанных.Добавить(Новый Структура("Значение, Представление, ИмяПодчиненногоМеню, МассивЗначений", "Взаимодействие", "ПереключательВидыВзаимодействий", "ПодчиненноеМенюОтборВидыВзаимодействий", МассивВидовВзаимодействий));	
	
	УправлениеИнтерфейсамиСервер.СоздатьДинамическоеМенюФормыРасписанияЗанятий(
	"МенюОтборВидыВзаимодействий",
	ЭтаФорма, 
	Элементы.ГруппаОтборВидыВзаимодействий,
	МассивДанных, 
	"ОбработчикНажатияЭлементаДинамическогоМеню",
	ЗначениеПоУмолчанию,,
	Истина,,,,
	Новый Структура("ШиринаЭлемента", 14),,
	"Отбор");

КонецПроцедуры

#КонецОбласти

&НаСервере
// При изменении состава отборов
//
Процедура ПриИзмененииОтборовСервер(знач ИмяЭлемента)
		
	ИмяМеню = Неопределено;
	
	ЭлементФормы        = УправлениеИнтерфейсамиСервер.ЭлементФормыПоИмениЭлемента(ЭтаФорма, ИмяЭлемента);
	ИмяЭлемента         = ЭлементФормы.Имя;
	ОбновитьПланировщик = УправлениеИнтерфейсамиСервер.ОбработчикЭлементаДинамическогоМенюПриНажатии(ЭтаФорма, ИмяЭлемента);
	 
	// Селектирование страниц филтров в зависимости от переключателей
	Если УправлениеИнтерфейсамиСервер.ЭтоЭлементБыстрогоВыбора(ИмяЭлемента) Тогда
		
		ИмяМеню = УправлениеИнтерфейсамиСервер.ИмяДинамическогоМенюФормыИзЭлемента(ИмяЭлемента);
		                    		
		// Если сменился период отображения, необходимо обновить меню отборов 
		Если СтрНайти(ИмяЭлемента,"КнопкаПрименить") > 0 
			ИЛИ СтрНайти(ИмяЭлемента,"УдалитьЗначение") > 0 Тогда
			
			ОбновитьДинамическиеМенюОтборов("ПереключательПериод");
			// ДатаПриИзмененииСервер(Ложь);
			
			Если СтрНайти(ИмяМеню, "МенюОтборПомещения") > 0 
				И ЭтотОбъект.ОтборПредставление = "Сотрудники" Тогда
				
				ОбновитьДинамическиеМенюОтборов("Отборы");
				
			ИначеЕсли СтрНайти(ИмяМеню, "МенюОтборСотрудники") > 0 
				И ЭтотОбъект.ОтборПредставление = "Помещения" Тогда
				
				ОбновитьДинамическиеМенюОтборов("ОтборТипыЗанятий, ОтборПодразделения, ОтборСотрудники");
				ОбновитьДинамическиеМенюОтборов("ОтборПомещения, ОтборУслуги, ОтборСтатусыЗанятия");

			ИначеЕсли СтрНайти(ИмяМеню, "МенюОтборСотрудники") > 0 Тогда
				
				ОбновитьДинамическиеМенюОтборов("Отборы");
				
			КонецЕсли;
			
		КонецЕсли; 
		
	КонецЕсли;
	
	// Обновить планировщик
	Если ОбновитьПланировщик Тогда 
		ОбновитьДанныеДляОтображения();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти


