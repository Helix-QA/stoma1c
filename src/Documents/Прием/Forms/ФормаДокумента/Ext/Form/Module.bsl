&НаКлиенте
// Процедура, выполянет завершение обработки штрихкода 
//
Процедура ПоискПоПромокодуЗавершение(Значение, ДополнительныеПараметры) Экспорт
	
	ТекущийПромокод = ?(Значение = Неопределено, ДополнительныеПараметры.ТекущийПромокод, Значение);
	
	Если НЕ ПустаяСтрока(ТекущийПромокод) Тогда
		
		ДанныеПромокода = ПолучитьДанныеПромокода(ТекущийПромокод, Объект.Контрагент); 
		
		Если ДанныеПромокода.ПромокодСуществует Тогда				
			
			Объект.Промокод	= ТекущийПромокод;
			
			Элементы.ГруппаИнформацияПоОплатеПодробно.Видимость  = Истина;			
			ОтобразитьИнформациюПоОплате();	
			ПересчитатьАвтоматическиеСкидки();
			ОбработкаТабличныхЧастейКлиент.ОбновитьЗаголовкиТабЧастей(ЭтаФорма);
			
		Иначе		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ДанныеПромокода.ТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает данные промокода.
//
Функция ПолучитьДанныеПромокода(Промокод, Контрагент)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Промокоды.Владелец КАК Владелец,
	|	Промокоды.Вид КАК Вид,
	|	Промокоды.Активен КАК Активен
	|ИЗ
	|	РегистрСведений.Промокоды КАК Промокоды
	|ГДЕ
	|	Промокоды.Промокод = &Промокод");
	
	Запрос.УстановитьПараметр("Промокод", Промокод);
	
	Результат = Запрос.Выполнить().Выгрузить();	

	ТекстОшибки = "";
	Если Результат.Количество() = 0 Тогда
		ТекстОшибки = НСтр("ru = 'Промокод не существует'");                                     	
	ИначеЕсли НЕ Результат[0].Активен Тогда
		ТекстОшибки = НСтр("ru = 'Промокод не активен'");                                        	
	ИначеЕсли Результат[0].Владелец = Контрагент Тогда
		ТекстОшибки = НСтр("ru = 'Распространитель не может использовать свой реферальный код'");		
	ИначеЕсли Результат[0].Вид.ПометкаУдаления = Истина Тогда
		ТекстОшибки = НСтр("ru = 'Промоакция удалена'");		
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ТекстОшибки"       , ТекстОшибки);
	СтруктураВозврата.Вставить("ПромокодСуществует", ?(ТекстОшибки = "", Истина, Ложь ));	
	СтруктураВозврата.Вставить("ВидПромокода"	   , ?(Результат.Количество() > 0, Результат[0].Вид,      Неопределено));
	СтруктураВозврата.Вставить("Владелец"		   , ?(Результат.Количество() > 0, Результат[0].Владелец, Неопределено));
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаКлиенте
// Процедура  обработчик "ВопросУдалитьПромокодЗавершение".
//
Процедура ВопросУдалитьПромокодЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		УдалитьПромокод(Параметры);
		
	КонецЕсли; 
	
