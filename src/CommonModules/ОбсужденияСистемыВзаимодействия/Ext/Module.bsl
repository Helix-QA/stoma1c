// Функция, возвращает список сотрудников, соответствующих переданным пользователям ИБ.
//
Функция ПолучитьСотрудниковПоИдентификаторПользователяИБ(ПользователиИБ)
	
	МассивИдентификаторов = Новый Массив;
	Если ТипЗнч(ПользователиИБ) = Тип("ПользовательИнформационнойБазы") Тогда
		МассивИдентификаторов.Добавить(ПользователиИБ.УникальныйИдентификатор);
	ИначеЕсли ТипЗнч(ПользователиИБ) = Тип("Массив") Тогда
		Для каждого Пользователь из ПользователиИБ Цикл
			МассивИдентификаторов.Добавить(Пользователь.УникальныйИдентификатор);		
		КонецЦикла;
	КонецЕсли;
	
	Запрос = Новый Запрос(	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Пользователи.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.ИдентификаторПользователяИБ В(&ИдентификаторПользователяИБ)
	|	И Пользователи.ПометкаУдаления = ЛОЖЬ
	|	И Пользователи.ЭтоПользовательИБ = ИСТИНА");
	
	Запрос.УстановитьПараметр("ИдентификаторПользователяИБ", МассивИдентификаторов);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция, возвращает список пользователей, соответсвующих переданным сотрудникам.
Функция ПолучитьСписокСотрудниковПоСотрудникам(Сотрудники)
	
	// Проверяем, если массив с Пользователями возвращаем его.
	Если ТипЗнч(Сотрудники) = Тип("Массив") Тогда
		Для каждого Сотрудник из Сотрудники Цикл
			Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Пользователи") Тогда
				ПользователиИБ = Истина;
				Возврат Сотрудники; 
			Иначе
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Пользователи.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.Сотрудник В(&Сотрудники)
	|	И Пользователи.ПометкаУдаления = ЛОЖЬ
	|	И Пользователи.ЭтоПользовательИБ = ИСТИНА");
	Запрос.УстановитьПараметр("Сотрудники", Сотрудники);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Функция, удаляет дубли из массива пользователей и возвращает результат.
//
Функция ПолучитьМассивУникальныхПользователей(ПользователиИБ)
	
	Результат					 = Новый Массив;
	СоответствиеПользователей	 = Новый Соответствие;
	
	Для Каждого Пользователь Из ПользователиИБ Цикл
		СоответствиеПользователей.Вставить(Пользователь.УникальныйИдентификатор, Пользователь);
	КонецЦикла;
	
	Для Каждого Пользователь Из СоответствиеПользователей Цикл
		Результат.Добавить(Пользователь.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Создает нового пользователя системы взаимодействий и заполняет его данными пользователя
// информационной базы.
//
// Выбрасывает исключение, если не удалось создать нового пользователя системы Взаимодействия.
//
// Параметры:
// 	Пользователь - СправочникиСсылка.Пользователи - пользователь, для которого будет создан
//													пользователь системы взаимодействия.
// Возвращаемое значение:
// 	ПользовательСистемыВзаимодействия
//
Функция НовыйПользовательСистемыВзаимодействия(Пользователь)
	
	ОписаниеПользователя = ОписаниеПользователя(Пользователь);
	
	Если НЕ ЗначениеЗаполнено(ОписаниеПользователя.ИдентификаторПользователяИБ) Тогда
		ВызватьИсключение НСтр("ru='Не существует пользователь информационной базы'");
	КонецЕсли;
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ОписаниеПользователя.ИдентификаторПользователяИБ);
	ПользовательСВ = СистемаВзаимодействия.СоздатьПользователя(ПользовательИБ);
	
	ОбновитьОписаниеПользователяВСистемеВзаимодействия(ПользовательСВ, ОписаниеПользователя);
	
	Возврат ПользовательСВ;
	
КонецФункции

Процедура ОбновитьОписаниеПользователяВСистемеВзаимодействия(ПользовательСВ, ОписаниеПользователя)
	
	Фотография = ОписаниеПользователя.ФайлКартинки;
	Если Фотография <> Неопределено Тогда 	
		ДанныеКартинки = РаботаСФайламиВызовСервера.ПолучитьДанныеФайлаИДвоичныеДанные(Фотография);
		ПользовательСВ.Картинка = Новый Картинка(ДанныеКартинки.ДвоичныеДанные);
	КонецЕсли;
	
	ПользовательСВ.Заблокирован = ОписаниеПользователя.ПометкаУдаления;
	
	УстановитьПривилегированныйРежим(Истина);
	ПользовательСВ.Записать();
	
КонецПроцедуры
 
Функция ОписаниеПользователя(Пользователь)
	
	Результат = Новый Структура;
	Результат.Вставить("Наименование"				, "");
	Результат.Вставить("ИдентификаторПользователяИБ", "");
	Результат.Вставить("ФайлКартинки");
	Результат.Вставить("ПометкаУдаления"			, Истина);
	
	СвойстваПользователя = ?(ТипЗнч(Пользователь) = Тип("СправочникОбъект.Сотрудники"),
	Пользователь,
	ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Пользователь,
	" Наименование,
	| ИдентификаторПользователяИБ,
	| ФайлКартинки,
	| ПометкаУдаления"));
	ЗаполнитьЗначенияСвойств(Результат, СвойстваПользователя);
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьПолучателей(ПолучателиПриемник, ПолучателиИсточник)
	
	Если ПолучателиИсточник.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПолучателиПользователиИБ = ТипЗнч(ПолучателиИсточник) = Тип("Соответствие") 
	ИЛИ (ТипЗнч(ПолучателиИсточник) = Тип("Массив") 
	И ТипЗнч(ПолучателиИсточник[0]) = Тип("СправочникСсылка.Пользователи"));
	
	Если ПолучателиПользователиИБ Тогда
		Для каждого Получатель Из ПолучателиИсточник Цикл
			
			Если Получатель.Значение <> Неопределено Тогда
				ПолучателиПриемник.Добавить(Получатель.Значение.Идентификатор);
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе	
		Для каждого Получатель Из ПолучателиИсточник Цикл
			Если ТипЗнч(Получатель) = Тип("ИдентификаторПользователяСистемыВзаимодействия") Тогда
				ПолучателиПриемник.Добавить(Получатель);
			Иначе	
				ПолучателиПриемник.Добавить(Получатель.Идентификатор);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция ЭлементСоответствия(Соответствие, Индекс)
	
	Сч = 0;
	Для каждого КлючЗначение Из Соответствие Цикл
		Если Сч = Индекс Тогда
			Возврат КлючЗначение;
		КонецЕсли;
		Сч = Сч + 1;
	КонецЦикла;
	
КонецФункции

// Параметры:
//  Автор	 - ИдентификаторПользователяСистемыВзаимодействия
//  Участник - ИдентификаторПользователяСистемыВзаимодействия
// 
// Возвращаемое значение:
//    ОбсуждениеСистемыВзаимодействия
//
Функция НеГрупповоеОбсуждениеМеждуПользователями(Автор, Участник)
	
	Обсуждение = Неопределено;
	
	Отбор = Новый ОтборОбсужденийСистемыВзаимодействия;
	Отбор.КонтекстноеОбсуждение = Ложь;
	Отбор.Групповое 			= Ложь;
	НайденныеОбсуждения = СистемаВзаимодействия.ПолучитьОбсуждения(Отбор);
	
	Для каждого ОтобранноеОбсуждение Из НайденныеОбсуждения Цикл
		Если ОтобранноеОбсуждение.Участники.Содержит(Участник) 
			И ОтобранноеОбсуждение.Участники.Содержит(Автор) Тогда
			
			Обсуждение = ОтобранноеОбсуждение;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Обсуждение = Неопределено Тогда
		Обсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
		Обсуждение.Отображаемое = Истина;
		Обсуждение.Групповое = Ложь;
		Обсуждение.Участники.Добавить(Автор);
		Обсуждение.Участники.Добавить(Участник);
		Обсуждение.Записать();
	КонецЕсли;
	
	Возврат Обсуждение;
	
КонецФункции

// Функция, возвращаем массив с идентификаторами пользователей в системе взаимодействия.
//
Функция ПолучателиСообщенияВСистемеВзаимодействия(Сотрудники)
	
	Получатели = Новый Массив;
	
	Если ТипЗнч(Сотрудники) = Тип("Массив") Тогда
		
		Для каждого Сотрудник из Сотрудники Цикл
			
			ИдентификаторПользователяИБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сотрудник, "ИдентификаторПользователяИБ");	
			Если ЗначениеЗаполнено(ИдентификаторПользователяИБ) Тогда
				Попытка
					ПользовательСистемыВзаимодейтсвия = СистемаВзаимодействия.ПолучитьИдентификаторПользователя(ИдентификаторПользователяИБ);
					Получатели.Добавить(ПользовательСистемыВзаимодейтсвия);
				Исключение
					Продолжить;
				КонецПопытки;
			КонецЕсли;	
			
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Сотрудники) = Тип("СправочникСсылка.Сотрудники") Тогда	
		
		ИдентификаторПользователяИБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сотрудники, "ИдентификаторПользователяИБ");	
		Если ЗначениеЗаполнено(ИдентификаторПользователяИБ) Тогда
			Попытка
				ПользовательСистемыВзаимодейтсвия = СистемаВзаимодействия.ПолучитьИдентификаторПользователя(ИдентификаторПользователяИБ);
				Получатели.Добавить(ПользовательСистемыВзаимодейтсвия);
			Исключение
			КонецПопытки;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Получатели;
	
КонецФункции 

// Функция - Оповестить остальных пользователей об изменении
//
// Параметры:
//  Событие	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ОповеститьПользователейОбИзмененииРабочегоСтола(Событие) Экспорт

	ИспользоватьСистемуВзаимодействия = ОбсужденияСистемыВзаимодействия.СистемаВзаимодействияВключена();
	
	Если ИспользоватьСистемуВзаимодействия = Истина Тогда
		
		ТекущиеСеансы 		   = ПолучитьСеансыИнформационнойБазы();
		НомерСеанса   		   = НомерСеансаИнформационнойБазы();
		ПользователиОповещения = Новый Массив;
			
		Для Каждого ТекущийСеанс Из ТекущиеСеансы Цикл
			
			Если НомерСеанса <> ТекущийСеанс.НомерСеанса
				И (ТекущийСеанс.ИмяПриложения = "1CV8C"
				ИЛИ ТекущийСеанс.ИмяПриложения = "WebClient") Тогда
				
				ПользователиОповещения.Добавить(ТекущийСеанс.Пользователь);
			КонецЕсли;
			
		КонецЦикла;
		
		СтруктурнаяЕдиница = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Событие, "СтруктурнаяЕдиница");
		Дата     		   = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Событие, "Дата");
		
		Если ЗначениеЗаполнено(ПользователиОповещения) Тогда
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("Ключ"			     , "ОбновлениеРабочегоСтола");
			ДанныеСообщения.Вставить("СтруктурнаяЕдиница", ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(СтруктурнаяЕдиница));
			ДанныеСообщения.Вставить("Событие"			 , ОбсужденияСистемыВзаимодействия.ПроверитьЗаполненностьЭлемента(Событие));
			ДанныеСообщения.Вставить("ДатаСобытия"		 , Дата);  
			
			ОбсужденияСистемыВзаимодействия.ДобавитьСообщениеВСистемуВзаимодействия(ДанныеСообщения,, ПользователиОповещения);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

// Функция - Получить идентификатор пользователя системы взаимодействия
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьИдентификаторПользователяСистемыВзаимодействия()
	
	// Проверяем, может ли пользователь рассылки пользоваться СВ
	Попытка
		ИдентификаторПользователя = СистемаВзаимодействия.ИдентификаторТекущегоПользователя();	
	Исключение
	КонецПопытки; 
	
	// Если нельзя пробуем сделать отправку через служебного пользователя.
	Попытка
		Если ИдентификаторПользователя = Неопределено Тогда
			СистемнаяИнформация = Новый СистемнаяИнформация();
			ВерсияПлатформы = СистемнаяИнформация.ВерсияПриложения; 
			
			Если ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ВерсияПлатформы, "8.3.20.0") >= 0 Тогда
				СлужебныйПользователь = ПользователиИнформационнойБазы.НайтиПоИмени("ServiceUserAPI");
				Если СлужебныйПользователь <> Неопределено Тогда
					ПользовательИБ = СлужебныйПользователь.УникальныйИдентификатор;
					СистемаВзаимодействия.УстановитьТекущегоПользователя(ПользовательИБ);
					ИдентификаторПользователя = СистемаВзаимодействия.ИдентификаторТекущегоПользователя();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли; 
	Исключение
		//ЗаписьЖурналаРегистрации(НСтр("ru='Поиск обсуждения Системы взаимодействия по ключу'"), УровеньЖурналаРегистрации.Ошибка,, КлючОбсуждения, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки; 
	
	Возврат ИдентификаторПользователя; 
	
КонецФункции

// Функция - Получить активных пользователей для оповещения
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьАктивныхПользователейДляОповещения(СтруктурнаяЕдиница) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СоединенияИнформационнойБазы.Пользователь КАК Пользователь,
	|	СоединенияИнформационнойБазы.НачалоСоединения КАК НачалоСоединения
	|ПОМЕСТИТЬ ВтАктивныеСотрудники
	|ИЗ
	|	РегистрСведений.СоединенияИнформационнойБазы КАК СоединенияИнформационнойБазы
	|ГДЕ
	|	НЕ СоединенияИнформационнойБазы.Пользователь = &Сотрудник
	|			И НЕ СоединенияИнформационнойБазы.Пользователь = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник
	|ПОМЕСТИТЬ ВтСотрудники
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ВтАктивныеСотрудники.Пользователь
	|			ИЗ
	|				ВтАктивныеСотрудники)
	|	И Сотрудники.ДоступныеСтруктурныеЕдиницы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Ссылка В
	|			(ВЫБРАТЬ
	|				ВтАктивныеСотрудники.Пользователь
	|			ИЗ
	|				ВтАктивныеСотрудники)
	|	И Сотрудники.ДоступныеСтруктурныеЕдиницыЖурналаЗаписи.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ОткрытыеФормы.Сотрудник КАК Сотрудник,
	|	ОткрытыеФормы.ДатаОткрытия КАК ДатаОткрытия,
	|	ВтАктивныеСотрудники.НачалоСоединения КАК НачалоСоединения
	|ИЗ
	|	РегистрСведений.ОткрытыеФормы КАК ОткрытыеФормы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтАктивныеСотрудники КАК ВтАктивныеСотрудники
	|		ПО ОткрытыеФормы.Сотрудник = ВтАктивныеСотрудники.Пользователь
	|ГДЕ
	|	ОткрытыеФормы.Сотрудник В
	|			(ВЫБРАТЬ
	|				ВтСотрудники.Сотрудник
	|			ИЗ
	|				ВтСотрудники)
	|	И (ОткрытыеФормы.ИмяФормы = ""ЖурналЗаписи.Форма""
	|			ИЛИ ОткрытыеФормы.ИмяФормы = ""РабочийКалендарь.ФормаЗаписи"")");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник"	      , ПараметрыСеанса.ТекущийСотрудник);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ПользователиОповещения = Новый Массив;	
	Пока Выборка.Следующий() Цикл
		Если ПользователиОповещения.Найти(Выборка.Сотрудник) = Неопределено  
			И Выборка.ДатаОткрытия >= Выборка.НачалоСоединения Тогда
			
			ПользователиОповещения.Добавить(Выборка.Сотрудник);
		КонецЕсли;
	КонецЦикла;

	Возврат ПользователиОповещения;
	
КонецФункции

#КонецОбласти