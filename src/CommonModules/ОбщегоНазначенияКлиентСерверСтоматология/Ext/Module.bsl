// Возвращает текстовое представление интервала времени, заданного в секундах.
//
// Параметры:
//
//  Время - Число - интервал времени в секундах.
//
//  ПолноеПредставление	- Булево - кратное или полное представление времени.
//		Например, интервал 1 000 000 секунд:
//		- полное представление:  11 дней 13 часов 46 минут 40 секунд;
//		- краткое представление: 11 дней 13 часов.
//
// Возвращаемое значение:
//   Строка - представление интервала времени.
//
Функция ПредставлениеВремени(Знач Время, ПолноеПредставление = Истина, ВыводитьСекунды = Истина, СокращатьОбозначения = Истина) Экспорт
	
	Результат = "";
	
	Если СокращатьОбозначения Тогда 
		ПредставлениеНедель = НСтр("ru = ';%1 нед.;;%1 нед.;%1 нед.;%1 нед.'");
		ПредставлениеДней   = НСтр("ru = ';%1 дн.;;%1 дн.;%1 дн.;%1 дн.'");
		ПредставлениеЧасов  = НСтр("ru = ';%1 ч.;;%1 ч.;%1 ч.;%1 ч.'");
		ПредставлениеМинут  = НСтр("ru = ';%1 мин.;;%1 мин.;%1 мин.;%1 мин.'");
		ПредставлениеСекунд = НСтр("ru = ';%1 сек.;;%1 сек.;%1 сек.;%1 сек.'");
	Иначе 	
		// Представление единиц измерения времени в винительном падеже для количеств: 1, 2-4, 5-20.
		ПредставлениеНедель = НСтр("ru = ';%1 неделю;;%1 недели;%1 недель;%1 недели'");
		ПредставлениеДней   = НСтр("ru = ';%1 день;;%1 дня;%1 дней;%1 дня'");
		ПредставлениеЧасов  = НСтр("ru = ';%1 час;;%1 часа;%1 часов;%1 часа'");
		ПредставлениеМинут  = НСтр("ru = ';%1 минуту;;%1 минуты;%1 минут;%1 минуты'");
		ПредставлениеСекунд = НСтр("ru = ';%1 секунду;;%1 секунды;%1 секунд;%1 секунды'");
	КонецЕсли;
	
	Время = Число(Время);
	
	Если Время < 0 Тогда
		Время = -Время;
	КонецЕсли;
	
	КоличествоНедель = Цел(Время / 60/60/24/7);
	КоличествоДней   = Цел(Время / 60/60/24);
	КоличествоЧасов  = Цел(Время / 60/60);
	КоличествоМинут  = Цел(Время / 60);
	КоличествоСекунд = Цел(Время);
	
	КоличествоСекунд = КоличествоСекунд - КоличествоМинут * 60;
	КоличествоМинут  = КоличествоМинут - КоличествоЧасов * 60;
	КоличествоЧасов  = КоличествоЧасов - КоличествоДней * 24;
	КоличествоДней   = КоличествоДней - КоличествоНедель * 7;
	
	Если Не ВыводитьСекунды Тогда
		КоличествоСекунд = 0;
	КонецЕсли;
	
	Если КоличествоНедель > 0 И КоличествоДней+КоличествоЧасов+КоличествоМинут+КоличествоСекунд=0 Тогда
		Результат = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(ПредставлениеНедель, КоличествоНедель);
	Иначе
		КоличествоДней = КоличествоДней + КоличествоНедель * 7;
		
		Счетчик = 0;
		Если КоличествоДней > 0 Тогда
			Результат = Результат + СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(ПредставлениеДней, КоличествоДней) + " ";
			Счетчик = Счетчик + 1;
		КонецЕсли;
		
		Если КоличествоЧасов > 0 Тогда
			Результат = Результат + СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(ПредставлениеЧасов, КоличествоЧасов) + " ";
			Счетчик = Счетчик + 1;
		КонецЕсли;
		
		Если (ПолноеПредставление Или Счетчик < 2) И КоличествоМинут > 0 Тогда
			Результат = Результат + СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(ПредставлениеМинут, КоличествоМинут) + " ";
			Счетчик = Счетчик + 1;
		КонецЕсли;
		
		Если (ПолноеПредставление Или Счетчик < 2) И (КоличествоСекунд > 0 Или КоличествоНедель+КоличествоДней+КоличествоЧасов+КоличествоМинут = 0) Тогда
			Результат = Результат + СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(ПредставлениеСекунд, КоличествоСекунд);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СокрП(Результат);
	
КонецФункции

// Функция - Получить остаток времени выполнения процесса в секундах
//
// Параметры:
//  ПроцентВыполнения	 - 	 - 
//  ДатаНачалаПроцесса	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьОстатокВремениВыполненияПроцессаВСекундах(Знач ПроцентВыполнения, Знач ДатаНачалаПроцесса, Знач ТекущаяДатаВыполненияПроцесса, Знач ОсталосьВремени) Экспорт 
	
	ВременнойКоэффициент 	= 100 / ?(ПроцентВыполнения < 1, 1, ПроцентВыполнения);
	ВремениПрошлоВСекундах 	= ТекущаяДатаВыполненияПроцесса - ДатаНачалаПроцесса;
	ВремениПрошлоВСекундах 	= ?(ВремениПрошлоВСекундах < 1, 1, ВремениПрошлоВСекундах);
	ОбщееВремяВСекундах		= Цел(ВремениПрошлоВСекундах * ВременнойКоэффициент);
	ОсталосьВСекундах 		= ОбщееВремяВСекундах - ВремениПрошлоВСекундах;
	ОсталосьВСекундах 		= ?(ОсталосьВСекундах < 1, 0, ОсталосьВСекундах);
	ОсталосьВСекундах 		= ?(ОсталосьВремени = Неопределено ИЛИ ПроцентВыполнения < 2, ОсталосьВСекундах, ?(ОсталосьВСекундах > ОсталосьВремени, ОсталосьВремени, ОсталосьВСекундах));	
	
	Возврат ОсталосьВСекундах;
	
КонецФункции

// Функция возвращает интервалы времени
// 
//  Параметры
//   МассивПериодов - структура, периоды, между которыми необходимо возвратить интервалы
//   Интервал - число, интервал в минутах
//   Формат - строка, представление интервала
//
// Возвращаемое значение:
//   СписокЗначений, список времени с интервалом.
//
Функция ВернутьСписокВремени(МассивПериодов, ДатаНачала, Интервал = Неопределено, Формат = "ДФ=ЧЧ:мм", НачинаяСВремени = Неопределено) Экспорт

	СписокВремени = Новый СписокЗначений;
	Если Интервал = Неопределено Тогда
		// Интервал = Пользователи.ПолучитьЗначениеПоУмолчаниюПользователя(, "ИнтервалГрафикаЗанятий");
		Интервал = ?(ЗначениеЗаполнено(Интервал), Число(Сред(Интервал, 1, 2)), 15);
	КонецЕсли;
	
	Для Каждого Период Из МассивПериодов Цикл
		Если ДатаНачала Тогда
			ИндексУвелВремени = 0;
		Иначе
			ИндексУвелВремени = 1;
		КонецЕсли;
		
		Период.ДатаНачала = НачалоЧаса(Период.ДатаНачала) + Цел (Минута(Период.ДатаНачала) / 15) * 15 * 60;
		Пока Период.ДатаНачала + Интервал * 60 * ИндексУвелВремени <= Период.ДатаОкончания Цикл
			Время = Период.ДатаНачала + Интервал * 60 * ИндексУвелВремени;
			
			// Если указан параметр стартовой даты, начинать от нее
			Если НачинаяСВремени = Неопределено ИЛИ Время >= НачинаяСВремени Тогда				
				Если СписокВремени.НайтиПоЗначению(Время) = Неопределено Тогда
					Если НЕ ЗначениеЗаполнено(Время) Тогда
						СписокВремени.Добавить(Время, "00:00");
					Иначе
						СписокВремени.Добавить(Время, Формат(Время, Формат));
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
			ИндексУвелВремени = ИндексУвелВремени + 1;
		КонецЦикла;
		
		Если Период.ДатаОкончания = Дата(01,01,01,23,59,59) И НЕ ДатаНачала Тогда
			СписокВремени.Добавить(Период.ДатаНачала + Интервал * 60 * ИндексУвелВремени, "00:00");
		КонецЕсли;
	КонецЦикла;

	Возврат СписокВремени; 
	
КонецФункции

// Функция - Представление минут
//
// Параметры:
//  Минуты	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПредставлениеМинут(Знач Минуты) Экспорт
	
	Если Минуты < 60 Тогда
		Возврат Строка(Цел(Минуты)) + " мин";		
	Иначе	
	    Часы  = Цел(Минуты / 60);
		Минут = Цел(Минуты - (Часы * 60));
		
		Возврат Строка(Часы) + " ч" + ?(Минут > 0, " " + Минут + " мин", "");
	КонецЕсли;
	
КонецФункции

// Функция - Вернуть представление времени
//
// Параметры:
//  Секунды	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ВернутьПредставлениеВремени(Знач Секунды) Экспорт
	
	Если Секунды < 61 Тогда 
		Возврат Строка(Секунды) + " сек.";
	Иначе
		Минут = Цел(Секунды / 60);
		Возврат ПредставлениеМинут(Минут);
	КонецЕсли;
	
КонецФункции

// Возвращает строки вида "день", "дня", "дней".
//
// Параметры:
//   Число                       - Число  - целое число, к которому нужно добавить предмет исчисления.
//   ФорматнаяСтрока             - Строка - см. одноименный параметр метода ЧислоПрописью,
//                                          например: "Л = ru_RU".
//   ПараметрыПредметаИсчисления - Строка - см. одноименный параметр метода ЧислоПрописью,
//                                          например: НСтр("ru='день,дня,дней,,,,,,0';en='день,of the day,days,,,,,,0'").
//
//  Возвращаемое значение:
//   Строка.
//
Функция ПредметЦелогоЧисла(Число, ФорматнаяСтрока, ПараметрыПредметаИсчисления) Экспорт
	
	ЦелоеЧисло = Цел(Число);
	
	ПрописьЧисла = ЧислоПрописью(ЦелоеЧисло, ФорматнаяСтрока, НСтр("ru=',,,,,,,,0';en=',,,,,,,,0'"));
	
	ПрописьЧислаИПредмета = ЧислоПрописью(ЦелоеЧисло, ФорматнаяСтрока, ПараметрыПредметаИсчисления);
	
	Возврат СтрЗаменить(ПрописьЧислаИПредмета, ПрописьЧисла, "");
	
КонецФункции

// Функция - Дата по номеру недели
//
// Параметры:
//  НомерНедели	 - 	 - 
//  Год			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ДатаПоНомеруНедели(Знач НомерНедели, Год = Неопределено) Экспорт
	
	Если НомерНедели < 1 Тогда 
		НомерНедели = 1;
	КонецЕсли;
	
	Возврат НачалоНедели(Дата(?(Год=Неопределено, Год(ТекущаяДата()), Год),1,1)+(НомерНедели-НеделяГода(Дата(?(Год = Неопределено, Год(ТекущаяДата()), Год), 1, 1))) * 604800);
	
КонецФункции

// Получить представление интервалов времени
//
Функция ПолучитьПредставлениеСпискаИнтерваловВремени(СписокИнтервала) Экспорт
	
	МассивНадстрочныхСимволов = Неопределено;
	СуммМинут                 = 0;
	Для Каждого ЭлементС ИЗ СписокИнтервала Цикл
		НачалоПредст           	= Формат(ЭлементС.Значение.НачалоРаботы		, "ДФ=HH:mm"); 
		КонецПредст            	= Формат(ЭлементС.Значение.ОкончаниеРаботы	, "ДФ=HH:mm"); 
		КоличествоМинут 		= Цел((ЭлементС.Значение.ОкончаниеРаботы - ЭлементС.Значение.НачалоРаботы) / 60);		
		ВремяИнтервала 			= ?(КоличествоМинут > 60, Строка(КонвертироватьМинутыВЧасы(КоличествоМинут)), Строка(КоличествоМинут) + " мин.");
		ЭлементС.Представление 	= НачалоПредст + "-" + КонецПредст + " (" + ВремяИнтервала + ")";
		СуммМинут              = СуммМинут + Цел((ЭлементС.Значение.ОкончаниеРаботы - ЭлементС.Значение.НачалоРаботы) / 60);	
	КонецЦикла;
	
	СуммаВремени  = КонвертироватьМинутыВЧасы(СуммМинут);
	Если ЗначениеЗаполнено(СуммаВремени) Тогда
	    Возврат Строка(СписокИнтервала);
	// ИначеЕсли СуммМинут = 0 Тогда 
	//    Возврат Строка(СписокИнтервала);
	Иначе 	
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

// Получить представление интервалов времени
//
Функция ПолучитьПредставлениеСпискаИнтерваловВремениДляHTML(СписокИнтервала) Экспорт
	
	ПредставлениеСпискаИнтервалов = "";
	КоличествоИнтервалов = СписокИнтервала.Количество();
	Для Каждого ЭлементС ИЗ СписокИнтервала Цикл
		ТегПереносаСтроки 		= ?(СписокИнтервала.Индекс(ЭлементС) + 1 = КоличествоИнтервалов, "", "<br>");
		ПредставлениеСпискаИнтервалов = ПредставлениеСпискаИнтервалов + ЭлементС.Представление + ТегПереносаСтроки;                         
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ПредставлениеСпискаИнтервалов) Тогда
	    Возврат ПредставлениеСпискаИнтервалов;
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

// Функция - Сформировать представление интервала
//
// Параметры:
//  Интервал - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьПредставлениеИнтервала(Интервал) Экспорт

	НачалоПредст           	= ?(Интервал.НачалоРаботы 		= Неопределено	, "Неопределено", Формат(Интервал.НачалоРаботы		, "ДФ=HH:mm")); 
	КонецПредст            	= ?(Интервал.ОкончаниеРаботы 	= Неопределено	, "Неопределено", Формат(Интервал.ОкончаниеРаботы	, "ДФ=HH:mm")); 
	Если Интервал.НачалоРаботы = Неопределено ИЛИ Интервал.ОкончаниеРаботы = Неопределено Тогда 
		КоличествоМинут 	= 0;
	Иначе 	
		КоличествоМинут 	= Цел((Интервал.ОкончаниеРаботы - Интервал.НачалоРаботы) / 60);		
	КонецЕсли;	
	ВремяИнтервала 			= ?(КоличествоМинут > 60, Строка(КонвертироватьМинутыВЧасы(КоличествоМинут)), Строка(КоличествоМинут) + " мин.");
	
	Возврат НачалоПредст + "-" + КонецПредст + " (" + ВремяИнтервала + ")";

КонецФункции

// Вернет конвертированные минуты в часы и остаток минут
//
Функция КонвертироватьМинутыВЧасы(Минуты) Экспорт
	
	Часы  = Цел(Минуты / 60);
	Минут = Минуты - (Часы * 60);
	
	Возврат ?(Часы > 0 ,"" + Часы + НСтр("ru= ' ч.';en= ' h.'"),"") + ?(Минут > 0 ,"" + Минут + НСтр("ru= ' м.';en= ' m.'"),"");
	
КонецФункции

// Функция - Получить картинку по дню недели.
//
// Параметры:
//  Дата - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьКартинкуПоДнюНедели(Дата) Экспорт 
	
	ДеньНедели = ДеньНедели(Дата);
	
	Если ДеньНедели = 1 Тогда	
		Возврат БиблиотекаКартинок.Понедельник;
	ИначеЕсли ДеньНедели = 2 Тогда
		Возврат БиблиотекаКартинок.Вторник;
	ИначеЕсли ДеньНедели = 3 Тогда
		Возврат БиблиотекаКартинок.Среда;
	ИначеЕсли ДеньНедели = 4 Тогда 
		Возврат БиблиотекаКартинок.Четверг;
	ИначеЕсли  ДеньНедели = 5 Тогда 
		Возврат БиблиотекаКартинок.Пятница;
	ИначеЕсли ДеньНедели = 6 Тогда
		Возврат БиблиотекаКартинок.Суббота;
	ИначеЕсли ДеньНедели = 7 Тогда
		Возврат БиблиотекаКартинок.Воскресенье;
	КонецЕсли;	
	
	Возврат БиблиотекаКартинок.Пустая;
	
КонецФункции

#Область ФильтрацияИсторииВзаимодействия 

// Процедура - Заполнить список фильтрации истории взаимодействия по умолчанию.
//
// Параметры:
//  ЗаполняемыйСписокЗначений	 - 	 - 
//  ТипФормы					 - 	 - 
//  ВсплывающаяГруппа			 - 	 - 
//
Процедура ЗаполнитьСписокФильтрацииИсторииВзаимодействияПоУмолчанию (ЗаполняемыйСписокЗначений, Группа = Неопределено, ВремСписокФильтрацииИсторииВзаимодействия = Неопределено, Ссылка) Экспорт
	
	ЗаполняемыйСписокЗначений.Очистить();
	
	Если ЗначениеЗаполнено(Группа) Тогда
		Для Каждого Элемент Из Группа.ПодчиненныеЭлементы Цикл 
			
			Если Не СтрНачинаетсяС(Элемент.Имя, "ГруппаФильтр") Тогда
				Продолжить;	
			КонецЕсли; 
			
			ИмяФильтра = СтрЗаменить(Элемент.Имя, "ГруппаФильтр", "");
			
			ЗаполняемыйСписокЗначений.Добавить(ИмяФильтра,, Ложь); 
			
		КонецЦикла; 
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЗаполняемыйСписокЗначений) Тогда
		Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.Заявки") Тогда
			ЗаполняемыйСписокЗначений.Добавить("Заметки"	, , Ложь);
			ЗаполняемыйСписокЗначений.Добавить("Задачи"		, , Ложь);
            ЗаполняемыйСписокЗначений.Добавить("Сообщения"	, , Ложь);
			ЗаполняемыйСписокЗначений.Добавить("Звонки"		, , Ложь);
		Иначе
			ЗаполняемыйСписокЗначений.Добавить("Заметки"		, , Ложь);
			ЗаполняемыйСписокЗначений.Добавить("Задачи"			, , Ложь);
            ЗаполняемыйСписокЗначений.Добавить("Сообщения"		, , Ложь);
			ЗаполняемыйСписокЗначений.Добавить("Звонки"			, , Ложь);
			ЗаполняемыйСписокЗначений.Добавить("Обращения"		, , Ложь); 
			ЗаполняемыйСписокЗначений.Добавить("События"		, , Ложь); 
			ЗаполняемыйСписокЗначений.Добавить("Приемы"			, , Ложь);
			ЗаполняемыйСписокЗначений.Добавить("ПланыЛечения"	, , Ложь);
           	ЗаполняемыйСписокЗначений.Добавить("НарядЗаказы"	, , Ложь);
		КонецЕсли;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВремСписокФильтрацииИсторииВзаимодействия) Тогда	
		Для Каждого ВремЭлемент Из ВремСписокФильтрацииИсторииВзаимодействия Цикл
			Если ВремЭлемент.Пометка = Истина Тогда
				НайденныйЭлементСпискаЗначений = ЗаполняемыйСписокЗначений.НайтиПоЗначению(ВремЭлемент.Значение);
				
				Если НайденныйЭлементСпискаЗначений <> Неопределено Тогда
					НайденныйЭлементСпискаЗначений.Пометка = Истина;	
				КонецЕсли;
				
			КонецЕсли;                                                                                           
			
		КонецЦикла;
	КонецЕсли;  
			
КонецПроцедуры  

// Процедура - Заполнить список фильтрации истории взаимодействия по умолчанию.
//
// Параметры:
//  ЗаполняемыйСписокЗначений	 - 	 - 
//  ТипФормы					 - 	 - 
//  ВсплывающаяГруппа			 - 	 - 
//
Процедура ЗаполнитьСтруктуруФильтрациИсторииВзаимодйствия (СписокФильтрации, Структура) Экспорт
	
	Для Каждого ЭлементСписка Из СписокФильтрации Цикл
		Структура.Вставить(ЭлементСписка.Значение, ЭлементСписка.Пометка)	
	КонецЦикла
				
КонецПроцедуры  

// Процедура - Отметить выбранные фильтры.
//
// Параметры:
//  ГруппаВсплывающая	 - 	 - 
//  СписокФильтрации	 - 	 - 
//
Процедура ОтметитьВыбранныеФильтры(ГруппаВсплывающая, СписокФильтрации) Экспорт
	
	ЦветВыделеннойГруппы 	= Новый Цвет(218, 230, 244);
	ЦветОбычнойГруппы		= Новый Цвет(255, 255, 255);	
	
	Для Каждого ЭлементФормы Из ГруппаВсплывающая.ПодчиненныеЭлементы Цикл 
		
		Если Не СтрНачинаетсяС(ЭлементФормы.Имя, "ГруппаФильтр") Тогда
			Продолжить;	
		КонецЕсли;	
		
		ИмяФильтра = СтрЗаменить(ЭлементФормы.Имя, "ГруппаФильтр", "");
		
		ЭлементСпискаЗначения = СписокФильтрации.НайтиПоЗначению(ИмяФильтра);
		
		Если ЭлементСпискаЗначения = Неопределено Тогда
			ЭлементФормы.ЦветФона = ЦветОбычнойГруппы;
			Продолжить;
		КонецЕсли;
		
		ЭлементФормы.ЦветФона = ?(ЭлементСпискаЗначения.Пометка = Истина, ЦветВыделеннойГруппы, ЦветОбычнойГруппы); 
			
	КонецЦикла;
	
КонецПроцедуры 

// Процедура - Фильтр истории взаимодействия нажатие.
//
// Параметры:
//  ИмяКоманды			 - 	 - 
//  ГруппаВсплывающая	 - 	 - 
//  СписокФильтрации	 - 	 - 
//
Процедура ФильтрИсторииВзаимодействияНажатие(ИмяКоманды, ГруппаВсплывающая, СписокФильтрации) Экспорт
	
	ЦветВыделеннойГруппы 	= Новый Цвет(218, 230, 244);
	ЦветОбычнойГруппы		= Новый Цвет(255, 255, 255);
	
	Для Каждого ЭлементФормы Из ГруппаВсплывающая.ПодчиненныеЭлементы Цикл 
		
		Если Не СтрНачинаетсяС(ЭлементФормы.Имя, "ГруппаФильтр") Тогда
			Продолжить;	
		КонецЕсли;
		
		ИмяФильтра = СтрЗаменить(ЭлементФормы.Имя, "ГруппаФильтр", "");
		
		Если СтрНайти(ИмяКоманды, ИмяФильтра) = 0 Тогда 
			Продолжить;
		КонецЕсли;     
		
		ЭлементСпискаЗначения = СписокФильтрации.НайтиПоЗначению(ИмяФильтра);
		
		Если ЭлементСпискаЗначения = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементСпискаЗначения.Пометка = Не ЭлементСпискаЗначения.Пометка;
		
		ЭлементФормы.ЦветФона = ?(ЭлементСпискаЗначения.Пометка = Истина, ЦветВыделеннойГруппы, ЦветОбычнойГруппы);
						
	КонецЦикла;
	
КонецПроцедуры

