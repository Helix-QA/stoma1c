// Процедура выполняет получение расписания регламентного задания
//
Процедура ПолучитьРасписаниеРегламентногоЗадания()	
	
	Если ПравоДоступа("Администрирование", Метаданные) Тогда
		Расписание = РегламентныеЗадания.НайтиПредопределенное("АктуализацияСтатусовПациентов").Расписание;
	Иначе
		Расписание = "Доступно для администратора.";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура выполняет сохранение расписания регламентного задания
//
Процедура СохранитьРасписание()
	
	Задание = РегламентныеЗадания.НайтиПредопределенное("АктуализацияСтатусовПациентов");
	Задание.Расписание = Расписание;
	Задание.Записать();
	
КонецПроцедуры

&НаСервере
// Процедура выполняет установку надписи расписания
//
Процедура УстановитьНадписьРасписания()
	
	Если ПравоДоступа("Администрирование", Метаданные) Тогда
		
		Расписание                   = РегламентныеЗадания.НайтиПредопределенное("АктуализацияСтатусовПациентов").Расписание; 	
		ПрефиксРасписания            = "Расписание проставления статуса: "; 	
		ТекстРасписания              = ПрефиксРасписания + Строка(Расписание); 	
		Элементы.Настроить.Заголовок = ТекстРасписания;
		
	Иначе
		
		Элементы.Настроить.Видимость    = Ложь;
		
	КонецЕсли;
	
