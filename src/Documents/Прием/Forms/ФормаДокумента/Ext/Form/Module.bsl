// Процедура - Сформировать блок с долгом и остатком на ЛС Пациента.
//
Процедура СформироватьБлокСДолгомИОстаткомНаЛСПациента() 
	
	ОстатокПоЛС = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевымСчетахКонтрагентаПоСЕ(Объект.Контрагент, ТекущаяДатаСеанса(),, Объект.СтруктурнаяЕдиница,, Истина, Истина).Итог("СуммаОстаток");
	ДолгПациента = РегистрыНакопления.ВзаиморасчетыСКонтрагентами.ПолучитьОстатокПоВзаиморасчетамСконтрагентом(Объект.Контрагент,, Объект.СтруктурнаяЕдиница);		
	Элементы.ЛС_Пациента.Заголовок = "" + ?(ОстатокПоЛС = 0, "0,00", Формат(ОстатокПоЛС,"ЧЦ=15; ЧДЦ=2")) + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	Элементы.Долг_Пациента.Заголовок = "" + ?(ДолгПациента = 0, "0,00", Формат(ДолгПациента,"ЧЦ=15; ЧДЦ=2")) + " " + ОбщегоНазначенияСтоматология.ПолучитьСимвольноеПредставлениеВалюты();
	Если ДолгПациента > 0 Тогда
		Элементы.Долг_Пациента.ЦветТекста = WebЦвета.Красный;                    
	ИначеЕсли ДолгПациента < 0 Тогда
		Элементы.Долг_Пациента.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
	КонецЕсли;  

КонецПроцедуры

