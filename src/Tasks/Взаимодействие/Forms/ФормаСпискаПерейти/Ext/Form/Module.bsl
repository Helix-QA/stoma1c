		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ЗавершенаПериод"); 
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_ПериодЗапланированнойЗадачи");
		МассивИменОчищаемыхФильтров.Добавить("Фильтр_СтруктурнаяЕдиница");
	КонецЕсли;

	Если ЗначениеЗаполнено(МассивИменОчищаемыхФильтров) Тогда 
		УправлениеИнтерфейсамиСервер.ДеактивироватьВсеЗначенияФильтрацииДанных(ЭтаФорма, МассивИменОчищаемыхФильтров);
	КонецЕсли;
	
	СписокСтатусовПометокУдаления = Новый СписокЗначений;
	СписокСтатусовПометокУдаления.Добавить(Истина, , Ложь);
	УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПометкаУдаленияЗадачи", СписокСтатусовПометокУдаления, Истина);		
	
	// Отбор СЕ.
	Если ПараметрыОтбора.Свойство("МассивСтруктурныхЕдиниц") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтруктурнаяЕдиница", ПараметрыОтбора.МассивСтруктурныхЕдиниц);		
	КонецЕсли;
	
	// Отбор статус.
	Если ПараметрыОтбора.Свойство("МассивСтатусовЗадач") Тогда 	
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Статус", ПараметрыОтбора.МассивСтатусовЗадач);		
	КонецЕсли;
	
	// Отбор Вид сделки. 
	Если ПараметрыОтбора.Свойство("МассивВидовСделок") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ВидСделки", ПараметрыОтбора.МассивВидовСделок);
	КонецЕсли;
	
	// Отбор этапы.
	Если ПараметрыОтбора.Свойство("МассивЭтапов") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Этап", ПараметрыОтбора.МассивЭтапов);		
	КонецЕсли;	
	
	//// Отбор статус клиента
	//Если ПараметрыОтбора.Свойство("МассивСтатусовКлиентов") Тогда 	
	//	УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_СтатусКлиента", ПараметрыОтбора.МассивСтатусовКлиентов);
	//КонецЕсли;
	
	// Отбор признак наличия задач.
	Если ПараметрыОтбора.Свойство("МассивСтатусовНаличияЗадач") Тогда 
		
		МассивСтатусовНаличияЗадач = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовНаличияЗадач) 
			И ПараметрыОтбора.МассивСтатусовНаличияЗадач[0] = Нстр("ru = 'Нет задач'; en = 'No tasks'") Тогда
			
			МассивСтатусовНаличияЗадач.Добавить(Ложь);
		Иначе
			МассивСтатусовНаличияЗадач.Добавить(Истина);		
		КонецЕсли;
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Задача", МассивСтатусовНаличияЗадач);
		ОбновитьСписок = Истина;
	КонецЕсли;
	
	// Отбор статусов сделки.
	Если ПараметрыОтбора.Свойство("МассивСтатусовСделок") Тогда
		
		МассивСтатусовСделок = Новый Массив();
		Если ЗначениеЗаполнено(ПараметрыОтбора.МассивСтатусовСделок) 
			И ПараметрыОтбора.МассивСтатусовСделок[0] = "Нет" Тогда
			
			МассивСтатусовСделок.Добавить(Ложь);
		Иначе
			МассивСтатусовСделок.Добавить(Истина);		
		КонецЕсли;
		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_ПризнакВыполненияСделки", МассивСтатусовСделок);
		
	КонецЕсли;
	
	// Отбор менеджеров.
	Если ПараметрыОтбора.Свойство("МассивИсполнителей") Тогда 		
		УправлениеИнтерфейсамиСервер.УстановитьЗначенияФильтрацииДанных(ЭтаФорма, "Фильтр_Исполнитель", ПараметрыОтбора.МассивИсполнителей);
	КонецЕсли;	
	
	Если ПараметрыОтбора <> Неопределено И ТипЗнч(ПараметрыОтбора) = Тип("Структура") И (ПараметрыОтбора.Свойство("ОтборПериодТип") ИЛИ ПараметрыОтбора.Свойство("МассивСтатусовЗадач")) Тогда 
		Если УправлениеИнтерфейсамиСервер.ПолучитьЗначенияФильтра(ЭтаФорма.ТаблицаФильтров, "Фильтр_Статус").НайтиПоЗначению("Просрочена") <> Неопределено Тогда 
			Если ЭтаФорма.РежимОтображенияФормы = 1 Тогда
				РежимОтображенияФормы 		= 0;
				ПериодОтбора.ДатаНачала    	= Дата(01, 01, 0001);
				ПериодОтбора.ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;
				ВыбранныйПериод 			= 4;
				УстановтьРежимОтображения(Ложь);
			Иначе 	
				ПериодОтбора.ДатаНачала    	= Дата(01, 01, 0001);
				ПериодОтбора.ДатаОкончания 	= НачалоДня(ТекущаяДатаСеанса()) - 1;
				ВыбранныйПериод 			= 4;
			КонецЕсли;
			УстановитьСвойстваОтображенияЭлементов();
		ИначеЕсли ПараметрыОтбора.Свойство("ОтборПериодТип") И ПараметрыОтбора.Свойство("ОтборПериодЗначение") Тогда 
			Если ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.День Тогда 
				ВыбранныйПериод = 0;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Неделя Тогда
				ВыбранныйПериод = 2;
				ПериодОтбора = ПараметрыОтбора.ОтборПериодЗначение;								
			ИначеЕсли ПараметрыОтбора.ОтборПериодТип = Перечисления.Периодичность.Месяц Тогда
