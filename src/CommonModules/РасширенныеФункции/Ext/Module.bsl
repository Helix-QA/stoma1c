		Возврат Неопределено;
		
	#КонецЕсли

КонецФункции

// Функция конвертирует результат выполнения функции XTDO в структуру
// 
Функция ФабрикаXDTOВСтроковоеПредставление(СтруктураXDTO, Отступ = "") Экспорт
	
	Результат = "";
	
	Если ТипЗнч(СтруктураXDTO) = Тип("СписокXDTO") Тогда
		Результат = "(Список - " + СтруктураXDTO.Количество() + " стр.)";
		Для Каждого ЭлементСпискаСвойстваXTDO Из СтруктураXDTO Цикл
			Результат = Результат + Символы.ПС + Отступ + "	" + ФабрикаXDTOВСтроковоеПредставление(ЭлементСпискаСвойстваXTDO, Отступ + "	");
		КонецЦикла;
	ИначеЕсли ТипЗнч(СтруктураXDTO) = Тип("ОбъектXDTO") Тогда
		Результат = "(Структура - " + СтруктураXDTO.Свойства().Количество() + " Эл.)";
		Для Каждого СвойствоXTDO Из СтруктураXDTO.Свойства() Цикл
			Результат = Результат + Символы.ПС + Отступ + "	" + СвойствоXTDO.Имя + ": " + ФабрикаXDTOВСтроковоеПредставление(СтруктураXDTO[СвойствоXTDO.Имя], Отступ + "	");
		КонецЦикла;
	ИначеЕсли ТипЗнч(СтруктураXDTO) = Тип("ДвоичныеДанные") Тогда
		Результат = "...";
	Иначе
		Результат = Строка(СтруктураXDTO);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


