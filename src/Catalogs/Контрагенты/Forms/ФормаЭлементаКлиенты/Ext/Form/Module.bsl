&НаСервереБезКонтекста
Функция УдалитьСкидку(Клиент, Скидка)
	
	СкидкаУдалена = Ложь;
	ТаблицаСкидок = Справочники.СкидкиНаценки.ПолучитьСкидкиДоступныеДляКлиента(Клиент);
	
	Если ТаблицаСкидок.Количество() <> 0 И ЗначениеЗаполнено(Скидка) Тогда
		
		СкидкаСуществует = ТаблицаСкидок.Найти(Скидка, "Скидка");
		Если СкидкаСуществует <> Неопределено Тогда
			
			СкидкаОбъект    = Скидка.ПолучитьОбъект();
			НайденнаяСтрока = СкидкаОбъект.Получатели.НайтиСтроки(Новый Структура("Получатель", Клиент));
			Если НайденнаяСтрока.Количество() > 0 Тогда
				
				СкидкаОбъект.Получатели.Удалить(НайденнаяСтрока[0]);
				СкидкаОбъект.Записать();
				СкидкаУдалена = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СкидкаУдалена;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик оповещения выбора скидки.
//
Процедура ВыборСкидкиЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ДобавитьСкидкуКлиенту(Результат, Объект.Ссылка);
		Оповестить("ЗаписанаСкидка");
	КонецЕсли;
	
КонецПроцедуры

