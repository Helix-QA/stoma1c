
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	СписокПользователей = Параметры.Пользователи;
	Параметры.Свойство("ВариантОтчета", ВариантОтчета);
	Если Параметры.Свойство("ПользователиВариантаРедактирование") Тогда
		Для Каждого ЭлементСписка ИЗ Параметры.ПользователиВариантаРедактирование Цикл 
			НоваяСтрока 					= ДоступностьРедактирование.Добавить();
			НоваяСтрока.ПользовательРоль 	= ЭлементСписка.Значение;
			НоваяСтрока.Доступность 		= ЭлементСписка.Пометка;
			НоваяСтрока.Представление 		= ЭлементСписка.Представление;
		КонецЦикла;	
	КонецЕсли;
	ДоступенВсем 		= СписокПользователей.Количество() = 0;
	
	Если ЗначениеЗаполнено(СписокПользователей.ДоступныеЗначения) Тогда 
		Для Каждого ДоступноеЗначение Из СписокПользователей.ДоступныеЗначения Цикл 
			Если ТипЗнч(ДоступноеЗначение.Значение) = Тип("СправочникСсылка.Сотрудники") Тогда 
				СтрокаПользователя              	= ДоступностьПользователей.Добавить();
				СтрокаПользователя.Пользователь 	= ДоступноеЗначение.Значение;
				СтрокаПользователя.Представление 	= ДоступноеЗначение.Представление;
				Если ДоступенВсем Тогда 
					СтрокаПользователя.Видимость 	= Истина;
				Иначе
					ДоступныйЭлементСписка 			= СписокПользователей.НайтиПоЗначению(ДоступноеЗначение.Значение);
					СтрокаПользователя.Видимость 	= ?(ДоступныйЭлементСписка = Неопределено, Ложь, Истина);
				КонецЕсли;
			ИначеЕсли ТипЗнч(ДоступноеЗначение.Значение) = Тип("ПеречислениеСсылка.РольПользователя") Тогда
				СтрокаПользователя              	= ДоступностьРолей.Добавить();
				СтрокаПользователя.Пользователь 	= ДоступноеЗначение.Значение;
				СтрокаПользователя.Представление 	= ДоступноеЗначение.Представление;
				Если ДоступенВсем Тогда 
					СтрокаПользователя.Видимость 	= ДоступноеЗначение.Пометка;
				Иначе
					ДоступныйЭлементСписка 			= СписокПользователей.НайтиПоЗначению(ДоступноеЗначение.Значение);
					СтрокаПользователя.Видимость 	= ?(ДоступныйЭлементСписка = Неопределено, Ложь, Истина);
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;
			
	Иначе
		// Старый механизм заполнения
		
		// Пользователи
		ТЗ = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Сотрудники.Ссылка КАК Пользователь, ПРЕДСТАВЛЕНИЕ(Сотрудники.Ссылка) КАК Представление
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.ИдентификаторПользователяИБ <> &Идентификатор
		|	И НЕ Сотрудники.ПометкаУдаления
		|	И НЕ Сотрудники.Служебный
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудники.Наименование";
		
		Запрос = Новый Запрос(ТЗ);
		Запрос.УстановитьПараметр("Идентификатор", Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"));
		УстановитьПривилегированныйРежим(истина);
		Выборка = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(ложь);
		
		Пока Выборка.Следующий() Цикл
			
			СтрокаПользователя              	= ДоступностьПользователей.Добавить();
			СтрокаПользователя.Пользователь 	= Выборка.Пользователь;
			СтрокаПользователя.Представление 	= Выборка.Представление;		
			Если СписокПользователей.Количество() = 0 Тогда 
				СтрокаПользователя.Видимость 	= Истина;
			ИначеЕсли СписокПользователей.НайтиПоЗначению(Выборка.Пользователь) <> Неопределено тогда
				СтрокаПользователя.Видимость 	= Истина;
			Иначе
				СтрокаПользователя.Видимость 	= Ложь;
			КонецЕсли;
			
		КонецЦикла;
		
		// Роли
		ТЗ = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	РолиПользователя.Ссылка КАК РольПользователя, ПРЕДСТАВЛЕНИЕ(РолиПользователя.Ссылка) КАК Представление
		|ИЗ
		|	Перечисление.РольПользователя КАК РолиПользователя";
		
		Запрос = Новый Запрос(ТЗ);
		УстановитьПривилегированныйРежим(истина);
		Выборка = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(ложь);
		
		Пока Выборка.Следующий() Цикл
			
			СтрокаПользователя              	= ДоступностьРолей.Добавить();
			СтрокаПользователя.Пользователь 	= Выборка.РольПользователя;
			СтрокаПользователя.Представление 	= Выборка.Представление;
			Если СписокПользователей.Количество() = 0 Тогда 
				СтрокаПользователя.Видимость 	= Истина;		
			ИначеЕсли СписокПользователей.НайтиПоЗначению(Выборка.РольПользователя) <> Неопределено тогда
				СтрокаПользователя.Видимость 	= Истина;
			Иначе
				СтрокаПользователя.Видимость 	= Ложь;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
	
	ПодсчитатьИтогиПоДоступности();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Принять
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура Принять(Команда)
	
	СписокПользователи = Новый СписокЗначений;
	
	Если ЗначениеЗаполнено(ВариантОтчета) Тогда 
		Для Каждого СтрокаРедактирование Из ДоступностьРедактирование Цикл 
			СписокПользователи.Добавить(СтрокаРедактирование.ПользовательРоль, СтрокаРедактирование.Представление, СтрокаРедактирование.Доступность);
		КонецЦикла;	
	Иначе 		
		Для каждого СтрокаПользователя Из ДоступностьПользователей Цикл
			Если СтрокаПользователя.Видимость Тогда
				СписокПользователи.Добавить(СтрокаПользователя.Пользователь, СтрокаПользователя.Представление);
			КонецЕсли;
		КонецЦикла;
		
		Для каждого СтрокаПользователя Из ДоступностьРолей	 Цикл
			Если СтрокаПользователя.Видимость Тогда
				СписокПользователи.Добавить(СтрокаПользователя.Пользователь, СтрокаПользователя.Представление);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	
	Структура = Новый Структура("Пользователи", СписокПользователи);
	Закрыть(Структура);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Отметить все
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ОтметитьВсе(Команда)
	
	Если Элементы.ГруппаПользователиРоли.ТекущаяСтраница = Элементы.СтраницаПользователи Тогда
		
		Для Каждого СтрокаПользователя Из ДоступностьПользователей Цикл
			Если НЕ СтрокаПользователя.Видимость Тогда
				РедактированиеПроизводилось = Ложь;
				Для Каждого СтрокаРедактирование Из ДоступностьРедактирование Цикл 
					Если СтрокаРедактирование.ПользовательРоль = СтрокаПользователя.Пользователь Тогда
						РедактированиеПроизводилось = Истина;
						Если НЕ СтрокаРедактирование.Доступность Тогда 
							ДоступностьРедактирование.Удалить(СтрокаРедактирование);
						КонецЕсли;	
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				Если НЕ РедактированиеПроизводилось Тогда 
					СтрокаРедактирования = ДоступностьРедактирование.Добавить();
					СтрокаРедактирования.ПользовательРоль 	= СтрокаПользователя.Пользователь;
					СтрокаРедактирования.Представление 		= СтрокаПользователя.Представление;
					СтрокаРедактирования.Доступность 		= Истина;
				КонецЕсли;	
				СтрокаПользователя.Видимость = Истина;				
			КонецЕсли;	
		КонецЦикла;
		
	Иначе
		
		Для Каждого СтрокаПользователя Из ДоступностьРолей Цикл
			Если НЕ СтрокаПользователя.Видимость Тогда
				РедактированиеПроизводилось = Ложь;
				Для Каждого СтрокаРедактирование Из ДоступностьРедактирование Цикл 
					Если СтрокаРедактирование.ПользовательРоль = СтрокаПользователя.Пользователь Тогда
						РедактированиеПроизводилось = Истина;
						Если НЕ СтрокаРедактирование.Доступность Тогда 
							ДоступностьРедактирование.Удалить(СтрокаРедактирование);
							РольПользователей = СтрокаПользователя.Пользователь;
						КонецЕсли;	
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				Если НЕ РедактированиеПроизводилось Тогда 
					СтрокаРедактирования = ДоступностьРедактирование.Добавить();
					СтрокаРедактирования.ПользовательРоль 	= СтрокаПользователя.Пользователь;
					СтрокаРедактирования.Представление 		= СтрокаПользователя.Представление;
					СтрокаРедактирования.Доступность 		= Истина;
					РольПользователей 						= СтрокаПользователя.Пользователь;
				КонецЕсли;	
				СтрокаПользователя.Видимость 				= Истина;
				УстановитьФлагиПользователямПоРоли(РольПользователей, Истина);
			КонецЕсли;	
		КонецЦикла;
		
	КонецЕсли;
	
	ПодсчитатьИтогиПоДоступности();
	
КонецПроцедуры

&НаКлиенте
