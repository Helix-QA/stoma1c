// Процедура, обработчик команды "ОтправитьДанныеДоступаКалендаряСотруднику".
//
Процедура ОтправитьДанныеДоступаКалендаряСотруднику(Команда)
	
	МассивДанныхЛогин = ЭтаФорма.КонтактнаяИнформацияОписаниеДополнительныхРеквизитов.НайтиСтроки(Новый Структура("ИмяЭлемента", "ЛогинОнЛайнКалендаря"));
	ЛогинОнЛайнКалендаря = ?(МассивДанныхЛогин.Количество() > 0, ЭтаФорма[МассивДанныхЛогин[0].ИмяРеквизита], "");
	
	РассылкаСМСФорма = ПолучитьФорму("Документ.РассылкаСообщений.ФормаОбъекта");
	РассылкаСМСФорма.Объект.Дата = ТекущаяДата();
	РассылкаСМСФорма.Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидОперацииОтправкаSMS.ОтправкаSMSПолучателю");
	РассылкаСМСФорма.Объект.СервисSMSРассылки = ОбщегоНазначенияСтоматология.ПолучитьЗначениеКонстанты("СервисSMSРассылкиПоУмолчанию");
	РассылкаСМСФорма.Объект.СтруктурнаяЕдиница = ЭтотОбъект.ТекущаяСтруктурнаяЕдиница;
	РассылкаСМСФорма.Объект.ОтправитьНемедленно = Истина;
	РассылкаСМСФорма.Объект.Содержание = "Адрес:" + АдресОнЛайнКалендаря + "
										 |Логин:" + ЛогинОнЛайнКалендаря + "
										 |Пароль:" + Объект.ПарольОнЛайнКалендаря;
	НоваяСтрока = РассылкаСМСФорма.Объект.Получатели.Добавить();
	НоваяСтрока.НомерТелефона = ЛогинОнЛайнКалендаря;
	
	РассылкаСМСФорма.Открыть();
	
КонецПроцедуры

