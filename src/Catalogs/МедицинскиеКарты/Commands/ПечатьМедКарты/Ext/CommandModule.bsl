
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	КартаКлиента = Неопределено;
	КартаКлиентаМассивом = Новый Массив;
	МедицинскиеКартыКлиента = ПолучитьМедКартыКлиентаПоПриему(ПараметрКоманды);
		
	Если МедицинскиеКартыКлиента.Количество() = 0 Тогда		
		ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаКомандыПослеВопросаОСозданииМедКарты", ЭтотОбъект, Новый Структура("КартаКлиентаМассивом, ПараметрКоманды", КартаКлиентаМассивом, ПараметрКоманды)), 
		"У клиента нет медицинской карты! Создать?", РежимДиалогаВопрос.ДаНет);
        Возврат;
	ИначеЕсли МедицинскиеКартыКлиента.Количество() = 1 Тогда
		КартаКлиента = МедицинскиеКартыКлиента[0];
	Иначе
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаКомандыПечатьМедКартыЗавершение", ОбщегоНазначенияКлиент, Новый Структура("ВариантПечати", "ПечатьМедКарты"));
		КартаКлиента = ОткрытьФорму("Справочник.МедицинскиеКарты.ФормаВыбора", Новый Структура("Отбор", Новый Структура("Ссылка", МедицинскиеКартыКлиента)),,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		Возврат;
	КонецЕсли;
		
	ОбработкаКомандыФрагмент(КартаКлиента, КартаКлиентаМассивом);  
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКомандыПослеВопросаОСозданииМедКарты(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	КартаКлиентаМассивом = ДополнительныеПараметры.КартаКлиентаМассивом;
	ПараметрКоманды = ДополнительныеПараметры.ПараметрКоманды;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		СоздатьМедКарту(ПараметрКоманды);	
		ПоказатьВопрос(Новый ОписаниеОповещения("ОбработкаКомандыЗавершение", ЭтотОбъект, Новый Структура("КартаКлиентаМассивом, ПараметрКоманды", КартаКлиентаМассивом, ПараметрКоманды)), 
		"Медицинская карта создана!", РежимДиалогаВопрос.ОК, 1);
        Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКомандыЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	КартаКлиентаМассивом = ДополнительныеПараметры.КартаКлиентаМассивом;
	ПараметрКоманды = ДополнительныеПараметры.ПараметрКоманды;
	
	МедицинскиеКартыКлиента = ПолучитьМедКартыКлиентаПоПриему(ПараметрКоманды);
	КартаКлиента = МедицинскиеКартыКлиента[0];
	
	ОбработкаКомандыФрагмент(КартаКлиента, КартаКлиентаМассивом);

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаКомандыФрагмент(Знач КартаКлиента, Знач КартаКлиентаМассивом)
	
	КартаКлиентаМассивом.Добавить(КартаКлиента);
	Если КартаКлиента = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Справочник.МедицинскиеКарты", "ПечатьМедКарты", КартаКлиентаМассивом, Неопределено);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьМедКартыКлиентаПоПриему(Прием)
	МассивМедКарт = Новый Массив;
	МассивМедКарт = Справочники.МедицинскиеКарты.ПолучитьМедКартыКлиента(Прием.Контрагент);
	Если МассивМедКарт.Количество() = 1 Тогда
		КартаКлиента = МассивМедКарт[0];
		Если Не ЗначениеЗаполнено(КартаКлиента.ВидМедицинскойКарты.ПечатнаяФорма) Тогда
			ВидМедКартыОбъект = КартаКлиента.ВидМедицинскойКарты.ПолучитьОбъект();
			ВидМедКартыОбъект.ПечатнаяФорма = Перечисления.ПечатныеФормыМедицинскихКарт.АмбулаторнаяКарта_043_У_А4;
			ВидМедКартыОбъект.Записать();	
		КонецЕсли;
	КонецЕсли;
	Возврат МассивМедКарт;	
КонецФункции

&НаСервере
Процедура СоздатьМедКарту(ДокСсылка)
	Прием = ДокСсылка.ПолучитьОбъект();	
	МедКартаОбъект = Справочники.МедицинскиеКарты.СоздатьЭлемент();
	МедКартаОбъект.ВидМедицинскойКарты = Справочники.ВидыМедицинскихКарт.ОсновнойВидМедицинскойКарты;
	МедКартаОбъект.ДополнительныеСвойства.Вставить("ВладелецКартыНаименование", Прием.Контрагент);
	МедКартаОбъект.ВладелецКарты = Прием.Контрагент;
	МедКартаОбъект.Записать();
	Справочники.МедицинскиеКарты.УстановитьМестоположениеМедицинскойКарты(МедКартаОбъект.Ссылка, Справочники.Местоположения.ВКлинике);	
	Контрагент = Прием.Контрагент.ПолучитьОбъект();
	Контрагент.ТекущаяМедицинскаяКарта =МедКартаОбъект.Ссылка;
	Контрагент.Записать();    	
КонецПроцедуры

#КонецОбласти