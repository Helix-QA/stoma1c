				ДеньРождения	= ?(ДеньРождения > День(КонецМесяца(Дата(ГодРождения, МесяцРождения, 1))), День(КонецМесяца(Дата(ГодРождения, МесяцРождения, 1))), ДеньРождения);
				ДатаРождения 	= Дата(ГодРождения, МесяцРождения, ДеньРождения);
