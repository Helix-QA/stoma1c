// Процедура - Взаимодействие SMS Отправить сервер.
//
Процедура ВзаимодействиеSMSPushОтправитьСервер()
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ПолучательСсылка = Контрагент;
	ИначеЕсли ЗначениеЗаполнено(Заявка) Тогда 
		ПолучательСсылка = Заявка;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	
	ОписаниеОшибки = "";
	
	Если ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.SMS") Тогда
		
		ДокументСоздан = СоздатьДокументРассылкаСообщенийИОтправитьSMSНаСервере(
			ПолучательСсылка, 
			ЭтотОбъект.ВзаимодействиеSMSНомерТелефона, 
			ЭтотОбъект.ВзаимодействиеSMSТекст,
			ЭтотОбъект.ВзаимодействиеСделка,
			ЭтотОбъект.ТекущаяСтруктурнаяЕдиница,
			ОписаниеОшибки
		); 
		
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПушУведомление") Тогда
		
		ДокументСоздан = СоздатьДокументРассылкаСообщенийИОтправитьPushНаСервере(
			ПолучательСсылка, 
			ЭтотОбъект.ВзаимодействиеPushВнешняяСистемаWallet, 
			ЭтотОбъект.ВзаимодействиеSMSТекст,
			ЭтотОбъект.ВзаимодействиеСделка,
			ЭтотОбъект.ТекущаяСтруктурнаяЕдиница,
			ОписаниеОшибки
		); 
		
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Письмо") Тогда
		
		ДокументСоздан = СоздатьДокументИсходящееПисьмоОтправитьПисьмоНаСервере(
			ПолучательСсылка, 
			ЭтотОбъект.ВзаимодействиеПисьмоАдресЭП,
			ЭтотОбъект.ВзаимодействиеПисьмоТема,
			ЭтотОбъект.ВзаимодействиеSMSТекст,
			ЭтотОбъект.ВзаимодействиеСделка,
			ОписаниеОшибки
		);
		
	ИначеЕсли ТипСообщенияPushSMS = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Мессенджер") Тогда 
		
		ВыбранныйКанал = ЭтотОбъект.ТаблицаКаналовРассылки.НайтиПоИдентификатору(ЭтотОбъект.ИдентификаторКаналаМессенджер);
		
		Если ВыбранныйКанал = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ДанныеКанала = Новый Структура;
		ДанныеКанала.Вставить("ИдКлиента"		, ВыбранныйКанал.ИдКлиента);
		ДанныеКанала.Вставить("ВнешняяСистема"	, ВыбранныйКанал.ВнешняяСистема);
		ДанныеКанала.Вставить("НомерМессенджера", ВыбранныйКанал.НомерМессенджера);
		
		ДокументСоздан = СоздатьДокументРассылкаСообщенийИОтправитьСообщениеМессенджерНаСервере(
			ПолучательСсылка, 
			ДанныеКанала,
			ЭтотОбъект.ВзаимодействиеSMSТекст,
			ЭтотОбъект.ТекущаяСтруктурнаяЕдиница,
			ЭтотОбъект.ШаблонСообщения,
			ЭтотОбъект.ДокументОснование,
			ОписаниеОшибки
		);
		
	КонецЕсли;
	
	Если ДокументСоздан = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сообщение не доставлено: " + ОписаниеОшибки);
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.ВзаимодействиеSMSТекст      = "";
	ЭтотОбъект.ВзаимодействиеКаналРассылки = "";
	ЭтаФорма.Закрыть();
	
КонецПроцедуры

