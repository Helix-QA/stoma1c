	СтандартнаяОбработка = Ложь;
	ПараметрыОповещения = Новый Структура("Элемент", Элемент);
	ПараметрыФормы = Новый Структура("ИдентификаторПоля", ЭтаФорма.ИмяФормы + "." + Элемент.Имя); 
