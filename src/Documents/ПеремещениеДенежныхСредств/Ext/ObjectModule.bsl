
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Дата               = ТекущаяДата();
	ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные;
	АвторДокумента     = ПараметрыСеанса.ТекущийПользователь;
	СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	
	Если ДанныеЗаполнения <> Неопределено Тогда
		Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда	
			ТипДенежныхСредств = ?(ДанныеЗаполнения.Свойство("ТипДенежныхСредств"), ДанныеЗаполнения.ТипДенежныхСредств,ТипДенежныхСредств);
		КонецЕсли;	
	КонецЕсли;	 
	
	Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет И НЕ Константы.ИспользоватьВидыЛицевыхСчетов.Получить() Тогда
		 ИсточникВидЛицевогоСчета   = Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет;
	     ПриемникВидЛицевогоСчета   = Справочники.ВидыЛицевыхСчетов.ОсновнойЛицевойСчет;
    КонецЕсли;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	
КонецПроцедуры

// Процедура - обработчик события "ПриКопировании" объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	                       
КонецПроцедуры

// Обработчик проверки заполнения формы объекта
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Перем МассивВсехРеквизитов;
	МассивОбязательныхРеквизитов = Новый Массив;
	//
	Документы.ПеремещениеДенежныхСредств.ПолучитьМассивыОбязательныхРеквизитов(ЭтотОбъект,
	МассивОбязательныхРеквизитов);
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	ДенежныеСредстваСервер.ЗаполнитьМассивНепроверяемыхРеквизитовПоОбъекту(ЭтотОбъект,
	МассивОбязательныхРеквизитов,
	МассивНепроверяемыхРеквизитов
	);
	//
	ДенежныеСредстваСервер.УдалитьНепроверяемыеРеквизитыИзМассива(
	ПроверяемыеРеквизиты,
	МассивНепроверяемыхРеквизитов
	);

КонецПроцедуры

// Обработчик перед записью объекта
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Проверка возможности проведения перемещения
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		// Проверка на достаточность остатка суммы в источнике средств
		ОстатокСредствИсточника = 0;
		Если ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные 
			ИЛИ ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			
			ОстатокСредствИсточника = РегистрыНакопления.ДенежныеСредства.ПолучитьОстаткоДенежныхСредств(?(ЭтотОбъект.Дата = НачалоДня(ТекущаяДата()), ТекущаяДата(), ЭтотОбъект.Дата),ЭтотОбъект.ИсточникСписанияСредств,ЭтотОбъект.Ссылка);
		ИначеЕсли ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.ЛицевойСчет Тогда			
			ОстатокСредствИсточника = РегистрыНакопления.ДенежныеСредстваНаЛицевыхСчетах.ПолучитьОстаткиНаЛицевыхСчетахКонтрагента(ЭтотОбъект.ИсточникСписанияСредств,?(ЭтотОбъект.Дата = НачалоДня(ТекущаяДата()), ТекущаяДата(), ЭтотОбъект.Дата),ЭтотОбъект.Ссылка,ЭтотОбъект.СтруктурнаяЕдиница,ЭтотОбъект.ИсточникВидЛицевогоСчета,Истина);
		КонецЕсли;
		
		Если ОстатокСредствИсточника < СуммаДокумента Тогда
			
			Отказ = Истина;
			Текст = НСтр("ru = 'Источник средств " +ИсточникСписанияСредств+ " не содеражит необходимой суммы. Остаток " +ОстатокСредствИсточника+ "'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			Текст,
			ЭтотОбъект,
			"СуммаДокумента",);

		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);	
	
    // Инициализация данных документа.	
	Документы.ПеремещениеДенежныхСредств.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);	
	
	// Движения по регистрам
	ДвиженияДокументовСервер.ДенежныеСредства(ДополнительныеСвойства, Движения, Отказ);   	
	ДвиженияДокументовСервер.ДенежныеСредстваНаЛицевыхСчетах(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.ВзаиморасчетыСКонтрагентами(ДополнительныеСвойства, Движения, Отказ);
	ДвиженияДокументовСервер.Управленческий(ДополнительныеСвойства, Движения, Отказ);
	
	// Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);
		
КонецПроцедуры // ОбработкаПроведения()


#КонецОбласти

