//
//
Процедура УдалитьСтрочкуСоставУслуг(Команда)
	
	ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);	
