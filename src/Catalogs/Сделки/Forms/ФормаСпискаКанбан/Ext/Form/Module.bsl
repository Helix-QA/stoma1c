	|      title: """ + ПредставлениеСтатуса + " <span class='item-count' data-count='" + КоличествоСделок + "'></span><svg xmlns='http://www.w3.org/2000/svg' width='13' height='32' viewBox='0 0 13 32'><path fill='#39a8ef' fill-opacity='1' d='M0 0h3c2.8 0 4 3 4 3l6 13-6 13s-1.06 3-4 3H0V0z'/></svg>"",
	|      class: 'col-head',
	|      " + ТекстНастройкиОграниченияПереносаСделок + "
	|      item: [
	|          " + СодержимоеКолонки + "
