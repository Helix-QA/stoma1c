// Функция, Сформировать печатную форму вкладыша мед. карты для страховой.
//
Функция СформироватьПечатнуюФормуВкладышаМедКартыДляСтраховой(МассивОбъектов, ОбъектыПечати, ПараметрыПечати = Неопределено, ФорматПечати) 
			
	ТабличныйДокумент                      = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ВкладышМедКартыДляСтраховой";
	ТабличныйДокумент.РазмерСтраницы       = ФорматПечати;
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийОбъект Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент    = Ложь;	
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос       = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДокументПрием.Дата,
		|	ДокументПрием.Ссылка,
		|	ДокументПрием.РезультатПриема,
		|	ДокументПрием.Контрагент,
		|	ДокументПрием.Сотрудник
		|ИЗ
		|	Документ.Прием КАК ДокументПрием
		|ГДЕ
		|	ДокументПрием.Контрагент = &Пациент
		|	И ДокументПрием.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументПрием.Дата";
		
		ВладелецКарты = ТекущийОбъект.ВладелецКарты; 
		
		Запрос.УстановитьПараметр("Пациент", ВладелецКарты);		
		
		МассивПриемов = ?(ТипЗнч(ПараметрыПечати.ВкладышМедКартыДляСтраховой) = Тип("Массив"), ПараметрыПечати.ВкладышМедКартыДляСтраховой, Неопределено);
		МассивПриемов = ?(ЗначениеЗаполнено(МассивПриемов), МассивПриемов, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
		
		Макет =	ПолучитьМакет("ВкладышМедКартыДляСтраховой");
		ВладелецКарты = ТекущийОбъект.ВладелецКарты;
		
		Для Каждого СтрокаПриема Из МассивПриемов Цикл
			
			ОбластьМакета = Макет.ПолучитьОбласть("Пациент"); 
			ОбластьМакета.Параметры.Пациент = ВладелецКарты.Наименование;
			ОбластьМакета.Параметры.ДатаПриема = Формат(СтрокаПриема.Дата, "ДФ=dd.MM.yyyy"); 
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("Врач"); 
			ОбластьМакета.Параметры.Врач = СтрокаПриема.Сотрудник.Наименование;
			ОбластьМакета.Параметры.НомерКарты = ТекущийОбъект.КодБезНулей;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаДневника");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			ОбластьМакета = Макет.ПолучитьОбласть("Дневник");
			ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийОбъект.ВладелецКарты, СтрокаПриема,, Истина);
			Для Каждого СтрокаТ Из ТаблицаОбследований Цикл
				
				// Используются только реквизиты дневника
				Если СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
					Продолжить;
				КонецЕсли;
				ОбластьМакета.Параметры.ТекстИмяРеквизита = СтрокаТ.РеквизитНаименование + ":"; 			            
				ОбластьМакета.Параметры.ТекстЗначениеРеквизита = СтрокаТ.РеквизитЗначение; 
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
			
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицы"); 			
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
			ОбластьМакета = Макет.ПолучитьОбласть("СтрокаТаблицы");
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ПриемЛечение.Зуб КАК НомерЗуба,
			|	ПриемЛечение.Количество КАК Количество,
			|	ПриемЛечение.Номенклатура.Представление КАК Услуга,
			|	ПриемЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг КАК КодУслуги
			|ИЗ
			|	Документ.Прием.Лечение КАК ПриемЛечение
			|ГДЕ
			|	ПриемЛечение.Ссылка = &Ссылка
			|
			|СГРУППИРОВАТЬ ПО
			|	ПриемЛечение.Зуб,
			|	ПриемЛечение.Количество,
			|	ПриемЛечение.Номенклатура.Представление,
			|	ПриемЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг");
			
			Запрос.УстановитьПараметр("Ссылка", СтрокаПриема);
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл 
				ОбластьМакета.Параметры.Заполнить(Выборка); 
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЦикла;         
			
			ОбластьМакета = Макет.ПолучитьОбласть("Подпись"); 
			Должность = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаПриема.Сотрудник, "Должность");
			ОбластьМакета.Параметры.ПодписьВрача = Должность.Наименование + " " + СтрокаПриема.Сотрудник.Наименование;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЦикла; 
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийОбъект.ВладелецКарты.Ссылка);
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;	
	Возврат ТабличныйДокумент; 
	
Конецфункции	

