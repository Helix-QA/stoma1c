// Процедура, обработчик события команды
//
Процедура Микрофон(Команда)
	
	Если Не СофтФон = Неопределено Тогда
		Объект.MicrophoneMute = Не Объект.MicrophoneMute;
		СофтФон.MicrophoneMute = Объект.MicrophoneMute;
		СофтФон.MicrophoneChanged();
		Если Объект.MicrophoneMute Тогда
			Элементы.Микрофон.Картинка = Элементы.КартинкаМикрофонВыключить.Картинка;
		Иначе
			Элементы.Микрофон.Картинка = Элементы.КартинкаМикрофонВключить.Картинка;
		КонецЕсли;		
	КонецЕсли;    	
	
КонецПроцедуры

