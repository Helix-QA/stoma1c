// Процедура - Подарки партия начало выбора завершение
//
// Параметры:
//  Результат1				 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура ПодаркиПартияНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	СтрокаТабличнойЧасти = ДополнительныеПараметры.СтрокаТабличнойЧасти;
		
	Если Результат <> Неопределено и Результат.Количество() <> 0 Тогда
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Партия", Результат[0]);
		
		НайденныеСтрокиЗапасы	= Объект.Запасы.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтрокиПодарки	= Объект.Подарки.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтрокиЗапасы.Количество() > 0 
			Или НайденныеСтрокиПодарки.Количество() > 0 Тогда		
			ОбщегоНазначения.СообщитьПользователю("Серийный номер уже был указан в документе!");		
		Иначе	
			СтрокаТабличнойЧасти.Партия = Результат[0];
			Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "ВидНоминала") = Ложь Тогда
				СтрокаТабличнойЧасти.СуммаПодарочногоСертификата = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "Номинал");
			КонецЕсли;   
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
// Процедура печати документов.
//
Процедура ДокументПечать(Команда)
	
	МассивДокументов = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		МассивДокументов.Добавить(Объект.Ссылка);
	КонецЕсли;
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "Прием");
	Структура.Вставить("МассивДокументов", МассивДокументов);
	Структура.Вставить("Контрагент", Объект.Контрагент);
	
	СписокПечатныхФорм = ПолучитьСписокПечати(); 	
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаКоманды", УправлениеПечатьюКлиентСтоматология, Структура);	
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Или ЭтаФорма.Модифицированность Тогда	
		
		СтруктураВопроса = Новый Структура;
		СтруктураВопроса.Вставить("СписокПечатныхФорм", СписокПечатныхФорм);
		СтруктураВопроса.Вставить("Оповещение", Оповещение);
		ОповещениеДляВопроса = Новый ОписаниеОповещения("ПослеВопросаЗавершение", ЭтотОбъект, СтруктураВопроса);
		Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
			ПоказатьВопрос(ОповещениеДляВопроса, "Данные ещё не записаны. Записать?", РежимДиалогаВопрос.ДаНет);
		Иначе
			ПоказатьВопрос(ОповещениеДляВопроса, "Данные изменены. Записать?", РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
		
	Иначе
		
		ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, Элементы.ФормаДокументаПечать);
		
	КонецЕсли;   				
	
КонецПроцедуры

&НаКлиенте
