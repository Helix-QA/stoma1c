// Процедура, выполянет копирование настроек сотрудника.
//
Процедура СкопироватьНастройкиСотрудника(Источник)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	&Номенклатура КАК Номенклатура,
	|	УслугиСотрудника.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	УслугиСотрудника.Сотрудник КАК Сотрудник,
	|	УслугиСотрудника.НормаВремени КАК НормаВремени
	|ИЗ
	|	РегистрСведений.УслугиСотрудника КАК УслугиСотрудника
	|ГДЕ
	|	УслугиСотрудника.Номенклатура = &Источник
	|	И УслугиСотрудника.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)");
	
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МестаРаботы.Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница"));
	Запрос.УстановитьПараметр("Источник" 			   , Источник);
	Запрос.УстановитьПараметр("Номенклатура"		   , Номенклатура);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	НаборЗаписей = РегистрыСведений.УслугиСотрудника.СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(Результат);
	НаборЗаписей.Отбор.Номенклатура.Использование = Истина;
	НаборЗаписей.Отбор.Номенклатура.Значение 	  = Номенклатура;
	НаборЗаписей.Записать(Истина);
	
	ОтборСотрудник 			= Справочники.Сотрудники.ПустаяСсылка();
	ОтборСотрудникДолжность = Справочники.Должности.ПустаяСсылка();
	ОтборСотрудникРоль      = Перечисления.РольПользователя.ПустаяСсылка();
	
	ОбновитьДеревоПодборовСотрудников(Истина,Истина,Истина);
	
	// Проставялем флаги на группах дерева.
	УстановитьНачальныеФлагиНаГруппы();
	
КонецПроцедуры

