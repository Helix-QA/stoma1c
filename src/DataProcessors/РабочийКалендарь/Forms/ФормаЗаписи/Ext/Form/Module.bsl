// Процедура - обработчик события ПриОткрытии формы.
//
Процедура ОбновитьТаблицуПомещений()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Помещения.Ссылка КАК Помещение,
	|	НЕОПРЕДЕЛЕНО КАК Картинка,
	|	НЕОПРЕДЕЛЕНО КАК Доступность
	|ИЗ
	|	Справочник.Помещения КАК Помещения
	|ГДЕ
	|	Помещения.ПометкаУдаления = ЛОЖЬ
	|	И Помещения.ЭтоГруппа = ЛОЖЬ
	|	И Помещения.ОтображатьВРасписанииЗанятий = ИСТИНА
	|	И Помещения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|
	|УПОРЯДОЧИТЬ ПО
	|	Помещения.ЭтоГруппа, Помещения.Ссылка
	|ИТОГИ ПО
	|	Помещения.Ссылка ТОЛЬКО ИЕРАРХИЯ";
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	РезультатДеревоПомещений = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ДеревоПомещений.ПолучитьЭлементы().Очистить();
	// В зависимости от режима графика ПЗ выставляем возможность отбора по всем сотрудникам
	Если ПЗГрафикаРежимотОбражения = 0 Тогда
		ВерхнийУровень                  = ДеревоПомещений.ПолучитьЭлементы().Добавить();
		ВерхнийУровень.Помещение        = "Все";
		ВерхнийУровень.ИндексКартинки   = 0;
		ВерхнийУровень.Доступность      = ПЗГрафикаРежимОтображения = 0;
	ИначеЕсли ПЗГрафикаРежимотОбражения = 1 Тогда
		ВерхнийУровень = ДеревоПомещений;
	КонецЕсли;	
	// Рекурсивное заполнение дерева
	ТекущаяСтрока = Неопределено;
	Для Каждого ЭлементДерева Из РезультатДеревоПомещений.Строки Цикл
		Временная = ДобавитьВДеревоРекурсивно(ЭлементДерева, ВерхнийУровень);
		Если НЕ Временная = Неопределено Тогда
			ТекущаяСтрока = Временная;
		КонецЕсли;
	КонецЦикла;
	
	Если ПЗГрафикаРежимОтображения = 0 Тогда
		ЭлВерхнегоУровня = ДеревоПомещений.ПолучитьЭлементы();
		Для Каждого ЭлементВерхнегоУровня Из ЭлВерхнегоУровня Цикл
			Если ТипЗнч(ЭлементВерхнегоУровня.Помещение) = Тип("Строка") И ЭлементВерхнегоУровня.Помещение = "Все" Тогда 
				ТекущаяСтрока = ЭлементВерхнегоУровня;
				ПЗФиьтрГрафикаТекущаяСтрока = ЭлементВерхнегоУровня.Помещение;
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;	
	
	// Если не удалось установить позиционирование 	
	Если ТекущаяСтрока = Неопределено Тогда
		ЭлВерхнегоУровня = ДеревоПомещений.ПолучитьЭлементы();
		Если ЭлВерхнегоУровня.Количество() > 0 Тогда
			Если ЭлВерхнегоУровня[0].Доступность Тогда
				ТекущаяСтрока               = ЭлВерхнегоУровня[0];
				ПЗФиьтрГрафикаТекущаяСтрока = ЭлВерхнегоУровня[0].Помещение;
			Иначе
				ЭлНижнегоУровня = ЭлВерхнегоУровня[0].ПолучитьЭлементы();
				Если ЭлНижнегоУровня.Количество() > 0 Тогда
					ТекущаяСтрока               = ЭлНижнегоУровня[0];
					ПЗФиьтрГрафикаТекущаяСтрока = ЭлНижнегоУровня[0].Помещение;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// Позиционирование текущего элемента
	Если НЕ ТекущаяСтрока = Неопределено Тогда
		Элементы.ДеревоПомещений.ТекущаяСтрока = ТекущаяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Рекурсивное заполнение дерева 
//
Функция ДобавитьВДеревоРекурсивно(ДеревоИсточник, ДеревоПриемник)
	
	ТекущаяСтрока = Неопределено;
	Если Не ДеревоИсточник.Помещение.Пустая() Тогда
		НовыйЭлемент             = ДеревоПриемник.ПолучитьЭлементы().Добавить();
		НовыйЭлемент.Помещение   = ДеревоИсточник.Помещение;
		НовыйЭлемент.ИндексКартинки = ?(НовыйЭлемент.Помещение.ЭтоГруппа, 0, 2);
		НовыйЭлемент.Доступность = ?(НовыйЭлемент.Помещение.ЭтоГруппа И ПЗГрафикаРежимОтображения = 1, Ложь, Истина);	
		// Проверка на возможность позиционирования
		Если НовыйЭлемент.Помещение = ПЗФиьтрГрафикаТекущаяСтрока Тогда
			ТекущаяСтрока = НовыйЭлемент;
		КонецЕсли;	
	Иначе
		НовыйЭлемент = ДеревоПриемник;
	КонецЕсли;
	// Рекурсивный вызов
	Для Каждого ЭлементДерева Из ДеревоИсточник.Строки Цикл
		Временная    =  ДобавитьВДеревоРекурсивно(ЭлементДерева, НовыйЭлемент);
		Если НЕ Временная = Неопределено Тогда
			ТекущаяСтрока = Временная;
		КонецЕсли;
	КонецЦикла;	
	Возврат ТекущаяСтрока;
	
КонецФункции

