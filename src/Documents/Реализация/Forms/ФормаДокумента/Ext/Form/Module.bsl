// Подарки партия начало выбора.
//
Процедура ПодаркиПартияНачалоВыбораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ ДополнительныеПараметры.Свойство("СтрокаТабличнойЧасти") Тогда
		Возврат;
	КонецЕСли;
	
	СтрокаТабличнойЧасти = ДополнительныеПараметры.СтрокаТабличнойЧасти;
		
	Если Результат <> Неопределено и Результат.Количество() <> 0 Тогда
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Партия", Результат[0]);
		
		НайденныеСтрокиЗапасы	= Объект.Запасы.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтрокиПодарки	= Объект.Подарки.НайтиСтроки(ПараметрыОтбора);
		
		Если НайденныеСтрокиЗапасы.Количество() > 0 
			Или НайденныеСтрокиПодарки.Количество() > 0 Тогда		
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Серийный номер уже был указан в документе!");		
		Иначе	
			СтрокаТабличнойЧасти.Партия = Результат[0];
			Если ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "ВидНоминала") = Ложь Тогда
				СтрокаТабличнойЧасти.СуммаПодарочногоСертификата = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТабличнойЧасти.Номенклатура, "Номинал");
			КонецЕсли;   
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

