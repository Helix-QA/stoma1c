// Функция, получает текст запроса для переопределения динамического списка элемента формы "Договоры".
//
Функция ПолучитьТекстЗапросаДоговоров(АрхивныеДоговора)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДоговорыКонтрагентовПереопределяемый.НомерДоговора КАК Номер,
	|	ДоговорыКонтрагентовПереопределяемый.ДатаДоговора КАК Дата,
	|	ДоговорыКонтрагентовПереопределяемый.ДатаНачала КАК ДатаНачала,
	|	ДоговорыКонтрагентовПереопределяемый.ДатаОкончания КАК ДатаОкончания,
	|	ДоговорыКонтрагентовПереопределяемый.ПрограммаСтрахования КАК ПрограммаСтрахования,
	|	ДоговорыКонтрагентовПереопределяемый.ВидЦен КАК ВидЦен,
	|	ДоговорыКонтрагентовПереопределяемый.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентовПереопределяемый
	|ГДЕ
	|	ДоговорыКонтрагентовПереопределяемый.Контрагент = &Контрагент";
	
	Если АрхивныеДоговора = Ложь Тогда
		
		УсловиеАрхив = 
		"	И ВЫБОР
		|			КОГДА ДоговорыКонтрагентовПереопределяемый.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ДоговорыКонтрагентовПереопределяемый.ДатаОкончания >= &ТекущаяДата
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА ДоговорыКонтрагентовПереопределяемый.ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ДоговорыКонтрагентовПереопределяемый.ДатаНачала <= &ТекущаяДата
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
		
	Иначе
		
		УсловиеАрхив =		
		"	И (ВЫБОР
		|				КОГДА ДоговорыКонтрагентовПереопределяемый.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ДоговорыКонтрагентовПереопределяемый.ДатаОкончания < &ТекущаяДата
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ
		|			ИЛИ ВЫБОР
		|				КОГДА ДоговорыКонтрагентовПереопределяемый.ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ДоговорыКонтрагентовПереопределяемый.ДатаНачала > &ТекущаяДата
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ)";
		
	КонецЕсли;
	
	Возврат ТекстЗапроса + УсловиеАрхив;
	
КонецФункции

&НаСервере
// Процедура, устанавливает текст запроса для переопределения динамического списка элемента формы "Договоры".
//
Процедура УстановитьТекстЗапросаДинамическогоСпискаДоговоры(АрхивныеДоговора)
	
	ТекстЗапроса = ПолучитьТекстЗапросаДоговоров(АрхивныеДоговора);
	
	СвойстваСписка = ОбщегоНазначения.СтруктураСвойствДинамическогоСписка();
	СвойстваСписка.ОсновнаяТаблица = "Справочник.ДоговорыКонтрагентов";
	СвойстваСписка.ДинамическоеСчитываниеДанных = Истина;
	СвойстваСписка.ТекстЗапроса = ТекстЗапроса;
	ОбщегоНазначения.УстановитьСвойстваДинамическогоСписка(Элементы.Договоры, СвойстваСписка);
	
	Договоры.Параметры.УстановитьЗначениеПараметра("Контрагент" , Объект.Ссылка);
	Договоры.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	
