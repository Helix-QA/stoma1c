	УстановитьВидыОплатСервер(Истина);	
	РасставитьПриоритетПечатиЧека();
	
	// ОбновитьФорму("ОБНОВИТЬ_ТАБЛИЦУ_ОПЛАТ", Истина);
	
	ПредПолеВводаСуммыОплаты = Неопределено;

	
КонецПроцедуры

&НаСервере
// Обновить таблицу задолженностей без перезагрузки ее элементов.
//
Процедура ПриИзмененииВыбораСервер(ЭлементИмя)
	
	Индекс = 0;
	
	Если СтрНайти(ЭлементИмя, "КассаОплаты") > 0 Тогда
		
		Для Каждого СтрокаТ ИЗ ДоступныеКассы Цикл
			
			Если ЭлементИмя = "КассаОплаты_" + Индекс Тогда
				
				ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Доступность     = Истина;
				ЭтаФорма.Элементы["КассаОплаты_" + Индекс].ЦветТекста      = Новый Цвет(77,77,77); // Новый Цвет(51,102,187); 
				ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Шрифт           = Новый Шрифт(ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Шрифт,,11);
				ЭтаФорма.Элементы["ГруппаКассаОплатыКнопка_" + Индекс].ЦветФона  = Новый Цвет(242,242,242);   
				
				ЭтотОбъект.Касса = СтрокаТ.Касса;
				
			Иначе
				Если СтрокаТ.КассаДоступна Тогда
					ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Доступность     = Истина;
					ЭтаФорма.Элементы["КассаОплаты_" + Индекс].ЦветТекста      = Новый Цвет(51,102,187);
					ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Шрифт           = Новый Шрифт(ЭтаФорма.Элементы["КассаОплаты_" + Индекс].Шрифт,,11);
					ЭтаФорма.Элементы["ГруппаКассаОплатыКнопка_" + Индекс].ЦветФона  = Новый Цвет(255,255,255);
				КонецЕсли;
			КонецЕсли;
			
			Индекс = Индекс + 1;
			
		КонецЦикла;
				
	КонецЕсли;
	
	СостояниеКассовойСмены                 = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(ЭтотОбъект.Касса);
	ЭтотОбъект.КассоваяСмена               = ?(СостояниеКассовойСмены <> Неопределено, СостояниеКассовойСмены.КассоваяСмена, Неопределено);
	
	ЭтотОбъект.Организация 				   = ЭтотОбъект.Касса.СтруктурнаяЕдиница.Организация;  
	ЭквайринговыйТерминал                  = Справочники.ЭквайринговыеТерминалы.ПолучитьЭквайринговыйТерминалПоУмолчанию(ЭтотОбъект.Касса);
	ЭтотОбъект.ТекущаяКассаИспользуетсяККТ = ЭтотОбъект.Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ 
	
КонецПроцедуры 

