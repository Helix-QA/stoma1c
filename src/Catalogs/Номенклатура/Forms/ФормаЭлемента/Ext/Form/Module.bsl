// Процедура, обработчик события "ПриИзменении".
//
Процедура ЦенаПриИзменении(Элемент)
	 
	СтрокаДанных = ТаблицаЦенНоменклатуры.НайтиПоИдентификатору(Сред(Элемент.Имя,7));
	ВременноеЦенообразование = Новый Структура;
	ВременноеЦенообразование.Вставить("ДеньНедели", СтрокаДанных.ДеньНедели);
	ВременноеЦенообразование.Вставить("ВремяНачала", СтрокаДанных.ВремяНачала);
	ВременноеЦенообразование.Вставить("ВремяОкончания", СтрокаДанных.ВремяОкончания);
	ИзменитьЦенуПродажи(Объект.Ссылка, СтрокаДанных.ВидЦен, СтрокаДанных.Упаковка, СтрокаДанных.Цена, ВременноеЦенообразование);
	
