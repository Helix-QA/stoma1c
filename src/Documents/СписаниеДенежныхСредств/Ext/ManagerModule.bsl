#Область СлужебныеПроцедурыИФункции	
	
////////////////////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРА ФОРМИРОВАНИЯ ПАКЕТА ДАННЫХ ДЛЯ ДВИЖЕНИЯ ДОКУМЕНТА

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата КАК Период,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств КАК ТипДенежныхСредств,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Касса
	|		ИНАЧЕ ВЫБОР
	|				КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
	|					ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.БанковскийСчет
	|				ИНАЧЕ ВЫБОР
	|						КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта)
	|							ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ЭквайрингТерминал.Эквайер.БанковскийСчетПоУмолчанию
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма КАК Сумма,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Статья = ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Статья
	|		ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Статья
	|	КОНЕЦ КАК Статья,
	|	NULL КАК ЭтоАванс
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредства
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств <> ЗНАЧЕНИЕ(Перечисление.типыДенежныхСредств.ЛицевойСчет)
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств <> ЗНАЧЕНИЕ(Перечисление.типыДенежныхСредств.ПодарочныйСертификат)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПереводыВПути),
	|	NULL,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Статья = ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Статья
	|		ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Статья
	|	КОНЕЦ,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.СдачаНаличныхВБанк), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыбытиеВкассу), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.СдачаРозничнойВыручкиВКассуПредприятия), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыбытиеВОперационнуюКассу))	
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата КАК Период,
	|	NULL КАК ДокументОснования,
	|	NULL КАК ДокументАванса,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент КАК Контрагент,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма * -1 КАК Сумма,
	|	NULL КАК ЭтоАванс,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыКонтрагентов
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет)
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
	|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыклиенту)
	|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
	|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании)
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата,
	|	ВЫБОР
	|		КОГДА НЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаПоставщику)
	|			ТОГДА ВЫБОР
	|					КОГДА (СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
	|							ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыклиенту)
	|							ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании))
	|							И СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования ССЫЛКА Документ.ВозвратОтПокупателя
	|						ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.ДокументОснования
	|					ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования
	|				КОНЕЦ
	|		ИНАЧЕ NULL
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Значение = ИСТИНА
	|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс = ЛОЖЬ
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументАванса
	|	КОНЕЦ,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Выгодоприобретатель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Выгодоприобретатель
	|		ИНАЧЕ ВЫБОР
	|				КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования ССЫЛКА Документ.Прием
	|						И СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	|						И СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.Контрагент <> СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент
	|					ТОГДА ВЫБОР
	|							КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования ССЫЛКА Документ.Прием
	|									И СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.ПолисМедСтрахования <> ЗНАЧЕНИЕ(Справочник.ПолисыМедицинскогоСтрахования.ПустаяССылка)
	|								ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.ПолисМедСтрахования.СтраховаяКомпания
	|							ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.Контрагент
	|						КОНЕЦ
	|				ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент
	|			КОНЕЦ
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
	|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыклиенту)
	|				ИЛИ СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании)
	|			ТОГДА СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма * -1
	|		ИНАЧЕ СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма
	|	КОНЕЦ,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Договор
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа,
	|	Константа.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов КАК УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыСтраховойКомпании), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаПоставщику), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыдачаЗайма), ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОшибочнойОплатыклиенту))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	3,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	СписаниеДенежныхСредств.Дата,
	|	NULL,
	|	NULL,
	|	СписаниеДенежныхСредств.СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредств.Контрагент,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредств.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА СписаниеДенежныхСредств.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ СписаниеДенежныхСредств.Организация
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредств.Сертификат.ВидНоминала
	|			ТОГДА СписаниеДенежныхСредств.СертификатСерийныйНомер.Номинал
	|		ИНАЧЕ СписаниеДенежныхСредств.Сертификат.Номинал
	|	КОНЕЦ - СписаниеДенежныхСредств.СуммаДокумента,
	|	ЛОЖЬ,
	|	СписаниеДенежныхСредств.Договор
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств,
	|	Константа.ЗачислятьОплатуСертификатомНаЛицевойСчет КАК ЗачислятьОплатуСертификатомНаЛицевойСчет
	|ГДЕ
	|	СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат)
	|	И ЗачислятьОплатуСертификатомНаЛицевойСчет.Значение = ИСТИНА
	|	И СписаниеДенежныхСредств.Сертификат.СертификатМногоразовоеИспользование = ЛОЖЬ
	|	И СписаниеДенежныхСредств.Ссылка = &Ссылка
	|	И ВЫБОР
	|			КОГДА СписаниеДенежныхСредств.Сертификат.ВидНоминала
	|				ТОГДА СписаниеДенежныхСредств.СертификатСерийныйНомер.Номинал
	|			ИНАЧЕ СписаниеДенежныхСредств.Сертификат.Номинал
	|		КОНЕЦ > СписаниеДенежныхСредств.СуммаДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	СписаниеДенежныхСредств.Ссылка.Дата КАК Период,
	|	СписаниеДенежныхСредств.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредств.Ссылка.Контрагент КАК Контрагент,
	|	СписаниеДенежныхСредств.ЛицевойСчетКонтрагента КАК ВидЛицевогоСчета,
	|	СписаниеДенежныхСредств.СуммаДокумента КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредстваНаЛицевыхСчетах
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|ГДЕ
	|	СписаниеДенежныхСредств.Ссылка = &Ссылка
	|	И (СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета)
	|			ИЛИ СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.типыДенежныхСредств.ЛицевойСчет))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	СписаниеДенежныхСредств.Дата,
	|	СписаниеДенежныхСредств.СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредств.Контрагент,
	|	ЗНАЧЕНИЕ(Справочник.ВидыЛицевыхсчетов.ОсновнойЛицевойСчет),
	|	ВЫБОР
	|		КОГДА СписаниеДенежныхСредств.Сертификат.ВидНоминала
	|			ТОГДА СписаниеДенежныхСредств.СертификатСерийныйНомер.Номинал
	|		ИНАЧЕ СписаниеДенежныхСредств.Сертификат.Номинал
	|	КОНЕЦ - СписаниеДенежныхСредств.СуммаДокумента
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств,
	|	Константа.ЗачислятьОплатуСертификатомНаЛицевойСчет КАК ЗачислятьОплатуСертификатомНаЛицевойСчет
	|ГДЕ
	|	СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПодарочныйСертификат)
	|	И ЗачислятьОплатуСертификатомНаЛицевойСчет.Значение = ИСТИНА
	|	И СписаниеДенежныхСредств.Сертификат.СертификатМногоразовоеИспользование = ЛОЖЬ
	|	И СписаниеДенежныхСредств.Ссылка = &Ссылка
	|	И ВЫБОР
	|			КОГДА СписаниеДенежныхСредств.Сертификат.ВидНоминала
	|				ТОГДА СписаниеДенежныхСредств.СертификатСерийныйНомер.Номинал
	|			ИНАЧЕ СписаниеДенежныхСредств.Сертификат.Номинал
	|		КОНЕЦ > СписаниеДенежныхСредств.СуммаДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	СписаниеДенежныхСредств.Дата КАК Период,
	|	СписаниеДенежныхСредств.Дата КАК ДатаПлатежа,
	|	СписаниеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредств.ТипДенежныхСредств КАК ТипДенежныхСредств,
	|	СписаниеДенежныхСредств.СуммаДокумента КАК Сумма,
	|	СписаниеДенежныхСредств.ЭквайрингТерминал КАК ЭквайринговыйТерминал,
	|	СписаниеДенежныхСредств.ЭквайрингВидПлатежнойКарты КАК ВидПлатежнойКарты,
	|	СписаниеДенежныхСредств.ЭквайрингНомерПлатежнойКарты КАК НомерПлатежнойКарты
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыПоЭквайрингу
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|ГДЕ
	|	СписаниеДенежныхСредств.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.типыДенежныхСредств.ПлатежнаяКарта)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ВложенныйЗапрос.Период КАК Период,
	|	ВложенныйЗапрос.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВложенныйЗапрос.Сертификат КАК Сертификат,
	|	ВложенныйЗапрос.СерийныйНомер КАК СерийныйНомер,
	|	ВложенныйЗапрос.Сумма КАК Сумма,
	|	ВложенныйЗапрос.Контрагент КАК Контрагент,
	|	ВЫБОР
	|		КОГДА ВложенныйЗапрос.Сумма < ВложенныйЗапрос.СуммаОстаток
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Количество
	|ПОМЕСТИТЬ ВременнаяТаблицаСертификаты
	|ИЗ
	|	(ВЫБРАТЬ
	|		СписаниеДенежныхСредств.Дата КАК Период,
	|		СписаниеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		СписаниеДенежныхСредств.Сертификат КАК Сертификат,
	|		СписаниеДенежныхСредств.СертификатСерийныйНомер КАК СерийныйНомер,
	|		ВЫБОР
	|			КОГДА СписаниеДенежныхСредств.Сертификат.СертификатМногоразовоеИспользование
	|				ТОГДА СписаниеДенежныхСредств.СуммаДокумента
	|			ИНАЧЕ ВЫБОР
	|					КОГДА СписаниеДенежныхСредств.Сертификат.ВидНоминала
	|						ТОГДА ОстатокСуммыСертификата.СуммаОстаток
	|					ИНАЧЕ СписаниеДенежныхСредств.Сертификат.Номинал
	|				КОНЕЦ
	|		КОНЕЦ КАК Сумма,
	|		ВЫБОР
	|			КОГДА СписаниеДенежныхСредств.Сертификат.ЭтоИменнойСертификат
	|				ТОГДА СписаниеДенежныхСредств.Контрагент
	|		КОНЕЦ КАК Контрагент,
	|		ВЫБОР
	|			КОГДА СписаниеДенежныхСредств.Сертификат.ИспользоватьПартии
	|				ТОГДА ОстатокСуммыСертификата.СуммаОстаток
	|			ИНАЧЕ СписаниеДенежныхСредств.Сертификат.Номинал
	|		КОНЕЦ КАК СуммаОстаток
	|	ИЗ
	|		Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				СертификатыОстатки.Сертификат КАК Сертификат,
	|				СертификатыОстатки.СерийныйНомер КАК СерийныйНомер,
	|				СертификатыОстатки.Контрагент КАК Контрагент,
	|				СУММА(СертификатыОстатки.СуммаОстаток) КАК СуммаОстаток
	|			ИЗ
	|				РегистрНакопления.Сертификаты.Остатки КАК СертификатыОстатки
	|			
	|			СГРУППИРОВАТЬ ПО
	|				СертификатыОстатки.Сертификат,
	|				СертификатыОстатки.СерийныйНомер,
	|				СертификатыОстатки.Контрагент) КАК ОстатокСуммыСертификата
	|			ПО СписаниеДенежныхСредств.Сертификат = ОстатокСуммыСертификата.Сертификат
	|				И СписаниеДенежныхСредств.СертификатСерийныйНомер = ОстатокСуммыСертификата.СерийныйНомер
	|				И (ВЫБОР
	|					КОГДА ОстатокСуммыСертификата.Сертификат.ЭтоИменнойСертификат
	|						ТОГДА СписаниеДенежныхСредств.Контрагент = ОстатокСуммыСертификата.Контрагент
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ)
	|	ГДЕ
	|		СписаниеДенежныхСредств.Ссылка = &Ссылка
	|		И СписаниеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.типыДенежныхСредств.ПодарочныйСертификат)) КАК ВложенныйЗапрос
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	СписаниеДенежныхСредств.Дата КАК Период,
	|	СписаниеДенежныхСредств.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредств.Контрагент КАК Сотрудник,
	|	СписаниеДенежныхСредств.СуммаДокумента КАК Сумма,
	|	СписаниеДенежныхСредств.Ссылка КАК ДокументОснования
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПодотчетниками
	|ИЗ
	|	Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|ГДЕ
	|	СписаниеДенежныхСредств.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыдачаПодотчетнику)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата КАК Период,
	|	НАЧАЛОПЕРИОДА(СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВыплатаЗПМесяц, МЕСЯЦ) КАК МесяцНачисления,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования КАК ДокументНачисления,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Сотрудник КАК Сотрудник,
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПерсоналом
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка = &Ссылка
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыплатаЗаработнойПлаты)
	|;
