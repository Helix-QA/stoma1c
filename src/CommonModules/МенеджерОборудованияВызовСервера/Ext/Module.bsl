// Функция, выполняет формирование общих параметров для пробития чека. 
//
Функция ПолучитьОбщиеПараметрыПробитияЧека(ПараметрыЧека) Экспорт
	
	ОбщиеПараметры = МенеджерОборудованияКлиентСервер.ПараметрыОперацииФискализацииЧека();
	
	Если Не ЗначениеЗаполнено(ПараметрыЧека.Сотрудник) Тогда
		ПараметрыЧека.Сотрудник = ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	СтруктураРеквизитов = Новый Структура;
	СтруктураРеквизитов.Вставить("Наименование");
	СтруктураРеквизитов.Вставить("ИНН");
	СтруктураРеквизитов.Вставить("КПП");
	РеквизитыОрганизация = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыЧека.Организация, СтруктураРеквизитов);
	
	СтруктураРеквизитов = Новый Структура;
	СтруктураРеквизитов.Вставить("ЭлектронныйЧекSMSПередаютсяПрограммой1С");
	СтруктураРеквизитов.Вставить("ЭлектронныйЧекEmailПередаютсяПрограммой1С");
	СтруктураРеквизитов.Вставить("ККМНомерПроизводителя");
	РеквизитыКассыККМ = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыЧека.Касса, СтруктураРеквизитов);	
	
	ОбщиеПараметры.ТипРасчета = МенеджерОборудованияКлиентСервер.ПолучитьТипРасчетаДенежнымиСредствами(ПараметрыЧека.ТипЧека); //?(ПараметрыЧека.ТипЧека = 0, Перечисления.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств, Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств); // 0 - продажа, 1 - возврат

	ОбщиеПараметры.Электронно = Ложь;    
	
	ДанныеКассира = ОбщегоНазначенияСтоматология.ПолучитьКассира(ПараметрыЧека.Касса, ПараметрыЧека.Сотрудник);  
	ОбщиеПараметры.Вставить("ИмяКассира", ДанныеКассира.Наименование);
	ОбщиеПараметры.КассирИНН 		   = ДанныеКассира.ИНН; 	
	ОбщиеПараметры.Кассир 			   = ДанныеКассира.Наименование;
	
	ОбщиеПараметры.Организация		   = ПараметрыЧека.Организация; 
	ОбщиеПараметры.ОрганизацияНазвание = РеквизитыОрганизация.Наименование;
	ОбщиеПараметры.ОрганизацияИНН      = РеквизитыОрганизация.ИНН;
	ОбщиеПараметры.ОрганизацияКПП      = РеквизитыОрганизация.КПП;
	ОбщиеПараметры.НомерКассы          = "00001";
	ОбщиеПараметры.НомерЧека           = "1";
	ОбщиеПараметры.НомерСмены          = "1";

	СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ПараметрыЧека.Организация, ПараметрыЧека.Дата);
	АдресМагазина         = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(ПараметрыЧека.СтруктурнаяЕдиница, "Фактический");
		
	СерийныйНомер = РеквизитыКассыККМ.ККМНомерПроизводителя;
	Если НЕ ЗначениеЗаполнено(СерийныйНомер) Тогда
		СерийныйНомер = "1";
	КонецЕсли;
	
	ОбщиеПараметры.АдресМагазина        = АдресМагазина;
	ОбщиеПараметры.НаименованиеМагазина = Строка(ПараметрыЧека.СтруктурнаяЕдиница);
	ОбщиеПараметры.СерийныйНомер        = СерийныйНомер;
	ОбщиеПараметры.Вставить("КодСистемыНалогообложения", 0);
	
	Если ПараметрыЧека.Свойство("ВидНалога") Тогда
		ОбщиеПараметры.КодСистемыНалогообложения = МенеджерОборудованияВызовСервера.КодСистемыНалогообложения(ПараметрыЧека.Организация, ПараметрыЧека.ВидНалога); 		
		ОбщиеПараметры.СистемаНалогообложения    = ПараметрыЧека.ВидНалога;
	КонецЕсли;
	
	ОбщиеПараметры.Вставить("ВидОперации"  , ПараметрыЧека.ВидОперации);
	ОбщиеПараметры.Вставить("СуммаКОплате" , ПараметрыЧека.СуммаКОплате);
	ОбщиеПараметры.Вставить("СуммаОплачено", ПараметрыЧека.СуммаОплачено);
	ОбщиеПараметры.Вставить("Касса"        , ПараметрыЧека.Касса);
	
	ОбщиеПараметры.Электронно      = ПараметрыЧека.ВыводитьЧекНаБумагу <> Истина;
    ОбщиеПараметры.ПокупательEmail = ПараметрыЧека.ЭлектроннаяПочтаКлиента;	
	ОбщиеПараметры.ПокупательНомер = ПараметрыЧека.НомерТелефонаКлиента;
	
	ОбщиеПараметры.Вставить("Контрагент", ?(ПараметрыЧека.Свойство("Клиент"), ПараметрыЧека.Клиент, ""));
	
	ЗаполнитьДанныеПокупателя(ОбщиеПараметры, ПараметрыЧека); // теги 1227 и 1228.
	
	Если ОбщиеПараметры.Свойство("ДокументОснование") И ПараметрыЧека.Свойство("МассивДокументовОснований") Тогда
		ОбщиеПараметры.ДокументОснование = ПараметрыЧека.МассивДокументовОснований;         
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка указания документов основания при пробитии чека");
	КонецЕсли; 
	
	Если ПараметрыЧека.Свойство("ДополнительныйРеквизит") Тогда
		ОбщиеПараметры.ДополнительныйРеквизит = ПараметрыЧека.ДополнительныйРеквизит;	
	КонецЕсли;
	
	Возврат Новый ФиксированнаяСтруктура(ОбщиеПараметры);
	
КонецФункции

// Процедура - заполняет данные покупателя (теги 1227 и 1228).
//
Процедура ЗаполнитьДанныеПокупателя(ОбщиеПараметры, ПараметрыЧека)
	
	// В соответствии с подп. «д» п. 15 ст. 1 Закона от 03.07.2018 № 192-ФЗ (ССЫЛКА) в положениях ст. 4.7 Закона № 54-ФЗ (ССЫЛКА) появится новый пункт 6.1:
	// «6.1. Кассовый чек или бланк строгой отчетности, сформированные при осуществлении расчетов между организациями и (или) индивидуальными 
	// Предпринимателями с использованием наличных денег и (или) с предъявлением электронных средств платежа, наряду с реквизитами, указанными в пункте 1 
	// Настоящей статьи, должен содержать следующие реквизиты:
	// 1) наименование покупателя (клиента) (наименование организации, фамилия, имя, отчество (при наличии) индивидуального предпринимателя);
	// 2) идентификационный номер налогоплательщика покупателя (клиента);
	// 3) сведения о стране происхождения товара (при осуществлении расчетов за товар);
	// 4) сумма акциза (если применимо);
	// 5) регистрационный номер таможенной декларации (при осуществлении расчетов за товар) (если применимо).»
	// соответствии с которым в кассовом чеке (БСО), что формируется при расчетах между хозяйствующими субъектами (ИП, юрлицами) с помощью наличных или по карте, обязательно должны быть отражены следующие реквизиты (наряду с теми, что предусмотрены п. 1 ст. 4.7):
	// наименование покупателя или клиента (ФИО ИП);
	// ИНН покупателя или клиента;
	// данные о стране происхождения реализованного товара;
	// величина акциза (по подакцизному товару);
	// номер таможенной декларации (если она применяется в правоотношениях между покупателем и продавцом).
	
	Если ПараметрыЧека.Свойство("Клиент") 
		И ТипЗнч(ПараметрыЧека.Клиент) = Тип("СправочникСсылка.Контрагенты") 
		И ЗначениеЗаполнено(ПараметрыЧека.Клиент) Тогда
		
		РеквизитыПокупателя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
								ПараметрыЧека.Клиент,
								"НаименованиеПолное, ИНН, ТипКонтрагента");
		
		Если РеквизитыПокупателя.ТипКонтрагента = Перечисления.ТипыКонтрагентов.Клиенты Тогда
			Возврат;											
		КонецЕсли;      		
		
		ДокументУдостоверяющийЛичность	= РегистрыСведений.ДокументыФизическихЛиц.ДокументУдостоверяющийЛичностьФизлица(ПараметрыЧека.Клиент);
		
		Если ЗначениеЗаполнено(ДокументУдостоверяющийЛичность) Тогда
			ДокументУдостоверяющийЛичность = " " + СокрЛП(ДокументУдостоверяющийЛичность);
		КонецЕсли;
		
		ОбщиеПараметры.Вставить("Получатель"	, РеквизитыПокупателя.НаименованиеПолное + ДокументУдостоверяющийЛичность);
		ОбщиеПараметры.Вставить("ПолучательИНН"	, РеквизитыПокупателя.ИНН);
		
	КонецЕсли;  
	
КонецПроцедуры

// Функция, выполняет формирование общих параметров для пробития чека. 
//
Функция ПолучитьОбщиеПараметрыПробитияЧекаКоррекции(ПараметрыЧека) Экспорт
	
	ОбщиеПараметры = МенеджерОборудованияКлиентСервер.ПараметрыОперацииЧекаКоррекции();
	
	ОбщиеПараметрыЧека = Новый Структура(ПолучитьОбщиеПараметрыПробитияЧека(ПараметрыЧека));
	// ЗаполнитьЗначенияСвойств(ОбщиеПараметры, ОбщиеПараметрыЧека);
	// надо добавлять, т.к. ряд свойств добавляется в функции ПолучитьОбщиеПараметрыПробитияЧека.
	Для Каждого ЭлементСтруктуры Из ОбщиеПараметрыЧека Цикл
		Если Не ОбщиеПараметры.Свойство(ЭлементСтруктуры.Ключ) Тогда
			 ОбщиеПараметры.Вставить(ЭлементСтруктуры.Ключ);
		 КонецЕсли;
		 ОбщиеПараметры[ЭлементСтруктуры.Ключ] = ЭлементСтруктуры.Значение;
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(ОбщиеПараметры, ПараметрыЧека, "СформироватьЧекКоррекции, НеприменениеККТ, КорректируемыйДокумент"); 
	ЗаполнитьЗначенияСвойств(ОбщиеПараметры.ДанныеКоррекции, ПараметрыЧека.ДанныеКоррекции); 
		
	Возврат Новый ФиксированнаяСтруктура(ОбщиеПараметры);
	
КонецФункции  

// Процедура, добавляет товары в общие параметры чека.
//
Процедура ДобавитьТоварыВОбщиеПараметрыЧека(ОбщиеПараметры, МассивТоваров)
	
	ИспользоватьСтаруюСистемуФормированияДляФРдляККТ = Справочники.Кассы.ИспользоватьСтаруюСистемуФормированияДляФРдляККТ(ОбщиеПараметры.Касса);
		    	
	Для Каждого СтрокаМ ИЗ МассивТоваров Цикл		
		
		Цена = СтрокаМ.СтоимостьБезСкидки / СтрокаМ.Количество;		
		
		СтрокаПозицииЧека = МенеджерОборудованияКлиентСервер.ПараметрыФискальнойСтрокиЧека(); 	
		
		СтрокаПозицииЧека.Вставить("Номенклатура", СтрокаМ.Номенклатура);
		СтрокаПозицииЧека.Наименование     = СтрокаМ.Наименование;
		СтрокаПозицииЧека.Количество       = СтрокаМ.Количество;
		СтрокаПозицииЧека.Цена             = Цена;		
		// СтрокаПозицииЧека.Сумма            = СтрокаМ.СтоимостьСоСкидкой;
		СтрокаПозицииЧека.Сумма            = СтрокаМ.СтоимостьСоСкидкой  
												+ ?((СтрокаМ.Свойство("СуммаВключаетНДС") и СтрокаМ.СуммаВключаетНДС) 
														Или НЕ СтрокаМ.Свойство("СуммаВключаетНДС"), 0, СтрокаМ.СуммаНДС);
		СтрокаПозицииЧека.ЦенаСоСкидками   = Окр(СтрокаПозицииЧека.Сумма / СтрокаПозицииЧека.Количество, 2, 1); // - ?((СтрокаМ.Свойство("СуммаВключаетНДС") и СтрокаМ.СуммаВключаетНДС) или НЕ СтрокаМ.Свойство("СуммаВключаетНДС"), 0, СтрокаМ.СуммаНДС);
		СтрокаПозицииЧека.СуммаСкидок      = СтрокаМ.СуммаСкидки;
		СтрокаПозицииЧека.НомерСекции      = СтрокаМ.НомерСекции;		
		
		Если ОбщиеПараметры.Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ Тогда
			СтрокаПозицииЧека.СтавкаНДС        = ПолучитьСтавкуНДСККТ(СтрокаМ.СтавкаНДС); 
		Иначе
			СтрокаПозицииЧека.СтавкаНДС        = ПолучитьСтавкуНДСККТ(СтрокаМ.СтавкаНДС);// СтрокаМ.СтавкаНДС.Ставка;  // возможно необходимо умножать на 100
		КонецЕсли;
		
		СтрокаПозицииЧека.СуммаНДС         = СтрокаМ.СуммаНДС;
		СтрокаПозицииЧека.Штрихкод         = СтрокаМ.Штрихкод;	
		СтрокаПозицииЧека.Вставить("ЭтоОплатаКредита", СтрокаМ.ЭтоОплатаКредита);
		
		СтрокаПозицииЧека.ПризнакАгентаПоПредметуРасчета		= СтрокаМ.ПризнакАгентаПоПредметуРасчета; 
		// СтрокаПозицииЧека.ДанныеАгента.ПлатежныйАгент.Телефон 	= СтрокаМ.ДанныеПоставщика.Телефон;
		СтрокаПозицииЧека.ДанныеПоставщика.ИНН					= СтрокаМ.ДанныеПоставщика.ИНН;		
		СтрокаПозицииЧека.ДанныеПоставщика.Наименование 		= СтрокаМ.ДанныеПоставщика.Наименование;
		СтрокаПозицииЧека.ДанныеПоставщика.Телефон				= СтрокаМ.ДанныеПоставщика.Телефон;
		
		СтрокаПозицииЧека.СуммаВключаетНДС						= СтрокаМ.СуммаВключаетНДС;
		
		Если СтрокаПозицииЧека.Свойство("ДанныеКодаТоварнойНоменклатуры") И СтрокаМ.Свойство("ДанныеКодаТоварнойНоменклатуры") Тогда
			ЗаполнитьЗначенияСвойств(СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры, СтрокаМ.ДанныеКодаТоварнойНоменклатуры); 
		КонецЕсли;
		
		Если Не ИспользоватьСтаруюСистемуФормированияДляФРдляККТ Тогда
			
			Если (ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.Продажа
				ИЛИ ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.Возврат
				ИЛИ ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту) Тогда
				
				СтрокаПозицииЧека.ПризнакПредметаРасчета = ПризнакПредметаРасчетаПриПродажеИлиВозврате(
																СтрокаПозицииЧека.Номенклатура, 
																СтрокаПозицииЧека.ЭтоОплатаКредита); 
				
												
				Если ЗначениеЗаполнено(СтрокаМ.Номенклатура) 
					И ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаМ.Номенклатура, "ТипНоменклатуры") = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
					
					СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПризнакСпособаРасчетаПриПродажеИлиВозвратеСертификата();
					
				Иначе
					
					Если ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.Продажа
						Или ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.ВозвратОшибочнойОплатыКлиенту Тогда
						
						СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(
																		СтрокаМ.СтоимостьСоСкидкой, 
																		СтрокаМ.СуммаОплачено, 
																		СтрокаПозицииЧека.ЭтоОплатаКредита); 
						
					Иначе
						
						СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(
																		ОбщиеПараметры.СуммаКОплате, 
																		ОбщиеПараметры.СуммаОплачено, 
																		Ложь); 
						
					КонецЕсли;
					
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(СтрокаМ.Номенклатура)
					И (СтрокаМ.Наименование = МенеджерОборудованияВызовСервера.ПолучитьСловоСУчетомЯзыка("Взнос на лицевой счет") 
					Или СтрНайти(СтрокаМ.Наименование, МенеджерОборудованияВызовСервера.ПолучитьСловоСУчетомЯзыка("Аванс от:")) <> 0)  Тогда
					
					СтрокаПозицииЧека.ПризнакПредметаРасчета = ПризнакПредметаРасчетаПриВзносеНаЛицевойСчетИлиВозврате();
					СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПризнакСпособаРасчетаПриВзносееНаЛицевойСчетИлиВозврате();
					
				КонецЕсли;
				
			ИначеЕсли ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет
				ИЛИ ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.ВозвратСЛицевогоСчета Тогда
				
				СтрокаПозицииЧека.ПризнакПредметаРасчета = ПризнакПредметаРасчетаПриВзносеНаЛицевойСчетИлиВозврате();
				СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПризнакСпособаРасчетаПриВзносееНаЛицевойСчетИлиВозврате();
				
			// ИначеЕсли ОбщиеПараметры.ВидОперации = Перечисления.ВидыОпераций.ЗачетАванса Тогда
			//	
			//	СтрокаПозицииЧека.ПризнакСпособаРасчета  = ?(ЗначениеЗаполнено(СтрокаМ.ПризнакСпособаРасчета) , СтрокаМ.ПризнакСпособаРасчета, Перечисления.ПризнакиСпособаРасчета.ПередачаСПолнойОплатой);
			//	СтрокаПозицииЧека.ПризнакПредметаРасчета = ?(ЗначениеЗаполнено(СтрокаМ.ПризнакПредметаРасчета),СтрокаМ.ПризнакПредметаРасчета,Перечисления.ПризнакиПредметаРасчета.Услуга);
				
			КонецЕсли;
			
		// ИначеЕсли ЗначениеЗаполнено(СтрокаМ.ПризнакПредметаРасчета) И ЗначениеЗаполнено(СтрокаМ.ПризнакСпособаРасчета) Тогда
		//	// в чеке коррекции сами указывают.
		//	 СтрокаПозицииЧека.ПризнакПредметаРасчета	= СтрокаМ.ПризнакПредметаРасчета;
		//	 СтрокаПозицииЧека.ПризнакСпособаРасчета	= СтрокаМ.ПризнакСпособаРасчета;
		КонецЕсли;

		ОбщиеПараметры.ПозицииЧека.Добавить(СтрокаПозицииЧека);
		
	КонецЦикла;	
	
КонецПроцедуры

// Процедура, добавляет оплаты в общие параметры чека.
//
Процедура ДобавитьОплатуВОбщиеПараметрыЧека(ОбщиеПараметры, МассивОплат)
	
	ЭтоККТ = ОбщиеПараметры.Касса.ВнешнееОборудование.ТипОборудования = Перечисления.ТипыПодключаемогоОборудования.ККТ;
    ИспользоватьСтаруюСистемуФормированияДляФРдляККТ = Справочники.Кассы.ИспользоватьСтаруюСистемуФормированияДляФРдляККТ(ОбщиеПараметры.Касса);
	
	Для Каждого СтрокаМ ИЗ МассивОплат Цикл
		
		ТипОплаты     = Неопределено;
		ОплатаСумма   = СтрокаМ.Сумма;
		ТипОплаты     = ПолучитьТипОплатыПоТипуДенежныхСредств(ЭтоККТ, СтрокаМ.ТипОплаты);		
		
		СтрокаОплаты = Новый Структура();
		СтрокаОплаты.Вставить("ТипОплаты", ТипОплаты);
		СтрокаОплаты.Вставить("Сумма"    , ОплатаСумма);
		
		ОбщиеПараметры.ТаблицаОплат.Добавить(СтрокаОплаты);			
		
	КонецЦикла;
	
	// При не полной оплате добавляем строку постоплаты(долг, рассрочка, кредит)
	Если ЭтоККТ = Истина 
		И ИспользоватьСтаруюСистемуФормированияДляФРдляККТ = Ложь
		И ОбщиеПараметры.СуммаКОплате > ОбщиеПараметры.СуммаОплачено Тогда
		
		СтрокаОплаты = Новый Структура();
		СтрокаОплаты.Вставить("ТипОплаты", Перечисления.ТипыОплатыККТ.Постоплата);
		СтрокаОплаты.Вставить("Сумма"    , ОбщиеПараметры.СуммаКОплате - ОбщиеПараметры.СуммаОплачено);
		
		ОбщиеПараметры.ТаблицаОплат.Добавить(СтрокаОплаты);	
		
	КонецЕсли;
	
КонецПроцедуры

// Функция, формирует таблицы товаров и оплат.
//
Функция СформироватьТаблицыТоваровИОплат(ПараметрыЧека, ОписаниеОшибки)
	
	ПроизошлоИсключение = Ложь;
	СуммаЧекаБезСкидок  = 0;
	СуммаЧекаСоСкидками = 0;
	Счетчик             = 1;
	ТаблицаТовары       = Новый Массив;
	
	///////////////// ПОДГОТОВКА МАССИВА ПАРАМЕТРОВ ТОВАРОВ ///////////////////////	
	
	// Если передана таблица товаров значения берутся из нее
	Если ПараметрыЧека.Свойство("МассивПараметровТовары")
		И ЗначениеЗаполнено(ПараметрыЧека.МассивПараметровТовары) Тогда
		
		// Заполнение массива параметров товаров
		Для Каждого СтрокаМ ИЗ ПараметрыЧека.МассивПараметровТовары Цикл
			
			Если СтрокаМ.СтоимостьБезСкидки = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ПараметрыТовара  = ПустаяСтруктураСтрокиТоваровЧека();
			
			ЗаполнитьЗначенияСвойств(ПараметрыТовара, СтрокаМ);
			
			ПараметрыТовара.Наименование       = ?(СтрокаМ.Свойство("Наименование")      , СтрокаМ.Наименование,"Позиция №" + Счетчик);		
			ПараметрыТовара.НомерСекции        = ?(СтрокаМ.Свойство("НомерСекции")       , СтрокаМ.НомерСекции, 1);
			ПараметрыТовара.СтоимостьБезСкидки = ?(СтрокаМ.Свойство("СтоимостьБезСкидки"), СтрокаМ.СтоимостьБезСкидки,0);
			ПараметрыТовара.СуммаСкидки        = ?(СтрокаМ.Свойство("СуммаСкидки")       , СтрокаМ.СуммаСкидки,0);
			ПараметрыТовара.Количество         = ?(СтрокаМ.Свойство("Количество")        , СтрокаМ.Количество,0);
			ПараметрыТовара.СтавкаНДС          = ?(СтрокаМ.Свойство("СтавкаНДС")         , СтрокаМ.СтавкаНДС, ПараметрыЧека.Организация.СтавкаНДС);
			ПараметрыТовара.Штрихкод           = ?(СтрокаМ.Свойство("Штрихкод")          , СтрокаМ.Штрихкод, Null);  
			
			Счетчик = Счетчик + 1;
			ТаблицаТовары.Добавить(ПараметрыТовара);
			
		КонецЦикла;		  
		 
	// Если переданы одничные параметры товара
	Иначе
		
		ПараметрыТовара = ПустаяСтруктураСтрокиТоваровЧека();
				
		ПараметрыТовара.Наименование       = ?(ПараметрыЧека.Свойство("Наименование")      , ПараметрыЧека.Наименование,"Позиция №1");
		ПараметрыТовара.НомерСекции        = ?(ПараметрыЧека.Свойство("НомерСекции")       , ПараметрыЧека.НомерСекции, 1);
        ПараметрыТовара.СтоимостьБезСкидки = ?(ПараметрыЧека.Свойство("СтоимостьБезСкидки") И ЗначениеЗаполнено(ПараметрыЧека.СтоимостьБезСкидки), ПараметрыЧека.СтоимостьБезСкидки, 0);
		// Если НЕ ЗначениеЗаполнено(ПараметрыТовара.СтоимостьБезСкидки) Тогда
		//	ПараметрыТовара.СтоимостьБезСкидки = ПараметрыЧека.СуммаКОплате;
		// КонецЕсли;
		
		ПараметрыТовара.СуммаСкидки        = ?(ПараметрыЧека.Свойство("СуммаСкидки")       , ПараметрыЧека.СуммаСкидки, 0);
		ПараметрыТовара.Количество         = ?(ПараметрыЧека.Свойство("Количество")        , ПараметрыЧека.Количество,0);
		ПараметрыТовара.СтавкаНДС          = ?(ПараметрыЧека.Свойство("СтавкаНДС")         , ПараметрыЧека.СтавкаНДС, ПараметрыЧека.Организация.СтавкаНДС);
		ПараметрыТовара.Штрихкод           = ?(ПараметрыЧека.Свойство("Штрихкод")          , ПараметрыЧека.Штрихкод, Null);
		ПараметрыТовара.СуммаНДС           = Ценообразование.РассчитатьСуммуНДС(
												?(ПараметрыЧека.Свойство("СтоимостьСоСкидкой"), ПараметрыЧека.СтоимостьСоСкидкой, ПараметрыТовара.СтоимостьБезСкидки), 
												ПараметрыТовара.СтавкаНДС);
		
		ТаблицаТовары.Добавить(ПараметрыТовара);

	КонецЕсли;

	// Подготовка таблицы товароа и проверка правильности заполнения	
	Счетчик = 1;
	Для Каждого СтрокаМ ИЗ ТаблицаТовары Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаМ.Наименование) Тогда
			 СтрокаМ.Наименование = "Позиция №" + Счетчик;
		КонецЕсли;
		
		// Обработка исключительных ситуаций
		Если НЕ ЗначениеЗаполнено(СтрокаМ.СтоимостьБезСкидки) Тогда
			
			ОписаниеОшибки      = НСтр("ru= 'Не указана стоимость для позиции: ';en= 'No value for position: '") + СтрокаМ.Наименование;
			ПроизошлоИсключение = Истина;
			Прервать;
			
		ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаМ.Количество) Тогда
			
			ОписаниеОшибки      = НСтр("ru= 'Не указано количество для позиции: ';en= 'Not specified quantity for item: '") + СтрокаМ.Наименование;
			ПроизошлоИсключение = Истина;
			Прервать;
			
		КонецЕсли;
		
		// Расчет процента скидки
		Если ЗначениеЗаполнено(СтрокаМ.СуммаСкидки) Тогда		
			
			СтрокаМ.СтоимостьСоСкидкой = СтрокаМ.СтоимостьБезСкидки - СтрокаМ.СуммаСкидки; 
			СтрокаМ.ПроцентСкидки      = (СтрокаМ.СуммаСкидки / СтрокаМ.СтоимостьБезСкидки) % 10;
			
		Иначе
			
			СтрокаМ.СтоимостьСоСкидкой = СтрокаМ.СтоимостьБезСкидки;
			СтрокаМ.ПроцентСкидки      = 0;
			
		КонецЕсли;
		
		// Подсчет суммы чека
		СуммаЧекаБезСкидок   = СуммаЧекаБезСкидок  +  СтрокаМ.СтоимостьБезСкидки; //(СтрокаМ.Количество *
		СуммаЧекаСоСкидками  = СуммаЧекаСоСкидками +  СтрокаМ.СтоимостьСоСкидкой + ?(СтрокаМ.СуммаВключаетНДС, 0, СтрокаМ.СуммаНДС); //(СтрокаМ.Количество * 
		Счетчик              = Счетчик + 1;
		
	КонецЦикла;
	
	Если ПараметрыЧека.Свойство("МассивПараметровТовары") Тогда
		ПараметрыЧека.МассивПараметровТовары = ТаблицаТовары;
	Иначе
		ПараметрыЧека.Вставить("МассивПараметровТовары",ТаблицаТовары);
	КонецЕсли;
	
    ///////////////// ПОДГОТОВКА МАССИВА ПАРАМЕТРОВ ОПЛАТЫ ///////////////////////	
	
	// Подготовка таблицы оплат. Группировка и суммирование одинаковых типов
	Если ПараметрыЧека.Свойство("МассивПараметровОплаты")
		И ЗначениеЗаполнено(ПараметрыЧека.МассивПараметровОплаты) Тогда
		
		МассивДанных = ПараметрыЧека.МассивПараметровОплаты;
		Для А = 0 По МассивДанных.Количество() - 2 Цикл
						
			Счетчик = А + 1;
			Пока  Счетчик <= МассивДанных.Количество() - 1 Цикл
				Если МассивДанных[А].ТипОплаты = МассивДанных[Счетчик].ТипОплаты Тогда
					МассивДанных[А].Сумма =  МассивДанных[А].Сумма +  МассивДанных[Счетчик].Сумма;
					МассивДанных.Удалить(Счетчик);
				Иначе
					Счетчик = Счетчик + 1;
				КонецЕсли;	 
			КонецЦикла;
		КонецЦикла;
		
	Иначе // Если не указан массив параметров оплаты создаем его
		
		Если НЕ ПараметрыЧека.Свойство("ТипОплаты") Тогда
			
			ОписаниеОшибки      = НСтр("ru= 'В параметрах переданных для печати чека не указан тип денежных средств.';en= 'In the parameters of the check sent for printing, the type of funds is not indicated.'");
			ПроизошлоИсключение = Истина;
			
		ИначеЕсли ЗначениеЗаполнено(ПараметрыЧека.ТипОплаты) Тогда
			
			ПараметрыОплаты = Новый Структура; 
			ПараметрыОплаты.Вставить("ТипОплаты", ПараметрыЧека.ТипОплаты);
			ПараметрыОплаты.Вставить("Сумма"    , СуммаЧекаСоСкидками);
			
			МассивПараметровОплаты = Новый Массив;
			МассивПараметровОплаты.Добавить(ПараметрыОплаты);
			
			ПараметрыЧека.Вставить("МассивПараметровОплаты", МассивПараметровОплаты);
			
		Иначе
			
			ПараметрыЧека.Вставить("МассивПараметровОплаты", Новый Массив);
			
		КонецЕсли;
		
	КонецЕсли;	
	
	 ///////////////// ЗАВЕРШЕНИЕ ОПЕРАЦИИ ПОДГОТОВКИ ///////////////////////	
	
	// Операция подготовки проведена успешно
	Если НЕ ПроизошлоИсключение Тогда
				
		ПараметрыЧека.Вставить("СуммаЧекаБезСкидок" ,СуммаЧекаБезСкидок);
		ПараметрыЧека.Вставить("СуммаЧекаСоСкидками",СуммаЧекаСоСкидками);
		
		Возврат Истина;
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Функция - Подготовить данные для пробития фискального чека
//
// Параметры:
//  ПараметрыЧека	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПодготовитьДанныеДляПробитияФискальногоЧекаККТ(ПараметрыЧека) Экспорт
	
	РезультатОперации  = Новый Структура("Результат, ОписаниеОшибки", Истина, Неопределено);
	
	Попытка
		
		Касса				= ?(ПараметрыЧека.Свойство("Касса"), ПараметрыЧека.Касса, Неопределено);
		ПроизошлоИсключение	= Ложь;
		
		Если Касса = Неопределено Тогда
			
			РезультатОперации.Результат      = Ложь;
			РезультатОперации.ОписаниеОшибки = НСтр("ru = 'Для данной операции необходимо указать кассу!'; en = 'For this operation, you must specify the cashbox!'");
			Возврат РезультатОперации;		
			
		КонецЕсли;
		
		// Если в кассе не используется оборудование отменить операцию.
		Если Касса.ИспользоватьБезПодключенияОборудования Тогда
			
			РезультатОперации.Результат      = Ложь;
			РезультатОперации.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Касса: %1 используется без подключения оборудования!';en= 'Cashbox: %1 is used without connecting equipment!'"), Касса);
			Возврат РезультатОперации;
			
		КонецЕсли;		
		
		// Если ПараметрыЧека.ВыводитьЧекНаБумагу <> Истина
		//	И НЕ ЗначениеЗаполнено(ПараметрыЧека.ЭлектроннаяПочтаКлиента)
		//	И НЕ ЗначениеЗаполнено(ПараметрыЧека.НомерТелефонаКлиента) Тогда
		//	
		//	РезультатОперации.Результат      = Ложь;
		//	РезультатОперации.ОписаниеОшибки = "Необходимо выбрать хотя бы один из методов вывода чека ККТ. На бумагу, эл. почту или телефон клиента";
		//	Возврат РезультатОперации;
		
		// КонецЕсли;
		
		// Предварительная подготовка товаров и оплат.
		ОписаниеОшибки = "";
		Если СформироватьТаблицыТоваровИОплат(ПараметрыЧека, ОписаниеОшибки) = Ложь Тогда
			
			РезультатОперации.Результат      = Ложь;
			РезультатОперации.ОписаниеОшибки = ОписаниеОшибки;
			Возврат РезультатОперации;
			
		КонецЕсли;
		
		// Получаем общие параметры для пробития чека на ФР (ФИКСИРОВАННАЯ СТРУКТУРА).
		ОбщиеПараметры = ПолучитьОбщиеПараметрыПробитияЧека(ПараметрыЧека);  	
		
		// Копируем основные параметры чека.
		ФискальныйЧек = Новый Структура(ОбщиеПараметры);
		ФискальныйЧек.ПозицииЧека  = Новый Массив;
		ФискальныйЧек.ТаблицаОплат = Новый Массив;
		
		ДобавитьТоварыВОбщиеПараметрыЧека(ФискальныйЧек, ПараметрыЧека.МассивПараметровТовары);
		ДобавитьОплатуВОбщиеПараметрыЧека(ФискальныйЧек, ПараметрыЧека.МассивПараметровОплаты);		
		
		// При необходимости будет проведен формато-логический контроль
		Если ЗначениеЗаполнено(ФискальныйЧек.Касса.ВнешнееОборудование) Тогда 
			РеквизитыОборудования  = ФорматноЛогическийКонтрольВызовСервера.СтруктураДанныхФорматноЛогическогоКонтроля(ФискальныйЧек.Касса.ВнешнееОборудование);
			ФискальныйЧек.СпособФорматноЛогическогоКонтроля				= РеквизитыОборудования.СпособФорматноЛогическогоКонтроля;
			ФискальныйЧек.ДопустимоеРасхождениеФорматноЛогическогоКонтроля = РеквизитыОборудования.ДопустимоеРасхождениеФорматноЛогическогоКонтроля;
		Иначе
			ФискальныйЧек.СпособФорматноЛогическогоКонтроля = Перечисления.СпособыФорматноЛогическогоКонтроля.РазделятьСтроки;
		КонецЕсли;
		
		ФорматноЛогическийКонтрольКлиентСервер.ПровестиФорматноЛогическийКонтроль(ФискальныйЧек, ФискальныйЧек.Касса.ВнешнееОборудование);
		
		// ФискальныйЧек.СпособФорматоЛогическогоКонтроля = ФискальныйЧек.Касса.ВнешнееОборудование.СпособФорматоЛогическогоКонтроля;
		// ФискальныйЧек.ДопустимоеРасхождениеФорматоЛогическогоКонтроля = ФискальныйЧек.Касса.ВнешнееОборудование.ДопустимоеРасхождениеФорматоЛогическогоКонтроля;
		// Если МенеджерОборудованияКлиентСервер.НуженФорматоЛогическийКонтроль(ФискальныйЧек) Тогда
		//	МенеджерОборудованияКлиентСервер.ПровестиФорматоЛогическийКонтроль(ФискальныйЧек);
		// КонецЕсли; 
		
		РезультатОперации.Вставить("ФискальныйЧек", ФискальныйЧек);
		
	Исключение
		ОписаниеОшибки				= ОписаниеОшибки();
		СтрокаДокументовОснований	= "";
		Если ПараметрыЧека.Свойство("МассивДокументовОснований") Тогда
			Для Каждого ЭлементМ Из ПараметрыЧека.МассивДокументовОснований Цикл
				СтрокаДокументовОснований = СтрокаДокументовОснований + ?(ЗначениеЗаполнено(СтрокаДокументовОснований), ", ", "") + ЭлементМ;
			КонецЦикла;
		КонецЕсли;
		СтрокаТоваров = "";
		Если ПараметрыЧека.Свойство("МассивПараметровТовары") Тогда
			Если ЗначениеЗаполнено(ПараметрыЧека.МассивПараметровТовары) Тогда
				Для Каждого ЭлементМ Из ПараметрыЧека.МассивПараметровТовары Цикл
					СтрокаТоваров = СтрокаТоваров +
										?(ЗначениеЗаполнено(СтрокаТоваров), ", ", "") +
										?(ЭлементМ.Свойство("Наименование"), ЭлементМ.Наименование, "<не указано>");
				КонецЦикла;
			Иначе
				СтрокаТоваров = "<не указано>";
			КонецЕсли;
		КонецЕсли;
		
		ТекстСообщения = СтрШаблон("Ошибка формирования параметров чека для документов оплаты: %1. Список товаров: %2. Описание ошибки %3",
							СтрокаДокументовОснований, СтрокаТоваров, ОписаниеОшибки);
		ЗаписьЖурналаРегистрации("Ошибка пробития чека ККМ", УровеньЖурналаРегистрации.Предупреждение,,, ТекстСообщения);
		
		РезультатОперации = Новый Структура("Результат, ОписаниеОшибки", Ложь, ТекстСообщения);
	КонецПопытки;
	
	Возврат РезультатОперации;
	
КонецФункции

// Функция - Признак способа расчета при продаже
//
// Параметры:
//  СуммаКОплате	 - 	 - 
//  СуммаПлатежа	 - 	 - 
//  ЭтоОплатаКредита - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПризнакСпособаРасчетаПриПродажеИлиВозвратеУслугиТовара(СуммаКОплате, СуммаПлатежа, ЭтоОплатаКредита = Ложь)
	
	Если ЭтоОплатаКредита Тогда
		
		Возврат Перечисления.ПризнакиСпособаРасчета.ОплатаКредита;
		
	КонецЕсли;
	
	Если СуммаКОплате <= СуммаПлатежа Тогда
		
		Возврат Перечисления.ПризнакиСпособаРасчета.ПередачаСПолнойОплатой;
		
	ИначеЕсли СуммаПлатежа > 0 И СуммаПлатежа < СуммаКОплате Тогда
		
		Возврат Перечисления.ПризнакиСпособаРасчета.ПередачаСЧастичнойОплатой;
		
	ИначеЕсли СуммаПлатежа = 0 Тогда
		
		Возврат Перечисления.ПризнакиСпособаРасчета.ПередачаБезОплаты;
		
	КонецЕсли;
	
КонецФункции

// Функция - Признак предмета расчета при продаже
//
// Параметры:
//  Номенклатура - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПризнакПредметаРасчетаПриПродажеИлиВозврате(Номенклатура, ЭтоОплатаКредита = Ложь)
	
	ТипНоменклатуры = Неопределено;
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		ТипНоменклатуры = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Номенклатура, "ТипНоменклатуры"); 
	КонецЕсли;
	
	Если ЭтоОплатаКредита <> Истина
		И (ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
		ИЛИ ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Набор) Тогда
		
		Возврат Перечисления.ПризнакиПредметаРасчета.Услуга;
		
	ИначеЕсли ЭтоОплатаКредита <> Истина
		И (ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас
		ИЛИ ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Материал) Тогда
		
		Возврат Перечисления.ПризнакиПредметаРасчета.Товар;

	ИначеЕсли ЭтоОплатаКредита = Истина 
		ИЛИ ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
		
	    Возврат Перечисления.ПризнакиПредметаРасчета.ПлатежВыплата;

	КонецЕсли;
	
КонецФункции

