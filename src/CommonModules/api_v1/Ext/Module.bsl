#Область book_times

// Функция, возвращает список сеансов, доступных для бронирования.
// 
Функция book_times(СтруктурнаяЕдиница, datetime, service_ids, service_id, staff_id) Экспорт
	
	СтруктураОшибки = Неопределено;
	
	ДатаСреза	  	   = ПолучитьИПроверитьДату(datetime, СтруктураОшибки);
	ДатаСрезаЗаполнена = ЗначениеЗаполнено(ДатаСреза);
	МассивУслуг	  	   = ПолучитьМассивУслугПоИдентификаторам(service_ids, service_id, СтруктураОшибки);
	Сотрудник 	  	   = ПолучитьСсылкуПоИдентификатору(staff_id, СтруктураОшибки, Истина, "Сотрудники", 1050);
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	ПроверятьВремяДействияУслуги = МассивУслуг.Количество() = 1;
	МассивДоступныхСеансов 		 = Новый Массив;	
	ИнтервалОнлайнЗаписи = Константы.ИнтервалОнлайнЗаписи.Получить();
	Если ЗначениеЗаполнено(ИнтервалОнлайнЗаписи) Тогда
		Если ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут5 Тогда
			ДлительностьСлота = 5 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут10 Тогда
			ДлительностьСлота = 10 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут15 Тогда
			ДлительностьСлота = 15 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут30 Тогда
			ДлительностьСлота = 30 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут60 Тогда
			ДлительностьСлота = 60 * 60;
		КонецЕсли;
	Иначе
		ДлительностьСлота = 10 * 60;
	КонецЕсли;

	НачалоПериода 	  	   = ПолучитьДатуСреза(ДатаСреза, ДатаСрезаЗаполнена);
	ТаблицаСотрудников 	   = ПолучитьСотрудниковСНормойВремени2(СтруктурнаяЕдиница, Сотрудник, МассивУслуг, ТекущаяДатаСеанса());
	СтруктураВремениРаботы = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(НачалоПериода, СтруктурнаяЕдиница, ДеньНедели(НачалоПериода), Ложь);
	
	Если ТаблицаСотрудников.Количество() > 0 И СтруктураВремениРаботы <> Неопределено Тогда
		
		ИнтервалЗаписи 	  = Константы.ИнтервалМеждуЗаписями.Получить();
		МассивСотрудников = ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник");
		НачалоПериода 	  = ?(СтруктураВремениРаботы.НачалоРаботы > НачалоПериода, СтруктураВремениРаботы.НачалоРаботы, НачалоПериода);
		КонецПериода  	  = СтруктураВремениРаботы.ОкончаниеРаботы;
		
		ТаблицаИнтервалов = ПолучитьСвободныеИнтервалы(СтруктурнаяЕдиница, МассивСотрудников,, НачалоПериода, КонецПериода);
		
		Если ИнтервалЗаписи > 0 И ТаблицаИнтервалов.Количество() > 0 Тогда
			
			ТаблицаГрафикаРаботыСотрудников = РегистрыСведений.СвободныеИнтервалыСотрудников.ПолучитьГрафикРаботыСотрудников(
				ТаблицаИнтервалов.ВыгрузитьКолонку("Сотрудник"),
				СтруктурнаяЕдиница,,,
				ТаблицаИнтервалов.ВыгрузитьКолонку("ДеньИнтервала")
			);
			
		КонецЕсли;
		
		ТаблицаЗначенийСеансов = Новый ТаблицаЗначений;
		ТаблицаЗначенийСеансов.Колонки.Добавить("ВремяНачала");	
		ТаблицаЗначенийСеансов.Колонки.Добавить("Структура");
		
		Для Каждого СтрокаТЧ Из ТаблицаИнтервалов Цикл
			
			МассивСтрок = ТаблицаСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Если Не ЗначениеЗаполнено(МассивУслуг) ИЛИ МассивСтрок.Количество() = МассивУслуг.Количество() Тогда
				
				Если ЗначениеЗаполнено(МассивУслуг) Тогда
					
					МинНормаВремени = 0;
					Для Каждого НайденнаяСтрока Из МассивСтрок Цикл
						МинНормаВремени = МинНормаВремени + НайденнаяСтрока.НормаВремениПоСотруднику;
					КонецЦикла;
					
				Иначе
					МинНормаВремени = МассивСтрок[0].НормаВремениПоСотруднику;
				КонецЕсли;
				
				МинНормаВремени = МинНормаВремени * 60;
				
				Если ИнтервалЗаписи > 0 Тогда
					
					Если ТаблицаГрафикаРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник, ДатаВремяНачала", 
							СтрокаТЧ.Сотрудник, СтрокаТЧ.ДатаВремяНачалаИнтервала)).Количество() = 0
						И СтрокаТЧ.ДатаВремяНачалаИнтервала + ИнтервалЗаписи * 60 > СтрокаТЧ.ДатаВремяНачала Тогда
						
						НоваяДатаВремяНачала 	 = СтрокаТЧ.ДатаВремяНачалаИнтервала + ИнтервалЗаписи * 60;
						СтрокаТЧ.Длительность	 = СтрокаТЧ.Длительность - (НоваяДатаВремяНачала - СтрокаТЧ.ДатаВремяНачала) / 60;
						СтрокаТЧ.ДатаВремяНачала = НоваяДатаВремяНачала;
					КонецЕсли;
					
					Если ТаблицаГрафикаРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник, ДатаВремяОкончания", 
							СтрокаТЧ.Сотрудник, СтрокаТЧ.ДатаВремяОкончания)).Количество() = 0 Тогда
						СтрокаТЧ.ДатаВремяОкончания = СтрокаТЧ.ДатаВремяОкончания - ИнтервалЗаписи * 60;
						СтрокаТЧ.Длительность	 	= СтрокаТЧ.Длительность - ИнтервалЗаписи;
					КонецЕсли;
					
				КонецЕсли;
				
				Если СтрокаТЧ.Длительность * 60 < МинНормаВремени Тогда
					Продолжить;
				КонецЕсли;
				
				Если ПроверятьВремяДействияУслуги Тогда
					МассивИнтервалов = ПолучитьИнтервалыДоступныеДляЗаписиПоУслуге(МассивУслуг[0], СтрокаТЧ.ДатаВремяНачала,
						СтрокаТЧ.Длительность);
					ДатаВПродажеДо 	 = ПолучитьДатуОкончанияПродажиНоменклатуры(СтруктурнаяЕдиница, МассивУслуг[0]);
				Иначе
					МассивИнтервалов = Новый Массив;
					МассивИнтервалов.Добавить(СтрокаТЧ);
				КонецЕсли;
				
				Для Каждого Интервал Из МассивИнтервалов Цикл
					
					ВремяНачалаИнтервала = НачалоМинуты(Интервал.ДатаВремяНачала);
					
					ВремяОкончания = ВремяНачалаИнтервала + Интервал.Длительность * 60;
					ВремяОкончания = ?(ВремяОкончания > КонецПериода, КонецПериода, ВремяОкончания);
					
					Если ПроверятьВремяДействияУслуги И ЗначениеЗаполнено(ДатаВПродажеДо) И ВремяОкончания > ДатаВПродажеДо Тогда
						ВремяОкончания = ДатаВПродажеДо;
					КонецЕсли;
					
					ДлительностьОкна = ВремяОкончания - ВремяНачалаИнтервала;//Интервал.Длительность * 60;
					
					Если ДлительностьОкна >= МинНормаВремени
						И ТаблицаЗначенийСеансов.НайтиСтроки(Новый Структура("ВремяНачала", ВремяНачалаИнтервала)).Количество() = 0 Тогда
						
						ДобавитьСтруктурыСеансовВМассив(ВремяНачалаИнтервала, ДлительностьОкна, ДлительностьСлота, МинНормаВремени,
							ТаблицаЗначенийСеансов);
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ТаблицаЗначенийСеансов.Сортировать("ВремяНачала Возр");
		МассивДоступныхСеансов = ТаблицаЗначенийСеансов.ВыгрузитьКолонку("Структура");
		
	КонецЕсли;
	
	Возврат Новый Структура("Parameters, Errors", МассивДоступныхСеансов, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция - Re book times
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  datetime			 - 	 - 
//  service_ids			 - 	 - 
//  service_id			 - 	 - 
//  staff_id			 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция re_book_times(СтруктурнаяЕдиница
					, datetime
					, service_ids
					, service_id
					, staff_id
					, reason_entry_id
					, duration = 0) Экспорт
	
	СтруктураОшибки = Неопределено;
	
	ДатаСреза	  	   	= ПолучитьИПроверитьДату(datetime, СтруктураОшибки);
	ДатаСрезаЗаполнена 	= ЗначениеЗаполнено(ДатаСреза);
	МассивУслуг	  	   	= ПолучитьМассивУслугПоИдентификаторам(service_ids	, service_id		, СтруктураОшибки);
	Сотрудник 	  	   	= ПолучитьСсылкуПоИдентификатору(staff_id			, СтруктураОшибки	, Истина, "Сотрудники"		, 1050);
	ПричинаЗаписи		= ПолучитьСсылкуПоИдентификатору(reason_entry_id	, СтруктураОшибки	,		, "ПричиныЗаписи"	, 1130);
	Длительность		= duration;
	
	Если ЗначениеЗаполнено(СтруктураОшибки) Тогда
		Возврат СтруктураОшибки;
	КонецЕсли;
	
	ПроверятьВремяДействияУслуги = МассивУслуг.Количество() = 1;
	МассивДоступныхСеансов 		 = Новый Массив;	
	ИнтервалОнлайнЗаписи = Константы.ИнтервалОнлайнЗаписи.Получить();
	Если ЗначениеЗаполнено(ИнтервалОнлайнЗаписи) Тогда
		Если ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут5 Тогда
			ДлительностьСлота = 5 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут10 Тогда
			ДлительностьСлота = 10 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут15 Тогда
			ДлительностьСлота = 15 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут30 Тогда
			ДлительностьСлота = 30 * 60;
		ИначеЕсли ИнтервалОнлайнЗаписи = Перечисления.ИнтервалыВремениЗаписи.Минут60 Тогда
			ДлительностьСлота = 60 * 60;
		КонецЕсли;
	Иначе
		ДлительностьСлота = 10 * 60;
	КонецЕсли;

	НачалоПериода 	  	   = ПолучитьДатуСреза(ДатаСреза, ДатаСрезаЗаполнена);
	ТаблицаСотрудников 	   = ПолучитьСотрудниковСНормойВремениДляПерезаписи(СтруктурнаяЕдиница, Сотрудник, МассивУслуг);
	СтруктураВремениРаботы = Справочники.СтруктурныеЕдиницы.ВремяРаботыСтруктурнойЕдиницы(НачалоПериода, СтруктурнаяЕдиница, ДеньНедели(НачалоПериода), Ложь);
	
	Если ТаблицаСотрудников.Количество() > 0 И СтруктураВремениРаботы <> Неопределено Тогда
		
		ИнтервалЗаписи 	  = Константы.ИнтервалМеждуЗаписями.Получить();
		МассивСотрудников = ТаблицаСотрудников.ВыгрузитьКолонку("Сотрудник");
		НачалоПериода 	  = ?(СтруктураВремениРаботы.НачалоРаботы > НачалоПериода, СтруктураВремениРаботы.НачалоРаботы, НачалоПериода);
		КонецПериода  	  = СтруктураВремениРаботы.ОкончаниеРаботы;
		
		ТаблицаИнтервалов = ПолучитьСвободныеИнтервалы(СтруктурнаяЕдиница, МассивСотрудников,, НачалоПериода, КонецПериода);
		
		Если ИнтервалЗаписи > 0 И ТаблицаИнтервалов.Количество() > 0 Тогда
			
			ТаблицаГрафикаРаботыСотрудников = РегистрыСведений.СвободныеИнтервалыСотрудников.ПолучитьГрафикРаботыСотрудников(
				ТаблицаИнтервалов.ВыгрузитьКолонку("Сотрудник"),
				СтруктурнаяЕдиница,,,
				ТаблицаИнтервалов.ВыгрузитьКолонку("ДеньИнтервала")
			);
			
		КонецЕсли;
		
		ТаблицаЗначенийСеансов = Новый ТаблицаЗначений;
		ТаблицаЗначенийСеансов.Колонки.Добавить("ВремяНачала");	
		ТаблицаЗначенийСеансов.Колонки.Добавить("Структура");
		
		Для Каждого СтрокаТЧ Из ТаблицаИнтервалов Цикл
			
			МассивСтрок = ТаблицаСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Если НЕ ЗначениеЗаполнено(МассивУслуг) ИЛИ МассивСтрок.Количество() = МассивУслуг.Количество() Тогда
				Если ЗначениеЗаполнено(МассивУслуг) Тогда
					МинНормаВремени = 0;
					Для Каждого НайденнаяСтрока Из МассивСтрок Цикл
						МинНормаВремени = МинНормаВремени + НайденнаяСтрока.НормаВремениПоСотруднику;
					КонецЦикла;
				ИначеЕсли ЗначениеЗаполнено(Длительность) Тогда 
					МинНормаВремени = Длительность;
				Иначе
					МинНормаВремени = МассивСтрок[0].НормаВремениПоСотруднику;
				КонецЕсли;
				
				МинНормаВремени = МинНормаВремени * 60;
				
				Если ИнтервалЗаписи > 0 Тогда
					
					Если ТаблицаГрафикаРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник, ДатаВремяНачала", 
							СтрокаТЧ.Сотрудник, СтрокаТЧ.ДатаВремяНачалаИнтервала)).Количество() = 0
						И СтрокаТЧ.ДатаВремяНачалаИнтервала + ИнтервалЗаписи * 60 > СтрокаТЧ.ДатаВремяНачала Тогда
						
						НоваяДатаВремяНачала 	 = СтрокаТЧ.ДатаВремяНачалаИнтервала + ИнтервалЗаписи * 60;
						СтрокаТЧ.Длительность	 = СтрокаТЧ.Длительность - (НоваяДатаВремяНачала - СтрокаТЧ.ДатаВремяНачала) / 60;
						СтрокаТЧ.ДатаВремяНачала = НоваяДатаВремяНачала;
					КонецЕсли;
					
					Если ТаблицаГрафикаРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник, ДатаВремяОкончания", 
							СтрокаТЧ.Сотрудник, СтрокаТЧ.ДатаВремяОкончания)).Количество() = 0 Тогда
						СтрокаТЧ.ДатаВремяОкончания = СтрокаТЧ.ДатаВремяОкончания - ИнтервалЗаписи * 60;
						СтрокаТЧ.Длительность	 	= СтрокаТЧ.Длительность - ИнтервалЗаписи;
					КонецЕсли;
					
				КонецЕсли;
				
				Если СтрокаТЧ.Длительность * 60 < МинНормаВремени Тогда
					Продолжить;
				КонецЕсли;
				
				Если ПроверятьВремяДействияУслуги Тогда
					МассивИнтервалов = ПолучитьИнтервалыДоступныеДляЗаписиПоУслуге(МассивУслуг[0], СтрокаТЧ.ДатаВремяНачала,
						СтрокаТЧ.Длительность);
					ДатаВПродажеДо 	 = ПолучитьДатуОкончанияПродажиНоменклатуры(СтруктурнаяЕдиница, МассивУслуг[0]);
				Иначе
					МассивИнтервалов = Новый Массив;
					МассивИнтервалов.Добавить(СтрокаТЧ);
				КонецЕсли;
				
				Для Каждого Интервал Из МассивИнтервалов Цикл
					
					ВремяНачалаИнтервала = НачалоМинуты(Интервал.ДатаВремяНачала);
					
					ВремяОкончания = ВремяНачалаИнтервала + Интервал.Длительность * 60;
					ВремяОкончания = ?(ВремяОкончания > КонецПериода, КонецПериода, ВремяОкончания);
					
					Если ПроверятьВремяДействияУслуги И ЗначениеЗаполнено(ДатаВПродажеДо) И ВремяОкончания > ДатаВПродажеДо Тогда
						ВремяОкончания = ДатаВПродажеДо;
					КонецЕсли;
					
					ДлительностьОкна = ВремяОкончания - ВремяНачалаИнтервала;//Интервал.Длительность * 60;
					
					Если ДлительностьОкна >= МинНормаВремени
						И ТаблицаЗначенийСеансов.НайтиСтроки(Новый Структура("ВремяНачала", ВремяНачалаИнтервала)).Количество() = 0 Тогда
						
						ДобавитьСтруктурыСеансовВМассив(ВремяНачалаИнтервала, ДлительностьОкна, ДлительностьСлота, МинНормаВремени,
							ТаблицаЗначенийСеансов);
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ТаблицаЗначенийСеансов.Сортировать("ВремяНачала Возр");
		МассивДоступныхСеансов = ТаблицаЗначенийСеансов.ВыгрузитьКолонку("Структура");
		
	КонецЕсли;
	
	Возврат Новый Структура("Parameters, Errors", МассивДоступныхСеансов, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция, добавляет структуры сеансов в массив возврата.
// 
Процедура ДобавитьСтруктурыСеансовВМассив(
		ДатаВремяНачалаОкна,
		Знач ДлительностьОкна, 
		ДлительностьСлота, 
		МинНормаВремени, 
		ТаблицаЗначенийСеансов) Экспорт
	
	ДатаВремяПоследнегоСеанса = ДатаВремяНачалаОкна;
	ОстатокОтДеления 		  = (НачалоМинуты(ДатаВремяПоследнегоСеанса) - Дата(1,1,1)) % ДлительностьСлота;
	
	Если ОстатокОтДеления <> 0 Тогда
		ДатаВремяПоследнегоСеанса = ДатаВремяПоследнегоСеанса + (ДлительностьСлота - ОстатокОтДеления);
		ДлительностьОкна 		  = ДлительностьОкна - (ДлительностьСлота - ОстатокОтДеления);
	КонецЕсли;
	
	Пока ДлительностьОкна >= ДлительностьСлота Цикл
			
		ВремяНачалаСеанса = Формат(ДатаВремяПоследнегоСеанса, "ДФ=HH:mm");
		
		Если ТаблицаЗначенийСеансов.Найти(ВремяНачалаСеанса, "ВремяНачала") = Неопределено
			И ДлительностьОкна >= МинНормаВремени Тогда
			
			НоваяСтрока 			= ТаблицаЗначенийСеансов.Добавить();
			НоваяСтрока.ВремяНачала = ВремяНачалаСеанса;
			НоваяСтрока.Структура   = Новый Структура("time, seance_length, datetime", 
				ВремяНачалаСеанса, ДлительностьСлота / 60, НачалоМинуты(ДатаВремяПоследнегоСеанса));
			
		КонецЕсли;
		
		ДатаВремяПоследнегоСеанса = ДатаВремяПоследнегоСеанса + ДлительностьСлота;
		ДлительностьОкна   		  = ДлительностьОкна - ДлительностьСлота;
		
	КонецЦикла;
	
КонецПроцедуры

// Функция - Получить дату окончания продажи номенклатуры
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
//  Номенклатура		 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДатуОкончанияПродажиНоменклатуры(СтруктурнаяЕдиница, Номенклатура) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СтатусыНоменклатурыСрезПоследних.Период КАК Период,
	|	СтатусыНоменклатурыСрезПоследних.ВПродаже КАК ВПродаже
	|ИЗ
	|	РегистрСведений.СтатусыНоменклатуры.СрезПоследних(
	|			,
	|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И Номенклатура = &Номенклатура) КАК СтатусыНоменклатурыСрезПоследних");
	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Номенклатура"	  , Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий() И Не Выборка.ВПродаже, Выборка.Период, Неопределено);
	
КонецФункции

#КонецОбласти

#Область client

// Функция возвращает информацию о клиенте.
//
Функция client(Контрагент) Экспорт
	
	МассивEmailСтрок = Контрагент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
	
	ПолКлиента = Неопределено;
	Если Контрагент.ПолКлиента = Перечисления.ПолФизическогоЛица.Мужской Тогда
		ПолКлиента = "Мужской";
	ИначеЕсли Контрагент.ПолКлиента = Перечисления.ПолФизическогоЛица.Женский Тогда
		ПолКлиента = "Женский";
	КонецЕсли;
	
	ДанныеКлиента = Новый Структура;
	ДанныеКлиента.Вставить("full_name"	, Контрагент.Наименование);
	ДанныеКлиента.Вставить("name"		, Контрагент.Имя);
	ДанныеКлиента.Вставить("second_name", Контрагент.Отчество);
	ДанныеКлиента.Вставить("last_name"	, Контрагент.Фамилия);
	ДанныеКлиента.Вставить("birthday"	, ?(ЗначениеЗаполнено(Контрагент.ДатаРожденияКлиента), Формат(Контрагент.ДатаРожденияКлиента, "ДФ=dd.MM.yyyy"), Неопределено));
	ДанныеКлиента.Вставить("sex"		, ПолКлиента);
	ДанныеКлиента.Вставить("email"		, ?(МассивEmailСтрок.Количество() > 0, МассивEmailСтрок[0].АдресЭП, Неопределено));
	
	Возврат Новый Структура("Parameters, Errors", ДанныеКлиента, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

#КонецОбласти

#Область auth_types

// Функция - Auth types
//
// Параметры:
//  СтруктурнаяЕдиница	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция auth_types(СтруктурнаяЕдиница) Экспорт
	
	МассивВариантовАвторизации	= Новый Массив;
	ДоступныеТипыАвторизации	= Константы.ДоступныеТипыАвторизации.Получить().Получить(); 		
	
	Если ТипЗнч(ДоступныеТипыАвторизации) = Тип("Структура") И ДоступныеТипыАвторизации.Свойство("СписокТиповАвторизации") Тогда
		
		Для Каждого ТипАвторизации Из ДоступныеТипыАвторизации.СписокТиповАвторизации Цикл
			Если ТипАвторизации.Пометка Тогда
				МассивВариантовАвторизации.Добавить(Новый Структура("type, title", ТипАвторизации.Значение, ТипАвторизации.Представление));	
			КонецЕсли;
		КонецЦикла;	
		
	Иначе
		
		ВнешняяСистема = ПолучитьВнешнююСистемуСПриоритетомПоСалону(Перечисления.ТипыВнешнихСистем.GreenApi, СтруктурнаяЕдиница);	
		Если ЗначениеЗаполнено(ВнешняяСистема) Тогда
			МассивВариантовАвторизации.Добавить(Новый Структура("type, title", "whats_app", "WhatsApp"));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Константы.СервисSMSРассылкиПоУмолчанию.Получить()) Тогда
			МассивВариантовАвторизации.Добавить(Новый Структура("type, title", "sms", "СМС"));
		КонецЕсли;
		
		УчетнаяЗаписьЭлПочты = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
		Если УчетнаяЗаписьЭлПочты.ИспользоватьДляОтправки = Истина Тогда
			МассивВариантовАвторизации.Добавить(Новый Структура("type, title", "email", "Email"));
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Новый Структура("Parameters, Errors", МассивВариантовАвторизации, ПолучитьСтруктуруВозвратаОшибки(,, Истина));
	
КонецФункции

// Функция - Получить внешние системы
//
// Параметры:
//  ТипСистемы	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьВнешнююСистемуСПриоритетомПоСалону(ТипСистемы, СтруктурнаяЕдиница) Экспорт // Если есть внешняя система с нужным салоном, то берем ее, иначе берем без салона
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ВнешниеСистемы.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ВнешниеСистемы.СтруктурнаяЕдиница <> ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК ИндексСортировки
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ПометкаУдаления = ЛОЖЬ
	|	И ВнешниеСистемы.Используется = ИСТИНА
	|	И ВнешниеСистемы.ТипВнешнейСистемы = &ТипСистемы
	|	И ВЫБОР
	|			КОГДА ВнешниеСистемы.СтруктурнаяЕдиница <> ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|				ТОГДА ВнешниеСистемы.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИндексСортировки");
	
	Запрос.УстановитьПараметр("ТипСистемы"			, ТипСистемы);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, СтруктурнаяЕдиница);

	Выборка = Запрос.Выполнить().Выбрать();
	Возврат ?(Выборка.Следующий(), Выборка.Ссылка, Неопределено);
	
КонецФункции

