
#Область СлужебныеПроцедурыИФункции

// Процедура обновляет регистр с рекламаторами
//
Процедура ИнициализацияДоступаРекламаторам(СтруктураПараметров) Экспорт  	
	
	Для Каждого Документ Из СтруктураПараметров.МассивДокументов Цикл 
		НаборЗаписей = РегистрыСведений.Рекламаторы.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктураПараметров.СтруктурнаяЕдиница);
		НаборЗаписей.Отбор.Документ.Установить(Документ);
		НаборЗаписей.Отбор.Пользователь.Установить(СтруктураПараметров.АвторДокумента);
		НаборЗаписей.Отбор.УникальныйИдентификаторДоступа.Установить(СтруктураПараметров.УникальныйИдентификаторДоступа);
		Если СтруктураПараметров.Режим = "Открыть" Тогда 
			НоваяСтрока = НаборЗаписей.Добавить();
			НоваяСтрока.СтруктурнаяЕдиница 				= СтруктураПараметров.СтруктурнаяЕдиница;
			НоваяСтрока.Документ 						= Документ;
			НоваяСтрока.Пользователь 					= СтруктураПараметров.АвторДокумента;
			НоваяСтрока.УникальныйИдентификаторДоступа 	= СтруктураПараметров.УникальныйИдентификаторДоступа;
			НаборЗаписей.Записать(Истина);		
		ИначеЕсли СтруктураПараметров.Режим = "Закрыть" Тогда
			Если СтруктураПараметров.ВыбранныйДокумент <> Неопределено И СтруктураПараметров.ВыбранныйДокумент = Документ Тогда
				Продолжить;
			Иначе 	
				НаборЗаписей.Записать();
			КонецЕсли;
		КонецЕсли;			       
	КонецЦикла;
	
КонецПроцедуры

// Процедура удаляет все записи для определенного пользователя
//
Процедура УдалитьЗаписиПользователя(Пользователь, СтруктурнаяЕдиница) Экспорт
	
	НаборЗаписей = РегистрыСведений.Рекламаторы.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(СтруктурнаяЕдиница);
	НаборЗаписей.Отбор.Пользователь.Установить(Пользователь);
	НаборЗаписей.Записать();	
	
КонецПроцедуры

#КонецОбласти