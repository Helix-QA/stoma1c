// Процедура - обработчик события "ПриСозданииНаСервере" формы.
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОтборСтрЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтрЕдиница, ЗначениеЗаполнено(ОтборСтрЕдиница));
	Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	Элементы.КассаОтбор.ОграничениеТипа      = Новый ОписаниеТипов("СправочникСсылка.Кассы");

КонецПроцедуры // ПриСозданииНаСервере()

&НаСервере
//
//
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если ОтборВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВыдачаПодотчетнику") Тогда
	     Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
		 Элементы.КонтрагентОтбор.Заголовок       = "Сотрудник";
    Иначе
	 	 Элементы.КонтрагентОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
		 Элементы.КонтрагентОтбор.Заголовок       = "Контрагент";
	КонецЕсли;	
	
	Если ОтборТипДенСредств = ПредопределенноеЗначение("Перечисление.ТипыДенежныхСредств.Безналичные") Тогда
	     Элементы.КассаОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		 Элементы.КассаОтбор.Заголовок       = "Банковский счет";
    Иначе
	 	 Элементы.КассаОтбор.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Кассы");
		 Элементы.КассаОтбор.Заголовок       = "Касса";
	КонецЕсли;	
	
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", ОтборСтрЕдиница, ЗначениеЗаполнено(ОтборСтрЕдиница));
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ТипДенежныхСредств", ОтборТипДенСредств, ЗначениеЗаполнено(ОтборТипДенСредств));
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ВидОперации", ОтборВидОперации, ЗначениеЗаполнено(ОтборВидОперации));
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Контрагент", ОтборКонтрагентСотрудник, ЗначениеЗаполнено(ОтборКонтрагентСотрудник));
    ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Касса", ОтборКассаБанковскийСчет, ЗначениеЗаполнено(ОтборКассаБанковскийСчет));
		 
КонецПроцедуры

