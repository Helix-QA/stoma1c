	Иначе
		Если Объект.ОбъектСкидки = Параметры.КэшируемыеДанные.ОбъектСкидок.ПоПродажам Тогда
			ТекстОписания = ТекстОписания + Нстр("ru = ' если купил'; en = ' if bought'");		
			Если НЕ ЗначениеЗаполнено(Объект.ПериодНакопления) Тогда
				ТекстОписания = ТекстОписания + Нстр("ru = ' ранее'; en = ' early'");
			Иначе
				ТекстОписания = ТекстОписания + Нстр("ru = ' за последние '; en = ' for last '") + Объект.ПериодНакопления + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу(Строка(Объект.ПериодНакопленияТип), Объект.ПериодНакопления) ;
			КонецЕсли;		
			ТекстОписания = ТекстОписания + Нстр("ru = ' номенклатуру'; en = ' nomenclature'");	
		ИначеЕсли Объект.ОбъектСкидки = Параметры.КэшируемыеДанные.ОбъектСкидок.НаДокумент И Объект.УсловиеПредоставленияСкидки <> Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.БонусРефералу Тогда		
			ТекстОписания = ТекстОписания + " если в документе присутствует номенклатура";	
		ИначеЕсли Объект.ОбъектСкидки = Параметры.КэшируемыеДанные.ОбъектСкидок.НаДокумент Тогда		
			ТекстОписания = ТекстОписания + Нстр("ru = ' если в документе присутствует номенклатура'; en = 'if the document contains a nomenclature'");	
		КонецЕсли;
		Если Объект.УсловиеПредоставленияСкидки = Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.Количество Тогда
			ТекстОписания = ТекстОписания + ?(Объект.ВидСравненияУсловия, Нстр("ru = ' количеством не менее'; en = ' quantity not less than'"), Нстр("ru = ' количеством не более'; en = ' quantity not more than'")) + " " + Строка(Объект.ЗначениеУсловия) + Нстр("ru = ' ед.'; en = ' pc.'");
		ИначеЕсли Объект.УсловиеПредоставленияСкидки = Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.Сумма Тогда
			ТекстОписания = ТекстОписания + ?(Объект.ВидСравненияУсловия, Нстр("ru = ' на сумму не менее'; en = ' for amount not less than'"), Нстр("ru = ' на сумму не более'; en = ' for amount not more than'")) + " " + Строка(Объект.ЗначениеУсловия) + Валюта;
		ИначеЕсли Объект.УсловиеПредоставленияСкидки = Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.НомерПокупки Тогда
			
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.СегментНоменклатуры)  Тогда
		ТекстОписания = ТекстОписания + Нстр("ru = ' по сегменту ""'; en = ' by segment ""'") + Объект.СегментНоменклатуры + """";
	КонецЕсли;
	
	Союз = ?(Объект.УсловиеПредоставленияСкидки = Параметры.КэшируемыеДанные.УсловияПредоставленияСкидки.Всегда, Нстр("ru = ', если'; en = ', if'"), Нстр("ru = ', и'; en = ', and'"));	
	Если Объект.ТипПолучателя = ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСпискомКлиентов") Тогда
		Если Объект.Получатели.Количество() = 1 Тогда
			ТекстОписания = ТекстОписания + Союз + Нстр("ru = ' он - '; en = ' he - '") + Объект.Получатели[0].Получатель;
		Иначе
			ТекстОписания = ТекстОписания + Союз + Нстр("ru = ' он входит в указаный список'; en = ' he is on the list'");
		КонецЕсли;
	ИначеЕсли Объект.ТипПолучателя = ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоСегментомКлиентов") Тогда
		Если Объект.Получатели.Количество() = 1 Тогда
			ТекстОписания = ТекстОписания + Союз + Нстр("ru = ' он входит в сегмент - '; en = ' he enters the segment - '") + Объект.Получатели[0].Получатель;
		Иначе
			ТекстОписания = ТекстОписания + Союз + Нстр("ru = ' он входит в сегмент из списка'; en = ' he enters a segment from the list'");
		КонецЕсли;
	ИначеЕсли Объект.ТипПолучателя = ПредопределенноеЗначение("Перечисление.ТипыПолучателейСкидкиНаценки.ОграниченоВидамиДисконтныхКарт") Тогда
		ТекстОписания = ТекстОписания + Союз +  Нстр("ru = ' у него есть карта из списка'; en = ' he has a card from the list'");
	КонецЕсли;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Выбран", Истина);
	СтрокиТаблицыВремени = Объект.ВремяПоДнямНедели.НайтиСтроки(Отбор);
	Если СтрокиТаблицыВремени.Количество() > 0 Тогда
		ТекстОписания = ТекстОписания + Нстр("ru = ', и совершит покупку в указанное время'; en = ', and make a purchase at the specified time'")
	КонецЕсли;		
	
	ТекстОписания = СтрЗаменить(ТекстОписания, "  ", "");
	ТекстОписания = СтрЗаменить(ТекстОписания, ",,", ",");
	Если Прав(ТекстОписания,1) = "," Тогда
		ТекстОписания = Лев(ТекстОписания, СтрДлина(ТекстОписания) - 1);
	КонецЕсли;
	
	ОписаниеСкидкиНаценки = ТекстОписания;
	
КонецПроцедуры // СформироватьОписаниеСкидкиНаценки()
 
&НаКлиенте
Процедура ОчиститьТЧПолучателей(ВозвратДиалога, Параметр = Неопределено) Экспорт
	
	Если ВозвратДиалога = КодВозвратаДиалога.Да Тогда
		Объект.Получатели.Очистить();
	ИначеЕсли ВозвратДиалога = КодВозвратаДиалога.Нет Тогда
		Объект.ТипПолучателя = пТипПолучателяПредыдущий;
	КонецЕсли;
	
	Если пТипПолучателяПредыдущий <> Объект.ТипПолучателя Тогда
		УправлениеВидимостью();
		СформироватьОписаниеСкидкиНаценки();
	КонецЕсли;	
	
	Если Элементы.СтраницыСпособПримененияСкидки.ТекущаяСтраница = Элементы.СтраницаСППодарком Тогда		
		ПроцедураОбработкиНажатияМеню(Элементы["_ГруппаПолучатели"]);
	КонецЕсли;  
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает выбранные структурные единицы.
//
Функция ПолучитьВыбранныеСтруктурныеЕдиницы(МассивСтруктурныхЕдиниц)
		
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК СтруктурнаяЕдиница
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И СтруктурныеЕдиницы.Родитель В(&МассивСтруктурныхЕдиниц)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И НЕ СтруктурныеЕдиницы.ЭтоГруппа
	|	И СтруктурныеЕдиницы.Ссылка В(&МассивСтруктурныхЕдиниц)");
	
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц", МассивСтруктурныхЕдиниц);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");
		
КонецФункции

