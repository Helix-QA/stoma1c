// Процедура - Проверить статус
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ПроверитьСтатус(Команда)
	
	РезультатЗапроса = ПроверитьСтатусНаСервере(НомерЗаказа);
	ЗаказОплачен	 = РезультатЗапроса.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовОнлайнОплаты.Оплачено");
	ЗаказОтклонен	 = РезультатЗапроса.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовОнлайнОплаты.Отказ");
	
	Если ЗаказОплачен Тогда
		
		СообщениеПользователю = "Заказ успешно оплачен";
		
	ИначеЕсли ЗаказОтклонен Тогда
		
		СообщениеПользователю = "Заказ отклонен";
		
	ИначеЕсли РезультатЗапроса.ВыполненоУспешно = Ложь И ЗначениеЗаполнено(РезультатЗапроса.ОписаниеОшибки) Тогда 
		
		СообщениеПользователю = РезультатЗапроса.ОписаниеОшибки;
		
	Иначе
		
		СообщениеПользователю = "Заказ ожидает оплаты";
		
	КонецЕсли;
		
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеПользователю);
	
	Если ЗаказОплачен ИЛИ ЗаказОтклонен Тогда
		ОбновитьИнформациюОСсылкахНаОплату = Истина;
		ЗакрытьФорму();
	КонецЕсли;
			
КонецПроцедуры

