				ГруппаКнопкиДолгКлиентаДинам.Отображение 		                = ОтображениеОбычнойГруппы.Нет;
				ГруппаКнопкиДолгКлиентаДинам.ГоризонтальноеПоложениеВГруппе     = ГоризонтальноеПоложениеЭлемента.Право;
				ГруппаКнопкиДолгКлиентаДинам.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Право;
				ГруппаКнопкиДолгКлиентаДинам.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
				
				ГруппаКнопкиДолгКлиентаДинам.ГоризонтальныйИнтервал             = ИнтервалМеждуЭлементамиФормы.Половинный;
				//ГруппаКнопкиДолгКлиентаДинам.ЦветФона                           = Новый Цвет(235, 235, 237);
				ГруппаКнопкиДолгКлиентаДинам.ОтображатьЗаголовок                = Ложь;	
				
				ГруппаКнопкиДолгКлиентаДинам.Видимость = (Долг > 0);
				ЗаголовокКнопки = "Долг: " + Формат(Долг, "ЧЦ=15; ЧДЦ=2; ЧН=") + " " + Валюта;
				
				Если НЕ ПравоДоступа("Просмотр", Метаданные.Отчеты.РасчетыСКлиентами) Тогда									
					Если Форма.Команды.Найти("Подключаемый_Открыть_Отчет_Долг") = Неопределено Тогда
						Команда 			= Форма.Команды.Добавить("Подключаемый_Открыть_Отчет_Долг");
						Команда.Заголовок 	= ЗаголовокКнопки;
						Команда.Действие 	= "Подключаемый_Открыть_Отчет_Долг_Нажатие";
					КонецЕсли;
					
					Кнопка = Форма.Элементы.Добавить("Кнопка_Открыть_Отчет_Долг", Тип("КнопкаФормы"), ГруппаКнопкиДолгКлиентаДинам);
					Кнопка.ИмяКоманды 				= "Подключаемый_Открыть_Отчет_Долг";
					Кнопка.Заголовок 				= ЗаголовокКнопки;
					Кнопка.ОтображениеФигуры    	= ОтображениеФигурыКнопки.Нет;
					Кнопка.ЦветТекста 				= WebЦвета.Красный;
					Кнопка.Шрифт 					= Новый Шрифт("Arial", 11);
				Иначе
					ДекорацияДолга = Форма.Элементы.Добавить("Кнопка_Открыть_Отчет_Долг", Тип("ДекорацияФормы"), ГруппаКнопкиДолгКлиентаДинам);
					ДекорацияДолга.Заголовок 				= ЗаголовокКнопки;
					ДекорацияДолга.ЦветТекста 				= WebЦвета.Красный;
					ДекорацияДолга.Шрифт 					= Новый Шрифт("Arial", 11);    
				КонецЕсли;
			КонецЕсли;
			
			Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.Визит") Тогда
				
				Если Заголовок = "Продажа не оплачена:" Или Заголовок = "Визит не оплачен:" Тогда
					ДекорацияФормы_Заглушка = Элементы.Добавить("ДекорацияФормы_Заглушка", Тип("ДекорацияФормы"), ГруппаРодитель);
					ДекорацияФормы_Заглушка.Вид 					 = ВидДекорацииФормы.Надпись;
					ДекорацияФормы_Заглушка.АвтомаксимальнаяШирина   = Ложь; 
					ДекорацияФормы_Заглушка.МаксимальнаяШирина       = ?(Форма.Объект.Продажа = Истина, 86, 89);
					ДекорацияФормы_Заглушка.РастягиватьПоГоризонтали = Истина;
					ДекорацияФормы_Заглушка.ГоризонтальноеПоложение  = ГоризонтальноеПоложениеЭлемента.Право;
				КонецЕсли;
				
				//  Создаем группу для кнопки оплаты--------------------------------------------------------------------------------------------		
				Группа_Кнопки_Оплаты = Форма.Элементы.Добавить("Группа_Кнопки_Оплаты", Тип("ГруппаФормы"), ГруппаРодитель);
				Группа_Кнопки_Оплаты.Вид 												= ВидГруппыФормы.ОбычнаяГруппа;
				Группа_Кнопки_Оплаты.Заголовок 											= Группа_Кнопки_Оплаты.Имя;
				Группа_Кнопки_Оплаты.Отображение 										= ОтображениеОбычнойГруппы.Нет;
				Группа_Кнопки_Оплаты.Группировка 										= ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
				Группа_Кнопки_Оплаты.ОтображатьЗаголовок 								= Ложь;
				Группа_Кнопки_Оплаты.ЦветФона 											= ЦветКнопкиОплаты;
				Группа_Кнопки_Оплаты.ГоризонтальноеПоложениеВГруппе 					= ГоризонтальноеПоложениеЭлемента.Право;
				Группа_Кнопки_Оплаты.ГоризонтальноеПоложениеПодчиненных 				= ГоризонтальноеПоложениеЭлемента.Право;				
				//Группа_Кнопки_Оплаты.ВертикальноеПоложениеВГруппе 						= ВертикальноеПоложениеЭлемента.Центр;
				//Группа_Кнопки_Оплаты.ВертикальноеПоложениеПодчиненных 					= ВертикальноеПоложениеЭлемента.Центр;
				
				Команда = Форма.Команды.Найти("Подключаемый_Оплатить_Визит");
				
				Если Команда = Неопределено Тогда
					Команда 			= Форма.Команды.Добавить("Подключаемый_Оплатить_Визит");
