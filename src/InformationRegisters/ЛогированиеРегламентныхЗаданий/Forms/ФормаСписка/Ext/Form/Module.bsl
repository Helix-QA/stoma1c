
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.ОбластьДанныхВспомогательныеДанные.Видимость = ОбщегоНазначенияПовтИсп.РазделениеВключено();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
// Процедура - Добавить фильтрацию по отчетам
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьФильтрациюПоОтчетам(Команда)
	
	ОбновитьСписокНаСервере("Отчеты");
	
КонецПроцедуры

&НаКлиенте
// Процедура - Добавить фильтрацию по заданиям
//
// Параметры:
//  Команда	 - 	 - 
//
Процедура ДобавитьФильтрациюПоЗаданиям(Команда)
	
	ОбновитьСписокНаСервере("Задания");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
// Процедура - Обновить список на сервере
//
// Параметры:
//  ТипОбъекта	 - 	 - 
//
Процедура ОбновитьСписокНаСервере(ТипОбъекта)
	
	Если ТипОбъекта = "Отчеты" Тогда 
		ЭлементСписка = СписокОтборов.НайтиПоЗначению(Истина);
		Если ЭлементСписка = Неопределено Тогда 
			СписокОтборов.Добавить(Истина);
			Элементы.ГруппаКнопкиФильтр_Отчеты.ЦветФона 					= Новый Цвет(25, 116, 206);
			Элементы.ДобавитьФильтрациюПоОтчетам.ЦветТекста 				= Новый Цвет(255, 255, 255);
		Иначе 
			СписокОтборов.Удалить(ЭлементСписка);
			Элементы.ГруппаКнопкиФильтр_Отчеты.ЦветФона 					= Новый Цвет(242, 242, 242);
			Элементы.ДобавитьФильтрациюПоОтчетам.ЦветТекста 				= Новый Цвет();		
		КонецЕсли;	
	ИначеЕсли ТипОбъекта = "Задания" Тогда
		ЭлементСписка = СписокОтборов.НайтиПоЗначению(Ложь);
		Если ЭлементСписка = Неопределено Тогда 
			СписокОтборов.Добавить(Ложь);
			Элементы.ГруппаКнопкиФильтр_РегламентныеЗадания.ЦветФона 		= Новый Цвет(25, 116, 206);
			Элементы.ДобавитьФильтрациюПоРегламентнымЗаданиям.ЦветТекста 	= Новый Цвет(255, 255, 255);
		Иначе 
			СписокОтборов.Удалить(ЭлементСписка);
			Элементы.ГруппаКнопкиФильтр_РегламентныеЗадания.ЦветФона 		= Новый Цвет(242, 242, 242);
			Элементы.ДобавитьФильтрациюПоРегламентнымЗаданиям.ЦветТекста 	= Новый Цвет();		
		КонецЕсли;	
	КонецЕсли;
	
	Если СписокОтборов.Количество() = 0 Тогда 
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Отчет", СписокОтборов.ВыгрузитьЗначения(), Истина, ВидСравненияКомпоновкиДанных.НеВСписке);
	Иначе 
		ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Отчет", СписокОтборов.ВыгрузитьЗначения(), Истина, ВидСравненияКомпоновкиДанных.ВСписке);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти