				"ДокументПрием.Лечение.Номенклатура В
				|			(ВЫБРАТЬ
				|				НоменклатураСегмента.Номенклатура
				|			ИЗ
				|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
				|			ГДЕ
				|				НоменклатураСегмента.Сегмент = &СегментУслуг)");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			КонецЕсли;	
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ДокументПрием.Лечение.Номенклатура В(&СегментУслуг)", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ИСТИНА", "");
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда 
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Функция - Получить данные события план лечения создание плана лечения
//
// Параметры:
//  ДанныеТриггера				 - 	 - 
//  РегистрацияПоПодписке		 - 	 - 
//  РегистрацияЗапланированных	 - 	 - 
//  ОбъектСобытия				 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьДанныеСобытия_ПланЛеченияСозданиеПланаЛечения(ДанныеТриггера, РегистрацияПоПодписке = Ложь, РегистрацияЗапланированных = Ложь, ОбъектСобытия = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РегистрацияПоПодписке"		, РегистрацияПоПодписке);
	Запрос.УстановитьПараметр("РегистрацияЗапланированных"	, РегистрацияЗапланированных);
	Запрос.УстановитьПараметр("ТриггерноеСобытие"			, ДанныеТриггера.ТриггерноеСобытие);
	
	Если РегистрацияПоПодписке ИЛИ РегистрацияЗапланированных Тогда 
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_ПОДПИСКЕ

		Запрос.УстановитьПараметр("ПланЛечения"			, ОбъектСобытия);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПланЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПланЛечения.Ссылка КАК ПланЛечения,
		|	ПланЛечения.Контрагент КАК Контрагент,
		|	ПланЛечения.Сотрудник КАК Сотрудник,
		|	ПланЛечения.Статус КАК СтатусПланаЛечения,
		|	ПланЛечения.Дата КАК Дата
		|ПОМЕСТИТЬ ТаблицаПлановЛечения
		|ИЗ
		|	Документ.ПланЛечения КАК ПланЛечения
		|ГДЕ
		|	ПланЛечения.Ссылка = &ПланЛечения
		|	И ПланЛечения.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Рассматривается), ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Принят), ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Закрыт))
		|	И ПланЛечения.Контрагент В(&СегментКонтрагентов)
		|	И ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПлановЛечения.ПланЛечения КАК ПланЛечения,
		|	ТаблицаПлановЛечения.Контрагент КАК Контрагент,
		|	ТаблицаПлановЛечения.Сотрудник КАК Сотрудник,
		|	ТаблицаПлановЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаПлановЛечения.Дата КАК Дата
		|ПОМЕСТИТЬ ТаблицаПлановЛеченияКРегистрации
		|ИЗ
		|	ТаблицаПлановЛечения КАК ТаблицаПлановЛечения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ТаблицаПлановЛечения.Контрагент = ЖурналРегистрацииТриггерныхСобытий.Контрагент
		|			И ТаблицаПлановЛечения.ПланЛечения = ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия
		|ГДЕ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПлановЛеченияКРегистрации.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаПлановЛеченияКРегистрации.ПланЛечения КАК ПланЛечения,
		|	ТаблицаПлановЛеченияКРегистрации.Контрагент КАК Контрагент,
		|	ТаблицаПлановЛеченияКРегистрации.ПланЛечения КАК ОбъектСобытия,
		|	ТаблицаПлановЛеченияКРегистрации.Сотрудник КАК Сотрудник,
		|	ТаблицаПлановЛеченияКРегистрации.Дата КАК Дата,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаПлановЛеченияКРегистрации КАК ТаблицаПлановЛеченияКРегистрации";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Контрагент В(&СегментКонтрагентов)",
			"ПланЛечения.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
				
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментУслуг) Тогда 
			Если ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.Номенклатура") Тогда 
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)", "ПланЛечения.Лечение.Номенклатура = &СегментУслуг");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			ИначеЕсли ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)",
				"ПланЛечения.Лечение.Номенклатура В
				|			(ВЫБРАТЬ
				|				НоменклатураСегмента.Номенклатура
				|			ИЗ
				|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
				|			ГДЕ
				|				НоменклатураСегмента.Сегмент = &СегментУслуг)");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			КонецЕсли;	
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)", "ИСТИНА");
		КонецЕсли;
		
#КонецОбласти
		
	Иначе
		
#Область ПОЛУЧЕНИЕ_ДАННЫХ_ПРИ_РЕГИСТРАЦИИ_ПО_РЕГЛАМЕНТУ
		
		Запрос.УстановитьПараметр("ДатаТриггера"		, ПолучитьДатуТриггера(ДанныеТриггера));
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ПланЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПланЛечения.Ссылка КАК ПланЛечения,
		|	ПланЛечения.Контрагент КАК Контрагент,
		|	ПланЛечения.Сотрудник КАК Сотрудник,
		|	ПланЛечения.Статус КАК СтатусПланаЛечения,
		|	ПланЛечения.Дата КАК Дата
		|ПОМЕСТИТЬ ТаблицаПлановЛечения
		|ИЗ
		|	Документ.ПланЛечения КАК ПланЛечения
		|ГДЕ
		|	НАЧАЛОПЕРИОДА(ПланЛечения.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаТриггера, ДЕНЬ)
		|	И ПланЛечения.Проведен = ИСТИНА
		|	И ПланЛечения.Контрагент В(&СегментКонтрагентов)
		|	И ПланЛечения.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Рассматривается), ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Принят), ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Закрыт))
		|	И ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент КАК Контрагент,
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия КАК ПланЛечения
		|ПОМЕСТИТЬ ТаблицаОтработанныхКонтрагентов
		|ИЗ
		|	РегистрСведений.ЖурналРегистрацииТриггерныхСобытий КАК ЖурналРегистрацииТриггерныхСобытий
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаПлановЛечения КАК ТаблицаПлановЛечения
		|		ПО (ЖурналРегистрацииТриггерныхСобытий.ТриггерноеСобытие = &ТриггерноеСобытие)
		|			И ЖурналРегистрацииТриггерныхСобытий.Контрагент = ТаблицаПлановЛечения.Контрагент
		|			И ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия = ТаблицаПлановЛечения.ПланЛечения
		|
		|СГРУППИРОВАТЬ ПО
		|	ЖурналРегистрацииТриггерныхСобытий.ОбъектСобытия,
		|	ЖурналРегистрацииТриггерныхСобытий.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПлановЛечения.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ТаблицаПлановЛечения.ПланЛечения КАК ПланЛечения,
		|	ТаблицаПлановЛечения.Контрагент КАК Контрагент,
		|	ТаблицаПлановЛечения.ПланЛечения КАК ОбъектСобытия,
		|	ТаблицаПлановЛечения.Сотрудник КАК Сотрудник,
		|	ТаблицаПлановЛечения.СтатусПланаЛечения КАК СтатусПланаЛечения,
		|	ТаблицаПлановЛечения.Дата КАК Дата,
		|	&РегистрацияПоПодписке КАК РегистрацияПоПодписке,
		|	&РегистрацияЗапланированных КАК РегистрацияЗапланированных
		|ИЗ
		|	ТаблицаПлановЛечения КАК ТаблицаПлановЛечения
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтработанныхКонтрагентов КАК ТаблицаОтработанныхКонтрагентов
		|		ПО ТаблицаПлановЛечения.ПланЛечения = ТаблицаОтработанныхКонтрагентов.ПланЛечения
		|			И ТаблицаПлановЛечения.Контрагент = ТаблицаОтработанныхКонтрагентов.Контрагент
		|ГДЕ
		|	ТаблицаОтработанныхКонтрагентов.Контрагент ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	ТаблицаПлановЛечения.Дата,
		|	ТаблицаПлановЛечения.СтруктурнаяЕдиница,
		|	ТаблицаПлановЛечения.Контрагент,
		|	ТаблицаПлановЛечения.СтатусПланаЛечения,
		|	ТаблицаПлановЛечения.Сотрудник,
		|	ТаблицаПлановЛечения.ПланЛечения,
		|	ТаблицаПлановЛечения.ПланЛечения";
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментКонтрагентов) Тогда 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Контрагент В(&СегментКонтрагентов)",
			"ПланЛечения.Контрагент В
		|			(ВЫБРАТЬ
		|				КонтрагентыСегмента.Контрагент
		|			ИЗ
		|				РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
		|			ГДЕ
		|				КонтрагентыСегмента.Сегмент = &СегментКонтрагентов)");
			Запрос.УстановитьПараметр("СегментКонтрагентов", ДанныеТриггера.СегментКонтрагентов);
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Контрагент В(&СегментКонтрагентов)", "ИСТИНА");
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ДанныеТриггера.СегментУслуг) Тогда 
			Если ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.Номенклатура") Тогда 
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)", "ПланЛечения.Лечение.Номенклатура = &СегментУслуг");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			ИначеЕсли ТипЗнч(ДанныеТриггера.СегментУслуг) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)",
				"ПланЛечения.Лечение.Номенклатура В
				|			(ВЫБРАТЬ
				|				НоменклатураСегмента.Номенклатура
				|			ИЗ
				|				РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
				|			ГДЕ
				|				НоменклатураСегмента.Сегмент = &СегментУслуг)");
				Запрос.УстановитьПараметр("СегментУслуг", ДанныеТриггера.СегментУслуг);
			КонецЕсли;	
		Иначе 
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПланЛечения.Лечение.Номенклатура В(&СегментУслуг)", "ИСТИНА");
