	Элементы["ГруппаПереключатель"+НазваниеЭлемента].ЦветФона    = Новый Цвет(25 , 116, 206);		
	Элементы["КнопкаПереключатель"+НазваниеЭлемента].ЦветТекста = Новый Цвет(255, 255, 255);
	
	
	Элементы.ВзаимодействиеSMSВыбратьНомерТелефона.Видимость = ?(НЕ НазваниеЭлемента = "Мессенджер", Истина, Ложь);
    Элементы.ГруппаВыбораВнешнейСистемыМессенджера.Видимость = ?(НазваниеЭлемента = "Мессенджер", Истина, Ложь);
	
	КнопкаПерейтиВЧат = Элементы.Найти("ГруппаКнопкиМессенджер");
	Если НЕ КнопкаПерейтиВЧат = Неопределено Тогда
		КнопкаПерейтиВЧат.Видимость = ?(НазваниеЭлемента = "Мессенджер", Истина, Ложь);		
	КонецЕсли;
	
КонецПроцедуры	


