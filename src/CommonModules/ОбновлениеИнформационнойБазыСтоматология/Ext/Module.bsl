// Процедура - Перенести общие настройки оповещений в триггерную систему
//
Процедура ПеренестиОбщиеНастройкиОповещенийВТриггернуюСистему() Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ТаблицаСервисовSMS = Справочники.СтруктурныеЕдиницы.ПолучитьТаблицуСервисовРассылокДляСтруктурныхЕдиниц();	
	
	// Актуализируем триггерное событие для информирования об окончании страхового полиса
	Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие_ПациентОкончаниеСрокаДействияСтраховогоПолиса(ТаблицаСервисовSMS);
	
	// Актуализируем триггерное событие для информирования пациента о подтверждении он-лайн записи
	Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие_ЗаписьСменаСтатусаСотрудникомКлиники(ТаблицаСервисовSMS);
	
	// Актуализируем триггерное событие "ЗаписьНачалоПриема" для напоминания пациентам о записи (константа отключается внутри)
	Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие_ЗаписьНачалоПриема(ТаблицаСервисовSMS);
	
	// Актуализируем триггерные события для работы с ЛС
	Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие_ЛицевойСчетВзнос(ТаблицаСервисовSMS);
	Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие_ЛицевойСчетСписание(ТаблицаСервисовSMS);
	
	//// Актуализируем триггерное событие "День рождения клиента" (константа отключается внутри)
	// Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие_КлиентДеньРождения(ТаблицаСервисовSMS);
	
КонецПроцедуры

// Процедура, заполняет ресурс "ИдПоследнегоДиалога" в регистре сведений "КонтактыМессенджеров".
//
Процедура ЗаполнениеИдентификаторовПоследнихДиалогов() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.Начало) КАК Начало,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ДатыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	НЕ Диалоги.ВнешняяСистема.ПометкаУдаления
	|	И Диалоги.ВнешняяСистема.Используется
	|
	|СГРУППИРОВАТЬ ПО
	|	Диалоги.ИдКлиента,
	|	Диалоги.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.ИдДиалога) КАК ИдДиалога,
	|	ДатыПоследнихДиалогов.ИдКлиента КАК ИдКлиента,
	|	ДатыПоследнихДиалогов.ВнешняяСистема КАК ВнешняяСистема
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихДиалогов КАК ДатыПоследнихДиалогов
	|		ПО Диалоги.ИдКлиента = ДатыПоследнихДиалогов.ИдКлиента
	|			И Диалоги.ВнешняяСистема = ДатыПоследнихДиалогов.ВнешняяСистема
	|			И Диалоги.Начало = ДатыПоследнихДиалогов.Начало
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатыПоследнихДиалогов.ИдКлиента,
	|	ДатыПоследнихДиалогов.ВнешняяСистема");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.КонтактыМессенджеров.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Идентификатор = Выборка.ИдКлиента;
		МенеджерЗаписи.ВнешняяСистема = Выборка.ВнешняяСистема;
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			
			МенеджерЗаписи.ИдПоследнегоДиалога = Выборка.ИдДиалога;
			Попытка
				МенеджерЗаписи.Записать();
			Исключение
				ОписаниеОшибки = ОписаниеОшибки();
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура, заполняет дополнительные поля в регистре сведений "Диалоги".
//
Процедура ЗаполнениеДополнительныхПолейДетализацииЧатов() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.Начало) КАК Начало,
	|	Диалоги.ИдКлиента КАК ИдКлиента,
	|	Диалоги.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ДатыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|ГДЕ
	|	НЕ Диалоги.ВнешняяСистема.ПометкаУдаления
	|	И Диалоги.ВнешняяСистема.Используется
	|
	|СГРУППИРОВАТЬ ПО
	|	Диалоги.ИдКлиента,
	|	Диалоги.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	МАКСИМУМ(Диалоги.ИдДиалога) КАК ИдДиалога,
	|	ДатыПоследнихДиалогов.ИдКлиента КАК ИдКлиента,
	|	ДатыПоследнихДиалогов.ВнешняяСистема КАК ВнешняяСистема
	|ПОМЕСТИТЬ ИдентификаторыПоследнихДиалогов
	|ИЗ
	|	РегистрСведений.Диалоги КАК Диалоги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихДиалогов КАК ДатыПоследнихДиалогов
	|		ПО Диалоги.ИдКлиента = ДатыПоследнихДиалогов.ИдКлиента
	|			И Диалоги.ВнешняяСистема = ДатыПоследнихДиалогов.ВнешняяСистема
	|			И Диалоги.Начало = ДатыПоследнихДиалогов.Начало
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатыПоследнихДиалогов.ИдКлиента,
	|	ДатыПоследнихДиалогов.ВнешняяСистема
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЖурналСообщений.ИдДиалога КАК ИдДиалога,
	|	ЖурналСообщений.СлужебноеСообщение,
	|	ЖурналСообщений.ОператорСообщения,
	|	ЖурналСообщений.Период КАК Период,
	|	ЖурналСообщений.СообщениеОтКлиента КАК СообщениеОтКлиента
	|ИЗ
	|	ИдентификаторыПоследнихДиалогов КАК ИдентификаторыПоследнихДиалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналСообщений КАК ЖурналСообщений
	|		ПО ИдентификаторыПоследнихДиалогов.ИдДиалога = ЖурналСообщений.ИдДиалога
	|ГДЕ
	|	НЕ ЖурналСообщений.ОжиданиеСообщения
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период
	|ИТОГИ ПО
	|	ИдДиалога");
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи			 = РегистрыСведений.Диалоги.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ИдДиалога = Выборка.ИдДиалога;
		
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			
			ВыборкаПоДиалогу = Выборка.Выбрать();
			
			ДанныеИзменены = Ложь;
			ПервоеСообщение = Истина;
			
			ИнициированКлиентом			 = Ложь;
			ПоследнееСообщениеОтКлиента	 = Ложь;
			ДатаПоследнегоСообщения		 = Дата(1, 1, 1);
			КоличествоСообщений			 = 0;
			ВремяДоПервогоОтвета		 = Дата(1, 1, 1);
			ОбщееВремяОтветов			 = Дата(1, 1, 1);
			МаксимальноеВремяОтвета		 = Дата(1, 1, 1);
			КоличествоОтветов			 = 0;
			ДатаНачальногоСообщенияСерии = Дата(1, 1, 1);
			
			Пока ВыборкаПоДиалогу.Следующий() Цикл
				
				Если ПервоеСообщение Тогда
					
					ИнициированКлиентом = ?(
						ВыборкаПоДиалогу.СлужебноеСообщение,
						Не ЗначениеЗаполнено(ВыборкаПоДиалогу.ОператорСообщения),
						ВыборкаПоДиалогу.СообщениеОтКлиента
					);
					ПервоеСообщение = Ложь;
					
				КонецЕсли;
				
				Если ВыборкаПоДиалогу.СлужебноеСообщение Тогда
					Продолжить;
					
				ИначеЕсли Не ДанныеИзменены Тогда
					ДанныеИзменены = Истина;
					
				КонецЕсли;
				
				ЭтоОтвет = ПоследнееСообщениеОтКлиента И Не ВыборкаПоДиалогу.СообщениеОтКлиента;
				
				Если ЭтоОтвет Тогда
					
					ВремяОтвета		 = ВыборкаПоДиалогу.Период - ДатаНачальногоСообщенияСерии;
					ВремяОтветаДатой = Дата(1, 1, 1) + ВремяОтвета;
					
					ВремяДоПервогоОтвета	 = ?(ИнициированКлиентом И Не ЗначениеЗаполнено(ВремяДоПервогоОтвета), ВремяОтветаДатой, ВремяДоПервогоОтвета);
					КоличествоОтветов		 = КоличествоОтветов + 1;
					ОбщееВремяОтветов		 = ОбщееВремяОтветов + ВремяОтвета;
					МаксимальноеВремяОтвета	 = ?(ВремяОтветаДатой > МаксимальноеВремяОтвета, ВремяОтветаДатой, МаксимальноеВремяОтвета);
					
				КонецЕсли;
				
				ПоследнееСообщениеОтКлиента	 = ВыборкаПоДиалогу.СообщениеОтКлиента;
				ДатаПоследнегоСообщения		 = ВыборкаПоДиалогу.Период;
				КоличествоСообщений			 = КоличествоСообщений + 1;
			
				ДатаНачальногоСообщенияСерии = ?(
					ВыборкаПоДиалогу.СообщениеОтКлиента,
					?(ЗначениеЗаполнено(ДатаНачальногоСообщенияСерии), ДатаНачальногоСообщенияСерии, ВыборкаПоДиалогу.Период),
					Дата(1, 1, 1)
				);
				
			КонецЦикла;
			
			Если ДанныеИзменены Тогда
				
				МенеджерЗаписи.ИнициированКлиентом			 = ИнициированКлиентом;
				МенеджерЗаписи.ПоследнееСообщениеОтКлиента	 = ПоследнееСообщениеОтКлиента;
				МенеджерЗаписи.ДатаПоследнегоСообщения		 = ДатаПоследнегоСообщения;
				МенеджерЗаписи.КоличествоСообщений			 = КоличествоСообщений;
				МенеджерЗаписи.ВремяДоПервогоОтвета			 = ВремяДоПервогоОтвета;
				МенеджерЗаписи.ОбщееВремяОтветов			 = ОбщееВремяОтветов;
				МенеджерЗаписи.МаксимальноеВремяОтвета		 = МаксимальноеВремяОтвета;
				МенеджерЗаписи.КоличествоОтветов			 = КоличествоОтветов;
				МенеджерЗаписи.ДатаНачальногоСообщенияСерии	 = ДатаНачальногоСообщенияСерии;
				
				Попытка
					МенеджерЗаписи.Записать();
				Исключение
					ОписаниеОшибки = ОписаниеОшибки();
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Перенести статусы контрагентов на новый регистр
//
Процедура ПеренестиСтатусыКонтрагентовНаНовыйРегистр(Параметры = Неопределено) Экспорт 
	
	УстановитьПривилегированныйРежим(Истина); 
	
	#Область ПерезаполнениеСтруктурныхЕдиницКлиентов
	
	СтруктурныеЕдиницы = Справочники.СтруктурныеЕдиницы.ВернутьМассивСтруктурныхЕдиниц(); 
	
	Если ЗначениеЗаполнено(СтруктурныеЕдиницы) И СтруктурныеЕдиницы.Количество() > 0 Тогда
		
		Запрос = Новый Запрос();
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Контрагент
		|ПОМЕСТИТЬ ВТКлентыСПустойСтруктурнойЕдиницей
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
		|	И Контрагенты.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.Пустаяссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(Прием.Дата) КАК Дата,
		|	ВТКлентыСПустойСтруктурнойЕдиницей.Контрагент КАК Контрагент
		|ПОМЕСТИТЬ ВТПоследнийПрием
		|ИЗ
		|	ВТКлентыСПустойСтруктурнойЕдиницей КАК ВТКлентыСПустойСтруктурнойЕдиницей
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Прием КАК Прием
		|		ПО ВТКлентыСПустойСтруктурнойЕдиницей.Контрагент = Прием.Контрагент
		|ГДЕ
		|	Прием.Проведен = ИСТИНА
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТКлентыСПустойСтруктурнойЕдиницей.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПоследнийПрием.Контрагент КАК Контрагент,
		|	Прием.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ СтруктурныеЕдиницыПоследнихПриемов
		|ИЗ
		|	ВТПоследнийПрием КАК ВТПоследнийПрием
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Прием КАК Прием
		|		ПО ВТПоследнийПрием.Контрагент = Прием.Контрагент
		|			И ВТПоследнийПрием.Дата = Прием.Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТКлентыСПустойСтруктурнойЕдиницей.Контрагент КАК Контрагент,
		|	ВЫБОР
		|		КОГДА СтруктурныеЕдиницыПоследнихПриемов.СтруктурнаяЕдиница ЕСТЬ NULL
		|			ТОГДА &СтруктурнаяЕдиницаПоУмолчанию
		|		ИНАЧЕ СтруктурныеЕдиницыПоследнихПриемов.СтруктурнаяЕдиница
		|	КОНЕЦ КАК СтруктурнаяЕдиница
		|ИЗ
		|	ВТКлентыСПустойСтруктурнойЕдиницей КАК ВТКлентыСПустойСтруктурнойЕдиницей
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СтруктурныеЕдиницыПоследнихПриемов КАК СтруктурныеЕдиницыПоследнихПриемов
		|		ПО ВТКлентыСПустойСтруктурнойЕдиницей.Контрагент = СтруктурныеЕдиницыПоследнихПриемов.Контрагент";
		
		
		Запрос.УстановитьПараметр("СтруктурнаяЕдиницаПоУмолчанию", СтруктурныеЕдиницы[0]);
		
		Выборка = Запрос.Выполнить().Выбрать(); 
		
		Пока Выборка.Следующий() Цикл 	
			
			Попытка
				ОбъектКонтрагент = Выборка.Контрагент.ПолучитьОбъект();	
				ОбъектКонтрагент.СтруктурнаяЕдиница = Выборка.СтруктурнаяЕдиница;	
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ОбъектКонтрагент);
			Исключение
				
			КонецПопытки; 
			
		КонецЦикла;
		
	КонецЕсли;
	
	#КонецОбласти
	
	#Область ПотенциальныеКлиенты
	
	// Заполним потенциальных клиентов
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Контрагенты.ДатаРегистрации КАК ДатаРегистрации
	|ПОМЕСТИТЬ КонтрагентыСДатойРегистрации
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ДатаРегистрации <> ДАТАВРЕМЯ(1, 1, 1)
	|	И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Обсуждения.Объект КАК Справочник.Контрагенты) КАК Контрагент,
	|	МИНИМУМ(Обсуждения.МоментВремени) КАК Дата
	|ИЗ
	|	РегистрСведений.Обсуждения КАК Обсуждения
	|ГДЕ
	|	Обсуждения.Объект ССЫЛКА Справочник.Контрагенты
	|	И НЕ Обсуждения.Объект В
	|				(ВЫБРАТЬ
	|					КонтрагентыСДатойРегистрации.Контрагент КАК Контрагент
	|				ИЗ
	|					КонтрагентыСДатойРегистрации КАК КонтрагентыСДатойРегистрации)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫРАЗИТЬ(Обсуждения.Объект КАК Справочник.Контрагенты)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КонтрагентыСДатойРегистрации.Контрагент,
	|	КонтрагентыСДатойРегистрации.ДатаРегистрации
	|ИЗ
	|	КонтрагентыСДатойРегистрации КАК КонтрагентыСДатойРегистрации";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Попытка 	
		
		Пока Выборка.Следующий() Цикл
			
			НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Контрагент.Установить(Выборка.Контрагент);
			НаборЗаписей.Отбор.Период.Установить(Выборка.Дата);
			
			ЗаписьНабора = НаборЗаписей.Добавить();
			
			ЗаписьНабора.Контрагент = Выборка.Контрагент;
			ЗаписьНабора.Период 	= Выборка.Дата;
			ЗаписьНабора.Статус 	= Перечисления.СтатусыКонтрагентов.Потенциальный;
			
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
			
		КонецЦикла;	
		
	Исключение
		
	КонецПопытки; 
	
	#КонецОбласти  
	
	#Область НовыеНеВернувшиесяИПостоянныеКонтрагенты 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Прием.Контрагент КАК Контрагент,
	|	Прием.Дата КАК Дата
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Проведен = ИСТИНА
	|
	|СГРУППИРОВАТЬ ПО
	|	Прием.Контрагент,
	|	Прием.Дата
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Дата)
	|ПО
	|	Контрагент";
	
	ДниПоискаНеВернувшихсяКлиентов = Константы.ПериодПоискаНеВернувшихсяКлиентов.Получить(); 
	
	ВыборкаИтоги = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	Пока ВыборкаИтоги.Следующий() Цикл
		
		ДатаПредыдущегоПриема 			= Дата(1,1,1);
		ДатаСтатусаНеВернувшийся 		= Дата(1,1,1); 
		ПоследнийСтатусКонтрагента 		= Неопределено; 
		
		Контрагент = ВыборкаИтоги.Контрагент;
		
		Выборка = ВыборкаИтоги.Выбрать(ОбходРезультатаЗапроса.Прямой);
		
		Пока Выборка.Следующий() Цикл
			
			// Статус НОВЫЙ.
			Если ДатаПредыдущегоПриема = Дата(1,1,1) Или ДатаПредыдущегоПриема = Выборка.Дата Тогда // Это первый прием.
				
				Попытка
					
					НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Контрагент.Установить(Контрагент); 
					НаборЗаписей.Отбор.Период.Установить(Выборка.Дата); 
					
					ЗаписьНабора = НаборЗаписей.Добавить();
					ЗаписьНабора.Контрагент = Контрагент;
					ЗаписьНабора.Период 	= Выборка.Дата;
					ЗаписьНабора.Статус 	= Перечисления.СтатусыКонтрагентов.Первичный;
					
					ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
					
				Исключение 
					
				КонецПопытки;
				
				ПоследнийСтатусКонтрагента = Перечисления.СтатусыКонтрагентов.Первичный;
				
				// Статус ПОСТОЯННЫЙ.		
			ИначеЕсли ПоследнийСтатусКонтрагента <> Перечисления.СтатусыКонтрагентов.Постоянный Тогда
				
				Попытка
					
					НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Контрагент.Установить(Контрагент);
					НаборЗаписей.Отбор.Период.Установить(Выборка.Дата);
					
					ЗаписьНабора = НаборЗаписей.Добавить();
					
					ЗаписьНабора.Контрагент = Контрагент;
					ЗаписьНабора.Период 	= Выборка.Дата;
					ЗаписьНабора.Статус 	= Перечисления.СтатусыКонтрагентов.Постоянный;
					
					ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
					
				Исключение 
					
				КонецПопытки;
				
				ПоследнийСтатусКонтрагента = Перечисления.СтатусыКонтрагентов.Постоянный;
				
			КонецЕсли;
			
			КоличествоДнейМеждуПриемами = (НачалоДня(Выборка.Дата) - НачалоДня(ДатаПредыдущегоПриема))/(60*60*24);
			КоличествоДнейМеждуПриемами = ?(КоличествоДнейМеждуПриемами >= 0, КоличествоДнейМеждуПриемами, -КоличествоДнейМеждуПриемами); 
			
			// Статус НЕВЕРНУВШИЙСЯ.
			Если ДатаПредыдущегоПриема <> Дата(1,1,1) 
				И КоличествоДнейМеждуПриемами >= ДниПоискаНеВернувшихсяКлиентов Тогда
				
				ДатаСтатусаНеВернувшийся = КонецДня(ДатаПредыдущегоПриема + ДниПоискаНеВернувшихсяКлиентов *60*60*24) + 1;
				
				Попытка
					
					НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Контрагент.Установить(Контрагент);
					НаборЗаписей.Отбор.Период.Установить(ДатаСтатусаНеВернувшийся);
					
					ЗаписьНабора = НаборЗаписей.Добавить();
					
					ЗаписьНабора.Контрагент = Контрагент;
					ЗаписьНабора.Период 	= ДатаСтатусаНеВернувшийся;
					ЗаписьНабора.Статус 	= Перечисления.СтатусыКонтрагентов.НеВернувшийся;
					
					ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);	
					
				Исключение
					
				КонецПопытки; 
				
				ПоследнийСтатусКонтрагента	= Перечисления.СтатусыКонтрагентов.НеВернувшийся;
				
			КонецЕсли;
			
			ДатаПредыдущегоПриема 			= Выборка.Дата; 
			
		КонецЦикла;
		
		// Сравним с текущей датой. И Проставим статус "НЕВУРНУВШИЙСЯ" 
		Если ДатаСтатусаНеВернувшийся < ДатаПредыдущегоПриема Тогда	// После установленного статуса был еще прием или были приемы и еще статус не вернувшегося не установлен.  
			
			КоличествоДнейПослеПоследнегоПриема = (НачалоДня(ТекущаяДатаСеанса()) - НачалоДня(ДатаПредыдущегоПриема))/(60*60*24); 
			КоличествоДнейПослеПоследнегоПриема = ?(КоличествоДнейПослеПоследнегоПриема >= 0, КоличествоДнейПослеПоследнегоПриема, -КоличествоДнейПослеПоследнегоПриема);
			
			Если КоличествоДнейПослеПоследнегоПриема >= ДниПоискаНеВернувшихсяКлиентов Тогда
				
				ДатаСтатусаНеВернувшийся = КонецДня(ДатаПредыдущегоПриема + ДниПоискаНеВернувшихсяКлиентов *60*60*24) + 1;
				
				Попытка 
					НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Контрагент.Установить(Контрагент);
					НаборЗаписей.Отбор.Период.Установить (ДатаСтатусаНеВернувшийся);  					
					ЗаписьНабора = НаборЗаписей.Добавить();
					
					ЗаписьНабора.Контрагент = Контрагент;
					ЗаписьНабора.Период 	= ДатаСтатусаНеВернувшийся;
					ЗаписьНабора.Статус 	= Перечисления.СтатусыКонтрагентов.НеВернувшийся;
					
					ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
				Исключение
					
				КонецПопытки
				
			КонецЕсли;
			
		КонецЕсли;	
		
	КонецЦикла;
	
	#КонецОбласти 
	
	#Область КонтрагентыСОтказом
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СтатусыКонтрагентов.Контрагент КАК Контрагент,
	|	МИНИМУМ(СтатусыКонтрагентов.Период) КАК Период
	|ПОМЕСТИТЬ ВТКонтрагентыБезПотенциальныхИОтказов
	|ИЗ
	|	РегистрСведений.СтатусыКонтрагентов КАК СтатусыКонтрагентов
	|ГДЕ
	|	НЕ СтатусыКонтрагентов.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный), ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ))
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатусыКонтрагентов.Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сделки.Контрагент КАК Контрагент,
	|	Сделки.ДатаЗавершенияСделки КАК ДатаЗавершенияСделки
	|ПОМЕСТИТЬ СделкиСОтказом
	|ИЗ
	|	Справочник.Сделки КАК Сделки
	|ГДЕ
	|	Сделки.ПометкаУдаления = ЛОЖЬ
	|	И Сделки.РезультатСделки = ЗНАЧЕНИЕ(Перечисление.РезультатыСделок.Отказ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СделкиСОтказом.Контрагент КАК Контрагент,
	|	МАКСИМУМ(СделкиСОтказом.ДатаЗавершенияСделки) КАК ДатаЗавершенияСделки
	|ПОМЕСТИТЬ ВТОтказыСПоследующимиДругимиСтатусами
	|ИЗ
	|	СделкиСОтказом КАК СделкиСОтказом
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКонтрагентыБезПотенциальныхИОтказов КАК ВТКонтрагентыБезПотенциальныхИОтказов
	|		ПО СделкиСОтказом.Контрагент = ВТКонтрагентыБезПотенциальныхИОтказов.Контрагент
	|			И СделкиСОтказом.ДатаЗавершенияСделки < ВТКонтрагентыБезПотенциальныхИОтказов.Период
	|
	|СГРУППИРОВАТЬ ПО
	|	СделкиСОтказом.Контрагент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СделкиСОтказом.Контрагент КАК Контрагент,
	|	МАКСИМУМ(СделкиСОтказом.ДатаЗавершенияСделки) КАК Дата
	|ИЗ
	|	СделкиСОтказом КАК СделкиСОтказом
	|ГДЕ
	|	НЕ СделкиСОтказом.Контрагент В
	|				(ВЫБРАТЬ
	|					ВТКонтрагентыБезПотенциальныхИОтказов.Контрагент КАК Контрагент
	|				ИЗ
	|					ВТКонтрагентыБезПотенциальныхИОтказов КАК ВТКонтрагентыБезПотенциальныхИОтказов)
	|
	|СГРУППИРОВАТЬ ПО
	|	СделкиСОтказом.Контрагент
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТОтказыСПоследующимиДругимиСтатусами.Контрагент,
	|	ВТОтказыСПоследующимиДругимиСтатусами.ДатаЗавершенияСделки
	|ИЗ
	|	ВТОтказыСПоследующимиДругимиСтатусами КАК ВТОтказыСПоследующимиДругимиСтатусами";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			
			НаборЗаписей = РегистрыСведений.СтатусыКонтрагентов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Контрагент.Установить(Выборка.Контрагент); 
			НаборЗаписей.Отбор.Период.Установить(Выборка.Дата);
			
			ЗаписьНабора = НаборЗаписей.Добавить();
			
			ЗаписьНабора.Контрагент = Выборка.Контрагент;
			ЗаписьНабора.Период 	= Выборка.Дата;
			ЗаписьНабора.Статус 	= Перечисления.СтатусыКонтрагентов.Отказ;
			
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина);
			
		Исключение 
			
		КонецПопытки;
		
	КонецЦикла;
	
	#КонецОбласти 	
	
КонецПроцедуры

// Процедура - Исправить сохраненный HTML код мед карты ортодонтического пациента.
//
Процедура ИсправитьСохраненныйHTMLКодМедКартыОртодонтическогоПациента() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МедицинскиеКарты.Ссылка КАК Ссылка,
	|	МедицинскиеКарты.ПечатнаяФорма КАК ПечатнаяФорма
	|ИЗ
	|	Справочник.МедицинскиеКарты КАК МедицинскиеКарты
	|ГДЕ
	|	НЕ МедицинскиеКарты.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ПолеТекстHTML = ВыборкаДетальныеЗаписи.ПечатнаяФорма.Получить();
		
		Если ТипЗнч(ПолеТекстHTML) = Тип("Строка") И ЗначениеЗаполнено(ПолеТекстHTML) Тогда

			ОшибкиИсправлены = Ложь;
			
			// Должна быть только одна ячейка с зубом №47.
			ПозицияДублирующейЯчейки47 = СтрНайти(ПолеТекстHTML, "<td><b>47</b></td>",,, 2);	
			Если НЕ ПозицияДублирующейЯчейки47 = 0 Тогда
				
				ЛеваяЧасть = Сред(ПолеТекстHTML, 1, ПозицияДублирующейЯчейки47 - 1); 
				ПолеТекстHTML = ЛеваяЧасть + "<td><b>46</b></td>" + Сред(ПолеТекстHTML, ПозицияДублирующейЯчейки47 + 18);		
				
				// Если выше верхней челюсти два блока "- положения *".
				ПозицияЯчейкиСПоложением = СтрНайти(ПолеТекстHTML, "<td>- положения *</td>",,, 2);
				Если ПозицияЯчейкиСПоложением < ПозицияДублирующейЯчейки47 Тогда
					
					ЛеваяЧасть = Сред(ПолеТекстHTML, 1, ПозицияЯчейкиСПоложением - 1); 
					ПолеТекстHTML = ЛеваяЧасть + "<td>- сроков прорез. **</td>" + Сред(ПолеТекстHTML, ПозицияЯчейкиСПоложением + 22);		
					
				КонецЕсли;
				
				ОшибкиИсправлены = Истина;
				
			КонецЕсли;
			
			Если ОшибкиИсправлены Тогда
				
				МедКартаОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
				
				МедКартаОбъект.ПечатнаяФорма = Новый ХранилищеЗначения(ПолеТекстHTML);
				
				Попытка 
					МедКартаОбъект.Записать();
				Исключение
					ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации("Исправление реквизита ""ПечатнаяФорма"" в мед. картах."
					, УровеньЖурналаРегистрации.Ошибка,,
					, ОписаниеОшибки());					
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЦикла;	

КонецПроцедуры

// Процедура - Заполнить результат приема в триггерных событиях
//
Процедура ЗаполнитьРезультатПриемаВТриггерныхСобытиях() Экспорт

	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТриггерныеСобытия.Ссылка КАК Триггер,
	|	ТриггерныеСобытия.УсловиеСобытия КАК УсловиеСобытия,
	|	ТриггерныеСобытия.РезультатПриема КАК РезультатПриема,
	|	ТриггерныеСобытия.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ТриггерныеСобытия КАК ТриггерныеСобытия
	|ГДЕ
	|	ТриггерныеСобытия.ЭтоГруппа = ЛОЖЬ
	|	И ТриггерныеСобытия.УсловиеСобытия В (ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен), ЗНАЧЕНИЕ(Перечисление.ВариантыУсловийТриггерныхСобытий.ПриемЗавершенПродолжаетЛечение))";
	
	ТаблицаТриггерныхСобытий = Запрос.Выполнить().Выгрузить();
	
	МетаданныеСправочника = Метаданные.Справочники.ТриггерныеСобытия;		
	
	Для Каждого СтрокаТаблицы Из ТаблицаТриггерныхСобытий Цикл
		Триггер_Объект = Неопределено;
		Если СтрокаТаблицы.УсловиеСобытия = Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершенПродолжаетЛечение Тогда 
			Триггер_Объект 					= СтрокаТаблицы.Триггер.ПолучитьОбъект();
		    Триггер_Объект.УсловиеСобытия 	= Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен;
			Триггер_Объект.РезультатПриема 	= 2;
		ИначеЕсли СтрокаТаблицы.РезультатПриема = 0 Тогда 
			Триггер_Объект 					= СтрокаТаблицы.Триггер.ПолучитьОбъект();
			Триггер_Объект.РезультатПриема 	= 1;
		КонецЕсли;
		Если НЕ Триггер_Объект = Неопределено Тогда
			Попытка
				// Сохраняем триггер
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Триггер_Объект);
			Исключение
				ШаблонКомментария = НСтр("ru = 'Не удалось заполнить результат приёма в триггерном событие ""%1"" 
				|по причине: %2'");
				
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария
																					, СтрокаТаблицы.Наименование
																					, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				
				ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,
				МетаданныеСправочника,,
				Комментарий);
			КонецПопытки;	
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

// Процедура - Инициализация стандартного набора триггеров
//
// Параметры:
//  ТаблицаСервисовSMS	 - 	 - 
//
Процедура ИнициализацияСтандартногоНабораТриггеров(ТаблицаСервисовSMS = Неопределено) Экспорт
	
	Если НЕ ПривилегированныйРежим() Тогда 
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	МассивДанныхТриггеров = Новый Массив;
	
	МассивДанныхТриггеров.Добавить(Новый Структура("НаименованиеТриггера, ЗаголовокШаблона, УсловиеСобытия, МоментСобытия, ПериодСобытия, ПериодСобытияВид, ВремяСобытия, НаименованиеСегмента"
	, "Уведомление о записи на прием"	
	, "Создание предварительной записи"
	, Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьСозданиеЗаписиНаПрием
	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ВМоментСобытия
	, 1
	, Перечисления.Периодичность.День
	, Дата('0001.01.01 12:00:00')
	, ""));

	МассивДанныхТриггеров.Добавить(Новый Структура("НаименованиеТриггера, ЗаголовокШаблона, УсловиеСобытия, МоментСобытия, ПериодСобытия, ПериодСобытияВид, ВремяСобытия, НаименованиеСегмента"
	, "Напоминание о записи за 2 часа"	
	, "Напоминание о записи за 2 часа"
	, Перечисления.ВариантыУсловийТриггерныхСобытий.ЗаписьНачалоПриема
	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ДоСобытия
	, 2
	, Перечисления.Периодичность.Час
	, Дата('0001.01.01 12:00:00')
	, ""));	
	
	МассивДанныхТриггеров.Добавить(Новый Структура("НаименованиеТриггера, ЗаголовокШаблона, УсловиеСобытия, МоментСобытия, ПериодСобытия, ПериодСобытияВид, ВремяСобытия, НаименованиеСегмента"
	, "Самочувствие после операции"	
	, "Как ваше самочувствие после операции?"
	, Перечисления.ВариантыУсловийТриггерныхСобытий.ПриемЗавершен
	, Перечисления.ВариантыМоментовАктивацииТриггерныхСобытий.ПослеСобытия
	, 1
	, Перечисления.Периодичность.День
	, Дата('0001.01.01 12:00:00')
	, "Услуги удаления и имплантации (A16.07.054, A16.07.001, A16.07.024)"));		
	
	// Инициализируем таблицу внешних систем
	Если НЕ ЗначениеЗаполнено(ТаблицаСервисовSMS) Тогда 
		ТаблицаСервисовSMS = Справочники.СтруктурныеЕдиницы.ПолучитьТаблицуСервисовРассылокДляСтруктурныхЕдиниц();	
	КонецЕсли;	
	АктивностьТриггера = ЗначениеЗаполнено(ТаблицаСервисовSMS);

	Для Каждого ЭлементКоллекции Из МассивДанныхТриггеров Цикл 
		
		// Инициализируем сегмент услуг
		СегментУслуг 	= Справочники.СегментыНоменклатуры.ИнициализироватьСегментНоменклатуры(ЭлементКоллекции.НаименованиеСегмента);
		// Инициализируем шаблон рекомендаций
		ШаблонСообщения = Справочники.ШаблоныСообщений.ИнициализироватьШаблонСообщения(ЭлементКоллекции.ЗаголовокШаблона);
		
		Если НЕ ЗначениеЗаполнено(ШаблонСообщения) Тогда 
			Продолжить;
		КонецЕсли;
		
		ПараметрыТриггерногоСобытия = Новый Структура;
		ПараметрыТриггерногоСобытия.Вставить("Наименование" 	, ЭлементКоллекции.НаименованиеТриггера);
		ПараметрыТриггерногоСобытия.Вставить("Активно"			, АктивностьТриггера);
		ПараметрыТриггерногоСобытия.Вставить("УсловиеСобытия"	, ЭлементКоллекции.УсловиеСобытия);
		ПараметрыТриггерногоСобытия.Вставить("МоментСобытия"	, ЭлементКоллекции.МоментСобытия);
		ПараметрыТриггерногоСобытия.Вставить("ПериодСобытия"	, ЭлементКоллекции.ПериодСобытия);
		ПараметрыТриггерногоСобытия.Вставить("ПериодСобытияВид"	, ЭлементКоллекции.ПериодСобытияВид);
		ПараметрыТриггерногоСобытия.Вставить("ВремяСобытия"		, ЭлементКоллекции.ВремяСобытия);
		ПараметрыТриггерногоСобытия.Вставить("СегментУслуг"		, СегментУслуг);
		ПараметрыТриггерногоСобытия.Вставить("ПараметрыДействия"
		, Новый Структура("Использование, ВидДействия, ВидАдресата, ШаблонСообщения, Описание"
		, Истина, Перечисления.ВариантыДействийТриггерныхСобытий.ОтправитьСообщение, Перечисления.ВидыАдресатов.КонтрагентСобытия, ШаблонСообщения, НСтр("ru = 'Отправить пациенту сообщение';en= 'Send a message to the patient'")));
		
		ТриггерноеСобытие = Справочники.ТриггерныеСобытия.ИнициализироватьТриггерноеСобытие(ПараметрыТриггерногоСобытия, Истина, ТаблицаСервисовSMS);
		
	КонецЦикла;
	
	
КонецПроцедуры

