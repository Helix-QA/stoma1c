// Процедуры используемые при обмене данными

// Процедура является обработчиком события ПриОтправкеДанныхПодчиненному.
//
// Параметры:
// см. описание обработчика события ПриОтправкеДанныхПодчиненному() в синтаксис-помощнике.
// 
Процедура ПриОтправкеВерсийПодсистем(ЭлементДанных, ОтправкаЭлемента, Знач СозданиеНачальногоОбраза = Ложь) Экспорт
	
	Если ОтправкаЭлемента = ОтправкаЭлементаДанных.Удалить
		ИЛИ ОтправкаЭлемента = ОтправкаЭлементаДанных.Игнорировать Тогда
		
		// Стандартную обработку не переопределяем
		
	ИначеЕсли ТипЗнч(ЭлементДанных) = Тип("РегистрСведенийНаборЗаписей.ВерсииПодсистем") Тогда
		
		Если СозданиеНачальногоОбраза Тогда
			
			Если ОбщегоНазначенияПовтИсп.РазделениеВключено() Тогда
				
				Если ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
					
					Для Каждого СтрокаНабора Из ЭлементДанных Цикл
						
						ТекстЗапроса =
						"ВЫБРАТЬ РАЗРЕШЕННЫЕ
						|	ВерсииПодсистемОбластейДанных.Версия КАК Версия
						|ИЗ
						|	РегистрСведений.ВерсииПодсистемОбластейДанных КАК ВерсииПодсистемОбластейДанных
						|ГДЕ
						|	ВерсииПодсистемОбластейДанных.ИмяПодсистемы = &ИмяПодсистемы";
						
						Запрос = Новый Запрос;
						Запрос.УстановитьПараметр("ИмяПодсистемы", СтрокаНабора.ИмяПодсистемы);
						Запрос.Текст = ТекстЗапроса;
						
						Выборка = Запрос.Выполнить().Выбрать();
						
						Если Выборка.Следующий() Тогда
							
							СтрокаНабора.Версия = Выборка.Версия;
							
						Иначе
							
							СтрокаНабора.Версия = "";
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
				
			Иначе
				
				// При создании начального образа с отключенным разделением
				// выгрузку регистра выполняем без дополнительной обработки.
				
			КонецЕсли;
			
		Иначе
			
			// Выгрузку регистра выполняем только при создании начального образа
			ОтправкаЭлемента = ОтправкаЭлементаДанных.Игнорировать;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура обновляет/дозаполняет предопределнные виды КИ
//
// Для справочников:
// - Контрагент
// - Физ. лица
// - Контактные лица
// 
// Справочник "Организации" обновляется/дозаполняется механизмами БСП.
//
Процедура ОбновитьПредопределенныеВидыКонтактнойИнформации() Экспорт
	
	// Обновить виды КИ	
	КонтактнаяИнформацияСервер.УстановитьСвойстваПредопределенныхВидовКонтактнойИнформации();
	
КонецПроцедуры

// Процедура обновляет значения контактной информации
//
Процедура ОбновитьКонтактнуюИнформацию(Параметры = Неопределено) Экспорт 

	УстановитьПривилегированныйРежим(Истина);
		
	КонтактнаяИнформацияСервер.УстановитьСвойстваПредопределенныхВидовКонтактнойИнформации();
	// Обновляем клиентов
	УИДТелКлиенты = Справочники.ВидыКонтактнойИнформации.ТелефонКлиента.УникальныйИдентификатор();
	УИДАдрКлиенты = Справочники.ВидыКонтактнойИнформации.АдресКлиента.УникальныйИдентификатор();
	УИДЭлПКлиенты = Справочники.ВидыКонтактнойИнформации.EmailКлиента.УникальныйИдентификатор();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	Контрагенты.ТипКонтрагента КАК ТипКонтрагента,
	|	Контрагенты.Родитель КАК Родитель
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЭтоГруппа = ЛОЖЬ
	|	И Контрагенты.Ссылка.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)
	|	И Контрагенты.ПометкаУдаления = ЛОЖЬ");
	                                                                     
	Выборка = Запрос.Выполнить().Выбрать();                          
												
	Пока Выборка.Следующий() Цикл
		
		СсылкаНаЭлемент = Выборка.Ссылка.ПолучитьОбъект();
		КонтИнформация = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(СсылкаНаЭлемент,,,Ложь);
		СсылкаНаЭлемент.КонтактнаяИнформация.Очистить();
		Для Каждого Элемент Из КонтИнформация Цикл
			Если Элемент.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				Элемент.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКлиента;
				СписокПолей = Новый СписокЗначений;
				УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Элемент.Представление, СписокПолей);
				Элемент.ЗначенияПолей = КонтактнаяИнформацияВызовСервера.КонтактнаяИнформацияXMLПоПредставлению(Элемент.Представление, Элемент.Вид);
				Если Элемент.Значение <> "" Тогда
					СтруктураJSON = УправлениеКонтактнойИнформациейСлужебный.СтрокуJSONВСтруктуру(Элемент.Значение);
					Если Не СтруктураJSON.Свойство("value") Тогда
						СтруктураJSON.Вставить("value");
					КонецЕсли;
					СтруктураJSON.value = Элемент.Представление;
					Элемент.Значение = УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураJSON);
				КонецЕсли;
				// Элемент.НеУчаствоватьВРассылке = ;
			ИначеЕсли Элемент.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда	
				Элемент.Вид = Справочники.ВидыКонтактнойИнформации.EmailКлиента;
				Элемент.ЗначенияПолей = КонтактнаяИнформацияВызовСервера.КонтактнаяИнформацияXMLПоПредставлению(Элемент.Представление, Элемент.Вид);
				УправлениеКонтактнойИнформациейСтоматология.ЗаписатьКонтактнуюИнформацию(СсылкаНаЭлемент, Элемент.ЗначенияПолей, Элемент.Вид, Элемент.Тип,,,СсылкаНаЭлемент.НеУчаствоватьВРассылкеEmail);
				Продолжить;
			ИначеЕсли Элемент.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
				Элемент.Вид = Справочники.ВидыКонтактнойИнформации.АдресКлиента;
				Если СтрЧислоСтрок (Элемент.Представление) > 1 Тогда
					Элемент.Представление = УправлениеКонтактнойИнформациейСлужебныйСтоматология.ПредставлениеКонтактнойИнформации(Элемент.ЗначенияПолей, Элемент.Вид);					
				КонецЕсли;
				Если Элемент.Значение <> "" Тогда
					СтруктураJSON = УправлениеКонтактнойИнформациейСлужебный.СтрокуJSONВСтруктуру(Элемент.Значение);
					Если Не СтруктураJSON.Свойство("value") Тогда
						СтруктураJSON.Вставить("value");
					КонецЕсли;
					СтруктураJSON.value = Элемент.Представление;
					Элемент.Значение = УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураJSON);
					Элемент.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияВXML(Элемент.Значение, Элемент.Представление, Элемент.Тип);
				Иначе
					Элемент.ЗначенияПолей = КонтактнаяИнформацияВызовСервера.КонтактнаяИнформацияXMLПоПредставлению(Элемент.Представление, Элемент.Вид);
				КонецЕсли;

			КонецЕсли;
			
			УправлениеКонтактнойИнформациейСтоматология.ЗаписатьКонтактнуюИнформацию(СсылкаНаЭлемент, Элемент.ЗначенияПолей, Элемент.Вид, Элемент.Тип,,,СсылкаНаЭлемент.НеУчаствоватьВРассылкеEmail);
			
		КонецЦикла;
	 	СсылкаНаЭлемент.Записать();
	КонецЦикла;

	
	// Обновляем сотрудников
	УИДТелСотрудники = Справочники.ВидыКонтактнойИнформации.ТелефонСотрудника.УникальныйИдентификатор();
	УИДАдрСотрудники = Справочники.ВидыКонтактнойИнформации.EmailСотрудника.УникальныйИдентификатор();
	УИДЭлПСотрудники = Справочники.ВидыКонтактнойИнформации.АдресСотрудника.УникальныйИдентификатор();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ЭтоГруппа = ЛОЖЬ
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ");
	                                                                     
	Выборка = Запрос.Выполнить().Выбрать();                          
												
	Пока Выборка.Следующий() Цикл
		
		СсылкаНаЭлемент = Выборка.Ссылка.ПолучитьОбъект();
		КонтИнформация = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(СсылкаНаЭлемент,,,Ложь);
		СсылкаНаЭлемент.КонтактнаяИнформация.Очистить();
		Для Каждого Элемент Из КонтИнформация Цикл
			Если Элемент.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				Элемент.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонСотрудника;
				СписокПолей = Новый СписокЗначений;
				УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(Элемент.Представление, СписокПолей);
				Элемент.ЗначенияПолей = КонтактнаяИнформацияВызовСервера.КонтактнаяИнформацияXMLПоПредставлению(Элемент.Представление, Элемент.Вид);
				Если Элемент.Значение <> "" Тогда
					СтруктураJSON = УправлениеКонтактнойИнформациейСлужебный.СтрокуJSONВСтруктуру(Элемент.Значение);
					Если Не СтруктураJSON.Свойство("value") Тогда
						СтруктураJSON.Вставить("value");
					КонецЕсли;
					СтруктураJSON.value = Элемент.Представление;
