			ДекорацияФормы_Дефис.ГоризонтальноеПоложениеВГруппе 					= ГоризонтальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Дефис.ВертикальноеПоложение 								= ВертикальноеПоложениеЭлемента.Центр;
			ДекорацияФормы_Дефис.ВертикальноеПоложениеВГруппе						= ВертикальноеПоложениеЭлемента.Центр;		
			
			Если ЭтаФорма.Команды.Найти("Подключаемый_ВыборОкончанияИнтервала_" + ИндексИнтервала) = Неопределено Тогда
				Команда 			= ЭтаФорма.Команды.Добавить("Подключаемый_ВыборОкончанияИнтервала_" + ИндексИнтервала);
