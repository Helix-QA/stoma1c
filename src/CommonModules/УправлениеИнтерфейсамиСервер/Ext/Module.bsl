		ЭлементСпискаЗначенияФильтра.Значение.ИмяКнопкиЗначенияФильтра 				= КнопкаЗначениеФильтра.Имя;
		
		КоличествоЭлементовРазмещаемыхВСтроке = КоличествоЭлементовРазмещаемыхВСтроке + 1;
	КонецЦикла;
	
	СтрокаФильтр.Инициализирован 	= Истина;
	СтрокаФильтр.Актуализирован 	= Истина;
	
КонецПроцедуры

// Процедура - Обновить элементы фильтрации периода
//
// Параметры:
//  Форма		 - 	 - 
//  СтрокаФильтр - 	 - 
//
Процедура ОбновитьЭлементыФильтрацииПериода(Форма, СтрокаФильтр)
	
	ИдентификаторФильтра 	= СтрокаФильтр.ПолучитьИдентификатор();
	
