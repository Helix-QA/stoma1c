
#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьЗначениеПоУмолчаниюПользователя(Знач Пользователь = Неопределено, Настройка, Знач СтруктурнаяЕдиница = Неопределено) Экспорт

	Если ОбщегоНазначенияПовтИсп.РазделениеВключено()
		И НЕ ОбщегоНазначенияПовтИсп.ДоступноИспользованиеРазделенныхДанных() Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ ЗначениеЗаполнено(Пользователь) Тогда
		Пользователь = ПараметрыСеанса.ТекущийСотрудник;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь"      , Пользователь);
	Запрос.УстановитьПараметр("Настройка"         , ПланыВидовХарактеристик.НастройкиПользователей[Настройка]);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	РегистрЗначениеПрав.Значение КАК Значение
	               |ИЗ
	               |	РегистрСведений.НастройкиПользователей КАК РегистрЗначениеПрав
	               |ГДЕ
	               |	РегистрЗначениеПрав.Пользователь = &Пользователь
	               |	И РегистрЗначениеПрав.Настройка = &Настройка
	               |	И ВЫБОР
	               |			КОГДА РегистрЗначениеПрав.Настройка.Родитель.Общая
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ РегистрЗначениеПрав.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |		КОНЕЦ";

	Выборка = Запрос.Выполнить().Выбрать();

	ПустоеЗначение = ПланыВидовХарактеристик.НастройкиПользователей[Настройка].ТипЗначения.ПривестиЗначение();

	Если Выборка.Количество() = 0 Тогда
		
		Возврат ПустоеЗначение;

	ИначеЕсли Выборка.Следующий() Тогда

		Если НЕ ЗначениеЗаполнено(Выборка.Значение) Тогда
			Возврат ПустоеЗначение;
		Иначе
			Возврат Выборка.Значение;
		КонецЕсли;

	Иначе
		Возврат ПустоеЗначение;

	КонецЕсли;

КонецФункции 

#КонецОбласти