// Функция - Получить список сотрудников.
// 
// 
Функция ПолучитьСписокКлиник()
	
	ТаблицаКлиник = ПолучитьТаблицуКлиник();
	СписокКлиник = Новый СписокЗначений;
	
	// Заполнение списка сотрудников.
	Для Каждого СтрокаКлиника Из ТаблицаКлиник Цикл
		Если ЗначениеЗаполнено(СтрокаКлиника.Клиника) Тогда    			
			СписокКлиник.Добавить(
			СтрокаКлиника.Клиника,
			Строка(СтрокаКлиника.Клиника) ,,
			БиблиотекаКартинок.РеквизитКартинка);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокКлиник;
	
КонецФункции

