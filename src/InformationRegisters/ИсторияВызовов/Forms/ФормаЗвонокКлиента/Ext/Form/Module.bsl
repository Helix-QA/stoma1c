
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// ЭтоВерсияКОРП = ОбщегоНазначения.ЭтоВерсияКОРП();

	Параметры.Свойство("ПОIPТелефонии"	, ПОIPТелефонии);	
	Параметры.Свойство("IDЗвонка"		, IDЗвонка);
	Параметры.Свойство("IDПлеча"		, IDПлеча);
	Параметры.Свойство("СНомерТелефона"	, СНомерТелефона);
	Параметры.Свойство("НаНомерТелефона", НаНомерТелефона);
	Параметры.Свойство("ОткрытаИзСписка", ОткрытаИзСписка);
	Параметры.Свойство("Заявка", ЗаявкаОснование);
	
	ЗаписьРазговораДоступна = ?(Параметры.Свойство("ЗаписьРазговораДоступна"), Параметры.ЗаписьРазговораДоступна, Ложь);
	
	Отказ = НЕ ЗначениеЗаполнено(ПОIPТелефонии) ИЛИ НЕ ЗначениеЗаполнено(IDЗвонка); 
	      
	Если НЕ Отказ Тогда
		// Заполняем таблицу активных пользователей
		ТаблицаАктивныхПользователей.Загрузить(IPТелефония.ПолучитьСписокАктивныхПользователей(,Истина));
		ТаблицаАктивныхПользователей.Сортировать("ВнутреннийНомер");
		// Инициализируем номер телефона клиента
		ИнициализироватьПараметрыТелефонногоЗвонка();
		// Получаем структуру клиента
		СтруктураКлиента = ПолучитьСтруктуруКлиентаПоНомеруТелефона(СписокВариантовНомераТелефона); 
		
		ЭтоГородской = УправлениеКонтактнойИнформациейСтоматология.ЭтоГородскойРФ(ПреобразованныйНомерТелефона);
		ТелефонВЧС = РегистрыСведений.ЗаблокированныеНомераТелефонов.ТелефонВЧерномСписке(НомерТелефонаКлиента);
		Если НЕ ТелефонВЧС Тогда
			Если НЕ ЗначениеЗаполнено(СтруктураКлиента.СписокКонтрагентов) Тогда
				СоздатьОбновитьЗаявку();
			Иначе
				ОтобразитьЗаявки();
			КонецЕсли;              
		КонецЕсли;
		УстановитьВидимостьЭлементовФормы();   
	КонецЕсли;	
	
	ГруппаКонтрагентов = Справочники.Контрагенты.ПолучитьПапкуПоТипу(Перечисления.ТипыКонтрагентов.Клиенты);
	
КонецПроцедуры

&НаКлиенте
// Процедура - При открытии
//
// Параметры:
//  Отказ	 - 	 - 
//
Процедура ПриОткрытии(Отказ)
	
	// Если НЕ ОткрытаИзСписка И ТаблицаАктивныхПользователей.НайтиСтроки(Новый Структура("ВнутреннийНомер", СНомерТелефона)).Количество() <> 0 И ЗначениеЗаполнено(ПараметрыТелефонногоЗвонка.Заявка) И ТипЗнч(ПараметрыТелефонногоЗвонка.Заявка) = Тип("ДокументСсылка.Заявка") Тогда 
	//	// Это переадресация с внутреннего номера и заявка уже создана - поэтому открываем ее
	//	Отказ = Истина;
	//	ОткрытьФорму("Документ.Заявка.ФормаОбъекта", Новый Структура("Ключ, IDЗвонка, ПОIPТелефонии", ПараметрыТелефонногоЗвонка.Заявка, IDЗвонка, ПОIPТелефонии));
	// Иначе 
		Если ЗначениеЗаполнено(СокрЛП(Заметка)) Тогда 
			Элементы.Заметки.УстановитьГраницыВыделения(СтрДлина(Заметка + " "), СтрДлина(Заметка) + 1);
		КонецЕсли;
	// КонецЕсли;
	
	Элементы.ГруппаПредставлениеСделки.Видимость 					= Ложь;
	Элементы.ГруппаПредставлениеЗаписи.Видимость					= Ложь;
	Элементы.ПолисМедицинскогоСтрахованияПредставление.Видимость 	= Ложь;
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка оповещения
//
// Параметры:
//  ИмяСобытия	 - 	 - 
//  Параметр	 - 	 - 
//  Источник	 - 	 - 
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаписанНовыйКлиент" ИЛИ ИмяСобытия = "ЗаписанаНоваяЗаявка" ИЛИ ИмяСобытия = "ОБНОВИТЬ_ЭТАПЫ_СДЕЛКИ" Тогда
		СтруктураКлиента = ПолучитьСтруктуруКлиентаПоНомеруТелефона(СписокВариантовНомераТелефона);
		УстановитьВидимостьЭлементовФормы();   
	ИначеЕсли ИмяСобытия = "ОбновитьИсториюВзаимодействияКонтрагента" Или ИмяСобытия = "ИзмененоСобытие" Тогда
		Если ТипЗнч(Параметр) = Тип("Структура") И Параметр.Свойство("ТелефонДляСоздания") Тогда
			//НомераТелефонов = ПолучитьНомераТелефонов(Параметр.Пациент);
			//ПреобразованныйНомер = СтрЗаменить(СтрСоединить(СтрРазделить(НомерТелефонаКлиента, "+&<>`“‘|%/\@() "), ""), Символы.НПП, "");
			Если ПривестиНомер(НомерТелефонаКлиента) = ПривестиНомер(Параметр.ТелефонДляСоздания) Тогда   
				ЗаявкаОснование = Параметр.Сделка;
				СохранитьКонтрАгента(ПОIPТелефонии, IDЗвонка, Параметр.Пациент, ЗаявкаОснование);     
			КонецЕсли;
		ЗаполнитьРезультатЗвонка(ПредопределенноеЗначение("Перечисление.РезультатыОбработкиЗвонка.ЗаписанНаПрием"));	
		КонецЕсли;
		УстановитьВидимостьЭлементовФормы();
	ИначеЕсли ИмяСобытия = "ЗакрытьФормуЗвонкаПациенту" И Параметр.IDЗвонка = IDЗвонка Тогда 
		ПропуститьПроверкуПриЗакрытииФормы = Истина;
		ЭтаФорма.Закрыть();	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

