&НаКлиентеНаСервереБезКонтекста
// Процедура - Изменить сортировку подбора
//
Процедура ИзменитьСортировкуПодбора(ТекущаяТаблица, ПолеСортировки, ПорядокСортировки)
	
	ТекущаяТаблица.Порядок.Элементы.Очистить();		
	Сортировка = ТекущаяТаблица.КомпоновщикНастроек.Настройки.Порядок.Элементы;
	
	УсловиеСортировки = Сортировка.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
	УсловиеСортировки.Поле = Новый ПолеКомпоновкиДанных(ПолеСортировки);
	УсловиеСортировки.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных[ПорядокСортировки];
	
	ТекущаяТаблица.КомпоновщикНастроек.ЗагрузитьНастройки(ТекущаяТаблица.КомпоновщикНастроек.Настройки);
		
КонецПроцедуры

