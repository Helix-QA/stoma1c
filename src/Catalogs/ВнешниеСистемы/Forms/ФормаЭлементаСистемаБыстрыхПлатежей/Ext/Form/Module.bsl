
&НаСервере
// Процедура - При создании на сервере
//
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 	 - 
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		Параметры.Свойство("ТипВнешнейСистемы", Объект.ТипВнешнейСистемы);
		Объект.КлючПриложения = Новый УникальныйИдентификатор();
		СформироватьНаименование();
		Если ЗначениеЗаполнено(Объект.ТипВнешнейСистемы) Тогда
			Элементы.ТипВнешнейСистемы.Видимость = Ложь;
		Иначе
			Элементы.ТипВнешнейСистемы.Видимость = Истина;
		КонецЕсли;
		Элементы.ГруппаУдалить.Видимость 		 = Ложь;
	Иначе
		ПараметрыВнешнейСистемы = Объект.Ссылка.Параметры.Получить();		
		Элементы.ТипВнешнейСистемы.Видимость = Ложь;
	КонецЕсли;
	
	Если ПараметрыВнешнейСистемы <> Неопределено Тогда
		МассивСтруктурноЭквайринговыхСоответствий = ПолучитьЗначениеИзСтруктуры(ПараметрыВнешнейСистемы, "МассивСтруктурноЭквайринговыхСоответствий", Новый Массив);
		
		ЗаполнитьТЗСтруктурноЭкайринговыхСоответсвий(МассивСтруктурноЭквайринговыхСоответствий);
		ЗаполнитьСтруктурноЭкайринговыеСоответствия();
	КонецЕсли;
	
	ЭтотОбъект.Webhook = "https://cloud.stoma1c.ru/api/hs/api/sbp/" + Объект.КлючПриложения;
	
КонецПроцедуры

&НаСервере
// Процедура - Перед записью на сервере
//
// Параметры:
//  Отказ			 - 	 - 
//  ТекущийОбъект	 - 	 - 
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ПараметрыВнешнейСистемы = ТекущийОбъект.Параметры.Получить();
	
	Если ПараметрыВнешнейСистемы = Неопределено Тогда
		ПараметрыВнешнейСистемы = Новый Структура;
	КонецЕсли;
	
	// Удаляем пустые строки Структурных единиц
	Индекс = 0;
	Пока Индекс < ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Количество() Цикл
		
		СЭС = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия;
		
		Если Не ЗначениеЗаполнено(СЭС[Индекс].СтруктурнаяЕдиница) Тогда
			ИндексСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Индекс(СЭС[Индекс]);
			ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Удалить(ИндексСтроки);
			УдалитьДинамическиеЭлементыИПерезаполнитьСписок();
		Иначе
			Индекс = Индекс + 1;
		КонецЕсли;	
	КонецЦикла;
	
	//Если Не СтруктурноЭквайринговыеСоответсвияЗаполненыВерно() Тогда
	//	Отказ = Истина;
	//	Возврат;
	//КонецЕсли;
	
	ПараметрыВнешнейСистемы.Вставить("МассивСтруктурноЭквайринговыхСоответствий", ПолучитьМассивСтруктурноЭквайринговыеСоответствий());	
	
	ДобавитьРеквизитВСтруктуру(ПараметрыВнешнейСистемы, "Webhook", ЭтотОбъект.Webhook);
	
	ТекущийОбъект.Параметры = Новый ХранилищеЗначения(ПараметрыВнешнейСистемы);
	
КонецПроцедуры

&НаКлиенте
// Процедура - После записи
//
// Параметры:
//  ПараметрыЗаписи	 - 	 - 
//
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ЗаписанаВнешняяСистема", Новый Структура("ВнешняяСистема, ТипВнешнейСистемы", Объект.Ссылка, Объект.ТипВнешнейСистемы));
	
КонецПроцедуры

&НаСервере
// Процедура, обработчик события "ПослеЗаписиНаСервере".
//
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбновитьВнешнююСистему();
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаписанаВнешняяСистема" Тогда
		
		ЭтаФорма.Прочитать();
		Этаформа.ОбновитьОтображениеДанных();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, формирует наименование.
//
Процедура СформироватьНаименование() 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ВнешниеСистемы.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВнешниеСистемы КАК ВнешниеСистемы
	|ГДЕ
	|	ВнешниеСистемы.ТипВнешнейСистемы = &ТипВнешнейСистемы");
	
	Запрос.УстановитьПараметр("ТипВнешнейСистемы", Объект.ТипВнешнейСистемы);
	
	ТаблицаВнешнихСистем = Запрос.Выполнить().Выгрузить();
	
	Объект.Наименование = Строка(Объект.ТипВнешнейСистемы) + ?(ТаблицаВнешнихСистем.Количество() > 1, "-" + Строка(ТаблицаВнешнихСистем.Количество()), ""); 
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет реквизит в структуру.
//
Процедура ДобавитьРеквизитВСтруктуру(ПараметрыВнешнейСистемы, НаименованиеРеквизита, ЗначениеРеквизита)
	
	Если ПараметрыВнешнейСистемы.Свойство(НаименованиеРеквизита) Тогда
		ПараметрыВнешнейСистемы[НаименованиеРеквизита] = ЗначениеРеквизита;
	Иначе
		ПараметрыВнешнейСистемы.Вставить(НаименованиеРеквизита, ЗначениеРеквизита); 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "СоздатьКлюч" 
//
Процедура СоздатьКлюч(Команда)
	
	Объект.КлючПриложения = Строка(Новый УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура ЭквайринговыйТерминал_ДляКопированияПриИзменении(Элемент)
	
	ИндексСтрокиЭТ        = ПолучитьИндексНаименования(Элемент.Имя);
	ИндексСтрокиСЕ        = ПолучитьИндексНаименования(Элемент.Родитель.Родитель.Имя);
	
	ЭквайринговыйТерминал = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексСтрокиЭТ)].ЭквайринговыйТерминал;
	СтруктурнаяеЕдиница   = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексСтрокиСЕ)].СтруктурнаяЕдиница;             
	НайденныеСтроки       = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("ЭквайринговыйТерминал, СтруктурнаяЕдиница", ЭквайринговыйТерминал, СтруктурнаяеЕдиница));
	
	Если НайденныеСтроки.Количество() > 1  И ЗначениеЗаполнено(ЭквайринговыйТерминал) И ЗначениеЗаполнено(СтруктурнаяеЕдиница) Тогда		
		ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексСтрокиЭТ)].ЭквайринговыйТерминал = Неопределено;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Эквайринговый терминал: ""%1"" ,  уже добавлен для структурной единицы: ""%2""';en='Acquiring terminal: ""%1"" already added for structural unit: ""%2""'"), ЭквайринговыйТерминал, СтруктурнаяеЕдиница));
	ИначеЕсли ЗначениеЗаполнено(ЭквайринговыйТерминал) Тогда
		Организация = ПолучитьЗначенияРеквизитовПоСсылке(ЭквайринговыйТерминал, "Организация");
		Элементы["ДекорацияОрганизация_" + ИндексСтрокиЭТ].Заголовок = Строка(Организация); 	
	КонецЕсли;	
	
	НайденныеСтрокиЭТ = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяеЕдиница));
	КоличествоЭТ      = 0;
	Для Каждого СтрокаНС Из НайденныеСтрокиЭТ Цикл
		Если ЗначениеЗаполнено(СтрокаНС.ЭквайринговыйТерминал) Тогда
			КоличествоЭТ = КоличествоЭТ + 1;	
		КонецЕсли;
	КонецЦикла;	
	
	ДекорацияНажатие = Элементы.Найти("ДекорацияНажатиеЭквайриговыеТерминалы_" + ИндексСтрокиСЕ);
	ДекорацияНажатие.Заголовок = Нстр("ru = 'Эквайринговые терминалы('; en = 'Acquiring terminals('") + КоличествоЭТ + ")";
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "ПриИзменении".
//
Процедура СтруктурнаяЕдиница_ДляКопированияПриИзменении(Элемент)
	
	ИндексСтроки       = ПолучитьИндексНаименования(Элемент.Имя);
	СтруктурнаяЕдиница = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексСтроки)].СтруктурнаяЕдиница;
	НайденныеСтроки    = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", СтруктурнаяЕдиница));
	
	Если НайденныеСтроки.Количество() > 1 И значениеЗаполнено(СтруктурнаяЕдиница) Тогда		
		ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексСтроки)].СтруктурнаяЕдиница = Неопределено;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru='Структурная едница: ""%1"",  уже добавлена';en='Structural unit: ""%1"" already added'"), СтруктурнаяЕдиница));
	Иначе
		
		КлючСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексСтроки)].КлючСтроки;
		НайденныеСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки));
		
		Для Каждого СтрокаНС Из НайденныеСтроки Цикл 
			СтрокаНС.СтруктурнаяЕдиница = СтруктурнаяЕдиница; 			
		КонецЦикла;	
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
// Функция, возвращает массив структурно эквайринговых соответствий.
//
Функция ПолучитьМассивСтруктурноЭквайринговыеСоответствий()
	
	МассивСЭС = Новый Массив;
	Для Каждого СтрокаТЧ ИЗ ЭтотОбъект.СтруктурноЭквайринговыеСоответствия Цикл 
		СтруктураСтроки = Новый Структура("СтруктурнаяЕдиница, ЭквайринговыйТерминал, КлючСтроки");
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, СтрокаТЧ);
		МассивСЭС.Добавить(СтруктураСтроки);
	КонецЦикла;	
	
	Возврат МассивСЭС;
	
КонецФункции	

&НаСервере
// Процедура, заполняет таблицу значений структурно эквайринговых соответствий.
//
Процедура ЗаполнитьТЗСтруктурноЭкайринговыхСоответсвий(МассивСЭС)
	
	Для Каждого ЭлементМ ИЗ МассивСЭС Цикл 
		НоваяСтрорка = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Добавить();
		НоваяСтрорка.СтруктурнаяЕдиница    = ЭлементМ.СтруктурнаяЕдиница;
		НоваяСтрорка.ЭквайринговыйТерминал = ЭлементМ.ЭквайринговыйТерминал;
		НоваяСтрорка.КлючСтроки            = ЭлементМ.КлючСтроки;
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
// Процедура,обработчик команды "ДобавитьЭквайринговыйТерминал".
//
Процедура ДобавитьЭквайринговыйТерминал(Команда)
	
	ИндексГруппы = ПолучитьИндексНаименования(Команда.Имя);
	
	НоваяСтрока  = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Добавить();
	ИндексСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Индекс(НоваяСтрока);
	
	ДобавитьЭквайринговыйТерминалНаФорму(ИндексГруппы, ИндексСтроки);
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ДобавитьСтруктурнуюЕдиницу".
//
Процедура ДобавитьСтруктурнуюЕдиницу(Команда)
	
	НоваяСтрока  = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Добавить();
	НоваяСтрока.КлючСтроки = Новый УникальныйИдентификатор;
	
	ИндексСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия.Индекс(НоваяСтрока);
	ДобавитьСтруктурнуюЕдиницуНаФорму(ИндексСтроки, ИндексСтроки);
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет эквайринговый терминал на форму.
//
Процедура ДобавитьЭквайринговыйТерминалНаФорму(ИндексГруппы, ИндексТЧ, ПервичноеЗаполнение = Ложь)
	
	// Заполняем группу списка ЭТ
	ГруппаСписокЭТ = Элементы["ГруппаСписокЭквайринговыхТерминалов_" + Число(ИндексГруппы)];
	ГруппаЭТиО     = КопироватьГруппуФормы(Элементы.ГруппаЭквайринговыйТерминалОрганизация_ДляКопирования, ИндексТЧ, ГруппаСписокЭТ);
	
	// Заполняем группу ЭТ и О
	ПутьКДаннымЭТ            = "СтруктурноЭквайринговыеСоответствия[" + ИндексТЧ + "].ЭквайринговыйТерминал";	
	ЭлементЭТ                = КопироватьЭлементФормы(Элементы.ЭквайринговыйТерминал_ДляКопирования    , ИндексТЧ, ГруппаЭТиО, ПутьКДаннымЭТ);	
	ДекорацияОрганизация     = КопироватьЭлементФормы(Элементы.ДекорацияОрганизация_ДляКопирования     , ИндексТЧ, ГруппаЭТиО);
	ДекорацияУдалитьСтрокуЭТ = КопироватьЭлементФормы(Элементы.ДекорацияУдалитьСтрокуЭТ_ДляКопипрования, ИндексТЧ, ГруппаЭТиО);	
	
	Если Не ПервичноеЗаполнение Тогда
		
		СтруктурнаяЕдиница = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексГруппы)].СтруктурнаяЕдиница;
		ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексТЧ)].СтруктурнаяЕдиница = СтруктурнаяЕдиница;
		
		КлючСтроки = ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексГруппы)].КлючСтроки;
		ЭтотОбъект.СтруктурноЭквайринговыеСоответствия[Число(ИндексТЧ)].КлючСтроки = КлючСтроки;
		
		ЭтаФорма.ТекущийЭлемент = ЭлементЭТ;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, добавляет структурную единицу на форму.
//
Процедура ДобавитьСтруктурнуюЕдиницуНаФорму(Индекс, ИндексСЕ, ПервичноеЗаполнение = Ложь)
	
	// Общая группа = ГруппаОбщаяДляСтруктурныхЕдиниц!!!
	ГруппаСтрокаСтруктурнойЕдиницы = КопироватьГруппуФормы(Элементы.ГруппаСтрокаСтруктурнойЕдиницы_ДляКопирпования, Индекс, Элементы.ГруппаОбщаяДляСтруктурныхЕдиниц);
	
	ПутьКДаннымСЕ 			  = "СтруктурноЭквайринговыеСоответствия[" + ИндексСЕ + "].СтруктурнаяЕдиница";
	ЭлементСтруктурнаяЕдиница = КопироватьЭлементФормы(Элементы.СтруктурнаяЕдиница_ДляКопирования, Индекс, ГруппаСтрокаСтруктурнойЕдиницы, ПутьКДаннымСЕ);
	
	ГруппаЭквайринговыхТерминаловВсплывающая = КопироватьГруппуФормы(Элементы.ГруппаЭквайринговыеТерминалыВсплывающая_ДляКопирования, Индекс, ГруппаСтрокаСтруктурнойЕдиницы);
	ГруппаОбщаяЭквайринговыеТерминалы 		 = КопироватьГруппуФормы(Элементы.ГруппаОбщаяЭквайринговыеТерминалы_ДляКопирования		, Индекс, ГруппаЭквайринговыхТерминаловВсплывающая);
	ДекорацияНажатияЭквайринговыеТерминалы 	 = КопироватьЭлементФормы(Элементы.ДекорацияНажатиеЭквайриговыеТерминалы_ДляКопирования	, Индекс, ГруппаСтрокаСтруктурнойЕдиницы);
	ДекорацияУдалитьСтрокуСЕ               	 = КопироватьЭлементФормы(Элементы.ДекорацияУдалитьСтрокуСЕ_ДляКопипрования            	, Индекс, ГруппаСтрокаСтруктурнойЕдиницы);
	
	// Заполняем общую группу эквайринговых терминалов
	ДекорацияЭквайринговыТерминалы = КопироватьЭлементФормы(Элементы.ДекорацияЭквайринговыйТерминалы_ДляКопирования		  , Индекс, ГруппаОбщаяЭквайринговыеТерминалы);
	ГруппаСписокЭТ     			   = КопироватьГруппуФормы(Элементы.ГруппаСписокЭквайринговыхТерминалов_ДляКопирования    , Индекс, ГруппаОбщаяЭквайринговыеТерминалы);
	ГруппаДобавленияЭТ 			   = КопироватьГруппуФормы(Элементы.ГруппаДобавлениеЭквайринговогоТерминала_ДляКопирования, Индекс, ГруппаОбщаяЭквайринговыеТерминалы);
	
	// Заполняем ГруппуДобавленияЭТ
	ДобавитьЭквайринговыйТерминал  = КопироватьКнопкуФормы(Элементы.ДобавитьЭквайринговыйТерминал_ДляКопирования, Индекс, ГруппаДобавленияЭТ);
	
	Если Не ПервичноеЗаполнение Тогда
		ДобавитьЭквайринговыйТерминалНаФорму(Индекс, Индекс);
		ЭтаФорма.ТекущийЭлемент = ЭлементСтруктурнаяЕдиница;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Нажатие".
//
Процедура ДекорацияУдалитьСтрокуСЕ_ДляКопипрованияНажатие(Элемент)	
	УдалитьДинамическийЭлемент(Элемент);
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик события "Нажатие".
