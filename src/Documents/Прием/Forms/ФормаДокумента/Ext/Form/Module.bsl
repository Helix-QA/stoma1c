// Функция, считает запланированную дату следующего приема (при окончании приема).
//
// Параметры:
//  ИнтервалЗаписи		 - 	 Исходная дата
//  ИнтервалЗаписи		 - 	 ЭтотОбъект.ФормаПовторныйПриемИнтервал 
//  ТипИнтервалаЗаписи	 - 	 ЭтотОбъект.ФормаИнтервалПередПриемом 
// 
// Возвращаемое значение:
//   Посчитанная дата, в соответствии с выбранными параметрами 
//
Функция ВернутьДатуСледующегоПриемаПриОкончании(Дата, ИнтервалПовторногоПриема, ТипИнтервалаПовторногоПриема)
	
	// 3 = Месяцы, 2 = Недели, 1 = Дни
	
	Если ТипИнтервалаПовторногоПриема = 3 Тогда
		Результат = ДобавитьМесяц(Дата, ИнтервалПовторногоПриема);	
	ИначеЕсли ТипИнтервалаПовторногоПриема = 1 ИЛИ ТипИнтервалаПовторногоПриема = 2 Тогда
		КоличествоДнейПоТипу = ?(ТипИнтервалаПовторногоПриема = 1, 1, 7);
		Результат = Дата + ИнтервалПовторногоПриема * 60*60*24 * КоличествоДнейПоТипу;	
	Иначе
		Результат = ТекущаяДата();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
// Процедура, обработчик события "ПодготовитьДанныеДляЗаписиВРегистр".
//
Процедура ПодготовитьДанныеДляЗаписиВРегистр(ОбновитьНаправления)
	
	НайденнаяСтрока = НаправленияНаКонсультацию.НайтиСтроки(Новый Структура("ВидОсмотра", ПредопределенноеЗначение("Перечисление.ВидыОсмотров.ПовторныйПрием")));
	Если НайденнаяСтрока.Количество() > 0 Тогда
		Для Каждого НСтрока Из НайденнаяСтрока Цикл 
			НСтрока.НаправленКСпециалисту = ФормаПовторныйПриемИспользовать; 
			НСтрока.ПредварительнаяЗапись = Объект.ПредварительнаяЗаписьНаСледующийПрием; 
			НСтрока.Длительность          = ЭтотОбъект.ДлительностьПриема;
			НСтрока.ДатаЗапланированная   = ВернутьДатуСледующегоПриемаПриОкончании(Объект.Дата, ЭтотОбъект.ФормаПовторныйПриемИнтервал, ЭтотОбъект.ФормаИнтервалПередПриемом); 
			НСтрока.Статус                = ПредопределенноеЗначение("Перечисление.СтатусыПрофосмотров.Согласился");
			Индекс                        = НаправленияНаКонсультацию.Индекс(НСтрока);
			ОбновитьТекущуюЗаписьВРегистреПрофосмотры(Индекс, ОбновитьНаправления);			
		КонецЦикла; 
	ИначеЕсли ФормаПовторныйПриемИспользовать Тогда
		СтрокаТЧ = НаправленияНаКонсультацию.Добавить();
		СтрокаТЧ.НаправленКСпециалисту = ФормаПовторныйПриемИспользовать;
		СтрокаТЧ.ВидОсмотра            = ПредопределенноеЗначение("Перечисление.ВидыОсмотров.ПовторныйПрием");
		СтрокаТЧ.Сотрудник             = Объект.Сотрудник; 
		СтрокаТЧ.Длительность          = ДлительностьПриема; 
		СтрокаТЧ.ПредварительнаяЗапись = Объект.ПредварительнаяЗаписьНаСледующийПрием; 
		СтрокаТЧ.Статус                = ПредопределенноеЗначение("Перечисление.СтатусыПрофосмотров.Согласился");
		СтрокаТЧ.ДатаЗапланированная   = ВернутьДатуСледующегоПриемаПриОкончании(Объект.Дата, ЭтотОбъект.ФормаПовторныйПриемИнтервал, ЭтотОбъект.ФормаИнтервалПередПриемом);
		Индекс                         = НаправленияНаКонсультацию.Индекс(СтрокаТЧ);  
		ОбновитьТекущуюЗаписьВРегистреПрофосмотры(Индекс);
	КонецЕсли;
	
КонецПроцедуры	

