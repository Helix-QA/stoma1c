// Процедура - Проверить услугу на согласованность по полису.
//
Процедура ПроверитьУслугуНаСогласованностьПоПолису(СтруктураПараметров, ОписаниеОшибки)
	
	// Образец структуры обязательных полей.
	 // ЭлементМЗуб
	 // КоличествоНоменклатурыВТЧ 
	 // КоличествоЗубовСНомненклатуройВТЧ
	 // КоличествоЗубов
	 // КоличествоВПриеме
	 // Номенклатура
	 // ПолисНеограничено
	 // ПолисКоличество
	 // КоличествоВсего
		
	Если СтруктураПараметров.КоличествоЗубов > 0 Тогда
		
		Если СтруктураПараметров.ЭлементМЗуб = ПредопределенноеЗначение("Перечисление.Зубы.ВсяПолость") Тогда
			
			ОписаниеОшибки = "Ограничение на количество зубов. Выберите зуб.";
			Возврат;   
			
		Иначе   
			
			Если СтруктураПараметров.КоличествоВПриеме > 0
				И СтруктураПараметров.КоличествоВПриеме <= СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ Тогда
				
				МассивСтрок = Объект.Запасы.НайтиСтроки(Новый Структура("Номенклатура, Зуб", СтруктураПараметров.Номенклатура, СтруктураПараметров.ЭлементМЗуб));
				Если СтруктураПараметров.КоличествоВПриеме = СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ
					И МассивСтрок.Количество() = 0 Тогда
					
					ОписаниеОшибки = "Ограничение на количество зубов в приеме. Доступно не более: " + СтруктураПараметров.КоличествоВПриеме;
					Возврат; 
				КонецЕсли;
				
			КонецЕсли;
			
			Если СтруктураПараметров.ПолисНеограничено = Истина Тогда
				
				Если СтруктураПараметров.КоличествоЗубовСНомненклатуройВТЧ > СтруктураПараметров.КоличествоЗубов Тогда								
					ОписаниеОшибки = "Ограничение на количество зубов. Доступно зубов: "+ СтруктураПараметров.КоличествоЗубов;
					Возврат; 
				КонецЕсли; 
				
			Иначе
				
				Если СтруктураПараметров.ПолисКоличество <= СтруктураПараметров.КоличествоНоменклатурыВТЧ + СтруктураПараметров.КоличествоВсего Тогда			
					ОписаниеОшибки = "Ограничение по количеству услуг. Всего доступно: " + СтруктураПараметров.ПолисКоличество;
					Возврат; 				
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;  
		
	Иначе
		
		Если СтруктураПараметров.ПолисНеограничено = Ложь			
			И СтруктураПараметров.ПолисКоличество <= СтруктураПараметров.КоличествоНоменклатурыВТЧ + СтруктураПараметров.КоличествоВсего Тогда			
			
			ОписаниеОшибки = "Ограничение по количеству услуг. Всего доступно: " + СтруктураПараметров.ПолисКоличество;
			Возврат; 		
		КонецЕсли;
		
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
// Функция - Вернуть количество номенклатуры ВТЧЛечение.
//
Функция ВернутьКоличествоНоменклатурыВТЧЛечение(Номенклатура) 
				
	СтрокаТЧ = Объект.Запасы.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
	
	Результат = 0;
	Если ЗначениеЗаполнено(СтрокаТЧ) Тогда
	
		Для Каждого Строка Из СтрокаТЧ Цикл
			Результат = Результат + Строка.Количество;		
		КонецЦикла;
	
	КонецЕсли;

	Возврат Результат;
		
КонецФункции

&НаКлиенте
// Функция - Получить количество зубов с номненклатурой.
//
Функция ПолучитьКоличествоЗубовСНомненклатурой(Номенклатура)

	СтрокаТЧ = Объект.Запасы.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
	
	Результат = 0;
	Зуб = Неопределено;
	Если ЗначениеЗаполнено(СтрокаТЧ) Тогда
	
		Для Каждого Строка Из СтрокаТЧ Цикл 
			
			Если Зуб <> Строка.Зуб Тогда
				Зуб = Строка.Зуб; 
				Результат = Результат + 1;	
			КонецЕсли;
					
		КонецЦикла;
	
	КонецЕсли;
 	
	Возврат Результат;
	
КонецФункции

