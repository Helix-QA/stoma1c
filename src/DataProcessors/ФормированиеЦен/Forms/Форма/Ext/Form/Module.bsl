// Процедура заполняет таблицу ЦеныНоменклатуры номенклатурой входящей в группу номенклатуры.
//
// ПАРАМЕТРЫ:
//		ВыбранноеЗначение - СправочникСсылка, ссылка на группу справочника номенклатуры
//		ОчищатьТЧ - Булево, признак очистки таблицы перед заполнением
//
Процедура ЗаполнитьНоменклатуруПоГруппамНоменклатурыНаСервере(ВыбранноеЗначение, ОчищатьТЧ)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СправочникНоменклатура.Ссылка КАК Номенклатура,
	               |	ИСТИНА КАК Пометка,
	               |	СправочникНоменклатура.УпаковкаПоУмолчанию КАК Упаковка
	               |ИЗ
	               |	Справочник.Номенклатура КАК СправочникНоменклатура
	               |ГДЕ
	               |	СправочникНоменклатура.Ссылка В ИЕРАРХИИ(&ГруппыНоменклатуры)
	               |	И НЕ СправочникНоменклатура.ЭтоГруппа
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СправочникНоменклатура.Родитель";
		
	Запрос.УстановитьПараметр("ГруппыНоменклатуры", ВыбранноеЗначение);
	
	Если ОчищатьТЧ = Истина Тогда
		ЦеныНоменлатуры.Загрузить(Запрос.Выполнить().Выгрузить());
	Иначе
		ОбщегоНазначенияКлиентСерверСтоматология.ЗагрузитьВТаблицуЗначений(Запрос.Выполнить().Выгрузить(), ЦеныНоменлатуры);
	КонецЕсли;

	
КонецПроцедуры

