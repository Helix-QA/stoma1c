&НаКлиенте
// Процедура, возвращает заявку в изначальный блок.
//
Процедура ОтменитьПеретаскиваниеЗаявки()
	
	Документ = Элементы.Канбан.Документ;
	
	Документ.defaultView.dropTarget.removeChild(Документ.defaultView.dropElement);
	Документ.defaultView.dropSource.prepend(Документ.defaultView.dropElement);
	
