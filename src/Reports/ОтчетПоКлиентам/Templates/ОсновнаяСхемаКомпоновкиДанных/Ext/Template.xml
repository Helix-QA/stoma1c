		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Клиенты.Контрагент КАК Контрагент,
	Клиенты.ИНН КАК ИНН,
	Клиенты.ПолКлиента КАК ПолКлиента,
	Клиенты.ДатаРожденияКлиента КАК ДатаРожденияКлиента,
	Клиенты.ДатаРегистрации КАК ДатаРегистрации,
	Клиенты.Количество КАК Количество,
	ВЫБОР
		КОГДА &amp;ЕстьПолныеПрава
			ТОГДА ПОДСТРОКА(Клиенты.Email, 1, 500)
		ИНАЧЕ ВЫБОР
				КОГДА ПОДСТРОКА(Клиенты.Email, 1, 500) &lt;&gt; ""
					ТОГДА "*****@****.**"
				ИНАЧЕ NULL
			КОНЕЦ
	КОНЕЦ КАК Email,
	ВЫБОР
		КОГДА &amp;ЕстьПолныеПрава
			ТОГДА ПОДСТРОКА(Клиенты.ПочтовыйАдрес, 1, 500)
		ИНАЧЕ ВЫБОР
				КОГДА ПОДСТРОКА(Клиенты.ПочтовыйАдрес, 1, 500) &lt;&gt; ""
					ТОГДА "************************"
				ИНАЧЕ NULL
			КОНЕЦ
	КОНЕЦ КАК ПочтовыйАдрес,
	ВЫБОР
		КОГДА &amp;ЕстьПолныеПрава
			ТОГДА ПОДСТРОКА(Клиенты.Телефон, 1, 500)
		ИНАЧЕ ВЫБОР
				КОГДА ПОДСТРОКА(Клиенты.Телефон, 1, 500) &lt;&gt; ""
					ТОГДА "+ (**) **-**-*"
				ИНАЧЕ NULL
			КОНЕЦ
	КОНЕЦ КАК Телефон,
	ВЫБОР
		КОГДА &amp;ЕстьПолныеПрава
			ТОГДА ПОДСТРОКА(Клиенты.ФактАдрес, 1, 500)
		ИНАЧЕ ВЫБОР
				КОГДА ПОДСТРОКА(Клиенты.ФактАдрес, 1, 500) &lt;&gt; ""
					ТОГДА "************************"
				ИНАЧЕ NULL
			КОНЕЦ
	КОНЕЦ КАК Адрес,
	ВЫБОР
		КОГДА &amp;ЕстьПолныеПрава
			ТОГДА ПОДСТРОКА(Клиенты.Факс, 1, 500)
		ИНАЧЕ ВЫБОР
				КОГДА ПОДСТРОКА(Клиенты.Факс, 1, 500) &lt;&gt; ""
					ТОГДА "+ (**) **-**-*"
				ИНАЧЕ NULL
			КОНЕЦ
	КОНЕЦ КАК Факс,
	ВЫБОР
		КОГДА &amp;ЕстьПолныеПрава
			ТОГДА ПОДСТРОКА(Клиенты.ЮрАдрес, 1, 500)
		ИНАЧЕ ВЫБОР
				КОГДА ПОДСТРОКА(Клиенты.ЮрАдрес, 1, 500) &lt;&gt; ""
					ТОГДА "************************"
				ИНАЧЕ NULL
			КОНЕЦ
	КОНЕЦ КАК ЮрАдрес,
	Клиенты.Пользователь КАК Пользователь,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, МИНУТА) КАК ДатаРегистрацииМинута,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, ЧАС) КАК ДатаРегистрацииЧас,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, ДЕКАДА) КАК ДатаРегистрацииДекада,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, ДЕНЬ) КАК ДатаРегистрацииДень,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, НЕДЕЛЯ) КАК ДатаРегистрацииНеделя,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, МЕСЯЦ) КАК ДатаРегистрацииМесяц,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, КВАРТАЛ) КАК ДатаРегистрацииКвартал,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, ПОЛУГОДИЕ) КАК ДатаРегистрацииПолугодие,
	НАЧАЛОПЕРИОДА(Клиенты.ДатаРегистрации, ГОД) КАК ДатаРегистрацииГод,
	ВЫБОР
		КОГДА Клиенты.ДатаРожденияКлиента = &amp;ПустаяДата
			ТОГДА 0
		ИНАЧЕ ДЕНЬ(Клиенты.ДатаРожденияКлиента)
	КОНЕЦ КАК ДатаРожденияДень,
	ВЫБОР
		КОГДА Клиенты.ДатаРожденияКлиента = &amp;ПустаяДата
			ТОГДА 0
		ИНАЧЕ МЕСЯЦ(Клиенты.ДатаРожденияКлиента)
	КОНЕЦ КАК ДатаРожденияМесяц,
	ВЫБОР
		КОГДА Клиенты.ДатаРожденияКлиента = &amp;ПустаяДата
			ТОГДА 0
		ИНАЧЕ НАЧАЛОПЕРИОДА(Клиенты.ДатаРожденияКлиента, ГОД)
	КОНЕЦ КАК ДатаРожденияГод,
	Клиенты.Родитель КАК Родитель,
	Клиенты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	Клиенты.Сегмент КАК Сегмент,
	Клиенты.Статус КАК Статус,
	ВЫБОР
		КОГДА Клиенты.ДатаРожденияКлиента &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА ДЕНЬГОДА(&amp;Период) &gt; ДЕНЬГОДА(Клиенты.ДатаРожденияКлиента)
						ТОГДА РАЗНОСТЬДАТ(Клиенты.ДатаРожденияКлиента, &amp;Период, ГОД)
					ИНАЧЕ (ВЫРАЗИТЬ(РАЗНОСТЬДАТ(Клиенты.ДатаРожденияКлиента, &amp;Период, ГОД) КАК ЧИСЛО)) - 1
				КОНЕЦ
	КОНЕЦ КАК Возраст
ИЗ
	(ВЫБРАТЬ
		Контрагенты.Ссылка КАК Контрагент,
		Контрагенты.ИНН КАК ИНН,
		Контрагенты.ПолКлиента КАК ПолКлиента,
		Контрагенты.ДатаРожденияКлиента КАК ДатаРожденияКлиента,
		Контрагенты.ДатаРегистрации КАК ДатаРегистрации,
		Контрагенты.Ссылка КАК Количество,
		Email.Представление КАК Email,
		ПочтовыйАдрес.Представление КАК ПочтовыйАдрес,
		ТелефонРаб.Представление КАК Телефон,
		Факс.Представление КАК Факс,
		ФактАдрес.Представление КАК ФактАдрес,
		ЮрАдрес.Представление КАК ЮрАдрес,
		Контрагенты.БанковскийСчетПоУмолчанию.Ссылка КАК БанковскийСчет,
		Контрагенты.СотрудникРегистрации КАК Пользователь,
		Контрагенты.Родитель КАК Родитель,
		Контрагенты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		КонтрагентыСегмента.Сегмент КАК Сегмент,
		СтатусыКонтрагентовСрезПоследних.Статус КАК Статус
	ИЗ
		Справочник.Контрагенты КАК Контрагенты
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				Телефон.Представление КАК Представление,
				Телефон.Ссылка КАК Ссылка
			ИЗ
				Справочник.Контрагенты.КонтактнаяИнформация КАК Телефон
			ГДЕ
				Телефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКлиента)) КАК ТелефонРаб
			ПО Контрагенты.Ссылка = ТелефонРаб.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				Факс.Представление КАК Представление,
				Факс.Ссылка КАК Ссылка
			ИЗ
				Справочник.Контрагенты.КонтактнаяИнформация КАК Факс
			ГДЕ
				(Факс.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксКонтрагента)
						ИЛИ Факс.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксОрганизации))) КАК Факс
			ПО Контрагенты.Ссылка = Факс.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				ПочтовыйАдрес.Ссылка КАК Ссылка,
				ПочтовыйАдрес.Представление КАК Представление
			ИЗ
				Справочник.Контрагенты.КонтактнаяИнформация КАК ПочтовыйАдрес
			ГДЕ
				(ПочтовыйАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПочтовыйАдресКонтрагента)
						ИЛИ ПочтовыйАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПочтовыйАдресОрганизации))) КАК ПочтовыйАдрес
			ПО Контрагенты.Ссылка = ПочтовыйАдрес.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				Email.Ссылка КАК Ссылка,
				ВЫРАЗИТЬ(Email.Представление КАК СТРОКА(500)) КАК Представление
			ИЗ
				Справочник.Контрагенты.КонтактнаяИнформация КАК Email
			ГДЕ
				Email.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКлиента)) КАК Email
			ПО Контрагенты.Ссылка = Email.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				ФактАдрес.Ссылка КАК Ссылка,
				ВЫРАЗИТЬ(ФактАдрес.Представление КАК СТРОКА(500)) КАК Представление
			ИЗ
				Справочник.Контрагенты.КонтактнаяИнформация КАК ФактАдрес
			ГДЕ
				ФактАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресКлиента)) КАК ФактАдрес
			ПО Контрагенты.Ссылка = ФактАдрес.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				ЮрАдрес.Ссылка КАК Ссылка,
				ВЫРАЗИТЬ(ЮрАдрес.Представление КАК СТРОКА(500)) КАК Представление
			ИЗ
				Справочник.Контрагенты.КонтактнаяИнформация КАК ЮрАдрес
			ГДЕ
				(ЮрАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
						ИЛИ ЮрАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))) КАК ЮрАдрес
			ПО Контрагенты.Ссылка = ЮрАдрес.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
			ПО Контрагенты.Ссылка = КонтрагентыСегмента.Контрагент
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКонтрагентов.СрезПоследних({(&amp;Период)}, ) КАК СтатусыКонтрагентовСрезПоследних
			ПО Контрагенты.Ссылка = СтатусыКонтрагентовСрезПоследних.Контрагент
	ГДЕ
		Контрагенты.ЭтоГруппа = ЛОЖЬ
		И Контрагенты.ТипКонтрагента = ЗНАЧЕНИЕ(Перечисление.ТипыКонтрагентов.Клиенты)) КАК Клиенты</query>
