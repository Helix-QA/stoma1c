// Функция - Получить количество зубов с номненклатурой.
//
Функция ПолучитьКоличествоЗубовСНомненклатурой(Номенклатура)

	СтрокаТЧ = Объект.Лечение.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
	
	Результат = 0;
	Зуб = Неопределено;
	Если ЗначениеЗаполнено(СтрокаТЧ) Тогда
	
		Для Каждого Строка Из СтрокаТЧ Цикл 
			
			Если Зуб <> Строка.Зуб Тогда
				Зуб = Строка.Зуб; 
				Результат = Результат + 1;	
			КонецЕсли;
					
		КонецЦикла;
	
	КонецЕсли;
 	
	Возврат Результат;
	
