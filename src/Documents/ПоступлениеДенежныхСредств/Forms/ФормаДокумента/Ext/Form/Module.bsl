// Функция возвращает массив товаров для ККТ.
//
Функция ПолучитьМассивТоваровФискальногоЧекаОплатыПродажиДляККТ() 
	
	МассивТоваров = Новый Массив;
	Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл
		Если СтрокаТЧ.ЭтоАванс
			Или СтрокаТЧ.Статья = Справочники.СтатьиДоходовИРасходов.ВзносАвансаОтКлиента
			Или СтрокаТЧ.Статья = Справочники.СтатьиДоходовИРасходов.ВзносНалицевойСчет Тогда
			
			МассивТоваров.Добавить(СформироватьПозициюАвансаЧека(СтрокаТЧ.Статья, СтрокаТЧ.Сумма));
		Иначе			
			МассивТоваровДокумента = ПолучитьМассивПараметровТовары(СтрокаТЧ.ДокументОснования, СтрокаТЧ.Сумма);
			ОбщегоНазначенияСтоматология.ДобавитьВМассив(МассивТоваров, МассивТоваровДокумента);																			
		КонецЕсли;		
	КонецЦикла; 

	Возврат МассивТоваров;
	
