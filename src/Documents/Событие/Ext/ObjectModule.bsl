#Область ОбработчикиСобытий

// Процедура, обработчик события "ОбработкаЗаполнения".
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения = Неопределено Тогда
		Статус = Перечисления.СтатусыСобытия.НеПодтверждена;
	КонецЕсли;	
	
	Если НЕ ЗначениеЗаполнено(ДатаСоздания) Тогда
		ДатаСоздания = ТекущаяДатаСеанса();		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ИсточникЗаписи) Тогда 
		ИсточникЗаписи = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ИсточникиЗаписей.Администратор");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(АвторДокумента) Тогда
		АвторДокумента = ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТипСобытия) Тогда
		ТипСобытия = Перечисления.ТипыСобытий.ПредварительнаяЗапись;
	КонецЕсли;
	
	ВидЦен = ?(Не СтруктурнаяЕдиница.ВидЦенРеализации.Пустая(), СтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Розничная);

	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	
КонецПроцедуры

// Процедура, обработчик события "ПриКопировании".
//
Процедура ПриКопировании(ОбъектКопирования)	
	
	ЭтотОбъект.Дата 					= Дата(1,1,1);
	ЭтотОбъект.ДатаСоздания 			= ТекущаяДатаСеанса();
	ЭтотОбъект.СтруктурнаяЕдиница 		= ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;	
	ЭтотОбъект.АвторДокумента 			= ПараметрыСеанса.ТекущийПользователь;	
	ЭтотОбъект.Статус        			= Перечисления.СтатусыСобытия.НеПодтверждена;
	ЭтотОбъект.ПричинаОтмены 			= Неопределено;
	ЭтотОбъект.КодСинхронизации 		= "";
	ЭтотОбъект.СсылкаНаПрием 			= Неопределено;
	ЭтотОбъект.Сделка		  			= Неопределено;
	ЭтотОбъект.ТелефонныйЗвонок	 		= Неопределено;
	ЭтотОбъект.ИдентификаторДиалога 	= Неопределено;
	ЭтотОбъект.ВидЦен 					= ?(Не СтруктурнаяЕдиница.ВидЦенРеализации.Пустая(), СтруктурнаяЕдиница.ВидЦенРеализации, Справочники.ВидыЦен.Розничная);
	ЭтотОбъект.УИД 						= ""; 
	
	ЭтотОбъект.Услуги.Очистить(); 
	
	// Нельзя оставлять ТЧ Услуг без единой строки.
	НоваяСтрокаУслуги = ЭтотОбъект.Услуги.Добавить();
	НоваяСтрокаУслуги.ДатаНачала    = ТекущаяДатаСеанса();
	НоваяСтрокаУслуги.ДатаОкончания = НоваяСтрокаУслуги.ДатаНачала + 3600;
	НоваяСтрокаУслуги.НормаВремени  = (НоваяСтрокаУслуги.ДатаОкончания - НоваяСтрокаУслуги.ДатаНачала) / 60;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	
КонецПроцедуры

