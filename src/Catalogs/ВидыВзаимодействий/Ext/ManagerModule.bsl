// Функция - Актуализировать предопределенный вид взаимодейтсвия
//
// Параметры:
//  ИмяПредопреленногоЗначения	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция АктуализироватьПредопределенныйВидВзаимодейтсвия(ИмяПредопреленногоЗначения) Экспорт
	
	ПолноеИмяПредопреленногоЗначения 	= "Справочник.ВидыВзаимодействий." + ИмяПредопреленногоЗначения;
	ВидВзаимодействий		 			= ОбщегоНазначения.ПредопределенныйЭлемент(ПолноеИмяПредопреленногоЗначения);
	Если ЗначениеЗаполнено(ВидВзаимодействий) Тогда 
		ВидВзаимодействияОбъект 							= ВидВзаимодействий.ПолучитьОбъект();
	Иначе 
		ВидВзаимодействияОбъект 							= Справочники.ВидыВзаимодействий.СоздатьЭлемент();
	КонецЕсли;
	Если ИмяПредопреленногоЗначения = "Встреча" Тогда
		ТипВзаимодействия = Перечисления.ВидыВзаимодействия.Встреча;
		ВидВзаимодействияОбъект.ИндексКартинки = 33;
	ИначеЕсли ИмяПредопреленногоЗначения = "ЗвонокВходящий" Тогда
		ТипВзаимодействия = Перечисления.ВидыВзаимодействия.ЗвонокВходящий;
		ВидВзаимодействияОбъект.ИндексКартинки = 21;
	ИначеЕсли ИмяПредопреленногоЗначения = "ЗвонокИсходящий" Тогда
		ТипВзаимодействия = Перечисления.ВидыВзаимодействия.ЗвонокИсходящий;
		ВидВзаимодействияОбъект.ИндексКартинки = 1;
	ИначеЕсли ИмяПредопреленногоЗначения = "ОнлайнЗаявка" Тогда
		ТипВзаимодействия = Перечисления.ВидыВзаимодействия.ОнлайнЗаявка;
		ВидВзаимодействияОбъект.ИндексКартинки = 32;
	ИначеЕсли ИмяПредопреленногоЗначения = "Прочее" Тогда
		ТипВзаимодействия = Перечисления.ВидыВзаимодействия.Прочее;
		ВидВзаимодействияОбъект.ИндексКартинки = 25;
	Иначе 
		ТипВзаимодействия = Перечисления.ВидыВзаимодействия.ПустаяСсылка();
	КонецЕсли;	
	ВидВзаимодействияОбъект.ВидВзаимодействия 				= ТипВзаимодействия;
	Если НЕ ЗначениеЗаполнено(СокрЛП(ВидВзаимодействияОбъект.ТемаПоУмолчанию)) И ЗначениеЗаполнено(ТипВзаимодействия) Тогда 
		ВидВзаимодействияОбъект.ТемаПоУмолчанию 			= СокрЛП(Строка(ТипВзаимодействия));
	КонецЕсли;	
	ВидВзаимодействияОбъект.ИмяПредопределенныхДанных 		= ИмяПредопреленногоЗначения;
	//ВидВзаимодействияОбъект.Предопределенный 				= Истина;
	ВидВзаимодействияОбъект.ПометкаУдаления 				= Ложь;
	ВидВзаимодействияОбъект.Наименование	 				= Строка(ТипВзаимодействия);
	
	Попытка
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ВидВзаимодействияОбъект);
		Возврат ВидВзаимодействияОбъект.Ссылка;		
	Исключение
		МетаданныеСправочника 		= Метаданные.Справочники.ВидыВзаимодействий;
		ПредставлениеСправочника 	= МетаданныеСправочника.Представление();
		
		ШаблонКомментария = НСтр("ru = 'Не удалось актуализировать предопределенный вид взаимодейтсвия ""%1"" в справочнике ""%2""
		|по причине: %3'");
		
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ШаблонКомментария,
		Строка(ВидВзаимодействияОбъект.Ссылка),
		ПредставлениеСправочника,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Предупреждение,
		МетаданныеСправочника,
		ВидВзаимодействияОбъект.Ссылка,
		Комментарий);
		
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

