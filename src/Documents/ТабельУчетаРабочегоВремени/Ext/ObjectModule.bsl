
#Область ОбработчикиСобытий

// Процедура - обработчик события "ОбработкаЗаполнения" объекта
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения = Неопределено Тогда
		СтруктурнаяЕдиница = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;
	КонецЕсли;
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, , ДанныеЗаполнения);
	
КонецПроцедуры

// Процедура - обработчик события "ПриКопировании" объекта
//
Процедура ПриКопировании(ОбъектКопирования)
	
	// Заполнение реквизитов документа по умолчанию
	ОбщегоНазначенияСтоматология.ЗаполнитьРеквизитыОбъектаПоУмолчанию(ЭтотОбъект, ОбъектКопирования);
	                       
КонецПроцедуры

// Процедура - обработчик события "ОбработкаПроверкиЗаполнения".
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	// Проверяем нет ли документа с такой же шапкой
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ТабельУчетаРабочегоВремени.Ссылка
	               |ИЗ
	               |	Документ.ТабельУчетаРабочегоВремени КАК ТабельУчетаРабочегоВремени
	               |ГДЕ
	               |	ТабельУчетаРабочегоВремени.Проведен = ИСТИНА
	               |	И ТабельУчетаРабочегоВремени.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |	И ТабельУчетаРабочегоВремени.Период = &Период
	               |	И ТабельУчетаРабочегоВремени.ВидОперации = &ВидОперации 
				   |	И ТабельУчетаРабочегоВремени.Ассистент = &Ассистент
				   |	И ТабельУчетаРабочегоВремени.Ссылка <> &Ссылка";
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ВидОперации", ВидОперации);
	Запрос.УстановитьПараметр("Ассистент", Ассистент);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	РезультатТаблица = Запрос.Выполнить().Выгрузить();
								
	Если РезультатТаблица.Количество() > 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Табель работы " + ?(ВидОперации = 0, "сотрудников на ", "ассистента на") + Формат(Период, "ДФ='MMMM yyyy'") + " уже существует.");
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события "ПередЗаписью".
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ВидОперации = Ложь Тогда
		Ассистент = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, Режим)

	// Инициализация дополнительных свойств для проведения документа.
	ДвиженияДокументовСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);	
	
    // Инициализация данных документа.	
	Документы.ТабельУчетаРабочегоВремени.УстановитьНачальныеДанныеДокумента(Ссылка, ДополнительныеСвойства);	
	
	// Движения по регистрам
	ДвиженияДокументовСервер.РабочееВремяСотрудников(ДополнительныеСвойства, Движения, Отказ);
    // Запись наборов записей.
	ДвиженияДокументовСервер.ДобавитьНаборыЗаписей(ЭтотОбъект);	

КонецПроцедуры

#КонецОбласти

