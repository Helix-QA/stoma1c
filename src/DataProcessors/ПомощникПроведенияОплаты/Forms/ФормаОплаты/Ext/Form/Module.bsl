#Область ОбработчикиСобытийФормы

&НаСервере
// Создание формы на сервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		                 
	ПараметрДокументыПродажи = Неопределено;
	ЗакрытьЗанятияБезЗапроса = Неопределено;
	Параметры.Свойство("Контрагент"               , ЭтотОбъект.Контрагент); 
	Параметры.Свойство("ВидОперации"              , ЭтотОбъект.ВидОперации);
	Параметры.Свойство("ДатаПродажи"              , ЭтотОбъект.ДатаПродажи);
	Параметры.Свойство("ДокументыПродажи"         , ПараметрДокументыПродажи);
    Параметры.Свойство("ОткрытиеИзФормыСписка"    , ОткрытиеИзФормыСписка);
	Параметры.Свойство("ЗакрытьФормуАвтоматически", ПараметрФормыЗакрыватьФормуПослеОплаты);
	
	ЭтотОбъект.ДатаПродажи               = ?(НЕ ЗначениеЗаполнено(ДатаПродажи),ТекущаяДатаСеанса(),ДатаПродажи);
	ЭтотОбъект.СтруктурнаяЕдиница        = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница;	
	ЭтотОбъект.Сотрудник                 = ПараметрыСеанса.ТекущийСотрудник;
	ЭтотОбъект.ЗакрыватьФормуПослеОплаты = Параметры.Свойство("ЗакрытьФормуАвтоматически") ИЛИ ПараметрДокументыПродажи <> Неопределено;
	НеЗачислятьСдачуНаЛицевойСчет        = ПользователиСтоматология.ПолучитьБулевоЗначениеПраваПользователя(ПланыВидовХарактеристик.ПраваПользователей.НеЗачислятьСдачуНаЛицевойСчет, Ложь);
    УчитыватьАвансыВРазрезеДокументов    = Константы.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Получить();
	РежимЗачисленияСдачи                 = Константы.ЗачислениеСдачиОтОплаты.Получить();

	// Подготовка массива документов для оплаты
	Если НЕ ПараметрДокументыПродажи = Неопределено Тогда
		Если ТипЗнч(ПараметрДокументыПродажи) = Тип("Массив") Тогда
			ДокументыЗадолженности.ЗагрузитьЗначения(ПараметрДокументыПродажи);
		Иначе
			ДокументыЗадолженности.Добавить(ПараметрДокументыПродажи);
			ДокументАванса = ПараметрДокументыПродажи;
			ЭтоВзносАванса = (ТипЗнч(ПараметрДокументыПродажи) = Тип("ДокументСсылка.НарядЗаказ") 
				Или ТипЗнч(ПараметрДокументыПродажи) = Тип("ДокументСсылка.ПланЛечения"));
		КонецЕсли;	 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументыЗадолженности) 
		И ТипЗнч(ДокументыЗадолженности[0].Значение) = Тип("ДокументСсылка.ВозвратОтПокупателя") Тогда
		ЭтотОбъект.ЭтоВозвратВДеньПродажи = НачалоДня(ДокументыЗадолженности[0].Значение.ДокументОснования.Дата) = НачалоДня(ТекущаяДатаСеанса());		
	КонецЕсли;	
	ЭтаФорма.Заголовок = ?(ЭтотОбъект.ВидОперации = Перечисления.ВидыОпераций.Продажа, "Оплата", "Возврат") 
					   + ?(ЗначениеЗаполнено(ЭтотОбъект.Контрагент), " пациента: " + ЭтотОбъект.Контрагент, "");	
	
	// Инициализация состояния формы
	ОбновитьФормуСервер("ПРИ_ЗАПУСКЕ", Истина);	
	
	ЭтотОбъект.КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор();

	 		
КонецПроцедуры

&НаКлиенте
// Обработчик при открытии формы на клиенте.
//
Процедура ПриОткрытии(Отказ)
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ТекущаяКасса)  Тогда
			
		Описание = "Оплата невозможна! Кассы доступные для текущего сотрудника недоступны на текущем рабочем месте.";
		ПоказатьОповещениеПользователя("Оплата",,Описание, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 			

	КонецЕсли;

	Если ПечатьКопииЧекаКоличество = 0 Тогда 
		ПечатьКопииЧекаКоличество = 1;
	КонецЕсли;	
	
	УстановитьДоступностьЦветФонаОплатить();
	УстановитьАвтоВводСуммДляАвансов();	
	УстановитьКоличествоОбъектовПечатиПоУмолчанию();
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ОбработкаОповещения".
//
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// Работа с внешним оборудованием
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "TracksData" Тогда
			
			ДанныеКарты = МенеджерОборудованияКлиент.ОбработатьДанныеМагнитнойКарты(Параметр);		   		   
			Если ЗначениеЗаполнено(ДанныеКарты.ТипДанных) Тогда
				ОбработатьДанныеСВнешнегоУстройстваСчитывания(ДанныеКарты);
			Иначе
				ПоказатьОповещениеПользователя("Оплата",,"Данная карта не зарегистрирован! Код: " + ДанныеКарты.КодШифра, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 			
			КонецЕсли;
			
		КонецЕсли;		
	КонецЕсли;
	Если Источник = "ВнешнееОборудование" И ВводДоступен() Тогда
		
		Если ИмяСобытия = "ScanData" Тогда
			
			ДанныеШтрихКода = МенеджерОборудованияКлиент.ОбработатьДанныеШтрихКода(Параметр);	
			Если ЗначениеЗаполнено(ДанныеШтрихКода.ТипДанных) Тогда			
				ОбработатьДанныеСВнешнегоУстройстваСчитывания(ДанныеШтрихКода);		
			Иначе
				ПоказатьОповещениеПользователя("Оплата",,"Данный штрих-код не зарегистрирован! Код: " + ДанныеШтрихКода.КодШифра, БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "СБП_УспешнаяОплата" ИЛИ ИмяСобытия = "СБП_ВозвратОплаты" Тогда
		ОбсужденияСистемыВзаимодействияКлиент.ОбработкаОповещенияОбУспешностиОплатыСБП(ЭтаФорма, Параметр, ИмяСобытия = "СБП_ВозвратОплаты");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Функция обрабатывает код карты, полученный от внешнего оборудования.
// 
Процедура ОбработатьДанныеСВнешнегоУстройстваСчитывания(СтруктураДанных) 
	
	Если СтруктураДанных.ТипДанных = "СЕРТИФИКАТ_НА_СУММУ" Тогда 	
		
		ОбработатьДанныеШтрихкодаСертификата(СтруктураДанных, Истина);
		
	Иначе 	
		
	    ПоказатьОповещениеПользователя("Оплата",,"Штрихкод не принадлежит сертификату на сумму средств!", БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Важное); 

	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
// Процедура - Обработать данные штрихкода сертификата.
// 
// Параметры:
//  СтруктураДанных	 - 	 - 
// 
Процедура ОбработатьДанныеШтрихкодаСертификата(СтруктураДанных, ВводСоСканера)
	
	ДанныеСертифиаката = ПолучитьДанныеСертификата(
		СтруктураДанных.Сертификат, 
		СтруктураДанных.ПартияСертификата, 
		ВводСоСканера, 
		СтруктурнаяЕдиница, 
		Контрагент);
		
	ДобавитьВыбранныйСертификатВВидыОплат(ДанныеСертифиаката);
	
КонецПроцедуры

&НаКлиенте
// Реинициализация формы, сброс всех выбранных параметров.
Процедура ОбновитьФорму(Режим = "", ОчиститьРеквизитыОплаты = Ложь, ИдентификаторТЗЗадолженностей = Неопределено)
	
	ОбновитьФормуСервер(Режим, ОчиститьРеквизитыОплаты, ИдентификаторТЗЗадолженностей);
	
КонецПроцедуры	

&НаСервере
// Реинициализация формы, сброс всех выбранных параметров.
Процедура ОбновитьФормуСервер(Режим = "", ОчиститьРеквизитыОплаты = Ложь, ИдентификаторТЗЗадолженностей = Неопределено)
	
	// Процедуры подготовки формы
	Если Режим = "ПРИ_ЗАПУСКЕ" Тогда   
		
		ПодготовкаТаблицыЗадолженностей();
		
		Если ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
			
			КонтактнаяИнформация = ПолучитьКонтактнуюИнформациюКлиента(ЭтотОбъект.Контрагент);
			
			ЭтотОбъект.ЧекККТКонтактыКлиентаПочта   = КонтактнаяИнформация.Email;
			ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон = КонтактнаяИнформация.Телефон;
			
		КонецЕсли; 
		
		ОбновитьСписокНаправленийКВрачам();
		
		ЭтотОбъект.ЧекПечатать = ?(ЗначениеЗаполнено(Этотобъект.ТекущаяКасса), Не ОбщегоНазначения.ПолучитьЗначениеРеквизита(Этотобъект.ТекущаяКасса, "ПриоритетЭлектронногоЧека"), Истина); 
		
		РасставитьПриоритетПечатиЧека();
		
	ИначеЕсли Режим = "ОБНОВИТЬ_ТАБЛИЦУ_ЗАДОЛЖЕННОСТЕЙ" Тогда
		
		ПодготовкаТаблицыЗадолженностей();
		
	ИначеЕсли Режим = "ОБНОВИТЬ_ВИДЫ_ОПЛАТ" Тогда
		
		УстановитьВидыОплатСервер();
		
	КонецЕсли;	
	
	Если НЕ Режим = "ОБНОВИТЬ_ВИДЫ_ОПЛАТ" Тогда
		
		Если ОчиститьРеквизитыОплаты Тогда
			
			ОчиститьВнесенныеВидыОплат();
			ЭтотОбъект.ОплатаВнесено = 0;
			ЭтотОбъект.ОплатаСдача   = 0;	
			
		КонецЕсли;
		
		УстановитьВидыОплатСервер(Режим = "ПРИ_ЗАПУСКЕ");
		
	КонецЕсли;
	
	УстановитьВидимостьЭлементов();	
	
	ПересчитатьСуммуКоплате();  
	
КонецПроцедуры

&НаСервере
// Функция, возвращает структуру контактной информации.
//
Функция ПолучитьКонтактнуюИнформациюКлиента(Клиент, ДобавитьКодСтраны = Ложь)
	
	EmailСтроки = Клиент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты));
	Email = Неопределено;
	Если EmailСтроки.Количество() > 0 Тогда
	  Email = EmailСтроки[0].АдресЭП;
	КонецЕсли;
	
	ТелефонСтроки = Клиент.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон));
	НомерТелефона = Неопределено;
	Если ТелефонСтроки.Количество() > 0 Тогда
		
		НомерТелефона = ТелефонСтроки[0].НомерТелефона;
		
		СписокПолей = Новый СписокЗначений;
		УправлениеКонтактнойИнформациейСтоматология.ПреобразоватьНомерТелефона(НомерТелефона, СписокПолей); 
		НомерТелефона = ?(ДобавитьКодСтраны, СписокПолей[0].Значение, "") + СписокПолей[1].Значение + СписокПолей[2].Значение;
		
	КонецЕсли;
	
	Возврат Новый Структура("Email, Телефон", Email, НомерТелефона);
	
КонецФункции

&НаСервере
// Процедура установки видимости и доступности элементов. 
// 
Процедура УстановитьВидимостьЭлементов()
	
	Элементы.ГруппаПлательщик.Видимость               = Не ЗначениеЗаполнено(Контрагент);	
	Элементы.ПечатьКопииЧекаКоличество.Доступность	  = ПечатьКопииЧека;	
	Элементы.ПечатьКвитанций_Количество.Доступность   = ПечатьКвитанции;
	
	Если ВидОперации = Перечисления.ВидыОпераций.Возврат Тогда
		Элементы.ПечатьАктаОвыполненыхРаботах.Видимость = Ложь;
		Элементы.ПечатьКвитанции.Видимость              = Ложь;
		Элементы.ПечатьКвитанций_Количество.Видимость   = Ложь;
	КонецЕсли;

КонецПроцедуры

// Процедура - Пересчитать сумму коплате.
// 
&НаСервере
Процедура ПересчитатьСуммуКоплате()
	
	ЭтотОбъект.ОплатаСумма = 0;
	Для Каждого СтрокаТ ИЗ ЭтотОбъект.ТаблицаЗадолженностей Цикл				                          
		
		ЭтотОбъект.ОплатаСумма  = ЭтотОбъект.ОплатаСумма + ?(СтрокаТ.ПризнакВыбора, СтрокаТ.Задолженность, 0);		
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// При изменении выбора контрагента.
//
Процедура КонтрагентПриИзменении(Элемент)
	
    ОбновитьФорму("ОБНОВИТЬ_ТАБЛИЦУ_ЗАДОЛЖЕННОСТЕЙ",Истина);
	
КонецПроцедуры

// Процедура - Процедура обработки нажатия меню.
// 
// Параметры:
//  Элемент	 - 	 - 
// 
&НаКлиенте
Процедура ПриИзмененииВыбораКассыОплаты(Элемент)
	
	ТекущееПолеВводаСерииСертификата	= Неопределено;
	ТекущееПолеВВодаСуммыОплаты			= Неопределено;
	ПредПолеВВодаСуммыОплаты			= Неопределено;	
	
	ПриИзмененииВыбораКассыОплатыСервер(Элемент.Имя);
   	УстановитьДоступностьЦветФонаОплатить();
	
КонецПроцедуры

&НаКлиенте
// Процедура - Чек печатать при изменении.
//
// Параметры:
//  Элемент	 - 	 - 
//
Процедура ЧекПечататьПриИзменении(Элемент)
		
	Если ЭтотОбъект.ЧекПечатать = Ложь Тогда
		
		Если ЗначениеЗаполнено (ЭтотОбъект.ЧекККТКонтактыКлиентаПочта) Тогда
			
			Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Истина;
			Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту 				= Истина;
			
		ИначеЕсли ЗначениеЗаполнено (ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон) Тогда
			
			Элементы.ГруппаКонтактыКлиентаТелефон.Видимость			= Истина;
			Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость 	= Ложь;
			ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон 				= Истина;
		Иначе 
			ЭтотОбъект.ЧекПечатать = Истина;   			
			
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Нужно указать почту или телефон пациента для отправки электронного чека.';
															|en='You must specify the patient''s mail or phone number to send an electronic receipt.'"));	
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#Область ОбработчикиКонтактнойИнформацииКлиента

// Процедура - Контакты клиента использвоать телефон
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура КонтактыКлиентаИспользоватьТелефон(Команда)
	
	Элементы.ГруппаКонтактыКлиентаТелефон.Видимость       = Истина;
	Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость = Ложь;
	
	ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон = Истина;
	
КонецПроцедуры

// Процедура - Контакты клиента удалить телефон
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура КонтактыКлиентаУдалитьТелефон(Команда)
	
	Элементы.ГруппаКонтактыКлиентаТелефон.Видимость       = Ложь;
	Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость = Истина;
	
	ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон = Ложь;
	
	Если ЭтотОбъект.ЧекПечатать = Ложь И ЗначениеЗаполнено (ЭтотОбъект.ЧекККТКонтактыКлиентаПочта) Тогда
			
		Элементы.ГруппаКонтактыКлиентаПочта.Видимость 			= Истина;
		Элементы.КонтактыКлиентаИспользоватьПочту.Видимость 	= Ложь;
		ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту 				= Истина; 
		
	ИначеЕсли ЭтотОбъект.ЧекПечатать = Ложь Тогда
		
		ЭтотОбъект.ЧекПечатать = Истина;
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Нужно указать почту или телефон пациента для отправки электронного чека.';
															|en='You must specify the patient''s mail or phone number to send an electronic receipt.'"));
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Контакты клиента использвоать почту
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура КонтактыКлиентаИспользоватьПочту(Команда)
	
	Элементы.ГруппаКонтактыКлиентаПочта.Видимость       = Истина;
	Элементы.КонтактыКлиентаИспользоватьПочту.Видимость = Ложь;
	
	ПодключитьОбработчикОжидания("УстановитьФокусПоляКонтактыКлиентаПочтаТаймер", 0.1, Истина);
	
	ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту = Истина;
	
КонецПроцедуры

// Процедура - Установить фокус поля контакты клиента почта таймер
// 
&НаКлиенте
Процедура УстановитьФокусПоляКонтактыКлиентаПочтаТаймер()
	
	ЭтаФорма.ТекущийЭлемент = Элементы.КонтактыКлиентаПочта;
	
КонецПроцедуры

// Процедура - Контакты клиента удалить почту
// 
// Параметры:
//  Команда	 - 	 - 
// 
&НаКлиенте
Процедура КонтактыКлиентаУдалитьПочту(Команда)
	
	Элементы.ГруппаКонтактыКлиентаПочта.Видимость       = Ложь;
	Элементы.КонтактыКлиентаИспользоватьПочту.Видимость = Истина;

	ЭтотОбъект.ЧекККТОтправлятьЧекНаЭлПочту = Ложь;
	
	Если ЭтотОбъект.ЧекПечатать = Ложь И ЗначениеЗаполнено (ЭтотОбъект.ЧекККТКонтактыКлиентаТелефон) Тогда
		
		Элементы.ГруппаКонтактыКлиентаТелефон.Видимость			= Истина;
		Элементы.КонтактыКлиентаИспользоватьТелефон.Видимость 	= Ложь;
		ЭтотОбъект.ЧекККТОтправлятьЧекНаТелефон 				= Истина; 
		
	ИначеЕсли ЭтотОбъект.ЧекПечатать = Ложь Тогда
		
		ЭтотОбъект.ЧекПечатать = Истина;
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Нужно указать почту или телефон пациента для отправки электронного чека.';
															|en='You must specify the patient''s mail or phone number to send an electronic receipt.'"));
		
	КонецЕсли;
	
КонецПроцедуры

