// Процедура - Команда записать на прием
//
Процедура ЗаписатьНаПриемЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ПараметрыФормы = Новый Структура;
		Если ТипЗнч(Результат) = Тип("СправочникСсылка.Контрагенты") Тогда
			ПараметрыФормы.Вставить("Контрагент"              , Результат); 
		Иначе
			ПараметрыФормы.Вставить("Контрагент"              , Результат.Значение);
		КонецЕсли;
		ПараметрыФормы.Вставить("ЗакрытьПриСозданииЗаписи"	, Истина);    
		ПараметрыФормы.Вставить("Заявка"					, ЗаявкаОснование);
		ПараметрыФормы.Вставить("Сделка"					, СделкаПоЗаявке);
		ПараметрыФормы.Вставить("ИсточникЗаписи"			, "Телефон");
		ПараметрыФормы.Вставить("IDЗвонка"					, IDЗвонка);
        ПараметрыФормы.Вставить("ВходящийНомерТелефона"		, ПреобразованныйНомерТелефона);

		//Если ПараметрыТелефонногоЗвонка.ПиктограммаЗвонка = 0 Тогда	
			ПараметрыФормы.Вставить("ВнутреннийНомерСотрудника"			, ПараметрыТелефонногоЗвонка.ВнутреннийНомерСотрудника);	
		//КонецЕсли;
	
		ИмяФормыПланировщика = ОбщегоНазначенияКлиент.ПолучитьИмяФормыПланировщика(ПараметрыФормы, "ФормаЗаписи");
		
		Форма = ПолучитьФорму(ИмяФормыПланировщика, ПараметрыФормы,, "ФормаПланировщикКлючУникальности");
		Форма.Открыть();
		Оповестить("СозданиеСобытияСКонтрагентом", ПараметрыФормы);
		
		ВызвытьОповещение = Истина;
		
	КонецЕсли;
	    
КонецПроцедуры

