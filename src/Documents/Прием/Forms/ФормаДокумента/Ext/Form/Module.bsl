// Процедура - Заполнить дополнительные реквизиты таблицы лечения.
//
Процедура ЗаполнитьДополнительныеРеквизитыТаблицыЛечения()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СогласованияСтраховыхУслуг.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	СогласованияСтраховыхУслуг.СтатусСогласования КАК СтатусСогласования,
	|	СогласованияСтраховыхУслуг.ДатаОтправки КАК ДатаОтправки,
	|	СогласованияСтраховыхУслуг.ДатаСогласования КАК ДатаСогласования,
	|	СогласованияСтраховыхУслуг.Согласователь КАК Согласователь,
	|	ДоговорыКонтрагентовУслугиПоДоговору.Согласование КАК ТребуетсяСогласование,
	|	СогласованияСтраховыхУслуг.Комментарий КАК КомментарийСогласования
	|ИЗ
	|	РегистрСведений.СогласованияСтраховыхУслуг КАК СогласованияСтраховыхУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов.УслугиПоДоговору КАК ДоговорыКонтрагентовУслугиПоДоговору
	|		ПО СогласованияСтраховыхУслуг.Договор = ДоговорыКонтрагентовУслугиПоДоговору.Ссылка
	|			И СогласованияСтраховыхУслуг.Номенклатура = ДоговорыКонтрагентовУслугиПоДоговору.Номенклатура
	|ГДЕ
	|	СогласованияСтраховыхУслуг.Прием = &Прием
	|	И ДоговорыКонтрагентовУслугиПоДоговору.Ссылка.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("Прием",  Объект.Ссылка);
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();

	Пока ВыборкаЗапроса.Следующий() Цикл
		Для каждого СтрокаТаблицыЛечение Из Объект.Лечение Цикл 			
			Если СтрокаТаблицыЛечение.КлючСтроки = ВыборкаЗапроса.ИдентификаторСтроки Тогда
				ЗаполнитьЗначенияСвойств(СтрокаТаблицыЛечение, ВыборкаЗапроса);
				Прервать;
			КонецЕсли;
		КонецЦикла;			
	КонецЦикла;
	
КонецПроцедуры

