// Процедура, обработчик события "ПриИзменение"
//
Процедура СотрудникПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Сотрудник) Тогда		
		ЭтоСтоматологическиеУслугиПред    = ЭтоСтоматологическиеУслуги;
		ЭтоСтоматологическиеУслуги        = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(Объект.Сотрудник);
		// При несовпадении признаком запрос на продолжение
		Если НЕ ЭтоСтоматологическиеУслугиПред = ЭтоСтоматологическиеУслуги И Объект.Запасы.Количество() > 0 Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("СотрудникПриИзмененииПослеВопроса", ЭтотОбъект, Новый Структура("ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги", ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги)),
													"Специализация выбранного сотрудника не соответсвует текущей специализации приема. Обследование и табличные части будут очишены. Продолжить?",РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли; 
		СотрудникПриИзмененииФрагмент(ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги)
	КонецЕсли;
	
	СотрудникПриИзмененииЗавершение();
				
КонецПроцедуры

&НаКлиенте
Процедура СотрудникПриИзмененииПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ЭтоСтоматологическиеУслугиПред = ДополнительныеПараметры.ЭтоСтоматологическиеУслугиПред;
	ЭтоСтоматологическиеУслуги     = ДополнительныеПараметры.ЭтоСтоматологическиеУслуги;
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Объект.Запасы.Очистить();
	Иначе
		// Отмена выбора сотрудгика
		Объект.Сотрудник           = СотрудникПред;
		ЭтоСтоматологическиеУслуги = ЭтоСтоматологическиеУслугиПред;
		Возврат;
	КонецЕсли;
	
	СотрудникПриИзмененииФрагмент(ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги);

	СотрудникПриИзмененииЗавершение();
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникПриИзмененииФрагмент(ЭтоСтоматологическиеУслугиПред, ЭтоСтоматологическиеУслуги) 
	
	// Подготовка вида цен
	Объект.ВидЦенПродажи = ВернутьВидЦены(Объект.ПолисМедСтрахования, Объект.Сотрудник, Объект.СтруктурнаяЕдиница);
	Если НЕ ЭтоСтоматологическиеУслугиПред = ЭтоСтоматологическиеУслуги Тогда
		НастройкаФормыСервер("ПРИ_ИЗМЕНЕНИИ_СОТРУДНИКА");
	КонецЕсли;
	// Перезаполнить цены
	ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен(Истина, Ложь);		 	
	// Обновить документ
	Если ЭтоСтоматологическиеУслуги   
		И (НЕ ЭтоСтоматологическиеУслугиПред = ЭтоСтоматологическиеУслуги) Тогда
		ОбновитьДокумент();	
	КонецЕсли;
	
КонецПроцедуры

