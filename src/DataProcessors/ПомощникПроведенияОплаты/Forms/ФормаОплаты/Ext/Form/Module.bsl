// Процедура выполняет проверку возможности пробития чека.
// 
Функция ОплатаПодготовкаПроверкаВозможностиСервер(СообщениеПользователю, ЗапросПодтверждения)
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ТекущаяКасса) Тогда
		
		СообщениеПользователю = "Не выбрана касса для оплаты!";
		ЗапросПодтверждения   = Ложь;
		Возврат Ложь; 	
		
	КонецЕсли;
	
	Если ЭтотОбъект.ОплатаСумма = 0 Тогда
		
		СообщениеПользователю = "Нет оплачиваемых документов!";
		ЗапросПодтверждения   = Ложь;
		Возврат Ложь; 
		
	КонецЕсли;
					
	Если ОплатаВнесено = 0  Тогда		
		
		СообщениеПользователю = "Не указана оплачиваемая сумма!";
		ЗапросПодтверждения   = Ложь;
		Возврат Ложь; 
		
	ИначеЕсли ОплатаВнесено < ОплатаСумма  Тогда		
		
		СообщениеПользователю = "Сумма внесенной оплаты меньше суммы требуемой. Продолжить?";
		ЗапросПодтверждения   = Истина;
		Возврат Ложь; 		
		
	КонецЕсли;	     
	
		// проверка на сегмент в настройках кассы
	ВходитВСегмент = ПринадлежностьКСекциям(СообщениеПользователю);
	Если Не ВходитВСегмент Тогда
		Возврат Ложь;
	КонецЕсли;  
	
	Возврат Истина;
	
КонецФункции

