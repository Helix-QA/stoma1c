//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	
	
КонецПроцедуры

// Процедура - Актуализировать данные курса и лечения
//
// Параметры:
//  Прием		 - 	 - 
//  КурсЛечения	 - 	 - 
//  ЛечениеВрача - 	 - 
//
Процедура АктуализироватьДанныеКурсаИЛечения(Прием, КурсЛечения, ЛечениеВрача) Экспорт
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////   
	// ЛечениеВрача 
	Если ЗначениеЗаполнено(ЛечениеВрача) Тогда
		
		ЛечениеВрачаОбъект = ЛечениеВрача.ПолучитьОбъект();	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Прием.Ссылка КАК Ссылка,
		|	Прием.ВремяОкончанияПриема КАК ВремяОкончанияПриема,
		|	Прием.ВремяНачалаПриема КАК ВремяНачалаПриема,
		|	Прием.РезультатПриема КАК РезультатПриема,
		|	Прием.Номер КАК Номер,
		|	Прием.СуммаДокумента КАК СуммаДокумента
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.ЛечениеВрача = &ЛечениеВрача
		|	И Прием.Проведен
		|	И Прием.ВремяОкончанияПриема <> ДАТАВРЕМЯ(1, 1, 1)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВремяОкончанияПриема,
		|	РезультатПриема,
		|	Ссылка,
		|	Номер";
		
		Запрос.УстановитьПараметр("ЛечениеВрача", ЛечениеВрача);   
		Результат         = Запрос.Выполнить().Выгрузить();  
		ЗаписатьЛечение   = Ложь;
		КоличествоПриемов = Результат.Количество(); 
		ДатаОкончания     = Неопределено;
		Если КоличествоПриемов <= 1 Тогда 
			// 1. Если удаляют единственный прием по лечению, то удалять лечение
			ЛечениеВрачаОбъект.ДатаНачала      = Дата(1,1,1); 
			ЛечениеВрачаОбъект.ПометкаУдаления = Истина; 
			ДатаОкончания                      = Дата(1,1,1); 
			ЗаписатьЛечение = Истина;
		ИначеЕсли Результат[0].Ссылка = Прием Тогда
			// 2. Если удаляется первый прием по данному лечению, то дата начала лечения должна сдвигаться на дату следующего приема. 
			ЛечениеВрачаОбъект.ДатаНачала = Результат[1].ВремяНачалаПриема;
			ЗаписатьЛечение = Истина;
		ИначеЕсли Результат[КоличествоПриемов - 1].Ссылка = Прием Тогда 
			// 3. Если удаляется последний прием, то найти дату пред последнего приема для закрытия лечения
			Если Результат[КоличествоПриемов - 2].РезультатПриема = 1 И ЛечениеВрачаОбъект.ДатаОкончания <> Результат[КоличествоПриемов - 2].ВремяОкончанияПриема Тогда
				ДатаОкончания = Результат[КоличествоПриемов - 2].ВремяОкончанияПриема;
			ИначеЕсли Результат[КоличествоПриемов - 2].РезультатПриема = 2 Тогда
				ДатаОкончания = Дата(1,1,1);
			КонецЕсли; 
			ЗаписатьЛечение = (ДатаОкончания <> Неопределено); 
		ИначеЕсли Результат[КоличествоПриемов - 1].Ссылка <> Прием Тогда 
			// 4. Если удаляется НЕ последний прием, то найти дату последнего приема для закрытия лечения
			Если Результат[КоличествоПриемов - 1].РезультатПриема = 1 
				И ЛечениеВрачаОбъект.ДатаОкончания <> Результат[КоличествоПриемов - 1].ВремяОкончанияПриема Тогда
				ДатаОкончания = Результат[КоличествоПриемов - 1].ВремяОкончанияПриема;
			ИначеЕсли Результат[КоличествоПриемов - 1].РезультатПриема = 2
				И ЛечениеВрачаОбъект.ДатаОкончания <> Дата(1,1,1) Тогда
				ДатаОкончания = Дата(1,1,1);
			КонецЕсли;
			ЗаписатьЛечение = (ДатаОкончания <> Неопределено);
		КонецЕсли;
		
		Если ЗаписатьЛечение Тогда 
			ИтогСуммаПриемов = Результат.Итог("СуммаДокумента");
			ЛечениеВрачаОбъект.ДатаОкончания = ДатаОкончания; 
			ЛечениеВрачаОбъект.СуммаЛечения  = ИтогСуммаПриемов;
			Попытка
				ЛечениеВрачаОбъект.Записать(); 
			Исключение
				ОписаниеОшибки = "Ошибка при изменении даты окончания лечения по приему " + Строка(Прием) + " " + ОписаниеОшибки();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
				ЗаписьЖурналаРегистрации("ИзменениеЛеченияПриУдаленииПриема", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			КонецПопытки;
		КонецЕсли;		
		
	КонецЕсли;
	
	/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////   
	// КурсЛечения 
	Если ЗначениеЗаполнено(КурсЛечения) Тогда 
		
		КурсЛеченияОбъект = КурсЛечения.ПолучитьОбъект();	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Лечения.Ссылка КАК Ссылка,
		|	Лечения.ДатаНачала КАК ДатаНачала,
		|	Лечения.ДатаОкончания КАК ДатаОкончания,
		|	Лечения.СуммаЛечения КАК СуммаЛечения
		|ИЗ
		|	Справочник.Лечения КАК Лечения
		|ГДЕ
		|	Лечения.КурсЛечения = &КурсЛечения
		|	И НЕ Лечения.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаОкончания УБЫВ,
		|	ДатаНачала УБЫВ,
		|	Ссылка УБЫВ";
	
		Запрос.УстановитьПараметр("КурсЛечения", КурсЛечения);
		Результат = Запрос.Выполнить();
		Если Результат.Пустой() Тогда 
			КурсЛеченияОбъект.ДатаОкончания   = Дата(1,1,1);  
			КурсЛеченияОбъект.ДатаНачала      = Дата(1,1,1);
			КурсЛеченияОбъект.ПометкаУдаления = Истина;
			Попытка
				КурсЛеченияОбъект.Записать(); 
			Исключение
				ОписаниеОшибки = "Ошибка при изменении даты окончания курса лечения по приему " + Строка(Прием) + " " + ОписаниеОшибки();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
				ЗаписьЖурналаРегистрации("ИзменениеКурсаПриУдаленииПриема", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			КонецПопытки;
		КонецЕсли;  
		
		Если КурсЛеченияОбъект.ПометкаУдаления = Истина Тогда
			Возврат;	
		КонецЕсли;
		
		РезультатТЧ = Результат.Выгрузить();
		ДатаОкончания = Неопределено;
		ЛечениеВрачаОбъект = ЛечениеВрача.ПолучитьОбъект();
		Если ЛечениеВрачаОбъект.ДатаОкончания = Дата(1,1,1) Тогда
			ДатаОкончания = Дата(1,1,1);  
		Иначе 
			НайденныеСтроки            = РезультатТЧ.НайтиСтроки(Новый Структура("ДатаОкончания", Дата(1,1,1)));
			ЕстьОткрытыеЛеченияПоКурсу = (НайденныеСтроки.Количество() <> 0);
			Если Не ЕстьОткрытыеЛеченияПоКурсу Тогда
				Для Каждого СтрокаТЧ Из РезультатТЧ Цикл 
					Если СтрокаТЧ.ДатаОкончания <> Дата(1,1,1) Тогда 
						ДатаОкончания = СтрокаТЧ.ДатаОкончания;
					КонецЕсли;	
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		РезультатТЧ.Сортировать("ДатаНачала");		
		ДатаНачала = РезультатТЧ[0].ДатаНачала;
		
		ЗаписыватьКурс = (ДатаОкончания <> Неопределено И КурсЛеченияОбъект.ДатаОкончания <> ДатаОкончания)
			Или (ДатаНачала <> Неопределено И КурсЛеченияОбъект.ДатаНачала <> ДатаНачала);
		Если ЗаписыватьКурс Тогда  
			Если ДатаОкончания <> Неопределено И КурсЛеченияОбъект.ДатаОкончания <> ДатаОкончания Тогда
				КурсЛеченияОбъект.ДатаОкончания = ДатаОкончания; 
			КонецЕсли;
			Если ДатаНачала <> Неопределено И КурсЛеченияОбъект.ДатаНачала <> ДатаНачала Тогда
				КурсЛеченияОбъект.ДатаНачала = ДатаНачала;
			КонецЕсли; 
			ИтогСуммаЛечений = РезультатТЧ.Итог("СуммаЛечения");
			Попытка
				КурсЛеченияОбъект.СуммаКурса = ИтогСуммаЛечений;
				КурсЛеченияОбъект.Записать(); 
			Исключение
				ОписаниеОшибки = "Ошибка при изменении даты окончания курса лечения по приему " + Строка(Прием) + " " + ОписаниеОшибки();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки);
				ЗаписьЖурналаРегистрации("ИзменениеКурсаПриУдаленииПриема", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки); 
			КонецПопытки;
		КонецЕсли;				
	КонецЕсли;
	
КонецПроцедуры

// Функция - Возвращает булево - был ли документ пробит по ФР.
//
Функция ДокументПробитПоФР(Прием) Экспорт

	Если НЕ ЗначениеЗаполнено(Прием) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПриемУчтенныеАвансы.ДокументАванса КАК ДокументАванса
	|ИЗ
	|	Документ.Прием.УчтенныеАвансы КАК ПриемУчтенныеАвансы
	|ГДЕ
	|	ПриемУчтенныеАвансы.Ссылка = &Ссылка
	|	И ПриемУчтенныеАвансы.НомерЧекаККМ > 0");
	
	Запрос.УстановитьПараметр("Ссылка", Прием);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Возврат Истина;
	КонецЕсли;

	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ДокументПробитПоФР
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументОснования
	|	И ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.НомерЧекаККМ > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА
	|ИЗ
	|	Документ.СписаниеДенежныхСредств.РасшифровкаПлатежа КАК СписаниеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	СписаниеДенежныхСредствРасшифровкаПлатежа.ДокументОснования = &ДокументОснования
	|	И СписаниеДенежныхСредствРасшифровкаПлатежа.Ссылка.НомерЧекаККМ > 0");
	
	Запрос.УстановитьПараметр("ДокументОснования", Прием);
	
	Возврат НЕ Запрос.Выполнить().Пустой();

КонецФункции

// Функция, возвращает структуру данных по приему.
//
Функция ПолучитьИнформациюИзТекущегоПриема(Прием) Экспорт
	
	ИнформацияПоПриему = Новый Структура(); 
	УстановитьПривилегированныйРежим(Истина);  
	
	Если ЗначениеЗаполнено(Прием.Контрагент) Тогда
		
#Область _______________________________________________________ЗУБНАЯ_фОРМУЛА___________________________________________________	
		
		Запрос = Новый запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗубнаяФормулаСрезПоследних.Зуб КАК Зуб,
		|	ВЫБОР
		|		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		|			ТОГДА ""0""
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Удален)
		|					ТОГДА ""1""
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Штифт)
		|							ТОГДА ""2""
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Абатмент)
		|									ТОГДА ""3""
		|								ИНАЧЕ ""4""
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	КОНЕЦ КАК СтатусЗуба
		|ИЗ
		|	РегистрСведений.ЗубнаяФормула.СрезПоследних(&Дата, Контрагент = &Контрагент) КАК ЗубнаяФормулаСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗубнаяФормулаСрезПоследних.Зуб,
		|	ВЫБОР
		|		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		|			ТОГДА ""0""
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Удален)
		|					ТОГДА ""1""
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Штифт)
		|							ТОГДА ""2""
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Абатмент)
		|									ТОГДА ""3""
		|								ИНАЧЕ ""4""
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	КОНЕЦ");
		Запрос.УстановитьПараметр("Контрагент", Прием.Контрагент); 	
		Запрос.УстановитьПараметр("Дата",  Прием.Дата); 		
		Результат = Запрос.Выполнить().Выгрузить();			
		МассивСтатусов = Новый Массив;
		Для Каждого СтрокаТЧ из Результат Цикл
			МассивСтатусов.Добавить(Новый Структура("Зуб, СтатусЗуба", СтрокаТЧ.Зуб, СтрокаТЧ.СтатусЗуба));			
		КонецЦикла;
		ИнформацияПоПриему.Вставить("Статусы", МассивСтатусов);
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗубнаяФормулаСрезПоследних.Зуб КАК Зуб,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы КАК Состояние,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Цвет КАК Цвет,
		|	ЗубнаяФормулаСрезПоследних.Область КАК Область,
		|	ВЫБОР
		|		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		|			ТОГДА ""0""
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Удален)
		|					ТОГДА ""1""
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Штифт)
		|							ТОГДА ""2""
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Абатмент)
		|									ТОГДА ""3""
		|								ИНАЧЕ ""4""
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	КОНЕЦ КАК СтатусЗуба
		|ИЗ
		|	РегистрСведений.ЗубнаяФормула.СрезПоследних(&Дата, Контрагент = &Контрагент) КАК ЗубнаяФормулаСрезПоследних
		|ГДЕ
		|	НЕ ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы = ЗНАЧЕНИЕ(Справочник.СостояниеЗубнойФормулы.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗубнаяФормулаСрезПоследних.Зуб,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы,
		|	ЗубнаяФормулаСрезПоследних.СостояниеЗубнойФормулы.Цвет,
		|	ЗубнаяФормулаСрезПоследних.Область,
		|	ВЫБОР
		|		КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Свой)
		|			ТОГДА ""0""
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Удален)
		|					ТОГДА ""1""
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Штифт)
		|							ТОГДА ""2""
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗубнаяФормулаСрезПоследних.СостояниеЗуба = ЗНАЧЕНИЕ(Перечисление.СостояниеЗуба.Абатмент)
		|									ТОГДА ""3""
		|								ИНАЧЕ ""4""
		|							КОНЕЦ
		|					КОНЕЦ
		|			КОНЕЦ
		|	КОНЕЦ");
		Запрос.УстановитьПараметр("Контрагент", Прием.Контрагент);					
		Запрос.УстановитьПараметр("Дата", Прием.Дата);
		Результат = Запрос.Выполнить().Выгрузить(); 
		МассивСостояний = Новый Массив;
		Для Каждого СтрокаТЧ из Результат Цикл
			МассивСостояний.Добавить(Новый Структура("Зуб, Состояние, Цвет, Область, СтатусЗуба", СтрокаТЧ.Зуб, СтрокаТЧ.Состояние, СтрокаТЧ.Цвет, СтрокаТЧ.Область, СтрокаТЧ.СтатусЗуба));			
		КонецЦикла;
		ИнформацияПоПриему.Вставить("Состояния", МассивСостояний);
		
#КонецОбласти	
		
#Область _______________________________________________________ТАБЛИЦА_УСЛУГИ___________________________________________________
		
		Если ТипЗнч(Прием) = Тип("ДокументСсылка.Прием") Тогда
			
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ПриемЛечение.Номенклатура КАК Номенклатура,
			|	ПриемЛечение.Зуб КАК Зуб,
			|	ПриемЛечение.Количество КАК Количество,
			|	ПриемЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг КАК КодУслуги,
			|	ПриемЛечение.Номенклатура.Наименование КАК НоменклатураНаименование
			|ИЗ
			|	Документ.Прием.Лечение КАК ПриемЛечение
			|ГДЕ
			|	ПриемЛечение.Ссылка = &Ссылка");
			Запрос.УстановитьПараметр("Ссылка", Прием); 
			Выборка = Запрос.Выполнить().Выгрузить(); 
			МассивУслуг = Новый Массив;
			Для Каждого СтрокаТЧ Из Выборка Цикл
				МассивУслуг.Добавить(Новый Структура("Номенклатура, Зуб, КодУслуги, Количество, НоменклатураНаименование", СтрокаТЧ.Номенклатура, СтрокаТЧ.Зуб, СтрокаТЧ.КодУслуги, СтрокаТЧ.Количество, СтрокаТЧ.НоменклатураНаименование));
			КонецЦикла;	
			ИнформацияПоПриему.Вставить("МассивУслуг", МассивУслуг);
			
#КонецОбласти	 
			
#Область _____________________________________________________ТИП_ЗУБНОЙ_ФОРМУЛЫ_________________________________________________
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ЗубнаяФормулаСрезПоследних.ТипЗубнойФормулы КАК ТипЗубнойФормулы
			|ИЗ
			|	РегистрСведений.ЗубнаяФормула.СрезПоследних(, Прием = &Прием) КАК ЗубнаяФормулаСрезПоследних"; 
			Запрос.УстановитьПараметр("Прием", Прием);
			Выборка = Запрос.Выполнить().Выбрать(); 
			Если Выборка.Следующий() Тогда
				ТипЗубнойФормулы = Выборка.ТипЗубнойФормулы;  
			Иначе
				ТипЗубнойФормулы = Прием.Контрагент.ТипЗубнойФормулы;  
			КонецЕсли;  
			
			ИнформацияПоПриему.Вставить("ТипЗубнойФормулы", ТипЗубнойФормулы); 
			
#КонецОбласти
			
#Область _____________________________________________________ТЕКСТ_ОБСЛЕДОВАНИЯ_________________________________________________
			
			ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(Прием.Контрагент, Прием,, Истина);
			
			МассивОбследований = Новый Массив;
			Для Каждого СтрокаТ Из ТаблицаОбследований Цикл 
				МассивОбследований.Добавить(Новый Структура("РеквизитНаименование, РеквизитЗначение", СтрокаТ.РеквизитНаименование, СтрокаТ.РеквизитЗначение));  
			КонецЦикла; 
			
			ИнформацияПоПриему.Вставить("МассивОбследований", МассивОбследований);  
			
#КонецОбласти 
			
		КонецЕсли;
		
	КонецЕсли; 
	
	УстановитьПривилегированныйРежим(Ложь); 
	
	Возврат ИнформацияПоПриему;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли
