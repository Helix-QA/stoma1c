&НаСервере
// Процедура - результат вопроса об удалении картинки на сервере
//
Процедура ВопросОбУдаленииКартинкиЗавершениеНаСервере(ФайлКартинки)
	
	ФайлКартинкиОбъект = ФайлКартинки.ПолучитьОбъект();
	ФайлКартинкиОбъект.УстановитьПометкуУдаления(Истина);
	ОтобразитьКартинки();
	ЭтаФорма.Модифицированность = Истина;
КонецПроцедуры

&НаСервере
// Процедура, отображает картинки номенклатуры.
//
Процедура ОтобразитьКартинки()
	
	ЭтотОбъект.ФайлыКартинок.Очистить();
	
	МассивФайловКартинок = ПолучитьВсеПодчиненныеФайлы(СтруктурнаяЕдиница);
	
	Для Индекс = 1 По 6 Цикл
		
		Если МассивФайловКартинок.Количество() >= Индекс Тогда
			ФайлКартинки = МассивФайловКартинок[Индекс - 1];
			ЭтотОбъект["АдресКартинки" + Индекс] = ПолучитьНавигационнуюСсылкуКартинки(ФайлКартинки, ЭтаФорма.УникальныйИдентификатор);
			ЭтотОбъект.ФайлыКартинок.Добавить(ФайлКартинки);
		КонецЕсли;
		
		Элементы["ПолеКартинки_" + Индекс].Видимость = МассивФайловКартинок.Количество() >= Индекс;
		
	КонецЦикла;
	
	Элементы.ГруппаКнопкиДобавитьКартинку.Видимость = (ЭтотОбъект.ФайлыКартинок.Количество() <= 5);
	
	ГруппаРодитель = ?(ЭтотОбъект.ФайлыКартинок.Количество() > 2, Элементы.ГруппаСтрокаСКартинками_2, Элементы.ГруппаСтрокаСКартинками_1);
	Элементы.Переместить(Элементы.ГруппаКнопкиДобавитьКартинку, ГруппаРодитель);
	
	Если МассивФайловКартинок.Количество() = 0 Тогда
		ЭтотОбъект.АдресКартинки1 = ПоместитьВоВременноеХранилище(БиблиотекаКартинок.ПросмотрНедоступен.ПолучитьДвоичныеДанные(), ЭтаФорма.УникальныйИдентификатор);
	КонецЕсли;
	
КонецПроцедуры

// Получает все подчиненные файлы.
//
// Параметры:
//   ВладелецФайла - ЛюбаяСсылка - владелец файла.
//
// Возвращаемое значение:
//   Массив из СправочникСсылка.Файлы - массив файлов.
//
Функция ПолучитьВсеПодчиненныеФайлы(ВладелецФайла)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Файлы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Файлы КАК Файлы
	|ГДЕ                     
	|	Файлы.ВладелецФайла = &ВладелецФайла
	|	И НЕ Файлы.ПометкаУдаления
	|	И (ВЫРАЗИТЬ(Файлы.Описание КАК СТРОКА(100))) = ""КартинкаЯндексСалон""");
	
	Запрос.УстановитьПараметр("ВладелецФайла", ВладелецФайла);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

&НаСервереБезКонтекста
// Функция возвращает навигационную ссылку картинки
//
Функция ПолучитьНавигационнуюСсылкуКартинки(ФайлКартинки, ИдентификаторФормы)
	
	УстановитьПривилегированныйРежим(Истина);
	//Возврат РаботаСФайламиСлужебныйВызовСервера.ПолучитьНавигационнуюСсылкуВоВременномХранилище(ФайлКартинки.ТекущаяВерсия);
	
	СсылкаНаДвоичныеДанные = РаботаСФайламиВызовСервераСтоматология.СсылкаНаДвоичныеДанныеФайла(ФайлКартинки, ИдентификаторФормы);
	Возврат ?(СсылкаНаДвоичныеДанные = Неопределено, "", СсылкаНаДвоичныеДанные);
	
КонецФункции

