// Процедура обработчик команды вызывает форму настройки и редактирования цен.
//
Процедура РедактироватьЦены(Команда)
	
	// 1. Формируем структуру параметров для заполнения формы "Цены и Валюта".
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ВидЦен", 	  			Объект.ВидЦен);
	СтруктураПараметров.Вставить("ПерезаполнитьЦены",	Ложь);
	
	// 2. Открвыаем форму "Цены и Валюта".
	ОткрытьФорму("ОбщаяФорма.ФормаЦены", СтруктураПараметров,,,,, Новый ОписаниеОповещения("РедактироватьЦеныЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте  
// Процедура - Редактировать цены завершение
//
// Параметры:
//  СтруктураЦены			 - 	 - 
//  ДополнительныеПараметры	 - 	 - 
//
Процедура РедактироватьЦеныЗавершение(СтруктураЦены, ДополнительныеПараметры) Экспорт
	
	// 3. Перезаполняем табличную часть "Запасы" если были внесены изменения в форме "Цены и Валюта".
	Если ТипЗнч(СтруктураЦены) = Тип("Структура") И СтруктураЦены.БылиВнесеныИзменения Тогда
		
		Объект.ВидЦен = СтруктураЦены.ВидЦен;
		
		// Пересчитываем цены по виду цен.					
		Если СтруктураЦены.ПерезаполнитьЦены Тогда
			
			СтруктураДанныеМассив = Новый Массив;
			
			Для Каждого СтрокаТабличнойЧасти Из Объект.Услуги Цикл 
				СтруктураДанные = Новый Структура();
				СтруктураДанные.Вставить("СтруктурнаяЕдиница",	Объект.СтруктурнаяЕдиница);
				СтруктураДанные.Вставить("ДатаОбработки",		Объект.Дата);
				СтруктураДанные.Вставить("ВидЦен", 				Объект.ВидЦен);
				СтруктураДанные.Вставить("Сотрудник", 			СтрокаТабличнойЧасти.Сотрудник);
				СтруктураДанные.Вставить("Номенклатура", 		СтрокаТабличнойЧасти.Номенклатура);
				СтруктураДанныеМассив.Добавить(СтруктураДанные);
			КонецЦикла;
			
			ДобавитьЦеныКаждойЗаписиПакетом(СтруктураДанныеМассив);
			
			// Заполняем цены
			Для Каждого СтруктураДанные Из СтруктураДанныеМассив Цикл 
				РезультатПоиска = Объект.Услуги.НайтиСтроки(Новый Структура("Номенклатура, Сотрудник", СтруктураДанные.Номенклатура, СтруктураДанные.Сотрудник));
				Для каждого СтрокаРезультат Из РезультатПоиска Цикл
					СтрокаРезультат.Цена = СтруктураДанные.Цена;
				КонецЦикла;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Сформируем надпись
	СтруктураНадписи = Новый Структура("ВидЦен", Объект.ВидЦен);
	Элементы.ЦеныИВалютаНадпись.Заголовок = СтроковыеФункцииКлиентСерверСтоматология.СформироватьНадписьЦеныИВалюта(СтруктураНадписи);

КонецПроцедуры

