// Процедура - Обработка команды "Удалить выбранный" табличного документа
// 
// 
Процедура КомандаГрафикПеридовРаботыТабДокУдалитьВыбранные(Команда)
	
	НомерОперации = НомерПоследнейОперацииВОчередиБуфера() + 1;
	ИмяОбласти = Элементы.ГрафикПериодовРаботыТабДок.ТекущаяОбласть.Имя; 
	СтруктураДанныхОбласти = ПолучитьДанныеВыделеннойОбластиГрафикПериодовРаботыТабДок(ИмяОбласти);
	
	СтартоваяДата = СтруктураДанныхОбласти.ВыбПериод;
	Если Не ЗначениеЗаполнено(СтартоваяДата) Тогда
		Возврат;
	КонецЕсли;     	
	
	Сотрудник = СтруктураДанныхОбласти.Сотрудник;
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда
		Возврат;
	КонецЕсли;  
	
	МассивИзмененныхДней = новый Массив;
	СтрокаБуфера = СтрокаБуфераФомированияПоСотрудникуДате(Сотрудник, СтартоваяДата);
	
	Если СтрокаБуфера <> Неопределено Тогда
		Если СтрокаБуфера.Операция = "Создать" Тогда
			МассивИзмененныхДней.Добавить(СтартоваяДата);
			БуферФормирования.Удалить(СтрокаБуфера);
		Иначе    				
			Данные = ПроверитьНаличиеПриема(СтрокаБуфера.Сотрудник, СтрокаБуфера.Дата, СтрокаБуфера.ИнтервалыРаботы, ОтборСтруктурнаяЕдиница);
			Если НЕ ЗначениеЗаполнено(Данные) Тогда
				МассивИзмененныхДней.Добавить(СтартоваяДата);
				СтрокаБуфера.Операция              = "Удалить";
				СтрокаБуфера.НомерОчередиОперации  = НомерОперации;
			Иначе   					
				Интервал = Формат(СтрокаБуфера.Дата, "ДЛФ=DD") + " с " + Формат(Данные.НачалоРаботы, "ДФ=HH:мм") + " по " + Формат(Данные.ОкончаниеРаботы, "ДФ=HH:мм");
				Текст = "В интервале " + Интервал + " созданы приемы. Удаление интервала невозможно.";
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Текст);
				Возврат;   					
			КонецЕсли;   				
		КонецЕсли;
	КонецЕсли;
	
	ОбновитьОтображениеПланирования(Ложь, Сотрудник, МассивИзмененныхДней);
	
КонецПроцедуры

