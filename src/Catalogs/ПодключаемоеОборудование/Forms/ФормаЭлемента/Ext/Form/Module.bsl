// Функция возвращает тип оборудования
//
Функция ПолучитьТипОборудованияВСтандарте(ТипОборудования)

	ТипСтандарта = Неопределено;

	Для каждого ИмяПеречисления Из Метаданные.Перечисления.ТипыПодключаемогоОборудования.ЗначенияПеречисления Цикл
		Если Строка(ТипОборудования) = ИмяПеречисления.Синоним Тогда
			ТипСтандарта = ИмяПеречисления.Комментарий;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат ТипСтандарта;

КонецФункции

&НаКлиенте
// Процедура - После подлючения отключения дисплея покупателя.
//
Процедура ПослеПодлюченияОтключенияДисплеяПокупателя(Результат, ДопПараметры) Экспорт
	
	Если Результат.Свойство("Результат") Тогда
		
		Если Результат.Результат = Ложь Тогда
			
			ДопОписаниеОшибки = "";
			Если ТипЗнч(Результат.ВыходныеПараметры) = Тип("Структура") И Результат.ВыходныеПараметры.Свойство("ОписаниеОшибки") Тогда
				ДопОписаниеОшибки = Результат.ВыходныеПараметры.ОписаниеОшибки	
			КонецЕсли;
			
			НаименованиеДействия = "подключить / отключить";
			Если ДопПараметры.Свойство("ЭтоПодключение") Тогда
				НаименованиеДействия = ?(ДопПараметры.ЭтоПодключение = Истина, "подключить", "отключить");			
			КонецЕсли;
			
			СообщениеПользователю = СтрШаблон("Не удалось %1 дисплей покупателя. %2", НаименованиеДействия, ДопОписаниеОшибки);	

			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеПользователю);
			
		Иначе
			
			НаименованиеДействия = "подключен / отключен";
			Если ДопПараметры.Свойство("ЭтоПодключение") Тогда
				НаименованиеДействия = ?(ДопПараметры.ЭтоПодключение = Истина, "подключен", "отключен");			
			КонецЕсли;
			
			СообщениеПользователю = СтрШаблон("Дисплей покупателя успешно %1.", НаименованиеДействия);	
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеПользователю);
			
		КонецЕсли;	

	КонецЕсли;
	
КонецПроцедуры

