	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда 
		ЭтоИнвентаризация = (ТипЗнч(Объект)=Тип("ДокументСсылка.ИнвентаризацияЗапасов"));
		Объект.ВидОперации = ?(ЭтоИнвентаризация, Объект.ВидОперации, Перечисления.ВидыОпераций.ПоСкладу);
		ЗаполнитьЗначенияСвойств(Объект, Объект.ДокументОснование, "Склад, СтруктурнаяЕдиница"+?(ЭтоИнвентаризация,",ВидОперации",""));
