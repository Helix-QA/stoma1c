&НаКлиенте
Процедура ПослеВопросаОПродолженииУдаленияПолиса(Ответ, ДопПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ИДСтрокиДанных = ИдентификаторСтрокиДанныхПоИмениЭлемента(ЭтаФорма.ТекущийЭлемент.Имя);	
		СтрокаДанных   = ЭтаФорма.ПолисыСуществующие.НайтиПоИдентификатору(ИДСтрокиДанных);
		
		Если СтрокаДанных <> Неопределено Тогда
			
			ОписаниеОшибки = "";
			
			ПолисУдален = УдалитьСтрокуПолисСервер(СтрокаДанных.Полис, ОписаниеОшибки);
			
			Если ПолисУдален Тогда
				МассивРодителей = Новый Массив();
				МассивРодителей.Добавить("ГруппаПолисыСуществующие");
				ОтображениеДополнительнойИнформации(МассивРодителей);
			Иначе 
				ПоказатьПредупреждение(,"Не удалось удалить полис. " + ОписаниеОшибки);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

