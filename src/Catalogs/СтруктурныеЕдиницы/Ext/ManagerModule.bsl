		Возврат СтруктЕдиница.ДоступныеКассы.ВыгрузитьКолонку("Касса"); 
		
	Иначе
		
		Кассы = Новый Массив;
		Кассы.Добавить(СтруктЕдиница.ОсновнаяКасса);
		
		Возврат Кассы;
		
	КонецЕсли;
	
