					// Добавим команду
					НоваяКоманда 							= Команды.Найти("Кнопка_ОткрытьКуратора_" + Индекс);
					Если НоваяКоманда = Неопределено Тогда 
						НоваяКоманда 						= Команды.Добавить("Кнопка_ОткрытьКуратора_" + Индекс);
						НоваяКоманда.Действие 				= "Подключаемый_ОткрытьКуратора";				
					КонецЕсли;
					НовыйЭлемент_Кнопка.ИмяКоманды          = НоваяКоманда.Имя;
					
				КонецЕсли;
				
				// Общая группа меток контрагента
				Группа_МеткиКонтрагента_НоваяСтрока                     = Элементы.Добавить("Группа_МеткиКонтрагента_НоваяСтрока" + Индекс, Тип("ГруппаФормы"), Группа_Контрагент_НоваяСтрока);
				Группа_МеткиКонтрагента_НоваяСтрока.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
				Группа_МеткиКонтрагента_НоваяСтрока.Отображение         = ОтображениеОбычнойГруппы.Нет;
				Группа_МеткиКонтрагента_НоваяСтрока.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная; 
				Группа_МеткиКонтрагента_НоваяСтрока.ОтображатьЗаголовок = Ложь;
				
				ОтобразитьМеткиКонтрагента(ЭлементСписка.Значение.КонтрагентСсылка,Группа_МеткиКонтрагента_НоваяСтрока,Индекс);
				
			КонецЕсли;	
			
			/////////////////////////// Отображение Полиса мед страхования
			
			МассивПолисовДействующие = Справочники.ПолисыМедицинскогоСтрахования.ПолучитьАктивныеПолисыКонтрагента(ЭлементСписка.Значение.КонтрагентСсылка, ТекущаяДатаСеанса(),,Ложь); 
			
			Индекс = ТаблицаПолисов.Количество();
			
			Для Каждого ЭлМассива Из МассивПолисовДействующие Цикл
				
				ЭлементГруппаМеткиПолис                     	= ЭтаФорма.Элементы.Добавить("ГруппаМеткиПолисИНФО_" + Индекс, Тип("ГруппаФормы"), ГруппаРазмещенияКонтрагентов);
				ЭлементГруппаМеткиПолис.Вид                 	= ВидГруппыФормы.ОбычнаяГруппа;
				ЭлементГруппаМеткиПолис.ОтображатьЗаголовок 	= Ложь;
				ЭлементГруппаМеткиПолис.Отображение         	= ОтображениеОбычнойГруппы.Нет;
				ЭлементГруппаМеткиПолис.Группировка         	= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
				ЭлементГруппаМеткиПолис.ГоризонтальныйИнтервал  = ИнтервалМеждуЭлементамиФормы.Нет;
				
				Если ЗначениеЗаполнено(ЭлМассива.СтраховаяКомпания.КраткоеНаименование) Тогда
					ФонМетки = ?(ЗначениеЗаполнено(ЭлМассива.СтраховаяКомпания.ЦветФонаМетки), ЗначениеИзСтрокиВнутр(ЭлМассива.СтраховаяКомпания.ЦветФонаМетки), WebЦвета.СеребристоСерый); 
					
					ЭлементГруппаМетка                      	= ЭтаФорма.Элементы.Добавить("ГруппаМеткаСКИНФО_" + Индекс, Тип("ГруппаФормы"), ЭлементГруппаМеткиПолис);
					ЭлементГруппаМетка.Вид                  	= ВидГруппыФормы.ОбычнаяГруппа;
					ЭлементГруппаМетка.ОтображатьЗаголовок  	= Ложь;
					ЭлементГруппаМетка.Отображение          	= ОтображениеОбычнойГруппы.Нет;
					ЭлементГруппаМетка.ЦветФона          		= ФонМетки;
					
					ДекорацияФормы_Метка = Элементы.Добавить("ДекорацияМеткаСКИНФО_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаМетка);
					ДекорацияФормы_Метка.Вид 				   = ВидДекорацииФормы.Надпись;
					ДекорацияФормы_Метка.Заголовок 			   = ЭлМассива.СтраховаяКомпания.КраткоеНаименование;
					ДекорацияФормы_Метка.АвтоМаксимальнаяШирина = Ложь;
					ДекорацияФормы_Метка.ЦветТекста             = ?(ЭлМассива.СтраховаяКомпания.ЦветТекстаБелый, Новый Цвет(255,255,255), Новый Цвет(77,77,77));
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ЭлМассива.Договор) 
					И ЗначениеЗаполнено(ЭлМассива.Договор.ПрограммаСтрахования) Тогда
					
					ДанныеПрограммыСтрахования = Справочники.ПрограммыСтрахования.ПолучитьТекстЦветФонаИТекста(ЭлМассива.Договор.ПрограммаСтрахования);
					
					ЭлементГруппаМетка                      	= ЭтаФорма.Элементы.Добавить("ГруппаМеткаДоговорИНФО_" + Индекс, Тип("ГруппаФормы"), ЭлементГруппаМеткиПолис);
					ЭлементГруппаМетка.Вид                  	= ВидГруппыФормы.ОбычнаяГруппа;
					ЭлементГруппаМетка.ОтображатьЗаголовок  	= Ложь;
					ЭлементГруппаМетка.Отображение          	= ОтображениеОбычнойГруппы.Нет;
					ЭлементГруппаМетка.ЦветФона          		= ДанныеПрограммыСтрахования.ЦветФона;
					
					ДекорацияФормы_Метка = Элементы.Добавить("ДекорацияМеткаДоговорИНФО_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаМетка);
					ДекорацияФормы_Метка.Вид 				   	= ВидДекорацииФормы.Надпись;
					ДекорацияФормы_Метка.Заголовок 			   	= ДанныеПрограммыСтрахования.Текст;
					ДекорацияФормы_Метка.АвтоМаксимальнаяШирина = Ложь;
					ДекорацияФормы_Метка.ЦветТекста             = ДанныеПрограммыСтрахования.ЦветТекста;
					
				КонецЕсли;  
				
				// Добавим декорацию перенести прием
				ДекорацияФормы_ПеренестиПрием 					= Элементы.Добавить("Декорация_ОткрытьПолис_" + Индекс, Тип("ДекорацияФормы"), ЭлементГруппаМеткиПолис);
				ДекорацияФормы_ПеренестиПрием.Вид 				= ВидДекорацииФормы.Надпись;
				ДекорацияФормы_ПеренестиПрием.Заголовок 		= ЭлМассива.Наименование; // + " №" + ЭлМассива.НомерПолиса + " с " + Формат(ЭлМассива.ДанаНачала,"ДФ=dd.MM.yyyy") + " по " + Формат(ЭлМассива.ДатаОкончания,"ДФ=dd.MM.yyyy"); 
				ДекорацияФормы_ПеренестиПрием.Гиперссылка 		= Истина;
				ДекорацияФормы_ПеренестиПрием.УстановитьДействие("Нажатие", "Подключаемый_ДекорацияФормы_ОткрытьПолис_Нажатие");
				ДекорацияФормы_ПеренестиПрием.АвтоМаксимальнаяШирина = Ложь;
				
				СсылкаНаПолис = ТаблицаПолисов.Добавить();
				СсылкаНаПолис.Полис = ЭлМассива;
				
				Индекс = Индекс + 1;
				
			КонецЦикла; 
			
		КонецЦикла; 	
		
		
		#Область Комментарии
		// Для Каждого ЭлементСписка Из СтруктураКлиента.СписокЗаявок Цикл
		//	Индекс 									= СтруктураКлиента.СписокЗаявок.Индекс(ЭлементСписка);
		//	// Добавим кнопку
		//	НовыйЭлемент_Кнопка 					= Элементы.Добавить("Кнопка_ОткрытьЗаявку_" + Индекс, Тип("КнопкаФормы"), ГруппаРазмещенияКонтрагентов);
		//	НовыйЭлемент_Кнопка.Заголовок 			= СокрЛП(ЭлементСписка.Значение.Наименование) + НСтр("ru = ' (Заявка)'; en = ' (Request)'");
		//	НовыйЭлемент_Кнопка.ЦветТекста 			= Новый Цвет(51, 51, 51);
		//	НовыйЭлемент_Кнопка.Шрифт 				= Новый Шрифт("Arial", 18);
		//	НовыйЭлемент_Кнопка.ОтображениеФигуры 	= ОтображениеФигурыКнопки.Нет;
