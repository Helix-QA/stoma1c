// Функция - Получить список исключенных свойств
//
// Параметры:
//  ВидЭлемента	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ПолучитьСписокИсключенныхСвойств(ВидЭлемента)
	
	СписокСвойств = "";
	
	Если ВидЭлемента = ВидПоляФормы.ПолеФлажка Тогда 
		СписокСвойств = "ПутьКДанным";
	ИначеЕсли ВидЭлемента = ВидПоляФормы.ПолеВвода Тогда 
		СписокСвойств = "ВыделенныйТекст, ПутьКДанным";
	ИначеЕсли ВидЭлемента = ВидГруппыФормы.ОбычнаяГруппа Тогда	
		СписокСвойств = "ПутьКДаннымЗаголовка";
	КонецЕсли;
	
	Возврат СписокСвойств;
	
КонецФункции

// Процедура - Установить действия для элемента
//
// Параметры:
//  НовыйЭлемент - 	 - 
//  ЭлементФормы - 	 - 
//  ТипЭлемента	 - 	 - 
//
Процедура УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, ТипЭлемента)
	
	Если ТипЭлемента = Тип("ДекорацияФормы") Тогда
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("Нажатие");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("Нажатие", ИмяОбработчикаСобытия);	
		КонецЕсли;
	ИначеЕсли ТипЭлемента = Тип("ПолеФормы") Тогда	
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("ПриИзменении");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("ПриИзменении", ИмяОбработчикаСобытия);	
		КонецЕсли;
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("НачалоВыбора");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("НачалоВыбора", ИмяОбработчикаСобытия);	
		КонецЕсли;
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("НачалоВыбораИзСписка");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("НачалоВыбораИзСписка", ИмяОбработчикаСобытия);	
		КонецЕсли;		
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("Очистка");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("Очистка", ИмяОбработчикаСобытия);	
		КонецЕсли;
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("Открытие");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("Открытие", ИмяОбработчикаСобытия);	
		КонецЕсли;		
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("ОбработкаВыбора");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("ОбработкаВыбора", ИмяОбработчикаСобытия);	
		КонецЕсли;		
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("ОбработкаВыбора");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("ОбработкаВыбора", ИмяОбработчикаСобытия);	
		КонецЕсли;		
	КонецЕсли;
	        
КонецПроцедуры

// Процедура - Определить путь к данным настроек каналов
//
// Параметры:
//  Форма			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//  ПутьКДанным		 - 	 - 
//  ИмяРеквизита	 - 	 - 
//
Процедура ОпределитьПутьКДаннымНастроекКаналов(Форма, ИндексСтроки, СтрокаТаблицы, ПутьКДанным, ИмяРеквизита)
	
	СтруктурнаяЕдиница = Неопределено;
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		СтрокаТаблицы.Свойство("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
		СтруктурнаяЕдиница = ?(ЗначениеЗаполнено(СтруктурнаяЕдиница), СтруктурнаяЕдиница, Форма.ТекущаяСтруктурнаяЕдиница);
		МассивСтрокНастроекКаналов = Форма.МоделируемыеНастройкиКаналовУведомлений.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница", СтрокаТаблицы.ИдентификаторДействия, СтруктурнаяЕдиница));
		Если НЕ МассивСтрокНастроекКаналов.Количество() = 0 Тогда 
			ПутьКДанным = "МоделируемыеНастройкиКаналовУведомлений[" + Формат(Форма.МоделируемыеНастройкиКаналовУведомлений.Индекс(МассивСтрокНастроекКаналов[0]), "ЧГ=0") + "]." + ИмяРеквизита;
		КонецЕсли;	
	Иначе
		СтрокаТаблицыПлана = Форма.Объект.Действия.Получить(ИндексСтроки);
		МассивСтрокНастроекКаналов = Форма.МоделируемыеНастройкиКаналовУведомлений.НайтиСтроки(Новый Структура("ИдентификаторДействия, СтруктурнаяЕдиница", СтрокаТаблицыПлана.ИдентификаторДействия, Форма.ТекущаяСтруктурнаяЕдиница));
		Если НЕ МассивСтрокНастроекКаналов.Количество() = 0 Тогда 
			ПутьКДанным = "МоделируемыеНастройкиКаналовУведомлений[" + Формат(Форма.МоделируемыеНастройкиКаналовУведомлений.Индекс(МассивСтрокНастроекКаналов[0]), "ЧГ=0") + "]." + ИмяРеквизита;
		КонецЕсли;				
	КонецЕсли;
	
КонецПроцедуры

