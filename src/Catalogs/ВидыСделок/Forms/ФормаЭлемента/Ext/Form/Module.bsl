&НаСервере
// Процедура - Установить видимость элементам списка структурных единиц
//
// Параметры:
//  НачатьДобавление - 	 - 
//
Процедура УстановитьВидимостьЭлементамСпискаСтруктурныхЕдиниц(НачатьДобавление = Ложь)
	
	Если РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" Тогда 
		Элементы.СтраницыДоступностиПоСтруктурнымЕдиницам.ТекущаяСтраница = Элементы.ГруппаСтруктурнаяЕдиница;
	Иначе 
		Элементы.СтраницыДоступностиПоСтруктурнымЕдиницам.ТекущаяСтраница = Элементы.ГруппаСтруктурныеЕдиницыПрименения;
	КонецЕсли;	
	
	Если НачатьДобавление Тогда 
		Элементы.ГруппаПодсказка.Видимость = Ложь;
	Иначе 	
		Элементы.ГруппаПодсказка.Видимость = НЕ РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" И Объект.СтруктурныеЕдиницыПрименения.Количество() = 0;	
	КонецЕсли;	
	Элементы.СтруктурныеЕдиницыПрименения.Видимость = НЕ РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" И НЕ Элементы.ГруппаПодсказка.Видимость;
	Элементы.КнопкаДобавить.Видимость 				= НЕ РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" И НЕ Элементы.ГруппаПодсказка.Видимость;
	Элементы.УстановитьПоУмолчанию.Видимость 		= НЕ РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" И НЕ Элементы.ГруппаПодсказка.Видимость;
	
КонецПроцедуры

&НаСервере
// Процедура - Установить видимость элементам списка статусов пациентов
//
// Параметры:
//  НачатьДобавление - 	 - 
//
Процедура УстановитьВидимостьЭлементамСпискаСтатусовПациентов(НачатьДобавление = Ложь)
	
	Если РежимОтображенияСпискаСтатусовПациента = "Поле" Тогда 
		Элементы.СтраницыДоступностиПоСтатусамПациентов.ТекущаяСтраница = Элементы.ГруппаСтатусПациента;
	Иначе 
		Элементы.СтраницыДоступностиПоСтатусамПациентов.ТекущаяСтраница = Элементы.ГруппаСтатусыПациентовПрименения;
	КонецЕсли;	
	
	Если НачатьДобавление Тогда 
		Элементы.ГруппаПодсказкаДляПанелиСтатусовПациентов.Видимость = Ложь;
	Иначе 	
		Элементы.ГруппаПодсказкаДляПанелиСтатусовПациентов.Видимость = НЕ РежимОтображенияСпискаСтатусовПациента = "Поле" И Объект.СтатусыПациентовПрименения.Количество() = 0;	
	КонецЕсли;	
	Элементы.СтатусыПациентовПрименения.Видимость 	= НЕ РежимОтображенияСпискаСтатусовПациента = "Поле" И НЕ Элементы.ГруппаПодсказкаДляПанелиСтатусовПациентов.Видимость;
	Элементы.КнопкаДобавитьСтатус.Видимость 		= НЕ РежимОтображенияСпискаСтатусовПациента = "Поле" И НЕ Элементы.ГруппаПодсказкаДляПанелиСтатусовПациентов.Видимость;
	Элементы.УстановитьПоУмолчаниюСтатусы.Видимость = Ложь; //НЕ РежимОтображенияСпискаСтатусовПациента = "Поле" И НЕ Элементы.ГруппаПодсказкаДляПанелиСтатусовПациентов.Видимость;
	
КонецПроцедуры

&НаСервере
// Процедура - Инициализировать список структурных единиц
//
Процедура ИнициализироватьСписокСтруктурныхЕдиниц()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	СтруктурныеЕдиницы.Ссылка КАК СтруктурнаяЕдиница
	               |ИЗ
	               |	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	               |ГДЕ
	               |	СтруктурныеЕдиницы.ПометкаУдаления = ЛОЖЬ
	               |	И СтруктурныеЕдиницы.ЭтоГруппа = ЛОЖЬ";
	
	МассивСтруктурныхЕдиниц = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтруктурнаяЕдиница");
	
	СписокДоступныхСтруктурныхЕдиниц.ЗагрузитьЗначения(МассивСтруктурныхЕдиниц);
	МассивОтбираемыхСЕ = Новый Массив;
	
	Если РежимОтображенияСпискаСтруктурныхЕдиниц = "Поле" И Объект.СтруктурныеЕдиницыПрименения.Количество() = 0 Тогда
		НоваяСтрока = Объект.СтруктурныеЕдиницыПрименения.Добавить();
	КонецЕсли;
	
	Для Каждого ЭлементСписка Из СписокДоступныхСтруктурныхЕдиниц Цикл
		Если Объект.СтруктурныеЕдиницыПрименения.НайтиСтроки(Новый Структура("СтруктурнаяЕдиница", ЭлементСписка.Значение)).Количество() = 0 Тогда 
			МассивОтбираемыхСЕ.Добавить(ЭлементСписка.Значение);
		КонецЕсли;	
		Элементы.СтруктурнаяЕдиница.СписокВыбора.Добавить(ЭлементСписка.Значение, , ?(Объект.СтруктурныеЕдиницыПрименения.Количество() > 0, Объект.СтруктурныеЕдиницыПрименения[0].СтруктурнаяЕдиница = ЭлементСписка.Значение, Ложь));
		//Элементы.СтруктурныеЕдиницыПримененияСтруктурнаяЕдиница.СписокВыбора.Добавить(ЭлементСписка.Значение);		
	КонецЦикла;
	
	Элементы.СтруктурнаяЕдиница.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), "В любой клинике", ?(Объект.СтруктурныеЕдиницыПрименения.Количество() > 0, Объект.СтруктурныеЕдиницыПрименения[0].СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), Ложь));
	
	Массив = Новый Массив;
	Массив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивОтбираемыхСЕ)));
	
	Элементы.СтруктурныеЕдиницыПримененияСтруктурнаяЕдиница.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
	
КонецПроцедуры

&НаСервере
// Процедура - Инициализировать список статусов пациентов
//
Процедура ИнициализироватьСписокСтатусовПациентов()
	
	ВидСделок__НовыеПациенты 		= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.НовыеПациенты");
	ВидСделок__ПостоянныеПациенты 	= ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыСделок.ПостоянныеПациенты");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭтоПредопределенныеДанные_НовыеПациенты"		, ВидСделок__НовыеПациенты 		= Объект.Ссылка);
	Запрос.УстановитьПараметр("ЭтоПредопределенныеДанные_ПостоянныеПациенты", ВидСделок__ПостоянныеПациенты = Объект.Ссылка);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	СтатусыКонтрагентов.Ссылка КАК СтатусПациента
	               |ИЗ
	               |	Перечисление.СтатусыКонтрагентов КАК СтатусыКонтрагентов
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА &ЭтоПредопределенныеДанные_НовыеПациенты
	               |				ТОГДА СтатусыКонтрагентов.Ссылка В (ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный), ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Первичный), ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Отказ))
	               |			КОГДА &ЭтоПредопределенныеДанные_ПостоянныеПациенты
	               |				ТОГДА СтатусыКонтрагентов.Ссылка В (ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.НеВернувшийся), ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Постоянный))
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СтатусыКонтрагентов.Порядок";
	
	МассивСтатусовПациентов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СтатусПациента");
	
	СписокДоступныхСтатусовПациентов.ЗагрузитьЗначения(МассивСтатусовПациентов);
	МассивОтбираемыхСтатусов = Новый Массив;
	
	Если РежимОтображенияСпискаСтатусовПациента = "Поле" И Объект.СтатусыПациентовПрименения.Количество() = 0 Тогда
		НоваяСтрока = Объект.СтатусыПациентовПрименения.Добавить();
	КонецЕсли;
	
	Для Каждого ЭлементСписка Из СписокДоступныхСтатусовПациентов Цикл
		Если Объект.СтатусыПациентовПрименения.НайтиСтроки(Новый Структура("СтатусПациента", ЭлементСписка.Значение)).Количество() = 0 Тогда 
			МассивОтбираемыхСтатусов.Добавить(ЭлементСписка.Значение);
		КонецЕсли;	
		Элементы.СтатусПациента.СписокВыбора.Добавить(ЭлементСписка.Значение, Перечисления.СтатусыКонтрагентов.ПолучитьПредставлениеСтатусаПациентаДляСпискаВыбора(ЭлементСписка.Значение), ?(Объект.СтатусыПациентовПрименения.Количество() > 0, Объект.СтатусыПациентовПрименения[0].СтатусПациента = ЭлементСписка.Значение, Ложь));
	КонецЦикла;
	
	Элементы.СтатусПациента.СписокВыбора.Добавить(Перечисления.СтатусыКонтрагентов.ПустаяСсылка(), "Пациентов с любым статусом", ?(Объект.СтатусыПациентовПрименения.Количество() > 0, Объект.СтатусыПациентовПрименения[0].СтатусПациента = Перечисления.СтатусыКонтрагентов.ПустаяСсылка(), Ложь));
	
	Массив = Новый Массив;
	Массив.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивОтбираемыхСтатусов)));
	
	Элементы.СтатусыПациентовПримененияСтатусПациента.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
	
КонецПроцедуры

&НаСервере
// Процедура, создает элементы списка точек доступа.
//
Процедура СоздатьЭлементыТаблицы()
	
	Индекс = 0;
	Для Каждого СтрокаТЧ из ЭтотОбъект.ЭтапыСделок Цикл
		СоздатьСтрокуЭлементовЭтапыСделок(Индекс);
		Индекс = Индекс + 1;
	КонецЦикла; 
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
// Процедура, создает строку элементов списка точек доступа.
//
Процедура СоздатьСтрокуЭлементовЭтапыСделок(Индекс)
	
	ГруппаНовыхЭл                       	= Элементы.Добавить("СтрокаТаблицы_" + Индекс, Тип("ГруппаФормы"), Элементы.ГруппаЭтапы);
	ГруппаНовыхЭл.Вид                  	 	= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНовыхЭл.Группировка           	= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаНовыхЭл.Отображение           	= ОтображениеОбычнойГруппы.Нет;
	ГруппаНовыхЭл.ОтображатьЗаголовок   	= Ложь;
	ГруппаНовыхЭл.ГоризонтальныйИнтервал	= ИнтервалМеждуЭлементамиФормы.Половинный;
	ГруппаНовыхЭл.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
	
	// Создаем заглушку = номер этапа.
	ДекорацияФормы_Заглушка = Элементы.Добавить("Заглушка_" + Индекс, Тип("ДекорацияФормы"), ГруппаНовыхЭл);
	ДекорацияФормы_Заглушка.Вид 				   = ВидДекорацииФормы.Надпись;
	ДекорацияФормы_Заглушка.Заголовок 			   = Индекс + 1;
	ДекорацияФормы_Заглушка.АвтоМаксимальнаяШирина = Ложь;
	ДекорацияФормы_Заглушка.МаксимальнаяШирина     = 4;
	ДекорацияФормы_Заглушка.Ширина                 = 4;
	//ДекорацияФормы_Заглушка.Шрифт				   = Новый Шрифт(11);
	ДекорацияФормы_Заглушка.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
	ДекорацияФормы_Заглушка.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	
	КомандаКнопки = ЭтаФорма.Команды.Найти("КомандаВыбратьЦвет_" + Индекс);
	
	Если КомандаКнопки = Неопределено Тогда
		
		// Создаем команду кнопки.
		КомандаКнопки 	       = ЭтаФорма.Команды.Добавить("КомандаВыбратьЦвет_" + Индекс);
		КомандаКнопки.Действие = "ВыбратьЦвет";

	КонецЕсли;
		
	// Создаем кнопку выбора цвета.
	КнопкаФормы_Этап_Цвет = Элементы.Добавить("ИзменитьЦвет_" + Индекс, Тип("КнопкаФормы"), ГруппаНовыхЭл);
	КнопкаФормы_Этап_Цвет.Отображение 	    = ОтображениеКнопки.Картинка;	
	КнопкаФормы_Этап_Цвет.ИмяКоманды  	    = КомандаКнопки.Имя;
	КнопкаФормы_Этап_Цвет.ЦветФона 	  	    = ?(ЗначениеЗаполнено(ЭтапыСделок[Индекс].Цвет), ЗначениеИзСтрокиВнутр(ЭтапыСделок[Индекс].Цвет), Новый Цвет());
	КнопкаФормы_Этап_Цвет.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
	
	// Всплывающая группа палитры цветов.
	ГруппаВсплывающая = Элементы.Добавить("ГруппаВсплывающая_" + Индекс, Тип("ГруппаФормы"), ГруппаНовыхЭл);
	ГруппаВсплывающая.Вид                   = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВсплывающая.Поведение			    = ПоведениеОбычнойГруппы.Всплывающая;
	ГруппаВсплывающая.Заголовок			    = " ";	
	ГруппаВсплывающая.Группировка           = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаВсплывающая.Отображение           = ОтображениеОбычнойГруппы.Нет;
	ГруппаВсплывающая.ШрифтЗаголовка	    = Новый Шрифт(,1);
	ГруппаВсплывающая.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
	
	// Создаем заглушку, для постоянного отображения всплывающей группы.
	ДекорацияФормы_Заглушка = Элементы.Добавить("ЗаглушкаПромежуток_" + Индекс, Тип("ДекорацияФормы"), ГруппаВсплывающая);
	ДекорацияФормы_Заглушка.Вид 			= ВидДекорацииФормы.Надпись;
	ДекорацияФормы_Заглушка.ЦветФона 		= Новый Цвет(255, 255, 255);
	
	// Создаем поле ввода наименования этапа.
	НовыйЭтап                    			= Элементы.Добавить("Наименование_" + Индекс, Тип("ПолеФормы"), ГруппаНовыхЭл);
	НовыйЭтап.Вид                			= ВидПоляФормы.ПолеВвода;
	НовыйЭтап.ПоложениеЗаголовка 			= ПоложениеЗаголовкаЭлементаФормы.Нет;		
	НовыйЭтап.ПодсказкаВвода     			= "Наименование";		
	НовыйЭтап.ПутьКДанным        			= "ЭтапыСделок[" + Индекс +"].Наименование";		
	НовыйЭтап.УстановитьДействие("ПриИзменении", "ДобавитьНовыйЭтап");
	НовыйЭтап.МаксимальнаяШирина            = 42;
	НовыйЭтап.АвтоМаксимальнаяШирина        = Ложь;
	
	// Группа кнопок вверх/вниз.
	ГруппаВверхВниз                       	= Элементы.Добавить("ГруппаВверхВниз_" + Индекс, Тип("ГруппаФормы"), ГруппаНовыхЭл);
	ГруппаВверхВниз.Вид                  	= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаВверхВниз.Группировка           	= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаВверхВниз.Отображение           	= ОтображениеОбычнойГруппы.Нет;
	ГруппаВверхВниз.ГоризонтальныйИнтервал  = ИнтервалМеждуЭлементамиФормы.Нет;
	ГруппаВверхВниз.ОтображатьЗаголовок		= Ложь;
	ГруппаВверхВниз.Доступность 			= НЕ ЗаблокироватьИзменениеЭтапов;
	
	// Создаем кнопку вверх.
	КнопкаПереместитьВверх                  = Элементы.Добавить("СтрокуТаблицыВверх_" + Индекс, Тип("КнопкаФормы"), ГруппаВверхВниз);
	КнопкаПереместитьВверх.Отображение     	= ОтображениеКнопки.Картинка;
	КнопкаПереместитьВверх.ОтображениеФигуры= ОтображениеФигурыКнопки.Нет;
	КнопкаПереместитьВверх.ИмяКоманды      	= "ПереместитьВверх";  
	КнопкаПереместитьВверх.Доступность 		= НЕ ЗаблокироватьИзменениеЭтапов;
	
	// Создаем кнопку вниз.
	КнопкаПереместитьВниз                 	= Элементы.Добавить("СтрокуТаблицыВниз_" + Индекс, Тип("КнопкаФормы"), ГруппаВверхВниз);
	КнопкаПереместитьВниз.Отображение     	= ОтображениеКнопки.Картинка;
	КнопкаПереместитьВниз.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
	КнопкаПереместитьВниз.ИмяКоманды      	= "ПереместитьВниз";  
	КнопкаПереместитьВниз.Доступность 		= НЕ ЗаблокироватьИзменениеЭтапов;
	
	// Создаем кнопку удаления.
	КнопкаУдаления                  		= Элементы.Добавить("УдалитьСтрокуТаблицы_" + Индекс, Тип("КнопкаФормы"), ГруппаНовыхЭл);
	КнопкаУдаления.Отображение     	    	= ОтображениеКнопки.Картинка;
	КнопкаУдаления.ОтображениеФигуры 		= ОтображениеФигурыКнопки.Нет;
	КнопкаУдаления.ИмяКоманды      	    	= "УдалитьСтрокуТаблицы";    	
	КнопкаУдаления.Доступность 				= НЕ ЗаблокироватьИзменениеЭтапов;
	
КонецПроцедуры

&НаСервере
// Процедура, устанавливает видимость динамических элементов.
//
Процедура УстановитьВидимость()
	
	Индекс = 0;
	Для Каждого СтрокаТЧ из ЭтапыСделок Цикл		
		
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Наименование) И НЕ ЗначениеЗаполнено(СтрокаТЧ.Ссылка) Тогда
			
			Элементы["ИзменитьЦвет_" + Индекс].Доступность 		 = Ложь;
			Элементы["ИзменитьЦвет_" + Индекс].ЦветФона 		 = Новый Цвет(255,255,255);
			Элементы["ИзменитьЦвет_" + Индекс].ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
			
			Элементы["УдалитьСтрокуТаблицы_" + Индекс].Видимость = Ложь;
			Элементы["СтрокуТаблицыВверх_" + Индекс].Видимость   = Ложь;			
			Элементы["СтрокуТаблицыВниз_" + Индекс].Видимость 	 = Ложь;
			
			Элементы["Заглушка_" + Индекс].Заголовок 	 		 = "";
			Элементы["Заглушка_" + Индекс].Ширина	 	 		 = 3;
			Элементы["Заглушка_" + Индекс].МаксимальнаяШирина	 = 3;

		Иначе	
			
			Элементы["ИзменитьЦвет_" + Индекс].Доступность 		 = Истина;
			Элементы["ИзменитьЦвет_" + Индекс].ОтображениеФигуры = ОтображениеФигурыКнопки.Авто;
			
			Элементы["ИзменитьЦвет_" + Индекс].Видимость 		 = Истина;
			Элементы["УдалитьСтрокуТаблицы_" + Индекс].Видимость = Истина;
			Элементы["СтрокуТаблицыВверх_" + Индекс].Видимость 	 = Истина;			
			Элементы["СтрокуТаблицыВниз_" + Индекс].Видимость 	 = Истина;
			
			Элементы["Заглушка_" + Индекс].Заголовок 	 		 = Индекс + 1;
			Элементы["Заглушка_" + Индекс].Ширина	 	 		 = 2;
			Элементы["Заглушка_" + Индекс].МаксимальнаяШирина	 = 2;

		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Процедура, удаляет элементы формы связанные со списком точек доступа.
//
Процедура УдалитьЭлементыТаблицы(ИндексСтроки)
	
	СтрокаДанных = ЭтапыСделок[ИндексСтроки];	
	Если Не СтрокаДанных = Неопределено Тогда 		
		
		Индекс = 0;
		Для Каждого СтрокаТЧ Из ЭтапыСделок Цикл
			Элементы.Удалить(Элементы["УдалитьСтрокуТаблицы_" + Индекс]);	
			Элементы.Удалить(Элементы["СтрокаТаблицы_" + Индекс]);
			Индекс = Индекс + 1;              
		КонецЦикла;	
		
		Если Не СтрокаДанных.Ссылка.Пустая() Тогда
			ОбъектСсылка = СтрокаДанных.Ссылка.ПолучитьОбъект();
			ОбъектСсылка.ПометкаУдаления = Истина;
			ОбъектСсылка.Записать();
		КонецЕсли;
		
		ЭтапыСделок.Удалить(СтрокаДанных);		
		СоздатьЭлементыТаблицы(); 
		
	КонецЕсли;                            
	
КонецПроцедуры

&НаСервере
// Процедура - Удалить причину отказа на сервере
//
// Параметры:
//  ИндексСтроки - 	 - 
//
Процедура УдалитьПричинуОтказаНаСервере(ИндексСтроки)
	
	СтрокаДанных = Объект.ПричиныОтказов.Получить(ИндексСтроки);	
	ГруппаРазмещенияПричинОтказа = Элементы.Найти("ГруппаЭтапаИПричинОтказов");
	Если НЕ ГруппаРазмещенияПричинОтказа = Неопределено Тогда 
		//УдалитьЭлементыГруппы(ГруппаРазмещенияПричинОтказа);
		Объект.ПричиныОтказов.Удалить(СтрокаДанных);		
        ОтобразитьДопустимыеПричиныОтказа();
    КонецЕсли;
		
КонецПроцедуры

&НаСервере
// Процедура - Удалить элементы группы
//
// Параметры:
//  Форма				 - 	 - 
//  РодительскаяГруппа	 - 	 - 
//
Процедура УдалитьЭлементыГруппы(РодительскаяГруппа)
	
	УдаляемыеЭлементы = Новый Массив;
	
	Для Каждого ГруппаЭлементов Из Элементы[РодительскаяГруппа.Имя].ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ГруппаЭлементов);
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
// Функция, возвращает идентификатор строки данных по имени элемента.
//  
// Параметры:
//	 ИмяЭлемента 	- Строка - имя элемента.
//   ИндексЭлемента - Булево - признак чего получаем индекс (Элемента или Виджета).
//
Функция ПолучитьИндексСтроки(ИмяЭлемента, ИндексЭлемента = Истина)
	
	Если ИндексЭлемента Тогда
		НомерСимвола = СтрНайти(ИмяЭлемента,"_");
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	Иначе
		НомерСимвола = СтрНайти(ИмяЭлемента,"_", НаправлениеПоиска.СКонца);
		Возврат Число(Сред(ИмяЭлемента, НомерСимвола + 1, 1));
	КонецЕсли;
	 	
КонецФункции

&НаСервере
// Процедура, обновить динамические элементы.
//
Процедура ОбновитьДинамическиеЭлементы()
	
	ОчиститьДинамическиеЭлементы();
	СоздатьЭлементыТаблицы();

КонецПроцедуры

&НаСервере
// Процедура, очищает динамические элементы.
//
Процедура ОчиститьДинамическиеЭлементы()
	
	ПереместитьПалитруКРодителю();
	
	ЭлементыГруппы = Элементы.ГруппаЭтапы.ПодчиненныеЭлементы;
	КоличествоЭлементов = ЭлементыГруппы.Количество();
	
	Пока КоличествоЭлементов <> 0  Цикл
		
		Элементы.Удалить(ЭлементыГруппы[0]);
		КоличествоЭлементов = КоличествоЭлементов - 1;
			
	КонецЦикла; 
		
КонецПроцедуры

&НаКлиенте
// Процедура, добавить этап на сервере.
//
Процедура ДобавитьНовыйЭтапНаСервере()
	
	НоваяСтрока  = ЭтапыСделок.Добавить();	
	ИндексСтроки = ЭтапыСделок.Количество() - 1;
	
	СоздатьСтрокуЭлементовЭтапыСделок(ИндексСтроки);
	
	ЭтаФорма.ТекущийЭлемент = Элементы["Наименование_" + ИндексСтроки];
	
	УстановитьВидимость();

КонецПроцедуры

&НаСервере
// Процедура, изменить этап на сервере.
//
Процедура ИзменитьЦветЭтапаНаСервере(ИмяКоманды, Цвет)
	
	ИндексСтроки = ПолучитьИндексСтроки(Элементы.ВсплывающаяПалтира.Родитель.Имя);
	Этап 	  	 = ЭтаФорма.ЭтапыСделок[ИндексСтроки];
	Этап.Цвет 	 = ЗначениеВСтрокуВнутр(Цвет);
	Элементы["ИзменитьЦвет_" + ИндексСтроки].ЦветФона = Цвет;
	
	ПереместитьПалитруКРодителю();
	
	ИндексПоследнейСтроки   = ЭтапыСделок.Количество() - 1;
	ЭтаФорма.ТекущийЭлемент = Элементы["Наименование_" + ИндексПоследнейСтроки]; 
	
КонецПроцедуры

&НаКлиенте
// Функция - Добавить новую причину отказа
// 
// Возвращаемое значение:
//   - 
//
Функция ДобавитьНовуюПричинуОтказа()
	
	НоваяСтрока  = Объект.ПричиныОтказов.Добавить();	
	ИндексСтроки = Объект.ПричиныОтказов.Индекс(НоваяСтрока);
	
	Возврат ИндексСтроки;
	
КонецФункции












