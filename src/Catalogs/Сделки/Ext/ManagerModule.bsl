		//Если ТаблицаДоступныхВидовСделокПоСЕ.Количество() = 0 И ТаблицаДоступныхВидовСделокПоСтатусам.Количество() = 0 Тогда 
		//	ШаблонКомментария 	= НСтр("ru = 'Создание сделки с данным видом: ""%1"" запрещено! Проверьте заполнение данного вида сделки или обратитесь к администратору базы данных!'");
		//	Комментарий 		= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонКомментария, СокрЛП(Строка(ГенерируемаяСделка.ВидСделки)));
		Если ТаблицаДоступныхВидовСделокПоСЕ.Количество() = 0 Тогда 
