
#Область ОбработчикиСобытийФормы

&НаСервере
// Процедура - При создании на сервере
// 
// Параметры:
//  Отказ				 - 	 - 
//  СтандартнаяОбработка - 		 - 
// 
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИзменениеДоступностиКомментария = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("АдминистраторСистемы");
	
	ТекущаяСтраница = 0;
	ОценокНаСтраницу = 12;
	
	Если Параметры.Свойство("Контрагент") И ЗначениеЗаполнено(Параметры.Контрагент) Тогда
		
		Контрагент = Параметры.Контрагент; 
		ЭтаФорма.Элементы.ДекорацияСотрудник.Видимость = Истина;
		ТаблицаОценок.Загрузить(ПолучитьОценки(,Параметры.Контрагент));
		Если ТаблицаОценок.Количество() > ОценокНаСтраницу Тогда
			КоличествоСтраниц = ПолучитьКоличествоСтраниц(ТаблицаОценок.Количество(), ОценокНаСтраницу);
			ПерейтиНаСтраницу(1);
		Иначе
			СформироватьБлокОценкиИОтзывы();
		КонецЕсли;
		                                                    
	ИначеЕсли Параметры.Свойство("Сотрудник") И ЗначениеЗаполнено(Параметры.Сотрудник) Тогда
		
		Сотрудник = Параметры.Сотрудник; 
		ЭтаФорма.Элементы.ДекорацияКонтрагент.Видимость = Истина;
		ТаблицаОценок.Загрузить(ПолучитьОценки(Параметры.Сотрудник));
		Если ТаблицаОценок.Количество() > ОценокНаСтраницу Тогда
			КоличествоСтраниц = ПолучитьКоличествоСтраниц(ТаблицаОценок.Количество(), ОценокНаСтраницу);
			ПерейтиНаСтраницу(1);
		Иначе
			СформироватьБлокОценкиИОтзывы();
		КонецЕсли;
		
	Иначе
		
		ВыводитьВсе = Истина;
		ЭтаФорма.Элементы.ДекорацияСотрудник.Видимость  = Истина;
		ЭтаФорма.Элементы.ДекорацияКонтрагент.Видимость = Истина;
		ТаблицаОценок.Загрузить(ПолучитьОценки());
		Если ТаблицаОценок.Количество() > ОценокНаСтраницу Тогда
			КоличествоСтраниц = ПолучитьКоличествоСтраниц(ТаблицаОценок.Количество(), ОценокНаСтраницу);
			ПерейтиНаСтраницу(1);
		Иначе
			СформироватьБлокОценкиИОтзывы();
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработкаСобытийЭлементовФормы

&НаКлиенте
// Процедура - Процедура обработки нажатия динамической кнопки
// 
// Параметры:
//  Элемент	 - 	 - 
// 
Процедура ПроцедураОбработкиНажатияДинамическойКнопки(Элемент)
	
	Если Найти(Элемент.Имя, "Прием") <> 0 Тогда
		
		Идентификатор       = Число(Сред(Элемент.Имя, 14)) - 1;
		СтрокаТаблицаОценок = ЭтотОбъект.ТаблицаОценок[Идентификатор];
		
		Если СтрокаТаблицаОценок <> Неопределено Тогда	
			ДокументСсылка = СтрокаТаблицаОценок.Прием;
			ПоказатьЗначение(, ДокументСсылка);		
		КонецЕсли;	
		
	ИначеЕсли Найти(Элемент.Имя, "Сотрудник") <> 0 Тогда
		
		Идентификатор       = Число(Сред(Элемент.Имя, 18)) - 1;
		СтрокаТаблицаОценок = ЭтотОбъект.ТаблицаОценок[Идентификатор];
		
		Если СтрокаТаблицаОценок <> Неопределено Тогда
			Сотрудник = СтрокаТаблицаОценок.Сотрудник;
			ПоказатьЗначение(, Сотрудник);
		КонецЕсли;
		
	ИначеЕсли Найти(Элемент.Имя, "Контрагент") <> 0 Тогда
		
		Идентификатор       = Число(Сред(Элемент.Имя, 19)) - 1;
		СтрокаТаблицаОценок = ЭтотОбъект.ТаблицаОценок[Идентификатор];
		
		Если СтрокаТаблицаОценок <> Неопределено Тогда
			Контрагент	    = СтрокаТаблицаОценок.Контрагент;
			ПоказатьЗначение(, Контрагент);
		КонецЕсли;
		
	ИначеЕсли Найти(Элемент.Имя, "ДоступностьКомментария") Тогда
		
		Идентификатор = Число(Сред(Элемент.Имя, 31)) - 1;
		СтрокаТаблицаОценок = ЭтотОбъект.ТаблицаОценок[Идентификатор];
		Структураотбора = Новый Структура("Прием, Сотрудник, Контрагент", СтрокаТаблицаОценок.Прием, СтрокаТаблицаОценок.Сотрудник, СтрокаТаблицаОценок.Контрагент);
		Если СтрокаТаблицаОценок <> Неопределено Тогда
			Для Каждого СтрокаТЧ Из ТаблицаОценок.НайтиСтроки(Структураотбора) Цикл
				СтрокаТЧ.Деактивирован = Не СтрокаТЧ.Деактивирован;
			КонецЦикла;
			Кнопка = Элементы.Найти(СтрЗаменить(Элемент.Имя, "Команда", "Кнопка"));
			Кнопка.Картинка = ?(СтрокаТаблицаОценок.Деактивирован, БиблиотекаКартинок.ПоказатьСкрытыеЭлементы, БиблиотекаКартинок.КомментарийДоступен);
			ИзменитьПодсказкуКнопки(Кнопка.Имя, СтрокаТаблицаОценок.Деактивирован);
			Если СтрокаТаблицаОценок.Деактивирован Тогда
				СкрытьПоказатьКомментарий("ГруппаДанныеОценкиСотрудникаГоризонтальная" + (Идентификатор + 1), WebЦвета.СветлоСерый);
			Иначе 
				СкрытьПоказатьКомментарий("ГруппаДанныеОценкиСотрудникаГоризонтальная" + (Идентификатор + 1), Новый Цвет(51,51,51));
			КонецЕсли;
			Для Каждого СтрокаТЧ Из ТаблицаОценок.НайтиСтроки(Структураотбора) Цикл
				Идентификатор = ТаблицаОценок.Индекс(СтрокаТЧ);
				ИзменитьДоступностьКомментария(Идентификатор);
			КонецЦикла;
		КонецЕсли;                                                     
	ИначеЕсли Найти(Элемент.Имя, "ЭлементНавигации") Тогда
		
		Если Элемент.Имя = "КомандаЭлементНавигации_Назад" Тогда
			ПерейтиНаСтраницу(ТекущаяСтраница - 1);
		ИначеЕсли Элемент.Имя = "КомандаЭлементНавигации_Вперед"  Тогда
			ПерейтиНаСтраницу(ТекущаяСтраница + 1);
		ИначеЕсли Элемент.Имя <> "КомандаЭлементНавигации_Точки" Тогда
			ИндексСтраницы = Число(Сред(Элемент.Имя, 25));
			ПерейтиНаСтраницу(ИндексСтраницы);			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, изменяет доступность комментария.
// 
Процедура ИзменитьДоступностьКомментария(Индекс)
	
	СтрокаТаблицаОценок = ЭтотОбъект.ТаблицаОценок[Индекс];
	
	НаборЗаписей = РегистрыСведений.ОценкиПриемов.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.Контрагент.Значение        = СтрокаТаблицаОценок.Контрагент; 	
	НаборЗаписей.Отбор.Контрагент.Использование   = Истина;	
	НаборЗаписей.Отбор.Прием.Значение             = СтрокаТаблицаОценок.Прием; 	
	НаборЗаписей.Отбор.Прием.Использование        = Истина;
	НаборЗаписей.Отбор.Сотрудник.Значение         = СтрокаТаблицаОценок.Сотрудник;
	НаборЗаписей.Отбор.Сотрудник.Использование    = Истина;
	НаборЗаписей.Отбор.ПараметрОценки.Значение    = СтрокаТаблицаОценок.ПараметрОценки;
	НаборЗаписей.Отбор.ПараметрОценки.Использование = Истина;
	
	НоваяЗапись                = НаборЗаписей.Добавить();
	НоваяЗапись.Период         = СтрокаТаблицаОценок.Период;
	НоваяЗапись.Контрагент     = СтрокаТаблицаОценок.Контрагент;
	НоваяЗапись.Прием          = СтрокаТаблицаОценок.Прием;
	НоваяЗапись.Оценка         = СтрокаТаблицаОценок.Оценка;
	НоваяЗапись.Комментарий    = СтрокаТаблицаОценок.Комментарий;
	НоваяЗапись.Деактивирован  = СтрокаТаблицаОценок.Деактивирован;
	НоваяЗапись.ПараметрОценки = СтрокаТаблицаОценок.ПараметрОценки;
	НоваяЗапись.Сотрудник      = СтрокаТаблицаОценок.Сотрудник;	
	
	НаборЗаписей.Записать(Истина);

КонецПроцедуры

&НаСервере
// Процедура, скрывает/показывает камментарий.
// 
Процедура СкрытьПоказатьКомментарий(ИмяЭлемента, ЦветТекста) 
	
	ГруппаОценки = ЭтаФорма.Элементы.Найти(СтрЗаменить(ИмяЭлемента, Символы.НПП, ""));
	Если ГруппаОценки <> Неопределено Тогда		
		Для Каждого ЭлементФормы из ГруппаОценки.ПодчиненныеЭлементы Цикл
			
			Если ТипЗнч(ЭлементФормы) = Тип("ГруппаФормы") Тогда
				СкрытьПоказатьКомментарий(ЭлементФормы.Имя, ЦветТекста);
			ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Или ТипЗнч(ЭлементФормы) = Тип("ДекорацияФормы")  Тогда
				ЭлементФормы.ЦветТекста = ЦветТекста;
			КонецЕсли;
			
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Процедура, изменяет подсказку кнопки.
// 
Процедура ИзменитьПодсказкуКнопки(ИмяКнопки, Деактивирован)
	
	Кнопка = ЭтаФорма.Элементы.Найти(ИмяКнопки);
	Если Кнопка <> Неопределено Тогда
		
		Кнопка.РасширеннаяПодсказка.Заголовок = ?(Деактивирован, "Комментарий не активен", "Комментарий активен");	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик нажатия навигационной ссылки.
// 
Процедура ОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СтрокаОценка = ТаблицаОценок[Число(Сред(Элемент.Имя, 24)) - 1];
	Если Не ЗначениеЗаполнено(СтрокаОценка.Комментарий) Тогда
		Комментарий = ПолучитьКомментарийСотрудника(СтрокаОценка.Период, СтрокаОценка.Прием, СтрокаОценка.Сотрудник);
	Иначе
		Комментарий = СтрокаОценка.Комментарий; 
	КонецЕсли;
	Если НавигационнаяСсылкаФорматированнойСтроки = "Читать дальше" Тогда
		
		мКоммент = Новый Массив;
		ФорматироватьКомментарий(Комментарий, НавигационнаяСсылкаФорматированнойСтроки, мКоммент);
		Элемент.Заголовок = Новый ФорматированнаяСтрока(мКоммент);
	Иначе
		
		мКоммент = Новый Массив();		
		ФорматироватьКомментарий(Комментарий, НавигационнаяСсылкаФорматированнойСтроки, мКоммент);
		Элемент.Заголовок = Новый ФорматированнаяСтрока(мКоммент);		
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти 

&НаСервереБезКонтекста
// Функция, удаляет недопустимые символы xml.
// 
Функция ФорматироватьКомментарий(Комментарий, НавСсылка, мКоммент)
	
	Если НавСсылка = "Читать дальше" Тогда		
		мКоммент.Добавить(ОбщегоНазначенияКлиентСерверСтоматология.УдалитьНедопустимыеСимволыXML(Комментарий) + Символы.ПС);		
		ФормСтрока = Новый ФорматированнаяСтрока("Свернуть", Новый Шрифт(, 8, Истина) , WebЦвета.Серый , , "Свернуть");
		мКоммент.Добавить(ФормСтрока);
	Иначе		
		мКоммент.Добавить(ОбщегоНазначенияКлиентСерверСтоматология.УдалитьНедопустимыеСимволыXML(Лев(Комментарий, 27)) + "..." + Символы.ПС);
		ФормСтрока = Новый ФорматированнаяСтрока("Читать дальше", Новый Шрифт(, 8, Истина) , WebЦвета.Серый , , "Читать дальше");
		мКоммент.Добавить(ФормСтрока);
	КонецЕсли;
	
КонецФункции

&НаСервере
// Процедура, обработчик нажатия динамической кнопки. 
// 
Процедура ПерейтиНаСтраницу(ИндексСтраницы)
	
	ТекущаяСтраница = ИндексСтраницы;
	СформироватьБлокОценкиИОтзывы(ИндексСтраницы);
	СформироватьПанельНавигации(ИндексСтраницы);
	
КонецПроцедуры

// Процедура, формирует панель навигации.
// 
Процедура СформироватьПанельНавигации(ТекущаяСтраница = 1, Шаг = 2)
	
	ГруппаНавигации = СоздатьЭлементГруппа("ГруппаНавигация", ЭтаФорма, ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 0);
	СоздатьЭлементКнопка( "Назад", "<", ГруппаНавигации, "ЭлементНавигации",,"Назад",,);	
	Если ТекущаяСтраница = 1 Тогда
		Элементы.Найти("КнопкаЭлементНавигации_Назад").Доступность = Ложь;
	иначе
		Элементы.Найти("КнопкаЭлементНавигации_Назад").Доступность = Истина;
	КонецЕсли;
	
	ПредСтраница = ТекущаяСтраница - 1;
	СледСтраница = ТекущаяСтраница + 1;
	ПоследняяСтраница = КоличествоСтраниц; 
	ПредПослСтраница  = КоличествоСтраниц - 1;
	
	Если ПоследняяСтраница < (7 + (Шаг * 2)) Тогда 	
		Счетчик = 1;
		Пока Счетчик <= ПоследняяСтраница Цикл
			СоздатьЭлементКнопка( Счетчик, Счетчик, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			Счетчик = Счетчик + 1;
		КонецЦикла;
	ИначеЕсли ПоследняяСтраница >= (7 + (Шаг * 2)) Тогда
		Если ТекущаяСтраница < (1 + (Шаг * 3)) Тогда
			Счетчик = 1;
			Пока Счетчик < (4 + (Шаг * 2)) Цикл
				СоздатьЭлементКнопка( Счетчик, Счетчик, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
				Счетчик = Счетчик + 1;
			КонецЦикла;
			СоздатьЭлементКнопка( "Точки", "...", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( ПредПослСтраница, ПредПослСтраница, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( ПоследняяСтраница, ПоследняяСтраница, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
		ИначеЕсли ПоследняяСтраница - (Шаг * 2) > ТекущаяСтраница И ТекущаяСтраница > (Шаг * 2) Тогда
			СоздатьЭлементКнопка( "1", "1", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( "2", "2", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( "Точки", "...", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			Счетчик = ТекущаяСтраница - Шаг;
			Пока Счетчик <= ТекущаяСтраница + Шаг Цикл
				СоздатьЭлементКнопка( Счетчик, Счетчик, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
				Счетчик = Счетчик + 1;
			КонецЦикла;
			СоздатьЭлементКнопка( "Точки2", "...", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( ПредПослСтраница, ПредПослСтраница, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( ПоследняяСтраница, ПоследняяСтраница, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
		Иначе
			СоздатьЭлементКнопка( "1", "1", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( "2", "2", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			СоздатьЭлементКнопка( "Точки", "...", ГруппаНавигации, "ЭлементНавигации",, "" ,,);
			Счетчик = ПоследняяСтраница - (1 + (Шаг * 3));
			Пока Счетчик <= ПоследняяСтраница Цикл
				СоздатьЭлементКнопка(Счетчик, Счетчик, ГруппаНавигации, "ЭлементНавигации",, "" ,,);
				Счетчик = Счетчик + 1;
			КонецЦикла;	
		КонецЕсли;
	КонецЕсли;
		
	СоздатьЭлементКнопка( "Вперед", ">", ГруппаНавигации, "ЭлементНавигации",,"Вперед",,);	
	Если ТекущаяСтраница = КоличествоСтраниц Тогда
		Элементы.Найти("КнопкаЭлементНавигации_Вперед").Доступность = Ложь;
	Иначе
		Элементы.Найти("КнопкаЭлементНавигации_Вперед").Доступность = Истина;
	КонецЕсли;	
	Элементы.Найти("КнопкаЭлементНавигации_" + ТекущаяСтраница).ЦветТекста = WebЦвета.Красный; 
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция, возвращает количество страниц.
// 
Функция ПолучитьКоличествоСтраниц(ВсегоОценок, ОценокНаСтраницу)
	
	Возврат ?(ВсегоОценок % ОценокНаСтраницу = 0, ВсегоОценок / ОценокНаСтраницу, Цел(ВсегоОценок / ОценокНаСтраницу) + 1); 	
	
КонецФункции

&НаСервере
// Процедура, выполянет создание блока история приемов.
// 
Процедура СформироватьБлокОценкиИОтзывы(Страница = Неопределено)
				
	// удаляем оценки и отзывы
	Если Элементы.Найти("ГруппаОценкиИОтзывы") <> Неопределено Тогда
		Элементы.Удалить(Элементы.Найти("ГруппаОценкиИОтзывы"));
	КонецЕсли;
	
	// удаляем группу навигации
	Если Элементы.Найти("ГруппаНавигация") <> Неопределено Тогда
		Элементы.Удалить(Элементы.Найти("ГруппаНавигация"));
	КонецЕсли;
	
	// удаляем команды 
	Пока Команды.Количество() > 0 Цикл 
		Для Каждого Команда из Команды Цикл
			Команды.Удалить(Команда);
		КонецЦикла;
	КонецЦикла;
	
	ИдСтроки   = ?(Страница = Неопределено, 1, Страница * ОценокНаСтраницу - ОценокНаСтраницу + 1);      
 	ДатаОценки = Неопределено;
	
	ГруппаоценкиИОтзывы = СоздатьЭлементГруппа(
	"ГруппаОценкиИОтзывы", 
	ЭтаФорма, 
	ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, 
	?(ВыводитьВсе, 130, 110));	
	
	Если ТаблицаОценок.Количество() <> 0 Тогда	
		СоздатьЭлементДекорация("ДекорацияРазделениеДаты_0", Элементы.ГруппаОценкиИОтзывы, "", ?(ВыводитьВсе, 122, 102),,Истина,,Истина);
	КонецЕсли;
	
	ТекущийСотрудник  = Неопределено;
	ТекущийКонтрагент = Неопределено;
	ИндексНачало = ?(Страница <> Неопределено, Страница * ОценокНаСтраницу - ОценокНаСтраницу, 0);
	ИндексКонец  = ?(Страница <> Неопределено, ?(Страница * ОценокНаСтраницу - 1 > ТаблицаОценок.Количество() - 1, ТаблицаОценок.Количество() - 1, Страница * ОценокНаСтраницу - 1), ТаблицаОценок.Количество() - 1);	
	
	// Сформировать таблицу оценок
 	Для Индекс = ИндексНачало По ИндексКонец Цикл
		
		Если ТаблицаОценок[Индекс].Период <> ДатаОценки Тогда  
			
			Прием = Неопределено;
			ПараметрОценки = Неопределено;
			// Дата оценивания
			ДатаОценки = ТаблицаОценок[Индекс].Период;
			Дата       = ПолучитьПредставлениеДатыОценивания(ДатаОценки);
			
			ГруппаВыравнивание = СоздатьЭлементГруппа(
			"ГруппаВыравнивание_" + ИдСтроки, 
			Элементы.ГруппаОценкиИОтзывы, 
			ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
			?(ВыводитьВсе, 122, 102));
			
			СоздатьЭлементДекорация("ДекорацияДатаОценки_" + ИдСтроки, ГруппаВыравнивание, Дата, 8, ВертикальноеПоложениеЭлемента.Центр); 
			
			ГруппаДанныеОценкиВертикальная = СоздатьЭлементГруппа(
			"ГруппаДанныеОценкиВертикальная_" + ИдСтроки, 
			ГруппаВыравнивание, 
			ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, 
			?(ВыводитьВсе, 122, 102));
			СоздатьЭлементДекорация("ДекорацияРазделениеДаты_" + ИдСтроки, Элементы.ГруппаОценкиИОтзывы, "", ?(ВыводитьВсе, 122, 102),, Истина,, Истина);
			
		КонецЕсли;
						
		Если Прием <> ТаблицаОценок[Индекс].Прием Тогда 
			
			ТекущийСотрудник = Неопределено;

			// Разделение приемов
			Если Прием <> Неопределено Тогда 
				СоздатьЭлементДекорация("ДекорацияРазделениеПриема_" + ИдСтроки, ГруппаДанныеОценкиВертикальная, "", ?(ВыводитьВсе, 122, 102),, Истина,, Истина); 
			КонецЕсли;
			
			Прием = ТаблицаОценок[Индекс].Прием;

			ГруппаОценкаПриемаОсновная = СоздатьЭлементГруппа(
			"ГруппаОценкаПриемаОсновная" + ИдСтроки, 
			ГруппаДанныеОценкиВертикальная, 
			ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
			?(ВыводитьВсе, 122, 102));
			
			// Прием
			ПриемПредставление = Формат(Прием.ВремяНачалаПриема, НСтр("ru = 'ДФ=''дд МММ ЧЧ:мм'''")) + " - " + Формат(Прием.ВремяОкончанияПриема, "ДФ=HH:mm");  
			//ПродолжительностьПриема = Окр((ТаблицаОценок[Индекс].Прием.ВремяОкончанияПриема - ТаблицаОценок[Индекс].Прием.ВремяНачалаПриема)/60);
			//ПриемПредставление      = Формат(ТаблицаОценок[Индекс].Прием.ВремяНачалаПриема, НСтр("ru = 'ДФ=''дд МММ'''")) + " " + Строка(ПродолжительностьПриема) + " мин.";  
			
			СоздатьЭлементКнопка(ИдСтроки, ПриемПредставление, ГруппаОценкаПриемаОсновная, "Прием", ВертикальноеПоложениеЭлемента.Верх, Строка(ТаблицаОценок[Индекс].Прием), 15);		
			
			// Данные Оценок сотрудников			
			ГруппаДанныеОценкиСотрудникаВертикальная = СоздатьЭлементГруппа(
			"ГруппаДанныеОценкиСотрудникаВертикальная" + ИдСтроки, 
			ГруппаОценкаПриемаОсновная, 
			ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, 
			?(ВыводитьВсе, 108, 88));
	
		КонецЕсли;	
				
		Если ТекущийСотрудник <> ТаблицаОценок[Индекс].Сотрудник Тогда 
		
			Если ТекущийСотрудник <> Неопределено Тогда 
				СоздатьЭлементДекорация("ДекорацияРазделениеСотрудника_" + ИдСтроки, ГруппаДанныеОценкиСотрудникаВертикальная, "", ?(ВыводитьВсе, 108, 88),, Истина,, Истина); 
			КонецЕсли;
			
			ТекущийСотрудник  = ТаблицаОценок[Индекс].Сотрудник;
			ТекущийКонтрагент = ТаблицаОценок[Индекс].Контрагент;
			
			// Данные Оценок сотрудника			
			ГруппаДанныеОценкиСотрудникаГоризонтальная = СоздатьЭлементГруппа(
			"ГруппаДанныеОценкиСотрудникаГоризонтальная" + ИдСтроки, 
			ГруппаДанныеОценкиСотрудникаВертикальная, 
			ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
			?(ВыводитьВсе, 108, 88));
			
			// Оценки сотрудника			
			ГруппаОценкаСотрудникаВертикальная = СоздатьЭлементГруппа(
			"ГруппаОценкаСотрудникаВертикальная" + ИдСтроки, 
			ГруппаДанныеОценкиСотрудникаГоризонтальная, 
			ГруппировкаПодчиненныхЭлементовФормы.Вертикальная, 
			22);
			
			// Сотрудник
			СоздатьЭлементКнопка(
			ИдСтроки, ?(ЗначениеЗаполнено(Контрагент), Справочники.Сотрудники.ПредставлениеФИОСотрудника(ТаблицаОценок[Индекс].Сотрудник),  
			Справочники.Контрагенты.ПредставлениеФИОКонтрагента(ТаблицаОценок[Индекс].Контрагент)), 
			ГруппаДанныеОценкиСотрудникаГоризонтальная, 
			?(ЗначениеЗаполнено(Контрагент), "Сотрудник", "Контрагент"),, 
			?(ЗначениеЗаполнено(Контрагент), Строка(ТаблицаОценок[Индекс].Сотрудник), Строка(ТаблицаОценок[Индекс].Контрагент)),  
			18);
			
			Если Не ЗначениеЗаполнено(Сотрудник) И Не ЗначениеЗаполнено(Контрагент) Тогда 
				
				СоздатьЭлементКнопка(
				ИдСтроки, Справочники.Сотрудники.ПредставлениеФИОСотрудника(ТаблицаОценок[Индекс].Сотрудник), 
				ГруппаДанныеОценкиСотрудникаГоризонтальная, 
				"Сотрудник",, 
				Строка(ТаблицаОценок[Индекс].Сотрудник),  
				14);
				
			КонецЕсли;
						
			// Услуги
			УслугиСотрудника = ПолучитьУслугиСотрудника(ТаблицаОценок[Индекс].Сотрудник, ТаблицаОценок[Индекс].Прием);
			
			СоздатьЭлементДекорация("Состав_" + ИдСтроки, ГруппаДанныеОценкиСотрудникаГоризонтальная, УслугиСотрудника, 14); 
			Комментарий = ПолучитьКомментарийСотрудника(ТаблицаОценок[Индекс].Период, ТаблицаОценок[Индекс].Прием, ТаблицаОценок[Индекс].Сотрудник);
			
			СоздатьЭлементДекорация("Комментарий_" + ИдСтроки, ГруппаДанныеОценкиСотрудникаГоризонтальная, Комментарий, 22, ВертикальноеПоложениеЭлемента.Центр,, Комментарий); 					
			СоздатьЭлементКнопка(ИдСтроки, "", ГруппаДанныеОценкиСотрудникаГоризонтальная, "ДоступностьКомментария", ВертикальноеПоложениеЭлемента.Верх, ?(ТаблицаОценок[Индекс].Деактивирован, "Комментарий не активен", "Комментарий активен"), 10, ТаблицаОценок[Индекс].Деактивирован);		

		КонецЕсли;
		
		// Оценка Сотрудника
		ГруппаОценкаСотрудникаГоризонтальная = СоздатьЭлементГруппа(
		"ГруппаОценкаСотрудникаГоризонтальная" + ИдСтроки, 
		ГруппаОценкаСотрудникаВертикальная, 
		ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, 
		19);
		
		СоздатьЭлементДекорация("ПараметрОценки_" + ИдСтроки, ГруппаОценкаСотрудникаГоризонтальная, "", 3); 
		Если ТаблицаОценок[Индекс].Оценка > 0 Тогда
			
			ОценкаСотрудника = ТаблицаОценок[Индекс].Оценка;
			
			ИдСтрокиОценкаСотрудника = 1;
			Для а = 1 по 5 Цикл
				
				Декорация = Элементы.Вставить("ОценкаСотрудника" + СтрЗаменить(ИдСтроки, Символы.НПП, "") + "_" + ИдСтрокиОценкаСотрудника, Тип("ДекорацияФормы"), ГруппаОценкаСотрудникаГоризонтальная);
				
				Декорация.Вид                  = ВидДекорацииФормы.Картинка;
				Декорация.Картинка             = ?(ОценкаСотрудника > 0, БиблиотекаКартинок.РейтингЗвездаЗаполненная, БиблиотекаКартинок.РейтингЗвездаПустая);
				Декорация.Подсказка            = ТаблицаОценок[Индекс].Комментарий;
				Декорация.ОтображениеПодсказки = ОтображениеПодсказки.Всплывающая; 
				ОценкаСотрудника 		       = ОценкаСотрудника - 1;
				
				ИдСтрокиОценкаСотрудника = ИдСтрокиОценкаСотрудника + 1;
				
			КонецЦикла;
			
		Иначе
			СоздатьЭлементДекорация("ОценкаСотрудника" + ИдСтроки, ГруппаОценкаСотрудникаГоризонтальная, "", 14); 
		КонецЕсли;
		
		//СоздатьЭлементДекорация("ПараметрОценки_" + ИдСтроки, ГруппаОценкаСотрудникаГоризонтальная, ТаблицаОценок[Индекс].ПараметрОценки, 10); 
		СоздатьЭлементДекорация("ПараметрОценки2_" + ИдСтроки, ГруппаОценкаСотрудникаГоризонтальная, "", 3); 
		
		ИдСтроки = ИдСтроки + 1;
		
	КонецЦикла;
	
	Для Индекс = ИндексНачало По ИндексКонец Цикл
		Если ТаблицаОценок[Индекс].Деактивирован Тогда
			СкрытьПоказатьКомментарий("ГруппаДанныеОценкиСотрудникаГоризонтальная" + (Индекс + 1), WebЦвета.СветлоСерый);
		КонецЕсли;
	КонецЦикла;		

КонецПроцедуры

&НаСервере
// Функция - Получить оценки сотрудника
// 
// Параметры:
//  Сотрудник	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьОценки(Сотрудник = Неопределено, Контрагент = Неопределено)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОценкиПриемов.Период КАК Период,
	|	ОценкиПриемов.Прием КАК Прием,
	|	ОценкиПриемов.Сотрудник КАК Сотрудник,
	|	ОценкиПриемов.ПараметрОценки КАК ПараметрОценки,
	|	ОценкиПриемов.Оценка КАК Оценка,
	|	ОценкиПриемов.Комментарий КАК Комментарий,
	|	ОценкиПриемов.Контрагент КАК Контрагент,
	|	ОценкиПриемов.Деактивирован КАК Деактивирован
	|ИЗ
	|	РегистрСведений.ОценкиПриемов КАК ОценкиПриемов
	|ГДЕ
	|	ОценкиПриемов.Прием.СтруктурнаяЕдиница В
	|			(ВЫБРАТЬ
	|				НастройкиПользователей.СтруктурнаяЕдиница
	|			ИЗ
	|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
	|			ГДЕ
	|				НастройкиПользователей.Пользователь = &ТекущийПользователь)
	|	{Условие}");
	
	Если Сотрудник <> Неопределено Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "{Условие}", "И ОценкиПриемов.Сотрудник = &Сотрудник");
		Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
		
	ИначеЕсли Контрагент <> Неопределено Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "{Условие}", "И ОценкиПриемов.Контрагент = &Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "{Условие}", "");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ТекущийПользователь", ПараметрыСеанса.ТекущийПользователь);
	
	Запрос.Текст = Запрос.Текст + "
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

&НаСервере
// Функция - Получить представление даты оценивания
// 
// Параметры:
//  Период	 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьПредставлениеДатыОценивания(Период)
	
	Если НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(Период) Тогда
		
		Дата = НСтр("ru = 'Сегодня'");
		
	ИначеЕсли НачалоДня(НачалоДня(ТекущаяДатаСеанса())-1) = НачалоДня(Период) Тогда
		
		Дата = НСтр("ru = 'Вчера'");
	Иначе
		Дата = Формат(Период, НСтр("ru = 'ДФ=''дд МММ'''"));
		
	КонецЕсли;
	
	Возврат Дата;

КонецФункции

&НаСервере
// Функция - Получить услуги сотрудника
// 
// Параметры:
//  Сотрудник	 - 	 - 
//  Запасы		 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьУслугиСотрудника(Сотрудник, Прием)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПриемЛечение.Номенклатура КАК Услуга
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|ГДЕ
	|	ПриемЛечение.Сотрудник = &Сотрудник
	|	И НЕ ПриемЛечение.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И ПриемЛечение.Ссылка = &Прием");
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Прием"    , Прием);
	
	УслугиСотрудника = "";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		УслугиСотрудника = УслугиСотрудника + ", " + Выборка.Услуга; 	
	КонецЦикла;
		
	Возврат Сред(УслугиСотрудника, 3, СтрДлина(УслугиСотрудника));

КонецФункции

&НаСервере
// Функция - Получить комментарий приемаа
// 
// Параметры:
//  ОценкиСотрудника - 	 - 
//  Период			 - 	 - 
//  Прием			 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПолучитьКомментарийСотрудника(Период, Прием, Сотрудник)
		
	КомментарииПриема = ТаблицаОценок.НайтиСтроки(Новый Структура("Период, Прием, Сотрудник", Период, Прием, Сотрудник));
	Комментарий       = "";
	
	Для Каждого СтрокаТ Из КомментарииПриема Цикл 
		
		Если Не ЗначениеЗаполнено(СтрНайти(Комментарий, СтрокаТ.Комментарий)) Тогда 
			
			Комментарий = Комментарий + ?(ЗначениеЗаполнено(Комментарий), ", ", "") + СтрокаТ.Комментарий;   
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Комментарий;

КонецФункции

&НаСервере
// Процедура, выполянет добавление элемента формы.
// 
Процедура СоздатьЭлементКнопка(ИмяЭлемента, Заголовок, Родитель, Тип, ВертикальноеПоложение = Неопределено, Подсказка = "", Ширина = 0, СкрытьКомментарий = Неопределено)
	
	КомандаФормы          = ЭтаФорма.Команды.Добавить("Команда" + Тип + "_" + СтрЗаменить(ИмяЭлемента, Символы.НПП, ""));	
	КомандаФормы.Действие = "ПроцедураОбработкиНажатияДинамическойКнопки";
	
	ЭлементКнопка = Элементы.Добавить("Кнопка" + Тип + "_" + СтрЗаменить(ИмяЭлемента, Символы.НПП, ""), Тип("КнопкаФормы"), Родитель);	
	
	ЭлементКнопка.Заголовок                      = Заголовок;
	ЭлементКнопка.ИмяКоманды 					 = КомандаФормы.Имя;		
	
	Если Тип = "ДоступностьКомментария" Тогда		
		ЭлементКнопка.Отображение                    = ОтображениеКнопки.Картинка;
		ЭлементКнопка.Картинка						 = ?(СкрытьКомментарий, БиблиотекаКартинок.ПоказатьСкрытыеЭлементы, БиблиотекаКартинок.КомментарийДоступен);				
		ЭлементКнопка.Доступность                    = ИзменениеДоступностиКомментария;
	КонецЕсли;
	
	Если Тип = "ЭлементНавигации" Тогда
		ЭлементКнопка.Шрифт = Новый Шрифт(, 12);
	КонецЕсли;
	ЭлементКнопка.ОтображениеФигуры              = ОтображениеФигурыКнопки.Нет;
	ЭлементКнопка.РастягиватьПоГоризонтали       = Ложь;
	ЭлементКнопка.РасширеннаяПодсказка.Заголовок = Подсказка;
	ЭлементКнопка.ОтображениеПодсказки           = ОтображениеПодсказки.Всплывающая;
	Если ВертикальноеПоложение <> Неопределено Тогда 
		ЭлементКнопка.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр; 
	КонецЕсли;
	
	Если Ширина <> 0 Тогда
		ЭлементКнопка.Ширина = Ширина;
	КонецЕсли;
	 
КонецПроцедуры

&НаСервере
// Процедура, выполняет добавление элемента формы.
// 
Процедура СоздатьЭлементДекорация(
	ИмяЭлемента, 
	Родитель, 
	Заголовок, 
	МаксШирина, 
	ВертикальноеПоложение = Неопределено, 
	Растягивать = Ложь, 
	Комментарий = Неопределено, 
	РамкаПодчеркивание = Ложь)
	
	Декорация = Элементы.Добавить("_Декорация_" + СтрЗаменить(ИмяЭлемента, Символы.НПП, ""), Тип("ДекорацияФормы"), Родитель);
	Декорация.ГоризонтальноеПоложение      = ГоризонтальноеПоложениеЭлемента.Центр;
	Декорация.Заголовок = Заголовок;
	Декорация.ВертикальноеПоложение = ВертикальноеПоложениеЭлемента.Центр;
	
	Если СтрНайти(ИмяЭлемента,"Состав_") Тогда 
		Декорация.Высота = 2;
	КонецЕсли;
	
	Если Комментарий <> Неопределено Тогда
		
		Декорация.Подсказка               = Комментарий;
		Декорация.ОтображениеПодсказки    = ОтображениеПодсказки.Всплывающая; 
		
		Если СтрДлина(Заголовок) <= 60 Тогда
			Декорация.Заголовок = Заголовок;
		Иначе
			
			мКоммент = Новый Массив();		
			мКоммент.Добавить(ОбщегоНазначенияКлиентСерверСтоматология.УдалитьНедопустимыеСимволыXML(Лев(Комментарий, 27)) + "..." + Символы.ПС);
			ФормСтрока = Новый ФорматированнаяСтрока("Читать дальше", Новый Шрифт(, 8, Истина, , , ) , WebЦвета.Серый , , "Читать дальше");
			мКоммент.Добавить(ФормСтрока);
			Декорация.Заголовок = Новый ФорматированнаяСтрока(мКоммент);
			Декорация.УстановитьДействие("ОбработкаНавигационнойСсылки", "ОбработкаНавигационнойСсылки");
			Декорация.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
			
		КонецЕсли;
	КонецЕсли;
	
	Декорация.АвтоМаксимальнаяШирина       = Ложь;
	Декорация.Ширина                       = МаксШирина;
	Декорация.РастягиватьПоГоризонтали     = Растягивать;
	Декорация.Рамка                        = Новый Рамка(ТипРамкиЭлементаУправления.Одинарная, 1);
	Декорация.АвтоМаксимальнаяВысота       = Ложь;
	// Декорация.МаксимальнаяВысота           = 3;
	
	Если ВертикальноеПоложение <> Неопределено Тогда 	
		Декорация.ВертикальноеПоложениеВГруппе = ВертикальноеПоложение;
	КонецЕсли;

	Если РамкаПодчеркивание Тогда 
		
		Декорация.Рамка = Новый Рамка(ТипРамкиЭлементаУправления.Подчеркивание);
		Декорация.ЦветРамки = WebЦвета.СветлоСерый;	
	Иначе
		Декорация.ЦветРамки = Новый Цвет(255,255,255);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
// Функция - Создать элемент группа
// 
// Параметры:
//  ИмяЭлемента				 - 	 - 
//  Родитель				 - 	 - 
//  ГруппировкаПодчиненных	 - 	 - 
//  Ширина					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция СоздатьЭлементГруппа(ИмяЭлемента, Родитель, ГруппировкаПодчиненных, Ширина)
	
	Группа = Элементы.Добавить(СтрЗаменить(ИмяЭлемента, Символы.НПП, ""), Тип("ГруппаФормы"), Родитель);		
	
	Группа.Вид                            	  = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка                        = ГруппировкаПодчиненных;
	Группа.Отображение                        = ОтображениеОбычнойГруппы.Нет;
	Группа.ОтображатьЗаголовок                = Ложь;
	Группа.Ширина                             = Ширина;
	Группа.РастягиватьПоГоризонтали           = Ложь;
	
	Если ИмяЭлемента = "ГруппаОценкиИОтзывы" Или СтрНайти(ИмяЭлемента, "ГруппаВыравнивание_") > 0 Или ИмяЭлемента = "ГруппаНавигация" Тогда
		Группа.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
		Если ИмяЭлемента = "ГруппаНавигация" Тогда
			 Группа.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
		КонецЕсли;
	Иначе
		Группа.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
	КонецЕсли;
	Группа.ВертикальноеПоложениеПодчиненных   = ВертикальноеПоложениеЭлемента.Центр;
	Группа.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Центр;
	
	Возврат Группа;
КонецФункции

#КонецОбласти
