			// КонецЕсли;
			ОбластьИсторияПриемов_Документ.Параметры.Дата 					= ВыборкаПриемы.Дата;
			ОбластьИсторияПриемов_Документ.Параметры.Прием 					= ?(ТипЗнч(ВыборкаПриемы.ДокументПродажи.Ссылка) = Тип("ДокументСсылка.Прием"), Формат(ВыборкаПриемы.Дата, "ДФ=HH:mm") + ", Врач: " + Строка(ВыборкаПриемы.Сотрудник), Формат(ВыборкаПриемы.Дата, "ДФ=HH:mm"));
			Если ЗначениеЗаполнено(ВыборкаПриемы.ПолисМедСтрахования) Тогда
				ПолисМедСтрахования = ВыборкаПриемы.ПолисМедСтрахования;
				ОбластьИсторияПриемов_Документ.Параметры.СтраховаяКомпания  = Строка(ПолисМедСтрахования.СтраховаяКомпания) + ", полис №" + ПолисМедСтрахования.НомерПолиса + "-" + ПолисМедСтрахования.СерияПолиса + " до: " + Формат(ПолисМедСтрахования.ДатаОкончания, "ДФ='dd MMMM yyyy'");
			КонецЕсли;
			ОбластьИсторияПриемов_Документ.Параметры.СуммаДокумента 		= Формат(ВыборкаПриемы.Сумма, "ЧДЦ=2; ЧРД=.");
			ОбластьИсторияПриемов_Документ.Параметры.ОплаченоПоДокументу 	= Формат(ВыборкаПриемы.Оплачено, "ЧДЦ=2; ЧРД=.");
		//	ОбластьИсторияПриемов_Документ.Параметры.ДолгПоДокументу 		= Формат(ВыборкаПриемы.Долг, "ЧДЦ=2; ЧРД=.");
			ОбластьИсторияПриемов_Документ.Параметры.СписаноПоДокументу     = Формат(ВыборкаПриемы.Списано, "ЧДЦ=2; ЧРД=.");
			ОбластьИсторияПриемов_Документ.Параметры.РасшифровкаПриема 		= ВыборкаПриемы.ДокументПродажи;
			
			// Если ВыборкаПриемы.Долг > 0 Тогда
			//	ОбластьИсторияПриемов_Документ.Область("ОбластьДолгПоДокументу").ЦветТекста = WebЦвета.Красный;
			// ИначеЕсли ВыборкаПриемы.Долг < 0 Тогда
			//	ОбластьИсторияПриемов_Документ.Область("ОбластьДолгПоДокументу").ЦветТекста = WebЦвета.Фиолетовый;
			// КонецЕсли;		
			ВыборкаПоУслугам = ВыборкаПриемы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПоУслугам.СледующийПоЗначениюПоля("Услуга") Цикл
				Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") Тогда
					ОбластьИсторияПриемов_Услуга = Макет.ПолучитьОбласть("ИсторияПриемов_Услуга");
					СтрокаЗуб = "";
					СкидкаСредняя = 0;
					СуммаБезСкидкиПоУслуге = 0;
					СуммаСоСкидкойПоУслуге = 0;
					Пока ВыборкаПоУслугам.СледующийПоЗначениюПоля("НомерЗуба") Цикл 
						СуммаБезСкидкиПоУслуге = СуммаБезСкидкиПоУслуге + ВыборкаПоУслугам.СуммаБезСкидки;
						СуммаСоСкидкойПоУслуге = СуммаСоСкидкойПоУслуге + ВыборкаПоУслугам.СуммаСоСкидкой;
						Если СтрокаЗуб = "" Тогда
							СтрокаЗуб = Строка(?(ВыборкаПоУслугам.НомерЗуба = Перечисления.Зубы.ВсяПолость, "", ВыборкаПоУслугам.НомерЗуба));
						Иначе 
							СтрокаЗуб = СтрокаЗуб + ?(ЗначениеЗаполнено(?(ВыборкаПоУслугам.НомерЗуба = Перечисления.Зубы.ВсяПолость, "", ВыборкаПоУслугам.НомерЗуба)), ", ", "") + Строка(?(ВыборкаПоУслугам.НомерЗуба = Перечисления.Зубы.ВсяПолость, "", ВыборкаПоУслугам.НомерЗуба));
						КонецЕсли;
					КонецЦикла;
					Если СуммаБезСкидкиПоУслуге - СуммаСоСкидкойПоУслуге = 0 Тогда
						ОбластьИсторияПриемов_Услуга.Параметры.Услуга = ?(ЗначениеЗаполнено(СтрокаЗуб), СтрокаЗуб + ": ", "") + Строка(ВыборкаПоУслугам.Услуга);
					Иначе
						Если СуммаБезСкидкиПоУслуге <> 0 и СуммаСоСкидкойПоУслуге <> 0 и СуммаБезСкидкиПоУслуге <> Неопределено Тогда
							СкидкаСредняя =  (СуммаБезСкидкиПоУслуге - СуммаСоСкидкойПоУслуге) / СуммаБезСкидкиПоУслуге * 100;
						КонецЕсли;
						ОбластьИсторияПриемов_Услуга.Параметры.Услуга = ?(ЗначениеЗаполнено(СтрокаЗуб), Строка(СтрокаЗуб) + ": ", "") + Строка(ВыборкаПоУслугам.Услуга);
						СкидкаОкр = ОбщегоНазначенияКлиентСерверСтоматология.ОкруглитьЦену(СкидкаСредняя, Перечисления.ПорядкиОкругления.Окр0_1, Истина);			   
						ОбластьИсторияПриемов_Услуга.Параметры.ПроцентСкидки = "-" + СкидкаОкр + "%";
					КонецЕсли;				   
					ОбластьИсторияПриемов_Документ.Присоединить(ОбластьИсторияПриемов_Услуга);						
				КонецЕсли;					
			КонецЦикла;				
			ТабличныйДокумент.Вывести(ОбластьИсторияПриемов_Документ);			
		КонецЦикла;
	КонецЕсли;
		
	УстановитьПривилегированныйРежим(Ложь);	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция возвращает текст запроса
//
Функция ПолучитьЗапросОбщейИнформации() Экспорт
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусКлиента.Статус КАК Статус,
	|	СтатусКлиента.Контрагент КАК Контрагент,
	|	МИНИМУМ(Продажи.Период) КАК ДатаПервогоПосещения,
	|	МАКСИМУМ(Продажи.Период) КАК ДатаПоследнегоПосещения,
	|	ЛицСчет.СуммаОстаток КАК Остаток,
	|	ДатаРегистрации.Период КАК ДатаРегистрации
	|ИЗ
	|	(ВЫБРАТЬ
	|		НЕОПРЕДЕЛЕНО КАК ПустоеПоле) КАК ПустаяКолонка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКонтрагентов.СрезПоследних(, ) КАК СтатусКлиента
	|		ПО (СтатусКлиента.Контрагент = &Клиент)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи КАК Продажи
	|		ПО (Продажи.Контрагент = &Клиент)
	|			И (ВЫБОР
	|				КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|					ТОГДА Продажи.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредстваНаЛицевыхСчетах.Остатки(, Контрагент = &Клиент) КАК ЛицСчет
	|		ПО (ЛицСчет.Контрагент = &Клиент)
	|			И (ВЫБОР
	|				КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|					ТОГДА ЛицСчет.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыКонтрагентов.СрезПервых КАК ДатаРегистрации
	|		ПО (ДатаРегистрации.Контрагент = &Клиент)
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатусКлиента.Статус,
	|	СтатусКлиента.Контрагент,
	|	ДатаРегистрации.Период,
	|	ЛицСчет.СуммаОстаток
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Предпочтения.Сотрудник.Наименование КАК ФамилияМастера,
	|	Предпочтения.Сотрудник.Должность.Наименование КАК ДолжностьМастера
	|ИЗ
	|	РегистрСведений.ПредпочтенияКлиентовПоМастерам КАК Предпочтения
	|ГДЕ
	|	Предпочтения.Контрагент = &Клиент
	|	И ВЫБОР
	|			КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|				ТОГДА Предпочтения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КонтрагентыСегмента.Сегмент КАК Сегмент
	|ИЗ
	|	РегистрСведений.КонтрагентыСегмента КАК КонтрагентыСегмента
	|ГДЕ
	|	КонтрагентыСегмента.Контрагент = &Клиент
	|	И НЕ КонтрагентыСегмента.Сегмент.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПродажиОбороты.ДокументПродажи КАК ДокументПродажи,
	|	ПродажиОбороты.ДокументПродажи.Дата КАК Дата,
	|	ПродажиОбороты.ДокументПродажи.Сотрудник КАК Сотрудник,
	|	СУММА(ЕСТЬNULL(ПродажиОбороты.ДокументПродажи.СуммаДокумента, 0)) КАК Сумма,
	|	СУММА(ЕСТЬNULL(ПродажиОбороты.ДокументПродажи.СуммаОплачено, 0)) КАК Оплачено,
	|	СУММА(-ЕСТЬNULL(ЗадолженностьПоДокументу.СуммаЗадолженности, 0)) КАК Долг,
	|	СУММА(ЕСТЬNULL(ЗадолженностьПоДокументу.СуммаСписания, 0)) КАК Списано,
	|	СУММА(ВЫБОР
	|			КОГДА ПродажиОбороты.СтоимостьБезСкидкиОборот - ПродажиОбороты.СтоимостьОборот <= 0
	|				ТОГДА 0
	|			ИНАЧЕ ВЫБОР
	|					КОГДА ПродажиОбороты.СтоимостьБезСкидкиОборот <> 0
	|						ТОГДА (ПродажиОбороты.СтоимостьБезСкидкиОборот - ПродажиОбороты.СтоимостьОборот) / ПродажиОбороты.СтоимостьБезСкидкиОборот * 100
	|					ИНАЧЕ 0
	|				КОНЕЦ
	|		КОНЕЦ) КАК Скидка,
	|	СУММА(ПродажиОбороты.КоличествоОборот) КАК Количество,
	|	ПродажиОбороты.Номенклатура КАК Услуга,
	|	ПродажиОбороты.НомерЗуба КАК НомерЗуба,
	|	СУММА(ПродажиОбороты.СтоимостьОборот * ПродажиОбороты.КоличествоОборот) КАК СуммаСоСкидкой,
	|	СУММА(ПродажиОбороты.СтоимостьБезСкидкиОборот * ПродажиОбороты.КоличествоОборот) КАК СуммаБезСкидки,
	|	ПродажиОбороты.ДокументПродажи.ПолисМедСтрахования КАК ПолисМедСтрахования
	|ИЗ
	|	РегистрНакопления.Продажи.Обороты(
	|			,
	|			,
	|			Авто,
	|			Контрагент = &Клиент
	|				И ВЫБОР
	|					КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|						ТОГДА СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ
	|				И (ДокументПродажи ССЫЛКА Документ.Прием
	|					ИЛИ ДокументПродажи ССЫЛКА Документ.Реализация)) КАК ПродажиОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ВзаиморасчетыСКонтрагентамиОбороты.ДокументРеализации КАК ДокументРеализации,
	|			СУММА(ЕСТЬNULL(ВзаиморасчетыСКонтрагентамиОбороты.СуммаОборот, 0)) КАК СуммаЗадолженности,
	|			СУММА(ВЫБОР
	|					КОГДА ВзаиморасчетыСКонтрагентамиОбороты.Регистратор ССЫЛКА Документ.СписаниеЗадолженности
	|						ТОГДА -ВзаиморасчетыСКонтрагентамиОбороты.СуммаРасход
	|					ИНАЧЕ 0
	|				КОНЕЦ) КАК СуммаСписания
	|		ИЗ
	|			РегистрНакопления.ВзаиморасчетыСКонтрагентами.Обороты(
	|					,
	|					,
	|					Авто,
	|					ВЫБОР
	|							КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|								ТОГДА СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|							ИНАЧЕ ИСТИНА
	|						КОНЕЦ
	|						И Контрагент = &Клиент) КАК ВзаиморасчетыСКонтрагентамиОбороты
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ВзаиморасчетыСКонтрагентамиОбороты.ДокументРеализации) КАК ЗадолженностьПоДокументу
	|		ПО ПродажиОбороты.ДокументПродажи = ЗадолженностьПоДокументу.ДокументРеализации
	|ГДЕ
	|	НЕ ПродажиОбороты.ДокументПродажи В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					ВозвратОтПокупателя.ДокументОснования КАК ДокументОснования
	|				ИЗ
	|					Документ.ВозвратОтПокупателя КАК ВозвратОтПокупателя
	|				ГДЕ
	|					НЕ ВозвратОтПокупателя.ПометкаУдаления
	|					И ВозвратОтПокупателя.Проведен
	|					И ВозвратОтПокупателя.ДокументОснования ССЫЛКА Документ.Прием
	|					И ВозвратОтПокупателя.Контрагент = &Клиент
	|					И ВозвратОтПокупателя.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПродажиОбороты.ДокументПродажи,
	|	ПродажиОбороты.ДокументПродажи.Дата,
	|	ПродажиОбороты.ДокументПродажи.Сотрудник,
	|	ПродажиОбороты.Номенклатура,
	|	ПродажиОбороты.НомерЗуба,
	|	ПродажиОбороты.ДокументПродажи.ПолисМедСтрахования
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|ИТОГИ
	|	МАКСИМУМ(Долг),
	|	МАКСИМУМ(Списано)
	|ПО
	|	ДокументПродажи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Взаимодействие.Ссылка КАК Взаимодействие,
	|	Взаимодействие.Дата КАК Дата,
	|	Взаимодействие.ВидОперации КАК ВидОперации,
	|	Взаимодействие.Задача КАК Тема,
	|	Взаимодействие.ПредварительнаяЗаписьНаСледующийПрием КАК ПредварительнаяЗапись
	|ИЗ
	|	Документ.Взаимодействие КАК Взаимодействие
	|ГДЕ
	|	Взаимодействие.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Взаимодействие.ЗадачаПредмет = &Клиент
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПланЛеченияЛечение.Ссылка КАК ПланЛеченияСсылка,
	|	ПланЛеченияЛечение.Зуб КАК НомерЗуба,
	|	ПланЛеченияЛечение.Номенклатура КАК Услуга,
	|	ПланЛеченияЛечение.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА ПланЛеченияЛечение.СуммаАвтоматическойСкидкиНаценки > 0
	|				И ПланЛеченияЛечение.Количество * ПланЛеченияЛечение.Цена <> 0
	|			ТОГДА ПланЛеченияЛечение.СуммаАвтоматическойСкидкиНаценки / (ПланЛеченияЛечение.Количество * ПланЛеченияЛечение.Цена / 100)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПроцентСкидки,
	|	ПланЛеченияЛечение.СуммаАвтоматическойСкидкиНаценки КАК СуммаАвтСкидки,
	|	ПланЛеченияЛечение.Всего КАК СуммаИтого,
	|	ПланЛеченияЛечение.Прием КАК Прием
	|ИЗ
	|	Документ.ПланЛечения.Лечение КАК ПланЛеченияЛечение
	|ГДЕ
	|	ПланЛеченияЛечение.Ссылка.Контрагент = &Клиент
	|	И ВЫБОР
	|			КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|				ТОГДА ПланЛеченияЛечение.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И (ПланЛеченияЛечение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Рассматривается)
	|			ИЛИ ПланЛеченияЛечение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Принят)
	|			ИЛИ ПланЛеченияЛечение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Отвергнут)
	|			ИЛИ ПланЛеченияЛечение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПланЛечения.Закрыт))
	|	И НЕ ПланЛеченияЛечение.Ссылка.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПланЛеченияЛечение.Ссылка.Дата УБЫВ
	|ИТОГИ
	|	СУММА(СуммаИтого)
	|ПО
	|	ПланЛеченияСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НарядЗаказЗапасы.Зуб КАК Зуб,
	|	НарядЗаказЗапасы.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(НарядЗаказЗапасы.ДатаВыполнения) КАК ДатаВыполнения,
	|	НарядЗаказЗапасы.Статус КАК Статус,
	|	НарядЗаказЗапасы.НомерЗаказа КАК НомерЗаказа,
	|	НарядЗаказЗапасы.Ссылка.Сотрудник КАК Сотрудник,
	|	МАКСИМУМ(НарядЗаказЗапасы.ДатаЗаказа) КАК ДатаЗаказа,
	|	НарядЗаказЗапасы.Ссылка.Ссылка КАК Ссылка,
	|	МАКСИМУМ(НарядЗаказЗапасы.Ссылка.Дата) КАК Дата,
	|	НарядЗаказЗапасы.Ссылка.Статус КАК СтатусНарядЗаказа
	|ИЗ
	|	Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	|				ТОГДА НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ НарядЗаказЗапасы.Ссылка.ПометкаУдаления
	|	И НарядЗаказЗапасы.Ссылка.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|	И НарядЗаказЗапасы.Ссылка.Контрагент = &Клиент
	|
	|СГРУППИРОВАТЬ ПО
	|	НарядЗаказЗапасы.Номенклатура,
	|	НарядЗаказЗапасы.Зуб,
	|	НарядЗаказЗапасы.Статус,
	|	НарядЗаказЗапасы.НомерЗаказа,
	|	НарядЗаказЗапасы.Ссылка.Сотрудник,
	|	НарядЗаказЗапасы.Ссылка.Ссылка,
	|	НарядЗаказЗапасы.Ссылка.Статус
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ,
	|	ДатаЗаказа УБЫВ,
	|	ДатаВыполнения УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Профосмотры.ДатаЗапланированная КАК ДатаЗапланированная,
	|	Профосмотры.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Профосмотры.Контрагент КАК Контрагент,
	|	Профосмотры.Сотрудник КАК Сотрудник,
	|	Профосмотры.ВидОсмотра КАК ВидОсмотра,
	|	Профосмотры.Период КАК Период
	|ИЗ
	|	РегистрСведений.Профосмотры КАК Профосмотры
	|ГДЕ
	|	Профосмотры.Контрагент = &Клиент
	|	И Профосмотры.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Профосмотр)
	|	И Профосмотры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПрофосмотров.Запланирован)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаЗапланированная";
	
	Возврат ТекстЗапроса;
	
КонецФункции

