// Процедура заполняет таблицу меток разрешенными метками и устанавливает значиния их активности.
//
Процедура ЗаполнитьТаблицуМеток()
	
	ТаблицаМеток.Очистить();
	
	Запрос = Новый Запрос;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Метки.Ссылка КАК Метка,
		|	Метки.Наименование КАК ПредставлениеМетки,
		|	Метки.ЦветМетки КАК ЦветМетки,
		|	Метки.ЦветТекстаБелый КАК ЦветТекстаБелый,
		|	ЕСТЬNULL(МеткиКлиентов.Активна, ЛОЖЬ) КАК Активна
		|ИЗ
		|	Справочник.Метки КАК Метки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МеткиКлиентов КАК МеткиКлиентов
		|		ПО Метки.Ссылка = МеткиКлиентов.Метка
		|			И (МеткиКлиентов.Клиент = &Ссылка)
		|ГДЕ
		|	Метки.ИспользоватьДляПредварительнойЗаписи
		|	И НЕ Метки.ПометкаУдаления";	
		
		Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МеткиКлиентов.Метка КАК Метка,
		|	МеткиКлиентов.Активна КАК Активна
		|ПОМЕСТИТЬ МеткиДокументаКлиента
		|ИЗ
		|	РегистрСведений.МеткиКлиентов КАК МеткиКлиентов
		|ГДЕ
		|	МеткиКлиентов.Клиент = &Ссылка
		|	И МеткиКлиентов.Активна
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	Метки.Ссылка КАК Метка,
		|	ЕСТЬNULL(МеткиДокументаКлиента.Активна, ЛОЖЬ) КАК Активна,
		|	Метки.Наименование КАК ПредставлениеМетки,
		|	Метки.ЦветМетки КАК ЦветМетки,
		|	Метки.ЦветТекстаБелый КАК ЦветТекстаБелый
		|ИЗ
		|	Справочник.Метки КАК Метки
		|		ЛЕВОЕ СОЕДИНЕНИЕ МеткиДокументаКлиента КАК МеткиДокументаКлиента
		|		ПО Метки.Ссылка = МеткиДокументаКлиента.Метка
		|ГДЕ
		|	Метки.ИспользоватьДляПредварительнойЗаписи
		|	И НЕ Метки.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПредставлениеМетки";
		
		Запрос.УстановитьПараметр("Ссылка", Объект.Контрагент);
		
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Метка Из Результат Цикл
		
		СтрокаТаблицы = ТаблицаМеток.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Метка);
		
		Если ЗначениеЗаполнено(Метка.ЦветМетки) Тогда
			
			ЦветМетки = ЗначениеИзСтрокиВнутр(Метка.ЦветМетки);
			
			Если ЦветМетки.Вид = ВидЦвета.АвтоЦвет Или (ЦветМетки.Красный = 255 И ЦветМетки.Зеленый = 255 И ЦветМетки.Синий = 255) Тогда
				ЦветФона = Новый Цвет(242, 242, 242);
			Иначе
				ЦветФона = ЦветМетки;
			КонецЕсли;
			
		Иначе
			ЦветФона = Новый Цвет(242, 242, 242);
			
		КонецЕсли;
		
		СтрокаТаблицы.ЦветФона = ЦветФона;
		
	КонецЦикла;

КонецПроцедуры

