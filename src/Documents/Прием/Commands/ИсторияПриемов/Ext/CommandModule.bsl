
#Область ОбработчикиСобытий

&НаКлиенте 
// Процедура, Обработчик события "ОбработкаКоманды".
//
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыФормы = Новый Структура();
	Если ЗначениеЗаполнено(ПараметрКоманды) Тогда 
		Если ТипЗнч(ПараметрКоманды) = Тип("ДокументСсылка.Прием") Тогда  
			ПараметрыФормы.Вставить("Контрагент", ПациентИзДокумента(ПараметрКоманды));
		Иначе
			ПараметрыФормы.Вставить("Контрагент", ПараметрКоманды);
		КонецЕсли;
	КонецЕсли;	
	ОткрытьФорму("Документ.Прием.Форма.ФормаСпискаКонтрагенты", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	
КонецПроцедуры

&НаСервере
// Функция, возвращает пациента из приема.
//
Функция ПациентИзДокумента(Документ)  
	
	Возврат Документ.Контрагент;	
	
КонецФункции

#КонецОбласти