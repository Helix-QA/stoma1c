// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Процедура ОбновитьПанельДниНедели()
	
	Если ПЗГрафикаРежимОтображения = 1 Тогда
		КонецМесяца      = КонецМесяца(Объект.Дата);
		НомерВсегоНедель = Цел((День(КонецМесяца) - ДеньНедели(КонецМесяца)) / 7) + ?((День(КонецМесяца) - ДеньНедели(КонецМесяца)) % 7 > 0, 1, 0) + 1;	
		НомерНедели      = Цел((День(Объект.Дата) + ДеньНедели(НачалоМесяца(Объект.Дата) ) - 2 ) / 7) + 1;
		Элементы.ДатаНеделяМесяца1.Пометка   = Ложь;
		Элементы.ДатаНеделяМесяца2.Пометка   = Ложь;
		Элементы.ДатаНеделяМесяца3.Пометка   = Ложь;
		Элементы.ДатаНеделяМесяца4.Пометка   = Ложь;
		Элементы.ДатаНеделяМесяца5.Пометка   = Ложь;
		Элементы.ДатаНеделяМесяца6.Пометка   = Ложь;
		Элементы.ДатаНеделяМесяца1.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 1);
		Элементы.ДатаНеделяМесяца2.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 2);
		Элементы.ДатаНеделяМесяца3.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 3);
		Элементы.ДатаНеделяМесяца4.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 4);
		Элементы.ДатаНеделяМесяца5.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 5);
		Элементы.ДатаНеделяМесяца6.Заголовок = ВернутьЗаголовокНеделиМесяца(Объект.Дата, 6);
		Элементы["ДатаНеделяМесяца" + НомерНедели].Пометка = Истина;	
		Для а = 1 По 6 Цикл
			Элементы["ДатаНеделяМесяца" + а + ""].Видимость = ?(а <= НомерВсегоНедель, Истина, Ложь);
		КонецЦикла;
	ИначеЕсли ПЗГрафикаРежимОтображения = 0 Тогда	
		Элементы.ДатаДеньНедели1.Пометка   = Ложь;
		Элементы.ДатаДеньНедели2.Пометка   = Ложь;
		Элементы.ДатаДеньНедели3.Пометка   = Ложь;
		Элементы.ДатаДеньНедели4.Пометка   = Ложь;
		Элементы.ДатаДеньНедели5.Пометка   = Ложь;
		Элементы.ДатаДеньНедели6.Пометка   = Ложь;
		Элементы.ДатаДеньНедели7.Пометка   = Ложь;	
		Элементы.ДатаДеньНедели1.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 1);
		Элементы.ДатаДеньНедели2.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 2);
		Элементы.ДатаДеньНедели3.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 3);
		Элементы.ДатаДеньНедели4.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 4);
		Элементы.ДатаДеньНедели5.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 5);
		Элементы.ДатаДеньНедели6.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 6);
		Элементы.ДатаДеньНедели7.Заголовок = ВернутьЗаголовокДняНедели(Объект.Дата, 7);		
		Элементы["ДатаДеньНедели" + ДеньНедели(Объект.Дата)].Пометка = Истина;
		Элементы.ПерейтиТекущийДень.Пометка = ?(День(Объект.Дата) = День(ТекущаяДатаСеанса()), Истина, Ложь);			
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Функция ВернутьЗаголовокДняНедели(Знач Дата, НомерДня)
	
	СтруктураСокрашенияМесяца = Новый Структура("М1, М2, М3, М4, М5, М6, М7, М8, М9, М10, М11, М12", "янв.", "фев.", "март", "апр.", "май", "июнь", "июль", "авг.", "сен.", "окт.", "нояб.", "дек.");
	Дата = НачалоНедели(Дата) + (НомерДня - 1) * 24 * 60 * 60;
	
	//Возврат "  " + Формат(Дата, "ДФ=dd") + " " + СтруктураСокрашенияМесяца["М" + Месяц(Дата)] + "  "; 
	Возврат Формат(Дата, "ДФ=dd") + " " + СтруктураСокрашенияМесяца["М" + Месяц(Дата)];
	
КонецФункции

&НаСервереБезКонтекста
// Процедура - обработчик события ПриИзменении поля ввода Дата
//
Функция ВернутьЗаголовокНеделиМесяца(Знач Дата, НомерНедели)
	
	Дата = НачалоМесяца(Дата);
	НачалоНеделиПоНомеру = НачалоНедели(Дата + (НомерНедели - 1) * 7 * 24 * 60 * 60);
	КонецНеделиПоНомеру = КонецНедели(Дата + (НомерНедели - 1) * 7 * 24 * 60 * 60);
	
	Возврат "  " + Формат(НачалоНеделиПоНомеру, "ДФ=dd") + " - " + Формат(КонецНеделиПоНомеру, "ДФ=dd")+" " +Формат(КонецНеделиПоНомеру, "ДФ=MMM") + "  ";
	
КонецФункции

///////////////////////////////////// ДОПОЛНИТЕЛЬНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ//////////////////////////////////////////////

Процедура УстановитьЦветГруппыКнопки()
	
	Если Элементы.День.Пометка Тогда 
		
		ГруппаКоманднойПанели          = Элементы.ГруппаКоманднаяПанельДни;
		
		Элементы.День.ЦветТекста       = ЭтотОбъект.ЦветаЭлементов.ЦветТекстаВыбранного;
		Элементы.ГруппаДень.ЦветФона   = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
		Элементы.Неделя.ЦветТекста     = ЭтотОбъект.ЦветаЭлементов.ЦветТекста;
		Элементы.ГруппаНеделя.ЦветФона = ЭтотОбъект.ЦветаЭлементов.ЦветФона;  
		
	Иначе
		
		ГруппаКоманднойПанели          = Элементы.ГруппаКоманднаяПанельНедели;
		
		Элементы.День.ЦветТекста       = ЭтотОбъект.ЦветаЭлементов.ЦветТекста;
		Элементы.ГруппаДень.ЦветФона   = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.Неделя.ЦветТекста     = ЭтотОбъект.ЦветаЭлементов.ЦветТекстаВыбранного;
		Элементы.ГруппаНеделя.ЦветФона = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
		
	КонецЕсли;
	
	Если ПЗФильтраГрафикаРежим = 0 И ПЗОтборПоСотрудникамРежимФильтра Тогда 
		Элементы.ГруппаОтборПоСотруднику.ЦветФона    = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.ГруппаОтборПоПомещениям.ЦветФона    = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.ГруппаОтборПоГрафику.ЦветФона    	 = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
	ИначеЕсли ПЗФильтраГрафикаРежим = 0 И НЕ ПЗОтборПоСотрудникамРежимФильтра Тогда
		Элементы.ГруппаОтборПоСотруднику.ЦветФона    = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
		Элементы.ГруппаОтборПоПомещениям.ЦветФона    = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.ГруппаОтборПоГрафику.ЦветФона    	 = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
	Иначе 
		Элементы.ГруппаОтборПоСотруднику.ЦветФона    = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.ГруппаОтборПоГрафику.ЦветФона    	 = ЭтотОбъект.ЦветаЭлементов.ЦветФона;
		Элементы.ГруппаОтборПоПомещениям.ЦветФона    = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного;
	КонецЕсли; 	
	
	Для Каждого Группа Из ГруппаКоманднойПанели.ПодчиненныеЭлементы Цикл
		
		Если Группа.ПодчиненныеЭлементы[0].Пометка Тогда 
			Группа.ЦветФона                          = ЭтотОбъект.ЦветаЭлементов.ЦветФонаВыбранного; 
			Группа.ПодчиненныеЭлементы[0].ЦветТекста = ЭтотОбъект.ЦветаЭлементов.ЦветТекстаВыбранного;
		Иначе
			Группа.ЦветФона                          = ЭтотОбъект.ЦветаЭлементов.ЦветФона; 			
			Группа.ПодчиненныеЭлементы[0].ЦветТекста = ЭтотОбъект.ЦветаЭлементов.ЦветТекста;
		КонецЕсли;  		
		
	КонецЦикла;
	
	Элементы.ПЗДекорацияКнопкаСтраницыОтбора.Видимость = Не ПЗПанельФильтраВидимость;
		
КонецПроцедуры

