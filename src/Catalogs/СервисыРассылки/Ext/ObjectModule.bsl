
#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Наименование = ИмяОбработки + ", логин - " + ?(ЗначениеЗаполнено(Пользователь), Пользователь, "(не указано)");
	КонецЕсли;
	
	Если SMSСервис.Пустая() = Ложь Тогда
		ХранилищеОбработки = Неопределено;
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти