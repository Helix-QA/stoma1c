////////////////////////////////////////////////////////////////////////////////
// Подсистема "ИнтернетПоддержкаПользователей.РаботаСКлассификаторами".
// ОбщийМодуль.РаботаСКлассификаторамиПереопределяемый.
//
// Серверные переопределяемые процедуры загрузки классификаторов:
//  - определение списка автоматический обновляемых классификаторов;
//  - определение алгоритмов обработки файлов классификаторов;
//
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

// Переопределяется список и настройки классификаторов обновления которых необходимо
// загружать из сервиса классификаторов. Для получения идентификатора необходимо
// перевести наименование объекта метаданных, данные которого планируется обновлять,
// на английский язык. При переводе рекомендуется использовать профессиональные
// программы перевода текста, либо воспользоваться услугами переводчика, т.к. при
// обнаружении смысловых ошибок в идентификаторе потребуется заводить новый классификатор
// и изменять код конфигурации.
//
// Параметры:
//  Классификаторы  - Массив - содержит настройки загрузки классификаторов.
//                    Состав настроек см. функцию РаботаСКлассификаторами.ОписаниеКлассификатора.
//
// Пример:
//	Описатель = РаботаСКлассификаторами.ОписаниеКлассификатора();
//	Описатель.Наименование               = НСтр("ru = 'Ставки рефинансирования'");
//	Описатель.Идентификатор              = "CentralBankRefinancingRate";
//	Описатель.ОбновлятьАвтоматически     = Истина;
//	Описатель.ОбщиеДанные                = Истина;
//	Описатель.СохранятьФайлВКэш          = Ложь;
//	Описатель.ОбработкаРазделенныхДанных = Ложь;
//	Классификаторы.Добавить(Описатель);
//
Процедура ПриДобавленииКлассификаторов(Классификаторы) Экспорт
	
	
КонецПроцедуры

// Переопределяются номер версии классификатора, который уже загружен в информационную базу.
// При начале использовании подсистемы "РаботаСКлассификаторами" или при подключении нового
// классификатора к сервису, неизвестно какой номер версии классификатора загружен в ИБ,
// поэтому при очередной итерации обновления данных из сервиса данные будут загружены повторно.
// Чтобы избежать повторной загрузки, необходимо указать задать начальный номер версии.
// Метод будет вызван при попытке загрузить версию классификатора, у которого установлена
// версия равная 0.
//
// Параметры:
//  Идентификатор        - Строка - идентификатор классификатора в сервисе классификаторов.
//                         Определяется в процедуре ПриДобавленииКлассификаторов.
//  НачальныйНомерВерсии - Число - номер версии загруженного классификатора.
//
// Пример:
//	Если Идентификатор = "CentralBankRefinancingRate" Тогда
//		НачальныйНомерВерсии = РегистрыСведений.СтавкиРефинансирования.НомерЗагруженнойВерсии();
//	КонецЕсли;
//
Процедура ПриОпределенииНачальногоНомераВерсииКлассификатора(Идентификатор, НачальныйНомерВерсии) Экспорт
	
	
КонецПроцедуры

// Переопределяются алгоритмы обработки файла загруженного
// из сервиса классификаторов. После обработки файла нельзя удалять
// временного хранилища, т.к. при необходимости он будет сохранен в
// кэше для последующего использования.
//
// Параметры:
//  Идентификатор           - Строка - идентификатор классификатора в сервисе классификаторов.
//                            Определяется в процедуре ПриДобавленииКлассификаторов.
//  Версия                  - Число - номер загруженной версии;
//  Адрес                   - Строка - адрес двоичных данных файла обновления во
//                            временном хранилище;
//  Обработан               - Булево - если Ложь, при обработке файла обновления были ошибки
//                            и его необходимо загрузить повторно;
//  ДополнительныеПараметры - Структура - содержит дополнительные параметры обработки.
//                            Необходимо использовать для передачи значений в переопределяемый
//                            метод РаботаСКлассификаторамиВМоделиСервисаПереопределяемый.ПриОбработкеОбластиДанных
//                            и метод ИнтеграцияПодсистемБИП.ПриОбработкеОбластиДанных..
// Пример:
//	Если Идентификатор = "CentralBankRefinancingRate" Тогда
//		Обработан = РегистрыСведений.СтавкиРефинансирования.ОбновитьДанныеРегистраИзФайла(Адрес, ДополнительныеПараметры);
//	КонецЕсли;
//
Процедура ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.РаботаВМоделиСервиса") Тогда
		МодульЗагрузкаКлассификатораУслуг = ОбщегоНазначения.ОбщийМодуль("ЗагрузкаКлассификатораУслуг");
		МодульЗагрузкаКлассификатораУслуг.ПриЗагрузкеКлассификатора(Идентификатор, Версия, Адрес, Обработан, ДополнительныеПараметры);
	КонецЕсли;

КонецПроцедуры

// Функция осуществляет подбор данных классификатора, для копирования в элемент справочника Номенклатура
// если такой услуги ещё нет, то она создается
// если услуга находится в иерархии не на первом уровне, то создается/копируется вся цепочка родителей
//
// Параметры:
//
// - СсылкиУслуг - Массив с элементами типа СправочникСсылка.КлассификаторУслуг - список значений классификатора
//   которые необходимо обработать
//
// Возвращаемое значение:
//
// - Массив с элементами типа СправочникСсылка.Номенклатура
//
Функция ПодобратьУслугиИзКлассификатора(Знач СсылкиУслуг, Группа) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	МассивУслуг = Новый Массив;
	
	Если СсылкиУслуг.Количество() = 0 Тогда
		Возврат МассивУслуг;
	КонецЕсли;
	
	СсылкиИерархия = ДополнитьМассивРодителямиСсылок(СсылкиУслуг);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкиИерархия", СсылкиИерархия);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КлассификаторНоменклатурыМедицинскихУслуг.Ссылка КАК Ссылка,
	|	КлассификаторНоменклатурыМедицинскихУслуг.ЭтоГруппа КАК ЭтоГруппа,
	|	КлассификаторНоменклатурыМедицинскихУслуг.Наименование КАК Наименование,
	|	КлассификаторНоменклатурыМедицинскихУслуг.Родитель.Наименование КАК РодительНаименование,
	|	КлассификаторНоменклатурыМедицинскихУслуг.НормаВремени КАК НормаВремени,
	|	КлассификаторНоменклатурыМедицинскихУслуг.Код КАК Код,
	|	КлассификаторНоменклатурыМедицинскихУслуг.УЕТ КАК УЕТ
	|ПОМЕСТИТЬ ВТ_КлассификаторУслуг
	|ИЗ
	|	Справочник.КлассификаторНоменклатурыМедицинскихУслуг КАК КлассификаторНоменклатурыМедицинскихУслуг
	|ГДЕ
	|	КлассификаторНоменклатурыМедицинскихУслуг.Ссылка В(&СсылкиИерархия)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(Номенклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Номенклатура,
	|	ВТ_КлассификаторУслуг.Наименование КАК Наименование,
	|	ВТ_КлассификаторУслуг.ЭтоГруппа КАК ЭтоГруппа,
	|	ВТ_КлассификаторУслуг.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ВТ_КлассификаторУслуг.РодительНаименование, """") КАК РодительНаименование,
	|	ВТ_КлассификаторУслуг.НормаВремени КАК НормаВремени,
	|	ВТ_КлассификаторУслуг.Код КАК Код,
	|	ВТ_КлассификаторУслуг.УЕТ КАК УЕТ,
	|	ВТ_КлассификаторУслуг.Ссылка КАК Классификатор
	|ПОМЕСТИТЬ УслугиБезРодителей
	|ИЗ
	|	ВТ_КлассификаторУслуг КАК ВТ_КлассификаторУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|		ПО ВТ_КлассификаторУслуг.Наименование = Номенклатура.Наименование
	|			И ВТ_КлассификаторУслуг.ЭтоГруппа = Номенклатура.ЭтоГруппа
	|ГДЕ
	|	НЕ ВТ_КлассификаторУслуг.ЭтоГруппа
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(Номенклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)),
	|	ВТ_КлассификаторУслуг.Наименование,
	|	ВТ_КлассификаторУслуг.ЭтоГруппа,
	|	ВТ_КлассификаторУслуг.Ссылка,
	|	ЕСТЬNULL(ВТ_КлассификаторУслуг.РодительНаименование, """"),
	|	ВТ_КлассификаторУслуг.НормаВремени,
	|	0,
	|	0,
	|	ВТ_КлассификаторУслуг.Ссылка
	|ИЗ
	|	ВТ_КлассификаторУслуг КАК ВТ_КлассификаторУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|		ПО ВТ_КлассификаторУслуг.Наименование = Номенклатура.Наименование
	|			И ВТ_КлассификаторУслуг.ЭтоГруппа = Номенклатура.ЭтоГруппа
	|ГДЕ
	|	ВТ_КлассификаторУслуг.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УслугиБезРодителей.Номенклатура КАК Услуга,
	|	УслугиБезРодителей.Наименование КАК Наименование,
	|	УслугиБезРодителей.Ссылка КАК Ссылка,
	|	УслугиБезРодителей.ЭтоГруппа КАК ЭтоГруппа,
	|	УслугиБезРодителей.РодительНаименование КАК РодительНаименование,
	|	ЕСТЬNULL(ВложенныйЗапрос.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Родитель,
	|	УслугиБезРодителей.НормаВремени КАК НормаВремени,
	|	УслугиБезРодителей.Код КАК КодНоменклатурыМедицинскиУслуг,
	|	УслугиБезРодителей.УЕТ КАК УЕТ,
	|	УслугиБезРодителей.Классификатор КАК Классификатор
	|ИЗ
	|	УслугиБезРодителей КАК УслугиБезРодителей
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СправочникНоменклатура.Родитель.Наименование КАК РодительНаименование,
	|			СправочникНоменклатура.ЭтоГруппа КАК ЭтоГруппа,
	|			СправочникНоменклатура.Ссылка КАК Ссылка
	|		ИЗ
	|			Справочник.Номенклатура КАК СправочникНоменклатура
	|		ГДЕ
	|			СправочникНоменклатура.ЭтоГруппа = ИСТИНА) КАК ВложенныйЗапрос
	|		ПО УслугиБезРодителей.РодительНаименование = ВложенныйЗапрос.РодительНаименование
	|			И УслугиБезРодителей.ЭтоГруппа = ВложенныйЗапрос.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтоГруппа УБЫВ,
	|	Наименование";
		
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаУслуг = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Ссылки = Новый Массив;
	Для каждого СтрокаТаблицыЗначений Из ТаблицаУслуг Цикл
		
		ПараметрыОбъекта = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицыЗначений);
		Ссылки.Добавить(ПараметрыОбъекта);
		
	КонецЦикла;
	
	МассивУслуг = СоздатьОбновитьУслуги(Ссылки, Группа);
	
	Возврат МассивУслуг;
	
КонецФункции
	
Функция ДополнитьМассивРодителямиСсылок(Знач Ссылки)
	
	ИмяТаблицы = Ссылки[0].Метаданные().ПолноеИмя();
	
	МассивСсылок = Новый Массив;
	Для каждого Ссылка Из Ссылки Цикл
		МассивСсылок.Добавить(Ссылка);
	КонецЦикла;
	
	ТекущиеСсылки = Ссылки;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Таблица.Родитель КАК Ссылка
	|ИЗ
	|	" + ИмяТаблицы + " КАК Таблица
	|ГДЕ
	|	Таблица.Ссылка В (&Ссылки)
	|	И Таблица.Родитель <> ЗНАЧЕНИЕ(" + ИмяТаблицы + ".ПустаяСсылка)";
	
	Пока Истина Цикл
		Запрос.УстановитьПараметр("Ссылки", ТекущиеСсылки);
		Результат = Запрос.Выполнить();
		Если Результат.Пустой() Тогда
			Прервать;
		КонецЕсли;
		
		ТекущиеСсылки = Новый Массив;
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			ТекущиеСсылки.Добавить(Выборка.Ссылка);
			МассивСсылок.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЦикла;
	
	Возврат МассивСсылок;
	
КонецФункции

// Функция для изменения и запись справочника Номенклатура по переданным параметрам
// если такой услуги ещё нет, то она создается
// если банк находится в иерархии не на первом уровне, то создается/копируется вся цепочка родителей
//
// Параметры:
//
// - Ссылки - Массив с элементами типа Структура - Ключи структуры - названия реквизитов справочника,
//   Значения структуры - значения данных реквизитов
// - ИгнорироватьРучноеИзменение - Булево - указание не обрабатывать услуги, измененные вручную
//   
// Возвращаемое значение:
//
// - Массив с элементами типа СправочникСсылка.Номенклатура
//
Функция СоздатьОбновитьУслуги(Ссылки, Группа)
	
	МассивУслуг = Новый Массив;
	
	Для инд = 0 По Ссылки.ВГраница() Цикл
		ПараметрыОбъект = Ссылки[инд];
		Услуга        = ПараметрыОбъект.Услуга;
		Классификатор = ПараметрыОбъект.Классификатор;
		
		Если Услуга.Пустая() Тогда
			Если ПараметрыОбъект.ЭтоГруппа Тогда
				УслугаОбъект = Справочники.Номенклатура.СоздатьГруппу();
			Иначе
				УслугаОбъект = Справочники.Номенклатура.СоздатьЭлемент();
			КонецЕсли;
		Иначе
			УслугаОбъект = Услуга.ПолучитьОбъект();
		КонецЕсли;
		
		Если Не ПараметрыОбъект.ЭтоГруппа Тогда
			ЗаполнитьЗначенияСвойств(УслугаОбъект, ПараметрыОбъект);
		Иначе
			УслугаОбъект.Наименование = ПараметрыОбъект.Наименование;
		КонецЕсли;

		Если ЗначениеЗаполнено(Группа) Тогда 
			УслугаОбъект.Родитель = Группа;
		КонецЕсли;

		УслугаОбъект.НоменклатураМедицинскихУслуг = Классификатор;
		УслугаОбъект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
		
		Если НЕ ПустаяСтрока(ПараметрыОбъект.РодительНаименование) 
			И НЕ ЗначениеЗаполнено(ПараметрыОбъект.Родитель) Тогда
			
			Родитель = СсылкаНаРодителя(ПараметрыОбъект.РодительНаименование, Истина);
				
			Если ЗначениеЗаполнено(Родитель) И Родитель.ЭтоГруппа Тогда
				УслугаОбъект.Родитель = Родитель;
			ИначеЕсли ЗначениеЗаполнено(Группа) Тогда
				УслугаОбъект.Родитель = Группа;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(УслугаОбъект.Родитель) Тогда
				ИмяСобытия = ?(ИмяСобытия = "",
					НСтр("ru = 'Подбор из классификатора'"), ИмяСобытия);
				ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Не смогли получить родителя у элемента с наименованием %1'"), СокрЛП(ПараметрыОбъект.РодительНаименование));
				ЗаписьЖурналаРегистрации(ИмяСобытия, 
					УровеньЖурналаРегистрации.Ошибка,,, ТекстОшибки);
				Прервать;
			КонецЕсли;
		КонецЕсли;
		
		Если Не ПараметрыОбъект.ЭтоГруппа
			И Не ЗначениеЗаполнено(УслугаОбъект.ЕдиницаИзмерения) Тогда
			УслугаОбъект.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
		КонецЕсли;
		
		НачатьТранзакцию();
		Попытка
			УслугаОбъект.Записать();
			ЗафиксироватьТранзакцию();
			МассивУслуг.Добавить(УслугаОбъект.Ссылка);
		Исключение
			ОтменитьТранзакцию();
			
			ИмяСобытия = ?(ИмяСобытия = "",
				НСтр("ru = 'Подбор из классификатора'"), ИмяСобытия);
			ЗаписьЖурналаРегистрации(ИмяСобытия, 
				УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			Прервать;
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат МассивУслуг;
	
КонецФункции

// Полчучение ссылки на элемент справочника Номенклатура
//
Функция СсылкаНаРодителя(Наименование, ЭтоГруппа = Ложь)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Наименование = &Наименование
	|	И Номенклатура.ЭтоГруппа = &ЭтоГруппа";
	
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Запрос.УстановитьПараметр("ЭтоГруппа"   , ЭтоГруппа);
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Результат.Пустой() Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Результат.Выгрузить()[0].Ссылка;
	
КонецФункции // СсылкаНаБанк()

#КонецОбласти
