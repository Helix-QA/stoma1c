		НайденнаяСтрока = Скидкаобъект.Получатели.НайтиСтроки(Новый Структура("Получатель", Клиент));
		Если НайденнаяСтрока.Количество() > 0 Тогда
			Скидкаобъект.Получатели.Удалить(НайденнаяСтрока[0]);
		КонецЕсли;
	КонецЕсли;
	Скидкаобъект.Записать();
	
