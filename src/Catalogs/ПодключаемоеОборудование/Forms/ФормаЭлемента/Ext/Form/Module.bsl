&НаСервере
// Функция, возвращает признак использования кассового сервера по рабочему месту
// Доработка Юля.
//  Параметры:
//    КС - СправочникСсылка.ПодключаемоеОборудование;
//    Рабочее место - СправочникСсылка.РабочиеМеста;
//  Возвращаемое значение:
//    Признак наличия на рабочем месте уже ранее настроенного КС
//
Функция ЕстьНастроенныйКассовыйСерверПоРабочемуМесту(КС, РабочееМесто)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПодключаемоеОборудование.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	|ГДЕ
	|	ПодключаемоеОборудование.ТипОборудования = ЗНАЧЕНИЕ(Перечисление.ТипыПодключаемогоОборудования.ККТ)
	|	И ПодключаемоеОборудование.УстройствоИспользуется
	|	И ПодключаемоеОборудование.ДрайверОборудования.ИмяПредопределенныхДанных = ""ДрайверКассовогоСервера""
	|	И НЕ ПодключаемоеОборудование.ПометкаУдаления
	|	И ПодключаемоеОборудование.РабочееМесто = &РабочееМесто
	|	И ПодключаемоеОборудование.Ссылка <> &ТекущийКС");
	
	запрос.УстановитьПараметр("ТекущийКС"	, КС);
	запрос.УстановитьПараметр("РабочееМесто", РабочееМесто); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Истина, Ложь);
	
КонецФункции

