	 
#Область ОбработчикиСобытийФормы	 
	 
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СписокОпераций.Добавить(Перечисления.ВидыОпераций.ПоСкладу);
	СписокОпераций.Добавить(Перечисления.ВидыОпераций.ПоСотруднику);
	СписокОпераций.Добавить(Перечисления.ВидыОпераций.ВводОстатков);

	СтрЕдиницаОтбор = ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница; 
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", СтрЕдиницаОтбор, ЗначениеЗаполнено(СтрЕдиницаОтбор));
	

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СоздатьПоСкладу(Команда)
	
	СоздатьОприходованиеЗапасов(0);

КонецПроцедуры

&НаКлиенте
Процедура СоздатьПоСОтруднику(Команда)
	
	СоздатьОприходованиеЗапасов(1);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВводОстатков(Команда)
	
	СоздатьОприходованиеЗапасов(2);

КонецПроцедуры

 #КонецОбласти
 
 #Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля СтрЕдиницаОтбор
//
Процедура СтрЕдиницаОтборПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "СтруктурнаяЕдиница", СтрЕдиницаОтбор, ЗначениеЗаполнено(СтрЕдиницаОтбор));
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля ВидОперацииОтбор
//
Процедура ВидОперацииОтборПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "ВидОперации", ВидОперацииОтбор, ЗначениеЗаполнено(ВидОперацииОтбор));
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события "ПриИзменении" поля СкладСотрудникОтбор
//
Процедура СкладСотрудникОтборПриИзменении(Элемент)
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Склад", СкладСотрудникОтбор, ЗначениеЗаполнено(СкладСотрудникОтбор));
КонецПроцедуры

&НаКлиенте
// Процедура создает новый документ "Расходный кассовый ордер".
//
Процедура СоздатьОприходованиеЗапасов(ИндексОперации)
	
	ВидОперации = СписокОпераций[ИндексОперации].Значение;
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("Основание", Новый Структура("ВидОперации, Отбор", ВидОперации, Новый Структура("Склад", СкладСотрудникОтбор)));
	// СтруктураПараметры.Вставить("Отбор", Новый Структура("Склад", СкладСотрудникОтбор));	
	ОткрытьФорму("Документ.ОприходованиеЗапасов.ФормаОбъекта", СтруктураПараметры);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
// Процедура печати.
//
Процедура ДокументПечать(Команда)	
	
	Структура = Новый Структура;
	Структура.Вставить("ИмяДокумента", "ОприходованиеЗапасов");	
	Структура.Вставить("МассивДокументов", Элементы.Список.ВыделенныеСтроки);
	
	СписокПечатныхФорм = ПолучитьСписокПечати();
	Оповещение = Новый ОписаниеОповещения("ОбработкаКоманды", УправлениеПечатьюКлиентСтоматология, Структура);									

	ПоказатьВыборИзМеню(Оповещение, СписокПечатныхФорм, ТекущийЭлемент);
	
КонецПроцедуры

&НаСервереБезКонтекста
// Функция Полчить список печатных форм.
//
Функция ПолучитьСписокПечати()                           	
	Возврат Документы.ОприходованиеЗапасов.ПолучитьСписокПечатныхФорм();	
КонецФункции

&НаКлиенте
// Процедура - Команда создать
//
Процедура КомандаСоздать(Команда)
	
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить("СоздатьПоСкладу", "По складу");
	СписокКнопок.Добавить("СоздатьПоСотруднику", "По персоналу");
	СписокКнопок.Добавить("СписокСоздатьВводОстатков", "Ввод остатков");

	Оповещение = Новый ОписаниеОповещения("КомандаСоздатьОбработкаВыбора", ЭтотОбъект, Неопределено);									
	ПоказатьВыборИзМеню(Оповещение, СписокКнопок, ТекущийЭлемент);
	
КонецПроцедуры

&НаКлиенте
// Процедура - Обработка выбора при нажатии на кнопку Создать
//
Процедура КомандаСоздатьОбработкаВыбора(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Значение = "СоздатьПоСкладу" Тогда
		
		СоздатьПоСкладу(Неопределено);
		
	ИначеЕсли Результат.Значение = "СоздатьПоСотруднику" Тогда
		
		СоздатьПоСОтруднику(Неопределено);
		
	ИначеЕсли Результат.Значение = "СписокСоздатьВводОстатков" Тогда
		
		СоздатьВводОстатков(Неопределено);

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
