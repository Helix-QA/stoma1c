// Функция - Тестирование сервера
// 
// Параметры:
//  ТипыПодключаемогоОборудования	 - 	 - 
//  Сервер							 - 	 - 
//  Порт							 - 	 - 
//  Логин							 - 	 - 
//  Пароль							 - 	 - 
//  ОписаниеОшибки					 - 	 - 
// 
// Возвращаемое значение:
//   - 
// 
Функция ПодключитьУстройство(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт

#Если НЕ МобильныйКлиент Тогда	
	
	ВыходныеПараметры = Новый Массив;
	// Если не подключен телефонный аппарат к рабочему месту то не подключаем (жрет лицензии);
	ВозможностьЗвонка = IPТелефония.ПростыеЗвонки_ПроверитьВозможностьЗвонкаНаДанномПК(Истина);
	Если Не ВозможностьЗвонка Тогда 
		ВыходныеПараметры.Добавить("");
		ВыходныеПараметры.Добавить("На данном рабочем месте нет возможности осуществлять звонки");
		Возврат Ложь;
	КонецЕсли;
			
	ОшибкиСоответствие = Новый Соответствие;
	ОшибкиСоответствие.Вставить(0, "Нет соединения");
	ОшибкиСоответствие.Вставить(2, "Лицензия истекла");
	ОшибкиСоответствие.Вставить(3, "Превышен лимит клиентов");
	ОшибкиСоответствие.Вставить(4, "Второе подключение пользователя");
		
	ПОПЫТКА
		
		НомерШага = 1; // Создание КОМ объекта для отправки запроса
		
		МассивТелефонныхАппаратовСотрудника = IPТелефония.ПолучитьСтруктуруВнутреннегоНомераПоПользователю(ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущийПользователь"), ПредопределенноеЗначение("Перечисление.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикВедисофтПростыеЗвонки"));
		
		Если КомпонентаПростыеЗвонки = Неопределено Тогда				
			КомпонентаПростыеЗвонки = Новый Структура();		
			
			Для Каждого СтрокаТЧ Из МассивТелефонныхАппаратовСотрудника Цикл 		
								
				COMОбъектПростыеЗвонки = Новый COMОбъект("CTIControlX.CTIControlX");
				
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnConnectionState,		ПриИзмененияСостоянияПодключения;
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnTransferRequest,		ПереадресоватьВходящийЗвонок;
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnCompletedCall,			ПриЗавершенииЗвонка;
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnTransferredCall,		ОбработатьВходящийЗвонок;
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnOutcomingCall,			ОбработатьИсходящийЗвонок;
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnOutcomingCallAnswer,	ОбработатьОтветНаИсходящийЗвонок;
				ДобавитьОбработчик COMОбъектПростыеЗвонки.OnTransferredCallAnswer,  ОбработатьОтветНаВходящийЗвонок;		
								
				Если ЗначениеЗаполнено(СтрокаТЧ.НомерТелефона) Тогда				
					COMОбъектПростыеЗвонки.PhoneNumber = Строка(СтрокаТЧ.НомерТелефона);				
				КонецЕсли;
				
				ИдентификаторБазы1С = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("НастройкиПростыеЗвонки", "ИдентификаторБазы1С",,, "ПростыеЗвонки");
				
				Если ИдентификаторБазы1С <> Неопределено Тогда
					COMОбъектПростыеЗвонки.BroadcastGroup = ИдентификаторБазы1С;
				КонецЕсли; 
				
				// Идентификатор должен начинаться с нижнего подчерка или буквы!!!
				
				КомпонентаПростыеЗвонки.Вставить("_" + СтрЗаменить(СтрокаТЧ.Оборудование.УникальныйИдентификатор(), "-", ""), COMОбъектПростыеЗвонки);
				
			КонецЦикла;   	
			
		КонецЕсли;
		
		НомерШага = 2; // Отправка XML запроса на сервер и получение ответа 		
		Если Параметры = Неопределено Тогда
			
			ПОIPТелефонии = IPТелефония.ОпределитьПодключаемоеОборудование(ПредопределенноеЗначение("Перечисление.ОбработчикиДрайверовПодключаемогоОборудования.ОбработчикВедисофтПростыеЗвонки"));
			Если Не ЗначениеЗаполнено(ПОIPТелефонии) Тогда
				ВыходныеПараметры.Добавить("");
				ВыходныеПараметры.Добавить("Number is not registred");			
				Возврат Ложь;
			КонецЕсли;
			Параметры = ПОIPТелефонии.Параметры.Получить();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Параметры.Сервер) = Ложь Тогда
			ВызватьИсключение "Ошибка! Необходимо произвести настройки сервера IP-телефонии в подключаемом оборудовании.";
		КонецЕсли;		
		
		АвторизованныйПользователь = Пользователи.АвторизованныйПользователь();
		УИД = СокрЛП(Строка(АвторизованныйПользователь.УникальныйИдентификатор()));
		
		Для Каждого СтрокаТЧ Из МассивТелефонныхАппаратовСотрудника Цикл
			
			ПараметрыОборудования = IPТелефония.ПолучитьПараметрыОборудования(СтрокаТЧ.оборудование);		
			Пароль = ?(ЗначениеЗаполнено(ПараметрыОборудования.Пароль), ПараметрыОборудования.Пароль, Неопределено);
			
			КлючТелефонии = "_" + СтрЗаменить(СтрокаТЧ.Оборудование.УникальныйИдентификатор(), "-", "");
			
			Если КомпонентаПростыеЗвонки[КлючТелефонии].connectionState <> 1 Тогда
				КомпонентаПростыеЗвонки[КлючТелефонии].Connect(ПараметрыОборудования.Сервер, Пароль, "1C", УИД, "", 0, 5000); 			
			КонецЕсли;
		
			Если ЗначениеЗаполнено(КомпонентаПростыеЗвонки[КлючТелефонии].errorBuffer) Тогда // КомпонентаПростыеЗвонки.connectionState <> 1 Тогда
				ОписаниеОшибки = ?(ОшибкиСоответствие.Получить(КомпонентаПростыеЗвонки[КлючТелефонии].connectionState) <> Неопределено,
				Строка(ОшибкиСоответствие.Получить(КомпонентаПростыеЗвонки[КлючТелефонии].connectionState)), КомпонентаПростыеЗвонки[КлючТелефонии].errorBuffer);
				ВыходныеПараметры.Добавить("");
				ВыходныеПараметры.Добавить(ОписаниеОшибки);			
				Возврат Ложь;
			КонецЕсли;
			
		КонецЦикла; 
		
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		ВыходныеПараметры.Добавить("");
		ВыходныеПараметры.Добавить(ОписаниеОшибки);					
		Возврат Ложь;
		
	КонецПопытки;
	
	Возврат Истина;
	
#КонецЕсли

КонецФункции

Функция ПростыеЗвонки_ПолучитьВерсиюКомпоненты(КлючТелефонии = Неопределено) Экспорт
	
	Версия = Неопределено;
	
	Попытка
		
		Если КомпонентаПростыеЗвонки = Неопределено Тогда
			IPТелефонияКлиент.ПодключитьУстройство(Неопределено, Неопределено, Неопределено, Неопределено);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КлючТелефонии) Тогда	
			Попытка
				Версия = КомпонентаПростыеЗвонки[КлючТелефонии].activeXVersion();
			Исключение
				Версия = Неопределено;
			КонецПопытки;
		КонецЕсли;
		
	Исключение
		
	КонецПопытки;
	
	Возврат Версия;
	
КонецФункции

Функция ПростыеЗвонки_ПолучитьНомерПоследнейВерсии() Экспорт
	
	АктуальнаяВерсияActiveX = Неопределено;
	ИмяФайла = КаталогВременныхФайлов()+"CTI_version.xml";
	
	Попытка
		Соединение = Новый HTTPСоединение("prostiezvonki.ru");
		Соединение.Получить("version.xml", ИмяФайла);
		
		Чтение = Новый ЧтениеXML;
		Чтение.ОткрытьФайл(ИмяФайла);
		Чтение.Прочитать();
		
	Исключение
		Возврат АктуальнаяВерсияActiveX;
		
	КонецПопытки;
	
	Пока Чтение.Прочитать() Цикл
		Если Чтение.ПолучитьАтрибут("Name") = "CTIControl_1C" Тогда
			АктуальнаяВерсияActiveX = Чтение.ПолучитьАтрибут("Version");
		КонецЕсли;
	КонецЦикла;
	
	Возврат АктуальнаяВерсияActiveX;
	
КонецФункции

Функция ПростыеЗвонки_ИсходящийЗвонокОсуществить(ПользовательSip, НомерТелефона, ОписаниеОшибки = "") Экспорт
	
	Попытка
		
		Если КомпонентаПростыеЗвонки = Неопределено Тогда
			IPТелефонияКлиент.ПодключитьУстройство(Неопределено, Неопределено, Неопределено, Неопределено);
		КонецЕсли;
		
		НомерТелефонаПриведенный = ОбщегоНазначенияКлиентСервер.ВернутьПриведенныйНомер_ПростыеЗвонки(НомерТелефона);
		
		МассивТелефонныхАппаратовСотрудника = IPТелефония.ПолучитьСтруктуруВнутреннегоНомераПоПользователю(ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущийПользователь"));
		
		Для Каждого СтрокаТЧ Из МассивТелефонныхАппаратовСотрудника Цикл
			
			КлючТелефонии = "_" + СтрЗаменить(СтрокаТЧ.Оборудование.УникальныйИдентификатор(), "-", "");
			
			Если КомпонентаПростыеЗвонки.Свойство(КлючТелефонии) Тогда 
				КомпонентаПростыеЗвонки[КлючТелефонии].Call(ПользовательSip, НомерТелефонаПриведенный);
			КонецЕсли;
		
		КонецЦикла;
	
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ОписаниеОшибки = ИнформацияОбОшибке.Описание + ?(ИнформацияОбОшибке.Причина <> Неопределено, ": " + ИнформацияОбОшибке.Причина.Описание, "");
		
	КонецПопытки;
	
КонецФункции

Процедура ПереадресоватьВходящийЗвонок(callID, from, line)
	
	ОписаниеОшибки = "";
	Если line="from_internal" Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураЛичныйМенеджер = IPТелефония.ПолучитьЛичногоМенеджераДляПереадресации(СокрЛП(from), ОписаниеОшибки);
	Если ТипЗнч(СтруктураЛичныйМенеджер) = Тип("Структура") И ЗначениеЗаполнено(СтруктураЛичныйМенеджер.НомерТелефона) Тогда
		
		МассивТелефонныхАппаратовСотрудника = IPТелефония.ПолучитьСтруктуруВнутреннегоНомераПоПользователю(ОбщегоНазначенияСтоматология.ПолучитьЗначениеПараметровСеанса("ТекущийПользователь"));
		
		Для Каждого СтрокаТЧ Из МассивТелефонныхАппаратовСотрудника Цикл
			
			КлючТелефонии = "_" + СтрЗаменить(СтрокаТЧ.Оборудование.УникальныйИдентификатор(), "-", "");
			
			Если КомпонентаПростыеЗвонки.Свойство(КлючТелефонии) Тогда 
				КомпонентаПростыеЗвонки[КлючТелефонии].Transfer(callID, СтруктураЛичныйМенеджер.НомерТелефона);
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

