// Процедура переносит текущие маркетинговыен акции в предопределенную группу "Скидки".
//
Процедура ПереносТекущихМаркетинговыхАкцийВГруппуСкидки() Экспорт 
	
	ПривелигированныйРежимДо = ПривилегированныйРежим();
	Если Не ПривелигированныйРежимДо Тогда	
		УстановитьПривилегированныйРежим(Истина);	
	КонецЕсли;

	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СкидкиНаценки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СкидкиНаценки КАК СкидкиНаценки");
	
	ТаблицаСкидок = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЗ Из ТаблицаСкидок Цикл 
		Попытка
			ТекОбъект = СтрокаТЗ.Ссылка.ПолучитьОбъект();
			ТекОбъект.Родитель = Справочники.СкидкиНаценки.Скидки;
			ТекОбъект.Записать();
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка переноса %1 в группу ""Скидки"". Описание ошибки: %2.'"), СтрокаТЗ.Ссылка, ОписаниеОшибки));      
		КонецПопытки;    		
	КонецЦикла;
	
	Если Не ПривелигированныйРежимДо Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;     	
	
КонецПроцедуры       

// Процедура добавляет вид оплаты "Бонусынй счет" в справочник "Кассы".
//
Процедура ДобавитьВидОплатыБонусныйСчетВКассы() Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый ЗАпрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Кассы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	НЕ Кассы.ВидыОплат.ВидОплаты = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.БонусныйСчет)");
	
	Результат = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЗ Из Результат Цикл 
		Попытка
			ТекОбъект = СтрокаТЗ.Ссылка.ПолучитьОбъект();
			Если ТекОбъект.ВидыОплат.Найти(Перечисления.ТипыДенежныхСредств.БонусныйСчет, "ВидОплаты") = Неопределено Тогда
				НоваяСтрока = ТекОбъект.ВидыОплат.Добавить();
				НоваяСтрока.ВидОплаты = Перечисления.ТипыДенежныхСредств.БонусныйСчет;
			КонецЕсли;
			ТекОбъект.Записать();
		Исключение	
			ОписаниеОшибки = ОписаниеОшибки();
			ТекстОшибки = СтрШаблон(НСтр("ru = 'Ошибка добавления %1 в группу ""Скидки"". Описание ошибки: %2.'"), СтрокаТЗ.Ссылка, ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("ДобавлениеВидОплатыБонусныйСчетВКасса", УровеньЖурналаРегистрации.Ошибка,,, ТекстОшибки);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);      
		КонецПопытки; 		
	КонецЦикла;    	
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

