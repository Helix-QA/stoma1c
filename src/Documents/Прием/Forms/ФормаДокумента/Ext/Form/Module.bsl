	Если СписокПолейСортировки.Количество() <= 1 Тогда 
		СообщитьПользователю = "Отобразите больше колонок для настройки сортировки!";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщитьПользователю);
		Возврат;
	КонецЕсли;
	
	ПередаваемыеПараметры = Новый Структура("ТекущаяСтраница, СписокПолейСортировкиПолиса", ТекущаяСтраница, СписокПолейСортировки);  	
	Оповещение = Новый ОписаниеОповещения("НастройкаСортировкиПодбораЗавершение", ЭтотОбъект, ПередаваемыеПараметры);		
	ПоказатьВыборИзМеню(Оповещение, СписокПолейСортировки, ТекущийЭлемент);
		
КонецПроцедуры

