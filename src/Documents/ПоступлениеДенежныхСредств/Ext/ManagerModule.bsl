#Область СлужебныеПроцедурыИФункции
////////////////////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРА ФОРМИРОВАНИЯ ПАКЕТА ДАННЫХ ДЛЯ ДВИЖЕНИЯ ДОКУМЕНТА

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура УстановитьНачальныеДанныеДокумента(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ДвиженияВРасход.Ссылка КАК Ссылка,
	|	ДвиженияВРасход.Ссылка.Дата КАК Период,
	|	ДвиженияВРасход.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ДвиженияВРасход.Ссылка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзКассы), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзКассыПредприятия))
	|			ТОГДА ЗНАЧЕНИЕ(перечисление.ТипыДенежныхСредств.ПереводыВпути)
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ДвиженияВРасход.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВыбытиеВкассу)
	|					ТОГДА ЗНАЧЕНИЕ(перечисление.ТипыДенежныхСредств.Безналичные)
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ДвиженияВРасход.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзБанка)
	|							ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПереводыВПути)
	|						ИНАЧЕ ВЫБОР
	|								КОГДА ДвиженияВРасход.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеОтЭквайера)
	|									ТОГДА ЗНАЧЕНИЕ(перечисление.ТипыДенежныхСредств.ПлатежнаяКарта)
	|							КОНЕЦ
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ТипДенежныхСредств,
	|	ВЫБОР
	|		КОГДА ДвиженияВРасход.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеОтЭквайера)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	ВЫБОР
	|		КОГДА ДвиженияВРасход.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеОтЭквайера)
	|			ТОГДА ДвиженияВРасход.Сумма + ДвиженияВРасход.Ссылка.ЭквайрингСуммаКомиссииБанка
	|		ИНАЧЕ ДвиженияВРасход.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА ДвиженияВРасход.Статья = ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА ДвиженияВРасход.Ссылка.Статья
	|		ИНАЧЕ ДвиженияВРасход.Статья
	|	КОНЕЦ КАК Статья
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредства
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ДвиженияВРасход
	|ГДЕ
	|	ДвиженияВРасход.Ссылка = &Ссылка
	|	И ДвиженияВРасход.Ссылка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзБанка), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеОтЭквайера), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзКассы), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеРозничнойВыручкиИзОперационнойКассы), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПоступлениеИзКассыПредприятия))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ДвиженияВПриход.Ссылка,
	|	ДвиженияВПриход.Ссылка.Дата,
	|	ДвиженияВПриход.Ссылка.СтруктурнаяЕдиница,
	|	ДвиженияВПриход.Ссылка.ТипДенежныхСредств,
	|	ВЫБОР
	|		КОГДА ДвиженияВПриход.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
	|			ТОГДА ДвиженияВПриход.Ссылка.Касса
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ДвиженияВПриход.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
	|					ТОГДА ДвиженияВПриход.Ссылка.БанковскийСчет
	|				ИНАЧЕ ВЫБОР
	|						КОГДА ДвиженияВПриход.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ПлатежнаяКарта)
	|							ТОГДА ДвиженияВПриход.Ссылка.ЭквайрингТерминал.Эквайер.БанковскийСчетПоУмолчанию
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ,
	|	ДвиженияВПриход.Сумма,
	|	ВЫБОР
	|		КОГДА ДвиженияВПриход.Статья = ЗНАЧЕНИЕ(Справочник.СтатьиДоходовИРасходов.ПустаяСсылка)
	|			ТОГДА ДвиженияВПриход.Ссылка.Статья
	|		ИНАЧЕ ДвиженияВПриход.Статья
	|	КОНЕЦ
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ДвиженияВПриход
	|ГДЕ
	|	ДвиженияВПриход.Ссылка = &Ссылка
	|	И ДвиженияВПриход.Ссылка.ТипДенежныхСредств <> ЗНАЧЕНИЕ(Перечисление.типыДенежныхСредств.ЛицевойСчет)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ПоступлениеДенежныхСредств.Ссылка КАК Ссылка,
	|	ПоступлениеДенежныхСредств.Ссылка.Дата КАК Период,
	|	ПоступлениеДенежныхСредств.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПоступлениеДенежныхСредств.Ссылка.Контрагент КАК Контрагент,
	|	ПоступлениеДенежныхСредств.ЛицевойСчетКонтрагента КАК ВидЛицевогоСчета,
	|	ПоступлениеДенежныхСредств.СуммаДокумента КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаДенежныеСредстваНаЛицевыхСчетах
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|ГДЕ
	|	ПоступлениеДенежныхСредств.Ссылка = &Ссылка
	|	И (ПоступлениеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВзносНаЛицевойСчет)
	|			ИЛИ ПоступлениеДенежныхСредств.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка КАК Ссылка,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата КАК Период,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент КАК Контрагент,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования КАК ДокументОснования,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПодотчетниками
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа
	|ГДЕ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка = &Ссылка
	|	И ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОтПодотчетника)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫБОР
	|		КОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика)
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	КОНЕЦ КАК ВидДвижения,
	|	1 КАК НомерСтроки,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка КАК Ссылка,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата КАК Период,
	|	ВЫБОР
	|		КОГДА НЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика)
	|			ТОГДА ВЫБОР
	|					КОГДА НЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования ССЫЛКА Документ.НарядЗаказ
	|						ТОГДА ВЫБОР
	|								КОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования ССЫЛКА Документ.ВозвратОтПокупателя
	|									ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.ДокументОснования
	|								ИНАЧЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования
	|							КОНЕЦ
	|				КОНЕЦ
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК ДокументОснования,
	|	ВЫБОР
	|		КОГДА УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Значение = ИСТИНА
	|				ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс = ЛОЖЬ
	|			ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументАванса
	|	КОНЕЦ КАК ДокументАванса,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтСтраховойКомпании)
	|				И ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования ССЫЛКА Документ.Прием
	|			ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументОснования.ПолисМедСтрахования.СтраховаяКомпания
	|		ИНАЧЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент
	|	КОНЕЦ КАК Контрагент,
	|	ВЫБОР
	|		КОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация
	|	КОНЕЦ КАК Организация,
	|	ВЫБОР
	|		КОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика)
	|				ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту)
	|			ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Сумма * -1
	|		ИНАЧЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс КАК ЭтоАванс,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаВзаиморасчетыКонтрагентов
	|ИЗ
	|	Документ.ПоступлениеДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеДенежныхСредствРасшифровкаПлатежа,
	|	Константа.УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов КАК УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов
	|ГДЕ
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Ссылка = &Ссылка
	|	И (ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации В (ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтСтраховойкомпании), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыКлиенту), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВзносНаЛицевойСчет), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратОплатыОтПоставщика), ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ВозвратЗайма))
	|			ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ПрочееПоступление)
	|				И ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.ЛицевойСчет))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	2,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Дата,
	|	NULL,
	|	ВЫБОР
	|		КОГДА УчитыватьАвансыВРазрезеПлановЛеченияИНарядЗаказов.Значение = ИСТИНА
	|				ИЛИ ПоступлениеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс = ЛОЖЬ
	|			ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.ДокументАванса
	|	КОНЕЦ,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Контрагент,
	|	ВЫБОР
	|		КОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяССылка)
	|			ТОГДА ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.СтруктурнаяЕдиница.Организация
	|		ИНАЧЕ ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Организация
	|	КОНЕЦ,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Сумма,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.ЭтоАванс,
	|	ПоступлениеДенежныхСредствРасшифровкаПлатежа.Ссылка.Договор
