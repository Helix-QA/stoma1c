&НаСервере
// Процедура - Процедура обработка команды перейти сделки этап
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура Процедура_ОбработкаКоманды_Перейти_Сделки_Этап(Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины = Неопределено)
	
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		Элемент.Заголовок = СокрЛП(СтрокаТаблицы.ЭтапСделкиНаименование);
	КонецЕсли;
	
	Команда.Подсказка = "";		
	
КонецПроцедуры

&НаСервере
// Процедура - Процедура обработка декорации заголовок этапа
//
// Параметры:
//  Элемент			 - 	 - 
//  Команда			 - 	 - 
//  ИндексСтроки	 - 	 - 
//  СтрокаТаблицы	 - 	 - 
//
Процедура Процедура_ОбработкаДекорации_ЗаголовокЭтапа(Элемент, Команда = Неопределено, ИндексСтроки, СтрокаТаблицы, ИндексСтрокиПричины = Неопределено)
	
	Если НЕ СтрокаТаблицы = Неопределено Тогда
		Если СтрокаТаблицы.ЭтапСделки = Справочники.ЭтапыСделок.Отказ И НЕ ИндексСтрокиПричины = Неопределено Тогда 
			Элемент.Заголовок = СтрокаТаблицы.ТаблицаПричинОтказов[ИндексСтрокиПричины].Наименование;
		Иначе 	
			Элемент.Заголовок = СокрЛП(СтрокаТаблицы.ЭтапСделкиНаименование);
		КонецЕсли;	
	КонецЕсли;
	
	Элемент.Подсказка = "";		
	
КонецПроцедуры

&НаСервере
// Процедура - Установить действия для элемента
//
// Параметры:
//  НовыйЭлемент - 	 - 
//  ЭлементФормы - 	 - 
//  ТипЭлемента	 - 	 - 
//
Процедура УстановитьДействияДляЭлемента(НовыйЭлемент, ЭлементФормы, ТипЭлемента)
	
	Если ТипЭлемента = Тип("ДекорацияФормы") Тогда
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("Нажатие");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("Нажатие", ИмяОбработчикаСобытия);	
		КонецЕсли;
	ИначеЕсли ТипЭлемента = Тип("ПолеФормы") Тогда	
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("ПриИзменении");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("ПриИзменении", ИмяОбработчикаСобытия);	
		КонецЕсли;
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("НачалоВыбора");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("НачалоВыбора", ИмяОбработчикаСобытия);	
		КонецЕсли;
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("НачалоВыбораИзСписка");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("НачалоВыбораИзСписка", ИмяОбработчикаСобытия);	
		КонецЕсли;		
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("Очистка");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("Очистка", ИмяОбработчикаСобытия);	
		КонецЕсли;
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("Открытие");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("Открытие", ИмяОбработчикаСобытия);	
		КонецЕсли;		
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("ОбработкаВыбора");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("ОбработкаВыбора", ИмяОбработчикаСобытия);	
		КонецЕсли;		
		ИмяОбработчикаСобытия = ЭлементФормы.ПолучитьДействие("ОбработкаВыбора");
		Если НЕ ИмяОбработчикаСобытия = "" Тогда 
			НовыйЭлемент.УстановитьДействие("ОбработкаВыбора", ИмяОбработчикаСобытия);	
		КонецЕсли;		
	КонецЕсли;
	        
КонецПроцедуры

#КонецОбласти

&НаСервере
// Процедура - Обновить общие сведения
//
// Параметры:
//  ОбновитьЗаявки	 - 	 - 
//  ОбновитьКлиентов - 	 - 
//  ОбновитьЗадачи	 - 	 - 
//  ОтборСотрудники	 - 	 - 
//
Процедура ОбновитьОбщиеСведения(ЗНАЧ ОтборСотрудники = Неопределено, ОбновитьЗаявки = Истина, ОбновитьКлиентов = Истина, ОбновитьОбщиеПоСделкам = Истина, ОбновитьЗадачи = Истина)
	
	Если ОтборСотрудники = Неопределено ИЛИ ОтборАдресатСведенийТип = "Все" Тогда 	
		Если ОтборАдресатСведенийТип = "ИзСписка" Тогда
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
			ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, Неопределено); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
		ИначеЕсли ОтборАдресатСведенийТип = "Мои" Тогда 
			ОтборСотрудники = Новый Массив();
			ОтборСотрудники.Добавить(ТекущийПользователь);
		Иначе 
			ОтборСотрудники = Неопределено;// УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина);
		КонецЕсли;
	КонецЕсли;

	Если ОбновитьЗаявки = Истина Тогда 
		ОбновитьСведенияПоЗаявкам(ОтборСотрудники);
	КонецЕсли;
	
	Если ОбновитьКлиентов = Истина Тогда 
    	ОбновитьСведенияПоКлиентам(ОтборСотрудники);
	КонецЕсли;
	
	Если ОбновитьОбщиеПоСделкам = Истина Тогда 
		ОбновитьОбщиеСведенияПоСделкам(ОтборСотрудники);
	КонецЕсли;

	Если ОбновитьЗадачи = Истина Тогда 
		ОбновитьСведенияПоЗадачам(ОтборСотрудники);
	КонецЕсли;

КонецПроцедуры

&НаСервере
// Процедура - Обновить сведения по заявкам
//
// Параметры:
//  ОтборСотрудники	 - 	 - 
//
Процедура ОбновитьСведенияПоЗаявкам(ЗНАЧ ОтборСотрудники = Неопределено)
	
	Запрос = Новый Запрос;	
	Если ОтборСотрудники = Неопределено Тогда
		Если ОтборАдресатСведенийТип = "Мои" Тогда 
			ОтборСотрудники = Новый Массив;
			ОтборСотрудники.Добавить(ТекущийПользователь);
		ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина);
		Иначе 	
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
			ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, СписокМенеджеровПоПродажам.ВыгрузитьЗначения()); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
		КонецЕсли;
	КонецЕсли;	
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Сотрудники.Ссылка КАК Исполнитель
	               |ПОМЕСТИТЬ ТаблицаИсполнителей
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.Ссылка В(&МассивСотрудников)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Заявки.Ссылка) КАК КоличествоНовыхЗаявок
	               |ИЗ
	               |	Справочник.Заявки КАК Заявки
	               |ГДЕ
	               |	Заявки.ПометкаУдаления = ЛОЖЬ
	               |	И Заявки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.НеОбработана)
	               |	И Заявки.ОсновнойМенеджер В
	               |			(ВЫБРАТЬ
	               |				ТаблицаИсполнителей.Исполнитель
	               |			ИЗ
	               |				ТаблицаИсполнителей)
	               |	И Заявки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Заявки.Ссылка) КАК КоличествоЗаявокВРаботе
	               |ИЗ
	               |	Справочник.Заявки КАК Заявки
	               |ГДЕ
	               |	Заявки.ПометкаУдаления = ЛОЖЬ
	               |	И Заявки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Перезвонить), ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.ОтвеченныйЗвонок), ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.ОтвеченныйДиалог), ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.ПропущенныйЗвонок))
	               |	И Заявки.ОсновнойМенеджер В
	               |			(ВЫБРАТЬ
	               |				ТаблицаИсполнителей.Исполнитель
	               |			ИЗ
	               |				ТаблицаИсполнителей)
	               |	И Заявки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
	
	Если ЗначениеЗаполнено(ОтборСтруктурнаяЕдиница) Тогда 
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ОтборСтруктурнаяЕдиница);
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Заявки.СтруктурнаяЕдиница = &СтруктурнаяЕдиница", "ИСТИНА");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОтборСотрудники) Тогда 
		Запрос.УстановитьПараметр("МассивСотрудников", ОтборСотрудники);
		РезультатЗапроса 						= Запрос.ВыполнитьПакет();
		ВыборкаКоличестваНовыхЗаявок 			= РезультатЗапроса[1].Выбрать();
		ВыборкаКоличестваЗаявокВРаботе 			= РезультатЗапроса[2].Выбрать();
	Иначе 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Сотрудники.Ссылка КАК Исполнитель
	               |ПОМЕСТИТЬ ТаблицаИсполнителей
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.Ссылка В(&МассивСотрудников)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |", "");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Заявки.ОсновнойМенеджер В
	               |			(ВЫБРАТЬ
	               |				ТаблицаИсполнителей.Исполнитель
	               |			ИЗ
	               |				ТаблицаИсполнителей)", "ИСТИНА");
		
		РезультатЗапроса 						= Запрос.ВыполнитьПакет();
		ВыборкаКоличестваНовыхЗаявок 			= РезультатЗапроса[0].Выбрать();
		ВыборкаКоличестваЗаявокВРаботе 			= РезультатЗапроса[1].Выбрать();
		
	КонецЕсли;	
	
	Если ВыборкаКоличестваНовыхЗаявок.Следующий() Тогда
		КоличествоНовыхЗаявок = ВыборкаКоличестваНовыхЗаявок.КоличествоНовыхЗаявок;
	Иначе
		КоличествоНовыхЗаявок = 0;
	КонецЕсли;	
	Элементы.ПерейтиНовыеЗаявки.Заголовок	= ?(КоличествоНовыхЗаявок > 0, Строка(КоличествоНовыхЗаявок) + " " + СтроковыеФункцииКлиентСервер.ВернутьСловоСклоненноеПоЧислу("Новая", КоличествоНовыхЗаявок), Нстр("ru='нет новых заявок';en='not new applications'")); // подготовить к переводу
	Элементы.ПерейтиНовыеЗаявки.Доступность = КоличествоНовыхЗаявок > 0;				
	// Элементы.ПерейтиНовыеЗаявки.ЦветТекста 				= ?(КоличествоНовыхЗаявок > 0, Новый Цвет(), Новый Цвет(242, 242, 242));					
	
	Если ВыборкаКоличестваЗаявокВРаботе.Следующий() Тогда
		КоличествоЗаявокВРаботе = ВыборкаКоличестваЗаявокВРаботе.КоличествоЗаявокВРаботе;
	Иначе 	
		КоличествоЗаявокВРаботе = 0;		
	КонецЕсли;
	Элементы.ПерейтиНеОбработанныеЗаявки.Заголовок 	 = Строка(КоличествоЗаявокВРаботе) + Нстр("ru=' в работе';en=' at work'");	
	Элементы.ПерейтиНеОбработанныеЗаявки.Доступность = КоличествоЗаявокВРаботе > 0;					
	Элементы.ПерейтиНеОбработанныеЗаявки.ЦветТекста  = ?(КоличествоЗаявокВРаботе > 0, Новый Цвет(255, 0, 0), Новый Цвет(242, 242, 242));					
	
КонецПроцедуры

&НаСервере
// Процедура - Обновить сведения по клиентам
//
// Параметры:
//  ОтборСотрудники	 - 	 - 
//
Процедура ОбновитьСведенияПоКлиентам(ЗНАЧ ОтборСотрудники = Неопределено)
	
	Если ОтборСотрудники = Неопределено Тогда
		Если ОтборАдресатСведенийТип = "Мои" Тогда 
			ОтборСотрудники = Новый Массив;
			ОтборСотрудники.Добавить(ТекущийПользователь);
		ИначеЕсли ОтборАдресатСведенийТип = "Все" Тогда
			ОтборСотрудники = СписокМенеджеровПоПродажам.ВыгрузитьЗначения();
		Иначе 	
			ОтборСотрудники = УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники");
			ОтборСотрудники = ?(ЗначениеЗаполнено(ОтборСотрудники), ОтборСотрудники, СписокМенеджеровПоПродажам.ВыгрузитьЗначения()); // УправлениеИнтерфейсамиСервер.ВсеЗначенияВыбораДинамическогоМеню(ЭтаФорма, "МенюОтборСотрудники", Истина));		
		КонецЕсли;
	КонецЕсли;	
	
	Запрос 			= Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.Текст 	= "ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	             	  |	СотрудникиМестаРаботы.Сотрудник КАК Сотрудник
	             	  |ПОМЕСТИТЬ ТаблицаСотрудников
	             	  |ИЗ
	             	  |	РегистрСведений.НастройкиСотрудников КАК СотрудникиМестаРаботы
	             	  |ГДЕ
	             	  |	СотрудникиМестаРаботы.Сотрудник В(&МассивМенеджеров)
	             	  |	И ВЫБОР
	             	  |			КОГДА СотрудникиМестаРаботы.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
	             	  |				ТОГДА ИСТИНА
	             	  |			ИНАЧЕ СотрудникиМестаРаботы.ДатаУвольнения > &ТекущаяДата
	             	  |		КОНЕЦ
	             	  |	И СотрудникиМестаРаботы.Сотрудник.ПометкаУдаления = ЛОЖЬ
	             	  |	И СотрудникиМестаРаботы.Сотрудник.ЭтоГруппа = ЛОЖЬ
	             	  |	И СотрудникиМестаРаботы.СтруктурнаяЕдиница.ПометкаУдаления = ЛОЖЬ
	             	  |	И СотрудникиМестаРаботы.СтруктурнаяЕдиница.ЭтоГруппа = ЛОЖЬ
	             	  |;
	             	  |
	             	  |////////////////////////////////////////////////////////////////////////////////
	             	  |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             	  |	КонтрагентыСведенияДляСписка.Контрагент КАК Контрагент,
	             	  |	КонтрагентыСведенияДляСписка.СледующаяЗадача КАК СледующаяЗадача,
	             	  |	КонтрагентыСведенияДляСписка.ТекущаяСделка КАК ТекущаяСделка
	             	  |ПОМЕСТИТЬ ТаблицаКлиентыДляСписка
	             	  |ИЗ
	             	  |	РегистрСведений.КонтрагентыСведенияДляСписка КАК КонтрагентыСведенияДляСписка
	             	  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаСотрудников КАК ТаблицаСотрудников
	             	  |		ПО КонтрагентыСведенияДляСписка.Контрагент.Куратор = ТаблицаСотрудников.Сотрудник
	             	  |ГДЕ
	             	  |	КонтрагентыСведенияДляСписка.Контрагент.ПометкаУдаления = ЛОЖЬ
	             	  |	И КонтрагентыСведенияДляСписка.Контрагент.ЭтоГруппа = ЛОЖЬ
	             	  |	И КонтрагентыСведенияДляСписка.Контрагент.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	             	  |	И КонтрагентыСведенияДляСписка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКонтрагентов.Потенциальный)
	             	  |
