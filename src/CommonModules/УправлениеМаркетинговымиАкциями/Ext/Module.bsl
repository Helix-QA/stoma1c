		|ИЗ
		|	ТаблицаУслуг КАК ТаблицаУслуг";
		
		МассивТекст.Добавить(Текст); 
	КонецЕсли;   	
	
	Запрос.Текст = СтрСоединить(МассивТекст, Символы.ПС);
	Запрос.Выполнить();
		  	
	// Заполняем стоимость подарка
	Для каждого СтрокаТЧСкидки Из ТаблицаСкидок Цикл
		Если СтрокаТЧСкидки.СпособПредоставленияСкидки = Перечисления.СпособПредоставленияСкидки.Подарок Тогда
			СтрокаТЧСкидки.СуммаСкидки = 0;
			Для каждого СтрокаНаборПодарков Из СтрокаТЧСкидки.СкидкаНаценка.НаборПодарков Цикл
				СтруктураПолученияЦены = Новый Структура();
				СтруктураПолученияЦены.Вставить("СтруктурнаяЕдиница",		СтруктураПараметров.СтруктурнаяЕдиница);
				СтруктураПолученияЦены.Вставить("ВидЦен", 					?(СтруктураПараметров.Свойство("ВидЦен"), СтруктураПараметров.ВидЦен, Справочники.ВидыЦен.Розничная));
