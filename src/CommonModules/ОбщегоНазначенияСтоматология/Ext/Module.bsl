// Функция, возвращает RGB код цвета по его названию
//
Функция ПолучитьЦвет(НазваниеЦвета)Экспорт
	
	Если НЕ НазваниеЦвета = "" и НазваниеЦвета.Вид = ВидЦвета.Абсолютный Тогда
		Красный = НазваниеЦвета.Красный;
		Зеленый = НазваниеЦвета.Зеленый;
		Синий   = НазваниеЦвета.Синий;
		Red   = КонвертацияСистемСчисления(Красный, Истина);
		Green = КонвертацияСистемСчисления(Зеленый, Истина);
		Blue  = КонвертацияСистемСчисления(Синий, Истина);
		Возврат "#"+Red+Green+Blue;
	ИначеЕсли НЕ НазваниеЦвета = "" и НазваниеЦвета.Вид = ВидЦвета.ЭлементСтиля Тогда
		НазваниеЦвета = Сред(НазваниеЦвета, 8, 100);
		Если НазваниеЦвета = "Фон формы" Тогда
			Возврат "#FCFAEB";
		ИначеЕсли НазваниеЦвета = "Текст формы" Тогда
			Возврат "#413003";
		ИначеЕсли НазваниеЦвета = "Фон кнопки" Тогда
			Возврат "#F5F2DD";
		ИначеЕсли НазваниеЦвета = "Текст кнопки" Тогда
			Возврат "#896704";
		ИначеЕсли НазваниеЦвета = "Фон редактирования" Тогда
			Возврат "#FFFFFF";
		ИначеЕсли НазваниеЦвета = "Текст редактирования" Тогда
			Возврат "#000000";
		ИначеЕсли НазваниеЦвета = "Фон выделения редактирования" Тогда
			Возврат "#536AC2";
		ИначеЕсли НазваниеЦвета = "Текст выделения редактирования" Тогда
			Возврат "#FFFFFF";
		ИначеЕсли НазваниеЦвета = "Альтернативный фон редактирования" Тогда
			Возврат "#F5FBF7";
		ИначеЕсли НазваниеЦвета = "Фон подсказки" Тогда
			Возврат "#FFFAD9";
		ИначеЕсли НазваниеЦвета = "Текст подсказки" Тогда
			Возврат "#000000";	
		ИначеЕсли НазваниеЦвета = "Особый текст" Тогда
			Возврат "#FF0000";	
		ИначеЕсли НазваниеЦвета = "Отрицательное число" Тогда
			Возврат "#FF0000";	
		ИначеЕсли НазваниеЦвета = "Рамка" Тогда
			Возврат "#B3AC86";	
		ИначеЕсли НазваниеЦвета = "Фон шапки отчета" Тогда
			Возврат "#F4ECC5";	
		ИначеЕсли НазваниеЦвета = "Фон группировки отчета 1" Тогда
			Возврат "#F8F2D8";	
		ИначеЕсли НазваниеЦвета = "Фон группировки отчета 2" Тогда
			Возврат "#F8F9EC";	
		ИначеЕсли НазваниеЦвета = "Линия отчета" Тогда
			Возврат "#CCC085";	
		ИначеЕсли НазваниеЦвета = "ВыполненнаяЗадача" Тогда
			Возврат "#2F4F4F";
		ИначеЕсли НазваниеЦвета = "ЗавершенныйБизнесПроцесс" Тогда
			Возврат "#808080";
		ИначеЕсли НазваниеЦвета = "НеСтартованныйБизнесПроцесс" Тогда
			Возврат "#B22222";	
		ИначеЕсли НазваниеЦвета = "ПользовательВыбранный" Тогда
			Возврат "#DCDCDC";
		ИначеЕсли НазваниеЦвета = "ПоясняющийТекст" Тогда
			Возврат "#1955AE";	
		ИначеЕсли НазваниеЦвета = "ПросроченнаяЗадача" Тогда
			Возврат "#800000";	
		ИначеЕсли НазваниеЦвета = "РольБезИсполнителей" Тогда
			Возврат "#800000";	
		ИначеЕсли НазваниеЦвета = "УдаленныйДополнительныйРеквизитЦвет" Тогда
			Возврат "#FF0000";
		ИначеЕсли НазваниеЦвета = "ФайлЗанятыйДругимПользователем" Тогда
			Возврат "#808080";	
		ИначеЕсли НазваниеЦвета = "ФайлЗанятыйТекущимПользователем" Тогда
			Возврат "#008000";		
		КонецЕсли;		
	ИначеЕсли НЕ НазваниеЦвета = "" Тогда	
		Возврат Сред(НазваниеЦвета, Найти(НазваниеЦвета, "(")+1, СтрДлина(НазваниеЦвета) - Найти(НазваниеЦвета, "(")-1); 			
