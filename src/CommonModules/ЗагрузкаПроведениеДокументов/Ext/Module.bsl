КонецПроцедуры

// Процедура - Актуализировать таблицу лицевых счетов на этапе реализация
//
// Параметры:
//  ТаблицаЛицевыхСчетовВБазе		 - 	 - 
//  ТаблицаЛицевыхСчетов			 - 	 - 
//  ТаблицаВидовЛицевыхСчетовВБазе	 - 	 - 
//
Процедура АктуализироватьТаблицуЛицевыхСчетовНаЭтапеРеализация(ТаблицаЛицевыхСчетовВБазе, ТаблицаЛицевыхСчетов, ТаблицаВидовЛицевыхСчетовВБазе, ТекстовыйНакопитель)

	СтепеньРодстваПрочее = ПолучитьСтепеньРодстваПрочее();

	Для Каждого СтрокаЛицевойСчет Из ТаблицаЛицевыхСчетов Цикл
		СообщилиПрогресс = Ложь;
		Если ЗначениеЗаполнено(СтрокаЛицевойСчет.Клиент) И НЕ СтрокаЛицевойСчет.Аннулирован <> 0 Тогда 
			Если СтрокаЛицевойСчет.ТипОплаты = 6 ИЛИ СтрокаЛицевойСчет.ТипОплаты = 7 Тогда
				Если НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.ПкоСсылка) И НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.РкоСсылка) Тогда // И НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.Ссылка) Тогда				
					СтруктураВидаЛицевогоСчета 	= ПолучитьВидЛицевогоСчета(СтрокаЛицевойСчет.ТипОплаты, ТаблицаВидовЛицевыхСчетовВБазе);
					Если НЕ СтруктураВидаЛицевогоСчета = Неопределено Тогда
						СтруктураПоиска = Новый Структура;
						Если НЕ ЗначениеЗаполнено(СтрокаЛицевойСчет.НомерЛС) Тогда 
							СтруктураПоиска.Вставить("ВладелецЛицевогоСчета", СтрокаЛицевойСчет.Клиент);
						Иначе 
							СтруктураПоиска.Вставить("КодСинхронизации", СтрокаЛицевойСчет.НомерЛС);
							СтруктураПоиска.Вставить("ПрефиксСинхронизации", СтрокаЛицевойСчет.ПрефиксСинхронизации);							
						КонецЕсли;
						Если ЗначениеЗаполнено(СтруктураВидаЛицевогоСчета.Ссылка) Тогда 
							СтруктураПоиска.Вставить("ВидЛицевогоСчета", СтруктураВидаЛицевогоСчета.Ссылка);
						КонецЕсли;
						МассивСтрокЛС = ТаблицаЛицевыхСчетовВБазе.НайтиСтроки(СтруктураПоиска);
						Если МассивСтрокЛС.Количество() = 0 Тогда 
							// Создаем ЛС и добавляем в таблицу
							ЛицевойСчетКонтрагентаОбъект = Справочники.ЛицевыеСчета.СоздатьЭлемент();
							ЛицевойСчетКонтрагентаОбъект.ОбменДанными.Загрузка = Истина;									
							ЛицевойСчетКонтрагентаОбъект.Заполнить(Неопределено);// Новый Структура("СтруктураДанныхПриПроведенииДенежныхСредств", Новый Структура("Владелец, Сертификат, ВидЛицевогоСчета, ДатаОткрытия", СтрокаЛицевойСчет.Клиент, Неопределено, ВидЛицевогоСчета, Неопределено)));				
							// Заполняем дату открытия
							// ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия = ТекущаяДатаСеанса();
							Если ЗначениеЗаполнено(СтрокаЛицевойСчет.ДатаПродажи) И ЗначениеЗаполнено(СтрокаЛицевойСчет.ДатаОплаты) Тогда 
								ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия = ?(Мин(СтрокаЛицевойСчет.ДатаПродажи, СтрокаЛицевойСчет.ДатаОплаты) > ТекущаяДатаСеанса(), НачалоДня(ТекущаяДатаСеанса()), Мин(СтрокаЛицевойСчет.ДатаПродажи, СтрокаЛицевойСчет.ДатаОплаты));
							ИначеЕсли ЗначениеЗаполнено(СтрокаЛицевойСчет.ДатаПродажи) Тогда 
								ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия = ?(СтрокаЛицевойСчет.ДатаПродажи > ТекущаяДатаСеанса(), НачалоДня(ТекущаяДатаСеанса()), СтрокаЛицевойСчет.ДатаПродажи);
							ИначеЕсли ЗначениеЗаполнено(СтрокаЛицевойСчет.ДатаОплаты) Тогда 
								ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия = ?(СтрокаЛицевойСчет.ДатаОплаты > ТекущаяДатаСеанса(), НачалоДня(ТекущаяДатаСеанса()), СтрокаЛицевойСчет.ДатаОплаты);
							Иначе 
								ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия = НачалоДня(ТекущаяДатаСеанса());
							КонецЕсли;
							ЛицевойСчетКонтрагентаОбъект.ВидЛицевогоСчета 							= СтруктураВидаЛицевогоСчета.Ссылка;
							ЛицевойСчетКонтрагентаОбъект.ВладелецЛицевогоСчета 						= СтрокаЛицевойСчет.Клиент;									
							Если ЗначениеЗаполнено(ЛицевойСчетКонтрагентаОбъект.ВидЛицевогоСчета) Тогда
								ЛицевойСчетКонтрагентаОбъект.ОграничениеПоСрокуДействия             = СтруктураВидаЛицевогоСчета.ОграничениеПоСрокуДействия;
								ЛицевойСчетКонтрагентаОбъект.ОграничиватьСуммуСписанияСоСчета       = СтруктураВидаЛицевогоСчета.ОграничиватьСуммуСписанияСоСчета;
								ЛицевойСчетКонтрагентаОбъект.ПроцентОграниченияСуммыСписанияСоСчета = СтруктураВидаЛицевогоСчета.ПроцентОграниченияСуммыСписанияСоСчета;
								ЛицевойСчетКонтрагентаОбъект.Организация                            = СтруктураВидаЛицевогоСчета.Организация;
								ЛицевойСчетКонтрагентаОбъект.НеВестиУчетВРазрезеОрганизаций         = СтруктураВидаЛицевогоСчета.НеВестиУчетВРазрезеОрганизаций;
								ЛицевойСчетКонтрагентаОбъект.Внешний                                = СтруктураВидаЛицевогоСчета.Внешний;
								// Заполним табличную часть ПакетУслуг
								ЛицевойСчетКонтрагентаОбъект.ПакетУслугСоставУслуг.Загрузить(СтруктураВидаЛицевогоСчета.ПакетУслугСоставУслуг); 
								// Заполним срок действия ЛС
								Если СтруктураВидаЛицевогоСчета.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийПакетовУслуг.СрокДействия_С_По Тогда 
									ЛицевойСчетКонтрагентаОбъект.СрокДействияНачало 				= НачалоДня(СтруктураВидаЛицевогоСчета.СрокДействияДатойС);
									ЛицевойСчетКонтрагентаОбъект.СрокДействияКонец 					= НачалоДня(СтруктураВидаЛицевогоСчета.СрокДействияДатойПо) - 1;			
								ИначеЕсли СтруктураВидаЛицевогоСчета.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийПакетовУслуг.СрокОграниченПериодом Тогда 
									ЛицевойСчетКонтрагентаОбъект.СрокДействияНачало 				= НачалоДня(?(ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия = Дата(1,1,1), ТекущаяДатаСеанса(), ЛицевойСчетКонтрагентаОбъект.ДатаОткрытия));
									Если ЗначениеЗаполнено(СтруктураВидаЛицевогоСчета.СрокДействияТип) Тогда
										Если СтруктураВидаЛицевогоСчета.СрокДействияТип = Перечисления.Периодичность.День Тогда 
											ЛицевойСчетКонтрагентаОбъект.СрокДействияКонец 			= (ЛицевойСчетКонтрагентаОбъект.СрокДействияНачало + СтруктураВидаЛицевогоСчета.СрокДействия * (60*60*24)) - 1;
										ИначеЕсли СтруктураВидаЛицевогоСчета.СрокДействияТип = Перечисления.Периодичность.Месяц Тогда	
											ЛицевойСчетКонтрагентаОбъект.СрокДействияКонец 			= ДобавитьМесяц(ЛицевойСчетКонтрагентаОбъект.СрокДействияНачало, СтруктураВидаЛицевогоСчета.СрокДействия) - 1;
										ИначеЕсли СтруктураВидаЛицевогоСчета.СрокДействияТип = Перечисления.Периодичность.Год Тогда	
											ЛицевойСчетКонтрагентаОбъект.СрокДействияКонец 			= (ДобавитьМесяц(ЛицевойСчетКонтрагентаОбъект.СрокДействияНачало, СтруктураВидаЛицевогоСчета.СрокДействия * 12)) - 1;
										КонецЕсли;	
									Иначе 
										ЛицевойСчетКонтрагентаОбъект.СрокДействияКонец 				= Дата(1,1,1);
									КонецЕсли;			
								ИначеЕсли СтруктураВидаЛицевогоСчета.ОграничениеПоСрокуДействия = Перечисления.ТипыОграниченийПакетовУслуг.Бессрочный Тогда 
									ЛицевойСчетКонтрагентаОбъект.СрокДействияНачало 				= Дата(1,1,1);
									ЛицевойСчетКонтрагентаОбъект.СрокДействияКонец 					= Дата(1,1,1);		
								КонецЕсли;
							КонецЕсли;
							ЛицевойСчетКонтрагентаОбъект.УстановитьНовыйКод();
							// Сформируем наименование лицевого счета
							ЛицевойСчетКонтрагентаОбъект.Наименование 								= Справочники.ЛицевыеСчета.СформироватьНаименование(ЛицевойСчетКонтрагентаОбъект.Код, ЛицевойСчетКонтрагентаОбъект.ВидЛицевогоСчета, ЛицевойСчетКонтрагентаОбъект.ВладелецЛицевогоСчета);									
							ЛицевойСчетКонтрагентаОбъект.КодСинхронизации = ?(СтрокаЛицевойСчет.НомерЛС = Неопределено, 0, СтрокаЛицевойСчет.НомерЛС);
							ЛицевойСчетКонтрагентаОбъект.ПрефиксСинхронизации 	= СтрокаЛицевойСчет.ПрефиксСинхронизации;
							ЛицевойСчетКонтрагентаОбъект.Комментарий 			= СтрокаЛицевойСчет.ПрефиксСинхронизации + " - " + ЛицевойСчетКонтрагентаОбъект.КодСинхронизации;							
							Попытка
								ЛицевойСчетКонтрагентаОбъект.Записать();
								ЗаполнитьЗначенияСвойств(ТаблицаЛицевыхСчетовВБазе.Добавить(), ЛицевойСчетКонтрагентаОбъект);
							Исключение
								// Запись в лог
								ТекстовыйНакопитель.ЗаписатьБезОбработки(СтрШаблон(НСтр("ru='%1 Ошибка создания лицевого счета клиента ""%2"" Вид счета: %3 %1 %4';en='%1 Mistake create facial accounts client ""%2"" View accounts: %3 %1 %4'"), Символы.ПС, Строка(СтрокаЛицевойСчет.Клиент), Строка(СтруктураВидаЛицевогоСчета.Ссылка), ОписаниеОшибки()));						
							КонецПопытки;	
							ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (лицевые счета)...';en='Preservation of preliminary data (personal accounts)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", ЛицевойСчетКонтрагентаОбъект.Наименование, 0, ""));
							СообщилиПрогресс = Истина;
						ИначеЕсли НЕ СтрокаЛицевойСчет.Клиент = МассивСтрокЛС[0].ВладелецЛицевогоСчета Тогда
							// Создаем родственную связь
							РодственнаяЗапись 									= РегистрыСведений.РодственныеСвязи.СоздатьНаборЗаписей();
							РодственнаяЗапись.Отбор.Контрагент.Значение 		= СтрокаЛицевойСчет.Клиент;
							РодственнаяЗапись.Отбор.Контрагент.Использование 	= Истина;
							РодственнаяЗапись.Отбор.Родственник.Значение 		= МассивСтрокЛС[0].ВладелецЛицевогоСчета;
							РодственнаяЗапись.Отбор.Родственник.Использование 	= Истина;
							НоваяЗапись                    						= РодственнаяЗапись.Добавить();
							НоваяЗапись.Период		            				= Дата("20010101000000");
							НоваяЗапись.Контрагент              				= СтрокаЛицевойСчет.Клиент;
							НоваяЗапись.Родственник             				= МассивСтрокЛС[0].ВладелецЛицевогоСчета;
							НоваяЗапись.СтепеньРодства          				= СтепеньРодстваПрочее;
							НоваяЗапись.ОбщийЛицевойСчет        				= Истина;
							НоваяЗапись.ОбщийНакопительныйСчет  				= Истина;
							НоваяЗапись.ОбщийБонусныйСчет       				= Истина;
							НоваяЗапись.ЗаконныйПредставитель   				= Истина;
							РодственнаяЗапись.ОбменДанными.Загрузка 			= Истина;
							РодственнаяЗапись.Записать(Истина);
							
							РодственнаяЗапись 									= РегистрыСведений.РодственныеСвязи.СоздатьНаборЗаписей();
							РодственнаяЗапись.Отбор.Контрагент.Значение 		= МассивСтрокЛС[0].ВладелецЛицевогоСчета;
							РодственнаяЗапись.Отбор.Контрагент.Использование 	= Истина;
							РодственнаяЗапись.Отбор.Родственник.Значение 		= СтрокаЛицевойСчет.Клиент;
							РодственнаяЗапись.Отбор.Родственник.Использование 	= Истина;
							НоваяЗапись                    						= РодственнаяЗапись.Добавить();
							НоваяЗапись.Период		            				= Дата("20010101000000");
							НоваяЗапись.Контрагент              				= МассивСтрокЛС[0].ВладелецЛицевогоСчета;
							НоваяЗапись.Родственник             				= СтрокаЛицевойСчет.Клиент;
							НоваяЗапись.СтепеньРодства          				= СтепеньРодстваПрочее;
							НоваяЗапись.ОбщийЛицевойСчет        				= Истина;
							НоваяЗапись.ОбщийНакопительныйСчет  				= Истина;
							НоваяЗапись.ОбщийБонусныйСчет       				= Истина;
							НоваяЗапись.ЗаконныйПредставитель   				= Истина;
							РодственнаяЗапись.ОбменДанными.Загрузка 			= Истина;									
							РодственнаяЗапись.Записать(Истина);
							ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (лицевые счета)...';en='Preservation of preliminary data personal accounts)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Создание родственных связей...", 0, ""));										
							СообщилиПрогресс = Истина;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Если СообщилиПрогресс = Ложь Тогда 
			ДлительныеОперации.СообщитьПрогресс(0, НСтр("ru='Сохранение предварительных данных (лицевые счета)...';en='Preservation of preliminary data personal accounts)...'"), Новый Структура("ПредставлениеОбъекта, ОсталосьВремениВСекундах, ПредставлениеОставшегосяВремени", "Проверка необходимости создания лицевых счетов...", 0, ""));			
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

// Функция - Инициализировать документ возврата товара от покупателя
//
// Параметры:
//  СтрокаВыборкаПоОплатам	 - 	 - 
//  ДокументРеализация		 - 	 - 
//  ПараметрыЗагрузки		 - 	 - 
//  ТекОрганизация			 - 	 - 
//  ТаблицаСотрудниковВБазе	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ИнициализироватьДокументВозвратаТовараОтПокупателя(СтрокаВыборкаПоОплатам, ДокументРеализация, ПараметрыЗагрузки, ТекОрганизация, ОператорОплаты)
	
	Если ЗначениеЗаполнено(СтрокаВыборкаПоОплатам.ВозвратОтПокупателяПоРеализации) Тогда 
		ДокументВозвратТовара = СтрокаВыборкаПоОплатам.ВозвратОтПокупателяПоРеализации.ПолучитьОбъект();
		ДокументВозвратТовара.Запасы.Очистить();
		ДокументВозвратТовара.ВозвращенныеАвансы.Очистить();
		ДокументВозвратТовара.Заполнить(ДокументРеализация.Ссылка);
	Иначе 	
		ДокументВозвратТовара 				= Документы.ВозвратОтПокупателя.СоздатьДокумент();
		НовыйДокументВозвратТовараСсылка 	= Документы.ВозвратОтПокупателя.ПолучитьСсылку(Новый УникальныйИдентификатор);
    	ДокументВозвратТовара.УстановитьСсылкуНового(НовыйДокументВозвратТовараСсылка);		
		ДокументВозвратТовара.Заполнить(ДокументРеализация.Ссылка);
	КонецЕсли;
	ДокументВозвратТовара.ВидНалога 						= ДокументРеализация.ВидНалога; 
	ДокументВозвратТовара.СтруктурнаяЕдиница 				= ПараметрыЗагрузки.СтруктурнаяЕдиница;
	ДокументВозвратТовара.Организация 						= ТекОрганизация;										
	// ДокументВозвратТовара.КодСинхронизации 					= ДокументРеализация.ИДОплаты;
	// ДокументВозвратТовара.ПрефиксСинхронизации 				= ДокументРеализация.ПрефиксСинхронизации;			
	ДокументВозвратТовара.Дата 								= СтрокаВыборкаПоОплатам.ДатаОплаты;
	ДокументВозвратТовара.Комментарий 						= ДокументРеализация.Комментарий;											
	// Получаем оператора оплаты
	ДокументВозвратТовара.АвторДокумента = ?(ЗначениеЗаполнено(ОператорОплаты), ОператорОплаты, ДокументВозвратТовара.АвторДокумента);											
	Для Каждого СтрокаЗапасы Из ДокументРеализация.Запасы Цикл 
		СтрокаЗапасыВозврат = ДокументВозвратТовара.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЗапасыВозврат, СтрокаЗапасы);
		СтрокаЗапасыВозврат.ОснованиеВозврата 				= ДокументРеализация.Ссылка;
		СтрокаЗапасыВозврат.ПолныйВозврат 					= Истина;
		СтрокаЗапасыВозврат.ДатаРасчетаВозврата 			= СтрокаВыборкаПоОплатам.ДатаОплаты;
		СтрокаЗапасыВозврат.Продавец 						= ?(ЗначениеЗаполнено(СтрокаЗапасыВозврат.Продавец), СтрокаЗапасыВозврат.Продавец, ДокументВозвратТовара.АвторДокумента);
	КонецЦикла;	
	
	ДокументВозвратТовара.СуммаДокумента 					= ДокументВозвратТовара.Запасы.Итог("Всего");
	ДокументВозвратТовара.СуммаДляВозврата 					= ДокументВозвратТовара.СуммаДокумента;
	
	Возврат ДокументВозвратТовара;
	
КонецФункции

// Функция - Создать документ оплаты
//
// Параметры:
//  СтруктураОплаты		 - 	 - 
//  ПараметрыСоздания	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция СоздатьДокументОплаты(СтруктураОплаты, ПараметрыСоздания, ПараметрыЗагрузки, ТекстовыйНакопитель)
	
	ВидОперации = СтруктураОплаты.ВидОперации;
	// ID	Op	
	// 1	Внесение депозита	
	// 5	Списание с депозита
	// 7	Оплата контракта	
	// 8	Возврат оплаты контракта
	// 9 Кредит на оплату (рассрочка)
	ТипОплаты = СтруктураОплаты.ТипОплаты;
	// ID	Typ	Code
	// 1	Наличные	НЛ
	// 2	Безналичные	БН
	// 3	Кредитная карта	КК
	// 4	Бартер	БТ
	// 5 Кредит  КТ (рассрочка)
	// 6	Бонус	БС
	// 7	Лицевой счет	ЛС	
	
	ПкоРко = Неопределено;
	Если ВидОперации = 1 Тогда // Внесение депозита
		
		ПкоРко 				= Документы.ПоступлениеДенежныхСредств.СоздатьДокумент();
		СтруктураЗаполнения = Новый Структура();
		Если ТипОплаты = 1 Тогда
			СтруктураЗаполнения.Вставить("ВидОперации"				, Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
			СтруктураЗаполнения.Вставить("ТипДенежныхСредств"		, Перечисления.ТипыДенежныхСредств.Наличные);
		ИначеЕсли ТипОплаты = 2 Тогда
			СтруктураЗаполнения.Вставить("ВидОперации"				, Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
			СтруктураЗаполнения.Вставить("ТипДенежныхСредств"		, Перечисления.ТипыДенежныхСредств.Безналичные);
		ИначеЕсли ТипОплаты = 3 Тогда
			СтруктураЗаполнения.Вставить("ВидОперации"				, Перечисления.ВидыОпераций.ВзносНаЛицевойСчет);
			СтруктураЗаполнения.Вставить("ТипДенежныхСредств"		, Перечисления.ТипыДенежныхСредств.ПлатежнаяКарта);
		Иначе
			СтруктураЗаполнения.Вставить("ВидОперации"				, Перечисления.ВидыОпераций.ПрочееПоступление);
