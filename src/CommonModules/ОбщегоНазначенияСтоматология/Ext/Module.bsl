// Вернет сотрудника являющегося ответсвенным в данной организации по данному типу должности
//
Функция ПолучитьСрезПоследнихПоОтветсвеннымЛицам(Организация, ТипОтветственногоЛица, НаДату = Неопределено, ПолучитьСотрудника = Ложь) Экспорт
	
	СтруктураВыборки = Новый Структура();
	СтруктураВыборки.Вставить("Организация"			  , Организация);
	СтруктураВыборки.Вставить("ТипОтветственногоЛица" , ТипОтветственногоЛица);
	
	Если НаДату <> Неопределено Тогда
		ТаблицаЗначений = РегистрыСведений.ОтветственныеЛица.СрезПоследних(НаДату, СтруктураВыборки);		 
		Если ПолучитьСотрудника Тогда
			Возврат ?(ЗначениеЗаполнено(ТаблицаЗначений), ТаблицаЗначений[0].Сотрудник, Неопределено);
		Иначе
			Возврат ТаблицаЗначений;	
		КонецЕсли;
	Иначе	 
		ТаблицаЗначений = РегистрыСведений.ОтветственныеЛица.СрезПоследних(, СтруктураВыборки);
		Если ПолучитьСотрудника Тогда
			Возврат ?(ЗначениеЗаполнено(ТаблицаЗначений), ТаблицаЗначений[0].Сотрудник, Неопределено);
		Иначе
			Возврат ТаблицаЗначений;	
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

// Функция - проверяет наличие предварительной записи сотрудника
//
Функция ПроверитьНаличиеПредварительнойЗаписи(Сотрудник, Период, МассивПериодов, СтруктурнаяЕдиница) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ  РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.ДатаНачала,
		|	ВложенныйЗапрос.ДатаОкончания
		|ИЗ
		|	(ВЫБРАТЬ
		|		МИНИМУМ(МинимальнаяДата.ДатаНачала) КАК ДатаНачала,
		|		МАКСИМУМ(МаксимальнаяДата.ДатаОкончания) КАК ДатаОкончания
		|	ИЗ
		|		Документ.Событие.Услуги КАК МинимальнаяДата
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Событие.Услуги КАК МаксимальнаяДата
		|			ПО МинимальнаяДата.Ссылка = МаксимальнаяДата.Ссылка
		|				И МинимальнаяДата.Сотрудник = МаксимальнаяДата.Сотрудник
		|	ГДЕ
		|		МинимальнаяДата.Сотрудник = &Сотрудник
		|		И НАЧАЛОПЕРИОДА(МинимальнаяДата.ДатаНачала, ДЕНЬ) = &Период
		|		И МинимальнаяДата.ДатаНачала ЕСТЬ НЕ NULL 
		|		И (НЕ МаксимальнаяДата.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен))
		|		И (НЕ МинимальнаяДата.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен))
		|		И МаксимальнаяДата.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|		И МинимальнаяДата.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ВложенныйЗапрос
		|ГДЕ
		|	ВложенныйЗапрос.ДатаНачала ЕСТЬ НЕ NULL 
		|	И ВложенныйЗапрос.ДатаОкончания ЕСТЬ НЕ NULL "; 

	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	Результат = Запрос.Выполнить().Выбрать();
	ЕстьЗаписи = Истина;
	
	Если Результат.Следующий() Тогда 
		
		Если МассивПериодов.Количество() > 0 Тогда
			Если Результат.ДатаНачала >= (Период + (МассивПериодов[0].НачалоСмены - Дата(01,01,01))) 
				И Результат.ДатаОкончания <= (Период + (МассивПериодов[МассивПериодов.Количество() - 1].ОкончаниеСмены - Дата(01,01,01))) Тогда 
				ЕстьЗаписи = Ложь;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ЕстьЗаписи = Ложь;
	КонецЕсли;
	
	Возврат ЕстьЗаписи;
	
КонецФункции

// Функция, проверяет не работает ли сотрудник в данный период в др. структурной единице
//
Функция ПроверитьЗанятостьСотрудника(МассивПериодов, Сотрудник, СтруктурнаяЕдиница, Дата) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК ВремяНачала,
	                      |	ВремяРаботыСотрудниковПлан.ДатаВремяОкончания КАК ВремяОкончания
	                      |ИЗ
	                      |	РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
	                      |ГДЕ
	                      |	ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
	                      |	И ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница <> &СтруктурнаяЕдиница
	                      |	И НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяНачала, ДЕНЬ) = &Дата");
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Результат = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЧ из Результат Цикл
		Для Каждого СтрокаПериода из МассивПериодов Цикл
			Если  (СтрокаТЧ.ВремяНачала > Дата + (СтрокаПериода.НачалоСмены - Дата(01, 01, 01)) и СтрокаТЧ.ВремяНачала < Дата + (СтрокаПериода.ОкончаниеСмены - Дата(01, 01, 01))) 
				   или (СтрокаТЧ.ВремяОкончания >  Дата + (СтрокаПериода.НачалоСмены - Дата(01, 01, 01)) и СтрокаТЧ.ВремяОкончания < Дата + (СтрокаПериода.ОкончаниеСмены - Дата(01, 01, 01))) Тогда
				   Возврат Истина;
			КонецЕсли;
		КонецЦикла;		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции
  
&НаСервере
// Функция возвращает признак работы сотрудника
//
Функция ПроверитьДатуУвольнения(Сотрудник, ТекущаяДата, СтруктурнаяЕдиница) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	НастройкиСотрудников.Сотрудник
	                      |ИЗ
	                      |	РегистрСведений.НастройкиСотрудников КАК НастройкиСотрудников
	                      |ГДЕ
	                      |	НастройкиСотрудников.Сотрудник = &Сотрудник
	                      |	И НастройкиСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	                      |	И ВЫБОР
	                      |			КОГДА НастройкиСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
	                      |				ТОГДА НастройкиСотрудников.ДатаУвольнения > &ТекущаяДата
	                      |			ИНАЧЕ ИСТИНА
	                      |		КОНЕЦ");
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
	
КонецФункции

&НаСервере
// Функция выполняет отмену события
//
Функция ОтменитьВосстановитьСобытие(СобытиеСсылка, ПричинаОтменыЗаписи,ВосстановитьСобытие = Ложь) Экспорт 
	
	Если НЕ ВосстановитьСобытие Тогда
		Если ТипЗнч(ПричинаОтменыЗаписи) <> Тип("СправочникСсылка.ПричиныОтменыЗаписи") ИЛИ ПричинаОтменыЗаписи.Пустая() Тогда
			Возврат Ложь;
		КонецЕсли;
		// Нафиг два раза проверять!!!
		// Результат = ОбщегоНазначения.ПроверитьВозможностьОтменыСобытия(СобытиеСсылка);
		// Если Результат <> Истина Тогда
		//	Сообщить(Результат);
		//	Возврат Ложь;
		// КонецЕсли;	
	КонецЕсли;
	
	ПОПЫТКА
		ОбъектРасшифровки               = СобытиеСсылка.ПолучитьОбъект();
		ОбъектРасшифровки.Статус        = ?(НЕ ВосстановитьСобытие, Перечисления.СтатусыСобытия.ПриемОтменен, Перечисления.СтатусыСобытия.Подтверждена);
		ОбъектРасшифровки.ПричинаОтмены = ?(НЕ ВосстановитьСобытие,ПричинаОтменыЗаписи,Неопределено);
		ОбъектРасшифровки.Записать();
	ИСКЛЮЧЕНИЕ
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		Возврат Ложь;
	КОНЕЦПОПЫТКИ;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
// Функция выполняет проверку возможности отмены события.
//
Функция ПроверитьВозможностьОтменыСобытия(СобытиеСсылка) Экспорт
	
	Если СобытиеСсылка.Проведен = Ложь Тогда
		ТекстОшибки = "Отменить можно только проведенное событие!";
		Возврат ТекстОшибки;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Функция выполняет получение цвета фона события.
//
Функция ПолучитьЦветФонаСобытия(Статус = Неопределено, Событие = Неопределено, ТаблицаЦветов = Неопределено, ЭтоПеренос = Ложь) Экспорт
			
	Если ТаблицаЦветов = Неопределено Тогда  
		
		СтруктураЦветов = РегистрыСведений.НастройкиИнтерфейсов.ПолучитьНастройкиЦветаЖурналаЗаписи(ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница);
		
		Если ЭтоПеренос = Истина Тогда
			ЦветФона = СтруктураЦветов.ЦветПриемПеренесен;
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда
			ЦветФона = СтруктураЦветов.ЦветПриемНачат;
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда
			ЦветФона = СтруктураЦветов.ЦветПриемНеСостоялся;
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда
			ЦветФона = СтруктураЦветов.ЦветПриемОкончен;
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
			ЦветФона = СтруктураЦветов.ЦветПриемОтменен;
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.НеПодтверждена Тогда
			ЦветФона = СтруктураЦветов.ЦветНеПодтверждена;
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда
			ЦветФона = СтруктураЦветов.ЦветПодтверждена; 
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПациентОжидает Тогда
			ЦветФона = СтруктураЦветов.ЦветПациентОжидает;
		ИначеЕсли Событие <> Неопределено И Событие.Ссылка.Пустая() Тогда
			ЦветФона = СтруктураЦветов.ЦветПодтверждена;;
		Иначе
			Возврат Новый Цвет();
		КонецЕсли;
		
	Иначе
		
		Если ЭтоПеренос = Истина Тогда
			ИмяНастройки = "ЦветПриемПеренесен";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда
			ИмяНастройки = "ЦветСобытияЗапланировано";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПациентОжидает Тогда
			ИмяНастройки = "ЦветСобытияПациентОжидает";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда
			ИмяНастройки = "ЦветСобытияПациентВКресле";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда
			ИмяНастройки = "ЦветСобытияПриемОкончен";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда
			ИмяНастройки = "ЦветСобытияПриемНеСостоялся";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
			ИмяНастройки = "ЦветСобытияПриемОтменен";
		ИначеЕсли Статус = Перечисления.СтатусыСобытия.НеПодтверждена Тогда
			ИмяНастройки = "ЦветСобытияНеПодтверждено";			
		ИначеЕсли Событие <> Неопределено И Событие.Ссылка.Пустая() Тогда
			ИмяНастройки = "ЦветСобытияЗапланировано";		
		Иначе
			Возврат Новый Цвет(); 
		КонецЕсли;
		
		ЦветФона = ТаблицаЦветов.Найти(ИмяНастройки, "Имя").Цветфона;
		
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ЦветФона) Тогда
		ЦветФона = ЗначениеИзСтрокиВнутр(ЦветФона);
	Иначе 
		
		ЦветФонаПоУмолчанию = Новый Структура("ЦветСобытияЗапланировано, ЦветСобытияПациентОжидает, ЦветСобытияПациентВКресле, ЦветСобытияПриемОкончен, ЦветСобытияПриемНеСостоялся, ЦветСобытияПриемОтменен, ЦветСобытияНеПодтверждено, ЦветПриемПеренесен",
							WebЦвета.БледноЗолотистый,WebЦвета.БледноСиреневый, WebЦвета.ГолубойСоСтальнымОттенком, WebЦвета.СветлоЗеленый, WebЦвета.СветлоКоралловый, WebЦвета.СветлоКоралловый, WebЦвета.НейтральноПурпурный, Новый Цвет(230, 127, 106));

							
		ЦветФона = ЦветФонаПоУмолчанию[ИмяНастройки];
		
	КонецЕсли;
	
	Возврат ЦветФона;
		
КонецФункции

// Функция выполняет установку цвета фона события.
//
Процедура УстановитьЦветФонаСобытия(Статус, Событие = Неопределено, Знач Значение, ЭтоПеренос = Ложь) Экспорт
	
	Если Статус = Перечисления.СтатусыСобытия.Подтверждена Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПодтверждена;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПациентОжидает Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПациентОжидает;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНачат Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемНачат;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОкончен Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемОкончен;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемНеСостоялся Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемНеСостоялся;
	ИначеЕсли Статус = Перечисления.СтатусыСобытия.ПриемОтменен Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемОтменен;
  	ИначеЕсли Статус = Перечисления.СтатусыСобытия.НеПодтверждена Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветНеПодтверждена;		
	ИначеЕсли ЭтоПеренос = Истина Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПриемПеренесен;	
	ИначеЕсли Событие <> Неопределено И Событие.Ссылка.Пустая() Тогда
		Настройка = ПланыВидовХарактеристик.НастройкиИнтерфейсов.ЦветПодтверждена;;			
	КонецЕсли;
	
	Если ТипЗнч(Значение) =  Тип("Цвет") Тогда
		Значение = ЗначениеВСтрокуВнутр(Значение);
	КонецЕсли;
	
	РегистрыСведений.НастройкиИнтерфейсов.ЗаписатьЗначениеНастройки(, Настройка, Значение);
	
КонецПроцедуры

// Функция возвращает периоды работы.
//
Функция	ВернутьПериодыРаботы(ОбъектСсылка, ПериодДень, Параметры = Неопределено) Экспорт
	
	Результат = Неопределено;
	
	Если ТипЗнч(ОбъектСсылка) = Тип("СписокЗначений") Тогда 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК Начало,
		|	ВЫБОР
		|		КОГДА ВремяРаботыСотрудниковПлан.ДатаВремяОкончания = НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)
		|			ТОГДА КОНЕЦПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)
		|		ИНАЧЕ ВремяРаботыСотрудниковПлан.ДатаВремяОкончания
		|	КОНЕЦ КАК Окончание,
		|	ВремяРаботыСотрудниковПлан.Сотрудник
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК РасписаниеРаботы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
		|		ПО РасписаниеРаботы.Ссылка = ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница
		|ГДЕ
		|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ВремяРаботыСотрудниковПлан.Сотрудник В (&СписокСотрудников)
		|	И &ДатаДня МЕЖДУ НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ) И КОНЕЦПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)
		|	И РасписаниеРаботы.Активность = ИСТИНА
		|	И ДЕНЬНЕДЕЛИ(РасписаниеРаботы.ДеньНедели) = &ДеньНедели";
		
		Запрос.УстановитьПараметр("ДатаДня", ПериодДень);
		Запрос.УстановитьПараметр("СписокСотрудников", ОбъектСсылка);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Параметры.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ДеньНедели", ДеньНедели(ПериодДень));
		
		Результат = Запрос.Выполнить().Выгрузить();
		
	ИначеЕсли ТипЗнч(ОбъектСсылка) = Тип("СправочникСсылка.Сотрудники") Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВремяРаботыСотрудниковПлан.ДатаВремяНачала КАК Начало,
		|	ВЫБОР
		|		КОГДА ВремяРаботыСотрудниковПлан.ДатаВремяОкончания = НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)
		|			ТОГДА КОНЕЦПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)
		|		ИНАЧЕ ВремяРаботыСотрудниковПлан.ДатаВремяОкончания
		|	КОНЕЦ КАК Окончание
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК РасписаниеРаботы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВремяРаботыСотрудниковПлан КАК ВремяРаботыСотрудниковПлан
		|		ПО РасписаниеРаботы.Ссылка = ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница
		|ГДЕ
		|	ВремяРаботыСотрудниковПлан.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ВремяРаботыСотрудниковПлан.Сотрудник = &Сотрудник
		|	И &ДатаДня МЕЖДУ НАЧАЛОПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ) И КОНЕЦПЕРИОДА(ВремяРаботыСотрудниковПлан.ДатаВремяОкончания, ДЕНЬ)
		|	И РасписаниеРаботы.Активность = ИСТИНА
		|	И ДЕНЬНЕДЕЛИ(РасписаниеРаботы.ДеньНедели) = &ДеньНедели";
		
		Запрос.УстановитьПараметр("ДатаДня", ПериодДень);
		Запрос.УстановитьПараметр("Сотрудник", ОбъектСсылка);
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Параметры.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("ДеньНедели", ДеньНедели(ПериодДень));
		
		Результат = Запрос.Выполнить().Выгрузить();
		
	ИначеЕсли ТипЗнч(ОбъектСсылка) = Тип("СправочникСсылка.СтруктурныеЕдиницы") ИЛИ ТипЗнч(ОбъектСсылка) = Тип("СправочникСсылка.Помещения") Тогда
		
		ОтображаемоеКоличествоДней = ?(Параметры <> Неопределено И Параметры.Свойство("КолДней"), Параметры.КолДней - 1, 0); // Если КолДней = 0 (1 День).
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	РасписаниеРаботы.ДеньНедели КАК ДеньНедели,
		|	ВЫБОР
		|		КОГДА РасписаниеРаботы.НачалоРаботы = &ПустаяДата
		|			ТОГДА &НачалоРаботы
		|		ИНАЧЕ РасписаниеРаботы.НачалоРаботы
		|	КОНЕЦ КАК Начало,
		|	ВЫБОР
		|		КОГДА РасписаниеРаботы.ОкончаниеРаботы = &ПустаяДата
		|			ТОГДА &ОкончаниеРаботы
		|		ИНАЧЕ РасписаниеРаботы.ОкончаниеРаботы
		|	КОНЕЦ КАК Окончание
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.РасписаниеРаботы КАК РасписаниеРаботы
		|ГДЕ
		|	РасписаниеРаботы.Активность = ИСТИНА
		|	И ДЕНЬНЕДЕЛИ(РасписаниеРаботы.ДеньНедели) МЕЖДУ &ДеньНеделиОт И &ДеньНеделиПо
		|	И РасписаниеРаботы.Ссылка = &СтруктурнаяЕдиница";
		
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ОбъектСсылка);
		Запрос.УстановитьПараметр("ПустаяДата", Дата(01,01,01));
		Запрос.УстановитьПараметр("НачалоРаботы", Дата(01,01,01,00,00,01)); 
		Запрос.УстановитьПараметр("ОкончаниеРаботы",  Дата(01,01,01,23,59,59));
		Запрос.УстановитьПараметр("ДеньНеделиОт", ДеньНедели(ПериодДень));
		Запрос.УстановитьПараметр("ДеньНеделиПо", ДеньНедели(ПериодДень) + ОтображаемоеКоличествоДней);
		
		Результат = Запрос.Выполнить().Выгрузить();
	Иначе
		Результат = Новый ТаблицаЗначений;
	КонецЕсли;
	
	Возврат Результат;   	
	
КонецФункции

// Процедура обновляет данные в календаря дня.
//
Функция СформироватьГрафикСобытий(ПараметрыЗнач, МассивСотрудниковИОбластей = Неопределено, ИнтервалВремени = Неопределено, ВыводНаПечать = Ложь) Экспорт
	
	Параметры = Новый Структура;
	Для Каждого ЭлементСтруктуры Из ПараметрыЗнач Цикл
		Параметры.Вставить(ЭлементСтруктуры.Ключ, ЭлементСтруктуры.Значение);
	КонецЦикла;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	// Вычисляем какую область графика  по времени показывать
	Если ИнтервалВремени = Неопределено ИЛИ ИнтервалВремени = 15 Тогда
		Параметры.Вставить("МакетДня", Обработки.РабочийКалендарь.ПолучитьМакет("МакетДень"));
	ИначеЕсли ИнтервалВремени = 5 Тогда
		Параметры.Вставить("МакетДня", Обработки.РабочийКалендарь.ПолучитьМакет("МакетДень5"));
	Иначе
		Параметры.Вставить("МакетДня", Обработки.РабочийКалендарь.ПолучитьМакет("МакетДень10"));
	КонецЕсли;
		
	// 1. Получаем данные событий
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Услуги.Ссылка КАК Событие,
	|	Услуги.Ссылка.Контрагент КАК Контрагент,
	|	Услуги.Ссылка.Контрагент.ДатаРожденияКлиента КАК ДатаРожденияКлиента,
	|	Услуги.Ссылка.ТелефонныйЗвонок,
	|	Услуги.Ссылка.ОснованиеРезерва,
	|	Услуги.Ссылка.Комментарий КАК Комментарий,
	|	Услуги.ДатаНачала КАК ДатаНачала,
	|	Услуги.ДатаОкончания,
	|	Услуги.Сотрудник КАК Сотрудник,
	|	Услуги.Помещение КАК Помещение,
	|	Услуги.Номенклатура КАК Услуга,
	|	Услуги.ПричинаЗаписи КАК ПричинаЗаписи,
	|	Услуги.ПризнакЗаблокированно КАК ПризнакЗаблокированно,
	|	Услуги.НомерСтроки - 1 КАК ИндексВТЧ,
	|	0 КАК НомерБлокаСобытий,
	|	Услуги.Ссылка.АвторДокумента,
	|	Услуги.Ссылка.Дата КАК ДатаСобытия,
	|	Услуги.Ссылка.Резерв,
	|	Услуги.Ссылка.Статус,
	|	Услуги.Ссылка.ЦветФонаРезерва,
	|	ЛОЖЬ КАК ЕстьЗадолженность,
	|	ЛОЖЬ КАК ЕстьНезавершенныеНарядЗаказы,
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыНарядЗаказа.Заказано) КАК ОбщийСтатусНезавершенныхНарядЗаказов,
	|	Услуги.Ссылка.Контрагент.Наименование КАК ФИОПациента,
	|	Услуги.Ссылка.Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей,
	|	Услуги.Ссылка.Контрагент.ТекущаяМедицинскаяКарта,
	|	Услуги.Ссылка.Контрагент.Телефон
	|ИЗ
	|	Документ.Событие.Услуги КАК Услуги
	|ГДЕ
	|	Услуги.Ссылка.Проведен
	|	И Услуги.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|	И Услуги.Ссылка.ТипСобытия = ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ПредварительнаяЗапись)
	|	И НЕ Услуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)
	|	И Услуги.ДатаНачала МЕЖДУ &ДатаОт И &ДатаПо
	|	И (&Контрагенты = НЕОПРЕДЕЛЕНО
	|			ИЛИ Услуги.Ссылка.Контрагент = &Контрагенты)
	|	И (""Все"" В (&Сотрудники)
	|			ИЛИ Услуги.Сотрудник В (&Сотрудники)
	|			ИЛИ Услуги.Сотрудник.Должность В (&Сотрудники))
	|	И (""Все"" В (&Помещения)
	|			ИЛИ Услуги.Помещение В (&Помещения)
	|			ИЛИ Услуги.Помещение.Родитель В (&Помещения))
	|	И НЕ Услуги.Ссылка В (&МассивИсключаемыхСобытий)
	|	И ВЫБОР
	|			КОГДА НЕ Услуги.Сотрудник.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
	|				ТОГДА Услуги.Сотрудник.Должность.ОтображатьВЖурналеПредварительнойЗаписи = ИСТИНА
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Событие,
	|	Сотрудник,
	|	Контрагент,
	|	Помещение,
	|	ДатаНачала");
	
	Если Параметры.Свойство("ОтмененныеЗаписи")
		И Параметры.ОтмененныеЗаписи = Истина Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "НЕ Услуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)", "Услуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСобытия.ПриемОтменен)"); 	
		Статус  = Перечисления.СтатусыСобытия.ПриемОтменен;
	КонецЕсли;
	
	ДатаНачала 			= ?(Параметры.СтраницаМенеджера = "Неделя",НачалоНедели(Параметры.Дата), НачалоДня(Параметры.Дата));
	ДатаОкончания		= ?(Параметры.СтраницаМенеджера = "Неделя",КонецНедели(Параметры.Дата), КонецДня(Параметры.Дата));
	ВыбранныеКлиенты 	= ?(Параметры.Свойство("ВыбранныеКонтрагенты"), Параметры.ВыбранныеКонтрагенты, Неопределено);
	
	Запрос.УстановитьПараметр("МассивИсключаемыхСобытий", ?(Параметры.Свойство("ИсключаемыеСобытий"), Параметры.ИсключаемыеСобытий, Новый Массив));	
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"      , Параметры.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Контрагенты"             , ВыбранныеКлиенты);
	Запрос.УстановитьПараметр("Сотрудники"              , Параметры.ВыбранныеСотрудники);
	Запрос.УстановитьПараметр("Помещения"               , Параметры.ВыбранныеПомещения);
	Запрос.УстановитьПараметр("ДатаОт"					, ДатаНачала);
	Запрос.УстановитьПараметр("ДатаПо"					, ДатаОкончания);
	
	ТаблицаСобытий = Запрос.Выполнить().Выгрузить();
	
	РегистрыСведений.ИсторияПереносовСобытий.ДополнитьТаблицуСобытийПереносами( ДатаНачала,
																				ДатаОкончания, 
																				Параметры.СтруктурнаяЕдиница, 
																				Параметры.ВыбранныеСотрудники, 
																				Параметры.ВыбранныеПомещения, 
																				Статус, 
																				ВыбранныеКлиенты, 
																				ТаблицаСобытий);  
	
	Если ТаблицаСобытий.Количество() > 0 Тогда 
		ПроставимНекоторыеСтатусы(ТаблицаСобытий, Параметры.СтруктурнаяЕдиница);
	КонецЕсли;
	
	Если Параметры.Свойство("ВиртуальныеСобытия") = Истина Тогда
		Для Каждого СтрокаТаблицы Из Параметры.ВиртуальныеСобытия Цикл
			НоваяСтрока = ТаблицаСобытий.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		КонецЦикла;
	КонецЕсли;
		
	// Делаем колонку услуги не привязанным к типу
	ТаблицаСобытий.Колонки.Услуга.Имя = "УслугаДел";
	ТаблицаСобытий.Колонки.Добавить("Услуга");
	ТаблицаСобытий.ЗагрузитьКолонку(ТаблицаСобытий.ВыгрузитьКолонку("УслугаДел"), "Услуга");
	ТаблицаСобытий.Колонки.Удалить("УслугаДел");
	// Делаем колонку услуги не привязанным к типу
	ТаблицаСобытий.Колонки.ИндексВТЧ.Имя = "ИндексВТЧДел";
	ТаблицаСобытий.Колонки.Добавить("ИндексВТЧ");
	ТаблицаСобытий.ЗагрузитьКолонку(ТаблицаСобытий.ВыгрузитьКолонку("ИндексВТЧДел"), "ИндексВТЧ");
	ТаблицаСобытий.Колонки.Удалить("ИндексВТЧДел");
	
	// Группируем события по блокам
	ИндексСтроки = 0;
	Если Параметры.Свойство("ВиртуальныеСобытия") = Истина Тогда
	  ТаблицаСобытий.Сортировать("Событие, Сотрудник, Контрагент, Помещение, ДатаНачала");
    КонецЕсли;
  
	Пока ИндексСтроки < ТаблицаСобытий.Количество() - 1 Цикл
		СтрокаТаблицаСобытий = ТаблицаСобытий[ИндексСтроки];
		СтрокаТаблицаСобытийСледующая = ТаблицаСобытий[ИндексСтроки + 1];
		Если СтрокаТаблицаСобытий.Событие = СтрокаТаблицаСобытийСледующая.Событие И СтрокаТаблицаСобытий.Сотрудник = СтрокаТаблицаСобытийСледующая.Сотрудник И СтрокаТаблицаСобытий.Помещение = СтрокаТаблицаСобытийСледующая.Помещение
				И СтрокаТаблицаСобытий.Контрагент = СтрокаТаблицаСобытийСледующая.Контрагент И СтрокаТаблицаСобытий.ПризнакЗаблокированно = СтрокаТаблицаСобытийСледующая.ПризнакЗаблокированно
				И СтрокаТаблицаСобытийСледующая.ДатаНачала >= СтрокаТаблицаСобытий.ДатаНачала И СтрокаТаблицаСобытийСледующая.ДатаНачала <= СтрокаТаблицаСобытий.ДатаОкончания Тогда
			СтрокаТаблицаСобытий.ДатаОкончания = ?(СтрокаТаблицаСобытийСледующая.ДатаОкончания < СтрокаТаблицаСобытий.ДатаОкончания, СтрокаТаблицаСобытий.ДатаОкончания, СтрокаТаблицаСобытийСледующая.ДатаОкончания);
			Если ТипЗнч(СтрокаТаблицаСобытий.Услуга) = Тип("Массив") Тогда
				СтрокаТаблицаСобытий.Услуга.Добавить(СтрокаТаблицаСобытийСледующая.Услуга);
			Иначе
				НовыйМассив = Новый Массив;
				НовыйМассив.Добавить(СтрокаТаблицаСобытий.Услуга);
				НовыйМассив.Добавить(СтрокаТаблицаСобытийСледующая.Услуга);
				СтрокаТаблицаСобытий.Услуга = НовыйМассив;
			КонецЕсли;
			Если ТипЗнч(СтрокаТаблицаСобытий.ИндексВТЧ) = Тип("Массив") Тогда
				СтрокаТаблицаСобытий.ИндексВТЧ.Добавить(СтрокаТаблицаСобытийСледующая.ИндексВТЧ);
			Иначе
				НовыйМассив = Новый Массив;
				НовыйМассив.Добавить(СтрокаТаблицаСобытий.ИндексВТЧ);
				НовыйМассив.Добавить(СтрокаТаблицаСобытийСледующая.ИндексВТЧ);
				СтрокаТаблицаСобытий.ИндексВТЧ = НовыйМассив;
			КонецЕсли;
			ТаблицаСобытий.Удалить(СтрокаТаблицаСобытийСледующая);
		Иначе
			ИндексСтроки = ИндексСтроки + 1;
		КонецЕсли;
	КонецЦикла;
	
	
	// Получим метки для всех событий
	ТаблицаДляФильтра = ТаблицаСобытий.ВыгрузитьКолонку("СОбытие");
	
	ЗапросМеток = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КлиентскиеМеткиСрезПоследних.Клиент КАК Событие,
	|	КлиентскиеМеткиСрезПоследних.Метка,
	|	КлиентскиеМеткиСрезПоследних.Активна
	|ИЗ
	|	РегистрСведений.МеткиКлиентов.СрезПоследних(, Клиент В (&Клиент)) КАК КлиентскиеМеткиСрезПоследних
	|ГДЕ
	|	КлиентскиеМеткиСрезПоследних.Активна = ИСТИНА
	|	И КлиентскиеМеткиСрезПоследних.Метка.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	КлиентскиеМеткиСрезПоследних.Метка");
	

	ЗапросМеток.УстановитьПараметр("Клиент", ТаблицаДляФильтра);
	ТаблицаМеток = ЗапросМеток.Выполнить().Выгрузить();
	
	Параметры.Вставить("ТаблицаМеток", ТаблицаМеток);
	
	// Высчитываем номер блока, для вывода надписи в событии
	Для Каждого СтрокаТаблицы Из ТаблицаСобытий Цикл
		МассивБлокаСобытий = ТаблицаСобытий.НайтиСтроки(Новый Структура("Событие", СтрокаТаблицы.Событие));
		Если МассивБлокаСобытий.Количество() > 1 И СтрокаТаблицы.НомерБлокаСобытий = 0 Тогда
			Для а = 0 По МассивБлокаСобытий.Количество() - 1 Цикл
				МассивБлокаСобытий[а].НомерБлокаСобытий = а + 1;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	ТаблицаСобытий.Сортировать("ДатаНачала");
	
	// 2. Распределяем событие по периодам дня
	ТаблицаИнтервалов = ТаблицаСобытий.СкопироватьКолонки();
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("Число"));
	ОписаниеТиповЧисло = Новый ОписаниеТипов(МассивТипов);
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("Дата"));
	ОписаниеТиповДата = Новый ОписаниеТипов(МассивТипов);
	
	ТаблицаИнтервалов.Колонки.Добавить("НомерНачальнойСтроки", 					ОписаниеТиповЧисло);
	ТаблицаИнтервалов.Колонки.Добавить("НомерКонечнойСтроки" , 					ОписаниеТиповЧисло);
	ТаблицаИнтервалов.Колонки.Добавить("НомерНачальнойКолонки", 				ОписаниеТиповЧисло);
	ТаблицаИнтервалов.Колонки.Добавить("НомерКонечнойКолонки" , 				ОписаниеТиповЧисло);
	ТаблицаИнтервалов.Колонки.Добавить("ПорядковыйНомерВДне" , 					ОписаниеТиповЧисло);
	ТаблицаИнтервалов.Колонки.Добавить("ДатаИнтервала" , 						ОписаниеТиповДата);
	ТаблицаИнтервалов.Колонки.Добавить("КоличествоОдновременныхДокументов" , 	ОписаниеТиповЧисло);
	ТаблицаИнтервалов.Колонки.Добавить("ИндексСтроки" , 						ОписаниеТиповЧисло);
	
	Для каждого СтрокаТаблицы Из ТаблицаСобытий Цикл
		
		НачальнаяСтрока = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоСоставнойДаты(Формат(СтрокаТаблицы.ДатаНачала,"ДФ=Ч"), Формат(СтрокаТаблицы.ДатаНачала,"ДФ=м"), СтрокаТаблицы.ДатаНачала, Истина, СтрокаТаблицы.ДатаНачала, ИнтервалВремени);
		Если Формат(СтрокаТаблицы.ДатаНачала,"ДФ=Ч") = Формат(СтрокаТаблицы.ДатаОкончания,"ДФ=Ч") И Формат(СтрокаТаблицы.ДатаНачала,"ДФ=м") = Формат(СтрокаТаблицы.ДатаОкончания,"ДФ=м") Тогда
			КонечнаяСтрока  = НачальнаяСтрока;
		Иначе
			Если НачалоДня(СтрокаТаблицы.ДатаОкончания) = СтрокаТаблицы.ДатаОкончания Тогда
				СтрокаТаблицы.ДатаОкончания = КонецДня(СтрокаТаблицы.ДатаОкончания);
			КонецЕсли;			
			КонечнаяСтрока  = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоСоставнойДаты(Формат(СтрокаТаблицы.ДатаОкончания,"ДФ=Ч"), Формат(СтрокаТаблицы.ДатаОкончания,"ДФ=м"), СтрокаТаблицы.ДатаОкончания, Ложь, СтрокаТаблицы.ДатаОкончания, ИнтервалВремени);
		КонецЕсли; 
		
		Если НачалоДня(СтрокаТаблицы.ДатаНачала) <> НачалоДня(СтрокаТаблицы.ДатаОкончания) Тогда
			
			КоличествоИнтерваловМеждуДнями = Цел((НачалоДня(СтрокаТаблицы.ДатаОкончания) - КонецДня(СтрокаТаблицы.ДатаНачала) + 1)/(60*60*24));
			Для а = 1 По КоличествоИнтерваловМеждуДнями Цикл
				ДатаИнтервала                     = НачалоДня(СтрокаТаблицы.ДатаНачала) + (60*60*24)*а;							
				НоваяСтрока                       = ТаблицаИнтервалов.Добавить();
				НоваяСтрока.ИндексСтроки          = ТаблицаИнтервалов.Индекс(НоваяСтрока);
				НоваяСтрока.ДатаИнтервала         = ДатаИнтервала;
				НоваяСтрока.НомерНачальнойСтроки  = 1;
				НоваяСтрока.НомерКонечнойСтроки   = 96;
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);				
			КонецЦикла;
			
			НоваяСтрока                      = ТаблицаИнтервалов.Добавить();
			НоваяСтрока.ИндексСтроки         = ТаблицаИнтервалов.Индекс(НоваяСтрока);
			НоваяСтрока.ДатаИнтервала        = НачалоДня(СтрокаТаблицы.ДатаНачала);
			НоваяСтрока.НомерНачальнойСтроки = НачальнаяСтрока;
			НоваяСтрока.НомерКонечнойСтроки  = 96;
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			
			НоваяСтрока                      = ТаблицаИнтервалов.Добавить();
			НоваяСтрока.ИндексСтроки         = ТаблицаИнтервалов.Индекс(НоваяСтрока);
			НоваяСтрока.ДатаИнтервала        = НачалоДня(СтрокаТаблицы.ДатаОкончания);
			НоваяСтрока.НомерНачальнойСтроки = 1;
			НоваяСтрока.НомерКонечнойСтроки  = КонечнаяСтрока;
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		Иначе
			НоваяСтрока                      = ТаблицаИнтервалов.Добавить();
			НоваяСтрока.ИндексСтроки         = ТаблицаИнтервалов.Индекс(НоваяСтрока);
			НоваяСтрока.ДатаИнтервала        = НачалоДня(СтрокаТаблицы.ДатаНачала);
			НоваяСтрока.НомерНачальнойСтроки = НачальнаяСтрока;
			НоваяСтрока.НомерКонечнойСтроки  = КонечнаяСтрока;
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);		
		КонецЕсли;
		
	КонецЦикла;
	
	ПериодыРаботыСтруктурнойЕдиницы = ОбщегоНазначенияСтоматология.ВернутьПериодыРаботы(Параметры.СтруктурнаяЕдиница, ?(Параметры.СтраницаМенеджера = "Неделя", НачалоНедели(Параметры.Дата), Параметры.Дата), Новый Структура("КолДней" , ?(Параметры.СтраницаМенеджера = "Неделя", 7, 1)));
	
	Если ПериодыРаботыСтруктурнойЕдиницы.Количество() > 0 Тогда
		Параметры.Вставить("ОграничениеВремениС" ,ПериодыРаботыСтруктурнойЕдиницы[0].Начало);
		Параметры.Вставить("ОграничениеВремениПО",ПериодыРаботыСтруктурнойЕдиницы[0].Окончание);
	Иначе
		Параметры.Вставить("ОграничениеВремениС" ,Дата(01, 01, 01, 0, 0, 0));
		Параметры.Вставить("ОграничениеВремениПО",Дата(01, 01, 01, 23, 59, 59));
	КОнецЕсли;
	
	// 3. Выполняем процедуру распределения событий на графике
	Параметры.Вставить("ВыводитьСтрокуЛистОжидания", ВыводНаПечать = Ложь И Параметры.СтраницаМенеджера = "Сотрудники");
	
	Если Параметры.СтраницаМенеджера = "ДеньСотрудника" Тогда		
		
		Если Параметры.ВыбранныеСотрудники.Количество() = 0 Тогда
			Параметры.ВыбранныеСотрудники.Добавить(Неопределено);
		КонецЕсли;
		
		Для Счетчик = 1 По Параметры.ВыбранныеСотрудники.Количество() Цикл
			ГруппировкаСсылка            = Параметры.ВыбранныеСотрудники[Счетчик - 1];
			ТаблицаИнтерваловГруппировки = ТаблицаИнтервалов.Скопировать(Новый Структура("ДатаИнтервала, Сотрудник", Параметры.Дата, ГруппировкаСсылка));
			ЗаполнитьГрафикСобытийПоГруппам(ТабличныйДокумент, ТаблицаИнтерваловГруппировки, Счетчик, Параметры.ВыбранныеСотрудники.Количество(), ГруппировкаСсылка, Ложь, Параметры, Неопределено, ИнтервалВремени, ВыводНаПечать);
		КонецЦикла;

	ИначеЕсли Параметры.СтраницаМенеджера = "Неделя" Тогда
		
		Параметры.Вставить("ОграничениеВремениС" , Неопределено);
		Параметры.Вставить("ОграничениеВремениПО", Неопределено);
		
		// Определяем максимальное время начала и окончания дня.
		Для Каждого СтрокаТЗ Из ПериодыРаботыСтруктурнойЕдиницы Цикл			
			Если Параметры.ОграничениеВремениС = Неопределено И Параметры.ОграничениеВремениПО = Неопределено Тогда
				Параметры.ОграничениеВремениС  = СтрокаТЗ.Начало;
				Параметры.ОграничениеВремениПО = СтрокаТЗ.Окончание;
			Иначе
				Если Параметры.ОграничениеВремениС > СтрокаТЗ.Начало Тогда
					Параметры.ОграничениеВремениС  = СтрокаТЗ.Начало;
				КонецЕсли;	
				Если Параметры.ОграничениеВремениПО < СтрокаТЗ.Окончание Тогда
					Параметры.ОграничениеВремениПО = СтрокаТЗ.Окончание;
				КонецЕсли;				
			КонецЕсли;			
		КонецЦикла;		
		
		Для Счетчик = 1 По 7 Цикл
			ДеньРабочий = Ложь;
			// Параметры.Вставить("ОграничениеВремениС", Дата(01, 01, 01, 0, 0, 0));
			// Параметры.Вставить("ОграничениеВремениПО", Дата(01, 01, 01, 23, 59, 59));			
			Для Каждого СтрокаТЗ Из ПериодыРаботыСтруктурнойЕдиницы Цикл
				Если ДеньНедели(СтрокаТЗ.ДеньНедели) = ДеньНедели(Дата(2001, 1, Счетчик)) Тогда
					ДеньРабочий = Истина;
					// Параметры.Вставить("ОграничениеВремениС", СтрокаТЗ.Начало);
					// Параметры.Вставить("ОграничениеВремениПО", СтрокаТЗ.Окончание);
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если ДеньРабочий = Истина Тогда
				ГруппировкаСсылка = НачалоНедели(Параметры.Дата) + (Счетчик - 1) * 60 * 60 * 24;						
				ЗаполнитьГрафикСобытийПоГруппам(ТабличныйДокумент, ТаблицаИнтервалов.Скопировать(Новый Структура("ДатаИнтервала", ГруппировкаСсылка)), Счетчик, 7, ГруппировкаСсылка, Ложь, Параметры, Неопределено, ИнтервалВремени, ВыводНаПечать);
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли Параметры.СтраницаМенеджера = "Сотрудники" Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Сотрудники.Сотрудник КАК Сотрудник,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ИнтервалыЛистаОжидания.Контрагент) КАК КоличествоВЛистеОжидания
		|ИЗ
		|	РегистрСведений.НастройкиСотрудников КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИнтервалыЛистаОжидания КАК ИнтервалыЛистаОжидания
		|		ПО Сотрудники.Сотрудник = ИнтервалыЛистаОжидания.Сотрудник
		|			И (ИнтервалыЛистаОжидания.Дата = &Дата)
		|			И (ИнтервалыЛистаОжидания.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		|ГДЕ
		|	Сотрудники.Сотрудник.ПометкаУдаления = ЛОЖЬ
		|	И НЕ Сотрудники.Сотрудник.Служебный
		|	И Сотрудники.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И (""Все"" В (&Сотрудники)
		|			ИЛИ Сотрудники.Сотрудник В (&Сотрудники)
		|			ИЛИ Сотрудники.Сотрудник.Должность В (&Сотрудники))
		|	И ВЫБОР
		|			КОГДА &УчитыватьГрафикРаботы = ИСТИНА
		|				ТОГДА Сотрудники.Сотрудник В
		|						(ВЫБРАТЬ
		|							РабочиеДниСотрудников.Сотрудник
		|						ИЗ
		|							РегистрСведений.ВремяРаботыСотрудниковПлан КАК РабочиеДниСотрудников
		|						ГДЕ
		|							НАЧАЛОПЕРИОДА(РабочиеДниСотрудников.ДатаВремяНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)
		|							И РабочиеДниСотрудников.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА НЕ Сотрудники.Сотрудник.Должность = ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
		|				ТОГДА Сотрудники.Сотрудник.Должность.ОтображатьВЖурналеПредварительнойЗаписи = ИСТИНА
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И (Сотрудники.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
		|			ИЛИ НАЧАЛОПЕРИОДА(ВЫРАЗИТЬ(Сотрудники.ДатаУвольнения КАК ДАТА), ДЕНЬ) > НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)
		|			ИЛИ Сотрудники.ДатаУвольнения ЕСТЬ NULL)
		|
		|СГРУППИРОВАТЬ ПО
		|	Сотрудники.Сотрудник
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудники.Сотрудник.Должность.Наименование,
		|	Сотрудники.Сотрудник.Наименование");
					
		Запрос.УстановитьПараметр("УчитыватьГрафикРаботы",?(ПараметрыЗнач.Свойство("УчитыватьГрафикРаботыСотрудников"),ПараметрыЗнач.УчитыватьГрафикРаботыСотрудников,Ложь));
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	 , Параметры.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("Сотрудники"			 , Параметры.ВыбранныеСотрудники);
		Запрос.УстановитьПараметр("Дата"				 , Параметры.Дата);
		
		ТЗСотрудников = Запрос.Выполнить().Выгрузить();
		
		Параметры.ВыводитьСтрокуЛистОжидания = Параметры.ВыводитьСтрокуЛистОжидания И ТЗСотрудников.Итог("КоличествоВЛистеОжидания") > 0;	
		ТабличныйДокумент.ФиксацияСверху = ?(Параметры.ВыводитьСтрокуЛистОжидания, 2, 0);
		
		КоличествоВТЗ = ТЗСотрудников.Количество(); 
		Если КоличествоВТЗ = 0 Тогда
			НовСтрокаТЗСотрудников = ТЗСотрудников.Добавить();
			НовСтрокаТЗСотрудников.Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
			НовСтрокаТЗСотрудников.КоличествоВЛистеОжидания = 0;
			КоличествоВТЗ = 1;
		КонецЕсли;
				
		// Юля
		Если Параметры.Свойство("Дата") и Параметры.Дата <> Дата(1,1,1) Тогда
			ДатаРаботы = Параметры.Дата;
		Иначе
			ДатаРаботы = НачалоДня(ТекущаяДата());
		КонецЕсли;   		
		Сп_Сотрудников = Новый СписокЗначений;
		Сп_Сотрудников.ЗагрузитьЗначения(ТЗСотрудников.ВыгрузитьКолонку("Сотрудник")); 		
		ТаблицаВремяРаботыСотрудников = ОбщегоНазначенияСтоматология.ВернутьПериодыРаботы(Сп_Сотрудников, ДатаРаботы, Новый Структура("СтруктурнаяЕдиница, КолДней", Параметры.СтруктурнаяЕдиница, 1)); 
		// Конец
		
		ЗаполнитьСписокСотрудниковЛистаОжидания = ПараметрыЗнач.Свойство("СписокСотрудниковВЛистеОжидания") И ТипЗнч(ПараметрыЗнач.СписокСотрудниковВЛистеОжидания) = Тип("СписокЗначений");
		
		Счетчик = 0;
		Для Каждого СтрокаТЗ Из ТЗСотрудников Цикл
			
			Счетчик = Счетчик + 1; 			
			ТаблицаИнтерваловГруппировки = ТаблицаИнтервалов.Скопировать(Новый Структура("ДатаИнтервала, Сотрудник", Параметры.Дата, СтрокаТЗ.Сотрудник));
			// Юля
			Если ТаблицаВремяРаботыСотрудников.Количество() <> 0 Тогда
				МассивВремяРаботыСотрудника = ТаблицаВремяРаботыСотрудников.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЗ.Сотрудник));
			Иначе
				МассивВремяРаботыСотрудника = Неопределено;
			КонецЕсли;
			//
			
			Параметры.Вставить("КоличествоПациентовВЛистеОжидания", СтрокаТЗ.КоличествоВЛистеОжидания);
			
			ЗаполнитьГрафикСобытийПоГруппам(
			ТабличныйДокумент, 
			ТаблицаИнтерваловГруппировки, 
			Счетчик, 
			КоличествоВТЗ, 
			СтрокаТЗ.Сотрудник, 
			Ложь, 
			Параметры, 
			МассивСотрудниковИОбластей, 
			ИнтервалВремени,
			ВыводНаПечать,
			МассивВремяРаботыСотрудника);
			
			Если ЗаполнитьСписокСотрудниковЛистаОжидания И ЗначениеЗаполнено(СтрокаТЗ.КоличествоВЛистеОжидания) Тогда
				ПараметрыЗнач.СписокСотрудниковВЛистеОжидания.Добавить(СтрокаТЗ.Сотрудник);		
			КонецЕсли;
				
		КонецЦикла;			
		
	ИначеЕсли Параметры.СтраницаМенеджера = "Помещения" Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Помещения.Родитель КАК Родитель,
		|	Помещения.Ссылка КАК Помещения
		|ИЗ
		|	Справочник.Помещения КАК Помещения
		|ГДЕ
		|	Помещения.ПометкаУдаления = ЛОЖЬ
		|	И Помещения.ОтображатьВРасписанииЗанятий = ИСТИНА
		|	И Помещения.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И (""Все"" В (&Помещения)
		|			ИЛИ Помещения.Ссылка В (&Помещения)
		|			ИЛИ Помещения.Ссылка.Родитель В (&Помещения))
		|	И Помещения.ЭтоГруппа = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	Помещения.Ссылка,
		|	Помещения.Родитель
		|
		|УПОРЯДОЧИТЬ ПО
		|	Родитель,
		|	Помещения.Наименование");		
		
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Параметры.СтруктурнаяЕдиница);
		Запрос.УстановитьПараметр("Помещения"		  , Параметры.ВыбранныеПомещения);
		МассивГруппировок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Помещения");
		
		Если МассивГруппировок.Количество() = 0 Тогда
			МассивГруппировок.Добавить(Справочники.Помещения.ПустаяСсылка());
		КонецЕсли;	
		Счетчик = 0;
		Для Каждого ГруппировкаСсылка Из МассивГруппировок Цикл
			Счетчик = Счетчик + 1;
			ТаблицаИнтерваловГруппировки = ТаблицаИнтервалов.Скопировать(Новый Структура("ДатаИнтервала, Помещение", Параметры.Дата, ГруппировкаСсылка));
			ЗаполнитьГрафикСобытийПоГруппам(ТабличныйДокумент, ТаблицаИнтерваловГруппировки, Счетчик, МассивГруппировок.Количество(), ГруппировкаСсылка, Ложь, Параметры, Неопределено, ИнтервалВремени, ВыводНаПечать);
			
		КонецЦикла;		
	КонецЕсли;
	
	// Форматирование документа устанавливаем
	ТабличныйДокумент.Область(2, 3,ТабличныйДокумент.ВысотаТаблицы,ТабличныйДокумент.ШиринаТаблицы).РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ТабличныйДокумент.Область(2,,ТабличныйДокумент.ВысотаТаблицы,).ВысотаСтроки = 10;
	
	Если Параметры.Свойство("ОграничениеНаШиринуДня") Тогда
		ПараметрыЗнач.Вставить("ОграничениеНаШиринуДня", Параметры.ОграничениеНаШиринуДня);
	КонецЕсли;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;	
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Процедура заполняет данными поле табличного документа ПолеТабличногоДокументаДень.
//
// Параметры
//  НЕТ
//
// Возвращаемое значение
//  НЕТ
Процедура ЗаполнитьГрафикСобытийПоГруппам(
	ТабличныйДокумент, 
	ТаблицаИнтервалов, 
	НомерГруппы, 
	ВсегоГрупп, 
	ГруппировкаСсылка, 
	ВставитьРазделительДней = Ложь, 
	Параметры, 
	МассивСотрудниковИОбластей,
	ИнтервалВремени, 
	ВыводНаПечать = Ложь,
	МассивВремяРаботыСотрудника = Неопределено)
	
	Если ИнтервалВремени = Неопределено Тогда
		ИнтервалВремени = 15;
	КонецЕсли;
	Если ТипЗнч(ГруппировкаСсылка) = Тип("Дата") Тогда
		ДатаРаботы = ГруппировкаСсылка;
	Иначе
		ДатаРаботы = Параметры.Дата;
	КонецЕсли;
	
	ЦветРабочегоВремени 	= Новый Цвет(255, 255, 255);	
	ШиринаЭкранаСтрокой		= Сред(Параметры.РазрешениеЭкрана, 1, Найти(Параметры.РазрешениеЭкрана, "*") - 1);
	ШиринаЭкрана 			= ?(ЗначениеЗаполнено(ШиринаЭкранаСтрокой), Число(ШиринаЭкранаСтрокой), 640);	
	// 3. Определение места в периоде
	ТаблицаКобработке = ТаблицаИнтервалов.Скопировать();	
	НомерСтрокиНачало = 0;
	НомерСтрокиКонец  = 0;	
	ДобавочнаяШиринаПоследнейЯчеки = 0;	
	Если ТаблицаКобработке.Количество() > 0 Тогда		
		КопияТаблицаКобработке = ТаблицаКобработке.Скопировать();		
		КопияТаблицаКобработке.Сортировать("НомерНачальнойСтроки ВОЗР");
		НомерСтрокиНачало = КопияТаблицаКобработке[0].НомерНачальнойСтроки;		
		КопияТаблицаКобработке.Сортировать("НомерКонечнойСтроки УБЫВ");
		НомерСтрокиКонец = КопияТаблицаКобработке[0].НомерКонечнойСтроки;		
	КонецЕсли; 
	
	КоличествоСтрок = (60/ИнтервалВремени) * 24;
	СписокЗначенийВремен = Новый СписокЗначений;	
	Если НомерСтрокиНачало <> 0 И НомерСтрокиКонец <> 0 Тогда		
		Для а=1 По КоличествоСтрок Цикл
			НовыйСписок = Новый СписокЗначений;
			СписокЗначенийВремен.Добавить(НовыйСписок);
		КонецЦикла;		
		Для а=НомерСтрокиНачало По НомерСтрокиКонец Цикл			
			НовыйСписок = СписокЗначенийВремен[а-1].Значение;			
			ИндексСтрокиТаблицы = 0;
			Пока Истина Цикл				
				Если ИндексСтрокиТаблицы > ТаблицаКобработке.Количество() - 1 Тогда
					Прервать;
				КонецЕсли; 				
				СтрокаТаблицы = ТаблицаКобработке[ИндексСтрокиТаблицы];				
				Если СтрокаТаблицы.НомерНачальнойСтроки <= а И СтрокаТаблицы.НомерКонечнойСтроки >= а Тогда					
					ЕстьСвободноеМесто = Ложь;					
					Для каждого ЭлементНовогоСписка Из НовыйСписок Цикл						
						Если ЭлементНовогоСписка.Значение = Неопределено Тогда							
							ЭлементНовогоСписка.Значение = СтрокаТаблицы.ИндексСтроки;							
							ЕстьСвободноеМесто = Истина;
							ИндексСписка = НовыйСписок.Индекс(ЭлементНовогоСписка);
							Прервать;							
						КонецЕсли;						
					КонецЦикла;					
					Если НЕ ЕстьСвободноеМесто Тогда						
						Если НовыйСписок.Количество() >= 18 Тогда
							Прервать;
						КонецЕсли; 						
						ВновьВведенныйЭлемент = НовыйСписок.Добавить(СтрокаТаблицы.ИндексСтроки);
						ИндексСписка = НовыйСписок.Индекс(ВновьВведенныйЭлемент);						
					КонецЕсли;					
					Если а <= СписокЗначенийВремен.Количество() Тогда						
						ИндексТекущегоСписка = а - 1 + 1;
						Для б = а По СтрокаТаблицы.НомерКонечнойСтроки - 1 Цикл							
							ТекущийСписок = СписокЗначенийВремен[б].Значение;							
							Если ТекущийСписок.Количество() < (ИндексСписка + 1) Тогда								
								Для с = (ТекущийСписок.Количество() + 1) По (ИндексСписка + 1) Цикл									
									ТекущийСписок.Добавить(Неопределено);									
								КонецЦикла;								
							КонецЕсли;						
							ТекущийСписок[ИндексСписка].Значение = СтрокаТаблицы.ИндексСтроки;							
						КонецЦикла; 						
					КонецЕсли; 					
					ТаблицаКобработке.Удалить(СтрокаТаблицы);
					Продолжить;					
				КонецЕсли;				
				ИндексСтрокиТаблицы = ИндексСтрокиТаблицы + 1;				
			КонецЦикла; 			
		КонецЦикла;		
	КонецЕсли; 
	
	// Проведем распределение заново
	МаксимальноеКоличество = 0;
	Для каждого СтрокаВремени Из СписокЗначенийВремен Цикл
		СписокТекущегоВремени = СтрокаВремени.Значение;
		Если СписокТекущегоВремени.Количество() > МаксимальноеКоличество Тогда
			МаксимальноеКоличество = СписокТекущегоВремени.Количество();		
		КонецЕсли;
	КонецЦикла;	
	Для каждого СтрокаВремени Из СписокЗначенийВремен Цикл		
		СписокТекущегоВремени = СтрокаВремени.Значение;	
		Если ТипЗнч(СписокТекущегоВремени) = Тип("СписокЗначений") И СписокТекущегоВремени.Количество() > 0 Тогда		
			Для каждого ЭлементДокумента Из СписокТекущегоВремени Цикл			
				СтрокиТаблицыИнтервалов = ТаблицаИнтервалов.НайтиСтроки(Новый Структура("ИндексСтроки", ЭлементДокумента.Значение));
				Для каждого СтрокаТаблицы Из СтрокиТаблицыИнтервалов Цикл				
					СтрокаТаблицы.ПорядковыйНомерВДне = СписокТекущегоВремени.Индекс(ЭлементДокумента) + 1;				
				КонецЦикла;								
			КонецЦикла; 			
		КонецЕсли; 		
	КонецЦикла;	
	
    ИндексНачалаГруппы = -1;
	ИндексОкончанияГруппы = -1;
	Для ИнтексСписокЗначенийВремен = 0 По СписокЗначенийВремен.Количество() - 1 Цикл
		Если ИндексНачалаГруппы = -1 И СписокЗначенийВремен[ИнтексСписокЗначенийВремен].Значение.Количество() > 0 Тогда
			ИндексНачалаГруппы = ИнтексСписокЗначенийВремен;
		КонецЕсли;
		СовпаденияВСледующейСтроке = Ложь;
		Для Каждого ЭлементСписка Из СписокЗначенийВремен[ИнтексСписокЗначенийВремен].Значение Цикл
			Если ИнтексСписокЗначенийВремен < СписокЗначенийВремен.Количество() - 1 И СписокЗначенийВремен[ИнтексСписокЗначенийВремен + 1].Значение.НайтиПоЗначению(ЭлементСписка.Значение) <> Неопределено Тогда
				СовпаденияВСледующейСтроке = Истина;
			КонецЕсли;
		КонецЦикла;
		Если ИндексНачалаГруппы > 0 И (ИнтексСписокЗначенийВремен = СписокЗначенийВремен.Количество() - 1 ИЛИ Не СовпаденияВСледующейСтроке) Тогда
			ИндексОкончанияГруппы = ИнтексСписокЗначенийВремен;
		КонецЕсли;		
		Если ИндексНачалаГруппы >= 0 И ИндексОкончанияГруппы >= 0 Тогда
			КоличествоОдновременныхДокументов = 0;
			Для а = ИндексНачалаГруппы По ИндексОкончанияГруппы Цикл
				Если КоличествоОдновременныхДокументов < СписокЗначенийВремен[а].Значение.Количество() Тогда
					КоличествоОдновременныхДокументов = СписокЗначенийВремен[а].Значение.Количество();
				КонецЕсли;
			КонецЦикла;
			Для а = ИндексНачалаГруппы По ИндексОкончанияГруппы Цикл
				Для Каждого ЭлементСписка Из СписокЗначенийВремен[а].Значение Цикл
					Для каждого СтрокаТаблицы Из ТаблицаИнтервалов.НайтиСтроки(Новый Структура("ИндексСтроки", ЭлементСписка.Значение)) Цикл
						СтрокаТаблицы.КоличествоОдновременныхДокументов = КоличествоОдновременныхДокументов;	
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			ИндексНачалаГруппы = -1;
			ИндексОкончанияГруппы = -1;
		КонецЕсли;
	КонецЦикла;
	
	// Построение
	
	СмещениеОтНачалаПервойЯчейкиДня = Час(Параметры.ОграничениеВремениС) * (60/ИнтервалВремени);
	НомерПоследнейЯчейкиДня         = Час(Параметры.ОграничениеВремениПо)* (60/ИнтервалВремени) + ?(Минута(Параметры.ОграничениеВремениПо) > 0, (60/ИнтервалВремени), 0);

	КоэфРазрешения = КоэффициентЭкранаПоРазрешению(ШиринаЭкрана);
	
	ШиринаТабличногоПоляДня = Цел(ШиринаЭкрана / КоэфРазрешения) - 4 - 2 - ?(ВставитьРазделительДней, 4 + 2, 0) + ?(Параметры.Свойство("НаВсюФорму") И Параметры.НаВсюФорму = Истина, 34, 0); 
	//	ШиринаТабличногоПоляДня = 140; // Цел(ШиринаЭкрана / КоэфРазрешения) - 4 - 2 - ?(ВставитьРазделительДней, 4 + 2, 0) + ?(Параметры.Свойство("НаВсюФорму") И Параметры.НаВсюФорму = Истина, 34, 0); 
	ОбщаяШиринаДня = Цел(ШиринаТабличногоПоляДня / (ВсегоГрупп * 4));
	
	Если НомерГруппы >= (ВсегоГрупп - (ШиринаТабличногоПоляДня - (ОбщаяШиринаДня * 4) * ВсегоГрупп) / 4) + 1 Тогда
		ОбщаяШиринаДня = ОбщаяШиринаДня + 1;
	КонецЕсли;
	ДобавочнаяШиринаПоследнейЯчеки = ШиринаТабличногоПоляДня % 1;
	Если ШиринаТабличногоПоляДня / (ВсегоГрупп * 4) < 4 Тогда
		ОбщаяШиринаДня = 4;
		Если Не Параметры.Свойство("ОграничениеНаШиринуДня") Тогда
			Параметры.Вставить("ОграничениеНаШиринуДня", 4);
		КонецЕсли;
	КонецЕсли;	
	
	ВыводитьСтрокуЛистОжидания = Ложь;
	Параметры.Свойство("ВыводитьСтрокуЛистОжидания", ВыводитьСтрокуЛистОжидания);
	
	РазмерШапки      = ?(ВыводитьСтрокуЛистОжидания = Истина, 2, 1);	
	СмещениеДняСлева = ТабличныйДокумент.ШиринаТаблицы;
	
	// Вставляем область времени
	Если НомерГруппы = 1 Или ВставитьРазделительДней Тогда
		ТабличныйДокумент.ВставитьОбласть(Параметры.МакетДня.Область(СмещениеОтНачалаПервойЯчейкиДня + 1, 1, НомерПоследнейЯчейкиДня, 2), ТабличныйДокумент.Область(1 + РазмерШапки, 1 + СмещениеДняСлева, НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, 2 + СмещениеДняСлева));
		ТабличныйДокумент.Область(, 1 + СмещениеДняСлева, , 1 + СмещениеДняСлева).ШиринаКолонки  = 4;
		ТабличныйДокумент.Область(, 2 + СмещениеДняСлева, , 2 + СмещениеДняСлева).ШиринаКолонки  = 2;
		Для а = РазмерШапки + 1 По ТабличныйДокумент.ВысотаТаблицы Цикл
			ТабличныйДокумент.Область(а, СмещениеДняСлева + 2).Расшифровка = Дата(01,01,01) + ((СмещениеОтНачалаПервойЯчейкиДня - РазмерШапки) + а - 1) * ИнтервалВремени * 60;
		КонецЦикла;
	КонецЕсли;	
	
	Если НомерГруппы = 1 Тогда
		ШиринаЧасов = 2;
	ИначеЕсли ВставитьРазделительДней Тогда
		ШиринаЧасов = 2;
	Иначе
		ШиринаЧасов = 0;
	КонецЕсли;
	
	// Вставляем область группы из макента
	ТабличныйДокумент.ВставитьОбласть(Параметры.МакетДня.Область(СмещениеОтНачалаПервойЯчейкиДня + 1, 2 + 1, НомерПоследнейЯчейкиДня, 2 + ОбщаяШиринаДня), ТабличныйДокумент.Область(РазмерШапки + 1, ШиринаЧасов + СмещениеДняСлева + 1, НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, ШиринаЧасов + СмещениеДняСлева + ОбщаяШиринаДня));
	// ТабличныйДокумент.Область(РазмерШапки + 1, , НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, ).ВысотаСтроки = 11;
	ТабличныйДокумент.Область(, ШиринаЧасов + СмещениеДняСлева + 1, , ШиринаЧасов + СмещениеДняСлева + ОбщаяШиринаДня).ШиринаКолонки = 4;
	Если НомерГруппы = ВсегоГрупп И ЗначениеЗаполнено(ДобавочнаяШиринаПоследнейЯчеки) Тогда
		ТабличныйДокумент.Область(, ШиринаЧасов + СмещениеДняСлева + ОбщаяШиринаДня, , ШиринаЧасов + СмещениеДняСлева + ОбщаяШиринаДня).ШиринаКолонки = 4 + ДобавочнаяШиринаПоследнейЯчеки;
	КонецЕсли;
	
	// Наименование дня
	ЗаполнениеГрафикаСобытийПоГруппамСформироватьОбластьНаименованияДняНедели(
	ТабличныйДокумент,	
	ГруппировкаСсылка, 
	МассивСотрудниковИОбластей,
	Параметры,
	ВыводНаПечать, 
	ОбщаяШиринаДня, 
	РазмерШапки, 
	СмещениеДняСлева, 
	ШиринаЧасов,
	ВсегоГрупп);
	
	// Вывод событий дня		
	ОбластьРабочегоДня = ТабличныйДокумент.Область(1 + РазмерШапки, 1 + ШиринаЧасов + СмещениеДняСлева,НомерПоследнейЯчейкиДня-СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, ОбщаяШиринаДня + ШиринаЧасов + СмещениеДняСлева);
	ОбластьРабочегоДня.ЦветФона = Новый Цвет(218, 212, 205);
	
	// Устанавливаем цвет работы сотрудника
	Если Параметры.ВыбранныеСотрудники.Количество() = 1 И ТипЗнч(Параметры.ВыбранныеСотрудники[0]) = Тип("СправочникСсылка.Сотрудники") Тогда
		ОбъектРасскрашивания = Параметры.ВыбранныеСотрудники[0];
	ИначеЕсли ТипЗнч(ГруппировкаСсылка) = Тип("СправочникСсылка.Сотрудники") Тогда
		ОбъектРасскрашивания = ГруппировкаСсылка;
	ИначеЕсли ТипЗнч(ГруппировкаСсылка) = Тип("Дата") Или ТипЗнч(ГруппировкаСсылка) = Тип("СправочникСсылка.Помещения") Тогда
		ОбъектРасскрашивания = Параметры.СтруктурнаяЕдиница;
	Иначе
		ОбъектРасскрашивания = ГруппировкаСсылка;
	КонецЕсли;	
	
	НомерНачалоПериодаРаботыСтоматологии = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоДате(Параметры.ОграничениеВремениС, Ложь) - СмещениеОтНачалаПервойЯчейкиДня;
	НомерОкончанияПериодаРаботыСтоматологии = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоДате(Параметры.ОграничениеВремениПО, Истина) - СмещениеОтНачалаПервойЯчейкиДня;
		
	// Юля 	
	Если Параметры.СтраницаМенеджера = "Сотрудники"  Тогда
		Если Не МассивВремяРаботыСотрудника = Неопределено Тогда
			Для Каждого ПериодРаботыГруппы Из МассивВремяРаботыСотрудника Цикл
				НомерНачалоПериода = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоДате(ПериодРаботыГруппы.Начало, Ложь, ИнтервалВремени) - СмещениеОтНачалаПервойЯчейкиДня;
				НомерОкончанияПериода = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоДате(ПериодРаботыГруппы.Окончание, Истина, ИнтервалВремени) - СмещениеОтНачалаПервойЯчейкиДня;		
				Если (НомерНачалоПериода < 0 И НомерОкончанияПериода < 0) Или (НомерНачалоПериода > НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня И НомерОкончанияПериода > НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня) Тогда 
					Продолжить;
				КонецЕсли;	
				НомерНачалаРаботыСтруктурнойЕдиницы = ?(НомерНачалоПериода < НомерНачалоПериодаРаботыСтоматологии, НомерНачалоПериодаРаботыСтоматологии, НомерНачалоПериода);
				НомерОкончанияРаботыСтруктурнойЕдиницы =  ?(НомерОкончанияПериода > НомерОкончанияПериодаРаботыСтоматологии, НомерОкончанияПериодаРаботыСтоматологии, НомерОкончанияПериода);	
				ОбластьРабочегоДня = ТабличныйДокумент.Область(РазмерШапки + НомерНачалоПериода, 1 + ШиринаЧасов + СмещениеДняСлева, РазмерШапки + НомерОкончанияПериода, ОбщаяШиринаДня + ШиринаЧасов + СмещениеДняСлева);
				ОбластьРабочегоДня.ЦветФона = ЦветРабочегоВремени;// ЦветаСтиля.ЦветФонаКнопки;		
			КонецЦикла;
		КонецЕсли;
	Иначе 		
		Для Каждого ПериодРаботыГруппы Из ОбщегоНазначенияСтоматология.ВернутьПериодыРаботы(ОбъектРасскрашивания, ДатаРаботы, Новый Структура("СтруктурнаяЕдиница, КолДней", Параметры.СтруктурнаяЕдиница, 1)) Цикл
			НомерНачалоПериода = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоДате(ПериодРаботыГруппы.Начало, Ложь, ИнтервалВремени) - СмещениеОтНачалаПервойЯчейкиДня;
			НомерОкончанияПериода = ОбщегоНазначенияКлиентСерверСтоматология.ВозвратитьНомерСтрокиПоДате(ПериодРаботыГруппы.Окончание, Истина, ИнтервалВремени) - СмещениеОтНачалаПервойЯчейкиДня;		
			Если (НомерНачалоПериода < 0 И НомерОкончанияПериода < 0) Или (НомерНачалоПериода > НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня И НомерОкончанияПериода > НомерПоследнейЯчейкиДня - СмещениеОтНачалаПервойЯчейкиДня) Тогда 
				Продолжить;
			КонецЕсли;	
			НомерНачалаРаботыСтруктурнойЕдиницы = ?(НомерНачалоПериода < НомерНачалоПериодаРаботыСтоматологии, НомерНачалоПериодаРаботыСтоматологии, НомерНачалоПериода);
			НомерОкончанияРаботыСтруктурнойЕдиницы =  ?(НомерОкончанияПериода > НомерОкончанияПериодаРаботыСтоматологии, НомерОкончанияПериодаРаботыСтоматологии, НомерОкончанияПериода);	
			ОбластьРабочегоДня = ТабличныйДокумент.Область(РазмерШапки + НомерНачалоПериода, 1 + ШиринаЧасов + СмещениеДняСлева, РазмерШапки + НомерОкончанияПериода, ОбщаяШиринаДня + ШиринаЧасов + СмещениеДняСлева);
			ОбластьРабочегоДня.ЦветФона = ЦветРабочегоВремени;// ЦветаСтиля.ЦветФонаКнопки;		
		КонецЦикла;	
	КонецЕсли;
	// Конец
	
	КонечнаяСтрокаРабочегоДня  = Неопределено;
	НачальнаяСтрокаРабочегоДня = Неопределено;
    // СтруктураРасшифровки       = Новый Структура("Дата,Интервал,Сотрудник, РабочееВремя,Событие, ИндексВТЧ");         
	Для а = СмещениеОтНачалаПервойЯчейкиДня + 1 По НомерПоследнейЯчейкиДня Цикл			
		ТекОбласть = ТабличныйДокумент.Область(а - СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, СмещениеДняСлева + ШиринаЧасов + 1, а - СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, СмещениеДняСлева + ШиринаЧасов + ОбщаяШиринаДня);
		Объединять = Истина;
		Для Каждого СтрокаТИ Из ТаблицаИнтервалов Цикл
			Если СтрокаТИ.НомерНачальнойСтроки <= а
				И СтрокаТИ.НомерКонечнойСтроки >= а Тогда
				Объединять = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Объединять Тогда
			ТекОбласть.Объединить();	
		КонецЕсли;
		Интервал     = а - 1;
		ПараметрОснования = Неопределено;
		Если ТипЗнч(ГруппировкаСсылка) = Тип("Дата") Тогда
			Дата = ГруппировкаСсылка;
		Иначе
			Дата              = ДатаРаботы;
			ПараметрОснования = ГруппировкаСсылка;			
		КонецЕсли;
		РабочееВремя   = ТекОбласть.ЦветФона = ЦветРабочегоВремени;	
		СтрокаВозврата = "" + Дата 
		              + "," + Интервал 
	                  + "," + ?(ЗначениеЗаполнено(ПараметрОснования),ПараметрОснования.УникальныйИдентификатор(),"")
		              + "," + РабочееВремя;	
		ТекОбласть.Расшифровка = СтрокаВозврата;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СписокЗначенийВремен) Тогда		
		Если ТипЗнч(ТаблицаИнтервалов) = Тип("ТаблицаЗначений") Тогда
			Если ТаблицаИнтервалов.Колонки.Найти("ИндексСтроки")<>Неопределено ТОгда
				ТаблицаИнтервалов.Индексы.Добавить("ИндексСтроки");
			КонецЕсли;
		КонецЕсли;		
		ОбщаяШиринаДняДляРаспределенияСобытий = ОбщаяШиринаДня;		
		// определим колонки для таблицы событий (независимо от диапазона показа)
		Для а = 0 По КоличествоСтрок-1 Цикл		
			ПоследнийСтолбец = 0;		
			СписокТекущихДокументов = СписокЗначенийВремен.Получить(а).Значение;		
			Для каждого ТекДокумент Из СписокТекущихДокументов Цикл			
				СтрокаТаблицыДокументов = ТаблицаИнтервалов.Найти(ТекДокумент.Значение, "ИндексСтроки");
				Если СтрокаТаблицыДокументов <> Неопределено Тогда
					ШиринаТекущегоДокумента = Цел(ОбщаяШиринаДняДляРаспределенияСобытий/?(СтрокаТаблицыДокументов.КоличествоОдновременныхДокументов=0, 1, СтрокаТаблицыДокументов.КоличествоОдновременныхДокументов));
				Иначе
					ШиринаТекущегоДокумента = 0;
					Продолжить;
				КонецЕсли;			
				Если СтрокаТаблицыДокументов.ПорядковыйНомерВДне = СтрокаТаблицыДокументов.КоличествоОдновременныхДокументов Тогда
					ШиринаТекущегоДокумента = ОбщаяШиринаДняДляРаспределенияСобытий - ПоследнийСтолбец;
				КонецЕсли;  			
				Если СтрокаТаблицыДокументов.НомерНачальнойКолонки = 0 И СтрокаТаблицыДокументов.НомерКонечнойКолонки = 0 Тогда
					СтрокаТаблицыДокументов.НомерНачальнойКолонки = ПоследнийСтолбец + 1;
					СтрокаТаблицыДокументов.НомерКонечнойКолонки = ПоследнийСтолбец + ШиринаТекущегоДокумента;
				КонецЕсли;			
				ПоследнийСтолбец = СтрокаТаблицыДокументов.НомерНачальнойКолонки - 1 + ШиринаТекущегоДокумента;				
			КонецЦикла; 			
		КонецЦикла;   
		
		ИндексСтрокиТаблицы = 0;
		// СтруктураДанных     = Новый Структура("Событие, ИндексВТЧ,РабочееВремя");
		Пока Истина Цикл		
			Если ИндексСтрокиТаблицы > ТаблицаИнтервалов.Количество() - 1 Тогда
				Прервать;
			КонецЕсли; 		
			СтрокаТаблицы = ТаблицаИнтервалов[ИндексСтрокиТаблицы];		
			Если СтрокаТаблицы.НомерНачальнойКолонки = 0 ИЛИ СтрокаТаблицы.НомерКонечнойКолонки = 0 Тогда
				ТаблицаИнтервалов.Удалить(СтрокаТаблицы);
			Иначе
				ИндексСтрокиТаблицы = ИндексСтрокиТаблицы + 1;
			КонецЕсли; 			
		КонецЦикла; 		
		Для каждого СтрокаТаблицы Из ТаблицаИнтервалов Цикл		
			ПерваяСтрокаОбласти    = СтрокаТаблицы.НомерНачальнойСтроки-СмещениеОтНачалаПервойЯчейкиДня;
			ПоследняяСтрокаОбласти = СтрокаТаблицы.НомерКонечнойСтроки-СмещениеОтНачалаПервойЯчейкиДня;
			Если ПерваяСтрокаОбласти < 1 Тогда
				Если ПоследняяСтрокаОбласти < 1 Тогда
					Продолжить;
				Иначе
					ПерваяСтрокаОбласти = 1;
				КонецЕсли;
			ИначеЕсли ПерваяСтрокаОбласти > НомерПоследнейЯчейкиДня-СмещениеОтНачалаПервойЯчейкиДня Тогда
				Продолжить;
			КонецЕсли;		
			Если ПоследняяСтрокаОбласти > НомерПоследнейЯчейкиДня-СмещениеОтНачалаПервойЯчейкиДня Тогда
				ПоследняяСтрокаОбласти = НомерПоследнейЯчейкиДня-СмещениеОтНачалаПервойЯчейкиДня;
			КонецЕсли;			
				
			ВысотаГруппы = (ПоследняяСтрокаОбласти + РазмерШапки) - (ПерваяСтрокаОбласти + РазмерШапки);
			
			Отбор = Новый Структура("Событие",СтрокаТаблицы.Событие);
			
			МассивМетокСобытия = Параметры.ТаблицаМеток.НайтиСтроки(Отбор);
			
			// ТаблицаМетокСобытия = РегистрыСведений.МеткиКлиентов.ПолучитьМеткиКлиента(СтрокаТаблицы.Событие,ТекущаяДата());
			// Если ТаблицаМетокСобытия.Количество() > 0 Тогда
			Если МассивМетокСобытия.Количество() > 0 Тогда
				СдвигДляМетки = Цел(МассивМетокСобытия.Количество() / (ВысотаГруппы+1))+?((МассивМетокСобытия.Количество() / (ВысотаГруппы+1))-Цел(МассивМетокСобытия.Количество() / (ВысотаГруппы+1)) > 0, 1, 0);
			Иначе
				СдвигДляМетки = 1;
			КонецЕсли;                              			
			СтолбецМетки    = 0;
			СтрокаМетки     = 0;      
			
			// Для Индекс = 0 По ВысотаГруппы Цикл
			//	ОбластьМеток = ТабличныйДокумент.Область(ПерваяСтрокаОбласти + РазмерШапки + Индекс, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов, ПерваяСтрокаОбласти + РазмерШапки + Индекс, СтрокаТаблицы.НомерНачальнойКолонки + 6 + СмещениеДняСлева + ШиринаЧасов);			
			//	ОбластьМеток.Разъединить();
			// КонецЦикла;
			
			Для Индекс = 0 По СдвигДляМетки*(ВысотаГруппы+1)-1 Цикл
				Если СтолбецМетки < Цел(Индекс/(ВысотаГруппы+1)) Тогда
					СтолбецМетки = Цел(Индекс/(ВысотаГруппы+1));
					СтрокаМетки = 0;
				КонецЕсли;
				ОбластьМетки = ТабличныйДокумент.Область(ПерваяСтрокаОбласти + РазмерШапки + СтрокаМетки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СтолбецМетки, ПерваяСтрокаОбласти + РазмерШапки + СтрокаМетки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СтолбецМетки);
				Если СтрокаМетки < ВысотаГруппы Тогда
					ОбластьМетки.ГраницаСнизу = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.НетЛинии);
					ОбластьМетки.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.НетЛинии);
				Иначе
					ОбластьМетки.ГраницаСнизу = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
				КонецЕсли;
				ОбластьМетки.Текст = "";
				
				Если Индекс <= МассивМетокСобытия.Количество()-1 Тогда				
					Если ЗначениеЗаполнено(МассивМетокСобытия[Индекс].Метка.ЦветМетки) Тогда
						ОбластьМетки.ЦветФона = ЗначениеИзСтрокиВнутр(МассивМетокСобытия[Индекс].Метка.ЦветМетки);		
					Иначе
						ОбластьМетки.ЦветФона = Новый Цвет();
					КонецЕсли;	
				Иначе 
					ОбластьМетки.ЦветФона = ОбщегоНазначенияСтоматология.ПолучитьЦветФонаСобытия(СтрокаТаблицы.Статус, СтрокаТаблицы.Событие, , СтрокаТаблицы.ЭтоПеренос);
				КонецЕсли;
				СтрокаМетки    = СтрокаМетки + 1;
				Интервал       = "";
				Дата           = "";
				РабочееВремя   = Истина;	
				// Преобразование массива в строку
				ИндексВТЧМассив = "";
				Если  ТипЗнч(СтрокаТаблицы.ИндексВТЧ) = Тип("Массив") Тогда
					Для Каждого Элемент ИЗ СтрокаТаблицы.ИндексВТЧ Цикл
						ИндексВТЧМассив = ИндексВТЧМассив + Элемент + ";";	
					КонецЦикла;	 
				Иначе
					ИндексВТЧМассив = "" + СтрокаТаблицы.ИндексВТЧ + ";";
				КонецЕсли;				
				Если ТипЗнч(СтрокаТаблицы.Событие) = Тип("Структура") Тогда
					Дата                   = СтрокаТаблицы.Событие.ДатаВремяНачала;
					Интервал               = СтрокаТаблицы.Событие.ДатаВремяОкончания - СтрокаТаблицы.Событие.ДатаВремяНачала;
					ПараметрОснования      = ?(ЗначениеЗаполнено(СтрокаТаблицы.Событие.Сотрудник),СтрокаТаблицы.Событие.Сотрудник.УникальныйИдентификатор(),"");
					РабочееВремя           = СтрокаТаблицы.Событие.ПризнакДежурства;
					ОбластьМетки.Расшифровка = "" +Дата+ "," +Интервал+  "," +ПараметрОснования +"," +РабочееВремя+ ",,,," + СтрокаТаблицы.ЭтоПеренос;
				Иначе
					Дата                   = СтрокаТаблицы.ДатаИнтервала;
					Интервал               = СтрокаТаблицы.НомерНачальнойСтроки - 1;
					ПараметрОснования      = ?(ЗначениеЗаполнено(СтрокаТаблицы.Сотрудник),СтрокаТаблицы.Сотрудник.УникальныйИдентификатор(),"");			
					ДокументЗаписи         = ?(ЗначениеЗаполнено(СтрокаТаблицы.Событие),СтрокаТаблицы.Событие.УникальныйИдентификатор(),"");
					Резерв                 = ?(ТипЗнч(СтрокаТаблицы.Событие) = Тип("ДокументСсылка.Событие"), СтрокаТаблицы.Резерв, "");	
					ОбластьМетки.Расшифровка = "" +Дата+ "," +Интервал+ "," +ПараметрОснования+ ",Да," +ДокументЗаписи+ "," +ИндексВТЧМассив+","+Резерв+","+ СтрокаТаблицы.ЭтоПеренос;
				КонецЕсли;				
			КонецЦикла;
			
//=====================================================РАБОТА С ПИКТОГРАММАМИ В ЯЧЕЙКЕ ПРЕДВАРИТЕЛЬНОЙ ЗАПИСИ=======================================================
			СдвигДляКартинкиЗадолженность 				= 0;
			СдвигДляКартинкиНезавершенныеНарядЗаказы 	= 0;
			Если Параметры.Свойство("ВыводитьКартинки") И Параметры.ВыводитьКартинки = Истина Тогда 
				СдвигДляКартинкиЗадолженность 				= ?(СтрокаТаблицы.ЕстьЗадолженность, 1, 0);
				СдвигДляКартинкиНезавершенныеНарядЗаказы 	= ?(СтрокаТаблицы.ЕстьНезавершенныеНарядЗаказы, 1, 0);
			КонецЕсли;
			ТекОбласть = ТабличныйДокумент.Область(ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки, ПоследняяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерКонечнойКолонки + СмещениеДняСлева + ШиринаЧасов);
			ТекОбластьДляКартинок1 = ТабличныйДокумент.Область(ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки, ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки);
			ТекОбластьДляКартинок2 = ТабличныйДокумент.Область(ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки + СдвигДляКартинкиЗадолженность, ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки + СдвигДляКартинкиЗадолженность);			
			ТекОбластьДляКартинок3 = ТабличныйДокумент.Область(ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки + СдвигДляКартинкиЗадолженность + СдвигДляКартинкиНезавершенныеНарядЗаказы, ПерваяСтрокаОбласти + РазмерШапки, СтрокаТаблицы.НомерНачальнойКолонки + СмещениеДняСлева + ШиринаЧасов + СдвигДляМетки + СдвигДляКартинкиЗадолженность + СдвигДляКартинкиНезавершенныеНарядЗаказы);			
			ТекстЯчейки = "";			
			// Вставляем в область картинку состояния блокировки услуги
			Если СтрокаТаблицы.ПризнакЗаблокированно = 1 И Параметры.Свойство("ВыводитьКартинки") И Параметры.ВыводитьКартинки = Истина Тогда
				// Добавляем новый Рисунок типа Картинка
				РисунокТД = ТабличныйДокумент.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка); 
				// выводим рисунов в область документа
				РисунокТД.Расположить(ТекОбласть);
				РисунокТД.Высота   = 4; РисунокТД.Ширина = 4;	
				РисунокТД.Линия    = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
				РисунокТД.Узор     = ТипУзораТабличногоДокумента.БезУзора;
				РисунокТД.Картинка = ?(СтрокаТаблицы.ПризнакЗаблокированно = 1, БиблиотекаКартинок.ЗамокБлокировкаБелая, БиблиотекаКартинок.КартинкаОсвободить);
				ТекстЯчейки        = ТекстЯчейки + "     ";
			КонецЕсли;			
			Если СтрокаТаблицы.ТелефонныйЗвонок И Параметры.Свойство("ВыводитьКартинки") И Параметры.ВыводитьКартинки = Истина Тогда
				// Добавляем новый Рисунок типа Картинка для телефонного звонка
				РисунокТД = ТабличныйДокумент.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка); 
				// выводим рисунов в область документа
			   	РисунокТД.РазмерКартинки = РазмерКартинки.АвтоРазмер;
				РисунокТД.Линия    = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
				РисунокТД.Узор     = ТипУзораТабличногоДокумента.БезУзора;
				РисунокТД.Картинка = БиблиотекаКартинок.ВидВзаимодействияБелая_21;
				РисунокТД.Расположить(ТекОбластьДляКартинок1);
		       	ТекстЯчейки        = ТекстЯчейки + "         ";
			КонецЕсли;	
			
			
			Если СтрокаТаблицы.ЕстьЗадолженность И Параметры.Свойство("ВыводитьКартинки") И Параметры.ВыводитьКартинки = Истина Тогда
				// Добавляем новый Рисунок типа Картинка для задолженности
				РисунокТД = ТабличныйДокумент.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка); 
				// выводим рисунов в область документа
			   	РисунокТД.РазмерКартинки = РазмерКартинки.АвтоРазмер;
				РисунокТД.Линия    = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
				РисунокТД.Узор     = ТипУзораТабличногоДокумента.БезУзора;
				РисунокТД.Картинка = БиблиотекаКартинок.ВидВзаимодействияБелая_12;
				РисунокТД.Расположить(?(СтрокаТаблицы.ТелефонныйЗвонок, ТекОбластьДляКартинок2, ТекОбластьДляКартинок1));
		       	ТекстЯчейки        = ?(СтрокаТаблицы.ТелефонныйЗвонок, ТекстЯчейки + "           ", ТекстЯчейки + "         ");
			КонецЕсли;
			Если СтрокаТаблицы.ЕстьНезавершенныеНарядЗаказы И Параметры.Свойство("ВыводитьКартинки") И Параметры.ВыводитьКартинки = Истина Тогда
				// Добавляем новый Рисунок типа Картинка для отображения статуса незавершенных наряд-заказов
				РисунокТД = ТабличныйДокумент.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка); 
				// выводим рисунов в область документа
			   	РисунокТД.РазмерКартинки = РазмерКартинки.АвтоРазмер;
				РисунокТД.Линия    = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
				РисунокТД.Узор     = ТипУзораТабличногоДокумента.БезУзора;
				Если СтрокаТаблицы.ОбщийСтатусНезавершенныхНарядЗаказов = Перечисления.СтатусыНарядЗаказа.Заказано Тогда 
					РисунокТД.Картинка = БиблиотекаКартинок.СтатусЗаказаноБелая;
				ИначеЕсли СтрокаТаблицы.ОбщийСтатусНезавершенныхНарядЗаказов = Перечисления.СтатусыНарядЗаказа.ВРаботе Тогда	
					РисунокТД.Картинка = БиблиотекаКартинок.СтатусВРаботеБелая;
				ИначеЕсли СтрокаТаблицы.ОбщийСтатусНезавершенныхНарядЗаказов = Перечисления.СтатусыНарядЗаказа.Выполнено Тогда
					РисунокТД.Картинка = БиблиотекаКартинок.СтатусВыполненоБелая;
				КонецЕсли;	
				Если СтрокаТаблицы.ТелефонныйЗвонок Тогда 
					Если СтрокаТаблицы.ЕстьЗадолженность Тогда 
						РисунокТД.Расположить(ТекОбластьДляКартинок3);
						ТекстЯчейки = ТекстЯчейки + "         ";
					Иначе 
						РисунокТД.Расположить(ТекОбластьДляКартинок3);
						ТекстЯчейки = ТекстЯчейки + "           ";
					КонецЕсли;
				Иначе 
					Если СтрокаТаблицы.ЕстьЗадолженность Тогда
						РисунокТД.Расположить(ТекОбластьДляКартинок2);
						ТекстЯчейки = ТекстЯчейки + "           ";
					Иначе 
						РисунокТД.Расположить(ТекОбластьДляКартинок1);
						ТекстЯчейки = ТекстЯчейки + "         ";
					КонецЕсли;	
				КонецЕсли;		
			КонецЕсли;	
			
			//=======================================================РАБОТА С ТЕКСТОМ В ЯЧЕЙКЕ ПРЕДВАРИТЕЛЬНОЙ ЗАПИСИ=========================================================
			
			ТекстЯчейки = ТекстЯчейки + ?(СтрокаТаблицы.ЭтоПеренос, "[Перенос] ", "");
			
			// Вставляем в область номер услуги в ТЧ
			Если СтрокаТаблицы.НомерБлокаСобытий > 0 Тогда
				ТекстЯчейки = ТекстЯчейки + "[ " + Строка(СтрокаТаблицы.НомерБлокаСобытий) + " ]" + " ";
			КонецЕсли;
			// Вставляем номер мед.карты, ФИО и телефон
			Если ЗначениеЗаполнено(СтрокаТаблицы.Контрагент) Тогда
				Если Найти(СтрокаТаблицы.Комментарий, СтрокаТаблицы.ФИОПациента) > 0 Тогда // Если комментарий заполнен контактной информацией, сформированной в ПЗ
					Комментарий = СтрокаТаблицы.Комментарий;					
					Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач Тогда // Если это врач вырезаем телефон
						Комментарий = СтрЗаменить(Комментарий, ", тел. " + СтрокаТаблицы.Контрагент.Телефон, "");
					КонецЕсли;
					
					Телефон     = ?(Константы.НеВыводитьТелефонКлиентаВЖурнале.Получить(), "", СтрокаТаблицы.Контрагент.Телефон);
					ТекстЯчейки = ТекстЯчейки + Комментарий;
					
				Иначе // Сформируем контактную информацию сами
					Если НЕ СтрокаТаблицы.КонтрагентТекущаяМедицинскаяКарта.Пустая() Тогда 
						ТекстЯчейки = ТекстЯчейки + "№ " + Строка(СтрокаТаблицы.КонтрагентТекущаяМедицинскаяКартаКодБезНулей) + ", ";
					КонецЕсли;
					
					Телефон 	= ?(Константы.НеВыводитьТелефонКлиентаВЖурнале.Получить(), "", СтрокаТаблицы.Контрагент.Телефон);
					ТекстЯчейки = ТекстЯчейки + СтрокаТаблицы.ФИОПациента;
					
					Если ПараметрыСеанса.ТекущийПользователь.РольПользователя <> Перечисления.РольПользователя.Врач // Для врача телефон не отображаем
						И ЗначениеЗаполнено(Телефон) Тогда
						
						ТекстЯчейки = ТекстЯчейки + ", тел. " + Телефон;
					КонецЕсли;
				КонецЕсли;
			Иначе
				ТекстЯчейки = ТекстЯчейки + СтрокаТаблицы.Комментарий;
			КонецЕсли;
			// Дополним текст причиной записи
			Если ЗначениеЗаполнено(СтрокаТаблицы.ПричинаЗаписи) Тогда
				ТекстЯчейки = ТекстЯчейки + ?(ЗначениеЗаполнено(ТекстЯчейки), ": ", "") + СтрокаТаблицы.ПричинаЗаписи;
			КонецЕсли;
			// Дополним текст возростом клиента
			ТекстЯчейки = ТекстЯчейки + "" + ВозвратитьВозрастСтрокой(СтрокаТаблицы.ДатаРожденияКлиента, ", ");
			// Дополним текст комментариями
			Если ЗначениеЗаполнено(СтрокаТаблицы.Контрагент) И Найти(СтрокаТаблицы.Комментарий, СтрокаТаблицы.ФИОПациента) = 0 Тогда
				ТекстЯчейки = ТекстЯчейки + Символы.ПС + СтрокаТаблицы.Комментарий;
			КонецЕсли;	
			ТекстЯчейки = ТекстЯчейки + Символы.ПС + "Создана: " + Формат(СтрокаТаблицы.Событие.ДатаСоздания, "ДФ='дд ММММ ""в"" ЧЧ:мм, '") + СтрокаТаблицы.АвторДокумента;
			
			//==============================================================================================================================================================
			
			// Если СтрокаТаблицы.КонтактнаяИнформация <> "" Тогда
			//	// Если это врач вырезаем телефон
			//	КонтактнаяИнформация = СтрокаТаблицы.КонтактнаяИнформация;
			//	Если ПараметрыСеанса.ТекущийПользователь.РольПользователя = Перечисления.РольПользователя.Врач Тогда 
			//		КонтактнаяИнформация = СтрЗаменить(КонтактнаяИнформация, ", тел. " + СтрокаТаблицы.Контрагент.Телефон, "");
			//		// И СтрЧислоВхождений(СтрокаТаблицы.КонтактнаяИнформация,", тел") > 0 Тогда
			//		// КонтактнаяИнформация = Лев(СтрокаТаблицы.КонтактнаяИнформация, Найти(СтрокаТаблицы.КонтактнаяИнформация, ", тел") - 1);
			//	КонецЕсли;	
			//	ТекстЯчейки = ТекстЯчейки + КонтактнаяИнформация;
			// КонецЕсли;
			//// Формируем текст ячейки.
			//// Если ТипЗнч(СтрокаТаблицы.Услуга) = Тип("Массив") Тогда
			////	ТекстЯчейки = ТекстЯчейки + ?(ЗначениеЗаполнено(ТекстЯчейки), ": ", "") + АнкетированиеКлиентСервер.ПреобразоватьМассивВСтроку(СтрокаТаблицы.Услуга, ",");
			//// ИначеЕсли ЗначениеЗаполнено(СтрокаТаблицы.Услуга) Тогда
			////	ТекстЯчейки = ТекстЯчейки + ?(ЗначениеЗаполнено(ТекстЯчейки), ": ", "") + СтрокаТаблицы.Услуга;
			//// КонецЕсли;

			// Если ЗначениеЗаполнено(СтрокаТаблицы.ПричинаЗаписи) Тогда
			//	ТекстЯчейки = ТекстЯчейки + ?(ЗначениеЗаполнено(ТекстЯчейки), ": ", "") + СтрокаТаблицы.ПричинаЗаписи;
			// КонецЕсли;
			//
			// ТекстЯчейки = ТекстЯчейки + "" + ВозвратитьВозрастСтрокой(СтрокаТаблицы.ДатаРожденияКлиента, ", ");
			//			
			// ТекстЯчейки = ТекстЯчейки + Символы.ПС + "Создана: " + Формат(СтрокаТаблицы.ДатаСобытия, "ДФ='дд ММММ ""в"" ЧЧ:мм, '") + СтрокаТаблицы.АвторДокумента;
			
			
			Если СдвигДляМетки = 0 Тогда    // Определяем наличие меток у события
				ТекОбласть.ГраницаСлева = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
			Иначе
				ТекОбласть.ГраницаСлева = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.НетЛинии);
			КонецЕсли;
			ТекОбласть.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
			ТекОбласть.ГраницаСверху = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
			ТекОбласть.ГраницаСнизу = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);
			ТекОбласть.Объединить();
			Если ЗначениеЗаполнено(СтрокаТаблицы.Событие) Тогда 
				Если СтрокаТаблицы.Резерв Тогда
					ТекстЯчейки = СтрокаТаблицы.ОснованиеРезерва;					
					Если МногоТекста(СтрокаТаблицы.ОснованиеРезерва, Параметры) Тогда 
						ТекОбласть.ВертикальноеПоложение 	= ВертикальноеПоложение.Верх;
					Иначе 
					    ТекОбласть.ВертикальноеПоложение 	= ВертикальноеПоложение.Центр;
					КонецЕсли;	
					ТекОбласть.ГоризонтальноеПоложение 	= ГоризонтальноеПоложение.Центр;
					ТекОбласть.ЦветТекста 				= WebЦвета.Черный;
					ТекОбласть.Шрифт 					= Новый Шрифт(ТекОбласть.Шрифт, , 9, Истина);
					Если ЗначениеЗаполнено(СтрокаТаблицы.ЦветФонаРезерва) Тогда 
						ТекОбласть.ЦветФона 				= ?(ВыводНаПечать, ТекОбласть.ЦветФона, ЗначениеИзСтрокиВнутр(СтрокаТаблицы.ЦветФонаРезерва));
					Иначе 
						ТекОбласть.ЦветФона 				= ?(ВыводНаПечать, ТекОбласть.ЦветФона, WebЦвета.Хаки);
					КонецЕсли;	
				Иначе 	
					ТекОбласть.ВертикальноеПоложение = ВертикальноеПоложение.Верх;
					ТекОбласть.ЦветФона = ?(ВыводНаПечать, ТекОбласть.ЦветФона, ОбщегоНазначенияСтоматология.ПолучитьЦветФонаСобытия(СтрокаТаблицы.Статус, СтрокаТаблицы.Событие, , СтрокаТаблицы.ЭтоПеренос));
					ТекОбласть.ЦветТекста = WebЦвета.Черный;
					ТекОбласть.Шрифт = Новый Шрифт(ТекОбласть.Шрифт,,8);
				КонецЕсли;
			КонецЕсли;			
			ТекОбласть.Текст = ТекстЯчейки;
			Если (ТекОбласть.Низ - ТекОбласть.Верх + 1) < 2 Тогда
				ТекОбласть.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Авто;
			Иначе
				ТекОбласть.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
			КонецЕсли; 
			ТекОбласть.Заполнение = ТипЗаполненияОбластиТабличногоДокумента.Текст;
			ТекОбласть.ПоВыделеннымКолонкам     = Истина;	
			// Преобразование массива в строку
			ИндексВТЧМассив = "";
			Если  ТипЗнч(СтрокаТаблицы.ИндексВТЧ) = Тип("Массив") Тогда
				Для Каждого Элемент ИЗ СтрокаТаблицы.ИндексВТЧ Цикл
					ИндексВТЧМассив = ИндексВТЧМассив + Элемент + ";";	
				КонецЦикла;	 
			Иначе
				ИндексВТЧМассив = "" + СтрокаТаблицы.ИндексВТЧ + ";";
			КонецЕсли;	
			Если ТипЗнч(СтрокаТаблицы.Событие) = Тип("Структура") Тогда
				Дата                   = СтрокаТаблицы.Событие.ДатаВремяНачала;
				Интервал               = СтрокаТаблицы.Событие.ДатаВремяОкончания - СтрокаТаблицы.Событие.ДатаВремяНачала;
				ПараметрОснования      = ?(ЗначениеЗаполнено(СтрокаТаблицы.Событие.Сотрудник),СтрокаТаблицы.Событие.Сотрудник.УникальныйИдентификатор(),"");
				РабочееВремя           = СтрокаТаблицы.Событие.ПризнакДежурства;
				ТекОбласть.Расшифровка = "" +Дата+ "," +Интервал+  "," +ПараметрОснования +"," +РабочееВремя+ ",,,,"+ СтрокаТаблицы.ЭтоПеренос;
			Иначе
				Дата                   = СтрокаТаблицы.ДатаИнтервала;
				Интервал               = СтрокаТаблицы.НомерНачальнойСтроки - 1;
				ПараметрОснования      = ?(ЗначениеЗаполнено(СтрокаТаблицы.Сотрудник),СтрокаТаблицы.Сотрудник.УникальныйИдентификатор(),"");			
				ДокументЗаписи         = ?(ЗначениеЗаполнено(СтрокаТаблицы.Событие),СтрокаТаблицы.Событие.УникальныйИдентификатор(),"");
				Резерв                 = ?(ТипЗнч(СтрокаТаблицы.Событие) = Тип("ДокументСсылка.Событие"), СтрокаТаблицы.Резерв, "");	
				ТекОбласть.Расшифровка = "" +Дата+ "," +Интервал+ "," +ПараметрОснования+ ",Да," +ДокументЗаписи+ "," +ИндексВТЧМассив +"," +Резерв+","+СтрокаТаблицы.ЭтоПеренос;
			КонецЕсли;	
		КонецЦикла;				
	КонецЕсли;
	Линия      = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная);	
	ТекОбласть = ТабличныйДокумент.Область(1 + РазмерШапки, 1+ ШиринаЧасов + СмещениеДняСлева, НомерПоследнейЯчейкиДня-СмещениеОтНачалаПервойЯчейкиДня + РазмерШапки, ОбщаяШиринаДня + ШиринаЧасов + СмещениеДняСлева);
	ТекОбласть.Обвести(Линия, Линия, Линия, Линия);
	ТекОбласть.ЦветРамки = ЦветаСтиля.ЦветТекстаКнопки;
	
КонецПроцедуры

// Процедура - Заполнение графика событий по группам сформировать область наименования дня недели.
//
// Параметры:
//  ВыводНаПечать				 - 	 - 
//  ГруппировкаСсылка			 - 	 - 
//  МассивСотрудниковИОбластей	 - 	 - 
//  ОбщаяШиринаДня				 - 	 - 
//  РазмерШапки					 - 	 - 
//  СмещениеДняСлева			 - 	 - 
//  ТабличныйДокумент			 - 	 - 
//  ШиринаЧасов					 - 	 - 
//
Процедура ЗаполнениеГрафикаСобытийПоГруппамСформироватьОбластьНаименованияДняНедели(
	ТабличныйДокумент,	
	ГруппировкаСсылка, 
	МассивСотрудниковИОбластей,
	Параметры,
	ВыводНаПечать, 
	ОбщаяШиринаДня, 
	РазмерШапки, 
	СмещениеДняСлева, 
	ШиринаЧасов,
	ВсегоГрупп)
	
	ВыводитьСтрокуЛистОжидания = Ложь;
	Параметры.Свойство("ВыводитьСтрокуЛистОжидания", ВыводитьСтрокуЛистОжидания);	
	КорректорВысотыШапки = ?(ВыводитьСтрокуЛистОжидания, 1, 0);
	
	ОбластьНаименованияДняНедели = ТабличныйДокумент.Область(РазмерШапки-КорректорВысотыШапки, 1 + ШиринаЧасов + СмещениеДняСлева, РазмерШапки-КорректорВысотыШапки, ОбщаяШиринаДня+ ШиринаЧасов + СмещениеДняСлева);
	ОбластьНаименованияДняНедели.Объединить();
		
	ВысотаСтрокиОбласти = 22;
	ЦветРамкиОбласти    = ЦветаСтиля.ЦветТекстаКнопки;	
	ТолщинаЛинииГраницы = 1;
	
	ЛинияГраницы = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, ТолщинаЛинииГраницы);
	НулеваяЛинияГраницы = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.НетЛинии, 0);
	
	Если ТипЗнч(ГруппировкаСсылка) = Тип("Дата") Тогда
		
		ОбластьНаименованияДняНедели.Текст    = ОбщегоНазначенияКлиентСерверСтоматология.ОпределитьДеньНедели(ДеньНедели(ГруппировкаСсылка)) + Символы.ПС + Формат(ГруппировкаСсылка,"ДФ='d MMMM'");
		ОбластьНаименованияДняНедели.ЦветФона = Новый Цвет(255, 255, 255);
		
	ИначеЕсли ТипЗнч(ГруппировкаСсылка) = Тип("СправочникСсылка.Сотрудники") Тогда		
		
		ВысотаСтрокиОбласти = 37;
		
		ЦветФонаЯчейки = ?(ЗначениеЗаполнено(ГруппировкаСсылка.Должность.ЦветФона) И Не ВыводНаПечать, ЗначениеИзСтрокиВнутр(ГруппировкаСсылка.Должность.ЦветФона), Новый Цвет());
		
		ОбластьНаименованияДняНедели.Текст    = ГруппировкаСсылка.Наименование + ?(ГруппировкаСсылка.Должность.ОтображатьВЖурналеПредварительнойЗаписи, Символы.ПС + ГруппировкаСсылка.Должность, "");
		ОбластьНаименованияДняНедели.ЦветФона = ЦветФонаЯчейки;
				
		// СотрудникНовый = Справочники.Сотрудники.ПроверитьСотрудникЯвляетсяНовымДляСтруктурнойЕдиницы(ГруппировкаСсылка, Параметры.СтруктурнаяЕдиница);
		
		// Если СотрудникНовый Тогда 
		//	ТолщинаЛинииГраницы = 2;
		//	ЦветРамкиОбласти    = WebЦвета.Красный;	
		// КонецЕсли;
		
		Если МассивСотрудниковИОбластей <> Неопределено Тогда 
			
			СтруктураСотрудниковИОбластей = Новый Структура;
			
			СтруктураСотрудниковИОбластей.Вставить("Область"       , ОбластьНаименованияДняНедели.Имя);
			СтруктураСотрудниковИОбластей.Вставить("Сотрудник"     , ГруппировкаСсылка);
			// СтруктураСотрудниковИОбластей.Вставить("СотрудникНовый", СотрудникНовый);	
			
			МассивСотрудниковИОбластей.Добавить(СтруктураСотрудниковИОбластей);
			
		КонецЕсли;
		
		// Заполнение количества пациентов в листе ожидания				
		
		Если ВыводитьСтрокуЛистОжидания Тогда
			
			ОбластьЛистОжидания = ТабличныйДокумент.Область(РазмерШапки, 1 + ШиринаЧасов + СмещениеДняСлева, РазмерШапки, ОбщаяШиринаДня + ШиринаЧасов + СмещениеДняСлева);
			ОбластьЛистОжидания.Объединить();
			
			ОбластьЛистОжидания.ЦветФона = ЦветФонаЯчейки;
			ОбластьЛистОжидания.Шрифт                   = Новый Шрифт(, 7, Ложь);
			ОбластьЛистОжидания.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
			ОбластьЛистОжидания.ВертикальноеПоложение   = ВертикальноеПоложение.Центр;
			ОбластьЛистОжидания.ВысотаСтроки            = 1;
			ОбластьЛистОжидания.РазмещениеТекста        = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
			ОбластьЛистОжидания.Заполнение              = ТипЗаполненияОбластиТабличногоДокумента.Текст;
			ОбластьЛистОжидания.Расшифровка             = "" +Параметры.Дата+ ",," +ГруппировкаСсылка.УникальныйИдентификатор()+ ",,,,,,"+Параметры.КоличествоПациентовВЛистеОжидания;
			ОбластьЛистОжидания.ГиперСсылка             = Истина;
			ОбластьЛистОжидания.ГраницаСверху           = НулеваяЛинияГраницы;
			ОбластьЛистОжидания.ГраницаСнизу            = ЛинияГраницы;
			ОбластьЛистОжидания.ГраницаСлева            = ЛинияГраницы;
			ОбластьЛистОжидания.ГраницаСправа           = ЛинияГраницы;	
			ОбластьЛистОжидания.ЦветРамки               = ЦветРамкиОбласти;
			ОбластьЛистОжидания.ЦветТекста				= ЦветаСтиля.ЦветОсобогоТекста;
			
			Если Параметры.Свойство("КоличествоПациентовВЛистеОжидания") И НЕ Параметры.КоличествоПациентовВЛистеОжидания = 0 Тогда
				ОбластьЛистОжидания.Текст = "Лист ожидания ("+Параметры.КоличествоПациентовВЛистеОжидания+")";
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ГруппировкаСсылка) = Тип("СправочникСсылка.Помещения") Тогда
		
		ОбластьНаименованияДняНедели.Текст    = ГруппировкаСсылка.Наименование;
		ОбластьНаименованияДняНедели.ЦветФона = ?(ЗначениеЗаполнено(ГруппировкаСсылка.ЦветФона), ЗначениеИзСтрокиВнутр(ГруппировкаСсылка.ЦветФона), Новый Цвет());
	Иначе
		ОбластьНаименованияДняНедели.Текст    = ГруппировкаСсылка;
		ОбластьНаименованияДняНедели.ЦветФона = Новый Цвет(255, 255, 255);
		
	КонецЕсли;
	
	ОбластьНаименованияДняНедели.Шрифт                   = Новый Шрифт(, 7, Ложь);
	ОбластьНаименованияДняНедели.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	ОбластьНаименованияДняНедели.ВертикальноеПоложение   = ВертикальноеПоложение.Центр;
	ОбластьНаименованияДняНедели.ВысотаСтроки            = ВысотаСтрокиОбласти;
	ОбластьНаименованияДняНедели.РазмещениеТекста        = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ОбластьНаименованияДняНедели.Заполнение              = ТипЗаполненияОбластиТабличногоДокумента.Текст;
	ОбластьНаименованияДняНедели.Расшифровка             = ГруппировкаСсылка;
	ОбластьНаименованияДняНедели.ГиперСсылка             = Истина;
	ОбластьНаименованияДняНедели.ГраницаСверху           = ЛинияГраницы;
	ОбластьНаименованияДняНедели.ГраницаСнизу            = ?(ВыводитьСтрокуЛистОжидания, НулеваяЛинияГраницы, ЛинияГраницы);
	ОбластьНаименованияДняНедели.ГраницаСлева            = ЛинияГраницы;
	ОбластьНаименованияДняНедели.ГраницаСправа           = ЛинияГраницы;	
	ОбластьНаименованияДняНедели.ЦветРамки               = ЦветРамкиОбласти;
		
КонецПроцедуры

// Привести набор данных в строку.
//
Функция ПривестиНаборДанныхВСтроку(СтруктураДанных) Экспорт
	
	СтрокаВозврата = "";
	ПервоеЗначение = Истина;
	ПустоеЗначение = Истина;
	Для Каждого ЭлементМ ИЗ СтруктураДанных Цикл
		СтрокаВозврата = СтрокаВозврата + ?(НЕ ПервоеЗначение,",","");
		Если НЕ ЭлементМ.Значение = Неопределено И НЕ ЭлементМ.Значение = "" Тогда
			ПустоеЗначение = Ложь;
			Если НЕ Метаданные.НайтиПоТипу(ТипЗнч(ЭлементМ.Значение)) = Неопределено Тогда
				СтрокаВозврата = СтрокаВозврата + ЭлементМ.Значение.УникальныйИдентификатор();
			Иначе
				СтрокаВозврата = СтрокаВозврата + Строка(ЭлементМ.Значение);
			КонецЕсли;
		Иначе
			ПустоеЗначение = Истина;
		КонецЕсли;
		ПервоеЗначение = Ложь;
	КонецЦикла;
	// Если последнее значение было пустым проставить доп. запятую
	СтрокаВозврата = СтрокаВозврата + ?(ПустоеЗначение,",","");
	
	Возврат СтрокаВозврата;
	
КонецФункции

// Привести из строки в набор данных.
//
Функция ПривестиСтрокуВНаборДанных(СтрокаДанных,ШаблонТипов) Экспорт
	
	Индекс            = 0;
	СтруктураВозврата = Новый Структура;
	// Разложить строку на массив элементов
	МассивЭлементов   = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаДанных,",");
	Для Каждого ЭлементС ИЗ ШаблонТипов Цикл
		Если  Индекс < МассивЭлементов.Количество() И Не МассивЭлементов[Индекс] = Неопределено И Не МассивЭлементов[Индекс] = "" Тогда
			
			Если ЭлементС.Значение = Неопределено Тогда
				Продолжить;
			КонецЕсли;
				
			НайденныйОбъект = Метаданные.НайтиПоТипу(ЭлементС.Значение);
			// Приведение к ссылочному типу
			Если НЕ НайденныйОбъект = Неопределено Тогда
				ПолноеИмя          = НайденныйОбъект.ПолноеИмя();
				СоставноеИмя       = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПолноеИмя,".");
				ИдентифкаторСсылки = Новый УникальныйИдентификатор(МассивЭлементов[Индекс]);
				Если СоставноеИмя[0] = "Справочник" Тогда
					СтруктураВозврата.Вставить(ЭлементС.Ключ,Справочники[СоставноеИмя[1]].ПолучитьСсылку(ИдентифкаторСсылки));
				ИначеЕсли СоставноеИмя[0] = "Документ" Тогда
	                СтруктураВозврата.Вставить(ЭлементС.Ключ,Документы[СоставноеИмя[1]].Получитьссылку(ИдентифкаторСсылки));
				Иначе
					СтруктураВозврата.Вставить(ЭлементС.Ключ,Неопределено);
				КонецЕсли;
			Иначе
				// Приведение к значимому типу данных
				Если ЭлементС.Значение = Тип("Дата") Тогда
					СтруктураВозврата.Вставить(ЭлементС.Ключ,Дата(МассивЭлементов[Индекс])); 
				ИначеЕсли ЭлементС.Значение = Тип("Число") Тогда
					СтруктураВозврата.Вставить(ЭлементС.Ключ,Число(МассивЭлементов[Индекс]));
				ИначеЕсли ЭлементС.Значение = Тип("Булево") Тогда
					СтруктураВозврата.Вставить(ЭлементС.Ключ,Булево(МассивЭлементов[Индекс])); 
				ИначеЕсли ЭлементС.Значение = Тип("Строка") Тогда
					СтруктураВозврата.Вставить(ЭлементС.Ключ,МассивЭлементов[Индекс]); 
				ИначеЕсли ЭлементС.Значение = Тип("Массив") Тогда		  	
					ВременныйМассив = СтроковыеФункцииКлиентСерверСтоматология.РазложитьСтрокуВМассивПодстрок(МассивЭлементов[Индекс],";");
					МассивЗначений  = Новый Массив;
					Для Каждого Эл ИЗ ВременныйМассив Цикл
						МассивЗначений.Добавить(Число(Эл));   
					КонецЦикла;
					СтруктураВозврата.Вставить(ЭлементС.Ключ,МассивЗначений); 
				КонецЕсли;	
			КонецЕсли;	
		Иначе
			СтруктураВозврата.Вставить(ЭлементС.Ключ,Неопределено); 
		КонецЕсли;
	   Индекс = Индекс + 1;		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Функция возвращает коэффициент разрешения по разрешению экрана.
//
Функция КоэффициентЭкранаПоРазрешению(ШиринаЭкрана = Неопределено) Экспорт
	
	Настройки = ХранилищеСистемныхНастроек.Загрузить("Общее/НастройкиИнтерфейсаКлиентскогоПриложения");
	
	Если Настройки <> Неопределено Тогда
		НастройкиСостава = Настройки.ПолучитьСостав();
		
		Если НастройкиСостава.Лево.Количество() > 0 Тогда
			Увеличить = 1;
		Иначе
			Увеличить = 0;
		КонецЕсли;
	Иначе 
		Увеличить = 1;
	КонецЕсли;

	КоэфРазрешения = 0;
	
	Если ШиринаЭкрана = Неопределено Тогда
		ШиринаЭкрана = 1920;
	КонецЕсли;
	
	Если ШиринаЭкрана = 640 Тогда 
		КоэфРазрешения = 9.10;
	ИначеЕсли ШиринаЭкрана = 800 Тогда 
		КоэфРазрешения = 10.32 + Увеличить*0.8;		
	ИначеЕсли ШиринаЭкрана = 1024 Тогда 
		КоэфРазрешения = 9.60 + Увеличить*0.8;		
	ИначеЕсли ШиринаЭкрана = 1152 Тогда 
		КоэфРазрешения = 9.14 + Увеличить*0.8;		
	ИначеЕсли ШиринаЭкрана = 1280 Тогда 
		КоэфРазрешения = 8.95 + Увеличить*0.5;  
	ИначеЕсли ШиринаЭкрана = 1360 Тогда 
		КоэфРазрешения = 9.29 + Увеличить*0.56;	
	ИначеЕсли ШиринаЭкрана = 1366 Тогда 
		КоэфРазрешения = 9.59 + Увеличить*0.3;	
	ИначеЕсли ШиринаЭкрана = 1400 Тогда 
		КоэфРазрешения = 9.81 + Увеличить*0.3;		
	ИначеЕсли ШиринаЭкрана = 1440 Тогда 
		КоэфРазрешения = 10.05 + Увеличить*0.4;	
	ИначеЕсли ШиринаЭкрана = 1600 Тогда 
		КоэфРазрешения = 11.00 + Увеличить*0.35;		
	ИначеЕсли ШиринаЭкрана = 1680 Тогда 
		КоэфРазрешения = 11.56 + Увеличить*0.6;     
	ИначеЕсли ШиринаЭкрана = 1920 Тогда 
		КоэфРазрешения = 10.60 + Увеличить*0.4;		  
	ИначеЕсли ШиринаЭкрана = 2048 Тогда 
		КоэфРазрешения = 10.42 + Увеличить*0.3;
	ИначеЕсли ШиринаЭкрана = 2560 Тогда 
		КоэфРазрешения = 10.31 + Увеличить*0.3;		
	ИначеЕсли ШиринаЭкрана = 3200 Тогда 
		КоэфРазрешения = 10.15 + Увеличить*0.2;		
	Иначе 
		КоэфРазрешения = -0.003734375 * ШиринаЭкрана + 14.2675 + Увеличить*0.8;
	КонецЕсли;	
	
	
	Возврат КоэфРазрешения;
	
КонецФункции

&НаСервере
// Функция возвращает значение "Истина" в том случе, если строка "КонтактнаяИнформация" является многострочной
// или ее длина превышает установленное значение (23 или 35).
//
Функция МногоТекста(КонтактнаяИнформация, Параметры)
	
	Если Параметры.СтраницаМенеджера = "Неделя" Тогда		
		Если СтрЧислоСтрок(КонтактнаяИнформация) > 1 ИЛИ СтрДлина(КонтактнаяИнформация)	> 23 Тогда 
			Возврат Истина;
		Иначе 
			Возврат Ложь;
		КонецЕсли;
	Иначе 
		Если СтрЧислоСтрок(КонтактнаяИнформация) > 1 ИЛИ СтрДлина(КонтактнаяИнформация)	> 35 Тогда 
			Возврат Истина;
		Иначе 
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

&НаСервере
//
//
Процедура ПроставимНекоторыеСтатусы(ТаблицаСобытий, СтруктурнаяЕдиница) Экспорт
	
	// Подготовим таблицу задолженностей
	Таблица = ТаблицаСобытий.Скопировать();
	Таблица.Свернуть("Контрагент");
	МассивКонтрагентов = Таблица.ВыгрузитьКолонку("Контрагент");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ВзаиморасчетыСКонтрагентамиОстатки.Контрагент КАК Контрагент,
	               |	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток КАК ОбщийБаланс
	               |ИЗ
	               |	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
	               |			,
	               |			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	               |				И Контрагент В (&МассивКонтрагентов)) КАК ВзаиморасчетыСКонтрагентамиОстатки";			   
	
	Запрос.УстановитьПараметр("МассивКонтрагентов", МассивКонтрагентов);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	
	ТаблицаЗадолженностей = Запрос.Выполнить().Выгрузить();
	
	// Подготовим таблицу незавершенных наряд-заказов
	МассивСтруктурныхЕдиниц = Новый Массив;
	МассивСтруктурныхЕдиниц.Добавить(СтруктурнаяЕдиница);
	ТаблицаНезавершенныхНарядЗаказов = ВернутьТаблицуНезавершенныхНарядЗаказов(МассивКонтрагентов, МассивСтруктурныхЕдиниц);
	// ТаблицаНезавершенныхНарядЗаказов.Свернуть("Контрагент");
	
	// Проставим статусы	
	Для Каждого Событие Из ТаблицаСобытий Цикл 
		СтрокаТаблицыЗадолженностей 					= ТаблицаЗадолженностей.Найти(Событие.Контрагент, "Контрагент");
		МассивСтрок_ТаблицыНезавершенныхНарядЗаказов 	= ТаблицаНезавершенныхНарядЗаказов.НайтиСтроки(Новый Структура("Контрагент", Событие.Контрагент));
		Если СтрокаТаблицыЗадолженностей <> Неопределено Тогда 
			Событие.ЕстьЗадолженность = СтрокаТаблицыЗадолженностей.ОбщийБаланс < 0;
		КонецЕсли;
		Если МассивСтрок_ТаблицыНезавершенныхНарядЗаказов.Количество() <> 0 Тогда 
			Событие.ЕстьНезавершенныеНарядЗаказы = Истина;
			Если МассивСтрок_ТаблицыНезавершенныхНарядЗаказов.Количество() = 1 Тогда 
				Событие.ОбщийСтатусНезавершенныхНарядЗаказов = МассивСтрок_ТаблицыНезавершенныхНарядЗаказов[0].Статус;
			Иначе 
				Событие.ОбщийСтатусНезавершенныхНарядЗаказов = Перечисления.СтатусыНарядЗаказа.ВРаботе;
			КонецЕсли;
		Иначе 
			Событие.ЕстьНезавершенныеНарядЗаказы = Ложь;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

Функция ВозвратитьВозрастСтрокой(ДатаРожденияКлиента, Префикс = "") Экспорт
	
	Если Не ЗначениеЗаполнено(ДатаРожденияКлиента)  Тогда
		Возврат "";
	КонецЕсли;
	                                 
	Возраст = Год(Дата(01, 01, 01) + (ТекущаяДата() - ДатаРожденияКлиента)) - 1;
	ВозрастСтрока = Строка(Возраст);
	
	ПоследняяЦифра = Сред(Строка(Возраст), СтрДлина(Строка(Возраст)));
	ПредпоследняяЦифра = Сред("0" + Строка(Возраст), СтрДлина("0" + Строка(Возраст)) - 1, 1);
	
	Если (ПоследняяЦифра = "1") И ПредпоследняяЦифра <> "1" Тогда
		ВозрастСтрока = ВозрастСтрока + " год";
	ИначеЕсли (ПоследняяЦифра = "2" ИЛИ ПоследняяЦифра = "3" ИЛИ ПоследняяЦифра = "4") И ПредпоследняяЦифра <> "1" Тогда
		ВозрастСтрока = ВозрастСтрока + " года";
	Иначе
		ВозрастСтрока = ВозрастСтрока + " лет";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВозрастСтрока) Тогда
		ВозрастСтрока = Префикс + ВозрастСтрока;
	КонецЕсли;
	
	Возврат ВозрастСтрока;
	
КонецФункции

// Функция возвращает таблицу с незавершенными наряд-заказами
//
Функция ВернутьТаблицуНезавершенныхНарядЗаказов(МассивКонтрагентов, МассивСтруктурныхЕдиниц) Экспорт
	
	Запрос = Новый Запрос;
	// Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	//               |	НарядЗаказ.Ссылка КАК НарядЗаказ,
	//               |	НарядЗаказ.Контрагент КАК Контрагент,
	//               |	НарядЗаказ.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	//               |	НарядЗаказ.Дата КАК Дата,
	//               |	"""" КАК СтрокаКлюч				   
	//               |ИЗ
	//               |	Документ.НарядЗаказ КАК НарядЗаказ
	//               |ГДЕ
	//               |	НЕ НарядЗаказ.Статус
	//               |	И НарядЗаказ.Проведен
	//               |	И НЕ НарядЗаказ.ПометкаУдаления
	//               |	И НарядЗаказ.Контрагент В(&МассивКонтрагентов)
	//               |	И НарядЗаказ.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)";
	//			   
				   
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	НарядЗаказЗапасы.Ссылка.Контрагент КАК Контрагент,
	               |	НарядЗаказЗапасы.Статус КАК Статус
	               |ИЗ
	               |	Документ.НарядЗаказ.Запасы КАК НарядЗаказЗапасы
	               |ГДЕ
	               |	НарядЗаказЗапасы.Ссылка.Проведен
	               |	И НЕ НарядЗаказЗапасы.Ссылка.ПометкаУдаления
	               |	И (НарядЗаказЗапасы.Прием = ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
	               |			ИЛИ НарядЗаказЗапасы.Прием = НЕОПРЕДЕЛЕНО
	               |			ИЛИ НарядЗаказЗапасы.Прием = NULL)
	               |	И НарядЗаказЗапасы.Ссылка.Контрагент В(&МассивКонтрагентов)
	               |	И НарядЗаказЗапасы.Ссылка.СтруктурнаяЕдиница В(&МассивСтруктурныхЕдиниц)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	НарядЗаказЗапасы.Статус,
	               |	НарядЗаказЗапасы.Ссылка.Контрагент";
	
	
	Запрос.УстановитьПараметр("МассивКонтрагентов"		, МассивКонтрагентов);
	Запрос.УстановитьПараметр("МассивСтруктурныхЕдиниц"	, МассивСтруктурныхЕдиниц);
	
	Таблица = Запрос.Выполнить().Выгрузить();
	// Таблица.Сортировать("Дата");
	
	Возврат Таблица;	
	
КонецФункции

// Выполняет установку параметра сеанса ПредлагатьУстановкуРасширенияРаботыСФайлами 
// при начале работы системы.
//
// Параметры
//  ИмяПараметра  			- Строка - имя устанавливаемого параметра
//  УстановленныеПараметры  - Массив - массив, в котором собираются 
//                 имена установленных параметров сеанса
//
Процедура НачальнаяУстановкаПараметраСеанса(ИмяПараметра, УстановленныеПараметры) Экспорт

	Если ИмяПараметра <> "ПредлагатьУстановкуРасширенияРаботыСФайлами" Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);   
	
	Если ИмяПараметра = "ПредлагатьУстановкуРасширенияРаботыСФайлами" Тогда
		
		ПредлагатьУстановку = ХранилищеОбщихНастроек.Загрузить("НастройкиПрограммы", 
			"ПредлагатьУстановкуРасширенияРаботыСФайлами");
		Если ПредлагатьУстановку = Неопределено Тогда
			ПредлагатьУстановку = Истина;
			ХранилищеОбщихНастроек.Сохранить("НастройкиПрограммы", 
				"ПредлагатьУстановкуРасширенияРаботыСФайлами", ПредлагатьУстановку);
		КонецЕсли;
		
		ПараметрыСеанса.ПредлагатьУстановкуРасширенияРаботыСФайлами = ПредлагатьУстановку;
		УстановленныеПараметры.Добавить(ИмяПараметра);
		
	КонецЕсли;
	
КонецПроцедуры 

// Процедура, определяет структурную единицу, под которым запущен сеанс и пытается
// найти соответсвие ему в справочнике "СтруктурныеЕдиницы". Параметр сеанса ТекущаяСтруктурнаяЕдиница
// устанавливается как ссылка на найденный (созданный) элемент справочника.
//
Процедура ОпределитьТекущуюСтруктурнуюЕдиницу(Знач ИмяПараметра, УстановленныеПараметры) Экспорт
	  	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ИмяПараметра <> "ТекущаяСтруктурнаяЕдиница" Тогда
		Возврат;
	КонецЕсли;
		
	ПоследняяЗакрытаяСтрЕд = ХранилищеСистемныхНастроек.Загрузить(ПараметрыСеанса.ТекущийПользователь.УникальныйИдентификатор(), "СтруктрнаяЕдиница");
		
	СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	
	МассивСтруктурныхЕдиниц = Новый Массив; 		
	ВыборкаСтруктурныхЕд = Справочники.СтруктурныеЕдиницы.Выбрать();
	Пока ВыборкаСтруктурныхЕд.Следующий() Цикл   				
		Если ВыборкаСтруктурныхЕд.ЭтоГруппа Тогда
			Продолжить;
		КонецЕсли;  				
		МассивСтруктурныхЕдиниц.Добавить(ВыборкаСтруктурныхЕд.Ссылка);  				
	КонецЦикла;
	
	ТекущийСотрудник = ПараметрыСеанса.ТекущийСотрудник;
	Если ЗначениеЗаполнено(ТекущийСотрудник) Тогда   		
		Если ТекущийСотрудник.ДоступныеСтруктурныеЕдиницы.Количество() = 0 Тогда 		
		    МассивСтруктурныхЕдДоступныхВСеансе  = МассивСтруктурныхЕдиниц;
		Иначе
			
			МассивСтруктурныхЕдДоступныхВСеансе = Новый Массив;   			
			Для Каждого СтруктурныеЕдСтрока Из МассивСтруктурныхЕдиниц Цикл   				
				Если ТекущийСотрудник.ДоступныеСтруктурныеЕдиницы.Найти(СтруктурныеЕдСтрока, "СтруктурнаяЕдиница") <> Неопределено Тогда
					МассивСтруктурныхЕдДоступныхВСеансе.Добавить(СтруктурныеЕдСтрока);
				КонецЕсли;  				
			КонецЦикла; 	
		КонецЕсли;	
		
		
		Если МассивСтруктурныхЕдДоступныхВСеансе.Количество() > 0 Тогда
			
			Если ЗначениеЗаполнено(ПоследняяЗакрытаяСтрЕд) Тогда
				ТекущаяСтруктурнаяЕд = ПоследняяЗакрытаяСтрЕд;
			Иначе
				ТекущаяСтруктурнаяЕд = МассивСтруктурныхЕдДоступныхВСеансе[0];
			КонецЕсли;
		КонецЕсли;
	
	КонецЕсли;
	
	ПараметрыСеанса.ТекущаяСтруктурнаяЕдиница = ?(ТекущаяСтруктурнаяЕд = Неопределено, Справочники.СтруктурныеЕдиницы.ПустаяСсылка(), ТекущаяСтруктурнаяЕд);
	
КонецПроцедуры 

// Функция ПолучитьЗначениеРеквизита возвращает значение
// реквизита, прочитанного из информационной базы по ссылке на объект.
// 
//  Если доступа к реквизиту нет, возникнет исключение прав доступа.
//  Если необходимо зачитать реквизит независимо от прав текущего пользователя,
//  то следует использовать предварительный переход в привилегированный режим.
// 
// Параметры:
//  Ссылка       - ссылка на объект, - элемент справочника, документ, ...
//  ИмяРеквизита - Строка, например, "Код".
// 
// Возвращаемое значение:
//  Произвольный    - зависит от типа значения прочитанного реквизита.
// 
Функция ПолучитьСтарыйНаборПередЗаписьюРегистра(Объект, Замещение = Истина) Экспорт
	
	СтарыйНаборЗаписей = РегистрыСведений[Объект.Метаданные().Имя].СоздатьНаборЗаписей();
	Для Каждого ЗначениеОтбора Из Объект.Отбор Цикл
		СтрокаОтбора = СтарыйНаборЗаписей.Отбор.Найти(ЗначениеОтбора.Имя);
		СтрокаОтбора.Значение = ЗначениеОтбора.Значение;
		СтрокаОтбора.Использование = ЗначениеОтбора.Использование;
	КонецЦикла;
	Если Замещение = Истина Тогда // Если незамещаются, считаем что записей не было. Если записи нужны в любом случае - параметр не передавать
		СтарыйНаборЗаписей.Прочитать();
	КонецЕсли;
	
	Возврат СтарыйНаборЗаписей;
	
КонецФункции

// Функция ПолучитьЗначениеПараметровСеанса возвращает значение реквизита параметра сеанса
