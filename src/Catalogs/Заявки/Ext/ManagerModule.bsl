	Фильтры		 = ?(Фильтры = Неопределено, Новый Структура, Фильтры);
	
	ОбъектыОтбора = Новый Массив;
	ОбъектыОтбора.Добавить(ПараметрыДанных.Ссылка);
	
	Если ЗначениеЗаполнено(ПараметрыДанных.ОсновнойКлиент) Тогда
		
		ОбъектыОтбора.Добавить(ПараметрыДанных.ОсновнойКлиент);
		
		СтруктураОбъект = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ПараметрыДанных.ОсновнойКлиент, "ДатаРожденияКлиента, ДатаРегистрации");
		ДатаРождения	= СтруктураОбъект.ДатаРожденияКлиента;
		ПараметрыДанных.Вставить("ДатаРожденияКлиента" , СтруктураОбъект.ДатаРожденияКлиента);

		// Если год не высокосный, тогда передвигаем дату рождения на один день. 
		Если ЗначениеЗаполнено(ДатаРождения) 
			И Месяц(ДатаРождения) = 2 
			И День(ДатаРождения) = 29 
			И Не ДеньГода(КонецГода(ТекущаяДатаСеанса())) = 366 Тогда
			
			ДатаРождения = ДатаРождения + 86400;		
		КонецЕсли;
		
		ДатаРождения = Дата("" + Формат(ТекущаяДата(),"ДФ=yyyy; ДП=0001") + "" + Формат(ДатаРождения,"ДФ=MM; ДП=01") + "" + Формат(ДатаРождения,"ДФ=dd; ДП=01"));
		
		ПараметрыДанных.Вставить("ДатаРегистрацииКлиента", СтруктураОбъект.ДатаРегистрации);

	КонецЕсли;
		
	МассивВнешнихСистем = Новый Массив;
	Если ЗначениеЗаполнено(ПараметрыДанных.ВнешняяСистема) Тогда
		МассивВнешнихСистем.Добавить(ПараметрыДанных.ВнешняяСистема);	
	КонецЕсли;	
	Если Не ЗначениеЗаполнено(МассивВнешнихСистем) Тогда
		МассивВнешнихСистем.Добавить(Справочники.ВнешниеСистемы.ПолучитьВнешнююСистему(, Перечисления.ТипыВнешнихСистем.JivoSite));	
	КонецЕсли;
	
	ВсеФильтрыОтключены = ВсеФильтрыОтключены(Фильтры);
	
	Запрос.УстановитьПараметр("Заявка"                  , ПараметрыДанных.Ссылка);
	Запрос.УстановитьПараметр("Контрагент"              , ПараметрыДанных.ОсновнойКлиент);
