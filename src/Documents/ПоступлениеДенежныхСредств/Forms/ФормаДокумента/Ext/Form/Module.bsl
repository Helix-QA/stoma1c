// Процедура печати чека на фискальном регистраторе.
//
Процедура НапечататьЧек(Команда)
	
	Если ЗначениеЗаполнено(Объект.НомерЧекаККМ) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Документ уже пробит на фискальном регистраторе! Номер чека:';en='Document already stamped on the fiscal registrar! Room check:'") + Объект.НомерЧекаККМ);
		Возврат;
	КонецЕсли;
	
	Если Объект.Проведен = Ложь 
		ИЛИ ЭтаФорма.Модифицированность = Истина Тогда
		
		ПоказатьПредупреждение(, НСтр("ru='Предварительно документ необходимо провести.';en='Pre document is necessary conduct.'"));
		Возврат;
	КонецЕсли;
	
	// Проверяем ставку НДС.
	СтавкаНДС = ОбщегоНазначенияСтоматология.ПолучитьСтавкуНДС(Объект.СтруктурнаяЕдиница);			
	Если Не ЗначениеЗаполнено(СтавкаНДС) Тогда
		ПоказатьПредупреждение(, "Заполните ставку НДС в организации и повторите операцию оплаты.");
		ОткрытьФорму("Справочник.Организации.Форма.ФормаЭлемента", 
					Новый Структура("Ключ", ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.СтруктурнаяЕдиница, "Организация")));
		Возврат;	
	КонецЕсли;  
	
	ВидНалога = Неопределено;
	
	Если Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВзносНаЛицевойСчет") 
		И Объект.ВидОперации <> ПредопределенноеЗначение("Перечисление.ВидыОпераций.ВозвратСЛицевогоСчета")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВозвратСЛицевогоСчета")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВозвратАвансаКлиенту")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВзносНалицевойСчет")
		И Объект.Статья <> ПредопределенноеЗначение("Справочник.СтатьиДоходовИРасходов.ВзносАвансаОтКлиента") Тогда
		
		Для Каждого СтрокаТЧ из Объект.РасшифровкаПлатежа Цикл
			Если ТипЗнч(СтрокаТЧ.ДокументОснования) = Тип("ДокументСсылка.Реализация")
				Или ТипЗнч(СтрокаТЧ.ДокументОснования) = Тип("ДокументСсылка.Прием") Тогда
				
				Если ВидНалога = Неопределено Тогда
					ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.ДокументОснования, "ВидНалога");
				ИначеЕсли НЕ ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(СтрокаТЧ.ДокументОснования, "ВидНалога") Тогда
					ТекстСообщения = "В одном документе, пробиваемом в ККТ с передачей данных, может пробиваться номенклатура, использующая один режим налогообложения (ЕНВД, УСХН, ПСН).";
					ПоказатьПредупреждение(, ТекстСообщения);
					Возврат;										
				КонецЕсли;
				
			КонецЕсли;			
		КонецЦикла;	
	Иначе
		ВидНалога = ОбщегоНазначенияСтоматология.ПолучитьВидНалогаАванс(Объект.СтруктурнаяЕдиница);
	КонецЕсли;

	// Выполнить контроль кассовой смены
	ОписаниеОшибки					= Неопределено;
	ВыполнятьОперациюНаФискальнике  = ОбщегоНазначенияСтоматология.ПолучитьЗначениеРеквизита(Объект.Касса, "ИспользоватьБезПодключенияОборудования") = Ложь; 
	ПараметрыИспользованияКассовойСмены = Новый Структура("ВыполнятьОперациюНаФискальнике", ВыполнятьОперациюНаФискальнике);
	РозничныеПродажиКлиент.ВыполнитьКонтрольИспользованияКассовойСмены(ЭтотОбъект, Объект.Касса, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки);
		
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик команды "ОчиститьЧекККМ".
//
Процедура ОчиститьЧекККМ(Команда)
		
	Если НЕ Объект.Ссылка.Пустая()
		И Объект.НомерЧекаККМ = 99999999 Тогда
		
		Объект.НомерЧекаККМ = 0;
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
		ЭтаФорма.Закрыть();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура, обработчик завершения выемки из кассы.
// 
Процедура ИнкассацияНаФискальномУстройствеЗавершение(РезультатВыполнения, Параметры) Экспорт
		
	Если РезультатВыполнения.Результат Тогда		
		// Если чек пробился, то возвращаем номер чека ккм в документ (по умолчанию 88888888).
		Объект.НомерЧекаККМ = 88888888;
		ЭтаФорма.Записать(Новый Структура("РежимЗаписи",РежимЗаписиДокумента.Запись));	
		//УстановитьСостояниеЭлементовФормы();                                                                                  		
	Иначе
		ТекстСообщения = НСтр("ru = 'При выполнении операции произошла ошибка.
			                        |Чек не напечатан на фискальном устройстве.
			                        |Дополнительное описание: %ДополнительноеОписание%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", РезультатВыполнения.ОписаниеОшибки);		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - После контроля использования кассовой смены
//
// Параметры:
//  ИспользованиеКассовойСменыРазрешено	 - 	 - 
//  ПараметрыИспользованияКассовойСмены	 - 	 - 
//  ОписаниеОшибки						 - 	 - 
//
Процедура ПослеКонтроляИспользованияКассовойСмены(ИспользованиеКассовойСменыРазрешено, ПараметрыИспользованияКассовойСмены, ОписаниеОшибки) Экспорт 
	
	Если ИспользованиеКассовойСменыРазрешено = Ложь Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Поступление денежных средств'; en = 'Cash inflow'"),,
										НСтр("ru = 'Операция запрещена: '; en = 'Operation is prohibited: '") + ОписаниеОшибки, 
										БиблиотекаКартинок.Предупреждение32,
										СтатусОповещенияПользователя.Важное); 
		Возврат;
	КонецЕсли;
	
	Если ПараметрыИспользованияКассовойСмены.Свойство("ВыполнятьОперациюНаФискальнике") 
		И ПараметрыИспользованияКассовойСмены.ВыполнятьОперациюНаФискальнике Тогда
		
		Если КассаИспользуетсяККТ(Объект.Касса) = Истина Тогда
			Если Не ЗначениеЗаполнено(ОписаниеОшибки) Тогда
				ПараметрыФормы	= Новый Структура("Клиент, Касса", Объект.Контрагент, Объект.Касса);
				Оповещение		= Новый ОписаниеОповещения("НапечататьЧекЗавершение", ЭтотОбъект);
				ОткрытьФорму("Обработка.ПомощникПроведенияОплаты.Форма.ФормаФормированиеЧека", 
					ПараметрыФормы,
					ЭтаФорма,,,,
					Оповещение, 
					РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
					
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		ВыполнитьОперациюНаЭТиНапечататьЧекФР();
		
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
 // Процедура - Напечатать чек завершение
//
 // Параметры:
 // Результат	 - 	 - 
 // ДопПараметры - 	 - 
//      
Процедура НапечататьЧекЗавершение(Результат, ДопПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ВыполнитьОперациюНаЭТиНапечататьЧекФР(Результат);
