// Процедура - При изменении картинки
//
Процедура ПриИзмененииКартинки() 
	
	Видимость = Не Объект.ФайлКартинки.Пустая();
	Элементы.АдресКартинки.КонтекстноеМеню.ПодчиненныеЭлементы.АдресКартинкиКонтекстноеМенюПросмотреть.Доступность = Видимость;	
	
	Если НЕ Элементы.АдресКартинки.КонтекстноеМеню.ПодчиненныеЭлементы.Найти("АдресКартинкиКонтекстноеМенюУдалить") = Неопределено Тогда
		Элементы.АдресКартинки.КонтекстноеМеню.ПодчиненныеЭлементы.АдресКартинкиКонтекстноеМенюУдалить.Доступность	= Видимость;
	КонецЕсли;
	
	Если НЕ Элементы.АдресКартинки.КонтекстноеМеню.ПодчиненныеЭлементы.Найти("АдресКартинкиКонтекстноеМенюСохранить") = Неопределено Тогда
		Элементы.АдресКартинки.КонтекстноеМеню.ПодчиненныеЭлементы.АдресКартинкиКонтекстноеМенюСохранить.Доступность  = Видимость;
	КонецЕсли;
	
	Если Видимость Тогда
		АдресКартинки = ПолучитьНавигационнуюСсылкуКартинки(Объект.ФайлКартинки, УникальныйИдентификатор);
		Элементы.АдресКартинки.РазмерКартинки = РазмерКартинки.Пропорционально;
	Иначе
		АдресКартинки = ПоместитьВоВременноеХранилище(БиблиотекаКартинок.ФотоПоУмолчанию.ПолучитьДвоичныеДанные(), УникальныйИдентификатор);
		Элементы.АдресКартинки.РазмерКартинки = РазмерКартинки.РеальныйРазмер;
	Конецесли;
	
КонецПроцедуры // ОбновитьКартинку

