#Область ПРОЦЕДУРЫ_И_ФУНКЦИИ_ФОРМИРОВАНИЯ_ПЕЧАТНЫХ_ФОРМ

// Функция генерации печатной формы "РасходнаяНакладная"
//
Функция СформироватьПечатнуюФорму_Квитанция(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ПФ_MXL_Квитанция";
	
	// МассивОбъектов = ОтСортироватьМассивДокументов(МассивОбъектов);
	УстановитьПривилегированныйРежим(Истина);
	
	НесколькоВрачейВОдномПриеме = Константы.НесколькоВрачейВОдномПриеме.Получить();	
	
	КоличествоОбъектов = МассивОбъектов.Количество();
	ИндексОбъекта	   = 0;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		ЭтоСтоматологическиеУслуги = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(ТекущийДокумент.Сотрудник); 
		НомерСтрокиНачало          = ТабличныйДокумент.ВысотаТаблицы + 1;
		ПакетЗапросов              = ПолучитьРезультатЗапроса(ТекущийДокумент);
		
		Прием 				= ПакетЗапросов[0].Выбрать();
		ТаблицаОплаты		= ПакетЗапросов[2+1].Выгрузить();
		ВыборкаЗаписи    	= ПакетЗапросов[3+1].Выбрать();
		ВыборкаПоУслугам 	= ПакетЗапросов[4+1].Выбрать();
		ТаблицаАвансов 		= ПакетЗапросов[5+1].Выгрузить();
		ТаблицаЛицевыеСчета = ПакетЗапросов[6+1].Выгрузить();   
		ТаблицаВозврата		= ПакетЗапросов[8].Выгрузить();
				
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_Квитанция");
		
		//==============================================================ЗАПОЛНЕНИЕ ШАПКИ====================================================================
		Прием.Следующий();
		
		Область_Заголовок 	= Макет.ПолучитьОбласть("Заголовок");
		Область_Организация = Макет.ПолучитьОбласть("Организация");
		Область_Врач 		= Макет.ПолучитьОбласть("Врач");
		Область_Пациент 	= Макет.ПолучитьОбласть("Пациент");                                     
		Область_Диагноз 	= Макет.ПолучитьОбласть("Диагноз");
		Область_Заказчик    = Макет.ПолучитьОбласть("Заказчик");
		
		НомерИДатаДокумента = "№ " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Прием.Номер, Прием.Организация.Префикс) + " от " + Формат(Прием.Дата, "ДЛФ=DD");
		ВыводитьЗаказчика   = Ложь;
		
		Если ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.Прием") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Квитанция об оплате приема " + НомерИДатаДокумента;
		ИначеЕсли ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.ПланЛечения") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Квитанция об оплате плана лечения " + НомерИДатаДокумента;
		ИначеЕсли ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.НарядЗаказ") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Квитанция об оплате наряд-заказа " + НомерИДатаДокумента;
		ИначеЕсли ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.Реализация") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Квитанция об оплате реализации " + НомерИДатаДокумента;
		КонецЕсли;
		
		Область_Организация.Параметры.ПредставлениеОрганизации 	= ?(ЗначениеЗаполнено(Прием.Организация.ПолноеНаименование), Прием.Организация.ПолноеНаименование, Прием.Организация.Наименование);
		Область_Врач.Параметры.ПредставлениеВрача 				= Прием.Врач;
		
		Если ЗначениеЗаполнено(Прием.Диагноз) Тогда
			
			Если ТипЗнч(Прием.Диагноз) = Тип("СправочникСсылка.Диагнозы")
				И ЗначениеЗаполнено(Прием.Диагноз.Наименование) Тогда
				Область_Диагноз.Параметры.Диагноз = Прием.Диагноз.Наименование;
			Иначе
				Область_Диагноз.Параметры.Диагноз = Строка(Прием.Диагноз);		
			КонецЕсли;
			
		Иначе
			Область_Диагноз.Параметры.Диагноз = "";		
		КонецЕсли;
		
		Область_Пациент.Параметры.ПредставлениеПациента 		= СокрЛП(Прием.Пациент) + ?(ЗначениеЗаполнено(Прием.Пациент.ДатаРожденияКлиента),", дата рождения: " + Формат(Прием.Пациент.ДатаРожденияКлиента, "ДФ=dd.MM.yyyy"), "") + ?(ЗначениеЗаполнено(Прием.Пациент.Телефон), ", тел. " + Прием.Пациент.Телефон, "");
		Если ЗначениеЗаполнено(Прием.Пациент.ДатаРожденияКлиента) И ЗначениеЗаполнено(Прием.Пациент.ЗаконныйПредставитель)
			И Справочники.Контрагенты.ПолучитьВидимостьЗаконногоПредставителя(Прием.Пациент.ДатаРожденияКлиента, Прием.Пациент.НедееспособныйГражданин) Тогда
			ВыводитьЗаказчика = Истина;
			Область_Заказчик.Параметры.ПредставлениеЗаказчика = Строка(Прием.Пациент.ЗаконныйПредставитель) + ?(ЗначениеЗаполнено(Прием.Пациент.ЗаконныйПредставитель.Телефон), ", тел. " + Прием.Пациент.ЗаконныйПредставитель.Телефон, "");
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(Область_Заголовок);
		ТабличныйДокумент.Вывести(Область_Организация);
		Если НЕ НесколькоВрачейВОдномПриеме Тогда 
			ТабличныйДокумент.Вывести(Область_Врач);
		КонецЕсли;
		ТабличныйДокумент.Вывести(Область_Пациент);
		Если ВыводитьЗаказчика = Истина Тогда
			ТабличныйДокумент.Вывести(Область_Заказчик);
		КонецЕсли;
		Если ЗначениеЗаполнено(Прием.Диагноз) Тогда
			ТабличныйДокумент.Вывести(Область_Диагноз);
		КонецЕсли;
		
		//=============================================================ЗАПОЛНЕНИЕ ТАБЛИЦЫ===================================================================
		ОбластьЗаголовка = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ОбластьСтрока    = ?(НЕ НесколькоВрачейВОдномПриеме, Макет.ПолучитьОбласть("СтрокаТаблицы"), Макет.ПолучитьОбласть("СтрокаТаблицы2"));
		ОбластьИтого     = Макет.ПолучитьОбласть("Подвал_Итого");
		ОбластьСкидка    = Макет.ПолучитьОбласть("Подвал_Итого_Скидка");
		ОбластьКОплате   = Макет.ПолучитьОбласть("Подвал_КОплате");
		
		Если НЕ ЭтоСтоматологическиеУслуги Тогда
			ОбластьКолонкаЗуб = ОбластьЗаголовка.Область("R1C3:R2C3");
			ОбластьЗаголовка.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
			ОбластьКолонкаЗуб = ОбластьСтрока.Область("R1C3:R2C3");
			ОбластьСтрока.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
			ОбластьКолонкаЗуб = ОбластьИтого.Область("R1C3:R2C3");
			ОбластьИтого.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
		КонецЕсли;
		
		Если НесколькоВрачейВОдномПриеме Тогда
			НашаОбласть = ОбластьЗаголовка.НайтиТекст("Наименование работ", , , , Истина, , Истина);
			Если НашаОбласть <> Неопределено Тогда 
				НашаОбласть.Текст = "Наименование работ / Врач";
			КонецЕсли;	
		КонецЕсли;		
		ТабличныйДокумент.Вывести(ОбластьЗаголовка);
		
		НомерСтроки 		= 0;
		ОбщаяСуммаСкидки 	= 0;
		
		Пока ВыборкаПоУслугам.Следующий() Цикл
			
			Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") Тогда
				
				НомерСтроки                                  = НомерСтроки + 1;
				Цена										 = ВыборкаПоУслугам.Сумма / ?(ВыборкаПоУслугам.Количество = 0, 1, ВыборкаПоУслугам.Количество);
				СуммаСкидки									 = ВыборкаПоУслугам.Сумма - ВыборкаПоУслугам.СуммаСоСкидкой;
				ОбластьСтрока.Параметры.Заполнить(ВыборкаПоУслугам);
				ОбластьСтрока.Параметры.НомерСтроки          = НомерСтроки; 
				ОбластьСтрока.Параметры.Услуга               = ВыборкаПоУслугам.Услуга.НаименованиеПолное;
				Если ВыборкаПоУслугам.Услуга.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
					ОбластьСтрока.Параметры.Артикул          = ВыборкаПоУслугам.Артикул;
				Иначе
					ОбластьСтрока.Параметры.Артикул          = ВыборкаПоУслугам.Услуга.Артикул;
				КонецЕсли;
				ОбластьСтрока.Параметры.Цена                 = Цена;
				ОбластьСтрока.Параметры.СуммаСкидки          = СуммаСкидки;
				ОбластьСтрока.Параметры.ПроцентСкидки		 = ?(ВыборкаПоУслугам.ПроцентСкидки > 0, Формат(ВыборкаПоУслугам.ПроцентСкидки, "ЧДЦ=2") + "%", "");
				// ВыборкаПоЗубам                               = ВыборкаПоУслугам.Зуб;
				
				СтрокаЗуб = "";
				Если ЗначениеЗаполнено(ВыборкаПоУслугам.Зуб) Тогда
					Если СтрокаЗуб = "" Тогда
						СтрокаЗуб = Строка(ВыборкаПоУслугам.Зуб);
					Иначе 
						СтрокаЗуб = СтрокаЗуб + ?(ЗначениеЗаполнено(ВыборкаПоУслугам.Зуб), ", ", "") + Строка(ВыборкаПоУслугам.Зуб);
					КонецЕсли;
					
					СтрокаВрач = "";
					// ВыборкаПоВрачам = ВыборкаПоЗубам.Выбрать();
					Если ЗначениеЗаполнено(ВыборкаПоУслугам.Врач) Тогда						
						Если СтрокаВрач = "" Тогда
							СтрокаВрач = Строка(ВыборкаПоУслугам.Врач);
						Иначе 
							СтрокаВрач = СтрокаВрач + ?(ЗначениеЗаполнено(ВыборкаПоУслугам.Врач), ", ", "") + Строка(ВыборкаПоУслугам.Врач);
						КонецЕсли;						
					КонецЕсли;			
				КонецЕсли;
				
				Если НесколькоВрачейВОдномПриеме Тогда
					ОбластьСтрока.Параметры.Врач = СтрокаВрач;
				КонецЕсли;
				Если ЭтоСтоматологическиеУслуги Тогда
					ОбластьСтрока.Параметры.Зуб = СтрокаЗуб;
				КонецЕсли;
				ТабличныйДокумент.Вывести(ОбластьСтрока);
				
				ОбщаяСуммаСкидки = ОбщаяСуммаСкидки + (ВыборкаПоУслугам.Сумма - ВыборкаПоУслугам.СуммаСоСкидкой);
				
			КонецЕсли;
			
		КонецЦикла;
		
		ОбластьИтого.Параметры.ОбщееИтогоБезСкидкой 	= Прием.ОбщееИтогоСоСкидкой + ОбщаяСуммаСкидки - ТаблицаВозврата.Итог("Сумма") + ТаблицаВозврата.Итог("СуммаСкидки");
		ОбластьСкидка.Параметры.Скидка 					= ОбщаяСуммаСкидки ;
		ОбластьКОплате.Параметры.ОбщееИтогоСоСкидкой 	= Прием.ОбщееИтогоСоСкидкой - ТаблицаВозврата.Итог("Сумма")+ ТаблицаВозврата.Итог("СуммаСкидки");
		
		ТабличныйДокумент.Вывести(ОбластьИтого);
		Если ОбщаяСуммаСкидки > 0 Тогда 
			ТабличныйДокумент.Вывести(ОбластьСкидка);
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьКОплате);
		
		// Выводим виды оплат
		ТипыОплаты = ТаблицаОплаты.Скопировать();
		ТипыОплаты.Свернуть("ДатаПроведения,ТипДенежныхСредств","Сумма");	
		Если ТипыОплаты.Количество() > 0 Тогда		
			ТекОбласть = Макет.ПолучитьОбласть("ШапкаВидыОплат");
			ТабличныйДокумент.Вывести(ТекОбласть);
			
			Для Каждого Строка из ТипыОплаты Цикл
				ТекОбласть                       = Макет.ПолучитьОбласть("ВидОплаты");
				ТекОбласть.Параметры.ДатаОплаты  = Строка.ДатаПроведения;
				ТекОбласть.Параметры.ВидОплаты   = Строка.ТипДенежныхСредств;
				ТекОбласть.Параметры.СуммаОплаты = Строка.Сумма;
				ТабличныйДокумент.Вывести(ТекОбласть);			
			КонецЦикла;			
			ТекОбласть = Макет.ПолучитьОбласть("Подвал_ИтогоОплачено");
			ТекОбласть.Параметры.ИтогоОплачено = ТипыОплаты.Итог("Сумма");
			ТабличныйДокумент.Вывести(ТекОбласть);			
		КонецЕсли;
		
		ЧтоОплачено = ТаблицаОплаты.Скопировать();
		ЧтоОплачено.Свернуть("ДокументОснования, ВидОперации","Сумма");
		ЧтоОплачено.Сортировать("ДокументОснования УБЫВ");
		Если ЧтоОплачено.Количество() > 1 Тогда
			
			ТекОбласть = Макет.ПолучитьОбласть("Подвал_ИзНих");
			ТабличныйДокумент.Вывести(ТекОбласть);			
			Для Каждого Строка из ЧтоОплачено Цикл				
				ТекОбласть = Макет.ПолучитьОбласть("Подвал_ЧтоОплачено");
				Если ЗначениеЗаполнено(Строка.ДокументОснования) И Строка.ДокументОснования = ТекущийДокумент Тогда					
					ТекОбласть.Параметры.ЧтоОплачено = "Текущий прием:";					
				ИначеЕсли ЗначениеЗаполнено(Строка.ДокументОснования) И Строка.ДокументОснования <> ТекущийДокумент  Тогда										
					ТекОбласть.Параметры.ЧтоОплачено = "" + ТипЗнч(Строка.ДокументОснования) + " №" + Формат(ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(Строка.ДокументОснования.Номер, Истина, Истина),"ЧГ=0") + " от " + Формат(Строка.ДокументОснования.Дата,"ДФ=dd.MM.yyyy") + ", вр. " + Строка.ДокументОснования.Сотрудник.Фамилия + " " + Лев(Строка.ДокументОснования.Сотрудник.Имя,1) + ". " + Лев(Строка.ДокументОснования.Сотрудник.Отчество,1) + ".";										
				ИначеЕсли НЕ ЗначениеЗаполнено(Строка.ДокументОснования) И Строка.ВидОперации = Перечисления.ВидыОпераций.ВзносНаЛицевойСчет Тогда					
					ТекОбласть.Параметры.ЧтоОплачено = "Зачислено на лицевой счет:";					
				КонецЕсли;			
				ТекОбласть.Параметры.СуммаОплаты = Строка.Сумма;
				ТабличныйДокумент.Вывести(ТекОбласть);				
			КонецЦикла;
		КонецЕсли;
		
		//=============================================================ЗАПОЛНЕНИЕ ДОЛГОВ===================================================================			
		ДатаПолученияЗадолженности = ТаблицаОплаты.Скопировать();
		ДатаПолученияЗадолженности.Свернуть("ДатаПроведения","");
		ДатаПолученияЗадолженности.Сортировать("ДатаПроведения УБЫВ");
		
		Если ДатаПолученияЗадолженности.Количество() > 0 Тогда
			ДатаЗадолженности = КонецДня(ДатаПолученияЗадолженности[0].ДатаПроведения);				 
		Иначе
			ДатаЗадолженности = КонецДня(ТекущийДокумент.Дата);
		КонецЕсли;
		
		ЗапросПоДолгам = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументРеализации КАК ДокументЗадолженности,
		|	-ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток КАК Сумма
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
		|			&Дата,
		|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|				И Контрагент = &Контрагент
		|				И ДокументРеализации <> НЕОПРЕДЕЛЕНО
		|				И ДокументРеализации <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)
		|				И ДокументРеализации <> &ТекущийДокумент) КАК ВзаиморасчетыСКонтрагентамиОстатки
		|ГДЕ
		|	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток < 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументАванса,
		|	-ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
		|			&Дата,
		|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|				И Контрагент = &Контрагент
		|				И ДокументРеализации = НЕОПРЕДЕЛЕНО
		|				И ДокументРеализации <> ЗНАЧЕНИЕ(Документ.Прием.ПустаяСсылка)) КАК ВзаиморасчетыСКонтрагентамиОстатки
		|ГДЕ
		|	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток < 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументРеализации,
		|	-ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
		|			,
		|			СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|				И Контрагент = &Контрагент
		|				И ДокументРеализации = &ТекущийДокумент) КАК ВзаиморасчетыСКонтрагентамиОстатки
		|ГДЕ
		|	ВзаиморасчетыСКонтрагентамиОстатки.СуммаОстаток < 0");
		
		ЗапросПоДолгам.УстановитьПараметр("СтруктурнаяЕдиница", ТекущийДокумент.СтруктурнаяЕдиница);
		ЗапросПоДолгам.УстановитьПараметр("Контрагент"		  , ТекущийДокумент.Контрагент);
		ЗапросПоДолгам.УстановитьПараметр("Дата"			  , ДатаЗадолженности + 1);
		ЗапросПоДолгам.УстановитьПараметр("ТекущийДокумент"	  , ТекущийДокумент);
		
		ТаблицаДолгов = ЗапросПоДолгам.Выполнить().Выгрузить();
		
		Если ТаблицаДолгов.Количество() > 0 Тогда
			
			ТекОбласть = Макет.ПолучитьОбласть("ШапкаДолга");
			ТабличныйДокумент.Вывести(ТекОбласть);			
			Для Каждого Строка ИЗ ТаблицаДолгов Цикл				
				ТекОбласть = Макет.ПолучитьОбласть("СтрокаДолга");
				ТекОбласть.Параметры.ДатаДолга = ?(ЗначениеЗаполнено(Строка.ДокументЗадолженности), Формат(Строка.ДокументЗадолженности.Дата, "ДФ=dd.MM.yyyy"), "NULL");
				ТекОбласть.Параметры.ДокументДолга = ?(ЗначениеЗаполнено(Строка.ДокументЗадолженности), "" + ТипЗнч(Строка.ДокументЗадолженности) + " №" + Формат(ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(Строка.ДокументЗадолженности.Номер, Истина, Истина), "ЧГ=0") + ", вр. " + Строка.ДокументЗадолженности.Сотрудник.Фамилия + " " + Лев(Строка.ДокументЗадолженности.Сотрудник.Имя,1) + ". " + Лев(Строка.ДокументЗадолженности.Сотрудник.Отчество, 1) + ".", "NULL");
				ТекОбласть.Параметры.СуммаДолга = Строка.Сумма;                                                                                   
				ТабличныйДокумент.Вывести(ТекОбласть);			
			КонецЦикла;		
			ТекОбласть = Макет.ПолучитьОбласть("ПодвалДолга");
			ТекОбласть.Параметры.СуммаДолга = ТаблицаДолгов.Итог("Сумма");
			ТабличныйДокумент.Вывести(ТекОбласть);		
		КонецЕсли;
		
		Если КоличествоОбъектов > 1
			И ИндексОбъекта < КоличествоОбъектов - 1 Тогда
			
			ОбластьМакета = Макет.ПолучитьОбласть("Комментарий");
			ОбластьМакета.Параметры.Комментарий = ТекущийДокумент.Комментарий;
			ТабличныйДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		
		ИндексОбъекта = ИндексОбъекта + 1;
		
	КонецЦикла;
	
	//=============================================================ЗАПОЛНЕНИЕ АВАНСОВ===================================================================	
	Если ТаблицаАвансов.Количество() > 0 Тогда
		
		ТекОбласть = Макет.ПолучитьОбласть("ШапкаАванса");
		ТабличныйДокумент.Вывести(ТекОбласть);			
		Для Каждого Строка ИЗ ТаблицаАвансов Цикл				
			ТекОбласть = Макет.ПолучитьОбласть("СтрокаАванса");
			ТекОбласть.Параметры.ДатаАванса = ?(ЗначениеЗаполнено(Строка.ДокументАванса), Формат(Строка.ДокументАванса.Дата, "ДФ=dd.MM.yyyy"), "NULL");
			ТекОбласть.Параметры.ДокументАванса = ?(ЗначениеЗаполнено(Строка.ДокументАванса), "" + ТипЗнч(Строка.ДокументАванса) + " №" + Формат(ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(Строка.ДокументАванса.Номер, Истина, Истина), "ЧГ=0") + ", вр. " + Строка.ДокументАванса.Сотрудник.Фамилия + " " + Лев(Строка.ДокументАванса.Сотрудник.Имя, 1) + ". " + Лев(Строка.ДокументАванса.Сотрудник.Отчество, 1) + ".", "NULL");
			ТекОбласть.Параметры.СуммаАванса = Строка.СуммаОстаток;                                                                                   
			ТабличныйДокумент.Вывести(ТекОбласть);			
		КонецЦикла;		
		ТекОбласть = Макет.ПолучитьОбласть("ПодвалАванса");
		ТекОбласть.Параметры.СуммаАванса = ТаблицаАвансов.Итог("СуммаОстаток");
		ТабличныйДокумент.Вывести(ТекОбласть);		
	КонецЕсли;	
	
	//=========================================================ЗАПОЛНЕНИЕ ЛИЦЕВЫХ СЧЕТОВ=================================================================	 
	Если ТаблицаЛицевыеСчета.Количество() > 0 Тогда
		
		ТекОбласть = Макет.ПолучитьОбласть("ШапкаЛицевыСчета");
		ТабличныйДокумент.Вывести(ТекОбласть);			
		Для Каждого Строка ИЗ ТаблицаЛицевыеСчета Цикл				
			ТекОбласть = Макет.ПолучитьОбласть("СтрокаЛицевыСчета");
			ТекОбласть.Параметры.ЛицевойСчет 			= Строка.ВидСчета;
			ТекОбласть.Параметры.СуммаНаЛицевомСчету 	= Строка.СуммаОстаток;                                                                                   
			ТабличныйДокумент.Вывести(ТекОбласть);			
		КонецЦикла;		
		ТекОбласть = Макет.ПолучитьОбласть("ПодвалЛицевыСчета");
		ТекОбласть.Параметры.СуммаНаЛицевомСчету = ТаблицаЛицевыеСчета.Итог("СуммаОстаток");
		ТабличныйДокумент.Вывести(ТекОбласть);		
	КонецЕсли;	
	
	//===================================================================================================================================================
	Пока ВыборкаЗаписи.Следующий() Цикл
		Если ВыборкаЗаписи.Ссылка.Услуги.Количество() <> 0 Тогда
			Область_ПредварительнаяЗапись                                 = Макет.ПолучитьОбласть("ПредварительнаяЗапись");
			СтрокаТЧУслуги                                                = ВыборкаЗаписи.Ссылка.Услуги[0];
			ДатаПриема                                                    = СтрокаТЧУслуги.ДатаНачала;
			Сотрудник                                                     = СтрокаТЧУслуги.Сотрудник;
			Область_ПредварительнаяЗапись.Параметры.ПредварительнаяЗапись = "Вы записаны на прием: " + Формат(ДатаПриема, "ДФ='ддд дд ММММ ""в"" ЧЧ:мм'") + ", к " + Сотрудник;			
			ТабличныйДокумент.Вывести(Область_ПредварительнаяЗапись);
		КонецЕсли;
	КонецЦикла;
	
	//=============================================================ЗАПОЛНЕНИЕ ГАРАНТИИ===================================================================
	ОбластьШапка  = Макет.ПолучитьОбласть("ШапкаГарантия");
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаГарантия");
	Если НЕ ЭтоСтоматологическиеУслуги Тогда
		ОбластьКолонкаЗуб = ОбластьШапка.Область("R1C3:R2C5");
		ОбластьШапка.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
		ОбластьКолонкаЗуб = ОбластьСтрока.Область("R1C3:R1C5");
		ОбластьСтрока.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
	КонецЕсли;
	//
	ВыборкаПоУслугам.Сбросить();
	НомерСтроки = 0;
	Пока ВыборкаПоУслугам.Следующий() Цикл				
		Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") И ВыборкаПоУслугам.Гарантия <> NULL И ВыборкаПоУслугам.Гарантия > 0 Тогда
			НомерСтроки = НомерСтроки + 1;
			Если НомерСтроки = 1 Тогда
				ТабличныйДокумент.Вывести(ОбластьШапка);	
			КонецЕсли;				
			ОбластьСтрока.Параметры.Заполнить(ВыборкаПоУслугам);
			ОбластьСтрока.Параметры.Услуга        = ВыборкаПоУслугам.Услуга.НаименованиеПолное;
			ОбластьСтрока.Параметры.НомерСтроки   = НомерСтроки;
			ОбластьСтрока.Параметры.ГарантияДо    = ДобавитьМесяц(Прием.Дата,ВыборкаПоУслугам.Гарантия);
			ТабличныйДокумент.Вывести(ОбластьСтрока);						
		КонецЕсли;					
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если КоличествоОбъектов > 0 Тогда
		ОбластьМакета = Макет.ПолучитьОбласть("Комментарий");
		ОбластьМакета.Параметры.Комментарий = ?(ЗначениеЗаполнено(ТекущийДокумент), ТекущийДокумент.Комментарий, "");
		ТабличныйДокумент.Вывести(ОбластьМакета);
	КонецЕсли;
	
	Область_Подписи = Макет.ПолучитьОбласть("Подписи");
	ТабличныйДокумент.Вывести(Область_Подписи);
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

// Функция генерации печатной формы "АктОВыполненныхРаботах"
//
Функция СформироватьПечатнуюФорму_АктОВыполненныхРаботах(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ПФ_MXL_АктОВыполненныхРаботах";
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если ТипЗнч(ТекущийДокумент) <> Тип("ДокументСсылка.Прием") Тогда
			Продолжить;
		КонецЕсли;
			
		ЭтоСтоматологическиеУслуги = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(ТекущийДокумент.Сотрудник); 
		НомерСтрокиНачало          = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Прием.Номер КАК Номер,
		|	Прием.Дата КАК Дата,
		|	Прием.СтруктурнаяЕдиница.Организация КАК Организация,
		|	Прием.Контрагент КАК Пациент,
		|	Прием.Сотрудник КАК Врач,
		|	Прием.СуммаДокумента КАК ОбщееИтогоСоСкидкой,
		|	Прием.СуммаОплачено КАК ИтогоОплачено,
		|	Прием.ПредварительнаяЗаписьНаСледующийПрием КАК ПредварительнаяЗапись,
		|	Прием.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств КАК Валюта,
		|	ЕСТЬNULL(Прием.Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей, 0) КАК ТекущаяМедицинскаяКарта,
		|	Прием.ПолисМедСтрахования КАК ПолисМедСтрахования
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВозвратОтПокупателяЛечение.Зуб КАК Зуб,
		|	ВозвратОтПокупателяЛечение.Номенклатура КАК Номенклатура,
		|	ВозвратОтПокупателяЛечение.КоличествоУпаковок КАК Количество,
		|	ВозвратОтПокупателяЛечение.Цена КАК Цена,
		|	ВозвратОтПокупателяЛечение.Цена * ЕСТЬNULL(ВозвратОтПокупателяЛечение.КоличествоУпаковок, 1) КАК СуммаБезСкидки,
		|	ВозвратОтПокупателяЛечение.Сумма КАК Сумма,
		|	ВозвратОтПокупателяЛечение.Ссылка КАК Ссылка,
		|	ВозвратОтПокупателяЛечение.Номенклатура.НоменклатураМедицинскихУслуг.Код КАК НоменклатураКод,
		|	ВозвратОтПокупателяЛечение.Упаковка КАК Упаковка,
		|	ВозвратОтПокупателяЛечение.СтавкаНДС КАК СтавкаНДС,
		|	ВозвратОтПокупателяЛечение.СуммаНДС КАК СуммаНДС,
		|	ВозвратОтПокупателяЛечение.Номенклатура.Артикул КАК НоменклатураАртикул
		|ПОМЕСТИТЬ ВозвращенныеУслуги
		|ИЗ
		|	Документ.ВозвратОтПокупателя.Лечение КАК ВозвратОтПокупателяЛечение
		|ГДЕ
		|	ВозвратОтПокупателяЛечение.Ссылка.ДокументОснования = &Ссылка
		|	И ВозвратОтПокупателяЛечение.Ссылка.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПриемЛечение.Зуб КАК Зуб,
		|	ПриемЛечение.Номенклатура КАК Номенклатура,
		|	СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.Количество, 0)) КАК Количество,
		|	МАКСИМУМ(ПриемЛечение.Цена) КАК Цена,
		|	СУММА(ПриемЛечение.Цена * ЕСТЬNULL(ПриемЛечение.КоличествоУпаковок, 1) - ЕСТЬNULL(ВозвращенныеУслуги.СуммаБезСкидки, 0)) КАК СуммаБезСкидки,
		|	СУММА(ПриемЛечение.Сумма - ЕСТЬNULL(ВозвращенныеУслуги.Сумма, 0)) КАК Сумма,
		|	ПриемЛечение.Ссылка КАК Ссылка,
		|	ПриемЛечение.Номенклатура.НоменклатураМедицинскихУслуг.Код КАК НоменклатураКод,
		|	ЕСТЬNULL(ПриемЛечение.Гарантия, 0) КАК Гарантия,
		|	ПриемЛечение.НомерСтроки КАК НомерСтроки,
		|	ПриемЛечение.Рекламация КАК Рекламация,
		|	ПриемЛечение.СтавкаНДС КАК СтавкаНДС,
		|	СУММА(ПриемЛечение.СуммаНДС) КАК СуммаНДС,
		|	ВЫРАЗИТЬ(ПриемЛечение.Номенклатура.НаименованиеПолное КАК СТРОКА(200)) КАК Услуга,
		|	ПриемЛечение.Номенклатура.Артикул КАК НоменклатураАртикул
		|ИЗ
		|	Документ.Прием.Лечение КАК ПриемЛечение
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвращенныеУслуги КАК ВозвращенныеУслуги
		|		ПО ПриемЛечение.Номенклатура = ВозвращенныеУслуги.Номенклатура
		|			И ПриемЛечение.Упаковка = ВозвращенныеУслуги.Упаковка
		|ГДЕ
		|	ПриемЛечение.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриемЛечение.Номенклатура,
		|	ПриемЛечение.Зуб,
		|	ПриемЛечение.Ссылка,
		|	ПриемЛечение.НомерСтроки,
		|	ПриемЛечение.Рекламация,
		|	ПриемЛечение.СтавкаНДС,
		|	ВЫРАЗИТЬ(ПриемЛечение.Номенклатура.НаименованиеПолное КАК СТРОКА(200)),
		|	ЕСТЬNULL(ПриемЛечение.Гарантия, 0),
		|	ПриемЛечение.Номенклатура.НоменклатураМедицинскихУслуг.Код
		|
		|ИМЕЮЩИЕ
		|	(СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.Количество, 0)) > 0
		|		ИЛИ СУММА(ПриемЛечение.Сумма - ЕСТЬNULL(ВозвращенныеУслуги.Сумма, 0)) > 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ
		|	СУММА(Количество),
		|	МАКСИМУМ(Цена),
		|	СУММА(СуммаБезСкидки),
		|	СУММА(Сумма),
		|	МАКСИМУМ(Гарантия),
		|	СУММА(СуммаНДС)
		|ПО
		|	Номенклатура,
		|	Зуб";
		
		Запрос.УстановитьПараметр("Ссылка", ТекущийДокумент);
		ПакетЗапросов 		= Запрос.ВыполнитьПакет();
		
		Прием_Шапка 		= ПакетЗапросов[0].Выбрать();
		ВыборкаУслуги       = ПакетЗапросов[1+1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ТаблицаУслуги	 	= ПакетЗапросов[1+1].Выгрузить();
		
		УказанПолис = ЗначениеЗаполнено(ТекущийДокумент.ПолисМедСтрахования);
		
		Если  УказанПолис Тогда 
			Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_АктОВыполненныхРаботахЕстьПолис");	
		Иначе
			Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_АктОВыполненныхРаботах");
		КонецЕсли;
		//==============================================================ЗАПОЛНЕНИЕ ШАПКИ====================================================================
		Прием_Шапка.Следующий();		
		
		ОбластьМакета                          = Макет.ПолучитьОбласть("Заголовок");
		ТекстЗаголовка                         = "Акт № " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(Прием_Шапка.Номер, Истина, Истина) + " от " +Формат(Прием_Шапка.Дата, "ДЛФ=DD");
		ОбластьМакета.Параметры.ТекстЗаголовка = ТекстЗаголовка;
		ТабличныйДокумент.Вывести(ОбластьМакета);		
		
		ОбластьМакета                                    = Макет.ПолучитьОбласть("Поставщик");
		ПредставлениеПоставщика  = ?(ЗначениеЗаполнено(Прием_Шапка.Организация.ПолноеНаименование), Прием_Шапка.Организация.ПолноеНаименование, Прием_Шапка.Организация.Наименование);		
		ЮрАдрес 										 = Прием_Шапка.Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Вид");
		
		Если ЮрАдрес <> Неопределено Тогда
			ПредставлениеПоставщика = ПредставлениеПоставщика + ", Адрес: " + ЮрАдрес.Представление;
		КонецЕсли;
		Если Прием_Шапка.Организация.ИНН <> "" Тогда 
			ПредставлениеПоставщика = ПредставлениеПоставщика + ", ИНН: " + Прием_Шапка.Организация.ИНН;
		КонецЕсли; 	
		
		ОбластьМакета.Параметры.ПредставлениеПоставщика  = ПредставлениеПоставщика;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                    = Макет.ПолучитьОбласть("Врач");
		ОбластьМакета.Параметры.ПредставлениеВрача		 = Прием_Шапка.Врач;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                   = Макет.ПолучитьОбласть("Покупатель");
		ОбластьМакета.Параметры.ПредставлениеПолучателя = Строка(Прием_Шапка.Пациент) + ?(Прием_Шапка.ТекущаяМедицинскаяКарта <> 0, ", мед. карта № " + Строка(Прием_Шапка.ТекущаяМедицинскаяКарта), "");
		
		Если ЗначениеЗаполнено(Прием_Шапка.Пациент.ДатаРожденияКлиента) И ЗначениеЗаполнено(Прием_Шапка.Пациент.ЗаконныйПредставитель)
			И Справочники.Контрагенты.ПолучитьВидимостьЗаконногоПредставителя(Прием_Шапка.Пациент.ДатаРожденияКлиента, Прием_Шапка.Пациент.НедееспособныйГражданин) Тогда
			ОбластьМакета.Параметры.Пациент = "Пациент: ";
			ОбластьМакета.Параметры.ПредставлениеПолучателя = Строка(Прием_Шапка.Пациент.ЗаконныйПредставитель);
			ОбластьМакета.Параметры.ПредставлениеПациента = Строка(Прием_Шапка.Пациент) + ?(Прием_Шапка.ТекущаяМедицинскаяКарта <> 0, ", мед. карта № " + Строка(Прием_Шапка.ТекущаяМедицинскаяКарта), "");
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьМакета); 
		
		Если УказанПолис Тогда 
			
			ОбластьМакета                                    = Макет.ПолучитьОбласть("Полис");
			ПолисНаименование 								 = Прием_Шапка.ПолисМедСтрахования.СтраховаяКомпания.Наименование + " №" + Прием_Шапка.ПолисМедСтрахования.НомерПолиса + " с " + Формат(Прием_Шапка.ПолисМедСтрахования.ДанаНачала, "ДФ =дд.ММ.гггг") + " по " + Формат(Прием_Шапка.ПолисМедСтрахования.ДатаОкончания, "ДФ =дд.ММ.гггг");  
			// ОбластьМакета.Параметры.ПредставлениеПолиса		 = Строка(Прием_Шапка.ПолисМедСтрахования);
			ОбластьМакета.Параметры.ПредставлениеПолиса		 = ПолисНаименование;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			НомерСтроки = 0;
			//=============================================================ЗАПОЛНЕНИЕ ТАБЛИЦЫ===================================================================		
			ОбластьЗаголовок = Макет.ПолучитьОбласть("ШапкаТаблицы");
			ОбластьСтроки    = Макет.ПолучитьОбласть("Строка");
			ОбластьПодписи   = Макет.ПолучитьОбласть("Подписи");
			
			// Удалить колонки зуб если это не стом. прием
			Если НЕ ЭтоСтоматологическиеУслуги Тогда
				ОбластьКолонкаЗуб = ОбластьЗаголовок.Область("R1C4:R2C7");
				ОбластьЗаголовок.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
				ОбластьКолонкаЗуб = ОбластьСтроки.Область("R1C4:R1C7");
				ОбластьСтроки.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
			КонецЕсли; 
			ТабличныйДокумент.Вывести(ОбластьЗаголовок);
			
			Пока ВыборкаУслуги.Следующий() Цикл
				ОбластьСтроки.Параметры.Заполнить(ВыборкаУслуги);
				ОбластьСтроки.Параметры.Услуга = ВыборкаУслуги.Номенклатура.НаименованиеПолное;
				СтрокаЗуб = "";			
				ОбластьСтроки.Параметры.Количество =  ?(ВыборкаУслуги.Количество = 0, 1, ВыборкаУслуги.Количество);			 
				
				НомерСтроки                         = НомерСтроки + 1;
				ОбластьСтроки.Параметры.НомерСтроки = НомерСтроки;
				ОбластьСтроки.Параметры.Сумма		= ВыборкаУслуги.Сумма;
				
				ВыборкаПоЗубам = ВыборкаУслуги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"");
				Пока ВыборкаПоЗубам.Следующий() Цикл 
					
					Если ЗначениеЗаполнено(ВыборкаПоЗубам.Зуб) и СтрНайти(СтрокаЗуб, ВыборкаПоЗубам.Зуб) = 0 Тогда
						Если СтрокаЗуб = "" Тогда
							СтрокаЗуб = Строка(ВыборкаПоЗубам.Зуб);
						Иначе 
							СтрокаЗуб = СтрокаЗуб + ?(ЗначениеЗаполнено(ВыборкаПоЗубам.Зуб), ", ", "") + Строка(ВыборкаПоЗубам.Зуб);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				Если ЭтоСтоматологическиеУслуги Тогда
					ОбластьСтроки.Параметры.Зуб = СтрокаЗуб;
				КонецЕсли;
				ТабличныйДокумент.Вывести(ОбластьСтроки);
				
			КонецЦикла; 		
			
			ТабличныйДокумент.Вывести(ОбластьПодписи); 	
			
		Иначе
			//=============================================================ЗАПОЛНЕНИЕ ТАБЛИЦЫ===================================================================		
			ЕстьСкидки = ТаблицаУслуги.Итог("СуммаБезСкидки") - ТаблицаУслуги.Итог("Сумма") <> 0;
			Если ЕстьСкидки  Тогда
				ОбластьЗаголовок = Макет.ПолучитьОбласть("ШапкаТаблицыСоСкидкой");
				ОбластьСтроки    = Макет.ПолучитьОбласть("СтрокаСоСкидкой");
			Иначе
				ОбластьЗаголовок = Макет.ПолучитьОбласть("ШапкаТаблицы");
				ОбластьСтроки    = Макет.ПолучитьОбласть("Строка");
			КонецЕсли;
			ОбластьИтог          = Макет.ПолучитьОбласть("Итого");
			ОбластьСуммаПрописью = Макет.ПолучитьОбласть("СуммаПрописью");
			ОбластьПодписи       = Макет.ПолучитьОбласть("Подписи");	
			// Удалить колонки зуб если это не стом. прием
			Если НЕ ЭтоСтоматологическиеУслуги Тогда
				ОбластьКолонкаЗуб = ОбластьЗаголовок.Область("R1C4:R2C7");
				ОбластьЗаголовок.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
				ОбластьКолонкаЗуб = ОбластьСтроки.Область("R1C4:R1C7");
				ОбластьСтроки.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
				ОбластьКолонкаЗуб = ОбластьИтог.Область("R1C4:R2C7");
				ОбластьИтог.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
			КонецЕсли; 
			ТабличныйДокумент.Вывести(ОбластьЗаголовок);
			НомерСтроки = 0;
			ОбщееИтого  = 0;
			ОбщееСуммаНДС = 0;
			
			Пока ВыборкаУслуги.Следующий() Цикл
				ОбластьСтроки.Параметры.Заполнить(ВыборкаУслуги);
				СтрокаЗуб = "";			
				Если Не ЗначениеЗаполнено(ВыборкаУслуги.Рекламация) Тогда
					ОбластьСтроки.Параметры.Цена = ВыборкаУслуги.СуммаБезСкидки / ?(ВыборкаУслуги.Количество = 0, 1, ВыборкаУслуги.Количество);			 
					Если ВыборкаУслуги.СуммаБезСкидки <> 0 и  ЕстьСкидки Тогда
						ОбластьСтроки.Параметры.СуммаСкидки = ВыборкаУслуги.СуммаБезСкидки - ВыборкаУслуги.Сумма;
					КонецЕсли;
					ОбластьСтроки.Параметры.Сумма = ВыборкаУслуги.Сумма;
				Иначе
					ОбластьСтроки.Параметры.Цена        = 0;
					ОбластьСтроки.Параметры.СуммаСкидки = 0;
					ОбластьСтроки.Параметры.Сумма       = 0;
				КонецЕсли;
				
				НомерСтроки                         = НомерСтроки + 1;
				ОбластьСтроки.Параметры.НомерСтроки = НомерСтроки;
				
				ВыборкаПоЗубам = ВыборкаУслуги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"");
				Пока ВыборкаПоЗубам.Следующий() Цикл 
					Если Не ЗначениеЗаполнено(ОбластьСтроки.Параметры.СтавкаНДС) Тогда
						ОбластьСтроки.Параметры.СтавкаНДС = ВыборкаПоЗубам.СтавкаНДС;		
					КонецЕсли;
					Если ЗначениеЗаполнено(ВыборкаПоЗубам.Зуб) и СтрНайти(СтрокаЗуб, ВыборкаПоЗубам.Зуб) = 0 Тогда
						Если СтрокаЗуб = "" Тогда
							СтрокаЗуб = Строка(ВыборкаПоЗубам.Зуб);
						Иначе 
							СтрокаЗуб = СтрокаЗуб + ?(ЗначениеЗаполнено(ВыборкаПоЗубам.Зуб), ", ", "") + Строка(ВыборкаПоЗубам.Зуб);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				Если ЭтоСтоматологическиеУслуги Тогда
					ОбластьСтроки.Параметры.Зуб = СтрокаЗуб;
				КонецЕсли;
				ТабличныйДокумент.Вывести(ОбластьСтроки);
				ОбщееИтого    = ОбщееИтого + ОбластьСтроки.Параметры.Сумма;
				ОбщееСуммаНДС = ОбщееСуммаНДС + ОбластьСтроки.Параметры.СуммаНДС;
				
			КонецЦикла;
			
			ОбластьИтог.Параметры.Всего = ОбщееИтого;
			ОбластьИтог.Параметры.ВсегоНДС = ОбщееСуммаНДС;
			ТабличныйДокумент.Вывести(ОбластьИтог);
			
			ОбластьСуммаПрописью.Параметры.ИтоговаяСтрока     = "Всего оказано услуг " + НомерСтроки + ", на сумму: " + ФормированиеПечатныхФорм.СуммаРубКоп(ОбщееИтого,,);// ФормированиеПечатныхФорм.СуммаРубКоп(Прием_Шапка.ОбщееИтогоСоСкидкой, ,);// Формат(ТаблицаУслуги.Итог("Сумма"), "ЧЦ=15; ЧДЦ=2; ЧН=") + " руб." ;
			ОбластьСуммаПрописью.Параметры.СуммаПрописью      = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(ОбщееИтого); // Прием_Шапка.ОбщееИтогоСоСкидкой
			ТабличныйДокумент.Вывести(ОбластьСуммаПрописью);
			
			ТабличныйДокумент.Вывести(ОбластьПодписи);
		КонецЕсли;	
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент; 	
	
КонецФункции     

// Функция генерации печатной формы "АктОВыполненныхРаботах"
//
Функция СформироватьПечатнуюФорму_АктОВыполненныхРаботахБезСумм(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ПФ_MXL_АктОВыполненныхРаботахБезСумм";
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если ТипЗнч(ТекущийДокумент) <> Тип("ДокументСсылка.Прием") Тогда
			Продолжить;
		КонецЕсли;
			
		ЭтоСтоматологическиеУслуги = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(ТекущийДокумент.Сотрудник); 
		НомерСтрокиНачало          = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Прием.Номер КАК Номер,
		|	Прием.Дата КАК Дата,
		|	Прием.СтруктурнаяЕдиница.Организация КАК Организация,
		|	Прием.Контрагент КАК Пациент,
		|	Прием.Сотрудник КАК Врач,
		|	Прием.ПредварительнаяЗаписьНаСледующийПрием КАК ПредварительнаяЗапись,
		|	Прием.СтруктурнаяЕдиница.Организация.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств КАК Валюта,
		|	ЕСТЬNULL(Прием.Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей, 0) КАК ТекущаяМедицинскаяКарта,
		|	Прием.ПолисМедСтрахования КАК ПолисМедСтрахования
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВозвратОтПокупателяЛечение.Зуб КАК Зуб,
		|	ВозвратОтПокупателяЛечение.Номенклатура КАК Номенклатура,
		|	ВозвратОтПокупателяЛечение.КоличествоУпаковок КАК Количество,
		|	ВозвратОтПокупателяЛечение.Ссылка КАК Ссылка,
		|	ВозвратОтПокупателяЛечение.Номенклатура.НоменклатураМедицинскихУслуг.Код КАК НоменклатураКод,
		|	ВозвратОтПокупателяЛечение.Упаковка КАК Упаковка,
		|	ВозвратОтПокупателяЛечение.Номенклатура.Артикул КАК НоменклатураАртикул
		|ПОМЕСТИТЬ ВозвращенныеУслуги
		|ИЗ
		|	Документ.ВозвратОтПокупателя.Лечение КАК ВозвратОтПокупателяЛечение
		|ГДЕ
		|	ВозвратОтПокупателяЛечение.Ссылка.ДокументОснования = &Ссылка
		|	И ВозвратОтПокупателяЛечение.Ссылка.Проведен = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПриемЛечение.Зуб КАК Зуб,
		|	ПриемЛечение.Номенклатура КАК Номенклатура,
		|	СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.Количество, 0)) КАК Количество,
		|	ПриемЛечение.Ссылка КАК Ссылка,
		|	ПриемЛечение.Номенклатура.НоменклатураМедицинскихУслуг.Код КАК НоменклатураКод,
		|	ЕСТЬNULL(ПриемЛечение.Гарантия, 0) КАК Гарантия,
		|	ПриемЛечение.НомерСтроки КАК НомерСтроки,
		|	ПриемЛечение.Рекламация КАК Рекламация,
		|	ВЫРАЗИТЬ(ПриемЛечение.Номенклатура.НаименованиеПолное КАК СТРОКА(200)) КАК Услуга,
		|	ПриемЛечение.Номенклатура.Артикул КАК НоменклатураАртикул
		|ИЗ
		|	Документ.Прием.Лечение КАК ПриемЛечение
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвращенныеУслуги КАК ВозвращенныеУслуги
		|		ПО ПриемЛечение.Номенклатура = ВозвращенныеУслуги.Номенклатура
		|			И ПриемЛечение.Упаковка = ВозвращенныеУслуги.Упаковка
		|ГДЕ
		|	ПриемЛечение.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриемЛечение.Номенклатура,
		|	ПриемЛечение.Зуб,
		|	ПриемЛечение.Ссылка,
		|	ПриемЛечение.НомерСтроки,
		|	ПриемЛечение.Рекламация,
		|	ВЫРАЗИТЬ(ПриемЛечение.Номенклатура.НаименованиеПолное КАК СТРОКА(200)),
		|	ЕСТЬNULL(ПриемЛечение.Гарантия, 0),
		|	ПриемЛечение.Номенклатура.НоменклатураМедицинскихУслуг.Код
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки
		|ИТОГИ
		|	СУММА(Количество),
		|	МАКСИМУМ(Гарантия)
		|ПО
		|	Номенклатура,
		|	Зуб";
		
		Запрос.УстановитьПараметр("Ссылка", ТекущийДокумент);
		ПакетЗапросов 		= Запрос.ВыполнитьПакет();
		
		Прием_Шапка 		= ПакетЗапросов[0].Выбрать();
		ВыборкаУслуги       = ПакетЗапросов[1+1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ТаблицаУслуги	 	= ПакетЗапросов[1+1].Выгрузить();
		
		УказанПолис = ЗначениеЗаполнено(ТекущийДокумент.ПолисМедСтрахования);
		
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_АктОВыполненныхРаботахБезСумм");
		
		//==============================================================ЗАПОЛНЕНИЕ ШАПКИ====================================================================
		Прием_Шапка.Следующий();		
		
		ОбластьМакета                          = Макет.ПолучитьОбласть("Заголовок");
		ТекстЗаголовка                         = "Акт № " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(Прием_Шапка.Номер, Истина, Истина) + " от " +Формат(Прием_Шапка.Дата, "ДЛФ=DD");
		ОбластьМакета.Параметры.ТекстЗаголовка = ТекстЗаголовка;
		ТабличныйДокумент.Вывести(ОбластьМакета);		
		
		ОбластьМакета                                    = Макет.ПолучитьОбласть("Поставщик");
		ПредставлениеПоставщика  = ?(ЗначениеЗаполнено(Прием_Шапка.Организация.ПолноеНаименование), Прием_Шапка.Организация.ПолноеНаименование, Прием_Шапка.Организация.Наименование);		
		ЮрАдрес 										 = Прием_Шапка.Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, "Вид");
		
		Если ЮрАдрес <> Неопределено Тогда
			ПредставлениеПоставщика = ПредставлениеПоставщика + ", Адрес: " + ЮрАдрес.Представление;
		КонецЕсли;
		Если Прием_Шапка.Организация.ИНН <> "" Тогда 
			ПредставлениеПоставщика = ПредставлениеПоставщика + ", ИНН: " + Прием_Шапка.Организация.ИНН;
		КонецЕсли; 	
		
		ОбластьМакета.Параметры.ПредставлениеПоставщика  = ПредставлениеПоставщика;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                    = Макет.ПолучитьОбласть("Врач");
		ОбластьМакета.Параметры.ПредставлениеВрача		 = Прием_Шапка.Врач;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                   = Макет.ПолучитьОбласть("Покупатель");
		ОбластьМакета.Параметры.ПредставлениеПолучателя = Строка(Прием_Шапка.Пациент) + ?(Прием_Шапка.ТекущаяМедицинскаяКарта <> 0, ", мед. карта № " + Строка(Прием_Шапка.ТекущаяМедицинскаяКарта), "");
		
		Если ЗначениеЗаполнено(Прием_Шапка.Пациент.ДатаРожденияКлиента) И ЗначениеЗаполнено(Прием_Шапка.Пациент.ЗаконныйПредставитель)
			И Справочники.Контрагенты.ПолучитьВидимостьЗаконногоПредставителя(Прием_Шапка.Пациент.ДатаРожденияКлиента, Прием_Шапка.Пациент.НедееспособныйГражданин) Тогда
			ОбластьМакета.Параметры.Пациент = "Пациент: ";
			ОбластьМакета.Параметры.ПредставлениеПолучателя = Строка(Прием_Шапка.Пациент.ЗаконныйПредставитель);
			ОбластьМакета.Параметры.ПредставлениеПациента = Строка(Прием_Шапка.Пациент) + ?(Прием_Шапка.ТекущаяМедицинскаяКарта <> 0, ", мед. карта № " + Строка(Прием_Шапка.ТекущаяМедицинскаяКарта), "");
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьМакета); 		
		
		Если УказанПолис Тогда
			ОбластьМакета                                    = Макет.ПолучитьОбласть("Полис");
			ПолисНаименование 								 = Прием_Шапка.ПолисМедСтрахования.СтраховаяКомпания.Наименование + " №" + Прием_Шапка.ПолисМедСтрахования.НомерПолиса + " с " + Формат(Прием_Шапка.ПолисМедСтрахования.ДанаНачала, "ДФ =дд.ММ.гггг") + " по " + Формат(Прием_Шапка.ПолисМедСтрахования.ДатаОкончания, "ДФ =дд.ММ.гггг");  
			ОбластьМакета.Параметры.ПредставлениеПолиса		 = ПолисНаименование;
			ТабличныйДокумент.Вывести(ОбластьМакета); 
		КонецЕсли;
		НомерСтроки = 0;
		//=============================================================ЗАПОЛНЕНИЕ ТАБЛИЦЫ===================================================================		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ОбластьСтроки    = Макет.ПолучитьОбласть("Строка");
		ОбластьПодписи   = Макет.ПолучитьОбласть("Подписи");
		
		// Удалить колонки зуб если это не стом. прием
		Если НЕ ЭтоСтоматологическиеУслуги Тогда
			ОбластьКолонкаЗуб = ОбластьЗаголовок.Область("R1C4:R2C7");
			ОбластьЗаголовок.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
			ОбластьКолонкаЗуб = ОбластьСтроки.Область("R1C4:R1C7");
			ОбластьСтроки.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
		КонецЕсли; 
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		Пока ВыборкаУслуги.Следующий() Цикл
			ОбластьСтроки.Параметры.Заполнить(ВыборкаУслуги);
			ОбластьСтроки.Параметры.Услуга = ВыборкаУслуги.Номенклатура.НаименованиеПолное;
			СтрокаЗуб = "";			
			ОбластьСтроки.Параметры.Количество =  ?(ВыборкаУслуги.Количество = 0, 1, ВыборкаУслуги.Количество);			 
			
			НомерСтроки                         = НомерСтроки + 1;
			ОбластьСтроки.Параметры.НомерСтроки = НомерСтроки;
			
			ВыборкаПоЗубам = ВыборкаУслуги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"");
			Пока ВыборкаПоЗубам.Следующий() Цикл 
				
				Если ЗначениеЗаполнено(ВыборкаПоЗубам.Зуб) и СтрНайти(СтрокаЗуб, ВыборкаПоЗубам.Зуб) = 0 Тогда
					Если СтрокаЗуб = "" Тогда
						СтрокаЗуб = Строка(ВыборкаПоЗубам.Зуб);
					Иначе 
						СтрокаЗуб = СтрокаЗуб + ?(ЗначениеЗаполнено(ВыборкаПоЗубам.Зуб), ", ", "") + Строка(ВыборкаПоЗубам.Зуб);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Если ЭтоСтоматологическиеУслуги Тогда
				ОбластьСтроки.Параметры.Зуб = СтрокаЗуб;
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьСтроки);
			
		КонецЦикла; 		
		
		ТабличныйДокумент.Вывести(ОбластьПодписи); 			
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент; 	
	
КонецФункции 

// Функция генерации печатной формы "СправкаВНалоговую"
//
Функция СформироватьПечатнуюФорму_СправкаВНалоговую(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ПФ_MXL_Справка";
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВозвратОтПокупателяЛечение.Номенклатура КАК Номенклатура,
	|	ВозвратОтПокупателяЛечение.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВозвратОтПокупателяЛечение.Всего КАК Всего
	|ПОМЕСТИТЬ ВозвращенныеУслуги
	|ИЗ
	|	Документ.ВозвратОтПокупателя.Лечение КАК ВозвратОтПокупателяЛечение
	|ГДЕ
	|	ВозвратОтПокупателяЛечение.Ссылка.ДокументОснования В(&МассивДокументов)
	|	И ВозвратОтПокупателяЛечение.Ссылка.Проведен = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриемУчтенныеАвансы.ДокументАванса КАК ДокументАванса
	|ПОМЕСТИТЬ ВТАвансы
	|ИЗ
	|	Документ.Прием.УчтенныеАвансы КАК ПриемУчтенныеАвансы
	|ГДЕ
	|	ПриемУчтенныеАвансы.Ссылка В (&МассивДокументов)
	|	И ((ВЫРАЗИТЬ(ПриемУчтенныеАвансы.ДокументАванса КАК Документ.ПланЛечения)) <> ЗНАЧЕНИЕ(Документ.ПланЛечения.ПустаяСсылка)
	|			ИЛИ (ВЫРАЗИТЬ(ПриемУчтенныеАвансы.ДокументАванса КАК Документ.НарядЗаказ)) <> ЗНАЧЕНИЕ(Документ.НарядЗаказ.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.КоличествоУпаковок, 0)) КАК Количество,
	|	ВЫБОР
	|		КОГДА ПриемЛечение.КодУслуги = 0
	|			ТОГДА ПриемЛечение.Номенклатура.КодУслуги
	|		ИНАЧЕ ПриемЛечение.КодУслуги
	|	КОНЕЦ КАК КодУслуги,
	|	ПриемЛечение.Номенклатура КАК Номенклатура,
	|	СУММА(ПриемЛечение.Всего - ЕСТЬNULL(ВозвращенныеУслуги.Всего, 0)) КАК Всего
	|ПОМЕСТИТЬ ОказанныеУсулгиСУчетомВозвращенных
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвращенныеУслуги КАК ВозвращенныеУслуги
	|		ПО ПриемЛечение.Номенклатура = ВозвращенныеУслуги.Номенклатура
	|ГДЕ
	|	ПриемЛечение.Ссылка В(&МассивДокументов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриемЛечение.Номенклатура,
	|	ВЫБОР
	|		КОГДА ПриемЛечение.КодУслуги = 0
	|			ТОГДА ПриемЛечение.Номенклатура.КодУслуги
	|		ИНАЧЕ ПриемЛечение.КодУслуги
	|	КОНЕЦ
	|
	|ИМЕЮЩИЕ
	|	СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.КоличествоУпаковок, 0)) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Прием.Ссылка КАК Ссылка,
	|	Прием.Номер КАК Номер,
	|	Прием.Дата КАК ДатаОплаты,
	|	Прием.Контрагент КАК ФИО_Пациента,
	|	Прием.Контрагент.ТекущаяМедицинскаяКарта.Код КАК КодПациента,
	|	Прием.Сотрудник.Наименование КАК ФИО_Налогоплательщика,
	|	Прием.СтруктурнаяЕдиница.Организация.ПолноеНаименование КАК НаименованиеОрганизации,
	|	Прием.СтруктурнаяЕдиница.Организация.ИНН КАК ИНН_Организации,
	|	Прием.СтруктурнаяЕдиница.Организация.СерияНомер КАК СерияНомер,
	|	Прием.СтруктурнаяЕдиница.Организация.ДатаВыдачиЛицензии КАК ДатаВыдачиЛицензии,
	|	Прием.СтруктурнаяЕдиница.Организация.СрокДействияЛицензии КАК СрокДействияЛицензии,
	|	Прием.СтруктурнаяЕдиница.Организация.КемВыданаЛицензия КАК КемВыданаЛицензия
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка В(&МассивДокументов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаОплаты УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(Прием.СуммаДокумента) КАК СуммаДокумента,
	|	СУММА(Прием.СуммаОплачено) КАК СуммаОплачено
	|ИЗ
	|	Документ.Прием КАК Прием
	|ГДЕ
	|	Прием.Ссылка В(&МассивДокументов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОрганизацииКонтактнаяИнформация.Тип КАК Тип,
	|	ОрганизацииКонтактнаяИнформация.Вид КАК Вид,
	|	ОрганизацииКонтактнаяИнформация.Ссылка КАК Ссылка,
	|	ОрганизацииКонтактнаяИнформация.Представление КАК Представление
	|ИЗ
	|	Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
	|ГДЕ
	|	ОрганизацииКонтактнаяИнформация.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОтветственныеЛицаСрезПоследних.Сотрудник КАК ФИО_Сотрудника,
	|	ОтветственныеЛицаСрезПоследних.Должность КАК Должность
	|ИЗ
	|	РегистрСведений.ОтветственныеЛица.СрезПоследних КАК ОтветственныеЛицаСрезПоследних
	|ГДЕ
	|	ОтветственныеЛицаСрезПоследних.Организация = &Ссылка
	|	И ОтветственныеЛицаСрезПоследних.ТипОтветственногоЛица = &Бухгалтер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВЫБОР
	|			КОГДА ОказанныеУсулгиСУчетомВозвращенных.КодУслуги = 1
	|				ТОГДА ОказанныеУсулгиСУчетомВозвращенных.Всего
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаКодУслуги1,
	|	СУММА(ВЫБОР
	|			КОГДА ОказанныеУсулгиСУчетомВозвращенных.КодУслуги = 2
	|				ТОГДА ОказанныеУсулгиСУчетомВозвращенных.Всего
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаКодУслуги2
	|ИЗ
	|	ОказанныеУсулгиСУчетомВозвращенных КАК ОказанныеУсулгиСУчетомВозвращенных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Контрагент КАК ФИО_Налогоплательщика,
	|	ВложенныйЗапрос.КонтрагентИНН КАК ИНН_Налогоплательщика
	|ИЗ
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|		ВЫБОР
	|			КОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|				ТОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель
	|			ИНАЧЕ ПоступлениеДенежныхСредств.Контрагент
	|		КОНЕЦ КАК Контрагент,
	|		ВЫБОР
	|			КОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|				ТОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель.ИНН
	|			ИНАЧЕ ПоступлениеДенежныхСредств.Контрагент.ИНН
	|		КОНЕЦ КАК КонтрагентИНН
	|	ИЗ
	|		Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|	ГДЕ
	|		ПоступлениеДенежныхСредств.РасшифровкаПлатежа.ДокументОснования В(&МассивДокументов)
	|		И ПоступлениеДенежныхСредств.Проведен = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ ПЕРВЫЕ 1
	|		СписаниеДенежныхСредств.Контрагент,
	|		СписаниеДенежныхСредств.Контрагент.ИНН
	|	ИЗ
	|		Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|	ГДЕ
	|		СписаниеДенежныхСредств.РасшифровкаПлатежа.ДокументОснования В(&МассивДокументов)
	|		И СписаниеДенежныхСредств.Проведен = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|				ТОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель
	|			ИНАЧЕ ПоступлениеДенежныхСредств.Контрагент
	|		КОНЕЦ,
	|		ВЫБОР
	|			КОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|				ТОГДА ПоступлениеДенежныхСредств.Контрагент.ЗаконныйПредставитель.ИНН
	|			ИНАЧЕ ПоступлениеДенежныхСредств.Контрагент.ИНН
	|		КОНЕЦ
	|	ИЗ
	|		Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|	ГДЕ
	|		ПоступлениеДенежныхСредств.Проведен
	|		И ПоступлениеДенежныхСредств.РасшифровкаПлатежа.ДокументАванса В
	|				(ВЫБРАТЬ
	|					ВТАвансы.ДокументАванса КАК ДокументАванса
	|				ИЗ
	|					ВТАвансы КАК ВТАвансы)) КАК ВложенныйЗапрос
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВложенныйЗапрос.Дата КАК Дата
	|ИЗ
	|	(ВЫБРАТЬ
	|		НАЧАЛОПЕРИОДА(ПоступлениеДенежныхСредств.Дата, ДЕНЬ) КАК Дата
	|	ИЗ
	|		Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|	ГДЕ
	|		ПоступлениеДенежныхСредств.РасшифровкаПлатежа.ДокументОснования В(&МассивДокументов)
	|		И ПоступлениеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
	|		И ПоступлениеДенежныхСредств.Проведен = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НАЧАЛОПЕРИОДА(СписаниеДенежныхСредств.Дата, ДЕНЬ)
	|	ИЗ
	|		Документ.СписаниеДенежныхСредств КАК СписаниеДенежныхСредств
	|	ГДЕ
	|		СписаниеДенежныхСредств.РасшифровкаПлатежа.ДокументОснования В(&МассивДокументов)
	|		И СписаниеДенежныхСредств.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОпераций.ОплатаОтКлиента)
	|		И СписаниеДенежныхСредств.Проведен = ИСТИНА
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НАЧАЛОПЕРИОДА(ПоступлениеДенежныхСредств.Дата, ДЕНЬ)
	|	ИЗ
	|		Документ.ПоступлениеДенежныхСредств КАК ПоступлениеДенежныхСредств
	|	ГДЕ
	|		ПоступлениеДенежныхСредств.Проведен
	|		И ПоступлениеДенежныхСредств.РасшифровкаПлатежа.ДокументАванса В
	|				(ВЫБРАТЬ
	|					ВТАвансы.ДокументАванса КАК ДокументАванса
	|				ИЗ
	|					ВТАвансы КАК ВТАвансы)) КАК ВложенныйЗапрос
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата");
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	Запрос.УстановитьПараметр("Ссылка"			, МассивОбъектов[0].СтруктурнаяЕдиница.Организация);
	Запрос.УстановитьПараметр("Бухгалтер"	    , Перечисления.ТипыОтветственныхЛиц.ГлавныйБухгалтер);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	Результат 	  	= ПакетЗапросов[0+3].Выбрать();
	ТЗ 		  	  	= ПакетЗапросов[1+3].Выгрузить();
	КИ 		  	 	= ПакетЗапросов[2+3].Выгрузить();
	Бухгалтер  		= ПакетЗапросов[3+3].Выбрать();
	СуммаКодУслуг	= ПакетЗапросов[4+3].Выбрать();
	ДанныеПациента	= ПакетЗапросов[5+3].Выбрать();
	ДанныеОплат     = ПакетЗапросов[6+3].Выгрузить();
	
	Для Каждого Док Из МассивОбъектов Цикл
		
		Если ТипЗнч(Док) = Тип("ДокументСсылка.СправкаВНалоговую") Тогда
			НомерДок = Док.Номер;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Следующий();
	ДанныеПациента.Следующий();
	ОбластьМакета = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_Справка").ПолучитьОбласть("ОбластьМакета");
	ОбластьМакета.Параметры.Заполнить(Результат);
	ОбластьМакета.Параметры.Заполнить(ДанныеПациента);
	
	СуммаВсехКодовУслуг = 0;
	Если СуммаКодУслуг.Следующий() Тогда
		ОбластьМакета.Параметры.СуммаКодУслуги1 = Формат(СуммаКодУслуг.СуммаКодУслуги1, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + " руб.";
		ОбластьМакета.Параметры.СуммаКодУслуги2 = Формат(СуммаКодУслуг.СуммаКодУслуги2, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + " руб.";
		СуммаВсехКодовУслуг = ?(ТипЗнч(СуммаКодУслуг.СуммаКодУслуги1) = Тип("Число"), СуммаВсехКодовУслуг + СуммаКодУслуг.СуммаКодУслуги1, СуммаВсехКодовУслуг);
		СуммаВсехКодовУслуг = ?(ТипЗнч(СуммаКодУслуг.СуммаКодУслуги2) = Тип("Число"), СуммаВсехКодовУслуг + СуммаКодУслуг.СуммаКодУслуги2, СуммаВсехКодовУслуг); 
	КонецЕсли;
	    	
	СуммаПрописью = ФормированиеПечатныхФорм.СформироватьСуммуПрописью(СуммаВсехКодовУслуг);// ТЗ[0].СуммаДокумента);
	
	ОбластьМакета.Параметры.СтоимостьУслуг 		= СуммаПрописью;// Формат(ТЗ[0].СуммаДокумента, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + " руб.";
	ДатаОплаты = СформироватьДатуОплаты(ДанныеОплат);
	ОбластьМакета.Параметры.ДатаОплаты			= ДатаОплаты;
	ОбластьМакета.Параметры.ДатаТекущая 	   	= Формат(ТекущаяДата(), "ДЛФ=DD");
	ОбластьМакета.Параметры.Номер 			   	= ФормированиеПечатныхФорм.ПолучитьНомерНаПечатьПосле2011г(НомерДок, Истина, Истина);
	ОбластьМакета.Параметры.СуммаПрописью 	   	= СуммаПрописью;
	ОбластьМакета.Параметры.ДатаВыдачиЛицензии 	= Формат(Результат.ДатаВыдачиЛицензии, "ДЛФ=DD");
	
	Если Бухгалтер.Следующий() Тогда
		
		ОбластьМакета.Параметры.ФИО_Сотрудника = Бухгалтер.ФИО_Сотрудника;
		ОбластьМакета.Параметры.Должность = Бухгалтер.Должность;
		
	КонецЕсли;
	
	// Если СуммаКодУслуг.Следующий() Тогда
	//	ОбластьМакета.Параметры.СуммаКодУслуги1 = Формат(СуммаКодУслуг.СуммаКодУслуги1, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + " руб.";
	//	ОбластьМакета.Параметры.СуммаКодУслуги2 = Формат(СуммаКодУслуг.СуммаКодУслуги2, "ЧЦ=15; ЧДЦ=2; ЧН=0,00") + " руб.";
	// КонецЕсли;
	
	Для Каждого Элемент Из КИ Цикл
		
		Если Элемент.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации Тогда
			ОбластьМакета.Параметры.НомерТелефона = Элемент.Представление;
		КонецЕсли;
		
		Если Элемент.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации Тогда
			ОбластьМакета.Параметры.АдресОрганизации = Элемент.Представление;
		КонецЕсли;
		
	КонецЦикла;
	
	ТабличныйДокумент.Вывести(ОбластьМакета);
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Функция генерации печатной формы "ТалонАмбулаторногоПациента"
//
Функция СформироватьПечатнуюФорму_ТалонАмбулаторногоПациента(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати	= "ПараметрыПечати_ТалонАмбулаторногоПациента";
	ТабличныйДокумент.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.ОтображатьСетку		= Ложь;
	ТабличныйДокумент.ОтображатьЗаголовки	= Ложь;
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_ТалонАмбулаторногоПациента");
	
	МассивДокументовПечати = Новый Массив;	
	Если ТипЗнч(МассивОбъектов) <> Тип("Массив") Тогда
		МассивДокументовПечати.Добавить(МассивОбъектов);
	Иначе
		МассивДокументовПечати = МассивОбъектов;
	Конецесли; 
	
	ПервыйДокумент = Истина;
	ДанныеПациента = Новый Структура;
	
	Для Каждого Документ Из МассивДокументовПечати Цикл
		
		Если Не ПервыйДокумент Тогда
			// Документы нужно выводить на разных страницах
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		Иначе 
			ПервыйДокумент = Ложь;
		КонецЕсли;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		ДанныеДокумента = ПолучитьДанныеДокумента(Документ);
		Макет.Параметры.Заполнить(ДанныеДокумента);
		
		ВыделитьЯчейку("ВидОплаты"			, ДанныеДокумента.ВидОплаты			, Макет);
		ВыделитьЯчейку("ЦельОбращения"		, ДанныеДокумента.ЦельОбращения		, Макет);
		ВыделитьЯчейку("РезультатОбращения"	, ДанныеДокумента.РезультатОбращения, Макет);
		ВыделитьЯчейку("ЦельПосещения"		, ДанныеДокумента.ЦельПосещения		, Макет);
		ВыделитьЯчейку("Пол"				, ДанныеДокумента.Пол				, Макет);
		ВыделитьЯчейку("Занятость"			, ДанныеДокумента.Занятость			, Макет);
		ВыделитьЯчейку("ЗаконченныйСлучай"	, ДанныеДокумента.ЗаконченныйСлучай	, Макет);
		ВыделитьЯчейку("ВидОбращения"		, ДанныеДокумента.ВидОбращения		, Макет);
		
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ЛицеваяСторона"));
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();	
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ОборотнаяСторона1"));
		ТабЛечение = ПолучитьСписокОказанныхУслугСУчетомВозвращенных(Документ); // Документ.Лечение;
		МедицинскаяУслуга1 = "";
		Если ТабЛечение.Количество() <> 0 Тогда
			МедицинскаяУслуга1 			= ТабЛечение[0].Номенклатура;
			Макет.Параметры.КодУслуги1  = МедицинскаяУслуга1.Артикул;
		КонецЕсли;	
		Макет.Параметры.МедицинскаяУслуга1 = МедицинскаяУслуга1;
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("СтрокаУслуга1"));
		
		Если ТабЛечение.Количество() > 1 Тогда
			Для Ном = 1 По ТабЛечение.Количество() - 1 Цикл
				МедицинскаяУслуга2					= ТабЛечение[Ном].Номенклатура; 
				Макет.Параметры.МедицинскаяУслуга2  = МедицинскаяУслуга2;
				Макет.Параметры.КодУслуги2  		= МедицинскаяУслуга2.Артикул;
				ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("СтрокаУслуга2"));
			КонецЦикла;
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ОборотнаяСторона2"));
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("Рецепты"));
		ТабличныйДокумент.Вывести(Макет.ПолучитьОбласть("ОбратнаяСторонаПродолжение"));
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
		ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, Документ.Ссылка
		);
	КонецЦикла;	
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Функция генерации печатной формы "ГарантийныйТалон"
//
Функция СформироватьПечатнуюФорму_ГарантийныйТалон(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ПФ_MXL_ГарантийныйТалон";
	
	// МассивОбъектов = ОтСортироватьМассивДокументов(МассивОбъектов);
	УстановитьПривилегированныйРежим(Истина);
	
	НесколькоВрачейВОдномПриеме = Константы.НесколькоВрачейВОдномПриеме.Получить();	
	
	КоличествоОбъектов = МассивОбъектов.Количество();
	ИндексОбъекта	   = 0;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		ЭтоСтоматологическиеУслуги = ОбщегоНазначенияСтоматология.ПолучитьПризнакОказанияСтоматологическихУслуг(ТекущийДокумент.Сотрудник); 
		НомерСтрокиНачало          = ТабличныйДокумент.ВысотаТаблицы + 1;
		ПакетЗапросов              = ПолучитьРезультатЗапроса(ТекущийДокумент);
		
		Прием 				= ПакетЗапросов[0].Выбрать();
		ТаблицаОплаты		= ПакетЗапросов[2+1].Выгрузить();
		ВыборкаЗаписи    	= ПакетЗапросов[3+1].Выбрать();
		ВыборкаПоУслугам 	= ПакетЗапросов[4+1].Выбрать();
		ТаблицаАвансов 		= ПакетЗапросов[5+1].Выгрузить();
		ТаблицаЛицевыеСчета = ПакетЗапросов[6+1].Выгрузить();   
		ТаблицаВозврата		= ПакетЗапросов[8].Выгрузить();
				
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_ГарантийныйТалон");
		
		//==============================================================ЗАПОЛНЕНИЕ ШАПКИ====================================================================
		Прием.Следующий();
		
		Область_Заголовок 	= Макет.ПолучитьОбласть("Заголовок");
		Область_Организация = Макет.ПолучитьОбласть("Организация");
		Область_Врач 		= Макет.ПолучитьОбласть("Врач");
		Область_Пациент 	= Макет.ПолучитьОбласть("Пациент");                                     
		Область_Диагноз 	= Макет.ПолучитьОбласть("Диагноз");
		
		НомерИДатаДокумента = "№ " + ФормированиеПечатныхФорм.ПолучитьНомерНаПечать(Прием.Номер, Прием.Организация.Префикс) + " от " + Формат(Прием.Дата, "ДЛФ=DD");
		
		Если ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.Прием") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Гарантийный талон приема " + НомерИДатаДокумента;
		ИначеЕсли ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.ПланЛечения") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Гарантийный талон плана лечения " + НомерИДатаДокумента;
		ИначеЕсли ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.НарядЗаказ") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Гарантийный талон наряд-заказа " + НомерИДатаДокумента;
		ИначеЕсли ТипЗнч(ТекущийДокумент) = Тип("ДокументСсылка.Реализация") Тогда
			Область_Заголовок.Параметры.ТекстЗаголовка			= "Гарантийный талон реализации " + НомерИДатаДокумента;
		КонецЕсли;
		
		Область_Организация.Параметры.ПредставлениеОрганизации 	= ?(ЗначениеЗаполнено(Прием.Организация.ПолноеНаименование), Прием.Организация.ПолноеНаименование, Прием.Организация.Наименование);
		Область_Врач.Параметры.ПредставлениеВрача 				= Прием.Врач;
		Область_Пациент.Параметры.ПредставлениеПациента 		= СокрЛП(Прием.Пациент) + ?(ЗначениеЗаполнено(Прием.Пациент.ДатаРожденияКлиента),", дата рождения: " + Формат(Прием.Пациент.ДатаРожденияКлиента, "ДФ=dd.MM.yyyy"), "") + ?(ЗначениеЗаполнено(Прием.Пациент.Телефон), ", тел. " + Прием.Пациент.Телефон, "");
		
		Если ЗначениеЗаполнено(Прием.Диагноз) Тогда
			
			Если ТипЗнч(Прием.Диагноз) = Тип("СправочникСсылка.Диагнозы")
				И ЗначениеЗаполнено(Прием.Диагноз.Наименование) Тогда
				Область_Диагноз.Параметры.Диагноз = Прием.Диагноз.Наименование;
			Иначе
				Область_Диагноз.Параметры.Диагноз = Строка(Прием.Диагноз);		
			КонецЕсли;
			
		Иначе
			Область_Диагноз.Параметры.Диагноз = "";		
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(Область_Заголовок);
		ТабличныйДокумент.Вывести(Область_Организация);
		Если НЕ НесколькоВрачейВОдномПриеме Тогда 
			ТабличныйДокумент.Вывести(Область_Врач);
		КонецЕсли;
		ТабличныйДокумент.Вывести(Область_Пациент);
		Если ЗначениеЗаполнено(Прием.Диагноз) Тогда
			ТабличныйДокумент.Вывести(Область_Диагноз);
		КонецЕсли;
	КонецЦикла;
	
	//=============================================================ЗАПОЛНЕНИЕ ГАРАНТИИ===================================================================
	ОбластьШапка  = Макет.ПолучитьОбласть("ШапкаГарантия");
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаГарантия");
	Если НЕ ЭтоСтоматологическиеУслуги Тогда
		ОбластьКолонкаЗуб = ОбластьШапка.Область("R1C3:R2C5");
		ОбластьШапка.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
		ОбластьКолонкаЗуб = ОбластьСтрока.Область("R1C3:R1C5");
		ОбластьСтрока.Удалитьобласть(ОбластьКолонкаЗуб,ТипСмещенияТабличногоДокумента.ПоГоризонтали);
	КонецЕсли;
	//
	ВыборкаПоУслугам.Сбросить();
	НомерСтроки = 0;
	Пока ВыборкаПоУслугам.Следующий() Цикл				
		Если ТипЗнч(ВыборкаПоУслугам.Услуга) = Тип("СправочникСсылка.Номенклатура") И ВыборкаПоУслугам.Гарантия <> NULL И ВыборкаПоУслугам.Гарантия > 0 Тогда
			НомерСтроки = НомерСтроки + 1;
			Если НомерСтроки = 1 Тогда
				ТабличныйДокумент.Вывести(ОбластьШапка);	
			КонецЕсли;				
			ОбластьСтрока.Параметры.Заполнить(ВыборкаПоУслугам);
			ОбластьСтрока.Параметры.Услуга        = ВыборкаПоУслугам.Услуга.НаименованиеПолное;
			ОбластьСтрока.Параметры.НомерСтроки   = НомерСтроки;
			ОбластьСтрока.Параметры.ГарантияС     = Прием.Дата;
			ОбластьСтрока.Параметры.ГарантияДо    = ДобавитьМесяц(Прием.Дата, ВыборкаПоУслугам.Гарантия);
			ТабличныйДокумент.Вывести(ОбластьСтрока);						
		КонецЕсли;					
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если КоличествоОбъектов > 0 Тогда
		ОбластьМакета = Макет.ПолучитьОбласть("Комментарий");
		ОбластьМакета.Параметры.Комментарий = ?(ЗначениеЗаполнено(ТекущийДокумент), ТекущийДокумент.Комментарий, "");
		ТабличныйДокумент.Вывести(ОбластьМакета);
	КонецЕсли;
	
	Область_Подписи = Макет.ПолучитьОбласть("Подписи");
	ТабличныйДокумент.Вывести(Область_Подписи);
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;

КонецФункции // ПечатнаяФорма()

// Функция генерации печатной формы "КонсультацияВрача"
//
Функция СформироватьПечатнуюФорму_КонсультацияВрача(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	ТабличныйДокумент                      = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_ПФ_MXL_КонсультацияВрача";
	ТабличныйДокумент.РазмерСтраницы       = "A4";
	
	ПервыйДокумент = Истина;
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		Если Не ПервыйДокумент Тогда
			// Документы нужно выводить на разных страницах
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		Иначе 
			ПервыйДокумент = Ложь;
		КонецЕсли;
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Прием.Дата КАК Дата,
		|	Прием.Контрагент.Наименование КАК КонтрагентНаименование,
		|	ЕСТЬNULL(Прием.Контрагент.ТекущаяМедицинскаяКарта.КодБезНулей, 0) КАК КодМедКартыБезНулей,
		|	Прием.Сотрудник.Наименование КАК СотрудникНаименование,
		|	Прием.Сотрудник.Должность КАК СотрудникДолжность
		|ИЗ
		|	Документ.Прием КАК Прием
		|ГДЕ
		|	Прием.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВЫБОР
		|		КОГДА Профосмотры.Специализация.Наименование = ""Ортодонтия""
		|			ТОГДА ""Ортодонт:""
		|		КОГДА Профосмотры.Специализация.Наименование = ""Гигиена""
		|			ТОГДА ""Гигиенист:""
		|		КОГДА Профосмотры.Специализация.Наименование = ""Терапия""
		|			ТОГДА ""Терапевт:""
		|		КОГДА Профосмотры.Специализация.Наименование = ""Хирургия""
		|			ТОГДА ""Хирург:""
		|		КОГДА Профосмотры.Специализация.Наименование = ""Ортопедия""
		|			ТОГДА ""Ортопед:""
		|		КОГДА Профосмотры.Специализация.Наименование = ""Парадонтология""
		|			ТОГДА ""Пародонтолог:""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК Специализация,
		|	Профосмотры.Сотрудник.Наименование КАК Сотрудник
		|ИЗ
		|	РегистрСведений.Профосмотры КАК Профосмотры
		|ГДЕ
		|	Профосмотры.Прием = &Ссылка
		|	И Профосмотры.ВидОсмотра = ЗНАЧЕНИЕ(Перечисление.ВидыОсмотров.Направление)
		|	И Профосмотры.Специализация <> ЗНАЧЕНИЕ(Справочник.Специализации.ПустаяСсылка)
		|	И Профосмотры.Сотрудник.Ссылка <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Профосмотры.Специализация.Наименование
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПриемЛечение.Зуб КАК НомерЗуба,
		|	ПриемЛечение.Количество КАК Количество,
		|	ПриемЛечение.Номенклатура.Представление КАК Услуга,
		|	ПриемЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг КАК КодУслуги,
		|	ПриемЛечение.Сумма КАК Стоимость
		|ИЗ
		|	Документ.Прием.Лечение КАК ПриемЛечение
		|ГДЕ
		|	ПриемЛечение.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриемЛечение.Зуб,
		|	ПриемЛечение.Количество,
		|	ПриемЛечение.Номенклатура.Представление,
		|	ПриемЛечение.Номенклатура.КодНоменклатурыМедицинскиУслуг,
		|	ПриемЛечение.Сумма"); 
		
		Запрос.УстановитьПараметр("Ссылка", ТекущийДокумент);  
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		ШапкаПечатнойФормы = РезультатЗапроса[0].Выбрать(); 		 
		Лечение = РезультатЗапроса[2].Выбрать();
		
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.Прием.ПФ_MXL_КонсультацияВрача");
		ШапкаПечатнойФормы.Следующий();
		ОбластьМакета = Макет.ПолучитьОбласть("Пациент"); 
		ОбластьМакета.Параметры.Пациент = ШапкаПечатнойФормы.КонтрагентНаименование;
		ОбластьМакета.Параметры.ДатаПриема = Формат(ШапкаПечатнойФормы.Дата, "ДФ=dd.MM.yyyy"); 
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Врач"); 
		ОбластьМакета.Параметры.Врач = ШапкаПечатнойФормы.СотрудникНаименование; 
		ОбластьМакета.Параметры.НомерКарты = ШапкаПечатнойФормы.КодМедКартыБезНулей;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ТаблицаОбследований = РегистрыСведений.ЗначенияПараметровОбследований.ПолучитьМенеджераВременнойТаблицыОбследованияСтоматолога(ТекущийДокумент.Контрагент, ТекущийДокумент,, Истина);
		Если ЗначениеЗаполнено(ТаблицаОбследований) Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("ШапкаОбследования");
			ТабличныйДокумент.Вывести(ОбластьМакета);
			ОбластьМакета = Макет.ПолучитьОбласть("Обследование");
			Для Каждого СтрокаТ Из ТаблицаОбследований Цикл 			
				// Используются только реквизиты дневника
				//Если Не СтрокаТ.ЭтоТитульныйРеквизит = Истина Тогда
				//	Продолжить;
				//КонецЕсли;
				ОбластьМакета.Параметры.ТекстИмяРеквизита = СтрокаТ.РеквизитНаименование; 			            
				ОбластьМакета.Параметры.ТекстЗначениеРеквизита = СтрокаТ.РеквизитЗначение; 
				ТабличныйДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
		КонецЕсли; 
		
		Если Не РезультатЗапроса[1].Пустой() Тогда
			Направления = РезультатЗапроса[1].Выбрать();
			ОбластьМакета = Макет.ПолучитьОбласть("НаправленияЗаголовок");
			ТабличныйДокумент.Вывести(ОбластьМакета); 
			ОбластьМакета = Макет.ПолучитьОбласть("Направления");
			Пока Направления.Следующий() Цикл 
				ОбластьМакета.Параметры.Специализация = Направления.Специализация;
				ОбластьМакета.Параметры.ПредставлениеНаправления = Направления.Сотрудник;
				ТабличныйДокумент.Вывести(ОбластьМакета);				
			КонецЦикла;	
		КонецЕсли;
		ОбластьМакета = Макет.ПолучитьОбласть("ШапкаТаблицы"); 			
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("СтрокаТаблицы");
	
		Пока Лечение.Следующий() Цикл 
			ОбластьМакета.Параметры.Заполнить(Лечение); 
			ТабличныйДокумент.Вывести(ОбластьМакета);
		КонецЦикла;         
		
		ОбластьМакета = Макет.ПолучитьОбласть("Подпись"); 
		ОбластьМакета.Параметры.ПодписьВрача = Строка(ШапкаПечатнойФормы.СотрудникДолжность) + " " + ШапкаПечатнойФормы.СотрудникНаименование;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		//ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла; 
	
	ТабличныйДокумент.АвтоМасштаб = Истина;	
	Возврат ТабличныйДокумент;
	
КонецФункции 

// Функция получения списка оказанынх услуг с учетом возвращённых.
//
Функция ПолучитьСписокОказанныхУслугСУчетомВозвращенных(Документ)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВозвратОтПокупателяЛечение.Номенклатура,
	|	ВозвратОтПокупателяЛечение.КоличествоУпаковок
	|ПОМЕСТИТЬ ВозвращенныеУслуги
	|ИЗ
	|	Документ.ВозвратОтПокупателя.Лечение КАК ВозвратОтПокупателяЛечение
	|ГДЕ
	|	ВозвратОтПокупателяЛечение.Ссылка.ДокументОснования = &Ссылка
	|	И ВозвратОтПокупателяЛечение.Ссылка.Проведен = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПриемЛечение.Номенклатура,
	|	СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.КоличествоУпаковок, 0)) КАК КоличествоУпаковок,
	|	ПриемЛечение.КодУслуги,
	|	ПриемЛечение.Номенклатура.Артикул КАК Артикул
	|ИЗ
	|	Документ.Прием.Лечение КАК ПриемЛечение
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвращенныеУслуги КАК ВозвращенныеУслуги
	|		ПО ПриемЛечение.Номенклатура = ВозвращенныеУслуги.Номенклатура
	|ГДЕ
	|	ПриемЛечение.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриемЛечение.Номенклатура,
	|	ПриемЛечение.КодУслуги,
	|	ПриемЛечение.Номенклатура.Артикул
	|
	|ИМЕЮЩИЕ
	|	СУММА(ПриемЛечение.КоличествоУпаковок - ЕСТЬNULL(ВозвращенныеУслуги.КоличествоУпаковок, 0)) > 0");
	
	Запрос.УстановитьПараметр("Ссылка", Документ);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

